    <JadeMethod name="unSelectTiToDoTask" id="01d82d2b-27c6-4606-9c4a-ca2dc8b73820">
        <source>unSelectTiToDoTask( _tiToDoTask : CM_TiToDoTask; _removeFromSelected : Boolean ):Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 September 2015	cnwndl1	Initial creation	Par 36993

*/

vars

	rowIndex : Integer;
	invalid : Boolean;
	str : String;

begin

	if _removeFromSelected then
		self.tblSelected.findObjectInRow( _tiToDoTask, rowIndex );
		if rowIndex &gt; self.tblSelected.fixedRows then
			self.tblSelected.removeItem( rowIndex );
		endif;
	endif;
	rowIndex := 0;
	
	if _tiToDoTask = null or _tiToDoTask.myTrackedItem = null then
		return false;
	endif;
	
	on Exception do app.handleDeletedObject( exception, _tiToDoTask.myTrackedItem, invalid );
	str := _tiToDoTask.myTrackedItem.id;
	if invalid then
		return false;
	endif;

	self.tblAvailable.findObjectInRow( _tiToDoTask, rowIndex );
	if rowIndex &lt; self.tblAvailable.fixedRows then
		rowIndex := self.tblAvailable.addItem( str );
		self.tblAvailable.accessRow( rowIndex ).itemObject := _tiToDoTask;
		return true;
	endif;
	
	return false;

epilog

	self.resetColumnHeadings();

end;</source>
        <Parameter name="_tiToDoTask" type="CM_TiToDoTask"/>
        <Parameter name="_removeFromSelected" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
