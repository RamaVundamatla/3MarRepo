    <JadeMethod name="pxyCreateUpdateProxy" id="4df6ee0d-d5c0-4456-9b9d-28bf547e85d4">
        <source>pxyCreateUpdateProxy(): SelfType;
// ---------------------------------------------------------------------------
// Created:     22 June 2009 by concms1:1
// Purpose:     CCMS SFW 1047 - Totals Only Lists
// Parameters:  None
// Returns:     Nothing
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 20/04/2011	cnwmh5		PAR #27401 - Add code to handle prossible exceptions occurring when
//							trying to create the proxy
// ---------------------------------------------------------------------------
vars
	proxy	:SelfType;
	completedOK		: Boolean;
begin
	proxy := inheritMethod();
		
	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return proxy;
epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete proxy;
	endif;

end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="19bac821-668a-4c37-a926-b3683f5d8001">
        <updating/>
        <source>setForCreate(_proxy :CM_LaneDevice; _lane :CM_LaneController )updating;
// ---------------------------------------------------------------------------
// Created:     22 June 2009 by concms1:1
// Purpose:     CCMS SFW 1047 - Totals Only Lists
// Parameters:  None
// Returns:     Nothing
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	self.setForUpdate (_proxy);
	
	self.myLaneController := _lane;
epilog

end;</source>
        <Parameter name="_proxy" type="CM_LaneDevice"/>
        <Parameter name="_lane" type="CM_LaneController"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="ca416aaf-bfaf-4694-abbd-e56670aa1bcb">
        <updating/>
