    <JadeMethod name="getGateLaneControllerFrmLaneID" id="f71479dc-6889-4232-ac48-d149406040cf">
        <source>getGateLaneControllerFrmLaneID(_laneID : String) : CM_GateAreaLaneController;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 August 2023	jlier1	Initial creation 59732

*/

vars
	gate : CM_Gate;
	gateArea : CM_GateArea;
	gridController : CM_GridController;
	kiosk : CM_Kiosk;
begin

	if _laneID = null then
		return null;
	endif;

	foreach gate in self.allGates discreteLock do
		gateArea := gate.getFirstAGate_IN();
		if gateArea &lt;&gt; null and gateArea.laneCount &gt; 0 then
			gridController := gateArea.getLaneByNumber(_laneID.Integer);
			if gridController &lt;&gt; null and gridController.isKindOf(CM_GateAreaLaneController) then
				kiosk:= gridController.CM_GateAreaLaneController.getKiosk();
				if kiosk &lt;&gt; null then
					return gridController.CM_GateAreaLaneController;
				endif;
			endif;
		endif;
	endforeach;
	
	return null;
epilog

end;</source>
        <Parameter name="_laneID" type="String"/>
        <ReturnType type="CM_GateAreaLaneController"/>
    </JadeMethod>
    <JadeMethod name="getHMSNextVoyageCode" id="6ae858d5-5281-4584-83c7-67e4fb72a1b6">
        <source>getHMSNextVoyageCode() : String;
//--------------------------------------------------------------
//Created: 17 May 2002 By: cnwgd1
//--------------------------------------------------------------
constants
	KeyDesc = 'System Voyage Code';
vars
	theKeySeries 	: CM_KeySeries;
	seriesKey		: CM_SeriesKey;
	prefix,
	suffix 			: String;
	root 			: Integer;	
begin
	
	prefix := self.getConfig(HMSVoyageCodePrefix).String;
	if prefix = null then
		prefix := self.code;
	endif;
	theKeySeries := self.allKeySeriesByCode[SN_HMSVoyageCode];
	
	if theKeySeries = null then
		create theKeySeries persistent;
		theKeySeries.set(SN_HMSVoyageCode, KeyDesc, self);
		create seriesKey persistent;
		seriesKey.set(prefix, 1);
		theKeySeries.nextKey := seriesKey;
	else
		seriesKey := theKeySeries.nextKey;
		if seriesKey.prefix &lt;&gt; prefix then
			seriesKey.set(prefix, 1);
		endif;
	endif;

	lock(theKeySeries, Reserve_Lock, Transaction_Duration, 5000);

	theKeySeries.reserve(app.computerName, process.signOnUserCode, prefix, root, suffix);
	theKeySeries.issue(app.computerName, process.signOnUserCode);

	return prefix &amp; root.String; // &amp; suffix; not used at present.

epilog
	unlock(theKeySeries);		
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getHMSTransForAuditEnquiry" id="1e939f8e-5717-44f8-bcc7-894ef6d3d220">
        <source>getHMSTransForAuditEnquiry(_auditEnquirySearcher : CMIF_HMS_AuditEnquiry input; _passport : CM_Passport input);
//--------------------------------------------------
// Created:	17 September 2004 By: cnwgd1
//--------------------------------------------------
vars
	hmsTrans : HMS_Transaction;
	terminal : CM_Terminal;
	iter : Iterator;
	endDT : TimeStamp;
begin
	if _auditEnquirySearcher = null then
		app.setContinueCMExceptions(false);
		app.raiseUnexpectedProgramError(class.name, method.name, '_auditEnquirySearcher is null');
		return;
	endif;
	
	endDT := _auditEnquirySearcher.endDateTime;
	if (not endDT.isValid) then
		endDT := null;
	endif;
	
	iter := self.allHMSTransactions.createIterator();
	self.allHMSTransactions.startKeyGeq(_auditEnquirySearcher.startDateTime, null, iter);

	while iter.next(hmsTrans) do
		if endDT.isValid()
		and hmsTrans.transactionDT &gt; endDT then
			break;
		endif;
		hmsTrans.getHMSTransForAuditEnquiry(_auditEnquirySearcher, _passport);
	endwhile;

epilog
	delete iter;
end;</source>
        <Parameter name="_auditEnquirySearcher" type="CMIF_HMS_AuditEnquiry" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
