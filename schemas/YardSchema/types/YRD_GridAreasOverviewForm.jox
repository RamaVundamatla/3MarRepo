    <JadeMethod name="doMnuLcnPadHeights" id="2b427b28-691b-4d5d-a060-f9469bb2a038">
        <updating/>
        <source>doMnuLcnPadHeights(_gridController : CM_GridController;_theMode, _theValue : Integer) updating;
// ---------------------------------------------------------------------------
// Created:		September 2003 By Andrew Bishop cnwab1
//
// Purpose:		We allow the user to paint power good, power bad, locations avail or unavail
//				Plus height restrictions. We store each of these as a seperate set of updates to the location controller
//				When they click the height save button we pass the array of CMIF objects to the TRX
// 29/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
vars
//	aPoint : CMUI_GridPoint;
	anInterfaceObject : CMIF_GridTARegion;
//	theFrame : CMUI_GridAreaFrame;
	theInterfaceObjects : ObjectArray;
	aGridArea : CM_GridArea;
	result : Integer;
begin
	aGridArea :=  _gridController.myTerminalArea.CM_GridArea;
	
	create anInterfaceObject transient;
	
//	theFrame := self.frmGridArea;
	anInterfaceObject.updateMode := _theMode;
	anInterfaceObject.myGridArea :=aGridArea;
	anInterfaceObject.allLocationControllers.add(_gridController);

	// ### HEIGHTS, Availability etc
	if _theMode &lt;&gt; CMIF_GridTARegion.UpdateMode_PowerGood
	and _theMode &lt;&gt; CMIF_GridTARegion.UpdateMode_PowerDamaged then
		if _gridController.isKindOf(CM_StackController) then
			anInterfaceObject.oldAvailability := _gridController.CM_StackController.availability;
		elseif _gridController.isKindOf(CM_RTGController) then
			anInterfaceObject.oldAvailability := _gridController.CM_RTGController.availability;
		
		endif;
		anInterfaceObject.availability := _theValue;
	// ### POWER GOOD OR BAD
	else
		if _gridController.power then
			if _theMode = CMIF_GridTARegion.UpdateMode_PowerGood then
				anInterfaceObject.oldPowerDamaged := _gridController.powerDamaged;
			endif;
			// only do this if the point has a power ability
			if _theMode = CMIF_GridTARegion.UpdateMode_PowerDamaged and _gridController.power then 
				anInterfaceObject.oldPowerDamaged := _gridController.powerDamaged;
			endif;
		endif;
	endif;

	create theInterfaceObjects transient;
	theInterfaceObjects.add(anInterfaceObject);

	while true do
		app.myTrxUA.trxUpdateGridControllers(theInterfaceObjects,aGridArea,app.myPassport);
		if app.myPassport.trxCompletedOK then
			// Clear errors/warnings from form and err/warnings window
			self.clearErrorWarnings();
			break;
		else
			result := app.showErrorWarningDialog(_gridController.getFullId &amp; ' Pad Edit', app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   result = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
		endif;
		break;
	endwhile;

epilog
	delete anInterfaceObject;
	delete theInterfaceObjects;
	
end;</source>
        <Parameter name="_gridController" type="CM_GridController"/>
        <Parameter name="_theMode" type="Integer"/>
        <Parameter name="_theValue" type="Integer"/>
    </JadeMethod>
