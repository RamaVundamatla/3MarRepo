    <JadeMethod name="isValidForRT" id="e1ede085-2e74-471a-a84e-59d50dbaabbb">
        <source>isValidForRT(): Boolean;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
26 July 2011	cnwndl1	Initial creation	Par 27890

*/

vars

begin
	return true;

epilog

