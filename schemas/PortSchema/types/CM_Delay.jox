    <JadeMethod name="getCraneCurrentShift" id="bab93cf3-8204-42eb-afc1-0959dcaac389">
        <source>getCraneCurrentShift():CM_Shift;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 Sep 2020 cnwma1 ChangeRequest 49758: MTN - Navis Smart Data API - Snapshot Data

*/

vars
	jobSheet : CM_VoyageJobSheet;
	job      : CM_Job;
	shift    : CM_Shift;
	terminal : CM_Terminal;
begin
	if self.myMachine = null then
	
		return null;
	endif;	
	
	if self.myMachine.isKindOf(CM_Crane) or self.myMachine.isKindOf(CM_WorkPoint) then
		if self.myVoyage &lt;&gt; null then
			foreach jobSheet in self.myVoyage.allJobSheets discreteLock do
				if jobSheet.crane &lt;&gt; self.myMachine.code then
					continue;
				endif;
					foreach job in jobSheet.allJobsByOrder discreteLock do
						if job.myShift = null then
							continue;
						endif;
						
						if job.myShift.startDateTime &gt; self.startDT then
							continue;
						endif;
						if job.myShift.endDateTime &lt; self.startDT then
							continue;
						endif;
						
						shift := job.myShift;
						return shift;
						
					endforeach;
			endforeach;
		endif;
	endif;
	
	return shift;
epilog

end;</source>
        <ReturnType type="CM_Shift"/>
    </JadeMethod>
    <JadeMethod name="getDelayDuration" id="a9ffdd77-39e2-466e-be3f-347c8e638f1e">
        <source>getDelayDuration():Decimal;
/*
	Purpose:		Delay duration in hours		
	Parameters:			
	Return Value:		

Date			Who		Reason
31 July 2008	concms1	Initial creation
*/

vars
	ts1, ts2	:TimeStamp;
	ms			:Integer64;
begin
	ts1 := self.startDT;
	ts2 := self.getEndDT();
	
	if ts1 = null or ts2 = null then
		return null;
	endif;
	
	ms	:= (ts2 - ts1).getMilliseconds;

	return ms/MillisecondsPerHour;	// hours
epilog

end;</source>
        <ReturnType type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="getDelayDurationInMins" id="70fe2c63-6e81-4f15-a018-42244ea5f3f4">
        <source>getDelayDurationInMins():Decimal;
/*****************************************************
Author		: jlika1 (Karen Alexander)
Date		: 22 Jan 2024
TFS#		: 61436
Function	: Delay Duration in Minutes

*** Changes ***
Date			Name		TFS#		Description

****************************************************/

vars
	ts1, ts2	:TimeStamp;
	ms			:Integer64;
begin
	ts1 := self.startDT;
	ts2 := self.getEndDT();
	
	if ts1 = null or ts2 = null then
		return null;
	endif;
	
	ms	:= (ts2 - ts1).getMilliseconds;

	return ms/MillisecondsPerMinute;
epilog

end;</source>
        <ReturnType type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="getDelayDurationMillisec" id="a3d7a3bc-409b-4681-b3ea-883663608a46">
