    <JadeMethod name="addCompulsoryResultCols" id="3bc2fc78-8e19-47fe-9900-84dafe23e793">
        <source>addCompulsoryResultCols( _warn : Boolean ) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26 October 2016	cnwndl1	Initial creation	TFS 2850 / 2370

*/

vars

	entTableDef : EntTableDef;
	view : EntTableView;
	viewRows : EntTableRowArray;
	entRow : EntTableRow;
	index : Integer;
	warnCount : Integer;

begin

	//All relates to MOB_HHCargoFind 
	//ETGrp_TrackedItemDetails  //ETDef_CargoQuickViewHandHeld  // view = "HandHeld"

	entTableDef := app.myRoot.myEntTableDataRoot.getEntTableDef(ETDef_CargoQuickViewHandHeld);
	if entTableDef &lt;&gt; null then
		viewRows := entTableDef.getViewRows("HandHeld"); // These are the mandatory rows in the results searcher.
		if viewRows &lt;&gt; null then
			foreach entRow in viewRows do
				index := self.mulResultsCol.mySelectedListBox.findStringExact( 1, entRow.getRawHeadingValue);
				if index &lt; 1 then
					//add the compulsory one to selected
					index := self.mulResultsCol.mySelectedListBox.addItem( self.displayEntryCriteria(entRow) );
					self.mulResultsCol.mySelectedListBox.itemObject[index] := entRow;
					self.mulResultsCol.mySelectedListBox.itemForeColor[index] := Blue;
					//remove from available
					index := self.mulResultsCol.myAvailableListBox.findStringExact( 1, entRow.getRawHeadingValue);
					if index &gt; 0 then
						self.mulResultsCol.myAvailableListBox.removeItem( index );
					endif;
					warnCount := warnCount + 1;
				else
					self.mulResultsCol.mySelectedListBox.itemForeColor[index] := Blue;
				endif;
			endforeach;
		endif;
	endif;
	
	if warnCount &gt; 0 and _warn then
		app.msgBox(  app.getErrorString1(Mandat_result_column_added_bac, warnCount.String), app.getErrorString(Warning), MsgBox_OK_Only );
	endif;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_warn" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="addCompulsorySearchCriteria" id="9fd2e0cf-dab0-4d82-baa6-389f4440d027">
        <source>addCompulsorySearchCriteria( _warn : Boolean; _hhConfig : CM_HandHeldConfig ) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25 October 2016	cnwndl1	Initial creation	TFS 2850 / 2370

*/

vars

	entTableDef : EntTableDef;
	view : EntTableView;
	viewRows : EntTableRowArray;
	entRow : EntTableRow;
	index : Integer;
	warnCount : Integer;

begin

	//All relates to MOB_HHCargoFind 
	//ETGrp_TrackedItemDetails  //ETDef_HandHeldFind  // view = "HandHeld"

	entTableDef := app.myRoot.myEntTableDataRoot.getEntTableDef(ETDef_HandHeldFind);
	if entTableDef &lt;&gt; null then
	
		if _hhConfig = null and _warn = false and self.mulSearchCrit.mySelectedListBox.listCount = 0 then
			//we are loading for the first time, and there is no definition, load the historic default values
			viewRows := entTableDef.getViewRows("HandHeld"); // These are the mandatory rows in teh searcher.
			if viewRows &lt;&gt; null then
				foreach entRow in viewRows do
					index := self.mulSearchCrit.mySelectedListBox.findStringExact( 1, entRow.getRawHeadingValue);
					if index &lt; 1 then
						//add the compulsory one to selected
						index := self.mulSearchCrit.mySelectedListBox.addItem( self.displayEntryCriteria(entRow) );
						self.mulSearchCrit.mySelectedListBox.itemObject[index] := entRow;
						//remove from available
						index := self.mulSearchCrit.myAvailableListBox.findStringExact( 1, entRow.getRawHeadingValue);
						if index &gt; 0 then
							self.mulSearchCrit.myAvailableListBox.removeItem( index );
						endif;
					endif;
				endforeach;
			endif;
		endif;
		
		viewRows := entTableDef.getViewRows("HandHeldComp"); // These are the mandatory rows in the searcher.
		if viewRows &lt;&gt; null then
			foreach entRow in viewRows do
				index := self.mulSearchCrit.mySelectedListBox.findStringExact( 1, entRow.getRawHeadingValue);
				if index &lt; 1 then
					//add the compulsory one to selected
					index := self.mulSearchCrit.mySelectedListBox.addItem( self.displayEntryCriteria(entRow) );
					self.mulSearchCrit.mySelectedListBox.itemObject[index] := entRow;
					self.mulSearchCrit.mySelectedListBox.itemForeColor[index] := Blue;
					//remove from available
					index := self.mulSearchCrit.myAvailableListBox.findStringExact( 1, entRow.getRawHeadingValue);
					if index &gt; 0 then
						self.mulSearchCrit.myAvailableListBox.removeItem( index );
					endif;
					warnCount := warnCount + 1;
				else
					self.mulSearchCrit.mySelectedListBox.itemForeColor[index] := Blue;
				endif;
			endforeach;
		endif;
	endif;
	
	if warnCount &gt; 0 and _warn then
		app.msgBox( app.getErrorString1(Mandat_result_column_added_bac, warnCount.String), app.getErrorString(Warning), MsgBox_OK_Only );
	endif;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_warn" type="Boolean"/>
        <Parameter name="_hhConfig" type="CM_HandHeldConfig"/>
    </JadeMethod>
    <JadeMethod name="addCompulsoryViewRows" id="a437306e-db8e-4d75-a570-0f979570c3ad">
        <source>addCompulsoryViewRows( _warn : Boolean ) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 December 2016	cnwndl1	Initial creation	TFS 3008 / 2370

*/

vars

	group : EntTableGroup;
	entRow : EntTableRow;
	index : Integer;
	warnCount : Integer;

begin

	group := app.myRoot.myEntTableDataRoot.allEntTableGroups.getAtKey(ETGrp_CargoDetails);
	if group &lt;&gt; null then
	
		entRow := group.allEntTableRowsByName.getAtKey(ETRow_CargoId); // The only mandatory row in the View Table.
		if entRow &lt;&gt; null then
			index := self.mulViewTable.mySelectedListBox.findStringExact( 1, entRow.getRawHeadingValue);
			if index &lt; 1 then
				//add the compulsory one to selected
				index := self.mulViewTable.mySelectedListBox.addItem( self.displayEntryCriteria(entRow) );
				self.mulViewTable.mySelectedListBox.itemObject[index] := entRow;
				self.mulViewTable.mySelectedListBox.itemForeColor[index] := Blue;
				//remove from available
				index := self.mulViewTable.myAvailableListBox.findStringExact( 1, entRow.getRawHeadingValue);
				if index &gt; 0 then
					self.mulViewTable.myAvailableListBox.removeItem( index );
				endif;
				warnCount := warnCount + 1;
			else
				self.mulViewTable.mySelectedListBox.itemForeColor[index] := Blue;
			endif;
		endif;
	endif;
	
	if warnCount &gt; 0 and _warn then
		app.msgBox( app.getErrorString1(Mandat_result_column_added_bac, warnCount.String), app.getErrorString(Warning), MsgBox_OK_Only );
	endif;
	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_warn" type="Boolean"/>
    </JadeMethod>
