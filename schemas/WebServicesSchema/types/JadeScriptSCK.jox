<Class name="JadeScriptSCK" id="1c7210ad-89d8-4da0-ad04-5759c058af01">
    <superclass name="JadeScript"/>
    <transient/>
    <sharedTransientAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="webservice"/>
    <JadeMethod name="exportAllWebservices" id="614d6644-9a23-4841-b00b-9e179195c669">
        <source>exportAllWebservices();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 May 2025	navsck1	Initial creation

*/

vars
	file		: File; 
	fileSave 	: CMDFileSave;
	fileString 	: String;
begin
	create file transient;
	create fileSave transient;
	file.mode := File.Mode_Output;
	fileSave.defaultExt := '.csv';
	fileSave.fileMustExist := false;
	fileSave.fileName := 'webservice_' &amp; app.myRoot.client &amp; '.csv';
	fileSave.initDir := app.getTempDir();
	
	if fileSave.open() = 0 then
		file.openOutput(fileSave.fileName);
		/// write headers about the webservice 
		/// SOAP headers
		fileString := "SOAP Webservices,,"&amp; CrLf;
		file.writeLine(fileString);
		
		// JMTUserInterfaceService details 
		fileString := CrLf &amp; "WebServiceName (SOAP &lt;WebServicesSchema::JMTUserInterfaceService&gt;),ReturnType,Type Of Parameters," &amp; CrLf;
		file.writeLine(fileString);
		fileString := self.getAllMethods(JMTUserInterfaceService);
		file.writeLine(fileString);
		
		//WebServicesSchema::JMTSecureService
		fileString := CrLf &amp; "WebServiceName (SOAP &lt;WebServicesSchema::JMTSecureService&gt;),ReturnType,Type Of Parameters," &amp; CrLf;
		file.writeLine(fileString);
		fileString := self.getAllMethods(JMTSecureService);
		file.writeLine(fileString);
		
		// WebServicesSchema::JMTExternalInterfaceService
		fileString := CrLf &amp; "WebServiceName (SOAP &lt;WebServicesSchema::JMTExternalInterfaceService&gt;),ReturnType,Type Of Parameters," &amp; CrLf;
		file.writeLine(fileString);
		fileString := self.getAllMethods(JMTExternalInterfaceService);
		file.writeLine(fileString);
		
		// WebServicesSchema::JMTEDIService 
		fileString := CrLf &amp; "WebServiceName (SOAP &lt;WebServicesSchema::JMTEDIService&gt;),ReturnType,Type Of Parameters," &amp; CrLf;
		file.writeLine(fileString);
		fileString := self.getAllMethods(JMTEDIService);
		file.writeLine(fileString);
		
		// WebServicesSchema::WS_WebServiceProvider
		fileString := CrLf &amp; "WebServiceName (SOAP &lt;WebServicesSchema::WS_WebServiceProvider&gt;),ReturnType,Type Of Parameters," &amp; CrLf;
		file.writeLine(fileString);
		fileString := self.getAllMethods(WS_WebServiceProvider);
		file.writeLine(fileString);
		
		// Rest webservice 
		fileString := "Rest Webservices,,"&amp; CrLf;
		file.writeLine(fileString);
		
		// WebServicesSchema::WS_NavisRestProvider
		fileString := CrLf &amp; "WebServiceName (Reset &lt;WebServicesSchema::WS_NavisRestProvider&gt;),ReturnType,Type Of Parameters," &amp; CrLf;
		file.writeLine(fileString);
		fileString := self.getAllMethods(WS_NavisRestProvider);
		file.writeLine(fileString);
		
		// WebServicesSchema::NavisAPIService
		fileString := CrLf &amp; "WebServiceName (Reset &lt;WebServicesSchema::NavisAPIService&gt;),ReturnType,Type Of Parameters," &amp; CrLf;
		file.writeLine(fileString);
		fileString := self.getAllMethods(NavisAPIService);
		file.writeLine(fileString);
		
		// WebServicesSchema::NReeferAPI
		fileString := CrLf &amp; "WebServiceName (Reset &lt;WebServicesSchema::NReeferAPI&gt;),ReturnType,Type Of Parameters," &amp; CrLf;
		file.writeLine(fileString);
		fileString := self.getAllMethods(NReeferAPI);
		file.writeLine(fileString);
		
		// WebServicesSchema::NavisSmartService
		fileString := CrLf &amp; "WebServiceName (Reset &lt;WebServicesSchema::NavisSmartService&gt;),ReturnType,Type Of Parameters," &amp; CrLf;
		file.writeLine(fileString);
		fileString := self.getAllMethods(NavisSmartService);
		file.writeLine(fileString);
		
		// WebServicesSchema::NavisSmartData
		fileString := CrLf &amp; "WebServiceName (Reset &lt;WebServicesSchema::NavisSmartData&gt;),ReturnType,Type Of Parameters," &amp; CrLf;
		file.writeLine(fileString);
		fileString := self.getAllMethods(NavisSmartData);
		file.writeLine(fileString);
		
		// WebServicesSchema::MasterTerminalAPIService 
		fileString := CrLf &amp; "WebServiceName (Reset &lt;WebServicesSchema::MasterTerminalAPIService&gt;),ReturnType,Type Of Parameters," &amp; CrLf;
		file.writeLine(fileString);
		fileString := self.getAllMethods(MasterTerminalAPIService);
		file.writeLine(fileString);
		
		// WebServicesSchema::MTNInternalAPIService
		fileString := CrLf &amp; "WebServiceName (Reset &lt;WebServicesSchema::MTNInternalAPIService&gt;),ReturnType,Type Of Parameters," &amp; CrLf;
		file.writeLine(fileString);
		fileString := self.getAllMethods(MTNInternalAPIService);
		file.writeLine(fileString);
		
		// WebServicesSchema::KioskInternalAPIService
		fileString := CrLf &amp; "WebServiceName (Reset &lt;WebServicesSchema::KioskInternalAPIService&gt;),ReturnType,Type Of Parameters," &amp; CrLf;
		file.writeLine(fileString);
		fileString := self.getAllMethods(KioskInternalAPIService);
		file.writeLine(fileString);
		
		// WebServicesSchema::MTNGenericInterfaceService
		fileString := CrLf &amp; "WebServiceName (Reset &lt;WebServicesSchema::MTNGenericInterfaceService&gt;),ReturnType,Type Of Parameters," &amp; CrLf;
		file.writeLine(fileString);
		fileString := self.getAllMethods(MTNGenericInterfaceService);
		file.writeLine(fileString);
		
		// WebServicesSchema::JMTPortSystemsAPIService
		fileString := CrLf &amp; "WebServiceName (Reset &lt;WebServicesSchema::JMTPortSystemsAPIService&gt;),ReturnType,Type Of Parameters," &amp; CrLf;
		file.writeLine(fileString);
		fileString := self.getAllMethods(JMTPortSystemsAPIService);
		file.writeLine(fileString);
		
		// WebServicesSchema::JMTHandheldService
		fileString := CrLf &amp; "WebServiceName (Reset &lt;WebServicesSchema::JMTHandheldService&gt;),ReturnType,Type Of Parameters," &amp; CrLf;
		file.writeLine(fileString);
		fileString := self.getAllMethods(JMTHandheldService);
		file.writeLine(fileString);
		
		// WebServicesSchema::WS_RestWebServiceProvider 
		fileString := CrLf &amp; "WebServiceName (Reset &lt;WebServicesSchema::WS_RestWebServiceProvider&gt;),ReturnType,Type Of Parameters," &amp; CrLf;
		file.writeLine(fileString);
		fileString := self.getAllMethods(WS_RestWebServiceProvider);
		file.writeLine(fileString);
		
		// WebServicesSchema::WS_CargoChainSubscriberService
		fileString := CrLf &amp; "WebServiceName (Reset &lt;WebServicesSchema::WS_CargoChainSubscriberService&gt;),ReturnType,Type Of Parameters," &amp; CrLf;
		file.writeLine(fileString);
		fileString := self.getAllMethods(WS_CargoChainSubscriberService);
		file.writeLine(fileString);
		
		
		// WebServicesSchema::HandheldInternalAPIService but this is not in the production
		fileString := CrLf &amp; "WebServicesSchema::HandheldInternalAPIService but this is not in the production under development";
		file.writeLine(fileString);
		
		fileString := CrLf &amp; "WebServiceName (Reset &lt;WebServicesSchema::HandheldInternalAPIService&gt;),ReturnType,Type Of Parameters," &amp; CrLf;
		file.writeLine(fileString);
		fileString := self.getAllMethods(HandheldInternalAPIService);
		file.writeLine(fileString);
		
		
		file.close();
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="getAllMethods" id="4a6b24ab-39ab-4f61-bf0c-70f0bb612c5e">
        <source>getAllMethods(className: Class) : String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 May 2025	navsck1	Initial creation

*/


vars
	cls			: Class;
	mthd		: Method;
	param 		: Parameter;
	mthdString	: String;
	paramString : String;
	fileString 	: String;
begin
	cls := className;
	foreach mthd in cls.cnGetMethods do
		mthdString := "";
		paramString := "";
		mthdString := mthd.name ;
		if mthd.cnEcGetReturnType &lt;&gt; null then
			mthdString := mthdString &amp; " , " &amp;mthd.cnEcGetReturnType.name;
		else
			mthdString := mthdString &amp; " , ";
		endif;
		foreach param in mthd.cnGetParameters do
			if paramString.length &gt;0 then
				paramString :=  paramString &amp;" ; " &amp;param.type.name;
			else
				paramString :=  param.type.name ;
			endif;
		endforeach;
		mthdString := mthdString &amp; " , " &amp; paramString;
		write mthdString;
		fileString := fileString &amp; CrLf &amp; mthdString;
		write "";
	endforeach;
	return fileString;
	
epilog

end;</source>
        <Parameter name="className" type="Class"/>
        <ReturnType type="String"/>
    </JadeMethod>
</Class>
