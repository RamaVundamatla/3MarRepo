    <JadeMethod name="setComboValues" id="aeeb4be2-c2f0-496e-9076-501522d52c51">
        <source>setComboValues(_combo: ComboBox input; _params: CM_QueryCriteriaLineHolder; _queryOperator: CM_QueryOperator; _passport: CM_Passport);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 Aug 2023	navlw1	ChangeRequest 59284:[59664] EUP | FR - VAS Work Order Transactions - Fixing Selector Query

*/

vars
	task 		: CM_ToDoTaskDesc;
	idx			: Integer;
	selected	: CM_ToDoTaskDesc;
	selectStr	: String;
begin
	_combo.clear();	
	_combo.sorted := true;
	
	if CM_QStringLookup.hasInstance(_queryOperator) then
		selectStr := _queryOperator.CM_QStringLookup.selectionValue;
	elseif CM_QStringLookupNotEqual.hasInstance(_queryOperator) then
		selectStr := _queryOperator.CM_QStringLookupNotEqual.selectionValue;
	endif;

	foreach task in app.myRoot.allToDoTaskDescsByShortDesc  do
	
		idx := _combo.addItem(task.description.toUpper());
		_combo.itemObject[idx] := task;
					
		if task.description = selectStr then
			selected := task;
		endif;
	endforeach;
	
	idx  := _combo.findObject(selected);
	
	if idx &gt; 0 and idx &lt; _combo.listCount then
		_combo.listIndex := idx;
	endif;
epilog
	
end;</source>
        <Parameter name="_combo" type="ComboBox" usage="input"/>
        <Parameter name="_params" type="CM_QueryCriteriaLineHolder"/>
        <Parameter name="_queryOperator" type="CM_QueryOperator"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="setListValues" id="ac633752-eaf1-4c0e-9250-1dcf9535ae4a">
        <source>setListValues(_tbl: Table input; _params: CM_QueryCriteriaLineHolder; _operator: CM_QueryOperator; _passport: CM_Passport);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 Aug 2023	navlw1	ChangeRequest 59284:[59664] EUP | FR - VAS Work Order Transactions - Fixing Selector Query
*/

vars
	selectionValue, idx : Integer;
	array 				: ObjectArray;
	task 				: CM_ToDoTaskDesc;
	dict 				: CM_ToDoTaskDescByShortDesc;
	str					: String;
begin
	_tbl.rows := _tbl.fixedRows;
	_tbl.sortColumn[1] := 2;
	_tbl.sortAsc[1] := true;
	
	array := _tbl.getPropertyValue('allSelectedObjects').ObjectArray;
	array.clear;
	
	foreach task in app.myRoot.allToDoTaskDescsByShortDesc  do	
	
		selectionValue := 0;
		if _operator &lt;&gt; null and  _operator.CM_QStringIsOneOf.allSelectionValues.includes(task.description) then
			selectionValue := 1;
			array.add(task);
		endif;
	
		idx := _tbl.addItem(selectionValue.String &amp; Tab  &amp; task.description.toUpper());
		_tbl.accessRow(idx).itemObject := task;
	endforeach;
epilog

end;</source>
        <Parameter name="_tbl" type="Table" usage="input"/>
        <Parameter name="_params" type="CM_QueryCriteriaLineHolder"/>
        <Parameter name="_operator" type="CM_QueryOperator"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="setValuesFromList" id="6fc6b36f-6341-4541-9c93-83b51336d93f">
        <source>setValuesFromList(_tbl: Table input; _op: CM_QueryOperator input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 Aug 2023	navlw1	ChangeRequest 59284:[59664] EUP | FR - VAS Work Order Transactions - Fixing Selector Query

*/

vars
	task 			: CM_ToDoTaskDesc;
	str 			: String;
	numRows, idx 	: Integer;
	sa 				: StringArray;
begin
	create sa transient;
	
	numRows := _tbl.rows;
	foreach idx in _tbl.fixedRows + 1 to numRows do
		str := _tbl.accessCell(idx, 1).text;
		if str = TableCheckBox_Selected then
			task := _tbl.accessRow(idx).itemObject.CM_ToDoTaskDesc;
			sa.add(task.description);
		endif;
	endforeach;
	
	_op.setSearchValue(sa);

epilog
	delete sa;
end;</source>
        <Parameter name="_tbl" type="Table" usage="input"/>
        <Parameter name="_op" type="CM_QueryOperator" usage="input"/>
    </JadeMethod>
    <JadeMethod name="translateToDisplayValue" id="22443a66-b499-4ee9-b957-9cb410bb8a4e">
        <source>translateToDisplayValue(_value: Any): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 Aug 2023	navlw1	ChangeRequest 59284:[59664] EUP | FR - VAS Work Order Transactions - Fixing Selector Query

*/

vars

begin
	if _value.isKindOf(CM_ToDoTaskDesc) then
		if _value &lt;&gt; null then
			return _value.CM_ToDoTaskDesc.description;
		else
			return null;
		endif;
	else
		return _value.String;
	endif;
epilog

end;</source>
        <Parameter name="_value" type="Any"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="translateToSearchValue" id="2ef18f1d-f30b-4142-ad38-22756d1e4909">
        <source>translateToSearchValue(_value: Any): Any;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 Aug 2023	navlw1	ChangeRequest 59284:[59664] EUP | FR - VAS Work Order Transactions - Fixing Selector Query

*/

vars
	invalidObj 	: Boolean;
	object 		: CM_ToDoTaskDesc;
	returnVal 	: String;
begin
	if _value &lt;&gt; null then
		if _value.isKindOf(Collection) then
			return _value;
		endif;
		
		if _value.isKindOf(CM_ToDoTaskDesc) then
			object := _value.CM_ToDoTaskDesc;
		endif;
	endif;
	
	if object &lt;&gt; null then
		on Exception do app.handleDeletedObject(exception, object, invalidObj);
		
		returnVal := object.description;
	endif;
	
	return returnVal;

epilog

end;</source>
        <Parameter name="_value" type="Any"/>
        <ReturnType type="Any"/>
    </JadeMethod>
</Class>
