    <JadeMethod name="getVoyageColour" id="545fdafd-1b64-43b2-8561-f02f682377ec">
        <source>getVoyageColour(colour : Integer output) : Boolean;
// ---------------------------------------------------------------------------
// Created:      10 June 2003 by cnwsgp1
// ---------------------------------------------------------------------------
vars
	stockAlloc : CM_StockOrderAllocation;
	voy : CM_Voyage;
	ti : CM_TrackedItem;

begin
	if self.isStockControlled then
		foreach stockAlloc in self.allStockOrderAllocations do
			voy := stockAlloc.myStockOrderHeader.myVoyage;
			if voy &lt;&gt; null then
				colour := voy.colour;
				return true;
			endif;
		endforeach;

	else
		if self.numTIs &gt; 0 then
			foreach ti in self.allTrackedItems do
				voy := ti.myVoyage;
				if voy &lt;&gt; null then
					colour := voy.colour;
					return true;
				endif;
			endforeach;
		endif;
	endif;		
				
	return false;
end;</source>
        <Parameter name="colour" type="Integer" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
