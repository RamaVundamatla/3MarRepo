    <JadeMethod name="translateForm" id="ebe0cc36-4584-4304-8e58-e880ddeec0d3">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0013543, locale);
	btnCancelCC.translateCaption(Xlat_0013544, locale);
	btnDeleteVA.translateBubbleHelp(Xlat_0014626, locale);
	btnDeleteVA.translateCaption(Xlat_0014165, locale);
	btnDeleteVALL.translateBubbleHelp(Xlat_0014283, locale);
	btnDeleteVALL.translateCaption(Xlat_0014284, locale);
	btnEraseAlloc.translateBubbleHelp(Xlat_0016921, locale);
	btnEraseAlloc.translateCaption(Xlat_0016922, locale);
	btnExportCSV.translateBubbleHelp(Xlat_0014166, locale);
	btnExportCSV.translateCaption(Xlat_0014167, locale);
	btnPrintTable.translateBubbleHelp(Xlat_0014168, locale);
	btnPrintTable.translateCaption(Xlat_0014169, locale);
	btnRefresh.translateBubbleHelp(Xlat_0016258, locale);
	btnRefresh.translateCaption(Xlat_0016259, locale);
	btnSaveCC.translateCaption(Xlat_0013545, locale);
	btnSaveProj.translateBubbleHelp(Xlat_0014627, locale);
	btnSaveProj.translateCaption(Xlat_0014628, locale);
	btnSummBooking.translateBubbleHelp(Xlat_0014170, locale);
	btnSummBooking.translateCaption(Xlat_0014171, locale);
	btnSummCargo.translateBubbleHelp(Xlat_0014172, locale);
	btnSummCargo.translateCaption(Xlat_0014173, locale);
	mnuInspectObject.translateCaption(Xlat_0013546, locale);
	mnuViewContext.translateCaption(Xlat_0013547, locale);
end;</source>
    </JadeMethod>
    <JadeMethod name="unload" id="f15cf141-dadc-4569-ac14-af7e5e967f4d">
        <controlMethod name="Form::unload"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>unload() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
08 Jan 2010	cnwas3	Initial creation
01 Mar 2011	cnwkpd1	PAR #27032 - Load Colour Code performance

*/

vars
	option,
	time			: Integer;

begin
	if self.myParentForm &lt;&gt; null then
		if self.myParentForm.isKindOf(CMUI_GridAreaForm2) then // PAR 27749
			self.myParentForm.CMUI_GridAreaForm2.hideCCP(false);
		elseif self.myParentForm.class().name = "SHP_ROROPlanningForm" then
			self.myParentForm.sendMsgWithParams("hideCCP", false);
		endif;
	endif;
	if self.getTimerStatus(Timer_Tag_Refresh, option, time) then
		self.endTimer(Timer_Tag_Refresh);
	endif;
	inheritMethod();
epilog

end;</source>
    </JadeMethod>
