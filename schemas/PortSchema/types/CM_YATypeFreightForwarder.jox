    </JadeMethod>
    <JadeMethod name="isSnapShotDataMatch" id="8de6c648-13ef-4d4a-8ce2-94a1fdf87bd4">
        <source>isSnapShotDataMatch(_criteria: CM_YACriteria; _yaType: Integer; _propertyValue: String): Boolean;

vars
	obj		: Object;
begin
	if _yaType &lt;&gt; self.type then
		return false;
	endif;
	
	foreach obj in _criteria.myYAData.CM_YADataObjects.allObjects do
		if obj.CM_ConsigneeConsignor.code = _propertyValue then
			return true;
		endif;
	endforeach;
	
	if _criteria.myYAData.isKindOf(CM_YADataPattern) and
	   _criteria.myYAData.CM_YADataPattern.pattern = null then
		return true;
	endif;
	
	return false;
end;
</source>
        <Parameter name="_criteria" type="CM_YACriteria"/>
        <Parameter name="_yaType" type="Integer"/>
        <Parameter name="_propertyValue" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isStorageDetailMatch" id="713c64b4-653d-4d40-9c78-3e18a6bc8929">
        <source>isStorageDetailMatch(_criteria : CM_YACriteria; _ti: CM_TrackedItem; _tiTrx : CM_TITransaction): Boolean;
// CCMS DPH 2278 Storage Billing by Terminal Area
vars
	forwarder	: CM_ConsigneeConsignor;

begin
//	forwarder := _ti.myFreightForwarder;
	
	if _tiTrx &lt;&gt; null then	//13 Nov 2019	NDL	TFS 47344
		if _tiTrx.freightForwarderCode &lt;&gt; null then
			forwarder := app.myRoot.allConsigneeConsignors[ _tiTrx.freightForwarderCode ];
		endif;
	else
		forwarder := _ti.myFreightForwarder;
	endif;
	
	// specific value - handle wild cards as well
	if _criteria.myYAData.CM_YADataObjects.matchesStorage(forwarder) then
		return true;
	endif;
	
	// default value
	if _criteria.myYAData.isKindOf(CM_YADataPattern) and
	   _criteria.myYAData.CM_YADataPattern.pattern = null then
		return true;
	endif;
	
	return false;
end;
</source>
        <Parameter name="_criteria" type="CM_YACriteria"/>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_tiTrx" type="CM_TITransaction"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
