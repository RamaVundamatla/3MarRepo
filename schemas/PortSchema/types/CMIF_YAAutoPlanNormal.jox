    <JadeMethod name="isOnboardHazards_Match" id="170f7b99-603a-4ec0-87aa-24c232e1c59c">
        <source>isOnboardHazards_Match(__yaData: CM_YADataString): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 January 2025	navhn30	Initial creation

*/

vars
	tiSet : CM_TISet;
	ti : CM_TrackedItem;
	str 	 : String;
	strArray : StringArray;
	pos		 : Integer;
	
begin

	if self.myTrackedItem = null or not self.myTrackedItem.isTILC() then
		return false;
	endif;
	
	create tiSet transient;
	self.myTrackedItem.CM_TILC.getAllOnboardTIs(tiSet);
	
	create strArray transient;
	
	foreach ti in tiSet discreteLock do
		ti.getHazardsAsString.getTokensForDelimiter(",", strArray);
	endforeach;
	
	foreach str in strArray do
		pos := str.pos('(', 1);
		if pos &lt;&gt; 0 then			// 23/01/2012 cnwar2 #29020
			str := str[1:pos-2];	// strip UNDG number
		endif;
		
		if __yaData.doesValueMatch(str.trimBlanks) then
			return true;
		endif;
	endforeach;

	return false;
epilog
	delete strArray;
end;</source>
        <Parameter name="__yaData" type="CM_YADataString"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
