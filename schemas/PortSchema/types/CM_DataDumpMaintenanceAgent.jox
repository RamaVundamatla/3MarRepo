		// Start 14/09/2022 navrk21 TFS 54635
		elseif _class = CM_Crane then
			xCM_Crane(_features);
		elseif _class = CM_CraneMoveRates then
			xCM_CraneMoveRates(_features);
		// End 14/09/2022 navrk21 TFS 54635
		//Start	04.10.2022 navtnr20 TFS 54967
		elseif _class = CM_InstructionType  then
			xCM_InstructionType (_features);
		elseif _class = CM_InstructionsIssued then
			xCM_InstructionsIssued(_features);
		elseif _class = CM_WorkOrder  then
			xCM_WorkOrder (_features);
		elseif _class = CM_WorkOrderDtl then
			xCM_WorkOrderDtl(_features);	
		//End 04.10.2022 navtnr20 TFS 54967
		elseif _class = CM_TaxCode then  //24/11/2022navmv20 TFS 55005
			xCM_TaxCode(_features); //24/11/2022navmv20 TFS 55005
		// Start 16 Feb 2023 navvt20 TFS 55687
		elseif _class = CM_InvoiceContract then
			xCM_InvoiceContract(_features);
		elseif _class = CM_InvoiceContractDetails then
			xCM_InvoiceContractDetails(_features);
		elseif _class = CM_InvoiceContractRate then
			xCM_InvoiceContractRate(_features);
		elseif _class = CM_InvoiceContractRateEntry then
			xCM_InvoiceContractRateEntry(_features);
		// End 16 Feb 2023 navvt20 TFS 55687
		// ### JIRA 33348 27NOV2024 NAVAB1
		elseif _class = CM_InvoiceContractAccumulate then
			xCM_InvoiceContractAccumulate(_features);
		elseif _class = CM_VehicleBookingTimeSlot then		// ### TFS 53902 25May2023 NAVPW1
			xCM_VehicleBookingTimeSlot(_features);			// ### TFS 53902 25May2023 NAVPW1
		elseif _class = CM_VehicleBookingTimeSlotType then	// ### TFS 53902 25May2023 NAVPW1
			xCM_VehicleBookingTimeSlotType(_features);		// ### TFS 53902 25May2023 NAVPW1
		elseif _class = CM_DriverDetails then				// ### TFS 53902 25May2023 NAVPW1
			xCM_DriverDetails(_features);					// ### TFS 53902 25May2023 NAVPW1
		elseif _class = CM_VehicleBookingTimeSlotItem then	// ### TFS 58327 01June2023 NAVLW1
			xCM_VehicleBookingTimeSlotItem(_features);
		elseif _class = CM_OwnershipChange then	// ### TFS CR 58246 TASK 58248 21JUL2023 NAVAB1
			xCM_OwnershipChange(_features); // ### TFS CR 58246 TASK 58248 21JUL2023 NAVAB1
		elseif _class = CM_OwnershipChangeDetail then	// ### TFS CR 58246 TASK 58248 21JUL2023 NAVAB1
			xCM_OwnershipChangeDetail(_features); // ### TFS CR 58246 TASK 58248 21JUL2023 NAVAB1
		elseif _class = CM_OwnershipChangeFinancial then	// ### TFS CR 58246 TASK 58248 21JUL2023 NAVAB1
			xCM_OwnershipChangeFinancial(_features); // ### TFS CR 58246 TASK 58248 21JUL2023 NAVAB1
		elseif _class = CM_WorkPoint then					//30.01.2023 navhl20 #55111
			xCM_WorkPoint(_features); 						//30.01.2023 navhl20 #55111
		elseif _class = CM_WorkPointType then				//28.02.2024 navhl20 #62671
			xCM_WorkPointType(_features);
		elseif _class = HMS_MarineServicesTimings then		//02.02.2024 navnk30 #62313
			xHMS_MarineServiceTimings(_features);
		elseif _class = CM_CargoForecast then				//03.09.2025 navbs1 #35845
			xCM_CargoForecast(_features);
		else
			_features.purge();
		endif;
	else
		create xdbFeature transient;
		xdbFeature.featureName := "edition";
		xdbFeature.subClassName := _class.name;
		_features.add(xdbFeature);

		create props transient;
		allprops := _class.allProperties();
		allprops.copy(props);
		_class.getPropertiesInSubclasses(props);
		foreach property in props do
			if property.name = "oidAsBin" or
			   property.name = "oidAsHex" or
			   property.name = "createdTime" or
			   property.name = "bitmap" or 
			   (_class = CM_TempReading and property.name = "flags") then
			   	continue;
			endif;
			if property.cnEcIsPrimitive() then
				create xdbFeature transient;
				xdbFeature.subClassName := _class.name;
				xdbFeature.featureName := property.name;
				_features.add(xdbFeature);
			endif;
		endforeach;	
		delete props;
		_class.allMethodsInFullTree(allMethods);
		foreach aMethod in allMethods do
			if aMethod.isPseudoProperty() then
				create xdbFeature transient;
				xdbFeature.subClassName := _class.name;
				xdbFeature.featureName := aMethod.name;
				_features.add(xdbFeature);
			endif;
		endforeach;	
	endif;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_class" type="Class"/>
        <Parameter name="_features" type="CMIF_ExternalDBFeatureSet" usage="input"/>
    </JadeMethod>
    <JadeMethod name="maintainDataDumpClasses" id="cae960a4-7537-48e3-956b-df5148b4b6d0">
        <updating/>
        <source>maintainDataDumpClasses() updating;
// ---------------------------------------------------------------------------
// Created:     20 May 2003 by cnwsb1
//
// Purpose:		Maintains all Data Dump classes and their attributes from the
//				data stored in the text of this method.
//				Also updates server ini file with changes.
//				The data was obtained from the old SQLServerDb structures.
//
//				NB: When loading data from method text, be aware that there
//				is a 65KB limit to method data during a schema load pre-
//				JADE 6.0.16 (see JADE PAR 29803).

//	Updated		
// ---------------------------------------------------------------------------
// 23/11/2017	jlgdap1		TFS 7511 LNX Issue when subclass attributes were repeated on more than one subclass 
vars
//	data : String;
//	sta : StringArray;
//	str : String;
//	ptrFrom : Integer;
//	ptrTo : Integer;
	
	classId : String;
	classAlias : String;
	featureName : String;
	groupClassId : String;
	proxyDdClass : CM_DataDumpClass;
	realDdClass : CM_DataDumpClass;
	proxyDdFeature : CM_DataDumpFeature;
	toDeleteRealClasses : CM_DataDumpClassSet;
	toDeleteProxyFeatures : CM_DataDumpFeatureSet;
	classes : ObjectArray; 
	sqlTables : StringArray;
	features    : CMIF_ExternalDBFeatureSet;
	xdbFeature  : CMIF_ExternalDBFeature;
	
	index : Integer;
	
	subClassName : String;					// TFS 7511
begin
	
//	data := method.text;
//	create sta transient;
	create classes transient;
	create sqlTables transient;
	create features transient;
	create toDeleteRealClasses transient;
	create toDeleteProxyFeatures transient;
	
	self.lockMutex("Maintain data dump classes");
			
	app.myRoot.allDataDumpClasses.copy(toDeleteRealClasses);

	self.getFeaturedClasses(classes, sqlTables);

	
	foreach index in 1 to classes.size  do

		classId := classes[index].Class.name;
		classAlias := sqlTables[index];
		
		self.getFeaturesForClassNew(classes[index].Class, features);
		//features.inspectModal;
		foreach xdbFeature in features do
		//foreach featureName in features do
			featureName := xdbFeature.featureName; 
			subClassName := xdbFeature.subClassName;											// TFS 7511
			if groupClassId &lt;&gt; classId then
				if groupClassId &lt;&gt; null then
					// Save prior group data
					self.dataDumpGroupChange(proxyDdClass, toDeleteProxyFeatures, app.myPassport);
				endif;
				groupClassId := classId;
				toDeleteProxyFeatures.clear;
	
				realDdClass := app.myRoot.allDataDumpClasses[classId];
				if realDdClass = null then
					create proxyDdClass transient;
				else
					toDeleteRealClasses.removeIfPresent(realDdClass);
					proxyDdClass := app.createUpdateProxy(realDdClass).CM_DataDumpClass;
					proxyDdClass.allDataDumpFeatures.copy(toDeleteProxyFeatures);
				endif;
	
				proxyDdClass.setProxy(classId, classAlias);
			endif;
			
			//proxyDdFeature := proxyDdClass.allDataDumpFeatures[featureName];					// TFS 7511
			proxyDdFeature := proxyDdClass.allDataDumpFeatures[featureName, subClassName];		// TFS 7511
			if proxyDdFeature = null then
				proxyDdClass.pxyCreateFeature(featureName, xdbFeature);
				//proxyDdClass.pxyCreateFeature(featureName, xdbFeature.subClassName, xdbFeature.returnValueIsAnObject, xdbFeature.isProtected);
			else
				proxyDdFeature.setProxy(featureName, xdbFeature);
				toDeleteProxyFeatures.removeIfPresent(proxyDdFeature);
			endif;
		
//		ptrFrom := ptrTo + CrLf.length;
		
//		if ptrFrom &gt; data.length then
//			break;
//		endif;
//	endwhile;
		endforeach;
	endforeach;	
	if groupClassId &lt;&gt; null then
		// Save final classId group
		self.dataDumpGroupChange(proxyDdClass, toDeleteProxyFeatures, app.myPassport);
	endif;
	
	// Delete non-existing classes.
	foreach realDdClass in toDeleteRealClasses do
		app.myTrxDA.trxDeleteDataDumpClass(realDdClass, app.myPassport);
	endforeach;
	
	// Now write changes to ini file - for change tracker app to use
//	self.updateServerIniFile;		// 26/09/2006	PAR12534	cnwvu1
	
epilog
	self.unlockMutex;
//	delete sta;
	delete classes;
	delete sqlTables;
	if features &lt;&gt; null then
		features.purge();
		delete features;
	endif;
	delete proxyDdClass;
	delete toDeleteRealClasses;
	delete toDeleteProxyFeatures;
end;</source>
