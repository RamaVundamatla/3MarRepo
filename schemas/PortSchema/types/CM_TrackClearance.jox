    <JadeMethod name="validateMe" id="6e7b088b-bd43-4bc1-8fd0-3b1d33594af6">
        <source>validateMe();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
25 June 2009	cnwndl1	Initial creation

*/

vars

begin
	
	if self.code = null then
		app.raiseCMException(Gauge_cleara_code_value_requir, null, null);
		return;
	endif;
	
epilog

end;</source>
    </JadeMethod>
