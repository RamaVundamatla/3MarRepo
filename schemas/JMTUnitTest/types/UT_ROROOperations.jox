    <JadeMethod name="checkGCDCorrect" id="10a29d64-7ff6-4d99-ba3d-95d7960ca968">
        <source>checkGCDCorrect(_mode, _modeView : Integer; _deck : CM_DeckVoyage; _failedArray : HugeStringArray io);

/*

Purpose:		Check that the details from getCargoDetails is correct

Date			Who		Reason
07/09/2012		cnwmh5	Initial creation

*/

vars

	locnDefnVoyage 				: CM_ROROLocnDefnVoyage;
	job 						: CM_VoyageJob;
	aReq 						: CM_RORORequest;
	slotDefn 					: CM_ROROSlotDefn;
	slotLC 						: CM_ROROSlotController;

	locationArray				: StringArray;
	statusArray					: HugeStringArray;
	
	detailsToCheck				: String;
	detailsToCheckFromMethod	: String;
	locationStr					: String;
	mode						: String;
	index 						: Integer;
	modeWritten					: Boolean;

begin

	create statusArray transient;
	create locationArray transient;
	
	// setup the locations and details we are expecting
	if _mode = ShpDisplayMode_Actual then
		if _modeView = ShpDisplayMode_ColCodeDisch then
			mode := "Dischage";
			locationArray.clear();
			locationArray.add("D4270682");
			statusArray.add("D4270682 D4270682 |  Fwd: D4250682 | 4 x CONT NZPOE  U20G | UTMDHYA0020, UTMDHYA0021, UTMDHYA0022, UTMDHYA0023 Job: 201");
			locationArray.add("D4270282");
			statusArray.add("D4270282 D4270282 |  Fwd: D4250282 | 2 x CONT NZPOE  U20G | UTMDHYA0003, UTMDHYA0004");
			locationArray.add("D4250282");
			statusArray.add("D4250282 D4250282 | Aft: D4270282 | 1 x CONT NZPOE  U20G | UTMDHYA0002");
			locationArray.add("D4250382");
			statusArray.add("D4250382 D4250382 | Aft: D4270382 | 2 x CONT NZPOE  U20G| 1 x CONT NZPOE  U40G | UTMDHYA0011, UTMDHYA0012, UTMDHYA0013");
			locationArray.add("D4250982");
			statusArray.add("D4250982 D4250982 | Aft: D4270982 | 2 x CONT NZPOE  U20G| 2 x CONT NZPOE  U40G | UTMDHYA0033, UTMDHYA0035, UTMDHYA0036, UTMDHYA0034");
			locationArray.add("D4230682");
			statusArray.add("D4230682 D4230682 |  Fwd: D4210682 | 1 x CONT NZPOE  U20G | UTMDHYA0027");
			locationArray.add("D4210682");
			statusArray.add("D4210682 D4210682 | Aft: D4230682 | 1 x CONT NZPOE  U20G | UTMDHYA0026");
			locationArray.add("D4210182");
			statusArray.add("D4210182 D4210182 | Aft: D4230182 | 4 x CONT NZPOE  U40G | UTMDHYA0014, UTMDHYA0015, UTMDHYA0016, UTMDHYA0017 Job: 200");
			locationArray.add("D4210782");
			statusArray.add("D4210782 D4210782 | Aft: D4230782  |  Job: 205");
			locationArray.add("D4211182");
			statusArray.add("D4211182 D4211182 | Aft: D4231182 | 2 x CONT NZPOE  U20G | UTMDHYA0005, UTMDHYA0007 Job: 203");
		else
			mode := "Actual";
			locationArray.clear();
			locationArray.add("D4270682");
			statusArray.add("D4270682 |  Fwd: D4250682 | 4 x CONT NZPOE  U20G | UTMDHYA0020, UTMDHYA0021, UTMDHYA0022, UTMDHYA0023");
			locationArray.add("D4270282");
			statusArray.add("D4270282 |  Fwd: D4250282 | 2 x CONT NZPOE  U20G | UTMDHYA0003, UTMDHYA0004");
			locationArray.add("D4250282");
			statusArray.add("D4250282 | Aft: D4270282 | 1 x CONT NZPOE  U20G | UTMDHYA0002");
			locationArray.add("D4250382");
			statusArray.add("D4250382 | Aft: D4270382 | 2 x CONT NZPOE  U20G| 1 x CONT NZPOE  U40G | UTMDHYA0011, UTMDHYA0012, UTMDHYA0013");
			locationArray.add("D4250982");
			statusArray.add("D4250982 | Aft: D4270982 | 2 x CONT NZPOE  U20G| 2 x CONT NZPOE  U40G | UTMDHYA0033, UTMDHYA0035, UTMDHYA0036, UTMDHYA0034");
			locationArray.add("D4230682");
			statusArray.add("D4230682 |  Fwd: D4210682 | 1 x CONT NZPOE  U20G | UTMDHYA0027");
			locationArray.add("D4210682");
			statusArray.add("D4210682 | Aft: D4230682 | 1 x CONT NZPOE  U20G | UTMDHYA0026");
			locationArray.add("D4210182");
			statusArray.add("D4210182 | Aft: D4230182 | 4 x CONT NZPOE  U40G | UTMDHYA0014, UTMDHYA0015, UTMDHYA0016, UTMDHYA0017");
			locationArray.add("D4231182");
			statusArray.add("D4231182 |  Fwd: D4211182 | 1 x CONT NZPOE  U20G | UTMDHYA0007");
			locationArray.add("D4211182");
			statusArray.add("D4211182 | Aft: D4231182 | 1 x CONT NZPOE  U20G | UTMDHYA0005");
		endif;
	elseif _mode = ShpDisplayMode_Proposed then
		if _modeView = ShpDisplayMode_ColCodeLoad then
			mode := "Load";
			locationArray.clear();
			locationArray.add("D4270682");
			statusArray.add("D4270682 D4270682 |  Fwd: D4250682 | 4 x CONT NZPOE  U20G | UTMDHYA0020, UTMDHYA0021, UTMDHYA0022, UTMDHYA0023");
			locationArray.add("D4211082");
			statusArray.add("D4211082 D4211082 | Aft: D4231082 | 1 x CONT NZAKL  U20G | UTMDHYA0032 Job: 207");
			locationArray.add("D4210682");
			statusArray.add("D4210682 D4210682 | Aft: D4230682 | 2 x CONT NZPOE  U20G| 1 x CONT NZAKL  U40G | UTMDHYA0026, UTMDHYA0031, UTMDHYA0027 Job: 209");
			locationArray.add("D4210182");
			statusArray.add("D4210182 D4210182 | Aft: D4230182 | 4 x CONT NZPOE  U40G | UTMDHYA0014, UTMDHYA0015, UTMDHYA0016, UTMDHYA0017");
			locationArray.add("D4231182");
			statusArray.add("D4231182 D4231182 |  Fwd: D4211182 | 1 x CONT NZPOE  U20G | UTMDHYA0007");
			locationArray.add("D4211182");
			statusArray.add("D4211182 D4211182 | Aft: D4231182 | 1 x CONT NZPOE  U20G | UTMDHYA0005");
		else
			mode := "Proposed";
			locationArray.clear();
			locationArray.add("D4270682");
			statusArray.add("D4270682 |  Fwd: D4250682 | 4 x CONT NZPOE  U20G | UTMDHYA0020, UTMDHYA0021, UTMDHYA0022, UTMDHYA0023");
			locationArray.add("D4270282");
			statusArray.add("D4270282 |  Fwd: D4250282 | 2 x CONT NZPOE  U20G | UTMDHYA0003, UTMDHYA0004");			
			locationArray.add("D4250282");
			statusArray.add("D4250282 | Aft: D4270282 | 1 x CONT NZPOE  U20G | UTMDHYA0002");
			locationArray.add("D4250382");
			statusArray.add("D4250382 | Aft: D4270382 | 2 x CONT NZPOE  U20G| 1 x CONT NZPOE  U40G | UTMDHYA0011, UTMDHYA0012, UTMDHYA0013");
			locationArray.add("D4270982");
			statusArray.add("D4270982 |  Fwd: D4250982 | 1 x CONT NZPOE  U20G | UTMDHYA0034");
			locationArray.add("D4250982");
			statusArray.add("D4250982 | Aft: D4270982 | 1 x CONT NZPOE  U20G | UTMDHYA0033");
			locationArray.add("D4211082");
			statusArray.add("D4211082 | Aft: D4231082 | 1 x CONT NZAKL  U20G | UTMDHYA0032");
			locationArray.add("D4210682");
			statusArray.add("D4210682 | Aft: D4230682 | 2 x CONT NZPOE  U20G| 1 x CONT NZAKL  U40G | UTMDHYA0026, UTMDHYA0031, UTMDHYA0027");
			locationArray.add("D4210182");
			statusArray.add("D4210182 | Aft: D4230182 | 4 x CONT NZPOE  U40G | UTMDHYA0014, UTMDHYA0015, UTMDHYA0016, UTMDHYA0017");
			locationArray.add("D4231182");
			statusArray.add("D4231182 |  Fwd: D4211182 | 1 x CONT NZPOE  U20G | UTMDHYA0007");
			locationArray.add("D4211182");
			statusArray.add("D4211182 | Aft: D4231182 | 1 x CONT NZPOE  U20G | UTMDHYA0005");
		endif;
	endif;
	
	// time to check the details
	index := 1;
	foreach index in 1 to locationArray.size do
		job := null;
		aReq := null;
		locnDefnVoyage := _deck.allROROLocnDefnByCode[locationArray[index]].CM_ROROLocnDefnVoyage;
		self.assertNotEqual(locnDefnVoyage, null);
		detailsToCheck := statusArray[index];
		app.writeLog(detailsToCheck, LogINFO);
		detailsToCheckFromMethod := locnDefnVoyage.getCargoDetails(_mode, _modeView, ShpDisplayModeSub_ExportsHide);
		if _modeView = ShpDisplayMode_ColCodeLoad or _modeView = ShpDisplayMode_ColCodeDisch then
			detailsToCheckFromMethod := locnDefnVoyage.code &amp; " " &amp; detailsToCheckFromMethod;
		endif;
		foreach slotDefn in locnDefnVoyage.allROROSlotDefnByOrdinal discreteLock do
			slotLC := slotDefn.CM_ROROSlotDefnVoyage.mySlotController;
			if _modeView = ShpDisplayMode_ColCodeLoad then
				aReq := slotLC.myRORORequestLoad;
				if aReq &lt;&gt; null then
					job := aReq.myJob.CM_VoyageJob;
					break;
				endif;
			elseif _modeView = ShpDisplayMode_ColCodeDisch then
				aReq := slotLC.myRORORequestDischarge ;
				if aReq &lt;&gt; null then
					job := aReq.myJob.CM_VoyageJob;
					break;
				endif;
			endif;
			
		endforeach;
		if job &lt;&gt; null then
			detailsToCheckFromMethod := detailsToCheckFromMethod &amp; " " &amp; app.getErrorString(Job) &amp; ": " &amp; job.jobNum;
		endif;
		
		//cnwmc5 - added the below for statement for new error checking
		if detailsToCheckFromMethod &lt;&gt; detailsToCheck then
			if not modeWritten then
				_failedArray.add(mode);
				modeWritten := true;
			endif;
			_failedArray.add("Actual:    " &amp; detailsToCheckFromMethod);
			_failedArray.add("Expected:  " &amp; detailsToCheck);
		endif;
		//self.assertEqual(detailsToCheckFromMethod, detailsToCheck);		//cnwmc5 - 8/10/2012 - old error handling, moved to conrtoller method now
	endforeach;
	
epilog

	delete locationArray;
	delete statusArray;

end;</source>
        <Parameter name="_mode" type="Integer"/>
        <Parameter name="_modeView" type="Integer"/>
        <Parameter name="_deck" type="CM_DeckVoyage"/>
        <Parameter name="_failedArray" type="HugeStringArray" usage="io"/>
    </JadeMethod>
    <JadeMethod name="createCargoOnVoyage" id="0d482179-b43c-41e8-91d4-b511df402f21">
        <source>createCargoOnVoyage(_tiArray : CM_TIArray input; _voyage	: CM_Voyage);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 July 2012	cnwmc5	Initial creation

*/
vars
	pxyTI 	: CM_TrackedItem;
	strs	: StringArray;
	theSlot : CM_LocationsController;
	idx 	: Integer;
	cargo 	: CM_TrackedItem;
	thePort : CM_Port;
	
begin
	create strs transient;
	
	thePort := app.myRoot.allPorts[_voyage.myTerminal.getConfig(PortDestCode).String];
	// 20ft containers
	strs.clear;
	strs.add("AUTOLOCN51");
	_voyage.findLocation(strs, false, theSlot, idx);
	cargo := self.addContainerAtLocnDisch("UTMC220001", "2200", "GENL", TI_IMEX_STATUS_EXPORT, theSlot, thePort, _voyage);
	_tiArray.add(cargo);
	
	strs.clear;
	strs.add("AUTOLOCN101");
	_voyage.findLocation(strs, false, theSlot, idx);
	cargo := self.addContainerAtLocnDisch("UTMC220002", "2200", "GENL", TI_IMEX_STATUS_EXPORT, theSlot, thePort, _voyage);
	_tiArray.add(cargo);
	
	// 40ft containers
	strs.clear;
	strs.add("AUTOLOCN351");
	_voyage.findLocation(strs, false, theSlot, idx);
	cargo := self.addContainerAtLocnDisch("UTMC400001", "U40G", "GENL", TI_IMEX_STATUS_EXPORT, theSlot, thePort, _voyage);
	_tiArray.add(cargo);
	
	strs.clear;
	strs.add("AUTOLOCN301");
	_voyage.findLocation(strs, false, theSlot, idx);
	cargo := self.addContainerAtLocnDisch("UTMC400002", "U40G", "GENL", TI_IMEX_STATUS_EXPORT, theSlot, thePort, _voyage);
	_tiArray.add(cargo);
	
	self.assertTrueMsg((_voyage.allOnshipTIsByCargoTypeId.size = 4), "Not All Cargo Produced, Expecting 4 TI's");
	
epilog
	delete strs;
end;</source>
        <Parameter name="_tiArray" type="CM_TIArray" usage="input"/>
        <Parameter name="_voyage" type="CM_Voyage"/>
    </JadeMethod>
    <JadeMethod name="createCargoOnship" id="af28032c-8fb9-451a-a123-678606a5c220">
        <source>createCargoOnship(_voyage : CM_Voyage);
/*
Purpose:			
Date				Who			Reason
SEPTEMBER 2012		NAVAB1		Initial creation
*/

vars
	theSlot : CM_LocationsController;
	cargo : CM_TrackedItem;
	strs : StringArray;
	idx : Integer;
	aPort : CM_Port;
	voyageDeck : CM_DeckVoyage;
	lcs : CM_LCArray;
begin

	aPort := app.myRoot.allPorts[_voyage.myTerminal.getConfig(PortDestCode).String];
	create strs transient;
	
	if _voyage.myROROStructure &lt;&gt; null then
		voyageDeck:=_voyage.myROROStructure.allDecksByCode["D1"];
		if voyageDeck &lt;&gt; null then
			voyageDeck:= voyageDeck.allSubDecks[1];
			if voyageDeck &lt;&gt; null then
				self.addROROVoyageContainers(voyageDeck,false, 35);
				self.addROROVoyageGC(voyageDeck);
				self.addROROVoyageOOTL(voyageDeck);
			endif;
		endif;
	endif;
epilog
	delete lcs;
	delete strs;
end;</source>
        <Parameter name="_voyage" type="CM_Voyage"/>
    </JadeMethod>
    <JadeMethod name="createCargoOnship2" id="9e73095f-0bd3-4404-9f96-a3d2fb8729a4">
        <source>createCargoOnship2(_voyage : CM_Voyage);
/*
Purpose:			
Date				Who			Reason
SEPTEMBER 2012		NAVAB1		Initial creation
*/

vars
	theSlot : CM_LocationsController;
	cargo : CM_TrackedItem;
	strs : StringArray;
	idx : Integer;
	aPort : CM_Port;
	voyageDeck : CM_DeckVoyage;
	lcs : CM_LCArray;
	ti : CM_TrackedItem;
begin

	aPort := app.myRoot.allPorts[_voyage.myTerminal.getConfig(PortDestCode).String];
	create strs transient;
	
	if _voyage.myROROStructure &lt;&gt; null then
		voyageDeck:=_voyage.myROROStructure.allDecksByCode["D1"];
		if voyageDeck &lt;&gt; null then
			self.addROROVoyageContainersNoMix(voyageDeck, true, 20);
			voyageDeck:= voyageDeck.allSubDecks[1];
			if voyageDeck &lt;&gt; null then
				self.addROROVoyageContainers(voyageDeck,false, 30);
			endif;
		endif;
	endif;
	
	// 16/09/2015 cnwmh5
	beginTransaction;
	foreach ti in _voyage.allOnshipTIsByIdCargoType discreteLock do
		ti.setRemarks(self.createdByUnitTest(ti.remarks), true);
	endforeach;
	commitTransaction;
	
epilog
	delete lcs;
	delete strs;
end;</source>
        <Parameter name="_voyage" type="CM_Voyage"/>
    </JadeMethod>
    <JadeMethod name="createGCDCDischJobs" id="bca9c287-b8b0-4f06-a481-0fa7b46205ee">
        <updating/>
        <source>createGCDCDischJobs(_voyage : CM_Voyage io; _deck : CM_DeckVoyage) updating;

/*

Purpose:		Create the discharge jobs for the voyage	

Date			Who		Reason
07/09/2012		cnwmh5	Initial creation

*/

vars

	voyageJob				: CM_VoyageJob;
	loadCC					: CMIF_LoadColorCode;
	realAlloc 				: CM_VoyageAllocation;
	roroController			: CM_VoyageROROController;
	locnDefnVoyage			: CM_ROROLocnDefnVoyage;
	theSlot					: CM_LocationsController;
	
	locnDefnArray			: StringArray;
	strs					: StringArray;
	roroLCs					: CM_LCArray;
	
	locnDefn				: String;
	idx						: Integer;
	
begin

	app.writeLog("Colour coding discharge jobs.  Please wait...", LogINFO);

	create strs transient;
	create locnDefnArray transient;
	locnDefnArray.add("D4230190");
	locnDefnArray.add("D4230192");
	locnDefnArray.add("D4210190");
	locnDefnArray.add("D4210192");
	locnDefnArray.add("D4270690");
	locnDefnArray.add("D4270692");
	locnDefnArray.add("D4211184");
	locnDefnArray.add("D4230782");
	locnDefnArray.add("D4210782");
	locnDefnArray.add("D4210784");
	locnDefnArray.add("D4250984");
	locnDefnArray.add("D4250986");
	
	beginTransaction;
	foreach locnDefn in locnDefnArray do
		strs.clear;
		strs.add(locnDefn);
		_voyage.findLocation(strs, false, theSlot, idx);
		theSlot.CM_ROROSlotController.createDefaultDischargeCC(app.myPassport, true);
	endforeach;
	commitTransaction;
	self.assertNoTrxErrorsOrWarnings();
	
	app.writeLog("Creating discharge jobs.  Please wait...", LogINFO);
	
	create roroLCs transient;
	
	roroLCs.clear();
	self.getJobROROControllerByID(_voyage.code, _deck.code, null, "D4210190", roroLCs, false, 1); 
	self.getJobROROControllerByID(_voyage.code, _deck.code, null, "D4210192", roroLCs, false, 1); 
	voyageJob := self.addVoyageROROJob(_voyage, _deck, "UT_MHQ", roroLCs, true);
	assertTrue(voyageJob &lt;&gt; null);

	roroLCs.clear();
	self.getJobROROControllerByID(_voyage.code, _deck.code, null, "D4270690", roroLCs, false, 1); 
	self.getJobROROControllerByID(_voyage.code, _deck.code, null, "D4270692", roroLCs, false, 1); 
	voyageJob := self.addVoyageROROJob(_voyage, _deck, "UT_MHQ", roroLCs, true);
	assertTrue(voyageJob &lt;&gt; null);
	
	roroLCs.clear();
	self.getJobROROControllerByID(_voyage.code, _deck.code, null, "D4211184", roroLCs, false, 1); 
	voyageJob := self.addVoyageROROJob(_voyage, _deck, "UT_MHQ", roroLCs, true);
	assertTrue(voyageJob &lt;&gt; null);
	
	roroLCs.clear();
	self.getJobROROControllerByID(_voyage.code, _deck.code, null, "D4230782", roroLCs, false, 1); 
	self.getJobROROControllerByID(_voyage.code, _deck.code, null, "D4210782", roroLCs, false, 1); 
	self.getJobROROControllerByID(_voyage.code, _deck.code, null, "D4210784", roroLCs, false, 1); 
	voyageJob := self.addVoyageROROJob(_voyage, _deck, "UT_MHQ", roroLCs, true);
	assertTrue(voyageJob &lt;&gt; null);
	
epilog

	delete locnDefnArray;
	delete strs;
	delete roroLCs;
	
end;</source>
        <Parameter name="_voyage" type="CM_Voyage" usage="io"/>
        <Parameter name="_deck" type="CM_DeckVoyage"/>
    </JadeMethod>
    <JadeMethod name="createGCDCLoadJobsPlan" id="e0157b7c-4070-4997-8880-dc15b87560c9">
        <updating/>
        <source>createGCDCLoadJobsPlan(_voyage : CM_Voyage io; _deck : CM_DeckVoyage) updating;

/*

Purpose:		Create the Load jobs for the voyage	

Date			Who		Reason
07/09/2012		cnwmh5	Initial creation

*/

vars

	voyageJob				: CM_VoyageJob;
	loadCC					: CMIF_LoadColorCode;
	realAlloc 				: CM_VoyageAllocation;
	roroController			: CM_VoyageROROController;
	locnDefnVoyage			: CM_ROROLocnDefnVoyage;
	theSlot					: CM_LocationsController;
	bs						: CM_BlockStack;
	cargo					: CM_TrackedItem;
	
	locnDefnArray			: StringArray;
	strs					: StringArray;
	roroLCs					: CM_LCArray;
	roroLCsHold					: CM_LCArray;
	altRoroLCs				: CM_LCArray;
	tis						: CM_TIArray;
	
	locnDefn				: String;
	idx						: Integer;
	
begin

	// setup ship cargo
	self.opts.purge;
	self.opts.addAssoc("CENum", "123");
	
	app.writeLog("Creating load jobs and containers.  Please wait...", LogINFO);
	
	bs := self.getTerminal().allTerminalAreas["UTMHBSE"].CM_BlockStack;
	self.assertNotNull(bs);
	
	create roroLCs transient;
	create altRoroLCs transient;
	create tis transient;
	create roroLCsHold transient;
	
	roroLCs.clear();
	self.getJobROROControllerByID(_voyage.code, _deck.code, null, "D4211082", roroLCs, true, 1); 
	self.getJobROROControllerByID(_voyage.code, _deck.code, null, "D4231082", roroLCs, true, 1); 
	realAlloc := self.addVoyageAllocation(_voyage, "NZAKL", "U20G", "", TI_CargoType_Container, false, false);
	self.addLCsToROROAllocation(true, realAlloc, roroLCs, altRoroLCs,1);
	roroLCs.copy(roroLCsHold);
	
	roroLCs.clear();
	self.getJobROROControllerByID(_voyage.code, _deck.code,  null,"D4211084", roroLCs, true, 1); 
	realAlloc := self.addVoyageAllocation(_voyage, "NZAKL", "U40G", "", TI_CargoType_Container, false, false);
	self.addLCsToROROAllocation(true, realAlloc, roroLCs, altRoroLCs,1);
	roroLCs.copy(roroLCsHold);
	
	voyageJob:=self.addVoyageROROJob(_voyage, _deck, "UT_MHQ", roroLCsHold, false);
	assertTrue(voyageJob &lt;&gt; null);
	
	roroLCs.clear();
	tis.clear();
	self.getJobROROControllerByID(_voyage.code, _deck.code,  null, "D4211082", roroLCs, true, 1); 
	cargo := self.addContainerAtLocnDisch("UTMDHYA0032", "U20G", "MT", TI_IMEX_STATUS_EXPORT, bs.myLocationsController, app.myRoot.allPorts["NZAKL"], _voyage);
	self.assertNotNull(cargo);
	self.deleteStops(cargo);
	tis.add(cargo);
	self.planTIsRORO(tis, roroLCs, realAlloc.allRequests.first.CM_RORORequest);
	self.assertNoTrxErrorsOrWarnings();
	
	roroLCsHold.clear();
	roroLCs.clear();
	self.getJobROROControllerByID(_voyage.code, _deck.code, null, "D4210684", roroLCs, true, 1); 
	realAlloc := self.addVoyageAllocation(_voyage, "NZAKL", "U40G", "", TI_CargoType_Container, false, false);
	self.addLCsToROROAllocation(true, realAlloc, roroLCs, altRoroLCs,1);
	voyageJob:=self.addVoyageROROJob(_voyage, _deck, "UT_MHQ", roroLCs, false);
	assertTrue(voyageJob &lt;&gt; null);
	
	roroLCs.clear();
	tis.clear();
	self.getJobROROControllerByID(_voyage.code, _deck.code, null, "D4210684", roroLCs, true, 1); 
	cargo := self.addContainerAtLocnDisch("UTMDHYA0031", "U40G", "MT", TI_IMEX_STATUS_EXPORT, bs.myLocationsController, app.myRoot.allPorts["NZAKL"], _voyage);
	self.assertNotNull(cargo);
	self.deleteStops(cargo);
	tis.add(cargo);
	self.planTIsRORO(tis, roroLCs, realAlloc.allRequests.first.CM_RORORequest);
	self.assertNoTrxErrorsOrWarnings();
	
epilog

	self.expectedTrxErrors.clear();
	
	delete locnDefnArray;
	delete strs;
	delete roroLCs;
	delete altRoroLCs;
	delete tis;
	delete roroLCsHold;
	
end;</source>
        <Parameter name="_voyage" type="CM_Voyage" usage="io"/>
        <Parameter name="_deck" type="CM_DeckVoyage"/>
    </JadeMethod>
    <JadeMethod name="createReturnCargoToYardData" id="321c7de4-93aa-409b-889e-95d56d11bfb4">
        <updating/>
        <source>createReturnCargoToYardData(_tiArray : CM_TIArray input; _voyage : CM_Voyage) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 July 2012	cnwmc5	Initial creation

*/

vars
	theJobParams : CMIF_VoyageJobParams;
	theWorkPoint : CM_WorkPoint;
	ti			 : CM_TrackedItem;
	tmpRORO 	 : CM_VoyageROROController;

begin
	create theJobParams transient;
	
	theWorkPoint := addWorkPoint("UTMC01", true);
	
	theJobParams.isDischarge 	:= true;
	theJobParams.useNewMethod 	:= true;
	theJobParams.isExportReturn := true;
	theJobParams.isAutoplan 	:= false;
	theJobParams.isChargable 	:= true;
	theJobParams.id 			:= "200";
	theJobParams.myVoyage 		:= _voyage;
	theJobParams.craneID 		:= theWorkPoint.code;
	theJobParams.myWorkPoint	:= theWorkPoint;
	theJobParams.resquence		:= true;
	theJobParams.isSeqForJob	:= false;
	
	foreach ti in _tiArray do
		tmpRORO := ti.myPrimaryActualLocation.CM_VoyageROROController;
		theJobParams.myDeck	:= tmpRORO.myDeck;
		if (not theJobParams.allROROControllers.includes(tmpRORO)) then
			theJobParams.allROROControllers.add(tmpRORO);
			theJobParams.allObjectEditions.add(tmpRORO);
		endif;
	endforeach;
	
	app.myTrxUA.trxUpdateReturnCargoToYard(theJobParams, _tiArray, app.myPassport);	
	
	//Error checking
	self.assertNoTrxErrorsOrWarnings();
	
	foreach ti in _tiArray do
		self.assertTrueMsg((ti.getVoyageWLEUnactioned(false) &lt;&gt; null), ti.id &amp; " - doesn't have a Work List Entry");
	endforeach;

epilog
	delete theJobParams.myProxyJob;
	delete theJobParams;
end;</source>
        <Parameter name="_tiArray" type="CM_TIArray" usage="input"/>
        <Parameter name="_voyage" type="CM_Voyage"/>
    </JadeMethod>
    <JadeMethod name="createVesselVoyage" id="a6fd47d0-8456-4c2c-8453-7c3a22250a96">
        <updating/>
        <source>createVesselVoyage(_voyage : String; _vessel : String; _operator :CM_Operator) : CM_Voyage updating;
// ---------------------------------------------------------------------------
// Created:     28 May 2010 by NAVAB1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	voyage : CM_Voyage;
	vessel : CM_Vessel; 
	
begin
	voyage := self.getVoyage(null);
	if voyage &lt;&gt; null then
		self.loadAllJobsToOps(voyage, false);
	endif;
	
	deleteVoyage(_voyage);
	deleteVessel(_vessel);
	
	vessel := self.addVesselLOLOholdsRORO(_vessel, self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));
	self.assertNotNullMsg(vessel, 'Add vessel failed');
	self.addVesselDefnReefer40(vessel);

	voyage := self.addVoyageWithConRORO(_voyage, _vessel, self.getProfileSetting(UT_Profile.P_OPERATOR).asString, self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString, null, 0, false, true);
	
	return voyage;
epilog

end;</source>
        <Parameter name="_voyage" type="String"/>
        <Parameter name="_vessel" type="String"/>
        <Parameter name="_operator" type="CM_Operator"/>
        <ReturnType type="CM_Voyage"/>
    </JadeMethod>
    <JadeMethod name="createVoyageLoadJobsVA" id="ad00936d-1146-432b-91d7-afb8c04cc550">
        <updating/>
        <source>createVoyageLoadJobsVA() updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
18 December 2008	cnwer1	Initial creation

*/

vars
	altRoroLCs, roroLCs : CM_LCArray;
	allocBNE, allocSYD, allocMEL 				: CM_VoyageAllocation;
	voyage : CM_Voyage;
	voyageJob : CM_VoyageJob;
	tmpLoadCC	: CMIF_LoadColorCode;
	voyageDeck : CM_DeckVoyage;
	gcDefn : CM_ROROGCDefnVoyage;
	ct : CM_CargoType;
	product: CM_Product;
	layout : CM_RORORequestLayout;
	roroLC : CM_ROROLaneController;
	roroPosLC : CM_ROROLanePositionController;
	theReq : CM_RORORequest;
	aPoint : Point;
	newPoints, oldPoints : PointArray;
	newLength : Integer;
begin
	ct	:= self.getTerminal.getFirstNonSystemCargoType().CM_CargoType;
	product := ct.allProducts.first;

	//create a voyage job for bay 
	
	voyage := self.getVoyage("UTBISH2");
	
	create roroLCs transient;
	create altRoroLCs transient;
	
	if voyage.myROROStructure &lt;&gt; null then
		voyageDeck:=voyage.myROROStructure.allDecksByCode[DECK2];
		

		if voyageDeck &lt;&gt; null then
			allocBNE := self.addVoyageAllocation(voyage, "AUBNE", "", "", ct.id, false, false); // Cannon Balls
			allocSYD := self.addVoyageAllocation(voyage, "AUSYD", "", "", ct.id, false, false); // Cannon Balls
 			allocMEL := self.addVoyageAllocation(voyage, "AUMEL", "", "", ct.id, false, false); // Cannon Balls
 		
			// ### First Lane
			// ##########
			roroLCs.clear();

			self.getJobROROLaneController("UTBISH2",DECK2, roroLCs, true, 1);
			// ### First colour code request
 			self.addLCsToROROAllocation(true, allocBNE, roroLCs, altRoroLCs,1);
			
			// ### Resize it
			roroLC := roroLCs.first.CM_ROROLaneController;
			roroPosLC := roroLC.allLanePositionsLCs.first;

			theReq := roroPosLC.myRORORequestLoad;
			layout := theReq.myLayout;
			self.doResize(layout, 200,0);
			


			// ### Second colour code request
 			self.addLCsToROROAllocation(true, allocMEL, roroLCs, altRoroLCs,1);
			
			// ### Resize it
			roroLC := roroLCs.first.CM_ROROLaneController;
			roroPosLC := roroLC.allLanePositionsLCs.last;
			theReq := roroPosLC.myRORORequestLoad;
			layout := theReq.myLayout;
			self.doResize(layout, 300,0);

			// ### Third colour code request
 			self.addLCsToROROAllocation(true, allocSYD, roroLCs, altRoroLCs,1);
			
			// ### Second Lane
			// ##########
			roroLCs.clear();
			self.getJobROROLaneController("UTBISH2",DECK2, roroLCs, true, 2);

			// ### First colour code request
			self.addLCsToROROAllocation(true, allocSYD, roroLCs, altRoroLCs,1);
			
			// ### Resize it
			roroLC := roroLCs.first.CM_ROROLaneController;
			roroPosLC := roroLC.allLanePositionsLCs.first;
			theReq := roroPosLC.myRORORequestLoad;
			layout := theReq.myLayout;
			self.doResize(layout, 500,250);

			// ### Second colour code request INSERT
			self.addLCsToROROAllocation(true, allocMEL, roroLCs, altRoroLCs,1);
		endif;
	endif;

epilog
	delete newPoints;
	delete altRoroLCs;
	delete roroLCs;
	delete tmpLoadCC;

end;</source>
    </JadeMethod>
    <JadeMethod name="doDLRSOBCCSlots" id="94ed814d-a56a-4149-b90b-2bffa2772c14">
        <source>doDLRSOBCCSlots(_deck : CM_DeckVoyage; _isSubDeck : Boolean; _moveType : Integer; _group : String);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 August 2013	cnwmc5	Initial creation

*/

vars
	locn			: CM_ROROSlotController;
	locnCont		: CM_LocationsController;
	altRoroLCs, 
	roroLCs 		: CM_LCArray;
	theEditions 	: CM_ObjectByOidEditionDict;
	
	voyCode 		: String;
	deckCode 		: String;
	subDeckCode		: String;
	subDeck 		: CM_DeckVoyageSub;
begin
	create roroLCs transient;
	create altRoroLCs transient;
	create theEditions transient;
	
	if _isSubDeck then
		subDeck := _deck.CM_DeckVoyageSub;
		subDeckCode	:= subDeck.code;
		deckCode := subDeck.myParentDeck.code;
		voyCode := subDeck.myParentDeck.myVoyageStructure.myVoyage.code;
	else
		subDeck := null;
		subDeckCode	:= null;
		deckCode := _deck.code;
		voyCode := _deck.myVoyageStructure.myVoyage.code;
	endif;
	
	foreach locn in _deck.allROROSlotControllers do
		if locn.ident.length &gt;= 10 and locn.ident[locn.ident.length:locn.ident.length] = _group then
			if locn.numTIs &lt;&gt; 0
			and not locn.hasColourAttribute then
				self.getJobROROControllerByID(voyCode, deckCode, subDeckCode, locn.ident, roroLCs, false, 1);
			endif;
		endif;
	endforeach;
	
	self.assertNotNull(roroLCs);
	
	roroLCs.copyNoDuplicates(theEditions);
	
	app.myTrxUA.doRORORequestDLRSoB(roroLCs, altRoroLCs, false, _moveType, theEditions, app.myPassport);
	
	self.assertNoTrxErrorsOrWarnings();
epilog
	delete roroLCs;
	delete altRoroLCs;
	delete theEditions;
end;</source>
        <Parameter name="_deck" type="CM_DeckVoyage"/>
        <Parameter name="_isSubDeck" type="Boolean"/>
        <Parameter name="_moveType" type="Integer"/>
        <Parameter name="_group" type="String"/>
    </JadeMethod>
    <JadeMethod name="doResize" id="ff27a85e-881b-42c4-9b34-a55f8207e820">
        <source>doResize(layout : CM_DeckItemLayout input; _leftAdjust : Integer; _rightAdjust : Integer);
/*
Purpose:			
Date		Who		Reason
01 December 2011	NAVAB1	Initial creation
*/

vars
	oldPoints, newPoints : PointArray;
	aPoint : Point;
begin
			oldPoints := layout.myPolygonPixels;
			
			create newPoints transient;

			aPoint.set(oldPoints[2].x - _leftAdjust, oldPoints[1].y);
			newPoints.add(aPoint);
			aPoint.set(oldPoints[2].x - _rightAdjust, oldPoints[2].y);
			newPoints.add(aPoint);
			aPoint.set(oldPoints[3].x - _rightAdjust, oldPoints[3].y);
			newPoints.add(aPoint);
			aPoint.set(oldPoints[2].x - _leftAdjust, oldPoints[4].y);
			newPoints.add(aPoint);
			aPoint.set(oldPoints[2].x - _leftAdjust, oldPoints[1].y);
			newPoints.add(aPoint);
		
			app.myTrxUA.trxUpdateROROGraphicPolygon(layout, newPoints, app.myPassport);

epilog
	delete newPoints;
end;</source>
        <Parameter name="layout" type="CM_DeckItemLayout" usage="input"/>
        <Parameter name="_leftAdjust" type="Integer"/>
        <Parameter name="_rightAdjust" type="Integer"/>
    </JadeMethod>
