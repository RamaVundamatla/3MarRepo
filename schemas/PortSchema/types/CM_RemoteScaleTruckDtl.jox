        <access>readonly</access>
    </PrimAttribute>
    <PrimAttribute name="scalerCode" id="b94ad428-49a0-416b-ade0-bc4f2563efa8">
        <length>31</length>
        <embedded/>
        <type name="String"/>
        <access>readonly</access>
    </PrimAttribute>
    <PrimAttribute name="startTime" id="cbc54c76-9441-4837-a343-f91357c4f872">
        <length>31</length>
        <embedded/>
        <type name="String"/>
        <access>readonly</access>
    </PrimAttribute>
    <PrimAttribute name="supplier" id="75b1e21b-e77f-4e20-9b0c-7451826bc13f">
