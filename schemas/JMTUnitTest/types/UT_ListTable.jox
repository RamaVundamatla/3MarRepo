<GUIClass name="UT_ListTable" id="a1fa0d43-0297-44b7-a20a-e38869faac7f">
    <superclass name="Table"/>
    <transient/>
    <sharedTransientAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>
Custom control which has a column which is a listbox.  A collection
can be attached to the control and it will maintain a list of all the
objects checked (self.allSelectedObjects).</text>
    <DbClassMap file="_usergui"/>
    <Constant name="XMLTag_ListTable" id="45581149-cfc2-44b2-8b78-da4278d2d5bd">
        <source>'listTable'</source>
        <type name="String"/>
    </Constant>
    <Constant name="XMLTag_SelectedValue" id="0f02eb82-7402-4d1d-aaab-49843c0a21bf">
        <source>'selectedValue'</source>
        <type name="String"/>
    </Constant>
    <ImplicitInverseRef name="allSelectedObjects" id="fc1c6629-dcb7-460e-a93c-770b6206d824">
        <memberTypeInverse/>
        <type name="ObjectArray"/>
        <access>readonly</access>
    </ImplicitInverseRef>
