    <JadeMethod name="unload" id="0817930c-0730-480d-9d20-244cae98250a">
        <controlMethod name="Form::unload"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>unload() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29/03/2018	jlgndl1	Initial creation
22/06/2018	jlgdap1	TFS 39355 PEL1 Pilot Surchrages
*/

vars

	invalidObj : Boolean;

begin

	on Exception do app.handleDeletedObject( exception, self.myProxyDrSurRate, invalidObj );
	if self.myProxyDrSurRate &lt;&gt; null then
		delete self.myProxyDrSurRate;
	endif;
	
	on Exception do app.handleDeletedObject( exception, self.myProxyCTSurRate, invalidObj );
	if self.myProxyCTSurRate &lt;&gt; null then
		delete self.myProxyCTSurRate;
	endif;
	
	on Exception do app.handleDeletedObject( exception, self.myProxyAFCharges, invalidObj );
	if self.myProxyAFCharges &lt;&gt; null then
		delete self.myProxyAFCharges;
	endif;
	
	on Exception do app.handleDeletedObject( exception, self.myProxyETTax, invalidObj );
	if self.myProxyETTax &lt;&gt; null then
		delete self.myProxyETTax;
	endif;
	
	on Exception do app.handleDeletedObject( exception, self.myProxyVMCharges, invalidObj );
	if self.myProxyVMCharges &lt;&gt; null then
		delete self.myProxyVMCharges;
	endif;
	
	on Exception do app.handleDeletedObject( exception, self.myProxyDMCharges, invalidObj );
	if self.myProxyDMCharges &lt;&gt; null then
		delete self.myProxyDMCharges;
	endif;
	
	on Exception do app.handleDeletedObject( exception, self.myProxySPCharges, invalidObj );	// TFS 39355
	if self.myProxySPCharges &lt;&gt; null then														// TFS 39355
		delete self.myProxySPCharges;															// TFS 39355
	endif;																						// TFS 39355
	
	//21 Mar 2019	NDL	TFS 43687
	on Exception do app.handleDeletedObject( exception, self.myProxyGMCharges, invalidObj );
	if self.myProxyGMCharges &lt;&gt; null then
		delete self.myProxyGMCharges;
	endif;
	
	inheritMethod();

epilog

end;</source>
    </JadeMethod>
</GUIClass>
