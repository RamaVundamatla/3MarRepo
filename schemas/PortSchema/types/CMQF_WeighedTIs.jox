<Class name="CMQF_WeighedTIs" id="b061349a-d4fa-46aa-b139-85be86055b1e">
    <superclass name="CMQF_TrackedItem"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="query"/>
    <JadeMethod name="filterObjects" id="0753a487-9801-4157-8c65-2180fde5deae">
        <updating/>
        <source>filterObjects(_collection  : Collection input; _passport : CM_Passport) updating;
// ---------------------------------------------------------------------------
// Created:		22 January 2003  by Jason Chapman  (cnwjc2)
// ---------------------------------------------------------------------------
vars
	ti			: CM_TrackedItem;
	breakOut	: Boolean;
	voyage		: CM_Voyage;
	exchangeTxns: CM_TITransactionByTypeDateDict;
	txn			: CM_TITransaction;
begin
	
	voyage := self.getMyVoyage;
	
	if voyage = null then
		return;
	endif;

	// cargo loaded
	foreach ti in voyage.allOnshipTIsByIdCargoType discreteLock do
		if self.checkStatusIncludesObject(ti, _passport, breakOut) then
			if not _collection.includes(ti) then
				_collection.add(ti);
			endif;
		endif;
	endforeach;

	// cargo unloaded and yet to be loaded
	foreach ti in voyage.allOnsiteTIsByIdCargoType discreteLock do
		if self.checkStatusIncludesObject(ti, _passport, breakOut) then
			if not _collection.includes(ti) then
				_collection.add(ti);
			endif;
		endif;

	endforeach;

	// cargo never loaded or unloaded and offsite
	foreach ti in voyage.allOffsiteTIsByIdCargoType discreteLock do
		if self.checkStatusIncludesObject(ti, _passport, breakOut) then
			if not _collection.includes(ti) then
				_collection.add(ti);
			endif;
		endif;
	endforeach;

	create exchangeTxns transient;
	voyage.getExchangeTxns(exchangeTxns);
	//check for cargo that is no longer in the voyages collections
	foreach txn in exchangeTxns where (not txn.deleted) do
		ti := txn.myTrackedItem;
		if ti &lt;&gt; null then
			if not _collection.includes(ti) then	
				if self.checkStatusIncludesObject(ti, _passport, breakOut) then
					_collection.add(ti);
				endif;
			endif;
		endif;
		
	endforeach;

end;</source>
        <Parameter name="_collection" type="Collection" usage="input"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="includesObject" id="1c81ab2a-d863-4bb3-920a-577e2cdebc8c">
        <updating/>
        <source>includesObject(_ti: CM_TrackedItem; _passport : CM_Passport; _breakOut : Boolean output): Boolean updating, protected;
// ---------------------------------------------------------------------------
// Created:		22 January 2003  by Jason Chapman  (cnwjc2)
// ---------------------------------------------------------------------------
vars
	weighTxn		: CM_TITransaction;
	failedDAC  :CM_DataAccessController;
begin

	self.numSearched := self.numSearched + 1;
	weighTxn := _ti.getLastWeighTransaction();
	if weighTxn &lt;&gt; null then
		if (self.myOperator = null or weighTxn.operatorCode.trimBlanks = self.myOperator.code)
		and weighTxn.getVoyage() = self.getMyVoyage		//need to check the voyage here as it may've been weighed under a different voyage
		and _ti.canUserAccessSelf(null, failedDAC,_passport) then
			self.numFound := self.numFound + 1;
			return true;
		endif;
	endif;

	return false;

end;</source>
        <access>protected</access>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_passport" type="CM_Passport"/>
        <Parameter name="_breakOut" type="Boolean" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
