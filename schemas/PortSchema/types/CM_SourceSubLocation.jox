    <JadeMethod name="getAllSubLocations" id="22f8825c-9b41-4fa2-af2c-d396bcc7f45d">
        <source>getAllSubLocations() : String;
/*
Purpose:			
Date		Who		Reason
13 December 2016	cnwab1	Initial creation
*/

vars

begin
	return self.allSubSubLocations.getEntriesAsString();

epilog

end;</source>
