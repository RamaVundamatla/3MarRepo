    <JadeMethod name="matches" id="98982b96-9af5-4f99-bb3f-a0c548a85aa0">
        <source>matches(_ti: CM_TrackedItem): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
28 March 2018	jlgsl4	TFS 37410 Import MTs IMEX transition status

*/

vars
	criteria : CM_YACriteria;

begin

	if _ti = null then
		return false;
	endif;
	
	foreach criteria in self.allCriteria discreteLock do
		if not criteria.isStorageDetailMatch(_ti,null) then
			return false; // if any criterion is unmatched, result is no match
		endif;
	endforeach;
	
	return true;

epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="32417287-3ebc-4401-8fa1-dc2af7c57e4f">
        <source>pxyCreateUpdateProxy(): SelfType;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
28 March 2018	jlgsl4	TFS 37410 Import MTs IMEX transition status

*/

vars
	imexTransition : CM_IMEXTransitionCriteria;
	completedOK : Boolean;
begin
	imexTransition := inheritMethod();
	imexTransition.setBaseData(self.description, self.name, self.myTerminal, self.transitionIMEX);
	completedOK := true;
	
	return imexTransition;

epilog

	if not completedOK then
		delete imexTransition;
	endif;
	
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setBaseData" id="a98d3e00-2716-4f14-8a1b-d8140e06cce5">
