    <JadeMethod name="getColumnCount" id="76168174-f26a-4248-832f-1605cd5c1678">
        <source>getColumnCount( _onDeck : Integer output; _underDeck : Integer output);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 September 2020	jlgndl1	Initial creation	TFS 49963

*/

vars

	iter : Iterator;
	slotCont : CM_SlotController;

begin
	
	iter := self.myBay.allSlotControllersByOrdinal.createIterator;
	while iter.next( slotCont ) do
		if slotCont.ordinalDeck = 1 then //under
			if slotCont.ordinalCell &gt; _underDeck then
				_underDeck := slotCont.ordinalCell;
			endif;
		elseif slotCont.ordinalDeck = 2 then //over
			if slotCont.ordinalCell &gt; _onDeck then
				_onDeck := slotCont.ordinalCell;
			endif;
		endif;
	endwhile;

epilog

	delete iter;

end;</source>
        <Parameter name="_onDeck" type="Integer" usage="output"/>
        <Parameter name="_underDeck" type="Integer" usage="output"/>
    </JadeMethod>
    <JadeMethod name="getLegendsUsed" id="527b77ef-ab8e-40f6-a450-3fb7a841b096">
        <source>getLegendsUsed( _perPageLegendsUsed : CMIF_ScanPlanLegendDict input );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 September 2020	jlgndl1	Initial creation	TFS 49963

*/

vars

	booleanArray : BooleanArray;
	legend : CMIF_ScanPlanLegend;
	attributeIndex : Integer;

begin

	//Add in the legends used by slots in this bay.
	foreach legend in self.allScanPlanLegends do
		_perPageLegendsUsed.addNoDuplicates( legend, false );
	endforeach;

	//find the attributes used in this bay
	create booleanArray transient;
	self.getPrintAttributesUsed( booleanArray, true );
	
	//Add in the legends used by attributes used in this bay.
	foreach attributeIndex in 1 to 14 do
		if booleanArray[attributeIndex] then
			legend := myAgent.findCreateColourLegend( null, attributeIndex, null);
			if legend &lt;&gt; null then
				_perPageLegendsUsed.addNoDuplicates( legend, false );
			endif;
		endif;
	endforeach;

epilog

	delete booleanArray;

end;</source>
        <Parameter name="_perPageLegendsUsed" type="CMIF_ScanPlanLegendDict" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getPrintAttributesUsed" id="245e0a6c-0c62-491d-bf72-580446893201">
        <source>getPrintAttributesUsed( _booleanArray : BooleanArray input; _clearFirst : Boolean );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 September 2020	jlgndl1	Initial creation	TFS 49963

*/

vars

	index : Integer;
	cmifSlot : CMIF_ScanPlanReportSlot;

begin

	if _clearFirst then
		_booleanArray.clear();
		foreach index in 1 to 14 do
			_booleanArray.add(false);
		endforeach;
	endif;
	
	if not _booleanArray[1] then
		if self.myAgent.baysPerPage &lt;= BaysPerPageThree then // Only used in in large print.
			foreach cmifSlot in self.allScanPlanReportSlots do
				if cmifSlot.attr01_Over40Long then
					_booleanArray[1] := true;
					break;
				endif;
			endforeach;
		endif;
	endif;
	
	if not _booleanArray[2] then
		foreach cmifSlot in self.allScanPlanReportSlots do
			if cmifSlot.attr02_HighCube then
				_booleanArray[2] := true;
				break;
			endif;
		endforeach;
	endif;
	
	if not _booleanArray[3] then
		foreach cmifSlot in self.allScanPlanReportSlots do
			if cmifSlot.attr03_OverHeight then
				_booleanArray[3] := true;
				break;
			endif;
		endforeach;
	endif;
	
	if not _booleanArray[4] then
		foreach cmifSlot in self.allScanPlanReportSlots do
			if cmifSlot.attr04_OverLength then
				_booleanArray[4] := true;
				break;
			endif;
		endforeach;
	endif;
	
	if not _booleanArray[5] then
		foreach cmifSlot in self.allScanPlanReportSlots do
			if cmifSlot.attr05_OverWidthRight then
				_booleanArray[5] := true;
				break;
			endif;
		endforeach;
	endif;
	
	if not _booleanArray[6] then
		foreach cmifSlot in self.allScanPlanReportSlots do
			if cmifSlot.attr06_OverWidthLeft then
				_booleanArray[6] := true;
				break;
			endif;
		endforeach;
	endif;
	
	if not _booleanArray[7] then
		foreach cmifSlot in self.allScanPlanReportSlots do
			if cmifSlot.attr07_FlatRack then
				_booleanArray[7] := true;
				break;
			endif;
		endforeach;
	endif;
	
	if not _booleanArray[8] then
		foreach cmifSlot in self.allScanPlanReportSlots do
			if cmifSlot.attr08_Reefer then
				_booleanArray[8] := true;
				break;
			endif;
		endforeach;
	endif;
	
	if not _booleanArray[9] then
		foreach cmifSlot in self.allScanPlanReportSlots do
			if cmifSlot.attr09_MT then
				_booleanArray[9] := true;
				break;
			endif;
		endforeach;
	endif;
	
	if not _booleanArray[10] then
		foreach cmifSlot in self.allScanPlanReportSlots do
			if cmifSlot.attr10_Haz then
				_booleanArray[10] := true;
				break;
			endif;
		endforeach;
	endif;
	
	if not _booleanArray[11] then
		foreach cmifSlot in self.allScanPlanReportSlots do
			if cmifSlot.attr11_SOB_DLR then
				_booleanArray[11] := true;
				break;
			endif;
		endforeach;
	endif;
		
	if not _booleanArray[12] then
		foreach cmifSlot in self.allScanPlanReportSlots do
			if cmifSlot.attr12_ROB then
				_booleanArray[12] := true;
				break;
			endif;
		endforeach;
	endif;
	
	if not _booleanArray[13] then
		foreach cmifSlot in self.allScanPlanReportSlots do
			if cmifSlot.attr13_Tranship then
				_booleanArray[13] := true;
				break;
			endif;
		endforeach;
	endif;
	
	if not _booleanArray[14] then
		foreach cmifSlot in self.allScanPlanReportSlots do
			if cmifSlot.attr14_40_53_Backend then
				_booleanArray[14] := true;
				break;
			endif;
		endforeach;
	endif;

epilog

end;</source>
        <Parameter name="_booleanArray" type="BooleanArray" usage="input"/>
        <Parameter name="_clearFirst" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getTierCount" id="4b6d726c-8a92-469b-a51f-1c47024d6f30">
        <source>getTierCount( _onDeck : Integer output; _underDeck : Integer output);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 September 2020	jlgndl1	Initial creation	TFS 49963

*/

vars

	iter : Iterator;
	slot : CMIF_ScanPlanReportSlot;
	slotCont : CM_SlotController;

begin

	iter := self.allScanPlanReportSlots.createIterator;
	while iter.next( slot ) do
		if slot.ordinalDeck = 1 then //under
			if slot.ordinalTier &gt; _underDeck then
				_underDeck := slot.ordinalTier;
			endif;
		elseif slot.ordinalDeck = 2 then //over
			if slot.ordinalTier &gt; _onDeck then
				_onDeck := slot.ordinalTier;
			endif;
		endif;
	endwhile; 

epilog

	delete iter;

end;</source>
        <Parameter name="_onDeck" type="Integer" usage="output"/>
        <Parameter name="_underDeck" type="Integer" usage="output"/>
    </JadeMethod>
    <JadeMethod name="isTwinBayHold" id="08e343c9-4c40-4c5d-8fb3-811099bf9b22">
        <source>isTwinBayHold():Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 January 2021	jlgndl1	Initial creation	TFS 50541

*/

vars

begin

	if self.myBay.myHold.allBays.size = 2 then
		return true;
	endif;

	return false;

epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setFromBay" id="199e4706-e6ae-4b8c-b9a9-024589f8ecfe">
        <updating/>
        <source>setFromBay( _bay : CM_BayVoyage; _agent : CMIF_ScanPlanReportAgent  )updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 September 2020	jlgndl1	Initial creation	TFS 49963

*/

vars

	slot : CM_SlotController;
	slotCMIF : CMIF_ScanPlanReportSlot;

begin

	self.bayId := _bay.id;
	self.myBay := _bay;
	
	self.myAgent := _agent;
	
	foreach slot in self.myBay.allSlotControllersByOrdinal discreteLock do
		if slot.mySlotDefnVoyage.unavailable then
			continue;
		endif;
		create slotCMIF transient;
		//slotCMIF.setFromSlotController( slot, self );
		slotCMIF.setFromSlotContV3( slot, self );	//20 Jan 2021	NDl	TFS 50539
	endforeach;

epilog

end;</source>
        <Parameter name="_bay" type="CM_BayVoyage"/>
        <Parameter name="_agent" type="CMIF_ScanPlanReportAgent"/>
    </JadeMethod>
</Class>
