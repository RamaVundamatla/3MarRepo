    <JadeMethod name="doUpdateRate" id="cf9978ee-f7c4-40c7-92f6-7572413fb2c7">
        <updating/>
        <source>doUpdateRate()updating;
/*
Purpose - 	if the calculation type changes we need to update the rate
Who - NAVAB1
Date - 13FEB2024
ADO -  CR 61579 TASK 62453
*/

vars
	contractRateEntry , proxyRateEntry		: CM_InvoiceContractRateEntry;
	terminal				: CM_Terminal;
	bank 					: CM_Bank;
	scheduleTSstart 		: TimeStamp;
	scheduleTSend 			: TimeStamp;
	theReturn, idx 			: Integer;
	fromAmount  			: Decimal[23,2];
	toAmount 				: Decimal[23,2];
	rate 					: Decimal [23,4];
	contractrate 			: CM_InvoiceContractRate;
	proxyRate, realRate 	: CM_InvoiceContractRate;
	bulkRates 				: CMIF_InvoiceContractBulkRates;
begin
	self.mousePointer := Window.MousePointer_HourGlass;
	
	if self.myContractRate &lt;&gt; null 
	and self.myCalculationType &lt;&gt; self.myContractRate.myCalculationType then
	
		if app.msgBox("Changing the calculation type changes it on all ranges" &amp; CrLf &amp; "Do you want to continue?", "Confirm", MsgBox_Yes_No) = MsgBox_Return_No then
			self.cmbDeriveQuantity.listObject := self.myContractRate.myCalculationType;
			return;
		endif;
		
		proxyRate := app.createUpdateProxy(self.myContractRate).CM_InvoiceContractRate;
		proxyRate.setProxy(null, self.myService, self.myContractDetail, self.myCalculationType); 
		while true do
			app.myTrxUA.trxUpdateInvContractDtlRt(proxyRate,  app.myPassport);
			if app.myPassport.trxCompletedOK then
				self.clearErrorWarnings();
				self.unloadForm();
				break;
			else
				theReturn := app.showErrorWarningDialog(app.getErrorString(Invoic_contra_rate_entry_creat), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
				if app.myPassport.noErrors and
				   theReturn = IDOK then
					app.myPassport.warningsAcknowledged	:= true;
					continue;
				endif;
				self.setAllErrorWarnings(app.myPassport);
			endif;
			return;
		endwhile;
	endif;

epilog
	delete proxyRate;
	self.mousePointer := Window.MousePointer_Default;
end;</source>
    </JadeMethod>
    <JadeMethod name="doUpdateRateEntries" id="37b895c9-6ae4-496e-871b-93406523d493">
        <updating/>
        <source>doUpdateRateEntries()updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25 October 2023 navmv20 CR 60503 Task 60505: UI - Contract Rate Entry UI Changes
14 Oct 2024 navlc30 JIRA 19508 UI - Contract Enquiry extra tables for results

*/

vars
	proxyRateEntry, contractRateEntry : CM_InvoiceContractRateEntry;
	theReturn : Integer;
	bulkRates,pxyBulkRates : CMIF_InvoiceContractBulkRates;
	scheduleTSstart 		: TimeStamp;
	scheduleTSend 			: TimeStamp;
	fromAmount, toAmount : Decimal[23,4];
	cpu : Decimal[23,6];
	idx : Integer;
	col : Integer;

begin

	self.doUpdateRate(); // ### TFS CR 61579 TASK 62453 13FEB2024 NAVAB1
	
	scheduleTSstart.setDate(self.mskStartDate.text.asDateJMT());
	scheduleTSstart.setTime(self.mskStartTime.text.asTimeJMT());
	scheduleTSend.setDate(self.mskEndDate.text.asDateJMT());
	scheduleTSend.setTime(self.mskEndTime.text.asTimeJMT());

	self.mousePointer := Window.MousePointer_HourGlass;
	
	create bulkRates transient;
	create pxyBulkRates transient;
	
	foreach idx in 2 to self.tblData.rows do
		contractRateEntry := self.tblData.accessRow(idx).itemObject.CM_InvoiceContractRateEntry;
		fromAmount := self.tblData.accessCell(idx,FROM_AMOUNT).text.Decimal;
		toAmount := self.tblData.accessCell(idx,TO_AMOUNT).text.Decimal;
		cpu := self.tblData.accessCell(idx,RATE).text.Decimal;
		if contractRateEntry = null then
			if fromAmount &lt; 0 or toAmount = 0 then // ### JIRA 34344 027MAR 2025 NAVAB1 - Zero is OK for a start
				continue;
			endif;
			create contractRateEntry transient;
			contractRateEntry.setProxy(contractRateEntry.id,cpu,fromAmount,toAmount,scheduleTSstart,scheduleTSend, 
														self.myContractRate, self.myContractRate.myInvoiceContractDetail.myBusinessUnit    );
			pxyBulkRates.allPxyRateEntries.add(contractRateEntry);
		else
			proxyRateEntry := app.createUpdateProxy(contractRateEntry).CM_InvoiceContractRateEntry;
			proxyRateEntry.setProxy(proxyRateEntry.id,cpu,fromAmount,toAmount,scheduleTSstart,scheduleTSend, 
				proxyRateEntry.myInvoiceContractRate, proxyRateEntry.myBusinessUnit);
			bulkRates.allPxyRateEntries.add(proxyRateEntry);
		endif;
	endforeach;
	
	while true do
		app.myTrxUA.trxUpdateAddCntrctRtEntries(bulkRates, pxyBulkRates, app.myPassport);
		if app.myPassport.trxCompletedOK then
			self.clearErrorWarnings();
			app.msgBox(app.getErrorString(Invoi_contr_rate_entri_updat_s), app.getErrorString(Message),MsgBox_OK_Only);
			// ### TFS BUG 61268 28NOV2023 NAVAB1
			if self.myParentForm &lt;&gt; null  
			and self.myParentForm.isKindOf(INV_ContractRateMaint) 						//14.10.2024 navlc30 #19508
			and self.myParentForm.INV_ContractRateMaint.myRateEntryForm = null then
				self.unloadForm();
			endif;
			break;
		else
			theReturn := app.showErrorWarningDialog(app.getErrorString(Invoice_contract_update), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   theReturn = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			self.setAllErrorWarnings(app.myPassport);
		endif;
		break;
	endwhile;
epilog
	self.mousePointer := Window.MousePointer_Default;
	delete bulkRates;

end;</source>
    </JadeMethod>
    <JadeMethod name="getNumberFormat" id="4a48fe96-9cba-47e7-bd49-261021adbe98">
        <source>getNumberFormat(_maxLength, _numDecimalPlaces : Integer output; _increment : Decimal output);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
60505
26/06/2024 navrv30 Bug 64284: FR - 54089 - Invoice Contracts - Derive Quantity on Contract Rate screen
22/07/2024 navrv30 Bug 64284: FR - 54089 - Invoice Contracts - Derive Quantity on Contract Rate screen
*/

vars
	
begin
	if self.myContractDetail &lt;&gt; null then
		if self.myContractDetail.myUnitOfMeasure &lt;&gt; null then
			if self.myContractDetail.myUnitOfMeasure.type = Invoice_UOM_Type_Weight then
				_numDecimalPlaces := 2;
				_maxLength := 21;			//22/07/2024 navrv30 Bug 64284
				_increment := 0.01;
			elseif self.myContractDetail.myUnitOfMeasure.type = Invoice_UOM_Type_Volume then
				_numDecimalPlaces := 2;
				_maxLength := 21;           //22/07/2024 navrv30 Bug 64284
				_increment := 0.01;
			elseif self.myContractDetail.myUnitOfMeasure.type = Invoice_UOM_Type_Quantity then
				_numDecimalPlaces := 0;
				_maxLength := 18;            //22/07/2024 navrv30 Bug 64284
				_increment := 1;
			elseif self.myContractDetail.myUnitOfMeasure.type = Invoice_UOM_Type_TEU then
				_numDecimalPlaces := 0;
				_maxLength := 18;           //22/07/2024 navrv30 Bug 64284
				_increment := 1;
			endif;
		else // ### TFS CR 61579 TASK 62453 13FEB2024 NAVAB1
			_numDecimalPlaces := 0;
			_maxLength := 9;
			_increment := 1;

		endif;
	endif;

epilog

end;</source>
        <Parameter name="_maxLength" type="Integer" usage="output"/>
        <Parameter name="_numDecimalPlaces" type="Integer" usage="output"/>
        <Parameter name="_increment" type="Decimal" usage="output"/>
    </JadeMethod>
    <JadeMethod name="initTableHeading" id="c9d57a2f-ea50-4066-8d99-bad43e183d3c">
        <source>initTableHeading(_tbl : CM_EntryTable io);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
60505

*/

vars
	rateStr : String;
	headingStr : String;
begin
	rateStr := app.getErrorString(Rate);
	if self.myContractDetail &lt;&gt; null then
		if self.myContractDetail.contractType = INV_CONTRACT_TYPE_VOLUME_BASED then
			if self.myContractDetail.myUnitOfMeasure &lt;&gt; null then
				if self.myContractDetail.myUnitOfMeasure.type = Invoice_UOM_Type_Weight then
					headingStr :=app.getErrorString(Weight_from) &amp; Tab &amp; app.getErrorString(WeightKGTo) &amp; Tab &amp; rateStr;
				elseif self.myContractDetail.myUnitOfMeasure.type = Invoice_UOM_Type_Volume then
					headingStr := app.getErrorString(Volume_from) &amp; Tab &amp; app.getErrorString(VolumeM3To) &amp; Tab &amp; rateStr;
				elseif self.myContractDetail.myUnitOfMeasure.type = Invoice_UOM_Type_Quantity then
					headingStr := app.getErrorString(Quantity_from) &amp; Tab &amp; app.getErrorString(QuantityToTo) &amp; Tab &amp; rateStr;
				elseif self.myContractDetail.myUnitOfMeasure.type = Invoice_UOM_Type_TEU then
					headingStr := app.getErrorString(TEUFrom) &amp; Tab &amp; app.getErrorString(TEUTo) &amp; Tab &amp; rateStr;
				endif;
			endif;
		endif;
	endif;
	
	if headingStr = null then
		headingStr := app.getErrorString(Quantity_from) &amp; Tab &amp; app.getErrorString(QuantityToTo) &amp; Tab &amp; rateStr;
	endif;
	
	_tbl.addItem(headingStr);
epilog

end;</source>
        <Parameter name="_tbl" type="CM_EntryTable" usage="io"/>
    </JadeMethod>
    <JadeMethod name="initTblContractRateEntries" id="f4598d5e-f37f-46b6-91b2-8f7106effd96">
        <source>initTblContractRateEntries();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25 October 2023 navmv20 CR 60503 Task 60505: UI - Contract Rate Entry UI Changes

*/

vars
	theTable		: CM_EntryTable;
	entTableDef		: EntTableDef;
	rateStr : String;
	headingStr : String;
	numDecimalPlaces, maxLength : Integer;
	increment : Decimal[3,2];
begin

	theTable := self.tblData;
	theTable.allSelectedObjects.clear;
		
	theTable.rows := 0;
	theTable.columns:= 3;
	theTable.accessColumn(1).inputType := Table.InputType_Default;
	theTable.accessColumn(2).inputType := Table.InputType_Default;
	theTable.accessColumn(3).inputType := Table.InputType_Default;
		
	theTable.readOnly := false;
	theTable.userInputEnabled := true;
	
	self.getNumberFormat(maxLength,numDecimalPlaces, increment);
	
	self.initTableHeading(theTable);

	theTable.fixedRows := 1;
	theTable.fixedColumns := 1;
	
		
	theTable.accessColumn(FROM_AMOUNT).inputType := Table.InputType_TextNumeric;
	theTable.accessColumn(FROM_AMOUNT).decimals := numDecimalPlaces;
	theTable.accessColumn(FROM_AMOUNT).maxLength	:= maxLength;
	theTable.accessColumn(TO_AMOUNT).inputType := Table.InputType_TextNumeric;
	theTable.accessColumn(TO_AMOUNT).decimals := numDecimalPlaces;
	theTable.accessColumn(TO_AMOUNT).maxLength	:= maxLength;
		
	theTable.accessColumn(RATE).inputType := Table.InputType_TextNumeric;
	theTable.accessColumn(RATE).decimals := 4;
	theTable.accessColumn(RATE).maxLength	:= 14;
	self.setColorsForTable(self.tblData);
end;</source>
    </JadeMethod>
