    <JadeMethod name="doClick" id="11186135-be81-47a3-8e11-24fe6b5b7266">
        <source>doClick(_isControlKeyDown : Boolean; _user : CM_User; _terminal : CM_Terminal);
// ---------------------------------------------------------------------------
// Created:     23 January 2003		cnwth2	
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	userDtl			: CM_MenuUserDtl;
	menuAction		: CM_MenuAction;
	tmpClassName	: String;
	tmpClass		: Class;
	ut				: CM_UserTerminal;
	foundExisting	: Boolean;
	errorMessage	: String;
	isSelectorByTerminal : Boolean;
begin
	if self.myMenuDtlSystem = null then
		app.raiseUnexpectedProgramError(class.name, method.name, "Toolbar tool::mySystemMenuItem is null");
		return;
	endif;
	
	if not self.myMenuDtlSystem.isKindOf(CM_MenuDtlNav) then
		app.raiseUnexpectedProgramError(class.name, method.name, "CM_MenuToolbar::myMenuDtlSystem is an invalid type");
		return;
	endif;
	
	if self.myMenuDtlSystem.CM_MenuDtlNav.classNameToCreate = null then
		// Do we need a default class on root (ie CMUI_MenuAction)
	else
		tmpClassName := self.myMenuDtlSystem.CM_MenuDtlNav.classNameToCreate;
	endif;
	
	tmpClass := currentSchema.getClass(tmpClassName);
	if tmpClass = null then
		return;
	endif;
	
	if self.myMenuDtlSystem.isSystemDtl  then
		userDtl := self.myMenuDtlSystem.getMenuUserDtlSystem(_user).CM_MenuUserDtl;
	else
		ut := _user.getUserTerminal(_terminal);
		if ut = null then
			// Par14746 cnwvu1
			if _user.allUserTerminals.isEmpty() then // when a user doesn't have access to all terminals.
				app.raiseCMException( ERR_dontHaveAccessToThisItem, null, self );
				return;
			else	
				//a user doesn't have access to the first terminal, however he has access to the second terminal or third one.
				//After logon, when the Navigator is not open, there is no selected terminal at the first moment. We will make the first accessible terminal selected to avoid exception.
				ut := _user.allUserTerminals.first;
			endif;
		endif;
		
		userDtl := self.myMenuDtlSystem.getMenuUserDtl(ut).CM_MenuUserDtl;
	endif;
	
	if userDtl = null then
		// PAR 17795 - assume if not found that user does not have permission for this
		app.msgBox(app.getErrorString1(VB_SECSHOW, self.heading), "Security Warning", MsgBox_Stop_Icon);
		//app.raiseUnexpectedProgramError(class.name, method.name, 'Menu User Detail object not found');
		return;		
	endif;

	isSelectorByTerminal := ((_terminal &lt;&gt; null) and self.heading = "Selector"); // PAR 20591
	
	
	create menuAction as tmpClass transient;
	
	menuAction.setFromMenuDtl(userDtl, self.myMenuDtlSystem.CM_MenuDtlNav);
	
	if isSelectorByTerminal then // PAR 20591
		menuAction.setPropertyValue(CM_MenuAction::myTerminal.name,_terminal);
	endif;
	
	menuAction.actionFromMenuDtl(not _isControlKeyDown, null);
	
end;</source>
        <Parameter name="_isControlKeyDown" type="Boolean"/>
        <Parameter name="_user" type="CM_User"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="getHeading" id="81806b64-7e95-4e35-bf5b-e711d97dca2c">
        <source>getHeading(): String;
// ---------------------------------------------------------------------------
// Created:     22 January 2003		cnwth2	
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars

begin
	return self.heading;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="isSpecialButton" id="ac3836f0-efe7-482b-889f-f1e58f4b6149">
        <source>isSpecialButton() : Boolean;
// ---------------------------------------------------------------------------
// Created:     18 February 2003		cnwth2	
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
// 21/11/25 navsaa30 MTN-36586 MTN | Add a new Portia Assistant icon to the existing MTN application UI
vars

begin
	if 	self.menuId = CM_MenuToolbar.MENU_ID_EXIT or
		self.menuId = CM_MenuToolbar.MENU_ID_HELP or
		self.menuId = CM_MenuToolbar.MENU_ID_BOT or		//navsaa30 #36586    21/11/25
		self.menuId = CM_MenuToolbar.MENU_ID_LOGOFF or
		self.menuId = CM_MenuToolbar.MENU_ID_NAV or
		self.menuId = CM_MenuToolbar.MENU_ID_SEP then
		return true;
	endif;
	
	return false;

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setFromMenuDtlSystem" id="c15c8ccb-f0a4-4c39-ab45-bb938ec344c1">
        <updating/>
        <source>setFromMenuDtlSystem(_menuDtl : CM_MenuDtlSystem)updating;
// ---------------------------------------------------------------------------
// Created:     21 January 2003		cnwth2	
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	tmpMenuID	: String;
begin
	
	
	self.heading 				:= _menuDtl.heading;
	self.isSystemMenuItem 		:= true;

	// rs nov 2005 dont use instance id as it changes with every build used by constant MenuHdrToolbar_1
	tmpMenuID					:= '_TB' &amp; _menuDtl.menuId[5: _menuDtl.menuId.length];
	self.menuId					:= tmpMenuID;

	self.myMenuDtlSystem		:= _menuDtl;
	self.pictureStringIcon 		:= _menuDtl.pictureStringIcon;
	self.pictureStringButton	:= _menuDtl.pictureStringButton;
	self.pictureStringButtonDown:= _menuDtl.pictureStringButtonDown;
	self.toolTip				:= _menuDtl.heading;
	self.type					:= _menuDtl.type;
	// DVB Added 10/02/2005 to save constant value.
	self.constantValue			:= _menuDtl.constantValue;
	
end;</source>
        <Parameter name="_menuDtl" type="CM_MenuDtlSystem"/>
    </JadeMethod>
