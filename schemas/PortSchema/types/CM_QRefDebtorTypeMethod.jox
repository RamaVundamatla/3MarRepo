    <JadeMethod name="setComboValues" id="b4631a1c-e158-4e77-b9ae-0850fd88ae1c">
        <source>setComboValues(_combo: ComboBox input; _params: CM_QueryCriteriaLineHolder; _queryOperator: CM_QueryOperator; _passport: CM_Passport);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
17 June 2014	cnwjre1	Initial creation 34364

*/

vars
	debtorType	: CM_DebtorType;
	listItem	: Integer;
	
begin
	_combo.clear();
	
	// note - this deliberately includes debtor types with isNotAvailableForEntry set, to allow query of usages of these
	foreach debtorType in app.myRoot.allDebtorTypes do
		listItem := _combo.addItem(debtorType.description);
		_combo.itemObject[listItem] := debtorType;
	endforeach;

	//Highlight selected
	if _queryOperator &lt;&gt; null then
		if _queryOperator.isKindOf(CM_QReferenceLookup) then
			_combo.listObject := _queryOperator.CM_QReferenceLookup.mySelectionValue;
		endif;
	endif;

epilog

end;</source>
        <Parameter name="_combo" type="ComboBox" usage="input"/>
        <Parameter name="_params" type="CM_QueryCriteriaLineHolder"/>
        <Parameter name="_queryOperator" type="CM_QueryOperator"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="setListValues" id="3fe223cd-4af4-4c06-9b43-be01e89998cd">
        <source>setListValues(_tbl: Table input; _params: CM_QueryCriteriaLineHolder; _operator: CM_QueryOperator; _passport: CM_Passport);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 November 2014	cnwma1	Initial creation

*/

vars
	debtorType		: CM_DebtorType;
	debtorDict		: CM_DebtorTypeByCodeDict;
	idx,
	selectionValue	: Integer;
	strArray	: StringArray;
	str : String;
begin
	_tbl.rows := _tbl.fixedRows;
	_tbl.sortColumn[1] := 2; // TFS 7821

	debtorDict := app.myRoot.allDebtorTypes;
	
	foreach debtorType in debtorDict do
		selectionValue := 0;
		if _operator &lt;&gt; null and _operator.CM_QReferenceIsOneOf.allSelectionValues.includes(debtorType) then
			selectionValue := 1;
		endif;
		idx := _tbl.addItem(selectionValue.String &amp; Tab &amp; debtorType.description);
		_tbl.accessRow(idx).itemObject := debtorType;
		_tbl.row := idx;
		_tbl.change(_tbl);
	endforeach;	
	create strArray transient;



	
epilog
	delete strArray;
end;</source>
        <Parameter name="_tbl" type="Table" usage="input"/>
        <Parameter name="_params" type="CM_QueryCriteriaLineHolder"/>
        <Parameter name="_operator" type="CM_QueryOperator"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="setValuesFromList" id="34659fad-9c46-4e1a-8de1-23b2b361035c">
        <source>setValuesFromList(_tbl: Table input; _op: CM_QueryOperator input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 November 2014	cnwma1	Initial creation

*/

vars

	str : String;
	numRows,
	idx : Integer;
	debtorTypeArray : ObjectSet;
	debtorType : Object;

begin

	create debtorTypeArray transient;
	
	numRows := _tbl.rows;
	foreach idx in (_tbl.fixedRows + 1) to numRows do
		str := _tbl.accessCell(idx, 1).text;
		if str = TableCheckBox_Selected then
			debtorType := _tbl.accessRow(idx).itemObject;
			debtorTypeArray.add(debtorType);
		endif;
	endforeach;
	
	_op.setSearchValue(debtorTypeArray);
	
epilog

	delete debtorTypeArray;
	
end;</source>
        <Parameter name="_tbl" type="Table" usage="input"/>
        <Parameter name="_op" type="CM_QueryOperator" usage="input"/>
    </JadeMethod>
    <JadeMethod name="translateToDisplayValue" id="3e8dee61-15b7-4a20-9add-da285cfeec4c">
        <source>translateToDisplayValue(_value: Any): String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
17 June 2014	cnwjre1	Initial creation 34364

*/

vars

begin
	if _value &lt;&gt; null then
		if _value.isKindOf(CM_DebtorType) then
			return _value.CM_DebtorType.description;
		elseif _value.isKindOf(String) then
			return _value.String;
		endif;
	endif;

	return null;


epilog

end;</source>
        <Parameter name="_value" type="Any"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="translateToSearchValue" id="a4c21f7c-32c4-44d2-828e-9a9d538d2a99">
        <source>translateToSearchValue(_value: Any): Any;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
17 June 2014	cnwjre1	Initial creation 34364

*/

vars

begin
	if _value &lt;&gt; null then
		if _value.isKindOf(Collection) then
			return _value;
		endif;

		if _value.isKindOf(CM_DebtorType) then
			return _value.CM_DebtorType;
		endif;
	endif;
	
	return null;


epilog

end;</source>
        <Parameter name="_value" type="Any"/>
        <ReturnType type="Any"/>
    </JadeMethod>
</Class>
