    <JadeMethod name="utlUpdateEDITI" id="122dba16-59ba-49ab-81c9-abe7ecbae7c2">
        <updating/>
        <source>utlUpdateEDITI(_proxyEDITI: CM_EDITrackedItem; _passport: CM_Passport input)updating;
//----------------------------------------------------------------
//	Created:	08 September 2003	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
//04 May 2012	cnwrs1		Par 29531 - EDI Data auditing
// 04 Mar 2019	jlgrs1	TFS 41913 STWR - Reconfiguration of the EDI Operation form to better handle EDI collection locks while loading 
//
vars
	cancelSave		: Boolean;
	realEDITI		: CM_EDITrackedItem;
	expectedEdition	: Integer;
	terminal		: CM_Terminal;
	
begin

	self.initialiseActivity();

	_proxyEDITI.raiseExceptionIfNotProxy(method);

	app.setContinueCMExceptions(true);
	_proxyEDITI.pxyGetRealObjectAndEdition(realEDITI, expectedEdition);
	
	if realEDITI = null then	
		app.raiseCMException1(ProxyMgrCannotLocateReal, CM_EDITrackedItem.name, null, null);
		return;
	endif;

	app.setContinueCMExceptions(false);

	exclusiveLock(realEDITI);

	if _passport.noErrors and realEDITI.edition &lt;&gt; expectedEdition then
		app.raiseCMException1(ObjectUpdatedByAnotherUserSave, 'EDI tracked item ' &amp; realEDITI.id, null, realEDITI);
		return;
	endif;
	
	if _passport.noErrors then
		// This is only required if the class is being auditted
		self.myUpdateAuditAgent.audUpdateGeneric(realEDITI, true);
	endif;

	if _passport.noErrors then
		realEDITI.setForUpdate(_proxyEDITI);
	endif;

	if _passport.noErrors then
		// This is only required if the class is being auditted
		self.myUpdateAuditAgent.audUpdateGeneric(realEDITI, false);
	endif;
	
	// cnwmc5 - 4 September 2014 - PAR 34533
	terminal := realEDITI.getMyTerminal();
	if terminal &lt;&gt; null then
		terminal.causeEvent(terminal.getTerminalEvent(EVENT_EDI_EDITI_UPDATE), false, realEDITI);
	endif;

epilog
	
	
end;</source>
        <Parameter name="_proxyEDITI" type="CM_EDITrackedItem"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateEDITIPackComplete" id="44354f39-9dc8-4bd4-9ca9-b6db77874c3b">
        <updating/>
        <source>utlUpdateEDITIPackComplete(_proxyTI, _realTI: CM_TrackedItem input; _passport: CM_Passport input) updating;
// -----------------------------------------------------------------------------
// Created:		08 Dec 2010 cnwrs1 ccms 1976
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//04 May 2012	cnwrs1		Par 29531 - EDI Data auditing
// -----------------------------------------------------------------------------
vars
	theTransactionController : CMIF_TITransactionController;
	txnControllerDict : CMIF_TITxnContrlrByTypeDTDict;
	preUpdateSubTerm : CM_SubTerminal;	//06 Mar 2018	NDL	TFS 37278
begin

	preUpdateSubTerm := _realTI.mySubTerminal;	//06 Mar 2018	NDL	TFS 37278

	create theTransactionController transient;
	create txnControllerDict transient;

//  Set pack fields on TI (via proxy)
	theTransactionController.myTrackedItem := _realTI;
	theTransactionController.myOtherTrackedItem := null;
	theTransactionController.noCharge := false;
	theTransactionController.type := TRANS_TYPE_PackComplete;
	txnControllerDict.add(theTransactionController);
	
	//update the container 
	app.myUtilityUA.utlUpdateTrackedItem(_proxyTI, null, TI_UPDMODE_NORMAL, txnControllerDict, null, null, _passport);
	if _passport.hasErrors() then
		return;
	endif;
	
	if _passport.noErrors then
		// This is only required if the class is being auditted
		self.myUpdateAuditAgent.audUpdateGeneric(_realTI, true);
	endif;

	// Set any pack complete stops
	if _passport.noErrors then
		_realTI.setStopsToBeApplied(StopApplyPackComplete, true, _passport);
	endif;
	
	//06 Mar 2018	NDL	TFS 37278 - Special case for EDI Pack Complete.
	if app.isSubTerminalsOn(_realTI.myTerminal) then
		_passport.updateSubTermForDeferUpd( preUpdateSubTerm );
	endif;

	if _passport.noErrors then
		// This is only required if the class is being auditted
		self.myUpdateAuditAgent.audUpdateGeneric(_realTI, false);
	endif;
epilog
	delete theTransactionController;
	delete txnControllerDict;
end;</source>
        <Parameter name="_proxyTI" type="CM_TrackedItem" usage="input"/>
        <Parameter name="_realTI" type="CM_TrackedItem" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
