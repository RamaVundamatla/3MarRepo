    <JadeMethod name="calculateTotalTime" id="18f0b3f1-11bb-4924-bb86-aaa34e84b8bc">
        <source>calculateTotalTime( _craneOrWorkPointId : String ):Real protected;
/*		
Date		Who		Reason
23 August 2011	cnwcs5	Initial creation - CCMS MES 1033 / par 27951 RORO KPI
*/
vars
	coll		:CM_TransactionSet;
	firstTran, 
	lastTran 	: CM_Transaction;
	length 		: Real;
	downTime 	: Real;
begin
	coll := self.allTransactions;
	
	if coll.size &lt; 2 then
		length :=  0;
	else
		firstTran	:= coll.first;
		lastTran 	:= coll.last;
		
		downTime := self.myVoyage.getDownHoursForTsRange( _craneOrWorkPointId, firstTran.CM_TITransaction.dateTime, lastTran.CM_TITransaction.dateTime );	//04 Apr 2012	NDL	Par 29369
		
		length := lastTran.CM_TITransaction.dateTime.differenceInHoursReal(firstTran.CM_TITransaction.dateTime);
		
		if downTime &gt; 0 then
			length := length - downTime;
			if length &lt; 0 then
				length := 0;
			endif;
		endif;
	endif;
	
	return length;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_craneOrWorkPointId" type="String"/>
        <ReturnType type="Real"/>
    </JadeMethod>
