// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin
	return self.isoType;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="d6854dc4-925f-4fb2-adc4-a2b56ccab47a">
        <updating/>
        <source>setForUpdate(_proxyTiMaster: SelfType) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
12 August 2008	cnwrd1	Initial creation

*/

vars

begin
	inheritMethod(_proxyTiMaster);
	
	self.isoType := _proxyTiMaster.isoType;
	
//	self.causeEvent(Event_TiMaster_Update, false, null); this is in superclass

epilog

end;
</source>
        <Parameter name="_proxyTiMaster" type="SelfType"/>
    </JadeMethod>
</Class>
