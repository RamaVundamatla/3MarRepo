    <JadeMethod name="getXlatedVoyageCodes" id="840dbf70-0924-46d8-ae00-a073776e1758">
        <source>getXlatedVoyageCodes(_operatorCode : String; _inVoyageCode : String; _outOpVoyageCode, _outVoyVoyageCode : String io; _terminal: CM_Terminal);
//
//25 May 2017	cnwrs1	TFS 4470
//
vars
	voyOperator : CM_Operator;
	opOperator : CM_Operator;
	matchFound : Boolean;
	voyage : CM_Voyage;
begin
	if _inVoyageCode.trimBlanks &lt;&gt; null then
		voyage := _terminal.lookupVoyage(_inVoyageCode, null, true);
		if voyage &lt;&gt; null then
			voyOperator := voyage.myOperator;
			if voyOperator &lt;&gt; null then
				_outVoyVoyageCode := voyOperator.getXlationForeignCode (_inVoyageCode, XLATION_TYPE_VOYAGETERMINAL, matchFound);
			else 
				_outVoyVoyageCode := _inVoyageCode.trimBlanks;
			endif;
		endif;
		opOperator := app.myRoot.allOperators[_operatorCode];
		if opOperator &lt;&gt; null then
			_outOpVoyageCode := opOperator.getXlationForeignCode (_inVoyageCode, XLATION_TYPE_VOYAGETERMINAL, matchFound);
		else //par15042 oct 2007 cnwrs1
			_outOpVoyageCode := _inVoyageCode.trimBlanks;
		endif;
	endif;
end;
</source>
        <Parameter name="_operatorCode" type="String"/>
        <Parameter name="_inVoyageCode" type="String"/>
        <Parameter name="_outOpVoyageCode" type="String" usage="io"/>
        <Parameter name="_outVoyVoyageCode" type="String" usage="io"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="imExStatusToString" id="08126c36-2cb6-47df-85e8-dbcd5f229045">
        <source>imExStatusToString(_ti: CM_TrackedItem): String;
//
//25 May 2017	cnwrs1	TFS 4470
//
vars
	imexString:String;
begin
	if _ti.isRehandle and not _ti.isARework then
		imexString := "5";  //Shifter(restow)
	elseif _ti.isSOB and not _ti.isARework then
		imexString := "5";  //remain on board
	elseif _ti.isExport then
		imexString := "2";
	elseif _ti.isStorage then//for Coarri a storage has been imported
		imexString := "3";
	elseif _ti.isImport then
		imexString := "3";
	elseif _ti.isTranshipItem then
		imexString := "6";  
	else
		imexString := "";
	endif;
	return imexString;
end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="makeMessageLOC" id="2b79f64b-3c06-4e6f-97d9-0668cd8e7552">
        <source>makeMessageLOC(_protocol :CM_CamProtocol; _group :HugeStringArray input; _activity :Integer; _ti :CM_TrackedItem) protected;
//
//25 May 2017	cnwrs1	TFS 4470
// 02 Oct 2017	jlgrs1	TFS 7033 Standard CODECO Corrections
// 11 Oct 2017	jlgrs1	TFS 7358 SNO LOC+147 on discharge on no TDT+10' TDT+30'
// 30 Nov 2017  cnwma1  TFS #7780: SNO - Tranship Discharge needs to use the incoming voyage info
//
vars
	terminal : CM_Terminal;
	code : String;
	fCode : String; 
	pCode : String;
	location : CM_LocationsController;
	ourCode : String;
	foundHeight : Integer;
begin
	terminal := _protocol.terminal;
	ourCode := terminal.getConfig(PortDestCode).String;
	
	
	// LOC+9 - load port
	code := _ti.loadPort.trimRight;
	
	//30.11.2017 cnwma1 TFS #7780
	if _activity = COARRI_SHIPDISCHARGE then
		if _ti.isTranshipItem then
			if _ti.myTranshipDetail &lt;&gt; null then
				if  _ti.myTranshipDetail.importOriginalLoadPort &lt;&gt; null then
					code := _ti.myTranshipDetail.importOriginalLoadPort;
				endif;
			endif;
		endif;
	endif;
	
	fCode := self.getXlatedForeignCode(_protocol.operatorXlationCode.trimBlanks, code, XLATION_TYPE_PORT_BYOP, terminal);
	
	if fCode = null then
		fCode := code.trimRight;
	endif;
	if code = ourCode or fCode = ourCode then
		self.makeLOCSegment(_protocol, _group, '9', fCode, '139', '6', _protocol.camGroup.facilityCode, "TER", "ZZZ");
	else
		self.makeLOCSegment(_protocol, _group, '9', fCode, '139', '6', null, null, null);
	endif;
	if _activity = COARRI_SHIPLOAD then
		// LOC+11 - get the discharge port code
		code := _ti.dischargePort;
		pCode := self.getXlatedForeignCode(_protocol.operatorXlationCode.trimBlanks, code, XLATION_TYPE_PORT_BYOP, terminal);
		
		if pCode = null then
			pCode := code;
		endif;
		
		pCode := pCode.trimRight;
		
		if code = ourCode or pCode = ourCode then
			self.makeLOCSegment(_protocol, _group, '11', pCode, '139', '6', _protocol.camGroup.facilityCode, "TER", "ZZZ");
		else
			self.makeLOCSegment(_protocol, _group, '11', pCode, '139', '6', null, null, null);
		endif;
		// LOC+8 - get the destination port code PAR2836 99/115
		code := _ti.destinationPort;
		pCode := self.getXlatedForeignCode(_protocol.operatorXlationCode.trimBlanks, code, XLATION_TYPE_PORT_BYOP, terminal);
		
		if pCode = null then
			pCode := code;
		endif;
		
		pCode := pCode.trimRight;
		
		if pCode &lt;&gt; null then
			if code = ourCode or pCode = ourCode then
				self.makeLOCSegment (_protocol, _group, '7', pCode, '139', '6', _protocol.camGroup.facilityCode, "TER", "ZZZ");
			else
				self.makeLOCSegment (_protocol, _group, '7', pCode, '139', '6', null, null, null);
			endif;
		endif;
		
		// LOC+147 - setup bay position
		location := _ti.getPrimaryLocation(REAL_MODE);
		
		if location &lt;&gt; null and location.isKindOf(CM_SlotController) and not location.isKindOf(CM_ShipBlockController) then
			self.makeLOCSegment (_protocol, _group, '147', location.CM_SlotController.getStowageId(_ti).trimRight, null, '5', null, null, null);
		endif;
	else
				// LOC+9 - get the discharge port code
		code := _ti.loadPort;
		pCode := self.getXlatedForeignCode(_protocol.operatorXlationCode.trimBlanks, code, XLATION_TYPE_PORT_BYOP, terminal);
		
		if pCode = null then
			pCode := code;
		endif;
		
		pCode := pCode.trimRight;
		terminal.findLocationFromString(_ti.priorStowage, true, location, foundHeight);
		if location &lt;&gt; null and location.isKindOf(CM_SlotController) and not location.isKindOf(CM_ShipBlockController) then
			self.makeLOCSegment (_protocol, _group, '147', location.CM_SlotController.getStowageId(_ti).trimRight, null, '5', null, null, null);
		endif;
//		self.makeLOCSegment(_protocol, _group, '9', pCode, '139', '6', _protocol.camGroup.facilityCode, "TER", "ZZZ");
	endif;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_protocol" type="CM_CamProtocol"/>
        <Parameter name="_group" type="HugeStringArray" usage="input"/>
        <Parameter name="_activity" type="Integer"/>
        <Parameter name="_ti" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="makeMessageSealsData" id="19d661da-0b35-408b-ae10-ba5f95dba1e6">
        <source>makeMessageSealsData(_ti: CM_TrackedItem; _camMessage: CM_CamMessage input; _group: HugeStringArray input; _camProtocol: CM_CamProtocol; _contentsStatus : String );
/* Changes

Date		Name	TFS#		Description
============================================================================
25 May 2017	cnwrs1	TFS 4465
25 May 2017	cnwrs1	TFS 4466 	SNO SEL for MTs
11 Oct 2017	jlgrs1	TFS 7355 	SNO muliple seal numbers
31 Oct 2017	jlgrs1	TFS 7701 	SNO Terminal Operator seals extractings as TO
29 Mar 2019 jlgka1	TFS 44020	Change StringArray to HugeStringArray.
============================================================================*/
vars
	strSeal		: String;
	plus 		: Character;
	singleQuote	: Character;	
	seals 		: HugeStringArray;	//jlgka1 TFS 44020
	sealParty 	: String;
	ventSeal 	: String;
	seal 		: String;
	sealTI 		: CM_SealTI;
begin
//	if _contentsStatus = '4' then
//		//Empty Containers should never include seals data...
//		return;
//	endif;
	
	create seals transient;
	plus := _camProtocol.elementSeparator;	
	singleQuote	:= _camProtocol.segmentTerminator;	
	_ti.getSealNumStringArray(seals, SealType_Operator);
	foreach strSeal in seals do
		if strSeal.trimRight &lt;&gt; "" then	
			_group.add("SEL" &amp; plus &amp; _camProtocol.formatSeal(strSeal) &amp; plus &amp; "CA" &amp; singleQuote);	
		endif;
	endforeach;
	seals.clear();
	_ti.getSealNumCustomsStringArray(seals);
	foreach strSeal in seals do
		if strSeal.trimRight &lt;&gt; "" then		// 12/09/2014 cnwar2 #34897
			_group.add("SEL" &amp; plus &amp; _camProtocol.formatSeal(strSeal) &amp; plus &amp; "CU" &amp; singleQuote);	// 10/05/2011 cnwcs5 par 27460
		endif;
	endforeach;
	seals.clear();
	_ti.getSealNumStringArray(seals, SealType_Shipper);
	foreach strSeal in seals do
		if strSeal.trimRight &lt;&gt; "" then	
			_group.add("SEL" &amp; plus &amp; _camProtocol.formatSeal(strSeal) &amp; plus &amp; "SH" &amp; singleQuote);
		endif;
	endforeach;
	seals.clear();
	_ti.getSealNumStringArray(seals, SealType_TerminalOperator);
	foreach strSeal in seals do
		if strSeal.trimRight &lt;&gt; "" then	
			_group.add("SEL" &amp; plus &amp; _camProtocol.formatSeal(strSeal) &amp; plus &amp; "TO" &amp; singleQuote);
		endif;
	endforeach;
	
	if _ti.isKindOf (CM_Container) then
		seals.clear();
		_ti.getSealNumStringArray(seals, SealType_Vent);
		foreach strSeal in seals do
			if strSeal.trimRight &lt;&gt; "" then
				_group.add("SEL" &amp; plus &amp; _camProtocol.formatSeal(strSeal) &amp; plus &amp; "AB" &amp; singleQuote);
			endif;
		endforeach;
	endif;
	foreach sealTI in _ti.allSeals do
		if sealTI.sealType = SealType_Customs or
		   sealTI.sealType = SealType_Operator or
		   sealTI.sealType = SealType_Shipper or
		   sealTI.sealType = SealType_TerminalOperator or
		   sealTI.sealType = SealType_Vent then
			continue;
		endif;	
		foreach seal in sealTI.allSealNums do
			//27 Aug 2020	NDL	TFS 49974 - Don't report 'unknown' type seals with no 'current' value.
			if _camProtocol.formatSeal(seal).trimBlanks = null then
				continue;
			endif;
			_group.add("SEL" &amp; plus &amp; _camProtocol.formatSeal(seal) &amp; plus &amp; "AB" &amp; singleQuote);
		endforeach;
	endforeach;
epilog
	delete seals;
end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_camMessage" type="CM_CamMessage" usage="input"/>
        <Parameter name="_group" type="HugeStringArray" usage="input"/>
        <Parameter name="_camProtocol" type="CM_CamProtocol"/>
        <Parameter name="_contentsStatus" type="String"/>
    </JadeMethod>
    <JadeMethod name="makeMessages" id="f40ff892-20a4-4609-b75c-d0f686220059">
        <source>makeMessages(_trackedItem: CM_TrackedItem; _transaction: CM_TITransaction; _camProtocol: CM_CamProtocol; _camMessage: CM_CamMessage input; _xlVoyageId: String; _terminal: CM_Terminal; _secondTrx : CM_TITransaction);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25 May 2017	cnwrs1	TFS 4470
25 May 2017	cnwrs1	TFS 4467 SNO FTX+DAR
07/07/2017	cnwdap1	TFS 4492 SNO VERMAS Changes
23/08/2017	cnwma1  TFS #5834-PNL - EDI Translation - ISO Code foreign out
19 Sep 2017	jlgrs1	TFS 6957 Codeco/Coarri VGM extra details
02 Oct 2017	jlgrs1	TFS 7033 Standard CODECO Corrections
11 Oct 2017	jlgrs1	TFS 7358 SNO LOC+147 on discharge on no TDT+10' TDT+30'
19 Jan 2018 cnmwa1	Bug 36613: RE: QNS - RE: COARRI and CODECO Transshipment Discharge/Load
28 Jun 2018	jlgkpd1	TFS 39157 - Protect again null CM_Voyage::myVessel
28 Aug 2018	jlggb1	TFS 40080 No Translation of Tranship Voyage Code
25 Sep 2018	jlggb1	TFS 40947 Correction to 36713
09 Nov 2018	jlgsl4	TFS 39345 - SNO - add LOC+7,LOC+PDS/LOC+11 to TDT+30
20 Mar 2019	jlgsl4	TFS 41786 SNO - output DAM segment for Standard Coarri/Codeco
17 Jul 2019	jlgdap1	TFS 45582 SNO - correct DAM segment formatting
19 Oct 2020 cnwma1  Bug 50155: SNO -- Misplaced segments ( DAM and DGS ) in STANDARD COARRI SMDG162
21 Jun 2022	jlizm1	TFS 53754 LNX Different local and server time zones causing incorrect edi outputs
*/
vars
	fCode 			: String; 
	code 			: String; 
	pCode 			: String;
	temp 			: String; 
	carrierCode 	: String;
	ti 				: CM_TrackedItem;
	exportVoyage 	: String; 
	callSign 		: String; 
	lloydsNumber 	: String; 
	vesselName 		: String;
	contentsStatus  : String;
	isoCode,
	fIsoCode 		: String;
	includeVGM 		: Boolean;
	xlationOperator : CM_Operator;
	foundMatch 		: Boolean;
	ourCode 		: String;
begin
	ourCode := _terminal.getConfig(PortDestCode).String;
	ti := _transaction.myTrackedItem;
	if _camProtocol.useVGM and 
	   _camProtocol.getIncludeExtraVGM and
	   ti &lt;&gt; null and 
	   ti.isWeightCertified and 
	   not ti.isEmpty then		// TFS #2061
		includeVGM := true;
	endif;
	contentsStatus := self.contentsStatusToString(_transaction.contentsStatus,_camMessage.activity, _transaction.type);

	// EQD segment
	//self.makeEQDSegment(_camProtocol, _camMessage.group3, "CN", ti.id.trimRight, ti.CM_Container.isoType, '102', '5', null, self.imExStatusToString(ti),  contentsStatus); 	//23/08/2017 cnwma1 TFS #5834
	isoCode := ti.CM_Container.isoType;
	fIsoCode := self.getXlatedForeignCode(_camProtocol.operatorXlationCode, isoCode, XLATION_TYPE_ISOTYPE_BYOP, _terminal);
	self.makeEQDSegment(_camProtocol, _camMessage.group3, "CN", ti.id.trimRight, fIsoCode, '102', '5', null, self.imExStatusToString(ti),  contentsStatus); 	//23/08/2017 cnwma1 TFS #5834
	
	_camMessage.eqdCount := _camMessage.eqdCount + 1;

	// RFF+BN
	self.makeMessageRFF_BN(_camProtocol, _camMessage.group3,  ti);
	
	// RFF+BM
	self.makeMessageRFF_BM_for_162( _camProtocol, _camMessage.group3, ti );	//26 Jan 2021	NDL	TFS 50708

	// RFF+CN
	self.makeMessageRFF_CN(_camProtocol, _camMessage.group3, ti);

	// RFF+ABT
	self.makeMessageRFF_ABT(_camProtocol, _camMessage.group3,  _camMessage.activity, ti);	

	// DTM - transaction date/time
	self.makeDTMSegment(_camProtocol, _camMessage.group3, self.getDTMFormatQualifier(_camProtocol), _transaction.dateTime, "203"); // TFS 53754
	if includeVGM then
		self.makeMessageDTM_VGM(_camProtocol, _camMessage.group3, ti);					// TFS 4492
	endif;
	
	// LOC segments
	self.makeMessageLOC(_camProtocol, _camMessage.group3, _camMessage.activity, ti);

	// MEA - weight
	self.makeMEASegmentForTotalWeight(_camProtocol, _camMessage.group3, ti, null);
	if ti.weightTare &lt;&gt; 0 then
		self.makeMEASegment(_camProtocol, _camMessage.group3, 'AAE', 'T', 'KGM', ti.weightTare);	
	endif;
	// DIM+ segment
	self.makeMessageDimensionsData(_camProtocol, _camMessage.group3, ti);

	// TMP Segment
	self.makeTMPSegment(_camProtocol, _camMessage.group3, 2, ti.getTemperature, "CEL"); 				

	//the SEL for the seal number
	self.makeMessageSealsData(ti, _camMessage, _camMessage.group3, _camProtocol, contentsStatus);	

	// FTX+AAA+++&lt;goods description&gt;
	temp := ti.getCommodityDesc;
	
	if temp &lt;&gt; null then
		self.makeFTXSegment(_camProtocol, _camMessage.group3, "AAA", null, null, temp);
	endif;
	
	if ti.damaged then  // TFS 41786
		self.makeMessageFTX_Damage(_camProtocol, _camMessage.group3, ti, ":ZZZ:184"); //);// TFS 41786
	else // TFS 41786
		temp := getAVGradeCodeAndDesc(ti, code); // TFS 41786
		self.makeFTXSegment(_camProtocol, _camMessage.group3, "DAR", null, code&amp;":ZZZ:184", "NOT DAMAGED"); // TFS 41786
	endif; // TFS 41786
	
	// Dangerous Goods
	self.makeMessageHazardsData(ti, _camProtocol, _camMessage.group3);	//19.10.2020 cnwma1 #50155
	
	// DAM+ segment
	if ti.damaged and _camProtocol.getProduceDAMSegment() then // TFS 41786
		//self.makeDAMSegment(_camProtocol, _camMessage.group3, '1', '33', null, null, "DAMAGED "&amp; ti.getDamageDetailsDescr[1:70]); // TFS 41786	// TFS 45582
		self.makeMessageDAM(_camProtocol, _camMessage.group3, ti);																					// TFS 45582
	endif; // TFS 41786
		
	// EQA - the only attached equipment is a reefer generator
	self.makeEQASegment(_camProtocol, _camMessage.group3, 'RG', ti);
	
	// ECN/MOT Requirement - TDT+30 (on carriage transport in segment 5)
	// mandatory TDT+30 in group 5
	if ti.isTranshipItem and ti.myExportVoyage &lt;&gt; null and _transaction.getMyVoyage &lt;&gt; ti.myExportVoyage then
		// only has values if tranship
		exportVoyage := ti.myExportVoyage.code;						
		callSign := ti.myExportVoyage.callSign.trimRight;
		if callSign = null and ti.myExportVoyage.myVessel &lt;&gt; null then			// TFS 39157
			callSign := ti.myExportVoyage.myVessel.callSign;
		endif;
		lloydsNumber := ti.myExportVoyage.lloydsNumber;
		if lloydsNumber = null and ti.myExportVoyage.myVessel &lt;&gt; null then		// TFS 39157
			lloydsNumber := ti.myExportVoyage.myVessel.lloydsNumber;
		endif;
		vesselName := ti.myExportVoyage.vesselName.trimRight.toUpper;
	
		if ti.myExportVoyage.myOperator &lt;&gt; null then	
			code := ti.myExportVoyage.myOperator.code;
			xlationOperator := app.myRoot.allOperators[_camProtocol.operatorXlationCode.trimBlanks];
			fCode := app.myRoot.getXlationForeignOperatorCode(xlationOperator, code, foundMatch).trimRight;
			if fCode = null then
				fCode := code;
			endif;
			carrierCode := fCode;
			if xlationOperator &lt;&gt; null then	//19 Mar 2019	NDL	TFS 43463
				fCode := xlationOperator.getXlationForeignCode(exportVoyage, XLATION_TYPE_VOYAGETERMINAL, foundMatch);  //TFS 40080 jlggb1	28/08/2018
				if foundMatch and fCode&lt;&gt; null then
					exportVoyage := fCode;
				endif;
			endif;
		endif;

		if _camProtocol.camGroup.useCallSign then
			if _camMessage.activity = COARRI_SHIPLOAD then
				self.makeTDT10Segment(_camProtocol, _camMessage.group3, exportVoyage, '1', null, carrierCode, '172', '20', null, null, callSign, '103', null, vesselName); // 25/9/2018 jlggb1 40947
			else
				self.makeTDT30Segment(_camProtocol, _camMessage.group3, exportVoyage, '1', null, carrierCode, '172', '20', null, null, callSign, '103', null, vesselName); // 25/9/2018 jlggb1 40947				fCode := ti.destinationPort; // TFS 39345
				if _camProtocol.getCoarri95BLocPDS() then	// TFS 39345 - include LOC+7 and LOC+PDS if configured to do so
					fCode := ti.destinationPort; // TFS 39345
					if fCode &lt;&gt; null then // TFS 39345
						self.makeLOCSegment(_camProtocol, _camMessage.group3, '7', fCode, '139', '6', null, null, null); // TFS 39345
					endif;  // TFS 39345
					fCode := ti.dischargePort; // TFS 39345
					if fCode &lt;&gt; null then // TFS 39345 
						self.makeLOCSegment(_camProtocol, _camMessage.group3, 'PDS', fCode, '139', '6', null, null, null); // TFS 39345
					endif;  // TFS 39345
				endif;  // TFS 39345
			endif;
		else
			if _camMessage.activity = COARRI_SHIPLOAD then
				self.makeTDT10Segment(_camProtocol, _camMessage.group3, exportVoyage, '1', null, carrierCode, '172', '20', null, null, lloydsNumber, '146', null, vesselName); // 25/9/2018 jlggb1 40947
			else
				self.makeTDT30Segment(_camProtocol, _camMessage.group3, exportVoyage, '1', null, carrierCode, '172', '20', null, null, lloydsNumber, '146', null, vesselName); // 25/9/2018 jlggb1 40947
				if _camProtocol.getCoarri95BLocPDS() then	// TFS 39345 - include LOC+7 and LOC+PDS if configured to do so
					fCode := ti.destinationPort; // TFS 39345
					if fCode &lt;&gt; null then // TFS 39345 
						self.makeLOCSegment(_camProtocol, _camMessage.group3, '7', fCode, '139', '6', null, null, null); // TFS 39345
					endif;  // TFS 39345
					fCode := ti.dischargePort; // TFS 39345
					if fCode &lt;&gt; null then // TFS 39345
						self.makeLOCSegment(_camProtocol, _camMessage.group3, 'PDS', fCode, '139', '6', null, null, null); // TFS 39345
					endif;  // TFS 39345
				endif;  // TFS 39345
			endif;
		endif;

	endif;
	

	// NAD+CF
	self.makeMessageNAD_CF(_camProtocol, _camMessage.group3, ti);	
	
	if includeVGM then
		self.makeMessageNAD_VGM(_camProtocol, _camMessage.group3, ti);
	endif;
end;
</source>
        <Parameter name="_trackedItem" type="CM_TrackedItem"/>
        <Parameter name="_transaction" type="CM_TITransaction"/>
        <Parameter name="_camProtocol" type="CM_CamProtocol"/>
        <Parameter name="_camMessage" type="CM_CamMessage" usage="input"/>
        <Parameter name="_xlVoyageId" type="String"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
