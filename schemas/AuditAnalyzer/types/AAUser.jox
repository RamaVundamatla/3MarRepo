<Class name="AAUser" id="9a6c247b-c086-4e2c-bcef-32cbc9465fd2">
    <superclass name="Object"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="auditor"/>
    <PrimAttribute name="index" id="05e1326f-d769-4804-a9cb-faab4b4baa24">
        <embedded/>
        <type name="Integer"/>
    </PrimAttribute>
    <ExplicitInverseRef name="myControl" id="732f2143-6a4d-4f72-8ad4-121d6b690ec0">
        <updateMode>automatic</updateMode>
        <embedded/>
        <type name="AAControl"/>
        <Inverse name="AAControl::users"/>
    </ExplicitInverseRef>
    <ImplicitInverseRef name="myRoot" id="afa5bb77-fd11-47dc-8cab-967693618ceb">
        <embedded/>
        <type name="AARoot"/>
        <access>protected</access>
    </ImplicitInverseRef>
    <PrimAttribute name="name" id="d4c5d2f9-dc28-4d64-bd5d-e19d02de8cca">
        <length>31</length>
        <embedded/>
        <type name="String"/>
    </PrimAttribute>
    <JadeMethod name="create" id="b7068247-68d7-40c9-bfaf-d8ade4030015">
        <updating/>
        <source>create() updating;

vars

begin
	name := "&lt;anon&gt;";
end;
</source>
    </JadeMethod>
    <JadeMethod name="update" id="8a57f768-4ee6-43d4-843f-cff9d54895d6">
        <updating/>
        <source>update(userIndex : Integer; userName : String) updating;

vars

begin
	index := userIndex;
	if userName &lt;&gt; null then
		name  := userName;
	endif;
end;
</source>
        <Parameter name="userIndex" type="Integer"/>
        <Parameter name="userName" type="String"/>
    </JadeMethod>
</Class>
