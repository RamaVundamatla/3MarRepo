    <JadeMethod name="clearFilterTbl" id="4c4259df-3a48-4c39-a85c-3503d0b6cb28">
        <updating/>
        <source>clearFilterTbl(_tbl : CM_DataTable;_txt : CMUI_TextBox input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 Jun 2023	navhl20	ChangeRequest 57747:[57748] EUP - Delivery Dispatch – Allocate Jobs to Gangs
04 Jul 2023 navhl20 Defect 58906: MTN - The Allocated and Unallocated list is not refreshing correctly using the filter criteria
*/

vars
	
begin
	if _tbl = self.tblJobsAllocated then
		self.loadTblAllocated();					//04.7.2023 navhl20 #58906
	elseif	_tbl = self.tblJobsUnallocated then
		self.loadTblUnAllocated();					//04.7.2023 navhl20 #58906
	elseif _tbl = self.tblJobSheet then
		self.loadTblJobSheets();
	endif;
epilog

end;</source>
        <Parameter name="_tbl" type="CM_DataTable"/>
        <Parameter name="_txt" type="CMUI_TextBox" usage="input"/>
    </JadeMethod>
