    <JadeMethod name="jreFixTranMapForDoug" id="e981c081-7fdf-4964-a2cc-0ea54e6373b6">
        <source>jreFixTranMapForDoug();
// CM_TransServiceBroker for CM_Duty and CM_DutyCharge but no myTransactionType, so get duplicate key errors on tran map open
// also an entry for CM_Duty which doesn't exist
vars
	root	: CM_Root;
	tranType	: CM_TransactionType;
	broker		: CM_TransServiceBroker;
begin
	root := CM_Root.firstInstance;
	beginTransaction;
	foreach broker in CM_TransServiceBroker.instances do
		if broker.className &lt;&gt; null and
		   broker.myTransactionType = null then
			foreach tranType in root.allTransactionTypes do
				if tranType.classNameToCreate = broker.className then
					break;
				endif;
			endforeach;
			if broker.className = tranType.classNameToCreate then
				write broker.className &amp; " " &amp; tranType.classNameToCreate;
				broker.setPropertyValue("myTransactionType", tranType);
			else
				write "deleting CM_Duty entry";
				delete broker;
			endif;
		endif;
		if broker.className = "CM_DutyCharge" then
			write "deleting CM_DutyCharge entry";
			delete broker;
		endif;
		
	endforeach;
	commitTransaction;
end;
</source>
    </JadeMethod>
    <JadeMethod name="jreFixTransactionType" id="72fa0786-9e35-4832-a2a2-e2b0818ae86c">
        <source>jreFixTransactionType();

vars
	tranType	: CM_TransactionType;
begin
	beginTransaction;
	foreach tranType in CM_TransactionType.instances do
		if tranType.trxType = 172 then
			tranType.setPropertyValue("description", "Future Storage");
			break;
		endif;
	endforeach;
	commitTransaction;
end;
</source>
    </JadeMethod>
    <JadeMethod name="jreFixView" id="7ca40cf3-7ecb-4166-9ec6-5fe4e847dccd">
        <source>jreFixView();

vars
	rws	: Schema;
	root	: Object;
	view	: Object;
	type	: Object;
	feature	: Object;
	featureName	: String;
begin
	rws := rootSchema.getSchema("JadeReportWriterSchema");
	if rws = null then
		app.writeStatement(method.name&amp;" no report writer schema");
		return;
	endif;
	root := rws.getClass("JRDRoot").firstInstance;
	if root = null then
		app.writeStatement(method.name&amp;" no report writer root");
		return;
	endif;
	
	view := root.getPropertyValue("allReportingViews").MemberKeyDictionary.getAtKey("CM_TrackedItemView");
	if view = null then
		return;
	endif;
	type := view.getPropertyValue("allReportingTypeDefns").MemberKeyDictionary.getAtKey("CM_Log", null);
	if type = null then
		return;
	endif;
	feature := type.getPropertyValue("allReportingFields").MemberKeyDictionary.getAtKey("scalerCode");
	if feature = null then
		return;
	endif;
	// single feature/method 
	beginTransaction;
	//feature.sendMsgWithParams("setPathName","speciesCode");
	feature.sendMsgWithParams("setPathName","scalerCode");
	abortTransaction;
	featureName := feature.sendMsg("getPathname").String;
	write featureName;

	view := root.getPropertyValue("allReportingViews").MemberKeyDictionary.getAtKey("CM_InvoiceView");
	if view = null then
		return;
	endif;
	type := view.getPropertyValue("allReportingTypeDefns").MemberKeyDictionary.getAtKey("CM_Voyage", null);
	if type = null then
		return;
	endif;
	feature := type.getPropertyValue("allReportingFields").MemberKeyDictionary.getAtKey("operatorCode");
	if feature = null then
		return;
	endif;
	// path
	beginTransaction;
	//feature.sendMsgWithParams("setPathName","myOperator.getName");
	feature.sendMsgWithParams("setPathName","myOperator.code");
	abortTransaction;
	featureName := feature.sendMsg("getPathname").String;
	write featureName;
end;
</source>
    </JadeMethod>
    <JadeMethod name="jreGetInvoiceType" id="97a664fc-cdb1-492e-973a-a0aa55fbad01">
        <source>jreGetInvoiceType(_bank : CM_Bank; _invType : CM_InvoiceDesc) : CM_InvoiceDesc;
// called from jreCheckInterTermInvoicing
vars
	invType		: CM_InvoiceDesc;
begin
	foreach invType in _bank.invoiceTypes do
		if invType.accrualType = _invType.accrualType and
		   invType.invoiceKey = _invType.invoiceKey and
		   invType.invoiceType = _invType.invoiceType and
		   invType.triggerOnAction = _invType.triggerOnAction then
			write method.name&amp;" found " &amp; invType.description;
			return invType;
		endif;
	endforeach;
	
	// not found, create one
	create invType persistent;
	invType.setPropertyValue("company", _bank);
	///invType.initialise();
	invType.accrualType := _invType.accrualType;
	invType.arrNarrationDesc.clear;
	_invType.arrNarrationDesc.copy(invType.arrNarrationDesc);
	invType.description := _invType.description;
	invType.invoiceKey := _invType.invoiceKey;
	invType.invoiceType := _invType.invoiceType;
	invType.setPropertyValue("myFinancialPeriodEnd", _invType.myFinancialPeriodEnd);
	invType.setPropertyValue("myInvTermsOfTrade", _invType.myInvTermsOfTrade);
	invType.printSingleLineForDayType := _invType.printSingleLineForDayType;
	invType.triggerOnAction := _invType.triggerOnAction;
	invType.setPropertyValue("invoiceGenerationDateFrom", _invType.invoiceGenerationDateFrom);
	invType.setPropertyValue("invoiceGenerationDateTo", _invType.invoiceGenerationDateTo);
	invType.setPropertyValue("invoiceGenerationStatus", _invType.invoiceGenerationStatus);
	invType.setPropertyValue("externalReference", _invType.externalReference);
	write method.name&amp;" created " &amp; invType.description;
	
	return invType;
end;
</source>
        <Parameter name="_bank" type="CM_Bank"/>
        <Parameter name="_invType" type="CM_InvoiceDesc"/>
        <ReturnType type="CM_InvoiceDesc"/>
    </JadeMethod>
    <JadeMethod name="jreInvoicePropsText" id="c8a5838b-40d7-4f4b-b606-ab6e04abaf25">
        <source>jreInvoicePropsText();
// no references
vars
	msg		: String;
	cls		: Class;
	subs	: ClassColl;
	props	: PropertyNDict;
	prop	: Property;
begin
	cls := rootSchema.getSchema("PortSchema").getClass(CM_FinancialObject.name);
	create subs transient;
	cls.getSubclasses(subs);
	foreach cls in subs do
		props := cls.getProperties();
		foreach prop in props do
			if prop.text &lt;&gt; null then
				write cls.name &amp; ' ' &amp; prop.name &amp; ' ' &amp; prop.text;
			endif;
		endforeach;
	endforeach;
	
epilog
	delete subs;
end;
</source>
    </JadeMethod>
    <JadeMethod name="jreListChargeDays" id="a0d75e90-f68b-482b-9421-b6248cd83c21">
        <source>jreListChargeDays(_recDate, _relDate : Date; _inclFirst, _inclLast : Boolean) : Integer protected;

vars
	days	: Integer;
	fcd, lcd	: Date;
begin
	if _inclFirst then
		fcd :=_recDate;
	else
		fcd := _recDate + 1;
	endif;
	if _inclLast then
		lcd := _relDate;
	else
		lcd := _relDate - 1;
	endif;
	
	days := lcd - fcd + 1;
	return days;
end;
</source>
        <access>protected</access>
        <Parameter name="_recDate" type="Date"/>
        <Parameter name="_relDate" type="Date"/>
        <Parameter name="_inclFirst" type="Boolean"/>
        <Parameter name="_inclLast" type="Boolean"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="jreListFreeChargeDays" id="c8d72615-d807-439e-95a8-ae9be15e5038">
        <source>jreListFreeChargeDays(_recDate, _relDate : Date; _inclFirst, _inclLast : Boolean; _freeDays : Integer) : String protected;
// calculations with non-zero free days
vars
	days		: Integer;
	fcd, lcd	: Date;		// first and last charged days
	lfd			: Date;		// last free date
	result		: String;
begin
	if _inclFirst then
		lfd := _recDate + _freeDays - 1;
	else
		lfd := _recDate + _freeDays;
	endif;
	if _inclLast then
		lcd := _relDate;
	else
		lcd := _relDate - 1;
	endif;
	fcd := lfd + 1;		// first charged day
	// case 1: within free storage period
	if _relDate &lt;= lfd then
		result := "In free storage - no transactions";
		return result;
	endif;
	
	// case 2: past free storage
	// create a no-charge storage, dated the last free day
	result := "No-charge storage created for " &amp; lfd.String &amp; ". ";
	days := lcd - fcd;		// number of days difference
	if days &lt;= 0 then
		result := result &amp; days.String &amp; " no second storage created.";
	else
		// create a charged storage, dated the release date
		result := result &amp; days.String &amp; " second storage created for " &amp; _relDate.String &amp; ".";
	endif;
	return result;
end;
</source>
        <access>protected</access>
        <Parameter name="_recDate" type="Date"/>
        <Parameter name="_relDate" type="Date"/>
        <Parameter name="_inclFirst" type="Boolean"/>
        <Parameter name="_inclLast" type="Boolean"/>
        <Parameter name="_freeDays" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="jreListFreeStorageOptions" id="99223ff4-81cf-4dc0-99c1-46d49962f599">
        <source>jreListFreeStorageOptions();
// cycle around free storage variants/options (no free days)
vars
	count		: Integer;
	freeDays	: Integer;
	charge, free		: Integer;
	recDate, relDate	: Date;
	fcd, lcd	: Date;
	includeFirst, includeLast	: Boolean;
begin
	freeDays := 0;
	recDate := "01/01/2013".Date;
	write freeDays.String &amp; " free days";
	write "Receive date,Release Date,Include first,Include last,Charge days,Free Days";
	foreach count in 0 to 10 do
		relDate := recDate + count;
		includeFirst := false; includeLast := false;
		charge := self.jreListChargeDays(recDate, relDate, includeFirst, includeLast);
		write recDate.String &amp; "," &amp; relDate.String &amp; "," &amp; includeFirst.String &amp; "," &amp; includeLast.String &amp; "," &amp; charge.String &amp; "," &amp; free.String;
		includeFirst := false; includeLast := true;
		charge := self.jreListChargeDays(recDate, relDate, includeFirst, includeLast);
		write recDate.String &amp; "," &amp; relDate.String &amp; "," &amp; includeFirst.String &amp; "," &amp; includeLast.String &amp; "," &amp; charge.String &amp; "," &amp; free.String;
		includeFirst := true; includeLast := false;
		charge := self.jreListChargeDays(recDate, relDate, includeFirst, includeLast);
		write recDate.String &amp; "," &amp; relDate.String &amp; "," &amp; includeFirst.String &amp; "," &amp; includeLast.String &amp; "," &amp; charge.String &amp; "," &amp; free.String;
		includeFirst := true; includeLast := true;
		charge := self.jreListChargeDays(recDate, relDate, includeFirst, includeLast);
		write recDate.String &amp; "," &amp; relDate.String &amp; "," &amp; includeFirst.String &amp; "," &amp; includeLast.String &amp; "," &amp; charge.String &amp; "," &amp; free.String;
	endforeach;
end;
</source>
    </JadeMethod>
    <JadeMethod name="jreListFreeStorageOptions2" id="8e42da29-6783-41d5-bb87-416d5401ad8a">
        <source>jreListFreeStorageOptions2();
// cycle around free storage variants/options (with free days)
vars
	count		: Integer;
	freeDays	: Integer;
	recDate, relDate	: Date;
	includeFirst, includeLast	: Boolean;
	msg			:String;
begin
	freeDays := 2;
	recDate := "01/01/2013".Date;
	write freeDays.String &amp; " free days";
	write "Receive date,Release Date,Include first,Include last,Result";
	foreach count in 0 to freeDays + 3 do
		relDate := recDate + count;
		includeFirst := false; includeLast := false;
		msg := self.jreListFreeChargeDays(recDate, relDate, includeFirst, includeLast, freeDays);
		write recDate.String &amp; "," &amp; relDate.String &amp; "," &amp; includeFirst.String &amp; "," &amp; includeLast.String &amp; "," &amp; msg;
		includeFirst := false; includeLast := true;
		msg := self.jreListFreeChargeDays(recDate, relDate, includeFirst, includeLast, freeDays);
		write recDate.String &amp; "," &amp; relDate.String &amp; "," &amp; includeFirst.String &amp; "," &amp; includeLast.String &amp; "," &amp; msg;
		includeFirst := true; includeLast := false;
		msg := self.jreListFreeChargeDays(recDate, relDate, includeFirst, includeLast, freeDays);
		write recDate.String &amp; "," &amp; relDate.String &amp; "," &amp; includeFirst.String &amp; "," &amp; includeLast.String &amp; "," &amp; msg;
		includeFirst := true; includeLast := true;
		msg := self.jreListFreeChargeDays(recDate, relDate, includeFirst, includeLast, freeDays);
		write recDate.String &amp; "," &amp; relDate.String &amp; "," &amp; includeFirst.String &amp; "," &amp; includeLast.String &amp; "," &amp; msg;
	endforeach;
end;
</source>
    </JadeMethod>
    <JadeMethod name="jreLoadInvoiceStuff" id="5b8149e6-7fb9-4e3f-ab31-cef592656a6d">
        <source>jreLoadInvoiceStuff();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
27 May 2015	cnwjre1	Initial creation

*/

vars
	terminal	: CM_Terminal;
	bank		: CM_Bank;
	agent		: CM_ExtractLoadAgent;
	file		: File;
begin
	app.initialize();

	terminal := CM_Root.firstInstance.allTerminals["JT1"];
	bank := terminal.companies["COMP"];
	
	create agent transient;
	create file transient;
	file.kind := File.Kind_Unknown_Text;	// 29/2/16 cnwmp6 PAR 36286 unicode version
	file.openInput("c:\temp\GLCodes.xml");
	agent.loadGLCodes(file, bank);
	file.close;
	file.openInput("c:\temp\InvoiceTypes.xml");
	agent.loadInvoiceTypes(file, bank);
	file.close;
	file.openInput("c:\temp\Services.xml");
	agent.loadServices(file, bank);
	file.close;
	file.openInput("c:\temp\InvoiceLineTypes.xml");
	agent.loadInvoiceLineTypes(file, bank);
	
epilog
	delete agent;
	if file &lt;&gt; null then
		if file.isOpen then
			file.close();
		endif;
		delete file;
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="jreMissingCashPayments" id="a8f05aed-7181-441c-be44-2aaf23b1220e">
        <source>jreMissingCashPayments();
// from 35443 where some invoice lines missed having payments applied at gate out
vars
	cr	: CM_CashReceipt;
	cp	: CM_CashPayment;
	il	: CM_InvoiceLine;
	ti	: CM_TrackedItem;
	offsiteCount	: Integer;
	cashTotal,
	payTotal1,
	payTotal2	: Decimal[16,6];
begin
	foreach cr in CM_CashReceipt.instances do
		cashTotal := cr.cashValue;
		payTotal1 := 0;
		foreach cp in cr.allCashPayments do
			if not cp.voided then
				payTotal1 := payTotal1 + cp.cashValue;
			endif;
		endforeach;
		payTotal2 := 0;
		foreach ti in cr.allTrackedItems do
			if ti.isOffSite then
				offsiteCount := offsiteCount + 1;
			endif;
			foreach il in ti.invoiceLines do
				foreach cp in il.allCashPayments do
					if cp.voided then
						continue;
					endif;
					payTotal2 := payTotal2 + cp.cashValue;
				endforeach;
				payTotal2 := payTotal2 - il.lineTotal;
			endforeach;
		endforeach;
		write cr.externalInvoiceNumber &amp; " receipt=" &amp; cashTotal.String &amp; " payments=" &amp; payTotal1.String &amp; " TI missing payments=" &amp; payTotal2.String
			&amp; " offsite=" &amp; offsiteCount.String;
	endforeach;
end;
</source>
    </JadeMethod>
    <JadeMethod name="jreOffsiteProformaPayments" id="6670af81-1da4-4360-a80c-6323c02c2fe0">
        <source>jreOffsiteProformaPayments();
// from 35464 where some released cargo still has proforma payments
vars
	cr	: CM_CashReceipt;
	cp	: CM_CashPayment;
	ti	: CM_TrackedItem;
	ad	: CMIF_AgentDebtor;
	oa	: ObjectArray;
	tiCount			: Integer;
	offsiteCount	: Integer;
	profCount		: Integer;
	cashTotal,
	payTotal1,
	payTotal2	: Decimal[16,6];
begin
	create oa transient;
	foreach cr in CM_CashReceipt.instances do
		cashTotal := cr.cashValue;
		payTotal1 := 0;
		foreach cp in cr.allCashPayments do
			if not cp.voided then
				payTotal1 := payTotal1 + cp.cashValue;
			endif;
		endforeach;
		profCount := 0;
		offsiteCount := 0;
		tiCount := 0;
		foreach ti in cr.allTrackedItems do
			tiCount := tiCount + 1;
			if ti.isOffSite then
				offsiteCount := offsiteCount + 1;
				foreach cp in ti.allCashPayments do
					if cp.voided then
						continue;
					endif;
					if cp.isProformaPayment then
						profCount := profCount + 1;
					endif;
				endforeach;
			endif;
		endforeach;
		if offsiteCount &gt; 0 and profCount &gt; 0 then
			create ad transient;
			ad.debtorAddress := cr.externalInvoiceNumber &amp; " " &amp; cr.dateTime.String &amp; " receipt value=" &amp; cashTotal.String &amp; " payments=" &amp; payTotal1.String &amp; " proforma count=" &amp; profCount.String
				&amp; " offsite count=" &amp; offsiteCount.String &amp; " of " &amp; tiCount.String;
			oa.add(ad);
		endif;
	endforeach;
	oa.inspectModal;
	oa.purge;
	delete oa;
end;
</source>
    </JadeMethod>
    <JadeMethod name="jreOpenInvoices" id="7c2399c6-8489-4b56-adb6-686f2c2b975c">
        <source>jreOpenInvoices();

vars
	status		: Integer;
	count		: Integer;
	debtor		: CM_Debtor;
	debtorNode	: CM_DebtorNode;
	invoice		: CM_Invoice;
	iter 		: Iterator;
	oa			: ObjectArray;
	obj			: Object;
begin

	create oa transient;
	CM_DebtorNode.allInstances(oa, 0, true);
	foreach obj in oa do
		debtorNode := obj.CM_DebtorNode;
		if debtorNode.isKindOf(CM_Debtor) then
			debtor := debtorNode.CM_Debtor;
			delete iter;
			count := 0;
			status := CM_Invoice.INVOICE_OPEN;
			iter := debtor.invoicesByStatus.createIterator();
			debtor.invoicesByStatus.startKeyGeq(status, iter);
			while iter.next(invoice) do
				if invoice.status &lt;&gt; status then
					break;
				endif;
			
				count := count + 1;
			endwhile;
			write debtor.String &amp; " " &amp; debtor.name &amp; " open invoices " &amp; count.String;

			delete iter;
			count := 0;
			status := CM_Invoice.INVOICE_SUSPENSE;
			iter := debtor.invoicesByStatus.createIterator();
			debtor.invoicesByStatus.startKeyGeq(status, iter);
			while iter.next(invoice) do
				if invoice.status &lt;&gt; status then
					break;
				endif;
		
				count := count + 1;
			endwhile;
			write debtor.name &amp; " suspense invoices " &amp; count.String;
		endif;
	endforeach;
epilog
	delete iter;
	delete oa;
end;</source>
    </JadeMethod>
    <JadeMethod name="jrePrintSteinwegLabel" id="7e586807-30c9-43e6-b2ed-17d988733e96">
