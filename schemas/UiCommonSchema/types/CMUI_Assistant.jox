    <JadeMethod name="comboBoxCraneArea" id="d3c3ce68-be00-4d8c-a9cd-2070f30db81d">
        <source>comboBoxCraneArea(_cmb:ComboBox input; _craneTransferArea:CM_CraneTransferArea; _terminal : CM_Terminal);
// ---------------------------------------------------------------------------
// Created:		25 March 2003  by Jason Chapman  (cnwjc2)
// ---------------------------------------------------------------------------

vars
	taType			: CM_TerminalAreaType;
	ta				: CM_TerminalAreaMaster;
	taDict			: CM_TAByTerminalIdDict;		
begin

	_cmb.sorted := false;
	_cmb.clear();
	
	if _terminal = null then
		return;
	endif;
	
	foreach ta in _terminal.allTerminalAreas do
		if ta.isKindOf(CM_CraneTransferArea) then
			_cmb.itemObject[_cmb.addItem(ta.id)] := ta;
		endif;
	endforeach;

	if _craneTransferArea &lt;&gt; null then
		_cmb.text := self.displayEntryCraneArea(_craneTransferArea);
		_cmb.listObject := _craneTransferArea;
	endif;

end;</source>
        <Parameter name="_cmb" type="ComboBox" usage="input"/>
        <Parameter name="_craneTransferArea" type="CM_CraneTransferArea"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="comboBoxCraneLaneDescription" id="06d71066-0803-47a6-857e-dc9177ffa22a">
        <source>comboBoxCraneLaneDescription(_cmb : CMUI_ComboBox input; _val : String);

// Created by cnwdvb1 on 09 August 2006
vars

	idx		: Integer;
	lstIdx	: Integer;
//	printer	: CM_PrinterDef;	
	
begin

	_cmb.clear;
	_cmb.addItem(app.getErrorString(None));
	
	_cmb.addItem(app.getErrorString(North_South));
	_cmb.addItem(app.getErrorString(South_North));
	_cmb.addItem(app.getErrorString(West_East));
	_cmb.addItem(app.getErrorString(East_West) );
	_cmb.addItem(app.getErrorString(Left_Right));
	
	idx := _cmb.findStringExact(1,_val);
	
	_cmb.listIndex := idx;
	
end;</source>
        <Parameter name="_cmb" type="CMUI_ComboBox" usage="input"/>
        <Parameter name="_val" type="String"/>
    </JadeMethod>
    <JadeMethod name="comboBoxCranes" id="78f53b58-6e71-4823-9fce-5212199a4bc1">
        <source>comboBoxCranes(_cmb : CMUI_ComboBox input; _terminal : CM_Terminal input);
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
27 July 2011	cnwer1	Initial creation CCMS MES 1033

*/

vars
	theMachines : CM_MachineSet;
	mach			: CM_Machine;
begin
	create theMachines transient;
	_terminal.getAllMachines(theMachines,true);
	foreach mach in theMachines 
	where (mach.available and not mach.isNotAvailableForEntry) do	// 16/05/2012 cnwar2 #28342
		_cmb.addItemObject(mach.id,mach);
	endforeach;	
epilog
	delete theMachines;


end;</source>
        <Parameter name="_cmb" type="CMUI_ComboBox" usage="input"/>
        <Parameter name="_terminal" type="CM_Terminal" usage="input"/>
    </JadeMethod>
    <JadeMethod name="comboBoxCriteriaType" id="951f5dff-d743-421b-a96c-c9fdd1b112e5">
        <source>comboBoxCriteriaType(_table : CM_EntryTable input; _attrName, _value : String);
/*
Date		Who		Reason
23/122012	cnwcs5	Initial creation - par 29158 EDI Booking Cutoff
*/
vars
	row	: Integer;	
begin
	row := _table.getRow(_attrName);
	
	_table.setComboValues(row, CM_ReceivalCutoffTermDef.CriteriaType_CARGO_Desc &amp; Tab &amp; 
								CM_ReceivalCutoffTermDef.CriteriaType_EDI_Desc);

	if _value &lt;&gt; null then
		_table.setValue(row, _value);
	endif;
	
end;</source>
