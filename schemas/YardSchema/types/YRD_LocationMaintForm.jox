    <JadeMethod name="initForm" id="38192c8f-fc2b-44c9-b6f7-a57745fbc9de">
        <updating/>
        <source>initForm() updating;
// ---------------------------------------------------------------------------
// Created:		August  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 06/11/2012	cnwcs5		par 30475 - removing location restrictions
// ---------------------------------------------------------------------------
vars
	
begin

	if self.sptMainRatioSaved = 0 then
		self.sptMainRatioSaved := 20;
	endif;

	self.setNavigatorHeading(self.caption);
	self.zClearSortColumns();
	self.zAddSortColumn('id', false);

	self.useTblThumb 				:= false;
	self.frmDetailsBottom.visible 	:= true;
	
	self.sptThumbEdit.showRightControl(65, true);
	self.initTblOther(self.tblOther, ETDef_TARestrictionsOther);
	
	self.tblOther.visible 			:= true;
	self.useTblData 				:= true;
	self.useNumRowsShown			:= true;	
	self.fldTop.stretchToParent 	:= true;
	self.fldTop.tabsStyle 			:= Folder.TabsStyle_RightSloped;
	self.fldTop.useSheetBackColors 	:= true;
	
	self.fldTop.setDefaultSheetBackColors();
	self.fldTop.initSheetBackColors();

	self.shtRestrictData.visible := false;

	self.mySDF.setHLabelDetails(25);
	self.mySDF.setVLabelDetails(40);
	self.mySDF.setupDrawingAttributes();
	
	self.allowPrint  	:= false;
	self.allowExportCSV	:= false;
	self.allowSearch 	:= false;
	self.useProxyObject := false;
	self.topSheet 		:= self.shtRestrictData;
end;</source>
    </JadeMethod>
    <JadeMethod name="initListBox" id="1a06715a-3fad-48c3-bb6d-51e343262625">
        <source>initListBox();
// ---------------------------------------------------------------------------
// Created:		September 2003 By Andrew Bishop cnwab1
//
// ---------------------------------------------------------------------------
// 07/11/2012	CNWCS5	PAR 30475 - REMOVE LOCATION RESTRICTIONS
vars
	listbox	:CMUI_ListBox;
begin
	listbox := self.lstRestrictions;
	
	listbox.clear;

	listbox.backColor 			:= White;
	listbox.hasTreeLines 		:= true;
	listbox.hasPlusMinus 		:= true;
	listbox.defaultLineHeight 	:= 13;
	listbox.hasPictures 		:= false; // this will put the windows pictures, folder etc. onto the tree

end;</source>
    </JadeMethod>
    <JadeMethod name="initSDF" id="8b369eab-6c74-42a5-8594-0c25f25ab2aa">
