    <JadeMethod name="resetMachineType" id="9f652877-944d-4785-850e-91d53253c80d">
        <source>resetMachineType(pConstant : Constant; _passport : CM_Passport input);
// ---------------------------------------------------------------------------
// Created:     21 August 2006 by cnwdvb1
//
// Purpose:     This is used as a "callBack" method 

vars

	realMachineType,
	pxyMachineType	: CM_MachineType;
	type			: Integer;
		
begin

	if pConstant.valueAsInteger &gt; MACHINETYPE_MAX then
	   	return;
	endif;

	type := pConstant.valueAsInteger;
	realMachineType := self.allMachineTypes[type];
	
	if realMachineType &lt;&gt; null then
		return;
	endif;
	
//	str := pConstant.text;
	
//	classToCreate	:= str.cnEcGetTagValueOfName('classNameToCreate');
//	className		:= str.cnEcGetTagValueOfName('className');
//	desc			:= str.cnEcGetTagValueOfName('description');
//	isSystemType	:= str.cnEcGetTagValueOfName('systemType').isTrueFalse('Yes', 'No', false);
	
	// 10/08/2009 	cnwsh3 		CCMS SFW1066 PAR20321 - Recording Damage Details Changes.
	if pConstant.valueAsInteger = MACHINETYPE_WAGONRAIL then
		create pxyMachineType as CM_WagonMachineType transient;
	else
		create pxyMachineType as CM_MachineType transient;
	endif;
	pxyMachineType.setProxy(type, self.machineTypeDescription(type), null, null, null, null); // CCMS SFW1066 PAR20321 - Recording Damage Details Changes.
	app.myUtilityCA.utlCreateMachineType(pxyMachineType, realMachineType, app.myPassport);
	
epilog
	delete pxyMachineType;
end;</source>
        <Parameter name="pConstant" type="Constant"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="resetMachineTypeGroup" id="19eef8b7-2824-4c56-a696-ce7945e34afe">
        <source>resetMachineTypeGroup(pConstant : Constant; _passport : CM_Passport input);
// ---------------------------------------------------------------------------
// Created:     21 August 2006 by cnwdvb1
//
// Purpose:     This is used as a "callBack" method 

vars

	realMachineTypeGroup,
	pxyMachineTypeGroup		: CM_MachineTypeGroup;
	str						: String;
			
begin

	if pConstant.valueAsInteger &gt; MACHINETYPEGRP_MAX then
	   	return;
	endif;

	realMachineTypeGroup := self.allMachineTypeGroups[pConstant.valueAsInteger];
	
	str := pConstant.text;
		
			
	if realMachineTypeGroup = null then
		create pxyMachineTypeGroup transient;
		pxyMachineTypeGroup.setProxyFromXML(pConstant.valueAsInteger, str, self);
		app.myUtilityCA.utlCreateMachineTypeGroup(pxyMachineTypeGroup, realMachineTypeGroup, app.myPassport);
	else
		pxyMachineTypeGroup := app.createUpdateProxy(realMachineTypeGroup).CM_MachineTypeGroup;
		pxyMachineTypeGroup.setProxyFromXML(pConstant.valueAsInteger, str, self);
		app.myUtilityUA.utlUpdateMachineTypeGroup(pxyMachineTypeGroup, app.myPassport);
	endif;
	
epilog
	
	delete pxyMachineTypeGroup;
	
end;</source>
        <Parameter name="pConstant" type="Constant"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
