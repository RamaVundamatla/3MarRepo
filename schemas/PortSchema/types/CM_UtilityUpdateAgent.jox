    <JadeMethod name="utlUpdateIFCSUMHSCodes" id="4941d4b1-c0c0-46b5-95e8-06bd4823ffcb">
        <updating/>
        <source>utlUpdateIFCSUMHSCodes(_allProxies:CM_ObjectArray; _passport:CM_Passport input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 November 2024	navsp1	Initial creation MTN-33228

*/

vars
	obj					: Object;
	pxyHSRule,
	realHSRule			: CM_EDIIFCSUMHSRule;
	reaEDIPartyRules	: CM_EDIPartyRules;
	expectedEdition		: Integer;
	rule, pxyRule		: CM_EDIRule;
	party				: CM_EDIParty;
begin
	self.initialiseActivity();
	
	// do validation
	self.raiseExceptionIfNull(_allProxies, 'EDI_Party_HSCodes');

	app.setContinueCMExceptions(true);
	
	reaEDIPartyRules := _allProxies.first.CM_EDIIFCSUMHSRule.myEDIPartyRules;
	if reaEDIPartyRules &lt;&gt; null then
		party := reaEDIPartyRules.myEDIParty;
	else
		return;
	endif;
	foreach obj in _allProxies do	
		pxyHSRule := obj.CM_EDIIFCSUMHSRule;
		
		pxyHSRule.pxyGetRealObjectAndEdition(realHSRule, expectedEdition);
		pxyRule := obj.CM_EDIRule;		
		if realHSRule = null and not reaEDIPartyRules.isExists(pxyHSRule.hsCode) then
			create rule as pxyRule.class persistent;			
			rule.setForCreate (pxyRule);			
			rule.setMyEDIPartyRules (reaEDIPartyRules);
		endif;
	endforeach;
	
	//if party &lt;&gt; null then											//MTN-33537
	//	party.causeEvent (EDI_PARTY_UPDATE_EVENT, false, null);		//MTN-33537
	//endif;														//MTN-33537
epilog

end;</source>
        <Parameter name="_allProxies" type="CM_ObjectArray"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateISOType" id="641dcb9b-98f6-4abc-ac5d-683918e4d7fe">
        <source>utlUpdateISOType(pProxyISOType:CM_ISOType; _passport : CM_Passport input);
// ---------------------------------------------------------------------------
// Created:     16 July 2001 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//09 May 2016	cnwma1		  TFS #1961 PAR #37474 Changing colour of ISO type only updates selected instance
//21 Sep 2020   cnwma1 		  ChangeRequest 49906: MTN - Ops View External Webservice
// ---------------------------------------------------------------------------
vars
	cancelSave:Boolean;
	realISOType:CM_ISOType;
	expectedEdition:Integer;
	eventStr : String;
	colorChanged : Boolean;
	
begin

	self.initialiseActivity();

	pProxyISOType.raiseExceptionIfNotProxy(method);

	app.setContinueCMExceptions(true);

	pProxyISOType.pxyGetRealObjectAndEdition(realISOType, expectedEdition);
	
	if realISOType = null then	
		app.raiseCMException1(ProxyMgrCannotLocateReal, CM_ISOType.name, null, null);
		return;
	endif;

	app.myValUA.valISOType(realISOType, pProxyISOType);
	
	if (not self.checkValidationWithPassport(_passport)) then
		return;		// note that this gets "ignored" in the eplog
	endif;


	app.setContinueCMExceptions(false);

	exclusiveLock(realISOType);

	if _passport.noErrors and realISOType.edition &lt;&gt; expectedEdition then
		app.raiseCMException1(ObjectUpdatedByAnotherUserSave, 'ISOType', null, null);
		return;
	endif;
	
	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realISOType, true);
	endif;
	
	if _passport.noErrors then
		if realISOType.colour &lt;&gt; pProxyISOType.colour then   //09/05/2016 cnwma1 PAR #37474 TFS #1961
			colorChanged := true;
		endif;
		realISOType.setForUpdate(pProxyISOType);
	endif;

	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realISOType, false);
	endif;
	
	if _passport.noErrors then     //09/05/2016 cnwma1 PAR #37474 TFS #1961
		if colorChanged then
			eventStr := eventStr &amp;  "&lt;" &amp; GridXML_ColourCode &amp; "&gt;" &amp; realISOType.code  &amp; "&lt;/" &amp; GridXML_ColourCode &amp; "&gt;";
			eventStr := eventStr &amp;  "&lt;" &amp; GridXML_Colour &amp; "&gt;" &amp; realISOType.colour.String  &amp; "&lt;/" &amp; GridXML_Colour &amp; "&gt;";
			realISOType.causeEvent(EVENT_CODE_COLOUR_CHANGE, false, eventStr);
		endif;
		//21.09.2020 cnwma1 TFS #49906
		if _passport.isOpsViewEnabled(null) then
			realISOType.createOpsViewEWSActivity(BGP_OpsViewWSRequest.OPS_ACTION_UPDATE,
												  BGP_OpsViewWSRequest.OPS_TYPE_ISOTYPE,
												  realISOType);
        endif;
		//21.09.2020 cnwma1 TFS #49906
	endif;
	

epilog
	
	
end;</source>
        <Parameter name="pProxyISOType" type="CM_ISOType"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateISOTypeGroup" id="e385ce0c-e2d1-4f0a-8e22-5772ea846224">
        <source>utlUpdateISOTypeGroup(pProxyISOTypeGroup:CM_ISOTypeGroup; _passport : CM_Passport input);
