    <JadeMethod name="getPlaceString" id="b2daf009-f2f5-4a38-a121-005a0a25041f">
        <source>getPlaceString(_place : Integer) : String protected;

vars

begin

	if _place = PlaceDeck then
		return 'DCK';
	elseif _place = PlaceHold then
		return 'HLD';
	endif;

end;</source>
        <access>protected</access>
        <Parameter name="_place" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
