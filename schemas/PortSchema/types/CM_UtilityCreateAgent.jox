    <JadeMethod name="utlCreateCGComplete" id="4ddf78f0-ea7d-4a79-ace3-593542cfa6f9">
        <updating/>
        <source>utlCreateCGComplete(//	_notifyGroup : CM_NotifiedCargoGroup;
						_realCargoGroup : CM_TrackedItem input;
						_txn : CM_TITransaction output;
						_passport : CM_Passport input
						) updating;

/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21/08/2015	cnwndl1	Initial creation	Par 36608
20/02/2018	jlgdap1	TFS 37096 Suppress maximum weight warning when a cargo group that's part of a preassigned notified group is completed
27 Jun 2018	jlgkpd1	TFS 39132 - Set complete flag on the Cargo Group as well as creating the transaction, for performance when checking 
					for complete Cargo Groups
26 Sep 2018 cnwma1	ChangeRequest 40213: PEL1 - Cargo Work Order Print Once Job Order Report
*/

vars
	trxCont : CMIF_CargoGroupComplete;
	cargoGroup : CM_CargoGroup;
	//cgNotified : CM_NotifiedCargoGroup;
begin

	cargoGroup := _realCargoGroup.CM_CargoGroup;

	//app.myValUA.valCargoGroupComplete( cargoGroup, _passport );					// TFS 37096
	app.myValUA.valCargoGroupComplete( cargoGroup, _passport );		// TFS 37096
	
	if _passport.hasErrors then
		return;
	endif;

	self.initialiseActivity();
	app.setContinueCMExceptions(true);
	
	create trxCont transient;
	trxCont.type := TRANS_TYPE_GRP_COMPLETE;
	trxCont.userId := _passport.userCode;
	trxCont.dateTime := app.actualTimeServer();
	/* 26.09.2018 cnwma1 TFS #41092
	if _notifyGroup &lt;&gt; null and _notifyGroup.myCargoGroupAssignment &lt;&gt; null then
		trxCont.assignmentNumber := _notifyGroup.myCargoGroupAssignment.id;
	endif;
	*/
	//02 Oct 2018	NDL	TFS 39186
	if cargoGroup &lt;&gt; null then
		trxCont.assignmentNumber := cargoGroup.getMyCargoGroupAssignmentId;
	endif;
		// 26.09.2018 cnwma1 TFS #41092
	//	if _notifyGroup &lt;&gt; null then
	//		if _notifyGroup.myCargoGroupAssignment &lt;&gt; null then
	//			trxCont.assignmentNumber := _notifyGroup.myCargoGroupAssignment.id;
	//		endif;
	//	
	//	else
	//		if cargoGroup &lt;&gt; null and cargoGroup.myCargoGroupTerminal &lt;&gt; null then
	//			cgNotified := cargoGroup.myCargoGroupTerminal.getNotifiedGroupForCargoGroup(cargoGroup);	
	//			if cgNotified &lt;&gt; null and cgNotified.myCargoGroupAssignment &lt;&gt; null then
	//				trxCont.assignmentNumber := cgNotified.myCargoGroupAssignment.id;
	//			endif;
	//		endif;
	//	endif;
	//endif;
	trxCont.minWeight := cargoGroup.minWeight;
	trxCont.maxWeight := cargoGroup.maxWeight;
	trxCont.actualWeight := cargoGroup.totalWeight;
	
	_txn := cargoGroup.createTransaction(trxCont, _passport);
	
	cargoGroup.setComplete(true);					// TFS 39132
	cargoGroup.updateObjectEdition(cargoGroup);

epilog

	delete trxCont;
	
end;</source>
        <Parameter name="_realCargoGroup" type="CM_TrackedItem" usage="input"/>
        <Parameter name="_txn" type="CM_TITransaction" usage="output"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlCreateCO2Reading" id="6bf3267d-cf47-4d07-9d5b-9be4a6291dd1">
        <source>utlCreateCO2Reading(_co2Params : CMIF_CO2Reading input; _passport : CM_Passport input) : CM_CO2Reading;
//
// Purpose:			Record a CO2 reading for a reefer cargo item and create the associated TI transaction
//
// Parameters:			CMIF parameters for creating a CO2 reading / passport
//
// Return Value:		The created CO2 reading object
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 16/12/2025	navdap1		Initial creation MTN-36569 CPL | Reefer Runner Integration
//
vars
	co2Reading : CM_CO2Reading;
	realTI, proxyTI : CM_TrackedItem;
	expectedEdition : Integer;

begin
	self.initialiseActivity();
	
	proxyTI := _co2Params.myTrackedItem;
	proxyTI.raiseExceptionIfNotProxy(method);
	
	app.setContinueCMExceptions(true);
	
	proxyTI.pxyGetRealObjectAndEdition(realTI, expectedEdition);
	if realTI = null then
		app.raiseCMException1(ProxyMgrCannotLocateReal, CM_TrackedItem.name, null, null);
		return null;
	endif;
	
	app.myValCA.valCO2Reading(_co2Params);
	if not self.checkValidationWithPassport(_passport) then
		return null;
	endif;
	app.setContinueCMExceptions(false);
	
	self.exclusiveLock(realTI);

	if _passport.noErrors then
		_co2Params.myTrackedItem := realTI;
		create co2Reading persistent;
		co2Reading.setForCreate(_co2Params);
	endif;
	
	if _passport.noErrors then
		// raise a note
		_co2Params.myTrackedItem.causeEvent(_co2Params.myTerminal.getTerminalEvent(EVENT_TEMP_CREATE), false, co2Reading);
	endif;
	
	return co2Reading; 
	
epilog

end;</source>
        <Parameter name="_co2Params" type="CMIF_CO2Reading" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <ReturnType type="CM_CO2Reading"/>
    </JadeMethod>
