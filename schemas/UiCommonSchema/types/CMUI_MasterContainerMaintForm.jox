    <JadeMethod name="cmbISOType_closeup" id="6a611a98-10a1-4f56-8a80-3e2ac5af356c">
        <controlMethod name="ComboBox::closeup"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbISOType_closeup(combobox: ComboBox input) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
22 August 2008	cnwrd1	Initial creation

*/

vars
	tmpIsoType : CM_ISOType;
begin


	tmpIsoType := combobox.listObject.CM_ISOType;
	if tmpIsoType &lt;&gt; null then
		setForReefer ( tmpIsoType.isReefer );
	endif;
epilog

end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="cmbISOType_displayEntry" id="0b7efbab-184b-4106-806f-cd2596ac7fc3">
