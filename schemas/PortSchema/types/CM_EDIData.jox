    <JadeMethod name="canUserAccessSelf" id="344c0e8a-340c-4384-959d-cdc6c4b16a92">
        <source>canUserAccessSelf(_user: CM_User; _failedDAC: CM_DataAccessController output; _passport: CM_Passport): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 May 2023	navsp1	Initial creation TFS Bug 57864: AAT - EDI Operation - Users with Stevedore role should see only Voyage assigned to their Data access group
*/

vars
	voyage 	: CM_Voyage;
	voyCode : String;
begin 
	if app.isSpecial then
		return true;
	endif;
	
	voyCode := self.getVoyageCode();
	if voyCode = null then
		return true;
	endif;
	
	voyage := self.getVoyageFromCode(voyCode);
	if voyage = null then
		return true;
	endif;
	
	return voyage.canUserAccessSelf(_user, _failedDAC, _passport);

epilog

end;</source>
        <Parameter name="_user" type="CM_User"/>
        <Parameter name="_failedDAC" type="CM_DataAccessController" usage="output"/>
        <Parameter name="_passport" type="CM_Passport"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="canUserSet" id="973d5c3d-3545-4ffe-b80c-6e6df0483f86">
        <source>canUserSet(_propName: String): Boolean;
/*
 05 Nov 2014	cnwrs1	Par 34702 - Add support for JMT XML with implied header
 06 Dec 2022	navma1	ChangeRequest 55424: MTN - Improve the performance of Edi file loading
//13 Nov 2023	jlirs1	TFS 59171 User Defined Transport Manifest 
*/
vars

begin
	if _propName = CM_EDIData::allAuditObjects.name or
	   _propName = CM_EDIData::allEDITrackedItems.name or
	   _propName = CM_EDIData::allErrorWarnings.name or
	   _propName = CM_EDIData::allExtraData.name or
	   _propName = CM_EDIData::currentDefaultIdNum.name or
	   _propName = CM_EDIData::ediConfig.name or
	   _propName = CM_EDIData::ediDataType.name or
	   _propName = CM_EDIData::ediFileArray.name or
	   _propName = CM_EDIData::ediFileCode.name or
	   _propName = CM_EDIData::fileAdditionalInfo.name or
	   _propName = CM_EDIData::fileName.name or
	   _propName = CM_EDIData::fileVersion.name or
	   _propName = CM_EDIData::items.name or
	   _propName = CM_EDIData::myBayPlanController.name or
	   _propName = CM_EDIData::myEDIFile.name or
	   _propName = CM_EDIData::myOperator.name or
	   _propName = CM_EDIData::mySubTerminal.name or
	   _propName = CM_EDIData::number.name or
	   _propName = CM_EDIData::parseDatesForLocale.name or
	   _propName = CM_EDIData::processDate.name or
	   _propName = CM_EDIData::processDateTime.name or
	   _propName = CM_EDIData::status.name or
	   _propName = CM_EDIData::xlationOperatorCode.name or		//06.12.2022 namva1 #55424
	   _propName = CM_EDIData::userCode.name then
		return false;
	endif;
	return true;	

end;
</source>
        <Parameter name="_propName" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="checkEDICutoff" id="8845f12e-71ef-49de-84fd-4190cb4f3e23">
        <source>checkEDICutoff(_voyageCode :String; _operatorCode :String; _ediTI :CM_EDITrackedItem );
/*
Date		Who		Reason
01/03/2012	cnwcs5	Initial creation - par 29158 EDI Booking Cutoff
17/03/2012	cnwcs5	par 29257 - conversion of extension object properties
2/09/2019 	JLGNS1	Bug 46164: LNX - Criteria of Voyage Cutoff Code Does Not Work
*/
vars
	terminal		:CM_Terminal;
	type,relTo		:Integer;
	cutoff			:CM_ReceivalCutoffTermDef;
	voyageCutoff	:CM_ReceivalCutoffVoyage;
	opCutoff	: CM_ReceivalCutoffOpTerm;
	array			:IntegerArray;
	voyage			:CM_Voyage;
	operator		:CM_Operator;
	tsPN, earliestTSPN, //04/03/2025	navkc1 JIRA Story MTN-34227
	now, earliestTS,ts			:TimeStamp;
	typeStr,		//10/03/2025	navkc1 JIRA Story MTN-34226
	errStr			: String;
	cutoffPN,		//10/03/2025	navkc1 JIRA Story MTN-34226
	isPreNote		: Boolean;
	agent			: CM_EDIControllerAgent; //10/03/2025	navkc1 JIRA Story MTN-34226
begin 
	terminal	:= self.getMyTerminal;
	type 		:= self.ediDataType;
	voyage		:= terminal.lookupVoyage (_voyageCode, null, false);
	
	isPreNote := type = EDIDataType_Prenote; //10/03/2025	navkc1 JIRA Story MTN-34226
	
	if voyage = null then 
		// no point even checking - probably voyage did not translate
		return;
	endif;
	
	//skip this check if the ignorecutoffs is true
	if voyage.ignoreCutoffs then					//19.Sep.2023 navsp1 TFS 57809
		return;
	endif;
	
	create agent transient; //10/03/2025	navkc1 JIRA Story MTN-34226
	typeStr := agent.getEDIDisplayStrForType(type); //10/03/2025	navkc1 JIRA Story MTN-34226
	
	if _operatorCode &lt;&gt; null then
		operator := app.myRoot.allOperators [_operatorCode];
	endif;
	
	cutoffPN := voyage &lt;&gt; null and voyage.shipCutoffsForPrenotes; //10/03/2025	navkc1 JIRA Story MTN-34226
	
	foreach cutoff in terminal.allReceivalCutoffDefs where cutoff.isAvailableForEntry do
		if not cutoff.isEDIType then
			continue;
		endif;
		
		array := cutoff.allEDIDataTypes;	// par 29257
				
		if not array.includes (type) and not array.includes (EDIDataType_All) then 
			continue;
		endif;
		
		voyageCutoff := null;
		opCutoff:=null;
		if voyage.overrideDefaults then
			// do we have a cutoff for the operator/voyage
			if operator &lt;&gt; null then
				voyageCutoff := voyage.allReceivalCutoffs[cutoff.code, operator];
			endif;
			
			if voyageCutoff = null then
				voyageCutoff := voyage.allReceivalCutoffs[cutoff.code, null];
			endif;
		else
			if operator &lt;&gt; null then
				opCutoff:=operator.getTerminalReceivalCutoff(cutoff);
			endif;
		endif;
				
		relTo 	:= cutoff.defaultRelativeTo;
		ts:=null;
		//epr par 29487 derive default cutofffs
		if voyageCutoff &lt;&gt; null then
			ts		:= voyageCutoff.cutoffDateTime; 
			tsPN	:= voyageCutoff.cutoffDateTimePN; //04/03/2025	navkc1 JIRA Story MTN-34227
		elseif opCutoff &lt;&gt; null then
			
			if isPreNote then //04/03/2025	navkc1 JIRA Story MTN-34227
				if not cutoffPN then //10/03/2025	navkc1 JIRA Story MTN-34226
					continue;
				endif;
				opCutoff.getCutoffsPNForVoyage(voyage,earliestTSPN,tsPN);
			else
				opCutoff.getCutoffsForVoyage(voyage,earliestTS,ts);
			endif;
		else
			
			if isPreNote then //04/03/2025	navkc1 JIRA Story MTN-34227
				if not cutoffPN then //10/03/2025	navkc1 JIRA Story MTN-34226
					continue;
				endif;
				cutoff.getCutoffsPNForVoyage(voyage,earliestTSPN,tsPN);
			else
				cutoff.getCutoffsForVoyage(voyage,earliestTS,ts);
			endif;
			
		endif;
		
		if relTo = DefaultRelativeTo_Arrival or
			relTo = DefaultRelativeTo_Departure or
			relTo = DefaultRelativeTo_ShipExchange then 
			
			//04/03/2025	navkc1 JIRA Story MTN-34227
			if isPreNote then
				ts := tsPN;
				earliestTS := earliestTSPN;
			endif;
			
			if 	(ts &lt;&gt; null and ts &lt; now) then 
				if type = EDIDataType_TransportManifest or type = EDIDataType_CallOff then			//18.Sep.2023 navsp1 TFS 57809
					errStr := app.getErrorString4(Receive_after_voyage_cutoff, _ediTI.id, voyage.code, null, ts.String);			
					app.myPassport.addErrorFull(Receive_after_voyage_cutoff, errStr, null, null, null);	
				else
					//10/03/2025	navkc1 JIRA Story MTN-34226
					//app.raiseCMException (EDI_Cutoff_Message1, ETRow_VoyageCode, _ediTI);
					app.raiseCMException2(EDI_Cutoff_Message3, typeStr, voyage.code, ETRow_VoyageCode, _ediTI); //10/03/2025	navkc1 JIRA Story MTN-34226
				endif;
			endif;
		elseif relTo = DefaultRelativeTo_RecCutOff then 
			// this one is different as there is no date associated with the
			// cargo stop receival for an operator. Basically if the operator
			// is in the voyage.allOperatorsCargoReceiveOnHold collection then
			// it is too late.
			if operator &lt;&gt; null and operator.hasReceivalCutOffForVoyage(voyage,null) then //epr par 36705 2/9/15	//Bug 46164
				//10/03/2025	navkc1 JIRA Story MTN-34226
				//app.raiseCMException (EDI_Cutoff_Message2, ETRow_VoyageCode, _ediTI);
				app.raiseCMException3(EDI_Cutoff_Message4, typeStr, voyage.code, operator.code, ETRow_VoyageCode, _ediTI);//10/03/2025	navkc1 JIRA Story MTN-34226
			endif;
		endif;
	endforeach;
epilog
	delete agent; //10/03/2025	navkc1 JIRA Story MTN-34226
end;</source>
