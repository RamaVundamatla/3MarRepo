    <PrimAttribute name="pxyHeadingsHaveBeenProcessed" id="aba6eb6b-4525-42e3-b093-0056a403c1c5">
        <embedded/>
        <type name="Boolean"/>
        <access>protected</access>
        <text>
Because the user heading 'processing' (i.e replacing their expression with ours) 
should always be done to the terminology details proxies, this attribute
is used to check that this has in fact happened before we copy those headings
onto the persistent instances.</text>
    </PrimAttribute>
