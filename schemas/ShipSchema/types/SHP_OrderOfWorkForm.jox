vars
	folderTop,
	folderHeight : Integer;
begin
	//30 Oct. 2008 cnwdz2 par 18339
	folderTop := (self.frmToolbar.top + self.frmToolbar.height).Integer;
	folderHeight := self.clientHeight;
	if self.staStatusBar.visible then
		folderHeight := folderHeight - self.staStatusBar.height.Integer;
	endif;
	
	self.fldMain.move(0,folderTop, self.clientWidth, folderHeight);
	
	inheritMethod();
	
	self.splMain.top := 0;
