    <JadeMethod name="buildSelf" id="d811eb1c-2537-4cf1-b67d-0ae3923a6e58">
        <updating/>
        <source>buildSelf() updating, protected;
// ---------------------------------------------------------------------------
// Created:     11 April 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	root	: CM_Root;
	tmpPic	: GTE_DoorsDirArrow;
	
begin

	if self.isInPainter then
		root := CM_Root.firstInstance;
	else
		root := app.myRoot;
	endif;

	self.borderStyle		:= self.BorderStyle_None;
	self.pictureDown 		:= root.getConfig(DoorsDirDownPic).Binary;
	self.pictureRollOver 	:= root.getConfig(DoorsDirOverPic).Binary;
	self.picture 			:= root.getConfig(DoorsDirUpPic).Binary;
	self.stretch			:= Stretch_ToControl;

	self.maxWidth 	:= 50;
	self.width 		:= self.maxWidth;
	self.height 	:= 20;

	if self.myArrowDoorsLeftPic = null then
		create tmpPic transient;
		tmpPic.parent := self;
		form.addControl(tmpPic);
		
		tmpPic.height 	:= 10;
		tmpPic.width	:= 5;
		tmpPic.top		:= 5;
		tmpPic.left		:= 3;
		
		tmpPic.borderStyle	:= BorderStyle_None;
		tmpPic.stretch 		:= Stretch_ToControl;
		tmpPic.transparent 	:= true;
		tmpPic.transparentColor := 65280;
	else
		tmpPic := self.myArrowDoorsLeftPic;
	endif;

	tmpPic.picture := root.getConfig(DoorsLeftArrowPic).Binary;
	tmpPic.visible := false;

	self.myArrowDoorsLeftPic := tmpPic;
	
	// Create the Right Picture

	if self.myArrowDoorsRightPic = null then
		create tmpPic transient;
		tmpPic.parent := self;
		form.addControl(tmpPic);

		tmpPic.height 	:= 10;
		tmpPic.width	:= 5;
		tmpPic.top		:= 5;
		tmpPic.left		:= self.width - tmpPic.width - 3;
		
		tmpPic.borderStyle	:= BorderStyle_None;
		tmpPic.stretch 		:= Stretch_ToControl;
		tmpPic.transparent 	:= true;
		tmpPic.transparentColor := 65280;
	else
		tmpPic := self.myArrowDoorsRightPic;
	endif;

	tmpPic.picture := root.getConfig(DoorsRightArrowPic).Binary;
	tmpPic.visible := false;

	self.myArrowDoorsRightPic := tmpPic;
	
	self.doorsRight := true;
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="click" id="5b8a424b-5e1f-4d60-91c6-275ba9eb2a53">
        <updating/>
        <source>click(jadeMask: JadeMask input) updating;
// ---------------------------------------------------------------------------
// Created:     19 March 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	contFrm	: GTE_ContainerFrame;
	
begin

	self.doorsRight := (not self.doorsRight);
	
	if self.parent.isKindOf(GTE_ContainerFrame) then
		contFrm := self.parent.GTE_ContainerFrame;
		if contFrm.parent.isKindOf(GTE_TruckLayoutFrame) then
			contFrm.parent.GTE_TruckLayoutFrame.selectContainer(contFrm);
		endif;
	endif;

end;</source>
        <Parameter name="jadeMask" type="JadeMask" usage="input"/>
    </JadeMethod>
    <JadeMethod name="cnEcResizeContents" id="cb546c58-02ac-42e3-810b-659712261b16">
        <updating/>
        <source>cnEcResizeContents() updating;
// ---------------------------------------------------------------------------
// Created:     11 April 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	inheritMethod();
	
	self.myArrowDoorsRightPic.left := self.width - self.myArrowDoorsRightPic.width - 3;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="doorsRight" id="c383dcbf-07d9-4f12-af96-b2844265064a">
        <methodInvocation>mapping</methodInvocation>
        <updating/>
        <source>doorsRight(set: Boolean; _value: Boolean io) updating, mapping;
// ---------------------------------------------------------------------------
// Created:     11 April 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	if set then
		if self.doorsRight &lt;&gt; _value then
			self.doorsRight := _value;
			if _value then
				self.myArrowDoorsRightPic.visible := true;
				self.myArrowDoorsLeftPic.visible  := false;
			else
				self.myArrowDoorsRightPic.visible := false;
				self.myArrowDoorsLeftPic.visible  := true;
			endif;
		endif;
	else
		_value := self.doorsRight;
	endif;

end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="Boolean" usage="io"/>
    </JadeMethod>
    <JadeMethod name="dragDrop" id="17a398a5-b77f-47f4-bb97-9d5309dcb569">
        <updating/>
        <source>dragDrop(jadeMask: JadeMask input; win: Window input; x: Real; y: Real) updating;
// ---------------------------------------------------------------------------
// Created:     19 March 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
//	inheritMethod(jadeMask, win, x, y);

	self.myContainerFrame.myTruckLayoutFrame.dragDropContainer(self.myContainerFrame);

end;</source>
        <Parameter name="jadeMask" type="JadeMask" usage="input"/>
        <Parameter name="win" type="Window" usage="input"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="setWidth" id="e17c0145-2407-4059-a87b-f563ea7dbaac">
        <updating/>
        <source>setWidth(pMax : Integer) updating;
// ---------------------------------------------------------------------------
// Created:     11 April 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	if self.maxWidth &lt;= pMax then
		self.width 		:= self.maxWidth;
		self.caption 	:= 'Doors';
	else
		self.width 		:= pMax - 4;
		self.caption 	:= null;
	endif;
	
	// need to reposition arrow
	self.cnEcResizeContents;

end;</source>
        <Parameter name="pMax" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="windowCreated" id="9276fa10-c7c8-4f5f-a44f-7ad9ce1a7b4a">
        <updating/>
        <source>windowCreated(cntrl: Control input; persistCntrl: Control) updating;
// ---------------------------------------------------------------------------
// Created:     19 March 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	inheritMethod(cntrl, persistCntrl);
	
	self.buildSelf();

end;</source>
        <Parameter name="cntrl" type="Control" usage="input"/>
        <Parameter name="persistCntrl" type="Control"/>
    </JadeMethod>
