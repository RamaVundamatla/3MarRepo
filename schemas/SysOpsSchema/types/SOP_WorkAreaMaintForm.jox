    <JadeMethod name="clickSubAreaExpand" id="e120139b-f82a-4541-874b-859d800fe567">
        <source>clickSubAreaExpand( _rowIndex : Integer ) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 April 2014	cnwndl1	Initial creation	Par 33995

*/

vars

	expand : Boolean;
	gridObject : CM_GridObject;
	index : Integer;
	obj : Object;

begin

	expand := self.tblAreas.accessCell( _rowIndex, Col_Expand_SubArea).text = Exp_Expand;
	gridObject := self.tblAreas.accessRow( _rowIndex ).itemObject.CM_GridObject;
		
	if expand then
		self.tblAreas.setCellText( _rowIndex,Col_Expand_SubArea,Exp_Contract);
		foreach index in _rowIndex + 1 to self.tblAreas.rows do
			obj := self.tblAreas.accessRow( index ).itemObject;
			if obj.isKindOf( CM_TerminalArea ) then
				//this is the next ta.
				break;
			elseif obj.isKindOf( CM_GridObject ) then
				//this is the next grid object.
				break;
			endif;
			self.tblAreas.accessRow( index ).visible := true;
		endforeach;
		
	else
		self.tblAreas.setCellText( _rowIndex,Col_Expand_SubArea,Exp_Expand);
		foreach index in _rowIndex + 1 to self.tblAreas.rows do
			obj := self.tblAreas.accessRow( index ).itemObject;
			if obj.isKindOf( CM_TerminalArea ) then
				//this is the next ta.
				break;
			elseif obj.isKindOf( CM_GridObject ) then
				//this is the next grid object.
				break;
			endif;
			self.tblAreas.accessRow( index ).visible := false;
		endforeach;
	endif;
	
	self.refreshTableHighlighting();

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_rowIndex" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="clickSubAreaInclude" id="59b2aa5a-d70a-4ecb-8755-a11fa5b55d21">
        <source>clickSubAreaInclude( _rowIndex : Integer ) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 Apr 2014	cnwndl1	Initial creation	Par 33995
25 Jun 2020	jlgdap1	TFS 49453 ASPA Satellite View Screen for Flexible Terminal Areas
*/

vars

	selected : Boolean;
	gridObject : CM_GridObject;
	index : Integer;
	obj : Object;
	locationControllerArray : ObjectArray;
	lc : CM_LocationsController;
	roroCont : CM_RoRoController;
	group : CM_GeneralCargoAllocGroup;			// TFS 49453

begin

	selected := self.tblAreas.accessCell( _rowIndex, Col_Incl_SubArea).text = Item_Selected;
	
	obj := self.tblAreas.accessRow( _rowIndex ).itemObject;
	if obj.isKindOf( CM_GridObject ) then
		gridObject := obj.CM_GridObject;
	elseif obj.isKindOf( CM_RoRoController ) then
		roroCont := obj.CM_RoRoController;
		self.selectLocation( roroCont, selected, true );
		return;
	elseif obj.isKindOf(CM_GeneralCargoAllocGroup) then		// TFS 49453
		group := obj.CM_GeneralCargoAllocGroup;				// TFS 49453
		self.selectLocation(group, selected, true);			// TFS 49453
		return;												// TFS 49453
	else
		return;
	endif;
	

	if selected then
		//we are selecting the whole SUB area
		//unselect any children objects
		//hide the children rows.
		//hide the expand/contract
		self.tblAreas.setCellText( _rowIndex,Col_Expand_SubArea,Exp_Hide);
		
		foreach index in _rowIndex + 1 to self.tblAreas.rows do
			obj := self.tblAreas.accessRow( index ).itemObject;
			if obj.isKindOf( CM_TerminalArea ) then
				//this is the next ta.
				break;
			elseif obj.isKindOf( CM_GridObject ) then
				//this is the next grid object.
				break;
			endif;
			self.tblAreas.setCellText(index,Col_Incl_Location,Item_Unselected);
			self.tblAreas.accessRow( index ).visible := false;
		endforeach;
		
	elseif not selected then
		//we are UN selecting the whole SUB area
		//show the expand/contract if the area has sub sub areas
		create locationControllerArray transient;
		gridObject.getAllLocationsControllers( locationControllerArray, false );
		if locationControllerArray.size &lt; 2 then
			self.tblAreas.setCellText( _rowIndex,Col_Expand_SubArea,Exp_Hide);
		else
			self.tblAreas.setCellText( _rowIndex,Col_Expand_SubArea,Exp_Expand);
		endif;
	endif;
	
	self.selectGridObject( gridObject, selected, true );

epilog

	delete locationControllerArray;

end;</source>
        <access>protected</access>
        <Parameter name="_rowIndex" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="clickSubSubAreaInclude" id="734c92c1-2c82-4fb7-984d-722cba7c49f2">
        <source>clickSubSubAreaInclude( _rowIndex : Integer ) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 April 2014	cnwndl1	Initial creation	Par 33995

*/

vars

	selected : Boolean;
