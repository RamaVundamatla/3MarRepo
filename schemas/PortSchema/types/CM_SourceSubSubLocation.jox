    <JadeMethod name="validateForCreate" id="074a7895-00f4-4cbc-b2c9-976cc2281fa0">
        <source>validateForCreate();
//--------------------------------------------------------------
//Created: 07 February 2002 By: cnwgd1
//--------------------------------------------------------------
vars

begin
	inheritMethod();
	if self.mySourceSubLocation = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'mySourceSubLocation', null, null);
		app.raiseCMException(Input_required_field_mySrcSub, null, null); // cnwdb2	PAR 35364
		return;
	elseif self.mySourceSubLocation.allSubSubLocations.includesKey(code) then
		app.raiseCMException1(VB_DUPLICATED_ITEM, self.code, null, null);
	endif;

end;</source>
    </JadeMethod>
