    </JadeMethod>
    <JadeMethod name="openCloseSelector" id="c54cb25e-38c7-41b6-917e-d937de84eba6">
        <updating/>
        <source>openCloseSelector(_visible : Boolean) protected, updating;
// -------------------------------------------
// Created 26 August 2003 by cnwdvb1
// -------------------------------------------
vars
	
	addresses		: CM_EmailEntityByTypeNameDict;
	form			: CMUI_RecipientSelector;
	entity			: CM_EmailEntity;


begin

	//11 Aug 2017	NDL	TFS 5820
	if not app.getMyUser.canDo( self.myTerminal, PmGenRecipientSelector ) then
		return;
	endif;

	create form transient;
	
	if self.myEmailController = null then
		create self.myEmailController transient;
	endif;

	self.setNavigatorHeading(form.caption);
	form.myEmailController := self.myEmailController;
	form.myTerminal := self.myTerminal;	//11 Aug 2017	NDL	TSF 5820
	
	form.myEmailController.clear();
	foreach entity in self.allToAddresses do
		form.doAddAddress(entity, form.lstBoxTo);
	endforeach;
	
	foreach entity in self.allCCAddresses do
		form.doAddAddress(entity, form.lstBoxCc);
	endforeach;
	
	foreach entity in self.allBCCAddresses do
		form.doAddAddress(entity, form.lstBoxBcc);
	endforeach;
	
	form.mode := self.getModeFromRow();
	form.centreWindow;
		
	form.showModal;
//	self.allBCCAddresses.clear();
//	self.allToAddresses.clear();
//	self.allCCAddresses.clear();
	
//	emailController.allToAddresses.copy(self.allToAddresses);
//	emailController.allCcAddresses.copy(self.allCCAddresses);
//	emailController.allBccAddresses.copy(self.allBCCAddresses);

	if form.modalResult = IDOK then
		self.doubleClickedRow := 1;
		self.doSaveAddresses();
		self.doubleClickedRow := 2;
		self.doSaveAddresses();
		self.doubleClickedRow := 3;
		self.doSaveAddresses();
	endif;
	return;
	if _visible then
		addresses := self.adjustFromSelected(self.doubleClickedRow);
		if addresses &lt;&gt; null then
			self.lstAddresses.setSelected(addresses);
		endif;
	endif;

	self.frSelector.visible := _visible;
	if _visible then
		self.lstAddresses.setFocus();
		if addresses.first &lt;&gt; null then
			self.gotoRow(addresses.first);
		endif;
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="_visible" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="saveAndClose" id="14c7f97b-e216-4357-ad35-08d0ae072800">
        <updating/>
        <source>saveAndClose() protected, updating;
// -------------------------------------------
// Created 26 August 2003 by cnwdvb1
// -------------------------------------------
vars
	
	
begin

	self.adjustFromSelected(1);
	self.adjustFromSelected(2);
	self.adjustFromSelected(3);
	
	self.myEmail.setProxy(	self.allToAddresses,
							self.allCCAddresses,
							self.allBCCAddresses,
							null,
							self.allFreeTextToAddresses,
							self.allFreeTextCCAddresses,
							self.allFreeTextBCCAddresses,
							self.txtSubject.text,
							self.txtBody.text,
							self.tblEmail.getValueByName(ETRow_UseExtraInfo).Boolean);
	
	self.myEmail.validate();
	self.modalResult := MsgBox_Return_OK;
	self.unloadForm();
	

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setColorsFromController" id="56d86267-3254-48ca-88e1-b7427651b275">
        <updating/>
        <source>setColorsFromController(_colorControl: CM_ColorController) updating;
// -------------------------------------------
// Created 26 August 2003 by cnwdvb1
// -------------------------------------------
vars

begin
	inheritMethod(_colorControl);
//	self.grpHeader.backColor		:= self.backColor;
	self.frmEmail.backColor := self.backColor;
	self.setColorsForEntryTable(self.tblEmail);



