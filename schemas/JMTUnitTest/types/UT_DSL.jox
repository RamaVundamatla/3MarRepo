    <JadeMethod name="updateInstructionIssued" id="ef416890-58b0-4dcf-afcf-7f0eb1894068">
        <source>updateInstructionIssued(_extrenal:String;_instruct : CM_InstructionsIssued io);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 Nov 2022 navtnr20 ChangeRequest 54967: EUP - INB/OUT - Operational Instructions

*/

vars
	pxyInstructType				: CM_InstructionsIssued;
	loadState					: Boolean;
begin
	if _instruct = null then 
		return;
	endif;
	
	beginTransaction;
		pxyInstructType := _instruct.pxyCreateUpdateProxy();
	commitTransaction;
	
	pxyInstructType.setProxy(_instruct.internalInstructions,_extrenal,_instruct.myInstructionType,_instruct.myParent);
	self.ignoreTrxWarnings(true);
	
	app.myTrxUA.trxUpdateInstructionIssued(pxyInstructType, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
epilog
	delete pxyInstructType;
end;</source>
        <Parameter name="_extrenal" type="String"/>
        <Parameter name="_instruct" type="CM_InstructionsIssued" usage="io"/>
    </JadeMethod>
    <JadeMethod name="updateInstructionType" id="9b96ec60-8124-44c3-bb6f-e9d9cccf463a">
        <source>updateInstructionType( instruct : CM_InstructionType io; _desc : String);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 Oct 2022 navtnr20 ChangeRequest 54967: EUP - INB/OUT - Operational Instructions

*/

vars
	pxyInstructType					: CM_InstructionType;
	loadState					: Boolean;
begin
	if instruct = null then 
		return;
	endif;
	
	app.cmsBeginLoad(loadState);
	pxyInstructType := instruct.pxyCreateUpdateProxy();
	app.cmsEndLoad(loadState);
	
	pxyInstructType.setProxy(instruct.code, _desc, instruct.notAvailableForEntry, instruct.alwaysToGateOffice, null, self.getTerminal());
	self.ignoreTrxWarnings(true);
	
	app.myTrxUA.trxUpdateInstructiontype(pxyInstructType, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
epilog
	app.cmsEndLoad(loadState);
	delete pxyInstructType;
end;</source>
        <Parameter name="instruct" type="CM_InstructionType" usage="io"/>
        <Parameter name="_desc" type="String"/>
    </JadeMethod>
    <JadeMethod name="updateInterTermConfig" id="5b7e7be2-0eff-42df-9d2e-faf0d95a77a3">
        <source>updateInterTermConfig( _itc : CM_InterTerminalConfig);

/*

Purpose:			

Parameters:			

Return Value:		


Date				Who		Reason
24 February 2010	cnwrd1	Initial creation
08/04/2011			cnwmh5	PAR #27347 - Add cmsEndLoad or endLoad to epilog so that if error occurs it will not leave it in beginLoad state
05/08/2011			cnwmh5	Change to use the classes version of opts
*/

vars
	myITCProxyObject			: CM_InterTerminalConfig;
	passport				: CM_Passport;

begin
	passport	:= app.myPassport;
	
	beginLoad;
	myITCProxyObject	:= _itc.pxyCreateUpdateProxy();
	endLoad;
	
	/*myITCProxyObject.setProxy(	_opts.bool( ETRow_RequiresInfo ),
setProxy(_configName                 : String;
		 _myGate                     : CM_Gate;
		 _myLaneController           : CM_GateAreaLaneController;
		 _myRelease                  : CM_InterTerminalBulkRelease;
		 _mySourceTerminal           : CM_Terminal;
		 _selectedTerminalAreas      : CM_TerminalAreaSet;
		 _autoAssignCargoOnMoveIn    : Boolean;
		 _autoUnassignCargoOnMoveOut : Boolean) updating;*/
		 
		 
		 // need to change this
		 
		 myITCProxyObject.setProxy(
									_itc.configName,
									_itc.myGate,
									_itc.myLaneController,
									_itc.myRelease,
									_itc.mySourceTerminal,
									_itc.allSourceAreas,
									_itc.autoAssignCargoOnMoveIn,
									_itc.autoUnassignCargoOnMoveOut
									);


	app.myTrxUA.trxUpdateInterTerminalConfig(myITCProxyObject, passport);
	self.assertTrueMsg( passport.trxCompletedOK(), passport.getAllErrorsWarningsAsString() );
	
epilog
	endLoad;				// 08/04/2011 cnwmh5 #27347
	delete myITCProxyObject;
end;</source>
        <Parameter name="_itc" type="CM_InterTerminalConfig"/>
    </JadeMethod>
    <JadeMethod name="updateInterTermMove" id="27feee97-f16c-4402-b534-05af1c8d011b">
        <source>updateInterTermMove( _realMove : CM_InterTerminalMove; _status : Integer; _lc : CM_LocationsController  );

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
25 February 2010	cnwrd1	Initial creation

*/

vars
	pxyInterTerminalMove : CM_InterTerminalMove ;
begin

	pxyInterTerminalMove := app.createUpdateProxy(_realMove).CM_InterTerminalMove;
	pxyInterTerminalMove.setMyTargetLC(_lc);
	pxyInterTerminalMove.setStatus( _status);
	
	app.myTrxUA.trxUpdateInterTerminalMove( pxyInterTerminalMove , app.myPassport) ;
	
	self.assertNoTrxErrorsOrWarnings();
		
	

epilog
	delete pxyInterTerminalMove;
end;</source>
        <Parameter name="_realMove" type="CM_InterTerminalMove"/>
        <Parameter name="_status" type="Integer"/>
        <Parameter name="_lc" type="CM_LocationsController"/>
    </JadeMethod>
    <JadeMethod name="updateInvoiceLineType" id="11b55ce2-6709-4b34-a18d-7bdd8bc569a6">
        <source>updateInvoiceLineType(_invLineDesc : CM_InvoiceLineDesc; _narration : String; _calType : CM_CalculationType; _invoiceType : CM_InvoiceDesc; _services : CM_ServiceByNameDict; _debtorType : String) : CM_InvoiceLineDesc;
// --------------------------------------------------------------------------------
//
// Purpose:		Update an invoice line type
// 
// Changed On	By			Reason
// ----------	--------	-------------------------------------------------------
// 17/09/2105	cnwdap1		PAR #36909 New parameters for creating invoice type
// 31/01/2023	navvt20		TFS CR 56132 Task 56134: UI - Invoice Line Type - UOM

vars
	pxyInvoiceLineDesc : CM_InvoiceLineDesc;
	chgNum : Integer;
	debtorType : CM_DebtorType;
	bank	: CM_Bank;
begin
	bank := self.getTerminal().getDefaultCompanyBank();
	pxyInvoiceLineDesc := app.createUpdateProxy(_invLineDesc).CM_InvoiceLineDesc;
	pxyInvoiceLineDesc.bank := bank;
	
	chgNum  := 0;
	
	if _calType = null or _calType.isCargoCalcType then
		if _debtorType &lt;&gt; null then
			debtorType := app.myRoot.allDebtorTypes[_debtorType];
		else
			foreach debtorType in app.myRoot.allDebtorTypes where debtorType.code &lt;&gt; "SDT8" and debtorType.code = "SDT4" do
				break;
			endforeach;
		endif;
	elseif _calType.isVoyageCalcType then
		debtorType := app.myRoot.allDebtorTypes["SDT4"];
	elseif _calType.isEventCalcType then
		debtorType := app.myRoot.allDebtorTypes["SDT8"];
	endif;
	
	pxyInvoiceLineDesc.setProxy(false,
								true,
								chgNum,
								debtorType,
								_calType,
								_invoiceType,
								_narration,
								10,
								"This is a invoice line type",
								"Unit Narration",
								_services,
								false,
								null, null, null, false, false,null,null);				// PAR #36909 //31 Jan 2023 navvt20 TFS 56134

	
	app.myTrxUA.trxUpdateInvoiceLineDesc(pxyInvoiceLineDesc, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
 	
	return _invLineDesc;
epilog
	delete pxyInvoiceLineDesc;
end;</source>
        <Parameter name="_invLineDesc" type="CM_InvoiceLineDesc"/>
        <Parameter name="_narration" type="String"/>
        <Parameter name="_calType" type="CM_CalculationType"/>
        <Parameter name="_invoiceType" type="CM_InvoiceDesc"/>
        <Parameter name="_services" type="CM_ServiceByNameDict"/>
        <Parameter name="_debtorType" type="String"/>
        <ReturnType type="CM_InvoiceLineDesc"/>
    </JadeMethod>
    <JadeMethod name="updateInvoiceRateEntry" id="20660530-0ae1-4512-907d-33d434603068">
        <source>updateInvoiceRateEntry(_rate : CM_Rate; _rateEntry : CM_RateEntry; _start : TimeStamp; _expiry : TimeStamp; _ignoreEntry : Boolean; _costs : DecimalArray;
			_adjustToBase : Decimal;
			_percentOfBase : Decimal;
			_parentRate : CM_Rate;
			_tidalClassRates : CM_RateByTidalClass
			);
// 08/04/2011	cnwmh5	PAR #27347 - Add cmsEndLoad or endLoad to epilog so that if error occurs it will not leave it in beginLoad state
vars
	pxyRE	: CM_RateEntry;
	cpu : Real;
	user : String;
	ls	: Boolean;
	tidalClassRate : CM_TidalClassRate;
	pxyTidalClassRate : CM_TidalClassRate;
begin
	if _costs.size &gt;= 1 then
		cpu := _costs[1];
	endif;
	
	user := app.myPassport.myUser.code; 
	app.cmsBeginLoad(ls);
	pxyRE := app.createUpdateProxy(_rateEntry).CM_RateEntry;
	app.cmsEndLoad(ls);

	pxyRE.setProxy(_costs, cpu, _rate, user, _start, _expiry, _ignoreEntry, _adjustToBase, _percentOfBase, _parentRate );
	//24 Jul 2018	NDL	TFS 39338
	if _tidalClassRates &lt;&gt; null then
		foreach tidalClassRate in _tidalClassRates do
			pxyTidalClassRate := pxyRE.getObjectRateForObject( tidalClassRate.myTidalClass ).CM_TidalClassRate;
			if pxyTidalClassRate &lt;&gt; null then
				pxyTidalClassRate.setCostPerUnit( tidalClassRate.costPerUnit );
			else
				create pxyTidalClassRate transient;
				pxyTidalClassRate.setDetails(	tidalClassRate.costPerUnit,	//_costPerUnit : Decimal;
												tidalClassRate.myTidalClass,	//_myTidalClass : HMS_TidalClass;
												pxyRE	//_myRateEntry : CM_RateEntry
												);
			endif;
		endforeach;
	endif;
	
	app.myTrxUA.trxUpdateRateEntry(pxyRE, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
epilog
	app.cmsEndLoad(ls);				// 08/04/2011 cnwmh5 #27347
	delete pxyRE;
end;
</source>
        <Parameter name="_rate" type="CM_Rate"/>
        <Parameter name="_rateEntry" type="CM_RateEntry"/>
        <Parameter name="_start" type="TimeStamp"/>
        <Parameter name="_expiry" type="TimeStamp"/>
        <Parameter name="_ignoreEntry" type="Boolean"/>
        <Parameter name="_costs" type="DecimalArray"/>
        <Parameter name="_adjustToBase" type="Decimal"/>
        <Parameter name="_percentOfBase" type="Decimal"/>
        <Parameter name="_parentRate" type="CM_Rate"/>
        <Parameter name="_tidalClassRates" type="CM_RateByTidalClass"/>
    </JadeMethod>
    <JadeMethod name="updateInvoiceReevaluate" id="5cdb0151-577e-4a02-988e-b56bec08aaa0">
        <source>updateInvoiceReevaluate(_trans : CM_TransactionSet; _ti : CM_TrackedItem; _opts : CM_AssociationDict);
// ---------------------------------------------------------------------------
// Created:     21 July 2010 by NAVAB1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	controller : CMIF_TiTransactionResync;
begin

	create controller transient;
	
	controller.myTrackedItem := _ti;
	_trans.copy(controller.allTransactions);
	if _opts &lt;&gt; null then
		controller.updateWeight := _opts.bool("updateWeight");
		controller.updateCustomsAgent := _opts.bool("updateCustomsAgent");
	endif;
	
	app.myTrxUA.trxUpdateRsyncTrans(controller, app.myPassport);

epilog

	delete controller;

end;</source>
        <Parameter name="_trans" type="CM_TransactionSet"/>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_opts" type="CM_AssociationDict"/>
    </JadeMethod>
    <JadeMethod name="updateInvoiceStatus" id="d0188786-0eec-4bfc-a60f-e86e7c6234a2">
        <source>updateInvoiceStatus(_invoice : CM_Invoice; _status : Integer; _isZeroRated : Boolean; _termsOfTrade : CM_InvoiceTermsOfTrade; 
					_purchaseOrderNumber : String; _narration : String; _endDate : Date; _doExport : Boolean) ;
vars
	theStatus : CMIF_InvoiceStatus;
	pxyInvoice,realInvoice : CM_Invoice;
	idx : Integer;
	invoices : CM_InvoiceBySeqNumDict;
	statuses	: CMIF_Array;
	finIOClass	: CM_ExtFinanceIO;
begin
	realInvoice := _invoice;
	create invoices transient;
	create statuses transient;
	invoices.add(realInvoice);

	idx := invoices.size;

	pxyInvoice := app.createUpdateProxy(realInvoice).CM_Invoice;
	
	create theStatus transient;
	theStatus.myInvoice := pxyInvoice;
	theStatus.newStatus := _status;
	if _status = CM_Invoice.INVOICE_POSTED then
		theStatus.isZeroRatedTax := _isZeroRated;
		theStatus.myTermsOfTrade := _termsOfTrade;
		theStatus.purchaseOrderNumber := _purchaseOrderNumber;
		theStatus.narration := _narration;
		theStatus.toDT.setDate(_endDate);
		theStatus.toDT.setTime('23:59:59.999'.Time);
		theStatus.doExport :=  _doExport;

	endif;
	theStatus.myLocale := realInvoice.myLocale;								//navra1 - CR 57933 - 12th Mar 2024
	statuses.add(theStatus);
	
	app.myTrxUA.trxUpdateInvoiceStatuses(statuses, app.myPassport);
	
	// TFS 1930 May 2016 export moved after the transaction
	if _status = CM_Invoice.INVOICE_POSTED and
	   _doExport then
		// assume that this has been set up in testing
		finIOClass := self.getTerminal().getConfig(FinancialIOClass).CM_ExtFinanceIO;
		finIOClass.export(realInvoice);
	endif;

	
epilog
	delete invoices;
	delete pxyInvoice;
	statuses.purge;
	delete statuses;
end;</source>
        <Parameter name="_invoice" type="CM_Invoice"/>
        <Parameter name="_status" type="Integer"/>
        <Parameter name="_isZeroRated" type="Boolean"/>
        <Parameter name="_termsOfTrade" type="CM_InvoiceTermsOfTrade"/>
        <Parameter name="_purchaseOrderNumber" type="String"/>
        <Parameter name="_narration" type="String"/>
        <Parameter name="_endDate" type="Date"/>
        <Parameter name="_doExport" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="updateInvoiceStatusMulti" id="ff14bd48-ba3c-4bfd-98d9-1a53adff1c47">
        <source>updateInvoiceStatusMulti(_pxyStatuses : CMIF_Array; _passport : CM_Passport input);
/*

Purpose:			Updates the status of multiple invoices

Parameters:			_pxyStatuses	CMIF_Array	List of statuses to update
					_passport		CM_Passport	The passport to hold all the errors and warnings

Return Value:		NONE

Date		Who		Reason
08 December 2022	navpw1	Initial creation TFS: 54571

*/

begin
	app.myTrxUA.trxUpdateInvoiceStatuses(_pxyStatuses, _passport);
	
end;</source>
        <Parameter name="_pxyStatuses" type="CMIF_Array"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="updateInvoiceStatusSingle" id="73f7c948-4f4e-4397-b726-95d1fa72d72a">
        <source>updateInvoiceStatusSingle(_invoice : CM_Invoice ; _status : Integer; _isZeroRated : Boolean; _termsOfTrade : CM_InvoiceTermsOfTrade; 
							_purchaseOrderNumber, _narration : String; _endDate : Date; _doExport : Boolean);
/*

Purpose:			Updates the status of a single invoice

Parameters:			_invoice				CM_Invoice				The invoice to update the status for
					_status					Integer					The status to change the invoice to
					_isZeroRated			Boolean					Whether or not the invoice is zero rated
					_termsOfTrade			CM_InvoiceTermsOfTrade	The terms of trade for the invoice
					_purchaseOrderNumber	String					The purchase order number to use on the invoice
					_narration				String					The narration to use for the invoice
					_endDate				Date					The end date to use for the invoice
					_doExport				Boolean					Whether or not we need to export the invoice

Return Value:		NONE

Date		Who		Reason
08 December 2022	navpw1	Initial creation TFS: 54571

*/

vars
	theStatus		: CMIF_InvoiceStatus;
	pxyInvoice,
	realInvoice		: CM_Invoice;
	finIOClass		: CM_ExtFinanceIO;
	
begin
	realInvoice := _invoice;
	
	pxyInvoice := app.createUpdateProxy(realInvoice).CM_Invoice;
	
	create theStatus transient;
	theStatus.myInvoice := pxyInvoice;
	theStatus.newStatus := _status;
	if _status = CM_Invoice.INVOICE_POSTED then
		theStatus.isZeroRatedTax := _isZeroRated;
		theStatus.myTermsOfTrade := _termsOfTrade;
		theStatus.purchaseOrderNumber := _purchaseOrderNumber;
		theStatus.narration := _narration;
		theStatus.toDT.setDate(_endDate);
		theStatus.toDT.setTime('23:59:59.999'.Time);
		theStatus.doExport :=  _doExport;
	endif;
	
	app.myTrxUA.trxUpdateInvoiceStatus(theStatus, app.myPassport);
	
	// TFS 1930 May 2016 export moved after the transaction
	if _status = CM_Invoice.INVOICE_POSTED and
	   _doExport then
		// assume that this has been set up in testing
		finIOClass := self.getTerminal().getConfig(FinancialIOClass).CM_ExtFinanceIO;
		finIOClass.export(realInvoice);
	endif;
	
epilog
	delete pxyInvoice;
	delete theStatus;
	
end;</source>
        <Parameter name="_invoice" type="CM_Invoice"/>
        <Parameter name="_status" type="Integer"/>
        <Parameter name="_isZeroRated" type="Boolean"/>
        <Parameter name="_termsOfTrade" type="CM_InvoiceTermsOfTrade"/>
        <Parameter name="_purchaseOrderNumber" type="String"/>
        <Parameter name="_narration" type="String"/>
        <Parameter name="_endDate" type="Date"/>
        <Parameter name="_doExport" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="updateJobType" id="e43d3097-8b8b-4259-9c46-9de5084dfe00">
        <source>updateJobType(_jobType : CM_JobType);

/*

Purpose:		Update the job type

Date			Who		Reason
07/03/2014		cnwmh5	Initial creation

*/

vars

	pxyJobType					: CM_JobType;
	
	loadState					: Boolean;
	hatchType					: Boolean;
	colour						: Integer;

begin

	app.cmsBeginLoad(loadState);
	pxyJobType := _jobType.pxyCreateUpdateProxy();
	app.cmsEndLoad(loadState);
	
	hatchType := _jobType.isHatchType;
	if self.opts.includesKey("HatchType") then
		hatchType := self.opts.bool("HatchType");
	endif;
	
	colour := _jobType.colour;
	if self.opts.includesKey("Colour") then
		colour := self.opts.int("Colour");
	endif;
	
	pxyJobType.setProxy(_jobType.name, hatchType, _jobType.estimatedTimeToCompleteMins, colour);
	
	app.myTrxUA.trxUpdateJobType(pxyJobType, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();

epilog

	app.cmsEndLoad(loadState);

	delete pxyJobType;

end;</source>
        <Parameter name="_jobType" type="CM_JobType"/>
    </JadeMethod>
    <JadeMethod name="updateLabourRestriction" id="0c6f57a0-67d2-4c35-9a1c-baedd1e1d812">
        <source>updateLabourRestriction(_labourRestriction : CM_LabourRestriction io );
/*

Purpose: 	Update Labour Restriction 			

Date		Who		Reason
31/03/2014	cnwma1	Initial creation

*/

vars
	pxyLabRestriction	: CM_LabourRestriction;
begin

	beginLoad;
		pxyLabRestriction := _labourRestriction.pxyCreateUpdateProxy();
	endLoad;
	
			pxyLabRestriction.setProxy(	_labourRestriction.colour,
											app.getMyUserCode(),
											"UnitTest Labour Restrication Updated", 	
											 null,								// hours
											 3,
											 _labourRestriction.myReason,
											_labourRestriction.allLocationControllers,
											_labourRestriction.id,
											false,
											_labourRestriction.myOrganisation,					// organisation
											null,					// email entity
											null,					//_emails : CM_EmailAddressByAddressDict;
											_labourRestriction.myTerminalArea);	
											

		app.myTrxUA.trxUpdateRestrictionLabour(pxyLabRestriction, _labourRestriction, app.myPassport);
		self.assertNoTrxErrorsOrWarnings();										

epilog
 delete pxyLabRestriction;
end;</source>
        <Parameter name="_labourRestriction" type="CM_LabourRestriction" usage="io"/>
    </JadeMethod>
    <JadeMethod name="updateLocationContainerLength" id="69d10ab2-083b-458d-ac64-2c70c4b7652d">
        <source>updateLocationContainerLength(_ta: CM_GridArea; _locations: CM_LCSet; _isThirty, _isFortyFive, _isFiftyThree, _isForty, _isTwenty : Boolean);
//03 September 2008	cnwdw1	
//
vars

	proxyTA: CM_GridArea;
	proxyLC: CM_GridController;
	lc: CM_LocationsController;
	gridLCDict: CM_RTGControllerBySeqRowCol;
	row, column: Integer;
begin
	proxyTA := app.createUpdateProxy(_ta).CM_GridArea;
	
	create gridLCDict transient;
	foreach lc in _locations where lc.isKindOf(CM_GridController) do
		row := lc.CM_GridController.row;
		column := lc.CM_GridController.column;
		proxyLC := proxyTA.allGridControllersByRowColumn[row, column];
		gridLCDict.add(proxyLC);
		if _isThirty then
			proxyTA.set30ftControllers(gridLCDict);
		else
			lc.setIs30ft(false);
		endif;
		if _isFortyFive then
			proxyTA.set45ftControllers(gridLCDict);
		else
			lc.setIs45ft(false);
		endif;
		if _isFiftyThree then
			proxyTA.set53ftControllers(gridLCDict);
		else
			lc.setIs53ft(false);
		endif;
		if _isForty then
			proxyTA.set40ftControllers(gridLCDict);
		else
			lc.setIs40ft(false);
		endif;
		if _isTwenty then
			proxyTA.set20ftControllers(gridLCDict);
		else
			lc.setIs20ft(false);
		endif;
	endforeach;
	
	if gridLCDict.size &gt; 0 then
		
		app.myTrxUA.trxUpdateTerminalArea(proxyTA, app.myPassport);
		self.assertTrueMsg(app.myPassport.trxCompletedOK(), app.myPassport.getAllErrorsWarningsAsString());
	endif;
	
epilog
	delete proxyTA;
	delete gridLCDict;

end;</source>
        <Parameter name="_ta" type="CM_GridArea"/>
        <Parameter name="_locations" type="CM_LCSet"/>
        <Parameter name="_isThirty" type="Boolean"/>
        <Parameter name="_isFortyFive" type="Boolean"/>
        <Parameter name="_isFiftyThree" type="Boolean"/>
        <Parameter name="_isForty" type="Boolean"/>
        <Parameter name="_isTwenty" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="updateMachine" id="67f6775b-36e5-48aa-88b4-09cda3e4fc21">
        <source>updateMachine(_machine : CM_Machine);

/*

Purpose:		Update a machine

Date			Who		Reason
02/03/2014		cnwmh5	Initial creation

*/

vars

	pxyMachine						: CM_Machine;
	cmif_Machine					: CMIF_Machine;
	
	loadState						: Boolean;
	
begin

	create cmif_Machine transient;
	
	cmif_Machine.code := _machine.id;
	cmif_Machine.description := _machine.description;
    cmif_Machine.machineType := app.myRoot.allMachineTypes[_machine.machineType];
   	cmif_Machine.colour := _machine.colour;
	cmif_Machine.available := _machine.available;
    cmif_Machine.canLift40Foot := _machine.canLift40Foot;
    cmif_Machine.canLift30Foot := _machine.canLift30Foot;
    cmif_Machine.canLift45Foot := _machine.canLift45Foot;
    cmif_Machine.canLift53Foot := _machine.canLift53Foot;
	cmif_Machine.maxLiftWeight := _machine.maxLiftWeight.Integer;
    cmif_Machine.maxLiftWeightTL := _machine.twinLiftMaxWeightDiff.Integer; 
    cmif_Machine.maxStackHeightMT := _machine.maxHeightMT;
    cmif_Machine.maxStackHeightFull := _machine.maxHeightFull;
    cmif_Machine.isNotAvailableForEntry	:= _machine.isNotAvailableForEntry;
	cmif_Machine.myRFIDTag:= _machine.myRFIDTag;
	cmif_Machine.weightDifference := _machine.weightDifference;
	cmif_Machine.machineLiftType := _machine.machineLiftType;
	if self.opts.includesKey("MachineLiftType") then
		cmif_Machine.machineLiftType := self.opts.int("MachineLiftType");
	endif;
	cmif_Machine.loadingPosition := _machine.loadingPosition;
	cmif_Machine.myPhysicalStartBay	:= _machine.myPhysicalStartBay;
	cmif_Machine.myPhysicalEndBay := _machine.myPhysicalEndBay;

	//12 Aug 2020	NDL	TFS 49894
	if self.opts.includesKey("hasRadioTelemetry") then
		cmif_Machine.hasRadioTelemetry := self.opts.bool("hasRadioTelemetry");
	else
		cmif_Machine.hasRadioTelemetry := _machine.hasRadioTelemetry;
	endif;
    cmif_Machine.networkAddress := _machine.networkAddress;
    cmif_Machine.recordActivityHistory := _machine.recordActivityHistory;
    cmif_Machine.maxRejectedTasks := _machine.maxRejectedTasks;
    cmif_Machine.canWeigh := _machine.canWeighCargo;
	cmif_Machine.canCertifyWeight := _machine.canCertifyWeight;
     
	if cmif_Machine.hasRadioTelemetry then
		_machine.allowedTAMasters.copy(cmif_Machine.terminalAreas);
		_machine.allAllowedCargoTypes.copy(cmif_Machine.cargoTypes);
		_machine.allQueues.copy(cmif_Machine.allSelectedQueues);
		_machine.allAllowableContentsStatuses.copy(cmif_Machine.allAllowableContentStatuses);
    endif;    

	
	app.cmsBeginLoad(loadState);
	pxyMachine := _machine.pxyCreateUpdateProxy;
	app.cmsEndLoad(loadState);

	pxyMachine.setProxyFromCMIF_Machine(cmif_Machine, app.myPassport);

	app.myTrxUA.trxUpdateMachine(pxyMachine, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();

epilog

	app.cmsEndLoad(loadState);

	delete pxyMachine;
	delete cmif_Machine;

end;</source>
        <Parameter name="_machine" type="CM_Machine"/>
    </JadeMethod>
    <JadeMethod name="updateManualInvoiceLineTax" id="e1b0f290-20ba-42ac-b533-a148dcaea4a4">
        <source>updateManualInvoiceLineTax(realInvoice : CM_Invoice; ild : CM_InvoiceLineDesc; newTaxCode: CM_TaxCode;ti : CM_TrackedItem) : Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 October 2022	navmv20	ChangeRequest 55005: EUP - Invoicing - Invoice Line TAX Maintenance

*/

vars
	now			  : Date;
	operator	  : CM_Operator;
	invLine		  : CM_InvoiceLine;
	manController : CMIF_InvoiceLineManual;

	theController : CMIF_ChargesController;
	aCharge,
	pxyCharge,
	charge 		  : CM_Charge;
	isAudit       : Boolean;
	
begin

	create theController transient;

	foreach aCharge in realInvoice.invoiceLines.first.charges do 
		pxyCharge := app.createUpdateProxy(aCharge).CM_Charge;
		pxyCharge.setProxyTaxNew(newTaxCode);
		theController.allChargesByTax.add(pxyCharge);
	endforeach;

	app.myTrxUA.trxUpdateChargesTaxManual(theController,app.myPassport);	
	charge := theController.allChargesByTax.last;
	if charge.isTransient then
		charge := app.myProxyManager.getRealObject(charge).CM_Charge;
	endif;
	if not charge.allAuditObjects.isEmpty then
		isAudit := charge.allAuditObjects.last.CM_AuditObject.type = AuditUpdated;
	else
		isAudit := false;
	endif;
	
	return isAudit;
epilog
	self.resetDefaultTranMap();
	delete manController;
	delete pxyCharge;
	theController.allChargesByTax.purge();
	delete theController;
end;
</source>
        <Parameter name="realInvoice" type="CM_Invoice"/>
        <Parameter name="ild" type="CM_InvoiceLineDesc"/>
        <Parameter name="newTaxCode" type="CM_TaxCode"/>
        <Parameter name="ti" type="CM_TrackedItem"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
