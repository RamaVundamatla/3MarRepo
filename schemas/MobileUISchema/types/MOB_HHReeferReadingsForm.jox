    <JadeMethod name="translateForm" id="0ed72f25-a6b0-4ce2-89fd-12cd9ccc4807">
        <updating/>
        <source>translateForm(locale : CM_Locale) updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 20 March 2015.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	
begin
	// Determine the locale for translations.
	inheritMethod(locale);
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0013118, locale);
	btnSearchLocs.translateCaption(Xlat_0017606, locale);
	chkNoCharge.translateCaption(Xlat_0013119, locale);
	chkTraverseCol.translateCaption(Xlat_0013120, locale);
	lblCargoId.translateCaption(Xlat_0019068, locale);
	lblHumidity.translateCaption(Xlat_0020344, locale);
	lblLocationTitle.translateCaption(Xlat_0013121, locale);
	lblTemperature.translateCaption(Xlat_0013122, locale);
	lblVentilation.translateCaption(Xlat_0020345, locale);
	mAlert.translateCaption(Xlat_0013123, locale);
	mPopup.translateCaption(Xlat_0013124, locale);
end;</source>
        <Parameter name="locale" type="CM_Locale"/>
    </JadeMethod>
    <JadeMethod name="txtCargoId_gotFocus" id="2ef2ebb5-436c-46f8-aa66-bfbb0a68b7c0">
        <controlMethod name="TextBox::gotFocus"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>txtCargoId_gotFocus(textbox: TextBox input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 May 2013	cnwndl1	Initial creation	Par 51506

*/

vars

begin

	if self.txtCargoId.text = self.lblCargoId.caption.toUpper then
		self.txtCargoId.selStart := 0;
		self.txtCargoId.selLength := self.lblCargoId.caption.length;
	endif;

epilog

end;</source>
        <Parameter name="textbox" type="TextBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="txtCargoId_lostFocus" id="4d82be5c-e380-4c8d-ab7b-159ad0b9aa58">
        <controlMethod name="TextBox::lostFocus"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>txtCargoId_lostFocus(textbox: TextBox input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 May 2013	cnwndl1	Initial creation		Par 51506

*/

vars

begin

	app.convertScannedCargoId( self.myTerminal, textbox, false, null );	//06 Jul 2016	NDL	TFS 2275

	if self.txtCargoId.text = self.lblCargoId.caption.toUpper then
		self.setMyTrackedItem( null );
		//do nothing
	elseif self.txtCargoId.text.trimBlanks = null then
		self.setMyTrackedItem( null );
		self.txtCargoId.text := self.lblCargoId.caption.toUpper;
	else
		if self.myTrackedItem &lt;&gt; null and self.myTrackedItem.id &lt;&gt; self.txtCargoId.text then
			self.selectCargoItem( false );
		endif;
	endif;
	
	self.txtCargoId.selStart := 0;
	self.txtCargoId.selLength := 0;

epilog


end;</source>
        <Parameter name="textbox" type="TextBox" usage="input"/>
    </JadeMethod>
