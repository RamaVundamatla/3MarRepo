    <JadeMethod name="shouldAuditProperty" id="bc5ec256-66de-48e6-a44f-c501d36e6e22">
        <source>shouldAuditProperty(_rootClass: Class; _property: Property): Boolean protected;
/*
Purpose:			

Date		Who		Reason
03 August 2023	navab1	CR 56093 TASK 59624
*/

begin
	if _property.name = 'direction' then
		return false;
	endif;
	return inheritMethod(_rootClass, _property);
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_rootClass" type="Class"/>
        <Parameter name="_property" type="Property"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validateForCreate" id="f7776b50-47f2-4a32-872a-7198635cbc64">
        <source>validateForCreate();
/*
Purpose:			

Date		Who		Reason
03 August 2023	navab1	 CR 56093 TASK 59623
*/

vars

begin
	if self.myTerminal = null then
		app.raiseCMException(Custom_docume_must_have_termin,null,null);
	endif;
	
	self.validateForUpdate();
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="validateForDelete" id="9e27ae04-6ce6-44be-98a0-a9e88f409f63">
        <source>validateForDelete();
/*
Purpose:			

Date		Who		Reason
03 August 2023	navab1	 CR 56093 TASK 59623
*/

vars

begin
	if self.allCustomDocuments.isNotEmpty() then
		if self.allCustomDocuments.size &gt; 3 then
			app.raiseCMException1(Custo_docum_type_used_many_cus,self.code,null,null);
		else
			app.raiseCMException2(Custom_docume_type_cannot_dele, self.code, self.getCustomDocsUsed(),null,null);
		endif;
	endif;
	
	if self.allCustomLicenses.isNotEmpty() then
		if self.allCustomLicenses.size &gt; 3 then
			app.raiseCMWarning1(Custom_licenses_canot_delete,self.code,null,null, null);
		else
			app.raiseCMWarning2(Custom_license_cannot_delete, self.code, self.getCustomLicenseUsed(),null,null, null);
		endif;
	
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="validateForUpdate" id="c2ff9ae3-dea2-4641-97a3-4d16b6d29c0b">
        <source>validateForUpdate();
/*
Purpose:			

Date		Who		Reason
03 August 2023	navab1	 CR 56093 TASK 59623
*/

vars
	otherMe, realMe, docType : SelfType;
	isUpdate : Boolean;
begin
	isUpdate := self.pxyIsProxy();
	
	if self.code = null then
		app.raiseCMException(Custo_docum_type_must_have_cod,null,null);
	endif;
	
	if self.description = null then
		app.raiseCMException(Custo_docum_type_must_have_des,null,null);
	
	endif;
	
	if self.direction &gt; 2 then
		app.raiseCMException(Custo_docum_type_only_inwar_ou,null,null);
	
	endif;
	
	otherMe :=  self.myTerminal.allCustomDocumentTypes[self.code];
	if isUpdate then
		realMe := self.pxyGetRealObject();
		if otherMe &lt;&gt; null 
		and (realMe &lt;&gt; null and otherMe &lt;&gt; realMe) then
			app.raiseCMException1(Custo_docum_type_with_code_alr,self.code,null,null);
		
		endif;
	elseif otherMe &lt;&gt; null then
		app.raiseCMException1(Custo_docum_type_with_code_alr,self.code,null,null);
	endif;
	
	// ### TFS CR 60424 TASK 60549 29SEP2023 NAVAB1
	if self.allStopsToApply.isNotEmpty 
	and self.allStopsToClear.isNotEmpty then
		app.raiseCMWarning(Docum_type_canno_apply_stops_c,null,null,null);
	endif;
	
	// ### TFS CR 60424 TASK 60549 29SEP2023 NAVAB1
	if self.allStopsToApply.isEmpty 
	and self.allStopsToClear.isEmpty then
	// this is fine we do not care what the direction is
	elseif self.allStopsToApply.isEmpty
	and self.direction = self.CustDocTypeDir_Inward then
		app.raiseCMWarning(Stops_apply_have_not_been,null,null,null);
	elseif self.allStopsToClear.isEmpty 
	and self.direction = self.CustDocTypeDir_Outward then
		app.raiseCMWarning(Stops_clear_have_not_been,null,null,null);
	
	endif;	

	
	foreach docType in self.allNextDocumentTypes discreteLock do
		if docType.code = self.code then
			app.raiseCMException1(Canno_inclu_docum_type_next_do,self.code,null,null);
		
		endif;
	
	endforeach;
epilog

end;</source>
    </JadeMethod>
</Class>
