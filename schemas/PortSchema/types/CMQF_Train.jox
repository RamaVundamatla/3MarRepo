    <JadeMethod name="cloneReferences" id="3a9f0c60-0a64-4d35-9722-fbb39fb59068">
        <updating/>
        <source>cloneReferences(_obj: CMQF_Train; _transient: Boolean) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
05 July 2010	cnwmd1	Initial creation

*/

vars

begin
	inheritMethod(_obj, _transient);
	
	self.setMyTrain( _obj.getMyTrain );
	
epilog

end;</source>
