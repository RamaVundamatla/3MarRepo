    <JadeMethod name="addToAlerts" id="6c1636b6-db78-4c08-b2c0-8e2b07dc22b2">
        <interfaceImplements>
            <JadeInterfaceMethod name="IF_AlertAlarm::addToAlerts"/>
        </interfaceImplements>
        <updating/>
        <source>addToAlerts(alert: CM_SystemAlert) updating;
/*

Purpose:			


Return Value:		


Date		Who		Reason
06 September 2006	cnwer1	Initial creation - PAR#xxxx

*/
vars
	terminal : CM_Terminal;
begin

	if not self.alerts.includes(alert) then
		self.alerts.add(alert);
	endif;

	/*- cnwmd1, CCMS 1871 - No longer required.  app.causeEventForSystemAlertType method is called in CM_SystemAlert::commitAlert()
	if job &lt;&gt;  null then
		terminal := self.getTerminalForAlert();
		if terminal &lt;&gt; null and alert.mySystemAlertType &lt;&gt; null then
			//terminal.causeEvent(alert.mySystemAlertType.type,false,alert); 	//- cnwmd1 CCMS 1871
			app.causeEventForSystemAlertType(alert, terminal); 					//+ cnwmd1 CCMS 1871
		endif;
	endif;
	*/
epilog

end;</source>
        <Parameter name="alert" type="CM_SystemAlert"/>
    </JadeMethod>
    <JadeMethod name="addToDynaDictForRoadOps" id="f0a5e11d-e3ff-49ea-a7d8-da61d4d242c6">
        <source>addToDynaDictForRoadOps( _dynaDict : DynaDictionary input; _keysArray : StringArray input );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 December 2016	cnwndl1	Initial creation	TFS 2995 / 2638
20 Dec 2016			NDL							TFS 3123/2638

*/

vars

	type : Integer;
	str : String;

begin

	_keysArray.add( self.getOidAsString );
	
	if self.myTrackedItem &lt;&gt; null then
		foreach type in self.getMyTerminal.allRoadOpsDisplayCriteria do
			self.myTrackedItem.addStringForRoadOpsDDKey( type, _keysArray );
		endforeach;
	
	elseif self.myRequest &lt;&gt; null then
		foreach type in self.getMyTerminal.allRoadOpsDisplayCriteria do
			self.myRequest.addStringForRoadOpsDDKey( type, _keysArray );
		endforeach;
	
	else
		str := null;
		foreach type in self.getMyTerminal.allRoadOpsDisplayCriteria do
			_keysArray.add(str);
		endforeach;
		
	endif;
	
	//the first key is only for the oid, it is not part of the sort key
	if _keysArray.size = 2 then
		_dynaDict.putAtKey(_keysArray[2], self);
	elseif _keysArray.size = 3 then
		_dynaDict.putAtKey(_keysArray[2], _keysArray[3], self);
	elseif _keysArray.size = 4 then
		_dynaDict.putAtKey(_keysArray[2], _keysArray[3], _keysArray[4], self);
	elseif _keysArray.size = 5 then
		_dynaDict.putAtKey(_keysArray[2], _keysArray[3], _keysArray[4], _keysArray[5], self);
	elseif _keysArray.size = 6 then
		_dynaDict.putAtKey(_keysArray[2], _keysArray[3], _keysArray[4], _keysArray[5], _keysArray[6], self);
	elseif _keysArray.size = 7 then
		_dynaDict.putAtKey(_keysArray[2], _keysArray[3], _keysArray[4], _keysArray[5], _keysArray[6], _keysArray[7], self);
	endif;
	
epilog

end;</source>
        <Parameter name="_dynaDict" type="DynaDictionary" usage="input"/>
        <Parameter name="_keysArray" type="StringArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="anyIdCargoAvailableCount" id="8c004107-ea5f-492f-a855-fa6a653d9590">
        <source>anyIdCargoAvailableCount():Integer;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 Mar 2017	cnwndl1	Initial creation	TFS 3813
04 Dec 2025 navma1  MTN-36742 AAT- Webb Dock West (WDCT) experiencing slowness 			
*/

vars
	ti 			: CM_TrackedItem;
	delReq 		: CM_DeliveryRequest;
	bulkRelease : CM_BulkRelease;
	count 		: Integer;

begin

	if not self.isAnyId then
		return count;
	endif;

	delReq 		:= self.myRequest.CM_DeliveryRequest; // its always a delivery request if its an Any Id
	bulkRelease := delReq.myOriginatingBulkRelease;
	
	if bulkRelease = null then
		return count;
	endif;

	foreach ti in bulkRelease.allTrackedItemsAssigned discreteLock do		//04.12.2025 navma1 #MTN-36742
		if not ti.isTiAvailableForAnyIdSelection() then
			continue;
		endif;
		
		count := count + 1;
		
		if count &gt; 0 then													//04.12.2025 navma1 #MTN-36742
			break;
		endif;
	endforeach;

	return count;
	
epilog
end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="archive" id="180df8db-1950-4d3c-9125-dcc9925b6ba3">
        <updating/>
        <source>archive() updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
03 August 2011	cnwer1	Initial creation CCMS MES 1033

*/

vars

begin

	self.updateRequest(null);
	self.erase(NORMAL_ERASE);
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="areAllEntryTasksEqStatus" id="75cf9a6d-e616-4c91-9ec5-7d751ed3c54f">
        <source>areAllEntryTasksEqStatus(statusToTest : Integer) : Boolean;
/*
 ------------------------------------------------------------------------
Created:			28 August 2002 by cnwdwq1
Purpose:			
Parameters:		None
Returns:			Nothing
Changed On		Changed By		Reason
--------------	--------------	-----------------------------------------
06 Mar 2025		navma1  		MTN-34179 MTN | Dead Lock (1081) on CM_WLEArray
---------------------------------------------------------------------------
*/
vars
	nextQE,
	rtqe 	: CM_RTQueueEntry;
begin
	foreach rtqe in self.allRTQueueEntries discreteLock do					//06.03.2025 navma1 #MTN-34179
		if rtqe.areAllTasksEqualStatus(statusToTest) = false then
			return false;
		endif;
		
		//epr par 35702 5/3/15 
		if rtqe.myBreakBulkMaster &lt;&gt; null then
			if not rtqe.myBreakBulkMaster.areAllTasksEqualStatus(statusToTest) then
				return false;
			endif;
		endif;
		
		if rtqe.machineTypeGroup = MACHINETYPEGRP_IMV then
			nextQE := rtqe.getNextRelatedEntry;
			if nextQE &lt;&gt; null and not self.allRTQueueEntries.includes(nextQE) then
				if not nextQE.areAllTasksEqualStatus(statusToTest) then
					return false;
				endif;
			endif;
		endif;
		
	endforeach;
	
	
	return true;
end;</source>
        <Parameter name="statusToTest" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="areTasksUnactionedOrHeld" id="c612178c-5cf6-4f20-a3a5-6c49e602b38e">
        <source>areTasksUnactionedOrHeld() : Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26 July 2013	cnwmc5	Initial creation		PAR 31553

*/

vars
	rtqe : CM_RTQueueEntry;
begin
	foreach rtqe in self.allRTQueueEntries do
		if rtqe.areTasksUnactionedOrHeld() = false then
			return false;
		endif;
	endforeach;
	
	return true;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="assignTIandBOL" id="a5ecd38e-5e3b-483f-a369-efed8fbbcfb1">
        <updating/>
        <source>assignTIandBOL(_ti : CM_TrackedItem; _bol : CM_BOL) updating;
//--------------------------------------------------------------
//Created: 21 February 2003 By: cnwgd1
//--------------------------------------------------------------
// 01/04/2010	cnwcs5	par 23383 - pass context info (self) to updateTICollections 
//									via new parameter (_extra)
// 12/11/2010	cnwdap1	PAR #23794 CCMS MES 1102 if the WLE already has a TBA tracked item, transfer any future moves
// 									to the real tracked item. Delete the TBA trackd item
// 03/12/2010	cnwdap1	PAR #26426 job may be null - don't update collections if we don't have a job
// 15/12/2010	cnwdap1	PAR #26426 Also call changeTBAForRealTI for voyage jobs
// 19/11/2019   cnwma1	Bug 47436: PEN - Avail Cargo to load not showing in correctly in hand held
// 06 Jun 2023  navma1 ChangeRequest 58339: EUP | Delivery Dispatch Screen - Road Operation
// 23/06/2023	navkc1	CR 58406 Task 58408: Jade - Release Request All Tracked Items
// 27/07/2023	jlizm1	TFS 58752 WLE Wagon details not displaying
// 12/09/2024	navpw1	TFS: 65623 (65624) - Added code to update work order job with the tis assigned to it
// 17/03/202    navma1 MTN-34120 MTN | Dead Lock (1081) on CM_OfflineFutureActorParentDct

vars
	ti 				  : CM_TrackedItem;
	bulkRelease       : CM_BulkRelease;
	reserve			  : CM_ReserveDetail;
	weight 			  : Decimal[14,4];
	quantity 		  : Integer;
	gcRequest 		  : CM_ROROGCRequest;
	isBBReleasebyType : Boolean;
	otherWlesQuantity : Integer;
	updateAllLocs 	  : Boolean;
	preWleCount 	  : Integer;
	newRailBBWle 	  : CM_WorkListEntry;
	request			  : CM_Request;
begin
	
	request  := self.myRequest;						//06.06.2023 navma1 #58339
	
	// PAR #23794 if my current TI is a TBA TI, and my job is a rail job, copy TBA details to the new TI
	// and delete the TBA TI
	if _ti &lt;&gt; null and self.myTrackedItem &lt;&gt; null and self.myTrackedItem.isRRPforRail 
	and (CM_RailJob.hasInstance(self.job) or CM_VoyageJob.hasInstance(self.job)) then
		ti := _ti;
		self.changeTBAForRealTI(ti);
	endif;
	// PAR #23794 end
	
	self.myBOL := _bol;
	self.setMyTrackedItem(_ti);

	if _ti &lt;&gt; null then		
		if self.isDRLinkedByFM then     			 //19.11.2019 cnwma1 #47436
			// 28/06/2019 jglzm1 tfs42863
			// if we've set the quanity before now, use that.
			// it's set ahead of time when planning to split cargo during direct release
			if self.quantity &gt; 1 then
				quantity := self.quantity;
			else
				quantity :=_ti.totalQuantity.max(1);
			endif;
		else
			quantity :=_ti.totalQuantity.max(1);
		endif;
		
			
		if self.isAnyAmount then	//20 July 2017	NDL	TFS 5477
			quantity := 1;
			weight   := 1;			//20 May 2020	NDL	TFS 49167
			
		elseif  request &lt;&gt; null then
			//epr par 34296 13/6/14
			isBBReleasebyType := request.isBreakBulkReleaseByType() or request.isBulkMultiReleaseByType;
			
			if request.isKindOf(CM_ROROGCRequest) then
				gcRequest := request.CM_ROROGCRequest;
				quantity  := (gcRequest.quantity - gcRequest.getWLEQuantityTIAssigned(self)).Integer.min(quantity);	
			elseif request.isKindOf(CM_DeliveryRequest) then
			
				//epr par 34296 13/6/14 minumum of the ti quatity or the remaining total requested
				if request.CM_DeliveryRequest.getRemainingTotalRequested &gt; 0 then
					otherWlesQuantity := request.CM_DeliveryRequest.totalRequested - request.getWLEQuantityExceptWLE(self);	//16 Jul 2015	NDL	Par 36480
					quantity 		  := quantity.min( otherWlesQuantity ); 												//16 Jul 2015	NDL	Par 36480
				endif;
			elseif request.isKindOf(CM_TIRequest) then
				if request.CM_TIRequest.quantity &gt; 0 then
					quantity := quantity.min( request.CM_TIRequest.quantity - request.getWLEQuantityExceptWLE(self));
				endif;
			endif;
			
			if _ti.myCargoType.isBulkMulti then
				
				weight:=_ti.totalWeight;
				if request.weightRequested &gt; 0 then
					if request.isDeliveryRequest() then
						weight := _ti.totalWeight.min(request.CM_DeliveryRequest.weightRequested - request.getWLEWeightTIAssigned(self));
					else
						weight := _ti.totalWeight.min( request.weightRequested ); 
					endif;
				endif;
				self.setWeight(weight);
			endif;
		endif;
		
		self.setQuantity(quantity);
	
		if  gcRequest &lt;&gt; null  or isBBReleasebyType then
		//the request is created with wles.size = request.quantity for RORO GC when a ti is assigned with quantity  &gt; 1 need to 
		//delete some of the unassigned wles 
		
			//01 Mar 2017	NDL	TFS 3523
			if isBBReleasebyType
			and self.isKindOf(CM_YardWLE)
			and not self.CM_YardWLE.allLocationControllers.isEmpty then// Means its a rail assigned wle
				// TFS 58752
				if (request.bulkRelease &lt;&gt; null
					and request.bulkRelease.isRailType)
				or  (request.myOriginatingBulkRelease &lt;&gt; null
					and request.myOriginatingBulkRelease.isRailType) then
					updateAllLocs := true;
					preWleCount   := request.allWorkListEntries.size;
				endif;
			endif;
			
			request.createWLEs();
			
			//01 Mar 2017	NDL	TFS 3523
			if updateAllLocs then
				if request.allWorkListEntries.size = ( preWleCount + 1 ) then
					newRailBBWle := request.allWorkListEntries.last;
					if newRailBBWle.isKindOf(CM_YardWLE) then
						newRailBBWle.CM_YardWLE.allLocationControllers.add(self.CM_YardWLE.allLocationControllers.first);
					endif;
				endif;
			endif;
			
		endif;
	endif;
	
	// PAR 26482 When assigning TI need to make sure we are assigning to the 
	// correct reserveTI. 
	bulkRelease := request.myOriginatingBulkRelease;
	if bulkRelease &lt;&gt; null and not self.isAnyAmount then  //epr TFS 36643 22/1/18 if any amount don't assign reserve ti and amount
		foreach reserve in bulkRelease.allReserveDetails do
			if reserve.isKindOf(CM_ReserveTI) then
				//if reserve.allTrackedItems.includes(_ti) then
				if reserve.includeTrackedItem(_ti, false) then //23/06/2023	navkc1	CR 58406 Task 58408
				    // Found correct ReserveTI for this ti, so update the wle
					request.setReserveDetail(reserve);
					//16 Sep 2013	NDL	Par 32479
					if reserve.totalRequested &gt; 0 then
						self.setQuantity( quantity.min(reserve.totalRequested) );
					endif;
					break;
				endif;
			endif;
		endforeach;
	endif;
	
	// PAR #23794 if current TI is a TBA item, don't assign to request
	if request &lt;&gt; null and self.myTrackedItem &lt;&gt; null and not self.myTrackedItem.isTBAorIsRRP then	// PAR #23794
		request.setBulkReleaseTI(self.myTrackedItem);
	endif;
	
	//if _ti &lt;&gt; null then // when unplanning a ship job the TI is null. The update collection does not like nulls.
	if _ti &lt;&gt; null and self.job &lt;&gt; null then 	// PAR #26426 // when unplanning a ship job the TI is null. The update collection does not like nulls.
		self.job.updateTICollections(_ti, self);	// 01/04/2010 cnwcs5 par 23383
		
		//epr par 37028 6/1/16
		if self.status = WLE_COMPLETED  and self.myFutureMove = null and not self.isCompleteForJob then	//17.03.2025 navma1 #MTN-34120
			//we have re-assigned a ti
			self.setStatus(WLE_UNACTIONED);
		endif;

	endif;
	
	if self.myWorkOrderWLE &lt;&gt; null then
		self.myWorkOrderWLE.job.updateTICollections(_ti, null);
	endif;
	
end;</source>
