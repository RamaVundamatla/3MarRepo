    <JadeMethod name="setTextAndEmailID" id="03067e27-2a7f-49cd-ab67-c083148ae23f">
        <updating/>
        <source>setTextAndEmailID(_errMsg: String; _emailID : Integer) updating;
// ---------------------------------------------------------------------------
// Created:		26 May 2003  by Jason Chapman  (cnwjc2)
// ---------------------------------------------------------------------------

vars

begin
	
	if _errMsg.trimBlanks &lt;&gt; null then
		self.errorMessage := _errMsg[1:60];
		self.status := CAM_ERRORSTATUS;
	endif;
	
	if _emailID &lt;&gt; 0 then
		self.uniqueEmailID := _emailID;
	endif;
end;</source>
        <Parameter name="_errMsg" type="String"/>
        <Parameter name="_emailID" type="Integer"/>
    </JadeMethod>
