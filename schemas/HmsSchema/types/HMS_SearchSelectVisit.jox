    <JadeMethod name="doAllVisits" id="73ba6a71-bd60-409f-91be-39c2f5df4e58">
        <updating/>
        <source>doAllVisits() updating;
//-----------------------------------------
//Created: July 2003 By: cnwgd1
//-----------------------------------------
vars

begin
	// Reset all selection criteria to n/a
	// Reset ship name
	cbxShipName.listIndex:=1;
	cbxShipName.text:=cbxShipName.itemText[cbxShipName.listIndex];

	// Reset ship type
	cbxShipType.listIndex:=1;
	cbxShipType.text:=cbxShipType.itemText[cbxShipType.listIndex];

	// Reset shipping line
	cbxShipLineCo.listIndex:=1;
	cbxShipLineCo.text:=cbxShipLineCo.itemText[cbxShipLineCo.listIndex];

	// Reset pilot
	cbxPilot.listIndex:=1;
	cbxPilot.text:=cbxPilot.itemText[cbxPilot.listIndex];

	// Reset agent
	cbxAgent.listIndex:=1;
	cbxAgent.text:=cbxAgent.itemText[cbxAgent.listIndex];

	//NFS 1011: Reset berth
	cbxBerth.listIndex:=1;
	cbxBerth.text:=cbxBerth.itemText[cbxBerth.listIndex];	
	self.doFind();
end;</source>
    </JadeMethod>
    <JadeMethod name="doExportData" id="5afbac4a-93e5-4665-b4f9-8852b6a7742c">
        <updating/>
        <source>doExportData() updating;
/* 
NFS 1011: Export the contents of the exportArray as a .csv file
AKB2002MAY16 added [1:61] to all adds to string array
// 11/03/2015	cnwmh5	Transient Leaks
*/

vars
	obj 				: Object;
	textFileLines		: HMS_TextFileLineArray;
	fileIO				: CMIF_HMS_FileIO;
	fileName, str		: String;
	strArrayOut			: StringArray;
	move, prevMove		: HMS_VoyageMovement;
	voy					: CM_Voyage;
	cargoForecast		: CM_CargoForecast;	// ### TFS 53132 19Apr2022 NAVPW1
	//comm				: CM_Commodity;		// ### TFS 53132 20Apr2022 NAVPW1
	stevedore			: CM_Stevedore;
	timeInHrs			: Integer;
	delay				: HMS_VoyageDelay;
	resource			: HMS_ResourceUsed;
	harbour				: HMS_Harbour;
	voyageData			: HMS_VoyageData;
begin

	if self.exportArray.size = 0 then
		app.msgBox("There are no voyages to export", "Voyage Export", MsgBox_Information_Icon);
		return;
	endif;
	
	harbour := self.myAssistant.HMS_Assistant.myHarbour;
	if harbour = null then
		app.msgBox("Could not locate harbour", "Voyage Export", MsgBox_Information_Icon);
		return;
	endif;

	app.mousePointer := MousePointer_HourGlass;
	create textFileLines transient;

	foreach obj in exportArray do
		move := obj.HMS_VoyageMovement;
		voyageData := move.myHMSVoyageData;
		voy := voyageData.myVoyage;
		//ship := voy.getMyVessel();
		create strArrayOut transient;
		//strArrayOut.clear;

		strArrayOut.add(voy.vesselName[1:61]);	
		// AKB2002APR added IF
		if voyageData.myVesselCategoryIn &lt;&gt; null and global.isValidObject(voyageData.myVesselCategoryIn) then
			strArrayOut.add(voyageData.myVesselCategoryIn.description[1:61]);
		else
			strArrayOut.add("N/A");
		endif;
		strArrayOut.add(voyageData.dim_LengthOverall.String[1:61]);
		strArrayOut.add(voyageData.dim_GrossRegTonnes.String[1:61]);
		strArrayOut.add(move.draftMax.String[1:61]);
		// AKB2002APR added IF
		if move.myShippingLine &lt;&gt; null then
			strArrayOut.add(move.myShippingLine.description[1:61]);
		else
			strArrayOut.add("N/A");
		endif;

		strArrayOut.add(move.moveType[1:61]);
		strArrayOut.add(move.occursOnDTNEW.date.format("dd/MM/yy"));
		strArrayOut.add(move.occursOnDTNEW.Time.format("HH:mm"));

		//Add in discharge cargo for arrivals and load cargo for departures 
		//Ditto for stevedores
		if move.moveType = HMSMovementTypeDeparture then
			str := "";
			/*foreach comm in voy.myHMSVoyageData.allCommodityLoad do
			//Looping through Load commodities for voyage
				if str &lt;&gt; null then 
					str := str &amp; " / "; 
				endif;
				str := str &amp; comm.description;
			endforeach;*/ // ### TFS 53132 20Apr2022 NAVPW1 - Commented out code as below replaces it
			
			// ### TFS 53132 20Apr2022 NAVPW1
			//Looping through Load commodities for voyage
			foreach cargoForecast in voy.allCargoForecasts where cargoForecast.mode = CM_CargoForecast.Mode_Load do
				if cargoForecast.myCargoType = null and cargoForecast.myCommodity = null then
					continue;
					
				endif;
				
				if str &lt;&gt; null then 
					str := str &amp; " / ";
					
				endif;
				
				if cargoForecast.myCargoType &lt;&gt; null then
					str := str &amp; cargoForecast.myCargoType.description;
					
				elseif cargoForecast.myCommodity &lt;&gt; null then
					str := str &amp; cargoForecast.myCommodity.description;
					
				endif;
				
			endforeach;
			// ### TFS 53132 20Apr2022 NAVPW1
			
			strArrayOut.add(str[1:61]);	
			str := "";

			foreach stevedore in voy.myHMSVoyageData.allStevedoresLoad do
				if str &lt;&gt; null then str := str &amp; " / "; endif;
				str := str &amp; stevedore.description;
			endforeach;
			strArrayOut.add(str[1:61]);

			// AKB2002APR added IF
			if voy.myHMSVoyageData.myPortTo &lt;&gt; null and global.isValidObject(voy.myHMSVoyageData.myPortTo) then
				strArrayOut.add(voy.myHMSVoyageData.myPortTo.description[1:61]);
			else
				strArrayOut.add("N/A");
			endif;

		elseif move.moveType = HMSMovementTypeArrival then
			str := "";
			/*foreach comm in voy.myHMSVoyageData.allCommodityDischarge do
			//Looping through Discharge commodities for voyage
				if str &lt;&gt; null then 
					str := str &amp; " / "; 
				endif;
				str := str &amp; comm.description;
			endforeach;*/ // ### TFS 53132 20Apr2022 NAVPW1 - Commented out code as below replaces it
			
			// ### TFS 53132 20Apr2022 NAVPW1
			//Looping through Discharge commodities for voyage
			foreach cargoForecast in voy.allCargoForecasts where cargoForecast.mode = CM_CargoForecast.Mode_Discharge do
				if cargoForecast.myCargoType = null and cargoForecast.myCommodity = null then
					continue;
					
				endif;
				
				if str &lt;&gt; null then 
					str := str &amp; " / "; 
					
				endif;
				
				if cargoForecast.myCargoType &lt;&gt; null then
					str := str &amp; cargoForecast.myCargoType.description;
					
				elseif cargoForecast.myCommodity &lt;&gt; null then
					str := str &amp; cargoForecast.myCommodity.description;
					
				endif;
				
			endforeach;
			// ### TFS 53132 20Apr2022 NAVPW1
			
			strArrayOut.add(str[1:61]);		

			str := "";			
			foreach stevedore in voy.myHMSVoyageData.allStevedoresLoad do
				if str &lt;&gt; null then str := str &amp; " / "; endif;
				str := str &amp; stevedore.description;
			endforeach;
			strArrayOut.add(str[1:61]);			

			// AKB2002APR added IF
			if voy.myHMSVoyageData.myPortFrom &lt;&gt; null and global.isValidObject(voy.myHMSVoyageData.myPortFrom) then
				strArrayOut.add(voy.myHMSVoyageData.myPortFrom.description[1:61]);
			else
				strArrayOut.add("N/A");
			endif;
		else
			//Add in blank fields for shifts
			strArrayOut.add("");
			strArrayOut.add("");
			strArrayOut.add("");		
		endif;

		if move.myShippingAgent &lt;&gt; null then
			strArrayOut.add(move.myShippingAgent.description[1:61]);
		else
			strArrayOut.add("None");
		endif;

	//	if move.myPilot &lt;&gt; null then
		if move.getPilotsSummary() &lt;&gt; null then	//30 Oct 2018	NDL	TFS 41662
	//		strArrayOut.add(move.myPilot.description[1:61]);
			strArrayOut.add(move.getPilotsSummary()[1:61]);
		else
			strArrayOut.add("None");
		endif;
		strArrayOut.add(move.getMyBerth.description[1:61]);

		if move.moveType = HMSMovementTypeDeparture or move.moveType  = HMSMovementTypeShift then
			//Work out time spent occupying the berth
			prevMove := move.getVoyageMovementPrevious;
			if prevMove &lt;&gt; null then
				timeInHrs := prevMove.occursOnDTNEW.differenceInHours(move.occursOnDTNEW);
			else
				timeInHrs := 0;
			endif;
			strArrayOut.add(timeInHrs.String);		
		else
			strArrayOut.add("");		
		endif;

		if move.myTidalClass &lt;&gt; null then
			strArrayOut.add(move.myTidalClass.description[1:61]);
		endif;

		if move.moveType = HMSMovementTypeDeparture then
			str := "";
			foreach delay in voy.myHMSVoyageData.allVoyageDelays do
				if str &lt;&gt; null then str := str &amp; " / "; endif;
				timeInHrs := delay.startTime.differenceInHours(delay.stopTime);	
				// AKB2002APR added IF
				if delay.myDelay &lt;&gt; null and global.isValidObject(delay.myDelay) then
					str := str &amp; delay.myDelay.description &amp; " (" &amp; timeInHrs.String &amp; ")";		
				else
					str := str &amp; "N/A (" &amp; timeInHrs.String &amp; ")";		
				endif;
			endforeach;
			strArrayOut.add(str[1:61]);
		else
			strArrayOut.add("");		
		endif;

		strArrayOut.add((move.bowMarkTo.String &amp; "/" &amp; move.sternMarkTo.String)[1:61]);

		str := "";
		foreach resource in move.allResourceUsed do
			if str &lt;&gt; null then 
				str := str &amp; " / "; 
			endif;
			// AKB2002APR added IF
			if resource.myResource &lt;&gt; null and global.isValidObject(resource.myResource) then
				if resource.myResource.myResourceType &lt;&gt; null and global.isValidObject(resource.myResource.myResourceType) then
					str := str &amp; resource.myResource.myResourceType.description &amp; " (" &amp; resource.description &amp; ")";			
				else
					str := str &amp; resource.myResource.description &amp; " (" &amp; resource.description &amp; ")";			

				endif;
			else
				str := str &amp; "N/A (" &amp; resource.description &amp; ")";			
			endif;

		endforeach;
		strArrayOut.add(str[1:61]);

		textFileLines.add(strArrayOut);
	endforeach;


	// Generate output file
	create fileIO transient;

	if harbour.pathShippingReportFile &lt;&gt; null then
		fileIO.defaultPath:=harbour.pathShippingReportFile;
	else
		fileIO.defaultPath := "c:\temp";
	endif;

	fileName := fileIO.writeTextFile(textFileLines,DelimiterType_Comma);

epilog
	if textFileLines &lt;&gt; null then
		textFileLines.purge;		//Gets rid of all those string arrays
	endif;
	delete textFileLines;
	delete strArrayOut;
	delete fileIO;
	app.mousePointer := MousePointer_Default;	
end;</source>
    </JadeMethod>
    <JadeMethod name="doFind" id="e6676a7f-06dd-47dc-91f8-50f22b810185">
        <updating/>
        <source>doFind() updating;
//-----------------------------------------
//Created: July 2003 By: cnwgd1
//-----------------------------------------
vars
begin

	if self.myAssistant.HMS_Assistant.myHarbour = null then
		app.raiseCMException1(HMSNoHarbourForTerminal, self.myTerminal.name, null, null);
		return;
	endif;
	
	app.mousePointer := MousePointer_HourGlass;
	
 	if self.buildMatchingVoyagesListMod() then
 		// Matches were found
		fldSearchSelect.topSheet:=shtResults;
		fldSearchSelect.sheetChg(fldSearchSelect);
	endif;

epilog
	app.mousePointer := MousePointer_Default;
end;</source>
    </JadeMethod>
