    <JadeMethod name="addItemToBeginning" id="a8f9b224-d62b-49e9-b2ee-318cfa976fdd">
        <updating/>
        <source>addItemToBeginning(_newItem : CM_DeckItemLayout) updating;
/*
Purpose:			
Date		Who		Reason
09 December 2011	cnwab1	Initial creation
*/

vars
	reorderObjs : CM_RORODeckItemLayoutArray;
	realLayout : CM_DeckItemLayout;
begin
	create reorderObjs transient;
	reorderObjs.add(_newItem);
	self.allDeckItemLayouts.copy(reorderObjs);
	self.matchOrderOfItemLayouts(reorderObjs);

epilog
	delete reorderObjs;
end;</source>
        <Parameter name="_newItem" type="CM_DeckItemLayout"/>
    </JadeMethod>
    <JadeMethod name="cloneMySelf" id="fadc335f-4aab-436f-8d6d-b9edae4c34df">
        <source>cloneMySelf(_newLayout : CM_DeckLayout; _copy : Boolean) : CM_DeckLayerLayout;
/*
Purpose:			
Date		Who		Reason
29 April 2011	cnwab1	Initial creation
*/

vars
	aLane, newLane : CM_ROROLaneDefn;
	aLocn, newLocn : CM_ROROLocnDefn;
	aLayout, newLayout : CM_DeckItemLayout;
	newMe : SelfType;
	totItems, idx : Integer;
begin
	newMe := self.cloneSelf(_copy);

	newMe.myDeckLayout := _newLayout;
	
	
	foreach aLane in self.allROROLaneDefnByOrdinal discreteLock do
		newLane := aLane.cloneMySelf(newMe, _copy, false);// PAR 27528 
	endforeach;
	
	foreach aLocn in self.allROROLocnDefnByOrdinal discreteLock do
		newLocn := aLocn.cloneMySelf(newMe, _copy, false);// PAR 27528 
	endforeach;
	
	totItems := self.allDeckItemLayouts.size;
	while true do
		idx := idx + 1;
		if idx &gt; totItems then
			break;
		endif;
		aLayout :=  self.allDeckItemLayouts[idx];
		if aLayout.myDeckItem &lt;&gt; null then
			continue; // only clone the graphics with no deck item object, since the deck item objects and their graphic are cloned on the deck
		endif;
		
		newLayout := aLayout.cloneMySelf(null, newMe, _copy);
	endwhile;
	
	return newMe;
epilog

end;</source>
        <Parameter name="_newLayout" type="CM_DeckLayout"/>
        <Parameter name="_copy" type="Boolean"/>
        <ReturnType type="CM_DeckLayerLayout"/>
    </JadeMethod>
    <JadeMethod name="createPxyQuickDrawLocn" id="c90205d3-7524-42f3-8b14-1dcfe59b454f">
        <source>createPxyQuickDrawLocn(_polytype, _x1, _y1, _fillColour,_fillStyle : Integer; _lblStr : String; _locnWidth, _locnHeight, _locnGap : Decimal; _prevLocnDefn : CM_ROROLocnDefn; _orientation : Integer) : CM_DeckItemLayout;
/*
Purpose:		 PAR 27821 handle vertical and horizontal location linking	
Date		Who		Reason
07 July 2011	cnwab1	Initial creation
*/

vars
	tmpLocn : CM_DeckItemLayout;
	l1, t1, w1, h1,idx : Integer;
	lPoint	: Point;
	pointsPolygon : PointArray;
	deck : CM_Deck;
	tmpLocnDefn : CM_ROROLocnDefn;
	tmpLaneDefn : CM_ROROLaneDefn;

begin
	deck:=self.myDeckLayout.myDeck;
	create tmpLocn transient;
	create pointsPolygon transient;
				
	l1 := _x1; t1 := _y1; w1 := (l1 + _locnWidth).Integer; h1 := (t1 + _locnHeight).Integer;
	
	// ### SET POLYGON
	if _polytype = DeckItemLayoutType_Power then 
		lPoint.set(_x1 + 7,_y1 + 1);
		pointsPolygon.add(lPoint);
		lPoint.set(_x1 + 13,_y1 + 7);
		pointsPolygon.add(lPoint);
		lPoint.set(_x1 + 7,_y1 + 13);
		pointsPolygon.add(lPoint);
		lPoint.set(_x1 + 1,_y1 + 7);
		pointsPolygon.add(lPoint);
		lPoint.set(_x1 + 7,_y1 + 1);
		pointsPolygon.add(lPoint);
	else
		tmpLocn.setDefaultOutline4(l1,t1, w1, h1,pointsPolygon);
	endif;
	
	// ### SET PROXY (ORPHANED)
	if _polytype = DeckItemLayoutType_Locn  
	or _polytype = DeckItemLayoutType_Slot then 
		tmpLocn.setProxyRORO(DEFAULT_YARD_X, DEFAULT_YARD_Y, null, Black, 0, 0, null, pointsPolygon,_lblStr ,self, _fillColour, _fillStyle, 1, true, DeckItemLayoutType_Locn);
	elseif _polytype = DeckItemLayoutType_Lane then 
		tmpLocn.setProxyRORO(DEFAULT_YARD_X, DEFAULT_YARD_Y, null, Black, 0, 0, null, pointsPolygon,_lblStr ,self, _fillColour, _fillStyle, 1, true, DeckItemLayoutType_Lane);
	endif;
	
	if _polytype = DeckItemLayoutType_Locn  
	or _polytype = DeckItemLayoutType_Slot then 
		if deck.isKindOf(CM_DeckVessel) then
			create tmpLocnDefn as CM_ROROLocnDefnVessel transient;
		elseif deck.isKindOf(CM_DeckVoyage) then
			create tmpLocnDefn as CM_ROROLocnDefnVoyage transient;
		endif;
		tmpLocnDefn.setProxyForCreateDefaults(tmpLocn, _prevLocnDefn, _orientation);
		
	elseif _polytype = DeckItemLayoutType_Lane then 
		if deck.isKindOf(CM_DeckVessel) then
			create tmpLaneDefn as CM_ROROLaneDefnVessel transient;
		elseif deck.isKindOf(CM_DeckVoyage) then
			create tmpLaneDefn as CM_ROROLaneDefnVoyage transient;
		endif;
		tmpLaneDefn.setProxyForCreateDefaults(tmpLocn,(_locnGap / 10));
	endif;
	
	
	return tmpLocn;			
epilog
	delete pointsPolygon;
end;</source>
        <Parameter name="_polytype" type="Integer"/>
        <Parameter name="_x1" type="Integer"/>
        <Parameter name="_y1" type="Integer"/>
        <Parameter name="_fillColour" type="Integer"/>
        <Parameter name="_fillStyle" type="Integer"/>
        <Parameter name="_lblStr" type="String"/>
        <Parameter name="_locnWidth" type="Decimal"/>
        <Parameter name="_locnHeight" type="Decimal"/>
        <Parameter name="_locnGap" type="Decimal"/>
        <Parameter name="_prevLocnDefn" type="CM_ROROLocnDefn"/>
        <Parameter name="_orientation" type="Integer"/>
        <ReturnType type="CM_DeckItemLayout"/>
    </JadeMethod>
    <JadeMethod name="createPxyQuickDrawPolyArray" id="e9dd8855-a890-4059-a088-1618c7a31f80">
        <updating/>
        <source>createPxyQuickDrawPolyArray(_startX, _startY : Integer; _numRows, _numCol : Integer; _horiz : Boolean; _polytype : Integer; _scale : Decimal; _newDeckItems : ObjectArray input) updating;
/*
Purpose:			
Date		Who		Reason
11 April 2011	cnwab1	Initial creation
*/
constants
	LocnWidth = 60;
	LaneWidth = 500;
	LocnHeight = 60; // PAR 27513 make the default square so that it is obvious that no defaults are set
	LocnGap = 2;
	PillarWidth = 20;
	PillarHeight = 10;
vars
	allStateData : CM_StateDataDict;
	lPoint	: Point;
	pointsPolygon : PointArray;
	numGraphic, x1, y1, l1, t1, w1, h1, locnRow, locnCol, idx, fillStyle, fillColour: Integer;
	locnWidth, locnHeight,locnGap : Decimal[12,2];
	tmpLocn : CM_DeckItemLayout;
	tmpLocnDefn, prevLocnDefn : CM_ROROLocnDefn;
	tmpLaneDefn : CM_ROROLaneDefn;
	lblStr : String;
	theMode : Integer;
//	aVes : CM_Vessel;
	deck : CM_Deck;
begin
	deck:=self.myDeckLayout.myDeck;

	/* PAR 28971
	// PAR 27493
	aVes := self.getVessel();
	if aVes &lt;&gt; null then
		allStateData:= aVes.allStateData;
	endif;
	
// PAR 27513	if allStateData = null then
	if allStateData.size= 0 then
		allStateData:= app.myRoot.getStateObject(ConfigGrp_System).allStateData;
	endif;
	*/
	allStateData := deck.getAllStateDataObject(); // PAR 28971

	fillStyle :=  Frame.DrawFillStyle_Transparent;
	fillColour := Black;
	
	// ### SET DEFAULTS FOR EACH QUICK DRAW TYPE
	if _polytype = DeckItemLayoutType_Locn  
	or _polytype = DeckItemLayoutType_Slot then 
	
		lblStr := "AUTOLOCN";
		if _horiz then
			global.getExtraData(allStateData,RoRoLocationWidth,locnHeight);
			global.getExtraData(allStateData,RoRoLocationLength,locnWidth);
			global.getExtraData(allStateData,RoRoLocationGap,locnGap);
		else
			global.getExtraData(allStateData,RoRoLocationWidth,locnWidth);
			global.getExtraData(allStateData,RoRoLocationLength,locnHeight);
			global.getExtraData(allStateData,RoRoLocationGap,locnGap);
		endif;
		locnWidth := (locnWidth * ROROStructurePixelsPerMetre) - 1; // PAR 28317 should not be inclusive
		locnHeight := (locnHeight * ROROStructurePixelsPerMetre) - 1; // PAR 28317 should not be inclusive
		locnGap := (locnGap * ROROStructurePixelsPerMetre);
	elseif _polytype = DeckItemLayoutType_Lane then 
	//	lblStr := "AUTOLANE";
		lblStr := CM_Deck.AUTOLANE;	//21 Jul 2016	NDL	TFS 2371
		if _horiz then
			global.getExtraData(allStateData,RoRoLaneWidth,locnHeight);
			global.getExtraData(allStateData,RoRoLaneLength,locnWidth);
			global.getExtraData(allStateData,RoRoLaneGap,locnGap);
		else
			global.getExtraData(allStateData,RoRoLaneWidth,locnWidth);
			global.getExtraData(allStateData,RoRoLaneLength,locnHeight);
			global.getExtraData(allStateData,RoRoLaneGap,locnGap);
		endif;
		locnWidth := locnWidth * ROROStructurePixelsPerMetre;
		locnHeight := locnHeight * ROROStructurePixelsPerMetre;
		locnGap := locnGap * ROROStructurePixelsPerMetre;

	elseif _polytype = DeckItemLayoutType_Pillar then
		fillStyle :=  Frame.DrawFillStyle_Solid;
		if _horiz then
			locnWidth := PillarWidth;
			locnHeight := PillarHeight;
		else
			locnWidth := PillarHeight;
			locnHeight := PillarWidth;
	
		endif;
	elseif _polytype = DeckItemLayoutType_Power then
		lblStr := "Power";
		fillStyle :=  Frame.DrawFillStyle_Solid;
		fillColour := Yellow;
		
		if _horiz then
			locnWidth := PillarWidth;
			locnHeight := PillarHeight;
		else
			locnWidth := PillarHeight;
			locnHeight := PillarWidth;
	
		endif;

	endif;
	
	// DEFAULTS
	if locnWidth &lt;= 0 then
		locnWidth := LocnWidth;
	endif;
	if locnHeight &lt;= 0 then
		locnHeight := LocnHeight;
	endif;
	if locnGap &lt; 0 then  // PAR 27749 removed '='
		locnGap := LocnGap;
	elseif locnGap = 0 then
		locnGap := 1; //  PAR 27749 add 1 pixel so that the locns are no draw overlapping by 1 pixel
	endif;
	
	// ### CREATE THE REQUIRED NUMBER OF POLYGONS. NOTE THESE ARE NOT ATTACHED TO THE LAYER, THEY ARE ORPHANS. Attahced seperately.
	create pointsPolygon transient;
	
	if _horiz then //  PAR 27821
		y1 := (_startY / _scale).Integer;
		foreach locnRow in 1 to _numRows do
			x1 := (_startX / _scale).Integer;
			prevLocnDefn := null;
			foreach locnCol in 1 to _numCol do
				tmpLocn := self.createPxyQuickDrawLocn(_polytype, x1, y1, fillColour,fillStyle, lblStr, locnWidth, locnHeight, locnGap,prevLocnDefn, ROROLocn_AftForward);
				/* PAR 27821
				create tmpLocn transient;
				
				l1 := x1; t1 := y1; w1 := (l1 + locnWidth).Integer; h1 := (t1 + locnHeight).Integer;
				
				// ### SET POLYGON
				if _polytype = 4 then //CMUI_PointDrawingFrame.AutoPolyType_Power then
					lPoint.set(x1 + 7,y1 + 1);
					pointsPolygon.add(lPoint);
					lPoint.set(x1 + 13,y1 + 7);
					pointsPolygon.add(lPoint);
					lPoint.set(x1 + 7,y1 + 13);
					pointsPolygon.add(lPoint);
					lPoint.set(x1 + 1,y1 + 7);
					pointsPolygon.add(lPoint);
					lPoint.set(x1 + 7,y1 + 1);
					pointsPolygon.add(lPoint);
				else
					tmpLocn.setDefaultOutline(l1,t1, w1, h1,pointsPolygon);
				endif;
				
				// ### SET PROXY (ORPHANED)
				tmpLocn.setProxyRORO(DEFAULT_YARD_X, DEFAULT_YARD_Y, null, Black, 0, 0, null, pointsPolygon,lblStr ,self, fillColour,fillStyle, 1, true);
				if _polytype = 1 then //CMUI_PointDrawingFrame.AutoPolyType_Location then
					if deck.isKindOf(CM_DeckVessel) then
						create tmpLocnDefn as CM_ROROLocnDefnVessel transient;
					elseif deck.isKindOf(CM_DeckVoyage) then
						create tmpLocnDefn as CM_ROROLocnDefnVoyage transient;
					endif;
					tmpLocnDefn.setProxyForCreateDefaults(tmpLocn, prevLocnDefn);
					
				elseif _polytype = 2 then //CMUI_PointDrawingFrame.AutoPolyType_Lane then
					if deck.isKindOf(CM_DeckVessel) then
						create tmpLaneDefn as CM_ROROLaneDefnVessel transient;
					elseif deck.isKindOf(CM_DeckVoyage) then
						create tmpLaneDefn as CM_ROROLaneDefnVoyage transient;
					endif;
					tmpLaneDefn.setProxyForCreateDefaults(tmpLocn,(locnGap / 10));
				endif;
				*/
				_newDeckItems.add(tmpLocn);
				
				if _polytype = DeckItemLayoutType_Locn then 
					prevLocnDefn := tmpLocn.myDeckItem.CM_ROROLocnDefn;
				endif;
				
				x1 := x1 + ((locnWidth) + (locnGap)).Integer;
					
			endforeach;
			y1 := y1 + (locnHeight + locnGap).Integer;
		endforeach;
	else // PAR 27821 added this vertical version
		x1 := (_startX / _scale).Integer;
		foreach locnCol in 1 to _numCol do
				y1 := (_startY / _scale).Integer;
			prevLocnDefn := null;
			foreach locnRow in 1 to _numRows do
				tmpLocn := self.createPxyQuickDrawLocn(_polytype, x1, y1,fillColour,fillStyle,  lblStr, locnWidth, locnHeight, locnGap,prevLocnDefn, ROROLocn_PortStarboard);

				_newDeckItems.add(tmpLocn);
				
				if _polytype = DeckItemLayoutType_Locn then 
					prevLocnDefn := tmpLocn.myDeckItem.CM_ROROLocnDefn;
				endif;
				y1 := y1 + (locnHeight + locnGap).Integer;
					
			endforeach;
			x1 := x1 + (locnWidth + locnGap).Integer;
		endforeach;

	endif;



epilog
	delete pointsPolygon;
end;</source>
        <Parameter name="_startX" type="Integer"/>
        <Parameter name="_startY" type="Integer"/>
        <Parameter name="_numRows" type="Integer"/>
        <Parameter name="_numCol" type="Integer"/>
        <Parameter name="_horiz" type="Boolean"/>
        <Parameter name="_polytype" type="Integer"/>
        <Parameter name="_scale" type="Decimal"/>
        <Parameter name="_newDeckItems" type="ObjectArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doCopyPxyLayer" id="77fec9f6-cc66-4fd6-a089-b16f9131a1dc">
        <source>doCopyPxyLayer(_deck : CM_DeckLayout);
// ---------------------------------------------------------------------------
// Created:     24 March 2011 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

	currentBun, newBun : CM_DeckLayerLayout;
	pxyGraphic, clonedGraphic : CM_Graphic;
begin
	currentBun := self;
	
	create newBun transient;
	newBun.setProxy(self.code, self.description, self.remarks, _deck, true, self.type);
	
	
	foreach pxyGraphic in currentBun.allDeckItemLayouts discreteLock do
		pxyGraphic.CM_DeckItemLayout.doCopyPxyItem(newBun, 0);
	endforeach;


epilog

end;</source>
        <Parameter name="_deck" type="CM_DeckLayout"/>
    </JadeMethod>
    <JadeMethod name="exportAsXMLInverseRef" id="fd7b5d17-c2cd-4d6b-be8d-477d6bd416a3">
        <source>exportAsXMLInverseRef(_property: Reference): Integer protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
04 April 2011	cnwer1	Initial creation

*/

vars

begin
	if _property = CM_DeckLayerLayout::allDeckItemLayouts then
		return ExportAsParent;
	endif;

	return inheritMethod(_property);

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_property" type="Reference"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getAftLocnByPosition" id="25ebff69-983a-4312-b861-9fbe77cdc913">
        <source>getAftLocnByPosition(_fwdLocn : CM_ROROLocnDefn) : CM_ROROLocnDefn;
/*
Purpose:		CCMS 1009 28479	
Date		Who		Reason
01 November 2011	cnwab1	Initial creation
*/

vars
	itemLayout : CM_DeckItemLayout;
	fwdX, fwdY : Integer;
begin
	
	// PAR 28525
	if _fwdLocn.isVerticalOrientation() then
		fwdX := _fwdLocn.myLayout.myPolygonPixels[1].x;
		fwdY := _fwdLocn.myLayout.myPolygonPixels[1].y;
		
		foreach itemLayout in self.allDeckItemLayouts discreteLock do
// PAR 28932			if itemLayout.myDeckItem.isLocnContainer() then
			if itemLayout.myDeckItem.isKindOf(CM_ROROLocnDefn) then
	
				if _fwdLocn.orientation = itemLayout.myDeckItem.CM_ROROLocnDefn.orientation
				and itemLayout.myPolygonPixels[1].x = fwdX
				and (itemLayout.myPolygonPixels[3].y = fwdY or itemLayout.myPolygonPixels[3].y = (fwdY - 1))  then
					return itemLayout.myDeckItem.CM_ROROLocnDefn;
				endif;
			endif;
		endforeach;
	else
		fwdX := _fwdLocn.myLayout.myPolygonPixels[1].x;
		fwdY := _fwdLocn.myLayout.myPolygonPixels[1].y;
		
		foreach itemLayout in self.allDeckItemLayouts discreteLock do
//	PAR 28932		if itemLayout.myDeckItem.isLocnContainer() then
			if itemLayout.myDeckItem.isKindOf(CM_ROROLocnDefn) then
	
				if _fwdLocn.orientation = itemLayout.myDeckItem.CM_ROROLocnDefn.orientation
				and (itemLayout.myPolygonPixels[2].x = (fwdX - 1) or itemLayout.myPolygonPixels[2].x = fwdX)
				and itemLayout.myPolygonPixels[2].y = fwdY then
					return itemLayout.myDeckItem.CM_ROROLocnDefn;
				endif;
			endif;
		endforeach;
	endif;
	
	return null;
epilog

end;</source>
        <Parameter name="_fwdLocn" type="CM_ROROLocnDefn"/>
        <ReturnType type="CM_ROROLocnDefn"/>
    </JadeMethod>
    <JadeMethod name="getAllCoveringLayouts" id="4a09870f-6944-47a4-b291-3a008507ab91">
        <updating/>
        <source>getAllCoveringLayouts(_locns : CM_RORODeckItemByOrd1Ord2; _coveringItems : CM_RORODeckItemLayoutArray input; _type : Integer; _clear : Boolean) : Boolean updating;
// ---------------------------------------------------------------------------
// Created:     08 May 2013 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	item : CM_DeckItem;
	layout : CM_DeckItemLayout;
	found : Boolean;
begin
	if _locns = null then
		return false;
	endif;
	if _coveringItems = null then
		return false;
	endif;
	
	if _clear then
		_coveringItems.clear;
	endif;
		
	foreach item in _locns discreteLock do
		layout := item.myLayout.getCoveredBy(_type, true);
		if layout &lt;&gt; null then
			_coveringItems.add(layout);
			found := true;
		endif;
		
	endforeach;
	
	return found;
epilog

end;</source>
        <Parameter name="_locns" type="CM_RORODeckItemByOrd1Ord2"/>
        <Parameter name="_coveringItems" type="CM_RORODeckItemLayoutArray" usage="input"/>
        <Parameter name="_type" type="Integer"/>
        <Parameter name="_clear" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getAllStateDataObject" id="141d7a97-8c0b-496b-9869-dc41c4df0069">
        <source>getAllStateDataObject() : CM_StateDataDict;
/*
Purpose:			
Date		Who		Reason
24 February 2012	cnwab1	Initial creation
*/

vars

begin
	return self.myDeckLayout.getAllStateDataObject();
epilog

end;</source>
        <ReturnType type="CM_StateDataDict"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="d371c29b-ab69-4d36-a95c-1a167a492b1f">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
/*
Date		    Who			Reason
17 May 2011	cnwas3	  Initial creation: CCMS 1031  par 27498
*/

vars

begin
	if _attrName = ETRow_Code or _attrName = ETRow_DeckItemCode then
		return self.code;
	elseif _attrName = ETRow_DeckCode then
		if self.myDeckLayout &lt;&gt; null and self.myDeckLayout.myDeck &lt;&gt; null then
			return self.myDeckLayout.myDeck.code;
		endif;
	elseif _attrName = ETRow_DeckItemType then
		return self.typeName();
	elseif _attrName = ETRow_Description then
		return self.description;
	elseif _attrName = ETRow_Remarks then
		return self.remarks;
	else	
		return inheritMethod(_attrName, _short);
	endif;
epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getExtremePoints" id="edb46e11-84df-49c6-8c6d-f95557521230">
        <source>getExtremePoints(_x1, _y1, _x2, _y2 : Integer io);
/*

Purpose:	Get the extreme edges of the all the points in all the polygons
					x1 is left 
					y1 is top 
					x2 is right 
					y2 is bottom		

Parameters:			

Return Value:		


Date		Who		Reason
28 April 2011	cnwer1	Initial creation CCMS 1031

*/

vars
	iter : Iterator;
	deckItemLayout : CM_DeckItemLayout;
	
begin
	
	iter:= self.allDeckItemLayouts.createIterator;
	
	while iter.next(deckItemLayout) do
		if not deckItemLayout.isVisible then
			continue;
		endif;
		deckItemLayout.getExtremePoints(_x1, _y1, _x2, _y2);
	endwhile;
epilog
	delete iter;
end;</source>
        <Parameter name="_x1" type="Integer" usage="io"/>
        <Parameter name="_y1" type="Integer" usage="io"/>
        <Parameter name="_x2" type="Integer" usage="io"/>
        <Parameter name="_y2" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="getFwdLocnByPosition" id="b3d8668c-7791-42e4-9939-cfb98d265ee7">
        <source>getFwdLocnByPosition(_aftLocn : CM_ROROLocnDefn) : CM_ROROLocnDefn;
/*
Purpose:			
Date				Who			Reason
AUGUST 2012		CNWAB1		Initial creation
*/

vars
	itemLayout : CM_DeckItemLayout;
	fwdX, fwdY : Integer;
begin
	
	if _aftLocn.isVerticalOrientation() then
		fwdX := _aftLocn.myLayout.myPolygonPixels[4].x;
		fwdY := _aftLocn.myLayout.myPolygonPixels[4].y;
		
		foreach itemLayout in self.allDeckItemLayouts discreteLock do
			if itemLayout.myDeckItem.isKindOf(CM_ROROLocnDefn) then
	
				if _aftLocn.orientation = itemLayout.myDeckItem.CM_ROROLocnDefn.orientation
				and itemLayout.myPolygonPixels[1].x = fwdX
				and (itemLayout.myPolygonPixels[1].y = fwdY or itemLayout.myPolygonPixels[1].y = (fwdY + 1))  then
					return itemLayout.myDeckItem.CM_ROROLocnDefn;
				endif;
			endif;
		endforeach;
	else
		fwdX := _aftLocn.myLayout.myPolygonPixels[2].x;
		fwdY := _aftLocn.myLayout.myPolygonPixels[2].y;
		
		foreach itemLayout in self.allDeckItemLayouts discreteLock do
			if itemLayout.myDeckItem.isKindOf(CM_ROROLocnDefn) then
	
				if _aftLocn.orientation = itemLayout.myDeckItem.CM_ROROLocnDefn.orientation
				and (itemLayout.myPolygonPixels[1].x = (fwdX - 1) or itemLayout.myPolygonPixels[1].x = fwdX)
				and itemLayout.myPolygonPixels[1].y = fwdY then
					return itemLayout.myDeckItem.CM_ROROLocnDefn;
				endif;
			endif;
		endforeach;
	endif;
	
	return null;
epilog

end;</source>
        <Parameter name="_aftLocn" type="CM_ROROLocnDefn"/>
        <ReturnType type="CM_ROROLocnDefn"/>
    </JadeMethod>
    <JadeMethod name="getFwdSideLocnByPosition" id="7956958b-cce7-4839-b11c-7a46e6424b69">
        <source>getFwdSideLocnByPosition(_startLocn : CM_DeckItemLayout) : CM_ROROLocnDefn;
// ---------------------------------------------------------------------------
// Created:     MARCH 2012 ANDREW BISHOP
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
// 28/5/2012		cnwcs5			Fix exception in unit tests - invalid type cast
// ------------------------------------------------------------------------------------

vars
	itemLayout 		: CM_DeckItemLayout;
	fwdX, fwdY, fudgeFactor1, fudgeFactor2		: Integer;			// cnwcs5 May 2012
	locnGap 		: Decimal[12, 2];	// cnwcs5 May 2012
	allStateData 	: CM_StateDataDict;
begin
	allStateData := self.myDeckLayout.myDeck.getAllStateDataObject(); // PAR 28971

	global.getExtraData(allStateData,RoRoLocationGap,locnGap);

	locnGap := (locnGap * ROROStructurePixelsPerMetre) + 1;
	fudgeFactor1 := 1; // PAR 29749
	fudgeFactor2 := 2; // PAR 29749

	
	fwdX := _startLocn.myPolygonPixels[2].x;
	fwdY := _startLocn.myPolygonPixels[2].y;
		
	foreach itemLayout in self.allDeckItemLayouts discreteLock do
		if itemLayout.myDeckItem.isKindOf(CM_ROROLocnDefn) then

		if _startLocn.myDeckItem.CM_ROROLocnDefn.orientation = itemLayout.myDeckItem.CM_ROROLocnDefn.orientation
			and itemLayout.myPolygonPixels[1].y = fwdY
			and (itemLayout.myPolygonPixels[1].x = fwdX 
				or itemLayout.myPolygonPixels[1].x = (fwdX + locnGap)
				or itemLayout.myPolygonPixels[1].x = (fwdX + (locnGap + fudgeFactor1)) //  PAR 29590 FUDGE for Mr Portunato's XML
				or itemLayout.myPolygonPixels[1].x = (fwdX + (locnGap + fudgeFactor2)) //  PAR 29590 FUDGE for Mr Portunato's XML
				
				)  then //  PAR 29590 FUDGE for Mr Portunato's XML
				return itemLayout.myDeckItem.CM_ROROLocnDefn;
			endif;
		endif;
	endforeach;
	
	return null;
epilog

end;</source>
        <Parameter name="_startLocn" type="CM_DeckItemLayout"/>
        <ReturnType type="CM_ROROLocnDefn"/>
    </JadeMethod>
    <JadeMethod name="getGraphicSamePoints" id="bdcd3abf-1781-4a2f-8a36-1ce180728b35">
        <source>getGraphicSamePoints(_tmpGraphic : CM_DeckItemLayout) : CM_DeckItemLayout;
// ---------------------------------------------------------------------------
// Created:     24 March 2011 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	actualGraphic : CM_Graphic;
	actualPoint, tmpPoint : Point;
	idx, actualX, actualY, tempX, tempY : Integer;
	
begin
	if _tmpGraphic = null then
		return null;
	endif;
	
	foreach actualGraphic in self.allDeckItemLayouts discreteLock do : outerLoop
		if actualGraphic.pointsPolygon.size = _tmpGraphic.pointsPolygon.size then
			foreach idx in 1 to actualGraphic.pointsPolygon.size do
				actualPoint := actualGraphic.pointsPolygon[idx];
				actualX := actualPoint.x();
				actualY := actualPoint.y();
				
				tmpPoint := _tmpGraphic.pointsPolygon[idx];
				tempX := tmpPoint.x();
				tempY := tmpPoint.y();
				
				if ((tempX &lt;&gt; actualX) or (tempY &lt;&gt; actualY)) then
					continue outerLoop;
				endif;
			endforeach;
			return actualGraphic.CM_DeckItemLayout;
			
		endif;
	endforeach;
	
	return null;
epilog

end;</source>
        <Parameter name="_tmpGraphic" type="CM_DeckItemLayout"/>
        <ReturnType type="CM_DeckItemLayout"/>
    </JadeMethod>
    <JadeMethod name="getLocnDefnForArea" id="aa463ec4-d4c8-4345-98d7-aaf8c49e15a1">
        <source>getLocnDefnForArea(_firstPoint, _lastPoint : Point; _locns : CM_RORODeckItemByOrd1Ord2 input; _scale : Decimal);
/*
Purpose:			
Date		Who		Reason
20 July 2011	cnwab1	Initial creation
*/

vars
	anItemLayout : CM_DeckItemLayout;
	tmpLocn :CM_DeckItem;
	aPoint : Point;
	areaPoints : PointArray;
	ord1, ord2 : Integer;
begin
	create areaPoints transient;
	// Create Area Polygon
	aPoint.set(_firstPoint.x,_lastPoint.y); // BL
	areaPoints.add(aPoint);
	aPoint.set(_firstPoint.x,_firstPoint.y); // TL
	areaPoints.add(aPoint);
	aPoint.set(_lastPoint.x,_firstPoint.y); // TR
	areaPoints.add(aPoint);
	aPoint.set(_lastPoint.x,_lastPoint.y); // BR
	areaPoints.add(aPoint);
	aPoint.set(_firstPoint.x,_lastPoint.y); // BL
	areaPoints.add(aPoint);


	// ask each locn polygon if it's top left is in our area
	foreach anItemLayout in self.allDeckItemLayouts discreteLock do
		//epr TFS 3594 30/5/17
		if not anItemLayout.myDeckItem.isKindOf(CM_ROROLocnDefn) and
			not anItemLayout.myDeckItem.isKindOf(CM_ROROGCDefn) then
			continue;
		endif;
		if not anItemLayout.isVisible then
			continue;
		endif;
		
		tmpLocn := anItemLayout.myDeckItem;

		if areaPoints.isPointInRectangleBLTR((anItemLayout.myPolygonPixels[1].x * _scale).Integer, (anItemLayout.myPolygonPixels[1].y * _scale).Integer) 
		or areaPoints.isPointInRectangleBLTR((anItemLayout.myPolygonPixels[2].x * _scale).Integer, (anItemLayout.myPolygonPixels[2].y * _scale).Integer) 
		or areaPoints.isPointInRectangleBLTR((anItemLayout.myPolygonPixels[3].x * _scale).Integer, (anItemLayout.myPolygonPixels[3].y * _scale).Integer) 
		or areaPoints.isPointInRectangleBLTR((	anItemLayout.myPolygonPixels[4].x * _scale).Integer, (anItemLayout.myPolygonPixels[4].y * _scale).Integer) then
			anItemLayout.getOrdinalsForSorting(AFSP_Value, ord1, ord2);
			_locns.putAtKey(ord1, ord2, tmpLocn);
		else
			if anItemLayout.myPolygonPixels.isPointInRectangleTLBR((areaPoints[1].x / _scale).Integer, (areaPoints[1].y / _scale).Integer) 
			or anItemLayout.myPolygonPixels.isPointInRectangleTLBR((areaPoints[2].x / _scale).Integer, (areaPoints[2].y / _scale).Integer) 
			or anItemLayout.myPolygonPixels.isPointInRectangleTLBR((areaPoints[3].x / _scale).Integer, (areaPoints[3].y / _scale).Integer) 
			or anItemLayout.myPolygonPixels.isPointInRectangleTLBR((areaPoints[4].x / _scale).Integer, (areaPoints[4].y / _scale).Integer) then
				anItemLayout.getOrdinalsForSorting(AFSP_Value, ord1, ord2);
				_locns.putAtKey(ord1, ord2, tmpLocn);
			else
				if anItemLayout.myPolygonPixels[1].x * _scale &gt; areaPoints[2].x and anItemLayout.myPolygonPixels[2].x * _scale &lt; areaPoints[3].x
				and anItemLayout.myPolygonPixels[2].y * _scale &lt; areaPoints[2].y and anItemLayout.myPolygonPixels[3].y * _scale &gt; areaPoints[4].y then
					_locns.putAtKey(ord1, ord2, tmpLocn);
				else
					if anItemLayout.myPolygonPixels[1].x * _scale &lt; areaPoints[2].x and anItemLayout.myPolygonPixels[3].x * _scale &gt; areaPoints[3].x
					and anItemLayout.myPolygonPixels[1].y * _scale &gt; areaPoints[2].y and anItemLayout.myPolygonPixels[3].y * _scale &lt; areaPoints[4].y then
						_locns.putAtKey(ord1, ord2, tmpLocn);
					endif;
				endif;
			endif;
		endif;
	
	endforeach;
epilog
	delete areaPoints;
end;</source>
        <Parameter name="_firstPoint" type="Point"/>
        <Parameter name="_lastPoint" type="Point"/>
        <Parameter name="_locns" type="CM_RORODeckItemByOrd1Ord2" usage="input"/>
        <Parameter name="_scale" type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="getLocnDefnsToRotate" id="e288a85c-9da8-4da4-a68e-a4f1e0ad6754">
        <source>getLocnDefnsToRotate(_startLocn : CM_ROROLocnDefn; _items, _split : Integer; _locns : CM_RORODeckItemByOrd1Ord2 input; _clear : Boolean) : PointArray;
/*
Purpose:			
Date		Who		Reason
12 July 2011	cnwab1	Initial creation

_items - how many items to rotate e.g. 3 or 10
_split - how many groups to splits into e.g. 1 for 1x3 or 2 for 2x5
*/

vars
	 areaW, areaH : Integer;
	startItemLayout, anItemLayout : CM_DeckItemLayout;
	thePoints, areaPoints : PointArray;
	startPoint, aPoint : Point;
	tmpLocn : CM_ROROLocnDefn;
	ord1, ord2, x1, x2, y1, y2, chkX, chkY : Integer;
	itemW, itemH, locnGap : Decimal[12,2];
	allStateData : CM_StateDataDict;
//	aVes : CM_Vessel;
	isOOTL : Boolean;
begin
	if _locns = null then
		return null;
	endif;
	
	if _startLocn = null then // PAR 28886
		return null;
	endif;
	
	isOOTL := _startLocn.isOOTL(); // PAR 28886
	
	// PAR 28886
	if isOOTL then
		_locns.putAtKey(1, 1, _startLocn);
		
		// PAR 29990 - we were just returning the persistent polygon, but this created a crash for OOTL in teh validation and a  change to the polygon in teh rotation method.
		create areaPoints transient;
		_startLocn.myLayout.myPolygonPixels.copy(areaPoints);
		return areaPoints;
		// PAR 29990 return _startLocn.myLayout.myPolygonPixels;
	endif;
	
	if self.type &lt;&gt; ROROLayerType_Cargo and self.type &lt;&gt; ROROLayerType_OOTL 
	and not ( self.type = ROROLayerType_CCLoad and isOOTL) then // PAR 28886
		return null;
	endif;
	
	if _clear then
		_locns.clear();
	endif;
	
	 if self.allROROLocnDefnByOrdinal.size &lt; _items then
		return null;
	 endif;
	 
	 if _startLocn = null then
		return null;
	endif;
	
	startItemLayout := _startLocn.myLayout;
	if startItemLayout = null then
		return null;
	endif;
	
	thePoints := startItemLayout.myPolygonPixels;
	if thePoints.size &lt; 5 then
		return null;
	endif;

//	areaPoints := self.getRotationNetByConfig(_startLocn, _items, _split );
	areaPoints := self.getRotationNetByPixels(_startLocn, _items, _split );
	
	
/*	
	create areaPoints transient;
	
	// PAR 28886
	if isOOTL then
		_locns.putAtKey(1, 1, _startLocn);
		
		_startLocn.myLayout.myPolygonPixels.copy(areaPoints);
		return areaPoints;
	endif;
	allStateData := self.myDeckLayout.myDeck.getAllStateDataObject(); // PAR 28971

	global.getExtraData(allStateData,RoRoLocationGap,locnGap);

	locnGap := locnGap * ROROStructurePixelsPerMetre;

	if locnGap = 0 then
// PAR 28317		locnGap := 1;
	endif;
	
	if _startLocn.isRotated() then // Vertical
		global.getExtraData(allStateData,RoRoLocationWidth,itemW);
		global.getExtraData(allStateData,RoRoLocationLength,itemH);
	else
		global.getExtraData(allStateData,RoRoLocationWidth,itemH);
		global.getExtraData(allStateData,RoRoLocationLength,itemW);
	endif;	
	itemH := itemH * ROROStructurePixelsPerMetre;
	itemW := itemW * ROROStructurePixelsPerMetre;
	
	startPoint := thePoints[4];

	if _startLocn.isRotated() then // Vertical
		if _split &gt; 1 then
			areaW := (itemW* (_items / _split).Integer).Integer + (locnGap *((_items / _split).Integer - 1)).Integer;
			//areaH := (itemH + locnGap).Integer * _split;
			areaH := (itemH * _split).Integer +  (locnGap * (_split - 1)).Integer;
		else
			areaW := (itemW * _items).Integer + (locnGap * (_items - 1)).Integer;
			areaH := (itemH + locnGap).Integer ;
		endif;
	else // Horizontal
		if _split &gt; 1 then
			areaW := (itemW * _split).Integer +  (locnGap * (_split - 1)).Integer;
			//areaH := (itemH + locnGap).Integer * (_items / _split).Integer;
			areaH:= (itemH * (_items / _split).Integer).Integer + (locnGap *((_items / _split).Integer - 1)).Integer;
		else
			areaW := itemW.Integer ;
			areaH := (itemH * _items).Integer + (locnGap * (_items - 1)).Integer;
		endif;
	endif;
	
	areaW := areaW - 1; // PAR 28317
	
	if not isOOTL then // PAR 28886
		areaH := areaH - 1; // PAR 28317
	endif;
	
	// Create Area Polygon
	aPoint.set((startPoint.x).Integer, (startPoint.y ).Integer); // Bottom left
	areaPoints.add(aPoint);
	aPoint.set((startPoint.x).Integer,(startPoint.y-areaH).Integer); // top left
	areaPoints.add(aPoint);
	aPoint.set(startPoint.x+areaW,(startPoint.y-areaH).Integer); // top right
	areaPoints.add(aPoint);
	aPoint.set(startPoint.x+areaW,startPoint.y); // bottom right
	areaPoints.add(aPoint);
	aPoint.set((startPoint.x).Integer, (startPoint.y).Integer); // Bottom left
	areaPoints.add(aPoint); 

*/



	// ask each locn polygon if it's top left is in our area
	foreach anItemLayout in self.allDeckItemLayouts discreteLock do
		if not anItemLayout.myDeckItem.isKindOf(CM_ROROLocnDefn) then
			continue;
		endif;
		tmpLocn := anItemLayout.myDeckItem.CM_ROROLocnDefn;

		// Is the polygon rectangle fully inside the outer polygon
		if areaPoints.isPointInRectangleBLTR(anItemLayout.myPolygonPixels[1].x, anItemLayout.myPolygonPixels[1].y) then
		
			if _startLocn.isVerticalOrientation() then // Vertical
				anItemLayout.getOrdinalsForSorting(SPAF_Value, ord1, ord2); //
			else
				anItemLayout.getOrdinalsForSorting(AFSP_Value, ord1, ord2);
			endif;
	
			_locns.putAtKey(ord1, ord2, tmpLocn);
				
		endif;
	
	endforeach;

	return areaPoints;
epilog

end;</source>
        <Parameter name="_startLocn" type="CM_ROROLocnDefn"/>
        <Parameter name="_items" type="Integer"/>
        <Parameter name="_split" type="Integer"/>
        <Parameter name="_locns" type="CM_RORODeckItemByOrd1Ord2" usage="input"/>
        <Parameter name="_clear" type="Boolean"/>
        <ReturnType type="PointArray"/>
    </JadeMethod>
    <JadeMethod name="getNumTiers" id="8140dc34-d3da-43e3-83a0-90ffd6dca888">
        <source>getNumTiers() : Integer;
/*
Purpose:			
Date		Who		Reason
10 June 2011	cnwab1	Initial creation
*/

vars

begin
	if self.myDeckLayout = null then
		return 0;
	endif;
	
	if self.myDeckLayout.myDeck = null then
		return 0;
	endif;
	
	return self.myDeckLayout.myDeck.numTier;
epilog

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getPortSideLocnByPosition" id="a650a4df-7e1b-4343-9db5-7d3e55e24f60">
        <source>getPortSideLocnByPosition(_startLocn : CM_DeckItemLayout) : CM_ROROLocnDefn;
// ---------------------------------------------------------------------------
// Created:     MARCH 2012 ANDREW BISHOP
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	itemLayout : CM_DeckItemLayout;
	fwdX, fwdY, fudgeFactor1, fudgeFactor2 : Integer;
	locnGap : Decimal[12,2]; // PAR 29749
	allStateData : CM_StateDataDict;
begin
	allStateData := self.myDeckLayout.myDeck.getAllStateDataObject(); // PAR 28971

	global.getExtraData(allStateData,RoRoLocationGap,locnGap);

	locnGap := (locnGap * ROROStructurePixelsPerMetre) + 1;
	fudgeFactor1 := 1; // PAR 29749
	fudgeFactor2 := 2; // PAR 29749
	
	fwdX := _startLocn.myPolygonPixels[1].x;
	fwdY := _startLocn.myPolygonPixels[1].y;
		
	foreach itemLayout in self.allDeckItemLayouts discreteLock do
	if itemLayout.myDeckItem.isKindOf(CM_ROROLocnDefn) then
		if _startLocn.myDeckItem.CM_ROROLocnDefn.orientation = itemLayout.myDeckItem.CM_ROROLocnDefn.orientation
			and itemLayout.myPolygonPixels[1].x = fwdX
			and (itemLayout.myPolygonPixels[4].y = fwdY 
				or itemLayout.myPolygonPixels[4].y = (fwdY - locnGap)
				or itemLayout.myPolygonPixels[4].y = (fwdY - (locnGap + fudgeFactor1)) //  PAR 29590 FUDGE for Mr Portunato's XML
				or itemLayout.myPolygonPixels[4].y = (fwdY - (locnGap + fudgeFactor2)) //  PAR 29590 FUDGE for Mr Portunato's XML
			
			)  then 
				return itemLayout.myDeckItem.CM_ROROLocnDefn;
			endif;
		endif;
	endforeach;
	
	return null;
epilog

end;</source>
        <Parameter name="_startLocn" type="CM_DeckItemLayout"/>
        <ReturnType type="CM_ROROLocnDefn"/>
    </JadeMethod>
    <JadeMethod name="getRotationNetByConfig" id="b65f8864-a71b-4501-a15b-973541ddf739">
        <source>getRotationNetByConfig(_startLocn : CM_ROROLocnDefn; _items, _split : Integer) : PointArray;
/*
Purpose:			work out the 'net' that covers all teh polygons for our group
Date		Who		Reason
12 July 2011	cnwab1	Initial creation

_items - how many items to rotate e.g. 3 or 10
_split - how many groups to splits into e.g. 1 for 1x3 or 2 for 2x5
*/

vars
	 areaW, areaH : Integer;
	startItemLayout, anItemLayout : CM_DeckItemLayout;
	thePoints, areaPoints : PointArray;
	startPoint, aPoint : Point;
	tmpLocn : CM_ROROLocnDefn;
	ord1, ord2, x1, x2, y1, y2, chkX, chkY : Integer;
	itemW, itemH, locnGap : Decimal[12,2];
	allStateData : CM_StateDataDict;
	isOOTL : Boolean;
begin
	
	if _startLocn = null then // PAR 28886
		return null;
	endif;
	startItemLayout := _startLocn.myLayout;
	if startItemLayout = null then
		return null;
	endif;
	
	thePoints := startItemLayout.myPolygonPixels;
	if thePoints.size &lt; 5 then
		return null;
	endif;

	create areaPoints transient;

	allStateData := self.myDeckLayout.myDeck.getAllStateDataObject(); // PAR 28971

	global.getExtraData(allStateData,RoRoLocationGap,locnGap);

	locnGap := locnGap * ROROStructurePixelsPerMetre;

	if _startLocn.isVerticalOrientation() then // Vertical
		global.getExtraData(allStateData,RoRoLocationWidth,itemW);
		global.getExtraData(allStateData,RoRoLocationLength,itemH);
	else
		global.getExtraData(allStateData,RoRoLocationWidth,itemH);
		global.getExtraData(allStateData,RoRoLocationLength,itemW);
	endif;	
	itemH := itemH * ROROStructurePixelsPerMetre;
	itemW := itemW * ROROStructurePixelsPerMetre;
	
	startPoint := thePoints[4];

	if _startLocn.isVerticalOrientation() then // Vertical
		if _split &gt; 1 then
			areaW := (itemW* (_items / _split).Integer).Integer + (locnGap *((_items / _split).Integer - 1)).Integer;
			areaH := (itemH * _split).Integer +  (locnGap * (_split - 1)).Integer;
		else
			areaW := (itemW * _items).Integer + (locnGap * (_items - 1)).Integer;
			areaH := (itemH + locnGap).Integer ;
		endif;
	else // Horizontal
		if _split &gt; 1 then
			areaW := (itemW * _split).Integer +  (locnGap * (_split - 1)).Integer;
			areaH:= (itemH * (_items / _split).Integer).Integer + (locnGap *((_items / _split).Integer - 1)).Integer;
		else
			areaW := itemW.Integer ;
			areaH := (itemH * _items).Integer + (locnGap * (_items - 1)).Integer;
		endif;
	endif;
	
	areaW := areaW - 1; // PAR 28317
	
	if not isOOTL then // PAR 28886
		areaH := areaH - 1; // PAR 28317
	endif;
	
	// Create Area Polygon
	aPoint.set((startPoint.x - 1).Integer, (startPoint.y - 1 ).Integer); // Bottom left
	areaPoints.add(aPoint);
	aPoint.set((startPoint.x).Integer,(startPoint.y-areaH).Integer); // top left
	areaPoints.add(aPoint);
	aPoint.set(startPoint.x+areaW,(startPoint.y-areaH).Integer); // top right
	areaPoints.add(aPoint);
	aPoint.set(startPoint.x+areaW,startPoint.y); // bottom right
	areaPoints.add(aPoint);
	aPoint.set((startPoint.x - 1).Integer, (startPoint.y - 1).Integer); // Bottom left
	areaPoints.add(aPoint); 



	return areaPoints;
epilog

end;</source>
        <Parameter name="_startLocn" type="CM_ROROLocnDefn"/>
        <Parameter name="_items" type="Integer"/>
        <Parameter name="_split" type="Integer"/>
        <ReturnType type="PointArray"/>
    </JadeMethod>
    <JadeMethod name="getRotationNetByPixels" id="652dcf11-c6fd-4e74-bf26-abf2d73f41a0">
        <source>getRotationNetByPixels(_startLocn : CM_ROROLocnDefn; _items, _split : Integer) : PointArray;
/*
Purpose:			work out the 'net' that covers all teh polygons for our group
Date		Who		Reason
12 July 2011	cnwab1	Initial creation

_items - how many items to rotate e.g. 3 or 10
_split - how many groups to splits into e.g. 1 for 1x3 or 2 for 2x5
*/

vars
	 areaW, areaH : Integer;
	startItemLayout, anItemLayout : CM_DeckItemLayout;
	thePoints, areaPoints : PointArray;
	startPoint, endPoint, aPoint : Point;
	endLocn : CM_ROROLocnDefn;
	ord1, ord2, x1, x2, y1, y2, chkX, chkY : Integer;
	itemW, itemH, locnGap : Decimal[12,2];
	allStateData : CM_StateDataDict;
	isOOTL : Boolean;
begin
	if _startLocn = null then // PAR 28886
		return null;
	endif;
	
	if _startLocn.myLayout.myPolygonPixels.size &lt; 5 then
		return null;
	endif;
	
	create areaPoints transient;

	endLocn := _startLocn.getTopRightLocnForRotationGrp(_items, _split);
	
	startPoint := _startLocn.myLayout.myPolygonPixels[4];
	endPoint := endLocn.myLayout.myPolygonPixels[2];
	
	// Create Area Polygon
	aPoint.set((startPoint.x).Integer, (startPoint.y ).Integer); // Bottom left
	areaPoints.add(aPoint);
	aPoint.set((startPoint.x).Integer,(endPoint.y).Integer); // top left
	areaPoints.add(aPoint);
	aPoint.set(endPoint.x,(endPoint.y).Integer); // top right
	areaPoints.add(aPoint);
	aPoint.set(endPoint.x,startPoint.y); // bottom right
	areaPoints.add(aPoint);
	aPoint.set((startPoint.x).Integer, (startPoint.y).Integer); // Bottom left
	areaPoints.add(aPoint); 
	
	return areaPoints;
epilog

end;</source>
        <Parameter name="_startLocn" type="CM_ROROLocnDefn"/>
        <Parameter name="_items" type="Integer"/>
        <Parameter name="_split" type="Integer"/>
        <ReturnType type="PointArray"/>
    </JadeMethod>
    <JadeMethod name="getSideLocnByPosition" id="90447f59-e044-44cf-87e9-483dc8134487">
        <source>getSideLocnByPosition(_startLocn : CM_ROROLocnDefn; _toRight : Boolean) : CM_ROROLocnDefn;
/*
Purpose:		CCMS 1009 28479	
Date		Who		Reason
01 November 2011	cnwab1	Initial creation
*/

vars
	itemLayout : CM_DeckItemLayout;
	checkLocn : CM_ROROLocnDefnVoyage;
	fwdX, fwdY : Integer;
begin
	
	// PAR 28525
	if _startLocn.isVerticalOrientation() then
		fwdX := _startLocn.myLayout.myPolygonPixels[2].x;
		fwdY := _startLocn.myLayout.myPolygonPixels[2].y;
	
		foreach itemLayout in self.allDeckItemLayouts  discreteLock where itemLayout.myDeckItem.isKindOf(CM_ROROLocnDefnVoyage) do

		checkLocn := itemLayout.myDeckItem.CM_ROROLocnDefnVoyage;
			if checkLocn = _startLocn then
				continue; //IGNORE
			endif;
			
			if _startLocn.orientation = checkLocn.orientation
			and (( itemLayout.myPolygonPixels[1].x = fwdX) or (itemLayout.myPolygonPixels[1].x = (fwdX + 1)))
			and (itemLayout.myPolygonPixels[1].y = fwdY )  then
				return checkLocn;
			endif;

		endforeach;
	else
		fwdX := _startLocn.myLayout.myPolygonPixels[1].x;
		fwdY := _startLocn.myLayout.myPolygonPixels[1].y;
		
		foreach itemLayout in self.allDeckItemLayouts discreteLock where itemLayout.myDeckItem.isKindOf(CM_ROROLocnDefnVoyage) do
			checkLocn := itemLayout.myDeckItem.CM_ROROLocnDefnVoyage;
			if checkLocn = _startLocn then
				continue; //IGNORE
			endif;
			
				if _startLocn.orientation = checkLocn.orientation
				and (itemLayout.myPolygonPixels[4].y = (fwdY - 1) or itemLayout.myPolygonPixels[4].y = fwdY)
				and itemLayout.myPolygonPixels[4].x = fwdX then
					return checkLocn;
				endif;

		endforeach;
	endif;
	
	return null;
epilog

end;</source>
        <Parameter name="_startLocn" type="CM_ROROLocnDefn"/>
        <Parameter name="_toRight" type="Boolean"/>
        <ReturnType type="CM_ROROLocnDefn"/>
    </JadeMethod>
    <JadeMethod name="getVessel" id="9f77e45a-c400-46ed-a159-34004ac092a8">
        <source>getVessel() : CM_Vessel;
/*
Purpose:		// PAR 27493
		
Date		Who		Reason
16 May 2011	cnwab1	Initial creation
*/

vars
	deck : CM_Deck;
begin
	if self.myDeckLayout = null then
		return null;
	endif;
	
	deck:= self.myDeckLayout.myDeck;
	
	if deck = null then
		return null;
	endif;
	
	return deck.getVessel;

epilog

end;</source>
        <ReturnType type="CM_Vessel"/>
    </JadeMethod>
    <JadeMethod name="hideContainerPosUnderGCLoad" id="78ca6cb0-966b-4b19-be66-c5cf853ec7af">
        <source>hideContainerPosUnderGCLoad(_layout : CM_DeckItemLayout input);
/*

Date		Who		Reason
18 September 2013	cnwer1	Initial creation PAR 32488 when unrotating in load mode have to check if covered by gc jobs


*/

vars
itemLayout : CM_DeckItemLayout;
	deckItem : CM_DeckItem;
	gcPoints, contPoints : PointArray;
	xGC1, yGC1, xGC2, yGC2 : Integer;
	diLayout : CM_DeckItemLayout;
begin

	if _layout = null then // PAR 29178
		return;
	endif;


	if self.type &lt;&gt; ROROLayerType_CCLoad then
		return;
	endif;

	gcPoints := _layout.myPolygonPixels;
	diLayout := _layout.getDeckItemLayout();
	
	_layout.getExtremePoints(xGC1, yGC1, xGC2, yGC2);
	
	foreach itemLayout in self.allDeckItemLayouts discreteLock do
	
		if itemLayout.type &lt;&gt; DeckItemLayoutType_CCLoad and  itemLayout.type &lt;&gt;DeckItemLayoutType_GCLoad then
			continue;
		endif;
		// PAR 29979 Do not include the locn defn for a roro request layout
		if diLayout &lt;&gt; null and diLayout = itemLayout then
			continue;
		endif;	
			
		
		contPoints := itemLayout.myPolygonPixels;

		// PAR 28886 - Performance - IGNORE the container rectangles that are outside of the GC poly limits. The GC limits are a rectangle that the polygon fits in.
		if contPoints[1].x &gt; xGC2  // CONT x1 &gt; GC x2
		or contPoints[2].x &lt; xGC1  // CONT x2 &lt; GC x1
		or contPoints[1].y &gt; yGC2  // CONT y1 &gt; GC y2
		or contPoints[2].y &lt; yGC1  // CONT y2 &lt; GC y1
		then
			continue;
		endif;
			
		//epr better detection of polygon intersection 3/2/12 par 29079
		if contPoints.intersectsPolygon(gcPoints,false) then
			_layout.hideContainerPositionsUnderGC(itemLayout); 
		endif;
		
	endforeach;
epilog

end;</source>
        <Parameter name="_layout" type="CM_DeckItemLayout" usage="input"/>
    </JadeMethod>
    <JadeMethod name="hideContainerPositionUnderGC" id="79ac6642-73ae-449c-923e-57c117670b29">
        <updating/>
        <source>hideContainerPositionUnderGC(_itemLayout : CM_DeckItemLayout input; _gcLayout : CM_DeckItemLayout) updating;
/*
Purpose:	only looking at container layers. OOTL are on seperate layer as are structures etc.		
Date		Who		Reason
21 July 2011	cnwab1	Initial creation
*/

vars
	code : String;
	deckItem : CM_DeckItem;
	gcPoints, contPoints : PointArray;
	xGC1, yGC1, xGC2, yGC2 : Integer;
begin

	if _gcLayout = null then // PAR 29178
		return;
	endif;

	// PAR 28886
	if self.type &lt;&gt; ROROLayerType_Cargo and self.type &lt;&gt; ROROLayerType_CCLoad then
		return;
	endif;

	gcPoints := _gcLayout.myPolygonPixels;
	
	_gcLayout.getExtremePoints(xGC1, yGC1, xGC2, yGC2);
	
		if not _itemLayout.isLocnDefnLayout() then // PAR 28886		
			return;
		endif;
			
		contPoints := _itemLayout.myPolygonPixels;

		// PAR 28886 - Performance - IGNORE the container rectangles that are outside of the GC poly limits. The GC limits are a rectangle that the polygon fits in.
		if contPoints[1].x &gt; xGC2  // CONT x1 &gt; GC x2
		or contPoints[2].x &lt; xGC1  // CONT x2 &lt; GC x1
		or contPoints[1].y &gt; yGC2  // CONT y1 &gt; GC y2
		or contPoints[2].y &lt; yGC1  // CONT y2 &lt; GC y1
		then
			return;
		endif;
			
		deckItem := _itemLayout.myDeckItem;
		if deckItem = null then
			return;
		endif;
		if  deckItem.hasTIs(REAL_MODE)
		and deckItem.hasColourCoding(DISCHARGE_MOVETYPE) = null then // PAR 29607
			_itemLayout.showContainerPositionUnderGC(_gcLayout); // SHOW
			if self.type = ROROLayerType_Cargo then
				return; // always show cargo
			endif;
		endif;

		//epr better detection of polygon intersection 3/2/12 par 29079
		if gcPoints.intersectsPolygon(contPoints, false) then
			_itemLayout.hideContainerPositionsUnderGC(_gcLayout); 
		endif;
		
	
epilog

end;</source>
        <Parameter name="_itemLayout" type="CM_DeckItemLayout" usage="input"/>
        <Parameter name="_gcLayout" type="CM_DeckItemLayout"/>
    </JadeMethod>
    <JadeMethod name="hideContainerPositionsUnderGA" id="441d1015-77fd-4d52-a92f-766fab4bf8eb">
