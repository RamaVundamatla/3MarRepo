    <JadeMethod name="formatName" id="6a7fc167-c030-4b0e-be8b-1b5da220c6a9">
        <source>formatName(_includeNull : Boolean);
// adm 080609 Par 19637 defaultYACodeChanged
vars
	criteriaCtrl	: CMUI_YACriteriaCntl;
	criteriaValue	: Any;
	i				: Integer;
	imexStatus		: CM_IMEXStatus;
	groupName		: String;
	yaTemplate		: CM_YATemplate;

	// cnwjk3 SFW1030
	yaConfig: CM_YAConfig;
	yaIMEXConfig: CM_YAIMEXConfig;
	yaCriteriaType : CM_YACriteriaType;

begin
	imexStatus := self.cmbIMEX.listObject.CM_IMEXStatus;
	
	if imexStatus = null or imexStatus.code = TI_IMEX_STATUS_NULL then
		groupName := "N";
	else
		groupName := imexStatus.abbreviation[1];
	endif;

	// cnwjk3 SFW1030
	yaConfig := self.myTerminal.myYAConfig;
	if imexStatus &lt;&gt; null and yaConfig &lt;&gt; null then
			yaIMEXConfig := yaConfig.allYAIMEXConfigs[imexStatus.code];
	endif;

		// cnwjk3 SFW1030
	if yaIMEXConfig &lt;&gt; null and yaIMEXConfig.allGroupLabelCriteria &lt;&gt; null and yaIMEXConfig.allGroupLabelCriteria.size() &gt; 0 then
		
		// We have a group order specified, so form the names using only those group criteriam and in the configured order.
		foreach yaCriteriaType in yaIMEXConfig.allGroupLabelCriteria do
			// Locate the control associated with this criteria type
			criteriaCtrl := self.locateControlForCriteriaType(yaCriteriaType);
			if criteriaCtrl &lt;&gt; null then 
				if criteriaCtrl.visible then
					criteriaValue := criteriaCtrl.getDisplayForGroupName;
					if criteriaValue &lt;&gt; null then
						groupName := groupName &amp; " " &amp; criteriaValue.String;
					elseif _includeNull then	// CCMS 1043 Snapshot Summary Invoicing 	Oct 2010 	cnwjre1	default values are null
						groupName := groupName &amp; " (Default)";
					endif;
				endif;
			endif;
		endforeach;
	
	else	

		while true do
			i := i + 1;
			criteriaCtrl := self.frmCriteria.getControl(i);
			if criteriaCtrl = null then
				break;
			endif;
			if criteriaCtrl.visible then
				criteriaValue := criteriaCtrl.getDisplayForGroupName;
				if criteriaValue &lt;&gt; null then
					groupName := groupName &amp; " " &amp; criteriaValue.String;
				endif;
			endif;
		endwhile;
	endif;
	
	txtGroupName.text := groupName;
	
	yaTemplate := cmbYATemplate.listObject.CM_YATemplate;

	if not defaultYACodeChanged then
		if yaTemplate = null then
			txtYACode.text := groupName;
		else
			txtYACode.text := groupName &amp; " - " &amp; yaTemplate.code;
		endif;
	endif;
epilog

end;</source>
        <Parameter name="_includeNull" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getAllTemplateCriteriaFromTI" id="5b794eaf-e0e9-4486-a819-dea191a9791c">
        <source>getAllTemplateCriteriaFromTI(_allOperationCriteria : CM_YACriteriaArray input; _cmifArray : CMIF_Array input);
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
19 March 2009	cnwer1	Initial creation  par 19078

*/

vars
	iter : Iterator;
	cmifObj : CMIF_Object;
	cmifYACriteria : CMIF_YACriteriaPriority;
	criteria,proxyCriteria: CM_YACriteria;
begin

	iter:= _cmifArray.createIterator;
	
	while iter.next(cmifObj) do
		cmifYACriteria:=cmifObj.CMIF_YACriteriaPriority;
		criteria:=cmifYACriteria.myProxy.CM_YACriteria;
		if criteria.myYACriteriaType.type = YACriteriaType_ImexStatus then
			continue;
		endif;
		if _allOperationCriteria.includes(criteria) then
			continue;
		endif;
		
		create proxyCriteria transient;
		proxyCriteria.setProxy(criteria.myYACriteriaType, criteria.myYAData.getDataValue(), criteria.code);
		self.allTemplateCriteria.add( proxyCriteria.getTransient() );
	
	endwhile; 
epilog
	delete iter;
end;</source>
        <Parameter name="_allOperationCriteria" type="CM_YACriteriaArray" usage="input"/>
        <Parameter name="_cmifArray" type="CMIF_Array" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getControlValueForCriteriaType" id="df12b1e7-a4bc-4c15-b9f1-53aa35ce8884">
        <source>getControlValueForCriteriaType(_yaCriteriaType : CM_YACriteriaType) : String;
/*
Purpose:			
Date		Who		Reason
27 May 2014	cnwab1	Initial creation
*/

vars

	criteriaCtrl	: CMUI_YACriteriaCntl;
	criteriaValue : String;
begin
	
	criteriaCtrl := self.locateControlForCriteriaType(_yaCriteriaType);
	if criteriaCtrl &lt;&gt; null then 
		if criteriaCtrl.visible then
			criteriaValue := criteriaCtrl.getDisplayForGroupName;
		endif;
	endif;

	return criteriaValue;
epilog

end;</source>
        <Parameter name="_yaCriteriaType" type="CM_YACriteriaType"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getCriteriaAllCMIF" id="1b2299e7-ab67-47ea-abf5-fc8767e3fd8b">
        <source>getCriteriaAllCMIF( _cmifArray	: CMIF_Array input );

/*

Purpose:		Create transient objects for maintaining criteria

Parameters:			

Return Value:	Transients returned in collection _cmifArray


Date			Who		Reason
06 August 2008	consw1	Initial creation
20 May 2010		cnwdap1	CCMS 1116 Tranship changes
*/

vars
	cmifCriteria 	: CMIF_YACriteriaPriority;
	cmifObject 		: CMIF_Object;
	criteria 		: CM_YACriteria;
	criteriaCtrl	: CMUI_YACriteriaCntl;
	i				: Integer;
	imexStatus		: CM_IMEXStatus;
	objSet			: CM_ObjectSet;
	template		: CM_YardAllocation;
	strArray		: CnStringArray;
	str 			: String;
	value			: String;
begin
	//  Create transient maintenance objects for all existing criteria and mark for delete action

	if self.myYardAllocation &lt;&gt; null then
		foreach criteria in self.myYardAllocation.allCriteria do
			cmifCriteria := criteria.getTransient();
			cmifCriteria.setFlag(false, false, true);	
			_cmifArray.add(cmifCriteria);
		endforeach;
	endif;

	//  For IMEX status criteria - update/add transient maintenance object

	imexStatus := self.cmbIMEX.listObject.CM_IMEXStatus;
	if self.cmbIMEX.visible and imexStatus.code &lt;&gt; TI_IMEX_STATUS_NULL then
		create objSet transient;
		objSet.add( imexStatus );
		self.getCriteriaSingleCMIF( _cmifArray, app.myRoot.allYACriteriaTypes[YACriteriaType_ImexStatus], objSet );
	elseif not self.cmbIMEX.visible or imexStatus.code = TI_IMEX_STATUS_NULL then						//+cnwml2 PAR22042
		if self.txtImex.text &lt;&gt; null then
			create strArray transient;
			create objSet transient;
			strArray := self.txtImex.text.cnGetTokens(", ");
			foreach str in strArray do	
				imexStatus := null; //17/02/2011 cnwdz2 par27014
				if str = "EXP" then
					imexStatus := app.myRoot.allImexStatuses[TI_IMEX_STATUS_EXPORT];
				elseif str = "IMP" then
					imexStatus := app.myRoot.allImexStatuses[TI_IMEX_STATUS_IMPORT];
				elseif str = "STO" then
					imexStatus := app.myRoot.allImexStatuses[TI_IMEX_STATUS_STORAGE];
				//elseif str = "TRA" then												// PAR #23645 CCMS 1116
				elseif str = "ROB" then													// PAR #23645 CCMS 1116
					imexStatus := app.myRoot.allImexStatuses[TI_IMEX_STATUS_REMAINONBOARD];
				elseif str = "TSH" then													// PAR #23645 CCMS 1116
					imexStatus := app.myRoot.allImexStatuses[TI_IMEX_STATUS_TRANSHIP];	// PAR #23645 CCMS 1116
				elseif str = "NONE" then
					imexStatus := app.myRoot.allImexStatuses[TI_IMEX_STATUS_NULL]; //17/02/2011 cnwdz2 par27014
				endif;
				//17/02/2011 cnwdz2 par27014
				if imexStatus &lt;&gt; null then
					//objSet.add( imexStatus );
					objSet.addNoDuplicates( imexStatus,false );
				endif;
			endforeach;
			self.getCriteriaSingleCMIF( _cmifArray, app.myRoot.allYACriteriaTypes[YACriteriaType_ImexStatus], objSet );

		endif;
	endif;

	//  For each criteria control - update/add transient maintenance object

	while true do
		i := i + 1;
		criteriaCtrl := self.frmCriteria.getControl(i);
		if criteriaCtrl = null then
			break;
		endif;
		if criteriaCtrl.visible and criteriaCtrl.hasValue() then			
			value := criteriaCtrl.getValue().String;		
			self.getCriteriaSingleCMIF( _cmifArray, criteriaCtrl.getCriteriaType(), value );
		endif;
	endwhile;

	//  Handle template criteria
	if self.allTemplateCriteria.isEmpty then
		//  For each criteria in selected template - update/add transient maintenance object
		if self.cmbYATemplate.listIndex &gt; 0 then
			template := self.cmbYATemplate.listObject.CM_YATemplate.myYardAllocation;
			foreach criteria in template.allCriteria
			where not criteria.myYACriteriaType.isKindOf(CM_YATypeImexStatus) do
				self.getCriteriaSingleCMIF( _cmifArray, criteria.myYACriteriaType, criteria.myYAData.getDataValue() );
			endforeach;
		endif;
	else
		//  For each criteria in selected list - update/add transient maintenance object
		foreach cmifObject in self.allTemplateCriteria do
			criteria := cmifObject.CMIF_YACriteriaPriority.myProxy.CM_YACriteria;
			self.getCriteriaSingleCMIF( _cmifArray, criteria.myYACriteriaType, criteria.myYAData.getDataValue() );
		endforeach;
	endif;
epilog
	delete objSet;
	delete strArray;
end;</source>
        <Parameter name="_cmifArray" type="CMIF_Array" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getCriteriaOfTypeFromTI" id="5be8e6fd-ba29-4e73-a354-d942299db195">
        <source>getCriteriaOfTypeFromTI(_cmifArray : CMIF_Array input; _criteriaType :Integer) : CM_YACriteria;
/*

Purpose:			

Parameters:		_cmifArray should be all the CMIF_YACriteria that we have already found for self.myTrackedItem 

				need to return the CM_YACriteria that has the _criteriaType

Return Value:		


Date		Who		Reason
19 March 2009	cnwer1	Initial creation PAR 19078

*/

vars
	iter : Iterator;
	cmifObj : CMIF_Object;
	cmifYACriteria : CMIF_YACriteriaPriority;
	criteria : CM_YACriteria;
begin

	iter:=_cmifArray.createIterator;
	while iter.next(cmifObj) do
		cmifYACriteria:=cmifObj.CMIF_YACriteriaPriority;
		criteria:=cmifYACriteria.myProxy.CM_YACriteria;
		if criteria = null then
			continue;
		endif;
		
		if criteria.myYACriteriaType = null then
			continue;
		endif;
		
		if criteria.myYACriteriaType.type = _criteriaType then
			return criteria;
		endif;
		
	endwhile;
	
	return null;
	
epilog
	delete iter;
end;</source>
        <Parameter name="_cmifArray" type="CMIF_Array" usage="input"/>
        <Parameter name="_criteriaType" type="Integer"/>
        <ReturnType type="CM_YACriteria"/>
    </JadeMethod>
    <JadeMethod name="getCriteriaSingleCMIF" id="a184d688-ad61-4bb8-aff3-9056f8d7e885">
        <source>getCriteriaSingleCMIF( _cmifArray : CMIF_Array input; _criteriaType :CM_YACriteriaType; _value : Any );

/*

Purpose:		Update/add transient maintenance object for given criteria type

Parameters:			

Return Value:		


Date			Who		Reason
06 August 2008	consw1	Initial creation

*/

vars
	cmifCriteria : CMIF_YACriteriaPriority;
	cmifObject : CMIF_Object;
	itemCode : String;
	proxyCriteria: CM_YACriteria;

begin
	//  Check if maintenance object already exists.
	//  If so, it will have a delete action.  Convert it to a change request.

	if self.myYardAllocation &lt;&gt; null then
		foreach cmifObject in _cmifArray do
			cmifCriteria := cmifObject.CMIF_YACriteriaPriority;
			proxyCriteria := cmifCriteria.myProxy.CM_YACriteria;
			if proxyCriteria.myYACriteriaType = _criteriaType and cmifCriteria.isDeleted then
				//  Change value of existing criteria
				proxyCriteria.setProxy(proxyCriteria.myYACriteriaType, _value, proxyCriteria.code);
				cmifCriteria.setFlag(false, true, false);
				return;
			endif;
		endforeach;
	endif;
	
	// Create an Add Criteria request
	
	create proxyCriteria transient;
	itemCode := _criteriaType.description.cnEcUpto(CM_YACriteriaPriority::code.length -1);
	proxyCriteria.setProxy(_criteriaType, _value, itemCode);
	cmifCriteria := proxyCriteria.getTransient();
	cmifCriteria.setFlag(true, false, false);
	_cmifArray.add(cmifCriteria);
	
epilog

end;</source>
        <Parameter name="_cmifArray" type="CMIF_Array" usage="input"/>
        <Parameter name="_criteriaType" type="CM_YACriteriaType"/>
        <Parameter name="_value" type="Any"/>
    </JadeMethod>
    <JadeMethod name="getExpiryType" id="683c9085-ffe1-4a54-8275-8de3c3448346">
        <source>getExpiryType() : Integer;

/*

Purpose:		Get the value of the relevant YA Expiry Type global constant.		

Parameters:			

Return Value:		


Date			Who		Reason
07 August 2008	consw1	Initial creation
18 March 2021	navdap1	TFS 50946 PRP Auto Delete of Yard Allocations
*/

vars

begin
	if self.optExpiryNever.value then
		return YAExpiryType_Never;
	elseif self.optExpiryVoyage.value then
		return YAExpiryType_VoyageDepart;
	elseif self.optExpiryEmpty.value then
		return YAExpiryType_WhenEmpty;
	elseif self.optExpiryDate.value then
		return YAExpiryType_SpecifiedDate;
	elseif self.optExpiryClear.value then	//29 Jun 2011	NDL	Par 27786
		return YAExpiryType_VoyageClear;
	elseif self.optExpiryNoCargo.value then 		// TFS 50946
		return YAExpiryType_NoCargo;				// TFS 50946
	endif;
	
	return 0;

epilog

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
