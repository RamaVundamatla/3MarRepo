<CollClass name="CM_ColumnFilterDict" id="0058e75e-efcf-40d0-9063-50ede8f4eeb2">
    <loadFactor>66</loadFactor>
    <memberType name="CM_ColumnFilter"/>
    <superclass name="CM_TransientDicts"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="colFilter"/>
    <MemberKey>
        <property name="CM_ColumnFilter::tableName"/>
    </MemberKey>
    <MemberKey>
        <property name="CM_ColumnFilter::entableRowHeading"/>
    </MemberKey>
    <JadeMethod name="addColumnFilter" id="591ff4a2-8ac2-484e-bdab-8f4ad1ce7b86">
        <lockReceiver/>
        <updating/>
        <source>addColumnFilter(	_table : Table;
					_columnIndex : Integer;
					_entableRowHeading : String;
					_filterValues : StringArray;
					_userEntered : Boolean
					) : CM_ColumnFilter protected, updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
20 December 2011	cnwndl1	Initial creation	Par 28889

*/

vars

	colFilter : CM_ColumnFilter;

begin

	
	create colFilter transient;
	colFilter.setColumnFilterData(	_table,
									_columnIndex,
									_entableRowHeading,
									_filterValues,
									_userEntered,
									self
									);
	self.add(colFilter);
	return colFilter;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_table" type="Table"/>
        <Parameter name="_columnIndex" type="Integer"/>
        <Parameter name="_entableRowHeading" type="String"/>
        <Parameter name="_filterValues" type="StringArray"/>
        <Parameter name="_userEntered" type="Boolean"/>
        <ReturnType type="CM_ColumnFilter"/>
    </JadeMethod>
    <JadeMethod name="applyFiltersToRow" id="66c4b4d4-2f59-4059-832f-173318e21a5d">
        <source>applyFiltersToRow( _table : Table; rowIndex : Integer; _row : JadeTableRow io ):Boolean;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
21 December 2011	cnwndl1	Initial creation	par 28889

*/

vars

	iter : Iterator;
	colFilter : CM_ColumnFilter;
	column : Integer;
	cellText : String;
	
begin

	iter := self.createIterator;
	while iter.next( colFilter ) do
	
		if colFilter.tableName &lt;&gt; _table.name then
			continue;
		endif;
	
	//	column := colFilter.columnIndex;
		column := _table.getColumnIndexOf(colFilter.entableRowHeading, colFilter.columnIndex);
		if column = 0 then
			continue;
		endif;
		cellText := _table.getCellText( rowIndex, column ).trimBlanks[1:50];
		
		if not colFilter.showInTable( cellText ) then
			_row.visible := false;
			return false;
		endif;
		
	endwhile;
	
	_row.visible := true;
	return true;

epilog

	delete iter;

end;</source>
        <Parameter name="_table" type="Table"/>
        <Parameter name="rowIndex" type="Integer"/>
        <Parameter name="_row" type="JadeTableRow" usage="io"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="cloneFiltersForTable" id="927fde64-8426-4b43-b89c-eff5890e6713">
        <source>cloneFiltersForTable( _table : Table; _toDict : CM_ColumnFilterDict io );

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
21 Dec 2011	cnwndl1	Initial creation	Par 28889
09 Feb 2012	cnwkpd1	PAR #28731 - fix transient leaks

*/

vars

	deletedObject : Boolean;
	tableName : String;
	iter : Iterator;
	colFilter : CM_ColumnFilter;
	columnIndex : Integer;

begin

	if _toDict = null then
		return;
	endif;

	if _table = null then
		_toDict.clear();
		return;
	endif;
	
	on Exception do app.handleDeletedObject( exception, _table, deletedObject );
	
	tableName := _table.name;
	
	if deletedObject then
		return;
	endif;
	
	if self.isEmpty then
		return;
	endif;
	
	iter := self.createIterator;
	while iter.next( colFilter ) do
		if colFilter.tableName &lt;&gt; tableName then
			continue;
		endif;
		
		//correct the column position if necessary;
		columnIndex := _table.getColumnIndexOf( colFilter.entableRowHeading, colFilter.columnIndex );
		if columnIndex = 0 then
			// can't find it anymore... huh!
			continue;
		endif;
		
		_toDict.addColumnFilter(	_table,	//_table : Table;
									columnIndex,	//_columnIndex : Integer;
									colFilter.entableRowHeading,	//_entableRowHeading : String;
									colFilter.filterValues,	//_filterValues : StringArray;
									colFilter.userEntered	//_userEntered : Boolean
									);
	endwhile;

epilog
	delete iter;
	
end;</source>
        <Parameter name="_table" type="Table"/>
        <Parameter name="_toDict" type="CM_ColumnFilterDict" usage="io"/>
    </JadeMethod>
    <JadeMethod name="delete" id="327921df-d8a0-4628-90bd-5cb55941fb86">
        <lockReceiver/>
        <updating/>
        <source>delete() updating, protected, lockReceiver;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
20 December 2011	cnwndl1	Initial creation	Par 28889

*/

vars

begin

	if not self.isEmpty then
		self.purge();
	endif;

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="getColumnFilter" id="0f98da22-06da-4e92-a6be-844a655888ff">
        <source>getColumnFilter( _table : Table; _columnIndex : Integer; _entableRowHeading : String ):CM_ColumnFilter;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
20 December 2011	cnwndl1	Initial creation	Par 28889

*/

vars

	colFilter : CM_ColumnFilter;
	tableName : String;
	deletedObject : Boolean;

begin

	if self.isEmpty then
		return null;
	endif;
	
	if _table = null then
		return null;
	endif;
	
	if _columnIndex &lt; 1 then
		return null;
	endif;
	
	on Exception do app.handleDeletedObject( exception, _table, deletedObject );
	
	tableName := _table.name;
	
	if deletedObject then
		return null;
	endif;
	
	colFilter := self.getAtKey( tableName, _entableRowHeading );
	
	return colFilter;

epilog

end;</source>
        <Parameter name="_table" type="Table"/>
        <Parameter name="_columnIndex" type="Integer"/>
        <Parameter name="_entableRowHeading" type="String"/>
        <ReturnType type="CM_ColumnFilter"/>
    </JadeMethod>
    <JadeMethod name="includesFiltersFor" id="7d2c9529-d73e-4bf4-997d-2ab66b902446">
        <source>includesFiltersFor( _table: Table ):Boolean;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
04 January 2012	cnwndl1	Initial creation	Par 28889

*/

vars

	colFilter : CM_ColumnFilter;
	tableName : String;
	deletedObject : Boolean;

begin

	if self.isEmpty then
		return false;
	endif;
	
	if _table = null then
		return false;
	endif;
	
	on Exception do app.handleDeletedObject( exception, _table, deletedObject );
	
	tableName := _table.name;
	
	if deletedObject then
		return false;
	endif;
	
	colFilter := self.getAtKeyGeq( tableName, null );
	
	if colFilter = null then
		return false;
	endif;
	
	return colFilter.tableName = tableName;

epilog

end;</source>
        <Parameter name="_table" type="Table"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="replaceAllFiltersForTable" id="83e47294-e050-474e-83e5-d56b90f0ce41">
        <lockReceiver/>
        <updating/>
        <source>replaceAllFiltersForTable(_table: Table; _allNewFilterColumns: CM_ColumnFilterDict) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
21 December 2011	cnwndl1	Initial creation	Par 28889

*/

vars

	deletedObject : Boolean;
	tableName : String;
	col : Integer;
	entableRow : EntTableRow;
	entableRowHeading : String;
	oldColFilter : CM_ColumnFilter;
	newColFilter : CM_ColumnFilter;

begin

	if _table = null then
		return;
	endif;
	
	on Exception do app.handleDeletedObject( exception, _table, deletedObject );
	
	tableName := _table.name;
	if deletedObject then
		return;
	endif;
	
	foreach col in 1 to _table.columns do
		oldColFilter := null;
		newColFilter := null;
		
		entableRow := _table.getEntTableRowAtColumn( col );
		entableRowHeading := entableRow.getHeading(_table.getMyTerminologyCargoBOLType, _table.getMyTerminologyTerminal, app.myCurrentLocale);
		
		oldColFilter := self.getColumnFilter( _table, col, entableRowHeading );
		if _allNewFilterColumns &lt;&gt; null then
			newColFilter := _allNewFilterColumns.getColumnFilter( _table, col, entableRowHeading );
		endif;
		
		if newColFilter &lt;&gt; null then
			self.updateColumnFilter(	_table,	//_table : Table;
										col,	//_columnIndex : Integer;
										entableRowHeading,	//_entableRowHeading : String;
										newColFilter.filterValues,	//_filterValues : StringArray;
										newColFilter.userEntered	//_userEntered : Boolean
										);
		
		elseif oldColFilter &lt;&gt; null then
			self.updateColumnFilter(	_table,	//_table : Table;
										col,	//_columnIndex : Integer;
										entableRowHeading,	//_entableRowHeading : String;
										null,	//_filterValues : StringArray;
										false	//_userEntered : Boolean
										);
		
		endif;
		
	endforeach;

epilog

end;</source>
        <Parameter name="_table" type="Table"/>
        <Parameter name="_allNewFilterColumns" type="CM_ColumnFilterDict"/>
    </JadeMethod>
    <JadeMethod name="updateColumnFilter" id="d60546b3-9c51-4323-96f2-c57458be8b5d">
        <lockReceiver/>
        <updating/>
        <source>updateColumnFilter(	_table : Table;
					_columnIndex : Integer;
					_entableRowHeading : String;
					_filterValues : StringArray;
					_userEntered : Boolean
					):CM_ColumnFilter updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
20 December 2011	cnwndl1	Initial creation	Par 28889

*/

vars

	colFilter : CM_ColumnFilter;
	tableName : String;
	deletedObject : Boolean;

begin

	if _table = null then
		return null;
	endif;
	
	if _columnIndex &lt; 1 then
		return null;
	endif;
	
	on Exception do app.handleDeletedObject( exception, _table, deletedObject );
	
	tableName := _table.name;
	
	if deletedObject then
		return null;
	endif;
	
	// get the existing one if it exists.
	colFilter := getColumnFilter( _table, _columnIndex, _entableRowHeading );
	
	if colFilter = null then
		if _filterValues = null or _filterValues.isEmpty then
			//we were clearing it anyway, just return.
			return null;
		endif;
		// creating a new one.
		colFilter := self.addColumnFilter(	_table,
										_columnIndex,
										_entableRowHeading,
										_filterValues,
										_userEntered
										);
	else
		if _filterValues = null or _filterValues.isEmpty then
			// we are clearing it, remove it and delete it and return null.
			self.remove(colFilter);
			delete colFilter;
			return null;
		endif;
		//updating an existing filter
		colFilter.setFilterValues( _filterValues, _userEntered );
	endif;
	
	return colFilter;
	
epilog

end;</source>
        <Parameter name="_table" type="Table"/>
        <Parameter name="_columnIndex" type="Integer"/>
        <Parameter name="_entableRowHeading" type="String"/>
        <Parameter name="_filterValues" type="StringArray"/>
        <Parameter name="_userEntered" type="Boolean"/>
        <ReturnType type="CM_ColumnFilter"/>
    </JadeMethod>
</CollClass>
