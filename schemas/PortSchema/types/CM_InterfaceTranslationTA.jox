<Class name="CM_InterfaceTranslationTA" id="45331f11-4ff0-4ed6-816f-f2a57cd965da">
    <superclass name="CM_InterfaceTranslation"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="jmtinterface"/>
    <PrimAttribute name="destinationTranslation" id="05ebd9f7-f2ef-45dc-b1f9-89c8ca05a7f6">
        <type name="String"/>
        <access>readonly</access>
    </PrimAttribute>
    <ExplicitInverseRef name="myTerminalAreaMaster" id="63ac9409-2f6f-42e8-9837-9e49c57c2ac5">
        <kind>child</kind>
        <transientToPersistentAllowed/>
        <embedded/>
        <type name="CM_TerminalAreaMaster"/>
        <access>readonly</access>
        <Inverse name="CM_TerminalAreaMaster::allInterfaceTranslations"/>
    </ExplicitInverseRef>
    <JadeMethod name="getDescription" id="990b5245-c7d5-420e-ad72-cd0dba0e020b">
        <source>getDescription():String;
// --------------------------------------------------------------------------------
// Created:		04 September 2008 by cnwdad1
//
// Purpose:		Returns the ID of the receiver's Terminal Area Master.
//
// Parameters:	None
//
// Returns:		The Terminal Area Master description.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if self.myTerminalAreaMaster = null then
		app.raiseUnexpectedProgramError(class.name, method.name, "Terminal Area Master reference is missing.");
	else
		return self.myTerminalAreaMaster.id;
	endif;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getTableDisplay" id="b6890f8f-67f2-4007-96b6-10dd7dc484e0">
        <source>getTableDisplay():String;
// --------------------------------------------------------------------------------
// Created:		04 September 2008 by cnwdad1
//
// Purpose:		Returns a tab-delimited string for displaying the receiver's details
//				in a table control.
//
// Parameters:	None
//
// Returns:		The tab-delimited string.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return self.getDescription() &amp; Tab &amp; self.translationString &amp; Tab &amp; self.destinationTranslation;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="24d7a34e-0993-44e5-820c-39af16164ad3">
        <source>pxyCreateUpdateProxy(): SelfType;
// --------------------------------------------------------------------------------
// Created:		04 September 2008 by cnwdad1
//
// Purpose:		Standard method to instantiate and return a proxy of the receiver.
//
// Parameters:	None
//
// Returns:		A reference to the transient proxy object.
//
// Changed On	Changed By	Reason
// 20/04/2011	cnwmh5		PAR #27401 - Add code to handle prossible exceptions occurring when
//							trying to create the proxy
// --------------------------------------------------------------------------------
vars
	proxyObj	: SelfType;
	completedOK		: Boolean;
	
begin
	proxyObj	:=	inheritMethod();
	
	proxyObj.myTerminalAreaMaster	:=	self.myTerminalAreaMaster;
	
	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return proxyObj;
	
epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete proxyObj;
	endif;	
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="0a61a95c-82b6-4719-8f14-289e71930207">
        <updating/>
        <source>setForCreate(_proxyObj:SelfType) updating;
// --------------------------------------------------------------------------------
// Created:		04 September 2008 by cnwdad1
//
// Purpose:		Standard method that is invoked from a transaction when the receiver
//				is created.
//
// Parameters:	_proxyObj - A reference to a proxy of the receiver.
//
