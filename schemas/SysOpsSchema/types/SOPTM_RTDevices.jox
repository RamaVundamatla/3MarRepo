    <JadeMethod name="changeViews" id="90014797-351b-4434-87fb-46f88adeb7cf">
        <source>changeViews(_type : String);

vars

begin

	if _type = RTDevice_HandHeld then
		self.myForm.tblInput1.showHideRowsByViewName('viewRTHandHeld', CM_EntryTable.ShowHideRows, false);
	elseif _type = RTDevice_Vehicle then
		self.myForm.tblInput1.showHideRowsByViewName('viewRTVehicle', CM_EntryTable.ShowHideRows, false);
	elseif _type = RTDevice_Scanner then
		self.myForm.tblInput1.showHideRowsByViewName('viewRTScanner', CM_EntryTable.ShowHideRows, false);
	endif;

end;</source>
        <Parameter name="_type" type="String"/>
    </JadeMethod>
