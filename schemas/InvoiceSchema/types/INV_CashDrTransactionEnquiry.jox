    <JadeMethod name="includeCashReceiptItem" id="086cdf55-9e24-4b84-87c0-e968ef5dabf6">
        <source>includeCashReceiptItem( cash : CM_CashReceipt;
						recPayMeth : CM_PaymentMethod;
						bolNumber : String;
						voyageCode : String;
						customsNumber : String;
						receiptNumber : String;
						cargoId : String;
						bank : CM_Bank;
						dr : CM_Debtor
						):Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 July 2019	jlgndl1	Initial creation	TFS 45296

*/

vars

begin

	if bank &lt;&gt; null and cash.CM_CashReceipt.myBank &lt;&gt; bank then
		return false;
	endif;
	if dr &lt;&gt; null and cash.myDebtorTerminal.myDebtor &lt;&gt; dr then
		return false;
	endif;
	if recPayMeth &lt;&gt; null and cash.CM_CashReceipt.myPaymentMethod &lt;&gt; recPayMeth then
		return false;
	endif;
	if not cash.CM_CashReceipt.matches(bolNumber, voyageCode, customsNumber, receiptNumber, cargoId) then
		return false;
	endif;
	
	return true;

epilog

end;</source>
        <Parameter name="cash" type="CM_CashReceipt"/>
        <Parameter name="recPayMeth" type="CM_PaymentMethod"/>
        <Parameter name="bolNumber" type="String"/>
        <Parameter name="voyageCode" type="String"/>
        <Parameter name="customsNumber" type="String"/>
        <Parameter name="receiptNumber" type="String"/>
        <Parameter name="cargoId" type="String"/>
        <Parameter name="bank" type="CM_Bank"/>
        <Parameter name="dr" type="CM_Debtor"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="includeConsolidatedItem" id="77a4d420-1fd8-4af9-b2a9-a0ff5ce6dfef">
        <source>includeConsolidatedItem( 	cash : CM_Cash;
							includePayments : Boolean;
							includeReceipts : Boolean;
							recPayMeth : CM_PaymentMethod;
							refPayMeth : CM_PaymentMethod;
							bolNumber : String;
							voyageCode : String;
							customsNumber : String;
							receiptNumber : String;
							cargoId : String;
							startDateIsValid : Boolean;
							startDate : Date;
							bank : CM_Bank;
							dr : CM_Debtor
							):Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
03 July 2019	jlgndl1	Initial creation
31 Jan  2020	cnwma1  ChangeRequest 48428: JMT - Refactor Deleting Unused Cash Classes
*/

vars
	cashBank : CM_Bank;
begin

	if cash.isPayment then
		// proformas can't be archived, no need to check here.
		if not includePayments then
			return false;
		endif;
		
		if bank &lt;&gt; null then
			cashBank := cash.CM_CashPayment.getBank();
			if cashBank &lt;&gt; null and cashBank &lt;&gt; bank then
				return false;
			endif;
		endif;
		
	elseif cash.isReceipt then
		if not includeReceipts then
			return false;
		endif;
		if not self.includeCashReceiptItem( cash.CM_CashReceipt,	//cash : CM_CashReceipt;
											recPayMeth,	//recPayMeth : CM_PaymentMethod;
											bolNumber,	//bolNumber : String;
											voyageCode,	//voyageCode : String;
											customsNumber,	//customsNumber : String;
											receiptNumber,	//receiptNumber : String;
											cargoId,	//cargoId : String;
											bank,	//bank : CM_Bank
											dr	//dr : CM_Debtor
											) then
			return false;
		endif;
	elseif cash.isCredit then
		if bank &lt;&gt; null and cash.CM_CashCredit.myBank &lt;&gt; bank then
			return false;
		endif;
		
	endif;
	
	if startDateIsValid then
		if cash.dateTime.Date &lt; startDate then
			return false;
		endif;
	endif;
	
	return true;

epilog

end;</source>
        <Parameter name="cash" type="CM_Cash"/>
        <Parameter name="includePayments" type="Boolean"/>
        <Parameter name="includeReceipts" type="Boolean"/>
        <Parameter name="recPayMeth" type="CM_PaymentMethod"/>
        <Parameter name="refPayMeth" type="CM_PaymentMethod"/>
        <Parameter name="bolNumber" type="String"/>
        <Parameter name="voyageCode" type="String"/>
        <Parameter name="customsNumber" type="String"/>
        <Parameter name="receiptNumber" type="String"/>
        <Parameter name="cargoId" type="String"/>
        <Parameter name="startDateIsValid" type="Boolean"/>
        <Parameter name="startDate" type="Date"/>
        <Parameter name="bank" type="CM_Bank"/>
        <Parameter name="dr" type="CM_Debtor"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="initFromUserWindow" id="03363a25-fc66-4c7c-97e2-4e97602408cf">
        <updating/>
        <source>initFromUserWindow(_userWindow: CM_UserWindow) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
09 August 2012	cnwndl1	Initial creation

*/

vars

	xmlText : String;

begin

	inheritMethod(_userWindow);
	
	xmlText := _userWindow.xmlInfo.cnEcGetTagValueOfName(self.chkIncludeArch.name);
	self.chkIncludeArch.value := (xmlText = "true").Boolean;
	xmlText := _userWindow.xmlInfo.cnEcGetTagValueOfName(self.chkIncludeCred.name);
	self.chkIncludeCred.value := (xmlText = "true").Boolean;
	xmlText := _userWindow.xmlInfo.cnEcGetTagValueOfName(self.chkIncludePay.name);
	self.chkIncludePay.value := (xmlText = "true").Boolean;
	xmlText := _userWindow.xmlInfo.cnEcGetTagValueOfName(self.chkIncludePro.name);
	self.chkIncludePro.value := (xmlText = "true").Boolean;
	xmlText := _userWindow.xmlInfo.cnEcGetTagValueOfName(self.chkIncludeRec.name);
	self.chkIncludeRec.value := (xmlText = "true").Boolean;
	xmlText := _userWindow.xmlInfo.cnEcGetTagValueOfName(self.chkIncludeRef.name);
	self.chkIncludeRef.value := (xmlText = "true").Boolean;
	xmlText := _userWindow.xmlInfo.cnEcGetTagValueOfName(self.chkAddTotal.name);
	self.chkAddTotal.value := (xmlText = "true").Boolean;
	

epilog

end;</source>
        <Parameter name="_userWindow" type="CM_UserWindow"/>
    </JadeMethod>
    <JadeMethod name="keyDown" id="7c743828-f42b-4849-9937-30d61a822d1c">
