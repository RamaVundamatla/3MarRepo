    <JadeMethod name="setForUpdateLocnCntrl" id="b43efa4a-93c2-4cb1-9c3e-3c915ca4ffcc">
        <updating/>
        <source>setForUpdateLocnCntrl(_pxyLC : CM_LocationsController; _ta :CM_TerminalArea) updating, protected;
// -------------------------------------------
// Created 26 August 2003 by cnwdvb1
