    <JadeMethod name="getDisplayString" id="85626d24-6f8c-4b3b-8606-22e5008bf439">
        <source>getDisplayString(): String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
11 August 2009	cnwmd1	Initial creation
28 May 2024 navma1	Bug 64224: MTN - DeadLocks Caused by Future Actors
23 Jun 2025 navtr3  Bug MTN-35056: MTN - Error 1308 Work Order Enquiry Screen
*/

vars
	wodtl : CM_WorkOrderDtl;
	email : CM_EmailEntity;
	auditStr, tmpStr : String;
	taskAuditStr : String;
	allWoDtlsArray : CM_WorkOrderDtlArray;
begin
	
	tmpStr := null;
	create allWoDtlsArray transient;															  			//23.06.2025 navtr3 #35056
	self.allWoDtls.copy(allWoDtlsArray);																    //23.06.2025 navtr3 #35056
	foreach wodtl in allWoDtlsArray discreteLock do					 //28.05.2024 navma1 #64224
		if tmpStr = null then
			tmpStr := wodtl.getDisplayString(true);					 // TFS 41026 changed to exclude the task id
		else
			tmpStr := tmpStr &amp; ', ' &amp; wodtl.getDisplayString(true); // TFS 41026 changed to exclude the task id
		endif;

	endforeach;
	
	
epilog
	delete allWoDtlsArray;																				//23.06.2025 navtr3 #35056
	return tmpStr;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="a6b88d6e-8847-4a69-8a41-66e3e3ffa450">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
23/07/2009	cnwrd1	Initial creation
29/08/2016	cnwns1	TFS 488 - Multi Timezone Support
09/05/2018	jlgdap1	TFS 38501 PEl1 Work Order Changes
29/09/2021	jlizm1	TFS 51963 SAL Voyage Request Changes
19/10/2021	jlizm1	TFS 52219 SAL Add vesel name/code to column organiser
16/12/2021  navma1	ChangeRequest 52580: SAL - Work Order and Invoicing link
09/03/2022	jlizm1	TFS 52834 SAL file attachments filter by work order
20 Oct 2022 navtnr20 ChangeRequest 54967: EUP - INB/OUT - Operational Instructions
12 Jan 2023	navma1   ChangeRequest 56141: EUP - Refactor and Remove CM_WorkOrderTISource from CM_WorkOrderTI
08 Feb 2023 navma1   ChangeRequest 56457: EUP - Allowing different sets of cargo items per work order task [Refactor]
06 Apr 2023 navhl20  Bug 57458: EUP - Work Order Remarks
08 June 2023 navmv20 CR 54345 Task 57116: Jade - Contract Id Work Order Enquiry
*/

vars
	voyage : CM_Voyage;
	vessel : CM_Vessel;
	debtor : CM_Debtor;
begin
 
	if _attrName = ETRow_WorkOrderNum then
		return id;
	elseif _attrName = ETRow_Status then
		return self.getStatusString();
	elseif _attrName = ETRow_Reference then
		return self.customerReference;
	elseif _attrName = ETRow_RequestedBy then
		return self.getEnteredByDisplay();
	elseif _attrName = ETRow_RequestedByTS then
		return self.systemToLocalTime(self.enteredByDT).asStringJMT;//29 Apr 2016	cnwns1	TFS 488 - Multi Timezone Support
	elseif _attrName = ETRow_ConfirmedBy then
		return self.approvedBy;
	elseif _attrName = ETRow_ConfirmedByTS 	then
		return self.systemToLocalTime(self.approvedByDT).asStringJMT();//29 Apr 2016	cnwns1	TFS 488 - Multi Timezone Support
	elseif _attrName = ETRow_Progress then
		return self.getProgressString();
	elseif _attrName = ETRow_NumberOfTasks then
		return self.getNumberOfTasks().asStringJMT();
	elseif _attrName = ETRow_RequiredByTS then
		return self.systemToLocalTime(self.requiredByDT).asStringJMT();//29 Apr 2016	cnwns1	TFS 488 - Multi Timezone Support
	elseif _attrName = ETRow_Actioned then
		return self.getTotalActionedTasks().asStringJMT();
	elseif _attrName = ETRow_CompleteLastTask then
		return self.getTotalCompleteTasks().asStringJMT();
	elseif _attrName = ETRow_Required then
		return self.getTotalRequired().asStringJMT();
	elseif _attrName = ETRow_Archived then
		return self.archived.asStringJMT();
	elseif _attrName = ETRow_PinNo then											// TFS 38501
		return self.getPINNumber();
	elseif _attrName = ETRow_ApprovalExpiryTS then								//11 Jun 2018	NDL	TFS 38795
		return self.systemToLocalTime(self.approvalExpiryTS).asStringJMT();
	elseif _attrName = ETRow_WoDetailStr then									//15 Jun 2018	NDL	TFS 39167
		return self.getDisplayString;
	elseif _attrName = ETRow_WoTypeStr then										//15 Jun 2018	NDL	TFS 39167
		return self.getTypeString;
	elseif _attrName = ETRow_MyBerth then										// TFS 51963
		if self.getMyBerth() &lt;&gt; null then
			return self.getMyBerth().code;
		else
			return null;
		endif;
	elseif _attrName = ETRow_VesselCode then									// TFS 52219	//06.03.2023 navma1 #56457:[56458]
		vessel := self.getVessel();
		if vessel &lt;&gt; null then
			return vessel.code;
		endif;
		return null;
		
	elseif _attrName = ETRow_VesselName then									// TFS 52219	//06.03.2023 navma1 #56457:[56458]
		vessel := self.getVessel();
		if vessel &lt;&gt; null then
			return vessel.name;
		endif;
		return null;		
	elseif _attrName = ETRow_Invoices then										//16.12.2021 navma1 #52580
		return self.allInvoices.listString(Comma,CM_Invoice::sequenceNum.name.String);
	elseif _attrName = ETRow_Voyage then
		return null;	
	elseif _attrName = ETRow_FileAttachments then		// TFS 52834
		if self.allFiles.isEmpty then					// TFS 52834
			return null;								// TFS 52834
		else
			return self.allFiles.size().asStringJMT();	// TFS 52834
		endif;
	// Start 20.10.2022 navtnr20 TFS 54967
	elseif _attrName = ETRow_InstructionInternal then		
		if self.myInstructions &lt;&gt; null then
			return self.myInstructions.internalInstructions.formatWithEllipsis(1,50,true);
		endif;
		return null;
	elseif _attrName = ETRow_InstructionExternal then
		if self.myInstructions &lt;&gt; null then
			return self.myInstructions.externalInstruction.formatWithEllipsis(1,50,true);
		endif;
		return null;
	elseif _attrName = ETRow_InstructionCode then
		if self.myInstructions &lt;&gt; null then
			return self.myInstructions.getInstructionCode();
		endif;
		return null;
	elseif _attrName = ETRow_InstructionDesc then		
		if self.myInstructions &lt;&gt; null then
			return self.myInstructions.getInstructionDesc();
		endif;
		return null;
	// End 20.10.2022 navtnr20 TFS 54967
	elseif _attrName = ETRow_Remarks then							//06.4.2023 navhl20	#57458
		if self.remarks &lt;&gt; null then
			return self.remarks.formatWithEllipsis(1,100,true);
		endif;
		return null;
	elseif _attrName = ETRow_ContractId then   //08/06/2023 navmv20 CR 54345 Task 57116
		return self.getContractIds(); //08/06/2023 navmv20 CR 54345 Task 57116
	elseif _attrName = ETRow_DebtorName then  // ### TFS CR 56814 TASK 56813 07JUL2023 NAVAB1
		
		return self.getDebtorNames();
	elseif _attrName = ETRow_BillOfLading then //26/11/2024	navkc1 JIRA Story MTN-19092
		return self.getBOLIDStr().formatWithEllipsis(1,100,true);
	elseif _attrName = ETRow_BookingId then //26/11/2024	navkc1 JIRA Story MTN-19092
		return self.getBookingIDStr().formatWithEllipsis(1, 100, true);
	elseif _attrName = ETRow_CargoGroupId then //26/11/2024	navkc1 JIRA Story MTN-19092
		return self.getCargoGroupIdStr().formatWithEllipsis(1, 100, true);
	elseif _attrName = ETRow_CargoType then //26/11/2024	navkc1 JIRA Story MTN-19092
		return self.getCargoTypeStr().formatWithEllipsis(1, 100, true);
	elseif _attrName = ETRow_CargoSubType then //26/11/2024	navkc1 JIRA Story MTN-19092
		return self.getCargoSubTypeStr().formatWithEllipsis(1, 100, true);
	elseif _attrName = ETRow_Commodity then //26/11/2024	navkc1 JIRA Story MTN-19092
		return self.getCommodity().formatWithEllipsis(1, 100, true);
	elseif _attrName = ETRow_CustomsEntryNumber then //26/11/2024	navkc1 JIRA Story MTN-19092
		return self.getCustomEntryNumber().formatWithEllipsis(1, 100, true);
	elseif _attrName = ETRow_DebtorCode then //26/11/2024	navkc1 JIRA Story MTN-19092
		return self.getDebtorCode();
	elseif _attrName = ETRow_ReleaseRequestNumber then //26/11/2024	navkc1 JIRA Story MTN-19092
		return self.getReleaseRequestIDStr().formatWithEllipsis(1, 100, true);
	elseif _attrName = ETRow_OperatorTI then //26/11/2024	navkc1 JIRA Story MTN-19092
		return self.getTIOperatorStr().formatWithEllipsis(1, 100, true);
	elseif _attrName = ETRow_ToDoTaskDesc then //26/11/2024	navkc1 JIRA Story MTN-19092
		return self.getToDoTaskDescStr();
	elseif _attrName = ETRow_TrainCode then //26/11/2024	navkc1 JIRA Story MTN-19092
		return self.getTrainCode();
	elseif _attrName = ETRow_TransportMode then //26/11/2024	navkc1 JIRA Story MTN-19092
		return self.getTransportModeStr();
	elseif _attrName = ETRow_VbsExternalReference then //26/11/2024	navkc1 JIRA Story MTN-19092
		return self.getVBSExternalRef().formatWithEllipsis(1, 100, true);
	elseif _attrName = ETRow_VehicleVisitNumber then //26/11/2024	navkc1 JIRA Story MTN-19092
		return self.getAllVehicleVisitsStr();
	elseif _attrName = ETRow_WagonNumber then //26/11/2024	navkc1 JIRA Story MTN-19092
		return self.getWagonStr();
	endif;
	return inheritMethod(_attrName, _short);
epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getEmailsString" id="e7821705-6417-48cc-887e-39e242e5d020">
        <source>getEmailsString() : String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
05 August 2009	cnwmd1	Initial creation

*/

vars
	selectedEmails : String;
	emailAddress : CM_EmailEntity;
begin
	foreach emailAddress in self.allEmailAddresses do
		if emailAddress.name &lt;&gt; null then
			selectedEmails := selectedEmails &amp; ';' &amp; emailAddress.name.trimBlanks();
		endif;
	endforeach;
	if selectedEmails.length &gt; 1 then
		selectedEmails := selectedEmails[2:end];	
	endif;
epilog
	return selectedEmails;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
