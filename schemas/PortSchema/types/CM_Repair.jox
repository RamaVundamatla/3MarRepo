    <JadeMethod name="updateTI" id="8059b0b0-5e3b-435e-9c92-d5791fb02b84">
        <updating/>
        <source>updateTI(_passport : CM_Passport input) updating;

vars

begin
	inheritMethod(_passport);
	if self.myTrackedItem = null then
		return;
	endif;
	
	//self.myTrackedItem.setDamagedDT();		//Sorts out damage and repair	//27.07.2022 navsrk20 TFS 53862		
	self.myTrackedItem.setDamagedDT(false);		//27.07.2022 navsrk20 TFS 53862
end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
