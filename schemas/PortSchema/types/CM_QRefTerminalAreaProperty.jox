    <JadeMethod name="setComboValues" id="c5c9e065-ffa2-4a0f-8d4c-2de7a355bad9">
        <source>setComboValues(_combo : ComboBox input; _params : CM_QueryCriteriaLineHolder; _queryOperator : CM_QueryOperator; _passport : CM_Passport);
// ---------------------------------------------------------------------------
// Created:     18 February 2003 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 31/03/2020	jlgdap1		TFS 49024 MTN Cargo Enquiry - Terminal Area not poopulated
// ---------------------------------------------------------------------------
vars
	ta				: CM_TerminalAreaMaster;
	idx				: Integer;
	os				: ObjectSet;
	obj				: Object;
	multiTerminal	: Boolean;
	qrl				: CM_QReferenceLookup;
	tmpLbl : String;
		taTypeCrit : CM_SelectorCriteriaLine;
	taTypes : ObjectSet;
begin
	
	_combo.clear;
	
	if _params = null then
		return;
	endif;
	
	
	create os transient;
	_params.getTerminals(os,_passport);
	
	//epr TFS 47132 25/11/2019
	taTypeCrit:=_params.findCriteriaByName(CM_TrackedItem::getTAType.name);
	if taTypeCrit &lt;&gt; null then
		create taTypes transient;
		taTypeCrit.myQueryOperator.getSearchValueAsObjectSet(taTypes);
	endif;
	
	multiTerminal := (os.size &gt; 1);

	foreach obj in os do
		foreach ta in obj.CM_Terminal.allTerminalAreas do
			tmpLbl := ta.getID();
			//epr TFS 47132 18/12/19
			//if taTypes &lt;&gt; null then							// TFS 49024
			if taTypes &lt;&gt; null and not taTypes.isEmpty then		// TFS 49024
				if not taTypes.includes(ta.myType) then
					continue;
				endif;
			endif;
			if multiTerminal then
				idx := _combo.addItem(tmpLbl &amp; ' - ' &amp; ta.myTerminal.code);
			else
				idx := _combo.addItem(tmpLbl);
			endif;
			_combo.itemObject[idx] := ta;
		endforeach;
	endforeach;
	
	if CM_QReferenceLookup.hasInstance(_queryOperator) then
		qrl := _queryOperator.CM_QReferenceLookup;
		if _combo.findObject(qrl.mySelectionValue) &gt; 0 then
			_combo.listObject := qrl.mySelectionValue;
		endif;
	endif;
	
epilog
	delete os;
	delete taTypes;
end;</source>
        <Parameter name="_combo" type="ComboBox" usage="input"/>
        <Parameter name="_params" type="CM_QueryCriteriaLineHolder"/>
        <Parameter name="_queryOperator" type="CM_QueryOperator"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="setListValues" id="d82d4271-1a51-4fc2-9d49-411201878c04">
        <source>setListValues(_tbl : Table input; _params : CM_QueryCriteriaLineHolder; _operator : CM_QReferenceIsOneOf; _passport : CM_Passport);
// ---------------------------------------------------------------------------
// Created:     17 March 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
vars
	crit		: CM_SelectorCriteriaLine;
	tmpTerminal	: CM_Terminal;
	ta			: CM_TerminalArea;
	idx			: Integer;
	os			: ObjectSet;
	value		: Any;
	ut			: CM_UserTerminal;
	obj			: Object;
	multiTerminal	: Boolean;
	selectionValue	: Integer;
begin

	_tbl.rows := _tbl.fixedRows;
	_tbl.sortColumn[1] := 2; // TFS 7821

	
	if _params = null then
		return;
	endif;
	
	/* TFS 7821
	crit := _params.allCriteriaByPropertyName['myTerminal', null];

	create os transient;
	
	if crit &lt;&gt; null then
		crit.myQueryOperator.getSearchValueAsObjectSet(os);
	else
		foreach ut in _passport.myUser.allUserTerminals do
			os.add(ut.getMyTerminal);
		endforeach;
	endif;
	
	multiTerminal := (os.size &gt; 1);

	foreach obj in os do
		foreach ta in obj.CM_Terminal.allTerminalAreas do
			selectionValue := 0;
			if _operator &lt;&gt; null and _operator.allSelectionValues.includes(ta) then
				selectionValue := 1;
			endif;
			
			if multiTerminal then
				idx := _tbl.addItem(selectionValue.String &amp; Tab &amp; ta.id &amp; ' - ' &amp; ta.myTerminal.code);
			else
				idx := _tbl.addItem(selectionValue.String &amp; Tab &amp; ta.id);
			endif;
			_tbl.accessRow(idx).itemObject := ta;
			_tbl.row := idx;
			_tbl.change(_tbl);
		endforeach;
	endforeach;
	 NOW */
	 
	create os transient;
	_params.getTerminals(os,_passport);
	
	multiTerminal := (os.size &gt; 1);

	foreach obj in os do
		foreach ta in obj.CM_Terminal.allTerminalAreas do
			selectionValue := 0;
			if _operator &lt;&gt; null and _operator.allSelectionValues.includes(ta) then
				selectionValue := 1;
			endif;
			
			if multiTerminal then
				idx := _tbl.addItem(selectionValue.String &amp; Tab &amp; ta.id &amp; ' - ' &amp; ta.myTerminal.code);
			else
				idx := _tbl.addItem(selectionValue.String &amp; Tab &amp; ta.id);
			endif;
			_tbl.accessRow(idx).itemObject := ta;
			_tbl.row := idx;
			_tbl.change(_tbl);
		endforeach;
	endforeach;
		 
epilog
	delete os;
end;</source>
        <Parameter name="_tbl" type="Table" usage="input"/>
        <Parameter name="_params" type="CM_QueryCriteriaLineHolder"/>
        <Parameter name="_operator" type="CM_QReferenceIsOneOf"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="setValuesFromList" id="ddb24173-df38-4059-a9a1-20f076abeacd">
        <source>setValuesFromList(_tbl: Table input; _op: CM_QueryOperator input);
// ---------------------------------------------------------------------------
// Created:     17 March 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
vars
	str				: String;
	numRows,
	idx				: Integer;
	taSet				: CM_ObjectSet;
	termArea		: CM_TerminalAreaMaster;
begin

	create taSet transient;
	
	numRows := _tbl.rows;
	foreach idx in (_tbl.fixedRows + 1) to numRows do
		str := _tbl.accessCell(idx, 1).text;
		if str = TableCheckBox_Selected then
			termArea := _tbl.accessRow(idx).itemObject.CM_TerminalAreaMaster;
			taSet.add(termArea);
		endif;
	endforeach;
	
	_op.setSearchValue(taSet);
	
epilog
	delete taSet;	
end;</source>
        <Parameter name="_tbl" type="Table" usage="input"/>
        <Parameter name="_op" type="CM_QueryOperator" usage="input"/>
    </JadeMethod>
    <JadeMethod name="translateStringToSearchValue" id="6a1cef90-21a0-413b-8164-9549e9366a82">
        <source>translateStringToSearchValue(_value: Any; _criteriaLine : CM_SelectorCriteriaLine ): Any;
// ----------------------------------------------------------------------
// Created 12 May 2008 by cnwvu1
//
// Purpose:	Gets value as String from RT screen and returns value
//			 into criteriaLineLine for running a query
// ----------------------------------------------------------------------

vars
	t		: CM_Terminal;
	ta		: CM_TerminalArea;
	passport: CM_Passport;
	tDict	: CM_TAByIdDict;
	tmpValue: String;
	
begin

	if _value.isKindOf( CM_TerminalArea ) then
		return _value;
	endif;
	
	t := app.getMyTerminalDO_NOT_USE();
	tDict	:= t.allTerminalAreas;
	
	tmpValue:= _value.String.toUpper();
	
	foreach ta in tDict do
		if ta.id.toUpper() = tmpValue then
			return ta;
		endif;
	endforeach;

	// when not found. Par 17092	cnwvu1, June 2008
	inheritMethod( _value, _criteriaLine );

end;
</source>
        <Parameter name="_value" type="Any"/>
        <Parameter name="_criteriaLine" type="CM_SelectorCriteriaLine"/>
        <ReturnType type="Any"/>
    </JadeMethod>
    <JadeMethod name="translateToDisplayValue" id="0b341807-0b40-49b1-9277-68c1fe419f1c">
        <source>translateToDisplayValue(_value: Any): String;
// ---------------------------------------------------------------------------
// Created:     18 February 2003 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	if _value = null then
		return null;
	endif;
	
	if _value.isKindOf(CM_TerminalAreaMaster)then
		return _value.CM_TerminalAreaMaster.getID();
	else
		return _value.String;
	endif;
end;</source>
        <Parameter name="_value" type="Any"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="translateToSearchValue" id="e351fbad-aef3-4176-9c88-91e30991fcab">
        <source>translateToSearchValue(_value: Any): Any;
// ---------------------------------------------------------------------------
// Created:     17 March 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
/*

Date		Who		Reason
06 Oct 2008	cnwkpd1	PAR #18099 - Correct Selector query processing
22 Oct 2008	cnwkpd1	PAR #18348 - Prevent 1002 exceptions in Selector query processing with isOneOf

*/

vars
	returnVal		: CM_TerminalAreaMaster;
	
begin
	if _value &lt;&gt; null then
		if _value.isKindOf(Collection) then			// PAR #18348
			return _value;
		endif;

		if _value.isKindOf(CM_TerminalAreaMaster) then
			returnVal := _value.CM_TerminalAreaMaster;
		endif;
	endif;
	
	return returnVal;
	
end;
</source>
        <Parameter name="_value" type="Any"/>
        <ReturnType type="Any"/>
    </JadeMethod>
    <JadeMethod name="translateToSearchValueForWeb" id="edf0989d-cd48-4302-97a2-56823ef68784">
        <source>translateToSearchValueForWeb(_value: Any; _sending : Boolean): Any;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 04/09/2019	jlgdap1		Initial creation TFS 45769 JMT Web Portal selector query parameters
//
vars
	objSet : ObjectSet;
	obj : Object;
	termArea : CM_TerminalArea;
	rtnValue : String;
	term : CM_Terminal;
	collStr, str : String;
	strArray : StringArray;
	coll : ObjectSet;

begin
	if _value.isKindOf(CM_TerminalAreaMaster) then
		return _value.CM_TerminalAreaMaster.id;
		
	elseif _value.isKindOf(Collection) then
		objSet := _value.ObjectSet;
		foreach obj in objSet do
			termArea := obj.CM_TerminalArea;
			rtnValue := rtnValue &amp; termArea.id &amp; CNEC_COMMA &amp; Space;
		endforeach;
		rtnValue := rtnValue[1:rtnValue.length-2];
		return rtnValue;
		
	elseif _value.isKindOf(String) then								
		term := app.myPassport.myTerminal;
		if term &lt;&gt; null then
			if _value.String.cnContains("|") then
				collStr := _value.String;
				create strArray transient;
				create coll transient;
				collStr.getTokensForDelimiter("|", strArray);
				foreach str in strArray do
					coll.addNoDuplicates(term.allTerminalAreas[str], false);
				endforeach;
				return coll;
			endif;
			
			return term.allTerminalAreas[_value.String];
		endif;
		
	endif;
	
	return inheritMethod(_value, _sending);

epilog
	delete strArray;
end;</source>
        <Parameter name="_value" type="Any"/>
        <Parameter name="_sending" type="Boolean"/>
        <ReturnType type="Any"/>
    </JadeMethod>
</Class>
