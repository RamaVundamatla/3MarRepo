        <updating/>
        <source>setIncludeLOC7InterTerm(_includeLOC7InterTerm : Boolean) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 03/02/2021	jlgdap1		Initial creation TFS 50726 GPHA CODECO Message to Differentiate Between Inter-Terminal Transfer and Delivery
//
vars

begin
	if self.protocolDesc &lt;&gt; null 
	and (self.protocolDesc.isKindOf(CM_CamStandardCODECODesc) or self.protocolDesc.isKindOf(CM_CamStandardCODECOSMDG213)) then
		global.setExtraData(self.allExtraData, self, "IncludeLOC7InterTerm", _includeLOC7InterTerm);
	else
		global.setExtraData(self.allExtraData, self, "IncludeLOC7InterTerm", false);
	endif;
epilog

end;</source>
