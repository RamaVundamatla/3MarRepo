    <JadeMethod name="setProxyForDeleteAllQueueEntry" id="185308a6-33f3-45cf-8664-225ed58c4c73">
        <updating/>
        <source>setProxyForDeleteAllQueueEntry(	_machine		: CM_Machine;
								_interfaceDefn	: CM_ITSInterfaceDefinition	) updating;

/*

Purpose:			Set the proxy object's properties for a Delete Queue Entry response for ALL of a machine's entries.

Parameters:			

Return Value:		None


Date		Who		Reason
23 Nov 2009	consw1	PAR #21593 - Development of CCMS MES 1014 - RDT ITS Interface

*/

vars

begin
	self.createdTS		:= app.actualTimeServer();
	//self.messageType	:= ITS_MESSAGETYPE_DELETEQE;
	self.setMessageType(ITS_MESSAGETYPE_DELETEQE);  //cnwjo3 par 25401
	self.messageVersion	:= 1;
	
	self.priority		:= self.Priority_Normal;

	self.myITSInterfaceDefinition 	:= _interfaceDefn;
	self.myRTQueueEntry				:= null;	
	self.myMachine					:= _machine;

	self.setBodyXMLforDeleteQueueEntry(null);
	
epilog

end;
</source>
