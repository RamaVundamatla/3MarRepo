    <JadeMethod name="conflictTypeDescription" id="92b118b8-4821-4265-9cc5-d8442816b271">
        <source>conflictTypeDescription() : String;
//--------------------------------------------------
// Created:	10 February 2004 By: cnwgd1
//--------------------------------------------------
begin
	if self.conflictType = ValidateWharfLockout then
		return app.getErrorString(ConflictDescWharfLockout);
	elseif self.conflictType = ValidateShipPosn then
		return app.getErrorString(ConflictDescWharfSection);
	elseif self.conflictType = ValidateClearances then
		return app.getErrorString(ConflictDescShipOverlap);
	elseif self.conflictType = ValidateWharfOverhang then
		return app.getErrorString(ConflictDescOverhangExceeded);
	elseif self.conflictType = ValidateTidalWindow then
		return app.getErrorString(OutsideTidalWindow);
	elseif self.conflictType = ValidateBerthDepths then
		return app.getErrorString(ConflictDescShipDraft);
	elseif self.conflictType = ValidatePilotMaster then
		return app.getErrorString(NoMasterPilot);
	elseif self.conflictType = ValidateSteamTime then
		return app.getErrorString(ConflictDescSteamTime);
	elseif self.conflictType = ValidateStockpile then
		return self.conflictDescription;
	elseif self.conflictType = ValidateVesselUnavail then
		return app.getErrorString(ConflictDescVesselUnavail);
	else
		return null;
	endif;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="conflictTypeString" id="ebdc54b4-9a2f-437a-8c3c-21b0d155bf60">
        <source>conflictTypeString() : String;
//--------------------------------------------------
// Created:	10 February 2004 By: cnwgd1
//--------------------------------------------------
begin
	if self.conflictType = ValidateWharfLockout then
		return app.getErrorString(ConflictTypeWharfLockout);
	elseif self.conflictType = ValidateShipPosn then
		return app.getErrorString(ConflictTypeWharfSection);
	elseif self.conflictType = ValidateWharfOverhang then
		return app.getErrorString(ConflictTypeOverhangExceeded);
	elseif self.conflictType = ValidateTidalWindow then
		return app.getErrorString(ConflictTypeTidalWindow);
	elseif self.conflictType = ValidateBerthDepths then
		return app.getErrorString(ConflictTypeShipDraft);
	elseif self.conflictType = ValidateClearances then
		return app.getErrorString(ConflictTypeShipOverlap);
	elseif self.conflictType = ValidatePilotMaster then
		return app.getErrorString(ConflictTypeMasterPilot);
	elseif self.conflictType = ValidateSteamTime then
		return app.getErrorString(ConflictTypeSteamTime);
	elseif self.conflictType = ValidateStockpile then
		return app.getErrorString(ValidateStockpileTitle);
	elseif self.conflictType = ValidateVesselUnavail then
		return app.getErrorString(ConflictTypeVesselUnavail);
	else
		return null;
	endif;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="2cd31194-979c-4a94-a558-a071e686e69c">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
//--------------------------------------------------
// Created:	09 February 2004 By: cnwgd1
//--------------------------------------------------
begin
	if _attrName = ETRow_ConflictType then
		return self.conflictTypeString();
		
	elseif _attrName = ETRow_ConflictDescription then
		return self.conflictTypeDescription();
		
	elseif _attrName = ETRow_ExtraDetail then
		return self.extraDetail;
		
	else
		if self.myVoyageMovement = null then
			if _attrName = ETRow_VesselName then
				return self.vesselName;
				
			elseif _attrName = ETRow_HmsMovementVoyage then
				return self.voyageCode;
				
			elseif _attrName = ETRow_OccursOnDT then
				return self.occursOn;
				
			else
				return "N/A";
			endif;
		else
			return self.myVoyageMovement.getDisplayStringForAttribute(_attrName, _short);
		endif;
	endif;
end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="setConflictDescription" id="7b64f669-e754-4ade-b7b5-f7db9e79161c">
        <updating/>
        <source>setConflictDescription(_conflictDescription:String) updating;
// --------------------------------------------------------------------------------
// Created:		22 February 2007 by cnwdad1
//
// Purpose:		Sets a description of the Conflict - this description can be used
//				instead of the Global Constant values to provide more dynamic
//				information, such as a message with a date or Voyage details.
//
// Parameters:	_conflictDescription - The description of the Conflict.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.conflictDescription	:=	_conflictDescription;
end;</source>
        <Parameter name="_conflictDescription" type="String"/>
    </JadeMethod>
    <JadeMethod name="setConflictDetails" id="af2868ad-8b01-4e02-b750-6d5589002480">
        <updating/>
        <source>setConflictDetails(_vesselName:String; _vesselCode:String; _occursOn:String; _conflictDescription:String) updating;
// --------------------------------------------------------------------------------
// Created:		23 February 2007 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.vesselName				:=	_vesselName;
	self.voyageCode				:=	_vesselCode;
	self.occursOn				:=	_occursOn;
	self.conflictDescription	:=	_conflictDescription;
end;</source>
        <Parameter name="_vesselName" type="String"/>
        <Parameter name="_vesselCode" type="String"/>
        <Parameter name="_occursOn" type="String"/>
        <Parameter name="_conflictDescription" type="String"/>
    </JadeMethod>
</Class>
