    <JadeMethod name="checkMessageId" id="10ad28f6-c4a3-4597-89cb-55f7f6a70d85">
        <source>checkMessageId() : Boolean;

begin

	// Roll over code is in trx.
	if self.messageId.Integer &gt; self.myRadioTelemetryDevice.lastMessageId then
		app.myTrxUA.trxUpdateRadioTelemetryLastMsg(self.myRadioTelemetryDevice, self.messageId.Integer, app.myPassport);
		if app.myPassport.trxCompletedOK then
			return true;
		endif;
	endif;
	return false;

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doBuildMessage" id="d4c91089-aba3-4a28-987a-b80f290c9b7e">
        <source>doBuildMessage(_body : String) : String protected;

vars

begin

	return self.formatAsXMLPrefix(XML_MSG) &amp; _body &amp; self.formatAsXMLSuffix(XML_MSG);

end;</source>
        <access>protected</access>
        <Parameter name="_body" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDisplay" id="23d20556-655b-4ac3-9df8-6153b753d106">
        <source>getDisplay() : String;

// cnwdvb1 17 February 2003 

vars

begin

	return 'Message - ' &amp; self.messageId &amp; '/ User ' &amp; self.userId &amp; '/ Message Type ' &amp; self.class.text.cnEcGetTagValueOfName('display');

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getHeaderDtlExternal" id="4b459010-4051-4439-80ac-0e1bc4480acd">
        <updating/>
        <source>getHeaderDtlExternal(_parseAgent : CM_RemoteParseAgent io) : Boolean updating;

vars


begin

	self.raiseExceptionIfNotTransient(method);
	return _parseAgent.getHeaderDetails(self.messageId, self.messageType, self.time, self.terminal);

end;</source>
        <Parameter name="_parseAgent" type="CM_RemoteParseAgent" usage="io"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
