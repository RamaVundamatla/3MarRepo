    <JadeMethod name="getEventOfTypeShiftFirst" id="3986d15e-8646-4fca-8633-e796d655c5b4">
        <source>getEventOfTypeShiftFirst(_eventType : CM_EventType; _shift : CM_Shift input) : CM_EventTransaction;
/*
Purpose:			
Date		Who		Reason
03 February 2017	cnwab1	Initial creation
*/

vars
	event : CM_EventTransaction;
begin
	foreach event in self.allEventTransactionsByDateTime discreteLock do
		if _shift = null then
			if event.myEventType = _eventType then
				return event;
			endif;
		else
			if event.myEventType = _eventType then
				if event.matchesShift(_shift) then
					return event;
				endif;
			endif;
		endif;
	endforeach;
	
	return null;
epilog

end;</source>
        <Parameter name="_eventType" type="CM_EventType"/>
        <Parameter name="_shift" type="CM_Shift" usage="input"/>
        <ReturnType type="CM_EventTransaction"/>
    </JadeMethod>
    <JadeMethod name="getExchangeDetailsSetPC" id="ca567a46-5ada-4d53-933c-71a72ebd16a6">
        <source>getExchangeDetailsSetPC() : Integer;
/*
Purpose:PAR 35397	on the voyage enq, there is a tab called exchange details. This has a set of timestamps. This method simply shows the percentage that are set.		
Date		Who		Reason
12 January 2015	cnwab1	Initial creation
*/

vars
	numSet, numAvail : Integer;
begin
	numAvail := 9;
	
	if self.pilotOnBoardDT.isValid then
		numSet	 := numSet + 1;
	endif;
	
	if self.shipPilotReturnDT.isValid then
		numSet	 := numSet + 1;
	endif;
	
	if self.shipAnchorDownDT.isValid then
		numSet	 := numSet + 1;
	endif;
	
	if self.labourOnBoard.isValid then
		numSet	 := numSet + 1;
	endif;
	
	if self.labourOnShore.isValid then
		numSet	 := numSet + 1;
	endif;
	
	if self.departTargetDT.isValid then
		numSet	 := numSet + 1;
	endif;
	
	// first day cargo available
	if self.dateFirstAvailable.isValid then
		numSet	 := numSet + 1;
	endif;
	if self.shipExchangeCompleteDT.isValid then
		numSet	 := numSet + 1;
	endif;
	if self.shipExchangeDate.isValid then
		numSet	 := numSet + 1;
	endif;
	
	return ((numSet / numAvail) * 100).Integer;
	
epilog

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getExchangeTxns" id="2f8e1442-5a57-495d-98f7-3b2bfc57d8c9">
        <source>getExchangeTxns(_txnBucket: CM_TITransactionByTypeDateDict input);
//----------------------------------------------------------------
//	Created:	21 July 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	startTS,
	endTS			: TimeStamp;

begin
	
	startTS.setDate('01/01/0001'.Date);
	startTS.setTime('00:00:00:000'.Time);
	endTS.setDate(app.actualTimeServer.date);
	endTS.setTime('23:59:59:999'.Time);
	
	self.getTITxns(TRANS_TYPE_REC_SHIP, startTS, endTS, true, null, self, _txnBucket);
	self.getTITxns(TRANS_TYPE_REL_SHIP, startTS, endTS, true, null, self, _txnBucket);
	self.getTITxns(TRANS_TYPE_MOVE, startTS, endTS, true, null, self, _txnBucket);
	
end;</source>
        <Parameter name="_txnBucket" type="CM_TITransactionByTypeDateDict" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getExpectedDischargeMinutes" id="3354362c-74be-456d-b578-d0d75f74c882">
        <source>getExpectedDischargeMinutes():Integer;

constants
	DischargeTonnage	: Integer = 70000;	// FOR DEMO ONLY -- VALUE WILL BE AVAILABLE AS PART OF BULK LOAD DEVELOPMENT
	
vars
	dischargeTonnage	: Integer;		// bulk tonnage to discharge

begin
	if self.dischargeRate = 0 then
		return 0;
	endif;
	
	// calculate allowed duration for load + discharge
	dischargeTonnage	:=	DischargeTonnage;	// 	DEMO VALUES ONLY
	
	return (dischargeTonnage / self.dischargeRate * 60).rounded();
end;
</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getExpectedLoadMinutes" id="3cb64a9a-7d0e-4618-a7dd-7178eb0cbe43">
        <source>getExpectedLoadMinutes():Integer;

// expected time to load based on load tonnage and load rate

constants
	LoadTonnage	: Integer = 70000;	// FOR DEMO ONLY -- VALUE WILL BE AVAILABLE AS PART OF BULK LOAD DEVELOPMENT
	
vars
	loadTonnage	: Integer;		// bulk tonnage to load
	
begin
	if self.loadRate = 0 then
		return 0;
	endif;
	
	loadTonnage	:=	LoadTonnage;	// 	DEMO VALUES ONLY
	
	return (loadTonnage / self.loadRate * 60).rounded();
end;
</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getExportBOLNumbers" id="a863e483-3ea3-46fd-b914-e5597c3e2860">
        <source>getExportBOLNumbers(_bols : StringArray input);
// 34917 populate the string array with all BOL numbers for on-site cargo
//  from both the explicit CM_BOLs and also the CM_TrackedItem.billOfLading text to get all bill of lading numbers
//		whether they have a BOL object or not, for the EXPORT bols
vars
	bol	: CM_BOL;

begin
	foreach bol in self.allBOLOutByTypeStatusNumDT do
		_bols.add(bol.number);
	endforeach;
end;
</source>
        <Parameter name="_bols" type="StringArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getExtensionResourceUsed" id="fb4bc40b-d703-46d4-95fe-b75944c5b055">
        <source>getExtensionResourceUsed() : HMS_ResourceUsed;
/*
Purpose:	TFS 42241		
Date				Who			Reason
NOVEMBER 2018		CNWAB1		Initial creation
*/

vars
	term : CM_Terminal;
	harbour : HMS_Harbour;
	processHarbour : CM_ProcessHarbour;
	departMovement : HMS_VoyageMovement;
	resused : HMS_ResourceUsed;
begin
	term :=self.myTerminal;
	
	harbour := term.myHarbour;
	
	processHarbour := harbour.allProcessHarbours.getAtKey( self.myVoyageProcess, harbour );
	
	if processHarbour = null then
		return null;
	endif;
	
	if processHarbour.myHMSResourceForExtension = null then
		return null;
	endif;
	
	departMovement := self.getMovementDeparture();
	
	if departMovement = null then
		return null;
	endif;
	
	
	foreach resused in departMovement.allResourceUsed	discreteLock do
		if resused.myResource = processHarbour.myHMSResourceForExtension then
			return resused;
		endif;
	endforeach;
	
	return null;
	
epilog

end;</source>
        <ReturnType type="HMS_ResourceUsed"/>
    </JadeMethod>
    <JadeMethod name="getExtraInfo" id="8f6fa5e8-89df-49b2-b417-665b303a9114">
        <source>getExtraInfo(_dataContainer: CM_DataContainer) ;


// 14 Mar 2013	PJS		PAR # 3132
// 24 June 2016	cnwns1	TFS 488 - Multi Timezone Support
vars
	block : CM_DataContainerBlock;
	remStr : String;
begin
	inheritMethod(_dataContainer);

	if self.remarks.length &gt; 2000 then
		remStr := self.remarks[1:2000];
	else
		remStr := self.remarks;
	endif;
	block := _dataContainer.addNewBlock;
	block.addNewItem(app.getErrorString(Remarks_GC), DC_Label, 1, self);
	block.addNewItem(remStr, DC_Data, 1, self);

	block := _dataContainer.addNewBlock;
	block.addNewItem(app.getErrorString(CM_Vessel_GC), DC_Label, 1, self);
	block.addNewItem(self.vesselName, DC_Data, 1, self);

	block := _dataContainer.addNewBlock;
	block.addNewItem(app.getErrorString(CM_Starboard_Berthed), DC_Label, 1, self);
	block.addNewItem(app.getYesNo(self.starboardBerthed), DC_Data, 1, self);


	block := _dataContainer.addNewBlock;
	block.addNewItem(app.getErrorString(CM_Arrival_Date), DC_Label, 1, self);
	block.addNewItem(self.systemToLocalTime(self.arrivedDT).shortCurrentLocaleFormat, DC_Data, 1, self);// 24 June 2016	cnwns1	TFS 488 - Multi Timezone Support

	block := _dataContainer.addNewBlock;
	block.addNewItem(app.getErrorString(CM_Departure_Date), DC_Label, 1, self);
	block.addNewItem(self.systemToLocalTime(self.departedDT).shortCurrentLocaleFormat, DC_Data, 1, self);// 24 June 2016	cnwns1	TFS 488 - Multi Timezone Support
	
	block := _dataContainer.addNewBlock;
	block.addNewItem("Harbour Invoice Status", DC_Label, 1, self);
	block.addNewItem(self.statusInvoiceString, DC_Data, 1, self);
	
	// 31232 

	block.addNewItem('Cargo Structure', DC_Label, 1, null);
	block.addNewItem(self.getVoyageTypeString, DC_Data, 1, null);	
	
	block := _dataContainer.addNewBlock;		//13.05.2022 navsrk	53142
	block.addNewItem(app.getErrorString(Cargo_Forecast), DC_Label, 1, self);	//13.05.2022 navsrk	53142
	block.addNewItem(self.getCargoForecastStr, DC_Data, 1, self);	//13.05.2022 navsrk	53142
	
end;</source>
        <Parameter name="_dataContainer" type="CM_DataContainer"/>
    </JadeMethod>
    <JadeMethod name="getExtraInfoLogVoyOps" id="15741140-ffc9-422f-9990-b92536b14c0a">
        <source>getExtraInfoLogVoyOps(_array : HugeStringArray input;  _terminalForTerminology : CM_Terminal);
//--------------------------------------------------------------
//Created: 07 August 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	str,
	term : String;
	berth	: HMS_Berth;
	voyOper : CM_VoyageOperator;
begin
	_array.add("Voyage" &amp; Tab &amp; self.code &amp; ' ' &amp; self.description);
	_array.add("Terminal" &amp; Tab &amp; self.myTerminal.name);	
	if self.remarks.length &gt; 2000 then
		_array.add("Comments" &amp; Tab &amp; self.remarks[1:2000]);
	else
		_array.add("Comments" &amp; Tab &amp; self.remarks);				
	endif;
	// 33174 CCMS 1124 add berth, side-to, arrival date/time
	berth := self.getMyBerth();
	if berth &lt;&gt; null then
		_array.add("Berth" &amp; Tab &amp; berth.code);
	endif;
	if self.starboardBerthed then
		str := "Starboard";
	else
		str := "Port";
	endif;
	_array.add("Side To" &amp; Tab &amp; str);
	_array.add("Arrival Date/Time" &amp; Tab &amp; self.systemToLocalTime(self.arrivedDT).cnEcShortFullFormat);	// 22/4/16 cnwmp6 TFS 488 - Multi timezone support
	_array.add("Load Start Date/Time" &amp; Tab &amp; self.systemToLocalTime(self.loadStartDT).cnEcShortFullFormat);	// 22/4/16 cnwmp6 TFS 488 - Multi timezone support
	_array.add("Load End Date/Time" &amp; Tab &amp; self.systemToLocalTime(self.loadEndDT).cnEcShortFullFormat);	// 22/4/16 cnwmp6 TFS 488 - Multi timezone support
//	Aug 2011	cnwjre1		CCMS 1120 Par 28082 Log voyage operations changes
	_array.add("Sail Date/Time" &amp; Tab &amp; self.systemToLocalTime(self.departedDT).cnEcShortFullFormat);	// 22/4/16 cnwmp6 TFS 488 - Multi timezone support
	_array.add("Load Rate" &amp; Tab &amp; self.loadRate.asStringJMT);
	// 33265 add Status
	_array.add("Status" &amp; Tab &amp; self.statusDescription);

	if self.myLogVoyageStructure &lt;&gt; null then
		self.myLogVoyageStructure.getExtraInfoLogVoyOps(_array, _terminalForTerminology);

		str	:= null;
		foreach voyOper in self.allVoyageIOperators do
			str := str &amp; voyOper.myOperator.code &amp; '; ';
		endforeach;
		term := app.getTerminologyAlternate(app.myRoot.allCargoTypesById[TI_CargoType_Log], _terminalForTerminology, CM_TerminologyOperator, CM_TermExpressionPlural, 'Suppliers');
		_array.add(term &amp; Tab &amp; str);			
			
	endif;
						
end;</source>
        <Parameter name="_array" type="HugeStringArray" usage="input"/>
        <Parameter name="_terminalForTerminology" type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="getFileAttachments" id="1e55a43e-0dc3-46b0-ab67-4ebabd5faf42">
        <source>getFileAttachments(): CM_FileDataSet;
/*
Purpose:			

Date		Who		Reason
13 December 2022	navab1	TFS CR 55645 TASK 55662
*/

vars
	tmp : CM_FileDataSet;
	wo : CM_WorkOrder;
begin
	create tmp transient;
	self.allFiles.copy(tmp);
	
	foreach wo in self.allWorkOrders do
		wo.allFiles.copy(tmp);
	endforeach;
	
	return tmp;

epilog

end;</source>
