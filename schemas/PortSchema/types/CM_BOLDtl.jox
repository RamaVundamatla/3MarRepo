    <JadeMethod name="getMeasurementStringForAttrib" id="578bfa18-7b44-48ee-9e24-43b4831909db">
        <source>getMeasurementStringForAttrib(_attrName: String; _measureType: String; _short: Boolean): String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
15 April 2013	cnwrd1	Initial creation

*/

vars

begin
	if _attrName = ETRow_WeightTotal then
		return app.convertMeasurementForDisplay(_measureType, self.weight);
	elseif _attrName = ETRow_LengthCode then
		return app.convertMeasurementForDisplay(_measureType, self.length);
	endif;
	return inheritMethod(_attrName, _measureType, _short);

epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_measureType" type="String"/>
        <Parameter name="_short" type="Boolean"/>
