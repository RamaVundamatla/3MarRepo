    <JadeMethod name="doViewDelete" id="7c011a5b-3260-484c-ad03-30f53dcf993a">
        <interfaceImplements>
            <JadeInterfaceMethod name="IF_CM_TerminalAreaViews::deleteView"/>
        </interfaceImplements>
        <source>doViewDelete(_taView : CM_TerminalAreaView input);

	/*
		this method stub has been automatically generated by Jade to satisfy interface implementation requirements
	*/
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
18 November 2010	cnwer1	Initial creation

*/

vars

	theResult : Integer;	//15 Jan 2020 NDL	TFS 46815

begin
	if _taView = null then
		return;
	endif;
	
	//15 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
	while true do
	
		app.myTrxDA.trxDeleteTerminalAreaView(_taView,app.myPassport);
	
		if app.myPassport.trxCompletedOK then
			break;
		else
			theResult := app.showErrorWarningDialog(self.caption, app.myPassport, ErrWarnMode_Update);
			if app.myPassport.noErrors and theResult = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		
		break;
		
	endwhile;
	
epilog

end;</source>
