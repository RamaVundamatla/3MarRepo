    <JadeMethod name="addSprite" id="d76f06e6-bd87-43fb-aa92-3356cfcf2262">
        <updating/>
        <source>addSprite(	_workingMove:CMIF_HMS_WorkingMovement;
			_nextMove:CMIF_HMS_WorkingMovement;
			_selectedMove:CMIF_HMS_WorkingMovement;
			_allRestrictedObj:CMIF_HMS_WorkingVoyageSet) : HMS_GraphicalDragPicture updating;

vars
	dragPic				: HMS_GraphicalDragPicture;
	bowOnLeft			: Boolean;
	dispLeftToRight		: Boolean;
	xLeft				: Real;
	yTop				: Real;
	xWidth				: Real;
	yHeight 			: Real;
	voyageData			: HMS_VoyageData;
	
begin
	// this method builds and positions the ships
	
	if (not self.calculateSpriteLeftPosition(_workingMove, xLeft, dispLeftToRight, bowOnLeft)) then
		return null;
	endif;

	// get the display width and height for the ship
	voyageData	:=	_workingMove.myHMSVoyageData;
	
	if voyageData = null then
		voyageData	:=	_workingMove.myWorkingVoyage.myHMSVoyageData;
	endif;
	
	if voyageData &lt;&gt; null then
		//There is an actual voyage
		xWidth	:=	voyageData.dim_LengthOverall/self.metersPerPixel;
	endif;
	
	if xWidth &lt; 1 then
		xWidth	:=	3;
	endif;

	self.myGraphicalViewForm.calculateSpriteTopHeight(_workingMove, _nextMove, yTop, yHeight);
	// create and position the ship sprite
	dragPic	:=	self.myGraphicalViewForm.getNewPicDrag(self, _workingMove, _nextMove, bowOnLeft);

	dragPic.move(xLeft, yTop, xWidth, yHeight);
	dragPic.colourSelectedSprite3(_selectedMove, false, _allRestrictedObj);

	return dragPic;
end;</source>
        <Parameter name="_workingMove" type="CMIF_HMS_WorkingMovement"/>
        <Parameter name="_nextMove" type="CMIF_HMS_WorkingMovement"/>
        <Parameter name="_selectedMove" type="CMIF_HMS_WorkingMovement"/>
        <Parameter name="_allRestrictedObj" type="CMIF_HMS_WorkingVoyageSet"/>
        <ReturnType type="HMS_GraphicalDragPicture"/>
    </JadeMethod>
    <JadeMethod name="addVoyageToView" id="c3b7b339-b3ef-406c-a57e-0f6522416b6c">
        <updating/>
        <source>addVoyageToView(_workingVoyage : CMIF_HMS_WorkingVoyage; _selectedMovement : CMIF_HMS_WorkingMovement)updating;
//--------------------------------------------------
// Created:	30 July 2004 By: cnwgd1
//--------------------------------------------------
vars
	nextMove,
	workingMove : CMIF_HMS_WorkingMovement;
begin

	foreach workingMove in _workingVoyage.allWorkingMovements do
		nextMove := workingMove.getMovementNext();
		if nextMove &lt;&gt; null and global.isValidObject(nextMove) then	
			self.addSprite(workingMove, nextMove, _selectedMovement, null);
		endif;
	endforeach;
end;</source>
        <Parameter name="_workingVoyage" type="CMIF_HMS_WorkingVoyage"/>
        <Parameter name="_selectedMovement" type="CMIF_HMS_WorkingMovement"/>
    </JadeMethod>
    <JadeMethod name="backoutSpriteChanges" id="6a988c67-ad96-48c4-94f1-93f8403c9111">
        <source>backoutSpriteChanges(_currentSprite:HMS_GraphicalDragPicture input);

vars

begin

	// backout changes to currently selected sprite
	_currentSprite.moveToSavePosition();

	// backout changes to any associated sprites that have been moved
	if _currentSprite.myDragPictureNext &lt;&gt; null then
		_currentSprite.myDragPictureNext.moveToSavePosition();
	endif;
	if _currentSprite.myDragPicturePrevious &lt;&gt; null then
		_currentSprite.myDragPicturePrevious.moveToSavePosition();
	endif;		
end;</source>
        <Parameter name="_currentSprite" type="HMS_GraphicalDragPicture" usage="input"/>
    </JadeMethod>
    <JadeMethod name="calculateSpriteLeftPosition" id="59747443-5169-4de2-a9fb-41022e565a52">
        <source>calculateSpriteLeftPosition(_workingMove : CMIF_HMS_WorkingMovement;
							_leftPos : Real output;
							_dispLeftToRight : Boolean output;
							_bowOnLeft : Boolean output):Boolean;
vars
	indx			: Integer;
	berth			: HMS_Berth;
	wharf			: HMS_Wharf;
	wharfOverhang  	: Integer;
	
begin
	// this method gets the left (x) position for the sprite
	if (not global.isValidObject(_workingMove)) then
		return false;
	endif;
	
	berth := _workingMove.myBerth;
	indx  := self.allBerthByLeftPos.indexOf(berth);

	if indx &lt; 1 then
		return false;
	endif;

	wharf				:= berth.myWharf;
	_dispLeftToRight	:= wharf.displayLeftToRight;
	
	// calc the bow indicator
	if _workingMove.bowMarkTo &lt; _workingMove.sternMarkTo then
		if _dispLeftToRight then
			_bowOnLeft := true;
		else
			_bowOnLeft := false;
		endif;
	elseif _workingMove.bowMarkTo &gt; _workingMove.sternMarkTo then
		if _dispLeftToRight then
			_bowOnLeft := false;
		else
			_bowOnLeft := true;
		endif;
	else
		//Bow and stern are the same, can't see it, must be at sea or logical berth
		return false;
	endif;

	//Wharf displayed left to right
	if _dispLeftToRight and _bowOnLeft then
		_leftPos := ((_workingMove.bowMarkTo + wharf.overhangZeroMetreEnd) / self.metersPerPixel);
	elseif _dispLeftToRight and (not _bowOnLeft) then
		_leftPos := ((_workingMove.sternMarkTo + wharf.overhangZeroMetreEnd) / self.metersPerPixel);
	
	//Wharf displayed right to left
	elseif (not _dispLeftToRight) and _bowOnLeft then
		_leftPos := ((wharf.length + wharf.overhangMaxMetreEnd - _workingMove.bowMarkTo) / self.metersPerPixel);
	elseif (not _dispLeftToRight) and (not _bowOnLeft) then
		_leftPos := ((wharf.length + wharf.overhangMaxMetreEnd - _workingMove.sternMarkTo) / self.metersPerPixel);
	endif;

	return true;
end;</source>
        <Parameter name="_workingMove" type="CMIF_HMS_WorkingMovement"/>
        <Parameter name="_leftPos" type="Real" usage="output"/>
        <Parameter name="_dispLeftToRight" type="Boolean" usage="output"/>
        <Parameter name="_bowOnLeft" type="Boolean" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
