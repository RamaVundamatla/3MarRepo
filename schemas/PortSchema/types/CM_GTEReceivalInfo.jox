    <JadeMethod name="addTrackedItem" id="47dc0793-983d-48f6-88de-8875bda39592">
        <source>addTrackedItem(_ti: CM_TrackedItem);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
25 February 2010	cnwjk3	ccms 1071

*/

vars

begin
	inheritMethod(_ti);
	if self.myReceivalRequestInfo &lt;&gt; null then
		if not self.myReceivalRequestInfo.allTrackedItems.includes( _ti ) then
			self.myReceivalRequestInfo.allTrackedItems.add( _ti );
		endif;
	endif;
epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="3ac4b846-4318-40cd-9878-cdae9deba432">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 March 2014	cnwndl1	Initial creation	Par 33596

*/

vars

begin

	if _attrName = ETRow_NumItems then // this is "Total Quantity"
		if self.myCargoType &lt;&gt; null and self.myCargoType.allowDuplicates then
			if self.myGTEReceivalByType &lt;&gt; null and self.myGTEReceivalByType.quantity &gt; 0 then
				return self.myGTEReceivalByType.quantity.String;
			endif;
		endif;
		return "1".String;
		
	elseif _attrName = ETRow_VoyageCode then
		if self.myGTEReceivalByType &lt;&gt; null and self.myGTEReceivalByType.voyageCode &lt;&gt; null then
			return self.myGTEReceivalByType.voyageCode;
		endif;
					
	endif;
	
	return inheritMethod(_attrName, _short);
	
epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getParent" id="49b3963c-6a87-4b9e-8426-72bfb8dbb9ab">
        <source>getParent() : CMGTE_ReceivalByType;
//15 February 2010	cnwdw1	
//

begin
	return self.myGTEReceivalByType;
end;</source>
        <ReturnType type="CMGTE_ReceivalByType"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="00a321c0-0a28-49d9-9d84-10776d990a12">
        <source>pxyCreateUpdateProxy(): SelfType;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
23 February 2010	cnwjk3	Initial creation
11 February 2011	cnwdap1	PAR #26929 Prevent 1210 errors when trying to set proxy myReceivalRequestInfo reference
20/04/2011			cnwmh5	PAR #27401 - Add code to handle prossible exceptions occurring when
							trying to create the proxy
*/

vars
	_pxyReceivalInfo : SelfType;
	receivalRequest : CM_ReceivalRequestInfo;		// PAR #26929
	completedOK		: Boolean;
begin
	_pxyReceivalInfo := inheritMethod();
	///_pxyReceivalInfo.myReceivalRequestInfo := self.myReceivalRequestInfo;		// 13/12/2010 cnwmh5 #26556
	if self.myReceivalRequestInfo &lt;&gt; null then
		// PAR #26929 can't just create the reference as a proxy, as the myReceivalRequestInfo.pxyCreateUpdateProxy method sets its
		// myGTEReceivalInfo reference to its persistent version. We then get a 1210 Duplicate relationship reference
		//_pxyReceivalInfo.myReceivalRequestInfo := self.myReceivalRequestInfo.pxyCreateUpdateProxy();	// 13/12/2010 cnwmh5 #26556
		receivalRequest := self.myReceivalRequestInfo.pxyCreateUpdateProxy();
		receivalRequest.setGTEReceivalInfo(null);
		receivalRequest.setGTEReceivalInfo(_pxyReceivalInfo);
		// PAR #26929 end
	endif;

	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return _pxyReceivalInfo;
epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete _pxyReceivalInfo;
	endif;

end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="6f83a327-409a-43b1-a4a7-52c55bac6705">
        <updating/>
        <source>setForUpdate(_pxyGTEReceivalInfo: CM_GTEReceivalInfo; _parent: Any) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
24 February 2010	cnwjk3	Initial creation

*/

vars

begin
	inheritMethod(_pxyGTEReceivalInfo, _parent);
	if self.myReceivalRequestInfo &lt;&gt; null then
		self.myReceivalRequestInfo.setForUpdate(_pxyGTEReceivalInfo.myReceivalRequestInfo, self.myReceivalRequestInfo.myReceivalRequest);
	endif;

epilog

end;</source>
        <Parameter name="_pxyGTEReceivalInfo" type="CM_GTEReceivalInfo"/>
        <Parameter name="_parent" type="Any"/>
    </JadeMethod>
    <JadeMethod name="setParent" id="a39bfd1d-51c0-4b4d-96f5-588fcf85ba9e">
        <updating/>
        <source>setParent(_parent: CMGTE_ReceivalByType) updating;
//12 February 2010	cnwdw1	
//
vars

begin
	self.myGTEReceivalByType := _parent;
end;</source>
        <Parameter name="_parent" type="CMGTE_ReceivalByType"/>
    </JadeMethod>
