    <JadeMethod name="getDisplayStringForAttribute" id="9ef8e201-e976-40e8-b9c9-8235a022163a">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
// ---------------------------------------------------------------------------
// Created:     15 April 2014 by cnwdb2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 15 Apr 2014	cnwdb2		PAR #33977  
// ---------------------------------------------------------------------------


vars
	dac : CM_DataAccessController;
begin

	if _attrName = ETRow_NotAvailableForEntry then
		return self.isNotAvailableForEntry.String;
	elseif _attrName = ETRow_Debtor then
		if self.myDebtor &lt;&gt; null then
			return self.myDebtor.name;
		endif;
		return null;
	elseif _attrName = ETRow_DataAccessCarrier then
	
		dac := self.allDataAccessControllers[CM_Carrier.name];
		if dac &lt;&gt; null then
			return dac.name;
		endif;
		return "";
	
	elseif _attrName = ETRow_DataAccessOrganisation then
		dac := self.allDataAccessControllers[CM_Organisation.name] ; 
		if dac &lt;&gt; null then
			return dac.name ; 
		endif ; 
			return "" ;
	
	elseif _attrName = ETRow_DataAccessOperator then
		dac := self.allDataAccessControllers[CM_Operator.name] ; 
		if dac &lt;&gt; null then
			return dac.name  ;
		endif	;
		
		return "" ;
		
	elseif _attrName = ETRow_DataAccessConsignee then 
		dac := self.allDataAccessControllers[CM_ConsigneeConsignor.name] ; 
		if dac &lt;&gt; null then
			return dac.name ; 
		endif  ;
		return "" ; 

	elseif _attrName = ETRow_DataAccessCustomsAgent then 
		dac := self.allDataAccessControllers[CM_CustomsAgent.name] ; 
		if dac &lt;&gt; null then
			return dac.name ; 
		endif  ;
		return "" ; 
		
	elseif _attrName = ETRow_AvailForLabourRestrict then
			return self.isAvailableForLabourRestiction.String;
	endif ; 


	return inheritMethod(_attrName, _short);

epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="3118b264-12a6-4f90-b6b3-4308744d07e6">
        <source>pxyCreateUpdateProxy(): SelfType;

// 20/04/2011	cnwmh5		PAR #27401 - Add code to handle prossible exceptions occurring when
//							trying to create the proxy

vars
	tmpOrganisation : CM_Organisation;
	completedOK		: Boolean;
begin
	tmpOrganisation := inheritMethod();
	self.allDataAccessControllers.copy(tmpOrganisation.allDataAccessControllers);
	tmpOrganisation.myDebtor := self.myDebtor;
	
	self.allSelectedEmailAddresses.copy(tmpOrganisation.allSelectedEmailAddresses);		// cnwmc5 - 24 June 2016 - TFS 2204
	
	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return tmpOrganisation;
	
epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete tmpOrganisation;
	endif;	
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setDataAccessControllers" id="9c9f509f-65cd-43f9-b436-5fc349999dfc">
        <source>setDataAccessControllers(_isCreate : Boolean; dacs : CM_DataAccessControllerSet);
// ---------------------------------------------------------------------------
// Created:			04 April 2001 by cnwdwq1
// Purpose:			!     
// Parameters:	None
// Returns:			Nothing
// Changed On	Changed By		Reason
// ----------			----------			--------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	organisationDac,
	dac 			: CM_DataAccessController;
	user			: CM_User;
	organisation	: CM_Organisation;
	
begin
	self.allDataAccessControllers.clear;
	dacs.copy(self.allDataAccessControllers);

	// Added the below code to make sure that an organisations data access group contains the organisation itself.
	
	dac := self.allDataAccessControllers[CM_Organisation.name];
	
	if dac &lt;&gt; null and not dac.canAccess(self) then
		if _isCreate then
			dac.addObject(self);
			return;
		endif;
		app.raiseCMException2(Organ_data_acces_group_does_co, dac.name, self.name, null, null);
	endif;
	
	// Add organisation to users dataAccess if necessary.
	if _isCreate then
		user := app.getMyUser();
		if user &lt;&gt; null then
			organisation := user.myOrganisation;
			if organisation &lt;&gt; null then
				organisationDac := organisation.allDataAccessControllers[CM_Organisation.name];
				
				if organisationDac &lt;&gt; null and not organisationDac.canAccess(self) then
					organisationDac.addObject(self);
				endif;
			endif;
		endif;
	endif;
	

end;</source>
        <Parameter name="_isCreate" type="Boolean"/>
        <Parameter name="dacs" type="CM_DataAccessControllerSet"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="8e2044af-c1dd-4797-af4c-dbe1605ac647">
        <updating/>
        <source>setForCreate(_name : String; _logo : Binary; 
		_isNotAvailableForEntry : Boolean; 
		_isAvailableForLabourRestrict : Boolean;
		_emails : CM_EmailAddressByAddressDict;
		_root : CM_Root; _passport : CM_Passport) updating;
// ---------------------------------------------------------------------------
// Created:			05 April 2001 by cnwdwq1
// Purpose:			!     
// Parameters:	None
// Returns:			Nothing
// Changed On	Changed By		Reason
// ----------			----------			--------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	tmpDAC	: CM_DataAccessController;

begin
	self.name := _name;
	self.logo := _logo;
	self.isNotAvailableForEntry := _isNotAvailableForEntry;
	self.isAvailableForLabourRestiction := _isAvailableForLabourRestrict;
	
	//07 Jul 2015	NDL	Par 36588
	self.allSelectedEmailAddresses.clear;
	if _emails &lt;&gt; null and not _emails.isEmpty then
		_emails.copy(self.allSelectedEmailAddresses);
	endif; 
	
	self.myRoot := _root;

	tmpDAC := _passport.allDataAccessControllers[CM_Organisation.name];
	if tmpDAC &lt;&gt; null then
		tmpDAC.addObject(self);
	endif;
end;</source>
        <Parameter name="_name" type="String"/>
        <Parameter name="_logo" type="Binary"/>
        <Parameter name="_isNotAvailableForEntry" type="Boolean"/>
        <Parameter name="_isAvailableForLabourRestrict" type="Boolean"/>
        <Parameter name="_emails" type="CM_EmailAddressByAddressDict"/>
        <Parameter name="_root" type="CM_Root"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="06d36f7d-eaff-42e6-aa59-6716d0d3d724">
        <updating/>
        <source>setForUpdate(_logo : Binary;
				_isNotAvailableForEntry : Boolean;
				_isAvailableForLabourRestrict : Boolean;
				_debtor : CM_Debtor;
				_emails : CM_EmailAddressByAddressDict ) updating;
// ---------------------------------------------------------------------------
// Created:			05 April 2001 by cnwdwq1
// Purpose:			!     
// Parameters:	None
// Returns:			Nothing
// Changed On	Changed By		Reason
// ----------			----------			--------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	self.logo := _logo;
	self.isNotAvailableForEntry := _isNotAvailableForEntry;
	self.isAvailableForLabourRestiction := _isAvailableForLabourRestrict;
	self.myDebtor := _debtor;
	
	//07 Jul 2015	NDL	Par 36588
	self.allSelectedEmailAddresses.clear;
	if _emails &lt;&gt; null and not _emails.isEmpty then
		_emails.copy(self.allSelectedEmailAddresses);
	endif; 
	
end;</source>
        <Parameter name="_logo" type="Binary"/>
        <Parameter name="_isNotAvailableForEntry" type="Boolean"/>
        <Parameter name="_isAvailableForLabourRestrict" type="Boolean"/>
        <Parameter name="_debtor" type="CM_Debtor"/>
        <Parameter name="_emails" type="CM_EmailAddressByAddressDict"/>
    </JadeMethod>
