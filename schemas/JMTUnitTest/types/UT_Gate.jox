    <JadeMethod name="tReeferPackDetailsONPowerOff" id="ba1b4989-0bd0-407d-b9ec-27ce4390fd77">
        <source>tReeferPackDetailsONPowerOff();
/*

Purpose:			Testlink test 01-957

Date		Who		Reason
10 November 2016	cnwmk3	Initial creation

*/
constants
	TruckId					= "TRK957";
	ContId					= "CONTR957";
vars
	ti						: CM_TrackedItem;
	vvr						: CM_VehicleVisitRecord;
	ts						: TimeStamp;
	params					: CMIF_ConnectParams;
	powerPoint				: CM_GapController;
begin
	self.deleteContainer(ContId);
	self.deleteVehicle(TruckId);
	
	ts := app.cnGetServerTime();
	ts.setDate(ts.date - 1);
	self.opts.purge();
	self.opts.addAssoc("Temp", -18.Real);
	self.opts.addAssoc("PackTempC", -19);
	self.opts.addAssoc("PackSenderOffPowerDateTime", ts);
	self.opts.addAssoc("AllowableTimeOffPower", 0.01);
	self.opts.addAssoc("OnPowerDuringTransit", true);
	self.opts.addAssoc("TransitOnPowerDateTime", ts);
	self.opts.addAssoc("TransitOnPowerRemarks", "Check Power stays ON");
	vvr := self.gateInContainer(TruckId, ContId, "2231", "UTOP", "FZBF", self.getGate(self.getProfileSetting(UT_Profile.P_DGATE).asString()));
	self.assertEqual(app.myPassport.allWarnings.last.text, "Code :73022. Warning: Container CONTR957 is still connected to power.");
	self.workVehicle(vvr);
	self.roadExit(vvr);
	
	ti := self.getTrackedItem(ContId);
	self.assertFalse(ti.isConnected);
	self.assertEqual(ti.myReeferProperties.transitOnPowerDate, ts.date);
	self.assertEqual(ti.myReeferProperties.transitOnPowerTime, ts.time);
	self.assertEqual(ti.packTempC, "-19.0");
	self.assertEqual(ti.myReeferProperties.onPowerDuringTransit, true);
	self.assertEqual(ti.myReeferProperties.transitOnPowerRemarks, "Check Power stays ON");
	
	ts := app.cnGetServerTime();
	self.updateTIConnection(ti, true, false, ts, powerPoint);
	self.assertFalse(ti.isConnected);
	
	ts := app.cnGetServerTime();
	self.updateTIConnection(ti, true, true, ts, powerPoint);
	self.assertTrue(ti.isConnected);
	
	ts := app.cnGetServerTime();
	self.updateTIConnection(ti, true, false, ts, powerPoint);
	self.assertFalse(ti.isConnected);
	
	app.doWindowEvents(ti.getAllowableTimeOffPower.Integer);
	self.assertEqual(self.getTerminal().allSystemAlertsByDateTime.last.details.asStringJMT(), "Cargo CONTR957 has been off power for 0h 1m which has exceeded the maximum allowable time of . 
The Consignor is . The Commodity is Frozen Beef. 
Remarks : Created by unit test UT_Gate::tReeferPackDetailsONPowerOff");
	
	ts := app.cnGetServerTime();
	self.updateTIConnection(ti, true, true, ts, powerPoint);
	self.assertTrue(ti.isConnected);
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="tReleaseAndDeleteJob" id="b128f2ed-830c-423f-b68c-99b53f6bb7ea">
        <source>tReleaseAndDeleteJob();
// cnwdap1
//30 July 2009	cnwdw1	
// gate In comtainer thru to yard, release by id, then delete the road job PAR 27252
// Cancelled job should still create a Road Exit visit record  PAR 27472
vars
	truck: CM_Vehicle;
	ti: CM_TrackedItem;
	vvr: CM_VehicleVisitRecord;
	vvrDetail: CM_VehicleVisitRecordDetail;
	tx: CM_TITransaction;
	iter: Iterator;
	oldSecurityGate : Boolean;
	
begin
	oldSecurityGate := self.setTerminalConfig(SiteHasSecurityGate, false).Boolean;
	deleteContainer("UUT12345678");
	deleteVehicle("UTTRUCK");

	// First Gate In an Empty so we get Road Receival Txs
	vvr := gateInContainer("UTTRUCK", "UUT12345678", "2200", operator.code, "MT", dualGate);
		ti := self.getTrackedItem("UUT12345678");
		assertNotNull(ti);
		assertNotNull(ti.getPrimaryLocation(QUEUE_MODE));
		assertEqual(pin.myInTransitToLocation, vvr.vehicle.myPrimaryActualLocation);
		assertEqual(vvr.vehicle.allRoadJobs.size, 1);
		assertEqual(vvr.vehicle.allRoadJobs.first.workListEntries.size, 1);
		assertEqual(vvr.vehicle.allRoadJobs.first.workListEntries.first.status, JOB_UNACTIONED);

	self.moveVehicleToLane(vvr.vehicle, pin, 1);
		assertEqual(vvr.vehicle.myPrimaryActualLocation, self.getGateLane(pin, 1));
		
	self.moveVehicleToYard(vvr.vehicle);
		assertTrue(vvr.vehicle.myPrimaryActualLocation.isInterchangeAreaLocation);
		
	self.workVehicle(vvr);
		assertNotNull(ti.getPrimaryLocation(REAL_MODE));
		assertTrue(ti.getPrimaryLocation(REAL_MODE).isKindOf(CM_YardController));
		assertTrue(vvr.vehicle.myPrimaryActualLocation.isInterchangeAreaLocation);
		
	self.moveVehicleToLane(vvr.vehicle, pout, 1);
		assertEqual(vvr.vehicle.myPrimaryActualLocation, self.getGateLane(pout, 1));
		
	self.roadExit(vvr);
		assertNull(vvr.myRoadJob);
		assertEqual(vvr.status, CM_VehicleVisitRecord.Status_Complete);
		assertNull(vvr.vehicle.myPrimaryActualLocation);
		
   // Now Gate out the NT as a release		
	vvr := gateOutContainer("UTTRUCK", "", "UTDRIVER",ti.CM_Container, true, dualGate, null);
		assertEqual(vvr.myRoadJob.workListEntries.size, 1);
		assertEqual(vvr.myRoadJob.workListEntries.first.myTrackedItem,ti);
		
	// Delete the road job 
	self.deleteJobEntry(vvr.myRoadJob.workListEntries.first);
		self.assertEqual(vvr.status, CM_VehicleVisitRecord.Status_Cancelled);
		self.assertFalse(ti.isPreNote);	// PAR 23675
		// check that no txs have been deleted	
		foreach tx in ti.allTransactions do
			self.assertFalseMsg(tx.deleted, "Transaction has been deleted");
		endforeach;
		foreach vvrDetail in vvr.allVehicleVisitRecordDetails do
			self.logMessage(vvrDetail.recordTypeString &amp; " " &amp; vvrDetail.timeStart.getNumeralString);
		endforeach;
		iter := vvr.allVehicleVisitRecordDetails.createIterator;
		iter.back(vvrDetail);
		self.assertEqual(vvrDetail.recordType, VisitRecord_Complete_OutGate); // PAR 27472
		iter.back(vvrDetail);
		self.assertEqual(vvrDetail.recordType, VisitRecord_Cancel); // PAR 27472

epilog
	self.setTerminalConfig(SiteHasSecurityGate, oldSecurityGate);
	delete iter;
end;</source>
    </JadeMethod>
    <JadeMethod name="tReleaseBestPickBOL" id="b2fb6927-24bc-4a10-a5ba-04652c9171ea">
        <updating/>
        <source>tReleaseBestPickBOL() updating;
// cnwdap1
//30 July 2009	cnwdw1	
// 10 Sep 2019	cnwrs1	TFS 46030
//
constants
	FORKSTACK = "UFRKST";
vars
	voyage1: CM_Voyage;
	vessel: CM_Vessel; 
	bol: CM_BOL;
	slots : CM_SlotControllerArray;
	tmpLoadCC	: CMIF_LoadColorCode;
	voyageJob : CM_VoyageJob;
	dischargePort: CM_Port;
	destinationPort: CM_Port;
	craneName: String;
	cargo1, cargo2, cargo3, cargo4: CM_TrackedItem;
	fs1: CM_ForkLiftStack;
	wle: CM_WorkListEntry;
	ti: CM_TrackedItem;
	truck1, truck2: CM_Vehicle;
	vvr1, vvr2: CM_VehicleVisitRecord;
	mt: CM_Container;
	rr: CM_BulkRelease;
	request: CM_Request;
	isDoClearanceCheck : Boolean;
begin
	isDoClearanceCheck := self.getMyTerminal.myHarbour.isDoClearanceCheck;
	self.setHarbourIsDoClearanceCheck(false);
	dischargePort := app.myRoot.allPorts["NZAKL"];
	craneName := self.getProfileSetting(UT_Profile.P_CRANE).asString;

	self.deleteTerminalArea(FORKSTACK);

	fs1 := addForkLiftStack(FORKSTACK, 10, 5, 4);

	deleteVoyage("UTMTREL");
	deleteVessel("UTMTREL");
	vessel := addVesselCellular("UTMTREL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));
	voyage1 := addVoyageWithContainerStructur("UTMTREL", "UTMTREL", self.getProfileSetting(UT_Profile.P_OPERATOR).asString, self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString);
	destinationPort := app.myRoot.allPorts[voyage1.myTerminal.getConfig(PortDestCode).String];

	bol := self.addBOL("UBOL123", voyage1, self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString), "", self.getTerminal);
	
	self.deleteContainer("TEST0000001");
	self.deleteContainer("TEST0000002");
	self.deleteContainer("TEST0000003");
	self.deleteContainer("TEST0000004");
	create slots transient;
	self.getJobSlotControllers("UTMTREL","01",DeckOnDeck,1,1,4,slots);
	self.opts.addAssoc(UTTI_BOL, bol.number);
	cargo1 := self.addContainerAtLocnDisch("TEST0000001", "UT20", "GENL", TI_IMEX_STATUS_IMPORT, slots[1], destinationPort, voyage1);
	assertEqual(cargo1.billOfLading, bol.number);
	cargo2 := self.addContainerAtLocnDisch("TEST0000002", "UT20", "GENL", TI_IMEX_STATUS_IMPORT, slots[2], destinationPort, voyage1);
	assertEqual(cargo2.billOfLading, bol.number);
	cargo3 := self.addContainerAtLocnDisch("TEST0000003", "UT20", "GENL", TI_IMEX_STATUS_IMPORT, slots[3], destinationPort, voyage1);
	assertEqual(cargo3.billOfLading, bol.number);
	cargo4 := self.addContainerAtLocnDisch("TEST0000004", "UT20", "GENL", TI_IMEX_STATUS_IMPORT, slots[4], destinationPort, voyage1);
	assertEqual(cargo4.billOfLading, bol.number);
	
	self.voyageDischargeColourCode(voyage1);
	voyageJob:=self.addVoyageJob(voyage1,craneName,slots, true);
	assertTrueMsg(voyageJob &lt;&gt; null, "Voyage job not created");
	
	foreach request in voyageJob.allRequests do
		foreach wle in request.allWorkListEntries do
			self.movePlannedWLE(wle.myTrackedItem, fs1.allGridRows[1].allControllersByColumn[1], wle);
		endforeach;
	endforeach;
	assertTrue(cargo1.getFutureMovePlanned(false) &lt;&gt; null);
	assertTrue(cargo2.getFutureMovePlanned(false) &lt;&gt; null);
	assertTrue(cargo3.getFutureMovePlanned(false) &lt;&gt; null);
	assertTrue(cargo4.getFutureMovePlanned(false) &lt;&gt; null);
	
	self.moveAllCargoOnVoyage(voyage1, REAL_MODE);
	
	self.deleteReleaseRequest("UTMREL_RR");
	self.opts.addAssoc("FullRelease", true);
	self.opts.addAssoc("BOL", bol);
	//self.opts.addAssoc("TerminalArea", fs1);
	self.opts.addAssoc("ISOType", "UT20");
	self.opts.addAssoc("BestPick", true);
	self.opts.addAssoc("Voyage", voyage1);
	self.opts.addAssoc("Number", 5);
	rr := self.addReleaseByTypeRequestOpts("UTMREL_RR", BR_TYPE_ROAD, TI_CargoType_Container);
	assertEqual(rr.allReserveDetails.size, 1);
	assertEqual(rr.allReserveDetails.first.CM_ReserveSelection.myBOLIn, bol);
	assertTrue(rr.allReserveDetails.first.CM_ReserveSelection.bestPick);
	assertTrue(rr.fullRelease);
	
	deleteVehicle("UTTRUCK1");
	deleteVehicle("UTTRUCK2");
	
	opts.addAssociation("CENum", "UUU");
	self.deleteStops(cargo1);
	self.deleteStops(cargo2);
	self.deleteStops(cargo3);
	self.deleteStops(cargo4);
	
	// Work Trucks individually
	// Gate out First cargo
	opts.purge;
	opts.addAssociation("release", rr);
	vvr1 := gateOutContainer("UTTRUCK1", "", "UTDRIVER1", mt, false, dualGate, null);
		assertEqual(vvr1.allGateEntities.first.CMGTE_Release.billOfLading, bol.number);
		assertEqual(vvr1.myRoadJob.workListEntries.size, 1); 
		assertTrue(vvr1.myRoadJob.workListEntries.first.isBestPick);
		assertNotNull(vvr1.myRoadJob.workListEntries.first.myRequest.getBOL);
		assertEqual(vvr1.myRoadJob.workListEntries.first.myTrackedItem, cargo4);

	self.workVehicle(vvr1);
	
	self.roadExit(vvr1);
		self.assertEqual(vvr1.status, CM_VehicleVisitRecord.Status_Complete);

	// Gate out 2nd cargo
	vvr1 := gateOutContainer("UTTRUCK1", "", "UTDRIVER1", mt, false, dualGate, null);
		assertEqual(vvr1.allGateEntities.first.CMGTE_Release.billOfLading, bol.number);
		assertEqual(vvr1.myRoadJob.workListEntries.size, 1); 
		assertTrue(vvr1.myRoadJob.workListEntries.first.isBestPick);
		assertNotNull(vvr1.myRoadJob.workListEntries.first.myRequest.getBOL);
		assertEqual(vvr1.myRoadJob.workListEntries.first.myTrackedItem, cargo3);

	self.workVehicle(vvr1);
	
	self.roadExit(vvr1);
		self.assertEqual(vvr1.status, CM_VehicleVisitRecord.Status_Complete);

	// Try working two trucks at the same time
	// Gate out 3rd Cargo	
	vvr1 := gateOutContainer("UTTRUCK1", "", "UTDRIVER1", mt, false, dualGate, null);
		assertEqual(vvr1.allGateEntities.first.CMGTE_Release.billOfLading, bol.number);
		assertEqual(vvr1.myRoadJob.workListEntries.size, 1); 
		assertTrue(vvr1.myRoadJob.workListEntries.first.isBestPick);
		assertNotNull(vvr1.myRoadJob.workListEntries.first.myRequest.getBOL);
		assertEqual(vvr1.myRoadJob.workListEntries.first.myTrackedItem, cargo2);

	// Gate out 4th cargo 
	vvr2 := gateOutContainer("UTTRUCK2", "", "UTDRIVER2", mt, false, dualGate, null);
		assertEqual(vvr2.allGateEntities.first.CMGTE_Release.billOfLading, bol.number);
		assertEqual(vvr2.myRoadJob.workListEntries.size, 1); 
		assertTrue(vvr2.myRoadJob.workListEntries.first.isBestPick);
		assertNotNull(vvr2.myRoadJob.workListEntries.first.myRequest.getBOL);
		assertEqual(vvr2.myRoadJob.workListEntries.first.myTrackedItem, cargo1);

	self.workVehicle(vvr1);
	self.workVehicle(vvr2);
	
	self.roadExit(vvr1);
		self.assertEqual(vvr1.status, CM_VehicleVisitRecord.Status_Complete);
	self.roadExit(vvr2);
		self.assertEqual(vvr2.status, CM_VehicleVisitRecord.Status_Complete);
		

	// tests Par 26863
	vvr1 := gateOutContainer("UTTRUCK1", "", "UTDRIVER1", mt, false, dualGate, null);
		self.assertEqual(vvr1.myRoadJob.workListEntries.size, 1); 
	ti := app.sourceTisForRequestBestPick(	self.getTerminal,	//_terminal : CM_Terminal;
											vvr1.myRoadJob.workListEntries.first,	//_wle : CM_WorkListEntry;
											null,	//_terminalArea : CM_TerminalArea;
											true,	//_scanTerminal : Boolean
											null);
		self.assertEqual(ti, null);
											
	//self.assertTrue(rr.isComplete);
epilog
	self.setHarbourIsDoClearanceCheck(isDoClearanceCheck);
	delete slots;
end;</source>
    </JadeMethod>
    <JadeMethod name="tReleaseBestPickImport" id="5ec85b83-7a46-42dc-933d-e00a25c0499c">
        <updating/>
        <source>tReleaseBestPickImport() updating;
// cnwdap1
//30 July 2009	cnwdw1	
// 10 Sep 2019	cnwrs1	TFS 46030
//23/06/2023	navkc1	CR 58406 Task 58408: Jade - Release Request All Tracked Items
//
constants
	FORKSTACK = "UFRKST";
vars
	voyage1: CM_Voyage;
	vessel: CM_Vessel; 
	slots : CM_SlotControllerArray;
	tmpLoadCC	: CMIF_LoadColorCode;
	voyageJob : CM_VoyageJob;
	dischargePort: CM_Port;
	destinationPort: CM_Port;
	craneName: String;
	cargo1, cargo2: CM_TrackedItem;
	fs1: CM_ForkLiftStack;
	wle: CM_WorkListEntry;
	cargos: CM_TISet;
	ti: CM_TrackedItem;
	truck: CM_Vehicle;
	vvr: CM_VehicleVisitRecord;
	mt: CM_Container;
	rr: CM_BulkRelease;
	request: CM_Request;
	isDoClearanceCheck : Boolean;
	allTis : CM_TISet;
	firstTi : CM_TrackedItem;
begin
	
	create allTis transient;
	
	isDoClearanceCheck := self.getMyTerminal.myHarbour.isDoClearanceCheck;
	self.setHarbourIsDoClearanceCheck(false);
	dischargePort := app.myRoot.allPorts["NZAKL"];
	craneName := self.getProfileSetting(UT_Profile.P_CRANE).asString;

	self.deleteTerminalArea(FORKSTACK);
	fs1 := addForkLiftStack(FORKSTACK, 10, 5, 3);

	deleteVoyage("UTMTREL");
	deleteVessel("UTMTREL");
	vessel := addVesselCellular("UTMTREL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));
	voyage1 := addVoyageWithContainerStructur("UTMTREL", "UTMTREL", self.getProfileSetting(UT_Profile.P_OPERATOR).asString, self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString);
	destinationPort := app.myRoot.allPorts[voyage1.myTerminal.getConfig(PortDestCode).String];

	self.deleteContainer("TEST0000001");
	self.deleteContainer("TEST0000002");
	create slots transient;
	self.getJobSlotControllers("UTMTREL","01",DeckOnDeck,1,1,2,slots);
	cargo1 := self.addContainerAtLocnDisch("TEST0000001", "2200", "GENL", TI_IMEX_STATUS_IMPORT, slots[1], destinationPort, voyage1);
	cargo2 := self.addContainerAtLocnDisch("TEST0000002", "2200", "GENL", TI_IMEX_STATUS_IMPORT, slots[2], destinationPort, voyage1);
	self.voyageDischargeColourCode(voyage1);
	voyageJob:=self.addVoyageJob(voyage1,craneName,slots, true);
	assertTrueMsg(voyageJob &lt;&gt; null, "Voyage job not created");
	
	foreach request in voyageJob.allRequests do
		foreach wle in request.allWorkListEntries do
			self.movePlannedWLE(wle.myTrackedItem, fs1.allGridRows[1].allControllersByColumn[1], wle);
		endforeach;
	endforeach;
	assertTrue(cargo1.getFutureMovePlanned(false) &lt;&gt; null);
	assertTrue(cargo2.getFutureMovePlanned(false) &lt;&gt; null);
	
	self.moveAllCargoOnVoyage(voyage1, REAL_MODE);
	
	self.deleteReleaseRequest("UTMREL_RR");
	opts.addAssociation("FullRelease", true);
	create cargos transient;
	cargos.add(cargo1);
	cargos.add(cargo2);
	rr := self.addReleaseById("UTMREL_RR", BR_TYPE_ROAD, cargos);
	assertEqual(rr.allReserveDetails.size, 2);
	assertTrue(rr.fullRelease);
	rr.allReserveDetails.first.CM_ReserveTI.getAllTrackedItems(allTis, false); //23/06/2023	navkc1	CR 58406 Task 58408
	firstTi := allTis.first(); //23/06/2023	navkc1	CR 58406 Task 58408
	assertEqual(allTis.size, 1);
	assertEqual(firstTi, cargo1);
	
	rr.allReserveDetails.last.CM_ReserveTI.getAllTrackedItems(allTis, false); //23/06/2023	navkc1	CR 58406 Task 58408
	firstTi := allTis.first(); //23/06/2023	navkc1	CR 58406 Task 58408
	assertEqual(allTis.size, 1);
	assertEqual(firstTi, cargo2);
	
	deleteVehicle("UTTRUCK");
	
	opts.addAssociation("CENum", "UUU");
	self.deleteStops(cargo1);
	self.deleteStops(cargo2);
	
	opts.addAssociation("release", rr);
	opts.addAssociation("BestPick", true);
	vvr := gateOutContainer("UTTRUCK", "", "UTDRIVER", mt, false, dualGate, null);
		assertEqual(vvr.myRoadJob.workListEntries.size, 1); 
		assertEqual(vvr.myRoadJob.workListEntries.first.myTrackedItem, cargo2);
		
	self.workVehicle(vvr);
	
	self.roadExit(vvr);
	
	rr.allReserveDetails.first.CM_ReserveTI.getAllTrackedItems(allTis, false); //23/06/2023	navkc1	CR 58406 Task 58408
	firstTi := allTis.first(); //23/06/2023	navkc1	CR 58406 Task 58408
	assertEqual(allTis.size, 1);
	assertEqual(firstTi, cargo1);
	assertEqual(rr.allReserveDetails.first.CM_ReserveTI.allTrackedItemsReleased.size, 0);
	
	rr.allReserveDetails.last.CM_ReserveTI.getAllTrackedItems(allTis, false); //23/06/2023	navkc1	CR 58406 Task 58408
	assertEqual(allTis.size, 0);
	assertEqual(rr.allReserveDetails.last.CM_ReserveTI.allTrackedItemsReleased.size, 1);
	assertEqual(rr.allReserveDetails.last.CM_ReserveTI.allTrackedItemsReleased.first, cargo2);


	vvr := gateOutContainer("UTTRUCK", "", "UTDRIVER", mt, false, dualGate, null);
		assertEqual(vvr.myRoadJob.workListEntries.size, 1); 
		assertEqual(vvr.myRoadJob.workListEntries.first.myTrackedItem, cargo1);
		
	self.workVehicle(vvr);
	
	self.roadExit(vvr);
	
	rr.allReserveDetails.first.CM_ReserveTI.getAllTrackedItems(allTis, false); //23/06/2023	navkc1	CR 58406 Task 58408
	assertEqual(allTis.size, 0);
	assertEqual(rr.allReserveDetails.first.CM_ReserveTI.allTrackedItemsReleased.size, 1);
	assertEqual(rr.allReserveDetails.first.CM_ReserveTI.allTrackedItemsReleased.first, cargo1);

	rr.allReserveDetails.last.CM_ReserveTI.getAllTrackedItems(allTis, false); //23/06/2023	navkc1	CR 58406 Task 58408
	assertEqual(allTis.size, 0);
	assertEqual(rr.allReserveDetails.last.CM_ReserveTI.allTrackedItemsReleased.size, 1);
	assertEqual(rr.allReserveDetails.last.CM_ReserveTI.allTrackedItemsReleased.first, cargo2);
epilog
	self.setHarbourIsDoClearanceCheck(isDoClearanceCheck);
	delete slots;
	delete cargos;
	delete allTis;
end;
</source>
    </JadeMethod>
    <JadeMethod name="tReleaseBestPickWithTA" id="25f05a77-fd83-4b32-adac-43987cb3c503">
        <source>tReleaseBestPickWithTA();
/*

Purpose:			This unit test check whether the Best Pick for Source TA is returning the location correctly when user has specified Terminal Area and Row/Column
					*Gridded Block Stack*
Parameters:			

Return Value:		

Date		Who		Reason
28/10/2025	navkc1 JIRA 36411 MTN - Selecting certain columns of a gridded block stack not working as expected

*/

constants
	UTTAID		= "UTBPBS1";
	TRUCKID		= "UTBPBSTRUCK";
	TIID1		= "UTBPCONT1";
	TIID2		= "UTBPCONT2";
	UTRELREQ	= "UTBPREL1";
	
vars
	testTi,
	ti1,
	ti2			: CM_TrackedItem;
	tagbs		: CM_TerminalArea;
	relReq		: CM_BulkRelease;
	operator	: CM_Operator;
	loc1,
	loc2		: CM_LocationsController;
	gate		: CM_Gate;
	vvr			: CM_VehicleVisitRecord;

begin
	
	// Get Operator;
		operator := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);
	
	// Get Gate
		gate := self.getGate(self.getProfileSetting(UT_Profile.P_SGATE).asString);
	
	// Do best pick for source
		self.setTerminalConfig(GateBestPickForSource, true);
	
	// Delete existing TI
		ti1 := self.getTrackedItem(TIID1);
		if ti1 &lt;&gt; null then
			self.deleteTrackedItem(ti1, true);
		endif;
		
		ti2 := self.getTrackedItem(TIID2);
		if ti2 &lt;&gt; null then
			self.deleteTrackedItem(ti2, true);
		endif;
		
	// Delete existing terminal area
		tagbs := self.getTerminalArea(UTTAID);
		
		if tagbs &lt;&gt; null then
			self.deleteTerminalArea(UTTAID);
		endif;
	
	// Create Terminal Area
		tagbs := self.addForkLiftStack(UTTAID, 1, 5, 2);
		loc1 := tagbs.CM_ForkLiftStack.allGridControllersByRowColumn[1, 4];
		loc2 := tagbs.CM_ForkLiftStack.allGridControllersByRowColumn[1, 5];
		
		self.assertNotNullMsg(loc1, "Failed to get the location for TI 1");
		self.assertNotNullMsg(loc2, "Failed to get the location for TI 2");
		
	// Create TI
		ti1 := self.createContainer(TIID1, "2200", null, operator, false);
		self.assertNotNullMsg(ti1, "Failed to create Container 1");
		
		ti2 := self.createContainer(TIID2, "2200", null, operator, false);
		self.assertNotNullMsg(ti2, "Failed to create Container 2");
		
	// Change to Import for testing
		self.editIMEXStatus(ti1, TI_IMEX_STATUS_IMPORT, true);
		self.editIMEXStatus(ti2, TI_IMEX_STATUS_IMPORT, true);
		
	// Move TI to location
		self.moveCargo(ti1, null, loc1, app.myPassport);
		self.moveCargo(ti2, null, loc2, app.myPassport);
	
	// Gate out container
		self.deleteVehicle(TRUCKID);
		self.opts.purge();
		self.opts.addAssoc("ISOType", "2200");
		self.opts.addAssoc("FullRelease", true);
		self.opts.addAssoc("ReleaseByType", true);
		self.opts.addAssoc("OperatorCode", operator.code);
		self.opts.addAssoc("SourceTA", loc2.CM_GridController.getMyGridArea());			// Set to expect TI2
		self.opts.addAssoc("SourceGrid", loc2.CM_GridController.myGridColumn);			// Set to expect TI2
		vvr := self.gateOutContainer(TRUCKID, null, TRUCKID, null, false, gate, null);
		self.assertNotNullMsg(vvr.myRoadJob.workListEntries.first, "Failed to get the WLE of the road job");
		
	// Test the best pick
		testTi := app.sourceTisForRequestBestPick(self.getTerminal(), vvr.myRoadJob.workListEntries.first, null, true, null);
		self.assertEqualMsg(testTi, ti2, "Best pick TI is not TI2. Expecting TI2 because we have specified the location of TI2");
epilog
	if ti1 &lt;&gt; null then
		self.deleteTrackedItem(ti1, true);
	endif;
	
	ti2 := self.getTrackedItem(TIID2);
	if ti2 &lt;&gt; null then
		self.deleteTrackedItem(ti2, true);
	endif;
	
	self.deleteTerminalArea(UTTAID);
end;</source>
    </JadeMethod>
    <JadeMethod name="tReleaseByIDTruckSwap" id="980fe141-4ac5-401f-a68c-6cd764618a31">
        <source>tReleaseByIDTruckSwap();
// cnwdap1
//cnwrd1
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
12 November 2013	cnwrd1	Initial creation

*/
constants
	Truck1 = 'UTTRUCK1';
	Truck2 = 'UTTRUCK2';
	Container1ID = 'UUT12345678';
	Container2ID = 'UUT12345679';
vars
	ti: CM_TrackedItem;
	truck1, 
	truck2	: CM_Vehicle;
	vvr1,
	vvr2	: CM_VehicleVisitRecord;
	mt1,
	mt2 : CM_Container;
	job1,
	job2 : CM_RoadJob;
	wle1,
	wle2 	:CM_WorkListEntry;
begin
	deleteContainer(Container1ID);
	deleteContainer(Container2ID);
	deleteVehicle(Truck1);
	deleteVehicle(Truck2);
	
	mt1 := self.addContainer(Container1ID, self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString),"2200", "MT", TI_IMEX_STATUS_STORAGE).CM_Container;
	mt2 := self.addContainer(Container2ID, self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString),"2200", "MT", TI_IMEX_STATUS_STORAGE).CM_Container;
	
	self.move(mt1, bs.myLocationsController);
	self.move(mt2, bs.myLocationsController);
	
	vvr1 := gateOutContainer(Truck1, "", "UTDRIVER1", mt1, true, dualGate, null);
	vvr2 := gateOutContainer(Truck2, "", "UTDRIVER2", mt2, true, dualGate, null);
	
	truck1 := self.getVehicle(Truck1);
	self.assertTrueMsg(truck1 &lt;&gt; null, "Can't find the truck.");
	self.assertTrueMsg(truck1.allRoadJobs.size = 1, "Wrong number of jobs on the truck.");
	
	truck2 := self.getVehicle(Truck2);
	self.assertTrueMsg(truck2 &lt;&gt; null, "Can't find the truck.");
	self.assertTrueMsg(truck2.allRoadJobs.size = 1, "Wrong number of jobs on the truck.");
		
	job1 := truck1.allRoadJobs.first.CM_RoadJob;
	self.assertTrueMsg(job1 &lt;&gt; null, "Can't find the job.");
	self.assertTrueMsg(job1.workListEntries.size = 1, "Wrong number of wles on the job.");
	
	job2 := truck1.allRoadJobs.first.CM_RoadJob;
	self.assertTrueMsg(job2 &lt;&gt; null, "Can't find the job.");
	self.assertTrueMsg(job2.workListEntries.size = 1, "Wrong number of wles on the job.");
	
	wle1 := truck1.allRoadJobs.first.workListEntries.first;
	self.assertTrueMsg(wle1 &lt;&gt; null, "Can't find the wle.");

	wle2 := truck2.allRoadJobs.first.workListEntries.first;
	self.assertTrueMsg(wle2 &lt;&gt; null, "Can't find the wle.");
	

	self.assertTrue( vvr2.allReleasedTrackedItems.includes(mt2));
	self.assertTrue( vvr1.allReleasedTrackedItems.includes(mt1));

	app.myTrxUA.trxSwapTruckTasks(wle1, wle2, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
	// at this point wle1 should be on truck 2 &amp; VV
	self.assertEqual(wle1.job.CM_RoadJob.myVehicle, truck2);
	self.assertEqual(wle2.job.CM_RoadJob.myVehicle, truck1);

	self.workVehicle(vvr1);	
	self.roadExit(vvr1);
	
	self.workVehicle(vvr2);	
	self.roadExit(vvr2);
	
	self.assertTrue( vvr2.allReleasedTrackedItems.includes(mt1));
	self.assertTrue( vvr1.allReleasedTrackedItems.includes(mt2));
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="tReleaseByTypeAreaOStow1" id="be2b5b3f-3017-46ad-93b4-39b051496bec">
        <source>tReleaseByTypeAreaOStow1();
// cnwmp6
/* cnwjre1
	release by type from nominated area, several candidates, should choose the least-overstowed (which is not actually overstowed)
*/
vars
	taSource: CM_ForkLiftStack;
	ti, nextTI, osTI: CM_TrackedItem;
	releaseRequest: CM_BulkRelease;
	truck: CM_Vehicle;
	vvr: CM_VehicleVisitRecord;

begin

	deleteVehicle("UTTRUCK");
	deleteTerminalArea("UTFORK");
	taSource:= self.addForkLiftStack("UTFORK", 6, 5, 2);
	assertNotNullMsg(taSource, "UTFORK");
	
	self.deleteContainer("TEST0000011");
	self.deleteContainer("TEST0000002");
	self.deleteContainer("TEST0000003");

	// add as STORAGE so the best pick will find them
	self.opts.addAssoc("IMEX", TI_IMEX_STATUS_STORAGE);
	ti := self.addContainerOpts("TEST0000011", "2200", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));
	assertNotNullMsg(ti, "TEST0000011");
	self.move(ti ,taSource.allGridControllersByRowColumn[2, 3]);
	self.assertEqualMsg(ti.myPrimaryActualLocation, taSource.allGridControllersByRowColumn[2, 3], "Did not move TEST0000011 to correct location");
	
	osTI:= self.addContainerOpts("TEST0000002", "2200", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));
	assertNotNullMsg(osTI, "TEST0000002");
	self.move(osTI ,taSource.allGridControllersByRowColumn[2, 3]);
	self.assertEqualMsg(osTI.myPrimaryActualLocation, taSource.allGridControllersByRowColumn[2, 3], "Did not move TEST0000002 to correct location");
	
	//more overstowed cargo
	nextTI:= self.addContainerOpts("TEST0000003", "2200", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));
	assertNotNullMsg(nextTI, "TEST0000003");
	self.move(nextTI ,taSource.allGridControllersByRowColumn[1, 3]);
	self.assertEqualMsg(nextTI.myPrimaryActualLocation, taSource.allGridControllersByRowColumn[1, 3], "Did not move TEST0000003 to correct location");
	
	// Remove all automatic stops
	self.opts.purge;
	self.opts.addAssoc("CENum", "123");
	self.deleteStops(ti);
	self.deleteStops(osTI);
	self.deleteStops(nextTI);

	// Create the Release, looking for the least-overstowed full 2200
	self.opts.purge;
	self.opts.addAssoc("ISOType", "2200");
	self.opts.addAssoc("FullRelease", true);
	releaseRequest := addReleaseByTypeRequestOpts("UTRRRoad", BR_TYPE_ROAD, TI_CargoType_Container);
	assertNotNull(releaseRequest);
	
	// Gate Out
	self.opts.purge;
	self.opts.addAssoc("release", releaseRequest);
	self.opts.addAssoc("BestPick", true);
	vvr := self.gateOutContainer("UTTRUCK", "", "UTDRIVER", null, true, singleGate , taSource.id);
	
	truck := self.getVehicle("UTTRUCK");
	assertEqual(truck.allRoadJobs.size, 1);
	assertEqual(truck.allRoadJobs.first.workListEntries.size, 1);
	assertEqual(truck.allRoadJobs.first.workListEntries.first.getRTLetter(), "Q".String);
	// check that the non-overstowed tracked item has been chosen
	assertEqual(truck.allRoadJobs.first.workListEntries.first.allRTQueueEntries.first.allTasks.first.ti.id, osTI.id);

	self.workVehicle(vvr);
	
	self.roadExit(vvr);

epilog
	
end;</source>
    </JadeMethod>
    <JadeMethod name="tReleaseByTypeAreaOStow2" id="50421cd4-bf40-492c-9187-c3cc81f8dbd8">
        <source>tReleaseByTypeAreaOStow2();
// cnwmp6
/* cnwjre1
	release by type from nominated area, two candidates, should choose the least-overstowed (which actually is overstowed)
*/
vars
	taSource: CM_ForkLiftStack;
	ti, nextTI, osTI: CM_TrackedItem;
	releaseRequest: CM_BulkRelease;
	truck: CM_Vehicle;
	vvr: CM_VehicleVisitRecord;

begin
