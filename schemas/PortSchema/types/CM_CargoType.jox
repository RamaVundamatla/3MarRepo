    <JadeMethod name="getYADisplay" id="63b7fc84-711d-45bb-bfd8-70db763c92c1">
        <source>getYADisplay(): String;
// --------------------------------------------------------------------------------
// Created:		08 March 2005 by cnwdad1:2
//
// Purpose:		Refer to superclass implementation.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 30/11/2009	cnwmh5		PAR 21660 - Filter hout not available for entry and
//							not in terminal
// 08/05/2020	jlgdap1		TFS 49252 CPL Cargo Types not showing in System Admin
// --------------------------------------------------------------------------------
begin

	// 30/11/2009 cnwmh5 #21660 - Start
	if app.myPassport.myTerminal &lt;&gt; null and not self.allTerminals.includes(app.myPassport.myTerminal) then
		return null;
	endif;
	
	if self.isNotAvailableForEntry then
		return null;
	endif;
	// 30/11/2009 cnwmh5 #21660 - End
	
	if self.id &gt; TI_CargoBOLType_JMTMax and not app.myRoot.isClientCentrePort then	// TFS 49252
		return null;																// TFS 49252
	endif;																			// TFS 49252
	
	return self.abbreviation &amp; Tab &amp; self.description;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
