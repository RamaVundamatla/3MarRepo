    <JadeMethod name="getSelectableSealTypes" id="b36811e2-3ed5-43fe-9fc6-c26d84e7d4ca">
        <source>getSelectableSealTypes( _allSealTypes : CM_SealTypeSet input );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 March 2015	cnwndl1	Initial creation	Par 35828

*/

vars

	sealType : CM_SealType;

begin

	if _allSealTypes = null then
		return;
	endif;

	foreach sealType in self.allSelectedSealTypes do
		if sealType.notAvailableForEntry then
			continue;
		endif;
		_allSealTypes.add( sealType );
	endforeach;

epilog

end;</source>
        <Parameter name="_allSealTypes" type="CM_SealTypeSet" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getWagonSealTypesString" id="a80928df-d609-4579-9dab-fe7664d583cb">
        <source>getWagonSealTypesString():String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 March 2015	cnwndl1	Initial creation	Par 35828

*/

vars

	str : String;
	sealType : CM_SealType;

begin

	foreach sealType in self.allSelectedSealTypes do
		if str &lt;&gt; null then
			str := str &amp; ", ";
		endif;
		str := str &amp; sealType.sealType;
	endforeach;
	
	return str;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getWagonTypeString" id="8cf1c28e-7349-421a-9f66-83e50ded965d">
        <source>getWagonTypeString():String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 March 2013	cnwndl1	Initial creation	Par 31278

*/

vars

begin

	if self.isBoxcar then
		return app.getErrorString(Boxcar);
	elseif self.isFlatcar then
		return app.getErrorString(Flatcar);
	elseif self.isWellcar then
		return app.getErrorString(Wellcar);	//Par 35346 / CCMS 1408
	elseif self.isSkeletonCar then
		return app.getErrorString(Skeleton);	// TFS 2533
	else
		return null;
	endif;

epilog

end;</source>
        <ReturnType type="String"/>
