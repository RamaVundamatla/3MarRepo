    <JadeMethod name="addToExistingBOLIn" id="9ddbfd52-f5d5-4900-b721-22c6968a096a">
        <updating/>
        <source>addToExistingBOLIn(_bolNumber : String) updating, protected;
// cnwrs1 PAR14286 June 2007 to allow Centreport to keep the Billoflading in step with the myReceivalBOL.number
// it is assumed that myVoyage are not null
vars
	bolIn : CM_BOLIn;
	intFaceBOLIn : CMIF_BOLIn;
	control : CMIF_TIUpdateController;
begin
	//NOTE:  Superclass implementation is slightly different, checking for the terminal config flag.
	//This has been maintained like this for CentrePort's benefit and remains as it was originally implemented for 
	//cars.
	if not self.getCreateBOL then //CCMS 1100 Mar 2008 cnwrs1
		return;
	endif;
	if self.billOfLading = _bolNumber then 
		return;
	endif;

	bolIn := self.myVoyage.doesBOLAlreadyExist(_bolNumber); // PAR  16180
	if bolIn = null then
		// create a new bol and shift us to that bolIn
		create intFaceBOLIn transient;
		intFaceBOLIn.bolNumber := _bolNumber;
		intFaceBOLIn.bolType := BOLType_GeneralBillOfLading;
		intFaceBOLIn.myTerminal := self.myTerminal;
		intFaceBOLIn.myVoyage := self.myVoyage;
		intFaceBOLIn.operatorCode := self.operatorCode;
		intFaceBOLIn.myOperator := app.myRoot.allOperators[self.operatorCode];
		intFaceBOLIn.transportMode := TI_TRANSMODE_SHIP;
		intFaceBOLIn.headerOnly := true;
		intFaceBOLIn.mySubTerminal := self.mySubTerminal; //par 20074 cnwrs1 June 2009
		create control transient; //par 20074 cnwrs1 June 2009
		control.setMyUserObject(self);
		app.myUtilityCA.utlCreateBOLInWithTIs(intFaceBOLIn, bolIn, control, app.myPassport);
		if not app.myPassport.checkValidation() then
			return;
		endif;
		// PAR 23147 - now retuurn the BOL from the utl above
		//bolIn := self.myVoyage.allBOLInByTypeStatusNumDT.getAtKeyGeq(BOLType_GeneralBillOfLading, BOL_STATUS_NORMAL, _bolNumber, null);
		//if bolIn.number &lt;&gt; _bolNumber then
		//	bolIn := null;
		//endif;
	endif;
	if bolIn = null then
		app.raiseCMException1(ERR_NO_OBJECT, "No BOL Object", null, null);
		return;
	endif;
	self.myReceivalBOL := bolIn;
	//29 Jan 2013	NDL	Par 31102
	if bolIn &lt;&gt; null then
		self.setDirectDelivery( bolIn.directDelivery, true );
	endif;
epilog
	delete intFaceBOLIn;
	delete control;
end;

</source>
        <access>protected</access>
        <Parameter name="_bolNumber" type="String"/>
    </JadeMethod>
    <JadeMethod name="billOfLading" id="9bda4ce6-fe93-42f1-b902-bf237f7c96d2">
        <methodInvocation>mapping</methodInvocation>
        <updating/>
        <source>billOfLading(_set : Boolean; _value : String io) mapping, updating;
// cnwrs1 PAR dec 2006 to allow Centreport to keep the Billoflading in step with the myReceivalBOL.number

vars

begin
	if _set then
		if self.myReceivalBOL &lt;&gt; null and //removed cnwrs1 June 2007 par 14286
		   self.myVoyage &lt;&gt; null and
		   not self.isTransient() then
			self.updateBOLNumber(_value);
		elseif self.myReceivalBOL = null and //removed cnwrs1 June 2007 par 14286
		   self.myVoyage &lt;&gt; null and
		   not self.isTransient() then
			self.addToExistingBOLIn(_value);
		endif;
		self.billOfLading := _value;
	endif;
end;
</source>
        <Parameter name="_set" type="Boolean"/>
        <Parameter name="_value" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="create" id="7968f245-56ed-48cf-9b54-cc411b85a6b9">
        <updating/>
        <source>create() updating;
// ---------------------------------------------------------------------------
// Created:     10 September 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	self.cargoType		:= TI_CargoType_Car;
	//self.volume			:= NULL_VOLUME;
	self.setMyTotalVolume(NULL_VOLUME);	// cnwdw1 27868
	self.hasRadio := UnknownRadio;

end;</source>
    </JadeMethod>
    <JadeMethod name="erase" id="291e2f51-e5de-49d3-a326-e195ef65cbb5">
        <updating/>
        <source>erase(_eraseLevel: Integer) updating;

vars

begin
	if self.myReceivalBOL &lt;&gt; null and
	   self.myReceivalBOL.allTrackedItems.size = 1 and
	   self.myReceivalBOL.allTrackedItems.includes(self) then
		self.myReceivalBOL.erase(_eraseLevel);
		self.myReceivalBOL := null;
	endif;
	if self.myReleaseBOL &lt;&gt; null and
	   self.myReleaseBOL.allTrackedItems.size = 1 and
	   self.myReleaseBOL.allTrackedItems.includes(self) then
		self.myReleaseBOL.erase(_eraseLevel);
		self.myReleaseBOL := null;
	endif;
	inheritMethod(_eraseLevel);
end;</source>
        <Parameter name="_eraseLevel" type="Integer"/>
    </JadeMethod>
