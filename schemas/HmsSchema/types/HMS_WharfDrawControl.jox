    <JadeMethod name="scrollControl" id="a198b189-99a5-4ed6-ab62-bf2d17aa7177">
        <source>scrollControl(pDirection: Integer; pValue: Integer);
//--------------------------------------------------
// Created:	09 August 2004 By: cnwgd1
//--------------------------------------------------
vars
	tmpValue : Integer;
begin
	if pDirection = ScrollBar_Horizontal then
		return;
	else
		//Scrolling vertically
		if self.myScrollableLabelFrame.visible and (not self.myScrollableFrame.hLabelsAlignBottom) then
			tmpValue := self.myScrollableLabelFrame.height.Integer;
		endif;
		tmpValue := tmpValue - pValue;
		if self.myScrollingFrame &lt;&gt; null then
			self.myScrollingFrame.top := tmpValue;
		endif;
	endif;
end;</source>
        <Parameter name="pDirection" type="Integer"/>
        <Parameter name="pValue" type="Integer"/>
    </JadeMethod>
