    <JadeMethod name="getOperatorTerminalConfig" id="33ae3584-814e-4e82-822d-01961b4185a1">
        <updating/>
        <source>getOperatorTerminalConfig(_operator : CM_Operator) updating;
//
// Changed On	By			Reason
// ----------	--------	--------------------------------------------------------------
// 21/09/2011	cnwdap1		PAR #28223 CCMS MSL 1024 extra info flags
// 05/12/2016	cnwdap1		TFS 3039 SNO Empty Container Pool Management
vars

	terminal		: CM_Terminal;
	theForm			: SOP_TableMaintForm;
	cmif			: CMIF_OperatorTerminalConfig;
	recCutoff		: CM_ReceivalCutoffOpTerm;
begin
	
	theForm := self.myForm;
	theForm.tblInput3.enabled := true; // rs /oct 2004 reenable in case of cancel
	theForm.cmbTerminal.enabled := true; // rs /oct 2004 reenable in case of cancel
	terminal := theForm.cmbTerminal.listObject.CM_Terminal;
	
	theForm.cmbMTPoolParty.listCollection(terminal.allMTPoolingParties, true, ComboBox.DisplayCollection_Forward);		// TFS 3039
	theForm.tblInput3.setValueByName(ETRow_PoolParty, null);															// TFS 3039
	
	cmif := self.allOpTerminalConfigs[terminal, _operator];
	if cmif = null then

		create cmif transient;
		cmif.myTerminal := terminal;
		cmif.myOperator	:= _operator;
		self.allOpTerminalConfigs.add(cmif);
	
		//epr TFS 3581 6/3/17
		cmif.setFromConfig();		
		
	endif;
	
	theForm.tblInput3.setValueByName(ETRow_WeighImports, cmif.weighImports);
	theForm.tblInput3.setValueByName(ETRow_WeighExports, cmif.weighExports);
	theForm.tblInput3.setValueByName(ETRow_WeighMTImports, cmif.weighMTImports);
	theForm.tblInput3.setValueByName(ETRow_WeighMTExports, cmif.weighMTExports);
	
	// PAR #28223 start
	theForm.tblInput3.setValueByName(ETRow_ExtraEditInfoExports, cmif.recordExtraEditInfoExports);
	theForm.tblInput3.setValueByName(ETRow_ExtraEditInfoImports, cmif.recordExtraEditInfoImports);
	theForm.tblInput3.setValueByName(ETRow_ExtraEditInfoStorage, cmif.recordExtraEditInfoStorage);
	theForm.tblInput3.setValueByName(ETRow_ExtraEditInfoTranships, cmif.recordExtraEditInfoTranships);
	// PAR #28223 end
	
	//th2 PAR 14641
//	theForm.tblInput3.setValueByName(ETRow_FreeStorageDays, cmif.freeStorageDays);
//	theForm.tblInput3.setValueByName(ETRow_FullFreeStorageDays, cmif.fullFreeStorageDays);
//	theForm.tblInput3.setValueByName(ETRow_EmptyFreeStorageDays, cmif.emptyFreeStorageDays);
	
	// CCMS 1489
	theForm.tblInput3.setValueByName(ETRow_WeighTranships, cmif.weighTranships);
	
	//cnwjo3 ccms 1039 par 22315
	theForm.tblInput3.setValueByName(ETRow_RestrictCargoBookEdits,cmif.restrictCargoBookingEdits);
	
	if cmif.myMTPoolParty &lt;&gt; null then																			// TFS 3039
		theForm.tblInput3.setValueByName(ETRow_PoolParty, cmif.myMTPoolParty.code);								// TFS 3039
		theForm.cmbMTPoolParty.listIndex := theForm.cmbMTPoolParty.findObject(cmif.myMTPoolParty);				// TFS 3039
	endif;																										// TFS 3039
	
	// 25/05/2009 cnwar2 CCMS1040
	foreach recCutoff in cmif.allReceivalCutoffs do
		self.addRecRestrict(recCutoff);
	endforeach;
	
	theForm.tblInput3.setValueByName(ETRow_IsExternallyMonitored, cmif.isExternallyMonitored); //epr TFS 3581 6/3/17
	
	
	self.myCurrentOpTerminalObject := cmif;
end;</source>
        <Parameter name="_operator" type="CM_Operator"/>
    </JadeMethod>
    <JadeMethod name="getTerminalsForUser" id="ecf572a0-0e75-4dd6-bdd6-26e4ca280678">
        <source>getTerminalsForUser();

vars

	user 			: CM_User;
	userTerminal	: CM_UserTerminal;
	iter			: Iterator;

begin

	self.allTerminalsForThisUser.clear();
	user := app.getMyUser();
	iter := user.allUserTerminals.createIterator();
	while iter.next(userTerminal) do
		self.allTerminalsForThisUser.add(userTerminal.getRealTerminal);
	endwhile;

epilog
	delete iter;	
end;</source>
    </JadeMethod>
    <JadeMethod name="includeObject" id="96478018-73f8-4eb1-b888-0513c2e878bd">
        <updating/>
        <source>includeObject(_obj: Object; _passport: CM_Passport): Boolean updating;
// --------------------------------------------------------------------------------
// Created:		04 August 2006 by cnwdad1
//
// Purpose:		Refer to superclass implementation.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if self.includeNotAvailableEntries then
		return true;
	else
		return not _obj.CM_Operator.isNotAvailableForEntry;
	endif;
end;</source>
        <Parameter name="_obj" type="Object"/>
        <Parameter name="_passport" type="CM_Passport"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="initRecCutoffsTbl" id="d9866331-c52a-490c-9c38-058743436d5e">
        <source>initRecCutoffsTbl();

/*
Date		Who		Reason
25 May 2009	cnwar2	Initial creation
19 Dec 2025 navlc30 JIRA 36848 PENN | Operator Table Error 14077

*/
vars
	tmpTable	: CM_DataTable;
	terminal	: CM_Terminal;
	sortedList 	: CM_RecCutoffDefsBySortKey;
	recCutoff	: CM_ReceivalCutoffTermDef;
	idx			: Integer;
	
begin
	tmpTable := self.myForm.tblData5;
	//tmpTable.columns 	  := 4;
	tmpTable.columns 	  := 6; //20/03/2025	navkc1 JIRA Story MTN-34232
	tmpTable.rows		  := 1;
	tmpTable.fixedColumns := 0;
	tmpTable.allowResize  := Table.AllowResize_Column;
	tmpTable.clear;
	
	// Set table headings
	tmpTable.accessCell(1, 1).text := 	app.getErrorString(Code) &amp; Tab &amp; app.getErrorString(Relative_To) &amp; Tab &amp; 
										app.getErrorString(Earliest_Receival_Hrs) &amp; Tab &amp; app.getErrorString(Cutoff_Hrs) &amp; Tab &amp; 
										app.getErrorString(PN_Earliest_Receival_Hrs) &amp; Tab &amp; app.getErrorString(PN_Cutoff_Hrs); //20/03/2025	navkc1 JIRA Story MTN-34232

	// Set table colours and input modes
	tmpTable.accessMode := tmpTable.AccessMode_Column;
	tmpTable.column 	:= 1;
	tmpTable.inputType 	:= tmpTable.InputType_None;	
	tmpTable.column 	:= 2;
	tmpTable.inputType 	:= tmpTable.InputType_ComboBox;
	tmpTable.comboList 	:= DefaultRelativeTo_Arrival_Str &amp; Tab &amp; DefaultRelativeTo_Depart_Str;
	tmpTable.column 	:= 3;
	//tmpTable.inputType 	:= tmpTable.InputType_TextNumeric;				//19.12.2025 navlc30 #36848
	tmpTable.inputType 	:= tmpTable.InputType_SignedNumeric;				//19.12.2025 navlc30 #36848
	tmpTable.decimals 	:= 2;
	tmpTable.maxLength 	:= 7;
	tmpTable.column 	:= 4;
	//tmpTable.inputType 	:= tmpTable.InputType_TextNumeric;				//19.12.2025 navlc30 #36848
	tmpTable.inputType 	:= tmpTable.InputType_SignedNumeric;				//19.12.2025 navlc30 #36848
	tmpTable.decimals 	:= 2;
	tmpTable.maxLength 	:= 7;
	//20/03/2025	navkc1 JIRA Story MTN-34232 - Start
	tmpTable.column 	:= 5;
	//tmpTable.inputType 	:= tmpTable.InputType_TextNumeric;				//19.12.2025 navlc30 #36848
	tmpTable.inputType 	:= tmpTable.InputType_SignedNumeric;				//19.12.2025 navlc30 #36848
	tmpTable.decimals 	:= 2;
	tmpTable.maxLength 	:= 7;
	tmpTable.column 	:= 6;
	//tmpTable.inputType 	:= tmpTable.InputType_TextNumeric;				//19.12.2025 navlc30 #36848
	tmpTable.inputType 	:= tmpTable.InputType_SignedNumeric;				//19.12.2025 navlc30 #36848
	tmpTable.decimals 	:= 2;
	tmpTable.maxLength 	:= 7;
	//20/03/2025	navkc1 JIRA Story MTN-34232 - End
	tmpTable.accessMode := tmpTable.AccessMode_Cell;
	
	self.getTerminalsForUser();
	terminal := self.myForm.cmbTerminal.listObject.CM_Terminal;
	if terminal = null then
		terminal := self.allTerminalsForThisUser.first;
	endif;

	create sortedList transient;
	foreach recCutoff in terminal.allReceivalCutoffDefs where recCutoff.isAvailableForEntry do
		sortedList.add(recCutoff);
	endforeach;
	
	tmpTable.rows := sortedList.size + tmpTable.fixedRows;
	idx := 2;
	foreach recCutoff in sortedList do
		tmpTable.accessCell(idx, 1).text 	 := recCutoff.code &amp; Tab &amp; app.defRelativeToEnumToString(recCutoff.defaultRelativeTo) &amp; Tab &amp; '' &amp; Tab &amp; '' &amp; Tab &amp; '' &amp; Tab &amp; '';
		tmpTable.accessCell(idx, 1).fontBold := true;
		idx := idx + 1;
	endforeach;
	
	if tmpTable.rows &gt; tmpTable.fixedRows then
		tmpTable.row 	:= tmpTable.fixedRows + 1;
		tmpTable.column	:= 2;
	endif;
	self.doResize();
	
epilog
	delete sortedList;
end;</source>
    </JadeMethod>
    <JadeMethod name="initShtFld1" id="a29ccc27-d214-4704-8af8-0cc9d19bcfc5">
        <source>initShtFld1();
//26 August 2010	cnwml2
//+cnwml2 PAR23715 SFW CCMS1131

vars

	theForm : SOP_TableMaintForm;
	tbl : CM_EntryTable;
	terminal : CM_Terminal;
	operator : CM_Operator;
	columnWidth : Integer;
begin
	self.myForm.shtFolder1.visible := true;
	theForm := self.myForm;
	
	//set Form Sheet Captions
	theForm.shtFolder1.caption := "Seal Checks";
	theForm.shtFldSheet1.caption := "System Level";
	theForm.shtFldSheet2.caption := app.getString(Operator);
	
	//setup tables
	tbl := theForm.tblFldSheet1;
	tbl.clear();
	tbl.columns := 3;
	tbl.rows := 1;
	
	tbl.accessCell(1,1).text := "Seal Check Type" &amp; Tab &amp; "Receivals" &amp; Tab &amp; "Releases";
	tbl.parentAspect := 0;
	tbl.stretchToParent := false;
	tbl.selectMode := Table.SelectMode_Default;
	tbl.width		:= tbl.parent.Control.clientWidth;
	columnWidth := (tbl.width / 3).Integer;
	tbl.columnWidth[1] := columnWidth;
	tbl.columnWidth[2] := columnWidth;
	tbl.columnWidth[3] := columnWidth;
	
	tbl.top		:= 0;
	tbl.left 	:= 0;
	tbl.fixedRows := 1;
	tbl.fixedColumns := 0;
	
	theForm.shtFldSheet2.visible := false;

epilog

end;</source>
    </JadeMethod>
