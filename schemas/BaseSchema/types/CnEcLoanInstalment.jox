    <JadeMethod name="initializeMe" id="2793b758-1900-4fb5-b384-fdee30204dd2">
        <updating/>
        <source>initializeMe(	pOpeningBalance:Decimal;
				pPrincipalAmount:Decimal;
				pInterestAmount:Decimal) updating;
// --------------------------------------------------------------------------------
// Created:		30 October 2001 by cnwdad1
//
// Purpose:		Initializes the loan instalment values.
//
// Parameters:	pOpeningBalance - The loan's opening balance.
//				pPrincipalAmount - The principal portion of the instalment.
//				pInterestAmount - The interest portion of the instalment.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	// Set the opening balance and instalment part values.
	
	self.openingBalance		:=	pOpeningBalance;
	self.principalAmount	:=	pPrincipalAmount;
	self.interestAmount		:=	pInterestAmount;
	
	// Calculate the instalment amount and closing balance.
	
	self.instalmentAmount	:=	pPrincipalAmount + pInterestAmount;
	
	if self.instalmentAmount = pOpeningBalance then
		self.closingBalance		:=	pOpeningBalance - self.instalmentAmount;
	else
		self.closingBalance		:=	pOpeningBalance - pPrincipalAmount;
	endif;
end;</source>
        <Parameter name="pOpeningBalance" type="Decimal"/>
        <Parameter name="pPrincipalAmount" type="Decimal"/>
        <Parameter name="pInterestAmount" type="Decimal"/>
    </JadeMethod>
</Class>
