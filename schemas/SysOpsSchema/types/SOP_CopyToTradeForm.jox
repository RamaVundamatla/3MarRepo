    <JadeMethod name="addToolbarControls" id="fc0c3485-cf94-4059-9a1e-a112c708bad6">
        <updating/>
        <source>addToolbarControls() updating, protected;

/*

Purpose:		
Parameters:		
Return Value:	

Date				Who		Reason
23 June 2009		cnwrl1	Initial creation as part of PAR 19998 - Copy To Trade

*/
	
vars
	toolbar	: CMUI_Toolbar;
	
begin
	inheritMethod();
	toolbar	:= self.frmToolbar;
	toolbar.addButton( self.btnSaveBase, CMUI_Toolbar.Control_Alignment_Left );
	toolbar.addButton( self.btnCancelBase, CMUI_Toolbar.Control_Alignment_Right );
	
epilog
	
end;
</source>
        <access>protected</access>
    </JadeMethod>
