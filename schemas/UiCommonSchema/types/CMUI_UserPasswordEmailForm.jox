/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 May 2018	jlgndl1	Initial creation	TFS 38767

*/

vars

begin

	delete self.myEmailController;
	
	inheritMethod;
	
epilog

end;</source>
    </JadeMethod>
</GUIClass>
