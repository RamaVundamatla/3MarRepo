    <JadeMethod name="includeObject" id="ea97a73b-1a19-4941-93e8-07ad1ab3bd2e">
        <updating/>
        <source>includeObject(_obj: Object; _passport: CM_Passport): Boolean updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22/12/2022   navcs2	ChangeRequest 56006: EUP - New VAS Workorder Subscription (task 56008)


*/

vars

begin
	if (not app.myPassport.isVASEnabled) and _obj.CM_WorkOrderDetailType.type = WorkOrderMode_ToDo then
		return false;
	else
		return true;
	endif;

epilog

end;</source>
        <Parameter name="_obj" type="Object"/>
        <Parameter name="_passport" type="CM_Passport"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
