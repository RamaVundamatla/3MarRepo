    <JadeMethod name="handleNotificationException" id="ec76a655-d7f2-4dc1-9dfd-d2e1038b912b">
        <updating/>
        <source>handleNotificationException(ex : Exception) : Integer updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27/05/2025	navkc1 JIRA MTN 34904 MTN | Notification Framework String too Long

*/

vars
	str			: String;
	errCodeMsg 	: String;
	mtd			: MethodCallDesc;
begin
	
	executeWhen JMTDevelopmentEnvironment;
		mtd := ex.currentMethodDesc;
		
		if mtd &lt;&gt; null then
			str := ex.errorCode.String &amp; Space &amp; mtd.getName() &amp; CrLf;
		else
			str := ex.errorCode.String &amp; CrLf;
		endif;
		
		/* ====================================================================================
		Need to check what could have caused exception to the notification object
		==================================================================================== */
		
		errCodeMsg := "Unhandled error code";
		
		if ex.errorCode = Cn_StringTooLong then
			errCodeMsg := 'If you are passing Oid to the causeEvent userInfo field, please make sure it contains only 1 Oid.';
		endif;
		
		str &amp;= errCodeMsg;
		
		app.msgBox(str, "Exception in handling notification", MsgBox_Exclamation_Mark_Icon + MsgBox_OK_Only);
	endExecuteWhen;
	
	// Refresh the screen by default when excaption occured in the notification	
	//self.doClearNoteRecords(false);
	self.doClearNoteRecords(false, true); //23/06/2025	navkc1 JIRA MTN 34973
	self.doNoteRefresh();
	
	return Ex_Abort_Action;

epilog

end;</source>
        <Parameter name="ex" type="Exception"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
