    <JadeMethod name="doMnuGridUnplanBayClick" id="691e4334-234d-469d-b41c-3b7fb4752984">
        <updating/>
        <source>doMnuGridUnplanBayClick(menuItem: MenuItem input) updating;

// 24/10/2024	navcs2		MTN-28961 EUP | Transaction Instrumentation - Voyage Planning
// 14 Jan 2026 	navhl20 	Bug MTN-35897: PEN - System Locking Errors (1000010 - Unknown message)
vars
	bayVoyage 		: CM_BayVoyage;
	anObject 		: Object;
	slotController 	: CM_SlotController;
begin
	app.mousePointer := Window.MousePointer_HourGlass;
	
	anObject := menuItem.userObject;
	if anObject = null or not anObject.isKindOf(CM_BayVoyage) then
		return;
	endif;
	
	bayVoyage := anObject.CM_BayVoyage;

	foreach slotController in bayVoyage.allSlotControllersByOrdinal do
		unplanSlot(slotController);
	endforeach;
	
epilog	
	app.mousePointer := Window.MousePointer_Default;
end;</source>
        <Parameter name="menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doMnuGridUnplanJobClick" id="3bdbd57f-e746-4d7f-830d-f5893f7066db">
        <updating/>
        <source>doMnuGridUnplanJobClick(menuItem: MenuItem input) updating;
// ---------------------------------------------------------------------------
// Created:		April 2003 By Andrew Bishop cnwab1
//
// Purpose:		
// ---------------------------------------------------------------------------
vars
	result : Integer; 
	realVoyageJob : CM_VoyageJob;
	anObject : Object;
	request : CM_Request;
	slotController : CM_SlotController;

begin
	app.mousePointer := Window.MousePointer_HourGlass;
	
	anObject := menuItem.userObject;
	
	if anObject = null or not anObject.isKindOf(CM_VoyageJob) then
		return;
	endif;
	
	realVoyageJob := anObject.CM_VoyageJob;
	
	while true do
		app.myTrxUA.trxUpdateVoyageJobUnplan(realVoyageJob, app.myPassport);	
		if app.myPassport.trxCompletedOK then
			break;
		else
			result := app.showErrorWarningDialog('Unplan Voyage Job ' &amp; realVoyageJob.jobId.String &amp; ' Cargo', app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   result = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		break;
	endwhile;

epilog	
	app.mousePointer := Window.MousePointer_Default;

end;</source>
        <Parameter name="menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doMnuGridUnplanSlotClick" id="a913aa16-5422-4762-a08a-2cf204bba98c">
        <updating/>
        <source>doMnuGridUnplanSlotClick(menuItem: MenuItem input) updating;

// 22/10/2024	navcs2		MTN-28961 EUP | Transaction Instrumentation - Voyage Planning
// 14 Jan 2026 	navhl20 	Bug MTN-35897: PEN - System Locking Errors (1000010 - Unknown message)
vars
	tmpObj,
	anObject 			: Object;
	tmpDrawController	: SHP_BayDrawingController;
begin
	app.mousePointer := Window.MousePointer_HourGlass;
	
	anObject := menuItem.userObject;
	if anObject = null or not anObject.isKindOf(CM_SlotController) then
		return;
	endif;
	
	// 27/11/2008 cnwdz2 par18550
	tmpDrawController := self.myBayDrawingController;
	foreach tmpObj in tmpDrawController.allSelectedObjects do
		if CM_SlotController.hasInstance(tmpObj) then
			unplanSlot(tmpObj.CM_SlotController);
		endif;
	endforeach;
	//unplanSlot(anObject.CM_SlotController);

epilog	
	app.mousePointer := Window.MousePointer_Default;
end;</source>
        <Parameter name="menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doMnuNonTranship" id="69f90544-966c-4edb-9d25-8f50ccadd3cb">
        <updating/>
        <source>doMnuNonTranship(_tiArray: CM_TIArray): Boolean updating;
// ---------------------------------------------------------------------------
// Created:     19 December 2007 by cnwaer1
//
// Purpose:     
// ---------------------------------------------------------------------------
// Changed On	By			Reason
// ----------	--------	--------------------------------------------------
// 12/05/2010	cnwdap1		CCMS 1116 Tranship changes - rewrite to display tranship form
vars
	result 	: Integer;
	ti, pxyTI :CM_TrackedItem;
	pxyObject :CM_Object;
	obj :Object;
	//pxyTISet : CM_TISet;			// PAR #23645 CCMS 1116
	pxyTIArray : CM_TIArray;		// PAR #23645 CCMS 1116
begin
	//create pxyTISet transient;	// PAR #23645 CCMS 1116
	//pxyTISet.clear;				// PAR #23645 CCMS 1116
	create pxyTIArray transient;	// PAR #23645 CCMS 1116
	
	// PAR #23645 CCMS 1116 - handle single and multiple TIs the same way
	foreach obj in _tiArray do
		if CM_TrackedItem.hasInstance(obj) and obj.CM_TrackedItem.isTranshipItem then
			pxyTIArray.add(obj.CM_TrackedItem);
		endif;	
	endforeach;
	
	// call tranship form to make TIs non-tranship
	self.myAssistant.showTranshipDetailForm(pxyTIArray);
	
	// PAR #23645 CCMS 1116 - used to go down different path for one TI as opposed to more than one
	/*if _tiArray.size &gt; 1 then
			foreach obj in _tiArray do
			/*
				if obj.isKindOf(CM_TrackedItem) and obj.CM_TrackedItem.isTranshipItem and obj.CM_TrackedItem.myTranshipExport &lt;&gt; null then
					pxyObject := app.createUpdateProxy(obj.CM_TrackedItem.myTranshipExport);
					if pxyObject.CM_TrackedItem &lt;&gt; null then
						pxyTI := pxyObject.CM_TrackedItem;
						pxyTI.zSetPxyIsTranshipItem(false);
						pxyTISet.add(pxyTI);
					endif;
				endif;	
				*//*
				// work from the import end 
				if obj.isKindOf(CM_TrackedItem) and obj.CM_TrackedItem.isTranshipItem then
				
					if obj.CM_TrackedItem.isTranshipImport() then
						pxyObject := app.createUpdateProxy(obj.CM_TrackedItem);
					elseif obj.CM_TrackedItem.isTranshipExport() then
						pxyObject := app.createUpdateProxy(obj.CM_TrackedItem.myTranshipImport);
					else
						continue; // ignore possibly old tranship
					endif;
					if pxyObject.CM_TrackedItem &lt;&gt; null then
						pxyTI := pxyObject.CM_TrackedItem;
						pxyTI.zSetPxyIsTranshipItem(false);
						pxyTI.zSetPxyRemarks(null);
						pxyTISet.add(pxyTI);
					endif;
				endif;	

			endforeach;	
			if pxyTISet &lt;&gt; null then
				return self.doSaveBulkTiNonTrans(pxyTISet);
			else 
				return false;
			endif;
	elseif _tiArray.size = 1 then
		ti := _tiArray.first.CM_TrackedItem.myTranshipExport;
		if ti &lt;&gt; null then
			pxyObject := app.createUpdateProxy(ti);
			if pxyObject.CM_TrackedItem &lt;&gt; null then
				pxyTI := pxyObject.CM_TrackedItem;
				pxyTI.zSetPxyIsTranshipItem(false);
				return self.doSaveSingleTiNonTrans(pxyTI);
			endif;
		endif;
		return false;
	endif;	*/
	
	return false;
	
epilog
	delete pxyObject;
	//pxyTISet.purge;		// PAR #23645 CCMS 1116
	//delete pxyTISet;		// PAR #23645 CCMS 1116
	delete pxyTIArray;		// PAR #23645 CCMS 1116
end;
</source>
        <Parameter name="_tiArray" type="CM_TIArray"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
