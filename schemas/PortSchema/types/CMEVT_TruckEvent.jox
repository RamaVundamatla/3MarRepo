    <JadeMethod name="hasTaskThatIsComplete" id="3c7da973-ba48-441f-8001-059f8ba8d299">
        <source>hasTaskThatIsComplete(): Boolean;
/*
Purpose:			

Date		Who		Reason
16JUN2023	NAVAB1	 CR 54345 TASK 58281 
05 Dec 2024 navma1	 MTN-33567 MTN - Charges Are Not Created When adding Events
*/


vars
	taskDesc 	: CM_ToDoTaskDesc;
	task 		: CM_ToDoTask;
	myWodToDo 	: CM_WodToDo;
	vvr			: CM_VehicleVisitRecord;
begin

	if self.myToDoTask = null then
		return false;
	endif;
	
	vvr := self.myVisit;
	
	if vvr = null then
		return null;
	endif;
	
	return vvr.allToDoTasksCompleted.includes(self.myToDoTask);
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="e037393a-1800-479d-8e22-1bc43533d9ea">
        <source>pxyCreateUpdateProxy(): SelfType;
/*

Date		Who		Reason
10 December 2014	cnwer1	Initial creation PAR

*/

vars
	proxy : SelfType;
	completedOK		: Boolean;
begin
	proxy := inheritMethod();
	
	if proxy &lt;&gt; null then
		proxy.myVisit 	:= self.myVisit;
	endif;
	
	completedOK := true;			
	return proxy;
epilog
	if not completedOK then			
		delete proxy;
	endif;

end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="remarks" id="56a35861-2810-4d32-9293-1e0d0dd59212">
        <methodInvocation>mapping</methodInvocation>
        <source>remarks(set: Boolean; _value: String io) mapping;
/*

Purpose:			

Parameters:			

Return Value:		

Date					Who		Reason
20 February 2023		jlizm1	Initial creation TFS 56675 Truck Events remarks field

*/

vars

begin
	if set then
		global.setExtraData(self.allExtraData, self, CMEVT_TruckEvent::remarks.name, _value);
	else
		global.getExtraData(self.allExtraData, CMEVT_TruckEvent::remarks.name, _value);
	endif;


epilog

end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="setDebtor" id="d8607c1f-725b-4d6a-ac16-b6c1b70fd07f">
        <updating/>
        <source>setDebtor(_debtor : CM_Debtor)updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08/06/2020 cnwma1 ChangeRequest 49400: ASPA - Invoice Enhancements for Barges

*/

