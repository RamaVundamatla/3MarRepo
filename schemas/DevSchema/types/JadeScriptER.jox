	charge : CM_Charge;
	isCreditReturn : Boolean;
begin
	app.initialize;
	app.myPassport.setMyUserFromCode("CNWER1");
	

	invoice:="2216.1183047".asOid.CM_Invoice;  //61031 FRED
	invoice:="2216.1281521".asOid.CM_Invoice; 
/*	beginTransaction;
	invoice.setStatus(CM_Invoice.INVOICE_POSTED_CREDIT_ERROR);
	invoice.allEWSInvoiceAPIActivities.purge;
	commitTransaction;
	return;*/
