    <JadeMethod name="isSameCriteria" id="0321f2ea-e751-4882-92f8-9c9f746c5ea5">
        <source>isSameCriteria(_compareData: SelfType): Boolean;
//27 August 2008	cnwdw1	
//
vars

begin
	if not _compareData.isKindOf(CM_YADataPattern) then
		return false;
	endif;
	return self.pattern = _compareData.pattern;

end;</source>
        <Parameter name="_compareData" type="SelfType"/>
