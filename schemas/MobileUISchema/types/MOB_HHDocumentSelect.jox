    <JadeMethod name="getSelectedDocumentAction" id="251487d4-6b7d-480a-986b-16020d592b02">
        <source>getSelectedDocumentAction( _parentHasDAs : Boolean output; _allowMaint : Boolean output ):CM_DocumentActions protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 October 2016	cnwndl1	Initial creation	TFS 2655 / 2419

*/

vars

	bookRefItem : CM_BookingRefItem;
	reserve : CM_ReserveDetail;
	docAction : CM_DocumentActions;
	
	booking : CM_BookingRef;
	release : CM_BulkRelease;

begin

	if self.optBooking.value then
		//12 Dec 2016	NDL	TFS 3023/2001
		booking := self.cmbBookings.listObject.CM_BookingRef;
		if booking &lt;&gt; null then
			_parentHasDAs := booking.hasDocActions;
		endif;
		_allowMaint := app.myCurrentUserCan( self.myTerminal, PmGteBookingRefMaint ) and app.myCurrentUserCan( self.myTerminal, PmAdmDocActionsMaint );
		
		bookRefItem := self.cmbBookingItems.listObject.CM_BookingRefItem;
		if bookRefItem &lt;&gt; null then
			docAction := bookRefItem.myBookingRefItemActions;
		endif;
		
	elseif self.optRelease.value then
		//12 Dec 2016	NDL	TFS 3023/2001
		release := self.cmbReleases.listObject.CM_BulkRelease;
		if release &lt;&gt; null then
			_parentHasDAs := release.hasDocActions;
		endif;
		_allowMaint := app.myCurrentUserCan( self.myTerminal, PmGteEmptyReleaseMaintAll ) and app.myCurrentUserCan( self.myTerminal, PmAdmDocActionsMaint );
		
		reserve := self.cmbReserveDetails.listObject.CM_ReserveDetail;
		if reserve &lt;&gt; null then
			docAction := reserve.myReserveDetailActions;
		endif;
	
	endif;
	
	return docAction;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_parentHasDAs" type="Boolean" usage="output"/>
        <Parameter name="_allowMaint" type="Boolean" usage="output"/>
        <ReturnType type="CM_DocumentActions"/>
    </JadeMethod>
    <JadeMethod name="handleBtnOne" id="0622c540-265f-431a-8965-11f21f3adcfb">
        <updating/>
        <source>handleBtnOne() updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 October 2016	cnwndl1	Initial creation	TFS 2655 / 2419

*/

vars

	docAction : CM_DocumentActions;
	
	reserveDetail : CM_ReserveDetail;
	resDetailSet : CM_ReserveDetailSet;
	bookingItem : CM_BookingRefItem;
	bookingItemSet : CM_BookingRefItemSet;
	parentHasDAs : Boolean;	//12 Dec 2016	NDL	TFS 3023/2001
	allowMaint : Boolean;	//12 Dec 2016	NDL	TFS 3023/2001
	booking : CM_BookingRef;	//12 Dec 2016	NDL	TFS 3023/2001
	release : CM_BulkRelease;	//12 Dec 2016	NDL	TFS 3023/2001

begin
	
	docAction := self.getSelectedDocumentAction( parentHasDAs, allowMaint );
	
	if docAction = null and not allowMaint then
		self.resetButtons();
		return;
	endif;
	
	create resDetailSet transient;
	create bookingItemSet transient;
	
	if docAction = null then
		//12 Dec 2016	NDL	TFS 3023/2001
		if self.optBooking.value then
			booking := self.cmbBookings.listObject.CM_BookingRef;
			foreach bookingItem in booking.allBookingRefItems do
				if bookingItem.myBookingRefItemActions &lt;&gt; null and bookingItem.myBookingRefItemActions.hasActions then
					bookingItemSet.add( bookingItem );
				endif;
			endforeach;
		elseif self.optRelease.value then
			release := self.cmbReleases.listObject.CM_BulkRelease;
			foreach reserveDetail in release.allReserveDetails do
				if reserveDetail.myReserveDetailActions &lt;&gt; null and reserveDetail.myReserveDetailActions.hasActions then
					resDetailSet.add( reserveDetail );
				endif;
			endforeach;
			foreach reserveDetail in release.allReservePackingChildren do
				if reserveDetail.myReserveDetailActions &lt;&gt; null and reserveDetail.myReserveDetailActions.hasActions then
					resDetailSet.add( reserveDetail );
				endif;
			endforeach;
		endif;
	else
		if docAction.isBookingItemAction then
			bookingItem := docAction.CM_BookingItemActions.myBookingItem;
			bookingItemSet.add( bookingItem );
		elseif docAction.isReserveDetailAction then
			reserveDetail := docAction.CM_ReserveDetailActions.myReserveDetail;
			resDetailSet.add( reserveDetail );
		endif;
	endif;
	
	self.myMobileGenericAgent.setAllReserveDetails( resDetailSet );
	self.myMobileGenericAgent.setAllBookingRefItems( bookingItemSet );
	self.gotoForm( MOB_HHDocumentActions, false );

epilog

	delete resDetailSet;
	delete bookingItemSet;

end;</source>
        <access>protected</access>
    </JadeMethod>
