    <JadeMethod name="setForCreate" id="fb8f5a19-ad0c-4134-ac48-a2170415167a">
        <updating/>
        <source>setForCreate(_proxyDeckItem: SelfType; _passport: CM_Passport input) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
03 June 2011	cnwer1	Initial creation CCMS MES 1116

*/

vars
	pxyAdj, realAdj : CM_ROROLocnDefn;
begin
	self.ordinal := _proxyDeckItem.ordinal;

	inheritMethod(_proxyDeckItem, _passport);

	pxyAdj := _proxyDeckItem.myAdjacentSlotAft;
	if pxyAdj &lt;&gt; null then
		realAdj := pxyAdj.pxyGetRealObject();
		if realAdj = null then
			realAdj :=  self.myLayout.myDeckLayer.allROROLocnDefnByOrdinal[pxyAdj.ordinal];
		endif;
	endif;

	self.myAdjacentSlotAft := realAdj;
	
	self.myDeckLayerLayout := self.myLayout.myDeckLayer;
	
	self.createRealSlots(_proxyDeckItem, _passport);
epilog

end;</source>
        <Parameter name="_proxyDeckItem" type="SelfType"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setForCreateImport" id="c4f02498-2bef-424e-b419-417717737cdb">
        <updating/>
        <source>setForCreateImport(_proxyDeckItem: SelfType; _passport: CM_Passport input) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
06 May 2011	cnwer1	Initial creation CCMS 1031
28 Sep 2011 cnwer1	PAR 28276
*/

vars
	slotAft			: CM_ROROLocnDefn;
	pxySlotDefn ,
	realSlotDefn 	: CM_ROROSlotDefn;
begin
	inheritMethod(_proxyDeckItem, _passport);
	
	self.myDeckLayerLayout:=self.myLayout.myDeckLayer;
	self.labelManuallyChanged:=true;
	
	foreach pxySlotDefn in _proxyDeckItem.allROROSlotDefnByOrdinal do
		create realSlotDefn as pxySlotDefn.class persistent;
		realSlotDefn.setRealLocnDefn(self);
		realSlotDefn.setForCreateImport(pxySlotDefn,_passport);
		
	endforeach;

	if _proxyDeckItem.myAdjacentSlotAft &lt;&gt; null then
		slotAft := self.myDeck.allROROLocnDefnByCode[_proxyDeckItem.myAdjacentSlotAft.code];
		if slotAft &lt;&gt; null then
			slotAft.myAdjacentSlotFwd := null;
		endif;
		self.myAdjacentSlotAft := slotAft;
	endif;
	
	if _proxyDeckItem.myAdjacentSlotFwd &lt;&gt; null then
		slotAft := self.myDeck.allROROLocnDefnByCode[_proxyDeckItem.myAdjacentSlotFwd.code];
		if slotAft &lt;&gt; null then
			slotAft.myAdjacentSlotAft := null;
		endif;
		self.myAdjacentSlotFwd := slotAft;
	endif;
	
epilog

end;</source>
        <Parameter name="_proxyDeckItem" type="SelfType"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="29233dde-a181-4bc1-aa71-3515b8b4dbb0">
        <updating/>
        <source>setForUpdate(_proxyDeckItem: SelfType;_passport : CM_Passport input) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
11 Apr 2011	cnwer1	Initial creation CCMS 1031
28 Sep 2011 cnwer1	PAR 28276
*/

vars
	realSlot, pxySlot : CM_ROROSlotDefn;
	realHaz, pxyHaz : CM_Hazard;
	slotAft,slotFwd : CM_ROROLocnDefn;
begin
	inheritMethod(_proxyDeckItem,_passport);
	
	self.hasPower := _proxyDeckItem.hasPower;
	self.isRotatable := _proxyDeckItem.isRotatable;
	self.isWaterCooled := _proxyDeckItem.isWaterCooled;
	self.maxLoadPer20 := _proxyDeckItem.maxLoadPer20;
	self.maxLoadPer40 := _proxyDeckItem.maxLoadPer40;
	self.maxLoadTotal := _proxyDeckItem.maxLoadTotal;
	self.maxStackHeight := _proxyDeckItem.maxStackHeight;
	self.orientation := _proxyDeckItem.orientation;
	self.voltageType := _proxyDeckItem.voltageType;
	self.isOOTLLocn := _proxyDeckItem.isOOTLLocn; // PAR 27749
	self.labelManuallyChanged := _proxyDeckItem.labelManuallyChanged; // PAR 27749

	
	if _proxyDeckItem.myAdjacentSlotAft &lt;&gt; null then
		slotAft := _proxyDeckItem.myAdjacentSlotAft.pxyGetRealObject();
		if slotAft &lt;&gt; null then
			slotAft.myAdjacentSlotFwd := null;
		endif;
		self.myAdjacentSlotAft := slotAft;
	endif;
	
	if _proxyDeckItem.myAdjacentSlotFwd &lt;&gt; null then
		slotFwd := _proxyDeckItem.myAdjacentSlotFwd.pxyGetRealObject();
		if slotFwd &lt;&gt; null then
			slotFwd.myAdjacentSlotAft := null;
		endif;
		self.myAdjacentSlotFwd := slotFwd;
	endif;
	
	self.numTiers := self.allROROSlotDefnByOrdinal.size;

	
	foreach realSlot in self.allROROSlotDefnByOrdinal discreteLock do
		pxySlot := realSlot.pxyGetProxyObject();
		realSlot.setForUpdate(pxySlot);
	endforeach;
	
	self.allHazardsAllowed.purge();
	foreach pxyHaz in _proxyDeckItem.allHazardsAllowed discreteLock do
	// only create if the hazard class exists for this code
		if app.myRoot.allHazardClasses[pxyHaz.code] = null then
			continue;
		endif;
		create realHaz as CM_ROROHazard;
		realHaz.setForCreate(pxyHaz,self,_passport);
	endforeach;
epilog
	
end;</source>
        <Parameter name="_proxyDeckItem" type="SelfType"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setForUpdateRotate" id="3d701ac2-4bf5-4a2f-bf65-fdd11f1d395c">
        <updating/>
        <source>setForUpdateRotate(_startLocn : CM_ROROLocnDefn; _items, _split : Integer; _clear : Boolean; _isLoad : Boolean) updating;
/*
Purpose:			
Date		Who		Reason
08 September 2011	cnwab1	Initial creation
*/
//22 Jan 2013	cnwrs1	Par30951 include Exports as ROBs for EDI Proposed
//
vars
	startLocn, rotatedLinked, loadLinked, actualLinked : CM_ROROLocnDefn;
	cargoLayer, loadLayer : CM_DeckLayerLayout;
	clear  : Boolean;
	//cnwmc5 - PAR 32093
	mode : String;
begin
	startLocn := _startLocn;
	
	clear := _clear; // PAR 29749

	// PAR 29749
	rotatedLinked := startLocn.getRotatedLinked(); 
	if rotatedLinked &lt;&gt; null then // we are already rotated in this or the other view
		if _isLoad then // Attempting LOAD VIEW ROTATION
			// The actual is already rotated for the same grouping so delete the load rotation
			if rotatedLinked.isPlannedRotated then
				cargoLayer := self.myDeck.myDeckLayout.getCargoLayer(); 
				rotatedLinked.myLayout.myDeckLayer.causeEvent(EVENT_RORO_LAYER_UPDATE,false,cargoLayer); 

				loadLayer := self.myDeck.myDeckLayout.getCCLoadLayer(); 
				startLocn.myLayout.myDeckLayer.causeEvent(EVENT_RORO_LAYER_UPDATE,false,loadLayer); 
				
				
				//###
				foreach actualLinked in rotatedLinked.allPlannedRotatedLocnDefns discreteLock do
					loadLinked := actualLinked.getRotatedLinked();
					actualLinked.setRotateCloneLink(null);
			
					delete loadLinked;
				endforeach;

				
				//###
				return;
			endif;
		else  // Attempting ACTUAL VIEW ROTATION
			// The load is already rotated for the same grouping so delete the load rotation, and then carry on and rotate me
			if rotatedLinked.isPlannedRotated then
				cargoLayer := self.myDeck.myDeckLayout.getCargoLayer(); 
				startLocn.myLayout.myDeckLayer.causeEvent(EVENT_RORO_LAYER_UPDATE,false,cargoLayer); 

				loadLayer := self.myDeck.myDeckLayout.getCCLoadLayer(); 
				rotatedLinked.myLayout.myDeckLayer.causeEvent(EVENT_RORO_LAYER_UPDATE,false,loadLayer); 
				
				rotatedLinked.CM_ROROLocnDefnVoyage.eraseForUnrotate(true); // erase the cloned load locations
				clear := false; // do no cloning for the load  view
			endif;
		
		endif;
	endif;

	//cnwmc5 - PAR 32093
	if _isLoad then
		mode := "LOAD";
	else
		mode := "ACTUAL";
	endif;
	app.writeVoyageLog(startLocn, "Rotation Start (Items: " &amp; _items.String &amp; " Split: " &amp; _split.String &amp; " Mode: " &amp; mode &amp; ")"); // PAR 31878 - logging
	
	self.myDeckLayerLayout.setForUpdateRotate(startLocn, _items, _split, clear, _isLoad); // PAR 29749
	
	// PAR 28886
	if startLocn.isOOTL() then
		 if not startLocn.myLayout.moveAftWithForward(true) then	//22 Jan 2013	cnwrs1	Par30951 include Exports as ROBs for EDI Proposed
			if startLocn.myLayout.moveForwardWithAft(true) then	//22 Jan 2013	cnwrs1	Par30951 include Exports as ROBs for EDI Proposed
				startLocn.myAdjacentSlotFwd.setIsPlannedRotated(startLocn.isPlannedRotated); // PAR 29990
			
			endif;
		else
			startLocn.myAdjacentSlotAft.setIsPlannedRotated(startLocn.isPlannedRotated); // PAR 29990
		endif;
	endif;

epilog

end;</source>
        <Parameter name="_startLocn" type="CM_ROROLocnDefn"/>
        <Parameter name="_items" type="Integer"/>
        <Parameter name="_split" type="Integer"/>
        <Parameter name="_clear" type="Boolean"/>
        <Parameter name="_isLoad" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setForUpdateRotateToDefinition" id="8bddc0ca-adba-4670-8e4b-d275040bc3d2">
        <updating/>
        <source>setForUpdateRotateToDefinition() updating;
/*
Purpose:			PAR 31110 (CCMS 1320)
Date		Who		Reason
19 February 2013	cnwab1	Initial creation
*/

vars
	loadClone, actualDefn, actualMaster, theCloneMaster : CM_ROROLocnDefn;
	cloneItems, actualItems : CM_RORODeckItemByOrd1Ord2;
	ord1, ord2 : Integer;
	numcloneItems, split : Integer;
	wasVertical : Boolean;
begin
	wasVertical := self.isVerticalOrientation();

	actualMaster := self.myRotateDischarge;
	if actualMaster = null then
		return;
	endif;
	
	if not actualMaster.isRotationMaster() then
		return;
	endif;
	
	if not self.isOnLayerLoad() then
		return;
	endif;
	wasVertical := not actualMaster.isVerticalOrientation();

	create cloneItems transient;
	create actualItems transient;

	foreach actualDefn in actualMaster.allPlannedRotatedLocnDefns discreteLock do
		loadClone := actualDefn.myRotateLoad;
		
		loadClone.myLayout.setPointsPolygon(actualDefn.myPreRotatePoints);
		loadClone.myLayout.setPropertyValue("isVisible",true);
		loadClone.removeRotateLabel("R");
		loadClone.removeRotateLabel("#");
		loadClone.isPlannedRotated := false;
		if actualDefn.orientation = ROROLocn_PortStarboard then
			loadClone.orientation := ROROLocn_AftForward;
		else
			loadClone.orientation := ROROLocn_PortStarboard;
		endif;
		
//		loadClone.myLayout.getOrdinalsForSorting(PSAF_Value, ord1, ord2);
		
		if wasVertical then // Vertical
			loadClone.myLayout.getOrdinalsForSorting(SPAF_Value, ord1, ord2); 
		else
			loadClone.myLayout.getOrdinalsForSorting(AFSP_Value, ord1, ord2);
		endif;
		cloneItems.putAtKey(ord1, ord2, loadClone);
		// use the same ordinals
		actualItems.putAtKey(ord1, ord2, actualDefn);
	endforeach;
	
	numcloneItems := cloneItems.size;
	if numcloneItems = 6 or numcloneItems = 10 then
		split := 2;
	else
		split := 1;
	endif;
	
	self.myLayout.myDeckLayer.setForUpdateRotateLinkAft(cloneItems,numcloneItems, split, wasVertical);
	self.myLayout.myDeckLayer.setForUpdateRotateLinkCloneAft(numcloneItems, split,actualItems, wasVertical, true);
epilog
	delete cloneItems;
	delete actualItems;
end;</source>
    </JadeMethod>
    <JadeMethod name="setFwdLocn" id="bc01e290-48c3-4b5d-8ef6-2f5161a45342">
        <updating/>
