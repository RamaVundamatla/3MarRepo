    <JadeMethod name="chkSoundsLike_click" id="2329a6a2-459d-41c4-82b5-9c0024e3371c">
        <controlMethod name="CheckBox::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>chkSoundsLike_click(checkbox: CheckBox input) updating;
// --------------------------------------------------------------------------------
// Created:		26 November 2008 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	isSoundsLike	: Boolean;
	
begin
	isSoundsLike			:=	checkbox.value;
	optMetaphone.enabled	:=	isSoundsLike;
	optSoundex.enabled		:=	isSoundsLike;
end;</source>
