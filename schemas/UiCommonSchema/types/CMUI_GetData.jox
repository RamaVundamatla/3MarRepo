    <JadeMethod name="doCancel" id="80e4bb2c-b831-45f9-8cad-cec5cbcbc5ac">
        <updating/>
        <source>doCancel() updating;
// ---------------------------------------------------------------------------
// Created:		January  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin
	self.modalResult := ModalResultCancel; // TFS 3873

	self.unloadForm();

end;</source>
    </JadeMethod>
    <JadeMethod name="doOK" id="9f816ccc-7504-4e9f-bf94-809cadaaaa36">
        <updating/>
        <source>doOK() updating;
// ---------------------------------------------------------------------------
// Created:		January  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin
	app.mousePointer := MousePointer_HourGlass;
	if self.msrWeight.visible then
		self.myCaller.getData(self.msrWeight.getConvertedValue.String, self.type);
	else
		self.myCaller.getData(self.txtData.text, self.type);
	endif;
	self.modalResult := ModalResultOK; // TFS 3873
	app.mousePointer := MousePointer_Default;
	self.unloadForm();

end;</source>
    </JadeMethod>
