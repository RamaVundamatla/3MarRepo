        <source>setLoggingOrganisation(_loggingOrg: String)updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
21 January 2010	#cnwdz2	CCMS 1108 par22177 

*/

vars

begin
	self.loggingOrganisation := _loggingOrg;
	//15 Jan 2014	NDL	Par 33264
	if self.myBOL &lt;&gt; null and not self.isTransient then	//20 Jan 2014	NDL	Par 33264
		self.updateObjectEdition(self.myBOL);
	endif;
epilog

end;</source>
        <Parameter name="_loggingOrg" type="String"/>
    </JadeMethod>
