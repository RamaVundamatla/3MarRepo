    <JadeMethod name="setUpPropertyCombo" id="08455597-7fe9-47a7-94e1-db352d762b58">
        <source>setUpPropertyCombo();
/*
Purpose:	TFS 40336		
Date				Who			Reason
SEPTEMBER 2018		CNWAB1		Initial creation
*/


vars
	entTableDef : EntTableDef;
	entTableRow : EntTableRow;
begin
	self.cmbProperties.clear();
	
	
	entTableDef := app.myController.getEntTableDef(ETDef_SnapShotView);
	if entTableDef &lt;&gt; null then
		foreach entTableRow in entTableDef.allEntTableRows	discreteLock do
			if entTableRow.name = ETRow_ChangeReason 
			or entTableRow.name = ETRow_LastChangedBy 
			or entTableRow.name = ETRow_LastChangedDT
			or entTableRow.name = ETRow_Size
			or entTableRow.name = ETRow_Ignore
			or entTableRow.name = ETRow_Type
			then
				continue;
			endif;
			self.cmbProperties.addItemObject(entTableRow.getHeading(null,self.myTerminal,null),entTableRow);
//			self.cmbProperties.addItemObject(entTableRow.name,entTableRow);
		endforeach;
	
	endif;
	


epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setUpTable" id="2cac8093-0e59-4daf-8970-41052a2db4cb">
        <source>setUpTable();
/*
Purpose:	TFS 40336		
Date				Who			Reason
SEPTEMBER 2018		CNWAB1		Initial creation
*/

vars

	snap : CM_SnapShot;
	snapti : CM_TISnapShot;
	table : CM_DataTable;
begin
	table := self.tblData;
	table.rows := 0;
	table.selectMode := CM_EntryTable.SelectMode_FixedRow;
	table.selectionType := CM_EntryTable.SelectionType_Row;
	table.readOnly := false;	
	table.fixedColumns := 0;
	table.show3D := Table.Show3D_Not3D;
	table.multiSelect := CM_BaseTable.MultiSelect_Simple;
	
	table.addItem("Cargo Id" &amp; Tab &amp; "Snap Shot Value" &amp; Tab &amp; "Cargo Value");
	table.fixedRows := 1;
	
	
	foreach snap in self.allEditSnapShots	discreteLock do
		snapti := snap.CM_TISnapShot;
		table.addItemObject(snapti,snapti.id &amp; Tab &amp; "" &amp; Tab);
		
	endforeach;
	
epilog

end;</source>
    </JadeMethod>
