    <JadeMethod name="getWorkOrderTIDtl" id="a0f6e2e8-8b48-4396-b740-0a7a9704727c">
        <source>getWorkOrderTIDtl(): CM_WodRelease;
// -----------------------------------------------------------------------------
// Created:		31 July 2009 by consw1
//
