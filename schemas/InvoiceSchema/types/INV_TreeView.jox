    <JadeMethod name="setEnableObjects" id="598ca124-9806-4a0f-8d5b-ff296ef0255b">
        <updating/>
        <source>setEnableObjects(_enable : Boolean) updating, protected;
//------------------------------------------------
// Created: 17 May 2006 By: cnwgd1
//------------------------------------------------
vars

begin
	
	self.btnSearch.enabled := _enable;
	self.btnSaveBase.enabled := _enable;
	self.btnRefresh.enabled := _enable;
	self.btnCancelBase.enabled := _enable;
	
	self.frmToolbar.enabled := _enable;
	self.lstData.enabled := _enable;
	
	self.frmProperties.visible := (not _enable);

	if (not self.frmProperties.visible) then
		self.updateMode := null;
	endif;	
			
end;</source>
        <access>protected</access>
        <Parameter name="_enable" type="Boolean"/>
    </JadeMethod>
