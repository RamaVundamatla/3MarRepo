<Class name="BmkStdRun" id="c73cb9f6-eadb-4bff-9c9b-e466b3bdb0e1">
    <superclass name="ModelEntity"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="Coy"/>
    <ImplicitInverseRef name="myBmkControlSession" id="22e75429-aa7f-4261-8238-171ca889f6ce">
        <embedded/>
        <type name="BmkControlSession"/>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="myCreatorControlForm" id="833ad51d-b1a9-40bc-b331-446eb4cc0d93">
        <embedded/>
        <type name="CreatorControlForm"/>
    </ImplicitInverseRef>
    <PrimAttribute name="noteCount" id="d2991c9c-7c58-4442-b7fa-ad3d1ac8b5ed">
        <embedded/>
        <type name="Integer"/>
    </PrimAttribute>
    <PrimAttribute name="noteType" id="45eae006-96fe-455c-9bb7-35a1744e910a">
        <embedded/>
        <type name="Integer"/>
    </PrimAttribute>
    <PrimAttribute name="productConfig" id="c9b969f5-265b-4c4e-af60-27c5bcad10fc">
        <type name="String"/>
    </PrimAttribute>
    <PrimAttribute name="session" id="3b8920e7-91fa-4dc8-ad9c-bcbf3b4642ec">
        <embedded/>
        <type name="Integer"/>
    </PrimAttribute>
    <JadeMethod name="countApps" id="57e5fdb7-326f-405c-a657-e6c94e2d7881">
        <source>countApps(appName,userInfo:String; elapsedSeconds:Integer):Integer;

vars
	proc:Process;
	error:Boolean;
	count:Integer;
begin
	on Exception do app.jtdObjNotFoundExceptionHandler(exception, error);
	foreach proc in Process.instances 
	where proc.getUserCode = process.getUserCode 
	and proc.persistentApp.name = appName 
	and (userInfo = "*" or proc.userInfo = userInfo) do
		app.logMessageGraduated("found " &amp; appName &amp; " " &amp; proc.String &amp; " " &amp; proc.userCode &amp; "@" &amp; userInfo, elapsedSeconds);
		count := count + 1;
	endforeach;
	
	return count;
end;
</source>
        <Parameter name="appName" type="String"/>
        <Parameter name="userInfo" type="String"/>
        <Parameter name="elapsedSeconds" type="Integer"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="doExtract" id="4b67c85f-8bea-4ecf-8e36-50d7948d45c1">
        <updating/>
        <source>doExtract(currentRun:Integer) updating;

vars
	retCode, files, folders : Integer;
begin
	app.logMessage(method.name &amp; " Removing the old database");
	app.housekeepingRemoveDir("t:\"&amp;myBmkControlSession.envid, files, folders, -2, true);
	app.logMessage(method.name &amp; " Removing the old logs"); 
	app.housekeepingRemoveDir("u:\"&amp;myBmkControlSession.envid, files, folders, -2, true);
	
	app.logMessage(method.name &amp; " old database and logs are removed");
	
	app.logMessage(method.name &amp; " Extracting the archive for run " &amp; currentRun.String);
	retCode:=app.doCmd('"c:\Program Files\WinRAR\WinRAR.exe" x v:\autorunarchives\'&amp;myBmkControlSession.product&amp;'\'&amp;myBmkControlSession.envid&amp;'.rar t:\', true, true);
	
	if retCode = 0 then
		app.logMessage(method.name &amp; " Finished extract for StdRun " &amp; myBmkControlSession.currentRun.String);
	endif;
	
	if retCode = 1 then
		app.logMessage(method.name &amp; " extract failed with exit code 1, possibly the archive is not found");
	endif;
	
end;

</source>
        <Parameter name="currentRun" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="doFinal" id="34fb9bf2-07b8-4b39-b5f5-77fdf77dfe5a">
        <updating/>
        <source>doFinal() updating;

begin
	app.logMessage(method.name &amp; " Finishing up");
	myCreatorControlForm.stopAllMine;
	
	app.logMessage(method.name &amp; " Sending results email");
	app.sendEmail(myBmkControlSession.developerEmail, 
						app.getJblWorkerConf.getXMLValue("email"),
						"Benchmark for " &amp; myBmkControlSession.product &amp; " (" &amp; myBmkControlSession.envid &amp; ") has completed",
						"Benchmark results are in " &amp; ("\\cnwchcm24\cnwjbl$\BenchMarkResults\" &amp; myBmkControlSession.product &amp; "\" &amp; myBmkControlSession.runid).asFolderName &amp; ".&lt;br&gt;&lt;br&gt;"
						&amp; "totalRuns=" &amp; myBmkControlSession.totalRuns.String);
	
	app.logMessage(method.name &amp; " Finished StdRun " &amp; myBmkControlSession.currentRun.String &amp; ", all runs completed for " &amp; myBmkControlSession.envid &amp; " on session " &amp; session.String);
end;
</source>
    </JadeMethod>
    <JadeMethod name="doStartClientMachines" id="d6d406bb-bf6c-44cd-8c00-79e24409afb0">
        <source>doStartClientMachines();

vars
	i,j,elapsedSeconds:Integer;
	f:File;
	line:String;
begin
	app.logMessage("Stopping any existing CreatorCreators and Creators for this session");
	myCreatorControlForm.stopAllMine;
	while countApps("CreatorCreator", myBmkControlSession.rapHost, elapsedSeconds) &gt; 0 do
		app.logMessageGraduated("Waiting for rapHost CreatorCreator to go away", elapsedSeconds);
		app.doWindowEvents(1000);
		elapsedSeconds := elapsedSeconds + 1;
	endwhile;
	
	app.logMessage("Queue CreatorCreator jobs");
	create f transient;
	f.usePresentationFileSystem := false;
	f.mode := File.Mode_Output;
	line := "startcreatorcreatoraccount,," &amp; process.getUserCode &amp; ";" &amp; session.String &amp; ";" &amp; app.computerName.toLower &amp; ",,,,,,";
	foreach i in 1 to myBmkControlSession.numClients do
		f.fileName := app.miscPath &amp; "\jobs\benchmarkclientmachine\creatorin\JBLCLIENT" &amp; app.computerName.toLower &amp; "_" &amp; i.String &amp; "_StartRemoteCreatorsQtyBased.job";
		f.writeLine(line);
		f.close;
	endforeach;
	
	app.logMessage("Wait for CreatorCreators to start up");
	elapsedSeconds := 0;
	while countApps("CreatorCreator", "*", elapsedSeconds) &lt; myBmkControlSession.numClients do
		app.logMessageGraduated("Waiting for client machine CreatorCreator(s) to start", elapsedSeconds);
		app.doWindowEvents(1000);
		elapsedSeconds := elapsedSeconds + 1;
	endwhile;
	app.logMessage("Client machine CreatorCreators have all started up");
	myCreatorControlForm.showCreatorCreators;
epilog
	delete f;
end;
</source>
    </JadeMethod>
    <JadeMethod name="doStdRun" id="b2346fe4-74ca-41d8-ab00-c96e602ea04d">
        <updating/>
        <source>doStdRun(currentRun:Integer) updating;

vars
	i,j,retCode:Integer;
	elevenPm : Time;
	controllerDoCommand:String;
begin
	elevenPm.setTime(23,0,0,0);
	while app.actualTime.time &gt; elevenPm do
		app.logMessage(method.name &amp; " Waiting till midnight, to avoid cn_tranlog split over multiple dates");
		app.doWindowEvents(60000);
	endwhile;
	
	app.logMessage(method.name &amp; " Starting StdRun " &amp; currentRun.String &amp; " for " &amp; myBmkControlSession.envid &amp; " on session " &amp; session.String);
	
	myCreatorControlForm.showCreatorCreators;
	startCreatorCreator;
	startCreators;
	startPerfMonLogs;
	startRap;
	startAppServers;
	startControllerApp;
	startDriverApps;
	
	app.logMessage(method.name &amp; " starting the main run");
	controllerDoCommand := "C:\thinbin\" &amp; myBmkControlSession.envid &amp; "\jade.exe appServer=" &amp; myBmkControlSession.appServerHost &amp; " appServerPort=" &amp; myBmkControlSession.controlPort &amp; " schema=JtdControllerSchema app=DoCommand endjade ";
	app.doCmd(controllerDoCommand &amp; "start", true, true);
	
	app.logMessage(method.name &amp; " waiting for the main run to finish");
	app.doWindowEvents(productConfig.getXMLValue("runtimebenchmarksecs").Integer*1000);
	
	app.logMessage(method.name &amp; " stopping the main run");  // it should have auto-stopped already, but we'll issue the command just in case
	app.doCmd(controllerDoCommand &amp; "stop", true, true);
	app.doWindowEvents(5000);
	
	app.logMessage(method.name &amp; " terminating the driver apps");
	app.doCmd(controllerDoCommand &amp; "terminate", true, true);
	// wait a little while for them to stop
	retCode := app.doCmd('C:\cardinal\bin\jbluiinteraction.exe --wintitle="Driver Controller - 0 Nodes, 0 Processes" --keys="{F5}" --wintitleclasshint="Jade:form"', true, true);  // don't really care that much if they don't stop
	
	app.logMessage(method.name &amp; " stopping the controller app");
	retCode := app.doCmd('C:\cardinal\bin\jbluiinteraction.exe --wintitle="Driver Controller" --keys="%{F4}" --wintitleclasshint="Jade:form"', true, true);
	
	app.logMessage(method.name &amp; " stopping the appservers");
	foreach i in 0 to myBmkControlSession.appServers-1 do
		retCode := app.doCmd('C:\cardinal\bin\jbluiinteraction.exe --wintitle="Port ' &amp; (myBmkControlSession.bmkBasePort.Integer+i).String &amp; '" --keys="%{F4}" --wintitleclasshint="Jade:AppServer"', true, true);
	endforeach;
	
	stopControlAppserver;
	stopRap;
	stopPerfMonLogs;
	
	if myBmkControlSession.product = "StartStopTest" then
		makeCnTranlog;
	endif;
	
	saveLogFiles;
	
	myCreatorControlForm.stopCreators;
	app.doWindowEvents(1000);
	
	app.logMessage(method.name &amp; " Finished StdRun " &amp; currentRun.String &amp; " for " &amp; myBmkControlSession.envid &amp; " on session " &amp; session.String);
end;
</source>
        <Parameter name="currentRun" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="doSyncThinbins" id="7e346840-c138-4cda-93ac-4a4ecebb18ba">
        <updating/>
        <source>doSyncThinbins() updating;

begin
	app.logMessage(method.name &amp; " Starting");

	startCreatorCreator;
	startRap;
	myCreatorControlForm.syncMasterThinbin;
	setNoteType(Bmk0_Sync_Thinbin*-1);
	myCreatorControlForm.syncThinbin;
	waitForNotes(myBmkControlSession.numClients + 1);  // server does this also (need client machines logged on for this to work)
	
	stopControlAppserver;
	stopRap;
	myCreatorControlForm.stopRapHostCreatorCreator;
	app.doWindowEvents(1000);

	app.logMessage(method.name &amp; " Finished");
end;
</source>
    </JadeMethod>
    <JadeMethod name="makeCnTranlog" id="5f96cc71-d355-4471-9a2b-a0837ec11203">
        <source>makeCnTranlog();

vars
	f : File;
begin
	app.logMessage(method.name &amp; " running jblstdruncnlogmaker.exe to create cntranlog");
	app.doWindowEvents(60000);	//sleep for a bit to get a couple of samples after the rap's memory is returned
	create f transient;
	f.mode := File.Mode_Output;
	f.fileName := "C:\thinbin\tools\StartStopTest_cnlogmaker.conf";
	f.writeLine('&lt;uniqueid&gt;');
	f.writeLine(productConfig.getXMLValue("envid").asXML("envid"));
	f.writeLine(productConfig.getXMLValue("product").asXML("product"));
	f.writeLine(productConfig.getXMLValue("csversion").asXML("csversion"));
	f.writeLine('&lt;/uniqueid&gt;');
	app.doCmd('C:\cardinal\bin\jblstdruncnlogmaker.exe c:\thinbin\tools\Autodino_cnlogmaker.conf', true, true);
end;
</source>
    </JadeMethod>
    <JadeMethod name="run" id="a7714805-3719-4019-af91-1c1e0f51fb0d">
        <updating/>
        <source>run() updating;

begin
	session := app.computerName[8:end].Integer;
	myBmkControlSession := global.allBmkControls[session];
	productConfig := myBmkControlSession.getProductConfig(myBmkControlSession.product);
	create myCreatorControlForm transient;
	myCreatorControlForm.myBmkControl := myBmkControlSession;
	
	if myBmkControlSession.currentRun = 0 then
		app.logMessage("Starting initial setup for " &amp; myBmkControlSession.envid &amp; " on session " &amp; session.String);
		beginTransaction;
		myBmkControlSession.currentRun := 1;
		commitTransaction;
		doStartClientMachines;
		doExtract(myBmkControlSession.currentRun);
		doSyncThinbins;
		app.logMessage("Finished initial setup for " &amp; myBmkControlSession.envid &amp; " on session " &amp; session.String);
	else
		// do a run
		doStdRun(myBmkControlSession.currentRun);
		
		// extract for the next run, or send email if all finished
		if myBmkControlSession.currentRun &lt; myBmkControlSession.totalRuns then
			beginTransaction;
			myBmkControlSession.currentRun := myBmkControlSession.currentRun + 1;
			commitTransaction;
			doExtract(myBmkControlSession.currentRun);
			
		else
			doFinal;
		endif;
	endif;
	
	terminate;
epilog
	endNotificationForSubscriber(myCreatorControlForm);
	delete myCreatorControlForm;
end;
</source>
    </JadeMethod>
    <JadeMethod name="saveLogFiles" id="35d30821-0614-4cef-a4be-ae1c43490b17">
        <updating/>
        <source>saveLogFiles() updating;

begin
	setNoteType(Bmk0_Save_Log_Files*-1);
	myCreatorControlForm.saveLogFiles;
	waitForNotes(1);
end;
</source>
    </JadeMethod>
    <JadeMethod name="setNoteType" id="71e61211-46a9-470d-98f4-f92bac43fe83">
        <updating/>
        <source>setNoteType(type:Integer) updating;

begin
	noteCount := 0;
	noteType := type;
end;
</source>
        <Parameter name="type" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setup" id="3888e001-164c-4990-b455-dffb184bac3c">
        <updating/>
        <source>setup() updating;

begin
	beginNotification(process, StartStdRun, Response_Continuous, 0);
	beginNotification(global, Bmk0_Sync_Thinbin*-1, Response_Continuous, 0);
	beginNotification(global, Bmk0_Start_Creators*-1, Response_Continuous, 0);
	beginNotification(global, Bmk0_Start_PerfMonLog*-1, Response_Continuous, 0);
	beginNotification(global, Bmk0_Stop_PerfMonLog*-1, Response_Continuous, 0);
	beginNotification(global, Bmk_Start_App*-1, Response_Continuous, 0);
	beginNotification(global, Bmk0_Save_Log_Files*-1, Response_Continuous, 0);
	beginNotification(global, Bmk_Result, Response_Continuous, 0);
end;
</source>
    </JadeMethod>
    <JadeMethod name="startAppServers" id="77f95833-9e5e-4f6e-8f73-9be927a1992c">
        <source>startAppServers();

vars
	i,j,retCode:Integer;
begin
	myCreatorControlForm.startAppServers;
	app.logMessage(method.name &amp; " waiting for appservers to start");
	foreach i in 0 to myBmkControlSession.appServers-1 do
		retCode := app.doCmd('C:\cardinal\bin\jbluiinteraction.exe --wintitle="Port ' &amp; (myBmkControlSession.bmkBasePort.Integer+i).String &amp; '" --keys="{F5}" --wintitleclasshint="Jade:AppServer"', true, true);
		if retCode = 108 then
			app.logMessage(method.name &amp; " could not find appserver ");
			return;
		endif;
	endforeach;
	app.logMessage(method.name &amp; " all appservers have started");
end;
</source>
    </JadeMethod>
    <JadeMethod name="startControllerApp" id="05e3ac80-ae88-4d43-b5c3-6564f6892d72">
        <updating/>
        <source>startControllerApp() updating;

vars
	i,j,retCode:Integer;
begin
	myCreatorControlForm.startControllerApp;
	app.doWindowEvents(1000);  // wait for notes
	app.logMessage(method.name &amp; " waiting for controllerApp to start");
	retCode := app.doCmd('C:\cardinal\bin\jbluiinteraction.exe --wintitle="Driver Controller" --keys="{F5}" --wintitleclasshint="Jade:form"', true, true);
	if retCode = 108 then
		app.logMessage(method.name &amp; " could not find the controller app");
	endif;
	app.doWindowEvents(0);
	app.logMessage(method.name &amp; " controller app has started");
end;
</source>
    </JadeMethod>
    <JadeMethod name="startCreatorCreator" id="9866acfd-883a-4381-b190-be8f3b0fb852">
        <updating/>
        <source>startCreatorCreator() updating;

vars
	retCode,elapsedSeconds:Integer;
begin
	app.logMessage("Ensuring the rapHost CreatorCreator is not already running");
	while countApps("CreatorCreator", myBmkControlSession.rapHost, elapsedSeconds) &gt; 0 do
		app.doWindowEvents(1000);
		elapsedSeconds := elapsedSeconds + 1;
	endwhile;
	
	app.logMessage(method.name &amp; " Starting the CreatorCreator on " &amp; myBmkControlSession.rapHost);
	retCode := app.doCmd('"C:\thinbin\creator\jade.exe" appServer=cnwchcs118.cnw.co.nz appServerPort=51824 schema=BenchmarkControlSchema app=CreatorCreator', true, false);

	elapsedSeconds := 0;
	while countApps("CreatorCreator", myBmkControlSession.rapHost, elapsedSeconds) &lt; 1 do
		app.doWindowEvents(250);
	endwhile;
	myCreatorControlForm.showCreatorCreators;
end;
</source>
    </JadeMethod>
    <JadeMethod name="startCreators" id="96f71802-afa9-446a-8ded-fd861282e7df">
        <updating/>
        <source>startCreators() updating;

vars
	elapsedSeconds:Integer;
begin
	//stop any existing creators 
	myCreatorControlForm.stopCreators;
	
	app.logMessage("Waiting for any existing Creators to go away");
	while countApps(session.asCreatorName, "*", elapsedSeconds) &gt; 0 do
		app.doWindowEvents(1000);
		elapsedSeconds := elapsedSeconds + 1;
	endwhile;
	
	//start creators 
	setNoteType(Bmk0_Start_Creators*-1);
	myCreatorControlForm.startCreators;
	waitForNotes(myBmkControlSession.numClients);
	app.doWindowEvents(5000);
	myCreatorControlForm.showCreatorCreators;
end;
</source>
    </JadeMethod>
    <JadeMethod name="startDriverApps" id="e496ea5c-dda3-4790-8449-82d8d43dd975">
        <updating/>
        <source>startDriverApps() updating;

begin
	setNoteType(Bmk_Start_App*-1);
	myCreatorControlForm.startDriverApps;
	waitForNotes(productConfig.getXMLValue("NumCreators").Integer);
end;
</source>
    </JadeMethod>
    <JadeMethod name="startPerfMonLogs" id="3b9c85dc-d642-4eb8-a37d-0e2a0ce0b42a">
        <updating/>
        <source>startPerfMonLogs() updating;

begin
	setNoteType(Bmk0_Start_PerfMonLog*-1);
	myCreatorControlForm.doPerfMonLogStart;
	waitForNotes(myBmkControlSession.numClients+1);
end;
</source>
    </JadeMethod>
    <JadeMethod name="startRap" id="88e3f936-36d7-43f9-92ad-d5f880694807">
        <updating/>
        <source>startRap() updating;

vars
	retCode:Integer;
begin
	//start Rap and control Appserver
	myCreatorControlForm.startRap;
	app.doWindowEvents(1000);  // allow for notification to be logged
	retCode := app.doCmd('C:\cardinal\bin\jbluiinteraction.exe --wintitle="Port ' &amp; myBmkControlSession.controlPort.String &amp; '" --keys="{F5}" --wintitleclasshint="Jade:AppServer"', true, true);
	if retCode = 108 then
		app.logMessage(method.name &amp; " could not find the control appserver");
	endif;
	app.doWindowEvents(0);
	app.logMessage(method.name &amp; " rap and control appserver have started");
end;
</source>
    </JadeMethod>
    <JadeMethod name="stopControlAppserver" id="8a3b3a1c-ee59-4a50-8da9-c5379c447bf9">
        <updating/>
        <source>stopControlAppserver() updating;

vars
	retCode:Integer;
begin
	app.logMessage("Stopping the control appserver");
	retCode := app.doCmd('C:\cardinal\bin\jbluiinteraction.exe --wintitle="Port ' &amp; myBmkControlSession.controlPort.String &amp; '" --keys="%{F4}" --wintitleclasshint="Jade:AppServer"', true, true);
	//C:\cardinal\bin\jbluiinteraction.exe --wintitle="Do you still wish to close?" --button="&amp;Yes" --wintitleclasshint="Static"
end;
</source>
    </JadeMethod>
    <JadeMethod name="stopPerfMonLogs" id="794e23cf-fe67-4f2a-b3b1-491bfa6753e7">
        <updating/>
        <source>stopPerfMonLogs() updating;

begin
	setNoteType(Bmk0_Stop_PerfMonLog*-1);
	myCreatorControlForm.doPerfMonLogStop;
	waitForNotes(myBmkControlSession.numClients+1);
end;
</source>
    </JadeMethod>
    <JadeMethod name="stopRap" id="8109df4e-31ed-4ff6-b6a8-7d7f52c338f2">
        <updating/>
        <source>stopRap() updating;

vars
	retCode:Integer;
begin
	app.logMessage("Stopping the rap");
	retCode := app.doCmd('C:\cardinal\bin\jbluiinteraction.exe --wintitle="' &amp; productConfig.getXMLValue("rapport") &amp; '" --keys="%{F4}" --wintitleclasshint="JADRAP"', true, true);
	retCode := app.doCmd('C:\cardinal\bin\jbluiinteraction.exe --wintitle="TERMINATION" --button="&amp;Yes"', true, true);
	app.doWindowEvents(5000);  // wait for it to finish going away
end;
</source>
    </JadeMethod>
    <JadeMethod name="userNotification" id="8d308106-9ebc-4ad1-a640-b80716a037b0">
        <updating/>
        <source>userNotification(eventType:Integer; o:Object; tag:Integer; userInfo:Any) updating;

begin
	if eventType &lt;&gt; Bmk_Result and eventType &lt;&gt; StartStdRun then
		app.logMessage(method.qualifiedName
				&amp; " eventType=" &amp; currentSchema.getConstantName(eventType.String)
				&amp; " theObject=" &amp; o.String  // o.display.replace(CrLf,", ")
				&amp; " tag=" &amp; tag.String
				&amp; " userInfo=" &amp; userInfo.String); /**/
	endif;
	
	if eventType = StartStdRun then
		run;

	elseif eventType = Bmk_Result then
		app.logMessage(userInfo.String);

	elseif eventType = noteType then
		noteCount := noteCount + 1;
	endif;
end;
</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="o" type="Object"/>
        <Parameter name="tag" type="Integer"/>
        <Parameter name="userInfo" type="Any"/>
    </JadeMethod>
    <JadeMethod name="waitForNotes" id="70c2c85d-96b3-4541-98d4-8c8d40f72452">
        <updating/>
        <source>waitForNotes(target:Integer) updating;

vars
	elapsedSeconds:Integer;
begin
	while noteCount &lt; target do
		app.logMessageGraduated(method.name &amp; " noteCount=" &amp; noteCount.String &amp; ", target=" &amp; target.String &amp; ", waiting...", elapsedSeconds);
		app.doWindowEvents(1000);
		elapsedSeconds := elapsedSeconds + 1;
	endwhile;
	app.logMessage(method.name &amp; " noteCount=" &amp; noteCount.String &amp; ", target=" &amp; target.String &amp; ", carrying on");
end;
</source>
        <Parameter name="target" type="Integer"/>
    </JadeMethod>
</Class>
