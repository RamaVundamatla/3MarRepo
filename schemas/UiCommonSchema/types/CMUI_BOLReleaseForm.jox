    <JadeMethod name="handleExceptionObject" id="5b56c00a-e18f-4157-9e94-2f01b07ba870">
        <source>handleExceptionObject(exObj : Exception; _obj : CM_Object io) : Integer protected;
//--------------------------------------------------
// Created:	10 February 2006 By: cnwgd1
//--------------------------------------------------
constants
	ObjectNotFound	: Integer = 4;
	ObjectDeleted	: Integer = 1072;
begin

	if exObj.errorCode = ObjectNotFound 
	or exObj.errorCode = ObjectDeleted then
		_obj := null;
		return Ex_Resume_Next;
	endif;

	return Ex_Pass_Back;

end;</source>
        <access>protected</access>
        <Parameter name="exObj" type="Exception"/>
        <Parameter name="_obj" type="CM_Object" usage="io"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="handleSystemNotification" id="34f269f0-ff37-4235-9202-9a6747f7e8d8">
        <updating/>
        <source>handleSystemNotification(eventType: Integer; theObject: Object; eventTag: Integer) updating;
//---------------------------------------
// Created: April 2006 By: cnwgd1
//---------------------------------------
vars
	idx : Integer;
	tmpTI : CM_TrackedItem;
	str : String;
begin

	if theObject = null then
		return;
	endif;
	
	if (not global.isValidObject(theObject)) then
		self.tblReleases.removeDeletedObject(theObject);
		return;
	endif;
	
	if CM_BulkRelease.hasInstance(theObject) then
		self.tblReleases.findObjectInRow(theObject, idx);
		if idx &lt; 1 then
			return;
		endif;
		
		str := theObject.CM_BulkRelease.getAttributeStringForDefArray(self.tblReleases.allTblDataEntRows);
		self.tblReleases.accessCell(idx, 1).text := str;
		
	elseif CM_BOLIn.hasInstance(theObject) then
		if self.myCurrentBOL = theObject then
			self.setMyCurrentBol(theObject.CM_BOLIn);
		endif;
	elseif CM_TrackedItem.hasInstance(theObject) then

		tmpTI := theObject.CM_TrackedItem;
		self.tblData.findObjectInRow(tmpTI, idx);
		if idx &lt; 1 then
			return;
		endif;

		str := tmpTI.getAttributeStringForDefArray(self.tblData.allTblDataEntRows);
		self.tblData.accessCell(idx, 1).text := str;

		if tmpTI.site = TI_SITE_OFFSITE then
			self.tblData.accessRow(idx).backColor := Gray;
		elseif tmpTI.hasStops then
			self.tblData.accessRow(idx).backColor := Red;
		elseif tmpTI.site &lt;&gt; TI_SITE_ONSITE then
			self.tblData.accessRow(idx).backColor := LightBlue;
		elseif idx mod 2 = 0 then
			self.tblData.accessRow(idx).backColor := self.colorRow1;
		else
			self.tblData.accessRow(idx).backColor := self.colorRow2;
		endif;
		
		if self.myCurrentBOL &lt;&gt; null then
			self.displayBulkReleasesForBOL();
		else
			self.displayBulkReleasesForVoyage();			
		endif;

		self.updateTotals();		
		
	endif;	
	
end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="includeRelease" id="4f10c179-bfa6-4af5-bffd-920ddb340075">
        <source>includeRelease(_release : CM_BulkRelease) : Boolean;
//--------------------------------------------------
// Created:	13 February 2006 By: cnwgd1
//--------------------------------------------------
vars

begin
	if _release = null then
		return false;
	endif;
	
	if self.myCurrentVoyage &lt;&gt; null then
		if _release.myVoyage &lt;&gt; self.myCurrentVoyage then
			return false;
		endif;
	endif;
	
	return true;
end;</source>
        <Parameter name="_release" type="CM_BulkRelease"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="initForm" id="2216a044-d81e-4940-b78d-b7f8ae9bf984">
        <source>initForm();
//--------------------------------------------------
// Created:	10 February 2006 By: cnwgd1
//--------------------------------------------------
vars
	tmpDef : EntTableDef;
	tmpTable : CM_DataTable;
begin

	tmpTable := self.tblData;		
	tmpDef := app.myController.getEntTableDef(ETDef_GCReleaseData);
	tmpTable.setMyDataClass(CM_TrackedItem);
	tmpTable.setTblDataEntRowsFromDef(tmpDef);
	tmpTable.selectionType := CM_DataTable.SelectionType_Row;
	tmpTable.multiSelect := tmpTable.MultiSelect_Simple;

	tmpTable := self.tblReleases;
	tmpDef := app.myController.getEntTableDef(ETDef_BOLReleaseRecord);
	tmpTable.setTblDataEntRowsFromDef(tmpDef);
	tmpTable.multiSelect := tmpTable.MultiSelect_Simple;	
	tmpTable.selectionType := CM_DataTable.SelectionType_Row;
	tmpTable.tabKey := J_key_Tab;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="loadCmbBolFromVoyageBOLs" id="658604cf-0b6c-4724-809e-3a785a313d33">
        <updating/>
        <source>loadCmbBolFromVoyageBOLs(_cmb : CMUI_ComboBox input; _bol : CM_BOLIn; _voyage : CM_Voyage)updating;
//----------------------------------------------------------------------
//  Created by cnwsh3
//	Date 23 February 2009
//
// Implemented version:
// 
//----------------------------------------------------------------------
vars
	bol : CM_BOL;
	idx : Integer;
begin
	_cmb.clear();
	
	if _voyage = null then // or
	  // _voyage.myGeneralCargoVoyage = null then // CCMS SFW1039 PAR18889 - US Customs &amp; Border Protection messaging changes.
		return;
	endif;
	
	foreach bol in _voyage.allBOLInByTypeStatusNumDT do
		idx := _cmb.addItemObject(bol.number, bol);
		if bol = _bol then
			_cmb.listIndex := idx;
		endif;
	endforeach;
	self.setMyCurrentBol(_cmb.listObject.CM_BOL);
epilog
end;</source>
        <Parameter name="_cmb" type="CMUI_ComboBox" usage="input"/>
        <Parameter name="_bol" type="CM_BOLIn"/>
        <Parameter name="_voyage" type="CM_Voyage"/>
    </JadeMethod>
    <JadeMethod name="loadComboBOL" id="08d1e622-a116-4017-9949-f7e560b6fba2">
        <updating/>
        <source>loadComboBOL(_cmb : CMUI_ComboBox input; _bol : CM_BOLIn; _voyage : CM_Voyage) updating;

vars
	tmpMan : CM_Manifest;
	tmpBOL : CM_BOL;
	tmpUser : CM_User;
	tmpDict : CM_ManifestByIdDict;
	idx : Integer;
begin
	_cmb.clear();
	
	if _voyage = null then // or // CCMS SFW1039 PAR18889 - US Customs &amp; Border Protection messaging changes.
	  // _voyage.myGeneralCargoVoyage = null then
		return;
	endif;
	
	
	//if _voyage.myGeneralCargoVoyage &lt;&gt; null then
		//tmpDict := _voyage.myGeneralCargoVoyage.allManifestsById; // CCMS SFW1039 PAR18889 - US Customs &amp; Border Protection messaging changes.
		tmpDict := _voyage.allManifestsById;
		
		foreach tmpMan in tmpDict do
			foreach tmpBOL in tmpMan.allBOLsDT do
				idx := _cmb.addItemObject(tmpBOL.number, tmpBOL);
				if tmpBOL = _bol then
					_cmb.listIndex := idx;
				endif;
			endforeach;
		endforeach;
	//endif;
	
	self.setMyCurrentBol(_cmb.listObject.CM_BOL);
		
end;</source>
        <Parameter name="_cmb" type="CMUI_ComboBox" usage="input"/>
        <Parameter name="_bol" type="CM_BOLIn"/>
        <Parameter name="_voyage" type="CM_Voyage"/>
    </JadeMethod>
    <JadeMethod name="loadDataForFirstTime" id="d3b0ff56-6a1e-4b3d-a0b0-a461923ad3f0">
        <updating/>
        <source>loadDataForFirstTime() updating, protected;
//--------------------------------------------------
// Created:	17 November 2005 By: cnwgd1
//--------------------------------------------------
vars
begin
	inheritMethod();
	self.doRefresh();
end;</source>
