    <JadeWebServicesMethod name="getOperatorsForVoyage" id="24303d53-a03c-4a31-9f30-b0f4feabfcc8">
        <usesRPC>default</usesRPC>
        <source>getOperatorsForVoyage(voyageCode : String) : WS_OperatorsResponse webService;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
01 Oct 2008	cnwkao1	Initial creation

*/
vars
	operatorReq 	: WS_OperatorsRequest;
	
begin	
	create operatorReq transient;
	
	if voyageCode &lt;&gt; null then //if no voyage is passed in it will return the full list of operators, which we don't want for this particular method
		operatorReq.voyageCode := voyageCode;
		return self.getOperators(operatorReq);	
	endif;
	
	return null;
	
	
epilog
	delete operatorReq;
	
end;</source>
