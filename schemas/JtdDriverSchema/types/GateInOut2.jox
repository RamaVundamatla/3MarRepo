    <JadeMethod name="zAllocateRFIDTagAndReaders" id="4aab9097-dd62-47ef-b08b-2c198337bdac">
        <updating/>
        <source>zAllocateRFIDTagAndReaders() updating;

vars
	iter:Iterator;
	count:Integer;
	pxyTagReader,tagReader:CM_RFIDTagReader;
	code:String;  // will also be used as the 'windowsMachineName' attribute
begin
	// find two gate lane readers - one in, one out
	iter:=app.myPassport.myTerminal.allRFIDTagReadersByCode.createIterator;
	while true do
		iter.next(tagReader);
		if tagReader = null then
			if count = 0 then  // no readers in db
				break;
			endif;
			myRFIDTagReaderGLIn:=null;  // ensure first reader is IN, second is OUT (in case there are an odd number present)
			iter.reset;
			iter.next(tagReader);
		endif;
		if tagReader.context &lt;&gt; TagReaderContext_GateLane then
			continue;
		endif;
		count:=count+1;
		if count &gt; (app.profileSequenceId * 2) then
			if myRFIDTagReaderGLIn &lt;&gt; null then
				myRFIDTagReaderGLOut:=tagReader;
				break;
			else
				myRFIDTagReaderGLIn:=tagReader;
			endif;
		endif;
	endwhile;
	
	// find crane reader
	/*already allocated
	foreach tagReader in app.myPassport.myTerminal.allRFIDTagReadersByCode
	where tagReader.context = TagReaderContext_Machine do
		myRFIDTagReaderRTG:=tagReader;
		break;
	endforeach;
	*/
	// now generate one for the user's pc - it will be deleted in the stop method
	//th2 27/12/06 - N.B - the line of code below must correspond with the
	//match condition code in app::beginRFIDTagNoteWindowsPC for the CMUI_RFIDTag form to correctly listen out for
	//notifications of RFID tag swipes.
	code:=app.myUser.code&amp;"_"&amp;app.sequenceId.String;
	
	myRFIDTagReaderPC:=app.myPassport.myTerminal.allRFIDTagReadersByCode[code];
	if myRFIDTagReaderPC &lt;&gt; null then
		beginTransaction;
		delete myRFIDTagReaderPC;
		commitTransaction;
	endif;
	
	create pxyTagReader transient;
	/*pxyTagReader.setProxy(code,//we'll use the user code for the devices' code and it's PC name
							'RFID tag reader for process ' &amp; app.sequenceId.String,
							'ACS7CE',
							null, //mac address not used
							null, //IP address not used
							(60160 + app.sequenceId), //port number not actually used, but only because we're not using BGP
							TagReaderContext_WindowsPC,
							null,
							null,
							code);/**/
	app.myPassport.warningsAcknowledged := true;
	app.myPassport.setWarningsIgnored(true);
	
	app.myTrxCA.trxCreateRFIDTagReader(pxyTagReader,
										myRFIDTagReaderPC,
										app.myPassport.myTerminal,
										app.myPassport);						
	assert(app.myPassport.trxCompletedOK, app.myPassport.allErrorWarnings);

	app.logMessage("Using RFID tag readers "&amp;myRFIDTagReaderPC.code&amp;", "&amp;myRFIDTagReaderGLIn.code&amp;", "&amp;myRFIDTagReaderGLOut.code&amp;", "&amp;myRFIDTagReaderRTG.code);
epilog
	delete iter;
	delete pxyTagReader;
end;
</source>
    </JadeMethod>
    <JadeMethod name="zClearRoadJob" id="6b862763-943c-4966-9a05-eab3c9421b5d">
        <updating/>
        <source>zClearRoadJob(rj:CM_RoadJob input) updating;

begin
	//move any left over queued containers
	if rj &lt;&gt; null then
		app.logMessage(method.qualifiedName&amp;" clearing "&amp;rj.String);
		exclusiveLock(app.myRoot.allPilots);
		zRTGContainerDrop(rj, rj.allReceiveTrackedItems);
		exclusiveLock(app.myRoot.allPilots);
		zRTGContainerDrop(rj, rj.allReleaseTrackedItems);
		
		exclusiveLock(app.myRoot.allPilots);
		beginTransaction;
		rj.erase(NORMAL_ERASE);
		commitTransaction;
	endif;
end;
</source>
        <Parameter name="rj" type="CM_RoadJob" usage="input"/>
    </JadeMethod>
    <JadeMethod name="zGetSheetsOnGateForm" id="08d100b0-f9c3-4a4f-94af-24d6ba6981e3">
        <source>zGetSheetsOnGateForm();

vars
	fld:CMUI_Folder;
	ctl:Control;
	i:Integer;
begin
	fld := myGateInOutForm.getPropertyValue('fldInOut').CMUI_Folder;
	foreach i in 1 to myGateInOutForm.controlCount do
		ctl:=myGateInOutForm.controls(i);
		if ctl.parent = fld
		and ctl.visible = true
		and ctl.isKindOf(CMUI_Sheet) then
			allGateInOutFormSheets.add(ctl);
		endif;
	endforeach;
end;

</source>
    </JadeMethod>
    <JadeMethod name="zRTGContainerDrop" id="857e80d6-af90-46b4-b0d3-9dc3a95ddeb8">
        <source>zRTGContainerDrop(_roadJob:CM_RoadJob; _allTrackedItems:CM_TISet);
//adapted from MobileServerSchema::CM_UtilityAgent::utlMoveTI
vars
	ti				: CM_TrackedItem;
	moveController	: CMIF_MoveController;
begin
	create moveController transient;
	moveController.setMyMachine(self.myRTGCrane);
	moveController.setMoveMode(REAL_MODE);
	moveController.isRadioTelemetryMove := true;
	moveController.isSystemMove := true;
	moveController.isOverstowMove := false;
	moveController.isForcedMove := true;
	
	foreach ti in _allTrackedItems do
		if ti.myPrimaryQueuedLocation = null then
			continue;
		endif;
		
		app.logMessage(method.qualifiedName &amp; ' moving container ' &amp; ti.id &amp; ' to location ' &amp; ti.myPrimaryQueuedLocation.getFullId);
		moveController.setMyTrackedItem(ti);
		moveController.setMyToPrimaryLocation(ti.myPrimaryQueuedLocation);
		moveController.setMyWorkListEntry(_roadJob.getWLEForTI(ti));
		exclusiveLock(app.myPassport.myTerminal.allVehicleVisits);
		app.myTrxUA.trxMoveTrackedItem(moveController, app.myPassport);
		assert(app.myPassport.trxCompletedOK, app.myPassport.allErrorWarnings);
	endforeach;

epilog
	delete moveController;
end;
</source>
        <Parameter name="_roadJob" type="CM_RoadJob"/>
        <Parameter name="_allTrackedItems" type="CM_TISet"/>
    </JadeMethod>
    <JadeMethod name="zSetMainExtraValueOnGateForm" id="33e179e6-e6bb-4f13-a65c-a003f9ae2ae1">
        <source>zSetMainExtraValueOnGateForm(rowName:String; value:Any; _sheet : CMUI_Sheet);
//	Entry sheets are cloned off for entry, and in a schema we can't see - hence ugly code
vars
	fld			: CMUI_Folder;
	sheet		: CMUI_Sheet;
	tblMain,
	tblExtra	: CM_EntryTable;
	cellControl	: Control;
	row			: Integer;
begin
	sheet := _sheet;
	if sheet = null then
		fld := myGateInOutForm.getPropertyValue('fldInOut').CMUI_Folder;
		sheet := fld.topSheet.CMUI_Sheet;  // actually a GTE_Sheet but we can't see that
	endif;
	tblMain := sheet.getPropertyValue('myTblMain').CM_EntryTable;
	tblExtra := sheet.getPropertyValue('myTblExtra').CM_EntryTable;
	
	row := tblMain.getRow(rowName);
	if row &gt; 0 then
		tblMain.setValue(row, value);
		cellControl := tblMain.accessCell(row, CM_EntryTable.ColumnValue).cellControl;
	else
		row := tblExtra.setValueByName(rowName, value);
		if row &gt; 0 then
			cellControl := tblExtra.accessCell(row, CM_EntryTable.ColumnValue).cellControl;
		endif;
	endif;
	
	if CMUI_ComboBox.hasInstance(cellControl) then
		cellControl.CMUI_ComboBox.text := value.String;
		cellControl.CMUI_ComboBox.lostFocus(cellControl.CMUI_ComboBox);
	//elseif CMUI_TextBox then
		//etc
	endif;
end;

</source>
        <Parameter name="rowName" type="String"/>
        <Parameter name="value" type="Any"/>
        <Parameter name="_sheet" type="CMUI_Sheet"/>
    </JadeMethod>
</Class>
