    <DbClassMap file="jsslicensemaint_transient"/>
    <ImplicitInverseRef name="myConstant" id="3a1e36fb-0dad-4958-b76e-2c828a027dd5">
        <embedded/>
        <type name="Constant"/>
        <access>readonly</access>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="myProduct" id="12f7f260-fdef-415a-a759-440ac57cd980">
        <embedded/>
        <type name="JSSLKProduct"/>
        <access>readonly</access>
    </ImplicitInverseRef>
    <JadeMethod name="setConstant" id="0ce46f5e-c797-4a4e-ac93-a43a3b52625b">
        <updating/>
        <source>setConstant(pTheConstant:Constant) updating;
// --------------------------------------------------------------------------------
// Created:		04 April 2003 by cnwdad1
//
// Purpose:		Sets a reference to the receiver's Global Constant.
//
// Parameters:	pTheConstant - The Global Constant being imported.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if self.myConstant &lt;&gt; pTheConstant then
		self.myConstant	:=	pTheConstant;
	endif;
end;</source>
        <Parameter name="pTheConstant" type="Constant"/>
    </JadeMethod>
    <JadeMethod name="setProduct" id="26acad7c-0e1a-4985-a84d-f69c1f0f4b9e">
        <updating/>
        <source>setProduct(pTheProduct:JSSLKProduct) updating;
// --------------------------------------------------------------------------------
// Created:		04 April 2003 by cnwdad1
//
// Purpose:		Sets a reference to the receiver's Product.
//
// Parameters:	pTheProduct - The Product which the Component (represented by the
//					Global Constant) will belong to.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if self.myProduct &lt;&gt; pTheProduct then
		self.myProduct	:=	pTheProduct;
	endif;
end;</source>
        <Parameter name="pTheProduct" type="JSSLKProduct"/>
    </JadeMethod>
</Class>
