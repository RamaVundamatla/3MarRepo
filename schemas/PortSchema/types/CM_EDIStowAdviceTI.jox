    <JadeMethod name="canUserSet" id="174c919c-4e26-483b-af1a-09947661c5d6">
        <source>canUserSet(_propName: String): Boolean;
//
// 30 Jun 2014	cnwrs1	Par 34702 - Add support for JMT XML
//
//06 August 2018	jlgrs1	TFS 40086 JMT Not all EDI TrackedItem stringArray are exposed to the EDI JMT Internal
// 30 Apr 2019	jlgrs1	TFS40086 JMT Not all EDI TrackedItem stringArray are exposed to the EDI JMT Internal
//
vars

begin
//	if _propName = CM_EDIStowAdviceTI::optDischargePorts.name or
	if _propName = CM_EDIStowAdviceTI::imCodes.name then
//	   _propName = CM_EDIStowAdviceTI::dischargePorts.name then
		return false;
	else
		return inheritMethod(_propName);
	endif;
end;
</source>
        <Parameter name="_propName" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="create" id="8da2cf4e-2534-48cf-b3a0-d5e53d9b2475">
        <updating/>
        <source>create() updating;
/*
----------   ----------  --------------------------------------------------
Created:	18 September 2007 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars

begin
	self.messageMode := CM_EDITrackedItem.EDI_ACTION_ADD;
	self.temperature := NULL_TEMPERATURE;

end;


</source>
    </JadeMethod>
    <JadeMethod name="createAndGateInTesting" id="27051a80-54e4-40b1-bbc7-1d090ce91293">
        <source>createAndGateInTesting(_terminal: CM_Terminal; _mc: CMIF_MoveController input);
//----------------------------------------------------------------
//	Created:	14 June 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
// 04 Mar 2019	jlgrs1	TFS 41913 STWR - Reconfiguration of the EDI Operation form to better handle EDI collection locks while loading 
//
vars
	err				: CM_Error;
	loadPort,number	: String;
	comm			: CM_Commodity;
	voyage			: CM_Voyage;
	port			: CM_Port;
	pxyTI,realTI	: CM_TrackedItem;
	operator		: CM_Operator;
begin

	loadPort := _terminal.getConfig(PortDestCode).String;

	if self.loadPort &lt;&gt; loadPort 
	or self.mode &lt;&gt; CM_EDIStowAdviceTI.MODE_LOA then
		return;
	endif;
	
	//lets make cargo
	pxyTI := _terminal.createTI(self.myCargoType, true);
	    
	voyage := _terminal.lookupVoyage(self.myEDIData.CM_EDIDataStowAdvice.voyageCode, null, false);
	///port := app.myRoot.allPorts[self.dischargePort.reverse[1:3].reverse];
	port := app.myRoot.allPorts[self.dischargePort];
	if self.operatorCode &lt;&gt; null then
		operator := app.myRoot.allOperators[self.operatorCode];
	else
		operator := app.myRoot.allOperators[self.myEDIData.CM_EDIDataStowAdvice.operatorCode];
	endif;
	
	number := app.clock.String;
	
	//set item ()
	pxyTI.zSetPxyId((voyage.code &amp; self.id.padLeadingZeros(3).reverse[1:3] &amp; number.reverse()[1:6])[1:11]);
	pxyTI.zSetPxyOperator(operator);
	pxyTI.zSetPxyTerminal(_terminal);
	pxyTI.zSetPxyCompany(_terminal.companies.first);
	if app.isSubTerminalsOn(_terminal) then
		pxyTI.setSubTerminalDefaultFromTerm(_terminal);		// CCMS 1875
	endif;
	

	pxyTI.changeISOType(self.isoType, null, app.myPassport);
	
	if voyage = null then
		if port = null then
			pxyTI.zSetPxyDischargePort("SYD");
		else
			pxyTI.zSetPxyDischargePort(port.code);
		endif;
	else
		pxyTI.zSetPxyVoyage(voyage, self.myEDIData.CM_EDIDataStowAdvice.voyageCode);
		if port &lt;&gt; null 
		and voyage.includesPort(port) then
			pxyTI.zSetPxyDischargePort(port.code);
		else
			if voyage.allPorts.first.code = loadPort then
				if voyage.allPorts.size &gt; 1 then
					pxyTI.zSetPxyDischargePort(voyage.allPorts.last.code);
				else
					pxyTI.zSetPxyDischargePort("SYD");
				endif;
			else
				pxyTI.zSetPxyDischargePort(voyage.allPorts.first.code);
			endif;
		endif;
	endif;
	
	comm := app.myRoot.allCommodities[self.commodity];
	
	if comm = null then
		pxyTI.zSetPxyCommodity("MT");
	else
		pxyTI.zSetPxyCommodity(self.commodity);
		if comm.requiresPower
		and CM_Container.hasInstance(pxyTI) then
			pxyTI.CM_Container.zSetPxyTemperatureCelsius(comm.minTemp);
			if self.cooledType = ContainerWaterCooled then
				pxyTI.CM_Container.setPropertyValue('coolingType', ContainerWaterCooled);
			else
				pxyTI.CM_Container.setPropertyValue('coolingType', ContainerAirCooled);
			endif;
		endif;
	endif;
	
	pxyTI.zSetPxyWeight(4000);
	pxyTI.zSetPxyBookingReference("EDITEST00001");
	pxyTI.zSetPxyImexStatus(TI_IMEX_STATUS_EXPORT);

	app.myPassport.warningsAcknowledged := true;
	app.myPassport.setIsBackgroundWarningsIgnored(true);

	//create the persistent TI
	app.myTrxCA.trxCreateTrackedItem(pxyTI, realTI, app.myPassport);

	if not app.myPassport.trxCompletedOK then
		/* cnwrl1 17/06/2010 what it was
		if app.myPassport.hasErrors then
			app.writeStatement( "Create TI errors");
			foreach err in app.myPassport.allErrors do
				app.writeStatement( 'CNWJC2 ' &amp; class.name &amp; " " &amp; method.name &amp; " " &amp; err.errorCode.String &amp; " " &amp; err.text);		
			endforeach;
		endif;
		*/
		return;
	endif;	

	//do a move it
	if realTI = null then
		return;
	endif;
	
	_mc.setMyTrackedItem(realTI);
	
	app.myPassport.warningsAcknowledged	:= true;
	app.myTrxUA.trxMoveTrackedItem(_mc, app.myPassport);
	
	/* cnwrl1 17/06/2010 what it was
	if not app.myPassport.trxCompletedOK then
		if app.myPassport.hasErrors then
			app.writeStatement( "Move TI errors");
			foreach err in app.myPassport.allErrors do
				app.writeStatement('CNWJC2 ' &amp; class.name &amp; " " &amp; method.name &amp; " " &amp; err.errorCode.String &amp; " " &amp; err.text);		
			endforeach;
		endif;
	endif;
	*/
	
epilog

//	delete pxyTI;
	
end;
</source>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_mc" type="CMIF_MoveController" usage="input"/>
    </JadeMethod>
    <JadeMethod name="createProxySlotRequest" id="4989de01-0dc2-4186-a3c4-4e241f90aa48">
        <source>createProxySlotRequest(_pxySlot: CM_SlotRequest output; _realSlot: CM_SlotRequest output; _moveType: Integer; _isLoad: Boolean; _voyage: CM_Voyage; _strs: StringArray input; _theSC: CM_SlotController output);
//----------------------------------------------------------------
//	Created:	17 October 2003	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
// 08/04/2011	cnwmh5	PAR #27347 - Add cmsEndLoad or endLoad to epilog so that if error occurs it will not leave in begin load state
vars
	foundHeight : Integer;
	aLC			: CM_LocationsController;
	aSC			: CM_SlotController;
	aSR			: CM_SlotRequest;
	ls			: Boolean;
	isLoad		: Boolean;
begin
	
	if _moveType = NULL_MOVETYPE then
		return;
	endif;
	
	_voyage.findLocation(_strs, false, aLC, foundHeight);
	
	if aLC = null then
		return;
	endif;

	aSC := aLC.CM_SlotController;
	
	_theSC := aSC;
	
	if _isLoad then
		aSR := aSC.mySlotRequestLoad;
		isLoad := true;
	else
		aSR := aSC.mySlotRequestDischarge;
		isLoad := false;
	endif;
	
	if aSR = null then
		create _pxySlot transient;
		_pxySlot.setProxyForCreate(aSC, _moveType, isLoad, null, null);
	else
		_realSlot := aSR;
		app.cmsBeginLoad(ls);
		_pxySlot := aSR.pxyCreateUpdateProxy();
		app.cmsEndLoad(ls);
	endif;
	
	_pxySlot.setProxyForEDI(self, aSC);
	
epilog
	app.cmsEndLoad(ls);			// 08/04/2011 cnwmh5 #27347	
end;</source>
        <Parameter name="_pxySlot" type="CM_SlotRequest" usage="output"/>
        <Parameter name="_realSlot" type="CM_SlotRequest" usage="output"/>
        <Parameter name="_moveType" type="Integer"/>
        <Parameter name="_isLoad" type="Boolean"/>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_strs" type="StringArray" usage="input"/>
        <Parameter name="_theSC" type="CM_SlotController" usage="output"/>
    </JadeMethod>
