    <JadeMethod name="isSimilarQueueArea" id="48d6c4bd-9743-4fa4-8768-e6ef82d16ef3">
        <source>isSimilarQueueArea(_location	:	CM_LocationsController) : Boolean;

vars

	area : CM_TerminalArea;

begin

	area := _location.myTerminalArea;
	
	if self.type = TA_TYPE_RAIL_TRANS then
		if area.isKindOf(CM_Rail) and area.CM_Rail.myTransferArea = self then
			return true;
		endif;
	endif;

  //AJA PAR 3120 29/10/99: Now caters for non-rail areas too !!
	if area = self then			
		return true;
	endif;

	return false;
end;</source>
        <Parameter name="_location" type="CM_LocationsController"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isTIAbleToLand" id="1d762835-0dda-4d4c-b20e-134774e59790">
        <source>isTIAbleToLand(ti: CM_TrackedItem): Boolean;
/*
 ------------------------------------------------------------------------
Created:			27 November 2001 by cnwdwq1
Purpose:			
Parameters:		None
Returns:			Nothing
Changed On		Changed By		Reason
--------------		--------------		-----------------------------------------
---------------------------------------------------------------------------
*/
vars

begin
	if ti = null then
		return false;
	endif;
	if ti.state &lt;&gt; TI_STATE_NORMAL then
		if self.myType.type = TA_TYPE_DELETE then
			return false;
		endif;
	endif;
	return true;
end;</source>
        <Parameter name="ti" type="CM_TrackedItem"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
