			global.beep;
			break;
		else
			theReturn := app.showErrorWarningDialog("BOL Transaction Map", app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   theReturn = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			self.setAllErrorWarnings(app.myPassport);
			return;
		endif;
		break;
	endwhile;
	
	self.frmProperties.visible := false;
	self.lstData.enabled := true;
	self.frmToolbar.enabled := true;
	
epilog
	app.cmsEndLoad(ls);		
	delete pxyBOLTM;

end;</source>
