    <JadeMethod name="toggleOpenClosed" id="95607ba7-ac5e-4564-a992-d8153a66c830">
        <updating/>
        <source>toggleOpenClosed(_mainLoad : Boolean; _startingRow : Integer) updating;
/*

Purpose:			

Date		Who		Reason
10/07/2015 	cnwmc5	Initial creation

*/

vars
	
	row 					: Integer;
	startingRow				: Integer;
	needToOpen				: Boolean;
	
begin

	startingRow := 1;
	if _startingRow &gt; 0 then
		startingRow := _startingRow;
	endif;

	foreach row in startingRow to self.tblUserData.rows do
	
		if self.tblUserData.accessCell(row, 1).text = "[+]" then
			if _startingRow &gt; 0 and row &gt; _startingRow then
				break;
			endif;
			needToOpen := true;
			if not _mainLoad then
				self.tblUserData.accessCell(row, 1).text := "[-]";
			endif;
			continue;
		elseif self.tblUserData.accessCell(row, 1).text = "[-]" then
			if _startingRow &gt; 0 and row &gt; _startingRow then
				break;
			endif;
			needToOpen := false;
			if not _mainLoad then
				self.tblUserData.accessCell(row, 1).text := "[+]";
			endif;
			continue;
		endif;
	
		if _mainLoad then
			self.tblUserData.accessRow(row).visible := false;
		else
			self.tblUserData.accessRow(row).visible := needToOpen;
		endif;
	
	endforeach;
	
epilog

end;</source>
        <Parameter name="_mainLoad" type="Boolean"/>
        <Parameter name="_startingRow" type="Integer"/>
    </JadeMethod>
