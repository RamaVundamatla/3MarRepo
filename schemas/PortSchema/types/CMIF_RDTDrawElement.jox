    <JadeMethod name="drawGridRightRowHeader" id="812a1de1-8cc4-438a-afb7-4204fb176f37">
        <source>drawGridRightRowHeader(_x1, _y1, _x2, _y2 : Real; _frame : Frame input; _scaleFactor : Real;  _isLandscape, _flipH, _flipV : Boolean; _mode : Integer; _isGapRow : Boolean);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
21/06/2011	cnwdz2	Initial creation 27732

*/

vars
begin
	if _mode = self.MODE_TOPDOWN then
		self.drawGridRightRowHeaderTopDown(_x1, _y1, _x2, _y2, _frame, _scaleFactor, _isLandscape, _flipH, _flipV, _mode, _isGapRow);
	elseif _mode = self.MODE_FACE then
		self.drawGridRightRowheaderFace(_x1, _y1, _x2, _y2, _frame, _scaleFactor, _isLandscape, _flipH, _flipV, _mode, _isGapRow);	
	elseif _mode = self.MODE_END then
		self.drawGridRightRowHeaderEnd(_x1, _y1, _x2, _y2, _frame, _scaleFactor, _isLandscape, _flipH, _flipV, _mode, _isGapRow);		
	else
		app.raiseUnexpectedProgramError(class.name, method.name, "unsupported drawing mode specified");
	endif;
epilog

end;</source>
