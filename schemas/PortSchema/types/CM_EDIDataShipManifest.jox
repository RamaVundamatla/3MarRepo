    <JadeMethod name="doesReceiptTransportModeExist" id="fd4634b5-d031-472c-ac41-07ef244f9738">
        <source>doesReceiptTransportModeExist(_receiptTransportMode: String): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
6 April 2023	navra1	Initial creation for 57263

*/

vars

begin
	//since the receipt transport mode would be TI_TRANSMODE_SHIP_STR for a ship manifest edi file
	if _receiptTransportMode.toUpper().compareEql(TI_TRANSMODE_SHIP_STR.toUpper(), true, false, null) then
		return true;
	endif;
	
	return false;

epilog

end;</source>
        <Parameter name="_receiptTransportMode" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getCargoOperatorForShipManif" id="329511fd-2ad1-439d-8067-f73ee9afd321">
        <source>getCargoOperatorForShipManif() : String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 July 2024	navra1	Initial creation for //navra1 - CR-65068/Task-64641 - Auto Comparison - 15th July 2024

*/

vars
	ediTi : CM_EDITrackedItem;
	operatorCode : String;
begin
		
	foreach ediTi in self.allEDITrackedItems do					
		if ediTi.isEDICargo() then		
			operatorCode := ediTi.CM_EDICargoTI.operatorCode;
			break;
		endif;
	endforeach;
	
	return operatorCode;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDataTypeFromDefName" id="e8051ef3-ad50-4347-b4cb-3011c80d2938">
        <source>getDataTypeFromDefName(_name: String): Integer;
// ---------------------------------------------------------------------------
// Created:     24 September 2009 by cnwcs5:1
// Purpose:     Par 20320 - multiple user record types  
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//  12/5/2014   cnwgb1  PAR 34110 CCMS 2352 Penn CUSCAR update
// ---------------------------------------------------------------------------
// 30 Jun 2017	cnwrs1	TFS 4462 SNO add Terminal Operator, Unknown Seal and support multiple seals
vars

begin
	if _name = ETDef_EDITIBOLHdr then
		return EDIDataType_BOLHdr;
	elseif _name = ETDef_EDITIBOLDtl then
		return EDIDataType_BOLDtl;
	elseif _name = ETDef_EDITILayout then	// cmwrs1 28 July 2011 CCMS 1009
		return EDIDataType_Layout;
	elseif _name = ETDef_EDITILayoutPoint then
		return EDIDataType_LayoutPoint;
	elseif _name = ETDef_EDITICargo then
		return EDIDataType_CargoOnShip;
    elseif _name = ETDef_EDITIToDoTask then // cnwgb1 PAR 34110 12 May 2014 CCMS Penn 2352
		return EDIDataType_ToDoTask;
	elseif _name = ETDef_EDIHazDetailsTI then	//22 Nov 2016	NDL	TFS 2843 / 2604
		return EDIDataType_TIHazDets;
	elseif _name = ETDef_EDITISeal then
		return EDIDataType_TISeal;
	endif;
epilog

end;</source>
        <Parameter name="_name" type="String"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getDescription" id="2ba42093-f35b-4502-9c38-37eb7054d2ed">
        <source>getDescription() : String;

// cnwdvb1 25 February 2003 

vars

begin
	return "Ship Manifest at " &amp; app.actualTimeServer.String;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStrForDefName" id="242a88d3-319e-41f8-a353-8e99c2c025fb">
        <source>getDisplayStrForDefName(_name: String): String;
//
// 26 Jun 2017	cnwrs1	TFS 4462 SNO add Terminal Operator, Unknown Seal and support multiple seals
//
vars

begin
	if _name = ETDef_EDITIBOLHdr then
		return app.getErrorString(BOL_header);
	elseif _name = ETDef_EDITIBOLDtl then
		return app.getErrorString(BOL_details);
	elseif _name = ETDef_EDITILayout then	// cmwrs1 28 July 2011 CCMS 1009
		return app.getErrorString(Layout);
	elseif _name = ETDef_EDITILayoutPoint then
		return app.getErrorString(Layout_Point);
	elseif _name = ETDef_EDITICargo then
		return app.getErrorString(Cargo_OnShip);
    elseif _name = ETDef_EDITIToDoTask then // cnwgb1 PAR 34110 12 May 2014 CCMS Penn 2352
		return app.getErrorString(Todo_task);
	elseif _name = ETDef_EDIHazDetailsTI then	//22 Nov 2016	NDL	TFS 2843 / 2604
		return app.getErrorString(Hazardous_details);
	elseif _name = ETDef_EDITISeal then
		return "Seals";
	endif;
end;
</source>
        <Parameter name="_name" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getEDIChildDataTypes" id="e79f4e54-ee1c-4eb5-9a67-49d8cc3ec4b7">
        <source>getEDIChildDataTypes(_types: IntegerArray input);
// ---------------------------------------------------------------------------
// Created:	25 September 2009 By Graeme Black cnwgb1
// Status: 	
// Purpose:	Returns a list of Data Types that make up this data type.
//			It will return the code for itself if not structured
// ---------------------------------------------------------------------------
// 30 Jun 2017	cnwrs1	TFS 4462 SNO add Terminal Operator, Unknown Seal and support multiple seals
vars
	
begin
	_types.add(EDIDataType_BOLHdr);
	_types.add(EDIDataType_BOLDtl);
	_types.add(EDIDataType_Layout);	// cmwrs1 28 July 2011 CCMS 1009
	_types.add(EDIDataType_LayoutPoint);
	_types.add(EDIDataType_CargoOnShip); 
	_types.add(EDIDataType_CargoOnSite); //jlier1 TFS 56234 12/12/22
	_types.add(EDIDataType_ToDoTask);
	_types.add(EDIDataType_TIHazDets);	//22 Nov 2016	NDL	TFS 2843 / 2604
	_types.add(EDIDataType_TISeal);
epilog
end;</source>
        <Parameter name="_types" type="IntegerArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getEDIDataType" id="91de02a8-e082-4032-aedc-42fe4f28b360">
        <source>getEDIDataType(): Integer;
// ---------------------------------------------------------------------------
// Created:	12 October 2009 By Graeme Black cnwgb1 PAR 20920 
// Purpose:	Override - the Integer code associated with a data type
// ---------------------------------------------------------------------------
vars
begin
	return EDIDataType_ShipManifest;
epilog
end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getEDIDataTypeChildren" id="4c6ceb05-f676-4a6b-aa9c-05f229a89e13">
        <source>getEDIDataTypeChildren(_ediDataType: Integer; _childrenDataTypes : IntegerArray input);
//
// 27 Aug 2014	cnwrs1	Par 34702 - Add support for JMT XML 
//
// 30 Jun 2017	cnwrs1	TFS 4462 SNO add Terminal Operator, Unknown Seal and support multiple seals
//18 Dec 2023	jlirs1	TFS 59171 User Defined Transport Manifest 
vars

begin
	if (_ediDataType = EDIDataType_ShipManifest and
	   self.myTransportManifest &lt;&gt; null) or
	   _ediDataType = EDIDataType_JMTInternal then
		_childrenDataTypes.add(EDIDataType_BOLHdr);
		_childrenDataTypes.add(EDIDataType_Layout);
		_childrenDataTypes.add(EDIDataType_CargoOnShip);
		_childrenDataTypes.add(EDIDataType_ToDoTask);
	elseif _ediDataType = EDIDataType_BOLHdr then
		_childrenDataTypes.add(EDIDataType_BOLDtl);
		_childrenDataTypes.add(EDIDataType_CargoOnShip);
	elseif _ediDataType = EDIDataType_BOLDtl then
		_childrenDataTypes.add(EDIDataType_CargoOnShip);
	elseif _ediDataType = EDIDataType_Layout then
		_childrenDataTypes.add(EDIDataType_LayoutPoint);
	elseif _ediDataType = EDIDataType_CargoOnShip then
		_childrenDataTypes.add(EDIDataType_ToDoTask);
		_childrenDataTypes.add(EDIDataType_TIHazDets);	//22 Nov 2016	NDL	TFS 2843 / 2604
		_childrenDataTypes.add(EDIDataType_TISeal);
	endif;
end;</source>
        <Parameter name="_ediDataType" type="Integer"/>
        <Parameter name="_childrenDataTypes" type="IntegerArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getEDITIType" id="4f704822-cd52-4b9d-904a-ec51c98a1ca8">
        <source>getEDITIType(_ediDataType: Integer): Class;
// ---------------------------------------------------------------------------
// Created:	12 October 2009 By Graeme Black cnwgb1
// Purpose:	PAR 
// ---------------------------------------------------------------------------
//12 Jul 2014	cnwrs1	Par 34702 - Add support for JMT XML
// 30 Jun 2017	cnwrs1	TFS 4462 SNO add Terminal Operator, Unknown Seal and support multiple seals
vars

begin
	if _ediDataType =  EDIDataType_BOLHdr then
		return CM_EDIBOLHdrTI;
	elseif _ediDataType = EDIDataType_BOLDtl then
		return CM_EDIBOLDtlTI;
	elseif _ediDataType = EDIDataType_Layout then	// cmwrs1 28 July 2011 CCMS 1009
		return CM_EDILayoutTI;
	elseif _ediDataType = EDIDataType_LayoutPoint then
		return CM_EDILayoutPointTI;
	elseif _ediDataType = EDIDataType_CargoOnShip then
		return CM_EDICargoOnShipTI;
	elseif _ediDataType = EDIDataType_CargoOnSite then //jlier1 TFS 56234 12/12/22
		return CM_EDICargoOnSiteTI;
	elseif _ediDataType = EDIDataType_ToDoTask then
		return CM_EDIToDoTaskTI;
	elseif _ediDataType = EDIDataType_TIHazDets then	//22 Nov 2016	NDL	TFS 2843 / 2604
		return CM_EDIHazDetailsTI;
	elseif _ediDataType =  EDIDataType_TISeal then
		return CM_EDISealTI;
	endif;
end;
</source>
        <Parameter name="_ediDataType" type="Integer"/>
        <ReturnType type="Class"/>
    </JadeMethod>
