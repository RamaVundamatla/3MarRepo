    <JadeMethod name="unload" id="aa996427-64e3-4f59-94d4-761fdeb9e08e">
        <controlMethod name="Form::unload"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>unload() updating;
/*
Purpose:			
Date		Who		Reason
24 May 2011	cnwab1	Initial creation
30/01/2012	cnwmh5	make sure that hazard details are saved to the proxy
*/

vars
	hazs : CM_HazardByCodeDict;
begin
	if self.myROROLocnDefn.isTransient() then
		self.myROROLocnDefn.setProxyRemarks(self.txtRemarks.text); // PAR 27595
		
		create hazs transient;										// PAR 28846
		self.lstHazard.allSelectedObjects.copy(hazs);
		self.myROROLocnDefn.setProxyHazards(hazs);
	endif;

epilog
	delete hazs;
end;</source>
    </JadeMethod>
</GUIClass>
