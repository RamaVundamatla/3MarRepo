    <JadeMethod name="utlCreateTerminal" id="c5811d9d-520a-4dcc-9c69-c45c3b270226">
        <updating/>
        <source>utlCreateTerminal(_proxyTerminal : CM_Terminal input; pKeyValue : Any; _cmifConfig : CMIF_Config input; _newTerminal : CM_Terminal output; _passport : CM_Passport input) updating;
// -----------------------------------------------------------------------------
// Created:		19 February 2002 by cnwka1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	---------------------------------------------
// 21 Sep 2020 cnwma1 		ChangeRequest 49906: MTN - Ops View External Webservice
// -----------------------------------------------------------------------------
vars
	chkDate		: Date;
	businessUnit : CM_Bank;	
begin

	self.initialiseActivity();
	
	app.setContinueCMExceptions(true);
	app.myValCA.valTerminal(_proxyTerminal);
	
	if pKeyValue = null or (not pKeyValue.isKindOf(Date)) then
		app.raiseCMException(Invalid_action, null, null);
		return;
	endif;
	if (not pKeyValue.Date.isValid) then
		app.raiseCMException(Invalid_action, null, null);
		return;
	endif;
	if pKeyValue.Date &lt;&gt; app.actualTimeServer.date then
		app.raiseCMException(Invalid_action, null, null);
		return;
	endif;
	
	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	
	app.setContinueCMExceptions(false);

	create _newTerminal persistent;
	
	// the following check is required as the create method on
	// CM_Terminal does some checks and it not valid it
	// deletes the instance
	if global.isValidObject(_newTerminal) then
		_newTerminal.setForCreate(_proxyTerminal, pKeyValue);
		
		// the setForCreate creates the new businessUnit required
		// reset the interface object otherwise the config gets overwritten
		//businessUnit := _newTerminal.getConfig(DefCompany).CM_Bank;
		businessUnit := _newTerminal.getDefaultCompanyBank();	//17 Apr 2012	NDL	Par 29393
		_cmifConfig.CMIF_ConfigTerminal.defCompany := businessUnit;
				
		if _passport.noErrors then
			_cmifConfig.updatePersistentObject(_newTerminal, _passport);
		endif;
		
		if _passport.noErrors then
			self.myCreateAuditAgent.audCreateGeneric(_newTerminal);
		endif;
		
		//21.09.2020 cnwma1 TFS #49906
		if _passport.isOpsViewEnabled(_newTerminal) then // ### TFS 50669 24AUG2021 NAVAB1
			_newTerminal.createOpsViewEWSActivity(BGP_OpsViewWSRequest.OPS_ACTION_CREATE,
										 BGP_OpsViewWSRequest.OPS_TYPE_TERMINAL,
										 _newTerminal);
		endif;
		//21.09.2020 cnwma1 TFS #49906
	else
		_newTerminal := null;
	endif;

end;</source>
        <Parameter name="_proxyTerminal" type="CM_Terminal" usage="input"/>
        <Parameter name="pKeyValue" type="Any"/>
        <Parameter name="_cmifConfig" type="CMIF_Config" usage="input"/>
        <Parameter name="_newTerminal" type="CM_Terminal" usage="output"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlCreateTerminalArea" id="536137f9-603f-4d1a-958b-dc519f9d7c28">
        <source>utlCreateTerminalArea(_proxyTA : CM_TerminalAreaMaster input; _newTA : CM_TerminalAreaMaster output; _passport : CM_Passport input);
//utlCreateTerminalArea(_proxyTA : CM_TerminalArea input; _newTA : CM_TerminalArea output; _passport : CM_Passport input);


// ---------------------------------------------------------------------------
// Created:     2001 By Andrew Bishop cnwab1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 30/07/2009	cnwcs5		ccms 1061 - changed to return new terminal area created
// ---------------------------------------------------------------------------

vars
	tmpClass	: Class;
begin
	
	
	self.initialiseActivity();

	app.setContinueCMExceptions(true);
	app.myValCA.valTerminalArea(_proxyTA);
	
	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	
	app.setContinueCMExceptions(false);
	
	tmpClass := _proxyTA.class;
	create _newTA as tmpClass persistent;
	
	
	// 24/06/09 - ccms 1061 - change of method parameter
	_newTA.setForCreate(_proxyTA, _passport); // Populate Real Stack from Proxy

	_newTA.causeEvent(_newTA.myTerminal.getTerminalEvent(EVENT_REFRESH_GRID_AREA), false, _newTA);

	
	if _passport.noErrors then
		self.myCreateAuditAgent.audCreateGeneric(_newTA);
	endif;	

	
end;</source>
        <Parameter name="_proxyTA" type="CM_TerminalAreaMaster" usage="input"/>
        <Parameter name="_newTA" type="CM_TerminalAreaMaster" usage="output"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
