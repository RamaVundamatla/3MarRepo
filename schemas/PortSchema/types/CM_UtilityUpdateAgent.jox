    <JadeMethod name="utlUpdateInvContract" id="8a76eef5-8283-403b-84de-7090ea91c156">
        <updating/>
        <source>utlUpdateInvContract(_pxyObject : CM_InvoiceContract; _passport : CM_Passport input; _autoDateChange : Boolean) updating;
/*
Purpose:			

Date		Who		Reason
01DEC2022	NAVAB1	TFS CR 55623 TASK 55671
*/
vars
	realObject		: CM_InvoiceContract;
	expectedEdition	: Integer;
	theTerminal : CM_Terminal;
begin

	self.initialiseActivity();
	
	// do any pre-validation locks
	
	// do validation
	self.raiseExceptionIfNull(_pxyObject, 'Invoice Contract');

	app.setContinueCMExceptions(true);
	
	app.myValUA.valUpdateInvContract(_pxyObject);

	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	
	realObject := self.getRealObjectAndEditionCheck(_pxyObject, 'Invoice Contract', _passport).CM_InvoiceContract;

	if _passport.noErrors then
		// This is only required if the class is being auditted
		self.myUpdateAuditAgent.audUpdateGeneric(realObject, true);
	endif;

	if _passport.noErrors then
		// do updates
		if _autoDateChange then // ### TFS CR 55646 TASK 56413 21FEB2023 NAVAB1
			realObject.setForUpdateEndDate(_pxyObject.toTS); // ### TFS CR 55646 TASK 56413 21FEB2023 NAVAB1
		endif;
		realObject.setForUpdate(_pxyObject);
	endif;

	if _passport.noErrors then
		// This is only required if the class is being auditted
		self.myUpdateAuditAgent.audUpdateGeneric(realObject, false);

		theTerminal := realObject.getMyTerminal();
		app.myEventManager.createSingleObjInfoNoteEvt(realObject.myBusinessUnit,theTerminal.getTerminalEvent(Event_InvContractUpdate),realObject); // ### TFS CR 55645 TASK 55662 13DEC2022 NAVAB1
	endif;

end;</source>
        <Parameter name="_pxyObject" type="CM_InvoiceContract"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <Parameter name="_autoDateChange" type="Boolean"/>
    </JadeMethod>
