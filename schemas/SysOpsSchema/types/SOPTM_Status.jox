    <JadeMethod name="setControlsForAddEdit" id="44b462a4-d644-4d5a-9f03-26e3fedea159">
        <updating/>
        <source>setControlsForAddEdit() updating;
// ---------------------------------------------------------------------------
// Created:     11 June 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
vars
	theForm : SOP_TableMaintForm;

begin
  
	theForm := self.myForm;
	theForm.tblInput1.userInputEnabled := true;


	if theForm.mode = theForm.Mode_Add then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Should not be able to add!');
		return;
	else
		self.myForm.tblInput1.userInputEnabled := true;
	endif;

	theForm.tblInput1.disableRowByName(ETRow_Abbreviation);

	theForm.tblInput1.row := theForm.tblInput1.getRowByName(ETRow_Description);
	theForm.tblInput1.setFocus;
	
end;</source>
    </JadeMethod>
