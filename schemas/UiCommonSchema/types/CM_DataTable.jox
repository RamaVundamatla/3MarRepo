    <JadeMethod name="getCellValueByName" id="74e3d573-b8b6-4084-b023-d60c112bcd76">
        <updating/>
        <source>getCellValueByName(_heading : String; _theRow : Integer) : String updating;
// ---------------------------------------------------------------------------
// Created:		December 2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	theColumn : Integer;
begin
	theColumn := self.getColumnByRowName(_heading);
	
	if theColumn &gt; 0 then
		return self.accessCell(_theRow,theColumn).text;
	endif;
	return null;
