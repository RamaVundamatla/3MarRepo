    <JadeMethod name="doPostAddItem" id="765fe271-6a3f-431f-87a3-4e2af82c3870">
        <source>doPostAddItem(_rowIdx: Integer; _obj: Object);
// ---------------------------------------------------------------------------
// Created:		November 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	theBR : CM_BulkRelease;
	aReserveDetail : CM_ReserveDetail;
	idx : Integer;
begin
	if _obj.isKindOf(CM_BulkRelease) then
		theBR := _obj.CM_BulkRelease;
		
		if self.showFullReq then
			if theBR.getDeliveryRequest(false) &lt;&gt; null then
				foreach idx in _rowIdx to self.tblData.rows do
					if self.tblData.accessRow(idx).itemObject = theBR then
						self.doPostAddItemSetColour(theBR, idx);
					else
						break;
					endif;				
				endforeach;
			else
				self.doPostAddItemSetColour(theBR, _rowIdx);
			endif;
		else
			self.doPostAddItemSetColour(theBR, _rowIdx);
		endif;
	elseif _obj.isKindOf(CM_ReserveDetail) then
		aReserveDetail := _obj.CM_ReserveDetail;

		if aReserveDetail.getRequest() &lt;&gt; null then	//SFW1035
			self.tblData.accessRow(_rowIdx).foreColor := Red;
		else
			self.tblData.accessRow(_rowIdx).foreColor := Black;
		endif;
	elseif _obj.isKindOf(CM_TrackedItem) then
		theBR := _obj.CM_TrackedItem.allBulkReleasesAssigned.first;
		
		if theBR &lt;&gt; null then
			if theBR.isInRailOps then
				self.tblData.accessRow(_rowIdx).foreColor := Red;
			else 
				self.tblData.accessRow(_rowIdx).foreColor := Black;
			endif;
			self.tblData.accessedRow.itemObject := theBR;
		endif;
	endif;	
	

end;</source>
        <Parameter name="_rowIdx" type="Integer"/>
        <Parameter name="_obj" type="Object"/>
    </JadeMethod>
    <JadeMethod name="doPostAddItemSetColour" id="b2b1abef-e729-4a40-8423-2c3e39bda94a">
        <source>doPostAddItemSetColour(_theBR : CM_BulkRelease; idx : Integer);
// ---------------------------------------------------------------------------
// Created:		October 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars

begin
	if not _theBR.allRequestsBeingActioned.isEmpty and _theBR.type = BR_TYPE_RAIL then
		self.tblData.accessRow(idx).backColor := Gray;
		self.tblData.accessRow(idx).foreColor := Red;
	elseif _theBR.isInRailOps then
		self.tblData.accessRow(idx).foreColor := Red;
	else 
		self.tblData.accessRow(idx).foreColor := Black;
		if idx mod 2 = 0 then
			self.tblData.accessRow(idx).backColor := self.colorRow1;
		else
			self.tblData.accessRow(idx).backColor := self.colorRow2;
		endif;
	endif;

end;</source>
        <Parameter name="_theBR" type="CM_BulkRelease"/>
        <Parameter name="idx" type="Integer"/>
    </JadeMethod>
