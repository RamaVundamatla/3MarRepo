    <JadeMethod name="btnDeleteData_click" id="80def83b-73e9-40bc-8e4c-5174587c5182">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnDeleteData_click(btn: Button input) updating;
/*
----------   ----------  --------------------------------------------------
Created:	12 October 2006 By cnwmo1

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	msgStr : String;
begin

	msgStr := app.getErrorString2(ConfirmDelete, '', 'All Tidal Data');
	if app.msgBox(msgStr, 'Confirm Deletion', MsgBox_Yes_No + MsgBox_Question_Mark_Icon + MsgBox_Default_Second) = MsgBox_Return_Yes then
		self.myPxyTidalModelDef.allHMSTidalData.purge();
		app.msgBox('Data Delete Successfully','Data Deleted', MsgBox_OK_Only);
	endif;
end;
</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
