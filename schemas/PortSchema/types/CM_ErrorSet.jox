<CollClass name="CM_ErrorSet" id="eabdccd6-a7ec-4084-a96c-30d6b892dbf3">
    <memberType name="CM_Error"/>
    <superclass name="CM_ObjectSet"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="cmtrans"/>
    <JadeMethod name="copyErrors" id="eff2af70-6308-480b-b326-b56141e9a029">
        <lockReceiver/>
        <updating/>
        <source>copyErrors(_allNewErrors : CM_ErrorSet) updating;

vars
	newErr,
	error 	: CM_Error;
	
begin

	foreach error in _allNewErrors do
		create newErr transient;
		newErr.set(error.errorCode, error.text, error.warningOnly, error.fieldName, error.myUserObject, error.mySubject);
		self.add(newErr);
	endforeach;
end;</source>
        <Parameter name="_allNewErrors" type="CM_ErrorSet"/>
    </JadeMethod>
    <JadeMethod name="getAsString" id="cf96e15a-de14-489d-bb9c-a58d46d84229">
        <source>getAsString() : String;

vars
	newErr,
	error 	: CM_Error;
	desc : String;
begin

	foreach error in self do
		desc := desc &amp; error.text &amp; CrLf;
	endforeach;
	
	return desc;
end;

</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getErrorsCodeAndDescAsStr" id="2e0e2597-b856-4ab1-8fb6-b28c3f1c17e4">
        <source>getErrorsCodeAndDescAsStr() : String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 May 2025	navpw1	Initial creation

*/

vars
	error 	: CM_Error;
	desc	: String;
	
begin

	foreach error in self do
		desc &amp;= 'Code :' &amp; Err_Is_Null.String &amp; '. ' &amp; error.text &amp; CrLf;
	endforeach;
	
	desc := desc[1:desc.length-2]; //Strip Trailing CrLf
	
	return desc;
	
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="includesErrorCode" id="9a67e40d-cea0-4f27-bcec-7cbdb0af95b0">
        <source>includesErrorCode(_errorCode : Integer) : Boolean;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
08 April 2010	cnwas3 par 23465

*/

vars
	error : CM_Error;
begin
	foreach error in self where _errorCode = error.errorCode do
		return true;
	endforeach;		
	
	return false;
epilog

end;</source>
        <Parameter name="_errorCode" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="includesErrorLikeThis" id="69110ee4-d873-4247-ab70-f475852b5069">
        <source>includesErrorLikeThis( _error : CM_Error ):Boolean;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
16 October 2009	cnwndl1	Initial creation	Par 21325

*/

vars

	iter : Iterator;
	compareString : String;
	error : CM_Error;
	
begin

	if not self.isEmpty then
		iter := self.createIterator;
		compareString := _error.getDetailsForTableDisplay();
		while iter.next( error ) do
			if error.getDetailsForTableDisplay() = compareString then
				return true;
			endif;
		endwhile;
	endif;
	
	return false;

epilog

	delete iter;
	
end;</source>
        <Parameter name="_error" type="CM_Error"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="removeDuplicates" id="ab747e57-89c1-4338-9b1d-12bf95437a1f">
        <source>removeDuplicates();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 March 2014	cnwndl1	Initial creation	Par 33596

*/

vars

	keepColl : CM_ErrorSet;
	purgeColl : CM_ErrorSet;
	err : CM_Error;

begin

	
	create keepColl transient;
	create purgeColl transient;
	
	//find the unique ones.
	foreach err in self do
		if not keepColl.includesErrorLikeThis( err ) then
			keepColl.add( err );
		else
			//duplicates
			purgeColl.add( err );
		endif;
	endforeach;

epilog

	//purge the dups
	if not purgeColl.isEmpty then
		purgeColl.purge();
	endif;
	delete purgeColl;
	
	delete keepColl;

end;</source>
    </JadeMethod>
    <JadeMethod name="removeErrorLikeThis" id="d602a01b-140b-4446-80e2-fd19f6c730b6">
        <source>removeErrorLikeThis( _error : CM_Error );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 September 2016	cnwndl1	Initial creation	TFS 2649 / 2001

*/

vars

	iter : Iterator;
	compareString : String;
	error : CM_Error;
	errorToRemove : CM_Error;
	
begin

	if not self.isEmpty then
		iter := self.createIterator;
		compareString := _error.getDetailsForTableDisplay();
		while iter.next( error ) do
			if error.getDetailsForTableDisplay() = compareString then
				errorToRemove := error;
				break;
			endif;
		endwhile;
	endif;
	
	delete error;

epilog

	delete iter;
	
end;</source>
        <Parameter name="_error" type="CM_Error"/>
    </JadeMethod>
</CollClass>
