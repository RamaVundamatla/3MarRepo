    <JadeMethod name="doBtnToolBarRH" id="cfec24a6-ab0c-4dee-9fa0-51ca172ded1f">
        <updating/>
        <source>doBtnToolBarRH() updating;
// ---------------------------------------------------------------------------
// Created:		January 2003 By Andrew Bishop cnwab1
//
// Purpose:		
// ---------------------------------------------------------------------------
vars

begin
	// DLR, SOB and basic Discharge and Load colour coding allow for the ALT key to be used. 
	// This checks that the same amount of slots have been slected either side of the 'ALT'
	if (not self.myBayDrawingController.validateCompareSelectedPoints($Double_Lift_Re_Stow, $Slots)) then
		return;
	endif;

	if self.displayMode = ShpDisplayMode_ColCodeLoad or 
	   self.displayMode = ShpDisplayMode_ColCodeDisch then
		// PAR 28968 self.updateSlotRequestAttribute(CM_SlotRequest.Attribute_DLR);
		
		self.updateSlotRequestAttribDLRSoB(DLR_MOVETYPE);
	else
		app.raiseUnexpectedProgramError(class.name, method.name, 'Invalid displayMode (' &amp; self.displayMode.String &amp; ')');
	endif;

end;</source>
    </JadeMethod>
