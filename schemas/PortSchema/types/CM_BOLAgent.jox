<Class name="CM_BOLAgent" id="44a52512-3de1-4810-b600-6efafee9899c">
    <superclass name="CM_Agent"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="bol"/>
    <JadeMethod name="moveTIsToBOLDtl" id="94aa8de6-e495-4eef-8f47-153b024acf1d">
        <source>moveTIsToBOLDtl(_tis: CM_TISet input; _bol: CM_BOL input; _bolDtl: CM_BOLDtl input);
//06 August 2009	cnwdw1	
//
// 08/04/2011	cnwmh5	PAR #27347 - Add cmsEndLoad or endLoad to epilog so that if error occurs it will not leave in begin load state
vars
	pxyTIs: CM_TISet;
	ti: CM_TrackedItem;
	loadState: Boolean;
	result: Integer;
begin
	create pxyTIs transient;
	app.cmsBeginLoad(loadState);
	foreach ti in _tis do
		pxyTIs.add(ti.pxyCreateUpdateProxy());
	endforeach;
	app.cmsEndLoad(loadState);
	app.myTrxUA.trxUpdateTIBOL(pxyTIs, _bol, _bolDtl, app.myPassport);

epilog
	app.cmsEndLoad(loadState);			// 08/04/2011 cnwmh5 #27347
	if pxyTIs &lt;&gt; null then
		pxyTIs.purge;
	endif;
	delete pxyTIs;
end;</source>
        <Parameter name="_tis" type="CM_TISet" usage="input"/>
        <Parameter name="_bol" type="CM_BOL" usage="input"/>
        <Parameter name="_bolDtl" type="CM_BOLDtl" usage="input"/>
    </JadeMethod>
</Class>
