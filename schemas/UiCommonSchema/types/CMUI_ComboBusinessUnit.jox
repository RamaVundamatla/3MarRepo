    <JadeMethod name="displayEntry" id="58f9416d-51a1-49dc-a770-fe8ac9d1dfbb">
        <controlMethod name="ComboBox::displayEntry"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <executionLocation>client</executionLocation>
        <source>displayEntry(combobox: ComboBox input; _bank : CM_Bank; lstIndex: Integer): String updating, clientExecution;
//------------------------------------------------
// Created: 16 May 2006 By: cnwgd1
//------------------------------------------------
vars
	 failedDAC  :CM_DataAccessController;
begin
	if _bank = null then
		return null;
	endif;

	if not _bank.isBusinessUnit then
		return null;
	endif;

	if (not _bank.canUserAccessSelf(null, failedDAC, app.myPassport)) then
		return null;
	endif;		

	if _bank.isSuspended then
		if self.myObject &lt;&gt; _bank then
			return null;
		else
			self.hasDirtyObject := true;
			return null;//added by cnwyl1 for PAR 12173
		endif;
	endif;
	
	return _bank.code;
	
end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
        <Parameter name="_bank" type="CM_Bank"/>
        <Parameter name="lstIndex" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getCollectionJMT" id="ae86fc52-0857-4478-9b2a-cc2cbe180f7b">
        <source>getCollectionJMT(): Collection protected;
//------------------------------------------------
// Created: 16 May 2006 By: cnwgd1
//------------------------------------------------
vars
	term : CM_Terminal;
begin
	term := self.getMyTerminal();
	if term = null then 
		return null;
	endif;

	return term.companies;

end;</source>
        <access>protected</access>
        <ReturnType type="Collection"/>
    </JadeMethod>
