    <JadeMethod name="pwPNlReleaseRequest" id="ee5e55d9-98ca-4170-b6fa-ce51ff955ffa">
        <source>pwPNlReleaseRequest();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 May 2023	navpw1	Initial creation

*/

vars
	lFile      		: File;
	terminal : CM_Terminal;
	bulkRelease : CM_BulkRelease;
	reserveDetail : CM_ReserveDetail;
	remaining : Integer;
	
begin
	terminal := app.myRoot.allTerminals[""];
	
	create lFile transient;
	lFile.fileName := "C:\TEMP\pnl\" &amp; terminal.code &amp; "May20230509.csv";
    lFile.open;
	lFile.writeLine(
					"Code" &amp; "," &amp;
					"QuantityRemaining"
					);
	foreach bulkRelease in terminal.allBulkReleasesByCodeDate discreteLock do 
		remaining := bulkRelease.CM_BulkRelease.getTotalOutstanding() - bulkRelease.CM_BulkRelease.getNumItemsBeingActioned();
		lFile.writeLine(bulkRelease.code &amp; "," &amp; remaining.String);
	endforeach;
	
	lFile.close;
  
epilog

	delete lFile;
end;</source>
    </JadeMethod>
    <JadeMethod name="pwPopulateCargoForecasts" id="523b89f5-d2a9-4b18-b444-7fa7807a224a">
        <source>pwPopulateCargoForecasts();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 April 2022	navpw1	Initial creation TFS: 53132

*/

vars
	terminal 			: CM_Terminal;
	voyage				: CM_Voyage;
	cargoType			: CM_CargoType;
	commodity			: CM_Commodity;
	imexStatus			: CM_IMEXStatus;
	realCargoForecast	: CM_CargoForecast;
	converting			: Boolean;
	
begin
	app.initialize();
	
	beginTransaction;
	foreach terminal in app.myRoot.allTerminals do
		foreach voyage in terminal.allVoyagesSet do
			if voyage.myHMSVoyageData = null then
				continue;
				
			elseif voyage.myHMSVoyageData.allCommodityDischarge.size = 0 and voyage.myHMSVoyageData.allCommodityLoad.size = 0 then
				continue; //If our collections are not populated then process next voyage
				
			endif;
			
			if voyage.myHMSVoyageData.allCommodityDischarge.size &gt; 0 then
				foreach commodity in voyage.myHMSVoyageData.allCommodityDischarge do
					if commodity.allCargoTypes.size = 1 then
						cargoType := commodity.allCargoTypes.first;
					
					else
						cargoType := null;
						
					endif;
					
					create realCargoForecast persistent;
					realCargoForecast.setPropertyValue(CM_CargoForecast::myCargoType.name, cargoType);
					realCargoForecast.setPropertyValue(CM_CargoForecast::myCommodity.name, commodity);
					realCargoForecast.setPropertyValue(CM_CargoForecast::mode.name, CM_CargoForecast.Mode_Discharge);
					realCargoForecast.setPropertyValue(CM_CargoForecast::totalWeight.name, 0.Decimal);
					realCargoForecast.setPropertyValue(CM_CargoForecast::totalVolume.name, 0.Decimal);
					realCargoForecast.setPropertyValue(CM_CargoForecast::totalQuantity.name, 0);
					realCargoForecast.setPropertyValue(CM_CargoForecast::myParent.name, voyage);
					
				endforeach;
				
				voyage.myHMSVoyageData.allCommodityDischarge.clear;
			endif;
			
			if voyage.myHMSVoyageData.allCommodityLoad.size &gt; 0 then
				foreach commodity in voyage.myHMSVoyageData.allCommodityLoad do
					if commodity.allCargoTypes.size = 1 then
						cargoType := commodity.allCargoTypes.first;
					
					else
						cargoType := null;
						
					endif;
					
					create realCargoForecast persistent;
					realCargoForecast.setPropertyValue(CM_CargoForecast::myCargoType.name, cargoType);
					realCargoForecast.setPropertyValue(CM_CargoForecast::myCommodity.name, commodity);
					realCargoForecast.setPropertyValue(CM_CargoForecast::mode.name, CM_CargoForecast.Mode_Load);
					realCargoForecast.setPropertyValue(CM_CargoForecast::totalWeight.name, 0.Decimal);
					realCargoForecast.setPropertyValue(CM_CargoForecast::totalVolume.name, 0.Decimal);
					realCargoForecast.setPropertyValue(CM_CargoForecast::totalQuantity.name, 0);
					realCargoForecast.setPropertyValue(CM_CargoForecast::myParent.name, voyage);
					
				endforeach;
				
				voyage.myHMSVoyageData.allCommodityLoad.clear;
			endif; 
			
		endforeach;
		
	endforeach;
	commitTransaction;
	
epilog
	
end;</source>
    </JadeMethod>
    <JadeMethod name="pwPurgeOldContainers" id="ab677c0b-2eb1-491c-ad68-85ca34fd084e">
        <source>pwPurgeOldContainers();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 September 2025	navpw1	Initial creation

*/

vars
	dynaDict,
	dynaDictCounts		: DynaDictionary;
	container					: CM_TrackedItem;
	iter				: Iterator;
	invalidTi,
	invalidTerminal	: Boolean;
	terminal : CM_Terminal;
	allContainers : CM_TISet;
	lFile : File;
	exportHeaders,
	exportData : String;
	allContainersPurge : CM_TISet;
	ts : TimeStamp;
	date : Date;
	time : Time;
	
begin
	on Exception do app.handleDeletedObject(exception, container, invalidTi);
	on Exception do app.handleDeletedObject(exception, terminal, invalidTerminal);
	
	create allContainers transient;
	create allContainersPurge transient;
	
	CM_Container.instances.copy(allContainers);
	
	iter := allContainers.createIterator;
	
	date.setDate(1, 1, 2020);
	
	time.setTime(0, 0, 0, 0);
	
	ts.setDate(date);
	ts.setTime(time);
	
	exportHeaders := "id,createdDate";
	
	create lFile transient;
	lFile.fileName := "C:\TEMP\ut-terminal-cnts\containers-details-purge.csv";
    lFile.open;
	lFile.writeLine(exportHeaders);
	
	while iter.next(container) do
		if container.myTerminal &lt;&gt; null and container.myTerminal.code &lt;&gt; "UT" then
			continue;
		endif;
		
		if container.createdTime &gt; ts then
			continue;
			
		endif;
		
		exportData := container.id &amp; Comma &amp; container.createdTime.asStringJSON;
		
		lFile.writeLine(exportData);
		
	endwhile;
	
	lFile.close;
	
epilog
	delete iter;
	delete dynaDict;
	delete dynaDictCounts;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="pwTestActivityHistory" id="25d9b01e-4a6c-486a-a8fc-eb2befe05175">
