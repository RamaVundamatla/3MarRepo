    <JadeMethod name="comboBoxMachinesForTA" id="fd45f2e1-e8d7-4e63-a040-fc4ca6ce263f">
        <source>comboBoxMachinesForTA(	_combo : CMUI_ComboBox input;
						_ta : CM_TerminalArea input;
						_machineGrpType : Integer);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 May 2018	jlger1	Initial creation  tfs 37584

*/

vars
	machine : CM_Machine;
	machineGrp : CM_MachineTypeGroup;
begin
	_combo.clear;
	if _ta = null then
		return;
	endif;
	_combo.addItem(null);
	
	foreach machine in _ta.allowedMachines discreteLock do
		if machine.isNotAvailableForEntry then
			continue;
		endif;
		
		if _machineGrpType  &gt; 0 then
			machineGrp :=machine.getMachineTypeGroup;
			if machineGrp = null then
				continue;
			endif;

			if machineGrp.type &lt;&gt;  _machineGrpType then
				continue;
			endif;		
		endif;
		
		_combo.addItemObject(machine.code,machine);
	endforeach;
epilog

end;</source>
        <Parameter name="_combo" type="CMUI_ComboBox" usage="input"/>
        <Parameter name="_ta" type="CM_TerminalArea" usage="input"/>
        <Parameter name="_machineGrpType" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="comboBoxMafi" id="ba44b7dc-415b-45da-8d67-5c4d1bf6b423">
        <source>comboBoxMafi(_combo : ComboBox input; _type	:CM_TILCType );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 May 2025	navcs2	MTN-34843  Development - Fleet file Form implementation
*/
vars
	type	: CM_TILCType;
	index 	: Integer;
	found	: Boolean;
begin
	foreach type in app.myRoot.allTILCTypes discreteLock where type.isMAFI  do	// Only include MAFI types here
		// do not include trailer types that are not available for entry
		// unless it is the default type we want to select
		if type.isNotAvailableForEntry then
			if type &lt;&gt; _type then
				continue;
			endif;
		endif;
		
		if type = _type then
			found := true;
		endif;
		
		index						:=_combo.addItem(type.description);
		_combo.itemObject [index] 	:= type;
	endforeach;
		
	if _type &lt;&gt; null then 
		// make sure it is selected
		index 				:= _combo.findObject(_type);
		_combo.listIndex	:= index;
	endif;	
epilog

end;</source>
        <Parameter name="_combo" type="ComboBox" usage="input"/>
        <Parameter name="_type" type="CM_TILCType"/>
    </JadeMethod>
    <JadeMethod name="comboBoxMchLiftType" id="2bf4d39e-8b5e-4d0e-9d51-8827f8616f45">
        <source>comboBoxMchLiftType(pCmb:ComboBox input; _machineType, pMchLiftType : Integer);
// ---------------------------------------------------------------------------
// Created:     cnwyl1  Yi Liu
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	typeString : String;
	idx : Integer;
begin
	pCmb.clear();
	pCmb.addItem("Normal Lift");
	pCmb.addItem("Twin Lift");
	if _machineType &lt;&gt; MACHINETYPE_STRADDLE and
		_machineType &lt;&gt; MACHINETYPE_RTG and
		_machineType &lt;&gt; MACHINETYPE_RMG then	// ccms jmt 1032, Par 18649. Dec 2008
		pCmb.addItem("Tandem Lift");
	endif;
	pCmb.addItem("Multi Lift"); //epr CCMS 1391 warehouse VMT app
	
	if pMchLiftType &gt; -1 then //&lt;&gt; null then     06/04/2009 cnwdz2 PAR 19226
		typeString:=self.getMachineLiftType(pMchLiftType, null).String;
		idx:=pCmb.findString(1,typeString);
		if idx &gt; 0 then
			pCmb.listIndex:=idx;
			pCmb.text := typeString;// self.getMachineLiftType(pMchLiftType, null).String;
		endif;
	endif;
epilog

end;</source>
        <Parameter name="pCmb" type="ComboBox" usage="input"/>
        <Parameter name="_machineType" type="Integer"/>
        <Parameter name="pMchLiftType" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="comboBoxMethodOfPayment" id="7296b1a5-f184-49e7-b910-825c858c6bf4">
        <source>comboBoxMethodOfPayment( _cmb : ComboBox input; _includeAny : Boolean );

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
18 July 2012		cnwndl1	Initial creation	Par 29968
*/

vars

	mop : CM_PaymentMethod;
	index : Integer;
begin
	
	_cmb.clear;
	_cmb.sorted := true;
	
	if _includeAny then
		_cmb.addItem( Any_String );
	endif;

		foreach mop in app.myRoot.allPaymentMethods do
			if not mop.notAvailableForEntry then
				index := _cmb.addItem(mop.description);
				_cmb.itemObject[index] := mop;
			endif;
		endforeach;


epilog

end;</source>
        <Parameter name="_cmb" type="ComboBox" usage="input"/>
        <Parameter name="_includeAny" type="Boolean"/>
    </JadeMethod>
