    <JadeMethod name="setupForm" id="ed120b5c-5e67-459d-8dcc-969f189a6af5">
        <updating/>
        <source>setupForm() updating;
//--------------------------------------------------
// Created:	13 April 2005 By: cnwgd1
// 15/05/2025		navcs2	MTN-34843  Development - Fleet file Form implementation
//--------------------------------------------------
vars

begin
	inheritMethod();

//self.modeStr := "1";
	self.setPermissions();

	self.frmPictureActual.autoRedraw := true;
	self.frmToolbar.alignContainer	:=	Frame.AlignContainer_Top; // this will make the dkcMain line up its top	
	self.toolbarStyle := self.ToolbarStyle_ShowNoHide;	
	self.showToolbar := true;
	self.lblSearcherCap.visible := false;
	self.initCmbFleetType();
	self.initTblData();	
	self.initTblSearcher();
	
	self.btnSelectAll.visible := false;
	
	self.hideInfoPanel();
	
	if self.isWagonMaster() then	// 06 Jul 2009	NDL	CCMS 1067
		self.setCaption(app.getErrorString(Wagon_master) &amp; " " &amp; app.getErrorString(Maintenance) );
	elseif self.isTILC() then
		self.setCaption(app.getErrorString(Trailer) &amp; " " &amp; app.getErrorString(Maintenance));
	elseif self.isGenerator() then
		self.setCaption(app.getErrorString(CM_Generator_GC) &amp; " " &amp; app.getErrorString(Maintenance));
	elseif self.isMAFI() then																					// 15/05/2025		navcs2	MTN-34843
		self.setCaption(app.getErrorString(Mafi) &amp; " " &amp; app.getErrorString(Maintenance));						// 15/05/2025		navcs2	MTN-34843
	else
		self.setCaption(app.getErrorString(ISO_Container) &amp; " " &amp; app.getErrorString(Maintenance));
	endif;
	//self.useNumRowsShown	:= true;
	
	self.setStatusCaption();
	self.setNavigatorHeading(self.caption);
	
	//notifications
	self.beginClassNotification(CM_TIMaster, false, Any_System_Event, Response_Continuous, null);
	self.beginClassNotification(CM_WagonMaster, false, Any_System_Event, Response_Continuous, null);
	
	self.frmTableFilter.setupControl(self.tblData, null); //05/06/2024	navkc1 CR 63736 Task 63770
	
epilog
	
	
end;</source>
    </JadeMethod>
    <JadeMethod name="showColumnOrganiser" id="8d993290-7bbf-48d5-a7c2-f3bd381965c2">
        <source>showColumnOrganiser(_dataTable : CM_DataTable input);
//--------------------------------------------------
// Created:	13 April 2005 By: cnwgd1
//--------------------------------------------------
// Changed On	By			Reason
// ----------	--------	--------------------------------------------
// 22/02/2013	cnwdap1		PAR #31155 CCMS SFW 1321 Imperial Measurements
vars
	
begin
	if _dataTable = null then
		return;
	endif;
	//epr par 33900 4/4/14 measurement columns now handled on column orgainser form
	_dataTable.showColumnOrganiserFrm(self.myTerminal, null);					// PAR #31155
	
epilog
	
end;</source>
        <Parameter name="_dataTable" type="CM_DataTable" usage="input"/>
    </JadeMethod>
    <JadeMethod name="showHideSearcher" id="4d72edfd-2a77-496a-9195-de8a5d3bacaa">
        <updating/>
        <source>showHideSearcher() updating;
//--------------------------------------------------
// Created:	29 Nov 2005 cnwdvb1
// 15/05/2025	navcs2	MTN-34843  Development - Fleet file Form implementation
//--------------------------------------------------
vars
	readonly : Boolean;
begin

	if self.frmSearcher.visible then
		self.frmSearcher.visible := false;
	
	else
		self.btnSearcher.enabled := true;
		self.frmSearcher.visible := true;
		self.frmSearcher.zOrder(1);
		self.frmSearcher.centreWindow();
		self.tblSearcher.moveFirst();
		self.tblSearcher.setFocus();
	endif;
	
	self.searcherShowHideControls(not self.frmSearcher.visible);
	
	
	
	// #### TFS 2734
	readonly := false;
	
	if (self.isTILC or self.isMAFI) and not app.myCurrentUserCan(null, PmAdmTiMasterTrailerUpdate) then		// 15/05/2025	navcs2	MTN-34843
		readonly := true;
	elseif self.isContainer and not app.myCurrentUserCan(null, PmAdmTiMasterContainerUpdate) then
		readonly := true;
	elseif self.isGenerator and not app.myCurrentUserCan(null, PmAdmTiMasterGeneratorUpdate) then
		readonly := true;
	elseif self.isWagonMaster and not app.myCurrentUserCan(null, PmWagonMasterMaint) then
		readonly := true;
	elseif self.isWagonMaster and not app.myCurrentUserCan(null, self.permissionMaint) then
		readonly := true;
	endif;

	if readonly then
		self.btnNew.enabled:= false;
		self.btnDelete.enabled:= false;
		self.btnEdit.enabled:= false;
		self.mnuAdd.enabled:= false;
		self.mnuAddTask.enabled:= false;
		self.mnuEdit.enabled:= false;
		self.mnuStops.enabled:= false;
	endif;

end;</source>
    </JadeMethod>
    <JadeMethod name="sysNotify" id="7253c4e2-d1b2-4ee8-a7f8-28eedb9d329a">
        <controlMethod name="Form::sysNotify"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>sysNotify(eventType: Integer; theObject: Object; eventTag: Integer) updating;
/* ---------------------------------------------------------------------------
Created:	18 August 2008	by cnwvu1

Purpose:	
   
Change Date		Who		Reason

------------------------------------------------------------------------------*/
vars
begin

	if ( self.isTILC()	and theObject.isKindOf( CM_TIMasterTILC) )
	or ( self.isGenerator() and theObject.isKindOf( CM_TIMasterGenerator) )
	or ( self.isContainer()	and theObject.isKindOf( CM_TIMasterContainer) )
	or ( self.isWagonMaster and theObject.isKindOf( CM_WagonMaster) )	// 06 July 2009 NDL CCMS 1067
	then
	
		if eventType = Object_Update_Event then
			self.tblDataSysNotifyUpdate(eventType, theObject, eventTag);
	
		elseif eventType = Object_Create_Event then
			self.tblDataSysNotifyCreate(eventType, theObject, eventTag);
	
		elseif eventType = Object_Delete_Event then
			self.tblDataSysNotifyDelete(eventType, theObject, eventTag);
	
		endif;
	
	//	self.doRefresh();
	endif;


end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
    </JadeMethod>
