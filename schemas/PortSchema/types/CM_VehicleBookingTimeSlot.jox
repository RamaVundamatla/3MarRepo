    <JadeMethod name="getTiIdsFromBookedItemsOrVvr" id="6faae024-086b-48e4-8a0e-9f0c60dc9368">
        <source>getTiIdsFromBookedItemsOrVvr( _deliveryIds, _pickupIds : StringArray input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 Apr 2013	cnwndl1	Initial creation	Par 31393
10 Sep 2021	navdap1	TFS 51248 SNO Truck Appointment and Pre-Notes
*/

vars
	 ti : CM_TrackedItem;

begin

	if self.myVehicleVisitRecord &lt;&gt; null then
		foreach ti in self.myVehicleVisitRecord.allReceivedTrackedItems do
			//_strArray.add( ti.id );			// TFS 51248
			_deliveryIds.add( ti.id );			// TFS 51248
		endforeach;
		foreach ti in self.myVehicleVisitRecord.allReleasedTrackedItems do
			//_strArray.add( ti.id );			// TFS 51248
			_pickupIds.add( ti.id );			// TFS 51248
		endforeach;
	
	else
		foreach ti in self.allBookedTrackedItems do
			//_strArray.add( ti.id );			// TFS 51248
			if ti.isNotified then				// TFS 51248
				_deliveryIds.add( ti.id );		// TFS 51248
			else								// TFS 51248
				_pickupIds.add( ti.id );		// TFS 51248
			endif;								// TFS 51248
		endforeach;
		
	endif;

epilog

end;</source>
        <Parameter name="_deliveryIds" type="StringArray" usage="input"/>
        <Parameter name="_pickupIds" type="StringArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getTimeslotGraceTimeInterval" id="361cf797-6603-48b2-84f3-b63020ef9905">
