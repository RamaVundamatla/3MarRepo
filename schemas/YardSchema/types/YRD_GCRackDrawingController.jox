    <JadeMethod name="doDFMouseUp" id="028a58c7-55da-4261-aa72-3994abee1c95">
        <updating/>
        <executionLocation>client</executionLocation>
        <source>doDFMouseUp(frame: Frame input; button: Integer; shift: Integer; x: Real; y: Real) updating, clientExecution;
// ---------------------------------------------------------------------------
// Created:		10 August 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	form : Form;
	theObj : Object;
	key1, key2 : Point;
	lc : CM_IrregularBlockController;
begin
	if button &lt;&gt; Frame.MouseButton_Left then
		return;
	endif;

	if self.myGCAreaEnquiryForm &lt;&gt; null then
		theObj := self.allGridObjects.findObjectInDict(x.Integer, y.Integer, key1, key2);

		if theObj = null or not theObj.isKindOf(CM_IrregularBlockController) then
			self.drawSelf(true);
		else
			lc := theObj.CM_IrregularBlockController;
//			if lc.isKindOf(CM_RackShelfController) then
				if shift.isControlKeyPressed() then
					self.selectObject(lc,self.myDrawingFrame,true);
					self.drawShelf(lc, key1.x, key1.y, key2.x, key2.y);
				elseif shift.isShiftKeyPressed() then
					self.selectLocationBlock(theObj);
					self.drawSelf(false);
				else
					self.drawSelf(true);
					self.selectObject(lc,self.myDrawingFrame,true);
					self.drawShelf(lc, key1.x, key1.y, key2.x, key2.y);
				
				endif;
	//		endif;
		endif;
		
		self.myGCAreaEnquiryForm.doDFMouseUp(frame,button,shift, x,y);

	endif;
	
end;</source>
        <Parameter name="frame" type="Frame" usage="input"/>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="doDFStatusLine" id="786cbf9a-cf6c-4611-a14b-f71395f37186">
        <source>doDFStatusLine();
/*
Purpose:			
Date		Who		Reason
05 September 2013	cnwab1	Initial creation
*/

vars

begin
		self.myGCAreaEnquiryForm.frmStatusLine.myFrameCaption.caption := null;
		self.myGCAreaEnquiryForm.frmStatusLine.myFrameCaption.caption := " Selected: " &amp; self.allSelectedObjects.size.String;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="drawSelf" id="5ea7cb5d-c3d5-4b44-b801-506e844dc4f0">
        <updating/>
        <source>drawSelf(_clearSelected: Boolean) updating;
/*
Purpose:			
Date				Who		Reason
03 September 2013	cnwab1	Initial creation
05/03/2015			cnwmh5	Transient Leak
*/
constants
	SHELFWIDTH = 40;
	SHELFHEIGHT = 20;
	COLLABELHEIGHT = 20;
	SHELFGAP = 2;
	SHELFXOFFEST = 20;	
	SHELFYOFFEST = 25;
vars
	topLeftFiller : Frame;
	a, tmpLbl : String;
	idx, idy, row, col, ord, x1, y1, x2, y2, midX, shelfy1, shelfy2, lastRow, maxX, maxY : Integer;
	tmpTA : CM_TerminalArea;
	rack : CM_IrregularBlockController;
	shelf : CM_RackShelfController;
	iter : Iterator;
	rowHeights : IntegerArray;
	edge, fillColour, rowHeight, firstRowOrd : Integer;
	fontSize, scale : Real;
begin
	
	if _clearSelected then
		self.allSelectedObjects.clear();
	endif;
	
	scale := self.scaleFactor;
	self.allGridObjects.clear();
	
	create rowHeights transient;
	rowHeights[200] := 99;
	
	self.myDrawingFrame.autoRedraw := true;
	self.myDrawingFrame.backColor := self.myTerminal.getConfig(DefYardBackColSelected).Integer;
	self.myDrawingFrame.visible := true;
	self.myDrawingFrame.drawFillStyle := Frame.DrawFillStyle_Solid;
	self.myDrawingFrame.ignoreSkin := true;
	self.myDrawingFrame.drawWidth := 1;
	self.myDrawingFrame.drawFillColor := White;
	self.myDrawingFrame.drawFontSize := 12;
	self.myDrawingFrame.clearGraphics();

	iter := self.myGCAreaEnquiryForm.allRacks.createIterator();
	
	// ### Get the highest rack on each row
	lastRow := 0;
	while iter.next(rack) do
		self.myGCAreaEnquiryForm.allRacks.getIteratorKeys(row,col,ord, iter);
		if row &lt;&gt; lastRow then
			lastRow := row;
			if firstRowOrd = 0 then
				firstRowOrd := row;
			endif;
		endif;
		rowHeights[row] := rowHeights[row].max(rack.allSubLocations.size.max(1));
		self.myDrawingFrame.getTextDrawFontSizeForWidth(rack.ident,((SHELFWIDTH - 10)  * scale).Integer);
	endwhile;
	fontSize := self.myDrawingFrame.drawFontSize;

	// ### Set some defaults
	y1 := SHELFYOFFEST;
	x1 := SHELFXOFFEST;
	x2 := x1 + (SHELFWIDTH * scale).Integer;

	
	lastRow := 0;
	row := 0;
	col := 0;
	iter.reset();
	
	while iter.next(rack) do
		self.myGCAreaEnquiryForm.allRacks.getIteratorKeys(row,col,ord, iter);
		
		// ### Row has changed
		if row &lt;&gt; lastRow and lastRow &lt;&gt; 0 then
			x1 := SHELFXOFFEST;
			x2 := x1 + (SHELFWIDTH * scale).Integer;
			rowHeight := rowHeights[lastRow]; // get the height from the LAST row drawn so that we can move down the correct amount.
			y1 := y1 + ((rowHeight * (SHELFHEIGHT + SHELFGAP)) * scale).Integer + SHELFYOFFEST + (COLLABELHEIGHT * scale).Integer;

		
		endif;
		
		rowHeight := rowHeights[row]; // get the height from the CURRENT row so that we can draw from the bottom UP
		shelfy1 := y1 + ((rowHeight * (SHELFHEIGHT + SHELFGAP)) * scale).Integer + SHELFYOFFEST + (COLLABELHEIGHT * scale).Integer;
		shelfy2 := shelfy1 - (SHELFHEIGHT * scale).Integer;
		
		midX := (x1 +  ((SHELFWIDTH * scale).Integer /2)).Integer;
//		self.myDrawingFrame.drawFontSize := fontSize;
//		self.myDrawingFrame.drawTextAlign := Frame.DrawTextAlign_Center;
//		self.myDrawingFrame.drawTextAt(rack.ident, midX,y1+5,Black);
		self.allGridObjects.putAtKey(x1, y1,x2,y1+ SHELFYOFFEST , rack );
		self.drawShelf(rack, x1, y1, x2,y1+ SHELFYOFFEST);

//		write row.String &amp; " " &amp; rowHeight.String &amp; " " &amp; 	y1.String &amp; " " &amp; shelfy1.String &amp; " " &amp; shelfy2.String;


		if rack.allSubLocations.isEmpty() then
				shelfy1 := shelfy2 - SHELFGAP;
				shelfy2 := shelfy1 - (SHELFHEIGHT * scale).Integer;
				self.allGridObjects.putAtKey(x1, shelfy2, x2,shelfy1, rack );
				self.drawShelf(rack, x1, shelfy2, x2,shelfy1);
		else
			foreach shelf in rack.allSubLocations discreteLock do
				shelfy1 := shelfy2 - SHELFGAP;
				shelfy2 := shelfy1 - (SHELFHEIGHT * scale).Integer;
				self.allGridObjects.putAtKey(x1, shelfy2, x2,shelfy1, shelf );
				self.drawShelf(shelf, x1, shelfy2, x2,shelfy1);
			
			endforeach;
		endif;
		x1 := x1 + ((SHELFWIDTH + SHELFGAP) * scale).Integer;
		x2 := x1 + (SHELFWIDTH * scale).Integer;
		lastRow := row;
		
		maxX:= x2.max(maxX);
	endwhile;

//	maxX := x2+SHELFXOFFEST;
	y1 := y1 + ((rowHeight * (SHELFHEIGHT+ SHELFGAP)) * scale).Integer + SHELFYOFFEST;
	maxY := y1+SHELFYOFFEST;
	
	tmpTA := self.myGCAreaEnquiryForm.allRacks.first.myTerminalArea;
	


	self.myVLabels.clearGraphics();
	self.myVLabels.width := self.LABEL_WIDTH;
	self.myVLabels.top := self.LABEL_WIDTH + 1;
	self.myVLabels.autoRedraw := true;
	self.myVLabels.backColor := self.myTerminal.getConfig(DefYardBackColSelected).Integer;
	self.myVLabels.drawFillStyle := Frame.DrawFillStyle_Solid;
	
	self.myHLabels.clearGraphics();
	self.myHLabels.height := self.LABEL_WIDTH;
	self.myHLabels.autoRedraw := true;
	self.myHLabels.backColor := self.myTerminal.getConfig(DefYardBackColSelected).Integer;
	self.myHLabels.drawFillStyle := Frame.DrawFillStyle_Solid;
	self.setFontDefaults();
	
	topLeftFiller := self.myDockBar.myScrollableFrame.myTopLeftFillerFrame;
	topLeftFiller.ignoreSkin := true;
	topLeftFiller.clearGraphics();
	topLeftFiller.autoRedraw := true;
	topLeftFiller.backColor := self.myTerminal.getConfig(DefYardBackColSelected).Integer;
	topLeftFiller.drawFillStyle := Frame.DrawFillStyle_Solid;
	topLeftFiller.drawFontSize := 10; // ### PAR 10555
	topLeftFiller.width := self.myVLabels.width;
	topLeftFiller.height := self.myHLabels.height;
	
	tmpLbl := tmpTA.getID();
	if tmpLbl.length &lt; 3 then // ### PAR 10555
		topLeftFiller.drawFontSize := 16; // ### PAR 10555
	elseif tmpLbl.length &lt; 6 then // ### PAR 10555
		topLeftFiller.drawFontSize := 8; // ### PAR 10555
	else
		topLeftFiller.drawFontSize := 6; 
	endif;
	
	topLeftFiller.drawTextAt(tmpLbl, 1, 8, self.myTerminal.getConfig(DefYardBackColSelected).Integer.getInverseColour()); // ### PAR 10555

	self.myDockBar.resizeScrollingFrame(maxX, maxY);
	
	self.maxColumn := maxX;
	self.maxRow := maxY;
	self.myDockBar.myScrollingFrame.left := self.LABEL_WIDTH + 1;
	self.myDockBar.myScrollingFrame.top := self.LABEL_WIDTH + 1;
	self.myDockBar.resetScrollValues();

	
epilog
	delete rowHeights;
	delete iter;
end;</source>
        <Parameter name="_clearSelected" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="drawShelf" id="3e76b196-a3ce-406a-874a-cb11952c30a3">
        <source>drawShelf(_lc : CM_IrregularBlockController;  x1, y1, x2, y2 : Integer);
/*
Purpose:			
Date		Who		Reason
04 September 2013	cnwab1	Initial creation
*/

vars
	fillColour, textColour, edge, y3, textY : Integer;
	capacityPC, capacityMax : Integer;
	caption : String;
	theTI : CM_TrackedItem;
	ya : CM_YardAllocation;
	vol, weight : Decimal[12,4]; 
	qty : Integer;
begin
	
	
	if self.allSelectedObjects.includes(_lc) then
		edge := Red;
	else
		edge := Green;
	
	endif;
	
	capacityPC := _lc.getCapacityPC(self.getMoveModeFromDisplayMode());
	capacityMax := _lc.getCurrentCapacity();
	_lc.getTotalsByMode(self.getMoveModeFromDisplayMode(), vol, weight, qty);
	
	if self.viewMode = VIEW_YARD_ALLOC then
		ya := _lc.allYardAllocations.first;
		if ya = null then
			fillColour := White;
		else
			fillColour := ya.color;
		endif;
		self.myDrawingFrame.drawFillColor := fillColour;
	else
		theTI := _lc.getTIAtIndex(self.getMoveModeFromDisplayMode(), 1);
		if theTI = null then
			fillColour := White;
		else
			fillColour := self.getFillColourForTI(theTI);
		endif;
		self.myDrawingFrame.drawFillColor := White;
	endif;
	
	if fillColour = White then
		self.myDrawingFrame.drawFillStyle := Frame.DrawFillStyle_Solid;
	else
		self.myDrawingFrame.drawFillStyle := Frame.DrawFillStyle_Solid;
	endif;
	
	if _lc.isShelf() then
		self.myDrawingFrame.drawFilledRectangle(x1, y1, x2, y2, edge);
	endif;
	
	
	if capacityPC = 0 then
		caption := _lc.ident;
		textY := y2 - 15;
		textColour := fillColour.getInverseColour();
	elseif self.viewMode = VIEW_YARD_ALLOC then
		caption := _lc.ident;
		textY := y2 - 15;
		textColour := fillColour.getInverseColour();
	else
		if self.scaleFactor &lt; 2 then // 1.5
			caption := _lc.ident &amp; CrLf &amp; capacityMax.String &amp; " "  &amp; capacityPC.String&amp;"%";
		elseif self.scaleFactor &lt; 3 then // 2
			caption := _lc.ident &amp; CrLf &amp; app.getErrorString1(RackCapacity2, capacityMax.String) &amp;  " "    &amp; app.getErrorString1(RackFull2,capacityPC.String);
		else
			caption := _lc.ident &amp; CrLf &amp; qty.String &amp;"/" &amp; app.getErrorString1(RackCapacity1, capacityMax.String) &amp;  CrLf     &amp; app.getErrorString1(RackFull1,capacityPC.String);
		
		endif;
		// ### Work out graphical 'filled' percentage
		y3 := y2 - y1;
		y3 := (y3 * (capacityPC.min(100)/ 100)).Integer;
		y3 := y2 - y3;
		self.myDrawingFrame.drawFillColor := fillColour;
		if _lc.isShelf() then
			self.myDrawingFrame.drawFilledRectangle(x1+1, y3, x2-1, y2-1, fillColour);
		endif;
		
			if self.scaleFactor = 3 then
				if (y2-y3) &gt; 35 then
					textY := y3 ;
					textColour := fillColour.getInverseColour();
				else
					textY := y1;
					textColour := Black;
				endif;
			elseif self.scaleFactor = 4 then 
				if (y2-y3) &gt; 38 then
					textY := y3 ;
					textColour := fillColour.getInverseColour();
				else
					textY := y1;
					textColour := Black;
				endif;
			elseif self.scaleFactor = 1.5 then 
				if (y2-y3) &gt; 20 then
					textY := y3 ;
					textColour := fillColour.getInverseColour();
				else
					textY := y1;
					textColour := Black;
				endif;
			elseif self.scaleFactor = 2 then 
				if (y2-y3) &gt; 20 then
					textY := y3 ;
					textColour := fillColour.getInverseColour();
				else
					textY := y1;
					textColour := Black;
				endif;
			endif;

//		endif;
	endif;
	
	if self.scaleFactor &lt; 1.5 then //  0.75 or 1
		self.myDrawingFrame.drawFontSize := 8;
		self.myDrawingFrame.drawTextAlign := Frame.DrawTextAlign_Left;
		self.myDrawingFrame.drawTextAt(caption, x1 + 3,textY,textColour);
	elseif self.scaleFactor &lt; 2 then // 1.5
		self.myDrawingFrame.drawFontSize := 8;
		self.myDrawingFrame.drawTextAlign := Frame.DrawTextAlign_Left;
		self.myDrawingFrame.drawTextAt(caption, x1 + 3,textY,textColour);
		if self.viewMode = VIEW_YARD_ALLOC and ya &lt;&gt; null then
			caption := ya.description[1:8];
			textY := y1;
			textColour := fillColour.getInverseColour();
			self.myDrawingFrame.drawFontSize := 8;
			self.myDrawingFrame.drawTextAlign := Frame.DrawTextAlign_Left;
			self.myDrawingFrame.drawTextAt(caption, x1 + 3,textY,textColour);
			self.myDrawingFrame.drawTextAlign := Frame.DrawTextAlign_Right;
			self.myDrawingFrame.drawTextAt("C:" &amp; _lc.maxCapacity.String, x2-3,y2-15,textColour);
		endif;
	elseif self.scaleFactor &lt; 3 then // 2
		self.myDrawingFrame.drawFontSize := 8;
		self.myDrawingFrame.drawTextAlign := Frame.DrawTextAlign_Left;
		self.myDrawingFrame.drawTextAt(caption, x1 + 3,textY,textColour);
		if self.viewMode = VIEW_YARD_ALLOC and ya &lt;&gt; null then
			caption := ya.description[1:10] &amp;  CrLf &amp; app.getErrorString(Capacity) &amp;":" &amp; _lc.maxCapacity.String; 
			textY := y1;
			textColour := fillColour.getInverseColour();
			self.myDrawingFrame.drawFontSize := 8;
			self.myDrawingFrame.drawTextAlign := Frame.DrawTextAlign_Left;
			self.myDrawingFrame.drawTextAt(caption, x1 + 3,textY,textColour);
		endif;
	elseif self.scaleFactor &lt; 10 then 
		self.myDrawingFrame.drawFontSize := 8;
		self.myDrawingFrame.drawTextAlign := Frame.DrawTextAlign_Left;
		self.myDrawingFrame.drawTextAt(caption, x1 + 3,textY,textColour);
		if self.viewMode = VIEW_YARD_ALLOC and ya &lt;&gt; null then
			caption := ya.description[1:16] &amp;  CrLf &amp; app.getErrorString(Capacity) &amp;":" &amp; _lc.maxCapacity.String; 
			textY := y1;
			textColour := fillColour.getInverseColour();
			self.myDrawingFrame.drawFontSize := 8;
			self.myDrawingFrame.drawTextAlign := Frame.DrawTextAlign_Left;
			self.myDrawingFrame.drawTextAt(caption, x1 + 3,textY,textColour);
		endif;
	endif;
epilog

end;</source>
        <Parameter name="_lc" type="CM_IrregularBlockController"/>
        <Parameter name="x1" type="Integer"/>
        <Parameter name="y1" type="Integer"/>
        <Parameter name="x2" type="Integer"/>
        <Parameter name="y2" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="drawShelfFromNote" id="0cef3816-4278-4e2b-8ca5-3a7e3c6cdcd0">
        <source>drawShelfFromNote(_lc: CM_RackShelfController);
/*
Purpose:			
Date		Who		Reason
19 September 2013	cnwab1	Initial creation
*/

vars
	x1, y1, x2, y2 : Integer;
	xy1, xy2 : Point ;
begin
		if self.allGridObjects.findObjectInDictGetXY(_lc, xy1, xy2) then

			x1 := xy1.x;
			y1 := xy1.y;
			x2 := xy2.x;
			y2 := xy2.y;
			
			self.drawShelf(_lc, x1, y1, x2, y2);
		endif;

epilog

end;</source>
        <Parameter name="_lc" type="CM_RackShelfController"/>
    </JadeMethod>
