    <JadeMethod name="jlirs1ProcessFile" id="aa44d53d-a4ea-458a-b6e8-5185a75b6fcd">
        <source>jlirs1ProcessFile();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 June 2023	jlirs1	Initial creation

*/

vars
	transData : CM_EDIDataTransManifest;
	ediFile : CM_EDIFile;
	ediControllerAgent :CM_EDIControllerAgent;
	terminal : CM_Terminal;
begin
	app.initialize;
	create ediControllerAgent transient;
	terminal := app.myRoot.allTerminals["UT"];
	app.myPassport.setMyTerminal(terminal);
	app.myPassport.setMyUserFromCode("SARGE");
	app.changeLogLevel(LogDEBUG);
	ediControllerAgent.setTerminal(terminal);	
	transData := "16931.95".asOid.CM_EDIDataTransManifest;
	ediFile := transData.myEDIFile;
	ediControllerAgent.processFileData(ediFile, app.myPassport);
epilog
	delete ediControllerAgent;
end;</source>
