    <JadeMethod name="setForUpdateTI" id="fa6a5042-404f-4791-a710-a1babeab83d8">
        <updating/>
        <source>setForUpdateTI(_ti: CM_TrackedItem) updating;
/*
Purpose:		27749	To allow location specific updates based on the TI update			
Date		Who		Reason
23 June 2011	cnwab1	Initial creation
*/

vars
	newColour : Integer;
begin
	inheritMethod(_ti);

	if self.mySlotDefn = null then
		return;
	endif;
	if _ti = null then
		return;
	endif;
	app.myEventManager.createSingleObjInfoNoteEvt(self.myVoyage,self.myVoyage.myTerminal.getTerminalEvent(EVENT_UPDATE_VOYAGE_AREA),	self);
	
	newColour := _ti.getDrawingColour(TI_ColourMode_DischargePort);
	if newColour &lt;&gt; self.mySlotDefn.myROROLocnDen.myLayout.drawFillColour then
		self.mySlotDefn.myROROLocnDen.myLayout.setRealDrawFillColour(newColour);
	endif;
epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="setFromROROSlotDefn" id="fa6e6372-c3f5-4a8b-a437-3db74b1b4bbd">
        <updating/>
        <source>setFromROROSlotDefn() updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
01 June 2011	cnwer1	Initial creation CCMS MES 1116

*/

vars

begin
	self.ident:=self.mySlotDefn.code;
	self.ordinalSlot:=self.mySlotDefn.ordinal;
	self.ordinalLocn:=self.mySlotDefn.myROROLocnDen.ordinal;
	self.myDeck:=self.mySlotDefn.myDeck.CM_DeckVoyage;
	self.ordinalDeck:=self.myDeck.ordinal;
	self.myVoyage:=self.myDeck.CM_DeckVoyage.getVoyage();
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setROROLayoutRemarks" id="60ca64ac-a63d-440f-9def-1a821f44fc80">
        <updating/>
        <source>setROROLayoutRemarks(_remarks :String) updating;
/*
Date		Who		Reason
20 Aug 2012	cnwcs5	Initial creation - par 29124:2
*/
vars
	slot 		:CM_ROROSlotDefnVoyage;
	location	:CM_ROROLocnDefn;
	layout		:CM_DeckItemLayout;
begin
	slot := self.mySlotDefn;
	
	if slot = null then
		return;
	endif;
	
	location := slot.myROROLocnDen;
	
	if location = null then
		return;
	endif;
	
	layout := location.myLayout;
	
	if layout &lt;&gt; null then
		layout.setRemarks (_remarks);
	endif;	
epilog

end;</source>
        <Parameter name="_remarks" type="String"/>
    </JadeMethod>
    <JadeMethod name="setupForPremove" id="35920562-f5c4-46a6-b3d3-75150133941d">
        <source>setupForPremove(_cmif: CMIF_MoveController input);
/*
Purpose:	28990 - if we are the first actual move in a rotated group we must rotated the actual locations and move all the colour coding
				and future moves from our 'clones' to the actuals for the whole group. 
				Then we delete all the clones and switch this move to the actual location		
				NOTE - WE ARE THE CLONE ALWAYS
Date		Who		Reason
24 February 2012	cnwab1	Initial creation
*/

vars
	vwle : CM_VoyageWLE;
	aftSlot : CM_ROROSlotController;
	di : CM_DeckItem;
	aftLocnNotInOurGroup : CM_VoyageROROController;
begin

	
	if _cmif.moveMode &lt;&gt; REAL_MODE then
		return;
	endif;

	if not self.isRotatedLinked(true) and not self.isRotatedLinked(false) then
		aftSlot := _cmif.allToLocations.last.CM_ROROSlotController;
		if aftSlot &lt;&gt; self then
			aftSlot.setupForPremove(_cmif);
		endif;
		
		return;
	endif;
	
	di := self.getDefn();
	if di.CM_ROROLocnDefn.isPlannedRotated then //I am the clone. If I am rotated them we need to rotate teh actual and get rid of me and my group
		// PAR 32078 - instant move but not colour coding, so we are being moved into a rotated area. 
		//					This means that now the load should be rotated as well, because not everything in this rotation group is colour coded for discharge
		vwle := _cmif.myTrackedItem.getVoyageWLEUnactioned(false);
		if di.isOnLayerCargo // on the actual cargo layer
		and self.isRotatedLinked(true) // is an actual linked to a load
		and vwle = null then // no discharge WLE, i.e. no discharge CC
				
			if self.isRotatedLinked(true) then
				self.setupForPremoveMoveIn(_cmif);
			endif;
			return;
		endif;
	
		// if loading from EDI PLANS we are just creating TIs in a loacation that has already been rotated so ignore.
		// Only rotate if we are in a formal WLE and Job.
		vwle := _cmif.myTrackedItem.getVoyageWLEUnactioned(true);
		if vwle = null then
			return;
		endif;
		self.setupForPremoveRotation(_cmif); // ROTATE The ACTUAL
	else //I am the clone. If I am NOT rotated them we need to unrotate the actual and get rid of me and my group
		// if loading from EDI PLANS we are just creating TIs in a loacation taht has already been rotated so ignore.
		// Only rotate if we are in a formal WLE and Job.
		vwle := _cmif.myTrackedItem.getVoyageWLEUnactioned(true);
		if vwle = null then
			return;
		endif;
		aftLocnNotInOurGroup := self.setupForPremoveUnrotation(_cmif); // UN ROTATE THE ACTUAL
		if aftLocnNotInOurGroup &lt;&gt; null then
			aftLocnNotInOurGroup.setupForPremove(_cmif);
		endif;
	endif;

epilog
end;</source>
        <Parameter name="_cmif" type="CMIF_MoveController" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setupForPremoveMoveIn" id="1dbbc124-6798-4771-aaff-489bd9c1ca4c">
        <source>setupForPremoveMoveIn(_cmif: CMIF_MoveController);
/*
Purpose: Determining whether to rotate the load view if a new container is moved into the rotated group			
Date		Who		Reason
07 August 2013	cnwab1	Initial creation
*/

vars
	theMaster, theCloneMaster, loadLocn, actualLocn : CM_ROROLocnDefn;
	allMasters : ObjectSet;
	obj : Object;
	loadLayer : CM_DeckLayerLayout;
begin
	
	create allMasters transient;
	
	// PAR 32078 - CCMS 1320 - if we are deleting discharge colour coding on a rotated actual, then we need to clean up the load clone.
	theMaster := self.getRotationMaster();
	if theMaster &lt;&gt; null and not theMaster.isOOTL() and theMaster.isOnLayerCargo() then
		allMasters.addNoDuplicates(theMaster, false);
	endif;

	// PAR 31110 - CCMS 1320 - The trigger to have a cloned unrotated load view is that everything is discharge colour coded, if they has erased any discharge CC then get rid of the load clone
	// PAR 31110 - CCMS 1320 - if we are deleting discharge colour coding on a rotated actual, then we need to clean up the load clone.
	foreach obj in allMasters  discreteLock do
		theMaster := obj.CM_ROROLocnDefn;
		if not theMaster.isRotatedLinked(true) then // not linked to a clone so ignore
			continue;
		endif;

		if not theMaster.isOOTL then 
			app.writeVoyageLog(theMaster, "Rotating load, " &amp; _cmif.myTrackedItem.String &amp; " moved into rotated group");
		
			foreach actualLocn in theMaster.allPlannedRotatedLocnDefns discreteLock do
				loadLocn := actualLocn.getRotatedLinked(); // Get the clone
				
				if loadLocn &lt;&gt; null then
					if loadLocn.hasColourCoding(LOAD_MOVETYPE) &lt;&gt; null then
						app.raiseCMException1(Posit_canno_rotat_becua_load_c,loadLocn.code, null, null);
					endif;

					delete loadLocn;
				endif;
			endforeach;

		endif;
		loadLayer := self.myDeck.myDeckLayout.getCCLoadLayer(); 
		theMaster.myLayout.myDeckLayer.causeEvent(EVENT_RORO_LAYER_UPDATE,false,loadLayer); 
	endforeach;

epilog

	delete allMasters;



end;</source>
        <Parameter name="_cmif" type="CMIF_MoveController"/>
    </JadeMethod>
    <JadeMethod name="setupForPremoveRemove" id="618c4798-cd6e-4e76-aed3-26abb0cf51b6">
        <source>setupForPremoveRemove(_cmif: CMIF_MoveController);
/*
Purpose:	Determining whether to unrotate the load view if a new container is moved out of the rotated group					
Date		Who		Reason
07 August 2013	cnwab1	Initial creation
*/

vars
	theMaster, theCloneMaster, loadLocn, actualLocn : CM_ROROLocnDefn;
	allMasters : ObjectSet;
	 obj : Object;

begin
	
	
	// PAR 32078 - CCMS 1320 - if we are deleting discharge colour coding on a rotated actual, then we need to clean up the load clone.
	theMaster := self.getRotationMaster();
	if theMaster = null then // not rotated
		return;
	endif;
	
	create allMasters transient;
	if not theMaster.isOOTL() and theMaster.isOnLayerCargo() then
		allMasters.addNoDuplicates(theMaster, false);
		app.writeVoyageLog(theMaster, "Unrotating load, " &amp; _cmif.myTrackedItem.String &amp; " moved out of rotated group");
	endif;

	// PAR 32078 - CCMS 1320 if everything in the rotated actual is colour coded for discharge then clone and unrotated the load view.
	app.myUtilityCA.utlCreateRORORotateSwitchLoad(allMasters, app.myPassport);

	epilog

	delete allMasters;



end;</source>
        <Parameter name="_cmif" type="CMIF_MoveController"/>
    </JadeMethod>
    <JadeMethod name="setupForPremoveRotation" id="7fda4900-430d-4eec-ab6b-79374817651c">
        <source>setupForPremoveRotation(_cmif: CMIF_MoveController input);
/*
Purpose:	if we are the first actual move in a rotated group of load positions we must rotated the actual locations and move all the colour coding
				and future moves from our 'clones' to the actuals for the whole group. 
				Then we delete all the clones and switch this move to the actual location.
				NOTE. this only happens when  the first item in the rotated group is moved.
				NOTE. The load is always the CLONE.
Date		Who		Reason
24 February 2012	cnwab1	Initial creation
*/

vars
	actualLocn, actualRotationMaster, clonedRotationMaster, clonedLocn : CM_ROROLocnDefn;
	actualSlotDefn : CM_ROROSlotDefn;
	cloneLC, actualLC : CM_ROROSlotController;
	items, split : Integer;
	array : CM_LCArray;
		dReq : CM_RORORequest;
begin
	if _cmif.moveMode &lt;&gt; REAL_MODE then
		return;
	endif;

	// I am the clone on the load layer
	cloneLC := self;
	clonedLocn := cloneLC.mySlotDefn.myROROLocnDen;
//	if not self.isRotatedLinked(true) then
	if not clonedLocn.isPlannedRotated then //I am the clone. If I am rotated them we need to rotate teh actual and get rid of me and my group
		return;
	endif;
	
	
	actualLocn := cloneLC.mySlotDefn.myROROLocnDen.getRotatedLinked();
	actualSlotDefn := actualLocn.allROROSlotDefnByOrdinal[actualLocn.ordinal, cloneLC.mySlotDefn.ordinal];
	actualLC := actualSlotDefn.CM_ROROSlotDefnVoyage.mySlotController;
	
	clonedRotationMaster := cloneLC.mySlotDefn.myROROLocnDen.getRotationMaster();
	
	if clonedRotationMaster = null then
		return;
	endif;
	
	actualRotationMaster := clonedRotationMaster.getRotatedLinked();

	// ### Go through the cloned locations and move all the colour coding and future move details to the actual location
	foreach clonedLocn in clonedRotationMaster.allPlannedRotatedLocnDefns discreteLock do
		clonedLocn.copyAllRotatedCloneDetails();
	endforeach;

	// ### Rotate Actual Locations
	items := clonedRotationMaster.allPlannedRotatedLocnDefns.size;
	if items = 10 or items = 6 then
		split := 2;
	else
		split := 1;
	endif;

	// PAR 28990 - if unrotating and the locn defns are on the load cc layer, then delete the locn defn
	clonedRotationMaster.myDeck.causeEvent(self.myTerminal.getTerminalEvent(EVENT_RORORotationUpdate),false,clonedRotationMaster); 

	if clonedRotationMaster.myLayout &lt;&gt; null
	and clonedRotationMaster.myLayout.myDeckLayer &lt;&gt; null then
	
		clonedRotationMaster.myDeck.causeEvent(self.myTerminal.getTerminalEvent(EVENT_RORORotationUpdate),false,clonedRotationMaster); 
		
		if clonedRotationMaster.isRotatedLoadLayer() then
//		if clonedRotationMaster.myLayout.myDeckLayer.type = ROROLayerType_CCLoad then
			clonedRotationMaster.myLayout.myDeckLayer.causeEvent(EVENT_RORO_LAYER_UPDATE,false,null); 
		endif;
	endif;
	
	clonedRotationMaster.CM_ROROLocnDefnVoyage.eraseForUnrotate(true);	// ### Delete Cloned Locations and de link from actuals
	
	app.myUtilityUA.utlUpdateROROLocnDefnRotate(actualRotationMaster, items, split,false, app.myPassport, false);
	
	if not app.myPassport.checkValidation() then
		return;
	endif;
	
	// ### Go through the cloned locations and on the actual location delink 
	foreach actualLocn in actualRotationMaster.allPlannedRotatedLocnDefns discreteLock do
		actualLocn.setRotateCloneLink(null);
	endforeach;

	// PAR 31347
	foreach actualLocn in actualRotationMaster.allPlannedRotatedLocnDefns discreteLock do
		dReq := actualLocn.getFirstRequest(false);
		if dReq &lt;&gt; null and actualLocn.myLayout &lt;&gt; null then
			actualLocn.myLayout.hideContainerPositionsUnderGC(dReq.myLayout);
		endif;
	endforeach;

	// ### Switch the move
	_cmif.setMyToPrimaryLocation(actualLC);
	
// PAR 30245 	if _cmif.myTrackedItem.isForty() then
	if not _cmif.myTrackedItem.isTwenty() then
		create array transient;
		array.add(actualLC.getAftLC());
		_cmif.setMyToSecondaryLocations(array);// 40 so pass in aft
	else
		_cmif.setMyToSecondaryLocations(null);// 20 so no extras
	endif;
	
epilog
	delete array;
end;</source>
        <Parameter name="_cmif" type="CMIF_MoveController" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setupForPremoveUnrotation" id="089ba614-cdb6-4abf-8c6e-08b7097d298b">
        <source>setupForPremoveUnrotation(_cmif: CMIF_MoveController input): CM_VoyageROROController;
/*
Purpose:	If we are the first actual move to a rotated group of actual positions, we must unrotated the actual locations and move all the colour coding
				and future moves from our 'clones' to the actuals for the whole group. 
				Then we delete all the clones and switch this move to the actual location.
				NOTE. this only happens when  the first item in the load group is moved.
				NOTE. The load is always the CLONE.
Date		Who		Reason
24 February 2012	cnwab1	Initial creation
*/

vars
	actualLocn, actualRotationMaster, clonedLocn : CM_ROROLocnDefn;
	aftLocnNotInOurGroup : CM_VoyageROROController;
	actualSlotDefn : CM_ROROSlotDefn;
	cloneLC, actualLC : CM_ROROSlotController;
	split, items : Integer;
	array : CM_LCArray;
	dReq : CM_RORORequest;
	locns : CM_ROROLocnDefnByOrdinalDict;
begin

	if _cmif.moveMode &lt;&gt; REAL_MODE then
		return null;
	endif;
	
	// I am the clone on the load layer
	cloneLC := self;
	clonedLocn := cloneLC.mySlotDefn.myROROLocnDen;
//	if not self.isRotatedLinked(false) then
	if clonedLocn.isPlannedRotated then //I am the clone.
		return null;
	endif;
	

	
	actualLocn := cloneLC.mySlotDefn.myROROLocnDen.getRotatedLinked();
	actualSlotDefn := actualLocn.allROROSlotDefnByOrdinal[actualLocn.ordinal, cloneLC.mySlotDefn.ordinal];
	actualLC := actualSlotDefn.CM_ROROSlotDefnVoyage.mySlotController;
	actualRotationMaster := actualLocn.getRotationMaster();
	
	if actualRotationMaster = null then
		return null;
	endif;
	
	create locns transient;// PAR 31366
	
	
	items := actualRotationMaster.allPlannedRotatedLocnDefns.size;
	if items = 10 or items = 6 then
		split := 2;
	else
		split := 1;
	endif;
	
	aftLocnNotInOurGroup := actualRotationMaster.getAft40LocnInRotateGroup(); // 28990 pt3

	actualRotationMaster.allPlannedRotatedLocnDefns.copy(locns); // PAR 31366

	// ### Go through the cloned locations and move all the colour coding and future move details to the actual location
	foreach actualLocn in actualRotationMaster.allPlannedRotatedLocnDefns discreteLock do
		actualLocn.myRotateLoad.copyAllRotatedCloneDetails();
/*		
		if split =1 then
			if actualLocn.myRotateLoad.myAdjacentSlotAft &lt;&gt; null then
				actualLocn.myRotateLoad.myAdjacentSlotAft.copyAllRotatedCloneDetails();
			endif;
		endif;
		*/
	endforeach;

	// ### Rotate Actual Locations

	// PAR 28990 - if unrotating and the locn defns are on the load cc layer, then delete the locn defn
	actualRotationMaster.myDeck.causeEvent(self.myVoyage.myTerminal.getTerminalEvent(EVENT_RORORotationUpdate),false,actualRotationMaster); 

	if actualRotationMaster.myLayout &lt;&gt; null
	and actualRotationMaster.myLayout.myDeckLayer &lt;&gt; null then
	
		actualRotationMaster.myDeck.causeEvent(self.myVoyage.myTerminal.getTerminalEvent(EVENT_RORORotationUpdate),false,actualRotationMaster); 
		
		if actualRotationMaster.isRotatedLoadLayer() then
		//if actualRotationMaster.myLayout.myDeckLayer.type = ROROLayerType_CCLoad then
			actualRotationMaster.myLayout.myDeckLayer.causeEvent(EVENT_RORO_LAYER_UPDATE,false,null); 
		endif;
	endif;
	
//	actualRotationMaster.CM_ROROLocnDefnVoyage.eraseForUnrotate(false);	// ### Delete Cloned Locations and de link from actuals
	
	app.myUtilityUA.utlUpdateROROLocnDefnUnRotate(false, true, actualRotationMaster,app.myPassport); // 29884

	if not app.myPassport.checkValidation() then
		return null;
	endif;
	
	// ### Go through the cloned locations and on the actual location delink 
	foreach actualLocn in actualRotationMaster.allPlannedRotatedLocnDefns discreteLock do
		actualLocn.setRotateCloneLink(null);
	endforeach;

	// PAR 31347
	foreach actualLocn in actualRotationMaster.allPlannedRotatedLocnDefns discreteLock do
		dReq := actualLocn.getFirstRequest(false);
		if dReq &lt;&gt; null and actualLocn.myLayout &lt;&gt; null then
			actualLocn.myLayout.hideContainerPositionsUnderGC(dReq.myLayout);
		endif;
	endforeach;
	
	// PAR 31366
	foreach actualLocn in locns discreteLock do
		// only do the afts
		if actualLocn.myAdjacentSlotFwd &lt;&gt; null
		and locns.includes(actualLocn.myAdjacentSlotFwd) then
			actualLocn.switchDischargeCCOnUnrotate();
		endif;
	endforeach;

	// ### Switch the move
	// NOTE - If get an crash here because of null LCs after this switch, it will be because there has been warnings that have aborted the transaction.
// PAR 30245 	if _cmif.myTrackedItem.isForty() then
	if not _cmif.myTrackedItem.isTwenty() then
		create array transient;
		if actualLC.isBackEnd(_cmif.myTrackedItem, PLANNING_MODE) then
			_cmif.setMyToPrimaryLocation(actualLC.getFwdLC());
			array.add(actualLC);
		else
			_cmif.setMyToPrimaryLocation(actualLC);
			array.add(actualLC.getAftLC());
		endif;
		_cmif.setMyToSecondaryLocations(array);// 40 so pass in aft
	else
		_cmif.setMyToPrimaryLocation(actualLC);
		_cmif.setMyToSecondaryLocations(null);// 20 so no extras
	endif;

	return aftLocnNotInOurGroup;
epilog
	delete array;
		delete locns;
end;</source>
        <Parameter name="_cmif" type="CMIF_MoveController" usage="input"/>
        <ReturnType type="CM_VoyageROROController"/>
    </JadeMethod>
    <JadeMethod name="testHazardLoadCC" id="73ac9ba9-bd19-4ebf-baf9-e7a1e51237bf">
        <source>testHazardLoadCC(_voyAlloc: CM_VoyageAllocation);
/*
Purpose:			
Date		Who		Reason
28 July 2011	cnwab1	Initial creation
*/

vars
	tmpHazardArray1	: ObjectArray;
	ruleType		: Integer;
	vert			: Integer;
	horiz			: Integer;
	depth			: Integer;

begin

	// get the rule type
	ruleType := self.getHazardSegregationRuleType();

	// get the current slot controllers hazard, vert, horiz, depth details
	create tmpHazardArray1 transient;
	_voyAlloc.getAllocationsHazAndProximity(ruleType, tmpHazardArray1, vert, horiz, depth);
	if tmpHazardArray1.isEmpty then
		return;
	endif;
	
	
	self.mySlotDefn.myROROLocnDen.CM_ROROLocnDefnVoyage.testHazardLoadCC(tmpHazardArray1);
	
epilog
	delete tmpHazardArray1;
end;</source>
        <Parameter name="_voyAlloc" type="CM_VoyageAllocation"/>
    </JadeMethod>
    <JadeMethod name="testIsControllerAvailable" id="7bcafb06-4432-426e-b85b-5f20ef6fe2f2">
        <source>testIsControllerAvailable(_autoMovePlan: CMIF_AutoMovePlan input);
/*
Purpose:			
Date				Who			Reason
SEPTEMBER 2011		CNWAB1		Initial creation
*/

vars
	slotDefn : CM_ROROSlotDefn;
	locnDefn : CM_ROROLocnDefn;
begin
	_autoMovePlan.updateController(null);
	
	slotDefn := self.mySlotDefn;
	if slotDefn = null then
		return;
	endif;
	
	locnDefn := slotDefn.myROROLocnDen;
	
	if locnDefn = null then
		return;
	endif;
	
	
	// OOTL location will not be visible because the request is complete
	if (locnDefn.isOOTL() and  not locnDefn.myLayout.isVisible)  or (locnDefn.myAdjacentSlotFwd&lt;&gt;null and  not locnDefn.myAdjacentSlotFwd.myLayout.isVisible) then
		_autoMovePlan.addLogEntry(app.getErrorString1(Unavailable, self.getFullId) &amp; " " &amp; app.getErrorString(Disch_ootl_roro_area_not_visib), IsError, Unavailable);
		return;
	endif;
	
	//We are happy, so set ref to us.
	_autoMovePlan.updateController(self);
end;</source>
        <Parameter name="_autoMovePlan" type="CMIF_AutoMovePlan" usage="input"/>
    </JadeMethod>
    <JadeMethod name="testPileColourHeightUnderDeck" id="88a0e4da-7904-4fe6-8d74-03922153af6e">
        <source>testPileColourHeightUnderDeck(_prevSelectedCellsHeight : Real; _changeHighCubes : Boolean);
/*
Purpose:			
Date				Who			Reason
JULY 2011		CNWAB1		Initial creation
*/

vars
	maxHeight,
	pileHeight : Real;
	maxHighCubesUD : Integer;
begin
	
	// Only validate under deck heights, on deck is not problem
	if self.ordinalDeck &lt;&gt; DeckUnderDeck then
		return;
	endif;
		
	if self.myDeck = null then
		return;	
	endif;
	if self.mySlotDefn = null then
		return;	
	endif;
	
	if self.mySlotDefn.myROROLocnDen = null then
		return;	
	endif;	
	
	maxHeight := self.mySlotDefn.myROROLocnDen.maxStackHeight; 
	
	pileHeight := self.mySlotDefn.myROROLocnDen.getCellPileColourHeight();
	
	
	
	if pileHeight &gt; maxHeight or (_changeHighCubes and _prevSelectedCellsHeight &gt; 0 and pileHeight + HEIGHT_FULL_HIGH_CUBE &gt; maxHeight) then
		if _changeHighCubes then
			app.raiseCMWarning2(WarningHighCubeHeightExceeded,maxHighCubesUD.String, self.getFullId(),null,null,null);
		endif;			
	endif;	
end;</source>
        <Parameter name="_prevSelectedCellsHeight" type="Real"/>
        <Parameter name="_changeHighCubes" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="testPileHazardous" id="099f99a8-a9f5-4387-b450-1b39b961aa27">
        <source>testPileHazardous(_ti: CM_TrackedItem);
/*
Purpose:			
Date		Who		Reason
23 September 2011	cnwab1	Initial creation
*/

vars
	locnDefn : CM_ROROLocnDefnVoyage;
	hazard : CM_Hazard;
	hazardClass			: CM_HazardClass;
	obj : Object;
	locnHazClasses : ObjectArray;
begin

	if not _ti.isHazardous then
		return;
	endif;
	
	locnDefn := self.mySlotDefn.myROROLocnDen.CM_ROROLocnDefnVoyage;

	// convert our haz object to haz class object
	create locnHazClasses transient;
	foreach hazard in locnDefn.allHazardsAllowed  discreteLock do
		hazardClass := hazard.getClassObject();
		if hazardClass &lt;&gt; null then
			locnHazClasses.add(hazardClass);
		endif;
	endforeach;
	
	// if the passed in class are not in our ALLOWED collection then error.
	foreach hazard in _ti.allTIHazards do
		hazardClass := hazard.getClassObject();
		if hazardClass &lt;&gt; null then
			if not locnHazClasses.includes(hazardClass) then
			// Hazardous validation : Colour coding cannot continue for location %1, because it does not allow hazard class of %2
				app.raiseCMWarning3(Hazar_hazar_type_not_allow_LOC, _ti.id, hazardClass.code &amp; " (" &amp; hazardClass.description &amp; ")",self.getFullId(), null, null, null);
	//			POPO9988771 is hazardous, it's XXX hazardous type in not allowed in location 22332
				
			endif;
		endif;
	endforeach;
epilog
	delete locnHazClasses;


end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="testPileHeight" id="7d2b3e7a-9701-443f-813f-1aa568190081">
        <source>testPileHeight(_ti: CM_TrackedItem);
/*
Purpose:			
Date		Who		Reason
23 September 2011	cnwab1	Initial creation
*/

vars
	height, heightMax, tiHeight, pileHeight : Decimal[12,2];
	locnDefn : CM_ROROLocnDefnVoyage;
begin
	inheritMethod(_ti);
	
	locnDefn := self.mySlotDefn.myROROLocnDen.CM_ROROLocnDefnVoyage;

	height := locnDefn.getHeightMetresTIs(REAL_MODE, true);
	heightMax := locnDefn.getMaxHeightLimit();
	
	tiHeight := _ti.getActualHeightRaw / 100;
	
	pileHeight :=  (height + tiHeight);
	if heightMax &gt; 0 and pileHeight &gt; heightMax then // PAR 28318
		//Warn user if max pile weight has been exceeded
		app.raiseCMWarning3(WarningPileHeightExceed2, heightMax.String, self.ident, pileHeight.asStringJMTWithPrecision(2,false), null, null,self);
	endif;

epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="testPileWeight" id="4fec3235-2c88-4607-8493-36d23f0e63bd">
        <source>testPileWeight(_ti: CM_TrackedItem; _mode : Integer);

/*
Purpose:			
Date		Who		Reason
23 Sep 2011	cnwab1	Initial creation
15 Apr 2024	navdap1	TFS 63688 MSL Warning Related to Exceeding the Maximum Pile Weight
*/

vars
	weight, weightMax, tiWeight, pileWeight : Decimal[12,2];
	mixed : Boolean;
	mode : Integer;
begin
	inheritMethod(_ti, _mode);
	
	// TFS 63688 start of this bit
	if _mode = ShpDisplayMode_Actual then
		mode := REAL_MODE;
	elseif _mode = ShpDisplayMode_Proposed then
		mode := PLANNING_MODE;
	elseif _mode = ShpDisplayMode_Queued then
		mode := QUEUE_MODE;
	endif;
	// TFS 63688 end of this bit
	
	//mixed := self.mySlotDefn.myROROLocnDen.CM_ROROLocnDefnVoyage.getWeightsForLocn(_mode, true,weight, weightMax);	// TFS 63688
	mixed := self.mySlotDefn.myROROLocnDen.CM_ROROLocnDefnVoyage.getWeightsForLocn(mode, true,weight, weightMax);		// TFS 63688
    if weightMax &lt;= 0 then // No maximum weight set PAR 29515 
        return; 
    endif;
	
	if mixed and not _ti.is20()  then
		tiWeight := _ti.totalWeight/2;
	else
		tiWeight := _ti.totalWeight;
	endif;
	
	pileWeight :=  (weight + tiWeight);
	if pileWeight &gt; weightMax then
		//Warn user if max pile weight has been exceeded
		app.raiseCMWarning3(WarningPileWeightExceeded, weightMax.asStringWeightJMT(), self.getFullId &amp; " (" &amp; _ti.id &amp; ")", pileWeight.asStringWeightJMT(), null, null, self);	
	endif;

epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_mode" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="updateRORORequestVA" id="b5d04ee3-4ddf-4e79-a2be-58952d69e9dc">
        <updating/>
        <source>updateRORORequestVA(_isLoad : Boolean; _voyAlloc : CM_VoyageAllocation; _numItems : Integer; _moveType : Integer; _passport : CM_Passport input): CM_RORORequest updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
29 December 2009	cnwas3	Initial creation

*/

vars
	theLinkedRequest,
	pxyRequest,
	realRequest,aftRequest	: CM_RORORequest;
	tmpSlot,
	theLinkedSlot	: CM_VoyageROROController;
	theTI			: CM_TrackedItem;
	theMoveType,
	voyUpdEvent		: Integer;
	tmpVoyage		: CM_Voyage;
	isCreate,
	needAftRequest, isOOTL	: Boolean;
	aftLC : CM_ROROSlotController;
begin
	realRequest := inheritMethod(_isLoad, _voyAlloc, _numItems, _moveType, _passport);

	// PAR 29010
	if _passport.hasErrorsOrWarnings() 
	and not _passport.warningsAcknowledged then // PAR 28883
		return null;
	endif;

	if _passport = null then
		return null;
	endif;
	
	isOOTL := self.mySlotDefn.myROROLocnDen.isOOTL(); // PAR 28879
	if _voyAlloc &lt;&gt; null then
		needAftRequest := _voyAlloc.needsAftRequest();
		
		if _passport.noErrors 
		and needAftRequest 
		and realRequest.CM_ROROSlotRequest.mySlotRequestAft = null 	
		and realRequest.CM_ROROSlotRequest.mySlotRequestForward = null then	
			aftLC := self.getAftLC();
			if aftLC &lt;&gt; null then
				
				if isOOTL then  // PAR 28879 will already have one of these
					if _isLoad then
						aftRequest := aftLC.myRORORequestLoad;
					else
						aftRequest := aftLC.myRORORequestDischarge;
					endif;
				endif;
				// PAR 28886 when a 40 OOTL Load CC position is created a request is created that is not linked to an allocation. Then it can be linked to an allocation.
				// So normally OOTL already have the aft request ready to go. However if the CC on the OOTL  is deleted and then the user re saves,  we will need to then re create the aft request.
				if aftRequest = null then
					aftRequest := aftLC.createUpdateRORORequest(_isLoad, _voyAlloc, _numItems,_moveType, self, _passport); // PAR 28585
				endif;
				
				if aftRequest &lt;&gt; null then		// newRequest not created if fails validation
					aftRequest.setForwardSlotRequest(realRequest);
					if isOOTL then // PAR 28883
						aftRequest.allAllocations.addNoDuplicates(_voyAlloc, false); // PAR 28883
					endif;
				endif;			
			endif;
		endif;
	endif;
	
	return realRequest;

epilog
	delete pxyRequest;
end;</source>
        <Parameter name="_isLoad" type="Boolean"/>
        <Parameter name="_voyAlloc" type="CM_VoyageAllocation"/>
        <Parameter name="_numItems" type="Integer"/>
        <Parameter name="_moveType" type="Integer"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <ReturnType type="CM_RORORequest"/>
    </JadeMethod>
    <JadeMethod name="validateEDIMoveTo" id="2c3b22cf-182d-4313-ab58-68bd9726bbbe">
        <source>validateEDIMoveTo(control: CMIF_MoveController input; _updateController: CMIF_TIUpdateController);
//----------------------------------------------------------------
//	Created:	26 February 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	lc	: CM_LocationsController;
	theTI	: CM_TrackedItem;
	thisJob,
	job : CM_Job;
begin
	/*
	theTI := control.myTrackedItem;
	
	if self.mySlotDefnVoyage.unavailable then
		app.raiseCMException2(SlotIsUnavailable, self.getLocationId(control.moveMode, theTI), app.getErrorString(MoveCargo) &amp; " (" &amp; theTI.id &amp;  ")" , 'location', _updateController.myUserObject);// PAR 26684 added TI ID
	endif;
	
	if self = control.myToPrimaryLocation then

		if not self.getSpannedToLCs(control) then
			//Not enough space!
			app.raiseCMException2(Err_MoveSize, theTI.id, self.getLocationId(control.moveMode, theTI), null, _updateController.myUserObject);
			return;	
		endif;

		//------------------
		//check each one of these, RENTRANT call.
		//------------------
		control.doToSecondaryLocationsLock();

		foreach lc in control.myToSecondaryLocations do
			if lc.CM_SlotController.mySlotDefnVoyage.unavailable then
				app.raiseCMException2(SlotIsUnavailable, lc.CM_SlotController.getLocationId(control.moveMode, theTI), app.getErrorString(MoveCargo) &amp; " (" &amp; theTI.id &amp;  ")" , 'location', _updateController.myUserObject);// PAR 27385 cnwrs1 11 Apr 2011
				return;
			endif;
			lc.validateMoveTo(control);			
		endforeach;
	endif;
	
	// DVB put this here so a forced move still sets up secondary locations. 02/09/03
	if control.isForcedMove then
		return;
	endif;
	//------------------------
	//This is the standard stuff to validate any move here	
	//------------------------
	if self.includesTI(theTI, control.moveMode) then
		//-----------------
		//If the TI is already here, then simply return. They must be shifting it?
		//-----------------
		return;
	endif;
	
	//---------------------------
	// Check it is compatible with slot request/job
	//---------------------------
	self.validateSlotRequestMoveTo(control);
	
	//---------------------------
	// Check to see if something in back end
	//---------------------------
	if control.myTrackedItem &lt;&gt; null then
		self.has20FTInBackend(control.myTrackedItem);		// 12/07/2010 cnwmh5 #24827 
	endif;
	
	//-------------------------
	//Perform these tests only once
	//-------------------------
	if self &lt;&gt; control.myToPrimaryLocation then
		return;
	endif;

	if control.indexForEDIBayPlan &lt;&gt; 0 then
		//If this is a real EDI move (make actual), ignore the rest of the checks.
		return;
	endif;

	self.testPileWeight(theTI,ShpDisplayMode_Actual); // PAR 8667 added	
//	self.testPileHeightUnderDeck(theTI);
	self.testPileHeight(theTI);	//03 Aug 2010	NDL Par 25127
	*/
end;</source>
        <Parameter name="control" type="CMIF_MoveController" usage="input"/>
        <Parameter name="_updateController" type="CMIF_TIUpdateController"/>
    </JadeMethod>
    <JadeMethod name="validateMoveTo" id="30d76352-7b37-4d85-be93-5a4da6817bde">
        <source>validateMoveTo(control: CMIF_MoveController input);
/*
 ------------------------------------------------------------------------
Created:			24 September 2002 by cnwdwq1
Purpose:			
Parameters:		None
Returns:			Nothing
Changed On		Changed By		Reason
----------		----------		-------------------------------------------
08/12/2011		cnwdap1			PAR #26619 CCMS SFW 1260 Warnings for over-dimension and flats
19/12/2011		cnwdap1			PAR #28881 Ignore EDI or discharge TIs when checking overdimensions
28/08/2012		cnwmh5			PAR #30281 Change getting of iso type to variable so stop 1090 error
---------------------------------------------------------------------------
*/
vars
	lc	: CM_LocationsController;
	theTI, tmpTI, onshipTI	: CM_TrackedItem;
	tmpFM : CM_FutureMove;
	tmpWLE : CM_WorkListEntry;
	thisJob,
	job : CM_Job;
	underSlot : CM_ROROSlotController;		// PAR #26619
	topTI : CM_TrackedItem;					// PAR #26619
	flat, height : Boolean;					// PAR #26619
	warning : CM_Error;						// PAR #26619
	ti : CM_TrackedItem;					// PAR #28881
	futureMove : CM_FutureMove;				// PAR #28881
	isoType		: CM_ISOType;				// 28/08/2012 cnwmh5 #30281
begin
	theTI := control.myTrackedItem;

	if not self.mySlotDefn.isAvailable then
		app.raiseCMException2(SlotIsUnavailable, self.getFullId(), app.getErrorString(MoveCargo) &amp; " (" &amp; theTI.id &amp;  ")" , app.getErrorString(Location).toLower, self);// PAR 26684
	endif;
	
	if self = control.myToPrimaryLocation then
		inheritMethod(control);
		if control.moveMode = REAL_MODE and theTI.isRehandle then
			if theTI.isOnShip then
				if control.myWorkListEntry &lt;&gt; null then
					thisJob := control.myWorkListEntry.job;
				endif;
				// its on the ship but check if the discharge DLR has completed
				if thisJob = null then
					//It must be a shift on board move, carry on...
				elseif thisJob.jobType = JOB_TYPE_SOB then
					// Carry on..					
				else
					foreach job in theTI.allJobsShipReceive do
						if job = thisJob then
							continue;
						endif;
						if job.isRelease then
							// Belts and braces - You never know, Ignore the Load job.
							continue;
						endif;
						if not job.isJobComplete then
							// Error, cannot move DLR to ship as it is still on the ship
							app.raiseCMException2(TI_DLRDischargeNotComplete, theTI.id, job.jobId, null, null);				
							return;
						endif;			
					endforeach;
				endif;
			endif;
		endif;
		
		// ## PAR 25513
		if control.moveMode = REAL_MODE  then
		
			// PAR 30245
			tmpTI := self.allTrackedItems.first;
			if tmpTI &lt;&gt; null and (theTI.isTwenty() &lt;&gt; tmpTI.isTwenty()) then
				// NO MIXING!
				app.raiseCMException2(Err_MoveSize, theTI.id, self.getFullId(), null, null);
				return;	
		
			endif;
			
			if tmpTI &lt;&gt; null and (not theTI.isTwenty() and not tmpTI.isTwenty()) then  // BOTH 40s, check if not lined up primary on primary
				if tmpTI &lt;&gt; null and self.myRORORequestDischarge = null 
				and tmpTI.myPrimaryActualLocation &lt;&gt; self then // PAR 30245
	
	
					//Not enough space!
					app.raiseCMException2(Err_MoveSize, theTI.id, self.getFullId(), null, null);
					return;	
				
				endif;
			endif;
/*
			if not self.myTerminal.getConfig(ShipAllowLoadifnoDisch).Boolean then
				if self.mySlotRequestDischarge &lt;&gt; null then
					tmpTI := self.mySlotRequestDischarge.getTrackedItem();
					if tmpTI &lt;&gt; null then
						onshipTI := self.allTrackedItems.first;
						if tmpTI = onshipTI and onshipTI &lt;&gt; null then
							app.raiseCMException3(Cargo_that_locat_colou_coded_d, onshipTI.id, self.getLocationId(control.moveMode, onshipTI),theTI.id, null, null);
						endif;
					endif;
				endif;
			endif;
			*/
			if self.isRotatedLinked(true) then // PAR 28990
				// Check all the locations in teh rotate are empty i.e. no cargo
			//	app.writeStatement( class.name &amp; '::' &amp; method.name &amp; ' 2.');
				self.validateMoveToRotatedLinked(control);
 			endif;
		endif;
		// ## PAR 25513
		if control.moveMode = QUEUE_MODE  then
		/*
			if not self.myTerminal.getConfig(ShipAllowLoadifnoDisch).Boolean then
				if self.mySlotRequestDischarge &lt;&gt; null then
					tmpWLE := self.mySlotRequestDischarge.allWorkListEntries.first;
					if tmpWLE &lt;&gt; null then
						tmpFM := tmpWLE.myFutureMove;
						if tmpFM &lt;&gt; null then
							if tmpFM.moveType &lt;&gt; TI_FutureMoveQueued then
								tmpFM := null;
							endif;
						endif;
						if tmpFM = null then
							onshipTI := self.allTrackedItems.first;
							if onshipTI &lt;&gt; null then
								app.raiseCMException3(Cargo_that_locat_colou_codedee, onshipTI.id, self.getLocationId(control.moveMode, onshipTI),theTI.id, null, null);
							endif;
						endif;
					endif;
				endif;
			endif;
			*/
		endif;

		//------------------- RE-ENTRANT PROTECTION PORTION - CALLED ONCE -----------------------------
		//As the primary target we have already been locked by the control object.
		//(or by the caller)
		//-------------------
		//------------------
		//get the extent of the TI in terms of other LC's of this type we have to span
		//------------------
		if not self.getSpannedToLCs(control) then
			//Not enough space!
			app.raiseCMException2(Err_MoveSize, theTI.id, self.getFullId(), null, null);
			return;	
		endif;
		//------------------
		//check each one of these, RENTRANT call.
		//------------------
		control.doToSecondaryLocationsLock();

		foreach lc in control.myToSecondaryLocations do
			lc.validateMoveTo(control);			
		endforeach;
		
		// 12/07/2010 cnwmh5 #24827 - Start
		//---------------------------
		// Check to see nothing in backend
		//---------------------------
		if control.myTrackedItem &lt;&gt; null then
			self.has20FTInBackend(control.myTrackedItem) ;
		endif;
		// 12/07/2010 cnwmh5 #24827 - End
	else
		// PAR 29161 we have a 40 moving in and I am a back end.
// PAR 30245 		if theTI.isForty() then
		if not theTI.isTwenty() then
			tmpTI := self.allTrackedItems.first;
			if tmpTI &lt;&gt; null and self.myRORORequestDischarge = null 
			and tmpTI.myPrimaryActualLocation = self then // PAR 30245


				//Not enough space!
				app.raiseCMException2(Err_MoveSize, theTI.id, self.getFullId(), null, null);
				return;	
			
			endif;
		endif;
		
	endif;
	
	// DVB put this here so a forced move still sets up secondary locations. 02/09/03
	if control.isForcedMove then
		return;
	endif;
	//------------------------
	//This is the standard stuff to validate any move here	
	//------------------------
	if self.includesTI(theTI, control.moveMode) then
		//-----------------
		//If the TI is already here, then simply return. They must be shifting it?
		//-----------------
		return;
	endif;
	
	//---------------------------
	// Check it is compatible with slot request/job
	//---------------------------
	self.validateSlotRequestMoveTo(control);
	
	//-------------------------
	//Perform these tests only once
	//-------------------------
	if self &lt;&gt; control.myToPrimaryLocation then
		return;
	endif;
	
	// PAR #26619 Warn if we're planning/queuing/moving a container on top of another overheight container
	underSlot := self.getSlotUnderneathMe();
	if underSlot &lt;&gt; null then
		// PAR #28881 changed the way we derive the TI to avoid picking up EDI moves or discharge TIs
		topTI := underSlot.getActualQueuedPlannedLoadTI();
		/*topTI := underSlot.allTrackedItems.first;
		if topTI = null then
			if not underSlot.allQueuedFutureMoves.isEmpty then
				topTI := underSlot.allQueuedFutureMoves.first.CM_FutureMoveQueued.myTrackedItem;
			endif;
		endif;
		if topTI = null then
			if not underSlot.allPlannedFutureMoves.isEmpty then
				topTI := underSlot.allPlannedFutureMoves.first.CM_FutureMovePlanned.myTrackedItem;
			endif;
		endif;	*/
		if topTI &lt;&gt; null then
			// this particular method gets called after warnings have already been acknowledged, so we can end up 
			// raising the same warning twice and displaying two warning boxes. Check here if we already have a 
			// warning for either of these messages
			flat := false; height := false;
			foreach warning in app.myPassport.allWarnings do
				if warning.errorCode = Cannot_contain_underne_overhei then
					height := true;
				elseif warning.errorCode = Container_flat_platform then
					flat := true;
				endif;
			endforeach;
			if topTI.isOverHeight and not height then
				app.raiseCMWarning2(Cannot_contain_underne_overhei, "'" &amp; app.moveModeStatusEnumToString(control.moveMode) &amp; "' " &amp; theTI.id, self.getFullId(), "Slot " &amp; self.getFullId(), null, self);
			endif;
			
			// also check whether we're putting this container on top of a flat
			isoType := topTI.getISOTypeObject();						// 28/08/2012 cnwmh5 #30281
			if isoType &lt;&gt; null and isoType.isFlat and not flat then		// 28/08/2012 cnwmh5 #30281
				app.raiseCMWarning3(Container_flat_platform, "'" &amp; app.moveModeStatusEnumToString(control.moveMode) &amp; "' ", theTI.id, self.getFullId(), "Slot " &amp; self.getFullId(), null, self);
			endif;
		endif;
	endif;
	// PAR #26619 end

/*
	if control.indexForEDIBayPlan &lt;&gt; 0 then
		//If this is a real EDI move (make actual), ignore the checks below
	else
		if control.moveMode = REAL_MODE then // PAR 8667 added
			self.testPileWeight(theTI,ShpDisplayMode_Actual);	 // PAR 8667 added
		else
			self.testPileWeight(theTI,ShpDisplayMode_Proposed);	 // PAR 8667 added
		endif;
		//self.testPileHeightUnderDeck(theTI);
		self.testPileHeight(theTI);	//03 Aug 2010	NDL Par 25127
	endif;

	*/
end;</source>
        <Parameter name="control" type="CMIF_MoveController" usage="input"/>
    </JadeMethod>
    <JadeMethod name="validateMoveToRotatedLinked" id="a9e3db8c-23e6-475a-b23c-184caecfc61b">
        <source>validateMoveToRotatedLinked(control: CMIF_MoveController input);
/*
Purpose:			
Date		Who		Reason
24 February 2012	cnwab1	Initial creation
*/

vars
	actualLocnDefn, clonedLocnDefn,actualRotationMaster, clonedRotationMaster : CM_ROROLocnDefn;
begin
	clonedRotationMaster := self.mySlotDefn.myROROLocnDen.getRotationMaster();
	if clonedRotationMaster = null then
		return;
	endif;
	
	// PAR 29394
	if clonedRotationMaster.isRotatedCargoLayer() then
		return;
	endif;
	
	// Cannot move any load items to the actual locations if there is any cargo in any of the locations in the rotated group.
	// This is because the actual locations have not been rotated yet. The first load items rotates the actual locations but only if they are totally empty.
	foreach clonedLocnDefn in clonedRotationMaster.allPlannedRotatedLocnDefns discreteLock do
		actualLocnDefn := clonedLocnDefn.getRotatedLinked();
		if actualLocnDefn &lt;&gt; null and actualLocnDefn.hasTIs(REAL_MODE) then
			app.raiseCMException2(Canno_move_rotat_cargo_item_be,control.myTrackedItem.id,actualLocnDefn.code, null, null);
			
		endif;
	endforeach;
epilog

end;</source>
        <Parameter name="control" type="CMIF_MoveController" usage="input"/>
    </JadeMethod>
</Class>
