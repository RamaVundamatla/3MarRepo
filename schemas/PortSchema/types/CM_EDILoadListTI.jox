    <JadeMethod name="setDischargePort" id="cae9746e-04ae-438d-bf6a-55382a3dff84">
        <updating/>
        <source>setDischargePort(_code: String) updating;
//----------------------------------------------------------------
//	Created:	22 October 2003	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
// 07 Mar 2013	cnwcs5	CCMS POL 2097 / par 31259 - include foundMatch in method signatures
vars
	operator 	: CM_Operator;
	foundMatch	: Boolean;
begin
	operator := app.myRoot.allOperators[self.operatorCode];
	
	if operator &lt;&gt; null then
		self.dischargePort := operator.getXlationSystemCode(_code[1:5].trimBlanks(), XLATION_TYPE_PORT_BYOP, foundMatch);
