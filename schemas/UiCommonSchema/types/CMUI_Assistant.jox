    <JadeMethod name="comboBoxYesNoAll_Translated" id="a4a5d5d9-cbcb-43a4-8a10-f98da3db3c43">
        <source>comboBoxYesNoAll_Translated(_combo :CMUI_ComboBox input);
/*
Date		Who		Reason
24 November 2011	cnwcs5	Initial creation - CCMS POL 2122 / par 28696 - Empty Releases via COPARN
*/
vars
	index	:Integer;
begin
	_combo.clear();
	
	_combo.sorted := false;
	
	// stored the constant value in item data so we know what is selected
	// it will be quicker than comparing with translated values
	index					:= _combo.addItem(app.getErrorString(CM_LIT_ALL));
	_combo.itemData[index] 	:= null;	// so can be same as having nothing selected
	index 					:= _combo.addItem(app.getErrorString(Yes));
	_combo.itemData[index] 	:= Yes;
	index 					:= _combo.addItem(app.getErrorString(No));
	_combo.itemData[index] 	:= No;
epilog

end;</source>
        <Parameter name="_combo" type="CMUI_ComboBox" usage="input"/>
    </JadeMethod>
