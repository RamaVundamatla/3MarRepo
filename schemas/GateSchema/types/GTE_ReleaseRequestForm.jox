    <JadeMethod name="setReportSelCriteriaBulk" id="61931e03-24d0-438a-9a56-af5d37083038">
        <source>setReportSelCriteriaBulk(_jrwTransient : CM_JRWBulkRelease input);

/*

Purpose:			Set up the selection criteria for reports using the Bulk Release reporting
					object


Return Value:		_jrwTransient populated


Date		Who		Reason
05 May 2008	cnwkpd1	PAR #16062 - Fix Release Request reports

*/

vars

begin
	_jrwTransient.myOperator := self.myFilterOperator;
	if self.myFilterConsignor &lt;&gt; null then
		_jrwTransient.consignor := self.myFilterConsignor.code;
	endif;
	
	_jrwTransient.myCarrier := self.myFilterCarrier;
//	_jrwTransient.fromDate := self.tblSearch.getValueByName(ETRow_FilterDateRequestFrom).Date;//filterDateFrom;
//	_jrwTransient.toDate := self.tblSearch.getValueByName(ETRow_FilterDateRequestTo).Date;//filterDateTo;
	_jrwTransient.fromDate := self.tblSearch.getValueAsDate(ETRow_FilterDateRequestFrom);
	_jrwTransient.toDate := self.tblSearch.getValueAsDate(ETRow_FilterDateRequestTo);
	_jrwTransient.myISOGroup := self.cmbISOGroup.listObject.CM_ISOTypeGroup;
	_jrwTransient.availabilityGrade := self.cmbMTGrade.listObject.CM_MTGrade;
	_jrwTransient.requiredDateTime.setDate(self.filterDateRequireFrom);
	_jrwTransient.requiredDateTime.setTime(self.filterTimeRequireFrom);
	_jrwTransient.searchText := self.filterFreeText;

	
epilog

end;</source>
        <Parameter name="_jrwTransient" type="CM_JRWBulkRelease" usage="input"/>
    </JadeMethod>
