    <JadeMethod name="selectUnselectAll" id="3d0d0a8e-322d-4bdd-9808-50b027658400">
        <source>selectUnselectAll(_all : Boolean) ;
//--------------------------------------------------------------
//Created: June 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	cell 	: JadeTableCell;
	table 	: CM_DataTable;
	row, col		: Integer;		
begin

	
	if self.optLocnDockets.value then 
		table := self.tblLocationDock; 
	else
		table := self.tblLocationDtls;
	endif;
	
	col := table.getColumnByRowName(ETRow_Opt);
	
	if col = null then 
		self.txtSelected.text := '0';
		return; // if column not found then return, as will get error
	endif;

	foreach row in 2 to table.rows do
		cell := table.accessCell(row, col);
		cell.text := _all.Integer.String;
	endforeach;
	if _all then
		self.txtSelected.text := (table.rows - table.fixedRows).String;
	else
		self.txtSelected.text := '0';
	endif;
end;</source>
        <Parameter name="_all" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="selectedCount" id="840b0250-8d91-4bba-840d-228d90f5f9d1">
        <source>selectedCount() : Integer;
//--------------------------------------------------------------
//Created: June 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	cell : JadeTableCell;
	col, row, cnt : Integer;		
	table : CM_DataTable;
begin

	if self.optLocnDockets.value then 
		table := self.tblLocationDock; 
	else
		table := self.tblLocationDtls;
	endif;
	
	col:= table.getColumnByRowName(ETRow_Opt);

	if col = null then 
		return 0; // if column not shown then return as will get error
	endif;
	
	foreach row in 2 to table.rows do
		cell := table.accessCell(row, col);
		if cell.text = '1' then
			cnt := cnt + 1;
		endif;
	endforeach;
	return cnt;
end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setColorsFromController" id="0daa812c-169a-42fb-a646-bf6fe9228948">
        <updating/>
        <source>setColorsFromController(_colorControl: CM_ColorController) updating;
// ---------------------------------------------------------------------------
// Created:     29 July 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin
	inheritMethod(_colorControl);
	
	self.fldMain.backColor			:= self.backColor;
	self.shtHeader.backColor		:= self.backColor;
	self.shtItemDetails.backColor	:= self.backColor;
	self.shtLocationDtls.backColor	:= self.backColor;
	self.shtNoNumbers.backColor		:= self.backColor;
	self.shtOnBoard.backColor		:= self.backColor;
	
	self.setColorsForEntryTable(self.tblHeaderDtls);
	self.setColorsForTable(self.tblLocationDtls);
	self.setColorsForTable(self.tblLocationDock);
	self.setColorsForTable(self.tblNNData);
	self.setColorsForTable(self.tblOnBoard);
	
	self.lbEntered.backColor := self.backColor;
	self.lbFilterHatch.backColor := self.backColor;
	self.lbFilterLot.backColor := self.backColor;
	self.lbFilterPlace.backColor := self.backColor;
	self.lblRequired.backColor := self.backColor;
	self.lblSelected.backColor := self.backColor;
	self.lblAddNoNumbers.backColor := self.backColor;
	self.lbRemaining.backColor := self.backColor;
	self.lblIdFilter.backColor := self.backColor;
	self.lblPage.backColor := self.backColor;
	self.lbRequired.backColor := self.backColor;
	self.lblLocation.backColor := self.backColor;	

end;</source>
        <Parameter name="_colorControl" type="CM_ColorController"/>
    </JadeMethod>
    <JadeMethod name="setCurrentObjectEdition" id="bfd08579-f6cf-4f37-9c27-8a90c3f987e6">
        <updating/>
        <source>setCurrentObjectEdition(_object : CM_Object)updating;
//--------------------------------------------------------------
//Created: 05 November 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	ls : Boolean;
begin
	
	if _object &lt;&gt; null then
		app.cmsBeginLoad(ls);
		sharedLock(_object);
		self.myCurrentObject := _object;
		self.objectEdition	 := _object.edition();		
	else
		self.myCurrentObject := null;
		self.objectEdition 	 := null;
