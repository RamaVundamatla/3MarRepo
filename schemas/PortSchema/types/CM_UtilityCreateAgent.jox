    <JadeMethod name="utlCreateEDITI" id="55238a35-d9de-428f-885c-6783b5172d11">
        <source>utlCreateEDITI(_ediData: CM_EDIData; _ediTIClass: Class; _passport: CM_Passport input): CM_EDITrackedItem;
//----------------------------------------------------------------
//	Created:	05 September 2003	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
//04 May 2012	cnwrs1		Par 29531 - EDI Data auditing
// 18 Jan 2019	jlgrs1	TFS 41659 42276 STWR Make EDI MultiThreaded Stage 8
// 07 Apr 2019	jlgrs1	TFS 41913 STWR - Reconfiguration of the EDI Operation form to better handle EDI collection locks while loading 
//
vars
	ediTI : CM_EDITrackedItem;
begin

	self.initialiseActivity();

	app.setContinueCMExceptions(false);

	if _ediData = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'the ediData object is null');
	endif;
	
	exclusiveLock(_ediData);

	create ediTI as _ediTIClass persistent;
	ediTI.setForCreateNew(_ediData);
	
	if app.myPassport.noErrors then
		self.myCreateAuditAgent.audCreateGeneric(ediTI);	// 04 May 2012	cnwrs1	par 29531
	endif;
	return ediTI;
	
end;</source>
        <Parameter name="_ediData" type="CM_EDIData"/>
        <Parameter name="_ediTIClass" type="Class"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <ReturnType type="CM_EDITrackedItem"/>
    </JadeMethod>
    <JadeMethod name="utlCreateEWSActivityHistory" id="bbc0b450-8400-4c7a-80f9-558b273b7004">
        <source>utlCreateEWSActivityHistory(_activityHistoryProxy : CM_ExternalWebServiceActivity; _passport : CM_Passport input) : CM_ExternalWebServiceActivity;
/*
Purpose:			

Date		Who		Reason
26JUL2021	NAVAB1	TFS 50669
*/

vars

	activityHistoryReal		: CM_ExternalWebServiceActivity;
	wsDef			: CM_OpsViewServiceDef;
	bgp : BGP_ExternalWSController;

begin

	self.initialiseActivity();
	// validation
	app.myValCA.valEWSActivityHistory(_activityHistoryProxy);
	
	if not self.checkValidationWithPassport(_passport) then
		return null;
	endif;
	
	create activityHistoryReal as _activityHistoryProxy.class persistent;
	activityHistoryReal.setSequence(); // do this before the setForCreate so that the  sequence number is correct in the request JSON
	activityHistoryReal.setForCreate(_activityHistoryProxy);

	
	
	if _activityHistoryProxy.class = CM_EWSActivityOpsview then
		if not _activityHistoryProxy.CM_EWSActivityOpsview.isSnapshot then // ### TFS 51855 19MAY2022 NAVAB1
			wsDef := app.myRoot.getFirstActiveExtWebService( CM_OpsViewServiceDef ).CM_OpsViewServiceDef;
			if wsDef &lt;&gt; null
			and wsDef.status = EWS_STATUS_RUNNING then
				bgp := wsDef.getBGPControllerForTerminal(activityHistoryReal.myTerminal);  // (BGP_ExternalWSController)
			
				// the Producer API receives a STARTING, this sets the BGP controller to STARTING whilst it processes the 'old' requests
				// when theBGP is finished with the 'old' requests its status will change to RUNNING
				if bgp &lt;&gt; null
				and bgp.status = EWS_STATUS_RUNNING then
					activityHistoryReal.createBGPRequest();
				endif;
			endif;
		endif;
	endif;
	
	return activityHistoryReal;
end; </source>
        <Parameter name="_activityHistoryProxy" type="CM_ExternalWebServiceActivity"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <ReturnType type="CM_ExternalWebServiceActivity"/>
    </JadeMethod>
