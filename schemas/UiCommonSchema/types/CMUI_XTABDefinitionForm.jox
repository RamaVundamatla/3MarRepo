    <JadeMethod name="cmbFunction_click" id="0fe68db4-70c0-4f86-91a0-4a904973f41a">
        <controlMethod name="CMUI_ComboBox::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbFunction_click(combobox: ComboBox input) updating;
// ---------------------------------------------------------------------------
// Created:     27 November 2008 by concms1:1
// Purpose:     CCMS SFW 1047 - Totals Only Lists
// Parameters:  None
// Returns:     Nothing
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	field		:CM_XTABField;
	function	:Integer;
begin
	// update our proxy
	field := shtProperties.userObject.CM_XTABField;
	
	function := cmbFunction.itemData[cmbFunction.listIndex];
	
	field.setFunction (function);
	
	self.updateButtonForField (field);
epilog

end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="cmbMapping_click" id="66c5661e-0146-492e-8906-81a1af4f16e2">
        <controlMethod name="CMUI_ComboBox::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbMapping_click(combobox: CMUI_ComboBox input) updating;
// ---------------------------------------------------------------------------
// Created:     24 November 2009 by cnwcs5
// Purpose:     CCMS 1028 - summary mappings
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	element	: CM_XTABGrouping;
	cmb		: ComboBox;
	mapping	: CM_XTABMapping;
begin
	element := shtGroupings.userObject.CM_XTABGrouping;
	cmb		:= cmbMapping;
	mapping := cmb.listObject.CM_XTABMapping;
	
	if element = null then
		return;
	endif;
	
	if cmb.listIndex = -1 or 						// nothing selected
		cmb.itemObject [cmb.listIndex] &lt;&gt; null or	// mapping selected
		cmb.itemText[cmb.listIndex] = null then		// empty entry selected	
		element.setMyXTABMapping (mapping);

	else
		// they have selected &lt;new mapping&gt; - show the mapping form
		element.setMyXTABMapping (null);	
		
		self.showMappingForm ();
	endif;
	
	
	
epilog
	btnMapping.enabled := (cmb.listIndex &gt; 0 and cmb.itemText [cmb.listIndex] &lt;&gt; null);	
end;</source>
        <Parameter name="combobox" type="CMUI_ComboBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="cmbMode_click" id="b3c6914d-135b-4983-a0ba-9189ed22c05c">
        <controlMethod name="CMUI_ComboBox::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbMode_click( combobox : ComboBox input ) updating;
// ---------------------------------------------------------------------------
// Created:     26 November 2008 by concms1
// Purpose:     CCMS SFW 1047 - Totals Only Lists
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 15/02/2010	cnwcs5	ccms 1925 / par 22295 Release Summaries
// ---------------------------------------------------------------------------
vars

begin
	self.setMyQueryDefinition( combobox.listObject.CM_QueryDefinition );
	
	// 15/02/2010 cnwcs5 ccms 1925 / par 22295
	// the following is now done at the time the summary is generated
	//self.setMyChildCollection();	
	
	if self.myProxyXTAB &lt;&gt; null and self.myQueryDefinition &lt;&gt; null then
		self.myProxyXTAB.setModeAndType( self.myQueryDefinition.mode, self.myQueryDefinition.type  );
	endif;
	
epilog
	
end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="cmbOrder_click" id="ec705d5f-76e6-4db9-9c21-67ead13daf49">
        <controlMethod name="CMUI_ComboBox::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbOrder_click(combobox: ComboBox input) updating;
// ---------------------------------------------------------------------------
// Created:     27 November 2008 by concms1:1
// Purpose:     CCMS SFW 1047 - Totals Only Lists
// Parameters:  None
// Returns:     Nothing
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	element		:CM_XTABGrouping;
	descending	:Boolean;
begin
	// update our proxy
	element := shtGroupings.userObject.CM_XTABGrouping;
	
	descending := combobox.listIndex = self.ListIndex_Descending;
	
	element.setDescending (descending);
epilog

end;</source>
