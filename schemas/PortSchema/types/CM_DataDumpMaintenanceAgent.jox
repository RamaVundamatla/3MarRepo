	create xdbFeature transient;
	xdbFeature.setupAndBuildSet(CM_ReserveSelection::customerReference.name, "CM_ReserveSelection", "customerReference", "", _features);//navtnr20 11-07-2022 53974
	
	//all super class references	CM_ReserveDetail
	create xdbFeature transient; 		
	xdbFeature.setupAndBuildSet(CM_ReserveSelection::getTrackedItems.name, "CM_ReserveSelection", "getTrackedItems", "", _features);
