    <JadeMethod name="printAuditTIEdit" id="68304aab-e361-4111-b3e6-de8820707c7f">
        <updating/>
        <source>printAuditTIEdit(auditObj: CM_AuditTIEdit) updating;
// ---------------------------------------------------------------------------
// Created:		April 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	size : Integer;
	str : String;
	fht, fwd, wd, ht :Real;

begin

	lblSeqNum.caption := auditObj.sequenceNum.String;
	lblTrackedItem.caption := auditObj.trackedItemId;
	lblRemarks.caption := auditObj.remarks;

	app.printer.print(fAuditTIEdit);
	app.printer.print(fAuditSep);

	if auditObj.transaction &lt;&gt; null then
	
		lblEditValue.caption := app.getErrorString(INV_Edited_By);
		lblEditDetails.caption := auditObj.transaction.userId;
		app.printer.print(fAuditTrans);
	
		lblEditValue.caption := app.getErrorString(INV_Edited_On);
		lblEditDetails.caption := auditObj.transaction.dateTime.String;
		app.printer.print(fAuditTrans);
		
		str := str &amp; auditObj.transaction.fieldsValues.getAsEditPair();
	endif;
	lblEditValue.caption := app.getErrorString(INV_Details);
	wd := lblEditDetails.width;
	ht := lblEditDetails.height;
	fwd := fAuditTrans.width;
	fht := fAuditTrans.height;
	lblEditDetails.caption := str;
	lblEditDetails.height := (size/2) * ht;
	fAuditTrans.height := lblEditDetails.height + 5;
	app.printer.print(fAuditTrans);

	lblEditDetails.wordWrap := false;
	lblEditDetails.autoSize := false;
	lblEditDetails.width := wd;
	lblEditDetails.height := ht;
	fAuditTrans.width := fwd;
	fAuditTrans.height := fht;

	if auditObj.clearedDateTime &lt;&gt; null then
		app.printer.print(fAuditSep);
		lblEditValue.caption := app.getErrorString(INV_Cleared_By);
		lblEditDetails.caption := auditObj.clearingUserId;
		app.printer.print(fAuditTrans);

		lblEditValue.caption := app.getErrorString(INV_Cleared_On);
		lblEditDetails.caption := auditObj.clearedDateTime.String;
		app.printer.print(fAuditTrans);

		lblEditValue.caption := app.getErrorString(INV_Remarks);
		lblEditDetails.caption := auditObj.clearingRemarks;
		app.printer.print(fAuditTrans);

	endif;

	app.printer.print(fAuditSep);

end;</source>
        <Parameter name="auditObj" type="CM_AuditTIEdit"/>
    </JadeMethod>
</GUIClass>
