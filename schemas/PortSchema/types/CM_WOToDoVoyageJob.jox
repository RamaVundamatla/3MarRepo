    <JadeMethod name="getDisplayStringForAttribute" id="3870a427-7206-4977-a907-d031cd794efc">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 June 2023 navhl20 ChangeRequest 58543: EUP - Delivery Dispatch – Allocation List - VAS

*/

vars

begin
	if _attrName = ETRow_Voyage then
		return self.allVoyages.listString(Comma,CM_Voyage::code.name);
	elseif _attrName = ETRow_Vessel then
		return self.getVesselCode();
	else
		return inheritMethod(_attrName, _short);
	endif;

epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getVesselCode" id="f1fe138b-efaf-489b-a10b-41884ab6a7c4">
        <source>getVesselCode():String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 Oct 2023 navhl20 Bug 60931: EUP - Delivery Dispatch Remedial [2]
06 Mar 2025 navma1  MTN-34179 MTN | Dead Lock (1081) on CM_WLEArray
*/

vars
	voyage			: CM_Voyage;
	vesselArr		: StringArray;
	str				: String;
	invalidObject	: Boolean;
	edition			: Integer;
begin
	on Exception do app.handleDeletedObject(exception, voyage, invalidObject);
	
	create vesselArr transient;
	
	foreach voyage in self.allVoyages discreteLock do	//06.03.2025 navma1 #MTN-34179
		invalidObject := false;
		edition 	  := voyage.edition;
		
		if invalidObject then
			continue;
		endif;
		if voyage.vesselCode &lt;&gt; null then
			vesselArr.add(voyage.vesselCode);
		endif;
	endforeach;
	str := vesselArr.concatenate(Comma);
	return str;
epilog
	delete vesselArr;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getVesselName" id="18f3fd6b-d00c-436b-a81a-febf147ff241">
