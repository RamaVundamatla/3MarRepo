    <JadeMethod name="replaceInvoiceLineTypes" id="e9c589d6-c5d2-46e9-a995-3257c0bab17c">
        <source>replaceInvoiceLineTypes(_oldILD : CM_InvoiceLineDesc; _newILD : CM_InvoiceLineDesc) : Integer;
// 32311
vars
	count	: Integer;
begin
	count := self.myChildQuantityMap.replaceInvoiceLineTypes(_oldILD, _newILD);

	return count;
end;
