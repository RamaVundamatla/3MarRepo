    <JadeMethod name="isSimilarQueueArea" id="5e3e79c3-10c2-493d-870d-432a101bfe1e">
        <source>isSimilarQueueArea(_location	:	CM_LocationsController) : Boolean;
//For Queueing, moves to/from the RTA are essentially the same as moving to US!
vars
	
	area : CM_TerminalArea;

begin

	area := _location.myTerminalArea;
	
	if area = self.myTransferArea then
		return true;
	endif;
	if area = self then
		return true;
	endif;
	return false;
end;</source>
        <Parameter name="_location" type="CM_LocationsController"/>
        <ReturnType type="Boolean"/>
