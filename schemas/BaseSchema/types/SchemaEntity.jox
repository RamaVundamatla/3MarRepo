<Class name="SchemaEntity">
    <Constant name="CNEC_ACCESS_PROTECTED" id="04fdefc8-3bc7-4f2a-96ea-4a9a00ef2cd0">
        <source>"2"</source>
        <type name="Character"/>
    </Constant>
    <Constant name="CNEC_ACCESS_PUBLIC" id="655de218-bd97-45e3-ba4c-050a70ae39b8">
        <source>"0"</source>
        <type name="Character"/>
    </Constant>
    <Constant name="CNEC_ACCESS_READONLY" id="ac956f01-fb07-40ce-a4fb-9fcaf2d425b9">
        <source>"1"</source>
        <type name="Character"/>
    </Constant>
    <JadeMethod name="cnEcDocumentGetClassHyperlink" id="340c0157-ad56-4df2-b7d4-d7f4934b3753">
        <source>cnEcDocumentGetClassHyperlink(	pParameterObj:CnEcDocParameter;
								pLinkClassName:String;
								pIsIncludeRootSchemaClasses:Boolean;
								pSchemaColl:SchemaColl;
								pPathToIndex:String):String protected;
// --------------------------------------------------------------------------------
// Created:		21 October 2000 by cnwdad1
//
// Purpose:		Generates an HTML hyperlink for the class documentation feature.
//
// Parameters:	pParameterObj - A reference to the class documentation parameter object.
//				pLinkClassName (Class) - The name of class whose documentation file
//					we want to build a hyperlink to.
//				pIsIncludeRootSchemaClasses (Boolean) - If true, RootSchema classes
//					will also be documented (useful for showing hyperlinks from
//					Class property references).
//				pSchemaColl (SchemaColl) - The collection (Array) of schemas that
//					are a valid list of schemas to be documented (used when including
//					hyperlinks from Class property references to the documentation
//					for for the reference type's Class).
//				pPathToIndex (String) - The file path if the documentation index file.
//
// Returns:		The hyperlink to the specified class.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 19/02/2003	cnwdad1		Added the pTheParameter parameter so that hyperlinks
//							will not be generated to classes that are not included
//							in the documentation.
// --------------------------------------------------------------------------------
vars
	pathDelimCount		: Integer;
	pathDelimIndex		: Integer;
	pathBackToIndex		: String;
	refClassObj			: Class;
	owningSchemaObj		: Schema;
	pathToRefClass		: String;

begin
	if pParameterObj.allClasses[pLinkClassName] = null then
		return pLinkClassName;
	endif;
	
	// Work out a relative file path back to the documentation index file.  This
	// is based upon working back up the directory tree, for example: "..\" will
	// move back up one directory level.
			
	pathDelimCount	:=	pPathToIndex.cnEcSubstringCount(global.cnEcGetFileSeparator());
			
	foreach pathDelimIndex in 1 to pathDelimCount do
		if pathBackToIndex = null then
			pathBackToIndex	:=	".." &amp; global.cnEcGetFileSeparator();
		else
			pathBackToIndex	:=	pathBackToIndex &amp; ".." &amp; global.cnEcGetFileSeparator();
		endif;
	endforeach;
	
	// Now that we have the path back to the root index file, now we'll add the file path
	// down to the class documentation file of the reference property type.  We'll only
	// include the hyperlink to the reference type's Class if that reference type's Class
	// is included in the range of schemas being documented.
	
	pathToRefClass	:=	null;

	// We'll start this by scanning through the range of schemas which we're documenting
	// in reverse order (the lowest subschema is lest in the array of schemas).  For each
	// schema we'll look for the class in that schema.

	foreach owningSchemaObj in pSchemaColl reversed do
		refClassObj		:=	owningSchemaObj.getClass(pLinkClassName);
		
		if refClassObj &lt;&gt; null then
			if (refClassObj.isSystemObject and pIsIncludeRootSchemaClasses)
			or (not refClassObj.isSystemObject) then
				if pSchemaColl.includes(refClassObj.cnEcGetImplementationSchema()) then
					pathToRefClass	:=	pathBackToIndex &amp;
										refClassObj.cnEcGetClassTreeName() &amp;
										global.cnEcGetFileSeparator() &amp;
										refClassObj.name &amp;
										CNEC_CLASS_DOC_HTML_SUFFIX;
					break;
				endif;
			endif;
		endif;
	endforeach;
	
	if pathToRefClass = null then
		return pLinkClassName;
	else
		return "&lt;A HREF=" &amp; 34.Character &amp; pathToRefClass &amp; 34.Character &amp; "&gt;" &amp; pLinkClassName &amp; "&lt;/A&gt;";
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="pParameterObj" type="CnEcDocParameter"/>
        <Parameter name="pLinkClassName" type="String"/>
        <Parameter name="pIsIncludeRootSchemaClasses" type="Boolean"/>
        <Parameter name="pSchemaColl" type="SchemaColl"/>
        <Parameter name="pPathToIndex" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="cnEcGetModifyTimeStamp" id="f27c876a-f8d4-4cbf-a46a-bacb139e4dd2">
        <source>cnEcGetModifyTimeStamp():TimeStamp;

begin
	if modifiedTimeStamp = null then
		return creationTime();
	endif;

	return modifiedTimeStamp;
end;</source>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="cnEcIsProtected" id="c5be9cde-fafa-4a45-be73-1a117abb7f02">
        <source>cnEcIsProtected():Boolean;
// --------------------------------------------------------------------------------
// Created:		16 August 2001 by cnwdad1
//
// Purpose:		Returns a boolean flag to indicate whether access to the receiver
//				is protected.
//
// Parameters:	None
//
// Returns:		True if the entity is protected, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return (self.access = self.CNEC_ACCESS_PROTECTED);
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="cnEcIsPublic" id="58649d65-6101-40d0-b0bc-b330d4cbfd28">
        <source>cnEcIsPublic():Boolean;
// --------------------------------------------------------------------------------
// Created:		16 August 2001 by cnwdad1
//
// Purpose:		Returns a boolean flag to indicate whether access to the receiver
//				is public.
//
// Parameters:	None
//
// Returns:		True if the entity is public, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return (self.access = self.CNEC_ACCESS_PUBLIC);
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="cnEcIsReadonly" id="ca0b3e39-9edc-4fe3-be0d-373bace6be50">
        <source>cnEcIsReadonly():Boolean;
// --------------------------------------------------------------------------------
// Created:		16 August 2001 by cnwdad1
//
// Purpose:		Returns a boolean flag to indicate whether access to the receiver
//				is read-only.
//
// Parameters:	None
//
// Returns:		True if the entity is read-only, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return (self.access = self.CNEC_ACCESS_READONLY);
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="cnEcSetModifiedBy" id="b7f17a33-a9e4-4463-a8f5-27230ac1a578">
        <updating/>
        <source>cnEcSetModifiedBy(_username : String) updating;

/*
** NEEDS TO BE RUN INSIDE A TRANSACTION
*/

vars
	ts : TimeStamp;
	
begin
	if _username = null then
		return;
	endif;
	
	self.setPropertyValue("_modifiedBy", _username); //Modified By is a special property
	self.modifiedTimeStamp := ts;
	
end;</source>
        <Parameter name="_username" type="String"/>
    </JadeMethod>
    <JadeMethod name="cnEcSetText" id="1e26981d-407e-4c85-b8f4-76212b4a926c">
        <updating/>
        <source>cnEcSetText(pText:String) updating;
// --------------------------------------------------------------------------------
// Created:		23 March 2007 by cnwdad1
//
// Purpose:		Sets the receiver's text.
//
// Parameters:	pText - The receiver's text.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.text	:=	pText;
end;</source>
        <Parameter name="pText" type="String"/>
    </JadeMethod>
    <JadeMethod name="cnEcSetUserText" id="b03948e7-9a7b-4338-95bf-338beeae3b14">
        <updating/>
        <source>cnEcSetUserText(pText:String) updating;
// --------------------------------------------------------------------------------
// Created:		23 March 2007 by cnwdad1
//
// Purpose:		Sets the receiver's user text.
//
// Parameters:	pText - The receiver's user text.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.userText	:=	pText;
end;</source>
        <Parameter name="pText" type="String"/>
    </JadeMethod>
</Class>
