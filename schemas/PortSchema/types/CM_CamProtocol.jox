    <JadeMethod name="setUNHSeqNum" id="09f91d8b-60a6-4112-be7c-8311559be477">
        <updating/>
        <source>setUNHSeqNum(_seqNum: Integer io) updating;
//----------------------------------------------------------------
//	Created:	09 December 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
//30 Jul 2012	cnwrs1	CCMS 1269 CAMS remove CM_CamTask
vars

begin
//write class.name&amp;'::'&amp;method.name&amp;' '&amp;self.code&amp;' _seqNum='&amp;_seqNum.String;
	if _seqNum &gt; 999998 then
		//reset
		self.unhSequenceNum := 0;
	else
		_seqNum := _seqNum + 1;
		self.unhSequenceNum := _seqNum;
	endif;

end;</source>
        <Parameter name="_seqNum" type="Integer" usage="io"/>
    </JadeMethod>
