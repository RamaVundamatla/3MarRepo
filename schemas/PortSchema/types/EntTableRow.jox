    <JadeMethod name="outputAsXML" id="7cf2baf8-e402-4ad8-834e-c9a0d2f7053d">
        <source>outputAsXML() : String;
// ---------------------------------------------------------------------------
// Created:     18 July 2001 by cnwrs2
//
// Purpose:     
/*
	Changed On	By			Reason
	----------	--------	--------------------------------------------------
	12/02/2013	cnwdap1		PAR #31155 CMS SFW 1321 Imperial Measurements
	12 Jan 2026 navlc30 	JIRA  36954 Story MTN | Highlight Mandatory fields
	
	&lt;GroupRow&gt;
		&lt;GroupName&gt;GateReceivals&lt;/GroupName&gt;
		&lt;Heading&gt;Container No&lt;/Heading&gt;
		&lt;Number&gt;1234&lt;/Number&gt;
		&lt;InputType&gt;3&lt;/InputType&gt;
		&lt;LostFocus&gt;&lt;/LostFocus&gt;
		&lt;GotFocus&gt;&lt;/GotFocus&gt;
		&lt;Click&gt;&lt;/Click&gt;
		&lt;Visible&gt;&lt;/Visible&gt;
		&lt;ControlName&gt;&lt;/ControlName&gt;
		&lt;ErrorReturnStr&gt;&lt;/ErrorReturnStr&gt;
		&lt;DependsOn&gt;
			&lt;DependRow&gt;aaa&lt;/DependRow&gt;
			&lt;DependRow&gt;bbb&lt;/DependRow&gt;
			&lt;DependRow&gt;ccc&lt;/DependRow&gt;
		&lt;/DependsOn&gt;
		&lt;CellControl&gt;
			&lt;Decimals&gt;3&lt;/Decimals&gt;
			&lt;Case&gt;3&lt;/Case&gt;
			&lt;MaxLength&gt;12&lt;/MaxLength&gt;
		&lt;/CellControl&gt;
	&lt;/GroupRow&gt;
*/
// ---------------------------------------------------------------------------
vars
	xmlStr,
	dependStr,
	tmpStr		: String;
	tmpGroupName		: String;	
	tmpGroup	: EntTableGroup;
	tmpETRow	: EntTableRow;
	termTypeName	: String;

begin


	// Code to move row details from one group to another.  It checks if the row
	// already exists in the other group, if not it writes with the moveTo group
	// name.  Do the "saveToGlobalConstants" then "reloadFromGlobalConstants".
	// (note this may not work if the group being shifted too is alphabetically
	// after the one being moved from)
/*
	if self.myGroup.name = 'LogDocket' then
		tmpGroup := self.myGroup.myEntTableDataRoot.allEntTableGroups['GateReceivals'];
		if tmpGroup.allEntTableRowsByName.includesKey(self.myEntTableRowHeader.name) then
			write "GD " &amp; class.name &amp; '::' &amp; method.name &amp; '  ignoring ' &amp; self.myEntTableRowHeader.name;
			return null;
		endif;
		tmpGroupName := 'GateReceivals';
	else
*/
		tmpGroupName := self.myGroup.name;
//	endif;
	
	foreach tmpStr in self.allDependencies do
		dependStr := dependStr &amp; self.formatAsXML(XMLTag_DependRow, tmpStr);
	endforeach;
	
	if dependStr &lt;&gt; null then
		dependStr := self.formatAsXML(XMLTag_DependsOn, dependStr);
	endif;

	xmlStr := self.formatAsXMLPrefix(XMLTag_GroupRow) &amp;
			  self.formatAsXML(XMLTag_GroupName, 		tmpGroupName.xmlReplaceReservedChars(true)) &amp;
			  self.formatAsXML(XMLTag_Heading, 			self.heading.xmlReplaceReservedChars(true)) &amp;
			  self.formatAsXML(XMLTag_ShortHeading, 	self.shortHeading.xmlReplaceReservedChars(true)) &amp;
			  self.formatAsXML(XMLTag_Number, 			self.number.String) &amp;
			  dependStr &amp;
			  self.formatAsXML(XMLTag_InputType, 		self.inputType.String) &amp;
			  self.formatAsXML(XMLTag_InputTypeWeb, 	self.inputTypeForWeb.String) &amp;
			  self.formatAsXML(XMLTag_SortField, 		self.sortFieldName.xmlReplaceReservedChars(true)) &amp;
			  self.formatAsXML(XMLTag_LostFocusMethod,	self.lostFocusMethodName.xmlReplaceReservedChars(true)) &amp;
			  self.formatAsXML(XMLTag_GotFocusMethod, 	self.gotFocusMethodName.xmlReplaceReservedChars(true)) &amp;
			  self.formatAsXML(XMLTag_ClickMethod, 		self.clickMethodName.xmlReplaceReservedChars(true)) &amp;
			  self.formatAsXML(XMLTag_Visible, 			self.visible.String) &amp;
			  self.formatAsXML(XMLTag_ControlName, 		self.controlName.xmlReplaceReservedChars(true)) &amp;
			  self.formatAsXML(XMLTag_TerminologyType, 	self.terminologyTypeName.xmlReplaceReservedChars(true)) &amp;
			  self.formatAsXML(XMLTag_ErrorReturnStr, 	self.errorReturnString.xmlReplaceReservedChars(true)) &amp;
			  self.formatAsXML(XMLTag_Text, 			self.text.xmlReplaceReservedChars(true)) &amp;
			  self.formatAsXML(XMLTag_DisplayNullIfZero, 	self.displayNullIfZero.String) &amp;
			  self.formatAsXML(XMLTag_MeasurementType,	self.measurementType) &amp;					// PAR #31155	//12.01.2026 navlc30 #36954
			  self.formatAsXML(XMLTag_IsMandatoryField, self.isMandatoryField.String);							//12.01.2026 navlc30 #36954
			  
	if self.myEntTableCellControl &lt;&gt; null then
		xmlStr := xmlStr &amp; self.myEntTableCellControl.outputAsXML();
	endif;
	
	xmlStr := xmlStr &amp; self.formatAsXMLSuffix(XMLTag_GroupRow);

	return xmlStr;

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="setDependenciesFromXMLElement" id="065c6606-c6fc-40ca-b82a-9c9ef3a9c08b">
        <source>setDependenciesFromXMLElement(_dependOnRows : JadeXMLElementArray) protected;
// ---------------------------------------------------------------------------
// Created:     11 May 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	tmpElement	: JadeXMLElement;
	tmpAttr		: JadeXMLAttribute;
	tmpAttrName	: String;
begin

	self.allDependencies.clear();

	foreach tmpElement in _dependOnRows do
		tmpAttrName := tmpElement.textData;
		if tmpAttrName = null then
			continue;
		endif;
		self.allDependencies.add(tmpAttrName);
	endforeach;

end;</source>
        <access>protected</access>
        <Parameter name="_dependOnRows" type="JadeXMLElementArray"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="3b76aeeb-9166-4cb4-8d36-ba93d7742276">
        <updating/>
        <source>setForCreate(pProxy : EntTableRowProxy; pGroup : EntTableGroup) updating;
// ---------------------------------------------------------------------------
// Created:     05 March 2001 by cnwrs2
//
// Purpose:     This method should only be called from the DEV schemea to create
//				a new row in the JMT Development System.  This method should not
//				be called at a client site (refer to setting of self.number)
// ---------------------------------------------------------------------------
// Changed On	By			Reason
// ----------	--------	--------------------------------------------------
// 12/02/2013	cnwdap1		PAR #31155 CCMS SFW 1321 Imperial Measurements
// 12 Jan 2026  navlc30     JIRA  36954 Story MTN | Highlight Mandatory fields

vars
	entTableControl		: EntTableCellControl;
	rowHeader			: EntTableRowHeader;
begin

	// RJS - This is OK as this method is only called for DEV environment
	if self.number = 0 then
		self.number := self.getInstanceIdForObject(self).Integer;
	endif;

	pProxy.allEntTableDefs.copy(self.allEntTableDefs);
	pProxy.allEntTableViews.copy(self.allEntTableViews);

	self.heading			:= pProxy.heading;
	self.shortHeading		:= pProxy.shortHeading;
	self.sortFieldName		:= pProxy.sortFieldName;
	self.controlName		:= pProxy.controlName;
	self.inputType			:= pProxy.inputType;
	self.inputTypeForWeb	:= pProxy.inputTypeForWeb;
	self.visible			:= pProxy.visible;
	self.clickMethodName	:= pProxy.clickMethodName;
	self.gotFocusMethodName  := pProxy.gotFocusMethodName;
	self.lostFocusMethodName := pProxy.lostFocusMethodName;
	self.displayNullIfZero	:= pProxy.displayNullIfZero;
	self.measurementType	:= pProxy.measurementType;			// PAR #31155
	self.isMandatoryField	:= pProxy.isMandatoryField;			//12.01.2026 navlc30 #36954

	self.errorReturnString := pProxy.errorReturnString;
	
	self.setMyEntTableRowHeader(pProxy.nameForProxy, pGroup.myEntTableDataRoot);
	self.myGroup := pGroup;
	
	self.myRoot := pGroup.myEntTableDataRoot;
	
	if pProxy.myEntTableCellControl &lt;&gt; null then
		create entTableControl as pProxy.myEntTableCellControl.class persistent;
		entTableControl.setForCreate(pProxy.myEntTableCellControl, self);
	endif;

	// 30/8/2006 RBarr Now removed to EntTableAgent::trxSaveDataToGlobalConstants to ensure the global constants exist when myEntTableText is set
	//self.setTranslatableText();

	self.allDependencies.clear;
	pProxy.allDependencies.copy(self.allDependencies);

end;</source>
        <Parameter name="pProxy" type="EntTableRowProxy"/>
        <Parameter name="pGroup" type="EntTableGroup"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="24e493fb-702d-4190-8d14-62829df1c4eb">
        <updating/>
        <source>setForUpdate(pProxy : EntTableRowProxy) updating;
// ---------------------------------------------------------------------------
// Created:     05 March 2001 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
// Changed On	By			Reason
// ----------	--------	--------------------------------------------------
// 12/02/2013	cnwdap1		PAR #31155 CCMS SFW 1321 Imperial Measurements
// 12 Jan 2026  navlc30     JIRA 36954 Story MTN | Highlight Mandatory fields

vars
	entTableControl	: EntTableCellControl;
	def				: EntTableDef;

begin
	
	if self.controlName &lt;&gt; null and pProxy.controlName = null then
		foreach def in self.allEntTableDefs do
			def.removeControl(self.controlName);
		endforeach;
	elseif pProxy.controlName &lt;&gt; null then
		// always add as addControl does a check first to see if present
		foreach def in self.allEntTableDefs do
			def.addControl(pProxy.controlName);
		endforeach;
	endif;

	if pProxy.nameForProxy &lt;&gt; self.name then
		self.setMyEntTableRowHeader(pProxy.nameForProxy, self.myGroup.myEntTableDataRoot);
	endif;

	self.heading				:= pProxy.heading;
	self.shortHeading			:= pProxy.shortHeading;
	self.sortFieldName			:= pProxy.sortFieldName;
	self.controlName			:= pProxy.controlName;
	self.inputType				:= pProxy.inputType;
	self.inputTypeForWeb		:= pProxy.inputTypeForWeb;
	self.myTerminologyType		:= pProxy.myTerminologyType;
	self.clickMethodName		:= pProxy.clickMethodName;
	self.gotFocusMethodName  	:= pProxy.gotFocusMethodName;
	self.lostFocusMethodName 	:= pProxy.lostFocusMethodName;
	self.visible				:= pProxy.visible;
	self.errorReturnString 		:= pProxy.errorReturnString;
	self.displayNullIfZero		:= pProxy.displayNullIfZero;
	self.measurementType		:= pProxy.measurementType;			// PAR #31155
	self.isMandatoryField		:= pProxy.isMandatoryField;			//12.01.2026 navlc30 #36954
	
	if self.myEntTableCellControl &lt;&gt; null then
		// Always delete and recreate as mey be of different type
		delete self.myEntTableCellControl;
	endif;

	if pProxy.myEntTableCellControl &lt;&gt; null then
		create entTableControl as pProxy.myEntTableCellControl.class persistent;
		entTableControl.setForCreate(pProxy.myEntTableCellControl, self);
	endif;
	
	// 28/8/2006 RBarr Localisation changes - replace EnttableLocales with XLAT_TranslatableText
//	self.setLocalesFromProxy(pProxy);


	// 30/8/2006 RBarr Now removed to EntTableAgent::trxSaveDataToGlobalConstants to ensure the global constants exist when myEntTableText is set
	//setTranslatableText;
	
	self.allDependencies.clear;
	pProxy.allDependencies.copy(self.allDependencies);
	
end;</source>
        <Parameter name="pProxy" type="EntTableRowProxy"/>
    </JadeMethod>
    <JadeMethod name="setFromXMLElement" id="13d3c6bb-0402-4aa8-a74a-f75c447aa81a">
        <updating/>
        <source>setFromXMLElement(pRowHeader : EntTableRowHeader; _xmlElement : JadeXMLElement; pGroup : EntTableGroup) updating;
// ---------------------------------------------------------------------------
// Created:     18 July 2001 by cnwrs2
//
// Purpose:     
/*
	&lt;GroupName&gt;GateReceivals&lt;/GroupName&gt;
	&lt;Heading&gt;Container No&lt;/Heading&gt;
	&lt;Number&gt;1234&lt;/Number&gt;
	&lt;AltHeading1&gt;xxx&lt;/AltHeading1&gt;
	&lt;AltHeading2&gt;yyy&lt;/AltHeading2&gt;
	&lt;InputType&gt;3&lt;/InputType&gt;
	&lt;LostFocus&gt;&lt;/LostFocus&gt;
	&lt;GotFocus&gt;&lt;/GotFocus&gt;
	&lt;Click&gt;&lt;/Click&gt;
	&lt;Visible&gt;&lt;/Visible&gt;
	&lt;ControlName&gt;&lt;/ControlName&gt;
	&lt;TerminologyType&gt;&lt;/TerminologyType&gt;
	&lt;ErrorReturnStr&gt;&lt;/ErrorReturnStr&gt;
	&lt;Text&gt;&lt;/Text&gt;
	&lt;DisplayNullIfZero&gt;&lt;/DisplayNullIfZero&gt;
	&lt;MeasurementType&gt;&lt;/MeasurementType&gt;
	&lt;CellControl&gt;
		&lt;Decimals&gt;3&lt;/Decimals&gt;
		&lt;Case&gt;3&lt;/Case&gt;
		&lt;MaxLength&gt;12&lt;/MaxLength&gt;
	&lt;/CellControl&gt;
*/
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 01 Mar 2010	cnwkpd1		PAR #22559 - Ent Table Row upgrade issues
//							Changed to set myRoot on new EntTableRow
// 17/05/2013	cnwdap1		Fix to reset myEntTableCellControl if class changes
// 04/06/2013	cnwdap1		PAR #31155 CCMS SFW 1321 Imperial Measurements
// 12 Jan 2026  navlc30     JIRA 36954 Story MTN | Highlight Mandatory fields
// ---------------------------------------------------------------------------
vars
	inputTypeDescr,
	cellControlStr	: String;
	entTableControl	: EntTableCellControl;
	controlClass	: Class;
	tmpElement		: JadeXMLElement;
	tmpElements		: JadeXMLElementArray;
	
	tmpShort,
	tmpHead		: String;
	
	
begin

	self.text				:= _xmlElement.getTagValueOfName(XMLTag_Text);

	self.heading			:= _xmlElement.getTagValueOfName(XMLTag_Heading);
	self.shortHeading		:= _xmlElement.getTagValueOfName(XMLTag_ShortHeading);
	self.number				:= _xmlElement.getTagValueOfName(XMLTag_Number).Integer;

//	tmpHead			:= _xmlElement.getTagValueOfName(XMLTag_Heading);
//	tmpShort		:= _xmlElement.getTagValueOfName(XMLTag_ShortHeading);
//	if tmpHead = tmpShort then
//		tmpShort := null;
//	endif;
//	
//	self.heading			:= tmpHead;
//	self.shortHeading		:= tmpShort;
	
	
	
	self.myTerminologyType	:= app.myRoot.allTerminologyTypes[_xmlElement.getTagValueOfName(XMLTag_TerminologyType)];
	
	create tmpElements transient;
	
	tmpElement := _xmlElement.getElementByTagName(XMLTag_DependsOn);
	if tmpElement &lt;&gt; null then
		tmpElements.clear;
		tmpElement.getAllElementsByTagName(XMLTag_DependRow, tmpElements);
		self.setDependenciesFromXMLElement(tmpElements);
	endif;
	
	self.inputType			:= _xmlElement.getTagValueOfName(XMLTag_InputType).Integer;
	self.inputTypeForWeb	:= _xmlElement.getTagValueOfName(XMLTag_InputTypeWeb).Integer;
	self.sortFieldName		:= _xmlElement.getTagValueOfName(XMLTag_SortField);
	self.lostFocusMethodName:= _xmlElement.getTagValueOfName(XMLTag_LostFocusMethod);
	self.gotFocusMethodName	:= _xmlElement.getTagValueOfName(XMLTag_GotFocusMethod);
	self.clickMethodName	:= _xmlElement.getTagValueOfName(XMLTag_ClickMethod);
	self.visible			:= _xmlElement.getTagValueOfName(XMLTag_Visible).Boolean;
	self.controlName		:= _xmlElement.getTagValueOfName(XMLTag_ControlName);
	self.errorReturnString	:= _xmlElement.getTagValueOfName(XMLTag_ErrorReturnStr);
	self.displayNullIfZero	:= _xmlElement.getTagValueOfName(XMLTag_DisplayNullIfZero).Boolean;
	self.measurementType	:= _xmlElement.getTagValueOfName(XMLTag_MeasurementType);			// PAR #31155
	self.isMandatoryField	:= _xmlElement.getTagValueOfName(XMLTag_IsMandatoryField).Boolean;	//12.01.2026 navlc30 #36954
	
	entTableControl := self.myEntTableCellControl;
	tmpElement := _xmlElement.getElementByTagName(XMLTag_CellControl);
	
	if tmpElement &lt;&gt; null then
		self.getInputTypeDetails(inputTypeDescr, controlClass);
		if controlClass &lt;&gt; null then
			if entTableControl &lt;&gt; null and controlClass &lt;&gt; entTableControl.class then	// cnwdap1 17/05/2013
				delete entTableControl;													// cnwdap1 17/05/2013
			endif;																		// cnwdap1 17/05/2013
			if entTableControl = null then
				create entTableControl as controlClass persistent;
			endif;
			
			entTableControl.setFromXMLElement(tmpElement, self);
		
		elseif entTableControl &lt;&gt; null then
			delete entTableControl;
		endif;
		
	elseif entTableControl &lt;&gt; null then
		delete entTableControl;
	endif;
//  if self.name.toUpper &lt;&gt; self.errorReturnString.toUpper then
//		write "current item num="&amp;self.number.String&amp;' name='&amp;self.name&amp;' errorReturn='&amp;self.errorReturnString&amp;' Group='&amp;pGroup.name;	
//endif;
	self.myEntTableRowHeader := pRowHeader;
	
	//epr JIRA 35088 18/6/25 - performance improvements if not deriving name everytime
	if self.myEntTableRowHeader &lt;&gt; null then
		self.name:=self.myEntTableRowHeader.name;
	endif;
	
	self.myGroup := pGroup;
	
	self.myRoot := pGroup.myEntTableDataRoot;		// PAR #22559
	
	self.setTranslatableText();

epilog
	delete tmpElements;

end;</source>
        <Parameter name="pRowHeader" type="EntTableRowHeader"/>
        <Parameter name="_xmlElement" type="JadeXMLElement"/>
        <Parameter name="pGroup" type="EntTableGroup"/>
    </JadeMethod>
    <JadeMethod name="setHeadingSpecial" id="82329b78-2d1f-4d32-a2d3-1d36d596a161">
        <updating/>
        <source>setHeadingSpecial( str : String ) updating;
//-----------------------------------------------------------------------
//	Created:	Anca
//  only used as temp for Toll Owens till after 7.5.1 when
// they can do translations themselves
//-----------------------------------------------------------------------
vars
	tmpTranslation	: XLAT_Translation;
begin
	heading := str;

	if self.myEntTableText &lt;&gt; null then
		foreach tmpTranslation in self.myEntTableText.allTextByLocale do
			tmpTranslation.setPropertyValue(XLAT_Translation::text.name, str);
		endforeach;
	endif;

epilog

end;</source>
        <Parameter name="str" type="String"/>
    </JadeMethod>
    <JadeMethod name="setMeasurementType" id="5005f530-0a11-474e-9cf5-4f8e870e323c">
        <updating/>
        <source>setMeasurementType(_measure : String) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 08/05/2013	cnwdap1		Initial creation PAR #31155 CCMS SFW 1321 Imperial Measurements
//
vars

begin
	self.measurementType := _measure;
epilog

end;</source>
        <Parameter name="_measure" type="String"/>
    </JadeMethod>
    <JadeMethod name="setMyEntTableRowHeader" id="71896573-89b8-4e98-9ba9-e16b92ce790a">
        <updating/>
        <source>setMyEntTableRowHeader(pName : String; pRoot : EntTableDataRoot) updating, protected;
// ---------------------------------------------------------------------------
// Created:     03 January 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	rowHeader		: EntTableRowHeader;

begin

	rowHeader := pRoot.allEntTableRowHeadersByName[pName];
	if rowHeader = null then
		create rowHeader;
		rowHeader.set(null, pName, pRoot);
	endif;
	self.myEntTableRowHeader := rowHeader;
	//epr JIRA 35088 18/6/25 - performance improvements if not deriving name everytime
	if self.myEntTableRowHeader &lt;&gt; null then
		self.name:=self.myEntTableRowHeader.name;
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="pName" type="String"/>
        <Parameter name="pRoot" type="EntTableDataRoot"/>
    </JadeMethod>
    <JadeMethod name="setMyTransientHeader" id="eca6099d-c905-46de-ae81-f75cbd700d08">
        <updating/>
        <source>setMyTransientHeader(_name : String; _header : EntTableRowHeader input) updating;

// Created by cnwdvb1 on 27 March 2007

vars

begin

	_header.setPropertyValue(EntTableRowHeader::name.name, _name[1:30]);	// 34658 trim name
	self.myEntTableRowHeader := _header;
	//epr JIRA 35088 18/6/25 - performance improvements if not deriving name everytime
	if self.myEntTableRowHeader &lt;&gt; null then
		self.name:=self.myEntTableRowHeader.name;
	endif;
end;</source>
        <Parameter name="_name" type="String"/>
        <Parameter name="_header" type="EntTableRowHeader" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setOriginalColumnName" id="b20d5d4c-b2fb-4e05-a874-91485086c79c">
        <updating/>
        <source>setOriginalColumnName(_colName : String) updating;
// 34685 hold measurement type name (can be &gt; 30) split over two attributes
vars

begin
	self.gotFocusMethodName := _colName[1:30];
	self.lostFocusMethodName := null;
	if _colName.length &gt; 30 then
		self.lostFocusMethodName := _colName[31:end];
	endif;
end;
</source>
        <Parameter name="_colName" type="String"/>
    </JadeMethod>
    <JadeMethod name="setTransientReferences" id="43729f6c-fb05-417a-a002-567caaa58aa4">
        <updating/>
        <source>setTransientReferences(pPersistent : EntTableRow; pGroup : EntTableGroup) updating;
// ---------------------------------------------------------------------------
// Created:     09 March 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	if pPersistent.myEntTableCellControl &lt;&gt; null then
		self.myEntTableCellControl := pPersistent.myEntTableCellControl.cloneSelf(true);
	endif;
	
	self.myGroup := pGroup;
	
end;</source>
        <Parameter name="pPersistent" type="EntTableRow"/>
        <Parameter name="pGroup" type="EntTableGroup"/>
    </JadeMethod>
    <JadeMethod name="setTranslatableText" id="3ae3f348-62f8-439c-9f0d-c3419816ce9f">
        <updating/>
        <source>setTranslatableText() updating;

// creat a related XLAT_EntityTableText object - call in transaction state

begin
	if self.myEntTableText = null then
		create self.myEntTableText persistent;
	endif;
	//const := constDict[etRow.constantName];
	self.myEntTableText.initialiseEntTableText(app.myRoot, EntTableRows, self);

end;
</source>
    </JadeMethod>
