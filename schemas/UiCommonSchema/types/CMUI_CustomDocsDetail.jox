    <JadeMethod name="createProxies" id="a6a29cbf-e085-41a0-a1e0-344db249b00b">
        <updating/>
        <source>createProxies()updating;
/*
Purpose - 	
Who - NAVAB1
Date - 15AUG2023
ADO - CR 59615 TASK 59620 	
*/

vars
	pxy, real : CM_CustomDocumentDetail;
begin
	delete self.myProxyDetail;
	self.allCustomDetails.purge();
	
	self.myProxyDetail := app.createUpdateProxy(self.myCustDocDetail).CM_CustomDocumentDetail;
	
	foreach real in self.myCustDocDetail.allSubDetails discreteLock do
		pxy := app.createUpdateProxy(real).CM_CustomDocumentDetail;
		pxy.setProxyParentDetail(self.myCustDocDetail);
		self.allCustomDetails.add(pxy);
	endforeach;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="displayContentTotals" id="f3625d85-9088-418d-b5b2-e54bdf35892f">
        <source>displayContentTotals(_currentDetail : CM_CustomDocumentDetail);
/*
Purpose - 	
Who - NAVAB1
Date - 15AUG2023
ADO - CR 59615 TASK 59620 	
*/

vars
	trackdItem  : CM_TrackedItem;
	custDocDetail 	: CM_CustomDocumentDetail;
	col, row , quantity, contentQuantity : Integer;
	weight, volume, volumeM3, weightKG, contentWeight, contentVolume : Decimal [23,4];
	indicator : String;
	table : CM_DataTable;
	ct : CM_CargoType;
begin
	table := self.tblData;
	col := table.getColumnByRowName(ETRow_IncludeChk);
	trackdItem := _currentDetail.myTrackedItem;
	 // ### TFS BUG 60193 01SEP2023 NAVAB1
	if trackdItem.isCargoGroupItem then
		trackdItem := trackdItem.CM_CargoGroup.allAssignedTrackedItems.first;
		ct := trackdItem.myCargoType;
		
		// ### TFS 60508 15SEP2023 NAVAB1 - moved this loop inside this IF
		foreach row in 2 to table.rows do

			table.accessRow(row);
			custDocDetail := table.accessedRow.itemObject.CM_CustomDocumentDetail;
			table.accessCell(row,col);
			if table.accessedCell.text = true.cnEcGetTableCheckBoxValue then
				quantity := quantity + custDocDetail.clearedQuantity;
				weight 	:= weight	 + custDocDetail.clearedWeight;
				volume  := volume 	+ 	custDocDetail.clearedVolume;
				custDocDetail.setInclude(true);

			else
				custDocDetail.setInclude(false);
			endif;
			
		endforeach;	
	else // ### TFS 60508 15SEP2023 NAVAB1
		ct := trackdItem.myCargoType;
		custDocDetail := self.myProxyDetail;
		quantity := quantity + custDocDetail.clearedQuantity;
		weight 	:= weight	 + custDocDetail.clearedWeight;
		volume  := volume 	+ 	custDocDetail.clearedVolume;
	endif;
	
	self.lblDisplayContentQuantity.caption	:= quantity.String;	
	self.lblDisplayContentWeight.caption := app.convertMeasurementForDisplay(self.myMeasurementTypeForWeight.shortName,weight).String; // ### TFS BUG 62187 14FEB2024 NAVAB1
	self.lblDisplayContentVolume.caption := app.convertMeasurementForDisplay(self.myMeasurementTypeForVolume.shortName,volume).String; // ### TFS BUG 62187 14FEB2024 NAVAB1
	
			volumeM3 := self.txtClearedVolume.getConvertedValue();
			if volumeM3 = volume then
				self.lblDisplayContentVolume.foreColor := Green;
			else
				self.lblDisplayContentVolume.foreColor := Red;
				contentVolume := (volumeM3 - volume) * -1;
				indicator := "";
				if contentVolume &gt; 0 then
					indicator := "+";
				endif;
				
				self.lblDisplayContentVolume.caption :=  self.lblDisplayContentVolume.caption &amp; " ( " &amp; indicator &amp;  app.convertMeasurementForDisplay(self.myMeasurementTypeForVolume.shortName,contentVolume).String &amp; " )"; // app.getVolumeForDefaultDisplay(contentVolume).String &amp; " )";
			endif;
			
			
			weightKG := self.txtClearedWeight.getConvertedValue();
			if weightKG = weight then
				self.lblDisplayContentWeight.foreColor := Green;
					
			else
				self.lblDisplayContentWeight.foreColor := Red;
				contentWeight := (weightKG - weight) * -1;
				indicator := "";
				if contentWeight &gt; 0 then
					indicator := "+";
				endif;
				
				self.lblDisplayContentWeight.caption :=  self.lblDisplayContentWeight.caption &amp; " ( " &amp; indicator &amp; app.convertMeasurementForDisplay(self.myMeasurementTypeForWeight.shortName,contentWeight).String &amp; " )";
			endif;			
		
		if self.txtClearedQuantity.text.Integer = quantity then
			self.lblDisplayContentQuantity.foreColor := Green;
		else
			self.lblDisplayContentQuantity.foreColor := Red;
			contentQuantity := (self.txtClearedQuantity.text.Integer - quantity) * -1;
			indicator := "";
			if contentQuantity &gt; 0 then
				indicator := "+";
			endif;
			self.lblDisplayContentQuantity.caption :=  self.lblDisplayContentQuantity.caption &amp; " ( " &amp; indicator &amp; contentQuantity.String &amp; " )";
		endif;
	
	self.displayStatus();
epilog

end;</source>
        <Parameter name="_currentDetail" type="CM_CustomDocumentDetail"/>
    </JadeMethod>
    <JadeMethod name="displayCustDocDetail" id="3e8d4e37-bb05-4337-a890-8f4119bd9ba7">
        <updating/>
        <source>displayCustDocDetail()updating;
/*
Purpose - 	
Who - NAVAB1
Date - 15AUG2023
ADO - CR 59615 TASK 59620 	
*/

vars
	weight, volume,
	totalWeight, totalVolume: String; 
	weightMeasurement, volumeMeasurement : CM_MeasurementType;
	cooDetail : CM_CustomDocumentDetail;
	col, row , quantity,clearedQuantity : Integer;
	weight1, volume1,clearedweight, clearedvolume, portion: Decimal [23,4];
	ct : CM_CargoType;
	ti, subTI : CM_TrackedItem;
begin 
	if self.myCustDocDetail &lt;&gt; null then
		self.setCaption(self.caption &amp; " " &amp; self.myCustDocDetail.auditId());
		
		ti := self.myCustDocDetail.myTrackedItem;
		if ti &lt;&gt; null then
			if ti.isCargoGroupItem() then
				subTI := ti.CM_CargoGroup.allAssignedTrackedItems.first;
			else
				subTI := ti;
			endif;
			if subTI = null then
				self.txtClearedQuantity.enabled := false;
				self.txtClearedVolume.enabled := false;
				self.txtClearedWeight.enabled := false;
				return;
			endif;
			
			ct := subTI.myCargoType;
			
			if ct.isBulk() then
				self.txtClearedQuantity.text			:= self.myCustDocDetail.clearedQuantity.String;
				self.txtClearedQuantity.enabled := false;
				self.lblDisplayCurrentQuantity.caption := self.totalQuantity.String; // ### TFS BUG 62187 14FEB2024 NAVAB1

				weightMeasurement := self.myMeasurementTypeForWeight;
				weight := app.convertMeasurementForDisplay(weightMeasurement.shortName,  self.myCustDocDetail.clearedWeight);
				totalWeight := app.convertMeasurementForDisplay(weightMeasurement.shortName,  ti.totalWeight); 
				self.txtClearedWeight.setValues(weight &amp; Space &amp; weightMeasurement.shortName);
				self.txtClearedCargoWeight.setValues("0" &amp; Space &amp; weightMeasurement.shortName);
				self.lblDisplayCurrentWeight.caption	:= totalWeight.asStringJMT() &amp; Space &amp; weightMeasurement.shortName; 

				volumeMeasurement := self.myMeasurementTypeForVolume;
				totalVolume := app.convertMeasurementForDisplay(volumeMeasurement.shortName,  ti.totalVolume); 
				volume := app.convertMeasurementForDisplay(volumeMeasurement.shortName, self.myCustDocDetail.clearedVolume);
				self.txtClearedVolume.setValues(volume &amp; Space &amp; volumeMeasurement.shortName);
				self.txtClearedCargoVolume.setValues("0" &amp; Space &amp; volumeMeasurement.shortName);
				self.lblDisplayCurrentVolume.caption	:= totalVolume.asStringJMT() &amp; Space &amp; volumeMeasurement.shortName; 

				if ct.isTrackByWeight then

					self.txtClearedWeight.enabled := true;
					self.txtClearedVolume.enabled := false;
					self.txtClearedWeight.setFocus();
				else
					self.txtClearedWeight.enabled := false;
					self.txtClearedVolume.enabled := true;
					self.txtClearedVolume.setFocus();
				
				endif;
			else
				self.lblDisplayCurrentQuantity.caption := self.totalQuantity.String; 
				self.txtClearedQuantity.text			:= self.myCustDocDetail.clearedQuantity.String;
				self.txtClearedQuantity.enabled := true;
				self.txtClearedQuantity.setFocus();

				// ### TFS BUG 62187 14FEB2024 NAVAB1
				//portion := self.myCustDocDetail.clearedQuantity / self.totalQuantity; //20.07.2024 navrv30 Bug 64858
				self.lblDisplayCurrentWeight.caption	:= self.totalWeight.String; // ### TFS BUG 62187 14FEB2024 NAVAB1
				self.txtClearedWeight.setValue( self.myCustDocDetail.clearedWeight); // ### TFS BUG 62187 14FEB2024 NAVAB1
				self.txtClearedWeight.enabled := false;

				// ### TFS BUG 64115 13MAY2024 NAVAB1
				self.lblDisplayCurrentVolume.caption	:= self.totalVolume.String;
				self.txtClearedVolume.setValue( self.myCustDocDetail.clearedVolume); 
				self.txtClearedVolume.enabled := false;
				/*
				self.txtClearedVolume.text			:= null;
				self.lblDisplayCurrentVolume.caption	:= self.totalVolume.String; // ### TFS BUG 62187 14FEB2024 NAVAB1
				self.txtClearedVolume.enabled := false;
				*/
			endif;
			
		endif;
	endif;
	
	if self.myCustDocDetail.allSubDetails.isNotEmpty() then
		self.displaySubDetails();
	endif;

	self.displayContentTotals(self.myCustDocDetail); // ### TFS BUG 59667 31AUG2023 NAVAB1
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="displayStatus" id="c4c8d91d-c2e3-4be8-bbba-792b50bea65b">
        <source>displayStatus();
/*
Purpose - 	
Who - NAVAB1
Date - 15AUG2023
ADO - CR 59615 TASK 59620 	
*/

vars
	custDocDetail : CM_CustomDocumentDetail;
	col, row , quantity,clearedQuantity : Integer;
	weight, volume,clearedweight, clearedvolume : Decimal [23,4];
	table : CM_DataTable;

begin
	// ### TFS 60508 15SEP2023 NAVAB1 - handle non cargo group, single items
	if self.myCustDocDetail &lt;&gt; null
	and self.myCustDocDetail.allSubDetails.isEmpty() then
		quantity := self.myCustDocDetail.myTrackedItem.totalQuantity;
		weight 	:= self.myCustDocDetail.myTrackedItem.totalWeight;
		volume  := self.myCustDocDetail.myTrackedItem.totalVolume;
		clearedQuantity := self.myProxyDetail.clearedQuantity;
		clearedweight 	:= self.myProxyDetail.clearedWeight;
		clearedvolume  := self.myProxyDetail.clearedVolume;
		
	else
		table := self.tblData;
		col := table.getColumnByHeading(ETRow_IncludeChk);
		
		foreach row in 2 to table.rows do
		
			table.accessRow(row);
			custDocDetail := table.accessedRow.itemObject.CM_CustomDocumentDetail;
			if custDocDetail.isIncluded() then
				if custDocDetail.myTrackedItem &lt;&gt; null then
					quantity := quantity + custDocDetail.myTrackedItem.totalQuantity;
					weight 	:= weight	 + custDocDetail.myTrackedItem.totalWeight;
					volume  := volume 	+ 	custDocDetail.myTrackedItem.totalVolume;
					clearedQuantity := clearedQuantity + custDocDetail.clearedQuantity;
					clearedweight 	:= clearedweight	 + custDocDetail.clearedWeight;
					clearedvolume  := clearedvolume 	+ 	custDocDetail.clearedVolume;
				endif;
			endif;
		endforeach;
	endif;
							
	self.statusBar.caption :=  " Current Quantity " &amp; quantity.String &amp;
		" Current Weight " &amp; app.getWeightForDefaultDisplay(weight) &amp; 
		" Current Volume " &amp; app.getVolumeForDefaultDisplay(volume) &amp; " | "&amp; 
		" Cleared Quantity " &amp; clearedQuantity.String &amp;
		" Cleared Weight " &amp;  app.getWeightForDefaultDisplay(clearedweight) &amp; 
		" Cleared Volume " &amp; app.getVolumeForDefaultDisplay(clearedvolume);
						
		
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="displaySubDetail" id="a63602d1-36a9-4745-b566-6d143bb03b89">
        <source>displaySubDetail();
/*
Purpose - 	
Who - NAVAB1
Date - 15AUG2023
ADO - CR 59615 TASK 59620 	
*/

vars
	weightStr, volumeStr : String;
	weightMeasurement, volumeMeasurement : CM_MeasurementType;
	trackdItem  : CM_TrackedItem;
	custDocDetail 	: CM_CustomDocumentDetail;
	col, row , quantity,clearedQuantity : Integer;
	weight, volume,clearedweight, clearedvolume, contentWeight, contentVolume : Decimal [23,4];
	indicator : String;
	table : CM_DataTable;
	include, includeClicked, updateable : Boolean;
	ct : CM_CargoType;
	portion : Decimal[23,4];
begin
	table := self.tblData;
	if table.allSelectedObjects.isEmpty then
		return;
	endif;
	
	col := table.getColumnByRowName(ETRow_IncludeChk);
	includeClicked := false;
	if col = table.column then // clicked 'include' column
		table.accessCell(table.row,col);
		include := table.accessedCell.text = true.cnEcGetTableCheckBoxValue ;
		includeClicked := true;
	endif;
	
	custDocDetail := table.allSelectedObjects.first.CM_CustomDocumentDetail;
	
	trackdItem := custDocDetail.myTrackedItem;
	if trackdItem &lt;&gt; null then
	
	
	
		ct := trackdItem.myCargoType;
		updateable := ct.allowDuplicates;
	
		// ### TFS BUG 62187 14FEB2024 NAVAB1 - rewritten
		self.lblDisplayCargoCurrentQuantity.caption := trackdItem.totalQuantity.String;
		self.txtClearedCargoQuantity.text := custDocDetail.clearedQuantity.String;

		self.lblDisplayCargoCurrentVolume.caption	:= trackdItem.totalVolume.String;
		volumeMeasurement :=  self.myMeasurementTypeForVolume;
		
		volumeStr := app.convertMeasurementForDisplay(volumeMeasurement.shortName,  custDocDetail.clearedVolume);
		self.txtClearedCargoVolume.setValues(volumeStr &amp; Space &amp; volumeMeasurement.shortName);
		self.txtClearedCargoVolume.enabled := updateable;

		weightMeasurement := self.myMeasurementTypeForWeight;
		weightStr := app.convertMeasurementForDisplay(weightMeasurement.shortName, custDocDetail.clearedWeight);
		self.txtClearedCargoWeight.setValues(weightStr &amp; Space &amp; weightMeasurement.shortName);

		self.lblDisplayCargoCurrentWeight.caption	:= trackdItem.totalWeight.String;
		self.txtClearedCargoWeight.enabled := updateable;
		if ct.isBulk() then
			if ct.isBulkByVolume then
				self.txtClearedCargoQuantity.enabled := false;
				self.txtClearedCargoWeight.enabled := false;
				self.txtClearedCargoVolume.enabled := updateable;
			else
				self.txtClearedCargoQuantity.enabled := false;
				self.txtClearedCargoWeight.enabled := updateable;
				self.txtClearedCargoVolume.enabled := false;
			endif;
		else
				self.txtClearedCargoQuantity.enabled := updateable;
				self.txtClearedCargoWeight.enabled := false;
				self.txtClearedCargoVolume.enabled := false;

		endif;
		

	endif;
	
	custDocDetail.setInclude(include); // ### TFS CR 60424 TASK 60549 26SEP2023 NAVAB1
	if includeClicked then
		self.displayContentTotals( self.myCustDocDetail);  // ### TFS CR 60424 TASK 60549 26SEP2023 NAVAB1 custDocDetail); self.myCustDocDetail
	endif;
	
	self.btnCargoUpdate.enabled := updateable;
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		self.tblData.userInputEnabled := false;
		self.btnCargoUpdate.enabled := false;
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="displaySubDetails" id="595ce48e-ceff-49ce-b705-1a6ea86d860d">
        <source>displaySubDetails();
/*
Purpose - 	
Who - NAVAB1
Date - 15AUG2023
ADO - CR 59615 TASK 59620 	
*/

vars
	tbl					: CM_DataTable;
	idx					: Integer;
	str 				: String;
	custDocDetail : CM_CustomDocumentDetail;
	theDataLine : String;
	trackedItem : CM_TrackedItem;
	cargoGroup 	: CM_CargoGroup;
	ti         : CM_TrackedItem;
	pxyCustDocDetail,detail : CM_CustomDocumentDetail;
	tiSet : CM_TISet; 
	included : Boolean;
	totalWeight, totalVolume : Decimal[23,4];
	totalQuantity : Integer;
begin

	tbl := self.tblData;
	tbl.rows := tbl.fixedRows;
	if self.myCustDocDetail.myTrackedItem.isKindOf(CM_CargoGroup)  then
		if self.allCustomDetails.isEmpty then // Create sub details
			cargoGroup := self.myCustDocDetail.myTrackedItem.CM_CargoGroup;
			tiSet := cargoGroup.allAssignedTrackedItems;  
			foreach trackedItem in tiSet do 
					create pxyCustDocDetail transient;
					included := trackedItem.getCustDocsIsIncluded();
					totalWeight := trackedItem.getCustDocsClearedWeight();
					totalVolume := trackedItem.getCustDocsClearedVolume();
					totalQuantity := trackedItem.getCustDocsClearedQuantity();
					
					pxyCustDocDetail.setProxy(totalQuantity, totalWeight,totalVolume,included,trackedItem,null,self.myCustDocDetail);
					self.allCustomDetails.add(pxyCustDocDetail);
					tblData.addObject(pxyCustDocDetail);				
				
			endforeach;
		else // display sub details
			foreach custDocDetail in self.allCustomDetails discreteLock do
				tblData.addObject(custDocDetail);				
			endforeach;
		endif;
	else
// ### TFS 60508 15SEP2023 NAVAB1		self.doClear();
	endif;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doClear" id="d521ed05-4902-489f-a6ec-65d955e8e4d8">
        <source>doClear();
/*
Purpose - 	
Who - NAVAB1
Date - 15AUG2023
ADO - CR 59615 TASK 59620 	
*/

vars

begin
	self.txtClearedCargoVolume.text := "";
	self.txtClearedCargoWeight.text := "";
	self.txtClearedCargoQuantity.text := "";
	self.lblDisplayCargoCurrentQuantity.caption := "";
	self.lblDisplayCargoCurrentVolume.caption	 := "";
	self.lblDisplayCargoCurrentWeight.caption	:= "";
	self.lblDisplayContentVolume.caption		:="";
	self.lblDisplayContentWeight.caption	:= "";
	self.lblDisplayContentQuantity.caption	:= "";
	self.tblData.allSelectedObjects.clear();
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doMeasurementVolume" id="3d441207-53b2-40c0-a4c1-bb71f11aea96">
        <updating/>
        <source>doMeasurementVolume() updating;
/*
Purpose - 	
Who - NAVAB1
Date - 15AUG2023
ADO - CR 59615 TASK 59620 	
*/

vars
	ti : CM_TrackedItem;
	ct : CM_CargoType;

begin
	self.txtClearedVolume.setup(Type_Volume, self.backColor);
	self.txtClearedCargoVolume.setup(Type_Volume, self.backColor);
	self.myMeasurementTypeForVolume :=  app.getDefaultMeasurementForType(Type_Volume);
	
	ti := self.myCustDocDetail.myTrackedItem;
	
	if ti &lt;&gt; null and ti.isCargoGroupItem then
		ti :=  ti.CM_CargoGroup.allAssignedTrackedItems.first;
	endif;
	
	if ti &lt;&gt; null then
		ct := ti.myCargoType;
		
		if ct &lt;&gt; null then
			if ct.isBulk 
			and ct.isTrackByVolume   then
				if ct.myVolumeMeasurementType &lt;&gt; null then
					self.myMeasurementTypeForVolume :=  ct.myVolumeMeasurementType;
				endif;
			
			endif;
		endif;
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doMeasurementWeight" id="40cc451a-7904-4b10-8ed6-7440e7173ad8">
        <updating/>
        <source>doMeasurementWeight() updating;
/*
Purpose - 	
Who - NAVAB1
Date - 15AUG2023
ADO - CR 59615 TASK 59620 	
*/

vars
	ti : CM_TrackedItem;
	ct : CM_CargoType;
begin
	self.txtClearedWeight.setup(Type_Weight, self.backColor);
	self.txtClearedCargoWeight.setup(Type_Weight, self.backColor);
	self.myMeasurementTypeForWeight := app.getDefaultMeasurementForType(Type_Weight);
	
	ti := self.myCustDocDetail.myTrackedItem;
	
	if ti &lt;&gt; null and ti.isCargoGroupItem then
		ti :=  ti.CM_CargoGroup.allAssignedTrackedItems.first;
	endif;
	
	if ti &lt;&gt; null then
		ct := ti.myCargoType;
		
		if ct &lt;&gt; null then
			if ct.isBulk 
			and not ct.isTrackByVolume   then
				if ct.myWeightMeasurementType &lt;&gt; null then
					self.myMeasurementTypeForWeight := ct.myWeightMeasurementType;
				endif;
			endif;
		endif;
	endif;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doMnuColumnOrganiserClick" id="9ba44b5d-7ebe-43bd-b327-ee0227a96368">
        <updating/>
        <source>doMnuColumnOrganiserClick(menuItem:MenuItem) updating;
/*
Purpose - 	
