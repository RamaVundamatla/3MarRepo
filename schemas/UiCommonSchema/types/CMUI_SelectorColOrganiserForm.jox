        <updating/>
        <source>fldMain_sheetChg(folder: Folder input) updating;
//--------------------------------------------------
// Created:	08 September 2005 By: cnwgd1
//--------------------------------------------------
vars

begin
	if folder.topSheet = self.shtColumnSorter then
		self.setColumnSorter(false);
	endif;
end;</source>
        <Parameter name="folder" type="Folder" usage="input"/>
    </JadeMethod>
    <JadeMethod name="initMultiSelectShts" id="c3cf54bd-5321-4c88-b51e-f2d7ceb94d66">
        <source>initMultiSelectShts()protected;
//--------------------------------------------------
// Created:	08 September 2005 By: cnwgd1
//--------------------------------------------------
vars
	tmpMulSel : CMUI_MultiSelectGroupBox;
begin
	
	tmpMulSel := self.mulColumns;
	tmpMulSel.availableHeading := 'Available';
	tmpMulSel.selectedHeading := 'Selected and Order';
	tmpMulSel.formDisplayEntryMethodName := 'displayMultiSelectAvailable'; 
	tmpMulSel.myBaseForm := self;
	tmpMulSel.myAvailableListBox.sorted := true;		
	tmpMulSel.mySelectedListBox.sorted := false;
	tmpMulSel.mySelectedListBox.allowDragDrop := true;	
	tmpMulSel.displayOrderBtns(true, true);
	tmpMulSel.multiSelect := ListBox.MultiSelect_Extended;
	//tmpMulSel.multiSelect := ListBox.MultiSelect_Simple;
	
	if (not self.allowSort) then
		self.shtColumnSorter.visible := false;
		return;
	endif;
	
	tmpMulSel := self.mulColumnSorter;	
	tmpMulSel.availableHeading := 'Available';
	tmpMulSel.selectedHeading := 'Selected and Order (Max ' &amp; self.maxSortingColumns.String &amp; ')';
	tmpMulSel.formDisplayEntryMethodName := 'displayMultiSelectAvailable'; 
	tmpMulSel.myBaseForm := self;
	tmpMulSel.myAvailableListBox.sorted := false;	
	tmpMulSel.mySelectedListBox.sorted := false;
	tmpMulSel.mySelectedListBox.allowDragDrop := true;		
	tmpMulSel.mySelectedListBox.formDisplayEntryMethodName := 'displayMultiSelectSorted';
	tmpMulSel.displayOrderBtns(true, true);
	//tmpMulSel.multiSelect := ListBox.MultiSelect_Simple;
	tmpMulSel.multiSelect := ListBox.MultiSelect_Extended;

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setColorsFromController" id="38813bb8-a454-4835-99d7-fbfd6e4a6888">
        <updating/>
        <source>setColorsFromController(_colorControl : CM_ColorController) updating;
//--------------------------------------------------
// Created:	08 September 2005 By: cnwgd1
//--------------------------------------------------
vars

begin
	inheritMethod(_colorControl);

	self.setColorsForMultiSelectGrpBox(self.mulColumns);
	self.setColorsForMultiSelectGrpBox(self.mulColumnSorter);

	self.fldMain.tabsStyle := Folder.TabsStyle_RightSloped;

	self.fldMain.useSheetBackColors := true;
	self.fldMain.setDefaultSheetBackColors();
	self.fldMain.initSheetBackColors();		
end;</source>
        <Parameter name="_colorControl" type="CM_ColorController"/>
    </JadeMethod>
    <JadeMethod name="setColumnSorter" id="ff158f11-5dfe-4037-8976-6ed19200c791">
        <source>setColumnSorter(_resetSelected : Boolean)protected;
//--------------------------------------------------
// Created:	08 September 2005 By: cnwgd1
//--------------------------------------------------
vars
	tmpAvailable,
	tmpSelected : EntTableRowArray;
begin
	// the avaiable sort columns are the selected table columns
	create tmpAvailable transient;
	self.mulColumns.getSelected(tmpAvailable);
	self.mulColumnSorter.setAvailable(tmpAvailable, _resetSelected);
			
	if _resetSelected then
		create tmpSelected transient;
		self.myDataTable.getSortColumnEntRows(tmpSelected);
		self.mulColumnSorter.setSelected(tmpSelected);			
	endif;
	
epilog
	delete tmpAvailable;
	delete tmpSelected;
end;</source>
        <access>protected</access>
        <Parameter name="_resetSelected" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setupForm" id="cce04427-dca4-4b4e-8f56-d1660f734833">
        <updating/>
        <source>setupForm() updating;
//--------------------------------------------------------------
//Created: 24 February 2003 By: cnwgd1
//--------------------------------------------------------------
vars

begin
	inheritMethod();

	self.allowSort := (not self.myDataTable.disallowColumnSorter);
	if app.getMyUser.canDo(self.myTerminal, PmCmpColumnOrgSystemMaint) then
		// 32345 add the reset button, disable both for Transaction selectors as there's nowhere to save system defauls
		//29 Mar 2019	NDL	TFS 44100 - There is now....
	//	if self.selectorMode &lt;&gt; CM_QueryDefinition.CargoTransaction_Query_Mode and
	//	   self.selectorMode &lt;&gt; CM_QueryDefinition.EventTransaction_Query_Mode and
	//	   self.selectorMode &lt;&gt; CM_QueryDefinition.HMSTransaction_Query_Mode then
			self.cbxSystem.enabled := true;
			self.btnResetJMT.enabled := true;
	//	endif;
	endif;
	
	if self.myDataTable.maxSortColumns &gt; self.maxSortingColumns then
		self.maxSortingColumns := self.myDataTable.maxSortColumns;
	endif;
	
	self.modalResult := IDCANCEL;
	self.btnAscDesc.parent := self.mulColumnSorter;	
	self.initMultiSelectShts();	
	self.showAllEntTblRows();	
	self.caption := self.Caption &amp; ' ' &amp; self.myDataTable.form.caption;
	
	// cnwrl1 17/03/2009 - PAR 19037
	// Make the form resizeable so that the last properties can be seen and selected
	// on both sides even with the scroll bars the last entry is not visible.
	self.borderStyle	:= Control.BorderStyle_Sizable;		// cnwrl1 17/03/2009 - PAR 19037
	
end;</source>
    </JadeMethod>
    <JadeMethod name="showAllEntTblRows" id="f3851478-5ea7-4556-9b22-481de044eeb8">
        <updating/>
        <source>showAllEntTblRows() updating, protected;
//--------------------------------------------------------------
//Created: 14 January 2003 By: cnwgd1
//--------------------------------------------------------------
vars
	entRow		: EntTableRow;
	array		: EntTableRowArray;
	tmpTable	: CM_DataTable;
	lstBox		: CM_MultiSelectListBox;
begin
	
	// This method gets all the available columns for the table
	
	tmpTable := self.myDataTable;
	if tmpTable.myEntTableDef = null then
		return;
	endif;
	
	// add the current visible columns 
	//tmpTable.allTblDataEntRows.copy(self.allTblDataEntRows);

	// add any hiden rows
	if tmpTable.myEntTableView = null then
		array := tmpTable.myEntTableDef.allEntTableRows;	
	else 
	//epr if table has a view only show those available to that view
	// view is set if CM_DataTable::setTblDataEntRowsFromView is called
		array :=tmpTable.myEntTableView.allEntTableRows;
	endif;
	
	foreach entRow in array do
		//25/06/2009 cnwdz2  par20107 
		if entRow.name = "mySubTerminal" and not app.isSubTerminalsLicensed then
			   continue;
		endif;

		if (not self.allTblDataEntRows.includes(entRow)) then
			self.allTblDataEntRows.add(entRow);
		endif;
	endforeach;
	
	self.mulColumns.setAvailable(self.allTblDataEntRows, true);
	self.mulColumns.setSelected(tmpTable.allTblDataEntRows);
	
	self.setColumnSorter(true);
	
	self.doResize();
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="translateForm" id="d169c635-484b-48e8-b31e-ddf4d822c57c">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 11 March 2019 19:43:17.
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0008095, locale);
	btnAscDesc.translateBubbleHelp(Xlat_0005189, locale);
	btnAscDesc.translateCaption(Xlat_0005190, locale);
//	btnResetJMT.translateBubbleHelp(Xlat_0023294, locale);
//	btnResetJMT.translateCaption(Xlat_0023295, locale);
//	btnResetSys.translateCaption(Xlat_0023296, locale);
	cbxSystem.translateBubbleHelp(Xlat_0005191, locale);
	cbxSystem.translateCaption(Xlat_0005192, locale);
	shtColumnSorter.translateCaption(Xlat_0005193, locale);
	shtColumns.translateCaption(Xlat_0005194, locale);
end;</source>
    </JadeMethod>
</GUIClass>
