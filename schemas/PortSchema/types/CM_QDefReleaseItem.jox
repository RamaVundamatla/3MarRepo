    <JadeMethod name="create" id="69f62313-9e11-4fb1-90b9-4a9d263a2127">
        <updating/>
        <source>create() updating;
/*
Purpose:			
Parameters:			
Return Value:		

Date		Who		Reason
========================================================
08/02/2010	cnwcs5	CCMS 1925/PAR 22295 Release Summaries (Initial creation)
*/

vars

begin
	self.className := CM_ReserveDetail.name;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="createProperties" id="bc5b16e2-558b-4d73-9b9b-1c8f721a4114">
        <source>createProperties();
/*
Purpose:			
Parameters:			
Return Value:		

Date		Who		Reason
========================================================
08/02/2010	cnwcs5	CCMS 1925/PAR 22295 Release Summaries (Initial creation)
21/04/2014	cnwdap1	PAR #33235 Measurement types in Summaries
10/03/2016	cnwdap1	PAR #37581 densitySelection on CM_ReserveSelection shanged from Integer to Decimal
*/

vars
	prop	:CM_QueryProperty;
begin
	inheritMethod();

	// Availability Grade
	create prop as CM_QRefAvailabilityGradeMethod persistent;
	prop.set ('Availability Grade', CM_ReserveDetail::getFirstAvailabilityGrade.name, self.className);
	prop.setPerformanceRating( CM_QueryProperty.Simple );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add (prop);
	
	// Cargo Type
	create prop as CM_QStringMethod persistent;
	prop.set('Cargo Type', CM_ReserveDetail::getCargoTypeDescr.name, self.className);
	prop.setPerformanceRating( CM_QueryProperty.Simple );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add(prop);

	// Clean
	create prop as CM_QBooleanMethod persistent;
	prop.set('Clean', CM_ReserveDetail::getClean.name, self.className);
	prop.setPerformanceRating( CM_QueryProperty.Simple );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add(prop);
	
	// Consignee
	create prop as CM_QStringMethod persistent;
	prop.set ('Consignee', CM_ReserveDetail::getConsigneeCode.name, self.className);
	prop.setPerformanceRating( CM_QueryProperty.Simple );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add (prop);
	
	// Consignor Voyage Code
	create prop as CM_QStringMethod persistent;
	prop.set ('Consignor Voyage Code', CM_ReserveDetail::getConsignorVoyageCode.name, self.className);
	prop.setPerformanceRating( CM_QueryProperty.Simple );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add (prop);	
	
	// Description
	create prop as CM_QStringMethod persistent;
	prop.set ('Description', CM_ReserveDetail::getDescriptionForSummary.name, self.className);
	prop.setPerformanceRating( CM_QueryProperty.Simple );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add (prop);
		
	// Density
	//create prop as CM_QIntegerMethod persistent;																										// PAR #33235
	//prop.set ('Density', CM_ReserveDetail::getDensitySelection.name, self.className);																	// PAR #33235
	//self.allQueryProperties.add (prop);																												// PAR #33235
	//self.createMeasurementProperties(CM_QIntegerMethod, Type_Density, 'Density', CM_ReserveDetail::getDensitySelection.name, self.className, null);	// PAR #33235	// PAR #37581
	self.createMeasurementProperties(CM_QDecimalMethod, Type_Density, 'Density', CM_ReserveDetail::getDensitySelection.name, self.className, null);		// PAR #33235	// PAR #37581
	
	// Estimated Required Date
	create prop as CM_QDateMethod persistent;
	prop.set ('Estimated Required Date', CM_ReserveDetail::getEstimatedRequiredDate.name, self.className);
	prop.setPerformanceRating( CM_QueryProperty.Simple );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add (prop);
	
	// Freight Forwarder Code
	create prop as CM_QStringMethod persistent;
	prop.set ('Freight Forwarder Code', CM_ReserveDetail::getFreightForwarderCode.name, self.className);
	prop.setPerformanceRating( CM_QueryProperty.Simple );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add (prop);
	
	// Freight Payer Code
	create prop as CM_QStringMethod persistent;
	prop.set ('Freight Payer Code', CM_ReserveDetail::getFreightPayerCode.name, self.className);
	prop.setPerformanceRating( CM_QueryProperty.Simple );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add (prop);
	
	// Heavy Rated
	create prop as CM_QBooleanMethod persistent;
	prop.set('Heavy Rated', CM_ReserveDetail::getHeavyRated.name, self.className);
	prop.setPerformanceRating( CM_QueryProperty.Simple );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add(prop);
	
	// height
	//create prop as CM_QDecimalMethod persistent;																										// PAR #33235
	//prop.set ('Height', CM_ReserveDetail::getHeightForSummary.name, self.className);																	// PAR #33235
	//self.allQueryProperties.add (prop);																												// PAR #33235
	self.createMeasurementProperties(CM_QDecimalMethod, Type_Linear, 'Height', CM_ReserveDetail::getHeightForSummary.name, self.className, null);		// PAR #33235
	
	// ISO Type
	create prop as CM_QRefISOTypeMethod persistent;
	prop.set('ISO Type', CM_ReserveDetail::getISOType.name, self.className);
	prop.setPerformanceRating( CM_QueryProperty.Simple );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add(prop);	
	
	// ISO Group
	create prop as CM_QRefISOGroupMethod persistent;
	//prop.set('ISO Group', CM_ReserveDetail::getISOGroup.name, self.className);
	prop.set('ISO Group', CM_ReserveDetail::getISOGroupFromType.name, self.className);	// 18/03/2010 cnwar2 #22475 - check iso type first
	prop.setPerformanceRating( CM_QueryProperty.Simple );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add(prop);
	
	// Length
	//create prop as CM_QDecimalMethod persistent;																										// PAR #33235
	//prop.set ('Length', CM_ReserveDetail::getLengthForSummary.name, self.className);																	// PAR #33235
	//self.allQueryProperties.add (prop);																												// PAR #33235
	self.createMeasurementProperties(CM_QDecimalMethod, Type_Linear, 'Length', CM_ReserveDetail::getLengthForSummary.name, self.className, null);		// PAR #33235
	
	// Max to Release
	create prop as CM_QIntegerProperty persistent;
	prop.set('Max To Release', CM_ReserveDetail::maxToRelease.name, self.className);
	prop.setPerformanceRating( CM_QueryProperty.Simple );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add(prop);
	
	// Operator
	create prop as CM_QRefOperatorMethod persistent;
	prop.set ('Operator', CM_ReserveDetail::getOperator.name, self.className);
	prop.setPerformanceRating( CM_QueryProperty.Simple );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add (prop);
	
	// Operator group
	create prop as CM_QStringMethod persistent;
	prop.set ('Operator Group', CM_ReserveDetail::getOperatorGroupCode.name, self.className);
	prop.setPerformanceRating( CM_QueryProperty.Simple );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add (prop);
	
	// Pack location 21 July 2010	NDL	Par 25076 
	create prop as CM_QStringMethod persistent;
	prop.set ('Pack Location', CM_ReserveDetail::getPackLocationString.name, self.className);
	prop.setPerformanceRating( CM_QueryProperty.Simple );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add (prop);
	
	// Product Code
	create prop as CM_QStringMethod persistent;
	prop.set ('Cargo Subtype', CM_ReserveDetail::getProductCode.name, self.className);
	prop.setPerformanceRating( CM_QueryProperty.Simple );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add (prop);
	
	// Total Requested
	create prop as CM_QIntegerMethod persistent;
	prop.set ('Total Requested', CM_ReserveDetail::getTotalRequested.name, self.className);
	prop.setPerformanceRating( CM_QueryProperty.Simple );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add (prop);
	
	// Items Delivered
	create prop as CM_QIntegerMethod persistent;
	prop.set ('Items Delivered', CM_ReserveDetail::getQuantityReleased.name, self.className);
	prop.setPerformanceRating( CM_QueryProperty.Simple );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add (prop);
	
	// Items Remaining
	create prop as CM_QIntegerMethod persistent;
	prop.set ('Items Remaining', CM_ReserveDetail::getQuantityRemaining.name, self.className);
	prop.setPerformanceRating( CM_QueryProperty.Simple );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add (prop);
	
	// Volumne
	//create prop as CM_QDecimalMethod persistent;																										// PAR #33235
	//prop.set ('Volume', CM_ReserveDetail::getVolumeForSummary.name, self.className);																	// PAR #33235
	//self.allQueryProperties.add (prop);																												// PAR #33235
	self.createMeasurementProperties(CM_QDecimalMethod, Type_Volume, 'Volume', CM_ReserveDetail::getVolumeForSummary.name, self.className, null);		// PAR #33235
	
	// Voyage
	create prop as CM_QStringMethod persistent;
	prop.set ('Voyage', CM_ReserveDetail::getVoyageCode.name, self.className);
	prop.setPerformanceRating( CM_QueryProperty.Simple );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add (prop);
	
	// Weight
	//create prop as CM_QDecimalMethod persistent;																										// PAR #33235
	//prop.set ('Weight', CM_ReserveDetail::getWeightForSummary.name, self.className);																	// PAR #33235
	//self.allQueryProperties.add (prop);																												// PAR #33235
	self.createMeasurementProperties(CM_QDecimalMethod, Type_Weight, 'Weight', CM_ReserveDetail::getWeightForSummary.name, self.className, null);		// PAR #33235
	
	// Width
	//create prop as CM_QDecimalMethod persistent;																										// PAR #33235
	//prop.set ('Width', CM_ReserveDetail::getWidthForSummary.name, self.className);																	// PAR #33235
	//self.allQueryProperties.add (prop);																												// PAR #33235
	self.createMeasurementProperties(CM_QDecimalMethod, Type_Linear, 'Width', CM_ReserveDetail::getWidthForSummary.name, self.className, null);			// PAR #33235

	// Discharge Port 								// 27/02/2014 cnwar2 #32665
	create prop as CM_QStringMethod persistent;
	prop.set('Discharge Port', CM_ReserveDetail::getDischargePort.name, self.className);
	prop.setPerformanceRating( CM_QueryProperty.Simple );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add	(prop);
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="isReleaseItemType" id="736ddfc9-a015-440a-9449-fc4654f6a11c">
        <source>isReleaseItemType(): Boolean;
/*
Purpose:			
Parameters:			
Return Value:		

Date		Who		Reason
===========================================================================
08/02/2010	cnwcs5	CCMS 1925/PAR 22295 Release Summaries (Initial creation)
*/

vars

begin
	return true;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
