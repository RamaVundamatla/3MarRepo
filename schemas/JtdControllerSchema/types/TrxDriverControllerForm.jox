        <controlMethod name="MenuItem::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>mnuDriversSetClnDelay_click(menuItem: MenuItem input) updating;

vars
	n, errNo : Integer;
	
begin
	n := self.lastCloneDelaySetting;
	
	if app.readInteger("Enter the clone startup delay interval in seconds (max 60):",
		true, 0, 60, n)
	then
		self.lastCloneDelaySetting := n;
		
		// always send this command to all drivers
		app.mySession.doCmdSetStartupDelaySecs(system, n);
	endif;
end;</source>
