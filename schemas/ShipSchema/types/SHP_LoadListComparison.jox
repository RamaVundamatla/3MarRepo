    </JadeMethod>
    <JadeMethod name="initiateCompareVoyDet" id="e8ae18ff-cb22-4c7d-aa43-f27bc611a777">
        <updating/>
        <source>initiateCompareVoyDet(_isRefresh : Boolean) updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
24 November 2009	cnwas3	Initial creation

*/
vars
	ediData			: CM_EDIDataLoadList;
	ignoreFields	: StringArray;
	operators		: CM_OperatorSet;
	cmifMonitor		: CMIF_Monitor;
	passport		: CM_Passport;
	compareStatus	: Integer;
	
begin
	self.tblData.allSelectedObjects.clear;	
	
	passport := app.myPassport;
	
	if passport.myCMIFMonitor = null then
		create cmifMonitor transient;
		cmifMonitor.myParent := self;
		passport.setMyCMIFMonitor(cmifMonitor);
	endif;
	self.initModalDialog();
	

	self.lblModalMessage.caption := Cr &amp; app.getErrorString(List_Comparison);
	self.frmModalDialog.visible := true;
	self.doWindowEvents(0);

	//reset before each run 
	self.rtsSaved := false;
	endNotificationForSubscriber(self);
	

	//-----------------------------------
	// Do Comparision
	//-----------------------------------
	self.myLLCAgent.doComparisonVoyagePorts(self.myCurrentVoyage,passport);
	
	self.doShowView(null,_isRefresh);
	
	// cnwrl1 09/08/2010 PAR 24337 - why do we not register for notifications again? - have changed to do so!
	self.reDoNotes();
	
epilog
	delete cmifMonitor;
	self.frmModalDialog.visible := false;
end;
</source>
        <access>protected</access>
        <Parameter name="_isRefresh" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isItemValidForCurrentView" id="411dbd16-953d-43d2-ba5c-410da8a852a1">
        <source>isItemValidForCurrentView(_item: CM_EDITrackedItem): Boolean;
//----------------------------------------------------------------
//	Created:	04 February 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	discepTI,
	ediLLTI		: CM_EDITrackedItem;
	ediLLCTI	: CM_EDILoadListComparisonTI;
	aView		: String;
begin
	
	ediLLTI := _item;
	
	if CM_EDILoadListComparisonTI.hasInstance(ediLLTI) then
		ediLLCTI := ediLLTI.CM_EDILoadListComparisonTI;
	endif;
	
	if ediLLCTI = null then
		if self.myLLCAgent.allUnmatchedLLTIs.includes(ediLLTI) then
			aView := self.VIEW_NOT_IN_DB;
		endif;
	else
		if self.myLLCAgent.allMatchingTIs.includesKey(ediLLCTI.id) then
			aView := self.VIEW_MATCHING;
		elseif self.myLLCAgent.allUnmatchedDBTIs.includesKey(ediLLCTI.id) then
			aView := self.VIEW_NOT_IN_LIST;
		elseif self.myLLCAgent.allDiscrepancyTIs.includesKey(ediLLCTI.id) then
			aView := self.VIEW_DISCREPS;
		endif;
	endif;

	return (aView = self.cmbView.text);

end;</source>
        <Parameter name="_item" type="CM_EDITrackedItem"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="keyDown" id="c24ebd1c-46e3-4b80-9163-6100ad284050">
        <controlMethod name="Form::keyDown"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>keyDown(keyCode: Integer io; shift: Integer) updating;
// cnwrs1 feb 2006 ccms 1371
vars
	tbl : CM_DataTable;
	row : Integer;
	obj : Object;
begin
	tbl := self.tblData;
	if keyCode = J_key_A and shift.isControlKeyPressed then
		self.doSelectAll();
	elseif keyCode = J_key_Enter then //ccms 1137 cnwrs1 14 July 2010
		self.doRunComparisonClick(false);
	elseif keyCode = J_key_F11 
	       and app.isDevelopmentSystem then
			if self.tblData.row &gt; self.tblData.fixedRows then
				obj := self.tblData.accessRow(self.tblData.row).itemObject;
				if obj &lt;&gt; null then
					obj.inspect;
				endif;
			endif;
		
	else
		inheritMethod(keyCode, shift);
	endif;
end;</source>
        <Parameter name="keyCode" type="Integer" usage="io"/>
        <Parameter name="shift" type="Integer"/>
    </JadeMethod>
