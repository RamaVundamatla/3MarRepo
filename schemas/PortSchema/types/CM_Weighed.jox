    <JadeMethod name="getCCEventProperties" id="11c130b4-9560-445e-bf0a-14a0e15df2c2">
        <source>getCCEventProperties(ccEvent: CMIF_CCEvent) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 August 2019	jlgndl1	Initial creation	TFS 45963

*/

vars

	
	weightCertified : Boolean;
	
begin

	weightCertified := self.isWeightCertified;

	inheritMethod(ccEvent);
	
	ccEvent.addBoolean( "weightCertified", weightCertified ) ;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="ccEvent" type="CMIF_CCEvent"/>
    </JadeMethod>
    <JadeMethod name="getCCEventType" id="f3f1edb1-b89d-4e10-8354-1898907ba066">
        <source>getCCEventType(): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 August 2019	jlgndl1	Initial creation	TFS 45963

*/

vars

begin

	return CC_EventType_Weighed;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="03e9fc16-aa71-4739-90ac-527cedfe48fa">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
04 June 2010	cnwndl1	Initial creation	Par 23498

*/

vars
	lDetail : String;
	str : String;
begin

	if _attrName = ETRow_Details  then
		if self.deleted then
			return self.getDeletedDetails();		// 15/10/18 MAP TFS41191
			
		else
		
			//08 July 2019	NDL TFS	44965
			if weighBridgeName &lt;&gt; null then	
				str := app.getErrorString(WeighBridge) &amp; ' ' &amp; self.weighBridgeName &amp; ' ';
			endif;
			
			if self.userId &lt;&gt; null then
				str := str &amp; app.getErrorString(User) &amp; ' ' &amp; self.userId &amp; ' ';
			endif;
			if self.machineId &lt;&gt; null then
				str := str &amp; app.getErrorString(Machine) &amp; ' ' &amp; self.machineId &amp; ' ';
			endif;
			
			if weighBridgeName = null then	//08 July 2019	NDL TFS	44965
				str := str &amp; app.getString(Weight_certified) &amp; self.isWeightCertified.getYesNo();
			endif;
			
			//04 Nov 2014	NDL	Par 35160
			self.appendReferenceString( str );
			
			return str;
			
		endif;
		
	elseif _attrName = ETRow_WeighDriver then
		return self.driverId;
	elseif _attrName = ETRow_WeighMachine then
		return self.machineId;
	elseif _attrName = ETRow_IsWeightCertified then
		return self.isWeightCertified.getYesNo();
	
	else
		return inheritMethod(_attrName, _short);
	
	endif;

epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getEnquiryRow" id="5a3c1aae-179d-4eb3-9da2-5e2fbf9c7111">
        <source>getEnquiryRow(): String;
// -------------------------------------------
// Created 10 September 2004 by cnwdvb1
// -------------------------------------------
vars

	str : String;

begin
	str := inheritMethod();
	
	//08 July 2019	NDL TFS	44965
	if self.weighBridgeName &lt;&gt; null then
		str := app.getErrorString(WeighBridge) &amp; ' ' &amp; self.weighBridgeName &amp; ' ';
		str := str &amp; app.getErrorString(User) &amp; ' ' &amp; self.userId &amp; ' ';
	else
		// CCMS 1319 Changed to include machine id
		//+cnwml2 MSL CCMS 1017  added to include is weight certified
		str := str &amp; app.getErrorString(User) &amp; ' ' &amp; self.userId &amp; ' ' &amp; app.getErrorString(Machine) &amp; ' ' &amp; self.machineId &amp; ' ' &amp; app.getString(Weight_certified) &amp; self.isWeightCertified.getYesNo();
	endif;
	return str;


end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="setFromCMIF_TIUpdateController" id="86efba95-9249-487f-b20e-3c79342d0aef">
        <updating/>
        <source>setFromCMIF_TIUpdateController(_tiUpdateCntrlr : CMIF_TIUpdateController; _passport : CM_Passport) updating;

vars

begin
	
	if _tiUpdateCntrlr = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Null _tiTransCntrl. Contact Developer.');
		return;
	endif;
//	self.driverId 			:= _tiUpdateCntrlr.userCode;	//-08 Jul 2019	NDL	TFS 44965
	self.previousWeight		:= _tiUpdateCntrlr.totalWeight;
	self.weighedAtWeight	:= _tiUpdateCntrlr.newWeight;
	// CCMS 1319
	self.machineId			:= _tiUpdateCntrlr.machineId;
	self.weighBridgeName	:= _tiUpdateCntrlr.weighBridgeName;	//08 Jul 2019	NDL	TFS 44965
	
	self.isWeightCertified := _tiUpdateCntrlr.isWeightCertified;
	inheritMethod(_tiUpdateCntrlr, _passport);
	
end;</source>
        <Parameter name="_tiUpdateCntrlr" type="CMIF_TIUpdateController"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
</Class>
