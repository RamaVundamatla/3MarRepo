    <JadeMethod name="doKeyDown" id="53bb63c2-2247-4b2b-b590-5fa70fbfdcd6">
        <updating/>
        <source>doKeyDown(keyCode: Integer io; shift: Integer) updating;
/*

Purpose:			


Return Value:		


Date		Who		Reason
14 September 2006	cnwer1	Initial creation - PAR#xxxx

*/
vars

begin
	
	inheritMethod(keyCode, shift);


	if keyCode = J_key_F2 then
		self.btnAccept.click(self.btnAccept);
	elseif keyCode = J_key_F6 then
		self.isPrimaryQueue:=false;
		self.setupChangeQueue();
	endif;
epilog

end;</source>
        <Parameter name="keyCode" type="Integer" usage="io"/>
        <Parameter name="shift" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="doLoadTask" id="c9cc5fd1-fe29-4cbe-822a-bb47ae0126de">
        <updating/>
        <source>doLoadTask() updating;
/*

Purpose:			


Return Value:		


Date		Who		Reason
26 October 2006	cnwer1	Initial creation - PAR#xxxx

*/
vars
	_type,
	_containerId,
	_fromLoc,
	_toLoc	: String;
	_ostow,
	_canEdit,
	_toIsVehicle: Boolean;
	theAcceptedRow : Integer;
	obj : Object;
begin
	app.mousePointer	:=	Busy;
	self.clearErrors;
	//app.myVehicleMountedIMVGuiAgent.setIsLoad(self.isLoad);
	//_containerId:=self.tblJobs.
	
	//epr par 21459
	
	theAcceptedRow:=0;
	//epr par 17955 26/9/08
	//nothing to check
	if self.tblJobs.rows =  self.tblJobs.fixedRows then 
		return;
	endif;
	theAcceptedRow:=self.tblJobs.row;
	//if it is the fixed row make it the first item
	if theAcceptedRow = self.tblJobs.fixedRows then
		theAcceptedRow:=self.tblJobs.fixedRows+1;
	endif;
	obj := self.tblJobs.accessRow(theAcceptedRow).itemObject;
	app.myVehicleMountedIMVGuiAgent.setIsLoad(false);
	app.myVehicleMountedIMVGuiAgent.getMoveDetails(_type,_containerId,_fromLoc,_toLoc,_ostow,_canEdit,_toIsVehicle,allErrorMsgs);
	app.myVehicleMountedIMVGuiAgent.doMoveCurrentTaskTI(_containerId,_toLoc , allErrorMsgs);

	
	if self.checkErrors then
		return;
	endif;

epilog
	app.mousePointer	:=	Idle;
end;</source>
    </JadeMethod>
