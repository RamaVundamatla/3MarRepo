    <JadeMethod name="setupForm" id="49be6555-93d7-4d60-be6f-0a3ca88f3c39">
        <updating/>
        <source>setupForm() updating;

// RBarr 20/7/2006 Change tblcurrent column label "Description" to "Location" (to match locode table)
vars

	country		: CM_Country;
	collViews	: EntTableViewSet;
	group		: EntTableGroup;
	def			: EntTableDef;
	view		: EntTableView;

begin

	inheritMethod();
	
	create collViews transient;
	
	self.setNavigatorHeading(self.caption);
	
	self.autoRedraw := true;
	self.tblUserDefs.columns := 3;
	self.tblUserDefs.row := 1;
	self.tblUserDefs.text := 'Definition' &amp; Tab &amp; 'Mandatory' &amp; Tab &amp; 'Default';
	
	self.tblDefs.columns := 1;
	self.tblDefs.row := 1;
	self.tblDefs.text := 'Definition';
	
	foreach group in app.myRoot.myEntTableDataRoot.allEntTableGroups do
		foreach def in group.allEntTableDefsByName do
			foreach view in def.allEntTableViews do
				if not collViews.includes (view) then
					collViews.add(view);
				endif;
			endforeach;
		endforeach;
	endforeach;
	self.cmbView.listCollection (collViews, false, 0);

	self.tblDefs.multiSelect := CM_DataTable.MultiSelect_Simple;
	self.tblDefs.selectionType := CM_DataTable.SelectionType_Row;

	
	self.tblUserDefs.multiSelect := CM_DataTable.MultiSelect_Simple;
	self.tblUserDefs.selectionType := CM_DataTable.SelectionType_Row;
	self.tblUserDefs.accessColumn(2).inputType := CM_DataTable.InputType_CheckBox;
	self.tblUserDefs.accessColumn(3).inputType := CM_DataTable.InputType_TextBox;
	

epilog
	delete collViews;
end;</source>
    </JadeMethod>
    <JadeMethod name="translateForm" id="67a68088-e1af-4874-a1c1-3a2ba6f151de">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0007421, locale);
	btnDeSelect.translateCaption(Xlat_0005048, locale);
	btnDown.translateCaption(Xlat_0005049, locale);
	btnHistory.translateBubbleHelp(Xlat_0005050, locale);
	btnHistory.translateCaption(Xlat_0005051, locale);
	btnSelect.translateCaption(Xlat_0005052, locale);
	btnUp.translateCaption(Xlat_0005053, locale);
	lblView.translateCaption(Xlat_0005054, locale);
end;</source>
    </JadeMethod>
