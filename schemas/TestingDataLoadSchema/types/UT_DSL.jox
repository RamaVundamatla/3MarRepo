    <JadeMethod name="updatePortGroup" id="3255c93a-caae-4e8b-9308-293d14c130d7">
        <source>updatePortGroup(_portGroup : CM_PortGroup);
/*

Purpose:		Update Port Group	

Date		Who		Reason
06/03/2014	cnwma1	Initial creation

*/

vars
	pxyPortGroup 	: CM_PortGroup;
	portGroupDesc	: String;
	ports			: CM_PortByCodeDict;
	

begin
	
	create ports transient;
	beginLoad;
	pxyPortGroup :=_portGroup.pxyCreateUpdateProxy();
	endLoad;
	
	portGroupDesc := _portGroup.description.asStringJMT();
	
	if self.opts.includesKey("portGroupDesc") then
		portGroupDesc := self.opts.str("portGroupDesc");
		_portGroup.allPorts.copy(ports);
		ports.add(app.myRoot.allPortLocodes["AEJEA"]);
	endif;
	
	pxyPortGroup.setProxy(_portGroup.code,
						  portGroupDesc,
						  ports);
	app.myTrxUA.trxUpdatePortGroup(pxyPortGroup,app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
epilog
	delete ports;
	delete pxyPortGroup;

end;</source>
        <Parameter name="_portGroup" type="CM_PortGroup"/>
    </JadeMethod>
    <JadeMethod name="updateProduct" id="7956bf5c-ef08-4a41-ae5a-5c9adb5b6b36">
        <source>updateProduct(_product : Any; _operator: CM_Operator; _cargoType: CM_CargoType);

/*

Purpose:		Update Product Details

Date			Who		Reason
15/05/2015		cnwmh5	Initial creation

*/

vars

	product					: CM_Product;
	pxyProduct				: CM_Product;

begin

	if _product.isKindOf(String) then
		product := _cargoType.allProducts[_operator.code, _product.String];
	elseif _product.isKindOf(CM_Product) then
		product := _product.CM_Product;
	endif;
	
	if product &lt;&gt; null then
		beginLoad;
		pxyProduct := product.pxyCreateUpdateProxy();
		pxyProduct.createProductAttributes();	
		pxyProduct.setForUpdate(product);
		endLoad;
		
		pxyProduct.setPropertyValue("isReefer", self.opts.bool("isReefer").Boolean);	
		
		app.myTrxUA.trxUpdateProduct(pxyProduct, app.myPassport);
		self.assertNoTrxErrors();
	endif;

epilog
	delete pxyProduct;
end;</source>
        <Parameter name="_product" type="Any"/>
        <Parameter name="_operator" type="CM_Operator"/>
        <Parameter name="_cargoType" type="CM_CargoType"/>
    </JadeMethod>
    <JadeMethod name="updateRFIDTag" id="1095036e-ecc0-4ece-8357-305f587ecf0c">
        <source>updateRFIDTag(_rfidTag : CM_RFIDTag io);

/*

Purpose:		Update the RFID Tag

Date			Who		Reason
05/02/2014		cnwmh5	Initial creation

*/

vars

	pxyRFIDTag					: CM_RFIDTag;

begin

	self.assertNotNull(_rfidTag);

	beginLoad;
	pxyRFIDTag := _rfidTag.pxyCreateUpdateProxy();
	endLoad;
	
	if self.opts.includesKey("RFIDDescription") then
		pxyRFIDTag.setPropertyValue("description", self.opts.str("RFIDDescription"));
	endif;
	
	app.myTrxUA.trxUpdateRFIDTag(pxyRFIDTag, self.getTerminal(), app.myPassport);
	self.assertNoTrxErrorsOrWarnings();	

epilog

	delete pxyRFIDTag;

end;</source>
        <Parameter name="_rfidTag" type="CM_RFIDTag" usage="io"/>
    </JadeMethod>
    <JadeMethod name="updateRORORehandle" id="d7fcb53c-589c-4748-85ef-239f1362945b">
        <source>updateRORORehandle(_roroLCs : CM_LCArray; _moveType : Integer; _isLoad : Boolean);
/*
Purpose:		28968	
Date		Who		Reason
30 April 2012	cnwab1	Initial creation
*/

vars
	lc : CM_LocationsController;
begin

	beginTransaction;
	foreach lc in _roroLCs discreteLock do
		lc.CM_VoyageROROController.updateSlotRequestDLRSOB(_isLoad, _moveType, app.myPassport);
	endforeach;

epilog
	commitTransaction;

end;</source>
        <Parameter name="_roroLCs" type="CM_LCArray"/>
        <Parameter name="_moveType" type="Integer"/>
        <Parameter name="_isLoad" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="updateResourceType" id="c542a128-6cca-4112-b3f8-dff163a46848">
        <source>updateResourceType(_resourceType : CM_ResourceType);
/*

Purpose:   Update Resource Type

Date		Who		Reason
01/05/2014 cnwma1	Initial creation
02/11/2022 navds20  ChangeRequest 56635:[54261] EUP - Todo Task Resources Maintenance
23/12/2022 navds21  ChangeRequest 54349[54262]: EUP - Enable Is Mandatory for ToDo Task Resources
*/

vars

	pxyResourceType  : CM_ResourceType;
	toDoTask     	 : CM_ToDoTaskDescBySortKey;
	eventType		 : CM_EventTypeByTypeDict;
	transTypeSet 	 : CM_TransactionTypeSet;
	transRescBrokers : CM_TransSBByTransTypeType;
	
begin

	create toDoTask transient;
	create eventType transient;
	create transTypeSet transient;
	create transRescBrokers transient;
	
	beginLoad;
	pxyResourceType := _resourceType.pxyCreateUpdateProxy();
	endLoad;
	
	_resourceType.allUsageContexts.copy(toDoTask);
	if self.opts.includesKey("TODO") then
		toDoTask.add(self.opts.obj("TODO").CM_ToDoTaskDesc);
	endif;
	
	pxyResourceType.setProxy(_resourceType.code,
							 _resourceType.description &amp;"UP",
							 _resourceType.decimalPlaces,
							 "UPUNIT",
							 _resourceType.hasBeenUsed,
							 _resourceType.isAvailable,
							 toDoTask,
							 eventType,
							 transTypeSet,
							 transRescBrokers,
							 _resourceType.isFromToDateTimeRequired,	//cnwmc5 - 22 Sep 2015 - PAR 36920
							 self.opts.str(JadeCode),					//cnwmc5 - 22 Sep 2015 - PAR 36920
							 null,
							 self.opts.str(UserCode),					//cnwmc5 - 22 Sep 2015 - PAR 36920
							 TODO_TYPE_GROUP_TI,						//02/11/2022 navds20 TFS #56635[54261]
							 false,										//23.12.2022 navds21 TFS #54349[54262]
							 null,										// ### TFS 58761 (60739) 16Nov2023 NAVPW1
							 null										// ### TFS 58761 (60739) 16Nov2023 NAVPW1
							 );
	
	app.myTrxUA.trxUpdateResourceType(pxyResourceType,app.myPassport);
	self.assertNoTrxErrorsOrWarnings();

epilog
	delete pxyResourceType;
	delete  toDoTask;
	delete eventType;
	delete transTypeSet;
	delete transRescBrokers;
end;</source>
        <Parameter name="_resourceType" type="CM_ResourceType"/>
    </JadeMethod>
    <JadeMethod name="updateSealType" id="04bea5ce-2aab-4dc7-86db-8748f6ca9ac6">
        <source>updateSealType(_sealType: CM_SealType; _code: String; _description: String; _cargoTypes: Any; _allowMultipleSealNums: Boolean; _showSealOnCheck: Boolean; _useForTrucks: Boolean) : CM_SealType;
// cnwdw1	 
// Add a seal type
// 08/04/2011	cnwmh5		PAR #27347 - Add cmsEndLoad or endLoad to epilog so that if error occurs it will not leave it in beginLoad state
vars
	proxy, 
	sealType   : CM_SealType;
	cargoTypes: CM_CargoTypeSet;
begin
	
	create cargoTypes transient;
	if _cargoTypes.isKindOf(String) then
		cargoTypes.add(self.getCargoType(_cargoTypes.String));
	else	
		if _cargoTypes &lt;&gt; null then
			_cargoTypes.CM_CargoTypeSet.copy(cargoTypes);
		endif;
	endif;
	
	beginLoad;
	proxy := _sealType.pxyCreateUpdateProxy();
	endLoad;
	proxy.setProxy(_code, _description, cargoTypes, _allowMultipleSealNums, proxy.notAvailableForEntry,  _showSealOnCheck, false, _useForTrucks);
	
	app.myTrxUA.trxUpdateSealType(proxy, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	return _sealType;
epilog
	endLoad;				// 08/04/2011 cnwmh5 #27347
	delete proxy;
	delete cargoTypes;
end;</source>
        <Parameter name="_sealType" type="CM_SealType"/>
        <Parameter name="_code" type="String"/>
        <Parameter name="_description" type="String"/>
        <Parameter name="_cargoTypes" type="Any"/>
        <Parameter name="_allowMultipleSealNums" type="Boolean"/>
        <Parameter name="_showSealOnCheck" type="Boolean"/>
        <Parameter name="_useForTrucks" type="Boolean"/>
        <ReturnType type="CM_SealType"/>
    </JadeMethod>
    <JadeMethod name="updateSecurityRole" id="6b5c0186-f5d2-43d1-96bb-8524128a0fc6">
        <source>updateSecurityRole(_securityRole : Any io);

/*

Purpose:		Update Security Role

Date			Who		Reason
10/02/2014		cnwmh5	Initial creation

*/

vars

	pxySecurityRole						: CM_SecurityRole;
	securityRole						: CM_SecurityRole;
	permissionAgent						: CM_PermissionAgent;
	
begin

	if _securityRole.isKindOf(String) then
		securityRole := app.myRoot.allRoles[_securityRole.String].CM_SecurityRole;
	else
		securityRole := _securityRole.CM_SecurityRole;
	endif;
	
	if securityRole = null then
		return;
	elseif securityRole.isKindOf(CM_SecurityRoleSystem) then
		beginLoad;
		pxySecurityRole := securityRole.CM_SecurityRoleSystem.pxyCreateUpdateProxy();
		endLoad;
	elseif securityRole.isKindOf(CM_SecurityRoleTerminal) then
		beginLoad;
		pxySecurityRole := securityRole.CM_SecurityRoleTerminal.pxyCreateUpdateProxy();
		endLoad;
	endif;
	
	create permissionAgent transient;
		
	if pxySecurityRole.mySecurityRoleVisibility &lt;&gt; null then
		pxySecurityRole.mySecurityRoleVisibility.setPropertyValue("availableToShippingCompany", false);
	endif;
	
	app.myTrxUA.trxUpdateSecurityRole(pxySecurityRole, permissionAgent, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();

epilog

	delete permissionAgent;
	delete pxySecurityRole;

end;</source>
        <Parameter name="_securityRole" type="Any" usage="io"/>
    </JadeMethod>
    <JadeMethod name="updateShippingAgent" id="1680a570-b7a0-4a14-a157-da2b7a5e6b78">
        <source>updateShippingAgent(_shippingAgent : CM_ShippingAgent);
/*

Date		Who		Reason
15/052014	cnwma1	Initial creation

*/

vars
	pxShippingAgent : CM_ShippingAgent;
	desc			: String;
begin

	if _shippingAgent = null then		
		return;
	endif;
	
	beginLoad;
	pxShippingAgent := _shippingAgent.pxyCreateUpdateProxy();
	endLoad;
	
	pxShippingAgent.setProxy(_shippingAgent.code,
							 _shippingAgent.description&amp;"_UP",
							 _shippingAgent.notAvailableForEntry);
							 
	app.myTrxUA.trxUpdateShippingAgent(pxShippingAgent,app.myPassport);
epilog
	endLoad;
	delete pxShippingAgent;
end;</source>
        <Parameter name="_shippingAgent" type="CM_ShippingAgent"/>
    </JadeMethod>
    <JadeMethod name="updateShippingLine" id="fa13f4fe-a792-48bd-8a9c-f9958aae96a6">
        <source>updateShippingLine(_shippingLine : CM_ShippingLine);
/*

Purpose:	Update Shipping Line			

Parameters:			

Return Value:		

Date		Who		Reason
24/03/2014	cnwma1	Initial creation
//	09-06-2022	navtnr20	53195: EUP - GEN/REP/INB - Additional Cargo Field – Shipping Line - Portschema

*/

vars

	pxyShippingLine 	: CM_ShippingLine;
	shippingLineDesc	: String;
	shippingLineColor	: Integer;//53195
begin
	beginLoad;
	pxyShippingLine := _shippingLine.pxyCreateUpdateProxy();
	endLoad;
	
	shippingLineDesc := _shippingLine.description.asStringJMT();
	shippingLineColor := _shippingLine.colour;		//09-06-2022	navtnr20 53195 
	
	if self.opts.includesKey("ShippingLineDesc") then
		shippingLineDesc := self.opts.str("ShippingLineDesc");
	endif;
	
	if self.opts.includesKey("ShippingLineColor") then				//09-06-2022	navtnr20 53195
		shippingLineColor := self.opts.str("ShippingLineColor").Integer;	//09-06-2022	navtnr20 53195
	endif;
	
	pxyShippingLine.setProxy(_shippingLine.code,
								  shippingLineDesc,
								  false ,
								  shippingLineColor,
								  _shippingLine.myDebtor);		//09-06-2022	navtnr20 53195  
								  
	app.myTrxUA.trxUpdateShippingLine(pxyShippingLine, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();		
 
epilog
	endLoad;
	delete pxyShippingLine;
end;</source>
        <Parameter name="_shippingLine" type="CM_ShippingLine"/>
    </JadeMethod>
    <JadeMethod name="updateSlotAttributes" id="b358eb11-d6e6-4bf0-9976-2eaff2b0bc4d">
        <source>updateSlotAttributes(_theSlots : CM_SlotControllerSet; _theAttribute : String);

/*

Purpose:		Update Slot Attributes

Date			Who		Reason
19/02/2014		cnwmh5	Initial creation

*/

vars
	
	theEditions 						: CM_ObjectByOidEditionDict;
	
begin

	if _theSlots.isEmpty() or _theAttribute = null then
		return;
	endif;
	
	create theEditions transient;
	_theSlots.copyNoDuplicates(theEditions, false);
	
	app.myTrxUA.trxUpdateSlotDefnsAttribute(_theSlots, theEditions, _theAttribute, app.myPassport);	
	self.assertNoTrxErrorsOrWarnings();
	
epilog

	delete theEditions;

end;</source>
        <Parameter name="_theSlots" type="CM_SlotControllerSet"/>
        <Parameter name="_theAttribute" type="String"/>
    </JadeMethod>
    <JadeMethod name="updateStevedore" id="4433111f-e1f5-4f39-8f4b-2724c3f02dc9">
        <source>updateStevedore(_stevedore : CM_Stevedore);

/*

Purpose:		Update Stevedore

Date			Who		Reason
28/02/2014		cnwmh5	Initial creation
30/05/2019		jlgdap1	TFS 44554 AAT Stevedore Data Access
*/

vars

	pxyStevedore						: CM_Stevedore;
	
	loadState							: Boolean;
	description							: String;

begin

	app.cmsBeginLoad(loadState);
	pxyStevedore := _stevedore.pxyCreateUpdateProxy();
	app.cmsEndLoad(loadState);
	
	description := _stevedore.description;
	if self.opts.includesKey("Description") then
		description := self.opts.str("Description");
	endif;
	
	pxyStevedore.setProxy(_stevedore.code, 
		description,
		_stevedore.notAvailableForEntry,
		_stevedore.myDebtor);						// TFS 44554
		
	app.myTrxUA.trxUpdateStevedore(pxyStevedore, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();

epilog

	app.cmsEndLoad(loadState);
	
	delete pxyStevedore;

end;</source>
        <Parameter name="_stevedore" type="CM_Stevedore"/>
    </JadeMethod>
    <JadeMethod name="updateStopsTable" id="a7677468-e93e-4a79-a440-aca85568c71b">
        <source>updateStopsTable(
	_stopsTable		: CM_StopsTable io;
	_selectedTypes	: CM_CargoBOLTypeSet);
// 08/04/2011	cnwmh5		PAR #27347 - Add cmsEndLoad or endLoad to epilog so that if error occurs it will not leave it in beginLoad state

vars
	proxyStopsTable			: CM_StopsTable;
	passport				: CM_Passport;

begin
	passport	:= app.myPassport;
	
	beginLoad;
	proxyStopsTable	:= _stopsTable.pxyCreateUpdateProxy();
	endLoad;
	
	proxyStopsTable.setProxy(	self.opts.bool( ETRow_RequiresInfo ),
								_stopsTable.code,
								_stopsTable.heading,
								_stopsTable.shortHeading,
								self.opts.int( ETRow_CustomsInfoEntry ),
								_stopsTable.id,
								_selectedTypes,
								self.opts.bool( ETRow_IsNotAvailableForEntry ),
								self.opts.bool( ETRow_AllowClearanceExpiryDate ),
								app.myRoot,
								self.opts.str( JadeCode ),
								self.opts.str( UserCode ),
								null						// ### TFS 61382 (61534) 01Dec2023 NAVPW1
								);
	
	app.myTrxUA.trxUpdateStopsTable( proxyStopsTable, passport );
	self.assertTrueMsg( passport.trxCompletedOK(), passport.getAllErrorsWarningsAsString() );
	
epilog
	endLoad;				// 08/04/2011 cnwmh5 #27347
	delete proxyStopsTable;
	
end;
</source>
        <Parameter name="_stopsTable" type="CM_StopsTable" usage="io"/>
        <Parameter name="_selectedTypes" type="CM_CargoBOLTypeSet"/>
    </JadeMethod>
    <JadeMethod name="updateStopsTableTemplate" id="dae02db7-93d0-4f5c-9f11-db88dc4533df">
        <source>updateStopsTableTemplate(
	_stopsTableTemplate	: CM_StopTableTemplate io);
// 08/04/2011	cnwmh5		PAR #27347 - Add cmsEndLoad or endLoad to epilog so that if error occurs it will not leave it in beginLoad state
// 05/08/2011	cnwmh5		Chnage to use classes version of opts
vars
	proxyStopsTableTemplate	: CM_StopTableTemplate;
	passport				: CM_Passport;

begin
	passport	:= app.myPassport;
	
	beginLoad;
	proxyStopsTableTemplate	:= _stopsTableTemplate.pxyCreateUpdateProxy();
	endLoad;
	
	// careful of order of booleans
	proxyStopsTableTemplate.setProxy(	self.opts.intArray( ETRow_CheckStopAreas ),
										self.opts.intArray( ETRow_SetStopAreas ),
										self.opts.intArray( ETRow_ProcessStopAreas ),
										null,									// Hold Voyages
										self.opts.bool( ETRow_IsChildOnly ),
										self.opts.bool( ETRow_IsChildIgnore ),
										self.opts.bool( ETRow_IsCoastalOnly ),
										self.opts.bool( ETRow_IsCoastalIgnore ),
										self.opts.bool( ETRow_IsTranshipOnly ),
										self.opts.bool( ETRow_IsTranshipIgnore ),
										self.opts.bool( ETRow_IsMT ),
										self.opts.bool( ETRow_IsFull ) );
	
	app.myTrxUA.trxUpdateStopTableTemplate( proxyStopsTableTemplate, passport );
	self.assertTrueMsg( passport.trxCompletedOK(), passport.getAllErrorsWarningsAsString() );
	
epilog
	endLoad;				// 08/04/2011 cnwmh5 #27347
	delete proxyStopsTableTemplate;
	
end;
</source>
        <Parameter name="_stopsTableTemplate" type="CM_StopTableTemplate" usage="io"/>
    </JadeMethod>
    <JadeMethod name="updateSubBlockStack" id="172e5870-e6d7-4c14-a5be-bd5a629c1df5">
        <source>updateSubBlockStack(_subBlockLocations : CM_LCArray; _subBlockStack : CM_SubBlockStack io);

/*

Purpose:		Update a Sub Block Stack

Date			Who		Reason
07/02/2014		cnwmh5	Initial creation

*/

vars

	theRegion						: CMIF_GridTARegion;
	location						: CM_LocationsController;

begin

	create theRegion transient;
	
	foreach location in _subBlockLocations do
		theRegion.allLocationControllers.add(location);
	endforeach;
	theRegion.id := theRegion.allLocationControllers.first.getID();
	theRegion.myGridArea := _subBlockStack.myParent;
	theRegion.isStockControlled := true;
	
	if self.opts.includesKey("SubBlockColour") then
		theRegion.colour := self.opts.int("SubBlockColour");
	endif;
	
	theRegion.idOriginal := _subBlockStack.id;
	
	app.myTrxUA.trxUpdateSubBlockStack(theRegion, _subBlockStack, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
epilog

	delete theRegion;

end;</source>
        <Parameter name="_subBlockLocations" type="CM_LCArray"/>
        <Parameter name="_subBlockStack" type="CM_SubBlockStack" usage="io"/>
    </JadeMethod>
    <JadeMethod name="updateSubTerminal" id="c4c50f7f-bdc3-42c7-87cf-72cd717e714f">
        <source>updateSubTerminal(_subTerminal : CM_SubTerminal);
/*

Purpose: Update SubTerminal			

Date		Who		Reason
23/04/2014	cnwma1	Initial creation

*/

vars
	pxySubTerminal  :CM_SubTerminal;
	description	    :String;

begin
	
	//create pxySubTerminal transient;
	beginLoad;
	pxySubTerminal := _subTerminal.pxyCreateUpdateProxy();
	endLoad;
	
	description := _subTerminal.description;
	if self.opts.includesKey("Description") then
		description := self.opts.str("Description");
	endif;
	
	pxySubTerminal.setProxy(_subTerminal.code,
							description,
							_subTerminal.type,
							_subTerminal.myTerminal,
							_subTerminal.getMyBank,	//_bank : CM_Bank //03 Dec 2014	NDL	Par 35295
							_subTerminal.allAllowedEditAvailGrades,
							_subTerminal.allAllowedEditToDoTasks);
	
	app.myTrxUA.trxUpdateSubTerminal(pxySubTerminal,app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
							
	
epilog
	delete pxySubTerminal;
end;</source>
        <Parameter name="_subTerminal" type="CM_SubTerminal"/>
    </JadeMethod>
    <JadeMethod name="updateSubTerminalOptions" id="08f72115-7901-4aee-8a29-a1a29c7178bd">
        <source>updateSubTerminalOptions();
/*

Purpose: Update Terminal subTerminal's Options			

Date		Who		Reason
23/04/2014	cnwma1	Initial creation

*/

vars
	 terminalObj		: CM_Terminal;
	 subTerminal		: CM_SubTerminal;
	 
begin
	
	terminalObj	:=	self.getTerminal;
	 
	subTerminal := terminalObj.getConfig(MySubTerminalForStorageFull).CM_SubTerminal;
	if self.opts.includesKey("StorageFull") then
		subTerminal := self.opts.obj("StorageFull").CM_SubTerminal;
	endif;	 
	 
	app.writeLog(class.name &amp; '::' &amp; method.name &amp; Tab &amp; 'terminal: ' &amp; terminalObj.code &amp; Tab &amp; 
		self.opts.obj("StorageFull").CM_SubTerminal.String &amp; Tab &amp; Tab &amp; subTerminal.String &amp; Tab &amp; Tab &amp; 
		self.opts.includesKey("StorageFull").String, LogINFO);
	 
	  app.myTrxUA.trxUpdateSubTerminalOptions(terminalObj,
											terminalObj.getConfig(IsSubTerminalsOn).Boolean,
											terminalObj.getConfig(IsSubTerminalAreaDefined).Boolean,
											terminalObj.getConfig(MySubTerminalForExportFull).CM_SubTerminal,
											terminalObj.getConfig(MySubTerminalForExportMTY).CM_SubTerminal,
											terminalObj.getConfig(MySubTerminalForImportFull).CM_SubTerminal,
											terminalObj.getConfig(MySubTerminalForImportMTY).CM_SubTerminal,
											subTerminal,//terminalObj.getConfig(MySubTerminalForStorageFull).CM_SubTerminal,
											terminalObj.getConfig(MySubTerminalForStorageMTY).CM_SubTerminal,
											terminalObj.getConfig(MySubTerminalForImportGen).CM_SubTerminal,
											terminalObj.getConfig(MySubTerminalForExportGen).CM_SubTerminal,
											terminalObj.getConfig(MySubTerminalForStorageGen).CM_SubTerminal,
											terminalObj.getConfig(MySubTerminalForOther).CM_SubTerminal,
											terminalObj.getConfig(MySubTerminalForSourceBulkRoad).CM_SubTerminal,
											terminalObj.getConfig(MySubTerminalForSourceBulkRail).CM_SubTerminal,
											terminalObj.getConfig(MySubTerminalForSourceBulkShip).CM_SubTerminal,
											terminalObj.getConfig(MySubTerminalForSourceBulkPack).CM_SubTerminal,
											terminalObj.getConfig(MySubTerminalForTargetBulk).CM_SubTerminal,
											terminalObj.getConfig(MySubTerminalForBOLIn).CM_SubTerminal,
											app.myPassport);
											
   self.assertNoTrxErrorsOrWarnings();
   
	 
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="updateSystemAlertType" id="db0a8605-7e0c-4ead-a7fc-fa68f0923b6f">
        <source>updateSystemAlertType(_sysAlertType : CM_SystemAlertType);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
13 May 2010	cnwmd1	Initial creation
08/04/2011	cnwmh5	PAR #27347 - Add cmsEndLoad or endLoad to epilog so that if error occurs it will not leave it in beginLoad state
05/08/2011	cnwmh5	Change to use classes version of opts
*/

vars
	proxySysAlertType : CM_SystemAlertType;
	passport : CM_Passport;
	emailAdd : CM_EmailAddress2;
	emailName : String;
	emails : CM_EmailEntityByTypeNameDict;
begin
	passport	:= app.myPassport;
	
	beginLoad;
	proxySysAlertType	:= _sysAlertType.pxyCreateUpdateProxy();
	endLoad;
	
	emailName := self.opts.str( ETRow_Email );
	if emailName &lt;&gt; null then
	
		emailAdd := app.myRoot.allEmailEntities[Email_Address, emailName].CM_EmailAddress2;
		
		create emails transient;
		if not emails.includes(emailAdd) then
			emails.add(emailAdd);
		endif;
	endif;
	
	proxySysAlertType.setProxy(_sysAlertType.type,
								_sysAlertType.name,
								_sysAlertType.description,
								_sysAlertType.area,
								_sysAlertType.myRoot,
								emails);
						
	app.myTrxUA.trxUpdateSystemAlertType( proxySysAlertType, passport );
	self.assertTrueMsg( passport.trxCompletedOK(), passport.getAllErrorsWarningsAsString() );
								
epilog
	endLoad;				// 08/04/2011 cnwmh5 #27347
	delete emails;
	delete proxySysAlertType;
end;</source>
        <Parameter name="_sysAlertType" type="CM_SystemAlertType"/>
    </JadeMethod>
    <JadeMethod name="updateTI" id="80d14cd9-82db-46e4-bd23-30222ca50165">
        <source>updateTI(_ti: CM_TrackedItem);
//13 November 2008	cnwdw1	
//
// 29/07/2011	cnwmh5	Change to use classes opts rather than a locally create and passed version
// 11/06/2015	cnwdap1	PAR #36421 Changed signature to CM_TIHazard::setProxy
// 30/06/2017	cnwdap1	TFS 4492 SNO VERMAS Changes
vars
	pxyTI: CM_TrackedItem;
	cargoType: Integer;
	booking: CM_BookingRef;
	voyage		: CM_Voyage;
	hazard			: CM_TIHazard;
	subT : CM_SubTerminal;
	skipErrorCheck : Boolean;

begin
	pxyTI := app.createUpdateProxy(_ti).CM_TrackedItem;
	pxyTI.zSetPxyCustomExportEntryNumber(self.opts.str("CustomsExportEntryNumber"), app.myPassport);
	pxyTI.zSetPxyCustomsEntryNumber(self.opts.str("CustomsEntryNumber"));
	if self.opts.includesKey("Booking") then
		booking := self.opts.obj("Booking").CM_BookingRef;
		pxyTI.setAttributeFromDisplayName(ETRow_BookingReference, booking);
		pxyTI.setAttributeFromDisplayName(ETRow_BookingReferenceItem, self.opts.obj("BookingItem"));
		pxyTI.setMyVoyage(booking.myVoyage, app.myPassport);
		pxyTI.setDestinationPort(booking.destinationPort);
		pxyTI.setDischargePort(booking.dischargePort);	
	endif;
	if self.opts.includesKey(UTTI_DischargePort) then					// 15/04/2011 cnwmh5 Added
		pxyTI.setDischargePort(self.opts.str(UTTI_DischargePort));
	endif;
	
	if self.opts.includesKey(UTTI_AvailabilityGrade) then				// 09/11/2016 cnwmk3
		pxyTI.CM_Container.setPropertyValue(CM_Container::availabilityGrade.name, self.opts.int(UTTI_AvailabilityGrade));
	endif;
	
	if self.opts.includesKey("Hazard") then
		create hazard transient;
		hazard.setProxy(self.opts.str("Hazard"), self.opts.strDef("HazardDescription", "Hazardous"),
						//"", pxyTI, false);			// PAR #36421
						"", pxyTI, false, null,			// PAR #36421
						NULL_TEMPERATURE, MarinePollutant_Null, null);	// TFS 2842
	endif;
		
	if self.opts.includesKey("OverDimension") then
		pxyTI.setIsOverDimensions(self.opts.bool("OverDimension"));
	endif;

	if self.opts.includesKey('IMEXStatus') then							// 15/04/2011 cnwmh5 Added
		pxyTI.setImExStatus(self.opts.int('IMEXStatus').Integer);
	endif;
	if self.opts.includesKey("State") then								// 15/04/2011 cnwmh5 Added
		pxyTI.setStatePxy(self.opts.int("State"));
	endif;
	if self.opts.includesKey("ISOType") then
		pxyTI.setISOType(self.opts.str("ISOType"));
	endif;
	if self.opts.includesKey("TotalWeight") then
		pxyTI.zSetPxyTotalWeight(self.opts.int("TotalWeight"));
	endif;
	if self.opts.includesKey("TareWeight") then
		pxyTI.setWeightTare(self.opts.int("TareWeight"));
	endif;
	if self.opts.includesKey('OperatorPin') then
		pxyTI.setOperatorImportReleasePIN(self.opts.str('OperatorPin'));
	endif;
	if self.opts.includesKey(CM_TrackedItem::operatorCode.name) then
		pxyTI.setOperatorCode(self.opts.str(CM_TrackedItem::operatorCode.name), app.myPassport);
	endif;
	if self.opts.includesKey("ReadyToShip") then
		pxyTI.zSetPxyReadyToShip(self.opts.bool("ReadyToShip"));
	endif;
	if self.opts.includesKey("Consignee") then							// 16/12/2011 cnwmh5
		pxyTI.zSetPxyConsignee(self.opts.str("Consignee"));
	endif;
	if self.opts.includesKey("Consignor") then							// 17/6/2013 cnwjre1
		pxyTI.zSetPxyConsignor(self.opts.str("Consignor"));
	endif;
	if self.opts.includesKey("FreightForwarder") then					// 17/6/2013 cnwjre1
		pxyTI.zSetPxyFreightFowarderCode(self.opts.str("FreightForwarder"));
	endif;
	if self.opts.includesKey("Operator") then							// 17/6/2013 cnwjre1
		pxyTI.zSetPxyOperator(self.opts.obj("Operator").CM_Operator);
	endif;
	if self.opts.includesKey("Voyage") then
		voyage := self.opts.obj("Voyage").CM_Voyage;
		pxyTI.zSetPxyVoyage(voyage, voyage.code);
	endif;
	if self.opts.includesKey("Commodity") then
		pxyTI.setCommodity(self.opts.str("Commodity"));
	endif;
	if self.opts.includesKey(UTTI_CustomsAgent) then
		if self.opts.str(UTTI_CustomsAgent) &lt;&gt; null then
			pxyTI.zSetPxyCustomsAgent(app.myRoot.allCustomsAgents[self.opts.str(UTTI_CustomsAgent)]);
		endif;
	endif;

	if self.opts.includesKey("Colour") then
		if pxyTI.isKindOf(CM_BreakBulkGeneric) then
			pxyTI.CM_BreakBulkGeneric.setColour(self.opts.str("Colour"));
		endif;
	endif;
	
	if self.opts.includesKey("Mark") then
		pxyTI.setMark(self.opts.str("Mark"));
	endif;
	
	//cnwmc5 - 22 April 2014
	if self.opts.includesKey("DischargePort") then
		pxyTI.setDischargePort(self.opts.str("DischargePort"));
	endif;

	if self.opts.includesKey("SpecialLiftUp") then // 03/03/2014 Added
		pxyTI.zSetPxySpecialLifts(self.opts.obj("SpecialLiftUp").CM_SpecialLiftByCodeDict);
	endif;
		
	if self.opts.includesKey("TotalQuantity") then			// 29/07/2014 cnwmh5
		pxyTI.setTotalQuantity(self.opts.int("TotalQuantity"));
	endif;	
	if self.opts.includesKey("contentsStatus") and
	   pxyTI.isKindOf(CM_Container) then
		pxyTI.CM_Container.zSetPxyContentsStatus(self.opts.int("contentsStatus"));
	endif;
	if self.opts.includesKey(UTTI_BOL) then				// 17/02/2015 cnwjre1
		pxyTI.setBOL(self.opts.str(UTTI_BOL));
	endif;
	
	if self.opts.includesKey("WashDT") then				// 18/02/2015 cnwmh5
		pxyTI.setPropertyValue("washDT", self.opts.str("WashDT").TimeStamp);
	endif;
	
	if self.opts.includesKey("Temperature") then	//05 May 2015	NDL	Par 36154	
		pxyTI.setTemperature(self.opts.int("Temperature"));
	endif;
	
	if self.opts.includesKey("CargoLength") then		// 04/05/2015 cnwmh5
		pxyTI.zSetPxyLength(self.opts.real("CargoLength"));
	endif;
	
	if self.opts.includesKey("CargoWidth") then		// 05/05/2015 cnwmh5
		pxyTI.zSetPxyWidth(self.opts.real("CargoWidth"));
	endif;
	
	if self.opts.includesKey("CargoHeight") then		// 05/05/2015 cnwmh5
		pxyTI.zSetPxyHeight(self.opts.real("CargoHeight"));
	endif;
	
	if self.opts.includesKey("SubTerminal") then
		subT := self.opts.obj("SubTerminal").CM_SubTerminal;
		pxyTI.zSetPxySubTerminal(subT);
	endif;
	
	if self.opts.includesKey("ExternallyMonitored") then						// 19/11/2015 cnwmh5
		if _ti.isReefer then
			pxyTI.myReeferProperties.setExternalMonitoring(self.opts.bool("ExternallyMonitored"));
		endif;
	endif;
	
	//01 Jun 2016	NDL	TFS 2022
	if self.opts.includesKey("Carrier") then
		pxyTI.setCarrier(self.opts.str("Carrier"));
	endif;
	if self.opts.includesKey("ReleaseCarrier") then
		pxyTI.setReleaseCarrier(self.opts.str("ReleaseCarrier"));
	endif;
	if self.opts.includesKey("CustomsAgent") then
		pxyTI.setCustomsAgent(self.opts.obj("CustomsAgent").CM_CustomsAgent);
	endif;
	
	// 07/11/2016 cnwmh5
	if self.opts.includesKey("TotalVolume") then
		pxyTI.setMyTotalVolume(self.opts.dec("TotalVolume"));
	endif;
	if self.opts.includesKey("TotalWeightWithoutTrans") then
		pxyTI.setTotalWeightWithoutTrans(self.opts.dec("TotalWeightWithoutTrans"));
	endif;
	
	// 17/06/2016 cnwmh5 - add vgm stuff
	if self.opts.includesKey("IsWeightCertified") then  
		pxyTI.setPropertyValue("isWeightCertified", self.opts.bool("IsWeightCertified"));
	endif;	
	if self.opts.includesKey("WeightCertBy") then   
		//pxyTI.setPropertyValue("weightCertifiedName", self.opts.str("WeightCertBy"));				// TFS 4492
		pxyTI.setMyVGMDetails(	pxyTI.weightCertifiedReference, self.opts.str("WeightCertBy"),		// TFS 4492
								null, null, null, null, null, null, 								// TFS 4492
								null, null, null, null, null, null	);								// TFS 4492
	endif;
	if self.opts.includesKey("AuthorisedPerson") then   
		//pxyTI.setPropertyValue("weightCertifiedReference", self.opts.str("AuthorisedPerson"));	// TFS 4492
		pxyTI.setMyVGMDetails(	self.opts.str("AuthorisedPerson"), pxyTI.weightCertifiedName,		// TFS 4492
								null, null, null, null, null, null, 								// TFS 4492
								null, null, null, null, null, null	);								// TFS 4492
	endif;

	app.myTrxUA.trxUpdateTrackedItem(pxyTI,	null, TI_UPDMODE_NORMAL, null, app.myPassport);
	//self.assertTrueMsg(app.myPassport.trxCompletedOK(), app.myPassport.getAllErrorsWarningsAsString());
	if self.opts.includesKey("DontDoAssert") then
		skipErrorCheck := self.opts.bool("DontDoAssert").Boolean;
	endif;
	
	if skipErrorCheck then
		return;
	endif;
	
	assertNoTrxErrorsOrWarnings();
epilog
	delete pxyTI;
end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="updateTIBooking" id="3b1efde3-9f25-4c0e-9ecd-6194881ed7da">
        <source>updateTIBooking(_ti: CM_TrackedItem; _booking: CM_BookingRef input; _bookingItem: CM_BookingRefItem input);
//11 August 2009	cnwdw1	
//
vars
	bookingAgent: CM_BookingAgent;
	tis: CM_TISet;
begin
	create bookingAgent transient;
	create tis transient;
	tis.add(_ti);
	self.ignoreTrxWarnings(true);
	bookingAgent.moveTIsToBookingItem(tis, _booking, _bookingItem);
	self.assertNoTrxErrorsOrWarnings();

epilog
	delete bookingAgent;
	delete tis;
end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_booking" type="CM_BookingRef" usage="input"/>
        <Parameter name="_bookingItem" type="CM_BookingRefItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="updateTIConnection" id="ca281403-8609-47d0-afb4-e2ff84783aeb">
        <source>updateTIConnection(_ti : CM_TrackedItem input;  _noCharge, _connect : Boolean; _connectTime : TimeStamp; _powerPoint : CM_GapController) : Boolean;
/* copy of MobileServerSchema CM_MobileAgent::updateTIConnection which takes the connection date/time as a parameter
Connects or disconnects a Tracked Item from _powerPoint

*/

vars
	connectParams			: CMIF_ConnectParams;
	loadState				: Boolean;
	connectTimeStamp		: TimeStamp;
	txn						: CM_TITransaction;
	action, result			: Integer;
begin

	if _ti = null then
		return false;
	endif;
	
	// Check to see if this container has been connected/disconnected already elsewhere
	if _ti.isConnected = _connect then
		return false;
	endif;
	
	on CM_Exception do app.validationExHandler(exception, app.myPassport);
	app.setContinueCMExceptions(true);
	app.myPassport.clearErrorsWarnings();
	
	if _connect then
		action := ACTION_CONNECT;
	else
		action := ACTION_DISCONNECT;
	endif;
	connectTimeStamp := _connectTime;

	create connectParams transient;

	app.cmsBeginLoad(loadState);
	connectParams.allTrackedItems.add(_ti.pxyCreateUpdateProxy());
	app.cmsEndLoad(loadState);
	
	//check time stamp will be after the last txn on the _ti
	txn := _ti.allTransactions.last;
	if txn &lt;&gt; null
	and txn.dateTime &gt; connectTimeStamp then
		if txn.dateTime.date = connectTimeStamp.date
		and txn.dateTime.time.hour = connectTimeStamp.time.hour
		and txn.dateTime.time.minute = connectTimeStamp.time.minute then
			//bump it by 1
			connectTimeStamp.setTime(txn.dateTime.time.addSeconds(1));
		endif;
	endif;

	connectParams.dateTime := connectTimeStamp;
	connectParams.noCharge := _noCharge;
	connectParams.myTerminal := _ti.myTerminal;
//	the following is set in the trx when allTrackedItems is used or below for COUs	
	connectParams.myTrackedItem := _ti;
	if connectParams.myTrackedItem &lt;&gt; null then
		connectParams.locationsController := connectParams.myTrackedItem.myPrimaryActualLocation;
	endif;

	connectParams.userId := app.getMyUserCode();
	connectParams.action := action;
	
	connectParams.gapController := _powerPoint; 
	
// All of these below are not set anywhere in this app. TODO: Check that default values are alright
	connectParams.urNumber := null;
	connectParams.radioTelemetryIgnoreWarnings := true;
	connectParams.radioTelemetryUser := false;
		
	// Do the Connect/disconnect
	if action = ACTION_CONNECT then
		app.myTrxUA.trxUpdateConnect(connectParams, app.myPassport);	
	else
		app.myTrxUA.trxUpdateDisconnect(connectParams, app.myPassport);	
	endif;
	self.assertNoTrxErrorsOrWarnings();
	
epilog	
	app.cmsEndLoad(loadState);
	if connectParams &lt;&gt; null then
		connectParams.allTrackedItems.purge();
		delete connectParams;
	endif;

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem" usage="input"/>
        <Parameter name="_noCharge" type="Boolean"/>
        <Parameter name="_connect" type="Boolean"/>
        <Parameter name="_connectTime" type="TimeStamp"/>
        <Parameter name="_powerPoint" type="CM_GapController"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="updateTIDamage" id="2df6134c-14a9-44cc-9d60-fc31b1a0f943">
        <source>updateTIDamage(_ti : CM_TrackedItem io; _damageCode, _damagePosition : String; _severity : CM_DamageSeverity);

/*

Purpose:		Update TI's Damage

Date			Who		Reason
07/02/2014		cnwmh5	Initial creation
11 July 2022	navak20	TFS 53862 EUP - WMS - Damage Recording Extra Details
*/

vars

	pxyTI						: CM_TrackedItem;
	damageObj					: CM_DamageInstance;
	damageDefObj				: CM_DamageDefinitionCode;
	damagePosition				: CM_DamagePosition;
	
	severity					: CM_DamageSeverity;		// 11.07.2022 navak20 TFS 53862
	damageNotes					: String;
	remarks 					: String;
	isNewDamage,
	isRepaired					: Boolean;	
	quantity					: Integer;
	
begin

	beginLoad;
	pxyTI := _ti.pxyCreateUpdateProxy();
	endLoad;

	pxyTI.setDamaged(true);
	
	if self.opts.includesKey("DamageNotes") then
		pxyTI.setRemarks(self.opts.str("DamageNotes"), false);
	endif;
	
	damagePosition :=  app.myRoot.allDamagePositionsByCode[_damagePosition];
	damageDefObj := app.myRoot.allDamageDefinitionCodes[_damageCode];
	
	if self.opts.includesKey("IsNewDamage") then
		isNewDamage := self.opts.bool("IsNewDamage");
	endif;
	
	if self.opts.includesKey("isRepaired") then
		isRepaired := self.opts.bool("IsRepaired");
	endif;
	
	if self.opts.includesKey("Quantity") then
		quantity := self.opts.int("Quantity");
	endif;
	
	create damageObj transient;
	damageObj.setProxy(pxyTI, 
		null, 
		damageDefObj, 
		damagePosition,
		remarks,
		isNewDamage,
		quantity,
		_severity,
		null,	//_locationStr 	: String	01 Mar 2016	NDL	TFS 1593
		null, null, null, null, null, null, null, null, null	//July 1, 2022 navak20 TFS 53862
		);

	app.myTrxUA.trxUpdateTIDamage(pxyTI, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();

epilog

	endLoad;
	
	delete damageObj;
	delete pxyTI;

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem" usage="io"/>
        <Parameter name="_damageCode" type="String"/>
        <Parameter name="_damagePosition" type="String"/>
        <Parameter name="_severity" type="CM_DamageSeverity"/>
    </JadeMethod>
    <JadeMethod name="updateTIDimensions" id="c2818692-ba30-4dca-a5bb-a863fa2f8a9f">
        <source>updateTIDimensions(_ti : CM_TrackedItem io; _overWidthLeft, _overWidthRight, _overLengthRear, _overLengthFront, _overHeight : Decimal; 
	_toDoTaskCode : Integer; _addingToDo : Boolean);

/*

Purpose:		Update Ti's Dimensions

Date			Who		Reason
10/02/2014		cnwmh5	Initial creation

*/

vars

	pxyTI					: CM_TrackedItem;
	addCompRemTodo		: Integer;	// 1 = add, 2 = complete, 3 = remove 16 Mar 2016	NDL TFS 1673

begin

	beginLoad;
	pxyTI := _ti.pxyCreateUpdateProxy();
	endLoad;
	
	//existing default behaviour
	addCompRemTodo := 3;
	if not _addingToDo then
		addCompRemTodo := 1;
	endif;
	
	pxyTI.CM_Container.setOverWidthLeft(_overWidthLeft, null, app.myPassport);
	pxyTI.CM_Container.setOverWidthRight(_overWidthRight, null, app.myPassport);
	pxyTI.CM_Container.setOverLengthRear(_overLengthRear, null, app.myPassport);
	pxyTI.CM_Container.setOverLengthFront(_overLengthFront, null, app.myPassport);
	pxyTI.CM_Container.setOverHeight(_overHeight, null, app.myPassport);
	app.myTrxUA.trxUpdateTIDimensionsToDo(pxyTI, _toDoTaskCode, addCompRemTodo, null, TI_UPDMODE_NORMAL, null, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
epilog

	delete pxyTI;

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem" usage="io"/>
        <Parameter name="_overWidthLeft" type="Decimal"/>
        <Parameter name="_overWidthRight" type="Decimal"/>
        <Parameter name="_overLengthRear" type="Decimal"/>
        <Parameter name="_overLengthFront" type="Decimal"/>
        <Parameter name="_overHeight" type="Decimal"/>
        <Parameter name="_toDoTaskCode" type="Integer"/>
        <Parameter name="_addingToDo" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="updateTIForCargoChecks" id="76b14531-4660-4989-9630-714ba4dcd602">
        <source>updateTIForCargoChecks(_ti : CM_TrackedItem io; _toDoTasks : IntegerArray; _addingToDoTasks : BooleanArray);

/*

Purpose:		

Date			Who		Reason
10/02/2014		cnwmh5	Initial creation

*/

vars

	pxyTI				: CM_TrackedItem;

begin

	beginLoad;
	pxyTI := _ti.pxyCreateUpdateProxy();
	endLoad;

	app.myTrxUA.trxUpdateTIForCargoChecks(pxyTI, null, TI_UPDMODE_NORMAL, null, _toDoTasks, _addingToDoTasks, app.myPassport);
