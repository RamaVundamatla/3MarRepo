    <JadeMethod name="keyDown" id="1e3827d7-6935-48d3-b4ad-5dd348514fce">
        <controlMethod name="Form::keyDown"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>keyDown(keyCode: Integer io; shift: Integer) updating;
// --------------------------------------------------------------------------------
// Created:		20 May 2010 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if keyCode = CNEC_KEY_F12 then
		if (app.isSpecial() or app.isDevelopmentSystem()) and shift.cnEcIsCtrlKey() then
			if shift.cnEcIsShiftKey() then
				self.cnEcShowContents();
			else
				self.cnEcShowGuiInfo();
			endif;
		elseif (app.isSpecial() or app.isDevelopmentSystem()) and shift.cnEcIsAltKey() then
			self.cnEcListInUseBy();
		endif;
	endif;
end;</source>
        <Parameter name="keyCode" type="Integer" usage="io"/>
        <Parameter name="shift" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="lbxTests_click" id="4d364627-54e8-4e18-ad45-3267fa5cde00">
