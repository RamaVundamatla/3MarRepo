    <JadeMethod name="getPaymentType" id="0fa244e3-41e6-4d1c-94a4-ffae3e18d919">
        <source>getPaymentType(_isInvoiceProforma : Boolean):String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 Feb 2020 cnwma1  Bug 48513: GUQ - Invoice with blank status after container has been released/ Cash transactions
11 Feb 2020 cnwma1  Bug 48511: JMT - Duplicate Narration for Manual Cash Payment on Cash Collection Screen

*/

vars
	str : String;
begin
	if self.manual then
		if self.myInvoiceLine &lt;&gt; null and not self.myInvoiceLine.isTransient then
			str := app.getErrorString(Invoiced);
		else
			str := app.getErrorString(Extra);
		endif;
	
	// ### INVOICED INVOICED
	elseif self.myInvoiceLine &lt;&gt; null then
		str := app.getErrorString(Invoiced);
	
	// ### ESTIMATE
	else
		if _isInvoiceProforma then
			str := app.getErrorString(Proforma);
		else
			str := app.getErrorString(Estimation);
		endif;
	
	endif;
	
	if self.voided then
		str := str &amp; " (" &amp; app.getErrorString(PaymentStatus_Void) &amp;")"; // 20.02.2020 cnwma1 #48513
	endif;
	
	
	return str;
epilog

end;</source>
        <Parameter name="_isInvoiceProforma" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
