    <JadeMethod name="canDrop" id="77b3e9f7-4d5e-417a-a807-4c6837c9fa4e">
        <source>canDrop(_control: Control input; _win: Window input):Boolean protected;
// ---------------------------------------------------------------------------
// Created:     15 December 2009 by cnwcs5
// Purpose:     CCMS 1028 - summary mappings
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	if _win = self.tblProperties then 
		if _control = self.frmCells or
			_control.parent = self.frmCells then
			// can't drag property onto field;
			return false;
		endif;
	endif;
	
	if _win = self.tblFields then 
		if _control &lt;&gt; frmCells then
			// can't drag field onto grouping property
			return false;
		endif;
	endif;
	
	if _win.name = btnField.name then
		// we are dragging a button within the XTAB definition
		if _control.name = btnField.name then
			// button on button
			if _win.Button.parent = self.frmCells and _control.parent &lt;&gt; self.frmCells then
				// can't change field to grouping
				return false;
			endif;
			if _win.Button.parent &lt;&gt; self.frmCells and _control.parent = self.frmCells then
				// can't change grouping to field
				return false;
			endif;
		else
			// button on frame
			if _win.Button.parent = self.frmCells and _control &lt;&gt; self.frmCells then
				// can't change field to grouping
				return false;
			endif;
			if _win.Button.parent &lt;&gt; self.frmCells and _control = self.frmCells then
				// can't change grouping to field
				return false;
			endif;
		endif;
	endif;
	
	return inheritMethod (_control, _win);
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_control" type="Control" usage="input"/>
        <Parameter name="_win" type="Window" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="createProxyForNewXTAB" id="e967ff5f-2ab0-4330-bce6-4f68f0da5532">
        <updating/>
        <source>createProxyForNewXTAB() updating, protected;
// ---------------------------------------------------------------------------
// Created:     15 December 2009 by cnwcs5
// Purpose:     CCMS 1028 - summary mappings
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	agent	:CMIF_OutputFormatAgent_SS;
	proxy	:CM_OutputFormat_XTAB;
begin
	create agent transient;

	proxy := agent.createXTABOutputFormat (self.myCurrentSnapshot, true);
	
	proxy.setName( ( app.getString( XTAB_New_Summary_Definition, process.userCode ) ) );
	proxy.setModeAndType(CM_QueryDefinition.Snapshot_Query_Mode,CM_QueryDefinition.Snapshot_Query_Type);	
	proxy.setOutputFormat_SS (self.myCurrentSnapshot);
	
	self.myProxyXTAB	:= proxy;
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doDragDrop" id="b027fe02-b116-4549-a499-7441a9e945b9">
        <updating/>
        <source>doDragDrop(_control: Control input; win: Window input; x: Real; y: Real) updating, protected;
// ---------------------------------------------------------------------------
// Created:     15 December 2009 by cnwcs5
// Purpose:     CCMS 1023 - snapshot summaries
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin					
	if win = self.tblFields then
		self.clearGraphics;
	
		if not self.canDrop (_control, win) then	
			return;									
		endif;	
		// we have dragged a property from the properties table
		self.doDragDrop_AddProperty (win, _control);
		
		return;
	endif;
	
	inheritMethod(_control, win, x, y);

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_control" type="Control" usage="input"/>
        <Parameter name="win" type="Window" usage="input"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="doDragDrop_AddProperty" id="a20f2f77-85b6-4273-b7b9-74e4199d3b82">
        <updating/>
        <source>doDragDrop_AddProperty(_win :Window; _control :Control) updating, protected;
// ---------------------------------------------------------------------------
// Created:     15 December 2009 by concms1
// Purpose:     ccms 1023 - snapshot summaries
// Parameters:  _control 	- control being dropped onto
//							- will be a button, frmTabs, frmRows, frmColumns
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	property	:CM_QueryProperty;
	frame		:Frame;
	btn			:Button;
begin
	if _win &lt;&gt; self.tblFields then
		inheritMethod (_win, _control);
		return;
	endif;
	
	property := self.getSelectedField; 
	
	if _control.isKindOf (Frame) then
		frame 	:= _control.Frame;
	else
		btn		:= _control.Button;
		frame	:= btn.parent.Frame;
	endif;
	
	if frame = self.frmTabs then
		btn := self.doAddTab (property, btn);
	elseif frame = self.frmRows then
		btn := self.doAddRow (property, btn);
	elseif frame = self.frmColumns then
		btn := self.doAddColumn (property, btn);
	else
		btn := self.doAddCell (property, btn);
	endif;
	
	self.doButtonClick (btn);
	
epilog
	
end;</source>
        <access>protected</access>
        <Parameter name="_win" type="Window"/>
        <Parameter name="_control" type="Control"/>
    </JadeMethod>
    <JadeMethod name="doMnuAddCell_click" id="7ac0171d-888f-4fa3-a9f2-98df66d69f40">
        <updating/>
        <source>doMnuAddCell_click() updating, protected;
// ---------------------------------------------------------------------------
// Created:     15 December 2009 by cnwcs5
// Purpose:     CCMS 1023 - snapshot summaries
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	property :CM_QueryProperty;
begin
	if mnuPopup1.userObject = self.tblFields then
		property := self.getSelectedField;
	
		if property = null then
			return;
		endif;
		
		self.doButtonClick( self.doAddCell( property, null ) );
		return;
	endif;
	
	inheritMethod();

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doTblProperties_contextMenu" id="22c8f943-96af-4705-8419-36b2808373ec">
        <updating/>
        <source>doTblProperties_contextMenu(_table: Table input; _conwin: Window input; _mouse: Boolean; _x: Integer; _y: Integer): Boolean updating, protected;
// ---------------------------------------------------------------------------
// Created:     17 December 2009 by cnwcs5
// Purpose:     CCMS 1023 - snapshot summaries
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	property	: CM_QueryProperty;
begin
	property := self.getSelectedProperty;
	
	if property = null then
		return false;
	endif;
	
	// only one TAB currently allowed.
	self.mnuPopup1AddTab.enabled	:= not self.myProxyXTAB.hasTabs;
	self.mnuPopup1AddColumn.visible	:= true;				
	self.mnuPopup1AddRow.visible	:= true;				
	self.mnuPopup1AddTab.visible	:= true;	
	self.mnuPopup1AddCell.visible	:= false;
	self.mnuPopup1.userObject 		:= self.tblProperties;	
	
	// now show the menu and terminate further processing
	return self.showContextMenu( self.mnuPopup1, _table, _conwin, _mouse, _x, _y );
epilog
	
end;</source>
        <access>protected</access>
        <Parameter name="_table" type="Table" usage="input"/>
        <Parameter name="_conwin" type="Window" usage="input"/>
        <Parameter name="_mouse" type="Boolean"/>
        <Parameter name="_x" type="Integer"/>
        <Parameter name="_y" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getDefaultFunctionForProperty" id="fd773759-d4e2-4eaf-9a05-8876a0c0cc2f">
        <source>getDefaultFunctionForProperty(_property : CM_QueryProperty):Integer protected;
// ---------------------------------------------------------------------------
// Created:     17 December 2009 by cnwcs5
// Purpose:     CCMS 1023 - snapshot summaries
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	
begin
	return self.myCurrentSnapshot.getDefaultFunctionForProperty (_property.propertyName);
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_property" type="CM_QueryProperty"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getSelectedField" id="d73f061e-cbf5-4f4e-bd37-9af90db3df74">
        <source>getSelectedField():CM_QueryProperty;
// ---------------------------------------------------------------------------
// Created:     15 December 2009 by cnwcs5
// Purpose:     CCMS 1023 - snapshot summaries
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	row	:Integer;
begin
	row	:= self.tblFields.row;
	
	if row = 0 then
		return null;
	endif;
	
	return self.tblFields.accessCell (row, 1).itemObject.CM_QueryProperty;
epilog

end;</source>
        <ReturnType type="CM_QueryProperty"/>
    </JadeMethod>
    <JadeMethod name="initialise" id="0c3ed5df-0d51-48b3-b949-f9114774c581">
        <updating/>
        <source>initialise(_coll : Collection; _showExpanded : Boolean ) updating;
// ---------------------------------------------------------------------------
// Created:     14 December 2009 by cnwcs5
// Purpose:     CCMS 1028 - summary mappings
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	any	:Any;
begin
	inheritMethod (_coll, _showExpanded);
	
	any := _coll.first;
	
	if any = null then
		app.raiseUnexpectedProgramError (self.class.name, method.name, 'XTAB form called with empty collection');
	endif;
	
	self.myCurrentSnapshot 	:= any.CM_DynamicObject_Snapshot.getOutputFormat_SS;	
epilog

end;</source>
        <Parameter name="_coll" type="Collection"/>
        <Parameter name="_showExpanded" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isSnapshotMode" id="b8876adc-d122-4f2a-9ea5-5f61e5787a1b">
        <source>isSnapshotMode(): Boolean protected;
// ---------------------------------------------------------------------------
// Created:     15 December 2009 by cnwcs5
// Purpose:     CCMS 1023 - summary snapshots
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	return true;
epilog

end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="loadFields" id="0d6e988d-0819-4e4c-b49d-01f6237053ee">
        <source>loadFields()protected;
// ---------------------------------------------------------------------------
// Created:     15 December 2009 by cnwcs5
// Purpose:     CCMS 1028 - summary mappings
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	tbl		:Table;
	bolType	:CM_CargoBOLType;
	coll	:CM_QueryPropertyArray;
	prop	:CM_QueryProperty;
	str		:String;
begin
	tbl					:= self.tblFields;
	tbl.clear;
	tbl.rows 			:= 0;
	tbl.columns			:= 1;
	tbl.sortColumn[ 1 ]	:= 0;			// no sorting ?
	tbl.gridLines		:= false;
	
	create coll transient;
	
	self.myCurrentSnapshot.getFieldProperties (coll);
	
	bolType				:= app.myRoot.getCargoBOLTypeForId( self.myCurrentSnapshot.mode ); 

	foreach prop in coll do
		if not prop.canBeViewed( app.myPassport ) then
			continue;
		endif;
		
		str := app.getTerminologyAlternate( bolType, null, prop.niceName, CM_TermExpressionSingular, prop.niceName );
		
		tbl.addItem( str );
		tbl.accessCell( tbl.rows, 1 ).itemObject	:= prop;
		tbl.accessRow( tbl.rows ).itemObject		:= prop;
	endforeach;

	tbl.sortColumn[ 1 ]	:= 1;			// now sorting on column 1
	tbl.resort;
epilog
	delete coll;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="loadFunctionsForField" id="53e0bbee-81cd-473b-9175-ce0d2d76f5eb">
        <source>loadFunctionsForField(_field: CM_XTABField) protected;
// ---------------------------------------------------------------------------
// Created:     15 December 2009 by cnwcs5
// Purpose:     CCMS 1023 - snapshot summaries
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 12/02/2010	cnwcs5	par 22140 - New functions
// ---------------------------------------------------------------------------
vars
	ss 			:CM_OutputFormat_SS;
	coll		:IntegerArray;
	int, index	:Integer;
	property	:CM_QueryProperty;
	str			:String;
begin
	cmbFunction.clear;
	
	if _field = null then
		return;
	endif;
	
	// we only load functions that have been used for this field
	ss := self.myCurrentSnapshot;
	
	create coll transient;
	ss.getFunctionsForProperty (_field.propertyName, coll);

	property := _field.getQueryProperty;

	// Only allow decimal places if have a decimal.
	self.txtDecimals.enabled	:= property &lt;&gt; null and property.isKindOf( CM_QDecimalProperty );

	foreach int in coll do
		// 12/02/2010 cnwcs5 par 22140 - I have simplified this block of code
		// see history for what it used to be
		if int = CM_XTABField.Function_Count then
			str := app.getErrorString( COUNT );
		elseif int = CM_XTABField.Function_Sum then
			str := app.getErrorString( SUM );
		elseif int = CM_XTABField.Function_Average then
			str := app.getErrorString( AVERAGE );
		elseif int = CM_XTABField.Function_Max then
			str := app.getErrorString( MAX );
		elseif int = CM_XTABField.Function_Min then
			str := app.getErrorString( MIN );
		elseif int = CM_XTABField.Function_Count_True then		
			str := app.getErrorString( COUNT_TRUE );		
		elseif int = CM_XTABField.Function_Count_False then	
			str := app.getErrorString( COUNT_FALSE );		
		elseif int = CM_XTABField.Function_Count_Null then	
			str := app.getErrorString( COUNT_NULL );		
		elseif int = CM_XTABField.Function_Count_NotNull then
			str := app.getErrorString( COUNT_NOT_NULL );	
		elseif int = CM_XTABField.Function_Count_Zero then		// 15/02/2010 cnwcs5 par 22140
			str := app.getErrorString( COUNT_ZERO );			// 15/02/2010 cnwcs5 par 22140	
		elseif int = CM_XTABField.Function_Count_NotZero then	// 15/02/2010 cnwcs5 par 22140
			str := app.getErrorString( COUNT_NOT_ZERO );		// 15/02/2010 cnwcs5 par 22140	
		else
			// not one we know about ???
			// should not happen
			continue;
		endif;
		// now add the entrye to the combo
		index	:= cmbFunction.addItem( str);	// 12/02/2010 cnwcs5 par 22140
		cmbFunction.itemData[ index ]	:= int;	// 12/02/2010 cnwcs5 par 22140
	endforeach;
	
epilog
	delete coll;
end;</source>
        <access>protected</access>
        <Parameter name="_field" type="CM_XTABField"/>
    </JadeMethod>
    <JadeMethod name="loadModeCombo" id="153ab832-9f7a-49be-9b8a-0da02f0744d8">
        <updating/>
        <source>loadModeCombo() updating, protected;
// ---------------------------------------------------------------------------
// Created:     14 December 2009 by cnwcs5
// Purpose:     CCMS 1028 - summary mappings
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	cmb		:ComboBox;
	qDef	:CM_QueryDefinition;
	idx		:Integer;
begin
	cmb := self.cmbMode;

	cmb.clear();
	cmb.sorted	:= true;				
	
	qDef := app.myRoot.allQueryDefinitionObjects [CM_QueryDefinition.Snapshot_Query_Type,CM_QueryDefinition.Snapshot_Query_Mode];	
		
	if qDef &lt;&gt; null then				
		idx := cmb.addItem(qDef.modeDescription);	
		cmb.itemObject[idx] := qDef;	
		cmb.listObject  	:= qDef;
	endif;							
	
	self.setMyQueryDefinition (qDef);
	
	cmb.enabled := false;
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="loadProperties" id="2d6e3992-5422-45ed-b964-cdcc4d21ac3f">
        <source>loadProperties() protected;
// ---------------------------------------------------------------------------
// Created:     15 December 2009 by cnwcs5
// Purpose:     CCMS 1028 - summary mappings
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	tbl		:Table;
	bolType	:CM_CargoBOLType;
	coll	:CM_QueryPropertyArray;
	prop	:CM_QueryProperty;
	str		:String;
begin
	tbl					:= self.tblProperties;
	tbl.clear;
	tbl.rows 			:= 0;
	tbl.columns			:= 1;
	tbl.sortColumn[ 1 ]	:= 0;			// no sorting ?
	tbl.gridLines		:= false;
	
	// load properties specific to a snapshot
	bolType				:= app.myRoot.getCargoBOLTypeForId( self.myCurrentSnapshot.mode ); 

	foreach prop in self.myQueryDefinition.allQueryProperties do
		if not prop.canBeViewed( app.myPassport ) then
			continue;
		endif;
		
		str := app.getTerminologyAlternate( bolType, null, prop.niceName, CM_TermExpressionSingular, prop.niceName );
		
		tbl.addItem( str ); 
		tbl.accessCell( tbl.rows, 1 ).itemObject	:= prop; 
		tbl.accessRow( tbl.rows ).itemObject		:= prop;
	endforeach;	

	// load properties that were used in the snapshot
	create coll transient;
	
	self.myCurrentSnapshot.getGroupingProperties (coll);
	
	bolType				:= app.myRoot.getCargoBOLTypeForId( self.myCurrentSnapshot.mode ); 

	foreach prop in coll do
		if not prop.canBeViewed( app.myPassport ) then
			continue;
		endif;
		
		str := app.getTerminologyAlternate( bolType, null, prop.niceName, CM_TermExpressionSingular, prop.niceName );
		
		tbl.addItem( str );
		tbl.accessCell( tbl.rows, 1 ).itemObject	:= prop;
		tbl.accessRow( tbl.rows ).itemObject		:= prop;
	endforeach;

	tbl.sortColumn[ 1 ]	:= 1;			// now sorting on column 1
	tbl.resort;
epilog
	delete coll;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="loadSavedDisplays" id="ca7d51bf-e8a0-42c8-bd76-312de58fcee6">
        <source>loadSavedDisplays() protected;
// ---------------------------------------------------------------------------
// Created:     15 December 2009 by cnwcs5
// Purpose:     CCMS 1023 - snapshot summaries
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

	xtab	: CM_OutputFormat;
	
begin
	lstSavedDisplays.clear;
	
	foreach xtab in self.myCurrentSnapshot.allOutputFormats_XTAB do	
		lstSavedDisplays.itemObject[ lstSavedDisplays.addItem( xtab.name ) ]	:= xtab;
		
		self.beginNotification( xtab, EVENT_SummaryTable_Update, Response_Continuous, null );
		self.beginNotification( xtab, EVENT_SummaryTable_Delete, Response_Continuous, null );
	endforeach;
epilog
		
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setupForm" id="a42f203c-0341-40a5-a614-5e897b4f1767">
        <updating/>
        <source>setupForm() updating;
// ---------------------------------------------------------------------------
// Created:     15 December 2009 by cnwcs5
// Purpose:     CCMS 1028 - summary mappings
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	inheritMethod();
	
	self.loadFields;
	
	// resize the available fields table so it ends before the 'Available fields' label
	tblProperties.height := lblFields.top - tblProperties.top - 10;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="tblFields_contextMenu" id="323837f9-60eb-4dd7-bf5b-a5bffed2f586">
        <controlMethod name="Table::contextMenu"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblFields_contextMenu(_table: Table input; _conwin: Window input; _mouse: Boolean; _x, _y: Integer):Boolean updating;
// ---------------------------------------------------------------------------
// Created:     15 December 2009 by cnwcs5
// Purpose:     CCMS 1023 - snapshot summaries
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	property	: CM_QueryProperty;
begin
	property := self.getSelectedField;
	
	if property = null then
		return false;
	endif;
	
	// only one TAB currently allowed.
	self.mnuPopup1AddTab.enabled	:= false;
	self.mnuPopup1AddColumn.visible	:= false;				
	self.mnuPopup1AddRow.visible	:= false;	
	self.mnuPopup1AddTab.visible	:= false;	
	self.mnuPopup1AddCell.visible	:= true;
	
	self.mnuPopup1.userObject 		:= self.tblFields;	
	
	// now show the menu and terminate further processing
	return self.showContextMenu( self.mnuPopup1, _table, _conwin, _mouse, _x, _y );
	
epilog
	
end;</source>
        <Parameter name="_table" type="Table" usage="input"/>
        <Parameter name="_conwin" type="Window" usage="input"/>
        <Parameter name="_mouse" type="Boolean"/>
        <Parameter name="_x" type="Integer"/>
        <Parameter name="_y" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="tblFields_keyDown" id="d08bb2cf-5c70-4edd-92e8-690ab3e71f18">
        <controlMethod name="CM_Table::keyDown"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblFields_keyDown(table: Table input; keyCode: Integer io; shift: Integer) updating;
// ---------------------------------------------------------------------------
// Created:     15 December 2009 by cnwcs5
// Purpose:     CCMS 1023 - snapshot summaries
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	if shift = null then			// not control or alt or shift pressed
		self.tblProperties.doSearch( keyCode.Character.display, 1 );
	endif;
epilog

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="keyCode" type="Integer" usage="io"/>
        <Parameter name="shift" type="Integer"/>
