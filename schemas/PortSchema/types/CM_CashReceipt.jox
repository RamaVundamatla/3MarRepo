    <JadeMethod name="getVesselName" id="5a28031d-9e1c-47c9-8af8-67a048114232">
        <source>getVesselName():String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 May 2014	cnwndl1	Initial creation	Par 34142
21/07/2014	cnwjre1 34580 extend to get from cargo if not on receipt
*/

vars
	vesselName	: String;
	ti		: CM_TrackedItem;
	vessel : CM_Vessel;
	localTiArray : CM_TIArray;		//30 Mar 2016	NDL	TFS 1726

begin

	if self.myVoyage &lt;&gt; null then
		vessel := self.myVoyage.myVessel;
		if vessel &lt;&gt; null then
			vesselName := vessel.name;
		endif;
	endif;
	
	if vesselName = null then
		create localTiArray transient;	//30 Mar 2016	NDL	TFS 1726
		self.getAllGoodTrackedItems( localTiArray );		//30 Mar 2016	NDL	TFS 1726
		//foreach ti in self.allTrackedItems do
		foreach ti in localTiArray do		//30 Mar 2016	NDL	TFS 1726
			vesselName := ti.vesselName;
			if vesselName &lt;&gt; null then
				break;
			endif;
		endforeach;
	endif;

	return vesselName;

epilog

	delete localTiArray;	//30 Mar 2016	NDL	TFS 1726

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getVoyage" id="e9451dea-f3a4-4dc8-b3ce-2cf2e132dbd6">
        <source>getVoyage() : CM_Voyage;
//	for 36704 get from receipt or cargo
vars
	voyage	: CM_Voyage;
	ti		: CM_TrackedItem;
	localTiArray : CM_TIArray;		//30 Mar 2016	NDL	TFS 1726
begin

	voyage := self.myVoyage;
	if voyage = null then
		create localTiArray transient;	//30 Mar 2016	NDL	TFS 1726
		self.getAllGoodTrackedItems( localTiArray );		//30 Mar 2016	NDL	TFS 1726
		//foreach ti in self.allTrackedItems do
		foreach ti in localTiArray do		//30 Mar 2016	NDL	TFS 1726
			voyage := ti.myVoyage;
			if voyage &lt;&gt; null then
				break;
			endif;
		endforeach;
	endif;
	
	return voyage;
	
epilog

	delete localTiArray;	//30 Mar 2016	NDL	TFS 1726
	
end;
</source>
        <ReturnType type="CM_Voyage"/>
    </JadeMethod>
