    <JadeMethod name="polEdit" id="fb7ed107-5fba-41f4-acfd-e9171a0feb5e">
        <source>polEdit();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 May 2017	cnwma1	Initial creation

*/


vars
	
	editStrings : HugeStringArray;
	str,s : String;
	i : Integer;
	field : String;
	oldValue : String;
	newValue : String;
	edit : CM_Edit;
begin
	edit :="2387.12818952".asOid.CM_Edit;
	create editStrings transient;
	i := 0;
	foreach i in 1 to edit.fieldsValues.size  do
		//edit.getFieldValuesForSQL(i, field, oldValue, newValue);
		str:= field&amp; "{" &amp; oldValue &amp; "|" &amp; newValue &amp;"}";
		if field &lt;&gt; null then
			editStrings.add(str);
		endif;
	endforeach;
	str := null;
	foreach s in editStrings do 
	     str :=str &amp; s &amp;" "  ; 
		
	endforeach;
	write "size1 " &amp;str.cnCountCharOccurences(' ').asStringJMT;
	str := str.trimRight();
		write "size2 " &amp;str.cnCountCharOccurences(' ').asStringJMT;
	write  str;
epilog
	delete editStrings;
end;</source>
    </JadeMethod>
    <JadeMethod name="polEdit2" id="e755dced-179a-4410-b406-fcd224f9c19d">
        <source>polEdit2();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 May 2017	cnwma1	Initial creation

*/


vars
	
	editStrings,formatedString : HugeStringArray;
	str,s : String;
	i : Integer;
	field : String;
	oldValue : String;
	newValue : String;
	edit : CM_Edit;
		change,
	propertyName,
	beforeValue,
	afterValue,
	strValue,
	returnValue		: String;
	changes			: HugeStringArray;
	peClass 		: CMIF_PushEventsClass;
	peFeature		: CMIF_PushEventsFeature;
	beforeAny,
	afterAny		: Any;
	strr : String;
begin
	edit :="2387.12809086".asOid.CM_Edit;
	create editStrings transient;
	create formatedString transient;
	if edit.fieldsValues &lt;&gt; null then
		strr:= edit.getDetailDisplayString();
		editStrings.add(strr);
	
	foreach str in editStrings  do 
		edit.splitEditChangeForSQL(str, propertyName, beforeValue, afterValue);
		if propertyName &lt;&gt; null then
			
			str:= propertyName&amp; "{" &amp; beforeValue &amp; "|" &amp; afterValue &amp;"}";
			if propertyName &lt;&gt; null then
				formatedString.add(str);
			endif;
		endif;
	endforeach;
	endif;
		str := null;
	foreach s in formatedString do 
	     str :=str &amp; s &amp;' ' ; 
		
	endforeach;
	str := str.trimRight(); 
	write str;
epilog
	delete editStrings;
	delete formatedString;
end;</source>
    </JadeMethod>
    <JadeMethod name="polEdit3" id="52fc4e02-952b-4758-88a0-4e8a4ad17207">
        <source>polEdit3();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 May 2017	cnwma1	Initial creation

*/

vars
	edit : CM_Edit;
	str,s,propertyName,beforeValue,afterValue : String;
	editArr,formatedString : HugeStringArray;
begin

	edit :="2387.12818952".asOid.CM_Edit;
		create editArr transient;
	if edit.fieldsValues &lt;&gt; null then
		editArr:= edit.getDetailDisplayStringSQL();
	endif;
	create formatedString transient;

	foreach str in editArr  do 
		edit.splitEditChangeForSQL(str, propertyName, beforeValue, afterValue);
		if propertyName &lt;&gt; null then
			
			str:= propertyName&amp; "{" &amp; beforeValue &amp; "|" &amp; afterValue &amp;"}";
			if propertyName &lt;&gt; null then
				formatedString.add(str);
			endif;
		endif;
	endforeach;

		str := null;
	foreach s in formatedString do 
	     str :=str &amp; s &amp;' ' ; 
		
	endforeach;
	str := str.trimRight(); 
	write str;
epilog
	delete editArr;
	delete formatedString;
end;</source>
    </JadeMethod>
    <JadeMethod name="populateInvSumm" id="fda0ca70-c539-40ab-93c4-35279c4988e9">
        <source>populateInvSumm();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 March 2020	jlgma1	Initial creation

*/
constants 
 SEQ = 91;
vars
	term 	 	: CM_Terminal;
	invoice	    : CM_Invoice;
	bank        : CM_Bank;
	summDict	: CM_GLSummaryByGLCodeRateDict;
	glSumm      : CM_GLSummary;
	repSumm		: CM_ReportInvoiceSummary;
	repTotal	: CM_ReportInvoiceTotal;
	repItem		: CM_ReportInvoiceItem;
	dilt		: CM_DebtorInvLineType;
	count1,
	count2      : Integer;
	detailTaxTotal,
	detailTotal		: Decimal[12, 2];
	totalQuantity   : Real;
	invLine      : CM_InvoiceLine;
	isStorage       : Boolean;
	itemId			: String;
	equipType     : String;
	ti    : CM_TrackedItem;
	objArr : CM_ObjectArray;
begin
	
	app.initialize();
	
	term := app.myRoot.allTerminals["CASH"];

	
	if term = null then
		return;
	endif;
	bank := term.companies["ADP3"];
	
	if bank = null then
		return;
	endif;
	invoice := bank.allInvoices[term,bank,SEQ];
	
	if invoice = null then
		return;
	endif;
	
	create summDict transient;
	invoice.getGLSummary(summDict);
	
	summDict.inspectModal;
	
	create objArr transient;
	foreach glSumm in summDict do
		
		create repSumm;
		objArr.add(repSumm);
		repSumm.myInvoice 		:= invoice;

		
		dilt := glSumm.myInvoiceLine.invoiceLineDesc.getDebtorInvLineType(invoice.debtor);
		if dilt &lt;&gt; null then
			repSumm.itemIdentifier := dilt.otherCode;
		endif;
		repSumm.itemId 			   := count1;
		repSumm.itemDescription    := glSumm.glCode;
		repSumm.groupById 	       := glSumm.glCode &amp; glSumm.rate.String;
		repSumm.rate 			   := glSumm.rate;
		repSumm.netAmount 	 	   := glSumm.amount;                                     //09/03/2020 cnwma1 TFS #48524
		repSumm.quantity 		   := glSumm.quantity;									//09/03/2020 cnwma1 TFS #48524
		repSumm.cargoIds           := glSumm.getCargoIds();                             //09/03/2020 cnwma1 TFS #45899
		repSumm.printOrder         := glSumm.printOrder;                                //09/03/2020 cnwma1 TFS #45899
		repSumm.printTrackedItems  := glSumm.printTrackedItems;                         //09/03/2020 cnwma1 TFS #45899
		repSumm.taxAmount 		   := glSumm.taxAmount;							        //09/03/2020 cnwma1 TFS #48524
		detailTaxTotal 			   := detailTaxTotal + repSumm.taxAmount;				 //the total gst charged amout
		detailTotal 			   := detailTotal    + repSumm.netAmount;
		totalQuantity 			   := totalQuantity  + repSumm.quantity;
		repSumm.totalAmount 	   := glSumm.amount  + glSumm.taxAmount;
		repSumm.unitPrice 		   := glSumm.rate.asStringJMTWithPrecision(3, false); // TFS 36954 MPD 20 Feb 2018
		count1 					   := count1 + 1;
		
		count2 := 1;
		foreach invLine in glSumm.allInvoiceLines do
			if invLine.myTransactionTI &lt;&gt; null and invLine.myTransactionTI.isKindOf(CM_Storage) then
				isStorage := true;
			else
				isStorage := false;
			endif;
			equipType := "UN";
			ti := invLine.getTrackedItem();
			if ti &lt;&gt; null and
			   ti.isContainer() then
				equipType := "CH";
			endif;
			
			itemId := invLine.getTIID();
			create repItem;
			repItem.myInvoiceLine 		    := invLine;
			repItem.myReportInvoiceSummary  := repSumm;
			repItem.itemId 					:= count2;
			count2 							:= count2 + 1;
			repItem.quantity				:= invLine.quantity;    			//09/03/2020 cnwma1 TFS #48524
			repItem.equipmentIdentifier 	:= itemId;
			repItem.equipmentType 			:= equipType;
			repItem.endIdentifier 			:= '140';
			repItem.endDate 				:= invLine.chargeTime.date.userFormat($ODBC_Date);
			
		endforeach;
		
	endforeach;
	
	objArr.inspectModal;
epilog
	delete repItem;
	delete summDict;
	delete objArr;
end;</source>
    </JadeMethod>
