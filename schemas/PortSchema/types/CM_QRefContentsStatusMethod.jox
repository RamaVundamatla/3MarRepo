<Class name="CM_QRefContentsStatusMethod" id="2b8dd1cb-f2e8-4fb0-85f3-e358c2d9f544">
    <superclass name="CM_QReferenceMethod"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="query"/>
    <JadeMethod name="getKeyLengthForXTABDictionary" id="262eb04b-ecaf-4cb1-99ac-130b3f315e17">
        <source>getKeyLengthForXTABDictionary(): Integer;
//  CCMS 1262 Jan 2012 transaction enquiry and selector queries
vars

begin
	return CM_ContentsStatus::description.length;
end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setComboValues" id="7a28306f-38b4-470e-97f1-129d94defb60">
        <source>setComboValues(_combo : ComboBox input; _params : CM_QueryCriteriaLineHolder; _queryOperator : CM_QueryOperator; _passport : CM_Passport);
//  CCMS 1262 Jan 2012 transaction enquiry and selector queries
vars
	stat 			: CM_ContentsStatus;
	statDict		: CM_ContentsStatusByCodeDict;
	qrl				: CM_QReferenceLookup;
begin
	_combo.clear();
	statDict := app.myRoot.allContentsStatuses;
	
	foreach stat in statDict discreteLock do
		
		//jlier1 TFS 54700 31/8/22 - if container don't show trailer content status
		if self.propertyClassName = CM_Container.name then
			if stat.code &gt; TI_CONTENTS_STATUS_EMPTY then
				break;
			endif;
		elseif self.propertyClassName = CM_TILC.name then
			if stat.code = TI_CONTENTS_STATUS_LCL then
				continue;
			endif;
		endif;
		
		_combo.itemObject[_combo.addItem(stat.description)] := stat;
	endforeach;

	if CM_QReferenceLookup.hasInstance(_queryOperator) then
		qrl := _queryOperator.CM_QReferenceLookup;
		if global.isValidObject(qrl.mySelectionValue) then
			_combo.listObject := qrl.mySelectionValue;
		endif;
	endif;
end;</source>
        <Parameter name="_combo" type="ComboBox" usage="input"/>
        <Parameter name="_params" type="CM_QueryCriteriaLineHolder"/>
        <Parameter name="_queryOperator" type="CM_QueryOperator"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="translateToDisplayValue" id="d8e68d92-7f84-4ebc-8b32-bcb6ced39397">
        <source>translateToDisplayValue(_value: Any): String;
//  CCMS 1262 Jan 2012 transaction enquiry and selector queries
vars

begin
	if _value.isKindOf (CM_ContentsStatus) then	
		if _value &lt;&gt; null then
			return _value.CM_ContentsStatus.description;
		else
			return null;
		endif;
	endif;
	
	return _value.String;
end;</source>
        <Parameter name="_value" type="Any"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="translateToSearchValue" id="0f356dbb-4d1f-4e6e-82fd-07de5054bfc9">
        <source>translateToSearchValue(_value: Any): Any;
//  CCMS 1262 Jan 2012 transaction enquiry and selector queries
vars
	
begin
	if _value &lt;&gt; null then
		if _value.isKindOf(Collection) then	
			return _value;
		endif;

		if _value.isKindOf(CM_ContentsStatus) then
			return _value.CM_ContentsStatus;
		endif;
	endif;
	
	return null;
end;</source>
        <Parameter name="_value" type="Any"/>
        <ReturnType type="Any"/>
    </JadeMethod>
</Class>
