    <JadeMethod name="populateOpCriteria" id="339d06b2-b7a0-4ec1-98af-a15c4968294a">
        <source>populateOpCriteria();
/*
Purpose:		Populate Operational Criteria for viewing

Parameters:			

Return Value:		

Date		Who		Reason
01/08/2008	consw1	Initial creation
01/06/2010	cnwdap1	CCMS 1116 Tranship changes
*/
vars

begin
	self.lblExport.caption 		:= self.getIMEXCriteriaString(TI_IMEX_STATUS_EXPORT);
	self.lblImport.caption 		:= self.getIMEXCriteriaString(TI_IMEX_STATUS_IMPORT);
	self.lblStorage.caption 	:= self.getIMEXCriteriaString(TI_IMEX_STATUS_STORAGE);
	self.lblTransship.caption 	:= self.getIMEXCriteriaString(TI_IMEX_STATUS_TRANSHIP);		// PAR #23645 CCMS 1116
	self.lblRemainOnBoard.caption := self.getIMEXCriteriaString(TI_IMEX_STATUS_REMAINONBOARD);	//PAR #29560 cnwmc5
	self.lblNoIMEX.caption 		:= self.getIMEXCriteriaString(TI_IMEX_STATUS_NULL);

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="populateRTCriteria" id="15ff55f9-2afc-4f9b-9335-1ce325b9f789">
        <source>populateRTCriteria();

/*

Purpose:		Populate RT Criteria sheet

Parameters:			

Return Value:		


Date			Who		Reason
31 October 2008	consw1	Initial creation
26/04/2016 		cnwma1  PAR #36914 TFS1768 Communicating/NonCommunciating Reefer Yard Allocation Criteria
*/

vars
	rtCriteriaType : CM_YACritetriaTypeByTypeDict;
	rtCt : CM_YACriteriaType;
begin
	self.mltRTCriteria.userInputEnabled := true;
	self.mltRTCriteria.formDisplayEntryMethodName 	:= CMUI_YAConfigForm::displayCriteria.name;
	self.mltRTCriteria.multiSelect					:= ListBox.MultiSelect_Extended;
	self.mltRTCriteria.myAvailableListBox.sorted 	:= true;		
	self.mltRTCriteria.mySelectedListBox.sorted 	:= true;
	self.mltRTCriteria.setTabIndex();

	//cnwjo3 par 22890, in MobileServerSchema::CMUI_YACriteriaValue::doPopulateCriteria we raise
	//an exception if the wrong criteria is selected.  Just adding some filtering here so that
	//we never get to the ugly exception
	create rtCriteriaType transient;
	foreach rtCt in app.myRoot.allYACriteriaTypes do
		if rtCt.isUsed then						//26/04/2016 cnwma1 PAR #36914 TFS1768 
			if not rtCt.isPrimitiveValue() then
				rtCriteriaType.add(rtCt);
			elseif rtCt.isPrimitiveValue() and rtCt.isBooleanType then
				rtCriteriaType.add(rtCt);
			elseif rtCt.isTransportModeType() then
				rtCriteriaType.add(rtCt);
			endif;
		endif;
	endforeach;
	
	self.mltRTCriteria.setAvailable(rtCriteriaType, true);
	self.mltRTCriteria.setSelected(self.getRealYAConfig.myTerminal.allRTAllocationCriteriaTypes);

epilog
	delete rtCriteriaType;
end;</source>
    </JadeMethod>
    <JadeMethod name="positionControlsInCentre" id="702421ef-7d0b-408e-aaf0-33b89a133c17">
        <updating/>
        <source>positionControlsInCentre() updating;
// --------------------------------------------------------------------------------
// Created:		15 Februrary 2010 by cnwjo3
//
// Purpose:		par 22338.  Its easier to position controls in code instead of painter.
//
// Changed On	By			Reason
// ----------	--------	-------------------------------------------------------
// 25/08/2025	navdap1		MTN-35615 ENS | Bulk Creation of Yard Allocations
vars

begin
	self.lblTemplateDef.left := (self.width/2)-(self.lblTemplateDef.width/2);
	self.mltTemplateDef.left := (self.width/2)-(self.mltTemplateDef.width/2);
	self.mltSearchDef.left := (self.width/2)-(self.mltSearchDef.width/2);
	self.lblSearchDef.left := (self.width/2)-(self.lblSearchDef.width/2);
	self.mltBulkDef.left := (self.width/2)-(self.mltBulkDef.width/2);		// MTN-35615
	self.lblBulkDef.left := (self.width/2)-(self.lblBulkDef.width/2);		// MTN-35615
	
	self.mltRTCriteria.left := (self.width/2)-(self.mltRTCriteria.width/2);
	
	self.btnSave.left := (self.fldYAConfig.left+self.fldYAConfig.width)-self.btnSave.width - self.btnCancel.width - 10;
	self.btnCancel.left := (self.fldYAConfig.left+self.fldYAConfig.width)-self.btnCancel.width;
end;</source>
    </JadeMethod>
    <JadeMethod name="setAPOverstowCombo" id="9e92dd72-7a10-4bbe-a74b-f0a3ae063fce">
        <source>setAPOverstowCombo(_overstowIndex : Integer);
// --------------------------------------------------------------------------------
// Created:		15 February 2010 by cnwjo3
//
// Purpose:		par 22338
//
vars

begin

	if _overstowIndex &gt; 0 then
		self.cmbAPOverstow.listIndex:= _overstowIndex;
	else
		self.cmbAPOverstow.listIndex:= 1;
	endif;
	
	self.doAPOverstowChange();
/*
	if not _useYardAlocation then
		self.cmbAPOverstow.listIndex := 1;  //0 - Closet Position
	else
		self.cmbAPOverstow.listIndex := 2;  //1 - Yard Allocation
	endif;
	*/
end;</source>
        <Parameter name="_overstowIndex" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setMTReleaseStrategyCombo" id="5df0ad11-26de-4fe0-bec5-fa5c15166b2e">
        <source>setMTReleaseStrategyCombo(_mtReleaseStrategy : Integer);
// PA 23677
begin
	self.cmbMTRelStrategy.listIndex := _mtReleaseStrategy;  
end;</source>
        <Parameter name="_mtReleaseStrategy" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setupForm" id="986b83a0-1491-4eb4-9f12-0819a71263ad">
        <updating/>
        <source>setupForm() updating;
//
// Changed On	By			Reason
// ----------	--------	------------------------------------------
// 25/08/2025	navdap1		MTN-35615 ENS | Bulk Creation of Yard Allocations
vars

begin
	self.centreOverParent(100);
	inheritMethod();
	self.btnCancelBase.visible := false;
	self.btnSaveBase.visible := false;

	self.frmToolbar.alignContainer	:=	Frame.AlignContainer_Top; // this will make the dkcMain line up its top

	if self.myTerminal.myYAConfig = null then
		self.createYAConfig();
	endif;
	
	self.loadDefaultFill();

	self.myProxyYAConfig := app.createUpdateProxy(self.myTerminal.myYAConfig).CM_YAConfig;
	self.populateAPOverstow();  //cnwjo3 par 22338
	self.populateMTReleaseStrategy();  // PAR 23677
	self.populateAutoPlan();
	self.populateDefaultCriteria();
	self.populateRTCriteria();
	self.populateOpCriteria();
	self.positionControlsInCentre();  //cnwjo3 par 22338
	if self.myProxyYAConfig.myYAOverstowHookCode &lt;&gt; null then
		self.overstowHookCode := self.myProxyYAConfig.myYAOverstowHookCode.getCurrentJadeCode();
	endif;
	
	//Added for PAR 29560 - cnwmc5
	self.myTerminal.myYAConfig.createNewIMEXConfig();
	
	//Added for PAR 29791 - cnwmc5
	if app.myRoot.isClientPortNelson = true or app.myRoot.isClientJadeMaster = true then
		shtRTCriteria.visible := true;
		if app.myRoot.isClientJadeMaster = true then
			shtRTCriteria.caption := "RT Criteria (PNL Only)"; // DEV - DO NOT TRANSLATE
		endif;
	else
		shtRTCriteria.visible := false;
	endif;
	
	
	// TFS 2198 CNWAB1
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		self.mltSearchDef.readOnly := true;
		self.mltRTCriteria.readOnly := true;
		self.mltBulkDef.readOnly := true;			// MTN-35615
		self.mltTemplateDef.readOnly := true;
		self.grpExport.enabled:= false;
		self.grpImport.enabled:= false;
		self.grpNoIMEX.enabled:= false;
		self.grpRemainOnBoard.enabled:= false;
		self.grpStorage.enabled:= false;
		self.grpTranship.enabled:= false;
		self.shtAutoPlan.disableAllChildren();
	endif;
	
	// MTN-35617 If coming from Bulk Yard Allcation form, default to setting focus to the criteria tab
	if self.myParentForm.isKindOf(CMUI_BulkYardAllocations) then
		self.shtCriteriaDef.setFocus();
	endif;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="translateForm" id="6027bd46-a7d3-4e50-af43-5d1e13dac193">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 23 September 2025 10:29:36.
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0010115, locale);
	btnCancel.translateCaption(Xlat_0010116, locale);
	btnExportEdit.translateCaption(Xlat_0010117, locale);
	btnHookCode.translateCaption(Xlat_0016923, locale);
	btnImportEdit.translateCaption(Xlat_0010118, locale);
	btnNoIMEXEdit.translateCaption(Xlat_0010119, locale);
	btnReaminOnBoard.translateCaption(Xlat_0018097, locale);
	btnSave.translateCaption(Xlat_0010120, locale);
	btnStorageEdit.translateCaption(Xlat_0010121, locale);
	btnTransshipEdit.translateCaption(Xlat_0010122, locale);
	chkAPAllowLog.translateCaption(Xlat_0010123, locale);
	chkAPEnabled.translateCaption(Xlat_0010124, locale);
	chkAPGenSwapJob.translateCaption(Xlat_0010125, locale);
	chkAPGenSwapYard.translateCaption(Xlat_0010126, locale);
	chkAPPreNotif.translateCaption(Xlat_0010127, locale);
	chkAPUseOstowRul.translateCaption(Xlat_0010129, locale);
//	chkAPUseRestrict.translateCaption(Xlat_0010130, locale);
	chkAPYAGroupBlk.translateCaption(Xlat_0014632, locale);
	chkFullGCArea.translateCaption(Xlat_0024955, locale);
	chkOsIgnorePandQ.translateCaption(Xlat_0023156, locale);
	chkUseBestPickDr.translateCaption(Xlat_0017521, locale);
	chkUsePriLookup.translateCaption(Xlat_0016262, locale);
	grpExport.translateCaption(Xlat_0010132, locale);
	grpImport.translateCaption(Xlat_0010133, locale);
	grpNoIMEX.translateCaption(Xlat_0010134, locale);
	grpRemainOnBoard.translateCaption(Xlat_0018098, locale);
	grpStorage.translateCaption(Xlat_0010135, locale);
	grpTranship.translateCaption(Xlat_0015086, locale);
	lblAPEmail.translateCaption(Xlat_0010137, locale);
	lblAPOverstow.translateCaption(Xlat_0014175, locale);
	lblBulkDef.translateCaption(Xlat_0027133, locale);
	lblDefaultFill.translateCaption(Xlat_0010138, locale);
