<Class name="CM_ManualInvoiceLineAgent" id="dd5b68a6-076d-4077-a02c-33ca251cc03e">
    <superclass name="CM_CargoChainFunctionAgent"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="cmtrans"/>
    <JadeMethod name="createInvoiceLine" id="e3e24efa-bc53-45bc-8f9d-48325a883fd2">
        <source>createInvoiceLine(_ccEventMap  : CM_CargoChainEventMapping ;
				  _ti          : CM_TrackedItem;
				  _amount      : Real) : Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 Nov 2019 cnwma1 ChangeRequest 45285: JMT - Cargo Chain API V2 - Process Events (AAT)
10 March 2023  navmv20 TFS 56128 Task 56129: UI - Manual Invoice Lines - Multi TI Invoice Line Type

*/

vars
	manController : CMIF_InvoiceLineManual;
	realInvLine,
	pxyInvLine 	  : CM_InvoiceLine;
	invoice       : CM_Invoice;
	debtor        : CM_Debtor;
	bank          : CM_Bank;
	invType       : CM_InvoiceDesc;
	invLineType   : CM_InvoiceLineDesc;
begin
	
	app.setMyTerminal(_ti.myTerminal);
	invLineType := self.getInvoiceLineDesc(_ccEventMap);
	
	if invLineType = null then
	
		return false;
	endif;
	invType := invLineType.invoiceType;
	debtor  := invLineType.getDebtorFromTI(_ti, null);	
	bank    := invLineType.bank;
	
	invoice := 	self.getInvoice(_ti,invType, debtor);
	if invoice &lt;&gt; null then
		create manController transient;
		manController.quantity   		:= _amount;
		manController.remarks  		:= invLineType.narration; // ### JIRA 33007 10DEC2024 NAVAB1
		//manController.myInvoiceLineType := invLineType; //10 March 2023  navmv20 TFS 56128 Task 56129
		manController.allInvoiceLineTypes.add(invLineType); //10 March 2023  navmv20 TFS 56128 Task 56129
		manController.myInvoice 		:= invoice;
		
		//manController.myTrackedItem		:= _ti; //10 March 2023  navmv20 TFS 56128 Task 56129
		manController.allTrackedItems.add(_ti); //10 March 2023  navmv20 TFS 56128 Task 56129
		manController.chargeTime.setDate(invoice.createdTime.Date);
		
		while true do
			app.myTrxCA.trxCreateInvoiceLineManual(manController, realInvLine, app.myPassport);
			if app.myPassport.trxCompletedOK then
				return true;
			else
				return false;
			endif;
			break;
		endwhile;
	endif;
	return false;
epilog
	delete manController;
end;</source>
        <Parameter name="_ccEventMap" type="CM_CargoChainEventMapping"/>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_amount" type="Real"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getInvoice" id="37154ee1-7f5c-4e3c-afca-12548f43a572">
        <source>getInvoice(_ti 		     : CM_TrackedItem; 
			_invTypeDesc : CM_InvoiceDesc;
			_debtor 	 : CM_Debtor
			):CM_Invoice;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 Nov 2019 cnwma1 ChangeRequest 45285: JMT - Cargo Chain API V2 - Process Events (AAT)
26 April 2023	navmk20	Bug 57663: EUP - Incorrect Statuses Available when copying an invoice
23 May 2023 navtnr20 	Bug 58089: FR | EUP 54086 - Invoicing - Maintenance Enhancements - 070.b
14/08/2023	navkc1	Bug 59803: FR | EUP 53978 - Invoicing - Configuration Enhancements - Invoice Update - missing items
*/

vars
	pxyInvoice,
	invoice 	: CM_Invoice;
	bank        : CM_Bank;
begin
	bank := _invTypeDesc.getBank;
	foreach invoice in  _ti.allInvoices discreteLock do
		if invoice.status &lt;&gt; CM_Invoice.INVOICE_PENDING then
			continue;
		endif;
		if invoice.invoiceType = _invTypeDesc then
			break;
		endif;
		invoice := null;
	endforeach;
	
	if invoice &lt;&gt; null then
		return invoice;
	
	endif;	
	
	// Create Invoice;
	create pxyInvoice transient;
		pxyInvoice.setProxyForCreate(bank,
									_debtor,
									null,
									null,
									_invTypeDesc,
									//false,	// 26.4.2023 navmk20 TFS 57663
									CM_Invoice.INVOICE_PENDING, // 26.4.2023 navmk20 TFS 57663
									true,
									_ti,
									null,	// ### TFS 54565 (54384) 03Oct2022 NAVPW1
									null,	// ### TFS 54565 (54384) 03Oct2022 NAVPW1
									null,	// ### TFS 54565 (54384) 03Oct2022 NAVPW1
									null,	// ### TFS 54565 (54384) 03Oct2022 NAVPW1
									0,
									null,  // ### BUG 56925 07MAR2023 NAVAB1
									bank.myInvoiceProcess,	// 26.4.2023 navmk20 TFS 57663
									null, //navtnr20 23-05-2023 BUG 58089
									null, //14/08/2023	navkc1	Bug 59803
									null, //14/08/2023	navkc1	Bug 59803
									null, //14/08/2023	navkc1	Bug 59803
									null, //14/08/2023	navkc1	Bug 59803
									null, //14/08/2023	navkc1	Bug 59803
									null //14/08/2023	navkc1	Bug 59803
									);
	while true do
		app.myTrxCA.trxCreateInvoiceManual(pxyInvoice,invoice, app.myPassport);
		if app.myPassport.trxCompletedOK then
			break;
		else
			
			return null;
		endif;
		break;
	endwhile;
	return invoice;
epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_invTypeDesc" type="CM_InvoiceDesc"/>
        <Parameter name="_debtor" type="CM_Debtor"/>
        <ReturnType type="CM_Invoice"/>
    </JadeMethod>
    <JadeMethod name="getInvoiceLineDesc" id="2ced8cfd-1a23-4a50-ae6f-9431aafd24aa">
        <source>getInvoiceLineDesc(_ccEventMap :CM_CargoChainEventMapping):CM_InvoiceLineDesc;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 Nov 2019 cnwma1 ChangeRequest 45285: JMT - Cargo Chain API V2 - Process Events (AAT)

*/

vars

	parameters		: JadeDynamicObject;
	invLineDesc : CM_InvoiceLineDesc;
begin
	
	parameters  := _ccEventMap.myParameters;
	invLineDesc := parameters.getPropertyValue("invoiceLineDesc").CM_InvoiceLineDesc;
	return invLineDesc;
epilog

end;</source>
        <Parameter name="_ccEventMap" type="CM_CargoChainEventMapping"/>
        <ReturnType type="CM_InvoiceLineDesc"/>
    </JadeMethod>
</Class>
