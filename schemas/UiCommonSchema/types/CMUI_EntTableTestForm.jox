    <JadeMethod name="chkHasAttachment_doAlignCtrls" id="07b0d170-adc0-4089-909c-ea44b9f81de2">
        <controlMethod name="CMUI_FieldGeneric::doAlignCtrls"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>chkHasAttachment_doAlignCtrls(_fieldGeneric: CMUI_FieldGeneric input) updating;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 July 2009	cnwdap1	Initial creation
*/
vars
	labelLeft	: Real;

begin
	// put button on the right hand side, check box on the left hand side, 
	// and stretch the label to fit in between these two
	self.btnAttachments.move(_fieldGeneric.width-self.btnIsOverDim.width, 0, self.btnAttachments.width, _fieldGeneric.height);
	self.chkAttachments.move(_fieldGeneric.myLabel.width + _fieldGeneric.HORIZONTAL_SPACING, 2, 21, self.chkAttachments.height);
	labelLeft := self.chkAttachments.left + _fieldGeneric.HORIZONTAL_SPACING - 5;
	self.lblAttachments.move(labelLeft, 0, self.btnAttachments.left - labelLeft - 5, _fieldGeneric.height);
	self.lblAttachments.borderStyle := self.lblAttachments.BorderStyle_None;

epilog

end;</source>
        <Parameter name="_fieldGeneric" type="CMUI_FieldGeneric" usage="input"/>
    </JadeMethod>
