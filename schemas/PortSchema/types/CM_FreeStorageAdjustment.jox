<Class name="CM_FreeStorageAdjustment" id="5aca0eff-8f5e-486d-bdc4-0a41ed4fbf3b">
    <superclass name="CM_TITransaction"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="transact"/>
    <PrimAttribute name="additionalStorageDays" id="300e9c75-1a0d-4351-a21b-a534287bee03">
        <embedded/>
        <type name="Integer"/>
        <access>readonly</access>
    </PrimAttribute>
    <PrimAttribute name="changeReason" id="2b09f3f6-7f35-4264-bbf8-f71a8b7c3938">
        <length>61</length>
        <embedded/>
        <type name="String"/>
        <access>readonly</access>
    </PrimAttribute>
    <JadeMethod name="getDisplayStringForAttribute" id="bd35bb0f-9881-469a-a1b1-47632bfcc594">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 September 2012	cnwer1	Initial creation SFW 1295

*/

vars
	details : String;
begin
	if _attrName = ETRow_Details  then
		if self.deleted then
			return self.getDeletedDetails();		// 15/10/18 MAP TFS41191
			
		else
			if self.myTrackedItem &lt;&gt; null then
				return app.getErrorString2(Additional_storage_days_reason,self.additionalStorageDays.asStringJMT, self.changeReason);
			endif;
			
		endif;
							
	else
		return inheritMethod(_attrName, _short);
	endif;

epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="setFromCMIF_TITransactionCntrl" id="ba09a3d6-f565-4110-abb9-cc2fbed93533">
        <updating/>
        <source>setFromCMIF_TITransactionCntrl(_tiTransCntrl: CMIF_FreeStorageAdjustment; _passport: CM_Passport input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 September 2012	cnwer1	Initial creation SFW 1295

*/

vars

begin
	inheritMethod(_tiTransCntrl, _passport);
	
	self.additionalStorageDays:=_tiTransCntrl.additionalStorageDays;
	self.changeReason:=_tiTransCntrl.changeReason;
epilog

end;</source>
        <Parameter name="_tiTransCntrl" type="CMIF_FreeStorageAdjustment"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
</Class>
