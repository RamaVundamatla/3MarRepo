    <JadeMethod name="trxCopyToXlationTable" id="2105f489-1088-46b6-81da-7a8b1fe46686">
        <updating/>
        <source>trxCopyToXlationTable( _xlationTable :CM_XlationTable; _operator :CM_Operator; _passport :CM_Passport input) updating;
//----------------------------------------------------------------
//	Created:	25 May 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
//13 May 2016	cnwrs1	TFS 1987 CargoSubType EDI Xlation
//12 Jun 2023	jlizm1	TFS 58500 add EDI Xlation for Operational Instruction and trailer type
vars
	xlation, newXlation	: CM_Xlation;
	xlationTable		: CM_XlationTable;
	type				: Integer;
	opTerm				: CM_OperatorTerminal;
	terminal			: CM_Terminal;
begin

	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	if _xlationTable = null then
		app.raiseUnexpectedProgramError (self.class.name, method.name, 'No xlation table to copy from');
		return;
	endif;

	if _xlationTable.isSystemXlationTable then
		app.raiseUnexpectedProgramError (self.class.name, method.name, 'Cannot copy system translations');
		return;
	endif;
	
	if _operator = null then
		app.raiseUnexpectedProgramError (self.class.name, method.name, 'Operator expected');
		return;
	endif;
	
	type := _xlationTable.type;
	
	if type = XLATION_TYPE_VOYAGETERMINAL or
		type = XLATION_TYPE_INSTRUCTTERMINAL then
		terminal := _xlationTable.getMyTerminal;
		
		if terminal = null then
			app.raiseUnexpectedProgramError (self.class.name, method.name, 'Terminal expected');
			return;
		endif;
		
		opTerm := _operator.allOperatorTerminals [terminal];
		
		if opTerm &lt;&gt; null then 
			xlationTable := opTerm.allXlationTables[type, null];
		endif;
	else
		xlationTable := _operator.allXlationTables [type, null];
	endif;
	
	beginTransaction;

	foreach xlation in _xlationTable.allInwardTranslations do
		if xlation.isDisabled then
			continue;
		endif;
		
		app.myUtilityCA.utlCreateXlationCopy(xlation, _operator, terminal, xlationTable, opTerm);
	endforeach;
	
	foreach xlation in _xlationTable.allOutwardTranslations do
		if xlation.isDisabled then
			continue;
		endif;
		
		app.myUtilityCA.utlCreateXlationCopy(xlation, _operator, terminal, xlationTable, opTerm);
	endforeach;
epilog
	self.finaliseActivityWithPassport(_passport);
end;</source>
        <Parameter name="_xlationTable" type="CM_XlationTable"/>
        <Parameter name="_operator" type="CM_Operator"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxCopyVessalBayPlanToVoyage" id="39033107-2e33-493f-8547-9a5bbfac915d">
        <updating/>
        <source>trxCopyVessalBayPlanToVoyage(	_voyageBay : CM_Bay input;
								_vessalBay : CM_BayDefn input;
								_currentVoyage : CM_Voyage;
								_passport 	: CM_Passport input) updating;

vars
	aCell : CM_CellDefn;
	aTier : CM_TierDefn;
	aLid : CM_HatchLid;
	structure : CM_CellularVoyageStructure;	
begin

	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	if _currentVoyage &lt;&gt; null then
		structure := _currentVoyage.myCellularVoyageStructure;
	endif;


	beginTransaction;
	// PAR 15971
	foreach aLid in _voyageBay.allHatchLids do
		delete aLid;
	endforeach;
	
	foreach aTier in _voyageBay.allTiersOnDeck do
		delete aTier;
	endforeach;
	foreach aTier in _voyageBay.allTiersUnderDeck do
		delete aTier;
	endforeach;
	foreach aCell in _voyageBay.allCellsOnDeck do
		delete aCell;
	endforeach;
	foreach aCell in _voyageBay.allCellsUnderDeck do
		delete aCell;
	endforeach;
	if structure &lt;&gt; null then
		_voyageBay.CM_BayVoyage.createPlanningStructures(_vessalBay);
		_voyageBay.setBaseBayDataDuringReplace(_vessalBay);	//22 Nov 2013	NDL	Par 32341
		_voyageBay.updateSlotLinks(); 
// AKB NOT NEEDED		_voyageBay.CM_BayVoyage.myCellularVoyageStructure.myVoyage.setDrawingDefinition();
	endif;
	commitTransaction;


epilog
	self.finaliseActivityWithPassport(_passport);

end;</source>
        <Parameter name="_voyageBay" type="CM_Bay" usage="input"/>
        <Parameter name="_vessalBay" type="CM_BayDefn" usage="input"/>
        <Parameter name="_currentVoyage" type="CM_Voyage"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxCreateCargoReleaseFromFile" id="095cb412-8458-4aaf-976e-7577d73553d3">
        <updating/>
        <source>trxCreateCargoReleaseFromFile(	_allRealBulkReleases : CM_BulkReleaseByCodeDict input;
								_allPxyBulkReleases : CM_BulkReleaseByCodeDict;
								_allPxyTis : CM_TISet;
								_passport : CM_Passport input
								)updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 Mar 2019	jlgndl1	Initial creation	TFS 43673
20 Jul 2023	navdap1	TFS 58923 EUP CallOff EDI Data Type / Data Load
*/

vars

	realBulkRelease : CM_BulkRelease;
	pxyBulkRelease : CM_BulkRelease;
	newBulkRelease : CM_BulkRelease;
	pxyTi : CM_TrackedItem;

begin

	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	beginTransaction;
	
	foreach pxyTi in _allPxyTis do
	
		app.myUtilityUA.utlUpdateTrackedItem( pxyTi, null, TI_UPDMODE_NORMAL, null, null, null, _passport );
		
		if _passport.hasErrors then
			break;
		endif;
	
	endforeach;
	
	if _passport.hasErrors then
		return;
	endif;

	foreach pxyBulkRelease in _allPxyBulkReleases discreteLock do
		
		if pxyBulkRelease.pxyGetRealObject = null then		
			app.myUtilityCA.utlCreateBulkRelease ( pxyBulkRelease, newBulkRelease, null, null, null, null, _passport);		// TFS 58923
			if newBulkRelease &lt;&gt; null then
				_allRealBulkReleases.add(newBulkRelease);
			endif;
			
		else			
			app.myUtilityUA.utlUpdateBulkRelease(pxyBulkRelease, null, true, null, null, _passport);						// TFS 58923
			
			if _passport.hasErrors then
				break;
			endif;
			_allRealBulkReleases.add(pxyBulkRelease.pxyGetRealObject);
			
		endif; 
		
		if _passport.hasErrors then
			break;
		endif;
		
	endforeach;
	

epilog

	self.finaliseActivityWithPassport(_passport);

end;</source>
