    <JadeMethod name="displayQuantityMap" id="04a0701e-3d92-4d60-88b4-0632187f4dba">
        <source>displayQuantityMap();
/*
Purpose:			
Date		Who		Reason
19 March 2015	cnwab1	Initial creation
*/

vars
	obj : Object;
	realQM : CM_QuantityMap;
	sb : CM_CargoAllocServiceBroker;
	theReturn, mapType, row : Integer;
	gt : CM_TranMapInvoiceLineGroupType;
	map : CM_TranMapInvoiceLineMapping;
	mapping : CM_TranMapInvoiceLineMapping;
	ild : CM_InvoiceLineDesc;
begin

	if self.myCurrentQuantityRangeMap = null then
		return;
	endif;
	
	
	realQM := self.myCurrentQuantityRangeMap.myQuantityMap;
	
	if realQM &lt;&gt; null then
		// TFS 4271 self.cmbQuantityType.listObject := realQM.myCalculationType;
		// TFS 4271 self.chkChargeZero.value := realQM.chargeZero;
		// TFS 4271 self.optSingle.value := (realQM.mappingType = CM_QuantityMap.MapType_Single);
	endif;

	if not updateMode then
		self.txtFrom.text := "0";
		self.txtTo.text := CM_QuantityRangeMap.MAX_RANGE.Integer.String;
		self.chkMaximum.value := true;
	else
		self.chkMaximum.value := false;
	endif;
	
	if self.myCurrentQuantityRangeMap &lt;&gt; null then
		/*
		foreach row in 1 to self.tblData.rows do
			self.tblData.accessRow(row);
	
			if self.myCurrentQuantityRangeMap.allInvoiceLineMaps.includes(self.tblData.accessedRow.itemObject.CM_InvoiceLineDesc) then
				self.tblData.selectRow(row,true);
			endif;
		endforeach;
		*/
		foreach row in 1 to self.tblData.rows do
			self.tblData.accessRow(row);
			ild := self.tblData.accessedRow.itemObject.CM_InvoiceLineDesc;
			foreach mapping in self.myCurrentQuantityRangeMap.allTMInvoiceLineMappings do // TFS 40620
				if ild = mapping.myTMInvoiceLineDesc then // TFS 40620
			
				//if self.myCurrentQuantityRangeMap.allInvoiceLineMaps.includes(self.tblData.accessedRow.itemObject.CM_InvoiceLineDesc) then
					self.tblData.selectRow(row,true);
				endif;
			endforeach;
		endforeach;

		
		
		
		self.txtFrom.text := self.myCurrentQuantityRangeMap.rangeStart.String;
		self.txtTo.text := self.myCurrentQuantityRangeMap.rangeEnd.String;
		
		// Set the grouping from the first, they are all the same
		foreach map in self.myCurrentQuantityRangeMap.allTMInvoiceLineMappings discreteLock do
			if map.myTMInvoiceLineGroupType.isTypeAll then
				self.optGroupAll.value := true;
			elseif map.myTMInvoiceLineGroupType.isTypeHigh then
				self.optGroupGreatest.value := true;
			elseif map.myTMInvoiceLineGroupType.isTypeLow then
				self.optGroupLeast.value := true;
			endif;
			
			break;
			
		endforeach;
	endif;
	
	// TFS 4271 future storage transactions have a fixed quantity which is set from the storage configuration detail CM_StorageDetail.chargeDays
	// 				the quantity will always be this amount (the first future storage transaction could be 1 day more or less than this based 
	//				on including the first and last days options).
	//				This means that a lot of options on the mapping screen are meaningless, so they are disabled.
	self.grpLines.enabled := false;  // TFS 4271
	self.grpQuantityMap.enabled := false;  // TFS 4271
	self.optSingle.value := true;  // TFS 4271

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doNew" id="e075e40b-e0af-449c-bf3f-e62b346c279c">
        <updating/>
        <source>doNew()  updating;
/*
Purpose:			
Date		Who		Reason
25 May 2015	cnwab1	Initial creation
*/

vars

begin
	self.updateMode := false;
	
	self.txtFrom.text := "";
	self.txtTo.text := "";
	self.chkMaximum.value := false;
	
	self.tblData.deselectAll();

	self.setDescription();
	
	self.setForNew();
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doSave" id="e7b3a141-ec79-4181-aecd-0617f47ef780">
        <updating/>
        <source>doSave(_close : Boolean) updating;
/*
Purpose:			
Date		Who		Reason
19 March 2015	cnwab1	Initial creation
27/01/2016	cnwjre1	Recoded to create quantity map and future storage mappings correctly as required
*/

vars
	isUpdate	: Boolean;
	count	: Integer;
	qm, pxyQM, realqm : CM_QuantityMap;
	qrm,
	pxyQRM : CM_QuantityRangeMap;
	theReturn, mapType : Integer;
	map,
	fsm	: CM_FutureStorageMapping;
	gt : CM_TranMapInvoiceLineGroupType;
	bu : CM_Bank;
begin
	// from 37434 added validation - must have at least one invoice line type - can select VOID if invoice lines are not required
	bu := self.myStorageGroup.getBank();
	isUpdate := self.updateMode;
	
	if self.myCurrentQuantityRangeMap &lt;&gt; null then
		qm := self.myCurrentQuantityRangeMap.myQuantityMap;
		fsm := qm.myFutureStorageMap;
	endif;
	if fsm = null then
		foreach map in self.myStorageGroup.allFutureStorageMappings do
			if map.myStorageDetail = self.myStorageDetail then		
				fsm := map;
				break;
			endif;
		endforeach;
		if fsm = null then
			foreach map in self.myStorageGroup.allFutureStorageMappings do
				if map.myStorageDetail = null then		// the default one created with a new storage group
					fsm := map;
					break;
				endif;
			endforeach;
		endif;
		if fsm &lt;&gt; null then
			qm := fsm.myQuantityMap;
		endif;
	endif;
	
	if updateMode then // UPDATE
		beginLoad;
		pxyQM := qm.pxyCreateUpdateProxy().CM_QuantityMap;
		pxyQRM := self.myCurrentQuantityRangeMap.pxyCreateUpdateProxy().CM_QuantityRangeMap;
		endLoad;
	else // CREATE
		if qm &lt;&gt; null then
			beginLoad;
			pxyQM := qm.pxyCreateUpdateProxy().CM_QuantityMap;
			endLoad;
		else
			create pxyQM transient;
			pxyQM.setMyCalculationType(self.cmbQuantityType.listObject.CM_CalculationType);
		endif;
		// if the default mapping is found with a 0-max VOID range map, use this as the current quantity map and overwrite the details
		//   to avoid creating a second quantity map with the same range and getting a duplicate key exception
		if fsm &lt;&gt; null and
		   fsm.myStorageDetail = null then
			foreach qrm in fsm.myQuantityMap.allQuantityRanges do
				count := count + 1;
			endforeach;
			if count = 1 and
			   qrm.rangeStart = 0 and
			   qrm.rangeEnd = CM_QuantityRangeMap.MAX_RANGE then
				beginLoad;
				pxyQRM := qrm.pxyCreateUpdateProxy();
				endLoad;
				isUpdate := true;
			endif;
		endif;
		if pxyQRM = null then
			create pxyQRM transient;
		endif;
		if fsm = null then
			create fsm transient;
			fsm.setProxy(self.myStorageGroup, null, self.myStorageDetail, null);
		endif;
	endif;
	
	if optSingle.value then
		mapType := CM_QuantityMap.MapType_Single;
	else
		mapType := CM_QuantityMap.MapType_Escalate;
	endif;
	
	if self.optGroupAll.value then
		gt := bu.getInvLineGroupByType(TranMapInvLineGroupTypeAll);
	elseif self.optGroupGreatest.value then
		gt := bu.getInvLineGroupByType(TranMapInvLineGroupTypeHigh);
	elseif self.optGroupLeast.value then
		gt := bu.getInvLineGroupByType(TranMapInvLineGroupTypeLow);
	endif;
	
	if fsm.isTransient then
		pxyQM.setProxy(null,self.chkChargeZero.value, mapType,self.cmbQuantityType.listObject.CM_CalculationType, null);
	else
		pxyQM.setProxy(null,self.chkChargeZero.value, mapType,self.cmbQuantityType.listObject.CM_CalculationType, fsm);
	endif;
	if qm &lt;&gt; null then
		pxyQRM.setProxy(qm, txtFrom.text.Integer, txtTo.text.Integer, 0);
	else
		pxyQRM.setProxy(pxyQM, txtFrom.text.Integer, txtTo.text.Integer, 0);
	endif;
	pxyQRM.setProxyInvoiceLineTypesFS(self.tblData.allSelectedObjects, gt);
	
	while true do
		app.myTrxUA.trxUpdateInvoiceFutureStorage(isUpdate, pxyQM,realqm, pxyQRM, fsm, self.myStorageDetail); // ### TFS CR 58022 TASK 58023 18MAY2023 NAVAB1 - realqm
 
		if app.myPassport.trxCompletedOK then
			global.beep;
			if _close then
				self.unloadForm();
			endif;
		else
			theReturn := app.showErrorWarningDialog(app.getErrorString(Allocation),  app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   theReturn = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			return;
		endif;
		break;
	endwhile;


epilog
	if global.isValidObject(pxyQRM) then
		delete pxyQRM;
	endif;
	if global.isValidObject(pxyQM) then
		delete pxyQM;
	endif;
	if fsm.isTransient then
		delete fsm;
	endif;
end;</source>
        <Parameter name="_close" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setDescription" id="3621fc69-4d5c-4865-8bce-884715b7586c">
        <source>setDescription();
/*
Purpose:			
Date		Who		Reason
25 May 2015	cnwab1	Initial creation
*/

vars

begin
	if self.myStorageGroup &lt;&gt; null then
		self.lblDescription.caption := self.myStorageGroup.description;
	endif;

	if updateMode then
		self.lblDescription.caption := self.lblDescription.caption &amp; " " &amp; app.getErrorString(InvCargoAllocMapUPDATE);
	else
		self.lblDescription.caption := self.lblDescription.caption &amp; " " &amp; app.getErrorString(InvCargoAllocMapNEW);
	endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setForNew" id="38d71e8e-6fa4-4f9e-862a-d740b8b14f0b">
        <source>setForNew();
/*
Purpose:			
Date		Who		Reason
25 May 2015	cnwab1	Initial creation
17 Jan 2018 cnwma1  Bug #36579: 1090 on Future Storage Invoice Line Mapping screen
*/

vars
	qm : CM_QuantityMap;
	qrm : CM_QuantityRangeMap;
	sb : CM_FutureStorageMapping;

begin
	if self.updateMode then
		return;
	endif;
	
	// TFS 4271 future storage transactions have a fixed quantity which is set from the storage configuration detail CM_StorageDetail.chargeDays
	// 				the quantity will always be this amount (the first future storage transaction could be 1 day more or less than this based 
	//				on including the first and last days options).
	//				This means that a lot of options on the mapping screen are meaningless, so they are disabled.
	
// TFS 4271	self.cmbQuantityType.listIndex := 1;
	self.chkChargeZero.value := false;
	self.optSingle.value := false;
	self.txtFrom.text := "0";
	self.txtTo.text := CM_QuantityRangeMap.MAX_RANGE.Integer.String;
	self.chkMaximum.value := true;
	self.optGroupAll.value := true;
	self.optSingle.value := true;  // TFS 4271
	self.grpQuantityMap.enabled := false;  // TFS 4271
	self.grpLines.enabled := false;  // TFS 4271
	
	
	// TFS 7496 set a default
	sb := self.myStorageMapping;
	if sb &lt;&gt; null then
		qm := sb.myQuantityMap;
		if qm &lt;&gt; null then
			qrm := qm.allQuantityRanges.last;
			if qrm &lt;&gt; null  and qrm.rangeEnd &lt; CM_QuantityRangeMap.MAX_RANGE then //cnwma1 17/01/2018 cnwma1  Bug #36579
					self.txtFrom.text := (qrm.rangeEnd + 1).String;
			endif;
		endif;
	endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setupForm" id="ae11d18e-bfc4-4e11-9ab1-7ba7084fa63f">
        <updating/>
        <source>setupForm() updating;
/*
Purpose:	 // PAR 36275		
Date		Who		Reason
19 March 2015	cnwab1	Initial creation
*/

vars

begin

	inheritMethod();
	
	
	self.setDescription();

	self.setForNew();
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="translateForm" id="d2902464-269b-4c5b-a3ae-1f562d642edf">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 21 May 2015.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0020691, locale);
end;</source>
    </JadeMethod>
</GUIClass>
