    <JadeMethod name="setProxyDeckItemLayouts" id="34688e07-6871-45bc-a4ff-6ed40b40d1e4">
        <updating/>
        <source>setProxyDeckItemLayouts(_allPointGraphics : ObjectArray) updating;
/*
Purpose:	Pass in orphaned items and parent them to me		
Date		Who		Reason
12 April 2011	cnwab1	Initial creation
*/

vars
	obj : Object;
	tmpItem : CM_DeckItemLayout;
begin
	if not self.isTransient then
		return;
	endif;
	
	foreach obj in _allPointGraphics discreteLock do
		tmpItem := obj.CM_DeckItemLayout;

		tmpItem.setMyDeckLayer(self);
	endforeach;
	self.causeEvent(EVENT_RORO_LAYER_UPDATE,true,null);
epilog

end;</source>
        <Parameter name="_allPointGraphics" type="ObjectArray"/>
    </JadeMethod>
