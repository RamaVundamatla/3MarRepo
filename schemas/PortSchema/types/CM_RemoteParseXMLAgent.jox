    <JadeMethod name="createJobListQueryDetail" id="e96a0a04-a770-4571-9d1f-c3f8e8314bae">
        <updating/>
        <source>createJobListQueryDetail(_jobListQueryHdr: CM_RemoteJobListQueryHdr input): Boolean updating;

vars

	itemList	: String;
	canContinue	: Boolean;
	huge		: HugeStringArray;
	oid			: String;
	list		: CnEcXmlStructureInstance;

begin

	on SystemException do self.handleException(exception, canContinue);
	
	canContinue := true;	
	list		:= self.xmlStruct.findStructure(XML_ITEMLST);
	if list &lt;&gt; null then
		itemList := list.tagData;
		create huge transient;
		itemList.parseCSV(huge);
		_jobListQueryHdr.setProxyForJobListQueryHdr(huge);
	endif;

epilog

	delete huge;
	return canContinue;
end;</source>
        <Parameter name="_jobListQueryHdr" type="CM_RemoteJobListQueryHdr" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="createJobQueryDetail" id="1634ba52-f2f5-4a36-a19c-661347cb1781">
