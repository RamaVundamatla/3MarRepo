    <JadeMethod name="doDeleteLocation" id="3fd2cd56-3774-4bb9-865d-43c3add09ddb">
        <source>doDeleteLocation();
//12 February 2009	cnwdw1	
//
vars

begin
	if self.tblLocation.row &lt;&gt; 0 then
