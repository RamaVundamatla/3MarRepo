    <JadeMethod name="init" id="f9b6b6c3-59fe-48eb-bed6-6d91e252d0c4">
        <updating/>
        <source>init() updating;
/*
----------   ----------  --------------------------------------------------
Created:	25 October 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	row			: Integer;
begin
	//self.initCombos();
	// CCMS SFW1066 PAR20321 - Recording Damage Details Changes.
	self.initCombosNew();
	
	self.rows := 0;
	self.columns := 5;
	self.fixedColumns := 0;
	
	self.addItem('Pos' &amp; Tab &amp; 'Damage' &amp; Tab &amp; 'Severity' &amp; Tab &amp; 'New' &amp; Tab &amp; 'Qty');
	
	self.fixedRows := 1;
	self.accessColumn(1).width := 45;
	self.accessColumn(3).width := 55;
	self.accessColumn(4).width := 25;
	self.accessColumn(5).width := 25;
	
	self.addNewRow();
	
	self.height := self.MAX_TABLE_HEIGHT;
	self.scrollBars := self.ScrollBar_Vertical;
	
end;





</source>
    </JadeMethod>
    <JadeMethod name="initCombos" id="03f5e4c7-3647-423e-a933-5afd3c6647fa">
        <source>initCombos() protected;
/*
----------   ----------  --------------------------------------------------
Created:	21 September 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	damageDef			: CM_DamageDefinitionCode;
	damageCodeDict		: MobileHandHeldThin::CM_DamageDefinitionByCodeDict;
	severity			: Integer;
	cmb					: ComboBox;
	
	a	: HandHeldGateGuiAgent;
begin
	/*
	// crap code to allow to run from painter
	if app.myHandHeldGuiAgent = null then
		create a transient;
		app.setPropertyValue('myHandHeldGateGuiAgent', a);
	endif;
	*/
	
	
	cmb := self.myCmbPosition;
	cmb.clear();
	cmb.style := ComboBox.Style_DropDownList;
	cmb.addItem(null);
	//no global constants from port schema can travel with the package so these are literals unfortunately
	cmb.itemData[cmb.addItem(app.myHandHeldGuiAgent.getDamageDescrForLoc(1))] := 1; //DamageLocation_Left;
	cmb.itemData[cmb.addItem(app.myHandHeldGuiAgent.getDamageDescrForLoc(2))] := 2; //DamageLocation_Right;
	cmb.itemData[cmb.addItem(app.myHandHeldGuiAgent.getDamageDescrForLoc(3))] := 3; //DamageLocation_Top;
	cmb.itemData[cmb.addItem(app.myHandHeldGuiAgent.getDamageDescrForLoc(4))] := 4; //DamageLocation_Bottom;
	cmb.itemData[cmb.addItem(app.myHandHeldGuiAgent.getDamageDescrForLoc(5))] := 5; //DamageLocation_Front;
	cmb.itemData[cmb.addItem(app.myHandHeldGuiAgent.getDamageDescrForLoc(6))] := 6; //DamageLocation_Back;
	cmb.itemData[cmb.addItem(app.myHandHeldGuiAgent.getDamageDescrForLoc(7))] := 7; //DamageLocation_Back;
	
	cmb := self.myCmbCode;
	cmb.clear();
	cmb.style := ComboBox.Style_DropDownList;
	cmb.addItem(null);
	damageCodeDict := app.myHandHeldGuiAgent.getDamageDefintionCodes();
	
	foreach damageDef in damageCodeDict do
		cmb.itemObject[cmb.addItem(damageDef.code)] := damageDef;
	endforeach;

	
	cmb := self.myCmbSeverity;
	cmb.clear();
	cmb.style := ComboBox.Style_DropDownList;
	cmb.addItem(null);
	foreach severity in 1 to 5 do //DamageSeverity_MAX = 6 in portschema
		cmb.itemData[cmb.addItem(severity.String)] := severity;
	endforeach;
	
end;


</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="initCombosNew" id="fec99051-3c23-4cdb-90a2-f92fac60fb16">
        <source>initCombosNew() protected;
//----------------------------------------------------------------------
//  Created by cnwsh3
//	Date 29 July 2009
//
// Implemented version: 7.7.3
// CCMS SFW1066 PAR20321 - Recording Damage Details Changes.
//----------------------------------------------------------------------
vars
	damageDef			: CM_DamageDefinitionCode;
	damageCodeDict		: MobileHandHeldThin::CM_DamageDefinitionByCodeDict;
	severity			: Integer;
	cmb					: ComboBox;
	damagePosition		: CM_DamagePosition;
	damagePosDict		: CM_DamagePositionByCodeDict;
begin
	//Populate Damage Positions combo
	cmb := self.myCmbPosition;
	cmb.clear();
	cmb.style := ComboBox.Style_DropDownList;
	cmb.addItem(null);
	// CCMS SFW1066 PAR20321 - Recording Damage Details Changes.
	//Used to use Integers only. Softened to allow user defined damage locations.
	damagePosDict := app.myHandHeldGuiAgent.getDamagePositionDict();
	foreach damagePosition in damagePosDict do
		cmb.itemObject[cmb.addItem(damagePosition.code)] := damagePosition;	
	endforeach;
	
	//Populate Damage Code combos
	cmb := self.myCmbCode;
	cmb.clear();
	cmb.style := ComboBox.Style_DropDownList;
	cmb.addItem(null);
	damageCodeDict := app.myHandHeldGuiAgent.getDamageDefintionCodes();
	
	foreach damageDef in damageCodeDict do
		cmb.itemObject[cmb.addItem(damageDef.code)] := damageDef;
	endforeach;
	
	//Populate Damage Severity combo
	cmb := self.myCmbSeverity;
	cmb.clear();
	cmb.style := ComboBox.Style_DropDownList;
	cmb.addItem(null);
	foreach severity in 1 to 5 do //DamageSeverity_MAX = 6 in portschema
		cmb.itemData[cmb.addItem(severity.String)] := severity;
	endforeach;
	
end;
</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="queryRowColChg" id="7d6bfdf3-b584-4cdb-b954-62785d1c2a84">
        <controlMethod name="Table::queryRowColChg"/>
