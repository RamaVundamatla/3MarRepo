    <JadeMethod name="setFromCMIF_TIUpdateController" id="df119480-3fc0-47b7-b4b2-ef2336f9fb57">
        <updating/>
        <source>setFromCMIF_TIUpdateController(_tiUpdateCntrlr: CMIF_TIUpdateController; _passport : CM_Passport) updating;
//--------------------------------------------------------------
//Created: 07 October 2002 By: cnwgd1
//--------------------------------------------------------------
vars

begin
	inheritMethod(_tiUpdateCntrlr, _passport);
	self.myVoyage := _tiUpdateCntrlr.myVoyage;
end;</source>
        <Parameter name="_tiUpdateCntrlr" type="CMIF_TIUpdateController"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="validateCMIF_TIUpdateCntrlr" id="c2c485d4-32df-48fe-a24c-b2ea192e9084">
        <source>validateCMIF_TIUpdateCntrlr(_tiUpdateCntrlr: CMIF_TIUpdateController; _passport : CM_Passport input): Boolean;
//--------------------------------------------------------------
//Created: 08 October 2002 By: cnwgd1
//--------------------------------------------------------------
vars

begin
	if (not inheritMethod(_tiUpdateCntrlr, _passport)) then
		return false;
	endif;
	
	if _tiUpdateCntrlr.myVoyage = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Null myVoyage. Contact Developer.');
		return false;
	endif;
	
epilog
	return _passport.noErrors;
end;</source>
        <Parameter name="_tiUpdateCntrlr" type="CMIF_TIUpdateController"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
