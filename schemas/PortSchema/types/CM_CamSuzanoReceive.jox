    <JadeMethod name="includeEvent" id="1b49e1b7-9f35-49aa-af40-f71ae0e0a607">
        <source>includeEvent(_eventTransaction: CM_EventTransaction; _camProtocol: CM_CamProtocol;  _camAgent: CM_CamControllerAgent): Boolean;
//
//20 Apr 2016	cnwrs1	Par 37788 TFS Came 1875 Events does not check cam group operators nor cargotype list
//
vars
	firstTI : CM_TrackedItem;
    theVisitRecord : CM_VehicleVisitRecord;
	theVoyage : CM_Voyage;
	tiTransaction : CM_TITransaction;
	result : Boolean;
begin
	if _eventTransaction.type = EVT_TruckDeparture then // Paper-only
 		theVisitRecord := _eventTransaction.getVehicleVisit;
		if theVisitRecord &lt;&gt; null then
			firstTI := theVisitRecord.allReceivedTrackedItems.first.CM_TrackedItem; // cnwgb1 PAR 35989 23.04.2015 
		endif;
    elseif  _eventTransaction.type = EVT_VoyageDeparture  then //Pulp-only
        theVoyage := _eventTransaction.getVoyage();
        foreach tiTransaction in theVoyage.allTITransactionsByTypeDT do
            if tiTransaction.isKindOf(CM_ReceiveShip) then
                firstTI := tiTransaction.myTrackedItem;
				break;
			endif;
		endforeach;
	endif;
	if firstTI &lt;&gt; null then
		if not _camProtocol.includeCargoType(firstTI.cargoType, _eventTransaction, _camAgent, _camAgent.logExcludedTransactions) then
			if _camAgent.logExcludedTransactions then
				_camAgent.logReasonForExclusion(_eventTransaction, 'Event transaction has incorrect cargotype');
			endif;
			return false;
		endif;
		if not _camProtocol.isCAMGroupMatchEvent(_eventTransaction, firstTI, _camAgent, _camAgent.logExcludedTransactions) then
			if _camAgent.logExcludedTransactions then
				_camAgent.logReasonForExclusion(_eventTransaction, 'Event transaction does not match cam group');
			endif;
			return false;
		endif;
	endif;
	return true;
end;
</source>
        <Parameter name="_eventTransaction" type="CM_EventTransaction"/>
        <Parameter name="_camProtocol" type="CM_CamProtocol"/>
        <Parameter name="_camAgent" type="CM_CamControllerAgent"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isEventType" id="e63d9b6e-4261-433e-a321-96b10919716f">
        <source>isEventType(): Boolean;
//
///11 Nov 2014	cnwrs1	 CCMS 2405 - Alabama Steel Cams
//
vars

begin
	return true;
end;
</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isEventTypeToBeProcessed" id="2e44635b-f441-4bbb-b7a6-c60e365010db">
        <source>isEventTypeToBeProcessed(_camProtocol: CM_CamProtocol; _trans: CM_EventTransaction): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 September 2014	cnwgb1	Initial creation
//23 Feb 2015	cnwrs1	Par 35738 - doesn't handle some test data
//23 Apr 2015	cnwgb1	PAR 35989 - Truck Departures
*/

vars
	result : Boolean;

begin
	result := inheritMethod(_camProtocol, _trans);
	if  result and
		_trans.type = EVT_VoyageDeparture and 
		_trans.getVoyage() = null then 
			return false; 
	endif;
	return result;

epilog

end;</source>
        <Parameter name="_camProtocol" type="CM_CamProtocol"/>
        <Parameter name="_trans" type="CM_EventTransaction"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="postSpecialFileName" id="8af736e3-8405-4366-a853-e3c2fc55e1b5">
        <source>postSpecialFileName(_camTaskHistory: CM_CamTaskHistory);
//
//19 Oct 2015	cnwrs1	Par37064 special file name
//27 Oct 2015	cnwrs1	Par37082 special file name longer than 30 chars
//17 Nov 2015	cnwrs1	Par37191 worded file name
//
vars
	xmlString : String;
	xmlDoc : JadeXMLDocument;
	xmlParser : JadeXMLDocumentParser;
	xmlElement : JadeXMLElement;
	fileName : String;
	camTaskHistory : CM_CamTaskHistory;
	recID : String;
	recInvoice : String;
	recMovementDate : String;
	pos1 : Integer;
	pos2 : Integer;
begin
	on JadeXMLException do self.handleXMLExceptions(exception);
	xmlString := _camTaskHistory.getRawDataString();
	if xmlString = null then 
		return;
	endif;
	create xmlParser transient;
	create xmlDoc transient;
	xmlParser.parseDocumentString(xmlDoc,xmlString);
	xmlElement := xmlDoc.findElementByTagName("rec:ID");
	if xmlElement &lt;&gt; null then
		recID := xmlElement.textData;
		if recID &lt;&gt; null then
			xmlElement := xmlDoc.findElementByTagName("rec:Movement_Date");
			if xmlElement &lt;&gt; null then
				recMovementDate := xmlElement.textData;
				xmlElement := xmlDoc.findElementByTagName("rec:Invoice");
				if xmlElement &lt;&gt; null then
					recInvoice := xmlElement.textData;
					if recInvoice &lt;&gt; null then
						pos1 := 1;
						pos2 := recID.pos(recMovementDate, pos1);
						if pos2 &gt; 0 then
							fileName := recID[1:2]&amp;recInvoice&amp;recID[pos2:recID.length];
						else
							fileName := recID[1:2]&amp;recInvoice&amp;recID[13:14];
						endif;
					else
						fileName := recID;
					endif;
				else
					fileName := recID;
				endif;
			else
				fileName := recID;
			endif;
		endif;
	endif;
	if fileName &lt;&gt; null then
		camTaskHistory := _camTaskHistory;
		camTaskHistory := _camTaskHistory;
		fileName := fileName.removeInvalidChars;
		if fileName[1:2] = "RW" then
			fileName := "ReceiveWarehouse"&amp;fileName[3:end];
		elseif fileName[1:2] = "LV" then
			fileName := "LoadingVehicle"&amp;fileName[3:end];
		endif;
		if fileName.length &lt; 56 then
			camTaskHistory.setFileName(fileName&amp;".xml");
		else
			camTaskHistory.setFileName(fileName[1:56]&amp;".xml");
		endif;
	endif;
epilog
	delete xmlDoc;
	delete xmlParser;
end;
</source>
        <Parameter name="_camTaskHistory" type="CM_CamTaskHistory"/>
    </JadeMethod>
    <JadeMethod name="processEvent" id="6fcdff97-28e4-420c-a5fa-eaf5a36b0a45">
        <updating/>
        <source>processEvent(_transaction: CM_EventTransaction; _camProtocol: CM_CamProtocol; _camAgent: CM_CamControllerAgent input; _camFile: CM_CamFile input) updating;
/*

Purpose:Create the XML Receive Warehouse Message			

Date		Who		Reason
14.7.2014	cnwgb1	Initial creation CCMS DPH 2346 PAR 34561
1.10.2014	cnwgb1  Make Event-based for both Paper and Pulp
9.12.2014 	cnwer1	CCMS 1405 refactoring changes
23.04.2015	cnwgb1	PAR 35989 
24 Aug 2015	cnwrs1	Par 36680/36801 Single transation not working for event files
31 Aug 2015	cnwrs1	Par 36837 no data being produced for Truck Depature
*/
//08 Dec 2015	cnwrs1	Par 37285 crashing in DPH test
//18 Dec 2015	cnwrs1	Par 37340 Cams is crashing with 4013 error (Result of expression overflows Integer precision)
constants 
    Namespace = "http://CECOL.suzano.com.br/LE/Receive";
vars
   	firstTI : CM_TrackedItem;
	ti : CM_TrackedItem;
    ediCargo : CM_TrackedItem;
    tiSet : CM_TISet; 
    camMessage : CM_CamMessage;
    strMsg : String;
    xmlDoc : JadeXMLDocument;
    rootElem : JadeXMLElement;
    attrib : JadeXMLAttribute;
    element : JadeXMLElement;
    itemElement : JadeXMLElement;
    posStart, posEnd : Integer;
    strID : String;
    orderNum : Integer64;
    eventType : CM_EventType;
    theVisitRecord : CM_VehicleVisitRecord;
    theVoyage : CM_Voyage;
    tiTransaction : CM_TITransaction;
    first : Boolean;
    shippingID : String;
    found : Boolean;
    
begin
	_camAgent.writeDebugLog(class.name&amp;'::'&amp;method.name&amp;" process "&amp;_transaction.type.asStringJMT);
    
    if _transaction = null then
		if _camAgent.logExcludedTransactions then
			_camAgent.logReasonForExclusion(_transaction, 'There is no Event transaction');
			return;
		endif;
	endif;
    
    create tiSet transient; 
	if _transaction.type = EVT_TruckDeparture then // Paper-only
 		theVisitRecord := _transaction.getVehicleVisit;
		if theVisitRecord &lt;&gt; null then
			firstTI := theVisitRecord.allReceivedTrackedItems.first.CM_TrackedItem; // cnwgb1 PAR 35989 23.04.2015 
		endif;
		if firstTI = null then
			if _camAgent.logExcludedTransactions then
				_camAgent.logReasonForExclusion(_transaction, 'There is no Cargo associated with the Vehicle Visit (or no Visit Record)');
			endif;
			return;
		endif;
        shippingID := firstTI.remarks;
		foreach ti in theVisitRecord.allReceivedTrackedItems do
			if not tiSet.includes(ti) then
                tiSet.add(ti);
			endif;
 		endforeach;
//        theVisitRecord.allReceivedTrackedItems.copy(tiSet);  // cnwgb1 PAR 35989 23.04.2015
		if tiSet.isEmpty() then
			if _camAgent.logExcludedTransactions then
				_camAgent.logReasonForExclusion(_transaction, 'There was no Cargo discharged from the Truck');
			endif;
			return;
		endif;
    elseif  _transaction.type = EVT_VoyageDeparture  then //Pulp-only
        theVoyage := _transaction.getVoyage();
        shippingID := theVoyage.myOperator.getXlationForeignCode(theVoyage.code, XLATION_TYPE_VOYAGETERMINAL, found); 
        foreach tiTransaction in theVoyage.allTITransactionsByTypeDT do
            if tiTransaction.isKindOf(CM_ReceiveShip) and
			   (not tiSet.includes(tiTransaction.myTrackedItem)) then
                tiSet.add(tiTransaction.myTrackedItem);
            endif;
        endforeach;
		if tiSet.isEmpty() then
			if _camAgent.logExcludedTransactions then
				_camAgent.logReasonForExclusion(_transaction, 'There was no Cargo discharged from the Voyage');
			endif;
			return;
		endif;
    else
		if _camAgent.logExcludedTransactions then
			eventType := app.myRoot.allEventTypesByType[_transaction.type];
			if eventType &lt;&gt; null then
				strMsg := eventType.name;
			else
				strMsg := _transaction.type.asStringJMT;
			endif;
			_camAgent.logReasonForExclusion(_transaction, 'The Event '&amp;strMsg&amp;' is not a Truck or a Voyage Departure Event');
		endif;
		return;
    endif;
	
    
	camMessage := self.getCamMessage(_camFile, null, null, CODECO_GATEOUT, _camProtocol.singleContainerPerBGM);	
    create xmlDoc transient;
    xmlDoc.outputDeclaration := true;
    rootElem := xmlDoc.addElementNS(Namespace, "rec:ReceiveWarehouse");
    rootElem.addAttribute("xmlns:rec", Namespace );
    element := rootElem.addElementNS(Namespace, "rec:ID");
    element.addText("RW" &amp; shippingID.padLeadingZeros(10) &amp; _transaction.createdTime.formatAsYYYYMMDDHHmmSS());
    element := rootElem.addElementNS(Namespace, "rec:Movement_Date");
    element.addText( _transaction.createdTime.date.formatAsYYYYMMDD);
    element := rootElem.addElementNS(Namespace, "rec:Dest_SL");
    element.addText("4103");
    first := true;
    foreach ediCargo in tiSet do
        if first then
            element := rootElem.addElementNS(Namespace, "rec:Invoice");
            element.addText(ediCargo.invoiceNumber);
            first := false;
        endif;
        itemElement := rootElem.addElementNS(Namespace, "rec:Items_Invoice");
        element := itemElement.addElementNS(Namespace, "rec:Item_Order");
        strID := ediCargo.id;
        posStart := 1;
        ediCargo.id.scanUntil("-", posStart);
        if posStart &gt; 0 then
            posEnd := posStart+1;
            strID := ediCargo.id.scanUntil("-", posEnd);
            orderNum := strID.asInteger64JMT;
            element.addText(orderNum.stringWithLeadingZeros(6));
        else
            element.addText("0000001");
        endif;
        element := itemElement.addElementNS(Namespace, "rec:Storage_Bin");
        element := itemElement.addElementNS(Namespace, "rec:NB_Unit");
        element := itemElement.addElementNS(Namespace, "rec:Status");
        element := itemElement.addElementNS(Namespace, "rec:BarCode");
        if ediCargo.alternativeId &lt;&gt; null then
            element.addText(ediCargo.alternativeId);
        else
            element.addText(ediCargo.id);
        endif;
    endforeach;
    element := rootElem.addElementNS(Namespace, "rec:Nationalized");
    element.addText( "N");
    element := rootElem.addElementNS(Namespace, "rec:End_Receive");
    element.addText("Y");

    strMsg := xmlDoc.writeToString();
    self.addMessage(camMessage.group3, strMsg );
    
epilog
    delete xmlDoc;
    delete tiSet;
end;</source>
        <Parameter name="_transaction" type="CM_EventTransaction"/>
        <Parameter name="_camProtocol" type="CM_CamProtocol"/>
        <Parameter name="_camAgent" type="CM_CamControllerAgent" usage="input"/>
        <Parameter name="_camFile" type="CM_CamFile" usage="input"/>
    </JadeMethod>
</Class>
