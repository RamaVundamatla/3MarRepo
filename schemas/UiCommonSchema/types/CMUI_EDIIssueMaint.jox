    <JadeMethod name="addRowToTable" id="985c494b-7a51-4da1-b31e-76f79bf1431b">
        <source>addRowToTable(_issue : CM_EDIIssue);
/*
Purpose:	

Date		Who		Reason
10 July 2024	navab1	CR 64617 TASK 64638
*/

vars

	theDataLine : String;
	docTypeColumn: Integer;
	custDocType	: CM_CustomDocumentType;
	row			: Integer;
begin
	theDataLine := _issue.getAttributeStringForDefArray(self.tblData.allTblDataEntRows);
	row := self.tblData.addItem(theDataLine); 
	self.tblData.accessRow(row).itemObject := _issue;
	self.doNotableAdd(_issue);
	

epilog

end;</source>
        <Parameter name="_issue" type="CM_EDIIssue"/>
    </JadeMethod>
