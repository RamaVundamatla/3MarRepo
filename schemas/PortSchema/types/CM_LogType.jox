    <JadeMethod name="setForCreate" id="db105fb3-4fb6-4b00-8a80-a243b53beff3">
        <updating/>
        <source>setForCreate(pProxy: CM_LogType) updating;
// ---------------------------------------------------------------------------
// Created:     12 March 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
