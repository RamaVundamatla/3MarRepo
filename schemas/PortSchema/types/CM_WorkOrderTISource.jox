    <JadeMethod name="getTotalWithoutRBT" id="62d28d0d-f1d0-47fa-9f9c-759925705600">
        <source>getTotalWithoutRBT() : Integer;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
22 January 2010	cnwrd1	Initial creation

*/

vars
	result : Integer;
	tiArray : HugeStringArray;
	aBooking : CM_BookingRef;
	aBulkRel : CM_BulkRelease;
	aWorkOrder 	: CM_WorkOrder;
	invalidWO : Boolean;
begin

	on Exception do app.handleDeletedObject(exception, aWorkOrder, invalidWO); 

	result := 0;
	
	//need to step through all my source items and add up !
	
	//1st titextlist:
	create tiArray transient;
	self.getTIsAsStringArray(tiArray);
	
	result := result + tiArray.size;

	// now each booking:
	foreach aBooking in self.allBookings do	
		result := result + aBooking.getTotalQuantity();
	endforeach;
	
	// now bulk releases
	foreach aBulkRel in self.allBulkReleases do
		result := result + aBulkRel.getTotalRequested();
	endforeach;
	
	foreach aWorkOrder in self.allSourceWorkOrders do
		result := result + aWorkOrder.CM_WorkOrderTI.getTotalRequired();
	endforeach;
	

	return result;
	
epilog
	delete tiArray;
end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getWorkOrder" id="4e8418f6-0c84-4ffe-8815-78a50098d404">
        <source>getWorkOrder() : CM_WorkOrder;
// -----------------------------------------------------------------------------
// Created:		19 August 2009 by consw1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//
// -----------------------------------------------------------------------------

vars

begin
	if self.myParent = null then
		return null;
	elseif CM_WorkOrder.hasInstance( self.myParent ) then
		return self.myParent.CM_WorkOrder;
	elseif CM_WorkOrderDtl.hasInstance( self.myParent ) then
		return self.myParent.CM_WorkOrderDtl.myParent;
	endif;
	
	app.raiseCMException3(UNEXPECTED_PROGRAM_ERROR, self.class.name, method.name, 'Unexpected Parent Reference', null, null);
	
epilog

end;</source>
        <ReturnType type="CM_WorkOrder"/>
    </JadeMethod>
    <JadeMethod name="hasNonIDSource" id="d00d6df8-1c70-42b3-aed0-e9d83c23d241">
        <source>hasNonIDSource() : Boolean;

/*

Purpose: 	To identify if the source only contains cargo ID's (no other sources). 
			Not aactgualy intrested if we actualy have cargo ID's.

Parameters:			

Return Value:		


Date		Who		Reason
14 December 2009	cnwrd1	Initial creation

*/

vars
	result : Boolean;
begin

	result := false; //ok default but
	
	if not self.allBookings.isEmpty then
		result := true;
	endif;
	
	if not self.allWORequestByType.isEmpty then
		result := true;
	endif;
	
	if not self.allBulkReleases.isEmpty then
		result := true;
	endif;
	
	if not self.allSourceWorkOrders.isEmpty then
		result := true;
	endif;
	
	return result;
	
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="hasRBTToAction" id="2f962496-b7e5-4ced-84d5-8db2dcc1d6ef">
        <source>hasRBTToAction() : Boolean ;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
12 November 2009	cnwrd1	Initial creation

*/

vars
	value : Boolean;
	rbt : CM_WorkOrderRequestByType;
begin

	value := false; //default but hey
	
	foreach rbt in self.allWORequestByType do
		if rbt.hasCargoToAction() then
			value := true;
		endif;
	endforeach;

	return value;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isSourceForPack" id="f127ad79-429d-4ae0-8c2e-3969e9abf81d">
        <source>isSourceForPack():Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 Sep 2021 navma1 ChangeRequest 51002: MTN - Web Portal Cargo Work Orders

*/

vars

begin

	if self.myParent &lt;&gt; null and self.myParent.isKindOf(CM_WodPack) then
		return true;
	endif;
	
	return false;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="populateSourceDisplayTable" id="a1e990dc-7e5c-4f39-83f7-3222ee97ba5f">
        <source>populateSourceDisplayTable( _table : Table io);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
15/12/2009	cnwrd1	Initial creation
*/

vars
	bookingRef : CM_BookingRef;
	bulkRelease : CM_BulkRelease;
	request : CM_WorkOrderRequestByType;
	workOrder : CM_WorkOrder;
	bookingRefStr, bulkReleaseStr, requestStr, workOrderStr, display : String;
	invalidWO : Boolean;
	titext : String;
begin

	on Exception do app.handleDeletedObject(exception, workOrder, invalidWO); 
	
	_table.rows:= 0;
		
		if self.tiTextList &lt;&gt; null then
			display := "Cargo ID's : " &amp; self.tiTextList;
			_table.addItem(display);
		endif;
	
		foreach bookingRef in self.allBookings do
			bookingRefStr := 'Booking :' &amp; bookingRef.bookingReference;		
			_table.accessRow(_table.addItem(bookingRefStr)).itemObject := bookingRef;
		endforeach;
		
		foreach bulkRelease in self.allBulkReleases do 
			bulkReleaseStr := 'Release :' &amp; bulkRelease.code;		
			_table.accessRow(_table.addItem(bulkReleaseStr)).itemObject := bulkRelease;		
		endforeach;
		
		foreach request in self.allWORequestByType do 
			requestStr := 'Request :' &amp; request.getListDisplay();		
			_table.accessRow(_table.addItem(requestStr)).itemObject := request;					
		endforeach;
		
		foreach workOrder in self.allSourceWorkOrders do 
			workOrderStr := 'Work Order :' &amp; workOrder.id;		
			_table.accessRow(_table.addItem(workOrderStr)).itemObject := workOrder;					
		endforeach;
	

epilog

end;</source>
        <Parameter name="_table" type="Table" usage="io"/>
