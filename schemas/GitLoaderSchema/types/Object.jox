<Class name="Object">
    <JadeMethod name="cnGetInstanceId64" id="58cb8ee5-306e-445f-af9f-955909d6df6a">
        <source>cnGetInstanceId64(pObject : Object) : Integer64;

vars
	posn 	: Integer;
	
	str		: String;
begin
	str := self.getOidStringForObject(pObject);
	posn := str.reversePos(".") + 1;
	return str[posn : end].Integer64;
end;</source>
        <Parameter name="pObject" type="Object"/>
        <ReturnType type="Integer64"/>
    </JadeMethod>
</Class>
