<Class name="CM_VehicleBookings" id="0e06832e-c4fa-466c-9bff-ea31ad8cfd0d">
    <superclass name="CM_Object"/>
    <transient/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <abstract/>
    <DbClassMap file="vehicleSchedule"/>
    <Constant name="BVR0" id="70148d61-9928-4468-b7a5-e8eaef3d040d">
        <source>"Use 'Min time in Advance' values"</source>
        <type name="String"/>
        <text>Exclusive use Vehicle Booking - Min time in Advance settings.</text>
    </Constant>
    <Constant name="BVR1" id="c0130299-f5f2-448b-855e-e763c38382aa">
        <source>"Validation rule 1"</source>
        <type name="String"/>
        <text>Vehicle Booking validation rule one.
Bookings for the period 16:00 thru 0800 must be made prior to 16:00.
And Vehicle Booking - Min time in Advance settings apply too.</text>
    </Constant>
</Class>
