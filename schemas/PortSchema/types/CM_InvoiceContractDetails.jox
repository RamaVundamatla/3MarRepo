    <JadeMethod name="getDisplayStringForAttribute" id="2cb8fd7d-38fb-44d3-9927-2f646c67d69a">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
/*
Purpose:			

Date		Who		Reason
01 December 2022	navab1	TFS CR 55623 TASK 55673
31 Jan 2023 		navtnr20 TFS CR 55646 Task 55664: UI - Contracts Maint
28 Aug 2023 		navhl20 Bug 59916: FR | EUP 54089 - Inv Contract - Append 'Copy' to copied rates
*/

vars
	re : CM_InvoiceContractRateEntry;
begin
	if _attrName = ETRow_FromTS then
		return self.systemToLocalTime(self.fromTS).asStringJMT();
	elseif _attrName = ETRow_ToTS then
		return self.systemToLocalTime(self.toTS).asStringJMT();
	elseif _attrName = ETRow_ShippingTerm then
		if self.myShippingTerm &lt;&gt; null then
			return self.myShippingTerm.code;
		endif;
		return null;
	elseif _attrName = ETRow_Criteria then
		if myInvoiceContractCriteria &lt;&gt; null then
			return self.myInvoiceContractCriteria.getCriteriaSummary(",");
		endif;
		return null;
	elseif _attrName = ETRow_CriteriaPriority then
		if self.criteriaPriority &lt;&gt; null then
			return self.criteriaPriority.asStringJMT;
		endif;
		return null;
	elseif _attrName = ETRow_InvoiceLine then
		if self.myInvoiceLineType &lt;&gt; null then
			return self.myInvoiceLineType.narration;
		endif;
		return null;
	elseif _attrName = ETRow_CalculationType then
		if self.myCalculationType &lt;&gt; null then
			return self.myCalculationType.description;
		endif;
		return null;
	elseif _attrName = ETRow_UomCode then
		if self.myUnitOfMeasure &lt;&gt; null then
			return myUnitOfMeasure.code;
		endif;
		return null;
	elseif _attrName = ETRow_Type then
		if  self.contractType = INV_CONTRACT_TYPE_STANDARD then
			return  INV_CONTRACT_TYPE_STANDARD_STR;
		else
			return INV_CONTRACT_TYPE_VOLBASED_STR;
		endif;
	elseif _attrName = ETRow_Description then							//28.8.2023 navhl20 #59916
		if self.myInvoiceContractCriteria &lt;&gt; null then
			return self.myInvoiceContractCriteria.description;
		endif;
		return null;
	// ### TFS BUG 61268 29NOV2023 NAVAB1
	elseif _attrName = ETRow_Rate then
		re := self.getCurrentRateForDisplay();
		if re = null then
			return "";
		else
			return re.costPerUnit.asStringJMTWithPrecision(4,true);
		endif;
	endif;
	return inheritMethod(_attrName, _short);

epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getRateForService" id="268dba47-25e3-49d8-bc0b-3f5f8db55634">
        <source>getRateForService(_service : CM_Service) : CM_InvoiceContractRate;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20/01/2023 navmv20 TFS 55650 Task 55702: Jade - Contracts XML Load TRX

*/

vars
	invContractRate : CM_InvoiceContractRate;
begin
	foreach invContractRate in allInvoiceContractRates do
		if invContractRate.myService = _service then
			return invContractRate;
		endif;
	endforeach;
epilog

end;</source>
        <Parameter name="_service" type="CM_Service"/>
        <ReturnType type="CM_InvoiceContractRate"/>
    </JadeMethod>
