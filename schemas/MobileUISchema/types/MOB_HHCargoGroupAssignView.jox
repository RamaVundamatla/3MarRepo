    <JadeMethod name="doResizeControls" id="5a43ec74-b136-4efe-ba0a-174f474649f6">
        <updating/>
        <source>doResizeControls(_initialSetup: Boolean) updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 July 2018	jlgndl1	Initial creation	TFS 39186

*/

vars

	stdLeft : Real;
	top : Real;
	stdWidth : Real;
	stdHeight : Real;
	width : Real;
	tabIndex : Integer;
	
	midLeft : Real;
	leftWidth : Real;
	rightWidth : Real;
	remainingHeight : Real;

begin

	self.setResizeableMarginAndFontSize();
	tabIndex := 4000;
	stdLeft :=  self.resizedMargin;
	top := self.resizedMargin;
	stdWidth := self.clientWidth - self.resizedMargin; 
	stdHeight := self.getStdControlHeight;
	
	leftWidth := ( stdWidth - self.resizedMargin ) * 3/4;
	rightWidth := ( stdWidth - self.resizedMargin ) * 1/4;
	midLeft := stdLeft + leftWidth + self.resizedMargin;
	
	if _initialSetup then
		self.lblNotifiedGroups.setAndIncrementTabIndex( tabIndex );
		self.lblNotifiedGroups.visible := true;
	endif;
	self.lblNotifiedGroups.move(	stdLeft,
									top,
									leftWidth,
									stdHeight );
									
	if _initialSetup then
		self.lblNotScanned.setAndIncrementTabIndex( tabIndex );
		self.lblNotScanned.visible := true;
	endif;
	self.lblNotScanned.move(	midLeft,
								top,
								rightWidth,
								stdHeight );
							
	top := self.lblNotifiedGroups.top + self.lblNotifiedGroups.height; 
	remainingHeight := self.clientHeight - top - ( self.resizedMargin * 2 ) - self.getCMDButtonsHeight;
	
	if _initialSetup then
		self.tblNotGrps.setAndIncrementTabIndex( tabIndex );
		self.tblNotGrps.visible := true;
	endif;
	self.tblNotGrps.move(	stdLeft,
							top,
							leftWidth,
							remainingHeight );
							
	if _initialSetup then
		self.tblNotScanned.setAndIncrementTabIndex( tabIndex );
		self.tblNotScanned.visible := true;
	endif;
	self.tblNotScanned.move(	midLeft,
								top,
								rightWidth,
								remainingHeight );
	
	
	inheritMethod(_initialSetup);

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_initialSetup" type="Boolean"/>
    </JadeMethod>
