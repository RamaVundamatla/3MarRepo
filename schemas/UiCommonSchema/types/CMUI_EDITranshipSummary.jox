    <JadeMethod name="toolbarShowCaptions" id="a4fa0d0e-2117-459d-9976-b63d4754eb80">
        <updating/>
        <source>toolbarShowCaptions(_showCaptions: Boolean) updating;

vars

begin
	inheritMethod(_showCaptions);
	self.setToolbarSearch();
