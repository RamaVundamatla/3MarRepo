    <JadeMethod name="doEnableControls" id="5cba8a9b-8b49-42a9-878b-e0edaab4b2ba">
        <source>doEnableControls() protected;
// --------------------------------------------------------------------------------
// Created:		21 January 2003 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	theProduct	: JSSLKProduct;
	
begin
	if lstProducts.listIndex = JSS_NULL_INDEX then
		lblNoLogo.visible			:=	true;
		picLogo.visible				:=	false;
		mnuProdAdd.enabled			:=	true;
		mnuProdEdit.enabled			:=	false;
		mnuProdDelete.enabled		:=	false;
		mnuProdCompAdd.enabled		:=	false;
		mnuProdCompEdit.enabled		:=	false;
		mnuProdCompDelete.enabled	:=	false;
		mnuProdCompImport.enabled	:=	true;
	else
		mnuProdAdd.enabled			:=	true;
		mnuProdEdit.enabled			:=	true;
		mnuProdDelete.enabled		:=	true;
		mnuProdCompAdd.enabled		:=	true;
		mnuProdCompEdit.enabled		:=	true;
		mnuProdCompDelete.enabled	:=	true;
		mnuProdCompImport.enabled	:=	true;
		
		theProduct	:=	self.listGetSelectedProduct(lstProducts);
		
		if theProduct.productLogo = null then
			lblNoLogo.visible	:=	true;
			picLogo.visible		:=	false;
		else
			lblNoLogo.visible	:=	false;
			picLogo.visible		:=	true;
			picLogo.picture		:=	theProduct.productLogo;
		endif;
	endif;
	
	if lstCustomers.listIndex = JSS_NULL_INDEX then
		lstProdUsed.clear();
		mnuCustomerAdd.enabled			:=	true;
		mnuCustomerEdit.enabled			:=	false;
		mnuCustomerDelete.enabled		:=	false;
		mnuCustomerCertificate.enabled	:=	false;
	else
		mnuCustomerAdd.enabled			:=	true;
		mnuCustomerEdit.enabled			:=	true;
		mnuCustomerDelete.enabled		:=	true;
		mnuCustomerCertificate.enabled	:=	true;
	endif;
	
	if lstProdUsed.listIndex = JSS_NULL_INDEX then
		mnuCustomerCertificate.enabled	:=	false;
		mnuCustomerMakeKey.enabled		:=	false;
		btnExpiryDate.enabled			:=	false;
	else
		mnuCustomerCertificate.enabled	:=	true;
		mnuCustomerMakeKey.enabled		:=	true;
		btnExpiryDate.enabled			:=	true;
	endif;
	
	mnuProdUsed.enabled		:=	true;
	mnuCustomerUsed.enabled	:=	true;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doFormInitialize" id="625c10e8-3d63-41ed-9fa5-887545816aae">
        <updating/>
        <source>doFormInitialize() updating, protected;
// --------------------------------------------------------------------------------
// Created:		21 January 2003 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	inheritMethod();
	
	lblNoLogo.visible	:=	true;
	picLogo.visible		:=	false;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doFormLoad" id="8e5412d1-4f6f-4251-b8ae-7c77709209af">
        <updating/>
        <source>doFormLoad() updating, protected;
// --------------------------------------------------------------------------------
// Created:		20 January 2003 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	lstCustomers.listCollection(app.myRoot.allCustomers, true, 0);
	self.populateProductList();
	
	beginClassNotification(JSSLKProduct, false, Any_System_Event, Response_Continuous, self.EVENT_TAG_PRODUCT);
	beginClassNotification(JSSLKComponent, false, Any_System_Event, Response_Continuous, self.EVENT_TAG_COMPONENT);
	beginNotification(app, CUSTOMER_USEDCOMPONENT_CHANGE, Response_Continuous, self.EVENT_TAG_USERCOMPONENT);
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doFormUnload" id="6edd4bc6-e55e-4c23-a6e0-df349c1a64da">
        <updating/>
        <source>doFormUnload() updating, protected;
// --------------------------------------------------------------------------------
// Created:		24 January 2003 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	endNotificationForSubscriber(self);
	
	inheritMethod();
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doSystemNotification" id="1b41f745-8814-4d6a-89f4-246125e730e9">
        <updating/>
        <source>doSystemNotification(pEventType: Integer; pTheObject: Object; pEventTag: Integer) updating, protected;
// --------------------------------------------------------------------------------
// Created:		22 January 2003 by cnwdad1
//
// Purpose:		Processes system notifications for the form.
//
// Parameters:	The sysNotify event method parameters.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 24/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
// --------------------------------------------------------------------------------
vars
	theProduct		: JSSLKProduct;
	theComponent	: JSSLKComponent;
	listPointer		: Integer;
	
begin
	if pEventTag = self.EVENT_TAG_PRODUCT then
		theProduct		:=	pTheObject.JSSLKProduct;
	elseif pEventTag = self.EVENT_TAG_COMPONENT then
		theComponent	:=	pTheObject.JSSLKComponent;
	endif;
	
	if pEventType = Object_Create_Event then
		if pEventTag = self.EVENT_TAG_PRODUCT or pEventTag = self.EVENT_TAG_COMPONENT then
			self.populateProductList();
			self.populateUsedProductsList();
		endif;
		
	elseif pEventType = Object_Update_Event then
		if pEventTag = self.EVENT_TAG_PRODUCT then
			listPointer	:=	lstProducts.findObject(pTheObject);
			
			if listPointer &lt;&gt; JSS_NULL_INDEX then
				lstProducts.itemText[listPointer]	:=	theProduct.productName;
			endif;
			
			listPointer	:=	lstProdUsed.findObject(pTheObject);
			
			if listPointer &lt;&gt; JSS_NULL_INDEX then
				lstProdUsed.itemText[listPointer]	:=	theProduct.productName;
			endif;
			
		elseif pEventTag = self.EVENT_TAG_COMPONENT then
			listPointer	:=	lstProducts.findObject(pTheObject);
			
			if listPointer &lt;&gt; JSS_NULL_INDEX then
				lstProducts.itemText[listPointer]	:=	theComponent.getDisplay();
			endif;
			
			listPointer	:=	lstProdUsed.findObject(pTheObject);
			
			if listPointer &lt;&gt; JSS_NULL_INDEX then
				lstProdUsed.itemText[listPointer]	:=	theComponent.getDisplay();
			endif;
			
		endif;
		
	elseif pEventType = Object_Delete_Event then
		listPointer	:=	lstProducts.findObject(pTheObject);
		
		if listPointer &lt;&gt; JSS_NULL_INDEX then
			self.listRemoveItem(lstProducts, listPointer);
		endif;
		
		listPointer	:=	lstProdUsed.findObject(pTheObject);
		
		if listPointer &lt;&gt; JSS_NULL_INDEX then
			self.listRemoveItem(lstProdUsed, listPointer);
		endif;
		
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="pEventType" type="Integer"/>
        <Parameter name="pTheObject" type="Object"/>
        <Parameter name="pEventTag" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="listGetSelectedComponent" id="4dc94090-093b-490c-98c8-9a505baa6dfe">
        <source>listGetSelectedComponent(pTheListbox:ListBox):JSSLKComponent protected;
// --------------------------------------------------------------------------------
// Created:		21 January 2003 by cnwdad1
//
// Purpose:		Returns the currently selected product component from the listbox.
//
// Parameters:	pTheListbox - The listbox control to scan.
//
// Returns:		The currently selected product component object, or null if none
//				is selected.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	theComponent	: JSSLKComponent;
	listPointer		: Integer;
	
begin
	if pTheListbox.listIndex = JSS_NULL_INDEX then
		return null;
		
	elseif JSSLKComponent.hasInstance(pTheListbox.listObject) then
		return pTheListbox.listObject.JSSLKComponent;
		
	else
		return null;
		
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="pTheListbox" type="ListBox"/>
        <ReturnType type="JSSLKComponent"/>
    </JadeMethod>
    <JadeMethod name="listGetSelectedCustomer" id="c9501b9a-14f3-4b9f-aafc-5012c91aef8b">
        <source>listGetSelectedCustomer(pTheListbox:ListBox):JSSLKCustomer protected;
// --------------------------------------------------------------------------------
// Created:		22 January 2003 by cnwdad1
//
// Purpose:		Returns the currently selected Customer from the listbox.
//
// Parameters:	pTheListbox - The listbox control to scan.
//
// Returns:		The currently selected Customer object, or null if none is selected.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if pTheListbox.listIndex = JSS_NULL_INDEX then
		return null;
	else
		return pTheListbox.listObject.JSSLKCustomer;
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="pTheListbox" type="ListBox"/>
        <ReturnType type="JSSLKCustomer"/>
    </JadeMethod>
    <JadeMethod name="listGetSelectedProduct" id="88f29e9b-63aa-4196-9a09-02a3df896e5d">
        <source>listGetSelectedProduct(pTheListbox:ListBox):JSSLKProduct protected;
// --------------------------------------------------------------------------------
// Created:		21 January 2003 by cnwdad1
//
// Purpose:		Returns the currently selected product from the listbox.
//
// Parameters:	pTheListbox - The listbox control to scan.
//
// Returns:		The currently selected product object, or null if none is selected.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	theProduct	: JSSLKProduct;
	listPointer	: Integer;
	
begin
	if pTheListbox.listIndex = JSS_NULL_INDEX then
		return null;
		
	elseif JSSLKProduct.hasInstance(pTheListbox.listObject) then
		theProduct	:=	pTheListbox.listObject.JSSLKProduct;
	else
		listPointer	:=	self.listFindParent(pTheListbox, pTheListbox.listIndex);
		
		if listPointer &gt; 0 then
			theProduct	:=	pTheListbox.itemObject[listPointer].JSSLKProduct;
		else
			theProduct	:=	null;
		endif;
	endif;
	
	return theProduct;
end;</source>
        <access>protected</access>
        <Parameter name="pTheListbox" type="ListBox"/>
        <ReturnType type="JSSLKProduct"/>
    </JadeMethod>
    <JadeMethod name="listGetSelectedUsedProduct" id="3ac52894-cf31-4aaf-b8c5-b07440bdc2b8">
        <source>listGetSelectedUsedProduct(pTheListbox:ListBox):JSSLKUsedProduct protected;
// --------------------------------------------------------------------------------
// Created:		21 January 2003 by cnwdad1
//
// Purpose:		Returns the currently selected used product from the listbox.
//
// Parameters:	pTheListbox - The listbox control to scan.
//
// Returns:		The currently selected used product object, or null if none is
//				selected.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	theUsedProduct	: JSSLKUsedProduct;
	listPointer		: Integer;
	
begin
	if pTheListbox.listIndex = JSS_NULL_INDEX then
		return null;
	elseif JSSLKUsedProduct.hasInstance(pTheListbox.listObject) then
		theUsedProduct	:=	pTheListbox.listObject.JSSLKUsedProduct;
	else
		listPointer	:=	self.listFindParent(pTheListbox, pTheListbox.listIndex);
		
		if listPointer &gt; 0 then
			theUsedProduct	:=	pTheListbox.itemObject[listPointer].JSSLKUsedProduct;
		else
			theUsedProduct	:=	null;
		endif;
	endif;
	
	return theUsedProduct;
end;</source>
        <access>protected</access>
        <Parameter name="pTheListbox" type="ListBox"/>
        <ReturnType type="JSSLKUsedProduct"/>
    </JadeMethod>
