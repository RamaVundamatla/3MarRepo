    <JadeMethod name="doDeleteAll" id="c44cdbd7-6ff4-4fc2-8bb4-9b6e293d1faa">
        <source>doDeleteAll() protected;

// cnwdvb1 01 May 2003 

vars
	objArray	: CM_ObjectArray;
	object		: Object;
begin

	create objArray transient;
	Yrk_Object.allInstances(objArray, 0, true);
	beginTransaction;
	foreach object in objArray do
		if not object.isKindOf(Yrk_Configuration) then
			object.Yrk_Object.erase(NORMAL_ERASE);
		endif;
	endforeach;
	commitTransaction;
epilog
	delete objArray;
end;</source>
        <access>protected</access>
    </JadeMethod>
