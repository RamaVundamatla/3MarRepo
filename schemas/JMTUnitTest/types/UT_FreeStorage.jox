    <JadeMethod name="tCheckAllStorageTriggers" id="293155fc-224a-4be3-81ec-f5747728bb40">
        <updating/>
        <source>tCheckAllStorageTriggers()updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 May 2015	cnwndl1	Initial creation	Par 36006
// 10 Sep 2019	cnwrs1	TFS 46030
*/

constants

	BlockStack1 : String = "STK1";
	Child1 : String = "KIDP000001";
	Container1 : String = "UUTU9999MT";
	
vars

	portSchema : Schema;
	category : ConstantCategory;
	constant : Constant;
	constantName : String;
	constantValueArray : IntegerArray;
	constantNameArray : StringArray;	// for error display
	
	resetSubTermAreaDefined	: Boolean;
	deriveDebtorFrom : CM_DebtorType;
	calendar : CM_Calendar;
	triggers : CM_StorageTriggerByType;
	storageConfig	: CM_StorageConfig;
	includeFirstDay	: Boolean;
	includeLastDay	: Boolean;
	shipReceivalType	: Integer;
	shipReleaseType		: Integer;
	tranDate : Date;
	now : Date;
	tranTS : TimeStamp;
	cargoId : String;
	commodity : String;
	ti1 : CM_Container;
	storageCount : Integer;
	
	pxyStorageTrigger : CM_StorageTrigger;
	index : Integer;
	transhipController: CMIF_TranshipTIController;
	vessel : CM_Vessel;
	voyage1 : CM_Voyage;
	voyage2 : CM_Voyage;
	expectedCount : Integer;
	
	childTi : CM_TrackedItem;
	cargoType : CM_CargoType;
	prod : CM_Product;
	oper : CM_Operator;
	bs1 : CM_BlockStack;
	packTIs : CM_TIArray;
	marineSubT : CM_SubTerminal;
	debtor : CM_Debtor;
	otherDebtor : CM_Debtor;
	oper2 : CM_Operator;
	lc : CM_LocationsController;
	height : Integer;
	isDoClearanceCheck : Boolean;
	storageDetail : CM_StorageDetail;
	allStoDtlCriterias : IntegerArray;
	allStoDtlCritValues : ObjectArray;
	subTerminalSettings : Boolean;
	terminal : CM_Terminal;
begin
	// ### TFS CR 58263 TASK 58264 22JAN2024 NAVAB1
	terminal := self.getTerminal();
	subTerminalSettings := terminal.getConfig(IsSubTerminalsOn).Boolean;
	
	if not subTerminalSettings then
		beginTransaction;
		terminal.setConfig(IsSubTerminalsOn, true);
		commitTransaction;
	endif;

	isDoClearanceCheck := self.getMyTerminal.myHarbour.isDoClearanceCheck;
	self.setHarbourIsDoClearanceCheck(false);
	self.deleteStorageConfig( false );

	marineSubT := self.getTerminal.allSubTerminals.getAtKey("UT_Marine");
	self.assertTrueMsg(marineSubT &lt;&gt; null, "Failed to find SubTerminal UT_Marine" );

	oper := self.getOperator("UTOP");
	self.assertTrueMsg(oper &lt;&gt; null, "Failed to find Operator UTOP" );
	oper2 := self.getOperator("UTO2");
	self.assertTrueMsg(oper2 &lt;&gt; null, "Failed to find Operator UTO2" );
	self.assertTrueMsg(oper.debtor &lt;&gt; oper2.debtor, "Debtor derived from Operator needs to be different" );
	
	self.deleteTerminalArea(BlockStack1);
	bs1 := addBlockStack(BlockStack1, 10, null);
	self.assertTrueMsg(bs1 &lt;&gt; null, "Failed to create Block Stack " &amp; BlockStack1 );
		
	self.deleteVoyage("UTFS1");
	self.deleteVoyage("UTFS2");
	self.deleteVessel("UTFS");
	vessel := addVesselCellular("UTFS", oper);
	voyage1 := addVoyageWithContainerStructur("UTFS1", "UTFS", oper.code, self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString);
	voyage2 := addVoyageWithContainerStructur("UTFS2", "UTFS", oper.code, self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString);


	// gather up a list of all of the declared triggers for storage and their names
	create constantValueArray transient;
	create constantNameArray transient;

	portSchema := rootSchema.getSchema("PortSchema");
	category := portSchema.getCategory("StorageTriggers");
	
	foreach constant in category.getConstants do
		if constant.type = Integer then
			index := constant.getSource.Integer;
			if index = 4 or index = 10 then	//IMEX - 'Export to Tranship'  and  IMEX - 'Storage to Tranship'
				continue;
			endif;
			constantValueArray.add( constant.getSource.Integer);
			constantNameArray.add( constant.name );
		endif;
	endforeach;
	
	if self.getTerminal.getConfig(IsSubTerminalAreaDefined).Boolean then
		resetSubTermAreaDefined := true;
		self.setSubTerminalAreaDefined(false);	
	endif;
	deriveDebtorFrom := app.myRoot.allDebtorTypes["SDT1"];		// cargo operator
	calendar := self.setupCalendar();
	create triggers transient;
	self.getAllStorageTriggers(triggers);
	
	//check we have one for each possible constant, ie.e that we will check all the triggers.
	foreach pxyStorageTrigger in triggers do
		index := constantValueArray.indexOf( pxyStorageTrigger.attributeType);
		if index &gt; 0 then
			constantValueArray.removeAt(index);
			constantNameArray.removeAt(index);
		endif;
	endforeach;
	
	self.assertTrueMsg(constantNameArray.isEmpty,"At least one 'new' Storage Trigger has been added that is not being tested. [" &amp; constantNameArray.first &amp; "]");
	
	includeFirstDay := true;
	create allStoDtlCriterias transient;
	create allStoDtlCritValues transient;
	
	// all options false/null - only the triggers are used here
	storageConfig := self.setupStorageConfig1(calendar, includeFirstDay, includeLastDay, shipReceivalType, shipReleaseType, false, false, deriveDebtorFrom, triggers, false);

	allStoDtlCriterias.add(YACriteriaType_CargoType);
	allStoDtlCritValues.add(self.getCargoType("CONT"));
	storageDetail := self.addStorageDetail(storageConfig, method.name, allStoDtlCriterias, allStoDtlCritValues, 0, 0, false, false, 0, 0, false, null);
	self.assertNotNull(storageDetail);
	
	cargoId := Container1;
	commodity := "MT";
	ti1 := self.receiveContainerIntoYard(cargoId, commodity).CM_Container;
	self.opts.purge();
	self.opts.addAssoc("Voyage",voyage1);
	self.updateTI( ti1 );

	
	// set the transaction dates 20 days back
	tranDate := now-20;
	tranTS.setDate(tranDate);
	self.resetTransactionDate(ti1, tranTS);
	storageCount := self.countTransactionsOfType(ti1, TRANS_TYPE_STORAGE);
	expectedCount := 1;
	self.assertEqualMsg(storageCount, expectedCount, "Initial storage transactions");
	
	
	
	
	self.editIMEXStatus(ti1, TI_IMEX_STATUS_IMPORT,false);	//"IMEX - Export to Import"
	expectedCount := expectedCount + 1;
	self.resetTransactionDate(ti1, tranTS);
	storageCount := self.countTransactionsOfType(ti1, TRANS_TYPE_STORAGE);
	self.assertEqualMsg(storageCount, expectedCount, "IMEX - 'Export to Import' didn't create storage trx");

	
	self.editIMEXStatus(ti1, TI_IMEX_STATUS_STORAGE,false);	//"IMEX - Import to Storage"
	expectedCount := expectedCount + 1;
	self.resetTransactionDate(ti1, tranTS);
	storageCount := self.countTransactionsOfType(ti1, TRANS_TYPE_STORAGE);
	self.assertEqualMsg(storageCount, expectedCount, "IMEX - 'Import to Storage' didn't create storage trx");

	self.opts.purge();
	self.opts.addAssoc("Voyage",voyage1);
	self.updateTI( ti1 );	//"Voyage Change (for Non Export)"
	expectedCount := expectedCount + 1;
	self.resetTransactionDate(ti1, tranTS);
	storageCount := self.countTransactionsOfType(ti1, TRANS_TYPE_STORAGE);
	self.assertEqualMsg(storageCount, expectedCount, "Voyage Change (for Non Export) didn't create storage trx");
	
	self.editIMEXStatus(ti1, TI_IMEX_STATUS_IMPORT,false);	//"IMEX - Storage to Import"
	expectedCount := expectedCount + 1;
	self.resetTransactionDate(ti1, tranTS);
	storageCount := self.countTransactionsOfType(ti1, TRANS_TYPE_STORAGE);
	self.assertEqualMsg(storageCount, expectedCount, "IMEX - 'Storage to Import' didn't create storage trx");

	
	// now make it a tranship
	create transhipController transient;
	transhipController.allTrackedItems.add(ti1);
	transhipController.myExportDisPort := app.myRoot.allPorts['DEBRV'];
	transhipController.myExportVoyage := voyage2;
	//transhipController.removeStops := true; // TFS 47222 jlgzm1 20/11/2019
	
	self.makeTrackedItemTranship(transhipController);
	expectedCount := expectedCount + 1;
	self.resetTransactionDate(ti1, tranTS);
	storageCount := self.countTransactionsOfType(ti1, TRANS_TYPE_STORAGE);
	self.assertEqualMsg(storageCount, expectedCount, "IMEX - 'Import to Tranship' didn't create storage trx");
	
	self.editIMEXStatus(ti1, TI_IMEX_STATUS_IMPORT,true);	//"IMEX - Tranship to Import"
	expectedCount := expectedCount + 1;
	self.resetTransactionDate(ti1, tranTS);
	storageCount := self.countTransactionsOfType(ti1, TRANS_TYPE_STORAGE);
	self.assertEqualMsg(storageCount, expectedCount, "IMEX - 'Tranship to Import' didn't create storage trx");
	
	transhipController.myExportVoyage := voyage1; //22 Jan 2019
	
	self.makeTrackedItemTranship(transhipController);
	expectedCount := expectedCount + 1;
	self.resetTransactionDate(ti1, tranTS);
	storageCount := self.countTransactionsOfType(ti1, TRANS_TYPE_STORAGE);
	self.assertEqualMsg(storageCount, expectedCount, "IMEX - 'Import to Tranship' didn't create storage trx number 2");
	self.assertTrueMsg(ti1.getImExStatus = TI_IMEX_STATUS_TRANSHIP, "IMEX not equal Tranship");
	
	self.editIMEXStatus(ti1, TI_IMEX_STATUS_EXPORT,true);	//"IMEX - Tranship to Export"
	expectedCount := expectedCount + 1;
	self.resetTransactionDate(ti1, tranTS);
	storageCount := self.countTransactionsOfType(ti1, TRANS_TYPE_STORAGE);
	self.assertEqualMsg(storageCount, expectedCount, "IMEX - 'Tranship to Export' didn't create storage trx");
	self.assertTrueMsg(ti1.getImExStatus = TI_IMEX_STATUS_EXPORT, "IMEX not equal Export");
	
	self.editIMEXStatus(ti1, TI_IMEX_STATUS_IMPORT,false);	//"IMEX - Export to Import"
	expectedCount := expectedCount + 1;
	self.resetTransactionDate(ti1, tranTS);
	storageCount := self.countTransactionsOfType(ti1, TRANS_TYPE_STORAGE);
	self.assertEqualMsg(storageCount, expectedCount, "IMEX - 'Export to Import' didn't create storage trx number 2");
	self.assertTrueMsg(ti1.getImExStatus = TI_IMEX_STATUS_IMPORT, "IMEX not equal Import");
	
	self.opts.purge();
	self.opts.addAssoc("Voyage",voyage2);
	self.updateTI( ti1 );	//"Voyage Change (for Non Export)"
	expectedCount := expectedCount + 1;
	self.resetTransactionDate(ti1, tranTS);
	storageCount := self.countTransactionsOfType(ti1, TRANS_TYPE_STORAGE);
	self.assertEqualMsg(storageCount, expectedCount, "Voyage Change (for Non Export) didn't create storage trx");
	self.assertTrueMsg(ti1.getImExStatus = TI_IMEX_STATUS_EXPORT, "IMEX not equal Export");
	
	
	self.editIMEXStatus(ti1, TI_IMEX_STATUS_IMPORT,false);	//"IMEX - Export to Import"
	expectedCount := expectedCount + 1;
	self.resetTransactionDate(ti1, tranTS);
	storageCount := self.countTransactionsOfType(ti1, TRANS_TYPE_STORAGE);
	self.assertEqualMsg(storageCount, expectedCount, "IMEX - 'Export to Import' didn't create storage trx number 3");
	self.assertTrueMsg(ti1.getImExStatus = TI_IMEX_STATUS_IMPORT, "IMEX not equal Import");

	beginTransaction;
	ti1.setPropertyValue( CM_TrackedItem::myVoyageTranshipImport.name, null);
	ti1.setPropertyValue( CM_TrackedItem::myVoyageTranshipExport.name, null);
	commitTransaction;
	
	self.makeTrackedItemTranship(transhipController);
	expectedCount := expectedCount + 1;
	self.resetTransactionDate(ti1, tranTS);
	storageCount := self.countTransactionsOfType(ti1, TRANS_TYPE_STORAGE);
	self.assertEqualMsg(storageCount, expectedCount, "IMEX - 'Import to Tranship' didn't create storage trx number 4");
	self.assertTrueMsg(ti1.getImExStatus = TI_IMEX_STATUS_TRANSHIP, "IMEX not equal Tranship");
	
	self.editIMEXStatus(ti1, TI_IMEX_STATUS_STORAGE,true);	//"IMEX - Tranship to Storage"
	expectedCount := expectedCount + 1;
	self.resetTransactionDate(ti1, tranTS);
	storageCount := self.countTransactionsOfType(ti1, TRANS_TYPE_STORAGE);
	self.assertEqualMsg(storageCount, expectedCount, "IMEX - 'Tranship to Storage' didn't create storage trx");
	self.assertTrueMsg(ti1.getImExStatus = TI_IMEX_STATUS_STORAGE, "IMEX not equal Storage");
	
	self.editIMEXStatus(ti1, TI_IMEX_STATUS_EXPORT,true);	//"IMEX - Tranship to Export"
	expectedCount := expectedCount + 1;
	self.resetTransactionDate(ti1, tranTS);
	storageCount := self.countTransactionsOfType(ti1, TRANS_TYPE_STORAGE);
	self.assertEqualMsg(storageCount, expectedCount, "IMEX - 'Storage to Export' didn't create storage trx");
	self.assertTrueMsg(ti1.getImExStatus = TI_IMEX_STATUS_EXPORT, "IMEX not equal Export");
	
	self.editIMEXStatus(ti1, TI_IMEX_STATUS_IMPORT,false);	//"IMEX - Storage to Import"
	expectedCount := expectedCount + 1;
	self.resetTransactionDate(ti1, tranTS);
	storageCount := self.countTransactionsOfType(ti1, TRANS_TYPE_STORAGE);
	self.assertEqualMsg(storageCount, expectedCount, "IMEX - 'Storage to Import' didn't create storage trx number 5");
	self.assertTrueMsg(ti1.getImExStatus = TI_IMEX_STATUS_IMPORT, "IMEX not equal Import");
	
	self.editIMEXStatus(ti1, TI_IMEX_STATUS_EXPORT,true);	//"IMEX - Import to Export"
	expectedCount := expectedCount + 1;
	self.resetTransactionDate(ti1, tranTS);
	storageCount := self.countTransactionsOfType(ti1, TRANS_TYPE_STORAGE);
	self.assertEqualMsg(storageCount, expectedCount, "IMEX - 'Import to Export' didn't create storage trx");
	self.assertTrueMsg(ti1.getImExStatus = TI_IMEX_STATUS_EXPORT, "IMEX not equal Export");
	
	self.editIMEXStatus(ti1, TI_IMEX_STATUS_STORAGE,false);	//"IMEX - Export to Storage"
	expectedCount := expectedCount + 1;
	self.resetTransactionDate(ti1, tranTS);
	storageCount := self.countTransactionsOfType(ti1, TRANS_TYPE_STORAGE);
	self.assertEqualMsg(storageCount, expectedCount, "IMEX - 'Export to Storage' didn't create storage trx");
	self.assertTrueMsg(ti1.getImExStatus = TI_IMEX_STATUS_STORAGE, "IMEX not equal Storage");
	
	//create a potential child cargo item
	cargoType := app.myRoot.getCargoTypeFromAbbrev("MELN");
	self.assertTrueMsg(cargoType &lt;&gt; null, "Failed to find cargo type MELN" );	
	prod := cargoType.allProducts.first;
	self.assertTrueMsg(prod &lt;&gt; null, "Failed to find sub cargo type within MELN" );
	self.deleteCargo(Child1,cargoType);
	childTi := self.addCargoAtLocation( Child1, prod, oper, bs1.myLocationsController );
	self.assertTrueMsg(childTi &lt;&gt; null, "Failed to create Child " &amp; Child1 &amp; " - " &amp; app.myPassport.getAllErrorsWarningsAsString);
	self.resetTransactionDate(childTi, tranTS);
	
	create packTIs transient;
	packTIs.add(childTi);
	self.packContainer(ti1, packTIs);	//"Pack as a parent"  and "Pack as a child"
	
	self.resetTransactionDate(childTi, tranTS);
	storageCount := self.countTransactionsOfType(childTi, TRANS_TYPE_STORAGE);
	self.assertEqualMsg(storageCount, 1, "'Pack as a child' didn't create storage trx");
	
	expectedCount := expectedCount + 1;
	self.resetTransactionDate(ti1, tranTS);
	storageCount := self.countTransactionsOfType(ti1, TRANS_TYPE_STORAGE);
	self.assertEqualMsg(storageCount, expectedCount, "'Pack as a parent' didn't create storage trx");
	
	self.packCompleteContainer(ti1);
	expectedCount := expectedCount + 1;
	self.resetTransactionDate(ti1, tranTS);
	self.resetTransactionDate(childTi, tranTS);
	storageCount := self.countTransactionsOfType(ti1, TRANS_TYPE_STORAGE);
	self.assertEqualMsg(storageCount, expectedCount, "'Pack complete as a parent' didn't create storage trx");
	
	self.unpackContainer(ti1, packTIs);		//"Unpacked as a child"
	self.resetTransactionDate(childTi, tranTS);
	storageCount := self.countTransactionsOfType(childTi, TRANS_TYPE_STORAGE);
	self.assertEqualMsg(storageCount, 3, "'Unpacked as a child' didn't create storage trx");
	
	self.opts.purge();
	self.opts.addAssoc("SubTerminal",marineSubT);
	self.updateTI( ti1 );			//'Sub-Terminal change'
	self.assertTrueMsg(ti1.mySubTerminal = marineSubT, "Sub Terminal not changed");
	expectedCount := expectedCount + 1;
	self.resetTransactionDate(ti1, tranTS);
	storageCount := self.countTransactionsOfType(ti1, TRANS_TYPE_STORAGE);
	self.assertEqualMsg(storageCount, expectedCount, "'Sub-Terminal change' didn't create storage trx");
	
	self.opts.addAssoc("Operator",oper2);
	self.updateTI( ti1 );		//'Debtor change'
	self.assertTrueMsg(ti1.myOperator = oper2, "Operator not changed");
	expectedCount := expectedCount + 1;
	self.resetTransactionDate(ti1, tranTS);
	storageCount := self.countTransactionsOfType(ti1, TRANS_TYPE_STORAGE);
	self.assertEqualMsg(storageCount, expectedCount, "'Debtor change' caused bu Operator change didn't create storage trx");

		
	ti1.myTerminal.findLocationFromString("UTSBTBS1", true, lc, height );
	self.move( ti1, lc );
	ti1.myTerminal.findLocationFromString("UTSBTBS3", true, lc, height );
	self.move( ti1, lc );
	self.assertTrueMsg(ti1.myPrimaryActualLocation = lc, "Terminal Area not changed");
	expectedCount := expectedCount + 1;
	self.resetTransactionDate(ti1, tranTS);
	storageCount := self.countTransactionsOfType(ti1, TRANS_TYPE_STORAGE);
	self.assertEqualMsg(storageCount, expectedCount, "'Terminal Area change' didn't create storage trx");
epilog
	self.setHarbourIsDoClearanceCheck(isDoClearanceCheck);
	self.deleteContainer(Container1);
	self.deleteCargo(Child1,cargoType);

	if triggers &lt;&gt; null then
		triggers.purge();
		delete triggers;
	endif;
	
	// ### TFS CR 58263 TASK 58264 22JAN2024 NAVAB1 - reset the sub terminal config
	beginTransaction;
	terminal.setConfig(IsSubTerminalsOn, subTerminalSettings);
	commitTransaction;	
	
	if resetSubTermAreaDefined then
		self.setSubTerminalAreaDefined( true );
	endif;
	delete constantValueArray;
	delete constantNameArray;
	delete transhipController;
	delete packTIs;
	
	// DON'T leave the config around to affect subsequent storage tests
	self.deleteStorageConfig( true );
	
	delete allStoDtlCriterias;
	delete allStoDtlCritValues;
end;
</source>
    </JadeMethod>
    <JadeMethod name="tConfigAllDefault" id="247a5b08-bebe-42cc-8730-cdd0a2c89c38">
        <updating/>
        <source>tConfigAllDefault() updating;
// cnwmp6
// cnwjre1
/*

Purpose:			Test using storage config with all default options and no free storage days 

Parameters:			

Return Value:		


Date		Who		Reason
02 October 2012	cnwjre1	Initial creation

*/

vars
	storageConfig	: CM_StorageConfig;
	triggers		: CM_StorageTriggerByType;
	calendar		: CM_Calendar;
	deriveDebtorFrom	: CM_DebtorType;
	includeFirstDay	: Boolean;
	includeLastDay	: Boolean;
	shipReceivalType	: Integer;
	shipReleaseType		: Integer;
begin
	self.deleteStorageConfig( false );
	deriveDebtorFrom := app.myRoot.allDebtorTypes["SDT1"];		// cargo operator
	calendar := self.setupCalendar2();
	create triggers transient;
	// all options false/null
	storageConfig := self.setupStorageConfig2(calendar, includeFirstDay, includeLastDay, shipReceivalType, shipReleaseType, false, false, deriveDebtorFrom, triggers, false, 0, 0, 0);	// TFS 2570
	self.importExportStorage3(storageConfig);
epilog
	self.resetDefaultTranMap();												// 17/04/2013 cnwmh5
	delete triggers;
	self.deleteStorageConfig( true );
end;</source>
    </JadeMethod>
    <JadeMethod name="tConfigFirstAndLastDays" id="9d7e7224-e534-4ddd-a986-62f975589ca9">
        <updating/>
        <source>tConfigFirstAndLastDays() updating;
// cnwmp6
// cnwjre1
/*

Purpose:			Test using storage config with use first and last days but with no free storage days

Parameters:			

Return Value:		


Date		Who		Reason
02 October 2012	cnwjre1	Initial creation

*/

vars
	storageConfig	: CM_StorageConfig;
	triggers		: CM_StorageTriggerByType;
	calendar		: CM_Calendar;
	deriveDebtorFrom	: CM_DebtorType;
	includeFirstDay	: Boolean;
	includeLastDay	: Boolean;
	shipReceivalType	: Integer;
	shipReleaseType		: Integer;
	chargedDaysWorking	: Boolean;
	freeDaysWorking		: Boolean;
begin
	self.deleteStorageConfig( false );
	deriveDebtorFrom := app.myRoot.allDebtorTypes["SDT1"];		// cargo operator
	calendar := self.setupCalendar2();
	create triggers transient;
	// set the options
	includeFirstDay := true;
	includeLastDay := true;
	//shipReceivalType := CM_StorageConfig.ShipReceivalExchangeStart;
	//shipReleaseType := CM_StorageConfig.ShipReleaseExchangeEnd;
	storageConfig := self.setupStorageConfig2(calendar, includeFirstDay, includeLastDay, shipReceivalType, shipReleaseType, chargedDaysWorking, freeDaysWorking, deriveDebtorFrom, triggers, false, 0, 0, 0);	// TFS 2570
	self.importExportStorage3(storageConfig);
epilog
	self.resetDefaultTranMap();												// 17/04/2013 cnwmh5
	delete triggers;
	self.deleteStorageConfig( true );
end;</source>
    </JadeMethod>
    <JadeMethod name="tConfigFirstDay" id="bf997e20-1841-4b78-9c47-5acb24f9c5d2">
