    <JadeMethod name="loadMachineRules" id="5d032fdc-57eb-4ffd-9c49-406c4a956a9b">
        <updating/>
        <source>loadMachineRules()updating, protected;
//--------------------------------------------------
// Created:	18 July 2005 By: cnwgd1
//--------------------------------------------------
// Changed On	By			Reason
// ----------	--------	-------------------------------------------------
// 31/03/2016	cnwdap1		PAR #35843 Make monitor time based rather than object count based
vars

	passport		: CM_Passport;
	cmifMonitor		: CMIF_Monitor;
	ruleMaster		: CM_RTQueueMultiRuleTAMaster;
	ruleType		: CM_RTQueueMultiRuleTAType;
	cnt,
	partsInJob,
	partsDone		: Integer;
	lastUpdated		: Decimal [20];										// PAR #35843
	
begin

	app.mousePointer := self.MousePointer_HourGlass;				
	passport := app.myPassport;
	self.tblTATypes.rows := self.tblTATypes.fixedRows;
	self.tblTATypes.clearAllSelected();
	
	self.tblTAMaster.rows := self.tblTAMaster.fixedRows;
	self.tblTAMaster.clearAllSelected();

	cmifMonitor := passport.myCMIFMonitor;
	if cmifMonitor &lt;&gt; null then
		delete cmifMonitor;
	endif;
	create cmifMonitor transient;
	cmifMonitor.myParent := self;
	passport.setMyCMIFMonitor(cmifMonitor);

	self.modalDialogReturnValue := self.ModalDialogReturn_Null;	
	self.modalDialogShow(null, 'Cancel' , null, null, 'Loading Rules',  'Please Wait....');
	self.pbProgressBar.visible := true;
	
	partsInJob := self.myTerminal.allRTQueueMultiRuleTATypes.size + self.myTerminal.allRTQueueMultiRuleTAMasters.size;
	
	
	foreach ruleType in self.myTerminal.allRTQueueMultiRuleTATypes discreteLock do
		cnt := cnt + 1;
		partsDone := partsDone + 1;
		self.tblDataDisplayRowTAType(ruleType);
		//if cnt = 100 then																				// PAR #35843
		if (app.relativeMachineTime - lastUpdated) &gt; CMIF_Monitor.Monitor_TimeBetweenUpdates then		// PAR #35843
			if (not cmifMonitor.updateProgress(cmifMonitor.message, partsInJob, partsDone)) then
				break;
			endif;
			cnt := 0;
			lastUpdated := app.relativeMachineTime;														// PAR #35843
		endif;
	endforeach;
	
	foreach ruleMaster in self.myTerminal.allRTQueueMultiRuleTAMasters discreteLock do
		cnt := cnt + 1;
		partsDone := partsDone + 1;
		self.tblDataDisplayRowMaster(ruleMaster);
		if cnt = 100 then
			if (not cmifMonitor.updateProgress(cmifMonitor.message, partsInJob, partsDone)) then
				break;
			endif;
			cnt := 0;
		endif;
	endforeach;

epilog
	app.mousePointer := self.MousePointer_Default;									
	delete cmifMonitor;
	app.myPassport.setMyCMIFMonitor(null);
	self.tblTATypes.colourRows(self.colorRow1, self.colorRow2);
	if self.tblTATypes.rows &gt; self.tblTATypes.fixedRows then
		self.tblTATypes.selectRow(self.tblTATypes.fixedRows + 1, false);		
		self.setCurrentRule(self.tblTATypes.accessRow(self.tblTATypes.row).itemObject.CM_RTQueueMultiRule);
	endif;
	
	self.tblTAMaster.colourRows(self.colorRow1, self.colorRow2);
	
	self.frmModalDialog.visible := false;	
	return;
end;</source>
        <access>protected</access>
    </JadeMethod>
