    <JadeMethod name="mnuClassSuper_click" id="3a4ec377-169b-44dd-8777-47ad75b09a74">
        <controlMethod name="MenuItem::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>mnuClassSuper_click(menuItem: MenuItem input) updating;
// --------------------------------------------------------------------------------
// Created:		21 January 1999 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 11/07/1999	cnwdad1		Added a call of the 'confirmRefresh' method.
//
// --------------------------------------------------------------------------------
begin
	menuItem.checked	:=	(not menuItem.checked);
	self.confirmRefresh();
end;</source>
        <Parameter name="menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
