    <JadeMethod name="doBaseFormCancel" id="ac05d1d9-b233-41a5-9d82-e342f28e1c4b">
        <updating/>
        <source>doBaseFormCancel() updating, protected;

vars

begin
	if app.msgBox(app.getErrorString(UnsavedChangesWillBeLost) &amp; CrLf &amp; app.getErrorString(AreYouSure), app.getErrorString(Warning), MsgBox_Yes_No + MsgBox_Exclamation_Mark_Icon) = MsgBox_Return_No then
		return;
	endif;

	inheritMethod();
	
	self.returnValue := IDCANCEL; 
	self.unloadForm;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doBaseFormSave" id="cd575cd1-a8c3-4291-be88-d50b8dcdc755">
        <updating/>
        <source>doBaseFormSave() updating, protected;

vars

begin
	inheritMethod();
	if self.doSave() then
		
		self.returnValue := IDOK; 
		self.unloadForm;
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
