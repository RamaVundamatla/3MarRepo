    <JadeMethod name="setIntFaceObject" id="a72b98ac-34f6-4b6b-82c6-347ea3236319">
        <source>setIntFaceObject(_intFaceObject	: CMIF_BulkRelease input) : Boolean;
//-----------------------------------------------------------------------
// Created:	13 February 2006 By: cnwgd1
//
// Changed On		Changed By		Reason
// ------------	------------	-----------------------------------------
// 20/06/2024		jlizm1			TFS 63908 Allow duplicate driver names
//-----------------------------------------------------------------------
vars
	loadStateSet 	: Boolean;
	tmpRegoNumber 	: String;
	tmpVehicle		: CM_Vehicle;
	pxyTI,
	ti				: CM_TrackedItem;
	tbl				: CM_DataTable;
	numRows,
	row				: Integer;
	localTimeIn,
	localTimeOut	: TimeStamp;
	driver			: CM_DriverDetails;
	
begin

	_intFaceObject.myTerminal := self.myTerminal;
	
	tbl := self.tblAttachments;
	numRows := tbl.rows;
	foreach row in tbl.fixedRows + 1 to numRows do
		pxyTI := tbl.accessRow(row).itemObject.CM_TrackedItem;
		if pxyTI = null then
			continue;
		endif;
		//app.cmsBeginLoad(loadStateSet);
		//pxyTI := ti.pxyCreateUpdateProxy();
		
		_intFaceObject.allTrackedItems.add(pxyTI);
		
		if _intFaceObject.myCargoType = null then
			_intFaceObject.myCargoType 	:= pxyTI.myCargoType;
		endif;
		if _intFaceObject.operatorCode = null then
			_intFaceObject.operatorCode := pxyTI.operatorCode;
		endif;
		//app.cmsEndLoad(loadStateSet);
	endforeach;
	/*
	if _intFaceObject.allTrackedItems.isEmpty then
		app.msgBox(app.getErrorString(MustAddAtLeastOneAttach), app.getErrorString(Error), MsgBox_Exclamation_Mark_Icon);
		return false;
	endif;
	*/
	_intFaceObject.myVoyage		:= self.cmbVoyage.listObject.CM_Voyage;
	
	_intFaceObject.type 	:= BR_TYPE_BOL; //BR_TYPE_ROAD;
	
	if self.cmbDriverCode.visible then
		if self.cmbDriverCode.listObject &lt;&gt; null then
			driver := self.cmbDriverCode.listObject.CM_DriverDetails;
		endif;
	else
		driver := self.myTerminal.findDriver(self.txtReceivedBy.text);
	endif;
	
	if driver &lt;&gt; null then
		_intFaceObject.userPickedUp := driver.code;
	endif;
	
	if self.cmbConsignee.listObject &lt;&gt; null then
		_intFaceObject.consigneeCode := self.cmbConsignee.listObject.CM_ConsigneeConsignor.code;
	endif;

	tmpRegoNumber 			:= self.txtVehicleNumber.text;
	tmpVehicle 				:= self.myTerminal.vehicles[tmpRegoNumber, ""];
	_intFaceObject.myVehicle := tmpVehicle;
	_intFaceObject.state 	:= self.txtState.text;

	_intFaceObject.myCarrier := self.cmbCarrier.myObject.CM_Carrier;	
	if _intFaceObject.myCarrier &lt;&gt; null then
		_intFaceObject.carrierCode := _intFaceObject.myCarrier.code;
	endif;

	_intFaceObject.myLoadingCompany := self.cmbLoader.myObject.CM_LoadingCompany;
	
	_intFaceObject.myUser := self.cmbUser.myObject.CM_User;
	
	_intFaceObject.dateRequested.setDate(app.actualTimeServer.date);
	_intFaceObject.dateRequested.setTime(app.actualTimeServer.Time);
	//release no below might be 'auto assigned' string - thats fine, gets assigned 
	//in transation state to preserve key series integrity
	_intFaceObject.releaseNo := self.txtGatePass.text;
	localTimeIn.setDate(self.dateIn.getDate());
	localTimeIn.setTime(self.timeIn.getTime());
	_intFaceObject.dateTimeIn := self.localToSystemTime(localTimeIn);	// 17/6/16 cnwmp6 TFS 488 - Multi timezone support
	localTimeOut.setDate(self.dateOut.getDate());
	localTimeOut.setTime(self.timeOut.getTime());
	_intFaceObject.dateTimeOut := self.localToSystemTime(localTimeOut);	// 17/6/16 cnwmp6 TFS 488 - Multi timezone support
		
	_intFaceObject.remarks := self.txtExceptions.text;
	_intFaceObject.deliveryReleaseNumber := self.txtWorkNumber.text;
	_intFaceObject.gate := self.cmbGate.text;
	_intFaceObject.transportId := tmpRegoNumber;
	_intFaceObject.myLoadingCompany := self.cmbLoader.myObject.CM_LoadingCompany;
			
	if _intFaceObject.status &lt; BR_ACTIVE then
		_intFaceObject.status := BR_ACTIVE;
	endif;
	
	return true;
end;</source>
        <Parameter name="_intFaceObject" type="CMIF_BulkRelease" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setupForm" id="3799df77-7221-4684-a183-f76b8307ce73">
        <updating/>
        <source>setupForm() updating;
//------------------------------------------------
// Created: 06 April 2006 By: cnwgd1
//------------------------------------------------
// 17 Mar 2010	cnwcs5	par 23151
vars

	terminalArea : CM_TerminalArea;
	
begin
	
	self.frmToolbar.alignContainer	:=	Frame.AlignContainer_Top; // this will make the dkcMain line up its top

	self.setNavigatorHeading(self.caption);
	self.toolbarStyle		:=	self.ToolbarStyle_ShowNoHide;
	self.showToolbar		:=	true;
	
//	terminalArea := self.myTerminal.allTerminalAreasByTypeId[TA_TYPE_ROAD_TRANS, self.myTerminal.getConfig(DefRoadOpsArea).String.trimRight];
//	self.myAssistant.comboBoxTerminalArea(self.cmbGate, TA_TYPE_ROAD_TRANS, terminalArea);
	// load departure gates
	self.myAssistant.comboBoxGates (self.cmbGate, self.myTerminal.getConfig (GateDefaultExit).CM_Gate);
	self.cmbUser.setObject(app.myPassport.myUser);
	self.initTblAttachments();
	
	inheritMethod();
	
	//th2 PAR 12549 - auto-generated BOL numbers
//	if app.getMyTerminalConfigDO_NOT_USE(GateInAutoVisitNo).Boolean then
	if self.myTerminal.getConfig(GateInAutoVisitNo).Boolean then
		//th2 PAR 12449 - eventually gets assigned the next number in CM_BulkRelease::setFromCMIFBulkRelease
		self.txtGatePass.text := app.getErrorString(BOLNumber_AutoGen);
		self.txtGatePass.enabled := false;
	else
		self.txtGatePass.text := null;
		self.txtGatePass.enabled := true;
	endif;
	
	self.txtReceivedBy.setFocus();
	
end;</source>
    </JadeMethod>
    <JadeMethod name="showHideDriverCode" id="0545ba79-4e3c-44cd-9fc3-9a9361d29504">
        <source>showHideDriverCode(_show : Boolean);
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
20 June 2024		jlizm1	Initial creation TFS 63908 Allow duplicate driver names

*/
constants
	Spacing 		: Integer = 23;
	TopGrpHeight 	: Integer = 203;
	GrpSpacing		: Integer = 2;
	
vars

begin
	if _show then
		self.grpReleaseDetail.height:= TopGrpHeight + Spacing;
		self.grpTrackedItems.top 	:= TopGrpHeight + Spacing + GrpSpacing;
		
		self.lblDriverCode.visible 	:= true;
		self.cmbDriverCode.visible 	:= true;
		self.lblDriverCode.top 		:= self.lblReceivedBy.top + (1 * Spacing);
		self.cmbDriverCode.top 		:= self.txtReceivedBy.top + (1 * Spacing);
		self.lblLoader.top 			:= self.lblReceivedBy.top + (2 * Spacing);
		self.cmbLoader.top 			:= self.txtReceivedBy.top + (2 * Spacing);
		self.lblDeliveredBy.top 	:= self.lblReceivedBy.top + (3 * Spacing);
		self.cmbUser.top 			:= self.txtReceivedBy.top + (3 * Spacing);
		self.lblExceptions.top 		:= self.lblReceivedBy.top + (4 * Spacing);
		self.txtExceptions.top 		:= self.txtReceivedBy.top + (4 * Spacing);
		self.lblVoyage.top 			:= self.txtExceptions.top + self.txtExceptions.height + 5;
		self.cmbVoyage.top 			:= self.txtExceptions.top + self.txtExceptions.height + 5;
		
	else
		self.grpReleaseDetail.height:= TopGrpHeight;
		self.grpTrackedItems.top 	:= TopGrpHeight + GrpSpacing;
		
		self.cmbDriverCode.clear();
		self.lblDriverCode.visible := false;
		self.cmbDriverCode.visible := false;
		self.lblLoader.top 			:= self.lblReceivedBy.top + (1 * Spacing);
		self.cmbLoader.top 			:= self.txtReceivedBy.top + (1 * Spacing);
		self.lblDeliveredBy.top 	:= self.lblReceivedBy.top + (2 * Spacing);
		self.cmbUser.top 			:= self.txtReceivedBy.top + (2 * Spacing);
		self.lblExceptions.top 		:= self.lblReceivedBy.top + (3 * Spacing);
		self.txtExceptions.top 		:= self.txtReceivedBy.top + (3 * Spacing);
		self.lblVoyage.top 			:= self.txtExceptions.top + self.txtExceptions.height + 5;
		self.cmbVoyage.top 			:= self.txtExceptions.top + self.txtExceptions.height + 5;

	endif;
	
epilog

end;</source>
        <Parameter name="_show" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="showWithObjectMode" id="0a36f1d9-6db1-4d6d-b1a9-acafaa06320d">
        <updating/>
        <source>showWithObjectMode(_object: CM_Object; _doMode: Boolean) updating;
//------------------------------------------------
