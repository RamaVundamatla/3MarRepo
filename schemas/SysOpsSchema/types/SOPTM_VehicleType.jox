    <JadeMethod name="setupThumbnailDetails" id="a2bee972-9ace-4937-9967-05bd525750c7">
        <updating/>
        <source>setupThumbnailDetails() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
31 January 2013	cnwmc5	Initial creation HAT 2189

*/

vars

begin
	self.myForm.useProxyObject := true;
	self.myForm.setTblDataEntRows(ETDef_VehicleType);
	
	self.myForm.shtTblInput1.caption := 'Details';
	self.myForm.initTblInput(self.myForm.tblInput1, ETDef_VehicleType);	
	self.myForm.shtTblInput1.visible := true;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="showThumbnail" id="082bee59-71a8-4bc6-9c5f-65a6b9158bbf">
        <updating/>
        <source>showThumbnail(_vehicleType : CM_VehicleType) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 January 2013	cnwmc5	Initial creation HAT 2189

*/

vars

begin
	self.myForm.tblInput1.clearValues;

	self.myForm.tblInput1.setValueByName(ETRow_Type, _vehicleType.type);

epilog

end;</source>
        <Parameter name="_vehicleType" type="CM_VehicleType"/>
    </JadeMethod>
