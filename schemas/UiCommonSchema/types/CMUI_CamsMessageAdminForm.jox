    <JadeMethod name="buildCmbStatus" id="c1468961-5adc-4ea8-86f0-6fe99689f979">
        <source>buildCmbStatus();
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
04 July 2024	navcs2	ChangeRequest 63797: EUP | CAMS Search for outgoing messages - CAMS Message Enquiry
22/08/2024		navcs2	Defect 65771: EUP - CAMS Administration form - All Status shown twice in the dropdown
*/

vars

begin
	self.cmbStatus.clear();
	
	self.cmbStatus.addItemWithData("All Statuses" , self.AllStatuses);
	self.cmbStatus.addItemWithData(self.getCamsStatusString(CAM_IDLESTATUS) ,CAM_IDLESTATUS);
	self.cmbStatus.addItemWithData(self.getCamsStatusString(CAM_SENDSTATUS) ,CAM_SENDSTATUS);
	self.cmbStatus.addItemWithData(self.getCamsStatusString(CAM_COMPLETESTATUS) ,CAM_COMPLETESTATUS);
	self.cmbStatus.addItemWithData(self.getCamsStatusString(CAM_RESENDSTATUS) ,CAM_RESENDSTATUS);
	self.cmbStatus.addItemWithData(self.getCamsStatusString(CAM_HOLDSTATUS) ,CAM_HOLDSTATUS);
	self.cmbStatus.addItemWithData(self.getCamsStatusString(CAM_ERRORSTATUS) ,CAM_ERRORSTATUS);
	
	self.cmbStatus.listIndex := 1;
epilog

end;</source>
    </JadeMethod>
