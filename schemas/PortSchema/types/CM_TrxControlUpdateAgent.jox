    <JadeMethod name="trxUpdateVoyage" id="2e035511-5131-4bdb-8ff9-bf91567aae05">
        <updating/>
        <source>trxUpdateVoyage(_hasStructure, _includeStructure : Boolean;
				_proxyVoyage : CM_Voyage;
				_conflictManager : CMIF_HMS_ConflictsManager output;
				_allMovementsUpdateOrient : HMS_VoyageMovementSet input;
				_changedPorts : Boolean;
				_passport : CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:     16 July 2001 by cnwrs1
//
// Purpose:     
// ---------------------------------------------------------------------------
//28 Sep 2009  	cnwer1 	PAR 20191 - added _allMovementsUpdateOreint 
//03 Feb 2014	cnwdap1	PAR #33337 CCMS PTR 2214 HMS Enhancements - correct orientation updating
vars

begin

	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);


	app.setContinueCMExceptions(false);

	if _passport.myStateChangeController &lt;&gt; null then
		_passport.myStateChangeController.initForObjects(_proxyVoyage.pxyGetRealObject().CM_Voyage.allOnsiteTIsByIdCargoType);  //jlier1 TFS 61676 14/12/23
	endif;
	
	beginTransaction;

	app.myUtilityUA.utlUpdateVoyage(_hasStructure, _includeStructure,_proxyVoyage, _conflictManager,_changedPorts, _passport); //par 23043

	//if not _passport.hasErrorsOrWarnings and															// PAR #33337
	if not _passport.hasErrors and (_passport.warningsAcknowledged or not _passport.hasWarnings) and	// PAR #33337
		_allMovementsUpdateOrient  &lt;&gt;  null and
		not _allMovementsUpdateOrient.isEmpty	then
		//EPR 28/9/09 PAR#20191
		app.myUtilityUA.utlUpdateMovementsOrientation(_allMovementsUpdateOrient,_proxyVoyage.starboardBerthed,_passport);
	endif;
epilog
	self.finaliseActivityWithPassport(_passport);
end;</source>
        <Parameter name="_hasStructure" type="Boolean"/>
        <Parameter name="_includeStructure" type="Boolean"/>
        <Parameter name="_proxyVoyage" type="CM_Voyage"/>
        <Parameter name="_conflictManager" type="CMIF_HMS_ConflictsManager" usage="output"/>
        <Parameter name="_allMovementsUpdateOrient" type="HMS_VoyageMovementSet" usage="input"/>
        <Parameter name="_changedPorts" type="Boolean"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
