    <JadeMethod name="doExit" id="8445f08f-7659-4aca-96a3-af0f1be0c0f2">
        <updating/>
        <source>doExit() updating;
// -----------------------------------------------------------------------------
// Created:		25 July 2002 by cnwka1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	---------------------------------------------
//
// -----------------------------------------------------------------------------
vars
	
begin
	self.allConnections.purge();
	delete self.myConnection;
	delete self.myTcpipSendAgent;
end;</source>
    </JadeMethod>
    <JadeMethod name="doFormLoad" id="7c1eab5b-b52e-402e-91b3-fb37e1e6ceb9">
        <updating/>
        <source>doFormLoad() updating,protected;
// -----------------------------------------------------------------------------
// Created:		25 July 2002 by cnwka1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	---------------------------------------------
//
// -----------------------------------------------------------------------------
begin
	self.centreWindow;
	if self.myConnection = null then 
		create myConnection transient;
	endif;
	if self.myTcpipSendAgent = null then
		create self.myTcpipSendAgent transient;
	endif;
	on ConnectionException do self.xhandlerConnection(exception) global;
	self.myTerminal := CM_Terminal.firstInstance;
	self.loadTags();
	self.loadReaders();
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doSwipeIt" id="eada8313-4b94-498a-b7a7-ddd9f59f1ec0">
        <source>doSwipeIt() protected;
/*
----------   ----------  --------------------------------------------------
Created:	07 September 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	reader				: CM_RFIDTagReader;
	tag					: CM_RFIDTag;
	ip,
	msgStr				: String;
	connection			: CM_TcpRFIDConnection;
begin
	if self.chkRandomTag.value then
		self.selectRandomTag();
	endif;
	
	if self.chkRandomRead.value then
		self.selectRandomReader();
	endif;
	self.doWindowEvents(0);
	
	reader := self.lstReader.listObject.CM_RFIDTagReader;
	tag:= self.lstTag.listObject.CM_RFIDTag;
	
	if reader = null then
		app.msgBox('No reader selected','Error', MsgBox_OK_Only);
		return;
	endif;
	
	if tag = null then
		app.msgBox('No tag selected','Error', MsgBox_OK_Only);
		return;
	endif;
	
	msgStr := 'B' &amp; tag.serialNumber &amp; '=00001TFFF';

	//app.writeStatement(class.name &amp; '::' &amp; method.name &amp; '-' &amp; app.computerName &amp; ' ' &amp; reader.portNumber.String);
	connection := self.getConnection(reader);
	
	if connection.state &lt;&gt; TcpIpConnection.Connected then
		connection.open();
	endif;
	
	if connection.state &lt;&gt; TcpIpConnection.Connected then
		app.writeStatement(class.name &amp; '::' &amp; method.name &amp; 'ERROR &gt;&gt; Connection not open');
		return;
	else
		//app.writeStatement(class.name &amp; '::' &amp; method.name &amp; 'connection opened.');
	endif;
	
	connection.writeBinary(msgStr.asANSI(0));	// 14/3/16 cnwmp6 PAR 36286 unicode version

	

end;


</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="getConnection" id="65e203b8-499d-45a2-b9d8-5384462eb924">
        <source>getConnection(_reader : CM_RFIDTagReader) : CM_TcpRFIDConnection;
/*
----------   ----------  --------------------------------------------------
Created:	07 September 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	connection			: CM_TcpRFIDConnection;
begin
	connection := self.allConnections[_reader];
	if connection = null then
		create connection transient;
		connection.myRFIDTagReader := _reader;
	
		self.allConnections.add(connection);
	endif;
	
	connection.name := app.computerName;
	connection.port := _reader.portNumber;
	connection.timeout := 5000;
	
	return connection;

end;


</source>
        <Parameter name="_reader" type="CM_RFIDTagReader"/>
        <ReturnType type="CM_TcpRFIDConnection"/>
    </JadeMethod>
    <JadeMethod name="goNuts" id="21fb1433-16df-4363-b951-9695307484b4">
        <source>goNuts();
/*
----------   ----------  --------------------------------------------------
Created:	07 September 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	tag,
	tags			: Integer;
	reader			: CM_RFIDTagReader;
	rfidTag			: CM_RFIDTag;
begin
	
	tags := self.txtSeconds.text.Integer;
	
	if self.chkRandomTag.value then
		self.selectRandomTag();
	endif;
	
	if self.chkRandomRead.value then
		self.selectRandomReader();
	endif;
	self.doWindowEvents(0);
	
	reader := self.lstReader.listObject.CM_RFIDTagReader;
	rfidTag:= self.lstTag.listObject.CM_RFIDTag;
	
	if reader = null then
		app.msgBox('No reader selected','Error', MsgBox_OK_Only);
		return;
	endif;
	
	if rfidTag = null then
		app.msgBox('No tag selected','Error', MsgBox_OK_Only);
		return;
	endif;
	
	
	foreach tag in 1 to tags do
		process.sleep(10);
		self.doSwipeIt();	
	endforeach;

end;


</source>
    </JadeMethod>
