    <JadeMethod name="isTransactionToBeProcessed" id="9e771242-4538-44ef-ab0f-776efa673ee5">
        <source>isTransactionToBeProcessed(_camProtocol: CM_CamProtocol; 
						   _trans: CM_TITransaction; 
						   _camAgent: CM_CamControllerAgent): Boolean;
/*
Purpose: Exclude logically deleted 'Received Road' transaction in EDI processing.
		 Reimplement the method to apply this condition check (for the meantime) specific to
		 1 - CODECO Standard
		 2 - CODECO SMDG 213
		 In this way, the code for other types of CODECO are still intact

Parameters:			

Return Value:		

Date		Who		TFS		Reason
25 Nov 2019	jlgdi1	46578	Initial creation
*/

begin
	if not inheritMethod(_camProtocol, _trans, _camAgent) then
		return false;
	endif;
	
	if _trans.isKindOf(CM_ReceiveRoad) and _trans.isDeleted() then 
		return false;
	endif;
	
	return true;
end;</source>
        <Parameter name="_camProtocol" type="CM_CamProtocol"/>
        <Parameter name="_trans" type="CM_TITransaction"/>
        <Parameter name="_camAgent" type="CM_CamControllerAgent"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="makeMessageHeader" id="61ce5f3e-e7a7-424d-8d89-477e94e36359">
        <updating/>
        <source>makeMessageHeader(_camFile : CM_CamFile input; _camTaskHistory : CM_CamTaskHistory input; _unhSeqNumber : Integer io; 
					_type : String; _fileType : String; _coll :HugeStringArray input) : String updating;
					
/*****************************************************
Date			Name		TFS#		Description
08 April 2019	jlgns1					Initial creation
8/04/2019 		JLGNS1	ChangeRequest 	39725: JMT - CODECO 00B
04/07/2022		jlizm1	TFS 53754 LNX Different local and server time zones causing incorrect edi outputs
****************************************************/
vars
	protocol	: CM_CamProtocol; 
	strLine 	: String;
begin
	_unhSeqNumber 	:= _unhSeqNumber + 1;
	protocol 		:= _camTaskHistory.camProtocol;
	// UNH
	
	strLine := strLine &amp; self.outputFileMessage(_camTaskHistory, self.makeUNHSegment (protocol, _unhSeqNumber, _fileType, "D", "00B", "UN", "SMDG21", null, _camTaskHistory.runDateTime), _coll);			//+17/06/2016 cnwma1  TFS#2159
	
	strLine := strLine &amp; self.outputFileMessage(_camTaskHistory, self.makeBGMSegment (protocol, _type, _unhSeqNumber, 9, null), _coll);
	
	strLine := strLine &amp; self.outputFileMessage(_camTaskHistory, self.makeDTMSegment(protocol,_coll,"137",_camTaskHistory.runDateTime,"203"), _coll);
	
	_camFile.incrementMessageCount();
	return strLine;
end;</source>
        <Parameter name="_camFile" type="CM_CamFile" usage="input"/>
        <Parameter name="_camTaskHistory" type="CM_CamTaskHistory" usage="input"/>
        <Parameter name="_unhSeqNumber" type="Integer" usage="io"/>
        <Parameter name="_type" type="String"/>
        <Parameter name="_fileType" type="String"/>
        <Parameter name="_coll" type="HugeStringArray" usage="input"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="makeMessageHeaderMsgFunc" id="5d3c8f1f-3852-46b8-94fc-3b5044123a96">
        <updating/>
        <source>makeMessageHeaderMsgFunc(_camFile : CM_CamFile input; 
						 _camTaskHistory : CM_CamTaskHistory input; 
						 _unhSeqNumber : Integer io; 
						 _type : String;
						 _msgFunction : Integer;
						 _fileType : String; 
						 _coll :HugeStringArray input) : String updating;
/*
Purpose: Create Message Header (like the original makeMessageHeader() method),
		 the difference is the parameter '_msgFunction'. The message function code will derive from 
		 the calling method.

Parameters:			

Return Value:		

Date		Who		TFS		Reason
07 Nov 2019	jlgdi1	46578	Initial creation
04 Jul 2022	jlizm1	53754 	LNX Different local and server time zones causing incorrect edi outputs
*/
constants
	Msg_Version_D = "D";
	Msg_Release_00B = "00B";
	Agency_UN = "UN";
	Association_SMDG21 = "SMDG21";
	Dtm_Function_DateTime = "137";
	Dtm_Format_CCYYMMDDHHMM = "203";
	
vars
	protocol : CM_CamProtocol; 
	strLine : String;
	
begin
	_unhSeqNumber 	:= _unhSeqNumber + 1;
	protocol 		:= _camTaskHistory.camProtocol;
	
	// UNH
	strLine := strLine &amp; self.outputFileMessage(_camTaskHistory, 
												self.makeUNHSegment(protocol, 
																	_unhSeqNumber, 
																	_fileType, 
																	Msg_Version_D,
																	Msg_Release_00B,
																	Agency_UN, 
																	Association_SMDG21, 
																	null, 
																	_camTaskHistory.runDateTime),
												_coll);	//+17/06/2016 cnwma1  TFS#2159
	// BGM
	strLine := strLine &amp; self.outputFileMessage(_camTaskHistory, 
												self.makeBGMSegment(protocol, 
																	_type, 
																	_unhSeqNumber, 
																	_msgFunction, 
																	null),
												_coll);
	
	strLine := strLine &amp; self.outputFileMessage(_camTaskHistory, 
												self.makeDTMSegment(protocol,
																	_coll,
																	Dtm_Function_DateTime,
																	_camTaskHistory.runDateTime,
																	Dtm_Format_CCYYMMDDHHMM), 
												_coll);
	
	_camFile.incrementMessageCount();
	return strLine;
end;</source>
        <Parameter name="_camFile" type="CM_CamFile" usage="input"/>
        <Parameter name="_camTaskHistory" type="CM_CamTaskHistory" usage="input"/>
        <Parameter name="_unhSeqNumber" type="Integer" usage="io"/>
        <Parameter name="_type" type="String"/>
        <Parameter name="_msgFunction" type="Integer"/>
        <Parameter name="_fileType" type="String"/>
        <Parameter name="_coll" type="HugeStringArray" usage="input"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="makeMessageLOC_GATEIN" id="2acec8e0-6452-459a-97ad-34d503acfd6b">
        <source>makeMessageLOC_GATEIN(_camProtocol: CM_CamProtocol; _group: HugeStringArray input; _activity: Integer; _ti: CM_TrackedItem; _contentsStatus: String) protected;
/*****************************************************
Date			Name		TFS#		Description
08 April 2019	jlgns1					Initial creation
8/04/2019 		JLGNS1	ChangeRequest 	39725: JMT - CODECO 00B
03 Feb 2021		jlgdap1	TFS 50726 		GPHA CODECO Message to Differentiate Between Inter-Terminal Transfer and Delivery
****************************************************/
vars
	code 	: String;
	pCode 	: String;
	ourCode : String;
	terminal: CM_Terminal;
begin
	terminal := _camProtocol.terminal;
	ourCode := terminal.getConfig(PortDestCode).String;
	//get the port code
	code := _ti.loadPort;
	if code &lt;&gt; null then
		pCode := self.getXlatedForeignCode(_camProtocol.operatorXlationCode.trimBlanks, code, XLATION_TYPE_PORT_BYOP, terminal);
		if code = ourCode or pCode = ourCode then
			self.makeLOCSegment(_camProtocol, _group, '9', pCode.trimRight, '139', '6', _camProtocol.camGroup.facilityCode, "72", "ZZZ");
		else
			self.makeLOCSegment(_camProtocol, _group, '9', pCode.trimRight, '139', '6', null, null, null);
		endif;
	endif;
	code := _ti.dischargePort;
	if code &lt;&gt; null then
		pCode := self.getXlatedForeignCode(_camProtocol.operatorXlationCode.trimBlanks, code, XLATION_TYPE_PORT_BYOP, terminal);
		if code = ourCode or pCode = ourCode then
			self.makeLOCSegment(_camProtocol, _group, '11', pCode.trimRight, '139', '6', _camProtocol.camGroup.facilityCode, "72", "ZZZ");
		else
			self.makeLOCSegment(_camProtocol, _group, '11', pCode.trimRight, '139', '6',null, null, null);
		endif;
	endif;
	code := _ti.destinationPort;
	if code &lt;&gt; null then
		pCode := self.getXlatedForeignCode(_camProtocol.operatorXlationCode.trimBlanks, code, XLATION_TYPE_PORT_BYOP, terminal);
		if code = ourCode or pCode = ourCode then
			self.makeLOCSegment(_camProtocol, _group, '8', pCode.trimRight, '139', '6', _camProtocol.camGroup.facilityCode, "72", "ZZZ");
		else
			self.makeLOCSegment(_camProtocol, _group, '8', pCode.trimRight, '139', '6', null, null, null);
		endif;
	endif;
	// TFS 50726 If we're an inter-terminal recival, make a LOC+7 segment if the config option tells us to
	if _ti.myMoveCloneFromTI &lt;&gt; null and _camProtocol.getIncludeLOC7InterTerm then
		self.makeLOC7Segment(_camProtocol, _group, ourCode, '139', '6', '72', 'ZZZ', _ti, false);
	endif;
	// TFS 50726 end
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_camProtocol" type="CM_CamProtocol"/>
        <Parameter name="_group" type="HugeStringArray" usage="input"/>
        <Parameter name="_activity" type="Integer"/>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_contentsStatus" type="String"/>
    </JadeMethod>
    <JadeMethod name="makeMessageLOC_GATEOUT" id="80bf5698-4377-4744-9730-d9d359e58c27">
        <source>makeMessageLOC_GATEOUT(_camProtocol: CM_CamProtocol; _group: HugeStringArray input; _activity: Integer; _ti: CM_TrackedItem; _contentsStatus: String) protected;
/*****************************************************
Date			Name		TFS#		Description
08 April 2019	jlgns1					Initial creation
8/04/2019 		JLGNS1	ChangeRequest 	39725: JMT - CODECO 00B
03 Feb 2021		jlgdap1	TFS 50726 		GPHA CODECO Message to Differentiate Between Inter-Terminal Transfer and Delivery

****************************************************/
vars
	xlCode 			: String;
	loadPort 		: String;
	dischargePort 	: String;
	destination 	: String;
	ourCode 		: String;
	terminal 		: CM_Terminal;
	bulkRelease 	: CM_BulkRelease;
begin
	terminal := _camProtocol.terminal;
	ourCode := terminal.getConfig(PortDestCode).String;
	//get the port code
	loadPort := _ti.loadPort;
	dischargePort := _ti.dischargePort;
	destination := _ti.destinationPort;
	bulkRelease := _ti.allBulkReleasesReleased.first;
	if _ti.isEmpty and	//send to shipper via deliveryRelease
	   bulkRelease &lt;&gt; null and
	   bulkRelease.myVoyage &lt;&gt; null then
		loadPort := ourCode;
//		if dischargePort = null and
		if bulkRelease.myDischargePort &lt;&gt; null then
			dischargePort := bulkRelease.myDischargePort.code;
		endif;
//		if dischargePort = null and
		if bulkRelease.myBookingRefStock &lt;&gt; null then
			dischargePort := bulkRelease.myBookingRefStock.dischargePort;
		endif;
//		if destination = null and
		if bulkRelease.myDestinationPort &lt;&gt; null then
			destination := bulkRelease.myDestinationPort.code;
		endif;
//		if destination = null and
		if bulkRelease.myBookingRefStock &lt;&gt; null then
			destination := bulkRelease.myBookingRefStock.destinationPort;
		endif;
	endif;
	if loadPort &lt;&gt; null then
		xlCode := self.getXlatedForeignCode(_camProtocol.operatorXlationCode.trimBlanks, loadPort, XLATION_TYPE_PORT_BYOP, terminal);
		if loadPort = ourCode or xlCode = ourCode then
			self.makeLOCSegment(_camProtocol, _group, '9', xlCode.trimRight, '139', '6', _camProtocol.camGroup.facilityCode, "72", "ZZZ");
		else
			self.makeLOCSegment(_camProtocol, _group, '9', xlCode.trimRight, '139', '6', null, null, null);
		endif;
	endif;
	if dischargePort &lt;&gt; null then
		xlCode := self.getXlatedForeignCode(_camProtocol.operatorXlationCode.trimBlanks, dischargePort, XLATION_TYPE_PORT_BYOP, terminal);
		if dischargePort = ourCode or xlCode = ourCode then
			self.makeLOCSegment(_camProtocol, _group, '11', xlCode.trimRight, '139', '6', _camProtocol.camGroup.facilityCode, "72", "ZZZ");
		else
			self.makeLOCSegment(_camProtocol, _group, '11', xlCode.trimRight, '139', '6', null, null, null);
		endif;
	endif;
	if destination &lt;&gt; null then
		xlCode := self.getXlatedForeignCode(_camProtocol.operatorXlationCode.trimBlanks, destination, XLATION_TYPE_PORT_BYOP, terminal);
		if destination = ourCode or xlCode = ourCode then
			self.makeLOCSegment(_camProtocol, _group, '8', xlCode.trimRight, '139', '6', _camProtocol.camGroup.facilityCode, "72", "ZZZ");
		else
			self.makeLOCSegment(_camProtocol, _group, '8', xlCode.trimRight, '139', '6', null, null, null);
		endif;
	endif;
	// TFS 50726 If we're an inter-terminal release, make a LOC+7 segment if the config option tells us to
	if _ti.myMoveCloneToTI &lt;&gt; null and _camProtocol.getIncludeLOC7InterTerm then
		self.makeLOC7Segment(_camProtocol, _group, ourCode, '139', '6', '72', 'ZZZ', _ti, true);
	endif;
	// TFS 50726 end
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_camProtocol" type="CM_CamProtocol"/>
        <Parameter name="_group" type="HugeStringArray" usage="input"/>
        <Parameter name="_activity" type="Integer"/>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_contentsStatus" type="String"/>
    </JadeMethod>
    <JadeMethod name="makeMessageRFF_BN" id="6b4e3160-2ac2-4d94-9ace-d8bd7ffef8dc">
        <source>makeMessageRFF_BN(_camProtocol :CM_CamProtocol; _group :HugeStringArray input; _activity :Integer;  _ti :CM_TrackedItem; _transaction :CM_TITransaction)protected;
/*****************************************************
Date			Name	Description
08 Apr 2019		jlgns1	Initial creation
8/04/2019 		JLGNS1	ChangeRequest 	39725: JMT - CODECO 00B
16 Dec 2019		jlgrs1	TFS 48016 - produce RFF+BN on cancelation
18 Feb 2020		jlgka1 	TFS 48550 - CODECO Deletion. Retrieve Booking reference from the ExternalReference Id that we preserve in the Received - Road Transaction.
****************************************************/

vars
	ref						: String;
	deliveryReleaseSnapShot : CM_SnapShot; 
begin
	if _activity = CODECO_GATEIN or 
	   _activity = CODECO_CANCEL or			// TFS 48016
	   _activity = CODECO_VGM then
		if _camProtocol.isUseCarrierRefForBooking then
			ref := _ti.getCarrierReference;
		else
			ref := _ti.bookingReference.trimRight;						
			if ref = null then											
				deliveryReleaseSnapShot := _transaction.mySnapShot;	
				if deliveryReleaseSnapShot &lt;&gt; null then	
					ref := deliveryReleaseSnapShot.CM_TISnapShot.getDeliveryRelease(); 
				endif;	
			endif;								
			
			//jlgka1 TFS 48550 --&gt;
			if ref = null then
				ref := self.getRoadReceiveTrxBookingRef(_ti);
			endif;
			//jlgka1 TFS 48550 &lt;--
		endif;
		
		if ref &lt;&gt; null then
			self.makeRFFSegment (_camProtocol, _group, "BN", ref);	
		endif;														
	endif;

	if _activity = CODECO_GATEOUT then
		if _camProtocol.isUseCarrierRefForBooking then
			ref := _ti.getCarrierReference;
		else
			ref := _ti.deliveryRelease.trimRight;						
			if ref = null then				
				ref := _ti.bookingReference.trimRight;					
			endif;														
		endif;
		
		if ref &lt;&gt; null then											
			self.makeRFFSegment (_camProtocol, _group, "BN", ref);	
		endif;
	endif;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_camProtocol" type="CM_CamProtocol"/>
        <Parameter name="_group" type="HugeStringArray" usage="input"/>
        <Parameter name="_activity" type="Integer"/>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_transaction" type="CM_TITransaction"/>
    </JadeMethod>
    <JadeMethod name="makeMessageRFF_RE" id="f715f2cd-a1e6-408d-99e2-c1460645c66a">
        <source>makeMessageRFF_RE(_camProtocol :CM_CamProtocol; _group :HugeStringArray input; _activity :Integer;  _ti :CM_TrackedItem; _transaction :CM_TITransaction)protected;
/*****************************************************
Date			Name		TFS#		Description
08 April 2019	jlgns1					Initial creation
8/04/2019 		JLGNS1	ChangeRequest 	39725: JMT - CODECO 00B

****************************************************/
vars
	ref			: String;
	bulkRelease : CM_BulkRelease;
begin
	if _activity = CODECO_GATEOUT then
		if _ti.isFull then
			if _ti.deliveryRelease &lt;&gt; null then
				ref := _ti.deliveryRelease.trimRight;
			endif;
		else
			bulkRelease := _ti.allBulkReleasesReleased.first;
			if _ti.deliveryRelease = null and
			   bulkRelease &lt;&gt; null then
				ref := bulkRelease.code.trimRight;
			endif;
		endif;
		if ref &lt;&gt; null then
			self.makeRFFSegment(_camProtocol, _group, "RE", ref);
		endif;
	endif;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_camProtocol" type="CM_CamProtocol"/>
        <Parameter name="_group" type="HugeStringArray" usage="input"/>
        <Parameter name="_activity" type="Integer"/>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_transaction" type="CM_TITransaction"/>
    </JadeMethod>
    <JadeMethod name="makeMessageSealsData" id="2eeaf4b0-1298-467a-bebc-e7282cb24a65">
        <source>makeMessageSealsData(_ti: CM_TrackedItem; _camMessage: CM_CamMessage input; _group: HugeStringArray input; _camProtocol: CM_CamProtocol; _contentsStatus : String );
/*****************************************************
Date			Name		TFS#		Description
08 April 2019	jlgns1					Initial creation
8/04/2019 		JLGNS1	ChangeRequest 	39725: JMT - CODECO 00B

****************************************************/

vars
	strSeal		: String;
	plus 		: Character;
	singleQuote	: Character;	
	seals 		: HugeStringArray;
	sealParty 	: String;
	ventSeal 	: String;
	seal 		: String;
	sealTI 		: CM_SealTI;
begin

	
	create seals transient;
	plus := _camProtocol.elementSeparator;	
	singleQuote	:= _camProtocol.segmentTerminator;	
	_ti.getSealNumStringArray(seals, SealType_Operator);
	foreach strSeal in seals do
		if strSeal.trimRight &lt;&gt; "" then	
			_group.add("SEL" &amp; plus &amp; _camProtocol.formatSeal(strSeal) &amp; plus &amp; "CA" &amp; singleQuote);	
		endif;
	endforeach;
	seals.clear();
	_ti.getSealNumCustomsStringArray(seals);
	foreach strSeal in seals do
		if strSeal.trimRight &lt;&gt; "" then	
			_group.add("SEL" &amp; plus &amp; _camProtocol.formatSeal(strSeal) &amp; plus &amp; "CU" &amp; singleQuote);	
		endif;
	endforeach;
	seals.clear();
	_ti.getSealNumStringArray(seals, SealType_Shipper);
	foreach strSeal in seals do
		if strSeal.trimRight &lt;&gt; "" then	
			_group.add("SEL" &amp; plus &amp; _camProtocol.formatSeal(strSeal) &amp; plus &amp; "SH" &amp; singleQuote);
		endif;
	endforeach;
	seals.clear();
	_ti.getSealNumStringArray(seals, SealType_TerminalOperator);
	foreach strSeal in seals do
		if strSeal.trimRight &lt;&gt; "" then	
			_group.add("SEL" &amp; plus &amp; _camProtocol.formatSeal(strSeal) &amp; plus &amp; "TO" &amp; singleQuote);
		endif;
	endforeach;
	
	if _ti.isKindOf (CM_Container) then
		seals.clear();
		_ti.getSealNumStringArray(seals, SealType_Vent);
		foreach strSeal in seals do
			if strSeal.trimRight &lt;&gt; "" then
				_group.add("SEL" &amp; plus &amp; _camProtocol.formatSeal(strSeal) &amp; plus &amp; "AB" &amp; singleQuote);
			endif;
		endforeach;
	endif;
	foreach sealTI in _ti.allSeals do
		if sealTI.sealType = SealType_Customs or
		   sealTI.sealType = SealType_Operator or
		   sealTI.sealType = SealType_Shipper or
		   sealTI.sealType = SealType_TerminalOperator or
		   sealTI.sealType = SealType_Vent then
			continue;
		endif;
		foreach seal in sealTI.allSealNums do
			//27 Aug 2020	NDL	TFS 49974 - Don't report 'unknown' type seals with no 'current' value.
			if _camProtocol.formatSeal(seal).trimBlanks = null then
				continue;
			endif;
			_group.add("SEL" &amp; plus &amp; _camProtocol.formatSeal(seal) &amp; plus &amp; "AB" &amp; singleQuote);
		endforeach;
	endforeach;
epilog
	delete seals;
end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_camMessage" type="CM_CamMessage" usage="input"/>
        <Parameter name="_group" type="HugeStringArray" usage="input"/>
        <Parameter name="_camProtocol" type="CM_CamProtocol"/>
        <Parameter name="_contentsStatus" type="String"/>
    </JadeMethod>
    <JadeMethod name="makeMessageSealsFromPrevVal" id="07fbcbb9-63ea-4629-82e0-1019af6b96cc">
        <source>makeMessageSealsFromPrevVal( _ti: CM_TrackedItem; _camMessage: CM_CamMessage input; _group: HugeStringArray input; _camProtocol: CM_CamProtocol; _contentsStatus : String );
/*****************************************************
Date			Name		TFS#		Description
08 April 2019	jlgns1					Initial creation
8/04/2019 		JLGNS1	ChangeRequest 	39725: JMT - CODECO 00B

****************************************************/

vars

	plus 		: Character;
	singleQuote	: Character;
	ti 			: CM_TrackedItem;
	sealType 	: CM_SealType;
	prevValue 	: String;
	sealTi 		: CM_SealTI;
	seals 		: StringArray;
	sealStr 	: String;

begin
		
	plus := _camProtocol.elementSeparator;	
	singleQuote	:= _camProtocol.segmentTerminator;
	ti := _ti;
	create seals transient;
	
	sealType := app.myRoot.getSealType(SealType_Operator);
	if sealType &lt;&gt; null then
		sealTi := ti.getSealTI(sealType);
		if sealTi &lt;&gt; null then
			prevValue := sealTi.previousSeal;
			if prevValue &lt;&gt; null then
				seals.clear();
				prevValue.getTokensForDelimiter(",",seals);
				foreach sealStr in seals do
					_group.add("SEL" &amp; plus &amp; _camProtocol.formatSeal(sealStr) &amp; plus &amp; "CA" &amp; singleQuote);
				endforeach;
			endif;
		endif;
	endif;
	
	sealType := app.myRoot.getSealType(SealType_Customs);
	if sealType &lt;&gt; null then
		sealTi := ti.getSealTI(sealType);
		if sealTi &lt;&gt; null then
			prevValue := sealTi.previousSeal;
			if prevValue &lt;&gt; null then
				seals.clear();
				prevValue.getTokensForDelimiter(",",seals);
				foreach sealStr in seals do
					_group.add("SEL" &amp; plus &amp; _camProtocol.formatSeal(sealStr) &amp; plus &amp; "CU" &amp; singleQuote);
				endforeach;
			endif;
		endif;
	endif;
	
	sealType := app.myRoot.getSealType(SealType_Shipper);
	if sealType &lt;&gt; null then
		sealTi := ti.getSealTI(sealType);
		if sealTi &lt;&gt; null then
			prevValue := sealTi.previousSeal;
			if prevValue &lt;&gt; null then
				seals.clear();
				prevValue.getTokensForDelimiter(",",seals);
				foreach sealStr in seals do
					_group.add("SEL" &amp; plus &amp; _camProtocol.formatSeal(sealStr) &amp; plus &amp; "SH" &amp; singleQuote);
				endforeach;
			endif;
		endif;
	endif;
	
	sealType := app.myRoot.getSealType(SealType_TerminalOperator);
	if sealType &lt;&gt; null then
		sealTi := ti.getSealTI(sealType);
		if sealTi &lt;&gt; null then
			prevValue := sealTi.previousSeal;
			if prevValue &lt;&gt; null then
				seals.clear();
				prevValue.getTokensForDelimiter(",",seals);
				foreach sealStr in seals do
					_group.add("SEL" &amp; plus &amp; _camProtocol.formatSeal(sealStr) &amp; plus &amp; "TO" &amp; singleQuote);
				endforeach;
			endif;
		endif;
	endif;
	
	if ti.isKindOf (CM_Container) then
		sealType := app.myRoot.getSealType(SealType_Vent);
		if sealType &lt;&gt; null then
			sealTi := ti.getSealTI(sealType);
			if sealTi &lt;&gt; null then
				prevValue := sealTi.previousSeal;
				if prevValue &lt;&gt; null then
					seals.clear();
					prevValue.getTokensForDelimiter(",",seals);
					foreach sealStr in seals do
						_group.add("SEL" &amp; plus &amp; _camProtocol.formatSeal(sealStr) &amp; plus &amp; "AB" &amp; singleQuote);
					endforeach;
				endif;
			endif;
		endif;
	endif;
	
	foreach sealType in ti.myCargoType.allSealTypes do
		if sealType.sealType = SealType_Customs or
		   sealType.sealType = SealType_Operator or
		   sealType.sealType = SealType_Shipper or
		   sealType.sealType = SealType_TerminalOperator or
		   sealType.sealType = SealType_Vent then
			continue;
		endif;
		
		sealTi := ti.getSealTI(sealType);
		if sealTi &lt;&gt; null then
			prevValue := sealTi.previousSeal;
			if prevValue &lt;&gt; null then
				seals.clear();
				prevValue.getTokensForDelimiter(",",seals);
				foreach sealStr in seals do
					_group.add("SEL" &amp; plus &amp; _camProtocol.formatSeal(sealStr) &amp; plus &amp; "AB" &amp; singleQuote);
				endforeach;
			endif;
		endif;
		
	endforeach; 
	
epilog

	delete seals;
	
end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_camMessage" type="CM_CamMessage" usage="input"/>
        <Parameter name="_group" type="HugeStringArray" usage="input"/>
        <Parameter name="_camProtocol" type="CM_CamProtocol"/>
        <Parameter name="_contentsStatus" type="String"/>
    </JadeMethod>
    <JadeMethod name="makeMessageSealsReceivedData" id="42cbcbf4-5248-4816-a246-f4e59185f3af">
        <source>makeMessageSealsReceivedData(_transaction : CM_Receive; _camProtocol: CM_CamProtocol; _group : HugeStringArray input);
/*****************************************************
Date			Name		TFS#		Description
08 April 2019	jlgns1					Initial creation
8/04/2019 		JLGNS1	ChangeRequest 	39725: JMT - CODECO 00B

****************************************************/

vars
	theSealNumbers 			: StringArray;
	knownSealTypes 			: StringArray;
	knownSealSegmentSuffixes: StringArray;
	sealNumber 				: String;
	sealType 				: String;
	plus 					: String;
	singleQuote 			: String;
	allKnownSealTypes 		: String;
	sealIndex 				: Integer;
begin
	create theSealNumbers transient;
	create knownSealTypes transient;
	create knownSealSegmentSuffixes transient;
	knownSealTypes.add(SealType_Customs);
	knownSealSegmentSuffixes.add("CU");
	knownSealTypes.add(SealType_Operator);
	knownSealSegmentSuffixes.add("CA");
	knownSealTypes.add(SealType_Shipper);
	knownSealSegmentSuffixes.add("SH");
	knownSealTypes.add(SealType_TerminalOperator);
	knownSealSegmentSuffixes.add("TO");
	knownSealTypes.add(SealType_Vent);
	knownSealSegmentSuffixes.add("AB"); // last seal-segment suffix also used for 'unknown' seal types...!
	plus := _camProtocol.elementSeparator;
	singleQuote	:= _camProtocol.segmentTerminator;	
	foreach sealType in knownSealTypes do
		_transaction.getSealsAtReceiveArray(sealType, theSealNumbers);
		foreach sealNumber in theSealNumbers do
			_group.add("SEL" &amp; plus &amp; _camProtocol.formatSeal(sealNumber) &amp; plus &amp;
				knownSealSegmentSuffixes[knownSealTypes.indexOf(sealType)] &amp; singleQuote);
		endforeach;
		theSealNumbers.clear;
	endforeach;
	allKnownSealTypes := knownSealTypes.asCSV(false);
	_transaction.getUnknownSealsAtReceiveArray(allKnownSealTypes, theSealNumbers);// get seal numbers for unknown seal-types
	foreach sealNumber in theSealNumbers do // note use of last seal-segment suffix here...
		_group.add("SEL" &amp; plus &amp; _camProtocol.formatSeal(sealNumber) &amp; plus &amp; knownSealSegmentSuffixes.last &amp; singleQuote);
	endforeach;
epilog
	delete theSealNumbers;
	delete knownSealTypes;
	delete knownSealSegmentSuffixes;
end;</source>
        <Parameter name="_transaction" type="CM_Receive"/>
        <Parameter name="_camProtocol" type="CM_CamProtocol"/>
        <Parameter name="_group" type="HugeStringArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="makeMessageTDT1Segment" id="ca868e59-d0eb-472a-b008-f6db38c38649">
        <source>makeMessageTDT1Segment(_camProtocol: CM_CamProtocol; _group: HugeStringArray input; _activity: Integer; _transaction: CM_TITransaction; _trackedItem: CM_TrackedItem) protected;
/*****************************************************
Date			Name		TFS#		Description
08 April 2019	jlgns1					Initial creation
8/04/2019 		JLGNS1	ChangeRequest 	39725: JMT - CODECO 00B
04 Nov 2019		jlgdi1	46579			Include Receive Road Cancelled transaction (isCamRcvRoadCancelType())
****************************************************/
vars
	voyOpVoyageCode : String;
	opVoyageCode 	: String;
begin
	if _transaction.isCamsRailReceiveType() or _transaction.isCamsRailReleaseType() then
		if _trackedItem.wagonNumber.trimRight &lt;&gt; null then
			self.makeTDT1Segment(_camProtocol, _group, null, '2', '30', _trackedItem.carrier.trimRight[1:17], '172', null, null, null, _trackedItem.wagonNumber.trimRight, "146", "ZZZ", null);
		else
			self.makeTDT1Segment(_camProtocol, _group, null, '2', '30', _trackedItem.carrier.trimRight[1:17], '172', null, null, null, _trackedItem.wagon.trimRight, "146", "ZZZ", null);
		endif;
	elseif (_transaction.isCamsRoadReceiveType()) or (_transaction.isCamRcvRoadCancelType()) then
		self.makeTDT1Segment(_camProtocol, _group, null, '3', '1', _trackedItem.carrier.trimRight[1:17], '172', null, null, null, _trackedItem.vehicle.trimRight, "146", "ZZZ", null);
	elseif _transaction.isCamsRoadReleaseType() then
		self.makeTDT1Segment(_camProtocol, _group, null, '3', '1', _trackedItem.releaseCarrier.trimRight[1:17], '172', null, null, null, _trackedItem.releaseVehicle.trimRight, "146", "ZZZ", null);
	elseif _transaction.isCamsShipReleaseType() or _transaction.isCamsShipReceiveType() then 
		self.makeTDT1Segment(_camProtocol, _group, null, '8', '15', _trackedItem.operatorCode, null, null, null, null, _trackedItem.vesselName , null, null, null);
	else
		self.makeTDT1Segment(_camProtocol, _group, null, null, null, null, null, null, null, null, null, null, null, null);
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="_camProtocol" type="CM_CamProtocol"/>
        <Parameter name="_group" type="HugeStringArray" usage="input"/>
        <Parameter name="_activity" type="Integer"/>
        <Parameter name="_transaction" type="CM_TITransaction"/>
        <Parameter name="_trackedItem" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="makeMessageTDT20Segment" id="bbe2c57c-65a5-4e20-a747-d9ad08be507b">
        <updating/>
        <source>makeMessageTDT20Segment(_protocol: CM_CamProtocol; _camVoyage: CM_CamVoyage; _activity: Integer): String updating, protected;
/*****************************************************
Date			Name		TFS#		Description
08 April 2019	jlgns1					Initial creation
8/04/2019 		JLGNS1	ChangeRequest 	39725: JMT - CODECO 00B

****************************************************/

vars
	vCode 			: String; 
	code 			: String; 
	fCode 			: String; 
	carrierCode 	: String;
	msg				: String;
	xlationOperator : CM_Operator;
	voyage 			: CM_Voyage;
	callSign 		: String;
	lloydsNumber 	: String;
	foundMatch 		: Boolean;
begin 
	vCode := _camVoyage.getSanitisedVoyageCode().trimBlanks;
	// ECN/MOT Requirement - work out carrier - it gets includeed on the TDT+20
	code := _camVoyage.getVoyageOperatorCode;
	xlationOperator := app.myRoot.allOperators[_protocol.operatorXlationCode.trimBlanks];
	fCode := app.myRoot.getXlationForeignOperatorCode(xlationOperator, code, foundMatch).trimRight;
	
	if fCode = null then
		carrierCode := code;
	else
		carrierCode := fCode;
	endif;
	
	voyage := _camVoyage.voyageOid;
	callSign := voyage.callSign.trimRight;
	if callSign = null and  voyage.myVessel &lt;&gt; null then		
		callSign := voyage.myVessel.callSign.trimRight;
	endif;
	lloydsNumber := voyage.lloydsNumber;
	if lloydsNumber = null and voyage.myVessel &lt;&gt; null then	
		lloydsNumber := voyage.myVessel.lloydsNumber;
	endif;
	
	if voyage &lt;&gt; null then
		if vCode &lt;&gt; null and
		   voyage.vesselName &lt;&gt; null then
			if _protocol.camGroup.useCallSign then
				msg := self.makeTDT20Segment(_protocol, _camVoyage.getVoyageVoyageCode(), '1', null, carrierCode, '172', '20', null, null, callSign, '103', null, voyage.vesselName.trimRight.toUpper);
			else
				msg := self.makeTDT20Segment(_protocol, _camVoyage.getVoyageVoyageCode(), '1', null, carrierCode, '172', '20', null, null, lloydsNumber, '146', null, voyage.vesselName.trimRight.toUpper);
			endif;
		else
			msg := self.makeTDT20Segment(_protocol, _camVoyage.getVoyageVoyageCode(), '1', null, carrierCode, '172', '20', null, null, null, '146', null, null);
		endif;
	else
		//no voyage TDT+20++1+++++:146::'
		msg := self.makeTDT20Segment(_protocol, null, '1', null, null, null, null, null, null, null, '146', null, null);	
	endif;

	return msg;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_protocol" type="CM_CamProtocol"/>
        <Parameter name="_camVoyage" type="CM_CamVoyage"/>
        <Parameter name="_activity" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="makeMessages" id="cbae339d-f15c-47a3-85e6-3527cb40491d">
        <source>makeMessages(_trackedItem: CM_TrackedItem; _transaction: CM_TITransaction; _camProtocol: CM_CamProtocol; _camMessage: CM_CamMessage input; _xlVoyageId: String; _terminal: CM_Terminal; _secondTrx: CM_TITransaction);
/*****************************************************
Date			Name		TFS#		Description
08 April 2019	jlgns1					Initial creation
8/04/2019 		JLGNS1	ChangeRequest 	39725: JMT - CODECO 00B
21/05/2019      cnwma1	Bug 44797: SNO - Testing reference 7813
04 Oct 2019		jlgdi1	46578 			Added CODECO_CANCEL in LOC segment creation,
										Create new entry 'FTX+AAI' if the activity is 'Cancellation'
13/02/2020		jlgka1	48550			Move "FTX+AAI" after the "FTX+DAR"		
21/06/2022		jlizm1	TFS 53754		LNX Different local and server time zones causing incorrect edi outputs								
****************************************************/
constants
	Reason_Max_Length : Integer = 512;
	
vars
	fCode 			: String; 
	code 			: String; 
	imExStatus 		: String; 
	contentsStatus 	: String;
	ti 				: CM_TrackedItem;
	isoCode 		: String;
	fIsoCode 		: String;
	commodity 		: String;
	trans 			: CM_TITransaction;
	startLooking 	: Boolean;
	includeVGM 		: Boolean;
	delRelease 		: String;
begin
	ti := _transaction.myTrackedItem;
	
	if _camProtocol.useVGM and 
	   _camProtocol.getIncludeExtraVGM and
	   ti &lt;&gt; null and 
	   ti.isWeightCertified and 
	   not ti.isEmpty then		
		includeVGM := true;
	endif;
	contentsStatus := self.contentsStatusToString(_transaction.contentsStatus, _camMessage.activity, _transaction.type);

	if contentsStatus = "5" then
		// set up the potential group of GID, TMP, SGP and DGS records.
		if ti.CM_Container.getTemperature &lt;&gt; NULL_TEMPERATURE or 
		   ti.allTIHazards.isNotEmpty or 
		   ti.commodity &lt;&gt; null then	
			// Goods Item Details
			
			// ECN/MOT requirement - FTX+AAA+++&lt;goods description&gt;
			commodity := ti.getCommodityDesc;
			if _transaction.isKindOf(CM_Unpack) or 
			   _transaction.isKindOf(CM_UnpackComplete) then
				commodity := _transaction.commodity;
				foreach trans in ti.allTransactions do
					if trans = _transaction then
						startLooking := true;
					endif;
					if trans.isKindOf(CM_Edit) and
					   startLooking then
						commodity := self.checkEditTransactionForUnpack(trans, CM_TrackedItem::commodity.name);
						break;
					endif;
				endforeach;
			endif;
			self.makeFTXSegment(_camProtocol, _camMessage.group3, "AAA", null, null, commodity); 
			
			// ECN/MOT requirement PIA+5+&lt;goods description&gt;:ZZZ
			// TMP Segment
			self.makeTMPSegment(_camProtocol, _camMessage.group3, 2, ti.getTemperature, "CEL");				
			// ie Dangerous Goods
			if not _camProtocol.dgsDetailsInGroup14  then							//JIRA-20814
				self.makeMessageHazardsData (ti, _camProtocol, _camMessage.group3);	
			endif;																	//JIRA-20814
		endif;
	endif;
	// EQD segment
	imExStatus := self.imExStatusToString(ti); 
	if  ti.isKindOf(CM_Container) then
		isoCode := ti.CM_Container.isoType;
		fIsoCode := self.getXlatedForeignCode(_camProtocol.operatorXlationCode, isoCode, XLATION_TYPE_ISOTYPE_BYOP, _terminal);
	endif;
	self.makeEQDSegment(_camProtocol, _camMessage.group5, "CN", ti.id.trimRight, fIsoCode, '102', '5', null, imExStatus, contentsStatus);    //23/08/2017 cnwma1 TFS #5834
	_camMessage.eqdCount := _camMessage.eqdCount + 1;

	// RFF+BN
	self.makeMessageRFF_BN(_camProtocol, _camMessage.group5, _camMessage.activity, ti, _transaction);
	// RFF+RE
	if contentsStatus = "5" and
	   ti.deliveryRelease = null then
		startLooking := false;
		delRelease := ti.deliveryRelease;
		if _transaction.isKindOf(CM_Unpack) or 
		   _transaction.isKindOf(CM_UnpackComplete) then
			foreach trans in ti.allTransactions do
				if trans = _transaction then
					startLooking := true;
				endif;
				if trans.isKindOf(CM_Edit) and
				   startLooking then
					delRelease := self.checkEditTransactionForUnpack(trans, CM_TrackedItem::deliveryRelease.name);
					break;
				endif;
			endforeach;
		endif;
		if delRelease &lt;&gt; null then
			self.makeRFFSegment(_camProtocol, _camMessage.group5, "RE", delRelease);
		endif;
	else
		self.makeMessageRFF_RE(_camProtocol, _camMessage.group5, _camMessage.activity, ti, _transaction);
	endif;
	// RFF+CN - special18 field
	self.makeMessageRFF_CN(_camProtocol, _camMessage.group5, ti);

	// if creating extra messages for pack/unpack add 1 minute to the second message
	self.makeDTMSegment(_camProtocol, _camMessage.group5, '7', self.transDateTime(_transaction, _camMessage.activity, _camProtocol), '203');	// TFS 53754

	if includeVGM then
		self.makeMessageDTM_VGM(_camProtocol, _camMessage.group5, ti);					// TFS 4492
	endif;

	if (_camMessage.activity = CODECO_GATEIN) or (_camMessage.activity = CODECO_CANCEL) then
		// LOC segments
		self.makeMessageLOC_GATEIN(_camProtocol, _camMessage.group5, _camMessage.activity, ti, contentsStatus);

	elseif _camMessage.activity = CODECO_GATEOUT then
		// LOC segments
		self.makeMessageLOC_GATEOUT(_camProtocol, _camMessage.group5, _camMessage.activity, ti, contentsStatus);		
	endif;
	
	// LOC+165 segment 
	code := _terminal.getConfig(PortDestCode).String;
	fCode := self.getXlatedForeignCode(_camProtocol.operatorXlationCode, code, XLATION_TYPE_PORT_BYOP, _terminal);
	
	self.makeLOCSegment(_camProtocol, _camMessage.group5, '165', fCode, '139', '6', _camProtocol.camGroup.facilityCode, "72", "ZZZ"); 
	
	// MEA+ segment
	if _secondTrx &lt;&gt; null then	
		self.makeMEASegment(_camProtocol, _camMessage.group5, self.getMeasurementQualifier() , "G", "KGM", _secondTrx.totalWeight);
	else
		self.makeMEASegmentForTotalWeight(_camProtocol, _camMessage.group5,ti,null);
	endif;
	if ti.weightTare &lt;&gt; 0 then
		self.makeMEASegment(_camProtocol, _camMessage.group5, 'AAE', 'T', 'KGM', ti.weightTare);	
	endif;	
	// DIM+ segment
	self.makeMessageDimensionsData(_camProtocol, _camMessage.group5, ti);
	
	//the SEL for the seal number
	if  _secondTrx &lt;&gt; null and _secondTrx.isKindOf( CM_Receive ) and _camMessage.activity = CODECO_GATEOUT then	
		self.makeMessageSealsFromPrevVal( ti, _camMessage, _camMessage.group5, _camProtocol, contentsStatus);
	else
		if _transaction.isA(CM_ReceiveRoad) then
			makeMessageSealsReceivedData(_transaction.CM_Receive, _camProtocol, _camMessage.group5);
		else 
			self.makeMessageSealsData(ti, _camMessage, _camMessage.group5, _camProtocol, contentsStatus);
		endif; 
	endif;

	// FTX+AAI
	self.makeMessageFTX_DeliveryReason(_camProtocol, _camMessage.group5, ti);	
	// FTX+DAR
	self.makeMessageFTX_Damage(_camProtocol, _camMessage.group5, ti);	
	
	//jlgka1 TFS 48550 --&gt;
	//Move from bottom to here
	// FTX+AAI for Cancellation
	if _camMessage.activity = CODECO_CANCEL then	
		self.makeMessageFTX_CancelReason(_camProtocol, 
										 _camMessage.group5, 
										 _transaction, 
										 Reason_Max_Length);
	endif;
	//jlgka1 TFS 48550 &lt;--
	// FTX+ABS
	if includeVGM then
		self.makeMessageFTX_VGM(_camProtocol, _camMessage.group5, ti);				
	endif;
	
	//DAM
	self.makeMessageDAM(_camProtocol,_camMessage.group5,ti);
	
	// EQA+ segment - the only attached equipment is a reefer generator
	self.makeEQASegment(_camProtocol, _camMessage.group5, 'RG', ti);
	
	// TDT+1
	self.makeMessageTDT1Segment(_camProtocol, _camMessage.group5, _camMessage.activity, _transaction, ti);	
		
	// NAD+CF
	fCode := _camProtocol.getContainerCarrier_NAD_CF (ti.CM_Container);
	
	if fCode &lt;&gt; null then
		self.makeNADSegment(_camProtocol, _camMessage.group5, 'CF', fCode, '172', '20'); 
	endif;
	
	if includeVGM then
		self.makeMessageNAD_VGM(_camProtocol, _camMessage.group5, ti);
	endif;
	
	// ie Dangerous Goods													//JIRA-20814
	if _camProtocol.dgsDetailsInGroup14  then								//JIRA-20814
		self.makeMessageHazardsData (ti, _camProtocol, _camMessage.group5);	//JIRA-20814
	endif;																	//JIRA-20814
end;</source>
        <Parameter name="_trackedItem" type="CM_TrackedItem"/>
        <Parameter name="_transaction" type="CM_TITransaction"/>
        <Parameter name="_camProtocol" type="CM_CamProtocol"/>
        <Parameter name="_camMessage" type="CM_CamMessage" usage="input"/>
        <Parameter name="_xlVoyageId" type="String"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_secondTrx" type="CM_TITransaction"/>
    </JadeMethod>
    <JadeMethod name="outputFile" id="1616d7ee-5abc-4dc5-8c39-8b863036f7c6">
        <updating/>
        <source>outputFile(_protocol : CM_CamProtocol input; _camAgent : CM_CamControllerAgent; _camFile : CM_CamFile input; _runDateTime : TimeStamp; _camTaskHistory : CM_CamTaskHistory input;
		   _unhSeqNumber : Integer io; _seqNumber : Integer; _terminal : CM_Terminal; _contextObj : CM_Object; _transactions : CM_TITransactionSet) updating;
/*****************************************************
Date			Name		TFS#		Description
08 April 2019	jlgns1					Initial creation
8/04/2019 		JLGNS1	ChangeRequest 	39725: JMT - CODECO 00B
04 Nov 2019		jlgdi1		46578		Create new entry 'RFF+ACW' segment if the activity is 'Cancellation'
09 Jan 2020		jlgdap1		TFS 48016 	SNO Deletion CODECO - new _transactions parameter
15 May 2020		jlgdap1		TFS 49371 	SNO BGM sequence handling corrected
****************************************************/
vars
	camVoyage 				: CM_CamVoyage;
	camMessage 				: CM_CamMessage;
	una, unb				: String;
	headerColl, trailerColl	: HugeStringArray;	
	strLine 				: String;
begin // UN
/*============================================================
  EDIFACT Values for element 1001

  Gate In   BGM+34
  Gate Out  BGM+36
--------------------------------------------------------------*/
	
	app.writeLog("===================================", LogWARN);
	
	// UNA Segment
	una := self.outputHeader_UNA (_protocol, _camTaskHistory);
	strLine := strLine &amp; una;
	//UNB header	
	unb := self.outputHeader_UNB (_protocol, _camTaskHistory, _seqNumber, null, _contextObj);
	strLine := strLine &amp; unb;

	
	if _camFile.camVoyages.size &gt; 0 then
		foreach camVoyage in _camFile.camVoyages do
			foreach camMessage in camVoyage.camMessages do
				if camMessage.group3.size = 0 and camMessage.group5.size = 0 then
					continue;
				endif;
				
				headerColl 	:= camMessage.header;
				trailerColl	:= camMessage.trailer;
				
				if una &lt;&gt; null then
					headerColl.add (una);
				endif;
				
				if unb &lt;&gt; null then
					headerColl.add (unb);
				endif;
				
				// UNH/BGM header
				strLine := strLine &amp; self.outputHeader_UNH_BGM (camMessage, _camTaskHistory, _camFile, _unhSeqNumber, headerColl);
				camMessage.segmentCount := camMessage.segmentCount + 1;	//to represent the 'BGM' - 23 Dec 2020	NDL	TFS 50556
				
				if not camVoyage.voyageOid.isNullVoyage then
					if camMessage.activity = CODECO_CANCEL then
						//strLine := strLine &amp; self.outputHeader_RFF_ACW(_protocol, _camTaskHistory, camMessage, headerColl);					// TFS 48016
						strLine := strLine &amp; self.outputHeader_RFF_ACW(_protocol, _camTaskHistory, camMessage, headerColl, _transactions);		// TFS 48016
					endif;
					//TDT header
					strLine := strLine &amp; self.outputFileMessage(_camTaskHistory, self.makeMessageTDT20Segment(_protocol, camVoyage, camMessage.activity), headerColl);
					camMessage.segmentCount := camMessage.segmentCount + 1;
					//RFF header
					strLine := strLine &amp; self.outputHeader_RFF(_protocol, _camTaskHistory, camMessage, headerColl);
					//LOC1 header
					strLine := strLine &amp; self.outputHeader_LOC(_protocol, camMessage, _camTaskHistory, _terminal, headerColl);
					//or here
				endif;
				//NAD header
				strLine := strLine &amp; self.outputHeader_NAD(_protocol, camMessage, _camTaskHistory, headerColl);
				
				//now give them all of the messages
				strLine := strLine &amp; self.outputFileGroup (_camTaskHistory, camMessage.group3, camMessage.segmentCount);
				strLine := strLine &amp; self.outputFileGroup (_camTaskHistory, camMessage.group5, camMessage.segmentCount);
				
				//CNT segment for message
				strLine := strLine &amp; self.outputFileMessage(_camTaskHistory, self.makeCNTSegment (_protocol, 16, camMessage.eqdCount), trailerColl);
				camMessage.segmentCount := camMessage.segmentCount + 1;	//to represent the 'CNT' - 23 Dec 2020	NDL	TFS 50556
				
			//	camMessage.segmentCount := camMessage.segmentCount + 2;
				
				// UNT segment
				camMessage.segmentCount := camMessage.segmentCount + 1;	//to represent the 'UNT' - 23 Dec 2020	NDL	TFS 50556
				strLine := strLine &amp; self.outputTrailer_UNT (_protocol, _camTaskHistory, camMessage.segmentCount, _unhSeqNumber, trailerColl);
				
				camMessage.segmentCount := 0;
				
				if camMessage.activity = CODECO_GATEIN then										// TFS 49371
					self.retainBGMSequenceOnTransaction(_protocol, strLine, _transactions);		// TFS 49371
				endif;																			// TFS 49371
				
			endforeach;
		endforeach;
		//set unhSeq here
		_protocol.setUNHSeqNum(_unhSeqNumber);
	endif;
	
	//UNZ segement for file
	strLine := strLine &amp; self.outputTrailer_UNZ (_protocol, _camTaskHistory, _camFile.messageCount, _seqNumber, null);

	app.writeLog(_protocol.code &amp; " File contains " &amp; _camFile.messageCount.String &amp; " messages.", LogWARN);
	app.writeLog("===================================", LogWARN);
	_camTaskHistory.setRawDataString(strLine.toUpper());
end;</source>
        <Parameter name="_protocol" type="CM_CamProtocol" usage="input"/>
        <Parameter name="_camAgent" type="CM_CamControllerAgent"/>
        <Parameter name="_camFile" type="CM_CamFile" usage="input"/>
        <Parameter name="_runDateTime" type="TimeStamp"/>
        <Parameter name="_camTaskHistory" type="CM_CamTaskHistory" usage="input"/>
        <Parameter name="_unhSeqNumber" type="Integer" usage="io"/>
        <Parameter name="_seqNumber" type="Integer"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_contextObj" type="CM_Object"/>
        <Parameter name="_transactions" type="CM_TITransactionSet"/>
    </JadeMethod>
    <JadeMethod name="outputHeader_LOC" id="b601ad45-f47d-400a-a3a9-666bf5e178d6">
        <updating/>
        <source>outputHeader_LOC(_protocol :CM_CamProtocol; _camMessage :CM_CamMessage input; _camTaskHistory :CM_CamTaskHistory input; _terminal :CM_Terminal; _coll :HugeStringArray input) : String updating, protected;
/*****************************************************
Date			Name		TFS#		Description
08 April 2019	jlgns1					Initial creation
8/04/2019 		JLGNS1	ChangeRequest 	39725: JMT - CODECO 00B
04/07/2022		jlizm1	TFS 53754 LNX Different local and server time zones causing incorrect edi outputs

****************************************************/

vars
	ourCode : String;
	fCode	: String;
	strLine : String;
begin
	ourCode := _terminal.getConfig(PortDestCode).String;
	fCode := self.getXlatedForeignCode(_protocol.operatorXlationCode.trimBlanks, ourCode, XLATION_TYPE_PORT_BYOP, _terminal);
	
	if _camMessage.activity = CODECO_GATEOUT then
		strLine := strLine &amp; self.outputFileMessage(_camTaskHistory, self.makeLOCSegment(_protocol, null, '11', fCode.trimRight, '139', '6', _protocol.camGroup.facilityCode, "72", "ZZZ"), _coll);
		
		strLine := strLine &amp; self.outputFileMessage(_camTaskHistory, self.makeDTMSegment(_protocol,_coll,"186",_camTaskHistory.runDateTime,"203"), _coll);
	else
		strLine := strLine &amp; self.outputFileMessage(_camTaskHistory, self.makeLOCSegment(_protocol, null, '9', fCode.trimRight, '139', '6', _protocol.camGroup.facilityCode, "72", "ZZZ"), _coll);
	
		strLine := strLine &amp; self.outputFileMessage(_camTaskHistory, self.makeDTMSegment(_protocol,_coll,"132",_camTaskHistory.runDateTime,"203"), _coll);
	endif;

	//_camMessage.segmentCount := _camMessage.segmentCount + 1;
	_camMessage.segmentCount := _camMessage.segmentCount + 2;	//23 Dec 2020	NDL	TFS 50556
	return strLine;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_protocol" type="CM_CamProtocol"/>
        <Parameter name="_camMessage" type="CM_CamMessage" usage="input"/>
        <Parameter name="_camTaskHistory" type="CM_CamTaskHistory" usage="input"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_coll" type="HugeStringArray" usage="input"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="outputHeader_NAD" id="e85c8518-384c-4ece-b498-030389ce0482">
        <updating/>
        <source>outputHeader_NAD (_protocol :CM_CamProtocol; _camMessage :CM_CamMessage input; _camTaskHistory :CM_CamTaskHistory input; _coll :HugeStringArray input) : String updating, protected;
/*****************************************************
Date			Name		TFS#		Description
08 April 2019	jlgns1					Initial creation
8/04/2019 		JLGNS1	ChangeRequest 	39725: JMT - CODECO 00B

****************************************************/
vars
	operatorOid 	: CM_Operator;
	xlationOperator : CM_Operator;
	nullOperator 	: Boolean;
	foundMatch 		: Boolean;
	code 			: String;
	fCode 			: String;
	strLine 		: String;
begin
	code := _camMessage.camVoyage.getVoyageOperatorCode;
	operatorOid := app.myRoot.allOperators[code];
	if operatorOid &lt;&gt; null and
	   CM_NullOperator.hasInstance(operatorOid) then
	   nullOperator := true;
	endif;
	xlationOperator := app.myRoot.allOperators[_protocol.operatorXlationCode.trimBlanks];
	fCode := app.myRoot.getXlationForeignOperatorCode(xlationOperator, code, foundMatch).trimRight;
	
	if fCode = null then
		fCode := code;
	endif;
	if fCode &lt;&gt; null then
		if not nullOperator then
			strLine := strLine &amp; self.outputFileMessage(_camTaskHistory, self.makeNADSegment(_protocol, null, "CA", fCode, '160', '20'), _coll);
			_camMessage.segmentCount := _camMessage.segmentCount + 1;
		endif;
		if _protocol.getSenderCode_NAD_MS &lt;&gt; null then
			strLine := strLine &amp; self.outputFileMessage(_camTaskHistory, self.makeNADSegment(_protocol, null, "MS", _protocol.getSenderCode_NAD_MS, '160', '87'), _coll);
			_camMessage.segmentCount := _camMessage.segmentCount + 1;
		endif;
	endif;
	return strLine;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_protocol" type="CM_CamProtocol"/>
        <Parameter name="_camMessage" type="CM_CamMessage" usage="input"/>
        <Parameter name="_camTaskHistory" type="CM_CamTaskHistory" usage="input"/>
        <Parameter name="_coll" type="HugeStringArray" usage="input"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="outputHeader_RFF" id="6b6ada2b-813f-4bdb-ab6b-953cf48d7baf">
        <updating/>
        <source>outputHeader_RFF(_protocol :CM_CamProtocol; _camTaskHistory :CM_CamTaskHistory input; _camMessage :CM_CamMessage input; _coll :HugeStringArray input) : String updating, protected;
/*****************************************************
Date			Name		TFS#		Description
08 April 2019	jlgns1					Initial creation
8/04/2019 		JLGNS1	ChangeRequest 	39725: JMT - CODECO 00B

****************************************************/
vars
	strLine 	: String;
	voyageCode 	: String;
begin
	voyageCode := _camMessage.camVoyage.getSanitisedVoyageCode();
	if voyageCode &lt;&gt; null then
		strLine := strLine &amp; self.outputFileMessage(_camTaskHistory, self.makeRFFSegment(_protocol, null, "VON",  voyageCode), _coll);
		_camMessage.segmentCount := _camMessage.segmentCount + 1;
	endif;
	return strLine;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_protocol" type="CM_CamProtocol"/>
        <Parameter name="_camTaskHistory" type="CM_CamTaskHistory" usage="input"/>
        <Parameter name="_camMessage" type="CM_CamMessage" usage="input"/>
        <Parameter name="_coll" type="HugeStringArray" usage="input"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="outputHeader_UNA" id="6eeebd53-4c41-4e6c-a38c-68858ed5746f">
        <updating/>
        <source>outputHeader_UNA(_protocol: CM_CamProtocol; _camTaskHistory: CM_CamTaskHistory input) : String updating, protected;
/*****************************************************
Date			Name		TFS#		Description
08 April 2019	jlgns1					Initial creation
8/04/2019 		JLGNS1	ChangeRequest 	39725: JMT - CODECO 00B

****************************************************/
vars
	
begin
	// UNA Segment unconditional
	return self.outputFileMessage(_camTaskHistory, self.makeUNASegment(_protocol), null);
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_protocol" type="CM_CamProtocol"/>
        <Parameter name="_camTaskHistory" type="CM_CamTaskHistory" usage="input"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="outputHeader_UNB" id="fec46edf-f7cd-4d5c-aa7f-765f9ce5fbeb">
        <updating/>
        <source>outputHeader_UNB(_protocol :CM_CamProtocol; _camTaskHistory: CM_CamTaskHistory input; _seqNumber : Integer; _coll :HugeStringArray input; _contextObj : CM_Object) : String updating, protected;
/*****************************************************
Date			Name		TFS#		Description
08 April 2019	jlgns1					Initial creation
8/04/2019 		JLGNS1	ChangeRequest 	39725: JMT - CODECO 00B

****************************************************/
vars
	code 	: String;
	result 	: String;
	strLine : String;
	ts 		: TimeStamp;	
begin
	ts := _camTaskHistory.runDateTime;
	if _protocol.singleContainerPerUNB and _contextObj &lt;&gt; null then
		_protocol.incrementTSForContext( _contextObj, ts );
	endif;
	
	code := self.getSenderCode_UNB(_protocol);
	
	result := self.makeUNBSegment(_protocol, "UNOA", 2, code, "ZZZ", _protocol.camGroup.recipient.trimBlanks, null, _seqNumber, null, false, ts);
		
	strLine := strLine &amp; self.outputFileMessage(_camTaskHistory, result, _coll);
	
	return strLine;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_protocol" type="CM_CamProtocol"/>
        <Parameter name="_camTaskHistory" type="CM_CamTaskHistory" usage="input"/>
        <Parameter name="_seqNumber" type="Integer"/>
        <Parameter name="_coll" type="HugeStringArray" usage="input"/>
        <Parameter name="_contextObj" type="CM_Object"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="outputHeader_UNH_BGM" id="e11d5489-abb8-4770-8506-ed3763a985fe">
        <updating/>
        <source>outputHeader_UNH_BGM(_camMessage :CM_CamMessage input; _camTaskHistory :CM_CamTaskHistory input; _camFile :CM_CamFile input; 
						_unhSeqNumber :Integer io; _coll :HugeStringArray input) : String updating, protected;
/*****************************************************
Date		Name		TFS#		Description
08 Apr 2019	jlgns1					Initial creation
8/04/2019 	JLGNS1	ChangeRequest 	39725: JMT - CODECO 00B
26 Jun 2019	jlgka1	TFS 44737 		PNL Hapag CODECO on Weighing.
04 Nov 2019	jlgdi1		46578		Added CODECO_CANCEL
****************************************************/
constants
	Doc_Type_GateIn : String = "109";
	Msg_Func_Cancellation : Integer = 1;
	File_Type_CODECO : String = "CODECO";
	Two_Segments : Integer = 2;
	
vars
	camProtocol 		: CM_CamProtocol;
	strLine 			: String;
	lBGMDamCode 		: String;
	lBGMRepCode 		: String;
	codecoVGMBGMMsgCode : String;
	
begin
	camProtocol := _camTaskHistory.camProtocol;
	if camProtocol &lt;&gt; null then
		lBGMDamCode := camProtocol.getDamageCodecoCode;
		lBGMRepCode := camProtocol.getRepairCodecoCode;
	endif;
	if lBGMRepCode = null then
		lBGMRepCode := "266";
	endif;
	if lBGMDamCode = null then
		lBGMDamCode := "266";
	endif;
	if _camMessage.activity = CODECO_GATEIN then
		strLine := strLine &amp; self.makeMessageHeader(_camFile, _camTaskHistory, _unhSeqNumber, Doc_Type_GateIn, File_Type_CODECO, _coll);
		_camMessage.segmentCount := _camMessage.segmentCount + Two_Segments;
	elseif _camMessage.activity = CODECO_GATEOUT then
		strLine := strLine &amp; self.makeMessageHeader(_camFile, _camTaskHistory, _unhSeqNumber, "111", File_Type_CODECO, _coll);
		_camMessage.segmentCount := _camMessage.segmentCount + Two_Segments;
	elseif _camMessage.activity = CODECO_DAMAGED then
		strLine := strLine &amp; self.makeMessageHeader(_camFile, _camTaskHistory, _unhSeqNumber, lBGMDamCode, File_Type_CODECO, _coll);
		_camMessage.segmentCount := _camMessage.segmentCount + Two_Segments;
	elseif _camMessage.activity = CODECO_REPAIRED then
		strLine := strLine &amp; self.makeMessageHeader(_camFile, _camTaskHistory, _unhSeqNumber, lBGMRepCode, File_Type_CODECO, _coll);
		_camMessage.segmentCount := _camMessage.segmentCount + Two_Segments;
	elseif _camMessage.activity = CODECO_PACK then
		strLine := strLine &amp; self.makeMessageHeader(_camFile, _camTaskHistory, _unhSeqNumber, "266", File_Type_CODECO, _coll);
		_camMessage.segmentCount := _camMessage.segmentCount + Two_Segments;
	elseif _camMessage.activity = CODECO_UNPACK then
		strLine := strLine &amp; self.makeMessageHeader(_camFile, _camTaskHistory, _unhSeqNumber, "266", File_Type_CODECO, _coll);
		_camMessage.segmentCount := _camMessage.segmentCount + Two_Segments;
	elseif _camMessage.activity = CODECO_VGM then 
		//jlgka1 TFS 44737 --&gt;
		if _camTaskHistory.camProtocol &lt;&gt; null then
			codecoVGMBGMMsgCode := _camTaskHistory.camProtocol.getCodecoVGMBGMMessageCode();
		endif;
		if codecoVGMBGMMsgCode &lt;&gt; null then
			strLine := strLine &amp; self.makeMessageHeader(_camFile, _camTaskHistory, _unhSeqNumber, codecoVGMBGMMsgCode, File_Type_CODECO, _coll);	
			_camMessage.segmentCount := _camMessage.segmentCount + Two_Segments;	
		else //jlgka1 TFS 44737 &lt;--
			strLine := strLine &amp; self.makeMessageHeader(_camFile, _camTaskHistory, _unhSeqNumber, "VGM", File_Type_CODECO, _coll);	
			_camMessage.segmentCount := _camMessage.segmentCount + Two_Segments;	
		endif;	
	elseif _camMessage.activity = CODECO_CANCEL then
		strLine := strLine &amp; self.makeMessageHeaderMsgFunc(_camFile, 
														   _camTaskHistory, 
														   _unhSeqNumber, 
														   Doc_Type_GateIn, 
														   Msg_Func_Cancellation,
														   File_Type_CODECO, 
														   _coll);
		_camMessage.segmentCount := _camMessage.segmentCount + Two_Segments;
	endif;
	
	return strLine;
end;</source>
        <access>protected</access>
        <Parameter name="_camMessage" type="CM_CamMessage" usage="input"/>
        <Parameter name="_camTaskHistory" type="CM_CamTaskHistory" usage="input"/>
        <Parameter name="_camFile" type="CM_CamFile" usage="input"/>
        <Parameter name="_unhSeqNumber" type="Integer" usage="io"/>
        <Parameter name="_coll" type="HugeStringArray" usage="input"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="processTransaction" id="ed3ca57d-e0a5-4f8c-81d6-b8b9ff21dfbc">
        <updating/>
        <source>processTransaction(_transaction: CM_TITransaction; _camProtocol: CM_CamProtocol; _camAgent: CM_CamControllerAgent input; _camFile: CM_CamFile input) updating;
/*****************************************************
Date			Name		TFS#		Description
08 April 2019	jlgns1					Initial creation
8/04/2019 		JLGNS1	ChangeRequest 	39725: JMT - CODECO 00B
08 Apr 2022		jlika1	TFS 53181		GPHA - Voyage Code Translation for Multiple Terminals and Co-Loaders
26 May 2022		navdap1	TFS 53693		GPHA Customs Manifest Code is not applied to TDT segment
****************************************************/
vars
	camMessage 				 : CM_CamMessage;
	messageTypeArray 		 : IntegerArray;
	messageType 			 : Integer;
	xlVoyageId 				 : String;
	outOpVoyageCode 		 : String;
	outVoyVoyageCode 		 : String;
	contentsStatus 			 : String;
	arrayPos3 				 : Integer;
	arrayPos4 				 : Integer; 
	arrayPos5 				 : Integer;
	theTI	 				 : CM_TrackedItem;
	vesselName 				 : String;
	xlVoyageIdSaved 		 : String;
	vesselNameSaved 		 : String;
	voyage 					 : CM_Voyage;
	receiveShip 			 : CM_ReceiveShip;
	receiveVoyage 			 : CM_Voyage;
	useReceiveShipVoyage 	 : Boolean;
	useDeliveryReleaseVoyage : Boolean;
	bulkRelease 			 : CM_BulkRelease;
	custVoyage				 : CM_Voyage;				// TFS 53693
begin
	_camAgent.writeDebugLog(class.name &amp; '::' &amp; method.name &amp; " process " &amp; _transaction.getCamsDisplayDetails);

	theTI 	:= _transaction.myTrackedItem;
	voyage 	:= _transaction.getVoyage();
	
	if (_transaction.type = TRANS_TYPE_UnpackComplete) and ( voyage = null or voyage.isNullVoyage ) then
		receiveShip := theTI.getLastTransOfTypeClass( CM_ReceiveShip ).CM_ReceiveShip;
		if receiveShip &lt;&gt; null then
			voyage := receiveShip.getVoyage();
			receiveVoyage := voyage;
		endif;
	endif;
	
	if (_transaction.isCamsShipReleaseType()) then
		receiveShip := theTI.getLastTransOfTypeClass( CM_ReceiveShip ).CM_ReceiveShip;
		if receiveShip &lt;&gt; null then
			voyage := receiveShip.getVoyage();
			receiveVoyage := voyage;
		endif;
	endif;
	custVoyage := voyage;								// TFS 53693
	
	create messageTypeArray transient;

	//get the translated voyage Code
	if receiveVoyage &lt;&gt; null and ( theTI.myVoyage = null or theTI.myVoyage.isNullVoyage ) then
		xlVoyageId := receiveVoyage.code;
	else
		xlVoyageId := self.getCodeForVoyage(theTI, voyage, _camProtocol);	
	endif;
	vesselName := voyage.vesselName; 									
	
	self.getXlatedVoyageCodes(_camProtocol.operatorXlationCode.trimBlanks, xlVoyageId, outOpVoyageCode, outVoyVoyageCode, _camProtocol.terminal);
	
	if receiveShip &lt;&gt; null then	
		xlVoyageId := self.getVoyageCode(receiveShip, _camProtocol, vesselName);
	else
		xlVoyageId := self.getVoyageCode(_transaction, _camProtocol, vesselName);
	endif;
	xlVoyageIdSaved := xlVoyageId;
	vesselNameSaved := vesselName;
	
	self.getMessageType(_transaction, messageTypeArray, _camProtocol,_camAgent);
	
	if messageTypeArray.size &gt; 0 then
		foreach messageType in messageTypeArray do
			useReceiveShipVoyage := false;
			useDeliveryReleaseVoyage := false;
			bulkRelease := theTI.allBulkReleasesReleased.first;
			if messageType = CODECO_GATEOUT and ( _transaction.type = TRANS_TYPE_UnpackComplete or 
												  _transaction.type = TRANS_TYPE_UNPACK or 
												  _transaction.isCamsShipReleaseType()) then 
				if  _transaction.type = TRANS_TYPE_UnpackComplete or _transaction.isCamsShipReleaseType() then
					if receiveShip &lt;&gt; null then
						useReceiveShipVoyage := true;
						xlVoyageId := self.getTransactionVoyageCode(receiveShip, _camProtocol, vesselName);
					else
						xlVoyageId := self.getTransactionVoyageCode(_transaction, _camProtocol, vesselName);
					endif;
				elseif _transaction.type = TRANS_TYPE_UNPACK then
					xlVoyageId := self.getTransactionVoyageCode(_transaction, _camProtocol, vesselName);
				endif;
			elseif messageType = CODECO_GATEOUT and
			   theTI.isEmpty and
			   bulkRelease &lt;&gt; null then
				useDeliveryReleaseVoyage := true;
				if bulkRelease.myVoyage &lt;&gt; null then
					voyage := bulkRelease.myVoyage;
					vesselName := voyage.vesselName;
					xlVoyageId := voyage.code;
					if xlVoyageId = NULL_VOYAGE_CODE then
						xlVoyageId := null;
					endif;
					if _camProtocol.getIsCustomsProtocol() and voyage.customsManifest &lt;&gt; null then
						outOpVoyageCode := voyage.customsManifest;
						outVoyVoyageCode := voyage.customsManifest;
					else
						self.getXlatedVoyageCodes(_camProtocol.operatorXlationCode.trimBlanks, xlVoyageId, outOpVoyageCode, outVoyVoyageCode, _camProtocol.terminal);
					endif;
				endif;
			elseif messageType = CODECO_GATEIN and 
			   (_transaction.type = TRANS_TYPE_UnpackComplete or
			    _transaction.type = TRANS_TYPE_UNPACK) then
				xlVoyageId := null;
				vesselName := null;
			else 
				xlVoyageId := xlVoyageIdSaved;
				vesselName := vesselNameSaved;
			endif;
			if _camProtocol.getIsCustomsProtocol() and custVoyage.customsManifest &lt;&gt; null then	// TFS 53693
				outVoyVoyageCode := custVoyage.customsManifest;									// TFS 53693
			endif;																				// TFS 53693
			camMessage := self.getCamMessageVoyage(_camFile, outOpVoyageCode, outVoyVoyageCode, vesselName, messageType, _camProtocol.singleContainerPerBGM);
			
			if camMessage &lt;&gt; null then
				contentsStatus := self.contentsStatusToString(_transaction.contentsStatus, camMessage.activity, _transaction.type);
				
				arrayPos3 := camMessage.group3.size;
				arrayPos4 := camMessage.group4.size;
				arrayPos5 := camMessage.group5.size;
				
				if useReceiveShipVoyage then	
					camMessage.camVoyage.voyageOid := receiveVoyage;
				elseif useDeliveryReleaseVoyage then
					camMessage.camVoyage.voyageOid := voyage;
				else
					camMessage.camVoyage.voyageOid := _transaction.myTrackedItem.myVoyage;
				endif;
				camMessage.dateTime := self.transDateTime(_transaction, camMessage.activity, _camProtocol);
				
				if useReceiveShipVoyage then
					self.makeMessages(null, _transaction, _camProtocol, camMessage, xlVoyageId, _camProtocol.terminal, receiveShip);
				else
					self.makeMessages(null, _transaction, _camProtocol, camMessage, xlVoyageId, _camProtocol.terminal, null);
				endif;
				
				camMessage.setupCAMSInfoDetails(_camProtocol, arrayPos3, arrayPos4, arrayPos5, _transaction);	
			else
				if _camAgent.logExcludedTransactions then
					_camAgent.logReasonForExclusion(_transaction, "CAM Message is null " &amp; _transaction.String &amp; ".");
				endif;
			endif;
		endforeach;
	endif;
epilog
	if messageTypeArray &lt;&gt; null then
		delete messageTypeArray;
	endif;
end;
</source>
        <Parameter name="_transaction" type="CM_TITransaction"/>
        <Parameter name="_camProtocol" type="CM_CamProtocol"/>
        <Parameter name="_camAgent" type="CM_CamControllerAgent" usage="input"/>
        <Parameter name="_camFile" type="CM_CamFile" usage="input"/>
    </JadeMethod>
    <JadeMethod name="retainBGMSequenceOnTransaction" id="55b6dfaf-105e-43f9-a313-b873f1cd40a5">
        <source>retainBGMSequenceOnTransaction(_protocol : CM_CamProtocol; _strLine : String; _transactions : CM_TITransactionSet);
//
// Purpose:			Find the last BGM segment sequence number in the passed-in string, and the last EQD (container) id
//
// Parameters:		_protocol - CAMS protocol
//					_strLine - the built-up string of CAMS message processed so far
//					_transactions - teh TI transactions processed to produce _strLine
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 14 May 2020	jlgdap1		Initial creation TFS 49371 SNO BGM Sequence corrections
//
vars
	bgmSeqPos, bgmSeqEndPos, eqdStart, eqdEnd : Integer;
	bgmSequence : Integer;
	tiTrans : CM_TITransaction;
	separator, tiId : String;

begin
	// Need to work backwards in the string passed in, as the TI just processed has been added to the end
	// of the big long file contents string
	// Find the cargo ID in the EQD segment
	separator := _protocol.elementSeparator;
	eqdStart := _strLine.reversePos("EQD" &amp; separator &amp; "CN" &amp; separator);
	eqdEnd := _strLine.pos(separator, eqdStart+8);	
	tiId := _strLine[eqdStart+7:eqdEnd-eqdStart-7];
	
	// Find the BGM sequence numebr in the BGM segment
	bgmSeqPos := _strLine.reversePos("BGM" &amp; separator &amp; "109" &amp; separator) + 7;
	bgmSeqEndPos := _strLine.pos(separator, bgmSeqPos + 1);
	bgmSequence := _strLine[bgmSeqPos:bgmSeqEndPos-bgmSeqPos].Integer;
	
	// store the BGM sequence (and TI booking ref if present) on the relevant TI transaction
	foreach tiTrans in _transactions where tiTrans.myTrackedItem.id = tiId do
		self.retainRecDataOnTiTrx(tiTrans, bgmSequence, tiTrans.myTrackedItem.bookingReference);
	endforeach;
epilog

end;</source>
        <Parameter name="_protocol" type="CM_CamProtocol"/>
        <Parameter name="_strLine" type="String"/>
        <Parameter name="_transactions" type="CM_TITransactionSet"/>
    </JadeMethod>
</Class>
