    <JadeMethod name="userNotificationUpdate" id="564fd52e-d3af-4bdc-b857-6e5bf264e909">
        <updating/>
        <source>userNotificationUpdate(_event: Integer; _noteobj : CM_Object; _obj: CM_Object) updating;
// ---------------------------------------------------------------------------
// Created:		May 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	idx, topRow : Integer;
	invalidObject : Boolean;
begin

	on Exception do app.handleDeletedObject(exception,_obj,invalidObject);
	_obj.fetchLatest;
	
	if invalidObject then
		return;
	endif;
	
	topRow := self.tblData.topRow;
	
	if _event = EVENT_OOWCREATION_UPDATE  
	or _event = VoyageJob_Delete_Event
	or _event = JobSheet_Update_Event then
		self.doQuery();
	endif;

	if _event = EVENT_CRANE_UPDATE then
		self.doNotesCrane(_obj.CM_Object);
	endif;

	if _event = EVENT_OOWVOYAGE_UPDATE then
		if _obj.isKindOf(CM_Voyage) then
			self.dteStart.setDate(self.myCurrentVoyage.shipExchangeDate.date);
			self.timeStart.setTime(self.myCurrentVoyage.shipExchangeDate.time);
			if self.myCurrentVoyage.starboardBerthed then
				self.cmbBerthage.listIndex := 2;
			else
				self.cmbBerthage.listIndex := 1;
			endif;
			
		endif;
	
	endif;
epilog
	if topRow &gt; self.tblData.fixedRows 
	and topRow &lt;= self.tblData.rows then
		//self.tblData.topRow := topRow;
	endif;

end;</source>
        <Parameter name="_event" type="Integer"/>
        <Parameter name="_noteobj" type="CM_Object"/>
        <Parameter name="_obj" type="CM_Object"/>
    </JadeMethod>
    <JadeMethod name="validateCraneMove" id="697176ec-639d-4cb9-9d0e-a6450da54c82">
        <updating/>
        <source>validateCraneMove(_table : Table input; _targetRow : Integer; _moveCrane : CM_Crane): Boolean updating;
// ---------------------------------------------------------------------------
// Created:		09 May 2006 By Andrew Bishop cnwab1
//
// Purpose:		the voyage has a crane clearance setting, this is teh number of bays that cranes should be kept apart.
//
// ---------------------------------------------------------------------------
vars
	diff,bayOrdinal, st, en, idx, numBays : Integer;
	anObj : Object;
	aBay, lastBay, thisBay : CM_Bay;
	aJS : CM_VoyageJobSheet;
	oowc : CM_OOWCreation;
begin
	anObj := _table.accessRow(_targetRow).itemObject;
	if anObj.isKindOf(CM_OOWCreation) then
		aBay := anObj.CM_OOWCreation.myBay;
		bayOrdinal := aBay.ordinalBay;
	endif;

	st := _targetRow;
	en := _table.rows;
	// ## work out how many bays seperate the cranes.
	foreach idx in st to en do
		if not self.validateCraneMoveSub(_table,bayOrdinal,idx,_moveCrane) then
			return false;
		endif;
	endforeach;

	en := _table.fixedRows + 1;
	// ## work out how many bays seperate the cranes.
	foreach idx in en to st reversed do
		if not self.validateCraneMoveSub(_table,bayOrdinal,idx,_moveCrane) then
			return false;
		endif;
	endforeach;
	
	return true;
end;</source>
        <Parameter name="_table" type="Table" usage="input"/>
        <Parameter name="_targetRow" type="Integer"/>
        <Parameter name="_moveCrane" type="CM_Crane"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validateCraneMoveSub" id="b96e6567-53e0-4d9f-be79-379b921bc7c3">
        <updating/>
        <source>validateCraneMoveSub(_table : Table input; bayOrdinal, idx : Integer; _moveCrane : CM_Crane) : Boolean updating;
// ---------------------------------------------------------------------------
// Created:		09 May 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	diff, st, en,  numBays : Integer;
	anObj : Object;
	aBay, lastBay, thisBay : CM_Bay;
	aJS : CM_VoyageJobSheet;
	oowc : CM_OOWCreation;
	aCrane : CM_Crane;
begin
	anObj := _table.accessRow(idx).itemObject;
	if anObj.isKindOf(CM_Crane) then
		aCrane := anObj.CM_Crane;
	
		if _moveCrane = aCrane then
			return true;
		endif;
		
		aJS := self.myCurrentVoyage.allJobSheets[anObj.CM_Crane.id];
		oowc := aJS.allOOWCreations.last;
		if oowc &lt;&gt; null then
			diff := (oowc.myBay.ordinalBay - bayOrdinal).abs();
			if diff &lt;= self.craneClearance then
				app.msgBox(app.getErrorString1(Cranes_bays_apart, self.craneClearance.asStringJMT),app.getErrorString(Error), MsgBox_Exclamation_Mark_Icon);
				self.doUndoDrag(_table);
				return false;
			endif;
		endif;
	endif;

	return true;
end;</source>
        <Parameter name="_table" type="Table" usage="input"/>
        <Parameter name="bayOrdinal" type="Integer"/>
        <Parameter name="idx" type="Integer"/>
        <Parameter name="_moveCrane" type="CM_Crane"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</GUIClass>
