    <JadeMethod name="selectCargoGroup" id="0bc42f96-d217-4b75-bae4-c5cfe6859d69">
        <updating/>
        <source>selectCargoGroup( _manual : Boolean ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 August 2015	cnwndl1	Initial creation	Par 36608

*/

vars

	cargoGroupId : String;
	firstTi : CM_TrackedItem;
	iter : Iterator;
	selectedTi : CM_TrackedItem;
	errMsg : String;
	
begin

	self.setMyCargoGroup( null );
	
	if app.isCargoGroupEnabled then	
	
		cargoGroupId := txtCargoGroupId.text.trimBlanks.toUpper;
		if cargoGroupId = lblCargoGroupId.caption.toUpper then
			cargoGroupId := null;
		endif;
		
		if cargoGroupId &lt;&gt; null then
			firstTi := self.myTerminal.allCargoGroupsByIdCargoType.getAtKeyGeq( cargoGroupId, null );
			if firstTi &lt;&gt; null and firstTi.id = cargoGroupId then	
				selectedTi := firstTi;
			endif;
			self.setMyCargoGroup( selectedTi.CM_CargoGroup );	
		endif;	
		
		if selectedTi = null then
			self.msgBox(app.getErrorString1(Cargo_group_not_found, cargoGroupId),app.getErrorString(Warning), MsgBox_OK_Only, false);
			self.txtCargoGroupId.setFocus();
		endif;
	
	endif;

epilog

	delete iter;

end;</source>
        <Parameter name="_manual" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setMyCargoGroup" id="3469b454-fed0-49ec-8c03-97f95296f665">
        <updating/>
        <source>setMyCargoGroup( _cargoGroup : CM_CargoGroup ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 August 2015	cnwndl1	Initial creation	Par 36608

*/

vars

begin

	self.myCargoGroup := _cargoGroup;
	
	if self.myCargoGroup = null then
		self.lblCGroupDesc.caption := null;
		self.lblWeightValue.caption := null;
		self.lblCountValue.caption := null;
	else
		if self.myCargoGroup.myCargoType &lt;&gt; null then
			self.lblCGroupDesc.caption := self.myCargoGroup.myCargoType.abbreviation &amp; " " &amp; self.myCargoGroup.operatorCode;
		else
			self.lblCGroupDesc.caption := self.myCargoGroup.operatorCode;
		endif;
		self.lblWeightValue.caption := app.getErrorString(Group_weight) &amp; " : " &amp; self.myMobileDataAgent.getMeasureConvertedForDisplay(null, Type_Weight, self.myCargoGroup.totalWeight) &amp; self.myMobileDataAgent.getMeasureLabelUnit(null,Type_Weight);
		self.lblCountValue.caption := app.getErrorString(Count) &amp; " : " &amp; self.myCargoGroup.totalQuantity.String;
		
	endif;

epilog

end;</source>
        <Parameter name="_cargoGroup" type="CM_CargoGroup"/>
    </JadeMethod>
