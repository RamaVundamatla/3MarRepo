    <JadeMethod name="canAccessTodoTasksAddRemove" id="b4b1de8f-3f86-406d-a833-8942d6447eff">
        <source>canAccessTodoTasksAddRemove(_terminal : CM_Terminal) : Boolean;
// ---------------------------------------------------------------------------
// Created:     19 September 2007 by cnwrs2
//
// Purpose:     
// 
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 09 Sep 2019	jlgdi1		45802 Added condition check for JMTSupport user 
// ---------------------------------------------------------------------------
vars
	tmpUT	: CM_UserTerminal;

begin

	if app.isSpecial() then
		return true;
	endif;

	if _terminal = null then
		return false;
	endif;
	
	// 45802
	if self.isJmtSupportUser() then 
		return false;
	endif;
	
	tmpUT := self.getUserTerminal(_terminal);
	if tmpUT = null then
		return false;
	endif;

	if tmpUT.mySecurityRole &lt;&gt; null and
	   (not tmpUT.mySecurityRole.allToDoTasksAddRemove.isEmpty()) then
	   	return true;
	endif;

	return false;
end;</source>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
