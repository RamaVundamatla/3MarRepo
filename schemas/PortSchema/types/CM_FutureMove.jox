    <JadeMethod name="setMyWorkListEntry" id="a3810020-9528-48e8-ae84-bc12220880a4">
        <updating/>
        <source>setMyWorkListEntry(_wle : CM_WorkListEntry input; _nullWleAllowed : Boolean) updating;
//--------------------------------------------------------------
//Created: 09 June 2003 By: cnwgd1
//--------------------------------------------------------------
vars

begin


	
	if _wle &lt;&gt; null then
		if _wle.myFutureMove &lt;&gt; null then
			if _wle.myFutureMove = self then
				return;
			else
				_wle.myFutureMove.setMyWorkListEntry(null, true);
			endif;
		endif;
	else
		if not _nullWleAllowed then
			// IF you see this exception tell Andrew Or Dave 
			app.writeLog('Allowing null wle on futureMove', LogINFO);
			//app.raiseCMException3(UNEXPECTED_PROGRAM_ERROR, class.name, method.name, "WLE is NULL!", null,null);
	//		return;
		endif;
	endif;
	
	self.myWorkListEntry := _wle;
	
end;</source>
        <Parameter name="_wle" type="CM_WorkListEntry" usage="input"/>
        <Parameter name="_nullWleAllowed" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setMyWorkListEntryDR" id="a991ab51-ced9-47e1-9361-b8f97e8080ff">
        <updating/>
        <source>setMyWorkListEntryDR(_wle : CM_WorkListEntry input; _nullWleAllowed : Boolean) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 May 2019	jlgzm1	TFS 42840 MSL Direct Release between Voyages and Rail

*/

vars

begin
	
	if _wle &lt;&gt; null then
		if _wle.myFutureMoveDR &lt;&gt; null then
			if _wle.myFutureMoveDR = self then
				return;
			else
				_wle.myFutureMoveDR.setMyWorkListEntryDR(null, true);
			endif;
		endif;
	else
		if not _nullWleAllowed then
			app.writeLog('Allowing null wle on futureMove', LogINFO);
		endif;
	endif;
	
	self.myWorkListEntryDR := _wle;
	
end;</source>
        <Parameter name="_wle" type="CM_WorkListEntry" usage="input"/>
        <Parameter name="_nullWleAllowed" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validateForCreate" id="312aff56-7eca-45a3-b8e8-4d4552331969">
        <source>validateForCreate(_myTerminal : CM_Terminal; _moveType : Integer; _allLocationsControllers : CM_LCArray; _myTrackedItem : CM_TrackedItem; arrayIndex : Integer );
/*
 ------------------------------------------------------------------------
Created:			31 October 2002 by cnwdwq1
Purpose:			
Parameters:		None
Returns:			Nothing
Changed On		Changed By		Reason
--------------		--------------		-----------------------------------------
---------------------------------------------------------------------------
*/
vars
begin
	//if _moveType &lt; TI_FutureMovePlanned or _moveType &gt; TI_FutureMoveEDI then
	if _moveType &lt; TI_FutureMovePlanned or _moveType &gt; TI_FutureMovePoP then  //cnwrd1 par 26734 CCMS 2014 plan on pickup
		app.raiseCMException1(Err_InvalidFutureMove, _moveType.String, null, null);
	endif;
	if _myTerminal = null then
		app.raiseCMException1(ERR_NO_OBJECT, 'myTerminal reference', null, null);
	endif;
end;</source>
        <Parameter name="_myTerminal" type="CM_Terminal"/>
        <Parameter name="_moveType" type="Integer"/>
        <Parameter name="_allLocationsControllers" type="CM_LCArray"/>
        <Parameter name="_myTrackedItem" type="CM_TrackedItem"/>
        <Parameter name="arrayIndex" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="validateForUpdateQtyWeight" id="73dd3fed-5902-428e-ad25-bb73efdf6bbe">
        <source>validateForUpdateQtyWeight(_newWeight : Decimal; _newQty : Integer);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 Mar 2021 cnwma1  ChangeRequest 50854: ASPA - Hold Planning Change Planned Amount

*/

vars
	ti 			  : CM_TrackedItem;
	measure		  : CM_MeasurementType;
	unit		  : String;
	converted	  :  String;
	wle           : CM_WorkListEntry;
	otherFmQty	  : Integer;
	fM            : CM_FutureMove;
	otherFmWt     : Decimal[14,4] ;
begin
	
	wle := self.myWorkListEntry;
	if wle = null then
		return;
	endif;
	
	ti := wle.myTrackedItem;
	if ti = null then
		app.raiseCMException( MACH_NO_CONTAINER, null, self );
		return;
	endif;
	
	if ( wle.weight &gt; 0 and _newWeight = 0 ) or ( wle.quantity &gt; 0 and _newQty = 0 ) then
		app.raiseCMException1( Must_greater_than_zero, app.getErrorString(Move_amount), null, self );
		return;
	endif;
	

	foreach fM in ti.allPlannedFutureMoves discreteLock do 
		if fM = self then
			continue;
		endif;
		
		wle := fM.myWorkListEntry;
		
		if wle = null then
			continue;
		endif;
		
		otherFmQty := otherFmQty + wle.quantity;
		otherFmWt  := otherFmWt  + wle.weight;
	endforeach;
	
	if _newQty + otherFmQty &gt; ti.totalQuantity then
		app.raiseCMException4( ERR_ChangeMoveQtyWt, app.getErrorString(Planned),(_newQty + otherFmQty).String,ti.id, ti.totalQuantity.String, null, wle );
		return;
	endif;
	
	if _newWeight + otherFmWt &gt; ti.totalWeight then
		measure   := ti.getDefaultMeasurementForType(Type_Weight);
		unit 	  := measure.shortName;
		converted := app.convertMeasurementForDisplay(unit, _newWeight +otherFmWt);
		app.raiseCMException4( ERR_ChangeMoveQtyWt, app.getErrorString(Planned),converted &amp; Space &amp; unit,ti.id, ti.getDefaultTotalWeightDisplay, null, wle );
		return;
	endif;
	
epilog

end;</source>
        <Parameter name="_newWeight" type="Decimal"/>
        <Parameter name="_newQty" type="Integer"/>
    </JadeMethod>
</Class>
