    <JadeMethod name="unload" id="36bd18c5-33ae-4349-8022-3a6f3dee58fc">
        <controlMethod name="Form::unload"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>unload() updating;
/*
Purpose:			

Date		Who		Reason
13DEC2022	NAVAB1	TFS CR 55645 TASK 55662
16 October 2023	navmv20	Bug 60893: FR - 54089 - Invoice Contract screens - Modal mode
14 Oct 2024 navlc30 JIRA 19508 UI - Contract Enquiry extra tables for results
*/


vars
	contractMaintForm : INV_ContractMaint; //16/10/2023	navmv20	Bug 60893
	contractRateMaint : INV_ContractRateMaint; //16/10/2023	navmv20	Bug 60893
	contractRateEntriesMaint : INV_ContractRateEntriesMaint;
begin
	//16/10/2023	navmv20	Bug 60893 - start
	contractMaintForm := self.myContractMaintForm;
	if contractMaintForm &lt;&gt; null then
		contractRateMaint := contractMaintForm.myContractRateMaint;
		if contractRateMaint &lt;&gt; null then
			contractRateMaint.unloadForm();
		endif;
		contractMaintForm.unloadForm();
	endif;
	
	contractRateMaint := self.myContractRateMaintForm;					//14.10.2024 navlc30 #19508
	if contractRateMaint &lt;&gt; null then
			contractRateMaint.unloadForm();
	endif;
	
	contractRateEntriesMaint := self.myRateEntriesMaintForm;			//14.10.2024 navlc30 #19508
	if contractRateEntriesMaint&lt;&gt; null  then
		contractRateEntriesMaint.unloadForm();
	endif;
	
	self.allTransientsToDelete.purge();									//14.10.2024 navlc30 #19508
	
	//16/10/2023	navmv20	Bug 60893 - end
	inheritMethod();
	delete self.myFilterCriteria;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="userNotify" id="e3fe5bc2-1f21-43aa-84fc-b9d96ad88165">
        <controlMethod name="Form::userNotify"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>userNotify(eventType: Integer; theObject: Object; eventTag: Integer; userInfo: Any) updating;
/*
Purpose:			

Date		Who		Reason
13 December 2022	navab1	TFS CR 55645 TASK 55662
*/

vars

begin
	self.handleUserNote(eventType, theObject,eventTag, userInfo);
	
epilog

end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
        <Parameter name="userInfo" type="Any"/>
    </JadeMethod>
</GUIClass>
