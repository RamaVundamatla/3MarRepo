    <JadeMethod name="initTblCargo" id="e13275f8-2fe3-4dd9-9e50-315d31b7ad5d">
        <updating/>
        <source>initTblCargo() updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
03 July 2009	cnwmd1	Initial creation

*/

vars
	entTableDef		: EntTableDef;
	view			: String;
	xmlStrTblData	: String;
begin
	self.resize();
	
	self.tblCargo.rows := 1;
	self.tblCargo.fixedRows 	:= 1;
	
	entTableDef := app.myController.getEntTableDef(ETDef_LlHeadings);
	if entTableDef &lt;&gt; null then
		if self.optDirInTB.value then 
			if self.tableDefIn &lt;&gt; null then //If size = 0 then no previously saved settings in CM_UserWindow.  Will use default view.
				xmlStrTblData := self.tableDefIn;
			endif;
			view := ETView_WagonIn2;
		elseif self.optDirOutTB.value then
			if self.tableDefOut &lt;&gt; null then
				xmlStrTblData := self.tableDefOut;
			endif;
			view := ETView_WagonOut2;
		endif;
	else
		app.raiseUnexpectedProgramError(class.name, method.name, 'Def (' &amp; ETDef_LlHeadings &amp; ') not found');
	endif;
	
	if xmlStrTblData &lt;&gt; null then
		self.tblCargo.setTblDataEntRowsFromXML(entTableDef, xmlStrTblData);	
	else
		self.tblCargo.setTblDataEntRowsFromView(entTableDef, view);
	endif;
	
	self.tblCargo.multiSelect := CM_DataTable.MultiSelect_Simple;
	self.tblCargo.selectionType := CM_DataTable.SelectionType_Row;
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="initialiseForm" id="b195618d-593b-476a-89ad-946012f9dd26">
        <updating/>
        <source>initialiseForm(	_train : CM_Train; 
			_wagon : CM_Wagon;
			_mode : Integer //set this to one of this forms display mode constants 
			)updating;

/*

Purpose:			Initialise properties on this form only.  Controls are initialised in setupForm().

Parameters:			_mode : Integer &lt;-- set this to the one of this forms display mode constants.
										Null will default to View

Return Value:		


Date		Who		Reason
24 June 2009	cnwmd1	Initial creation

*/

vars

begin
	self.myCurrentTrain := _train;
	self.myCurrentWagon := _wagon;
	self.mode := _mode;
epilog

end;</source>
        <Parameter name="_train" type="CM_Train"/>
        <Parameter name="_wagon" type="CM_Wagon"/>
        <Parameter name="_mode" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="loadCargo" id="414f96d7-0cfd-4b1e-b9cc-750fbe5be0a2">
        <source>loadCargo(_inward : Boolean) protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
03 July 2009	cnwmd1	Initial creation
// 12 Oct 2016	cnwrs1	TFS 2829 Cams processing failure with Train Events
*/

vars
	wagon : CM_Wagon;
	ti : CM_TrackedItem;
	tiArray : CM_TIArray;
	invalidObject : Boolean;
begin
	on Exception do app.handleDeletedObject(exception, wagon, invalidObject);
	wagon := self.myCurrentWagon;
	self.tblCargo.rows := self.tblCargo.fixedRows;
	self.tblCargo.allSelectedObjects.clear();
	if wagon = null then
		return;
	endif;
	create tiArray transient;
	if _inward then
		wagon.getAllTrackedItems(_inward, tiArray, wagon.confirmed);
	else
		wagon.getAllTrackedItems(_inward, tiArray, wagon.confirmedOutwards); // This will look at the collection of released TIs  on wagon
		if tiArray.isEmpty then
			wagon.getAllTrackedItems(_inward, tiArray, not wagon.confirmedOutwards); // This will look at the TIs on the wagon controllers.
		endif;
	endif;
	
	foreach ti in tiArray do
		self.addCargoRow(ti); 
	endforeach;
epilog
	delete tiArray;
end;</source>
        <access>protected</access>
        <Parameter name="_inward" type="Boolean"/>
    </JadeMethod>
