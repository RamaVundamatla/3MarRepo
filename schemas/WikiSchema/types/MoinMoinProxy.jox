    <JadeMethod name="putAttachment" id="7aa59f4b-98b1-4536-9825-11e615d51288">
        <updating/>
        <source>putAttachment( pageName, pathToAttachment: String; errormsg: String io ): Boolean updating;

vars
    fileName     : String ;
    fileContents : String;
    file         : File ;
    pos : Integer;
    len : Integer;  
    base64String : String;
    
	xmlDocument		: JadeXMLDocument ;
	rootElement		: JadeXMLElement ;
	methodElement	: JadeXMLElement ;
	paramsElement   : JadeXMLElement ;
	paramElement    : JadeXMLElement ;
	valueElement    : JadeXMLElement ;
	arrayElement    : JadeXMLElement ;
	dataElement     : JadeXMLElement ;
	dataElement2    : JadeXMLElement ;
	structElement   : JadeXMLElement ;
	memberElement   : JadeXMLElement ;
	nameElement     : JadeXMLElement ;
	stringElement   : JadeXMLElement ;
    base64Element   : JadeXMLElement ;
   	tokenDocument	: JadeXMLDocument ;
	faultElement    : JadeXMLElement ;
    resultXML       : String;
    success         : Boolean;
    hasFault        : Boolean;

    http      : JadeHTTPConnection; //use unpublished class
    cmd       : String;
    parms     : String;
    result    : String[256];
    headers   : String;
    response  : String;     
begin
    // Read the file and convert its contents to base64
    // Warning throws exception if file not found.
    create file transient ;
	file.kind := File.Kind_Unknown_Text;	// 3/3/16 cnwmp6 PAR 36286 unicode version
    file.fileName := pathToAttachment;
    if false = file.isAvailable()
    then
      success := false;
      errormsg := "File for attachment not available : " &amp; pathToAttachment;
      return success;
    endif;
      
    file.openInput( pathToAttachment ); // Assumes a full path C:\...
    fileContents := file.readString( file.fileLength );
    pos := file.fileName.reversePos('\');
    len := file.fileName.length;
    fileName := file.fileName[pos + 1:len];        

    base64String := fileContents.Binary.base64Encode();
    
    // Create XMLRPC request for uploading an attachment
    create xmlDocument transient ;
	rootElement	:= xmlDocument.addElement( 'methodCall' );
    methodElement := rootElement.addElement( 'methodName' );
    methodElement.addText( 'system.multicall' );
    paramsElement := rootElement.addElement( 'params' );
    paramElement := paramsElement.addElement( 'param' );
    valueElement := paramElement.addElement( 'value' );
    arrayElement := valueElement.addElement( 'array' );
    dataElement := arrayElement.addElement( 'data' );
    valueElement := dataElement.addElement( 'value' );
    structElement := valueElement.addElement( 'struct' );
    memberElement := structElement.addElement( 'member' );
    nameElement := memberElement.addElement( 'name' );
    nameElement.addText( 'params' );
    valueElement := memberElement.addElement( 'value' );
    arrayElement := valueElement.addElement( 'array' );
    dataElement2 := arrayElement.addElement( 'data' );
    valueElement := dataElement2.addElement( 'value' );
    stringElement := valueElement.addElement( 'string' );
    stringElement.addText( authToken );
    memberElement := structElement.addElement( 'member' );
    nameElement := memberElement.addElement( 'name' );
    nameElement.addText( 'methodName' );
    valueElement := memberElement.addElement( 'value' );
    stringElement := valueElement.addElement( 'string' );
    stringElement.addText( 'applyAuthToken' );
    valueElement := dataElement.addElement( 'value' );
    structElement := valueElement.addElement( 'struct' );
    memberElement := structElement.addElement( 'member' );
    nameElement := memberElement.addElement( 'name' );
    nameElement.addText( 'params' );
    valueElement := memberElement.addElement( 'value' );
    arrayElement := valueElement.addElement( 'array' );
    dataElement := arrayElement.addElement( 'data' );
    valueElement := dataElement.addElement( 'value' );
    stringElement := valueElement.addElement( 'string' );
    stringElement.addText( pageName.trimBlanks );
    valueElement := dataElement.addElement( 'value' );
    stringElement := valueElement.addElement( 'string' );
    stringElement.addText( fileName.trimBlanks );
    valueElement := dataElement.addElement( 'value' );
    base64Element := valueElement.addElement( 'base64' );
    base64Element.addText( base64String.trimBlanks );
    memberElement := structElement.addElement( 'member' );
    nameElement := memberElement.addElement( 'name' );
    nameElement.addText( 'methodName' );
    valueElement := memberElement.addElement( 'value' );
    stringElement := valueElement.addElement( 'string' );
    stringElement.addText( 'putAttachment' );

    // BEGIN HTTP stuff
    parms := xmlDocument.writeToString ;
    headers := null;
    cmd := '?action=xmlrpc2';
    
	// create a transient instance of the JadeHTTPCOnnection class and
	// call getHttpPage. Note that the server name (2nd parameter) must
	// include the scheme (in this case https).
    create http transient;
	response := http.getHttpPage('POST', 'https://' &amp; serverURL &amp; '/', cmd, parms, '');
	// A null response implies the call has failed.
	if response &lt;&gt; null then
      // Parse the response
      pos := response.pos('&lt;',1); // strip off leading number
      len := response.length;
      response := response[pos:len];

      create tokenDocument transient;
      tokenDocument.parseString( response );
      methodElement := tokenDocument.findElementByTagName( 'methodResponse' );       
      resultXML := methodElement.writeToString;
      success := resultXML.cnContains('SUCCESS');
      hasFault := resultXML.cnContains('faultString');
      if hasFault then
        faultElement := tokenDocument.findElementByTagName( 'faultString' );   
        pos := resultXML.pos('faultString',1);
        len := resultXML.length;
        errormsg := resultXML[pos:len];
      endif;
    else
        errormsg := "Unable to connect to MoinMoin server.";
        success := false;
    endif;

    return success;
epilog
    file.close ;
    delete file ; 
    delete http;
    delete tokenDocument;
    delete xmlDocument;
end;
</source>
        <Parameter name="pageName" type="String"/>
        <Parameter name="pathToAttachment" type="String"/>
        <Parameter name="errormsg" type="String" usage="io"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="putPage" id="9d5e1f64-4bad-4a0b-85b7-33f0eecf2146">
        <updating/>
        <source>putPage( pageName, pageContent : String; errormsg: String io ): Boolean updating;

vars
	xmlDocument		: JadeXMLDocument ;
	rootElement		: JadeXMLElement ;
	methodElement	: JadeXMLElement ;
	paramsElement   : JadeXMLElement ;
	paramElement    : JadeXMLElement ;
	valueElement    : JadeXMLElement ;
	arrayElement    : JadeXMLElement ;
	dataElement     : JadeXMLElement ;
	dataElement2    : JadeXMLElement ;
	structElement   : JadeXMLElement ;
	memberElement   : JadeXMLElement ;
	nameElement     : JadeXMLElement ;
	stringElement   : JadeXMLElement ;
   	tokenDocument	: JadeXMLDocument ;
	faultElement    : JadeXMLElement ;
    resultXML       : String;
    success         : Boolean;
    hasFault        : Boolean;

    http      : JadeHTTPConnection; //use unpublished class
    cmd       : String;
    parms     : String;
    result    : String[256];
    headers   : String;
    response  : String; 
    
    pos : Integer;
    len : Integer;    
begin
    // Create XMLRPC request for putting a page
    create xmlDocument transient ;
	rootElement	:= xmlDocument.addElement( 'methodCall' );
    methodElement := rootElement.addElement( 'methodName' );
    methodElement.addText( 'system.multicall' );
    paramsElement := rootElement.addElement( 'params' );
    paramElement := paramsElement.addElement( 'param' );
    valueElement := paramElement.addElement( 'value' );
    arrayElement := valueElement.addElement( 'array' );
    dataElement := arrayElement.addElement( 'data' );
    valueElement := dataElement.addElement( 'value' );
    structElement := valueElement.addElement( 'struct' );
    memberElement := structElement.addElement( 'member' );
    nameElement := memberElement.addElement( 'name' );
    nameElement.addText( 'params' );
    valueElement := memberElement.addElement( 'value' );
    arrayElement := valueElement.addElement( 'array' );
    dataElement2 := arrayElement.addElement( 'data' );
    valueElement := dataElement2.addElement( 'value' );
    stringElement := valueElement.addElement( 'string' );
    stringElement.addText( authToken );
    memberElement := structElement.addElement( 'member' );
    nameElement := memberElement.addElement( 'name' );
    nameElement.addText( 'methodName' );
    valueElement := memberElement.addElement( 'value' );
    stringElement := valueElement.addElement( 'string' );
    stringElement.addText( 'applyAuthToken' );
    valueElement := dataElement.addElement( 'value' );
    structElement := valueElement.addElement( 'struct' );
    memberElement := structElement.addElement( 'member' );
    nameElement := memberElement.addElement( 'name' );
    nameElement.addText( 'params' );
    valueElement := memberElement.addElement( 'value' );
    arrayElement := valueElement.addElement( 'array' );
    dataElement := arrayElement.addElement( 'data' );
    valueElement := dataElement.addElement( 'value' );
    stringElement := valueElement.addElement( 'string' );
    stringElement.addText( pageName.trimBlanks );
    valueElement := dataElement.addElement( 'value' );
    stringElement := valueElement.addElement( 'string' );
    stringElement.addText( pageContent.trimBlanks );
    memberElement := structElement.addElement( 'member' );
    nameElement := memberElement.addElement( 'name' );
    nameElement.addText( 'methodName' );
    valueElement := memberElement.addElement( 'value' );
    stringElement := valueElement.addElement( 'string' );
    stringElement.addText( 'putPage' );

    // BEGIN HTTP stuff
    parms := xmlDocument.writeToString ;
    headers := null;
    cmd := '?action=xmlrpc2';

	// create a transient instance of the JadeHTTPCOnnection class and
	// call getHttpPage. Note that the server name (2nd parameter) must
	// include the scheme (in this case https).
    create http transient;
	response := http.getHttpPage('POST', 'https://' &amp; serverURL &amp; '/', cmd, parms, '');
	// A null response implies the call has failed.
	if response &lt;&gt; null then
        
      // Parse the response
      pos := response.pos('&lt;',1); // strip off leading number
      len := response.length;
      response := response[pos:len];

      create tokenDocument transient;
      tokenDocument.parseString( response );
      methodElement := tokenDocument.findElementByTagName( 'methodResponse' );       
      resultXML := methodElement.writeToString;
      success := resultXML.cnContains('SUCCESS');
      hasFault := resultXML.cnContains('faultString');
      if hasFault then
        faultElement := tokenDocument.findElementByTagName( 'faultString' );   
        pos := resultXML.pos('faultString',1);
        len := resultXML.length;
        errormsg := resultXML[pos:len];
      endif;
    else
        errormsg := "Unable to connect to MoinMoin server.";
        success := false;
    endif;

    return success;
epilog
    delete tokenDocument;
    delete xmlDocument;
    delete http;
end;

</source>
        <Parameter name="pageName" type="String"/>
        <Parameter name="pageContent" type="String"/>
        <Parameter name="errormsg" type="String" usage="io"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
