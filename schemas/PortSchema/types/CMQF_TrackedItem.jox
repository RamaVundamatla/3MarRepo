    <JadeMethod name="getOIDAndDescForAttribute" id="f7facfcf-a841-472d-83af-ac5ea20af3a2">
        <source>getOIDAndDescForAttribute(_attrName : String; _getCalculatedDate : Boolean; _oid : String output): String;
// ---------------------------------------------------------------------------
// Created:     19/07/2010 cnwdz2	
//
// Purpose:     PAR24513 extend the current existing getDisplayStringForAttribute method to return an object's oid.	
// 
// Changed On	By			Reason
// ----------	--------	--------------------------------------------------
// 27/07/2017	cnwdap1		TFS 5557 Include Tranships criteria not saved to template
vars
	runDate			: Date;
	shipLine : CM_ShippingLine;
begin
	runDate := app.actualTimeServer().Date;	// 28/4/16 cnwmp6 TFS 488 - Multi timezone support
	
	if _attrName = ETRow_EndTime or
	   _attrName = ETRow_FirstConnectDT then
		if self.onTime.isValid then
			//return self.onTime.String;
			return self.onTime.asStringJMT();  //par 18944
		else
			//return '23:59:59';
			return '23:59';  //par 18944
		endif;
	elseif _attrName = ETRow_Id then
		return self.id;
	elseif _attrName = ETRow_LoadPort then
		if self.getMyLoadPort &lt;&gt; null then
			_oid := self.getMyLoadPort.getOidAsString(); //20/07/2010 cnwdz2 24513
			return self.getMyLoadPort.code;
		else
			return Any_String;
		endif;
		
	elseif _attrName = ETRow_IMEXStatuses then
		return self.getQryIMEXLabel(_oid);//21/07/2010 cnwdz2 24513
	
	elseif _attrName = ETRow_Port or
	   _attrName = ETRow_DischargePort then
		if self.getMyPort &lt;&gt; null then
			_oid := self.getMyPort.getOidAsString(); //20/07/2010 cnwdz2 24513
			return self.getMyPort.code;
		else
			return Any_String;
		endif;
	
	elseif _attrName = ETRow_IsoTypeGroup then
		if self.getMyISOTypeGroup &lt;&gt; null then
			_oid := self.getMyISOTypeGroup.getOidAsString(); //20/07/2010 cnwdz2 24513
			return self.getMyISOTypeGroup.code;
		else
			return Any_String;
		endif;
	
	elseif _attrName = ETRow_OperatorGroup then
		if self.getMyOperatorGroup &lt;&gt; null then
			_oid := self.getMyOperatorGroup.getOidAsString(); //20/07/2010 cnwdz2 24513
			return self.getMyOperatorGroup.code;
		else
			return Any_String;
		endif;
	
	elseif _attrName = ETRow_OnDate then
		if _getCalculatedDate then
			return self.setDateFromTemplate(self.onDateTplType, self.onDateTplFactor, runDate).shortFormatJMT();
		else
			return self.getTemplateDateStr(self.onDateTplType, self.onDateTplFactor);
		endif;
		
	elseif _attrName = ETRow_MyProduct or
		_attrName = ETRow_Product then
		if self.getMyProduct &lt;&gt; null then
			_oid := self.getMyProduct.getOidAsString(); //20/07/2010 cnwdz2 24513
			return self.getMyProduct.code;
		else
			return Any_String;
		endif;
	
	elseif _attrName = ETRow_SiteState then
		return self.getSiteOIDAndString(_oid); //31/08/2010 cnwdz2 par25524
	
	elseif _attrName = ETRow_Stops then
		return self.getStopsString(_oid);//21/07/2010 cnwdz2 24513
		
	elseif _attrName = 	ETRow_SaveToWorkList then 
		return self.saveToWorkList.cnEcGetTableCheckBoxValue();
		
	elseif _attrName = ETRow_Voyage or
		_attrName = ETRow_MyVoyage then
		if self.getMyVoyage &lt;&gt; null then
			_oid := self.getMyVoyage.getOidAsString(); //20/07/2010 cnwdz2 24513
			return self.getMyVoyage.code ;// &amp; '  ' &amp; self.myVoyage.vesselName;
		else
			return Any_String;
		endif;
	
	elseif _attrName = ETRow_DaysOnsite then
		return self.daysOnsite.String;
		
	elseif _attrName = ETRow_IncludeTranships then					// TFS 5557
		return self.includeTranships.cnEcGetTableCheckBoxValue;		// TFS 5557
		
	 // ### TFS BUG 56660 23FEB2023 NAVAB1
	elseif _attrName = ETRow_ShippingLine then
		shipLine := self.getMyShippingLine();
		if shipLine &lt;&gt; null then
			_oid:=shipLine.getOidAsString;
			return shipLine.code;
		endif;
		return Any_String;
	endif;	//par 14114
	
	return inheritMethod(_attrName, _getCalculatedDate, _oid);
	

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_getCalculatedDate" type="Boolean"/>
        <Parameter name="_oid" type="String" usage="output"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getOnTimeStamp" id="81cb76df-134f-4d3e-9132-4c5e357ad722">
        <source>getOnTimeStamp() : TimeStamp;
// ---------------------------------------------------------------------------
// Created:     22 January 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	ts			: TimeStamp;
begin
	ts.setDate(self.onDate);
	ts.setTime(self.onTime);
	return ts;
end;</source>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="getQryIMEXLabel" id="4ad111f9-c1c6-42db-8828-582b8bb2cfe7">
        <source>getQryIMEXLabel(_oid:String output): String;
//----------------------------------------------------------------
//	Created:	15 October 2003	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------

vars
	str				:	String;
	imexStatus		:	CM_IMEXStatus;
begin
	foreach imexStatus in self.allQryIMEXStatuses do
		if str = "" then
			_oid := imexStatus.getOidAsString(); //21/07/2010 cnwdz2 24513
			str := imexStatus.description.trimBlanks;
		else
			_oid := _oid &amp; ", " &amp; imexStatus.getOidAsString(); //21/07/2010 cnwdz2 24513		15/01/2013 - cnwmc5 - PAR #30958
			str := str &amp; ", " &amp;  imexStatus.description.trimBlanks;	//15/01/2013 - cnwmc5 - PAR #30958
		endif;
	endforeach;
	
return str[1:80];	//allows for 10 codes minimum - should be enough.
end;</source>
        <Parameter name="_oid" type="String" usage="output"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getQryStopsLabel" id="cb67eacb-cdb1-4943-b969-e7c1aad3ee83">
        <source>getQryStopsLabel(): String;
// ---------------------------------------------------------------------------
// Created:		06 January 2003  by Jason Chapman  (cnwjc2)
//				Returns a string containing stopTable codes
// ---------------------------------------------------------------------------

vars
	str				:	String;
	stopTable		:	CM_StopsTable;
	edition : Integer;	//18 July 2016	NDL	TFS 2329
	invalid : Boolean;	//18 July 2016	NDL	TFS 2329
begin

	on Exception do app.handleDeletedObject( exception, stopTable, invalid );	//18 July 2016	NDL	TFS 2329
	
	foreach stopTable in self.allQryStopTables do
	
		//18 July 2016	NDL	TFS 2329
		invalid := false;
		edition := stopTable.edition;
		if invalid then
			continue;
		endif;
		
		if str = "" then
			str := stopTable.code.trimBlanks;
		else
			str := str &amp; "/" &amp;  stopTable.code.trimBlanks;
		endif;
	endforeach;
	return str[1:80];	//allows for 20 codes minimum - should be enough.
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getSiteOIDAndString" id="fdfd93c3-28f6-4f56-905f-984db3e69aaa">
        <source>getSiteOIDAndString(_oid : String output) : String;
// ---------------------------------------------------------------------------
// Created:      31/08/2010 cnwdz2 par25524
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	siteString			: String;
	site				: Integer;
begin
	foreach site in self.allQrySites do
		_oid := _oid &amp; site.String &amp; ', ';
		siteString := siteString &amp; app.siteEnumToString(site) &amp; ', ';
	endforeach;
	
	if siteString &lt;&gt; null then
		_oid := _oid[1:_oid.length-2];
		siteString := siteString[1: siteString.length -2];
	endif;
	
	return siteString[1:50];
end;</source>
        <Parameter name="_oid" type="String" usage="output"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getSiteString" id="2285e52c-f403-4344-ae65-ad99ba943e76">
        <source>getSiteString() : String;
// ---------------------------------------------------------------------------
// Created:     13 January 2004	cnwth2:b
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	//siteString			: String;
	//site				: Integer;
	oid : String;
begin
	return self.getSiteOIDAndString(oid); //31/08/2010 cnwdz2 25524
/*
	foreach site in self.allQrySites do
		siteString := siteString &amp; app.siteEnumToString(site) &amp; ', ';
	endforeach;
	
	if siteString &lt;&gt; null then
		siteString := siteString[1: siteString.length -1];
	endif;
	
	return siteString[1:50];
	*/
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getStopsString" id="d4643cf5-dba4-4f86-b3d0-e35802b45771">
        <source>getStopsString(_oid : String output): String;
//----------------------------------------------------------------
//	Created:	04 June 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	obj	: Object;
	str	: String;
	edition : Integer;	//18 July 2016	NDL	TFS 2329
	invalid : Boolean;	//18 July 2016	NDL	TFS 2329
begin

	on Exception do app.handleDeletedObject( exception, obj, invalid );	//18 July 2016	NDL	TFS 2329
	
	if self.allQryStopTables.size = 0 then
		str := Any_String;
	else
		foreach obj in self.allQryStopTables do
		
			//18 July 2016	NDL	TFS 2329
			invalid := false;
			edition := obj.edition;
			if invalid then
				continue;
			endif;
		
			if str &lt;&gt; null then
				_oid := _oid &amp; ', ';
				str := str &amp; ', ';
			endif;
			_oid := _oid &amp; obj.getOidAsString(); //21/07/2010 cnwdz2 24513
			str := str &amp; obj.getPropertyValue('code').String.trimBlanks;
		endforeach;
		
		//18 July 2016	NDL	TFS 2329
		if str = null then
			str := Any_String;
		endif;
		
	endif;

	return str;
			
end;</source>
        <Parameter name="_oid" type="String" usage="output"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getVoyageJobIDs" id="7f47595c-cd1e-4848-896e-a64f6e300cfe">
        <source>getVoyageJobIDs(): String;
//----------------------------------------------------------------
//	Created:	24 November 2003	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	vj	: CM_VoyageJob;
	str	: String;
	edition : Integer;	//18 July 2016	NDL	TFS 2329
	invalid : Boolean;	//18 July 2016	NDL	TFS 2329
begin
	on Exception do app.handleDeletedObject( exception, vj, invalid );	//18 July 2016	NDL	TFS 2329
	
	foreach vj in self.allQryVoyageJobs do
	
		//18 July 2016	NDL	TFS 2329
		invalid := false;
		edition := vj.edition;
		if invalid then
			continue;
		endif;
		
		if str = null then
			str := vj.id;
		else
			str := str &amp; ", " &amp; vj.id;
		endif;
	endforeach;

	return str[1:50];
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="handleCountryOfOrigin" id="f850ced9-efba-4841-abd2-37bbc3d350e2">
        <updating/>
        <source>handleCountryOfOrigin(_collection : Collection input; _passport : CM_Passport; _breakOut : Boolean output) protected, updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 August 2022	navak20	TFS ChangeRequest 54441: EUP - Additional Field - Country of Origin

*/

vars
	ti				: CM_TrackedItem;
	querySelf		: CMQF_TrackedItem;
begin

	if querySelf.checkStatusIncludesObject(ti, _passport, _breakOut) then
		if (not _collection.includes(ti)) then
			_collection.add(ti);
			self.doStats(ti);				
		endif;
	endif;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_collection" type="Collection" usage="input"/>
        <Parameter name="_passport" type="CM_Passport"/>
        <Parameter name="_breakOut" type="Boolean" usage="output"/>
    </JadeMethod>
    <JadeMethod name="handleLocationsController" id="165a9b9b-9b16-4a62-9011-728c06a53cd7">
        <updating/>
        <source>handleLocationsController(_lc : CM_LocationsController; 
						_collection : Collection input; 
						_passport : CM_Passport; 
						_breakOut : Boolean output) protected, updating;
// ---------------------------------------------------------------------------
// Created:     24 October 2003	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	ti	 					: CM_TrackedItem;
begin
	if _lc = null then
		return;
	endif;
	
	foreach ti in _lc.allTrackedItems discreteLock do
		if self.checkStatusIncludesObject(ti, _passport, _breakOut) then
//		if self.includesObject(ti, _passport, _breakOut) then
			if _collection = self.allQryTIs then
				if self.allQryTIs.includesKey(ti.id) then
					continue;
				endif;
			endif;

			if (not _collection.includes(ti)) then
				_collection.add(ti);
				self.doStats(ti);
			endif;
			
//			if _breakOut then
//				break;
//			endif;
		endif;
	endforeach;
end;</source>
        <access>protected</access>
        <Parameter name="_lc" type="CM_LocationsController"/>
        <Parameter name="_collection" type="Collection" usage="input"/>
        <Parameter name="_passport" type="CM_Passport"/>
        <Parameter name="_breakOut" type="Boolean" usage="output"/>
    </JadeMethod>
    <JadeMethod name="handleOnSiteByAlternateId" id="69950d40-8f90-4aa4-90c3-5c62f38adbae">
        <updating/>
        <source>handleOnSiteByAlternateId(	_collection : Collection input; 
							_passport : CM_Passport; 
							_breakOut : Boolean output) protected, updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 May 2013	cnwndl1	Initial creation	Par 31506

*/

vars

	querySelf : CMQF_TrackedItem;
	altId : String;
	terminal : CM_Terminal;
	iter : Iterator;
	startAtObject : CM_TrackedItem;
	ti : CM_TrackedItem;

begin

	altId := self.alternativeId.toUpper;
	if altId.trimBlanks = null then
		return;
	endif;
	
	querySelf := self;
	
	foreach terminal in querySelf.allTerminals do
	
		iter := terminal.allOnsiteTIsByAlternativeId.createIterator;
		startAtObject := terminal.allOnsiteTIsByAlternativeId.getAtKeyGeq( altId );
		
		if startAtObject &lt;&gt; null then
			iter.startAtObject(startAtObject);
			while iter.next( ti ) do
				if ti.alternativeId &lt;&gt; altId then
					break;
				endif;
				if querySelf.checkStatusIncludesObject(ti, _passport, _breakOut) then
	
				if (not _collection.includes(ti)) then
					_collection.add(ti);
					self.doStats(ti);				
				endif;
			endif;
				
			endwhile;
		endif;
		
		delete iter;
	
	endforeach;

epilog

	delete iter;

end;</source>
        <access>protected</access>
        <Parameter name="_collection" type="Collection" usage="input"/>
        <Parameter name="_passport" type="CM_Passport"/>
        <Parameter name="_breakOut" type="Boolean" usage="output"/>
    </JadeMethod>
    <JadeMethod name="handlePrecisionError" id="0ab254fc-c575-4757-b21a-7db258f8f6a6">
        <source>handlePrecisionError(e : Exception; precisionError : Boolean io) : Integer;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
02 July 2010	cnwrd1	Initial creation

*/

vars

begin
	if e.errorCode = 4033 then
		precisionError := true;
		return Ex_Resume_Next;
	endif;
end;</source>
        <Parameter name="e" type="Exception"/>
        <Parameter name="precisionError" type="Boolean" usage="io"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="handleShippingLine" id="b9f474f2-9c1f-4659-99cb-d7a862badf64">
        <updating/>
        <source>handleShippingLine(_collection : Collection input; _passport : CM_Passport; _breakOut : Boolean output) protected, updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 May 2022	navak20	ChangeRequest 53204: EUP - GEN/REP/INB - Additional Cargo Field – Shipping Line - UI

*/

vars
	ti				: CM_TrackedItem;
	querySelf		: CMQF_TrackedItem;
begin

	if querySelf.checkStatusIncludesObject(ti, _passport, _breakOut) then
		if (not _collection.includes(ti)) then
			_collection.add(ti);
			self.doStats(ti);				
		endif;
	endif;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_collection" type="Collection" usage="input"/>
        <Parameter name="_passport" type="CM_Passport"/>
        <Parameter name="_breakOut" type="Boolean" usage="output"/>
    </JadeMethod>
    <JadeMethod name="handleTATypes" id="1efe1f29-cde3-47b8-9537-bb5c6f67c7a0">
        <updating/>
        <source>handleTATypes(_collection : Collection input; _passport : CM_Passport) protected, updating;
// ---------------------------------------------------------------------------
// Created:     24 October 2003	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	typeId					: Integer;
	taMaster				: CM_TerminalAreaMaster;
	taType					: CM_TerminalAreaType;
	taTypeDict				: CM_TATypeByTypeDict;
	breakOut				: Boolean;
begin

	taTypeDict := app.myRoot.allTerminalAreaTypes;
	foreach typeId in self.terminalAreaTypes do
		taType := taTypeDict[typeId];
		if taType = null then
			continue;
		endif;
		
		foreach taMaster in taType.allTerminalAreasByTerminal  discreteLock
		   where self.allTerminals.includes(taMaster.myTerminal) do
		   
			if (not CM_TerminalArea.hasInstance(taMaster)) then
				continue;
			endif;
			
			self.handleTerminalArea(taMaster.CM_TerminalArea, _collection, _passport, breakOut);
			if breakOut then
				break;
			endif;
		endforeach;
	endforeach;

end;</source>
        <access>protected</access>
        <Parameter name="_collection" type="Collection" usage="input"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="handleTIDict" id="badbb706-f96e-4c06-9902-a117a8417cb9">
        <updating/>
        <source>handleTIDict(_tiDict : Dictionary; 
			_collection : Collection input; 
			_passport : CM_Passport;
			_breakOut : Boolean output) protected, updating;
// ---------------------------------------------------------------------------
// Created:     24 October 2003	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	iter			: Iterator;
	ti				: CM_TrackedItem;
	querySelf		: CMQF_TrackedItem;
	haveIdCargoType,
	haveJustId,
	haveJustCargoType: Boolean;
	tmpCargoTypeId	: Integer;
	tmpId			: String;
begin
	if _tiDict = null then
		return;
	endif;
	
	querySelf := self;
	iter := _tiDict.Dictionary.createIterator;
	
	if self.getMyCargoType &lt;&gt; null then
		tmpCargoTypeId := self.getMyCargoType.id;
	endif;
	
	if self.id &lt;&gt; null then
		tmpId := self.id;
	endif;
	
	if tmpCargoTypeId &lt;&gt; null and
	   tmpId &lt;&gt; null then
		if _tiDict.isKindOf(CM_TIByCargoTypeIdDict) then
			haveIdCargoType := true;
			_tiDict.startKeyGeq(tmpCargoTypeId, tmpId, iter);
		elseif _tiDict.isKindOf(CM_TIByCargoTypeIdRelseDict) then
			haveIdCargoType := true;
			_tiDict.startKeyGeq(tmpCargoTypeId, tmpId, null, iter);
		else
			app.writeLog('Class:: ' &amp; class.name &amp; 'Method:: ' &amp; method.name &amp; ' Cargo and Id dictionary not found', LogINFO);
		endif;
	elseif tmpCargoTypeId = null and tmpId &lt;&gt; null then
		if _tiDict.isKindOf(CM_TIByIdCargoTypeDict) then
			haveJustId := true;
			_tiDict.startKeyGeq(tmpId, null, iter);
		elseif _tiDict.isKindOf(CM_TIByIdCargoTypeRelseDict) then
			haveJustId := true;
			_tiDict.startKeyGeq(tmpId, null, null, iter);
		else
			app.writeLog('Class:: ' &amp; class.name &amp; 'Method:: ' &amp; method.name &amp; ' Id ony dictionary not found', LogINFO);
		endif;
	elseif tmpCargoTypeId &lt;&gt; null and tmpId = null then
		if _tiDict.isKindOf(CM_TIByCargoTypeIdDict) then
			haveJustCargoType := true;
			_tiDict.startKeyGeq(tmpCargoTypeId, null, iter);
		elseif _tiDict.isKindOf(CM_TIByCargoTypeIdRelseDict) then
			haveJustCargoType := true;
			_tiDict.startKeyGeq(tmpCargoTypeId, null, null, iter);
		else
			app.writeLog('Class:: ' &amp; class.name &amp; 'Method:: ' &amp; method.name &amp; ' Cargo only dictionary not found', LogINFO);
		endif;
	endif;
	
	while iter.next(ti) do
		if haveIdCargoType and
		   (ti.cargoType &lt;&gt; tmpCargoTypeId or
		   (ti.id.pos(tmpId, 1) &lt;= 0)) then
			break;
		elseif haveJustId and
		   (ti.id.pos(tmpId, 1) &lt;= 0) then
			break;
		elseif haveJustCargoType and
			(ti.cargoType &lt;&gt; tmpCargoTypeId) then
			break;
		endif;
				
		if querySelf.checkStatusIncludesObject(ti, _passport, _breakOut) then
//		if querySelf.includesObject(ti, _passport, _breakOut) then

			if (not _collection.includes(ti)) then
				_collection.add(ti);
				self.doStats(ti);				
			endif;
		endif;

	endwhile;
	
epilog
	delete iter;
end;</source>
        <access>protected</access>
        <Parameter name="_tiDict" type="Dictionary"/>
        <Parameter name="_collection" type="Collection" usage="input"/>
        <Parameter name="_passport" type="CM_Passport"/>
        <Parameter name="_breakOut" type="Boolean" usage="output"/>
    </JadeMethod>
    <JadeMethod name="handleTerminalArea" id="9575c25f-60aa-4e09-964b-2f5fc7cf31ea">
        <updating/>
        <source>handleTerminalArea(_ta : CM_TerminalArea; 
					_collection : Collection input; 
					_passport : CM_Passport;
					_breakOut : Boolean output) protected, updating;
// ---------------------------------------------------------------------------
// Created:     24 October 2003	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	lc				: CM_LocationsController;
	breakOut		: Boolean;
begin
	if _ta = null then
		return;
	endif;
	
	foreach lc in _ta.allLocationsControllers discreteLock do
		self.handleLocationsController(lc, _collection, _passport, breakOut);
		if _breakOut then
			break;
		endif;
	endforeach;

end;</source>
        <access>protected</access>
        <Parameter name="_ta" type="CM_TerminalArea"/>
        <Parameter name="_collection" type="Collection" usage="input"/>
        <Parameter name="_passport" type="CM_Passport"/>
        <Parameter name="_breakOut" type="Boolean" usage="output"/>
    </JadeMethod>
    <JadeMethod name="handleTerminals" id="80ada1a2-308a-44d7-b947-49b7ebaae225">
        <updating/>
        <source>handleTerminals(_collection : Collection input; _passport : CM_Passport) protected, updating;
// ---------------------------------------------------------------------------
// Created:     24 October 2003	cnwth2
//
// Purpose:     
// 03.11.2025	navcs2	MTN-36231 IMT | Prenoted not available during creation of a new Cargo Report	 		 
// ----------   ----------  --------------------------------------------------
vars
	terminal			: CM_Terminal;
	termDict			: CM_TerminalByCodeDict;
	site				: Integer;
	tiDict 				: Dictionary;
	breakOut			: Boolean;
	opTerm				: CM_OperatorTerminal;
	tmpVoyage			: CM_Voyage;
	haveId				: Boolean;
	prenoteColl			: Collection;					//  03.11.2025	navcs2	MTN-36231
begin

	// Want id dicts if we only have id
	haveId := (self.id &lt;&gt; null and self.getMyCargoType = null);
	
	termDict := self.allTerminals;
	foreach terminal in termDict do : terminalLoop
		foreach site in self.allQrySites do
			if (self.myOperator &lt;&gt; null) then
				opTerm := terminal.allOperatorTerminals[self.myOperator];
				if opTerm &lt;&gt; null then
					tiDict := opTerm.getDictForTISite(site, haveId);
					if tiDict &lt;&gt; null then //jlier1 TFS 64470 5/6/24  - if onship won't return a dict so need to continue below
						self.handleTIDict(tiDict, _collection, _passport, breakOut);
						continue;
					endif;
				endif;
			endif;

			if site = TI_SITE_ONSHIP and self.getMyVoyage = null then
				// need to look through all voyages archived and non-archived
				//foreach tmpVoyage in terminal.allVoyages do
				foreach tmpVoyage in terminal.allVoyagesNew do
					tiDict := terminal.getDictForTISite(site, tmpVoyage, haveId, false);
					self.handleTIDict(tiDict, _collection, _passport, breakOut);
				endforeach;
				
				foreach tmpVoyage in terminal.allVoyagesArchived do
					tiDict := terminal.getDictForTISite(site, tmpVoyage, haveId, false);
					self.handleTIDict(tiDict, _collection, _passport, breakOut);
				endforeach;
			elseif site = SEL_QUERYSITE_NOTIFIED then												// 03.11.2025	navcs2	MTN-36231
				prenoteColl := terminal.getDictForTIState(TI_STATE_NOTIFIED, null, haveId, false);	// 03.11.2025	navcs2	MTN-36231
				tiDict := prenoteColl.Dictionary;													// 03.11.2025	navcs2	MTN-36231 
				self.handleTIDict(tiDict, _collection, _passport, breakOut);						// 03.11.2025	navcs2	MTN-36231 
			else
				tiDict := terminal.getDictForTISite(site, null, haveId, false);
				self.handleTIDict(tiDict, _collection, _passport, breakOut);
			endif;
			
			if breakOut then
				break terminalLoop;
			endif;
		endforeach;
	endforeach;

end;</source>
        <access>protected</access>
        <Parameter name="_collection" type="Collection" usage="input"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="handleVoyage" id="576906f3-285b-47c6-8f1c-b0f33053d793">
        <updating/>
        <source>handleVoyage(_voyage : CM_Voyage; _collection : Collection input; _passport : CM_Passport) protected, updating;
// ---------------------------------------------------------------------------
// Created:     24 October 2003	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	terminal		: CM_Terminal;
	site			: Integer;
	ti				: CM_TrackedItem;
	tiDict			: Dictionary;
	breakOut		: Boolean;
	haveId			: Boolean;
begin

	// Want id dicts if we only have id
	haveId := (self.id &lt;&gt; null and self.getMyCargoType = null);

	if _voyage = null then
		return;
	endif;
	
	foreach site in self.allQrySites do
		terminal := _voyage.myTerminal;
		if terminal = null then
			continue;
		endif;
		
		tiDict := terminal.getDictForTISite(site, _voyage, haveId, false);
		self.handleTIDict(tiDict, _collection, _passport, breakOut);
		if breakOut then
			break;
		endif;
	endforeach;
	
end;</source>
        <access>protected</access>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_collection" type="Collection" usage="input"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="includesObject" id="36c3a761-359f-40c8-ab04-8de4865cc78c">
        <updating/>
        <source>includesObject(_ti: CM_TrackedItem; _passport : CM_Passport; _breakOut : Boolean output): Boolean updating, protected;
// ---------------------------------------------------------------------------
// Created:     06 September 2002 by cnwth2
//
// Purpose:     
//
// ----------   ----------  --------------------------------------------------
// 21/07/2010	cnwdap1			PAR #25021 Correct tranship filtering
//30 May 2022	navak20		ChangeRequest 53204: EUP - GEN/REP/INB - Additional Cargo Field – Shipping Line - UI
// 23 August 2022	navak20	TFS ChangeRequest 54441: EUP - Additional Field - Country of Origin
vars
	tiImex					: CM_IMEXStatus;
	stopTable 				: CM_StopsTable;
	querySelf				: CMQF_TrackedItem;
	foundMatchingStop		: Boolean;
	failedDAC  :CM_DataAccessController;

begin
	querySelf := self;
	querySelf.numSearched := querySelf.numSearched + 1;
	
	if (not querySelf.allQryIMEXStatuses.isEmpty) then
		tiImex := _ti.getImExStatusObject();
		if tiImex &lt;&gt; null then
			if not querySelf.allQryIMEXStatuses.includesKey(tiImex.code) then
				return false;
			endif;
		endif;
	endif;

	if (not querySelf.allQryStopTables.isEmpty) then
		foreach stopTable in querySelf.allQryStopTables do
			if _ti.hasStopOfType(stopTable) then
				foundMatchingStop := true;
			endif;
		endforeach;
		if not foundMatchingStop then
			return false;
		endif;
	endif;
	
//if _ti.id = 'SHIP1112225' then
//	querySelf := querySelf;
//endif;

//if self.daysOnsite &gt; 0 then

//endif;

	if (querySelf.getMyVoyage = null or _ti.myVoyage = querySelf.getMyVoyage
		or (_ti.isTranshipItem and (_ti.myExportVoyage = querySelf.getMyVoyage) or (_ti.myImportVoyage = querySelf.getMyVoyage)))
	//th2 for PAR13833 - don't evaluate days onsite unless 1 or more.
	and (self.daysOnsite &lt; 1 or _ti.getNumDaysOnsiteJRW &gt;= self.daysOnsite)//CCMS 1504: Maersk Containers on Site Longer Than Seven Dates.
	and (querySelf.consignor = null or _ti.consignor = querySelf.consignor) 
	and (querySelf.myOperator = null or _ti.myOperator = querySelf.myOperator) 
	and (querySelf.getMyPort = null or app.myRoot.allPorts[_ti.dischargePort.trimBlanks] = querySelf.getMyPort)
	and (querySelf.getMyLoadPort = null or app.myRoot.allPorts[_ti.loadPort.trimBlanks] = querySelf.getMyLoadPort) 
	and (querySelf.getMyOperatorGroup = null or _ti.operatorBelongsToGrp(querySelf.getMyOperatorGroup)) 
	and (querySelf.getMyISOTypeGroup = null or _ti.isoTypeBelongsToGroup(querySelf.getMyISOTypeGroup)) 
	and	(querySelf.getMyCargoType = null or _ti.cargoType = querySelf.getMyCargoType.id)
	and	(querySelf.getMyProduct = null or _ti.productCode = querySelf.getMyProduct.code)
	and (querySelf.destinationPort = null or _ti.destinationPort = querySelf.destinationPort)
	and (querySelf.dischargePort = null or _ti.dischargePort = querySelf.dischargePort)
	and (querySelf.getMySubTerminal = null or _ti.mySubTerminal = querySelf.getMySubTerminal) //28/04/2009 cnwdz2 ccms1735
	and (querySelf.getMyBOL = null or _ti.billOfLading = querySelf.getMyBOL.number)	// 11 Nov 2010	NDL	Par 26055
	and	(querySelf.id = null or _ti.id.pos(querySelf.id, 1) = 1)
	//and (querySelf.includeTranships or not _ti.isTranshipItem)							// PAR #25021
	and ((querySelf.includeTranships and _ti.isTranshipItem) or not _ti.isTranshipItem)		// PAR #25021
	and (querySelf.alternativeId = null or _ti.alternativeId = querySelf.alternativeId)	//02 May 2013	NDL	Par 31506
	and (querySelf.getMyShippingLine = null or _ti.myShippingLine = querySelf.getMyShippingLine) 	// 30.05.2022 navak20 TFS 53204
	and (querySelf.getCountryOfOrigin = null or _ti.getCountryOfOriginCode = querySelf.getCountryOfOrigin().code)		// 23.08.2022 navak20 TFS 54441
	then
		if (not _ti.canUserAccessSelf(null, failedDAC, _passport)) then
			return false;
		endif;
		
		querySelf.numFound := querySelf.numFound + 1;
		return true;
	endif;
	
	return false;
end;</source>
        <access>protected</access>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_passport" type="CM_Passport"/>
        <Parameter name="_breakOut" type="Boolean" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
