    <JadeMethod name="getMachineCount" id="a4215761-e4d3-46c3-a1d1-2744573e9861">
        <source>getMachineCount() : Integer;
/*

Date		Who		Reason
20 January 2016	cnwer1	Initial creation PAR 37060

*/

vars
	vm : CM_VehicleMachine;
	count : Integer;
begin 
	foreach vm in  self.allVehicleMachines do
		if vm.isKindOf(CM_Machine) then
			count:=count + 1;
		endif;
	endforeach;
	
	return count;

epilog

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getName" id="321002d8-2224-4889-b420-8d3d3686f889">
        <source>getName(): String;
// ---------------------------------------------------------------------------
// Created:		August  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	returnStr		: String;
	
begin
	returnStr	:= 	inheritMethod();
	
	if myTerminal &lt;&gt; null then
		returnStr	:= returnStr &amp; Tab &amp; self.myTerminal.code.display;
	endif;
	
	returnStr	:= returnStr &amp; Tab &amp; self.terminalAreaId.display;
	
	return returnStr;
	
end;</source>
        <ReturnType type="String"/>
