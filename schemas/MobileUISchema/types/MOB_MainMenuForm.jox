    <JadeMethod name="checkButtonPermission" id="50dc9bd6-f233-496b-8396-3199eb5fbd86">
        <source>checkButtonPermission(_btn : Control input; _permission : Integer; _term : CM_Terminal;
					_buttons : CnEcControlArray input);

vars

begin
	if app.myCurrentUserCan(_term, _permission) then
		_buttons.add(_btn);
	else
		_btn.visible := false;
	endif;
end;
</source>
        <Parameter name="_btn" type="Control" usage="input"/>
        <Parameter name="_permission" type="Integer"/>
        <Parameter name="_term" type="CM_Terminal"/>
        <Parameter name="_buttons" type="CnEcControlArray" usage="input"/>
    </JadeMethod>
