        <source>setProxyFromObject(_resourceTypeGroup: CM_ResourceTypeGroup) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 November 2023	navpw1	Initial creation TFS: 58761 (60739)

*/

