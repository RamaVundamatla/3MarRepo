    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>
Holds the largest vertical,horizontal and depth proximity information
for a given hazard/rule mode. Used in ti.getLargestHazardArea</text>
    <DbClassMap file="terminal"/>
