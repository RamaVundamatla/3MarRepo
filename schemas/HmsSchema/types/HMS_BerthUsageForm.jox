    <JadeMethod name="includeObject" id="241af075-4f7a-434c-b1e3-2ec6b3849486">
        <source>includeObject(_voyage : CM_Voyage) : Boolean protected;
//--------------------------------------------------
// Created:	05 December 2005 By: cnwgd1
//--------------------------------------------------
vars
	tmpBerth : HMS_Berth;
begin
	if _voyage = null then
		return false;
	endif;
	
	if self.allBerths.size &gt; 0 then
		tmpBerth := _voyage.getMyBerth();
		if tmpBerth = null then
			return false;
		endif;
		if (not self.allBerths.includes(tmpBerth)) then
			return false;
		endif;
	endif;
	
	if _voyage.myHMSVoyageData = null then
		return false;
	endif;
	
	if (not self.includeIncompleteItinerary) then
		if (not _voyage.arrivedDT.isValid()) then
			return false;
		endif;
	endif;
	
	return true;
end;</source>
        <access>protected</access>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="initComboBoxes" id="213a2038-7260-4de5-885a-dd0afca950dd">
        <source>initComboBoxes() protected;
//--------------------------------------------------
// Created:	23 November 2005 By: cnwgd1
//--------------------------------------------------
vars
	cnt,
	idx,
	prevYear,
	tmpYear : Integer;
begin
	
	self.cmbMonth.sorted := false;
	self.cmbMonth.addItem('January');
	self.cmbMonth.addItem('February');
	self.cmbMonth.addItem('March');
	self.cmbMonth.addItem('April');
	self.cmbMonth.addItem('May');
	self.cmbMonth.addItem('June');
	self.cmbMonth.addItem('July');
	self.cmbMonth.addItem('August');
	self.cmbMonth.addItem('September');
	self.cmbMonth.addItem('October');
	self.cmbMonth.addItem('November');
	self.cmbMonth.addItem('December');

	self.cmbYear.sorted := false;
	tmpYear := app.actualTimeServer.date.year;
	prevYear := tmpYear-10;

	while tmpYear &gt;= prevYear do
		self.cmbYear.addItem(tmpYear.String);
		tmpYear := tmpYear-1;
		cnt := cnt + 1;		
		if cnt &gt; 20 then
			break;
		endif;
	endwhile;	
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="initControlsForView" id="f0d063ca-9cc1-48bf-9cc3-14b9d7b01364">
        <updating/>
        <source>initControlsForView() updating, protected;
//--------------------------------------------------
// Created:	23 November 2005 By: cnwgd1
//--------------------------------------------------
vars
	harbour : HMS_Harbour;
	index : Integer;
begin
	
	self.lstHarbours.clearTable();	
	self.lstTerminals.clearTable();		
	self.lstWharves.clearTable();		
	self.lstBerths.clearTable();
					
	//self.lstHarbours.displayCollection(app.myRoot.allHarbours, true, 0, self.myTerminal.myHarbour);
	//	09 Oct 2012	NDL	Par 30490
	foreach harbour in app.myRoot.allHarbours do
		self.lstHarbours.addItemObject(harbour.getDisplayString, harbour);
	endforeach;
	if self.myTerminal.myHarbour &lt;&gt; null then
		self.lstHarbours.findObjectInRow( self.myTerminal.myHarbour, index );
		if index &gt; 0 then
			self.lstHarbours.topRow := index;
		endif;
	endif;
	
	if (not app.myRoot.isMultiHarbour()) then
		self.lstHarbours.visible := false;
		self.lblHarbours.visible := false;
		self.btnAllHarbour.visible := false;
		self.doSelectAll(self.lstHarbours);
		self.lstTerminals.width := self.lstTerminals.width + self.lstHarbours.width+5;		
		self.lstTerminals.left := self.lstHarbours.left;
		self.lblTerminals.left := self.lstTerminals.left;						
	else
		self.lstHarbours.visible := true;
	endif;				
	
	if (not app.myRoot.isMultiTerminal()) then
		self.lstTerminals.visible := false;
		self.lblTerminals.visible := false;
		self.doSelectAll(self.lstTerminals);
		self.btnAllTerminals.visible := false;		
		self.lstHarbours.width := self.lstHarbours.width + self.lstTerminals.width+5;
	else
		self.lstTerminals.visible := true;
	endif;
	
	if (not self.lstTerminals.visible)
	and (not self.lstHarbours.visible) then
		self.grpHarbours.visible := false;
		self.grpWharves.top := self.grpHarbours.top;
		self.frmSearch.height := self.grpWharves.top + self.grpWharves.height+20;				
	endif;

	self.setFilterDefaults(true);
			
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="initTblData" id="8735dcea-9d9d-4b8d-8347-e6c8fbb3d5c5">
        <source>initTblData() protected;
//--------------------------------------------------
// Created:	23 November 2005 By: cnwgd1
//--------------------------------------------------
vars
	tableObj	: CM_DataTable;
	colPointer	: Integer;
	
begin
	tableObj	:=	self.tblData;
	
	tableObj.disallowColumnSorter	:=	true;
	tableObj.setTblDataEntRowsFromDef(app.myController.getEntTableDef(ETDef_BerthUsage));
	tableObj.sortColumn[1]	:=	null;

	tableObj.userInputEnabled	:=	false;
	tableObj.selectMode			:=	Table.SelectMode_CurrentRow;
	tableObj.selectionType		:=	CM_DataTable.SelectionType_Row;
	tableObj.multiSelect		:=	tableObj.MultiSelect_Simple;
	tableObj.stretchWidth		:=	true;
	tableObj.stretchHeight		:=	true;

// cnwdad1 30/03/2006 - PAR #11580.
//	tableObj.accessColumn(tableObj.getColumnByRowName(ETRow_Dockage)).alignment := Table.Alignment_Right_Middle;	
	colPointer	:=	tableObj.getColumnByRowName(ETRow_Dockage);
	
	if colPointer &gt; tableObj.fixedColumns and colPointer &lt;= tableObj.columns then
		tableObj.accessColumn(colPointer).alignment	:=	Table.Alignment_Right_Middle;
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="keyDown" id="0d5b4f2b-8633-4d9e-8e75-16070698002f">
        <controlMethod name="Form::keyDown"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>keyDown(keyCode: Integer io; shift: Integer) updating;
//--------------------------------------------------
// Created:	24 November 2005 By: cnwgd1
//--------------------------------------------------
vars

begin
	if keyCode = CMUI_Key_F3 then
		self.showHideSearcher();
	elseif keyCode = J_key_Enter then
		if self.frmSearch.visible then
			self.doSearch();
		endif;		
	else
		inheritMethod(keyCode, shift);
	endif;
end;</source>
        <Parameter name="keyCode" type="Integer" usage="io"/>
        <Parameter name="shift" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="loadDataForFirstTime" id="a9876c64-746c-4364-86ed-189dbeb5f457">
        <updating/>
        <source>loadDataForFirstTime() updating, protected;
//--------------------------------------------------
// Created:	23 November 2005 By: cnwgd1
//--------------------------------------------------
vars

begin
	inheritMethod();
	self.initComboBoxes();	
	self.initControlsForView();
	self.doResize(); // do before search to setup the graph sizes correctly	
	self.doSearch();
end;</source>
