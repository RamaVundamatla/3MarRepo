    <JadeMethod name="drawArea" id="89a2d040-6d50-47f0-80f4-d077c20e9bcb">
        <updating/>
        <source>drawArea() protected, updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
07 April 2010	cnwjk3	Initial creation

*/

vars
begin
	if  not self.isInitialised then
		app.raiseUnexpectedProgramError(class.name, method.name, "Drawing controller hasn't been initialised");
	endif;
	
	//self.calcDrawRows();
	self.calcGridDrawRowsUnflipped();

	//self.calcDrawCols();
	self.calcGridDrawColsUnflipped();
	if self.flipV then
		self.reCalcRowsForFlip();
	endif;
	if self.flipH then
		self.reCalcColsForFlip();
	endif;

	self.drawEverything();
epilog

end;</source>
