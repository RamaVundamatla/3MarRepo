// ---------------------------------------------------------------------------
// Created:     12 August 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	idx			: Integer;
	tmpSheet	: Sheet;
begin

	self.myForm.shtTblInput2.visible := false;
	// now have a multi-select box on this sheet as well
	self.myForm.mulSelIn21.visible := false;

	while true do
		idx := idx + 1;
		tmpSheet := self.myForm.shtTblInput2.getControl(idx);
		if tmpSheet = null then
			break;
		endif;
		tmpSheet.visible := false;
	endwhile;
	
end;</source>
