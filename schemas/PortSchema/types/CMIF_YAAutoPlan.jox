    <JadeMethod name="getMyTrackedItem" id="b0f00511-16ed-4fb0-a2b3-84ccddcdc484">
        <source>getMyTrackedItem() : CM_TrackedItem;
// -------------------------------------------
// Created 15 September 2005 by cnwdvb1
// -------------------------------------------
// 08/03/2011	cnwmh5	PAR #27142 - Change to local variable rather than self for handleDeleteObject exception
vars
	invalid: Boolean;
	ti	: CM_TrackedItem;
begin
	ti := self.myTrackedItem;
	if ti = null then
		return null;
	endif;
	on Exception do app.handleDeletedObject(exception, ti, invalid); 
	ti.edition;
	if invalid then
		return null;
	endif;
	
	return ti;
end;</source>
        <ReturnType type="CM_TrackedItem"/>
    </JadeMethod>
