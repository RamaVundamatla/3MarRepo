    <JadeMethod name="setForCreate" id="7b0f344c-6083-49c8-b393-f909a1b405d6">
        <updating/>
        <source>setForCreate(_pxyTCPConnectionDetails : CM_DeviceTCPConnectionDetails; _device : CM_RadioTelemetryDevice) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 August 2016	cnwrh7	Initial creation

*/

vars

begin
	_pxyTCPConnectionDetails.raiseExceptionIfNotTransient(method);
	
	self.setForUpdate(_pxyTCPConnectionDetails);
	if _device &lt;&gt; null then
		self.myRTDevice := _device;
	endif;
	
epilog

end;</source>
        <Parameter name="_pxyTCPConnectionDetails" type="CM_DeviceTCPConnectionDetails"/>
        <Parameter name="_device" type="CM_RadioTelemetryDevice"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="52ed7d7f-a4a5-4538-b21f-6f94b0f0fc6b">
        <updating/>
        <source>setForUpdate(_pxyTCPConnectinDetails : CM_DeviceTCPConnectionDetails) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 August 2016	cnwrh7	Initial creation

*/

vars

begin
	self.tcpAddress := _pxyTCPConnectinDetails.tcpAddress;
	self.tcpPortNumber := _pxyTCPConnectinDetails.tcpPortNumber;
	self.tcpTimeOut := _pxyTCPConnectinDetails.tcpTimeOut;
	self.tcpDeviceType := _pxyTCPConnectinDetails.tcpDeviceType;
	self.useTCPPresentationClient := _pxyTCPConnectinDetails.useTCPPresentationClient;
epilog

end;</source>
        <Parameter name="_pxyTCPConnectinDetails" type="CM_DeviceTCPConnectionDetails"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="1688822f-14aa-47b2-9856-d2c63362b4ae">
        <updating/>
        <source>setProxy(_tcpAddress : String;
					_tcpPortNumb,
					_tcpTimeout,
					_tcpDeviceType : Integer;
					_usePresentationClient : Boolean) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 August 2016	cnwrh7	Initial creation

*/

vars

begin
	self.raiseExceptionIfNotTransient(method);
	self.tcpAddress := _tcpAddress;
	self.tcpPortNumber := _tcpPortNumb;
	self.tcpTimeOut := _tcpTimeout;
	self.tcpDeviceType := _tcpDeviceType;
	self.useTCPPresentationClient := _usePresentationClient;
epilog

end;</source>
        <Parameter name="_tcpAddress" type="String"/>
        <Parameter name="_tcpPortNumb" type="Integer"/>
        <Parameter name="_tcpTimeout" type="Integer"/>
