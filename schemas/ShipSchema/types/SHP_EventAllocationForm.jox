    <JadeMethod name="setupForm" id="76aa6889-055c-4171-b0bb-d3ff3ce1a2f7">
        <updating/>
        <source>setupForm() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 January 2017	cnwns1	Initial creation

*/

vars

begin


	inheritMethod();
	
	
	
	self.populateForm();
	
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		self.btnSave.enabled:= false;
		self.btnCopyFromGroup.enabled:= false;
		self.mulColumns.readOnly := true;
	endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="translateForm" id="6f80975d-e915-45fc-aee2-caf38aa5e305">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 15 June 2017 09:47:05.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0021751, locale);
	btnClose.translateCaption(Xlat_0021752, locale);
	btnCopyFromGroup.translateCaption(Xlat_0021753, locale);
	btnSave.translateCaption(Xlat_0021754, locale);
	lblVessel.translateCaption(Xlat_0021755, locale);
	lblVoyage.translateCaption(Xlat_0021756, locale);
end;</source>
    </JadeMethod>
</GUIClass>
