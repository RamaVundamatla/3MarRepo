    <JadeMethod name="getForm" id="93d266b4-3ae7-48fa-b9e3-ff4703ab4eb9">
        <source>getForm() : Form;
// ---------------------------------------------------------------------------
// Created:		January 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
begin
	if self.myDockBar = null then
		return null;
	endif;
