    <JadeMethod name="setForCreate" id="4d35acbf-3de2-41dc-aae1-0bf956274d59">
        <updating/>
        <source>setForCreate(_proxy : CM_Building input; _passport : CM_Passport input) updating;
//setForCreate(_proxy : CM_Building; _passport : CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:		July 2001 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 23/06/2009	concms1		ccms 1061 - Changed method signature to use proxy rather than controller
// ---------------------------------------------------------------------------


vars
	
begin
	_proxy.raiseExceptionIfNotTransient(method);
	self.raiseExceptionIfTransient(method);
	
	self.rows := _proxy.rows;
	self.cols := _proxy.cols;
	
	inheritMethod(_proxy, _passport);

end;</source>
        <Parameter name="_proxy" type="CM_Building" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="ddbb6db1-2efb-4498-9950-84fc90a9804b">
        <updating/>
        <source>setForUpdate(_proxy :CM_Building) updating;
//setForUpdate(_proxy : CM_Building) updating;
// ---------------------------------------------------------------------------
// Created:		July 2001 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	
begin
	_proxy.raiseExceptionIfNotTransient(method);
	self.raiseExceptionIfTransient(method);

	self.type 		:= _proxy.type;
	self.rows 		:= _proxy.rows;
	self.cols 		:= _proxy.cols;
	
	inheritMethod(_proxy);
	
end;</source>
        <Parameter name="_proxy" type="CM_Building"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="b4723933-d3cf-488a-98b3-cc0fbcca7a74">
        <updating/>
        <source>setProxy(pID,
		 pComment		: String; 
		 pType 			: Integer;
		 pTypeString 	: String;
		 pRows 			: Integer;
		 pCols 			: Integer;
		 pTerm			: CM_Terminal;
		 _stockControlled : Boolean;
		_hideFromOverView : Boolean;
		_allInterchangeAreas	:CM_InterchangeAreaArray;	// par 24292
		_defaultInterchangeArea: CM_InterchangeArea) updating;
// ---------------------------------------------------------------------------
// Created:		July 2001 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 26/05/2010		cnwcs5	par 24292 - change _allInterchangeAreas parameter from set to array
vars
	i : Integer;
	lLabels : String;
begin
	self.raiseExceptionIfNotTransient(method);
	setProxyTerminalArea(pID, pComment, pType, false, pTerm, false, _stockControlled, _hideFromOverView, _allInterchangeAreas,_defaultInterchangeArea);
	self.rows := pRows;
	self.cols := pCols;
	

end;</source>
        <Parameter name="pID" type="String"/>
        <Parameter name="pComment" type="String"/>
        <Parameter name="pType" type="Integer"/>
        <Parameter name="pTypeString" type="String"/>
        <Parameter name="pRows" type="Integer"/>
        <Parameter name="pCols" type="Integer"/>
        <Parameter name="pTerm" type="CM_Terminal"/>
        <Parameter name="_stockControlled" type="Boolean"/>
        <Parameter name="_hideFromOverView" type="Boolean"/>
        <Parameter name="_allInterchangeAreas" type="CM_InterchangeAreaArray"/>
        <Parameter name="_defaultInterchangeArea" type="CM_InterchangeArea"/>
    </JadeMethod>
