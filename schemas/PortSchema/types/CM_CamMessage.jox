    <JadeMethod name="create" id="be8157ec-a088-42ed-add5-833514b26145">
        <updating/>
        <source>create() updating;
/*
Date		Who		Reason
17 Dec 2012	cnwcs5	Initial creation - par 30855
19 Aug 2022	jlger1	TFS 54478 - changed to StringArray with Jade increasing length of strings in - to fix 1035
*/
vars
	dd 		:DynaDictionary;
begin
	dd	:= self.allCAMSInfoDetails;
	
	dd.setMembership (StringArray);
	
	dd.addExternalKey (CM_TITransaction, null, null, null);
	// could probably make it no duplicates
	dd.endKeys (true);
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="delete" id="7b9d4425-749d-48e6-a15a-6c69f1a01f56">
        <updating/>
        <source>delete() updating;
/*
Date		Who		Reason
14 Dec 2012	cnwcs5	Initial creation - par 30855/ CCMS SFW 1294
*/
vars
	dd	:DynaDictionary;
begin
	dd := self.allCAMSInfoDetails;
	
	dd.purge;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setupCAMSInfoDetails" id="75aefdab-5050-490c-9a5f-f910b6f55583">
        <updating/>
        <source>setupCAMSInfoDetails(_camProtocol	: CM_CamProtocol; _arrayPos3, _arrayPos4, _arrayPos5 : Integer; _trx :CM_TITransaction) updating;
//
//12 Jul 2012	cnwrs1	CCMS 1269 CAMS reduce number of Trxs
//18 Jul 2012	cnwrs1	CCMS 1269 CAMS remove CM_CamTask - from CM_CamTask
//03 Feb 2013	cnwcs5 	CCMS SFW 1294 /par 30855 - moved from CM_CamControllerAgent.  Use collection on receiver.
//												 - renamed (was setupCamTiMessages)
//19 Aug 2022	jlger1	TFS 54478 - changed to StringArray with Jade increasing length of strings in - to fix 1035
vars
	trx			: CM_TITransaction;
	idx, size	: Integer;
	coll		: StringArray; 
	group		: HugeStringArray;
begin
	trx := _trx;
	
	// if we created output using proxy for edit transactions then use real trx as key
	if trx.pxyIsProxy then
		trx := trx.pxyGetRealObject;
	endif;
	
	// The tiMessages should only be cleared on change of transaction not just messageType
	coll := self.allCAMSInfoDetails[trx].StringArray;
	
	if coll = null then
		create coll transient;
		
		self.allCAMSInfoDetails [trx] := coll;
	endif;
	
	group 	:= self.group3;
	size	:= group.size;
	
	if group.size &gt; _arrayPos3 then
		foreach idx in _arrayPos3 + 1 to size do
			coll.add(group[idx]);
		endforeach;
	endif;
	
	group 	:= self.group4;
	size	:= group.size;

	if size &gt; _arrayPos4 then
		foreach idx in _arrayPos4 + 1 to size do
			coll.add(group[idx]);
		endforeach;
	endif;
	
	group 	:= self.group5;
	size	:= group.size;

	if size &gt; _arrayPos5 then
		foreach idx in _arrayPos5 + 1 to size do
			coll.add(group[idx]);
		endforeach;
	endif;
end;
</source>
        <Parameter name="_camProtocol" type="CM_CamProtocol"/>
        <Parameter name="_arrayPos3" type="Integer"/>
        <Parameter name="_arrayPos4" type="Integer"/>
        <Parameter name="_arrayPos5" type="Integer"/>
        <Parameter name="_trx" type="CM_TITransaction"/>
    </JadeMethod>
    <JadeMethod name="setupCAMSInfoDetailsStr" id="7164f13e-9590-44a4-8434-05e7c5ba8e8a">
        <updating/>
        <source>setupCAMSInfoDetailsStr(_camProtocol : CM_CamProtocol; _message :String; _trx :CM_TITransaction) updating;
//
//05 Feb 2013	cnwcs5 	Inital creation CCMS SFW 1294 /par 30855
//19 Aug 2022	jlger1	TFS 54478 - changed to StringArray with Jade increasing length of strings in - to fix 1035
vars
	coll		: StringArray; 
begin
	// The tiMessages should only be cleared on change of transaction not just messageType
	coll := self.allCAMSInfoDetails[_trx].StringArray;
	
	if coll = null then
		create coll transient;
		
		self.allCAMSInfoDetails [_trx] := coll;
	endif;
	
	coll.add (_message);
end;
</source>
        <Parameter name="_camProtocol" type="CM_CamProtocol"/>
        <Parameter name="_message" type="String"/>
        <Parameter name="_trx" type="CM_TITransaction"/>
    </JadeMethod>
</Class>
