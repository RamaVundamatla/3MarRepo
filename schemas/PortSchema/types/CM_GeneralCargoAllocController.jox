    <JadeMethod name="getCapacityPC" id="9da90743-e9f3-42ac-a514-6049d7fb1046">
        <source>getCapacityPC(_mode: Integer): Integer;

/*

Purpose:		TFS 49959	

Parameters:			

Return Value:		


Date		Who		Reason
04 December 2020	jlgab1	Initial creation

*/

vars
	capacity, capacityPC, totQty : Integer;
	array : CM_TIArray; 
	ti : CM_TrackedItem;
begin

	capacity := self.getCurrentCapacity();
	if capacity = 0 then
		return 0;
	endif;
	
	create array transient;
	self.getTIs(array, _mode, true);
	foreach ti in array discreteLock do
		totQty := totQty + ti.totalQuantity;
	endforeach;
	
	capacityPC := ((totQty / capacity) * 100).Integer;

	return capacityPC;
epilog
	delete array;
end;</source>
        <Parameter name="_mode" type="Integer"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getColumnsInAllocation" id="e013f324-8697-4de2-b587-7511e069662a">
        <source>getColumnsInAllocation() : Integer;
//
// Purpose:			
