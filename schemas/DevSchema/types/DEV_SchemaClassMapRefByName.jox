<CollClass name="DEV_SchemaClassMapRefByName" id="4b3a11b9-5c14-4f29-91d4-5ac5d388fd5a">
    <loadFactor>66</loadFactor>
    <memberType name="DEV_ClassMapReference"/>
    <superclass name="CM_MemberKeyDictionary"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="dev"/>
    <MemberKey>
        <property name="DEV_ClassMapReference::mapFileName"/>
        <caseInsensitive/>
        <sortOrder>-1</sortOrder>
    </MemberKey>
    <MemberKey>
        <property name="DEV_SchemaObjectEntity::name"/>
        <caseInsensitive/>
        <sortOrder>-1</sortOrder>
    </MemberKey>
    <JadeMethod name="display" id="48dd33a7-bf0b-40e1-bc8a-f3606bd2e866">
        <source>display(): String;
/*

Purpose:			Make viewing map file info a little nicer in the inspector

Parameters:			

Return Value:		

Date				Who		Reason
14 November 2021	navmd1	Initial creation TFS 52202

*/

vars
	str 			: String;
	currentMapFile	: String;
	value			: DEV_ClassMapReference;
begin
	str := "size = " &amp; self.size.String &amp; CrLf &amp; "(" &amp; CrLf;
	
	foreach value in self do
		if value.mapFileName &lt;&gt; currentMapFile then
			currentMapFile := value.mapFileName;
			str &amp;= "[" &amp; currentMapFile &amp; "]" &amp; CrLf;
		endif;
		str &amp;= Tab &amp; value.name &amp; CrLf;
	endforeach;
	
	str &amp;= ")";
	
	return str;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
</CollClass>
