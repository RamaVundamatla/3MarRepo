    <JadeMethod name="isComplete" id="23b5b0fd-486e-4a54-9c99-4eeee30a1e95">
        <methodInvocation>mapping</methodInvocation>
        <source>isComplete(set: Boolean; _value: Boolean io) mapping;
// ---------------------------------------------------------------------------
// Created:     08 March 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	toDoTask	: CM_ToDoTask;
begin

	if set then
		app.raiseSetVirtualError(class.name, method.name);
		return;
	endif;

	_value := true;
	
	foreach	toDoTask in self.allToDoTasks do
		if toDoTask.status = STATUS_TODO then
			_value := false;
			break;
		endif;
	endforeach;

end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="Boolean" usage="io"/>
    </JadeMethod>
