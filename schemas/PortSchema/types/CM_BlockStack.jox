    <JadeMethod name="autoPlan" id="c8a8112c-576f-4d73-a37c-b29602d1edf7">
        <updating/>
        <source>autoPlan(theAutoMovePlan: CMIF_AutoMovePlan input; theAttributeArea: CM_AttributeArea input) updating;
// ---------------------------------------------------------------------------
// Created:		May 2002 By Andrew Bishop cnwab1
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 24/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
// ---------------------------------------------------------------------------
vars
	lc	:CM_LocationsController;
	numInColl : Integer;
	locnId	:	String;
	extraMsg : String;
	firstEntry : Boolean;

begin
	//------------
	//theAutoMovePlan.addLogEntry("Testing Terminal Area " &amp; self.id &amp; extraMsg, IsForLogging);
	theAutoMovePlan.addLogEntry(app.getErrorString1(Testing_terminal_area, self.id), IsForLogging, Testing_terminal_area);

	// ###########################################

	firstEntry := true;
	if not app.isTerminalAutoPlanningEnabled() then   //SFW1030 04/08/2008
		theAutoMovePlan.updateController(null);
		return;
	endif;

	if theAutoMovePlan.myTrackedItem = null then
		app.raiseCMException1(ERR_NO_OBJECT, "No TI Reference", null, null);
		return;		
	endif;
	//---------------
	//Iterate through all the LC's in this list, test each one
	//---------------
	numInColl := theAttributeArea.allLocationControllers.size;
	if numInColl = 0 then
		/* Andrew and Steve changed this so that 96/2000 fault from Ponty is fixed, line below was added to ensure that the
		   autoplan continues with the next Attribute Area */
		theAutoMovePlan.updateController( null);
		//theAutoMovePlan.addLogEntry("No Locations to search in Attribute Area: " &amp; theAttributeArea.restrictedTermAreaId &amp; " , continuing with next Area." , IsForLogging); //- cnwmd1, Par 20524
		theAutoMovePlan.addLogEntry(app.getErrorString1(Locat_searc_attri_area_conti_w, theAttributeArea.restrictedTermAreaId) , IsForLogging, Locat_searc_attri_area_conti_w);
		return;
	endif;

	lc := self.myLocationsController;
	locnId := lc.getFullId &amp; theAutoMovePlan.iteration.String;
	//theAutoMovePlan.addLogEntry("Testing : " &amp; self.id , IsForLogging);
	theAutoMovePlan.addLogEntry(app.getErrorString1(Testing, self.id) , IsForLogging, Testing);

	//-------------
	//Test this LC and see if it meets the criteria in the autoplan
	//-------------
	lc.testAutoPlan(theAutoMovePlan);		//Test this lc against the autoplan criteria

end;</source>
        <Parameter name="theAutoMovePlan" type="CMIF_AutoMovePlan" usage="input"/>
        <Parameter name="theAttributeArea" type="CM_AttributeArea" usage="input"/>
    </JadeMethod>
    <JadeMethod name="availableLocationsForType" id="e1fdead4-da2c-478f-a74c-af7ea77b3572">
        <source>availableLocationsForType(_cmifSearchTypes: CMIF_SearchTypes; _locationsArray: Collection input);
// ---------------------------------------------------------------------------
// Created:     17 July 2002 by cnwth2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	inheritMethod(_cmifSearchTypes, _locationsArray);

end;</source>
        <Parameter name="_cmifSearchTypes" type="CMIF_SearchTypes"/>
        <Parameter name="_locationsArray" type="Collection" usage="input"/>
    </JadeMethod>
    <JadeMethod name="buildLocationStatistics" id="745b8e67-5e0c-4fb0-9d2a-a9a02b82f593">
        <source>buildLocationStatistics();
// --------------------------------------------------------------------------------
// Created:		19 Janurary 2010 by cnwjo3
//
// Purpose:		Build statistics for BlockStacks.  par 21189
//
vars
	c20Free				: Integer;
	c20PlannedIn		: Integer;
	c20PlannedOut		: Integer;
	c20Projected		: Integer;
	c20QueuedIn			: Integer;
	c20QueuedOut		: Integer;
	c20Total			: Integer;
	c20Used				: Integer;
	c30Free				: Integer;
	c30PlannedIn		: Integer;
	c30PlannedOut		: Integer;
	c30Projected		: Integer;
	c30QueuedIn			: Integer;
	c30QueuedOut		: Integer;
	c30Total			: Integer;
	c30Used				: Integer;
	c40Free				: Integer;
	c40PlannedIn		: Integer;
	c40PlannedOut		: Integer;
	c40Projected		: Integer;
	c40QueuedIn			: Integer;
	c40QueuedOut		: Integer;
	c40Total			: Integer;
	c40Used				: Integer;
	c45Free				: Integer;
	c45PlannedIn		: Integer;
	c45PlannedOut		: Integer;
	c45Projected		: Integer;
	c45QueuedIn			: Integer;
	c45QueuedOut		: Integer;
	c45Total			: Integer;
	c45Used				: Integer;
	c53Free				: Integer;
	c53PlannedIn		: Integer;
	c53PlannedOut		: Integer;
	c53Projected		: Integer;
	c53QueuedIn			: Integer;
	c53QueuedOut		: Integer;
	c53Total			: Integer;
	c53Used				: Integer;
	statisticsObj		: CM_LocationStatistics;
	proxyStatsObj		: CM_LocationStatistics;
	taStatsObj			: CM_LocationStatistics;
	fm					: CM_FutureMove;
	fmq					: CM_FutureMoveQueued;
	fmp					: CM_FutureMovePlanned;
	ti					: CM_TrackedItem;
	
	tmpTI				: CM_TrackedItem;
	gcQueuedOut			: Integer;
	gcPlannedOut		: Integer;
	gcQueuedIn			: Integer;
	gcPlannedIn			: Integer;
	container			: CM_Container;
	invalidTi			: Boolean;
begin
	if self.myLocationStatistics = null then
		create proxyStatsObj transient;
		proxyStatsObj.setParent(self);
		create statisticsObj  persistent;
		statisticsObj.setupForCreate(proxyStatsObj);
	else
		statisticsObj	:=	self.myLocationStatistics;
	endif;
	
	taStatsObj := self.myLocationStatistics;

	exclusiveLock(self.myLocationStatistics);
	self.myLocationStatistics.clearSystemCounts();  //clear values so we can start a fresh
	
	on Exception do app.handleDeletedObject(exception, ti, invalidTi); //+ cnwmd1 Par 26125
	
	//count all TIs being queued out of the area
	foreach ti in self.myLocationsController.allTrackedItems discreteLock do
		if ti.myPrimaryQueuedLocation &lt;&gt; null then
			if ti.myPrimaryQueuedLocation.myTerminalArea &lt;&gt; self then
				if ti.isKindOf(CM_Container) then
					container := ti.CM_Container;
					if container.is20 then
						c20QueuedOut := c20QueuedOut + 1;
					elseif container.is30 then
						c30QueuedOut := c30QueuedOut + 1;
					elseif container.is40 then
						c40QueuedOut := c40QueuedOut + 1;
					elseif container.is45 then
						c45QueuedOut := c45QueuedOut + 1;
					elseif container.is53 then
						c53QueuedOut := c53QueuedOut + 1;
					endif;
				else
					gcQueuedOut := gcQueuedOut + 1;
				endif;
			endif;
		endif;
		
		
		//count all TIs being planned out of the area
		if ti.myPrimaryPlannedLocation &lt;&gt; null then
			if ti.myPrimaryPlannedLocation.myTerminalArea &lt;&gt; self then
				if ti.isKindOf(CM_Container) then
					container := ti.CM_Container;
					if container.is20 then
						c20PlannedOut := c20PlannedOut + 1;
					elseif container.is30 then
						c30PlannedOut := c30PlannedOut + 1;
					elseif container.is40 then
						c40PlannedOut := c40PlannedOut + 1;
					elseif container.is45 then
						c45PlannedOut := c45PlannedOut + 1;
					elseif container.is53 then
						c53PlannedOut := c53PlannedOut + 1;
					endif;
				else
					gcPlannedOut := gcPlannedOut + 1;
				endif;
			endif;
		endif;
	endforeach;
	
	
	//count all TIs being queued in to the area
	foreach fm in self.myLocationsController.allQueuedFutureMoves discreteLock do
		if fm.isKindOf(CM_FutureMoveQueued) then
			fmq := fm.CM_FutureMoveQueued;
			ti := fmq.myTrackedItem;
			if ti.isKindOf(CM_Container) then
				container := ti.CM_Container;
				if container.is20 then
					c20QueuedIn := c20QueuedIn + 1;
				elseif container.is30 then
					c30QueuedIn := c30QueuedIn + 1;
				elseif container.is40 then
					c40QueuedIn := c40QueuedIn + 1;
				elseif container.is45 then
					c45QueuedIn := c45QueuedIn + 1;
				elseif container.is53 then
					c53QueuedIn := c53QueuedIn + 1;
				endif;
			else
				gcQueuedIn := gcQueuedIn + 1;
			endif;
		endif;
	endforeach;

	
	//count all TIs being planned in to the area
	foreach fm in self.myLocationsController.allPlannedFutureMoves discreteLock do
		if fm.isKindOf(CM_FutureMovePlanned) then
			fmp := fm.CM_FutureMovePlanned;
			ti := fmp.myTrackedItem;
			if ti.isKindOf(CM_Container) then
				container := ti.CM_Container;
				if container.is20 then
					c20PlannedIn := c20PlannedIn + 1;
				elseif container.is30 then
					c30PlannedIn := c30PlannedIn + 1;
				elseif container.is40 then
					c40PlannedIn := c40PlannedIn + 1;
				elseif container.is45 then
					c45PlannedIn := c45PlannedIn + 1;
				elseif container.is53 then
					c53PlannedIn := c53PlannedIn + 1;
				endif;
			else
				gcPlannedIn := gcPlannedIn + 1;
			endif;
		endif;
	endforeach;	

	
	//count all TIs in the current block stack
	foreach ti in self.myLocationsController.allTrackedItems discreteLock do
		if ti.isKindOf(CM_Container) then
			container := ti.CM_Container;
			if container.is20 then
				c20Used := c20Used + 1;
			elseif container.is30 then
				c30Used := c30Used + 1;
			elseif container.is40 then
				c40Used := c40Used + 1;
			elseif container.is45 then
				c45Used := c45Used + 1;
			elseif container.is53 then
				c53Used := c53Used + 1;
			endif;
		endif;
	endforeach;
	
	statisticsObj.c20PlannedIn	:=	c20PlannedIn;
	statisticsObj.c20PlannedOut	:=	c20PlannedOut;
	statisticsObj.c20Projected	:=	c20Projected;
	statisticsObj.c20QueuedIn	:=	c20QueuedIn;
	statisticsObj.c20QueuedOut	:=	c20QueuedOut;
	statisticsObj.c20Total		:=	c20Total;
	statisticsObj.c20Used		:=	c20Used;
	statisticsObj.c20Free		:=	c20Free;
	statisticsObj.c30Free		:=	c30Free;
	statisticsObj.c30PlannedIn	:=	c30PlannedIn;
	statisticsObj.c30PlannedOut	:=	c30PlannedOut;
	statisticsObj.c30Projected	:=	c30Projected;
	statisticsObj.c30QueuedIn	:=	c30QueuedIn;
	statisticsObj.c30QueuedOut	:=	c30QueuedOut;
	statisticsObj.c30Total		:=	c30Total;
	statisticsObj.c30Used		:=	c30Used;
	statisticsObj.c40Free		:=	c40Free;
	statisticsObj.c40PlannedIn	:=	c40PlannedIn;
	statisticsObj.c40PlannedOut	:=	c40PlannedOut;
	statisticsObj.c40Projected	:=	c40Projected;
	statisticsObj.c40QueuedIn	:=	c40QueuedIn;
	statisticsObj.c40QueuedOut	:=	c40QueuedOut;
	statisticsObj.c40Total		:=	c40Total;
	statisticsObj.c40Used		:=	c40Used;
	statisticsObj.c45Free		:=	c45Free;
	statisticsObj.c45PlannedIn	:=	c45PlannedIn;
	statisticsObj.c45PlannedOut	:=	c45PlannedOut;
	statisticsObj.c45Projected	:=	c45Projected;
	statisticsObj.c45QueuedIn	:=	c45QueuedIn;
	statisticsObj.c45QueuedOut	:=	c45QueuedOut;
	statisticsObj.c45Total		:=	c45Total;
	statisticsObj.c45Used		:=	c45Used;
	statisticsObj.c53Free		:=	c53Free;
	statisticsObj.c53PlannedIn	:=	c53PlannedIn;
	statisticsObj.c53PlannedOut	:=	c53PlannedOut;
	statisticsObj.c53Projected	:=	c53Projected;
	statisticsObj.c53QueuedIn	:=	c53QueuedIn;
	statisticsObj.c53QueuedOut	:=	c53QueuedOut;
	statisticsObj.c53Total		:=	c53Total;
	statisticsObj.c53Used		:=	c53Used;
	
	statisticsObj.total := self.maxCapacity;
	//statisticsObj.used := self.myLocationsController.getTrackedItemCount;	//cnwrd1 31736 break bulk counting
	//	15 Apr 2015	NDL	Par 35969 - Don't include Break-Bulk
	statisticsObj.used := c20Used + c30Used + c40Used + c45Used + c53Used;
	
	statisticsObj.queuedIn := c20QueuedIn + c30QueuedIn + c40QueuedIn + c45QueuedIn + c53QueuedIn + gcQueuedIn;
	statisticsObj.queuedOut := c20QueuedOut + c30QueuedOut + c40QueuedOut + c45QueuedOut + c53QueuedOut + gcQueuedOut;
	statisticsObj.free := statisticsObj.total-statisticsObj.used;
	if statisticsObj.free &lt; 0 then     // KEA2
		statisticsObj.free := -1;	// This signals that we do not know how much space is free
	endif;
	statisticsObj.plannedIn := c20PlannedIn + c30PlannedIn + c40PlannedIn + c45PlannedIn + c53PlannedIn + gcPlannedIn;
	statisticsObj.plannedOut := c20PlannedOut + c30PlannedOut + c40PlannedOut + c45PlannedOut + c53PlannedOut + gcPlannedOut;
	
	self.myLocationStatistics.setUpdateTimestamp();
epilog
	delete proxyStatsObj;
end;</source>
    </JadeMethod>
    <JadeMethod name="calculateFIFODate" id="8b75839f-8191-407d-a90a-801677e556b4">
        <updating/>
        <source>calculateFIFODate() updating;
//Updates the date of the TI's in this stack. If NO TI's, sets the date to
//Today. Called from the MOVE methods whenever something comes/goes.
begin
	self.effectiveFIFODate := self.myLocationsController.calculateFIFODate;
end;</source>
    </JadeMethod>
    <JadeMethod name="canBeStockControlled" id="138dc8ed-c7a3-4ad2-b12a-476aa2b4c970">
        <source>canBeStockControlled(): Boolean;
// ---------------------------------------------------------------------------
// Created:     04 May 2006 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin
	return true;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="createLC" id="4cfcb180-e149-4b0a-8627-a55f5af0afa1">
        <updating/>
        <source>createLC() : CM_BlockController updating;

vars
 	aLCProxy, aLC : CM_BlockController;
begin

	exclusiveLock(self);
	if self.allLocationsControllers.size &gt; 1 then
	  	//A controller already exists! Can only be 1!!!!
		app.setContinueCMExceptions(false);
		app.raiseCMException(ERR_CURR_BLOCK_CONT, null, null);
		return null;
	elseif self.allLocationsControllers.isEmpty then
		//	aLC.myTerminalArea := self;
		//aLC.setForCreate(self, (self.type = TA_TYPE_REPAIR or self.type = TA_TYPE_PTI));
		create aLCProxy transient;
		create aLC;
		aLCProxy.setProxy(self);
		aLC.setForCreate(aLCProxy, self);
	endif;

epilog
	if aLCProxy &lt;&gt; null then
		delete aLCProxy;
	endif;

end;</source>
        <ReturnType type="CM_BlockController"/>
    </JadeMethod>
    <JadeMethod name="createQuickCargo" id="2977f973-4fa7-41ab-afbd-f195112c4a86">
        <updating/>
        <source>createQuickCargo(_numItems : Integer; _is40 : Boolean) updating;
// ---------------------------------------------------------------------------
// Created:     05 Sept 2010 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

	aTerm : CM_Terminal;
	aRoot : CM_Root;
	aVoy : CM_Voyage;
	realTI,
	pxyTI			: CM_TrackedItem;
	cargoType		: CM_CargoType;
	passport		: CM_Passport;
	moveController	: CMIF_MoveController;
	state			: Integer;
	slot : CM_LocationsController;
	tmpID : String;
	subT : CM_SubTerminal;
	idx : Integer;
begin


	aTerm := self.myTerminal;
	aVoy	:= aTerm.getNullVoyage();
 
	//lets make cargo
	passport := app.myPassport;
	passport.setMyTerminal(aTerm);
	cargoType	:= app.myRoot.allCargoTypesById[TI_CargoType_Container];
	state := TI_STATE_NORMAL;
	
	create moveController transient;
	foreach idx in 1 to _numItems do : outerloop
		moveController.setMyToPrimaryLocation(self.myLocationsController);
		tmpID := self.getNextQuickCargoID(TI_CargoType_Container);
		
		while true do // NAVAB1 added this so that TIs are created if only get warnings.
		
			pxyTI := aTerm.createTI(cargoType, true);
			pxyTI.zSetPxyTerminal(aTerm);
			pxyTI.setCargoType(cargoType.id);

			pxyTI.setMyOperator(app.myRoot.allOperators["MSC"]);
			if pxyTI.myOperator = null then
				pxyTI.setMyOperator(app.myRoot.allOperators["MSL"]);
			endif;
			if pxyTI.myOperator = null then
				pxyTI.setMyOperator(app.myRoot.allOperators.first);
			endif;
			pxyTI.setCommodity("GENL");
			pxyTI.setImExStatus(TI_IMEX_STATUS_EXPORT);
			pxyTI.setMyVoyage(aVoy, passport);
			pxyTI.changeState(state, passport);
			pxyTI.setWeight(12999, null,passport);
			pxyTI.setTotalWeight(12999, null,passport);
			//pxyTI.zSetPxyCompany(aTerm.getConfig(DefCompany).CM_Bank);
			pxyTI.zSetPxyCompany(aTerm.getDefaultCompanyBank);//17 Apr 2012 NDL	Par 29393
			pxyTI.zSetPxyDischargePort(aTerm.getConfig(PortDestCode).String);
			if _is40 then
				pxyTI.changeISOType("4200", null, app.myPassport);
			else
				pxyTI.changeISOType("2200", null, app.myPassport);
			endif;
			if app.isSubTerminalsOn(self.myTerminal) then
				subT := aTerm.getDefaultSubTerminal(CM_SubTerminal.Type_TrackedItem,
																		0,	
																		TI_IMEX_STATUS_IMPORT,
																		"MT",
																		true); 
				pxyTI.setSubTerminal(subT,null);
			endif;
			pxyTI.zSetPxyId(tmpID);

			passport.setWarningsIgnored(true);
			passport.setWarningsAcknowledged(true);
			app.myTrxCA.trxCreateTIWithMove(pxyTI, realTI, moveController, passport); // this deletes the pxyTI
			
			if passport.hasErrors then // NAVAB1 if get errors leave to show on UI
				break outerloop;
			endif;
		
			if app.myPassport.trxCompletedOK then
				// Clear errors/warnings from form and err/warnings window
				break;
			else

				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			break;
			
		endwhile;
		
	endforeach;

epilog

	delete moveController;

end;</source>
        <Parameter name="_numItems" type="Integer"/>
        <Parameter name="_is40" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="createQuickCargoGC" id="29e6df97-ffd5-4b52-96db-9a8df01c4445">
        <updating/>
        <source>createQuickCargoGC(_numItems : Integer; _cargoType		: CM_CargoType) updating;
/*
Purpose:			
Date				Who			Reason
AUGUST 2011		CNWAB1		Initial creation
*/


vars

	aTerm : CM_Terminal;
	aRoot : CM_Root;
	aVoy : CM_Voyage;
	realTI,
	pxyTI			: CM_TrackedItem;
	cargoType		: CM_CargoType;
	passport		: CM_Passport;
	moveController	: CMIF_MoveController;
	state			: Integer;
	slot : CM_LocationsController;
	tmpID : String;
	subT : CM_SubTerminal;
	idx : Integer;
	commCode : String;
begin

 
	aTerm := self.myTerminal;
	aVoy	:= aTerm.getNullVoyage();
 
	//lets make cargo
	passport := app.myPassport;
	passport.setMyTerminal(aTerm);
	if _cargoType = null then
		cargoType	:= aTerm.getFirstNonSystemCargoType().CM_CargoType;
	else
		cargoType := _cargoType;
	endif;
	
	if not cargoType.allCommodities.isEmpty() and not cargoType.abbreviation = "CONT" then
		commCode := cargoType.allCommodities.first.code;
	else
		commCode := "GENL";
	endif;
	
	if not cargoType.isCommodityRequired then
		commCode := "";
	endif;
	
//	cargoType := "2083.342".asOid.CM_CargoType; // BreakBulk
	state := TI_STATE_NORMAL;

	
	create moveController transient;
	foreach idx in 1 to _numItems do
		moveController.setMyToPrimaryLocation(self.myLocationsController);
		tmpID := self.getNextQuickCargoIDGC(cargoType.id,commCode);
		
		pxyTI := aTerm.createTI(cargoType, true);
		pxyTI.zSetPxyTerminal(aTerm);
		if _cargoType.isTrailer then
			pxyTI.CM_TILC.setMyType(_cargoType.allTILCTypes.first);
		endif;

		pxyTI.setCargoType(cargoType.id);
		pxyTI.setMyProduct(cargoType.allProducts.first);
		pxyTI.setMyOperator(app.myRoot.allOperators["MSC"]);
		if pxyTI.myOperator = null then
			pxyTI.setMyOperator(app.myRoot.allOperators["MSL"]);
		endif;
		if pxyTI.myOperator = null then
			pxyTI.setMyOperator(app.myRoot.allOperators.first);
		endif;
		pxyTI.setCommodity(commCode);
		pxyTI.setImExStatus(TI_IMEX_STATUS_EXPORT);
		pxyTI.setMyVoyage(aVoy, passport);
		pxyTI.changeState(state, passport);
		pxyTI.setWeight(12999, null,passport);
		pxyTI.setTotalWeight(12999, null,passport);
		pxyTI.setMyTotalVolume(1767);	// cnwdw1 27868
		//pxyTI.zSetPxyCompany(aTerm.getConfig(DefCompany).CM_Bank);
		pxyTI.zSetPxyCompany(aTerm.getDefaultCompanyBank);//17 Apr 2012 NDL	Par 29393
		pxyTI.zSetPxyDischargePort(aTerm.getConfig(PortDestCode).String);
		if app.isSubTerminalsOn(self.myTerminal) then
			subT := aTerm.getDefaultSubTerminal(CM_SubTerminal.Type_TrackedItem,
																	0,	
																	TI_IMEX_STATUS_IMPORT,
																	commCode,
																	true); 
			pxyTI.setSubTerminal(subT,null);
		endif;
		pxyTI.zSetPxyId(tmpID);
		app.myTrxCA.trxCreateTIWithMove(pxyTI, realTI, moveController, passport); // this deletes the pxyTI
	endforeach;

epilog

	delete moveController;

end;</source>
        <Parameter name="_numItems" type="Integer"/>
        <Parameter name="_cargoType" type="CM_CargoType"/>
    </JadeMethod>
    <JadeMethod name="createQuickCargoWithAlloc" id="f4d284be-4e0d-4d28-baf2-f81c8c46829f">
        <updating/>
        <source>createQuickCargoWithAlloc(_alloc : CM_VoyageAllocation) updating;
// ---------------------------------------------------------------------------
// Created:     1 DEC 2010 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

	aTerm : CM_Terminal;
	aRoot : CM_Root;
	aVoy : CM_Voyage;
	realTI,
	pxyTI			: CM_TrackedItem;
	cargoType		: CM_CargoType;
	passport		: CM_Passport;
	moveController	: CMIF_MoveController;
	state			: Integer;
	slot : CM_LocationsController;
	startLC : CM_GridController;
	tmpID : String;
	subT : CM_SubTerminal;
	idx, numItems : Integer;
	isoGroup : CM_ISOTypeGroup;
	isoType : CM_ISOType;
begin

 
	aVoy	:= _alloc.myVoyage;
 
	aTerm := aVoy.myTerminal;
	//lets make cargo
	passport := app.myPassport;
	passport.setMyTerminal(aTerm);
	cargoType	:= _alloc.getCargotype();
	state := TI_STATE_NORMAL;
	numItems := _alloc.getNumSlotReqs();
		write numItems;
	
	create moveController transient;
	foreach idx in 1 to numItems do
		moveController.setMyToPrimaryLocation(self.myLocationsController);
		if moveController.myToPrimaryLocation = null then
			break;
			endif;
		tmpID := self.getNextQuickCargoID(cargoType.id);
		
		pxyTI := aTerm.createTI(cargoType, true);
		pxyTI.zSetPxyTerminal(aTerm);

		pxyTI.setCargoType(cargoType.id);
		pxyTI.setMyOperator(app.myRoot.allOperators["MSC"]);
		if pxyTI.myOperator = null then
			pxyTI.setMyOperator(app.myRoot.allOperators["MSL"]);
		endif;
		if pxyTI.myOperator = null then
			pxyTI.setMyOperator(app.myRoot.allOperators.first);
		endif;
		
		if cargoType.allCommodities.first &lt;&gt; null then
		
			pxyTI.setCommodity(cargoType.allCommodities.first.code);
		else
		
			pxyTI.setCommodity("GENL");
		
		endif;
		pxyTI.setImExStatus(_alloc.getIMEXStatus().code);
		pxyTI.setMyVoyage(aVoy, passport);
		pxyTI.changeState(state, passport);
		pxyTI.setWeight(12999, null,passport);
		pxyTI.setTotalWeight(12999, null,passport);
		pxyTI.zSetPxyCompany(aTerm.getDefaultCompanyBank);//17 Apr 2012 NDL	Par 29393
		
		pxyTI.zSetPxyDischargePort(_alloc.getDischargePort().code);
		
		
		if cargoType.id = TI_CargoType_Container then
			isoGroup := _alloc.getISOGroup();
			if isoGroup &lt;&gt; null then
				isoType := isoGroup.allISOTypes.first;
			endif;
			
			if isoType &lt;&gt; null then
				pxyTI.changeISOType(isoType.code, null, app.myPassport);
			else
				pxyTI.changeISOType("2200", null, app.myPassport);
			endif;
		
		endif;
		if app.isSubTerminalsOn(self.myTerminal) then
			subT := aTerm.getDefaultSubTerminal(CM_SubTerminal.Type_TrackedItem,
																	0,	
																	TI_IMEX_STATUS_IMPORT,
																	"MT",
																	true); 
			pxyTI.setSubTerminal(subT,null);
		endif;
		pxyTI.zSetPxyId(tmpID);
		
		passport.setWarningsIgnored(true);
		passport.setWarningsAcknowledged(true);

		app.myTrxCA.trxCreateTIWithMove(pxyTI, realTI, moveController, passport); // this deletes the pxyTI
		if passport.hasErrorsOrWarnings then
		write passport.getErrorsAndWarningsAsString;
		endif;
	endforeach;

epilog

	delete moveController;

end;</source>
        <Parameter name="_alloc" type="CM_VoyageAllocation"/>
    </JadeMethod>
    <JadeMethod name="erase" id="7fc21ec4-7fc0-4cf7-8077-fa792388218b">
