    <JadeMethod name="addItem" id="f6aa55b3-d786-48f3-9366-87ed96e4bfd7">
        <source>addItem();
// ---------------------------------------------------------------------------
// Created:     05 September 2002 by cnwth2
//
// Purpose:     
//
// ----------   ----------  --------------------------------------------------
vars
	logReticket		: CMIF_TIReticket;
	idx				: Integer;
	table			: CM_EntryTable;
	newId,
	oldId			: String;
	
begin
	table := self.tblItem;
	oldId := table.getValueByName(ETRow_OldLogId).String;
	newId := table.getValueByName(ETRow_NewLogId).String;
	
	if newId = null or oldId = null then
		return;
	endif;
	
	create logReticket transient;
	logReticket.oldId := table.getValueByName(ETRow_OldLogId).String;
	logReticket.newId := table.getValueByName(ETRow_NewLogId).String;
	logReticket.myLog := self.myTerminal.lookupTrackedItem(logReticket.oldId, TI_CargoType_Log, TI_STATE_NORMAL, null, false).CM_Log;
	self.allCMIF_TIRetickets.add(logReticket);
	
	self.addTblAllRow(logReticket);
	
// cnwdad1 20/10/2008 - PAR #17968.
//	table.setValueByName(ETRow_OldLogId, null);
//	table.setValueByName(ETRow_NewLogId, null);

	table.setFocus();
	table.goToRowByName(ETRow_OldLogId);
	tblItem.setFocus();
end;</source>
    </JadeMethod>
    <JadeMethod name="addTblAllRow" id="4886cf28-370a-4efd-9682-f32124f84ec5">
        <source>addTblAllRow(_tiReticket : CMIF_TIReticket);
// ---------------------------------------------------------------------------
// Created:     18 September 2002 by cnwth2
//
// Purpose:     
//
// ----------   ----------  --------------------------------------------------
vars
	idx		: Integer;
begin
	idx := self.tblAll.addItem(_tiReticket.oldId &amp; Tab &amp; _tiReticket.newId);
	self.tblAll.accessRow(idx).itemObject := _tiReticket;
	
end;</source>
        <Parameter name="_tiReticket" type="CMIF_TIReticket"/>
    </JadeMethod>
