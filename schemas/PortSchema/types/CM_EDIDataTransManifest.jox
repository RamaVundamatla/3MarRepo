    <JadeMethod name="getEDIChildDataTypes" id="30e6318d-6fde-4e1c-be08-6e735242be5c">
        <source>getEDIChildDataTypes(_types: IntegerArray input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 June 2023	navsp1	Initial creation TFS ChangeRequest 58054: EUP - Manifest Send EDI Endpoint
13 Nov 2023	jlirs1	TFS 59171 User Defined Transport Manifest 
//29 Jan 2024	jlirs1	TFS 59172 61640 62182 User Defined CallOff
*/

vars

begin
	_types.add(EDIDataType_TransportManifest);
	if self.myCargoOnSite &lt;&gt; null then
		_types.add(EDIDataType_CargoOnSite);		
	endif;
	
	if self.myGateDocument &lt;&gt; null then
		_types.add(EDIDataType_BookingHeader);
		_types.add(EDIDataType_BookingItem);
		_types.add(EDIDataType_Prenote);
		_types.add(EDIDataType_TIHazDets);
		_types.add(EDIDataType_TISeal);		
	endif;
	
	if self.myShipManifest &lt;&gt; null then
		_types.add(EDIDataType_BOLHdr);
		_types.add(EDIDataType_BOLDtl);
		_types.add(EDIDataType_CargoOnShip);
		_types.add(EDIDataType_TIHazDets);
		_types.add(EDIDataType_TISeal);		
	endif;
	
	if self.myTrainConsist &lt;&gt; null then
		_types.add(EDIDataType_Wagon);
		_types.add(EDIDataType_Prenote);
		_types.add(EDIDataType_TISeal);		
	endif;	
	
epilog

end;</source>
        <Parameter name="_types" type="IntegerArray" usage="input"/>
    </JadeMethod>
