        <updating/>
        <executionLocation>client</executionLocation>
        <source>writeToDiskFileClient(pDiskFileObj:File; pFileData:Binary; pIsCompressionUsed:Boolean) updating, protected, clientExecution;
// --------------------------------------------------------------------------------
// Created:		08 July 2002 by cnwdad2
//
// Purpose:		Client node wrapper for the writeToDiskFile method.
// --------------------------------------------------------------------------------
begin
	self.writeToDiskFile(pDiskFileObj, pFileData, pIsCompressionUsed);
end;</source>
        <access>protected</access>
