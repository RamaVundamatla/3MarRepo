    <JadeMethod name="setMyProxy" id="8b5fe159-17cd-403f-927c-b1bd054977ed">
        <updating/>
        <source>setMyProxy(_obj : Object) updating;
// ---------------------------------------------------------------------------
// Created:	16 January 2009 By Graeme Black cnwgb1
// Purpose:	Creates or Deletes a Proxy object. Created to maintain a tracked item 
// 			proxy for MOB_HandHeldForms.
//			PNL CCMS 1658 PAR 18787
// ---------------------------------------------------------------------------
vars

begin
	if self.myProxyObject &lt;&gt; null then
		self.myProxyObject.erase(NORMAL_ERASE);
		self.myProxyObject := null;
	endif;
	if _obj &lt;&gt; null then
		self.myProxyObject := app.createUpdateProxy(_obj.CM_Object);
	endif;
epilog
end;</source>
        <Parameter name="_obj" type="Object"/>
    </JadeMethod>
