    <JadeMethod name="timerEvent" id="219b8632-5547-4ece-b377-05cf46819bc7">
        <updating/>
        <source>timerEvent(eventTag: Integer) updating;
//----------------------------------------------------------------
//	Created:	29 September 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
// Changed On	By			Reason
// ----------	--------	--------------------------------------
// 25/11/2010	cnwdap1		PAR #26426 Release requests on Ship Load List
vars

begin
	app.mousePointer	:=	Busy;
	if eventTag = TimerTag then
		app.myPassport.myActivityCapture.startCaptureDebugMisc(method.name);
		beginLoad;
		self.doCentralisedTINoteUpdate();
		self.doCentralisedWLENoteUpdate();		// PAR #26426
		endLoad;
		app.myPassport.myActivityCapture.stopCaptureDebugMisc();
	endif;
	
epilog
	endLoad; // PAR 15648, just in case of a CRASH!!!!
	app.mousePointer	:=	Idle;
end;</source>
        <Parameter name="eventTag" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="translateForm" id="04172f2f-f050-4c95-9045-5784f810a6fa">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 November 2019 09:31:17.
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0006540, locale);
	btnCancelPref.translateCaption(Xlat_0002911, locale);
	btnCargoUnplan.translateBubbleHelp(Xlat_0002901, locale);
	btnCargoUnplan.translateCaption(Xlat_0002914, locale);
