    <JadeMethod name="showSplitWorkCraneForm" id="66619ad5-cb77-4f6a-b72c-1231d01905d9">
        <source>showSplitWorkCraneForm(		_voyageJob : CM_VoyageJob; 
							_selectedWLEs : CM_WLESet;
							_allVoyageJobs : CM_JobArray	);
// --------------------------------------------------------------------------------
// Created:		31 August 2010 by cnwjo3
//
// Purpose:		Open CMUI_SplitOrTransWorkCraneForm and setup properties
//				CCMS 1178 PAR 23366
//
// Changed On	By			Reason
// ----------	----------	-------------------------------------------------------
// 16/12/2019	jlgdap1		TFS 47144 JMT Refactor OOW Job Split Transfer
vars
	splitForm 	: CMUI_SplitOrTransWorkCraneForm;
	job 		: CM_Job;
begin

	if _voyageJob = null then
		return;
	endif;

	
	splitForm := app.loadForm(CMUI_SplitOrTransWorkCraneForm, CMUI_Assistant, false, false, true, self.myTerminal, null).CMUI_SplitOrTransWorkCraneForm;
	
	splitForm.setDetails(_voyageJob,_selectedWLEs,_allVoyageJobs);

	splitForm.setFormParent(app.mainForm);
	
	splitForm.mode := splitForm.Mode_Split;					// TFS 47144

	splitForm.show();	
end;</source>
        <Parameter name="_voyageJob" type="CM_VoyageJob"/>
