    <JadeMethod name="verifyEDIDataTIs" id="4efb960b-5be2-41c1-882d-ec7891613668">
        <updating/>
        <source>verifyEDIDataTIs(_passport : CM_Passport input): Integer updating;

// reimplemented
// 24/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
// 24 No 2022 	navma1 		ChangeRequest 52499: MTN - Improve the performance of the Edi file verification process.
vars
	propArray			: ObjectArray;
	object				: Object;
	property			: Property;
	ediTI				: CM_EDITrackedItem;
	methodName,
	valueString			: String;
	numInError,
	int2				: Integer;
	shortDesc,
	longDesc			: String;
	width,
	num					: Integer;
	ediTIError			: CM_Error;
	warning				: Boolean;
	errorMessage		: String;
	errorWarningLimit	: Integer;
	terminal			: CM_Terminal;
	
begin
	
	create propArray transient;
	terminal := self.getMyTerminal();
	
	if terminal = null then
		app.raiseCMException1(Err_InvalidTerminal, null, null, null);
	endif;
	
	errorWarningLimit := terminal.getConfig(EDIVerificationErrorLimit).Integer;	
	getTIProperties(propArray);


	foreach ediTI in self.allEDITrackedItems do
		//need to put this somewhere else
		if ediTI.status = CM_EDIFile.EDI_STATUS_DBLOADED then
			continue;
		endif;
		
		int2 := int2 + 1;
		
		foreach object in propArray do
			property := object.Property;
			if ediTI.propertyNotVerified(property.getName) then
				continue;
			endif;
			methodName := property.getName &amp; "Verify";
			valueString := ediTI.sendMsgWithParams(methodName, terminal).String;
			
			if valueString[1:1].Integer &lt;&gt; CM_EDITrackedItem.VALID then
				if valueString[1:1].Integer = CM_EDITrackedItem.ERROR then
					numInError := numInError + 1;
				endif;
				
				findHeadings(property.getName,shortDesc,longDesc,width,num);
				
				if  valueString[1:1].Integer = CM_EDITrackedItem.WARNING then
					warning := true;
				else
					warning := false;
				endif;
				
				errorMessage := valueString[2:50];
				
				create ediTIError transient;
				
				ediTIError.set(0,errorMessage,warning,longDesc,ediTI, ediTI);
				
				if warning then
					ediTIError.setMyWarningPassport(_passport);
				else
					ediTIError.setMyErrorPassport(_passport);
				endif;
			endif;
		endforeach;
	endforeach;
	
	return numInError;
epilog
	delete propArray;			// transient leaks
end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
