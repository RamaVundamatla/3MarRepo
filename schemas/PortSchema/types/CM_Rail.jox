    <JadeMethod name="getAllWLEs" id="c6668441-3acc-4a0e-a897-b1e7a1e11286">
        <source>getAllWLEs(_wleArray : CM_WLEArray input);
//--------------------------------------------------------------
//Created: 17 March 2003 By: cnwgd1
//--------------------------------------------------------------
vars
	railLine	: CM_RailLine;
begin
	foreach railLine in self.allRailLinesByIndex do 
		railLine.getAllWLEs(_wleArray);
	endforeach;
end;</source>
        <Parameter name="_wleArray" type="CM_WLEArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getAutoPlanLocationFor" id="cec375ad-c2d8-4cea-968a-f7c13376120c">
        <source>getAutoPlanLocationFor(	_ti : CM_TrackedItem;
						_yaAgent : CM_YAAutoplanAgent input;
						_cmifAutoPlan : CMIF_YAAutoPlan;
						_moveMode : Integer;
						_specificArea : Boolean
						): CM_WagonController;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 June 2013	cnwndl1	Initial creation	Par 31692

*/

vars

	railLine : CM_RailLine;
	wagon : CM_Wagon;
	wagonController : CM_WagonController;

begin

	if _yaAgent &lt;&gt; null then
		if _specificArea then
			_yaAgent.addLogEntry(AP_Log_YA_Default, app.getErrorString1(Using_specifi_rail_area, self.getName), false);
		else
			_yaAgent.addLogEntry(AP_Log_YA_Default, app.getErrorString1(Rail_area, self.getName), false);
		endif;
	endif;
	
	foreach railLine in self.allRailLines discreteLock do
		if _yaAgent &lt;&gt; null then
			_yaAgent.addLogEntry(AP_Log_YA_Default,app.getErrorString1(Rail_line_id, railLine.getName), false);
		endif;
		foreach wagon in railLine.allWagons discreteLock do//array
			wagonController := wagon.getAutoPlanLocationFor( _ti, _yaAgent, _cmifAutoPlan, _moveMode );
			if wagonController &lt;&gt; null then
				return wagonController;
			endif;
		endforeach;
	endforeach;
	
	return null;
		
epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_yaAgent" type="CM_YAAutoplanAgent" usage="input"/>
        <Parameter name="_cmifAutoPlan" type="CMIF_YAAutoPlan"/>
        <Parameter name="_moveMode" type="Integer"/>
        <Parameter name="_specificArea" type="Boolean"/>
        <ReturnType type="CM_WagonController"/>
    </JadeMethod>
    <JadeMethod name="getConfirmedWagonsForRailLine" id="f7152a64-00c1-4472-b077-7a0389fc3e79">
        <source>getConfirmedWagonsForRailLine(pRailLine : CM_RailLine)	:	CM_WagonArray;
//Gets the confirmed wagons for a specified Rake.
vars
	index	:	Integer;
	lc	:	CM_LocationsController;
	array	:	CM_WagonArray;
	lWagon : CM_Wagon;
begin
	create array;
	foreach lWagon in pRailLine.allWagons do
		if lWagon = null then 
			continue;
		endif;
		foreach lc in lWagon.allLocationsControllersArray do
			if not lc.CM_WagonController.isAvailable then
				if self.confirmFromFarEnd then // this is to get the sequencing right for autoplanning. stg 2 sep 99
					array.insert(1, lc.CM_WagonController.myWagon);	
				else
					array.add(lc.CM_WagonController.myWagon);	
				endif;
			endif;
		endforeach;
	endforeach;
	
	return array;
end;</source>
        <Parameter name="pRailLine" type="CM_RailLine"/>
        <ReturnType type="CM_WagonArray"/>
    </JadeMethod>
    <JadeMethod name="getCurrentLocationsControllers" id="b83c46f7-e567-4640-a130-7ff262f723a4">
        <source>getCurrentLocationsControllers( _allLocs : CM_LCSet input);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
13 March 2012	cnwndl1	Initial creation	Par 29220

*/

vars

	line : CM_RailLine;
	wagon : CM_Wagon;
	wc : CM_WagonController;
	invalidLine : Boolean;
	invalidWagon : Boolean;
	invalidWC : Boolean;

begin

	on Exception do app.handleDeletedObject( exception, line, invalidLine );
	on Exception do app.handleDeletedObject( exception, wagon, invalidWagon );
	on Exception do app.handleDeletedObject( exception, wc, invalidWC );

	foreach line in self.allRailLines discreteLock do
		if line = null then
			continue;
		endif;
		foreach wagon in line.allWagons discreteLock do
			if wagon = null or not wagon.confirmed then
				continue;
			endif;
			//foreach wc in wagon.allLocationsControllers discreteLock do
			foreach wc in wagon.allLocationsControllersArray discreteLock do	//04 Dec 2014	NDL	Par 35345
				if wc = null then
					continue;
				endif;
				_allLocs.add(wc);
			endforeach;
		endforeach;
	endforeach;

epilog

end;</source>
        <Parameter name="_allLocs" type="CM_LCSet" usage="input"/>
    </JadeMethod>
