    <JadeMethod name="doMnuWagonMasterClick" id="7a7404b4-227d-412e-aa14-da1ae3802096">
        <source>doMnuWagonMasterClick(menuItem: MenuItem input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 February 2014	cnwndl1	Initial creation	Par 33439

*/

vars

	wagonMaster : CM_WagonMaster;
	form : CMUI_WagonMasterMaintForm;

begin

	wagonMaster := menuItem.userObject.CM_WagonMaster;
	
	if wagonMaster = null then
		return;
	endif;
	
	form := app.loadForm(CMUI_WagonMasterMaintForm, CMUI_Assistant, false, false, false, self.myTerminal, null).CMUI_WagonMasterMaintForm;
	if form = null then
		return;
	endif;
	
	form.CMUI_WagonMasterMaintForm.setAttributes(wagonMaster);
	form.setParentForm(self);
	form.centreOverParent(0);
	form.disableExceptRestrictionDamage();
	form.show;
	return;

epilog

end;</source>
        <Parameter name="menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
