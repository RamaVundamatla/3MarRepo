<Class name="WS_Train" id="5e1eb97e-27f4-435a-9f68-74e533f69e16">
    <superclass name="WS_ProxyObject"/>
    <transient/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="webservice"/>
    <ImplicitInverseRef name="allWagonsIn" id="03e8cbed-1d18-4c46-8d29-d6afd5aebaa8">
        <memberTypeInverse/>
        <type name="WS_WagonArray"/>
        <access>readonly</access>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="allWagonsOut" id="6bca972a-6512-4f3c-abc6-292cd71de07a">
        <memberTypeInverse/>
        <type name="WS_WagonArray"/>
        <access>readonly</access>
    </ImplicitInverseRef>
    <PrimAttribute name="arrivalDT" id="a87c46e8-576b-41b6-8ae8-273d67d43499">
        <type name="String"/>
        <access>readonly</access>
    </PrimAttribute>
    <PrimAttribute name="code" id="e3a5652d-e678-432b-bd45-80ca5440069f">
        <type name="String"/>
        <access>readonly</access>
    </PrimAttribute>
    <PrimAttribute name="departureDT" id="c6f0e6b8-bc87-40b5-8093-30fb7bd072c1">
        <type name="String"/>
        <access>readonly</access>
    </PrimAttribute>
    <PrimAttribute name="description" id="f13fe364-3342-4c6f-84ea-5d2c487b7f22">
        <type name="String"/>
        <access>readonly</access>
    </PrimAttribute>
    <PrimAttribute name="scheduledArrivalDT" id="5b03028a-290f-4888-9e9a-422434292a59">
        <type name="String"/>
        <access>readonly</access>
    </PrimAttribute>
    <PrimAttribute name="scheduledDepartureDT" id="cd126639-4544-494a-a598-0d85d89076e1">
        <type name="String"/>
        <access>readonly</access>
    </PrimAttribute>
    <JadeMethod name="addWagonIn" id="bb102010-8607-4ef3-9692-66211fc64229">
        <updating/>
        <source>addWagonIn(_wagon: WS_Wagon) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 November 2016	cnwmp6	Initial creation

*/

vars

begin
	self.allWagonsIn.add(_wagon);
epilog

end;</source>
        <Parameter name="_wagon" type="WS_Wagon"/>
    </JadeMethod>
    <JadeMethod name="delete" id="f25496d8-8c52-4dbc-9ee8-efbd01885480">
        <updating/>
        <source>delete() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 November 2016	cnwmp6	Initial creation

*/

vars

begin
	if not self.allWagonsIn.isEmpty then
		self.allWagonsIn.purge;
	endif;
	if not self.allWagonsOut.isEmpty then
		self.allWagonsOut.purge;
	endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setProxyFromObject" id="47f3e178-3962-486f-8f11-0f69841986c6">
        <updating/>
        <source>setProxyFromObject(_train: CM_Train) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 Jan 2016	cnwmc5	Initial creation
03 Aug 2022 jlier1 TFS 53971 
*/

vars

begin
	inheritMethod(_train);
	
	self.code 					:= _train.code;
	self.description 			:= _train.description;
	self.arrivalDT 				:= _train.arrivalDT.asStringForWebInterface();
	self.departureDT 			:= _train.departureDT.asStringForWebInterface();
	self.scheduledArrivalDT 	:= _train.scheduledArrivalDT.asStringForWebInterface();
	self.scheduledDepartureDT 	:= _train.scheduledDepartureDT.asStringForWebInterface();
	


epilog

end;</source>
        <Parameter name="_train" type="CM_Train"/>
    </JadeMethod>
    <JadeMethod name="setProxyWagons" id="a7f3725e-0262-4772-a85d-f6e625fee30e">
        <updating/>
        <source>setProxyWagons(_train: CM_Train) updating;
/*****************************************************
Author		: jlika1 (Karen Alexander)
Date		: 28 June 2022
TFS#		: 53971
Function	:

*** Changes ***
Date			Name		TFS#		Description

****************************************************/

vars
	wagon	: CM_Wagon;
	wsWagon	: WS_Wagon;
begin
	foreach wagon in _train.allWagonsByIdInward discreteLock do
		create wsWagon transient;
		wsWagon.setProxyFromObject(wagon);
		self.allWagonsIn.add(wsWagon);
	endforeach;
	
	foreach wagon in _train.allWagonsByIdOutward discreteLock do
		create wsWagon transient;
		wsWagon.setProxyFromObject(wagon);
		self.allWagonsOut.add(wsWagon);
	endforeach;
end;</source>
        <Parameter name="_train" type="CM_Train"/>
    </JadeMethod>
</Class>
