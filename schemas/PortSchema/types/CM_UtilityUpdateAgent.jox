    <JadeMethod name="utlUpdatePreNote" id="57e4644b-773a-47e5-b0ec-8a5c97fea613">
        <updating/>
        <source>utlUpdatePreNote(	_intFaceObject : CMIF_PreNote io;
					_validateOnly : Boolean;
					_isCheckEdition : Boolean;
					_isInitialise : Boolean;
					_passport : CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:     Jan 2010 cnwrs1 par 21329
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 28/07/2010	cnwdad1		PAR #25120, added parameter for calling "initialiseActivity".
// ---------------------------------------------------------------------------
vars
	nullObject	: CM_Object;
	tmpEvent	: Integer;
begin
	if _isInitialise then
		self.initialiseActivity();
	endif;

	// do the validation here
	_intFaceObject.validateForUpdate(_passport);		//Also does the sub items
	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;

	app.setContinueCMExceptions(false);
	
	_intFaceObject.actionForUpdate(nullObject, self.myUpdateAuditAgent, _isCheckEdition, _passport); 	//Also does sub items
	
	if _passport.noErrors() then
		// issue notifications on updated objcets
		tmpEvent := _passport.myTerminal.getTerminalEvent(TIEvent_PreNote_Update);
		
		if _intFaceObject.isKindOf(CMIF_PreNote) then
			_intFaceObject.CMIF_PreNote.myPersistentTrackedItem.causeEvent(tmpEvent, false, _intFaceObject.myPersistentTrackedItem);
		endif;
	endif;
end;</source>
        <Parameter name="_intFaceObject" type="CMIF_PreNote" usage="io"/>
        <Parameter name="_validateOnly" type="Boolean"/>
        <Parameter name="_isCheckEdition" type="Boolean"/>
        <Parameter name="_isInitialise" type="Boolean"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdatePreNotes" id="5ff17103-d3f7-44cf-9809-503fad0ed0bc">
        <updating/>
        <source>utlUpdatePreNotes(	pIntFaceArray : CMIF_TIObjectArray;
					_isValidate : Boolean;
					_isCheckEdition : Boolean;
					_passport : CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:     15 February 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	item		: CMIF_TIObject;
	nullObject	: CM_Object;
	tmpEvent	: Integer;

begin

	self.initialiseActivity();

	// do the validation here
	foreach item in pIntFaceArray do
		if item.isKindOf(CMIF_PreNote) then
			item.validateForUpdate(_passport);		//Also does the sub items
		else
			app.raiseUnexpectedProgramError(class.name, method.name, 'Called for non Pre-Note item (' &amp; item.String &amp; ')');
			return;
		endif;
	endforeach;
	
	if not self.checkValidationWithPassport(_passport) or _isValidate then
		return;
	endif;

	app.setContinueCMExceptions(false);
	
	foreach item in pIntFaceArray do
		if (not item.actionForUpdate(nullObject, self.myUpdateAuditAgent, _isCheckEdition, _passport)) then 	//Also does sub items
			break;
		endif;
		
		if (not _passport.noErrors()) then
			break;
		endif;
	endforeach;

	if _passport.noErrors then
		// issue notifications on updated objcets
		tmpEvent := _passport.myTerminal.getTerminalEvent(TIEvent_PreNote_Update);
		foreach item in pIntFaceArray do
			if item.isKindOf(CMIF_PreNote) then
				item.CMIF_PreNote.myPersistentTrackedItem.causeEvent(tmpEvent, false, item.CMIF_PreNote.myPersistentTrackedItem);
			endif;
		endforeach;
	endif;	
	
end;</source>
        <Parameter name="pIntFaceArray" type="CMIF_TIObjectArray"/>
        <Parameter name="_isValidate" type="Boolean"/>
        <Parameter name="_isCheckEdition" type="Boolean"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdatePredefinedRemark" id="7292bd4b-8780-4be6-8103-c24a008cc64e">
        <source>utlUpdatePredefinedRemark(pProxyPredefinedRemark:CM_PredefinedRemark; _passport : CM_Passport input);
// ---------------------------------------------------------------------------
// Created:     13 May 2003 by cnwsb1
// ---------------------------------------------------------------------------
vars
	cancelSave : Boolean;
	realPredefinedRemark : CM_PredefinedRemark;
	expectedEdition : Integer;
	
begin
	self.initialiseActivity();

	pProxyPredefinedRemark.raiseExceptionIfNotProxy(method);

	app.setContinueCMExceptions(true);

	pProxyPredefinedRemark.pxyGetRealObjectAndEdition(realPredefinedRemark, expectedEdition);
	
	if realPredefinedRemark = null then	
		app.raiseCMException1(ProxyMgrCannotLocateReal, CM_PredefinedRemark.name, null, null);
		return;
	endif;

	app.myValUA.valPredefinedRemark(realPredefinedRemark, pProxyPredefinedRemark);
	
	if (not self.checkValidationWithPassport(_passport)) then
		return;		// note that this gets "ignored" in the eplog
	endif;

	app.setContinueCMExceptions(false);

	exclusiveLock(realPredefinedRemark);

	if _passport.noErrors and realPredefinedRemark.edition &lt;&gt; expectedEdition then
		app.raiseCMException1(ObjectUpdatedByAnotherUserSave, 'PredefinedRemark', null, null);
		return;
	endif;
	
	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realPredefinedRemark, true);
	endif;
	
	if _passport.noErrors then
		realPredefinedRemark.setForUpdate(pProxyPredefinedRemark);
	endif;

	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realPredefinedRemark, false);
	endif;
end;</source>
        <Parameter name="pProxyPredefinedRemark" type="CM_PredefinedRemark"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdatePrinterDef" id="3ba30344-d5c8-459a-b97d-26f9e6743cfd">
        <source>utlUpdatePrinterDef(_proxyPrinterDef :  CM_PrinterDef input; _passport : CM_Passport input);

// cnwdvb1 22 April 2003 

vars

	realPrinterDef	: CM_PrinterDef;
	expectedEdition	: Integer;

begin

	app.myValUA.valPrinterDef(_proxyPrinterDef);	
	
	if not self.checkValidationWithPassport(_passport) then
