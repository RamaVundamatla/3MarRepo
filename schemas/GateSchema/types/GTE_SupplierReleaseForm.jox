    <JadeMethod name="doLocationsLoad" id="a96655cf-1003-4201-b32c-2e4c5936d216">
        <updating/>
        <source>doLocationsLoad() protected, updating;

// cnwdvb1 22 October 2002 

vars

	allSoh			: CM_SOHLocationsByLocnProduct;
	operator		: CM_Operator;
	species			: CM_LogSpecies;
	grade			: CM_LogGrade;
	type			: CM_LogType;
	treatment		: CM_LogTreatment;
	length			: CM_LogLength;
	theSpecies, theGrade, theType, theTreatment, theLength : String;
	soh				: CM_SOHLocation;
	compare			: String;
begin

	create allSoh transient;
	operator	:= self.cmbOperator.myObject.CM_Operator;
	species		:= self.cmbSpecies.myObject.CM_LogSpecies;
	grade		:= self.cmbGrade.myObject.CM_LogGrade;
	type		:= self.cmbType.myObject.CM_LogType;
	treatment	:= self.cmbTreatment.myObject.CM_LogTreatment;
	length		:= self.cmbLength.myObject.CM_LogLength;
	
	if species &lt;&gt; null then
		theSpecies := species.code;
	endif;
	
	if grade &lt;&gt; null then
		theGrade := grade.code;
	endif;
	
	if type &lt;&gt; null then
		theType := type.code;
	endif;
	
	if treatment &lt;&gt; null then
		theTreatment := treatment.code;
	endif;
	
	if length &lt;&gt; null then
		theLength := length.code;
	endif;
	compare := theSpecies &amp; theGrade &amp; theType &amp; theTreatment &amp; theLength;
	if compare &lt;&gt; self.compareSpec then
		self.compareSpec := compare;
		self.myTerminal.getSOHLocationsForLogSpec(operator, theSpecies, theGrade, theType, theTreatment, theLength, allSoh);
		self.allSohLocations.clear;
		self.allLocations.clear;
		foreach soh in allSoh do
			self.allSohLocations.add(soh);
			self.allLocations.add(soh.myLocationsController);
		endforeach;	
		self.myAssistant.comboBoxAddLocationsWithNull(self.cmbLocations, self.allLocations);
	endif;

epilog

	delete allSoh;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doResize" id="d45d23be-7d9b-4a74-932d-ebc5e50de481">
        <updating/>
        <source>doResize() updating;
// ---------------------------------------------------------------------------
// Created:     02 April 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
