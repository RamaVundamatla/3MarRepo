    <JadeMethod name="flatRackEndsEnumToString" id="bdbe225c-7dcf-4d23-b884-a0dafa3e31de">
        <source>flatRackEndsEnumToString(_value : Integer) : String;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 04/11/2019	jlgdap1		Initial creation TFS 46405 AAT Flat Rack and OOG in LOLO Planning Screen
//
vars

begin
	if _value = TI_DOORSDIRN_ENDUP then
		return app.getErrorString(Ends_Up);
	elseif _value = TI_DOORSDIRN_ENDDOWN then
		return app.getErrorString(Ends_Down);
	endif;
	
	return null;
epilog

end;</source>
        <Parameter name="_value" type="Integer"/>
        <ReturnType type="String"/>
