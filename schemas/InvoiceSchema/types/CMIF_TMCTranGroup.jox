    </JadeMethod>
    <JadeMethod name="initialise" id="9cc19deb-4c77-4f46-b683-532a48ff56b9">
        <updating/>
        <source>initialise(_groupCount : Integer io) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 Feb 2020 cnwma1	Bug 48541: ADP - FW: transaction map error

*/

vars
	extractName : String;
	tiMap : CM_TIServiceMap;
	tmctig : CMIF_TMCTIGroup;
	resSB : CM_ResourceServiceBroker;
	restmc :	CMIF_TMCResourceGroup;
	evemc :	CMIF_TMCEventGroup;
	eveSB : CM_EventServiceBroker;
	ssSB : CM_SnapShotServiceBroker;
	ssmc : CMIF_TMCSSGroup;
	womc :	CMIF_TMCWorkOrderGroup;
	woSB : CM_WorkOrderServiceBroker;
	bolmc :	CMIF_TMCBOLTrxGroup;
	bolSB : CM_BOLServiceBroker;
begin
	self.myTMCController := self.myGroup.myTMCController;	// April 2010, cnwjre1, par 23659, invoice transaction map extract enhancements for Tranship IMEX status
	self.hidePictures := self.myTMCController.hidePictures;
	if self.myTranMapCargo &lt;&gt; null then
		foreach tiMap in myTranMapCargo.tiServiceMap do
			if tiMap.className = CM_TIServiceMap.DEFAULT_TI_MAP then
				create tmctig as CMIF_TMCTIDefaultGroup;
			else
				create tmctig;
			endif;
			tmctig.myTIServiceMap := tiMap;
			tmctig.itemName := tiMap.getTIClassName;
			tmctig.extractName := tiMap.getItemCode();	// 23659
			tmctig.myGroup := self;
			tmctig.initialise(_groupCount);
		endforeach;
	elseif self.myTranMapVTMIS &lt;&gt; null then
		foreach resSB in self.myTranMapVTMIS.allResourceSBs do
			if not global.isValidObject(resSB) then
				continue;
			endif;
			if resSB.myResource = null then
				create restmc as CMIF_TMCResourceGroupDefault;
				restmc.myResource := null;
			else
				create restmc;
				restmc.myResource := resSB.myResource;
			endif;
			restmc.myResourceBroker := resSB;
			if resSB.myResource &lt;&gt; null then
				restmc.itemName := resSB.myResource.description;
				if self.allGroupMembers[restmc.itemName] &lt;&gt; null then
					restmc.itemName := resSB.myResource.description &amp; resSB.myResource.code;
				endif;
				extractName 	   := resSB.myResource.code &amp; "| " &amp; resSB.myResource.description;		// 33095 use | delimiter for spaces in ids
				restmc.extractName := extractName;      //14.02.2020 cnwma1 #48541
			else
				restmc.itemName := "Default";
				restmc.extractName := CM_FinancialObject.Extract_Default;
			endif;
			restmc.myGroup := self;
			restmc.initialise(_groupCount);
		endforeach;
	elseif self.myTranMapEvent &lt;&gt; null then
		foreach eveSB in self.myTranMapEvent.allEventServiceBrokers discreteLock do
			if not global.isValidObject(eveSB) then
				continue;
			endif;
			if eveSB.myEventType = null then
				create evemc as CMIF_TMCEventGroupDefault transient;
				evemc.myEvent := null;
			else
				create evemc transient;
				evemc.myEventType := eveSB.myEventType;
			endif;
			evemc.myEventBroker := eveSB;
			if eveSB.myEventType &lt;&gt; null then
				evemc.itemName := eveSB.myEventType.name;
				if self.allGroupMembers[evemc.itemName] &lt;&gt; null then
					evemc.itemName := eveSB.myEventType.name;
				endif;
				evemc.extractName := eveSB.myEventType.type.String &amp; "| " &amp; eveSB.myEventType.name;		// 33095 use | delimiter for spaces in ids
			else
				evemc.itemName := "Default (Event)";
				evemc.extractName := CM_FinancialObject.Extract_Default;
			endif;
			evemc.myGroup := self;
			evemc.initialise(_groupCount);
		
		endforeach;

	elseif self.myTranMapSSSummary &lt;&gt; null then
		foreach ssSB in self.myTranMapSSSummary.allSnapShotServiceBrokers discreteLock do
			if not global.isValidObject(ssSB) then
				continue;
			endif;
			create ssmc;
			ssmc.mySnapShotBroker := ssSB;
			ssmc.itemName := ssSB.getDescription();
			ssmc.extractName := ssSB.getCode();
			ssmc.myGroup := self;
			ssmc.myTMCController := self.myTMCController;
			_groupCount := _groupCount + 1;
		endforeach;
	elseif self.myCurrentMapTMCargoAllocation &lt;&gt; null then // PAR 35833
	elseif self.myTranMapInventory &lt;&gt; null then // ### TFS 51219 25MAY2021 NAVAB1
	
	// ### TFS 39236
	elseif self.myTranMapWO &lt;&gt; null then
		foreach woSB in self.myTranMapWO.allWorkOrderSBs discreteLock do
			if not global.isValidObject(woSB) then
				continue;
			endif;
			if woSB.workOrderType = 0 then
				create womc as CMIF_TMCWorkOrderGroupDefault transient;
				womc.workOrderType := 0;
			else
				create womc transient;
				womc.workOrderType := woSB.workOrderType;
			endif;
			womc.myWOBroker := woSB;
			if woSB.workOrderType &lt;&gt; 0 then
				womc.itemName := woSB.getWorkOrderTypeDesc();
				if self.allGroupMembers[womc.itemName] &lt;&gt; null then
					womc.itemName := woSB.getWorkOrderTypeDesc();
				endif;
				womc.extractName := woSB.workOrderType.String &amp; "| " &amp; womc.itemName;	
			else
				womc.itemName := "Default (Work Order)";
				womc.extractName := CM_FinancialObject.Extract_Default;
			endif;
			womc.myGroup := self;
			womc.initialise(_groupCount);
		
		endforeach;

	//31 Oct 2019	NDL	TFS 47100
	elseif self.myTranMapBOL &lt;&gt; null then
		foreach bolSB in self.myTranMapBOL.allBOLServiceBrokers discreteLock do
			if not global.isValidObject(bolSB) then
				continue;
			endif;
			if bolSB.transactionType = 0 then
				create bolmc as CMIF_TMCBolTrxGroupDefault transient;
				bolmc.bolTrxType := 0;
			else
				create bolmc transient;
				bolmc.bolTrxType := bolSB.transactionType;
			endif;
			bolmc.myBOLBroker := bolSB;
			if bolSB.transactionType &lt;&gt; 0 then
				bolmc.itemName := bolSB.getBOLTypeDesc();
				if self.allGroupMembers[bolmc.itemName] &lt;&gt; null then
					bolmc.itemName := bolSB.getBOLTypeDesc();
				endif;
				bolmc.extractName := bolSB.transactionType.String &amp; "| " &amp; bolmc.itemName;	
			else
				bolmc.itemName := "Default (BOL)";
				bolmc.extractName := CM_FinancialObject.Extract_Default;
			endif;
			bolmc.myGroup := self;
			bolmc.initialise(_groupCount);
		
		endforeach;
		
	endif;
	
	_groupCount := _groupCount + 1;
end;</source>
        <Parameter name="_groupCount" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="loadList" id="3dfc3a64-76a4-4020-b7b0-2cbbf0b7a986">
        <source>loadList(listbox: ListBox; level: Integer);

vars
	tmc : CMIF_TranMapController;
	pic : Picture;

begin

	listbox.addItem(itemName);
	listbox.itemLevel[listbox.newIndex] := level;
	listbox.itemObject[listbox.newIndex] := self;
	pic := getPicture(listbox.form.INV_TransactionMap);
	if pic &lt;&gt; null then
		listbox.itemPicture[listbox.newIndex] := pic.picture;
	endif;

	foreach tmc in self.allGroupMembers do
		tmc.loadList(listbox, level + 1);
	endforeach;

end;</source>
        <Parameter name="listbox" type="ListBox"/>
        <Parameter name="level" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="populate" id="51683faf-ec0e-4b6b-a322-5ff86fb7cec0">
        <source>populate(listbox: ListBox; level: Integer; at : Integer);
// 35386
vars
	tmc : CMIF_TranMapController;
	pic : Picture;
	count	: Integer;
begin
	count := at;
	foreach tmc in self.allGroupMembers do
		listbox.addItemAt(tmc.itemName, count);
		listbox.itemLevel[listbox.newIndex] := level+1;
		listbox.itemObject[listbox.newIndex] := tmc;
		pic := getPicture(listbox.form.INV_TransactionMap);
		if pic &lt;&gt; null then
			listbox.itemPicture[listbox.newIndex] := pic.picture;
		endif;
		count := count + 1;
	endforeach;

end;</source>
        <Parameter name="listbox" type="ListBox"/>
        <Parameter name="level" type="Integer"/>
        <Parameter name="at" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setControllerCurrent" id="96c5596a-d695-4cfc-9f55-c3f24cc46c2e">
        <source>setControllerCurrent() ;
// April 2010, cnwjre1, par 23659, invoice transaction map extract enhancements for Tranship IMEX status
vars

begin
	inheritMethod();

	if self.myTranMapCargo &lt;&gt; null then // TRACKED ITEM
		
		myTMCController.myCurrentMapTM := self.myTranMapCargo;
	elseif self.myTranMapVTMIS &lt;&gt; null then // VOYAGE
		myTMCController.myCurrentMapTMVoyage := self.myTranMapVTMIS;
	elseif self.myTranMapEvent &lt;&gt; null then // EVENT
		myTMCController.myCurrentMapTMEvent := self.myTranMapEvent;
	elseif self.myTranMapWO &lt;&gt; null then // WORK ORDER
		myTMCController.myCurrentMapTMWO := self.myTranMapWO; // TFS 39236
	elseif self.myTranMapSSSummary &lt;&gt; null then // TFS 39236
		myTMCController.myCurrentMapTMSS := self.myTranMapSSSummary;
	elseif self.myCurrentMapTMCargoAllocation &lt;&gt; null then // PAR 35833
		myTMCController.myCurrentMapTMCargoAlloc := self.myCurrentMapTMCargoAllocation; // PAR 35833
	elseif self.myTranMapInventory &lt;&gt; null then  // ### TFS 51219 25MAY2021 NAVAB1
		myTMCController.myCurrentMapTMInventory := self.myTranMapInventory;  // ### TFS 51219 25MAY2021 NAVAB1
	
	elseif self.myTranMapBOL &lt;&gt; null then	//31 Oct 2019	NDL	TFS 47100
		myTMCController.myCurrentMapTMBOL := self.myTranMapBOL;	//31 Oct 2019	NDL	TFS 47100
		
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="setEnableObjects" id="e515b3bf-47da-4535-a54e-076305ae1ac1">
        <source>setEnableObjects(form: INV_TransactionMap io);

vars
	allowUpdates : Boolean;
begin
	allowUpdates := app.myCurrentUserCan(form.myTerminal, form.permissionMaint); // TFS 2734 CNWAB1
	
	
	inheritMethod(form);
	form.modePropertyUpdate := INV_TransactionMap.ModeProperty_TransMap;
	form.modePropertyDelete := INV_TransactionMap.ModeProperty_TransMap;
	
	// 23659 'question' methods added to extract, extract format enhanced so can be reloaded
	form.mnuTMExport.visible := allowUpdates; // TFS 2734 CNWAB1;
	form.mnuTMExport.enabled := allowUpdates; // TFS 2734 CNWAB1;
	form.btnExtractCSV.enabled := allowUpdates; // TFS 2734 CNWAB1;
	form.mnuTSExport.enabled := app.isDevelopmentSystem() or app.isSpecial(); 		// internal option to extract tranship-affected items
	form.mnuTSExport.visible := form.mnuTSExport.enabled;
	form.btnLoadCSV.visible := allowUpdates; // TFS 2734 CNWAB1;
	form.btnExtractCSV.visible := allowUpdates; // TFS 2734 CNWAB1;
	
	if self.myTranMapCargo &lt;&gt; null then
		form.modePropertyNew := INV_TransactionMap.ModeProperty_CargoType;
		form.menuTMVnew.visible := false;
		form.menuSItemNew.visible := allowUpdates; // TFS 2734 CNWAB1
		form.btnNew.enabled := allowUpdates; // TFS 2734 CNWAB1
	
		form.menuSINewContainer.visible := allowUpdates; // TFS 2734 CNWAB1
		form.menuSItemDelete.visible := allowUpdates; // TFS 2734 CNWAB1
		form.menuSItemDelete.enabled := allowUpdates; // TFS 2734 CNWAB1
		form.btnDelete.enabled := allowUpdates; // TFS 2734 CNWAB1
	
		form.menuSItemProperties.visible := allowUpdates; // TFS 2734 CNWAB1
		form.menuSItemProperties.enabled := allowUpdates; // TFS 2734 CNWAB1
		form.menuSItemProperties.userObject := self.myTranMapCargo;
		
		form.btnProperties.enabled := allowUpdates; // TFS 2734 CNWAB1
	
		form.menuMappingSetActive.visible := allowUpdates; // TFS 2734 CNWAB1
		if self.myTranMapCargo = self.myTMCController.myBank.currentTransactionMap then
			form.menuMappingSetActive.enabled := false;
			form.menuMappingSetActive.checked := allowUpdates; // TFS 2734 CNWAB1
			form.menuSItemDelete.visible := false;
			form.btnDelete.enabled := false;
		else

			form.menuMappingSetActive.enabled := allowUpdates; // TFS 2734 CNWAB1
			form.menuMappingSetActive.checked := false;
			form.menuSItemDelete.visible := allowUpdates; // TFS 2734 CNWAB1
			form.btnDelete.enabled := allowUpdates; // TFS 2734 CNWAB1
		endif;
	elseif self.myTranMapVTMIS &lt;&gt; null then
		
		form.modePropertyNew := INV_TransactionMap.ModeProperty_Resource;
		form.menuSItemNew.visible := false;
		form.menuTMVresource.visible := allowUpdates; // TFS 2734 CNWAB1;
		form.menuSItemDelete.visible := allowUpdates; // TFS 2734 CNWAB1;
		form.btnDelete.enabled := allowUpdates; // TFS 2734 CNWAB1;
	
		form.menuSItemProperties.visible := allowUpdates; // TFS 2734 CNWAB1;
		form.menuSItemProperties.userObject := self.myTranMapVTMIS;
		
		form.btnProperties.enabled := allowUpdates; // TFS 2734 CNWAB1;
	
		form.menuMappingSetActive.visible := allowUpdates; // TFS 2734 CNWAB1;
		if self.myTranMapVTMIS = self.myTMCController.myBank.myCurrentTranMapVoyage then

			form.menuMappingSetActive.enabled := false;
			form.menuMappingSetActive.checked := allowUpdates; // TFS 2734 CNWAB1;
			form.menuSItemDelete.visible := false;
			form.btnDelete.enabled := false;
		else

			form.menuMappingSetActive.enabled := allowUpdates; // TFS 2734 CNWAB1;
			form.menuMappingSetActive.checked := false;
			form.menuSItemDelete.visible := allowUpdates; // TFS 2734 CNWAB1;
			form.btnDelete.enabled := allowUpdates; // TFS 2734 CNWAB1;
		endif;

		form.menuTMVnew.visible := allowUpdates; // TFS 2734 CNWAB1;
		form.btnNew.enabled := allowUpdates; // TFS 2734 CNWAB1;
	elseif self.myTranMapEvent &lt;&gt; null then
		
		form.modePropertyNew := INV_TransactionMap.ModeProperty_Event;
		form.menuTMEevent.enabled := allowUpdates; // TFS 2734 CNWAB1;
		form.menuTMEevent.visible := allowUpdates; // TFS 2734 CNWAB1;
		form.menuSItemDelete.visible := allowUpdates; // TFS 2734 CNWAB1;
		form.menuSItemDelete.enabled := allowUpdates; // TFS 2734 CNWAB1;
		form.btnDelete.enabled := allowUpdates; // TFS 2734 CNWAB1;
	
		form.menuSItemProperties.enabled := allowUpdates; // TFS 2734 CNWAB1;
		form.menuSItemProperties.visible := allowUpdates; // TFS 2734 CNWAB1;
		form.menuSItemProperties.userObject := self.myTranMapEvent;
		
		form.btnProperties.enabled := allowUpdates; // TFS 2734 CNWAB1;
	
		form.menuMappingSetActive.visible := allowUpdates; // TFS 2734 CNWAB1;
		if self.myTranMapEvent = self.myTMCController.myBank.myCurrentTranMapEvent then

			form.menuMappingSetActive.enabled := false;
			form.menuMappingSetActive.checked := allowUpdates; // TFS 2734 CNWAB1;
			form.menuSItemDelete.enabled := false;
			form.menuSItemDelete.visible := false;
			form.btnDelete.enabled := false;
		else

			form.menuMappingSetActive.enabled := allowUpdates; // TFS 2734 CNWAB1;
			form.menuMappingSetActive.checked := false;
			form.menuSItemDelete.visible := allowUpdates; // TFS 2734 CNWAB1;
			form.menuSItemDelete.enabled := allowUpdates; // TFS 2734 CNWAB1;
			form.btnDelete.enabled := allowUpdates; // TFS 2734 CNWAB1;
		endif;
		form.menuTMEnew.enabled := allowUpdates; // TFS 2734 CNWAB1;
		form.menuTMEnew.visible := allowUpdates; // TFS 2734 CNWAB1;
		form.btnNew.enabled := allowUpdates; // TFS 2734 CNWAB1;
		
	//31 Oct 2019	NDL	TFS 47100
	elseif self.myTranMapBOL &lt;&gt; null then
		
		form.modePropertyNew := INV_TransactionMap.ModeProperty_BOL;
		form.menuTMBOLTrx.enabled := allowUpdates; 
		form.menuTMBOLTrx.visible := allowUpdates; 
		form.menuSItemDelete.visible := allowUpdates; 
		form.menuSItemDelete.enabled := allowUpdates; 
		form.btnDelete.enabled := allowUpdates; 
	
		form.menuSItemProperties.enabled := allowUpdates; 
		form.menuSItemProperties.visible := allowUpdates; 
		form.menuSItemProperties.userObject := self.myTranMapBOL;
		
		form.btnProperties.enabled := allowUpdates; 
	
		form.menuMappingSetActive.visible := allowUpdates; 
		if self.myTranMapBOL = self.myTMCController.myBank.myCurrentTranMapBOL then

			form.menuMappingSetActive.enabled := false;
			form.menuMappingSetActive.checked := allowUpdates; 
			form.menuSItemDelete.enabled := false;
			form.menuSItemDelete.visible := false;
			form.btnDelete.enabled := false;
		else

			form.menuMappingSetActive.enabled := allowUpdates; 
			form.menuMappingSetActive.checked := false;
			form.menuSItemDelete.visible := allowUpdates; 
			form.menuSItemDelete.enabled := allowUpdates; 
			form.btnDelete.enabled := allowUpdates; 
		endif;
		form.menuTMBOLnew.enabled := allowUpdates; 
		form.menuTMBOLnew.visible := allowUpdates; 
		form.btnNew.enabled := allowUpdates;
		
	elseif self.myTranMapWO &lt;&gt; null then // TFS 39236
		
		form.modePropertyNew := INV_TransactionMap.ModeProperty_WorkOrder;
		form.menuTMWorkOrder.enabled := allowUpdates; 
		form.menuTMWorkOrder.visible := allowUpdates; 
		form.menuSItemDelete.visible := allowUpdates; 
		form.menuSItemDelete.enabled := allowUpdates; 
		form.btnDelete.enabled := allowUpdates; 
	
		form.menuSItemProperties.enabled := allowUpdates; 
		form.menuSItemProperties.visible := allowUpdates; 
		form.menuSItemProperties.userObject := self.myTranMapWO;
		
		form.btnProperties.enabled := allowUpdates; 
	
		form.menuMappingSetActive.visible := allowUpdates; 
		if self.myTranMapWO = self.myTMCController.myBank.myCurrentTranMapWorkOrder then

			form.menuMappingSetActive.enabled := false;
			form.menuMappingSetActive.checked := allowUpdates; 
			form.menuSItemDelete.enabled := false;
			form.menuSItemDelete.visible := false;
			form.btnDelete.enabled := false;
		else

			form.menuMappingSetActive.enabled := allowUpdates; 
			form.menuMappingSetActive.checked := false;
			form.menuSItemDelete.visible := allowUpdates; 
			form.menuSItemDelete.enabled := allowUpdates; 
			form.btnDelete.enabled := allowUpdates; 
		endif;
		form.menuTMWOnew.enabled := allowUpdates; 
		form.menuTMWOnew.visible := allowUpdates; 
		form.btnNew.enabled := allowUpdates; 
	
	
	elseif self.myTranMapSSSummary &lt;&gt; null then	
		form.modePropertyNew := INV_TransactionMap.ModeProperty_SnapShot;
		form.menuTMSinv.enabled := allowUpdates; // TFS 2734 CNWAB1;
		form.menuTMSinv.visible := allowUpdates; // TFS 2734 CNWAB1;
		form.menuSItemDelete.visible := allowUpdates; // TFS 2734 CNWAB1;
		form.menuSItemDelete.enabled := allowUpdates; // TFS 2734 CNWAB1;
		form.btnDelete.enabled := allowUpdates; // TFS 2734 CNWAB1;
		form.mnuTSExport.visible := false;
	
		form.menuSItemProperties.enabled := allowUpdates; // TFS 2734 CNWAB1;
		form.menuSItemProperties.visible := allowUpdates; // TFS 2734 CNWAB1
		form.menuSItemProperties.userObject := self.myTranMapSSSummary;
		
		form.btnProperties.enabled := allowUpdates; // TFS 2734 CNWAB1;
	
		form.menuMappingSetActive.visible := allowUpdates; // TFS 2734 CNWAB1;
		if self.myTranMapSSSummary = self.myTMCController.myBank.myCurrentTranMapSnapShot then

			form.menuMappingSetActive.enabled := false;
			form.menuMappingSetActive.checked := allowUpdates; // TFS 2734 CNWAB1;
			form.menuSItemDelete.enabled := false;
			form.menuSItemDelete.visible := false;
			form.btnDelete.enabled := false;
		else

			form.menuMappingSetActive.enabled := allowUpdates; // TFS 2734 CNWAB1;
			form.menuMappingSetActive.checked := false;
			form.menuSItemDelete.visible := allowUpdates; // TFS 2734 CNWAB1;
			form.menuSItemDelete.enabled := allowUpdates; // TFS 2734 CNWAB1;
			form.btnDelete.enabled := allowUpdates; // TFS 2734 CNWAB1;
		endif;
		form.menuTMSnew.enabled := allowUpdates; // TFS 2734 CNWAB1;
		form.menuTMSnew.visible := allowUpdates; // TFS 2734 CNWAB1;
		form.btnNew.enabled := true;
	elseif self.myCurrentMapTMCargoAllocation &lt;&gt; null then	// PAR 35833
		form.modePropertyNew := INV_TransactionMap.ModeProperty_CargoAlloc;
		form.modePropertyUpdate := INV_TransactionMap.ModeProperty_CargoAlloc;
		form.menuSItemDelete.visible := allowUpdates; // TFS 2734 CNWAB1;
		form.menuSItemDelete.enabled := allowUpdates; // TFS 2734 CNWAB1;
		form.btnDelete.enabled := allowUpdates; // TFS 2734 CNWAB1;
		form.menuTMSnew.visible := false;
	
		form.menuSItemProperties.enabled := allowUpdates; // TFS 2734 CNWAB1;
		form.menuSItemProperties.visible := allowUpdates; // TFS 2734 CNWAB1;
		form.menuSItemProperties.userObject := self.myCurrentMapTMCargoAllocation;
		form.mnuTMExport.visible := false;
		form.mnuTSExport.visible := false;
		form.btnLoadCSV.visible := false;
		form.btnExtractCSV.visible := false;
		
		form.btnProperties.enabled := allowUpdates; // TFS 2734 CNWAB1;
	
		form.menuMappingSetActive.visible := allowUpdates; // TFS 2734 CNWAB1;
		if self.myCurrentMapTMCargoAllocation = self.myTMCController.myBank.myCurrentTranMapCargoAlloc then

			form.menuMappingSetActive.enabled := false;
			form.menuMappingSetActive.checked := allowUpdates; // TFS 2734 CNWAB1;
			form.menuSItemDelete.enabled := false;
			form.menuSItemDelete.visible := false;
			form.btnDelete.enabled := false;
		else

			form.menuMappingSetActive.enabled := allowUpdates; // TFS 2734 CNWAB1;
			form.menuMappingSetActive.checked := false;
			form.menuSItemDelete.visible := allowUpdates; // TFS 2734 CNWAB1;
			form.menuSItemDelete.enabled := allowUpdates; // TFS 2734 CNWAB1;
			form.btnDelete.enabled := allowUpdates; // TFS 2734 CNWAB1;
		endif;
	elseif self.myTranMapInventory &lt;&gt; null then	 // ### TFS 51219 25MAY2021 NAVAB1
		form.modePropertyNew := INV_TransactionMap.ModeProperty_Inventory;
		form.modePropertyUpdate := INV_TransactionMap.ModeProperty_Inventory;
		form.menuSItemDelete.visible := allowUpdates; 
		form.menuSItemDelete.enabled := allowUpdates; 
		form.btnDelete.enabled := allowUpdates; 
		form.menuTMSnew.visible := false;
	
		form.menuSItemProperties.enabled := allowUpdates; 
		form.menuSItemProperties.visible := allowUpdates; 
		form.menuSItemProperties.userObject := self.myCurrentMapTMCargoAllocation;
		form.mnuTMExport.visible := false;
		form.mnuTSExport.visible := false;
		form.btnLoadCSV.visible := false;
		form.btnExtractCSV.visible := false;
		
		form.btnProperties.enabled := allowUpdates; 
	
		form.menuMappingSetActive.visible := allowUpdates;
		
		if self.myTranMapInventory = self.myTMCController.myBank.myCurrentTranMapInventory then

			form.menuMappingSetActive.enabled := false;
			form.menuMappingSetActive.checked := allowUpdates; 
