    <JadeMethod name="getTSWType" id="404af4c4-d52e-4027-8431-088125d21214">
        <source>getTSWType() : String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26 Jul 2018	jlgsl4	TFS 39133 - Trade Single Window

*/

vars
	type : String;
begin
	if self.messageMode = Agency_MPI then
		type := "MPIBIO ";
	else
		type := "NZCS ";
	endif;
	if self.isTSWExport() then
		type := type &amp; "Export ";
	else
		type := type &amp; "Import ";
	endif;
	if self.isToBeTSWHeld() then
		type := type &amp; "Hold";
	else
		type := type &amp; "Clearance";
	endif;
	return type;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
