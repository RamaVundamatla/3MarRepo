    <JadeMethod name="loadResourceBooked" id="84f68568-5b45-4d26-91e8-a7c46f43bc5f">
        <source>loadResourceBooked(_resourceBookedProxy:HMS_ResourceBooked io) :Boolean protected;

vars
	realHMSTransaction: HMS_Transaction;
//	realObject, proxyObject: HMS_ResourceBooked;
	error: CM_Error;
	theTerminal: CM_Terminal;
	transController: CMIF_HMS_TransactionController;
	workingMovementCtrl: CMIF_HMS_WorkingMovement;
//	countError,countOK: Integer;
begin
//	if _resourceBookedProxy.myPassageeMovement = null then
//		app.writeLog(class.name&amp;'::'&amp;method.name&amp;' '&amp;_resourceBookedProxy.transactionDT.String&amp;" ERROR: "&amp;"No Voyage Movement.",0);
//		return false;
//	endif;
	if _resourceBookedProxy.myResourceUsed = null then
		app.writeLog(class.name&amp;'::'&amp;method.name&amp;' '&amp;_resourceBookedProxy.transactionDT.String&amp;" ERROR: "&amp;"No Resoure Used.",0);
		return false;
	endif;
	beginTransaction;
	create transController transient;
	create workingMovementCtrl transient;
	transController.myWorkingMovement := workingMovementCtrl;
	theTerminal := app.myPassport.myTerminal;

//	transController.myVoyageMovement := _resourceBookedProxy.myPassageeMovement;
//	transController.myHMSVoyageData := _resourceBookedProxy.myPassageeMovement.myHMSVoyageData;
//	transController.myTerminal := _resourceBookedProxy.myPassageeMovement.myHMSVoyageData.getMyTerminal();
	transController.myResourceUsed := _resourceBookedProxy.myResourceUsed;
	transController.myResource := _resourceBookedProxy.myResourceUsed.myResource;
	transController.type := TRANS_TYPE_ResourceBooked;
	
	realHMSTransaction := transController.createConversionTransaction(app.myPassport);
	if app.myPassport.allErrorWarnings.size = 0 and 
	   realHMSTransaction &lt;&gt; null then
		realHMSTransaction.setPropertyValue("userCode",_resourceBookedProxy.userCode);
		realHMSTransaction.setPropertyValue("userName",_resourceBookedProxy.userName);
		realHMSTransaction.setPropertyValue("transactionDT",_resourceBookedProxy.transactionDT);
		commitTransaction;
		return true;
	else
		abortTransaction;
		foreach error in app.myPassport.allErrors do
			app.writeLog(class.name&amp;'::'&amp;method.name&amp;' '&amp;_resourceBookedProxy.transactionDT.String&amp;" ERROR: "&amp;error.text,0);
		endforeach;
		return false;
	endif;
epilog
	delete transController;
	delete workingMovementCtrl;

end;</source>
        <access>protected</access>
        <Parameter name="_resourceBookedProxy" type="HMS_ResourceBooked" usage="io"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="loadResourceCancelled" id="d135d598-2333-47f9-9dca-432a353490c8">
        <source>loadResourceCancelled(_resourceCancelledProxy:HMS_ResourceCancelled io) :Boolean protected;

vars
	realHMSTransaction: HMS_Transaction;
//	realObject, proxyObject: HMS_ResourceCancelled;
	error: CM_Error;
	theTerminal: CM_Terminal;
	transController: CMIF_HMS_TransactionController;
	workingMovementCtrl: CMIF_HMS_WorkingMovement;
//	countError,countOK: Integer;
begin
//	if _resourceCancelledProxy.myPassageeMovement = null then
//		app.writeLog(class.name&amp;'::'&amp;method.name&amp;' '&amp;_resourceCancelledProxy.transactionDT.String&amp;" ERROR: "&amp;"No Voyage Movement.",0);
//		return false;
//	endif;
	if _resourceCancelledProxy.myResource = null then
		app.writeLog(class.name&amp;'::'&amp;method.name&amp;' '&amp;_resourceCancelledProxy.transactionDT.String&amp;" ERROR: "&amp;"No Resource.",0);
		return false;
	endif;
//			self.myResourceUsedArchived := resourceUsed;
//			self.myResource := self.myResourceUsedArchived.myResource;
	beginTransaction;
	create transController transient;
	create workingMovementCtrl transient;
	transController.myWorkingMovement := workingMovementCtrl;
	theTerminal := app.myPassport.myTerminal;

//	transController.myVoyageMovement := _resourceCancelledProxy.myPassageeMovement;
//	transController.myHMSVoyageData := _resourceCancelledProxy.myPassageeMovement.myHMSVoyageData;
//	transController.myTerminal := _resourceCancelledProxy.myPassageeMovement.myHMSVoyageData.getMyTerminal();
	transController.myResource := _resourceCancelledProxy.myResource;
//	transController.myResourceUsed := _resourceCancelledProxy.myResourceUsedArchived;
	transController.type := TRANS_TYPE_ResourceCancelled;
	
	realHMSTransaction := transController.createConversionTransaction(app.myPassport);
	if app.myPassport.allErrorWarnings.size = 0 and 
	   realHMSTransaction &lt;&gt; null then
		realHMSTransaction.setPropertyValue("userCode",_resourceCancelledProxy.userCode);
		realHMSTransaction.setPropertyValue("userName",_resourceCancelledProxy.userName);
		realHMSTransaction.setPropertyValue("transactionDT",_resourceCancelledProxy.transactionDT);
		commitTransaction;
		return true;
	else
		abortTransaction;
		foreach error in app.myPassport.allErrors do
			app.writeLog(class.name&amp;'::'&amp;method.name&amp;' '&amp;_resourceCancelledProxy.transactionDT.String&amp;" ERROR: "&amp;error.text,0);
		endforeach;
		return false;
	endif;
epilog
	delete transController;
	delete workingMovementCtrl;

end;</source>
        <access>protected</access>
        <Parameter name="_resourceCancelledProxy" type="HMS_ResourceCancelled" usage="io"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="loadResourceType" id="7d50b8cc-b285-44d5-aa99-94d72e2d55e5">
        <source>loadResourceType(_resourceTypeProxy:HMS_ResourceType io) :Boolean protected;

vars
	realObject, proxyObject: HMS_ResourceType;
	error: CM_Error;
	countError,countOK: Integer;
begin
	realObject := app.myRoot.allResourceTypes[_resourceTypeProxy.code];
	if realObject = null then
		app.myTrxCA.trxCreateHMSResourceType(_resourceTypeProxy, realObject, app.myPassport);
	else
		app.writeLog(class.name&amp;'::'&amp;method.name&amp;' '&amp;_resourceTypeProxy.code&amp;" ERROR: "&amp;"Resource Type already exists.",0);
		return false;
	endif;
	if app.myPassport.trxCompletedOK and
	   app.myPassport.allErrorWarnings.size = 0 then
		return true;
	else
		foreach error in app.myPassport.allWarnings do
			app.writeLog(class.name&amp;'::'&amp;method.name&amp;' '&amp;_resourceTypeProxy.code&amp;" WARNING: "&amp;error.text,0);
		endforeach;
		foreach error in app.myPassport.allErrors do
			app.writeLog(class.name&amp;'::'&amp;method.name&amp;' '&amp;_resourceTypeProxy.code&amp;" ERROR: "&amp;error.text,0);
		endforeach;
		return false;
	endif;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_resourceTypeProxy" type="HMS_ResourceType" usage="io"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="loadResourceUsed" id="70170f94-06d5-4c4f-9d25-b78c8aee33cd">
        <source>loadResourceUsed(_resourceUsedProxy:HMS_ResourceUsed io) :Boolean protected;

vars
	realObject: HMS_Object;
	usedResource, proxyObject: HMS_ResourceUsed;
	error: CM_Error;
	found: Boolean;
	countError,countOK: Integer;
	theResource: HMS_Resource;
begin
	if _resourceUsedProxy.myVoyageMovement = null then
		app.writeLog(class.name&amp;'::'&amp;method.name&amp;' '&amp;_resourceUsedProxy.code&amp;" ERROR: "&amp;"No VoyageMovement.",0);
		return false;
	endif;
	if _resourceUsedProxy.myResource = null then
		app.writeLog(class.name&amp;'::'&amp;method.name&amp;' '&amp;_resourceUsedProxy.code&amp;" ERROR: "&amp;"No Resource.",0);
		return false;
	endif;
	if _resourceUsedProxy.myHarbour = null then
		app.writeLog(class.name&amp;'::'&amp;method.name&amp;' '&amp;_resourceUsedProxy.code&amp;" ERROR: "&amp;"No Harbour.",0);
		return false;
	endif;
	found := false;
	theResource := _resourceUsedProxy.myResource;
//	if theResource = null then
//		theResource := _resourceUsedProxy.myResourceArchive;
//	endif;
	if theResource &lt;&gt; null then
		foreach usedResource in theResource.allResourceUsed do
			if usedResource.code = _resourceUsedProxy.code then
				found := true;
				break;
			endif;
		endforeach;
	endif;
	if not found then
		app.myTrxCA.trxCreateHMSObject(_resourceUsedProxy, realObject, app.myPassport);
	else
		app.writeLog(class.name&amp;'::'&amp;method.name&amp;' '&amp;_resourceUsedProxy.code&amp;" ERROR: "&amp;"Resource Used already exists.",0);
		return false;
	endif;
	if app.myPassport.trxCompletedOK and
	   app.myPassport.allErrorWarnings.size = 0 then
		return true;
	else
		foreach error in app.myPassport.allWarnings do
			app.writeLog(class.name&amp;'::'&amp;method.name&amp;' '&amp;_resourceUsedProxy.code&amp;" WARNING: "&amp;error.text,0);
		endforeach;
		foreach error in app.myPassport.allErrors do
			app.writeLog(class.name&amp;'::'&amp;method.name&amp;' '&amp;_resourceUsedProxy.code&amp;" ERROR: "&amp;error.text,0);
		endforeach;
		return false;
	endif;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_resourceUsedProxy" type="HMS_ResourceUsed" usage="io"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
