    <JadeMethod name="getHeavyDuty" id="13f53c04-6176-4b69-80c8-40aed03d2ff8">
        <source>getHeavyDuty() : String;
//
// Purpose:	ALSO USED IN SQL EXTRACTS - DO NOT DELETE
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 09/06/2016	cnwdap1		Initial creation POL TFS #1963 SQL Extract for Bulk Releases
// 07/10/2024   navma1		MTN - 32769 TPT | 1011 with 2 x Group Group ID's on a Release Request
//
vars
	detail : CM_ReserveDetail;
	rtnStr : String;
begin
	foreach detail in self.allReserveDetails discreteLock do
		if detail.isReserveSelection then
			rtnStr := rtnStr &amp; " " &amp; detail.CM_ReserveSelection.heavyRated.getYesNo; //07.10.2024 navma1 #MTN - 32769
		endif;
	endforeach;
	
	rtnStr :=  rtnStr.trimBlanks;
	return rtnStr;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getISOCode" id="5550b38f-602d-430b-8372-66b4ffd455c4">
        <source>getISOCode():String;
// ---------------------------------------------------------------------------
// Created:		25 July 2003  by Jason Chapman  (cnwjc2)
//	For reports
// ---------------------------------------------------------------------------

vars
	res : CM_ReserveDetail;
begin
	
	res := self.allReserveDetails.first;
	if res = null then
		return null;
	endif;
	
	if res.isKindOf(CM_ReserveSelection) and res.CM_ReserveSelection.myISOType &lt;&gt; null then
		return res.CM_ReserveSelection.myISOType.code;
	endif;
	
	return null;
end;</source>
