    <JadeMethod name="loadCmbGateLane" id="2fe16dda-af4b-442b-88bf-a78574d55c3e">
        <source>loadCmbGateLane();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 February 2017	cnwns1	Initial creation

*/
constants
	
vars

	gate 		: CM_Gate;
	gateArea 	: CM_GateArea;
	laneNumber	: Integer;
	laneCont	: CM_GateAreaLaneController;	
	index 		: Integer;
	inLanesSet 	: CM_ObjectSet;
	outLanesSet : CM_ObjectSet;
	laneObj		: Object;
	usage		: CM_GateAreaUsage;
begin
	
	cmbGateLane.clear();

	create inLanesSet transient;
	create outLanesSet transient;
	
	foreach gate in self.myTerminal.allGates do
		if gate.allGateAreas_IN.size &gt; 0 then
			foreach usage in gate.allGateAreas_IN do
				gateArea := usage.myGateArea;
				if gateArea &lt;&gt; null and gateArea.areaType = CM_GateArea.AreaType_P then
					if gateArea.laneCount &gt; 0 then
						foreach laneNumber  in 1 to gateArea.laneCount	do	
							laneCont := gateArea.getLaneByNumber(laneNumber).CM_GateAreaLaneController;
							if not inLanesSet.includes(laneCont) then	
								inLanesSet.add(laneCont);
							endif;
						endforeach;
					else	
						laneCont := gateArea.getLaneByNumber(1).CM_GateAreaLaneController;
						if not inLanesSet.includes(laneCont) then
							inLanesSet.add(laneCont);
						endif;	
					endif;	
				endif;
			endforeach;
			
		endif;
		
		if gate.allGateAreas_OUT.size &gt; 0 then
			foreach usage in gate.allGateAreas_OUT do
				gateArea := usage.myGateArea;
				if gateArea &lt;&gt; null and gateArea.areaType = CM_GateArea.AreaType_P then
					if gateArea.laneCount &gt; 0 then
						foreach laneNumber  in 1 to gateArea.laneCount	do	
						laneCont := gateArea.getLaneByNumber(laneNumber).CM_GateAreaLaneController;
							if not outLanesSet.includes(laneCont) then
								outLanesSet.add(laneCont);
							endif;
						endforeach;
					else	
					laneCont := gateArea.getLaneByNumber(1).CM_GateAreaLaneController;
						if not outLanesSet.includes(laneCont) then
							outLanesSet.add(laneCont);
						endif;	
					endif;	
				endif;
			endforeach;
		
		endif;	
	endforeach;
	
	index := self.cmbGateLane.addItem(null  );
	self.cmbGateLane.itemObject[index] := null;	
	
	
	foreach laneObj in inLanesSet reversed do
		laneCont := laneObj.CM_GateAreaLaneController;
		if outLanesSet.includes(laneObj) then
			index := self.cmbGateLane.addItem(laneCont.getGateLaneNumber  );
			self.cmbGateLane.itemObject[index] := laneCont;	
		else
			index := self.cmbGateLane.addItem(laneCont.getGateLaneNumber );
			self.cmbGateLane.itemObject[index] := laneCont;	
		endif;
	endforeach;
	
	foreach laneObj in outLanesSet reversed do		
		if not inLanesSet.includes(laneObj) then
			laneCont := laneObj.CM_GateAreaLaneController;
			index := self.cmbGateLane.addItem(laneCont.getGateLaneNumber );
			self.cmbGateLane.itemObject[index] := laneCont;	
		endif;
	endforeach;
		
	delete outLanesSet;
	delete inLanesSet;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="loadCmbMeasureType" id="c1ea26af-8bbf-40d4-84ce-d80e7994a4ab">
        <source>loadCmbMeasureType(measurement : CM_MeasurementType);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 June 2022	navhl20	ChangeRequest 53862: EUP - WMS - Damage Recording Extra Details

*/

vars
	measure : CM_MeasurementType;
begin
	self.cmbMeasureType.clear;
	foreach measure in app.myRoot.allMeasurementTypesByShortName where measure.measurementType = Type_Linear and measure.isDisplay do
		self.cmbMeasureType.itemObject[ self.cmbMeasureType.addItem( measure.name ) ] := measure;
	endforeach;

	if measurement &lt;&gt; null then
		self.cmbMeasureType.listIndex := self.cmbMeasureType.findObject(measurement);
	endif;
epilog

end;</source>
        <Parameter name="measurement" type="CM_MeasurementType"/>
    </JadeMethod>
