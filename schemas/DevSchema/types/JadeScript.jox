    <JadeMethod name="rsPar37738" id="46ccf136-adfa-4e31-852e-cfd6e60601bb">
        <source>rsPar37738();

constants
	TrainCode : String = "WL01ATRAIN";
	WagonClassCode : String = "WLA";
	RailAreaId : String = "WLRAA";
	BlockStack : String = "UT_BS6";
	WagonId1 : String = "WL01A";
vars
	ti1:CM_TrackedItem;
	ti2:CM_TrackedItem;
	lc1:CM_WellcarWagonController;
	lc2:CM_WellcarWagonController;
	str:String;
	terminal : CM_Terminal;
begin
	app.initialize();
	app.myPassport.setMyUserFromCode('SUPERUSER');
	terminal := app.myRoot.allTerminals["UT"];
	beginTransaction;
	terminal.setConfig(RailDefaultWCIdFormat, Rail_JMT_Int); //Rail_UPSP_Int);
	commitTransaction;
	ti1 := terminal.lookupTrackedItem("UTWLAA22002", 1, TI_STATE_NORMAL, "", false); //UTWLAA22002
	ti2 := terminal.lookupTrackedItem("UTWLAA22003", 1, TI_STATE_NORMAL, "", false); //UTWLAA22003
	lc1 := ti1.allQueuedFutureMoves.first.CM_FutureMoveQueued.allLocationsControllers.first.CM_WellcarWagonController;
	lc2 := ti2.allQueuedFutureMoves.first.CM_FutureMoveQueued.allLocationsControllers.first.CM_WellcarWagonController;
//	lc1 := '8253.11568'.asOid.CM_WellcarWagonController;
//	lc2 := '8253.11572'.asOid.CM_WellcarWagonController;
	str := "getIdUPSPformat"&amp;CrLf;
	str := str &amp; lc1.CM_WellcarWagonController.getIdUPSPformat(null) &amp; CrLf;
	str := str &amp; lc2.CM_WellcarWagonController.getIdUPSPformat(null) &amp;CrLf;
	str := str &amp; lc1.CM_WellcarWagonController.getIdUPSPformat(ti1) &amp;CrLf;
	str := str &amp; lc2.CM_WellcarWagonController.getIdUPSPformat(ti2) &amp;CrLf;
	write str;
	str := "getFullId"&amp;CrLf;
	str := str&amp;lc1.getFullId&amp;CrLf;
	str := str&amp;lc2.getFullId&amp;CrLf;
	str := str&amp;lc1.getFullIdTI(ti1)&amp;CrLf;
	str := str&amp;lc2.getFullIdTI(ti2)&amp;CrLf;
	write str;
	str := "ident"&amp;CrLf;
	str := str&amp;lc1.ident&amp;CrLf;
	str := str&amp;lc2.ident&amp;CrLf;
	write str;
end;</source>
    </JadeMethod>
    <JadeMethod name="rsPar38364" id="efd59988-abb3-44b5-86ac-c8e30db7c0ec">
        <source>rsPar38364();
//
// 03 Nav 2016	cnwrs1	2892*:PAR38364 C3 - CreateLogDocket Webservice
vars
