    <JadeMethod name="cmbTILCType_change" id="60447b12-fa4e-4ba7-a077-9f810169255f">
        <controlMethod name="ComboBox::change"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbTILCType_change(combobox: ComboBox input) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
03 December 2008	cnwrd1	Initial creation
17 May 2018	jlgma1	Bug 38541: PENN - Chassis Maintenance
15/05/2025	navcs2	MTN-34843  Development - Fleet file Form implementation

*/

vars
	cargoType  	: CM_CargoType;
	tilcType 	: CM_TILCType;
	
begin

	tilcType := combobox.itemObject[cmbTILCType.listIndex].CM_TILCType;
	if tilcType &lt;&gt; null then
		cargoType := tilcType.myCargoType;
		self.allStopsForUser.clear();
		self.allToDoTasksForUser.clear();
		self.lstTblStops.clearTable();
		self.lstTblToDoTasks.clearTable();
		
		self.myAssistant.listTableStopsTableSysUser( self.lstTblStops, cargoType, self.allStopsForUser, true);
		self.myAssistant.listTableToDoTasksSysUser( self.lstTblToDoTasks,cargoType, self.allToDoTasksForUser );	//self.myAssistant.listTableToDoTasks(self.lstToDoTasks,self.myTerminal);
		
		if tilcType.isMAFI then					// 15/05/2025	navcs2	MTN-34843
			self.cmbFloorType.visible := true;	// 15/05/2025	navcs2	MTN-34843
		else									// 15/05/2025	navcs2	MTN-34843
			self.cmbFloorType.visible := false;	// 15/05/2025	navcs2	MTN-34843
		endif;									// 15/05/2025	navcs2	MTN-34843
	
	endif;
	
	
epilog

end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="cmbTILCType_closeup" id="4cb53835-6176-42ba-8977-5940cc9ff7bd">
        <controlMethod name="ComboBox::closeup"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbTILCType_closeup(combobox: ComboBox input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 May 2018	jlgma1	Bug 38541: PENN - Chassis Maintenance

*/

vars
	cargoType  	: CM_CargoType;
	tilcType 	: CM_TILCType;
	measure     : CM_MeasurementType;
begin
	if  cmbTILCType.listIndex &lt;&gt; -1 then
		tilcType := combobox.itemObject[cmbTILCType.listIndex].CM_TILCType;
	endif;
	if tilcType &lt;&gt; null then
		cargoType := tilcType.myCargoType;
		self.allStopsForUser.clear();
		self.allToDoTasksForUser.clear();
		self.lstTblStops.clearTable();
		self.lstTblToDoTasks.clearTable();
		
		self.myAssistant.listTableStopsTableSysUser( self.lstTblStops, cargoType, self.allStopsForUser, true);
		self.myAssistant.listTableToDoTasksSysUser( self.lstTblToDoTasks,cargoType, self.allToDoTasksForUser );
		measure := app.getDefaultMeasurementForType(Type_Weight);	                                       //15.5.2018 cnwma1	Bug 38541
		self.txtWeight.text	:= app.convertMeasurementForDisplay(measure.shortName, tilcType.tareWeight);   //1
	endif;
epilog

end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
    </JadeMethod>
