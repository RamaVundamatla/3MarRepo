    <JadeMethod name="doClickAdd" id="99f9883a-58f2-4074-9924-9a140f7812a8">
        <updating/>
        <source>doClickAdd() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 July 2020	jlgndl1	Initial creation	TFS 49579

*/

vars

begin

	self.unselectAllRowsDeleteProxies();
	
	create self.myProxyReeferBlock transient;
	self.populateReeferWalkPositions();
	
	self.setButtons();

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doClickCmbGriddedArea" id="4e793a84-ae81-4d93-a8d6-64d2545495b0">
        <updating/>
        <source>doClickCmbGriddedArea()updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 July 2020	jlgndl1	Initial creation	TFS 49579

*/

vars

	ta : CM_TerminalArea;
	reeferBlock: CM_ReeferBlock;
	rowIndex : Integer;

begin

	self.unselectAllRowsDeleteProxies(); 
	
	self.populateReeferWalkPositions();

	self.tblReeferWalkBlocks.enabled := false;
	self.grpWalkPositions.enabled := false;

	self.tblReeferWalkBlocks.rows := 1;
	ta := self.cmbGridTermArea.listObject.CM_TerminalArea;
	if ta = null then
		return;
	endif;
	
	foreach reeferBlock in ta.allReeferBlocks do
		rowIndex := self.tblReeferWalkBlocks.addItem( reeferBlock.name );
		self.tblReeferWalkBlocks.accessRow( rowIndex ).itemObject := reeferBlock;
	endforeach;
	
	self.tblReeferWalkBlocks.enabled := true;
	self.grpWalkPositions.enabled := true;
	
	self.setButtons();

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doClickDelete" id="dbdcee1c-4365-4532-9feb-5d6386de6c4a">
        <updating/>
        <source>doClickDelete()updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 July 2020	jlgndl1	Initial creation	TFS 49579

*/

vars

	result : Integer;
	selectedObj : CM_Object;

begin

	if self.mySelectedReeferBlock &lt;&gt; null then
	
		while true do
		
			app.myTrxDA.trxDeleteReeferBlock( self.mySelectedReeferBlock, app.myPassport );
					  	  
			if app.myPassport.trxCompletedOK then
				self.doClickCmbGriddedArea();
				break;
				
			else
				result := app.showErrorWarningDialog(self.caption, app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
				if app.myPassport.noErrors and
				   result = IDOK then
					app.myPassport.warningsAcknowledged	:= true;
					continue;
				endif;
			endif;
			
			break;
			
		endwhile;
		
	endif;

	self.setButtons();

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doClickUpdate" id="fd8c6d7c-8842-44cd-bd54-7555240f7173">
        <updating/>
        <source>doClickUpdate()updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 July 2020	jlgndl1	Initial creation	TFS 49579

*/

vars

	blockName : String;
	reeferWalkPositionArray : CM_ReeferBlockPositionArray;
	terminalArea : CM_TerminalArea;
	result : Integer;
	
begin

	create reeferWalkPositionArray transient;
	
	if not self.validateForUpdate( blockName, reeferWalkPositionArray, terminalArea ) then
		return;
	endif;
	
	self.myProxyReeferBlock.setProxy( blockName, terminalArea );

	while true do
		if self.mySelectedReeferBlock = null then
			app.myTrxCA.trxCreateReeferWalkPath( self.myProxyReeferBlock, reeferWalkPositionArray, self.mySelectedReeferBlock, app.myPassport );
		else
			app.myTrxUA.trxUpdateReeferWalkPath( self.myProxyReeferBlock, reeferWalkPositionArray, app.myPassport );
		endif;
		
		if app.myPassport.trxCompletedOK then
			break;
		else
			result := app.showErrorWarningDialog( self.caption, app.myPassport, ErrWarnMode_Add + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   result = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			return;
		endif;
		
	endwhile;
	
	self.doClickCmbGriddedArea();

epilog

	delete reeferWalkPositionArray;

end;</source>
    </JadeMethod>
    <JadeMethod name="populateCmbGriddedAreas" id="0bc28944-f6e7-4e27-8c3f-7408d19559aa">
        <source>populateCmbGriddedAreas();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 July 2020	jlgndl1	Initial creation	TFS 49579

*/

vars

	ta : CM_TerminalArea;
	iter : Iterator;

begin

	self.cmbGridTermArea.clear();
	
	iter := self.myTerminal.allTerminalAreas.createIterator;
	while iter.next( ta ) do
		if ta.type.isOneOf( TA_TYPE_FORK_LIFT_STACK, TA_TYPE_RTG, TA_TYPE_STRADDLE_STACK ) then
			self.cmbGridTermArea.itemObject[self.cmbGridTermArea.addItem( ta.id )] := ta;
		endif;
	endwhile;
	
	if self.myTerminalArea &lt;&gt; null then
		self.cmbGridTermArea.listIndex := self.cmbGridTermArea.findObject( self.myTerminalArea );
	endif;

epilog

	delete iter;

end;</source>
    </JadeMethod>
    <JadeMethod name="populateReeferWalkPositions" id="1d049e7f-e9ce-402d-a97f-86cc00bdf014">
        <source>populateReeferWalkPositions();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 July 2020	jlgndl1	Initial creation	TFS 49759

*/

vars
	ta					: CM_TerminalArea;
	//lc				: CM_LocationsController;		// ### TFS 57947 (59757) 16Aug2023 NAVPW1
	proxyReeferBlockPos,
	reeferBlockPos		: CM_ReeferBlockPosition;
	//count,											// ### TFS 57947 (59757) 16Aug2023 NAVPW1
	//tier,												// ### TFS 57947 (59757) 16Aug2023 NAVPW1
	//maxHeight, 										// ### TFS 57947 (59757) 16Aug2023 NAVPW1
	remPos,
	addPos				: Integer;
	gridArea			: CM_GridArea;					// ### TFS 57947 (59757) 16Aug2023 NAVPW1
	
begin
	ta := self.cmbGridTermArea.listObject.CM_TerminalArea;

	if self.myProxyReeferBlock &lt;&gt; null and ta &lt;&gt; null then
		self.txtWalkBlockName.text := self.myProxyReeferBlock.name;
		
		//create a proxy for each of the potential positions.
		/*foreach lc in ta.allLocationsControllers do
			maxHeight := lc.getMaxStackingHeight;
			if maxHeight &lt; 1 then
				continue;
			endif;
			tier := 1;
			foreach tier in 1 to maxHeight do
				count := count + 1;
				create proxyReeferBlockPos transient;	
				proxyReeferBlockPos.setDetails( lc, self.myProxyReeferBlock, count, tier );
			endforeach;	
		endforeach;*/ 	// ### TFS 57947 (59757) 16Aug2023 NAVPW1
		
		// ### TFS 57947 (59757) 16Aug2023 NAVPW1
		if ta.isGridArea then
			gridArea := ta.CM_GridArea;
		endif;
		
		if gridArea &lt;&gt; null then
			gridArea.getReeferWalkPositions(self.myProxyReeferBlock);
		endif;
		// ### TFS 57947 (59757) 16Aug2023 NAVPW1
		
		//Load the 'available' proxies
		//self.mulWalkPositions.setAvailable( self.myProxyReeferBlock.allReeferPositions, true );
		self.mulWalkPositions.setupControl(app.getErrorString(Attributes), self.myProxyReeferBlock.allReeferPositions, SOP_ReeferWalkPathForm::displayWalkPositionAvail.name);	// ### TFS 57947 (59757) 11Aug2023 NAVPW1
		
		//If we have an existing Walk block, find the existing walk path and corresponding proxies in teh matching order.
		if self.mySelectedReeferBlock &lt;&gt; null then
			foreach reeferBlockPos in self.mySelectedReeferBlock.allReeferPositions do
				proxyReeferBlockPos := self.myProxyReeferBlock.allReeferPositions.findMatchingLCandTier( reeferBlockPos );
				if proxyReeferBlockPos &lt;&gt; null then
					remPos := self.mulWalkPositions.myAvailableListBox.findObject( proxyReeferBlockPos );
					if remPos &gt; 0 then
						self.mulWalkPositions.myAvailableListBox.removeItem( remPos );
					endif;
					addPos := self.mulWalkPositions.mySelectedListBox.listCount + 1;
					self.mulWalkPositions.mySelectedListBox.addItemAt( self.displayWalkPositionSel( proxyReeferBlockPos ), addPos );
					self.mulWalkPositions.mySelectedListBox.itemObject[addPos] := proxyReeferBlockPos;
				endif;
			endforeach;
		endif;
		
	else
		self.txtWalkBlockName.text := null;
		self.mulWalkPositions.setSelected( null );
		self.mulWalkPositions.setAvailable( null, true );
		
	endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setButtons" id="3dd7c458-61aa-4300-9265-dc2a1deac67c">
        <source>setButtons();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 July 2020	jlgndl1	Initial creation	TFS 49579

*/

vars

	ta : CM_TerminalArea;

begin

	self.btnOk.visible := false;
	ta := self.cmbGridTermArea.listObject.CM_TerminalArea;
	
	self.btnAdd.enabled := ta &lt;&gt; null;
	self.btnDelete.enabled := self.mySelectedReeferBlock &lt;&gt; null;
	self.btnUpdate.enabled := self.myProxyReeferBlock &lt;&gt; null;

epilog

end;</source>
    </JadeMethod>
