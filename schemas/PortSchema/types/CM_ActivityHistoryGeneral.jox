    <JadeMethod name="setDescription" id="8787a93a-1932-467d-8cbc-c3310bd56706">
        <updating/>
        <source>setDescription(_description: String) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 January 2021	jlgndl1	Initial creation - record full description if truncated.

*/

vars

begin

	inheritMethod(_description);
	
	if _description.length &gt; 80 then
		self.setExtraDetail( _description );
	endif;

epilog

end;</source>
        <Parameter name="_description" type="String"/>
    </JadeMethod>
    <JadeMethod name="setExtraDetail" id="d37376d2-aac6-41c1-8b78-3e485bb59315">
        <updating/>
        <source>setExtraDetail(_extraDetail : String) updating;
// -------------------------------------------
// Created 28 February 2005 by cnwdvb1
// -------------------------------------------
vars

begin

	if self.allExtraDetail = null then
		create self.allExtraDetail transient;
	endif;
	
	self.allExtraDetail.add(_extraDetail[1:2047]);
end;</source>
        <Parameter name="_extraDetail" type="String"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="d5809731-cf2d-4dfa-b018-5e5323955bd7">
        <updating/>
        <source>setForCreate(_proxy: CM_ActivityHistoryGeneral) updating;
// -------------------------------------------
// Created 28 February 2005 by cnwdvb1
// -------------------------------------------
vars

begin
	inheritMethod(_proxy);
	if _proxy.allExtraDetail &lt;&gt; null then
		create self.allExtraDetail persistent;
		_proxy.allExtraDetail.copy(self.allExtraDetail);
	endif;


end;</source>
        <Parameter name="_proxy" type="CM_ActivityHistoryGeneral"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="59fbf545-e2c8-4dda-a3db-3c5c289a2c2c">
        <updating/>
        <source>setForUpdate(_proxy: CM_ActivityHistoryGeneral) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 September 2018	jlger1	Initial creation

*/

vars

begin
	inheritMethod(_proxy);
	if self.allExtraDetail &lt;&gt; null then
		create self.allExtraDetail persistent;
	endif;
	 self.allExtraDetail.clear;
	if _proxy.allExtraDetail &lt;&gt; null then
		_proxy.allExtraDetail.copy(self.allExtraDetail);
	endif;
epilog

end;</source>
        <Parameter name="_proxy" type="CM_ActivityHistoryGeneral"/>
    </JadeMethod>
