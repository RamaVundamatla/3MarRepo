    <JadeMethod name="tMakeTranshipTBA" id="956b75b8-ea9a-47e5-b82d-34089ed4544c">
        <updating/>
        <source>tMakeTranshipTBA()updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 March 2020	jlgndl1	Initial creation	TFS 47004

*/

constants

	Ship = "UTRDSHIP";
	VoyageIn = "UTBAVOYIN";
	VoyageOut = "UTBAVOYOUT";
	CraneTransferAreaId	= "CTRD";
	CraneId = "CRR1";
	YardAlloc = 'TBALLOC';
	BlockStack1 = "UT_TBA";
	Tranship1 = "UTTS0000009";
vars
	terminal : CM_Terminal;
	tas : StringArray;
	cta : CM_CraneTransferArea;
	crane : CM_Machine;
	operator : CM_Operator;
	bs : CM_BlockStack;
	locations : CM_LCArray;
	ya : CM_YardAllocation;
	vessel : CM_Vessel;
	voyageIn : CM_Voyage;
	voyageOut : CM_Voyage;
	voyageQueueIn : CM_VoyageQueue;
	voyageQueueOut : CM_VoyageQueue;
	craneQueueIn : CM_VoyageCraneQueue;
	craneQueueOut : CM_VoyageCraneQueue;
	loadPort : CM_Port;
	dischargePort : CM_Port;
	slots : CM_SlotControllerArray;
	dischargeTi : CM_TrackedItem;
	voyageJobDis : CM_VoyageJob;
	voyageJobLoad : CM_VoyageJob;
	voyAlloc : CM_VoyageAllocation;
	transhipController : CMIF_TranshipTIController;
	tbaController : CMIF_TBAContainer;
	tba : CM_TrackedItem;
	agent : CMIF_MobileGenericAgent;
	pxyTI : CM_TrackedItem;
	wle : CM_WorkListEntry;
	straddle : CM_Machine;
	
	
begin

	self.setTerminalConfig(ShpTranshipTBAMatch, true);	//16 Mar 2020	NDL	TFS 47004
	
	// delete setup stuff.
	
	self.deleteContainer(Tranship1);
	self.deleteTerminalArea(BlockStack1);
	self.deleteVoyage(VoyageIn);
	self.deleteVoyage(VoyageOut);
	self.deleteVessel(Ship);
	self.deleteMachine(CraneId);
	self.deleteTerminalArea(CraneTransferAreaId);
	self.deleteYA(YardAlloc);
	self.deleteMachine("UTS1");
	self.deleteRTDevice("91");
	
	//create base stuff
	terminal := self.getTerminal;
	cta := self.addCraneTransferArea(CraneTransferAreaId);
	// create the crane
	create tas transient;
	tas.add(cta.id);
	self.opts.purge();
	self.opts.addAssoc("CraneTransferArea", cta);
	self.opts.addAssoc("MachineLiftType", TWIN_LIFT);
	crane := self.addCrane(CraneId, null, tas, null);
	self.assertNotNull(crane);
	delete tas;
	bs := self.addBlockStack(BlockStack1, 20, null);
	operator := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);
	
	create locations transient;
	locations.add(bs.allLocationsControllers.first);
	ya := self.addYA1WithFill(YardAlloc, YACriteriaType_OperatorItem, operator.code, locations, YAFillOption_InOrder, YAFillOption_FIFO,false);
	
	vessel := addVesselCellular(Ship,operator);
	
	//create outward voyage
	voyageOut := self.addVoyageWithContainerStructur(VoyageOut, Ship, operator.code, self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString);
	voyageQueueOut := self.addVoyageQueue(voyageOut);
	craneQueueOut := self.addVoyageCraneQueue(voyageOut, voyageQueueOut, crane);
	
	//create container on inward voyage and make tranship
	voyageIn := self.addVoyageWithContainerStructur(VoyageIn, Ship, operator.code, self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString);
	voyageQueueIn := self.addVoyageQueue(voyageIn);
	craneQueueIn := self.addVoyageCraneQueue(voyageIn, voyageQueueIn, crane);
	
	loadPort := app.myRoot.allPorts[terminal.getConfig(PortDestCode).String];
	dischargePort := voyageIn.myTrade.allPortRotations.first.myPort;
	
	create slots transient;
	self.getJobSlotControllers(VoyageIn, '01', DeckOnDeck, 1, 1, 1, slots);
	assertEqual(slots.size, 1);
	dischargeTi := self.addContainerAtLocnDisch(Tranship1 , "2200", "GENL", TI_IMEX_STATUS_IMPORT, slots[1], loadPort, voyageOut);
	
	//make the cargo a tranship
	create transhipController transient;
	transhipController.allTrackedItems.add(dischargeTi);
	transhipController.myExportDestPort := dischargePort;
	transhipController.myExportDisPort := dischargePort;
	transhipController.myExportVoyage := voyageOut;
	self.makeTrackedItemTranship(transhipController);
	delete transhipController;

	// Color code and Create Discharge Jobs
	self.voyageDischargeColourCode(voyageIn);
	
	voyageJobDis := self.addVoyageJob(voyageIn, CraneId, slots, true);
	assertTrueMsg(voyageJobDis &lt;&gt; null, "Voyage job Discharge not created");
	delete slots;
	
	//Load the inward job to operations
	self.loadAllJobsToOps(voyageIn, true);
	
	// get the slots for the load
	create slots transient;
	self.getJobSlotControllers(voyageOut.code, '01', DeckOnDeck, 1, 2, 1, slots);
	
	//plan the slot for the TBA to the outward voyage
	self.opts.purge();
	self.opts.addAssoc("Operator", operator);
	self.opts.addAssoc("ISOType", '2200');
	voyAlloc := self.addVoyageAllocation(voyageOut, dischargePort.code,null, "GENL",1,false,false);
	self.addLCsToLOLOAllocation(true, voyAlloc, slots, null);
	self.opts.purge();
	self.opts.addAssoc("OutOfOrder", true);
	voyageJobLoad := self.addVoyageJob(voyageOut, CraneId, slots, false);
	assertTrueMsg(voyageJobLoad &lt;&gt; null, "Voyage job Load not created");
	
	//Make TBA for outward voyage.
	create tbaController transient;	
	tbaController.id				:=	"TBA";
	tbaController.myCommodity		:=	self.getCommodity("GENL");
	tbaController.myDischargePort	:=	dischargePort;
	tbaController.myISOType			:=	self.getISOType("2200");
	tbaController.myLocationSource	:=	bs.allLocationsControllers.first;
	tbaController.myLocationTarget	:=	slots[1];
	tbaController.myOperator		:=	operator;
	tbaController.myTerminal		:=	terminal;
	tbaController.bookingReference	:= null;
	tbaController.myVoyage			:=	voyageOut;
	tbaController.state				:=	TI_STATE_TBA;
	tbaController.weight			:=	dischargeTi.totalWeight.Integer;
	tbaController.planContainer		:=	true;
	app.myPassport.setWarningsIgnored(true);
	app.myTrxCA.trxCreateTBAContainer(tbaController, app.myPassport);
	self.assertNoTrxErrorsOrWarnings;
	tba := tbaController.myTrackedItem;
	beginTransaction;
	tba.setPropertyValue( "id", dischargeTi.id );
	commitTransaction;
	delete tbaController;
	
	//Load the outward job to operations
	self.loadAllJobsToOps(voyageOut, true);
	
	create agent transient;
	agent.setMyTerminal( terminal );
	agent.setMyVoyage(voyageIn);
	agent.setDoNotShowMsgBox(true);
	agent.doLanderDischarge( dischargeTi, bs.getLocationsController, null, null );
	
	self.assertTrueMsg( dischargeTi.myMatchedTBA &lt;&gt; null, "Landed Tranship Cargo should have matched to the TBA");
	self.assertTrueMsg( tba.myMatchedActual &lt;&gt; null, "TBA should have matched to the Landied Tranship Cargo");
	
	self.move( dischargeTi, cta.lanes.first ); // I.e. move to another area.

	self.assertTrueMsg( dischargeTi.myMatchedTBA &lt;&gt; null, "Move of Tranship Cargo matched to a TBA should not have cleared the ref.");
	self.assertTrueMsg( tba.myMatchedActual &lt;&gt; null, "Move of Tranship Cargo matched to a TBA should not have cleared the TBAs ref.");
	
	self.move( dischargeTi, bs.getLocationsController ); // move back again.

	self.setCargoReadyToShip(dischargeTi);
	self.deleteStops(dischargeTi);	
	
	//Now force the real matching, i.e. replace the planned TBA with the real tranship
	pxyTI := app.createUpdateProxy(dischargeTi).CM_TrackedItem;
	pxyTI.setFromTBAMatch();
	while true do
		app.myTrxUA.trxUpdateTrackedItemFromTBA(pxyTI, null, TI_UPDMODE_NORMAL, dischargeTi.myMatchedTBA, app.myPassport);
		if app.myPassport.trxCompletedOK then
			break;
		elseif app.myPassport.noErrors then
			app.myPassport.warningsAcknowledged	:= true;
			continue;
		endif;
		break;
	endwhile;
	delete pxyTI;
	
	self.addMachineRule( bs, crane.CM_Crane.transferArea, RTMoveMethod_23);
	self.addMachineRule( crane.CM_Crane.transferArea, bs, RTMoveMethod_23);
	
	wle := dischargeTi.allWorklistEntries.last; // this is the load wle that was transferred from the TBA to the Real TI
	self.queueWLE( wle );
	
	// work load Job using straddle
	
	create tas transient;
	tas.add(bs.id); 
	tas.add(crane.CM_Crane.transferArea.id); 
	self.addStraddle("UTS1", 91, tas, null);
	straddle := self.getMachine("UTS1");
	assertNotNull(straddle);
	if craneQueueOut &lt;&gt; null then
		beginTransaction;
		straddle.addToQueue(craneQueueOut, true, 0); //add straddle to crane queue
		commitTransaction;
	endif;
	delete tas;
	
	app.isRTApp := true;  
	self.machineLogon(straddle);
	
	self.machineAcceptSpecifiedTask(straddle, wle.allRTQueueEntries.first);
	self.machinePickup(straddle);
	self.machineSetdownTask(straddle,wle.allRTQueueEntries.last.allTasks.last , crane.CM_Crane.transferArea.id);
	agent.moveTI( wle.myTrackedItem, null, slots.first, wle, true, 0, 0, null );
	
	self.assertEqual( dischargeTi.myPrimaryActualLocation, slots[1]);
	
epilog

	app.isRTApp := false;  
	delete locations;
	delete slots;
	delete agent;
	delete pxyTI;
	delete tas;

end;</source>
    </JadeMethod>
    <JadeMethod name="tMoveCargoToAllVoyageLCTypes" id="743a9c78-4659-4dad-82cd-790401463cda">
        <updating/>
        <source>tMoveCargoToAllVoyageLCTypes() updating;
// CNWMA1
/*
Purpose:			
Date		Who		Reason
05 February 2014	NAVAB1	Initial creation
*/
constants
	VOYCODE = "UTALLStrTypes";
vars
	voy : CM_Voyage;
	cont : CM_TrackedItem;
	lc : CM_LocationsController;
	strs : StringArray;
	idx : Integer;
begin
	create strs transient;

	self.createVesselVoyage(VOYCODE,"LOLOGCRORO", null);
	
	self.createOnsiteCargo(VOYCODE);
	
	voy := self.getVoyage(VOYCODE);
	self.removeAllStops(VOYCODE);	
	
	// ### SHIP BLOCK CONTROLLER
	cont := voy.allOnsiteTIsByCargoTypeId[TI_CargoType_Container,"GENL5077441"];
	strs.clear();
//	strs.add(VOYCODE);
	voy.findLocation(strs, false, lc, idx);
	assertTrueMsg(lc&lt;&gt;null, "SHIP Could not find LC");
	move(cont, lc);
	
	
	// ### GC HOLD CONTROLLER
	cont := voy.allOnsiteTIsByCargoTypeId[TI_CargoType_Container,"GENL5077442"];
	lc := null;
	strs.clear();
	strs.add("0101");
	voy.findLocation(strs, false, lc, idx);
	assertTrueMsg(lc&lt;&gt;null, "HOLD Could not find LC");
	move(cont, lc);
	
	
	// ### LOLO SLOT CONTROLLER
	cont := voy.allOnsiteTIsByCargoTypeId[TI_CargoType_Container,"GENL5077443"];
	lc := null;
	strs.clear();
	strs.add("010102");
	voy.findLocation(strs, false, lc, idx);
	assertTrueMsg(lc&lt;&gt;null, "LOLO Could not find LC");
	self.opts.addAssoc("IsForcedMove", true);
	move(cont, lc);
	
	
	// ### RORO SLOT CONTROLLER
	cont := voy.allOnsiteTIsByCargoTypeId[TI_CargoType_Container,"GENL5077444"];
	lc := null;
	strs.clear();
	strs.add("AUTOLOCN271");
	voy.findLocation(strs, false, lc, idx);
	assertTrueMsg(lc&lt;&gt;null, "RORO Could not find LC");
	self.opts.addAssoc("IsForcedMove", true);
	move(cont, lc);

	
epilog
	delete strs;
end;</source>
    </JadeMethod>
    <JadeMethod name="tMovingCargoWhilePlannedLOLO" id="31af5eb8-5c69-412c-a0f4-0e3ff157f3bb">
        <updating/>
        <source>tMovingCargoWhilePlannedLOLO() updating;
/*

Purpose:			
Check that we get the correct error code when trying to change slot position on ship for a load container yet to be loaded. 
When a cargo item is planned to a ship slot, but then also queued to another yard area, if the Move button on the Job Operations form is clicked for this cargo item.
Parameters:			

Return Value:		

Date		Who		Reason
24 November 2021	navlw1	Initial creation TFS 52118

*/
constants
	LoadBox1    			= "UTLW0000001";
	DischargeBox		    = "UTLW0000004";
	Voyage1     			= "UTLWVOYAGE";
	Ship        			= "UTRDSHIP";
	BlockStack1				= "UT_LWBS1";
	BlockStack2				= "UT_LWBS2";
	YardIC					= "UT_LW_IC";
	CraneId					= "CRR1";
	CraneTransferAreaId 	= "CTRD";
	YardAlloc	            = 'RDALLOC';
vars
	bs, bs2	        	: CM_BlockStack;
	newSource   		: CM_LocationsController;
	cargoItem,
   	dischargeTi     	: CM_TrackedItem;
	voyage      		: CM_Voyage;
	yardIC				: CM_InterchangeArea;
	operator			: CM_Operator;
	vessel		 		: CM_Vessel;
	location 	  		: CM_LocationsController;
	cta			  		: CM_CraneTransferArea;
	voyageCode 	  		: String;
	cargoId       		: String;
	loadPort,
	dischargePort		: CM_Port;
	tas					: StringArray;
	crane				: CM_Machine;
	bayName				: String;
	slots 				: CM_SlotControllerArray;
	queuedLocationId 	: String;
	voyageQueue			: CM_VoyageQueue;
	job					: CM_Job;	
	jobs				: CM_JobArray;
	request				: CM_Request;
	wle					: CM_WorkListEntry;
	voyageJob			: CM_VoyageJob;
	voyAlloc        	: CM_VoyageAllocation;
begin
	create jobs transient;
		
	// delete everything first
	self.deleteContainer(LoadBox1);
	self.deleteVoyage(Voyage1);
	self.deleteVessel(Ship);
	self.deleteTerminalArea(BlockStack1);
	self.deleteTerminalArea(YardIC);
	self.deleteMachine(CraneId);
	
	self.opts.purge;
	self.opts.addAssoc("ActAsReleasePoint", 1);
	self.opts.addAssoc("HideOverview", true);
	
	yardIC := self.addInterchangeArea(YardIC, null);
	
	self.opts.purge;
	self.opts.addAssoc("ActAsReleasePoint", 1);
	self.opts.addAssoc("StockControlled", true);
	self.opts.addAssoc("DefaultYIC", yardIC);
	bs := self.addBlockStack(BlockStack1, 20, null);
	bs2 := self.addBlockStack(BlockStack2, 20, null);
	
	operator := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);
	
	//set up vessel
	vessel := addVesselCellular(Ship,operator);
	self.opts.purge;
	self.opts.addAssoc("UseAllocations", true);
	self.opts.addAssoc("UseDefaultVAConfig", true);
		
	voyage := self.addVoyageWithContainerStructur(Voyage1, Ship, operator.code, self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString);
	self.assertNotNull(vessel);
	self.assertNotNull(voyage);

	// create the crane transfer area
	cta := self.addCraneTransferArea(CraneTransferAreaId);
	self.assertNotNull(cta);
	
	// create the crane
	create tas transient;
	tas.add(cta.id);
	self.opts.purge();
	self.opts.addAssoc("CraneTransferArea", cta);
	self.opts.addAssoc("MachineLiftType", TWIN_LIFT);
	self.opts.addAssoc("BaseJobNumber", 100);
	crane := self.addCrane(CraneId, null, tas, null);
	self.assertNotNull(crane);
	delete tas;
	
	//port stuff
	loadPort := app.myRoot.allPorts[voyage.myTerminal.getConfig(PortDestCode).String];
	dischargePort := voyage.myTrade.allPortRotations.first.myPort;
	
	self.opts.purge();
	self.opts.addAssoc("Operator", operator);
	self.opts.addAssoc("ISOType", '2200');

	//voyage allocation
	voyAlloc := self.addVoyageAllocation(voyage, dischargePort.code,"GEN2",self.getTerminal.getDefaultEmptyCommodity(),1,false,false);		// 05/04/2013 cnwmh5
	bayName :='01';
	
	//create the slot
	create slots transient;
	self.getJobSlotControllers(Voyage1, bayName, DeckOnDeck, 1, 1, 1, slots);
	assertEqual(slots.size, 1);
	
	self.addLCsToLOLOAllocation(true, voyAlloc, slots, null);
	self.opts.purge();
	self.opts.addAssoc("OutOfOrder", true);
	
	//create voyage job
	voyageJob := self.addVoyageJob(voyage, CraneId, slots, false);
	assertTrueMsg(voyageJob &lt;&gt; null, "Voyage job not created");
	jobs.add(voyageJob);	
	
	//cargo item (container)
	cargoItem := self.addContainerForExport(LoadBox1, operator,
				"2200",	"MT", TI_IMEX_STATUS_EXPORT, null, voyage.code, dischargePort.code, null).CM_Container;
	self.move(cargoItem, bs.getLocationsController);
	self.assertEqual(cargoItem.myPrimaryActualLocation, bs.myLocationsController);
	self.setCargoReadyToShip(cargoItem);
	self.deleteStops(cargoItem);	
	
	//set up the wle
	wle := voyageJob.workListEntries.first();
	self.opts.purge();
	self.opts.addAssoc("IsForcedMove", true);
	self.movePlannedRequestToJob(cargoItem, slots[1], wle.myRequest);
	self.assertTrueMsg(wle.myTrackedItem &lt;&gt; null, "the wle has no tracked item");
	
	//load jobs to ops
	self.loadAllJobsToOps(voyage, true);
	self.moveQueued(cargoItem, bs2);
	self.assertTrueMsg(cargoItem.myPrimaryQueuedLocation &lt;&gt; null, "container did not queue");
	//attempt to move the wle and should throw the exception
	on Exception do self.exHandlerAssertException(exception);
	self.moveWLEWithNoAssert(wle);
	on Exception do null;
	self.assertExceptionRaised(Canno_moved_voyag_becau_queue_, "failed");
epilog
	delete slots;
	delete jobs;
end;</source>
    </JadeMethod>
    <JadeMethod name="tNonContainerisedMAFIDetails" id="5f26dba8-160b-4311-b2c3-53f25b8e3069">
        <updating/>
        <source>tNonContainerisedMAFIDetails() updating;
/*****************************************************
Author		: jlika1 (Karen Alexander)
Date		: 16 June 2024
TFS#		: 64453
Function	:

*** Changes ***
Date			Name		TFS#		Description
27 Dec 2024		navah1		Change 33742: MTN - 22.0.24.12 - Unit Tests Review - [2]
****************************************************/

constants

	VesselCode 		: String = 'CUXVES1';
	VoyageCode 		: String = 'CUXVOY1';
	VoyageCode2 	: String = 'CUXVOY2';
	
	BOOK_ID 		: String = "UTKBOOKING1";
	MAFI_ID_A		: String = "KMAFIA1";
	MAFI_ID_B		: String = "KMAFIA2";
	MAFI_ID_C		: String = "KMAFIA3";
	MAFI_ID_D		: String = "KMAFIA4";
	MAFI_ID_E		: String = "KMAFIA5";
	MAFI_ID_F		: String = "KMAFIA6";
	MAFI_ID_G		: String = "KMAFIA7";
	MAFI_ID_H		: String = "KMAFIA8";
	
	TILC_ID_A		: String = "KTILCA";
	
	CONT_ID_A		: String = "KJMU2312131";
	
	BBLK_ID_A		: String = "KMBB2406131";
	BBLK_ID_B		: String = "KMBB2406132";
	BBLK_ID_C		: String = "KMBB2406133";
	BBLK_ID_D		: String = "KMBB2406134";
	BBLK_ID_E		: String = "KMBB2406135";
	BBLK_ID_F		: String = "KMBB2406136";
	BBLK_ID_G		: String = "KMBB2406137";
	BBLK_ID_H		: String = "KMBB2406138";
	BBLK_ID_I		: String = "KMBB2406139";
	BBLK_ID_J		: String = "KMBB2406140";
	
	BBULKCargoType 	: String = "KBBLK"; 
	MAFICargoType 	: String = "KMAF7";
	TrailerType 	: String = "KMAF7A";
	TrailerType2 	: String = "KMAF7B";
	MAFIAreaName 	: String = "UTKM1";
	AreaName 		: String = "UTKBS1";
	TrailerTypeDesc : String = "KMAF7A - MAFI Trailer Type";
	TrailerTypeDesc2: String = "KMAF7B - Non MAFI Trailer Type";
	
	Truck1			: String = "KTRUCK";
	Truck2			: String = "KTRUCK2";
	Truck3			: String = "KTRUCK3";
	Truck4			: String = "KTRUCK4";
	Truck5			: String = "KTRUCK5";
	Truck6			: String = "KTRUCK6";
	Truck7			: String = "KTRUCK7";
	Truck8			: String = "KTRUCK8";
	Truck9			: String = "KTRUCK9";
	Truck10			: String = "KTRUCK10";
vars

	operator 		: CM_Operator;
	shipLineStr 	: String;
	nullVoyage		: CM_Voyage;
	voyage 			: CM_Voyage;
	voyage2			: CM_Voyage;
	pxyVoyage		: CM_Voyage;
	vessel			: CM_Vessel;
	
	selectedTypes 	: CM_CargoBOLTypeSet;
	preventActions 	: IntegerArray;
	toDoTask		: CM_ToDoTaskDesc; // Block RTL
	toDoTask2		: CM_ToDoTaskDesc; // Dont Block RTL
	tis				: CM_TISet;
	
	bbCargoType 	: CM_CargoType;
	mafiCargoType	: CM_CargoType;
	contCargoType 	: CM_CargoType;
	trailerType		: CM_TILCType;
	
	mafiHeap		: CM_BlockStack;
	blockStack		: CM_BlockStack;
	
	bblkTI			: CM_BreakBulkGeneric;
	bblkTI1			: CM_BreakBulkGeneric;
	mafiTI			: CM_TILC;
	contTI			: CM_TrackedItem;
	
	rtlResult		: Boolean;
	rtlReason 		: String;
	truck			: CM_Vehicle;
	truck2			: CM_Vehicle;
	truck3			: CM_Vehicle;
	truck4			: CM_Vehicle;
	truck5			: CM_Vehicle;
	truck6			: CM_Vehicle;
	truck7			: CM_Vehicle;
	truck8			: CM_Vehicle;
	truck9			: CM_Vehicle;
	truck10			: CM_Vehicle;
begin
	//==========================
	// Generic Stuff
	//==========================
	operator := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);
	shipLineStr := self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString;
	nullVoyage := self.getVoyage(NULL_VOYAGE_CODE);
	
	//==========================
	// Clean-up
	//==========================	
	self.deleteCargo(BBLK_ID_A, BBULKCargoType);
	self.deleteCargo(BBLK_ID_B, BBULKCargoType);
	self.deleteCargo(BBLK_ID_C, BBULKCargoType);
	self.deleteCargo(BBLK_ID_D, BBULKCargoType);
	self.deleteCargo(BBLK_ID_E, BBULKCargoType);
	self.deleteCargo(BBLK_ID_F, BBULKCargoType);
	self.deleteCargo(BBLK_ID_G, BBULKCargoType);
	self.deleteCargo(BBLK_ID_H, BBULKCargoType);
	self.deleteCargo(BBLK_ID_I, BBULKCargoType);
	self.deleteCargo(BBLK_ID_J, BBULKCargoType);
	
	self.deleteCargo(CONT_ID_A, TI_CargoType_Container);
	
	self.deleteCargo(MAFI_ID_A, MAFICargoType);
	self.deleteCargo(MAFI_ID_B, MAFICargoType);
	self.deleteCargo(MAFI_ID_C, MAFICargoType);
	self.deleteCargo(MAFI_ID_D, MAFICargoType);
	self.deleteCargo(MAFI_ID_E, MAFICargoType);
	self.deleteCargo(MAFI_ID_F, MAFICargoType);
	self.deleteCargo(MAFI_ID_G, MAFICargoType);
	self.deleteCargo(MAFI_ID_H, MAFICargoType);
	
	self.deleteVoyage(VoyageCode);
	self.deleteVoyage(VoyageCode2);
	self.deleteVessel(VesselCode);
	self.deleteCargoType(BBULKCargoType);
	self.deleteCargoType(MAFICargoType);
	self.deleteTrailerType(trailerType);
	self.deleteTerminalArea(MAFIAreaName);	
	self.deleteTerminalArea(AreaName);
	
	//==========================
	// Set up Voyages
	//==========================
	vessel := self.addVesselLOLOholdsRORO(VesselCode, operator);
	voyage := self.addVoyageWithConRORO(VoyageCode, VesselCode, operator.code, shipLineStr, null, 0, false, true);
	self.assertTrueMsg(voyage &lt;&gt; null, "'Voyage' not created during setup");
	
	voyage2 := self.addVoyageWithConRORO(VoyageCode2, VesselCode, operator.code, shipLineStr, null, 0, false, true);
	self.assertTrueMsg(voyage2 &lt;&gt; null, "'Voyage2' not created during setup");
		
	//==========================
	// Set up Cargotypes
	//==========================
	self.opts.purge();
	self.opts.addAssoc("AllowDuplicateId", true);
	bbCargoType := self.addCargoType(BBULKCargoType, false);
	self.assertTrueMsg(bbCargoType &lt;&gt; null, "BBLK cargo type failed to be created");
	
	self.opts.purge;
	self.opts.addAssoc("TrackAs", ProductType_Trailer);
	mafiCargoType := self.addCargoType(MAFICargoType, false);
	self.assertTrueMsg(mafiCargoType &lt;&gt; null, "MAFI cargo type failed to be created");
	trailerType := self.addTrailerType(TrailerType, TrailerTypeDesc, mafiCargoType, 1, 600, 600, 30000, 6000, 300, TRAILER_CATEGORY_MAFI, null);
		
	contCargoType := app.myRoot.allCargoTypesById[TI_CargoType_Container];
	self.assertTrueMsg(contCargoType &lt;&gt; null, "Container Cargo Type not found during setup.");
	
	//==========================
	// Set up Terminal Area
	//==========================
	self.opts.purge;
	self.opts.addAssoc("TA_Type", TA_TYPE_MAFI);
	mafiHeap := self.addBlockStack(MAFIAreaName, null, null);
	self.assertNotNullMsg(mafiHeap, "Mafi Heap");
	
	self.opts.purge;
	blockStack := self.addBlockStack(AreaName, 9999, null);
	self.assertNotNullMsg(blockStack, "Block Stack");
	/*
	//==========================
	// Set up Cargo For Scenario 1 MAFI got a Voyage and POD but Cargo got the null Voyage and POD it should Inherit Voyage and POD from MAFI
	//==========================
	// Gate in from 
	self.opts.purge;
	truck := self.getVehicle(Truck1);
	if truck &lt;&gt; null then
		self.deleteVehicle(Truck1);
	endif;
	self.gateInGC(Truck1,null,Truck1,BBLK_ID_A,bbCargoType.description,self.getProfileSetting(UT_Profile.P_OPERATOR).asString,null,self.getGate(self.getProfileSetting(UT_Profile.P_DGATE).asString),50);
	
	bblkTI := self.getTerminal.lookupTrackedItem(BBLK_ID_A, bbCargoType.id, TI_STATE_NORMAL, null, false).CM_BreakBulkGeneric;	
	self.assertTrueMsg(bblkTI &lt;&gt; null, "'" &amp; BBLK_ID_A &amp; "' cargo not created during setup");
	self.opts.purge;
	self.opts.addAssoc("TotalWeight", 8000);
	self.updateTI(bblkTI);
	self.opts.purge;
	self.deleteStops(bblkTI);	

	mafiTI := self.addTrailerAtLocation(MAFI_ID_A, mafiCargoType, trailerType, operator, mafiHeap.myLocationsController);
	self.assertTrueMsg(mafiTI &lt;&gt; null, MAFI_ID_A &amp; " mafi not created");
	self.deleteStops(mafiTI);
	
	//==========================
	// Tests For Scenario 1
	//==========================	
	// Update MAFI Voyage
	self.opts.purge();
	self.opts.addAssoc("Voyage", voyage);
	self.opts.addAssoc("DischargePort", "NZAKL");
	self.opts.addAssoc("DontDoAssert", true);
	app.myPassport.setWarningsIgnored(true);
	self.updateTI(mafiTI);
	app.myPassport.setWarningsIgnored(false);
	self.deleteStops(mafiTI);
	
	// Update Break Bulk IMEX to Export
	self.opts.purge;
	self.opts.addAssoc("IMEXStatus", TI_IMEX_STATUS_EXPORT);	
	self.updateTI(bblkTI);
	
	// load bblk to mafi
	self.move(bblkTI, mafiTI.allLCs.first);	
	self.assertNoTrxErrorsOrWarnings();
	self.assertEqualMsg(bblkTI.myVoyage, mafiTI.myVoyage, " should Inherit Voyage from MAFI");
	self.assertEqualMsg(bblkTI.dischargePort, mafiTI.dischargePort, " should Inherit POD from MAFI");
	
	//==========================
	// Set up Cargo For Scenario 2 both MAFI and Cargo got a null voyage
	//==========================	
	// Gate in from 
	self.opts.purge;
	truck2 := self.getVehicle(Truck2);
	if truck2 &lt;&gt; null then
		self.deleteVehicle(Truck2);
	endif;
	self.gateInGC(Truck2,null,Truck2,BBLK_ID_B,bbCargoType.description,self.getProfileSetting(UT_Profile.P_OPERATOR).asString,null,self.getGate(self.getProfileSetting(UT_Profile.P_DGATE).asString),50);
	
	bblkTI := self.getTerminal.lookupTrackedItem(BBLK_ID_B, bbCargoType.id, TI_STATE_NORMAL, null, false).CM_BreakBulkGeneric;	
	self.assertTrueMsg(bblkTI &lt;&gt; null, "'" &amp; BBLK_ID_B &amp; "' cargo not created during setup");
	self.opts.purge;
	self.opts.addAssoc("TotalWeight", 8000);
	self.updateTI(bblkTI);
	self.opts.purge;
	self.deleteStops(bblkTI);	

	mafiTI := self.addTrailerAtLocation(MAFI_ID_B, mafiCargoType, trailerType, operator, mafiHeap.myLocationsController);
	self.assertTrueMsg(mafiTI &lt;&gt; null, MAFI_ID_B &amp; " mafi not created");
	self.deleteStops(mafiTI);
	
	//==========================
	// Tests For Scenario 2
	//==========================	
	// Update Break Bulk IMEX to Export
	self.opts.purge;
	self.opts.addAssoc("IMEXStatus", TI_IMEX_STATUS_EXPORT);
	self.updateTI(bblkTI);
	
	// load bblk to mafi
	self.move(bblkTI, mafiTI.allLCs.first);	
	self.assertNoTrxErrorsOrWarnings();
	self.assertTrueMsg(bblkTI.myVoyage.isNullVoyage, " should remain null voyage");
	self.assertTrueMsg(mafiTI.myVoyage.isNullVoyage, " should remain null voyage");
	
	//==========================
	// Set up Cargo For Scenario 3 Cargo got a voyage MAFI got a null voyage
	//==========================	
	// Gate in from 
	self.opts.purge;
	truck3 := self.getVehicle(Truck3);
	if truck3 &lt;&gt; null then
		self.deleteVehicle(Truck3);
	endif;
	self.gateInGC(Truck3,null,Truck3,BBLK_ID_C,bbCargoType.description,self.getProfileSetting(UT_Profile.P_OPERATOR).asString,null,self.getGate(self.getProfileSetting(UT_Profile.P_DGATE).asString),50);
	
	bblkTI := self.getTerminal.lookupTrackedItem(BBLK_ID_C, bbCargoType.id, TI_STATE_NORMAL, null, false).CM_BreakBulkGeneric;	
	self.assertTrueMsg(bblkTI &lt;&gt; null, "'" &amp; BBLK_ID_C &amp; "' cargo not created during setup");
	self.opts.purge;
	self.opts.addAssoc("TotalWeight", 8000);
	self.updateTI(bblkTI);
	self.opts.purge;
	self.deleteStops(bblkTI);	

	mafiTI := self.addTrailerAtLocation(MAFI_ID_C, mafiCargoType, trailerType, operator, mafiHeap.myLocationsController);
	self.assertTrueMsg(mafiTI &lt;&gt; null, MAFI_ID_C &amp; " mafi not created");
	self.deleteStops(mafiTI);
	
	//==========================
	// Tests For Scenario 3
	//==========================	
	// Update Break Bulk IMEX to Export, Voyage and POD
	self.opts.purge();
	self.opts.addAssoc("Voyage", voyage);
	self.opts.addAssoc("DischargePort", "NZAKL");
	self.opts.addAssoc("IMEXStatus", TI_IMEX_STATUS_EXPORT);	
	self.opts.addAssoc("DontDoAssert", true);
	app.myPassport.setWarningsIgnored(true);
	self.updateTI(bblkTI);
	app.myPassport.setWarningsIgnored(false);
	self.deleteStops(bblkTI);
	
	// load bblk to mafi
	self.move(bblkTI, mafiTI.allLCs.first);	
	self.assertNoTrxErrorsOrWarnings();
	self.assertEqualMsg(bblkTI.myVoyage, mafiTI.myVoyage, " should Inherit Voyage from Cargo");
	self.assertEqualMsg(bblkTI.dischargePort, mafiTI.dischargePort, " should Inherit POD from Cargo");
	
	//==========================
	// Set up Cargo For Scenario 4 Both MAFI and Cargo has different Voyage - Should raise a warning message
	//==========================	
	// Gate in from 
	self.opts.purge;
	truck4 := self.getVehicle(Truck4);
	if truck4 &lt;&gt; null then
		self.deleteVehicle(Truck4);
	endif;
	self.gateInGC(Truck4,null,Truck4,BBLK_ID_D,bbCargoType.description,self.getProfileSetting(UT_Profile.P_OPERATOR).asString,null,self.getGate(self.getProfileSetting(UT_Profile.P_DGATE).asString),50);
	
	bblkTI := self.getTerminal.lookupTrackedItem(BBLK_ID_D, bbCargoType.id, TI_STATE_NORMAL, null, false).CM_BreakBulkGeneric;	
	self.assertTrueMsg(bblkTI &lt;&gt; null, "'" &amp; BBLK_ID_D &amp; "' cargo not created during setup");
	self.opts.purge;
	self.opts.addAssoc("TotalWeight", 8000);
	self.updateTI(bblkTI);
	self.opts.purge;
	self.deleteStops(bblkTI);	

	mafiTI := self.addTrailerAtLocation(MAFI_ID_D, mafiCargoType, trailerType, operator, mafiHeap.myLocationsController);
	self.assertTrueMsg(mafiTI &lt;&gt; null, MAFI_ID_D &amp; " mafi not created");
	self.deleteStops(mafiTI);
	
	//==========================
	// Tests For Scenario 4
	//==========================	
	// Update Break Bulk IMEX to Export, Voyage and POD
	self.opts.purge();
	self.opts.addAssoc("Voyage", voyage);
	self.opts.addAssoc("IMEXStatus", TI_IMEX_STATUS_EXPORT);
	self.opts.addAssoc("DontDoAssert", true);
	app.myPassport.setWarningsIgnored(true);
	self.updateTI(bblkTI);
	app.myPassport.setWarningsIgnored(false);
	self.deleteStops(bblkTI);
	
	// Update MAFI Voyage
	self.opts.purge();
	self.opts.addAssoc("Voyage", voyage2);
	self.opts.addAssoc("DontDoAssert", true);
	app.myPassport.setWarningsIgnored(true);
	self.updateTI(mafiTI);
	app.myPassport.setWarningsIgnored(false);
	self.deleteStops(mafiTI);
	
	
	// load bblk to mafi
	self.move(bblkTI, mafiTI.allLCs.first);			
	self.assertTrxWarning(Mafi_does_not_match_voyage);
	
	//==========================
	// Set up Cargo For Scenario 5 Both MAFI and Cargo has different POD same Voyage - Should raise a warning message
	//==========================	
	// Gate in from 
	self.opts.purge;
	truck5 := self.getVehicle(Truck5);
	if truck5 &lt;&gt; null then
		self.deleteVehicle(Truck5);
	endif;
	self.gateInGC(Truck5,null,Truck5,BBLK_ID_E,bbCargoType.description,self.getProfileSetting(UT_Profile.P_OPERATOR).asString,null,self.getGate(self.getProfileSetting(UT_Profile.P_DGATE).asString),50);
	
	bblkTI := self.getTerminal.lookupTrackedItem(BBLK_ID_E, bbCargoType.id, TI_STATE_NORMAL, null, false).CM_BreakBulkGeneric;	
	self.assertTrueMsg(bblkTI &lt;&gt; null, "'" &amp; BBLK_ID_E &amp; "' cargo not created during setup");
	self.opts.purge;
	self.opts.addAssoc("TotalWeight", 8000);
	self.updateTI(bblkTI);
	self.opts.purge;
	self.deleteStops(bblkTI);	

	mafiTI := self.addTrailerAtLocation(MAFI_ID_E, mafiCargoType, trailerType, operator, mafiHeap.myLocationsController);
	self.assertTrueMsg(mafiTI &lt;&gt; null, MAFI_ID_E &amp; " mafi not created");
	self.deleteStops(mafiTI);
	
	//==========================
	// Tests For Scenario 5
	//==========================	
	// Update Break Bulk IMEX to Export, Voyage and POD
	self.opts.purge();
	self.opts.addAssoc("Voyage", voyage);
	self.opts.addAssoc("DischargePort", "NZAKL");
	self.opts.addAssoc("IMEXStatus", TI_IMEX_STATUS_EXPORT);
	self.opts.addAssoc("DontDoAssert", true);
	app.myPassport.setWarningsIgnored(true);
	self.updateTI(bblkTI);
	app.myPassport.setWarningsIgnored(false);
	self.deleteStops(bblkTI);
	
	// Update MAFI Voyage
	self.opts.purge();
	self.opts.addAssoc("Voyage", voyage);
	self.opts.addAssoc("DischargePort", "NZDUG");
	self.opts.addAssoc("DontDoAssert", true);
	app.myPassport.setWarningsIgnored(true);
	self.updateTI(mafiTI);
	app.myPassport.setWarningsIgnored(false);
	self.deleteStops(mafiTI);
	
	
	// load bblk to mafi
	self.move(bblkTI, mafiTI.allLCs.first);	
	self.assertTrxWarning(Mafi_does_not_match_disch_port);

	//==========================
	// Set up Cargo For Scenario 6 - One onboard cargo is a Container do not update anything
	//==========================	
	// Gate in from 
	self.opts.purge;
	truck6 := self.getVehicle(Truck6);
	if truck6 &lt;&gt; null then
		self.deleteVehicle(Truck6);
	endif;
	self.gateInGC(Truck6,null,Truck6,BBLK_ID_F,bbCargoType.description,self.getProfileSetting(UT_Profile.P_OPERATOR).asString,null,self.getGate(self.getProfileSetting(UT_Profile.P_DGATE).asString),50);
	
	bblkTI := self.getTerminal.lookupTrackedItem(BBLK_ID_F, bbCargoType.id, TI_STATE_NORMAL, null, false).CM_BreakBulkGeneric;	
	self.assertTrueMsg(bblkTI &lt;&gt; null, "'" &amp; BBLK_ID_F &amp; "' cargo not created during setup");
	self.opts.purge;
	self.opts.addAssoc("TotalWeight", 8000);
	self.updateTI(bblkTI);
	self.opts.purge;
	self.deleteStops(bblkTI);	
	
	contTI := self.addContainerAtLocation(CONT_ID_A, operator, "2200", "MT", TI_IMEX_STATUS_EXPORT, blockStack.myLocationsController);
	self.assertTrueMsg(contTI &lt;&gt; null, CONT_ID_A &amp; " container not created");
	self.opts.purge;
	self.opts.addAssoc("Voyage", voyage);
	self.opts.addAssoc("DontDoAssert", true);
	app.myPassport.setWarningsIgnored(true);
	self.updateTI(contTI);
	app.myPassport.setWarningsIgnored(false);
	self.opts.purge;
	self.deleteStops(contTI);

	mafiTI := self.addTrailerAtLocation(MAFI_ID_F, mafiCargoType, trailerType, operator, mafiHeap.myLocationsController);
	self.assertTrueMsg(mafiTI &lt;&gt; null, MAFI_ID_F &amp; " mafi not created");
	self.deleteStops(mafiTI);
	
	//==========================
	// Tests For Scenario 6
	//==========================		
	// Update Break Bulk IMEX to Export
	self.opts.purge;
	self.opts.addAssoc("IMEXStatus", TI_IMEX_STATUS_EXPORT);
	self.updateTI(bblkTI);
	app.myPassport.setWarningsIgnored(false);
	self.deleteStops(bblkTI);
	
	// Update MAFI Voyage
	self.opts.purge();
	app.myPassport.setWarningsIgnored(false);
	self.deleteStops(mafiTI);
	
	
	// load container to mafi
	self.move(contTI, mafiTI.allLCs.first);	
	self.assertNoTrxErrorsOrWarnings();
	self.assertEqualMsg(mafiTI.myVoyage, voyage, " should Inherit from Container Voyage");	
	
	// load bblk to mafi
	self.move(bblkTI, mafiTI.allLCs.last);	
	self.assertNoTrxErrorsOrWarnings();
	self.assertNotEqualMsg(bblkTI.myVoyage, mafiTI.myVoyage, " should not update Voyage from MAFI as there is a container onboard");	
	*/
	//==========================
	// Set up Cargo For Scenario 7 - MAFI and Loaded Cargo got a null Voyage and POD then Modify the MAFI Voyage Cargo Loaded will have to inherit the MAFI Voyage
	//==========================	
	// Gate in from 
	self.opts.purge;
	truck7 := self.getVehicle(Truck7);
	if truck7 &lt;&gt; null then
		self.deleteVehicle(Truck7);
	endif;
	self.gateInGC(Truck7,null,Truck7,BBLK_ID_G,bbCargoType.description,self.getProfileSetting(UT_Profile.P_OPERATOR).asString,null,self.getGate(self.getProfileSetting(UT_Profile.P_DGATE).asString),50);
	
	bblkTI := self.getTerminal.lookupTrackedItem(BBLK_ID_G, bbCargoType.id, TI_STATE_NORMAL, null, false).CM_BreakBulkGeneric;	
	self.assertTrueMsg(bblkTI &lt;&gt; null, "'" &amp; BBLK_ID_G &amp; "' cargo not created during setup");
	self.opts.purge;
	self.opts.addAssoc("TotalWeight", 8000);
	self.updateTI(bblkTI);
	self.opts.purge;
	self.deleteStops(bblkTI);	
	
	truck8 := self.getVehicle(Truck8);
	if truck8 &lt;&gt; null then
		self.deleteVehicle(Truck8);
	endif;
	
	self.gateInGC(Truck8,null,Truck8,BBLK_ID_H,bbCargoType.description,self.getProfileSetting(UT_Profile.P_OPERATOR).asString,null,self.getGate(self.getProfileSetting(UT_Profile.P_DGATE).asString),50);
	bblkTI1 := self.getTerminal.lookupTrackedItem(BBLK_ID_H, bbCargoType.id, TI_STATE_NORMAL, null, false).CM_BreakBulkGeneric;	
	self.assertTrueMsg(bblkTI1 &lt;&gt; null, "'" &amp; BBLK_ID_H &amp; "' cargo not created during setup");
	self.opts.purge;
	self.opts.addAssoc("TotalWeight", 8000);
	self.updateTI(bblkTI1);
	self.opts.purge;
	self.deleteStops(bblkTI1);	

	mafiTI := self.addTrailerAtLocation(MAFI_ID_G, mafiCargoType, trailerType, operator, mafiHeap.myLocationsController);
	self.assertTrueMsg(mafiTI &lt;&gt; null, MAFI_ID_G &amp; " mafi not created");
	self.deleteStops(mafiTI);
	
	//==========================
	// Tests For Scenario 7 
	//==========================	
	// Update Break Bulk IMEX to Export
	self.opts.purge;
	self.opts.addAssoc("IMEXStatus", TI_IMEX_STATUS_EXPORT);	
	self.updateTI(bblkTI);	
	self.updateTI(bblkTI1);
	
	// load bblk to mafi
	self.move(bblkTI, mafiTI.allLCs.first);	
	self.assertEqualMsg(bblkTI.myVoyage, mafiTI.myVoyage, " both should retain null Voyage");
	self.assertEqualMsg(bblkTI.dischargePort, mafiTI.dischargePort, " both should retain null Voyage");
	
	self.move(bblkTI1, mafiTI.allLCs.last);	
	self.assertEqualMsg(bblkTI1.myVoyage, mafiTI.myVoyage, " both should retain null Voyage");
	self.assertEqualMsg(bblkTI1.dischargePort, mafiTI.dischargePort, " both should retain null Voyage");
		
	// Update MAFI Voyage
	self.opts.purge();
	self.opts.addAssoc("Voyage", voyage);
	self.opts.addAssoc("DischargePort", "NZAKL");
	self.opts.addAssoc("DontDoAssert", true);
	app.myPassport.setWarningsIgnored(true);
	self.updateTI(mafiTI);
	
	self.assertNoTrxErrorsOrWarnings();	
	self.assertEqualMsg(bblkTI.myVoyage, mafiTI.myVoyage, " Cargo should inherit Voyage from MAFI");
	self.assertEqualMsg(bblkTI.dischargePort, mafiTI.dischargePort, " Cargo should inherit POD from MAFI");
	
	self.assertEqualMsg(bblkTI1.myVoyage, mafiTI.myVoyage, " Cargo should inherit Voyage from MAFI");
	self.assertEqualMsg(bblkTI1.dischargePort, mafiTI.dischargePort, " Cargo should inherit POD from MAFI");
	
	// Update MAFI Voyage to a different Voyage
	self.opts.purge();
	self.opts.addAssoc("Voyage", voyage2);
	self.opts.addAssoc("DischargePort", "NZAKL");
	self.opts.addAssoc("DontDoAssert", true);
	app.myPassport.setWarningsIgnored(true);
	self.updateTI(mafiTI);
	
	self.assertTrxWarning(Mafi_does_not_match_voyage);	
	
	//==========================
	// Set up Cargo For Scenario 8 - MAFI and Loaded Cargo got a null Voyage and POD then Modify the one Cargo Voyage then Modify MAFI Voayge one Cargo will inherit the MAFI Voyage the other one will receive a warning message.
	//==========================	
	// Gate in from 
	self.opts.purge;
	truck9 := self.getVehicle(Truck9);
	if truck9 &lt;&gt; null then
		self.deleteVehicle(Truck9);
	endif;
	self.gateInGC(Truck9,null,Truck9,BBLK_ID_I,bbCargoType.description,self.getProfileSetting(UT_Profile.P_OPERATOR).asString,null,self.getGate(self.getProfileSetting(UT_Profile.P_DGATE).asString),50);
	
	bblkTI := self.getTerminal.lookupTrackedItem(BBLK_ID_I, bbCargoType.id, TI_STATE_NORMAL, null, false).CM_BreakBulkGeneric;	
	self.assertTrueMsg(bblkTI &lt;&gt; null, "'" &amp; BBLK_ID_I &amp; "' cargo not created during setup");
	self.opts.purge;
	self.opts.addAssoc("IMEXStatus", TI_IMEX_STATUS_EXPORT);	
	self.opts.addAssoc("TotalWeight", 8000);
	self.updateTI(bblkTI);
	self.opts.purge;
	self.deleteStops(bblkTI);	
	
	truck10 := self.getVehicle(Truck10);
	if truck10 &lt;&gt; null then
		self.deleteVehicle(Truck10);
	endif;
	
	self.gateInGC(Truck10,null,Truck10,BBLK_ID_J,bbCargoType.description,self.getProfileSetting(UT_Profile.P_OPERATOR).asString,null,self.getGate(self.getProfileSetting(UT_Profile.P_DGATE).asString),50);
	bblkTI1 := self.getTerminal.lookupTrackedItem(BBLK_ID_J, bbCargoType.id, TI_STATE_NORMAL, null, false).CM_BreakBulkGeneric;	
	self.assertTrueMsg(bblkTI1 &lt;&gt; null, "'" &amp; BBLK_ID_J &amp; "' cargo not created during setup");
	self.opts.purge;
	self.opts.addAssoc("IMEXStatus", TI_IMEX_STATUS_EXPORT);	
	self.opts.addAssoc("TotalWeight", 8000);
	self.updateTI(bblkTI1);
	self.opts.purge;
	self.deleteStops(bblkTI1);	

	mafiTI := self.addTrailerAtLocation(MAFI_ID_H, mafiCargoType, trailerType, operator, mafiHeap.myLocationsController);
	self.assertTrueMsg(mafiTI &lt;&gt; null, MAFI_ID_H &amp; " mafi not created");
	self.deleteStops(mafiTI);
	
	//==========================
	// Tests For Scenario 8
	//==========================	
	// load bblk to mafi
	self.move(bblkTI, mafiTI.allLCs.first);	
	self.assertNoTrxErrorsOrWarnings();
	self.assertEqualMsg(bblkTI.myVoyage, mafiTI.myVoyage, " both should retain null Voyage");
	self.assertEqualMsg(bblkTI.dischargePort, mafiTI.dischargePort, " both should retain null Port");
	
	self.move(bblkTI1, mafiTI.allLCs.last);	
	self.assertNoTrxErrorsOrWarnings();
	self.assertEqualMsg(bblkTI1.myVoyage, mafiTI.myVoyage, " both should retain null Voyage");
	self.assertEqualMsg(bblkTI1.dischargePort, mafiTI.dischargePort, " both should retain null Port");
	
	//Update one Cargo Voyage
	self.opts.purge();
	self.opts.addAssoc("Voyage", voyage);
	self.updateTI(bblkTI);		
	
	// Update MAFI Voyage
	self.opts.purge();
	self.opts.addAssoc("Voyage", voyage2);
	self.opts.addAssoc("DischargePort", "NZAKL");
	self.opts.addAssoc("DontDoAssert", true);
	app.myPassport.setWarningsIgnored(true);
	self.updateTI(mafiTI);	
	
	//self.assertTrxWarning(Mafi_does_not_match);					//27.12.2024 navah1 #33742
	self.assertTrxWarning(Mafi_does_not_match_voyage);				//27.12.2024 navah1 #33742
	self.assertTrxWarning(Mafi_does_not_match_disch_port);			//27.12.2024 navah1 #33742
	
	self.assertEqualMsg(bblkTI1.myVoyage, mafiTI.myVoyage, " Cargo should inherit Voyage from MAFI");
	self.assertEqualMsg(bblkTI1.dischargePort, mafiTI.dischargePort, " Cargo should inherit POD from MAFI");	
	
epilog
	delete tis;
	delete selectedTypes;
	delete preventActions;
	delete pxyVoyage;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="tOutOfSequenceLoading" id="755937ff-70a8-490c-a164-ffa7b3c07282">
        <updating/>
        <source>tOutOfSequenceLoading() updating;
// cnwma1
// cnwrd1
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
30 October 2012	cnwrd1	Initial creation
08 Jan 2024	jlirs1	TFS 60575 - Jade 2022 upgrade fixing unitTests
*/



constants
	DischargeBox		= "UTDR0000002";
	LoadBox1			= "UTDR0000003";
	LoadBox2			= "UTDR0000004";
	LoadBox3			= "UTDR0000005";
	LoadBox4			= "UTDR0000006";
	LoadBox5			= "UTDR0000007";
	BlockStack1			= "UT_RDBS1";
	YardIC				= "UT_RD_IC";
	Ship				= "UTRDSHIP";
	Voyage1				= "UTRDVOYAGE";
	CraneTransferAreaId	= "CTRD";
	CraneId				= "CRR1";

vars
	dischargeTi,
	loadTi,
	ti4				: CM_TrackedItem;
	bs				: CM_BlockStack;
	yardIC			: CM_InterchangeArea;
	wle				: CM_WorkListEntry;
	vessel			: CM_Vessel;
	voyage			: CM_Voyage;
	slots 			: CM_SlotControllerArray;
	voyageJob		: CM_VoyageJob;
	job				: CM_Job;
	request			: CM_Request;
	voyageQueue		: CM_VoyageQueue;
	craneQueue		: CM_VoyageCraneQueue;
	crane			: CM_Machine;
	operator		: CM_Operator;
	bayName			: String;
	loadPort,
	dischargePort	: CM_Port;
	jobs			: CM_JobArray;
	voyAlloc		: CM_VoyageAllocation;
	wles 			: CM_WLEArray;
	straddle		: CM_Machine;
	tas				: StringArray;
	cta				: CM_CraneTransferArea;
//	agent			: CM_MobileAgent;
	agent : CMIF_MobileGenericAgent;
	looper			: Integer;
begin
	
	
	self.setTerminalConfig(AllowRTSwithoutVGM, true);					// 10/06/2016 cnwmh5
	
	create jobs transient;
	create wles transient;

	// delete everything first
	self.deleteContainer(DischargeBox);
	self.deleteContainer(LoadBox1);
	self.deleteContainer(LoadBox2);
	self.deleteContainer(LoadBox3);
	self.deleteContainer(LoadBox4);
	self.deleteContainer(LoadBox5);
	self.deleteTerminalArea(BlockStack1);
	self.deleteTerminalArea(YardIC);
	self.deleteVoyage(Voyage1);
	self.deleteVessel(Ship);
	self.deleteMachine(CraneId);
	self.deleteTerminalArea(CraneTransferAreaId);
	
	
	// create the terminal areas - gridded block stack, block stack and interchange
	self.opts.purge;
	self.opts.addAssoc("ActAsReleasePoint", 1);
	self.opts.addAssoc("HideOverview", true);
	yardIC := self.addInterchangeArea(YardIC, null);
	self.opts.purge;
	self.opts.addAssoc("ActAsReleasePoint", 1);
	self.opts.addAssoc("StockControlled", true);
	self.opts.addAssoc("DefaultYIC", yardIC);
	bs := self.addBlockStack(BlockStack1, 20, null);		
	
	
	// create the crane transfer area
	cta := self.addCraneTransferArea(CraneTransferAreaId);
	self.assertNotNull(cta);
	
	//create vessel and voyage
	vessel := addVesselCellular(Ship, self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));
	voyage := self.addVoyageWithContainerStructur(Voyage1, Ship, self.getProfileSetting(UT_Profile.P_OPERATOR).asString, self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString);
	self.assertNotNull(vessel);
	self.assertNotNull(voyage);
	
	// create the crane
	create tas transient;
	tas.add(cta.id);
	self.opts.purge();
	self.opts.addAssoc("CraneTransferArea", cta);
	self.opts.addAssoc("MachineLiftType", TWIN_LIFT);
	crane := self.addCrane(CraneId, null, tas, null);
	self.assertNotNull(crane);
	delete tas;

	
	loadPort := app.myRoot.allPorts[voyage.myTerminal.getConfig(PortDestCode).String];
	dischargePort := voyage.myTrade.allPortRotations.first.myPort;

	//create discharge job
	bayName := '01';
	create slots transient;
	self.getJobSlotControllers(Voyage1, bayName, DeckOnDeck, 1, 1, 1, slots);
	assertEqual(slots.size, 1);
	dischargeTi := self.addContainerAtLocnDisch(DischargeBox , "2200", "GENL", TI_IMEX_STATUS_IMPORT, slots[1], loadPort, voyage);
	// Color code and Create Discharge Jobs
	self.voyageDischargeColourCode(voyage);
	
	voyageJob := self.addVoyageJob(voyage, CraneId, slots, true);
	assertTrueMsg(voyageJob &lt;&gt; null, "Voyage job 1 not created");
	jobs.add(voyageJob);
	
	foreach wle in voyageJob.workListEntries do
		self.movePlannedWLE(wle.myTrackedItem, 	bs.myLocationsController, wle);
	endforeach;
	delete slots;
	
	self.opts.purge;																				// cnwmk3 6/01/2016
	voyAlloc := self.addVoyageAllocation(voyage, dischargePort.code,"GEN2",null,1,false,false);
	bayName :='01';
	self.logMessageNow("Create Load Jobs for bay " &amp; bayName);
	create slots transient;
	self.getJobSlotControllers(voyage.code, bayName, DeckOnDeck, 1, 2, 5, slots);
	assertEqual(slots.size, 5);
	
	self.addLCsToLOLOAllocation(true, voyAlloc, slots, null);
	self.opts.purge();
	self.opts.addAssoc("OutOfOrder", true);
	
	voyageJob := self.addVoyageJob(voyage, CraneId, slots, false);
	assertTrueMsg(voyageJob &lt;&gt; null, "Voyage job not created");
	jobs.add(voyageJob);	
	
	
	loadTi := self.addContainerForExport(LoadBox1, operator,
				"2200",	"GENL",	TI_IMEX_STATUS_EXPORT,	null, voyage.code, dischargePort.code, null).CM_Container;
	self.move(loadTi, bs.getLocationsController);
	self.setCargoReadyToShip(loadTi);
	self.deleteStops(loadTi);
	self.movePlannedRequestToJob(loadTi, slots[1], slots[1].getRequest(true));

	loadTi := self.addContainerForExport(LoadBox2, operator,
				"2200",	"GENL",	TI_IMEX_STATUS_EXPORT,	null, voyage.code, dischargePort.code, null).CM_Container;
	self.move(loadTi, bs.getLocationsController);
	self.setCargoReadyToShip(loadTi);
	self.deleteStops(loadTi);
	self.movePlannedRequestToJob(loadTi, slots[2], slots[2].getRequest(true));
	
	loadTi := self.addContainerForExport(LoadBox3, operator,
				"2200",	"GENL",	TI_IMEX_STATUS_EXPORT,	null, voyage.code, dischargePort.code, null).CM_Container;
	self.move(loadTi, bs.getLocationsController);
	self.setCargoReadyToShip(loadTi);
	self.deleteStops(loadTi);
	self.movePlannedRequestToJob(loadTi, slots[3], slots[3].getRequest(true));
	
	loadTi := self.addContainerForExport(LoadBox4, operator,
				"2200",	"GENL",	TI_IMEX_STATUS_EXPORT,	null, voyage.code, dischargePort.code, null).CM_Container;
	self.move(loadTi, bs.getLocationsController);
	self.setCargoReadyToShip(loadTi);
	self.deleteStops(loadTi);
	self.movePlannedRequestToJob(loadTi, slots[4], slots[4].getRequest(true));
	
	loadTi := self.addContainerForExport(LoadBox5, operator,
				"2200",	"GENL",	TI_IMEX_STATUS_EXPORT,	null, voyage.code, dischargePort.code, null).CM_Container;
	self.move(loadTi, bs.getLocationsController);
	self.setCargoReadyToShip(loadTi);
	self.deleteStops(loadTi);
	self.movePlannedRequestToJob(loadTi, slots[5], slots[5].getRequest(true));
	
	

	// ok have my load and discharge jobs now
	
	//load to ops
	self.loadAllJobsToOps(voyage, true);				
	
	self.addMachineRule( bs, crane.CM_Crane.transferArea, RTMoveMethod_23); //simple single straddle moves
	self.addMachineRule( crane.CM_Crane.transferArea, bs, RTMoveMethod_23); 
		
	voyageQueue := self.addVoyageQueue(voyage);
	craneQueue := self.addVoyageCraneQueue(voyage, voyageQueue, crane);
	
	// Create Queues
	foreach job in jobs do
		foreach request in job.allRequests do
			foreach wle in request.allWorkListEntries do
				wles.add(wle);
				self.queueWLE(wle);
			endforeach;
		endforeach;
	endforeach;
	
	// workJob using straddle
	self.deleteMachine("UTS1");
	self.deleteRTDevice("91");
	create tas transient;
	tas.add(bs.id); 
	tas.add(yardIC.id); 
	tas.add(crane.CM_Crane.transferArea.id); 
	self.addStraddle("UTS1", 91, tas, null);
	straddle := self.getMachine("UTS1");
	assertNotNull(straddle);
	if craneQueue &lt;&gt; null then
		beginTransaction;
		straddle.addToQueue(craneQueue, true, 0); //add straddle to crane queue
		commitTransaction;
	endif;
	delete tas;
	
	app.isRTApp:=true;  
	self.machineLogon(straddle);
	// Use Lander to move to ship
	create agent transient;
	agent.setDoNotShowMsgBox(true);

	looper := 5;
	foreach wle in wles do
		self.machineAcceptTask(straddle, wle.allRTQueueEntries.first.allTasks.first);
		
		if wle.isReceipt and wle.job.isVoyageJob then 
			//crane := wle.job.CM_VoyageJob.getJobCrane();
			self.machineCraneActionPickup(straddle, dischargeTi, ti4);
			self.machinePickup(straddle);			
			self.machineSetdownTask(straddle, wle.allRTQueueEntries.first.allTasks.last, bs.id);	
		else
			self.machinePickup(straddle);
			
			//self.machineSetdownTask(straddle, wle.allRTQueueEntries.first.allTasks.last, wle.allRTQueueEntries.first.allTasks.last.targetLocationId);
			 agent.moveTI( wle.myTrackedItem, null, slots[looper], wle, true, 0, 0, null );
			looper := looper-1;
		endif;
		
	endforeach;	
	
	self.assertTrue( dischargeTi.myPrimaryActualLocation.isYardLocation);
	self.assertTrue( loadTi.myPrimaryActualLocation.isVoyageController);
	
	self.assertEqual( loadTi.myPrimaryActualLocation, slots[1]);
	self.assertTrue( loadTi.allQueuedFutureMoves.isEmpty);
	// check txns created correctly for the following
	self.checkTIForTxnOfType(dischargeTi, TRANS_TYPE_REC_SHIP);			// 15/08/2012 cnwmh5
	self.checkTIForTxnOfType(dischargeTi, TRANS_TYPE_WHARFAGE);			// 15/08/2012 cnwmh5
	self.checkTIForTxnOfType(loadTi, TRANS_TYPE_REL_SHIP);				// 15/08/2012 cnwmh5
	self.checkTIForTxnOfType(loadTi, TRANS_TYPE_WHARFAGE);				// 15/08/2012 cnwmh5
	
epilog
	app.isRTApp:=false;  
	delete jobs;
	delete slots;
	delete wles;
	delete tas;	
	delete agent;
end;</source>
        <text>&lt;?xml version="1.0"?&gt;
&lt;UT_Additional&gt;
  &lt;Categories&gt;
    &lt;Category CanDelete="true"&gt;Fails1006&lt;/Category&gt;
  &lt;/Categories&gt;
&lt;/UT_Additional&gt;</text>
    </JadeMethod>
    <JadeMethod name="tPAR28816DLR" id="2a7c43ec-1548-4043-be2e-2dbf5c8e0fec">
        <source>tPAR28816DLR();
//
//13 August 2019	jlgrs1	Initial creation
//
constants
	BLOCKSTACK			: String = "UTMBS9";
	YARDALLOCATION 	 	: String = "UTMBS9";
	CRANENAME			: String = "CRN9";   //"UTC1";
	RTDEVICE			: Integer = 19;
	VOYAGENAME			: String = "UTMHHH9";
	VESSELNAME			: String = "UTMHHH9";
	ContainerBaseId		: String = "MDHZ99999";
vars
	vessel				: CM_Vessel;
	voyage				: CM_Voyage;
	tmpLoadCC			: CMIF_LoadColorCode;
	slotsTo				: CM_SlotControllerArray;
	slotsFrom			: CM_SlotControllerArray;
	operator			: CM_Operator;
	crane				: CM_Crane;
	voyageDischJob		: CM_VoyageJob;
	voyageLoadJob		: CM_VoyageJob;
	blockStack			: CM_BlockStack;
	locations			: CM_LCArray;
	dischargePort		: CM_Port;
	theSlot 			: CM_LocationsController;
	cargo: CM_TrackedItem;
	cta					: CM_CraneTransferArea;
	slot				: CM_SlotController;
	wle					: CM_WorkListEntry;
	trackedItem			: CM_TrackedItem;
	obj					: Object;
	strs 				: StringArray;
	tas					: StringArray;
	cargoArray			: ObjectArray;
	allObjectEditions	: CM_ObjectByOidEditionDict;	
	idx 				: Integer;
	index				: Integer;
	cargoId				: String;
begin
	operator := app.myRoot.allOperators["UTOP"];
	dischargePort := app.myRoot.allPorts["NZPOE"];
	
	// create the block stack
	self.deleteTerminalArea(BLOCKSTACK);
	blockStack := addBlockStack(BLOCKSTACK, 100, null);
	
	// create the crane transfer area
	self.deleteMachine(CRANENAME);
	self.deleteTerminalArea("UTC1T9");
	self.opts.purge();
	self.opts.addAssoc("SetCraneLaneCages", true);
	cta := self.addCraneTransferArea("UTC1T9");
	self.assertNotNull(cta);
	
	// create yard allocation;
	self.deleteYA(YARDALLOCATION);
	create locations transient;
	locations.add(blockStack.allLocationsControllers.first.CM_YardController);
	self.addYA1(YARDALLOCATION, YACriteriaType_Clean, CM_YADataBoolean.VALUE_TRUE, locations);
	
	// create Voyage
	deleteVoyage(VOYAGENAME);
	deleteVessel(VESSELNAME);
	vessel := addVesselCellular(VESSELNAME, operator);
	voyage := addVoyageWithContainerStructur(VOYAGENAME, VESSELNAME, operator.code, self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString);
	
	create cargoArray transient;
	create strs transient;
	index := 8;
	while index &gt; 0 do
		cargoId := ContainerBaseId &amp; index.String.padLeadingZeros(2);
		self.deleteContainer(cargoId);
		strs.clear();
		if index = 8 then
			strs.add("010682");
			voyage.findLocation(strs, false, theSlot, idx);
		elseif index = 7 then
			strs.add("010684");
			voyage.findLocation(strs, false, theSlot, idx);
		elseif index = 6 then
			strs.add("010686");
			voyage.findLocation(strs, false, theSlot, idx);
		elseif index = 5 then
			strs.add("010688");
			voyage.findLocation(strs, false, theSlot, idx);
		elseif index = 4 then
			strs.add("030682");
			voyage.findLocation(strs, false, theSlot, idx);
		elseif index = 3 then
			strs.add("030684");
			voyage.findLocation(strs, false, theSlot, idx);
		elseif index = 2 then
			strs.add("030686");
			voyage.findLocation(strs, false, theSlot, idx);
		elseif index = 1 then
			strs.add("030688");
			voyage.findLocation(strs, false, theSlot, idx);
		endif;
		cargo := self.addContainerAtLocnDisch(cargoId, "2200", "GENL", TI_IMEX_STATUS_IMPORT, theSlot, dischargePort, voyage);
		cargoArray.add(cargo);
		index := index - 1;
	endwhile;
		
	app.myTrxUA.trxSetDfltDischargeColourCode(voyage.myCellularVoyageStructure, app.myPassport);
	
	// create the crane
	self.deleteMachine(CRANENAME);
	create tas transient;
	tas.add(cta.id);
	self.opts.purge();
	self.opts.addAssoc("CraneTransferArea", cta);
	self.opts.addAssoc("MachineLiftType", TWIN_LIFT);
	crane := self.addCrane(CRANENAME, null, tas, null).CM_Crane;
	self.assertNotNull(crane);
		
	// colour code the discharge slots
	create slotsFrom transient;
	self.getJobSlotControllers(VOYAGENAME, "01", DeckOnDeck, 1, 1, 4, slotsFrom);
	self.markSlotsAsDischargeCC(slotsFrom, tmpLoadCC, CM_SlotRequest.Attribute_D20);
	self.markSlotsAsDischargeCC(slotsFrom, tmpLoadCC, CM_SlotRequest.Attribute_DLR);
	self.getJobSlotControllers(VOYAGENAME, "03", DeckOnDeck, 1, 1, 4, slotsFrom);
	self.markSlotsAsDischargeCC(slotsFrom, tmpLoadCC, CM_SlotRequest.Attribute_D20);
	self.markSlotsAsDischargeCC(slotsFrom, tmpLoadCC, CM_SlotRequest.Attribute_DLR);
	voyageDischJob := self.addVoyageJob(voyage, crane.id, slotsFrom, true);
	assertTrue(voyageDischJob &lt;&gt; null);
	
	// colour code the load slots
	create slotsTo transient;
	self.getJobSlotControllers(VOYAGENAME, "01", DeckOnDeck, 3, 1, 4, slotsTo);
	self.markSlotsAsLoadJob(slotsTo, tmpLoadCC);
	self.markSlotsAsLoadCC(slotsTo, tmpLoadCC, CM_SlotRequest.Attribute_D20);
	self.markSlotsAsLoadCC(slotsTo, tmpLoadCC, CM_SlotRequest.Attribute_DLR);
	self.getJobSlotControllers(VOYAGENAME, "03", DeckOnDeck, 3, 1, 4, slotsTo);
	self.markSlotsAsLoadJob(slotsTo, tmpLoadCC);
	self.markSlotsAsLoadCC(slotsTo, tmpLoadCC, CM_SlotRequest.Attribute_D20);
	self.markSlotsAsLoadCC(slotsTo, tmpLoadCC, CM_SlotRequest.Attribute_DLR);
	voyageLoadJob := self.addVoyageJob(voyage, crane.id, slotsTo, false);
	assertTrue(voyageLoadJob &lt;&gt; null);
	
	// link the slots
	create allObjectEditions transient;
	foreach slot in slotsFrom do
		allObjectEditions.add(slot);
	endforeach;
	foreach slot in slotsTo do
		allObjectEditions.add(slot);
	endforeach;
	app.myTrxUA.trxUpdateSlotReqLinkSOBDLR2(slotsFrom, slotsTo, allObjectEditions, true, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
	beginTransaction;
	foreach obj in cargoArray do
		voyageLoadJob.updateReleaseTI(obj.CM_TrackedItem);
	endforeach;
	commitTransaction;
	
	// load to job ops
	self.loadAllJobsToOps(voyage, true);	
	
	// plan the items back to the ship
	idx := 0;
	foreach obj in cargoArray do
		idx := idx + 1;
		self.planItemBackToShip(obj.CM_TrackedItem, slotsTo[idx]);
	endforeach;
	
	// use the hand held to move item(s) to the ground
	foreach obj in cargoArray do
		self.moveToGroundUsingHH(obj.CM_TrackedItem, voyageDischJob, crane);
	endforeach;
	
	idx := 0;
	foreach obj in cargoArray do
		idx := idx + 1;
		self.moveToShipUsingHatchman(obj.CM_TrackedItem, voyageLoadJob, slotsTo[idx]);
	endforeach;
	
	// check to see discharge status is completed
	foreach wle in voyageDischJob.workListEntries do
		self.assertEqual(WLE_COMPLETED, wle.status);
	endforeach;

	foreach obj in cargoArray do
		cargo := obj.CM_TrackedItem;
		self.assertTrueMsg(cargo.myPrimaryActualLocation.isKindOf(CM_SlotController), cargo.id &amp; " current location isn't a Crane Area (" &amp; 
			cargo.myPrimaryActualLocation.String &amp; ") and it isn't planned back to a slot (" &amp; cargo.myPrimaryPlannedLocation.String &amp; ")");
	endforeach;
epilog
	delete tmpLoadCC;
	delete slotsTo;
	delete slotsFrom;
	delete locations;
	delete strs;
	delete tas;
	delete allObjectEditions;
	delete cargoArray;
	
	if process.isInTransactionState then
		abortTransaction;
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="tPAR28816SOB" id="534057f0-4778-42c1-99ee-aa7338db2721">
        <source>tPAR28816SOB();
//
//13 August 2019	jlgrs1	Initial creation
//
constants
	BLOCKSTACK			: String = "UTMBS9";
	YARDALLOCATION 	 	: String = "UTMBS9";
	CRANENAME			: String = "CRN9";   //"UTC1";
	RTDEVICE			: Integer = 19;
	VOYAGENAME			: String = "UTMHHH9";
	VESSELNAME			: String = "UTMHHH9";
	ContainerBaseId		: String = "MDHZ99999";
vars
	vessel				: CM_Vessel;
	voyage				: CM_Voyage;
	tmpLoadCC			: CMIF_LoadColorCode;
	slotsTo				: CM_SlotControllerArray;
	slotsFrom			: CM_SlotControllerArray;
	operator			: CM_Operator;
	crane				: CM_Crane;
	voyageDischJob		: CM_VoyageJob;
	voyageLoadJob		: CM_VoyageJob;
	blockStack			: CM_BlockStack;
	locations			: CM_LCArray;
	dischargePort		: CM_Port;
	theSlot 			: CM_LocationsController;
	cargo: CM_TrackedItem;
	cta					: CM_CraneTransferArea;
	slot				: CM_SlotController;
	wle					: CM_WorkListEntry;
	trackedItem			: CM_TrackedItem;
	obj					: Object;
	strs 				: StringArray;
	tas					: StringArray;
	cargoArray			: ObjectArray;
	allObjectEditions	: CM_ObjectByOidEditionDict;	
	idx 				: Integer;
	index				: Integer;
	cargoId				: String;
	job				: CM_Job;
	request			: CM_Request;
begin
	operator := app.myRoot.allOperators["UTOP"];
	dischargePort := app.myRoot.allPorts["NZPOE"];
	
	// create the block stack
	self.deleteTerminalArea(BLOCKSTACK);
	blockStack := addBlockStack(BLOCKSTACK, 100, null);
	
	// create the crane transfer area
	self.deleteMachine(CRANENAME);
	self.deleteTerminalArea("UTC1T9");
	self.opts.purge();
	self.opts.addAssoc("SetCraneLaneCages", true);
	cta := self.addCraneTransferArea("UTC1T9");
	self.assertNotNull(cta);
	
	// create yard allocation;
	self.deleteYA(YARDALLOCATION);
	create locations transient;
	locations.add(blockStack.allLocationsControllers.first.CM_YardController);
	self.addYA1(YARDALLOCATION, YACriteriaType_Clean, CM_YADataBoolean.VALUE_TRUE, locations);
	
	// create Voyage
	deleteVoyage(VOYAGENAME);
	deleteVessel(VESSELNAME);
	vessel := addVesselCellular(VESSELNAME, operator);
	voyage := addVoyageWithContainerStructur(VOYAGENAME, VESSELNAME, operator.code, self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString);
	
	create cargoArray transient;
	create strs transient;
	index := 8;
	while index &gt; 0 do
		cargoId := ContainerBaseId &amp; index.String.padLeadingZeros(2);
		self.deleteContainer(cargoId);
		strs.clear();
		if index = 8 then
			strs.add("010682");
			voyage.findLocation(strs, false, theSlot, idx);
		elseif index = 7 then
			strs.add("010684");
			voyage.findLocation(strs, false, theSlot, idx);
		elseif index = 6 then
			strs.add("010686");
			voyage.findLocation(strs, false, theSlot, idx);
		elseif index = 5 then
			strs.add("010688");
			voyage.findLocation(strs, false, theSlot, idx);
		elseif index = 4 then
			strs.add("030682");
			voyage.findLocation(strs, false, theSlot, idx);
		elseif index = 3 then
			strs.add("030684");
			voyage.findLocation(strs, false, theSlot, idx);
		elseif index = 2 then
			strs.add("030686");
			voyage.findLocation(strs, false, theSlot, idx);
		elseif index = 1 then
			strs.add("030688");
			voyage.findLocation(strs, false, theSlot, idx);
		endif;
		cargo := self.addContainerAtLocnDisch(cargoId, "2200", "GENL", TI_IMEX_STATUS_IMPORT, theSlot, dischargePort, voyage);
		cargoArray.add(cargo);
		index := index - 1;
	endwhile;
		
	app.myTrxUA.trxSetDfltDischargeColourCode(voyage.myCellularVoyageStructure, app.myPassport);
	
	// create the crane
	self.deleteMachine(CRANENAME);
	create tas transient;
	tas.add(cta.id);
	self.opts.purge();
	self.opts.addAssoc("CraneTransferArea", cta);
	self.opts.addAssoc("MachineLiftType", TWIN_LIFT);
	crane := self.addCrane(CRANENAME, null, tas, null).CM_Crane;
	self.assertNotNull(crane);
		
	// colour code the discharge slots
	create slotsFrom transient;
	self.getJobSlotControllers(VOYAGENAME, "01", DeckOnDeck, 1, 1, 4, slotsFrom);
	self.markSlotsAsDischargeCC(slotsFrom, tmpLoadCC, CM_SlotRequest.Attribute_D20);
	self.markSlotsAsDischargeCC(slotsFrom, tmpLoadCC, CM_SlotRequest.Attribute_SOB);
	self.getJobSlotControllers(VOYAGENAME, "03", DeckOnDeck, 1, 1, 4, slotsFrom);
	self.markSlotsAsDischargeCC(slotsFrom, tmpLoadCC, CM_SlotRequest.Attribute_D20);
	self.markSlotsAsDischargeCC(slotsFrom, tmpLoadCC, CM_SlotRequest.Attribute_SOB);
	voyageDischJob := self.addVoyageJob(voyage, crane.id, slotsFrom, true);
	assertTrue(voyageDischJob &lt;&gt; null);
//	jobs.add(voyageDischJob);
	
	// colour code the load slots
	create slotsTo transient;
	self.getJobSlotControllers(VOYAGENAME, "01", DeckOnDeck, 3, 1, 4, slotsTo);
	self.markSlotsAsLoadJob(slotsTo, tmpLoadCC);
	self.markSlotsAsLoadCC(slotsTo, tmpLoadCC, CM_SlotRequest.Attribute_D20);
	self.markSlotsAsLoadCC(slotsTo, tmpLoadCC, CM_SlotRequest.Attribute_SOB);
	self.getJobSlotControllers(VOYAGENAME, "03", DeckOnDeck, 3, 1, 4, slotsTo);
	self.markSlotsAsLoadJob(slotsTo, tmpLoadCC);
	self.markSlotsAsLoadCC(slotsTo, tmpLoadCC, CM_SlotRequest.Attribute_D20);
	self.markSlotsAsLoadCC(slotsTo, tmpLoadCC, CM_SlotRequest.Attribute_SOB);
	voyageLoadJob := self.addVoyageJob(voyage, crane.id, slotsTo, false);
	assertTrue(voyageLoadJob &lt;&gt; null);
//	jobs.add(voyageLoadJob);
	
	// link the slots
	create allObjectEditions transient;
	foreach slot in slotsFrom do
		allObjectEditions.add(slot);
	endforeach;
	foreach slot in slotsTo do
		allObjectEditions.add(slot);
	endforeach;
	app.myTrxUA.trxUpdateSlotReqLinkSOBDLR2(slotsFrom, slotsTo, allObjectEditions, true, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
	beginTransaction;
	foreach obj in cargoArray do
		voyageLoadJob.updateReleaseTI(obj.CM_TrackedItem);
	endforeach;
	commitTransaction;
	
	// plan the items back to the ship
	idx := 0;
	foreach obj in cargoArray do
		idx := idx + 1;
		self.planItemBackToShip(obj.CM_TrackedItem, slotsTo[idx]);
		self.moveQueued(obj.CM_TrackedItem, slotsTo[idx]);
//		self.move
	endforeach;
	// load to job ops
	self.loadAllJobsToOps(voyage, true);
	
	self.moveCargoForVoyageJob(voyageDischJob, REAL_MODE);
	
	// check to see discharge status is completed
	foreach wle in voyageLoadJob.workListEntries do
		self.assertEqual(WLE_COMPLETED, wle.status);
	endforeach;

	foreach obj in cargoArray do
		cargo := obj.CM_TrackedItem;
		self.assertTrueMsg(cargo.myPrimaryActualLocation.isKindOf(CM_SlotController), cargo.id &amp; " current location isn't a Crane Area (" &amp; 
			cargo.myPrimaryActualLocation.String &amp; ") and it isn't planned back to a slot (" &amp; cargo.myPrimaryPlannedLocation.String &amp; ")");
	endforeach;
epilog
	delete tmpLoadCC;
	delete slotsTo;
	delete slotsFrom;
	delete locations;
	delete strs;
	delete tas;
	delete allObjectEditions;
	delete cargoArray;
	
	if process.isInTransactionState then
		abortTransaction;
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="tReadyToLoad" id="b04a6356-9c5d-482b-aa2e-4074ea3cad88">
        <updating/>
        <source>tReadyToLoad() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date					Who		Reason
15 December 2023		jlizm1	Initial creation  TFS 61655 Ready To Load Unit Tests
12 Nov 2025 			navhl20 Bug MTN-33391: CUX - Change voyage to ***** for MAFIs with onboard break bulk not possible
*/

constants

	VesselCode 		: String = 'CUXVES1';
	VoyageCode 		: String = 'CUXVOY1';
	
	BOOK_ID 		: String = "UTZBOOKING1";
	MAFI_ID_A		: String = "ZMAFIA";
	TILC_ID_A		: String = "ZTILCA";
	CONT_ID_A		: String = "ZJMU2312131";
	CONT_ID_B		: String = "ZJMU2312132";
	BBLK_ID_A		: String = "ZMBB2312131";
	
	BBULKCargoType 	: String = "ZBBLK"; 
	MAFICargoType 	: String = "ZMAF7";
	TrailerType 	: String = "ZMAF7A";
	TrailerType2 	: String = "ZMAF7B";
	MAFIAreaName 	: String = "UTZM1";
	TrailerTypeDesc : String = "ZMAF7A - MAFI Trailer Type";
	TrailerTypeDesc2: String = "ZMAF7B - Non MAFI Trailer Type";
	
	STOP_ID 		: Integer = 977;
	TODO_ID			: String = "UTZ_TODO";
	TODO_ID2		: String = "UTZ_TODO2";
	
vars

	operator 		: CM_Operator;
	shipLineStr 	: String;
	nullVoyage		: CM_Voyage;
	voyage 			: CM_Voyage;
	pxyVoyage		: CM_Voyage;
	vessel			: CM_Vessel;
	conflictManager : CMIF_HMS_ConflictsManager;
	
	selectedTypes 	: CM_CargoBOLTypeSet;
	preventActions 	: IntegerArray;
	stopTable 		: CM_StopsTable;
	toDoTask		: CM_ToDoTaskDesc; // Block RTL
	toDoTask2		: CM_ToDoTaskDesc; // Dont Block RTL
	options			: CM_AssociationDict;
	tis				: CM_TISet;
	
	bbCargoType 	: CM_CargoType;
	mafiCargoType	: CM_CargoType;
	contCargoType 	: CM_CargoType;
	trailerType		: CM_TILCType;
	trailerType2	: CM_TILCType;
	
	mafiHeap		: CM_BlockStack;
	
	booking 		: CM_BookingRef;
	bblkTI			: CM_BreakBulkGeneric;
	contTI			: CM_Container;
	contTI2			: CM_TrackedItem;
	mafiTI			: CM_TILC;
	trailerTI		: CM_TILC;
	
	rtlResult		: Boolean;
	rtlReason 		: String;
	
	
begin
	//==========================
	// Generic Stuff
	//==========================
	operator := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);
	shipLineStr := self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString;
	nullVoyage := self.getVoyage(NULL_VOYAGE_CODE);
	
	//==========================
	// Clean-up
	//==========================
	self.deleteStopsTable(STOP_ID);
	self.deleteCargo(BBLK_ID_A, BBULKCargoType);
	self.deleteCargo(CONT_ID_A, TI_CargoType_Container);
	self.deleteCargo(CONT_ID_B, TI_CargoType_Container);
	self.deleteCargo(MAFI_ID_A, MAFICargoType);
	self.deleteBooking(BOOK_ID);
	self.deleteVoyage(VoyageCode);
	self.deleteVessel(VesselCode);
	self.deleteCargoType(BBULKCargoType);
	self.deleteCargoType(MAFICargoType);
	self.deleteTerminalArea(MAFIAreaName);
	
	self.setTerminalConfig(DefaultVoyageProcess, VoyageProcessDefault);
	
	toDoTask := app.myRoot.allToDoTaskDescsByShortDesc.getAtKey(TODO_ID);
	if toDoTask &lt;&gt; null then
		self.deleteToDoTaskDescription(toDoTask);
	endif;
	toDoTask2 := app.myRoot.allToDoTaskDescsByShortDesc.getAtKey(TODO_ID2);
	if toDoTask2 &lt;&gt; null then
		self.deleteToDoTaskDescription(toDoTask2);
	endif;
	
	//==========================
	// Set up Voyages
	//==========================
	vessel := self.addVesselLOLOholdsRORO(VesselCode, operator);
	voyage := self.addVoyageWithConRORO(VoyageCode, VesselCode, operator.code, shipLineStr, null, 0, false, true);
	self.assertTrueMsg(voyage &lt;&gt; null, "'Voyage' not created during setup");
	
	
	//==========================
	// Set up Cargotypes
	//==========================
	self.opts.purge();
	self.opts.addAssoc("AllowDuplicateId", true);
	bbCargoType := self.addCargoType(BBULKCargoType, false);
	self.assertTrueMsg(bbCargoType &lt;&gt; null, "BBLK cargo type failed to be created");
	
	self.opts.purge;
	self.opts.addAssoc("TrackAs", ProductType_Trailer);
	mafiCargoType := self.addCargoType(MAFICargoType, false);
	self.assertTrueMsg(mafiCargoType &lt;&gt; null, "MAFI cargo type failed to be created");
	trailerType := self.addTrailerType(TrailerType, TrailerTypeDesc, mafiCargoType, 1, 600, 600, 30000, 6000, 300, TRAILER_CATEGORY_MAFI, null);
	trailerType2 := self.addTrailerType(TrailerType2, TrailerTypeDesc2, mafiCargoType, 1, 600, 600, 30000, 6000, 300, TRAILER_CATEGORY_TRAILER, null);
	
	contCargoType := app.myRoot.allCargoTypesById[TI_CargoType_Container];
	self.assertTrueMsg(contCargoType &lt;&gt; null, "Container Cargo Type not found during setup.");
	
	//==========================
	// Set up Terminal Area
	//==========================
	self.opts.purge;
	self.opts.addAssoc("TA_Type", TA_TYPE_MAFI);
	mafiHeap := self.addBlockStack(MAFIAreaName, null, null);
	self.assertNotNullMsg(mafiHeap, "Mafi Heap");
	
	//==========================
	// Set up Cargo
	//==========================
	bblkTI := self.addCargoBreakBulkAtLocation(BBLK_ID_A, bbCargoType, 80, mafiHeap.myLocationsController, null, TI_IMEX_STATUS_IMPORT, nullVoyage, operator).CM_BreakBulkGeneric;
	self.assertTrueMsg(bblkTI &lt;&gt; null, "'" &amp; BBLK_ID_A &amp; "' cargo not created during setup");
	self.opts.addAssoc("TotalWeight", 8000);
	self.updateTI(bblkTI);
	self.opts.purge;
	self.deleteStops(bblkTI);
	
	contTI := self.addContainerAtLocation(CONT_ID_A, operator, "2200", "MT", TI_IMEX_STATUS_EXPORT, mafiHeap.myLocationsController);
	self.assertTrueMsg(contTI &lt;&gt; null, CONT_ID_A &amp; " container not created");
	self.opts.addAssoc("Voyage", voyage);
	self.opts.addAssoc("DontDoAssert", true);
	app.myPassport.setWarningsIgnored(true);
	self.updateTI(contTI);
	app.myPassport.setWarningsIgnored(false);
	self.opts.purge;
	self.deleteStops(contTI);
	
	booking := self.addBookingForContainer(BOOK_ID, operator, voyage, "NZAKL", "2200", "MT");
	contTI2 := self.addPrenotedContainer(booking.allBookingRefItems.first, CONT_ID_B);
	self.deleteStops(contTI2);

	mafiTI := self.addTrailerAtLocation(MAFI_ID_A, mafiCargoType, trailerType, operator, mafiHeap.myLocationsController);
	self.assertTrueMsg(mafiTI &lt;&gt; null, MAFI_ID_A &amp; " mafi not created");
	self.deleteStops(mafiTI);
	
	trailerTI := self.addTrailerAtLocation(TILC_ID_A, mafiCargoType, trailerType2, operator, mafiHeap.myLocationsController);
	self.assertTrueMsg(trailerTI &lt;&gt; null, TILC_ID_A &amp; " trailer not created");
	self.opts.purge;
	self.opts.addAssoc("Voyage", voyage);
	self.opts.addAssoc("DontDoAssert", true);
	app.myPassport.setWarningsIgnored(true);
	self.updateTI(trailerTI);
	app.myPassport.setWarningsIgnored(false);
	self.deleteStops(trailerTI);
	
	//=============================
	// Set up Stops and TODO Tasks
	//=============================
	create options transient;
	create selectedTypes transient;
	create preventActions transient;
	selectedTypes.add(app.myRoot.allCargoTypesById[TI_CargoType_Container]);
	preventActions.add(StopPreventYardMove);
	options.addAssoc(ETRow_CheckStopAreas, preventActions);
	options.addAssoc(ETRow_IsMT, true);
	stopTable := self.addStopsTable(STOP_ID, "UTRTL", "Unit Test RTL", selectedTypes, options);
	
	toDoTask := self.createToDoTaskDesc(TODO_ID);
	self.opts.purge();
	self.opts.addAssoc("DoNotBlockRTL", true);
	toDoTask2 := self.createToDoTaskDesc(TODO_ID2);
	
	//==========================
	// Tests
	//==========================
	
	// Offsite - not ready
	rtlResult := contTI2.evaluateReadyToLoadReason(rtlReason);
	self.assertFalseMsg(rtlResult, CONT_ID_B &amp; " should not be rtl as is offsite");
	
	
	// Import - not ready
	rtlResult := bblkTI.evaluateReadyToLoadReason(rtlReason);
	self.assertFalseMsg(rtlResult, BBLK_ID_A &amp; " should not be rtl as is import");
	
	// Update to Export
	self.opts.purge;
	self.opts.addAssoc("IMEXStatus", TI_IMEX_STATUS_EXPORT);
	self.updateTI(bblkTI);
	
	
	// Null Voyage - not ready
	rtlResult := bblkTI.evaluateReadyToLoadReason(rtlReason);
	self.assertFalseMsg(rtlResult, BBLK_ID_A &amp; " should not be rtl as has null voyage");
	
	// voyage status post loading - not ready
	// Will put later on
	
	// Has Stops - not ready
	self.addStopById(contTI, STOP_ID);
	rtlResult := contTI.evaluateReadyToLoadReason(rtlReason);
	self.assertFalseMsg(rtlResult, CONT_ID_A &amp; " should not be rtl as has stops");
	self.deleteStops(contTI);
	
	// Has Blocking TODO task - not ready
	create tis transient;
	tis.add(contTI);
	self.addToDoTask(toDoTask, tis);
	rtlResult := contTI.evaluateReadyToLoadReason(rtlReason);
	self.assertFalseMsg(rtlResult, CONT_ID_A &amp; " should not be rtl as has TODO Task");
	
	// remove blocking task, add non blocking task
	app.myTrxUA.trxUpdateTIToDoTaskRemove(contTI, toDoTask.code, app.myPassport);
	self.assertTrueMsg(not contTI.allToDoTasksToDo.includesToDoDesc(toDoTask.code), "Failed to remove To Do Task");
	self.addToDoTask(toDoTask2, tis);
	
	// load bblk to mafi
	self.move(bblkTI, mafiTI.allLCs.first);
	
	// Child Cargo - Ready
	self.opts.purge();
	self.opts.addAssoc("Voyage", voyage);
	self.opts.addAssoc("DontDoAssert", true);
	app.myPassport.setWarningsIgnored(true);
	//self.updateTI(bblkTI);									//24.11.2025 navhl20 #33391
	self.updateTI(mafiTI);										//24.11.2025 navhl20 #33391
	app.myPassport.setWarningsIgnored(false);
	self.deleteStops(bblkTI);
	rtlResult := bblkTI.evaluateReadyToLoadReason(rtlReason);
	self.assertTrueMsg(rtlResult, BBLK_ID_A &amp; " should be rtl as is onboard; error: " &amp; rtlReason);
	
	// Cargo not on MAFI - Not Ready
	rtlResult := contTI.evaluateReadyToLoadReason(rtlReason);
	self.assertFalseMsg(rtlResult, CONT_ID_A &amp; " should not be rtl as is not onboard");
	
	// Mafi full but not lashed - Not Ready
	rtlResult := mafiTI.evaluateReadyToLoadReason(rtlReason);
	self.assertFalseMsg(rtlResult, MAFI_ID_A &amp; " should not be rtl as has onboard cargo but is not lashed");	
	
	// Not all onboard cargo is RTL = Not Ready
	// load container to mafi
	self.move(contTI, mafiTI.allLCs.first);
	rtlResult := bblkTI.evaluateReadyToLoadReason(rtlReason);
	self.assertTrueMsg(rtlResult, CONT_ID_A &amp; " should be rtl as is onboard; error: " &amp; rtlReason);
	tis.clear();
	tis.add(contTI);
	self.addToDoTask(toDoTask, tis);
	rtlResult := contTI.evaluateReadyToLoadReason(rtlReason);
	self.assertFalseMsg(rtlResult, CONT_ID_A &amp; " should not be rtl as has TODO Task");
	rtlResult := mafiTI.evaluateReadyToLoadReason(rtlReason);
	self.assertFalseMsg(rtlResult, MAFI_ID_A &amp; " should not be rtl as has 'notRTL' onboard cargo");
	// remove task again
	app.myTrxUA.trxUpdateTIToDoTaskRemove(contTI, toDoTask.code, app.myPassport);
	
	// Trailers not mafis that pass base criteria - Ready
	rtlResult := trailerTI.evaluateReadyToLoadReason(rtlReason);
	self.assertTrueMsg(rtlResult, TILC_ID_A &amp; " should be rtl as is not a mafi; error: " &amp; rtlReason);
	
	// Mafi full but not lashed, but has at least one container - Ready
	rtlResult := mafiTI.evaluateReadyToLoadReason(rtlReason);
	self.assertTrueMsg(rtlResult, MAFI_ID_A &amp; " should be rtl as has onboard cargo and is not lashed but has an onboard container; error: " &amp; rtlReason);	
	
	// Mafi is partially full lashed - Ready
	self.opts.purge();
	self.opts.addAssoc("ContentsStatus", TI_CONTENTS_STATUS_PRTLOADLASH);
	self.opts.addAssoc("DontDoAssert", true);
	app.myPassport.setWarningsIgnored(true);
	self.updateTI(mafiTI);
	app.myPassport.setWarningsIgnored(false);
	self.deleteStops(mafiTI);
	rtlResult := mafiTI.evaluateReadyToLoadReason(rtlReason);
	self.assertTrueMsg(rtlResult, MAFI_ID_A &amp; " should be rtl as is partially full lashed; error: " &amp; rtlReason);
	
	// Mafi is full lashed - Ready
	self.opts.purge();
	self.opts.addAssoc("ContentsStatus", TI_CONTENTS_STATUS_FULLLASHED);
	self.opts.addAssoc("DontDoAssert", true);
	app.myPassport.setWarningsIgnored(true);
	self.updateTI(mafiTI);
	app.myPassport.setWarningsIgnored(false);
	self.deleteStops(mafiTI);
	rtlResult := mafiTI.evaluateReadyToLoadReason(rtlReason);
	self.assertTrueMsg(rtlResult, MAFI_ID_A &amp; " should be rtl as is full lashed; error: " &amp; rtlReason);
	
	// Voyage status post loading - Not Ready
	// update voyage to closed
	beginLoad;
	pxyVoyage := voyage.pxyCreateUpdateProxy;
	endLoad;
	pxyVoyage.setPropertyValue(CM_Voyage::status.name,Voyage_Status_Closed);
	app.myTrxUA.trxUpdateVoyage(false,false,pxyVoyage,conflictManager,null,false,app.myPassport);
	self.assertNoTrxErrorsPassport("Update Voyage to closed failed");
	delete pxyVoyage;
	
	rtlResult := mafiTI.evaluateReadyToLoadReason(rtlReason);
	self.assertFalseMsg(rtlResult, MAFI_ID_A &amp; " should not be rtl as voyage is closed");
	
	rtlResult := contTI.evaluateReadyToLoadReason(rtlReason);
	self.assertFalseMsg(rtlResult, CONT_ID_A &amp; " should not be rtl as voyage is closed");
	
	rtlResult := bblkTI.evaluateReadyToLoadReason(rtlReason);
	self.assertFalseMsg(rtlResult, BBLK_ID_A &amp; " should not be rtl as voyage is closed");
	
	//==========================
	// Final Clean-up
	//==========================
	self.deleteStopsTable(STOP_ID);
	self.deleteToDoTaskDescription(toDoTask);
	self.deleteToDoTaskDescription(toDoTask2);
	self.deleteCargo(BBLK_ID_A, bbCargoType);
	self.deleteCargo(CONT_ID_A, contCargoType);
	self.deleteCargo(CONT_ID_B, contCargoType);
	self.deleteCargo(MAFI_ID_A, mafiCargoType);
	self.deleteCargo(TILC_ID_A, mafiCargoType);
	self.deleteBooking(BOOK_ID);
	
	self.deleteVoyage(VoyageCode);
	self.deleteVessel(VesselCode);
	
	self.deleteTrailerType(trailerType);
	self.deleteCargoType(BBULKCargoType);
	self.deleteCargoType(MAFICargoType);
	
	self.deleteTerminalArea(MAFIAreaName);
	
epilog
	delete tis;
	delete options;
	delete selectedTypes;
	delete preventActions;
	delete pxyVoyage;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="tReadyToLoadAuto" id="59aa8572-8262-4f64-a567-2f3fa46d188a">
        <source>tReadyToLoadAuto();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 December 2023	jlier1	Initial creation 61677

*/
constants

	VesselCode 		: String = 'CUXVES1';
	VoyageCode 		: String = 'CUXVOY1';
	MAFI_ID_A		: String = "ZMAFIA";
	MAFI_ID_B		: String = "ZMAFIB";
	CONT_ID_A		: String = "ZJMU2312131";
	CONT_ID_B		: String = "ZJMU2312132";
	BBLK_ID_A		: String = "ZMBB2312131";
	BBLK_ID_B		: String = "ZMBB2312132";
	
	BBULKCargoType 	: String = "ZBBLK"; 
	MAFICargoType 	: String = "ZMAF7";
	TrailerType 	: String = "ZMAF7A";
	MAFIAreaName 	: String = "UTZM1";
	TrailerTypeDesc : String = "ZMAF7A - MAFI Trailer Type";
	
	STOP_ID 		: Integer = 977;
	TODO_ID			: String = "UTZ_TODO";
	TODO_ID2		: String = "UTZ_TODO2";
	
vars

	operator 		: CM_Operator;
	shipLineStr 	: String;
	nullVoyage		: CM_Voyage;
	voyage 			: CM_Voyage;
	vessel			: CM_Vessel;
	
	selectedTypes 	: CM_CargoBOLTypeSet;
	preventActions 	: IntegerArray;
	stopTable 		: CM_StopsTable;
	toDoTask		: CM_ToDoTaskDesc; // Block RTL
	toDoTask2		: CM_ToDoTaskDesc; // Dont Block RTL
	options			: CM_AssociationDict;
	tis				: CM_TISet;	
	bbCargoType 	: CM_CargoType;
	mafiCargoType	: CM_CargoType;
	contCargoType 	: CM_CargoType;
	trailerType		: CM_TILCType;	
	mafiHeap		: CM_BlockStack;
	bblkTI			: CM_BreakBulkGeneric;
	contTI			: CM_Container;
	contTI2			: CM_TrackedItem;
	mafiTI			: CM_TILC;
	pxyVoyage 		: CM_Voyage;
	conflictManager : CMIF_HMS_ConflictsManager;
	pxyLink : CM_ProxyLink;
begin
	//==========================
	// Generic Stuff
	//==========================
	operator := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);
	shipLineStr := self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString;
	nullVoyage := self.getVoyage(NULL_VOYAGE_CODE);
	
	//==========================
	// Clean-up
	//==========================
	self.deleteStopsTable(STOP_ID);
	self.deleteCargo(BBLK_ID_A, bbCargoType);
	self.deleteCargo(CONT_ID_A, contCargoType);
	self.deleteCargo(CONT_ID_B, contCargoType);
	self.deleteCargo(MAFI_ID_A, mafiCargoType);
	self.deleteVoyage(VoyageCode);
	self.deleteVessel(VesselCode);
	self.deleteCargoType(BBULKCargoType);
	self.deleteCargoType(MAFICargoType);
	self.deleteTerminalArea(MAFIAreaName);
	
	self.setTerminalConfig(AutoEvalReadyToLoad, true);
	self.setTerminalConfig(ClearVoyageIMEXStorage, false);
	self.setTerminalConfig(DefaultVoyageProcess, VoyageProcessDefault);
	
	toDoTask := app.myRoot.allToDoTaskDescsByShortDesc.getAtKey(TODO_ID);
	if toDoTask &lt;&gt; null then
		self.deleteToDoTaskDescription(toDoTask);
	endif;
	toDoTask2 := app.myRoot.allToDoTaskDescsByShortDesc.getAtKey(TODO_ID2);
	if toDoTask2 &lt;&gt; null then
		self.deleteToDoTaskDescription(toDoTask2);
	endif;
	toDoTask:=null;
	toDoTask2:=null;
	
	
	//==========================
	// Set up Voyages
	//==========================
	vessel :=self.addVesselBasic(VesselCode, operator,false,true,true,false);
	//vessel := self.addVesselLOLOholdsRORO(VesselCode, operator);
	voyage := self.addVoyageWithConRORO(VoyageCode, VesselCode, operator.code, shipLineStr, null, 0, false, true);
	self.assertTrueMsg(voyage &lt;&gt; null, "'Voyage' not created during setup");
	
	beginTransaction;
		delete voyage.myROROStructure;
	commitTransaction;
	
	//==========================
	// Set up Cargotypes
	//==========================
	self.opts.purge();
	self.opts.addAssoc("AllowDuplicateId", true);
	bbCargoType := self.addCargoType(BBULKCargoType, false);
	self.assertTrueMsg(bbCargoType &lt;&gt; null, "BBLK cargo type failed to be created");
	
	self.opts.purge;
	self.opts.addAssoc("TrackAs", ProductType_Trailer);
	mafiCargoType := self.addCargoType(MAFICargoType, false);
	self.assertTrueMsg(mafiCargoType &lt;&gt; null, "MAFI cargo type failed to be created");
	trailerType := self.addTrailerType(TrailerType, TrailerTypeDesc, mafiCargoType, 1, 600, 600, 30000, 6000, 300, TRAILER_CATEGORY_MAFI, null);
	
	contCargoType := app.myRoot.allCargoTypesById[TI_CargoType_Container];
	self.assertTrueMsg(contCargoType &lt;&gt; null, "Container Cargo Type not found during setup.");
	
	//==========================
	// Set up Terminal Area
	//==========================
	self.opts.purge;
	self.opts.addAssoc("TA_Type", TA_TYPE_MAFI);
	mafiHeap := self.addBlockStack(MAFIAreaName, null, null);
	self.assertNotNullMsg(mafiHeap, "Mafi Heap");
	//===========================
	//set auto eval ready to load
	//============================
	
	//========================
	// set up cargo
	//========================
	
	// add trailer
	mafiTI := self.addTrailerAtLocation(MAFI_ID_A, mafiCargoType, trailerType, operator, mafiHeap.myLocationsController);
	self.assertTrueMsg(mafiTI &lt;&gt; null, MAFI_ID_A &amp; " mafi not created");
	
	self.assertFalseMsg(mafiTI.readyToLoad,"Empty storage MAFI with no voyage should not be ready to load");
	self.opts.addAssoc("Voyage", voyage);
	self.opts.addAssoc("DontDoAssert", true);
	app.myPassport.setWarningsIgnored(true);
	self.updateTI(mafiTI);
	app.myPassport.setWarningsIgnored(false);
	self.opts.purge;
	self.deleteStops(mafiTI);
	self.assertTrueMsg(mafiTI.readyToLoad,"MAFI  not on roro voyage should  be ready to load");
	
	
	// add container
	contTI := self.addContainerAtLocation(CONT_ID_A, operator, "2200", "MT", TI_IMEX_STATUS_EXPORT, mafiHeap.myLocationsController);
	self.assertTrueMsg(contTI &lt;&gt; null, CONT_ID_A &amp; " container not created");
	self.opts.addAssoc("Voyage", voyage);
	self.opts.addAssoc("DontDoAssert", true);
	app.myPassport.setWarningsIgnored(true);
	self.updateTI(contTI);
	app.myPassport.setWarningsIgnored(false);
	self.opts.purge;
	self.deleteStops(contTI);
	self.assertTrueMsg(contTI.readyToLoad,"Container not on MAFI on non roro voyage should  be ready to load");
	
	
	//add bb
	bblkTI := self.addCargoBreakBulkAtLocation(BBLK_ID_A, bbCargoType, 80, mafiHeap.myLocationsController, null, TI_IMEX_STATUS_IMPORT, nullVoyage, operator).CM_BreakBulkGeneric;
	self.assertTrueMsg(bblkTI &lt;&gt; null, "'" &amp; BBLK_ID_A &amp; "' cargo not created during setup");
	self.opts.addAssoc("TotalWeight", 8000);
	self.opts.addAssoc("Voyage", voyage);
	self.updateTI(bblkTI);
	self.opts.purge;
	self.deleteStops(bblkTI);
	
	self.assertTrueMsg(bblkTI.readyToLoad,"BBK  not on roro voyage should  be ready to load");
	
	//Update MAFI to export with a voyage
	//update the voyage to include RORO ???
	beginLoad;
	pxyVoyage:=voyage.pxyCreateUpdateProxy;
	endLoad;
	pxyVoyage.setProxyForVoyageType(	false,
										true,
										true,
										vessel);
	app.myTrxUA.trxUpdateVoyage(false,false,pxyVoyage,conflictManager,null,false,app.myPassport);
	self.assertNoTrxErrorsPassport("Update Voyage to RORO failed");
	self.assertTrueMsg(mafiTI.readyToLoad,"Empty export MAFI with  voyage should  be ready to load");
	self.assertFalseMsg(contTI.readyToLoad,"Container not on MAFI on  roro voyage should not be ready to load");
	self.assertFalseMsg(bblkTI.readyToLoad,"BBK  on roro voyage should not be ready to load");
	
	pxyLink:= app.myProxyManager.allReals[voyage];
	if pxyLink &lt;&gt; null then
		pxyLink.originalRealEdition :=voyage.edition;
	endif;

	// update voyage to closed 
	pxyVoyage.setPropertyValue(CM_Voyage::status.name,Voyage_Status_Closed);
	app.myTrxUA.trxUpdateVoyage(false,false,pxyVoyage,conflictManager,null,false,app.myPassport);
	self.assertNoTrxErrorsPassport("Update Voyage to closed failed");
	self.assertFalseMsg(mafiTI.readyToLoad,"Empty export MAFI on closed  voyage should not  be ready to load");
	self.assertFalseMsg(contTI.readyToLoad,"Container not on MAFI on closed voyage should not be ready to load");
	self.assertFalseMsg(bblkTI.readyToLoad,"BBK  on closed voyage should not be not ready to load");
	
	
	pxyLink:= app.myProxyManager.allReals[voyage];
	if pxyLink &lt;&gt; null then
		pxyLink.originalRealEdition :=voyage.edition;
	endif;
	pxyVoyage.setProxyForVoyageType(	false,
										false,
										true,
										vessel);
	
	pxyVoyage.setPropertyValue(CM_Voyage::status.name,Voyage_Status_Pending);
	app.myTrxUA.trxUpdateVoyage(false,false,pxyVoyage,conflictManager,null,false,app.myPassport);
	self.assertNoTrxErrorsPassport("Update Voyage to closed failed");
	self.assertTrueMsg(mafiTI.readyToLoad,"Empty export MAFI on non roro pending voyage should   be ready to load");
	self.assertTrueMsg(contTI.readyToLoad,"Container not on MAFI non roro pending voyage should  be ready to load");
	self.assertTrueMsg(bblkTI.readyToLoad,"BBK  on  non roro pending voyage should  be not ready to load");
	
	//=============================
	// Set up Stops and TODO Tasks
	//=============================
	create options transient;
	create selectedTypes transient;
	create preventActions transient;
	selectedTypes.add(app.myRoot.allCargoTypesById[TI_CargoType_Container]);
	preventActions.add(StopPreventYardMove);
	options.addAssoc(ETRow_CheckStopAreas, preventActions);
	options.addAssoc(ETRow_IsMT, true);
	stopTable := self.addStopsTable(STOP_ID, "UTRTL", "Unit Test RTL", selectedTypes, options);
	
	toDoTask := self.createToDoTaskDesc(TODO_ID);
	self.opts.purge();
	self.opts.addAssoc("DoNotBlockRTL", true);
	toDoTask2 := self.createToDoTaskDesc(TODO_ID2);
	
	
	self.addStopById(contTI, STOP_ID);
	self.assertFalseMsg(contTI.readyToLoad, CONT_ID_A &amp; " should not be rtl as has stops");
	self.deleteStops(contTI);
	self.assertTrueMsg(contTI.readyToLoad, CONT_ID_A &amp; " should  be rtl as has no stops");
	
	
	create tis transient;
	tis.add(contTI);
	self.addToDoTask(toDoTask, tis);
	self.assertFalseMsg(contTI.readyToLoad, CONT_ID_A &amp; " should not be rtl as has ToDO Task");
	
	// remove blocking task, add non blcoking task
	app.myTrxUA.trxUpdateTIToDoTaskRemove(contTI, toDoTask.code, app.myPassport);
	self.assertTrueMsg(not contTI.allToDoTasksToDo.includesToDoDesc(toDoTask.code), "Failed to remove To Do Task");
	self.assertTrueMsg(contTI.readyToLoad, CONT_ID_A &amp; " should  be rtl as has no ToDO Task");
	
	//change to con RORO 
	pxyLink:= app.myProxyManager.allReals[voyage];
	if pxyLink &lt;&gt; null then
		pxyLink.originalRealEdition :=voyage.edition;
	endif;
	pxyVoyage.setProxyForVoyageType(	false,
										true,
										true,
										vessel);
	
	pxyVoyage.setPropertyValue(CM_Voyage::status.name,Voyage_Status_Pending);
	app.myTrxUA.trxUpdateVoyage(false,false,pxyVoyage,conflictManager,null,false,app.myPassport);
	self.assertNoTrxErrorsPassport("Update Voyage to closed failed");
	self.assertTrueMsg(mafiTI.readyToLoad,"Empty export MAFI on  roro pending voyage should   be ready to load");
	self.assertFalseMsg(contTI.readyToLoad,"Container not on MAFI  roro pending voyage should  be not be ready to load");
	self.assertFalseMsg(bblkTI.readyToLoad,"BBK  on   roro pending voyage should  be not ready to load");
	
	
	// load bbklk to mafi
	self.move(bblkTI, mafiTI.allLCs.first);
	
	self.assertTrueMsg(bblkTI.readyToLoad,"BBK as a child on  roro pending voyage should   be ready to load");
	self.assertFalseMsg(mafiTI.readyToLoad,"MAFI with bbk cargo which is not lashed  on  roro pending voyage should  not be ready to load");
	
	self.opts.addAssoc("contentsStatus", TI_CONTENTS_STATUS_PRTLOADLASH);
	self.updateTI(mafiTI);
	self.opts.purge;
	self.assertTrueMsg(mafiTI.readyToLoad,"MAFI with bbk cargo which is  lashed  on  roro pending voyage should  be ready to load");
	
	
	self.move(bblkTI, mafiHeap.myLocationsController);
	self.assertFalseMsg(bblkTI.readyToLoad,"BBK  on  roro pending voyage not on MAFI should not  be ready to load");
	self.assertFalseMsg(mafiTI.readyToLoad,"Storage MAFI with no cargo  on  roro pending voyage should not be ready to load");
	
	self.opts.addAssoc("contentsStatus", TI_CONTENTS_STATUS_EMPTY);
	self.updateTI(mafiTI);
	self.opts.purge;
	
	self.move(contTI, mafiTI.allLCs.first);
	
	
	self.assertTrueMsg(contTI.readyToLoad,"Container on MAFI on  roro pending voyage should be ready to load");
	self.assertTrueMsg(mafiTI.readyToLoad,"MAFI on  roro pending voyage  with a Container on board should be ready to load");
	//==========================
	// Final Clean-up
	//==========================
	/*self.deleteStopsTable(STOP_ID);
	
	self.deleteToDoTaskDescription(toDoTask);
	self.deleteToDoTaskDescription(toDoTask2);
	self.deleteCargo(BBLK_ID_A, bbCargoType);
	self.deleteCargo(CONT_ID_A, contCargoType);
	self.deleteCargo(CONT_ID_A, contCargoType);
	self.deleteCargo(MAFI_ID_A, mafiCargoType);
	self.deleteBooking(BOOK_ID);
	
	self.deleteVoyage(VoyageCode);
	self.deleteVessel(VesselCode);
	
	self.deleteTrailerType(trailerType);
	self.deleteCargoType(BBULKCargoType);
	self.deleteCargoType(MAFICargoType);
	
	self.deleteTerminalArea(MAFIAreaName);*/
	
epilog
	delete tis;
	delete options;
	delete selectedTypes;
	delete preventActions;
	delete pxyVoyage;
end;</source>
    </JadeMethod>
    <JadeMethod name="tReadyToLoadAutoQueue" id="1fa296d8-7828-4640-9f12-d19f9aab61ff">
        <source>tReadyToLoadAutoQueue();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 January 2024	jlier1	Initial creation

*/
constants
	
	VesselCode 		: String = 'CUXVES1';
	VoyageCode 		: String = 'CUXVOY1';
	MAFI_ID_A		: String = "ZMAFIA";
	MAFI_ID_B		: String = "ZMAFIB";
	CONT_ID_A		: String = "ZJMU2312131";
	CONT_ID_B		: String = "ZJMU2312132";
	BBLK_ID_A		: String = "ZMBB2312131";
	BBLK_ID_B		: String = "ZMBB2312132";
	
	BBULKCargoType 	: String = "ZBBLK"; 
	MAFICargoType 	: String = "ZMAF7";
	TrailerType 	: String = "ZMAF7A";
	MAFIAreaName 	: String = "UTZM1";
	TrailerTypeDesc : String = "ZMAF7A - MAFI Trailer Type";
	
	STOP_ID 		: Integer = 977;
	TODO_ID			: String = "UTZ_TODO";
	TODO_ID2		: String = "UTZ_TODO2";
	
vars
	operator 		: CM_Operator;
	shipLineStr 	: String;
	nullVoyage		: CM_Voyage;
		bbCargoType 	: CM_CargoType;
	mafiCargoType	: CM_CargoType;
	contCargoType 	: CM_CargoType;
	trailerType		: CM_TILCType;
		voyage 			: CM_Voyage;
	vessel			: CM_Vessel;
	mafiHeap		: CM_BlockStack;
	selectedTypes 	: CM_CargoBOLTypeSet;
	pxyVoyage 		: CM_Voyage;
	bblkTI			: CM_BreakBulkGeneric;
	contTI			: CM_Container;
	contTI2			: CM_TrackedItem;
	mafiTI			: CM_TILC;
	conflictManager : CMIF_HMS_ConflictsManager;
	pxyLink : CM_ProxyLink;
	tis				: CM_TISet;	
	queueControl : CMIF_MoveController;
begin
	//==========================
	// Generic Stuff
	//==========================
	operator := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);
	shipLineStr := self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString;
	nullVoyage := self.getVoyage(NULL_VOYAGE_CODE);
	//==========================
	// Clean-up
	//==========================
	self.deleteCargo(BBLK_ID_A, bbCargoType);
	self.deleteCargo(CONT_ID_A, contCargoType);
	self.deleteCargo(CONT_ID_B, contCargoType);
	self.deleteCargo(MAFI_ID_A, mafiCargoType);
	self.deleteVoyage(VoyageCode);
	self.deleteVessel(VesselCode);
	self.deleteCargoType(BBULKCargoType);
	self.deleteCargoType(MAFICargoType);
	self.deleteTerminalArea(MAFIAreaName);
	
	self.setTerminalConfig(AutoEvalReadyToLoad, true);
	self.setTerminalConfig(AutoQueueReadyToLoad, true);
	self.setTerminalConfig(DefaultVoyageProcess, VoyageProcessDefault);
	
	//==========================
	// Set up Voyages
	//==========================
	vessel :=self.addVesselBasic(VesselCode, operator,false,true,true,false);
	//vessel := self.addVesselLOLOholdsRORO(VesselCode, operator);
	voyage := self.addVoyageWithConRORO(VoyageCode, VesselCode, operator.code, shipLineStr, null, 0, false, true);
	self.assertTrueMsg(voyage &lt;&gt; null, "'Voyage' not created during setup");
	
	beginTransaction;
		delete voyage.myROROStructure;
	commitTransaction;
	
	
	//==========================
	// Set up Cargotypes
	//==========================
	self.opts.purge();
	self.opts.addAssoc("AllowDuplicateId", true);
	bbCargoType := self.addCargoType(BBULKCargoType, false);
	self.assertTrueMsg(bbCargoType &lt;&gt; null, "BBLK cargo type failed to be created");
	
	self.opts.purge;
	self.opts.addAssoc("TrackAs", ProductType_Trailer);
	mafiCargoType := self.addCargoType(MAFICargoType, false);
	self.assertTrueMsg(mafiCargoType &lt;&gt; null, "MAFI cargo type failed to be created");
	trailerType := self.addTrailerType(TrailerType, TrailerTypeDesc, mafiCargoType, 1, 600, 600, 30000, 6000, 300, TRAILER_CATEGORY_MAFI, null);
	
	contCargoType := app.myRoot.allCargoTypesById[TI_CargoType_Container];
	self.assertTrueMsg(contCargoType &lt;&gt; null, "Container Cargo Type not found during setup.");
	
	//==========================
	// Set up Terminal Area
	//==========================
	self.opts.purge;
	self.opts.addAssoc("TA_Type", TA_TYPE_MAFI);
	mafiHeap := self.addBlockStack(MAFIAreaName, null, null);
	self.assertNotNullMsg(mafiHeap, "Mafi Heap");
	//===========================
	//set auto eval ready to load
	//============================
	
	//========================
	// set up cargo
	//========================
	
	// add trailer
	mafiTI := self.addTrailerAtLocation(MAFI_ID_A, mafiCargoType, trailerType, operator, mafiHeap.myLocationsController);
	self.assertTrueMsg(mafiTI &lt;&gt; null, MAFI_ID_A &amp; " mafi not created");
	
	self.assertFalseMsg(mafiTI.readyToLoad,"Empty storage MAFI with no voyage should not be ready to load");
	self.opts.addAssoc("Voyage", voyage);
	self.opts.addAssoc("DontDoAssert", true);
	app.myPassport.setWarningsIgnored(true);
	self.updateTI(mafiTI);
	app.myPassport.setWarningsIgnored(false);
	self.opts.purge;
	self.deleteStops(mafiTI);
	self.assertTrueMsg(mafiTI.readyToLoad,"MAFI  not on roro voyage should  be ready to load");
	
	
	// add container
	contTI := self.addContainerAtLocation(CONT_ID_A, operator, "2200", "MT", TI_IMEX_STATUS_EXPORT, mafiHeap.myLocationsController);
	self.assertTrueMsg(contTI &lt;&gt; null, CONT_ID_A &amp; " container not created");
	self.opts.addAssoc("Voyage", voyage);
	self.opts.addAssoc("DontDoAssert", true);
	app.myPassport.setWarningsIgnored(true);
	self.updateTI(contTI);
	app.myPassport.setWarningsIgnored(false);
	self.opts.purge;
	self.deleteStops(contTI);
	self.assertTrueMsg(contTI.readyToLoad,"Container not on MAFI on non roro voyage should  be ready to load");
	
	
	//add bb
	bblkTI := self.addCargoBreakBulkAtLocation(BBLK_ID_A, bbCargoType, 80, mafiHeap.myLocationsController, null, TI_IMEX_STATUS_IMPORT, nullVoyage, operator).CM_BreakBulkGeneric;
	self.assertTrueMsg(bblkTI &lt;&gt; null, "'" &amp; BBLK_ID_A &amp; "' cargo not created during setup");
	self.opts.addAssoc("TotalWeight", 8000);
	self.opts.addAssoc("Voyage", voyage);
	self.updateTI(bblkTI);
	self.opts.purge;
	self.deleteStops(bblkTI);
	
	self.assertTrueMsg(bblkTI.readyToLoad,"BBK  not on roro voyage should  be ready to load");
	
	//Update MAFI to export with a voyage
	//update the voyage to include RORO ???
	beginLoad;
	pxyVoyage:=voyage.pxyCreateUpdateProxy;
	endLoad;
	pxyVoyage.setProxyForVoyageType(	false,
										true,
										true,
										vessel);
	app.myTrxUA.trxUpdateVoyage(false,false,pxyVoyage,conflictManager,null,false,app.myPassport);
	self.assertNoTrxErrorsPassport("Update Voyage to RORO failed");
	self.assertTrueMsg(mafiTI.readyToLoad,"Empty export MAFI with  voyage should  be ready to load");
	self.assertFalseMsg(contTI.readyToLoad,"Container not on MAFI on  roro voyage should not be ready to load");
	self.assertFalseMsg(bblkTI.readyToLoad,"BBK  on roro voyage should not be ready to load");
	
	
	
	
	//voyage is pending so not cargo should be queued
	self.assertFalseMsg(mafiTI.isQueued, "Voyage Pending should not be queued");
	self.assertFalseMsg(contTI.isQueued, "Voyage Pending not RTL should not be queued");
	self.assertFalseMsg(bblkTI.isQueued, "Voyage Pending not RTL should not be queued");
	
	//queue container to the ship block stack to check it is unqueued when voyage set to loading
	create queueControl transient;
	queueControl.setMyTrackedItem(contTI);
	queueControl.setMyToPrimaryLocation(voyage.myShipBlockStack);
	queueControl.setMoveMode(QUEUE_MODE);
	app.myTrxUA.trxMoveTrackedItem(queueControl, app.myPassport);
	self.assertNoTrxErrorsPassport("Container failed to queue");
	
	//change voyage to Loading
	pxyLink:= app.myProxyManager.allReals[voyage];
	if pxyLink &lt;&gt; null then
		pxyLink.originalRealEdition :=voyage.edition;
	endif;
	pxyVoyage.setPropertyValue(CM_Voyage::status.name,Voyage_Status_Loading);
	app.myTrxUA.trxUpdateVoyage(false,false,pxyVoyage,conflictManager,null,false,app.myPassport);
	self.assertNoTrxErrorsPassport("Update Voyage to Loading failed");
	
	//MAFI is RTL should queue to the Vessel block stack
	self.assertTrueMsg(mafiTI.isQueued, "Voyage Loading should  be queued");
	self.assertTrueMsg(mafiTI.allQueuedFutureMoves.first &lt;&gt; null , "Voyage Loading should  be queued");
	self.assertTrueMsg(mafiTI.allQueuedFutureMoves.first.CM_FutureMoveQueued.allLocationsControllers.first &lt;&gt; null , "Voyage Loading should  be queued");
	self.assertTrueMsg(mafiTI.allQueuedFutureMoves.first.CM_FutureMoveQueued.allLocationsControllers.first = voyage.myShipBlockStack , "Voyage Loading should  be queued to the voyage block stack");

	//bbk should not be queued
	self.assertFalseMsg(bblkTI.isQueued, "Voyage Loading not RTL should not be queued");
	
	
		
	
	
	
epilog
		delete tis;
	delete selectedTypes;
	delete pxyVoyage;
	delete queueControl;
end;</source>
    </JadeMethod>
    <JadeMethod name="tReceiveReleaseStevedoreBulk" id="4efc1722-279d-402e-aade-9dbacf2944f8">
        <updating/>
        <source>tReceiveReleaseStevedoreBulk() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 Aug 2025	navlw1	JIRA:35648: Verify if stevedore is set correctly for onShip Bulk Cargo cargo(to cover MTN-35087)

*/
constants
Ship				= "UT35648Ship";
Voyage1				= "UT35648VOYAGE";
DischargeCargo		= "UT35648002";
LoadCargo			= "UT35648003";
BlockArea1			= "UT35648BA";
vars
	dischargeTi,
	loadTi				: CM_TrackedItem;
	bsl					: CM_BlockStack;
	vessel				: CM_Vessel;
	voyage				: CM_Voyage;
	stevedoreRec,
	stevedoreRel		: CM_Stevedore;
	cargoType			: CM_CargoType;
	lc					: CM_LocationsController;
	height				: Integer;
	sStevedorRecCode,
	sStevedorRelCode	: String;
begin
	// delete everything first
	self.deleteContainer(DischargeCargo);
	self.deleteContainer(LoadCargo);
	self.deleteTerminalArea(BlockArea1);
	self.deleteVoyage(Voyage1);
	self.deleteVessel(Ship);
	
	// create the vessel
	vessel := self.addVesselCellular(Ship, self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));
	self.assertNotNull(vessel);
	
	// create the voyage
	voyage := self.addVoyageWithContainerStructur(Voyage1, vessel.code, self.getProfileSetting(UT_Profile.P_OPERATOR).asString, self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString);
	self.assertNotNull(voyage);
	
	// Add the stevedore to the voyage
	stevedoreRec := app.myRoot.allStevedores.getAtKey('UTRECEIVE');
	self.assertNotNull(stevedoreRec);
	stevedoreRel := app.myRoot.allStevedores.getAtKey('UTRELEASE');
	self.assertNotNull(stevedoreRel);
	
	// add the stevedores to the voyage via HMS Data
	beginTransaction;
		voyage.myHMSVoyageData.allStevedoresDischarge.add( stevedoreRec );
		voyage.myHMSVoyageData.allStevedoresLoad.add( stevedoreRel );
	commitTransaction;
	
	// check stevedore recieved
	sStevedorRecCode :=  voyage.myHMSVoyageData.allStevedoresDischarge.getAtKey("UTRECEIVE").code;
	sStevedorRelCode :=  voyage.myHMSVoyageData.allStevedoresLoad.getAtKey("UTRELEASE").code;
	
	// set the location controller based on voyage
	self.getTerminal.findLocationFromString(voyage.code, true, lc, height); 
		
	// get the cargo type
	cargoType := app.myRoot.getCargoTypeFromAbbrevOrDescr("REBAR");
	self.assertNotNullMsg(cargoType, "cargoType " &amp; "REBAR" &amp; " not found");
	
	// create Bulk Cargo and put it on ship
	dischargeTi := self.addCargoBreakBulkAtLocation(DischargeCargo, cargoType, 50, lc, null, TI_IMEX_STATUS_IMPORT, voyage, vessel.myOperator);
	
	// check that the data is correct for the Bulk onShip Cargo
	self.assertNotNullMsg(sStevedorRecCode, "Stevedor Recieved Code UTRECEIVE not found");
	self.assertNotNullMsg(dischargeTi, "DischargedTi " &amp; DischargeCargo &amp; " not found");
	self.assertEqualMsg(dischargeTi.stevedoreCodeRecieve.toUpper, sStevedorRecCode, "Expected that the onship TI " &amp; dischargeTi.getStevedoreReceive.code &amp; "recieve stevedore matches the voyage receive stevedore" &amp; sStevedorRecCode);
	
	// create the bulk area
	bsl := self.addBlockStack(BlockArea1,20,null);
	self.assertNotNullMsg(bsl, "Block Stack not found");
	
	// set the location controller based on voyage
	self.getTerminal.findLocationFromString(bsl.id, true, lc, height);
	self.assertNotNullMsg(lc, "Location COntroller should not be null");
	
	// create Bulk Cargo onSite 
	loadTi := self.addCargoBreakBulkAtLocation(LoadCargo, cargoType, 50, lc, null, TI_IMEX_STATUS_EXPORT, voyage, vessel.myOperator);
	self.assertNotNullMsg(loadTi, "Should of created cargo on site");
	self.assertEqualMsg(loadTi.stevedoreCodeRecieve, null, "Expected the onSite TI recieve stevedore to be null");
	self.assertEqualMsg(loadTi.stevedoreCodeRelease, null, "Expected the onSite TI release stevedore to be null");
	
	// set the location controller based on voyage
	self.getTerminal.findLocationFromString(voyage.code, true, lc, height); 
	// move the cargo to ship
	self.instantMove(loadTi, lc);
	// check that the release stevedore is set
	self.assertEqualMsg(loadTi.stevedoreCodeRelease.toUpper, sStevedorRelCode, "Expected that the onship TI " &amp; loadTi.getStevedoreCodeRelease() &amp; " recieve stevedore matches the voyage receive stevedore " &amp; sStevedorRelCode);
	self.assertEqualMsg(loadTi.stevedoreCodeRecieve, null, "Expected the onShip TI recieve stevedore to be null");
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="tTFS49894" id="f6348b16-70f4-4953-9610-a4bccedd8e7e">
        <updating/>
        <source>tTFS49894()updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 August 2020	jlgndl1	Initial creation	TFS 49894

*/

constants

	LoadBox				= "UTDR4989401";
	BlockStack1			= "UT_RDBS1";
	YardIC				= "UT_RD_IC";
	Ship				= "UTRDSHIP";
	Voyage1				= "UTRDVOYAGE";
	CraneTransferAreaId	= "CTRD";
	CraneId				= "CRR1";

vars

	loadTi : CM_TrackedItem;
	bs : CM_BlockStack;
	yardIC : CM_InterchangeArea;
	wle : CM_WorkListEntry;
	vessel : CM_Vessel;
	voyage : CM_Voyage;
	slots : CM_SlotControllerArray;
	voyageJob : CM_VoyageJob;
	job : CM_Job;
	request : CM_Request;
	voyageQueue : CM_VoyageQueue;
	craneQueue : CM_VoyageCraneQueue;
	crane : CM_Machine;
	operator : CM_Operator;
	bayName : String;
//	loadPort : CM_Port;
	dischargePort : CM_Port;
	jobs : CM_JobArray;
	voyAlloc : CM_VoyageAllocation;
	wles : CM_WLEArray;
	straddle : CM_Machine;
	fork : CM_Machine;
	tas : StringArray;
	cta : CM_CraneTransferArea;
begin
	
	self.setTerminalConfig(AllowRTSwithoutVGM, true);				
	
	create jobs transient;
	create wles transient;

	// delete everything first
	self.deleteContainer(LoadBox);
	self.deleteTerminalArea(BlockStack1);
	self.deleteTerminalArea(YardIC);
	self.deleteVoyage(Voyage1);
	self.deleteVessel(Ship);
	self.deleteMachine(CraneId);
	self.deleteTerminalArea(CraneTransferAreaId);
	
	
	// create the terminal areas - gridded block stack, block stack and interchange
	self.opts.purge;
	self.opts.addAssoc("ActAsReleasePoint", 1);
	self.opts.addAssoc("HideOverview", true);
	yardIC := self.addInterchangeArea(YardIC, null);
	self.opts.purge;
	self.opts.addAssoc("ActAsReleasePoint", 1);
	self.opts.addAssoc("StockControlled", true);
	self.opts.addAssoc("DefaultYIC", yardIC);
	bs := self.addBlockStack(BlockStack1, 20, null);		
	
	
	// create the crane transfer area
	cta := self.addCraneTransferArea(CraneTransferAreaId);
	self.assertNotNull(cta);
	
	//create vessel and voyage
	vessel := addVesselCellular(Ship, self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));
	voyage := self.addVoyageWithContainerStructur(Voyage1, Ship, self.getProfileSetting(UT_Profile.P_OPERATOR).asString, self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString);
	self.assertNotNull(vessel);
	self.assertNotNull(voyage);
	
	// create the crane
	create tas transient;
	tas.add(cta.id);
	self.opts.purge();
	self.opts.addAssoc("CraneTransferArea", cta);
	self.opts.addAssoc("MachineLiftType", TWIN_LIFT);
	crane := self.addCrane(CraneId, null, tas, null);
	self.assertNotNull(crane);
	delete tas;

	dischargePort := voyage.myTrade.allPortRotations.first.myPort;

	//create load job	
	self.opts.purge;																				
	voyAlloc := self.addVoyageAllocation(voyage, dischargePort.code,"GEN2",null,1,false,false);
	bayName :='01';

	create slots transient;
	self.getJobSlotControllers(voyage.code, bayName, DeckOnDeck, 1, 2, 1, slots);
	assertEqual(slots.size, 1);

	self.addLCsToLOLOAllocation(true, voyAlloc, slots, null);
	
	voyageJob := self.addVoyageJob(voyage, CraneId, slots, false);
	assertTrueMsg(voyageJob &lt;&gt; null, "Voyage job not created");
	jobs.add(voyageJob);	
	loadTi := self.addContainerForExport(LoadBox, operator,
				"2200",	"GENL",	TI_IMEX_STATUS_EXPORT,	null, voyage.code, dischargePort.code, null).CM_Container;
	self.move(loadTi, bs.getLocationsController);
	self.setCargoReadyToShip(loadTi);
	self.deleteStops(loadTi);
	self.movePlannedRequestToJob(loadTi, slots[1], slots[1].getRequest(true));
	delete slots;
	
	//move load job to ops
	self.loadAllJobsToOps(voyage, true);				
	//Add machine rules for the move
	self.addMachineRule( bs, crane.CM_Crane.transferArea, RTMoveMethod_16); //straddle --&gt; i/c --&gt; FL moves
		
	voyageQueue := self.addVoyageQueue(voyage);
	craneQueue := self.addVoyageCraneQueue(voyage, voyageQueue, crane);
	
	// Create Queues
	foreach job in jobs do
		foreach request in job.allRequests do
			foreach wle in request.allWorkListEntries do
				wles.add(wle);
				self.queueWLE(wle);
			endforeach;
		endforeach;
	endforeach;
	
	// set up a straddle
	self.deleteMachine("UTS1");
	self.deleteRTDevice("91");
	create tas transient;
	tas.add(bs.id); 
	tas.add(yardIC.id); 
	self.addStraddle("UTS1", 91, tas, null);
	straddle := self.getMachine("UTS1");
	assertNotNull(straddle);
	if craneQueue &lt;&gt; null then
		beginTransaction;
		straddle.addToQueue(craneQueue, true, 0); //add straddle to crane queue
		commitTransaction;
	endif;
	delete tas;
	
	//setup an IMV
	self.deleteMachine("FL01");
	self.deleteRTDevice("85");
	create tas transient;
	tas.add(yardIC.id); 
	tas.add(crane.CM_Crane.transferArea.id); 
	fork := self.addForkLift("FL01", 85, tas, null);
	assertNotNull(fork);
	delete tas;
	
	//loon machines
	app.isRTApp:=true;  
	self.machineLogon(straddle);
	self.machineLogon(fork);

	// do the first part of the move
	foreach wle in wles do
		self.machineAcceptTask(straddle, wle.allRTQueueEntries.first.allTasks.first);
		self.machinePickup(straddle);
		self.machineSetdownTask(straddle, wle.allRTQueueEntries.first.allTasks.last, yardIC.id);
	endforeach;	
	
	//Now we have a two legged move with one leg complete, next the customer changed the machine to be NON RT which clears the primary queue.
	//Then tried to move the task using 'Move it' and got an exception
	
	self.opts.purge();
	self.opts.addAssoc("hasRadioTelemetry", false);
	self.updateMachine(straddle);
	
	self.moveIT( loadTi, REAL_MODE );
	
	//clean up
	self.deleteContainer(LoadBox);
	self.deleteTerminalArea(BlockStack1);
	self.deleteTerminalArea(YardIC);
	self.deleteVoyage(Voyage1);
	self.deleteVessel(Ship);
	self.deleteMachine(CraneId);
	self.deleteTerminalArea(CraneTransferAreaId); 
	
epilog
	if straddle &lt;&gt; null then
		self.opts.purge();
		self.opts.addAssoc("hasRadioTelemetry", true);
		self.updateMachine(straddle);
	endif;
	
	app.isRTApp:=false;  
	delete jobs;
	delete slots;
	delete wles;
	delete tas;						// 13/09/2012 cnwmc5
end;</source>
    </JadeMethod>
    <JadeMethod name="tTFS52440" id="a0eb7ad8-836c-497a-88a4-0cd854f542f5">
        <source>tTFS52440();
/*
Purpose:	Release transfer area with auto release set, should raise stops when cargo is moved to it.		

Date		Who		Reason
24 November 2021	navab1	TFS 52424
08 Jan 2024	jlirs1	TFS 60575 - Jade 2022 upgrade fixing unitTests
*/
constants
	
	VesselCode 		: String = 'SCONRO';
	Voyagecode 		: String = 'TFS52424';
	
	BBULKCargoType 	: String = "UT_WIDGET";  // Pre existing Break Bulk cargo type NO duplicates
	
	BBIdHR 			: String = "BBLK20006001";
	STOPID = 916;
	AUTORELID = "TFS52424AR";
	DRWorkPoint 	: String = "DRWP";
	
	// Machines
	IMV1 	= "IMVS";
	FLS	= "FLST";
	
	YANAME = "SPLITYA";
	
vars
	result: Boolean;

	operator 		: CM_Operator;
	shipLineStr 	: String;
	voyage 			: CM_Voyage;
	
	bbHR 			: CM_BreakBulkGeneric;
	newBBTI : CM_TrackedItem;
	
	
	bbCargoType 	: CM_CargoType;

	importHold 		: CM_LocationsController;
	exportHold 		: CM_LocationsController;
	bsLC			: CM_LocationsController;
	bs : CM_BlockStack;
	
	
	
	dischJob1		: CM_VoyageHoldJob;
	allocatedWLEs 	: CM_WLEArray;
	tmpVWle			: CM_VoyageWLE;
	workPoint 		: CM_WorkPoint;
	
	machine, imv 	: CM_Machine;
	queue			: CM_VoyageQueue;
	wpQueue			: CM_RadioTelemetryQueue;
	tas				: StringArray;
	
	loadWleSet		: CM_WLESet;
	cargos : CM_CargoTypeSet;
	wpaType, bsaType : CM_TerminalAreaType;
	locations : CM_LCArray;
	ya : CM_YardAllocation;
	rtq : CM_RadioTelemetryQueue;
	rtqtask : CM_RTQueueTask;
	isChildIgnore		: Boolean;
	isChildOnly			: Boolean;
	isCoastalIgnore		: Boolean;
	isCoastalOnly		: Boolean;
	isFull				: Boolean;
	isMT				: Boolean;
	tempIntegerArray	: IntegerArray;
	preventIntegerArray	: IntegerArray;
	processIntegerArray	: IntegerArray;
	selectedTypes		: CM_CargoBOLTypeSet;
	stopsTable			: CM_StopsTable;

begin

	// ### CLEANUP OLD DATA
	self.deleteVoyage(Voyagecode);
	self.deleteCargo( BBIdHR, bbCargoType );
	self.deleteTerminalArea(AUTORELID);
	self.deleteStopsTable(STOPID);			// first delete if it exists.
	
	// ## BASE DATA SETUP
	operator := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);
	shipLineStr := self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString;
	bs:= self.addReleaseTransAreaAuto(AUTORELID).CM_BlockStack;
	bsLC := bs.allLocationsControllers.first;
	bbCargoType := app.myRoot.getCargoTypeFromAbbrevOrDescr(BBULKCargoType);
	self.assertTrueMsg(bbCargoType &lt;&gt; null, "Cargo Type '" &amp; BBULKCargoType &amp; "' not found during setup.");
	self.assertTrueMsg(not bbCargoType.allowDuplicates, "Cargo Type '" &amp; BBULKCargoType &amp; "' is splittable.");  // ### TFS 51988 07OCT2021 NAVAB1

	// SETUP STOP
	create tempIntegerArray transient;
	create preventIntegerArray transient;
	create selectedTypes transient;
	create processIntegerArray transient;
	
	isChildIgnore := false;
	isChildOnly := false;
	isCoastalIgnore := false;
	isCoastalOnly := false;
	isFull := true;
	isMT := true;
	self.opts.purge();
	self.opts.addAssoc(ETRow_IsChildIgnore, isChildIgnore);
	self.opts.addAssoc(ETRow_IsChildOnly, isChildOnly);
	self.opts.addAssoc(ETRow_IsCoastalIgnore, isCoastalIgnore);
	self.opts.addAssoc(ETRow_IsCoastalOnly, isCoastalOnly);
	self.opts.addAssoc(ETRow_IsFull, isFull);
	self.opts.addAssoc(ETRow_IsMT, isMT);
	self.opts.addAssoc(ETRow_RequiresInfo, false);
	self.opts.addAssoc(ETRow_CustomsInfoEntry, null);
	self.opts.addAssoc(ETRow_IsNotAvailableForEntry, false);
	self.opts.addAssoc(ETRow_AllowClearanceExpiryDate, false);
	
	// STOP PROCESS ACTIONS
	self.opts.addAssoc(ETRow_ProcessStopAreas, processIntegerArray);
	// STOP AUTO APPLIES ACTIONS
	tempIntegerArray.add(TI_IMEX_STATUS_IMPORT);
	self.opts.addAssoc(ETRow_SetStopAreas, tempIntegerArray);
	// STOP PREVENT ACTIONS
	preventIntegerArray.add(StopPreventGateOut);
	preventIntegerArray.add(StopPreventImport);
	self.opts.addAssoc(ETRow_CheckStopAreas, preventIntegerArray);
	
	// CARGOTYPES
	selectedTypes.add(bbCargoType);
	
	stopsTable := self.addStopsTable(STOPID,
										"UTAR",
										method.name[1 : 30],		// to help identify what has created it
										selectedTypes,
										self.opts);
	
	self.assertNotNullMsg(stopsTable, 'Stop Table ' &amp; STOPID.display &amp; ' does not exist');
	
	// ### ADD VOYAGE AND HOLDS
	voyage := self.addVoyageWithConRORO(Voyagecode, VesselCode, operator.code, shipLineStr, null, 0, false, true);
	self.assertTrueMsg(voyage &lt;&gt; null, "'Voyage' not created during setup");
	
	importHold := voyage.myGeneralCargoVoyage.allLocationsByHatchPlace.first;
	exportHold := voyage.myGeneralCargoVoyage.allLocationsByHatchPlace.last;
	assertNotNullMsg(importHold, "Voyage doesn't have any holds");
	assertNotEqualMsg(exportHold, importHold, "Voyage doesn't have enough holds");
	
	// ### CREATE CARGO ON SHIP
	bbHR := self.addCargoBreakBulkAtLocation(BBIdHR, bbCargoType, 1000, importHold, null, TI_IMEX_STATUS_IMPORT, voyage, operator).CM_BreakBulkGeneric;
	self.assertTrueMsg(bbHR &lt;&gt; null, "'" &amp; BBIdHR &amp; "' on ship cargo not created during setup");
	self.opts.addAssoc("TotalWeight", 80);
	self.updateTI( bbHR );
	
	// ADD STOP TO CARGO
	self.addStop(bbHR, stopsTable);
	
	// MOVE CARGO TO AUTO RELEASE, SHOULD GET ERROR.
	self.opts.purge();
	self.opts.addAssoc("ExpectErrors",true);
	self.move(bbHR, bsLC);
	self.assertTrueMsg( app.myPassport.allErrors.includesErrorCode( WARN_TI_HAS_STOP ), "Should have errored during move of cargo with import stop");

epilog
	delete tempIntegerArray;
	delete selectedTypes;
	delete processIntegerArray;
	delete preventIntegerArray;
end;</source>
    </JadeMethod>
    <JadeMethod name="tTFS52539" id="6f21cd5d-5ac1-48b4-b70a-b987fd42dde3">
        <source>tTFS52539();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 Dec 2021	navma1	Bug 52539: SAL - Hold Planning Split Work - Delete Job

*/
constants
	REF = UT_DSL.TFS52539;
	Cargo_Type			: String = "UTREBAR";
vars
	bs1 		  : CM_BlockStack;
	operator	  : CM_Operator;
	cargoType	  : CM_CargoType;
	voyage 		  : CM_Voyage;
	workPoint     : CM_WorkPoint;
	hold0101 	  : CM_GeneralCargoController;
	hold0101Str   : String;
	vessel        : CM_Vessel;
	job01,job02	  : CM_VoyageHoldJob;
	allocatedWLEs : CM_WLEArray;
	voyageWle1,
	voyageWle2,
	voyageWle3,
	voyageWle4	  : CM_VoyageWLE;
	ti1,
	ti2,
	ti3,
	ti4			  : CM_TrackedItem;
	jobSheet      : CM_VoyageHoldJobSheet;
	jobs,
	jobsWithWarning  : CM_VoyageJobArray;
	requests		 : CM_RequestSet;
	selectedWls		 : CM_WLESet;
	str				 : String;
	lc: CM_LocationsController;
begin
	operator := app.myRoot.allOperators['APL'];	
	
	bs1 := self.addBlockStack(REF,999,null);
	
	//deleteCargoType('UT'&amp;REF);
	cargoType := app.myRoot.getCargoTypeFromAbbrev(Cargo_Type);
	self.assertTrueMsg( cargoType &lt;&gt; null, 'UTCT'&amp;REF &amp; " not created in setup." );	
	
	deleteCargo(REF&amp;"01",cargoType);
	deleteCargo(REF&amp;"02",cargoType);
	deleteCargo(REF&amp;"03",cargoType);
	deleteCargo(REF&amp;"04",cargoType);
	
	
	vessel := self.addVesselWithHolds(	REF, 2, 2);
	
	self.deleteVoyage(REF);
	voyage := self.addVoyageWithGeneralCargoStruc(REF, vessel.name, vessel.myOperator.code, "APL", 0);
	
	workPoint := self.addWorkPoint(REF, false);
	self.assertTrueMsg(workPoint &lt;&gt; null, "Work Point not created");
	
	hold0101 	:= voyage.myGeneralCargoVoyage.allLocationsByHatchPlace[1,1];
	hold0101Str := hold0101.getFullId;
	
	
	ti1 := self.addCargoBreakBulkAtLocation(REF&amp;"01", cargoType, 50, hold0101, null, TI_IMEX_STATUS_IMPORT, voyage, vessel.myOperator);
	ti2 := self.addCargoBreakBulkAtLocation(REF&amp;"02", cargoType, 50, hold0101, null, TI_IMEX_STATUS_IMPORT, voyage, vessel.myOperator);
	ti3 := self.addCargoBreakBulkAtLocation(REF&amp;"03", cargoType, 50, hold0101, null, TI_IMEX_STATUS_IMPORT, voyage, vessel.myOperator);
	ti4 := self.addCargoBreakBulkAtLocation(REF&amp;"04", cargoType, 50, hold0101, null, TI_IMEX_STATUS_IMPORT, voyage, vessel.myOperator);
	create allocatedWLEs transient;
	
	create voyageWle1 transient;
	voyageWle1.setMyTrackedItem(ti1);
	allocatedWLEs.add(voyageWle1);
	
	create voyageWle2 transient;
	voyageWle2.setMyTrackedItem(ti2);
	allocatedWLEs.add(voyageWle2);
	
	create voyageWle3 transient;
	voyageWle3.setMyTrackedItem(ti3);
	allocatedWLEs.add(voyageWle3);
	
	create voyageWle4 transient;
	voyageWle4.setMyTrackedItem(ti4);
	allocatedWLEs.add(voyageWle4);
	
	job01 := self.addVoyageHoldJob(JOB_TYPE_DISCHARGE, voyage, allocatedWLEs, hold0101, workPoint);
	jobSheet := voyage.allJobSheets.first.CM_VoyageHoldJobSheet;
	
	self.assertEqualMsg(jobSheet.allJobsByJobNum.size, 1, "Voyage Job sheet has the wrong number of jobs");
	
	moveBreakBulk(ti1, bs1, 50);
	self.assertEqual(ti1.myPrimaryActualLocation,bs1.getLocationsController);
	moveBreakBulk(ti2, bs1, 50);
	self.assertEqual(ti2.myPrimaryActualLocation,bs1.getLocationsController);
	
	create jobs transient;
	create jobsWithWarning transient;
	create requests transient;
	create selectedWls transient;
	
	jobs.add(job01);
	selectedWls.add(voyageWle3);
	
	selectedWls.add(voyageWle4);

	str := app.myTrxUA.trxTransferVoyageJobsToCrane(false, jobs, jobsWithWarning, voyage.allJobSheets.first, REAL_MODE, requests, selectedWls, job01.id&amp;'A', false, null, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();

	self.assertEqual(voyage.allJobSheets.first.allJobsByJobNum.size, 2);
	
epilog
	delete allocatedWLEs;
	delete voyageWle1;
	delete voyageWle2;
	delete voyageWle3;
	delete voyageWle4;
	delete jobs;
	delete jobsWithWarning;
	delete requests;
	delete selectedWls;
end;</source>
    </JadeMethod>
    <JadeMethod name="tTfs49464" id="1c95c084-1ca3-47f6-9a70-0235da3ac027">
        <source>tTfs49464();
/*

Purpose:			

Parameters:			Follows the process AAT say they are using for DLRs.

Return Value:		

Date		Who		Reason
26 May 2020	jlgndl1	Initial creation	TFS 49464

*/

constants

	BLOCKSTACK			: String = "DLRBS";
	YARDALLOCATION 	 	: String = "YADLR";
	CRANENAME			: String = "CRN9"; 
	CraneTermArea : String = "CRNTA9"; 
	VOYAGENAME			: String = "UT49464";
	VESSELNAME			: String = "UT49464";
	ContainerBaseId		: String = "DLRZ00099";
	
vars

	operator : CM_Operator;
	dischargePort : CM_Port;
	index : Integer;
	cargoId : String;
	cargoArray : ObjectArray;
	strs : StringArray;
	blockStack : CM_BlockStack;
	cta : CM_CraneTransferArea;
	tas : StringArray;
	crane : CM_Crane;
	locations : CM_LCArray;
	vessel : CM_Vessel;
	voyage : CM_Voyage;
	theSlot : CM_LocationsController;
	idx : Integer;
	cargo : CM_TrackedItem;
	slotsFrom : CM_SlotControllerArray;
	slotsTo : CM_SlotControllerArray;
	tmpLoadCC : CMIF_LoadColorCode;
	voyageDischJob : CM_VoyageJob;
	voyageLoadJob : CM_VoyageJob;
	allObjectEditions : CM_ObjectByOidEditionDict;
	slot : CM_SlotController;
	obj : Object;
	wle : CM_WorkListEntry;
	moveCont : CMIF_MoveController;
	voyages : ObjectSet;
	wleArray : CM_WLEArray;	
	wlesWithWarnings : CM_WLEArray;
	effectiveTimeStamp : TimeStamp;

begin

	operator := app.myRoot.allOperators["UTOP"];
	dischargePort := app.myRoot.allPorts["NZPOE"];
	
	//clean up
	foreach index in 1 to 4 do
		cargoId := ContainerBaseId &amp; index.String.padLeadingZeros(2);
		self.deleteContainer(cargoId);
	endforeach;
	
	self.deleteTerminalArea(BLOCKSTACK);
	self.deleteMachine(CRANENAME);
	self.deleteTerminalArea(CraneTermArea);
	self.deleteYA(YARDALLOCATION);
	deleteVoyage(VOYAGENAME);
	deleteVessel(VESSELNAME);
	
	//setup
	create cargoArray transient;
	create strs transient;
	
	blockStack := addBlockStack(BLOCKSTACK, 100, null);
	self.opts.purge();
	self.opts.addAssoc("SetCraneLaneCages", true);
	cta := self.addCraneTransferArea(CraneTermArea);
	self.assertNotNull(cta);
	
	create tas transient;
	tas.add(cta.id);
	self.opts.purge();
	self.opts.addAssoc("CraneTransferArea", cta);
	self.opts.addAssoc("MachineLiftType", TWIN_LIFT);
	crane := self.addCrane(CRANENAME, null, tas, null).CM_Crane;
	self.assertNotNull(crane);
	
	vessel := addVesselCellular(VESSELNAME, operator);
	voyage := addVoyageWithContainerStructur(VOYAGENAME, VESSELNAME, operator.code, self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString);
	
	create locations transient;
	locations.add(blockStack.allLocationsControllers.first.CM_YardController);
	create voyages transient;
	voyages.add( voyage );
	self.addYA1(YARDALLOCATION, YACriteriaType_Voyage, voyages, locations);
	
	index := 4;
	while index &gt; 0 do
		cargoId := ContainerBaseId &amp; index.String.padLeadingZeros(2);
		strs.clear();
		if index = 4 then
			strs.add("010682");
			voyage.findLocation(strs, false, theSlot, idx);
		elseif index = 3 then
			strs.add("010684");
			voyage.findLocation(strs, false, theSlot, idx);
		elseif index = 2 then
			strs.add("010686");
			voyage.findLocation(strs, false, theSlot, idx);
		elseif index = 1 then
			strs.add("010688");
			voyage.findLocation(strs, false, theSlot, idx);
		endif;
		cargo := self.addContainerAtLocnDisch(cargoId, "2200", "GENL", TI_IMEX_STATUS_IMPORT, theSlot, dischargePort, voyage);
		cargoArray.add(cargo);
		index := index - 1;
	endwhile;
		
	app.myTrxUA.trxSetDfltDischargeColourCode(voyage.myCellularVoyageStructure, app.myPassport);
		
	// colour code the discharge slots
	create slotsFrom transient;
	self.getJobSlotControllers(VOYAGENAME, "01", DeckOnDeck, 1, 1, 4, slotsFrom);
	self.markSlotsAsDischargeCC(slotsFrom, tmpLoadCC, CM_SlotRequest.Attribute_D20);
	self.markSlotsAsDischargeCC(slotsFrom, tmpLoadCC, CM_SlotRequest.Attribute_DLR);
	voyageDischJob := self.addVoyageJob(voyage, crane.id, slotsFrom, true);
	assertTrue(voyageDischJob &lt;&gt; null);
	
	// colour code the load slots
	create slotsTo transient;
	self.getJobSlotControllers(VOYAGENAME, "01", DeckOnDeck, 3, 1, 4, slotsTo);
	self.markSlotsAsLoadJob(slotsTo, tmpLoadCC);
	self.markSlotsAsLoadCC(slotsTo, tmpLoadCC, CM_SlotRequest.Attribute_D20);
	self.markSlotsAsLoadCC(slotsTo, tmpLoadCC, CM_SlotRequest.Attribute_DLR);
	voyageLoadJob := self.addVoyageJob(voyage, crane.id, slotsTo, false);
	assertTrue(voyageLoadJob &lt;&gt; null);
	
	// link the slots
	create allObjectEditions transient;
	foreach slot in slotsFrom do
		allObjectEditions.add(slot);
	endforeach;
	foreach slot in slotsTo do
		allObjectEditions.add(slot);
	endforeach;
	app.myTrxUA.trxUpdateSlotReqLinkSOBDLR2(slotsFrom, slotsTo, allObjectEditions, true, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
	// Plan the DLR Load to ship (same as Load List Non Planned DLR drag Drop to LOLO form)
	foreach index in 1 to 4 do
		cargo := cargoArray[index].CM_TrackedItem;
		slot := slotsTo[index];
		create moveCont transient;
		moveCont.setMyTrackedItem( cargo );
		moveCont.setMyToPrimaryLocation(slot);
		moveCont.mySlotRequest := slot.mySlotRequestLoad;
		moveCont.isDLRLoadWithOutDischarge := true;
		moveCont.setMoveMode( PLANNING_MODE );
		moveCont.moveTrackedItemTarget( self.getTerminal, slot, 0, 0 );
		delete moveCont;
	endforeach;
	
	// load to job ops
	self.loadAllJobsToOps(voyage, true);	
	
	// instant move items to BS (same as drag drop from Job Operations)
	foreach obj in cargoArray do
		cargo := obj.CM_TrackedItem;
		slot := cargo.myPrimaryActualLocation.CM_SlotController;
		create moveCont transient;
		moveCont.setMyTrackedItem( cargo );
		moveCont.setMyOriginatingLocation( slot );
		moveCont.mySlotRequest := slot.mySlotRequestDischarge;
		moveCont.setMyWorkListEntry( cargo.allWorklistEntries.first );
		moveCont.setMoveMode( REAL_MODE );
		moveCont.moveTrackedItemTarget( self.getTerminal, blockStack.myLocationsController, 0, 0 );
		delete moveCont;
	endforeach;
	
	//Check the wles are NOT Direct Releases
	foreach wle in voyageLoadJob.workListEntries do
		self.assertTrueMsg( not wle.isDRLinkedByFM, "DLR Load Wle should not be a Direct Release" );
	endforeach;
	
	// instant move to ship (equivalent to 'Move It' in Job Operations Form)
	create wleArray transient;	
	create wlesWithWarnings transient;	
	foreach wle in voyageLoadJob.workListEntries do
		wleArray.clear();
		wlesWithWarnings.clear();
		wleArray.add( wle );
		app.myTrxUA.trxUpdateWLEsDoMove( wleArray, wlesWithWarnings, REAL_MODE, true, effectiveTimeStamp, app.myPassport);
	endforeach;
	
	// check to see discharge status is completed
	foreach wle in voyageDischJob.workListEntries do
		self.assertTrueMsg( wle.status = WLE_COMPLETED, "DLR Discharge Wle not completed");
	endforeach;
	
	// check to see load status is completed
	foreach wle in voyageLoadJob.workListEntries do
		self.assertTrueMsg( wle.status = WLE_COMPLETED, "DLR Load Wle not completed");
	endforeach;

	foreach obj in cargoArray do
		cargo := obj.CM_TrackedItem;
		self.assertTrueMsg(cargo.myPrimaryActualLocation.isKindOf(CM_SlotController), cargo.id &amp; " not back on ship");
	endforeach;
	
epilog

	delete tmpLoadCC;
	delete slotsTo;
	delete slotsFrom;
	delete locations;
	delete strs;
	delete tas;
	delete allObjectEditions;
	delete cargoArray;
	delete moveCont;
	delete voyages;
	delete wleArray;	
	delete wlesWithWarnings;	
	
end;</source>
    </JadeMethod>
    <JadeMethod name="tTranshipVoyage" id="a2989fa4-9dd0-40bf-a11e-431d6ae657eb">
        <updating/>
        <source>tTranshipVoyage()updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 April 2020	jlgndl1	Initial creation	TFS 49087

*/

constants

	USER_DEF_NAME = 'CUSRES';
	BookingRefIdIn = "TFS49087IN";
	ContainerId = "CAIU9650230";
	VoyageInName = 'TSIN';
	VoyageOutName = 'TSOUT';
	VesselInName = 'TS_IN';
	VesselOutName = 'TS_OUT';
	TestOperator = 'UTOP';
	BlockStack1 = "UTBSTS";

vars

	passport : CM_Passport;
	term : CM_Terminal;
	voyageIn : CM_Voyage;
	voyageOut : CM_Voyage;
	container : CM_Container;
	bs : CM_BlockStack;
	controller : CMIF_TranshipTIController;
	ediText : String;
	ediFile : CM_EDIFile;
	tempStr : String;
	bookingOut : CM_BookingRef;
	tiSet : CM_TISet;
	tiRTS : CM_TIArray;
	ediLLTI : CM_EDILoadListTI;
	pxyTI : CM_TrackedItem;
	vesselIn : CM_Vessel;
	vesselOut : CM_Vessel;
	operator : CM_Operator;
	shippingLine : String;
	
begin

	passport := app.myPassport;
	term := self.getTerminal();
	operator := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);
	shippingLine := self.getProfileSetting( UT_Profile.P_SHIPPING_LINE ).asString;

		//Clean-up
	self.deleteContainer(ContainerId);
	
	self.deleteTerminalArea(BlockStack1);
	
	self.deleteVoyage(VoyageInName);
	self.deleteVoyage(VoyageOutName);
	self.deleteVessel(VesselInName);
	self.deleteVessel(VesselOutName);
	
	
		//Create vessels, voyages and one container on inward voyage.
	vesselIn := self.addVesselCellular(VesselInName, self.getOperator(TestOperator));
	self.assertNotNullMsg(vesselIn, 'Add import vessel failed');
	
	vesselOut := self.addVesselCellular(VesselOutName, self.getOperator(TestOperator));
	self.assertNotNullMsg(vesselOut, 'Add export vessel failed');
	
	voyageIn := self.addVoyageWithContainerStructur(VoyageInName, VesselInName, operator.code, shippingLine );
	voyageOut := self.addVoyageWithContainerStructur(VoyageOutName, VesselOutName, operator.code, shippingLine );
	
	bs := self.addBlockStack(BlockStack1, 20, null);
	
	container := self.addContainerForExport(ContainerId,
											voyageIn.myOperator,
											"2200",					// ISOType is not needed
											null,					// commodity is not needed
											TI_IMEX_STATUS_IMPORT,	// import not export
											null,					// booking id
											voyageIn.code,
											null,					// dischargePort
											null).CM_Container;			// transhipToPort
											
	self.move(container, voyageIn.myShipBlockStack);
	
		// Make the container a tranship
	create controller transient;
	controller.allTrackedItems.add(container);
	controller.myExportDisPort := app.myRoot.allPorts['GBABA'];
	controller.myExportVoyage := voyageOut;
	controller.remarks := "UT Tranship";
	self.makeTrackedItemTranship(controller);
	
		//Process a COPRAR to create edi objects for the 'Cargo Comparision' i.e. a Discharge List
	ediText	:=
"UNB+UNOA:2+"&amp;voyageIn.myOperator.code&amp;"+ITSALSCT+200325:0810+3625'"&amp;CrLf&amp;
"UNH+CFIITSAL01958+COPRAR:D:95B:UN:SMDG10'"&amp;CrLf&amp;
"BGM+43:::DISCHARGE ORDER+CFIITSAL01958+9'"&amp;CrLf&amp;
"RFF+XXX:1'"&amp;CrLf&amp;
"TDT+20+"&amp;voyageIn.code&amp;"+1++"&amp;voyageIn.myOperator.code&amp;":172:166+++VRLU9:103::"&amp;voyageIn.myVessel.name&amp;"'"&amp;CrLf&amp;
"RFF+VON:245278'"&amp;CrLf&amp;
"LOC+11+ITSAL:139:6++:BER:ZZZ:SALERNO CONTAINER TERMINAL SPA'"&amp;CrLf&amp;
"DTM+132:202003280200:203'"&amp;CrLf&amp;
"DTM+133:202003290602:203'"&amp;CrLf&amp;
"NAD+CF+HLC:160:166'"&amp;CrLf&amp;
"EQD+CN+"&amp;container.id&amp;"+"&amp;container.isoType&amp;":102:5++6+5'"&amp;CrLf&amp;
"RFF+BN:"&amp;BookingRefIdIn&amp;"'"&amp;CrLf&amp;
"TMD+3'"&amp;CrLf&amp;
"LOC+9+CAMTR:139:6'"&amp;CrLf&amp;
"LOC+11+ITSAL:139:6+:BER:ZZZ:SALERNO CONTAINER TERMINAL SPA'"&amp;CrLf&amp;
"LOC+7+GRPIR:139:6'"&amp;CrLf&amp;
"LOC+147+0180010::ZZZ'"&amp;CrLf&amp;
"MEA+AAE+T+KGM:2000'"&amp;CrLf&amp;
"MEA+AAE+G+KGM:2000'"&amp;CrLf&amp;
"MEA+AAE+VGM+KGM:4000'"&amp;CrLf&amp;
"SEL+375567+AB'"&amp;CrLf&amp;
"FTX+AAA+++"&amp;container.commodity&amp;"'"&amp;CrLf&amp;
"TDT+30+"&amp;voyageOut.code&amp;"+1+13+"&amp;voyageOut.myOperator.code&amp;":172:20+++V7KX5:103::"&amp;voyageOut.myVessel.name&amp;":MH'"&amp;CrLf&amp;
"RFF+VON:247385'"&amp;CrLf&amp;
"LOC+PDS+GRPIR:139:6'"&amp;CrLf&amp;
"LOC+7+GRPIR:139:6'"&amp;CrLf&amp;
"DTM+133:202003310200:203'"&amp;CrLf&amp;
"DTM+132:202004020300:203'"&amp;CrLf&amp;
"NAD+CF+HLC:160:166'"&amp;CrLf&amp;
"CNT+16:335'"&amp;CrLf&amp;
"UNT+5756+CFIITSAL01958'"&amp;CrLf&amp;
"UNZ+1+3625'";

	ediFile	:= self.ediLoadFileName(ediText, EDIFileType_Unknown, "COPRAR", "COPRAR1"&amp;method.name);
	self.assertNotNull(ediFile);

	self.ediVerify(ediFile);
	tempStr	:= 'Verify Failed'&amp;CrLf&amp;passport.getAllErrorsWarningsAsString;
	self.assertIsOneOf(ediFile.fileStatus, tempStr, CM_EDIFile.EDI_STATUS_VERIFIED, CM_EDIFile.EDI_STATUS_VERIFIED_WARNINGS );

		//Do the load list comparision update to the booking field here
	pxyTI := app.createUpdateProxy( container ).CM_TrackedItem;
	create tiSet transient;
	tiSet.add(pxyTI);
	ediLLTI := ediFile.ediData.allEDITrackedItems.first.CM_EDILoadListTI;
	pxyTI.setPxyFromNamedFields(ediLLTI.bookingRef, CM_TrackedItem::bookingReference.name);
	app.myTrxUA.trxUpdateTrackedItemsBatch(tiSet, TI_UPDMODE_NORMAL, null, passport);
	delete pxyTI;
	
	//Check that the 'Booking' value has been set properly
	self.assertTrueMsg( container.bookingReference = BookingRefIdIn, " container.bookingReference was not update in comparision update");

		//Now mark the container RTS
	create tiRTS transient;
	tiRTS.add(container);
	app.myTrxUA.trxUpdateTIsReadyToShip(tiRTS, true, passport); 
		
	//Now discharge the container to the Yard
	self.move(container, bs);
	
	//Being a tranship, then moving ashore will have updated the current "voyage" from the 'import voyage' to the 'export voyage'. Similarly the 
	//'import booking' should now be set from what was the current "booking" and teh currenmt "booking' should now equal the export one which for 
	// us means it shoudl be cleared.
	
	self.assertTrueMsg( container.bookingReference = null, " container.bookingReference was not updated/cleared in move ashore");
	self.assertTrueMsg( container.myTranshipDetail.importBookingReference = BookingRefIdIn, " container.myTranshipDetail.importBookingReference was set in move ashore");

		//All done, clean up again
		//Clean-up
	self.deleteContainer(ContainerId);
	
	self.deleteTerminalArea(BlockStack1);
	
	self.deleteVoyage(VoyageInName);
	self.deleteVoyage(VoyageOutName);
	self.deleteVessel(VesselInName);
	self.deleteVessel(VesselOutName);
	
epilog

	delete controller;
	delete tiRTS;
	delete tiSet;
	delete pxyTI;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="tVoyAllocLoadLOLO" id="3bf4ade7-bfc5-4b99-9ee0-ce2f83765afd">
        <updating/>
        <source>tVoyAllocLoadLOLO() updating;
// cnwma1

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
30 January 2013	cnwrd1	Initial creation
08 Jan 2024	jlirs1	TFS 60575 - Jade 2022 upgrade fixing unitTests
*/


constants
	DischargeBox		= "UTDR0000002";
	LoadBox1			= "UTDR0000003";
	LoadBox2			= "UTDR0000004";
	LoadBox3			= "UTDR0000005";
	LoadBox4			= "UTDR0000006";
	LoadBox5			= "UTDR0000007";
	BlockStack1			= "UT_RDBS1";
	YardIC				= "UT_RD_IC";
	Ship				= "UTRDSHIP";
	Voyage1				= "UTRDVOYAGE";
	CraneTransferAreaId	= "CTRD";
	CraneId				= "CRR1";
	YardAlloc			= 'RDALLOC';
vars
	dischargeTi,
	loadTi1,
	loadTi2,
	loadTi3,
	loadTi4,
	loadTi5,
	ti4				: CM_TrackedItem;
	bs				: CM_BlockStack;
	yardIC			: CM_InterchangeArea;
	wle				: CM_WorkListEntry;
	vessel			: CM_Vessel;
	voyage			: CM_Voyage;
	slots 			: CM_SlotControllerArray;
	voyageJob		: CM_VoyageJob;
	job				: CM_Job;
	request			: CM_Request;
	voyageQueue		: CM_VoyageQueue;
	craneQueue		: CM_VoyageCraneQueue;
	crane			: CM_Machine;
	operator		: CM_Operator;
	bayName			: String;
	loadPort,
	dischargePort	: CM_Port;
	jobs			: CM_JobArray;
	voyAlloc		: CM_VoyageAllocation;
	wles 			: CM_WLEArray;
	straddle		: CM_Machine;
	tas				: StringArray;
	cta				: CM_CraneTransferArea;
//	agent			: CM_MobileAgent;
	agent : CMIF_MobileGenericAgent;
	looper			: Integer;
	theLoadTis		: CM_TIArray;
	yaName			: String;
	ya				: CM_YardAllocation;
	locations 		: CM_LCArray;
begin
	
	create jobs transient;
	create wles transient;
	create theLoadTis transient;

	// delete everything first
	self.deleteContainer(DischargeBox);
	self.deleteContainer(LoadBox1);
	self.deleteContainer(LoadBox2);
	self.deleteContainer(LoadBox3);
	self.deleteContainer(LoadBox4);
	self.deleteContainer(LoadBox5);
	self.deleteTerminalArea(BlockStack1);
	self.deleteTerminalArea(YardIC);
	self.deleteVoyage(Voyage1);
	self.deleteVessel(Ship);
	self.deleteMachine(CraneId);
	self.deleteTerminalArea(CraneTransferAreaId);
	
	self.disableAllYA(true);
	
	
	
	// create the terminal areas - gridded block stack, block stack and interchange
	self.opts.purge;
	self.opts.addAssoc("ActAsReleasePoint", 1);
	self.opts.addAssoc("HideOverview", true);
	yardIC := self.addInterchangeArea(YardIC, null);
	self.opts.purge;
	self.opts.addAssoc("ActAsReleasePoint", 1);
	self.opts.addAssoc("StockControlled", true);
	self.opts.addAssoc("DefaultYIC", yardIC);
	bs := self.addBlockStack(BlockStack1, 20, null);		
	
	operator := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);
	
	create locations transient;
	
	locations.add(bs.allLocationsControllers.first);
	yaName := YardAlloc;
	self.deleteYA(YardAlloc);
	//ya := self.addYA1WithFill(YardAlloc, YACriteriaType_IsTwenty, CM_YADataBoolean.VALUE_TRUE, locations, YAFillOption_FIFO, YAFillOption_FIFO);
	ya := self.addYA1WithFill(YardAlloc, YACriteriaType_OperatorItem, operator.code, locations, YAFillOption_InOrder, YAFillOption_FIFO,false);
	
	// create the crane transfer area
	cta := self.addCraneTransferArea(CraneTransferAreaId);
	self.assertNotNull(cta);
	
	//create vessel and voyage
	vessel := addVesselCellular(Ship,operator);
	self.opts.purge;
	self.opts.addAssoc("UseAllocations", true);
	self.opts.addAssoc("CopyVoyageVAConfig", false);
	
	voyage := self.addVoyageWithContainerStructur(Voyage1, Ship, operator.code, self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString);
	self.assertNotNull(vessel);
	self.assertNotNull(voyage);
	
	// create the crane
	create tas transient;
	tas.add(cta.id);
	self.opts.purge();
	self.opts.addAssoc("CraneTransferArea", cta);
	self.opts.addAssoc("MachineLiftType", TWIN_LIFT);
	crane := self.addCrane(CraneId, null, tas, null);
	self.assertNotNull(crane);
	delete tas;

	
	loadPort := app.myRoot.allPorts[voyage.myTerminal.getConfig(PortDestCode).String];
	dischargePort := voyage.myTrade.allPortRotations.first.myPort;

	//create discharge job
	bayName := '01';
	create slots transient;
	self.getJobSlotControllers(Voyage1, bayName, DeckOnDeck, 1, 1, 1, slots);
	assertEqual(slots.size, 1);
	dischargeTi := self.addContainerAtLocnDisch(DischargeBox , "2200", "GENL", TI_IMEX_STATUS_IMPORT, slots[1], loadPort, voyage);
	// Color code and Create Discharge Jobs
	self.voyageDischargeColourCode(voyage);
	
	voyageJob := self.addVoyageJob(voyage, CraneId, slots, true);
	assertTrueMsg(voyageJob &lt;&gt; null, "Voyage job 1 not created");
	jobs.add(voyageJob);
	
	foreach wle in voyageJob.workListEntries do
		self.movePlannedWLE(wle.myTrackedItem, 	bs.myLocationsController, wle);
	endforeach;
	delete slots;
	

	self.opts.purge();
	self.opts.addAssoc("Operator", operator);
	self.opts.addAssoc("ISOType", '2200');
	//self.opts.addAssoc("Commodity",  self.getTerminal.getDefaultEmptyCommodity() );
	//voyAlloc := self.addVoyageAllocation(voyage, dischargePort.code,null,null,1,false,false);
	voyAlloc := self.addVoyageAllocation(voyage, dischargePort.code,null,self.getTerminal.getDefaultEmptyCommodity(),1,false,false);		// 05/04/2013 cnwmh5
	bayName :='01';
	
	create slots transient;
	self.getJobSlotControllers(voyage.code, bayName, DeckOnDeck, 1, 2, 5, slots);
	assertEqual(slots.size, 5);
	
	self.addLCsToLOLOAllocation(true, voyAlloc, slots, null);
	self.opts.purge();
	self.opts.addAssoc("OutOfOrder", true);
	
	voyageJob := self.addVoyageJob(voyage, CraneId, slots, false);
	assertTrueMsg(voyageJob &lt;&gt; null, "Voyage job not created");
	jobs.add(voyageJob);	
	
	
	loadTi1 := self.addContainerForExport(LoadBox1, operator,
				"2200",	"MT",	TI_IMEX_STATUS_EXPORT,	null, voyage.code, dischargePort.code, null).CM_Container;
	self.move(loadTi1, bs.getLocationsController);
	self.assertEqual(loadTi1.myPrimaryActualLocation, bs.myLocationsController);
	self.setCargoReadyToShip(loadTi1);
	self.deleteStops(loadTi1);	
	theLoadTis.add(loadTi1);
	//self.movePlannedRequestToJob(loadTi, slots[1], slots[1].getRequest(true));

	loadTi2 := self.addContainerForExport(LoadBox2, operator,
				"2200",	"MT",	TI_IMEX_STATUS_EXPORT,	null, voyage.code, dischargePort.code, null).CM_Container;
	self.move(loadTi2, bs.getLocationsController);
	self.assertEqual(loadTi2.myPrimaryActualLocation, bs.myLocationsController);
	self.setCargoReadyToShip(loadTi2);
	self.deleteStops(loadTi2);
	theLoadTis.add(loadTi2);	
	//self.movePlannedRequestToJob(loadTi, slots[2], slots[2].getRequest(true));
	
	loadTi3 := self.addContainerForExport(LoadBox3, operator,
				"2200",	"MT",	TI_IMEX_STATUS_EXPORT,	null, voyage.code, dischargePort.code, null).CM_Container;
	self.move(loadTi3, bs.getLocationsController);
	self.assertEqual(loadTi3.myPrimaryActualLocation, bs.myLocationsController);
	self.setCargoReadyToShip(loadTi3);
	self.deleteStops(loadTi3);
	theLoadTis.add(loadTi3);
	//self.movePlannedRequestToJob(loadTi, slots[3], slots[3].getRequest(true));
	
	loadTi4 := self.addContainerForExport(LoadBox4, operator,
				"2200",	"MT",	TI_IMEX_STATUS_EXPORT,	null, voyage.code, dischargePort.code, null).CM_Container;
	self.move(loadTi4, bs.getLocationsController);
	self.assertEqual(loadTi4.myPrimaryActualLocation, bs.myLocationsController);
	self.setCargoReadyToShip(loadTi4);
	self.deleteStops(loadTi4);
	theLoadTis.add(loadTi4);
	//self.movePlannedRequestToJob(loadTi, slots[4], slots[4].getRequest(true));
	
	loadTi5 := self.addContainerForExport(LoadBox5, operator,
				"2200",	"MT",	TI_IMEX_STATUS_EXPORT,	null, voyage.code, dischargePort.code, null).CM_Container;
	self.move(loadTi5, bs.getLocationsController);
	self.assertEqual(loadTi5.myPrimaryActualLocation, bs.myLocationsController);
	self.setCargoReadyToShip(loadTi5);
	self.deleteStops(loadTi5);
	theLoadTis.add(loadTi5);
	//self.movePlannedRequestToJob(loadTi, slots[5], slots[5].getRequest(true));
	
	
	
	// ok have my load and discharge jobs now
	
	//load to ops
	self.loadAllJobsToOps(voyage, true);				
	
	self.addMachineRule( bs, crane.CM_Crane.transferArea, RTMoveMethod_23); //simple single straddle moves
	self.addMachineRule( crane.CM_Crane.transferArea, bs, RTMoveMethod_23); 
		
	voyageQueue := self.addVoyageQueue(voyage);
	craneQueue := self.addVoyageCraneQueue(voyage, voyageQueue, crane);
	
	// Create Queues
	foreach job in jobs do
		foreach request in job.allRequests do
			foreach wle in request.allWorkListEntries do
				if wle.CM_VoyageWLE.myRequest.CM_SlotRequest.isLoad then
					wles.add(wle);
					self.autoplanWLE(wle);
				else
					wles.add(wle);
					self.queueWLE(wle);
				endif;

			endforeach;
		endforeach;
	endforeach;
	
	// workJob using straddle
	self.deleteMachine("UTS1");
	self.deleteRTDevice("91");
	create tas transient;
	tas.add(bs.id); 
	tas.add(yardIC.id); 
	tas.add(crane.CM_Crane.transferArea.id); 
	self.addStraddle("UTS1", 91, tas, null);
	straddle := self.getMachine("UTS1");
	assertNotNull(straddle);
	if craneQueue &lt;&gt; null then
		beginTransaction;
		straddle.addToQueue(craneQueue, true, 0); //add straddle to crane queue
		commitTransaction;
	endif;
	delete tas;
	
	app.isRTApp:=true;  
	self.machineLogon(straddle);
	// Use Lander to move to ship
	create agent transient;
	agent.setDoNotShowMsgBox(true);

	looper := 1;
	foreach wle in wles do
		if wle.isReceipt and wle.job.isVoyageJob then 
			//crane := wle.job.CM_VoyageJob.getJobCrane();
			self.machineAcceptTask(straddle, wle.allRTQueueEntries.first.allTasks.first);
			self.machineCraneActionPickup(straddle, dischargeTi, ti4);
			self.machinePickup(straddle);			
			self.machineSetdownTask(straddle, wle.allRTQueueEntries.first.allTasks.last, bs.id);	
		else
			self.machineAcceptSpecifiedTask(straddle, wle.allRTQueueEntries.first);
			self.machineDirector(straddle, theLoadTis[looper]);
			self.machineSetdownTask(straddle,wle.allRTQueueEntries.last.allTasks.last , crane.CM_Crane.transferArea.id);
			// Use Lander to move to ship
			agent.moveTI( theLoadTis[looper], null, slots.first, wle, true, 0, 0, null );
			self.assertNoTrxErrorsOrWarnings();
			self.assertTrue(wle.myTrackedItem.isOnShip);
			looper := looper+1;
		endif;
		
	endforeach;	
	
	self.assertTrue( dischargeTi.myPrimaryActualLocation.isYardLocation);
	self.assertTrue(  theLoadTis[1].myPrimaryActualLocation.isVoyageController);
	
	self.assertEqual( theLoadTis[1].myPrimaryActualLocation, slots[1]);
	self.assertTrue( theLoadTis[1].allQueuedFutureMoves.isEmpty);
	// check txns created correctly for the following
	self.checkTIForTxnOfType(dischargeTi, TRANS_TYPE_REC_SHIP);			// 15/08/2012 cnwmh5
	self.checkTIForTxnOfType(dischargeTi, TRANS_TYPE_WHARFAGE);			// 15/08/2012 cnwmh5
	self.checkTIForTxnOfType(theLoadTis[1], TRANS_TYPE_REL_SHIP);				// 15/08/2012 cnwmh5
	self.checkTIForTxnOfType(theLoadTis[1], TRANS_TYPE_WHARFAGE);				// 15/08/2012 cnwmh5
	
epilog
	app.isRTApp:=false;  
	delete jobs;
	delete slots;
	delete wles;
	delete tas;	
	delete agent;
	delete theLoadTis;
	delete locations;
	self.disableAllYA(false);
end;</source>
    </JadeMethod>
    <JadeMethod name="tVoyAllocLoadRORO" id="20443e5b-4d9c-4d9d-bb0f-ba71528a8cbc">
        <updating/>
        <source>tVoyAllocLoadRORO() updating;
// cnwma1

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
31 January 2013	cnwrd1	Initial creation
08 Jan 2024	jlirs1	TFS 60575 - Jade 2022 upgrade fixing unitTests
*/

constants
	BlockStack1			= "UT_RDBS1";
	YardIC				= "UT_RD_IC";
	Ship				= "UTRDSHIP";
	Voyage1				= "UTRDROROV2";
	CraneTransferAreaId	= "CTRD";
	CraneId				= "CRR1";
	YardAlloc			= 'RDALLOC';
	CTAbbrv = "GLOW";
vars
	vessel : CM_Vessel;
	vesselName: String;
	tradeName: String;
	operatorCode: String;
	deckContName, deckGCName, deckRehandleName: String;
	voyage : CM_Voyage;
	voyageCode : String;
	trade		: CM_Trade;
	portRotation : CM_PortRotation;
	port 		: CM_Port;
	voyAlloc20s 	: ObjectArray;
	voyAlloc40s		: ObjectArray;
	deckCont, deckGC, deckRehandle: CM_DeckVoyage;
	all40FrontSlotDefn,
	all20SlotDefns		 : CM_ROROSlotLCsByOrdDict;
	iter				: Iterator;
	slotController 	: CM_ROROSlotController;
	slotDefn			: CM_ROROSlotDefn;
	locnDefn			: CM_ROROLocnDefn;
	ccSize, ccIndex				: Integer;
	allJobSlots ,altSlots	: CM_LCArray;
	voyAlloc		: CM_VoyageAllocation;
	workPoints : ObjectArray;
	wpA: CM_WorkPoint;
	oowController : CMIF_OOWCreationAutoUpdate;
	jobController : CMIF_VoyageJobParams;
	request : CM_RORORequest;
	i, c : Integer;
	operator : CM_Operator;
	ti : CM_TrackedItem;
	bs 	: CM_BlockStack;
	lcs, lcSet : CM_LCSet;
	theJobParams : CMIF_VoyageJobParams;
	job : CM_Job;
	ct: CM_CargoType;
	editions : CM_ObjectByOidEditionDict;
	gcDischargePort: CM_Port;
	jobSheet: CM_VoyageJobSheet;
	tiArray20s,
 	tiArray40s,
	tiArrayGC		: CM_TIArray;
	tas				: StringArray;
	//agent			: CM_MobileAgent;
	agent : CMIF_MobileGenericAgent;
	straddle		: CM_Machine;
	aRequest		: CM_Request;
	looper 			: Integer;
	wle				: CM_WorkListEntry;
	voyageQueue		: CM_VoyageQueue;
	wpQueue			: CM_VoyageWorkPointQueue;
	locations 		: CM_LCArray;
	ya				: CM_YardAllocation;
		wpaType, bsaType : CM_TerminalAreaType;

begin
	
	self.disableAllYA(true);
	
	voyageCode := Voyage1;

	vesselName := "ROBRORO";
	tradeName := "Doug World";
	operatorCode := "RAJD";
	deckContName := "CONT1";
	deckGCName := "GC";
    deckRehandleName := "REHANDLE";

	vessel	:= self.getVessel( vesselName );
	if vessel = null then
		return;
	endif;
	
	trade:= app.myRoot.allTradesByDescription[tradeName];
	if trade = null then
		return;
	endif;

	self.deleteVoyage(voyageCode);
	self.assertNull( self.getVoyage(voyageCode));
	
	self.deleteCargoType(CTAbbrv); // ### TFS CR 58263 TASK 58264 25JAN2024 NAVAB1
	
	self.opts.purge();
	self.opts.addAssoc("OutOfSequenceVJ", true);
	voyage := self.addVoyageWithConRORO(voyageCode, vessel.code, operatorCode, 'DOUG', null, 0, false, true);
	operator := voyage.myOperator;

	beginTransaction;
	voyage.setMyTrade(trade);
	commitTransaction;
	
	create voyAlloc20s transient;
	create voyAlloc40s transient;
	create tiArray20s transient;
	create tiArray40s transient;
	create tiArrayGC transient;
	
	
	// create voyage allocations for each port in the trade	
	foreach portRotation in trade.allPortRotations discreteLock do
		port := portRotation.myPort;
		if port = self.getTerminal.getDefaultPort then
			continue;
		endif;
		self.opts.purge();
		self.opts.addAssoc("Operator", operator);
		self.opts.addAssoc("ISOType", '2200');
		//self.opts.addAssoc("Commodity",  "GENL" );
		//voyAlloc20s.add(self.addVoyageAllocation(voyage, port.code,"GEN2",null,1,false,false));
		voyAlloc20s.add(self.addVoyageAllocation(voyage, port.code,"GEN2","GENL",1,false,false));				// 05/04/2013 cnwmh5
		self.opts.purge();
		self.opts.addAssoc("Operator", operator);
		self.opts.addAssoc("ISOType", '4200');
		//self.opts.addAssoc("Commodity",  "GENL" );		
		//voyAlloc40s.add(self.addVoyageAllocation(voyage, port.code,"GEN4",null,1,false,false));
		voyAlloc40s.add(self.addVoyageAllocation(voyage, port.code,"GEN4","GENL",1,false,false));			// 05/04/2013 cnwmh5
	endforeach;
	
	self.opts.purge();

	
	// Blocks Stack for exports
	bs := self.addBlockStack(voyageCode, 10000, null);	
	
	create locations transient;
	self.deleteYA(YardAlloc);
	locations.add(bs.myLocationsController);
	//ya := self.addYA1WithFill(YardAlloc, YACriteriaType_IsTwenty, CM_YADataBoolean.VALUE_TRUE, locations, YAFillOption_FIFO, YAFillOption_FIFO);
	ya := self.addYA1WithFill(YardAlloc, YACriteriaType_OperatorItem, operator.code, locations, YAFillOption_InOrder, YAFillOption_FIFO,false);	
	// create the work points
	wpA:= self.getTerminal().allWorkPointsByCode["WPA"];
	if wpA &lt;&gt; null then
		beginTransaction;
			wpA.allJobSheets.purge;
		commitTransaction;
	endif;
	wpA := self.addWorkPoint("WPA", true);
		self.assertEqual(wpA.myTerminal, self.getTerminal);
	self.addWorkPointTransferArea("WPA_IC", wpA);

	// ### NAVAB1 17NOV2021 ADD MACHINE RULE FOR STRADDLE
	if wpA.myWorkPointInterchangeArea &lt;&gt; null then
		wpaType := wpA.myWorkPointInterchangeArea.myType;
	endif;
	if bs &lt;&gt; null then
		bsaType := bs.myType;
	endif;
	// ### Add Machine Rule BS to WPTA = STRADDLE
	self.addMachineRuleType(bsaType, wpaType, RTMoveMethod_23, FullMoveQueuing);

	
	
	
	create workPoints transient;
	workPoints.add(wpA);
	
	
	voyageQueue := self.addVoyageQueue(voyage);
	wpQueue := self.addVoyageWorkPointQueue(voyage, voyageQueue, wpA);
	
	app.myTrxUA.trxUpdateVoyageJobSheet(workPoints,voyage,CM_VoyageDeckJobSheet,app.myPassport);
	self.assertNoTrxErrorsOrWarnings;
	
	// Container
	create all40FrontSlotDefn  transient;
	create all20SlotDefns	transient;

	self.logMessage("Get 20/40ft slots");
	deckCont := voyage.myROROStructure.allDecksByCode[deckContName];
	deckGC := voyage.myROROStructure.allDecksByCode[deckGCName];
	
	iter := deckCont.allROROSlotControllers.createIterator;
	while iter.next(slotController) do
		locnDefn:=slotController.mySlotDefn.myROROLocnDen;
		if locnDefn.myAdjacentSlotAft &lt;&gt; null or locnDefn.myAdjacentSlotFwd &lt;&gt; null then
			if locnDefn.myAdjacentSlotAft &lt;&gt; null then
				if not all40FrontSlotDefn.includes(locnDefn.myAdjacentSlotAft.allROROSlotDefnByOrdinal.first.CM_ROROSlotDefnVoyage.mySlotController) then
					all40FrontSlotDefn.add(slotController);
				endif;
			endif;
		else
			all20SlotDefns.add(slotController);
		endif;	
	endwhile;
	delete iter;
	
	//do all 20ft slots hoping that because they are ordered by ordinal the slots will be positioned close to each other
	self.logMessage("CC 20ft slots");
	create allJobSlots transient;
	create altSlots transient;
	ccSize:=(all20SlotDefns.size/(voyAlloc20s.size)).roundedUp;
	
	self.ignoreTrxWarnings(true);
	
	ccIndex:=1;
	delete iter;
	iter:=all20SlotDefns.createIterator;
	c := 0;
	while iter.next(slotController) do
        c := c + 1;				
		if (c mod 3) = 0 and slotController.getOrdinalSlot = slotController.myDeck.numTier then
			continue;
		endif;
		allJobSlots.add(slotController);
		// once we get size for color coding CC the sucker
		if allJobSlots.size = ccSize then
			voyAlloc:=voyAlloc20s[ccIndex].CM_VoyageAllocation;
			self.ignoreTrxWarnings(true);
			slotDefn:=slotController.mySlotDefn;
			locnDefn:=slotDefn.myROROLocnDen;
			while true do
				slotDefn:=slotController.mySlotDefn;
				if slotDefn &lt;&gt; locnDefn.allROROSlotDefnByOrdinal.last then
					iter.next(slotController);
					allJobSlots.add(slotController);
				else
					break;
				endif;
			endwhile;
			
			self.addLCsToROROAllocation(true,voyAlloc,allJobSlots,altSlots,1);
			allJobSlots.clear;
			ccIndex:=ccIndex+1;
		endif;
	endwhile;
	
	if allJobSlots.size &gt; 0 then
		voyAlloc:=voyAlloc20s[ccIndex].CM_VoyageAllocation;
		self.ignoreTrxWarnings(true);
		self.addLCsToROROAllocation(true,voyAlloc,allJobSlots,altSlots,1);
		allJobSlots.clear;
	endif;
	
	self.logMessage("CC 40ft slots");
	allJobSlots.clear;
	ccSize:=(all40FrontSlotDefn.size/voyAlloc40s.size).roundedUp;
	ccIndex:=1;

	delete iter;
	iter:=all40FrontSlotDefn.createIterator;
	c := 0;
	while iter.next(slotController) do
        c := c + 1;				
		if (c mod 3) = 0 and slotController.getOrdinalSlot = slotController.myDeck.numTier then
			continue;
		endif;

		allJobSlots.add(slotController);
		
		// once we get size for color coding CC the sucker
		if allJobSlots.size = ccSize then
			voyAlloc:=voyAlloc40s[ccIndex].CM_VoyageAllocation;
			self.ignoreTrxWarnings(true);
			slotDefn:=slotController.mySlotDefn;
			locnDefn:=slotDefn.myROROLocnDen;
			while true do
				slotDefn:=slotController.mySlotDefn;
				if slotDefn &lt;&gt; locnDefn.allROROSlotDefnByOrdinal.last then
					iter.next(slotController);
					allJobSlots.add(slotController);
				else
					break;
				endif;
			endwhile;	
			self.addLCsToROROAllocation(true,voyAlloc,allJobSlots,altSlots,1);
			allJobSlots.clear;
			ccIndex:=ccIndex+1;
		endif;
	endwhile;
	
	if allJobSlots.size &gt; 0 then
		voyAlloc:=voyAlloc40s[ccIndex].CM_VoyageAllocation;
		self.ignoreTrxWarnings(true);
		self.addLCsToROROAllocation(true,voyAlloc,allJobSlots,altSlots,1);
		allJobSlots.clear;
	endif;
	

	// create the oowCreations for the Voyage
	self.logMessage("Create OOW");
	app.myTrxCA.trxCreateVoyageOOWCreationRORO(voyage.myROROStructure,app.myPassport);
	self.assertNoTrxErrorsOrWarnings;
	
	// Allocate OOWCreations to Voyage Allocations slots
	create oowController transient;
	oowController.myCellularStructure :=voyage.myCellularVoyageStructure;
	oowController.myROROStructure:=voyage.myROROStructure;
	app.myTrxUA.trxUpdateVoyageOOWAuto(false,oowController,app.myPassport);
	self.assertNoTrxErrorsOrWarnings;
	
	create jobController transient;
	app.myTrxCA.trxCreateVoyageJobOOW(voyage.allJobSheets,app.myPassport,jobController);
	self.assertNoTrxErrorsOrWarnings;
	

	create editions transient;
	deckRehandle := voyage.myROROStructure.allDecksByCode[deckRehandleName];
	voyAlloc := voyAlloc20s.first.CM_VoyageAllocation;
	

	// Create a Terminal Area and fill with cargo based on the Voyage Allocations
	// Will just for this example create a unlimited Block Stack the DIAM block stack
	self.logMessage("Create Onsite 20ft Cargo in BS");
	delete iter;
	iter:=all20SlotDefns.createIterator;
	self.opts.addAssoc(UTTI_VoyageCode,voyageCode);
	self.opts.addAssoc("CENum","1234");
	i:=1;
	while iter.next(slotController) do
		request := slotController.myRORORequestLoad;
		if request = null then
			continue;
		endif;
		self.opts.addAssoc(UTTI_DischargePort,request.getDischargePort);
		ti :=self.addContainerOpts(operatorCode &amp; i.padLeadingWith("0",7), "2200", "GENL",operator);
		self.assertNoTrxErrorsOrWarnings;
		self.ignoreTrxWarnings(true);
		self.move(ti,bs.myLocationsController);
		self.assertNoTrxErrorsOrWarnings;
		self.ignoreTrxWarnings(true);
		self.deleteStops(ti);
		self.assertNoTrxErrorsOrWarnings;
		self.ignoreTrxWarnings(true);
		//self.movePlannedRequestToJob(ti,slotController, slotController.myRORORequestLoad);  //dont want to plan
		self.assertNoTrxErrorsOrWarnings;
		tiArray20s.add(ti);
		i:=i+1;
	endwhile;
	
	self.logMessage("Create Onsite 40ft Cargo in BS");
	delete iter;
	iter:=all40FrontSlotDefn.createIterator;

	while iter.next(slotController) do
		request := slotController.myRORORequestLoad;
		if request = null then
			continue;
		endif;
		self.opts.addAssoc(UTTI_DischargePort,request.getDischargePort);
		ti :=self.addContainerOpts(operatorCode &amp; i.padLeadingWith("0",7), "4200", "GENL",operator);
		self.assertNoTrxErrorsOrWarnings;
		self.ignoreTrxWarnings(true);
		self.move(ti,bs.myLocationsController);
		self.assertNoTrxErrorsOrWarnings;
		
		self.ignoreTrxWarnings(true);
		self.deleteStops(ti);
		self.assertNoTrxErrorsOrWarnings;
		
		self.ignoreTrxWarnings(true);
		//self.movePlannedRequestToJob(ti,slotController, slotController.myRORORequestLoad); dont want to plan
		self.assertNoTrxErrorsOrWarnings;
		tiArray40s.add(ti);
		i:=i+1;
	endwhile;
	
	// GC
	self.logMessage("Create Load Job for GC");

// ### TFS CR 58263 TASK 58264 25JAN2024 NAVAB1	ct := self.getCargoType("CANNONBALL");						// 10047								// 28/06/2013 cnwmh5

	// ### TFS CR 58263 TASK 58264 25JAN2024 NAVAB1 add our own cargo type (fixing UTs)
	self.opts.purge();
	self.opts.addAssoc("TrackAs", ProductType_BreakBulk);
	self.opts.addAssoc("AllowDuplicateId", false);
	self.opts.addAssoc("TrackAs", 0);
	
	ct := self.addCargoType(CTAbbrv, false);
	gcDischargePort :=  trade.allPortRotations.first.myPort;
	if gcDischargePort = self.getTerminal.getDefaultPort then
		gcDischargePort :=  trade.allPortRotations.last.myPort;
	endif;

	
	self.opts.purge();
	self.opts.addAssoc("OutOfSequenceVJ", true);
	self.opts.addAssoc("PlanCargo", false);

	self.createGCLoadJobForRORO(voyage, wpA, deckGC, 20, -10, gcDischargePort.code, ct, operator,"CANC", 10, 20, bs,tiArrayGC);
	self.createGCLoadJobForRORO(voyage, wpA, deckGC, 45, -10, gcDischargePort.code, ct, operator, "CANC", 50, 70, bs,tiArrayGC);

	self.logMessage("Release all Jobs");

	// Release all jobs to ops
	foreach job in voyage.allVoyageJobs discreteLock do
		beginTransaction;
		job.CM_VoyageJob.setShipOpsLoad();
		commitTransaction;
	endforeach;
	
	// Check stuff
	foreach jobSheet in voyage.allJobSheets do
		assertNotNullMsg(jobSheet.CM_VoyageDeckJobSheet.myWorkPoint, "Job sheet missing workpoint reference");
	endforeach;
	
		
		
		// workJob using straddle
	self.deleteMachine("UTS1");
	self.deleteRTDevice("91");
	create tas transient;
	tas.add('WPA_IC'); 
	tas.add(voyageCode); 
	self.addStraddle("UTS1", 91, tas, null);
	straddle := self.getMachine("UTS1");
	assertNotNull(straddle);
	
	if wpA.allVoyageWorkPointQueues.first &lt;&gt; null then
		beginTransaction;
		straddle.addToQueue(wpQueue, true, 0); //add straddle to crane queue
		commitTransaction;
	endif;
	delete tas;
	
	app.isRTApp:=true;  
	self.machineLogon(straddle);
	// Use Lander to move to ship
	create agent transient;
	agent.setDoNotShowMsgBox(true);
	
	self.ignoreTrxWarnings(true);
	
	looper := 1;
	foreach job in voyage.allVoyageJobs discreteLock do
		foreach aRequest in job.allRequests do
			foreach wle in aRequest.allWorkListEntries do
			
			

				if aRequest.getAttrIs40 then
					self.autoplanWLE(wle);
					self.machineAcceptSpecifiedTask(straddle, wle.allRTQueueEntries.first);
					self.machineDirector(straddle, tiArray40s.first);
					tiArray40s.removeAt(1);
					self.machineSetdownTask(straddle,wle.allRTQueueEntries.last.allTasks.last , 'WPA_IC');
					// Use Lander to move to ship
					agent.moveTI( wle.myTrackedItem , null, wle.myRequest.CM_RORORequest.myROROControllerLoad, wle, true, 0, 0, null );
					self.assertNoTrxErrorsOrWarnings();
					self.assertTrue(wle.myTrackedItem.isOnShip);
				elseif aRequest.getAttrIs20 then
					self.autoplanWLE(wle);
					self.machineAcceptSpecifiedTask(straddle, wle.allRTQueueEntries.first);
					self.ignoreTrxWarnings(true);
					self.machineDirector(straddle, tiArray20s.first);
					tiArray20s.removeAt(1);
					self.machineSetdownTask(straddle,wle.allRTQueueEntries.last.allTasks.last , 'WPA_IC');
					// Use Lander to move to ship
					agent.moveTI( wle.myTrackedItem , null, wle.myRequest.CM_RORORequest.myROROControllerLoad, wle, true, 0, 0, null );			
					self.assertNoTrxErrorsOrWarnings();
					self.assertTrue(wle.myTrackedItem.isOnShip);
				else
					self.ignoreTrxWarnings(true);
					self.autoplanWLE(wle);
					self.machineAcceptSpecifiedTask(straddle, wle.allRTQueueEntries.first);
					self.ignoreTrxWarnings(true);
					self.machineDirector(straddle, tiArrayGC.first);
					tiArrayGC.removeAt(1);
					self.machineSetdownTask(straddle,wle.allRTQueueEntries.last.allTasks.last , 'WPA_IC');
					// Use Lander to move to ship
					self.deleteStops(wle.myTrackedItem);
					agent.moveTI( wle.myTrackedItem , null, wle.myRequest.CM_RORORequest.myROROControllerLoad, wle, true, 0, 0, null );	
					self.assertNoTrxErrorsOrWarnings();
					
					self.assertTrue(wle.myTrackedItem.isOnShip);
				endif;
			endforeach;		
		endforeach;
	endforeach;
	
	// ### NAVAB1 17NOV2021 ADD MACHINE RULE FOR STRADDLE
	self.deleteMachineRule(wpaType, bsaType);
	self.deleteCargoType(CTAbbrv); // ### TFS CR 58263 TASK 58264 25JAN2024 NAVAB1
epilog
	app.isRTApp:=false;  
	self.disableAllYA(false);
	self.ignoreTrxWarnings(false);
	delete voyAlloc20s;
	delete voyAlloc40s;
	delete all40FrontSlotDefn;
	delete all20SlotDefns;
	delete allJobSlots;
	delete altSlots;
	delete workPoints;
	delete oowController;
	delete jobController;
	delete iter;
	delete lcSet;
	delete theJobParams;
	delete lcs;
	delete editions;
	delete tiArray20s;
	delete tiArray40s;
	delete tiArrayGC;
	delete agent;
	delete locations;
	delete tas;											// 13/12/2013 cnwmh5
end;</source>
        <text>&lt;?xml version="1.0"?&gt;
&lt;UT_Additional&gt;
  &lt;Categories&gt;
    &lt;Category CanDelete="true"&gt;WorkPointDeleteIssue&lt;/Category&gt;
  &lt;/Categories&gt;
&lt;/UT_Additional&gt;</text>
    </JadeMethod>
    <JadeMethod name="tVoyLOLO_TBA_RRP" id="4bf79399-6294-4a53-aa67-5c6b6ec701b0">
        <updating/>
        <source>tVoyLOLO_TBA_RRP() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
16 Mar 2020	jlgndl1	TFS 47004 - TBAs vs RRPs
08 Jan 2024	jlirs1	TFS 60575 - Jade 2022 upgrade fixing unitTests
*/


constants
	DischargeBox		= "UTDR0000002";
	LoadBox1			= "UALC0000003";
	LoadBox2			= "UALC0000004";
	LoadBox3			= "URRP0000005";
	LoadBox4			= "URRP0000006";
	LoadBox5			= "UTBA0000007";
	LoadBox6			= "UTBA0000008";
	BlockStack1			= "UT_TBA";
	YardIC				= "UT_TBA_IC";
	Ship				= "UTRDSHIP";
	Voyage1				= "UTBAVOYAGE";
	CraneTransferAreaId	= "CTRD";
	CraneId				= "CRR1";
	YardAlloc			= 'TBALLOC';
	ShipRelReq			= "REL47004";
vars
	dischargeTi,
	loadTi1,
	loadTi2,
	loadTi3,
	loadTi4,
	loadTi5,
	loadTi6,
	ti4				: CM_TrackedItem;
	bs				: CM_BlockStack;
	yardIC			: CM_InterchangeArea;
	wle				: CM_WorkListEntry;
	vessel			: CM_Vessel;
	voyage			: CM_Voyage;
	slots 			: CM_SlotControllerArray;
	voyageJob		: CM_VoyageJob;
	job				: CM_Job;
	request			: CM_Request;
	voyageQueue		: CM_VoyageQueue;
	craneQueue		: CM_VoyageCraneQueue;
	crane			: CM_Machine;
	operator		: CM_Operator;
	bayName			: String;
	loadPort,
	dischargePort	: CM_Port;
	jobs			: CM_JobArray;
	voyAlloc		: CM_VoyageAllocation;
	wles 			: CM_WLEArray;
	straddle		: CM_Machine;
	tas				: StringArray;
	cta				: CM_CraneTransferArea;
//	agent			: CM_MobileAgent;
	agent : CMIF_MobileGenericAgent;
	looper			: Integer;
	theLoadTis		: CM_TIArray;
	yaName			: String;
	ya				: CM_YardAllocation;
	locations 		: CM_LCArray;
	rel47004		: CM_BulkRelease;
	tmpLoadCC	: CMIF_LoadColorCode;
	editions 	: CM_ObjectByOidEditionDict;
	relReqslots : CM_SlotControllerArray;
	tbaReqslots : CM_SlotControllerArray;
	tbaController : CMIF_TBAContainer;
	tba5 : CM_TrackedItem;
	tba6 : CM_TrackedItem;
	pxyTI : CM_TrackedItem;
	theFilter : CMQF_ShipLoadListTIs;
	moveController : CMIF_MoveController;
	
begin
	
	create jobs transient;
	create wles transient;
	create theLoadTis transient;
	
	self.setTerminalConfig(ShowRelReqOnShipLoadList, true);	//16 Mar 2020	NDL	TFS 47004

	// delete everything first
	self.deleteContainer(DischargeBox);
	self.deleteContainer(LoadBox1);
	self.deleteContainer(LoadBox2);
	self.deleteContainer(LoadBox3);
	self.deleteContainer(LoadBox4);
	self.deleteContainer(LoadBox5);
	self.deleteContainer(LoadBox6);
	self.deleteTerminalArea(BlockStack1);
	self.deleteTerminalArea(YardIC);
	self.deleteVoyage(Voyage1);
	self.deleteVessel(Ship);
	self.deleteMachine(CraneId);
	self.deleteTerminalArea(CraneTransferAreaId);
	self.deleteReleaseRequest(ShipRelReq);		//16 Mar 2020	NDL	TFS 47004
	
	self.disableAllYA(true);
		
	
	// create the terminal areas - gridded block stack, block stack and interchange
	self.opts.purge;
	self.opts.addAssoc("ActAsReleasePoint", 1);
	self.opts.addAssoc("HideOverview", true);
	yardIC := self.addInterchangeArea(YardIC, null);
	self.opts.purge;
	self.opts.addAssoc("ActAsReleasePoint", 1);
	self.opts.addAssoc("StockControlled", true);
	self.opts.addAssoc("DefaultYIC", yardIC);
	bs := self.addBlockStack(BlockStack1, 20, null);		
	
	operator := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);
	
	create locations transient;
	
	locations.add(bs.allLocationsControllers.first);
	yaName := YardAlloc;
	self.deleteYA(YardAlloc);
	//ya := self.addYA1WithFill(YardAlloc, YACriteriaType_IsTwenty, CM_YADataBoolean.VALUE_TRUE, locations, YAFillOption_FIFO, YAFillOption_FIFO);
	ya := self.addYA1WithFill(YardAlloc, YACriteriaType_OperatorItem, operator.code, locations, YAFillOption_InOrder, YAFillOption_FIFO,false);
	
	// create the crane transfer area
	cta := self.addCraneTransferArea(CraneTransferAreaId);
	self.assertNotNull(cta);
	
	//create vessel and voyage
	vessel := addVesselCellular(Ship,operator);
	self.opts.purge;
	self.opts.addAssoc("UseAllocations", true);
	self.opts.addAssoc("CopyVoyageVAConfig", false);
	
	voyage := self.addVoyageWithContainerStructur(Voyage1, Ship, operator.code, self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString);
	self.assertNotNull(vessel);
	self.assertNotNull(voyage);
	
	// create the crane
	create tas transient;
	tas.add(cta.id);
	self.opts.purge();
	self.opts.addAssoc("CraneTransferArea", cta);
	self.opts.addAssoc("MachineLiftType", TWIN_LIFT);
	crane := self.addCrane(CraneId, null, tas, null);
	self.assertNotNull(crane);
	delete tas;
	
	//add crane queues
	voyageQueue := self.addVoyageQueue(voyage);
	craneQueue := self.addVoyageCraneQueue(voyage, voyageQueue, crane);

	loadPort := app.myRoot.allPorts[voyage.myTerminal.getConfig(PortDestCode).String];
	dischargePort := voyage.myTrade.allPortRotations.first.myPort;

	//create discharge job
	bayName := '01';
	create slots transient;
	self.getJobSlotControllers(Voyage1, bayName, DeckOnDeck, 1, 1, 1, slots);
	assertEqual(slots.size, 1);
	dischargeTi := self.addContainerAtLocnDisch(DischargeBox , "2200", "GENL", TI_IMEX_STATUS_IMPORT, slots[1], loadPort, voyage);
	// Color code and Create Discharge Jobs
	self.voyageDischargeColourCode(voyage);
	
	voyageJob := self.addVoyageJob(voyage, CraneId, slots, true);
	assertTrueMsg(voyageJob &lt;&gt; null, "Voyage job 1 not created");
	jobs.add(voyageJob);
	
	foreach wle in voyageJob.workListEntries do
		self.movePlannedWLE(wle.myTrackedItem, 	bs.myLocationsController, wle);
	endforeach;
	delete slots;
	
	//create release request for RRP creation
	self.opts.purge();
	self.opts.addAssoc("Voyage",voyage);
	self.opts.addAssoc("Number",2.Integer);
	self.opts.addAssoc("Operator", operator);
	self.opts.addAssoc("DischargePort",dischargePort);
	rel47004 := self.addReleaseByTypeRequest(ShipRelReq, BR_TYPE_SHIP, TI_CargoType_Container, "2200");
	self.assertTrueMsg( rel47004 &lt;&gt; null, "Bulkrelease " &amp; ShipRelReq &amp; " not created - " &amp; app.myPassport.getErrorsAndWarningsAsString);
	

	self.opts.purge();
	self.opts.addAssoc("Operator", operator);
	self.opts.addAssoc("ISOType", '2200');
	voyAlloc := self.addVoyageAllocation(voyage, dischargePort.code,null,self.getTerminal.getDefaultEmptyCommodity(),1,false,false);		// 05/04/2013 cnwmh5
	bayName :='01';
	
	
	//create load jobs for onsite TIs
	create slots transient;
	create relReqslots transient;
	create tbaReqslots transient;
	self.getJobSlotControllers(voyage.code, bayName, DeckOnDeck, 1, 2, 6, slots);
	assertEqual(slots.size, 6);
	
	relReqslots.add( slots[3] );
	relReqslots.add( slots[4] );
	tbaReqslots.add( slots[5] );
	tbaReqslots.add( slots[6] );
	
	self.addLCsToLOLOAllocation(true, voyAlloc, slots, null);
	self.opts.purge();
	self.opts.addAssoc("OutOfOrder", true);
	
	voyageJob := self.addVoyageJob(voyage, CraneId, slots, false);
	assertTrueMsg(voyageJob &lt;&gt; null, "Voyage job not created");
	jobs.add(voyageJob);	
	
	//Assign release to 2nd two slots ( standard allocation ones will go in the first two)
	create editions transient;
	relReqslots.copyNoDuplicates(editions);
	create tmpLoadCC transient;
	tmpLoadCC.myBulkReleaseReserveDetail := rel47004.allReserveDetails.first;
	tmpLoadCC.myVoyageAllocation := relReqslots.first.CM_SlotController.mySlotRequestLoad.getFirstAllocation;
	app.myTrxUA.trxUpdateSlotRequestAttribute(relReqslots, null, true, editions, CM_SlotRequest.Attribute_AssignRelease, tmpLoadCC, app.myPassport);
	assertTrueMsg(app.myPassport.noErrors, "Assigning Release to slots failed with " &amp; app.myPassport.getAllErrorsWarningsAsString);
	
	
	//create the cargo that will be represented by simlpe director tasks against a voyage allocation
	loadTi1 := self.addContainerForExport(LoadBox1, operator,
				"2200",	"MT",	TI_IMEX_STATUS_EXPORT,	null, voyage.code, dischargePort.code, null).CM_Container;
	self.move(loadTi1, bs.getLocationsController);
	self.assertEqual(loadTi1.myPrimaryActualLocation, bs.myLocationsController);
	self.setCargoReadyToShip(loadTi1);
	self.deleteStops(loadTi1);	
	theLoadTis.add(loadTi1);

	loadTi2 := self.addContainerForExport(LoadBox2, operator,
				"2200",	"MT",	TI_IMEX_STATUS_EXPORT,	null, voyage.code, dischargePort.code, null).CM_Container;
	self.move(loadTi2, bs.getLocationsController);
	self.assertEqual(loadTi2.myPrimaryActualLocation, bs.myLocationsController);
	self.setCargoReadyToShip(loadTi2);
	self.deleteStops(loadTi2);
	theLoadTis.add(loadTi2);	
	
	//create the cargo that will be represented by RRP and bought in by Truck after planned to LOLO location
	loadTi3 := self.addContainerForExport(LoadBox3, operator,
				"2200",	"MT",	TI_IMEX_STATUS_EXPORT,	null, voyage.code, dischargePort.code, null).CM_Container;
	self.move(loadTi3, bs.getLocationsController);
	self.assertEqual(loadTi3.myPrimaryActualLocation, bs.myLocationsController);
	self.setCargoReadyToShip(loadTi3);
	self.deleteStops(loadTi3);
	theLoadTis.add(loadTi3);
	
	loadTi4 := self.addContainerForExport(LoadBox4, operator,
				"2200",	"MT",	TI_IMEX_STATUS_EXPORT,	"MT", voyage.code, dischargePort.code, null).CM_Container;
	self.move(loadTi4, bs.getLocationsController);
	self.assertEqual(loadTi4.myPrimaryActualLocation, bs.myLocationsController);
	self.setCargoReadyToShip(loadTi4);
	self.deleteStops(loadTi4);
	theLoadTis.add(loadTi4); 
	
	//create the pre-note cargo that will be represented by the TBAs and bought in by Truck after planned to LOLO location
	self.opts.purge();
	self.opts.addAssoc("Commodity","MT");
	self.opts.addAssoc("ExportVoyage",voyage);
	self.opts.addAssoc("DischargePort",dischargePort.code);
	self.opts.addAssoc("OperatorCode",operator.code);
	loadTi5 := self.addPrenoted(LoadBox5);
	loadTi6 := self.addPrenoted(LoadBox6);
	
	//create the 2 TBAs (Not RRPs) for the last two slots in the job
	create tbaController transient;
	
	tbaController.id				:=	"TBA";
	tbaController.myCommodity		:=	self.getCommodity("MT");
	tbaController.myDischargePort	:=	dischargePort;
	tbaController.myISOType			:=	self.getISOType("2200");
	tbaController.myLocationSource	:=	bs.myLocationsController;
	tbaController.myOperator		:=	operator;
	tbaController.myTerminal		:=	self.getTerminal;
	tbaController.bookingReference	:= null;
	tbaController.myVoyage			:=	voyage;
	tbaController.state				:=	TI_STATE_TBA;
	tbaController.weight			:=	2000;
	
	app.myPassport.setWarningsIgnored(true);
	app.myTrxCA.trxCreateTBAContainer(tbaController, app.myPassport);
	self.assertNoTrxErrorsOrWarnings;
	tba5 := tbaController.myTrackedItem;
	delete tbaController;
	
	self.setCargoReadyToShip(tba5);
	self.deleteStops(tba5);
	
	create tbaController transient;
	
	tbaController.id				:=	"TBA";
	tbaController.myCommodity		:=	self.getCommodity("MT");
	tbaController.myDischargePort	:=	dischargePort;
	tbaController.myISOType			:=	self.getISOType("2200");
	tbaController.myLocationSource	:=	bs.myLocationsController;
	tbaController.myOperator		:=	operator;
	tbaController.myTerminal		:=	self.getTerminal;
	tbaController.bookingReference	:= null;
	tbaController.myVoyage			:=	voyage;
	tbaController.state				:=	TI_STATE_TBA;
	tbaController.weight			:=	2000;
	
	app.myPassport.setWarningsIgnored(true);
	app.myTrxCA.trxCreateTBAContainer(tbaController, app.myPassport);
	self.assertNoTrxErrorsOrWarnings;
	tba6 := tbaController.myTrackedItem;
	delete tbaController;
	
	self.setCargoReadyToShip(tba6);
	self.deleteStops(tba6);
	
	/// Check the loadList collections. TFS 49219
	create theFilter transient;
	theFilter.reset;	
	theFilter.allTerminals.add( self.getTerminal );
	theFilter.allVoyages.add( voyage );
	theFilter.allCargoTypes.add( loadTi1.myCargoType );
	theFilter.allOperators.add( operator );
	
	//ALL
	theFilter.plannedToShip := false;
	theFilter.transhipOnly := false;
	theFilter.tbaOnly := false;
	app.myQAFilter.qryTerminalTIs(theFilter, app.myPassport);
	self.assertTrueMsg( theFilter.allQryTrackedItems.size = 6 ," All 6 should be in the All for the load list form");
	
	//ALL TBA UNPLANNED
	theFilter.tbaOnly := true;
	theFilter.transhipOnly := false; 
	theFilter.plannedToShip := false; 
	app.myQAFilter.qryTerminalTIs(theFilter, app.myPassport);
	self.assertTrueMsg( theFilter.allQryTrackedItems.size = 2 ," Should be just 2 for the TBA unplanned");
	
	//Now plan the two TBAs to the slots
	create moveController transient;
	moveController.setMyTrackedItem(tba5);
	moveController.setMyToPrimaryLocation(tbaReqslots[1]);
	moveController.setMoveMode(PLANNING_MODE);	
	moveController.isSystemMove := true;
	moveController.mySlotRequest := tbaReqslots[1].CM_SlotController.mySlotRequestLoad;
	moveController.setMyWorkListEntry(moveController.mySlotRequest.allWorkListEntries.first);
	app.myTrxUA.trxUpdateWLEAssignTI(moveController, app.myPassport);
	delete moveController;
	
	create moveController transient;
	moveController.setMyTrackedItem(tba6);
	moveController.setMyToPrimaryLocation(tbaReqslots[2]);
	moveController.setMoveMode(PLANNING_MODE);	
	moveController.isSystemMove := true;
	moveController.mySlotRequest := tbaReqslots[2].CM_SlotController.mySlotRequestLoad;	
	moveController.setMyWorkListEntry(moveController.mySlotRequest.allWorkListEntries.first);
	app.myTrxUA.trxUpdateWLEAssignTI(moveController, app.myPassport);
	delete moveController;
	
	//Check TBA UNPLANNED again
	app.myQAFilter.qryTerminalTIs(theFilter, app.myPassport);
	self.assertTrueMsg( theFilter.allQryTrackedItems.isEmpty ," Should be no unplanned TBAs now");
	
	//ok have my load and discharge jobs now
	//load to ops
	self.loadAllJobsToOps(voyage, true);	
	
	//now move the two pre-notes on-site, they should automatically match, then link and replace the TBAs
	
	self.move(loadTi5, bs.getLocationsController);
	self.assertEqual(loadTi5.myPrimaryActualLocation, bs.myLocationsController);
	self.setCargoReadyToShip(loadTi5);
	self.deleteStops(loadTi5); 
	self.assertTrueMsg( loadTi5.myMatchedTBA = tba5, "loadTi5 failed to auto match to tba5 during move onsite");
	
	self.move(loadTi6, bs.getLocationsController);
	self.assertEqual(loadTi6.myPrimaryActualLocation, bs.myLocationsController);
	self.setCargoReadyToShip(loadTi6);
	self.deleteStops(loadTi6);
	self.assertTrueMsg( loadTi6.myMatchedTBA = tba6, "loadTi6 failed to auto match to tba6 during move onsite");
	
	//////////////////////////////////////////////////////////
	// wle has turned green in Voyage Job OPs so now
	// do the equivalent of call SHP_VoyageOperationsForm::mnuAssignToIntendedTBA_click to replace the tba with its linked ti here.....
	
	pxyTI := app.createUpdateProxy(loadTi5).CM_TrackedItem;
	pxyTI.setFromTBAMatch();
	while true do
		app.myTrxUA.trxUpdateTrackedItemFromTBA(pxyTI, null, TI_UPDMODE_NORMAL, loadTi5.myMatchedTBA, app.myPassport);
		if app.myPassport.trxCompletedOK then
			break;
		elseif app.myPassport.noErrors then
			app.myPassport.warningsAcknowledged	:= true;
			continue;
		endif;
		break;
	endwhile;
	delete pxyTI;
	
	pxyTI := app.createUpdateProxy(loadTi6).CM_TrackedItem;
	pxyTI.setFromTBAMatch();
	while true do
		app.myTrxUA.trxUpdateTrackedItemFromTBA(pxyTI, null, TI_UPDMODE_NORMAL, loadTi6.myMatchedTBA, app.myPassport);
		if app.myPassport.trxCompletedOK then
			break;
		elseif app.myPassport.noErrors then
			app.myPassport.warningsAcknowledged	:= true;
			continue;
		endif;
		break;
	endwhile;
	delete pxyTI;
	
	self.addMachineRule( bs, crane.CM_Crane.transferArea, RTMoveMethod_23); //simple single straddle moves
	self.addMachineRule( crane.CM_Crane.transferArea, bs, RTMoveMethod_23); 
	
	// Create Queues
	foreach job in jobs do
		foreach request in job.allRequests do
			foreach wle in request.allWorkListEntries do
				if wle.CM_VoyageWLE.myRequest.CM_SlotRequest.isLoad then
					wles.add(wle);
					if wle.isPlanned then // the real cargo that were ex-TBAs will be planned by now, the others are RT
						self.queueWLE(wle);
					else
						self.autoplanWLE(wle);
					endif;
				else
					wles.add(wle);
					self.queueWLE(wle);
				endif;

			endforeach;
		endforeach;
	endforeach;
	
	// workJob using straddle
	self.deleteMachine("UTS1");
	self.deleteRTDevice("91");
	create tas transient;
	tas.add(bs.id); 
	tas.add(yardIC.id); 
	tas.add(crane.CM_Crane.transferArea.id); 
	self.addStraddle("UTS1", 91, tas, null);
	straddle := self.getMachine("UTS1");
	assertNotNull(straddle);
	if craneQueue &lt;&gt; null then
		beginTransaction;
		straddle.addToQueue(craneQueue, true, 0); //add straddle to crane queue
		commitTransaction;
	endif;
	delete tas;
	
	app.isRTApp:=true;  
	self.machineLogon(straddle);
	// Use Lander to move to ship
	create agent transient;
	agent.setDoNotShowMsgBox(true);

	looper := 1;
	foreach wle in wles do
		if wle.isReceipt and wle.job.isVoyageJob then 
			//crane := wle.job.CM_VoyageJob.getJobCrane();
			self.machineAcceptTask(straddle, wle.allRTQueueEntries.first.allTasks.first);
			self.machineCraneActionPickup(straddle, dischargeTi, ti4);
			self.machinePickup(straddle);			
			self.machineSetdownTask(straddle, wle.allRTQueueEntries.first.allTasks.last, bs.id);	
		else
			if wle.myTrackedItem = null or wle.myTrackedItem.isRRP then
				self.machineAcceptSpecifiedTask(straddle, wle.allRTQueueEntries.first);
				self.machineDirector(straddle, theLoadTis[looper]);
				self.machineSetdownTask(straddle,wle.allRTQueueEntries.last.allTasks.last , crane.CM_Crane.transferArea.id);
				agent.moveTI( theLoadTis[looper], null, slots.first, wle, true, 0, 0, null );
				looper := looper+1;
			else
				self.machineAcceptSpecifiedTask(straddle, wle.allRTQueueEntries.first);
				self.machinePickup(straddle);
				self.machineSetdownTask(straddle,wle.allRTQueueEntries.last.allTasks.last , crane.CM_Crane.transferArea.id);
				agent.moveTI( wle.myTrackedItem, null, slots.first, wle, true, 0, 0, null );
			endif;
			self.assertNoTrxErrorsOrWarnings();
			self.assertTrue(wle.myTrackedItem.isOnShip);
		endif;
		
	endforeach;	
	
	self.assertTrue( dischargeTi.myPrimaryActualLocation.isYardLocation);
	self.assertTrue(  theLoadTis[1].myPrimaryActualLocation.isVoyageController);
	
	self.assertEqual( theLoadTis[1].myPrimaryActualLocation, slots[1]);
	self.assertTrue( theLoadTis[1].allQueuedFutureMoves.isEmpty);
	// check txns created correctly for the following
	self.checkTIForTxnOfType(dischargeTi, TRANS_TYPE_REC_SHIP);			
	self.checkTIForTxnOfType(dischargeTi, TRANS_TYPE_WHARFAGE);			
	self.checkTIForTxnOfType(theLoadTis[1], TRANS_TYPE_REL_SHIP);				
	self.checkTIForTxnOfType(theLoadTis[1], TRANS_TYPE_WHARFAGE);				
	
epilog
	app.isRTApp:=false;  
	delete jobs;
	delete slots;
	delete wles;
	delete tas;	
	delete agent;
	delete theLoadTis;
	delete locations;
	self.disableAllYA(false);
	delete tmpLoadCC;
	delete editions;
	delete relReqslots;
	delete tbaReqslots;
	delete pxyTI;
	delete theFilter;
	delete moveController;
end;</source>
        <text>&lt;?xml version="1.0"?&gt;
&lt;UT_Additional&gt;
  &lt;Categories&gt;
    &lt;Category CanDelete="true"&gt;Fails1006&lt;/Category&gt;
  &lt;/Categories&gt;
&lt;/UT_Additional&gt;</text>
    </JadeMethod>
    <JadeMethod name="tVoyStopReceive" id="1be50a7f-d7d4-4a92-a5f8-5ada3b16191c">
        <source>tVoyStopReceive();
/*

Purpose: Cargo Stop receiving for specific operator voyage			

Date		Who		Reason
11/04/2014	cnwma1	Initial creation
// 12 May 2016	cnwns1	TFS 488 - Multi Timezone Support
// 10 Sep 2019	cnwrs1	TFS 46030
*/
constants
	VoyCode	 = "CAI666";
	ShipCode = "CAI";
	TRK		 = "TT123";
	CNTR	 = "FSCU6681955";
	
vars
	pxyVoyage,
	voyage 			: CM_Voyage;
	opreator 		: CM_Operator;
	vvr				: CM_VehicleVisitRecord;
	gate 			: CM_Gate;
	gte 			: CMGTE_Entity;
	earlyTS,
	cutoffTS 		: TimeStamp;
	voyageCutoff 	: CM_ReceivalCutoffVoyage;
	conflictManager : CMIF_HMS_ConflictsManager;
	isDoClearanceCheck : Boolean;
begin
	isDoClearanceCheck := self.getMyTerminal.myHarbour.isDoClearanceCheck;
	self.setHarbourIsDoClearanceCheck(false);
	gate := self.getGate(self.getProfileSetting(UT_Profile.P_DGATE).asString);
	opreator := self.getOperator("APL");
	
	//Delete Voyage
	self.deleteVoyage(VoyCode);
	
	// Add Voyage
	voyage := self.addVoyageWithContainerStructur(VoyCode, ShipCode, opreator.code.asStringJMT, self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString);
	self.assertNotNull(voyage);
		
	beginLoad;
	pxyVoyage:=voyage.pxyCreateUpdateProxy();
	endLoad;
	
	create voyageCutoff transient;
	earlyTS	:= app.actualTimeServer;// 12 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	earlyTS:=earlyTS.addDays(-7);
	cutoffTS:= app.actualTimeServer;// 12 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	cutoffTS:=cutoffTS.addDays(-1);
	voyageCutoff.setProxy("OPCUTOFF", cutoffTS, earlyTS, pxyVoyage, opreator, 
							null, 	//04/03/2025	navkc1 JIRA Story MTN-34227
							null,  	//04/03/2025	navkc1 JIRA Story MTN-34227
							null,null,null,null,null);
	
	//epr par 36705 2/9/15 operator voyage stops replaced with cutoffs
	app.myTrxUA.trxUpdateVoyage(true,false,pxyVoyage,conflictManager,null,false,app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
	self.assertEqual(voyage.allReceivalCutoffs.size,1);
	
	deleteVehicle(TRK);
	deleteContainer(CNTR);
	
	self.opts.addAssoc("Voyage", VoyCode);
	vvr := self.addVehicleVisitRecord(TRK,"MA","MO",gate.name.asStringJMT);
	self.assertNotNull(vvr);
	
	self.clearExpectedTrxErrors();
	self.expectedTrxErrors.add(ERR_OP_CARGO_REL_HALT);
	
	gte := self.createGateEntity(vvr,"CONT", CNTR,"2200","APL","GENL", 1);
	self.assertNoTrxErrorsOrWarnings();
	
	self.clearExpectedTrxErrors();
	app.myTrxUA.trxUpdateVVRCancel(vvr,"Stop Receving for APL at AMA666",app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
epilog
	self.setHarbourIsDoClearanceCheck(isDoClearanceCheck);
	delete voyageCutoff;
	delete pxyVoyage;
end;
</source>
    </JadeMethod>
    <JadeMethod name="tVoyagesInwardsExtCodeAutoSet" id="04a3b2df-13c0-48cf-9114-460d22766145">
        <updating/>
        <source>tVoyagesInwardsExtCodeAutoSet() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
19 July 2024	navlw1	ChangeRequest 63839: NSW | OnePort - Uniqueness of Inward and External Code 

*/

vars
	terminal 	: CM_Terminal;
	voyage 		: CM_Voyage;
	myRoot		: CM_Root;
begin

	myRoot := self.getRoot();
	self.assertNotNullMsg(myRoot,"myRoot is null");
	
	foreach terminal in myRoot.allTerminals discreteLock do
		foreach voyage in terminal.allVoyagesByCode discreteLock do
			self.assertFalseMsg(voyage.inwardCode &lt;&gt; null and voyage.inwardCodeAuto &lt;&gt; null, "both inwards codes should not be set " &amp; voyage.code);
			self.assertFalseMsg(voyage.voyageCodeExternal &lt;&gt; null and voyage.voyageCodeExternalAuto &lt;&gt; null, "both external codes should not be set " &amp; voyage.code);
		endforeach;
	endforeach;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="uBuildScanPlanVoyage" id="79b251e6-77b8-4c65-8684-d405f912af1c">
        <source>uBuildScanPlanVoyage();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 September 2020	jlgndl1	Initial creation	TFS 49963

*/

constants

	VesselCode : String = "SCANPLAN";  // existing vessel set up for scan plan testing with a variety of cell confiigurations
	Voyage1 : String = "SCP1";
	BlockStack : String = "49963";
	BaseCargoId : String = "UTSC201";

vars

	vessel : CM_Vessel;
	voyage : CM_Voyage;
	bs : CM_BlockStack;
	
	bay : CM_BayVoyage;
	slot : CM_SlotController;
	index : Integer;
	ti : CM_TrackedItem;
	tiId : String;
	operator : CM_Operator;
	commodity : CM_Commodity;
	commodities : StringArray;
	commStr : String;
	commIndex : Integer;
	contCargoType : CM_CargoType;
	isoType : CM_ISOType;
	isoTypes20 : StringArray;
	isoTypes40 : StringArray;
	isoStr : String;
	isoIndex : Integer;
	imexStatus : Integer;
	bayIndex : Integer;
	dischargeSlots : CM_SlotControllerArray;
	tmpLoadCC : CMIF_LoadColorCode;
	voyageJob : CM_VoyageJob;
	loadSlots : CM_SlotControllerArray;
	robSlots : CM_SlotControllerArray;
	dlrSlots : CM_SlotControllerArray;
	sobSlots : CM_SlotControllerArray;
	sobdlrIndex : Integer;
	voyageLoadJob : CM_VoyageJob;
	voyageDlrDischJob : CM_VoyageJob;
	voyageDlrLoadJob : CM_VoyageJob;
	size : Integer;
	slotIndex : Integer;
	slotsFrom : CM_SlotControllerArray;
	slotsTo : CM_SlotControllerArray;
	allObjectEditions : CM_ObjectByOidEditionDict;
	voyageSobDischJob : CM_VoyageJob;
	voyageSobLoadJob : CM_VoyageJob;
	
begin

	create dischargeSlots transient;
	create loadSlots transient;
	create robSlots transient;
	create dlrSlots transient;
	create sobSlots transient;
	create slotsFrom transient;
	create slotsTo transient;
	
	write "Starting... " &amp; app.actualTimeAppServer.String;

	//clean-up pre-existing
	voyage := self.getVoyage( Voyage1 ); 
	
	if voyage &lt;&gt; null then
		write "Deleting (" &amp; voyage.allOnshipTIsByIdCargoType.size.String &amp; ") On Ship Cargo... " &amp; app.actualTimeAppServer.String;
		foreach ti in voyage.allOnshipTIsByIdCargoType do
			self.deleteContainer( ti.id );
		endforeach;
		write "Deleting (" &amp; voyage.allOnsiteTIsByIdCargoType.size.String &amp; ") On Site Cargo... " &amp; app.actualTimeAppServer.String;
		foreach ti in voyage.allOnsiteTIsByIdCargoType do
			self.deleteContainer( ti.id );
		endforeach;
	endif;
	write "Deleting Voyage... " &amp; app.actualTimeAppServer.String;
	self.deleteVoyage(Voyage1);
	write "Deleting Terminal Area... " &amp; app.actualTimeAppServer.String;
	self.deleteTerminalArea(BlockStack);

	vessel := app.myRoot.allVessels.getAtKey( VesselCode );
	//create new voyage
	write "Creating Voyage... " &amp; app.actualTimeAppServer.String;
	voyage := self.addVoyageWithContainerStructur(Voyage1, VesselCode, self.getProfileSetting(UT_Profile.P_OPERATOR).asString, self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString);	
	
	bs := self.addBlockStack(BlockStack, 2000, null);
	operator := app.myRoot.allOperators.getAtKey( voyage.myOperator.code );
	contCargoType := app.myRoot.allCargoTypesById.getAtKey( TI_CargoType_Container );
	
	create commodities transient;
	foreach commodity in app.myRoot.allCommodities do
		if commodity.colour = 0 or commodity.colour = 16777215 then
			continue;
		endif;
		if commodity.isNotAvailableForEntry then
			continue;
		endif;
		if not commodity.allCargoTypes.includes( contCargoType ) then
			continue;
		endif;
		if commodity.hasTemp or commodity.requiresPower then
			continue;
		endif;
		commodities.add( commodity.code );
	endforeach;
	
	create isoTypes20 transient;
	create isoTypes40 transient;
	foreach isoType in app.myRoot.allISOTypes do
		if isoType.myISOTypeGroup &lt;&gt; null and ( isoType.myISOTypeGroup.colour = 0 or isoType.myISOTypeGroup.colour = 16777215 ) then
			continue;
		endif;
		if isoType.isNotAvailableForEntry then
			continue;
		endif;
		if not isoType.is20ftLong then
			continue;
		endif;
		if isoType.isReefer then
			continue;
		endif;
		isoTypes20.add( isoType.code );
	endforeach;
	foreach isoType in app.myRoot.allISOTypes do
		if isoType.myISOTypeGroup &lt;&gt; null and ( isoType.myISOTypeGroup.colour = 0 or isoType.myISOTypeGroup.colour = 16777215 ) then
			continue;
		endif;
		if isoType.isNotAvailableForEntry then
			continue;
		endif;
		if not isoType.is40ftLong then
			continue;
		endif;
		if isoType.isReefer then
			continue;
		endif;
		isoTypes40.add( isoType.code );
	endforeach;
	
	
	
	//fill the ship with an assortment of 20's
	write "Creating On Ship Cargo... " &amp; app.actualTimeAppServer.String;
	foreach bay in voyage.myCellularVoyageStructure.allBayVoyagesById do
		bayIndex := bayIndex + 1;
		if bay.id.Integer = 3 then
			imexStatus := TI_IMEX_STATUS_REMAINONBOARD;
		elseif bay.id.Integer.isOneOf(7,15) then
			imexStatus := TI_IMEX_STATUS_EXPORT;
		elseif bay.id.Integer.isOneOf(17,21) then
			//backend 40s
			continue;
		elseif bay.id.Integer = 27 then
		//	Load slots
			foreach slot in bay.allSlotControllersByOrdinal discreteLock do
				if slot.mySlotDefnVoyage.unavailable then
					continue;
				endif;
				loadSlots.add( slot );
			endforeach;
			continue;
		elseif bay.id.Integer = 29 then
		//	SOB and DLR slots
			foreach slot in bay.allSlotControllersByOrdinal discreteLock do
				if slot.mySlotDefnVoyage.unavailable then
					continue;
				endif;
				sobdlrIndex := sobdlrIndex + 1;
				if sobdlrIndex.isOdd then
					dlrSlots.add( slot );
				else
					sobSlots.add( slot );
				endif;
			endforeach;
			continue;
		else
			imexStatus := TI_IMEX_STATUS_IMPORT;
		endif;
		write "Bay " &amp; bay.id.String &amp; "... (" &amp; bay.allSlotControllersByOrdinal.size.String &amp; ")" &amp; app.actualTimeAppServer.String;
		foreach slot in bay.allSlotControllersByOrdinal discreteLock do
			if slot.mySlotDefnVoyage.unavailable then
				continue;
			endif;
			index := index + 1;
			commIndex := index mod commodities.size;
			if commIndex = 0 then
				commStr := commodities.last;
			else
				commStr := commodities[ commIndex ];
			endif;
			
			if bay.id.Integer.isOneOf(15,19) then
				//front end 40s
				isoIndex := index mod isoTypes40.size;
				if isoIndex = 0 then
					isoStr := isoTypes40.last;
				else
					isoStr := isoTypes40[ isoIndex ];
				endif;
			else
				isoIndex := index mod isoTypes20.size;
				if isoIndex = 0 then
					isoStr := isoTypes20.last;
				else
					isoStr := isoTypes20[ isoIndex ];
				endif;
			endif;
			
			tiId := BaseCargoId &amp; index.padLeadingWith('0',4);
			ti := self.addContainerAtLocation( tiId, operator, isoStr, commStr, imexStatus, slot );
			if imexStatus = TI_IMEX_STATUS_IMPORT then
				dischargeSlots.add( slot );
			elseif imexStatus = TI_IMEX_STATUS_REMAINONBOARD then
				robSlots.add( slot );
			endif;
		endforeach;
		
	endforeach; 
	
	write "Creating Discharge jobs... " &amp; app.actualTimeAppServer.String;
	
	self.markSlotsAsDischargeCC(dischargeSlots, tmpLoadCC, CM_SlotRequest.Attribute_ColourCode);
	voyageJob := self.addVoyageJob(voyage, "CRN1", dischargeSlots, true);
	self.assertNotNull(voyageJob);
	

	write "Creating Load jobs... " &amp; app.actualTimeAppServer.String;
	delete tmpLoadCC;
	create tmpLoadCC transient;
	tmpLoadCC.overrideMoveType := true;
	tmpLoadCC.myDischargePort := app.myRoot.allPorts["NZAKL"];
	tmpLoadCC.myCommodityGroup := app.myRoot.allCommodityGroups["GEN"];
	self.markSlotsAsLoadJob( loadSlots, tmpLoadCC );
	self.markSlotsAsLoadCC( loadSlots, tmpLoadCC, CM_SlotRequest.Attribute_D20);
	voyageLoadJob := self.addVoyageJob(voyage, "CRN1", loadSlots, false);
	assertTrue(voyageLoadJob &lt;&gt; null);
	
	// create and plan the load containers to the voyage
	size := loadSlots.size;
	foreach slotIndex in 1 to size reversed do
		index := index + 1;
		tiId := BaseCargoId &amp; index.padLeadingWith('0',4);
		ti := self.addContainerAtLocation( tiId, operator, "2200", "GENL", TI_IMEX_STATUS_EXPORT, bs.myLocationsController );
		beginTransaction;
		voyageLoadJob.updateReleaseTI( ti );
		commitTransaction;
		self.setCargoReadyToShip( ti );
		self.deleteStops( ti );
		self.planItemBackToShip( ti, loadSlots[slotIndex]);
	endforeach;
	
	
	//DLRS
	write "Creating DLR jobs... " &amp; app.actualTimeAppServer.String;
	
	slotsFrom.clear();
	slotsTo.clear();
	foreach slot in robSlots reversed do
		slotsFrom.add( slot );
		if slotsFrom.size = 6 then
			break;
		endif;
	endforeach;
	
	foreach slot in dlrSlots reversed do
		slotsTo.add( slot );
		if slotsTo.size = 6 then
			break;
		endif;
	endforeach;

	// colour code the discharge DLR slots
	self.markSlotsAsDischargeCC(slotsFrom, tmpLoadCC, CM_SlotRequest.Attribute_D20);
	self.markSlotsAsDischargeCC(slotsFrom, tmpLoadCC, CM_SlotRequest.Attribute_DLR);
	voyageDlrDischJob := self.addVoyageJob(voyage, "CRN1", slotsFrom, true);
	assertTrue(voyageDlrDischJob &lt;&gt; null);
	
	// colour code the load DLR slots
	self.markSlotsAsLoadJob(slotsTo, tmpLoadCC);
	self.markSlotsAsLoadCC(slotsTo, tmpLoadCC, CM_SlotRequest.Attribute_D20);
	self.markSlotsAsLoadCC(slotsTo, tmpLoadCC, CM_SlotRequest.Attribute_DLR);
	voyageDlrLoadJob := self.addVoyageJob(voyage, "CRN1", slotsTo, false);
	assertTrue(voyageDlrLoadJob &lt;&gt; null);
	
	// link the DLR slots
	create allObjectEditions transient;
	foreach slot in slotsFrom do
		allObjectEditions.add(slot);
	endforeach;
	foreach slot in slotsTo do
		allObjectEditions.add(slot);
	endforeach;
	app.myTrxUA.trxUpdateSlotReqLinkSOBDLR2(slotsFrom, slotsTo, allObjectEditions, true, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	delete allObjectEditions;
	


	write "Creating SOB jobs... " &amp; app.actualTimeAppServer.String;

	slotsFrom.clear();
	slotsTo.clear();
	foreach slot in robSlots do
		slotsFrom.add( slot );
		if slotsFrom.size = 6 then
			break;
		endif;
	endforeach;
	
	foreach slot in sobSlots do
		slotsTo.add( slot );
		if slotsTo.size = 6 then
			break;
		endif;
	endforeach;

	// colour code the SOB discharge slots
	self.markSlotsAsDischargeCC(slotsFrom, tmpLoadCC, CM_SlotRequest.Attribute_D20);
	self.markSlotsAsDischargeCC(slotsFrom, tmpLoadCC, CM_SlotRequest.Attribute_SOB);
	voyageSobDischJob := self.addVoyageJob(voyage, "CRN1", slotsFrom, true);
	assertTrue(voyageSobDischJob &lt;&gt; null);
	
	// colour code the SOB load slots
	self.markSlotsAsLoadJob(slotsTo, tmpLoadCC);
	self.markSlotsAsLoadCC(slotsTo, tmpLoadCC, CM_SlotRequest.Attribute_D20);
	self.markSlotsAsLoadCC(slotsTo, tmpLoadCC, CM_SlotRequest.Attribute_SOB);
	voyageSobLoadJob := self.addVoyageJob(voyage, "CRN1", slotsTo, false);
	assertTrue(voyageSobLoadJob &lt;&gt; null);
	
	// link the SOB slots
	create allObjectEditions transient;
	foreach slot in slotsFrom do
		allObjectEditions.add(slot);
	endforeach;
	foreach slot in slotsTo do
		allObjectEditions.add(slot);
	endforeach;
	app.myTrxUA.trxUpdateSlotReqLinkSOBDLR2(slotsFrom, slotsTo, allObjectEditions, true, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	delete allObjectEditions;
	
	
epilog

	delete commodities;
	delete isoTypes20;
	delete isoTypes40;
	delete dischargeSlots;
	delete loadSlots;
	delete robSlots;
	delete dlrSlots;
	delete sobSlots;
	delete slotsFrom;
	delete slotsTo;
	delete tmpLoadCC;
	delete allObjectEditions;

end;</source>
    </JadeMethod>
    <JadeMethod name="uCheckDLRSOBLOLOLinked" id="cc4432fe-af3e-4f22-8090-339a498e2616">
