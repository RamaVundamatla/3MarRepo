	commitTransaction;
	
	app.writeLog(method.qualifiedName &amp; " all Invoice Contract Rate Calculation Type converted", LogINFO);
	if _controller &lt;&gt; null then
		_controller.logEntry(" all Invoice Contract Rate Calculation Type converted") ;
	endif;
	
	self.addScriptRun(method.name);
epilog
	delete objArr;
end;</source>
