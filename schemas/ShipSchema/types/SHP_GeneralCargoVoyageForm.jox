    <JadeMethod name="removeObject" id="ac4f9ce0-1702-4d99-a198-e344bc49a82d">
        <source>removeObject(_obj : CM_Object);
//--------------------------------------------------
// Created:	07 February 2006 By: cnwgd1
//--------------------------------------------------
vars
	idx : Integer;
begin
	
	if (not self.allNotableObjects.includes(_obj)) then
		return;
	endif;
	
	if self.tblNNCargo.findObjectInRow(_obj, idx) then
		if idx = self.tblNNCargo.row then
			self.tblNNCargoInfo.rows := self.tblNNCargoInfo.fixedRows;
		endif;
		self.tblNNCargo.removeItem(idx);
	endif;

	if self.tblPlanned.findObjectInRow(_obj, idx) then
		if idx = self.tblPlanned.row then
			self.tblPlannedInfo.rows := self.tblPlannedInfo.fixedRows;
		endif;	
		self.tblPlanned.removeItem(idx);
	endif;

	if self.tblNonPlanned.findObjectInRow(_obj, idx) then
		if idx = self.tblNonPlanned.row then
			self.tblNonPlannedInf.rows := self.tblNonPlannedInf.fixedRows;
		endif;		
		self.tblNonPlanned.removeItem(idx);
	endif;

	if self.tblOnShip.findObjectInRow(_obj, idx) then
		if idx = self.tblOnShip.row then
			self.tblOnShipInfo.rows := self.tblOnShipInfo.fixedRows;
		endif;			
		self.tblOnShip.removeItem(idx);
	endif;
			
	if self.tblOnSite.findObjectInRow(_obj, idx) then
		if idx = self.tblOnSite.row then
			self.tblOnSiteInfo.rows := self.tblOnSiteInfo.fixedRows;
		endif;				
		self.tblOnSite.removeItem(idx);
	endif;

	// display the sheet caption to include the number of items in the table
	self.displaySheetCaptions();
			
end;</source>
        <Parameter name="_obj" type="CM_Object"/>
    </JadeMethod>
    <JadeMethod name="resetCargoTypeLst" id="b9513c80-f838-4044-a465-c4088c00d63e">
        <source>resetCargoTypeLst();
//--------------------------------------------------
// Created:	02 February 2006 By: cnwgd1
//--------------------------------------------------
vars
	tmpCargoType	: CM_CargoType;
	tmpBOLType		: CM_BOLType;
	tmpBTDict		: CM_BOLTypesByIdDict;
	tmpCTDict		: CM_CargoTypesByIdDict;
	table			: CMUI_ListTable;
begin
	table := self.lstCargoTypes;
	
	table.allSelectedObjects.clear();
	table.rows := 0;
	table.zOrder(1);
	
	if self.optCargo.value then
		// populate the cargo type list with cargo types
		tmpCTDict := app.myRoot.allCargoTypesById;
		
		foreach tmpCargoType in tmpCTDict do
			// 31981 skip not-available-for-entry cargo types
			if tmpCargoType.isNotAvailableForEntry then
				continue;
			endif;
			table.addItemObject(tmpCargoType.abbreviation &amp; " - " &amp; tmpCargoType.description, tmpCargoType);
		endforeach;
		
		self.shtCargoTypes.caption := 'Cargo Types';
		
	else
		// populate the cargo type list with BOL types
		tmpBTDict := app.myRoot.allBOLTypes;
		
		foreach tmpBOLType in tmpBTDict do
			table.addItemObject(tmpBOLType.abbreviation &amp; " - " &amp; tmpBOLType.description, tmpBOLType);
		endforeach;	

		self.shtCargoTypes.caption := 'Bill Of Lading Types';
				
	endif;


end;</source>
    </JadeMethod>
    <JadeMethod name="resetOperatorLst" id="d2cd93bd-4096-4f7b-9521-e30573b79085">
        <source>resetOperatorLst();
//--------------------------------------------------
// Created:	02 February 2006 By: cnwgd1
//--------------------------------------------------
//2/09/2019 	JLGNS1	Bug 46164: LNX - Criteria of Voyage Cutoff Code Does Not Work
vars
	tmpOperator	: CM_Operator;
	idx 		: Integer;
	ls 			: Boolean;
	passport 	: CM_Passport;
	opDict 		: CM_OperatorByCodeDict;
	tmpVoyage	: CM_Voyage;
	failedDAC  :CM_DataAccessController;
begin

	passport := app.myPassport;
	self.lstOperators.zOrder(1);
	self.lstOperators.rows := 0;
	
	if self.myCurrentGCVoyage &lt;&gt; null then
		tmpVoyage := self.myCurrentGCVoyage.myVoyage;	
		opDict := tmpVoyage.allOperators;
	else
		opDict := app.myRoot.allOperators;
	endif;
	
	app.cmsBeginLoad(ls);
	foreach tmpOperator in opDict do
		if tmpOperator.canUserAccessSelf(null, failedDAC,  passport) then
			idx := self.lstOperators.addItemObject(tmpOperator.code &amp; " - " &amp; tmpOperator.description,tmpOperator);
			if tmpOperator.hasReceivalCutOffForVoyage(tmpVoyage,null) then //epr par 36705 2/9/15	//Bug 46164
				self.lstOperators.accessRow(idx).backColor := Red;
				self.lstOperators.accessRow(idx).foreColor := White;
			else
				self.lstOperators.accessRow(idx).backColor := White;
				self.lstOperators.accessRow(idx).foreColor := Black;
				
			endif;
		endif;
	endforeach;
	app.cmsEndLoad(ls);
	

epilog
	endLoad;
end;</source>
    </JadeMethod>
    <JadeMethod name="resetPortLst" id="e34f2249-b035-4902-aa4a-f3e5f0e735eb">
        <source>resetPortLst(_voyage : CM_Voyage);
//--------------------------------------------------
// Created:	02 February 2006 By: cnwgd1
//--------------------------------------------------
vars
	tmpPort : CM_Port;
	ls : Boolean;
	portCmbOrderDescrFirst : Boolean;
begin

	self.lstPorts.zOrder(1);
	self.lstPorts.rows := 0;
	
	if _voyage = null then
		return;
	endif;
		
	portCmbOrderDescrFirst := app.myRoot.getConfig(PortCmbOrderDescrFirst).Boolean;
	app.cmsBeginLoad(ls);
	foreach tmpPort in _voyage.allPorts discreteLock do
		self.lstPorts.addItemObject(tmpPort.getDisplayFormatted(portCmbOrderDescrFirst), tmpPort);
		//if self.lstPorts.rows = 16000 then
			//break;
		//endif;
	endforeach;
	app.cmsEndLoad(ls);
	
	
epilog
	endLoad;
end;</source>
        <Parameter name="_voyage" type="CM_Voyage"/>
    </JadeMethod>
    <JadeMethod name="resetTblData" id="dcf4bda2-d341-44f1-8532-7d3d0d8534bc">
        <source>resetTblData(_table : CM_DataTable input);
//--------------------------------------------------
// Created:	01 February 2006 By: cnwgd1
//--------------------------------------------------
vars
	tmpDef : EntTableDef;
begin
	
	_table.rows := _table.fixedRows;
	
	if _table = self.tblNNCargo then
		//Display Cargo fields only
		tmpDef := app.myController.getEntTableDef(ETDef_GCVoyageData);
		_table.setMyDataClass(CM_TrackedItem);	
	
	elseif self.optBOL.value and _table.myDataClass &lt;&gt; CM_BOL then
		//Display BOL fields only
		tmpDef := app.myController.getEntTableDef(ETDef_BOLDataGCVoyage);		
		_table.setMyDataClass(CM_BOL);

	elseif self.optCargo.value and _table.myDataClass &lt;&gt; CM_TrackedItem then
		//Display Cargo fields only
		tmpDef := app.myController.getEntTableDef(ETDef_GCVoyageData);		
		_table.setMyDataClass(CM_TrackedItem);
	endif;

	if tmpDef = null then
		tmpDef := _table.myEntTableDef;
	endif;
	
	if tmpDef = null then
		return;
	endif;
	
	if tmpDef.name = ETDef_GCVoyageData and self.xmlStrTI &lt;&gt; null then
		_table.setTblDataEntRowsFromXML(tmpDef, self.xmlStrTI);	
	elseif tmpDef.name = ETDef_GCVoyageBOLData and self.xmlStrBOL &lt;&gt; null then
		_table.setTblDataEntRowsFromXML(tmpDef, self.xmlStrBOL);	
	else
		_table.setTblDataEntRowsFromDef(tmpDef);
	endif;
				
end;</source>
        <Parameter name="_table" type="CM_DataTable" usage="input"/>
    </JadeMethod>
    <JadeMethod name="runImportTasks" id="edcafb34-c5af-4fe3-ac25-e79506ed39d3">
        <updating/>
        <source>runImportTasks() updating;
//----------------------------------------------------------------
//	Created:	15 February 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

	theResult : Integer;	//14 Jan 2020 NDL	TFS 46815
	
begin

	app.mousePointer := Window.MousePointer_HourGlass;
	
	if self.myCurrentGCVoyage = null then
		return;
	endif;
	
	//14 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
	while true do
	
		app.myTrxUA.trxRunImportTasksOnShip(self.myCurrentGCVoyage.myVoyage, app.myPassport);
	
		if app.myPassport.trxCompletedOK then
			break;
		else
			theResult := app.showErrorWarningDialog('Run Import Tasks', app.myPassport, ErrWarnMode_Update);
			if app.myPassport.noErrors and theResult = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		
		return;
		
	endwhile;

epilog
	global.beep;
	app.mousePointer := Window.MousePointer_Default;
end;</source>
    </JadeMethod>
    <JadeMethod name="setColorsFromController" id="27e47389-8baf-461c-9a75-39f361e92789">
        <updating/>
        <source>setColorsFromController(_colorControl: CM_ColorController) updating;
//--------------------------------------------------
// Created:	01 February 2006 By: cnwgd1
//--------------------------------------------------
vars

begin
	inheritMethod(_colorControl);
	self.setColorsForTable(self.tblNNCargo);
	self.setColorsForTable(self.tblNonPlanned);
	self.setColorsForTable(self.tblOnShip);
	self.setColorsForTable(self.tblOnSite);
	self.setColorsForTable(self.tblPlanned);
					
	self.frmSearch.backColor := self.backColor;
	self.fldMain.useSheetBackColors := true;
	self.fldMain.setDefaultSheetBackColors();
	self.fldMain.initSheetBackColors();	
	self.fldSearch.setDefaultSheetBackColors();
	self.fldSearch.initSheetBackColors();	
end;</source>
        <Parameter name="_colorControl" type="CM_ColorController"/>
    </JadeMethod>
    <JadeMethod name="setMyCurrentGCVoyage" id="5cfdd8db-2bf7-4c31-85e1-d8021217810c">
        <updating/>
        <source>setMyCurrentGCVoyage(_gcVoyage : CM_GeneralCargoVoyageStructure) updating;
//--------------------------------------------------
// Created:	01 February 2006 By: cnwgd1
//--------------------------------------------------
vars

begin
	self.myCurrentGCVoyage := null;
	self.clearNotableObjects();
	
	if global.isValidObject(_gcVoyage) then
		self.myCurrentGCVoyage := _gcVoyage;
	else
		self.setCaption(self.Caption);
		return;	
	endif;
	
	self.doRetrospectiveClick();

	self.displayVoyage();
	self.setCaption(_gcVoyage.getDisplayDetails(false)&amp; ' - ' &amp; self.Caption);

end;</source>
        <Parameter name="_gcVoyage" type="CM_GeneralCargoVoyageStructure"/>
    </JadeMethod>
    <JadeMethod name="setTableDataFromOrganiser" id="2100326b-144e-4cbc-9786-080eaf5c8566">
        <updating/>
        <source>setTableDataFromOrganiser(_theTable: CM_DataTable input) updating;
//--------------------------------------------------
// Created:	08 February 2006 By: cnwgd1
//--------------------------------------------------
vars
	idx,
	fixed,
	numRows : Integer;
	obj : Object;
	objSet : CM_ObjectSet;
begin
	// Save the entTableDef order to XLMStr
	self.updateXMLStrForTable(_theTable);	
	
	// Reset and reload tables.
	self.doSearch();

/*	// get all the objects displayed in the table
	create objSet transient;
	numRows := _theTable.rows;
	fixed := _theTable.fixedRows;
	foreach idx in fixed to numRows do
		obj := _theTable.accessRow(idx).itemObject.CM_Object;
		if obj &lt;&gt; null
		and global.isValidObject(obj) then
			objSet.add(obj);
		endif;
	endforeach;

	// clear the table and display the saved objSet
	_theTable.rows := _theTable.fixedRows;
	foreach obj in objSet do
		self.addItemObjectToTable(obj.CM_Object, _theTable);
	endforeach;

	_theTable.cnAdjustColumnWidths();
	_theTable.colourRows(self.colorRow1, self.colorRow2);	
	
epilog
	delete objSet;	*/
end;</source>
        <Parameter name="_theTable" type="CM_DataTable" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setToolbarSearch" id="9f1e3033-912e-411f-bfb7-ec75624d3d95">
        <source>setToolbarSearch();
//----------------------------------------------------------------------
//
//  Created by cnwsh3
//
//	Date 20 April 2006
//
//----------------------------------------------------------------------

vars

begin

	self.frmSearchToolbar.showCaptions := self.frmToolbar.showCaptions;
	
	//The extra numbers on the end is to allow for the bevelwidth on the frame
	self.fldSearch.top := self.frmSearchToolbar.top + self.frmSearchToolbar.height + 1;
	self.fldSearch.width := self.frmSearch.width - 4;
	self.fldSearch.height := self.frmSearch.height - self.frmSearchToolbar.height - 12;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setupForm" id="12479b64-ff29-41b9-a0d4-12935256a134">
        <updating/>
        <source>setupForm() updating;
//--------------------------------------------------
// Created:	01 February 2006 By: cnwgd1
//--------------------------------------------------
vars

begin
	// cnwrl1 236/02/2009 - (CCMS SFW 1047 - Totals Only Lists)
	// The user can access the summarise functionality only if they have at least view security role.
	self.bAllowSummaryDefn	:= app.myCurrentUserCan( self.myTerminal, PmSummaryDefView );
	
	inheritMethod();
	
	self.toolbarStyle := self.ToolbarStyle_ShowNoHide;	
	self.showToolbar := true;

	self.frmToolbar2.alignContainer := Frame.AlignContainer_None; 
	self.frmToolbar.alignContainer := Frame.AlignContainer_Top; 
	self.frmToolbar2.top := self.frmToolbar.height-1;
	//self.frmToolbar2.alignContainer := Frame.AlignContainer_Top; 
	self.frmToolbar2.visible := true;
	
	self.initTblData(self.tblOnShip);
	self.initTblData(self.tblNNCargo);
	self.initTblData(self.tblNonPlanned);
	self.initTblData(self.tblOnSite);
	self.initTblData(self.tblPlanned);	
	
	self.setNavigatorHeading(self.caption);

	self.cmbVoyage.isDisplayByName := self.myTerminal.getConfig(VesselComboByName).Boolean;
	
	self.chkImports.value := true;
	self.chkExports.value := true;
	// not use on this form, disable 
	self.btnSaveBase.enabled := false;
	
	self.shtNNCargo.visible := false;
	
	self.btnSummariseAll.enabled	:= self.optCargo.value;	// cnwrl1 24/02/2009 - (CCMS SFW 1047 - Totals Only Lists)
	
epilog
	
end;</source>
    </JadeMethod>
    <JadeMethod name="showCargoEnquiry" id="78f04992-9a56-40b2-a77c-23c645ac6df7">
        <source>showCargoEnquiry(_obj : CM_Object; _doEdit : Boolean);
//--------------------------------------------------
// Created:	02 February 2006 By: cnwgd1
//--------------------------------------------------
vars
	objArray : ObjectArray;
begin
	create objArray transient;
	objArray.add(_obj);
	if CM_TrackedItem.hasInstance(_obj) then
		self.myAssistant.showCargoEnquiryForTIs(_obj.CM_TrackedItem, objArray, self.myMasterMenuAction, _doEdit);
	
	elseif CM_BOL.hasInstance(_obj) then
		self.myAssistant.showCargoEnquiryForBOLs(_obj.CM_BOL, objArray, self.myMasterMenuAction, _doEdit);	
	endif;
	
epilog
	delete objArray;
end;</source>
        <Parameter name="_obj" type="CM_Object"/>
        <Parameter name="_doEdit" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="showHideSearcher" id="cd1a784d-8cfb-4ef3-b1b1-cd594b6d828a">
        <source>showHideSearcher();
//--------------------------------------------------
// Created:	02 February 2006 By: cnwgd1
//--------------------------------------------------
vars

begin
	self.btnSearch.enabled := false;

	if self.frmSearch.visible then
		self.frmSearch.visible := false;
		self.btnPrint.enabled := true;
		self.btnReportOptions.enabled := true;
		self.btnShowSearch.enabled := true;
		self.btnVoyageDefin.enabled := true;
		self.btnSelectAll.enabled := true;
		self.btnMoveIt.enabled := true;
		self.btnImportTasks.enabled := true;
		self.btnCreateCargo.enabled := true;
		self.btnDelete.enabled := true;		
	else

		self.btnDelete.enabled := false;		
		self.btnPrint.enabled := false;
		self.btnReportOptions.enabled := false;
		self.btnShowSearch.enabled := false;
		self.btnVoyageDefin.enabled := false;
		self.btnSelectAll.enabled := false;
		self.btnMoveIt.enabled := false;
		self.btnImportTasks.enabled := false;
		self.btnCreateCargo.enabled := false;
			
		self.btnSearch.enabled := true;
		self.frmSearch.visible := true;
		self.frmSearch.zOrder(1);
		self.frmSearch.centreWindow();
		//We're showing the searcher, move to the first row ready for new values.
		self.cmbVoyage.setFocus();
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="showVoyageCreateNewCargoForm" id="c62b90d4-0a72-4958-a4c4-4c0bfdb05d60">
        <source>showVoyageCreateNewCargoForm(_editCurrentObject : Boolean);
//--------------------------------------------------
// Created:	07 February 2006 By: cnwgd1
//--------------------------------------------------
vars
	table : CM_DataTable;
	theObject : Object;
	objArray : ObjectArray;
begin
	if self.myCurrentGCVoyage = null then
		app.msgBox(app.getErrorString(SHP_Please_Select_A_Voyage), app.getErrorString(SHP_Query_Error), MsgBox_OK_Only+MsgBox_Information_Icon);
		return;		
	endif;

	if  _editCurrentObject = false then 
		self.myAssistant.showVoyageCreateNewCargo(self.myCurrentGCVoyage.myVoyage, self.myMasterMenuAction, false,null, false);
	else

		table := self.getTopTable();
	
		create objArray transient;
		table.allSelectedObjects.copy(objArray);
	
		if objArray.isEmpty() then 
			return;
		endif;
		theObject := objArray[1];
		
		if theObject.isKindOf(CM_BOLIn) then 
			// will only show one object as form can only currently edit one BOL at a time.
			self.myAssistant.showVoyageCreateNewCargo(self.myCurrentGCVoyage.myVoyage, self.myMasterMenuAction, _editCurrentObject, theObject.CM_BOLIn, false);	
		elseif theObject.isKindOf(CM_TrackedItem) then
			self.myAssistant.showCargoEnquiryForTIs(theObject.CM_TrackedItem, objArray, self.myMasterMenuAction, _editCurrentObject);
		endif;
	endif;
	
epilog
	delete objArray;
end;</source>
        <Parameter name="_editCurrentObject" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="showWithObjectMode" id="3a4d7a55-6bad-4bbc-9f90-89b6e2fc468e">
        <updating/>
        <source>showWithObjectMode(_object: CM_GeneralCargoVoyageStructure; _doMode: Boolean) updating;
//--------------------------------------------------
// Created:	01 February 2006 By: cnwgd1
//--------------------------------------------------
vars

	failedDAC  :CM_DataAccessController;

begin
	inheritMethod(_object, _doMode);
	if _object &lt;&gt; null then
		if _object.canUserAccessSelf(null, failedDAC, app.myPassport) then
			self.myCurrentGCVoyage := _object;		
		endif;
	endif;	

	self.show();
end;</source>
        <Parameter name="_object" type="CM_GeneralCargoVoyageStructure"/>
        <Parameter name="_doMode" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="sysNotify" id="0c96efb3-12e6-42a5-a157-e8bbb031c998">
        <controlMethod name="Form::sysNotify"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>sysNotify(eventType: Integer; theObject: Object; eventTag: Integer) updating;
//--------------------------------------------------
// Created:	07 February 2006 By: cnwgd1
//--------------------------------------------------
vars

begin
	self.handleNotificationEvent(eventType, theObject, eventTag);
end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="tblContextMenu" id="5e8d3a48-ca3c-4466-86d9-07bb6cf59e09">
        <updating/>
        <source>tblContextMenu(table : Table input; conwin: Window input; _hide: Boolean; x: Integer; y: Integer):Boolean updating;
//--------------------------------------------------
// Created:	02 February 2006 By: cnwgd1
//--------------------------------------------------
// 16/06/2010	cnwcs5	par 24342 - no context menu for stops
vars
	xLeft 	: Real;
	yTop	: Real;
	obj		: Object;
	tmpTI	: CM_TrackedItem;
	useTaskForm : Boolean;
	
begin
	xLeft := x;
	yTop := y;
	
	//07 Oct 2015	NDL	Par 37011
	useTaskForm := self.myTerminal.getConfig(UseTaskFormCount).Boolean;

	conwin.windowToScreen(xLeft, yTop);
	self.screenToWindow(xLeft, yTop);   // convert x, y relative to form
	
	if _hide then
		self.mnuHideAdditionalInfo.caption := self.MNU_EXTRAINFO_HIDE;
	else
		self.mnuHideAdditionalInfo.caption := self.MNU_EXTRAINFO_SHOW;	
	endif;
	
	// cnwrl1 17/02/2009 - (CCMS SFW 1047 - Totals Only Lists) - start of coding
	self.mnuSummarise.visible	:= false;	// default this menu level to invisible, makes sub-menu invisible.
	// Summarise function is not available unless Cargo option is selected.
	if self.optCargo.value and self.bAllowSummaryDefn then
		self.mnuSummarise.visible			:= true;
		// the summarise selected is only enabled if something is actually selected.
		self.mnuSummariseSelected.visible	:=	self.myCurrentContextTbl &lt;&gt; null and
												not self.myCurrentContextTbl.allSelectedObjects.isEmpty;
	endif;
	// cnwrl1 17/02/2009 - (CCMS SFW 1047 - Totals Only Lists) - end of coding
	
	if table.row &gt; 0 then
		obj := table.accessRow(table.row).itemObject;
	
		self.mnuInspectObject.visible := app.isAllowedToInspect();		
		self.mnuInspectObject.userObject := obj;	
		self.mnuCargoEnquiry.userObject := obj;
	endif;
	
	if table.parent = self.splPlanned 
	or table.parent = self.splOnShip then	
		self.mnuDischarge.enabled	:= true;
	else
		self.mnuDischarge.enabled	:= false;
	endif;
	
	if table.parent = self.splOnSite then
		self.mnuLoad.enabled		:= true;
		self.buildHatchsMenu();
	else
		self.mnuLoad.enabled		:= false;
	endif;
	
	// set up the cargo menu and cargo sub menus----------------------------------
	
	self.mnuSetGrade.visible := false;
	self.mnuSetStops.visible := false;
	self.mnuTasksAdd.visible := false;
	self.mnuTasksComplete.visible := false;
	self.mnuTasksRemove.visible := false;
	self.mnuCargoTaskAdd.visible := false;	//07 Oct 2015	NDL	Par 37011
	self.mnuCargoTaskComplete.visible := false;	//07 Oct 2015	NDL	Par 37011
	self.mnuCargoTaskRemove.visible := false;	//07 Oct 2015	NDL	Par 37011
	self.mnuCargoTaskRemarks.visible := false;	//07 Oct 2015	NDL	Par 37011
	
	if CM_TrackedItem.hasInstance(obj) then
		tmpTI := obj.CM_TrackedItem;
		//epr par 32261 19/8/13
		self.myAssistant.menuSetGradeBuild(self.mnuSetGrade,self.mnuSetGradeSub,tmpTI);
	
		
		// par 24342 self.buildMnuStops(self.mnuSetStops, tmpTI);	
		self.mnuSetStops.userObject	:= tmpTI;	// par 24342
		self.mnuSetStops.visible 	:= true;	// par 24342
		self.mnuSetStops.enabled 	:= true;	// par 24342
		
		if useTaskForm then	//07 Oct 2015	NDL	Par 37011
			self.mnuCargoTaskAdd.visible := true;	//07 Oct 2015	NDL	Par 37011
			self.mnuCargoTaskComplete.visible := true;	//07 Oct 2015	NDL	Par 37011
			self.mnuCargoTaskRemove.visible := true;	//07 Oct 2015	NDL	Par 37011
			self.mnuCargoTaskRemarks.visible := true;	//07 Oct 2015	NDL	Par 37011
		else
			self.buildMnuTasksAdd(self.mnuTasksAdd, tmpTI);		
			self.buildMnuTasksComplete(self.mnuTasksComplete, tmpTI);		
			self.buildMnuTasksRemove(self.mnuTasksRemove, tmpTI);
		endif;
		self.mnuCargo.userObject := tmpTI; //&lt;-- tmpTI is used by sub menus click events
	endif;
	//------------------------------------------------------------------------------
	
	self.mnuColumnOrganiser.userObject := table;
	
	// cnwrd1 par #18244 22.10.08 start - for empty or trackeditem thumbnail table has no enttabledef
	if table.CM_DataTable.myEntTableDef = null then
		self.mnuColumnOrganiser.visible := false;
	else
		self.mnuColumnOrganiser.visible := true;
	endif;
	// cnwrd1 par #18244 22.10.08 end

	self.popupMenu(self.mnuContext, xLeft.Integer, yTop.Integer);

	return false;
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="conwin" type="Window" usage="input"/>
        <Parameter name="_hide" type="Boolean"/>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="tblDblClick" id="3a0ead56-011e-4164-8398-27c2ac04f5f2">
        <updating/>
        <source>tblDblClick(table: CM_DataTable input) updating;
//--------------------------------------------------
// Created:	02 February 2006 By: cnwgd1
//--------------------------------------------------
vars
	obj : Object;
begin
	if table.row &lt;= table.fixedRows and table.row &gt; 0 then
		table.resortTableByColumn(table.column);
		table.colourRows(self.colorRow1, self.colorRow2);
	elseif table.row &gt; table.fixedRows and table.row &lt;= table.rows then
		obj := table.accessRow(table.row).itemObject;
		if CM_TrackedItem.hasInstance(obj) then
			self.myAssistant.showCargoEnquiryForm(obj.CM_Object, self.myMasterMenuAction, true, false);
		elseif CM_BOL.hasInstance(obj) then
			self.showVoyageCreateNewCargoForm(true);
			// Lorcan Changed the form shown on a double click
			//self.myAssistant.showCargoEnquiryForm(obj.CM_Object, self.myMasterMenuAction, true, false);
		endif;
	endif;

end;</source>
        <Parameter name="table" type="CM_DataTable" usage="input"/>
    </JadeMethod>
    <JadeMethod name="tblNNCargoInfo_contextMenu" id="9ed119bd-0492-4386-bdae-5f85d2a9923d">
        <controlMethod name="Table::contextMenu"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblNNCargoInfo_contextMenu(table: Table input; conwin: Window input; mouse: Boolean; x: Integer; y: Integer):Boolean updating;
//--------------------------------------------------
// Created:	03 February 2006 By: cnwgd1
//--------------------------------------------------
vars

begin
	myCurrentContextTbl := table.CM_DataTable;
	return self.tblContextMenu(table, conwin, self.tblNNCargoInfo.visible, x, y);
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="conwin" type="Window" usage="input"/>
        <Parameter name="mouse" type="Boolean"/>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
