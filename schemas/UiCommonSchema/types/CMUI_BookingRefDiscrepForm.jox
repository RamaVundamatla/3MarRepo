    <JadeMethod name="sysNotify" id="488632cc-ed82-4a57-b78f-3141ae4242b7">
        <controlMethod name="Form::sysNotify"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>sysNotify(eventType: Integer; theObject: Object; eventTag: Integer) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
03 September 2009	cnwndl1	Initial creation	ccmS 1609 Par 20521

*/

vars

begin
	if (eventType = Object_Create_Event or eventType = Object_Update_Event) and 
	   (CMEVT_BookingRefDiscrep.hasInstance(theObject)) then
		self.handleEventNotification(eventType, theObject.CMEVT_BookingRefDiscrep, eventTag);
	endif;
	
	inheritMethod(eventType, theObject, eventTag);
end;


</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="tblDataAddItem" id="bc4bf93c-1ec7-40ee-b0ab-ea2ad79f5cdd">
        <source>tblDataAddItem( bookingDiscrep : CMEVT_BookingRefDiscrep ) protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
03 September 2009	cnwndl1	Initial creation	CCMS 1609 Par 20521

*/

vars

	rowIdx : Integer;
	entRow : EntTableRow;
	tableRowNames : StringArray;
	columnIdx : Integer;
	ventilation : String;
begin

	rowIdx := self.tblData.addItemObject( bookingDiscrep, bookingDiscrep.getAttributeStringForDefArray(self.tblData.allTblDataEntRows) );
	self.allTableObjects.add(bookingDiscrep);
	
	if bookingDiscrep.isClosed then
		// background has to be grey.
		self.tblData.accessRow(rowIdx).backColor := Grey;
	endif;
	
	if bookingDiscrep.hasDiscrepancies then
		create tableRowNames transient;
		bookingDiscrep.getRowsWithDiscrepencies( tableRowNames );
		foreach entRow in self.tblData.allTblDataEntRows do
			columnIdx := columnIdx + 1;			
			if tableRowNames.includes(entRow.name) then
				self.tblData.accessCell(rowIdx,columnIdx).foreColor := Red;
				self.tblData.accessCell(rowIdx,columnIdx).fontUnderline := true;
			endif;			
		endforeach;
	endif;
		
epilog
	delete tableRowNames;
end;</source>
        <access>protected</access>
        <Parameter name="bookingDiscrep" type="CMEVT_BookingRefDiscrep"/>
    </JadeMethod>
    <JadeMethod name="tblDataUpdateDisplay" id="e7b96861-62d3-4a87-ac51-913ecc4dc5ad">
        <source>tblDataUpdateDisplay( bookingDiscrep : CMEVT_BookingRefDiscrep ) protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
03 September 2009	cnwndl1	Initial creation	CCMS 1609 Par 20521

*/

vars

	rowIdx : Integer;
	entRow : EntTableRow;
	tableRowNames : StringArray;
	columnIdx : Integer;
	foundIt : Boolean;
	
begin

	if not self.allTableObjects.includes(bookingDiscrep) then
		return;
	endif;
	
	if tblData.fixedRows &gt;= tblData.rows then
		return;
	endif;

	foreach rowIdx in self.tblData.fixedRows + 1 to self.tblData.rows do
		if self.tblData.accessRow(rowIdx).itemObject = bookingDiscrep then
			foundIt := true;
			break;
		endif;
	endforeach;
	
	if not foundIt then
		return;
	endif;

	self.tblData.setCellText(rowIdx,1,bookingDiscrep.getAttributeStringForDefArray(self.tblData.allTblDataEntRows) );
	
	if bookingDiscrep.isClosed then
		// background has to be grey.
		self.tblData.accessRow(rowIdx).backColor := Grey;
	endif;
	
	if bookingDiscrep.hasDiscrepancies then
		create tableRowNames transient;
		bookingDiscrep.getRowsWithDiscrepencies( tableRowNames );
		foreach entRow in self.tblData.allTblDataEntRows do
			columnIdx := columnIdx + 1;
			if tableRowNames.includes(entRow.name) then
				self.tblData.accessCell(rowIdx,columnIdx).foreColor := Red;
				self.tblData.accessCell(rowIdx,columnIdx).fontUnderline := true;
			endif;
		endforeach;
	endif;
		
epilog
	delete tableRowNames;
end;</source>
        <access>protected</access>
        <Parameter name="bookingDiscrep" type="CMEVT_BookingRefDiscrep"/>
    </JadeMethod>
    <JadeMethod name="translateForm" id="93324c8c-f517-490a-b2b8-c3906ee1dced">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0017257, locale);
	btnEditBookRef.translateBubbleHelp(Xlat_0014533, locale);
	btnEditBookRef.translateCaption(Xlat_0014534, locale);
	btnEditRemarks.translateBubbleHelp(Xlat_0014535, locale);
	btnEditRemarks.translateCaption(Xlat_0011828, locale);
	btnEditTI.translateBubbleHelp(Xlat_0014536, locale);
	btnEditTI.translateCaption(Xlat_0014537, locale);
	btnExportCSV_BRD.translateBubbleHelp(Xlat_0013408, locale);
	btnExportCSV_BRD.translateCaption(Xlat_0013409, locale);
//	btnResolve.translateBubbleHelp(Xlat_0017258, locale);
	btnResolve.translateCaption(Xlat_0017259, locale);
	mnuAudit.translateCaption(Xlat_0011833, locale);
	mnuCloneItem.translateCaption(Xlat_0011834, locale);
	mnuEditBookingRef.translateCaption(Xlat_0014538, locale);
	mnuEditRemarks.translateCaption(Xlat_0011836, locale);
	mnuEditTI.translateCaption(Xlat_0014539, locale);
	mnuLocalContext.translateCaption(Xlat_0011838, locale);
end;</source>
    </JadeMethod>
    <JadeMethod name="validateOperatorSetup" id="9aa95e60-2c5e-4afe-bf7b-d2bbe3370444">
        <source>validateOperatorSetup(_operator : CM_Operator) protected;
/* ---------------------------------------------------------------------------
Created:     30 October 2009 by cnwrs2

Purpose:     P
        
Change Date	Who		Reason

------------------------------------------------------------------------------*/
vars

begin

	if _operator = null then
		return;
	endif;

	if _operator.allAttribForBookingRefDiscrep.isEmpty then
		app.msgBox( app.getErrorString1(OperatorNotSetForBookingDiscre, _operator.code), app.getErrorString(Operator_setup), MsgBox_OK_Only + MsgBox_Information_Icon);
	endif;


epilog

end;</source>
        <access>protected</access>
        <Parameter name="_operator" type="CM_Operator"/>
    </JadeMethod>
</GUIClass>
