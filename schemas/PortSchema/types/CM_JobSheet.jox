    <JadeMethod name="getOOWPosition" id="486fde80-cfad-4058-8615-75e247120046">
        <source>getOOWPosition(_job :CM_Job; _hideBoomHatchJobs :Boolean) : Integer;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
28 October 2008	cnwer1	Initial creation

*/

vars
	iter 	: Iterator;
	job 	: CM_Job;
	pos 	: Integer;
begin
	if not _hideBoomHatchJobs then
		return self.allJobsByOrder.indexOf(_job);
	endif;
	pos:=0;
	iter:=self.allJobsByOrder.createIterator;
	while iter.next(job) do
		if not job.isKindOf(CM_VoyageJob) then
			continue;
		endif;
		if job.CM_VoyageJob.isHatchLidJob then
			continue;
		endif;
		pos:=pos+1;
		if job = _job then
			return pos;
		endif;
	
	endwhile;
epilog
	delete iter;
end;</source>
        <Parameter name="_job" type="CM_Job"/>
        <Parameter name="_hideBoomHatchJobs" type="Boolean"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getPreviousJobInOrder" id="a304f5c7-719c-4806-b120-7beab46193d4">
        <source>getPreviousJobInOrder(_job : CM_Job) : CM_Job;
// ---------------------------------------------------------------------------
// Created:		03 April 2007 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	idx : Integer;
begin
	idx := self.allJobsByOrder.indexOf(_job);
	if idx &gt; 1 then
		return self.allJobsByOrder[idx-1];
	endif;
	
	return null;
end;</source>
        <Parameter name="_job" type="CM_Job"/>
        <ReturnType type="CM_Job"/>
    </JadeMethod>
    <JadeMethod name="getTotalItems" id="f3fba552-bab3-4c90-b6a9-1ce2e815e3e0">
        <source>getTotalItems() : Integer;
// ---------------------------------------------------------------------------
// Created:		01 May 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	aJob : CM_Job;
	aReq : CM_Request;
	tot : Integer;
begin
	foreach aJob in self.allJobsByOrder do
		foreach aReq in aJob.allRequests do
			tot := tot + aReq.allWorkListEntries.size;
		endforeach;
	endforeach;
	
	return tot;
end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
