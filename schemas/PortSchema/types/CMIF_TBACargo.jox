<Class name="CMIF_TBACargo" id="4ef5b2f1-c33f-4feb-83c7-4f1027f044f9">
    <superclass name="CMIF_PreNote"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="cmtrans"/>
    <JadeMethod name="actionForCreate" id="f521999b-078d-4061-8371-b9c0d262138d">
        <updating/>
        <source>actionForCreate(pProxy: CM_Object io; _passport: CM_Passport input): Boolean updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 October 2019	jlgmp6	Initial creation	TFS 45590

*/

vars
	defer, result: Boolean;
	lc : CM_LocationsController;
	h : Integer;
begin
	result := inheritMethod(pProxy, _passport);
	if not result then
		return result;
	endif;
	
	defer := _passport.useTIDictDeferUpdate; // TFS 47863
	_passport.useTIDictDeferUpdate := false; // TFS 47863 turn this off so that the TBA state sets the tba terminal
	// TFS 47863 set this here so that the move (below) does not change the state from TBA to onsite.
	self.myPersistentTrackedItem.changeState(TI_STATE_TBA, _passport); 
	_passport.useTIDictDeferUpdate := defer; // TFS 47863
	
	// Move TBA to default location
	if self.myTerminal&lt;&gt; null then
		self.myTerminal.findLocationFromString(self.myTerminal.getConfig(DefaultTBAYardLocation).String,true,lc,h); // TFS 45590
		
		if lc &lt;&gt; null then
			self.myPersistentTrackedItem.doForcedMove(lc,null,REAL_MODE,true,true,_passport);
		endif;
	endif;
	
	
epilog

end;</source>
        <Parameter name="pProxy" type="CM_Object" usage="io"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
