    <JadeMethod name="addFromOnSiteTI" id="f5085428-caa9-4126-9065-ea2dc75afd07">
        <source>addFromOnSiteTI(pTI : CM_TrackedItem) protected;
// ---------------------------------------------------------------------------
// Created:     27 February 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	self.createMenuActionSheet(NavObj_GTE_Out, pTI);
	
end;</source>
