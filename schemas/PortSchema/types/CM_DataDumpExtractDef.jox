    <JadeMethod name="pxyCreateExtractClass" id="4f7be660-1686-4c4e-945f-be2c6d89bf66">
        <source>pxyCreateExtractClass(_dumpClass: CM_DataDumpClass; _realFeatures: CM_DataDumpFeatureArray) : CM_DataDumpExtractClass;
// ---------------------------------------------------------------------------
// Created:     26 May 2003 by cnwsb1
// ---------------------------------------------------------------------------
vars
	cls : CM_DataDumpExtractClass;
	
begin
	create cls transient;
	cls.setProxy(_dumpClass, _realFeatures, null, null, null, null, null, null, null, null, null, null, null);
	self.allDataDumpExtractClasses.add(cls);
	
	return cls;
end;</source>
        <Parameter name="_dumpClass" type="CM_DataDumpClass"/>
        <Parameter name="_realFeatures" type="CM_DataDumpFeatureArray"/>
        <ReturnType type="CM_DataDumpExtractClass"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="daf6c387-accf-44d0-9476-81acb23af90b">
        <source>pxyCreateUpdateProxy(): SelfType;
// ---------------------------------------------------------------------------
// Created:     27 May 2003 by cnwsb1
// ---------------------------------------------------------------------------
// 20/04/2011	cnwmh5		PAR #27401 - Add code to handle prossible exceptions occurring when
//							trying to create the proxy

vars
	pxyDef : CM_DataDumpExtractDef;
	realClass : CM_DataDumpExtractClass;
	pxyClass : CM_DataDumpExtractClass;
	completedOK		: Boolean;
	
begin
	pxyDef := inheritMethod;
	
	foreach realClass in self.allDataDumpExtractClasses do
		pxyClass := realClass.pxyCreateUpdateProxy;
		pxyDef.allDataDumpExtractClasses.add(pxyClass);
	endforeach;
	
	pxyDef.myTerminal := self.myTerminal;
	pxyDef.ignoreDeletesFromUser := self.ignoreDeletesFromUser;	//07 Jan 2014	NDL	Par 33264
	
	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return pxyDef;
	
epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete pxyDef;
	endif;	
	
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="resetProxyLinkEditions" id="6ba618b3-6960-4620-867a-658893ee786f">
        <source>resetProxyLinkEditions();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 September 2021	navndl1	Initial creation	TFS 51997

*/

vars

	proxyLink : CM_ProxyLink;
	extClass :CM_DataDumpExtractClass;

begin

	proxyLink := app.myProxyManager.allReals[self];
	if proxyLink &lt;&gt; null then
		proxyLink.originalRealEdition := self.edition;
	endif;

	foreach extClass in self.allDataDumpExtractClasses do
		proxyLink := app.myProxyManager.allReals[extClass];
		if proxyLink &lt;&gt; null then
			proxyLink.originalRealEdition := extClass.edition;
		endif;
	endforeach;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setCommon" id="f329e52c-0e95-4be5-8a30-6540d9690360">
        <updating/>
        <source>setCommon(_proxyExtractDef : CM_DataDumpExtractDef) updating, protected;
// ---------------------------------------------------------------------------
// Created:     27 May 2003 by cnwsb1
// ---------------------------------------------------------------------------
begin
	_proxyExtractDef.raiseExceptionIfNotTransient(method);
	
	self.description         := _proxyExtractDef.description;
	self.extractFormat       := _proxyExtractDef.extractFormat;
	self.fileFolderName      := _proxyExtractDef.fileFolderName;
	self.edbConnectionString := _proxyExtractDef.edbConnectionString;
	self.edbUserName         := _proxyExtractDef.edbUserName;
	self.edbPassword         := _proxyExtractDef.edbPassword;
	self.edbServerName       := _proxyExtractDef.edbServerName;
	self.createSQLStatements := _proxyExtractDef.createSQLStatements;
	self.isActive            := _proxyExtractDef.isActive;
	self.edbMachineDSN       := _proxyExtractDef.edbMachineDSN;
	self.oidColumnName       := _proxyExtractDef.oidColumnName;

	if self.oidFormat &gt; 0 and  self.oidFormat &lt;&gt; _proxyExtractDef.oidFormat then //28/06/2010 cnwdz2 24811
		self.doChangeOIDFormat(_proxyExtractDef);
	endif;
	self.oidFormat           := _proxyExtractDef.oidFormat;
	self.sqlDatabaseName     := _proxyExtractDef.sqlDatabaseName;

	//28/06/2010 cnwdz2 24811
	if self.sqlServerVersion &lt;&gt; null and self.sqlServerVersion &lt;&gt; _proxyExtractDef.sqlServerVersion then //25/06/2010 cnwdz2 24557
		self.doChangeSQLServerVersion(_proxyExtractDef);
	endif;
	self.sqlServerVersion    := _proxyExtractDef.sqlServerVersion;
	self.definitionModified  := _proxyExtractDef.definitionModified;

	self.myTerminal := _proxyExtractDef.myTerminal;
	self.alertLimit	:= _proxyExtractDef.alertLimit;
	self.ignoreDeletesFromUser := _proxyExtractDef.ignoreDeletesFromUser;	//07 Jan 2014	NDL	Par 33264
end;</source>
        <access>protected</access>
        <Parameter name="_proxyExtractDef" type="CM_DataDumpExtractDef"/>
    </JadeMethod>
