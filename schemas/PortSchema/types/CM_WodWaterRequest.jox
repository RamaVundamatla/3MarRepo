    <JadeMethod name="getOccursDT" id="a87a8855-9d8e-4714-bda2-e0c5d3617567">
        <source>getOccursDT() : TimeStamp;
/*

Purpose:			// TFS 40747 

Parameters:			

Return Value:		

Date		Who		Reason
07 September 2018	jlgab1	Initial creation

*/

vars
	voyage : CM_Voyage;
begin

	if self.fromDateTime.isValid() then
		return self.fromDateTime;
	endif;
	
	voyage := self.getMyVoyageObject();
	if voyage &lt;&gt; null then
		return voyage.arrivedDT;
	endif;
	
	return self.createdTime;
epilog

end;</source>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
