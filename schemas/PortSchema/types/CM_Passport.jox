// ---------------------------------------------------------------------------
// Created:     12 December 2000 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	return self.allWarnings.isEmpty;

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="opsViewCreateBGP" id="1722bd61-810d-4d02-97e4-d8fe386f0313">
        <source>opsViewCreateBGP();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 Aug 2020 cnwma1 ChangeRequest 49758: MTN - Navis Smart Data API - Snapshot Data

*/

vars
	req 		: CMIF_OpsViewRequest;
//	bgpRequest 	: BGP_OpsViewWSRequest;
	objectInfo  : Any;
	oid : String;
	proxyActHistory : CM_EWSActivityOpsview;
	activityHistory : CM_ExternalWebServiceActivity;
	desc : String;
begin
	/*  // ### TFS 50669 27AUG2021 NAVAB1 WAS
	foreach req in self.allOpsViewRequests do
		create bgpRequest persistent;
		if req.myObject &lt;&gt; null then
			objectInfo := req.myObject;
		else
			objectInfo := req.oid;
		endif;
		bgpRequest.setRequestDetails(req.updateAction,req.updateType,objectInfo );											
		bgpRequest.causeEvent(BGP_Object.BGP_ActionRequest, false, null);
		objectInfo := null;
	endforeach;
	NOW */
	
	
	
	foreach req in self.allOpsViewRequests do
		if req.myObject &lt;&gt; null then
			req.myObject.CM_Object.createOpsViewEWSActivity(req.updateAction,req.updateType,req.myObject);
		else // DELETES - by OID vessel and ISOTYPE??? so no terminal
			oid := req.oid;
			desc := "OpsView POST (" &amp; req.updateAction &amp; " - " &amp; req.updateType &amp; ")";
			create proxyActHistory transient;
			proxyActHistory.initialiseActivity(desc, "OpsView",null, null, req.updateAction,req.updateType, false, oid );
			
			activityHistory := app.myUtilityCA.utlCreateEWSActivityHistory(proxyActHistory, app.myPassport);
			delete proxyActHistory;
		endif;
		
		
		objectInfo := null;
	endforeach;

	
epilog
	delete proxyActHistory;


end;</source>
    </JadeMethod>
    <JadeMethod name="opsViewCreateRequest" id="6f6dbd9a-9126-4659-a5d4-a6003628e762">
        <source>opsViewCreateRequest(_updateAction : Character; _updateType   : String;_term: CM_Terminal;_objectInfo :Any);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 Sep 2020 cnwma1 ChangeRequest 49906: MTN - Ops View External Webservice

*/

vars
	opsReq      : CMIF_OpsViewRequest;
	dict        : CMIF_OpsViewRequestDict;
	oid         : String;
begin
	if app.myPassport.isOpsViewEnabled(_term) then
		dict   := self.allOpsViewRequests;
		
		if _objectInfo.isKindOf(Object) then
			oid := _objectInfo.Object.getOidString;
		else
			oid := _objectInfo.String;
		endif;
		
		opsReq := dict.getAtKey(oid, _updateAction);
		
		if opsReq &lt;&gt; null then
			return;
		endif;
	
		create opsReq transient;
		opsReq.initialize(oid,_updateAction,_updateType,_objectInfo);
		app.myPassport.allOpsViewRequests.addNoDuplicates(opsReq,false);
	endif;
epilog

end;</source>
        <Parameter name="_updateAction" type="Character"/>
        <Parameter name="_updateType" type="String"/>
        <Parameter name="_term" type="CM_Terminal"/>
        <Parameter name="_objectInfo" type="Any"/>
    </JadeMethod>
    <JadeMethod name="raiseExIfDeferredUpdNotDone" id="f573c7f4-c730-4eba-ab80-e232a47445c4">
        <source>raiseExIfDeferredUpdNotDone() : Boolean;
// ---------------------------------------------------------------------------
// Created:     19 March 2004 by cnwrs2
//
// Purpose: 
// 28 May 2024 navma1	Bug 64224: MTN - DeadLocks Caused by Future Actors    
// 17 Mar 2025 navma1	MTN-34120 MTN | Dead Lock (1081) on CM_OfflineFutureActorParentDct
// ---------------------------------------------------------------------------
vars

begin

	if (not self.allTIsForDeferredUpdate.isEmpty) 	   or
	   (not self.allTITransactionsForDeferUpd.isEmpty) or
	   (not self.allFutureActorForDefUpd.isEmpty)      or		//28.05.2024 navma1 #64224
	   (not self.allFutureActorForDefDel.isEmpty) 	   or		//17.03.2025 navma1 #MTN-34120
	   (not self.allEventsForDeferUpd.isEmpty) 		   then 	// ### TFS CR 63938 TASK 63942 02MAY2024 NAVAB1

		/*
		Not done here as this is called from the epilog which
		could cause a problem
		
		if self.noErrors then
			self.updateTIsForDeferUpd();
		endif;
		if self.noErrors then
			self.updateTITransForDeferUpd();
		endif;
		*/
	
		// need to call the passport updateTIsForDeferUpd or updateTITransForDeferUpd methods
		app.raiseUnexpectedProgramError(class.name, method.name, 
								'Deferred update not done (ti=' &amp;
								self.allTIsForDeferredUpdate.size.String 	  &amp; ', txn=' &amp;
								self.allTITransactionsForDeferUpd.size.String &amp; ', evt=' &amp;
								self.allEventsForDeferUpd.size.String 		  &amp;							 // ### TFS CR 63938 TASK 63942 02MAY2024 NAVAB1
								self.allFutureActorForDefUpd.size.String 	  &amp; ', actors Upt='&amp;		//23.05.2024 navma1 #64224
								self.allFutureActorForDefDel.size.String	  &amp; ', actors Del='&amp;		//17.03.2025 navma1 #MTN-34120
								') Might need to call DODEFERREDUPDATES() from TRX');
		return true;
	endif;

	return false;
	
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="rebuildDeferredDicts" id="11dd15de-1acf-453b-878f-3c4af5a952a6">
        <source>rebuildDeferredDicts();
// ---------------------------------------------------------------------------
// Created:     17 June 2004 by cnwrs2
//
// Purpose:     
// 17 Mar 2025 navma1 MTN-34120 MTN | Dead Lock (1081) on CM_OfflineFutureActorParentDct
// ---------------------------------------------------------------------------
vars

begin
	self.allTIsForDeferredUpdate.rebuild();
	self.allTITransactionsForDeferUpd.rebuild();
	self.allEventsForDeferUpd.rebuild(); 			// ### TFS CR 63938 TASK 63942 02MAY2024 NAVAB1
	self.allFutureActorForDefDel.rebuild();			//17.03.2025 navma1 #MTN-34120;
	self.allFutureActorForDefUpd.rebuild();			//17.03.2025 navma1 #MTN-34120
end;</source>
    </JadeMethod>
    <JadeMethod name="recordLogoffEvent" id="7b5cf78a-8f74-470c-ae57-d39f8b02c39d">
        <source>recordLogoffEvent(_machine : CM_Machine);
// ---------------------------------------------------------------------------
// Created:     09 October 2007 by cnwrs2
//
// Purpose:     
/* Changes

Date		Name	TFS#		Description
============================================================================
21 Jun 2011	cnwrs1	CCMS1150 	Change JMT to enable logon SDS Secondary databasevars
30 Nov 2017 cnwma1	TFS #7995 	STWO - Maximum Password Attempts - not matching security setup - system fault
18 Sep 2019 jlgka1 	TFS 45614 	JMT - Refactoring remove Voyage Commodity Scenario mode
18 Jul 2025	navdap1	MTN-34430	MTN - Deferred Updates For Event Required For Login and Logout Trxs
============================================================================*/
vars
	tmpEVTLogout	: CMEVT_Logout;
	cmifEventCtrl 	: CMIF_LogoutEventCtrl; //17/02/2025	navkc1 JIRA Bug MTN-33582
begin
	if app.isSDSSecondaryDB() then		// CCMS1150 cnwrs1 21 June 2011
		return;
	endif;
	/* //17/02/2025	navkc1 JIRA Bug MTN-33582
	tmpEVTLogout := app.createEvent(EVT_UserLogout, app.actualTimeServer(), null, self.userCode, false, false,0).CMEVT_Logout;
	if tmpEVTLogout = null then
		return;
	endif;

	on CM_Exception do app.handleTransactionMapError(exception, excOccurred);  //30.11.2017  cnwma1 TFS #7995
	//tmpEVTLogout.createCharge(self);
	app.myPassport.addEventTransactionForDeferUpd(tmpEVTLogout,app.myPassport.myTerminal); // ### JIRA 33567 03DEC2024 NAVAB1
	on CM_Exception do null;
	
	if self.myEventLogin &lt;&gt; null
	and self.myEventLogin.userCode = self.userCode
	and self.myEventLogin.myEventLogout = null
	then
		tmpEVTLogout.setEventLogin(self.myEventLogin);
	endif;
	*/
	
	//17/02/2025	navkc1 JIRA Bug MTN-33582 - Starts
	
	create cmifEventCtrl transient;
	cmifEventCtrl.type := EVT_UserLogout;
	cmifEventCtrl.dateTime := app.actualTimeServer();
	cmifEventCtrl.userCode := self.userCode;
	cmifEventCtrl.myEventLogin := self.myEventLogin;
	if _machine &lt;&gt; null then								// MTN-34430
		cmifEventCtrl.myTerminal := _machine.myTerminal;	// MTN-34430
	endif;													// MTN-34430
	
	tmpEVTLogout := app.createEventUsingCMIF(cmifEventCtrl).CMEVT_Logout; //17/02/2025	navkc1 JIRA Bug MTN-33582
	//17/02/2025	navkc1 JIRA Bug MTN-33582 - Ends
	
epilog
	delete cmifEventCtrl; 
end;</source>
        <Parameter name="_machine" type="CM_Machine"/>
    </JadeMethod>
    <JadeMethod name="removeDuplicateWarnings" id="e61a0e13-dd2b-41d9-a0ca-ab4b1d5eb71d">
        <source>removeDuplicateWarnings();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 March 2014	cnwndl1	Initial creation	Par 33596

*/

vars

begin

	self.allErrorWarnings.removeDuplicates();

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="removeTITransationForDeferUpd" id="6d799165-6486-4af1-b211-2b4ab493d34d">
        <updating/>
        <source>removeTITransationForDeferUpd(_tiTransaction : CM_TITransaction input) updating;
// ---------------------------------------------------------------------------
// Created:     24 June 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin

	if (not self.useTITransactionDeferUpdate) then
		return;
	endif;
	
	if self.allTITransactionsForDeferUpd.includes(_tiTransaction) then
		self.allTITransactionsForDeferUpd.remove(_tiTransaction);
	endif;

end;</source>
        <Parameter name="_tiTransaction" type="CM_TITransaction" usage="input"/>
    </JadeMethod>
    <JadeMethod name="removeWarnings" id="b7c4dba2-3101-48d1-93be-ce815f0f13b5">
        <updating/>
        <source>removeWarnings( _arrWarnings : HugeStringArray) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
29 March 2010	cnwjk3	PAR 23206

Remove any warnings where the messages match exactly

*/

vars
	strWarning 	: String;
	warning		: CM_Error;
	arrRemove	: ObjectArray;
begin
	create arrRemove transient;
	foreach strWarning in _arrWarnings do
		foreach warning in self.allWarnings do
			if warning.text = strWarning then
				arrRemove.add(warning);
			endif;
		endforeach;
	endforeach;
	arrRemove.purge();
epilog
	delete arrRemove;
end;</source>
        <Parameter name="_arrWarnings" type="HugeStringArray"/>
    </JadeMethod>
    <JadeMethod name="replaceTIForTITransForDeferUpd" id="260d88dc-410b-4b84-a3e6-708ac7937076">
        <updating/>
        <source>replaceTIForTITransForDeferUpd(_oldTi, _newTi : CM_TrackedItem) updating;
//
// cnwrs1 Jan 2008 Par 15781
// this is when we are un transhipping a ti the export leg will be removed and if we are
// going to switch the transaction over from the oldTi to the newTi
//
vars
	trans : CM_TITransaction;
begin
	if (not self.useTITransactionDeferUpdate) then
		return;
	endif;
	foreach trans in self.allTITransactionsForDeferUpd do
		if trans.myTrackedItem = _oldTi then
			trans.setMyTrackedItem(_newTi, null);
		endif;
	endforeach;
end;
</source>
        <Parameter name="_oldTi" type="CM_TrackedItem"/>
        <Parameter name="_newTi" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="replaceTrackedItemForDeferUpd" id="bcd1489f-ef18-4bb9-9a06-bdceb1df131d">
        <updating/>
        <source>replaceTrackedItemForDeferUpd(_oldTi, _newTi : CM_TrackedItem) updating;
//
// cnwrs1 Jan 2008 Par 15781
// this is when we are un transhipping a ti the export leg will be removed and if we are
// going to delete the ti we need to replace the export in the deferred list with the import
//
vars

begin
	if (not self.useTITransactionDeferUpdate) then
		return;
	endif;
	if self.allTIsForDeferredUpdate.includes(_oldTi) then
		self.allTIsForDeferredUpdate.add(_newTi);
		self.allTIsForDeferredUpdate.remove(_oldTi);
	endif;
end;
</source>
