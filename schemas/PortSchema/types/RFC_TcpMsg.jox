    <JadeMethod name="user_cnTcpExceptionHandler" id="13d574b1-1695-4d68-b78d-bbb7afc3ac9f">
        <updating/>
        <source>user_cnTcpExceptionHandler(_exObj: Exception): Integer updating;
// ---------------------------------------------------------------------------
// Created:     01 December 2001 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	tcpMsg 	: RFC_TcpMsg;
	message	: String;
begin
	tcpMsg := _exObj.ConnectionException.connection.RFC_TcpMsg;
	
	if self.myTcpIpClientAgent &lt;&gt; null then
		self.myTcpIpClientAgent.setIsConnected(false);
	endif;
	
	message := _exObj.errorCode.String;
	if _exObj.errorCode = 31001 then
		message :='No target host name specified';
	elseif _exObj.errorCode = 31002 then
		message := 'Target host not found';
	elseif _exObj.errorCode = 31003 then
		message := 'Invalid port specification';
	elseif _exObj.errorCode = 31004 then
		message := 'Failed to connect';
	elseif _exObj.errorCode = 31005 then
		message := 'Failed to bind';
	elseif _exObj.errorCode = 31006 then
		message := 'Failed to listen';
	elseif _exObj.errorCode = 31007 then
		message := 'Failed to accept';
	elseif _exObj.errorCode = 31008 then
		message := 'Failed to read';
	elseif _exObj.errorCode = 31009 then
		message := 'Failed to write';
	elseif  _exObj.errorCode = 31017 then
		message := 'Connection closed from server end';
	endif;
	
	if self.myTcpIpClientAgent &lt;&gt; null then
		self.myTcpIpClientAgent.logMonitor(message);
	endif;
	
	return Ex_Continue;
end;</source>
        <Parameter name="_exObj" type="Exception"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
</Class>
