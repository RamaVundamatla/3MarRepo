    <JadeMethod name="tVGMCargoOnShip" id="d9bd3c02-4db7-4746-9eb9-28fb9fc7ec6c">
        <source>tVGMCargoOnShip();

/*

Purpose:		

Date			Who		Reason
19 May 2016	cnwmh5	Initial creation

*/
constants

	UserDefinedCargoOnShip			: String = "Unit Test VGMCargoOnShip";
	ContainerId						: String = "UTMDHVGM003";
	VoyageId						: String = "UTMDHVGMVOY2";
	VesselId						: String = "MESDIAM";
	BlockStackName					: String = "UTVGM2";

vars

	cont							: CM_Container;
	operator						: CM_Operator;
	voyage							: CM_Voyage;
	ediFile							: CM_EDIFile;
	bs								: CM_BlockStack;
	tiTransaction					: CM_TITransaction;
	
	iter							: Iterator;
	
	checked							: Boolean;

begin

	// create user defined file type
	self.createUserDefinedFileType(UserDefinedCargoOnShip, self.xmlDef_CargoOnShipVGM(UserDefinedCargoOnShip));
	
	bs := self.addBlockStack(BlockStackName, 999, null);
	self.assertNotNull(bs);
	
	self.deleteVoyage(VoyageId);
	voyage := self.addVoyageWithConRORO(VoyageId, VesselId, self.getProfileSetting(UT_Profile.P_OPERATOR).asString(), 
		self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString(), self.getProfileSetting(UT_Profile.P_TRADE).asString(), 
		0, false, true);
	self.assertNotNull(voyage);
	
	// turn off CertifiedWeightNeedsVGM
	self.setTerminalConfig(CertifiedWeightNeedsVGM, false);
	
	// update all vgm fields
	ediFile := self.ediLoadVerifyDBLoadActualBasic(self.xVGMCargoOnShipDetails(1, ContainerId, voyage.code), UserDefinedCargoOnShip, UserDefinedCargoOnShip&amp;'1'&amp;method.name, EDIFileType_UserDefined, 
		true, true, false, false, null);
	self.assertNotNullMsg(ediFile, "1. EDI File not created - Update all VGM fields");
	cont := self.getTrackedItem(ContainerId).CM_Container;
	self.assertNotNull(cont);
	self.assertEqualMsg(cont.isWeightCertified, true, "1. Container (" &amp; cont.id &amp; ") isWeightCertified should be true");
	self.assertNotEqualMsg(cont.weightCertifiedReference, null, "2. Container (" &amp; cont.id &amp; ") weightCertifiedReference should NOT be null");
	self.assertNotEqualMsg(cont.weightCertifiedName, null, "3. Container (" &amp; cont.id &amp; ") weightCertifiedName should NOT be null");
	
	// remove certified by
	ediFile := self.ediLoadVerifyDBLoadActualBasic(self.xVGMCargoOnShipDetails(2, ContainerId, voyage.code), UserDefinedCargoOnShip, UserDefinedCargoOnShip&amp;'2'&amp;method.name, EDIFileType_UserDefined, 
		true, true, false, false, null);
	self.assertNotNullMsg(ediFile, "10. EDI File not created - Update all VGM fields");
	self.assertEqualMsg(cont.weightCertifiedReference, null, "11. Container (" &amp; cont.id &amp; ") weightCertifiedReference should be null");
	iter := cont.allTransactions.createIterator;
	iter.back(tiTransaction);
	if tiTransaction.isKindOf(CM_Edit) then
		//self.assertTrueMsg(tiTransaction.isKindOf(CM_Edit), "12. Container (" &amp; cont.id &amp; ")'s last transaction should be a CM_Edit");
		self.assertFalseMsg(tiTransaction.CM_Edit.fieldsValues.compareIDStrings("weightCertifiedReference"), "13. Container (" &amp; cont.id &amp; ")'s last transaction is not for weightCertifiedReference");
		checked := true;
	endif;
	if not checked then
		iter.back(tiTransaction);
		if tiTransaction.isKindOf(CM_Edit) then
			//self.assertTrueMsg(tiTransaction.isKindOf(CM_Edit), "12. Container (" &amp; cont.id &amp; ")'s last transaction should be a CM_Edit");
			self.assertFalseMsg(tiTransaction.CM_Edit.fieldsValues.compareIDStrings("weightCertifiedReference"), "13a. Container (" &amp; cont.id &amp; ")'s last transaction is not for weightCertifiedReference");
		endif;
	endif;
	
	// remove all vgm fields
	ediFile := self.ediLoadVerifyDBLoadActualBasic(self.xVGMCargoOnShipDetails(0, ContainerId, voyage.code), UserDefinedCargoOnShip, UserDefinedCargoOnShip&amp;'3'&amp;method.name, EDIFileType_UserDefined, 
		true, true, false, false, null);
	self.assertNotNullMsg(ediFile, "20. EDI File not created - Update all VGM fields");
	self.assertEqualMsg(cont.isWeightCertified, false, "21. Container (" &amp; cont.id &amp; ") isWeightCertified should be false");
	self.assertEqualMsg(cont.weightCertifiedReference, null, "22. Container (" &amp; cont.id &amp; ") weightCertifiedReference should be null");
	self.assertEqualMsg(cont.weightCertifiedName, null, "23. Container (" &amp; cont.id &amp; ") weightCertifiedName should be null");
	
	// turn on CertifiedWeightNeedsVGM
	self.setTerminalConfig(CertifiedWeightNeedsVGM, true);
	
	// set all vgm fields
	ediFile := self.ediLoadVerifyDBLoadActualBasic(self.xVGMCargoOnShipDetails(1, ContainerId, voyage.code), UserDefinedCargoOnShip, UserDefinedCargoOnShip&amp;'4'&amp;method.name, EDIFileType_UserDefined, 
		true, true, false, false, null);
	self.assertNotNullMsg(ediFile, "30. EDI File not created - Update all VGM fields");
	self.assertEqualMsg(cont.isWeightCertified, true, "31. Container (" &amp; cont.id &amp; ") isWeightCertified should be true");
	self.assertNotEqualMsg(cont.weightCertifiedReference, null, "32. Container (" &amp; cont.id &amp; ") weightCertifiedReference should NOT be null");
	self.assertNotEqualMsg(cont.weightCertifiedName, null, "33. Container (" &amp; cont.id &amp; ") weightCertifiedName should NOT be null");
		
	// remove certified by
	ediFile := self.ediLoadVerifyDBLoadActualBasic(self.xVGMCargoOnShipDetails(2, ContainerId, voyage.code), UserDefinedCargoOnShip, UserDefinedCargoOnShip&amp;'5'&amp;method.name, EDIFileType_UserDefined, 
		false, false, false, false, null);
	self.assertNotNullMsg(ediFile, "40. EDI File not created - Update all VGM fields");
	
	self.clearExpectedTrxErrors();
	self.expectedTrxErrors.add(Input_req_weight_certified_by);
	self.ediVerify(ediFile);
	self.assertNoTrxErrorsOrWarnings();
		
	// remove all vgm fields
	self.clearExpectedTrxErrors();
	ediFile := self.ediLoadVerifyDBLoadActualBasic(self.xVGMCargoOnShipDetails(0, ContainerId, voyage.code), UserDefinedCargoOnShip, UserDefinedCargoOnShip&amp;'6'&amp;method.name, EDIFileType_UserDefined, 
		true, true, false, false, null);
	self.assertNotNullMsg(ediFile, "50. EDI File not created - Update all VGM fields");
	self.assertEqualMsg(cont.isWeightCertified, false, "51. Container (" &amp; cont.id &amp; ") isWeightCertified should be false");
	self.assertEqualMsg(cont.weightCertifiedReference, null, "52. Container (" &amp; cont.id &amp; ") weightCertifiedReference should be null");
	self.assertEqualMsg(cont.weightCertifiedName, null, "53. Container (" &amp; cont.id &amp; ") weightCertifiedName should be null");
	
epilog

	delete iter;

end;</source>
    </JadeMethod>
    <JadeMethod name="tVGMCargoOnSite" id="744b708a-3d9d-4bd8-b153-167617f3f130">
        <source>tVGMCargoOnSite();

/*

Purpose:		

Date			Who		Reason
19 May 2016	cnwmh5	Initial creation
10 Sep 2019	jlgsl4	TFS 46404 - SNO - update from non-null Vermas details only
*/
constants

	UserDefinedCargoOnSite			: String = "Unit Test VGMCargoOnSite";
	ContainerId						: String = "UTMDHVGM002";
	VoyageId						: String = "UTMDHVGMVOY1";
	VesselId						: String = "MESDIAM";
	BlockStackName					: String = "UTVGM1";

vars

	cont							: CM_Container;
	operator						: CM_Operator;
	voyage							: CM_Voyage;
	ediFile							: CM_EDIFile;
	bs								: CM_BlockStack;
	tiTransaction					: CM_TITransaction;


begin

	// create user defined file type
	self.createUserDefinedFileType(UserDefinedCargoOnSite, self.xmlDef_CargoOnSiteVGM(UserDefinedCargoOnSite));
	
	bs := self.addBlockStack(BlockStackName, 999, null);
	self.assertNotNull(bs);
	
	self.deleteVoyage(VoyageId);
	voyage := self.addVoyageWithConRORO(VoyageId, VesselId, self.getProfileSetting(UT_Profile.P_OPERATOR).asString(), 
		self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString(), self.getProfileSetting(UT_Profile.P_TRADE).asString(), 
		0, false, true);
	self.assertNotNull(voyage);
	
	// turn off CertifiedWeightNeedsVGM
	self.setTerminalConfig(CertifiedWeightNeedsVGM, false);
	
	// update all vgm fields
	ediFile := self.ediLoadVerifyDBLoadActualBasic(self.xVGMCargoOnSiteDetails(1, ContainerId, voyage.code), UserDefinedCargoOnSite, UserDefinedCargoOnSite&amp;'1'&amp;method.name, EDIFileType_UserDefined, 
		true, true, false, false, null);
	self.assertNotNullMsg(ediFile, "1. EDI File not created - Update all VGM fields");
	cont := self.getTrackedItem(ContainerId).CM_Container;
	self.assertNotNull(cont);
	self.assertEqualMsg(cont.isWeightCertified, true, "1. Container (" &amp; cont.id &amp; ") isWeightCertified should be true");
	self.assertNotEqualMsg(cont.weightCertifiedReference, null, "2. Container (" &amp; cont.id &amp; ") weightCertifiedReference should NOT be null");
	self.assertNotEqualMsg(cont.weightCertifiedName, null, "3. Container (" &amp; cont.id &amp; ") weightCertifiedName should NOT be null");
	
	// remove certified by
	ediFile := self.ediLoadVerifyDBLoadActualBasic(self.xVGMCargoOnSiteDetails(2, ContainerId, voyage.code), UserDefinedCargoOnSite, UserDefinedCargoOnSite&amp;'2'&amp;method.name, EDIFileType_UserDefined, 
		true, true, false, false, null);
	self.assertNotNullMsg(ediFile, "10. EDI File not created - Update all VGM fields");
	self.assertEqualMsg(cont.weightCertifiedReference, null, "11. Container (" &amp; cont.id &amp; ") weightCertifiedReference should be null");
	tiTransaction := cont.allTransactions.last;
	self.assertTrueMsg(tiTransaction.isKindOf(CM_Edit), "12. Container (" &amp; cont.id &amp; ")'s last transaction should be a CM_Edit");
	self.assertFalseMsg(tiTransaction.CM_Edit.fieldsValues.compareIDStrings("weightCertifiedReference"), "13. Container (" &amp; cont.id &amp; ")'s last transaction is not for weightCertifiedReference");
	
	// remove all vgm fields
	ediFile := self.ediLoadVerifyDBLoadActualBasic(self.xVGMCargoOnSiteDetails(0, ContainerId, voyage.code), UserDefinedCargoOnSite, UserDefinedCargoOnSite&amp;'3'&amp;method.name, EDIFileType_UserDefined, 
		true, true, false, false, null);
	self.assertNotNullMsg(ediFile, "20. EDI File not created - Update all VGM fields");
	self.assertEqualMsg(cont.isWeightCertified, false, "21. Container (" &amp; cont.id &amp; ") isWeightCertified should be false");
	self.assertEqualMsg(cont.weightCertifiedReference, null, "22. Container (" &amp; cont.id &amp; ") weightCertifiedReference should be null");
	self.assertEqualMsg(cont.weightCertifiedName, null, "23. Container (" &amp; cont.id &amp; ") weightCertifiedName should be null");
	
	// turn on CertifiedWeightNeedsVGM
	self.setTerminalConfig(CertifiedWeightNeedsVGM, true);
	
	// set all vgm fields
	ediFile := self.ediLoadVerifyDBLoadActualBasic(self.xVGMCargoOnSiteDetails(1, ContainerId, voyage.code), UserDefinedCargoOnSite, UserDefinedCargoOnSite&amp;'4'&amp;method.name, EDIFileType_UserDefined, 
		true, true, false, false, null);
	beginTransaction; // --&gt; TFS 46404
	cont.setMyVGMDetailsVermas(cont.myVGMDetails.weightCertifiedReference, null, null, null, null, null,null, null, null, null, null, null, null, null);
	cont.setTotalWeightCertWeight(15100);
	commitTransaction; // &lt;-- TFS 46404		
	self.assertNotNullMsg(ediFile, "30. EDI File not created - Update all VGM fields");
	self.assertEqualMsg(cont.isWeightCertified, true, "31. Container (" &amp; cont.id &amp; ") isWeightCertified should be true");
	self.assertNotEqualMsg(cont.weightCertifiedReference, null, "32. Container (" &amp; cont.id &amp; ") weightCertifiedReference should NOT be null");
	self.assertNotEqualMsg(cont.weightCertifiedName, null, "33. Container (" &amp; cont.id &amp; ") weightCertifiedName should NOT be null");
	self.assertNotEqualMsg(cont.weightDeclared, 15100, "34. Container (" &amp; cont.id &amp; ") weightDeclared should be 15100 kg"); // TFS 46404
		
	// remove certified by
	ediFile := self.ediLoadVerifyDBLoadActualBasic(self.xVGMCargoOnSiteDetails(2, ContainerId, voyage.code), UserDefinedCargoOnSite, UserDefinedCargoOnSite&amp;'5'&amp;method.name, EDIFileType_UserDefined, 
		false, false, false, false, null);
	self.assertNotNullMsg(ediFile, "40. EDI File not created - Update all VGM fields");
	
	self.clearExpectedTrxErrors();
	self.expectedTrxErrors.add(Input_req_weight_certified_by);
	self.ediVerify(ediFile);
	self.assertNoTrxErrorsOrWarnings();
		
	// remove all vgm fields
	self.clearExpectedTrxErrors();
	ediFile := self.ediLoadVerifyDBLoadActualBasic(self.xVGMCargoOnSiteDetails(0, ContainerId, voyage.code), UserDefinedCargoOnSite, UserDefinedCargoOnSite&amp;'6'&amp;method.name, EDIFileType_UserDefined, 
		true, true, false, false, null);
	self.assertNotNullMsg(ediFile, "50. EDI File not created - Update all VGM fields");
	self.assertEqualMsg(cont.isWeightCertified, false, "51. Container (" &amp; cont.id &amp; ") isWeightCertified should be false");
	self.assertEqualMsg(cont.weightCertifiedReference, null, "52. Container (" &amp; cont.id &amp; ") weightCertifiedReference should be null");
	self.assertEqualMsg(cont.weightCertifiedName, null, "53. Container (" &amp; cont.id &amp; ") weightCertifiedName should be null");
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="tVGMCargoUpdateRequest" id="a37a347c-ad29-4de3-8c03-e88e1a193eec">
        <source>tVGMCargoUpdateRequest();

/*

Purpose:		

Date			Who		Reason
19/05/2016		cnwmh5	Initial creation

*/
constants

	UserDefinedCargoUpdateRequest	: String = "Unit Test VGMCargoUpdateRequest";
	UserDefinedCargoFieldUpdate		: String = "Unit Test VGMCargoFieldUpdate";
	ContainerId						: String = "UTMDHVGM004";
	VoyageId						: String = "UTMDHVGMVOY3";
	VesselId						: String = "MESDIAM";
	BlockStackName					: String = "UTVGM3";

vars

	cont							: CM_Container;
	operator						: CM_Operator;
	voyage							: CM_Voyage;
	ediFile							: CM_EDIFile;
	bs								: CM_BlockStack;
	tiTransaction					: CM_TITransaction;
	stop 							: CM_StopsTable;
		
	iter							: Iterator;
	
	selectedTypes 					: CM_CargoBOLTypeSet;
	optsDict						: CM_AssociationDict;

begin

	// create user defined file type
	self.createUserDefinedFileType(UserDefinedCargoUpdateRequest, self.xmfDef_CargoUpdateRequestVGM(UserDefinedCargoUpdateRequest));
	self.createUserDefinedFileType(UserDefinedCargoFieldUpdate, self.xmlDef_CargoFieldUpdateVGM(UserDefinedCargoFieldUpdate));
	
	bs := self.addBlockStack(BlockStackName, 999, null);
	self.assertNotNull(bs);
	
	self.deleteVoyage(VoyageId);
	voyage := self.addVoyageWithConRORO(VoyageId, VesselId, self.getProfileSetting(UT_Profile.P_OPERATOR).asString(), 
		self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString(), self.getProfileSetting(UT_Profile.P_TRADE).asString(), 
		0, false, true);
	self.assertNotNull(voyage);
	
	create selectedTypes transient;
	selectedTypes.add( app.myRoot.allCargoTypesById[TI_CargoType_Container] );
	
	create optsDict transient;
	
	self.deleteStopsTable(777);
	stop := self.addStopsTable(777, "UT777", "UT Michael's Stop", selectedTypes, optsDict);
	self.assertNotNull(stop);
	
	// turn off CertifiedWeightNeedsVGM
	self.setTerminalConfig(CertifiedWeightNeedsVGM, false);
	
	// create 2 containers
	cont := self.addContainer(ContainerId, operator, "2200", "GENL", TI_IMEX_STATUS_IMPORT).CM_Container;
	self.assertNotNull(cont);
	self.assertEqualMsg(cont.isWeightCertified, false, "1. Container (" &amp; cont.id &amp; ") isWeightCertified should be false");
	self.assertEqualMsg(cont.weightCertifiedReference, null, "2. Container (" &amp; cont.id &amp; ") weightCertifiedReference should be null");
	self.assertEqualMsg(cont.weightCertifiedName, null, "3. Container (" &amp; cont.id &amp; ") weightCertifiedName should be null");
	
	self.opts.purge();
	self.opts.addAssoc("TotalWeight", 5999);
	self.updateTI(cont);
	self.assertNotEqualMsg(cont.totalWeight, "5999.0000".String, "4. Container (" &amp; cont.id &amp; ")'s weight isn't correct.");
	
	
	// update all vgm fields
	ediFile := self.ediLoadVerifyDBLoadActualBasic(self.xVGMCargoUpdateRequestDetails(1, ContainerId, voyage.code, stop.id), UserDefinedCargoUpdateRequest, UserDefinedCargoUpdateRequest&amp;'1'&amp;method.name, EDIFileType_UserDefined, 
		true, true, false, false, null);
	self.assertNotNullMsg(ediFile, "10. EDI File not created - Update all VGM fields");
	self.assertEqualMsg(cont.isWeightCertified, true, "11. Container (" &amp; cont.id &amp; ") isWeightCertified should be true");
	self.assertNotEqualMsg(cont.weightCertifiedReference, null, "12. Container (" &amp; cont.id &amp; ") weightCertifiedReference should NOT be null");
	self.assertNotEqualMsg(cont.weightCertifiedName, null, "13. Container (" &amp; cont.id &amp; ") weightCertifiedName should NOT be null");
	
	
	self.assertNotEqualMsg(cont.totalWeight, "5999.0000".String, "4a. Container (" &amp; cont.id &amp; ")'s weight isn't correct.");
	
	
	// remove certified by
	ediFile := self.ediLoadVerifyDBLoadActualBasic(self.xVGMCargoUpdateRequestDetails(2, ContainerId, voyage.code, stop.id), UserDefinedCargoUpdateRequest, UserDefinedCargoUpdateRequest&amp;'2'&amp;method.name, EDIFileType_UserDefined, 
		true, true, false, false, null);
	self.assertNotNullMsg(ediFile, "20. EDI File not created - Update all VGM fields");
	self.assertEqualMsg(cont.weightCertifiedReference, null, "21. Container (" &amp; cont.id &amp; ") weightCertifiedReference should be null");
	iter := cont.allTransactions.createIterator;
	iter.back(tiTransaction);
	self.assertTrueMsg(tiTransaction.isKindOf(CM_Edit), "22. Container (" &amp; cont.id &amp; ")'s last transaction should be a CM_Edit");
	self.assertFalseMsg(tiTransaction.CM_Edit.fieldsValues.compareIDStrings("weightCertifiedReference"), "23. Container (" &amp; cont.id &amp; ")'s last transaction is not for weightCertifiedReference");
	
	
	
	self.assertEqualMsg(cont.totalWeight.String, "5999.0000".String, "4b. Container (" &amp; cont.id &amp; ")'s weight isn't correct.");
	
	
	// remove all vgm fields
	/*
	ediFile := self.ediLoadVerifyDBLoadActualBasic(self.xVGMCargoUpdateRequestDetails(0, ContainerId, voyage.code, stop.id), UserDefinedCargoUpdateRequest, EDIFileType_UserDefined, 
		true, true, false, false, null);
	self.assertNotNullMsg(ediFile, "30. EDI File not created - Update all VGM fields");
	self.assertEqualMsg(cont.isWeightCertified, false, "31. Container (" &amp; cont.id &amp; ") isWeightCertified should be false");
	self.assertEqualMsg(cont.weightCertifiedReference, null, "32. Container (" &amp; cont.id &amp; ") weightCertifiedReference should be null");
	self.assertEqualMsg(cont.weightCertifiedName, null, "33. Container (" &amp; cont.id &amp; ") weightCertifiedName should be null");
	*/
	
	
	ediFile := self.ediLoadVerifyDBLoadActualBasic(self.xVGMCargoFieldUpdateDetails(0, cont.id), UserDefinedCargoFieldUpdate, UserDefinedCargoFieldUpdate&amp;'3'&amp;method.name, EDIFileType_UserDefined, 
		true, true, false, false, null);
	self.assertNotNullMsg(ediFile, "30. EDI File not created - Update all VGM fields");
	self.assertEqualMsg(cont.isWeightCertified, false, "31. Container (" &amp; cont.id &amp; ") isWeightCertified should be false");
	self.assertEqualMsg(cont.weightCertifiedReference, null, "32. Container (" &amp; cont.id &amp; ") weightCertifiedReference should be null");
	self.assertEqualMsg(cont.weightCertifiedName, null, "33. Container (" &amp; cont.id &amp; ") weightCertifiedName should be null");
	
	self.assertEqualMsg(cont.totalWeight.String, "5999.0000".String, "4c. Container (" &amp; cont.id &amp; ")'s weight isn't correct.");
	
	
	// turn on CertifiedWeightNeedsVGM
	self.setTerminalConfig(CertifiedWeightNeedsVGM, true);
	
	
	// set all vgm fields
	ediFile := self.ediLoadVerifyDBLoadActualBasic(self.xVGMCargoUpdateRequestDetails(1, ContainerId, voyage.code, stop.id), UserDefinedCargoUpdateRequest, UserDefinedCargoUpdateRequest&amp;'4'&amp;method.name, EDIFileType_UserDefined, 
		true, true, false, false, null);
	self.assertNotNullMsg(ediFile, "40. EDI File not created - Update all VGM fields");
	self.assertEqualMsg(cont.isWeightCertified, true, "41. Container (" &amp; cont.id &amp; ") isWeightCertified should be true");
	self.assertNotEqualMsg(cont.weightCertifiedReference, null, "42. Container (" &amp; cont.id &amp; ") weightCertifiedReference should NOT be null");
	self.assertNotEqualMsg(cont.weightCertifiedName, null, "43. Container (" &amp; cont.id &amp; ") weightCertifiedName should NOT be null");
	
	
	// remove certified by
	ediFile := self.ediLoadVerifyDBLoadActualBasic(self.xVGMCargoUpdateRequestDetails(2, ContainerId, voyage.code, stop.id), UserDefinedCargoUpdateRequest, UserDefinedCargoUpdateRequest&amp;'5'&amp;method.name, EDIFileType_UserDefined, 
		false, false, false, false, null);
	self.assertNotNullMsg(ediFile, "50. EDI File not created - Update all VGM fields");
	
	self.clearExpectedTrxErrors();
	self.expectedTrxErrors.add(Input_req_weight_certified_by);
	self.ediVerify(ediFile);
	self.assertNoTrxErrorsOrWarnings();
	
	// remove all vgm fields
	self.clearExpectedTrxErrors();
	ediFile := self.ediLoadVerifyDBLoadActualBasic(self.xVGMCargoUpdateRequestDetails(0, ContainerId, voyage.code, stop.id), UserDefinedCargoUpdateRequest, UserDefinedCargoUpdateRequest&amp;'6'&amp;method.name, EDIFileType_UserDefined, 
		true, true, false, false, null);
	self.assertNotNullMsg(ediFile, "60. EDI File not created - Update all VGM fields");
	self.assertNotEqualMsg(cont.isWeightCertified, false, "61. Container (" &amp; cont.id &amp; ") isWeightCertified should be false");
	self.assertNotEqualMsg(cont.weightCertifiedReference, null, "62. Container (" &amp; cont.id &amp; ") weightCertifiedReference should be null");
	self.assertNotEqualMsg(cont.weightCertifiedName, null, "63. Container (" &amp; cont.id &amp; ") weightCertifiedName should be null");
	
epilog

	delete iter;
	delete selectedTypes;
	delete optsDict;
	
end;</source>
