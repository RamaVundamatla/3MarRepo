<Class name="CM_CargoScanRecordData" id="523fe12f-76c8-4e75-9b0c-368d829543bc">
    <superclass name="CM_GenericScanRecordData"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="terminal"/>
    <PrimAttribute name="alternateId" id="73ba88a5-b6cd-45f7-aea7-87aaebe099a1">
        <length>31</length>
