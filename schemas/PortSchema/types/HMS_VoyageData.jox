    <JadeMethod name="pxyCreateUpdateProxy" id="cf775230-82f2-4519-b9cc-5df97f426370">
        <source>pxyCreateUpdateProxy(): SelfType;
//--------------------------------------------------
// Created:	29 March 2004 By: cnwgd1
//--------------------------------------------------
// 20/04/2011	cnwmh5		PAR #27401 - Add code to handle prossible exceptions occurring when
//							trying to create the proxy

vars
	pxyMovement,
	tmpMovement : HMS_VoyageMovement;
	berthPref : HMS_BerthPreference;
	voyageDelay : HMS_VoyageDelay;
	proxy : HMS_VoyageData;
	completedOK		: Boolean;
begin
	proxy := inheritMethod();
	
	proxy.cloneReferences(self);
	
	foreach tmpMovement in self.allVoyageMovements do
		pxyMovement := tmpMovement.pxyCreateUpdateProxy();
		pxyMovement.setPropertyValue(HMS_VoyageMovement::myHMSVoyageData.name, proxy);
	endforeach;									

	foreach berthPref in self.allBerthPreferencesArray do
		proxy.allBerthPreferencesArray.add(berthPref.pxyCreateUpdateProxy);
	endforeach;									
		
	proxy.allBerthPreferencesByName.copy(proxy.allBerthPreferencesArray);	
	
	proxy.myTowingVoyage := self.myTowingVoyage;	//25 Jun 2018	NDL	TFS 39248

	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return proxy;
epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete proxy;
	endif;	
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setAllMovementsArchived" id="00c027e1-e29b-46fc-83e4-696158d340e1">
        <updating/>
        <source>setAllMovementsArchived(_passport : CM_Passport input) updating;
//--------------------------------------------------------------
//Created: 28 July 2003 By: cnwgd1
//--------------------------------------------------------------
/*

Date		Who		Reason
11 Jan 2011	cnwkpd1	PAR #26678 - Tidy up transient leaks

*/
vars
	iter : Iterator;
	permanentMovement :	HMS_VoyageMovement;
	tmpArchiveDT : TimeStamp;
begin

	exclusiveLock(self);
	
	if (not self.myVoyage.archived) then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Voyage not archived');
		return;
	endif;
	
	tmpArchiveDT := self.myVoyage.archivedDT;
	if (not tmpArchiveDT.isValid) then
		tmpArchiveDT := app.serverTimestampAtTrxStart;
	endif;	

	iter := self.allVoyageMovements.createIterator();
	
	while iter.next(permanentMovement) do
		// Archive all permResourceUsed objs marked for deletion
		permanentMovement.archive(tmpArchiveDT, _passport);
	endwhile;
	
	// ---------------------------------------------
	// Create 'Delete Voyage' Transaction
	if (not app.isConverting) then
		self.createTransaction(TRANS_TYPE_HMSVoyageArchive, null, null, null, _passport);
	endif;
	
	self.archived := true;	

epilog
	delete iter;		// PAR #26678
	
end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setArchivePostConversion" id="ffb8bcfb-05e2-44c9-b09e-8753130ef78a">
        <updating/>
        <source>setArchivePostConversion()updating;
//********************************************************************
//
// Created by: cnwsh3
//
// Date: 25 August 2004
//
// Temporary method to fix data conversion data without having to call
// the transaction layer.  Converted data already has the corresponding 
// transactions - we are just cleaning up a conversion.
//
//********************************************************************
vars

begin
	self.archived := self.myVoyage.archived;
end;</source>
    </JadeMethod>
    <JadeMethod name="setDatesFromVoyageUpdate" id="d34cb1dc-c474-4105-95e1-cfa949f9b03d">
        <source>setDatesFromVoyageUpdate(_arrivedDT, _departedDT : TimeStamp);
// ---------------------------------------------------------------------------
// Created:     21 January 2008 by cnwrs2
//
// Purpose:     Called if voyage arrival/departure dates are updated
//				for proxy to keep movements in sync
// ---------------------------------------------------------------------------
/* Changes

Date		Name	TFS#		Description
============================================================================
18/07/2019	jlgka1 	TFS 45620	JMT - Refactor remove remaining  Voyage Commodity  Planning
============================================================================*/
vars
	prevMovement,
	nextMovement,
	tmpMovement		: HMS_Movement;
	fromTS,
	toTS,
	defaultDTForMove	: TimeStamp;
	numOfHours		: Integer;
	
begin

	self.raiseExceptionIfNotTransient(method);
	
	if (not _arrivedDT.isValid) or
	   (not _departedDT.isValid) then
		return;
	endif;
	
	// Following code based on code originally in HMS_VoyageData::setForUpdate.
	// Moved here so can be called on transient BEFORE the update so validation
	// can be done on changes to dates here.
	
	foreach tmpMovement in self.allVoyageMovements do

		// update arrival move PAR 10872	
		if tmpMovement.moveType = HMSMovementTypeArrival then
			if tmpMovement.occursOnDTNEW &lt;&gt; _arrivedDT then
				tmpMovement.setTimings(_arrivedDT, tmpMovement.steamingTime, false); // jlgka1 TFS 45620
			endif;
		
		// update departure move PAR 10872
		elseif tmpMovement.moveType = HMSMovementTypeDeparture then
			if tmpMovement.occursOnDTNEW &lt;&gt; _departedDT then
				tmpMovement.setTimings(_departedDT, tmpMovement.steamingTime, false); // jlgka1 TFS 45620
			endif;

		// shift movement auto adjust if out of range
		elseif tmpMovement.occursOnDTNEW &gt; _departedDT	or 
			   tmpMovement.occursOnDTNEW &lt; _arrivedDT then
		
		 	// Set default DT to be half way between the previous movement and the departure movement for the voyage
			// Calculate the number of hours between the arrival move and the next move for the voyage

			if prevMovement &lt;&gt; null and
			   prevMovement.arrivalTimeAtToRegion &lt; _departedDT then
				fromTS := prevMovement.arrivalTimeAtToRegion;
			else
				fromTS := _arrivedDT;
			endif;
			numOfHours := fromTS.differenceInHours(_departedDT);
			
			// if the length of stay is less than two days then set the movement time to be
			// the arrival time + one hour, otherwise problems occur when trying to set date and time
			defaultDTForMove := fromTS.changeByXXHours((numOfHours/2).Integer);
	
			//realMovement.setOccursOnDT(defaultDTForMove, null, false,  false);
			tmpMovement.setTimings(defaultDTForMove, tmpMovement.steamingTime, false); // jlgka1 TFS 45620
			
		endif;
		
		prevMovement := tmpMovement;
	
	endforeach;


end;</source>
        <Parameter name="_arrivedDT" type="TimeStamp"/>
        <Parameter name="_departedDT" type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="setDefaultBerthPreferences" id="ceb03684-28b9-418b-96e5-43cc5f635238">
        <updating/>
        <source>setDefaultBerthPreferences(_passport : CM_Passport input) updating;
//--------------------------------------------------
// Created:	26 August 2004 By: cnwgd1
//--------------------------------------------------
//Only called from the create, clones the vessels berth preferences
vars
	berthPref	: HMS_BerthPreference;
	newBerthPref: HMS_BerthPreferenceVoyageData;
	vesselData 	: HMS_VesselData;
	tmpData		: HMS_VesselDataHarbour;
	tmpArray	: HMS_BerthPrefArray;
begin
	
	vesselData := self.getMyHMSVesselData();
	
	if vesselData = null then
		return;
	endif;
	
	tmpData := vesselData.allVesselDataForHarbour[self.myHarbour];
	
	if tmpData = null then
		return;
	endif;
	
	if tmpData.allBerthPrefByOrder.isEmpty then
		return;
	endif;
	
	tmpArray := tmpData.allBerthPrefByOrder;
	
	foreach berthPref in tmpArray do
		create newBerthPref persistent;
		newBerthPref.setForUpdate(berthPref, _passport);
		self.addBerthPreferenceToColls(newBerthPref);
	endforeach;
							
end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="e8eab5d7-c668-4ee6-9379-c6d293434807">
        <updating/>
        <source>setForCreate(_pxyObj: HMS_VoyageData; _passport: CM_Passport input) updating;
//--------------------------------------------------
// Created:	29 March 2004 By: cnwgd1
//--------------------------------------------------
vars
	pxyMovement,
	newMovement,
	prevMovement	: HMS_VoyageMovement;
begin
	inheritMethod(_pxyObj, _passport);

	if _passport.hasErrors() then
		return;
	endif;
	
	//create the voyage berth preferences from the vessel
	if _pxyObj.allBerthPreferencesArray.isEmpty then
		self.setDefaultBerthPreferences(_passport);
	endif;
					
	self.createTransaction(TRANS_TYPE_HMSVoyageAdd, null, _pxyObj, null, _passport);				

end;</source>
        <Parameter name="_pxyObj" type="HMS_VoyageData"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="a377c394-8b16-469b-9f2d-43aa8c741813">
        <updating/>
        <source>setForUpdate(_pxyVoyageData : HMS_VoyageData; _passport : CM_Passport input) updating;
//-----------------------------------------
// Created: March 2004 By: cnwgd1
//-----------------------------------------
// Changed On	By			Reason
// ----------	--------	-------------------------------------------------
// 24/01/2014	cnwdap1		PAR #33337 CCMS PTR 2214 HMS Enhancements
// 16/05/2016	cnwns1	TFS 488 - Multi Timezone Support
// 23/11/2018	jlgdap1		Initial creation TFS 41949 PEL1 Tax Number and Stamps based on SKTD and BUT Certificates on a Voyagevars
vars
	realMovement,
	prevMovement,
	pxyMovement	: HMS_VoyageMovement;
	prevVoyage,
	theVoyage	: CM_Voyage;
	numOfHours	: Integer;
	defaultDTForMove,
	tmpArrivalDT,
	tmpDepartDT : TimeStamp;
	tmpMovementsToDelete	: HMS_VoyageMovementSet;
	pilotExemptChanged : Boolean;
	now : TimeStamp;

begin

	create tmpMovementsToDelete transient;
	self.allVoyageMovements.copy(tmpMovementsToDelete);

	if (not app.isConverting) then
		self.createTransaction(TRANS_TYPE_HMSVoyageEdit, null, _pxyVoyageData, null, _passport);		
	endif;	
	
	self.berthPriority			:= _pxyVoyageData.berthPriority;
	self.coastalServiceVessel	:= _pxyVoyageData.coastalServiceVessel;
	self.countryCode			:= _pxyVoyageData.countryCode;
	self.dim_Beam				:= _pxyVoyageData.dim_Beam;
	self.dim_DeadWeight			:= _pxyVoyageData.dim_DeadWeight;
	self.dim_DraftAft			:= _pxyVoyageData.dim_DraftAft;
	self.dim_DraftFore			:= _pxyVoyageData.dim_DraftFore;
	self.dim_GrossRegTonnes		:= _pxyVoyageData.dim_GrossRegTonnes;
	self.dim_NetRegTonnes		:= _pxyVoyageData.dim_NetRegTonnes;		// QNS 2178
	//LOA (self.dim_LengthOverall) done last as movement marks may need updating
	//self.dim_LengthOverall	:= _pxyVoyageData.dim_LengthOverall;
	self.dist_BowToFwdContainer := _pxyVoyageData.dist_BowToFwdContainer;
	self.dist_BridgeToBow		:= _pxyVoyageData.dist_BridgeToBow;
	self.dist_BridgeToStern		:= _pxyVoyageData.dist_BridgeToStern;
	self.dist_SternToAftContainer:= _pxyVoyageData.dist_SternToAftContainer;
	self.dist_SternToBunker		:= _pxyVoyageData.dist_SternToBunker;
	self.estTieUpTime			:= _pxyVoyageData.estTieUpTime;
	self.excludeReport			:= _pxyVoyageData.excludeReport;
	self.hasBowThrust			:= _pxyVoyageData.hasBowThrust;
	self.hasFixedProp			:= _pxyVoyageData.hasFixedProp;
	self.hasHoldTanks			:= _pxyVoyageData.hasHoldTanks;
	self.hasRamp				:= _pxyVoyageData.hasRamp;
	self.hasSternThrust			:= _pxyVoyageData.hasSternThrust;
	
	//09 May 2012	NDL	Par 29496
	if self.isPilotExempt &lt;&gt; _pxyVoyageData.isPilotExempt then
		pilotExemptChanged := true;
		now := app.actualTimeServer;// 16 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	endif;
	self.isPilotExempt			:= _pxyVoyageData.isPilotExempt;

    self.setMyBerth( _pxyVoyageData.getMyBerth);
    self.myHarbour				:= _pxyVoyageData.myHarbour;
	self.myLineCompany 			:= _pxyVoyageData.myLineCompany;
	self.myShippingAgent 		:= _pxyVoyageData.myShippingAgent;
	self.myVisitType			:= _pxyVoyageData.myVisitType;
	self.myTidalClass 			:= _pxyVoyageData.myTidalClass;
	self.myTidalClassDept 		:= _pxyVoyageData.myTidalClassDept;
 	self.myVesselCategoryIn 	:= _pxyVoyageData.myVesselCategoryIn;
 	self.myVesselCategoryOut 	:= _pxyVoyageData.myVesselCategoryOut;	
	self.myVesselType			:= _pxyVoyageData.myVesselType;
	self.myPilot 				:= _pxyVoyageData.myPilot;
	self.myMaster	 			:= _pxyVoyageData.myMaster;

	self.numLCrewLetGo 			:= _pxyVoyageData.numLCrewLetGo;
	self.numLCrewTieUp 			:= _pxyVoyageData.numLCrewTieUp;
	self.numTugsIn 				:= _pxyVoyageData.numTugsIn;
	self.numTugsOut 			:= _pxyVoyageData.numTugsOut;
    self.portArrivingFromCode 	:= _pxyVoyageData.portArrivingFromCode;
    self.portDepartingToCode 	:= _pxyVoyageData.portDepartingToCode;
	self.remarksGeneral 		:= _pxyVoyageData.remarksGeneral;
	self.remarksPilotOnly 		:= _pxyVoyageData.remarksPilotOnly;
	self.remarksPreviousNames 	:= _pxyVoyageData.remarksPreviousNames;
	self.requiresTow 			:= _pxyVoyageData.requiresTow;	//01 Jun 2018	NDL	TFS 38905
	self.isZeroRatedTax 		:= _pxyVoyageData.isZeroRatedTax;	//12 Jun 2018	NDL	TFS 39141
	self.isZeroRatedTaxCargo	:= _pxyVoyageData.isZeroRatedTaxCargo;			// TFS 41949
    self.shortComment 			:= _pxyVoyageData.shortComment;
    
    //Used by HMS to indicate if voyage is locked or not and is nothing to do with CM_Voyage::status
    self.voyageStatus			:= _pxyVoyageData.voyageStatus;
    
 	theVoyage 					:= self.myVoyage;
    self.vesselCode				:= theVoyage.vesselCode;
    self.vesselName				:= theVoyage.vesselName;
	
	if self.vesselName &lt;&gt; null
	and self.vesselName &lt;&gt; self.remarksPreviousNames then
		if (not self.remarksPreviousNames.cnContains(self.vesselName)) then
			self.remarksPreviousNames := self.remarksPreviousNames &amp; ' ' &amp; self.vesselName;
		endif;
	endif;

	//ARGGH DELETE MOVEMENTS FIRST OTHERWISE WE GET VALIDATION ERRORS FOR MOVEMENTS WE ARE DELETING
	foreach pxyMovement in _pxyVoyageData.allVoyageMovements do
		realMovement := pxyMovement.pxyGetRealObject();
		if realMovement &lt;&gt; null then
			if tmpMovementsToDelete.includes(realMovement) then
				tmpMovementsToDelete.remove(realMovement);
			endif;
		endif;
	endforeach;
	
	// Now delete the movements not required
	if (not tmpMovementsToDelete.isEmpty) then
		foreach realMovement in tmpMovementsToDelete do
			realMovement.erase(NORMAL_ERASE);
		endforeach;
	endif;
	
	//ALSO if arrive/depart dates have changed then need to update the movement arrive/depart date
	tmpArrivalDT := theVoyage.arrivedDT;
	tmpDepartDT := theVoyage.departedDT;
	
	foreach pxyMovement in _pxyVoyageData.allVoyageMovements do
		realMovement := pxyMovement.pxyGetRealObject();
		
		if realMovement = null or (not global.isValidObject(realMovement)) then
			// must be a create
			create realMovement as pxyMovement.class persistent;
		endif;
		realMovement.setMyVoyageGlobal(self.myVoyage.myVoyageGlobalArrival);
		realMovement.setMyHMSVoyageData(self);	
		realMovement.setForUpdateMovement(pxyMovement, _passport, false, false);
		
		//09 May 2012	NDL	Par 29496
		if pilotExemptChanged then
			realMovement.setPilotExemptOnFutureMove( now );
		endif;

		// ensure that Tidal Class is set correctly in movements
		if realMovement.moveType = HMSMovementTypeDeparture and
		   realMovement.myTidalClass = null then
			realMovement.setTidalClass(self.myTidalClassDept);
		elseif realMovement.myTidalClass = null then
			realMovement.setTidalClass(self.myTidalClass);
		endif;			

		prevMovement := realMovement;
	endforeach;
	
	/*
	
	foreach realMovement in self.allVoyageMovements do

		// update arrival move PAR 10872	
		if realMovement.moveType = HMSMovementTypeArrival then
			if realMovement.occursOnDTNEW &lt;&gt; tmpArrivalDT then
				//realMovement.setOccursOnDT(tmpArrivalDT, null, false, false);
				realMovement.setTimings(tmpArrivalDT, realMovement.steamingTime, false);
			endif;
			if realMovement.myTidalClass = null then
				realMovement.setTidalClass(self.myTidalClass);
			endif;
		
		// update departure move PAR 10872
		elseif realMovement.moveType = HMSMovementTypeDeparture then
			if realMovement.occursOnDTNEW &lt;&gt; tmpDepartDT then
				//realMovement.setOccursOnDT(tmpDepartDT, null, false, false);
				realMovement.setTimings(tmpDepartDT, realMovement.steamingTime, false);
			endif;
			if realMovement.myTidalClass = null then
				realMovement.setTidalClass(self.myTidalClassDept);
			endif;			

		// shift movement auto adjust if out of range
		elseif realMovement.occursOnDTNEW &gt; tmpDepartDT	or 
			   realMovement.occursOnDTNEW &lt; tmpArrivalDT then
		
		 	// Lorcan 19/12/2006 defaultDTForMove not set prior to this so I have removed first bit of this
			
		 	// Set default DT to be half way between the arrival movement and the next movement for the voyage
			// Calculate the number of hours between the arrival move and the next move for the voyage
//			if defaultDTForMove &lt;&gt; null then
//				numOfHours := tmpArrivalDT.differenceInHours(defaultDTForMove);			
//			else
				numOfHours := tmpArrivalDT.differenceInHours(tmpDepartDT);
//			endif;
			
			// if the length of stay is less than two days then set the movement time to be
			// the arrival time + one hour, otherwise problems occur when trying to set date and time
			defaultDTForMove := tmpArrivalDT.changeByXXHours((numOfHours/2).Integer);
	
			//realMovement.setOccursOnDT(defaultDTForMove, null, false,  false);
			realMovement.setTimings(defaultDTForMove, realMovement.steamingTime, false);
			
			if realMovement.myTidalClass = null then
				realMovement.setTidalClass(self.myTidalClass);
			endif;			
											
		endif;
	
	endforeach;
	
	*/
	

    if theVoyage.archived
    and (not self.archived) then
    	self.setAllMovementsArchived(_passport);
    endif; 	
 	//self.archived := theVoyage.archived; //Used in the contraints	
	
 	// Deselect discharge cargo that is no longer selected
	//self.allCommodityDischarge.clear();										// ### TFS 53132 21Apr2022 NAVPW1 - Obsolete now using Cargo Forecasts instead on CM_Voyage
 	//_pxyVoyageData.allCommodityDischarge.copy(self.allCommodityDischarge);	// ### TFS 53132 21Apr2022 NAVPW1 - Obsolete now using Cargo Forecasts instead on CM_Voyage
 	
 	// Deselect load cargo that is no longer selected
 	//self.allCommodityLoad.clear();											// ### TFS 53132 21Apr2022 NAVPW1 - Obsolete now using Cargo Forecasts instead on CM_Voyage
 	//_pxyVoyageData.allCommodityLoad.copy(self.allCommodityLoad);				// ### TFS 53132 21Apr2022 NAVPW1 - Obsolete now using Cargo Forecasts instead on CM_Voyage

 	// Deselect discharge stevedores that is no longer selected
 	self.allStevedoresDischarge.clear();
	_pxyVoyageData.allStevedoresDischarge.copy(self.allStevedoresDischarge);

 	// Deselect load stevedores that is no longer selected
	self.allStevedoresLoad.clear();
 	_pxyVoyageData.allStevedoresLoad.copy(self.allStevedoresLoad);
 	
 	// do before berth preferences due to marks being updated
	self.setLOA(_pxyVoyageData.dim_LengthOverall);
	
	self.setForUpdateBerthPreferences(_pxyVoyageData, _passport);	 	
	
	self.setForUpdateMovementResources(_pxyVoyageData, _passport);				// PAR #33337
	
	self.myTowingVoyage := _pxyVoyageData.myTowingVoyage;	//25 Jun 2018	NDL	TFS 39248
	
epilog
	delete tmpMovementsToDelete;
end;</source>
        <Parameter name="_pxyVoyageData" type="HMS_VoyageData"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setForUpdateBerthPreferences" id="c940ffa8-868d-4d58-a3ee-66f47096e0ca">
        <updating/>
        <source>setForUpdateBerthPreferences(_pxyVoyageData : HMS_VoyageData; _passport : CM_Passport input)updating, protected;
//--------------------------------------------------
// Created:	25 August 2004 By: cnwgd1
//--------------------------------------------------
vars
	berthPref,
	realBerthPref : HMS_BerthPreferenceVoyageData;
	tmpBerthPref : HMS_BerthPreference;
	tmpBerthPrefArray,
	tmpToDeleteArray : HMS_BerthPrefArray;
begin
	
	create tmpToDeleteArray transient;
	self.allBerthPreferencesByName.copy(tmpToDeleteArray);	
		
	self.allBerthPreferencesByName.clear();
	self.allBerthPreferencesArray.clear();
	
	//Update the berth preferences and their order
	tmpBerthPrefArray := _pxyVoyageData.allBerthPreferencesArray;
	foreach tmpBerthPref in tmpBerthPrefArray do
		berthPref := tmpBerthPref.HMS_BerthPreferenceVoyageData;
		if berthPref.isTransient then
			realBerthPref := berthPref.pxyGetRealObject();
			if realBerthPref &lt;&gt; null then
				if tmpToDeleteArray.includes(realBerthPref) then
					tmpToDeleteArray.remove(realBerthPref);
				endif;
				//unpdate it
				realBerthPref.setForUpdate(berthPref, _passport);
			else //Create newbee
				create realBerthPref persistent;
				realBerthPref.setForCreate(berthPref, _passport);
			endif;
			self.addBerthPreferenceToColls(realBerthPref);
		else
			self.addBerthPreferenceToColls(realBerthPref);
			if tmpToDeleteArray.includes(berthPref) then
				tmpToDeleteArray.remove(berthPref);
			endif;
		endif;	
	endforeach;
	
	//Delete the unwanted berth preferences
	tmpToDeleteArray.purge();
	
epilog
	delete tmpToDeleteArray;
end;</source>
        <access>protected</access>
        <Parameter name="_pxyVoyageData" type="HMS_VoyageData"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setForUpdateMovementResources" id="2a2bebf2-4875-4d91-abd6-dc3cbee4513a">
        <updating/>
        <source>setForUpdateMovementResources(_pxyVoyageData : SelfType; _passport : CM_Passport input) updating, protected;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 23/1/2014	cnwdap1		Initial creation PAR #33337 CCMS PTR 2214 HMS Enhancements
// 15/02/2021	navdap1		TFS 50720 PNL How to remove contract movement resources
//
vars
	movementResourceDict	: HMS_MovementResourceByMovement;
	realMovementResource,
	tmpMovementResource,
	movementResource		: HMS_ResourceTypeForMovement;

begin
	create movementResourceDict transient;
	self.allDefaultMovementResources.copy(movementResourceDict);
		
	self.allDefaultMovementResources.clear();
		
	foreach tmpMovementResource in _pxyVoyageData.allDefaultMovementResources do
		movementResource := tmpMovementResource;
		if movementResource.isTransient then
			realMovementResource := movementResource.pxyGetRealObject();
			if realMovementResource &lt;&gt; null then
				if movementResourceDict.includes(realMovementResource) then
					movementResourceDict.remove(realMovementResource);
				endif;
				// update it
				self.allDefaultMovementResources.add(realMovementResource);			// TFS 50720
				realMovementResource.setForUpdate(movementResource, _passport);
			else //Create newbee
				create realMovementResource persistent;
				self.allDefaultMovementResources.add(realMovementResource);			// TFS 50720
				realMovementResource.setForCreate(movementResource, _passport);
			endif;
			// TFS 50720 moved further up - we need the myHMSVoyageData reference	// TFS 50720
			//self.allDefaultMovementResources.add(realMovementResource);			// TFS 50720
		else
			self.allDefaultMovementResources.add(realMovementResource);		
			if movementResourceDict.includes(movementResource) then
				movementResourceDict.remove(movementResource);
			endif;
		endif;	
	endforeach;
	
	//Delete the unwanted resource movements
	movementResourceDict.purge();
	
epilog
	delete movementResourceDict;	
end;</source>
        <access>protected</access>
        <Parameter name="_pxyVoyageData" type="SelfType"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setFromCMIFVoyageGlobal" id="1c77b637-9917-4c88-9bf1-c050c622e521">
        <updating/>
        <source>setFromCMIFVoyageGlobal(_cmif_VoyageGlobal : CMIF_VoyageGlobal; _harbour : HMS_Harbour; _passport : CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:     14 September 2006 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	voyMove		: HMS_VoyageMovement;
	theVoyage	: CM_Voyage;
	numOfHours	: Integer;
	defaultDTForMove,
	tmpArrivalDT,
	tmpDepartDT : TimeStamp;
	
	masterVoyageData	: HMS_VoyageData;
begin

	if (not self.isTransient) then
		app.raiseUnexpectedProgramError(class.name, method.name, 'call on a persistent object');
		return;
	endif;

	masterVoyageData := _cmif_VoyageGlobal.myHMSVoyageData;
	if masterVoyageData = null then
		app.raiseUnexpectedProgramError(class.name, method.name, '_cmif_VoyageGlobal.myHMSVoyageData is null');
		return;
	endif;

	self.berthPriority			:= masterVoyageData.berthPriority;
	self.coastalServiceVessel	:= masterVoyageData.coastalServiceVessel;
	self.countryCode			:= masterVoyageData.countryCode;
	self.dim_Beam				:= masterVoyageData.dim_Beam;
	self.dim_DeadWeight			:= masterVoyageData.dim_DeadWeight;
	self.dim_DraftAft			:= masterVoyageData.dim_DraftAft;
	self.dim_DraftFore			:= masterVoyageData.dim_DraftFore;
	self.dim_GrossRegTonnes		:= masterVoyageData.dim_GrossRegTonnes;
	self.dim_NetRegTonnes		:= masterVoyageData.dim_NetRegTonnes;		// QNS 2178
	//LOA (self.dim_LengthOverall) done last as movement marks may need updating
	//self.dim_LengthOverall	:= masterVoyageData.dim_LengthOverall;
	self.dist_BowToFwdContainer := masterVoyageData.dist_BowToFwdContainer;
	self.dist_BridgeToBow		:= masterVoyageData.dist_BridgeToBow;
	self.dist_BridgeToStern		:= masterVoyageData.dist_BridgeToStern;
	self.dist_SternToAftContainer:= masterVoyageData.dist_SternToAftContainer;
	self.dist_SternToBunker		:= masterVoyageData.dist_SternToBunker;
	self.estTieUpTime			:= masterVoyageData.estTieUpTime;
	self.excludeReport			:= masterVoyageData.excludeReport;
	self.hasBowThrust			:= masterVoyageData.hasBowThrust;
	self.hasFixedProp			:= masterVoyageData.hasFixedProp;
	self.hasHoldTanks			:= masterVoyageData.hasHoldTanks;
	self.hasRamp				:= masterVoyageData.hasRamp;
	self.hasSternThrust			:= masterVoyageData.hasSternThrust;
	self.isPilotExempt			:= masterVoyageData.isPilotExempt;

    
    self.myHarbour				:= masterVoyageData.myHarbour;
	self.myLineCompany 			:= masterVoyageData.myLineCompany;
	self.myShippingAgent 		:= masterVoyageData.myShippingAgent;
	self.myVisitType			:= masterVoyageData.myVisitType;
	self.myVesselType			:= masterVoyageData.myVesselType;
	self.myPilot 				:= masterVoyageData.myPilot;
	self.myMaster	 			:= masterVoyageData.myMaster;

	self.numLCrewLetGo 			:= masterVoyageData.numLCrewLetGo;
	self.numLCrewTieUp 			:= masterVoyageData.numLCrewTieUp;
	self.numTugsIn 				:= masterVoyageData.numTugsIn;
	self.numTugsOut 			:= masterVoyageData.numTugsOut;
    self.portArrivingFromCode 	:= masterVoyageData.portArrivingFromCode;
    self.portDepartingToCode 	:= masterVoyageData.portDepartingToCode;
	self.remarksGeneral 		:= masterVoyageData.remarksGeneral;
	self.remarksPilotOnly 		:= masterVoyageData.remarksPilotOnly;
	self.remarksPreviousNames 	:= masterVoyageData.remarksPreviousNames;    	
    self.shortComment 			:= masterVoyageData.shortComment;
    
    //Used by HMS to indicate if voyage is locked or not and is nothing to do with CM_Voyage::status
    self.voyageStatus			:= masterVoyageData.voyageStatus;
    
 	theVoyage 					:= self.myVoyage;
    self.vesselCode				:= theVoyage.vesselCode;
    self.vesselName				:= theVoyage.vesselName;
	
	if self.vesselName &lt;&gt; null
	and self.vesselName &lt;&gt; self.remarksPreviousNames then
		if (not self.remarksPreviousNames.cnContains(self.vesselName)) then
			self.remarksPreviousNames := self.remarksPreviousNames &amp; ' ' &amp; self.vesselName;
		endif;
	endif;

	//ALSO if arrive/depart dates have changed then need to update the movement arrive/depart date
	// we dont do this from setFromCMIFVoyageGlobal
	/*
	tmpArrivalDT := theVoyage.arrivedDT;
	tmpDepartDT := theVoyage.departedDT;
	
	// update the shift movements first PAR 10872	
	foreach voyMove in self.allVoyageMovements do

		// update arrival move PAR 10872	
		if voyMove.moveType = HMSMovementTypeArrival then
			if voyMove.occursOnDTNEW &lt;&gt; tmpArrivalDT then
				voyMove.setOccursOnDT(tmpArrivalDT, false);
			endif;
			if voyMove.myTidalClass = null then
				voyMove.setTidalClass(self.myTidalClass);
			endif;
		
		// update departure move PAR 10872
		elseif voyMove.moveType = HMSMovementTypeDeparture then
			if voyMove.occursOnDTNEW &lt;&gt; tmpDepartDT then
				voyMove.setOccursOnDT(tmpDepartDT, false);
			endif;
			if voyMove.myTidalClass = null then
				voyMove.setTidalClass(self.myTidalClassDept);
			endif;			

		// shift movement auto adjust if out of range
		elseif voyMove.occursOnDTNEW &gt; tmpDepartDT
		or voyMove.occursOnDTNEW &lt; tmpArrivalDT then
		
		 	// Set default DT to be half way between the arrival movement and the next movement for the voyage
			// Calculate the number of hours between the arrival move and the next move for the voyage
			if defaultDTForMove &lt;&gt; null then
				numOfHours := tmpArrivalDT.differenceInHours(defaultDTForMove);			
			else
				numOfHours := tmpArrivalDT.differenceInHours(tmpDepartDT);
			endif;
			
			// if the length of stay is less than two days then set the movement time to be
			// the arrival time + one hour, otherwise problems occur when trying to set date and time
			defaultDTForMove := tmpArrivalDT.changeByXXHours((numOfHours/2).Integer);
	
			voyMove.setOccursOnDT(defaultDTForMove, false);
				
			if voyMove.myTidalClass = null then
				voyMove.setTidalClass(self.myTidalClass);
			endif;			
											
		endif;
		
	endforeach;
	*/

    if theVoyage.archived
    and (not self.archived) then
    	self.setAllMovementsArchived(_passport);
    endif; 	
 	//self.archived := theVoyage.archived; //Used in the contraints	
	
 	// Deselect discharge cargo that is no longer selected
 	//self.allCommodityDischarge.clear();										// ### TFS 53132 20Apr2022 NAVPW1 - Obsolete now using Cargo Forecasts instead on CM_Voyage
 	//masterVoyageData.allCommodityDischarge.copy(self.allCommodityDischarge);	// ### TFS 53132 20Apr2022 NAVPW1 - Obsolete now using Cargo Forecasts instead on CM_Voyage
 	
 	// Deselect load cargo that is no longer selected
 	//self.allCommodityLoad.clear();											// ### TFS 53132 21Apr2022 NAVPW1 - Obsolete now using Cargo Forecasts instead on CM_Voyage
 	//masterVoyageData.allCommodityLoad.copy(self.allCommodityLoad);			// ### TFS 53132 21Apr2022 NAVPW1 - Obsolete now using Cargo Forecasts instead on CM_Voyage

 	// Deselect discharge stevedores that is no longer selected
 	self.allStevedoresDischarge.clear();
	masterVoyageData.allStevedoresDischarge.copy(self.allStevedoresDischarge);

 	// Deselect load stevedores that is no longer selected
	self.allStevedoresLoad.clear();
 	masterVoyageData.allStevedoresLoad.copy(self.allStevedoresLoad);
 	
 	// do before berth preferences due to marks being updated
	self.setLOA(masterVoyageData.dim_LengthOverall);
	
	self.setForUpdateBerthPreferences(masterVoyageData, _passport);	 
	
	self.myHarbour				:= _harbour;
	self.setMyBerth( _harbour.allBerths.first);
	self.myTidalClass 			:= app.myRoot.allTidalClasses.first;
	self.myTidalClassDept 		:= app.myRoot.allTidalClasses.first;
 	self.myVesselCategoryIn 	:= masterVoyageData.myVesselCategoryIn;
 	self.myVesselCategoryOut 	:= masterVoyageData.myVesselCategoryOut;	
	
end;</source>
        <Parameter name="_cmif_VoyageGlobal" type="CMIF_VoyageGlobal"/>
        <Parameter name="_harbour" type="HMS_Harbour"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setHasRamp" id="8fe459c6-9900-42e3-afa8-e7e030a25777">
        <updating/>
        <source>setHasRamp(_ramp : Boolean) updating;
/*

Purpose:		// TFS 40236	

Parameters:			

Return Value:		

Date		Who		Reason
13 August 2018	jlgab1	Initial creation

*/

vars

begin
	self.hasRamp := _ramp;
epilog

