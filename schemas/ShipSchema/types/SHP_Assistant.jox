    <JadeMethod name="showKPICargoCountForm" id="9235ff6e-6311-45f6-954d-231b938ed506">
        <source>showKPICargoCountForm(_months : Integer; _initMonth : Date; _cargoTypes : CM_CargoTypesByIdDict;_xmlColourAltRow : Integer;_xmlColourCargoType : Integer;_xmlColourRowColour : Integer;_xmlColourTotals : Integer);
/*

Date		    Who			Reason
15 June 2010	cnwas3	  	ccms 1134
8 February 2022 navcs2		TFS 52784 Added Boolean flags to method signature to be able to select certain rows in a table
*/

vars
	kpiCountForm : SHP_KPICargoCounterForm;
begin
	
	kpiCountForm := app.loadForm(SHP_KPICargoCounterForm, SHP_Assistant, false, false, true, self.myTerminal, null).SHP_KPICargoCounterForm;
	
	if kpiCountForm = null then
		return;
	endif;
	kpiCountForm.xmlColourAltRow :=_xmlColourAltRow;
	kpiCountForm.xmlColourCargoType :=_xmlColourCargoType;
	kpiCountForm.xmlColourRowColour :=_xmlColourRowColour;
	kpiCountForm.xmlColourTotals :=_xmlColourTotals;


	kpiCountForm.centreOverParent(10);
	kpiCountForm.isChildForm:=true;
	kpiCountForm.show(); 
	kpiCountForm.doShowCountResults(_months,_initMonth.cnEcGetFirstDayOfMonth(),_cargoTypes, kpiCountForm.isContainerCount, kpiCountForm.isContainerTeu, kpiCountForm.isGenTeu, kpiCountForm.isGenWeight, kpiCountForm.isGenCount, kpiCountForm.isGenVolume);
	
epilog
end;</source>
        <Parameter name="_months" type="Integer"/>
        <Parameter name="_initMonth" type="Date"/>
        <Parameter name="_cargoTypes" type="CM_CargoTypesByIdDict"/>
        <Parameter name="_xmlColourAltRow" type="Integer"/>
        <Parameter name="_xmlColourCargoType" type="Integer"/>
        <Parameter name="_xmlColourRowColour" type="Integer"/>
        <Parameter name="_xmlColourTotals" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="showKPIVoyageCapacityForm" id="18ab8e9e-8cf9-4c15-b55b-7f7bb4439e3e">
        <source>showKPIVoyageCapacityForm(_voyage :CM_Voyage; _menuAction :CMUI_MenuAction);
/*
Date		Who		Reason
18 August 2011	cnwcs5	Initial creation - CCMS MES 1033 / par 27951 RORO KPI
*/
vars
	form 		: SHP_VoyageCargoCounterForm;
	menuAction 	: CMUI_MenuAction;
begin
	menuAction := app.myController.createMenuAction(PmShipVoyageCargoCounter, null, _menuAction, self.myTerminal);
	
	if menuAction = null then
		return;
	endif;
	
	form := menuAction.goToObject(null, null, false, null).SHP_VoyageCargoCounterForm;

	if form = null then
		return;
	endif;
	
	if _voyage &lt;&gt; null then
		form.myCurrentVoyage := _voyage;
	else
		form.myCurrentVoyage := app.myCurrentVoyage;
	endif;
	
	form.show();
end;</source>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_menuAction" type="CMUI_MenuAction"/>
    </JadeMethod>
