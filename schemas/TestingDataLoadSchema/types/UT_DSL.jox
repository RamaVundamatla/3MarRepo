    <JadeMethod name="addGate" id="f9f2f0e5-110b-49e2-a594-f439ed039795">
        <source>addGate(_gateId : String; _dual, _in, _out, _promptRFID : Boolean; _icArea : CM_InterchangeArea; _gateAreas : StringArray) : CM_Gate;

/*

Purpose:		Add a Gate	

Parameters		_gateAreas : Format for this is &lt;Area Name&gt;;&lt;Comment&gt;;&lt;Area Type&gt;;&lt;In&gt;;&lt;Out&gt;;&lt;Lanes&gt;;

Date			Who		Reason
05/12/2011		cnwmh5	Initial creation

*/

vars

	pxyGate							: CM_Gate;
	gate							: CM_Gate;
	gateUsage						: CM_GateAreaUsage;
	obj								: Object;
	
	gadArray						: StringArray;
	objArray						: ObjectArray;
	
	str								: String;
	activeLanes						: String;
	
begin

	self.deleteGate(_gateId);

	create pxyGate transient;
			
	pxyGate.setProxy(_gateId,				// Id / Code
					 _dual,					// Dual
					 _in, 					// In
					 _out,					// out
					 _promptRFID,			// Prompt for RFID
					 _icArea,					// Interchange area
					 self.getTerminal());	// Terminal
					 
	// create gate areas
	create gadArray transient;
	foreach str in _gateAreas do
		//gadArray := str.cnGetTokens(";");
		gadArray.clear();
		str.getTokensForDelimiter(";", gadArray);
		if gadArray.size &gt;= 6 then
			activeLanes := gadArray[7];
		endif;
		pxyGate.pxyAddNewGateAreaUT(gadArray[1], gadArray[2], gadArray[3].Integer, gadArray[4].Boolean,
			gadArray[5].Boolean, gadArray[6].Integer, activeLanes);
		//delete gadArray;
	endforeach;
	
	app.myTrxCA.trxCreateGate(pxyGate, gate, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	return gate;
	
epilog
	create objArray transient;
	pxyGate.allGateAreas_IN.copy(objArray);
	pxyGate.allGateAreas_OUT.copy(objArray);
	foreach obj in objArray do
		obj.CM_GateAreaUsage.erase(NORMAL_ERASE);
	endforeach;
	delete objArray;
	delete gadArray;
	delete pxyGate;
end;</source>
        <Parameter name="_gateId" type="String"/>
        <Parameter name="_dual" type="Boolean"/>
        <Parameter name="_in" type="Boolean"/>
        <Parameter name="_out" type="Boolean"/>
        <Parameter name="_promptRFID" type="Boolean"/>
        <Parameter name="_icArea" type="CM_InterchangeArea"/>
        <Parameter name="_gateAreas" type="StringArray"/>
        <ReturnType type="CM_Gate"/>
    </JadeMethod>
    <JadeMethod name="addGeneralCargoArea" id="283e4608-d2b9-43d2-91d3-335156296d71">
        <source>addGeneralCargoArea(_gcId, _gcComment: String; _rows, _columns : Integer; _units : Integer; _allInterchangeAreas : CM_InterchangeAreaArray;
		_defaultInterchangeArea : CM_InterchangeArea) : CM_IrregularBlockArea;

/*

Purpose:		Add a General Cargo Area

Date			Who		Reason
06/12/2011		cnwmh5	Initial creation

*/

vars

	pxyGeneralCargoArea			: CM_IrregularBlockArea;
	generalCargoArea			: CM_TerminalAreaMaster;
	locationProxy 				: CM_IrregularBlockController;
	region 						: PointArray;
	topLeft,
	bottomRight					: Point;
	pDO : CM_YADeckingOptionsTA;
	autoRestrictions : Boolean;
	rackOrGroundArray			: StringArray;
	areaDetailsArray			: StringArray;
	tempStr						: String;
begin

	self.deleteTerminalArea(_gcId);
	
	autoRestrictions := false;
	if self.opts.includesKey("AutoRestrictions") then
		autoRestrictions := self.opts.bool("AutoRestrictions");
	endif;

	create pxyGeneralCargoArea transient;
	
	pxyGeneralCargoArea.setProxy(_gcId, 
								 _gcComment,			// Comment
								 TA_TYPE_IRREGULAR_BLOCK_AREA,					// Type
								 _rows,					// rows
								 _columns, 				// columns
								 _units,					// Units
								 null, 					// row labels
								 null,					// Column Labels
								 autoRestrictions, 				// autoRestrictions
								false,					// stockControlled
								self.getTerminal(),		// Terminal
								_allInterchangeAreas,	// All Interchange Areas
								_defaultInterchangeArea); // Default Interchange Area
								
	create pDO transient;
	pDO.setProxy(false, true, pxyGeneralCargoArea);
	pDO.setProxyRules(DeckingRule_Default, DeckingRule_Default);
	
	app.myTrxCA.trxCreateTerminalArea(pxyGeneralCargoArea, generalCargoArea, app.myPassport);
	self.assertTrueMsg(app.myPassport.trxCompletedOK(), app.myPassport.getAllErrorsWarningsAsString());
	
	// 07/03/2018 jlgmh5 
	if self.opts.includesKey("RackOrGround") then
		create rackOrGroundArray transient;
		create areaDetailsArray transient;
		tempStr := self.opts.str("RackOrGround");
		tempStr.getTokensForDelimiter(";", rackOrGroundArray);
		foreach tempStr in rackOrGroundArray do
			tempStr.getTokensForDelimiter(",", areaDetailsArray);
			foreach tempStr in areaDetailsArray do
				self.addGCRackOrGround(generalCargoArea.CM_IrregularBlockArea, areaDetailsArray[1].Integer, 
					areaDetailsArray[2].Integer, areaDetailsArray[3].Integer, areaDetailsArray[4].Integer, 
					areaDetailsArray[5]);
				self.assertNoTrxErrorsOrWarnings();
			endforeach;
		endforeach;	
	endif;
	
	return generalCargoArea.CM_IrregularBlockArea;

epilog
	delete pDO; // This is deleted by pxyGeneralCargoArea delete so this delete must be first.
	delete pxyGeneralCargoArea;
	delete rackOrGroundArray;
	delete areaDetailsArray;
end;</source>
        <Parameter name="_gcId" type="String"/>
        <Parameter name="_gcComment" type="String"/>
        <Parameter name="_rows" type="Integer"/>
        <Parameter name="_columns" type="Integer"/>
        <Parameter name="_units" type="Integer"/>
        <Parameter name="_allInterchangeAreas" type="CM_InterchangeAreaArray"/>
        <Parameter name="_defaultInterchangeArea" type="CM_InterchangeArea"/>
        <ReturnType type="CM_IrregularBlockArea"/>
    </JadeMethod>
    <JadeMethod name="addGenerator" id="48b1fcd4-e909-459e-93de-b1cc6f5c6365">
        <source>addGenerator(_id: String; _operator:CM_Operator) : CM_TrackedItem;
//
// 19 May 2017	cnwrs1	TFS 4259 _ Penn Seaboard implimentation
//
vars
	pxyTI: CM_TrackedItem;
	ti : CM_TrackedItem;
	voyage : CM_Voyage;
	id : String;
begin
	id := _id;
	self.deleteTrackedItem(id, false);
	pxyTI := self.createGenerator(_id, _operator, true);
	//pxyTI.setWeight(2000, null, null);					//-cnwml2 MSL CCMS 1017
//	pxyTI.setTotalWeight(2000, null, null);				//+cnwml2 MSL CCMS 1017
//	pxyTI.setWeightTare(400);
//	pxyTI.zSetPxyImexStatus(_imexStatus);
//	pxyTI.setVolume(6.666);	// #25592. Need some volume to test. 08/11/2010
//	pxyTI.zSetPxyTotalVolume(6.666);	//03 Jun 2011	NDL Par 26504

//	if self.opts.includesKey("quantity") then							// 24/09/2012 cnmwh5 #30120/#29876
//		pxyTI.zSetPxyQuantity(self.opts.int('quantity'));
//	endif;
	
	// PAr # 31237
//	if self.opts.includesKey(UTTI_SpecialLifts) then							
//		pxyTI.zSetPxySpecialLifts(self.opts.obj(UTTI_SpecialLifts).CM_SpecialLiftByCodeDict);
//	endif;
	
	if self.opts.includesKey(UTTI_VoyageCode) then
		voyage := self.getTerminal.allVoyagesByCode.getAtKeyGeq(self.opts.str(UTTI_VoyageCode), null);
		pxyTI.setMyVoyage(voyage, app.myPassport);
	endif;
	if self.opts.includesKey(UTTI_DischargePort) then
		pxyTI.setDischargePort(self.opts.str(UTTI_DischargePort));
	endif;
	
//	if _commodity = "REEF" then
//		pxyTI.setTemperature(4);
//	endif;
		pxyTI.CM_Generator.setMyGeneratorType(app.myRoot.allGeneratorTypes.first);
	
	return self.addContainerFromProxy(pxyTI);
end;
</source>
        <Parameter name="_id" type="String"/>
        <Parameter name="_operator" type="CM_Operator"/>
        <ReturnType type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="addGeneratorAtLocation" id="bf7fd495-a031-40ba-a8e5-850e830088f2">
        <source>addGeneratorAtLocation(id: String; _operator:CM_Operator; _location : Any) : CM_Generator;
//
// 19 May 2017	cnwrs1	TFS 4259 _ Penn Seaboard implimentation
//
vars
	generator : CM_Generator;
	operatorObj : CM_Operator;

begin
	if _operator = null then
		operatorObj	:=	self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString());
	else
		operatorObj	:=	_operator;
	endif;
	
	generator := self.addGenerator(id, operatorObj).CM_Generator;
	self.move(generator, self.getLocationsController(_location));
	
	return generator;
epilog
end;</source>
        <Parameter name="id" type="String"/>
        <Parameter name="_operator" type="CM_Operator"/>
        <Parameter name="_location" type="Any"/>
        <ReturnType type="CM_Generator"/>
    </JadeMethod>
    <JadeMethod name="addGeneratorType" id="28f7cba2-ae04-452f-aa69-c1efa49a8920">
        <source>addGeneratorType(_generatorTypeID, _generatorTypeDesc : String) : CM_GeneratorType;
/*

Purpose:			

Parameters:			

Return Value:		

Date								Who						Reason
12 July 2016				cnwrh7					Initial creation

*/

vars
	pxyGeneratorType					: CM_GeneratorType;
	generatorType							: CM_GeneratorType;
	defaultWeight							: Decimal[6,2];
	type												 : String;
begin
	defaultWeight := 1234.12;
	type := "Stand-alone";
	self.deleteGeneratorType(_generatorTypeID);

	create pxyGeneratorType transient;
	
	pxyGeneratorType.setProxy(_generatorTypeID,				// Id / Code
							 _generatorTypeDesc,				// Description
						    type,
							defaultWeight			// Default Weight
							 );
												  
	app.myTrxCA.trxCreateGeneratorType(pxyGeneratorType, generatorType, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	return generatorType;

epilog
	delete pxyGeneratorType;
end;
</source>
