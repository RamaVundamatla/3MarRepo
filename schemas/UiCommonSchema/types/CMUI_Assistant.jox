    <JadeMethod name="comboBoxIconAddPictures" id="ad37df78-ae5e-49bc-b3e1-317f8abcfbfb">
        <source>comboBoxIconAddPictures(_baseScm : Schema; _groupName : String; _cmb : ComboBox input; _icon : Binary) protected;
//--------------------------------------------------
// Created:	24 March 2004 By: cnwgd1
//--------------------------------------------------
vars
	root		: CM_Root;
	category 	: ConstantCategory;
	const 		: Constant;
	constDict	: ConstantNDict;
	pictureString	: String;
	thePicture 	: Binary;
	idx 		: Integer;
begin
	if _groupName = null then
		return;
	endif;
	if _cmb = null then
		return;
	endif;
	if _baseScm = null then
		return;
	endif;
	
	category := _baseScm.getCategory(_groupName);

	if category = null then
		return;
	endif;
		
	constDict := category.getConstants();
	root := app.myRoot;
	
	foreach const in constDict do
		pictureString := const.valueAsString;
		thePicture := root.getConfig(pictureString).Binary; 
	
		idx := _cmb.addItem(pictureString);
		_cmb.itemPicture[idx] := thePicture;
		
		if _cmb.listIndex &lt; 0 then
			if thePicture = _icon then
				_cmb.listIndex := idx;
			endif;
		endif;
	endforeach;

end;</source>
        <access>protected</access>
        <Parameter name="_baseScm" type="Schema"/>
        <Parameter name="_groupName" type="String"/>
        <Parameter name="_cmb" type="ComboBox" usage="input"/>
        <Parameter name="_icon" type="Binary"/>
    </JadeMethod>
    <JadeMethod name="comboBoxInDeckGridArea" id="85a7ac15-16f5-4822-b9bc-0a318b7e10a2">
        <source>comboBoxInDeckGridArea(_cmb: CMUI_ComboBox input; _level: Integer; _type: Integer; _yaDeckingOptions: CM_YADeckingOptions);
//----------------------------------------------------------------
//	Created:	21 April 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	cmbData	: Integer;
	idx		: Integer;
begin

	_cmb.clear;
	if _level &lt;&gt; DeckingLevel_TA then
		_cmb.addItemWithData(app.getDeckingInCaption(DeckingMenu_In_Opt0), app.getDeckingOptionFromMenuIndex(DeckingMenu_In_Opt0 - DeckingMenuOffset_In));
	endif;
	_cmb.addItemWithData(app.getDeckingInCaption(DeckingMenu_In_Opt1), app.getDeckingOptionFromMenuIndex(DeckingMenu_In_Opt1 - DeckingMenuOffset_In));
	_cmb.addItemWithData(app.getDeckingInCaption(DeckingMenu_In_Opt2), app.getDeckingOptionFromMenuIndex(DeckingMenu_In_Opt2 - DeckingMenuOffset_In));
	_cmb.addItemWithData(app.getDeckingInCaption(DeckingMenu_In_Opt3), app.getDeckingOptionFromMenuIndex(DeckingMenu_In_Opt3 - DeckingMenuOffset_In));
	_cmb.addItemWithData(app.getDeckingInCaption(DeckingMenu_In_Opt4), app.getDeckingOptionFromMenuIndex(DeckingMenu_In_Opt4 - DeckingMenuOffset_In));

	if _type = TA_TYPE_FORK_LIFT_STACK then
		_cmb.addItemWithData(app.getDeckingInCaption(DeckingMenu_In_Opt5), app.getDeckingOptionFromMenuIndex(DeckingMenu_In_Opt5 - DeckingMenuOffset_In));
		_cmb.addItemWithData(app.getDeckingInCaption(DeckingMenu_In_Opt6), app.getDeckingOptionFromMenuIndex(DeckingMenu_In_Opt6 - DeckingMenuOffset_In));
		_cmb.addItemWithData(app.getDeckingInCaption(DeckingMenu_In_Opt7), app.getDeckingOptionFromMenuIndex(DeckingMenu_In_Opt7 - DeckingMenuOffset_In));
		_cmb.addItemWithData(app.getDeckingInCaption(DeckingMenu_In_Opt8), app.getDeckingOptionFromMenuIndex(DeckingMenu_In_Opt8 - DeckingMenuOffset_In));
	endif;
	
	_cmb.addItemWithData(app.getDeckingInCaption(DeckingMenu_In_Opt9), app.getDeckingOptionFromMenuIndex(DeckingMenu_In_Opt9 - DeckingMenuOffset_In));
	
	if _yaDeckingOptions &lt;&gt; null then
		foreach idx in 1 to _cmb.listCount do
			cmbData := _cmb.itemData[idx];
			if cmbData = _yaDeckingOptions.inOptionType then
				_cmb.listIndex := idx;	
				break;
			endif;				
		endforeach;
	else
		if _level = DeckingLevel_TA then
			_cmb.listIndex := 1;	
		endif;
	endif;
end;</source>
        <Parameter name="_cmb" type="CMUI_ComboBox" usage="input"/>
        <Parameter name="_level" type="Integer"/>
        <Parameter name="_type" type="Integer"/>
        <Parameter name="_yaDeckingOptions" type="CM_YADeckingOptions"/>
    </JadeMethod>
    <JadeMethod name="comboBoxInstructionEntry" id="a0592764-907c-49ae-9d37-6584dc1d60be">
        <source>comboBoxInstructionEntry(_combo : ComboBox);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 Oct 2022 navtnr20 ChangeRequest 54967: EUP - INB/OUT - Operational Instructions

*/

vars
	instructionEntry : CM_InstructionType;
	idx : Integer;
begin
	foreach instructionEntry in self.myTerminal.allInstructionTypes do
		if not instructionEntry.notAvailableForEntry then
			//_combo.itemObject[_combo.addItem(instructionEntry.code &amp; ' - ' &amp; instructionEntry.description)] := instructionEntry;	
			idx := _combo.addItem(instructionEntry.code &amp; ' - ' &amp; instructionEntry.description);
			 _combo.itemObject[idx] := instructionEntry;
		endif;
	endforeach;
epilog

end;</source>
        <Parameter name="_combo" type="ComboBox"/>
    </JadeMethod>
    <JadeMethod name="comboBoxInvAPIExtWebService" id="e90c563b-c064-411e-9f4c-a532e76072b6">
        <source>comboBoxInvAPIExtWebService(pCmb : CMUI_ComboBox input; _extWebService : CM_InvoiceAPIServiceDef);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 November 2023	navra1	Initial creation for Invoice API for TFS 54090 - EUP | Interface - MTN Invoicing Oracle &lt;&lt;54090&gt;&gt;(CR 61386/Task - 61389)

*/
vars	
	extWebService : CM_ExternalWebServiceDef;
begin
	return;
	pCmb.clear;
	foreach extWebService in app.myRoot.allExternalWebServices where extWebService.isKindOf(CM_InvoiceAPIServiceDef) do
		pCmb.addItem(extWebService.name);
		pCmb.itemObject[pCmb.newIndex] := extWebService;		
	endforeach;
	
	if _extWebService &lt;&gt; null then
		pCmb.text := _extWebService.name;
		pCmb.listObject := _extWebService;	
	endif;

epilog
	
end;
</source>
        <Parameter name="pCmb" type="CMUI_ComboBox" usage="input"/>
        <Parameter name="_extWebService" type="CM_InvoiceAPIServiceDef"/>
    </JadeMethod>
    <JadeMethod name="comboBoxInvAPIOutputMode" id="e6666449-70a7-48b8-a454-499a02e689c0">
        <source>comboBoxInvAPIOutputMode(pCmb : CMUI_ComboBox input; _mode: String);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 Nov 2023	navra1	Initial creation for Invoice API for TFS 54090 - EUP | Interface - MTN Invoicing Oracle &lt;&lt;54090&gt;&gt;(CR 61386/Task - 61389)
24 Sep 2024 jlier1 	TFS 65961 CR NSW | Dynamic Integration Development
06 May 2025 navrv30 	MTN 34737 NSW | Invoice Grouping - Terminal Configuration Change
*/

vars
	idx : Integer;
	
begin	
	pCmb.clear;
	pCmb.sorted := false;
	pCmb.addItemWithData(CM_InvoiceAPI.CONSMODE_NO_CONS,1);
	pCmb.addItemWithData(CM_InvoiceAPI.CONSMODE_INV_LINE_AND_RATE,2);
	pCmb.addItemWithData(CM_InvoiceAPI.CONSMODE_CHARGE_AND_RATE,3);
	pCmb.addItemWithData(CM_InvoiceAPI.CONSMODE_INV_LINE_CRIT_RATE, 4);
	pCmb.addItemWithData(CM_InvoiceAPI.CONSMODE_EXTERNALREF4,5);
	pCmb.addItemWithData(CM_InvoiceAPI.CONSMODE_REF4_LINETYPE_RATE,6);
	
	idx := pCmb.findString(1, self.myTerminal.getConfig(InvoiceAPIOpModeConfig).String);
	if idx &lt;= 0 then
		pCmb.listIndex := 1;
	else
		pCmb.listIndex := idx;
	endif;
	
	if _mode &lt;&gt; null then
		pCmb.text := _mode;	
	endif;

epilog	
	
end;</source>
        <Parameter name="pCmb" type="CMUI_ComboBox" usage="input"/>
        <Parameter name="_mode" type="String"/>
    </JadeMethod>
    <JadeMethod name="comboBoxInvoiceLineType" id="73130a40-ee95-4521-880f-93dba0c359de">
        <source>comboBoxInvoiceLineType(	_cmb : CMUI_ComboBox;
							_includeVoid : Boolean;
							_bank : CM_Bank input);
/*

Date		Who		Reason
17 January 2017	cnwer1	Initial creation TFS 2903

*/

vars
	invoiceType : CM_InvoiceLineDesc;
begin
	if _cmb = null or _bank = null then
		return;
	endif;
	
	_cmb.clear;
	
	_cmb.addItem(null);
	foreach invoiceType in _bank.invoiceLineDescriptors discreteLock where not invoiceType.isNotAvailableForEntry do
		if not _includeVoid and invoiceType.isVoid then	//21 Mar 2019	NDL	TFS 43687
			continue;
		endif;
		_cmb.addItem(invoiceType.getComboDescription()); // ### TFS BUG 59913 31AUG2023 NAVAB1 
		_cmb.itemObject[_cmb.newIndex] := invoiceType;
	endforeach;
epilog

end;</source>
        <Parameter name="_cmb" type="CMUI_ComboBox"/>
        <Parameter name="_includeVoid" type="Boolean"/>
        <Parameter name="_bank" type="CM_Bank" usage="input"/>
    </JadeMethod>
    <JadeMethod name="comboBoxInvoiceStatus" id="beb095f5-530c-4310-8f86-072724f34b87">
        <source>comboBoxInvoiceStatus(_cmb : CMUI_ComboBox; _includeReverse : Boolean );
//----------------------------------------------------------------------
// Created by 	cnwsh3
// Date 		20 April 2010
//
// Implemented version: JMT 7.8.2
// Date  		User  		Change
// SFW CCMS 1115 PAR23680   cnwsh3 - Invoice JRW Interface
// 04/04/2018	jlgdap1		TFS 37560 PEL1 Prepend Invoice Status
// 31 Oct  2018    cnwma1 ChangeRequest 41703: PEL1 - Sap Integration - Post Billing Cancelled Invoice
//----------------------------------------------------------------------
vars
	combo : CMUI_ComboBox;
begin
	if _cmb = null then
		app.raiseUnexpectedProgramError(self.class.name, method.name, 'An Invoice combo box was expected but cannot be located.');
	endif;
	
	combo := _cmb;
	combo.clear;
	combo.sorted := false;
/* // TFS 39618 PATCH 1  this method is not referenced
	combo.addItem(app.getErrorString(CM_Any_Status));
	combo.itemData[combo.newIndex] := CM_Invoice.INVOICE_ALL_STATUS;

	combo.listIndex := combo.newIndex;

	combo.addItem(app.getInvoiceStatusString(self.myTerminal.getDefaultCompanyBank().myInvoiceProcess, CM_Invoice.INVOICE_SUSPENSE)); //app.getErrorString(Suspense)); // TFS 39618
	combo.itemData[combo.newIndex] := CM_Invoice.INVOICE_SUSPENSE;
	
	combo.addItem(app.getInvoiceStatusString(self.myTerminal.getDefaultCompanyBank().myInvoiceProcess, CM_Invoice.INVOICE_OPEN)); //app.getErrorString(Open_GC)); // TFS 39618
	combo.itemData[combo.newIndex] := CM_Invoice.INVOICE_OPEN;

	combo.addItem(app.getInvoiceStatusString(self.myTerminal.getDefaultCompanyBank().myInvoiceProcess, CM_Invoice.INVOICE_PENDING)); //app.getErrorString(Pending)); // TFS 39618
	combo.itemData[combo.newIndex] := CM_Invoice.INVOICE_PENDING;

	combo.addItem(app.getInvoiceStatusString(self.myTerminal.getDefaultCompanyBank().myInvoiceProcess, CM_Invoice.INVOICE_POSTED)); //app.getErrorString(Posted)); // TFS 39618
	combo.itemData[combo.newIndex] := CM_Invoice.INVOICE_POSTED;
	
	combo.addItem(app.getInvoiceStatusString(self.myTerminal.getDefaultCompanyBank().myInvoiceProcess, CM_Invoice.INVOICE_VOID)); //app.getErrorString(Void)); // TFS 39618
	combo.itemData[combo.newIndex] := CM_Invoice.INVOICE_VOID;
	
	//04 Sep 2017	NDL	TFS 6759
	if _includeReverse then
		combo.addItem(app.getInvoiceStatusString(self.myTerminal.getDefaultCompanyBank().myInvoiceProcess, CM_Invoice.INVOICE_POSTED_REVERSE)); //app.getErrorString(Posted_returned)); // TFS 39618
		combo.itemData[combo.newIndex] := CM_Invoice.INVOICE_POSTED_REVERSE;
	
		combo.addItem(app.getInvoiceStatusString(self.myTerminal.getDefaultCompanyBank().myInvoiceProcess, CM_Invoice.INVOICE_POSTED_CREDIT)); //app.getErrorString(Posted_credit)); // TFS 39618
		combo.itemData[combo.newIndex] := CM_Invoice.INVOICE_POSTED_CREDIT;		
	endif;
	
	combo.addItem(app.getInvoiceStatusString(self.myTerminal.getDefaultCompanyBank().myInvoiceProcess, CM_Invoice.INVOICE_PREPEND)); //app.getErrorString(Prepend)); // TFS 37560 // TFS 39618
	combo.itemData[combo.newIndex] := CM_Invoice.INVOICE_PREPEND;		// TFS 37560
	combo.addItem(app.getInvoiceStatusString(self.myTerminal.getDefaultCompanyBank().myInvoiceProcess, CM_Invoice.INVOICE_DISPUTED)); //app.getErrorString(Disputed)); // TFS 37560 // TFS 39618
	combo.itemData[combo.newIndex] := CM_Invoice.INVOICE_DISPUTED;		// TFS 37560
	
	combo.addItem(app.getInvoiceStatusString(self.myTerminal.getDefaultCompanyBank().myInvoiceProcess, CM_Invoice.INVOICE_PENDING_REVERSE)); //app.getErrorString(Pending_returned)); //31.10.2018 cnwma1 TFS #41703 // TFS 39618
	combo.itemData[combo.newIndex] := CM_Invoice.INVOICE_PENDING_REVERSE; //31.10.2018 cnwma1 TFS #41703
	*/
epilog
end;</source>
        <Parameter name="_cmb" type="CMUI_ComboBox"/>
        <Parameter name="_includeReverse" type="Boolean"/>
    </JadeMethod>
