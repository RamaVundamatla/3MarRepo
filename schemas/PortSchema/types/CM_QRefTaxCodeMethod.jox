    <JadeMethod name="create" id="9509f4bb-2b79-4f92-80e4-30ddcacf1d65">
        <updating/>
        <source>create() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		      Who		Reason
12 December 2022  navmv20   Defect 55746: MTN - New tax fields not in selectors or summaries as per BRD

*/

vars
	oper : CM_QueryOperator;

begin

	if self.isTransient then 
		return;
	endif;

	create oper as CM_QReferenceIsOneOf persistent;
	self.allAllowedOperators.add(oper);

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="getKeyLengthForXTABDictionary" id="9b9cfe48-fe13-4127-9ae7-586d3da8a742">
        <source>getKeyLengthForXTABDictionary(): Integer;

/*

Purpose:			

Parameters:			

Return Value:		


Date		      Who		Reason
12 December 2022  navmv20   Defect 55746: MTN - New tax fields not in selectors or summaries as per BRD

*/

vars

begin

	return CM_TaxCode::description.length + CM_Bank::code.length  + CM_Terminal::code.length + 5;

epilog

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
