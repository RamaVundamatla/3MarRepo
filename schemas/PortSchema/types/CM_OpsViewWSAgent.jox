    <JadeMethod name="setupDelayForActivity" id="484bf7b5-7932-4c4d-b555-38241dd8362a">
        <source>setupDelayForActivity(_cmifArray : CMIF_OpsViewTablesArray io; _ewsOpsView : CM_EWSActivityOpsview): CMIF_OpsViewTablesArray;
/*
Purpose:			

Date		Who		Reason
26AUG2021	NAVAB1	TFS 51853
*/

vars
	xpsCraneActivityCmif    	: CMIF_XpsCraneactivity;
	xpsCraneShiftCmif           : CMIF_XpsCraneshift;
	xpsPointOfWorkCmif          : CMIF_XpsPointOfWork;
	delay						: CM_Delay;
	data                 		: Any;
begin
	if _ewsOpsView.dataAction = BGP_OpsViewWSRequest.OPS_ACTION_DELETE then
		data := _ewsOpsView.objectOid;
	else
		data := _ewsOpsView.myOpsviewObject;
	endif;
	
	
	//1 Point Of Work
	create xpsPointOfWorkCmif transient;
	xpsPointOfWorkCmif.initializeForActivity(data,_ewsOpsView);
	_cmifArray.add(xpsPointOfWorkCmif);
	
	//2 CraneShift
	
	create xpsCraneShiftCmif transient;
	xpsCraneShiftCmif.initializeForActivity(data,_ewsOpsView);
