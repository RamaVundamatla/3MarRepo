    <JadeMethod name="getWorkingDTOEntry" id="5b719a42-727f-4acc-b97d-5a6a7c491ceb">
        <interfaceImplements>
            <JadeInterfaceMethod name="IF_VehicleMountedDetails::getWorkingDTOEntry"/>
        </interfaceImplements>
        <source>getWorkingDTOEntry(): DTO_RTQueueEntry ;

	/*
		this method stub has been automatically generated by Jade to satisfy interface implementation requirements
	*/
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
27 Apr 2010	cnwer1	Initial creation
16 Dec 2010 cnwer1	PAR 26612
20 May 2011 cnwer1	PAR 27554 was returning if not showing task list but we still need this when offered a task
*/

vars
	accessObject : Object;
	invalidObject : Boolean;
	edition			: Integer;
begin
	on Exception do app.handleDeletedObject(exception,accessObject,invalidObject);

	
	if self.tblMoveInfo.columns &gt; 1 then
		//return null;
	

		accessObject:=self.tblMoveInfo.accessColumn(2).itemObject;
		if accessObject &lt;&gt; null then
			edition:=accessObject.edition;
			if invalidObject then
				accessObject := null;
			endif;
		endif;
	endif;
	
	if accessObject = null and self.myMachine.allCurrentWorkingQueueTasks.size &gt; 0 then
		/*epr par 26612 - previously we returned null now
			the screen is displaying a task for the driver lets go fetch it 
			- could not reproduce how they got in this situation will prevent a 1090 exception
			
		*/
		self.clearTableData(self.tblMoveInfo);
		app.myVMAgent.loadRTTaskTable(self.tblMoveInfo,null);
		if self.tblMoveInfo.columns&lt; 2 then
			return null;
		endif;
		accessObject:=self.tblMoveInfo.accessColumn(2).itemObject;
	endif;

	if accessObject = null then
		return null;
	endif;
	
	if not accessObject.isKindOf(DTO_RTQueueEntry) then
		return null;
	endif;
	
	
	return accessObject.DTO_RTQueueEntry;
epilog

end;</source>
        <ReturnType type="DTO_RTQueueEntry"/>
    </JadeMethod>
    <JadeMethod name="getWorkingTwinDTOEntry" id="5f876798-ff8c-43e6-9cd7-30bca97141f7">
        <interfaceImplements>
            <JadeInterfaceMethod name="IF_VehicleMountedDetails::getWorkingTwinDTOEntry"/>
        </interfaceImplements>
        <source>getWorkingTwinDTOEntry(): DTO_RTQueueEntry;

	/*
		this method stub has been automatically generated by Jade to satisfy interface implementation requirements
	*/
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
27 April 2010	cnwer1	Initial creation

*/

vars
	accessObject : Object;
begin
	
	if not self.tblMoveInfo.columns &lt; 3 then
		accessObject:=self.tblMoveInfo.accessColumn(3).itemObject;
	endif;
	if accessObject = null then
	
		/*the screen is displaying a task for the driver lets go fetch it 
			- could not reproduce how they got in this situation will prevent a 1090 exception
			
		*/
		
		self.clearTableData(self.tblMoveInfo);
		app.myVMAgent.loadRTTaskTable(self.tblMoveInfo,null);
		if self.tblMoveInfo.columns &lt; 3 then
			return null;
		endif;
		accessObject:=self.tblMoveInfo.accessColumn(3).itemObject;
	endif;

	if not accessObject.isKindOf(DTO_RTQueueEntry) then
		return null;
	endif;
	
	return accessObject.DTO_RTQueueEntry;

	
epilog

end;</source>
