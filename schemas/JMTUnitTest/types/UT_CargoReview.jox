    <JadeMethod name="createOwnershipChange" id="b33de99a-76da-4171-b94f-dad65240af9f">
        <source>createOwnershipChange(_operatorId : String; _cargoGroup : CM_CargoGroup);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 Aug 2025 navrv30 MTN 35150 MTN | Unit Tests for Cargo Review Release Requests and COO Validation

*/

vars
	allTransientDetails,
	detailsSet : ObjectArray;
	pxyOwnershipChange,
	realOwnershipChange : CM_OwnershipChange;
	cmifOwnershipChangeDtl : CMIF_OwnershipChangeDetail;
	pxyDetail : CM_OwnershipChangeDetail;
	cmifAgent : CMIF_COOAgent;
begin
	
	create allTransientDetails transient;	
	pxyOwnershipChange := self.createOwnershipChangePxy("ABC2", _operatorId);	
	self.opts.addAssoc("CargoGroup", _cargoGroup);
	detailsSet := self.createDetailsProxies(true,null,null, 5);
	self.opts.purge();
	create cmifOwnershipChangeDtl transient;
	detailsSet.copy(cmifOwnershipChangeDtl.allPxyOwnershipChangeDetails);
	
	foreach pxyDetail in cmifOwnershipChangeDtl.allPxyOwnershipChangeDetails do
		allTransientDetails.add(pxyDetail);
		pxyDetail.allSubDetails.copy(allTransientDetails);
	endforeach;

	while true do
		app.myTrxCA.trxCreateOwnershipChangeAndDtl(pxyOwnershipChange,realOwnershipChange,cmifOwnershipChangeDtl,app.myPassport);		
		if not app.myPassport.trxCompletedOK and app.myPassport.noErrors then
			app.myPassport.warningsAcknowledged	:= true;
			continue;
		endif;
		break;
	endwhile;
	
	app.myTrxUA.trxUpdateOwnershipChangeApprov(realOwnershipChange, app.myPassport, cmifAgent);	
	self.opts.purge();
	self.clearExpectedTrxErrors();
	delete pxyOwnershipChange;
	detailsSet.purge();
	delete detailsSet;
	cmifOwnershipChangeDtl.allPxyOwnershipChangeDetails.clear();
	cmifOwnershipChangeDtl.allRealOwnershipChangeDtls.clear();
epilog
	delete cmifOwnershipChangeDtl;
	allTransientDetails.clear();
	delete allTransientDetails;
end;</source>
        <Parameter name="_operatorId" type="String"/>
        <Parameter name="_cargoGroup" type="CM_CargoGroup"/>
    </JadeMethod>
    <JadeMethod name="createOwnershipChangePxy" id="884f30dd-2d45-4f56-a9d4-18a6a798411f">
        <source>createOwnershipChangePxy(_refNumber : String; _operatorId : String) : CM_OwnershipChange;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 Aug 2025 navrv30 MTN 35150 MTN | Unit Tests for Cargo Review Release Requests and COO Validation

*/

constants

	//DEBTOR 		= "UT_DEBTOR_AB";
vars
	pxyOwnership				: CM_OwnershipChange;
	dateTimeCOO,storageExpriryOperatorNew: TimeStamp;
	remarks 					: String;
	myiNCOTerm					: CM_InvoiceINCOTerm;
	myOperatorNew,
	myOperatorOid,
	myOperatorOrig,
	myOperatorStorage			: CM_Operator;
	myFreightForward			: CM_ConsigneeConsignor;
	root						: CM_Root;
	terminal					: CM_Terminal;
	myOwnerShip					: CM_OwnershipChange;
	transferedWeight, transferedVolume : Decimal[23,4];
	debtor1			: CM_Debtor;
begin
	//Create OwnershipChange
 
	dateTimeCOO		:= app.actualTimeAppServer();
	storageExpriryOperatorNew := app.actualTimeAppServer();
	root := app.myRoot;
	terminal := self.getTerminal;
	if self.opts.includesKey("Remarks") then
		remarks := self.opts.str("Remarks");
	endif;
	transferedWeight		:= 25.4578;
	transferedVolume		:= 78.8974;
	self.deleteInvINCOTerm("abcd");
	self.contractINCOCreate(myiNCOTerm, "abcd");
	
	//self.deleteOperator("ABCO");
	self.deleteOperator("Oid");
	
	self.deleteOperator("OStorage");
	self.deleteConsigneeConsignor("UTFreightForward");
	myOperatorNew := app.myRoot.allOperators["ABCO"];	
	
	myOperatorOid := self.addOperator("Oid", "Ownership Change Operatoroid", false, 0, 0, debtor1, false, false, false, false, false, false, false, false, false, false, null, null, null, false, false, false, null, null, 0, null, false, false);
	self.assertNotNullMsg(myOperatorOid,"Operator Create Failed");
	
	myOperatorOrig := app.myRoot.allOperators[_operatorId];
	if myOperatorOrig = null then
		myOperatorOrig := self.addOperator("Orig", "Ownership Change OperatorOrig", false, 0, 0, debtor1, false, false, false, false, false, false, false, false, false, false, null, null, null, false, false, false, null, null, 0, null, false, false);
		self.assertNotNullMsg(myOperatorOrig,"Operator Create Failed");
	endif;
	myFreightForward := self.addConsigneeConsignor("UTFr", "FreightForward", true, false, false);
	myOperatorStorage := self.addOperator("OSto", "Ownership Change OperatorStorage", false, 0, 0, debtor1, false, false, false, false, false, false, false, false, false, false, null, null, null, false, false, false, null, null, 0, null, false, false);
	self.assertNotNullMsg(myOperatorStorage,"Operator Create Failed");
	foreach myOwnerShip in myOperatorNew.allOwnershipChangeNew do 
		if  myOwnerShip.refNumber = "ABCde" then
			deleteOwnershipChange(myOwnerShip);
		endif;
	endforeach;

    create pxyOwnership transient;
	pxyOwnership.setProxy(_refNumber,app.getMyUserCode(),"Good",app.getMyUserCode(),dateTimeCOO,null,storageExpriryOperatorNew,11,12,13,150,transferedWeight,transferedVolume,remarks,
	myFreightForward,myiNCOTerm,myOperatorNew,myOperatorOid,myOperatorOrig,myOperatorStorage,null,terminal, null);		//navra1 - TFS 64874 - 14th Aug 2024
	return pxyOwnership;
epilog

end;</source>
        <Parameter name="_refNumber" type="String"/>
        <Parameter name="_operatorId" type="String"/>
        <ReturnType type="CM_OwnershipChange"/>
    </JadeMethod>
    <JadeMethod name="createRelReqUsingJDO" id="216e5c5b-644e-4d1b-9b41-56bf3f157b17">
        <source>createRelReqUsingJDO(jdo : JadeDynamicObject; cargoReviewQueryObj : CMIF_CargoReviewQuery; quantity : Integer; relReqId : String) : CM_BulkRelease;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 Aug 2025 navrv30 MTN 35150 MTN | Unit Tests for Cargo Review Release Requests and COO Validation

*/

vars
	term : CM_Terminal;
	//tis : CM_TIArray;
	cargoType : CM_CargoType;
	ti : CM_TrackedItem;
	cargoGroup1 : CM_CargoGroup;
	cargoOp : CM_Operator;	
	voyage : CM_Voyage;
	bol : CM_BOL;
	bolCode : String;
	commodity : CM_Commodity;
	index : Integer;
	type : Type;
	value : Any;	
	tisInGrouping : CM_TIByCargoTypeIdDict;
	product : CM_Product;
	iso : CM_ISOType;
	opCode : String;
	releaseRequest : CM_BulkRelease;
begin
	term := self.getTerminal();
	opCode := self.getProfileSetting(UT_Profile.P_OPERATOR).asString();	
	cargoOp := self.getOperator(opCode);
	if jdo.getPropertyInfoByName(CMIF_CargoReviewQuery.CargoReviewAllTrackedItems,index,type,value) then		
			tisInGrouping := value.CM_TIByCargoTypeIdDict;
			ti := tisInGrouping.first;

			if ti &lt;&gt; null then
				cargoType := ti.myCargoType;
				product := ti.myProduct;
				if ti.isContainer then
					iso := ti.getISOTypeObject();
				endif;				
				if cargoReviewQueryObj.allGroupingRows.getEntRowNamed(ETRow_BillOfLading) &lt;&gt; null then					
					if bol = null and bolCode &lt;&gt; null then
						if ti.myVoyage &lt;&gt; null then
							bol := ti.myVoyage.getBOL(bolCode);
						endif;
					endif;				
					if ti.myBOLDtl &lt;&gt; null then
						bol := ti.myBOLDtl.myBOL.CM_BOLIn;
					endif;
				endif;				
				if jdo.getPropertyInfoByName(ETRow_CargoGroupId,index,type,value) then
					cargoGroup1 := ti.myCargoGroup;
				endif;				
				if cargoReviewQueryObj.allGroupingRows.getEntRowNamed(ETRow_Commodity) &lt;&gt; null then
					if jdo.getPropertyInfoByName(ETRow_Commodity,index,type,value) then
						commodity := ti.getCommodityObject();
					endif;
				endif;
			endif;
		endif;
	
	jdo.getPropertyInfoByName(ETRow_VoyageCode,index,type,value);
	voyage := term.allVoyagesByCode.getAtKeyGeq(value.String,null);
	if voyage &lt;&gt; null 
		and voyage.code &lt;&gt; value.String then
			voyage := null;
	endif;
	
	releaseRequest := createReleaseRequest(cargoType, cargoOp, voyage, commodity,quantity, cargoGroup1, bol, product, relReqId);
	return releaseRequest;
epilog

end;</source>
        <Parameter name="jdo" type="JadeDynamicObject"/>
        <Parameter name="cargoReviewQueryObj" type="CMIF_CargoReviewQuery"/>
        <Parameter name="quantity" type="Integer"/>
        <Parameter name="relReqId" type="String"/>
        <ReturnType type="CM_BulkRelease"/>
    </JadeMethod>
    <JadeMethod name="createReleaseRequest" id="5abc12e8-d680-49a1-8525-b673c7f90b5e">
        <source>createReleaseRequest(_cargoType : CM_CargoType; _operator : CM_Operator; _voyage : CM_Voyage; _commodity : CM_Commodity; _quantity : Integer; 
		_cargoGroup : CM_CargoGroup ; _bol : CM_BOL; _product : CM_Product; _releaseId : String) : CM_BulkRelease;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 Aug 2025 navrv30 MTN 35150 MTN | Unit Tests for Cargo Review Release Requests and COO Validation

*/

vars	
	release : CM_BulkRelease;
	detail : CM_ReserveDetail;
	pxyReleaseMatchCrit : CM_ReleaseByTypeCriteria;
	pxyCriteria : CM_YACriteria;
begin
// ### Create a road release request for the cargo group
	self.opts.purge();
	self.deleteReleaseRequest(_releaseId);
	
	self.opts.addAssoc("Context", RelReqContext_CargoGroupReview);
	self.opts.addAssoc("CargoGroup", _cargoGroup);
	self.opts.addAssoc("Voyage", _voyage);
	self.opts.addAssoc("Number", _quantity);
	self.opts.addAssoc("Commodity", _commodity);
	self.opts.addAssoc("BOL", _bol);
	self.opts.addAssoc("Product", _product);
	if _commodity &lt;&gt; null then
		create pxyReleaseMatchCrit transient;
		create pxyCriteria transient;
		pxyReleaseMatchCrit.allCriteria.add(pxyCriteria);
		pxyCriteria.setProxy(	CM_YATypeCommodity.firstInstance,	//pCriteriaTypeObj:CM_YACriteriaType;
								_commodity.code,	//pDataValue:Any;
								"Commodity"	//pCode:String
								);
		self.opts.addAssoc(ETRow_SetCriteria, pxyReleaseMatchCrit);
	endif;
	release := self.addReleaseByTypeRequestOpts(_releaseId,BR_TYPE_ROAD, _cargoType.id);
	
	self.assertTrueMsg(release &lt;&gt; null, "BR is null!");
	
	detail := release.allReserveDetails.first;
	self.assertTrueMsg(detail &lt;&gt; null, "BR Detail is null!");
	self.assertTrueMsg(release.context = RelReqContext_CargoGroupReview, "BR Context should be " &amp; RelReqContext_CargoGroupReview);
	return release;
epilog
	//delete pxyReleaseMatchCrit;
end;</source>
        <Parameter name="_cargoType" type="CM_CargoType"/>
        <Parameter name="_operator" type="CM_Operator"/>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_commodity" type="CM_Commodity"/>
        <Parameter name="_quantity" type="Integer"/>
        <Parameter name="_cargoGroup" type="CM_CargoGroup"/>
        <Parameter name="_bol" type="CM_BOL"/>
        <Parameter name="_product" type="CM_Product"/>
        <Parameter name="_releaseId" type="String"/>
        <ReturnType type="CM_BulkRelease"/>
    </JadeMethod>
    <JadeMethod name="createVoyage" id="024396c2-a9b5-4121-b368-912882e6dbcc">
        <source>createVoyage(_vesselName : String; _voyageName : String) : CM_Voyage;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 Aug 2025 navrv30 MTN 35150 MTN | Unit Tests for Cargo Review Release Requests and COO Validation

*/

vars
	
	oper : CM_Operator;
