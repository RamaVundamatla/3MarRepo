    <JadeMethod name="setControlsForAddEdit" id="82524955-9744-40b2-b2ff-410b5afa465b">
        <updating/>
        <source>setControlsForAddEdit() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 June 2022	navds20	TFS ChangeRequest 53862: EUP - WMS - Damage Recording Extra Details
*/

vars
	theForm : SOP_TableMaintForm;
begin
	theForm := self.myForm;
	theForm.tblInput1.userInputEnabled := true;
		
	if theForm.mode = theForm.Mode_Add then 
		theForm.tblInput1.clearValues;
		theForm.tblInput1.enableRowByName(ETRow_Code);
		theForm.tblInput1.enableRowByName(ETRow_Description);
		theForm.tblInput1.enableRowByName(ETRow_NotAvailableForEntry);
		theForm.tblInput1.setFocus;
		theForm.tblInput1.moveFirst();
		theForm.tblInput1.gotFocus(theForm.tblInput1);		
		
		theForm.mulSelect1.setSelected(null);
	else
		self.showThumbnail(theForm.myCurrentObject.CM_DamageParty);
		theForm.tblInput1.disableRowByName(ETRow_Code);
		theForm.tblInput1.enableRowByName(ETRow_Description);
		theForm.tblInput1.enableRowByName(ETRow_NotAvailableForEntry);
	endif;
    theForm.tblInput1.cnEcResizeContents;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setCtrlsForView" id="9191bbce-6841-40d0-99e7-a41017e87807">
