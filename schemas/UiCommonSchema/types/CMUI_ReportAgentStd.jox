// Purpose:     
// 03/10/2018 	jlgrh7 TFS #TFS40544 CIG - Problems with Reports
// ----------   ----------  --------------------------------------------------
vars
	row,
	inputType			: Integer;
	jCell				: JadeTableCell;
	clonedControl		: CMUI_TextBox;
	tbl			: CM_EntryTable;
//	clonedDateControl: CMUI_DateMask;
//	clonedTimeControl: CMUI_TimeMask;
begin

	tbl := self.myEntryTable;
	
	if _qryParam = null or tbl = null then
		return;
	endif;

	if _qryParam.type = Boolean.number then
		row := tbl.addAttribute(_qryParam.paramName, _qryParam.displayName, CM_EntryTable.InputType_CheckBox, null, _qryParam.isVisible);
		jCell := tbl.accessCell(row, CM_EntryTable.ColumnValue);
		jCell.text := _qryParam.getParamValue.String;
		_qryParam.initCellForType(jCell);
	
	elseif _qryParam.type = Binary.number then		
		row := tbl.addAttribute(_qryParam.paramName, _qryParam.displayName, CM_EntryTable.InputType_Picture, null, _qryParam.isVisible);
		jCell := tbl.accessCell(row, CM_EntryTable.ColumnValue);
		jCell.cellControl := self.myPicParamPic;
		self.myPicParamPic.picture := _qryParam.defaultValueBinary;
		jCell.picture := _qryParam.defaultValueBinary;
	
	elseif _qryParam.type = Date.number then
		row := tbl.addAttribute(_qryParam.paramName, _qryParam.displayName, CM_EntryTable.InputType_Date, null, _qryParam.isVisible);
		jCell := tbl.accessCell(row, CM_EntryTable.ColumnValue);
		_qryParam.initCellForType(jCell);
		//jCell.text := _qryParam.getParamValue.String.Date.shortFormatJMT();							//-TFS40544
		jCell.text := _qryParam.getParamValue.asStringJMT.asDateJMT().shortFormatJMT;		//+TFS40544
		
	elseif _qryParam.type = Decimal.number then
		row := tbl.addAttribute(_qryParam.paramName, _qryParam.displayName, CM_EntryTable.InputType_TextNumeric, null, _qryParam.isVisible);
		jCell := tbl.accessCell(row, CM_EntryTable.ColumnValue);
		_qryParam.initCellForType(jCell);
		jCell.text := _qryParam.getParamValue.String;
		
	elseif _qryParam.type = Integer.number then
		row := tbl.addAttribute(_qryParam.paramName, _qryParam.displayName, CM_EntryTable.InputType_TextNumeric, null, _qryParam.isVisible);
		jCell := tbl.accessCell(row, CM_EntryTable.ColumnValue);
		_qryParam.initCellForType(jCell);
		jCell.text := _qryParam.getParamValue.String;
	
	elseif _qryParam.type = Time.number then
		row := tbl.addAttribute(_qryParam.paramName, _qryParam.displayName, CM_EntryTable.InputType_Time, null, _qryParam.isVisible);
		jCell := tbl.accessCell(row, CM_EntryTable.ColumnValue);
		_qryParam.initCellForType(jCell);
		jCell.text := _qryParam.getParamValue.Time.shortFormatJMT();
		
	else
		row := tbl.addAttribute(_qryParam.paramName, _qryParam.displayName, CM_EntryTable.InputType_TextBox, null, _qryParam.isVisible);
		jCell := tbl.accessCell(row, CM_EntryTable.ColumnValue);
		jCell.text := _qryParam.getParamValue.String;
		_qryParam.initCellForType(jCell);
		
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="_qryParam" type="CM_QueryReportParam"/>
    </JadeMethod>
    <JadeMethod name="addListTransientsToCleanup" id="3ca45bf9-e2fb-493b-ae42-d899336b8b6e">
        <source>addListTransientsToCleanup(_listTable: CMUI_ListTable input) protected;
//----------------------------------------------------------------
//	Created:	29 October 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	startRow,	
	intRow		: Integer;
	obj			: Object;
begin

	startRow := _listTable.fixedRows + 1;
	
	foreach intRow in startRow to _listTable.rows do

		obj := _listTable.accessRow(intRow).itemObject;
		if obj &lt;&gt; null
		and obj.isTransient then
			self.allTransientsToPurge.add(obj);
		endif;
	
	endforeach;

end;</source>
        <access>protected</access>
        <Parameter name="_listTable" type="CMUI_ListTable" usage="input"/>
    </JadeMethod>
    <JadeMethod name="displayTIState" id="155fab41-af06-4dbe-a7fc-b006031be740">
        <source>displayTIState(_state : CM_String; _selected : Boolean) : String;
// ---------------------------------------------------------------------------
// Created:     12 January 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars

begin
	if _state = null then
		return null;
	endif;

	if _selected then
		return TableCheckBox_Selected &amp; Tab &amp; _state.string;
	else
		return TableCheckBox_NotSelected &amp; Tab &amp; _state.string;
	endif;
	
end;</source>
        <Parameter name="_state" type="CM_String"/>
        <Parameter name="_selected" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="doCmbBOLVoyageClick" id="e674d5c6-ab47-46a8-9dc1-77894b6e63c9">
        <source>doCmbBOLVoyageClick(_voyage : CM_Voyage; 
					_cmbBOL : CMUI_ComboBox input);
// refresh BOLIn combo on change of voyage
vars
	index	: Integer;
	bol		: CM_BOL;
	combo	: CMUI_ComboBox;
begin
	combo := _cmbBOL;
	if self.isRowIncluded (ETRow_Bol) and
	   _voyage &lt;&gt; null then 
		combo.clear();
		foreach bol in _voyage.allBOLInByTypeStatusNumDT do
			index := combo.addItem(bol.number);
			combo.itemObject[index] := bol;
		endforeach;
	endif;

end;
</source>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_cmbBOL" type="CMUI_ComboBox" usage="input"/>
    </JadeMethod>
