    <JadeMethod name="getObjects" id="2cf2578a-9d1f-492d-a3c5-5cfecd9a75d7">
        <source>getObjects(objects: ObjectLongNameDict input);
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 18/09/2013	cnwdap1		Initial creation PAR #32215
//
vars
	vehicleModel    : CM_VehicleModel;
	
begin
	foreach vehicleModel in app.myDutyDocRoot.allVehicleModels do 
		objects[vehicleModel.getYADisplay()] := vehicleModel;
	endforeach;
epilog

end;</source>
        <Parameter name="objects" type="ObjectLongNameDict" usage="input"/>
    </JadeMethod>
