    <JadeMethod name="createAssociatedDelay" id="8b1b72ea-02d5-40ab-bfda-f5bc8a70b430">
        <updating/>
        <source>createAssociatedDelay( _pxyEvent: CMEVT_VoyageEvent )updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 August 2018	jlgndl1	Initial creation	TFS 40309

*/

vars

	remarks : String;	//05 Nov 2018 	NDL	TFS 41711

begin

	if self.myEventType.myDelayTypeToCreate &lt;&gt; null then
	
		//05 Nov 2018 	NDL	TFS 41711
		remarks := _pxyEvent.remarks.trimBlanks;
		if remarks &lt;&gt; null then
			remarks := remarks &amp; CrLf &amp; app.getErrorString( Created_from_voyage_event );
		else
			remarks := app.getErrorString( Created_from_voyage_event );
		endif;
		
	
		create self.myVoyageDelay;
		self.myVoyageDelay.setProxy(self.myTerminal,	//_terminal : CM_Terminal;
									self.myVoyage,	//_voyage : CM_Voyage; 
									self.myEventType.myDelayTypeToCreate,	//_delayType : CM_DelayType;
									self.dateTime,	//_startDT : TimeStamp; 
									self.dateTimeEnd,	//_estEndDT : TimeStamp;
									self.dateTimeEnd,	//_endDT : TimeStamp;
									null,	//_machine : CM_Machine; 
									null,	//_driver : CM_User;
									null,	//_workPoint : CM_WorkPoint;
									remarks	//_remarks : String
									); 
		self.myVoyageDelay.setMyVoyageEvent( self );
	
	endif;

epilog

end;</source>
        <Parameter name="_pxyEvent" type="CMEVT_VoyageEvent"/>
    </JadeMethod>
    <JadeMethod name="delete" id="e2f5ea23-b7be-4dc4-912b-f479888f9dea">
        <updating/>
        <source>delete() updating;
/*

Date		Who		Reason
11 December 2014	cnwer1	Initial creation PAR

*/

vars

begin

	self.resetAuditsDuringDelete();	//01 Jan 2021	NDL	TFS 50152
	
	if not self.isTransient then
		if self.myVoyage &lt;&gt; null then
			self.myVoyage.causeEvent(EventTransaction_Delete_Event,false,self);	
		endif;
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="getBank" id="78349c67-d1db-4b49-ab45-730fe04950d7">
        <source>getBank() : CM_Bank;

/*

Purpose:			
	18 October 2007 By Andrew Bishop cnwab1
Parameters:			

Return Value:		

Date		Who		Reason
05 Dec 2024	navma1  MTN-33567 MTN - Charges Are Not Created When adding Events
*/

vars
	voyage : CM_Voyage;
begin
	voyage := self.myVoyage;
	
	if voyage &lt;&gt; null then								//05.12.2024 navma1 #MTN-33567
		if voyage.myDischargeCompany &lt;&gt; null then
			return voyage.myDischargeCompany;
		endif;
	endif;
	
	return inheritMethod();
end;</source>
        <ReturnType type="CM_Bank"/>
    </JadeMethod>
    <JadeMethod name="getDebtor" id="37a909e8-89b4-437c-975d-4bc3e80aeb53">
        <source>getDebtor() : CM_Debtor;
// ---------------------------------------------------------------------------
// Created:		18 October 2007 By Andrew Bishop cnwab1
//
// Purpose:		
// 08/06/2020 cnwma1 ChangeRequest 49400: ASPA - Invoice Enhancements for Barges
// 05/12/2024 navma1 MTN-33567 MTN - Charges Are Not Created When adding Events
// ---------------------------------------------------------------------------
vars
	voyage : CM_Voyage;
begin
	
	if self.myDebtor &lt;&gt; null then
		return self.myDebtor;
	endif;
	
	voyage := self.myVoyage;
	
	if voyage &lt;&gt; null then							//05.12.2024 navma1 #MTN-33567
		if voyage.myDebtor &lt;&gt; null then
			return voyage.myDebtor.CM_Debtor;
		endif;
	endif;
	
	return inheritMethod();
end;</source>
        <ReturnType type="CM_Debtor"/>
    </JadeMethod>
    <JadeMethod name="getDescription" id="bb94bc42-050b-432a-ae5a-0f9130be584f">
        <source>getDescription(): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26 October 2017	jlgndl1	Initial creation

*/

vars

	retStr : String;

begin
	retStr := inheritMethod();
	
	if self.isVoyBolOutturn and self.myBOL &lt;&gt; null then
		retStr := retStr &amp; " '" &amp; self.myBOL.number &amp; "'"; 
	endif;
	
	return retStr;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDisplayID" id="b49569c5-33d5-445b-88f9-f0ae053e66ac">
        <source>getDisplayID(): String;
//
//30 Apr 2015	cnwrs1	Par35784 - increased exclusion reason logging to include non excluded
//
vars

begin
	if self.myVoyage &lt;&gt; null then
		return self.myEventType.name &amp;' '&amp; self.myVoyage.code;
	else
		return inheritMethod();
	endif;
end;
</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="2216aba9-8396-47a2-81d2-77b1b80e0995">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 Mar 2016	cnwndl1	Initial creation	TFS 1407
02 Apr 2020 cnwma1  Bug 49035: MTN - Voyage events not recording remarks in table
29 Jul 2022	jlizm1	TFS 54165 EDI Voyage Events
*/

vars
	value : String;					// TFS 54165
	measure : CM_MeasurementType;	// TFS 54165
	
begin

	if _attrName = ETRow_GenLanding then	//14 Mar 2016	NDL	TFS 1407
		if self.type = EVT_VoyGeneralLandingDate then
			if self.generalLandingDate &lt;&gt; null then
				return self.generalLandingDate.asStringJMT;
			endif;
		endif;
		return null;
		
	elseif _attrName = ETRow_PrevGenLanding then	//14 Mar 2016	NDL	TFS 1407
			if self.prevGenLandingDate &lt;&gt; null then
				return self.prevGenLandingDate.asStringJMT;
			endif;
		return null;
	elseif _attrName = ETRow_EndDateTime then	
		if dateTimeEnd &lt;&gt; null then
			return self.systemToLocalTime(self.dateTimeEnd).asStringJMT;
		endif;
		
		return "";

	elseif _attrName = ETRow_WorkPoint then	//05 May 2017	NDL	TFS 4329
		if self.myJob &lt;&gt; null then
			return self.myJob.craneId;
		endif;
		return null;
		
	elseif _attrName = ETRow_MyVoyageDelay then		//28 Aug 2018	NDL TFS 40309
		if self.myVoyageDelay &lt;&gt; null
		and self.myVoyageDelay.myDelayType &lt;&gt; null then
			return self.myVoyageDelay.myDelayType.description;
		endif;	
		return null;
	elseif _attrName = ETRow_Remarks then		  //02.04.2020 cnwma1 #49035
		return self.remarks;
		
	elseif _attrName = ETRow_Weight then	// TFS 54165
		if self.myEventType &lt;&gt; null then
			measure := self.myEventType.myWeightType;
			if measure &lt;&gt; null then
				value := app.convertMeasurementForDisplay(measure.shortName, self.weight);
				return value &amp; Space &amp; measure.shortName;
			endif;
		endif;
		return null; 
	endif;
	
	return inheritMethod(_attrName, _short);

epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getEndTS" id="d7dcb27e-90b5-45a8-9323-34a1c47109ae">
        <source>getEndTS(): TimeStamp;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 19/07/2017	jlgdap1		Initial creation TFS 5286 SSL Voyage Event Charging
//
vars

begin
	if self.dateTimeEnd &lt;&gt; null then
		return self.dateTimeEnd;
	endif;
	return inheritMethod();

epilog

end;</source>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="getLoadingHours" id="3070f35f-e9e0-40e8-b971-eae607b961cd">
        <source>getLoadingHours(_date : Date ; _finishEvent : CM_EventTransaction) : Real;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 Aug 2019	jlgsl4	TFS 45615 - ASPA - Ship Load Summary
*/
constants
	MillisecInHour = 3600000;
vars
	loadingHours : Real;
	startDateTime, finishDateTime : TimeStamp;
begin
	startDateTime := self.dateTime;
	finishDateTime := _finishEvent.dateTime;
	if _date &gt;= startDateTime.date and _date &lt;= finishDateTime.date then // date is inside the operation 'window'
		if startDateTime.date = finishDateTime.date then // if loading for some part of a day
			loadingHours := finishDateTime.differenceInHoursReal(startDateTime); // then get the hours spent on that day
		elseif _date = startDateTime.date then // if checking hours on start date,
			loadingHours := 24 - startDateTime.time.Real / MillisecInHour; // find hours spent until end of the day
		elseif _date = finishDateTime.date then // if checking hours on finish date,
			loadingHours := finishDateTime.time.Real / MillisecInHour; // find hours spent until end time
		else
			loadingHours := 24;	
		endif;
	endif;
	return loadingHours;
epilog

end;</source>
        <Parameter name="_date" type="Date"/>
        <Parameter name="_finishEvent" type="CM_EventTransaction"/>
        <ReturnType type="Real"/>
    </JadeMethod>
