    <JadeMethod name="addToolbarControls" id="4e5b62eb-d0fe-4ede-b8c3-d4b7739b6da2">
        <updating/>
        <source>addToolbarControls() updating, protected;
//------------------------------------------------
// Created: 06 April 2006 By: cnwgd1
//------------------------------------------------
vars
	toolbarObj	: CMUI_Toolbar;
	
begin
	inheritMethod();

	toolbarObj	:=	self.frmToolbar;
	
	//toolbarObj.addButton(self.btnNew, CMUI_Toolbar.Control_Alignment_Left);				
	//toolbarObj.addButton(self.btnEdit, CMUI_Toolbar.Control_Alignment_Left);				
	
	//toolbarObj.addSeperator(CMUI_Toolbar.Control_Alignment_Left);				
	
	toolbarObj.addButton(self.btnSaveBase, CMUI_Toolbar.Control_Alignment_Left);				
	toolbarObj.addButton(self.btnNext, CMUI_Toolbar.Control_Alignment_Left);
//	toolbarObj.addButton(self.btnDelete, CMUI_Toolbar.Control_Alignment_Left);				
	toolbarObj.addSeperator(CMUI_Toolbar.Control_Alignment_Left);				
	
	toolbarObj.addButton(self.btnCancelBase, CMUI_Toolbar.Control_Alignment_Right);								
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="adjustVolumeWeight" id="d9735617-8d2b-48ec-972d-3eab0b654a34">
        <source>adjustVolumeWeight() protected;
/*
----------   ----------  --------------------------------------------------
Created:	28 March 2007 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	ti			: CM_TrackedItem;
	newVolume,
	enteredVolume		: Decimal[23,3];
	newWeight,
	enteredWeight,
	newQuantity,
	enteredQuantity		: Integer;
begin
	ti := self.mySelectedTI;
	if ti = null then
		return;
	endif;
	if ti.pxyIsProxy then
		ti := ti.pxyGetRealObject;
	endif;
	enteredQuantity := self.txtQuantity.text.Integer;
	enteredVolume := self.txtVolume.text.asDecimalJMT();// 01 APR 2010	NDL	Par 23556
	enteredWeight := self.txtWeight.text.Integer;
	
	if enteredQuantity &lt;&gt; null and ti.totalQuantity &lt;&gt; null then
		newVolume := ((enteredQuantity / ti.totalQuantity) * ti.getMyTotalVolume).roundedTo(3);
		newWeight := ((enteredQuantity / ti.totalQuantity) * ti.totalWeight).rounded();			//+cnwml2 MSL CCMS 1017
		
		self.txtVolume.text := newVolume.String;
		self.txtWeight.text := newWeight.String;
	endif;
end;


</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="attachmentAdd" id="858950c5-82ce-4707-a2de-3e4af1a1ce79">
        <updating/>
        <source>attachmentAdd(_ti : CM_TrackedItem; _doUpdateDetails : Boolean) protected, updating;
/*
----------   ----------  --------------------------------------------------
Created:	26 March 2007 By cnwth2

Purpose:	_doUpdateDetails will be true from when they click add from selecting
			in item combo and false when adding via drag and drop

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	pxyTI			: CM_TrackedItem;
	rowStr			: String;
	quantity,
	weight,
	row,
	numRows			: Integer;
	tbl				: CM_DataTable;
	voyage			: CM_Voyage;
begin
	if self.trackedItemDetailsChanged and (not self.checkDoAbandonTIChanges()) then
		return;
	endif;
	
	self.trackedItemDetailsChanged := false;
	tbl := self.tblAttachments;
	numRows := tbl.rows;
	foreach row in tbl.fixedRows + 1 to numRows do
		if tbl.accessRow(row).itemObject.CM_TrackedItem.id = _ti.id then
			app.msgBox('Item ' &amp; _ti.id &amp; ' has already been added as an attachment.', 'Item already attached.', MsgBox_Exclamation_Mark_Icon);
			return;
		endif;
	endforeach;
	
	if _ti.site &lt;&gt; TI_SITE_ONSITE then
		app.msgBox(app.getErrorString1(ERR_TI_NOT_ONSITE, _ti.id), app.getErrorString(Error), MsgBox_Exclamation_Mark_Icon);
		return;
	endif;
	
	voyage := self.cmbVoyage.listObject.CM_Voyage;
	
	if (not self.warnedAboutVoyage) and voyage &lt;&gt; null and (not voyage.isNullVoyage) and voyage &lt;&gt; _ti.myVoyage then
		if app.msgBox('The currently selected voyage  ' &amp; voyage.code &amp; ' but the item you are attaching is for voyage ' &amp; _ti.voyageCode &amp; '. ' &amp; 
						'Are sure you wish to attach the item?','Different voyage - are you sure?', MsgBox_Yes_No) &lt;&gt; MsgBox_Return_Yes then
			return;
		else
			self.warnedAboutVoyage := true;
		endif;
	endif;

	if self.cmbConsignee.listObject = null and _ti.myConsignee &lt;&gt; null then	//Par18714 Jan 2009
		self.cmbConsignee.setObject(_ti.myConsignee);
	endif;

	beginLoad;
	pxyTI := app.createUpdateProxy(_ti).CM_TrackedItem;
	endLoad;
	
	if _doUpdateDetails then
		if pxyTI.canMergeBreakBulk then
			pxyTI.setQVW(pxyTI.quantity, self.txtVolume.text.asDecimalJMT(), self.txtWeight.text.Integer);	// 01 APR 2010	NDL	Par 23556
			pxyTI.setTotalQuantity(self.txtQuantity.text.Integer);
		endif;
		
		pxyTI.setMark(self.txtMark.text.trimBlanks());
		pxyTI.setMarkNumber(self.txtMarkNumber.text.trimBlanks());
		pxyTI.setDescription(self.txtDescription.text.trimBlanks());
	endif;
	
	rowStr := pxyTI.getAttributeStringForDefArray(self.tblAttachments.allTblDataEntRows);
	self.tblAttachments.addItemObject(pxyTI, rowStr);
	
epilog
	endLoad;
end;


</source>
        <access>protected</access>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_doUpdateDetails" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="attachmentRemove" id="59a310e6-479e-4f72-816c-c44ff33a1510">
        <source>attachmentRemove() protected;
/*
----------   ----------  --------------------------------------------------
Created:	27 March 2007 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	pxyTI,
	ti			: CM_TrackedItem;
	
begin
	ti := self.tblAttachments.accessRow(self.tblAttachments.row).itemObject.CM_TrackedItem;
	
	if ti = null then //or (not self.tblAttachments.accessedRow.selected) then
		app.msgBox(app.getErrorString2(PleaseSelectAnObject,'cargo item', 'remove'), app.getErrorString(Nothing_Selected), MsgBox_Exclamation_Mark_Icon);
		return;
	endif;
	
	self.tblAttachments.removeItemObject(ti);
	delete ti;//it's a proxy
	
end;




</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="attachmentUpdate" id="34eb0e6b-a221-47b5-9d02-a56c7577c990">
        <updating/>
        <source>attachmentUpdate() protected, updating;
/*
----------   ----------  --------------------------------------------------
Created:	26 March 2007 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	rowStr			: String;
	row				: Integer;
	ti				: CM_TrackedItem;
begin
	self.trackedItemDetailsChanged := false;
	row := self.tblAttachments.row;
	ti := self.tblAttachments.accessRow(row).itemObject.CM_TrackedItem;
	
	if ti = null or (not self.tblAttachments.accessedRow.selected) then
		app.msgBox(app.getErrorString2(PleaseSelectAnObject, 'cargo item', 'update'), app.getErrorString(Nothing_Selected), MsgBox_Exclamation_Mark_Icon);
		return;
	endif;
	
	if ti.canMergeBreakBulk then
		ti.setQVW(ti.quantity, self.txtVolume.text.asDecimalJMT(), self.txtWeight.text.Integer);	// 01 APR 2010	NDL	Par 23556
		ti.setTotalQuantity(self.txtQuantity.text.Integer);
	endif;
	
	ti.setMark(self.txtMark.text.trimBlanks());
	ti.setMarkNumber(self.txtMarkNumber.text.trimBlanks());
	ti.setDescription(self.txtDescription.text.trimBlanks());
	
	rowStr := ti.getAttributeStringForDefArray(self.tblAttachments.allTblDataEntRows);
	self.tblAttachments.removeItem(row);
	self.tblAttachments.addItemAt(rowStr, row);
	self.tblAttachments.accessRow(row).itemObject := ti;
	self.tblAttachments.accessedRow.selected := true;
	
end;


</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="btnAttach_click" id="46eb1ff0-3c1c-4696-9ec9-58fda19a3201">
        <controlMethod name="CMUI_Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
