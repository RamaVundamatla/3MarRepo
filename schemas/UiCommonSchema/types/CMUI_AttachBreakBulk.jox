    <JadeMethod name="doCmbCargoTypeClick" id="e522575f-0965-48ea-bdd1-963ac19193f6">
        <updating/>
        <source>doCmbCargoTypeClick() updating;
// ---------------------------------------------------------------------------
// Created:     17 October 2002		cnwth2	
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	cargoType			: CM_CargoType;

begin
	cargoType := self.cmbCargoType.listObject.CM_CargoType;
	
	app.setMyCurrentCargoType(cargoType);
	self.showAttributesForCargoType(cargoType);	
	
	self.loadProducts(cargoType);

	self.doCmbProductClick();

	if self.aUseMasterContainer then 
		self.hideRowsForMakeAttachment;
	endif;

	if self.isFromShipPreNote then 
		self.hideRowsForShipPreNote();
	endif;
	
	// PAR #31155 handle measurement rows
//	self.resetMeasurementRows(self.tblItem);		//epr par 32062 already hidden the rows that don't apply to the cargo type don't re show them																			// PAR #31155
	self.loadMeasurementTypes(self.tblItem, self.tblItem.myEntTableDef.name, self.tblItem.myEntTableDef.allEntTableRows, true);	// PAR #31155
	// PAR #31155 end
end;</source>
    </JadeMethod>
