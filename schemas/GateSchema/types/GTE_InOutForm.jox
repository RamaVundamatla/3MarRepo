    <JadeMethod name="checkAndAddVehicle" id="cc864268-8d72-466a-9291-c58b1d18eab1">
        <updating/>
        <source>checkAndAddVehicle(_regNumber : String; _carrierCode : String) : Boolean updating, protected;
// ---------------------------------------------------------------------------
// Created:     29 May 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	pxyVehicle,
	realVehicle	: CM_Vehicle;
	result		: Integer;
	
begin

	realVehicle := self.myTerminal.vehicles[_regNumber, ""];
	if realVehicle = null then
	
		if (app.msgBox(app.getErrorString1(VB_NEW_VEHICLE, _regNumber), 'Warning', MsgBox_OK_Cancel) &lt;&gt; MsgBox_Return_OK) then
			return false;
		endif;

		create pxyVehicle transient;
		pxyVehicle.setProxy(_regNumber, null, null, 0, app.myRoot.allCarriers[_carrierCode], null,  false, self.myTerminal);

		while true do
			app.myTrxCA.trxCreateVehicle(pxyVehicle, realVehicle, app.myPassport);
			if app.myPassport.trxCompletedOK then
		
				// Clear errors/warnings from form and err/warnings window
				self.clearErrorWarnings();
				break;
			else
				result := app.showErrorWarningDialog('Gate In/Out', app.myPassport, ErrWarnMode_Add + ErrWarnMode_CanAckWarnings);
				if app.myPassport.noErrors and
				   result = IDOK then
					// there must have just been warnings that the user has acknoledged so ..
					app.myPassport.warningsAcknowledged	:= true;
					continue;
				endif;
		
				self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
			endif;
			
			return false;
	
		endwhile;
		
	endif;

	return true;

epilog
	delete pxyVehicle;
end;</source>
        <access>protected</access>
        <Parameter name="_regNumber" type="String"/>
        <Parameter name="_carrierCode" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
