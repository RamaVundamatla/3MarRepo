    <JadeMethod name="pxyCreateUpdateProxy" id="3ab69e65-a8f9-42a8-ab02-7ee9694cbd8c">
        <source>pxyCreateUpdateProxy(): SelfType;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 08/05/2018	jlgdap1		Initial creation TFS 38501 PEL1 Work Order Changes
//
vars
	pxy : SelfType;
	completedOK	: Boolean;

begin
	pxy := inheritMethod();
	
	pxy.myNewVoyage := self.myNewVoyage;
	
	completedOK := true;
	return pxy;

epilog
	if not completedOK then 
		delete pxy;
	endif;
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
