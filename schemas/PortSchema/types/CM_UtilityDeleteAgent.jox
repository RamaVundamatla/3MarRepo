		app.myEventManager.createSingleObjInfoNoteEvt(_obj.myInvoiceContractDetail,app.myPassport.myTerminal.getTerminalEvent(Event_InvContractRateDelete),_obj);//09-02-2023 navtnr20 TFS CR 55646 TASK 55665
