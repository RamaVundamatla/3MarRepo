    <JadeMethod name="btnDelPrefBerth_click" id="4938cb3e-d6ce-4231-9d6c-7817208d638e">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnDelPrefBerth_click(btn: Button input) updating;

vars
	berthPref:		HMS_BerthPreference;
	msgBoxType: 	Integer;
begin 
	if self.tblPrefBerth.row &lt;= self.tblPrefBerth.fixedRows then
		return;
	endif;
	// get selected berthPref;
	// Movement object associated with first column of the table
	tblPrefBerth.column:=1;
	
	//if tblPrefBerth.itemObject&lt;&gt;null then
		//berthPref:=tblPrefBerth.itemObject.HMS_BerthPreference;
		// Confirm deletion
		msgBoxType:=MsgBox_Yes_No+MsgBox_Question_Mark_Icon+MsgBox_Default_Second;
		if app.msgBox(app.getErrorString(MSGBOX_DelBerthPref) &amp; "'" &amp; tblPrefBerth.accessCell(tblPrefBerth.row,1).text &amp; "'?", app.getErrorString(Confirm_Delete), msgBoxType)=MsgBox_Return_Yes then
			// OK Clicked: Proceed with delete
			// delete berthPref from collection (this is automatic with inv references)
			// Delete row from table
			tblPrefBerth.deleteRow(tblPrefBerth.row);
			// update table
			setRowTblPrefBerth;
		endif;	
	//endif;
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="btnDelResource_click" id="c50aa40a-1041-4829-9cfb-9a1d840fd9a1">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnDelResource_click(btn: Button input) updating;
//--------------------------------------------------
// Created:	08 April 2005 By: cnwgd1
//--------------------------------------------------
vars
	resourceMove :	HMS_ResourceTypeForMovement;
begin 
	
	if self.tblResources.row &lt;= self.tblResources.fixedRows then
		return;
	endif;
	
	self.tblResources.column := 1;
	
	// Confirm deletion
	if app.msgBox(app.getErrorString2(ConfirmDelete, 'Resource for movement', self.tblResources.accessCell(self.tblResources.row, self.tblResources.getColumnByRowName(ETRow_MoveType)).text), 'Confirm Deletion', MsgBox_Yes_No + MsgBox_Question_Mark_Icon + MsgBox_Default_Second) = MsgBox_Return_No then	
		return;
	endif;
	
	// OK Clicked: Proceed with delete row from table
	self.tblResources.deleteRow(self.tblResources.row);

end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
