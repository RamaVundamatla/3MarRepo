    <JadeMethod name="setNetWeight" id="175a4823-dabf-409b-9140-343d25971e93">
        <source>setNetWeight(table : CM_EntryTable input; row : Integer);
// ---------------------------------------------------------------------------
// Created:     03 May 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	gross,
	tare,
	net		: Real;
	
begin

	gross := table.getValueByName(ETRow_WeightGrossTonnes).Real;
	if gross = 0 then
		return;
	endif;
	tare := table.getValueByName(ETRow_WeightTareTonnes).Real;
	if tare = 0 then
		return;
	endif;

	net := (gross - tare).roundedTo(3);
	if net &gt;= 0 then
		table.setValue(row, net);
	endif;
	
end;</source>
        <Parameter name="table" type="CM_EntryTable" usage="input"/>
        <Parameter name="row" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setProxyWorkOrderSource" id="a02279d3-9104-4ed2-93c5-904d4c8aaed1">
        <source>setProxyWorkOrderSource(
		_realWOSource : CM_WorkOrderTISource;  //This will only need to be set for persistent objects
		_parent : CM_Object; 
		_cargoType : CM_CargoType; 
		_tiStr : String; 
		_forUpdate : Boolean
		) : CM_WorkOrderTISource;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
18 August 2009	cnwmd1	Initial creation


 Replaced by CM_WorkOrder::setProxyWorkOrderSource()

*/

vars
	/*newProxy : CM_WorkOrderTISource;
	cargoTypeId : Integer;*/
begin
	return null;
	/*if _cargoType &lt;&gt; null then
		cargoTypeId := _cargoType.id;
	endif;
	
	if _forUpdate and _realWOSource &lt;&gt; null then
		newProxy := _realWOSource.pxyCreateUpdateProxy(); //Update proxy from real
	else
		create newProxy transient;
		newProxy.setProxy(cargoTypeId, _tiStr);
	endif;
	
	newProxy.setMyParent(_parent);
	return newProxy;*/
epilog

end;</source>
        <Parameter name="_realWOSource" type="CM_WorkOrderTISource"/>
        <Parameter name="_parent" type="CM_Object"/>
        <Parameter name="_cargoType" type="CM_CargoType"/>
        <Parameter name="_tiStr" type="String"/>
        <Parameter name="_forUpdate" type="Boolean"/>
