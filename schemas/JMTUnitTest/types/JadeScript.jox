<Class name="JadeScript">
    <JadeMethod name="aaaaaGetFailedTests" id="194b5a36-66c4-43d6-8e8f-6ec80a81badf">
        <source>aaaaaGetFailedTests();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 November 2014	cnwdb2	Initial creation

*/

vars
	unitTestResult : UM_UnitTestResult;
	unitTestRun : UM_UnitTestRun  ; 
	uTForm  :UnitTestResultsForm ; 
	
	file  : File  ;
begin

	create file;
    file.fileName := "c:\temp\temp.unl";
	if file.isAvailable() then
		file.purge() ; 
	endif ; 
	while not file.endOfFile do
		file.writeLine("Test") ; 
		file.writeLine("Another line test") ; 
	endwhile ;

	
	
	
epilog
	delete file  ; 
end;</source>
    </JadeMethod>
    <JadeMethod name="aaaaaaGetFailedTests2" id="7b113339-c88b-4dd7-97a0-11ab4b1c4569">
        <source>aaaaaaGetFailedTests2();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 November 2014	cnwdb2	Initial creation

*/

vars
	testRuns					: UM_UnitTestRun;
	unitTestResults				: UM_UnitTestResult;
	iter,iter2					: Iterator;	
	ts							: TimeStamp;
	tempTimeStamp				: TimeStamp;
	date : Date ; 
	currentDate : String ; 
	root : UM_Root ; 
	
	methNameCol : StringArray  ; 
	
	str : String ;  
		file  : File  ;

	
begin
	create methNameCol transient ; 

	root := UM_Root.firstInstance() ;
	
	if root = null then // if there is no first instance of root then leave.
		return ; 
	endif ; 
	currentDate :=  date.day().String &amp; "/" &amp; date.month().String &amp; "/" &amp; date.year().String ; 
//	ts.setDate("18/11/2014".Date) ; 
	ts.setDate(currentDate.Date);
	ts.setTime("00:00:00".Time);
	
	iter := root.allUnitTestRuns.createIterator;
	
//	root.allUnitTestRuns.startKeyGeq(ts, iter);

	testRuns := root.allUnitTestRuns.getAtKeyGeq(ts) ; 
//	while iter.next(testRuns) do

	tempTimeStamp := testRuns.startTS;
	if tempTimeStamp.date &lt; testRuns.endTS.date then
		tempTimeStamp := testRuns.endTS;
	endif;
	if tempTimeStamp = null then						
		tempTimeStamp := testRuns.startTS;
	endif;
	if tempTimeStamp.date &gt; ts.date then
		//break;
		return  ;
	endif;
	
	foreach unitTestResults in testRuns.allFailed do
		
	//	write unitTestResults.myClassMethod.methodName ; 
	methNameCol.add("Method " &amp; unitTestResults.myClassMethod.className &amp; " " &amp; unitTestResults.myClassMethod.methodName) ;
		
		
	endforeach ; 

	
	if methNameCol.size &gt; 1 then
	
		create file;
		file.fileName := "c:\temp\temp.unl";
		if file.isAvailable() then
			file.purge() ; 
		endif ; 
	
		foreach str in methNameCol do
				file.writeLine(str) ; 
		endforeach ;	 
	endif ; 
		//	mergeIter.addCollection(testRuns.allFailed);
		
	//	endwhile ; 
epilog
	delete methNameCol ; 
	delete file ; 
end;</source>
    </JadeMethod>
    <JadeMethod name="addMethodToList" id="3342086b-6c51-4498-a70e-f99d79f976e3">
        <source>addMethodToList(_klassName, _methodName : String; _meth : Method input; _methodsArray, _methodsAlreadyCheckedArray : MethodSet io; _index : Integer io;
		_outputFile : File io);

/*

Purpose:		update the _methodsArray with relevent methods (recursive routine)

Date			Who		Reason
27/09/2012		cnwmh5	Initial creation

*/

vars
	
	refMethod						: Method;			// The method in which "_meth" is referenced (invoked).
	form							: Form;
	cntrl							: Control;
	tmpMenu							: MenuItem;
	
	methodRefSet					: MethodSet;		// A set of the methods in which "_meth" is referenced (invoked).
	checkMethodsArray				: MethodSet;
	
	str								: String;
	idx								: Integer;
	numControls						: Integer;
	numMenus						: Integer;
	index							: Integer;
	isGUIClass						: Boolean;
	foundForm						: Boolean;
	foundMenu						: Boolean;
	className						: String;
	methodName						: String;
	
begin

	// set the number of tabs for output.  testing only
	/*
	_index := _index + 1;
	if _index &gt; 0 then
		foreach idx in 1 to _index do
			str := str &amp; "-";
		endforeach;
	endif;
	*/
	
	// get the methods and process
	create methodRefSet transient;
	_meth.getMethodRefs(methodRefSet);								// Get the set of references to the method.
	
	foreach refMethod in methodRefSet do
	
		// don't care if already been added to the array
		if not _methodsAlreadyCheckedArray.includes(refMethod) then
			_methodsAlreadyCheckedArray.add(refMethod);
		else
			continue;
		endif;
	
		// progess further down the tree
		self.addMethodToList(_klassName, _methodName, refMethod, _methodsArray, _methodsAlreadyCheckedArray, _index, _outputFile);
		
		// is GUIClass
		isGUIClass := refMethod.getSchemaType().isKindOf(GUIClass);
		
		// check to see if we actually need to add it to the list
		if not isGUIClass then
			if refMethod.isRunnableUnitTestMethod() then
				///write str &amp; " " &amp; _klassName &amp; Tab &amp; _methodName &amp; Tab &amp; refMethod.getSchemaType().name &amp; Tab &amp; refMethod.name &amp; Tab &amp; _index.String;
				write _klassName &amp; Tab &amp; _methodName &amp; Tab &amp; refMethod.getSchemaType().name &amp; Tab &amp; refMethod.name;
				_outputFile.writeLine(_klassName &amp; Tab &amp; _methodName &amp; Tab &amp; refMethod.getSchemaType().name &amp; Tab &amp; refMethod.name);
			endif;
		else 	
			// if it's a form then get all the controls on the form so can check against method name to see if 
			foundForm := false;
			foundMenu := false;
			
			// check to see if form
			foreach form in Form.instances do
				if form.name = refMethod.getSchemaType().name then
					break;
				endif;
			endforeach;
			
			// if form then check refMethod.name against controls to see if control
			if refMethod.name.cnContains("_") then
				// check the controls
				numControls := form.controlCount;
				foreach index in 1 to numControls do
					cntrl := form.controls(index);
					// dont match so get next control
					if refMethod.name[1:cntrl.name.length] &lt;&gt; cntrl.name then
						continue;
					endif;
					// match so set and break
					foundForm := true;
					break;
				endforeach;
				// check the menus
				numMenus := form.menuItemCount;
				foreach index in 1 to numMenus do
					tmpMenu := form.menuItems(index);
					// if name null don't want to know about it
					if tmpMenu.name = null then
						continue;
					endif;
					// if separator dont' want to know about it
					if tmpMenu.isSeparatorJMT() then
						continue;
					endif;
					if refMethod.name[1:tmpMenu.name.length] &lt;&gt; tmpMenu.name then
						continue;
					endif;
					// match so set and break;
					foundMenu := true;
					break;	
				endforeach;
			endif;
			
			// no control found so next
			if not foundForm then
				methodRefSet.addNoDuplicates(refMethod, false);
			endif;
			
			if not foundForm then
				methodRefSet.addNoDuplicates(refMethod, false);
			endif;
			
			if not foundForm and not foundMenu then
				continue;
			endif;
			
			///write str &amp; " " &amp; _klassName &amp; Tab &amp; _methodName &amp; Tab &amp; refMethod.getSchemaType().name &amp; Tab &amp; refMethod.name &amp; Tab &amp; _index.String;
			write _klassName &amp; Tab &amp; _methodName &amp; Tab &amp; refMethod.getSchemaType().name &amp; Tab &amp; refMethod.name;
			_outputFile.writeLine(_klassName &amp; Tab &amp; _methodName &amp; Tab &amp; refMethod.getSchemaType().name &amp; Tab &amp; refMethod.name);
			
		endif;
		
	endforeach;
	
	
epilog

	///write str &amp; Tab &amp; 'End: ' &amp; _meth.getSchemaType().name &amp; " :: " &amp; _meth.name;
	_index := _index - 1;

	delete methodRefSet;
	delete checkMethodsArray;

end;
</source>
        <Parameter name="_klassName" type="String"/>
        <Parameter name="_methodName" type="String"/>
        <Parameter name="_meth" type="Method" usage="input"/>
        <Parameter name="_methodsArray" type="MethodSet" usage="io"/>
        <Parameter name="_methodsAlreadyCheckedArray" type="MethodSet" usage="io"/>
        <Parameter name="_index" type="Integer" usage="io"/>
        <Parameter name="_outputFile" type="File" usage="io"/>
    </JadeMethod>
    <JadeMethod name="addMethodToList_New" id="2039816a-0cd3-4f7c-9d39-5588279790fe">
        <source>addMethodToList_New(_trxClassName, _trxMethodName : String input; _method : Method input; _index : Integer; _refsByLevel, _uniqueMethsByLevel : IntegerArray io; _allRefs : ObjectSet io);

/*

Purpose:			

Parameters:			

Return Value:		


Date			Who		Reason
19 October 2012	cnwmh5	Initial creation

*/

vars
	refMethod		: Method;			// The method in which "pMethod" is referenced (invoked).
	methodRefSet	: MethodSet;		// A set of the methods in which "pMethod" is referenced (invoked).
	i:Integer;
begin
	//i:=lstTree.addItem(pMethod.schemaType.schema.name &amp; " :: " &amp; pMethod.schemaType.name&amp;" :: "&amp;pMethod.name);
	write _trxClassName &amp; Tab &amp; _trxMethodName &amp; Tab &amp; _method.getSchemaType().name &amp; Tab &amp; _method.name;
	_refsByLevel[_index] := _refsByLevel[_index] + 1;
	//lstTree.itemObject[i]:=pMethod;
	//lstTree.itemLevel[i]:=pLevel;
	if _allRefs.includes(_method) then
		return;
	endif;
	_allRefs.add(_method);
	_uniqueMethsByLevel[_index] := _uniqueMethsByLevel[_index] + 1;
	//if chkSuppressFW.value and suppressThisMethod(pMethod.schemaType,pMethod.name) then
	//	return;
	//endif;
	
	create methodRefSet transient;							// Create a set for the references.
	_method.getMethodRefs(methodRefSet);				// Get the set of references to the method.
	foreach refMethod in methodRefSet do
		addMethodToList_New(_trxClassName, _trxMethodName, refMethod, _index + 1, _refsByLevel, _uniqueMethsByLevel, _allRefs);
	endforeach;

	//if chkSuperCalls.value then
//		addSuperclassRefsToList(pMethod.schemaType,pMethod.name,methodRefSet);
		processSuperClassRefs_New(_trxClassName, _trxMethodName, _method.schemaType, _method.name, _index, _refsByLevel, _uniqueMethsByLevel, _allRefs);
	//endif;


epilog
	delete methodRefSet;
end;</source>
        <Parameter name="_trxClassName" type="String" usage="input"/>
        <Parameter name="_trxMethodName" type="String" usage="input"/>
        <Parameter name="_method" type="Method" usage="input"/>
        <Parameter name="_index" type="Integer"/>
        <Parameter name="_refsByLevel" type="IntegerArray" usage="io"/>
        <Parameter name="_uniqueMethsByLevel" type="IntegerArray" usage="io"/>
        <Parameter name="_allRefs" type="ObjectSet" usage="io"/>
    </JadeMethod>
    <JadeMethod name="checkClassMapFiles" id="aa95e3eb-eeab-4200-9cbf-5f129b82c1b6">
        <source>checkClassMapFiles();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 April 2013	cnwmc5	Initial creation

*/

vars
	klass			: Class;
	
	dbClassMap		: DbClassMap;
	
begin
	foreach dbClassMap in DbClassMap.instances do
		klass := dbClassMap.diskClass;
		if klass.schema.name = "JMTUnitTest" then
			if klass.countPersistentInstances &gt; 0 then
				write klass.getDbFile.name &amp; " - " &amp; klass.name;
			endif;
		endif;
		/*if klass.schema.name = "JMTUnitTest" and not klass.name.cnContains("CMUI_") then
			if dbClassMap.diskFile.name &lt;&gt; "unitTest" then
				write klass.name &amp; " - " &amp; dbClassMap.diskFile.name;
			endif;
		endif;*/
	endforeach;
epilog
	
end;</source>
    </JadeMethod>
