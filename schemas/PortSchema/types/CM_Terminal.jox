    <JadeMethod name="setNextSystemVoyageCode" id="1b08266a-61a7-41ef-b85d-7395dc6498fb">
        <source>setNextSystemVoyageCode(_code : String);
//--------------------------------------------------
// Created:	23 August 2004 By: cnwgd1
//--------------------------------------------------
vars
	keySeries : CM_KeySeries;
	seriesKey : CM_SeriesKey;
	tmpCode	: String;
begin
	
	keySeries := self.allKeySeriesByCode[SN_HMSVoyageCode];
	if keySeries = null then
		return;
	endif;
	
	seriesKey := keySeries.nextKey;
	
	if seriesKey = null then
		return;
	endif;
	
	tmpCode := seriesKey.prefix &amp; seriesKey.root.String;
	
	if tmpCode &lt;&gt; _code then
		return;
	endif;
	
	//System code has been used for this voyage, update next system voyage code											
	self.getHMSNextVoyageCode();
	
end;</source>
        <Parameter name="_code" type="String"/>
    </JadeMethod>
    <JadeMethod name="setPermValue" id="ad285407-2409-4dfc-946a-7cd98698dafd">
        <updating/>
        <source>setPermValue(_keyValue : Any) updating, protected;
// ---------------------------------------------------------------------------
// Created:     10 March 2003 by cnwrs2
//
// Purpose:     _keyValue passed in is deliberately ignored
// ---------------------------------------------------------------------------
vars
	tmpTime	: Time;
	
begin
	
	// the calculation of the permValue below is repeated in the setForUpdate method 
	tmpTime := self.creationTime.localToUTCTime.Time;
	self.permValue := ((tmpTime.hour * tmpTime.minute) + tmpTime.second + 42);

end;</source>
        <access>protected</access>
        <Parameter name="_keyValue" type="Any"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="9513da14-6eb7-44e1-a98b-4c69aafaf242">
        <updating/>
        <source>setProxy(pCode, pName,_timeZoneID,_timeZoneShortID : String; pCargoBolTypeArray : CM_CargoBOLTypeArray; 
		_dfltCargoType, _dfltBolType, _dfltCargoBolType, _dfltCargoGroupType, _dfltTrailerCargoType : Integer; 
		_weightAuth : CM_WeighAuthority) updating;
// 22 June 2016	cnwns1	TFS 488 - Multi Timezone Support
// 04 July 2017	cnwdap1	TFS 4492 SNO VERMAS Changes
// 21 Jun 2023	navdap1	TFS 56747 EUP Manifest Load - Internal (Zimmer) - Create
// 01 Aug 2025  navsp1  JIRA-35530 Solution Implementation - COPRAR Trailer Support
vars
	weighAuthTerm : CM_WeighAuthTerminal;		// TFS 4492

begin
	self.raiseExceptionIfNotTransient(method);

	self.code	:= pCode;
	self.name 	:= pName;
	self.timeZoneID := _timeZoneID;				// 22 June 2016	cnwns1	TFS 488 - Multi Timezone Support
	self.timeZoneShortID := _timeZoneShortID;	// 22 June 2016	cnwns1	TFS 488 - Multi Timezone Support
	self.allCargoBOLTypes.clear;
	pCargoBolTypeArray.copy(self.allCargoBOLTypes);
	self.defaultCargoType := _dfltCargoType;
	self.defaultBolType := _dfltBolType;
	self.defaultCargoBolType := _dfltCargoBolType;
	self.defaultCargoGroupType := _dfltCargoGroupType;		// TFS 56747
	self.defaultTrailerCargoType := _dfltTrailerCargoType; //JIRA-35530
    
	if _weightAuth &lt;&gt; null then 										// TFS 4492
		weighAuthTerm := self.allWeighAuthTerminals[_weightAuth];		// TFS 4492
		if weighAuthTerm = null then									// TFS 4492
			create weighAuthTerm transient;								// TFS 4492
			weighAuthTerm.setForCreate(true, _weightAuth, self);		// TFS 4492
		endif;															// TFS 4492
	endif;																// TFS 4492
end;</source>
        <Parameter name="pCode" type="String"/>
        <Parameter name="pName" type="String"/>
        <Parameter name="_timeZoneID" type="String"/>
        <Parameter name="_timeZoneShortID" type="String"/>
        <Parameter name="pCargoBolTypeArray" type="CM_CargoBOLTypeArray"/>
        <Parameter name="_dfltCargoType" type="Integer"/>
        <Parameter name="_dfltBolType" type="Integer"/>
        <Parameter name="_dfltCargoBolType" type="Integer"/>
        <Parameter name="_dfltCargoGroupType" type="Integer"/>
        <Parameter name="_dfltTrailerCargoType" type="Integer"/>
        <Parameter name="_weightAuth" type="CM_WeighAuthority"/>
    </JadeMethod>
