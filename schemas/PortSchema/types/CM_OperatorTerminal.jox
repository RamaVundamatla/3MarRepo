    <JadeMethod name="displayCode" id="f1916b1a-86f6-482d-8e14-61bf1cfb9160">
        <methodInvocation>mapping</methodInvocation>
        <source>displayCode(set: Boolean; _value: String io) mapping;

vars

begin
	if set then
		// set code here
	else
		_value := self.myOperator.code&amp;' '&amp;self.myTerminal.code;
	endif;

end;
</source>
        <Parameter name="set" type="Boolean"/>
