    <JadeMethod name="getDisplayStringForAttribute" id="a48f715f-687b-4b00-9634-855c17a1d075">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 January 2018	jlgmp6	Initial creation

*/

vars
	dac: CM_DataAccessController;
begin
	if _attrName = ETRow_OpDAForReceive then
		dac := self.getFirstDACRec();
		if dac &lt;&gt; null then
			return dac.name;
		endif;
		return null;
	elseif _attrName = ETRow_OpDAForRelease then
		dac := self.getFirstDACRel();
		if dac &lt;&gt; null then
			return dac.name;
		endif;
		return null;		
	elseif _attrName = ETRow_FinancialId then	//04.Mar.24 navsp1 TFS 57177
		if self.myDebtor &lt;&gt; null then
			return self.myDebtor.code;
		endif;
		return null;
	endif;

	return inheritMethod(_attrName, _short);

epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
