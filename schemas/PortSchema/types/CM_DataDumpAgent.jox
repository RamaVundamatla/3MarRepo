<Class name="CM_DataDumpAgent" id="6e60e30e-9177-4fe7-b92c-b644f07d9f84">
    <superclass name="CM_Agent"/>
    <transient/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <abstract/>
    <text>Responsible for maintaining the supporting classes for data dumps.</text>
    <DbClassMap file="cmtrans"/>
    <Constant name="DataDumpLogName" id="d3d33ddb-395a-416f-a215-2062aa58673b">
        <source>"dataExtract.log"</source>
        <type name="String"/>
    </Constant>
    <Constant name="DataDumpLogUnderline" id="5b890a58-01cc-40d8-b196-bc12a0a740bb">
        <source>"----------------------------------------------------------------------------------------------------"</source>
        <type name="String"/>
    </Constant>
    <Constant name="DebugTracingToObjectLevel" id="9362ccae-c894-4322-a534-088c41c121ac">
        <source>false</source>
        <type name="Boolean"/>
    </Constant>
    <ImplicitInverseRef name="allSystemAlertMessages" id="895300b2-dc2e-4559-afb8-009aa1fde783">
        <embedded/>
        <type name="CM_FieldEntityArray"/>
        <access>protected</access>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="myLog" id="f770590c-2d81-4991-a6b1-aa5c2993231f">
        <embedded/>
        <type name="JadeLog"/>
        <access>protected</access>
    </ImplicitInverseRef>
    <JadeMethod name="createAlert" id="663ae634-d729-489d-8911-d38b150f4185">
        <source>createAlert(_msg : String; _severity : Integer) protected;

vars
	alert: CM_SystemAlert;
	setInTransState: Boolean;
begin
	if not process.isInTransactionState then
		setInTransState := true;
		beginTransaction;
	endif;
	create alert;
	alert.details := _msg;
	alert.setSeverity(_severity); //SEVERE_WARNING);
	//-----------
	//Tell alert to add itself to system
	//-----------
	alert.add;
epilog
	if setInTransState then
		app.cmsCommitTransaction(app.myPassport);
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="_msg" type="String"/>
        <Parameter name="_severity" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="createLog" id="0f786b24-2ccb-4959-8f6f-6e6019e86141">
        <updating/>
        <source>createLog(_filename: String) updating, protected;
// ---------------------------------------------------------------------------
// Created:     03 July 2003 by cnwsb1
// ---------------------------------------------------------------------------
begin
	self.myLog := app.createUserLog(_filename);
end;</source>
        <access>protected</access>
        <Parameter name="_filename" type="String"/>
    </JadeMethod>
    <JadeMethod name="dataDumpGlobalExceptionHandler" id="64065be3-a374-402c-8b22-9838ddd3c59c">
        <source>dataDumpGlobalExceptionHandler(_exObj: Exception) : Integer protected;
// ---------------------------------------------------------------------------
// Created:     28 July 2003 by cnwsb1
// ---------------------------------------------------------------------------
// 11 Jul 2019	jlgrs1	TFS45051 JMT terminate on a SDS secondary exception ie a takeover has happened.
vars
	msg : String;
begin
	if _exObj.errorCode = 1228 or 
	   _exObj.errorCode = 1295 or 
	   _exObj.errorCode = 3015 or 
	   _exObj.errorCode = 3037 then
		abortTransaction;
		abortTransientTransaction;
		msg := class.name&amp;'::'&amp;method.name&amp;' SDS Exception, cant continue,'&amp;_exObj.errorCode.String&amp;' '&amp;_exObj.extendedErrorText&amp;' processApp= '&amp;process.persistentApp.name&amp;' '&amp;process.userInfo&amp;' ('&amp;process.node.String&amp;", "&amp;process.String&amp;')';
		app.writeLog(msg, LogFATAL);	//25 Nov 2019	NDL	TFS 47053
		
		terminate;
	endif;

	if _exObj.isKindOf(LockException) then
		if self.dataDumpLockExceptionHandler(_exObj.LockException) then
			return Ex_Continue;
		else
			abortTransaction;
			app.doDumpStack(_exObj);			
			return Ex_Abort_Action;				
		endif;
	endif;		
		
	abortTransaction;
	
	app.doDumpStack(_exObj);
			
	return Ex_Abort_Action;	
end;</source>
        <access>protected</access>
        <Parameter name="_exObj" type="Exception"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="dataDumpLockExceptionHandler" id="98d3a552-2d18-40af-bd63-6376cf782fe3">
        <source>dataDumpLockExceptionHandler(_lockExObj: LockException) : Boolean protected;
// ---------------------------------------------------------------------------
// Created:     28 July 2003 by cnwsb1
//
// Purpose:		Retry getting the lock that caused the passed in LockException.
//				Answer true if lock obtained else answer false
// ---------------------------------------------------------------------------
/*

Date		Who		Reason
15 May 2015	cnwkpd1	PAR $36237 - change to use standard CardSchema lock exception handler
	
*/

vars
//	clockValue : Integer;
	
begin
	return app.cnGlobalLockExceptionHandler(_lockExObj) = Ex_Continue;

	/*
	clockValue := app.clock;
	
	while true do
		if app.clock - clockValue &gt;= 300000 then
			return false;
		endif;	

		if tryLock(_lockExObj.lockTarget, _lockExObj.lockType, _lockExObj.lockDuration, LockTimeout_Immediate) then
				// We got the lock
			return true;
		endif;
	endwhile;
*/
end;</source>
        <access>protected</access>
        <Parameter name="_lockExObj" type="LockException"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="deleteLog" id="b9690c27-5bae-4c96-a4fa-d45ae5fca40b">
        <updating/>
        <source>deleteLog() updating, protected;
// ---------------------------------------------------------------------------
// Created:     03 July 2003 by cnwsb1
// ---------------------------------------------------------------------------
begin
	app.deleteUserLog(self.myLog.JadeLog);
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="lockMutex" id="de6a3588-166a-4173-bcd8-a7de4f8f0e60">
        <updating/>
        <source>lockMutex(_reasonStr: String) updating, protected;
// ---------------------------------------------------------------------------
// Created:     23 July 2003 by cnwsb1
//
// Purpose:		We don't want anyone maintaining the data dump classes while
//				an extract is running, or while maintaining the data dump
//				collections.
// ---------------------------------------------------------------------------
begin
	if not process.isLockedByMe(app.myRoot.allDataDumpClasses) then
		if self.myLog &lt;&gt; null then
			self.log("Locking data dump mutex: " &amp; _reasonStr);
		endif;
		//22/02/2011 cnwdz2 par26892 start
		//self.lock(app.myRoot.allDataDumpClasses,
		//		Reserve_Lock, Session_Duration, LockTimeout_Immediate);
		self.lock(app.myRoot.allDataDumpClasses,
				Reserve_Lock, Session_Duration, LockTimeout_Server_Defined);
		//22/02/2011 cnwdz2 par26892 end
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="_reasonStr" type="String"/>
    </JadeMethod>
    <JadeMethod name="log" id="2df884d9-c1a7-4892-a68b-cb4e95551b49">
        <updating/>
        <source>log(_line: String) updating, protected;
// ---------------------------------------------------------------------------
// Created:     09 June 2003 by cnwsb1
// ---------------------------------------------------------------------------
vars
	field : CM_FieldEntity;

begin
	//app.writeToUserLog(self.myLog.JadeLog,
	//		CrLf &amp; _line &amp; CrLf &amp; self.DataDumpLogUnderline);
	if self.myLog = null then
		return;
	endif;
	
	self.writeLog( _line);
			
	if self.allSystemAlertMessages &lt;&gt; null then
		create field as CM_SlobField transient;
		field.setValueFromString(_line);
		self.allSystemAlertMessages.add(field);
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="_line" type="String"/>
    </JadeMethod>
    <JadeMethod name="purgeSystemAlerts" id="af031e61-96bf-4c14-93f0-e8496f552056">
        <source>purgeSystemAlerts() protected;
// ---------------------------------------------------------------------------
// Created:     30 July 2003 by cnwsb1
// ---------------------------------------------------------------------------
begin
	self.allSystemAlertMessages.purge;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="raiseAlert" id="6d99fe9d-6813-4673-8406-750377ff4509">
        <updating/>
        <source>raiseAlert(_extractClassId : String)updating, protected;
// ---------------------------------------------------------------------------
// Created:     30 July 2003 by cnwsb1
// 27.01.2020 cnwma1	Bug 48361: POL - System Alerts options
// ---------------------------------------------------------------------------
vars
	alert : CM_SystemAlert;
	details : String;
	field : CM_FieldEntity;
	
begin
	details := "Data Extract error";
	if _extractClassId &lt;&gt; null then
		details := details &amp; " - " &amp; _extractClassId;
	endif;
	
	create alert transient;
	alert.details := details;
	alert.setSeverity(SEVERE_ERROR);
	alert.setMySystemAlertType(app.myRoot.allSystemAlertTypes[EVENT_SQL_NativeRT]);   //27.01.2020 cnwma1 #48361
	
	if self.allSystemAlertMessages &lt;&gt; null then
		foreach field in self.allSystemAlertMessages do
			alert.addLogEntry(field.getValueAsString);
		endforeach;
	endif;
	
	alert.add;
	app.commitAlert;
	
epilog
	self.allSystemAlertMessages.purge;
end;</source>
        <access>protected</access>
        <Parameter name="_extractClassId" type="String"/>
    </JadeMethod>
    <JadeMethod name="unlockMutex" id="a8dd710a-6cc6-46b9-8778-68ace3b7c895">
        <updating/>
        <source>unlockMutex() updating, protected;
// ---------------------------------------------------------------------------
// Created:     23 July 2003 by cnwsb1
// ---------------------------------------------------------------------------
begin
	if process.isLockedByMe(app.myRoot.allDataDumpClasses) then
		if self.myLog &lt;&gt; null then
			self.log("Releasing data dump mutex");
		endif;
		self.unlock(app.myRoot.allDataDumpClasses);
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="writeLog" id="10d20031-72f1-44b8-b899-7d5d297d4b13">
        <executionLocation>client</executionLocation>
        <source>writeLog(_msg : String) clientExecution;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 October 2019	jlger1	Initial creation

*/

vars
	t : TimeStamp;
	s : String;
	logline : String;
	
begin
	if self.myLog = null then
		return;
	endif;
	
	t := app.actualTimeServer;
	s := t.date.shortFormatJMT() &amp; " " &amp; t.time.formatAsHHmmSS() &amp; "." &amp; t.time.milliSecond.String.padLeadingZeros(3);
    logline := s &amp; " : " &amp; app.name &amp; "/" &amp; process.String &amp; ": " &amp; _msg &amp; CrLf;

	self.myLog.log(logline);
	
	if app.myLoggingForm &lt;&gt; null then
		app.doFormLogging( method, logline, null );
	endif;

epilog

end;</source>
        <Parameter name="_msg" type="String"/>
    </JadeMethod>
</Class>
