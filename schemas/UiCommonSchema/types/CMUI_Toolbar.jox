    <JadeMethod name="getMinWidth" id="140ab4d9-eba3-4ba2-8d41-bdae1cbb3ee8">
        <source>getMinWidth() : Real;
// ---------------------------------------------------------------------------
// Created:     24 August 2004 by cnwrs2
//
// Purpose:     Returns the min width required by the toolbar
//				to show all the controls
// ---------------------------------------------------------------------------
vars
	theWidth	: Real;
	tmpCntrl	: Control;
begin

	foreach tmpCntrl in self.allLeftControls do
		theWidth := theWidth + ControlGap + tmpCntrl.width;
	endforeach;

	foreach tmpCntrl in self.allRightControls do
		theWidth := theWidth + ControlGap + tmpCntrl.width;
	endforeach;

	return theWidth;

end;</source>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="getNextControlIndex" id="02202f0c-43e3-4679-acf2-e626ea915203">
        <source>getNextControlIndex() : Integer;
// ---------------------------------------------------------------------------
// Created:     24 July 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
vars

begin
	return self.allLeftControls.size + self.allRightControls.size + 1;
end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getSeperatorFromIndex" id="985e4035-5bc3-4cb4-b01e-c3535a9ed8df">
        <source>getSeperatorFromIndex(_idx : Integer) : CMUI_ToolbarSeperator protected;
// ---------------------------------------------------------------------------
// Created:     24 March 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
begin
	if self.myMasterToolbarSeperator = null then
		return null;
	endif;
	return self.myMasterToolbarSeperator.getControl(_idx).CMUI_ToolbarSeperator;
end;</source>
        <access>protected</access>
        <Parameter name="_idx" type="Integer"/>
        <ReturnType type="CMUI_ToolbarSeperator"/>
    </JadeMethod>
    <JadeMethod name="hideExtraSeperators" id="f161d63e-8b85-445c-bc03-0e675764756f">
        <source>hideExtraSeperators();
// ---------------------------------------------------------------------------
// Created:		October 2003 By Andrew Bishop cnwab1
//
// Purpose:		When hiding buttons you can end up with seperators next to each other, this makes sure that there is only 1 at a time
//
// ---------------------------------------------------------------------------
vars
	control	: CMUI_ToolbarControl;
	numSep : Integer;
begin
	
	foreach control in self.allLeftControls do
		if control.isKindOf(CMUI_ToolbarSeperator) then
			control.visible := true;
			numSep := numSep + 1;
			if numSep &gt; 1 then
				control.visible := false;
			endif;
		elseif control.visible = true then
			numSep := 0;
		endif;
	endforeach;
end;</source>
    </JadeMethod>
    <JadeMethod name="hideSeperator" id="417edc61-f124-4416-b1b0-9a9b6c19498f">
        <source>hideSeperator(_idx : Integer);
// ---------------------------------------------------------------------------
// Created:     24 March 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	tmpSeperator	: CMUI_ToolbarSeperator;
	
begin
	tmpSeperator := self.getSeperatorFromIndex(_idx);
	if tmpSeperator = null then
		return;
	endif;
	tmpSeperator.visible := false;
end;</source>
        <Parameter name="_idx" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="loadToolbarFromMenuRoot" id="3590cec0-07da-4007-bb07-a43fd4c99247">
        <updating/>
        <source>loadToolbarFromMenuRoot(_menuRoot : CM_MenuUserToolbarRoot; _seperatorPic : Binary) updating;
// ---------------------------------------------------------------------------
// Created:     24 July 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
vars
	menuEntity			: CM_MenuEntity;
	menuItem			: CM_MenuItem;
	pos					: Integer;
	tmpUser				: CM_User;
	
begin

	if _menuRoot = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Menu toolbar root is null');
		return;
	endif;
	
	tmpUser := _menuRoot.myUser;

	self.allLeftControls.purge();
	self.allRightControls.purge();
	self.horizontalOffsetLeft := 0;
	self.isPositionsCalculated := false;
	self.showCaptions := _menuRoot.showCaption;
	
	foreach	menuEntity in _menuRoot.allMenuUserToolbarItems do
		if (not CM_MenuUserToolbar.hasInstance(menuEntity)) then
			continue;
		endif;
		
		// PAR 17795 - check if user has access to this option
		if menuEntity.CM_MenuUserToolbar.mySystemToolbar.isSpecialButton() or 
		   tmpUser.canDoSomewhere(menuEntity.CM_MenuUserToolbar.mySystemToolbar.constantValue) then
			self.loadUserToolbarButton(menuEntity.CM_MenuUserToolbar, _seperatorPic, self.Control_Alignment_Left);
		endif;
		
	endforeach;
	
	self.isPositionsCalculated := true;	
	self.cnEcResizeContents();
	
end;</source>
        <Parameter name="_menuRoot" type="CM_MenuUserToolbarRoot"/>
        <Parameter name="_seperatorPic" type="Binary"/>
    </JadeMethod>
    <JadeMethod name="loadUserToolbarButton" id="e74f9d72-6069-49bd-8bef-2cdf74615e94">
        <updating/>
        <source>loadUserToolbarButton(_userToolbar : CM_MenuUserToolbar; 
						_seperatorPic : Binary;
						_alignment : Integer) updating;
/* ---------------------------------------------------------------------------
 Created:     24 July 2003		cnwth2	

 Purpose:     		 
 Changes

Date		Name	TFS#		Description
============================================================================
20/09/2019 jlgka1 	TFS 45614 	JMT - Refactoring remove Voyage Commodity Scenario mode
============================================================================*/
vars
	newControl		: CMUI_ToolbarControl;
	systemToolbar	: CM_MenuToolbar;
begin
	systemToolbar := _userToolbar.mySystemToolbar.CM_MenuToolbar;
	
	if systemToolbar.menuId = CM_MenuToolbar.MENU_ID_SEP then
		newControl := self.myMasterToolbarSeperator.loadControl(self.getNextControlIndex).CMUI_ToolbarControl;
	else
		newControl := self.myMasterToolbarButton.loadControl(self.getNextControlIndex).CMUI_ToolbarControl;
	endif;

	newControl.initFromUserToolbar(_userToolbar, _seperatorPic, self.showCaptions);

	self.addToolbarControlAt(newControl, 0, _alignment);
		
end;</source>
        <Parameter name="_userToolbar" type="CM_MenuUserToolbar"/>
        <Parameter name="_seperatorPic" type="Binary"/>
        <Parameter name="_alignment" type="Integer"/>
    </JadeMethod>
