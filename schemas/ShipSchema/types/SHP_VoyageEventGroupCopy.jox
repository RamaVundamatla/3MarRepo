<GUIClass name="SHP_VoyageEventGroupCopy" id="ac4097e4-b8cd-4a7b-8e6f-b846813c286e">
    <superclass name="CMUI_Modal"/>
    <transient/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <ImplicitInverseRef name="cmbEventGroups" id="1ddfa4df-b7fb-420e-aac9-8ae8d9e3d54a">
        <embedded/>
        <type name="CMUI_ComboBox"/>
    </ImplicitInverseRef>
    <JadeMethod name="create" id="016834f0-b233-46de-a70c-3b63035b02ce">
        <updating/>
        <executionLocation>client</executionLocation>
        <source>create() updating, clientExecution;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 January 2017	cnwns1	Initial creation

*/

vars

begin
	self.permissionMaint := PmEventAllocationMaint;
	self.permissionView:= PmEventAllocationView;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doOK" id="93dfa0e2-661a-4cfa-a883-b4698fdb15c7">
        <updating/>
        <source>doOK() updating;
/*
Purpose:			
Date		Who		Reason
02 February 2017	cnwab1	Initial creation
*/

vars
	group : CM_EventTypeGroup;
begin

	group := self.cmbEventGroups.listObject.CM_EventTypeGroup;
	if group = null then
		app.msgBox("Please select an event group to copy", "Copy Issue", MsgBox_OK_Only);
		return;
	endif;
	
	if self.myParentForm &lt;&gt; null then
		self.myParentForm.SHP_EventAllocationForm.setFromGroupCopy(group);
	endif;
	
	
	inheritMethod();

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="populateComboEvents" id="301b03df-86d0-4c28-96e3-a5f89d2bae51">
        <source>populateComboEvents();
/*
Purpose:			
Date		Who		Reason
02 February 2017	cnwab1	Initial creation
*/

vars
	group : CM_EventTypeGroup;
begin
	self.cmbEventGroups.clear();
	self.cmbEventGroups.sorted := true;
	
	
	foreach group in app.myRoot.allEventTypeGroups discreteLock do
		if group.hasEventsOfCategory(CM_EventType.VOYAGE_EVENT) then
			self.cmbEventGroups.addItemObject(group.description, group);
		endif;
	
	endforeach;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setupForm" id="315f3fe8-d2fd-4d57-b026-d33edc8b7d68">
        <updating/>
        <source>setupForm() updating;
/*

Date		    Who			Reason
29 September 2010	cnwas3	  Initial creation

*/

vars

begin
	inheritMethod();	
//	self.btnOk.caption  := app.getErrorString(Copy).cnEcFirstToUpper();
	
	self.populateComboEvents();
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="translateForm" id="12389012-d6fb-446e-8e34-932ab901d2e5">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 20 June 2017 14:33:54.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0021891, locale);
end;</source>
    </JadeMethod>
</GUIClass>
