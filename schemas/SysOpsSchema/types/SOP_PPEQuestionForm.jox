		self.btnNext.enabled := false;
	endif;
epilog

end;</source>
        <Parameter name="_enable" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getCriteriaAllCMIF" id="0504d583-31ef-4bca-90d6-471df53607b7">
        <updating/>
        <source>getCriteriaAllCMIF(_cmifArray : CMIF_Array input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
28 August 2023		jlizm1	Initial creation TFS 59551 Kiosk Additional Question

*/

vars
	criteria		: CM_YAKioskCriteria;
	cmifCriteria	: CMIF_YACriteriaPriority;
	cmifObject		: CMIF_Object;
	question		: CM_KioskAdditionalQuestion;

begin

	question := self.myKioskObject.CM_KioskAdditionalQuestion;
	
	// Create transient maintenance objects for all existing criteria and mark for delete action
	if question &lt;&gt; null then
		foreach criteria in question.allCriteria do
			cmifCriteria := criteria.getTransient();
			cmifCriteria.setFlag(false, false, true);
			_cmifArray.add(cmifCriteria);
		endforeach;
	endif;
	
	// Now do all criteria on myself
	foreach cmifObject in self.allCriteria do
		criteria := cmifObject.CMIF_YACriteriaPriority.myProxy.CM_YAKioskCriteria;
		
		if question = null then
		endif;
		
		self.getCriteriaSingleCMIF(_cmifArray, criteria.myYACriteriaType, criteria.myYAData.getDataValue());
	endforeach;
epilog

end;</source>
        <Parameter name="_cmifArray" type="CMIF_Array" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getCriteriaSingleCMIF" id="1319cbe9-76b9-4e40-8384-59e354893cb8">
        <source>getCriteriaSingleCMIF(_cmifArray : CMIF_Array input; _criteriaType :CM_YACriteriaType; _value : Any);
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
28 August 2023		jlizm1	Initial creation TFS 59551 Kiosk Additional Question

*/

vars
	cmifObject		: CMIF_Object;
	cmifCriteria	: CMIF_YACriteriaPriority;
	proxyCriteria	: CM_YAKioskCriteria;
	itemCode		: String;
	question		: CM_KioskAdditionalQuestion;

begin

	question := self.myKioskObject.CM_KioskAdditionalQuestion;
	
	// Check if a maintenance object already exists - if it does it will have a Delete action
	// Convert it to a Change action
	if question &lt;&gt; null then
		foreach cmifObject in _cmifArray do
			cmifCriteria 	:= cmifObject.CMIF_YACriteriaPriority;
			proxyCriteria	:= cmifCriteria.myProxy.CM_YAKioskCriteria;
			if proxyCriteria.myYACriteriaType = _criteriaType and cmifCriteria.isDeleted then
				// change value of existing criteria
				proxyCriteria.setProxy(proxyCriteria.myYACriteriaType, _value, proxyCriteria.code);
				cmifCriteria.setFlag(false, true, false);
				return;
			endif;
		endforeach;
	endif;
	
	// Create an Add action Criteria request
	create proxyCriteria transient;
	itemCode := _criteriaType.description.cnEcUpto(CM_YACriteriaPriority::code.length -1);
	proxyCriteria.setProxy(_criteriaType, _value, itemCode);
	cmifCriteria := proxyCriteria.getTransient();
	cmifCriteria.setFlag(true, false, false);
	_cmifArray.add(cmifCriteria);
	
epilog

end;</source>
        <Parameter name="_cmifArray" type="CMIF_Array" usage="input"/>
        <Parameter name="_criteriaType" type="CM_YACriteriaType"/>
        <Parameter name="_value" type="Any"/>
    </JadeMethod>
    <JadeMethod name="init" id="5e76baf5-4d95-4e46-ab8a-1e6964e897b7">
        <updating/>
        <source>init(_kiosk : CM_Kiosk; _ppeQuestion : CM_KioskObject; _mode : Integer) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
14 August 2023		jlizm1	Initial creation TFS 59550 Kiosk PPE Questions
28 August 2023		jlizm1	TFS 59551 Kiosk Additional Question

*/

vars
	
begin
	
	self.myKiosk := _kiosk;
	self.myKioskObject := _ppeQuestion;
	
	if _ppeQuestion &lt;&gt; null then
		self.myProxyKioskObject := app.createUpdateProxy(_ppeQuestion).CM_KioskObject;
		
		if _ppeQuestion.isKindOf(CM_KioskAdditionalQuestion) then
			self.mode := MODE_ADDITIONAL;
		else
			self.mode := MODE_PPE;
		endif;
			
	else
		if self.myProxyKioskObject &lt;&gt; null then
			delete self.myProxyKioskObject;
		endif;
		
		self.mode := _mode;
	endif;

epilog

end;</source>
        <Parameter name="_kiosk" type="CM_Kiosk"/>
        <Parameter name="_ppeQuestion" type="CM_KioskObject"/>
        <Parameter name="_mode" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="isRequiredDataEntered" id="10f88799-d142-4775-bb29-97c82600f7ac">
        <source>isRequiredDataEntered() : Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 Jan 2024 navlc30 Bug 61956: FR | 57937 - [TKT: 61898] - Kiosk - US.040 'd' - Error Page Not Displayed
*/

vars

begin
	
	if self.txtCode.text &lt;&gt; null and 
	self.txtQuestion.text &lt;&gt; null and 
	self.txtErrorMessage.text &lt;&gt; null then
		return true;
	endif;
	
	return false;	
	
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="loadTranslationFields" id="6cbedd3f-d9ed-4002-91fa-ae533032e385">
        <source>loadTranslationFields();
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
28 August 2023		jlizm1	Initial creation TFS 59550 Kiosk PPE Questions
19 Jan 2024 		navlc30 Bug 61956: FR | 57937 - [TKT: 61898] - Kiosk - US.040 'd' - Error Page Not Displayed

*/

vars
	question : CM_KioskTranslation;
	errorMsg : CM_KioskTranslation;
	localeId : String;
	
begin
	self.txtQuestion.text := "";
	self.txtErrorMessage.text := "";

	if self.selectedLocale = null or self.myProxyKioskObject = null then
		return;
	endif;
	
	if self.myProxyKioskObject.isKindOf(CM_KioskAdditionalQuestion) then
		question := self.myProxyKioskObject.CM_KioskAdditionalQuestion.allQuestions[self.selectedLocale.localeId];
		errorMsg := self.myProxyKioskObject.CM_KioskAdditionalQuestion.allErrorMessages[self.selectedLocale.localeId];
	else
		question := self.myProxyKioskObject.CM_KioskPPEQuestion.allQuestions[self.selectedLocale.localeId];
		errorMsg := self.myProxyKioskObject.CM_KioskPPEQuestion.allErrorMessages[self.selectedLocale.localeId];
	endif;
	
	if question &lt;&gt; null then
		self.txtQuestion.text := question.text;
	endif;
	
	if errorMsg &lt;&gt; null then
		self.txtErrorMessage.text := errorMsg.text;
	endif;
	
	if  self.isRequiredDataEntered() then				//19.01.2024 navlc30 #61956
		self.enableSaveButtons(true);
	else 
		self.enableSaveButtons(false);
	endif;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setAllCriteria" id="3db9a2bd-ae75-4a81-a2b4-4adef66e3e0a">
        <source>setAllCriteria(_additionalQuestion : CM_KioskAdditionalQuestion);
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
28 August 2023		jlizm1	Initial creation TFS 59551 Kiosk Additional Question

*/

vars
	crit			: CM_YAKioskCriteria;
	proxyCriteria	: CM_YAKioskCriteria;
	cmifCriteria	: CMIF_YACriteriaPriority;
	itemCode		: String;
	value			: Any;
	
begin
	if self.allCriteria.size &gt; 0 then
		self.allCriteria.purge;	
	endif;
	
	if _additionalQuestion = null then
		return;
	endif;

	if _additionalQuestion.allCriteria.size &gt; 0 then
		foreach crit in _additionalQuestion.allCriteria do
			create proxyCriteria transient;
			itemCode := crit.myYACriteriaType.description.cnEcUpto(CM_YACriteriaPriority::code.length -1);
			value := crit.myYAData.getDataValue();
			proxyCriteria.setProxy(crit.myYACriteriaType, value, itemCode);
			cmifCriteria := proxyCriteria.getTransient();
			self.allCriteria.add(cmifCriteria);
		endforeach;
	endif;
	
epilog

end;</source>
        <Parameter name="_additionalQuestion" type="CM_KioskAdditionalQuestion"/>
    </JadeMethod>
    <JadeMethod name="setupForm" id="08f65df1-a343-470c-98ad-99e67d70dc28">
        <updating/>
        <source>setupForm() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
14 August 2023		jlizm1	Initial creation TFS 59550 Kiosk PPE Questions
28 August 2023		jlizm1	TFS 59551 Kiosk Additional Question

*/

vars
	locale : CM_Locale;
	tmpLocale : CM_Locale;
	idx : Integer;
	invalidObject : Boolean;

begin
	on Exception do app.handleDeletedObject(exception, tmpLocale, invalidObject);
	
	inheritMethod();
	
	if self.myKiosk = null then
		// can't really do much without a kiosk
		return;
	endif;
	
	self.allLocales.clear();
	foreach tmpLocale in self.myKiosk.allLocales do
		self.allLocales.addExclusive(tmpLocale);
		if invalidObject then
			invalidObject := false;
			continue;
		endif;
	endforeach;
	
	locale := self.myKiosk.myPrimaryLocale;
	if locale &lt;&gt; null and not self.allLocales.includes(locale) then
		self.allLocales.insert(1, locale);
	endif;
	self.cmbLocale.listCollection(self.allLocales, false, 0);
	
	if self.allLocales.size &gt; 0 then
		self.cmbLocale.listIndex := 1;
	endif;
	
	if self.cmbLocale.listObject &lt;&gt; null then
		self.selectedLocale := self.cmbLocale.listObject.CM_Locale;
	endif;
	
	self.btnOk.caption := app.getErrorString(Save);
	self.btnOk.enabled := false;
	self.btnNext.enabled := false;
	
	if self.myKioskObject &lt;&gt; null then
		self.txtCode.text := self.myKioskObject.code;
		
		if self.myKioskObject.isKindOf(CM_KioskPPEQuestion) then
			self.txtImageId.text := self.myKioskObject.CM_KioskPPEQuestion.imageID;
		else
			self.setAllCriteria(self.myKioskObject.CM_KioskAdditionalQuestion);
		endif;
		
		if self.txtCode.text &lt;&gt; null then
			self.btnOk.enabled := true;
			self.btnNext.enabled := true;
		endif;
	endif;
	
	if self.mode = MODE_ADDITIONAL then
		self.lblCriteria.visible := true;
		self.btnCriteria.visible := true;
		self.lblImageId.visible := false;
		self.txtImageId.visible := false;
		self.caption := app.getErrorString(Additional_questions) &amp; " " &amp; self.myTerminal.code;
		
	else
		self.lblCriteria.visible := false;
		self.btnCriteria.visible := false;
		self.lblImageId.visible := true;
		self.txtImageId.visible := true;
	endif;
	
	self.loadTranslationFields();
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="translateForm" id="84bb8ca9-589a-4072-9173-d5fc2758ec82">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 31 August 2023 03:52:14.
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0026413, locale);
	btnNext.translateCaption(Xlat_0026414, locale);
	lblCode.translateCaption(Xlat_0026415, locale);
	lblCriteria.translateCaption(Xlat_0026416, locale);
	lblErrorMessage.translateCaption(Xlat_0026417, locale);
	lblImageId.translateCaption(Xlat_0026418, locale);
	lblLocale.translateCaption(Xlat_0026419, locale);
	lblQuestion.translateCaption(Xlat_0026420, locale);
end;</source>
    </JadeMethod>
