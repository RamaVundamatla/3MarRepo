    <JadeMethod name="initCalendarMsg" id="c6e09c46-45c3-4e6c-bb69-40020a4d6c45">
        <source>initCalendarMsg();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
//30/05/2023	navkc1	CR 58013 Task 58014: UI - Storage Config - Storage Detail – Free Storage

*/

vars
	theMsg			: CMUI_MultiSelectGroupBox;
	root			: CM_Root;
	storageDetail	: CM_StorageDetail;
begin
	
	theMsg 								:= self.msgFreeStoExcCalendar;
	theMsg.caption 						:= null;
	theMsg.multiSelect 					:= ListBox.MultiSelect_Extended;
	theMsg.formDisplayEntryMethodName 	:= "displayCalendarView";
	theMsg.availableHeading 			:= app.getErrorString(Available_calendars);
	theMsg.selectedHeading 				:= app.getErrorString(Selected_calendars);
	theMsg.mySelectedListBox.sorted		:= false;
	theMsg.readOnly 					:= false;
	
	root := app.myRoot;
	
	if root = null then
		return;
	endif;
	
	theMsg.setAvailable(root.allCalendars, true);
	
	storageDetail := self.myStorageDetail;
	
	if storageDetail &lt;&gt; null then
		theMsg.setSelected(storageDetail.allAdditionalCalendars);
	endif;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="initChargeDayCombo" id="6ed870b0-f3b1-491a-9a1b-bb05d4344434">
        <source>initChargeDayCombo();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30/05/2023	navkc1	CR 58013 Task 58014: UI - Storage Config - Storage Detail – Free Storage
16/06/2023	navkc1	CR 58221 Task 58222: UI - Ownership Change Free Days
*/

vars
	combo	: CMUI_ComboBox;
	
begin
	// Release Storage tab - Charge period
	combo := self.cmbRelStoChrgPeriod;
	combo.itemData[combo.addItem(app.getErrorString(All_Days))] := CM_StorageDetail.Calendar_Days;
	// If we are creating a new storage details, add ALL MONTH option so it's in line with Future release combo 
	if self.myStorageDetail = null then
		combo.itemData[combo.addItem(app.getErrorString(Calendar_months))] := CM_StorageDetail.Calendar_Months;
	endif;
	combo.itemData[combo.addItem(app.getErrorString(Working_days))] := CM_StorageDetail.Working_Days;
	combo.itemData[combo.addItem(app.getErrorString(Working_compulsory_days))] := CM_StorageDetail.Working_Compulsory_Days;
	
	// Free storage tab - Free storage
	combo := self.cmbFreeStoPeriod;
	combo.itemData[combo.addItem(app.getErrorString(All_Days))] := CM_StorageDetail.Calendar_Days;
	combo.itemData[combo.addItem(app.getErrorString(Working_days))] := CM_StorageDetail.Working_Days;
	combo.itemData[combo.addItem(app.getErrorString(Working_compulsory_days))] := CM_StorageDetail.Working_Compulsory_Days;
	
	// Future storage tab - Charge day
	combo := self.cmbFutureStoChrgPeriod;
	combo.itemData[combo.addItem(app.getErrorString(All_Days))] := CM_StorageDetail.Calendar_Days;
	combo.itemData[combo.addItem(app.getErrorString(Calendar_months))] := CM_StorageDetail.Calendar_Months;
	combo.itemData[combo.addItem(app.getErrorString(Working_days))] := CM_StorageDetail.Working_Days;
	combo.itemData[combo.addItem(app.getErrorString(Working_compulsory_days))] := CM_StorageDetail.Working_Compulsory_Days;
	
	// Change of Ownership Free storage //16/06/2023	navkc1	CR 58221 Task 58222
	combo := self.cmbCooFreeDaysType;
	combo.itemData[combo.addItem(app.getErrorString(All_Days))] := CM_StorageDetail.Calendar_Days;
	combo.itemData[combo.addItem(app.getErrorString(Working_days))] := CM_StorageDetail.Working_Days;
	combo.itemData[combo.addItem(app.getErrorString(Working_compulsory_days))] := CM_StorageDetail.Working_Compulsory_Days;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="initReceivalCombo" id="21d59c1e-3a06-46b0-b3d7-c90933466442">
        <source>initReceivalCombo();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29/05/2023	navkc1	CR 58011 Task 58012: UI - Storage Config - Storage Detail Receival Date

*/

vars
	combo	: CMUI_ComboBox;
	
begin
	
	// Ship receival based on
	combo := self.cmbShipReceival;
	combo.sorted := true;
	combo.itemData[combo.addItem(Voyage_Actual_Discharge_Str)] := Voyage_Actual_Discharge;
	combo.itemData[combo.addItem(Voyage_Pilot_On_Board_Str)] := Voyage_Pilot_On_Board;
	combo.itemData[combo.addItem(Voyage_Anchor_Down_Str)] := Voyage_Anchor_Down;
	combo.itemData[combo.addItem(Voyage_Arrival_Str)] := Voyage_Arrival;
	combo.itemData[combo.addItem(Voyage_Labour_On_Board_Str)] := Voyage_Labour_On_Board;
	combo.itemData[combo.addItem(Voyage_Ship_Exchange_Start_Str)] := Voyage_Ship_Exchange_Start;
	combo.itemData[combo.addItem(Voyage_Rec_Labour_Ashore_Str)] := Voyage_Rec_Labour_Ashore;
	combo.itemData[combo.addItem(Voyage_Rec_Ship_Exch_End_Str)] := Voyage_Rec_Ship_Exch_End;
	combo.itemData[combo.addItem(Voyage_General_Landing_Str)] := Voyage_General_Landing;
	combo.itemData[combo.addItem(Voyage_Rec_First_Day_Avail_Str)] := Voyage_Rec_First_Day_Avail;
	
	// Truck receival based on
	combo := self.cmbTruckReceival;
	combo.itemData[combo.addItem(Storage_RoadActualReceivalStr)] := Storage_RoadActualReceival;
	combo.itemData[combo.addItem(Storage_RoadActualUnloadStr)] := Storage_RoadActualUnload;
	
	// Wagon receival based on
	combo := self.cmbWagonReceival;
	combo.itemData[combo.addItem(Storage_RailActualReceivalStr)] := Storage_RailActualReceival;
	combo.itemData[combo.addItem(Storage_RailActualUnloadStr)] := Storage_RailActualUnload;
	
	// Child receival based on
	combo := self.cmbChildReceival;
	combo.itemData[combo.addItem(Storage_UnpackSameAsParentStr)] := Storage_UnpackSameAsParent;
	combo.itemData[combo.addItem(Storage_UnpackActualUnpackStr)] := Storage_UnpackActualUnpack;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="initStopsCombo" id="71824b41-fa21-4ae1-b9e3-8ad9e61f6397">
        <source>initStopsCombo();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 Jul 2017	cnwma1	TFS #5409:STWO - Storage Slab Auto Commercial Hold

*/

vars
	term : CM_Terminal;
	stopTemplate : CM_StopTableTemplate;
	combo : CMUI_ComboBox;
begin
	
	combo := self.cmbStop;
	combo.clear();
	combo.sorted := true;
	combo.itemData[combo.addItem(" ")] := -1;

	term :=self.getMyTerminal;
	foreach stopTemplate in term.allStopTableTemplates do 
		if not stopTemplate.myStopTable.isNotAvailableForEntry then
			combo.addItemObject(stopTemplate.myStopTable.heading,stopTemplate.myStopTable);
		endif;
	endforeach;
		
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="loadCriteriaFrames" id="be5336a6-2fb2-4f81-98d8-cb03c9739b49">
        <updating/>
        <source>loadCriteriaFrames() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
24 July 2012	cnwndl1	Initial creation

*/

vars
	i: Integer;
	top, left, height, width: Integer;
	criteriaFrame : CMUI_YACriteriaCntl;
	criterias: Iterator;
	cntlTabIndex: Integer;
	propCount : Integer;
	splitAtPos : Integer;
	maxUsed : Integer;
	
begin

	top :=  1; 
	left := 1; 
	height := ((self.grpAllCriteria.height - 10) / 10).Integer;
	width := (self.grpAllCriteria.width / 2).Integer;
	if self.myTerminal.myStorageConfig &lt;&gt; null then
		propCount := self.myTerminal.myStorageConfig.allYACriteriaTypes.size;
	endif;
	splitAtPos := (propCount / 2).Decimal.rounded + 1;
	
	maxUsed := 20;
	

	cntlTabIndex := self.frmCriteria.tabIndex;

	foreach i in 1 to propCount do 
		
		if i = splitAtPos then
			left := width;	// second column
			top := 1;
		endif;
		criteriaFrame := self.frmCriteria.loadControl(i).CMUI_YACriteriaCntl;
		criteriaFrame.setWidth(width);			
		criteriaFrame.setTabIndex(cntlTabIndex);
		criteriaFrame.move(left, top, width, height);
		criteriaFrame.visible := true;
		criteriaFrame.tag := "true";	// to active three-state booleans 23 Mar 2015	NDL	Par 35886
		top := top + height;
		maxUsed := maxUsed.max( top );
	endforeach;

	self.frmCriteria.visible := false;
	
	//19 Apr 2017	NDL	TFS 4106
	if propCount &gt; 1 then
		self.width := 700;
	endif;
	
	self.setHeight( maxUsed ); 
	
epilog
	delete criterias;
end;
</source>
    </JadeMethod>
