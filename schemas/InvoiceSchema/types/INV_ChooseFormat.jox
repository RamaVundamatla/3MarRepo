    <JadeMethod name="btnOK_click" id="0838a8b8-0ed6-4711-a737-6f3b7afdfe35">
        <controlMethod name="CMUI_Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnOK_click(btn: Button input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 January 2023	navmv20	TFS 55650 Task 55701: Jade - Contracts XML Extract TRX

*/

vars
	noOfContracts : Integer;
	format : Integer;
begin
	if self.myFile &lt;&gt; null then
		if self.mode = EXTRACT_MODE then
			if optCSV.value then
				noOfContracts := self.dumpContractsCSV(self.myFile, app.myPassport);
			elseif optXml.value then
				noOfContracts := self.dumpContractsXML(self.myFile);
			endif;
		elseif self.mode = LOAD_MODE then
			if optCSV.value then
				format := CSV_FORMAT;
			elseif optXml.value then
				format := XML_FORMAT;
			endif;
			noOfContracts := self.loadContracts(self.myFile,format);
		endif;
	endif;
	self.unloadForm();
	
	if noOfContracts &gt; 0 then
		if self.mode = EXTRACT_MODE then
			if noOfContracts = 1 then
				app.msgBox(app.getErrorString1(Invoice_contract_extracted, noOfContracts.String), app.getErrorString(Extract_status),MsgBox_OK_Only);
			else
				app.msgBox(app.getErrorString1(Invoice_contracts_extracted, noOfContracts.String), app.getErrorString(Extract_status),MsgBox_OK_Only);
			endif;
		elseif self.mode = LOAD_MODE then
			if noOfContracts = 1 then
				app.msgBox(app.getErrorString1(Invoice_contract_loaded, noOfContracts.String), app.getErrorString(Load_status),MsgBox_OK_Only);
			else
				app.msgBox(app.getErrorString1(Invoice_contracts_loaded, noOfContracts.String), app.getErrorString(Load_status),MsgBox_OK_Only);
			endif;
		endif;
	endif;
epilog
	
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
