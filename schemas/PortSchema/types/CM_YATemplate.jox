    <JadeMethod name="getAuditTextForProperty" id="c4d36d3e-f69a-468b-b88d-c457ad15d3b8">
        <source>getAuditTextForProperty(_property: Property): String;

/*

Purpose:			

Parameters:			

Return Value:		


Date			Who		Reason
21 August 2008	consw1	Initial creation

*/

vars

begin
	if _property.name = CM_YATemplate::status.name then
		return self.formatAuditText( _property.name, self.getStatusString() );
	endif;
	
	return inheritMethod(_property);

epilog

end;</source>
        <Parameter name="_property" type="Property"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getCriteriaDescription" id="0b623594-eea3-4189-91b3-9f7a071302ae">
        <source>getCriteriaDescription(): String;
//30 July 2008	cnwdw1	
//
begin
	return self.myYardAllocation.getCriteriaString().replaceString(Cr, ", ");
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="928cc8a4-be7d-44d6-887e-83133892430f">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
//30 July 2008	cnwdw1	
//
vars

begin

	if _attrName = ETRow_Code then
		return self.code;
	elseif _attrName = ETRow_Criteria then
		return self.getCriteriaDescription();
	elseif _attrName = ETRow_LastUsed then
		return self.lastUsedDate.asStringJMT();
	elseif _attrName = ETRow_Status then
		return self.getStatusString;
	elseif _attrName = ETRow_Used then
		return self.allYardAllocations.size.asStringJMT();
	endif;
	
	return inheritMethod(_attrName, _short);

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getStatusString" id="5c54440d-d261-44f5-add2-37314ece4125">
        <source>getStatusString() : String;

/*

Purpose:		Get template status as a display string.

Parameters:			

Return Value:	Template status in string format.


Date			Who		Reason
21 August 2008	consw1	Initial creation

*/

vars

begin
	if self.status = YATemplateStatus_Active then
		return YATemplateStatus_ActiveStr;
	elseif self.status = YATemplateStatus_Disabled then
		return YATemplateStatus_DisabledStr;
	endif;
	
	return null;
		
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="isActive" id="f466d1fc-9fc8-45c6-8aee-d1ef4f4966eb">
        <condition/>
        <source>isActive():Boolean condition;

/*

Purpose:		

Parameters:			

Return Value:	True when template is active (may be selected when creating a new yard allocation).


Date			Who		Reason
21 August 2008	consw1	Initial creation

*/

begin
	return self.status = YATemplateStatus_Active;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="ff66b21d-ff63-4d36-9e6f-e25880ac832a">
        <source>pxyCreateUpdateProxy(): SelfType;
// 20/04/2011	cnwmh5		PAR #27401 - Add code to handle prossible exceptions occurring when
//							trying to create the proxy

vars
	proxyYATemplate: SelfType;
	completedOK		: Boolean;
begin
	if self.isTransient() then
		return null;
	endif;
	
	proxyYATemplate	:=	inheritMethod();
	proxyYATemplate.myTerminal := self.myTerminal;
	proxyYATemplate.code := self.code;
	proxyYATemplate.lastUsedDate := self.lastUsedDate;
	proxyYATemplate.myYardAllocation := self.myYardAllocation.pxyCreateUpdateProxy();
	
	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return proxyYATemplate;
	
epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete proxyYATemplate;
	endif;	
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="d61f5b3e-e65d-40c6-846c-b56bbff52cbe">
        <updating/>
        <source>setForCreate(proxyYATemplate: CM_YATemplate; _yardAllocation : CM_YardAllocation) updating;
begin
	self.myTerminal	:=	proxyYATemplate.myTerminal;
	self.setForUpdate(proxyYATemplate);
	self.myYardAllocation := _yardAllocation;
end;</source>
        <Parameter name="proxyYATemplate" type="CM_YATemplate"/>
        <Parameter name="_yardAllocation" type="CM_YardAllocation"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="2fcc3d72-a355-40cf-a8dc-6190d0b18871">
        <updating/>
        <source>setForUpdate(proxyYATemplate: CM_YATemplate) updating;
begin
	self.code := proxyYATemplate.code;
	self.lastUsedDate	:=	proxyYATemplate.lastUsedDate;
	self.status	:=	proxyYATemplate.status;
end;</source>
        <Parameter name="proxyYATemplate" type="CM_YATemplate"/>
    </JadeMethod>
