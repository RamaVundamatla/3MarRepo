    <JadeMethod name="getCOU" id="24f7de8d-3b53-40ca-a4c2-6ae952a79857">
        <source>getCOU() : CMIF_InOutCOU;
// ---------------------------------------------------------------------------
// Created:     29 May 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	intFaceCOU	: CMIF_InOutCOU;
	intFaceObj	: CMIF_TIObject;
begin

	foreach intFaceObj in self.allSubItems do
		if intFaceObj.isKindOf(CMIF_InOutCOU) then
			intFaceCOU := intFaceObj.CMIF_InOutCOU;
			break;
		endif;
	endforeach;
	
	return intFaceCOU;

end;</source>
        <ReturnType type="CMIF_InOutCOU"/>
    </JadeMethod>
