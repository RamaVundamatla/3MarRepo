	toolbar.addButton(self.btnJRWDesignT, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addFrame(self.frmFilterType, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addFrame(self.frmTableFilter, CMUI_Toolbar.Control_Alignment_Left);

end;</source>
