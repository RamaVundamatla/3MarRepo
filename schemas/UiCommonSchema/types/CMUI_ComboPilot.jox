    <JadeMethod name="displayEntry" id="f99fe91a-9db7-481a-9d3d-e96d801008fc">
        <controlMethod name="CMUI_ComboBox::displayEntry"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <executionLocation>client</executionLocation>
        <source>displayEntry(combobox: ComboBox input; _pilot : HMS_Pilot; lstIndex: Integer): String updating, clientExecution;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 May 2019	jlgsl4	TFS 44438 - PEL1 - Multiple Pilot Launches for one movement

*/

vars

begin
	if _pilot = null then
		return null;
	endif;
	
	if _pilot.isNotAvailableForEntry then
		if self.myObject &lt;&gt; _pilot then
			return null;
		else
			self.hasDirtyObject := true;
		endif;
	endif;

	return _pilot.description &amp; ' (' &amp; _pilot.code &amp; ')';				
end;
</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
        <Parameter name="_pilot" type="HMS_Pilot"/>
        <Parameter name="lstIndex" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getCollectionJMT" id="d7d52c50-b284-46e1-ba4e-bf16afabf9b0">
        <source>getCollectionJMT(): Collection protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 May 2019	jlgsl4	TFS 44438 - PEL1 - Multiple Pilot Launches for one movement

*/

vars
	pilot : HMS_Pilot;
begin
	self.allTempPilots.clear();
	if self.myHarbour &lt;&gt; null then
		foreach pilot in app.myRoot.allPilots discreteLock where not pilot.isNotAvailableForEntry
			and pilot.myCurrentHarbour = self.myHarbour do
			self.allTempPilots.add(pilot);
		endforeach;
	endif;
	return self.allTempPilots;
epilog

end;</source>
        <access>protected</access>
        <ReturnType type="Collection"/>
    </JadeMethod>
    <JadeMethod name="getListUpdateStatus" id="84bdf503-57c1-4d6d-baec-ea7072f1da5a">
