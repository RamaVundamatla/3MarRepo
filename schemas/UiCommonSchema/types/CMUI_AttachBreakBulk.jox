    <JadeMethod name="cmbSubTerminal_gotFocus" id="c57bc334-1cb4-4773-b787-8ca81784ec5b">
        <controlMethod name="ComboBox::gotFocus"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbSubTerminal_gotFocus(combobox: ComboBox input) updating;
// --------------------------------------------------------------------------------
// Created:		11 May 2009 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	objectType		: Integer;
	imexStatus		: Integer;
	commodCode		: String;
	isContainer		: Boolean;
	cargoTypeObj	: CM_CargoType;
	subTermObj		: CM_SubTerminal;
	
begin
	if self.myTerminal &lt;&gt; null then
		objectType	:=	CM_SubTerminal.Type_TrackedItem;
		commodCode	:=	null;
		
		if cmbImExStatus.listObject.CM_IMEXStatus &lt;&gt; null then
			imexStatus	:=	cmbImExStatus.listObject.CM_IMEXStatus.code;
		endif;
		
		if cmbCommodity.listObject.CM_Commodity &lt;&gt; null then
			commodCode	:=	cmbCommodity.listObject.CM_Commodity.code;
		endif;
		
		if cmbCargoType.listObject = null then
			isContainer	:=	false;
		else
			cargoTypeObj	:=	cmbCargoType.listObject.CM_CargoType;
			isContainer		:=	(cargoTypeObj.id = TI_CargoType_Container);
		endif;
		
		subTermObj	:=	self.myTerminal.getDefaultSubTerminal(	objectType,
																0,	// cnwdad1 27/01/2010 - PAR #22205.
																imexStatus,
																commodCode,
																isContainer);
		
		if subTermObj &lt;&gt; null then
			tblItem.setValueByName(ETRow_MySubTerminal, subTermObj.code);
		endif;
	endif;
end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
    </JadeMethod>
