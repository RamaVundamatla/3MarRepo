<Class name="BGP_ClearFilesRequest" id="914886a7-34ed-46cd-9918-2746a358031c">
    <superclass name="BGP_Request"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>&lt;display&gt;Clear Files&lt;/display&gt;
&lt;displayShort&lt;Clear Files&lt;/displayShort&gt;</text>
    <DbClassMap file="backgroundprocess"/>
    <PrimAttribute name="applyToSubfolders" id="443ee00a-6a2e-487e-a6d7-ee1497bce382">
        <embedded/>
        <type name="Boolean"/>
        <access>readonly</access>
    </PrimAttribute>
    <PrimAttribute name="directoryPath" id="0291a604-d309-4f56-9a52-d990e477c48d">
        <type name="String"/>
        <access>readonly</access>
    </PrimAttribute>
    <PrimAttribute name="fileMask" id="92f659b5-3fbf-44ff-8bf5-6820eb32dc01">
        <length>31</length>
        <embedded/>
        <type name="String"/>
        <access>readonly</access>
    </PrimAttribute>
    <PrimAttribute name="isDelete" id="0e439a6b-2e43-43f3-8019-d0e667f0c1f1">
        <embedded/>
        <type name="Boolean"/>
        <access>readonly</access>
    </PrimAttribute>
    <PrimAttribute name="numberOfDaysOld" id="b0204ce8-4e0a-4e27-83d0-c9f13e25a1b1">
        <embedded/>
        <type name="Integer"/>
        <access>readonly</access>
    </PrimAttribute>
    <JadeMethod name="action" id="89253288-cc27-4719-87d2-ad45dd64347d">
        <updating/>
        <source>action(): Boolean updating;
// -------------------------------------------
// Created 17 December 2003 by cnwdvb1
// -------------------------------------------
// 22/11/2012	cnwcs5	par 30618
vars
	errCode	: Integer;
	errTxt	: String;
begin
	on Exception do app.alertExceptionHandler(exception, null, self.getErrorDesc(), errCode, errTxt, true, true);
	on LockException do app.alertLockExceptionHandler(exception);
	
	self.setUser();
	self.clearFiles();

epilog
	if errCode &lt;&gt; null then
		app.myTrxUA.trxUpdateBGPRequest(self, true, errCode, errTxt, app.myPassport);
	else
		app.createActivityHistory(ActivityHistoryGeneral, null, null, app.getErrorString3(Successfully_Cleared_Files, self.fileMask, 
									self.directoryPath.substituteDirectory, numberOfDaysOld.String), false, false);	// par 30618
	endif;
	
	inheritMethod();
	
	return true;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="clearADirectory" id="e14bef0e-a813-4dae-979c-d17fce6fdf2a">
        <source>clearADirectory(_folder : FileFolder input; _deletePath : String );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26 May 2015	cnwgb1	Initial creation PAR 311012
// 18 Aug 2022	 navrk21	 Bug 52517: MTN - Clear Files BGP task allows users to clear entire hard drive if misconfigured
*/

vars
    fileObj : FileNode;
    subFolder : FileFolder;
    fileFolderDelete : FileFolder;
    newDeleteName : String;
	today : Date;
	fileNode : FileNode;
	file : File;
	path : String;
    timeStamp : TimeStamp;
	msg : String;
    rootDeleteName : String;
    
begin
    create fileFolderDelete transient;
    
    path := _folder.fileName;
    rootDeleteName := self.directoryPath.substituteDirectory &amp; '\Cleared';

	msg := 'Processing Clear Files from ' &amp; path;
	app.writeLog(msg,LogINFO);	//25 Nov 2019	NDL	TFS 47053
	// Start 18.08.2022 navrk21 TFS 52517
	if path.pos("c_bin", 1) &gt; 0 
	or path.pos("c_system", 1) &gt; 0 then
		return;
	endif;
	// End 18.08.2022 navrk21 TFS 52571
	if not self.isDelete then
		fileFolderDelete.fileName := _deletePath;
		if not fileFolderDelete.isAvailable then
			fileFolderDelete.make();
		endif;
	endif;
	
    if not _folder.isAvailable then
		app.raiseCMException1(BackgroundErrorGeneral, 'Unable to Clear files. File path ' &amp; path &amp; ' is invalid', null, null);
		return;
	endif; 
    
    foreach fileObj in _folder.files do
        if fileObj.isKindOf(FileFolder) then
            subFolder := fileObj.FileFolder;
            if subFolder.fileName = rootDeleteName then 
                continue;
            endif;
            newDeleteName := _deletePath &amp; '\' &amp; subFolder.name;
            self.clearADirectory(subFolder, newDeleteName);
        endif;
    endforeach;
    
	create file transient;
	today 	:= app.actualTimeServer().date;
	_folder.mask := self.fileMask;
	
	foreach fileNode in _folder.files do
        if fileNode.isKindOf(FileFolder) then
           continue;
        endif;
        file := fileNode.File;
		timeStamp		:= file.lastModified();

		app.sendHeartbeatIfRequired();		// 5/9/17 MAP TFS5551
		
		if self.canDelete(timeStamp.date, today, self.numberOfDaysOld) then
			if self.isDelete then
				if file.tryOpen then
					msg := 'Deleting file ' &amp; fileNode.name;
					app.writeLog(msg, LogINFO);	//25 Nov 2019	NDL	TFS 47053
					file.purge;
				else
					msg := 'Unable to open file ' &amp; fileNode.name;
					app.writeLog(msg, LogINFO);	//25 Nov 2019	NDL	TFS 47053
				endif;		
			else
				app.moveFile(file, fileFolderDelete.fileName, null, false);
			endif;
		endif;
	endforeach;
epilog
	delete file;
	delete fileFolderDelete;
end;
</source>
        <Parameter name="_folder" type="FileFolder" usage="input"/>
        <Parameter name="_deletePath" type="String"/>
    </JadeMethod>
    <JadeMethod name="clearFiles" id="d4132cff-e06d-4237-9bf1-635e4343d0ff">
        <source>clearFiles() protected;
// -------------------------------------------
// Created 17 December 2003 by cnwdvb1
// -------------------------------------------
//  22/11/2012	cnwcs5	30618 Allow %MISCDIR% in directory name
//  03/01/2013	cnwrs1	32983 Crash after user deleted.
//  25/05/2015  cnwgb1  31012 Purge Subfolders
vars
	fileFolder          : FileFolder;
	path				: String;
	timeStamp			: TimeStamp;
	today				: Date;
	file				: File;
	msg 				: String;
    deletePath          : String;
begin
	create fileFolder transient;	
	create file transient;
	
    today 	:= app.actualTimeServer().date;
	path 	:= self.directoryPath.substituteDirectory;
    if self.applyToSubfolders then
        msg := 'Processing Clear Files recursively starting at ' &amp; path;
    else
        msg := 'Processing Clear Files in ' &amp; path;
    endif;

	app.writeLog( msg,LogINFO);	//25 Nov 2019	NDL	TFS 47053
	
	
	fileFolder.fileName := path;
	
	if not fileFolder.isAvailable then
		app.raiseCMException1(BackgroundErrorGeneral, 'Unable to clear files. File path ' &amp; path &amp; ' is invalid', null, null);
		return;
	endif;
	
	if not self.isDelete then
        deletePath  := path &amp; '\' &amp; 'Cleared';
	endif;
    
    self.clearADirectory( fileFolder, deletePath );

epilog
	delete fileFolder;
	delete file;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="getDisplay" id="7a24a3cd-f84d-45b3-ae63-f759e5a75f7d">
        <source>getDisplay(): String;
// -------------------------------------------
// Created 17 December 2003 by cnwdvb1
// -------------------------------------------
// 22/11/2012	cnwcs5	par 30618
vars

	str, detail : String;

begin

	str := inheritMethod();

	return str &amp; Tab &amp; 'Clearing files older than ' &amp; self.numberOfDaysOld.String &amp; ' day(s) old with file mask of ' &amp; self.fileMask &amp;
				' from ' &amp; self.directoryPath.substituteDirectory;	// par 30618
	
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="initRequestFromTask" id="d826dc4c-2d2b-4246-808b-de7469016ffa">
        <updating/>
        <source>initRequestFromTask(_task: CM_AutoTaskClearFiles) updating;
// -------------------------------------------
// Created 17 December 2003 by cnwdvb1
// -------------------------------------------
vars


begin

	self.directoryPath := _task.directoryPath;
	self.fileMask := _task.fileMask;
	self.isDelete := _task.isToDelete;
	self.numberOfDaysOld := _task.numberOfDaysOld;
    self.applyToSubfolders := _task.applyToSubfolders;
	inheritMethod(_task);


end;</source>
        <Parameter name="_task" type="CM_AutoTaskClearFiles"/>
    </JadeMethod>
    <JadeMethod name="zTestClearFiles" id="205a8d1a-2c55-445a-84d9-9a6bcbb02f5f">
        <source>zTestClearFiles();
/*
Purpose:			NOT to be run in a production environment!

Date			Who		Reason
29 August 2022	navab1	TFS 53105
*/

vars

begin
	executeWhen JMTDevelopmentEnvironment;
	self.clearFiles();
	return;
	endExecuteWhen;
	
	app.raiseUnexpectedProgramError(class.name, method.name, "Debug code executed in production environment. Please contact support");
epilog

end;</source>
    </JadeMethod>
</Class>
