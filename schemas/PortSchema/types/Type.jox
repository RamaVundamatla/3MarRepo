    <JadeMethod name="getTypeNameForXSD" id="0d5b643e-769c-4a14-b005-e17679bc3a9f">
        <source>getTypeNameForXSD() : String;
/*

Purpose:			Get the valid XSD type for the receiver type

Parameters:			None

Return Value:		XSD type for this type

Date		Who		Reason
01 Sep 2014	cnwkpd1	PAR #34713 - .NET EDI transform integration
//18 Nov 2016	cnwrs1	dont write stringarray in the xsd replae it will string
// 08 Aug 2018	jlgrs1	TFS 39619 PEN - Approved Carriers For Operator 
*/

vars
	localName		: String;
	
begin
	localName := self.getName();
	if localName = TimeStamp.name then
		return 'dateTime';
	endif;
	if localName = Real.name then
		return 'decimal';
	endif;
	if localName = StringArray.name or
	   localName = IntegerArray.name then
		return 'string';
	endif;
	
	return localName.toLower();
		
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
