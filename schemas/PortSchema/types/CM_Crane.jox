        <source>getVoyageCraneQueueForVoyage(_voy : CM_Voyage) : CM_VoyageCraneQueue;
// ---------------------------------------------------------------------------
// Created:     11 August 2009 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
// // PAR 20474
// ---------------------------------------------------------------------------

vars
	cq : CM_VoyageCraneQueue;
begin
	foreach cq in self.allCraneQueues discreteLock do
		if cq.myParentQueue.isQueueForVoyage(_voy) then
			return cq;
		endif;
	endforeach;
	
	return null;
	
epilog

end;</source>
