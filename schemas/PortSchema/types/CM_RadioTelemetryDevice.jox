    <JadeMethod name="erase" id="70b70177-f15e-44b6-b821-dcf9492829dd">
        <updating/>
        <source>erase(_eraseLevel: Integer) updating;
/*
----------   ----------  --------------------------------------------------
Created:	15 September 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	mediator: CM_RadioTelemetryMediator;
begin
	self.eraseAlerts();
	
	//Don't do this if it is a proxy
	if not self.isTransient 
	and not self.id.length &gt; 9 then
		// make sure any persistent mediator is deleted
		mediator := self.getMyTerminal.allActiveMediators[self.id.Integer].CM_RadioTelemetryMediator;
		if mediator &lt;&gt; null then
			delete mediator;
		endif;
	endif;
	
	inheritMethod(_eraseLevel);

epilog
	
end;


</source>
        <Parameter name="_eraseLevel" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="eraseAlerts" id="4b965199-6d3b-492f-b16a-5656bebee55e">
        <interfaceImplements>
            <JadeInterfaceMethod name="IF_AlertAlarm::eraseAlerts"/>
        </interfaceImplements>
        <source>eraseAlerts();

	/*
		this method stub has been automatically generated by Jade to satisfy interface implementation requirements
	*/
/*

Purpose:			


Return Value:		


Date		Who		Reason
20 February 2007	cnwer1	Initial creation - PAR#xxxx

*/
vars

	iter : Iterator;
	alert : CM_SystemAlert;
begin
	iter:=self.allAlerts.createIterator;
	while iter.next(alert) do
	// tidy up this manual collection
		alert.setReviewed(true);
		alert.setLinkedTo(null);
	endwhile;
	


epilog
	delete iter;
end;</source>
    </JadeMethod>
