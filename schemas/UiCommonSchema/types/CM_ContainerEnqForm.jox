    <JadeMethod name="populateWithProductDefaults" id="360fb7ca-f791-45a1-8335-ab865f5ba578">
        <source>populateWithProductDefaults(_comboProduct : ComboBox input);

/*

Purpose:Clicking on the  Product combox box the other dimensions like length,height,width needs to get refected			

Parameters:			

Return Value:		


Date		Who		Reason
03 November 2008	conks1	Initial creation

*/

vars
	o			: Object;
	entRow			: EntTableRowTransient;
	prodAttr		: CM_ProductAttr;
	pro				: CM_Product;
	attrStr			: String;
	table			: CM_EntryTable;
	cargoType		: CM_CargoType;
begin
	
	pro := _comboProduct.listObject.CM_Product;
	if pro = null then
		return;
	endif;
	cargoType := pro.myCargoType;
	table := self.getTableForRow(ETRow_MyProduct);
	if table = null then
		return;
	endif;
	
	foreach o in table.allEntRowTransients do
		entRow := o.EntTableRowTransient;
		prodAttr := pro.getProdAttrFromName(entRow.name);
		if prodAttr = null then
			continue;
		endif;
		attrStr := entRow.name;
		//epr par 34311 26/6/14
		if (cargoType.allAttributesOnProduct.includes(prodAttr.name)) and (prodAttr.isViewable) then
			table.showRowByName(attrStr, false);
			if table.getValueByName(attrStr) = null then	// 27/01/2014 cnwar2 #33331 - do not clear if value already entered
				table.setValueByName(attrStr, prodAttr.getDisplayValueString());
			endif;
			table.setCellText(table.accessedRow.row, table.ColumnHeading, prodAttr.displayName);	
		
		else
			table.hideRowByName(attrStr, false);
		endif;
	endforeach;

end;</source>
        <Parameter name="_comboProduct" type="ComboBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="postSearchProcessing" id="9bd3fa97-a134-42dd-8e66-c2acac88ffae">
        <updating/>
        <source>postSearchProcessing() updating;
// ---------------------------------------------------------------------------
// Created:     18 September 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
//10 sept 2015 cnwma1 PAR #36139 Cargo Enquiry Screen will not autosize to show cargo
vars

begin
	inheritMethod();
	
	if self.numItemsShown &gt; 1 and 
	   (not self.useTblData) then
		// must have done a search after a showWithObject.  More then
		// 1 object found so need to show in tblData
		self.useTblData := true;
		self.useNumRowsShown := true;
		self.isDataTableVisible := false;
		if self.sptMainRatioSaved = 0 then
			self.sptMainRatioSaved := 50;
		endif;
		sptDataFilter.showRightControl(50, true);
		self.hideShowDataTable();
		self.doResize;
	endif;
	
	if self.allColumnFilters &lt;&gt; null and not self.allColumnFilters.isEmpty then
		self.applyColumnFilter( self.tblData );
	endif;
	
	self.doResize; //10/09/2015 cnwma1 PAR#36139
end;</source>
    </JadeMethod>
    <JadeMethod name="printTableIfVisible" id="01c4a473-b1aa-49c6-850c-bdaebb94a0a0">
        <source>printTableIfVisible(_rpt : CM_TIEnquiryOutput input; _sht : Sheet; _tbl : CM_EntryTable input) protected;
// ---------------------------------------------------------------------------
// Created:     15 September 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin

	if _sht.visible then
		_rpt.printDataFromTable(_sht.caption, _tbl);
	endif;

end;</source>
        <access>protected</access>
        <Parameter name="_rpt" type="CM_TIEnquiryOutput" usage="input"/>
        <Parameter name="_sht" type="Sheet"/>
        <Parameter name="_tbl" type="CM_EntryTable" usage="input"/>
    </JadeMethod>
    <JadeMethod name="recalcFutureStorageAnniv" id="fab4d4cd-6f0c-42d9-9b93-246f8c35ea0d">
        <source>recalcFutureStorageAnniv(storageExpiryDate : Date;
						 originalAdditionStorageDays : Integer;
						 newAdditionalStorageDays : Integer) : Date;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 Mar 2019	jlgdi1	TFS# 43372 - Recalculate future storage anniversary date based on the 

*/

begin

	return storageExpiryDate - 
	originalAdditionStorageDays + 
	newAdditionalStorageDays;	
end;</source>
        <Parameter name="storageExpiryDate" type="Date"/>
        <Parameter name="originalAdditionStorageDays" type="Integer"/>
        <Parameter name="newAdditionalStorageDays" type="Integer"/>
        <ReturnType type="Date"/>
    </JadeMethod>
    <JadeMethod name="resetNavigatorHeading" id="62c2a17e-7108-40fa-b6d1-8c6afb49660a">
        <source>resetNavigatorHeading(_cargoBOLType : CM_CargoBOLType);
// ---------------------------------------------------------------------------
// Created:     07 March 2003 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	cargoBOLType	: CM_CargoBOLType;

begin

	if _cargoBOLType = null then
		cargoBOLType := app.myRoot.getCargoBOLTypeForId(self.filterCargoTypeId);
	else
		cargoBOLType := _cargoBOLType;
	endif;

	if cargoBOLType &lt;&gt; null then
		self.setNavigatorHeading(cargoBOLType.description);
	else
		self.setNavigatorHeading('All Cargo Types');
	endif;

end;</source>
        <Parameter name="_cargoBOLType" type="CM_CargoBOLType"/>
    </JadeMethod>
    <JadeMethod name="resetNotifications" id="a56910b1-0510-46fa-a583-6db42356ce87">
        <source>resetNotifications();
// this is re-implemented to do nothing to prevent the super-class behaviour of resetting notifications from the cargo config form
vars

begin
	// do NOTHING
end;</source>
    </JadeMethod>
    <JadeMethod name="resizeFilterIdRow" id="4f2d554c-1c8a-446e-89b9-6d98852d6092">
        <updating/>
        <source>resizeFilterIdRow() updating;
/*

Date		    Who			Reason
07 July 2010	cnwas3	  par 24542

*/

vars
	row : JadeTableRow;
begin
	self.tblSearch.goToRowByName(ETRow_FilterId);
	
	row := self.tblSearch.accessedRow;
	
	if row &lt;&gt; null then	
		row.height := row.height * 3;
	endif;
	
	self.tblSearch.alignment := Table.Alignment_Left_Top;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="rowPostprocess" id="98a7ba92-69f0-430d-bd18-160af95b35b5">
        <updating/>
        <source>rowPostprocess(_dataTable: CM_DataTable io; _idx: Integer; _obj: Object): Boolean updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
11 October 2024		jlizm1	Initial creation TFS 65881 Cargo enquiry table sometimes not updating on notify

*/

vars

begin
	//navra1 - DEFECT 64356 - 31st May 2024 (jlizm1 65881 moved from parent class)
	if _obj &lt;&gt; null and (not _obj.isTransient) then
		self.armNotesForObject(_obj);
	endif;
		
	return inheritMethod(_dataTable, _idx, _obj);

epilog

end;</source>
        <Parameter name="_dataTable" type="CM_DataTable" usage="io"/>
        <Parameter name="_idx" type="Integer"/>
        <Parameter name="_obj" type="Object"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="searcherShowHideControls" id="c6bb272b-5aae-41cc-830e-c1d0f3dc4149">
        <source>searcherShowHideControls(_hide: Boolean);
// ---------------------------------------------------------------------------
// Created:     17 September 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin

	inheritMethod(_hide);
	
	if self.canAccessCargoMenu then
		self.mnuCargo.enabled := _hide;
	endif;
	

	self.btnPrintList.enabled	:= _hide;
	
	if self.canAccessTransactions then
		self.btnTransactions.enabled 	:= _hide;
		self.mnuTransactions.enabled	:= _hide;
	endif;

	
	if self.canAccessMoveIt then
		self.btnMoveIt.enabled := _hide;
	endif;
	
	if (not _hide) then
		// enabling of transship button is done in line by line basis
		// as only done for import cargo
		self.btnTranship.enabled := false;
	endif;
	
	if self.bAllowSummaryDefn then				// CCMS SFW 1047 (Recaps)
		self.mnuSummarise.enabled	:= _hide;	// CCMS SFW 1047 (Recaps)
	endif;										// CCMS SFW 1047 (Recaps)
	
	
	// TFS 2198 CNWAB1
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		self.mnuCargo.enabled := false;
		self.btnTranship.enabled := false;
		self.btnMoveIt.enabled := false;
	endif;
	
end;</source>
        <Parameter name="_hide" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="searcherTblGetDefName" id="ca9a492b-3dd3-40b9-af41-a8a437fcd0f0">
        <updating/>
