    </JadeMethod>
    <JadeMethod name="collapseExpandCargoGroups" id="f9dcab9d-a736-46f6-934e-550cac0d7b86">
        <updating/>
        <source>collapseExpandCargoGroups(_table : Table input; _all : Boolean; _skipStatusUpdate : Boolean) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On			By			Reason
// ----------			--------	-----------------------------------------------------------------------
// 19 May 2022			navdap1		Initial creation TFS 53388
// 08 Nov 2022			navmd1		TFS 55379 Refactor VoyageOpsCG Form
// 28 Nov 2022			navkc1		ChangeRequest 55408: MTN - Cargo Group Ops Form - Only show cargo groups by default
// 17 Jan 2023			navsp1 		ChangeRequest 56209: MTN - Cargo Group Voyage Ops Form - Expand/Collapse All button refactor
// 22 Mar 2024    		navsp1  	TFS Bug 61223: EUP | Cancel Transport Manifest not deleting all Cargo and doesn't db load.
// 09 Sep 2024			navsp1      TFS Bug 64455: MTN - 1311 error in voyage ops when cancelling transport manifest
// 20/02/2024			navcs2 		MTN-29368 EUP | Transaction Instrumentation - Voyage Discharge
// 14 Jan 2026 			navhl20 	Bug MTN-35897: PEN - System Locking Errors (1000010 - Unknown message)
vars
	clickedRow, clickedColumn,
	idx, totalParts					: Integer;
	row, rowId, rowStart, rowEnd	: Integer;
	cargoGroup, ti, nextTi			: CM_TrackedItem;
	collapse, noMonitor, last		: Boolean;
	plus, minus, currentState,
	newState, maxStr, tblStr, cgStr	: String;
	topTableRow, bottomTableRow		: Integer;
	selectedRow						: JadeTableRow;
	oriTable						: CM_DataTable;
	tis								: ObjectArray;
	cmifMonitor 					: CMIF_Monitor;
	passport						: CM_Passport;
	tmpRow							: Integer;
	invalid							: Boolean;//TFS 61223
begin
	if _table = null or not _table.visible then
		return;
	endif;
	
	clickedRow := _table.row;
	if not _all and clickedRow &lt;= _table.fixedRows then
		return;
	endif;
	clickedColumn :=  _table.column;
	if not _all and clickedColumn &gt; 1 then
		return;
	endif;
	
	plus := J_key_Plus.Character;
	minus := J_key_Hyphen.Character;
	
	topTableRow := _table.fixedRows;	// +1 added later in while loop
	bottomTableRow := _table.rows;
	
	// Set the table so we know which table we are processing and which Site/table we need to grab cargo group items for - // 28/11/2022	navkc1	#55408
	if _all then
		oriTable := self.myCurrentContextTbl;
		self.myCurrentContextTbl := _table.CM_DataTable;
	endif;
	
	passport := app.myPassport;
	cmifMonitor := passport.myCMIFMonitor;
	
	if cmifMonitor = null then
		noMonitor := true;
		create cmifMonitor transient;
		cmifMonitor.myParent := self;
		passport.setMyCMIFMonitor(cmifMonitor);
	endif;
	
	if _table = self.tblOnship then
		tblStr := app.getErrorString(Loading_onship_cargo) &amp; " ";
	elseif _table = self.tblOnsite then
		tblStr := app.getErrorString(Loading_onsite_cargo) &amp; " ";
	elseif _table = self.tblOffsite then
		tblStr := app.getErrorString(Loading_offsite_cargo) &amp; " ";
	elseif _table = self.tblPreNote then
		tblStr := app.getErrorString(Loading_prenotified_cargo) &amp; " ";
	endif;
	
	self.modalDialogReturnValue := self.ModalDialogReturn_Null;	
	if _all then
		self.modalDialogShow(null, null , null, null, 'Processing',  'Please Wait...');
		self.pbProgressBar.visible := true;
	endif;
	
	create tis transient;
	
	on SystemException do app.cnHandleNullOrInvObjectRef(exception, null, invalid); //TFS 61223
	// find the clicked cargo group (or do all)
	//foreach row in topTableRow to bottomTableRow do
	row := topTableRow;
	while row &lt; bottomTableRow do
		row += 1;
		selectedRow := _table.accessRow(row);
		cargoGroup := selectedRow.itemObject.CM_TrackedItem;
		
		// Not a cargo group, skip
		if cargoGroup &lt;&gt; null and not cargoGroup.isCargoGroupItem() then
			continue;	
		endif;
		
		// Not the row we're interested in
		if not _all and row &lt;&gt; clickedRow then
			continue;
		endif;
		
		// Are we expanding or collapsing ? Flip the symbol
		currentState := _table.accessCell(row, 1).text[1:1];	// + or -
		if _all then 
			/* // 28/11/2022	navkc1	#55408 - Changed to expand only
			if self.btnExpandAll.value then
				newState := plus;
				collapse := true;
			else
				newState := minus;
			endif;
			*/
			
			//25Jan2023 navsp1 TFS 56209
			if self.isExpand then //Expand All
				newState := minus;	
				if currentState &lt;&gt; newState then
					self.expandedRows += 1;	
				endif;
			else //Collapse All				
				newState := plus;
				collapse := true;
				if currentState &lt;&gt; newState and self.expandedRows &gt; 0 then
					self.expandedRows -= 1;	
				endif;
			endif;
			
		else			
			if currentState = plus then
				newState := minus;
				
				//25Jan2023 navsp1 TFS 56209
				if not self.isDoResize then
					self.expandedRows += 1;
				endif;
			else
				newState := plus;
				collapse := true;
				
				//25Jan2023 navsp1 TFS 56209
				if self.expandedRows &gt; 0 and not self.isDoResize then
					self.expandedRows -= 1;
				endif;
			endif;
		endif;
		_table.accessedCell.text[1:1] := newState;	// Now, - or +
		
		nextTi := null;
		if row &lt;&gt; bottomTableRow then
			nextTi := _table.accessRow(row + 1).itemObject.CM_TrackedItem;
		endif;
		
		invalid := false;		//TFS 61223
		nextTi.edition();		//TFS 61223
		
		// If we're expanding a cargo group, and we don't already have the TIs loaded, then add them to the table
		//if not collapse and ((not last and nextTi = null) or (last or nextTi.isCargoGroupItem())) then
		if not collapse and (nextTi = null or (not invalid and nextTi.isCargoGroupItem)) then	//TFS 61223
			if not _all and not self.frmModalDialog.visible then
				self.modalDialogShow(null, null , null, null, 'Processing',  'Please Wait...');
				self.pbProgressBar.visible := true;
			endif;
			
			tis.clear();
			
			self.getTIsForCargoGroup("", tis, cargoGroup.CM_CargoGroup);
			
			maxStr := tis.size().String;
			totalParts := maxStr.Integer;
			idx := 0;
			cgStr := "Unknown";
			if cargoGroup &lt;&gt; null then
				cgStr := cargoGroup.id;
			endif;
			
			foreach ti in tis as CM_TrackedItem do
				idx += 1;
				cmifMonitor.updateProgress(tblStr &amp; cgStr &amp; ' [' &amp; idx.String &amp; '/' &amp; maxStr &amp; ']', totalParts, idx);
				
				invalid := false;				//TFS 64455
				ti.edition();					//TFS 64455
				if ti = null or invalid then	//TFS 64455
					continue;					//TFS 64455
				endif;							//TFS 64455
				
				tmpRow := row;//18Jan2023 navsp1 TFS 56060
				self.loadCargoForTable(ti, row, _table.CM_DataTable, false, false);
				
				//18Jan2023 navsp1 TFS 56060
				// There are situations when the TI is not added to the table, eg, Child Cargo
				// These return early and don't change 'row'. So only increment bottomTableRow if the cargo has actually been added
				if tmpRow &lt;&gt; row then
					bottomTableRow += 1;
				endif;
				
			endforeach;
			
		else
			// Show/hide each TI under the cargo group
			rowStart := row + 1;	// Skip the cargo group row itself
			foreach rowId in rowStart to bottomTableRow do
				ti := _table.accessRow(rowId).itemObject.CM_TrackedItem;
				
				invalid := false;	//TFS 61223
				ti.edition();		//TFS 61223
				
				// We've hit the next cargo group, time to stop
				// (ti is null for Unknown Cargo Group)
				if ti = null or (not invalid and ti.isCargoGroupItem()) and ti &lt;&gt; cargoGroup then	//TFS 61223
					break;
				endif;
				
				if collapse then
					_table.accessRow(rowId).visible := false;
				else
					_table.accessRow(rowId).visible := true;
				endif;
				
			endforeach;	// foreach ti in cargoGroup
		endif;
	endwhile;	// foreach cargoGroup rows
	
	//25Jan2023 navsp1 TFS 56209
	if not _all then
		if self.expandedRows &gt; 0 then
			self.btnExpandAll.caption:= app.getErrorString(Collapse_all);
			self.btnExpandAll.bubbleHelp := app.getErrorString(Collapse_all);
		else
			self.btnExpandAll.caption:= app.getErrorString(Expand_all);
			self.btnExpandAll.bubbleHelp := app.getErrorString(Expand_all);
		endif;
	endif;
	
	if not _skipStatusUpdate then //25Jan2023 navsp1 TFS 56209
		self.updateStatusBarCounts(false, _table.CM_DataTable); // 28/11/2022	navkc1	#55408
	endif;
	
	// We have loaded something to the table, colour the rows - // 28/11/2022	navkc1	#55408
	if not tis.isEmpty() then
		self.colourTableRows(_table.CM_DataTable);
		_table.CM_DataTable.setCurrentViewObjects();
	endif;
	
epilog
	
	if _all then
		self.myCurrentContextTbl := oriTable;
	endif;
	
	if noMonitor then
		passport.setMyCMIFMonitor(null);
		delete cmifMonitor;
	endif;
	
	self.frmModalDialog.visible := false;
	
	delete tis;
end;</source>
        <Parameter name="_table" type="Table" usage="input"/>
        <Parameter name="_all" type="Boolean"/>
        <Parameter name="_skipStatusUpdate" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="colourTableRows" id="09d02411-ebb0-4893-b525-0e0e36cfa4e7">
        <source>colourTableRows(_table: CM_DataTable input);
/*

Purpose:			Alternate each TI row colour - skipping Cargo Groups

Parameters:			

Return Value:		

Date				Who		Reason
28 April 2022		navsj20	Initial creation TFS 53388
08 November 2022	navmd1	TFS 55379 Refactor VoyageOpsCG Form
22 March	2024    navsp1  TFS Bug 61223: EUP | Cancel Transport Manifest not deleting all Cargo and doesn't db load.
*/

vars
	rowIndex		: Integer;
	backColour		: Integer;
	startRow,
	lastRow			: Integer;
	row				: JadeTableRow;
	ti				: CM_TrackedItem;
	invalid			: Boolean; //TFS 61223
begin
	if _table = null then
		return;
	endif;
	
	_table.alignFilterHeaderColumns();
	
	startRow := _table.fixedRows + 1;
	lastRow := _table.rows;
	
	on SystemException do app.cnHandleNullOrInvObjectRef(exception, null, invalid); //TFS 61223
	foreach rowIndex in startRow to lastRow do
		
		invalid := false;	//TFS 61223
		
		row := _table.accessRow(rowIndex);
		ti := row.itemObject.CM_TrackedItem;
		
		ti.edition();		//TFS 61223
		if invalid then		//TFS 61223
			continue;		//TFS 61223
		endif;				//TFS 61223
		
		if ti = null or ti.isCargoGroupItem() then 
			continue; 
		endif;
		
		if rowIndex mod 2 = 0 then
			backColour := self.getRowColour(1, _table);
		else
			backColour := self.getRowColour(2, _table);
		endif;
		
		row.backColor := backColour;
	endforeach;

epilog

end;</source>
        <Parameter name="_table" type="CM_DataTable" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doAutoPlanGetTIs" id="09b14394-3d3b-40be-a3de-f411dcf61d59">
        <updating/>
        <source>doAutoPlanGetTIs(_mode : Integer; _all : Boolean; _params : CMIF_AutoplanParams input; _table : CM_DataTable) updating;

/*

Purpose:			BUG 58922

Parameters:			

Return Value:		


Date		Who		Reason
04 July 2023	navab1	Initial creation

*/

vars
	table 	: CM_DataTable;
	idx : Integer;
	ti, cgti : CM_TrackedItem;
	cargoGrp : CM_CargoGroup;
	obj : Object;
	tiset : CM_TISet;
begin
	table := _table;
	create tiset transient;
	
	if _all then
		foreach idx in table.fixedRows + 1 to table.rows do
			ti := table.accessRow(idx).itemObject.CM_TrackedItem;
			if ti = null then
				continue;
			endif;
			
			if self.isInCargoGrouping then
				if ti.isCargoGroupItem() then
					if _mode = PLANNING_MODE then
						self.getTIsForCargoGroup(Select_Context_Plan, tiset, ti.CM_CargoGroup);
					else
						self.getTIsForCargoGroup(Select_Context_Queue, tiset, ti.CM_CargoGroup);
					endif;
				else
					continue;
				endif;
			else
				if not ti.isCargoGroupItem() then
					if (_mode = PLANNING_MODE and ti.myPrimaryPlannedLocation = null)
					or (_mode = QUEUE_MODE and ti.myPrimaryQueuedLocation = null) then
						tiset.add(ti);	
					endif;
				endif;
			endif;		
		endforeach;
	else
		self.getAllSelectedTIs(Select_Context_Plan, tiset,_all,table);
	endif;

	foreach ti  in tiset do
		if (_mode = PLANNING_MODE and ti.myPrimaryPlannedLocation = null)
		or (_mode = QUEUE_MODE and ti.myPrimaryQueuedLocation = null) then
			_params.allTrackedItems.add(ti);
		endif;
	endforeach;

epilog
	delete tiset;
end;</source>
        <Parameter name="_mode" type="Integer"/>
        <Parameter name="_all" type="Boolean"/>
        <Parameter name="_params" type="CMIF_AutoplanParams" usage="input"/>
        <Parameter name="_table" type="CM_DataTable"/>
    </JadeMethod>
    <JadeMethod name="doClickCargoGrouping" id="caac26fe-b0c8-4e40-bd16-becee0c12738">
        <updating/>
        <source>doClickCargoGrouping() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
29 April 2022		navds20	Initial creation TFS 53388
08 November 2022	navmd1	TFS 55379 Refactor VoyageOpsCG Form

*/

vars
	userWindow	: CM_UserWindow;
begin
	if self.isInCargoGrouping then
		self.performAllowFilter					:= false;
		self.chkAllowFilter.value				:= false;
		self.chkAllowFilter.enabled				:= false;
				
		self.displayModeOnShip					:= DISPLAY_MODE_ACTUAL;
		self.displayModeOffSite					:= DISPLAY_MODE_ACTUAL;
		self.displayModeOnSite					:= DISPLAY_MODE_ACTUAL;
		self.displayModePreNote					:= DISPLAY_MODE_ACTUAL;
		
		self.frmDispOffsite.enabled				:= false;
		self.frmDispOnship.enabled				:= false;
		self.frmDispOnsite.enabled				:= false;
		self.frmDispPreNote.enabled				:= false;
		
		self.btnExpandAll.visible				:= true;
		self.btnRecalculateCargoGroup.visible	:= true;
	else
		// Allow filters to be set on the tables again
		self.chkAllowFilter.enabled				:= true;
		
		// Try and get the previously saved value
		userWindow := app.getUserWindow(self.name, false);
		if userWindow &lt;&gt; null then
			self.chkAllowFilter.value := userWindow.xmlInfo.cnEcGetTagValueOfName(self.chkAllowFilter.name).Boolean;
		endif;
		
		if self.chkAllowFilter.value then
			self.performAllowFilter				:= true;
		endif;
		
		self.frmDispOffsite.enabled				:= true;
		self.frmDispOnship.enabled				:= true;
		self.frmDispOnsite.enabled				:= true;
		self.frmDispPreNote.enabled				:= true;
		
		// Hide buttons that don't do anything outside of cargo grouping mode
		self.btnExpandAll.visible				:= false;
		self.btnRecalculateCargoGroup.visible	:= false;
	endif;
	
	self.frmToolbar.positionToolbarControls();
	self.validatePeformance(false, null);
	
	self.loadCurrentVoyage();
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doClickCollapseAll" id="a0d2ff64-0dcc-440f-98d1-937150afcd13">
        <updating/>
        <source>doClickCollapseAll() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
29 April 2022		navds20	Initial creation TFS 53388
28 November 2022	navkc1	ChangeRequest 55408: MTN - Cargo Group Ops Form - Only show cargo groups by default
17 Jan 2023         navsp1  ChangeRequest 56209: MTN - Cargo Group Voyage Ops Form - Expand/Collapse All button refactor
20/02/2024 			navcs2 	MTN-29368 EUP | Transaction Instrumentation - Voyage Discharge
14 Jan 2026 		navhl20 Bug MTN-35897: PEN - System Locking Errors (1000010 - Unknown message)
*/

vars
	
begin
	if self.isInCargoGrouping then
		
		//17Jan2023 navsp1 56209
		if self.expandedRows &gt; 0 then
			self.isExpand := false;
			self.btnExpandAll.caption:= app.getErrorString(Expand_all);
			self.btnExpandAll.bubbleHelp := app.getErrorString(Expand_all);
		else
			self.isExpand := true;
			self.btnExpandAll.caption:= app.getErrorString(Collapse_all);
			self.btnExpandAll.bubbleHelp := app.getErrorString(Collapse_all);
		endif;		
		self.collapseExpandCargoGroups(self.tblOffsite, true, false);
		self.collapseExpandCargoGroups(self.tblOnsite, true, false);
		self.collapseExpandCargoGroups(self.tblOnship, true, false);
		self.collapseExpandCargoGroups(self.tblPreNote, true, false);
		
	endif;
epilog
	
end;</source>
    </JadeMethod>
    <JadeMethod name="doClickRecalculateCargoDetails" id="547473ab-e33e-4132-b915-5c13aacc44b0">
        <updating/>
        <source>doClickRecalculateCargoDetails() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
06 May 2022	navsj20	Initial creation TFS 53388
08 November 2022	navmd1	TFS 55379 Refactor VoyageOpsCG Form
18 May 2023			navmd1	TFS 56062 Code tidy up

*/
vars
	invalidCargoGroup	: Boolean;
	controller 			: CMIF_CargoGroupDtlController;
	passport 			: CM_Passport;
	ti 					: CM_TrackedItem;
	retVal : Integer;
begin

	
	// ### TFS CR 58857 TASK 58967  30JUN2023 NAVAB1
	retVal :=  app.msgBox(app.getErrorString(Want_calcu_cargo_group_whole_v),app.getErrorString(Confirmation),MsgBox_Yes_No_Cancel);
	if retVal = MsgBox_Return_Cancel then
		return;
	elseif retVal = MsgBox_Return_Yes then
		controller := create CMIF_CargoGroupDtlController(null);
		controller.myVoyage := self.myCurrentVoyage;
		controller.myTerminal := self.myTerminal;
	else
		ti := self.myCurrentTrackedItem;
		if ti = null or not ti.isCargoGroupItem then
			app.msgBox(app.getErrorString(Please_select_item_update),app.getErrorString(Problem), MsgBox_OK_Only);
			return;
		endif;
		
		self.myCargoGroup := ti.CM_CargoGroup;
		on Exception do app.handleDeletedObject(exception, self.myCargoGroup, invalidCargoGroup);
		self.myCargoGroup.edition;
		
		if invalidCargoGroup then
			self.myCargoGroup := null;
			return;
		endif;
		
		controller := create CMIF_CargoGroupDtlController(self.myCargoGroup);
		controller.myTerminal := self.myTerminal;
	endif;
	
	controller.purgeExisting := true; // purge the existing current details
	// recalculate details
	while true do
		app.myTrxCA.trxCreateCargoGroupDetails(controller, app.myPassport);
		if app.myPassport.trxCompletedOK then
			// Clear errors/warnings from form and err/warnings window
			self.clearErrorWarnings();
			global.beep;
			break;
		else
			retVal := app.showErrorWarningDialog("Cargo Details", app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   retVal = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
			return;
		endif;
		break;
	endwhile;
epilog
	delete controller;
end;</source>
    </JadeMethod>
    <JadeMethod name="doDischarge" id="618271fc-feeb-422b-8ab5-e31c27be549a">
        <updating/>
        <source>doDischarge(_all: Boolean; _fromDragDrop: Boolean; _table: CM_DataTable; win: Window input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 Jun 2024	navhl20	Bug 64434: EUP -Planned Location getting updated twice.

*/

vars
	
begin
	if self.moveModeForm = PLANNING_MODE then
		self.doMove_Unplan(_all,_table);
	endif;
	inheritMethod(_all, _fromDragDrop, _table, win);
epilog
	
