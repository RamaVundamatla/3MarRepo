    <JadeMethod name="doNewBookRefItem" id="28481eff-49b3-4d14-8479-e66a220781b3">
        <updating/>
        <source>doNewBookRefItem()updating;
/*
	Created on 15 February 2008
	
	by Debby Hutchison
	
	Purpose:
*/

vars
	cmif_brItem : CMIF_BookingRefItem;
	cargoTypeId : Integer;
begin
	if not dck_BRefItem.visible then
		itemEditMode := Mode_Add;
		bookRefItemDockbarShow;
		tblExtra.clearValues;
	endif;
	cmif_brItem := myInterfaceBookingRef.createInterfaceItem(null, null);
	cargoTypeId := app.myPassport.getDefaultCargoType().id;
	cmif_brItem.setDefaults(cargoTypeId);

	loadTableFromBRItem(cmif_brItem);
	setDockBarMode;
	tblExtra.moveFirst();
	tblExtra.setFocus();
end;</source>
