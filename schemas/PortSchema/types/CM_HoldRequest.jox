    <JadeMethod name="getVoyageLoadController" id="5a45d64f-66f7-4979-b5a0-d3f553a75828">
        <source>getVoyageLoadController(): CM_LocationsController;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 December 2025	jlier1	Initial creation 36738

*/

vars
	voyage : CM_Voyage;
begin
	
	if self.myHoldControllerLoad &lt;&gt; null then
		return self.myHoldControllerLoad;
	endif;
	
	//must be the voyage block controller
	voyage:=self.getVoyage;
	if voyage &lt;&gt; null then
		return voyage.myShipBlockStack;
	endif;
	return null;
epilog

end;</source>
        <ReturnType type="CM_LocationsController"/>
    </JadeMethod>
