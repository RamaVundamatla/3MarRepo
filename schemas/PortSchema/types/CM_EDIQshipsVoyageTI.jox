    <JadeMethod name="canUserSet" id="a259208a-7387-432f-8416-0ca06b9d9cc2">
        <source>canUserSet(_propName: String): Boolean;
/*****************************************************
Author		: jlika1 (Karen Alexander)
Date		: 03 November 2022
TFS#		: 54892
Function	:

*** Changes ***
Date			Name		TFS#		Description

****************************************************/

begin
	if _propName.String.isOneOf(CM_EDIQshipsVoyageTI::allQshipsMovementTIs.name, CM_EDIQshipsVoyageTI::myQshipsVesselTI.name) then		
		return true;
	else
		return inheritMethod(_propName);
	endif;
end;</source>
        <Parameter name="_propName" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="b940050d-a1cb-41b0-93c1-86436ffcb922">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
/*****************************************************
Author		: jlika1 (Karen Alexander)
Date		: 26 October 2022
TFS#		: 54892
Function	:

*** Changes ***
Date			Name		TFS#		Description
20 Sep 2024     navsp1      66169		Defect 66169: NSW - OnePort - voyageNoIn and voyageNoOut field mapping
****************************************************/

vars

begin
	if _attrName = ETRow_VoyageCode then		
		return self.voyageId;
	elseif _attrName = ETRow_VesselName then
		return self.vesselName;
	elseif _attrName = ETRow_VesselCode then
		return self.vesselId;
	elseif _attrName = ETRow_Id then
		return self.qshipid;
	elseif _attrName = ETRow_Status then
		return self.statusType;
	elseif _attrName = ETRow_VoyageStatusType then
		if self.voyageStatusType = VoyageStatusType_ACTV then
			return VoyageStatusTypeStr_ACTV;
		elseif self.voyageStatusType = VoyageStatusType_CANC then
			return VoyageStatusTypeStr_CANC;
		elseif self.voyageStatusType = VoyageStatusType_CLOS then
			return VoyageStatusTypeStr_CLOS;
		elseif self.voyageStatusType = VoyageStatusType_COMP then
			return VoyageStatusTypeStr_COMP;
		elseif self.voyageStatusType = VoyageStatusType_CONF then
			return VoyageStatusTypeStr_CONF;
		elseif self.voyageStatusType = VoyageStatusType_DRFT then
			return VoyageStatusTypeStr_DRFT;
		elseif self.voyageStatusType = VoyageStatusType_INVC then
			return VoyageStatusTypeStr_INVC;
		elseif self.voyageStatusType = VoyageStatusType_PLAN then
			return VoyageStatusTypeStr_PLAN;
		elseif self.voyageStatusType = VoyageStatusType_RELS then
			return VoyageStatusTypeStr_RELS;
		elseif self.voyageStatusType = VoyageStatusType_SCHD then
			return VoyageStatusTypeStr_SCHD;		
		else
			return "";
		endif;
	elseif _attrName = ETRow_VoyageExternalCode then		//TFS 66169
		return self.voyageCodeExternal;						//TFS 66169
	endif;

	return inheritMethod(_attrName, _short);

epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="isQshipsVoyage" id="f8feee80-1b1c-4af9-bbcc-ce35193a7a9a">
        <condition/>
        <source>isQshipsVoyage():Boolean condition;
/*****************************************************
Author		: jlika1 (Karen Alexander)
Date		: 04 October 2022
TFS#		: 54892
Function	:

*** Changes ***
Date			Name		TFS#		Description

****************************************************/

begin
	if self.id = null then
		return false;
	endif;
	
	if self.jobTypeName = null then
		return false;
	endif;
	
	if self.statusType = null then
		return false;
	endif;
	
	if self.voyageId = null then
		return false;
	endif;
	
	if self.vesselId = null then
		return false;
	endif;
	
	return true;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isQshipsVoyageTI" id="3cead9f4-55ed-45f6-851c-bf62c85389a3">
        <source>isQshipsVoyageTI(): Boolean;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 11/12/2023	navdap1		Initial creation TFS 61709 POB - QShips - Update to Voyage Removes Manually Added Operators
//
vars

begin
	return true;

epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="e9385b19-7a7e-43a6-b22e-b291615f5986">
        <updating/>
        <source>setForUpdate(_proxyEDITI: SelfType) updating;
/*****************************************************
Author		: jlika1 (Karen Alexander)
Date		: 03 November 2022
TFS#		: 54892
Function	:

*** Changes ***
Date			Name		TFS#		Description

****************************************************/

vars
	prop : Property;
	propDict : PropertyNDict;	
begin
	
	propDict := CM_EDIQshipsVoyageTI.getProperties;	

	foreach prop in propDict do
		if self.canUserSet(prop.name) and
		not prop.name.String.isOneOf(CM_EDIQshipsVoyageTI::allQshipsMovementTIs.name, CM_EDIQshipsVoyageTI::myQshipsVesselTI.name) then		   
			// bypass all type integrity checking in the name of convenience!!!
			self.setPropertyValue(prop.name, _proxyEDITI.getPropertyValue(prop.name));
		endif;
	endforeach;
	
	inheritMethod(_proxyEDITI);
end;</source>
        <Parameter name="_proxyEDITI" type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setPropertyByName" id="4dc78196-55d4-4df5-9b7e-904064044c85">
        <updating/>
        <source>setPropertyByName(_columnName: String; _value: String io): Boolean updating;
/*****************************************************
Author		: jlika1 (Karen Alexander)
Date		: 16 November 2022
TFS#		: 54892
Function	:

*** Changes ***
Date			Name		TFS#		Description

****************************************************/

vars

begin
	if _columnName = ETRow_VoyageStatusType and self.isKindOf(CM_EDIQshipsVoyageTI) then		 
		if _value.toUpper = VoyageStatusTypeStr_ACTV.toUpper then
			 self.CM_EDIQshipsVoyageTI.voyageStatusType := VoyageStatusType_ACTV;
		elseif _value.toUpper = VoyageStatusTypeStr_CANC.toUpper then
			 self.CM_EDIQshipsVoyageTI.voyageStatusType := VoyageStatusType_CANC;
		elseif _value.toUpper = VoyageStatusTypeStr_CLOS.toUpper then
			 self.CM_EDIQshipsVoyageTI.voyageStatusType :=  VoyageStatusType_CLOS;
		elseif _value.toUpper = VoyageStatusTypeStr_COMP.toUpper then
			 self.CM_EDIQshipsVoyageTI.voyageStatusType := VoyageStatusType_COMP;
		elseif _value.toUpper = VoyageStatusTypeStr_CONF.toUpper then
			 self.CM_EDIQshipsVoyageTI.voyageStatusType := VoyageStatusType_CONF;
		elseif _value.toUpper = VoyageStatusTypeStr_DRFT.toUpper then
			 self.CM_EDIQshipsVoyageTI.voyageStatusType := VoyageStatusType_DRFT;
		elseif _value.toUpper = VoyageStatusTypeStr_INVC.toUpper then
			 self.CM_EDIQshipsVoyageTI.voyageStatusType := VoyageStatusType_INVC;
		elseif _value.toUpper = VoyageStatusTypeStr_PLAN.toUpper then
			 self.CM_EDIQshipsVoyageTI.voyageStatusType := VoyageStatusType_PLAN;
		elseif _value.toUpper = VoyageStatusTypeStr_RELS.toUpper then
			 self.CM_EDIQshipsVoyageTI.voyageStatusType := VoyageStatusType_RELS;
		elseif _value.toUpper = VoyageStatusTypeStr_SCHD.toUpper then
			 self.CM_EDIQshipsVoyageTI.voyageStatusType := VoyageStatusType_SCHD;		
		else
			 self.CM_EDIQshipsVoyageTI.voyageStatusType := 0;
		endif;		
		return true;
	else
		return inheritMethod(_columnName, _value);
	endif;			

epilog

end;</source>
        <Parameter name="_columnName" type="String"/>
        <Parameter name="_value" type="String" usage="io"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
