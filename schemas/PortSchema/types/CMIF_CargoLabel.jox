    <JadeMethod name="getVehicleVisitRecord" id="af892dff-3c41-4b63-bd2d-0f85b0021420">
        <source>getVehicleVisitRecord() : CM_VehicleVisitRecord;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
9/10/2013	cnwjre1		Initial creation PAR #32751 additional reporting fields
*/

vars

	record : CM_VehicleVisitRecord;
	
begin

	if self.myTrackedItem &lt;&gt; null then
		record := self.myTrackedItem.getVehicleVisitRelease();
		if record = null then
			record := self.myTrackedItem.getVehicleVisitReceival();
		endif;
	elseif self.myBookingRef &lt;&gt; null then
		record := null;
	elseif self.myBOL &lt;&gt; null then
		record := null;
	elseif self.myGateReceival &lt;&gt; null then
		record := self.myGateReceival.getVehicleVisitRecord();
	elseif self.myGateReceivalByType &lt;&gt; null then
		record := self.myGateReceivalByType.getVehicleVisitRecord();
	endif;
	
	return record;
	
epilog

end;</source>
        <ReturnType type="CM_VehicleVisitRecord"/>
    </JadeMethod>
    <JadeMethod name="getVesselName" id="ce8c258a-442c-4cb4-bde5-430ac8894ca0">
        <source>getVesselName() : String;
// 37594 Steinweg Oman cargo label print
vars
	vesselName		: String;
	voyage			: CM_Voyage;
	
begin

	if self.myTrackedItem &lt;&gt; null then
		voyage := self.myTrackedItem.myVoyage;
	elseif self.myBookingRef &lt;&gt; null then
		voyage := self.myBookingRef.myVoyage;
	elseif self.myBOL &lt;&gt; null then
		voyage := self.myBOL.getMyVoyage;
	//elseif self.myGateReceival &lt;&gt; null then
	//	voyageCode := self.myGateReceival.voyageCode;
	//elseif self.myGateReceivalByType &lt;&gt; null then
	//	voyageCode := self.myGateReceivalByType.voyageCode;
	endif;
	
	if voyage &lt;&gt; null then
		if voyage.myVessel &lt;&gt; null then
			vesselName := voyage.myVessel.name;
		else
			vesselName := voyage.vesselName;
		endif;
	endif;
	
	return vesselName;
epilog

end;
</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getVoyage" id="b775a18e-ef04-4cc9-8cff-87d5848fc330">
        <source>getVoyage() : String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
19 January 2010	cnwndl1	Initial creation	CCMS MES 1004

*/

vars

	voyageCode : String;
	voyage : CM_Voyage;
	
begin

	if self.myTrackedItem &lt;&gt; null then
		voyageCode := self.myTrackedItem.voyageCode;
	elseif self.myBookingRef &lt;&gt; null then
		voyageCode := self.myBookingRef.voyageCode;
	elseif self.myBOL &lt;&gt; null then
		voyage := self.myBOL.getMyVoyage;
	elseif self.myGateReceival &lt;&gt; null then
		voyageCode := self.myGateReceival.voyageCode;
	elseif self.myGateReceivalByType &lt;&gt; null then		// 10/12/2010 cnwmh5 #26556
		voyageCode := self.myGateReceivalByType.voyageCode;
	endif;
	
	if voyage &lt;&gt; null then
		voyageCode := voyage.code;
	endif;
	
	if voyageCode = null then
		voyageCode := " ";
	endif;
	
	return app.getErrorString(Voyage) &amp; "  =  " &amp; voyageCode;
	
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
