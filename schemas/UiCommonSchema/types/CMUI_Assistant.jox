    <JadeMethod name="comboBoxBulkRelByTypeStatus" id="f41fcf2f-ea72-4505-ac8c-6052fe9e190d">
        <source>comboBoxBulkRelByTypeStatus(_cmb : ComboBox input; 
							_typeStr,
							_statusStr  : String;
							_release : CM_BulkRelease);
/*
----------   ----------  --------------------------------------------------
Created:	25 May 2006 By cnwth2

Purpose:	N.B If you need change to this method - please be aware it needs to go like the clappers
			because some customers have upwards of 17,000 releases of a single type/status.
			Avoid dereferencing the bulk release object in anyway.

Changed On  Changed By  Reason
----------  ----------  --------------------------------------------------
11/08/2011	cnwdap1		PAR #27972 Bulk release type is no longer translatable, replaced by string constants
07-06-2022  navds20     52720 MTN - Delivery Requests - All Release Types
14/07/2025	naviv1	MTN-35226	MTN - Usage of Iterator.getCurrentKeys  	
*/
vars
	iter				: Iterator;
	dict				: CM_BulkReleaseByTypeStCodeDict;
	bulkRelease			: CM_BulkRelease;
	typeKey,
	statusKey			: Integer;
	codeKey				: String;
	requestDateKey		: TimeStamp;
	typesToSearch,
	statusToSearch		: IntegerArray;
	searchStatus,
		
	type				: Integer;
	tmpFound			: Boolean;
begin
	create typesToSearch transient;
	create statusToSearch transient;
	//TFS 52720 Starts
	if _typeStr.cnContains(BR_TYPE_ROAD_STR) then
		typesToSearch.add(BR_TYPE_ROAD);
	endif;
	if _typeStr.cnContains(BR_TYPE_RAIL_STR) then
		typesToSearch.add(BR_TYPE_RAIL);
	endif;
	if _typeStr.cnContains(BR_TYPE_SHIP_STR) then
		typesToSearch.add(BR_TYPE_SHIP);
	endif;
	if _typeStr.cnContains(BR_TYPE_PACK_STR) then
		typesToSearch.add(BR_TYPE_PACKING);
	endif;
	//TFS 52720 Ends
	
	if (_statusStr = BR_ACTIVE_STRING &amp; ' &amp; ' &amp; BR_PENDING_STRING) then
		statusToSearch.add(BR_ACTIVE);
		statusToSearch.add(BR_PENDING);
	elseif _statusStr = BR_PENDING_STRING then
		statusToSearch.add(BR_PENDING);
	elseif _statusStr = BR_COMPLETE_STRING then
		statusToSearch.add(BR_COMPLETE);
	elseif _statusStr = BR_ARCHIVE_STRING then 
	   statusToSearch.add(BR_ARCHIVE);
	elseif _statusStr = BR_ACTIVE_STRING then
		statusToSearch.add(BR_ACTIVE);
	elseif _statusStr = 'All' then
		statusToSearch.add(BR_PENDING);
		statusToSearch.add(BR_ACTIVE);
		statusToSearch.add(BR_COMPLETE);
		statusToSearch.add(BR_ARCHIVE);
	else
		app.raiseUnexpectedProgramError(class.name, method.name, 'Unhandled bulk release status (' &amp; _statusStr &amp; ')');
		return;
	endif;

	_cmb.clear();
	_cmb.sorted := true;
	dict := self.myTerminal.allBulkReleaseByTypeByStByCd;
	iter := dict.createIterator();
	
	foreach type in typesToSearch do
		foreach searchStatus in statusToSearch do : searchStatusLoop
			dict.startKeyGeq(type, searchStatus, null, null, iter);
		
			while iter.next(bulkRelease) do
				iter.getCurrentKeys(typeKey, statusKey, codeKey, requestDateKey);  //MTN-35226
				if type &lt;&gt; null then
					if (type &lt;&gt; typeKey) or (searchStatus &lt;&gt; statusKey) then
						continue searchStatusLoop;
					endif;
				endif;
				
				//_cmb.itemObject[_cmb.addItem(codeKey &amp; Tab &amp; requestDateKey.date.shortFormatJMT())] := bulkRelease;	//07.06.2022 navsrk20 TFS 52720
				_cmb.itemObject[_cmb.addItem(codeKey &amp; Space &amp; requestDateKey.date.shortFormatJMT() &amp; Space &amp; '(' &amp; bulkRelease.getTypeDescription &amp; ')')] := bulkRelease;	//07.06.2022 navsrk20 TFS 52720
				if bulkRelease = _release then
					tmpFound := true;
				endif;
			endwhile;
		endforeach;
	endforeach;
	
	
	if tmpFound then
		_cmb.text := _release.code &amp; Tab &amp; _release.dateRequested.date.shortFormatJMT();	//self.displayEntryBulkRelease(_release);
		_cmb.listObject := _release;
	endif;
	
epilog
	delete typesToSearch;
	delete statusToSearch;
	delete iter;
end;</source>
        <Parameter name="_cmb" type="ComboBox" usage="input"/>
        <Parameter name="_typeStr" type="String"/>
        <Parameter name="_statusStr" type="String"/>
        <Parameter name="_release" type="CM_BulkRelease"/>
    </JadeMethod>
    <JadeMethod name="comboBoxBulkRelFilterBooking" id="414123e4-8f26-4ca8-a569-2693b7f04c93">
        <source>comboBoxBulkRelFilterBooking(_comboboxObj: CMUI_ComboBox input; _status: Integer);
/* ---------------------------------------------------------------------------
Created:	07 September 2009	by cnwvu1

Purpose:	Populates Bulk Release searcher filtering by bookin:
			All				(all bulk releases)
			With Booking	(bulk releases with associated bookings)
			Without Booking	(bulk releases without bookings)
   
Change Date		Who		Reason

------------------------------------------------------------------------------*/
vars

begin

	_comboboxObj.cnEcAddItemDataObject(app.getErrorString(CM_LIT_ALL), FilterBooking_All, null);
	_comboboxObj.cnEcAddItemDataObject(app.getErrorString(WITH_BOOKING), FilterBooking_With, null);
	_comboboxObj.cnEcAddItemDataObject(app.getErrorString(WITHOUT_BOOKING), FilterBooking_Without, null);

	_comboboxObj.cnEcSetItemData(_status);

end;</source>
        <Parameter name="_comboboxObj" type="CMUI_ComboBox" usage="input"/>
        <Parameter name="_status" type="Integer"/>
    </JadeMethod>
