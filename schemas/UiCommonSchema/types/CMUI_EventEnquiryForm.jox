        <source>getXMLSettingsForSave(): String updating;
/*
----------   ----------  --------------------------------------------------
Created:	11 July 2007 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	block			: String;

begin
	
	
	block := inheritMethod();
	block := block &amp; self.xmlGetSearchCriteria();
	
	return block;
	
end;

</source>
        <ReturnType type="String"/>
