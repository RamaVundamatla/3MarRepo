    <JadeMethod name="updateJobDisplay" id="4a784971-8ff7-40e0-91dd-87d5a858a482">
        <source>updateJobDisplay(_tbl : CM_DataTable) protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
15 Feb 2011	cnwer1	Initial creation
16 oct 2012	PJS		PAR # 30438
28 Nov 2018	cnwma1	ChangeRequest 42141: PEL1 - Allow changing transfer type for ISO Containers
19 Jul 2022 navkc1	Bug 54130: CUX - 1090 Error in Job Operations with Ship Release
*/

vars
	job 			: CM_VoyageJob;
	str  			: String;
	label 			: CMUI_Label;
	displayString	: String;
	transferType    : String;
	voyJobTransferType : CM_VoyageJobTransferType;
begin
	job := _tbl.userObject.CM_VoyageJob;

	if job = null then
		return;
	endif;	
	
	//30438 - determine if its a crane or workpoint
	if job.isWorkPointJob then
		displayString := app.getErrorString(Work_point);
	else
		displayString := app.getErrorString(CM_Crane_GC);
	endif;
		
	//transferType := app.myRoot.allVoyageJobTransferTypes[job.transferType].CM_VoyageJobTransferType.description;	// navkc1	#54130	19/07/2022
	voyJobTransferType := app.myRoot.allVoyageJobTransferTypes[job.transferType].CM_VoyageJobTransferType;	// navkc1	#54130	19/07/2022
	
	if voyJobTransferType &lt;&gt; null then	// navkc1	#54130	19/07/2022
		transferType := voyJobTransferType.description;	// navkc1	#54130	19/07/2022
	endif;	// navkc1	#54130	19/07/2022
	
	//str := job.jobId &amp; " " &amp; job.jobTypeId &amp; " " &amp; job.statusString &amp; ', ' &amp; displayString &amp; " " &amp; job.craneId;                     //22.11.2018 cnwma1 TFS #42141
	str := job.jobId &amp; " " &amp; job.jobTypeId &amp; " " &amp; job.statusString &amp; ', ' &amp; displayString &amp; " " &amp; job.craneId &amp; ', ' &amp; transferType; //22.11.2018 cnwma1 TFS #42141
	label := self.getChildControlByName(_tbl.parent.CMUI_Frame, self.lblJobTable.name).CMUI_Label;
	label.caption := str;
	
	if job.isDischarge then
		// Green for landing a shore
		label.foreColor := Green;									
	else
		// Blue for going to sea
		label.foreColor := Blue;					
	endif;	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_tbl" type="CM_DataTable"/>
    </JadeMethod>
    <JadeMethod name="updateTIWle" id="25270197-59cb-4d52-b9f3-05ced89cb785">
        <updating/>
        <source>updateTIWle(_ti : CM_TrackedItem) updating;
//--------------------------------------------------
// Created:	12 January 2004 By: cnwgd1
//--------------------------------------------------
// 16 May 2016	cnwns1	TFS 488 - Multi Timezone Support
vars
	wle : CM_WorkListEntry;
	breakOut : Boolean;
begin
	endLoad;
	beginLoad;
	if (not self.allNotableTIs.includes(_ti)) then
		return;
	endif;

	self.tblWLESaveSelected();
	
	foreach wle in _ti.allWorklistEntries do
		if (not CM_VoyageWLE.hasInstance(wle)) then
			continue;
		endif;
		self.doNotificationStorage(wle, self.Mode_Update);
		if breakOut then
			// found
			break;
		endif;
	endforeach;

epilog
	endLoad;
	self.lastNote := app.actualTimeServer.time; // PAR 9401// 16 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	app.mousePointer := MousePointer_Default;			
end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="updateVoyageJob" id="39a2b5f3-a8c8-488a-ba48-2907472761cf">
        <updating/>
        <source>updateVoyageJob(_voyageJob : CM_VoyageJob; _event : Integer; _refreshTable : Boolean)updating;
//-----------------------------------------
// Created: January 2004 By: cnwgd1
// 24/02/2024 	navcs2 	MTN-29368 EUP | Transaction Instrumentation - Voyage Discharge
// 14 Jan 2026 	navhl20 Bug MTN-35897: PEN - System Locking Errors (1000010 - Unknown message)
//-----------------------------------------
vars
	shtIdx,
	jobIdx,
	idx,
	jobLvl,
	pos			: Integer;
	expanded 	: Boolean;
	tmpJob		: CM_Job;
begin
	if (not CM_VoyageJob.hasInstance(_voyageJob)) then
		return;
	endif;
	//navsp1 21 FEB 2022 TFS#52896
	if self.myCurrentVoyage = null then
		self.myCurrentVoyage := cmbVoyage.listObject.CM_Voyage;
	endif;
	
	if  not _voyageJob.myVoyage = self.myCurrentVoyage then // PAR 36296
		return; // PAR 36296
	endif; // PAR 36296
	
	if _voyageJob.isVoyageROROJob then // PAR 36296
		return; // PAR 36296
	endif; // PAR 36296
	
	if (not _voyageJob.isLoadedToOperations)
    or (hideCompletedJobs and _voyageJob.status = JOB_COMPLETE) then
		idx := self.lstJobs.findObject(_voyageJob);
		if idx &gt; 0 then
			self.lstJobs.clearBelowLevel(idx);
			self.lstJobs.removeItem(idx);
		endif;
		self.tblWLEUpdateJob(_voyageJob, self.Mode_Update);
		return;
	endif;
	
	if _event = VoyageJob_Create_Event then
		if _voyageJob.myVoyageJobSheet &lt;&gt; null then
			idx := self.lstJobs.findObject(_voyageJob.myVoyageJobSheet);	
			if idx &gt; 0 then
				jobLvl := lstJobs.itemLevel[idx];
				expanded :=	self.lstJobs.itemExpanded[jobLvl];										
				jobLvl := jobLvl+1;
				idx := idx + _voyageJob.myVoyageJobSheet.getJobOperationsPosition(_voyageJob);
				self.lstJobsUpdateJob(_voyageJob, Mode_Add, idx, jobLvl, expanded);
			else//Crane not allocated to voyage epr par 30498 not sure how to reproduce 
				self.doRefresh();
			endif;
		else
			self.lstJobsSetBelowVoyUnallocated(_voyageJob.myVoyage);
		endif;
		return;
	endif;

	//Should be an update then					
	if _event = VoyageJob_Update_Event then
	
		// Par 14066
		if _refreshTable then
			self.tblWLEUpdateJob(_voyageJob, self.Mode_Update);
		endif;

		jobIdx := self.lstJobs.findObject(_voyageJob);
		if jobIdx &gt; 0 then	
		
			// Par 13968
			if self.lstJobs.itemData[jobIdx] = _voyageJob.status then
				return;
			endif;
			
			self.lstJobs.removeItem(jobIdx);
		endif;
		
		//job may not have been allocated
		if _voyageJob.myVoyageJobSheet &lt;&gt; null then
			// Add to job sheet
			shtIdx := self.lstJobs.findObject(_voyageJob.myVoyageJobSheet);
			if shtIdx &gt; 0 then
				jobLvl := lstJobs.itemLevel[shtIdx];
				expanded :=	self.lstJobs.itemExpanded[jobLvl];										
				jobLvl := jobLvl+1;
				if jobIdx &lt; 1 then //job not found
					//jobIdx := shtIdx+1;
					// DVB added to find the correct place to put job back into order
					pos := _voyageJob.myVoyageJobSheet.getJobOperationsPosition(_voyageJob);
					jobIdx := shtIdx + pos;
				endif;
				//We have already removed it so mode should be add														
				self.lstJobsUpdateJob(_voyageJob, Mode_Add, jobIdx, jobLvl, expanded);
			else //Crane not allocated to voyage
				self.doRefresh();
				return;
			endif;				
		else //Job not allocated to crane
			self.lstJobsSetBelowVoyUnallocated(_voyageJob.myVoyage);		
		endif;

		idx := self.lstJobs.findObject(self.myCurrentJobSheet);
		if idx &lt; 0 then //job may be unassigned
			idx := self.lstJobs.findObject(self.myCurrentVoyage);
		endif;
		if idx &lt; 0 then
			self.lstJobs.itemExpanded[1] := true;				
		endif;
		
	endif;
epilog
	
end;</source>
        <Parameter name="_voyageJob" type="CM_VoyageJob"/>
        <Parameter name="_event" type="Integer"/>
        <Parameter name="_refreshTable" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="updateWLEForTable" id="1b9368cc-8176-4a0d-bc68-0d4c653fbe35">
        <source>updateWLEForTable(_tbl : CM_DataTable input; _wle : CM_WorkListEntry) : Integer protected;

// Created by cnwdvb1 on 26 February 2007

vars
	str 	: String;
	rowIdx	: Integer;

begin
	if not _tbl.findObjectInRow(_wle, rowIdx) then
		return 0;
	endif;
	
	str := self.displayRowForDataTable(_wle, _tbl);
	
	_tbl.accessCell(rowIdx, 1).text := str;
	
	// note has updated the wle lets update the job  display because the job status could of been updated
	self.updateJobDisplay(_tbl);
	
	
	
	return rowIdx;
end;</source>
        <access>protected</access>
        <Parameter name="_tbl" type="CM_DataTable" usage="input"/>
        <Parameter name="_wle" type="CM_WorkListEntry"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="updateWLEStillHasWarnings" id="d4807330-d700-4b77-b45e-4b8895d63250">
        <source>updateWLEStillHasWarnings(_table	: CM_DataTable);
// ---------------------------------------------------------------------------
// Created:		February 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	rtCol,rowst,rowend,rowIdx : Integer;
	table	: CM_DataTable;
	job 	: CM_VoyageJob;
	theWLE : CM_WorkListEntry;
	invalidObj : Boolean;
begin

	table := _table; //self.getWLETableForObject(_wle, rowIdx);
	// not displayed
	if table = null then
		return;
	endif;
	
	on Exception do app.handleDeletedObject( exception, table, invalidObj );	//05 Feb 2013	NDL	Par 31102
	
	rowst := table.fixedRows + 1;
	
	//05 Feb 2013	NDL	Par 31102
	if invalidObj then
		return;
	endif;
	
	rowend := table.rows;
	rtCol := table.getColumnByRowName(ETRow_RadioTelemetry);			
				
	foreach rowIdx in rowst to rowend do
		if table.accessRow(rowIdx).backColor = Red then
			
			theWLE := table.accessedRow.itemObject.CM_WorkListEntry;
			if theWLE.status = WLE_COMPLETED then
				continue;
			endif;

			self.tblWLESetRowColour(table, theWLE, rowIdx, rtCol);
		
		endif;
		
	endforeach;

end;</source>
        <Parameter name="_table" type="CM_DataTable"/>
    </JadeMethod>
    <JadeMethod name="userNotify" id="ad7098af-aef1-4ae7-8efc-b5b7e6901d35">
        <controlMethod name="Form::userNotify"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>userNotify(eventType: Integer; theObject: Object; eventTag: Integer; userInfo: Any) updating;
