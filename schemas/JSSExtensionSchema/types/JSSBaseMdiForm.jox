    <JadeMethod name="statusMsg" id="2e61f9fb-af9f-4191-bfd2-0ec89674ed36">
        <source>statusMsg(pMessage:String);
// --------------------------------------------------------------------------------
// Created:		18 January 2003 by cnwdad1
//
// Purpose:		Use this method in the "select" event method of a menu property to
//				display a message in the status bar of the MDI frame.
//
// Parameters:	pMessage - The message to display in the caption bar.
//				pClosed - The boolean flag from the menu's "select" event method.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if pMessage = null then
		staStatus.caption	:=	self.CAPTION_READY;
	else
		staStatus.caption	:=	" " &amp; pMessage;
	endif;
end;</source>
        <Parameter name="pMessage" type="String"/>
    </JadeMethod>
</GUIClass>
