    <JadeMethod name="displayPropData" id="3703a4f1-f559-4e8e-8f75-e5cefd5bf903">
        <updating/>
        <source>displayPropData() updating;
// ---------------------------------------------------------------------------
// Created:     20 January 2005	cnwhjg1
//
// Purpose:     
// ----------   ----------  --------------------------------------------------
vars
	theLabel 	:	CMUI_Label;
	theTable	:	CM_EntryTable;
	theYear		:	Integer;
	calendar	:	CM_Calendar;
	date		:	CM_CalendarDate;
	year		:	CM_CalendarYear;
begin
	theLabel	:= self.lblHeading;
	theTable	:= self.tblCalendar;
	date		:= self.myCurrentDate;	
	year		:= self.myCurrentYear;
	calendar	:= self.myCurrentCalendar;
		
	if self.updateMode = self.UpdateMode_New then
		theTable.clearValues(); 		
		if self.modePropertyNew = self.MODEPROPERTY_CALENDAR then
			theLabel.caption := 'Create New Calendar';
//			theTable.enableRowByName(ETRow_Code);
		elseif self.modePropertyNew = self.MODEPROPERTY_YEAR then
			theLabel.caption := 'Create New Year for Calendar ' &amp; calendar.code;
//			theTable.enableRowByName(ETRow_Year);		
		elseif self.modePropertyNew = self.MODEPROPERTY_DATE then 
			theLabel.caption := 'Create New Date for ' &amp; calendar.code &amp; ' - ' &amp; self.myCurrentYear.year.String;
//			theTable.setValueByName(ETRow_Code, self.myCurrentCalendar.code);	
			theTable.enableRowByName(ETRow_DescriptionDate);
			theTable.enableRowByName(ETRow_Date);
			self.setDate();
			
//			theTable.disableRowByName(ETRow_Code);
		endif;	
	elseif self.updateMode = self.UpdateMode_Update then
		if self.modePropertyNew = self.MODEPROPERTY_CALENDAR then 
			theLabel.caption := 'Edit Calendar ' &amp; calendar.code;			
			theTable.setValueByName(ETRow_DescriptionCalendar, calendar.description);
			theTable.setValueByName(ETRow_Code, calendar.code);	
//			theTable.enableRowByName(ETRow_Code);	
		elseif self.modePropertyNew = self.MODEPROPERTY_YEAR then 
			theLabel.caption := 'Edit Year ' &amp; self.myCurrentYear.year.String &amp; Cr &amp; Cr &amp; 'This will also change the year of the dates within this Year';
			theTable.setValueByName(ETRow_Year, self.myCurrentYear.year);
		elseif self.modePropertyNew = self.MODEPROPERTY_DATE then 
			theLabel.caption := 'Edit Date ' &amp; self.myCurrentDate.date.String;
			theTable.setValueByName(ETRow_Date, self.myCurrentDate.date);
			theTable.setValueByName(ETRow_DescriptionDate, self.myCurrentDate.description);
			theTable.enableRowByName(ETRow_DescriptionDate);
			theTable.enableRowByName(ETRow_Date);
			theTable.setValueByControlName(ETRow_Date, self.myCurrentDate.date);  
//			theTable.disableRowByName(ETRow_Code);
		endif;
	endif;		
end;</source>
    </JadeMethod>
    <JadeMethod name="displayPropDataCopy" id="30f13a07-403b-4389-812a-c3abab3a60c8">
        <source>displayPropDataCopy();
// ---------------------------------------------------------------------------
// Created:     26 January 2005	cnwhjg1
//
// Purpose:     
// ----------   ----------  --------------------------------------------------
vars

begin
		
		
	
		if self.modePropertyNew = self.MODEPROPERTY_DATE then 
			self.lblHeading.caption := 'Copy date : ' &amp; self.myCurrentDate.date.String;
			self.tblCalendar.setValueByName(ETRow_Date, self.myCurrentDate.date);
			self.tblCalendar.setValueByName(ETRow_DescriptionDate, self.myCurrentDate.description);
//			self.tblCalendar.setValueByName(ETRow_YearCombo, self.myCurrentYear.year);
//			self.tblProperties.setValueByName(ETRow_CalendarCode, self.myCurrentCalendar.code);
			self.tblCalendar.disableRowByName(ETRow_Date);
			self.tblCalendar.disableRowByName(ETRow_DescriptionDate);
		elseif self.modePropertyNew = self.MODEPROPERTY_YEAR then 
			self.lblHeading.caption := 'Copy year : ' &amp; self.myCurrentYear.year.String;
			
		elseif self.modePropertyNew = self.MODEPROPERTY_CALENDAR then
			self.lblHeading.caption := 'Create new Calendar from: ' &amp; self.myCurrentCalendar.code;	
			self.tblCalendar.clearValues();	
//			self.tblCalendar.setValueByName(ETRow_DescriptionCalendar, self.myCurrentCalendar.description);
//			self.tblCalendar.setValueByName(ETRow_Code, self.myCurrentCalendar.code);	
//			self.tblCalendar.enableRowByName(ETRow_Code);	
		endif;
		
		
end;</source>
    </JadeMethod>
    <JadeMethod name="doBtnCopyClick" id="16567b36-7d3f-4861-972d-7e67b1554e38">
        <updating/>
        <source>doBtnCopyClick()updating;
// ---------------------------------------------------------------------------
// Created:     25 January 2005	cnwhjg1
//
// Purpose:     
// ----------   ----------  --------------------------------------------------
vars
	entVeiw : String;
begin
	
	if self.lstData.listIndex &lt; 0 then
		global.beep;
		app.msgBox("Please select a Calendar, Year or Date to copy","Copy Error",MsgBox_OK_Only);
		return;
	endif;

	self.setUpdateMode(self.UpdateMode_Copy);
	if self.myCurrentDate &lt;&gt; null then
		self.modePropertyNew := self.MODEPROPERTY_DATE;
		entVeiw := 'CalendarDateCopy';
		self.cmbYear.myCalendar := self.myCurrentCalendar;
//		self.cmbCalendarCode.setObject(self.myCurrentCalendar);
//		self.tblProperties.setValueByName(ETRow_CalendarCode, self.myCurrentCalendar.code);		
	elseif self.myCurrentYear &lt;&gt; null then 
		self.modePropertyNew := self.MODEPROPERTY_YEAR;
		entVeiw := 'CalendarYearCopy';
	elseif self.myCurrentCalendar &lt;&gt; null then
		self.modePropertyNew := self.MODEPROPERTY_CALENDAR;
		entVeiw := 'CalendarEntry';		
	else
		global.beep;
		app.msgBox("Please select a Calendar, Year or Date to copy","Copy Error",MsgBox_OK_Only);
		return;
	endif;
	
	self.showPropertyFrame(entVeiw, null,PROPHEIGHT);
end;</source>
    </JadeMethod>
    <JadeMethod name="doBtnDeleteClick" id="a24d207f-942e-45b9-8deb-58dc29ecc526">
