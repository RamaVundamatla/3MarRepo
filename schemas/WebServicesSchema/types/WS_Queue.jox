<Class name="WS_Queue" id="54ccc62d-aa12-49b6-8f00-c633ffd9f298">
    <superclass name="WS_ProxyObject"/>
    <transient/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <PrimAttribute name="availableEntries" id="ac17fb04-7a91-42d4-9e58-09c823ae1853">
        <embedded/>
        <type name="Integer"/>
        <text>Number of work list entries in this queue, including completed entries</text>
    </PrimAttribute>
    <PrimAttribute name="availableMachines" id="15896a78-95dc-48b8-9e19-df711bc2ab5a">
        <embedded/>
        <type name="Integer"/>
        <text>Number of machines currently assigned to this queue</text>
    </PrimAttribute>
    <PrimAttribute name="id" id="b60d773d-df2f-496a-b63a-6b5119ac3857">
        <length>51</length>
        <embedded/>
        <type name="String"/>
    </PrimAttribute>
    <PrimAttribute name="unactionedEntries" id="c4278c69-c389-4100-99bf-81d5921b154c">
        <embedded/>
        <type name="Integer"/>
        <text>Number of items in this queue that are unactioned</text>
    </PrimAttribute>
    <JadeMethod name="setProxyFromObject" id="8e29b087-82b4-4fcf-a37c-458798f6c47f">
        <updating/>
        <source>setProxyFromObject(_object: CM_RadioTelemetryQueue) updating;
/*

Date		Who		Reason
07 Jun 2017	cnwer1	Initial creation TFS 4624
05/07/2021	navdap1	TFS 51409 PNL Queued Jobs in Driver Mode
*/

vars

begin
	inheritMethod(_object);
	self.id :=_object.id;
	self.availableEntries :=_object.allEntries.size;
	self.availableMachines:=_object.allMachines.size;
	self.unactionedEntries:=_object.getNumUnactionedEntries();		// TFS 51409
epilog

end;</source>
        <Parameter name="_object" type="CM_RadioTelemetryQueue"/>
    </JadeMethod>
</Class>
