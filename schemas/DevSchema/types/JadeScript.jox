    <JadeMethod name="rh_testLocale" id="e1d67359-64c4-491b-af90-7739996da467">
        <source>rh_testLocale();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 March 2018	jlgrh7	Initial creation

*/
constants
	JMTDecimalSeperator = ".";
vars
	thousandSeparator : String;
	decimalSeperator : String;
	strValue : String;
	localeFormat :String;
	deciValue : Decimal[10,4];
	intValue  : Integer;
begin
		//thousandSeparator	:=	app.getMyLocaleInfoJMT().numericInfo.thousandSeparator;
		thousandSeparator	:=	".";
		//decimalSeperator	:=	app.getMyLocaleInfoJMT().numericInfo.decimalSeparator;
		decimalSeperator	:=	",";
		//strValue := "7575";
		strValue:= app.convertMeasurementForStorage("kg/m3",7575).asStringJMT;
		write "strValue from app.convertMeasurementForStorage is &gt;&gt;" &amp; strValue;
		localeFormat := strValue;
		localeFormat.replaceChar(".",decimalSeperator.Character);
		strValue := localeFormat;
		write "str Value is &gt;&gt;" &amp; strValue;
		strValue.replaceChar(thousandSeparator.Character, " ");
		write "strValue replaceChar thousandSeparator is &gt;&gt; " &amp; strValue;
		strValue:=strValue.cnEcRemoveSubstring(" ");
		write "strValue cnEcRemoveSubstring SPACE is &gt;&gt; " &amp; strValue;
		strValue.replaceChar(decimalSeperator.Character, JMTDecimalSeperator);
		write "strValue.replaceChar decimalSeperator is &gt;&gt;" &amp; strValue;
		intValue := strValue.Integer;
		write "fianl decivalue is &gt;&gt;" &amp; intValue.String;
		write intValue;
epilog

end;</source>
    </JadeMethod>
