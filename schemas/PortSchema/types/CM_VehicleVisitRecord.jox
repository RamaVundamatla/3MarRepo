    <JadeMethod name="hasManualWeightEntry" id="a8810063-9802-4218-80e2-de47c31142eb">
        <source>hasManualWeightEntry():Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 February 2021	jlgndl1	Initial creation	TFS 50152

*/

vars

	vvrd : CM_VehicleVisitRecordDetail;
	str : String;

begin

	foreach vvrd in self.allVehicleVisitRecordDetails where ( vvrd.recordType = VisitRecord_Bulk_In or vvrd.recordType = VisitRecord_Bulk_Out ) do
		if vvrd.getExtraInfo_BulkGateModified(str) then
			return true;
		endif;
	endforeach;
	
	return false;

epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="hasMap" id="f6f7d200-d605-421a-9d27-910d096619ef">
        <source>hasMap(): Boolean;
/*
Purpose - 	
Who - NAVAB1
Date - 28DEC2023
ADO -  CR 58499 TASK 61455
*/

vars
	ti : CM_TrackedItem;
	lc : CM_LocationsController;
	ica : CM_InterchangeArea;
	ta : CM_TerminalArea;
	photo : CM_Photo;
	job : CM_Job;
	terminal : CM_Terminal;
	height : Integer;
begin

	job := self.myRoadJob;
	if job = null then
		return null;
	endif;
	
	//lc := job.getFirstLocationByRequest();
	//26/08/2024	navkc1 CR 63588 Task 63589
	terminal := self.getMyTerminal();
	if terminal &lt;&gt; null then
		terminal.findLocationFromString(job.plannedLocation, true, lc, height);
	endif;
	if lc &lt;&gt; null then
		ta := lc.getInterChangeArea();
		if ta = null then
			ta := lc.myTerminalArea;
		endif;
	endif;
	
	if ta &lt;&gt; null then
		return ta.hasPhotos();
	endif;
	
	return false;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
