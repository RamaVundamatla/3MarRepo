    <JadeMethod name="cloneReferences" id="67968fbb-ce52-4b3b-bf23-ba144d0ddc74">
        <updating/>
        <source>cloneReferences(_obj: CMQF_VehicleBookingReport; _transient: Boolean) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 February 2018	jlgndl1	Initial creation	TFS 37184
25/05/2022 			navhl20 TFS 53430  EUP - Sub Carrier registration in MTN
*/

vars

begin
	inheritMethod(_obj, _transient);
	
	self.setMyCarrier( _obj.myCarrier );
	self.setMySubCarrier( _obj.mySubCarrier );			//25/05/2022 navhl20 TFS 53430 
	self.setMyDriver( _obj.myDriver );
	self.setMyVehicle( _obj.myVehicle );

epilog

end;</source>
        <Parameter name="_obj" type="CMQF_VehicleBookingReport"/>
        <Parameter name="_transient" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="filterObjects" id="bbecfa14-d29c-4f10-8a77-a4b0ba9b7cf5">
        <updating/>
        <source>filterObjects(_collection: Collection input; _passport: CM_Passport) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 April 2013	cnwndl1	Initial creation
// 16 May 2016	cnwns1	TFS 488 - Multi Timezone Support
24 May 2023 	navhl20 ChangeRequest 53902:[57781] EUP - VBS MTN - [6] - Selector Query and JRW
28 Aug 2023 	navhl20 Bug 60056: FR | 53429 - VBS Selector issues
*/

vars

	terminal : CM_Terminal;
	vssTerm : CM_VehicleBookingTerminal;
	iter : Iterator;
	startTimeStamp : TimeStamp;
	startAtObject : CM_VehicleBookingTimeSlot;
	slot : CM_VehicleBookingTimeSlot;
	endTimeStamp : TimeStamp;

begin

	if self.dateFrom = null then
		//user has enter nothing for the dateFrom
		self.dateFrom.setDate(01,01,2013);
	endif;
	if self.dateTo = null then
		//user has enter nothing for the dateTo
		self.dateTo := app.actualTimeServer.Date;// 16 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	endif;
	
	if not app.isVehicleBookingEnabled then
		return;
	endif;
	
	startTimeStamp.setDate( self.dateFrom );
	startTimeStamp.setTime( "00.00".Time );
	
	endTimeStamp.setDate( self.dateTo );
	endTimeStamp.setTime( "23.59".Time );
	
	foreach terminal in self.allTerminals do
		if not terminal.isVehicleBookingEnabled then
			continue;
		endif;
		vssTerm := terminal.myVehicleBookingTerminal;
		if vssTerm = null or vssTerm.allBookingsByTS.isEmpty then
			continue;
		endif;
		
		delete iter;
		iter := vssTerm.allBookingsByTS.createIterator;
		startAtObject := vssTerm.allBookingsByTS.getAtKeyGeq(startTimeStamp,null);
		if startAtObject &lt;&gt; null then
			iter.startAtObject( startAtObject );
			while iter.next( slot ) do
				if slot.bookingTSstart &gt; endTimeStamp then
					break;
				endif;
				
				if slot.isUnBookedTimeslot then
					if self.inclUnBooked then
						_collection.add( slot );
					endif;
					continue;		
				endif;
				
				if self.getMyCarrier &lt;&gt; null then
					if slot.myCarrier &lt;&gt; self.getMyCarrier then
						continue;
					endif;
				endif;
		/*		if self.myDriver &lt;&gt; null then
					if slot.myDriver &lt;&gt; self.myDriver then
						continue;
					endif;
				endif;
				if self.myVehicle &lt;&gt; null then
					if slot.myVehicle &lt;&gt; self.myVehicle then
						continue;
					endif;
				endif; */
				
				/*
				//28.8.2023 navhl20 #60056
				if self.status &lt;&gt; null and slot.getStatusInteger &lt;&gt;	self.status then												//24.5.2023 navhl20 #53902[57781]
					continue;
				endif;*/
				if self.allVBSStatus.isNotEmpty() and not self.allVBSStatus.includes(slot.getStatusInteger()) then					//28.8.2023 navhl20 #60056
					continue;
				endif;
				if self.allVBSTimeSlotTypes.isNotEmpty() and not self.allVBSTimeSlotTypes.includes(slot.myVBTimeSlotType) then		//28.8.2023 navhl20 #60056
					continue;
				endif;
				if self.externalReference &lt;&gt; null and slot.externalReference &lt;&gt;	self.externalReference then							//24.5.2023 navhl20 #53902[57781]
					continue;
				endif;
				if self.bookingId &lt;&gt; null and slot.getBookingRefIdsAsString.pos(self.bookingId,1) &lt; 1 then							//24.5.2023 navhl20 #53902[57781]
					continue;
				endif;
				if self.mySubCarrier &lt;&gt; null and slot.mySubCarrier &lt;&gt; self.mySubCarrier then										//24.5.2023 navhl20 #53902[57781]
					continue;
				endif;
				if self.kioskCheck and not slot.kioskCheck then																		//24.5.2023 navhl20 #53902[57781]
					continue;
				endif;
				if self.preGateInCheck and not slot.preGateInCheck then																//24.5.2023 navhl20 #53902[57781]
					continue;
				endif;
				if self.preGateOutCheck and not slot.preGateOutCheck then															//24.5.2023 navhl20 #53902[57781]
					continue;
				endif;
				if self.includeDelivery and not slot.includesDelivery then															//24.5.2023 navhl20 #53902[57781]
					continue;
				endif;
				if self.includePickup and not slot.includesPickUp then																//24.5.2023 navhl20 #53902[57781]
					continue;
				endif;
				if self.remarks &lt;&gt; null and slot.remarks &lt;&gt;	self.remarks then														//24.5.2023 navhl20 #53902[57781]
					continue;
				endif;
				if self.id &lt;&gt; null and slot.id &lt;&gt;	self.id then																	//24.5.2023 navhl20 #53902[57781]
					continue;
				endif;
				if self.bulkReleaseId &lt;&gt; null and slot.getReleaseIdsAsString.pos(self.bulkReleaseId,1) &lt; 1 then						//24.5.2023 navhl20 #53902[57781]
					continue;
				endif;
				if self.vehicleVisitRecordNumber &lt;&gt; null and slot.getVehicleVisitNumber() &lt;&gt; self.vehicleVisitRecordNumber then		//24.5.2023 navhl20 #53902[57781]
					continue;
				endif;
				if self.cargoId &lt;&gt; null and not slot.allTiIds.includes(self.cargoId) then											//24.5.2023 navhl20 #53902[57781]
					continue;
				endif;
				
				_collection.add( slot );
				
			endwhile;
		endif;
		
	endforeach;

epilog

	delete iter;
	
end;</source>
        <Parameter name="_collection" type="Collection" usage="input"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
