    <JadeMethod name="doTblDataMouseDown" id="de98e933-f347-4747-a299-49cba1f0700e">
        <updating/>
        <source>doTblDataMouseDown(table: Table input; button: Integer; shift: Integer; x: Real; y: Real) updating;
//----------------------------------------------------------------
//	Created:	20 January 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin
	inheritMethod(table, button, shift, x, y);
	self.origXPos := x;
	self.origYPos := y;

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="doTblDataMouseMove" id="79981a4d-e86c-4239-b511-406167eed4d8">
        <updating/>
        <source>doTblDataMouseMove(table: Table input; button: Integer; shift: Integer; x: Real; y: Real) updating;
// ---------------------------------------------------------------------------
// Created:		June 2003 By Andrew Bishop cnwab1
//
// Purpose:		
// ---------------------------------------------------------------------------
vars

	gridPoint	: CMUI_GridPoint;
	theTI		: CM_TrackedItem;
	root : CM_Root;
	lPicture : Picture;
	moveController : CMIF_MoveController;
begin

	//if self.mode &lt;&gt; self.Mode_SummarySelection then	//25 Jan 2012	NDL	Par 25297
		self.tblData.mouseMoveForDragSelect(table, button, shift, x, y);
	//endif;

	if self.tblData.row &lt;= self.tblData.fixedRows 
	or y &lt;= table.accessRow(self.tblData.fixedRows).height then 
		self.origXPos := x;
		self.origYPos := y;
		return;
	endif;
	
	if button = Window.MouseButton_Left 
	and	app.dragDetected(x, y, self.origXPos, self.origYPos) 
	and self.origYPos &gt; 20  // ###  may be doing a column resize!
	and not shift.isControlKeyPressed()
	and not shift.isShiftKeyPressed()
	and not shift.isAltKeyPressed() then
		theTI := self.tblData.accessRow(self.tblData.row).itemObject.CM_TrackedItem;
		if theTI &lt;&gt; null then
			app.myDraggedTrackedItem := theTI;
			create moveController transient;
			
			moveController.setMyTrackedItem(theTI);
			delete app.myMoveController;
			app.myMoveController := moveController;
			app.isDragging := true;
			moveController.setMyOriginatingLocation(theTI.getPrimaryLocation(REAL_MODE));
			self.moveModeForm := PLANNING_MODE;
			moveController.setMoveMode(PLANNING_MODE);	
			table.dragMode := DragMode_Drag;
			root := app.myRoot;

			create lPicture transient;
			self.setPictureDragCursor(lPicture);
			if lPicture.picture &lt;&gt; null then
				table.dragCursor := lPicture.picture;
			endif;

		endif;
	else
		//do we really need to do this on a mouse move?   Mouse up is enough
		//self.frmStatLine.caption := self.statusStub &amp; " " &amp; $SHP_Selected &amp; self.tblData.allSelectedObjects.size.asStringJMT;
	endif;
epilog
	if lPicture &lt;&gt; null then
		delete lPicture;
	endif;
	

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="doTblDataMouseUp" id="b798c29c-64e0-4ff9-99dc-c1feceae2b0d">
        <updating/>
        <source>doTblDataMouseUp(table: Table input) updating;
// ---------------------------------------------------------------------------
// Created:		26 July 2005  By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

begin
	inheritMethod(table);
	self.frmStatLine.caption := self.statusStub &amp; " " &amp; app.getErrorString(SHP_Selected) &amp; self.tblData.allSelectedObjects.size.asStringJMT;
	self.btnSelectAllTIs.bubbleHelp := app.getErrorString(SelectAll);
	self.mnuContextSelectAll.caption := app.getErrorString(SelectAll);
	

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doTblDataRenumberItems" id="fdd6284f-a189-41ed-b6ff-54e6006cd738">
        <updating/>
        <source>doTblDataRenumberItems(_table :CM_DataTable input; _fromRow : Integer) updating;
// ---------------------------------------------------------------------------
// Created:		June 2003 By Andrew Bishop cnwab1
//
// Purpose:		
// ---------------------------------------------------------------------------
vars
	tmpFixedRows,
	idx,
	numZeros,
	startRow,
	endRow,
	col			: Integer;
begin
	col :=  _table.getColumnByRowName(ETRow_RowNumber); 
	
	if col = 0 then
		return;
	endif;

	tmpFixedRows := _table.fixedRows;
	if _fromRow &lt;= tmpFixedRows then
		startRow := tmpFixedRows + 1;
	else
		startRow := _fromRow;
	endif;
	endRow := _table.rows;
	numZeros := endRow.String.length;
	
	
	foreach idx in startRow to endRow do
		_table.accessCell(idx, col).text := (idx - tmpFixedRows).String.padLeadingZeros(numZeros);
	endforeach;

end;</source>
        <Parameter name="_table" type="CM_DataTable" usage="input"/>
        <Parameter name="_fromRow" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="doTblDataRowColChange" id="2743ce65-00e7-488a-b754-e070e807588a">
        <updating/>
        <source>doTblDataRowColChange(table: Table input) updating;
// ---------------------------------------------------------------------------
// Created:		December 2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin
	inheritMethod(table);

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doTblPlannedRowColumnChg" id="2bbb7995-8fe5-46ae-8a34-145fe5669e46">
        <updating/>
        <source>doTblPlannedRowColumnChg(table: Table input) updating;
// ---------------------------------------------------------------------------
// Created:		02 November 2005  By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	theTI : CM_TrackedItem;
	theVjob : CM_VoyageJob;
	theObject : Object;
	dataContainer : CM_DataContainer;
	theAttribs :	CMUI_GridAttributesArray;
	theAttrib : CMUI_GridAttributes;
begin
	self.doGetInfoTableData(self.tblPlanned,self.tblPlannedInfo);

return;




	self.mousePointer := Window.MousePointer_HourGlass;

	self.myCurrentTrackedItem := null;
	self.tblInfo.rows := 0;

	if table.row &lt;= table.fixedRows then
		return;
	endif;

	theObject := table.accessRow(table.row).itemObject;
	if (not global.isValidObject(theObject)) then
		return;
	endif;
	
	if CM_TrackedItem.hasInstance(theObject) then
		self.myCurrentTrackedItem := theObject.CM_TrackedItem;	
		if self.myCurrentTrackedItem &lt;&gt; null then
			self.btnLocate.enabled := self.myCurrentTrackedItem.myPrimaryActualLocation.isKindOf(CM_GridController);
		endif;
	elseif CM_WorkListEntry.hasInstance(theObject) then
		theObject := theObject.CM_WorkListEntry.myTrackedItem;
		self.myCurrentTrackedItem := theObject.CM_TrackedItem;
	endif;
	
	if useTableInfo then

		if self.mnuContextHide.caption = self.MNU_MACRO_SHOW // this means that the macro info is hidden
		and not app.isDragging then
		else

			create dataContainer transient;
			dataContainer.headerColour := self.colorHeadingColumn;
			dataContainer.valueColour := self.colorValueColumn;
			
			if theObject &lt;&gt; null and theObject.isKindOf(CM_Object) then
				theObject.CM_Object.getExtraInfo(dataContainer);
				self.tblInfo.userObject := theObject;
			endif;
			self.showExtraInformation(dataContainer, self.tblPlannedInfo, true, false, 4, 1, 1, 1, 1);
		endif;
	endif;
epilog
	delete dataContainer;
	delete theAttrib;
	delete theAttribs;
	self.mousePointer := Window.MousePointer_Default;


end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doTblSummaryDblClick" id="4ac56fa1-675b-4f83-b8f9-211658f29a48">
        <updating/>
        <source>doTblSummaryDblClick(_table: CM_DataTable input) updating;
//----------------------------------------------------------------
//	Created:	16 September 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	tbl				: CM_DataTable;
	tmpSumObj		: CMIF_LoadListSummaryObject;
	allSummariesObj	: CMIF_LoadListSummaryObjectSet;
//	sr				: CM_SlotRequest;
	str				: String;
	int,
	function	: Integer;
begin
	tbl := _table;
	tmpSumObj := tbl.accessRow(tbl.row).itemObject.CMIF_LoadListSummaryObject;
	
	if tmpSumObj = null then
		//nothing to do
		return;
	endif;

	if tbl.column = self.Column_ColourCode then
		self.showStowageIDs(tmpSumObj);
		return;
	endif;
	
	if self.defaultDblClickFunction = null then
		//ask - what do you want to do?
		self.doSetFunctionPref(tmpSumObj);
		return;
	endif;
	
	create allSummariesObj transient;
	allSummariesObj.add(tmpSumObj);
	
	self.handleFunctionForObject(self.defaultDblClickFunction, allSummariesObj, tbl.column);
epilog
	delete allSummariesObj;
end;</source>
        <Parameter name="_table" type="CM_DataTable" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doTblTBAContextMenu" id="880cba84-c56b-4904-9311-1adbab9a3287">
        <updating/>
        <source>doTblTBAContextMenu(cntrl: Table input; conwin: Window input; mouse: Boolean; x: Integer; y: Integer): Boolean updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 September 2019	jlgmp6	Initial creation	TFS 45590

*/

vars
	theRow : Integer;
	theTI : CM_TrackedItem;
	theLocationsController : CM_LocationsController;
begin

	self.mnuInspectObject.visible := app.isAllowedToInspect();
		
	self.mnuLoadListPlanLoad.visible := false;

	theRow := cntrl.CM_BaseTable.getRowFromY(y);
	if theRow &gt; cntrl.fixedRows then
		theTI := cntrl.accessRow(theRow).itemObject.CM_TrackedItem;

		self.mnuInspectObject.userObject := theTI;
		
		// #####################
		// PLANNING TO SHIP?
		// #####################
		if app.myMoveController &lt;&gt; null then
			if theTI &lt;&gt; null then
				if app.myMoveController.mySlotRequest &lt;&gt; null and app.myMoveController.mySlotRequest.myJob &lt;&gt; null then
					// YES!
					if app.myMoveController.mySlotRequest.isLoad and theTI.isTBAorIsRRP then
						app.myMoveController.setMyTrackedItem(theTI);
						self.mnuLoadListPlanLoad.userObject := cntrl;
						if cntrl.CM_DataTable.allSelectedObjects.size &gt; 1 then
							self.mnuLoadListPlanLoad.caption := app.getErrorString(SHP_Plan_Selected_TBA);
						else
							if cntrl.CM_DataTable.allSelectedObjects.isEmpty then
								cntrl.CM_DataTable.selectRow(theRow,false);
							endif;
							self.mnuLoadListPlanLoad.caption := app.getErrorString(SHP_Plan_TBA_Load_To) &amp; app.myMoveController.mySlotRequest.mySlotController.getFullId;
						endif;
				
						self.mnuLoadListPlanLoad.visible := true;
					endif;
				elseif app.myMoveController.myVoyageRequest &lt;&gt; null and app.myMoveController.myVoyageRequest.myJob &lt;&gt; null then
					// YES!
					if app.myMoveController.myVoyageRequest.isLoad and theTI.isTranshipItem then
						app.myMoveController.setMyTrackedItem(theTI);
						self.mnuLoadListPlanLoad.userObject := cntrl;
						if cntrl.CM_DataTable.allSelectedObjects.size &gt; 1 then
							self.mnuLoadListPlanLoad.caption := app.getErrorString(SHP_Plan_Selected_TBA);
						else
							if cntrl.CM_DataTable.allSelectedObjects.isEmpty then
								cntrl.CM_DataTable.selectRow(theRow,false);
							endif;
							self.mnuLoadListPlanLoad.caption := app.getErrorString(SHP_Plan_TBA_Load_To) &amp; app.myMoveController.myVoyageRequest.CM_RORORequest.myROROController.getFullId;
						endif;
				
						self.mnuLoadListPlanLoad.visible := true;
					endif;
				endif;
			endif;
		endif;
	endif;

	if not self.splTBA.getControlByName(self.tblTBAInfo.name).visible then
		self.mnuContextHide.caption := self.MNU_MACRO_SHOW;
	else
		self.mnuContextHide.caption := self.MNU_MACRO_HIDE;
	endif;
		
	return self.showContextMenu(self.mnuContextTable,cntrl,conwin,mouse,x,y);


end;</source>
        <Parameter name="cntrl" type="Table" usage="input"/>
        <Parameter name="conwin" type="Window" usage="input"/>
        <Parameter name="mouse" type="Boolean"/>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doTblTBAMouseMove" id="93a1779e-a899-440a-93b5-099330404a34">
        <updating/>
        <source>doTblTBAMouseMove(table: Table input; button: Integer; shift: Integer; x: Real; y: Real) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
12 August 2013	cnwrd1	Initial creation

*/
vars

	gridPoint	: CMUI_GridPoint;
	theTI		: CM_TrackedItem;
	root : CM_Root;
	lPicture : Picture;
	moveController : CMIF_MoveController;
begin

	self.tblTBA.mouseMoveForDragSelect(table, button, shift, x, y);

	if self.tblTBA.row &lt;= self.tblTBA.fixedRows 
	or y &lt;= table.accessRow(self.tblTBA.fixedRows).height then 
		self.origXPos := x;
		self.origYPos := y;
		return;
	endif;
	
	if button = Window.MouseButton_Left 
	and	app.dragDetected(x, y, self.origXPos, self.origYPos) 
	and self.origYPos &gt; 20  // ###  may be doing a column resize!
	and not shift.isControlKeyPressed()
	and not shift.isShiftKeyPressed()
	and not shift.isAltKeyPressed() then
		theTI := self.tblTBA.accessRow(self.tblTBA.row).itemObject.CM_TrackedItem;
		if theTI &lt;&gt; null and not theTI.isPlanned(PLANNING_MODE) then
			app.myDraggedTrackedItem := theTI;
			create moveController transient;
			
			moveController.setMyTrackedItem(theTI);
			delete app.myMoveController;
			app.myMoveController := moveController;
			app.isDragging := true;
			moveController.setMyOriginatingLocation(theTI.getPrimaryLocation(REAL_MODE));
			self.moveModeForm := PLANNING_MODE;
			moveController.setMoveMode(PLANNING_MODE);	
			table.dragMode := DragMode_Drag;
			root := app.myRoot;

			create lPicture transient;
			self.setPictureDragCursor(lPicture);
			if lPicture.picture &lt;&gt; null then
				table.dragCursor := lPicture.picture;
			endif;

		endif;
	endif;
epilog
	if lPicture &lt;&gt; null then
		delete lPicture;
	endif;
	

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
