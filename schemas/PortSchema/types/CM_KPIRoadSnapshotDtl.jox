<Class name="CM_KPIRoadSnapshotDtl" id="ff82a88a-5496-4c7a-83c0-edc48a28099c">
    <superclass name="CM_KPISnapshotDtl"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="kpiPeriod"/>
    <PrimAttribute name="receivedTEU" id="c2dad431-af2d-498e-87ea-2dd3ff513eb4">
        <embedded/>
        <type name="Integer"/>
        <access>readonly</access>
    </PrimAttribute>
    <PrimAttribute name="releasedTEU" id="9ddeb15e-3ec7-40b9-9dc6-6158e26f1689">
        <embedded/>
        <type name="Integer"/>
        <access>readonly</access>
    </PrimAttribute>
    <PrimAttribute name="truckVisits" id="b1ff1a26-38a4-4552-b855-8cf4c8d4b1d2">
        <embedded/>
        <type name="Integer"/>
        <access>readonly</access>
    </PrimAttribute>
    <JadeMethod name="create" id="1f655507-c677-413d-8687-7908111fe1a1">
        <updating/>
        <source>create() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 May 2013	cnwmc5	Initial creation

*/

vars

begin
	self.type := "ROAD";
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setFrom" id="04b99787-e04a-460f-beb0-72649a2278ac">
        <updating/>
        <source>setFrom(_object: CM_Object; _at: TimeStamp; _movements: CM_KPIMovementDtlArray) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 May 2013	cnwmc5	Initial creation

*/

vars
	gate		: CM_Gate;
	movement	: CM_KPIMovementDtl;

begin
	if _object.isKindOf(CM_Gate) then
		gate := _object.CM_Gate;

		self.id := gate.name;
		
		foreach movement in _movements reversed do
			if movement.isRoadSource and movement.workPointId = gate.name then
				self.receivedTEU := self.receivedTEU + movement.teu;
				self.truckVisits := self.truckVisits + 1;
			endif;
			if movement.isRoadTarget and movement.workPointId = gate.name then
				self.releasedTEU := self.releasedTEU + movement.teu;
				self.truckVisits := self.truckVisits + 1;
			endif;
		endforeach;
		self.dateTime := _at;
	endif;
	
epilog

end;</source>
        <Parameter name="_object" type="CM_Object"/>
        <Parameter name="_at" type="TimeStamp"/>
        <Parameter name="_movements" type="CM_KPIMovementDtlArray"/>
    </JadeMethod>
</Class>
