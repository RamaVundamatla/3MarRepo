    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>Localisation Support</text>
    <DbClassMap file="dev"/>
    <ExplicitInverseRef name="allClasses" id="57bd080f-89a9-4d0c-9b89-1ab92c822adc">
