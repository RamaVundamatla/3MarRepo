    </JadeMethod>
    <JadeMethod name="setControlsForAddEdit" id="236df386-a2ed-49cf-91cd-d4b0bc0bef3d">
        <updating/>
        <source>setControlsForAddEdit() updating;
//--------------------------------------------------------------
//Created: 22 January 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	filterRatio	: Integer;
	tmpBOLIn	: CM_BOLIn;
	entTableDef	: EntTableDef;
begin

	inheritMethod();
	
	tmpBOLIn := self.myCurrentObject.CM_BOLIn;

	sptThumbEdit.showRightControl(40, true);
	
	tblMain.clearValues();
	tblMain.clearAllSelected;

	if tmpBOLIn.bolType = BOLType_Log then
		entTableDef := app.myController.getEntTableDef(ETDef_DocketMain);
	else
		entTableDef := app.myController.getEntTableDef(ETDef_GenDocketMain);
	endif;

	self.tblMain.setEntTableDef(entTableDef, null, 'entTableDefSetupWarning');
	self.tblMain.adjustHeight(200);

	self.setDefaults();
	
	tblMain.userInputEnabled := true;
	tblMain.visible := true;

	// calculate the % of the left control (filter form) that we want to show).
	sptThumbEdit.showLeftControl(50, true);

	filterRatio := (100 - 1 - ((0 / sptThumbEdit.height)) * 100).Integer;

	sptThumbEdit.setLeftToRightRatioAndResize(filterRatio);
	
	if tmpBOLIn.isMatched then
		tblMain.disableRowByName(ETRow_ScalerCode);
	else
		tblMain.enableRowByName(ETRow_ScalerCode);
	endif;

	tblMain.moveFirst();
	tblMain.setFocus();

end;</source>
    </JadeMethod>
