    <JadeMethod name="btnAddItems_click" id="007bddff-b47f-490d-a83f-47acdb5ea101">
        <controlMethod name="CMUI_Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnAddItems_click(btn: Button input) updating;
/*
Purpose:			

Date		Who		Reason
11AUG2023	NAVAB1	 CR 59614 TASK 59619
*/

vars
	form   : CMUI_CargoSearchFormModal;
	ti 	   : CM_TrackedItem;
	object : Object;
begin
	form := app.loadForm(CMUI_CargoSearchFormModal, 
							CMUI_Assistant, 
							false, 
							false,
							true, 
							self.myTerminal,
							null).CMUI_CargoSearchFormModal;	

	if form = null then
		return;
	endif;
	
	
	form.setColumnsAndControlWidth(3, 175);
	form.setParentForm(self);
	form.showModal();
epilog

end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
