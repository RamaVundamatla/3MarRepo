	btnExport.translateCaption(Xlat_0006701, locale);
	btnHoldDef.translateBubbleHelp(Xlat_0019176, locale);
	btnHoldDef.translateCaption(Xlat_0019177, locale);
	btnImport.translateBubbleHelp(Xlat_0017994, locale);
	btnImport.translateCaption(Xlat_0006702, locale);
	btnJobPriority.translateBubbleHelp(Xlat_0003234, locale);
	btnJobPriority.translateCaption(Xlat_0003238, locale);
	btnNew.translateBubbleHelp(Xlat_0003245, locale);
	btnNew.translateCaption(Xlat_0003249, locale);
	btnPrint.translateCaption(Xlat_0003250, locale);
	btnReportOptions.translateBubbleHelp(Xlat_0003228, locale);
	btnReportOptions.translateCaption(Xlat_0003231, locale);
	btnResetSearch.translateBubbleHelp(Xlat_0003235, locale);
	btnResetSearch.translateCaption(Xlat_0003239, locale);
	btnResourcesUsed.translateBubbleHelp(Xlat_0003229, locale);
	btnResourcesUsed.translateCaption(Xlat_0003232, locale);
	btnRoRoDeckDef.translateBubbleHelp(Xlat_0015724, locale);
	btnRoRoDeckDef.translateCaption(Xlat_0015725, locale);
	btnSearch.translateBubbleHelp(Xlat_0003246, locale);
	btnSearch.translateCaption(Xlat_0003251, locale);
