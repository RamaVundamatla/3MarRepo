    <JadeMethod name="getInvoiceNumber" id="65f36efd-2689-4440-b756-4eb90651bdc2">
        <source>getInvoiceNumber():String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 December 2022	navhl20	ChangeRequest 54350:[54269] EUP - VAS Work Orders Selector Query

*/

vars
	invoiceLine		: CM_InvoiceLine;
begin
	if self.allInvoiceLines.isEmpty then
		return null;
	endif;
	invoiceLine := self.allInvoiceLines.first;
	if invoiceLine = null then
		return null;
	else
		return invoiceLine.invoice.sequenceNum.String;
	endif;
epilog

end;</source>
