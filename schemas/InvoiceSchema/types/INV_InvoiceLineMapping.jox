    <JadeMethod name="translateForm" id="398c6ee9-336b-4f52-923e-bdecf3f47ddd">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 23 March 2023 12:17:36.
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0006205, locale);
	btnExportCSVMap.translateBubbleHelp(Xlat_0025827, locale);
	btnExportCSVMap.translateCaption(Xlat_0025828, locale);
	btnImportCSVMap.translateBubbleHelp(Xlat_0025829, locale);
	btnImportCSVMap.translateCaption(Xlat_0025830, locale);
	btnOpenLineMappings.translateBubbleHelp(Xlat_0025122, locale);
	btnOpenLineMappings.translateCaption(Xlat_0025123, locale);
	btnPropCancel.translateBubbleHelp(Xlat_0002109, locale);
///	btnPropCancel.translateCaption(Xlat_0015137, locale);
	btnPropDelete.translateCaption(Xlat_0015138, locale);
	btnPropSave.translateBubbleHelp(Xlat_0002114, locale);
	btnPropSave.translateCaption(Xlat_0015139, locale);
	btnQueryDebtor.translateBubbleHelp(Xlat_0002106, locale);
	btnQueryDebtor.translateCaption(Xlat_0002107, locale);
	btnQueryShip.translateBubbleHelp(Xlat_0002112, locale);
	btnQueryShip.translateCaption(Xlat_0002113, locale);
///	btnRefresh.translateBubbleHelp(Xlat_0002117, locale);
	btnRefresh.translateCaption(Xlat_0015141, locale);
	lblBank.translateCaption(Xlat_0020696, locale);
	lblDebtor.translateCaption(Xlat_0002119, locale);
	lblInvoiceType.translateCaption(Xlat_0002108, locale);
	lblLineType.translateCaption(Xlat_0002116, locale);
	mnuAudits.translateCaption(Xlat_0021730, locale);
	mnuViewAudits.translateCaption(Xlat_0021731, locale);
end;</source>
    </JadeMethod>
    <JadeMethod name="userNotificationUpdate" id="4f1c7088-0384-4f18-97a2-fc2a9300fa03">
        <updating/>
        <source>userNotificationUpdate(_event: Integer; _noteobj : CM_Object; _obj: CM_Object) updating;
// ---------------------------------------------------------------------------
// Created:		September 2004 By Andrew Bishop cnwab1
//
// Purpose:		NOTE: The invoice Line Type is attach to an invoice type. By debtor we use the 
//						mapping to point the invoice line to a different invoice type.
//						If there is no mapping to a different invoice type, then we show the actual invoice type.
// ---------------------------------------------------------------------------

vars
	anObj : Object;
	theDebtor : CM_Debtor;
	theLineType : CM_InvoiceLineDesc;
	theType : CM_InvoiceDesc;
	theMapping : CM_InvoiceLineDescMapping;
	idx, theRow, theColumn : Integer;
begin 
	if not _obj.isKindOf(CM_InvoiceLineDescMapping) and
	   not _obj.isKindOf(CM_InvoiceLineDesc) then
		return;
	endif;
	if _event = EVENT_MAPPING_DELETE then
		self.tblData.findObjectInRow(_obj,idx);
		if idx &gt; 0 then
			// we have sent through the inv line desc from the delete note. This will let us find the row.
			theRow := idx;
			theLineType := _obj.CM_InvoiceLineDesc;
			theDebtor := null;
			// go through each column for this row and find and invalid object - the one that has been deleted. This will give us the debtor.
			foreach theColumn in 2 to self.tblData.columns do
				theDebtor := self.tblData.accessColumn(theColumn).itemObject.CM_Debtor;
				anObj := self.tblData.accessCell(theRow,theColumn).itemObject;
				if theDebtor &lt;&gt; null then
					theType := theLineType.getInvoiceType(theDebtor.CM_Debtor);
					if theType = null then	// test added from 35872
						self.tblData.accessCell(theRow,theColumn).text := "UNKNOWN";
						self.tblData.accessedCell.fontBold := false;
						self.tblData.accessedCell.foreColor := DarkGray;
						self.tblData.accessedCell.itemObject := null;
					else
						if (anObj.CM_InvoiceDesc &lt;&gt; theType) then
							self.tblData.accessCell(theRow,theColumn).text := theType.description;
							if (theLineType.invoiceType &lt;&gt; theType) then
								self.tblData.accessedCell.fontBold := true;
								self.tblData.accessedCell.foreColor := Black;
							else
								self.tblData.accessedCell.fontBold := false;
								self.tblData.accessedCell.foreColor := DarkGray;
							endif;
							self.tblData.accessedCell.itemObject := theType;
						endif;
					endif;
				endif;			
				
			endforeach;
		endif;
		return;
	endif;

	if _obj &lt;&gt; null 
	and (_event = EVENT_MAPPING_UPDATE or _event = EVENT_MAPPING_CREATE ) then
		theMapping := _obj.CM_InvoiceLineDescMapping;
		theDebtor := theMapping.myDebtor;
		theLineType := theMapping.myInvoiceLineDesc;
		theType := theMapping.myInvoiceType;
		
		self.tblData.findObjectInRow(theLineType,theRow);
		self.tblData.findObjectInColumn(theDebtor,theColumn);

		// from 35872 testing, only if found, may be for a different business unit
		if theRow &gt; 0 and
		   theColumn &gt; 0 then
			self.tblData.accessCell(theRow,theColumn).text := theType.description;
			self.tblData.accessedCell.fontBold := (theLineType.invoiceType &lt;&gt; theType);
			self.tblData.accessedCell.itemObject := theType;
		endif;
	endif;

end;</source>
        <Parameter name="_event" type="Integer"/>
        <Parameter name="_noteobj" type="CM_Object"/>
        <Parameter name="_obj" type="CM_Object"/>
    </JadeMethod>
</GUIClass>
