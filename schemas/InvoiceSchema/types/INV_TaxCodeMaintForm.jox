    <JadeMethod name="doRefresh" id="bd11893c-f3a5-41a4-b366-43050b201d37">
        <updating/>
        <source>doRefresh() updating, protected;
//------------------------------------------------
// Created: 17 May 2006 By: cnwgd1
//------------------------------------------------
vars

begin
	inheritMethod();
	self.myCurrentListObject := null;
	self.myCurrentTaxCode := null;
	self.myCurrentTaxRate := null;		
	self.loadTaxCodes();
end;</source>
