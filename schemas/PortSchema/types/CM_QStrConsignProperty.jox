    <JadeMethod name="getWebDataRowName" id="6960218f-bcf3-46d9-a83e-0b931e22cee4">
        <source>getWebDataRowName(): String;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 27/08/2019	jlgdap1		Initial creation TFS 45769 JMT Web portal selector query parameters
//
vars

begin
	if self.type = CONSIGNEE then
		return ETRow_Consignee;
	elseif self.type = CONSIGNOR then
		return ETRow_Consignor;
	elseif self.type = FREIGHT_FORWARDER then
		return ETRow_FreightForwarder;
	endif;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="setComboValues" id="2c83921a-79a9-4e9c-8b2b-e48effef104d">
        <source>setComboValues(_combo : ComboBox input; _params : CM_QueryCriteriaLineHolder; _queryOperator : CM_QueryOperator; _passport : CM_Passport);
// ---------------------------------------------------------------------------
// Created:     06 March 2003		cnwth2	
//
// Purpose:     		 
//
// Changed On	Changed By	Reason
// ----------   ----------  --------------------------------------------------
// 23/06/2022	navdap1		TFS 53362 EUP Master Data Interface Customers Between TOS and ERP
vars
	con			: CM_ConsigneeConsignor;
	conDict		: CM_ConsignByCodeDict;
	byName		: Boolean;				// TFS 53362
begin
	_combo.clear();
	conDict := app.myRoot.allConsigneeConsignors;
	byName := app.myRoot.getConfig(ConsigneeConsignorCmbOrdDescr).Boolean;		// TFS 53362
	
	foreach con in conDict do
		if self.type = 0 then
			// Add it please.
		elseif self.type = FREIGHT_FORWARDER and not con.isFreightFwdr then
			continue;
		elseif self.type = CONSIGNEE and not con.isConsignee then
			continue;
		elseif self.type = CONSIGNOR and not con.isConsignor then
			continue; 
		endif;
		if byName then																		// TFS 53362
			_combo.itemObject[_combo.addItem(con.description &amp; Tab &amp; con.code)] := con;		// TFS 53362
		else																				// TFS 53362
			_combo.itemObject[_combo.addItem(con.code &amp; Tab &amp; con.description)] := con;
		endif;																				// TFS 53362
	endforeach;

	if CM_QStringLookup.hasInstance(_queryOperator) then
		_combo.listObject := conDict[_queryOperator.CM_QStringLookup.selectionValue];
	elseif CM_QStringLookupNotEqual.hasInstance(_queryOperator) then
		_combo.listObject := conDict[_queryOperator.CM_QStringLookupNotEqual.selectionValue];
	endif;

end;</source>
        <Parameter name="_combo" type="ComboBox" usage="input"/>
        <Parameter name="_params" type="CM_QueryCriteriaLineHolder"/>
        <Parameter name="_queryOperator" type="CM_QueryOperator"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="setListValues" id="763f8c3f-6d79-43a7-88bd-6d8a4470c4ae">
        <source>setListValues(_tbl: Table input; _params: CM_QueryCriteriaLineHolder; _operator: CM_QueryOperator; _passport: CM_Passport);
/*

Purpose:			

Parameters:			

Return Value:		

***** Changes
Date				Name		TFS#		Description
10 February 2015	cnwma1					Initial creation
21 August 2018		jlgka1		40200		Filter the listing based on which Property is currently selected in the Selector Screen.

*/

vars
	consign 		: CM_ConsigneeConsignor;
	consignDict     : CM_ConsignByCodeDict;
	selectionValue,
	idx				: Integer;
	array			: ObjectArray;
begin
	
	consignDict := app.myRoot.allConsigneeConsignors;
	
	_tbl.rows := _tbl.fixedRows;
	
	//doesn't know about CMUI_ListTable - so have to do this:
	array := _tbl.getPropertyValue('allSelectedObjects').ObjectArray;
	array.clear;
	
	foreach consign in consignDict do
		selectionValue := 0;
		if _operator &lt;&gt; null and  _operator.CM_QStringIsOneOf.allSelectionValues.includes(consign.code) then
			selectionValue := 1;
			array.add(consign);
		endif;
		if self.type = 0 then
			// Add it please.
		elseif self.type = FREIGHT_FORWARDER and not consign.isFreightFwdr then
			continue;
		elseif self.type = CONSIGNEE and not consign.isConsignee then
			continue;
		elseif self.type = CONSIGNOR and not consign.isConsignor then
			continue; 
		endif;
		idx := _tbl.addItem(selectionValue.String &amp; Tab  &amp; consign.code &amp; ' (' &amp; consign.description&amp; ')');
		_tbl.accessRow(idx).itemObject := consign;
	endforeach;
end;</source>
        <Parameter name="_tbl" type="Table" usage="input"/>
        <Parameter name="_params" type="CM_QueryCriteriaLineHolder"/>
        <Parameter name="_operator" type="CM_QueryOperator"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="setValuesFromList" id="726788bb-6109-4ff2-8492-9d64096c0e63">
        <source>setValuesFromList(_tbl: Table input; _op: CM_QueryOperator input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 February 2015	cnwma1	Initial creation

*/

vars
	consignee : CM_ConsigneeConsignor;
	str			: String;
	numRows,
	idx			: Integer;
	sa			: StringArray;

begin

	create sa transient;
	
	numRows := _tbl.rows;
	foreach idx in (_tbl.fixedRows + 1) to numRows do
		str := _tbl.accessCell(idx, 1).text;
		if str = TableCheckBox_Selected then
			consignee := _tbl.accessRow(idx).itemObject.CM_ConsigneeConsignor;
			sa.add(consignee.code);
		endif;
	endforeach;
	
	_op.setSearchValue(sa);

epilog
	delete sa;
end;</source>
        <Parameter name="_tbl" type="Table" usage="input"/>
        <Parameter name="_op" type="CM_QueryOperator" usage="input"/>
    </JadeMethod>
    <JadeMethod name="translateToDisplayValue" id="0a7b6f51-b93c-42b9-a0d6-cff3dfbdf6b3">
        <source>translateToDisplayValue(_value: Any): String;
// ---------------------------------------------------------------------------
// Created:     06 March 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
vars

begin
	
	if _value.isKindOf(CM_ConsigneeConsignor) then
		if _value &lt;&gt; null then
			return _value.CM_ConsigneeConsignor.code;
		else 
			return null;
		endif;
	else
		return _value.String;
	endif;
	return null;
	
end;</source>
        <Parameter name="_value" type="Any"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="translateToSearchValue" id="77d1a777-fd66-4950-9c39-507a069eff7d">
        <source>translateToSearchValue(_value: Any): Any;
// ---------------------------------------------------------------------------
// Created:     17 March 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
/*

Date		Who		Reason
06 Oct 2008	cnwkpd1	PAR #18099 - Correct Selector query processing
22 Oct 2008	cnwkpd1	PAR #18348 - Prevent 1002 exceptions in Selector query processing with isOneOf

*/

vars
	invalidObj 		: Boolean;
	object			: CM_ConsigneeConsignor;
	returnVal		: String;
	
begin
	if _value &lt;&gt; null then
		if _value.isKindOf(Collection) then			// PAR #18348
			return _value;
		endif;

		if _value.isKindOf(CM_ConsigneeConsignor) then
			object := _value.CM_ConsigneeConsignor;
		endif;
		
		//30 Jan 2014	NDL	Par 33347
		if _value.isKindOf(String) then
			returnVal := _value.String;
		endif;
	endif;
	
	if object &lt;&gt; null then
		on Exception do app.handleDeletedObject(exception, object, invalidObj);
		
		returnVal := object.code;
	endif;
	
	return returnVal;
	
end;
</source>
        <Parameter name="_value" type="Any"/>
        <ReturnType type="Any"/>
    </JadeMethod>
    <JadeMethod name="translateToSearchValueForWeb" id="b0175617-7bc0-4cd5-b8f1-9e28742080ae">
        <source>translateToSearchValueForWeb(_value: Any; _sending : Boolean): Any;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 19/09/2019	jlgdap1		Initial creation TFS 45769 JMT Web Portal selector query parameters
//
vars
	str, result : String;
	strArray : StringArray;

begin
	if _value.isKindOf(StringArray) then
		foreach str in _value.StringArray do
			result := result &amp; str &amp; CNEC_COMMA &amp; Space;
		endforeach;
		result := result[1:result.length-2];
		return result;
		
	elseif _value.isKindOf(String) and _value.String.cnContains("|") then
		str := _value.String;
		create strArray transient;
		str.getTokensForDelimiter("|", strArray);
		return strArray;
		
	endif;
	
	return inheritMethod(_value, _sending);

epilog

end;</source>
        <Parameter name="_value" type="Any"/>
        <Parameter name="_sending" type="Boolean"/>
        <ReturnType type="Any"/>
    </JadeMethod>
</Class>
