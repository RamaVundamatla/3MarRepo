    <JadeMethod name="canBeDBLoaded" id="e70dbc54-3db5-4e22-b63b-578054a72c96">
        <source>canBeDBLoaded(): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 June 2023	navsp1	Initial creation TFS ChangeRequest 58054: EUP - Manifest Send EDI Endpoint

*/

vars

begin
	if self.myShipManifest &lt;&gt; null then
		return self.myShipManifest.canBeDBLoaded();
		
	elseif self.myTrainConsist &lt;&gt; null then
		return self.myTrainConsist.canBeDBLoaded();
		
	elseif self.myGateDocument &lt;&gt; null then
		return self.myGateDocument.canBeDBLoaded();
		
	elseif self.myCargoOnSite &lt;&gt; null then
		return self.myCargoOnSite.canBeDBLoaded();
		
	else	
		return inheritMethod();
		
	endif;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="canBeDBLoadedAutomatic" id="434a64e3-15cf-43b5-ac98-5669438ac5ae">
        <source>canBeDBLoadedAutomatic(_agent: CM_EDIControllerAgent): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 June 2023	navsp1	Initial creation TFS ChangeRequest 57805: EUP - Manifest Processing - Truck - Create
11 Aug  2023    navsp1  ChangeRequest 59751: EUP | Manifest and Calloff - AutoDB Load config
15 Nov 2023		navsaa30 Bug 61174: EUP | Issues reprocessing EDI files with errors and warnings
11 Sep 2024     navsp1   TFS Bug 66048: MTN - unexpected behaviour of User defined transport manifest file loaded in EDI ops
25/08/2025	navcs2	MTN-35671 MTN - Error 1090 | Process Edi File | CM_EDIDataTransManifest::canBeDBLoadedAutomatic 
*/

vars
	result	: Boolean;
	msgType	: String;
	transportMode	: String;
	canLoad	 : CM_NameValuePair;
    configValue : String;
	error 	: CM_EDIError;
	count 	: Integer;
	type	: String;//TFS 66048
begin
	result	:= inheritMethod(_agent);
	count 	:= 0;							//15.Nov.23  navsaa30  #61174
	if self.myGateDocument &lt;&gt; null then
		transportMode	:= CM_EDIFileTypeJSONTransManifst.TRANSPORT_MODE_ROAD;
	elseif self.myCargoOnSite &lt;&gt; null then
		transportMode	:= CM_EDIFileTypeJSONTransManifst.TRANSPORT_MODE_ONSITE;
	elseif self.myShipManifest &lt;&gt; null then
		transportMode	:= TI_TRANSMODE_SHIP_STR;//CM_EDIFileTypeTransManifest.TRANSPORT_MODE_SEA;
	elseif self.myTrainConsist &lt;&gt; null then
		transportMode	:= CM_EDIFileTypeJSONTransManifst.TRANSPORT_MODE_RAIL;
	endif;
	
	// are we running automatically from a BGP or from a web synchronous call
	// if so, we need to check whether auto DB loading is supressed for this 
	// transport mode
	app.writeLog(method.qualifiedName &amp; Tab &amp; "_agent.isBGPAuto is " &amp; _agent.isBGPAuto.String &amp; ", app.isFromEDIviaWeb is " &amp; app.isFromEDIviaWeb.String, LogDEBUG);
	if _agent.isBGPAuto or app.isFromEDIviaWeb then
		
		if self.myEDIFile.myEDIFileType &lt;&gt; null and self.myEDIFile.myEDIFileType.type = EDIFileType_UserDefined and 				//TFS 66048 25/08/2025	navcs2	MTN-35671
			self.myEDIFile.myEDIFileType.CM_EDIFileTypeUser.dataType = EDIDataType_TransportManifest then							//TFS 66048
			type := "Manifest";																										//TFS 66048
		else																														//TFS 66048
			type := self.type;																										//TFS 66048
		endif;																														//TFS 66048
		
		msgType := "Manifest|" &amp; type &amp; "|" &amp; transportMode;
		app.writeLog(method.qualifiedName &amp; Tab &amp; "msgType is " &amp; msgType, LogDEBUG);
		canLoad := self.getMyTerminal.allDBLoadOptions[msgType];
		if canLoad &lt;&gt; null then 
            configValue := canLoad.value;       //11.Aug.2023 navsp1 TFS 59751 &gt;&gt;&gt;&gt;
            if configValue.length = 3 then       
              
                if self.statusString = CMIF_JsonHeaderEUP.Status_Create and configValue[1:1] = "0" then
                    result := false;
                elseif self.statusString = CMIF_JsonHeaderEUP.Status_Replace and configValue[2:1] = "0" then
                    result := false;
                elseif self.statusString = CMIF_JsonHeaderEUP.Status_Cancel and configValue[3:1] = "0" then
                    result := false;
                endif;                          //11.Aug.2023 navsp1 TFS 59751 &lt;&lt;&lt;&lt;
               
			elseif configValue = "0" then
				result := false;
			endif;
			
			foreach error in self.allErrorWarnings do						// 15.11.23 navsaa30 #61174
				if error.errorCode = 1027 or error.errorCode = 1081 then 	//lock or deadlock
						count := count + 1;
				endif;
			endforeach;
			//Prevent automatic DB Load if any Errors or warnings				//21.Sep.2023 navsp1 TFS 60473
			if self.allErrorWarnings.size &lt;&gt; count then							// 15.11.23 navsaa30 #61174
				result := false;
				app.writeLog(method.qualifiedName &amp; Tab &amp; msgType &amp; " is unable to be loaded using automatic DB loading due to warnings", LogINFO);
			endif;
			
            if result = false then
				app.writeLog(method.qualifiedName &amp; Tab &amp; msgType &amp; " is not set for automatic DB Load", LogDEBUG);
			else
				app.writeLog(method.qualifiedName &amp; Tab &amp; msgType &amp; " is set for automatic DB Load", LogDEBUG);
			endif;
		else
			app.writeLog(method.qualifiedName &amp; Tab &amp; "canLoad value is null", LogDEBUG);
		endif;
	endif;
	
	return result;
epilog

end;</source>
        <Parameter name="_agent" type="CM_EDIControllerAgent"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="canBeDeleted" id="2faf02ba-7783-451c-8a7d-2ca93b66a1ea">
        <source>canBeDeleted(_purgeDate: Date): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 August 2025	navsaa30	Initial creation
28/8/2025 navsaa30 MTN-35322 UE 75755 when deleting EDI Transport Manifest EDI Data
*/

vars

begin
	return false;

epilog

end;</source>
        <Parameter name="_purgeDate" type="Date"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="canBePartiallyLoaded" id="54a325d6-cb86-42a0-8166-dd5a3dcddf81">
        <source>canBePartiallyLoaded(): Boolean protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 June 2023	navsp1	Initial creation TFS ChangeRequest 58054: EUP - Manifest Send EDI Endpoint

*/

vars

begin
	
	if self.myShipManifest &lt;&gt; null then
		if self.getMyTerminal.getConfig(EdiShipManAllowPartial).Boolean then
			return true;
		else
			return false;
		endif;
		
	elseif self.myTrainConsist &lt;&gt; null then
		return false;
		
	elseif self.myGateDocument &lt;&gt; null then
		return true;
		
	elseif self.myCargoOnSite &lt;&gt; null then
		if self.getMyTerminal.getConfig(EdiCargoByAllowPartial).Boolean then
			return true;
		else
			return false;
		endif;
		
	else	
		return inheritMethod();
		
	endif;

epilog

end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="canBeVerified" id="bb76aef7-9c5a-44ff-95a1-223416b3394e">
        <source>canBeVerified(): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 June 2023	navra1	Initial creation for TFS 57808 - EUP - Manifest Processing - Train - Create

*/

vars
	ediData : CM_EDIData;
begin	
	
	if self.myCargoOnSite &lt;&gt; null then
		ediData := self.myCargoOnSite;
	elseif self.myTrainConsist &lt;&gt; null then
		ediData := self.myTrainConsist;
	elseif self.myGateDocument &lt;&gt; null then
		ediData := self.myGateDocument;
	elseif self.myShipManifest &lt;&gt; null then
		ediData := self.myShipManifest;
	endif;
	
	if ediData = null then
		return false;
	endif;
	
	return ediData.canBeVerified();
	
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
