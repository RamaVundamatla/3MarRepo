    <JadeMethod name="drawBetweenPoints" id="f3f8dc90-6c2e-4f74-8dc3-df8fe494f234">
        <updating/>
        <source>drawBetweenPoints(_theFrame : CMUI_GridAreaFrame input) updating;
// ---------------------------------------------------------------------------
// Created:		August 2003 By Andrew Bishop cnwab1
//
// Purpose:		If a 40 is moved or unplanned - basically it is removed from the screen this little rectangle wiil get rid of a stripe left between the pads
//
// ---------------------------------------------------------------------------

vars
	theFrame : CMUI_GridAreaFrame;
begin
	theFrame := _theFrame;
	
	theFrame.drawFillColor := theFrame.backColor;
	if self.myGridArea.flipHorizontal then
		theFrame.drawFilledRectangle(self.x1 , self.y1, self.x1 - 2, self.y2,  _theFrame.backColor);
	else
		theFrame.drawFilledRectangle(self.x2 - 1 , self.y1, self.x2 + 2, self.y2,  _theFrame.backColor);
	endif;
end;</source>
        <Parameter name="_theFrame" type="CMUI_GridAreaFrame" usage="input"/>
    </JadeMethod>
    <JadeMethod name="drawBlankSpace" id="54c5fdf4-c48b-4965-a7f1-3ff7d4f7569a">
        <source>drawBlankSpace(pColor: Integer; pHeight: Integer; pFrame: CMUI_GridAreaFrame input; pX1: Real; pY1: Real; pX2: Real; pY2: Real) protected;
// ---------------------------------------------------------------------------
// Created:		June  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	theFrame : CMUI_GridAreaFrame;
	
begin
	theFrame := pFrame;

	theFrame.drawStyle := Frame.DrawStyle_Dash;
	theFrame.drawFillColor := pColor;
	if pColor = theFrame.backColor then
//		theFrame.drawFilledRectangle(pX1, pY1, pX2, pY2,  pColor); // leave this out AKB2003NOV. We now chANGE BACKGROUND COLOUR of current SDF so leave blank
	else
		theFrame.drawFilledRectangle(pX1, pY1, pX2, pY2,  Black);
	endif;
	theFrame.drawStyle := Frame.DrawStyle_Solid;
	
end;</source>
        <access>protected</access>
        <Parameter name="pColor" type="Integer"/>
        <Parameter name="pHeight" type="Integer"/>
        <Parameter name="pFrame" type="CMUI_GridAreaFrame" usage="input"/>
        <Parameter name="pX1" type="Real"/>
        <Parameter name="pY1" type="Real"/>
        <Parameter name="pX2" type="Real"/>
        <Parameter name="pY2" type="Real"/>
    </JadeMethod>
    <JadeMethod name="drawBuilding" id="6bfdb774-0e7f-4f9c-a39a-1fd23fa37214">
        <source>drawBuilding(_frame: CMUI_GridAreaFrame input);
// ---------------------------------------------------------------------------
// Created:		June  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	theFrame : CMUI_GridAreaFrame;
	aSlotHeight, aWindowHeight, idx : Integer;
	aHeight, tmpx1, tmpx2, tmpy1, tmpy2 : Integer;
begin
	theFrame := _frame;
	
	theFrame.drawStyle := Frame.DrawStyle_Solid;
	// #######################
	// DRAW ROOF
	if self.heightOfStack = 1 then
		aHeight := 2;
	else
		aHeight := self.heightOfStack;
	endif;
	aSlotHeight := ((self.x2 - self.x1) / aHeight).Integer;
	tmpx1 := self.x1.Integer;
	tmpy1 := self.y1.Integer + aSlotHeight;
	tmpx2 := (self.x1 + ((self.x2 - self.x1) / 2)).Integer;
	tmpy2 := self.y1.Integer;
	theFrame.drawLine(tmpx1, tmpy1, tmpx2, tmpy2, DarkBlue);

	tmpx1 := tmpx2;
	tmpy1 := tmpy2;
	tmpx2 :=  (self.x1 + (self.x2 - self.x1)).Integer;
	tmpy2 := self.y1.Integer + aSlotHeight;
	theFrame.drawLine(tmpx1, tmpy1, tmpx2, tmpy2, DarkBlue);

	tmpx1 := tmpx2;
	tmpy1 := tmpy2;
	tmpx2 := self.x1.Integer;
	tmpy2 := self.y1.Integer + aSlotHeight;
	theFrame.drawLine(tmpx1, tmpy1, tmpx2, tmpy2, DarkBlue);

	// #######################
	// DRAW Building

	theFrame.drawFillColor := Green;
	theFrame.drawFillStyle := Frame.DrawFillStyle_Cross;

	tmpx1 := tmpx2;
	tmpy1 := tmpy2;
	tmpx2 := self.x2.Integer;
	tmpy2 := self.y2.Integer;
	theFrame.drawFilledRectangle(tmpx1, tmpy1, tmpx2, tmpy2, Green);

	// #######################
	// DRAW Windows
	theFrame.drawFillColor := White;
	theFrame.drawFillStyle := Frame.DrawFillStyle_Solid;

	aWindowHeight := (aSlotHeight / 3).Integer;
	
	// ####
	// LEFT
	tmpy1 := (self.y1 + aSlotHeight + 10).Integer;
	tmpx1 := (self.x1 + 10).Integer;	
	while tmpy1 &lt; self.y2 - 10 do
		tmpy2 := tmpy1 + 10;
		tmpx2 := tmpx1 + 10;
		theFrame.drawFilledRectangle(tmpx1, tmpy1, tmpx2, tmpy2, Green);
	
		tmpy1 := tmpy1 + 15;
	endwhile;

	// ####
	// RIGHT
	tmpy1 := (self.y1 + aSlotHeight + 10).Integer;
	tmpx1 := (self.x2 - 20).Integer;	
	while tmpy1 &lt; self.y2 - 10 do
		tmpy2 := tmpy1 + 10;
		tmpx2 := tmpx1 + 10;
		theFrame.drawFilledRectangle(tmpx1, tmpy1, tmpx2, tmpy2, Green);
	
		tmpy1 := tmpy1 + 15;
	endwhile;
end;</source>
        <Parameter name="_frame" type="CMUI_GridAreaFrame" usage="input"/>
    </JadeMethod>
    <JadeMethod name="drawHeight" id="e35f9c3d-32dc-41b2-8734-b70688ad0171">
        <source>drawHeight(_label: String; _colour: Integer; _frame: CMUI_GridAreaFrame input; _theX1: Real; _theY1: Real; _theX2: Real; _theY2: Real);
// ---------------------------------------------------------------------------
// Created:		August  2002 By Andrew Bishop cnwab1
//
// Purpose:		
// ---------------------------------------------------------------------------
vars
	theFrame 	: CMUI_GridAreaFrame;
	scaleFactor,
	fontSize 	: Real;
begin
	theFrame := _frame;
	
	fontSize := theFrame.drawFontSize;
	scaleFactor := self.myGridArea.scaleXFactor;
	
	theFrame.drawFontBold := true;
	if scaleFactor &lt;= 1.5 then
		theFrame.drawFontSize := 8;
	elseif scaleFactor = 2 then
		theFrame.drawFontSize := 10;
	elseif scaleFactor = 3 then
		theFrame.drawFontSize := 18;
	elseif scaleFactor = 4 then
		theFrame.drawFontSize := 22;
	endif;
	theFrame.drawFontName := "Arial";
	theFrame.drawTextAt(_label, _theX1+((_theX2-_theX1)/2)-5, _theY1+((_theY2-_theY1)/2)-6, _colour);
	theFrame.drawFontBold := false;
	theFrame.drawFontSize := fontSize;

end;</source>
        <Parameter name="_label" type="String"/>
        <Parameter name="_colour" type="Integer"/>
        <Parameter name="_frame" type="CMUI_GridAreaFrame" usage="input"/>
        <Parameter name="_theX1" type="Real"/>
        <Parameter name="_theY1" type="Real"/>
        <Parameter name="_theX2" type="Real"/>
        <Parameter name="_theY2" type="Real"/>
    </JadeMethod>
    <JadeMethod name="drawLabour" id="0ba27caa-c1b9-47d6-9236-069e613eff1a">
        <source>drawLabour(_label : String;_colour : Integer;_frame : CMUI_GridAreaFrame input; _theX1: Real; _theY1: Real; _theX2: Real; _theY2: Real);
// ---------------------------------------------------------------------------
// Created:		June  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	theFrame : CMUI_GridAreaFrame;

	anOffset1, anOffset2, aSlotHeight, aWindowHeight, idx : Integer;
	aHeight, tmpx1, tmpx2, tmpy1, tmpy2 : Integer;

	aPrevGridPoint : YRD_GridPoint;
	theSamePrev, theSameAbove : Boolean;
	aRest : CM_Restriction;
begin
	theFrame := _frame;
	theFrame.drawFillColor := _colour;
	theFrame.drawFillStyle := Frame.DrawFillStyle_DownDiagonal;

	theFrame.drawFilledRectangle(_theX1, _theY1, _theX2, _theY2, _colour);
epilog
	theFrame.drawFillStyle := Frame.DrawFillStyle_Solid;

end;</source>
        <Parameter name="_label" type="String"/>
        <Parameter name="_colour" type="Integer"/>
        <Parameter name="_frame" type="CMUI_GridAreaFrame" usage="input"/>
        <Parameter name="_theX1" type="Real"/>
        <Parameter name="_theY1" type="Real"/>
        <Parameter name="_theX2" type="Real"/>
        <Parameter name="_theY2" type="Real"/>
    </JadeMethod>
    <JadeMethod name="drawLight" id="4b81530b-c7bc-4119-9be0-6e0d3bf62698">
        <source>drawLight(_frame: CMUI_GridAreaFrame input);
// ---------------------------------------------------------------------------
// Created:		June  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	theFrame : CMUI_GridAreaFrame;
	anOffset1, anOffset2, aSlotHeight, aWindowHeight,aColour, idx : Integer;
	aHeight, tmpx1, tmpx2, tmpy1, tmpy2 : Integer;
	aLetter : String;
	aPrevGridPoint : YRD_GridPoint;
	theSamePrev, theSameAbove : Boolean;
	lPicture : Binary;
begin
	theFrame := _frame;
	theSamePrev := false;
	aPrevGridPoint := self.myGridArea.allGridPoints[self.row, self.column - 1].YRD_GridPoint;
	if aPrevGridPoint &lt;&gt; null then
		if aPrevGridPoint.letter = GridPointType_Light then // the previous point is also a light
			theSamePrev := true;
		endif;
	endif;

	theSameAbove := false;
	aPrevGridPoint := self.myGridArea.allGridPoints[self.row - 1, self.column ].YRD_GridPoint;
	if aPrevGridPoint &lt;&gt; null then
		if aPrevGridPoint.letter = GridPointType_Light then // the point above is also a light
			theSameAbove := true;
		endif;
	endif;

	self.drawOverLappingRectangle(theSamePrev, theSameAbove, DarkGray, Yellow, theFrame);

	
	lPicture := app.myRoot.getConfig(PicLightBulb).Binary;
	theFrame.drawPictureAt(lPicture, self.x1 + 1, self.y1 + 1);

end;</source>
        <Parameter name="_frame" type="CMUI_GridAreaFrame" usage="input"/>
    </JadeMethod>
    <JadeMethod name="drawOverLappingRectangle" id="9e28f7d1-5a6d-4b0c-96a7-9ba75dfc07e1">
        <source>drawOverLappingRectangle(_theSamePrev, _theSameAbove: Boolean; _backColour, _foreColour : Integer; _frame: CMUI_GridAreaFrame input);
// ---------------------------------------------------------------------------
// Created:		June  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	theFrame : CMUI_GridAreaFrame;
	anOffset1, anOffset2,anOffset3,anOffset4,aSlotHeight, aWindowHeight, idx : Integer;
	aHeight, tmpx1, tmpx2, tmpy1, tmpy2 : Integer;
begin
	theFrame := _frame;
	
	theFrame.drawStyle := Frame.DrawStyle_Solid;
	theFrame.drawFillStyle := Frame.DrawFillStyle_Solid;

	tmpx1 := self.x1.Integer;
	tmpy1 := self.y1.Integer;
	anOffset4 := 2;
	tmpx2 := self.x2.Integer;
	tmpy2 := self.y2.Integer;
	if _theSameAbove then
		anOffset3 := 8;
	else
		anOffset3 := 0;
	endif;
	if _theSamePrev then // the previous point is also the same sub block
		anOffset1:= 2;
		anOffset2 := 4;
	else
		anOffset1:= 0;
		anOffset2 := 2;
	endif;

	theFrame.drawFillColor := _backColour;
	theFrame.drawFilledRectangle(tmpx1 - anOffset1 , tmpy1 - 2 - anOffset3 , tmpx2 , tmpy2,_backColour);
	theFrame.drawFillColor := _foreColour;
	theFrame.drawFilledRectangle(tmpx1 - anOffset2, tmpy1 - 4 - anOffset3, tmpx2 - anOffset4, tmpy2 - 2,_foreColour);

end;</source>
        <Parameter name="_theSamePrev" type="Boolean"/>
        <Parameter name="_theSameAbove" type="Boolean"/>
        <Parameter name="_backColour" type="Integer"/>
        <Parameter name="_foreColour" type="Integer"/>
        <Parameter name="_frame" type="CMUI_GridAreaFrame" usage="input"/>
    </JadeMethod>
    <JadeMethod name="drawReeferGantry" id="6a224149-be30-4e11-b16a-d377b8a2f55d">
        <source>drawReeferGantry(_frame: CMUI_GridAreaFrame input);
// ---------------------------------------------------------------------------
// Created:		June  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	theFrame : CMUI_GridAreaFrame;
	anOffset1, anOffset2, aSlotHeight, aWindowHeight,aColour, idx : Integer;
	aHeight, tmpx1, tmpx2, tmpy1, tmpy2 : Integer;
	aLetter : String;
	aPrevGridPoint : YRD_GridPoint;
	theSamePrev, theSameAbove : Boolean;
	lPicture : Binary;
begin
	theFrame := _frame;
	theSamePrev := false;
	aPrevGridPoint := self.myGridArea.allGridPoints[self.row, self.column - 1].YRD_GridPoint;
	if aPrevGridPoint &lt;&gt; null then
		if aPrevGridPoint.letter = GridPointType_ReeferGantry then // the previous point is also a reefer gantry
			theSamePrev := true;
		endif;
	endif;

	theSameAbove := false;
	aPrevGridPoint := self.myGridArea.allGridPoints[self.row - 1, self.column ].YRD_GridPoint;
	if aPrevGridPoint &lt;&gt; null then
		if aPrevGridPoint.letter = GridPointType_ReeferGantry then // the point above is also a reefer gantry
			theSameAbove := true;
		endif;
	endif;

	self.drawOverLappingRectangle(theSamePrev, theSameAbove, DarkGray, Color_ReeferGantry, theFrame);

	
	//lPicture := app.myRoot.getConfig(PicReeferGantry).Binary;
	theFrame.drawPictureAt(lPicture, self.x1 + 1, self.y1 + 1);

end;</source>
        <Parameter name="_frame" type="CMUI_GridAreaFrame" usage="input"/>
    </JadeMethod>
    <JadeMethod name="drawRestriction" id="c4cc367c-0288-490e-a8cb-5dc463afd467">
        <source>drawRestriction(_label : String;_colour : Integer;_frame : CMUI_GridAreaFrame input; _theX1: Real; _theY1: Real; _theX2: Real; _theY2: Real);
// ---------------------------------------------------------------------------
// Created:		June  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	theFrame : CMUI_GridAreaFrame;
	anOffset1, anOffset2, aSlotHeight, aWindowHeight, idx : Integer;
	aHeight, tmpx1, tmpx2, tmpy1, tmpy2 : Integer;
	aPrevGridPoint : YRD_GridPoint;
	theSamePrev, theSameAbove : Boolean;
	aRest : CM_Restriction;
begin
	theFrame := _frame;

	// ### if cargo is Qd or Pd to a location with a restriction and is then unqueued. 
	//		The Q or P was being left behind the restriction hashing
	//		This code clears that out
	theFrame.drawStyle := Frame.DrawStyle_Dash;
	theFrame.drawFillColor := Gray;
	theFrame.drawFilledRectangle(_theX1, _theY1, _theX2, _theY2, Black);
	
	// ## Draw the restriction
	theFrame.drawFillColor := _colour;
	theFrame.drawFillStyle := Frame.DrawFillStyle_DiagonalCross;
	theFrame.drawFilledRectangle(_theX1, _theY1, _theX2, _theY2, _colour);
epilog
	theFrame.drawFillStyle := Frame.DrawFillStyle_Solid;

end;</source>
        <Parameter name="_label" type="String"/>
        <Parameter name="_colour" type="Integer"/>
        <Parameter name="_frame" type="CMUI_GridAreaFrame" usage="input"/>
        <Parameter name="_theX1" type="Real"/>
        <Parameter name="_theY1" type="Real"/>
        <Parameter name="_theX2" type="Real"/>
        <Parameter name="_theY2" type="Real"/>
    </JadeMethod>
    <JadeMethod name="drawSelf" id="66d6ecc9-1279-46d4-bf41-9df9431ce331">
        <updating/>
        <source>drawSelf(_theFrame: CMUI_GridAreaFrame input) updating;
// ---------------------------------------------------------------------------
// Created:     31 December 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
constants
	FONTSIZE = 6;
vars
	startY, endY		: Real;
	idx, tmpNumTIs,
	theFrameHeight		: Integer;
	theTI, theDummyTI	: CM_TrackedItem;
	lDisplayMode,aColour, theFillColour, letterIndex : Integer;
	aLetter 			: String;
	lTIArray			: CM_TIArray;
	theAttributeArray 	: CMUI_GridAttributesArray;
	theGridAttributes 	: CMUI_GridAttributes;
	theCellHeight, numHalfHeights  : Integer;
	theGridArea 		: CMUI_GridArea;
begin
	if self.heightOfStack = 0 then
		// Nothing to draw
		return;
	endif;
		
	theGridArea := self.myGridArea;
	
	_theFrame.drawFontName 	:= "Arial";
	_theFrame.drawFontSize 	:= FONTSIZE * theGridArea.scaleXFactor;
	_theFrame.drawTextAlign := Frame.DrawTextAlign_Left;
	
	if self.power then 
		theFillColour := self.POWER_FILL_COLOUR;
	else
		theFillColour := Gray;
	endif;

	lDisplayMode 	:= theGridArea.mySDF.displayMode;
	theDummyTI 		:=	theGridArea.myDummyTI;
	theFrameHeight	:= _theFrame.height.Integer;
	
	if lDisplayMode = DISPLAY_MODE_ACTUAL then
		lTIArray 			:= self.allTrackedItems;
		theAttributeArray 	:= self.allTrackedItemAttributes;		

	elseif lDisplayMode = DISPLAY_MODE_QUEUE then
		lTIArray 			:= self.allQueuedTrackedItems;
		theAttributeArray 	:= self.allQueuedTrackedItemAttributes;		

	elseif lDisplayMode = DISPLAY_MODE_PLAN then
		lTIArray 			:= self.allPlannedTrackedItems;
		theAttributeArray 	:= self.allPlanTrackedItemAttributes;		
	endif;
	
	tmpNumTIs			:= lTIArray.size;
	_theFrame.drawWidth	:= 1;

	aColour := self.colour;
	aLetter := self.letter;

	if aLetter = GridPointType_Building then // BUILDING
		self.drawBuilding(_theFrame);

	elseif aLetter = GridPointType_Light then // LIGHT
		self.drawLight(_theFrame);
	
	elseif aLetter = GridPointType_ReeferGantry then // Reefer gantry
		self.drawReeferGantry(_theFrame);

	elseif aLetter[1:4] = GridPointType_SubBlock then // SUB BLOCK STACK
		self.drawSubBlockStack(aLetter[5:end], aColour, _theFrame);

	else
		self.cellHeight := ((self.y2 - self.y1) / self.heightOfStack).Integer;
		numHalfHeights 	:= 0;
		startY 			:= self.y2;
		
		while true do
			idx := idx + 1;
			
			if idx &lt;= tmpNumTIs then
				theTI 				:= lTIArray[idx];
				theGridAttributes 	:= theAttributeArray[idx];
				
				if theGridAttributes.height = Ti_Half_Height then
					numHalfHeights 	:= numHalfHeights + 1;
					theCellHeight 	:= (self.cellHeight / 2).Integer;
				else
					theCellHeight 	:= self.cellHeight.Integer;
				endif;
				startY 	:= startY - theCellHeight ; 
				endY	:= startY + theCellHeight;
				
				if startY &lt; self.y1 then
					break;
				endif;
				
				if theTI &lt;&gt; theDummyTI then
					self.drawTI(_theFrame, theTI, theGridAttributes, self.x1, startY, self.x2, endY);
				endif;
			else
				// #######################
				// OK if going in here then we do not have any TIs in this view mode
				if numHalfHeights mod 2 = 0 then
					theCellHeight := self.cellHeight.Integer; // there have bee an even number of 1/2s so reset now
				else
					theCellHeight := (self.cellHeight / 2).Integer;
				endif;
				
				numHalfHeights 	:= 0;				
				startY 			:= startY - theCellHeight ; 
				
				if startY &lt; self.y1 then
					break;
				endif;
				
				endY			:= startY + theCellHeight;
				theCellHeight 	:= self.cellHeight.Integer; // this may be half height to fill in, so reset it for next time

				if self.myLocationsController.isKindOf(CM_GapController) then
					if theFillColour &lt;&gt; POWER_FILL_COLOUR then
						theFillColour := theGridArea.myGridAreaFrame.backColor;
					endif;
					
					self.drawBlankSpace(theFillColour,idx, _theFrame, self.x1, startY, self.x2, endY - 1); 
				
				elseif self.labourRestrictionID &lt;&gt; null and aLetter &lt;&gt; GridPointType_Unavailable then
					if aLetter = GridPointType_RestHeight then // HEIGHT RESTRICTION
						if idx &gt;= self.heightNoStackFrom then
							self.drawBlankSpace(theFillColour,idx, _theFrame, self.x1, startY, self.x2, endY - 1); 
							self.drawHeight(aLetter, Red, _theFrame, self.x1, startY, self.x2, endY);
						else
							aColour := self.labourRestrictionColour;
							self.drawLabour(aLetter,aColour,_theFrame, self.x1, startY, self.x2, endY);
						endif;
					else
						aColour := self.labourRestrictionColour;
						self.drawLabour(aLetter,aColour,_theFrame, self.x1, startY, self.x2, endY);
					endif;
				
				elseif aLetter = GridPointType_RestHeight then // HEIGHT RESTRICTION
					self.drawBlankSpace(theFillColour,idx, _theFrame, self.x1, startY, self.x2, endY - 1); 
					if idx &gt;= self.heightNoStackFrom then
						self.drawHeight(aLetter, Red, _theFrame, self.x1, startY, self.x2, endY);
					endif;
				
				elseif lDisplayMode &lt;&gt; DISPLAY_MODE_ACTUAL and idx &lt;= self.allTrackedItems.size and self.allTrackedItems.size &gt; 0 then
					self.drawLetter(_theFrame,"A", (self.x1+((self.x2-self.x1)/2)-5).Integer, (startY + 2).Integer, Black,self.x1, startY, self.x2, endY,theFillColour,REAL_MODE,idx);
				else
					if aLetter = GridPointType_Unavailable then
						theFillColour := theGridArea.myGridAreaFrame.backColor;
					endif;
					// fill colour set up top - Gray or Blue
					self.drawBlankSpace(theFillColour,idx, _theFrame, self.x1, self.y1, self.x2, endY ); 
				endif;
				
				// draw the Ps and Qs in addition to the actual TI graphic
				letterIndex := letterIndex + 1;
				
				self.doDrawFMLetter(lDisplayMode, letterIndex, theFillColour, startY, endY, theDummyTI, _theFrame);
			endif;
		endwhile;
	endif;

epilog
	_theFrame.drawFontName 	:= "Arial";
	_theFrame.drawFontSize 	:= FONTSIZE * theGridArea.scaleXFactor;
	_theFrame.drawTextAlign := Frame.DrawTextAlign_Left;
end;</source>
        <Parameter name="_theFrame" type="CMUI_GridAreaFrame" usage="input"/>
    </JadeMethod>
    <JadeMethod name="drawSubBlockStack" id="8e3bef43-91e3-432e-8bee-b7ab2e8c8367">
        <source>drawSubBlockStack(_label: String; _colour: Integer; _frame: CMUI_GridAreaFrame input);
// ---------------------------------------------------------------------------
// Created:		June  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	theFrame : CMUI_GridAreaFrame;
	anOffset1, anOffset2,aSlotHeight, aWindowHeight, idx : Integer;
	aHeight, tmpx1, tmpx2, tmpy1, tmpy2 : Integer;
	aPrevGridPoint : YRD_GridPoint;
	_theSamePrev, theSameAbove : Boolean;
	aTA : CM_TerminalArea;
	theGridArea : CMUI_GridArea;
begin
	theGridArea := self.myGridArea;
	theFrame := _frame;
	aTA := self.mySubBlockStack;
	
	_theSamePrev := false;
	aPrevGridPoint := theGridArea.allGridPoints[self.row, self.column - 1].YRD_GridPoint;
	if aPrevGridPoint &lt;&gt; null then
		if aPrevGridPoint.mySubBlockStack =  aTA then
			_theSamePrev := true;
		endif;
	endif;
	theSameAbove := false;
	aPrevGridPoint := theGridArea.allGridPoints[self.row - 1, self.column].YRD_GridPoint;
	if aPrevGridPoint &lt;&gt; null then
		if aPrevGridPoint.mySubBlockStack = aTA then
			theSameAbove := true;
		endif;
	endif;
	
	self.drawOverLappingRectangle(_theSamePrev,theSameAbove, DarkGray, _colour, theFrame);
	
	if not theGridArea.allTerminalAreas.includes(aTA) then
		theGridArea.allTerminalAreas.add(aTA);
		// Here we are putting in any labels, plus X &amp; Y so that at the end of drawing we can put the sub block stack labels on the grid
		theGridArea.allPointLabels.putAtKey((self.x1 + 1).Integer, (self.y1 + 1).Integer, aTA);
	endif;
end;</source>
        <Parameter name="_label" type="String"/>
        <Parameter name="_colour" type="Integer"/>
        <Parameter name="_frame" type="CMUI_GridAreaFrame" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getExtraInfoForPoint" id="694a1abb-068f-4e3f-9154-8f7abf528ef8">
        <source>getExtraInfoForPoint(x, y: Real; _dataContainer: CM_DataContainer): Object;

// ---------------------------------------------------------------------------
// Created:     22 January 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 25 June 2003 sgp			Use CM_DataContainer to hold data
// 07/11/2012	cnwcs5		par 30475 - remove references to CM_locationRestrictionContainer
// ---------------------------------------------------------------------------
vars
	theTI			: CM_TrackedItem;
	theReturnObject : Object;
	block 			: CM_DataContainerBlock;
	aLR 			: CM_LabourRestriction;
	aSBS 			: CM_SubBlockStack;
begin
	theTI 		:= self.getTI(x, y);
	aSBS 		:= self.mySubBlockStack.CM_SubBlockStack;

	if theTI &lt;&gt; null then	
		theTI.getExtraInfo(_dataContainer);
		theReturnObject := theTI;
	elseif aSBS &lt;&gt; null then
		aSBS.getExtraInfo(_dataContainer);
		theReturnObject := aSBS;
	else
		// ### LABOUR RESTRICTIONS
		if not self.myLocationsController.CM_GridController.allLabourRestrictions.isEmpty then
			foreach aLR in self.myLocationsController.CM_GridController.allLabourRestrictions do
				theReturnObject := aLR;
				
				aLR.getExtraInfo(_dataContainer);
			endforeach;
		endif;
	endif;

	if app.isDevelopmentSystem then
		block := _dataContainer.addNewBlock;
		
		block.addNewItem("Grid Point  ", DC_Label, 1, self);
		block.addNewItem(self.String, DC_Data, 1, self);
	endif;
	
	return theReturnObject;
end;
</source>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
        <Parameter name="_dataContainer" type="CM_DataContainer"/>
        <ReturnType type="Object"/>
    </JadeMethod>
    <JadeMethod name="getTI" id="73a0b4d3-e49c-4962-bed9-4d4dbdcc86f7">
        <source>getTI(x, y : Real) : CM_TrackedItem;
// ---------------------------------------------------------------------------
// Created:     22 January 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	theTI	: CM_TrackedItem;
	rtnStr	: String;
	tmpYPos	: Real;
	numTIs,
	idx		: Integer;
	lTIArray : CM_TIArray;
	lDisplayMode : Integer;
	theAttributeArray : CMUI_GridAttributesArray;
	theGridAttributes : CMUI_GridAttributes;
begin

	if self.myLocationsController = null then
		return theTI;
	endif;
	create lTIArray transient;
	
	lDisplayMode := self.myGridArea.mySDF.displayMode;

	if lDisplayMode = DISPLAY_MODE_ACTUAL then
		theAttributeArray := self.allTrackedItemAttributes;
	elseif lDisplayMode = DISPLAY_MODE_QUEUE then
		theAttributeArray := self.allQueuedTrackedItemAttributes;
	elseif lDisplayMode = DISPLAY_MODE_PLAN then
		theAttributeArray := self.allPlanTrackedItemAttributes;
	endif;
	
	if lDisplayMode = DISPLAY_MODE_ACTUAL then
		self.myLocationsController.getTIs(lTIArray, REAL_MODE, true); // PAR 27749
	elseif lDisplayMode = DISPLAY_MODE_QUEUE then
		self.myLocationsController.getTIs(lTIArray, QUEUE_MODE, true); // PAR 27749
	elseif lDisplayMode = DISPLAY_MODE_PLAN then
		self.myLocationsController.getTIs(lTIArray, PLANNING_MODE, true); // PAR 27749
	endif;
	
	if lTIArray.size = 0 then
		return theTI;
	endif;

	numTIs := lTIArray.size;
	tmpYPos := self.y2;
	foreach idx in 1 to numTIs do
		if idx &gt;  theAttributeArray.size then
			continue;
		endif;
		theGridAttributes := theAttributeArray[idx];
		if theGridAttributes.height = Ti_Half_Height then
			tmpYPos := tmpYPos - (self.cellHeight / 2);
		else
			tmpYPos := tmpYPos - self.cellHeight;
		endif;

		if y &gt;= tmpYPos then
			theTI := lTIArray[idx];
			break;
		endif;
	endforeach;

	return theTI;
epilog
	delete lTIArray;
end;</source>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
        <ReturnType type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="selectTIsWithinXYs" id="fb005d09-ab07-4949-8ad3-8f32f5e5a3af">
        <source>selectTIsWithinXYs(_x1: Integer; _y1: Integer; _x2: Integer; _y2: Integer);
// ---------------------------------------------------------------------------
// Created:		May 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	theTI	: CM_TrackedItem;
	rtnStr	: String;
	tmpYPos	: Real;
	numTIs,
	idx		: Integer;
	lTIArray : CM_TIArray;
	lDisplayMode : Integer;
	theAttributeArray : CMUI_GridAttributesArray;
	theGridAttributes : CMUI_GridAttributes;
begin

	if self.myLocationsController = null then
		return;
	endif;
	create lTIArray transient;
	
	lDisplayMode := self.myGridArea.mySDF.displayMode;

	if lDisplayMode = DISPLAY_MODE_ACTUAL then
		theAttributeArray := self.allTrackedItemAttributes;
	elseif lDisplayMode = DISPLAY_MODE_QUEUE then
		theAttributeArray := self.allQueuedTrackedItemAttributes;
	elseif lDisplayMode = DISPLAY_MODE_PLAN then
		theAttributeArray := self.allPlanTrackedItemAttributes;
	endif;
	
	if lDisplayMode = DISPLAY_MODE_ACTUAL then
		self.myLocationsController.getTIs(lTIArray, REAL_MODE, true); // PAR 27749
	elseif lDisplayMode = DISPLAY_MODE_QUEUE then
		self.myLocationsController.getTIs(lTIArray, QUEUE_MODE, true); // PAR 27749
	elseif lDisplayMode = DISPLAY_MODE_PLAN then
		self.myLocationsController.getTIs(lTIArray, PLANNING_MODE, true); // PAR 27749
	endif;
	
	if lTIArray.size = 0 then
		return ;
	endif;

	numTIs := lTIArray.size;
	tmpYPos := self.y2;
	foreach idx in 1 to numTIs do
		if idx &gt;  theAttributeArray.size then
			continue;
		endif;
		theGridAttributes := theAttributeArray[idx];
		if theGridAttributes.height = Ti_Half_Height then
			tmpYPos := tmpYPos - (self.cellHeight / 2);
		else
			tmpYPos := tmpYPos - self.cellHeight;
		endif;

		if _y1 &lt;= tmpYPos and _y2 &gt;= tmpYPos then
			theTI := lTIArray[idx];
			self.myGridArea.addTIToSelected(theTI);
		endif;
	endforeach;


epilog
	delete lTIArray;

end;</source>
        <Parameter name="_x1" type="Integer"/>
        <Parameter name="_y1" type="Integer"/>
        <Parameter name="_x2" type="Integer"/>
        <Parameter name="_y2" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="7b6fdc61-ffae-4d1a-bc64-7bfc24586963">
        <updating/>
        <source>setForCreate(pController : CM_GridController; pGridArea : YRD_GridArea; 
			_controller : CMIF_DrawingAttrController input; _theTIs : CM_TIArray input) updating;
// ---------------------------------------------------------------------------
// Created:     28 December 2001 by cnwrs2
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 07/11/2012	cnwcs5		par 30475 - remove references to cm_LocationRestricContainer
// 29/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
// ---------------------------------------------------------------------------
vars
	tmpStr 				: String;
	idx					: Integer;
	aTI					: CM_TrackedItem;
	aSubBlockStack		: CM_BlockStack;
	aGapController		: CM_GapController;
	anLC 				: CM_LocationsController;
	tmpDummyTI			: CM_Container;
	tmpGridController	: CM_GridController;
	tmpTIs				: CM_TIArray;
	tmpData,tmpTIData,
	tmpArray			: StringArray512;
	
begin
	self.myLocationsController := pController;
	tmpGridController := pController.CM_GridController;
	
	aSubBlockStack := tmpGridController.mySubBlockStack;

	if pController.isKindOf(CM_GapController) then
		// this gap controller has no column to go in, because the column width is zero so we did not create a column
		if pGridArea.allGridColumns[pController.column] = null then
			return;
		endif;
		
		// gaps do not have sub block stacks, however if we have a sub block either side of this gap and
		// they are the same then we will populate so that the display is correct
		aGapController := pController.CM_GapController;
		anLC := aGapController.getPreviousControllerOfType(CM_StackController);
		if anLC &lt;&gt; null and anLC.CM_StackController.mySubBlockStack &lt;&gt; null then 
			aSubBlockStack := anLC.CM_StackController.mySubBlockStack;
			anLC := aGapController.getNextControllerOfType(CM_StackController);
			if anLC &lt;&gt; null and anLC.CM_StackController.mySubBlockStack &lt;&gt; null then 
				if aSubBlockStack &lt;&gt; anLC.CM_StackController.mySubBlockStack then
					aSubBlockStack := null;
				endif;
			else
				aSubBlockStack := null;
			endif;
		endif;
	endif;
	
	self.width				:= pController.width;
	self.heightOfStack		:= pController.getMaxHeight();
	self.heightNoStackFrom 	:= pController.getHeightNoStackFrom();

	tmpDummyTI := pGridArea.myDummyTI;
	
	_theTIs.clear;

	//pController.getTIs(_theTIs, REAL_MODE);
	tmpTIs := pController.allTrackedItems;
	// Only include those TIs where my controller is their primary location

	/* PAR 9720 WAS
	foreach aTI in tmpTIs do
		self.setForCreateTI(aTI, REAL_MODE, _controller);
		if aTI.myPrimaryActualLocation = pController then
			self.allTrackedItems.add(aTI);
		else
			// add in the dummy TI, this allows us to draw correctly for TIs spanning more than one point
			self.allTrackedItems.add(tmpDummyTI);
		endif;
	endforeach;
	
	NOW from here. Get and populate the same way as they are when they are created, when the screen is first built*/
	create tmpData transient;
	create tmpArray transient;
	create tmpTIData transient;

	pController.getGridTIsArray(tmpData, GridData_TI_Actual, _controller, null, REAL_MODE);
	idx := 0;
	foreach aTI in tmpTIs do
		idx := idx + 1; 
		if idx &lt;= tmpData.size then 
			tmpStr := tmpData[idx]; 
			tmpTIData.clear;  
			tmpStr.getTokensForDelimiter(GridData_Delimiter, tmpTIData); 
			self.setForCreateTI_Array(tmpTIData, REAL_MODE, _controller, tmpArray); 
		endif;
	endforeach;
	// ### PAR 9720 to here

	// Get all the TIs that are QUEUED here
	_theTIs.clear;
	// Only include those TIs where my controller is their primary location
	/* PAR 9720 WAS
	pController.getTIs(_theTIs, QUEUE_MODE);
	foreach aTI in _theTIs do
		self.setForCreateTI(aTI, QUEUE_MODE, _controller);
		if aTI.myPrimaryQueuedLocation = pController then
			self.allQueuedTrackedItems.add(aTI);
		else
			// add in the dummy TI, this allows us to draw correctly for TIs spanning more than one point
			self.allQueuedTrackedItems.add(tmpDummyTI);
		endif;
	endforeach;
	NOW from here. Get and populate the same way as they are when they are created, when the screen is first built*/
	tmpData.clear;
	tmpArray.clear;
	tmpTIData.clear;

	pController.getGridTIsArray(tmpData, GridData_TI_Queued, _controller, _theTIs, QUEUE_MODE);
	idx := 0;
	foreach aTI in _theTIs do
		idx := idx + 1; 
		if idx &lt;= tmpData.size then 
			tmpStr := tmpData[idx]; 
			tmpTIData.clear;  
			tmpStr.getTokensForDelimiter(GridData_Delimiter, tmpTIData); 
			self.setForCreateTI_Array(tmpTIData, QUEUE_MODE, _controller, tmpArray); 
		endif;
	endforeach;
	// ### PAR 9720 to here

	// Get all the TIs that are PLANNED here
	_theTIs.clear;
	// Only include those TIs where my controller is their primary location
	/* PAR 9720 WAS
	pController.getTIs(_theTIs, PLANNING_MODE);
	foreach aTI in _theTIs do
		self.setForCreateTI(aTI, PLANNING_MODE, _controller);

		if aTI.isRehandle then
			// need to get discharge one
			tmpLC := aTI.getRehandleDischPrimaryLocn();
			if tmpLC = null then
				tmpLC := aTI.myPrimaryPlannedLocation;
			endif;
		else
			tmpLC := aTI.myPrimaryPlannedLocation;
		endif;
//		if aTI.myPrimaryPlannedLocation = pController then
		if tmpLC = pController then
			self.allPlannedTrackedItems.add(aTI);
		else
			// add in the dummy TI, this allows us to draw correctly for TIs spanning more than one point
			self.allPlannedTrackedItems.add(tmpDummyTI);
		endif;
	endforeach;
	NOW from here. Get and populate the same way as they are when they are created, when the screen is first built*/
	tmpData.clear;
	tmpArray.clear;
	tmpTIData.clear;

	pController.getGridTIsArray(tmpData, GridData_TI_Planned, _controller, _theTIs, PLANNING_MODE);
	idx := 0;
	foreach aTI in _theTIs do
		idx := idx + 1; 
		if idx &lt;= tmpData.size then 
			tmpStr := tmpData[idx]; 
			tmpTIData.clear;  
			tmpStr.getTokensForDelimiter(GridData_Delimiter, tmpTIData); 
			//tmpTIData[2].Integer.Boolean

			self.setForCreateTI_Array(tmpTIData, PLANNING_MODE, _controller, tmpArray); 
		endif;
	endforeach;
	// ### PAR 9720 to here



	pController.getDrawingAttributes(0, 0, 0, self.colour, self.letter);	
	self.power := pController.hasPower();
	
	self.mySubBlockStack :=  aSubBlockStack;
	if aSubBlockStack &lt;&gt; null then
		if aSubBlockStack.myLayoutGraphic &lt;&gt; null then
			self.subBlockStackColour := aSubBlockStack.myLayoutGraphic.drawLineColour;
		else
			self.subBlockStackColour := NullColour;
		endif;
	endif;
	if pController.isKindOf(CM_GapController) and aSubBlockStack &lt;&gt; null then
		self.colour := aSubBlockStack.myLayoutGraphic.drawLineColour;
		self.letter := GridPointType_SubBlock &amp; aSubBlockStack.id;
	endif;

	if self.myGridColumn = null then // not in update
		self.setForCreateSuperClass(pGridArea, pController.row, pController.column);
	endif;

	if not tmpGridController.allLabourRestrictions.isEmpty then
		self.labourRestrictionColour := tmpGridController.allLabourRestrictions.first.colour; 
		self.labourRestrictionID := tmpGridController.allLabourRestrictions.first.id;
	else
		self.labourRestrictionColour := NullColour;
		self.labourRestrictionID := null;
	endif;
epilog
	delete tmpTIData ;
	delete tmpData ;
	delete tmpArray ;

end;</source>
        <Parameter name="pController" type="CM_GridController"/>
        <Parameter name="pGridArea" type="YRD_GridArea"/>
        <Parameter name="_controller" type="CMIF_DrawingAttrController" usage="input"/>
        <Parameter name="_theTIs" type="CM_TIArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setForCreateArray" id="b7bf8c04-e3bf-4112-9a2e-661d0354150a">
        <updating/>
        <source>setForCreateArray(_array : StringArray; _theGridArea : YRD_GridArea) updating;
// ---------------------------------------------------------------------------
// Created:     28 December 2001 by cnwrs2
//
// ---------------------------------------------------------------------------
// 07/11/2012	cnwcs5		par 30475 - remove references to cm_LocationRestricContainer
vars
	theRow, theCol		: Integer;

begin
	self.myLocationsController	:= _array[2].asOid.CM_LocationsController;

	theRow 						:= _array[3].Integer;  
	theCol 						:= _array[4].Integer;  

	self.label 					:= _array[5];
	self.width					:= _array[6].Integer; 
	self.heightOfStack			:= _array[7].Integer; 
	self.heightNoStackFrom 		:= _array[8].Integer; 
	self.power 					:= _array[9].Integer.Boolean;
	
	self.colour 				:= _array[11].Integer;
	self.letter  				:= _array[12];
	self.mySubBlockStack 		:= _array[13].asOid.CM_BlockStack;
	self.subBlockStackColour 	:= _array[14].Integer;
	self.subBlockStackID 		:= null;
	self.labourRestrictionColour	:= _array[16].Integer;
	self.labourRestrictionID 	:= _array[17];

	self.myGridColumn 	:= _theGridArea.allGridColumns[theCol];
	self.myGridRow		:= _theGridArea.allGridRows[theRow];
	self.myGridArea 	:= _theGridArea;
end;</source>
        <Parameter name="_array" type="StringArray"/>
        <Parameter name="_theGridArea" type="YRD_GridArea"/>
    </JadeMethod>
    <JadeMethod name="setForCreateTI" id="8af6ae52-7dcb-4ef7-a5d4-033132045d17">
        <updating/>
        <source>setForCreateTI(_theTI: CM_TrackedItem; _theMode: Integer; _controller: CMIF_DrawingAttrController input) updating;
// ---------------------------------------------------------------------------
// Created:		November 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
// 29/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
vars
	aGridAttributes : CMUI_GridAttributes;

begin
	create aGridAttributes transient;

	if _theMode = REAL_MODE then
		self.allTrackedItemAttributes.add(aGridAttributes);
	elseif _theMode = QUEUE_MODE then
		self.allQueuedTrackedItemAttributes.add(aGridAttributes);
	elseif _theMode = PLANNING_MODE then
		self.allPlanTrackedItemAttributes.add(aGridAttributes);
	endif;
	_theTI.getAllDrawingAttributes(aGridAttributes, _controller);

	if aGridAttributes.width &lt; 1 then
		aGridAttributes.width := 1;
	endif;
		aGridAttributes.width := (aGridAttributes.width / 2).Integer;


end;</source>
        <Parameter name="_theTI" type="CM_TrackedItem"/>
        <Parameter name="_theMode" type="Integer"/>
        <Parameter name="_controller" type="CMIF_DrawingAttrController" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setForCreateXML" id="21ff7e31-6b89-4013-8e34-a420821a23e9">
        <updating/>
        <source>setForCreateXML(_theXML : String; _theGridArea : YRD_GridArea) updating;
// ---------------------------------------------------------------------------
// Created:     28 December 2001 by cnwrs2
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 07/11/2012	cnwcs5		par 30475 - remove references to cm_LocationRestricContainer
// ---------------------------------------------------------------------------
vars
	theRow, theCol 			: Integer;
	pos 					: Integer;
	theXMLString, theXMLTag : String;
begin
	theRow := _theXML.cnEcGetTagValueOfName("ROW").Integer;  
	theCol := _theXML.cnEcGetTagValueOfName("COL").Integer;  

	self.myGridColumn 	:= _theGridArea.allGridColumns[theCol];
	self.myGridRow		:= _theGridArea.allGridRows[theRow];
	self.myGridArea 	:= _theGridArea;

	self.label 					:= _theXML.cnEcGetTagValueOfName("ID");
	self.myLocationsController 	:= _theXML.cnEcGetTagValueOfName("OID").asOid.CM_LocationsController;
	
	self.width					:= _theXML.cnEcGetTagValueOfName("WTH").Integer; 
	self.heightOfStack			:= _theXML.cnEcGetTagValueOfName("MAX").Integer; 
	self.heightNoStackFrom 		:= _theXML.cnEcGetTagValueOfName("NOF").Integer; 
	self.power 					:= _theXML.cnEcGetTagValueOfName("PWR").Integer.Boolean;

	// ### REAL TRACKED ITEMS
	theXMLString := _theXML.cnEcGetTagValueOfName("REAL");
	pos := 1;
	while (pos &lt;&gt; 0) do
		theXMLTag := theXMLString.cnEcGetNextTagValueOfName("TI",pos);  
		if pos = 0 then
			break;
		endif;
		self.setForCreateTIXML(theXMLTag,REAL_MODE);
	endwhile;
	
	// ### PLANNED TRACKED ITEMS
	theXMLString := _theXML.cnEcGetTagValueOfName("PLAN");
	pos := 1;
	while (pos &lt;&gt; 0) do
		theXMLTag := theXMLString.cnEcGetNextTagValueOfName("TI",pos);  
		if pos = 0 then
			break;
		endif;
		self.setForCreateTIXML(theXMLTag,PLANNING_MODE);
	endwhile;

	// ### PLANNED TRACKED ITEMS
	theXMLString := _theXML.cnEcGetTagValueOfName("QUEUE");
	pos := 1;
	while (pos &lt;&gt; 0) do
		theXMLTag := theXMLString.cnEcGetNextTagValueOfName("TI",pos);  
		if pos = 0 then
			break;
		endif;
		self.setForCreateTIXML(theXMLTag,QUEUE_MODE);
	endwhile;
	
	self.colour 			:= _theXML.cnEcGetTagValueOfName("CLR").Integer;
	self.letter 			:= _theXML.cnEcGetTagValueOfName("LTR");
	self.mySubBlockStack 	:=  _theXML.cnEcGetTagValueOfName("SBS").asOid.CM_BlockStack;
	
epilog
end;</source>
        <Parameter name="_theXML" type="String"/>
        <Parameter name="_theGridArea" type="YRD_GridArea"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="2308b94d-1049-473a-a7f5-9654f7766cbc">
        <updating/>
        <source>setForUpdate(_controller : CMIF_DrawingAttrController input) updating;
// ---------------------------------------------------------------------------
// Created:		September  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	theTIs	: CM_TIArray;
	
begin
	inheritMethod(_controller);

	create theTIs transient;
	
	self.setForCreate(self.myLocationsController.CM_GridController, 
					self.myGridArea.YRD_GridArea, _controller, theTIs);
	self.myGridArea.mySDF.myParentForm.sendMsgWithParams("doNoteForObject", self); // this will update the macro info table

epilog
	delete theTIs;
end;</source>
        <Parameter name="_controller" type="CMIF_DrawingAttrController" usage="input"/>
    </JadeMethod>
</Class>
