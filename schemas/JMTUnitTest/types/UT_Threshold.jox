    <JadeMethod name="addCargo" id="86e38dbb-c051-44fe-93fb-cf2d6f8e31dd">
        <source>addCargo(	_id : String;
			_isoType: String;
			_mtGrade : CM_MTGrade;
			_operator : CM_Operator;
			_toDo : CM_ToDoTaskDesc;
			_ta : CM_TerminalAreaMaster
			):CM_TrackedItem protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
23 June 2011	cnwndl1	Initial creation	Par 27731

*/

vars

	ti : CM_TrackedItem;
	pxyTI : CM_TrackedItem;
	tiTask : CM_ToDoTask;

begin

	//create bare bones container.
	self.deleteContainer(_id);
	ti := createContainer(	_id,	//id: String;
							_isoType,	//_isoType: String;
							"MT",	//_commodity: String;
							_operator,	//_operator: CM_Operator;
							false
							);
							
	// set up Mt grade
	if _mtGrade &lt;&gt; null then
		pxyTI := app.createUpdateProxy(ti).CM_TrackedItem;
		pxyTI.setPxyFromFieldValue(CM_EDICargoFieldUpdateTI.F_AvailabilityGrade, _mtGrade.code.String, null, app.myPassport);
		app.myTrxUA.trxUpdateTrackedItem(pxyTI,	null, TI_UPDMODE_NORMAL, null, app.myPassport);
		self.assertTrueMsg(app.myPassport.trxCompletedOK(), "[ Ti.id = " &amp; _id &amp; " ]" &amp; app.myPassport.getAllErrorsWarningsAsString());
		delete pxyTI;
	endif;
	
	//add todo task to the new ti.
	if _toDo &lt;&gt; null then
		beginTransaction;
		tiTask := ti.addToDoTask( _toDo.description.trimBlanks , app.myPassport );
		commitTransaction;
		self.assertTrueMsg(tiTask &lt;&gt; null, "Task '" &amp; _toDo.description.trimBlanks &amp; "' not created for '" &amp; _id &amp; "'.");
	endif;
	
	//move it to the appropriate terminal area
	if _ta &lt;&gt; null then
		self.move( ti, _ta);
	endif;
	
	return ti;

epilog

	delete pxyTI;

end;</source>
        <access>protected</access>
        <Parameter name="_id" type="String"/>
        <Parameter name="_isoType" type="String"/>
        <Parameter name="_mtGrade" type="CM_MTGrade"/>
        <Parameter name="_operator" type="CM_Operator"/>
        <Parameter name="_toDo" type="CM_ToDoTaskDesc"/>
        <Parameter name="_ta" type="CM_TerminalAreaMaster"/>
        <ReturnType type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="addMTThreshold" id="6d93768d-62d4-4058-932d-649ee34b6115">
        <source>addMTThreshold(_term : CM_Terminal;
			   _iSOTypeGroup : CM_ISOTypeGroup;
			   _mTGrade : CM_MTGrade;
			   _operator : CM_Operator
			   ) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		TFS		Reason
17 Sep 2019	jlgdi1	46124	Initial creation

*/

vars
	proxyThreshold : CM_MTThreshold;
	isActive : Boolean;
	maxLevel : Integer;
	minLevel : Integer;
	iSOTypeGroup : CM_ISOTypeGroup;
	mTGrade : CM_MTGrade;
	operator : CM_Operator;
	priority : Integer;
	reNotifyMins : Integer;
	thresh : CM_MTThreshold;

begin
	isActive := true;
	maxLevel := 2;
	minLevel := 1;
	iSOTypeGroup := _iSOTypeGroup;
	mTGrade := _mTGrade;
	operator := _operator;	
	reNotifyMins := 10;

	create proxyThreshold transient;
	priority := self.getNextPriorityNumber();
	proxyThreshold.setProxy(	isActive,	//_isActive : Boolean;
								maxLevel,	//_maxThresholdLevel : Integer;
								minLevel,	//_minThresholdLevel : Integer;
								iSOTypeGroup,	//_myISOTypeGroup : CM_ISOTypeGroup;
								operator,	//_myOperator : CM_Operator;
								priority,	//_processingPriority : Integer;
								reNotifyMins,	//_reNotificationMinutes : Integer;
								_term	//_myTerminal : CM_Terminal
								);
	proxyThreshold.setMyMTGrade(mTGrade);
	
	app.myTrxCA.trxCreateThreshold(proxyThreshold, thresh, app.myPassport);
	self.assertTrueMsg(app.myPassport.trxCompletedOK(), app.myPassport.getAllErrorsWarningsAsString());	
	
epilog
	delete proxyThreshold;
end;</source>
        <access>protected</access>
        <Parameter name="_term" type="CM_Terminal"/>
        <Parameter name="_iSOTypeGroup" type="CM_ISOTypeGroup"/>
        <Parameter name="_mTGrade" type="CM_MTGrade"/>
        <Parameter name="_operator" type="CM_Operator"/>
    </JadeMethod>
    <JadeMethod name="addMTThresholds" id="d21d2b0b-a551-4fd3-b491-328f64acdb68">
        <source>addMTThresholds(	_term : CM_Terminal;
					_iSOTypeGroup : CM_ISOTypeGroup;
					_mTGrade : CM_MTGrade;
					_operator : CM_Operator
					) protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
23 June 2011	cnwndl1	Initial creation	Par 27731

*/

vars

	proxyThreshold : CM_MTThreshold;
	isActive : Boolean;
	maxLevel : Integer;
	minLevel : Integer;
	iSOTypeGroup : CM_ISOTypeGroup;
	mTGrade : CM_MTGrade;
	operator : CM_Operator;
	priority : Integer;
	reNotifyMins : Integer;
	thresh : CM_MTThreshold;

begin

	isActive := true;
	maxLevel := 2;
	minLevel := 1;
	iSOTypeGroup := _iSOTypeGroup;
	mTGrade := _mTGrade;
	operator := _operator;
	priority := 0;
	reNotifyMins := 10;


	create proxyThreshold transient;
	priority := 1;
	proxyThreshold.setProxy(	isActive,	//_isActive : Boolean;
								maxLevel,	//_maxThresholdLevel : Integer;
								minLevel,	//_minThresholdLevel : Integer;
								iSOTypeGroup,	//_myISOTypeGroup : CM_ISOTypeGroup;
								operator,	//_myOperator : CM_Operator;
								priority,	//_processingPriority : Integer;
								reNotifyMins,	//_reNotificationMinutes : Integer;
								_term	//_myTerminal : CM_Terminal
								);
	proxyThreshold.setMyMTGrade(mTGrade);
	
	app.myTrxCA.trxCreateThreshold(proxyThreshold, thresh, app.myPassport);
	self.assertTrueMsg(app.myPassport.trxCompletedOK(), app.myPassport.getAllErrorsWarningsAsString());	
	delete proxyThreshold;
	
	create proxyThreshold transient;
	priority := 2;
	mTGrade := null;
	proxyThreshold.setProxy(	isActive,	//_isActive : Boolean;
								maxLevel,	//_maxThresholdLevel : Integer;
								minLevel,	//_minThresholdLevel : Integer;
								iSOTypeGroup,	//_myISOTypeGroup : CM_ISOTypeGroup;
								operator,	//_myOperator : CM_Operator;
								priority,	//_processingPriority : Integer;
								reNotifyMins,	//_reNotificationMinutes : Integer;
								_term	//_myTerminal : CM_Terminal
								);
	proxyThreshold.setMyMTGrade(mTGrade);
	
	app.myTrxCA.trxCreateThreshold(proxyThreshold, thresh, app.myPassport);
	self.assertTrueMsg(app.myPassport.trxCompletedOK(), app.myPassport.getAllErrorsWarningsAsString());	
	delete proxyThreshold;
	
	create proxyThreshold transient;
	priority := 3;
	iSOTypeGroup := null;
	proxyThreshold.setProxy(	isActive,	//_isActive : Boolean;
								maxLevel,	//_maxThresholdLevel : Integer;
								minLevel,	//_minThresholdLevel : Integer;
								iSOTypeGroup,	//_myISOTypeGroup : CM_ISOTypeGroup;
								operator,	//_myOperator : CM_Operator;
								priority,	//_processingPriority : Integer;
								reNotifyMins,	//_reNotificationMinutes : Integer;
								_term	//_myTerminal : CM_Terminal
								);
	proxyThreshold.setMyMTGrade(mTGrade);
	
	app.myTrxCA.trxCreateThreshold(proxyThreshold, thresh, app.myPassport);
	self.assertTrueMsg(app.myPassport.trxCompletedOK(), app.myPassport.getAllErrorsWarningsAsString());	
	delete proxyThreshold;
	
	create proxyThreshold transient;
	priority := 5;
	operator := null;
	proxyThreshold.setProxy(	isActive,	//_isActive : Boolean;
								maxLevel,	//_maxThresholdLevel : Integer;
								minLevel,	//_minThresholdLevel : Integer;
								iSOTypeGroup,	//_myISOTypeGroup : CM_ISOTypeGroup;
								operator,	//_myOperator : CM_Operator;
								priority,	//_processingPriority : Integer;
								reNotifyMins,	//_reNotificationMinutes : Integer;
								_term	//_myTerminal : CM_Terminal
								);
	proxyThreshold.setMyMTGrade(mTGrade);
	
	app.myTrxCA.trxCreateThreshold(proxyThreshold, thresh, app.myPassport);
	self.assertTrueMsg(app.myPassport.trxCompletedOK(), app.myPassport.getAllErrorsWarningsAsString());	
	delete proxyThreshold;
	
	create proxyThreshold transient;
	priority := 4;
	iSOTypeGroup := app.myRoot.allISOTypeGroups.getAtKey("40BX");
	proxyThreshold.setProxy(	false,	//_isActive : Boolean;
								maxLevel,	//_maxThresholdLevel : Integer;
								minLevel,	//_minThresholdLevel : Integer;
								iSOTypeGroup,	//_myISOTypeGroup : CM_ISOTypeGroup;
								operator,	//_myOperator : CM_Operator;
								priority,	//_processingPriority : Integer;
								reNotifyMins,	//_reNotificationMinutes : Integer;
								_term	//_myTerminal : CM_Terminal
								);
	proxyThreshold.setMyMTGrade(mTGrade);
	
	app.myTrxCA.trxCreateThreshold(proxyThreshold, thresh, app.myPassport);
	self.assertTrueMsg(app.myPassport.trxCompletedOK(), app.myPassport.getAllErrorsWarningsAsString());	
	delete proxyThreshold;
	
	
epilog

	delete proxyThreshold;

end;</source>
        <access>protected</access>
        <Parameter name="_term" type="CM_Terminal"/>
        <Parameter name="_iSOTypeGroup" type="CM_ISOTypeGroup"/>
        <Parameter name="_mTGrade" type="CM_MTGrade"/>
        <Parameter name="_operator" type="CM_Operator"/>
