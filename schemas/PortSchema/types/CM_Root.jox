    <JadeMethod name="setStateData" id="3d73f42a-69ec-4cbc-822c-64ed6801dd47">
        <source>setStateData(pGroup : Integer; pKey : String; pValue : Any);
// ---------------------------------------------------------------------------
// Created:     21 March 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	stateObj	: CM_StateObject;
	result			: Real;
begin

	if pGroup &lt; 1 then
		return;
	endif;
	
	if pGroup &lt;= self.allStateObjects.size then
		stateObj := self.allStateObjects[pGroup];
	endif;
	
	if stateObj = null then
		// create and add into array
		create stateObj persistent;
		self.allStateObjects.atPut(pGroup, stateObj);
	endif;
	/*
	if app.isDevelopmentSystem and pKey = AppBackgroundColor then
		app.writeLog(app.computerName &amp; ' changed the application color to ' &amp; pValue.String, LogAlways);
		if app.myCnCntrl &lt;&gt; null then
			app.myCnCntrl.cnWriteLog(app.myCnCntrl.CnLogComment, app.computerName &amp; ' changed the application color to ' &amp; pValue.String, null);	
		endif;
		if app.msgBox('TH2 is trying to track down a bug where the application back color is getting reset when its not supposed to.' &amp;
					'Did you mean to change the application back color?', 'Debug question in dev only', MsgBox_Yes_No) &lt;&gt; MsgBox_Return_Yes then	
			result := 1/0;//make it dump so we get the stack
		endif;
		
	endif;
	*/
	stateObj.setStateData(pKey, pValue, true);

end;</source>
        <Parameter name="pGroup" type="Integer"/>
        <Parameter name="pKey" type="String"/>
        <Parameter name="pValue" type="Any"/>
    </JadeMethod>
    <JadeMethod name="setStateObject" id="5e828a5d-e249-479c-a814-424acfd315a1">
        <source>setStateObject(pGroup : Integer; pProxyStateObject : CM_StateObject; _passport : CM_Passport input);
// ---------------------------------------------------------------------------
// Created:     09 July 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
