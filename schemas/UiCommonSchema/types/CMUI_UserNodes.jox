    <JadeMethod name="setTableDataFromOrganiser" id="21ccfdb7-3f04-4306-b9dd-d2341f0ff50d">
        <updating/>
        <source>setTableDataFromOrganiser(_theTable: CM_DataTable input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
18 September 2023	navmd1	Initial creation TFS 60524

*/

vars
	
begin
	if _theTable.rows &lt;= _theTable.fixedRows then
		return;	// No data loaded, return early
	endif;

	if self.viewMode = CMUI_UserNodes.ViewMode_Users then
		self.doDisplayNodes();
	endif;

epilog

end;</source>
        <Parameter name="_theTable" type="CM_DataTable" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setupForm" id="3b31da9d-d669-4dd8-885d-39a69419c2c8">
        <updating/>
        <source>setupForm() updating;
// ---------------------------------------------------------------------------
// Created:		June  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
begin
	self.setNavigatorHeading(self.caption); 
	self.lblPrint.visible := false;
	self.frmPrint.visible := false;

	self.toolbarStyle := self.ToolbarStyle_ShowNoHide;
	self.showToolbar := true;
	self.frmToolbar.priorityRight := true;
	
	self.frmLockDetails.left := 0;
	
	self.initTableNodes();
	self.locksTableInit();
	// Register for user changes.
	
	if app.getMyUser().canDo(null, PmViewOtherUsersScreens) then
		self.mnuTblNodesShowScreen.visible := true;
	else
		self.mnuTblNodesShowScreen.visible := false;
	endif;
	
	self.switchViewMode(ViewMode_Users);
	
	self.doResize();
	
	// TFS 2101 CNWAB1
	if not app.myCurrentUserCan(null, self.permissionMaint) then
		self.btnTermNode.enabled := false;
		self.btnTermProcess.enabled := false;
		self.mnuTblNodesSendReq.visible := false;
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="switchViewLocksMode" id="8aa13bf6-d12a-4253-9df1-d7fd3a190f46">
        <updating/>
        <source>switchViewLocksMode(_newMode : Integer) updating;
// ---------------------------------------------------------------------------
// Created:     14 October 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	entTblDef	: EntTableDef;

begin

	app.mousePointer := MousePointer_HourGlass;

	self.viewLocksMode := _newMode;
	
	if _newMode = self.ViewLocksBy_Table then
		if self.tblLocks.myEntTableDef = null then
			// need to initialise for first time use
			entTblDef := app.myController.getEntTableDef(ETDef_LockTransMain);
			self.tblLocks.setTblDataEntRowsFromDef(entTblDef);
		endif;

		self.locksTableDisplay();

		// then hide/show the controls
		self.grfLocks.visible := false;
		self.tblLocks.visible := true;
	else
		self.locksGraphDisplay();
		
		// then hide/show the controls
		self.grfLocks.visible := true;
		self.tblLocks.visible := false;
	endif;

epilog
	app.mousePointer := MousePointer_Default;

end;</source>
        <Parameter name="_newMode" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="switchViewMode" id="666bdcb3-2437-4987-9edf-6d93b2aced77">
        <updating/>
        <source>switchViewMode(_newMode : Integer) updating;
// ---------------------------------------------------------------------------
// Created:     13 October 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	captionStr	: String;

begin

	self.viewMode	:= _newMode;
	
	self.btnTermNode.enabled	:= (_newMode = ViewMode_Users);
	self.btnTermProcess.enabled	:= (_newMode = ViewMode_Users);
	
	self.endNotificationForSubscriber(self);
	
	if _newMode = ViewMode_Locks then
		captionStr := app.getErrorString(CMUI_UserNodes_LockCaption);
		if (not self.txtDateFrom.getDate().isValid) then
			// have not viewed locks yet
			self.locksInit();
		endif;
	else
		captionStr := app.getErrorString(CMUI_UserNodes_UsersCaption);
		self.beginClassNotification(Process, false, Object_Create_Event, Response_Continuous, null);
		self.beginClassNotification(Process, false, Object_Delete_Event, Response_Continuous, null);
		self.beginClassNotification(Process, false, Event_ProcessUserCodeUpdate, Response_Continuous, null);
		self.beginClassNotification(Process, false, EVENT_APP_LOG_LEVEL_Resp, Response_Continuous, null);	//29 Nov 2019	NDL	TFS 47053
	endif;
	
	self.tblNodes.visible := (_newMode = ViewMode_Users);
	self.frmLockDetails.visible := (_newMode = ViewMode_Locks);

	self.caption := captionStr;
	self.setNavigatorHeading(captionStr);

end;</source>
        <Parameter name="_newMode" type="Integer"/>
    </JadeMethod>
