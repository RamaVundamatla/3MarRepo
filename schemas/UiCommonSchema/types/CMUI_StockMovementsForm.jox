    <JadeMethod name="doViewCargoDetails" id="26e81cd8-9a16-40f5-b014-671d755aff3a">
        <source>doViewCargoDetails(_in : Boolean) protected;
/* ---------------------------------------------------------------------------
Created:     26 June 2009 by cnwrs2

Purpose:     
        
Change Date	Who		Reason

------------------------------------------------------------------------------*/
vars
	idx		: Integer;
	stkMoveDtl	: CMIF_StockMoveDtl;
	tiArray		: ObjectArray;
	itemObject  : Object;
begin

	idx	:= self.tblData.row;

	if idx &lt;= self.tblData.fixedRows then
		return;
	endif;
	
	itemObject := self.tblData.accessRow(idx).itemObject;
	
	if not itemObject.isKindOf(CMIF_StockMoveDtl) then
		return;
	endif;
	// CMIF_StockMoveHelper
	stkMoveDtl := itemObject.CMIF_StockMoveDtl;
	
	if stkMoveDtl = null then
		app.msgBox('No cargo details found', '', 0);
		return;
	endif;
	
	create tiArray transient;
	
	if _in then
		stkMoveDtl.getTIsForStockMoveIn(tiArray);
	else
		stkMoveDtl.getTIsForStockMoveOut(tiArray);
	endif;
	
	if tiArray.isEmpty then
		app.msgBox('No cargo details found', '', 0);
		return;
	endif;
	
	self.myAssistant.showCargoEnquiryForTIs(tiArray.first.CM_TrackedItem, tiArray, null, false);

epilog
	delete tiArray;

end;</source>
        <access>protected</access>
        <Parameter name="_in" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="executeQuery" id="a9e58929-6879-4622-9f49-1b32866d31f6">
        <updating/>
        <source>executeQuery() updating;
// ---------------------------------------------------------------------------
// Created:     30 July 2002 by cnwth2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	locationType	: String;
	stockMoveDict	: CM_StockMoveLocnsByDateProduct;
	
begin
	self.allStockMoveHelpers.purge();
	self.setQueryParametres();
	self.tblData.rows := tblData.fixedRows;

	if self.queryType = QueryType_StkMoveByLocation then	
		self.switchMode(Mode_StockMove);
		if self.filtLocationType = LocationType_LC then
			self.queryLCByDate();
		elseif self.filtLocationType = LocationType_TA then
			self.queryTAByDate();
		elseif self.filtLocationType = LocationType_Terminal then
			self.queryTerminalByDate();
		elseif self.filtLocationType = LocationType_Voyage then
			self.queryVoyageByDate();			
		endif;
	
	elseif self.queryType = QueryType_StkMoveByProduct then	
		self.switchMode(Mode_StockMove);
		if self.filtLocationType = LocationType_LC then
			self.queryLCByProduct();
		elseif self.filtLocationType = LocationType_TA then
			self.queryTAByProduct();
		elseif self.filtLocationType = LocationType_Terminal then
			self.queryTerminalByProduct();
		elseif self.filtLocationType = LocationType_Voyage then
			self.queryVoyageByProduct();			
		endif;

	elseif self.queryType = QueryType_StkMoveFixups then	
		self.switchMode(Mode_SOHFixups);
		self.queryTerminalFixups();
		
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="fixupStock" id="fe309829-253e-489e-9aee-b14bf59f0634">
        <updating/>
        <source>fixupStock()updating;
//--------------------------------------------------------------
//Created: 25 October 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	cmifMonitor : CMIF_Monitor;
	cancelSave 	: Boolean;
	comment		: String;
	errStr		: String;
	theResult : Integer;	//14 Jan 2020 NDL	TFS 46815
begin

	if (not app.getMyUser.canDo(self.myTerminal, PmAdmStockMoveMaint)) then
		app.raiseCMException1(VB_SECMOVE, 'Stock Movements - Fixup Stock', null, null);	
		return;
	endif;
		
	if self.getOperatorAccessController &lt;&gt; null then
		app.msgBox("Fixup Stock is not available as you have operator restrictions",
				"Fixup Stock Unavailable", MsgBox_OK_Only);
		return;
	endif;

	if self.filtLocationType = LocationType_LC and self.myFiltLC = null then
		errStr := 'Location';
	elseif self.filtLocationType = LocationType_TA and self.myFiltTA = null then
		errStr := 'Terminal Area';
	elseif self.filtLocationType = LocationType_Terminal and self.myFiltTerminal = null then
		errStr := 'Terminal';
	elseif self.filtLocationType = LocationType_Voyage and self.myFiltVoyage = null then
		errStr := 'Voyage';		
	endif;
	
	if errStr &lt;&gt; null then
	//	app.raiseCMException1(REQUIRED_FIELD, errStr, null, null);
		app.raiseCMException1(Input_required_field_Required, errStr, null, null); // cnwdb2	PAR 35364
		return;
	endif;

	app.mousePointer := MousePointer_HourGlass;
	
	create cmifMonitor transient;
   	cmifMonitor.myParent := self;
   	cmifMonitor.message := 'Checking Stock';
   	self.modalDialogReturnValue := self.ModalDialogReturn_Null;   	
	self.modalDialogShow(null, 'Cancel', null, null, 'Fixing Stock', cmifMonitor.message);
	self.pbProgressBar.visible := true;
	//Hard coded for now. Change when other users permitted run fixup.
	comment := 'Data Fix.';
	
	// ignore warnings when fixing up stock
	app.myPassport.warningsAcknowledged := true;
	
	//14 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
	while true do
	
		if self.filtLocationType = LocationType_LC then
			app.myTrxUA.trxFixupStockOnHandLC(self.myFiltLC, comment, cmifMonitor, app.myPassport);
		elseif self.filtLocationType = LocationType_TA then
			app.myTrxUA.trxFixupStockOnHandTA(self.myFiltTA, comment, cmifMonitor, app.myPassport);
		elseif self.filtLocationType = LocationType_Terminal then
			app.myTrxUA.trxFixupStockOnHandTerminal(self.myFiltTerminal, comment, cmifMonitor, app.myPassport);
		elseif self.filtLocationType = LocationType_Voyage then
			app.myTrxUA.trxFixupStockOnHandVoyage(self.myFiltVoyage, comment, cmifMonitor, app.myPassport);		
		else
			app.raiseUnexpectedProgramError(class.name, method.name, 'Unknown type (' &amp; self.filtLocationType &amp; ')');
		endif;
	
		if app.myPassport.trxCompletedOK then
			break;
		else
			theResult := app.showErrorWarningDialog('Stock Movements', app.myPassport, ErrWarnMode_Update);
			if app.myPassport.noErrors and theResult = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		
		return;
		
	endwhile;
	
	self.frmModalDialog.visible := false;
		
	self.executeQuery();
	
epilog
	self.frmModalDialog.visible := false;
	delete cmifMonitor;	
	app.myPassport.setMyCMIFMonitor(null);	
	app.mousePointer := MousePointer_Default;
end;</source>
    </JadeMethod>
    <JadeMethod name="getOperatorAccessController" id="af70b104-7232-4bc0-be43-847bce9bd199">
        <source>getOperatorAccessController() : CM_DataAccessController protected;
// ---------------------------------------------------------------------------
// Created:      26 May 2003 by cnwsgp1
// ---------------------------------------------------------------------------
vars
	passport : CM_Passport;

begin
	passport := app.myPassport;

	if app.isSpecial() then
		return null;
	endif;

	return passport.allDataAccessControllers[CM_Operator.name];
end;</source>
