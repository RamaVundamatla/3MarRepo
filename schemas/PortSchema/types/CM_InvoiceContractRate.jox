    <JadeMethod name="shouldAuditProperty" id="3f94025b-38b9-4773-b4eb-3d516b82c798">
        <source>shouldAuditProperty(_rootClass: Class; _property: Property): Boolean protected;
/*
Purpose:			

Date		Who		Reason
13 February 2024	navab1	CR 61579 TASK 62469
*/

vars

begin
	if _property = null or
	   _property.name = 'myCalculationType' or
	   _property.name = 'myService' or	
	   _property.name = 'myChildQuantityMap' then
		return false;
	endif;


	return inheritMethod(_rootClass, _property);

epilog

end;</source>
        <access>protected</access>
