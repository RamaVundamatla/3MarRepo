//
//15.Apr.2024 navsp1 TFS Bug 62295: EUP | FR 54084 - CallOff Message - "Unknown" Type Release Request Not Created for Zimmer Case.
// ----------------------------------------------------

vars

begin

	if _value.Integer = TI_TRANSMODE_SHIP then
		return TI_TRANSMODE_SHIP_STR;
	elseif _value.Integer = TI_TRANSMODE_ROAD then
		return TI_TRANSMODE_ROAD_STR;	
	elseif _value.Integer = TI_TRANSMODE_RAIL then
		return TI_TRANSMODE_RAIL_STR;
	elseif _value.Integer = TI_TRANSMODE_UNKNOWN then	//TFS 62295
		return TI_TRANSMODE_UNKNOWN_STR;				//TFS 62295
	else
		return null;
	endif;
end;</source>
