    <JadeMethod name="doShowWOJobMethod" id="d1d93ee5-770a-4ed3-b3c0-7130bf10377d">
        <source>doShowWOJobMethod(_obj : CM_WorkOrderTI; _detail : CM_WorkOrderTIDtl):Any;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 Sep 2023 navhl20 ChangeRequest 60063: EUP | Ship Operations in DD - Terminal Config for grouping attributes
18 Dec 2023 navhl20 ChangeRequest 58400:[61617] EUP | Ship Operations in DD - [54176.050] Mobile App changes
03 Jan 2023 navhl20 Defect 61895: EUP - Ship Operations - Release Ship WOs are not grouping based on the Cargo types.
*/

vars
	form		: YRD_WorkOrderGrpMethod;
	grpMethod	: String;
begin
	form := app.loadForm(YRD_WorkOrderGrpMethod, YRD_Assistant, false, false, false, self.myTerminal, self.myMasterMenuAction).YRD_WorkOrderGrpMethod;
	
	if form = null then
		return null;
	endif;
	form.myWorkOrder := _obj;
	form.myWorkOrderDetail := _detail;
	if form.showModal() = MsgBox_OK_Only then
		return form.cmbGrpMethod.listObject.CM_WorkOrderJobGroupMethod;
	else														//03.01.2023 navhl20 #61895
		return MsgBox_Return_Cancel;
	endif;
	return null;
epilog
	delete form;
end;</source>
        <Parameter name="_obj" type="CM_WorkOrderTI"/>
        <Parameter name="_detail" type="CM_WorkOrderTIDtl"/>
        <ReturnType type="Any"/>
    </JadeMethod>
    <JadeMethod name="doShowWagon" id="b3a379ed-67d9-41f9-9aba-1dbe3d5b8b1c">
        <source>doShowWagon(_obj : CM_Wagon);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 March 2023	navhl20	Defect 57173: MTN - 75776 exception when double clicking on the Vehicle on the Info table

*/

vars
	wagonForm : YRD_TrainWagonForm;
	wagon : CM_Wagon;
	trainForWagonCombo : CM_Train;
begin
	wagon := _obj.CM_Wagon;
	
	trainForWagonCombo := wagon.myTrainInwards;
	if trainForWagonCombo = null then
		trainForWagonCombo := wagon.myTrainOutwards;
	endif;
	
	app.mousePointer := MousePointer_HourGlass;
	
	wagonForm := app.getForm(YRD_TrainWagonForm.name).YRD_TrainWagonForm;
	if wagonForm = null then
		wagonForm := app.loadForm(YRD_TrainWagonForm, YRD_Assistant, false, false, false, self.myTerminal, self.myMasterMenuAction).YRD_TrainWagonForm;
	endif;
	
	if wagonForm = null then
		return;
	endif;
	
	self.setNavigatorHeading(app.getErrorString(Wagon_maintenance)); 
	wagonForm.setParentForm(self);
	wagonForm.setMyTerminal(self.myTerminal);
	wagonForm.setMyTrainForWagonCombo(trainForWagonCombo);
	wagonForm.initialiseForm(wagon.myTrainInwards, wagon, YRD_TrainWagonForm.Mode_View);
	wagonForm.show;
		
epilog
	app.mousePointer := MousePointer_Default;
end;</source>
        <Parameter name="_obj" type="CM_Wagon"/>
    </JadeMethod>
    <JadeMethod name="doTblDataContextMenu" id="92954e4b-d127-4653-9cf6-f998579a7af1">
        <updating/>
        <source>doTblDataContextMenu(cntrl: Table input; conwin: Window input; mouse: Boolean; x: Integer; y: Integer): Boolean updating;

/*

Purpose:			
	TFS 39286 Show "Set to Pending" menu item so we can set it back from Approved
Parameters:			

Return Value:		


Date		Who		Reason
25/08/2009	cnwrd1	Initial creation
11/05/2018	jlgdap1	TFS 38501 PEL1 Work Order Changes
07/06/2018	jlgdap1	TFS 38560 PEL1 Voyage Work Orders
20/06/2018	jlgdap1	TFS 39286 PEL1 Work Order Enquiry Voyage Requests
14/08/2018  cnwma1	ChangeRequest 39698: PEL1 - SAP Enable SAP interfaces
24/10/2018  cnwma1  ChangeRequest 41495: PEL1 - SAP Integration - Override statuses
22/02/2019  cnwma1	Bug 43514: PEL1 - SAP Credit check approval option
12/03/2019  cnwma1	Bug 43781: PEL1 - Estimation - Manual Cancellation (CR 42401 failed)
10/09/2021  navma1  ChangeRequest 51002: MTN - Web Portal Cargo Work Orders
29/09/2021	jlizm1	TFS 51963 SAL Voyage Request Changes
13/09/2022  navma1	ChangeRequest 54645: MTN - Work Order Refactor (Additional Changes and remove IsSpecial)
07/12/2022	navcs2	ChangeRequest 54698:[54264] EUP - [Framework] - Enable VAS Work Order in Work Order Enquiry Screen
12/12/2023	navma1  ChangeRequest 56141:[56147] EUP - Refactor and Remove CM_WorkOrderTISource from CM_WorkOrderTI
08 Feb 2023 navma1  ChangeRequest 56457:[56458] EUP - [Refactor] - Allowing different sets of cargo items per work order task
15 Feb 2023 navma1  ChangeRequest 56561: FR 53944 | EUP - Simplified Voyage Work Order
04 Apr 2023	navma1	Bug 57456: EUP - Not Approved Status is not enabled for ToDo work orders
31 May 2023 navmv20 CR 54345 Task 57116: Jade - Contract Id Work Order Enquiry
18 Aug 2023 navhl20 ChangeRequest 58568: EUP - Delivery Dispatch – Reporting
18 Oct 2023	navnk30	ChangeRequest 59946: EUP - Additional Operational Instructions on the Order - Enhancement 2
23 Apr 2024 navhl20 ChangeRequest 63583: EUP | 54014 - Cargo Work Orders Enhancements - Remedial
23 Aug 2024 navlc30 Bug 65665: EUP | Complete Job button should not be available on the Unallocated tab for the VAS work orders
*/

vars
	selObj 			 	: Object;
	workOrder 		 	: CM_WorkOrder;
	xLeft 			 	: Real;
	yTop			 	: Real;	
	task 			 	: CM_WorkOrderDtl;				
	voyageStatus	 	: CM_VoyageStatus;
	term			 	: CM_Terminal;
	user			 	: CM_User;
	canEdit			 	: Boolean;
	hasCashRec  	 	: Boolean;
	showReCheckFin   	: Boolean;
	showActionTask   	: Boolean;
	firstWod		 	: CM_WorkOrderDtl;
	showApproveMenu	 	: Boolean;
	showPendingMenu     : Boolean;
	isExternalUser   	: Boolean;
	voyageProcess   	: CM_VoyageProcess;
	job					: CM_Job;
	woToDoTask			: CM_WodToDo;	
	invalid				: Boolean;
begin
	on Exception do app.handleDeletedObject(exception, selObj, invalid);
	
	selObj  		:= self.tblData.allSelectedObjects.first;
	
	//27/05/2025	navkc1 JIRA MTN-34972
	if selObj  &lt;&gt; null then
		selObj.edition();
	endif;
	//07/05/2025	navkc1 JIRA MTN-34592
	if invalid then
		return false;
	endif;
	
   //31/05/2023 navmv20 CR 54345 Task 57116 - start
	/*
	if selObj = null then
		return false;
	endif;*/
	//31/05/2023 navmv20 CR 54345 Task 57116 - end

	term 			:= self.myTerminal; 												//07/12/2022 navcs2	#54698:[54264]
	canEdit 		:= app.myCurrentUserCan(term, self.permissionMaint);				//12.01.2023 navma1 #56141:[56147]
	user			:= app.getMyUser();
	isExternalUser	:= user.myOrganisation.isExternal;									//15.02.2023 navma1 #56561
	voyageProcess	:= term.getDefaultVoyageProcess();									//04.04.2023 navma1 #57456
	
	self.mnuWOColOrganiser.visible 		  := true;
	self.mnuCashCreateReceipt.visible 	  := false; 	// TFS 38524
	self.mnuCashDeleteReceipt.visible 	  := false; 	// TFS 39721
	self.mnuCashSeperator.visible 	  	  := false;
	self.mnuCashShowInvoice.visible   	  := false;
	self.mnuCashShowReceipt.visible   	  := false;
	self.mnuRecheckFinance.visible   	  := false;  	//14.8.2018 cnwma1 #39698
	self.mnuApproveCredit.visible     	  := false;  	//19.9.2018 cnwma1 #39698
	self.mnuResendInaport.visible     	  := false;  
	self.mnuSetNotApproved.visible 	      := false;		//TFS 51963
	self.mnuCRPaymentStatusCancel.visible := false; 	//12.3.2019  cnwma1 #43781    
	self.mnuShowTasks.visible 	          := false;		//14.09.2022 navma1 #54645
	self.mnuCompleteTask.visible 		  := false;    	//07.12.2022 navcs2 #54698:[54264]
	self.mnuSetArchived.visible 		  := false;
	self.mnuActionCargo.visible 		  := false;
	self.mnuSetApproved.visible  		  := false;
	self.mnuSetPending.visible  		  := false;		// TFS 39286
	self.mnuActionTasks.visible 	 	  := false;
	self.mnuSummarise.visible			  := false;		// default this menu level to invisible, makes sub-menu invisible.
	self.mnuWOInspect.visible 			  := false;
	self.mnuReport.visible 				  := false;		//18.8.2023 navhl20 #58568
	self.mnuReportAll.visible 			  := false;		//18.8.2023 navhl20 #58568
	self.mnuReportSelected.visible 		  := false;		//18.8.2023 navhl20 #58568
	self.mnuUnApprove.visible			  := false;		//23.04.2024 navhl20 #63583
	self.mnuCompleteToDoTasks.visible	  := false;		//23.08.2024 navlc30 #65665
	
	//31/05/2023 navmv20 CR 54345 Task 57116 - start
	if selObj = null then
		self.mnuEditWorkOrder.visible    := false;
		self.mnuWOAddInstructions.visible := false;		//18.10.2023 navnk30 #59946
		self.mnuDeleteWorkOrder.visible  := false;
		self.mnuAudit.visible 			 := false;
		self.mnuShowCargo.visible		 := false;
		self.mnuSetNotApproved.visible   := false;
		self.mnuWorkOrder.visible 		 := false;
		self.mnuNewWorkOrder.visible 	 := false;
		self.mnuViewTransactions.visible := false;
		self.mnuShowHideMacro.visible 	 := false;
		xLeft := x;
		yTop  := y;
		conwin.windowToScreen(xLeft, yTop);
		self.screenToWindow(xLeft, yTop);
		self.popupMenu(self.mnuWorkOrder, xLeft.Integer, yTop.Integer);
		return false;
	else
		self.mnuWOAddInstructions.visible := true;		//18.10.2023 navnk30 #59946
		self.mnuViewTransactions.visible := true;
		self.mnuShowHideMacro.visible 	 := true;
	endif;
	//31/05/2023 navmv20 CR 54345 Task 57116 - end
	
	if app.isAllowedToInspect then
		self.mnuWOInspect.visible := true;	
	endif;	   
	
	if selObj.isKindOf(CM_WorkOrder) then 
		workOrder	 		:= selObj.CM_WorkOrder;
		hasCashRec   		:= workOrder.allCashReceipts.isNotEmpty;											//24.01.2023 navma1 #56141:[56147]

		if workOrder.taskStatus = WO_STATUS_PENDING_FIN or workOrder.taskStatus = WO_STATUS_REJECTED_FIN  then
			if hasCashRec then
				showReCheckFin := true;
			endif;
		endif;
		
		if not workOrder.taskStatus &lt; WO_STATUS_APPROVED then 
			firstWod := workOrder.allWoDtls.first;
			if firstWod &lt;&gt; null  and  firstWod.canCreateResources( voyageStatus ) then	//01 Aug 2018	NDL	TFS 39900
				showActionTask := true;
			elseif /*workOrder.isWorkOrderForReceival or workOrder.isWorkOrderForRelease  or*/  not workOrder.canEditOrDeleteInEnquiry then		//06.03.2023 navma1 #56457:[56458]
				showActionTask := false;										// TFS 38501
			else																// TFS 38501
				showActionTask := true;
			endif;
			
			if workOrder.taskStatus &lt;&gt; WO_STATUS_COMPLETE then											//26.08.2024 navlc30 #65665	
			
				if firstWod.isKindOf(CM_WodToDo) then 
					woToDoTask := firstWod.CM_WodToDo;													//23.08.2024 navlc30 #65665
				endif;
				
				if woToDoTask &lt;&gt; null then																//23.08.2024 navlc30 #65665
					job := woToDoTask.allJobs.first;	
				endif;
				
				if job &lt;&gt; null and job.isKindOf(CM_WOToDoTaskJob) then 									//23.08.2024 navlc30 #65665
					self.mnuCompleteToDoTasks.visible :=  job.canCompleteToDoJob();	
				endif;
			endif;	
		endif;	
		
		if workOrder.taskStatus &lt; WO_STATUS_APPROVED  then								//15.02.2023 navma1 #56561
			if not isExternalUser then
				
				showApproveMenu := true;
				
				if workOrder.taskStatus &lt;&gt; WO_STATUS_PENDING then				// TFS 39286
					self.mnuSetPending.visible := true;							// TFS 39286
				endif;
				
				if voyageProcess &lt;&gt; null and voyageProcess.isEUPDefaultProcess then		//15.02.2023 navma1 #56561
					if workOrder.taskStatus = WO_STATUS_NOTAPPROVED then
						showApproveMenu := false;
						showPendingMenu := false;										//15.02.2023 navma1 #56561
					endif;
				endif;
			endif;
		endif;
	endif;
	
	if self.isEnqType_WorkOrder then
		self.mnuEditWorkOrder.visible    := canEdit;											//12.01.2023 navma1 #56141 Task#56147
		self.mnuDeleteWorkOrder.visible  := workOrder.canEditOrDeleteInEnquiry and canEdit;		//12.01.2023 navma1 #56141 Task#56147
		self.mnuAudit.visible 			 := workOrder.hasAudits;
		self.mnuShowCargo.visible		 := workOrder.canShowCargo;								//13.09.2022 navma1 #54645
		self.mnuSetApproved.visible		 := showApproveMenu;									//15.02.2023 navma1 #56561
		self.mnuSetNotApproved.visible   := workOrder.enableStatusNotApproved;					//04.04.2023 navma1	#57456
		self.mnuSetPending.visible		 := showPendingMenu;									//15.02.2023 navma1 #56561
		
		if workOrder.taskStatus &lt; WO_STATUS_APPROVED then			
			self.mnuCashCreateReceipt.visible := not hasCashRec;		      					 // TFS 38524
			self.mnuCashSeperator.visible 	  := not self.mnuCashCreateReceipt.visible;
		else
			
			if workOrder.taskStatus = WO_STATUS_APPROVED then                                	 // TFS 38524        
				self.mnuCashCreateReceipt.visible := not hasCashRec;							//10.09.2021 navma1 #51002
				self.mnuCashSeperator.visible 	  := true;
				self.mnuSetPending.visible 		  := true;
			endif;
		endif;
		
		if app.isSpecial() then
			self.mnuCashDeleteReceipt.visible := not self.mnuCashCreateReceipt.visible; 	// TFS 39721
		endif;
			
		self.mnuCashShowReceipt.visible := not hasCashRec;
		self.mnuCashShowInvoice.visible := workOrder.allInvoices.isNotEmpty();
		self.mnuCashSeperator.visible   := (self.mnuCashShowReceipt.visible or self.mnuCashShowInvoice.visible);
		
		self.mnuSetArchived.visible := workOrder.canArchive();					//06.03.2023 navma1 #56457:[56458]

		self.buildCompleteTaskMenu( workOrder.CM_WorkOrder );

		if showReCheckFin then
			self.mnuRecheckFinance.visible := true;
		endif;
		
		if showActionTask then
			self.buildActionTasksMenu( workOrder.CM_WorkOrder );			// TFS 38560
		endif;
		
		//19.9.2018 cnwma1 TFS #39698
		if workOrder &lt;&gt; null and hasCashRec then
			if workOrder.allCashReceipts.isNotEmpty then
				if  app.isSpecial or  user.canDo(term, PmAdmApproveCreditCheck)  then //22.02.2019 cnwma1 #43514
					if not workOrder.isAllCRCreditApproved then
						self.mnuApproveCredit.visible := true;
					endif;
					if workOrder.taskStatus = WO_STATUS_PENDING_FIN or workOrder.taskStatus = WO_STATUS_REJECTED_FIN then
						self.mnuApproveCredit.visible := true;
					endif;
				endif;
			endif;
			if user.canDo(term,PmAdmCashRecPaymentStatusChang) then // TFS 42401 12.3.2019 cnwma1 #43781
				self.buildCashReceiptCancelMenu(workOrder); // TFS 42401
			endif;
		endif;
		//19.9.2018 cnwma1 TFS #39698
		
		if workOrder.canBeUnApprove() then					//23.04.2024 navhl20 #63583
			self.mnuUnApprove.visible := true;
		endif;
	elseif self.isEnqType_Task() then
		
		if not selObj.isKindOf(CM_WorkOrderDtl) then
			app.raiseUnexpectedProgramError(self.class.name, method.name, "unexpected class type");
			return false;
		endif;
		
		task := selObj.CM_WorkOrderDtl;						
		
		self.mnuShowTasks.visible	  := true;
		self.mnuEditWorkOrder.visible := true;
		self.mnuAudit.visible 		  := task.getMyParent.hasAudits;
		//self.mnuActionCargo.visible := task.canActionCargo();					//06.03.2023 navma1 #56457:[56458]
		self.mnuActionCargo.visible   := false;									//06.03.2023 navma1 #56457:[56458]
	endif;

	xLeft := x;
	yTop  := y;
	
	conwin.windowToScreen(xLeft, yTop);
	self.screenToWindow(xLeft, yTop);

	// TFS 2198 CNWAB1
	if not canEdit then						  //12.01.2023 navma1 #56141 Task#56147
		self.mnuShowTasks.visible 			  := false;
		self.mnuEditWorkOrder.visible 		  := false;
		self.mnuSetApproved.visible 		  := false;
		self.mnuActionTasks.visible 		  := false;
		self.mnuSetPending.visible 			  := false;	 // TFS 39286
		self.mnuShowCargo.visible 			  := false;
		self.mnuWorkOrder.visible 			  := false;
		self.mnuActionCargo.visible 		  := false;
		self.mnuDeleteWorkOrder.visible 	  := false;
		self.mnuNewWorkOrder.visible 		  := false;
		self.mnuCRPaymentStatusCancel.visible := false; //JLGAB1 21MAR19
		self.mnuApproveCredit.visible 		  := false; //JLGAB1 21MAR19
	endif;
	

	self.mnuSetApproved.visible     :=  showApproveMenu and		 user.canAccessWorkOrderStatus(WO_STATUS_APPROVED,term);			//06.03.2023 navma1 #56457:[56458]
	self.mnuSetPending.visible      :=  showPendingMenu and 	user.canAccessWorkOrderStatus(WO_STATUS_PENDING,term);				//06.03.2023 navma1 #56457:[56458]
	//self.mnuCompleteTask.visible    := user.canAccessWorkOrderStatus(WO_STATUS_COMPLETE,term) or 									//06.03.2023 navma1 #56457:[56458]
	//								   user.canAccessWorkOrderStatus(WO_STATUS_PARTCOMPLETE,term);									//06.03.2023 navma1 #56457:[56458]
	self.mnuSetNotApproved.visible  := (workOrder&lt;&gt; null and workOrder.enableStatusNotApproved ) and  
										user.canAccessWorkOrderStatus(WO_STATUS_NOTAPPROVED,term);		//06.03.2023 navma1 #56457:[56458]  //04.04.2023 navma1	#57456
										
	if selObj &lt;&gt; null and self.isEnqType_WorkOrder() then					//18.8.2023 navhl20 #58568
		self.mnuReport.visible 			:= true;
		self.mnuReportAll.visible 		:= true;
		self.mnuReportSelected.visible 	:= true;
	endif;
	
	self.popupMenu(self.mnuWorkOrder, xLeft.Integer, yTop.Integer);

	return false;
epilog

end;</source>
        <Parameter name="cntrl" type="Table" usage="input"/>
        <Parameter name="conwin" type="Window" usage="input"/>
        <Parameter name="mouse" type="Boolean"/>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doTblDataDBClick" id="278d5730-522d-41de-a613-dd94dc837289">
        <updating/>
        <source>doTblDataDBClick(table: CM_DataTable input) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
05 August 2009	cnwmd1	Initial creation

*/

vars

begin
	inheritMethod(table);

	// TFS 2198 CNWAB1
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		return;
	endif;

	if table.row &gt; 1 then
		self.doEditItem();
	endif;

epilog

end;</source>
        <Parameter name="table" type="CM_DataTable" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doTblDataRowColChange" id="e8b28599-2708-4db7-bfd4-e6baa2bfe8c5">
        <updating/>
        <source>doTblDataRowColChange(table: Table input) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
25/08/2009	cnwrd1	Initial creation
20/06/2018	jlgdap1	TFS 39286 PEl1 Work Order Enquiry Voyage Requests
24/09/2021 	jlizm1	TFS 51963 SAL Voyage Request Changes
09/03/2022	jlizm1	TFS 52834 SAL file attachments filter by work order
14 Mar 2023 navhl20  ChangeRequest 56844:[56845] EUP - VAS Work Order Remarks
12 Jan 2023	navma1  ChangeRequest 56141: EUP - Refactor and Remove CM_WorkOrderTISource from CM_WorkOrderTI
*/

vars
	newRow				  : Integer;
	obj 				  : CM_Object;
	wodVoyage 			  : CM_WorkOrderVoyage;
	first 				  : CM_WorkOrderDtl;
	wodVoyageCargoRequest : CM_WodVoyageCargoRequest;
	canEdit				  : Boolean;
	invalid				  : Boolean;
begin
	on Exception do app.handleDeletedObject(exception, obj, invalid);
	
	canEdit := app.myCurrentUserCan(self.myTerminal, self.permissionMaint);				//12.01.2023 navma1 #56141 Task#56147
	newRow  := self.tblData.row;
	obj 	:= self.tblData.accessRow(newRow).itemObject.CM_Object;
	
	//27/05/2025	navkc1 JIRA MTN-34972
	if obj &lt;&gt; null then
		obj.edition();
	endif;
	
	//07/05/2025	navkc1 JIRA MTN-34592
	if invalid then
		return;
	endif;
	
	self.btnOOWConfirm.enabled := false;
	// ### TFS CR 55299 TASK 55985 28DEC2022 NAVAB1	self.btnAttachments.enabled := false;
	self.btnAttachments.userObject := obj;  	// ### TFS CR 55299 TASK 55985 28DEC2022 NAVAB1 
	self.btnAttachments.enabled    := true;     // ### TFS CR 55299 TASK 55985 28DEC2022 NAVAB1
 
	if obj &lt;&gt; null and obj.isKindOf(CM_WorkOrderVoyage) then
		wodVoyage := obj.CM_WorkOrderVoyage;
		first     := wodVoyage.allWoDtls.first;
		if first &lt;&gt; null then
			// ### TFS CR 55299 TASK 55985 28DEC2022 NAVAB1			self.btnAttachments.enabled := true;		 // TFS 51963
			// ### TFS CR 55299 TASK 55985 28DEC2022 NAVAB1			self.btnAttachments.userObject := wodVoyage; // TFS 51963
			if first.requiresLengthOfTime then		
				self.btnOOWConfirm.enabled    := true;	
				self.btnOOWConfirm.userObject := first;
			endif;
		endif;
	endif;
	
	if obj.isKindOf(CM_WorkOrder) then													// TFS 39286
		self.btnEditItem.enabled := canEdit;											// TFS 39286
		self.btnDelete.enabled   :=  obj.CM_WorkOrder.canEditOrDeleteInEnquiry and canEdit ;																				// TFS 3928
	else																				// TFS 39286
		self.btnEditItem.enabled := false;												// TFS 39286
		self.btnDelete.enabled   := false;												// TFS 39286
	endif;
	self.displayExtraInfoForObj(obj);
epilog

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doTblInfoContextMenu" id="ebecc164-8728-43a8-a17b-c0914fcaa5e7">
