    <JadeMethod name="getCurrentVisitDetailStage" id="ac069dee-e698-4727-90ba-160fbf370a71">
        <source>getCurrentVisitDetailStage() : CM_VehicleVisitRecordDetail;
/*
Purpose:			
Return Value: The most recent VVRD that indicates progress throught the terminal.
              As such, container moves, RFID tag assigns etc will not be returned.		

Date			Who		Reason
17 August 2006	cnwer1	Initial creation - PAR#xxxx
19 may 2009		concms1	Par 19715 - VVRD updating changes
11/11/2009		cnwcs5	par 21327 - exclude Ready To Leave
*/
vars
	detail	:CM_VehicleVisitRecordDetail;							// par 19715
begin
	foreach detail in self.allVehicleVisitRecordDetails reversed do	// par 19715
		//if detail.isCargoMove then								// par 19715
		if not detail.isVisitStage then								// par 21327 - cnwcs5 11/11/2009
			// exclude those detail records that are not related to 
			// movement through the terminal
			continue;												// par 19715
		endif;														// par 19715
		// we have one we want
		return detail;												// par 19715
	endforeach;														// par 19715
	
epilog

end;</source>
        <ReturnType type="CM_VehicleVisitRecordDetail"/>
    </JadeMethod>
    <JadeMethod name="getCustomStatus" id="25ad6e2f-aed8-432f-b2cb-f920341df00f">
        <source>getCustomStatus() : String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27/09/2023	navkc1	CR 60428 Task 60701: UI - Customs Status on Transport UI
23/02/2023	navkc1 CR 62580 Task 62581: UI - Road Exit Custom Document Details

*/

vars
	ti		: CM_TrackedItem;
	messStr,
	str		: String;
	tis		: CM_TISet;
	wle		: CM_WorkListEntry;
	roadjob	: CM_RoadJob;
begin
	
	create tis transient;
	
	self.allReceivedTrackedItems.copyNoDuplicates(tis, false);
	self.allReleasedTrackedItems.copyNoDuplicates(tis, false);
	
	roadjob := self.myRoadJob;
	if roadjob &lt;&gt; null then
		foreach wle in roadjob.workListEntries discreteLock do
			ti := wle.myTrackedItem;
			if ti &lt;&gt; null then
				tis.tryAddIfNotNull(ti);
			endif;
		endforeach;
	endif;
	
	foreach ti in tis discreteLock do
		str := ti.getCustomsStatus();
		
		if str = null then
			continue;
		endif;
		
		/*
		if messStr = null then
			messStr := str;
		elseif messStr.pos(str, 1) = 0 then
			messStr := messStr &amp; "," &amp; str;
		endif;
		*/
		
		messStr.addStringToList(str, ","); //04/04/2025	navkc1 JIRA Story MTN-33940
	endforeach;
	
	return messStr;
	
epilog
	delete tis;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDataForAttribute" id="06479a74-2d06-4f86-9837-54a914c74da1">
        <source>getDataForAttribute(_rowName: String; _heading: String; _headings: StringArray input; _data: HugeStringArray input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 April 2013	cnwndl1	Initial creation	Par 31393
16 Jan   2024	navbs1	ChangeRequest 61971: FR | 55168 - Seal Numbers on Trucks (remedial) - Add columns to Road Exit and Vehicle Enquiry
27 Mar 2025	navnk30	JIRA 34424: TPT | VBS - Change the information from "Arrived on schedule" to be more clear with the timestamp like "Arrived on schedule at 23:23 on 20th March 2025"

*/

constants
	SPACES					: String = '     ';
	
vars
	isVehicleBookingEnabled	: Boolean;
	vbsIdStr,
	statusStr				: String;
	allVehicleBookingSlots	: CM_VehicleBookingTimeSlotById;
	vbts					: CM_VehicleBookingTimeSlot;
	vbsProcess				: CM_VBSProcess;
	
begin
	isVehicleBookingEnabled := self.myTerminal.isVehicleBookingEnabled;
	vbsProcess := self.myTerminal.getMyVBSProcess();
	
	if _rowName = ETRow_VvsBooking and not isVehicleBookingEnabled then
		return;
	// ### TFS 54049 (55843) 18May2023 NAVPW1
	elseif _rowName = ETRow_VvsBooking and isVehicleBookingEnabled and vbsProcess &lt;&gt; null and vbsProcess.isVbsSlotValidation then
		allVehicleBookingSlots := self.allVehicleBookingSlots;
		if allVehicleBookingSlots.isEmpty then
				_headings.add(app.getErrorString(ToDo_Vehicle_booking));
				_data.add(app.getErrorString(No));
			return;
		endif;
		
		_headings.add(app.getErrorString(Vehicle_bookings) &amp; ":");
		_data.add(null);
		
		foreach vbts in allVehicleBookingSlots do
			_headings.add(SPACES &amp; app.getErrorString(VehicleBookingId));
			
			//statusStr := vbts.getStatusString;			//27.03.2025 navnk30 JIRA 34424
			statusStr := vbts.getStatusStringWithTS();		//27.03.2025 navnk30 JIRA 34424
			
			if vbts.id &lt;&gt; null then
				vbsIdStr := vbts.id &amp; " - ";
			endif;
			
			_data.add(vbsIdStr &amp; statusStr);
			
		endforeach;
		
		return;
	// ### TFS 54049 (55843) 18May2023 NAVPW1
	elseif _rowName = ETRow_TruckSeals then			//16.01.2024 navbs1 #61971
		if self.allTruckSeals.isEmpty then
			return;
		endif;
	endif;
	
	inheritMethod(_rowName, _heading, _headings, _data);
	
end;</source>
        <Parameter name="_rowName" type="String"/>
        <Parameter name="_heading" type="String"/>
        <Parameter name="_headings" type="StringArray" usage="input"/>
        <Parameter name="_data" type="HugeStringArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getDepartureEvent" id="1818b614-df08-47e0-a665-f7ec88175f3e">
        <source>getDepartureEvent() : CMEVT_TruckEvent;
/*
Purpose: Return the CMEVT_TruckDeparture event created when the truck departed	CCMS 2346 34936		
*/
vars
	detail	: CM_VehicleVisitRecordDetail;
begin
	foreach detail in self.allVehicleVisitRecordDetails do
		if detail.recordType = VisitRecord_Complete_OutGate then
			return detail.getDepartureEvent();
		endif;
	endforeach;
	
	return null;
epilog
end;</source>
        <ReturnType type="CMEVT_TruckEvent"/>
    </JadeMethod>
    <JadeMethod name="getDetailGateLaneIn" id="f428b6ee-a7aa-485e-bcd5-89b90c636272">
