    <JadeMethod name="cnEcCreateCopyFormatClass" id="b1ae724c-547f-4f98-a6cf-4d622aa9a6b2">
        <source>cnEcCreateCopyFormatClass(pCopyFromFormat : CnEcXmlFormat);

vars
	copyFromFormat : CnEcXmlFormat;
	copyFormatClass, newFormatClass	: CnEcXmlFormatClass;

begin
	copyFromFormat := pCopyFromFormat;
    foreach copyFormatClass in copyFromFormat.allFormatClasses do
    	create newFormatClass;
    	newFormatClass.copy(copyFormatClass, self);						 	
    endforeach; 
end;</source>
        <Parameter name="pCopyFromFormat" type="CnEcXmlFormat"/>
    </JadeMethod>
    <JadeMethod name="cnEcGetFormatClass" id="047648e2-f1d4-4a81-bc79-e2378591e85a">
        <source>cnEcGetFormatClass(pClassName : String): CnEcXmlFormatClass;

vars
	formatClass	: CnEcXmlFormatClass;
begin
	return self.allFormatClasses.getAtKey(pClassName);
end;</source>
        <Parameter name="pClassName" type="String"/>
        <ReturnType type="CnEcXmlFormatClass"/>
    </JadeMethod>
    <JadeMethod name="cnEcHandleOverflowException" id="5b674665-814c-44eb-b5b6-ed33f6b37412">
        <source>cnEcHandleOverflowException(pException : Exception ) : Integer;

begin
	if pException.errorCode = 1201 then
		CnEcBaseXmlException.raise_(CNEC_X_02800, "Xml Format Circular reference");
		return Ex_Resume_Next;
	endif;
	
	return Ex_Pass_Back;
end;</source>
        <Parameter name="pException" type="Exception"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="cnEcXmlFormatObjectString" id="8f7e6c8e-78e8-4066-8af5-23c1a8e60523">
        <source>cnEcXmlFormatObjectString(	pObject: Object;
							pIsDebug: Boolean;
							pMaxObjectCount : Integer io;
							pCurrentObjectCount : Integer io;
							pMaxResponseSize : Integer io): String;
// --------------------------------------------------------------------------------
// Created:		10 October 2000 by cnwdad1
//
// Purpose:		Special version of cnEcXmlObjectString used solely for exporting Formats.		
//
// Parameters:	pObject - The objct to generate the XML output for.
//				pIsDebug - Has no effect.
//				pMaxObjectCount - The maximum number of objects to process.
//				pCurrentObjectCount - The number of the current object being processed.
//				pMaxResponseSize - The maximum length of the XML stream.
//
// Returns:		The XML stream.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	xmlString	: String;
    
begin
	pCurrentObjectCount := pCurrentObjectCount + 1;
	
	if pMaxObjectCount &gt; 0 and pMaxObjectCount &lt; pCurrentObjectCount then
		return null;
	endif; 
	
    xmlString := self.cnEcXmlFormatOutput(pObject, pIsDebug, pMaxObjectCount, pCurrentObjectCount, pMaxResponseSize);
	
	return xmlString;
end;</source>
        <Parameter name="pObject" type="Object"/>
        <Parameter name="pIsDebug" type="Boolean"/>
        <Parameter name="pMaxObjectCount" type="Integer" usage="io"/>
        <Parameter name="pCurrentObjectCount" type="Integer" usage="io"/>
        <Parameter name="pMaxResponseSize" type="Integer" usage="io"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="cnEcXmlFormatOutput" id="ca975b53-2765-499c-acfa-d3007c28ccf8">
        <source>cnEcXmlFormatOutput(pObject:Object;
					pDebug:Boolean;
					pMaxObjectCount:Integer io;
					pCurrentObjectCount:Integer io;
					pMaxResponseSize:Integer io ) : String;

// Special version of cnEcXmlOutput, used for exporting Formats.

vars
	classFormat	: CnEcXmlFormatClass;
	xmlString	: String;
	
begin
    on Exception do self.cnEcHandleOverflowException(exception);

	classFormat := cnEcGetFormatClass(pObject.class().getName);
	
	if classFormat &lt;&gt; null then
		xmlString := classFormat.cnEcXmlOutput(pObject, pDebug, pMaxObjectCount, pCurrentObjectCount, pMaxResponseSize);
	else
		CnEcBaseXmlException.raise_(CNEC_X_02801, "No class format for " &amp; self.formatName &amp; " [" &amp; pObject.class().getName &amp; "]");
	endif;
	
	return xmlString;
end;</source>
        <Parameter name="pObject" type="Object"/>
        <Parameter name="pDebug" type="Boolean"/>
        <Parameter name="pMaxObjectCount" type="Integer" usage="io"/>
        <Parameter name="pCurrentObjectCount" type="Integer" usage="io"/>
        <Parameter name="pMaxResponseSize" type="Integer" usage="io"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="cnEcXmlImportEpilog" id="206a528f-ea82-492f-861a-f850169b19fe">
        <updating/>
        <source>cnEcXmlImportEpilog() updating;
		// DO NOT CHANGE THE NAME OF THIS METHOD.
		// Used in createDefaultMethods 
vars
	text,vSchemaName : String;
	theSchema : Schema;
begin
	while app.myCnEcXmlSchema = null do
		write "No schema currently selected, please enter the Schema name you want to load 'excluded classes' against, and press OK.";
		text := "Avaialble schema names are:" &amp; CrLf;
		foreach theSchema in Schema.instances do
			text := text &amp; Tab &amp; "'" &amp; theSchema.name &amp; "'" &amp; CrLf;
		endforeach; 
		write text;
		read vSchemaName;
		app.cnEcSetXmlSchema(vSchemaName);
		if app.myCnEcXmlSchema = null then
			write "Couldn't set the schema to '" &amp; vSchemaName &amp; "', try again...";
		else
			break;
		endif; 
	endwhile;
	
	if self.schemaName = "" then
		self.upgrade(app.myCnEcXmlSchema.name); 
	endif;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="cnEcXmlNoid" id="77528a47-4dc7-4079-b747-07b6396f7bfb">
        <source>cnEcXmlNoid(pIsDebug: Boolean): String;

vars
	retValue	: String;
	
begin
	retValue := cnEcXmlTagIt("DISPLAY_PROPERTY", "formatName", pIsDebug); 	// the 'property' for this class that will be shown
																			// in CnEcXmlNoidSelect listBox
	retValue := retValue &amp; cnEcXmlTagIt("DISPLAY_VALUE", self.formatName, pIsDebug); // the 'value' of the property that will be shown
																				//  for you to match to in the CnEcXmlCnEcNoidSelect textBox
	retValue := cnEcXmlTagIt("NOID", retValue, pIsDebug);
	retValue := retValue &amp; cnEcXmlTagIt("oid", self.getOidString(), pIsDebug);
	retValue := cnEcXmlTagIt(self.class().name, retValue, pIsDebug);
	 
	return retValue;           
end;</source>
        <Parameter name="pIsDebug" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="cnEcXmlObjectString" id="c57368a6-f000-45f3-8ff4-46ede997eb1f">
        <source>cnEcXmlObjectString(pObject: Object;
					pIsDebug: Boolean;
					pMaxObjectCount : Integer io;
					pCurrentObjectCount : Integer io;
					pMaxResponseSize : Integer io): String;
// --------------------------------------------------------------------------------
// Created:		10 October 2000 by cnwdad1
//
// Purpose:		Generates an XML stream for the specified object.
//
// Parameters:	pObject - The objct to generate the XML output for.
//				pIsDebug - Has no effect.
//				pMaxObjectCount - The maximum number of objects to process.
//				pCurrentObjectCount - The number of the current object being processed.
//				pMaxResponseSize - The maximum length of the XML stream.
//
// Returns:		The XML stream.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	xmlString	: String;
    //format 		: CnEcXmlFormat;
    
begin
	pCurrentObjectCount := pCurrentObjectCount + 1;
	
	if pMaxObjectCount &gt; 0 and pMaxObjectCount &lt; pCurrentObjectCount then
		return null;
	endif; 
	
    xmlString := self.cnEcXmlOutput(pObject, pIsDebug, pMaxObjectCount, pCurrentObjectCount, pMaxResponseSize);
	
	return xmlString;
end;</source>
        <Parameter name="pObject" type="Object"/>
        <Parameter name="pIsDebug" type="Boolean"/>
        <Parameter name="pMaxObjectCount" type="Integer" usage="io"/>
        <Parameter name="pCurrentObjectCount" type="Integer" usage="io"/>
        <Parameter name="pMaxResponseSize" type="Integer" usage="io"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="cnEcXmlOutput" id="4f476c02-32d9-4a35-913d-e382f4d95474">
        <source>cnEcXmlOutput(	pObject:Object;
				pDebug:Boolean;
				pMaxObjectCount:Integer io;
				pCurrentObjectCount:Integer io;
				pMaxResponseSize:Integer io ) : String;

vars
	classFormat	: CnEcXmlFormatClass;
	xmlString	: String;
	
begin
    on Exception do self.cnEcHandleOverflowException(exception);

	classFormat := cnEcGetFormatClass(pObject.class().getName);	
	if classFormat &lt;&gt; null then
		xmlString := classFormat.cnEcXmlOutput(pObject, pDebug, pMaxObjectCount, pCurrentObjectCount, pMaxResponseSize);
	else
		
		CnEcBaseXmlException.raise_(CNEC_X_02801, "No class format for " &amp; self.formatName &amp; " [" &amp; pObject.class().getName &amp; "]");

	endif;
	
	return xmlString;	
end;</source>
        <Parameter name="pObject" type="Object"/>
        <Parameter name="pDebug" type="Boolean"/>
        <Parameter name="pMaxObjectCount" type="Integer" usage="io"/>
        <Parameter name="pCurrentObjectCount" type="Integer" usage="io"/>
        <Parameter name="pMaxResponseSize" type="Integer" usage="io"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getFormatClass" id="adc19608-78cc-483a-b7f1-8a737a88db65">
        <source>getFormatClass(pName : String):CnEcXmlFormatClass;

begin
	return self.allFormatClasses.getAtKey(pName);
end;</source>
        <Parameter name="pName" type="String"/>
        <ReturnType type="CnEcXmlFormatClass"/>
    </JadeMethod>
    <JadeMethod name="getFormatClassByTagName" id="aeb3ba7c-038a-4dae-8bf9-daf912f9145b">
        <source>getFormatClassByTagName(pName : String):CnEcXmlFormatClass;

vars
	format	: CnEcXmlFormatClass;
	
begin
	foreach format in self.allFormatClasses do
		if format.tagName = pName then
			return format;
		endif;
	endforeach;
	
	return null;
end;</source>
        <Parameter name="pName" type="String"/>
        <ReturnType type="CnEcXmlFormatClass"/>
    </JadeMethod>
    <JadeMethod name="getGodBit" id="5e9afd7f-836c-4b8a-9b3a-4095629f4882">
        <source>getGodBit():Integer;

begin
	return self.godBit;
end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="initializeMe" id="6ed76310-4fbe-4edb-9b83-f5929f98ea43">
        <updating/>
        <source>initializeMe(pName : String; pGodBit : Integer; pSchema : Schema) updating;

begin
	self.formatName	:=	pName;
	self.godBit		:=	pGodBit;
	self.schemaName	:=	pSchema.name;
	self.myBaseRoot	:=	app.myBaseRoot;
end;</source>
        <Parameter name="pName" type="String"/>
        <Parameter name="pGodBit" type="Integer"/>
        <Parameter name="pSchema" type="Schema"/>
    </JadeMethod>
    <JadeMethod name="renameMe" id="b5311a65-163b-4363-8bcf-85ccbe09a292">
        <updating/>
        <source>renameMe(pName : String)updating;

begin
	if pName &lt;&gt; self.formatName then
		self.formatName := pName;
	endif;		
end;</source>
        <Parameter name="pName" type="String"/>
    </JadeMethod>
    <JadeMethod name="setGodBit" id="8ae9af4b-0dd1-48bf-b0e8-a1fe0021d787">
        <updating/>
        <source>setGodBit(value : Integer) updating;

begin
	if self.godBit &lt;&gt; value then
		self.godBit := value;
	endif;		
end;</source>
        <Parameter name="value" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="upgrade" id="9dfca2fc-c97e-41ff-92f2-2da08de2c2e5">
        <updating/>
        <source>upgrade(pSchemaName : String) updating;
	// can be deleted once the schemaName data has been populated
	// NDL 27/10/00
begin
	self.schemaName	:=	pSchemaName; 
end;</source>
        <Parameter name="pSchemaName" type="String"/>
    </JadeMethod>
    <JadeMethod name="xCnEcXmlImport" id="fa9dd27f-9b11-40d8-9045-389ff3298d32">
        <updating/>
        <source>xCnEcXmlImport(	pInput:CnEcXmlStructureInstance;
				pOidTableRoot:CnEcOidTable io;
				pLoadStage:Integer;
				pErrorMsg:String io;
				pFormat:CnEcXmlFormat):Boolean updating;

vars
	inputField		: CnEcXmlStructureInstance;
	thePropertyColl	: PropertyNDict;
	theProperty		: Property;
	propertyColl	: ObjectArray;
	theObject		: Object;
	value			: String;
	isDataCreated	: Boolean;
	oidTable		: CnEcOidPair;
	inheritClass	: Class;
	collection		: Collection;

begin

	pErrorMsg := "";

	if pLoadStage &lt;&gt; CNEC_DATA_LOAD_ATTRIBUTE  and pLoadStage &lt;&gt; CNEC_DATA_LOAD_SINGLETON and pLoadStage &lt;&gt; CNEC_DATA_LOAD_COLLECTION  then
		pErrorMsg := " LoadStage parameter invalid ";
    	return null;	
	endif;

	if pOidTableRoot = null then
		pErrorMsg := " OidTableRoot parameter invalid ";
    	return null;	
	endif;

	if pInput = null then
		pErrorMsg := " HubMsgStructureInstance parameter invalid ";
    	return null;	
	endif;

	if pLoadStage = CNEC_DATA_LOAD_ATTRIBUTE then
		// find the old oid to populate the dictionary for cross referencing.
		inputField := pInput.findStructure("oid");
		if app.isValidObject(inputField) then
			value := inputField.tagData;
			if value &lt;&gt; "" then
				create oidTable;
				oidTable.intializeMe(self.getOidString(), value, pOidTableRoot);
			endif;
		endif;
	else
	endif;


	// get a coll of each of the properties.
	create propertyColl transient;
//	self.class.getProperties.copy(propertyColl);		// cnwdad1 28/11/2002.
	thePropertyColl	:=	self.class().getProperties();	// cnwdad1 28/11/2002.
	thePropertyColl.copy(propertyColl);					// cnwdad1 28/11/2002.
	delete thePropertyColl;								// cnwdad1 28/11/2002.

	inheritClass := self.class();
	while inheritClass.name &lt;&gt; Object.name do	// add all the inherited properties too.
		inheritClass	:=	inheritClass.getSuperclass();
		thePropertyColl	:=	inheritClass.getProperties();	// cnwdad1 28/11/2002.
		
		foreach theProperty in thePropertyColl do
			propertyColl.add(theProperty); 
		endforeach;
		
		delete thePropertyColl;								// cnwdad1 28/11/2002.
	endwhile; 

	// check each property in the collection	
    foreach theObject in propertyColl do
    	theProperty := theObject.Property;
        // see if we have a property by this name 
		inputField := pInput.findStructure(theProperty.getName());
		if app.isValidObject(inputField) then
			value := inputField.tagData;
			if value = "" then
				continue;
			endif;
		else
			continue;	 
		endif;

     	if theProperty.isKindOf(Reference) then

			if pLoadStage = CNEC_DATA_LOAD_ATTRIBUTE then  // not loading references in this pass.
    			continue;
			endif;		

     		if theProperty.getType.isKindOf(CollClass) then
     			if pLoadStage &lt;&gt; CNEC_DATA_LOAD_COLLECTION then  // not loading collections in this pass.
    				continue;
				endif;	
				//if it is a collection
				foreach inputField in pInput.findStructure(theProperty.getName()).CnEcXmlGroupInstance.allFields do

					value := inputField.tagData;
					theObject := pOidTableRoot.getObject(value);
					if theObject &lt;&gt; null then  
     					collection := self.getPropertyValue(theProperty.getName()).Collection;
     					if not collection.includes(theObject) then
     						collection.add(theObject);
     					endif;
     				endif;	 		

                	isDataCreated := true;
                endforeach;
     		else
     			// It must be a singleton reference
     			if pLoadStage &lt;&gt; CNEC_DATA_LOAD_SINGLETON  then  // not loading singleton references in this pass.
    				continue;
				endif;
				if theProperty.getName() = CnEcXmlFormat::myBaseRoot.name then // allows for the load of XMLFormats by XMLFormatter
					self.setPropertyValue(theProperty.getName(), app.myBaseRoot);	
    	 			isDataCreated := true; 
				else 	
					inputField := pInput.findStructure(theProperty.getName());
					if app.isValidObject(inputField) then
						inputField := inputField.findStructure("OID");
						if app.isValidObject(inputField) then
							value := inputField.tagData;
  							theObject := pOidTableRoot.getObject(value);
  							//set up errorMsg in case of a 1310.
  							pErrorMsg := "Got '1310' doing 'self.setPropertyValue(property.getName(), object)', where self = " &amp; self.String &amp; ", property.getName() = " &amp; theProperty.getName() &amp; ", object = " &amp; theObject.String;
  							self.setPropertyValue(theProperty.getName(), theObject);	
    	 					isDataCreated := true;
    	 					pErrorMsg := ""; //reset the error if I got this far.. 
						endif;
					endif;
				endif;		
			
     		endif;

     	elseif theProperty.isKindOf(Attribute) then

			if pLoadStage &lt;&gt; CNEC_DATA_LOAD_ATTRIBUTE then  // Not loading attributes in this pass.
    			continue;
			endif;

     		if theProperty.getType = String then 
     			self.setPropertyValue(theProperty.getName(), value);
     		elseif theProperty.getType = Integer then 
     			self.setPropertyValue(theProperty.getName(), value.Integer);
     		elseif theProperty.getType = Real then 
     			self.setPropertyValue(theProperty.getName(), value.Real);
     		elseif theProperty.getType = Decimal then 
     			self.setPropertyValue(theProperty.getName(), value.Decimal);
     		elseif theProperty.getType = Boolean then 
     			self.setPropertyValue(theProperty.getName(), value.Boolean);
     		elseif theProperty.getType = Binary then 
     			self.setPropertyValue(theProperty.getName(), value.Binary);
     		elseif theProperty.getType = Character then 
     			self.setPropertyValue(theProperty.getName(), value.Character);
     		elseif theProperty.getType = Date then 
     			self.setPropertyValue(theProperty.getName(), value.Date);
     		elseif theProperty.getType = Point then 
     			self.setPropertyValue(theProperty.getName(), value.Point);
     		elseif theProperty.getType = Time then 
     			self.setPropertyValue(theProperty.getName(), value.Time);
     		elseif theProperty.getType = TimeStamp then 
     			self.setPropertyValue(theProperty.getName(), value.TimeStamp);
     		endif;
     		isDataCreated := true;	
     	endif;

	endforeach; 

    return isDataCreated;    

epilog
	delete propertyColl;
end;</source>
        <Parameter name="pInput" type="CnEcXmlStructureInstance"/>
        <Parameter name="pOidTableRoot" type="CnEcOidTable" usage="io"/>
        <Parameter name="pLoadStage" type="Integer"/>
        <Parameter name="pErrorMsg" type="String" usage="io"/>
        <Parameter name="pFormat" type="CnEcXmlFormat"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
