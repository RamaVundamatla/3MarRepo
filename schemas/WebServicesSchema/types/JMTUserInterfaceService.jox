			connectParams.radioTelemetryUser           := false;
			app.myTrxUA.trxUpdateDisconnect(connectParams, app.myPassport);
		endif;
	endif;
	
	// PAR 20338 18807
	app.myPassport.setupForDeadlockReplay(-100, 2000);
	
	while true do
		self.setIgnoreWarnings(true);  					
		app.myTrxUA.trxMachineDriverInitiatedMove(currentSession.myCurrentMachine,cargo, twinCargo, _request.quantity,_request.weight,  app.myPassport);
	
		if app.myPassport.noTrxReplayAllowed() then	//15 Jan 2013	NDL	Par 30920
			break;
		endif;

	endwhile;
	
	if app.myPassport.noErrors then
		create wsMachineTasks transient;
		wsMachineTasks.setProxyFromObject(currentSession.myCurrentMachine);	
