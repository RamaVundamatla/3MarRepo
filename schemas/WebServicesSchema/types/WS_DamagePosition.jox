<Class name="WS_DamagePosition" id="7c61f80f-c28b-4571-b6e1-e77d8af87cc6">
    <superclass name="WS_ProxyObject"/>
    <transient/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>The Damage Position used to define the position of damage on cargo or machines.</text>
    <DbClassMap file="webservice"/>
    <ImplicitInverseRef name="allCargoTypes" id="ed63a259-9c85-41ab-a015-a1be99ca193e">
        <memberTypeInverse/>
        <type name="WS_CargoTypeArray"/>
        <text>The list of cargo types that this damage position applies to</text>
    </ImplicitInverseRef>
    <PrimAttribute name="code" id="fe3eb77a-592c-46bf-9a77-9e03ddcadc94">
        <length>11</length>
        <embedded/>
        <type name="String"/>
        <text>Damage Position code ex.LL</text>
    </PrimAttribute>
    <PrimAttribute name="description" id="a554b6c0-6657-4ef9-92d7-13b07ec7fc36">
        <length>31</length>
        <embedded/>
        <type name="String"/>
        <text>Damage Position description ex. Lower Left</text>
    </PrimAttribute>
    <JadeMethod name="delete" id="3ea686b5-555b-4c71-8cae-8c2e1efbed16">
        <updating/>
        <source>delete() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
17 October 2011	cnwndl1	Initial creation	Par 28303

*/

vars

begin

	if not self.allCargoTypes.isEmpty then
		self.allCargoTypes.purge();
	endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setAllCargoTypes" id="dde94622-46ae-488f-bebd-d36b78f66ebe">
        <updating/>
        <source>setAllCargoTypes( _object : CM_DamagePosition ) updating;

/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 July 2022	jlier1	Initial creation 53971

*/

vars
	cargoType : CM_CargoType;
	wsCargoType : WS_CargoType;
begin
	foreach cargoType in _object.allActiveCargoTypes discreteLock do
		create wsCargoType transient;
		wsCargoType.setProxyFromObject( cargoType );
		wsCargoType.description := cargoType.abbreviation;
		self.allCargoTypes.add( wsCargoType );
	endforeach;
epilog

end;</source>
        <Parameter name="_object" type="CM_DamagePosition"/>
    </JadeMethod>
    <JadeMethod name="setProxyFromObject" id="32673a2d-3068-49ac-8f32-cabf525e7878">
        <updating/>
        <source>setProxyFromObject( _object : CM_DamagePosition ) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
17 October 2011	cnwndl1	Initial creation	Par 28303

*/

vars

begin
	inheritMethod(_object);
	
	self.code := _object.code;
	self.description := _object.description;
	

epilog

end;</source>
        <Parameter name="_object" type="CM_DamagePosition"/>
    </JadeMethod>
</Class>
