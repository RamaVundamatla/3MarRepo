    <JadeMethod name="setFilterValues" id="9e0b1a58-de12-41fc-ae5e-a9258b963861">
        <updating/>
        <source>setFilterValues() updating;

vars
	obj : Object;
begin

	self.clearFilterValues();
	
	self.filterID := self.tblSearcher.getValueByNameIfVisible(ETRow_Id).String;
	
	if self.isWagonMaster() then // 03 Jul 2009	NDL	CCMS 1067
		// nothing extra yet.
	
	elseif self.isTILC() then 
		obj := self.cmbTILCType.listObject;
		if obj &lt;&gt; null then
			self.filterCargoType := self.cmbTILCType.listObject.CM_TILCType.code;	
		endif;
	
		obj := self.cmbOperator.listObject;
		if obj &lt;&gt; null then
			self.filterOperator := self.cmbOperator.listObject.CM_Operator.code;
		endif;
	
	elseif self.isGenerator() then
		obj := self.cmbGeneratorType.listObject;
		if obj &lt;&gt; null then
			self.filterGeneratorType := self.cmbGeneratorType.listObject.CM_GeneratorType.code;	
		endif;
	
	else
			
		obj := self.cmbOperator.listObject;
		if obj &lt;&gt; null then
			self.filterOperator := self.cmbOperator.listObject.CM_Operator.code;
		endif;
		
		
		obj := self.cmbISOType.listObject;
		if obj &lt;&gt; null then
			self.filterISOType := self.cmbISOType.listObject.CM_ISOType.code;
		endif;
		
		
		//upper		
		self.filterUpper := self.tblSearcher.getValueByNameIfVisible(ETRow_RangeEnd).String;
		//lower
		self.filterLower := self.tblSearcher.getValueByNameIfVisible(ETRow_RangeStart ).String;
	
	endif;
	
end;
</source>
    </JadeMethod>
    <JadeMethod name="setMyCurrentTiMaster" id="b561ac0d-d24d-45f4-800d-54196885f850">
        <updating/>
        <source>setMyCurrentTiMaster(_tiMaster : CM_Object) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
25 September 2008	cnwrd1	Initial creation

*/

vars

begin

	if self.isWagonMaster then	// 03 Jul 2009	NDL	CCMS 1067
		self.myCurrentWagonMaster := _tiMaster.CM_WagonMaster;
		self.myCurrentTiMaster := null;
	else
		self.myCurrentWagonMaster := null;
		self.myCurrentTiMaster := _tiMaster.CM_TIMaster;
	endif;

epilog

end;</source>
