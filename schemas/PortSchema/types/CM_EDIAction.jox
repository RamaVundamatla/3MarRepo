    </JadeMethod>
    <JadeMethod name="validateForUpdate" id="8ef1e3b6-f4d0-433b-a69d-ab019dd0ef2b">
        <source>validateForUpdate();
//----------------------------------------------------------------
//	Created:	01 September 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin

	
	if self.name = null then
		app.raiseCMException2(ERR_INVALID_VALUE,"Name","A Name Must Be Entered.",null,null);
	endif;
	
	if self.keyword.trimBlanks = null then
		if self.myEDIFileType.type &lt;&gt; EDIFileType_XMLOneStopCust then	//08 Sep 2016	NDL	TFS 2278 / 2670
			app.raiseCMException2(ERR_INVALID_VALUE,"Keyword","A Keyword or Phrase Must Be Entered.",null,null);
		endif;
	endif;
	
	if self.myEDIFileType = null then
		app.raiseCMException2(ERR_INVALID_VALUE,"File Type","A File Type Must Be Selected.",null,null);
	elseif self.actionType= null then 
		app.raiseCMException2(ERR_INVALID_VALUE,"Action Item/Action Type","An Action Item must be selected.",null,null);
	elseif self.myEDIFileType.type = EDIFileType_CusRes then
		if self.myActionObject = null then // cnwgb1 5.10.08 CCMS SFW 1012
			app.raiseCMException2(ERR_INVALID_VALUE,"Action Item","An Action Item must be selected.",null,null);
		endif;
	endif;

end;</source>
    </JadeMethod>
</Class>
