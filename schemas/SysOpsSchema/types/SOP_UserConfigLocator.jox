    <JadeMethod name="txtLog_dblClick" id="8a62b063-c456-468d-877c-8b092f49c472">
        <controlMethod name="TextBox::dblClick"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>txtLog_dblClick(textbox: TextBox input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 September 2014	cnwndl1	Initial creation

*/

vars
	textboxObj : TextBox;
	
begin
	app.mousePointer	:=	Busy;
	textboxObj := textbox;
	self.selectFile(textboxObj);
epilog
	app.mousePointer	:=	Idle;
end;</source>
        <Parameter name="textbox" type="TextBox" usage="input"/>
