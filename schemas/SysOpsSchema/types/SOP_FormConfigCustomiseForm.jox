    <JadeMethod name="addToolbarControls" id="a4f99729-d595-4c50-9721-3822befdd01b">
        <source>addToolbarControls() protected;
// ---------------------------------------------------------------------------
// Created:     21 August 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	toolbar			: CMUI_Toolbar;
begin

	toolbar := self.frmToolbar;

	toolbar.addButton(self.btnSaveBase, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnCancelBase, CMUI_Toolbar.Control_Alignment_Right);
//	toolbar.addButton(self.btnDeleteTV, CMUI_Toolbar.Control_Alignment_Left);
//	toolbar.addButton(self.btnSelectAllTV, CMUI_Toolbar.Control_Alignment_Left);
	
	toolbar.positionToolbarControls();

	toolbar.visible := true;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="cloneControl" id="92faf690-8a83-4fce-8c08-01410bb0379c">
        <updating/>
        <source>cloneControl(_control :Control; _coll :CMUI_ControlsByNameDict input)updating;
/*
	Purpose:			
	Parameters:			
	Return Value:		

Date		Who		Reason
30 July 2008	concms1	Initial creation
*/

vars
	c :Control;
begin
	c := _control.cloneSelf (true);
	
	_coll.putAtKey (c.name, c);
epilog

end;</source>
        <Parameter name="_control" type="Control"/>
        <Parameter name="_coll" type="CMUI_ControlsByNameDict" usage="input"/>
    </JadeMethod>
    <JadeMethod name="create" id="ec8e1dcb-d078-43fb-9c6a-fb3b52166e6c">
        <updating/>
        <executionLocation>client</executionLocation>
        <source>create() updating, clientExecution;
// ---------------------------------------------------------------------------
// Created:     02 September 2008 by concms1:1
//
// Purpose:     User definable forms - CCMS 1011
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	// just use these permissions for the time being till we create some new ones
	self.permissionView   := PmFaultEnquiryView;
	self.permissionMaint  := PmFaultEnquiryView;
	
	create self.myAgent transient;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="delete" id="a826e21f-e3e2-4395-afef-63c917d4954e">
        <updating/>
        <executionLocation>client</executionLocation>
        <source>delete() updating, clientExecution;
