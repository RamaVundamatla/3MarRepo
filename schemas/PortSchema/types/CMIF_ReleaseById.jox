// ---------------------------------------------------------------------------

vars

begin
	return self.myTrackedItem;
epilog

end;</source>
        <ReturnType type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="isContainer" id="bef5209a-b0e3-4853-b97b-81c85ed1da68">
        <source>isContainer(): Boolean protected;
// --------------------------------------------------------------------------------
// Created:		05 May 2009 by cnwdad1
//
// Purpose:		Refer to superclass implementation.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return (self.cargoType = TI_CargoType_Container);
end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setForAAAI" id="5c90a17c-3344-4913-b0b5-4b2418b611c3">
        <updating/>
        <source>setForAAAI( _bulkReleaseObj : CM_BulkRelease ) updating;
/*

Purpose:			

Parameters:			Set for 'Any Amount Any Id'

Return Value:		

Date		Who		Reason
19 May 2020	jlgndl1	Initial creation	TFS 49167
23/06/2023	navkc1	CR 58406 Task 58408: Jade - Release Request All Tracked Items
*/

vars

begin
	if _bulkReleaseObj = null then
		app.raiseCMException2(MethodWithNullParam, method.name, '_bulkReleaseObj', null, null);
		return;
	endif;
	
	self.myTerminal				:=	_bulkReleaseObj.myTerminal;			
	self.consigneeCode			:=	_bulkReleaseObj.consigneeCode;
	self.myBulkRelease			:=	_bulkReleaseObj;
	

	self.freightForwarderCode	:= null;
	if _bulkReleaseObj.myFreightForwarder &lt;&gt; null then
		self.freightForwarderCode := _bulkReleaseObj.myFreightForwarder.code;
	endif;

	self.freightPayerCode		:=	_bulkReleaseObj.freightPayerCode;
	self.removeStops			:=	false;	// ???
	self.ignoreWarnings			:=	true;

	self.consignorVoyageCode	:= _bulkReleaseObj.consignorVoyageCode;
	self.deliveryReason			:= _bulkReleaseObj.deliveryReasonDescr;
	self.doorsDirection			:= _bulkReleaseObj.doorsDirection;
	self.eirNumber				:= null;								
	self.needCOU				:= false;								
	self.needGenerator			:= false;							
	self.remarks				:= _bulkReleaseObj.cargoRemarks;

	self.myTransferToTerminal := _bulkReleaseObj.myTransferToTerminal;
	
	self.id := "";
	//self.cargoType := _bulkReleaseObj.allReserveDetails.first.allTrackedItems.first().cargoType;
	self.cargoType := _bulkReleaseObj.allReserveDetails.first.getFirstTI(false).cargoType; //23/06/2023	navkc1	CR 58406 Task 58408
	
	self.deliveryReleaseNumber := _bulkReleaseObj.deliveryReleaseNumber;
	
	self.deliveryReleaseNumber := _bulkReleaseObj.code;
	
	self.isAnyAmountAnyId := true;
	
epilog

end;</source>
        <Parameter name="_bulkReleaseObj" type="CM_BulkRelease"/>
    </JadeMethod>
    <JadeMethod name="setForTypeChassis" id="07a4e2a3-ce07-4139-8e21-91ff2ced0ae7">
        <updating/>
        <source>setForTypeChassis(_cargoType : Integer; _id : String; _consigneeCode : String; _consVoyCode : String; _delReleaseNum : String; _terminal : CM_Terminal ) updating;
//----------------------------------------------------------------------
//
//  Created by cnwsh3
//
//	Date 08 August 2007
//
//----------------------------------------------------------------------

vars

begin
	self.cargoType := _cargoType;
	self.id := _id;
	self.consigneeCode := _consigneeCode;
	self.consignorVoyageCode := _consVoyCode;
	self.deliveryReleaseNumber := _delReleaseNum;
	self.myTerminal := _terminal;
epilog

end;</source>
        <Parameter name="_cargoType" type="Integer"/>
        <Parameter name="_id" type="String"/>
        <Parameter name="_consigneeCode" type="String"/>
        <Parameter name="_consVoyCode" type="String"/>
        <Parameter name="_delReleaseNum" type="String"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="setFromBulkRelease" id="191b70eb-c730-467c-b9a6-585e4faf3ac3">
        <updating/>
        <source>setFromBulkRelease(_bulkReleaseObj : CM_BulkRelease; _reserveDetail : CM_ReserveDetail) updating;
// --------------------------------------------------------------------------------
// Created:		23 February 2009 by cnwjo3
//
// Purpose:		Set all necessary promperties of CMIF_ReleaseById to allow for
//				Release By Item objects to be created and Road Jobs to be created
//
// Parameters:	
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 23/09/2009	consw1		SFW1035 - get info from ReserveDetail rather than Yard Request
// 23/06/2023	navkc1	CR 58406 Task 58408: Jade - Release Request All Tracked Items
// 18/07/2023	navkc1	Defect 59184: EUP - Kiosk - Unexpected Error Occurred message appearing when trying to release 2 containers
// --------------------------------------------------------------------------------
vars
//	requestObj : CM_Request;
//	reserveDetail : CM_ReserveDetail;
//	yardRequestObj	: CM_YardRequest;
//	deliveryObj		: CM_DeliveryRequest;	
//	allStringsObj	: HugeStringArray;
	firstTi			: CM_TrackedItem;
begin
	if _bulkReleaseObj = null then
		app.raiseCMException2(MethodWithNullParam, method.name, '_bulkReleaseObj', null, null);
		return;
	elseif _reserveDetail = null then
		app.raiseCMException2(MethodWithNullParam, method.name, '_reserveDetail', null, null);
		return;
	endif;
//	requestObj := _bulkReleaseObj.requests.first();
	
//	if requestObj = null then
//		app.raiseUnexpectedProgramError(class.name, method.name, 'Release object null for (' &amp; _bulkReleaseObj.String &amp; ')');
//		return;
//	endif;
	
	self.myTerminal				:=	_bulkReleaseObj.myTerminal;			// app.getMyTerminal();
	self.consigneeCode			:=	_bulkReleaseObj.consigneeCode;
//	self.myBulkRelease			:=	requestObj.bulkRelease;
	self.myBulkRelease			:=	_bulkReleaseObj;
	
//	reserveDetail 				:=  _rd;
	
//	self.freightForwarderCode	:=	requestObj.freightForwarderCode;
	self.freightForwarderCode	:= null;
	if _bulkReleaseObj.myFreightForwarder &lt;&gt; null then
		self.freightForwarderCode := _bulkReleaseObj.myFreightForwarder.code;
	endif;
//	self.freightPayerCode		:=	requestObj.freightPayerCode;
	self.freightPayerCode		:=	_bulkReleaseObj.freightPayerCode;
	self.removeStops			:=	false;	// ???
	self.ignoreWarnings			:=	true;
/*
	if requestObj.isKindOf(CM_YardRequest) then
		yardRequestObj				:=	requestObj.CM_YardRequest;
		self.consignorVoyageCode	:=	yardRequestObj.consignorVoyageCode;
		self.deliveryReason			:=	yardRequestObj.reasonCodeDescr;
		self.doorsDirection			:=	yardRequestObj.doorsDirection;
		self.eirNumber				:=	yardRequestObj.eirNumber;
		self.needCOU				:=	yardRequestObj.needCOU;
		self.needGenerator			:=	yardRequestObj.needGenerator;
		self.remarks				:=	yardRequestObj.remarks;
	endif;	
*/
	self.consignorVoyageCode	:= _bulkReleaseObj.consignorVoyageCode;
	self.deliveryReason			:= _bulkReleaseObj.deliveryReasonDescr;
	self.doorsDirection			:= _bulkReleaseObj.doorsDirection;
	self.eirNumber				:= null;								// looks like this was not set up in CM_YardRequest
	self.needCOU				:= false;								// looks like this was not set up in CM_YardRequest
	self.needGenerator			:= false;								// looks like this was not set up in CM_YardRequest
	self.remarks				:= _bulkReleaseObj.cargoRemarks;

	self.myTransferToTerminal := _bulkReleaseObj.myTransferToTerminal; //cnwrd1 par 25216 if the bulk release has a transfer to terminal need to set it here. 5.8.2010	
/*
	if requestObj.isKindOf(CM_DeliveryRequest) then
		deliveryObj					:=	requestObj.CM_DeliveryRequest;
		
		//there is a CM_DeliveryRequest but none of
		//the properties will fit in this object
		//hopefully this object is complete and finished
		
		
	elseif requestObj.isKindOf(CM_TIRequest) then
		// There are two properties on CM_TI_Request, neither of which appear relevant ?
		// CM_TIRequest.myTrackedItemIfRelease (type=CM_TrackedItem)
		// CM_TIRequest.trackedItem (type=CM_TrackedItem)
	else
		app.raiseUnexpectedProgramError(class.name, method.name, 'Unhandled release type (' &amp; requestObj.String &amp; ')');
		return;
	endif;
*/	
	//if _reserveDetail.allTrackedItems.size &gt; 1 then
	if _reserveDetail.getAllTrackedItemsSize(false) &gt; 1 then // 18/07/2023	navkc1	Defect 59184
		app.msgBox("Unexpected Error Occurred","Unexpected Error Occurred",0);
	endif;
	
	firstTi := _reserveDetail.getFirstTI(false); //23/06/2023	navkc1	CR 58406 Task 58408
	self.id := firstTi.id; //23/06/2023	navkc1	CR 58406 Task 58408
	self.cargoType := firstTi.cargoType; //23/06/2023	navkc1	CR 58406 Task 58408
	
	self.deliveryReleaseNumber := _bulkReleaseObj.deliveryReleaseNumber;
	
	//not sure if this is correct
	//cnwjo3
	self.deliveryReleaseNumber := _bulkReleaseObj.code;
	
epilog
//	delete allStringsObj;	
end;</source>
        <Parameter name="_bulkReleaseObj" type="CM_BulkRelease"/>
        <Parameter name="_reserveDetail" type="CM_ReserveDetail"/>
    </JadeMethod>
    <JadeMethod name="setFromTI" id="093fb575-2cf6-4a2d-96cc-e06566f1b4fa">
        <updating/>
        <source>setFromTI(_ti: CM_TrackedItem; _terminal: CM_Terminal) updating;
// ---------------------------------------------------------------------------
// Created:     26 August 2008 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------
//22 Jan 2018	jlgrs1	TFS 36627 - PENN - Request request code length too short

vars

begin
	inheritMethod(_ti, _terminal);
	
	//aparently this was for fast gate - removed - cnwjo3
	//self.deliveryReleaseNumber	:=	_ti.deliveryRelease; // PAR 17703

epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="setGateItemDetail" id="022e49c7-a5a2-4a76-86c0-2863f8ec3d38">
        <source>setGateItemDetail(_git : CM_GateItemDetail input);
// ---------------------------------------------------------------------------
// Created:     16 September 2008 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin
	if _git = null then
		return;
	endif;
	
	_git.id := self.id;
	_git.cargoType := self.cargoType;
	_git.bookingRef := self.bookingReference;
	
	
epilog

end;</source>
        <Parameter name="_git" type="CM_GateItemDetail" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setMyTrackedItem" id="8e995f93-db6e-4a23-b65a-b3b7f91b0ea9">
        <updating/>
        <source>setMyTrackedItem(_raiseExp : Boolean) : Boolean updating;
//--------------------------------------------------------------
//Created: 28 March 2003 By: cnwgd1
//--------------------------------------------------------------
vars
	tmpBR : CM_BulkRelease;
	tmpTI : CM_TrackedItem;
begin
	//Make sure TI exists before continuing
	if self.id = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Cargo Id', ETRow_IdCombo, self.myUserObject);
		app.raiseCMException(Input_required_field_cargoId, ETRow_IdCombo, self.myUserObject); // cnwdb2	PAR 35364
		return false;
	else		
		self.myTrackedItem := self.myTerminal.allOnsiteTIsByIdCargoType[self.id, self.cargoType];
		if self.myTrackedItem = null 
		and _raiseExp then // PAR 17703
			app.raiseCMException1(ERR_TI_NOT_ONSITE, self.id, 'id', self.myUserObject);
			return false;
		endif;
	endif;

	tmpTI := self.myTrackedItem; // AKB2005MAY handle duplicate BR Codes
	
	if tmpTI = null then // PAR 17703
		return false;
	endif;

	if self.myBulkRelease = null then
		foreach tmpBR in tmpTI.allBulkReleasesAssigned do
			if tmpBR.code = self.deliveryReleaseNumber then
				self.myBulkRelease := tmpBR;
			endif;
		endforeach;
	endif;

	exclusiveLock(self.myTrackedItem);

	return true;
end;</source>
        <Parameter name="_raiseExp" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="updateTIChassis" id="c745e4b6-b20f-460f-855d-db144e32496b">
        <updating/>
        <source>updateTIChassis(_theJob : CM_RoadJob input; _passport : CM_Passport input): Boolean updating;
//----------------------------------------------------------------------
//
//  Created by cnwsh3
//
//	Date 29 July 2007
//
//----------------------------------------------------------------------

vars
	tiUpdateCntrlr : CMIF_TIUpdateController;
	request : CM_Request;
	wle		: CM_WorkListEntry;
begin
	if _theJob = null then
		return false;
	endif;

	tiUpdateCntrlr := app.createTIUpdateControl(TI_UPDMODE_NORMAL, app.getMyUserCode, null);
	
	self.myTrackedItem.setForUpdate(self.myProxyTrackedItem, tiUpdateCntrlr, null, true, _passport);	 //cnwrd1 28.8.09 par 20545
	
	//Add the request. This creates a real request from our proxy &amp; adds to job. It also creates the wles for each request, so needs to be done before the move
	request := _theJob.addRequest(self.myProxyRequest, _passport);
	if request = null 
	or _passport.hasErrors then
		return false;
	endif;
	
	wle := _theJob.getWLEForTI(self.myTrackedItem);
	
	//self.myTrackedItem.moveToLocation(_theJob.myVehicle.locationsController, _theJob, wle, null, REAL_MODE, false, true, false, false, false,  false, null,null, _passport);		// TFS 2651
	self.myTrackedItem.moveToLocation(_theJob.myVehicle.locationsController, _theJob, wle, null, REAL_MODE, false, true, false, false, false,  false, null,null,null,null,_theJob.myVehicleVisit, _passport);	// TFS 2651
	wle.rebuildStatus();
	return true;
epilog
	delete self.myProxyRequest;
	delete tiUpdateCntrlr;	
end;</source>
        <Parameter name="_theJob" type="CM_RoadJob" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="updateTICreateRequest" id="1aae7f3a-cde9-4dc0-9649-e81d3b73aedb">
        <updating/>
        <source>updateTICreateRequest(_theJob : CM_RoadJob input; _passport : CM_Passport input): Boolean updating;
// ---------------------------------------------------------------------------
// Created:     16 February 2001 by cnwaa2
//
// Purpose:     Action a release of a specific TI from a gate application form
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	tiUpdateCntrlr : CMIF_TIUpdateController;
	request : CM_Request;
	wle		: CM_WorkListEntry;
begin

	if _theJob = null then
		return false;
	endif;

	tiUpdateCntrlr := app.createTIUpdateControl(TI_UPDMODE_NORMAL, app.getMyUserCode, null);
	
	if self.myTrackedItem &lt;&gt; null then // PAR 17703
		self.myTrackedItem.setForUpdate(self.myProxyTrackedItem, tiUpdateCntrlr, null, true, _passport);	  //cnwrd1 28.8.09 par 20545
	endif;
	
	//Add the request. This creates a real request from our proxy &amp; adds to job
	// I also creates the wles for each request, so needs to be done before the move
	if self.myProxyRequest &lt;&gt; null then	//19 May 2020	NDL TFS 49167
		request := _theJob.addRequest(self.myProxyRequest, _passport);
	elseif self.isAnyAmountAnyId then	//19 May 2020	NDL TFS 49167
		request := _theJob.addKioskAAAIDelRequest( self, _passport );
	endif;
	
	if request = null 
	or _passport.hasErrors then
		return false;
	endif;
	
	if self.myTrackedItem &lt;&gt; null then // PAR 17703
		// Par 8543 Need wle for move validation to work correctly.
		wle := _theJob.getWLEForTI(self.myTrackedItem);
		if _theJob.autoComplete then
			// DVB 18/06/04 Par8253. Forced move does not validate so we can get duplicate queue entries
		
			//changed back to orignal  
			//self.myTrackedItem.moveToLocation(_theJob.myVehicle.locationsController, _theJob, wle, null, PLANNING_MODE, false, true, false, false, false,  false,null, null,_passport);		// TFS 2651
			self.myTrackedItem.moveToLocation(_theJob.myVehicle.locationsController, _theJob, wle, null, PLANNING_MODE, false, true, false, false, false,  false,null, null,null,null,_theJob.myVehicleVisit,_passport);	// TFS 2651
		endif;
	endif;
	
	return true;
	
epilog
	delete self.myProxyRequest;
	delete tiUpdateCntrlr;	
end;</source>
        <Parameter name="_theJob" type="CM_RoadJob" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validateForCreate" id="f858757a-a682-4b7b-a312-10d63a7608b3">
        <updating/>
        <source>validateForCreate(_passport : CM_Passport input): Boolean updating;

vars
	control	: CMIF_TIUpdateController;
	tmpTI	: CM_TrackedItem;
	
begin
	//Ensure proxies are null to begin with
	if self.myProxyTrackedItem &lt;&gt; null then
		self.myProxyTrackedItem.erase(NORMAL_ERASE);
		self.myProxyTrackedItem := null;
	endif;
	
	/* WAS PAR 17703
	//Make sure TI exists before continuing
	if (not self.setMyTrackedItem()) then
		return false;
	endif;
	NOW */
	if self.isAnyAmountAnyId then	//19 May 2020	NDL TFS 49167
		//we wont know the id yet.
		return true;
	else
		self.setMyTrackedItem(true); // PAR 17703
	endif;
	
	if self.myTrackedItem &lt;&gt; null then // PAR 17703
		///self.myTrackedItem.validateForBulkRelease(self.deliveryReleaseNumber);	// 02/12/2010 cnwmh5 #26400
		if self.myBulkRelease &lt;&gt; null then
			self.myTrackedItem.validateForBulkRelease(self.myBulkRelease.getDeliveryReleaseNumber());
		endif;
		
		//cnwrd1 6.11.08 CCMS JMT 1743/1764
		//validate freight forwarder
		self.myTrackedItem.validateOperatorRequiredFF();
		//validate ti for op imp release PIN
		if self.myTrackedItem.myPinNo = null and self.myTrackedItem.getImExStatus = TI_IMEX_STATUS_IMPORT then  //cnwrd1 par 27161 8.3.2010  only validae if we do NOT have a JMT pin + par 27209
			self.myTrackedItem.validateOpImpReleasePIN(self.importReleasePIN);
		endif;
		
		if _passport.hasErrors then
			// no point in going any further
			return false;
		endif;
		
		//Deep copy the real TI, update its data and validate it
		self.myProxyTrackedItem := app.createUpdateProxy(self.myTrackedItem).CM_TrackedItem;
		self.myProxyTrackedItem.setPxyFromCMIF_ReleaseById(self, _passport);
		
		control := app.createTIUpdateControl(TI_UPDMODE_RELEASE, null, self.myUserObject);
		self.myProxyTrackedItem.validateTrackedItem(control, _passport);
	endif; // PAR 17703
	
	//OK, now sling it in a request		
	return self.createProxyRequest(_passport);
epilog
	if control &lt;&gt; null then
		delete control;
	endif;
end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
