    <JadeMethod name="isSelectedLocationPixel" id="7146c9db-2320-4376-b035-a8970a67cd47">
        <source>isSelectedLocationPixel(x, y : Real) : Boolean;
// return true if this pixel is in the currently selected location
vars
	cell : Point;
begin
	cell := pixelToCell(x, y);
	if self.mySelectedLocation &lt;&gt; null and 
	   self.mySelectedLocation = self.getLocationForCell(cell) then
	   return true;
	endif;
	
	return false;
end;
</source>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isValidCell" id="d816fab1-39fb-425b-815e-41650e9440e8">
        <source>isValidCell(cell : Point) : Boolean protected;
//18 June 2008	cnwdw1	
// Return true if the cell has a valid row and column
begin
	return cell.x &gt;= 1 and cell.x &lt;= self.columns and cell.y &gt;= 1 and cell.y &lt;= self.rows;
end;</source>
        <access>protected</access>
        <Parameter name="cell" type="Point"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="pixelToCell" id="979fa63b-3412-49d8-b93c-1d63c1d7b4fb">
        <source>pixelToCell(x: Real; y: Real) : Point protected; 
// Convert a pixel point to a cell point
vars
	cell: Point;
begin
	cell.setX(((x - gridBorderWidth) / (cellSize.x + gridLineWidth)).Integer + 1);
	cell.setY(((y - gridBorderWidth) / (cellSize.y + gridLineWidth)).Integer + 1);
	if cell.x &lt; 1 or cell.x &gt; self.columns or cell.y &lt; 1 or cell.y &gt; self.rows then
		cell.setX(0);
		cell.setY(0);
	endif;
	return cell;
end;
</source>
        <access>protected</access>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
        <ReturnType type="Point"/>
    </JadeMethod>
