    <JadeMethod name="addHoldSubTotalLine" id="2e88e51c-5207-4114-9b8f-603a507d4366">
        <source>addHoldSubTotalLine( _holdId : String );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 August 2018	jlgndl1	Initial creation	TFS 40050

*/

vars
	
	
	subTotal : Decimal[6,2];
	rowIndex : Integer;
	holdDisplayStr : String;

begin
	
	holdDisplayStr := _holdId &amp; Tab	// hold Id
				&amp;	 "" &amp; Tab	// work point
				&amp;	 "" &amp; Tab //job  type
				&amp;	 "" &amp; Tab // operator
				&amp;	 "" &amp; Tab // consignee
				&amp;	 "" &amp; Tab // commodity
				&amp;	 "" &amp; Tab // moveAmount
				&amp;	 "" &amp; Tab // transfer type
				&amp;	 "" &amp; Tab // gangs
				&amp;	 "" &amp; Tab // hrs/day
				&amp;	 "" &amp; Tab // target/hr
				&amp;	 "" &amp; Tab // days to complete
				&amp;	 subTotal.asStringJMT;	// Hold sub total
					
	rowIndex := self.tblData.addItem( holdDisplayStr );
	self.tblData.accessRow( rowIndex ).inputType := Table.InputType_None;
	self.tblData.accessRow( rowIndex ).backColor := self.tblData.accessRow( 1 ).backColor;

epilog

end;</source>
        <Parameter name="_holdId" type="String"/>
    </JadeMethod>
    <JadeMethod name="addWodCargoRequestLine" id="70feb567-1ca8-4cc7-a03b-c0f68dd7d628">
        <source>addWodCargoRequestLine( wodCargoRequest : CM_WodCargoRequest; comboValues : String );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 June 2018	jlgndl1	Initial creation
// 19 Dec 2018	NDL	TFS Protect against deleted Workpoint object

*/

vars
	
	operStr : String;
	consignStr : String;
	workPoint : CM_WorkPoint;
	daysToComplete : Decimal[6,2];
	wpRate : CM_WorkPointCargoRates;
	dummyTi : CM_TrackedItem;
	gangs : Integer;
	wodDisplayStr : String;	
	rowIndex : Integer;
	commodStr : String;
	moveAmountStr : String;
	holdId : String;	//15 Aug 2018	NDL	TFS 40050
	hrsPerDay : String;
	targetPerHr : String;

begin

	operStr := wodCargoRequest.getOperatorCode;
	consignStr := wodCargoRequest.getConsigneeCode;
	workPoint := wodCargoRequest.getMyWorkPoint;
	daysToComplete := 0.0;
	gangs := wodCargoRequest.numGangs;
	commodStr := wodCargoRequest.getCommodityCode;
	moveAmountStr := wodCargoRequest.getMoveAmountStr;
	holdId := wodCargoRequest.getHoldId;
	
	if workPoint &lt;&gt; null then
		wpRate := workPoint.getDefinedTargetRate( wodCargoRequest, null, dummyTi );
		if wpRate &lt;&gt; null then
			hrsPerDay := wpRate.dailyHoursWorkable.asStringJMT;
			targetPerHr := wpRate.getTargetRateStr;
			daysToComplete := wpRate.getDaysToComplete( wodCargoRequest, gangs, false );
		endif;
	endif;
	
	wodDisplayStr := holdId &amp; Tab	// hold Id
				&amp;	 wodCargoRequest.getWorkPointCode &amp; Tab	// work point
				&amp;	 wodCargoRequest.getJobTypeDescription &amp; Tab //job  type
				&amp;	 operStr &amp; Tab // operator
				&amp;	 consignStr &amp; Tab // consignee
				&amp;	 commodStr &amp; Tab // commodity
				&amp;	 moveAmountStr &amp; Tab // moveAmount
				&amp;	 wodCargoRequest.getTransferTypeStr &amp; Tab // transfer type
				&amp;	 gangs.asStringJMT &amp; Tab // gangs
				&amp;	 hrsPerDay &amp; Tab // hrs/day
				&amp;	 targetPerHr &amp; Tab // target/hr
				&amp;	 daysToComplete.asStringJMT &amp; Tab // days to complete
				&amp;	 "";	// Hold sub total
					
	rowIndex := self.tblData.addItem( wodDisplayStr );
	self.tblData.accessRow( rowIndex ).itemObject := wodCargoRequest;
	self.tblData.accessRow( rowIndex ).inputType := Table.InputType_None;
	self.tblData.accessCell( rowIndex, TransferTypeCol ).inputType := Table.InputType_ComboBox;
	self.tblData.accessCell( rowIndex, TransferTypeCol).comboList := comboValues;
	self.tblData.accessCell( rowIndex, GangsCol ).inputType := Table.InputType_TextNumeric;

epilog

end;</source>
        <Parameter name="wodCargoRequest" type="CM_WodCargoRequest"/>
        <Parameter name="comboValues" type="String"/>
    </JadeMethod>
