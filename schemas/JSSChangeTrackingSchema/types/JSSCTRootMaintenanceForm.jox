    <JadeMethod name="btnUpdate_click" id="db553b25-3b12-48af-9e5c-71cd584b6df8">
        <controlMethod name="JadeMask::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnUpdate_click(jadeMask: JadeMask input) updating;
/*
Date		Who		Reason
03 Feb 2011	cnwrs1	PAR #25828 - using up too many licences

*/
vars
//	days: Integer;
	journalNum : Integer;
	mgr : JSSCTNibblerManager;
begin
//	days := txtDays.text.Integer;	//par 25828 cnwrs1 3 Feb 2011
/*
	if days &lt; 2 or days &gt; 366 then
		app.msgBox("Number of days to track changes must be in range 2 - 366 (inclusive).",
					"Validation Error", MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
//		txtDays.text := self.myChangeTrackingRoot.daysToKeepTrackingChanges.String;
		txtDays.setFocus();
		return;
	endif;
	self.myChangeTrackingRootTA.daysToKeepTrackingChanges := days;
	self.myChangeTrackingRootTA.updateEntity();
*/
//	txtDays.text := self.myChangeTrackingRoot.daysToKeepTrackingChanges.String;
	
	if self.txtJournalNum.text &lt;&gt; null then
		journalNum := self.txtJournalNum.text.Integer;
		mgr := JSSCTNibblerManager.firstInstance;
	
		if mgr &lt;&gt; null then
			beginTransaction;
			mgr.setPropertyValue("lastAuditFileNumber", journalNum);
			mgr.setPropertyValue("lastJade5Log", 0);
			commitTransaction;
		endif;
	endif;
	self.doFormLoad(); //cnwrs1 Jan 2007 reload the form to reflect the changes
end;</source>
        <Parameter name="jadeMask" type="JadeMask" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doFormLoad" id="1c29e1e8-ead7-4f4b-ad44-f838b6f860d3">
        <updating/>
        <source>doFormLoad() updating, protected;
/*
Date		Who		Reason
03 Feb 2011	cnwrs1	PAR #25828 - using up too many licences
*/
vars
	mgr : JSSCTNibblerManager;
begin
	inheritMethod();

	create self.myChangeTrackingRootTA transient;
	self.myChangeTrackingRoot := JSSCTChangeTrackingRoot.firstInstance;
	self.myChangeTrackingRootTA.myChangeTrackingRoot := self.myChangeTrackingRoot;

	//
	// Hidden - now updated from Change Tracker Controller screen (SOP_BackgroundEditForm2)
	//
	lblLabel1.visible := false;
	txtDays.visible   := false;
//	txtDays.text := self.myChangeTrackingRoot.daysToKeepTrackingChanges.String;
	txtJournalNum.text := null;

	mgr := JSSCTNibblerManager.firstInstance;
	if mgr &lt;&gt; null then
		txtJournalOld.text := mgr.lastAuditFileNumber.String;
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doFormUnload" id="c2f7f665-ad08-4d04-8ee5-22e1b8955ad9">
        <updating/>
        <source>doFormUnload() updating, protected;

vars

begin
	inheritMethod();

	delete self.myChangeTrackingRootTA;

	self.myControllerForm := null;
end;</source>
        <access>protected</access>
    </JadeMethod>
</GUIClass>
