    <JadeMethod name="convertJsonKeysToUpperCase" id="40133288-ca22-4369-acf8-83d4ae25274b">
        <source>convertJsonKeysToUpperCase(inputJson : String input);
/*

Purpose:			

Parameters:			
	This method is used to convert the first char of all the keys in the json to caps, for instance when a json string like this is passed in,
	{
		"key1":"value1",
		"key2":"value2"
	}
	it would be converted to,
	{
		"Key1":"value1",
		"Key2":"value2"
	}

Return Value:		

	The value is converted in the passed in string "input" parameter inputJson

Date		Who		Reason
07 February 2023	navra1	Initial creation for TFS - 55859

*/

vars
	jsonStringLength : Integer;
	i : Integer;
	valuePortion : Boolean;
	quotesNumber    : Integer;
	
	insideValueQuotes :Boolean;
begin
	quotesNumber   := 0;
	insideValueQuotes := false;
	valuePortion  := false;
	jsonStringLength := inputJson.length;
	i := 0;
	
	//write CrLf&amp; CrLf&amp; 'got' &amp;CrLf&amp; inputJson;
	
	while i &lt; jsonStringLength do
		i := i+1;
		
		if inputJson[i] = '"' and not valuePortion then //count the quotes encountered in the key portion alone
			quotesNumber := quotesNumber + 1;
		endif;
		
		if inputJson[i] = ':' then	//we are entering the value portion
			valuePortion  :=true;
		endif;	
		
		if valuePortion and inputJson[i]='"' then	//know when you are inside any string inside the value to avoid special chars( } or , or { )
			insideValueQuotes := not insideValueQuotes;
		endif;		
				
		if valuePortion then //if we are in the value portion
			if not insideValueQuotes then				//ignore any ',' or '}' or '{' inside the value - dont let it make you think the value is over
				if inputJson[i] = '}' or inputJson[i] = ',' or inputJson[i] = '{' then	//either the value portion has has ended with a ',' or a '}' 
																						//or we are starting a new subsection and entering the key section 
																						//again(even if its an array we will definitely encounter a '{'
																						//before the keys, and so we can use that as our mark
					valuePortion := false;
				endif;
			endif;
		endif;
		
		if inputJson[i] = '"' and quotesNumber mod 2 &lt;&gt; 0 and not valuePortion then	//every char after the odd numbered quotes in the key portion should be capitalized
			if i &lt; jsonStringLength then 	//safety for index bounds
				inputJson[i+1] := inputJson[i+1].toUpper();
			endif;
		endif;
	endwhile;	
	
	//write CrLf&amp;CrLf&amp; 'converted' &amp;CrLf&amp; inputJson;
epilog

end;</source>
        <Parameter name="inputJson" type="String" usage="input"/>
    </JadeMethod>
    <JadeMethod name="convertJsonToXML" id="68cdb5ff-2f8b-4528-a699-ef309fb7e30b">
        <source>convertJsonToXML(_json : String) : String;
/*

Purpose:			Convert the passed in Json object to XML

Parameters:			Json object

Return Value:		XML string representing the Json object

Date		Who		Reason
21 Jun 2018	jlgkpd1	TFS #37190 - Pelindo 1 INAPORTNET Integration

*/

vars
	excOccurred		: Boolean;
	returnVal		: String;
	
begin
	on Exception do self.handleExceptions(exception, excOccurred);
	returnVal := self.myJsonHelper.convertJsonToXML(_json.StringUtf8).String;
	
	return returnVal;
	
epilog

end;</source>
        <Parameter name="_json" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="convertXMLToJson" id="d19fca55-fb41-4921-a5fb-af26cde30e65">
        <source>convertXMLToJson(_xml : String) : String;
/*

Purpose:			Convert the passed in XML string to the equivalent Json

Parameters:			XML document

Return Value:		Json equivalent of the passed in XML document

Date		Who		Reason
21 Jun 2018	jlgkpd1	TFS #37190 - Pelindo 1 INAPORTNET Integration

*/

vars
	excOccurred		: Boolean;
	returnVal		: String;
	
begin
	on Exception do self.handleExceptions(exception, excOccurred);
	returnVal := self.myJsonHelper.convertXMLToJson(_xml.StringUtf8).String;
	
	return returnVal;
	
epilog

end;</source>
        <Parameter name="_xml" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="create" id="32198273-f064-4929-9f47-f81d59f68279">
        <updating/>
        <source>create() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 Jun 2018	jlgkpd1	TFS #37190 - Pelindo 1 INAPORTNET Integration

*/

vars
	hadException	: Boolean;
	fileName		: String;
	iniValue		: String;
	usePresentation	: Boolean;
	
begin
	on Exception do self.handleExceptions(exception, hadException);
	
	create self.myJsonHelper transient;
	if self.myJsonHelper &lt;&gt; null then
		self.myJsonHelper.usePresentationClient := self.usePresentationClient;
	endif;
	
epilog

end;</source>
    </JadeMethod>
