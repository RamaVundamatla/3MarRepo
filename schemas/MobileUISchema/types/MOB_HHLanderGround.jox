    <JadeMethod name="setupControls" id="0de96d36-9d50-466e-884e-5491f7db9c35">
        <updating/>
        <source>setupControls() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
14 May 2010	cnwndl1	Initial creation	Par 23603

*/

vars

begin

	self.txtCargoId.text := myTrackedItem.id;
	self.populateTerminalAreas();
	
	self.doResizeControls(true);
		
epilog

end;</source>
