	tmpArray.add("Vehicle_colour");
	tmpArray.add("HS_codes");
	tmpArray.add("Vehicle_colour_proxy");
	tmpArray.add("Vehicle_make_proxy");
	tmpArray.add("Vehicle_model_proxy");
	tmpArray.add("Vehicle_type_proxy");
	tmpArray.add("TransType_170");
	transAgent.trxLoadSpecificErrors(tmpArray);
	
	delete tmpArray;
	
	//reset the transaction types
	app.myRoot.resetTrxTypes();

	// load new permissions
	create newPerms transient;
	newPerms.add(PmGteDutyDocManager);
	newPerms.add(PmGteDutyDocEnquiry);
	newPerms.add(PmGteDutyDocDataEntry);
	newPerms.add(PmGteDutyDocSupervisor);
	newPerms.add(PmGteDutyDocInCharge);
	newPerms.add(PmGteDutyDocCustomsSuper);
	newPerms.add(PmGteDutyDocItemEnquiry);
	termRole := CM_SecurityRoleTerminalRoot.firstInstance;
	sysRole := CM_SecurityRoleSystemRoot.firstInstance;
	beginTransaction;
	termRole.setPermissionsFromIntArray(newPerms, true);	//true if terminal permission
	sysRole.setPermissionsFromIntArray(newPerms, false);	//true if system permission
	commitTransaction;
	delete newPerms;

	// ### RESET MENUS to include the new menu items (2 of the permissions were new menu items)
	beginTransaction;
	app.myRoot.resetRootSecurityRoles(null);
	commitTransaction;
	create menuAgent transient;
	menuAgent.resetAllMenuDetails();
	delete menuAgent;
	
	return;
	
	//Config Constants - no special action required
	write DutyDocumentationEnabled;
	write DutyDocumentReport;
	write DutyDocCarReport;
	write ProFormaInclDDTicket;
	write ProFormaInclDDBill;
	
	//default report values - no special action required
	write DefRep_DutyDocumentReport;
	write DefRep_DutyDocumentCarReport;
	
	//duty doc status - no special action required
