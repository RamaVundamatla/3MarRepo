    <JadeMethod name="getGlobalConstant" id="7fba38b6-435b-472a-a2a6-132d0e53a60b">
        <source>getGlobalConstant(_constantName : String):GlobalConstant;

vars

begin
	return self.myConstantCategory.getConstants[_constantName].GlobalConstant;
end;
</source>
        <Parameter name="_constantName" type="String"/>
        <ReturnType type="GlobalConstant"/>
    </JadeMethod>
    <JadeMethod name="getNextGlobalConstantId" id="c5fec577-ee36-4cef-9476-f491f0ec9c56">
        <source>getNextGlobalConstantId():Integer;

vars
	nextId	: Integer;
	xltext	: XLAT_TranslatableText;
begin
	
	app.writeLog(class.name &amp; '::' &amp; method.name &amp; ' Creating global constant constantCategoryName: ' &amp; constantCategoryName, LogINFO);					// 20/09/2012 cnwmh5
	if constantCategoryName = XLAT_Exceptions then
		// special case - ids are above baseErrorNum to separate from Jade error messages
		//nextId := nextId + myRoot.baseErrorNum;

		// didn't work - the previous number allocation was all over the place, certainly not a contiguous series,
		// so get the last used number
		xltext := self.allTranslatableText.getAtKeyLeq(ExtDev_BaseErrorNo);
		app.writeLog(class.name &amp; '::' &amp; method.name &amp; ' Creating global constant translatableText: ' &amp; xltext.String, LogINFO);							// 20/09/2012 cnwmh5
		if xltext &lt;&gt; null then
			nextId := xltext.number + 1;
			app.writeLog(class.name &amp; '::' &amp; method.name &amp; ' Creating global constant translatableText.number: ' &amp; xltext.number.String &amp; Tab &amp; 		
				xltext.vConstantName &amp; Tab &amp; xltext.vConstantValue.String &amp; Tab &amp; 'nextId: ' &amp; nextId.String, LogINFO);									// 20/09/2012 cnwmh5
		else
			nextId := 60001;	// should never get here
		endif;
	else
		nextId := allTranslatableText.size + 1;
	endif;
	
	return nextId;
end;
</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="myConstantCategory" id="dd479af3-4881-4cf2-9db4-d2db0f0464b9">
        <methodInvocation>mapping</methodInvocation>
        <source>myConstantCategory(set: Boolean; _value: ConstantCategory io) mapping;

vars

begin
	if set then
		// read only
	else
		_value := getConstantCategory(constantCategoryName);
	endif;

end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="ConstantCategory" usage="io"/>
    </JadeMethod>
    <JadeMethod name="update" id="e2b73b8b-92b6-4671-a666-a2c1c759a0ec">
        <updating/>
        <source>update(	_root 							: CM_Root; 
		_constantCategoryName 			: String;
		_constantCategoryDescription	: String;
		_translatableTextClass 			: Class; 
		_usesShortText					: Boolean) updating;

vars

begin
	myTranslatableTextClass := _translatableTextClass;
	usesShortText := _usesShortText;
	constantCategoryDescription := _constantCategoryDescription;

	if constantCategoryName &lt;&gt; _constantCategoryName then
		constantCategoryName := _constantCategoryName;	// key
	endif;
	if myRoot &lt;&gt; _root then
		myRoot := _root;	// add to collection
	endif;
end;</source>
        <Parameter name="_root" type="CM_Root"/>
        <Parameter name="_constantCategoryName" type="String"/>
        <Parameter name="_constantCategoryDescription" type="String"/>
        <Parameter name="_translatableTextClass" type="Class"/>
        <Parameter name="_usesShortText" type="Boolean"/>
    </JadeMethod>
</Class>
