        <source>gotFocus(table: Table input) updating, clientExecution;
/*
----------   ----------  --------------------------------------------------
Created:	25 October 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars

begin
	inheritMethod(table);
	/*
