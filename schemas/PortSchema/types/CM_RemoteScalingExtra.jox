<Class name="CM_RemoteScalingExtra" id="0e46daed-d112-4c51-a1a5-a516056c20f5">
    <superclass name="CM_RemoteDataExtra"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="remoteDataProcessing"/>
    <PrimAttribute name="conditionCode" id="bc69bd0b-96e3-4317-a704-99eca8cb9e61">
        <length>31</length>
        <embedded/>
        <type name="String"/>
        <access>readonly</access>
    </PrimAttribute>
    <PrimAttribute name="id" id="3dd4d7fc-b6c3-4b1d-aa18-99b6aac68711">
        <length>36</length>
        <embedded/>
        <type name="String"/>
        <access>readonly</access>
    </PrimAttribute>
    <PrimAttribute name="maxSED" id="3b1f3fe3-ba7f-40e6-b3c5-1af30061f221">
        <embedded/>
        <type name="Integer"/>
        <access>readonly</access>
    </PrimAttribute>
    <PrimAttribute name="minSED" id="eda82a56-c459-46f2-b4ef-45f44bb529c9">
        <embedded/>
        <type name="Integer"/>
        <access>readonly</access>
    </PrimAttribute>
    <JadeMethod name="checkForDuplicateScalingDtl" id="66e0fcc3-fad0-448f-afc7-a99f1c351309">
        <source>checkForDuplicateScalingDtl(_logID : String; _logScaleHdrPxy	: CM_LogScalingHdr) protected;

// cnwdvb1 17 February 2003 

vars
	obj : CM_LogScalingDtl;
begin

	if not _logScaleHdrPxy.allLogScalingDtls.isEmpty then
		if not _logID.trimBlanks() = null then
			foreach obj in _logScaleHdrPxy.allLogScalingDtls do
				if obj.logID = _logID then
					app.raiseCMException1(VB_DUPLICATED_ITEM, 'Log ID ' &amp; _logID &amp; ' on docket ' &amp; _logScaleHdrPxy.bolNumber, 'id', null);
					break;
				endif;
			endforeach;
		endif;
	endif;

end;</source>
        <access>protected</access>
        <Parameter name="_logID" type="String"/>
        <Parameter name="_logScaleHdrPxy" type="CM_LogScalingHdr"/>
    </JadeMethod>
    <JadeMethod name="doJob" id="aeb00d18-cf3e-444b-83eb-215af2d8a516">
        <source>doJob(_logScaleHdrPxy	: CM_LogScalingHdr);

vars

	logDetailPxy	: CM_LogScalingDtl;

begin

	if self.id.trimBlanks() = null then
		return;
	endif;
	self.checkForDuplicateScalingDtl(self.id, _logScaleHdrPxy);
	create logDetailPxy transient;
	if self.conditionCode.length &gt; logDetailPxy.conditionCode.maxLength then
		app.raiseCMException2(ERR_STRING_TO_LONG, 'Condition Code for ' &amp;  self.id , logDetailPxy.conditionCode.maxLength.String, null, null);
	endif;
	// This is temporary as we need to get scaler code for each log.
	logDetailPxy.setProxy(self.id, self.conditionCode, self.minSED, self.maxSED, _logScaleHdrPxy, self.myRemoteDataDtl.CM_RemoteScaleTruckDtl.scalerCode);


end;</source>
        <Parameter name="_logScaleHdrPxy" type="CM_LogScalingHdr"/>
    </JadeMethod>
    <JadeMethod name="getDescription" id="a72355e0-1265-4b64-9a8c-3b8abf23ac9f">
        <source>getDescription(): String;

vars

begin
	return 'Scaled item extra detail';
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="saveFromTable" id="ca5d16c9-8a04-4c76-a994-b55e16b4938f">
        <updating/>
        <source>saveFromTable(_table: Table input; _entryTableColumns : Integer) updating;


begin

	self.id				:= _table.accessCell(2,_entryTableColumns).text.trimBlanks;
	self.conditionCode	:= _table.accessCell(3,_entryTableColumns).text.trimBlanks;
	self.minSED			:= _table.accessCell(4,_entryTableColumns).text.Integer;
	self.maxSED			:= _table.accessCell(5,_entryTableColumns).text.Integer;
	

end;</source>
        <Parameter name="_table" type="Table" usage="input"/>
        <Parameter name="_entryTableColumns" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="ff5d1670-fc00-42d6-859b-287d8e37d5dd">
        <updating/>
        <source>setForCreate(_proxy : CM_RemoteScalingExtra; _remoteScaleTruckDtl : CM_RemoteScaleTruckDtl) updating;

vars

begin

	self.conditionCode			:= _proxy.conditionCode;
	self.id						:= _proxy.id;
	self.maxSED					:= _proxy.maxSED;
	self.minSED					:= _proxy.minSED;
	inheritMethod(_proxy, _remoteScaleTruckDtl);

end;</source>
        <Parameter name="_proxy" type="CM_RemoteScalingExtra"/>
        <Parameter name="_remoteScaleTruckDtl" type="CM_RemoteScaleTruckDtl"/>
    </JadeMethod>
    <JadeMethod name="setProxyForScalingExtra" id="449f68c2-1326-49de-b326-e36bbdfad78b">
        <updating/>
        <source>setProxyForScalingExtra(_remoteDtl : CM_RemoteDataDtl; _id, _conditionCode : String; _minSED, _maxSED : Integer) updating;

vars

begin

	self.raiseExceptionIfNotTransient(method);
	self.id						:= _id;
	self.conditionCode			:= _conditionCode;
	self.maxSED					:= _maxSED;
	self.minSED					:= _minSED;
	self.setProxy(_remoteDtl);

end;</source>
        <Parameter name="_remoteDtl" type="CM_RemoteDataDtl"/>
        <Parameter name="_id" type="String"/>
        <Parameter name="_conditionCode" type="String"/>
        <Parameter name="_minSED" type="Integer"/>
        <Parameter name="_maxSED" type="Integer"/>
    </JadeMethod>
</Class>
