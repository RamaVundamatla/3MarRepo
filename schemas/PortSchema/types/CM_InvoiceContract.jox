    <JadeMethod name="cloneForCopy" id="bbbce5e1-e51e-4edf-86a2-83e00a6af9e5">
        <source>cloneForCopy(_transient : Boolean; _validOnly : Boolean; _todayDate : Date; _copy : Boolean) : SelfType;
/*

Purpose:			
			This method clones and returns the Invoice Contract
Parameters:			
			_validOnly : If this is true, then this method will only clone object that has "toTS" greater than _todayDate. Otherwise, clone everything.
			
Return Value:		

Date		Who		Reason
20 February 2023	navkc1	Initial creation CR #55652 Task 55681: Jade - Contracts Copy TRX

*/

vars
	clonedContract				: CM_InvoiceContract;
	contractDetails,
	clonedContractDetails		: CM_InvoiceContractDetails;
	allContractDetailsByTo		: CM_InvoiceContractDetailByTo;
	iter						: Iterator;
	toDate						: Date;
begin
	
	if _copy then // ### BUG 56908 21MAR2023 NAVAB1
		clonedContract := self.cloneSelf(_transient);
		
		clonedContract.contractId 		:= null;
		clonedContract.myBusinessUnit 	:= self.myBusinessUnit;
		clonedContract.myDebtor 		:= self.myDebtor;
		clonedContract.myTerminal 		:= self.myTerminal;
		// 1 debtor can only have 1 primary contract, set the cloned one to not primary
		clonedContract.primary 			:= false;
	else // ### BUG 56908 21MAR2023 NAVAB1 -  UPDATE
		clonedContract := app.createUpdateProxy(self).CM_InvoiceContract;	 // ### BUG 56908 21MAR2023 NAVAB1
	endif;
	

	if self.allInvoiceContractDetails.isEmpty() then
		return clonedContract;
	endif;
	
	create allContractDetailsByTo transient;
	
	self.allInvoiceContractDetails.copy(allContractDetailsByTo);
	
	contractDetails := allContractDetailsByTo.last();
	
	toDate := self.toTS.date();
	
	iter := allContractDetailsByTo.createIterator();
	iter.startAtObject(contractDetails);
	
	while iter.back(contractDetails) do
		if _validOnly and contractDetails.toTS.date() &lt; _todayDate then
			break;
		endif;
		
		clonedContractDetails := contractDetails.cloneForCopy(_transient, _validOnly, _todayDate, _copy); // ### BUG 56908 21MAR2023 NAVAB1
		clonedContractDetails.setMyInvoiceContract(clonedContract);
	endwhile;
	
	return clonedContract;
	
epilog
	delete allContractDetailsByTo;
	delete iter;
end;</source>
        <Parameter name="_transient" type="Boolean"/>
        <Parameter name="_validOnly" type="Boolean"/>
        <Parameter name="_todayDate" type="Date"/>
        <Parameter name="_copy" type="Boolean"/>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="delete" id="27910020-62f6-46cc-abc3-65bf8cc3ca03">
        <updating/>
        <source>delete() updating;
/*
Purpose:		used for auditing 	

Date		Who		Reason
09 December 2022	navab1	TFS CR 55623 TASK 55785
*/

vars
	iter : Iterator;
	cmqf : CMQF_InvoiceContract;

begin
	iter := CMQF_InvoiceContract.instances.createIterator;
	while iter.next(cmqf) do
		if cmqf.allContracts.includes(self) then
			cmqf.allContracts.remove(self);
		endif;
	endwhile;
	
	self.resetAuditsDuringDelete();

epilog
	delete iter;
end;</source>
    </JadeMethod>
    <JadeMethod name="deleteClonedProxy" id="aba34620-2dc9-482c-8c66-07d7390fadd9">
        <source>deleteClonedProxy();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 March 2023	navkc1	Initial creation  CR #55652 Task 55681: Jade - Contracts Copy TRX

*/

vars
	contractDetails		: CM_InvoiceContractDetails;
	rate				: CM_InvoiceContractRate;
	
begin
	
	if not self.isTransient() then
		return;
	endif;
	
	foreach contractDetails in self.allInvoiceContractDetails do
		contractDetails.deleteClonedProxy();
	endforeach;
	
	self.allInvoiceContractDetails.purge();
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="getAccumQuantity" id="d080f41f-2c5b-4ced-823d-de858470671d">
        <source>getAccumQuantity() : IntegerArray;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 November 2023 navmv20 Bug 61113: FR | 54089 - EUP - Invoice contracts - Selector query - Missing fields

*/

vars
	quantityArray : IntegerArray;
	contractDetail : CM_InvoiceContractDetails;
	quantity : Integer;
	accumulation : CM_InvoiceContractAccumulate;
begin
	create quantityArray transient;
	foreach contractDetail in self.allInvoiceContractDetails do
		if contractDetail.isKindOf(CM_InvoiceContractDtlsVolBased) then
			foreach accumulation in contractDetail.CM_InvoiceContractDtlsVolBased.allAccumulationsByType do
				quantity := accumulation.accumulatedQuantity;
				if not quantityArray.includes(quantity) then
					quantityArray.add(quantity);
				endif;
			endforeach;
		endif;
	endforeach;
	return quantityArray;
epilog

end;</source>
        <ReturnType type="IntegerArray"/>
    </JadeMethod>
