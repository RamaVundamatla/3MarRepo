*/

vars

begin
	
	return self.EDI_Bundle_CUSTOM;

epilog

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="processFile" id="a806aff0-3845-488d-a082-c57458337428">
        <updating/>
        <source>processFile(_ediFile: CM_EDIFile input) updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 July 2014	cnwmc5	Initial creation
//12 Jan 2015	cnwrs1	Par 35504 - Refactor EDI file load for .NET
// 18 Jan 2019	jlgrs1	TFS 41659 42276 STWR Make EDI MultiThreaded Stage 8
// 07 Apr 2019	jlgrs1	TFS 41913 STWR - Reconfiguration of the EDI Operation form to better handle EDI collection locks while loading 
// 31/10/2019	JLGNS1	ChangeRequest 46721: PEN - CAMIR Message Processing
// 23/03/2022	navdap1	TFS 52502 PEN CAMIR 7I Message (Release)
// 31/03/2022	navdap1	TFS 53306 PEN CAMIR 7I Message (Release)
04 Mar 2024	jlirs1	TFS 57192 - 57193 Pen Support Import Voyage Translation
08 Apr 2024	jlirs1	PEN 62335 63046 FR 57192 new operator should be voyage Operator
*/
vars
	customsMessageData	: CM_EDIDataUSCustomsMessage;
	customsMessageTI	: CM_EDIUSCustomsMessageTI;
//	binaryLine			: Binary;
	line				: String;
	tag					: String;
	r02Count			: Integer;
	found				: Boolean;
	dayStr				: String;
	monthStr			: String;
	yearStr				: String;
	hoursStr			: String;
	minsStr				: String;
	secsStr				: String;
	cpbPort				: String;
	quantity			: Integer;
	operCode			: String;
	voyageOperator		: String;
	voyageCode			: String;
	aPort				: CM_Port;
	operator			: CM_Operator;
	dischargePortStr : String;	//20 Nov 2014	NDL	Par 35259
	theLines : HugeStringArray;
	contIds : StringArray;
	m01Operator : CM_Operator;			// TFS 52052
	senderPartyRules : CM_EDIPartyCAMIRRules;
	isImport : Boolean;
begin
	r02Count := 0;
	customsMessageData := _ediFile.ediData.CM_EDIDataUSCustomsMessage;
	
	create theLines transient;
	create contIds transient;			//ChangeRequest 46721
	self.rawDataToHSA(_ediFile, theLines);
	foreach line in theLines do
		tag := line[1:3].toUpper();
		
		if tag = "ACR" then
			//This record (ACR) signals the beginning of a transaction file.
			create customsMessageTI;
			customsMessageTI.setForCreateNew(customsMessageData);
			customsMessageTI.setMyEDIFile(_ediFile);
			
			operCode := line[4:4].trimBlanks();
			customsMessageData.operatorCode := app.myRoot.getXlationSystemCode(operCode, XLATION_TYPE_OPERATOR, found);
			operator := app.myRoot.allOperators[customsMessageData.operatorCode];
			
			if operator &lt;&gt; null then
				customsMessageData.setOperator(operator);
			endif;
			
			dayStr := line[20:2];
			monthStr := line[18:2];
			yearStr := line[16:2];
			if not dayStr.isBlank() and not monthStr.isBlank() and not yearStr.isBlank() then
				customsMessageTI.postedDate.setDate(dayStr.Integer, monthStr.Integer, yearStr.Integer);
			endif;
			
			hoursStr := line[22:2];
			minsStr := line[24:2];
			secsStr := line[26:2];
			if not hoursStr.isBlank() and not minsStr.isBlank() and not secsStr.isBlank() then
				customsMessageTI.postedTime.setTime(hoursStr.Integer, minsStr.Integer, secsStr.Integer, null);
			endif;
		elseif tag = "M01" then
			customsMessageTI.vesselName := line[12:23].trimBlanks();
			customsMessageTI.vesselCode := line[52:7].trimBlanks();
			voyageCode := line[35:5].trimBlanks();
			voyageOperator := line[4:4].trimBlanks();
			
			if operator = null then
				// TFS 52052 starts - translate the M01 operator code if we didn't get an operator from the ACR line
				//customsMessageTI.voyageCode := voyageCode;
				//customsMessageTI.voyageOperator := voyageOperator;
				customsMessageTI.voyageOperator := app.myRoot.getXlationSystemCode(voyageOperator, XLATION_TYPE_OPERATOR, found);
				m01Operator := app.myRoot.allOperators[customsMessageTI.voyageOperator];
				if m01Operator &lt;&gt; null then
					senderPartyRules := self.getEDICAMIRPartyRules(m01Operator.code);
					if senderPartyRules &lt;&gt; null then
						isImport := senderPartyRules.isImport;
					endif;
					customsMessageTI.voyageCode := m01Operator.getXlationSystemCode_VoyageEx(voyageCode, customsMessageTI.vesselName, customsMessageTI.vesselCode, null, 0, found, isImport);		//04 Mar 2024	jlirs1	TFS 57192 - 57193 Pen Support Import Voyage Translation
					customsMessageData.operatorCode := m01Operator.code;		// TFS 53306
					customsMessageData.setOperator(m01Operator);				// TFS 53306
					operator := m01Operator;		//08 Apr 2024	jlirs1	PEN 62335 v63046 FR 57192 new operator should be voyage Operator
				else
					customsMessageTI.voyageCode := voyageCode;
				endif;
				// TFS 52052 end
			else
				senderPartyRules := self.getEDICAMIRPartyRules(operator.code);
				if senderPartyRules &lt;&gt; null then
					isImport := senderPartyRules.isImport;
				endif;
				customsMessageTI.voyageCode := operator.getXlationSystemCode_VoyageEx(voyageCode, customsMessageTI.vesselName, customsMessageTI.vesselCode, null, 0, found, isImport);		//04 Mar 2024	jlirs1	TFS 57192 - 57193 Pen Support Import Voyage Translation
			//	customsMessageTI.voyageOperator := operator.getXlationSystemCode(voyageOperator, XLATION_TYPE_CARRIER_BYOP, found);
				customsMessageTI.voyageOperator := operator.getXlationSystemCode(voyageOperator, XLATION_TYPE_OPERATOR_BYOP, found);	//20 Nov 2014	NDL	Par 35259
			endif;
		elseif tag = "R01" then
			//Ensure the CBP Port is our Port.
			cpbPort := line[8:4];
			aPort := app.myRoot.lookupScheduleDKPortCode(cpbPort, null);
			
			if aPort &lt;&gt; null then
				customsMessageTI.portOfEntry := aPort.code;
			else
				
				customsMessageTI.portOfEntry := cpbPort;
				
				//20 Nov 2014	NDL	Par 35259
				if operator &lt;&gt; null then
					dischargePortStr := operator.getXlationSystemCode(cpbPort, XLATION_TYPE_PORT_BYOP, found);
					if found then
						customsMessageTI.portOfEntry := dischargePortStr;
					endif;
				endif;
				
			endif;
		elseif tag = "J01" then
		elseif tag = "R02" then
			//Ignore the second R02 group... we only want data from the first.
			r02Count := r02Count + 1;
			if r02Count = 2 then
				continue;
			endif;
			
			customsMessageTI.billOfLading := line[4:12].trimBlanks();
			customsMessageTI.dispositionCode := line[16:2].trimBlanks();
			
			quantity := line[18:10].trimBlanks().Integer;
			if line[67] = CM_EDIFileTypeCAMIR.NEGATIVE_INDICATOR then
				quantity := -quantity;
			endif;
			customsMessageTI.quantity := quantity;
			
			customsMessageTI.entryNumber := line[30:15];	//ChangeRequest 46721
			
		elseif tag = "B04" then
		elseif tag = "R03" then
			if customsMessageTI.remarks = "" or customsMessageTI.remarks = null then
				customsMessageTI.remarks := line[4:30].trimBlanks();
			else
				customsMessageTI.remarks := customsMessageTI.remarks &amp; " " &amp; line[4:30].trimBlanks();
			endif;
		elseif tag = "R05" then
			contIds.add(line[4:14].trimBlanks());	//ChangeRequest 46721
		elseif tag = "R06" then
		elseif tag = "C01" then
		elseif tag = "C02" then
		elseif tag = "ZCR" then
		endif;
	endforeach;
	
	self.createCustomsMessageTIs(contIds,customsMessageData,customsMessageTI,_ediFile);//ChangeRequest 46721
	
epilog
	delete contIds;//ChangeRequest 46721
	delete theLines;
end;</source>
        <access>protected</access>
        <Parameter name="_ediFile" type="CM_EDIFile" usage="input"/>
    </JadeMethod>
    <JadeMethod name="rawDataToHSA" id="befbce01-ce42-4705-86bd-d8bcc033bba8">
        <source>rawDataToHSA(_ediFile: CM_EDIFile; _theLines: HugeStringArray input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12/04/2018	jlgrh7	Initial creation TFS36458 PEN - CAMIR Messages Missing Data
31/03/2022	navdap1	TFS 53306 PEN CAMIR 7I Message (Release)
*/

vars
	ediFile : CM_EDIFile;
	fileLine : String;
	eqdCount : Integer;
	camirDelimiter : Character;
	pos : Integer;
	str : String;
begin
	//inheritMethod(_ediFile, _theLines);
	_theLines.clear;
	pos := 1;
	fileLine := _ediFile.getRawDataString();
	if fileLine = null then
		self.compressedDataToHSD(_ediFile, _theLines);
	else
		fileLine := fileLine.replaceString(CrLf, null);
		fileLine := fileLine.replaceString(Cr, null);
		fileLine := fileLine.replaceString(Lf, null);
		fileLine := fileLine.replaceString(Tab,null);
	endif;
	//write fileLine;			// TFS 53306
	while pos &lt; fileLine.length-1 do																//Take every 80 Character to 1 field
			str :=  fileLine[pos:80];
			_theLines.add(str);
			pos := pos+80;
	endwhile;
		//fileLine.getHugeTokensForDelimiter(camirDelimiter, _theLines);
	ediFile := _ediFile;
	if process.isInTransactionState then
			ediFile.setNumContainers(_theLines.size);
	endif;
	
epilog

end;</source>
        <Parameter name="_ediFile" type="CM_EDIFile"/>
        <Parameter name="_theLines" type="HugeStringArray" usage="input"/>
    </JadeMethod>
</Class>
