    <JadeMethod name="create" id="f7935a80-26c2-450e-9f26-ee87c9426a41">
        <updating/>
        <source>create() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
02 January 2023	navhl20	ChangeRequest 54350:[54269] EUP - VAS Work Orders Selector Query

*/

vars
	oper : CM_QueryOperator;
begin
	if self.isTransient then 
		return;
	endif;

	create oper as CM_QReferenceIsOneOf persistent;
	self.allAllowedOperators.add(oper);
epilog

end;</source>
    </JadeMethod>
