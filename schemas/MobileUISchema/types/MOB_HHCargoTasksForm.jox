        <updating/>
        <source>setupControls() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 May 2013	cnwndl1	Initial creation	Par 31506

*/

vars

begin

	self.doResizeControls(true);
	
	self.txtFilter.lostFocus( self.txtFilter );
								
	if self.wasCalledViaContext(true) then
		self.btnThree.caption := app.getErrorString(Enquiry);
