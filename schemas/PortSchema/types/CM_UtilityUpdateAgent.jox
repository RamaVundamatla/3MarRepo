	self.setupInvoiceStatus(linxProcess, CM_Invoice.INVOICE_POSTED_REVERSE,		8, 	app.getErrorString(Posted_returned), PINEmail_InvProcLinxOffset);	 // ### TFS 52184 20OCT2021 NAVAB1	
	self.setupInvoiceStatus(linxProcess, CM_Invoice.INVOICE_VOID,				9, 	app.getErrorString(Void), PINEmail_InvProcLinxOffset);	 // ### TFS 52184 20OCT2021 NAVAB1	
	self.setupInvoiceStatus(linxProcess, CM_Invoice.INVOICE_APPROVEDRETURNED,	10, 	app.getErrorString(Approved_returned), PINEmail_InvProcLinxOffset);	 // ### TFS 52184 20OCT2021 NAVAB1*/

