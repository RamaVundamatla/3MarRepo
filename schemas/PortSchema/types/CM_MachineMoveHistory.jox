    <JadeMethod name="getEndOfMoveTS" id="5bc711a6-1372-478e-8948-f451e79610e8">
        <source>getEndOfMoveTS():TimeStamp;
// ---------------------------------------------------------------------------
// Created:     02 November 2010 by cnwcs5 par 23714/ccms 1132
// Purpose:     
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	type		:Integer;
	ts			:TimeStamp;
	nextHistory	:CM_MachineMoveHistory;
begin
	type 		:= self.type;
	ts			:= null;
	nextHistory	:= self.myNextHistory.CM_MachineMoveHistory;
	
	if type = self.Type_AcceptMove or
		type = self.Type_PickUp then
		if nextHistory &lt;&gt; null then
			ts := nextHistory.getEndOfMoveTS;
		endif;
	elseif type = self.Type_SetDown then
		ts := self.dateTime;
	elseif type = self.Type_Move then
		ts := self.dateTime;
	endif;
	
	return ts;
epilog

end;</source>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
