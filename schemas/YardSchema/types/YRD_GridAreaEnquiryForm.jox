    <JadeMethod name="keyDown" id="250dd8c8-a832-439a-be69-bfec02750cb5">
        <controlMethod name="Form::keyDown"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>keyDown(keyCode: Integer io; shift: Integer) updating;
// ---------------------------------------------------------------------------
// Created:		November 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	ydc : YRD_ContainerDrawingController;
	anObj : Object;
begin
	if keyCode = CMUI_Key_F3 then
		if app.isControlKeyDown()
		and not app.isAltKeyDown()
		and not app.isShiftKeyDown()
		then
			self.showSelectorForm(true);
		else
			return;
			
			if self.frmSelectAreas.visible then
				self.showAreaSelectorEnable(false);
			else
				self.showAreaSelector();
			endif;
			return;
		endif;

	elseif keyCode = CMUI_Key_Esc then
		delete app.myMoveController;
		app.myDraggedTrackedItem := null;
		app.isDragging := false;
		self.dragMode := self.DragMode_None;
		
		ydc := self.myCurrentDrawingController;
		ydc.doCancelDrag();
		return;
		
	elseif keyCode = J_key_Delete then
		self.doDeleteKeyDown();
		
	endif;

	inheritMethod(keyCode, shift);
end;</source>
        <Parameter name="keyCode" type="Integer" usage="io"/>
        <Parameter name="shift" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="layoutRedraw" id="600cdbe1-751d-44e9-a848-6e728f230f8e">
        <updating/>
        <source>layoutRedraw(_evenIfHidden : Boolean) updating, protected;
// ---------------------------------------------------------------------------
// Created:     27 May 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	msg			: String;
	theX1,theX2,theY1,theY2 : Integer;
	theWidth, theHeight, theTop, theLeft : Integer;
	theMainFrame, theViewFrame : Frame;
	numCol, numRow : Integer;
	thePCWidth, thePCHeight, thePCHScroll, thePCVScroll : Real;
	aReal : Real;
	tmpDkbPos	: CMUI_JadeDockBar;
	saveVisible	: Boolean;
begin

	tmpDkbPos := self.dkbPosition;

	if (not tmpDkbPos.visible) and
	   (not _evenIfHidden) then
		return;
	endif;

	theMainFrame := self.frmPosition;
	theViewFrame := self.frmPositionView;
	
	if self.myCurrentDrawingController.scaleFactor =1 then
		self.positionScaleX := 16;
		self.positionScaleY := 4.99;
	elseif self.myCurrentDrawingController.scaleFactor = 1.5 then
		self.positionScaleX := 5;
		self.positionScaleY := 4.99;
	elseif self.myCurrentDrawingController.scaleFactor = 2 then
		self.positionScaleX := 7;
		self.positionScaleY := 4.99;
	elseif self.myCurrentDrawingController.scaleFactor = 3 then
		self.positionScaleX := 10;
		self.positionScaleY := 4.99;
	elseif self.myCurrentDrawingController.scaleFactor = 4 then
		self.positionScaleX := 3;
		self.positionScaleY := 4.99;
	else
		self.positionScaleX := 10;
		self.positionScaleY := 6;
	endif;
	
	theTop := (self.frmToolbar.top + self.frmToolbar.height + 1).Integer;
	theLeft := 100;

	tmpDkbPos.zOrder(1);
	
	// save and reset visible status so that
	// the floating frame is resized
	saveVisible := tmpDkbPos.visible;
	if saveVisible then
		tmpDkbPos.visible := false;
	endif;


	tmpDkbPos.visible := saveVisible;

	self.frmPosToolbar.width := tmpDkbPos.clientWidth;
	self.frmPosToolbar.repositionAfterResize();

	// Draw the new view
	theMainFrame.clearGraphics;
	self.myCurrentDrawingController.drawMinature(theMainFrame, tmpDkbPos);
	
	self.scrollPositionFrame();
	theMainFrame.refreshNow();

	theViewFrame.clearGraphics;
	theViewFrame.drawRectangle(0, 0, theViewFrame.clientWidth, theViewFrame.clientHeight, Red);
	
end;</source>
        <access>protected</access>
        <Parameter name="_evenIfHidden" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="loadDataForFirstTime" id="c8974ec3-cdec-4c54-9c40-5342b84f44d1">
        <updating/>
        <source>loadDataForFirstTime() updating, protected;
// ---------------------------------------------------------------------------
// Created:		December 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	theMainFrame, 
	theViewFrame : Frame;
	regKeys : IntegerArray;
	key1, key2 : Point;
	x1,x2,y1,y2 : Integer;
begin
	self.dkbGridArea.isForRows := true;



	inheritMethod();
	self.positionScaleX := 10;
	if self.xmlToolbar then
		self.mnuGridHideToolbar.caption := self.MNU_TOOLBAR_HIDE;
	else
		self.mnuGridHideToolbar.caption := self.MNU_TOOLBAR_SHOW;
	endif;
	self.mnuGridHideToolbar_click(self.mnuGridHideToolbar); 

	self.defYardBackColUnselected := self.myTerminal.getConfig(DefYardBackColUnselected).Integer;
	self.defYardBackColSelected := self.myTerminal.getConfig(DefYardBackColSelected).Integer;
	self.isSelectorCapable := true;
	

	theMainFrame := self.frmPosition;
	theMainFrame.backColor := 16772829; //light Blue
	theMainFrame.autoRedraw := true;

	theViewFrame := self.frmPositionView;
	theViewFrame.autoRedraw := true;
	theViewFrame.boundaryWidth := 0;
	theViewFrame.drawWidth := 10;

	if global.isValidObject(self.userObject) then
		self.userObject.Collection.copy(self.allTIs);
	endif;

	self.populateGridRows();
	
	if self.initView &lt;&gt; null then // PAR 19913
		self.doQuery(self.initView);// PAR 19913
	else
		self.doQuery(VIEW_DISPORT);
	endif;

	create regKeys transient;
	regKeys.add(CMUI_Key_Esc);
	self.addRegisteredKeys(regKeys);
	regKeys.add(J_key_Delete);
	self.addRegisteredKeys(regKeys);

	self.doSetCaption();	// PAR 21532 CCMS SFW 1025
epilog
	if global.isValidObject(self.userObject) then
		delete self.userObject; // this is a transient object set created in the calling form.
	endif;
	delete regKeys;

end;</source>
        <access>protected</access>
    </JadeMethod>
