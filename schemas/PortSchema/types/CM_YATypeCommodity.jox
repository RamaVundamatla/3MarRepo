    <JadeMethod name="getObjects" id="09d8dd10-ab18-40e3-8265-03e02b379e17">
        <source>getObjects(objects: ObjectLongNameDict input);
//05 August 2008	cnwdw1	
// Return a dict of objects for this criteria type
vars
	commodity: CM_Commodity;
begin
	foreach commodity in app.myRoot.allCommodities do
		objects[commodity.getYAIdentifier] := commodity;
	endforeach;
end;</source>
        <Parameter name="objects" type="ObjectLongNameDict" usage="input"/>
    </JadeMethod>
