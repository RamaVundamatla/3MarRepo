    <JadeMethod name="doBrowseForFolder" id="ce9965f4-964a-4f17-a12a-7f1d9dfc4c63">
        <source>doBrowseForFolder() : String protected;

/*

Purpose:		Gets and returns the folder that you require

Parameters:			

Return Value:		


Date		Who		Reason
30 May 2011	cnwmh5	Initial creation

*/

vars
	
	fileFolder			: FileFolder;
	
	folderName			: String;
	initialDirectory	: String;
	systemNum			: String;
	pos					: Integer;
	pos1				: Integer;
	
begin

	// get system number
	systemNum := app.myRoot.getConfig(SystemTitle).String;
	pos := systemNum.pos(".", 1);
	if pos &gt; 0 then
		if pos &gt; 1 then
			pos := pos - 1;
		endif;
		pos1 := systemNum.pos(" ", pos);
		if pos1 &gt; 0 then
			systemNum := systemNum[pos:pos1-pos];
		endif;
	endif;
	systemNum := systemNum.replaceString(".", "");
	initialDirectory := "F:\Releases\" &amp; systemNum &amp; "\Hotfixes-Pending";
	///initialDirectory := "C:\temp\782Hotfix_030\JadeMaster\Schemas";

	create fileFolder transient;
	folderName := fileFolder.browseForFolder("Select directory that *.unl files reside in:", initialDirectory);

	return folderName;

epilog

	delete fileFolder;
	
end;</source>
        <access>protected</access>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="doClearResults" id="fcd25bd8-8e82-499c-96b3-c1b153a53d65">
        <source>doClearResults() protected;
//24 April 2009	cnwdw1	
//
vars
	numRows,
	idx		: Integer;
	row		: JadeTableRow;
begin
	// Delete any itemObjects that might have been created
	if process.isMPD then
		numRows := self.tblResults.rows;
		foreach idx in self.tblResults.fixedRows+1 to numRows do
			row := self.tblResults.accessRow(idx);
			if row.itemObject &lt;&gt; null and row.itemObject.isKindOf(CnEcString) then
				delete row.itemObject;
			endif;
		endforeach;
	endif;
	
	self.setupResultsTable;
	self.txtResultDetails.text	:= null;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doContextMenuEntity" id="4d31f8f8-dd9a-4db5-9cbb-f826ce1795da">
        <updating/>
        <source>doContextMenuEntity(listbox: ListBox input; 
					conwin: Window input; 
					mouse: Boolean; 
					x, y : Integer):Boolean updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 March 2025	NAVRV30	JIRA 33943 MTN | Unit Test Runner Select Failed Tests

*/

vars
	x1, 
	y1					: Real;
	menuEntity			: Object;
	idx					: Integer;
begin

	idx := listbox.getListIndex(x,y);
	if idx &lt;= 0 then
		return false; 
	endif;
	
	menuEntity := listbox.itemObject[idx];
	if menuEntity = null or not menuEntity.isKindOf(Class) then
		return false;
	endif;
	
	x1 := x;
	y1 := y;
	if not mouse then  // if keyboard, use current listIndex value
	    x1 := 20;
	    if listbox.listIndex &lt; 0 then
	        y1 := 5;
	    else
	        y1 := listbox.positionTop(listbox.listIndex);
	    endif;
	endif;
	
	conwin.windowToScreen(x1, y1);
	self.screenToWindow(x1, y1);   
	listbox.itemSelected[idx] := false;
	self.popupMenu(self.menuOrganise, x1.Integer, y1.Integer);

end;</source>
        <access>protected</access>
        <Parameter name="listbox" type="ListBox" usage="input"/>
        <Parameter name="conwin" type="Window" usage="input"/>
        <Parameter name="mouse" type="Boolean"/>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doDeleteCategory" id="046c6588-7b96-4071-8833-af42563c161f">
        <updating/>
        <source>doDeleteCategory(_category : UM_Category io; _categoryName : String; _allCategoryClassMethods : ObjectArray) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date			Who		Reason
23 September 2011	cnwmh5	Initial creation
16/03/2015			cnwmh5	Transient Leaks
*/

constants
	XMLHeader				: String = "&lt;?xml version=";
	XMLAdditional			: String = "UT_Additional";
	XMLCategories			: String = "Categories";
	XMLCategory				: String = "Category";
	XMLAttributeCanDelete	: String = "CanDelete";
	XMLEndString			: String = XMLAdditional &amp; "&gt;";
vars
	
	xmlDocument				: JadeXMLDocument;
	xmlElement,
	xmlElementAdditional,
	xmlElementCategories,
	xmlElementCategory		: JadeXMLElement;
	xmlAttributeCategories	: JadeXMLAttribute;
	category				: UM_Category;
	obj						: Object;
	
	categoryElements		: JadeXMLElementArray;
	categoryCMArray			: ObjectArray;
	
	classMethodText			: String;
	xmlText					: String;
	xmlHeaderPos			: Integer;
	xmlEndPos				: Integer;
	otherText				: String;

begin

	on Exception do app.handleXMLExceptions(exception);

	create categoryCMArray transient;
	_allCategoryClassMethods.copy(categoryCMArray);	
	
	beginTransaction;
	
	//foreach obj in _allCategoryClassMethods do
	foreach obj in categoryCMArray do
	
		// check to see whether we have xml text
		classMethodText := obj.getPropertyValue("text").String;
		xmlHeaderPos := classMethodText.pos(XMLHeader, 1);
		xmlEndPos := classMethodText.reversePos(XMLEndString);
		if xmlHeaderPos &lt;&gt; 0 then
			xmlText := classMethodText[xmlHeaderPos:xmlEndPos + XMLEndString.length - xmlHeaderPos];
		endif;
		
		if xmlHeaderPos = 0 then
			otherText := classMethodText;
		elseif xmlHeaderPos &gt; 1 then
			otherText := classMethodText[1:xmlHeaderPos-1];
			if xmlEndPos + XMLEndString.length &lt; classMethodText.length then
				if otherText.trimBlanks() &lt;&gt; null then
					otherText := otherText.trimBlanks() &amp; CrLf &amp; CrLf;
				endif;
				otherText := otherText.trimBlanks() &amp; classMethodText[xmlEndPos + XMLEndString.length + 1:end];
			endif;
		endif;
				
		// should never happen, so just being over cautious
		if xmlText = null then
			if otherText &lt;&gt; null then
				obj.setPropertyValue('text', otherText);
			endif;
			continue;
		endif;
		
		create xmlDocument transient;
		xmlDocument.parseString(xmlText);
		
		// check if there is a XMLAdditional element
		xmlElementAdditional := xmlDocument.getElementByTagName(XMLAdditional);
		if xmlElementAdditional = null then
			if otherText &lt;&gt; null then
				obj.setPropertyValue('text', otherText);
			endif;
			continue;
		endif;
	
		// check to see if there is a XMLCategories element
		xmlElementCategories := xmlElementAdditional.getElementByTagName(XMLCategories);
		if xmlElementCategories = null then
			continue;
		endif;
		
		// delete the categories element
		create categoryElements transient;
		xmlElementCategories.getAllElementsByTagName(XMLCategory, categoryElements);
		foreach xmlElement in categoryElements do
			if _categoryName &lt;&gt; null and xmlElement.text = _category.name then
				delete xmlElement;
				if _category.allCategoryClassMethods.includes(obj) then
					_category.allCategoryClassMethods.remove(obj);
				endif;
				//break;
			endif;
		endforeach;
		
		// check to see if Categories has any elements left
		if xmlElementCategories.childNodes.size = 0 then
			delete xmlElementCategories;
		endif;		
		
		// check to see if Additional element has any other elements
		if xmlElementAdditional.childNodes.size &gt; 0 then
			if otherText.trimBlanks() &lt;&gt; null and otherText.reversePos(CrLf) = 0 then
				otherText := otherText &amp; CrLf;
			endif;
			obj.setPropertyValue('text', otherText.trimBlanks() &amp; xmlDocument.writeToString());
		else
			obj.setPropertyValue("text", otherText.trimBlanks());
		endif;
		
	endforeach;
	
	commitTransaction;
	
	// all done so delete the category if it can be delete
	if _category.allCategoryClassMethods.isEmpty() and _category.canBeDeleted then
		app.allCategories.remove(_category);
		delete _category;
	endif;
	
	// rebuild the categories details
	self.populateCategories();
	self.cmbCategories.listIndex := self.cmbCategories.findStringExact(1, self.txtCategory.text);
	self.btnSelect.enabled := self.cmbCategories.listIndex &gt; 0;
	self.txtCategory.text := null;
	self.doSelectCatgory();
		
epilog

	if xmlDocument &lt;&gt; null then
		delete xmlDocument;
	endif;

	delete categoryElements;
	delete categoryCMArray;

end;</source>
        <Parameter name="_category" type="UM_Category" usage="io"/>
        <Parameter name="_categoryName" type="String"/>
        <Parameter name="_allCategoryClassMethods" type="ObjectArray"/>
    </JadeMethod>
    <JadeMethod name="doGetOwner" id="70fc8441-50d6-464e-aa60-ce46a78ae3e6">
        <source>doGetOwner(_meth : Method) : String;
/*
Purpose:			

Date		Who		Reason
26 October 2021	navab1	TFS 99999
*/

vars
	result: UT_TestResult;
	owner: String;
begin


	create result transient;
	result.construct(_meth, false, false, null, null, null,null,null,null);

	return result.getOwnerName.toUpper;
epilog
	delete result;
end;</source>
        <Parameter name="_meth" type="Method"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="doInspectOnString" id="d136f86a-24e6-4481-b9a0-3c981daea50e">
        <source>doInspectOnString();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
18 November 2010	cnwndl1	Initial creation

*/

vars

	str : String;
	pos : Integer;
	obj : Object;
	invalidObject : Boolean;
	
begin

	on Exception do app.handleDeletedObject(exception, obj, invalidObject);

	str := self.txtResultDetails.selText.trimBlanks;
	
	if str = null then
		return;
	endif; 
	
	pos := str.pos("/",1);
	if pos &gt; 0 and pos &lt;= str.length then
		str := str[ pos + 1 : end ];
	endif;
	
	pos := str.pos("&gt;",1);
	
	if pos &gt; 0 and pos &lt;= str.length then
		str := str[ 1 : pos - 1 ].trimBlanks;
	endif;
	
	obj := str.asOid.Object;
	
	if obj &lt;&gt; null then
		obj.inspectModal();
		if invalidObject then
			write "'" &amp; str &amp; "' unable to be resolved to a valid object ( May have been deleted ).";
		endif;
		return;
	endif;
	
	write "'" &amp; self.txtResultDetails.selText.trimBlanks &amp; "' can not be resolved to a valid object.";

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doLoadUNL" id="e751abe4-2440-4b2e-b019-af84ce517d6b">
        <updating/>
        <source>doLoadUNL() updating;

/*

Purpose:	Load the details of a directories unl's so can run

Parameters:			

Return Value:		


Date		Who		Reason
26 May 2011	cnwmh5	Initial creation
03/09/2012	cnwmh5	Update to handle only PortSchema*.unl, no JadeScript methods and 'Class' lines
16/03/2015	cnwm5h	Tranisent Leaks
*/

vars

	fileFolder		: FileFolder;
	file			: File;
	obj				: Object;
	
	tokensArray		: HugeStringArray;
	detailsArray	: HugeStringArray;
	
	allFiles		: FileNodeArray;

	directory		: String;
	line			: String;
	clearSelections	: Boolean;
	index			: Integer;
	posSpace		: Integer;
	methodName		: String;
	
begin

	directory := self.doBrowseForFolder();
	if directory = null then
		return;
	endif;
	
	create tokensArray transient;
	create detailsArray transient;
	
	foreach index in 1 to lbxTests.listCount do
		self.lbxTests.itemSelected[index] := false;
		self.lbxTests.itemExpanded[index] := false;
	endforeach;
	
	create allFiles transient;
	
	create fileFolder transient;
	fileFolder.mask := "*UnitTestHotfixToday.unl";
	fileFolder.fileName := directory;
	fileFolder.files.copy(allFiles);
	
	if allFiles.isEmpty() then								// 14/02/2013 cnwmh5
		delete fileFolder;
		create fileFolder transient;
		fileFolder.mask := "*UnitTestHotfix.unl";
		fileFolder.fileName := directory;
		fileFolder.files.copy(allFiles);
	endif;	
	
	if allFiles.isEmpty() then
		delete fileFolder;
		create fileFolder transient;
		fileFolder.mask := "PortSchema*.unl";
		fileFolder.fileName := directory;
		fileFolder.files.copy(allFiles);
	endif;	
	
	if allFiles.isEmpty() then							// 08/04/2013 cnwmh5
		delete fileFolder;
		create fileFolder transient;
		fileFolder.mask := "*.unl";
		fileFolder.fileName := directory;
		fileFolder.files.copy(allFiles);
	endif;	
		
	clearSelections := true;
	foreach obj in allFiles do
		file := obj.File;
		file.kind := File.Kind_Unknown_Text; // 29/2/16  cnwns1 PAR 36286 unicode version
		self.lblCurrentMethod.caption := "Loading UNL file: " &amp; file.fileName[file.fileName.reversePos("\") + 1:end];
		while not file.endOfFile do
			line := file.readLine();
			if line = null then
				continue;
			endif;
			if line[1:6].toUpper() = "METHOD" then
				methodName := line[8:line.pos(" ", 8) - 8].toUpper();
				if methodName &lt;&gt; "JADESCRIPT" and  methodName &lt;&gt; "DECIMAL" and 
						methodName &lt;&gt; "INTEGER"then 
					if not detailsArray.includes(line[8:end]) then
						detailsArray.add(line[8:end]);
					endif;
				endif;
			elseif line[1:5].toUpper() = "CLASS" then
				self.getDetailsForClass(line, file.fileName, detailsArray);
			endif;
			//tokensArray.clear();
			//line.getHugeTokensForDelimiter(" ", tokensArray);
			//if tokensArray.size = 3 then
			//	self.doSelectUNL(tokensArray[2], tokensArray[3], clearSelections);
			//endif;
		endwhile;
		clearSelections := false;
		self.lblCurrentMethod.caption := "Loaded UNL file: " &amp; file.fileName[file.fileName.reversePos("\") + 1:end];
	endforeach;
	
	clearSelections := false;
	foreach index in 1 to detailsArray.size do
		line := detailsArray[index];
		posSpace := line.pos(" ", 1);
		self.doSelectUNL(line[1:posSpace-1], line[posSpace+1:end], clearSelections);
	endforeach;
	
	self.recalcCurrentRunTotals();
	self.showTotals();

epilog

	delete fileFolder;
	delete tokensArray;
	delete detailsArray;
	delete allFiles;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="doLoadUNLMDHTEST" id="1f143338-0e3d-45b0-9b70-d0a356e07f53">
        <updating/>
        <source>doLoadUNLMDHTEST(_directory : String input) updating;

/*

Purpose:	Load the details of a directories unl's so can run

Parameters:			

Return Value:		


Date		Who		Reason
26 May 2011	cnwmh5	Initial creation
03/09/2012	cnwmh5	Update to handle only PortSchema*.unl, no JadeScript methods and 'Class' lines
16/03/215	cnwmh5	Tranisent Leaks
*/

vars

	fileFolder		: FileFolder;
	file			: File;
	obj				: Object;
	
	tokensArray		: HugeStringArray;
	detailsArray	: HugeStringArray;
	
	allFiles		: FileNodeArray;

	directory		: String;
	line			: String;
	clearSelections	: Boolean;
	index			: Integer;
	posSpace		: Integer;
	methodName		: String;
	
begin

	//directory := self.doBrowseForFolder();
	directory := _directory;
	if directory = null then
		return;
	endif;
	
	
	
	create tokensArray transient;
	create detailsArray transient;
	
	foreach index in 1 to lbxTests.listCount do
		self.lbxTests.itemSelected[index] := false;
		self.lbxTests.itemExpanded[index] := false;
	endforeach;
	
	create allFiles transient;
	
	create fileFolder transient;
	fileFolder.mask := "UnitTestHotfix*.unl";
	fileFolder.fileName := directory;
	fileFolder.files.copy(allFiles);
	
	if allFiles.isEmpty() then
		delete fileFolder;
		create fileFolder transient;
		fileFolder.mask := "PortSchema*.unl";
		fileFolder.fileName := directory;
		fileFolder.files.copy(allFiles);
	endif;	
		
	clearSelections := true;
	foreach obj in allFiles do
		file := obj.File;
		file.kind := File.Kind_Unknown_Text; // 29/2/16  cnwns1 PAR 36286 unicode version
		while not file.endOfFile do
			line := file.readLine();
			if line = null then
				continue;
			endif;
			if line[1:6].toUpper() = "METHOD" then
				methodName := line[8:line.pos(" ", 8) - 8].toUpper();
				if methodName &lt;&gt; "JADESCRIPT" and  methodName &lt;&gt; "DECIMAL" and 
						methodName &lt;&gt; "INTEGER"then 
					if not detailsArray.includes(line[8:end]) then
						detailsArray.add(line[8:end]);
					endif;
				endif;
			elseif line[1:5].toUpper() = "CLASS" then
				self.getDetailsForClass(line, file.fileName, detailsArray);
			endif;
			//tokensArray.clear();
			//line.getHugeTokensForDelimiter(" ", tokensArray);
			//if tokensArray.size = 3 then
			//	self.doSelectUNL(tokensArray[2], tokensArray[3], clearSelections);
			//endif;
		endwhile;
		clearSelections := false;
	endforeach;
	
	write '***** detailsArray.size: ' &amp; Tab &amp; detailsArray.size.String;
	
	clearSelections := false;
	foreach index in 1 to detailsArray.size do
		line := detailsArray[index];
		//write Tab &amp; Tab &amp; line;
		posSpace := line.pos(" ", 1);
		self.doSelectUNL(line[1:posSpace-1], line[posSpace+1:end], clearSelections);
	endforeach;
	write '***** index: ' &amp; Tab &amp; index.String;
	
	self.recalcCurrentRunTotals();
	self.showTotals();

epilog

	delete fileFolder;
	delete tokensArray;
	delete detailsArray;
	delete allFiles;
	
end;</source>
        <Parameter name="_directory" type="String" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doRefresh" id="4bd16f6b-2cc4-48e3-b30b-cde27103d95b">
        <updating/>
        <source>doRefresh() updating;
//03 August 2008	cnwdw1	
//
vars
	obj: Object;
	index: Integer;
begin
	if lbxTests.listIndex &gt; 0 then
		obj := lbxTests.itemObject[lbxTests.listIndex];
	endif;
	self.setupForm();
	index := lbxTests.findObject(obj);
	if index &gt; 0 then
		lbxTests.listIndex := index;
		lbxTests.itemExpanded[index] := true;
		lbxTests.topIndex := index;
	endif;

end;</source>
    </JadeMethod>
    <JadeMethod name="doRunTest" id="9987e811-dfeb-4b5f-a068-41f5d8592072">
        <updating/>
        <source>doRunTest() updating;
//03 August 2008	cnwdw1	
//

vars
	profileClass	: Class;
	profile			: UT_Profile;
	obj				: Object;
	baseClass		: Class;
	schemaClass		: Class;
	test			: Method;
	testController	: JMTTestController;
	index			: Integer;
	maxCount		: Integer;
begin

	btnStop.enabled := true;

	app.verboseLogging := self.chkErrStack.value;

	if self.cmbProfiles.listIndex &gt; 0 then
		profileClass := self.cmbProfiles.listObject.Class;
		create profile as profileClass transient;
		profile.initialize();
	endif;
	create testController transient;
	testController.setCheckLeaks(self.chkCheckLeaks.value);
	testController.logResult := false;
	testController.findBlame := self.chkBlame.value;
	testController.methods := self.chkMethods.value;	//12 Apr 2021	NDL	TFS 51023
	testController.setLogMessages(true);
	
	index		:= 1;
	maxCount	:= lbxTests.listCount;
	while index &lt;= maxCount do
		if lbxTests.itemSelected[index] then
		///if lbxTests.itemSelected[index] or (self.chkFailsOnly.value = true and lbxTests.itemPicture[index] = picFailed.picture) then	// 01/05/2015 cnwmh5
			obj := lbxTests.itemObject[index];
			if obj.isKindOf(Class) then
				if self.chkFailsOnly.value = true then																					// 01/05/2015 cnwmh5
					index := index + 1;
					continue;
				endif;
				btnStop.enabled := true;
				testController.runClassTests(obj.Class, profile, self);
			else
				if self.doStop then
					break;
				endif;
				baseClass := lbxTests.itemObject[lbxTests.itemData[index]].Class;
				test := lbxTests.itemObject[index].Method;
				if self.chkFailsOnly.value = true and lbxTests.itemPicture[index] = picSuccess.picture then								// 01/05//2015	cnwmh5
					index := index + 1;
					continue;
				endif;	
				schemaClass := self.getMethodClass(test, baseClass.name);
				testController.runMethodTest(null, schemaClass.Class, test, profile);
			endif;
		endif;
		index := index + 1;
	endwhile;	
epilog
	delete profile;
	delete testController;
	btnStop.enabled := false;
	self.doStop := false;
end;
</source>
    </JadeMethod>
    <JadeMethod name="doSaveCategory" id="92f39113-c46c-43cd-a2dc-34e8836c5b1c">
        <updating/>
        <source>doSaveCategory() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date			Who		Reason
26 August 2011	cnwmh5	Initial creation

*/

vars
	
	category				: UM_Category;
	klass					: Class;
	obj						: Object;
	
	selectedObjects			: ObjectArray;
	tokens					: StringArray;
	
	classes					: ClassColl;
	
	categoryName			: String;
	index, 
	index1					: Integer;
	nonRunClassSelected		: Boolean;
	msgBoxReturn			: Integer;
	selectedCount			: Integer;
	
begin

	// check that the category name isn't null;
	categoryName := self.txtCategory.text;
	if categoryName.trimBlanks() = null then
		app.msgBox("Category is empty.  Please enter a Category name.", "Category Name", MsgBox_OK_Only + MsgBox_Information_Icon);
		self.txtCategory.setFocus();
		return;
	endif;

	category := app.allCategories[categoryName];
	
	// check to see if anything selected and new
	if category = null and self.lbxTests.selectedCount = 0 then
		app.msgBox("No tests selected to save.  Please select some test(s) and resave the Category.", "Nothing Selected", MsgBox_OK_Only + MsgBox_Information_Icon);
		self.txtCategory.setFocus();
		return;
	endif;
	
	// check to see if the category exists
	if category = null then
		create category transient;
		category.updateCategoryName(categoryName);
		app.allCategories.add(category);
	elseif self.cmbCategories.text = categoryName and category &lt;&gt; null then
		nonRunClassSelected := self.lbxTests.itemSelected[self.lbxTests.findString(1, "UT_UnitTest")] or self.lbxTests.itemSelected[self.lbxTests.findString(1, "UT_DSL")];
		if self.lbxTests.selectedCount &gt; 0 and not nonRunClassSelected then
			if app.msgBox("Category (" &amp; categoryName &amp; ") already exists." &amp; CrLf &amp; "'Yes' to update the category, or 'No' to Cancel", "Category Already Exists", 
					MsgBox_Yes_No + MsgBox_Question_Mark_Icon) = MsgBox_Return_No then
				self.txtCategory.setFocus();
				return;
			endif;
		else
			//return;
			if not category.canBeDeleted then
				msgBoxReturn := app.msgBox("System defined category (" &amp; categoryName &amp; ") cannot be deleted." &amp; CrLf &amp; "'OK' to Cancel", 
						"System Defined Category", MsgBox_OK_Only + MsgBox_Question_Mark_Icon);
					self.txtCategory.setFocus();
					self.btnSelectCat.click(self.btnSelectCat);
					return;
				//return;
			else
				msgBoxReturn := app.msgBox("Category (" &amp; categoryName &amp; ") will be deleted." &amp; CrLf &amp; "'Yes' to delete the category, or 'No' to Cancel", "Delete Category", 
						MsgBox_Yes_No + MsgBox_Question_Mark_Icon);
				if msgBoxReturn = MsgBox_Return_Yes then
					self.doDeleteCategory(category, category.name, category.allCategoryClassMethods);
					return;
				else
					self.txtCategory.setFocus();
					self.btnSelectCat.click(self.btnSelectCat);
					return;
				endif;
			endif;
		endif;
	endif;
		
	if self.lbxTests.selectedCount = 0 and category.allCategoryClassMethods.isEmpty() then
		return;
	endif;
	
	create selectedObjects transient;
	create classes transient;
	foreach index in 1 to self.lbxTests.listCount do
		if self.lbxTests.itemSelected[index] then
			// if class and no subclasses selected then all subclasses are selected
			obj := self.lbxTests.itemObject[index];
			if obj.isKindOf(Class) then
				obj.Class.allLocalSubclasses(classes);
				selectedCount := 0;
				foreach klass in classes do
					index1 := self.lbxTests.findObject(klass);
					if index1 &gt; -1 then
						if self.lbxTests.itemSelected[index1] then
							selectedCount := selectedCount + 1;
						endif;
					endif;
				endforeach;
			endif;
			selectedObjects.add(self.lbxTests.itemObject[index]);
			if classes.size &gt; 0 and selectedCount = 0 then
				classes.copy(selectedObjects);
			endif;
		endif;	
	endforeach;
	
	// update the category's details
	self.updateCategoryDetails(category, selectedObjects);

	// rebuild the categories details
	self.populateCategories();
	self.cmbCategories.listIndex := self.cmbCategories.findStringExact(1, self.txtCategory.text);
	self.btnSelect.enabled := self.cmbCategories.listIndex &gt; 0;
	self.txtCategory.text := null;
	self.doSelectCatgory();
	
epilog

	self.btnSaveCateg.caption := "Save Category";

	delete selectedObjects;
	delete classes;

end;</source>
    </JadeMethod>
    <JadeMethod name="doSelect" id="a86e3589-a977-4f1b-9d75-f788e98e419f">
        <updating/>
        <source>doSelect() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
04 Feb 2011	cnwndl1	Initial creation
21 Oct 2011	cnwkpd1	Change criteria to include all Test Runs less than 2 weeks old

*/

vars
	root : UM_Root;
	///testRun : UM_TestRun;
	classString : String;
	methodString : String;
	///classMethod : UM_ClassMethod;
	iter : Iterator;
	///firstResult : UM_TestResult;
	///testResult : UM_TestResult;
	testRun	: UM_UnitTestRun;						// 10/09/2013 cnwmh5
	classMethod	: UM_UnitTestClassMethod;
	firestResult	: UM_UnitTestResult;
	testResult		: UM_UnitTestResult;
	index : Integer;
	firstIndex : Integer;
	firstTS : TimeStamp;
	invalid : Boolean;
	
begin
	root := UM_Root.firstInstance;
	if root = null then
		app.msgBox("No root!","Error",MsgBox_OK_Only);
		return;
	endif;
	
	///testRun := root.allTestRuns.last;
	testRun := root.allUnitTestRuns.last;				// 10/09/2013 cnwmh5
	if testRun = null then
		app.msgBox("No UM_TestRun!","Error",MsgBox_OK_Only);
		return;
	endif;
	
	classString := cmbClass.text;
	methodString := cmbMethod.text;
	
	///classMethod := root.allClassMethods.getAtKey( classString, methodString );
	classMethod := root.allClassMethodsUsedBy.getAtKey(classString, methodString);			// 10/09/2013 cnwmh5
	if classMethod = null then
		//app.msgBox("No UM_ClassMethod!","Error",MsgBox_OK_Only);
		app.msgBox("No UM_UnitTestClassMethod!","Error",MsgBox_OK_Only);
		return;
	endif;
	
	///if classMethod.allTestResults.isEmpty then
	if classMethod.allUnitTestResultsUsedBy.isEmpty() then											// 10/09/2013 cnwmh5
		app.msgBox("UM_ClassMethod.allTestResults.isEmpty!","Error",MsgBox_OK_Only);
		////app.msgBox("UM_UnitTestClassMethod.allUnitTestResultsUsedBy.isEmpty!","Error",MsgBox_OK_Only);
		return;
	endif;
	
	// Work out how far back to look
	firstTS := app.actualTimeServer().addDays(-1 * MaxAgeInDays);
	
	foreach index in 1 to lbxTests.listCount do
		self.lbxTests.itemSelected[index] := false;
		self.lbxTests.itemExpanded[index] := false;
	endforeach;
	
	///iter := classMethod.allTestResults.createIterator;
	on Exception do app.handleDeletedObject( exception, testResult, invalid );	//19 May 2021	NDL
	iter := classMethod.allUnitTestResultsUsedBy.createIterator;						// 10/09/2013 cnwmh5
	while iter.back( testResult ) do
		///if testResult.runTimestamp &lt; firstTS then
		///	break;
		///endif;
		//// 10/09/2013 cnwmh5 - Comment out above code
		index := self.doSelectTest(testResult);
		if firstIndex = 0 or index &lt; firstIndex then
			firstIndex := index;
		endif;
	endwhile;
	
	if firstIndex &gt; 0 then
		self.lbxTests.topIndex := firstIndex;
	endif;

epilog
	delete iter;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="doSelectCatgory" id="12cec6e4-c1cf-4c30-8400-037d4dde244a">
        <updating/>
        <source>doSelectCatgory() updating;

/*

Purpose:			Select the class / methods for the category

Parameters:			

Return Value:		


Date					Who		Reason
26 August 2011	cnwmh5	Initial creation

*/

vars

	category				: UM_Category;
	obj						: Object;

	index					: Integer;
	firstIndex				: Integer;
		
begin

	firstIndex := -1;
	
	// clear all branches
	foreach index in 1 to lbxTests.listCount do
		self.lbxTests.itemSelected[index] := false;
		self.lbxTests.itemExpanded[index] := false;
	endforeach;

	// see that category actually exists
	category := app.allCategories[self.cmbCategories.text];
	if category = null or category.allCategoryClassMethods.isEmpty() then
		self.lbxTests.itemExpanded[2] := true;
		self.lbxTests.topIndex := 1;
		self.txtCategory.text := self.cmbCategories.text;
		return;
	endif;
	
	// display all selected tests for the catgory
	foreach obj in category.allCategoryClassMethods do
		self.doSelectClassMethod(obj);
		if firstIndex = -1 then
			firstIndex := self.lbxTests.newIndex;
		endif;
	endforeach;

	self.txtCategory.text := self.cmbCategories.text;
	self.btnSelectCat.enabled := self.cmbCategories.enabled;
	self.lbxTests.topIndex := self.lbxTests.findObject(category.allCategoryClassMethods[1]);
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doSelectClassMethod" id="15c1c1c9-ed9d-46c8-887d-01c08fd83a69">
        <source>doSelectClassMethod(_classMethod : Object) : Integer;

/*

Purpose:			Show the class / methods that have been selected

Parameters:			

Return Value:		


Date				Who		Reason
23 September 2011	cnwmh5	Initial creation

*/

vars

	index : Integer;

begin


	index := lbxTests.findObject(_classMethod);
	if index &lt; 1 then
		return 0;
	endif;
	
	lbxTests.itemExpanded[index] := true;
	lbxTests.itemSelected[index] := true;
	
	return index;

epilog

end;</source>
        <Parameter name="_classMethod" type="Object"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="doSelectTest" id="4d0b92af-4566-4867-8507-0f1ee4f4ae14">
        <source>doSelectTest( testResult : UM_UnitTestResult ):Integer;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
04 February 2011	cnwndl1	Initial creation

*/

vars

	klass : Class;
	meth : Method;
	index : Integer;

begin

	/*
	klass := currentSchema.getClass(testResult.testClass);
	if klass = null then
		write testResult.testClass &amp; " not found!";
		return 0;
	endif;
	
	meth := klass.getMethodInHTree(testResult.testName);
	if klass = null then
		write testResult.testClass &amp; "::" &amp; testResult.testName &amp; " not found!";
		return 0;
	endif;
	
	index := lbxTests.findObject(meth);
	if index &lt; 1 then
		write testResult.testClass &amp; "::" &amp; testResult.testName &amp; " index not found!";
		return 0;
	endif;
	*/
	
	// 10/09/2013 cnwmh5
	klass := currentSchema.getClass(testResult.myClassMethod.className);
	if klass = null then
		if process.isCNWMH5(false) then
		write testResult.myClassMethod.className &amp; " not found!";
		endif;
		return 0;
	endif;
	
	meth := klass.getMethodInHTree(testResult.myClassMethod.methodName);
	if klass = null then
		if process.isCNWMH5(false) then
		write testResult.myClassMethod.className &amp; "::" &amp; testResult.myClassMethod.methodName &amp; " not found!";
		endif;
		return 0;
	endif;
	
	index := lbxTests.findObject(meth);
	if index &lt; 1 then
		if process.isCNWMH5(false) then
		write testResult.myClassMethod.className &amp; "::" &amp; testResult.myClassMethod.methodName &amp; " index not found!";
		endif;
		return 0;
	endif;
		
	lbxTests.itemExpanded[lbxTests.itemData[index]] := true;
	lbxTests.itemSelected[index] := true;
	
	return index;

epilog

end;</source>
        <Parameter name="testResult" type="UM_UnitTestResult"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="doSelectUNL" id="a3402d12-63ea-4647-b7db-f06a9c553670">
        <updating/>
        <source>doSelectUNL(_classString, _methodString : String; _clearSelections : Boolean) updating;

/*

Purpose:		Select those that have items in the unl	

Parameters:			

Return Value:		


Date		Who		Reason
04 Feb 2011	cnwndl1	Initial creation
21 Oct 2011	cnwkpd1	Change criteria to include all Test Runs less than 2 weeks old

*/

vars

	root : UM_Root;
	///testRun : UM_TestRun;
	///classMethod : UM_ClassMethod;
	iter : Iterator;
	///firstResult : UM_TestResult;
	///testResult,
	///pxyResult	: UM_TestResult;
	index : Integer;
	firstIndex : Integer;
	firstTS : TimeStamp;
	
	testRun			: UM_UnitTestRun;							// 10/09/2013 cnwmh5
	classMethod		: UM_UnitTestClassMethod;
	firstResult		: UM_UnitTestResult;
	testResult		: UM_UnitTestResult;
	pxyResult		: UM_UnitTestResult;
	
begin

	root := UM_Root.firstInstance;
	if root = null then
		return;
	endif;
	
	///testRun := root.allTestRuns.last;
	testRun := root.allUnitTestRuns.last;
	if testRun = null then
		return;
	endif;
	
	///classMethod := root.allClassMethods.getAtKey( _classString, _methodString );
	///classMethod := root.allRunnableUTClassesMethods.getAtKey(_classString, _methodString);			// 10/09/2013 cnwmh5
	classMethod := root.allClassMethodsUsedBy.getAtKey(_classString, _methodString);					// 30/10/2013 cnwmh5
	
	if classMethod &lt;&gt; null then
	
		///if classMethod.allTestResults.isEmpty then
		///if classMethod.allUnitTestResults.isEmpty() then								// 10/09/2013 cnwmh5
		if classMethod.allUnitTestResultsUsedBy.isEmpty() then							// 30/10/2013 cnwmh5
			return;
		endif;
		
		// Work out how far back to look
		firstTS := app.actualTimeServer().addDays(-1 * MaxAgeInDays);
		
		////iter := classMethod.allTestResults.createIterator;
		///iter := classMethod.allUnitTestResults.createIterator;							// 10/09/2013 cnwmh5
		iter := classMethod.allUnitTestResultsUsedBy.createIterator;						// 30/10/2013 cnwmh5
		while iter.back( testResult ) do
			////if testResult.runTimestamp &lt; firstTS then
			if testResult.methodRunStartTS &lt; firstTS then								// 10/09/2013 cnmwh5
				break;
			endif;
			index := self.doSelectTest(testResult);
			if firstIndex = 0 or index &lt; firstIndex then
				firstIndex := index;
			endif;
		
		endwhile;
	
	//else
		
	//	create pxyResult transient;
	//	pxyResult.setPropertyValue('classMethod', _classString);
	//	pxyResult.setPropertyValue('testResult', _methodString);
	//	firstIndex := self.doSelectTest(pxyResult);
		
	endif;
	
	
	if firstIndex &gt; 0 then
		self.lbxTests.topIndex := firstIndex;
	endif;

epilog
	delete pxyResult;
	delete iter;
	
end;</source>
        <Parameter name="_classString" type="String"/>
        <Parameter name="_methodString" type="String"/>
        <Parameter name="_clearSelections" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doShowSettings" id="7147e075-3b4a-4fc2-a7f4-a831e3cf62d1">
        <updating/>
        <source>doShowSettings() protected, updating;

/*

Purpose:			Display all the settings for the currently selected profile

Parameters:			None

Return Value:		None


Date		Who		Reason
23 Sep 2009	cnwkpd1	Initial creation

*/

vars
	profileClass	: Class;
	profile			: UT_Profile;
	
begin
	if self.cmbProfiles.listIndex &lt;= 0 then
		return;
	endif;
	
	profileClass := self.cmbProfiles.listObject.Class;
	create profile as profileClass transient;
	profile.initialize();
	
	self.fldTestResults.topSheet := self.shtDetails;
	self.txtResultDetails.text := profile.getSettingsDisplay();
	
	
epilog
	delete profile;
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doUnselectClassMethod" id="06c4067b-0607-4a41-b6c3-06018f3e150a">
        <source>doUnselectClassMethod(_classMethod : Object) : Integer;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
12 February 2013	cnwmc5	Initial creation

*/

vars

	index : Integer;

begin


	index := lbxTests.findObject(_classMethod);
	if index &lt; 1 then
		return 0;
	endif;
	
	lbxTests.itemSelected[index] := false;
	
	return index;

epilog

