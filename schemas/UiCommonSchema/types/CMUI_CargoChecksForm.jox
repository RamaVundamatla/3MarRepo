    </JadeMethod>
    <JadeMethod name="doAttachPhoto" id="bc304f95-a0b5-4441-8369-cd7b80455430">
        <updating/>
        <source>doAttachPhoto() updating;
/*****************************************************
Author		: jlika1 (Karen Alexander)
Date		: 30 January 2024
TFS#		: 62155
Function	:

*** Changes ***
Date			Name		TFS#		Description

****************************************************/

constants	
	PictureTaken	= 0;
	PictureCancelled = 1;
	MinimumOSVersion = "5.2";
	MinWindows8 = "6.1";
	CameraAppName ="JadeCam";
	PHOTO_TYPE_FILTER : String = "Photos(*.bmp;*.BMP;*.tif;*.TIF;*.tiff;*.TIFF;*.jpeg;*.JPEG;*.jpg;*.JPG;*.png;*.PNG; *.gif;*.GIF)|*.bmp;*.BMP;*.tif;*.TIF;*.tiff;*.TIFF;*.jpeg;*.JPEG;*.jpg;*.JPG;*.png;*.PNG;*.gif;*.GIF";
vars
	pic 			: CMDFileOpen;		
	errorMsg		: String;	
	result,
	result2			: Integer;
	args			: StringArray;
	jadeDir,
	photoDir,
	photoName,
	photoFileName,
	appName			: String;
	testPhotoFile	: File;
	
	osVersion		: String;
	osArchitecture	: Integer;
	osPlatform 		: Integer;
	cmdFile 		: CMDFileOpen;
	isWindows		: Boolean;		
	invalidThumbnail : Boolean;
begin
	osPlatform:=process.getOSPlatform(osVersion, osArchitecture);
	
	app.writeLog(app.getErrorString2(OS_Version_Architecture,osVersion,osArchitecture.String), LogTRACE);
	if  (osVersion.Real &gt;= MinimumOSVersion.Real) then
		
		// PAR #23221 - First try to run the external camera with a temporary file name
		photoDir := app.getTempDir(); //PAR22336 - presentation client executed so no need for app.getTempDirFromSystemConfig
		photoName := "JadePhoto" &amp; app.actualTimeServer().getNumeralString() &amp; ".jpg";
		photoFileName := photoDir &amp; photoName;		
		create args transient;
		if osVersion.Real &gt;= MinWindows8.Real then
			args.add( photoDir );
		else
			args.add('"' &amp; photoDir &amp; '"');
		endif;
		args.add(photoName);
	
		jadeDir := process.getJadeInstallDirectory();
		appName := '"' &amp; jadeDir &amp; CameraAppName &amp; '"';
		
		app.writeLog(app.getErrorString3(Running_thin_client_command, jadeDir, appName,args.concatenate(" ")), LogTRACE);
	
		result := node.createExternalProcess(jadeDir,
											 appName,
											 args,
											 null,
											 true,
											 true,
											 result2);
											 
		app.writeLog(app.getErrorString3(Returned_from_Camera, CameraAppName, result.String, result2.String), LogTRACE);		
		// If the camera executable returns OK, check that the file can be found
		if result = Node.ExternalProcess_Successful then
			if result2 = PictureTaken then
				create testPhotoFile transient;
				testPhotoFile.fileName := photoFileName;
				if not testPhotoFile.isAvailable() then
					app.writeLog("File " &amp; photoFileName &amp; " returned from " &amp; CameraAppName &amp; " is not available", LogTRACE);
					photoFileName := null;
				endif;
			else
				// Some kind of exception case from the camera, or the user cancelled the camera
				photoFileName := null;
			endif;	
		
		else
			// Camera didn't return OK, so need to manually select a file
			photoFileName := null;
		endif;
		
	elseif app.isDevelopmentSystem() then
		// add in so can test in dev environment
		create cmdFile transient;
		cmdFile.filter := PHOTO_TYPE_FILTER;
		if cmdFile.open = 0 then
			photoFileName := cmdFile.fileName;
		endif;
	endif;
	
	// If we haven't go a valid photo file name yet, then ask for one
	if photoFileName = null then
		create pic transient;
		pic.filter := PHOTO_TYPE_FILTER;
		if pic.open = 0 then
			photoFileName := pic.fileName;
		endif;
	endif;
	
	// All OK, so open form to save photo to DB
	if photoFileName &lt;&gt; null then
		
		errorMsg	:=	null;
		
		self.setTopSheetTo( self.shtPhoto );		
		self.picFileName := photoFileName;
		self.originalPhoto := app.loadPicture(photoFileName);
		self.photoPreview.picture := self.originalPhoto;
		
		on Exception do self.handleImageThumbnailException(exception, self.photoPreview.picture,invalidThumbnail); 
	
		self.photoPreview.picture := self.photoPreview.createPictureAsType(false, false, 24, Window.PictureType_Png);	
		
		if invalidThumbnail then 
			app.msgBox(app.getErrorString(Picture_large_thumbnail), '', MsgBox_OK_Only);
		endif;			
	endif;

	// PAR #23221 - If we created a photo, and it is still available, then delete the file
	if testPhotoFile &lt;&gt; null and testPhotoFile.isAvailable() then
		testPhotoFile.purge();
	endif;	
		
epilog
	delete pic;	
	delete args;
	delete testPhotoFile;
	delete cmdFile;
end;</source>
    </JadeMethod>
    <JadeMethod name="doClickCargoCheckTable" id="6003b178-7681-403b-a4e7-6ae6a454066f">
        <updating/>
        <source>doClickCargoCheckTable(	_displayOnly : Boolean ) : Class updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06/05/2014	cnwndl1	Initial creation	Par 34076
15/07/2014	cnwdap1	PAR #34568 CCMS SFW 1389 Alternative Id Cargo Check
21/04/2015	cnwdap1	PAR #36094 CCMS SFW 1413 TFS 313 Cold Store Enhancements
30/01/2018	jlgdap1	TFS 36611 PEN Cannot check hazard
22/11/2018  JLGNS1	ChangeRequest 39691: SNO- VGM Gate Process
31/01/2024	jlika1	TFS 62154 62155 CUX | Photo Checks for Foreman Live
07/07/2024	jlizm1	TFS 62142 Perform checks from voyage ops live
05 Feb 2025	navnk30	JIRA 33887: MTN | Road Gate In Checks throws error for damage check that is Inappropriate.
11 Feb 2025	navnk30	JIRA 33889: CUX | Voyage Ops Live Form cargo checks Form - Unable to Save Keep on loading.
*/

vars

	jadeCell 	: JadeTableCell;
	selected 	: Boolean;
	column 		: Integer;
	row 		: Integer;
	cargoType 	: CM_CargoType;
	setting		: CM_TICargoChecks;
begin

	column := self.tblCargoChecks.column;
	row := self.tblCargoChecks.row;
	
	if column &lt;= self.tblCargoChecks.fixedColumns or row &lt;= self.tblCargoChecks.fixedRows then
		return null;
	endif;
	
	self.myCurrentCheckItem := self.tblCargoChecks.accessRow(row).itemObject.CM_CargoCheckItem;
	if self.myCurrentCheckItem = null then
		return null;
	endif;
	
	jadeCell := self.tblCargoChecks.accessCell(self.tblCargoChecks.row, self.tblCargoChecks.column);
	// switch pictures on the Yes/No buttons
	if self.myCurrentCheckItem.required and column.isOneOf(self.ColumnValue, self.ColumnValueExtra) then
		// switch to the opposite button picture i.e. down for up, or up for down
		if jadeCell.selected and not _displayOnly then

		else
			//jlier1 TFS 62168 29/1/24
			selected := true;		
			if self.tblCargoChecks.column = self.ColumnValue then
				jadeCell.picture := self.btnTickDown.createPicture(false, false, 32);
				self.updateTICargoCheckSettings("Y");
				self.tblCargoChecks.accessCell( row, self.ColumnValueExtra).picture := self.btnCross.createPicture(false, false, 32);			
			elseif column = self.ColumnValueExtra then
				jadeCell.picture := self.btnCrossDown.createPicture(false, false, 32);
				self.updateTICargoCheckSettings("N");
				self.tblCargoChecks.accessCell( row, self.ColumnValue).picture := self.btnTick.createPicture(false, false, 32);
			endif;
			
		endif;
		
	elseif self.tblCargoChecks.accessCell(row, column).inputType = self.tblCargoChecks.InputType_CheckBox then
		if self.tblCargoChecks.accessedCell.text = "1" then
			self.updateTICargoCheckSettings("Y");
			selected := true;
		else
			self.updateTICargoCheckSettings(" ");
		endif;
		
	elseif column = self.ColumnValue then
		//jlier1 TFS 62168 29/1/24
		setting := self.allCargoCheckItemSelections[self.myTrackedItem, self.myGTEReceival , self.myCurrentCheckItem];
		if setting = null or setting.selection ="N" then
			jadeCell.picture := self.btnTickDown.createPicture(false, false, 24);
			self.updateTICargoCheckSettings("Y");
			selected := true;
		else
			jadeCell.picture := self.btnTick.createPicture(false, false, 24);
			self.updateTICargoCheckSettings("N");
		endif;
		
	endif;
	
	if column = self.ColumnValueExtra then
		if self.shouldShowLocationCheck then
			self.lblConfirmLocation.visible := true;
			self.cmbConfirmLocation.visible := true;
		endif;
	endif;
		
	// if the click was in column 2, see what sheet to switch to
	if not _displayOnly then
		if column = self.ColumnValue and selected then
		
			// Damage
			if self.myCurrentCheckItem.requiredExtraInfo = EXTRA_INFO_DAMAGE then
				//if self.myGTEReceival &lt;&gt; null and  app.getMyUser().canDo(self.myTerminal, PmAdmDamageCodeAdvancedView) then		//05.02.2025 navnk30 JIRA 33887
				if (self.myGTEReceival &lt;&gt; null or self.myTrackedItem &lt;&gt; null)
						and  app.getMyUser().canDo(self.myTerminal, PmAdmDamageCodeAdvancedView) then								//11.02.2025 navnk30 JIRA 33889
					self.showAdvCargoDamageForm();
				else
					self.setTopSheetTo( self.shtDamage );
				endif;
			
			// Seals
			elseif self.myCurrentCheckItem.requiredExtraInfo = EXTRA_INFO_SEALS then
				self.setTopSheetTo( self.shtSeals );
				
			// Dimensions
			elseif self.myCurrentCheckItem.requiredExtraInfo = EXTRA_INFO_DIMENSION then
				self.setTopSheetTo( self.shtDimensions );
			
			// Weight
			elseif self.myCurrentCheckItem.requiredExtraInfo = EXTRA_INFO_WEIGHT then
				if self.myTrackedItem &lt;&gt; null and self.myGTEReceival &lt;&gt; null then										//ChangeRequest 39691
					if self.myTrackedItem.isPreNote and self.myGTEReceival.myVehicleVisitRecord.hasWeghBridgeVVRD then	//ChangeRequest 39691
						return null;																					//ChangeRequest 39691
					endif;																								//ChangeRequest 39691
				endif;																									//ChangeRequest 39691
				self.setTopSheetTo( self.shtWeight );
				
			//Special Lifts
			elseif self.myCurrentCheckItem.requiredExtraInfo = EXTRA_INFO_SPECIAL_LIFT then
				self.setTopSheetTo( self.shtSpecialLifts );
				
			// Alternative Id																	// PAR #34568
			elseif self.myCurrentCheckItem.requiredExtraInfo = EXTRA_INFO_ALTERNATIVE_ID then	// PAR #34568
				self.setTopSheetTo( self.shtAlternativeId );									// PAR #34568
				
			// Temperature																		// PAR #36094
			elseif self.myCurrentCheckItem.requiredExtraInfo = EXTRA_INFO_TEMPERATURE then		// PAR #36094
				self.setTopSheetTo(self.shtTemperature);										// PAR #36094
				
			// TFS 36611 Hazard Symbols - no extra info required, but need to show the To Do Task box
			// if we haven't already decided to apply the configured to do task
			elseif self.myCurrentCheckItem.requiredExtraInfo = EXTRA_INFO_HAZARD_SYMBOLS then
				if self.myCurrentCheckItem.myToDoTaskDesc &lt;&gt; null then
					if self.myTrackedItem &lt;&gt; null then
						if self.myTrackedItem.allToDoTasksToDo.includesToDoDesc( self.myCurrentCheckItem.myToDoTaskDesc.code ) then
							return null;
						endif;
					elseif self.myGTEReceival &lt;&gt; null then
						if self.myGTEReceival.allToDoTasks.includes( self.myCurrentCheckItem.myToDoTaskDesc ) then
							return null;
						endif;
					endif;
					self.setTopSheetTo(self.shtHazards);
				endif;
			// TFS 36611 end
			elseif self.myCurrentCheckItem.requiredExtraInfo = EXTRA_INFO_PHOTO then		
				if self.myTrackedItem &lt;&gt; null then
					self.doAttachPhoto();
				elseif self.myGTEReceival &lt;&gt; null then
					self.doAttachPhoto();
				endif;
			endif;
		endif;
	endif;

	return null;
epilog

end;</source>
        <Parameter name="_displayOnly" type="Boolean"/>
        <ReturnType type="Class"/>
    </JadeMethod>
    <JadeMethod name="doClickCargoSelectTable" id="62984e4a-6dae-4746-bdee-33e3113a39e2">
        <updating/>
        <source>doClickCargoSelectTable() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
01 February 2024	jlizm1	Initial creation TFS 62142 Perform checks from voyage ops live

*/

vars

	column 		: Integer;
	row 		: Integer;
	obj 		: Object;

begin

	column := self.tblChildCargo.column;
	row := self.tblChildCargo.row;
	
	if column &lt;&gt; self.ColumnValue or row &lt;= self.tblChildCargo.fixedRows then
		return;
	endif;
	
	obj := self.tblChildCargo.accessRow(row).itemObject;
	if obj = null or not obj.isKindOf(CM_TrackedItem) then
		return;
	endif;
	
	self.myTrackedItem := obj.CM_TrackedItem;
	self.displayChecksForCargo();

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doClickCheckParent" id="d415bc5a-cffa-4a7a-a383-edd4325134ba">
        <updating/>
        <source>doClickCheckParent() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
31 January 2024		jlizm1	Initial creation TFS 62142 Perform checks from voyage ops live

*/

vars
	obj : Object;

begin

	if not self.isAllChildChecksComplete() then
		self.btnCheckParent.value := false;
		return;
	endif;
	
	obj := self.btnCheckParent.userObject;
	if obj = null or not obj.isKindOf(CM_TrackedItem) then
		self.btnCheckParent.value := false;
		return;
	endif;
	
	self.myTrackedItem := obj.CM_TrackedItem;
	self.displayChecksForCargo();
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doClickTableSeals" id="62be58f7-9467-4f7c-872e-4d06e57e511f">
        <updating/>
        <source>doClickTableSeals() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 May 2014	cnwndl1	Initial creation	Par 34076
29 Jan 2024	jlier1 	TFS 62168
*/

vars
	column : Integer;
	row : Integer;

begin

	if self.sealCheckType = SEAL_CHECK_NONE then
		return;
		
	elseif self.sealCheckType = SEAL_CHECK_VIEW then
	
		column := self.tblSeals.column;
		row := self.tblSeals.row;
		
		if row &lt;= tblSeals.fixedRows then
			return;
		elseif column &lt;= tblSeals.fixedColumns then
			return;
		endif;

			
		if column = self.ColumnValue then
			tblSeals.accessCell(row, column).picture := self.btnTickDown.createPicture(false, false, 32);
			tblSeals.accessCell(row, self.ColumnValueExtra).picture := self.btnCross.createPicture(false, false, 32);
			tblSeals.accessCell(row, self.ColumnValueExtra).text:="";
			tblSeals.accessCell(row, ColumnValue).text:="Y";
		elseif column = self.ColumnValueExtra then
			tblSeals.accessCell(row, column).picture := self.btnCrossDown.createPicture(false, false, 32);
			tblSeals.accessCell(row, self.ColumnValue).picture := self.btnTick.createPicture(false, false, 32);
			tblSeals.accessCell(row, self.ColumnValue).text:="";
			tblSeals.accessCell(row, ColumnValueExtra).text:="N";
		endif;
			
		
		
	elseif self.sealCheckType = SEAL_CHECK_FULL then
		if row &lt;= tblSeals.fixedRows then
			return;
		elseif column &lt;= tblSeals.fixedColumns then
			return;
		endif;
		
	elseif self.sealCheckType = SEAL_CHECK_STRICT then
		if row &lt;= tblSeals.fixedRows then
			return;
		elseif column &lt;= tblSeals.fixedColumns then
			return;
		endif;
		
	endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doToDoTaskComplete" id="bca85c83-f963-4f5c-b252-b8a1632fa790">
        <updating/>
        <source>doToDoTaskComplete(_taskDesc: CM_ToDoTaskDesc) updating;
/*
----------   ----------  --------------------------------------------------
Created:	

Purpose:	 

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
28/11/2018   	JLGNS1	ChangeRequest 39691: SNO- VGM Gate Process
*/
vars

	ti			    	: CM_TrackedItem;
	pxyTiSet			: CM_TISet;
	result				: Integer;
	resourceUsageProxys : CM_ResourceTypeUsageSet;
	pxyTI				: CM_TrackedItem;
	pxyGateRecieval 	: CMGTE_Receival;

begin
	// get all selected cargo items to add or remove stop from all.
		
	ti  := self.myTrackedItem;

	if ti = null  then
		return;
	endif;

	create pxyTiSet transient;
	
	pxyTI := app.createUpdateProxy(ti).CM_TrackedItem;
	pxyTiSet.add(pxyTI);
	
	pxyGateRecieval := app.createUpdateProxy(self.myGTEReceival).CMGTE_Receival;
			
	//perform the updating
	while true do
		
		app.myTrxUA.trxUpdateTIGTERecRemoveToDo(pxyTiSet,pxyGateRecieval,_taskDesc,resourceUsageProxys,app.myPassport);
				
		if app.myPassport.trxCompletedOK then
						
			break;
		else
			result := app.showErrorWarningDialog(app.getString(Complete_TDTask), app.myPassport, ErrWarnMode_Add + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   result = IDOK then
				// there must have just been warnings that the user has acknowledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		break;
	endwhile;

epilog
	if pxyTiSet &lt;&gt; null and not pxyTiSet.isEmpty then
		pxyTiSet.purge;
	endif;
	delete pxyTiSet;
	
	delete pxyGateRecieval;
	
	if resourceUsageProxys &lt;&gt; null then
		resourceUsageProxys.purge;
		delete resourceUsageProxys;
	endif;
end;

</source>
        <Parameter name="_taskDesc" type="CM_ToDoTaskDesc"/>
    </JadeMethod>
    <JadeMethod name="doVerifyChecksComplete" id="01bcc61f-2e61-4574-846a-8eb2b3bbe59e">
        <source>doVerifyChecksComplete():Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 May 2014	cnwndl1	Initial creation	Par 34076

*/

vars

	index : Integer;
	item : CM_CargoCheckItem;
	msg : String;

begin

	foreach index in 1 to self.tblCargoChecks.rows do
		item := self.tblCargoChecks.accessRow(index).itemObject.CM_CargoCheckItem;
		if item = null then
			continue;
		endif;
		if item.required then
			//jlier1 TFS 62168 29/1/24 
			if self.allCargoCheckItemSelections[self.myTrackedItem, self.myGTEReceival, item] = null then
				msg := app.getErrorString1( Cargo_check_mandat_not_perfor, item.name );
				if app.msgBox( msg, app.getErrorString(Error), MsgBox_Yes_No ) = MsgBox_Return_Yes then
					return false;
				endif;
			endif;
		endif;
	endforeach;

	return true;

epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getSealUpdateEditTransDetails" id="f2a2f22e-4841-4771-9751-88b56ba4fd4f">
        <source>getSealUpdateEditTransDetails( pxySealTi : CM_SealTI; fieldsValues : HugeStringArray io ) protected;
/*

Purpose:			

Parameters:			

Return Value:		
/* Changes

Date		Name	TFS#		Description
============================================================================
06 May 2014	cnwndl1	Par 34076	Initial creation	
07 Jun 2017	cnwrs1	TFS 4462 	SNO add Terminal Operator, Unknown Seal and support multiple seals
29 Mar 2019 jlgka1	TFS 44020	Change StringArray to HugeStringArray.
============================================================================*/

vars
	realTi 			: CM_TrackedItem;
	oldSealTi 		: CM_SealTI;
	sealType 		: CM_SealType;
	newSealValue 	: String;
	prevSealValue 	: String;
	oldSealDt 		: TimeStamp;
	newSealDt 		: TimeStamp;
	tiTrxDetails 	: String;	
begin
	realTi := self.myTrackedItem;
	if realTi = null then
		return;
	endif;
	
	sealType := app.myRoot.getSealType( pxySealTi.sealType );
	if sealType = null then
		return;
	endif;
	
	oldSealDt := null;
	newSealDt := null;
	if realTi &lt;&gt; null then
		prevSealValue := realTi.getSealValue(sealType);
		if sealType.sealType = SealType_Operator then
			oldSealTi := realTi.getSealTI(sealType);
			if oldSealTi &lt;&gt; null then
				oldSealDt := oldSealTi.sealedDT;
			endif;
		endif;
	endif;
	newSealValue := pxySealTi.getSealValueAsString;
	
	if prevSealValue &lt;&gt; newSealValue then
		if sealType.isSystemSealType then
		
			if sealType.sealType = SealType_Operator then
				tiTrxDetails := app.formatForEditTransaction( SealNum, prevSealValue, newSealValue );
				fieldsValues.add(tiTrxDetails);
				newSealDt := pxySealTi.sealedDT;
				if newSealDt &lt;&gt; oldSealDt then
					tiTrxDetails := app.formatForEditTransaction( SealDT, oldSealDt.asStringJMT, newSealDt.asStringJMT );
					fieldsValues.add(tiTrxDetails);
				endif;
				
			elseif sealType.sealType = SealType_Shipper then
				tiTrxDetails := app.formatForEditTransaction( SealNumShippers, prevSealValue, newSealValue );
				fieldsValues.add(tiTrxDetails);
				
			elseif sealType.sealType = SealType_Customs then
				tiTrxDetails := app.formatForEditTransaction( SealNumCustoms, prevSealValue, newSealValue );
				fieldsValues.add(tiTrxDetails);
				
			elseif sealType.sealType = SealType_Vent then
				tiTrxDetails := app.formatForEditTransaction( SealNumVent, prevSealValue, newSealValue );
				fieldsValues.add(tiTrxDetails);
				
			elseif sealType.sealType = SealType_TerminalOperator then
				tiTrxDetails := app.formatForEditTransaction(SealNumTerminalOperator, prevSealValue, newSealValue);
				fieldsValues.add(tiTrxDetails);

			elseif sealType.sealType = SealType_Unknown then
				tiTrxDetails := app.formatForEditTransaction(SealNumUnknown, prevSealValue, newSealValue);
				fieldsValues.add(tiTrxDetails);
			endif;		
		else
			tiTrxDetails := app.formatForEditTransaction( sealType.description, prevSealValue, newSealValue );
			fieldsValues.add(tiTrxDetails);
			
		endif;
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="pxySealTi" type="CM_SealTI"/>
        <Parameter name="fieldsValues" type="HugeStringArray" usage="io"/>
    </JadeMethod>
    <JadeMethod name="getToDoTaskDescToAdd" id="27c709c2-ec33-4158-a9c7-037a119fdaeb">
        <source>getToDoTaskDescToAdd( _ti : CM_TrackedItem ) : CM_ToDoTaskDesc;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 May 2014	cnwndl1	Initial creation	Par 34076

*/

vars

	toDoTaskDesc : CM_ToDoTaskDesc;
	
begin

	toDoTaskDesc := self.myCurrentCheckItem.myToDoTaskDesc;
	if toDoTaskDesc &lt;&gt; null then
		// there is a task associated with thee current check.
		if self.chkToDo.value then
			//The user has requested this task to be set.
			if _ti &lt;&gt; null and _ti.allToDoTasksToDo.includesToDoDesc( toDoTaskDesc.code ) then
				// its already been set on the ti, so don't worry about it.
				return null;
			else
				// it hasn't been set yet, pass it back.
				return toDoTaskDesc;
			endif;
		endif;	
	endif;
	
	//nothing to do.
	return null;

epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <ReturnType type="CM_ToDoTaskDesc"/>
    </JadeMethod>
    <JadeMethod name="getXMLSettingsForSetup" id="a8102826-ab0a-4c6d-9fbf-ae0711ca47d8">
        <updating/>
        <source>getXMLSettingsForSetup() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date					Who		Reason
21 November 2024		jlizm1	Initial creation MTN 33013 Retain Cargo Check form size and position

*/

vars
	userWindow	: CM_UserWindow;
	newTop 		: Real;
	newLeft 	: Real;
	tmpMainForm	: Form;
	
begin
	userWindow := self.myUserWindow;
	if userWindow = null then
		userWindow := app.getUserWindow(self.name, false);
		if userWindow = null then
			return;
		endif;
	endif;
	
	self.width := userWindow.width;
	self.height:= userWindow.height;
	
	newTop	:= userWindow.top;
	newLeft	:= userWindow.left;

	// need to ensure that the saved window positions are
	// still visible on the screen
	if newTop &lt; 0 then
		newTop := 0;
	endif;
	if newLeft &lt; 0 then
		newLeft := 0;
	endif;
	
	tmpMainForm := app.mainForm;
	
	if tmpMainForm &lt;&gt; null then
		if newTop &gt;= tmpMainForm.clientHeight - 10
		or newLeft &gt;= tmpMainForm.clientWidth - 10
		then
			newTop := 20;
			newLeft := 20;
		endif;
	endif;

	self.top	:= newTop;
	self.left	:= newLeft;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="handleImageThumbnailException" id="27090991-8b72-4089-a500-95122ac6f117">
        <source>handleImageThumbnailException(_exc : Exception; _image : Any; _invalidThumbnail : Boolean io) : Integer;
/*****************************************************
Author		: jlika1 (Karen Alexander)
Date		: 30 January 2024
TFS#		: 62155
Function	:

*** Changes ***
Date			Name		TFS#		Description

****************************************************/

constants
	ImageNotValid = 14015;
vars
	returnVal		: Integer;
begin
	returnVal := Ex_Pass_Back;
	
	
	if _exc.errorCode = ImageNotValid  then
		_invalidThumbnail := true;
		if _exc.resumable then
			returnVal := Ex_Resume_Next;
		endif;
	endif;


epilog
	return returnVal;
end;</source>
        <Parameter name="_exc" type="Exception"/>
        <Parameter name="_image" type="Any"/>
        <Parameter name="_invalidThumbnail" type="Boolean" usage="io"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="initCargoChecksTable" id="265beeb3-8aed-48d6-be27-2201d8caa7d5">
        <source>initCargoChecksTable();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 May 2014	cnwndl1	Initial creation	Par 34076
29 Jan 2024	jlier1 TFS 62168
*/

vars

begin
	self.btnTick.caption:=self.btnTick.caption.toUpper;
	self.btnTickDown.caption:=self.btnTick.caption.toUpper;
	self.btnCross.caption:=self.btnCross.caption.toUpper;
	self.btnCrossDown.caption:=self.btnCross.caption.toUpper; 

	self.tblCargoChecks.rows := 0;
	self.tblCargoChecks.fixedRows := 0;
	self.tblCargoChecks.columns := 3;
	self.tblCargoChecks.selectMode := Table.SelectMode_None;
	self.tblCargoChecks.defaultRowHeight := 45;
	self.tblCargoChecks.stretch:=Table.Stretch_None;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="isAllChildChecksComplete" id="8767d3c0-0365-4715-8131-d0fabfcf8cbf">
        <source>isAllChildChecksComplete() : Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
01 February 2024	jlizm1	Initial creation TFS 62142 Perform checks from voyage ops live

*/

vars
	context : Integer;
	ti 		: CM_TrackedItem;
	
begin
	if self.myCargoChecks = null then
		return true;
	endif;
	
	context := self.myCargoChecks.context;
	
	foreach ti in self.allChildCargo do
		if not ti.isCargoCheckComplete(context) then
			return false;
		endif;
	endforeach;
	
	return true;
	
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isCheckingMainCargo" id="5ab82e23-c34d-4281-96a4-664b8c4234f9">
        <source>isCheckingMainCargo() : Boolean;
/*

Purpose:				Determine if the form is currently performing checks on the main cargo item
						(ie the parent container, or the trailer, or just an individual cargo item)

Parameters:			

Return Value:		

Date					Who		Reason
07 February 2024		jlizm1	Initial creation TFS 62142 Perform checks from voyage ops live

*/

vars

begin
	if self.myTrackedItem = self.myParentTI then
		return true;
	endif;
	
	if self.allChildCargo.isEmpty then
		return true;
	endif;
	
	return false;
	
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isVoyageOpsContext" id="38204bfb-40fb-4cb5-8ed1-6b7c0ffeaf74">
        <source>isVoyageOpsContext() : Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
01 February 2024	jlizm1	Initial creation TFS 62142 Perform checks from voyage ops live

*/

vars

begin
	if self.myCargoChecks &lt;&gt; null then
		return self.myCargoChecks.context = CARGO_CHECK_CONTEXT_VOYOP_DISC or self.myCargoChecks.context = CARGO_CHECK_CONTEXT_VOYOP_LOAD;
	endif;
	
	return false;
	
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="onlyHasExistingWarnings" id="79b2fe0a-ff92-4663-af04-a96091575696">
        <source>onlyHasExistingWarnings( _passport : CM_Passport ):Boolean  protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 May 2014	cnwndl1	Initial creation
11 Feb 2025	navnk30	JIRA 33889: CUX | Voyage Ops Live Form cargo checks Form - Unable to Save Keep on loading.

*/

vars

	error : CM_Error;

begin

	//if not self.allGTEWarningsToIgnore.isEmpty then		//11.02.2025 navnk30 JIRA 33889
		foreach error in _passport.allErrorWarnings do
			if not self.allGTEWarningsToIgnore.includesErrorLikeThis( error ) then
				return false;
			endif;
		endforeach;
	//endif;
	
	return true;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_passport" type="CM_Passport"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="processSealFullChecks" id="90cafe5c-3977-425a-8ea4-6c789b167457">
        <source>processSealFullChecks( startPos : Integer; endPos : Integer ):Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
06 May 2014			cnwndl1	Initial creation	Par 34076
06 April 2023		jlizm1	TFS 57098 EUP Seal numbers on trucks
18 Dec 2024			navhl20 Bug MTN-33659: MTN - Unable to load cargo items using the complete job form if the checks are configured
*/

vars

	mess : String;
	pos : Integer;
	obj : Object;
	sealType : CM_SealType;
	sealTi : CM_SealTI;
	truckSeal : CM_TruckSeal;
	sealBefore : String;
	sealAfter : String;
	pxySealCheckTrx : CM_SealCheck;
	realSealCheckTrx : CM_SealCheck;
	truckMode : Boolean;
	pxySealCheckDetails : CM_SealCheckDetailSet;
	pxySealCheckDetail	: CM_SealCheckDetail;
	updateArray : CM_ObjectArray;
	
begin

	
	if self.sealCheckType &lt;&gt; SEAL_CHECK_FULL then
		return false;
	endif;
	
	truckMode := self.myVehicleVisit &lt;&gt; null and self.myCargoChecks = null;	//18.12.2024 navhl20 #33659
	
	create pxySealCheckTrx transient;
	create pxySealCheckDetails transient;
	create updateArray transient;
	
	foreach pos in startPos to endPos do
		obj := self.tblSeals.accessRow(pos).itemObject;
		if obj &lt;&gt; null then
			if obj.isKindOf( CM_SealType ) then
				sealType 	:= obj.CM_SealType;
				sealBefore 	:= null;
				sealTi 		:= null;
				//cnwmc5 - 26 Nov 2015 - PAR 37138
				if self.myGTEReceival &lt;&gt; null then
					sealTi := self.myGTEReceival.getSealTI(sealType);
				elseif truckMode then
					truckSeal := self.myVehicleVisit.allTruckSeals.getTruckSeal(sealType);
					if truckSeal &lt;&gt; null then
						sealBefore := truckSeal.getSealValueAsString;
					endif;
				endif;
			elseif obj.isKindOf( CM_SealTI ) then
				sealTi := obj.CM_SealTI;
				sealBefore := sealTi.getSealValueAsString;
				sealType := app.myRoot.getSealType(sealTi.sealType);
			endif;
		else
			continue;
		endif;
		sealAfter := self.tblSeals.accessCell(pos,2).text;
		
		if not self.sealMatchesValueFromUser( sealBefore, sealAfter, sealTi ) then

			mess := app.getErrorString2(Value_entered_does_not_match, sealAfter, sealType.description);
			mess := mess &amp; CrLf &amp; app.getErrorString1(Continue_update_values, sealType.description);
			if app.msgBox( mess, app.getErrorString(Warning) , MsgBox_Yes_No) = MsgBox_Return_Yes then
				updateArray.add(sealType);
			else
				//user wants the opportunity to re-enter the value(s) for this seal
				self.tblSeals.row := pos;
				self.tblSeals.column := 2;
				self.tblSeals.accessCell(pos,2).cellControl.TextBox.selStart := 0;
				self.tblSeals.accessCell(pos,2).cellControl.TextBox.selLength := sealAfter.length;
				self.tblSeals.setFocus;
				return false;
			endif;
			
		endif;	
		
		if truckMode then
			pxySealCheckDetail := self.createPxySealCheckDetail( 	null,	//_sealCheck : CM_SealCheck;
										sealAfter,	//_sealAfter : String;
										sealBefore,	//_sealBefore : String;
										self.sealCheckType,	//_sealCheckType : Integer;
										sealType.sealType,	//_sealType : String;
										0	//_viewed : Integer
										);
			pxySealCheckDetails.add(pxySealCheckDetail);
		else
			self.createPxySealCheckDetail( 	pxySealCheckTrx,	//_sealCheck : CM_SealCheck;
											sealAfter,	//_sealAfter : String;
											sealBefore,	//_sealBefore : String;
											self.sealCheckType,	//_sealCheckType : Integer;
											sealType.sealType,	//_sealType : String;
											0	//_viewed : Integer
											);
		endif;
	endforeach;
	
	if truckMode then
		return self.createSealChecksForTruck(pxySealCheckDetails, updateArray);
	else
		realSealCheckTrx := self.createSealCheckTransaction(pxySealCheckTrx, updateArray, app.myPassport);
	endif;
	
	return realSealCheckTrx &lt;&gt; null or ( self.myGTEReceival &lt;&gt; null and not self.myGTEReceival.allSealCheckDetails.isEmpty );

epilog

	delete pxySealCheckTrx;
	delete pxySealCheckDetails;
	delete updateArray;

end;</source>
        <Parameter name="startPos" type="Integer"/>
        <Parameter name="endPos" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="processSealStrictChecks" id="f664f0a8-bd5c-4884-9fa6-c3292f24d967">
        <source>processSealStrictChecks( startPos : Integer; endPos : Integer ):Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
06 May 2014			cnwndl1	Initial creation	Par 34076
06 April 2023		jlizm1	TFS 57098 EUP Seal numbers on trucks
18 Dec 2024			navhl20 Bug MTN-33659: MTN - Unable to load cargo items using the complete job form if the checks are configured
*/

vars

	mess : String;
	pos : Integer;
	obj : Object;
	sealType : CM_SealType;
	sealTi : CM_SealTI;
	truckSeal : CM_TruckSeal;
	sealBefore : String;
	sealAfter : String;
	pxySealCheckTrx : CM_SealCheck;
	realSealCheckTrx : CM_SealCheck;
	truckMode : Boolean;
	pxySealCheckDetails : CM_SealCheckDetailSet;
	pxySealCheckDetail	: CM_SealCheckDetail;
	
begin

	
	if self.sealCheckType &lt;&gt; SEAL_CHECK_STRICT then
		return false;
	endif;
	
	truckMode := self.myVehicleVisit &lt;&gt; null and self.myCargoChecks = null;	//18.12.2024 navhl20 #33659
	
	create pxySealCheckTrx transient;
	create pxySealCheckDetails transient;
	
	foreach pos in startPos to endPos do
		obj := self.tblSeals.accessRow(pos).itemObject;
		if obj &lt;&gt; null then
			if obj.isKindOf( CM_SealType ) then
				sealType 	:= obj.CM_SealType;
				sealBefore 	:= null;
				sealTi 		:= null;
				//cnwmc5 - 26 Nov 2015 - PAR 37138
				if self.myGTEReceival &lt;&gt; null then
					sealTi := self.myGTEReceival.getSealTI(sealType);
				elseif truckMode then
					truckSeal := self.myVehicleVisit.allTruckSeals.getTruckSeal(sealType);
					if truckSeal &lt;&gt; null then
						sealBefore := truckSeal.getSealValueAsString;
					endif;
				endif;
			elseif obj.isKindOf( CM_SealTI ) then
				sealTi := obj.CM_SealTI;
				sealBefore := sealTi.getSealValueAsString;
				sealType := app.myRoot.getSealType(sealTi.sealType);
			endif;
		else
			continue;
		endif;
		sealAfter := self.tblSeals.accessCell(pos,2).text;
		
		if not self.sealMatchesValueFromUser( sealBefore, sealAfter, sealTi ) then
			mess := app.getErrorString2(Value_entered_does_not_match, sealAfter, sealType.description);
			app.msgBox( mess, app.getErrorString(Error) , MsgBox_OK_Only);
			//set user back to this field.
			self.tblSeals.row := pos;
			self.tblSeals.column := 2;
			self.tblSeals.accessCell(pos,2).cellControl.TextBox.selStart := 0;
			self.tblSeals.accessCell(pos,2).cellControl.TextBox.selLength := sealAfter.length;
			self.tblSeals.setFocus;	
			return false;
		endif;	
		
		if truckMode then
			pxySealCheckDetail := self.createPxySealCheckDetail(null,	//_sealCheck : CM_SealCheck;
																sealAfter,	//_sealAfter : String;
																sealBefore,	//_sealBefore : String;
																self.sealCheckType,	//_sealCheckType : Integer;
																sealType.sealType,	//_sealType : String;
																0	//_viewed : Integer
																);
			pxySealCheckDetails.add(pxySealCheckDetail);
		else
			self.createPxySealCheckDetail( 	pxySealCheckTrx,	//_sealCheck : CM_SealCheck;
											sealAfter,	//_sealAfter : String;
											sealBefore,	//_sealBefore : String;
											self.sealCheckType,	//_sealCheckType : Integer;
											sealType.sealType,	//_sealType : String;
											0	//_viewed : Integer
											);
		endif;
	endforeach;
	
	if truckMode then
		return self.createSealChecksForTruck(pxySealCheckDetails, null);
	else
		realSealCheckTrx := self.createSealCheckTransaction(pxySealCheckTrx, null, app.myPassport);
	endif;
	
	return realSealCheckTrx &lt;&gt; null or ( self.myGTEReceival &lt;&gt; null and not self.myGTEReceival.allSealCheckDetails.isEmpty );

epilog

	delete pxySealCheckTrx;
	delete pxySealCheckDetails;

end;</source>
        <Parameter name="startPos" type="Integer"/>
        <Parameter name="endPos" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="processSealViewChecks" id="3b15414b-ba06-499d-aaba-087eaad40044">
        <source>processSealViewChecks( startPos : Integer; endPos : Integer ):Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
06 May 2014			cnwndl1	Initial creation	Par 34076
06 April 2023		jlizm1	TFS 57098 EUP Seal numbers on trucks
18 Dec 2024			navhl20 Bug MTN-33659: MTN - Unable to load cargo items using the complete job form if the checks are configured
*/

vars

	mess : String;
	pos : Integer;
	obj : Object;
	sealType : CM_SealType;
	sealTi : CM_SealTI;
	sealBefore : String;
	sealAfter : String;
	pxySealCheckTrx : CM_SealCheck;
	realSealCheckTrx : CM_SealCheck;
	viewed : Integer;
	truckMode : Boolean;
	pxySealCheckDetails : CM_SealCheckDetailSet;
	pxySealCheckDetail	: CM_SealCheckDetail;
	
begin

	
	if self.sealCheckType &lt;&gt; SEAL_CHECK_VIEW then
		return false;
	endif;
	
	truckMode := self.myVehicleVisit &lt;&gt; null and self.myCargoChecks = null;	//18.12.2024 navhl20 #33659
	
	create pxySealCheckTrx transient;
	create pxySealCheckDetails transient;
	
	foreach pos in startPos to endPos do
		obj := self.tblSeals.accessRow(pos).itemObject;
		if obj &lt;&gt; null then
			if obj.isKindOf( CM_SealType ) then
				//cnwmc5 - 26 Nov 2015 - PAR 37138
				if self.myGTEReceival &lt;&gt; null then
					sealType := obj.CM_SealType;
					sealTi := self.myGTEReceival.getSealTI(sealType);
					sealBefore := null;
				else
					sealTi := null;
					sealType := obj.CM_SealType;
					sealBefore := null;
				endif;
			elseif obj.isKindOf( CM_SealTI ) then
				sealTi := obj.CM_SealTI;
				sealBefore := sealTi.getSealValueAsString;
				sealType := app.myRoot.getSealType(sealTi.sealType);
			endif;
		else
			continue;
		endif;
		sealAfter := sealBefore;	// No provision to change it in this mode.
		if self.tblSeals.accessCell(pos,3).text = "N" then
			// Not viewed
			viewed := CM_SealCheckDetail.Seal_Not_Viewed;
		elseif self.tblSeals.accessCell(pos,2).text = "Y" then
			//viewed
			viewed := CM_SealCheckDetail.Seal_Viewed;
		else
			mess := app.getErrorString3(Must_select, app.getErrorString(Viewed), app.getErrorString(Not_viewed), sealType.description );
			app.msgBox( mess, app.getErrorString(Error) , MsgBox_OK_Only);
			return false;
		endif;
		
		if truckMode then
			pxySealCheckDetail := self.createPxySealCheckDetail(null,	//_sealCheck : CM_SealCheck;
																sealAfter,	//_sealAfter : String;
																sealBefore,	//_sealBefore : String;
																self.sealCheckType,	//_sealCheckType : Integer;
																sealType.sealType,	//_sealType : String;
																viewed	//_viewed : Integer
																);
			pxySealCheckDetails.add(pxySealCheckDetail);
		else
			self.createPxySealCheckDetail( 	pxySealCheckTrx,	//_sealCheck : CM_SealCheck;
											sealAfter,	//_sealAfter : String;
											sealBefore,	//_sealBefore : String;
											self.sealCheckType,	//_sealCheckType : Integer;
											sealType.sealType,	//_sealType : String;
											viewed	//_viewed : Integer
											);
		endif;
		
	endforeach;

	if truckMode then
		return self.createSealChecksForTruck(pxySealCheckDetails, null);
	else
		realSealCheckTrx := self.createSealCheckTransaction(pxySealCheckTrx, null, app.myPassport);
	endif;
	
	return realSealCheckTrx &lt;&gt; null or ( self.myGTEReceival &lt;&gt; null and not self.myGTEReceival.allSealCheckDetails.isEmpty );

epilog

	delete pxySealCheckTrx;
	delete pxySealCheckDetails;

end;</source>
        <Parameter name="startPos" type="Integer"/>
        <Parameter name="endPos" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="queryUnload" id="78615ece-0614-477e-9c35-cc738d73498e">
        <controlMethod name="Form::queryUnload"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>queryUnload(cancel: Integer io; reason: Integer) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 May 2014	cnwndl1	Initial creation	Par 34076
01 Feb 2024	jlizm1	TFS 62142 Perform checks from voyage ops live

*/

vars

begin
	if reason = QueryUnload_UnloadMethod then
		return;
	endif;
	
	if not self.doVerifyChecksComplete then
		cancel := 1;
	endif;

epilog

end;</source>
        <Parameter name="cancel" type="Integer" usage="io"/>
        <Parameter name="reason" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="requiredChecksComplete" id="4b7e8f22-c8d2-4b8b-b4ee-9d5445cbf872">
        <source>requiredChecksComplete() : Boolean;
/*

Purpose:				Determine if all required checks for the current cargo have been completed

Parameters:			

Return Value:		

Date					Who		Reason
07 February 2024		jlizm1	Initial creation TFS 62142 Perform checks from voyage ops live

*/

vars

	index : Integer;
	item : CM_CargoCheckItem;

begin

	foreach index in 1 to self.tblCargoChecks.rows do
		item := self.tblCargoChecks.accessRow(index).itemObject.CM_CargoCheckItem;
		if item = null then
			continue;
		endif;
		if item.required then
			if self.allCargoCheckItemSelections[self.myTrackedItem, self.myGTEReceival, item] = null then
				return false;
			endif;
		endif;
	endforeach;

	return true;

epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="saveCheckItemSelections" id="0b275ac2-b4f2-48bd-87f1-4a2f634d7d6f">
        <updating/>
        <source>saveCheckItemSelections():Boolean updating;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22/05/2014	cnwndl1	Initial creation	Par 33268
20/10/2016	cnwdap1	TFS 2840 A required check with a to do task is not getting processed
22/11/2018  JLGNS1	ChangeRequest 39691: SNO- VGM Gate Process
06/03/2023	jlika1	TFS 56882 - CUX - Transaction for hazardous symbol check in gate checker app.
01/02/2024	jlizm1	TFS 62142 Perform checks from voyage ops live
20 Feb 2024 navhl20 ChangeRequest 62525: EUP | Retrospective Operations - [54177.060] - Cargo &amp; Truck Checks
26 Feb 2024 navbs1  Defect 62566: MTN - Weigh To Do Task on Prenote when VGM weigh details are updated at gate in
10 Jun 2024	jlika1	TFS 64158 CUX | Configurability of Foreman checks for onboard cargo
*/

vars

	startRow 			: Integer;
	endRow 				: Integer;
	row 				: Integer;
	cargoCheck 			: CM_TICargoChecks;
	cargoCheckTemplate 	: CM_CargoCheckItem;
	toDoTaskDesc 		: CM_ToDoTaskDesc;
	toDoTasksToAdd 		: CM_ToDoTaskDescByCode;
	jadeTableCell 		: JadeTableCell;
	addToDo 			: Boolean;								// TFS 2840
	returnValue 		: Boolean;
	setting				: CM_TICargoChecks;

begin

	//need to process the 'todo' selections that were only captured from shtCargoChecks, these will not have been processed. 
	startRow := self.tblCargoChecks.fixedRows + 1;
	endRow := self.tblCargoChecks.rows;
	
	create toDoTasksToAdd transient;
	
	foreach row in startRow to  endRow do
		cargoCheckTemplate := self.tblCargoChecks.accessRow(row).itemObject.CM_CargoCheckItem;
		if cargoCheckTemplate = null or cargoCheckTemplate.myToDoTaskDesc = null then
			continue;
		endif;
		
		
		addToDo := false;															// TFS 2840
		toDoTaskDesc := cargoCheckTemplate.myToDoTaskDesc;
		jadeTableCell := self.tblCargoChecks.accessCell(row, self.ColumnValue);
		setting := self.allCargoCheckItemSelections[self.myTrackedItem,self.myGTEReceival,cargoCheckTemplate];  //26.02.2024 navbs1 #62566
		//if jadeTableCell.inputType = self.tblCargoChecks.InputType_CheckBox then								// TFS 2840
		if jadeTableCell.inputType = self.tblCargoChecks.InputType_CheckBox and jadeTableCell.text = "1" then	// TFS 2840
			addToDo := true;																					// TFS 2840
		elseif setting &lt;&gt; null and setting.selection="Y" and  cargoCheckTemplate.required then					//26.02.2024 navbs1 #62566
			addToDo := true;
		/*
		//26.02.2024 navbs1 #62566
		elseif jadeTableCell.selected and cargoCheckTemplate.required then										// TFS 2840
			addToDo := true;																					// TFS 2840
		*/
		endif;																									// TFS 2840
		if addToDo then	
			//if cargoCheckTemplate.required then										// TFS 2840
			if cargoCheckTemplate.requiredExtraInfo &lt;&gt; null then						// TFS 2840
				//Even though it says add we are completing tasks in this bit because the weighbridge has dealt with it 
				if (self.myTrackedItem &lt;&gt; null and self.myTrackedItem.isPreNote)		//ChangeRequest 39691 jlika1 TFS 56882
				and self.myGTEReceival.myVehicleVisitRecord.hasWeghBridgeVVRD 			//ChangeRequest 39691
				and cargoCheckTemplate.requiredExtraInfo = EXTRA_INFO_WEIGHT then		//ChangeRequest 39691
					self.doToDoTaskComplete(toDoTaskDesc);								//ChangeRequest 39691
				endif;
				// already dealt with by clicking the buttons
				continue;
			endif;
			// TFS 2840
			//if jadeTableCell.text = "1" then																	// TFS 2840
				if not toDoTasksToAdd.includes( toDoTaskDesc ) then
					toDoTasksToAdd.add( toDoTaskDesc );
				endif;
			//endif;																							// TFS 2840
		endif;
	endforeach;

	if toDoTasksToAdd.isEmpty then
		returnValue := true;
	else
		returnValue := self.updateToDoTasks( toDoTasksToAdd );
	endif;
	
	if returnValue then
		if (not shouldShowLocationCheck) or self.confirmLocation then
			app.myTrxUA.trxUpdateTICheckCompleted(self.myCargoChecks.context, true, self.myTrackedItem, self.effectiveDT, app.myPassport);			//20.02.2024 navhl20 #62525
			returnValue := true;
		else
			returnValue := false;
		endif;
	endif;
	
	return returnValue;
	
epilog

	delete toDoTasksToAdd;
	
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="sealMatchesValueFromUser" id="7aea1d60-d924-4555-8ce3-b7fe65899a70">
        <source>sealMatchesValueFromUser( _beforeValue : String; _afterValue : String; _sealTi : CM_SealTI ): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 May 2014	cnwndl1	Initial creation	Par 34076

*/

vars

begin

	if _sealTi &lt;&gt; null then
		// let the seal do the checking. ( covers multi seal options)
		if not _sealTi.matchesValueFromUser( _afterValue ) then
			return false;
		endif;
		
	else
		// no existing seal, can do a direct check.
		if _beforeValue.trimBlanks &lt;&gt; _afterValue.trimBlanks then
			return false;
		endif;
	
	endif;
	
	return true;

epilog

end;</source>
        <Parameter name="_beforeValue" type="String"/>
        <Parameter name="_afterValue" type="String"/>
        <Parameter name="_sealTi" type="CM_SealTI"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setBaseDetails" id="5d38be85-d13f-497f-a5df-30952842a80f">
        <updating/>
        <source>setBaseDetails( _ti : CM_TrackedItem; _gte : CMGTE_Receival; _context : Integer ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 May 2014	cnwndl1	Initial creation	Par 34076

*/

vars

begin

	self.myTrackedItem := _ti;
	self.myGTEReceival := _gte;
	self.myCargoChecks := self.myTerminal.allCargoChecks[_context];

epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_gte" type="CMGTE_Receival"/>
        <Parameter name="_context" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setDefaultLocation" id="aded097f-0819-4b93-9fc1-d986c36451b4">
        <updating/>
        <source>setDefaultLocation(_location : CM_LocationsController) updating;
/*****************************************************
Author		: jlika1 (Karen Alexander)
Date		: 29 May 2024
TFS#		: 64049
Function	:

*** Changes ***
Date			Name		TFS#		Description

****************************************************/
begin
	self.myDefaultLocation := _location;
end;</source>
        <Parameter name="_location" type="CM_LocationsController"/>
    </JadeMethod>
    <JadeMethod name="setEffectiveDT" id="b691f331-90e4-4a75-b5c0-a539041fbad9">
        <updating/>
        <source>setEffectiveDT(_dt : TimeStamp)updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 Feb 2024 navhl20 ChangeRequest 62525: EUP | Retrospective Operations - [54177.060] - Cargo &amp; Truck Checks

*/

vars

begin
	if _dt.isValid then
		self.effectiveDT := _dt;
	endif;
epilog

end;</source>
        <Parameter name="_dt" type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="setMyVehicleVisit" id="6d96f095-ad50-4f74-858f-1bb8f152e81c">
        <updating/>
        <source>setMyVehicleVisit(_vvr : CM_VehicleVisitRecord) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
06 April 2023		jlizm1	Initial creation TFS 57098 EUP Seal numbers on trucks

*/

vars

begin
	self.myVehicleVisit := _vvr;
	
epilog

end;</source>
        <Parameter name="_vvr" type="CM_VehicleVisitRecord"/>
    </JadeMethod>
    <JadeMethod name="setSealsTableForFullMode" id="095d6204-180b-4102-9352-257587df01b8">
        <source>setSealsTableForFullMode( allSealTypes : CM_SealTypeSet; ti : CM_TrackedItem );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 May 2014	cnwndl1	Initial creation	Par 34076

*/

vars

	sealType : CM_SealType;
	index : Integer;
	sealTi : CM_SealTI;

begin

	tblSeals.selectMode := Table.SelectMode_None;
	tblSeals.columns := 2;
	tblSeals.rows := 2;
	
	tblSeals.fixedRows := 2;
	tblSeals.fixedColumns := 1;
	
	tblSeals.accessCell(1,1).mergeCells := Table.MergeCells_Merge;

	tblSeals.setCellText(1,1,app.getErrorString1(Seal_check_mode, app.sealCheckTypeEnumToString(SEAL_CHECK_FULL) ) );
	tblSeals.accessCell(1,1).alignment := Table.Alignment_Center_Middle;
	
	tblSeals.accessRow(2).alignment := Table.Alignment_Left_Middle;
	tblSeals.accessRow(2).fontBold := true;
	tblSeals.setCellText(2,1,app.getErrorString(CM_Type) );
	tblSeals.setCellText(2,2,app.getErrorString(Value) );
	
	foreach sealType in allSealTypes do
	
		index := tblSeals.addItem(sealType.description);
		if ti &lt;&gt; null then
			sealTi := ti.getSealTI(sealType);
		endif;
		
		if sealTi = null then
			tblSeals.accessRow(index).itemObject := sealType;
		else
			if sealType.showSealOnCheck then
				tblSeals.setCellText(index,2,sealTi.getSealValueAsString);
			else
				tblSeals.setCellText(index,2,null);
			endif;
			tblSeals.accessRow(index).itemObject := sealTi;
		endif;
		tblSeals.accessCell(index,2).inputType := Table.InputType_TextBox;
		tblSeals.accessRow(index).height := 24;
		
	endforeach;
	
epilog

end;</source>
        <Parameter name="allSealTypes" type="CM_SealTypeSet"/>
        <Parameter name="ti" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="setSealsTableForNoneMode" id="789a78ba-33ca-46e7-8755-541b851d0276">
        <source>setSealsTableForNoneMode();
/*

Purpose:			

