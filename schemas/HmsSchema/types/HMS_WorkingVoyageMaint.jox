    <JadeMethod name="handleNotification" id="c13102ee-57b6-4a03-8104-ba93eb74e28a">
        <updating/>
        <source>handleNotification(eventType: Integer; theObject: Object; eventTag: Integer) updating;
//--------------------------------------------------
// Created:	19 August 2004 By: cnwgd1
//--------------------------------------------------
// 24/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
vars
	idx : Integer;
	vesselData : HMS_VesselData;
	vessel : CM_Vessel;
begin
	if eventType = Object_Delete_Event then
		if self.myCurrentVessel.String = theObject.String then
			//let user know that the vessel has been deleted
			app.msgBox(app.getErrorString(Selected_Vessel_Deleted), app.getErrorString(VesselDeleted), MsgBox_Stop_Icon + MsgBox_OK_Only);
			self.setMyCurrentVessel(null);
			self.loadSummaryTbl();
		endif;
	elseif eventType = Object_Update_Event then
		if HMS_VesselData.hasInstance(theObject) then
			vesselData := theObject.HMS_VesselData;
			vessel := vesselData.myVessel;
		elseif CM_Vessel.hasInstance(theObject) then
			vessel := theObject.CM_Vessel;
			vesselData := vessel.myHMSVesselData;
		endif;
		if vessel = null then
			return;
		endif;
		
		if self.myCurrentVessel = vessel then
			self.doVesselChangeWorkingVoyage();
			self.loadSummaryTbl();
		endif;

	endif;	
end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="handleNotificationRefreshView" id="0dd384a1-1078-451e-81c0-2c40de2632af">
        <updating/>
        <source>handleNotificationRefreshView(eventType: Integer; theObject: Object; eventTag: Integer; userInfo: Any) updating;

vars

begin
