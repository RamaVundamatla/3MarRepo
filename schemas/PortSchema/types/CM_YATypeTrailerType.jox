    <JadeMethod name="isCMIFDataMatch" id="bb32554e-c161-4437-8d94-4915e4be3f66">
        <source>isCMIFDataMatch(_cmifAutoPlan: CMIF_YAAutoPlan; _yaData: CM_YADataObjects): Boolean;
// -------------------------------------------
// Created 10 May 2005 by cnwdvb1
// -------------------------------------------
begin
	return _cmifAutoPlan.isTrailerType_Match(_yaData);
end;</source>
