    <JadeMethod name="convertTaxGenToByTerminal" id="c762c4fc-bac1-4298-941d-30cc363e6a8a">
        <source>convertTaxGenToByTerminal( _terminal : CM_Terminal; _date : Date ):CM_AutoTaxNumberGen;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 December 2018	jlgndl1	Initial creation	TFS 42614

*/

vars

	year : Integer;
	lastId : Real;
	autoTaxNumberGen : CM_AutoTaxNumberGen;

begin

	year := _date.format("yy").Integer;

	if self.myAutoTaxNumberGen &lt;&gt; null then	
		//converting from a system wide one to a terminal based one.
		if self.myAutoTaxNumberGen.nextSequenceNumArray.size &gt;= year then
			lastId := self.myAutoTaxNumberGen.nextSequenceNumArray[ year ];
		endif;
	endif;
	
	if lastId = 0 then
		lastId := 1;
	endif;

	if process.isInTransactionState then		
		autoTaxNumberGen := self.createMyAutoTaxNumberGen( _terminal );
		if autoTaxNumberGen &lt;&gt; null then
			autoTaxNumberGen.nextSequenceNumArray[ year ] := lastId;
		endif;
	else
		beginTransaction;
		autoTaxNumberGen := self.createMyAutoTaxNumberGen( _terminal );
		if autoTaxNumberGen &lt;&gt; null then
			autoTaxNumberGen.nextSequenceNumArray[ year ] := lastId;
		endif;
		commitTransaction;
	endif;
	
	return autoTaxNumberGen;
	
epilog

end;</source>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_date" type="Date"/>
        <ReturnType type="CM_AutoTaxNumberGen"/>
    </JadeMethod>
    <JadeMethod name="createMyAutoExtReceiptNbrGen" id="f0e4f901-dddf-4afd-a7b8-a65481da6653">
        <source>createMyAutoExtReceiptNbrGen():CM_AutoExternalReceiptGen;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
01 November 2018	jlgma1	Bug 41688: PEL1 - Estimation ID sequence
23 Oct 2024			navlw1	JIRA-33107: Invoice Logging Use Levels
*/

vars
	proxy : CM_AutoExternalReceiptGen;
	real : CM_AutoIdGenerator;
begin

	if self.isTransient then
		return null;
	endif;
	
	create proxy transient;
	proxy.setProxy(	null,
					6,	
					AutoIdStyle_SSS,
					null ,
					1,
					CM_AutoExternalReceiptGen.Reset_On_Year_Chg_Int
					);
	proxy.setPxyOtherAttributes( self );
							
	app.myUtilityCA.utlCreateAutoIdGenerator( proxy, real, app.myPassport );
	
	if app.myPassport.noErrors then
		app.invLog(method.qualifiedName &amp; " External Receipt Number Generator created.", LogTRACE.String);
	else
		app.invLog(method.qualifiedName &amp; " Failed to create Receipt External Number Generator - " &amp; app.myPassport.getAllErrorsWarningsAsString, LogTRACE.String);
	endif;
	
	return real.CM_AutoExternalReceiptGen;
epilog

end;</source>
        <ReturnType type="CM_AutoExternalReceiptGen"/>
    </JadeMethod>
