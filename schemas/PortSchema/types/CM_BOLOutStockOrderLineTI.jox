    <JadeMethod name="validateMe" id="1daea9b4-a85f-485f-9246-f100d5f7a02a">
        <source>validateMe() protected;
// ---------------------------------------------------------------------------
// Created:     17 July 2002 by cnwsb1
// ---------------------------------------------------------------------------
// 15/12/2014  cnwdb2	PAR 35364
vars

begin
	if self.myBOLOut = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'BOLOut', null, null);
		app.raiseCMException(Input_required_field_bolOut, null, null); // cnwdb2	PAR 35364
		
	endif;
	
	if self.myStockOrderLine = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'StockOrderLine', null, null);
		app.raiseCMException(Input_required_field_StkOrdLne, null, null); // cnwdb2	PAR 35364

	endif;

end;</source>
        <access>protected</access>
    </JadeMethod>
</Class>
