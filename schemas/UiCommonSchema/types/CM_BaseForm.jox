        <source>getMoveNoteInfo(_str : String; _ti : CM_TrackedItem output; _anLC : CM_LocationsController output);
// ---------------------------------------------------------------------------
// Created:		13 July 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
/*

Date		Who		Reason
08 Oct 2008	cnwkpd1	PAR #18009 - Prevent transient leaks

*/

