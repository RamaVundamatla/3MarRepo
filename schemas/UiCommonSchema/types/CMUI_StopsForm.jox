    <JadeMethod name="translateForm" id="e3ec825f-7fb4-4c2c-bf0d-825df71efc5a">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 11 March 2019 19:43:43.
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0023298, locale);
	btnClose.translateCaption(Xlat_0023301, locale);
	btnSave.translateCaption(Xlat_0023300, locale);
	btnSaveAndClose.translateCaption(Xlat_0023299, locale);
	cmbOverrideRsons.translateBubbleHelp(Xlat_0018846, locale);
	grpBottom.translateCaption(Xlat_0023302, locale);
	grpTop.translateCaption(Xlat_0015113, locale);
end;</source>
    </JadeMethod>
    <JadeMethod name="unloadFormWithMessage" id="6e3bb80d-f206-431d-9579-695898d0874d">
        <updating/>
        <source>unloadFormWithMessage() protected, updating;
// ---------------------------------------------------------------------------
// Created:     16 June 2010 by cnwcs5
// Purpose:     
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	// display message and close form
	if self.isTIForm then
		app.msgBox (app.getErrorString1(DeletedByAnotherUser, app.getErrorString (CargoItem_Name)), self.caption, MsgBox_OK_Only);
	elseif self.isBOLForm then
		app.msgBox (app.getErrorString1(DeletedByAnotherUser, app.getErrorString (BillOfLading)), self.caption, MsgBox_OK_Only);
	else	
		app.msgBox (app.getErrorString1(DeletedByAnotherUser, app.getErrorString (Item)), self.caption, MsgBox_OK_Only);	
	endif;
	
	self.resetFirstChange;
	self.unloadForm; 
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
</GUIClass>
