    <JadeMethod name="zCoparn_mtrel_dates" id="dd4aa862-fc68-42b4-a20b-05a512b91255">
        <source>zCoparn_mtrel_dates(_sender, _mode, _voyageCode, _vesselName, _consignorCode, _consigneeCode, _release, _grade, _isoType, _quantity :String;
							_reqTS, _estReqTS :TimeStamp; _mt :Character):String protected;
/*
Purpose:	Coparn file for MTY release with additional text (FTX) requirements
Date		Who		Reason
01 December 2011	cnwcs5	Initial creation - CCMS POL 2122 / par 28696 - Empty Releases via COPARN
23/04/2012	cnwcs5	CCMS POL 2172 / par 29480 - coparn release updates
*/
vars
	str, strTS1, strTS2, strRequestDTM	:String;
begin
	strTS2 := _estReqTS.date.format ('yyyyMMdd') &amp; _estReqTS.time.format ('HHmm');
	
	if _reqTS &lt;&gt; null then
		strTS1			:= _reqTS.date.format ('yyyyMMdd') &amp; _reqTS.time.format ('HHmm');
		strRequestDTM 	:= "DTM+133:" &amp; strTS1 &amp; ":203'";
	endif;
	
	str :=  
"UNA:+,? '
UNB+UNOA:1+" &amp; _sender &amp; "+NZPOE+110901:2034+1336'
UNH+133600001+COPARN:D:95B:UN:ITG14'
BGM+12+20110901203403+" &amp; _mode &amp; "'
RFF+BN:" &amp; _release &amp; "'
TDT+20+" &amp; _voyageCode &amp; "+1++MAE:172:20+++9294161:146:11:" &amp; _vesselName &amp; "'
LOC+88+NZPOE:139:6'
LOC+9+NZPOE:139:6'" &amp;
strRequestDTM &amp;
"DTM+201:" &amp; strTS2 &amp; ":203'
NAD+CZ+" &amp; _consignorCode &amp; "+MAERSK NEW ZEALAND LTD'
NAD+CC+" &amp; _consigneeCode &amp; "+MAERSK NEW ZEALAND LTD'
NAD+CA+MAE:172:20'
GID+1'
FTX+AAA+++FOOD PRODUCTS'
EQD+CN++" &amp; _isoType &amp; ":102:5+2+2+" &amp; _mt &amp;"'
RFF+BN:" &amp; _release &amp; "'
EQN+" &amp; _quantity &amp; "'
TMD+3++2'
LOC+7+AUSYD:139:6'
LOC+98+NZPOE:139:6'
LOC+11+NZAKL:139:6'
MEA+AAE+G+KGM:1000'
MEA+AAE+T+KGM:2500'
MEA+AAE+EGW+KGM:3500'
FTX+QQD++" &amp; _grade &amp; "'
TDT+30+1120+1++MAE:172:20+++9332705:146:11:MAERSK RADFORD'
LOC+11+AUSYD:139:6'
CNT+16:1'
UNT+26+133600001'
UNZ+1+1336'";

	return str;
epilog

end;</source>
