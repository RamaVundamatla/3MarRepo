		pCmb.listCollection(_operator.allStockOrderHeaders, true, 0);
	endif;
	
	if _header &lt;&gt; null then
		pCmb.text := self.displayEntryStockOrderHeader(_header);
		pCmb.listObject := _header;
	endif;
	
end;</source>
        <Parameter name="pCmb" type="ComboBox" usage="input"/>
        <Parameter name="_operator" type="CM_Operator"/>
        <Parameter name="_header" type="CM_StockOrderHeader"/>
    </JadeMethod>
    <JadeMethod name="comboBoxStopCharging" id="bced70e2-7c37-4bca-bdd2-4ad2d19408cb">
        <source>comboBoxStopCharging(_comboboxObj:CMUI_ComboBox input; _selection:String);
// --------------------------------------------------------------------------------
// Created:		25 August 2006 by cnwdad1
//
// Purpose:		Populates the specified combobox control with CM_Terminal class
//				constants for "Stop Charging At" values.
//
// Parameters:	_comboboxObj - A referrence to the combobox to populate.
//				_selection - The current selection item.
//
// Returns:		The populated combobox control parameter.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	listPointer	: Integer;
	
begin
	_comboboxObj.clear();
	_comboboxObj.addItem(app.getErrorString(Complete_Load_Discharge));
	_comboboxObj.addItem(app.getErrorString(Sail));
	
	if _selection &lt;&gt; null then
		listPointer	:=	_comboboxObj.findStringExact(1, _selection);
		
		if listPointer &lt;&gt; CNEC_NULL_INDEX then
			_comboboxObj.listIndex	:=	listPointer;
		endif;
	endif;
end;</source>
        <Parameter name="_comboboxObj" type="CMUI_ComboBox" usage="input"/>
        <Parameter name="_selection" type="String"/>
    </JadeMethod>
