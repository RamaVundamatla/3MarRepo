    <JadeMethod name="getIsReefer" id="6e3de55c-1aed-4d89-964c-26b8f451937f">
        <source>getIsReefer() : Boolean;
/*
Purpose:			

Date		Who		Reason
30 May 2022	navab1	TFS 53105
*/

vars
	commodity : CM_Commodity;
begin
	commodity := self.getMyCommodity();
	if commodity &lt;&gt; null 
       and commodity.hasTemp then
		return true;
	elseif self.myCargoType &lt;&gt; null then
		return self.myCargoType.isReefer();
	endif;
end;
</source>
