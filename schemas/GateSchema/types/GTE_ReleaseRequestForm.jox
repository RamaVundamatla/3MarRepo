    <JadeMethod name="doThumbnailDClick" id="8e505b92-1611-40a1-a016-1915963d4427">
        <source>doThumbnailDClick();
// ---------------------------------------------------------------------------
// Created:		March 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	found 			: Boolean;
	table 			: Table;
	cellValue,tiID 	: String;
	theTI 			: CM_TrackedItem;
	strPos, row		: Integer;
	tiSet 			: CM_TISet;
	
	objArray : CM_ObjectArray;
	
begin
	table := self.tblThumb;
	if table.row &lt; 1 then // PAR 10308
		return;
	endif;
		
	cellValue := table.accessCell(table.row,CM_EntryTable.ColumnHeading).text;
	row := table.row;
	while cellValue = null and row &gt; 1 do
		row 		:= row -1;
		cellValue 	:= table.accessCell(row, CM_EntryTable.ColumnHeading).text;
	endwhile;

	// ### GET THE TI AND SHOW ENQUIRY
		
	if cellValue = "Attachments" 
	or cellValue = "Allocated Items" then
		//tiID := table.accessCell(table.row, CM_EntryTable.ColumnValue).text[1:11];
		/*
		strPos	:= 1;
		tiID 	:= table.accessCell(table.row, CM_EntryTable.ColumnValue).text.scanUntil(" ", strPos);
		if tiID &lt;&gt; null then
			// ### ONSITE
			theTI := self.myTerminal.allOnsiteTIsByIdCargoType.getAtKeyGeq(tiID,0);
			if theTI &lt;&gt; null and theTI.id = tiID then
				self.myAssistant.showCargoEnquiryForm(theTI, self.myMasterMenuAction, true, false);
			else
				// ### OFFSITE
				theTI := self.myTerminal.allOffsiteTIsByIdCargoType.getAtKeyGeq(tiID,0,null);
				if theTI &lt;&gt; null and theTI.id = tiID then
					self.myAssistant.showCargoEnquiryForm(theTI, self.myMasterMenuAction, true, false);		
				endif;
			endif;
		endif;
		*/
		
		//01 Apr 2016	NDL	TFS 1760
		if self.myCurrentObject.isKindOf(CM_BulkRelease) then
			tiSet := self.myCurrentObject.CM_BulkRelease.allTrackedItemsAssigned;
		elseif self.myCurrentObject.isKindOf(CM_ReserveDetail) then
			tiSet := self.myCurrentObject.CM_ReserveDetail.myReserveHeader.allTrackedItemsAssigned;
		endif;
		
	// 30/09/2009 cnwar2 #20745
	elseif cellValue = "Items Delivered" then
/*		//tiID := table.accessCell(table.row, CM_EntryTable.ColumnValue).text[1:11];
		strPos	:= 1;
		tiID 	:= table.accessCell(table.row, CM_EntryTable.ColumnValue).text.scanUntil(" ", strPos);
		if tiID &lt;&gt; null then
			// check bulk release first
			tiSet := self.myCurrentObject.CM_BulkRelease.allTrackedItemsReleased;
			foreach theTI in tiSet do
				if theTI.id = tiID then
					found := true;
					break;
				endif;
			endforeach;
			if not found then	// check offsite cargo
				theTI := self.myTerminal.allOffsiteTIsByIdCargoType.getAtKeyGeq(tiID,0,null);
			endif;
			if theTI &lt;&gt; null and theTI.id = tiID then
				self.myAssistant.showCargoEnquiryForm(theTI, self.myMasterMenuAction, true, false);
			endif;
		endif; */
		
		//01 Apr 2016	NDL	TFS 1760
		if self.myCurrentObject.isKindOf(CM_BulkRelease) then
			tiSet := self.myCurrentObject.CM_BulkRelease.allTrackedItemsReleased;
		elseif self.myCurrentObject.isKindOf(CM_ReserveDetail) then
			tiSet := self.myCurrentObject.CM_ReserveDetail.myReserveHeader.allTrackedItemsReleased;
		endif;
		
		
	endif;
	
	//01 Apr 2016	NDL	TFS 1760
	if tiSet = null or tiSet.isEmpty then
		return;
	endif;
	create objArray transient;
	tiSet.copy(objArray);
	theTI := objArray.first.CM_TrackedItem;
	self.myAssistant.showCargoEnquiryForTIs(theTI, objArray, self.myMasterMenuAction, false);
	
epilog

	
	
end;</source>
    </JadeMethod>
    <JadeMethod name="doViewEDIMessages" id="e9a68da0-a823-4267-b877-22027ff23df6">
        <source>doViewEDIMessages() protected;
/*
Date		Who		Reason
24 Nov 2011	cnwcs5	Initial creation - CCMS POL 2122 / par 28696 - Empty Releases via COPARN
07/11/2011	cnwrs1	CCMS POL 2122 / PAR 28696 - new property allEDIFiles
*/
vars
	obj		:Object;
	br		:CM_BulkRelease;
	form	:CMUI_EDIMessagesForm;
begin
	obj := self.myCurrentObject; 
	
	if CM_BulkRelease.hasInstance(obj) then
		br := obj.CM_BulkRelease;
	elseif CM_ReserveDetail.hasInstance(obj) then
		br := obj.CM_ReserveDetail.myReserveHeader;
	endif;
	
	if br = null or br.allEDIFiles.isEmpty then
		return;
	endif;
	
	create form;
	
	// use method so any deleted files don't get copied
	br.getAllEDIFiles(form.allEDIFiles);
	
	form.textToHightlight	:= br.code;

	form.show;
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="exitForm" id="41fbcdcf-39cd-48ff-9f84-51a3cd741f1d">
        <updating/>
        <source>exitForm() updating;
// ---------------------------------------------------------------------------
// Created:		12 October 2005  By Andrew Bishop cnwab1
//
// Purpose:		
