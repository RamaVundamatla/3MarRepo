    <JadeMethod name="selectCargoItem" id="d3c1a943-d8f0-4d3d-8078-e70366bfc0f3">
        <updating/>
        <source>selectCargoItem( _manual : Boolean ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 May 2013	cnwndl1	Initial creation	Par 31506

*/

vars

	cargoId : String;
	term : CM_Terminal;
	firstTi : CM_TrackedItem;
	tiArray : CM_TIArray;
	iter : Iterator;
	ti : CM_TrackedItem;
	errMsg : String;
		
	cargoIdLength : Integer;	
		
	msg : String;
	
begin

	

	cargoId := txtCargoId.text.trimBlanks.toUpper;
	if cargoId = lblCargoId.caption.toUpper then
		cargoId := null;
	endif;
	
	self.setMyTrackedItem( null );
	
	term := self.myMobileDataAgent.myTerminal;
	
	create tiArray transient;
	
	if cargoId &lt;&gt; null then
	
		cargoIdLength := cargoId.length;	
		
		firstTi := term.allOnsiteTIsByIdCargoType.getAtKeyGeq(cargoId,null);
		if firstTi &lt;&gt; null and firstTi.id[1:cargoIdLength] = cargoId then	
			iter := term.allOnsiteTIsByIdCargoType.createIterator;
			iter.startAtObject(firstTi);
			while iter.next( ti ) do
				if ti.id[1:cargoIdLength] &lt;&gt; cargoId then
					break;
				endif;
				if ti.id &lt;&gt; cargoId then
					//to select, must be an exact match
					continue;
				endif;
				tiArray.addExclusive(ti);
			endwhile;
			delete iter;
		endif;
		
		
	endif;
		
	if tiArray.size = 1 then
		self.setMyTrackedItem( tiArray.first );
		return;
		
	elseif tiArray.size &gt; 1 then
		msg := app.getErrorString1( UniqueIdRequired, cargoId.trimBlanks);
		self.msgBox(msg, app.getErrorString(Warning), MsgBox_OK_Only, true);
	else
		msg := app.getErrorString1(Cargo_item_not_found_site, cargoId.trimBlanks);
		self.msgBox(msg, app.getErrorString(Warning), MsgBox_OK_Only, true);
	endif;
	

epilog

	delete tiArray;
	delete iter;

end;</source>
        <Parameter name="_manual" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setMoveEnabledDisabled" id="1a9b44ff-5eb1-42ed-8c4e-0238616531de">
        <updating/>
        <source>setMoveEnabledDisabled() updating, protected;
// ---------------------------------------------------------------------------
// Created:	13 January 2009 By Graeme Black cnwgb1
// Purpose:	Enables the Move button if there is enough information to do
//			a move (There is a tracked item and a target location )
//			PNL CCMS 1658 PAR 18787
// ---------------------------------------------------------------------------
vars

begin

	if self.myTrackedItem &lt;&gt; null and self.txtTargLocn.text &lt;&gt; null then
		self.btnOne.enabled := true;
	
	else
		self.btnOne.enabled := false;
		
	endif;
	
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setMyTrackedItem" id="33ce1483-4b97-451b-8886-4ec618ff4bc5">
        <updating/>
        <source>setMyTrackedItem( _ti : CM_TrackedItem ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 May 2013	cnwndl1	Initial creation	Par 31506

*/

vars

begin

	self.getSessionAgent().setMySelectedTI( _ti );
	app.myMobileCargoFindAgent.setMyTrackedItemToProcess( null );
	self.myTrackedItem := _ti;
	self.displayCurrentLocation();
	self.setMoveEnabledDisabled();
	
	if self.myTrackedItem &lt;&gt; null then
		self.btnDamage.enabled := true;
		self.btnLabel.enabled := true;
		self.txtCargoId.text := self.myTrackedItem.id;
		
	else
		self.btnDamage.enabled := false;
		self.btnLabel.enabled := false;
		self.txtCargoId.text := self.lblCargoId.caption.toUpper;
		
	endif;
	
epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="setupControls" id="b1fcaae9-8dbe-4b3d-b2da-4010e9e84f41">
        <updating/>
        <source>setupControls() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 May 2013	cnwndl1	Initial creation

*/

vars

	lc : CM_LocationsController;
	ta : CM_TerminalArea;
	taType : CM_TerminalAreaType;

begin
						
	self.doResizeControls(true);
	
	self.chkCharge.value := false;

	self.handleAreaTypeSelect();
	self.handleAreaSelect();
	
	self.displayCurrentLocation();
	self.setMoveEnabledDisabled();
	
	//16 Mar 2016	NDL	TFS 1593
	if self.myMobileGenericAgent.myLocationsController &lt;&gt; null then
		lc := self.myMobileGenericAgent.myLocationsController;
		ta := lc.getMyTerminalArea;
		if ta &lt;&gt; null then
			taType := ta.myType;
			if taType &lt;&gt; null then
				self.cmbAreaType.listIndex := self.cmbAreaType.findObject( taType );
				self.handleAreaTypeSelect();
			endif;
			self.cmbTerminalArea.listIndex := self.cmbTerminalArea.findObject( ta );
			self.handleAreaSelect();
		endif;
		self.cmbYardLocation.listIndex := self.cmbYardLocation.findObject( lc );
		self.handleYardLocationSelect();
		self.myMobileGenericAgent.setMyLocationsController( null );
	endif;
	
	self.txtCargoId.lostFocus(self.txtCargoId);
	self.txtCargoId.setFocus;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setupForm" id="cd8b1ba1-f13a-4d1c-a70c-034a4d3b5017">
        <updating/>
        <source>setupForm() updating, protected;
// ---------------------------------------------------------------------------
// Created:	09 January 2009 By Graeme Black cnwgb1
// Purpose:	Basic form setup 
//			PNL CCMS 1658 PAR 18787
// ---------------------------------------------------------------------------
vars

	ti : CM_TrackedItem;
	
begin

	if app.myMobileCargoFindAgent = null then
		create app.myMobileCargoFindAgent transient;
	endif;
	
	self.myHandHeldCheckerAgent := app.myHandHeldCheckerAgent;
	
	self.myLocale := app.myCurrentLocale;
	if self.myLocale = null then
		self.myLocale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
	endif;
	
	ti := self.getSessionAgent().mySelectedTI;
	
	self.setupCmdButtons( 2, app.getErrorString(Move), BACK_BUTTON, null, null, null );
	
	inheritMethod();
	
	self.setupControls();
	
	if ti &lt;&gt; null then
		self.setMyTrackedItem( ti );
	endif;
		
epilog
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setupMenu" id="6546d9ab-ea1e-4c2b-a96b-acb08615a487">
        <updating/>
        <source>setupMenu() updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
24 March 2011	cnwndl1	Initial creation	Par 27277

*/

vars

	passport : CM_Passport;
	term : CM_Terminal;
	
begin

	passport := app.myPassport;
	term := passport.myTerminal;
	
	if not app.myCurrentUserCan(term, PmHHGrading) then
		self.mnuGrades.visible := false;
	endif;
	if not app.myCurrentUserCan(term, PmHHMaintainStops) then
		self.mnuStops.visible := false;
	endif;
	if not app.myCurrentUserCan(term, PmHHMaintainTasks) then
		self.mnuTasks.visible := false;
	endif;
	
	self.isMenuItemsVisible := self.mnuStops.visible or
								self.mnuTasks.visible or
								self.mnuGrades.visible;
							
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="translateForm" id="bfbc0374-b6c9-4409-92de-47518ce1972f">
        <updating/>
        <source>translateForm(locale : CM_Locale) updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 03 March 2016.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	
begin
	// Determine the locale for translations.
	inheritMethod(locale);
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0021187, locale);
	btnDamage.translateCaption(Xlat_0021188, locale);
	btnLabel.translateCaption(Xlat_0021189, locale);
	chkCharge.translateCaption(Xlat_0021190, locale);
	lblCargoId.translateCaption(Xlat_0021191, locale);
	lblCurLocation.translateCaption(Xlat_0021192, locale);
	lblDamage.translateCaption(Xlat_0021193, locale);
	lblSelectTarget.translateCaption(Xlat_0021194, locale);
	lblTargLocn.translateCaption(Xlat_0021195, locale);
	lblTerminalArea.translateCaption(Xlat_0021196, locale);
	lblYardLocation.translateCaption(Xlat_0021197, locale);
	mnuContext.translateCaption(Xlat_0021198, locale);
	mnuGrades.translateCaption(Xlat_0021199, locale);
	mnuStops.translateCaption(Xlat_0021200, locale);
	mnuTasks.translateCaption(Xlat_0021201, locale);
end;</source>
        <Parameter name="locale" type="CM_Locale"/>
    </JadeMethod>
    <JadeMethod name="txtCargoId_gotFocus" id="3620eca0-3eb0-463a-922c-43c343cb26d3">
        <controlMethod name="TextBox::gotFocus"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>txtCargoId_gotFocus(textbox: TextBox input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 May 2013	cnwndl1	Initial creation	Par 51506

*/

vars

begin
	
	//cnwmc5 - PAR 32517 - commented out the 'if' statement
	//if self.txtCargoId.text = self.lblCargoId.caption.toUpper then
		self.txtCargoId.selStart := 0;
		self.txtCargoId.selLength := self.lblCargoId.caption.length;
	//endif;

epilog

end;</source>
        <Parameter name="textbox" type="TextBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="txtCargoId_lostFocus" id="fe920120-7989-4068-b0fa-d76400c36373">
        <controlMethod name="TextBox::lostFocus"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>txtCargoId_lostFocus(textbox: TextBox input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 May 2013	cnwndl1	Initial creation		Par 51506

*/

vars

begin

	app.convertScannedCargoId( self.myTerminal, textbox, false, null );	//05 Jul 2016	NDL	TFS 2275

	if self.txtCargoId.text.trimBlanks = null then
		self.txtCargoId.text := self.lblCargoId.caption.toUpper;
	else
		if ( self.myTrackedItem &lt;&gt; null and self.myTrackedItem.id &lt;&gt; self.txtCargoId.text )
		or ( self.myTrackedItem = null and self.txtCargoId.text &lt;&gt; self.lblCargoId.caption.toUpper )
		then
			self.selectCargoItem( false );
		endif;
	endif;
	
	self.txtCargoId.selStart := 0;
	self.txtCargoId.selLength := 0;
epilog

end;</source>
        <Parameter name="textbox" type="TextBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="txtTargLocn_change" id="0bc8a847-ebef-4e09-9e95-8d9dc5c3a2e5">
        <controlMethod name="TextBox::change"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>txtTargLocn_change(textbox: TextBox input) updating;
// ---------------------------------------------------------------------------
// Created:	13 January 2009 By Graeme Black cnwgb1
// Status: 	Unfinished
// Purpose:	
// ---------------------------------------------------------------------------
vars
begin
	self.cmbAreaType.listIndex := 1;
	self.cmbTerminalArea.clear();
	self.cmbYardLocation.clear();
	self.setMoveEnabledDisabled();
	
epilog
end;</source>
