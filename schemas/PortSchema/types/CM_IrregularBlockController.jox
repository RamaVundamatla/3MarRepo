    <JadeMethod name="pxyCreateUpdateProxy" id="cc8f01ec-2c95-47d4-89c9-18360d43ed53">
        <source>pxyCreateUpdateProxy(): SelfType;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 August 2013	cnwndl1	Initial creation

*/

vars

	proxyYardController : CM_IrregularBlockController;
	completedOK		: Boolean;
	lc : CM_IrregularBlockController;
	proxyIrrSubBlockCont : CM_RackShelfController;
	
begin
	
	proxyYardController := inheritMethod();
	proxyYardController.myAssociatedInterchangeArea := self.myAssociatedInterchangeArea;
	
	foreach lc in self.allSubLocations do
		proxyIrrSubBlockCont := lc.pxyCreateUpdateProxy.CM_RackShelfController;
		proxyIrrSubBlockCont.setMyLocation(proxyYardController);
	endforeach;
	
	completedOK := true;			
	return proxyYardController;
		
epilog

	if not completedOK then	
		delete proxyYardController;
	endif;	

end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
