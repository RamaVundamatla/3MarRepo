    <JadeMethod name="getAftSlotRequest" id="02dc6b16-afb2-46cf-b249-041a333a128f">
        <source>getAftSlotRequest() : CM_SlotRequest;
/*
------------------------------------------------------------------------
Created:			07 March 2003 by cnwdwq1
Purpose:			Dave Q's code
Parameters:		
Returns:			
Changed On		Changed By		Reason
------------	------------	-----------------------------------------
29/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls														
------------------------------------------------------------------------
*/
vars
	sc : CM_SlotController;
begin
	if self.mySlotController = null then
		return null;
	endif;
	sc := self.mySlotController.myAftSlotInHold(); //myAftSlot; AKB2003MAY
	if sc = null then
		return null;
	endif;
	
	if self.isDischarge then
		return sc.mySlotRequestDischarge;
	else
		return sc.mySlotRequestLoad;
	endif;
end;</source>
        <ReturnType type="CM_SlotRequest"/>
    </JadeMethod>
    <JadeMethod name="getAllDrawingIcons" id="d8dab850-e6fa-43c8-ba8b-af37bd2a46eb">
        <source>getAllDrawingIcons(_array : StringArray input;
					_maxIcons : Integer);  // 11/10/2022	navkc1	#54935
// ---------------------------------------------------------------------------
// Created:		July 2003 By Andrew Bishop cnwab1
//
// Purpose:		
// 11/10/2022	navkc1	Bug 54935: MSL - Roro planning - Slow on big decks/large vessels // 11/10/2022	navkc1	#54935
// ---------------------------------------------------------------------------
vars

	is40or45or53 : Boolean;
	motorDir : Integer;
begin

	inheritMethod(_array, _maxIcons);
	
	//09 Apr 2010 NDL	Par 22526
	if self.getAttrIs40() then
		is40or45or53 := true;
	elseif self.getAttrIs45() then
		is40or45or53 := true;
	elseif self.getAttrIs53() then
		is40or45or53 := true;
	endif;

	if self.isLoad then
		if self.doorsDirection = TI_DOORSDIRN_FWD then
			//if self.getAttrIs40() then
			if is40or45or53 then	//09 Apr 2010 NDL	Par 22526
				_array.add(PicTIDoorsFwd40);
			else
				_array.add(PicTIDoorsFwd);
			endif;
		elseif self.doorsDirection = TI_DOORSDIRN_AFT then
			//if self.getAttrIs40() then
			if is40or45or53 then	//09 Apr 2010 NDL	Par 22526
				_array.add(PicTIDoorsAft40);
			else
				_array.add(PicTIDoorsAft);
			endif;
		endif;
		//epr TFS 7006 29/9/17
		motorDir :=self.getMotorDirection();
		if motorDir = Motor_Forward then
			if is40or45or53 then	//09 Apr 2010 NDL	Par 22526
				_array.add(PicTIMotorFwd40);
			else
				_array.add(PicTIMotorFwd);
			endif;
		elseif motorDir = Motor_Aft then
			if is40or45or53 then	//09 Apr 2010 NDL	Par 22526
				_array.add(PicTIMotorAft40);
			else
				_array.add(PicTIMotorAft);
			endif;
		endif;
	endif;
end;</source>
        <Parameter name="_array" type="StringArray" usage="input"/>
        <Parameter name="_maxIcons" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getAllDrawingIconsArray" id="548fbdcf-1dbb-4ac7-8f8e-0655fd7bc5c7">
        <source>getAllDrawingIconsArray(): String;
// ---------------------------------------------------------------------------
// Created:		July 2003 By Andrew Bishop cnwab1
//
// Purpose:		
// ---------------------------------------------------------------------------
vars
	rtnStr		: String;
	is40or45or53 : Boolean;
begin

	//09 Apr 2010 NDL	Par 22526
	if self.getAttrIs40() then
		is40or45or53 := true;
	elseif self.getAttrIs45() then
		is40or45or53 := true;
	elseif self.getAttrIs53() then
		is40or45or53 := true;
	endif;
	
	if self.isLoad then
		if self.doorsDirection = TI_DOORSDIRN_FWD then
			//if self.getAttrIs40() then
			if is40or45or53 then //09 Apr 2010 NDL	Par 22526
				rtnStr := rtnStr &amp; "," &amp; PicTIDoorsFwd40;
			else
				rtnStr := rtnStr &amp; "," &amp; PicTIDoorsFwd;
			endif;
		elseif self.doorsDirection = TI_DOORSDIRN_AFT then
			//if self.getAttrIs40() then
			if is40or45or53 then //09 Apr 2010 NDL	Par 22526
				rtnStr := rtnStr &amp; "," &amp; PicTIDoorsAft40;
			else
				rtnStr := rtnStr &amp; "," &amp; PicTIDoorsAft;
			endif;
		endif;
		
	/*	if self.motorDirection = Motor_Forward then
			//if self.getAttrIs40() then
			if is40or45or53 then //09 Apr 2010 NDL	Par 22526
				rtnStr := rtnStr &amp; "," &amp; PicTIMotorFwd40;
			else
				rtnStr := rtnStr &amp; "," &amp; PicTIMotorFwd;
			endif;
		elseif self.motorDirection = Motor_Aft then
			//if self.getAttrIs40() then
			if is40or45or53 then //09 Apr 2010 NDL	Par 22526
				rtnStr := rtnStr &amp; "," &amp; PicTIMotorAft40;
			else
				rtnStr := rtnStr &amp; "," &amp; PicTIMotorAft;
			endif;
		endif;*/
	endif;
	return 	rtnStr;

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getAllDrawingIconsXML" id="f46d5994-d782-44aa-ab99-9a4d0baeeda3">
        <source>getAllDrawingIconsXML() : String;
// ---------------------------------------------------------------------------
// Created:		July 2003 By Andrew Bishop cnwab1
//
// Purpose:		
// 11/10/2022	navkc1	Bug 54935: MSL - Roro planning - Slow on big decks/large vessels
// ---------------------------------------------------------------------------
vars
	theArray : StringArray;
	aString , theXMLString : String;
begin
	if self.isLoad then
	
		create theArray transient;

		//self.getAllDrawingIcons(theArray);
		self.getAllDrawingIcons(theArray, 0);  // 11/10/2022	navkc1	#54935
		
		foreach aString in theArray do
			theXMLString := theXMLString &amp; "&lt;at&gt;" &amp; aString &amp; "&lt;/at&gt;";
		endforeach;
	endif;
	return theXMLString;	
epilog
	delete theArray;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
