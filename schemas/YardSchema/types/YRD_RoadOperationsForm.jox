        <updating/>
        <source>showHideFinder() updating, protected;
/*

Purpose:			


Return Value:		


Date		Who		Reason
22 August 2006	cnwer1	Initial creation - PAR#xxxx

*/
vars

begin
	//self.lastSearchObject:=null;
	self.btnFindNext.enabled := false;
	
