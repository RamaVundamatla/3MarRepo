    <JadeMethod name="checkOpsViewJSON" id="349c6311-e56f-4b5e-8a38-8705f3fda1b9">
        <source>checkOpsViewJSON(_activityHistory : CM_EWSActivityOpsview; _type : String; _object : CM_Object);
/*
Purpose:			

Date		Who		Reason
10 November 2021	navab1	TFS 51853
*/

vars
	jsonPos : Integer;
	agent : CMIF_OpsViewTables;
	gkey : Integer64;
	json : String;
begin
	json := _activityHistory.request;
	
	create agent transient;
	jsonPos := json.pos("allTableData",1);
	self.assertTrueMsg(jsonPos &gt; 1, "TYPE: " &amp; _type &amp; " allTableData MISSING from JSON");
	
	jsonPos := json.pos(_activityHistory.sequence.String,1);
	self.assertTrueMsg(jsonPos &gt; 1, "TYPE: " &amp; _type &amp; " Sequence number is MISSING from JSON");
	

	if _type  = BGP_OpsViewWSRequest.OPS_TYPE_VOYAGE then
		agent.setPropertyValue("termOid", _object.getMyTerminal.getOidAsString());
	
		jsonPos := json.pos("argo_carrier_visit",1);
		self.assertTrueMsg(jsonPos &gt; 1, "TYPE: " &amp; _type &amp; " argo_carrier_visit MISSING from JSON");

		jsonPos := json.pos("atd",1);
		self.assertTrueMsg(jsonPos &gt; 1, "TYPE: " &amp; _type &amp; " atd MISSING from JSON");

		jsonPos := json.pos("carrier_mode",1);
		self.assertTrueMsg(jsonPos &gt; 1, "TYPE: " &amp; _type &amp; " carrier_mode MISSING from JSON");

		jsonPos := json.pos("argo_visit_details",1);
		self.assertTrueMsg(jsonPos &gt; 1, "TYPE: " &amp; _type &amp; " argo_visit_details MISSING from JSON");

		jsonPos := json.pos("classification",1);
		self.assertTrueMsg(jsonPos &gt; 1, "TYPE: " &amp; _type &amp; " classification MISSING from JSON");

		jsonPos := json.pos("DEEPSEA",1);
		self.assertTrueMsg(jsonPos &gt; 1, "TYPE: " &amp; _type &amp; " DEEPSEA MISSING from JSON");

		jsonPos := json.pos("facilityId",1);
		self.assertTrueMsg(jsonPos &gt; 1, "TYPE: " &amp; _type &amp; " facilityId MISSING from JSON");

		gkey := agent.generateFullGKey(_object, "");
		jsonPos := json.pos(gkey.String,1);
		self.assertTrueMsg(jsonPos &gt; 1, "TYPE: " &amp; _type &amp; " voyage gkey MISSING from JSON");
	elseif _type  = BGP_OpsViewWSRequest.OPS_TYPE_JOB then
		agent.setPropertyValue("termOid", _object.getMyTerminal.getOidAsString());

		gkey := agent.generateFullGKey(_object, "");
		jsonPos := json.pos(gkey.String,1);
		self.assertTrueMsg(jsonPos &gt; 1, "TYPE: " &amp; _type &amp; " job gkey MISSING from JSON");
	
		if _object.isKindOf(CM_VoyageJob) then
			jsonPos := json.pos(_object.CM_VoyageJob.myVoyage.code,1);
			self.assertTrueMsg(jsonPos &gt; 1, "TYPE: " &amp; _type &amp; " Voyage code MISSING from JSON");
		elseif _object.isKindOf(CM_RoadJob) then
			if _activityHistory.dataAction &lt;&gt; BGP_OpsViewWSRequest.OPS_ACTION_DELETE then
				jsonPos := json.pos(_object.CM_RoadJob.myVehicle.code,1);
				self.assertTrueMsg(jsonPos &gt; 1, "TYPE: " &amp; _type &amp; " Truck code MISSING from JSON");
			endif;
		endif;
		
		jsonPos := json.pos("xps_craneshift",1);
		self.assertTrueMsg(jsonPos &gt; 1, "TYPE: " &amp; _type &amp; " xps_craneshift MISSING from JOB JSON");
	
		jsonPos := json.pos("inv_wq",1);
		self.assertTrueMsg(jsonPos &gt; 1, "TYPE: " &amp; _type &amp; " inv_wq MISSING from JSON");
	
		jsonPos := json.pos("first_shift_gkey",1);
		self.assertTrueMsg(jsonPos &gt; 1, "TYPE: " &amp; _type &amp; " first_shift_gkey MISSING from JSON");
	
		jsonPos := json.pos("JOB",1);
		self.assertTrueMsg(jsonPos &gt; 1, "TYPE: " &amp; _type &amp; " 'JOB' MISSING from JSON");
	
		jsonPos := json.pos('"facilityId":"UT"',1);
		self.assertTrueMsg(jsonPos &gt; 1, "TYPE: " &amp; _type &amp; " facilityId UT MISSING from JSON");
	
		jsonPos := json.pos('"tableName":"xps_craneshift"',1);
		self.assertTrueMsg(jsonPos &gt; 1, "TYPE: " &amp; _type &amp; " tableName xps_craneshift MISSING from JSON");
	
		jsonPos := json.pos('"tableName":"xps_pointofwork"',1);
		self.assertTrueMsg(jsonPos &gt; 1, "TYPE: " &amp; _type &amp; " tableName xps_pointofwork MISSING from JOB JSON");

		jsonPos := json.pos('"updateType":"JOB"',1);
		self.assertTrueMsg(jsonPos &gt; 1, "TYPE: " &amp; _type &amp; " updateType JOB MISSING from JSON");
	elseif _type  = BGP_OpsViewWSRequest.OPS_TYPE_WLE then
		agent.setPropertyValue("termOid", _object.getMyTerminal.getOidAsString());

		gkey := agent.generateFullGKey(_object, "");
		jsonPos := json.pos(gkey.String,1);
		self.assertTrueMsg(jsonPos &gt; 1, "TYPE: " &amp; _type &amp; " wle gkey MISSING from JSON");
		
		if _object.isKindOf(CM_VoyageWLE) then
			jsonPos := json.pos('"carrier_loctype":"VESSEL"',1);
			self.assertTrueMsg(jsonPos &gt; 1, "TYPE: " &amp; _type &amp; " carrier_loctype VOYAGE MISSING from JSON");
	
			if _object.CM_WorkListEntry.isReceipt then
				jsonPos := json.pos('"move_kind":"DSCH"',1);
				self.assertTrueMsg(jsonPos &gt; 1, "TYPE: " &amp; _type &amp; " move_kind DSCH MISSING from JSON");
			else
				jsonPos := json.pos('"move_kind":"LOAD"',1);
				self.assertTrueMsg(jsonPos &gt; 1, "TYPE: " &amp; _type &amp; " move_kind LOAD MISSING from JSON");

			endif;
		elseif _object.isKindOf(CM_YardWLE) then
			if _object.CM_WorkListEntry.isRoad() then
				jsonPos := json.pos('"carrier_loctype":"TRUCK"',1);
				self.assertTrueMsg(jsonPos &gt; 1, "TYPE: " &amp; _type &amp; " carrier_loctype TRUCK MISSING from JSON");
				if _object.CM_WorkListEntry.isReceipt then
					jsonPos := json.pos('"move_kind":"RECV"',1);
					self.assertTrueMsg(jsonPos &gt; 1, "TYPE: " &amp; _type &amp; " move_kind RECV MISSING from JSON");
				else
					jsonPos := json.pos('"move_kind":"DLVR"',1);
					self.assertTrueMsg(jsonPos &gt; 1, "TYPE: " &amp; _type &amp; " move_kind DLVR MISSING from JSON");

				endif;
			endif;
		endif;
	
		
		jsonPos := json.pos('"updateType":"WLE"',1);
		self.assertTrueMsg(jsonPos &gt; 1, "TYPE: " &amp; _type &amp; " updateType WLE MISSING from JSON");
		
	endif;
	
epilog
	delete agent;
end;</source>
        <Parameter name="_activityHistory" type="CM_EWSActivityOpsview"/>
        <Parameter name="_type" type="String"/>
        <Parameter name="_object" type="CM_Object"/>
    </JadeMethod>
    <JadeMethod name="tAllotrac" id="a9e6766c-67bf-40d3-99cb-43e76c6d388d">
        <source>tAllotrac();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 August 2020	jlgndl1	Initial creation	TFS 49869

*/

constants
	Cont1 : String = "TFSC4986901";
	Cont2 : String = "TFSC4986902";
	Cont3 : String = "TFSC4986903";
	Truck1 : String = "TRUKONE";
	Truck2 : String = "TRUKTWO";
	Truck3 : String = "TRUKFRE";
	ExtWebServiceDefName : String = "UT_ALLOTRAC";
vars

	activeAllotracDef : CM_AllotracServiceDef;
	pxyExtWebServiceDef : CM_ExternalWebServiceDef;
	extWebServiceDef : CM_ExternalWebServiceDef;
	allotracWebDef : CM_AllotracServiceDef;
	preCount : Integer;
	cont1 : CM_Container;
	cont2 : CM_Container;
	cont3 : CM_Container;
	vvr1 : CM_VehicleVisitRecord;
	vvr2 : CM_VehicleVisitRecord;
	vvr3 : CM_VehicleVisitRecord;
	vvr4 : CM_VehicleVisitRecord;
	vvr5 : CM_VehicleVisitRecord;
	gate : CM_Gate;
	expectedCount : Integer;
	latestCount : Integer;
	allotracRequest : BGP_AllocWSRequest;
	agent : CM_AllotracWSAgent;
	updateString : String;
	expectedUpdateString : String;
	startTime : TimeStamp;
	objsToPurge : ObjectArray;
	iter : Iterator;
	receive : CM_Receive;
	reason : String;

begin

	if not app.myCurrentUserCan( null, Sub_AllotracSend ) then
		self.assertTrueMsg( false, "Unable to test 'Allotrac' no subscription, or has expired" );
	endif;
	startTime := app.actualTimeAppServer;

	//clean up
	deleteContainer( Cont1 );
	deleteContainer( Cont2 );
	deleteContainer( Cont3 );
	self.deleteVehicle( Truck1 );
	self.deleteVehicle( Truck2 );
	self.deleteVehicle( Truck3 );
	
	//deactivate active AllotracServiceDef if required. Only allowed one active at a time
	activeAllotracDef := app.myRoot.getFirstActiveExtWebService(CM_AllotracServiceDef).CM_AllotracServiceDef;
	if activeAllotracDef &lt;&gt; null then
		pxyExtWebServiceDef := app.createUpdateProxy( activeAllotracDef ).CM_AllotracServiceDef;
		pxyExtWebServiceDef.setActive( false );
		app.myTrxUA.trxUpdateExtWebService(pxyExtWebServiceDef, app.myPassport);
		delete pxyExtWebServiceDef;
	endif;
	
	//Create/Update the web service def, select both send in &amp; out and make active
	extWebServiceDef := app.myRoot.allExternalWebServices.getAtKey( ExtWebServiceDefName );
	if extWebServiceDef = null then
		create pxyExtWebServiceDef as CM_AllotracServiceDef transient;
	else
		pxyExtWebServiceDef :=  app.createUpdateProxy( extWebServiceDef ).CM_AllotracServiceDef;
	endif;
	pxyExtWebServiceDef.CM_AllotracServiceDef.setExtras(	"navis",	//_deviceID : String;
															true,	//_sendJobCompleteOnReceive : Boolean;
															true	//_sendJobCompleteOnRelease : Boolean
															);
	pxyExtWebServiceDef.setProxy(	true,	//_active : Boolean;
									ExtWebServiceDefName,	//_name : String;  
									"https//Testing",	//_baseEndpoint : String;  
									app.pwEnCode( "TFS49869" ),	//_password : String;	//30 Aug 2921	NDL	TFS 51632
									"navis",	//_userCode : String; 
									3,	//_maxRetries : Integer;  
									1,	//_timeBetweenRetries : Integer; 
									10,	//_timeoutSeconds : Integer; 
									null,	//_restAPIAuthEndpoint : String; 
									null,	//_restAPIBaseEndpoint : String;
									null,	//_authProviderUrl : String;
									"navis",	//_clientId : String;
									null,	//_clientSecret : String;
									null,	//_runAsKey : String;
									null	//_callBackUrl : String
									);	
									
	if extWebServiceDef = null then
		app.myTrxCA.trxCreateExtWebService( pxyExtWebServiceDef, extWebServiceDef, app.myPassport );
		self.assertTrueMsg( extWebServiceDef &lt;&gt; null, "Failed ot create Allotrac Web Service Def - " &amp; app.myPassport.getAllErrorsWarningsAsString );
	else
		app.myTrxUA.trxUpdateExtWebService( pxyExtWebServiceDef, app.myPassport );
		self.assertTrueMsg( extWebServiceDef &lt;&gt; null, "Failed ot update Allotrac Web Service Def - " &amp; app.myPassport.getAllErrorsWarningsAsString );
	endif;
	
	preCount := BGP_AllocWSRequest.instances.size;
	
	self.opts.purge();
	self.opts.addAssoc( "clientRef", "75");
	cont1 := self.addPrenoteContainer( Cont1 );
	self.opts.purge();
	cont2 := self.addPrenoteContainer( Cont2 );
	cont3 := self.addPrenoteContainer( Cont3 );
	
	
	//Gate in 1 container with clientRef check that an Allotrac Ext Web Request is created.
	self.opts.purge();
	self.opts.addAssoc("PreNote",cont1);
	gate := self.getGate(self.getProfileSetting(UT_Profile.P_SGATE).asString);
	vvr1 := self.gateInContainer(Truck1, Cont1, "2200", cont1.operatorCode, "MT", gate);
	self.workVehicle(vvr1);
	
	expectedCount := preCount + 1;
	latestCount := BGP_AllocWSRequest.instances.size;
	allotracRequest := BGP_AllocWSRequest.lastInstance;
	if latestCount = preCount then
		receive := cont1.getLastTransOfTypeAdv( TRANS_TYPE_RECEIVE ).CM_Receive;
		beginTransaction;
		reason := cont1.createAllotracBGPRequest( receive, allotracRequest );
		commitTransaction;
	endif;
	self.assertTrueMsg( latestCount = expectedCount, "Wrong number of BGP_AllocWSRequests after 1st gate in is " &amp; latestCount.String &amp; " expected to be " &amp; expectedCount.String &amp; " : " &amp; reason );
	
	//Check the content of the raw message produced from the allotrac web request 
	create agent transient;
	agent.setupFromWebServiceDefinition( allotracRequest.myWSDef );
	updateString := agent.createUpdateRequestString( allotracRequest.myTrackedItem.clientRef.trimBlanks );
	expectedUpdateString := '{
  "JobId": "75",
  "CompleteJob": "1"
}';
	self.assertTrueMsg( updateString = expectedUpdateString, "Output format of first jason allotrac job update string incorrect. updateString is '" &amp; updateString &amp; "', expectedUpdateString is '" &amp; expectedUpdateString);

	
	//Gate in 2 more containers without a client ref check that NO Allotrac Ext Web Request is created.
	self.opts.purge();
	self.opts.addAssoc("PreNote",cont2);
	vvr2 := self.gateInContainer(Truck2, Cont2, "2200", cont2.operatorCode, "MT", gate);
	self.workVehicle(vvr2);
	self.opts.purge();
	self.opts.addAssoc("PreNote",cont3);
	vvr3 := self.gateInContainer(Truck3, Cont3, "2200", cont3.operatorCode, "MT", gate);
	self.workVehicle(vvr3);
	
	latestCount := BGP_AllocWSRequest.instances.size;
	self.assertTrueMsg( latestCount = expectedCount, "Wrong number of BGP_AllocWSRequests after 3rd gate in is " &amp; latestCount.String &amp; " expected to be " &amp; expectedCount.String );
	
	self.roadExit(vvr1);
	self.roadExit(vvr2);
	self.roadExit(vvr3);
		
	//set clientRef on the second container then gate it out, check that a second Allotrac Ext Web Request is created.
	beginTransaction;
	cont2.setClientRef("65");
	commitTransaction;
	
	vvr4 := self.gateOutContainer( Truck1, "", "", cont2, true, gate , null );
	self.assertTrueMsg( vvr4 &lt;&gt; null, "Gate of 2nd Container failed " &amp; app.myPassport.getAllErrorsWarningsAsString );
	self.workVehicle(vvr4);
	self.roadExit(vvr4);
	
	expectedCount := latestCount + 1;
	latestCount := BGP_AllocWSRequest.instances.size;
	allotracRequest := BGP_AllocWSRequest.lastInstance;
	self.assertTrueMsg( latestCount = expectedCount, "Wrong number of BGP_AllocWSRequests after 1st gate out is " &amp; latestCount.String &amp; " expected to be " &amp; expectedCount.String );
	
	agent.setupFromWebServiceDefinition( allotracRequest.myWSDef );
	updateString := agent.createUpdateRequestString( allotracRequest.myTrackedItem.clientRef.trimBlanks );
	expectedUpdateString := '{
  "JobId": "65",
  "CompleteJob": "1"
}';
	self.assertTrueMsg( updateString = expectedUpdateString, "Output format of jason allotrac job update string incorrect." );
	
	//gate NON clientRef one out (3rd  cont), check that No Allotrac Ext Web Request is created.
	
	vvr5 := self.gateOutContainer( Truck2, "", "", cont3, true, gate , null );
	self.assertTrueMsg( vvr5 &lt;&gt; null, "Gate of 3rd Container failed " &amp; app.myPassport.getAllErrorsWarningsAsString );
	self.workVehicle(vvr5);
	self.roadExit(vvr5);
	
	latestCount := BGP_AllocWSRequest.instances.size;
	self.assertTrueMsg( latestCount = expectedCount, "Wrong number of BGP_AllocWSRequests after 2nd gate out is " &amp; latestCount.String &amp; " expected to be " &amp; expectedCount.String );
	
	
	
	//clean up
	deleteContainer( Cont1 );
	deleteContainer( Cont2 );
	deleteContainer( Cont3 );
	self.deleteVehicle( Truck1 );
	self.deleteVehicle( Truck2 );
	self.deleteVehicle( Truck3 );
	
	create objsToPurge transient;
	iter := BGP_AllocWSRequest.instances.createIterator;
	while iter.back( allotracRequest ) do
		if allotracRequest.createdTime &lt; startTime then
			break;
		endif;
		if allotracRequest.myTrackedItem = cont1
		or allotracRequest.myTrackedItem = cont2
		then
			objsToPurge.add( allotracRequest );
		endif;
	endwhile;

epilog

	delete iter;
	if objsToPurge &lt;&gt; null then
		if not objsToPurge.isEmpty then
			beginTransaction;
			objsToPurge.purge();
			commitTransaction;
		endif;
		delete objsToPurge;
	endif;

	delete pxyExtWebServiceDef;
	if extWebServiceDef &lt;&gt; null and extWebServiceDef.active then
		pxyExtWebServiceDef := app.createUpdateProxy( extWebServiceDef ).CM_AllotracServiceDef;
		pxyExtWebServiceDef.setActive( false );
		app.myTrxUA.trxUpdateExtWebService(pxyExtWebServiceDef, app.myPassport);
		delete pxyExtWebServiceDef;
	endif;
	if activeAllotracDef &lt;&gt; null then
		pxyExtWebServiceDef := app.createUpdateProxy( activeAllotracDef ).CM_AllotracServiceDef;
		pxyExtWebServiceDef.setActive( true );
		app.myTrxUA.trxUpdateExtWebService(pxyExtWebServiceDef, app.myPassport);
		delete pxyExtWebServiceDef;
	endif;
	delete agent;
	

end;</source>
    </JadeMethod>
    <JadeMethod name="tOpsviewGate" id="940de1dd-0dc1-43f2-9e7a-31b625832726">
        <source>tOpsviewGate();
/*
Purpose:			

Date		Who		Reason
22 November 2021	navab1	TFS 51853
*/

vars
	allActivity : CM_ObjectSet;
	wsDef : CM_OpsViewServiceDef;
	currentStatus : String;
	activityHistory, pxyAct : CM_EWSActivityOpsview;
	truck: CM_Vehicle;
	ti: CM_TrackedItem;
	vvr: CM_VehicleVisitRecord;
	operator : CM_Operator;
	dualGate, singleGate : CM_Gate;
	pin, pout : CM_GateArea;
	job : CM_Job;
	wle : CM_WorkListEntry;
begin
	create allActivity transient;
	
	wsDef := app.myRoot.getFirstActiveExtWebService( CM_OpsViewServiceDef ).CM_OpsViewServiceDef;

	if wsDef &lt;&gt; null
	and wsDef.status = EWS_STATUS_RUNNING then
		currentStatus := EWS_STATUS_RUNNING;
		
		beginTransaction;
		wsDef.setPropertyValue("status", EWS_STATUS_STOPPED);
		commitTransaction;
	endif;

	deleteContainer("UUT12345678");
	deleteVehicle("UTTRUCK");
	dualGate := self.getGate(self.getProfileSetting(UT_Profile.P_DGATE).asString);
	
	operator := getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);
	pin := self.getPGate(self.getProfileSetting(UT_Profile.P_DGATE_PIN).asString);
	pout := self.getPGate(self.getProfileSetting(UT_Profile.P_DGATE_POUT).asString);
	singleGate := self.getGate(self.getProfileSetting(UT_Profile.P_SGATE).asString);

	vvr := gateInContainer("UTTRUCK", "UUT12345678", "2200", operator.code, "MT", dualGate);
	ti := self.getTrackedItem("UUT12345678");
	assertNotNullMsg(ti, "Container is Null");
	assertNotNullMsg(ti.getPrimaryLocation(QUEUE_MODE)," Container is not queued");
	assertEqual(pin.myInTransitToLocation, vvr.vehicle.myPrimaryActualLocation);
	assertEqual(vvr.vehicle.allRoadJobs.size, 1);
	assertEqual(vvr.vehicle.allRoadJobs.first.workListEntries.size, 1);
	assertEqual(vvr.vehicle.allRoadJobs.first.workListEntries.first.status, JOB_UNACTIONED);
	
	
	// ### CHECK ACTIVITY JSON for VVR
	create pxyAct transient;
	pxyAct.initialiseActivity("Navis Smart Data VVR","EXTOPSVIEW", vvr.getMyTerminal(), vvr, BGP_OpsViewWSRequest.OPS_ACTION_CREATE, BGP_OpsViewWSRequest.OPS_TYPE_VVR, false, null);
	activityHistory := app.myTrxCA.trxCreateEWSActivityHistory(pxyAct,app.myPassport).CM_EWSActivityOpsview;
	allActivity.add(activityHistory);
	delete pxyAct;
	
	self.assertNotNullMsg(activityHistory, "Activity for VVR is Null");
	self.assertNotNullMsg(activityHistory.request, "Activity Request for VVR is Null");
	self.checkOpsViewJSON(activityHistory, BGP_OpsViewWSRequest.OPS_TYPE_VVR, vvr); 
	
	// ### CHECK ACTIVITY JSON for ROAD JOB
	job := vvr.getMyJob();
	assertNotNullMsg(job, "Road Job is Null");
	wle := job.workListEntries.first;
	assertNotNullMsg(wle, "Road WLE is Null");
	
	create pxyAct transient;
	pxyAct.initialiseActivity("Navis Smart Data JOB","EXTOPSVIEW", vvr.getMyTerminal(),job , BGP_OpsViewWSRequest.OPS_ACTION_CREATE, BGP_OpsViewWSRequest.OPS_TYPE_JOB, false, null);
	activityHistory := app.myTrxCA.trxCreateEWSActivityHistory(pxyAct,app.myPassport).CM_EWSActivityOpsview;
	allActivity.add(activityHistory);
	delete pxyAct;
	
	self.assertNotNullMsg(activityHistory, "Activity for JOB is Null");
	self.assertNotNullMsg(activityHistory.request, "Activity Request for JOB is Null");
	self.checkOpsViewJSON(activityHistory, BGP_OpsViewWSRequest.OPS_TYPE_JOB, job); 
	
	
	
	
	// ### CHECK ACTIVITY JSON for ROAD WLE
	create pxyAct transient;
	pxyAct.initialiseActivity("Navis Smart Data WLE","EXTOPSVIEW", vvr.getMyTerminal(),wle , BGP_OpsViewWSRequest.OPS_ACTION_CREATE, BGP_OpsViewWSRequest.OPS_TYPE_WLE, false, null);
	activityHistory := app.myTrxCA.trxCreateEWSActivityHistory(pxyAct,app.myPassport).CM_EWSActivityOpsview;
	allActivity.add(activityHistory);
	delete pxyAct;
	
	self.assertNotNullMsg(activityHistory, "Activity for WLE is Null");
	self.assertNotNullMsg(activityHistory.request, "Activity Request for WLE is Null");
	self.checkOpsViewJSON(activityHistory, BGP_OpsViewWSRequest.OPS_TYPE_WLE, wle); 
	

	self.moveVehicleToLane(vvr.vehicle, pin, 1);
		assertEqual(vvr.vehicle.myPrimaryActualLocation, self.getGateLane(pin, 1));
		
	self.moveVehicleToYard(vvr.vehicle);
		assertTrue(vvr.vehicle.myPrimaryActualLocation.isInterchangeAreaLocation);
		
	self.workVehicle(vvr);
		assertNotNull(ti.getPrimaryLocation(REAL_MODE));
		assertTrue(ti.getPrimaryLocation(REAL_MODE).isKindOf(CM_YardController));
		assertTrue(vvr.vehicle.myPrimaryActualLocation.isInterchangeAreaLocation);
		
	self.moveVehicleToLane(vvr.vehicle, pout, 1);
		assertEqual(vvr.vehicle.myPrimaryActualLocation, self.getGateLane(pout, 1));
		
		
		
	// JOB is deleted as part of road exit
	// ### CHECK ACTIVITY JSON for ROAD JOB
	create pxyAct transient;
	pxyAct.initialiseActivity("Navis Smart Data JOB","EXTOPSVIEW", vvr.getMyTerminal(),job , BGP_OpsViewWSRequest.OPS_ACTION_DELETE, BGP_OpsViewWSRequest.OPS_TYPE_JOB, false, job.getOidString());
	activityHistory := app.myTrxCA.trxCreateEWSActivityHistory(pxyAct,app.myPassport).CM_EWSActivityOpsview;
	allActivity.add(activityHistory);
	delete pxyAct;
	
	self.assertNotNullMsg(activityHistory, "Activity for JOB is Null");
	self.assertNotNullMsg(activityHistory.request, "Activity Request for JOB is Null");
	self.checkOpsViewJSON(activityHistory, BGP_OpsViewWSRequest.OPS_TYPE_JOB, job); 

	self.roadExit(vvr);
		assertNull(vvr.myRoadJob);
		assertEqual(vvr.status, CM_VehicleVisitRecord.Status_Complete);
		assertNull(vvr.vehicle.myPrimaryActualLocation);
		
	
	
	// ### CHECK ACTIVITY JSON for VVR
	create pxyAct transient;
	pxyAct.initialiseActivity("Navis Smart Data VVR","EXTOPSVIEW", vvr.getMyTerminal(), vvr, BGP_OpsViewWSRequest.OPS_ACTION_UPDATE, BGP_OpsViewWSRequest.OPS_TYPE_VVR, false, null);
	activityHistory := app.myTrxCA.trxCreateEWSActivityHistory(pxyAct,app.myPassport).CM_EWSActivityOpsview;
	allActivity.add(activityHistory);
	delete pxyAct;
	
	self.assertNotNullMsg(activityHistory, "Activity for VVR is Null");
	self.assertNotNullMsg(activityHistory.request, "Activity Request for VVR is Null");
	self.checkOpsViewJSON(activityHistory, BGP_OpsViewWSRequest.OPS_TYPE_VVR, vvr); 
			
epilog
	 if currentStatus &lt;&gt; null 
	 and wsDef &lt;&gt; null then
			
		beginTransaction;
		wsDef.setPropertyValue("status", currentStatus);
		commitTransaction;
	 
	 endif;
	 
	 beginTransaction;
	 allActivity.purge();
	 commitTransaction;
	 
	delete pxyAct;
	delete allActivity;

end;</source>
    </JadeMethod>
    <JadeMethod name="tOpsviewVoyage" id="9d6fa215-715a-473e-87da-12b7dbb1be1c">
        <updating/>
        <source>tOpsviewVoyage() updating;
/*
Purpose:	Check the JSON generated for OpsView Waterside		

Date		Who		Reason
10 November 2021	navab1	TFS 50669
*/
constants
	SUFFIX = "TFS50669";
	BaseCargoId = "TFSU50699";
vars
	allActivity : CM_ObjectSet;
	wsDef : CM_OpsViewServiceDef;
	currentStatus : String;
	voyage : CM_Voyage;
	activityHistory, pxyAct : CM_EWSActivityOpsview;
	aPort : CM_Port;
	cont : CM_Container;
	oper : CM_Operator;
	bay : CM_Bay;
	slot : CM_SlotController;
	size : Integer;
	terminal : CM_Terminal;
	theCRANES : ObjectArray;
	crane : CM_Machine;
	cta : CM_CraneTransferArea;
	tas : StringArray;
	slots : CM_SlotControllerArray;
	job : CM_VoyageJob;
	wle : CM_WorkListEntry;
begin
	create allActivity transient;
	
	wsDef := app.myRoot.getFirstActiveExtWebService( CM_OpsViewServiceDef ).CM_OpsViewServiceDef;

	if wsDef &lt;&gt; null
	and wsDef.status = EWS_STATUS_RUNNING then
		currentStatus := EWS_STATUS_RUNNING;
		
		beginTransaction;
		wsDef.setPropertyValue("status", EWS_STATUS_STOPPED);
		commitTransaction;
	endif;

	// CREATE VOYAGE
	self.opts.purge();
	self.opts.addAssoc("Bays", 5);
	self.opts.addAssoc("Big", true);

	voyage := self.createVesselVoyage(SUFFIX, SUFFIX,null);
	self.assertNotNullMsg(voyage, "Voyage is Null");
	
	// ### CHECK ACTIVITY JSON for VOYAGE
	create pxyAct transient;
	pxyAct.initialiseActivity("Navis Smart Data Voyage","EXTOPSVIEW", voyage.getMyTerminal(), voyage, BGP_OpsViewWSRequest.OPS_ACTION_CREATE, BGP_OpsViewWSRequest.OPS_TYPE_VOYAGE, false, null);
	activityHistory := app.myTrxCA.trxCreateEWSActivityHistory(pxyAct,app.myPassport).CM_EWSActivityOpsview;
	allActivity.add(activityHistory);
	delete pxyAct;
	
	self.assertNotNullMsg(activityHistory, "Activity for Voyage is Null");
	self.assertNotNullMsg(activityHistory.request, "Activity Request for Voyage is Null");
	self.checkOpsViewJSON(activityHistory, BGP_OpsViewWSRequest.OPS_TYPE_VOYAGE, voyage); 
	
	
	// CREATE CONTAINERS
	create slots  transient;
	aPort := app.myRoot.allPorts[voyage.myTerminal.getConfig(PortDestCode).String];
	oper := self.getOperator(getProfileSetting(UT_Profile.P_OPERATOR).asString);
	bay := voyage.myCellularVoyageStructure.allBayVoyagesByOrdinal.first;
	self.assertNotNullMsg(bay, "Bay is Null");

	slot := bay.CM_BayVoyage.allSlotControllersByOrdinal[2,1,6];
	self.assertNotNullMsg(slot, "Slot 2 1 6 is Null");
	slots.add(slot);
	cont := self.addContainerOnShip( BaseCargoId &amp; "01", oper, "2200", "GENL", null, voyage, aPort.code, slot.mySlotDefnVoyage.getStowageId(false,true)).CM_Container;
	self.assertNotNullMsg(cont, "CONT "  &amp; BaseCargoId &amp; "01 is Null");

	slot := bay.CM_BayVoyage.allSlotControllersByOrdinal[2,2,6];
	self.assertNotNullMsg(slot, "Slot 2 2 6 is Null");
	slots.add(slot);
	cont := self.addContainerOnShip( BaseCargoId &amp; "03", oper, "2200", "GENL", null, voyage, aPort.code, slot.mySlotDefnVoyage.getStowageId(false,true)).CM_Container;
	self.assertNotNullMsg(cont, "CONT "  &amp; BaseCargoId &amp; "03 is Null");

	slot := bay.CM_BayVoyage.allSlotControllersByOrdinal[2,3,6];
	self.assertNotNullMsg(slot, "Slot 2 3 6 is Null");
	slots.add(slot);
	cont := self.addContainerOnShip( BaseCargoId &amp; "05", oper, "2200", "GENL", null, voyage, aPort.code, slot.mySlotDefnVoyage.getStowageId(false,true)).CM_Container;
	self.assertNotNullMsg(cont, "CONT "  &amp; BaseCargoId &amp; "05 is Null");

	slot := bay.CM_BayVoyage.allSlotControllersByOrdinal[2,4,6];
	self.assertNotNullMsg(slot, "Slot 2 4 6 is Null");
	slots.add(slot);
	cont := self.addContainerOnShip( BaseCargoId &amp; "07", oper, "2200", "GENL", null, voyage, aPort.code, slot.mySlotDefnVoyage.getStowageId(false,true)).CM_Container;
	self.assertNotNullMsg(cont, "CONT "  &amp; BaseCargoId &amp; "07 is Null");
	
	// DISCHARGE COLOUR CODING
	app.myTrxUA.trxSetDfltDischargeColourCode(voyage.myCellularVoyageStructure, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();

	self.deleteMachine("ABCR");
	cta := self.addCraneTransferArea("ABTA");
	self.opts.purge();
	self.opts.addAssoc("CraneTransferArea", cta);
	create tas transient;
	tas.add(cta.id);
	crane := self.addCrane("ABCR",788,tas,null);
	self.assertNotNullMsg(crane, "Crane is Null");

	// CREATE A JOB
	job := self.addVoyageJob(voyage, crane.code, slots,true);
	self.assertNotNullMsg(job, "Job is Null");
	
	
	// ### CHECK ACTIVITY JSON for JOB
	create pxyAct transient;
	pxyAct.initialiseActivity("Navis Smart Data Job","EXTOPSVIEW", voyage.getMyTerminal(), job, BGP_OpsViewWSRequest.OPS_ACTION_CREATE, BGP_OpsViewWSRequest.OPS_TYPE_JOB, false, null);
	activityHistory := app.myTrxCA.trxCreateEWSActivityHistory(pxyAct,app.myPassport).CM_EWSActivityOpsview;
	allActivity.add(activityHistory);
	delete pxyAct;
	
	self.assertNotNullMsg(activityHistory, "Activity for Job is Null");
	self.assertNotNullMsg(activityHistory.request, "Activity Request for Job is Null");
	self.checkOpsViewJSON(activityHistory, BGP_OpsViewWSRequest.OPS_TYPE_JOB, job); 
	
	// ### CHECK ACTIVITY JSON for WLE
	foreach wle in job.workListEntries do
	
		create pxyAct transient;
		pxyAct.initialiseActivity("Navis Smart Data Job","EXTOPSVIEW", voyage.getMyTerminal(), wle, BGP_OpsViewWSRequest.OPS_ACTION_CREATE, BGP_OpsViewWSRequest.OPS_TYPE_WLE, false, null);
		activityHistory := app.myTrxCA.trxCreateEWSActivityHistory(pxyAct,app.myPassport).CM_EWSActivityOpsview;
		allActivity.add(activityHistory);
		write activityHistory.request;
		delete pxyAct;
		
		self.assertNotNullMsg(activityHistory, "Activity for WLE is Null");
		self.assertNotNullMsg(activityHistory.request, "Activity Request for WLE is Null");
		self.checkOpsViewJSON(activityHistory, BGP_OpsViewWSRequest.OPS_TYPE_WLE, wle); 
		
	endforeach;
	
	return;
	self.deleteVoyage(voyage.code);

epilog
	delete theCRANES;
	delete tas;
	delete slots;
	
	 if currentStatus &lt;&gt; null 
	 and wsDef &lt;&gt; null then
			
		beginTransaction;
		wsDef.setPropertyValue("status", currentStatus);
		commitTransaction;
	 
	 endif;
	 
	 beginTransaction;
	 allActivity.purge();
	 commitTransaction;
	 
	delete pxyAct;
	delete allActivity;
end;</source>
    </JadeMethod>
    <JadeMethod name="tQshipsVoyage" id="4209faf4-781e-4832-a48d-497ee617efd8">
        <source>tQshipsVoyage();
/*****************************************************
Author		: jlika1 (Karen Alexander)
Date		: 08 November 2022
TFS#		: 54892
Function	:

*** Changes ***
Date			Name		TFS#		Description
17/08/2023		jlika1		TFS 599533	59168 - 55715.010 -  Update of Movement Status Based on the Value in the STATUS_TYPE_NAME Field
24/08/2023		jlika1		TFS 59852	59168 - 55715.020 Dates and Times of Voyage Movements
25/09/2023		jlika1		TFS 60540	POB - STATUS_TYPE_NAME "CANC" shown as Planned in MTN
08/01/2024		jlirs1		TFS 60575 - Jade 2022 upgrade fixing unitTests
19/02/2023		navlw1		TFS 62341	62502 - QShips add POB to ports of call
05/12/2024		navmd1		MTN-33527 Include pre-transformed message on EDI file
12/09/2025		navdap1		MTN-35988 MTN-35988 Unit test UT_WebExternal::tQShipsVoyage and tQShipsVoyageMovements need fixing
****************************************************/
constants
	PortOfBrisbane		: String = "AUBNE";
vars
	pxyExtWebServiceDef : CM_QshipsWebServiceDef;
	webService 			: CM_QshipsWebServiceDef;		
	bgpObject			: BGP_QshipsRequest;
	edifile				: CM_EDIFile;
	input				: String;
	lastSuccessfullTS	: TimeStamp;
	terminalCode		: String;
	terminal			: CM_Terminal;
	passport			: CM_Passport;
	ediData				: CM_EDIData;
	voyageArray			: StringArray;
	voyageCode			: String;
	voyageUpdArray		: StringArray;	
	vesselArray			: StringArray;
	vesselCode			: String;
	origHarbour			: HMS_Harbour;
	harbour				: HMS_Harbour;
	wharf				: HMS_Wharf;
	berth				: HMS_Berth;	
	objectArray			: ObjectArray;
	berthArray			: StringArray;
	berthCode			: String;
	startingPos			: Integer;
	voyage				: CM_Voyage;
	vessel				: CM_Vessel;
	isConverting		: Boolean;
	defVoyageProcess 	: String;
	utVoyProcess 		: CM_VoyageProcessDefault;
	isDoClearanceCheck	: Boolean;
	portRotation		: CM_PortRotation;
	port				: CM_Port;
	foundPort			: Boolean;
	extDef				: CM_ExternalWebServiceDef;		// MTN-35988
	extDefsInactivated	: ObjectArray;					// MTN-35988
	obj 				: Object;						// MTN-35988
begin			
	//preserve value
	isDoClearanceCheck := self.getMyTerminal.myHarbour.isDoClearanceCheck;	
	//set to what the unit test needed
	self.setHarbourIsDoClearanceCheck(false);
	
	//preserve value
	isConverting := app.isConverting;	
	//set to what the unit test needed
	app.isConverting := true;
	
	terminalCode := self.getProfileSetting(UT_Profile.P_TERMINAL).asString;
	terminal := app.myRoot.allTerminals[terminalCode];
	self.assertNotNullMsg(terminal, "No terminal set, unable to run test");	
	
	//set to what the unit test needed
	utVoyProcess := CM_VoyageProcessDefault.firstInstance;
	defVoyageProcess := self.setTerminalConfig(DefaultVoyageProcess, utVoyProcess.code).String;	
	
	//Create List of Created Voyages
	create voyageArray transient;
	voyageArray.add("155896");
	voyageArray.add("156399");
	voyageArray.add("156472");
	voyageArray.add("156562");
	voyageArray.add("156821");
	voyageArray.add("157029");
	voyageArray.add("157071");
	
	voyageArray.add("156869");
	voyageArray.add("156034");
	voyageArray.add("156173");
	voyageArray.add("155428");
	voyageArray.add("157133");
	voyageArray.add("156488");
	
	foreach voyageCode in voyageArray do
		deleteVoyage(voyageCode);
	endforeach;	
	
	//Create List of Updated Voyages
	create voyageUpdArray transient;
	voyageUpdArray.add("156399");
	voyageUpdArray.add("157029");	
	
	//Create List of Created Vessel
	create vesselArray transient;
	vesselArray.add("636915");
	vesselArray.add("638507");
	vesselArray.add("639241");
	vesselArray.add("639299");
	vesselArray.add("639495");
	vesselArray.add("639478");
	vesselArray.add("639471");
	
	vesselArray.add("639458");
	vesselArray.add("639313");
	vesselArray.add("639314");
	vesselArray.add("639158");
	vesselArray.add("636293");
	vesselArray.add("639342");
	
	foreach vesselCode in vesselArray do
		deleteVessel(vesselCode);
	endforeach;		
		
	origHarbour := terminal.myHarbour;
	//origHarbour := app.myRoot.allHarbours["HMSAVON"];
	
	// clear terminal harbour so can add new one
	if origHarbour &lt;&gt; null and origHarbour.allTerminalsByCode.includes(terminal) then
		beginTransaction;
		origHarbour.allTerminalsByCode.remove(terminal);
		commitTransaction;
	endif;
	// harbour
	create objectArray transient;
	objectArray.add(terminal);
	self.opts.purge();
	self.opts.addAssoc("IgnoreWarnings", true);
	self.opts.addAssoc("Terminals", objectArray);

	harbour := app.myRoot.allHarbours["UTQSHIP"];
	if harbour = null then
		harbour := self.addHarbour("UTQSHIP", "Qship Test harbour").HMS_Harbour;		
	endif;
	
	// wharf
	wharf := harbour.allWharves["UTQWHARF"];
	if wharf = null then
		wharf := self.addWharf("UTQWHARF","Qships Test wharf", harbour, 1600, 100);
	endif;
	
	// berth Just incase the berth is missing
	create berthArray transient;
	berthArray.add("DSM");
	berthArray.add("SEA");
	berthArray.add("CAB");
	berthArray.add("FI3");
	berthArray.add("FI9");
	berthArray.add("FI8");
	berthArray.add("FI1");
	berthArray.add("FI7");
	berthArray.add("BPPR");
	berthArray.add("FIGR");
	berthArray.add("PC^");
	berthArray.add("QBT");
	berthArray.add("DFTPC");
	
	startingPos := 0;
	foreach berthCode in berthArray do
		berth := harbour.allBerths[berthCode];
		if berth = null then	
			addBerth(berthCode, berthCode, harbour, startingPos, 100, 2.5, false, wharf);
		endif;
		startingPos += 100;
	endforeach;
		
	if harbour &lt;&gt; null and not harbour.allTerminalsByCode.includes(terminal) then
		beginTransaction;
			harbour.allTerminalsByCode.add(terminal);
		commitTransaction;
	endif;		
	
	passport := app.myPassport;
	
	// MTN-35988 turn off all NSW external web services so that CM_EDIDataVoyage::setupMoveProxies doesn't mistakenly think we're NSW
	// and try charging for movements
	create extDefsInactivated transient;
	while true do
		extDef := app.myRoot.getFirstActiveEWSForEndpoint(ETRow_NswVesselMovements);
		if extDef &lt;&gt; null then
			beginTransaction;
			extDef.setActive(false);
			commitTransaction;
			extDefsInactivated.add(extDef);
			continue;
		endif;
		break;
	endwhile;
	
	//Create/Update the web service def, select both send in &amp; out and make active
	webService := app.myRoot.allExternalWebServices.getAtKey(ExternalWebServiceQships).CM_QshipsWebServiceDef;
	if webService = null then
		create pxyExtWebServiceDef as CM_QshipsWebServiceDef transient;
	else
		pxyExtWebServiceDef :=  app.createUpdateProxy( webService ).CM_QshipsWebServiceDef;
	endif;
	
	input := self.xmlDef_QshipsForAddVoyage();
	create bgpObject transient;
	
	edifile := bgpObject.processResponse(input, null, pxyExtWebServiceDef, lastSuccessfullTS, terminal);
	self.assertNotNullMsg(edifile, "No edifile has been created.");	
	
	ediData := edifile.ediData;
	self.assertNotNullMsg(ediData, "No edidata has been created.");	
	
	self.assertEqualMsg(ediData.allEDITrackedItems.size,53, "Number of objects created is unmatched");	
	
	ediData.verifyEDIDataTIs(passport);
//	self.assertEqualMsg(ediData.status, CM_EDIFile.EDI_STATUS_VERIFIED, "Status should be Verified");	
	self.assertIsOneOf(ediData.status, "Status should be Verified - " &amp; ediData.status.String, CM_EDIFile.EDI_STATUS_VERIFIED_WARNINGS, CM_EDIFile.EDI_STATUS_VERIFIED );
	self.assertEqualMsg(ediData.allErrorWarnings.size, 0, "No error's or warning should occurs");	
	
	ediData.loadDB(true, passport);
	self.assertEqualMsg(ediData.status, CM_EDIFile.EDI_STATUS_DBLOADED, "Status should be DB Loaded");	
	
	// navlw1 #62341
	port := app.myRoot.allPorts[PortOfBrisbane];
	self.assertNotNullMsg(port, "Port " &amp; PortOfBrisbane &amp; " has not been found");
	
	foreach voyageCode in voyageArray do
		voyage := self.getVoyage(voyageCode);
		self.assertNotNullMsg(voyage, "Voyage '" &amp; voyageCode &amp; "' has not been found");
		self.assertNotNullMsg(voyage.myHMSVoyageData, "Voyage myHMSData should not be null.");
		self.assertEqualMsg(voyage.myHMSVoyageData.allVoyageMovements.size, 2, "Should have 2 Voyage Movements.");	
		
		// #62341
		foundPort := false;
		foreach portRotation in voyage.allPortRotations do 
			if portRotation.myPort = port then
				foundPort := true;
			endif;
		endforeach;
		self.assertEqualMsg(foundPort, true, "Port Of Brisbane has been added to port of call for voyage " &amp; voyageCode);
		// #62341
		
		if voyageCode = "155428" then
			self.assertEqualMsg(voyage.arrivedDT.asStringJMT, "24/10/2022 09:00", "Arrival Date");	
			self.assertEqualMsg(voyage.departedDT.asStringJMT, "26/10/2022 09:00", "Departure Date");				
			self.assertEqualMsg(voyage.externalRef,"35", "External Reference");
			self.assertEqualMsg(voyage.lloydsNumber, "9774032", "Lloyds Number");
			self.assertEqualMsg(voyage.status, Voyage_Status_Departed, "Working Status");
		endif;
		
		if voyageCode = "155896" then
			self.assertEqualMsg(voyage.arrivedDT.asStringJMT, "26/10/2022 08:38", "Arrival Date");	
			self.assertEqualMsg(voyage.departedDT.asStringJMT, "28/10/2022 08:38", "Departure Date");				
			self.assertNullMsg(voyage.externalRef, "External Reference");
			self.assertEqualMsg(voyage.lloydsNumber, "8681393", "Lloyds Number");
			self.assertEqualMsg(voyage.status, Voyage_Status_Arrived, "Working Status");
		endif;
		
		if voyageCode = "156034" then
			self.assertEqualMsg(voyage.arrivedDT.asStringJMT, "24/10/2022 02:05", "Arrival Date");	
			self.assertEqualMsg(voyage.departedDT.asStringJMT, "26/10/2022 02:05", "Departure Date");				
			//self.assertEqualMsg(voyage.externalRef.trimBlanks, "1", "External Reference");
			self.assertEqualMsg(voyage.lloydsNumber, "9738820", "Lloyds Number");
			self.assertEqualMsg(voyage.status, Voyage_Status_Departed, "Working Status");
		endif;
		
		if voyageCode = "156173" then
			self.assertEqualMsg(voyage.arrivedDT.asStringJMT, "23/10/2022 23:12", "Arrival Date");	
			self.assertEqualMsg(voyage.departedDT.asStringJMT, "25/10/2022 23:12", "Departure Date");				
			self.assertEqualMsg(voyage.externalRef,"2206S/N", "External Reference");
			self.assertEqualMsg(voyage.lloydsNumber, "9322310", "Lloyds Number");
			self.assertEqualMsg(voyage.status, Voyage_Status_Departed, "Working Status");
		endif;
		
		if voyageCode = "156399" then
			self.assertEqualMsg(voyage.arrivedDT.asStringJMT, "25/10/2022 22:12", "Arrival Date");	
			self.assertEqualMsg(voyage.departedDT.asStringJMT, "27/10/2022 22:12", "Departure Date");
			self.assertEqualMsg(voyage.externalRef, "3S/3N", "External Reference");
			self.assertEqualMsg(voyage.lloydsNumber, "9923968", "Lloyds Number");
			self.assertEqualMsg(voyage.status, Voyage_Status_Arrived, "Working Status");
		endif;
		
		if voyageCode = "156472" then
			self.assertEqualMsg(voyage.arrivedDT.asStringJMT, "26/10/2022 10:06", "Arrival Date");	
			self.assertEqualMsg(voyage.departedDT.asStringJMT, "28/10/2022 10:06", "Departure Date");
			self.assertEqualMsg(voyage.externalRef, "138", "External Reference");
			self.assertEqualMsg(voyage.lloydsNumber, "9277826", "Lloyds Number");
			self.assertEqualMsg(voyage.status, Voyage_Status_Pending, "Working Status");
		endif;
		
		if voyageCode = "156562" then
			self.assertEqualMsg(voyage.arrivedDT.asStringJMT, "26/10/2022 01:18", "Arrival Date");	
			self.assertEqualMsg(voyage.departedDT.asStringJMT, "26/10/2022 07:11", "Departure Date");				
			self.assertEqualMsg(voyage.externalRef, "016N", "External Reference");
			self.assertEqualMsg(voyage.lloydsNumber, "9992222", "Lloyds Number");
			self.assertEqualMsg(voyage.status, Voyage_Status_Departed, "Working Status");
		endif;
		
		if voyageCode = "156821" then
			self.assertEqualMsg(voyage.arrivedDT.asStringJMT, "25/10/2022 20:54", "Arrival Date");	
			self.assertEqualMsg(voyage.departedDT.asStringJMT, "26/10/2022 08:30", "Departure Date");
			self.assertEqualMsg(voyage.externalRef, "EE223", "External Reference");
			self.assertEqualMsg(voyage.lloydsNumber, "9519133", "Lloyds Number");
			self.assertEqualMsg(voyage.status, Voyage_Status_Departed, "Working Status");
		endif;
		
		if voyageCode = "156869" then
			self.assertEqualMsg(voyage.arrivedDT.asStringJMT, "24/10/2022 08:00", "Arrival Date");	
			self.assertEqualMsg(voyage.departedDT.asStringJMT, "26/10/2022 08:00", "Departure Date");
			self.assertNullMsg(voyage.externalRef,"External Reference");
			self.assertEqualMsg(voyage.lloydsNumber, "9690896", "Lloyds Number");
			self.assertEqualMsg(voyage.status, Voyage_Status_Departed, "Working Status");
		endif;
		
		if voyageCode = "157029" then
			self.assertEqualMsg(voyage.arrivedDT.asStringJMT, "26/10/2022 01:42", "Arrival Date");	
			self.assertEqualMsg(voyage.departedDT.asStringJMT, "28/10/2022 01:42", "Departure Date");
			self.assertEqualMsg(voyage.externalRef, "012", "External Reference");
			self.assertEqualMsg(voyage.lloydsNumber, "9919840", "Lloyds Number");
			self.assertEqualMsg(voyage.status, Voyage_Status_Arrived, "Working Status");
		endif;
		
		if voyageCode = "157071" then
			self.assertEqualMsg(voyage.arrivedDT.asStringJMT, "26/10/2022 06:00", "Arrival Date");	
			self.assertEqualMsg(voyage.departedDT.asStringJMT, "28/10/2022 06:00", "Departure Date"); 
			self.assertEqualMsg(voyage.externalRef, "2204", "External Reference");
			self.assertEqualMsg(voyage.lloydsNumber, "9860415", "Lloyds Number");
			self.assertEqualMsg(voyage.status, Voyage_Status_Arrived, "Working Status");
		endif;
		
		if voyageCode = "157133" then
			self.assertEqualMsg(voyage.arrivedDT.asStringJMT, "24/10/2022 10:00", "Arrival Date");	
			self.assertEqualMsg(voyage.departedDT.asStringJMT, "26/10/2022 10:00", "Departure Date");
			self.assertEqualMsg(voyage.externalRef, "Ki241A", "External Reference");
			self.assertEqualMsg(voyage.lloydsNumber, "9449869", "Lloyds Number");
			self.assertEqualMsg(voyage.status, Voyage_Status_Departed, "Working Status");
		endif;
		
		if voyageCode = "156488" then
			self.assertEqualMsg(voyage.arrivedDT.asStringJMT, "24/10/2022 16:00", "Arrival Date");	
			self.assertEqualMsg(voyage.departedDT.asStringJMT, "26/10/2022 16:00", "Departure Date");
			self.assertEqualMsg(voyage.externalRef, "175", "External Reference");
			self.assertEqualMsg(voyage.lloydsNumber, "9229398", "Lloyds Number");
			self.assertEqualMsg(voyage.status, Voyage_Status_Cancelled, "Working Status");
		endif;
	endforeach;	
	
	foreach vesselCode in vesselArray do
		vessel := self.getVessel(vesselCode);
		self.assertNotNullMsg(vessel, "Vessel '" &amp; vesselCode &amp; "' has not been found");
	endforeach;	
	//Edit Voyage Start Here
	
	input := self.xmlDef_QshipsForEditVoyage();
	
	edifile := bgpObject.processResponse(input, null, pxyExtWebServiceDef, lastSuccessfullTS, terminal);
	self.assertNotNullMsg(edifile, "No edifile has been created.");	
	
	ediData := edifile.ediData;
	self.assertNotNullMsg(ediData, "No edidata has been created.");	
	
	self.assertEqualMsg(ediData.allEDITrackedItems.size,21, "Number of tracked items created is unmatched");	
	
	ediData.verifyEDIDataTIs(passport);
	self.assertEqualMsg(ediData.status, CM_EDIFile.EDI_STATUS_VERIFIED, "Status should be Verified");	
	self.assertEqualMsg(ediData.allErrorWarnings.size, 0, "No error's or warning should occurs");	
	
	ediData.loadDB(true, passport);
	self.assertEqualMsg(ediData.status, CM_EDIFile.EDI_STATUS_DBLOADED, "Status should be DB Loaded");	
	
	foreach voyageCode in voyageArray do
		voyage := self.getVoyage(voyageCode);
		self.assertNotNullMsg(voyage, "Voyage '" &amp; voyageCode &amp; "' has not been found");
		self.assertNotNullMsg(voyage.myHMSVoyageData, "Voyage myHMSData should not be null.");
		if voyageCode = "156034" then
			self.assertEqualMsg(voyage.myHMSVoyageData.allVoyageMovements.size, 4, "Should have 4 Voyage Movements.");	
			self.assertEqualMsg(voyage.departedDT.asStringJMT, "27/10/2022 06:05", "Departure Date");
		elseif voyageCode = "157071" then
			self.assertEqualMsg(voyage.myHMSVoyageData.allVoyageMovements.size, 3, "Should have 3 Voyage Movements.");	
		else 
			self.assertEqualMsg(voyage.myHMSVoyageData.allVoyageMovements.size, 2, "Should have 2 Voyage Movements.");	
		endif;
		
		if voyageCode = "156399" then
			self.assertEqualMsg(voyage.arrivedDT.asStringJMT, "25/10/2022 22:12", "Arrival Date");	
			self.assertEqualMsg(voyage.departedDT.asStringJMT, "27/10/2022 03:05", "Departure Date");
			self.assertEqualMsg(voyage.externalRef, "3S/3N", "External Reference");
			self.assertEqualMsg(voyage.lloydsNumber, "9923968", "Lloyds Number");
			self.assertEqualMsg(voyage.status, Voyage_Status_Departed, "Working Status");
		endif;
		
		if voyageCode = "157029" then
			self.assertEqualMsg(voyage.arrivedDT.asStringJMT, "26/10/2022 01:42", "Arrival Date");	
			self.assertEqualMsg(voyage.departedDT.asStringJMT, "26/10/2022 17:00", "Departure Date");
			self.assertEqualMsg(voyage.externalRef, "012", "External Reference");
			self.assertEqualMsg(voyage.lloydsNumber, "9919840", "Lloyds Number");
			self.assertEqualMsg(voyage.status, Voyage_Status_Departed, "Working Status");
		endif;		
		
		if voyageCode = "157071" then
			self.assertEqualMsg(voyage.arrivedDT.asStringJMT, "26/10/2022 06:00", "Arrival Date");	
			//self.assertEqualMsg(voyage.departedDT.asStringJMT, "28/10/2022 06:00", "Departure Date"); // Check with Dave why there is a difference now in date
			self.assertEqualMsg(voyage.externalRef, "2204", "External Reference");
			self.assertEqualMsg(voyage.lloydsNumber, "9860415", "Lloyds Number");			
			self.assertEqualMsg(voyage.status, Voyage_Status_Arrived, "Working Status");
		endif;		
		
		if voyageCode = "156472" then
			self.assertEqualMsg(voyage.arrivedDT.asStringJMT, "26/10/2022 10:06", "Arrival Date");	
			self.assertEqualMsg(voyage.departedDT.asStringJMT, "28/10/2022 10:06", "Departure Date");
			self.assertEqualMsg(voyage.externalRef, "138", "External Reference");
			self.assertEqualMsg(voyage.lloydsNumber, "9277826", "Lloyds Number");
			self.assertEqualMsg(voyage.status, Voyage_Status_Cancelled, "Working Status");
		endif;
	endforeach;	
	
	//Cancel Shift MovementStart Here
	
	input := self.xmlDef_QshipsForCancelShift();
	
	edifile := bgpObject.processResponse(input, null, pxyExtWebServiceDef, lastSuccessfullTS, terminal);
	self.assertNotNullMsg(edifile, "No edifile has been created.");	
	
	ediData := edifile.ediData;
	self.assertNotNullMsg(ediData, "No edidata has been created.");	
	
	self.assertEqualMsg(ediData.allEDITrackedItems.size,3, "Number of tracked items created is unmatched");	
	
	ediData.verifyEDIDataTIs(passport);
	self.assertEqualMsg(ediData.status, CM_EDIFile.EDI_STATUS_VERIFIED, "Status should be Verified");	
	self.assertEqualMsg(ediData.allErrorWarnings.size, 0, "No error's or warning should occurs");	
	
	ediData.loadDB(true, passport);
	self.assertEqualMsg(ediData.status, CM_EDIFile.EDI_STATUS_DBLOADED, "Status should be DB Loaded");	
	
	foreach voyageCode in voyageArray do
		voyage := self.getVoyage(voyageCode);
		self.assertNotNullMsg(voyage, "Voyage '" &amp; voyageCode &amp; "' has not been found");
		self.assertNotNullMsg(voyage.myHMSVoyageData, "Voyage myHMSData should not be null.");
		if voyageCode = "157071" then
			self.assertEqualMsg(voyage.arrivedDT.asStringJMT, "26/10/2022 06:00", "Arrival Date");	
			//self.assertEqualMsg(voyage.departedDT.asStringJMT, "28/10/2022 06:00", "Departure Date"); // Check with Dave why there is a difference now in date
			self.assertEqualMsg(voyage.externalRef, "2204", "External Reference");
			self.assertEqualMsg(voyage.lloydsNumber, "9860415", "Lloyds Number");
			self.assertEqualMsg(voyage.myHMSVoyageData.allVoyageMovements.size, 2, "Should have 2 Voyage Movements.");	
			self.assertEqualMsg(voyage.status, Voyage_Status_Arrived, "Working Status");
		endif;		
	endforeach;	
epilog			
	//reset to original value	
	self.setHarbourIsDoClearanceCheck(isDoClearanceCheck);
	self.setTerminalConfig( DefaultVoyageProcess, defVoyageProcess );	
	app.isConverting := isConverting;
	
	delete objectArray;
	// restore original harbour
	if terminal &lt;&gt; null and origHarbour &lt;&gt; null and
	   global.isValidObject(origHarbour) then	   
		beginTransaction;
		if harbour &lt;&gt; null and harbour.allTerminalsByCode &lt;&gt; null and 
				harbour.allTerminalsByCode.includes(terminal) then
			harbour.allTerminalsByCode.remove(terminal);
		endif;
		origHarbour.allTerminalsByCode.add(terminal);
		commitTransaction;
	endif;
	
	// MTN-35988 turn on all the NSW external web service defs that we turned off
	foreach obj in extDefsInactivated do
		extDef := obj.CM_ExternalWebServiceDef;
		beginTransaction;
		extDef.setActive(true);
		commitTransaction;
	endforeach;
	delete extDefsInactivated;
	
	beginTransaction;		
	voyageArray.purge();
	delete voyageArray;
	vesselArray.purge();
	delete vesselArray;
	berthArray.purge();
	delete berthArray;
	voyageUpdArray.purge();
	delete voyageUpdArray;
	delete pxyExtWebServiceDef;
	delete bgpObject;	
	commitTransaction;
end;</source>
    </JadeMethod>
    <JadeMethod name="tQshipsVoyageMovements" id="0eb4dbab-5679-42f9-804a-487b074fbe1e">
        <source>tQshipsVoyageMovements();
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
10 October 2024		navcs2	MTN-32967 POB - QSHIPS - Completed Arrival Movements Get Updated and Revert to Planned 
05 December 2024	navmd1	MTN-33527 Include pre-transformed message on EDI file
12 September 2025	navdap1	MTN-35988 Unit test UT_WebExternal::tQShipsVoyage and tQShipsVoyageMovements need fixing
*/

constants
	VoyageCodeConst		: String = "215929";
vars
	pxyExtWebServiceDef : CM_QshipsWebServiceDef;
	webService 			: CM_QshipsWebServiceDef;		
	bgpObject			: BGP_QshipsRequest;
	edifile				: CM_EDIFile;
	input				: String;
	lastSuccessfullTS	: TimeStamp;
	terminalCode		: String;
	terminal			: CM_Terminal;
	passport			: CM_Passport;
	ediData				: CM_EDIData;
	origHarbour			: HMS_Harbour;
	harbour				: HMS_Harbour;
	wharf				: HMS_Wharf;
	berth				: HMS_Berth;	
	objectArray			: ObjectArray;
	berthArray			: StringArray;
	berthCode			: String;
	startingPos			: Integer;
	voyage				: CM_Voyage;
	isConverting		: Boolean;
	defVoyageProcess 	: String;
	utVoyProcess 		: CM_VoyageProcessDefault;
	isDoClearanceCheck	: Boolean;
	hmsData				: HMS_VoyageData;
	hmsMovementArrival,
	hmsMovementDep		: HMS_VoyageMovement;
	extDef				: CM_ExternalWebServiceDef;		// MTN-35988
	extDefsInactivated	: ObjectArray;					// MTN-35988
	obj 				: Object;						// MTN-35988
begin			
	//preserve value
	isDoClearanceCheck := self.getMyTerminal.myHarbour.isDoClearanceCheck;	
	//set to what the unit test needed
	self.setHarbourIsDoClearanceCheck(false);
	
	//preserve value
	isConverting := app.isConverting;	
	//set to what the unit test needed
	app.isConverting := true;
	
	terminalCode := self.getProfileSetting(UT_Profile.P_TERMINAL).asString;
	terminal := app.myRoot.allTerminals[terminalCode];
	self.assertNotNullMsg(terminal, "No terminal set, unable to run test");	
	
	//set to what the unit test needed
	utVoyProcess := CM_VoyageProcessDefault.firstInstance;
	defVoyageProcess := self.setTerminalConfig(DefaultVoyageProcess, utVoyProcess.code).String;	
	
	self.deleteVoyage(VoyageCodeConst);
	
	origHarbour := terminal.myHarbour;
	
	// clear terminal harbour so can add new one
	if origHarbour &lt;&gt; null and origHarbour.allTerminalsByCode.includes(terminal) then
		beginTransaction;
		origHarbour.allTerminalsByCode.remove(terminal);
		commitTransaction;
	endif;
	// harbour
	create objectArray transient;
	objectArray.add(terminal);
	self.opts.purge();
	self.opts.addAssoc("IgnoreWarnings", true);
	self.opts.addAssoc("Terminals", objectArray);

	harbour := app.myRoot.allHarbours["UTQSHIP"];
	if harbour = null then
		harbour := self.addHarbour("UTQSHIP", "Qship Test harbour").HMS_Harbour;		
	endif;
	
	// wharf
	wharf := harbour.allWharves["UTQWHARF"];
	if wharf = null then
		wharf := self.addWharf("UTQWHARF","Qships Test wharf", harbour, 1600, 100);
	endif;
	
	// berth Just incase the berth is missing
	create berthArray transient;
	berthArray.add("FIGR");

	startingPos := 0;
	foreach berthCode in berthArray do
		berth := harbour.allBerths[berthCode];
		if berth = null then	
			self.addBerth(berthCode, berthCode, harbour, startingPos, 100, 2.5, false, wharf);
		endif;
		startingPos += 100;
	endforeach;
		
	if harbour &lt;&gt; null and not harbour.allTerminalsByCode.includes(terminal) then
		beginTransaction;
			harbour.allTerminalsByCode.add(terminal);
		commitTransaction;
	endif;
	
	passport := app.myPassport;
	
	// MTN-35988 turn off all NSW external web services so that CM_EDIDataVoyage::setupMoveProxies doesn't mistakenly think we're NSW
	// and try charging for movements
	create extDefsInactivated transient;
	while true do
		extDef := app.myRoot.getFirstActiveEWSForEndpoint(ETRow_NswVesselMovements);
		if extDef &lt;&gt; null then
			beginTransaction;
			extDef.setActive(false);
			commitTransaction;
			extDefsInactivated.add(extDef);
			continue;
		endif;
		break;
	endwhile;
	
	//Create/Update the web service def, select both send in &amp; out and make active
	webService := app.myRoot.allExternalWebServices.getAtKey(ExternalWebServiceQships).CM_QshipsWebServiceDef;
	if webService = null then
		create pxyExtWebServiceDef as CM_QshipsWebServiceDef transient;
	else
		pxyExtWebServiceDef :=  app.createUpdateProxy( webService ).CM_QshipsWebServiceDef;
	endif;
	
	
	// Load the first Qships file	
	input := self.xmlDef_QshipsArrivalScheduled();
	create bgpObject transient;
	
	edifile := bgpObject.processResponse(input, null, pxyExtWebServiceDef, lastSuccessfullTS, terminal);
	self.assertNotNullMsg(edifile, "No edifile has been created.");	
	
	ediData := edifile.ediData;
	self.assertNotNullMsg(ediData, "No edidata has been created.");	
	
	self.assertEqualMsg(ediData.allEDITrackedItems.size,4, "Number of objects created is unmatched");	
	
	ediData.verifyEDIDataTIs(passport);
	
	ediData.loadDB(true, passport);
	self.assertEqualMsg(ediData.status, CM_EDIFile.EDI_STATUS_DBLOADED, "Status should be DB Loaded");	

	
	// Check that the correct voyage and movements has been created
	
	voyage := self.getVoyage(VoyageCodeConst);
	
	self.assertNotNullMsg(voyage, "The voyage: " &amp; VoyageCodeConst);
	
	hmsData	:= voyage.myHMSVoyageData;
	
	self.assertNotNullMsg(hmsData, "The voyage HMS data for voyage: " &amp; VoyageCodeConst);
	
	hmsMovementArrival := hmsData.getMovementForMoveType(HMSMovementTypeArrival);
	self.assertNotNullMsg(hmsMovementArrival, "The voyage HMS data for voyage: " &amp; VoyageCodeConst &amp; " has no arrival movement");	
	self.assertTrueMsg(hmsMovementArrival.moveStatusNEW = MovementStatus_Planned, "The arrival movement for voyage: " &amp; VoyageCodeConst &amp; " is not planned");
	
	hmsMovementDep := hmsData.getMovementForMoveType(HMSMovementTypeDeparture);
	self.assertNotNullMsg(hmsMovementDep, "The voyage HMS data for voyage: " &amp; VoyageCodeConst &amp; " has no departure movement");
	self.assertTrueMsg(hmsMovementDep.moveStatusNEW = MovementStatus_Planned, "The departure movement for voyage: " &amp; VoyageCodeConst &amp; " is not planned");
	
	
	// Load the second Qships file
	delete bgpObject;
	input := self.xmlDef_QshipsArrivalComplete();
	create bgpObject transient;
	
	edifile := bgpObject.processResponse(input, null, pxyExtWebServiceDef, lastSuccessfullTS, terminal);
	self.assertNotNullMsg(edifile, "No edifile has been created.");	
	
	ediData := edifile.ediData;
	self.assertNotNullMsg(ediData, "No edidata has been created.");	
	
	self.assertEqualMsg(ediData.allEDITrackedItems.size, 4, "Number of objects created is unmatched");	
	
	ediData.verifyEDIDataTIs(passport);
	
	ediData.loadDB(true, passport);
	self.assertEqualMsg(ediData.status, CM_EDIFile.EDI_STATUS_DBLOADED, "Status should be DB Loaded");	
	
	hmsData	:= voyage.myHMSVoyageData;
	
	self.assertNotNullMsg(hmsData, "The voyage HMS data for voyage: " &amp; VoyageCodeConst);
	
	hmsMovementArrival := hmsData.getMovementForMoveType(HMSMovementTypeArrival);
	self.assertNotNullMsg(hmsMovementArrival, "The voyage HMS data for voyage: " &amp; VoyageCodeConst &amp; " has no arrival movement");	
	self.assertTrueMsg(hmsMovementArrival.moveStatusNEW = MovementStatus_Actual, "The arrival movement for voyage: " &amp; VoyageCodeConst &amp; " is not actual");
	
	hmsMovementDep := hmsData.getMovementForMoveType(HMSMovementTypeDeparture);
	self.assertNotNullMsg(hmsMovementDep, "The voyage HMS data for voyage: " &amp; VoyageCodeConst &amp; " has no arrival movement");
	self.assertTrueMsg(hmsMovementDep.moveStatusNEW = MovementStatus_Planned, "The departure movement for voyage: " &amp; VoyageCodeConst &amp; " is not planned");
	
	
	// Load the third Qships file
	delete bgpObject;	
	input := self.xmlDef_QshipsArrivalReleased();
	create bgpObject transient;
	
	edifile := bgpObject.processResponse(input, null, pxyExtWebServiceDef, lastSuccessfullTS, terminal);
	self.assertNotNullMsg(edifile, "No edifile has been created.");	
	
	ediData := edifile.ediData;
	self.assertNotNullMsg(ediData, "No edidata has been created.");	
	
	self.assertEqualMsg(ediData.allEDITrackedItems.size, 4, "Number of objects created is unmatched");	
	
	ediData.verifyEDIDataTIs(passport);
	
	ediData.loadDB(true, passport);
	self.assertEqualMsg(ediData.status, CM_EDIFile.EDI_STATUS_DBLOADED, "Status should be DB Loaded");	
	
	hmsData	:= voyage.myHMSVoyageData;
	
	self.assertNotNullMsg(hmsData, "The voyage HMS data for voyage: " &amp; VoyageCodeConst);
	
	hmsMovementArrival := hmsData.getMovementForMoveType(HMSMovementTypeArrival);
	self.assertNotNullMsg(hmsMovementArrival, "The voyage HMS data for voyage: " &amp; VoyageCodeConst &amp; " has no arrival movement");	
	self.assertTrueMsg(hmsMovementArrival.moveStatusNEW = MovementStatus_Actual, "The arrival movement for voyage: " &amp; VoyageCodeConst &amp; " is not actual");
	
	hmsMovementDep := hmsData.getMovementForMoveType(HMSMovementTypeDeparture);
	self.assertNotNullMsg(hmsMovementDep, "The voyage HMS data for voyage: " &amp; VoyageCodeConst &amp; " has no arrival movement");
	self.assertTrueMsg(hmsMovementDep.moveStatusNEW = MovementStatus_Planned, "The departure movement for voyage: " &amp; VoyageCodeConst &amp; " is not planned");
	
	
	// Load the fourth Qships file
	delete bgpObject;	
	input := self.xmlDef_QshipsDeparturePlanned();
	create bgpObject transient;
	
	edifile := bgpObject.processResponse(input, null, pxyExtWebServiceDef, lastSuccessfullTS, terminal);
	self.assertNotNullMsg(edifile, "No edifile has been created.");	
	
	ediData := edifile.ediData;
	self.assertNotNullMsg(ediData, "No edidata has been created.");	
	
	self.assertEqualMsg(ediData.allEDITrackedItems.size, 4, "Number of objects created is unmatched");	
	
	ediData.verifyEDIDataTIs(passport);
	
	ediData.loadDB(true, passport);
	self.assertEqualMsg(ediData.status, CM_EDIFile.EDI_STATUS_DBLOADED, "Status should be DB Loaded");	
	
	hmsData	:= voyage.myHMSVoyageData;
	
	self.assertNotNullMsg(hmsData, "The voyage HMS data for voyage: " &amp; VoyageCodeConst);
	
	hmsMovementArrival := hmsData.getMovementForMoveType(HMSMovementTypeArrival);
	self.assertNotNullMsg(hmsMovementArrival, "The voyage HMS data for voyage: " &amp; VoyageCodeConst &amp; " has no arrival movement");	
	self.assertTrueMsg(hmsMovementArrival.moveStatusNEW = MovementStatus_Actual, "The arrival movement for voyage: " &amp; VoyageCodeConst &amp; " is not actual");
	
	hmsMovementDep := hmsData.getMovementForMoveType(HMSMovementTypeDeparture);
	self.assertNotNullMsg(hmsMovementDep, "The voyage HMS data for voyage: " &amp; VoyageCodeConst &amp; " has no arrival movement");
	self.assertTrueMsg(hmsMovementDep.moveStatusNEW = MovementStatus_Planned, "The departure movement for voyage: " &amp; VoyageCodeConst &amp; " is not planned");
epilog			
	//reset to original value	
	self.setHarbourIsDoClearanceCheck(isDoClearanceCheck);
	self.setTerminalConfig( DefaultVoyageProcess, defVoyageProcess );	
	app.isConverting := isConverting;
	
	delete objectArray;
	// restore original harbour
	if terminal &lt;&gt; null and origHarbour &lt;&gt; null and
	   global.isValidObject(origHarbour) then	   
		beginTransaction;
		if harbour &lt;&gt; null and harbour.allTerminalsByCode &lt;&gt; null and 
				harbour.allTerminalsByCode.includes(terminal) then
			harbour.allTerminalsByCode.remove(terminal);
		endif;
		origHarbour.allTerminalsByCode.add(terminal);
		commitTransaction;
	endif;
	
	// MTN-35988 turn on all the NSW external web service defs that we turned off
	foreach obj in extDefsInactivated do
		extDef := obj.CM_ExternalWebServiceDef;
		beginTransaction;
		extDef.setActive(true);
		commitTransaction;
	endforeach;
	delete extDefsInactivated;
	
	beginTransaction;
	berthArray.purge();
	delete berthArray;
	delete pxyExtWebServiceDef;
	delete bgpObject;
	commitTransaction;
end;</source>
    </JadeMethod>
    <JadeMethod name="uAllotracCreateBGPRequest" id="1711d48a-338f-4e62-a0df-4b89585e1e5f">
        <source>uAllotracCreateBGPRequest();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 August 2020	jlgndl1	Initial creation	TFS 49869

*/

vars

	obj : Object;
	ti : CM_TrackedItem;
	receive : CM_Receive;
	release : CM_Release;
	edition : Integer;
	invalid : Boolean;
	receiveStr : String;
	releaseStr : String;
	wsRequest1 : BGP_AllocWSRequest;
	wsRequest2 : BGP_AllocWSRequest;

begin

	//Make sure the 'Allotrac Web Subscription' is valid.
	//Setup an 'External Web Service' with 'Web Service Type' = ALLOTRAC.
	//Setup a BGP Manager with "No. Ext Web Services" set to '1' (or add one to the count of an existing one)  This will add a BGP controller to the BGP Manager for configuring.
	//In the new BGP controller, select an ADMIN user, and the ALLOTRAC 'External Web Service', and the Ternminal to send from.
	//Find a cargo item with the 'clientRef' field populated.
	
	on Exception do app.handleDeletedObject( exception, obj, invalid );
	
//	obj := "2367.36776716".asOid;
//	obj := "2367.44419045".asOid;
	obj := "2367.179177".asOid;	//"TESTAD1001" in CNWCJMT 'LINX PCC'
	
	if obj &lt;&gt; null then
		edition := obj.edition;
	endif;
	
	if invalid or obj = null then
		app.msgBox( "No object found", "Wrong OID", MsgBox_OK_Only );
		return;
	else
		if obj.isKindOf( CM_TrackedItem ) then
			ti := obj.CM_TrackedItem;
		else
			app.msgBox(  obj.String &amp; " is not a Tracked Item", "Wrong OID", MsgBox_OK_Only );
			return;
		endif;
	endif;
	
	receive := ti.getLastTransOfTypeAdv( TRANS_TYPE_RECEIVE ).CM_Receive;
	beginTransaction;
	receiveStr := ti.id &amp; CrLf &amp; ti.createAllotracBGPRequest( receive, wsRequest1 );
	commitTransaction;
	app.msgBox( receiveStr, "Receive Transaction", MsgBox_OK_Only );
	
	release := ti.getLastTransOfTypeAdv( TRANS_TYPE_RELEASE ).CM_Release;
	if release &lt;&gt; null then
		beginTransaction;
		releaseStr := ti.id &amp; CrLf &amp; ti.createAllotracBGPRequest( release, wsRequest2 );
		commitTransaction;
		app.msgBox(  releaseStr, "Release Transaction", MsgBox_OK_Only );
	endif;
	
/*	if wsRequest1 &lt;&gt; null then
		if app.msgBox(  "Do you want to attempt to send the Receive Transaction?", "Send Receive Transaction?", MsgBox_Yes_No ) = MsgBox_Return_Yes then
			//will show in Activity History
			wsRequest1.action();
		endif;
	endif;
	
	if wsRequest2 &lt;&gt; null then
		if app.msgBox(  "Do you want to attempt to send the Releasee Transaction?", "Send Release Transaction?", MsgBox_Yes_No ) = MsgBox_Return_Yes then
			wsRequest2.action();
		endif;
	endif; */


epilog

	abortTransaction;

end;</source>
    </JadeMethod>
    <JadeMethod name="uOpsviewGCWSNoJobsNoMachines" id="7ca19996-df0e-492b-9621-212f0289269d">
        <source>uOpsviewGCWSNoJobsNoMachines();
/*
Purpose:			

Date		Who		Reason
28 June 2022	navab1	TFS 53105
*/
constants
	Vessel_Name			: String = "UTOPSVH";
	Voyage_Name			: String = "UTOPSVH";
	Cargo_Type			: String = "UTREBAR"; // Break Bulk
	Sleep = 1;
vars
	vessel	: CM_Vessel;
	voyage	: CM_Voyage;
	bs1		: CM_BlockStack;
	cargoOnship, cargoOnSite	: CM_TrackedItem;
	cargoType : CM_CargoType;
	lc: CM_LocationsController;
	height: Integer;
	idx : Integer;
begin
	
	/* Clearup */
	
	

	/* Create Vessel */
	vessel := self.addVesselWithHolds(Vessel_Name, 2, 2);
	self.assertNotNullMsg(vessel, "Vessel is Null");
	
	/* Create Voyage - Default Process */
	voyage := self.addVoyageWithGeneralCargoStruc(Voyage_Name, vessel.name, vessel.myOperator.code,	self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString(), 0);
	self.assertNotNullMsg(voyage, "Voyage is Null");
	
	
	bs1 := self.addBlockStack("UTOPSBS1", 9999, null);
	self.assertNotNullMsg(bs1, "BlockStack is Null");
	
	/* Create cargo on voyage */
	cargoType := app.myRoot.getCargoTypeFromAbbrev(Cargo_Type);
	self.getTerminal.findLocationFromString("UT_OPS_VHOLDS 0101", true, lc, height); 	
	
	//cargoOnship := self.addCargoBreakBulkAtLocation("UTOPSCTYPE7", cargoType, 50, lc, null, TI_IMEX_STATUS_IMPORT, voyage, vessel.myOperator);
	foreach idx in 10 to 30 do
		cargoOnship := self.addOpsBreakBulkCargoAtLocation(cargoType,lc,voyage,vessel, "UTOPSCNTU"&amp; idx.String,TI_IMEX_STATUS_IMPORT);
	endforeach;
	
	self.assertNotNullMsg(cargoOnship, "Onship cargo is Null");
	
	/* Create cargo for voyage on site */
	
	//cargoOnSite:=self.addCargoAtLocation("UTOPSCTYPE8", cargoType, self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString), bs1.myLocationsController);
	foreach idx in 50 to 70 do
		cargoOnSite := self.addOpsBreakBulkCargoAtLocation(cargoType,bs1.myLocationsController,voyage,vessel, "UTOPSCNTU"&amp; idx.String,TI_IMEX_STATUS_EXPORT);
	endforeach;
	self.assertNotNullMsg(cargoOnSite, "Onsite cargo is Null");
	
	/* Set voyage status to Arrived	*/
	self.updateVoyageStatus(Voyage_Status_Arrived,voyage);
	
	/* Set voyage status to Loading */
	updateVoyageStatus(Voyage_Status_Loading,voyage);
	
	/* Move cargo from voyage to yard */
	foreach idx in 10 to 20 do
		cargoOnship := self.getTrackedItem( "UTOPSCNTU"&amp; idx.String );		
		moveBreakBulk(cargoOnship, bs1.myLocationsController, 50);
		process.sleep(Sleep);
		moveBreakBulk(cargoOnship, bs1.myLocationsController, 30);
		process.sleep(Sleep);
		moveBreakBulk(cargoOnship, bs1.myLocationsController, 20);
		process.sleep(Sleep);
	endforeach;	
	
	/* Move cargo from yard to voyage */
	//moveBreakBulk(cargoOnSite,lc, 1);
	foreach idx in 50 to 60 do
		cargoOnSite := self.getTrackedItem( "UTOPSCNTU"&amp; idx.String );
		moveBreakBulk(cargoOnSite, lc, 50);
		process.sleep(Sleep);
		moveBreakBulk(cargoOnSite, lc, 30);
		process.sleep(Sleep);
		moveBreakBulk(cargoOnSite, lc, 20);
		process.sleep(Sleep);
	endforeach;	
	
	/* Set voyage status to completed */
	updateVoyageStatus(Voyage_Status_Closed,voyage);
	
	/* Set voyage status to Departed */
	updateVoyageStatus(Voyage_Status_Departed,voyage);
	

epilog

end;</source>
    </JadeMethod>
