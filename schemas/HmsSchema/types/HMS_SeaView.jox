    <JadeMethod name="showHideMarksRemarks" id="c8b3a1db-208c-48a9-a0c8-d4060d575c51">
        <source>showHideMarksRemarks(_remarks : Boolean);
//--------------------------------------------------
// Created:	22 July 2004 By: cnwgd1
//--------------------------------------------------
vars
	vessel : String;
begin
	self.txtRemarks.text := null;
	self.tblMeterMarks.clearValues();
	
	if self.frmMeterMarks.visible then
		self.frmMeterMarks.visible := false;
		self.btnCancelBase.enabled := true;		
		return;
	endif;
			
	if self.myCurrentWorkingMovement = null then
		return;
	endif;
	
	vessel := self.myCurrentWorkingMovement.vesselName;
					
	if _remarks then
		self.lblMeterMarks.caption := 'Remarks: ' &amp; vessel;
		self.txtRemarks.visible := true;
		self.tblMeterMarks.visible := false;
		self.txtRemarks.text := self.myCurrentWorkingMovement.remarks;
		self.txtRemarks.setFocus();
	else
		self.lblMeterMarks.caption := 'Meter Marks: ' &amp; vessel;
		self.tblMeterMarks.visible := true;
		self.txtRemarks.visible := false;
		if self.myCurrentWorkingMovement.moveType = HMSMovementTypeDeparture then
			self.tblMeterMarks.setTableFromObject(self.myCurrentWorkingMovement.getMovementPrevious(), 'setTableFromObjectSpecial');			
			self.tblMeterMarks.disableRowByName(ETRow_MyBerth);
		else
			self.tblMeterMarks.setTableFromObject(self.myCurrentWorkingMovement, 'setTableFromObjectSpecial');			
			self.tblMeterMarks.enableRowByName(ETRow_MyBerth);		
		endif;
	endif;
	
	self.btnCancelBase.enabled := false;
	self.frmMeterMarks.visible := true;
	self.frmMeterMarks.centreWindow();

	if _remarks then
		self.txtRemarks.setFocus();		
	else
		self.tblMeterMarks.setFocus();
		self.tblMeterMarks.moveFirst();
	endif;
end;</source>
        <Parameter name="_remarks" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="showMovement" id="28726e00-d91f-4108-8919-3f8f215cff87">
        <updating/>
        <source>showMovement(workingMovement: CMIF_HMS_WorkingMovement) updating;
//-----------------------------------------
// Created: July 2004 By: cnwgd1
//-----------------------------------------
vars
	idx:			Integer;
begin

 	// This method adds the voyage details of a ship to the list of ships at the target berth
 	// NOTE: The default target berth is the non-booked berth. 

	if workingMovement.moveType = HMSMovementTypeDeparture then
		return;
	endif;

	self.tblMovement.addItemObject(workingMovement, workingMovement.getAttributeStringForDefArray(self.tblMovement.allTblDataEntRows));

/*	idx := self.tblMovement.addItemObject(workingMovement, workingMovement.getAttributeStringForDefArray(self.tblMovement.allTblDataEntRows));

	if self.tblMovement.rows mod 2 = 0 then
		self.tblMovement.accessRow(idx).backColor := self.colorRow2;
	else
		self.tblMovement.accessRow(idx).backColor := self.colorRow1;	
	endif;*/

end;</source>
        <Parameter name="workingMovement" type="CMIF_HMS_WorkingMovement"/>
    </JadeMethod>
