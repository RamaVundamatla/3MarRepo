    <JadeMethod name="trxCreateEDITI" id="9b448faf-a7b6-4554-ab1a-19ba103ff4b8">
        <updating/>
        <source>trxCreateEDITI(_ediData: CM_EDIData; _ediTIClass: Class; _passport: CM_Passport input): CM_EDITrackedItem updating;
//----------------------------------------------------------------
//	Created:	05 September 2003	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
// 18 Jan 2019	jlgrs1	TFS 41659 42276 STWR Make EDI MultiThreaded Stage 8
// 08 Apr 2019	jlgrs1	TFS 41913 STWR - Reconfiguration of the EDI Operation form to better handle EDI collection locks while loading 
//
vars
	ediTI : CM_EDITrackedItem;
begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);
	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	app.setContinueCMExceptions(false);
	// Start the transaction
	beginTransaction;
	ediTI := app.myUtilityCA.utlCreateEDITI(_ediData, _ediTIClass, _passport);
	if not tryLock(_ediData.ediConfig, Exclusive_Lock, Transaction_Duration, LockTimeout_Server_Defined) then
		self.exclusiveLock(_ediData.ediConfig);
	endif;
	if not tryLock(_ediData.ediConfig.allEDITrackedItemsByIdStatus, Exclusive_Lock, Transaction_Duration, LockTimeout_Server_Defined) then
		self.exclusiveLock(_ediData.ediConfig.allEDITrackedItemsByIdStatus);
	endif;
	ediTI.setMyEDIData(_ediData);
	ediTI.setMyEDIConfig(_ediData.ediConfig);
	return ediTI;
epilog
	self.finaliseActivityWithPassport(_passport);	
end;</source>
        <Parameter name="_ediData" type="CM_EDIData"/>
        <Parameter name="_ediTIClass" type="Class"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <ReturnType type="CM_EDITrackedItem"/>
    </JadeMethod>
    <JadeMethod name="trxCreateEDITIsCargo" id="1e69a2b1-f1e1-4854-84db-de867961cab7">
        <updating/>
        <source>trxCreateEDITIsCargo(_control : CMIF_TIUpdateController input; _ediData : CM_EDIData input; _validateOnly : Boolean; _passport : CM_Passport input) updating;
/*
----------   ----------  --------------------------------------------------
Created:	03 August 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
//21 Feb 2013	cnwrs1	Par 31143 EDI TRX not handling dbLoadErrors after no verify errors take 2
//04 Aug 2014	cnwrs1	Par 34668	EDI Status can be wrong if doDeferredUpdate fails
*/
vars
	realTI,
	pxyTI				: CM_TrackedItem;
	moveController 		: CMIF_MoveController;
	foundLocation 		: CM_LocationsController;
	strArray			: StringArray;
	expectedEdition,
	foundHeight,
	startPos			: Integer;
	status : Integer;
begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	_passport.useTITransactionDeferUpdate := false; //par14503 sh3 July 2007
	_passport.useTIDictDeferUpdate := false;
	
	app.myValCA.valTrackedItems(_control, _passport);

	// ensure any locks are cleared
	endLoad;

	if _passport.noErrors then			// PAR 21724
		beginTransaction;
		app.setContinueCMExceptions(false);
		self.createTrackedItems(_control, _passport);

		realTI := _control.allPersistentTIs.first;
		if realTI &lt;&gt; null and realTI.state = TI_STATE_NOTIFIED then
			//we don't don't need to move them anywhere, but we do need to generate a pin #
			app.myUtilityUA.utlUpdateGeneratePin(_control.allPersistentTIs, null, true, _passport);
		else
			//move the TIs
			create strArray transient;
			create moveController transient;
			moveController.setMoveMode(REAL_MODE);
			moveController.isSystemMove := true;
			_passport.warningsAcknowledged := true;
			foreach realTI in _control.allPersistentTIs do
				foundLocation := null;
				if realTI.site = TI_SITE_ONSHIP then
					startPos := realTI.myVoyage.code.length + 2;
					strArray.clear();
					if realTI.locationId.length &gt;= startPos then
						strArray.add(realTI.locationId[startPos:end]);
					else
						strArray.add(realTI.locationId);
					endif;
					
					 realTI.myVoyage.findLocation(strArray, false, foundLocation, foundHeight);
			
					if foundLocation = null then
						app.raiseCMException1(ERR_INVALID_STOWAGE,  strArray[1] &amp; ", for ti "&amp; realTI.id, ETRow_LocationId, null);
						break;
					endif;
				elseif realTI.site = TI_SITE_ONSITE then
					realTI.myTerminal.findLocationFromString(realTI.locationId, false, foundLocation, foundHeight);
					if foundLocation = null then
						app.raiseCMException1(ERR_INVALID_LOCN,  realTI.locationId &amp; ", for ti " &amp; realTI.id, ETRow_LocationId, null);
						break;
					endif;
				endif;
				moveController.setMyToPrimaryLocation(foundLocation);
				moveController.setMyToSecondaryLocations(null);
				moveController.setMyTrackedItem(realTI);
				
				moveController.setWeight(0);	//02 May 2018	NDL	TFS 38365
				moveController.setQuantity(0);	//02 May 2018	NDL	TFS 38365
				
//process.writeRJS(class.name &amp; '::' &amp; method.name &amp; '  moving ' &amp; realTI.id &amp; ' to ' &amp; realTI.locationId);
				
				app.myUtilityUA.utlUpdateMoveTrackedItem(moveController, _passport);	
				
				if _passport.hasErrors then			// PAR 21724
					break;
				endif;

			endforeach;
		endif;
	endif;
	
	if _validateOnly and _passport.noErrors then
		// sucessful validate - abort then update status in new transaction
		// we need to abort here as it won't get done for us in self.finaliseActivityWithPassport
		app.cmsAbortTransaction();
		return;
	else
		if _passport.noErrors() then
			// sucessful DB Load so update status in same transaction
			_passport.doDeferredUpdates();
			if _passport.noErrors() then
				// use passport to get new status for EDI Data
				status := _ediData.getStatusAfterVerifyOrDBLoad (_validateOnly, _passport);
				app.myUtilityUA.utlSetEDIDataStatusAfterVerify(_ediData, status);
			endif;
		endif;
	endif;
epilog
	self.finaliseActivityWithPassport(_passport);

	if _validateOnly or _passport.hasErrors then
		// use passport to get new status for EDI Data
		status := _ediData.getStatusAfterVerifyOrDBLoad (_validateOnly, _passport);
		app.myTrxUA.trxSetEDIDataStatusAfterVerify(_ediData, status);	// par 27392 cnwrs1 14 Apr 2011
	endif;
	delete moveController;
	delete strArray;
end;</source>
        <Parameter name="_control" type="CMIF_TIUpdateController" usage="input"/>
        <Parameter name="_ediData" type="CM_EDIData" usage="input"/>
        <Parameter name="_validateOnly" type="Boolean"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxCreateEDITisTranShip" id="6e999b4c-6861-48b9-9232-af4da5819b71">
        <updating/>
        <source>trxCreateEDITisTranShip(_ediData : CM_EDIDataTranship input; _validateOnly : Boolean; _passport : CM_Passport input) updating;
//
// par 26215 cnwrs1 15 Nov 2010
/* Changes

Date		Name	TFS#		Description
============================================================================
21 Feb 2013	cnwrs1	Par 31143 	EDI TRX not handling dbLoadErrors after no verify errors take 2
14 Nov 2013	cnwrs1	Par32985 	processing EDI tranships twice
04 Aug 2014	cnwrs1	Par 34668	EDI Status can be wrong if doDeferredUpdate fails
08 Oct 2015	cnwrs1	Par 36863 	make EDI consistant times when refreshing progress bar
16 May 2016	cnwns1	TFS 488 	Multi Timezone Support
03 Sep 2019 jlgka1 	TFS 45332 	STWR - Better Forms and Interfaces for EDI Module
29 Oct 2019	cnwrs1	TFS 47281
20 Oct 2020	jlgmd1	TFS 50204	Refactor progress updates to superclass method
============================================================================*/

vars
	controller 	: CMIF_TranshipTIController;
	startEDITI 	: CM_EDITranshipTI;
	status 		: Integer;
	total 		: Integer;
	count 		: Integer;
	progressTS 	: TimeStamp;
begin
	progressTS := app.actualTimeServer();// 16 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);
	
	app.setContinueCMExceptions(true);
	
	create controller transient;
	
	total := _ediData.allEDITrackedItems.size;
	count := null;
	_ediData.updateProgress(progressTS, "Validating Cargo " &amp; count.String &amp; "/" &amp; total.String, total, count, true, _passport);
	
	beginTransaction;
	
	_passport.useTITransactionDeferUpdate := true; // PAR 13204
	_passport.useTIDictDeferUpdate := true; // PAR 13204
	
	while true do
		_ediData.setControllerFromEDITIs(controller, startEDITI);
		count := count + controller.allTrackedItems.size;
		_ediData.updateProgress(progressTS, "Validating Cargo " &amp; count.String &amp; "/" &amp; total.String, total, count, false, _passport);		
		
		// Perform the operation
		if not controller.allTrackedItems.isEmpty then	//14 Nov 2013	cnwrs1	Par32985 processing EDI tranships twice
			app.myUtilityCA.utlCreateTisTranShipEDI(controller, _passport);
		endif;
		if not process.isInTransactionState then  //par 26412 cnwrs1 24 nov 2010
			break;
		endif;
		if startEDITI = null then
			break;
		endif;
	endwhile;
	
	_ediData.updateProgress(progressTS, "Validating Cargo " &amp; count.String &amp; "/" &amp; total.String, total, count, true, _passport);
	
	if _validateOnly and _passport.noErrors then
		// sucessful validate - abort then update status in new transaction
		// we need to abort here as it won't get done for us in self.finaliseActivityWithPassport
		app.cmsAbortTransaction();
		return;
	else
		if _passport.noErrors() then
			// sucessful DB Load so update status in same transaction
			_passport.doDeferredUpdates();
			if _passport.noErrors() then
				// use passport to get new status for EDI Data
				status := _ediData.getStatusAfterVerifyOrDBLoad (_validateOnly, _passport);
				app.myUtilityUA.utlSetEDIDataStatusAfterVerify(_ediData, status);
			endif;
		endif;
	endif;
epilog
	self.finaliseActivityWithPassport(_passport);

	if _validateOnly or _passport.hasErrors then
		// use passport to get new status for EDI Data
		status := _ediData.getStatusAfterVerifyOrDBLoad (_validateOnly, _passport);
		app.myTrxUA.trxSetEDIDataStatusAfterVerify(_ediData, status);	// par 27392 cnwrs1 14 Apr 2011
	endif;
	delete controller;
end;</source>
        <Parameter name="_ediData" type="CM_EDIDataTranship" usage="input"/>
        <Parameter name="_validateOnly" type="Boolean"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxCreateEDITrainConsist" id="858b6ea9-e4dd-413d-a408-44ebbb0b22f2">
        <updating/>
        <source>trxCreateEDITrainConsist(_pxyTrains : CM_ObjectArray input; _pxyWagons : CM_ObjectArray input; _prenoteIntFaceArray : CMIF_TIObjectArray; _validateOnly : Boolean; _terminal : CM_Terminal; _ediData : CM_EDIData; _passport : CM_Passport input) updating;

//ccms1008 messina  cnwrs1 Sept 2009

vars
	pxyTrain : CM_Train;
	realTrain : CM_Train;
	pxyWagon : CM_Wagon;
	realWagon : CM_Wagon;
	obj : Object;
	itemObj	: CMIF_TIObject;
	wagonController : CMIF_WagonUpdateController;
begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	app.setContinueCMExceptions(false);
	// Start the transaction
	beginTransaction;

	// Perform the operation
	foreach obj in _pxyTrains do
		pxyTrain := obj.CM_Train;
		app.myUtilityCA.utlCreateTrain(pxyTrain, realTrain, false, true, _passport);
	endforeach;
	if _passport.hasErrors() then
		return;
	endif;

	create wagonController transient;
	foreach obj in _pxyWagons do
		pxyWagon := obj.CM_Wagon;
		realTrain	:=	_passport.myTerminal.allTrainsOnTerminal.getAtKeyGeq(pxyWagon.myTrainInwards.code, null);
		
		if realTrain = null or (realTrain.code &lt;&gt; null and realTrain.code &lt;&gt; pxyWagon.myTrainInwards.code) then
			app.raiseUnexpectedProgramError(class.name, method.name, "Newly created train could not be found (" &amp; pxyWagon.myTrainInwards.code &amp; ").");
		endif;
		
		wagonController.setBasicDetails(CMIF_WagonUpdateController.Mode_Add,
										null,
										realTrain,
										realTrain.allWagonsByIdInward.size + 1,
										true);
		wagonController.myProxyWagon := pxyWagon;
		pxyWagon.setMyTrain(true, realTrain);
		pxyWagon.setMyTrain(false, realTrain);
		app.myUtilityCA.utlCreateWagonFromCMIF(wagonController, realWagon, false, true, _passport);
	endforeach;
	if _passport.hasErrors() then
		return;
	endif;

	foreach itemObj in _prenoteIntFaceArray do
		if itemObj.isKindOf(CMIF_PreNote) then
			if app.isSubTerminalsOn(itemObj.myTerminal) then
				if itemObj.mySubTerminal = null then
					itemObj.setSubTerminalDefault();
				endif;
			endif;
			
			itemObj.validateForCreate(_passport);		//Also does the sub items
			
			if _passport.allErrors.size &gt; 100 then
				app.setContinueCMExceptions(false);  // dh 10/7/2008 par 17254 added this option for performance
			else
				app.setContinueCMExceptions(true);
			endif;
		else
			app.raiseUnexpectedProgramError(class.name, method.name, 'Item is not a preNote (' &amp; itemObj.String &amp; ')');
		endif;
	endforeach;
	
	if _passport.hasErrors() then
		return;
	endif;
	
	app.setContinueCMExceptions(true);
	
//	endLoad;
	
	if not _validateOnly then
		_passport.useTIDictDeferUpdate := true;
		_passport.useTITransactionDeferUpdate := true;
	endif;
	
	app.myUtilityCA.utlCreatePreNotes(_prenoteIntFaceArray, _validateOnly, _passport);
	
	if _validateOnly then
		app.cmsAbortTransaction();
		return; //ccms1845
	else
		if _passport.noErrors() then
			_passport.doDeferredUpdates();
		endif;
	endif;
	if app.myPassport.noErrors then //ccms1845
		app.myUtilityUA.utlSetEDIDataStatus(_ediData, CM_EDIFile.EDI_STATUS_DBLOADED, null); //ccms1845
	endif;

epilog
	self.finaliseActivityWithPassport(_passport);
end;


</source>
        <text>to be deletd
//04 Feb 2013	cnwrs1	Par 31119 include Tranships as ROBs for EDI Proposed</text>
        <Parameter name="_pxyTrains" type="CM_ObjectArray" usage="input"/>
        <Parameter name="_pxyWagons" type="CM_ObjectArray" usage="input"/>
        <Parameter name="_prenoteIntFaceArray" type="CMIF_TIObjectArray"/>
        <Parameter name="_validateOnly" type="Boolean"/>
