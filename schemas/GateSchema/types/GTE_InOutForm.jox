    <JadeMethod name="getCellControl" id="72e66ccb-7f19-423f-be9b-8dc50b7f5018">
        <source>getCellControl(pName : String) : Control;
// ---------------------------------------------------------------------------
// Created:     10 November 2000 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 19/11/2009	cnwmh5		PAR21492 - Add cmbSysSubType
// 20/05/2013	cnwdap1		PAR #31574 Add txtTimeOffPower
// ---------------------------------------------------------------------------
vars
	sheet	: GTE_Sheet;

begin

	if pName = GTE_InOutForm::cmbCarrier.name or
	   pName = GTE_InOutForm::txtTrailerNumber.name or	
	   pName = GTE_InOutForm::txtRegNumber.name or
	   pName = GTE_InOutForm::cmbTILCTypes.name or
	   pName = GTE_InOutForm::cmbTILCOut.name or
	   pName = GTE_InOutForm::cmbTILCType.name or
	   pName = GTE_InOutForm::cmbOpChassis.name then
		return self.getControl(pName);
	endif;

	if pName = GTE_InOutForm::cmbBulkRelease.name or
	   //pName = GTE_InOutForm::cmbCarriageTempC.name or
	   //pName = GTE_InOutForm::cmbCarriageTempF.name or
	   pName = GTE_InOutForm::cmbCommodity.name or
	   pName = self.Cntrl_cmbConsignorTop or
	   pName = GTE_InOutForm::cmbConsignee.name or
	   pName = GTE_InOutForm::cmbConsignor.name or
	   pName = GTE_InOutForm::cmbFreightFwdr.name or 	// 20/11/2006 par#12903 Mohammad
	   pName = GTE_InOutForm::cmbCouISOType.name or
	   pName = GTE_InOutForm::cmbDestination.name or
	   pName = GTE_InOutForm::cmbDestTerminal.name or	   	   	   	   	   	   	   	   	   	   	   	   	   
	   pName = GTE_InOutForm::cmbDischarge.name or
	   pName = GTE_InOutForm::cmbTranship.name or
	   pName = GTE_InOutForm::cmbHdlCntr1.name or
	   pName = GTE_InOutForm::cmbHdlCntr2.name or
	   pName = GTE_InOutForm::cmbHdlSubCntr1.name or	   	   
	   pName = GTE_InOutForm::cmbISOType.name or
	   pName = GTE_InOutForm::cmbImexStatus.name or
	   pName = GTE_InOutForm::cmbLogLength.name or	   	   	   
	   pName = GTE_InOutForm::cmbLogGrade.name or
	   pName = GTE_InOutForm::cmbLogSpecies.name or
	   pName = GTE_InOutForm::cmbDocketError.name or //ccms 1110
	   pName = GTE_InOutForm::cmbLogType.name or
	   pName = GTE_InOutForm::cmbMTGrade.name or
	   pName = GTE_InOutForm::cmbOperator.name or
	   pName = GTE_InOutForm::cmbOperatorGroup.name or
	   pName = GTE_InOutForm::cmbProduct.name or
	   //pName = GTE_InOutForm::cmbPackTempC.name or
	   //pName = GTE_InOutForm::cmbPackTempF.name or
	   pName = GTE_InOutForm::cmbScaler.name or
	   pName = GTE_InOutForm::cmbSrcLocn.name or	   	   
	   pName = GTE_InOutForm::cmbSrcSubLocn.name or	   	   
	   pName = GTE_InOutForm::cmbSrcSubSubLocn.name or
	   pName = GTE_InOutForm::cmbStockOrder.name or	
	   pName = GTE_InOutForm::cmbSupplier.name or
	   pName = GTE_InOutForm::cmbTerminal.name or	   	   	   	   	   	   	   	   	   	   	   	   	   
	   pName = GTE_InOutForm::cmbTermArea.name or	   	   	   	   	   	   
	   pName = GTE_InOutForm::cmbTI.name or
	   pName = GTE_InOutForm::cmbTiType.name or
	   pName = GTE_InOutForm::cmbSubTerminal.name or
	   pName = GTE_InOutForm::cmbTreatment.name or	   	   	    
	   pName = GTE_InOutForm::cmbVoyage.name or
	   pName = GTE_InOutForm::lstDischarge.name or
	   pName = GTE_InOutForm::lstHazardList.name or
	   pName = GTE_InOutForm::lstMTGrade.name or
	   pName = GTE_InOutForm::txtBookingRef.name or
	   pName = GTE_InOutForm::cmbBRItem.name or // AER 12/01/2008 CCMS 1003
//	   pName = GTE_InOutForm::txtFellDate.name or	   
//	   pName = GTE_InOutForm::txtPackTime.name or
//	   pName = GTE_InOutForm::txtTimeOffPower.name or
	   pName = GTE_InOutForm::txtQuantity.name or
	   pName = GTE_InOutForm::txtDPCount.name or
	   pName = GTE_InOutForm::cmbLogLocation.name or
	   pName = GTE_InOutForm::cmbLogOperation.name or
	   pName = GTE_InOutForm::cmbProduct.name or
	   pName = GTE_InOutForm::cmbRowArea.name or
	   pName = GTE_InOutForm::cmbAvGrade.name or
	   pName = GTE_InOutForm::cmbCustomsAgent.name or
	   pName = GTE_InOutForm::cmbLoggingOrg.name or	  
   	   pName = GTE_InOutForm::cmbGenSetType.name or
	   pName = GTE_InOutForm::cmbSysSubType.name or		// 19/11/2009 cnwmh5 par21492
	   pName = GTE_InOutForm::cmbTrailerType.name or	// 23/02/2010 cnwar2 #22457
	   pName = GTE_InOutForm::txtTimeOffPower.name or	// PAR #31574
	   pName = GTE_InOutForm::txtTrackedItemID.name then
	   	return self.getTopSheetControl(pName);
	endif;

	return null;
	
end;</source>
        <Parameter name="pName" type="String"/>
        <ReturnType type="Control"/>
    </JadeMethod>
    <JadeMethod name="getInterTermTI" id="104e5e62-8dd8-4d3c-b050-f6a36ebd8bca">
        <source>getInterTermTI(pCode : String) : CM_TrackedItem protected;
//----------------------------------------------------------------
//	Created:	23 July 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	tmpTI	: CM_TrackedItem;
begin

