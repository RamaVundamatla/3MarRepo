    <JadeMethod name="loadNavObjectDefs" id="f5e3d9d8-678b-4c06-9f36-223a7173308e">
        <source>loadNavObjectDefs(_localTransaction : Boolean);
// ---------------------------------------------------------------------------
// Created:     31 July 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	baseScm 	: Schema;
	category 	: ConstantCategory;
	const 		: Constant;
	constDict	: ConstantNDict;
	navObjDef	: CM_NavObjectDef;

begin

	baseScm := rootSchema.getSchema(PortSchemaName);
	category := baseScm.getCategory(NavObjectCodes);
	constDict := category.getConstants();

	if _localTransaction then
		beginTransaction;
	endif;
	self.allNavObjectDefs.purge;

	foreach const in constDict do
		create navObjDef persistent;
		navObjDef.setFromXML(const.valueAsString, const.text, self);
	endforeach;
	
	
	if _localTransaction then
		commitTransaction;
	endif;
epilog
	
end;</source>
        <Parameter name="_localTransaction" type="Boolean"/>
    </JadeMethod>
