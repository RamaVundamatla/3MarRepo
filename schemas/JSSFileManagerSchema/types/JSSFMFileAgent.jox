    <JadeMethod name="renameDiskFileDbServer" id="9d0f6344-2a78-40a6-ac1f-154c3256af86">
        <updating/>
        <executionLocation>server</executionLocation>
        <source>renameDiskFileDbServer(pOldFileName:String; pNewFileName:String):Boolean updating, protected, serverExecution;
// --------------------------------------------------------------------------------
