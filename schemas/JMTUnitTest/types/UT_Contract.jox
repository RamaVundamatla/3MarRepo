    <JadeMethod name="createContractDetail" id="1a2db4ec-321a-4936-8e59-c4f6eef11195">
        <source>createContractDetail(_realCon : CM_InvoiceContract; _operator : CM_Operator; _cargoType : CM_CargoType) : CM_InvoiceContractDetails;
/*
Purpose:			

Date		Who		Reason
08 December 2022	navab1	TFS CR 55623 TASK 55674
08 Feb 2023	navmv20 TFS 55650 Task 55702: Jade - Contracts XML Load TRX
*/

vars
	pxyConDtl, realConDtl : CM_InvoiceContractDetails;
	fromTS, toTS : TimeStamp;
	operator : CM_Operator;
	invLineType100 : CM_InvoiceLineDesc;
	invType : CM_InvoiceDesc;
	services : CM_ServiceByNameDict;
	pxyCriteria : CM_InvoiceContractCriteria;
	criteriaCargoTypes : CM_CargoBOLTypeSet;
	cargoType : CM_CargoType;
	operators : CM_OperatorSet;
	yaCriteria : CM_YACriteria;
	cmifCriteria : CMIF_YACriteriaPriority;
	criteriaType	: CM_YACriteriaType;
	allCriteria : CMIF_Array;
	yaPurge : CM_ObjectSet;
	calcType : CM_CalculationType;
	service100, service200 : CM_Service;
	criteriaDesc : String;
begin
	self.deleteInvoiceService("UT_ServiceContract-1",0);
	self.deleteInvoiceService("UT_ServiceContract-2",0);
	self.deleteInvoiceType("UT_InvTypeContract");
	self.deleteInvoiceLineType("UT_LineTypeContract",0);

	fromTS := _realCon.fromTS;
	toTS := _realCon.toTS;

	operator := _operator;
	if operator = null then
	operator := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);
	endif;
	
	calcType := app.myRoot.allCalculationTypesByCode["CCT00"];
	service100 := self.createInvoiceService("UT_ServiceContract-1","1- Unit test for TFS 55623", calcType, null);
	self.assertNotNullMsg(service100, "UT_ServiceContract-1 not created");
	service200 := self.createInvoiceService("UT_ServiceContract-2","2- Unit test for TFS 55623", calcType, null);
	self.assertNotNullMsg(service100, "UT_ServiceContract-2 not created");
	create services transient;
 	services.add(service100);
 	services.add(service200);

	invType := self.createInvoiceType("UT_InvTypeContract", InvoiceTypeGeneral);
	self.assertNotNullMsg(invType, "Invoice type UT_InvTypeContract not created");
	
	invLineType100 := self.createInvoiceLineType("UT_LineTypeContract", calcType, invType, services,"SDT6");
	self.assertNotNullMsg(invLineType100, "UT_LineTypeContract not created");

	create pxyConDtl transient;
	//pxyConDtl.setProxy(INV_CONTRACT_TYPE_STANDARD,123, fromTS, toTS,calcType,_realCon,invLineType100, _realCon.myBusinessUnit, null);  //08/02/2022 navmv20 TFS 55650 Task 55702
	pxyConDtl.setProxy(null,INV_CONTRACT_TYPE_STANDARD,123, fromTS, toTS,calcType,_realCon,invLineType100, _realCon.myBusinessUnit, null,null);  //08/02/2022 navmv20 TFS 55650 Task 55702
	
	// ### TFS CR 55623 TASK 55680, adding criteria to contract detail
	// ### SETUP CRITERIA FOR DETAIL
	create criteriaCargoTypes transient;
	
	if _cargoType = null then
		cargoType := app.myRoot.getCargoTypeFromAbbrev("CONT");
	else	
		cargoType := _cargoType;
	endif;
	
	criteriaCargoTypes.add(cargoType);
	
	create operators transient;
	operators.add(operator);
	
	create yaPurge transient;
	create allCriteria transient;
	yaPurge.add(allCriteria);
	create pxyCriteria transient;
	yaPurge.add(pxyCriteria);
	
	// ### CARGO TYPE
	create cmifCriteria transient;
	yaPurge.add(cmifCriteria);
	create yaCriteria transient;
	yaPurge.add(yaCriteria);
	criteriaType := app.myRoot.allYACriteriaTypes[YACriteriaType_CargoType];
	yaCriteria.setProxy(criteriaType,criteriaCargoTypes,null);
	cmifCriteria.setReferences(yaCriteria);
	allCriteria.add(cmifCriteria);
	
	// ### OPERATOR
	create cmifCriteria transient;
	yaPurge.add(cmifCriteria);
	create yaCriteria transient;
	yaPurge.add(yaCriteria);
	criteriaType := app.myRoot.allYACriteriaTypes[YACriteriaType_OperatorItem];
	yaCriteria.setProxy(criteriaType,operators,null);
	cmifCriteria.setReferences(yaCriteria);
	allCriteria.add(cmifCriteria);
	
	
	
	pxyCriteria.setProxyContract(allCriteria,999, "UT_ContractCriteria_01", "UT_ContractCriteriaDescription_01", pxyConDtl);
	criteriaDesc := pxyCriteria.getCriteriaSummary("/"); 
	if criteriaDesc &lt;&gt; "" then
		pxyCriteria.setPropertyValue("description", criteriaDesc);
	endif;
	
	app.myTrxCA.trxCreateInvContractDtl(pxyConDtl, realConDtl, app.myPassport);
	
	assertNoTrxErrorsOrWarnings();
	assertTrueMsg(realConDtl.myInvoiceContract &lt;&gt; null, "Contract is null");
	assertTrueMsg(realConDtl.myInvoiceContract = _realCon, "Contract is wrong");
	assertTrueMsg(realConDtl.contractType = INV_CONTRACT_TYPE_STANDARD, "Contract Type is wrong");
	assertTrueMsg(realConDtl.fromTS = fromTS, "From Date is wrong");
	assertTrueMsg(realConDtl.toTS = toTS, "To Date is wrong");
	assertTrueMsg(realConDtl.myCalculationType &lt;&gt; null, "Calculation Type is null");
	assertTrueMsg(realConDtl.myCalculationType = calcType, "Calculation Type is wrong");
	assertTrueMsg(realConDtl.myInvoiceLineType &lt;&gt; null, "Line Type is null");
	assertTrueMsg(realConDtl.myInvoiceLineType = invLineType100, "Line Type is wrong");
	assertTrueMsg(realConDtl.myInvoiceContractCriteria &lt;&gt; null, "Criteria is null"); // ### TFS CR 55623 TASK 55680
	assertTrueMsg(realConDtl.myInvoiceContractCriteria.allCriteria.size = 2, "Criteria should have 2 criteria, has " &amp; 
								realConDtl.myInvoiceContractCriteria.allCriteria.size.String); // ### TFS CR 55623 TASK 55680
	
	return realConDtl;
epilog
	delete pxyConDtl;
	delete operators;
	if yaPurge &lt;&gt; null then
		yaPurge.purge();
		delete yaPurge;
	endif;
	delete services;
	delete criteriaCargoTypes;
end;</source>
