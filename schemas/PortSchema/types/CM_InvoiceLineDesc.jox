    <JadeMethod name="isUsedAsMinimumCharge" id="10fef5c4-fef7-49e9-9636-dddb56ab1af3">
        <source>isUsedAsMinimumCharge() : Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 Jan 2016	cnwdap1	Initial creation PAR #37337
29 Aug 2017	cnwma1	TFS #5725 QNS - System Performance issues
27 Sep 2019 cnwma1	Bug 46674: New Form - Minimum charges does not calculate minimum charges when grouping invoice lines
16 Jan 2020 cnwma1	Bug 48298: ADP - FW: Ticket 48149 - Minimum Charge Line remove in UAT - ##336278##

*/
vars
	invLineType 	: CM_InvoiceLineDesc;
	invLineGrp      : CM_InvoiceLineDescGroup;
begin
	/* 16.01.2020 cnwma1 48298
	if self.allMyMinimumLineDesc.isEmpty then
		if self.group &lt;&gt; null then
			if group.myMinimumChargeInvoiceLineType = self then
				return true;
			endif;
		endif;
	else
		return true;
	endif;
	
	return not self.allMyMinimumLineDesc.isEmpty();  //29.08.2017 cnwma1 TFS #5725
	*/
	
	//16.01.2020 cnwma1 48298
	if self.allMyMinimumLineDesc.isNotEmpty then
		return true;

	elseif self.bank.invLineDescGroups.isNotEmpty then
		foreach invLineGrp in self.bank.invLineDescGroups discreteLock do
			if self = invLineGrp.myMinimumChargeInvoiceLineType then
				return true;
			endif;
		endforeach;
	endif;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isVolumeBased" id="42801eae-2bb4-4ff4-a1c2-5fc9448937e7">
        <source>isVolumeBased() : Boolean;
// TFS 1990 return true if the calculation type is volume-based
vars
	result	: Boolean;
	chgByUnits : Integer;
begin
	chgByUnits := self.getChargeByUnits();

	if chgByUnits = INV_CALC_TYPE_CARGOVOLUMECONVT or
	   chgByUnits = INV_CALC_TYPE_VOLUME or
	   chgByUnits = INV_CALC_TYPE_BOL_VOLUME or // ### JIRA 35638 06AUG2025 NAVAB1
	   chgByUnits = INV_CALC_TYPE_DAYS_VOLUME then
		result := true;
	endif;

	return result;
end;
</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isVoyageCalcType" id="8804e527-86fb-43e4-964c-a72542a4ffe4">
