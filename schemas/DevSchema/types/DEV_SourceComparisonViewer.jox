    <JadeMethod name="txtSearchString_keyUp" id="173eb1b4-aebf-413c-8902-962f971df383">
        <controlMethod name="TextBox::keyUp"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>txtSearchString_keyUp(textbox: TextBox input; keyCode: Integer io; shift: Integer) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26 July 2022	navpw1	Initial creation

*/

vars
	type,
	remaining : Integer;
	
begin
	if self.getTimerStatus(self.Timer_Filter, type, remaining) then
		self.endTimer(self.Timer_Filter);
	endif;
	
	self.beginTimer(500, Timer_OneShot, self.Timer_Filter);
	
epilog

end;</source>
        <Parameter name="textbox" type="TextBox" usage="input"/>
        <Parameter name="keyCode" type="Integer" usage="io"/>
        <Parameter name="shift" type="Integer"/>
    </JadeMethod>
