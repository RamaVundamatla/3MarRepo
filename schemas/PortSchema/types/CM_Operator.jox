    <JadeMethod name="setConfig" id="ba3ac6ce-a50e-49ea-9473-8e33dfa2ed27">
        <updating/>
        <source>setConfig(_code : String; _value : Any) updating;
// ---------------------------------------------------------------------------
// Created:     12 September 2002 by cnwth2
//
// Purpose:     
//
// ----------   ----------  --------------------------------------------------
vars
	stateObj	: CM_StateObject;
	
begin

	exclusiveLock(self);
	
	stateObj := self.myStateObject;
	
	if stateObj = null then
		if self.isTransient then
			create stateObj transient;
		else
			create stateObj persistent;
		endif;
		self.myStateObject := stateObj;
 	endif;
	
	stateObj.setStateData(_code, _value, true);
end;</source>
        <Parameter name="_code" type="String"/>
        <Parameter name="_value" type="Any"/>
    </JadeMethod>
    <JadeMethod name="setConfigForTerminal" id="24ce8df2-dd77-41c2-b4f1-3a54747a7cf1">
        <source>setConfigForTerminal(_cmif	: CMIF_OperatorTerminalConfig; _terminal : CM_Terminal);
// ---------------------------------------------------------------------------
// Created:     19 August 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	opTerm	: CM_OperatorTerminal;

begin
	app.writeStatement(class.name &amp; "::" &amp; method.name &amp; " ");
	opTerm := self.getOperatorTerminal(_terminal, true);
	
	if opTerm &lt;&gt; null then
		self.exclusiveLock(opTerm);
		opTerm.setConfig(_cmif);
	endif;

end;</source>
        <Parameter name="_cmif" type="CMIF_OperatorTerminalConfig"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
    </JadeMethod>
