    <JadeMethod name="setProxyFromObject" id="2282d753-4c73-48ca-b2e7-d5338e25d990">
        <updating/>
        <source>setProxyFromObject(_ti : CM_TrackedItem) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 12/10/2020	jlgdap1		Initial creation TFS 49227 Navis API - nReefer API
//
vars

begin
	self.co2Pct := _ti.getCarbonDioxide().asStringJMT;
	self.o2Pct := _ti.getOxygen().asStringJMT;
	self.humidityPct := _ti.getHumidity().asStringJMT;
	self.tempMinC := _ti.getCommodityObject.minTemp.asStringJMT;
	self.tempReqdC := _ti.getCommodityObject.maxTemp.asStringJMT;
	self.timeLatestOffPower := _ti.getLastDisconnectDT().asStringJMT;
	self.timeLatestOnPower := _ti.getLastConnectDT().asStringJMT;
	self.ventRequiredUnit := app.getDefaultMeasurementForType(Type_Displacement).shortName;
	self.ventRequiredValue := _ti.ventilationString;
epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
    </JadeMethod>
</Class>
