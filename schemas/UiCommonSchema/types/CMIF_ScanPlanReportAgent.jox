    <JadeMethod name="setFrameSizes" id="badee36d-5f5e-49dd-b985-216e2ef852f7">
        <source>setFrameSizes( _report : CMUI_ScanPlanReport input )protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 September 2020	jlgndl1	Initial creation	TFS 49963

*/

vars

	frameArray1 : ObjectArray;
	frameArray2 : ObjectArray;
	frameArray3 : ObjectArray;
	obj : Object;
	mainAbsoluteTop : Real;
	mainAbsoluteLeft : Real;
	mainAbsoluteHeight : Real;
	mainPrintWidth : Real;
	frame : CMUI_Frame;
	currentTop : Real;
	currentLeft : Real;
	frameWidth : Real;
	frameHeight : Real;
	

begin

	//Set up the maximum sizes for the overall report based on the paper selected
	if self.paperSize = self.PaperA4 then
		_report.frmMain.width := 1074;
		_report.frmMain.height := 752;
	elseif self.paperSize = self.PaperA3 then
		_report.frmMain.width := 1518;
		_report.frmMain.height := 1074;
	else
		return;
	endif;

	mainAbsoluteTop := 62;
	mainAbsoluteHeight := _report.frmMain.height - 87;

	if self.legend = self.LegendOne or self.allScanPlanLegends.isEmpty then		
		// we can use the space where the legend would normally be	
		mainAbsoluteLeft := 0;
		//adjust the legend size for a bigger version on page one.
		_report.lblLegend.fontSize := 12;
		_report.lblLegend.fontBold := true;
		_report.frmLegend.width := _report.frmMain.width / 4; //columns across the page
		_report.frmLegendLine.width := _report.frmLegend.width - 1; 
		_report.frmLegendLine.height := ( _report.frmLegend.height - _report.frmLegendLine.top ) / 25;	//legend lines down the page 
		_report.lblLegendCol.height := _report.frmLegendLine.height;
		_report.lblLegendCol.width := _report.frmLegendLine.height * 1.6;
		_report.lblLegendDesc.left := _report.lblLegendCol.width + 1;
		_report.lblLegendDesc.width := _report.frmLegendLine.width - _report.lblLegendDesc.left; // 		
		_report.lblLegendDesc.height := _report.frmLegendLine.height;
		_report.lblLegendDesc.fontSize := 14;
		
	elseif self.legend = self.LegendAll then	
		mainAbsoluteLeft := 136; // as in painter
		_report.frmLegend.width := 136; // as in painter
		_report.frmLegendLine.width := 135; // as in painter
		_report.lblLegendDesc.width := 105; // as in painter
		
	endif; 
	
	mainPrintWidth := _report.frmMain.width - ( mainAbsoluteLeft + 4 );
	
	//set up teh frame for the cargo list
	_report.frmPrintCargoList.borderStyle := 0;
	_report.frmPrintCargoList.left := 0;
	_report.frmPrintCargoList.top := mainAbsoluteTop;
	_report.frmPrintCargoList.width := _report.frmMain.width - 4;	
	_report.frmPrintCargoList.height := mainAbsoluteHeight;

	
	//now setup which bay frames we will be using and their respective sizes
	// based on the format the user selected
	create frameArray1 transient;
	create frameArray2 transient;
	create frameArray3 transient;
	
	if self.baysPerPage = self.BaysPerPageOne then
		frameHeight := mainAbsoluteHeight;
		frameWidth := mainPrintWidth;
		frameArray1.add( _report.frmBay1 );	
	elseif self.baysPerPage = self.BaysPerPageTwo then
		frameHeight := mainAbsoluteHeight;
		frameWidth := ( mainPrintWidth / 2 ).Integer;
		frameArray1.add( _report.frmBay1 );
		frameArray1.add( _report.frmBay2 );
	elseif self.baysPerPage = self.BaysPerPageThree then
		frameHeight := mainAbsoluteHeight;
		frameWidth := ( mainPrintWidth / 3 ).Integer;
		frameArray1.add( _report.frmBay1 );
		frameArray1.add( _report.frmBay2 );
		frameArray1.add( _report.frmBay3 );
	elseif self.baysPerPage = self.BaysPerPage2x3 then
		frameHeight := ( mainAbsoluteHeight / 2 ).Integer;
		frameWidth := ( mainPrintWidth / 3 ).Integer;
		frameArray1.add( _report.frmBay1 );
		frameArray1.add( _report.frmBay2 );
		frameArray1.add( _report.frmBay3 );
		frameArray2.add( _report.frmBay4 );
		frameArray2.add( _report.frmBay5 );
		frameArray2.add( _report.frmBay6 );
	elseif self.baysPerPage = self.BaysPerPage3x4 then
		frameHeight := ( mainAbsoluteHeight / 3 ).Integer;
		frameWidth := ( mainPrintWidth / 4 ).Integer;
		frameArray1.add( _report.frmBay1 );
		frameArray1.add( _report.frmBay2 );
		frameArray1.add( _report.frmBay3 );
		frameArray1.add( _report.frmBay4 );
		frameArray2.add( _report.frmBay5 );
		frameArray2.add( _report.frmBay6 );
		frameArray2.add( _report.frmBay7 );
		frameArray2.add( _report.frmBay8 );
		frameArray3.add( _report.frmBay9 );
		frameArray3.add( _report.frmBay10 );
		frameArray3.add( _report.frmBay11 );
		frameArray3.add( _report.frmBay12 );
	endif;
	
	//now reposition the bay frames on the overall page.
	if not frameArray1.isEmpty then
		currentLeft := mainAbsoluteLeft;
	
		foreach obj in frameArray1 do
			frame := obj.CMUI_Frame;
			frame.top := mainAbsoluteTop;
			frame.left := currentLeft;
			frame.width := frameWidth;
			frame.height := frameHeight;
			currentLeft := currentLeft + frameWidth;
		endforeach;
	endif;
	
	if not frameArray2.isEmpty then
		currentLeft := mainAbsoluteLeft;
		
		foreach obj in frameArray2 do
			frame := obj.CMUI_Frame;
			frame.top := frameHeight + mainAbsoluteTop;
			frame.left := currentLeft;
			frame.width := frameWidth;
			frame.height := frameHeight;
			currentLeft := currentLeft + frameWidth;
		endforeach;
	endif;
	
	if not frameArray3.isEmpty then
		currentLeft := mainAbsoluteLeft;
		
		foreach obj in frameArray3 do
			frame := obj.CMUI_Frame;
			frame.top := (frameHeight * 2) + mainAbsoluteTop;
			frame.left := currentLeft;
			frame.width := frameWidth;
			frame.height := frameHeight;
			currentLeft := currentLeft + frameWidth;
		endforeach;
	endif;

epilog

	delete frameArray1;
	delete frameArray2;
	delete frameArray3;

end;</source>
        <access>protected</access>
        <Parameter name="_report" type="CMUI_ScanPlanReport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="validateMe" id="30e7589e-5470-4d88-990f-021014ec1f53">
        <source>validateMe();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 September 2020	jlgndl1	Initial creation	TFS 49963

*/

vars

begin

	if self.myVoyage = null then
		app.raiseCMException( Must_select_voyage, null, null );
	endif;

	if self.allSelectedBays.isEmpty then
		app.raiseCMException( Bays_selected_print, null, null );
	endif;

epilog

end;</source>
    </JadeMethod>
</Class>
