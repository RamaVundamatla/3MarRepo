<GUIClass name="GTE_EditBookRefStatusForm" id="78ca7a11-29b3-49be-84e8-d0c1a15a46a2">
    <superclass name="CMUI_Modal"/>
    <transient/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <ImplicitInverseRef name="allBookingRefs" id="c52d7bdd-f96e-4998-b6c8-86321ecf4f6a">
        <memberTypeInverse/>
        <type name="CM_BookingRefSet"/>
        <access>protected</access>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="cmbStatus" id="70172ba1-ce19-4a4d-b6c1-78e11446f4cd">
        <embedded/>
        <type name="CMUI_ComboBox"/>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="lblInstructions" id="32dd85a5-4adc-4f62-bf06-9d2bb53fd81c">
        <embedded/>
        <type name="CMUI_Label"/>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="lblStatus" id="28ad9310-fb56-4475-a5ab-e4b76b9e6919">
        <embedded/>
        <type name="CMUI_Label"/>
    </ImplicitInverseRef>
    <JadeMethod name="doOK" id="c9e78302-2d2d-4cdb-9ad0-8fa311b03104">
        <updating/>
        <source>doOK() updating;
// --------------------------------------------------------------------------------
// Created:		19 March 2009 by cnwdad1
//
// Purpose:		Standard method that is called when the OK button is clicked.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	status		: Integer;
	result		: Integer;
	
begin
	if cmbStatus.listIndex &lt;&gt; CNEC_NULL_INDEX then
		status	:=	cmbStatus.itemData[cmbStatus.listIndex];
	endif;
	
	while true do
		app.myTrxUA.trxSetBookRefsStatus(status, self.allBookingRefs, app.myPassport);
		
		if app.myPassport.trxCompletedOK() then
			// Clear errors/warnings from form and err/warnings window.
			self.clearErrorWarnings();
			break;
		else
			result	:=	app.showErrorWarningDialog(app.getString(Status), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			
			if app.myPassport.noErrors() and result = IDOK then
				// There must have just been warnings that the user has acknowledged so...
				app.myPassport.warningsAcknowledged	:=	true;
				continue;
			endif;
			
			self.setAllErrorWarnings(app.myPassport);	// Copies errors to this form and shows in err/warnings window.
		endif;
		
		break;
	endwhile;
	
	inheritMethod();
end;</source>
    </JadeMethod>
    <JadeMethod name="setBookingRefs" id="21636a9f-75ca-4bac-b1f0-9b7ec714b8a2">
        <updating/>
        <source>setBookingRefs(_allBookingRefs:CM_BookingRefSet) updating;
// --------------------------------------------------------------------------------
// Created:		19 March 2009 by cnwdad1
//
// Purpose:		Copies the set of Booking References to a local copy of the set.
//
// Parameters:	_allBookingRefs - A reference to the set of Booking References.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.allBookingRefs.clear();
	_allBookingRefs.copy(self.allBookingRefs);
end;</source>
        <Parameter name="_allBookingRefs" type="CM_BookingRefSet"/>
    </JadeMethod>
    <JadeMethod name="setupForm" id="6f4eaf11-75ae-4980-98ec-47d5e347e3c2">
        <updating/>
        <source>setupForm() updating;
// --------------------------------------------------------------------------------
// Created:		19 March 2009 by cnwdad1
//
// Purpose:		Standard form setup method.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if self.allBookingRefs.isEmpty() then
		app.msgBox("No Booking References have been selected to change.", app.getString(Error), MsgBox_Exclamation_Mark_Icon + MsgBox_OK_Only);
		self.unloadForm();
		return;
	endif;
	
	self.createMyAssistant(GTE_Assistant);
	
	inheritMethod();
	
	self.myAssistant.comboBoxBookingRefStatus(cmbStatus, 0);
	self.cmbStatus.setFocus();
end;</source>
    </JadeMethod>
    <JadeMethod name="translateForm" id="2e8f4726-fbca-48a8-85ce-c8714c7ced4e">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0010492, locale);
	lblInstructions.translateCaption(Xlat_0014351, locale);
	lblStatus.translateCaption(Xlat_0010494, locale);
end;</source>
    </JadeMethod>
</GUIClass>
