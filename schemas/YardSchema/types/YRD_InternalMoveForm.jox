    <JadeMethod name="getInfoOffScreen" id="691c03cb-41b5-4d6b-ab10-8cb6e843df05">
        <updating/>
        <source>getInfoOffScreen(	_allAvGrades		: IntegerArray io;
					_theOperatorCode	: String io;
					_theISOTypeCode 	: String io;
					_targetLocation		: String io;
					_sourceLocation 	: CM_LocationsController io;
					_sourceTA 			: CM_TerminalArea io;	// 23098
					_sourceTAGridObj 	: CM_GridObject io;
					_theTotalReq 		: Integer io;
					_addToRTQ 			: Boolean io;
					_isClean 			: Boolean io;
					_isoGroup 			: String io;
					_theID				: String io;
					_theSubTerminal		: CM_SubTerminal io;
					_theRemarks			: String io;
					_requiredBtDT 		: TimeStamp io;
					_targetSubTerminal 	: CM_SubTerminal io;
					_release			: CM_BulkRelease io;
					_releaseItem 		: CM_ReserveDetail io;
					_rtQueue			: CM_RadioTelemetryQueue io;
					_priority 			: Integer io;
					_bestPick 			: Boolean io;
					_updSubTerm 		: CM_SubTerminal io;		// 3 Nov 2022 NAVSKS20 TFS 52721
					_isAvail			: Boolean io				// 3 Nov 2022 NAVSKS20 TFS 52721
					) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		 Reason
13 Aug 2009	cnwrd1	 Initial creation
20 Jun 2022	navvt20	 Bug 53816 : Mismatch between the dropdown list (source area vs target area) of the delivery request form
03 Nov 2022	navsks20 ChangeRequest 52721: PNL - Delivery Requests - Assign Cargo to Specified Release Request
25 Apr 2023 navma1	 Bug 57739: PNL - Radio Telemetry Queues not working for multi move delivery requests (new issues)
*/

vars

	theOperator 	: CM_Operator;
	theISOType 		: CM_ISOType;
	theAvGrade 		: CM_MTGrade;
	reqTime 		: Time;
	aTA 			: CM_TerminalArea;
	obj 			: Object;
	aGridObject		: CM_GridObject;
	targetObj       : Object;  //22 June 2022 navvt20 Bug 53816
	
begin
	// ##########################
	// Get The Info Off the screen
	// DVB CCMS 1235
	
	_allAvGrades.clear;
	foreach obj in self.lstMTGrade.allSelectedObjects do
		_allAvGrades.add(obj.CM_MTGrade.code);
	endforeach;
	

	theOperator := self.cmbOperator.getObject().CM_Operator;
	if theOperator &lt;&gt; null then
		_theOperatorCode := theOperator.code;
	endif;

	
	// cnwdad1 03/07/2009 - CCMS 1735.
	if cmbSubTerminal.listIndex &lt;&gt; CNEC_NULL_INDEX then
		_theSubTerminal	:=	self.cmbSubTerminal.getObject().CM_SubTerminal;
	endif;
	
	if self.cmbISOType.listIndex &gt; 0 then
		theISOType := self.cmbISOType.getObject.CM_ISOType;		
		if theISOType &lt;&gt; null then
			_theISOTypeCode := theISOType.code;
		endif;
	endif;

	if self.cmbISOGroup.getObject() &lt;&gt; null then
		_isoGroup := self.cmbISOGroup.getObject().CM_ISOTypeGroup.code; 
	endif;
	
	
	targetObj := self.cmbTargetArea.getObject;						// 22 June 2022 navvt20 Bug 53816
	if targetObj &lt;&gt; null then 										// 22 June 2022 navvt20 Bug 53816
		
		if targetObj.isKindOf(CM_TerminalArea) then  				// 22 June 2022 navvt20 Bug 53816
			_targetLocation := targetObj.CM_TerminalArea.id;
		elseif targetObj.isKindOf(CM_GridObject) then 												//25.04.2023 navma1 #57739
			_targetLocation := targetObj.CM_GridObject.getFirstLocationController().getFullId;		//25.04.2023 navma1 #57739
		endif;
		
	elseif self.typeToCreate = Depot_Request then
		_targetLocation := self.cmbTargetArea.getString();
	endif;

	//cnwrd1 par 28628 4.11.11
	if self.cmbSourceArea.listIndex &gt; 0 then
		obj := self.cmbSourceArea.getObject();
		if obj &lt;&gt; null then
			if obj.isKindOf(CM_TerminalArea) then //just selected a TA
				aTA := obj.CM_TerminalArea;
			else //we have a grid object
				aGridObject := obj.CM_GridObject;
				aTA := aGridObject.getGridArea();	
				_sourceLocation := aGridObject.getFirstLocationController(); //cnwrd1 par 29351 3.4.2012  for move requests if they have selecte a grid object.
			endif;
		endif;
		_sourceTA		 := aTA;		// 23098
		_sourceTAGridObj := aGridObject;
	endif;
	
	
	_theTotalReq 	:= self.txtNumRequested.getInteger(); 
	_addToRTQ 		:= self.chkAddToRTQ.getBoolean(); 		
	_isClean 		:= self.chkIsClean.getBoolean();	
	_theID 			:= self.txtJobID.text;				
	_theRemarks		:= self.txtRemarks.getString();			
	_bestPick 		:= self.chkBestPick.getBoolean();		
	_priority 		:= self.cmbPriority.getEmbeddedControl.ComboBox.listIndex;
	

	_requiredBtDT.setDate( self.dtRequired.getDate() );
	reqTime := self.txtRequiredTime.getTime();
	if reqTime = null then
		reqTime.setTime( 23,59,00,00 );
	endif;
	_requiredBtDT.setTime( reqTime ); 
	_requiredBtDT := self.localToSystemTime(_requiredBtDT);
	
	if self.cmbTargetSubTerm.listIndex &lt;&gt; CNEC_NULL_INDEX then
		_targetSubTerminal	:=	self.cmbTargetSubTerm.getObject().CM_SubTerminal;
	endif;
	
	
	if self.cmbRelease.listIndex &lt;&gt; CNEC_NULL_INDEX then
		_release	:=	self.cmbRelease.getObject().CM_BulkRelease;
	endif;
	
	if self.cmbReleaseItem.listIndex &lt;&gt; CNEC_NULL_INDEX then
		_releaseItem	:=	self.cmbReleaseItem.getObject().CM_ReserveDetail;
	endif;
	
	if self.cmbRTQueue.listIndex &lt;&gt; CNEC_NULL_INDEX then
		_rtQueue	:=	self.cmbRTQueue.getObject().CM_RadioTelemetryQueue;
	endif;
	
	//Start 3 Nov 2022 NAVSKS20 TFS 52721
	if self.cmbUpdateSubTer.listIndex &lt;&gt; CNEC_NULL_INDEX then
		_updSubTerm	:=	self.cmbUpdateSubTer.getObject().CM_SubTerminal;
	endif;
	_isAvail := self.chkIsAvail.getBoolean();
	//End 3 Nov 2022 NAVSKS20 TFS 52721
epilog

end;</source>
        <Parameter name="_allAvGrades" type="IntegerArray" usage="io"/>
        <Parameter name="_theOperatorCode" type="String" usage="io"/>
        <Parameter name="_theISOTypeCode" type="String" usage="io"/>
        <Parameter name="_targetLocation" type="String" usage="io"/>
        <Parameter name="_sourceLocation" type="CM_LocationsController" usage="io"/>
        <Parameter name="_sourceTA" type="CM_TerminalArea" usage="io"/>
        <Parameter name="_sourceTAGridObj" type="CM_GridObject" usage="io"/>
        <Parameter name="_theTotalReq" type="Integer" usage="io"/>
        <Parameter name="_addToRTQ" type="Boolean" usage="io"/>
        <Parameter name="_isClean" type="Boolean" usage="io"/>
        <Parameter name="_isoGroup" type="String" usage="io"/>
        <Parameter name="_theID" type="String" usage="io"/>
        <Parameter name="_theSubTerminal" type="CM_SubTerminal" usage="io"/>
        <Parameter name="_theRemarks" type="String" usage="io"/>
        <Parameter name="_requiredBtDT" type="TimeStamp" usage="io"/>
        <Parameter name="_targetSubTerminal" type="CM_SubTerminal" usage="io"/>
        <Parameter name="_release" type="CM_BulkRelease" usage="io"/>
        <Parameter name="_releaseItem" type="CM_ReserveDetail" usage="io"/>
        <Parameter name="_rtQueue" type="CM_RadioTelemetryQueue" usage="io"/>
        <Parameter name="_priority" type="Integer" usage="io"/>
        <Parameter name="_bestPick" type="Boolean" usage="io"/>
        <Parameter name="_updSubTerm" type="CM_SubTerminal" usage="io"/>
        <Parameter name="_isAvail" type="Boolean" usage="io"/>
    </JadeMethod>
    <JadeMethod name="getYardSourceText" id="30cd16eb-1118-4409-8b9f-9825c8b609f7">
        <source>getYardSourceText() : String protected;
// show source locations and options from CMUI_SelectISOSourceMulti
vars
	ta 		: CM_TerminalArea;
	aGO		: CM_GridObject;
	sep 	: String;
	result 	: String;
	count	: Integer;
begin	

	count := 1;
	foreach ta in self.allSelectedTAs do
		if self.allSelectedTAGridObjs &lt;&gt; null and self.allSelectedTAGridObjs.size &gt;= count then
			aGO := self.allSelectedTAGridObjs[count];
		else
			aGO := null;
		endif;
			
		if aGO = null then
			result := result &amp; sep &amp; ta.id;
		else
			result := result &amp; sep &amp; ta.id &amp; '(' &amp; aGO.label &amp; ')';
		endif;
		
		sep := ', ';
		count := count +1;
	endforeach;
	
	/*if self.isBestPick and
	   result &lt;&gt; "" then
		result := result &amp; " (" &amp; app.getErrorString(Best_pick) &amp; ")";
	endif;*/
	
	if result.length &gt; 28 then
		result := result[1:25] &amp;'...';
	endif;
	
	return result;
epilog

end;</source>
        <access>protected</access>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="initForRequest" id="dd690984-145b-4985-bf92-40a6cce62f5b">
        <updating/>
        <source>initForRequest( _obj : CM_Object) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
13 August 2009	cnwrd1	Initial creation

*/

vars
	thejob : CM_YardInternalJob;
	theRequest : CM_Request;
begin

	self.allSelectedTIs.clear();

	if (not _obj.isKindOf(CM_YardInternalJob)) then
		return;
	endif;
		
	
	thejob := _obj.CM_YardInternalJob;
	theRequest := thejob.allRequests.first;
	if theRequest = null then
		return;
	endif;
	
	//self.cmbRequestType
	self.cmbRequestType.enabled := false;
	
	if theRequest.isKindOf(CM_YardDeliveryRequest) then
		self.displayDeliveryRequest(theRequest.CM_YardDeliveryRequest);
	elseif theRequest.isKindOf(CM_YardMoveRequest) then
		self.displayMoveRequest(theRequest.CM_YardMoveRequest);
	else
		app.raiseUnexpectedProgramError(class.name, method.name,  app.getErrorString(Invalid_type_create));
		return;
	endif;	

	self.displayJobQStatus(thejob);

	self.txtJobID.text := thejob.jobId;
	
//	self.tblMain.disableRowByName(ETRow_IsoSourceRestrict);
	//self.tblMain.disableRowByName(ETRow_Status);		
	self.txtSourceText.setValue("Use 'Source Area', if Autoplan could not determine a suitable source.");  //not shown now.
	//self.tblMain.disableRowByName(ETRow_IsoSourceText);	
	
	thejob.selectedTIs.copy(self.allSelectedTIs);
	self.displaySelectedTIs();
	

	// self.myAssistant.comboBoxYardInternalMove(tblMain, ETRow_TypeToCreate, thejob.type);

	self.btnNext.enabled := false;
	self.alignButtons();

	self.showHideFieldsForType();	
	
epilog

end;</source>
        <Parameter name="_obj" type="CM_Object"/>
    </JadeMethod>
    <JadeMethod name="initForm" id="34277389-b5ca-4c4e-9ecc-3542345e1964">
        <updating/>
        <source>initForm( _obj : CM_Object) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
13 August 2009	cnwrd1	Initial creation

*/

vars
	theBR : CM_BulkRelease;
begin

	self.myCurrentObject 			:= _obj;
	if CM_BulkRelease.hasInstance( self.myCurrentObject) then  //cnwr1 par 27715 20.6.2010
			theBR := self.myCurrentObject.CM_BulkRelease;
			self.myInitialisingRelease := theBR;
	endif;
epilog

end;</source>
