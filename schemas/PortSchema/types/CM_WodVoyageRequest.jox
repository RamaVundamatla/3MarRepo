    <JadeMethod name="validateForUpdate" id="9a78d42c-ae5f-437e-8f65-4c34a5e556dc">
        <source>validateForUpdate();
/*

Purpose:			TFS 40029

Parameters:			

Return Value:		

Date		Who		Reason
21 August 2018	jlgab1	Initial creation

*/

vars

	voyage : CM_Voyage;
	workorder : CM_WorkOrder;
begin
	voyage := self.getMyVoyageObject();
	workorder := self.myParent;
	
	//epr TFS 42220 27/11/18 - inaportnet need to update the load and discharge operator after it was created
	if voyage.isMTNWOVoyageProcess then
		// If the voyage has a cargo request or an initial marine services request the voyage request cannot be edited.
		if voyage.isWorkOrderForVoyageCargo() then
			app.raiseCMException2(Work_order_not_updat_becau_wor,workorder.id,"'" &amp; app.getErrorString(Voyage_cargo_requests) &amp; "'",null,null);
		endif;
		
		if voyage.isWorkOrderForIMSR() then
			app.raiseCMException2(Work_order_not_updat_becau_wor,workorder.id,"'" &amp;  app.getErrorString(Voyage_initial_marine_service) &amp; "'",null,null);
		endif;
	endif;
	
	if self.estimatedDepartureTS &lt;= self.estimatedArrivalTS then
		app.raiseCMException(MSGBOX_InvalidVoyageDate,null,null);
	endif;

	inheritMethod();

epilog

end;</source>
    </JadeMethod>
</Class>
