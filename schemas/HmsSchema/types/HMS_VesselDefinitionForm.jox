    <JadeMethod name="loadBerthPrefRow" id="adbf3e75-0fe7-4f06-a149-18478ae820a4">
        <updating/>
        <source>loadBerthPrefRow(berthPref: HMS_BerthPreference) updating;

vars
	newRow : Integer;
	newCntrl : Control;
	newCombo : CMUI_ComboBox;
	tmpTable : Table;
begin

	tmpTable := self.tblPrefBerth;
	tmpTable.clearAllSelected();
	newRow := tmpTable.rows+1;
	tmpTable.rows := newRow;
	tmpTable.row := newRow;
	tmpTable.column:=1;

	if berthPref &lt;&gt; null then
		tmpTable.itemObject:=berthPref;
	endif;			

	newCombo := self.cmbBerth.loadControl(newIndex).CMUI_ComboBox;
	self.allClonedControls.add(newCombo);
	tmpTable.accessCell(newRow, 1).cellControl := newCombo;
	if berthPref &lt;&gt; null then
		self.myAssistant.comboBoxHMSBerth(newCombo, self.myHarbour, berthPref.getMyBerth, true);	
	else
		self.myAssistant.comboBoxHMSBerth(newCombo, self.myHarbour, self.myHarbour.getDefaultBerthForMoveType(HMSMovementTypeArrival), true);
	endif;
	newCombo.click(newCombo);
	
	newIndex := newIndex+1;
	newCombo := self.cmbOrientation.loadControl(newIndex).CMUI_ComboBox;
	self.allClonedControls.add(newCombo);
	tmpTable.accessCell(newRow, 2).cellControl := newCombo;
	newCombo.addItem(app.getErrorString(PortSideToBerth));
	newCombo.addItem(app.getErrorString(StarboardSideToBerth));

	// Set orientation
	tmpTable.column := 2;	
	if berthPref &lt;&gt; null then	
		if berthPref.orientation = OrientPortSideTo then
			newCombo.listIndex := 1;
		else
			newCombo.listIndex := 2;
		endif;
	else
		newCombo.listIndex := 1;
	endif;
	tmpTable.text := newCombo.text;

	newIndex := newIndex+1;
	newCntrl := self.txtBow.loadControl(newIndex);
	self.allClonedControls.add(newCntrl);
	tmpTable.accessCell(newRow, 3).cellControl := newCntrl;
	
	// Set bow
	tmpTable.column:=3;
	if berthPref &lt;&gt; null then	
		tmpTable.text := berthPref.defaultBowMark.String;
		newCntrl.TextBox.text := berthPref.defaultBowMark.String;
	endif;
	// Set bridge
	tmpTable.column:=4;
	if berthPref &lt;&gt; null then	
		tmpTable.text:=berthPref.defaultBridgeMark.String;
	endif;
	// Set stern
	tmpTable.column:=5;
	if berthPref &lt;&gt; null then	
		tmpTable.text:=berthPref.defaultSternMark.String;
	endif;

	self.btnDelPrefBerth.enabled := true;		

	
end;</source>
        <Parameter name="berthPref" type="HMS_BerthPreference"/>
    </JadeMethod>
    <JadeMethod name="loadBerthPrefRows" id="b4172245-14d7-4b41-a270-01d970097596">
        <updating/>
        <source>loadBerthPrefRows() updating;

vars
	berthPref:	HMS_BerthPreference;
begin
	// Set table rows to 1
	tblPrefBerth.row:=1;
	tblPrefBerth.rows:=1;

 	// This method loads berthPref objs into the table tblPrefBerth
 	// Load berthPref into table
 	if self.myCurrentVesselDataHarbour &lt;&gt; null then
 		foreach berthPref in self.myCurrentVesselDataHarbour.allBerthPrefByOrder do
 			self.loadBerthPrefRow(berthPref);
 		endforeach;
 	endif;

 	// Set selected row
 	self.setRowTblPrefBerth();


end;</source>
    </JadeMethod>
    <JadeMethod name="loadBerthPrefTbl" id="1291e176-7f9a-41f8-a86b-ee11d7cc4dc5">
