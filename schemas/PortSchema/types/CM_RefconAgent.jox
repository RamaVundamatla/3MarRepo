    <JadeMethod name="readTimeOfAct" id="ee33edb8-a2b2-45f2-bff5-a647b8f9377e">
        <source>readTimeOfAct(_timeOfAct:String) :TimeStamp protected;

// Time is transmitted in local time (used to be UTC).

vars
	timeStamp			: TimeStamp;
	date				: Date;
	time				: Time;
	year,month,day		: Integer;
	hour,min,sec		: Integer;
	int 				: Integer;
begin
	year := _timeOfAct[3:2].Integer;
	month := _timeOfAct[5:2].Integer;
	day := _timeOfAct[7:2].Integer;
	date.setDate(day,month,year);
	timeStamp.setDate(date);

	hour := _timeOfAct[9:2].Integer;
	min := _timeOfAct[11:2].Integer;
	sec := _timeOfAct[13:2].Integer;
	time.setTime(hour,min,sec,0);
	timeStamp.setTime(time);

	//return timeStamp.utcToLocalTime;	//convert to local time
	return timeStamp;	// 27/05/2013 cnwar2 #31410
end;</source>
        <access>protected</access>
        <Parameter name="_timeOfAct" type="String"/>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="readTimeOfActLMT" id="2e51525e-ad0f-4886-abc3-cdfcc34b6db1">
        <source>readTimeOfActLMT(_timeOfAct:String) :TimeStamp protected;

// for times transmitted in LMT.

vars
	timeStamp			: TimeStamp;
	date				: Date;
	time				: Time;
	year,month,day		: Integer;
	hour,min,sec		: Integer;
	int 				: Integer;
begin
	year := _timeOfAct[3:2].Integer;
	month := _timeOfAct[5:2].Integer;
	day := _timeOfAct[7:2].Integer;
	date.setDate(day,month,year);
	timeStamp.setDate(date);

	hour := _timeOfAct[9:2].Integer;
	min := _timeOfAct[11:2].Integer;
	sec := _timeOfAct[13:2].Integer;
	time.setTime(hour,min,sec,0);
	timeStamp.setTime(time);

	return timeStamp;	//is already local time
end;</source>
        <access>protected</access>
        <Parameter name="_timeOfAct" type="String"/>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="recordType" id="70dd1e43-a44c-4e3e-9ab5-d523b3b60465">
        <source>recordType():String protected;
// ---------------------------------------------------------------------------
// Created:     01 December 2001 by cnwrs1
//
