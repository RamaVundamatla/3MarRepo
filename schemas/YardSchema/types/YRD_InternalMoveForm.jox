    <JadeMethod name="showHideFieldsForType" id="8dfdfe7e-04cc-4941-ab45-4123022418b9">
        <updating/>
        <source>showHideFieldsForType() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
13 August 2009	cnwrd1	Initial creation
3 Nov 2022 		navsks20 ChangeRequest 52721: PNL - Delivery Requests - Assign Cargo to Specified Release Request
*/

vars
	combo : ComboBox;
	tmpType : Integer;
	str	: String;
	show : Boolean;
begin


	str	:=  self.cmbRequestType.text.trimBlanks();
	self.minimumWidth :=  806;	//3.11.2022	navsks20 TFS 52721
	self.width :=  814;	//3.11.2022	navsks20 TFS 52721
	if str = Depot_Request_Str then 
		if process.isJLGAB1 then
			app.msgBox("This only works for empty Containers, it is hard coded.", "Remember", MsgBox_OK_Only + MsgBox_Information_Icon);
		endif;
		self.typeToCreate := Depot_Request;
		self.showHideFieldsForDepotRequest();
		self.minimumWidth :=  900;	//3.11.2022	navsks20 TFS 52721
		self.width :=  900;	//3.11.2022	navsks20 TFS 52721
	elseif str = Controller_Strip_Str then 
		self.typeToCreate := Controller_Strip;
		self.showHideFieldsForControllerStr();
	elseif str = Plan_On_Pickup_Str then  //cnwrd1 par 26734 CCMS 2014 plan on pickup
		self.typeToCreate := Plan_On_Pickup;
		self.showHideFieldsForPlanOnPickup();
	endif;
	

	self.alignDateField();
epilog
end;
</source>
    </JadeMethod>
    <JadeMethod name="showSelectorForm" id="fd930730-142c-470c-b7a1-fc981deab142">
        <updating/>
        <source>showSelectorForm() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
13 August 2009	cnwrd1	Initial creation

*/

vars
	str			: String;
	theSelector	: CMUI_Selector;
	cargoType	: CM_CargoType;
begin
	// cnwjre1 May 2011 27097
	str	:=  self.cmbRequestType.text.trimBlanks();
	if str = Depot_Request_Str then 
		self.showSelectorFormForDepotReq();
		return;
	endif;

	if self.mySelectorForm &lt;&gt; null then	// 14 Mar 2011	NDL	Par 26762
		theSelector := self.mySelectorForm;
		
	else

		theSelector := app.loadForm(CMUI_Selector, null, false, false, true, self.myTerminal, self.myMasterMenuAction).CMUI_Selector;
		if theSelector = null then
			return;
		endif;
		theSelector.myParent := self;
		
	endif;
	
	theSelector.myTerminal := self.myTerminal;
	theSelector.myEnquiryCollectionClass := CM_TIArray;
	theSelector.defaultSiteStr := TI_SITE_ONSITE_str;
	theSelector.myQDef := app.myRoot.allQueryDefinitionObjects[CM_QueryDefinition.TrackedItem_Query_Type, TI_CargoType_Container];
	theSelector.disableMnuEnquiry := false;
	theSelector.myDefaultTerminalArea := self.myCurrentSourceTA;
	
	if self.myCurrentSourceTA &lt;&gt; null and not theSelector.allDefaultTerminalAreas.includes(self.myCurrentSourceTA) then
		theSelector.allDefaultTerminalAreas.add(self.myCurrentSourceTA);
	endif;
	
	theSelector.myEnquiryCollectionClass := CM_TIArray;
	theSelector.show;
	

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="showSelectorFormForDepotReq" id="9a9497fb-c241-469d-a8c2-4f5ae34a69b0">
        <updating/>
        <source>showSelectorFormForDepotReq() updating, protected;
// cnwjre1 May 2011 27098 called from Selector button for a delivery request to call the selector form pre-populated from the major screen values
vars
	clean			: Boolean;
	str				: String;
	obj				: Object;
	assoc,
	assoc2			: CM_Association;
	theSelector		: CMUI_Selector;
	critLine		: CM_SelectorCriteriaLine;
	
begin
	
	if self.mySelectorForm &lt;&gt; null then
		theSelector := self.mySelectorForm;
	else
		theSelector := app.loadForm(CMUI_Selector, null, false, false, true, self.myTerminal, self.myMasterMenuAction).CMUI_Selector;
		if theSelector = null then
			return;
		endif;
		theSelector.myParent := self;
	endif;
	
	theSelector.myTerminal := self.myTerminal;
	theSelector.myEnquiryCollectionClass := CM_TIArray;
	theSelector.defaultSiteStr := TI_SITE_ONSITE_str;

	theSelector.myQDef := app.myRoot.allQueryDefinitionObjects[CM_QueryDefinition.TrackedItem_Query_Type, TI_CargoType_Container];
	theSelector.disableMnuEnquiry := false;
	theSelector.enableSendLocationMenu(self.caption);

	obj := self.cmbOperator.getObject();
	if obj &lt;&gt; null then
		theSelector.addDefaultPropertyLine("operatorCode", CM_QueryOperator.Operator_Equal, obj);
	endif;
	
	if self.cmbISOType.listIndex &gt; 0 then
		obj := self.cmbISOType.getObject;		
		if obj &lt;&gt; null then
			theSelector.addDefaultPropertyLine("isoType", CM_QueryOperator.Operator_Equal, obj);
		endif;
	endif;

	if self.cmbISOGroup.listIndex &gt; 0 then
		obj := self.cmbISOGroup.getObject;		
		if obj &lt;&gt; null then
			theSelector.addDefaultPropertyLine("isoGroup", CM_QueryOperator.Operator_Equal, obj);
		endif;
	endif;

	clean := self.chkIsClean.getBoolean();
	if clean then
		str := "Yes";
		create assoc transient;
		assoc.setValue(str);
		theSelector.addDefaultPropertyLine("isClean", CM_QueryOperator.Operator_Equal, assoc);
	endif;

	assoc := null;
	foreach obj in self.lstMTGrade.allSelectedObjects do
		if assoc  = null then
			create assoc transient;
		endif;
		create assoc2 transient;
		assoc2.setValue(obj.CM_MTGrade.code);
		assoc.objectArray.add(assoc2);
	endforeach;
	if assoc &lt;&gt; null then
		theSelector.addDefaultPropertyLine("availabilityGrade", CM_QueryOperator.Operator_IsOneOf, assoc);
	endif;
	
	// 27/02/2014 cnwar2 #33315
	assoc := null;
	str := "Yes";
	create assoc transient;
	assoc.setValue(str);
	theSelector.addDefaultPropertyLine("isEmpty", CM_QueryOperator.Operator_Equal, assoc);

	
	theSelector.show;

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="translateForm" id="27933bde-b6d9-41a8-a400-28928bfdb1f3">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 29 November 2022 09:35:49.
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0022893, locale);
	btnAdvanced.translateCaption(Xlat_0017727, locale);
	chkAddToRTQ.translateCaption(Xlat_0012264, locale);
	chkAutoPlan.translateCaption(Xlat_0012265, locale);
	chkBestPick.translateCaption(Xlat_0014653, locale);
	chkIsAvail.translateCaption(Xlat_0025219, locale);
	chkIsClean.translateCaption(Xlat_0012267, locale);
	chkNoChecks.translateCaption(Xlat_0012268, locale);
	chkStatusHeld.translateCaption(Xlat_0012269, locale);
//	cmbAvGrade.translateCaption(Xlat_0012270, locale);
	cmbISOGroup.translateCaption(Xlat_0013588, locale);
	cmbISOType.translateCaption(Xlat_0012271, locale);
	cmbOperator.translateCaption(Xlat_0012272, locale);
	cmbPriority.translateCaption(Xlat_0012273, locale);
	cmbRTQueue.translateCaption(Xlat_0012274, locale);
	cmbRelease.translateCaption(Xlat_0012275, locale);
	cmbReleaseItem.translateCaption(Xlat_0012276, locale);
	cmbSourceArea.translateCaption(Xlat_0012277, locale);
	cmbSubTerminal.translateCaption(Xlat_0012278, locale);
	cmbTargetArea.translateCaption(Xlat_0012279, locale);
	cmbTargetSubTerm.translateCaption(Xlat_0012280, locale);
	cmbUpdateSubTer.translateCaption(Xlat_0025220, locale);
	lblJobID.translateCaption(Xlat_0012282, locale);
	lblMainGroup.translateCaption(Xlat_0012283, locale);
	lblQueueInfo.translateCaption(Xlat_0012284, locale);
	lblRequestType.translateCaption(Xlat_0012285, locale);
	lblSourceInfo.translateCaption(Xlat_0012286, locale);
	lblStatus.translateCaption(Xlat_0012287, locale);
	lblStatusInfo.translateCaption(Xlat_0012288, locale);
	lblTargetInfo.translateCaption(Xlat_0012289, locale);
	lstMTGrades.translateCaption(Xlat_0016325, locale);
	lstTrackedItems.translateCaption(Xlat_0012290, locale);
	mnuListContext.translateCaption(Xlat_0016326, locale);
	mnuLstRemoveItem.translateCaption(Xlat_0016327, locale);
	picSelector.translateCaption(Xlat_0012291, locale);
	txtInQueue.translateCaption(Xlat_0012292, locale);
	txtNumRequested.translateCaption(Xlat_0012293, locale);
	txtRemarks.translateCaption(Xlat_0012294, locale);
	txtRequiredDate.translateCaption(Xlat_0012295, locale);
	txtRequiredDate2.translateCaption(Xlat_0012296, locale);
	txtRequiredTime.translateCaption(Xlat_0012297, locale);
	txtSourceRestric.translateCaption(Xlat_0012298, locale);
	txtSourceText.translateCaption(Xlat_0012299, locale);
end;</source>
