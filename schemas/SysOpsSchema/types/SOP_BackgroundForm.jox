    <JadeMethod name="userNotify" id="1b0b0b18-511f-4632-b877-50b427fa4796">
        <controlMethod name="Form::userNotify"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>userNotify(eventType: Integer; theObject: Object; eventTag: Integer; userInfo: Any) updating;

/*

Date		Who		Reason
23 Nov 2010	cnwkpd1	Performance enhancements
28 Nov 2011	cnwkpd1	PAR #28753 - Rework to consolidate multiple BGP_DisplayUpdate notes for the same controller
					Also removed unnecessary process.sleep(600)

*/

vars
	pos 			: Integer;
	detail,
	msg1,
	msg2			: String;
	obj				: Object;
	invalid			: Boolean;
	edition			: Integer;
	
begin

	executeWhen JMTDevelopmentEnvironment;
	app.writeLog(method.qualifiedName &amp; ", eventType="&amp;eventType.String &amp; " theObject="&amp; theObject.String &amp; " userInfo="&amp; userInfo.String, LogDEBUG);	//25 Nov 2019	NDL	TFS 47053
	endExecuteWhen;
	
//	process.sleep(600);				// PAR #28753
//	self.resynchObject(theObject);
	if eventType = BGP_Object.BGP_DisplayUpdate then
	
		// PAR #28753 - reworked to use timers
		if theObject.isKindOf(BGP_Object) then
			if not self.allNotifiedBGPObjects.includes(theObject) then
				self.allNotifiedBGPObjects.add(theObject);
				self.doStartNotesTimer();
			endif;
		endif;
/*	
		on Exception do app.handleDeletedObject(exception, theObject, invalid);
		edition := theObject.edition();
		if invalid then
			self.doDisplay();
			return;
		endif;
		
		if theObject.isKindOf(BGP_Object) then
			self.refreshBGPObject(theObject.BGP_Object);
		endif;
*/	
	elseif eventType = BGP_Object.BGP_CallBackMsg then
		detail := userInfo.String;
		pos := 1;
		msg1	:= detail.scanUntil('~*~', pos).trimBlanks;
		if pos &lt;&gt; 0 then
			obj := msg1.asOid;
			if obj &lt;&gt; process then
				return;
			else
				if detail.length &lt; (pos + 3) then
					return;
				else
					msg2 := detail[pos + 3 : end].trimBlanks();
				endif;
			endif;
		else
			msg2 := msg1;
		endif;
		//app.msgBox(msg2, 'Info',MsgBox_OK_Only + MsgBox_Information_Icon);
		//par 18306
		logMessage := msg2[1:249];
		
	endif;

end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
        <Parameter name="userInfo" type="Any"/>
    </JadeMethod>
    <JadeMethod name="xHandler" id="e25ce0c7-33a9-46f6-ae02-da31effa75fb">
        <source>xHandler(_exp : Exception; _bgpObject : BGP_Object input) : Integer protected;

/*

Purpose:			Exception handler for display methods

Parameters:			

Return Value:		Exception return value

Date		Who		Reason
19 Jun 2003	cnwdvb1 
29 Nov 2011	cnwkpd1	PAR #28752 - BGP form performance issues - noticed 
					potential issue with lock exception in tran state
	
*/

vars

begin
	// This exception handler allows the user to open the form if somehow the display method cannot
	// find the appropriate class for the controller due to a developer inadvertently changing a request
	// class name. The controllers won't start but this handler
	// will clear out the problem when the bgp form is opened.
	if _exp.isKindOf(CM_Exception) and _exp.errorCode = 79574 then
		if _bgpObject &lt;&gt; null and not _bgpObject.isRunning() then
			if _bgpObject.isKindOf(BGP_Controller) then
				beginTransaction;
				_bgpObject.BGP_Controller.allRequestClassesToProcess.clear();
				commitTransaction;
			endif;
		endif;
		return Ex_Resume_Next;
	elseif _exp.isKindOf(LockException) then
		abortTransaction;			// PAR #28753
		abortTransientTransaction;
		return Ex_Abort_Action;
	endif;
	

	return Ex_Pass_Back;

end;</source>
        <access>protected</access>
        <Parameter name="_exp" type="Exception"/>
        <Parameter name="_bgpObject" type="BGP_Object" usage="input"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
</GUIClass>
