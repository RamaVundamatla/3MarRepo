    <JadeMethod name="doUpdateChangeStatus" id="ba429848-1419-46b3-87b9-0652b8357f54">
        <updating/>
        <source>doUpdateChangeStatus(_vvr : CM_VehicleVisitRecord input) protected, updating;
/*

Purpose:			Cancels Gate Entities on a vehicle visit record

Parameters:			_vvr	CM_VehicleVisitRecord	The vehicle visit record to update

Return Value:		NONE

Date		Who		Reason
16 May 2023	navpw1	Initial creation TFS: 54049 (55843)

*/

vars
	theReturn : Integer;
	
begin
	if _vvr = null then
		return;
	endif;
	
	while true do
		app.myTrxUA.trxUpdateInOutGateStatus(_vvr,CMGTE_Entity.Status_Cancelled, app.myPassport);
		if app.myPassport.trxCompletedOK then
			// Clear errors/warnings from form and err/warnings window
			self.clearErrorWarnings();
			global.beep;
			break;
		else
			theReturn := app.showErrorWarningDialog(app.getErrorString(Change_status), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   theReturn = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
			return;
		endif;
		break;
	endwhile;
	
end;</source>
        <access>protected</access>
        <Parameter name="_vvr" type="CM_VehicleVisitRecord" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doVbsSlotClick" id="89e53a18-8295-40d0-b46a-005a3c4d714d">
        <updating/>
        <source>doVbsSlotClick(menuItem: MenuItem input) protected,updating;
/*

Purpose:			Disassociates a vehicle booking time slot from a vehicle visit record

Parameters:			menuItem	MenuItem	The menu item to use to get the vehicle booking time slot from	

Return Value:		NONE

Date		Who		Reason
18 May 2023	navpw1	Initial creation TFS: 54049 (55843)

*/

vars
	theReturn	: Integer;
	vbts		: CM_VehicleBookingTimeSlot;
	
begin	
	if menuItem.userObject = null then
		return;
	endif;
	
	vbts := menuItem.userObject.CM_VehicleBookingTimeSlot;
	
	while true do
		app.myTrxUA.trxDisassocVehicleBookingVvr(vbts, app.myPassport);
		
		if app.myPassport.trxCompletedOK then
			// Clear errors/warnings from form and err/warnings window
			break;
		else
			theReturn := app.showErrorWarningDialog(app.getErrorString(Vehicle_schedul_booking_slot), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   theReturn = IDOK then
				// there must have just been warnings that the user has acknowledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			return;
		endif;
		break;
	endwhile;
	self.zTblDataSortAndShow(true);
	
end;</source>
        <access>protected</access>
        <Parameter name="menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doVehicleVisitCancel" id="ddd6d28c-b8ec-4e1d-9a61-c328b46f0355">
        <updating/>
        <source>doVehicleVisitCancel(_vvr : CM_VehicleVisitRecord; _reason : String) updating, protected;
/*

Purpose:			Cancels a vehicle visit record

Parameters:			_vvr	CM_VehicleVisitRecord	The vehicle visit record to cancel.
					_reason	String					The reason the vehicle visit record was cancelled

Return Value:		NONE

Date		Who		Reason
16 May 2023	navpw1	Initial creation TFS: 54049 (55843)

*/

vars
	theReturn	: Integer;
	aVVR 		: CM_VehicleVisitRecord;
	
begin
	aVVR := _vvr;
	
//	if	aVVR.myRoadJob &lt;&gt; null and not aVVR.isUpdatable then
	if	aVVR.myRoadJob &lt;&gt; null and not aVVR.isUpdatable and not aVVR.isBulkGateVVR then		
		while true do
			app.myTrxUA.trxUpdateVVRCancelWithJob(aVVR, _reason, app.myPassport);
			
			if app.myPassport.trxCompletedOK then
					// Clear errors/warnings from form and err/warnings window
					self.clearErrorWarnings();
					break;
			else
					theReturn := app.showErrorWarningDialog(app.getErrorString(GateInOut), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
					if app.myPassport.noErrors and
					   theReturn = IDOK then
							// there must have just been warnings that the user has acknoledged so ..
							app.myPassport.warningsAcknowledged     := true;
							continue;
					endif;
					self.setAllErrorWarnings(app.myPassport);       // copies errors to this form and shows in err/warnings window
					return;
			endif;
			break;
		endwhile;	
		
		return;
	endif;
		
	while true do
		app.myTrxUA.trxUpdateVVRCancel(aVVR, _reason, app.myPassport);
		
        if app.myPassport.trxCompletedOK then
			// Clear errors/warnings from form and err/warnings window
			self.clearErrorWarnings();
			break;
        else
			theReturn := app.showErrorWarningDialog(app.getErrorString(GateInOut), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   theReturn = IDOK then
					// there must have just been warnings that the user has acknoledged so ..
					app.myPassport.warningsAcknowledged     := true;
					continue;
			endif;
			self.setAllErrorWarnings(app.myPassport);       // copies errors to this form and shows in err/warnings window
			return;
        endif;
        break;
	endwhile;
	
end;</source>
        <access>protected</access>
        <Parameter name="_vvr" type="CM_VehicleVisitRecord"/>
        <Parameter name="_reason" type="String"/>
    </JadeMethod>
    <JadeMethod name="getWeighFormObjects" id="a7f74956-7cc0-473b-b3f4-abd0af93145e">
        <source>getWeighFormObjects(_obj: CM_Object; _objArray: ObjectArray input): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 July 2019	jlgndl1	Initial creation	TFS 44965

*/

vars

	roadJobObj : CM_RoadJob;
	vvr : CM_VehicleVisitRecord;
	errStr : String;

begin

	if _obj &lt;&gt; null then
		_objArray.addExclusive(_obj);
	endif;
	
	roadJobObj := self.myCurrentObject.CM_RoadJob;
	if roadJobObj &lt;&gt; null then
		vvr := roadJobObj.myVehicleVisit;
	endif;
	
	if vvr &lt;&gt; null then
		_objArray.addExclusive(vvr);
		vvr.isWeighBridgeWeighable( _objArray, errStr );
	else
		errStr := "No current vehicle visit found!";	
	endif;
	
	if errStr &lt;&gt; null then
		app.writeLog(method.qualifiedName &amp; " " &amp; errStr, LogINFO);
		app.msgBox( errStr, "Unable to use weigh bridge interface!", MsgBox_OK_Only );
		return false;
	endif;
	
	return true;

epilog

end;</source>
        <Parameter name="_obj" type="CM_Object"/>
        <Parameter name="_objArray" type="ObjectArray" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
