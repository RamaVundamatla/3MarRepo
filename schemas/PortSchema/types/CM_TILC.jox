    <JadeMethod name="createOnboardTransactions" id="b1b0aaf9-ef5e-415a-ae17-c22115e58598">
        <source>createOnboardTransactions(	_txnParams 	: CMIF_TITransactionController input;
							_passport	: CM_Passport input);
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
25 July 2024		jlizm1	Initial creation TFS 65353 Onboard cargo does not get received transaction
BUG 65621 13AUG2024 NAVAB1 'self' is the trailer which does not have children.
*/

vars
	onnboardTIs : CM_TISet;
	ti			: CM_TrackedItem;
	child 		: CM_TrackedItem;
	
begin
	create onnboardTIs transient;
	self.getAllOnboardTIs(onnboardTIs);
	
	foreach ti in onnboardTIs do
		_txnParams.myTrackedItem := ti;
		ti.createTransaction(_txnParams, _passport);
		
		if ti.hasChildren then
// ### TFS BUG 65621 13AUG2024 NAVAB1	foreach child in self.allChildren do
			foreach child in ti.allChildren do
				_txnParams.myTrackedItem := child;
				child.createTransaction(_txnParams, _passport);
			endforeach;
		endif;
	endforeach;
	
epilog
	delete onnboardTIs;
	
end;</source>
        <Parameter name="_txnParams" type="CMIF_TITransactionController" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="delete" id="8f8d86eb-0a23-4b95-8059-dd4b4b1fac33">
        <updating/>
        <source>delete() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 September 2022	jlier1	Initial creation 54700

*/

vars

begin
	if self.isTransient then
		if self.myGenerator &lt;&gt; null and self.myGenerator.isTransient then
			delete self.myGenerator;
		endif;
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="detachGenerator" id="fcc60569-134e-4bc1-a0b7-739b8f229940">
        <updating/>
        <source>detachGenerator(_passport : CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:      18 July 2003 by cnwsgp1
// ---------------------------------------------------------------------------
// Detaches the generator. Does NOT move the generator anywhere after detach.
// Note that an attached generator is not known to the location controller of
// the parent TI, so if a generator is detached on site, the calling
// function must move it to make it appear somewhere in the terminal.
// 30 Aug 2012	cnwcs5	par 30292 - use updateObjectEdition instead of updateEdition 
vars
	theGererator : CM_Generator;
	desc		: String;
	task		: CM_ToDoTask;
	
begin
	exclusiveLock(self);	

	theGererator := self.myGenerator;
	// Check that we have a generator...
	if theGererator = null then
		return;
	endif;

	// Set the generator's parent to null...
	theGererator.myParent := null;	//Not required but just to be safe.

	//Null reference to the generator, generator.relatedTo will also be set null
	self.myGenerator := null;

	//Null the location strings: See comments at top of method
	theGererator.locationId := null;
	theGererator.plannedLocnId := null;
	theGererator.rehandleLocnId := null;
	
	// when detaching a generator type of nose-mounted, we should remove the To Do Task "Detach Generator Set" automatically
	// Par17775. ccms1405. APM Yard Ops, new generator types
	if theGererator.myGeneratorType &lt;&gt; null and theGererator.myGeneratorType.isUnderSlung then
		if (not self.isTransient) then	
			desc := null;
			foreach task in self.allToDoTasksToDo do
				if task.toDoTaskDesc.trxTypeOnCompletion = TRANS_TYPE_DetachGenerator then
					desc	:= task.toDoTaskDesc.description.trimBlanks;
					break;
				endif;
			endforeach;
			if desc &lt;&gt; null then
				self.completeToDoTaskForBulk( task.toDoTaskDesc, null, _passport);	
			endif;
		endif;
	endif;
	
	//Reset voyage and status properties
	if (not self.isTransient) then
		theGererator.changeVoyage(null, _passport);
	else
		theGererator.myVoyage 	:= null;
	endif;
	theGererator.setImExStatus(TI_IMEX_STATUS_STORAGE);

	self.updateObjectEdition(self);	// par 30292
end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getAllDrawingIconsByPriority" id="057b0608-bd00-4fd4-b952-2b02b731074b">
        <source>getAllDrawingIconsByPriority(_iconArray: StringArray input; _maxIcons: Integer; _planning : Boolean);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07/12/2017	jlgmp6	Initial creation	TFS7493
11/11/2019	jlgdap1	TFS 46405 AAT Flat Rack and OOG in LOLO Planning Screen
*/

vars
	root: CM_Root;
	attr,
	startObject: CM_DrawingAttribute;
	lController: CM_LocationsController;
	iter: Iterator;
	attrCode: String;
begin
	root := app.getMyRoot();
	if root = null then
		return;
	endif;
	lController := self.getPrimaryLocation(QUEUE_MODE);
	
	iter := root.allDrawingAttributesByTypePri.createIterator();
	startObject := root.allDrawingAttributesByTypePri.getAtKeyGtr(DrawingAttrType_TrackedItem, null);
	if startObject &lt;&gt; null then
		iter.startAtObject(startObject);
		while iter.next(attr) and attr.drawingAttrType = DrawingAttrType_TrackedItem do
			attrCode := attr.code;
			// tracked item
			if attrCode = PicTIInTransit then
				if self.isInTransitOnShip and self.isOnWagon() then
					_iconArray.add(attrCode);
				endif;
			elseif attrCode = PicTIReadyToShip then
				if self.readyToShip then
					_iconArray.add(attrCode);
				endif;
			elseif attrCode = PicTICustomHold then
				if self.isStopSetToBeProcessed(StopProcessEDICustomExport) then
					_iconArray.add(attrCode);
				endif;
			elseif attrCode = PicTIHazard then
				if self.isHazardous then
					_iconArray.add(attrCode);
				endif;
			elseif attrCode = PicSpecialStow then
				if self.specialStow &lt;&gt; null then
					_iconArray.add(attrCode);
				endif;
			elseif attrCode = PicTITBA then
				if self.myMatchedTBA &lt;&gt; null then
					_iconArray.add(attrCode);
				endif;
			elseif attrCode = PicTIQueued then
				if lController &lt;&gt; null or self.hasMembers(self.allQueuedFutureMoves) then
					_iconArray.add(attrCode);
				endif;
			elseif attrCode = PicTIPlanned then
				if _planning then					// TFS 46405
					continue;						// TFS 46405
				endif;								// TFS 46405
				if self.hasMembers(self.allPlannedFutureMoves) then
					_iconArray.add(attrCode);
				endif;
			elseif attrCode = PicTIActual then
				if self.getFirstAvailableLoadJob() &lt;&gt; null then
					_iconArray.add(attrCode);
				endif;
			elseif attrCode = PicTIControlledAtmos then
				if self.isControlledAtmosphere then
					_iconArray.add(attrCode);
				endif;
			elseif attrCode = PicTIReefer then
				if self.isReefer then
					_iconArray.add(attrCode);
				endif;
			// TILC
			elseif attrCode = PicTIBreakBulk then
				_iconArray.add(attrCode);
			elseif attrCode = PicTICOU then
				if self.hasGeneratorSetAttached() then
					_iconArray.add(attrCode);
				endif;
			endif;
	
			if _maxIcons &lt;&gt; 0 and _iconArray.size() &gt;= _maxIcons then
				break;
			endif;
		endwhile;
	endif;
	
epilog
	delete iter;
end;</source>
        <Parameter name="_iconArray" type="StringArray" usage="input"/>
        <Parameter name="_maxIcons" type="Integer"/>
        <Parameter name="_planning" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getAllOnboardTIs" id="f220d08d-3cda-4c69-a0f1-8409e3fb3446">
        <source>getAllOnboardTIs(_tiSet : CM_TISet input);
/*

Date		Who		Reason
26 September 2013	cnwer1	Initial creation PAR
29 May       2025   navsp1  JIRA-34864 CUX | Data Access Groups for MAFIs and Trailers - Development
*/

vars
	lc : CM_TILCController;
	ti : CM_TrackedItem;
    failedDAC       :CM_DataAccessController;       //JIRA-34864 
begin

	foreach lc in self.allLCs discreteLock do
		
		foreach ti in lc.allTrackedItems discreteLock do
            if not ti.canUserAccessSelf(null, failedDAC, app.myPassport) then           //JIRA-34864 
                continue;                                                               //JIRA-34864
            endif;                                                                      //JIRA-34864
			_tiSet.add(ti);
			if ti.isKindOf(CM_TILC) then
				ti.CM_TILC.getAllOnboardTIs(_tiSet);
			endif;			
		endforeach;
	endforeach;
epilog

end;</source>
        <Parameter name="_tiSet" type="CM_TISet" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getAllOnboardTIsCount" id="436f9da6-8dca-4377-affc-b91f3d1392dd">
        <source>getAllOnboardTIsCount() : Integer;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
09 March 2023		jlizm1	Initial creation TFS 56720 Running weight total for MAFIs

*/

vars
	count 	: Integer;
	anLC 	: CM_TILCController;
	tiSet : CM_TISet;
begin
	count := 0;
	create tiSet transient;
	//jlier1 TFS 63956 23/5/24
	self.getAllOnboardTIs(tiSet);
	count:=tiSet.size;
	
	return count;

epilog
	delete tiSet;
end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getAllTIHazards" id="59898b24-6153-425d-9c48-169329d77baf">
        <source>getAllTIHazards(trackedItem : CM_TrackedItem) : String;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
30 March 2023	navmk20	Task 57224: Jade - New MAFI Columns
*/

vars
	hazard : CM_Hazard;
	tempString, hazStr : String;
begin
	foreach hazard in trackedItem.allTIHazards do
		hazStr := hazard.CM_TIHazard.code &amp; "(" &amp; hazard.CM_TIHazard.undgCodes &amp; ")";
		if hazard.CM_TIHazard.limitedQuantity then
			hazStr := hazStr &amp; " L ";
		endif;
		
		if hazard.CM_TIHazard.isMarinePollutant = MarinePollutant_Yes then
			hazStr := hazStr &amp; " MP";
		endif;
		
		if hazStr &lt;&gt; null then
			if tempString = null then
				tempString := hazStr;
			else
				tempString := tempString &amp; ", " &amp; hazStr;
			endif;
		endif;
	endforeach;
	return tempString;
epilog

end;</source>
        <Parameter name="trackedItem" type="CM_TrackedItem"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getAuditTextForProperty" id="0387c078-8460-4101-9132-19116ef0a684">
        <source>getAuditTextForProperty(_property: Property): String;
/*

