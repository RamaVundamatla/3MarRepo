    <JadeMethod name="doCreateTableOrganisor" id="bf621cd1-2f81-46eb-bce9-1f07174ee49f">
        <updating/>
        <source>doCreateTableOrganisor() updating;
//-----------------------------------------------------------------------
//	Created:	11 May 2006 Lorcan Bolster  (cnwlb1/lorcan)
//-----------------------------------------------------------------------
//
// NB One thing to be aware of there is that we create EntTable stuff as transients to use the form
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 08/05/2013	cnwdap1		PAR #31155 CCMS SFW 1321 Imperial Measurements - massage column organiser stuff to suit
// 24/05/2013	cnwdap1		PAR #31486 New parameter for showSelectorColumnOrganiserFrm method
vars

	entTableDef			: EntTableDef;
	column				: String;
	entTableRow			: EntTableRow;
	queryProp			: CM_QueryProperty;
	pos					: Integer;
	header				: EntTableRowHeader;
	columnName			: String;									// PAR #31155
	revPos				: Integer;									// PAR #31155
	measure				: String;									// PAR #31155
	selectorMode		: Integer;									// PAR #31486
	selectorType		: Integer;	//29 Mar 2019	NDL	TFS 44100

begin
	self.tblResults.disallowColumnSorter := true;
	
	tblResults.allTblDataEntRows.purge();
	delete tblResults.myEntTableDef;
	
	if tblResults.myEntTableDef = null then
		if self.myTerminal.getConfig(UseDefColsInSelectorForm).Boolean = false then
			create entTableDef transient;

			foreach column in allColumns do

				create entTableRow transient;
				entTableRow.allEntTableDefs.add(entTableDef);
				
				if column.isMeasurementType then								// PAR #31155
					pos := column.pos("_", 1);									// PAR #31155
					revPos := column.reversePos("_");							// PAR #31155
					measure := column[revPos+1:end];							// PAR #31155
					columnName := column[pos+1:revPos-pos-1];					// PAR #31155
				else															// PAR #31155
					measure := null;											// PAR #31155
					columnName := column;										// PAR #31155
				endif;															// PAR #31155
					
				//queryProp := self.myQDef.allQueryProperties[column];			// PAR #31155
				queryProp := self.myQDef.allQueryProperties[columnName];		// PAR #31155
				// Par 12943
				if queryProp &lt;&gt; null then
					if queryProp.canBeViewed(app.myPassport) then //cnwgb1 25.11.08 PAR 18541 CCMS 1788
						if measure &lt;&gt; null then													// PAR #31155
							entTableRow.setHeading (queryProp.niceName &amp; Space &amp; measure);		// PAR #31155
						else																	// PAR #31155
							entTableRow.setHeading (queryProp.niceName);
						endif;																	// PAR #31155
						// this originally use control name as a way to store the original column name unaltered 
						entTableRow.setOriginalColumnName(column);		// 34658 measurement types, original names can be longer than 30
						create header transient;
						entTableRow.setMyTransientHeader(column, header);
						if measure &lt;&gt; null then																				// PAR #31155
							entTableRow.setMeasurementType(app.myRoot.allMeasurementTypesByShortName[measure].shortName);	// PAR #31155
						endif;																								// PAR #31155
						pos := self.allVisibleColumns.indexOf(column); 
						if pos &gt; 0 then
							//self.tblResults.allTblDataEntRows.add(entTableRow);		// 32345 was atPut(pos, caused problems and was not needed, just add
							self.tblResults.allTblDataEntRows.atPut(pos,entTableRow);	// 12 Nov 2013	NDL	Par 32961 - put it back so the column
																						//				organiser retains data in the correct order. 
						endif;
					endif;
				endif;
			endforeach;
		else
			create entTableDef transient;

			foreach column in allDefColumns do

				create entTableRow transient;
				entTableRow.allEntTableDefs.add(entTableDef);
				
				if column.isMeasurementType then								// PAR #31155
					pos := column.pos("_", 1);									// PAR #31155
					revPos := column.reversePos("_");							// PAR #31155
					measure := column[revPos+1:end];							// PAR #31155
					columnName := column[pos+1:revPos-pos-1];					// PAR #31155
				else															// PAR #31155
					measure := null;											// PAR #31155
					columnName := column;										// PAR #31155
				endif;															// PAR #31155
					
				//queryProp := self.myQDef.allQueryProperties[column];			// PAR #31155
				//queryProp := self.myQDef.allQueryProperties[columnName];		// PAR #31155
				// Par 12943
				//if queryProp &lt;&gt; null then
//				if queryProp.canBeViewed(app.myPassport) then //cnwgb1 25.11.08 PAR 18541 CCMS 1788
				if measure &lt;&gt; null then													// PAR #31155
					entTableRow.setHeading (columnName &amp; Space &amp; measure);		// PAR #31155
				else																	// PAR #31155
					entTableRow.setHeading (columnName);
				endif;																	// PAR #31155
				// this originally use control name as a way to store the original column name unaltered 
				entTableRow.setOriginalColumnName(column);		// 34658 measurement types, original names can be longer than 30
				create header transient;
				entTableRow.setMyTransientHeader(column, header);
				if measure &lt;&gt; null then																				// PAR #31155
					entTableRow.setMeasurementType(app.myRoot.allMeasurementTypesByShortName[measure].shortName);	// PAR #31155
				endif;																								// PAR #31155
				pos := self.allDefVisibleColumns.indexOf(column); 
				if pos &gt; 0 then
					//self.tblResults.allTblDataEntRows.add(entTableRow);		// 32345 was atPut(pos, caused problems and was not needed, just add
					self.tblResults.allTblDataEntRows.atPut(pos,entTableRow);	// 12 Nov 2013	NDL	Par 32961 - put it back so the column					
																				//				organiser retains data in the correct order. 
				endif;
	//			endif;
				//endif;
			endforeach;
		endif;
		
		self.tblResults.setMyEntTableDef (entTableDef);
	endif;
	
	if self.myQDef &lt;&gt; null then												// PAR #31486
		selectorMode := self.myQDef.mode;									// PAR #31486
		selectorType := self.myQDef.type;		//29 Mar 2019	NDL	TFS 44100
	endif;																	// PAR #31486

	//self.tblResults.showSelectorColumnOrganiserFrm(self.myTerminal, self.myCurrentCargoBOLType, self.myMasterMenuAction);				// PAR #31486
	self.tblResults.showSelectorColumnOrganiserFrm(self.myTerminal, self.myCurrentCargoBOLType, self.myMasterMenuAction, selectorMode, selectorType);	// PAR #31486
	
epilog


end;
</source>
    </JadeMethod>
    <JadeMethod name="doExtractToFile" id="942208d5-7873-43f5-be95-e6f56f48eee5">
        <source>doExtractToFile() protected;
// --------------------------------------------------------------------------------
// Created:		09 January 2006 by cnwdad1
//
// Purpose:		Extracts the Results table to a disk file, in CSV format.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 02/12/2008	cnwdad1		PAR 18578 - Changed to let the BaseSchema method take
//							care of determining the file name.
// --------------------------------------------------------------------------------
vars
	fileObj		: File;
	
begin
	if self.myEnqController.allObjects.isEmpty() then
		return;
	endif;
	
	create fileObj transient;	
	fileObj.mode := File.Mode_Output; // 1/3/16  cnwns1 PAR 36286 unicode version
	
// cnwdad1 02/12/2008 - PAR #18578.
//	if not fileObj.cnEcSetSaveName(	"",
//									true,
//									true,
//									/*CNEC_FILE_FILTER_ALL &amp; "|" &amp;*/ CNEC_FILE_FILTER_DATA) then
//		return;
//	endif;
//	if (not fileObj.tryOpen) then
//		app.raiseCMException1(FileUnavailable, fileObj.fileName, null, null);	
//		return;
//	endif;
	
	tblResults.cnEcExportToCSV(fileObj, true);
epilog
	delete fileObj;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doFilter" id="7c611ee5-e296-455b-bb1b-24f9aae30fcd">
        <updating/>
        <source>doFilter() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date			 	Who	      Reason
19 October 2022	 	navgm20   ChangeRequest 55106: EUP - Filtered Drop-downs and Lists FIND LISTS
27 February 2023 	navsa20   Bug 56681: EUP - Selector Query is One Of Filter

*/

vars
	findText	   : String;
	tbl            : CMUI_ListTable;
	rowIndex       : Integer;
	colIndex       : Integer;
	checkBoxColumn : Integer;
	checkText      : String;
	length         : Integer;
begin
	findText := self.txtArgFind.text.trimBlanks.toUpper();
	length := findText.length;
	tbl:= self.tblArgument;
	
	if findText = "" then
		self.doClearFilter();
		return;
	else
		self.btnClear.enabled := true;
	endif;
	
	checkBoxColumn := tbl.getChkBoxColumn;

	foreach rowIndex in 1 to tbl.rows do : loop
		if  tbl.accessRow( rowIndex ).visible then
		//	tbl.accessRow(rowIndex).visible	:= false;			//27.02.2023 NAVSA20 TFS 56681
		//	continue loop;										//27.02.2023 NAVSA20 TFS 56681
		//else													//27.02.2023 NAVSA20 TFS 56681
			foreach colIndex in 1 to tbl.columns where colIndex &lt;&gt; checkBoxColumn do : innerLoop
				checkText := tbl.accessCell( rowIndex, colIndex ).text.trimBlanks.toUpper();
				if checkText.pos(findText,1) &gt; 0 then
					//tbl.accessRow(rowIndex).visible	:= true;				 //27.02.2023 NAVSA20 TFS 56681
					break innerLoop;
				endif;
			endforeach;
			if checkText.pos(findText,1) &gt; 0 then               //27.02.2023 NAVSA20 TFS 56681
				tbl.accessRow(rowIndex).visible	:= true;		//27.02.2023 NAVSA20 TFS 56681
			else												//27.02.2023 NAVSA20 TFS 56681
				tbl.accessRow(rowIndex).visible	:= false;		//27.02.2023 NAVSA20 TFS 56681
			endif;												//27.02.2023 NAVSA20 TFS 56681
		endif;
	endforeach;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doHandle1066AfterCancel" id="a4af4d39-6ebc-4279-99aa-09ce084fb0bb">
        <source>doHandle1066AfterCancel(_exc : Exception) : Integer;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
18 June 2012	cnwndl1	Initial creation	Par 29508

*/

vars

	returnVal		: Integer;

begin

	returnVal := Ex_Pass_Back;
	
	if _exc.errorCode = 1066 then
		if _exc.resumable then
			returnVal := Ex_Resume_Next;
		endif;
	endif;

epilog

	return returnVal;

end;</source>
        <Parameter name="_exc" type="Exception"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
