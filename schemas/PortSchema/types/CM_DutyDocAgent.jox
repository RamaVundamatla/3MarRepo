    <JadeMethod name="isAssignedToDutyDoc" id="43e239ae-e162-4a5b-af4e-58995a6daadf">
        <source>isAssignedToDutyDoc(_ti: CM_TrackedItem; _dutyDoc: CM_DutyDoc) : Boolean;
/*
Return true if the ti is assigned to a different Duty Doc or no Duty Doc (32036)
16/09/2014 cnwma1 PAR #32925 Multiple HS code and Currency
 */
vars
	dutyDocRoot			: CM_DutyDocRoot;
	dutyDocTerminalRoot :CM_DutyDocTerminalRoot;
	dutyDocItem 	: CM_DutyDocItem;
	iter: Iterator;
begin
	
	dutyDocRoot:=app.myDutyDocRoot;
	if dutyDocRoot = null then
		return false;
	endif;
	
	dutyDocTerminalRoot:=dutyDocRoot.allDutyDocTerminalRoots[_ti.myTerminal];
	if dutyDocTerminalRoot  = null then
		return false;
	endif;
	
	iter:=dutyDocTerminalRoot.allDutyDocItemsByTI.createIterator;
	
	dutyDocTerminalRoot.allDutyDocItemsByTI.startKeyGeq(_ti,iter);
	while iter.next(dutyDocItem) do
		if dutyDocItem.getMyTrackedItem &lt;&gt; _ti then
			break;
		endif;

		if dutyDocItem.myDutyDoc = null   then  // PAR 34042
			return false;
		endif;
		if dutyDocItem.myDutyDoc = _dutyDoc then  // PAR 32925 //16/09/2014 CNWMA1 PAR32925
			return false;
		endif;
		
		
		return true;
	endwhile;
	
	return false;
	
epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_dutyDoc" type="CM_DutyDoc"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
