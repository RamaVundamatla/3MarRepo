<Class name="ExternalMethod">
    <JadeMethod name="jtdGetSourceLine" id="6e0d9e18-8fb2-4805-b1cb-2dcfc41d48e8">
        <source>jtdGetSourceLine(position : Integer) : String;

vars
	lib		: Library;
	libname	: String;
	str		: String;	
begin
	lib		:= self.library;
	if app.isValidObject(lib) then
		libname := lib.name;
	endif;

	return self.entrypoint &amp; " in " &amp; libname &amp; " @ line # " &amp; position.String; 
end;</source>
        <Parameter name="position" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
</Class>
