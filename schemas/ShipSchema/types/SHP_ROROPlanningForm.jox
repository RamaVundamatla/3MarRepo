epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="displayModeColour" id="c4c5b47c-eac9-441a-bebf-fa78b12a69c4">
        <updating/>
        <source>displayModeColour(_isLoad : Boolean) updating;
// ---------------------------------------------------------------------------
// Created:		January 2003 By Andrew Bishop cnwab1
//
// Purpose:		
// ---------------------------------------------------------------------------
/*

Date		Who		Reason
01 Mar 2011	cnwkpd1	PAR #27032 - Load Colour Code performance
			cnwer1

*/

vars
	yaIMEXConfig 	: CM_VoyageAllocationConfig;
	useAlloc 		: Boolean;
	
begin
	useAlloc := false;
	if self.myCurrentVoyage &lt;&gt; null then
		useAlloc := self.myCurrentVoyage.useVoyageAllocations;
	endif;

	if useAlloc then
		if self.myCurrentVoyage &lt;&gt; null and self.myCurrentVoyage.allVoyageAllocationConfigs.size &gt; 0 then
			yaIMEXConfig := self.myCurrentVoyage.allVoyageAllocationConfigs[TI_IMEX_STATUS_EXPORT].CM_VoyageAllocationConfig;
			if yaIMEXConfig &lt;&gt; null then
				if yaIMEXConfig.allOpCriteria.isEmpty then
					app.msgBox(app.getErrorString(Please_voyage_config_color_cod), app.getErrorString(Problem), MsgBox_OK_Only);
					return;
				endif;
			endif;
		endif;
		
		//24 Jan 2012	NDL	Par 28896
		if (not  self.myConfig.CMIF_ConfigUserVoyagePlanning.shipCCHidePalette )
		or (self.myCCPaletteLoad &lt;&gt; null) then 					
			if self.myCCScreen &lt;&gt; null and self.myCCScreen.isExport &lt;&gt; _isLoad  then
				self.myCCScreen.doChangeIMEX(_isLoad);
			endif;
			if not _isLoad then
				if self.myCCPalette &lt;&gt; null and self.myCCPalette.isExport &lt;&gt; false then
					self.myCCPalette.doChangeIMEX(false);
				endif;
			endif;
		endif;
		
	endif;

	//epr par 29098
	self.cmbWorkPoint.listIndex := -1;
	self.cmbWPJob.listIndex := -1;
	self.myCurrentJob:=null;
	if self.myCurrentVoyage = null then
		self.chkOutOfSequence.value := false;
	elseif self.modeView = ShpDisplayMode_ColCodeLoad then //cnwrd1 par 31771 19.6.13
		self.chkOutOfSequence.value := self.myCurrentVoyage.createOutOfSequenceLoadJobs(); //cnwrd1 par 30626 ccms 2209 23.10.12
	endif;



	self.doResize();

end;</source>
        <Parameter name="_isLoad" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doAlignment" id="a7737395-4dba-401b-9749-7dcffa85e40a">
        <updating/>
        <source>doAlignment(_position : Integer) updating;
/*
Purpose:			
Date		Who		Reason
14 April 2011	cnwab1	Initial creation
*/

vars
	theReturn : Integer;
begin
	
		while true do
			app.myTrxUA.trxUpdateROROLocnAlignment(self.frmDeck.myDrawingFrame.CMUI_PointDrawingFrame.allPointGraphics, _position, app.myPassport);
			if app.myPassport.trxCompletedOK then
				// Clear errors/warnings from form and err/warnings window
				self.clearErrorWarnings();
				global.beep;
				break;
			else
				theReturn := app.showErrorWarningDialog(app.getErrorString(Ootl_alignment), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
				if app.myPassport.noErrors and
				   theReturn = IDOK then
					// there must have just been warnings that the user has acknoledged so ..
					app.myPassport.warningsAcknowledged	:= true;
					continue;
				endif;
				self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
				return;
			endif;
			break;
		endwhile;
epilog

end;</source>
        <Parameter name="_position" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="doAssignRelease" id="4119e40f-95f8-415a-8152-2a3c8d1effc6">
        <updating/>
        <source>doAssignRelease( _menuItem : MenuItem input) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
12 December 2012	cnwrd1	Initial creation

*/

vars

	bulkReleaseReserveDetail : CM_ReserveDetail;
begin
	bulkReleaseReserveDetail := _menuItem.userObject.CM_ReserveDetail;
	self.updateRequestBulkRelease( bulkReleaseReserveDetail);

epilog

end;</source>
        <Parameter name="_menuItem" type="MenuItem" usage="input"/>
