        <source>setEDIStatus(_value : Integer) updating;
//
// 12 Mar 2018	jlgrs1	TFS 37484 - QNS Allow DB Loading of Bay Plan files
//
vars

begin
	self.ediStatus := _value;
epilog

end;</source>
        <Parameter name="_value" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="0afcd539-d4ee-4871-81b7-d749938c8d23">
        <updating/>
        <source>setForCreate(_voyage: CM_Voyage; _description: String; _ediData: CM_EDIData io) updating;
/*
------------------------------------------------------------------------
Created:			20 February 2003 by cnwdwq1
Purpose:			Dave Q's code
Parameters:		See Method signature above. Special comment:
Returns:			See Method signature above. Special comment:
Changed On		Changed By		Reason
------------	------------	-----------------------------------------
														
------------------------------------------------------------------------
*/
vars

begin
	self.setMyVoyage(_voyage);
	if _ediData.myBayPlanController &lt;&gt; null then //rs may 2006 found testing edi
		_ediData.myBayPlanController.myEdiData := null;
	endif;
	self.myEdiData := _ediData;
	self.description := _description &amp; " " &amp; self.getMyEDIIndex.String.padLeadingZeros(2);
	if self.myVoyage = null then
		return;
	endif;
end;</source>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_description" type="String"/>
        <Parameter name="_ediData" type="CM_EDIData" usage="io"/>
    </JadeMethod>
    <JadeMethod name="setMyVoyage" id="e384b774-ddf7-4a89-bcf0-55dc63133cf2">
        <updating/>
        <source>setMyVoyage(_voyage : CM_Voyage)  updating;
/*
------------------------------------------------------------------------
Created:			20 February 2003 by cnwdwq1
Purpose:			Dave Q's code
Parameters:		See Method signature above. Special comment:
Returns:			See Method signature above. Special comment:
Changed On		Changed By		Reason
------------	------------	-----------------------------------------
														
------------------------------------------------------------------------
*/
begin
	self.myVoyage := _voyage;
end;</source>
        <Parameter name="_voyage" type="CM_Voyage"/>
    </JadeMethod>
    <JadeMethod name="shortDescription" id="f6174614-95b0-4ab4-a45b-d05aa0e7fcbb">
        <methodInvocation>mapping</methodInvocation>
        <source>shortDescription(set: Boolean; _value: String io) mapping;
// ---------------------------------------------------------------------------
// Created:		March 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	thePos : Integer;
begin
	if set then
		return;
	endif;
	
	if self.myVoyage = null then
		_value := null;
	else
		thePos := self.description.pos(self.myVoyage.code.trimBlanks,1);
		if thePos &gt; 0 then
			_value := (self.description[thePos:end])[1:30]; //par 16500 cnwrs1 Mar 2008
		else
			_value := self.description[1:30];
		endif;
	endif;
end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="String" usage="io"/>
    </JadeMethod>
</Class>
