// --------------------------------------------------------------------------------
// Created:  07 August 2000 by cnwdad1
//
// Changed On Changed By Reason
// ---------- ---------- ----------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	reportForm	: CnEcReportQueueListForm;
	
