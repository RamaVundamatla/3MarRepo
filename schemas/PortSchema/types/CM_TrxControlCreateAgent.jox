    <JadeMethod name="trxCreateMultiVBSAdv" id="1bd93045-7207-4354-ab25-559b62ee0790">
        <updating/>
        <source>trxCreateMultiVBSAdv(_numCopies : Integer;_proxy : CM_VehicleBookingTimeSlot; _newVehicleBookingTimeSlot : CM_VehicleBookingTimeSlot output;  _passport : CM_Passport input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 Apr 2023	navhl20	ChangeRequest 57716:[57718] EUP - VBS changes MTN - Bulk Edit and Linking of slots [Refinement - 01]
24 May 2023 navhl20 Defect 58041: MTN - Unable to copy the slots with the status "Booked - Current"
11 Jul 2023 navhl20 Bug 59101: EUP | VBS changes MTN - Multiple warnings
*/

vars
	vbsTimeSlotItems 	: CM_VehicleBookingTSItemSet; 
	count			 	: Integer;
begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	app.setContinueCMExceptions(false);
	
	create vbsTimeSlotItems transient;
	
	_proxy.allVehicleBookingItems.copy(vbsTimeSlotItems);
	
	// Start the transaction
	beginTransaction;	

	// Perform the operation
	//foreach count in 1 to _numCopies do																													//11.7.2023 navhl20 #59101
	app.myUtilityCA.utlCreateMultiVBSAdv(_proxy, _newVehicleBookingTimeSlot, vbsTimeSlotItems,_numCopies, _passport);		//24.5.2023 navhl20 #58041		//11.7.2023 navhl20 #59101
	//endforeach;																																			//11.7.2023 navhl20 #59101
	
epilog
	delete vbsTimeSlotItems;
	self.finaliseActivityWithPassport(_passport);
end;</source>
