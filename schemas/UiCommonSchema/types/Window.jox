<GUIClass name="Window">
    <JadeMethod name="isRoadOpsForm" id="fcd3debc-94a4-41d4-b711-aa41227fbd99">
        <source>isRoadOpsForm():Boolean;
// --------------------------------------------------------------------------------
// Created:		03 November 2005 by cnwdad1
//
// Purpose:		Returns a boolean flag to indicate whether the receiver is the Yard
//				Schema's Road Operations form.  This method is reimplemented on the
//				Road Operations form in the YardSchema.
//
// Parameters:	None
//
// Returns:		True if the receiver is the Road Operations form, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return false;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
