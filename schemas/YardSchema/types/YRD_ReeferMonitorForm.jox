    <JadeMethod name="btnWalkPath_click" id="6acb4942-b6dc-4e9d-b3ef-ce29e92e6e9c">
        <controlMethod name="CMUI_Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnWalkPath_click(btn: Button input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 July 2020	jlgndl1	Initial creation	TFS 49581

*/

vars

	sysSchema : Schema;
	uiSchema : Schema;
	formClass : Class;
	form : Form;
	

begin

	if currentSchema.name = "UiCommonSchema" then
		uiSchema := currentSchema;
	else
		uiSchema := currentSchema.getSchema("UiCommonSchema");
	endif;
	if uiSchema &lt;&gt; null then
		sysSchema := uiSchema.getSchema("SysOpsSchema");
	endif;
	if sysSchema &lt;&gt; null then
		formClass := sysSchema.getClass("SOP_ReeferWalkPathNonModdal");
	endif;

	if formClass &lt;&gt; null then
		form := app.loadForm(formClass, CMUI_Assistant, false, false, true, self.myTerminal, null);
		form.show;
	endif;

epilog

end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
