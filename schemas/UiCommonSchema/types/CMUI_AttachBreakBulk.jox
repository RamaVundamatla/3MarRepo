    <JadeMethod name="getTblItemDef" id="dfc12f05-a2d9-4e50-9425-3ae1178d3a73">
        <source>getTblItemDef() : EntTableDef;
// ---------------------------------------------------------------------------
// Created:     16 October 2002		cnwth2	
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	entDef					:EntTableDef;
	warehouseEnabled		: Boolean;
begin
	warehouseEnabled := app.getMyUser().canDo(self.myTerminal, Mod_GeneralCargo);
	if self.aIsForCreation then
		if warehouseEnabled then
			if self.aMyMasterTI &lt;&gt; null then
				entDef := app.myController.getEntTableDef(ETDef_ItemDataAttach);
			else
				entDef := app.myController.getEntTableDef(ETDef_ItemDataExp);
			endif;
		else
			if self.aMyMasterTI &lt;&gt; null then
				entDef := app.myController.getEntTableDef(ETDef_ItemDataLCLAttach);
			else
				entDef := app.myController.getEntTableDef(ETDef_ItemDataLCLExp);
			endif;
		endif;
	else
		if warehouseEnabled then
			entDef := app.myController.getEntTableDef(ETDef_ItemData);
		else
			entDef := app.myController.getEntTableDef(ETDef_ItemDataLCL);
		endif;
	endif;
	
	return entDef;
end;</source>
        <ReturnType type="EntTableDef"/>
    </JadeMethod>
    <JadeMethod name="getXMLSettingsForSave" id="c541259e-06b1-4472-bd47-0a15314a7a26">
        <updating/>
        <source>getXMLSettingsForSave(): String updating;
// ---------------------------------------------------------------------------
// Created:     11 November 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	rtnStr			: String;
	taType			: CM_TerminalAreaType;
	taTypeStr		: String;
begin
	rtnStr := inheritMethod();
	
	//th2 for Everitt
	taType := self.cmbTAType.listObject.CM_TerminalAreaType;
	if taType &lt;&gt; null then
		taTypeStr := taType.type.String;
	endif;
	
	rtnStr := rtnStr &amp; global.formatAsXML(self.XMLTag_FormHeight, self.height.String) &amp;
						global.formatAsXML(self.XMLTag_FormWidth, self.width.String) &amp;
						global.formatAsXML(self.XMLTag_Splitter, self.sptMain.leftToRightRatio.String) &amp;
						global.formatAsXML('TAType', taTypeStr);
	return rtnStr;				
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="hideRowsForMakeAttachment" id="1e9a8559-a11f-498e-95db-c50077f966f1">
        <source>hideRowsForMakeAttachment();
//********************************************************************
//
// Created by: cnwsh3
//
// Date: 28 January 2004
//
//	As per version 6 when adding an attachment (previously make LCL), the ti
//  that is generated uses it's parent properties to find this info.  
//
//********************************************************************
vars
	tbl : CM_EntryTable;								
begin


	tbl := self.tblItem;
	tbl.hideRowByName(ETRow_Operator, false);
	tbl.hideRowByName(ETRow_DisPort,false);
	tbl.hideRowByName(ETRow_DestPort,false);
	tbl.hideRowByName(ETRow_Consignee, false);
	tbl.hideRowByName(ETRow_Consignor, false);
	//tbl.hideRowByName(ETRow_Commodity, false);		//cnwmc5 - 17 June 2014 - PAR 34244
	tbl.hideRowByName(ETRow_ImexStatus, false);
	tbl.hideRowByName(ETRow_BookingRef, false);
//	tbl.hideRowByName(ETRow_Remarks, false);
	tbl.hideRowByName(ETRow_Voyage, false);
	

	
end;</source>
    </JadeMethod>
    <JadeMethod name="hideRowsForShipPreNote" id="cffacc6b-1b0b-4561-8cc9-66a975022145">
        <source>hideRowsForShipPreNote();
// ---------------------------------------------------------------------------
// Created:     12 January 2006	cnwhjg1
//
// Purpose:     
// ----------   ----------  --------------------------------------------------
vars

	tbl : CM_EntryTable;								
begin

	tbl := self.tblItem;
	tbl.hideRowByName(ETRow_TaType, false);
