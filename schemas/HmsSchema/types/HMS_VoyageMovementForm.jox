    <JadeMethod name="clearData" id="5c74a063-ccd8-4884-9395-471a7be4df99">
        <source>clearData() protected;
//--------------------------------------------------
// Created:	28 October 2005 By: cnwgd1
//--------------------------------------------------
vars
	numControls,
	int:	Integer;
	ctl:	Control;
begin
	
	numControls := self.controlCount;
	int := 1;
	while int &lt;= numControls do
		ctl := self.controls(int);
		if ctl.isKindOf(Label)
		or ctl.isKindOf(Button)	
		or ctl.isKindOf(ListBox)
		or ctl.isKindOf(CMUI_ListTable)
		or ctl = self.cmbHMSVoyage
		or ctl = self.cmbMovements 			
		or ctl.isKindOf(CMUI_ButtonForToolbar) then
			int := int+1;
			continue;
		elseif ctl.isKindOf(CheckBox) then
			ctl.CheckBox.value := false;
		elseif ctl.isKindOf(TextBox) then
			ctl.TextBox.text := null;
		elseif ctl.isKindOf(Table) then
			ctl.Table.rows := ctl.Table.fixedRows;
		elseif ctl.isKindOf(JadeEditMask) then
			ctl.JadeEditMask.text := null;
		elseif ctl.isKindOf(ComboBox) then
			ctl.ComboBox.listIndex := -1;		
		elseif ctl.isKindOf(OptionButton) then
			ctl.OptionButton.value := false;
		endif;
		int := int+1;
	endwhile;
	
	self.lstTugs.setSelected(null);
	self.lstPilots.setSelected(null);	//30 Oct 2018	NDL	TFS 4662
	self.populateCmbMovements( null );	//19 Nov 2018	NDL	TFS 42043
			
end;</source>
        <access>protected</access>
    </JadeMethod>
