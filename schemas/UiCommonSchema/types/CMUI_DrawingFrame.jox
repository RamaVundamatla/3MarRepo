    <JadeMethod name="handleInvalidMethodCall" id="b411a583-e1a0-4b17-a9cc-44f2f28354b3">
        <source>handleInvalidMethodCall(_exc : Exception) : Integer;

constants
	MethodWrong	= 1010;
	
vars
	returnVal		: Integer;
	
begin
	returnVal := Ex_Pass_Back;
	if _exc.errorCode = MethodWrong  then
		if _exc.resumable then
			returnVal := Ex_Resume_Next;
		endif;
	endif;

	return returnVal;

end;</source>
        <Parameter name="_exc" type="Exception"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
