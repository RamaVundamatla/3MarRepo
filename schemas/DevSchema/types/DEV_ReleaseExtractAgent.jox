        <source>getJRWDetails(_views,
			  _templates,
			  _reports : StringArray input) typeMethod;

/*

Purpose:			Set up the list of JRW Views, Templates and Reports to be included in the release.
					Any new items should be added to this script as part of the development

Parameters:			Lists of Views, Templates and Reports to be populated

Return Value:		Views, Templates and Reports to be populated appropriately


Date		Who		Reason
23 Feb 2010	cnwkpd1	Automate release process
01 May 2019	jlgdap1	TFS 44298 PEL1 Host-to-Host (H2H) Monitoring
24/04/2023	navkc1	CR 55654 Task 55670: Jade - Contract reporting
21/07/2023	navkc1	Changed to typeMethod
16 Aug 2023 navhl20 ChangeRequest 58568: EUP - Delivery Dispatch – Reporting
*/

vars

begin
	// First populate the views
	_views.add("BOLIn");
	_views.add("BOLOut");
	_views.add("CM_AnyDataObjectView");
	_views.add("CM_GeneralCargoDocketsView");
	_views.add("CM_HMS_MovementView");
