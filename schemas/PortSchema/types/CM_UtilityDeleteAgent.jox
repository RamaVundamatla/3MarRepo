    <JadeMethod name="utlDeleteFiles" id="3ee1d8a6-e30f-49d1-a028-3c82a66b4aaf">
        <source>utlDeleteFiles(_theFiles : CM_FileDataSet input ; _passport : CM_Passport input);
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
26 August 2022		jlizm1	Initial creation TFS 54298 EUP - Simplified Voyage Work Order Process

*/

vars
	file : CM_FileData;
	tmpParent	: CM_Object;
	
begin
	self.initialiseActivity();

	app.setContinueCMExceptions(true);

	foreach file in _theFiles do
		app.myValDA.valDeleteFile(file.myParent, file);
	endforeach;
	
	if (not self.checkValidationWithPassport(_passport)) then // Show any Errors and Warnings in a list
		return;
	endif;

	app.setContinueCMExceptions(false);
	
	foreach file in _theFiles do
		tmpParent := file.myParent;
		delete file;
		
		if _passport.noErrors and tmpParent &lt;&gt; null then
			tmpParent.causeEvent(EventFileDelete, false, null);
			if tmpParent.isKindOf(CM_CargoBOLType) then
				self.updateObjectEdition(tmpParent);
			endif;
		endif;
	endforeach;
	
epilog

end;</source>
        <Parameter name="_theFiles" type="CM_FileDataSet" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlDeleteFinancialPeriodMap" id="a361dd86-14ed-44af-b0b8-22be3a0c00a0">
