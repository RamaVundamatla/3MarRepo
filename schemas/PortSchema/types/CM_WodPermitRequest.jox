epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="73b87d73-a6f0-42ba-a2b3-89848534a949">
        <updating/>
        <source>setForUpdate(_pxyWoDDtl: CM_WodPermitRequest) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 October 2018	jlger1	Initial creation 41310

*/

vars
	realCargoDetail,
	pxyCargoDetail : CM_WodCargoRequest;
	pxyDetail : CM_WorkOrderDtl;
	cargoToDelete : ObjectSet;
	realMarineDetail : CM_WodMarineServiceDetail;
	pxyMarineDetail : CM_WodMarineServiceDetail;
	wodMarineServiceDtl : CM_WodMarineServiceDetail;	
//	purgeSet : CM_WodMarineServiceDetailSet;
begin
	inheritMethod(_pxyWoDDtl);
	self.permitType:=_pxyWoDDtl.permitType;
	self.permitDetailType:=_pxyWoDDtl.permitDetailType;
	self.myOperator := _pxyWoDDtl.myOperator;
	
	//epr TFS 42254 28/11/18
	create cargoToDelete transient;
	self.allCargoDetails.copy(cargoToDelete);
	foreach pxyCargoDetail in _pxyWoDDtl.allCargoDetails discreteLock do
		 realCargoDetail:=pxyCargoDetail.pxyGetRealObject .CM_WodCargoRequest;
		 pxyDetail:=pxyCargoDetail;
		 if realCargoDetail = null then
			 create realCargoDetail persistent;	
			
			 realCargoDetail.setForCreate(pxyDetail, null);
			 self.allCargoDetails.add(realCargoDetail);
		else
			cargoToDelete.remove(realCargoDetail);
			realCargoDetail.setForUpdate(pxyCargoDetail);			
		endif;
	endforeach;
	
	//17 Aug 2018	NDL	TFS 40127 &amp; out with //28 Nov 2018	NDL	TFS 41980
/*	create purgeSet transient;
	foreach wodMarineServiceDtl in self.allMarineServiceDetails do
		if _pxyWoDDtl.allMarineServiceDetails.findWodMarineServiceDet( wodMarineServiceDtl.myHMSResource ) = null then
			purgeSet.add( wodMarineServiceDtl );
		endif;
	endforeach;
	if not purgeSet.isEmpty then
		foreach wodMarineServiceDtl in purgeSet do
			self.allMarineServiceDetails.remove( wodMarineServiceDtl );
		endforeach;
		purgeSet.purge();
	endif; */
     
	foreach pxyMarineDetail in _pxyWoDDtl.allMarineServiceDetails discreteLock do
		 realMarineDetail:=pxyMarineDetail.pxyGetRealObject .CM_WodMarineServiceDetail;
		 pxyDetail:=pxyMarineDetail;
		 if realMarineDetail = null then
			 create realMarineDetail persistent;	
			
			 realMarineDetail.setForCreate(pxyDetail.CM_WodMarineServiceDetail, null);
			 self.allMarineServiceDetails.add(realMarineDetail);
		else
			realMarineDetail.setForUpdate(pxyMarineDetail);			
		endif;
	endforeach;
	
	//epr TFS 41880 13/11/18
	if self.myPermitWodVoyageDetail = null and _pxyWoDDtl.myPermitWodVoyageDetail &lt;&gt; null then
		self.myPermitWodVoyageDetail:=_pxyWoDDtl.myPermitWodVoyageDetail;
	endif;
	
epilog
	if cargoToDelete &lt;&gt; null then
		cargoToDelete.purge;
	endif;
	delete cargoToDelete;
//	delete purgeSet;
end;</source>
        <Parameter name="_pxyWoDDtl" type="CM_WodPermitRequest"/>
    </JadeMethod>
    <JadeMethod name="setMyPermitWodVoyageDetail" id="e8c6694b-4202-4feb-b191-a6769895415a">
