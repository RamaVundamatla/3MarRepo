    <JadeMethod name="isForVoyage" id="a606191b-d3e7-4572-bc9b-dcc3920cdf8f">
        <source>isForVoyage(_voyage: CM_Voyage):Boolean;
// ---------------------------------------------------------------------------
// Created:		20 June 2003  by Jason Chapman  (cnwjc2)
// ---------------------------------------------------------------------------

vars
	voyageCode : String;
begin
	//epr par 37090 2/11/15
	if _voyage = null then
		return false;
	endif;
	
	voyageCode := self.getVoyageCode;
	
	if voyageCode = null then
		return false;
	endif;
	
	if _voyage.code = voyageCode then
		return true;
	endif;
	
	return false;
end;</source>
