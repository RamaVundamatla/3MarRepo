    <JadeMethod name="isShowROROKPI" id="8d240f44-0bab-421c-b80b-4b62e9690e82">
        <source>isShowROROKPI():Boolean protected;
/*

Date		Who		Reason
17 August 2011	cnwcs5	Initial creation - CCMS MES 1033 / par 27951 RORO KPI
*/
vars
	voyage	:CM_Voyage;
begin	
	// don't show if they don't have a license
	if  not self.hasKPILicense then
		return false;
	endif;
	
	if not self.hasROROLicense then
		return false;
	endif;
	
	// don't show if voyage is not RORO
	voyage := self.myCurrentVoyage;
	
	if voyage = null or voyage.myROROStructure = null then
		return false;	
	endif;
	
	return true;
epilog

end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="keyDown" id="9dcfa0d1-3a51-4621-a8a6-45129f17b4b5">
        <controlMethod name="Form::keyDown"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>keyDown(keyCode: Integer io; shift: Integer) updating;
// ---------------------------------------------------------------------------
// Created:		December 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

begin
	if keyCode = CMUI_Key_F5 then 
		self.btnTBRefresh.click(self.btnTBRefresh);
		return;
	endif;
	
	inheritMethod(keyCode, shift);
end;</source>
        <Parameter name="keyCode" type="Integer" usage="io"/>
        <Parameter name="shift" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="loadDataForFirstTime" id="a2dab35f-7716-4f65-b6f0-e3c03bd000b2">
        <updating/>
        <source>loadDataForFirstTime() updating, protected;
// ---------------------------------------------------------------------------
// Created:		December 2003 By Andrew Bishop cnwab1
//
// ---------------------------------------------------------------------------
// 09/08/2011	cnwcs5	CCMS MES 1033 - RORO KPI
vars
	regKeys : IntegerArray;
	idx 	: Integer;
	table	: CM_DataTable;
	sheet	: CMUI_Sheet;
	voyage	: CM_Voyage;
	combo	: CMUI_ComboBox;
begin
	inheritMethod();
	
	self.addToolbarControls();
	// All key strokes are turned off by default. This turns them back on and includes the H key. H for Help.
	create regKeys transient;
	regKeys.add(CMUI_Key_F5);
	self.addRegisteredKeys(regKeys);
	
	self.flipH := false;
	self.frmCraneMove.parent := self.sptBottom;
	self.sptBottom.setupChildControlsLeftRight(self.tblGridAreaInfo,self.frmCraneMove);
	self.sptBottom.cnEcResizeContents();
	self.sptBottom.setLeftToRightRatio(50);
	
	self.frmCraneMove.backColor 	:= White;
	self.frmCraneMove.ignoreSkin 	:= true;
	self.frmCraneMove.visible 		:= true;
	self.frmCraneMove.bubbleHelp 	:= null;
	// all tables should fill the parent client area
	// Moves table
	table 			:= self.tblStats;
	sheet			:= self.shtMoves;
	table.width		:= sheet.clientWidth;
	table.height	:= sheet.clientHeight;
	self.setColorsForTable(self.tblStats);
	// Delays table
	table 			:= self.tblDelays;
	sheet			:= self.shtDelays;
	table.width		:= sheet.clientWidth;
	table.height	:= sheet.clientHeight;
	// Timings table
	table 			:= self.tblTimings;
	sheet			:= self.shtTimings;
	table.width		:= sheet.clientWidth;
	table.height	:= sheet.clientHeight;
	// Timings table
	table 			:= self.tblBays;
	sheet			:= self.shtBays;
	table.width		:= sheet.clientWidth;
	table.height	:= sheet.clientHeight;
	// RORO moves table
	table 			:= self.tblROROMoves;
	sheet			:= self.shtROROMoves;
	table.width		:= sheet.clientWidth;
	table.height	:= sheet.clientHeight;
	// RORO decks table
	table 			:= self.tblRORODecks;
	sheet			:= self.shtRORODecks;
	table.width		:= sheet.clientWidth;
	table.height	:= sheet.clientHeight;
	
	self.splMain.parent 		:= self.shtProfile;
	self.frmGridArea.visible 	:= false;
	
	self.beginNotification(self.myTerminal, self.myTerminal.getTerminalEvent(EVENT_WEBCAM_ONE_UPDATE), Response_Continuous, null);
	
	self.initTableStats();
	self.initMovesTable();
	self.initDelaysTable();
	self.initTimings();
	self.initTblWOOpHrs(); //02 Apr 2012	NDL	Par 29369
	self.initBayTable();
	self.initRORODecksTable();
	self.initROROMovesTable();

	// ### PAR 20197 - Archived voyages  now drilling in from Voyage Enquiry
	voyage 	:= self.myCurrentVoyage;
	combo	:= self.cmbArea;
	
	if voyage &lt;&gt; null then
		idx := combo.findObject(voyage);
		if idx &lt;= 0 then	
			idx 					:= combo.addItem(voyage.code.trimBlanks &amp; " " &amp; voyage.vesselName.trimBlanks);
			combo.itemObject[idx] 	:= voyage;
		endif;
		combo.listIndex := idx;
		
		if voyage.archived then
			self.btnDelaysEnquiry.enabled := false;
			self.btnOOW.enabled := false;
			self.btnShipDelays.enabled := false;
		endif;
	endif;

	if self.cmbArea.listIndex &lt;&gt; CNEC_NULL_INDEX then
		self.doComboVoyageClick(combo);
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="loadTblWPOpHrs" id="e8a7817c-48a0-4fcf-8f44-49cd6ea5d3e4">
        <source>loadTblWPOpHrs();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
02 April 2012	cnwndl1	Initial creation	Par 29369

*/

vars

	iter : Iterator;
	opHr : CM_WorkPointOperatingHours;
	obj : Object;	
	dynaDict : DynaDictionary;

begin

	self.tblWPOpHrs.rows := 1;
	self.tblWPOpHrs.allSelectedObjects.clear();

	if self.myCurrentVoyage = null or self.myCurrentVoyage.allWorkPointOperatingHours.isEmpty then
		return;
	endif;
	
	create dynaDict transient;
	dynaDict.setMembership( CM_WorkPointOperatingHours );
	dynaDict.addMemberKey( CM_WorkPointOperatingHours::craneWorkPointId.name, false, true );
	dynaDict.addMemberKey( CM_WorkPointOperatingHours::exchangeStart.name, false, true );
	dynaDict.endKeys(true);	

	self.myCurrentVoyage.allWorkPointOperatingHours.copy(dynaDict);
	iter := dynaDict.createIterator;
	
	while iter.next( obj ) do
		opHr := obj.CM_WorkPointOperatingHours;
		self.tblWPOpHrs.addItemObject(opHr, opHr.getAttributeStringForDefArray(self.tblWPOpHrs.allTblDataEntRows));
	endwhile;
	
epilog

	delete iter;
	delete dynaDict;

end;</source>
    </JadeMethod>
