    <JadeMethod name="rotate" id="460908d2-67af-4ede-be76-040ea1e9a453">
        <updating/>
        <source>rotate( _rotationDegrees : Integer ) updating;

/*

Purpose:		Rotate from current rotation by given degrees.

Parameters:			

Return Value:		


Date				Who		Reason
03 September 2008	consw1	Initial creation

*/

vars

begin
	self.rotation := ( self.rotation + _rotationDegrees ) mod 360;
epilog

end;</source>
        <Parameter name="_rotationDegrees" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="8a354ede-1df8-472d-8e6d-7016032ee660">
        <updating/>
        <source>setForCreate( _areaView : CM_TerminalAreaView; _proxyPosition : CM_TerminalAreaViewPosition ) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date				Who		Reason
02 September 2008	consw1	Initial creation

*/

vars

begin
	self.setForUpdate( _proxyPosition );

	self.myTerminalArea		:= _proxyPosition.myTerminalArea;
	self.myTerminalAreaView	:= _areaView;
	
epilog

end;</source>
        <Parameter name="_areaView" type="CM_TerminalAreaView"/>
        <Parameter name="_proxyPosition" type="CM_TerminalAreaViewPosition"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="dd398345-46e5-4d6d-ac60-45727a1f8efe">
        <updating/>
        <source>setForUpdate( _proxyPosition : CM_TerminalAreaViewPosition ) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date				Who		Reason
02 September 2008	consw1	Initial creation

*/

vars

begin
	self.horizontalFlip	:= _proxyPosition.horizontalFlip;
	self.origin			:= _proxyPosition.origin;
	self.rotation		:= _proxyPosition.rotation;
	self.verticalFlip	:= _proxyPosition.verticalFlip;
	self.height			:= _proxyPosition.height;
	self.width			:= _proxyPosition.width;
	self.setLabelDisplays(_proxyPosition.displayTopColumnLabels,
							_proxyPosition.displayBottomColumnLabels,
							_proxyPosition.displayLeftRowLabels,
							_proxyPosition.displayRightRowLabels,
							_proxyPosition.displayItemCount,
							_proxyPosition.displayFreeCount);
epilog

end;</source>
        <Parameter name="_proxyPosition" type="CM_TerminalAreaViewPosition"/>
    </JadeMethod>
    <JadeMethod name="setLabelDisplays" id="b1ad0470-51b3-49d3-9325-7f3613125588">
        <updating/>
        <source>setLabelDisplays(_displayTop,
						_displayBottom,
						_displayLeft,
						_displayRight,
						_displayItems,
						_displaySpace: Boolean) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
14 August 2009	cnwer1	Initial creation

*/

vars

begin
	self.displayBottomColumnLabels:=_displayBottom;
	self.displayLeftRowLabels:=_displayLeft;
	self.displayRightRowLabels:=_displayRight;
	self.displayTopColumnLabels:=_displayTop;
	
	//22 Sep 2011	NDL	Par 28076
	self.displayItemCount:=_displayItems;
	self.displayFreeCount:=_displaySpace;

epilog

end;</source>
        <Parameter name="_displayTop" type="Boolean"/>
        <Parameter name="_displayBottom" type="Boolean"/>
        <Parameter name="_displayLeft" type="Boolean"/>
        <Parameter name="_displayRight" type="Boolean"/>
        <Parameter name="_displayItems" type="Boolean"/>
        <Parameter name="_displaySpace" type="Boolean"/>
    </JadeMethod>
