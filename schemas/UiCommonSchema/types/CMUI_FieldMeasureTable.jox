    <JadeMethod name="getMeasurementUnit" id="6cf77c7e-f29e-4712-9a07-1218d537c548">
        <source>getMeasurementUnit():String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 July 2017	jlgndl1	Initial creation	TFS 5509

*/

vars

begin

	if self.myMeasurementTable = null then
		return null;
	endif;
	
	if self.myMeasurementTable.rows &lt; 1 then
		return null;
	endif;
	
	if self.myMeasurementTable.columns &lt; self.ColumnUnit then
		return null;
	endif;
	
	return self.myMeasurementTable.accessCell(1,self.ColumnUnit).text;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
