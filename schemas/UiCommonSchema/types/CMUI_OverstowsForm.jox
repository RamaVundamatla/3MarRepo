    <JadeMethod name="stripCountFromLabelCaption" id="8502e696-1e84-4a72-a032-b48829280fbe">
        <source>stripCountFromLabelCaption( _label : CMUI_Label io) protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
01 November 2011	cnwndl1	Initial creation	Par 28466

*/

vars

	captionStr : String;
	workString : String;
	pos : Integer;

begin

	if _label = null then
		return;
	endif;

	captionStr := _label.caption.trimBlanks;
	pos := captionStr.pos("(",1);
	if pos &gt; 0 then
		workString := captionStr[1:pos - 1].trimBlanks;
		_label.caption := workString;
	endif;
	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_label" type="CMUI_Label" usage="io"/>
    </JadeMethod>
