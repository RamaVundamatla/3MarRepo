    <JadeMethod name="cnEcInitializeSpellDictionary" id="225a38e1-0c4f-49b1-a310-7f3ccb4b965a">
        <updating/>
        <source>cnEcInitializeSpellDictionary() updating;
// --------------------------------------------------------------------------------
// Created:		23 June 2001 by cnwdad1
//
// Purpose:		Initialize method for the Spellcheck Dictionary application.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	skinRootObj		: JadeSkinRoot;
	allAppSkinsObj	: JadeSkinApplicationNameDict;
	allSkinsObj		: ObjectArray;
	skinId			: Integer;
	skinObj			: JadeSkinApplication;
	
begin
	app.cnActivateKarmaControl(Cn_Fat_Client, null, null);
	self.cnEcInitializeBaseSchema();
	
/*
	skinRootObj		:=	JadeSkinRoot.firstInstance();
	allAppSkinsObj	:=	skinRootObj.allApplicationSkins;
	
	create allSkinsObj transient;
	allAppSkinsObj.copy(allSkinsObj);
	
	if allSkinsObj.cnEcIsNotEmpty() then
		skinId	:=	app.random(allSkinsObj.size());
		
		if skinId &gt; 0 then
			skinObj	:=	allSkinsObj[skinId].JadeSkinApplication;
			app.setApplicationSkin(skinObj);
		endif;
	endif;
*/
epilog
	delete allSkinsObj;
end;</source>
    </JadeMethod>
