    <JadeMethod name="setInvLineTypeCollection" id="16852718-52f7-4511-87db-a8d83df5093b">
        <updating/>
        <source>setInvLineTypeCollection() updating;
/*
Purpose:			

Date		Who		Reason
16 May 2023 navtnr20	TFS CR 57983 Task 57984: EUP - INCO Terms TRX Layer
*/

vars
	mapping : CM_InvoiceINCOMapping;
	invLineType : CM_InvoiceLineDesc;
begin
	self.allINCOTermMappingsByInvLnType.clear();
	
	
	foreach mapping in self.allINCOTermMappings discreteLock do
		foreach invLineType in mapping.allInvoiceLineTypes discreteLock do
			self.allINCOTermMappingsByInvLnType.tryPutAtKey(invLineType,mapping);
		endforeach;
	endforeach;
	
epilog

end;</source>
    </JadeMethod>
