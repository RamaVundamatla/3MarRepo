    <JadeMethod name="getDebtorAlternativeAddress" id="2cce3bda-a8ae-4615-9513-ab6a66fddf5a">
        <source>getDebtorAlternativeAddress() : CM_Address;
/*

Purpose:			Gets Debtor's Alternative Address

Parameters:			NONE

Return Value:		CM_Address	Returns the debtors Alternative Address

Date		Who		Reason
19 August 2022	navpw1	Initial creation TFS: 54564 (54381)

*/

vars
	address : CM_Address;
	
begin
	foreach address in self.allAddressesByCode discreteLock do
		if not address.isAlternative then
			continue;
		endif;
		
		return address;
	endforeach;
	
	return null;
	
end;</source>
