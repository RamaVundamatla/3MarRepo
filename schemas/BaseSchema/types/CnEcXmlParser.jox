    <JadeMethod name="createTagInstance" id="6c4bcc17-ab2f-4034-b2e8-b31d467aa26d">
        <updating/>
        <source>createTagInstance(	pMsgInstance:CnEcXmlStructureInstance input;
					pTag:String;
					pTagData:String;
					pIdRef:String;
					pTagClass:Class) : CnEcXmlStructureInstance updating, protected;

// 08/08/2002 - cnwdad1
// Add check for whether tag data is to be included on Group instances, and call
// the appropriate initialize method.

vars
	msgInst : CnEcXmlStructureInstance;
	
begin
	create msgInst as pTagClass;
	
//	msgInst.initializeMe(pTag, pTagData, pIdRef);
	if self.isTagDataOnGroup then
		msgInst.initializeWithTagData(pTag, pTagData, pIdRef);
	else
		msgInst.initializeMe(pTag, pTagData, pIdRef);
	endif;
	
	pMsgInstance.addStructure(msgInst);
	return msgInst;
end;</source>
        <access>protected</access>
        <Parameter name="pMsgInstance" type="CnEcXmlStructureInstance" usage="input"/>
        <Parameter name="pTag" type="String"/>
        <Parameter name="pTagData" type="String"/>
        <Parameter name="pIdRef" type="String"/>
        <Parameter name="pTagClass" type="Class"/>
        <ReturnType type="CnEcXmlStructureInstance"/>
    </JadeMethod>
    <JadeMethod name="extractDoctype" id="5f82710a-9f69-4c18-8cbe-9b193dfca62f">
        <updating/>
        <source>extractDoctype(pXmlString : String io; pMsgInstance : CnEcXmlStructureInstance io) updating, protected;

constants
	DOC_TYPE	: String = "&lt;!DOCTYPE";
	
vars
	startPos	: Integer;
	endPos		: Integer;
	docInfo		: String;
	
begin
	startPos := pXmlString.pos(DOC_TYPE, 1);
	
	if startPos &gt; 0 then
		endPos := pXmlString.pos("&gt;", startPos);
		
		if endPos &gt; startPos then
			if startPos = 1 then
				docInfo := pXmlString[1 : endPos + 1];
				pXmlString := pXmlString[endPos+1 : end];
			else
				docInfo := pXmlString[startPos : (endPos - startPos) + 1];
				pXmlString := pXmlString[1 : (startPos -1)] &amp; pXmlString[endPos + 1: end];
			endif;   
			
			createTagInstance(pMsgInstance, "DOCTYPE", docInfo, null, CnEcXmlFieldInstance);
		endif;
	endif; 
end;</source>
        <access>protected</access>
        <Parameter name="pXmlString" type="String" usage="io"/>
        <Parameter name="pMsgInstance" type="CnEcXmlStructureInstance" usage="io"/>
    </JadeMethod>
    <JadeMethod name="extractFirstTag" id="8b51a35a-e8b4-4547-94d3-4f17fdfcf3c4">
        <updating/>
        <source>extractFirstTag(pMsgString : String) : String updating, protected;
// Method:	extractFirstTag	
// Author:	cnwka1
// Created:	13 June 2000
//
// Purpose:	
//
// Parameters:
//
// Name		Purpose
// ---------------- -----------------------------------------------
//
// Returns:	
//
vars
	tag			: String;
	startPos	: Integer;
	endPos		: Integer;
	len			: Integer;
	spacePos	: Integer;
	
begin
	startPos := pMsgString.pos("&lt;", 1);
    endPos := pMsgString.pos("&gt;", 1);
    tag := "";

    if (startPos &gt; 0 and endPos &gt; 0) and (startPos &lt; endPos) then
    	if pMsgString[endPos-1:1] = "/" then
    		// looking for &lt;TAG_NAME/&gt;
    		endPos := endPos - 1;
    	endif;
    	
    	len := (endPos -1 ) - startPos;
    	tag := pMsgString[startPos + 1 : len];
        spacePos := tag.pos(" ", 1);
        
        if spacePos &gt; 0 then
        	tag := tag[1 : spacePos -1];
        endif;
    endif;
    
    return tag;
end;</source>
        <access>protected</access>
        <Parameter name="pMsgString" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="extractTag" id="8b549926-01e0-420b-bbd8-85357bdaeff9">
        <updating/>
        <source>extractTag(	pTagName:String;
			pXmlData:String;
			pTagData:String output;
			pIndex:Integer output;
			pIdRef:String output) : Integer updating, protected;
// --------------------------------------------------------------------------------
// Purpose:		Extracts an XML tag.
//
// Parameters:	pTagName - 
//				pXmlData - 
//				pTagData - 
//				pIndex - 
//				pIdRef - 
//
// Returns:		Integer - The result of the extract.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 04/01/2001	cnwdad1		Modified the method signature (changed the pIdRef
//							parameter from being "io" to simply "output").
// 23/01/2003	cnwdad1		Added a check for tag attributes for field instances.
// 02/05/2003	cnwndl1		Added check to allow for empty self-closing tag, i.e.
//							&lt;tag/&gt;.
// --------------------------------------------------------------------------------
vars
	msgTag		: String;
	startPos	: Integer;
	endPos		: Integer;
	front		: Integer;
	back		: Integer;
	
begin
	msgTag := "&lt;" &amp; pTagName;
	startPos := pXmlData.pos(msgTag, 1);
	endPos := pXmlData.pos("&gt;", 1);
	pIndex := -1;
	
	if startPos &gt; 0 and (startPos &lt; endPos) then
		front := endPos + 1;
		
		////////////// Patch from Kev 21/12/2000 - NDL
		if endPos &lt;&gt; (startPos + msgTag.length ) then
			if pXmlData[endPos -1 : 1] = "/" then
				pIndex := front;
				pTagData := "";
				
// cnwndl1 02/05/2003 - Added check to allow for empty self-closing tag (i.e. &lt;tag/&gt;.
//// cnwdad1 23/01/2003 - Added the following check for attributes.
//		        // check for IDREF e.g. &lt;SPUD cooked="Boiled"&gt;...
//		        if (startPos + msgTag.length) &lt;&gt; endPos then
				if (startPos + msgTag.length) &lt;&gt; endPos
				and endPos - (startPos + msgTag.length) &gt; 1
				then
		        	// we have an IDREF
		        	pIdRef := pXmlData[(startPos + msgTag.length + 1) : (endPos - (startPos + msgTag.length  +2))];
		        endif;
				
				return PARSER_OK;
			endif;
		endif;							
		//////////////end of Patch
		
		back := pXmlData.pos("&lt;/" &amp; pTagName &amp; "&gt;", front);
		
		if back = 0 then
			if pXmlData[endPos -1 : 1] = "/" then
				pIndex := front;
//				pTagData := pXmlData[front : end];
				pTagData := "";
				return PARSER_OK;
			else
				cnEcMonitor("No end tag for tag " &amp; pTagName &amp; " xmlData =&gt;" &amp; pXmlData &amp; "&lt;=");
				//write "No end tag for tag " &amp; pTagName &amp; " xmlData =&gt;" &amp; pXmlData &amp; "&lt;=";
				return XML_ERROR_NO_END_TAG;
			endif;	
		endif;
		
        // check for IDREF e.g. &lt;SPUD cooked="Boiled"&gt;...
        if (startPos + msgTag.length) &lt;&gt; endPos then
        	// we have an IDREF
        	pIdRef := pXmlData[(startPos + msgTag.length + 1) : (endPos - (startPos + msgTag.length  +1))];
        endif;
        
		if pXmlData[ front: back-front].cnEcIncludesXmlTags() then
			pIndex := front;
			pTagData := pXmlData[front : end];
			return XML_PARSER_MORE_TAGS;
		endif;
		
		pTagData := pXmlData[ front: back - front];

		pIndex :=  back + ("&lt;/" &amp; pTagName &amp; "&gt;").length;
	endif;
	
	return PARSER_OK;
end;</source>
        <access>protected</access>
        <Parameter name="pTagName" type="String"/>
        <Parameter name="pXmlData" type="String"/>
        <Parameter name="pTagData" type="String" usage="output"/>
        <Parameter name="pIndex" type="Integer" usage="output"/>
        <Parameter name="pIdRef" type="String" usage="output"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="parseRecursive" id="19d405d2-a796-429f-858b-b0fd1afc2e93">
        <updating/>
        <source>parseRecursive(pWorkString : String io; pMsgInstance : CnEcXmlStructureInstance input; pIndex : Integer io) : Integer updating;
// Author:	cnwka1
// Created:	13 June 2000
vars
	currentTag	: String;
	partString	: String;
	tag			: String;
	tagData		: String;
	idRef		: String;
	result		: Integer;
	pos			: Integer;
	msgInst		: CnEcXmlStructureInstance;
	
begin
	currentTag := pMsgInstance.tagName;
	
	while true do
		tag := pWorkString.cnEcXmlExtractFirstTag();
		
		if tag = "/" &amp; currentTag then
			pIndex := pWorkString.pos("&lt;/" &amp; currentTag &amp; "&gt;", 1) + ("&lt;/" &amp; currentTag &amp; "&gt;").length;
			
			if pIndex &lt;= pWorkString.length then
				pWorkString := pWorkString[pIndex:end];
			else
				pWorkString := "";
			endif;
			
			return PARSER_OK;
		endif; 
		
        if tag.length &gt; 0 then	
        	pIndex := 0;

        	result := extractTag(tag, pWorkString, tagData, pIndex, idRef);
        	
        	if result = PARSER_OK then
        		if pIndex &lt;= pWorkString.length then
	        	    pWorkString := pWorkString[pIndex : end];
	        	else 
	        		pWorkString := "";
	        	endif;
	        	
				createTagInstance(pMsgInstance, tag, tagData.cnEcXmlRemoveCDATA(), idRef, CnEcXmlFieldInstance); 
				
			elseif result = XML_PARSER_MORE_TAGS then
        	    pWorkString := pWorkString[pIndex : end];
				msgInst := createTagInstance(pMsgInstance, tag, tagData, idRef, CnEcXmlGroupInstance); 

        		result := parseRecursive(pWorkString, msgInst, pIndex);
        		
        		if result &lt;&gt; PARSER_OK then
        			return result;
        	    endif;
        	    
       	    else	
        		return result;
        	endif;
        else 
        	break;	
        endif;
        
	endwhile;
end;</source>
        <Parameter name="pWorkString" type="String" usage="io"/>
        <Parameter name="pMsgInstance" type="CnEcXmlStructureInstance" usage="input"/>
        <Parameter name="pIndex" type="Integer" usage="io"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="parseToMsgStructure" id="fa9d7153-4c70-4790-90c3-3eb859840fea">
        <updating/>
        <source>parseToMsgStructure(pMsgString : String; pMsgInstance : CnEcXmlStructureInstance io) : Integer updating;
// Author:	cnwka1
// Created:	13 June 2000
vars
	workString	: String;
	result 		: Integer;
	index		: Integer;
	
begin
	workString := pMsgString;
	stripXMLHeader(workString);
	extractDoctype(workString, pMsgInstance);
	stripComments(workString);
	index := 1;
	return parseRecursive(workString, pMsgInstance, index);
end;</source>
        <Parameter name="pMsgString" type="String"/>
        <Parameter name="pMsgInstance" type="CnEcXmlStructureInstance" usage="io"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setIsTagDataOnGroup" id="1b51920d-1a5a-498d-9546-373c4c7a9b92">
        <updating/>
        <source>setIsTagDataOnGroup(pIsTagDataOnGroup:Boolean) updating;
// --------------------------------------------------------------------------------
// Created:		08 August 2002 by cnwdad1
//
// Purpose:		Updates the boolean flag that indicates whether Tag Data is to be
//				used on Group structure instances.
//
// Parameters:	pIsTagDataOnGroup - The boolean flag.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if self.isTagDataOnGroup &lt;&gt; pIsTagDataOnGroup then
		self.isTagDataOnGroup	:=	pIsTagDataOnGroup;
	endif;
end;</source>
        <Parameter name="pIsTagDataOnGroup" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="stripComments" id="1ca490a2-c99a-46d4-933f-ba317473ccde">
        <updating/>
        <source>stripComments(pXmlString : String io) updating, protected;
// cnwdad1 04/04/2001 - An index out-of-bounds exception was being raised is the last tag in the message was a comment.
constants
	COMMENT_START	: String = "&lt;!--";
	COMMENT_END		: String = "--&gt;";
	
vars	
	startPos		: Integer;
	endPos			: Integer;
	index			: Integer;
	
begin
	index		:=	1;
	
	while true do
		startPos := pXmlString.pos(COMMENT_START, index);	
		
		if startPos &gt; 0 then
			endPos := pXmlString.pos(COMMENT_END, startPos);
			
			if endPos &gt; startPos then
				if startPos = 1 then
					pXmlString := pXmlString[endPos + COMMENT_END.length : end];
				else
					if (endPos + COMMENT_END.length - 1) = pXmlString.length then		// cnwdad1 04/04/2001.
						pXmlString := pXmlString[1 : (startPos - 1)];					// cnwdad1 04/04/2001.
					else																// cnwdad1 04/04/2001.
						pXmlString := pXmlString[1 : (startPos - 1)] &amp; pXmlString[( endPos + COMMENT_END.length) : end];
					endif;																// cnwdad1 04/04/2001.
				endif;
			else
				break;
			endif;
		else
			break;
		endif;
	endwhile;		
end;</source>
        <access>protected</access>
        <text>Strips comments from XML Documents
Comments are defined as:

&lt;!-- comment --&gt;</text>
        <Parameter name="pXmlString" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="stripXMLHeader" id="730eb995-ad49-4fb1-bb29-052aa100254a">
        <updating/>
        <source>stripXMLHeader(pMsgString : String io) updating, protected;
// Method:	stripXMLHeader	
// Author:	cnwka1
// Created:	13 June 2000
//
// Purpose:	
//
// Parameters:
//
// Name		Purpose
// ---------------- -----------------------------------------------
// cnwnl1	cnwndl1	Changed to better deal with incorrectly formatted XML.
// ---------------- -----------------------------------------------
vars
 startPos : Integer;
 endPos  : Integer;
 
begin
 startPos := pMsgString.pos("&lt;?", 1);
 endPos := pMsgString.pos("?&gt;", 1);
 
 // Was this...
// if (startPos &gt; 0 and endPos &gt; 0 ) and startPos &lt; endPos then
//  pMsgString := pMsgString[ endPos + 2: end ];
// endif;
 
 // Needs to be this to cater for finding the header at the wrong end of the file...
 if (startPos &gt; 0 and endPos &gt; 0 ) and startPos &lt; endPos and endPos + 2 &lt; pMsgString.length then
  pMsgString := pMsgString[ endPos + 2: end ];
 endif;
end;
/*
vars
	startPos	: Integer;
	endPos		: Integer;
	
begin
	startPos := pMsgString.pos("&lt;?", 1);
	endPos := pMsgString.pos("?&gt;", 1);

	if (startPos &gt; 0 and endPos &gt; 0 ) and startPos &lt; endPos then
		pMsgString := pMsgString[ endPos + 2: end ];
	endif;
end;
*/</source>
        <access>protected</access>
        <Parameter name="pMsgString" type="String" usage="io"/>
    </JadeMethod>
</Class>
