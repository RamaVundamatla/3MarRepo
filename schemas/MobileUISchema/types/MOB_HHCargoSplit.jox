    <JadeMethod name="doResizeControls" id="24cbae83-75d2-421a-8bc7-f89312a0417a">
        <updating/>
        <source>doResizeControls(_initialSetup: Boolean) updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 February 2015	cnwndl1	Initial creation	Par 35604

*/

vars

	cTop : Real;
	stdWidth : Real;
	cWidth : Real;
	stdHeight : Real;
	cHeight : Real;
	cLeft : Real;
	tabIndex : Integer;
	
	operator : CM_Operator;
	failedDAC  :CM_DataAccessController;

begin

	self.setResizeableMarginAndFontSize();
	stdWidth := self.clientWidth - self.resizedMargin - self.resizedMargin;
	stdHeight := self.getStdControlHeight;
	
	cTop := self.resizedMargin;
	cWidth := stdWidth - self.resizedMargin - stdHeight;
	cHeight := stdHeight;
	tabIndex := 4000;
	
	if _initialSetup then
		self.txtCargoId.setAndIncrementTabIndex( tabIndex );
		self.txtCargoId.visible := true;
	endif;
	self.txtCargoId.move( 	self.resizedMargin,
							cTop,
							cWidth,
							cHeight );
						 
	cWidth := self.getStdControlHeight();
	if _initialSetup then
		self.btnPartCargoId.setAndIncrementTabIndex( tabIndex );
		self.btnPartCargoId.visible := true;
	endif;
	self.btnPartCargoId.move(	self.txtCargoId.left + self.txtCargoId.width + self.resizedMargin,
								cTop,
								cWidth,
								cHeight );
								
	cTop := cTop + self.txtCargoId.height + self.resizedMargin;
	cWidth := stdWidth;
	if _initialSetup then
		self.optNewBB.setAndIncrementTabIndex( tabIndex );
		self.optNewBB.visible := true;
	endif;
	self.optNewBB.move(	self.resizedMargin,
						cTop,
						cWidth,
						cHeight );
								
	cTop := cTop + self.optNewBB.height - self.resizedMargin;
	cLeft := cHeight + self.resizedMargin;
	cWidth := stdWidth - cLeft;
	if _initialSetup then
		self.lblOptBB.setAndIncrementTabIndex( tabIndex );
		self.lblOptBB.visible := true;
	endif;
	self.lblOptBB.move(	cLeft,
						cTop,
						cWidth,
						cHeight );
								
	cTop := cTop + self.lblOptBB.height;
	cWidth := stdWidth;
	if _initialSetup then
		self.optNewPieceBB.setAndIncrementTabIndex( tabIndex );
		self.optNewPieceBB.visible := true;
	endif;
	self.optNewPieceBB.move(	self.resizedMargin,
								cTop,
								cWidth,
								cHeight );
								
	cTop := cTop + self.optNewPieceBB.height - self.resizedMargin;
	cWidth := stdWidth - cLeft;
	if _initialSetup then
		self.lblOptPieceBB.setAndIncrementTabIndex( tabIndex );
		self.lblOptPieceBB.visible := true;
	endif;
	self.lblOptPieceBB.move(cLeft,
							cTop,
							cWidth,
							cHeight );
								
	cTop := cTop + self.lblOptPieceBB.height + ( stdHeight / 2 );
	cWidth := stdWidth;
	if _initialSetup then
		self.cmbOperator.setAndIncrementTabIndex( tabIndex );
		self.cmbOperator.visible := true;
	endif;
	self.cmbOperator.move(	self.resizedMargin,
							cTop,
							cWidth,
							cHeight );
							
	cTop := cTop + self.cmbOperator.height + self.resizedMargin;
	cWidth := ( (stdWidth - self.resizedMargin) / 2 );
	if _initialSetup then
		self.lblQuantity.setAndIncrementTabIndex( tabIndex );
		self.lblQuantity.visible := true;
	endif;
	self.lblQuantity.move(	self.resizedMargin,
							cTop,
							cWidth,
							cHeight );
							
						
	cLeft := self.lblQuantity.left + self.lblQuantity.width + self.resizedMargin;
	if _initialSetup then
		self.txtQuantity.setAndIncrementTabIndex( tabIndex );
		self.txtQuantity.visible := true;
	endif;
	self.txtQuantity.move(	cLeft,
							cTop,
							cWidth,
							cHeight );
	
	if _initialSetup then
		self.tblWeightVolume.setAndIncrementTabIndex( tabIndex );
		self.tblWeightVolume.visible := false;
	endif;
	self.tblWeightVolume.move(	cLeft,
								cTop,
								cWidth,
								cHeight + self.resizedMargin // extra height to allow combo to be seen in measurement control
								);
							
	cTop := cTop + self.lblQuantity.height + self.resizedMargin;
	cWidth := stdWidth;
	if _initialSetup then
		self.txtNewCargoId.setAndIncrementTabIndex( tabIndex );
		self.txtNewCargoId.visible := true;
	endif;
	self.txtNewCargoId.move(	self.resizedMargin,
								cTop,
								cWidth,
								cHeight );
	
	cTop := cTop + self.txtNewCargoId.height + self.resizedMargin;
	cWidth := ( (stdWidth - self.resizedMargin) / 2 );
	if _initialSetup then
		self.lblSuffix.setAndIncrementTabIndex( tabIndex );
		self.lblSuffix.visible := true;
	endif;
	self.lblSuffix.move(	self.resizedMargin,
							cTop,
							cWidth,
							cHeight );
	
	cLeft := self.lblSuffix.left + self.lblSuffix.width + self.resizedMargin;
	if _initialSetup then
		self.txtSuffix.setAndIncrementTabIndex( tabIndex );
		self.txtSuffix.visible := true;
	endif;
	self.txtSuffix.move(	cLeft,
							cTop,
							cWidth,
							cHeight );
							
	cTop := cTop + self.lblSuffix.height;
	cWidth := stdWidth;
	if _initialSetup then
		self.lblExample.setAndIncrementTabIndex( tabIndex );
		self.lblExample.visible := true;
	endif;
	self.lblExample.move(	self.resizedMargin,
						cTop,
						cWidth,
						cHeight );
	if _initialSetup then
		self.lblExample.foreColor := Blue;
	endif;

	inheritMethod(_initialSetup);

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_initialSetup" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doSplit" id="b04ef4af-536f-495a-b9e5-c4893f071744">
        <updating/>
        <source>doSplit()protected, updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 May 2013	cnwndl1	Initial creation	CCMS 2274 Break Bulk
01 Apr 2014	NDl	CCMS 1366

*/

vars

	allTiIds : StringArray;
	quantity : Integer;
	weight : Decimal [16,4];
	operator : CM_Operator;
	tiID : String;
	theReturn : Integer;

begin

	create allTiIds transient;
	if not self.validate( allTiIds, quantity, weight, operator ) then
		return;
	endif;
	
	while true do 
	
		app.myTrxUA.trxSplitBreakBulkToNewID(	self.myTrackedItem.CM_Cargo,	//_sourceTi : CM_cargo;
												allTiIds,	//_newTiIds : StringArray;
												quantity,	//_quantity : Integer;
												weight,	// _weight : Decimal;
												operator,	//_operator : CM_Operator;
												true,
												true,
												true,
												true,
												app.myPassport	//_passport : CM_Passport input
												);
	
		
		if app.myPassport.trxCompletedOK then
			// Clear errors/warnings from form and err/warnings window
			if self.myTrackedItem.canSplitTotalQuantity then
				self.setMyTrackedItem( self.myTrackedItem );
			else
				self.setMyTrackedItem( null );
			endif;
			self.populateTrackedItem();
			if self.optNewBB.value then
				self.txtNewCargoId.text := null;
			endif;
			self.txtNewCargoId_lostFocus( self.txtNewCargoId );
			self.txtQuantity.text := null;
			self.txtSuffix.text := null;
			self.resetExample();
			return;
			
		else
			theReturn := app.showErrorWarningDialog(app.getErrorString(Split_breakbulk), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   theReturn = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			return;
			
		endif;
		break;
		
	endwhile;

epilog

	delete allTiIds;

end;</source>
        <access>protected</access>
    </JadeMethod>
