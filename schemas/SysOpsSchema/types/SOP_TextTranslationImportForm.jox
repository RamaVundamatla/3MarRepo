    <JadeMethod name="setupForm" id="e22a89d1-ac9d-4dae-88f8-c0cad5f91158">
        <updating/>
        <source>setupForm() updating;
//
// Changed On   Changed By  PAR             Reason
// ----------   ----------  --------------------------------------------------
//  09/10/2009	cnwmh5		Par 21251		Help file Added
// ---------------------------------------------------------------------------
//
vars

begin
	inheritMethod();

	self.btnCancel.width := self.btnBrowseFile.width;
	self.btnCancel.left := self.btnBrowseFile.left;
	self.btnCancel.top := self.btnImport.top;	//self.height - (self.btnCancel.height - 34);

	btnOk.visible:= false;
	btnCancel.visible:= true;
	
	self.helpFileName := HelpFile_Admin;				// 09/10/2009 PAR 21251
	
end;</source>
    </JadeMethod>
    <JadeMethod name="translateForm" id="3131275e-545b-427b-a061-1cf8f77c1a53">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0007224, locale);
	btnBrowseFile.translateCaption(Xlat_0004878, locale);
	btnImport.translateBubbleHelp(Xlat_0004879, locale);
	btnImport.translateCaption(Xlat_0004880, locale);
	lFilename.translateCaption(Xlat_0004881, locale);
end;</source>
    </JadeMethod>
