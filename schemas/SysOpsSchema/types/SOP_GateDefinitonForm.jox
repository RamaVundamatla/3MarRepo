/*
Date			Who		Reason
07 July 2009	cnwar2	Initial creation

*/
vars
	gateLane : CM_GateAreaLaneController;
	
begin
	if combobox.text = app.getErrorString(NewKiosk) then
		gateLane := combobox.parent.Table.accessedRow.itemObject.CM_GateAreaLaneController;
		self.doKiosk(self.Mode_Add, null, gateLane);
	endif;

	self.doCmbKiosk_UpdateProxy(combobox);

end;</source>
