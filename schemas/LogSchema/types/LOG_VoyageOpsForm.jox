    <JadeMethod name="sssDeleteEDIDataFile" id="f8f19381-9bbb-4159-aaff-87c89b4e01e6">
        <updating/>
        <source>sssDeleteEDIDataFile() updating;
//--------------------------------------------------------------
//Created: 12 December 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	ediData		: CM_EDIData;
	rtnValue	: Boolean;
	theResult : Integer;	//14 Jan 2020 NDL	TFS 46815
begin
	if self.fldSSSLoadOut.topSheet &lt;&gt; self.shtSSSEDIData then
		return;
	endif;
	
	if self.tblSSSEDIData.row &lt;= self.tblSSSEDIData.fixedRows then
		return;
	endif;
	
	app.mousePointer := MousePointer_HourGlass;
	
	ediData := tblSSSEDIData.accessRow(tblSSSEDIData.row).itemObject.CM_EDIData;

	app.writeLog('Shipside Scanning :: Deleting EDI Data', LogINFO);
	
	//14 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
	while true do
	
		app.myTrxDA.trxDeleteEDIData(ediData, app.myPassport);
	
		if app.myPassport.trxCompletedOK then
			break;
		else
			theResult := app.showErrorWarningDialog('Voyage Ops', app.myPassport, ErrWarnMode_Delete);
			if app.myPassport.noErrors and theResult = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		
		return;
		
	endwhile;

	self.sssShowEDIData();	
							
epilog
	app.mousePointer := MousePointer_Default;
end;</source>
    </JadeMethod>
    <JadeMethod name="sssExportTESTLogLoadOut" id="80ecefd3-178f-422e-95da-5a4ff9ea691c">
        <updating/>
        <source>sssExportTESTLogLoadOut() updating;
//--------------------------------------------------------------
//Created: 12 August 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	rowDownloadArray : CMIF_LogRowDownloadArray;
	dwnLoad	: CM_LogVoyageRowDownload;
	intFaceRow : CMIF_LogRowDownload;
	all, changes : Boolean;
	row, int, col3, col4 : Integer;	
	logFile, shipFile : String;
	theResult : Integer;	//14 Jan 2020 NDL	TFS 46815
begin
	app.mousePointer := MousePointer_HourGlass;	
	
	if (not app.isSpecial) then
		return;
	endif;
	
	if self.txtDwnLogFile.text &lt;&gt; null then
		logFile := self.txtDwnLogFile.text.trimBlanks;
	endif;
	
	if logFile = null then
//		app.raiseCMException1(REQUIRED_FIELD, 'Log File Name', null, null);
		app.raiseCMException(Input_required_field_logFleNme, null, null);
		return;
	endif;
	
	col3 := 3;
	col4 := 4;
	create rowDownloadArray transient;
	foreach row in 2 to self.tblDownloadInfo.rows do
		dwnLoad	:= self.tblDownloadInfo.accessRow(row).itemObject.CM_LogVoyageRowDownload;
		int := self.tblDownloadInfo.accessCell(row, col3).text.Integer;
		if int = 0 then
			int := self.tblDownloadInfo.accessCell(row, col3).text.Integer;
			if int = 1 then
				changes := true;
			endif;
		else
			all := true;		
		endif;
		if all or changes then
			create intFaceRow transient;
			intFaceRow.myRowDownload := dwnLoad;
			rowDownloadArray.add(intFaceRow);				
			if changes then
				intFaceRow.changesOnly := true;
			endif;
		endif;
		dwnLoad := null;
		all := false;
		changes := false;
	endforeach;

	if rowDownloadArray.size &gt; 0 then
	
		//14 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
		while true do
		
			app.myTrxCA.trxCreateLogOutFile(rowDownloadArray, logFile, app.myPassport);
		
			if app.myPassport.trxCompletedOK then
				break;
			else
				theResult := app.showErrorWarningDialog('Log Voyage Ops', app.myPassport, ErrWarnMode_Update);
				if app.myPassport.noErrors and theResult = IDOK then
					app.myPassport.warningsAcknowledged	:= true;
					continue;
				endif;
			endif;
			
			break;
			
		endwhile;
	
	else
		app.raiseCMException1(FileNotCreated, 'Log', null, null);
		return;
	endif;

	self.sssShowLogRowsForDownload();
	btnSelectAll.caption := CapSelectAll;
	btnSelectChanges.caption := CapSelectChanges;	
epilog
	if rowDownloadArray &lt;&gt; null then
		rowDownloadArray.purge();
		delete rowDownloadArray;
	endif;
	app.mousePointer := MousePointer_Default;		
end;</source>
    </JadeMethod>
    <JadeMethod name="sssExportToFile" id="7fe84724-08ba-486f-aaba-0a33c414db5b">
        <updating/>
        <source>sssExportToFile() updating;
//--------------------------------------------------------------
//Created: 12 August 2002 By: cnwgd1
//--------------------------------------------------------------
// 10/12/2014  cnwdb2	PAR 35364

vars
	rowDownloadArray : CMIF_LogRowDownloadArray;
	dwnLoad	: CM_LogVoyageRowDownload;
	intFaceRow : CMIF_LogRowDownload;
	all, changes : Boolean;
	row, int, col3, col4 : Integer;	
	logFile, shipFile : String;
	cmifMonitor	: CMIF_Monitor;
	obj : Object;
	logCntrl : CM_LogController;	
	theResult : Integer;	//14 Jan 2020 NDL	TFS 46815
begin

//	if (not CM_LogVoyage.hasInstance(self.myCurrentVoyage)) then
	if (self.myCurrentVoyage.myLogVoyageStructure =null) then
		app.msgBox('Please Select a Terminal from the list.', 'SSS Info', MsgBox_Information_Icon + MsgBox_OK_Only);		
		return;
	endif;

	app.mousePointer := MousePointer_HourGlass;	
	
	if self.txtDwnLogFile.text &lt;&gt; null then
		logFile := self.txtDwnLogFile.text.trimBlanks;
	endif;
	if self.txtDwnShipFile.text &lt;&gt; null then
		shipFile := self.txtDwnShipFile.text.trimBlanks;
	endif;
	
	if logFile = null and shipFile = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Log File Name and/or Ship File Name', null, null);
		app.raiseCMException(Input_required_field_logOrShp, null, null); // cnwdb2	PAR 35364
		
		return;
	endif;
	
   	create cmifMonitor transient;
   	app.myPassport.setMyCMIFMonitor(cmifMonitor);
   	cmifMonitor.myParent := self;
   	if logFile &lt;&gt; null then
   		if shipFile &lt;&gt; null then
   			cmifMonitor.message := 'Extracting Log and Ship Data';
		else
   			cmifMonitor.message := 'Extracting Log Data';
   		endif;
   	else
		cmifMonitor.message := 'Extracting Ship Data';
   	endif;
	self.modalDialogShow(null, 'Cancel', null, null, 'SSS Extracting File', cmifMonitor.message);
	
	col3 := 3;
	col4 := 4;
	create rowDownloadArray transient;
	
	foreach row in 2 to self.tblDownloadInfo.rows do

		dwnLoad := null;
		logCntrl := null;
		all := false;
		changes := false;
		
		obj	:= self.tblDownloadInfo.accessRow(row).itemObject;
		if CM_LogVoyageRowDownload.hasInstance(obj) then
			dwnLoad := obj.CM_LogVoyageRowDownload;
		elseif CM_LogController.hasInstance(obj) then
			logCntrl := obj.CM_LogController;
		else
			continue;
		endif;

		int := self.tblDownloadInfo.accessCell(row, col3).text.Integer;
		if int = 0 then
			int := self.tblDownloadInfo.accessCell(row, col4).text.Integer;
			if int = 1 then
				changes := true;
			endif;
		else
			all := true;		
		endif;
		
		if all or changes then
			if dwnLoad &lt;&gt; null then
				create intFaceRow transient;			
				intFaceRow.myRowDownload := dwnLoad;
							elseif logCntrl &lt;&gt; null then
				create intFaceRow transient;
				create intFaceRow.myRowDownload transient;
				intFaceRow.myRowDownload.setProxy(logCntrl, self.myCurrentVoyage.myLogVoyageStructure);
			else
				continue;
			endif;
			
			rowDownloadArray.add(intFaceRow);				
			if changes then
				intFaceRow.changesOnly := true;
			endif;
			
		endif;
		
	endforeach;

	if (not cmifMonitor.updateProgress(cmifMonitor.message, cmifMonitor.partsDone, cmifMonitor.partsInJob)) then
		return;
	endif;

	if rowDownloadArray.size &gt; 0 then
	   	self.pbProgressBar.visible := true; 
		
		//14 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
		while true do
		
			app.myTrxUA.trxUpdateLogRowDownload(rowDownloadArray, logFile, shipFile, app.myPassport);
		
			if app.myPassport.trxCompletedOK then
				break;
			else
				theResult := app.showErrorWarningDialog('Log Voyage Operations', app.myPassport, ErrWarnMode_Update);
				if app.myPassport.noErrors and theResult = IDOK then
					app.myPassport.warningsAcknowledged	:= true;
					continue;
				endif;
			endif;
			
			return;
			
		endwhile;
	
	else
		app.raiseCMException1(FileNotCreated, 'Log and/or Ship', null, null);
		return;
	endif;

	self.sssShowLogRowsForDownload();
	btnSelectAll.caption := CapSelectAll;
	btnSelectChanges.caption := CapSelectChanges;
		
epilog
	self.frmModalDialog.visible := false;
	delete cmifMonitor;
   	app.myPassport.setMyCMIFMonitor(null);

	if rowDownloadArray &lt;&gt; null then
		foreach intFaceRow in rowDownloadArray do
			if intFaceRow.myRowDownload &lt;&gt; null
			and intFaceRow.myRowDownload.isTransient then
				delete intFaceRow.myRowDownload;
			endif;
		endforeach;
		rowDownloadArray.purge();
		delete rowDownloadArray;
	endif;
	app.mousePointer := MousePointer_Default;		
end;</source>
    </JadeMethod>
    <JadeMethod name="sssExportToFileOLD" id="9f9e00ab-1f8c-4a0f-90cf-c254d8f2b345">
        <updating/>
        <source>sssExportToFileOLD() updating;
//--------------------------------------------------------------
//Created: 12 August 2002 By: cnwgd1
//--------------------------------------------------------------
// 10/12/2014  cnwdb2	PAR 35364

vars
	rowDownloadArray : CMIF_LogRowDownloadArray;
	dwnLoad	: CM_LogVoyageRowDownload;
	intFaceRow : CMIF_LogRowDownload;
	all, changes : Boolean;
	row, int, col3, col4 : Integer;	
	logFile, shipFile : String;
	cmifMonitor	: CMIF_Monitor;
	theResult : Integer;	//14 Jan 2020 NDL	TFS 46815

begin

	app.mousePointer := MousePointer_HourGlass;	
	
	if self.txtDwnLogFile.text &lt;&gt; null then
		logFile := self.txtDwnLogFile.text.trimBlanks;
	endif;
	if self.txtDwnShipFile.text &lt;&gt; null then
		shipFile := self.txtDwnShipFile.text.trimBlanks;
	endif;
	
	if logFile = null and shipFile = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Log File Name and/or Ship File Name', null, null);
		app.raiseCMException(Input_required_field_logOrShp, null, null); // cnwdb2	PAR 35364
		return;
	endif;
	
   	create cmifMonitor transient;
   	app.myPassport.setMyCMIFMonitor(cmifMonitor);
   	cmifMonitor.myParent := self;
   	if logFile &lt;&gt; null then
   		if shipFile &lt;&gt; null then
   			cmifMonitor.message := 'Extracting Log and Ship Data';
		else
   			cmifMonitor.message := 'Extracting Log Data';
   		endif;
   	else
		cmifMonitor.message := 'Extracting Ship Data';
   	endif;
	self.modalDialogShow(null, 'Cancel', null, null, 'SSS Extracting File', cmifMonitor.message);
	
	col3 := 3;
	col4 := 4;
	create rowDownloadArray transient;
	foreach row in 2 to self.tblDownloadInfo.rows do
		dwnLoad	:= self.tblDownloadInfo.accessRow(row).itemObject.CM_LogVoyageRowDownload;
		int := self.tblDownloadInfo.accessCell(row, col3).text.Integer;
		if int = 0 then
			int := self.tblDownloadInfo.accessCell(row, col4).text.Integer;
			if int = 1 then
				changes := true;
			endif;
		else
			all := true;		
		endif;
		if all or changes then
			create intFaceRow transient;
			intFaceRow.myRowDownload := dwnLoad;
			rowDownloadArray.add(intFaceRow);				
			if changes then
				intFaceRow.changesOnly := true;
			endif;
		endif;
		dwnLoad := null;
		all := false;
		changes := false;
	endforeach;

	if (not cmifMonitor.updateProgress(cmifMonitor.message, cmifMonitor.partsDone, cmifMonitor.partsInJob)) then
		return;
	endif;

	if rowDownloadArray.size &gt; 0 then
	   	self.pbProgressBar.visible := true; 
		
		//14 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
		while true do
		
			app.myTrxUA.trxUpdateLogRowDownload(rowDownloadArray, logFile, shipFile, app.myPassport);
		
			if app.myPassport.trxCompletedOK then
				break;
			else
				theResult := app.showErrorWarningDialog('Log Voyage Operations', app.myPassport, ErrWarnMode_Update);
				if app.myPassport.noErrors and theResult = IDOK then
					app.myPassport.warningsAcknowledged	:= true;
					continue;
				endif;
			endif;
			
			return;
			
		endwhile;
	
	else
		app.raiseCMException1(FileNotCreated, 'Log and/or Ship', null, null);
		return;
	endif;

	self.sssShowLogRowsForDownload();
	btnSelectAll.caption := CapSelectAll;
	btnSelectChanges.caption := CapSelectChanges;	
epilog
	self.frmModalDialog.visible := false;
	delete cmifMonitor;
   	app.myPassport.setMyCMIFMonitor(null);

	if rowDownloadArray &lt;&gt; null then
		rowDownloadArray.purge();
		delete rowDownloadArray;
	endif;
	app.mousePointer := MousePointer_Default;		
end;</source>
    </JadeMethod>
    <JadeMethod name="sssImportLoadOutFile" id="77fa226e-9009-40e4-9310-93d95a07ea21">
        <updating/>
        <source>sssImportLoadOutFile() updating;
//--------------------------------------------------------------
//Created: 22 August 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	alertCreated,
	rtnValue 				: Boolean;
	logOutFileName 			: String;
	newEDIDataBOLOutLog,
	pxyEDIDataBOLOutLog 	: CM_EDIDataBOLOutLog;
	realEDIDataBOLOutLog	: CM_EDIData;
	cmifMonitor				: CMIF_Monitor;
	theResult : Integer;	//14 Jan 2020 NDL	TFS 46815
	
begin

	self.btnImportLogOut.enabled := false;

	if self.txtImportFile.text &lt;&gt; null then
		logOutFileName := self.txtImportFile.text.trimBlanks;
	else	
		app.msgBox(app.getErrorString(Input_required_field_logOutFle), app.getErrorString(Import_failed), MsgBox_Stop_Icon + MsgBox_OK_Only);	// cnwdb2	PAR 35364
		self.txtImportFile.setFocus();
		return;
	endif;
	
	if self.myCurrentVoyage = null then
		app.msgBox('Please Select a Terminal from the list.', 'SSS Info', MsgBox_Information_Icon + MsgBox_OK_Only);
		if self.fldTreeView.topSheet = self.shtListPorts then
			self.lstPorts.setFocus();
		else
			self.lstSuppliers.setFocus();
		endif;
		return;
	endif;

	if self.myCurrentVoyage.myLogVoyageStructure.hasFileBeenLoaded(logOutFileName) then
		if app.msgBox(app.getErrorString1(FileAlreadyLoadedContinue, logOutFileName.fileBaseName), 'SSS Info', 
						MsgBox_Question_Mark_Icon + MsgBox_Yes_No + MsgBox_Default_Second) = MsgBox_Return_No then
			self.txtImportFile.setFocus();
			return;
		endif;
	endif;

	// set focus to the txt Import box remove focus
	// from the button in case the user presses the
	// return button while the system is still processing
	self.txtImportFile.setFocus();
	

	app.mousePointer := MousePointer_HourGlass;
   	create cmifMonitor transient;
   	app.myPassport.setMyCMIFMonitor(cmifMonitor);
   	cmifMonitor.myParent := self;
   	cmifMonitor.message := 'Creating EDI Data';
	self.modalDialogShow(null, 'Cancel', null, null, 'SSS Import Log Out File ', cmifMonitor.message);
	
	create pxyEDIDataBOLOutLog transient;
	pxyEDIDataBOLOutLog.setProxy(logOutFileName, app.getMyUserCode, self.myCurrentVoyage.myTerminal, app.myRoot);
	app.writeLog('SSS Import Log Out File :: Creating EDI Data (' &amp; logOutFileName &amp; ')', LogINFO);	
	
	//14 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
	while true do
	
		app.myTrxCA.trxCreateEDIDataBOLOutLog(pxyEDIDataBOLOutLog, true, realEDIDataBOLOutLog, self.myCurrentVoyageGlobal, app.myPassport);
	
		if app.myPassport.trxCompletedOK then
			break;
		else
			theResult := app.showErrorWarningDialog('Voyage Ops', app.myPassport, ErrWarnMode_Update);
			if app.myPassport.noErrors and theResult = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		
		self.frmModalDialog.visible := false;
		app.writeLog('SSS Import Log Out File :: ERROR Creating EDI Data (' &amp; logOutFileName &amp; ')', LogINFO);			
		return;
		
	endwhile;
	
   	cmifMonitor.message := 'Creating Load Out Dockets';
   	cmifMonitor.partsDone := 0;
   	cmifMonitor.partsInJob := 0;
   	self.pbProgressBar.visible := true;   	
   	self.updateProgress(cmifMonitor);
		
	newEDIDataBOLOutLog := realEDIDataBOLOutLog.CM_EDIDataBOLOutLog;
	app.writeLog('SSS Import Log Out File :: Creating Load Out Dockets (' &amp; logOutFileName &amp; ')', LogINFO);	
	
	//14 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
	while true do
	
		app.myTrxCA.trxCreateBOLOutFromEDIData(newEDIDataBOLOutLog, app.myPassport);
	
		if app.myPassport.trxCompletedOK then
			break;
		else
			theResult := app.showErrorWarningDialog('Voyage Ops', app.myPassport, ErrWarnMode_Update);
			if app.myPassport.noErrors and theResult = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
				
		app.writeLog('SSS Import Log Out File :: ERROR Creating Load Out Dockets (' &amp; logOutFileName &amp; ')', LogINFO);				
		return;
		
	endwhile;
	
	
   	cmifMonitor.message := 'Loading Dockets to voyage';
   	cmifMonitor.partsInJob := newEDIDataBOLOutLog.allBOLs.size;
   	cmifMonitor.partsDone := 0;
   	self.pbProgressBar.visible := true;   	
   	self.updateProgress(cmifMonitor);		
	
	app.writeLog('SSS Import Log Out File :: Loading Dockets to voyage (' &amp; logOutFileName &amp; ')', LogINFO);
	
	//14 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
	while true do
	
		app.myTrxUA.trxUpdateMoveBOLs(newEDIDataBOLOutLog.allBOLs, REAL_MODE, alertCreated, app.myPassport);
	
		if app.myPassport.trxCompletedOK then
			break;
		else
			theResult := app.showErrorWarningDialog('Voyage Ops', app.myPassport, ErrWarnMode_Update);
			if app.myPassport.noErrors and theResult = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
			
		app.writeLog('SSS Import Log Out File :: ERROR Loading Dockets to voyage (' &amp; logOutFileName &amp; ')', LogINFO);			
		return;
		
	endwhile;
	
	app.writeLog('SSS Import Log Out File :: Load Out Complete (' &amp; logOutFileName &amp; ')', LogINFO);		
	global.beep;		

epilog
	self.frmModalDialog.visible := false;
	self.sssShowEDIData();	
	self.sssShowDocketsToBeLoaded();
	delete pxyEDIDataBOLOutLog;
	delete cmifMonitor;
   	app.myPassport.setMyCMIFMonitor(null);
	self.btnImportLogOut.enabled := true;
	app.mousePointer := MousePointer_Default;

end;</source>
    </JadeMethod>
    <JadeMethod name="sssLoad" id="31f8c84d-c202-4586-9d4f-2bb9b0ff5eda">
        <updating/>
        <source>sssLoad() updating;
//--------------------------------------------------------------
//Created: 12 December 2002 By: cnwgd1
//--------------------------------------------------------------
vars

begin

	if self.fldSSSLoadOut.topSheet = self.shtSSSEDIData then
		//process selected import file
		self.sssLoadEDIData();
	else //load selected dockets
		self.sssLoadDockets();
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="sssLoadDockets" id="fc70d0f2-a945-4aa5-91af-de443f1e76bc">
        <updating/>
        <source>sssLoadDockets() updating;
//--------------------------------------------------------------
//Created: 12 December 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	bolExt		: CM_BOLExtLogOut;
	bolSet 		: CM_BOLSet;
	alertCreated,
	rtnValue	: Boolean;
	row			: Integer;
	cmifMonitor	: CMIF_Monitor;
	theResult : Integer;	//14 Jan 2020 NDL	TFS 46815
begin
	if self.fldSSSLoadOut.topSheet &lt;&gt; self.shtSSSBOL then
		return;
	endif;
	
	if self.tblSSSDockets.rows &lt;= self.tblSSSDockets.fixedRows then
		return;
	endif;
	
	app.mousePointer := MousePointer_HourGlass;
   	create cmifMonitor transient;
   	app.myPassport.setMyCMIFMonitor(cmifMonitor);
   	cmifMonitor.myParent := self;
   	cmifMonitor.message := 'Loading Dockets to voyage';
	self.modalDialogShow(null, 'Cancel', null, null, 'Shipside Scanning ', cmifMonitor.message);

	create bolSet transient;
	
	row := self.tblSSSDockets.rows;
	while row &gt; tblSSSDockets.fixedRows do
		if tblSSSDockets.accessCell(row, 1).text = '1' then
			bolExt := tblSSSDockets.accessRow(row).itemObject.CM_BOLExtLogOut;
			bolSet.add(bolExt.myBOL);
		endif;
		row := row - 1;
	endwhile;

	app.writeLog('Shipside Scanning :: Loading Dockets to voyage', LogINFO);			

   	cmifMonitor.partsInJob := bolSet.size;
   	cmifMonitor.partsDone := 0;
   	self.pbProgressBar.visible := true;   	
   	self.updateProgress(cmifMonitor);
	
	//14 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
	while true do
	
		app.myTrxUA.trxUpdateMoveBOLs(bolSet, REAL_MODE, alertCreated, app.myPassport);
	
		if app.myPassport.trxCompletedOK then
			break;
		else
			theResult := app.showErrorWarningDialog('Voyage Ops', app.myPassport, ErrWarnMode_Update);
			if app.myPassport.noErrors and theResult = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		
		app.writeLog('Shipside Scanning :: ERROR Loading Dockets to voyage', LogINFO);					
		return;
		
	endwhile;

	if alertCreated then
		app.raiseCMException1(SystemAlertCreated, 'Loading Dockets', null, self);
	else
		app.msgBox('Shipside docket load completed', 'SSS Info', MsgBox_Information_Icon + MsgBox_OK_Only);
	endif;

	self.sssShowDocketsToBeLoaded();	
							
epilog
	delete bolSet;
	self.frmModalDialog.visible := false;
	delete cmifMonitor;
   	app.myPassport.setMyCMIFMonitor(null);
	app.mousePointer := MousePointer_Default;
end;</source>
    </JadeMethod>
    <JadeMethod name="sssLoadEDIData" id="c44bf7fa-5e8d-4846-ad7a-84e0b72c170a">
        <updating/>
        <source>sssLoadEDIData() updating;
//--------------------------------------------------------------
//Created: 12 December 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	ediData 	: CM_EDIDataBOLOutLog;
	alertCreated	: Boolean;
	status,
	fileName	: String;
	bol			: CM_BOL;
	bolSet		: CM_BOLSet;
	cmifMonitor	: CMIF_Monitor;
	theResult : Integer;	//14 Jan 2020 NDL	TFS 46815
begin

	if self.fldSSSLoadOut.topSheet &lt;&gt; self.shtSSSEDIData then
		return;
	endif;

	if self.tblSSSEDIData.row &lt;= self.tblSSSEDIData.fixedRows then
		app.msgBox('Please select a file. Cannot continue', 'Select File', MsgBox_OK_Only);		
		return;
	endif;
	
	if self.mySSSLogVoyage = null then
		app.msgBox('Please select a Voyage. Cannot continue', 'Select Voyage', MsgBox_OK_Only);	
		return;
	endif;
	
	app.mousePointer := MousePointer_HourGlass;
	
   	create cmifMonitor transient;
   	app.myPassport.setMyCMIFMonitor(cmifMonitor);
   	cmifMonitor.myParent := self;
   	cmifMonitor.message := 'Creating Load Out Dockets';   	
	self.modalDialogShow(null, 'Cancel', null, null, 'SSS Import Log Out File ', cmifMonitor.message);
	
	fileName := self.tblSSSEDIData.accessCell(tblSSSEDIData.row, 1).text;
	ediData := self.tblSSSEDIData.accessRow(tblSSSEDIData.row).itemObject.CM_EDIDataBOLOutLog;
	status := ediData.getStatusForVoyage(self.mySSSLogVoyage);
	
	if status = ediData.File_Status_Imported then
		app.writeLog('SSS Import Log Out File :: Creating Load Out Dockets (' &amp; fileName &amp; ')', LogINFO);		

	   	cmifMonitor.partsInJob := 0;
	   	cmifMonitor.partsDone := 0;
	   	self.pbProgressBar.visible := true;   	
	   	self.updateProgress(cmifMonitor);	
		
		//14 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
		while true do
		
			app.myTrxCA.trxCreateBOLOutFromEDIData(ediData, app.myPassport);
		
			if app.myPassport.trxCompletedOK then
				break;
			else
				theResult := app.showErrorWarningDialog( cmifMonitor.message, app.myPassport, ErrWarnMode_Update);
				if app.myPassport.noErrors and theResult = IDOK then
					app.myPassport.warningsAcknowledged	:= true;
					continue;
				endif;
			endif;
			
			break;
			
		endwhile;
	
		
		if app.myPassport.trxCompletedOK then
		   	cmifMonitor.message := 'Deleting EDI Tracked Items';
		   	cmifMonitor.partsInJob := ediData.allEDITrackedItems.size;
		   	cmifMonitor.partsDone := 0;
		   	self.pbProgressBar.visible := true;   	
		   	self.updateProgress(cmifMonitor);	
			
			//14 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
			while true do
			
				app.myTrxDA.trxDeleteEDITrackedItems(ediData.allEDITrackedItems, app.myPassport);
			
				if app.myPassport.trxCompletedOK then
					break;
				else
					theResult := app.showErrorWarningDialog( cmifMonitor.message, app.myPassport, ErrWarnMode_Update);
					if app.myPassport.noErrors and theResult = IDOK then
						app.myPassport.warningsAcknowledged	:= true;
						continue;
					endif;
				endif;
				
				break;
				
			endwhile;
			
		endif;

	elseif status = ediData.File_Status_BOLCreated then
		app.writeLog('SSS Import Log Out File :: Loading Dockets to voyage (' &amp; fileName &amp; ')', LogINFO);
		create bolSet transient;	
		foreach bol in ediData.allBOLs do
//			if bol.myExtension.CM_BOLExtLogOut.myLogVoyageNotLoaded &lt;&gt; null then
			if bol.myExtension.CM_BOLExtLogOut.myLogVoyageStructNotLoaded &lt;&gt; null then
				bolSet.add(bol);
			endif;
		endforeach;		

	   	cmifMonitor.message := 'Loading Dockets to voyage';
	   	cmifMonitor.partsInJob := bolSet.size;
	   	cmifMonitor.partsDone := 0;
	   	self.pbProgressBar.visible := true;   	
	   	self.updateProgress(cmifMonitor);	
		
		//14 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
		while true do
		
			app.myTrxUA.trxUpdateMoveBOLs(bolSet, REAL_MODE, alertCreated, app.myPassport);
		
			if app.myPassport.trxCompletedOK then
				break;
			else
				theResult := app.showErrorWarningDialog( cmifMonitor.message, app.myPassport, ErrWarnMode_Update);
				if app.myPassport.noErrors and theResult = IDOK then
					app.myPassport.warningsAcknowledged	:= true;
					continue;
				endif;
			endif;
			
			break;
			
		endwhile;

		
	else
		app.msgBox('Dockets have already been loaded for file ' &amp; fileName, 'Already Loaded', MsgBox_OK_Only);	
		return;
	endif;		

	if (not app.myPassport.trxCompletedOK) then
		if status = ediData.File_Status_Imported then
			app.writeLog('SSS Import Log Out File :: ERROR Creating Load Out Dockets (' &amp; fileName &amp; ')', LogINFO);
		elseif status = ediData.File_Status_BOLCreated then
			app.writeLog('SSS Import Log Out File :: ERROR Loading Dockets to voyage (' &amp; fileName &amp; ')', LogINFO);					
		endif;
	else
		self.sssShowEDIData();
		app.msgBox('SSS data ' &amp; ediData.fileShortName &amp; ' load completed', 'SSS Info', MsgBox_Information_Icon + MsgBox_OK_Only);
	endif;
	
epilog
	delete bolSet;		// Jan 2014 transient leak fix
	self.frmModalDialog.visible := false;
	delete cmifMonitor;
   	app.myPassport.setMyCMIFMonitor(null);

	app.mousePointer := MousePointer_Default;
end;</source>
    </JadeMethod>
    <JadeMethod name="sssLoadOutSheetChange" id="579f1ac7-71a7-4042-adb3-dcc35061b45a">
        <source>sssLoadOutSheetChange();
//--------------------------------------------------------------
//Created: 12 December 2002 By: cnwgd1
//--------------------------------------------------------------
vars

begin
	if self.fldSSSLoadOut.topSheet = self.shtSSSBOL then
		self.sssShowDocketsToBeLoaded();
		if self.mode &lt;&gt; self.Mode_View_Only then
			self.btnSSSSelect.enabled := true;
		endif;
	else
		self.sssShowEDIData();
		self.btnSSSSelect.enabled := false;		
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="sssSelectDeselect" id="f04aabc5-fd49-4e23-b97c-76cb93c11da4">
        <source>sssSelectDeselect(_all : Boolean; _col : Integer; _table : CM_DataTable input);
//--------------------------------------------------------------
//Created: 12 August 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	cell 	: JadeTableCell;
	idx,
	row		: Integer;		
begin
	
	idx := _table.fixedRows + 1;
	
	foreach row in idx to _table.rows do
		cell := _table.accessCell(row, _col);
		cell.text := _all.Integer.String;
	endforeach;
end;</source>
        <Parameter name="_all" type="Boolean"/>
        <Parameter name="_col" type="Integer"/>
        <Parameter name="_table" type="CM_DataTable" usage="input"/>
    </JadeMethod>
    <JadeMethod name="sssShowDocketsToBeLoaded" id="51c07e1a-5e00-4e72-aca7-74f3397cd239">
        <source>sssShowDocketsToBeLoaded();
//--------------------------------------------------------------
//Created: 12 December 2002 By: cnwgd1
//--------------------------------------------------------------
// 24/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls

vars
	bolExt		: CM_BOLExtLogOut;
	idx, 
	backColour 	: Integer;
	str			: String;
begin

	tblSSSDockets.rows := tblSSSDockets.fixedRows;
	if self.mySSSLogVoyage = null or self.mySSSLogVoyage.myLogVoyageStructure = null then
		return;
	endif;

	foreach bolExt in self.mySSSLogVoyage.myLogVoyageStructure.allBOLExtLogOutNotLoaded do
		if (self.tblSSSDockets.rows mod 2) = 0 then
			backColour := self.colorRow1;
		else
			backColour := self.colorRow2;
		endif;			
		str := self.dataTableDisplayRow(tblSSSDockets, bolExt);
		idx := tblSSSDockets.addItem(str);
		tblSSSDockets.accessRow(idx).itemObject := bolExt;
		tblSSSDockets.accessRow(idx).backColor := backColour;		
	endforeach;
	
	self.btnSSSSelect.caption := CapDeselectAll;
end;</source>
    </JadeMethod>
    <JadeMethod name="sssShowEDIData" id="0ee9c6c8-f285-496c-aac8-2e3d99607a09">
        <source>sssShowEDIData();
//--------------------------------------------------------------
//Created: 11 December 2002 By: cnwgd1
//--------------------------------------------------------------
// 24/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls

vars
	ediData		: CM_EDIData;
	idx, 
	backColour 	: Integer;
	str			: String;
begin

	tblSSSEDIData.rows := tblSSSEDIData.fixedRows;
	if self.mySSSLogVoyage = null or self.mySSSLogVoyage.myLogVoyageStructure = null then
		return;
	endif;
	
	foreach ediData in self.mySSSLogVoyage.myLogVoyageStructure.allEDIDataBOLOutLog reversed do
		if (self.tblSSSEDIData.rows mod 2) = 0 then
			backColour := self.colorRow1;
		else
			backColour := self.colorRow2;
		endif;			
		str := self.dataTableDisplayRow(tblSSSEDIData, ediData);
		idx := tblSSSEDIData.addItem(str);
		tblSSSEDIData.accessCell(idx, 2).text := ediData.CM_EDIDataBOLOutLog.getStatusForVoyage(self.mySSSLogVoyage);
		tblSSSEDIData.accessRow(idx).itemObject := ediData;
		tblSSSEDIData.accessRow(idx).backColor := backColour;		
	endforeach;

end;</source>
    </JadeMethod>
    <JadeMethod name="sssShowLogRowsForDownload" id="27096d70-c5ab-42c6-b863-59acb279e9c6">
        <updating/>
        <source>sssShowLogRowsForDownload() updating;
//--------------------------------------------------------------
//Created: 12 August 2002 By: cnwgd1
//--------------------------------------------------------------
// 09/02/2011	cnwcs5	CCMS JML 1114/PAR 26847 - allow multiselect on Ship Sacn tab
vars
	dwnLoad		: CM_LogVoyageRowDownload;
	idx		 	: Integer;
	str			: String;
	tmpLogVoyage: CM_Voyage;
	tmpTable	: CM_DataTable;
	stkOrd		: CM_StockOrderHeader;
	alloc		: CM_StockOrderAllocation;
	locnCntrl	: CM_LocationsController;
	logCntrl	: CM_LogController;
	tmpLCSet	: CM_LCSet;	
	coll		: ObjectSet;		// 02/092011 cnwcs5 CCMS JML 1114/PAR 26929
	obj			: Object;			// 02/092011 cnwcs5 CCMS JML 1114/PAR 26929
begin
	tmpTable 		:= self.tblDownloadInfo;
	tmpTable.rows 	:= tmpTable.fixedRows;

	self.btnSelectAll.caption 		:= CapSelectAll;
	self.btnSelectChanges.caption 	:= CapSelectChanges;
	
	tmpLogVoyage := self.mySSSLogVoyage;
	
	if tmpLogVoyage = null or tmpLogVoyage.myLogVoyageStructure  = null then
		return;
	endif;
	
	// Go and get all the rows that have been allocated to the voyage via stock order allocations
	create tmpLCSet transient;
	
	// 02/092011 cnwcs5 CCMS JML 1114/PAR 26929 - show rows for all selected lots
	create coll transient;
	// grab collection of selected lots
	
	foreach obj in self.tblOrderData.allSelectedObjects do
		if not obj.isKindOf (CM_LogStockOrderLine) then
			continue;
		endif;
		coll.add (obj); 
	endforeach;
	// 02/092011 cnwcs5 CCMS JML 1114/PAR 26929 - end
	
	foreach stkOrd in tmpLogVoyage.allOrdersByOperatorOrderNo do
	
		// 03/04/2009 cnwar2 CCMS-1099 #19395
		if self.myCurrentVoyageOperator &lt;&gt; null then
			if self.myCurrentVoyageOperator.myOperator &lt;&gt; stkOrd.myOperator
			or self.myCurrentVoyageOperator.myVoyage &lt;&gt; stkOrd.myVoyage then
				continue;
			endif;
		elseif self.myCurrentVoyage &lt;&gt; null then
			if self.myCurrentVoyage &lt;&gt; stkOrd.myVoyage then
				continue;
			endif;
		else
			self.showCannotAccessSheetMsg(shtSSScan, 'You must select a terminal in the list box before you can do a download');
			return;
		endif;
	
		foreach alloc in stkOrd.allStockOrderAllocations do
			locnCntrl := alloc.myLocationsController;
			if CM_LogController.hasInstance(locnCntrl) then

				logCntrl := locnCntrl.CM_LogController;
				
				if (not tmpLCSet.includes(logCntrl)) then
					tmpLCSet.add(logCntrl);
				else
					// already added to table
					continue;
				endif;
				
				// 06/04/2009 cnwar2 CCMS-1099 #19395
				//if self.myCurrentStockOrderObject &lt;&gt; null and self.myCurrentStockOrderObject.isKindOf(CM_LogStockOrderLine) then
				//	if not (alloc.isKindOf(CM_StockOrderLineAlloc) and self.myCurrentStockOrderLine.allStockAllocations.includes(alloc.CM_StockOrderLineAlloc)) then
				//		continue;
				//	endif;
				//endif;
				// 02/092011 cnwcs5 CCMS JML 1114/PAR 26929 - show rows for all selected lots
				if not coll.isEmpty and
					alloc.isKindOf (CM_StockOrderLineAlloc) then
					// I think it will always be a CM_StockOrderLineAlloc
					if not coll.includes (alloc.CM_StockOrderLineAlloc.myStockOrderLine) then
						// not one of the selected ones
						continue;
					endif;
				endif;
				// 02/092011 cnwcs5 CCMS JML 1114/PAR 26929 - end
				
				dwnLoad := self.mySSSLogVoyage.myLogVoyageStructure.allLogRowDownloads[logCntrl];
				
				if dwnLoad &lt;&gt; null then
					str := dwnLoad.getDisplayStringForAttribute(ETRow_RowId, true) &amp; Tab &amp; dwnLoad.getDisplayStringForAttribute(ETRow_LastDownloadTime, true);
				else
					str := logCntrl.getID() &amp; Tab &amp; 'Never';				
				endif;				
				
				idx := tmpTable.addItem(str);
				
				if dwnLoad &lt;&gt; null then
					tmpTable.accessRow(idx).itemObject := dwnLoad;
				else
					tmpTable.accessRow(idx).itemObject := logCntrl;				
				endif;
						
			endif;
		endforeach;
	endforeach;
	// just recolouring rows here !
	foreach idx in tmpTable.fixedRows + 1 to tmpTable.rows do
		if (idx mod 2) = 0 then
			tmpTable.accessRow(idx).backColor := self.colorRow1;
		else
			tmpTable.accessRow(idx).backColor := self.colorRow2;
		endif;
	endforeach;
	
epilog	
	delete tmpLCSet;
	delete coll;		// 02/092011 cnwcs5 CCMS JML 1114/PAR 26929
end;</source>
    </JadeMethod>
    <JadeMethod name="stripCarriageReturns" id="03b8ad6e-2f04-4cf7-b4c6-f1a63de81722">
        <source>stripCarriageReturns(	_attrName : String io;
						_strValue : String io;
						_cmif : CMIF_LogStockOrderLine input;
						_tbl : CM_EntryTable input
						) : Boolean protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 December 2012	cnwndl1	Initial creation	Par 30709

*/

vars

	pos : Integer;
	text : String;

begin

	if _attrName = ETRow_LotNo and _strValue &lt;&gt; null then
		pos := _strValue.pos(Cr,1);
		if pos &gt; 0 then
			_cmif.lotNo := null;
			_strValue := _strValue.removeTabCrLfs().trimBlanks();
		endif;
		_cmif.lotNo := _strValue;
		return true;

	// 22/10/2014 cnwar2 #35094
	elseif _attrName = ETRow_Comments and _strValue &lt;&gt; null then
		pos := _strValue.pos(Cr,1);
		if pos &gt; 0 then
			_cmif.comments := null;
			_strValue := _strValue.removeTabCrLfs().trimBlanks();
		endif;
		_cmif.comments := _strValue;
		return true;
		
	// 22/10/2014 cnwar2 #35094
	elseif _attrName = ETRow_CommentsOperator and _strValue &lt;&gt; null then
		pos := _strValue.pos(Cr,1);
		if pos &gt; 0 then
			_cmif.commentsOperator := null;
			_strValue := _strValue.removeTabCrLfs().trimBlanks();
		endif;
		_cmif.commentsOperator := _strValue;
		return true;
		
	// 22/10/2014 cnwar2 #35094
	elseif _attrName = ETRow_OperatorRef1 and _strValue &lt;&gt; null then
		pos := _strValue.pos(Cr,1);
		if pos &gt; 0 then
			_cmif.operatorRef1 := null;
			_strValue := _strValue.removeTabCrLfs().trimBlanks();
		endif;
		_cmif.operatorRef1 := _strValue;
		return true;
		
	// 22/10/2014 cnwar2 #35094
	elseif _attrName = ETRow_OperatorRef2 and _strValue &lt;&gt; null then
		pos := _strValue.pos(Cr,1);
		if pos &gt; 0 then
			_cmif.operatorRef2 := null;
			_strValue := _strValue.removeTabCrLfs().trimBlanks();
		endif;
		_cmif.operatorRef2 := _strValue;
		return true;
		
	endif;

	return false;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_attrName" type="String" usage="io"/>
        <Parameter name="_strValue" type="String" usage="io"/>
        <Parameter name="_cmif" type="CMIF_LogStockOrderLine" usage="input"/>
        <Parameter name="_tbl" type="CM_EntryTable" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="summaryAllocResetSplit" id="f807b3bd-ed7a-46bf-898e-ace923379d52">
        <updating/>
        <source>summaryAllocResetSplit()updating;
//--------------------------------------------------------------
//Created: 08 August 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	summary : CM_StockOrderSummary;
	stockOrder : CM_StockOrderLine;
	theResult : Integer;	//14 Jan 2020 NDL	TFS 46815
	
begin

	if self.myCurrentStockOrderSummary = null then
		self.showCannotAccessSheetMsg(shtAllocToDetail, app.getErrorString(LVO_SelectSummary));
		return;
	else
		self.hideCannotAccessSheetMsg(shtAllocToDetail);
	endif;

	app.mousePointer := MousePointer_HourGlass;
	
	summary := self.myCurrentStockOrderSummary;
	
	//14 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
	while true do
	
		app.myTrxDA.trxDeleteStockOrderSummLines(summary, app.myPassport);
	
		if app.myPassport.trxCompletedOK then
			break;
		else
			theResult := app.showErrorWarningDialog('Log Voyage Operations', app.myPassport, ErrWarnMode_Delete);
			if app.myPassport.noErrors and theResult = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		
		return;
		
	endwhile;
	
epilog
	app.mousePointer := MousePointer_Default;		
end;</source>
    </JadeMethod>
    <JadeMethod name="summaryAllocSaveSplit" id="b3464d16-add8-4edd-bd25-b76a342f89ad">
        <updating/>
        <source>summaryAllocSaveSplit()updating;
//--------------------------------------------------------------
//Created: November 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	iFaceAlloc 		: CMIF_StockOrderAllocation;
	iFaceSet 		: CMIF_LogStockOrderAllocSet;
	summAlloc 		: CM_StockOrderSummaryAlloc;
	stockOrder 		: CM_LogStockOrderLine;
	sohLocn 		: CM_SOHLocation;
	volumeStr	 	: String;
	result,
	row, col        : Integer;	
	
begin
	
	app.mousePointer := MousePointer_HourGlass;	
	self.tblAllocDetailQueryRowColChg(tblAllocDetail);	

	row := tblAllocDetail.rows;
	create iFaceSet transient;
		
	while row &gt; tblAllocDetail.fixedRows do
		summAlloc := tblAllocDetail.accessRow(row).itemObject.CM_StockOrderSummaryAlloc;
		sohLocn   := summAlloc.mySOHLocation;
		sharedLock(summAlloc);
		sharedLock(sohLocn);
		col := tblAllocDetail.columns;
		while col &gt; tblAllocDetail.fixedColumns do
			stockOrder := tblAllocDetail.accessColumn(col).itemObject.CM_LogStockOrderLine;
			sharedLock(stockOrder);
			volumeStr := tblAllocDetail.accessCell(row, col).text;
			if not volumeStr.isInteger then 
				volumeStr := self.calculateVolForSplit(row, col);
			endif;

			create iFaceAlloc transient;
			iFaceAlloc.mySummaryAllocation			:= summAlloc;			
			iFaceAlloc.mySOHLocation 				:= sohLocn;
			iFaceAlloc.expectedEditionSOHLocn 		:= sohLocn.edition();									
			iFaceAlloc.myLogStockOrderLine 			:= stockOrder;
			iFaceAlloc.expectedEditionStockOrder 	:= stockOrder.edition();
			iFaceAlloc.volume 						:= volumeStr;						
			iFaceAlloc.mode							:= iFaceAlloc.Mode_SummarySplit;
			iFaceSet.add(iFaceAlloc);								
			col := (col - 1);			
		endwhile;
		row := (row - 1);	
	endwhile;


	while true do
		app.myTrxUA.trxUpdateCMIF_LogStockAlloc(iFaceSet, app.myPassport);
		if app.myPassport.trxCompletedOK then
			// Clear errors/warnings from form and err/warnings window
			self.clearErrorWarnings();
			break;
		else
			result := app.showErrorWarningDialog('Log Voyage Operations', app.myPassport, ErrWarnMode_Update + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   result = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
		endif;
		
		return;
	endwhile;

	/*foreach iFaceAlloc in iFaceSet do
		sharedLock(iFaceAlloc.myLogStockOrderLine);
		self.showAllocVolumeForOrderLine(iFaceAlloc.myLogStockOrderLine);						
	endforeach;*/
	
	//self.showAllocToDetail();	

epilog
	iFaceSet.purge();
	delete iFaceSet;
	app.mousePointer := MousePointer_Default;					
end;</source>
    </JadeMethod>
    <JadeMethod name="summaryAllocShowHide" id="2c123f42-099f-4c28-9bcc-939c423ee7b7">
        <source>summaryAllocShowHide(_show : Boolean);
//--------------------------------------------------------------
//Created: 08 August 2002 By: cnwgd1
//--------------------------------------------------------------
vars	
	str			: String;
	row,
	col,
	backColour 	: Integer;
	allocation 	: CM_StockOrderSummaryAlloc;
begin
	
	if _show then
		self.showAllocToDetail();	
	else
		col := tblAllocDetail.columns;
		row := tblAllocDetail.rows;
		while row &gt; tblAllocDetail.fixedRows do
			while col &gt; tblAllocDetail.fixedColumns do
				str := tblAllocDetail.accessCell(4, col).text;
				if str = '0.000' or str = null or str.Integer = null then
					if tblAllocDetail.accessColumn(col).visible then
						tblAllocDetail.accessColumn(col).visible := false;
					else
						tblAllocDetail.accessColumn(col).visible := true;
					endif;
				endif;
				col := (col - 1);					
			endwhile;
			str := tblAllocDetail.accessCell(row, 4).text;
			if str = '0.000' or str = null or str.Integer = null then
				if tblAllocDetail.accessRow(row).visible then
					tblAllocDetail.accessRow(row).visible := false;
					row := (row - 1);									
				else
					tblAllocDetail.accessRow(row).visible := true;				
					row := (row + 1);													
				endif;
			endif;
			row := (row - 1);													
		endwhile;
	endif;

end;</source>
        <Parameter name="_show" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="sysNotify" id="144ac27d-304a-4c79-a558-11a340bd9cc0">
