    <JadeMethod name="doPrint" id="cdf5f3ef-fa7e-4e50-99a0-f1a94f7e5671">
        <updating/>
        <source>doPrint() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 November 2018	jlgndl1	Initial creation	TFS 42116

*/

vars

	localFromDate : TimeStamp;
	localToDate : TimeStamp;
	msg : String;

begin

	localFromDate.setDate( self.txtDateFrom.getDate() );
	localFromDate.setTime( "00:00:00".Time );
	localToDate.setDate( self.txtDateTo.getDate() );
	localToDate.setTime( "23:59:59.999".Time );
	msg := "(" &amp; localFromDate.asStringJMT &amp; " - " &amp; localToDate.asStringJMT &amp; ")";

	self.doPrintOutTable( self.tblData, self.caption &amp; " " &amp; msg, true, false, false, false );
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doQuery" id="c6451107-7461-41f5-9df4-7e939a381243">
        <updating/>
        <source>doQuery() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 Nov 2018	jlgndl1	Initial creation	TFS 42116
15 Mar 2019 cnwma1	ChangeRequest 43787: PEL1 - SAP Service Monitoring Report - Final Changes
*/

vars

	table : CM_DataTable;
	bank : CM_Bank;
	inv : CM_Invoice;
	localProspects : CM_InvoiceSet;
	localFromDate : TimeStamp;
	localToDate : TimeStamp;
	lowestTS : TimeStamp;
	msg : String;
	rowIdx : Integer;

begin

	table := self.tblData;
	table.rows	:= table.fixedRows;
	
	self.totalJMT := 0;
	self.totalSAP := 0;
	//self.lblTotalJMTvalue.caption := self.totalJMT.roundedTo(2).asStringJMT; //15.03.2019 cnwma1 #43787
	//self.lblTotalSAPvalue.caption := self.totalSAP.roundedTo(2).asStringJMT; //15.03.2019 cnwma1 #43787
	
	self.lblTotalJMTvalue.caption := self.totalJMT.asStringJMT; //15.03.2019 cnwma1 #43787
	self.lblTotalSAPvalue.caption := self.totalSAP.asStringJMT; //15.03.2019 cnwma1 #43787
	
	if not self.txtDateFrom.getDate().isValid then
		msg := app.getErrorString( Date_Enter_Valid );
		self.txtDateFrom.setFocus();
		app.msgBox( msg, app.getErrorString(Error), MsgBox_OK_Only );
		return;
	endif;
	if not self.txtDateTo.getDate().isValid then
		msg := app.getErrorString( Date_Enter_Valid );
		self.txtDateTo.setFocus();
		app.msgBox( msg, app.getErrorString(Error), MsgBox_OK_Only );
		return;
	endif;
	
	localFromDate.setDate( self.txtDateFrom.getDate() );
	localFromDate.setTime( "00:00:00".Time );
	localToDate.setDate( self.txtDateTo.getDate() );
	localToDate.setTime( "23:59:59.999".Time );
	
	if localFromDate &gt; localToDate then
		msg := app.getErrorString( ERR_RESTRIC_TIME_MISMATCH );
		self.txtDateFrom.setFocus();
		app.msgBox( msg, app.getErrorString(Error), MsgBox_OK_Only );
		return;
	endif;
	
	lowestTS := self.myTerminal.localToSystemTime( localFromDate );
	
	create localProspects transient;

	foreach bank in self.myTerminal.companies discreteLock do
		foreach inv in bank.allInvoices reversed do
			if inv.createdTime &lt; lowestTS then
				break;
			endif;
			localProspects.addNoDuplicates( inv, false );
		endforeach;
	endforeach;

	foreach inv in localProspects do
		if not includeObject( inv, localFromDate, localToDate ) then
			continue;
		endif;
		rowIdx := self.tblData.addItemObject(inv, inv.getAttributeStringForDefArray(self.tblData.allTblDataEntRows));
		//tfs 42116 18/12/18 amounts should include tax amount
		self.totalJMT := self.totalJMT + (inv.getTotalAmountPlusPelindoTax);
		self.totalSAP := self.totalSAP + inv.getSapAmount();
	endforeach;

	//self.lblTotalJMTvalue.caption := self.totalJMT.roundedTo(2).asStringJMT; //15.03.2019 cnwma1 #43787
	//self.lblTotalSAPvalue.caption := self.totalSAP.roundedTo(2).asStringJMT; //15.03.2019 cnwma1 #43787
	
	self.lblTotalJMTvalue.caption := self.totalJMT.asStringJMT;  //15.03.2019 cnwma1 #43787
	self.lblTotalSAPvalue.caption := self.totalSAP.asStringJMT;  //15.03.2019 cnwma1 #43787
	
	inheritMethod();

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doResetSearch" id="0af6d1ef-9722-493f-b994-99c31f66a3cb">
        <source>doResetSearch();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 November 2018	jlgndl1	Initial creation	TFS 42116
15 Mar 2019 cnwma1	ChangeRequest 43787: PEL1 - SAP Service Monitoring Report - Final Changes
*/

vars

	today : Date;

begin

	inheritMethod();
	
	today := self.systemToLocalTime(app.actualTimeServer()).Date;
	
	self.txtDateFrom.setDate( today );
	self.txtDateTo.setDate( today );
	
	//self.lblTotalJMTvalue.caption := self.totalJMT.roundedTo(2).asStringJMT; //15.03.2019 cnwma1 #43787
	//self.lblTotalSAPvalue.caption := self.totalSAP.roundedTo(2).asStringJMT; //15.03.2019 cnwma1 #43787
	
	self.lblTotalJMTvalue.caption := self.totalJMT.asStringJMT; //15.03.2019 cnwma1 #43787
	self.lblTotalSAPvalue.caption := self.totalSAP.asStringJMT; //15.03.2019 cnwma1 #43787
	
	self.btnActivity.enabled := false;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doResize" id="c62e9ae0-0c5b-4583-b4ee-d45a223df95c">
        <updating/>
        <source>doResize() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 November 2018	jlgndl1	Initial creation	TFS 42116

*/

vars

begin

	inheritMethod();
	
	self.lblTotalJMT.top := self.splMain.top - 47;
	self.lblTotalJMTvalue.top := self.lblTotalJMT.top;
	self.lblTotalSAP.top := self.lblTotalJMT.top + 21;
	self.lblTotalSAPvalue.top := self.lblTotalSAP.top;
	
	self.lblTotalJMT.left := 10;
	self.lblTotalJMTvalue.left := self.lblTotalJMT.left + self.lblTotalJMT.width + 10;
	
	self.lblTotalSAP.left := self.lblTotalJMT.left;
	self.lblTotalSAPvalue.left := self.lblTotalJMTvalue.left;


epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doShowActivity" id="f05ad2c1-ae22-4d73-ad41-e88fd85da45d">
        <source>doShowActivity();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 November 2018	jlgndl1	Initial creation	TFS 42116

*/

vars

	invoice : CM_Invoice;
	form : CMUI_ActivityHistoryForm;
	coll : CM_ActivityByCreatedTsTypeDict;
	
//	extInter : CM_ActivityHistoryExtInterface;
//	count : Integer;
//	iter : Iterator;

begin

	invoice := self.tblData.accessRow(self.tblData.row).itemObject.CM_Invoice;
	if invoice &lt;&gt; null then
		create coll transient;
		if not invoice.allSAPActivity.isEmpty then
			invoice.allSAPActivity.copy( coll );
	/*	else
			//used for testing
			if process.isNDL then
				iter := CM_ActivityHistoryExtInterface.instances.createIterator;
				while iter.next(extInter) do
					if count &gt;= 100 then
						break;
					endif;
					coll.add( extInter );
					count := count + 1;
				endwhile;
			endif; */
		endif;
		form := app.loadForm( CMUI_ActivityHistoryForm, CMUI_Assistant, false, false, true, self.myTerminal, null ).CMUI_ActivityHistoryForm;
		form.setPreSelected( coll );
		form.show();
	endif;

epilog

	delete coll;

end;</source>
    </JadeMethod>
