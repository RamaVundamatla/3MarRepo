    <JadeMethod name="setupDrawing" id="97793466-6b14-4468-9022-188db23010fd">
        <updating/>
        <source>setupDrawing(_graphicIndex : Integer; theColour : Integer io; theText : String output) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
18 June 2012	cnwer1	Initial creation CCMS MES 1035

*/

vars

begin
	if _graphicIndex &gt; self.allFloodFill.size then
		return;
	endif;
		
	if self.showColour then
		if _graphicIndex &lt;= self.allFillColours.size then
			self.drawFillColor := self.allFillColours[_graphicIndex];
		else
			self.drawFillColor :=  theColour;
		endif;
	else
		self.drawFillColor := Black;
	endif;	
		
	if self.showColour then
		// we are not always run from a scrollable drawing frame
		if self.mySDF &lt;&gt; null and ( theColour = self.mySDF.backColor) then
			theColour := theColour;
		else
			theColour := self.allLineColours[_graphicIndex];
		endif;
	else
		theColour:=Black;
	endif;

		
	if _graphicIndex &lt;= self.allFillStyles.size then
		self.drawFillStyle := self.allFillStyles[_graphicIndex];
		if not self.showColour then
			if  self.drawFillStyle = Frame.DrawFillStyle_Solid  then		
				self.drawFillStyle :=  Frame.DrawFillStyle_Transparent;
			endif;
		endif;

	else
		self.drawFillStyle :=  Frame.DrawFillStyle_Transparent;
	endif;
		
	if _graphicIndex &lt;= self.allDrawWidths.size then
		self.drawWidth := self.allDrawWidths[_graphicIndex];
	else
		self.drawWidth :=  1;
	endif;
	
	
		
	if _graphicIndex &lt;= self.allDrawWidths.size then
		self.drawStyle := self.allLineStyles[_graphicIndex];
	else
		self.drawStyle :=  Frame.DrawStyle_Solid;
	endif;
	
	
	if self.showText then
		theText := self.allTexts[_graphicIndex];
	else
		theText := null;
	endif;
epilog

end;</source>
        <Parameter name="_graphicIndex" type="Integer"/>
        <Parameter name="theColour" type="Integer" usage="io"/>
        <Parameter name="theText" type="String" usage="output"/>
    </JadeMethod>
    <JadeMethod name="windowCreated" id="b2ba3e79-e155-4ead-86d1-6c771f27e89d">
        <updating/>
        <source>windowCreated(cntrl: Control input; persistCntrl: Control) updating;
// ---------------------------------------------------------------------------
// Created:		October 2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	theRoot : CM_Root;
begin
	inheritMethod(cntrl, persistCntrl);
	
	if self.isInPainter then
		return;
	endif;
	
	theRoot := app.myRoot;
	self.backColor := White;
	self.bevelInnerWidth := 1;
	self.bevelOuterWidth := 1;
	self.picCursorMove :=  theRoot.getConfig(PicDrawCursorMove).Binary;
	self.picCursorRotate :=  theRoot.getConfig(PicDrawCursorRotate).Binary;
	self.picCursorResize :=  theRoot.getConfig(PicDrawCursorResize).Binary;
	self.autoRedraw := true;
	self.showColour:=true;
	self.doBtnClearClick(true);
end;</source>
        <Parameter name="cntrl" type="Control" usage="input"/>
        <Parameter name="persistCntrl" type="Control"/>
    </JadeMethod>
