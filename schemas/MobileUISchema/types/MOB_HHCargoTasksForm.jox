    <JadeMethod name="doFilterTableTasks" id="1a81ebdc-0e4c-4b3e-9fe9-1104723bfb95">
        <source>doFilterTableTasks() protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 October 2015	cnwndl1	Initial creation	Par 37000

*/

vars

	filterText : String;
	rowIndex : Integer;
	startRow : Integer;
	endRows : Integer;
	cellText : String;
	isVisible : Boolean;
	hideUnused : Boolean;
	isSetValue : Boolean;
	isCompValue : Boolean;
	hasDate : Boolean;

begin

	filterText := self.txtFilter.text.toUpper.trimBlanks();
	hideUnused := self.btnHide.value;

	if filterText = self.lblFilter.caption.toUpper then
		filterText := null;
	endif;
	
	startRow := self.tblTasks.fixedRows + 1;
	endRows := self.tblTasks.rows;
	
	if endRows &gt;= startRow then
		foreach rowIndex in startRow to endRows do
			if filterText = null then
				isVisible := true;
			else
				cellText := self.tblTasks.accessCell(rowIndex,1).text.toUpper;
				if cellText.pos(filterText,1) &gt; 0 then
					isVisible := true;
				else
					isVisible := false;
				endif;
			endif;
			if hideUnused and isVisible then
				isSetValue := self.tblTasks.getCellText( rowIndex, 2) = '1';
				if not isSetValue then
					isCompValue := self.tblTasks.getCellText( rowIndex, 3) = '1';
					if not isCompValue then
						//11 Nov 2015	NDL	Par 37171
						hasDate := self.tblTasks.getCellText( rowIndex, 4).trimBlanks &lt;&gt; null;
						if not hasDate then
							isVisible := false;
						endif;
					endif;
				endif;
			endif;
			self.tblTasks.accessRow(rowIndex).visible := isVisible;
		endforeach;
	endif;

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doResizeControls" id="922c4e59-b527-4d98-9a35-d55d540cdb90">
        <updating/>
        <source>doResizeControls(_initialSetup: Boolean) updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 February 2015	cnwndl1	Initial creation	Par 35604

*/

vars

	cTop : Real;
	stdWidth : Real;
	cWidth : Real;
	stdHeight : Real;
	cHeight : Real;
	tabIndex : Integer;

begin

	self.setResizeableMarginAndFontSize();
	
	stdWidth := self.clientWidth - self.resizedMargin - self.resizedMargin;
	stdHeight := self.getStdControlHeight;
	
	cTop := self.resizedMargin;
	cWidth := stdWidth - self.getSearchButtonSpace();
	cHeight := stdHeight;
	tabIndex := 4000;
	
	if _initialSetup then
		self.txtCargoId.setAndIncrementTabIndex( tabIndex );
		self.txtCargoId.visible := true;
	endif;
	self.txtCargoId.move( 	self.resizedMargin,
							cTop,
							cWidth,
							cHeight );
						 
	cWidth := self.getStdControlHeight();
	if _initialSetup then
		self.btnPartCargoId.setAndIncrementTabIndex( tabIndex );
		self.btnPartCargoId.visible := true;
	endif;
	self.btnPartCargoId.move(	self.txtCargoId.left + self.txtCargoId.width + self.resizedMargin,
								cTop,
								cWidth,
								cHeight );
								
	cTop := cTop + self.txtCargoId.height + self.resizedMargin;
	
	//01 Oct 2015	NDL	Par 37000
	if _initialSetup then
		self.btnHide.setAndIncrementTabIndex( tabIndex );
		self.btnHide.visible := true;
	endif;
	self.btnHide.move(	self.resizedMargin,
						cTop,
						cWidth,
						cHeight );
	
	cWidth := stdWidth - (self.btnHide.left + self.btnHide.width) - ( self.getSearchButtonSpace() * 2.5 ) - self.resizedMargin;
	if _initialSetup then
		self.txtFilter.setAndIncrementTabIndex( tabIndex );
		self.txtFilter.visible := true;
	endif;
	self.txtFilter.move( 	self.btnHide.left + self.btnHide.width + self.resizedMargin,
							cTop,
							cWidth,
							cHeight );
//	self.txtFilter.lostFocus( self.txtFilter );
	
	//01 Oct 2015	NDL	Par 37000
	cWidth := ( self.getSearchButtonSpace() * 2.5 );
	if _initialSetup then
		self.btnFilter.setAndIncrementTabIndex( tabIndex );
		self.btnFilter.visible := true;
	endif;
	self.btnFilter.move(	self.txtFilter.left + self.txtFilter.width + self.resizedMargin,
								cTop,
								cWidth,
								cHeight );
								
	cTop := cTop + self.txtFilter.height + self.resizedMargin;
	cHeight:= (self.clientHeight - cTop - self.getCMDButtonsHeight() - self.resizedMargin - self.resizedMargin);
	if _initialSetup then
		self.tblTasks.setAndIncrementTabIndex( tabIndex );
		self.tblTasks.visible := true;
	endif;
	self.tblTasks.move(	self.resizedMargin, 
						cTop, 
						stdWidth, 
						cHeight);
						
	if _initialSetup then
		self.setupTable();
	endif;
	
	if self.tblTasks.rows &gt; 1 then
		if self.tblTasks.accessRow(1).height &lt; self.tblTasks.accessRow(2).height then
			self.tblTasks.accessRow(1).height := self.tblTasks.accessRow(1).height;
		endif;
	endif;
	
	self.tblTasks.cnAdjustColumnWidths();
	
	
	inheritMethod(_initialSetup);

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_initialSetup" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doSave" id="41da27de-ddf9-4cdf-a2fd-c436e179f9a0">
        <updating/>
        <source>doSave() : Boolean updating, protected;
// ---------------------------------------------------------------------------
// Created:	19 January 2009 By Graeme Black cnwgb1
// Purpose:	Call the agent to save the information in the tblTasks
//			PNL CCMS 1658 PAR 18787
// ---------------------------------------------------------------------------
vars

begin
	
	if self.myTrackedItem = null then
		self.msgBox(app.getErrorString(NO_Container_selected), app.getErrorString(Error), MsgBox_OK_Only, false);
		return false;
	endif;
	
	return self.getSessionAgent().updateTasks( self.tblTasks, self.myTrackedItem );
	
epilog
end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="handleBtnOne" id="9ef5e712-7800-4e84-8941-aec52c82dfa1">
        <updating/>
        <source>handleBtnOne() updating, protected;
// ---------------------------------------------------------------------------
// Created:	31 December 2008 By Graeme Black cnwgb1
// Purpose:	Handle the Save/Edit button on the form 
//			PNL CCMS 1658 PAR 18787
// ---------------------------------------------------------------------------
vars
begin
	if self.btnOne.caption = app.getErrorString(Edit) then
		self.setForEdit();
	elseif self.btnOne.caption = app.getErrorString(Save) then
		if somethingChanged then
			if self.doSave() then
				self.displayTasks();
			endif;
		endif;
	endif;

epilog
end;</source>
        <access>protected</access>
    </JadeMethod>
