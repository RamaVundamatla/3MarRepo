    <JadeMethod name="replaceInvoiceLineTypes" id="0d193e41-acd0-41d9-b0d5-41e3494030a1">
        <source>replaceInvoiceLineTypes(_oldILD : CM_InvoiceLineDesc; _newILD : CM_InvoiceLineDesc) : Integer;
// 32311
vars
	count	: Integer;
	commodMap		: CM_CommodityMap;
begin
	foreach commodMap in self.commoditiesMap do
		count := count + commodMap.replaceInvoiceLineTypes(_oldILD, _newILD);
	endforeach;
	return count;
end;
</source>
        <Parameter name="_oldILD" type="CM_InvoiceLineDesc"/>
        <Parameter name="_newILD" type="CM_InvoiceLineDesc"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
