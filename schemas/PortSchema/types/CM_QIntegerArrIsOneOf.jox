<Class name="CM_QIntegerArrIsOneOf" id="6d4d3bf7-ab8c-43ea-8ccc-d528287b42e8">
    <superclass name="CM_QIntegerIsOneOf"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="query"/>
    <JadeMethod name="doMatch" id="bb7da70d-4cf5-4d24-a57a-8aa8697a56cf">
        <source>doMatch(_value: Any): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 October 2023	navmv20	Bug 60677: FR | EUP 54086 - Invoicing Maintenance enhancements - Selector Query - Invoice mode

*/

vars
	intValue : Integer;
begin
	if _value = null or _value.IntegerArray.isEmpty() then
		return false;
	endif;
	
	foreach intValue in _value.IntegerArray do
		if  self.allSelectionValues.includes(intValue) then
			return true;
		endif;	
	endforeach;
	
	return false;

epilog

end;</source>
        <Parameter name="_value" type="Any"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
