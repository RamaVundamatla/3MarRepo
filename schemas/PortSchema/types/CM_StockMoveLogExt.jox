<Class name="CM_StockMoveLogExt" id="09f2b533-284a-41c8-b1df-fecaa56129f8">
    <superclass name="CM_StockMovementExtension"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="stkMoveExt"/>
    <ExplicitInverseRef name="allSEDStockMoves" id="6b67386d-802d-4314-a6ae-50204aa0e8df">
        <kind>parent</kind>
        <transientToPersistentAllowed/>
        <updateMode>automatic</updateMode>
        <type name="CM_SEDStockMovesBySEDMeanDict"/>
        <access>readonly</access>
        <Inverse name="CM_SEDStockMovement::myStockMovementExt"/>
    </ExplicitInverseRef>
    <JadeMethod name="addTrackedItem" id="2c4ab30a-4c48-4362-b085-ab200a4f8a05">
        <updating/>
        <source>addTrackedItem(_ti: CM_TrackedItem; _quantity: Integer; _weight : Decimal; _volume : Real): Boolean updating;
// ---------------------------------------------------------------------------
// Created:     05 May 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	sedStkMove	: CM_SEDStockMovement;
	sedMean		: Real;
	tmpLog		: CM_Log;
	
begin

	if (not _ti.isKindOf(CM_Log)) then
		app.raiseUnexpectedProgramError(class.name, method.name, 
						'Attempt to add non-log ti (' &amp;
						_ti.String &amp; ') to log stock movement (' &amp; 
						self.String &amp; ')');
		return false;
	endif;

	tmpLog := _ti.CM_Log;
	// Create the sub-analysis records for SED here
	
	sedMean := tmpLog.sedMean;
	sedStkMove := self.allSEDStockMoves[sedMean];
	if sedStkMove = null then
		create sedStkMove persistent;
		sedStkMove.init(sedMean, self);
	endif;
	
	sedStkMove.addTrackedItem(tmpLog, _weight, _volume);

	return true;	
end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_quantity" type="Integer"/>
        <Parameter name="_weight" type="Decimal"/>
        <Parameter name="_volume" type="Real"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
