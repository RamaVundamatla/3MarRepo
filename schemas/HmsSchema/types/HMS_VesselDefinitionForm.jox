        <source>tblPrefBerth_queryRowColChg(table: Table input; newSheet: Integer; newRow: Integer; newCol: Integer):Boolean updating;
//--------------------------------------------------
// Created:	08 April 2005 By: cnwgd1
//--------------------------------------------------
vars
	bow : Decimal[9,2];
begin
	if table.column = 3 then
		bow := table.accessCell(table.row, 3).cellControl.TextBox.text.Integer;	
		table.accessedCell.text := bow.String;
		self.setMeterMarks(bow, table.row);
	endif;
	return true;
end;</source>
