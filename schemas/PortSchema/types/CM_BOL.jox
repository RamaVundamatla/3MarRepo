    <JadeMethod name="getMyBank" id="b5ccaa41-3c57-46ad-b75d-2bb2a0640714">
        <source>getMyBank():CM_Bank;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 November 2019	jlgndl1	Initial creation	TFS 47100

*/

vars

	voyage : CM_Voyage;
	bank : CM_Bank;

begin

	voyage := getMyVoyage();
	if voyage &lt;&gt; null then
		bank := voyage.myDischargeCompany;
	endif;
	
	if bank = null then
		if self.myTerminal &lt;&gt; null then
			bank := self.myTerminal.getDefaultCompanyBank();
		endif;
	endif;

	return bank;
	
epilog

end;</source>
        <ReturnType type="CM_Bank"/>
    </JadeMethod>
