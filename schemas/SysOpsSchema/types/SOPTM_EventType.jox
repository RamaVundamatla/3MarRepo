    <JadeMethod name="doCmbCategoryLostFocus" id="ff270197-9bad-4636-981f-fb0d3b650882">
        <source>doCmbCategoryLostFocus();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
29 October 2009	cnwndl1	Initial creation	Par 21519
23/07/2019 	JLGNS1	ChangeRequest 45575: ASPA - Train Events
29/07/2022	jlizm1	TFS 54165 EDI Voyage Events

*/

vars

	theForm	 : SOP_TableMaintForm;
	eventCategory : Integer;
begin

	theForm := self.myForm; 
	if theForm.cmbCategory.listIndex &gt; 0 then
		eventCategory:=theForm.cmbCategory.itemData[theForm.cmbCategory.listIndex];
	endif;
	
	
	if eventCategory = CM_EventType.WARNING_EVENT then
		setupWarningMessages();
		theForm.shtMultiSelect1.enabled := true;
	else
		theForm.mulSelect1.enabled := false;
		theForm.shtMultiSelect1.enabled := false;
		theForm.mulSelect1.setSelected(null);
	endif;
	
	if eventCategory &lt;&gt; null then
		theForm.myAssistant.comboBoxEventTypeAction(theForm.comboBox1,eventCategory,0);
	endif;
	
	if theForm.cmbCategory.listIndex &lt; 1 then
		theForm.tblInput1.setValueByName(ETRow_Category, null);
	else
		theForm.tblInput1.setValueByName(ETRow_Category, theForm.cmbCategory.text);
	endif;
	
	//epr par 36967 25/9/15
	if eventCategory = CM_EventType.VOYAGE_EVENT then
		theForm.tblInput1.showRowByName(ETRow_NumDecimalPlaces,false);
		theForm.tblInput1.setValueByName(ETRow_NumDecimalPlaces,null); 
		theForm.tblInput1.showRowByName(ETRow_IsFromToDateTimeRequired,false);	//nds TFS 3047 13/01/17
		theForm.tblInput1.setValueByName(ETRow_IsFromToDateTimeRequired,null); 	//nds TFS 3047 13/01/17
		theForm.tblInput1.showRowByName(ETRow_UnitDescription,false);			//nds TFS 3047 13/01/17
		theForm.tblInput1.setValueByName(ETRow_UnitDescription,null); 			//nds TFS 3047 13/01/17
		theForm.tblInput1.showRowByName(ETRow_MyVoyageDelay,false);	//24 Aug 2018	NDL	TFS 40309
		theForm.tblInput1.showRowByName(ETRow_ShowWeight, false);				// TFS 54165
		theForm.tblInput1.setValueByName(ETRow_ShowWeight,null);				// TFS 54165
		theForm.tblInput1.hideRowByName(ETRow_WeightMeasureType, false);		// TFS 54165
		theForm.tblInput1.setValueByName(ETRow_WeightMeasureType, null);		// TFS 54165
	elseif eventCategory = CM_EventType.TRAIN_EVENT then
		theForm.tblInput1.showRowByName(ETRow_NumDecimalPlaces,false);			//ChangeRequest 45575
		theForm.tblInput1.setValueByName(ETRow_NumDecimalPlaces,null); 			//ChangeRequest 45575
		theForm.tblInput1.showRowByName(ETRow_IsFromToDateTimeRequired,false);	//ChangeRequest 45575
		theForm.tblInput1.setValueByName(ETRow_IsFromToDateTimeRequired,null); 	//ChangeRequest 45575
		theForm.tblInput1.showRowByName(ETRow_UnitDescription,false);			//ChangeRequest 45575
		theForm.tblInput1.setValueByName(ETRow_UnitDescription,null); 			//ChangeRequest 45575
		theForm.tblInput1.hideRowByName(ETRow_ShowWeight,false);				// TFS 54165
		theForm.tblInput1.setValueByName(ETRow_ShowWeight,null);				// TFS 54165
		theForm.tblInput1.hideRowByName(ETRow_WeightMeasureType,false);			// TFS 54165
		theForm.tblInput1.setValueByName(ETRow_WeightMeasureType, null);		// TFS 54165
	else
		theForm.tblInput1.hideRowByName(ETRow_NumDecimalPlaces,false);
		theForm.tblInput1.hideRowByName(ETRow_IsFromToDateTimeRequired,false);	//nds TFS 3047 13/01/17
		theForm.tblInput1.hideRowByName(ETRow_UnitDescription,false);			//nds TFS 3047 13/01/17
		theForm.tblInput1.hideRowByName(ETRow_ShowWeight,false);				// TFS 54165
		theForm.tblInput1.setValueByName(ETRow_ShowWeight,null);				// TFS 54165
		theForm.tblInput1.hideRowByName(ETRow_WeightMeasureType,false);			// TFS 54165
		theForm.tblInput1.setValueByName(ETRow_WeightMeasureType, null);		// TFS 54165
		//24 Aug 2018	NDL	TFS 40309
		theForm.tblInput1.hideRowByName(ETRow_MyVoyageDelay,false);
		theForm.cmbVoyageDelay.listIndex := -1;
		theForm.tblInput1.setValueByName( ETRow_MyVoyageDelay, null );
		
	endif;
	
	self.resetCategory( eventCategory );
	
	theForm.tblInput1.cnEcResizeContents();
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doComboBox1LostFocus" id="51246860-1a03-4237-b7fa-96594cc884d5">
        <source>doComboBox1LostFocus();
/*

Date		Who		Reason
12 December 2014	cnwer1	Initial creation PAR

*/

vars
	eventType : Integer;
begin
	
	if self.myForm.comboBox1.listIndex &gt; 0 then
		eventType:=self.myForm.comboBox1.listData;
	endif;
	
	if eventType = 0 then
		return;
	endif;
	
	self.myForm.tblInput1.setValueByName(ETRow_Name,self.myForm.comboBox1.text) ;
	self.myForm.tblInput1.setValueByName(ETRow_Description,self.myForm.myAssistant.getEventTypeActionDesc(eventType));
epilog

end;</source>
    </JadeMethod>
