    <JadeMethod name="clearReportingCollection" id="6de411fb-aabd-4592-b2da-05f0303ce6cf">
        <source>clearReportingCollection();
//----------------------------------------------------------------------
// Created by 	cnwsh3
// Date 		14 April 2010
//
// Implemented version: JMT 7.8.2
// Date  		User  		Change
// SFW CCMS 1115 PAR23680   cnwsh3 - Invoice JRW Interface
//----------------------------------------------------------------------
vars

begin
	self.allInvoices.clear();
	self.allInvoiceLines.clear();
	self.allCashReceiptReporting.clear();
	self.setCMIFInvSumF1Lines(); //10 Aug 2017	NDL	TFS 5679

epilog
end;</source>
    </JadeMethod>
    <JadeMethod name="copyReportItemsToCollection" id="8cc1db44-0490-4542-8fb6-12528a492cb0">
        <source>copyReportItemsToCollection(_collection: Collection; _collectionItem : Integer);
//----------------------------------------------------------------------
// Created by 	cnwsh3
// Date 		14 April 2010
//
// Implemented version: JMT 7.8.2
// Date  		User  		Change
// SFW CCMS 1115 PAR23680   cnwsh3 - Invoice JRW Interface
// 
// Parameters: 	_collection - the collecton of objects we're reporting on
//				
//				_collectionItem - a way of identifying which collection we're going to be using.  This is arbitrary and 
//								  and is dependent on what collections exist on the JRWTransient.  There are some JRWTransients
//								  that have more than one collection that can be used for reporting.
//----------------------------------------------------------------------
//02 Apr 2019	NDL	TFS 43417
vars

	any : Any;
	

begin

	if _collection &lt;&gt; null and not _collection.isEmpty then
		any := _collection.first;
	endif;
	
	if any &lt;&gt; null and any.isKindOf( CM_Invoice ) then
		_collection.copy(self.allInvoices);
	elseif any &lt;&gt; null and any.isKindOf( CM_InvoiceLine ) then
		_collection.copy(self.allInvoiceLines);
	endif;
	self.setCMIFInvSumF1Lines(); //10 Aug 2017	NDL	TFS 5679

epilog
end;</source>
        <Parameter name="_collection" type="Collection"/>
        <Parameter name="_collectionItem" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="delete" id="25727b1c-faca-4193-bc35-81dcb3e0acb7">
        <updating/>
        <source>delete() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 August 2017	jlgndl1	Initial creation	TFS 5679

*/

vars

begin

	self.clearReportingCollection();

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="getDateEndLocalTZ" id="d8695192-86ca-446d-9552-9694e0c3889a">
        <source>getDateEndLocalTZ(): Date;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 May 2016	cnwns1	Initial creation
// 30 May 2016	cnwns1	TFS 488 - Multi Timezone Support
*/

vars
	endTS : TimeStamp;
begin
	endTS.cnEcSetDateAndTime(self.dateEnd,TimeEndOfDay);
	return self.systemToLocalTime(endTS).date();
epilog

end;</source>
        <ReturnType type="Date"/>
    </JadeMethod>
    <JadeMethod name="getDateStartLocalTZ" id="b3e05468-951e-4081-a5b8-ab853312441e">
        <source>getDateStartLocalTZ() : Date;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 May 2016	cnwns1	Initial creation
// 30 May 2016	cnwns1	TFS 488 - Multi Timezone Support
*/

vars
	startTS : TimeStamp;
begin
	startTS.cnEcSetDateAndTime(self.dateStart,TimeStartOfDay);
	return self.systemToLocalTime(startTS).date();
epilog

end;</source>
        <ReturnType type="Date"/>
    </JadeMethod>
    <JadeMethod name="noOutputReturned" id="56eb8887-8ee4-477c-bfbb-8e027a4be28d">
        <source>noOutputReturned(): Boolean;
//----------------------------------------------------------------------
// Created by 	cnwsh3
// Date 		13 April 2010
//
// Implemented version: JMT 7.8.2
// Date  		User  		Change
// SFW CCMS 1115 PAR23680   cnwsh3 - Invoice JRW Interface
//----------------------------------------------------------------------
vars

begin
	return (self.allInvoices.isEmpty() and
	   self.allInvoiceLines.isEmpty() and
	   self.allCashReceiptReporting.isEmpty());

epilog
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setCMIFInvSumF1Lines" id="f5de6ee9-f841-4be7-b714-49c3045250a0">
        <source>setCMIFInvSumF1Lines();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 August 2017	jlgndl1	Initial creation		TFS 5799
23 Jan    2020	jlgma1	Bug 48352: ADP - FW: Get_invoice_date
*/

vars
	inv        : CM_Invoice;
	ti         : CM_TrackedItem;
	oldTi      : CM_TrackedItem;
	invalid    : Boolean;
	cmif       : CMIF_InvoiceSummaryLineF1;
	dynaDict   : DynaDictionary;
	invLineSet : CM_InvoiceLineSet;
	obj        : Object;
	invLine    : CM_InvoiceLine;

begin
		
	if not self.allCMIFInvSumF1Lines.isEmpty then
		self.allCMIFInvSumF1Lines.purge();
	endif;
	
	if not app.myRoot.isClientAAT then    //23.01.2020 cnwma1 #48352
		return;
	endif;
	
	on Exception do app.handleDeletedObject(exception, inv, invalid );
	on Exception do app.handleDeletedObject(exception, ti, invalid );
	
	create dynaDict transient;
	dynaDict.setMembership(CM_InvoiceLine);
	dynaDict.addMemberKey( CM_InvoiceLine::trackedItem.name, true, true );
	dynaDict.endKeys( true );
	
	foreach inv in self.allInvoices do
		inv.invoiceLines.copy( dynaDict );
	endforeach;
	
	create invLineSet transient;
	
	foreach obj in dynaDict do
		invLine := obj.CM_InvoiceLine;
		ti := invLine.getTrackedItem;
		if ti = null then
			continue;
		endif;
		if invLine.voided then	//23 Aug 2017
			continue;
		endif;
		if ti &lt;&gt; oldTi and not invLineSet.isEmpty then
			create cmif transient;
			cmif.setFromInvoice( oldTi, invLineSet ); 
			self.allCMIFInvSumF1Lines.add( cmif );
			invLineSet.clear();
		endif;
		invLineSet.add( invLine );
		oldTi := ti;
	endforeach;
	
	//do the last one
	if not invLineSet.isEmpty and oldTi &lt;&gt; null then
		create cmif transient;
		cmif.setFromInvoice( oldTi, invLineSet ); 
		self.allCMIFInvSumF1Lines.add( cmif );
	endif;
		
epilog

	delete dynaDict;
	delete invLineSet;
	
end;</source>
    </JadeMethod>
</Class>
