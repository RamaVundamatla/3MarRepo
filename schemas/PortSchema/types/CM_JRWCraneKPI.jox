    <JadeMethod name="copyReportItemsToCollection" id="6434fdb1-6bf3-4614-8b5a-f4439cf30e94">
        <source>copyReportItemsToCollection(_collection: Collection; _collectionItem : Integer);
//----------------------------------------------------------------------
// Created by 	cnwjre1	
// Date 		Dec 2010 CCMS 1134 KPI reporting
vars

begin
	_collection.copy(self.allVoyageKPICraneShifts);

epilog
end;</source>
        <Parameter name="_collection" type="Collection"/>
        <Parameter name="_collectionItem" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getDateFromLocalTZ" id="5036c0d5-9004-474f-a189-536299bccf58">
        <source>getDateFromLocalTZ() : Date;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 June 2016	cnwns1	Initial creation
// 07 June 2016	cnwns1	TFS 488 - Multi Timezone Support
*/
vars

	sysTS : TimeStamp;
begin
	sysTS.cnEcSetDateAndTime(dateFrom,timeFrom);
	return self.systemToLocalTime(sysTS).date();
epilog

end;</source>
        <ReturnType type="Date"/>
    </JadeMethod>
