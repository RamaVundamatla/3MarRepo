    <JadeMethod name="pxyCreateUpdateProxy" id="d7057d80-f416-41bb-b191-3311b506a5f2">
        <source>pxyCreateUpdateProxy(): SelfType;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 December 2022	jlier1	Initial creation

*/

vars
	proxy 		: CM_HSCodeHeading;
	completedOK	: Boolean;
	
begin

	proxy := inheritMethod();
	
	proxy.myHSChapter := self.myHSChapter;

	completedOK := true;
	return proxy;
	
epilog

	if not completedOK then
		delete proxy;
	endif;


end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
