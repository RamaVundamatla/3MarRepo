<Class name="CM_Object">
    <JadeMethod name="getProxyPropertiesToIgnore" id="fecf78fb-345c-43ad-9bbb-f463e7785bb3">
        <source>getProxyPropertiesToIgnore(_ignoreList : StringArray input);
/*

Purpose:			Get the list of property names for the receiver that do not get copied when the
					object is proxied
					

Parameters:			List to be ignored

Return Value:		Updated list with additional property names

Date		Who		Reason
14 Apr 2011	cnwkpd1	PAR #27401 - Fix up proxy framework

*/

vars

begin
	_ignoreList.add(CM_Object::createdTime.name);
	_ignoreList.add(CM_Object::oidAsBin.name);
	_ignoreList.add(CM_Object::oidAsHex.name);
	_ignoreList.add("myRoot");
	
	
epilog

end;</source>
        <Parameter name="_ignoreList" type="StringArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="matchesProxy" id="2ec55a55-3a9a-4a83-88b5-7f0dbdcae2f4">
        <source>matchesProxy(_proxy : SelfType; _proxyRefsCodedFor, _badProperties : StringArray input) : Boolean;
/*

Purpose:			Test whether the properties on the passed in proxy match the properties
					on the receiver

Parameters:			Proxy object to test, array to be populated with non-matching property names

Return Value:		True if they match, false if not (and _badProperties populated with mismatches)

Date		Who		Reason
14 Apr 2011	cnwkpd1	PAR #27401 - Fix up proxy framework
28/04/2011	cnmwh5	Add checking references against those that are coded for.
*/

vars
	prop			: Property;
	value			: Any;
	properties		: PropertyColl;
	ignoreList		: StringArray;
	propName		: String;
	returnVal		: Boolean;
	
begin
	properties := self.class.allProperties();
	create ignoreList transient;
	self.getProxyPropertiesToIgnore(ignoreList);
	
	returnVal := true;
	
	foreach prop in properties do
		propName := prop.name;
		
		if propName.startsWith("_") then
			continue;
		endif;
		
		if prop.virtual then
			continue;
		endif;
		
		if prop.getType.inheritsFrom(Collection) then
			continue;
		endif;
		
		if ignoreList.includes(propName) then
			continue;
		endif;
		
		// Test the property here
		if prop.isKindOf(Reference) and not _proxyRefsCodedFor.includes(propName) then	// 28/04/2011 cnmwh5
			_badProperties.add(propName &amp; " (Code)");
			returnVal := false;
		elseif self.getPropertyValue(propName) &lt;&gt; _proxy.getPropertyValue(propName) then
			_badProperties.add(propName);
			returnVal := false;
		endif;
	endforeach;
				
	return returnVal;
	
	
epilog
	delete ignoreList;
	delete properties;
	
end;</source>
        <Parameter name="_proxy" type="SelfType"/>
        <Parameter name="_proxyRefsCodedFor" type="StringArray" usage="input"/>
        <Parameter name="_badProperties" type="StringArray" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
