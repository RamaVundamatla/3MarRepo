					_reason:		Integer		Reason for adding the method to the report either 1 (Missing) or 2 (Different)

Return Value:		

Date		Who		Reason
08 December 2021	navpw1	Initial creation TFS: 52202

*/

vars
	devSchema 			: DEV_Schema;
	devClass 			: DEV_Class;
	newMethod 			: DEV_Method;
	modifiedTimeStamp 	: LSModifiedTimeStamp;
	
begin
	//Get Schema
	devSchema 	:= self.allSchemas.getAtKey(_schemaName);
	
	devClass 	:= devSchema.allClasses.getAtKey(_method.myClass.name);
	
	//Create timestamp object
	create modifiedTimeStamp transient;
	modifiedTimeStamp.setProperties(_method.modifiedBy, _method.modifiedVersion, _method.patchVersion, _method.modifiedTimeStamp);
	
	//else create the global constant category
	beginTransaction;
		newMethod := create DEV_Method(_method.name, _method.desc, _method.methodSource, _reason, devClass) persistent;
		newMethod.update(_method.methodSignature, _method.miscData, _method.desc, _method.methodSource, _method.documentationTextData);
		newMethod.setLastModifiedTimeStamp(modifiedTimeStamp);
	commitTransaction;
	
epilog
	delete modifiedTimeStamp;

end;</source>
