    <JadeMethod name="getMyBank" id="2f8b5723-6b04-40c3-a838-8495fac69714">
        <source>getMyBank() : CM_Bank;
/*

Purpose:			TFS 39237

Parameters:			

Return Value:		

Date		Who		Reason
26 June 2018	jlgab1	Initial creation
18 Oct 2024		navnk30	JIRA 19927: EUP - Error 1081 When using Rail Lander

*/

vars
	invLine : CM_InvoiceLine;
	bank : CM_Bank;
begin

	invLine := self.allInvoiceLines.first;
	
	if invLine &lt;&gt; null then
		return invLine.bank;
	endif;

	// ### TFS BUG 58790 23JUN2023 NAVAB1
	if self.myWorkOrderDetail &lt;&gt; null then
		bank := self.myWorkOrderDetail.getMyBank();
	endif;
	
	if bank = null then // ### TFS BUG 58790 23JUN2023 NAVAB1
		if self.myWorkOrder &lt;&gt; null then // TFS 39236
			bank :=  self.myWorkOrder.getMyBank();// TFS 39236
			if bank &lt;&gt; null then
				return bank;
			endif;
		endif;
	endif;
	
	if self.myTerminal &lt;&gt; null then			// 18.10.2024 navnk30 JIRA #19927
		return self.myTerminal.getDefaultCompanyBank(); // TFS 39236
	elseif self.myWorkOrder &lt;&gt; null and self.myWorkOrder.myTerminal &lt;&gt; null then
		return self.myWorkOrder.myTerminal.getDefaultCompanyBank();
	else
		return null;
	endif;
epilog

end;</source>
        <ReturnType type="CM_Bank"/>
    </JadeMethod>
    <JadeMethod name="getMyDebtor" id="fde83e12-825a-4783-8e0f-254963dbf8c1">
        <source>getMyDebtor() : CM_Debtor;
/*

Purpose:		TFS 39237	

Parameters:			

Return Value:		

Date		Who		Reason
26 June 2018	jlgab1	Initial creation

*/

vars
	workorder : CM_WorkOrder;
	debtor : CM_Debtor;
begin
	// ### TFS BUG 58790 23JUN2023 NAVAB1
	if self.myWorkOrderDetail &lt;&gt; null then
		debtor := self.myWorkOrderDetail.getMyDebtor();
	endif;
	
	if debtor = null then // ### TFS BUG 58790 23JUN2023 NAVAB1
		workorder := self.myWorkOrder;
		
		if workorder = null then
			return null;
		endif;
		
		debtor := workorder.getMyDebtor();
	endif;
	
	return debtor;
epilog

end;</source>
        <ReturnType type="CM_Debtor"/>
    </JadeMethod>
