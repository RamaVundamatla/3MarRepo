        <updating/>
        <source>utlUpdateROROPointRemove(_thePoint : Point; _theGraphic : CM_LayoutGraphic input;   _passport : CM_Passport input) updating;
/*
Purpose:			
Date				Who			Reason
AUGUST 2011		CNWAB1		Initial creation
*/

vars
begin

	self.initialiseActivity();

	if _theGraphic = null then
		return;
