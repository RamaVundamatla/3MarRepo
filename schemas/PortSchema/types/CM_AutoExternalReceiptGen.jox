    </JadeMethod>
    <JadeMethod name="getAuditText" id="a1b143cf-a607-41b4-a511-b4a4d9bd31dd">
        <source>getAuditText(): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 December 2022	navkc1	Initial creation TFS CR 55300 TASK 55524

*/

vars
	audTxt, 
	tmpStr			: String;
	size,
	year,
	seq				: Integer;
begin
	audTxt[10000] 	:= '*';
	
	audTxt := inheritMethod();
	
	size := self.nextSequenceNumArray.size();
	
	if size = 0 then
		return audTxt;
	endif;
	
	while year &lt; size do
		year += 1;
		
		seq := self.nextSequenceNumArray[year].Integer;
		
		if seq = 0 then
			continue;
		endif;
		
		tmpStr := (2000 + year).String &amp; "-" &amp; seq.String &amp; Cr &amp; tmpStr;
	endwhile;
	
	audTxt := audTxt &amp; AuditStringSeparator &amp; CM_AutoExternalReceiptGen::nextSequenceNum.name &amp; AuditStringSeparator &amp; tmpStr.length().String &amp; AuditStringSeparator &amp; tmpStr;
	
	return audTxt;
	
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getNextSequenceNumArray" id="658fa79a-e9b9-400d-bf04-b74ab8cd193b">
        <source>getNextSequenceNumArray(theYear: Integer): Real;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 November 2018	jlgma1	Bug 41688: PEL1 - Estimation ID sequence

*/

vars

begin
	if self.nextSequenceNumArray.size &lt; theYear then 
		return 0;
	endif;
	return self.nextSequenceNumArray[ theYear ];

epilog

end;</source>
        <Parameter name="theYear" type="Integer"/>
        <ReturnType type="Real"/>
    </JadeMethod>
