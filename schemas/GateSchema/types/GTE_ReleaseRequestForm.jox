    <JadeMethod name="canDoEdit" id="181dd853-7eae-4486-9eab-a66e5118205c">
        <source>canDoEdit(): Boolean;
// ---------------------------------------------------------------------------
// Created:     19 April 2001 by cnwrs2
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 07/02/2012	cnwcs5		par 28756
// ---------------------------------------------------------------------------
vars
	currentStatus	: Integer;
	obj				: Object;
	br 				: CM_BulkRelease;
begin
	obj := self.myCurrentObject;	
	
	if obj.isKindOf(CM_BulkRelease) then
		br := obj.CM_BulkRelease;
	elseif obj.isKindOf(CM_TrackedItem) then
		br := obj.CM_TrackedItem.allBulkReleasesAssigned.first;
	elseif CM_ReserveDetail.hasInstance(obj) then //PAR 10935
		br := obj.CM_ReserveDetail.myReserveHeader;
	else
		return false; //PAR 10935
	endif;
	
	if br = null then
		return false;
	endif;
	
	currentStatus := br.status;
	
	if (currentStatus = BR_COMPLETE and (not self.canMaintainAll)) then
// TFS 2198	   	app.msgBox(app.getErrorString1(NoPermission, 'update a completed bulk release'), 'Error', MsgBox_OK_Only);
		return false;
	elseif (currentStatus = BR_PENDING and (not self.canMaintainPending)) then
// TFS 2198	   	app.msgBox(app.getErrorString1(NoPermission, 'update a pending bulk release'), 'Error', MsgBox_OK_Only);
		return false;
	elseif (currentStatus = BR_ACTIVE and (not self.canMaintainAll)) then
// TFS 2198	   	app.msgBox(app.getErrorString1(NoPermission, 'update an active bulk release'), 'Error', MsgBox_OK_Only);
		return false;
	elseif (currentStatus = BR_ARCHIVE and (not self.canMaintainAll)) then
// TFS 2198	   	app.msgBox(app.getErrorString1(NoPermission, 'update an archive bulk release'), 'Error', MsgBox_OK_Only);
		return false;		
	endif;
	
	//navra1 - MTN-35875- 5th Sep 2025-3 - start	
	if br &lt;&gt; null and br.CM_BulkRelease &lt;&gt; null and br.remarksAdditional1.startsWith("YARA") and not app.myCurrentUserCan(self.myTerminal, PmAdmEditAGGatewayRRMaint) then
		return false;
	endif;
	//navra1 - MTN-35875- 5th Sep 2025-3 - end
	
	return true;
	
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="clearCmbReport" id="c9aa733a-9eea-44aa-9e71-693119402044">
        <source>clearCmbReport() protected;

/*

Purpose:			Clear cmbReport control

Parameters:			None

Return Value:		None


Date		Who		Reason
16 Mar 2010	consw1	PAR #22886 - Leaking report transients

*/

vars
	cmb		: CMUI_ComboBox;
	idx		: Integer;
	max		: Integer;
	
begin
	cmb := self.cmbReport;
	max := cmb.listCount;
	
	// Delete associated report transients
	foreach idx in 1 to max do
		delete cmb.itemObject[idx];
	endforeach;
	
	cmb.sorted := false;
	cmb.clear();

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
