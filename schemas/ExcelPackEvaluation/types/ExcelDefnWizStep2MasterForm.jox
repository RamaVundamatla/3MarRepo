    <JadeMethod name="loadForm" id="646fe659-8456-48e6-aa6c-e6cf41432d8f">
        <updating/>
        <source>loadForm() updating;

/******************************************
 *	
 *	Before this form is shown, the form assumes that myExcelWorkbookDefinitionDA is set to the instance of ExcelWorkbookDefinitionDA 
 *	that currently controls the workbook being edited. It also assumes self.assocName and self.assocType are set to the associated name and type 
 *	that is currently being edited.
 *	
 *****************************************/

vars
	
	
begin
	lblStep2.fontBold := true;
	lblStep2.left := 10;
	
	self.caption := "Excel Workbook Definition Wizard";
	lblWizHeader.caption:= self.assocType &amp; " - " &amp; self.assocName;
	
	self.loadDetails();
	
	self.centreWindow();
	self.top := self.top + 19;
end;</source>
    </JadeMethod>
    <JadeMethod name="trySaveData" id="eb86eddd-917d-43ad-a513-65eaa6cdb926">
        <updating/>
        <source>trySaveData() : Boolean updating, protected;

vars
	
	
begin
	return true;
end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
