    <JadeMethod name="matches" id="36d95733-2d84-4ddc-b5fb-db7f3c6fc42e">
        <source>matches(_voyageCode : String; _bol : String; _customsEntryNumber : String; _externalId : String; _cargoId : String) : Boolean;

/*

Purpose:			33256 Used in cash transaction enquiry when filtering by bol, customs entry number etc
					Also used in cash reporting for filtering.

Parameters:			

Return Value:		


Date		Who		Reason
08 January 2014	cnwjre1	Initial creation

*/

vars
	ti	: CM_TrackedItem;
	localTiArray : CM_TIArray;		//30 Mar 2016	NDL	TFS 1726
begin
	// all null parameters means no matching required so it passes
	if _voyageCode = null and
	   _bol = null and
	   _customsEntryNumber = null and
	   _externalId = null and
	   _cargoId = null then
		return true;
	endif;

	if _voyageCode &lt;&gt; null then
		// from 33983 extend voyage/bol checking
		if _bol = null then
			if _voyageCode = self.cashId1 then
				return true;
			else
				if _voyageCode = self.cashId1 and
				   _bol = self.cashId2 then
					return true;
				endif;
			endif;
		endif;
	endif;
	if _bol &lt;&gt; null then
		if _bol = self.cashId2 then
			return true;
		endif;
	endif;
	if _customsEntryNumber &lt;&gt; null then
		if _customsEntryNumber = self.cashId3 then
			return true;
		endif;
	endif;
	if _externalId &lt;&gt; null then
		if _externalId = self.getExternalInvoiceNumber then		// 36355 chage to 'get' method
			return true;
		endif;
	endif;

	if _cargoId &lt;&gt; null then
		create localTiArray transient;	//30 Mar 2016	NDL	TFS 1726
		self.getAllGoodTrackedItems( localTiArray );		//30 Mar 2016	NDL	TFS 1726
		//foreach ti in self.allTrackedItems do
		foreach ti in localTiArray do		//30 Mar 2016	NDL	TFS 1726
			if ti.id = _cargoId then
				return true;
			endif;
		endforeach;
	endif;

	return false;
epilog

	delete localTiArray;	//30 Mar 2016	NDL	TFS 1726

end;
</source>
        <Parameter name="_voyageCode" type="String"/>
        <Parameter name="_bol" type="String"/>
        <Parameter name="_customsEntryNumber" type="String"/>
        <Parameter name="_externalId" type="String"/>
        <Parameter name="_cargoId" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="needSAPRequest" id="44892717-2545-49ff-ab90-b6577d34bfb0">
        <source>needSAPRequest() : Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 August 2018	jlger1	Initial creation
11/06/2025	navcs2	MTN-34987 MTN -  Disable SAP Integration

*/

vars
	debtorTerm  : CM_DebtorTerminal;
	paymentType : Integer;
begin
	// 11/06/2025	navcs2	MTN-34987  Added as we are no onger using SAP but want to keep the code
	/*
	if not self.myTerminal.isSapFinancialEnabled then
		return false;
	endif;
	
	paymentType := self.paymentType;                 
	if paymentType = PaymentType_None then
		return false;
	endif;
	if	paymentType = PaymentType_NoCharge then
		return false;
	endif;
	if self.paymentStatus = CM_CashReceipt.CREDIT_CHECK_APPROVED then
		return false;
	endif;
	
	return true;
	*/
	
	return false;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="populateCashReceiptDetails" id="07502717-06bc-47c8-98ba-34d28add7589">
        <source>populateCashReceiptDetails(_allCashPayment,             
							_allCashPaymnetNonTI,
							_allCashPaymentPrevCredit,
							_allCashPaymentPrevCreditNonTI,
							_allTIOnCashPayment,
							_allTIOnPrevCredit,
							_allInvoiceLines                : ObjectArray input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 Oct 2019 cnwma1 ChangeRequest 46984: JMT - Refactor Cash Credit UI and Tax
*/

vars
	unCreditAmount : Decimal [23,6];
	
	cashPayment	: CM_CashPayment;
	invLine     : CM_InvoiceLine;
	proforma    : CM_ProformaDetails;
	ti          : CM_TrackedItem;
begin
	foreach cashPayment in self.allCashPayments discreteLock do
		if cashPayment.voided then
			continue;
		endif;
		if cashPayment.isTaxPayment then
			continue;
		endif;
		
		invLine  		:= cashPayment.myInvoiceLine;
		proforma 		:= cashPayment.myProformaDetail;
		unCreditAmount 	:= cashPayment.getUncreditedAmount();
		ti      	     := cashPayment.myTrackedItem;
		
		if invLine &lt;&gt; null then
			if invLine.voided then
				continue;
			endif;
			_allInvoiceLines.addExclusive(invLine);
		endif;
		
		
		if unCreditAmount = 0 then
			_allCashPaymentPrevCredit.addExclusive(cashPayment);
			if ti &lt;&gt; null then
				_allTIOnPrevCredit.addExclusive(ti);
			else
				_allCashPaymentPrevCreditNonTI.addExclusive(cashPayment);
			endif;
			continue;
		endif;

		
		if ti&lt;&gt; null then
			_allTIOnCashPayment.addExclusive(ti);
			_allCashPayment.addExclusive(cashPayment);
		else
			_allCashPaymnetNonTI.addExclusive(cashPayment);
		endif;
		
	endforeach;
epilog

end;</source>
        <Parameter name="_allCashPayment" type="ObjectArray" usage="input"/>
        <Parameter name="_allCashPaymnetNonTI" type="ObjectArray" usage="input"/>
        <Parameter name="_allCashPaymentPrevCredit" type="ObjectArray" usage="input"/>
        <Parameter name="_allCashPaymentPrevCreditNonTI" type="ObjectArray" usage="input"/>
        <Parameter name="_allTIOnCashPayment" type="ObjectArray" usage="input"/>
        <Parameter name="_allTIOnPrevCredit" type="ObjectArray" usage="input"/>
        <Parameter name="_allInvoiceLines" type="ObjectArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="printReceipt" id="40115ead-5171-4017-ac41-0b0ee871afd2">
        <source>printReceipt(_copies : Integer; _printPreview : Boolean; _jrwReport : JadeReportWriterReport; _reportName : String; _printer : String ;_isProfrmaPrint: Boolean) ;
// print receipt for this cash payment
vars
	termDict 	 : CM_TerminalByCodeDict;
	jadeReport	 : JadeReport;
	jrwManager	 : JadeReportWriterManager;
	jrwReport	 : JadeReportWriterReport;
	jrwCash		 : CM_JRWCashTransactions;
	transientRep : JadeReportWriterReport;
	duplex		 : Integer;
	reportString : String;
	printerName  : String;

begin

	if _copies = null or _copies = 0 then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Attempt to print 0 copies');
		return;
	endif;

	if _printer &lt;&gt; null then
		printerName := _printer;
		app.printer.setPrinter(printerName);
	endif;

	if _printPreview then
		create jadeReport transient;
		jadeReport.description := app.getErrorString(CM_Default);
		app.printer.setReport(jadeReport);
	endif;	
		
	jrwCash := app.myQAFilter.createJRWTransient(CM_JRWCashTransactions).CM_JRWCashTransactions;
	create termDict transient;
	termDict.add(self.getDebtorTerminal.myTerminal);
	jrwCash.setAllTerminals(termDict);
	jrwCash.allCashReceipts.add(self);
	
	if _jrwReport = null then
		// 33523 report name passed in
		if _reportName &lt;&gt; null then
			reportString := _reportName;
		elseif self.getDebtorTerminal.myTerminal &lt;&gt; null then
			reportString := self.getDebtorTerminal.myTerminal.getConfig(GateCashReceiptReport).String;
		endif;

		if reportString = null then
			reportString := DefRep_CashReceiptReport;
			
		else
			// print to lineflow via text file
			if reportString.pos("?TXT", 1) &gt; 0 then
				app.printReportViaTextFile(reportString);
				return;
			
			//12 Nov 2012	NDL	Par 30689
			elseif reportString.pos("?DOT", 1) &gt; 0 then
				app.printReportDotMatrix(reportString, self, false);
				return;
			
			endif;
		endif;
		jrwManager := app.createReportWriterManager();
		transientRep := jrwManager.getReport(reportString);
		if transientRep = null then
			app.raiseUnexpectedProgramError(class.name, method.name, "Cash Receipt report not specified in gate config, (" &amp; reportString &amp; " does not exist)");
			return;
		endif;
		jrwReport := transientRep;
	else
		jrwReport := _jrwReport;
	endif;

	jrwReport.setOutputDestination(JadeReportWriterReport.PRINTER);
		
	duplex := app.printer.duplex;
	jrwReport.setPageOptions(Print_A4, Print_Portrait, _copies, 0, 0, 0, 20, 0, false, duplex);
	if _printPreview then
		jrwReport.setPreviewOptions(false, true, false, true, null);
	endif;

	jrwReport.run;

	if _printPreview then
		app.printPreview(jadeReport, true);
	else
		delete jadeReport;
	endif;		
epilog
	delete transientRep;
	delete jrwCash;	
	delete jrwManager;
	delete termDict;
end;</source>
        <Parameter name="_copies" type="Integer"/>
        <Parameter name="_printPreview" type="Boolean"/>
        <Parameter name="_jrwReport" type="JadeReportWriterReport"/>
        <Parameter name="_reportName" type="String"/>
        <Parameter name="_printer" type="String"/>
        <Parameter name="_isProfrmaPrint" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="6a39ef92-4ce8-43b8-b8ad-8ed584d33107">
        <source>pxyCreateUpdateProxy(): SelfType;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
18 July 2012	cnwndl1	Initial creation

*/

vars

	pxy : CM_CashReceipt;
	localTiArray : CM_TIArray;		//30 Mar 2016	NDL	TFS 1726

begin

	pxy := inheritMethod();
	
	pxy.myPaymentMethod := self.myPaymentMethod;
	pxy.myDebtorTerminal := self.myDebtorTerminal;
	
	// 32498
	self.allInvoiceLines.copy(pxy.allInvoiceLines);
	self.allProformaDetails.copy(pxy.allProformaDetails);
	
	create localTiArray transient;	//30 Mar 2016	NDL	TFS 1726
	self.getAllGoodTrackedItems( localTiArray );		//30 Mar 2016	NDL	TFS 1726
	//self.allTrackedItems.copy(pxy.allTrackedItems);
	localTiArray.copy(pxy.allTrackedItems);	//30 Mar 2016	NDL	TFS 1726

	// 34227 add the rest of the references for updating
	// not bank or terminal, these are set in setForUpdate
	pxy.myCashInvoice := self.myCashInvoice;
	pxy.myUser := self.myUser;
	pxy.myVoyage := self.myVoyage;
	
	return pxy;

epilog

	delete localTiArray;	//30 Mar 2016	NDL	TFS 1726

end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="pxyGetBank" id="9084d67f-d3af-4dc0-9b76-a529f2ba2e5f">
        <source>pxyGetBank() : CM_Bank;

/*

Purpose:			// TFS 38732 the proxy cash receipt has invoice lines that get turned into cash payments
						So at this stage the only references with the cargo's BU are these invoic elines, some of which are transient.

Parameters:			

Return Value:		


Date		Who		Reason
16 May 2018	jlgab1	Initial creation
24 Sep 2019 cnwma1	Bug 46645: New cash form - subsequent payments going to default business unit
*/

vars
	bank : CM_Bank;
	terminal : CM_Terminal;
begin	
	
	if self.myBank &lt;&gt; null then									         //24.09.2019 cnwma1 #46645
		return self.myBank;
	endif;
	
	// Actual invoice lines
	if not self.allInvoiceLines.isEmpty() then
		bank := self.allInvoiceLines.first.bank;
	endif;
	
	// Proforma and Extra lines
	if bank = null then
		if not self.allProformaInvoiceLines.isEmpty() then
			bank := self.allProformaInvoiceLines.first.bank;
		endif;
	endif;
	
	/*MA 24.09.2019*/
	if not self.allProformaDetails.isEmpty then                          //24.09.2019 cnwma1 #46645
		if  self.allProformaDetails.first.myInvoiceLineType &lt;&gt; null then
			bank := self.allProformaDetails.first.myInvoiceLineType.bank;
		endif;
	endif;
	
	// Use default BU
	if bank = null then
		terminal := self.getDebtorTerminal().myTerminal;
		bank := terminal.getDefaultCompanyBank();
	endif;

	return bank;
epilog

end;</source>
        <ReturnType type="CM_Bank"/>
    </JadeMethod>
    <JadeMethod name="requireFinanceCheck" id="40893e35-ae60-42df-8fbc-90dab36b1354">
        <source>requireFinanceCheck():Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 Sep 2021 navma1 ChangeRequest 51925: SAL - Web Portal Cargo Work Orders

*/

vars
	debtorTerm  : CM_DebtorTerminal;
	paymentType : Integer;
begin
		
	paymentType := self.paymentType;                 
	
	if paymentType = PaymentType_None then
		return false;
	endif;
	
	if	paymentType = PaymentType_NoCharge then
		return false;
	endif;
	
	if self.paymentStatus = CM_CashReceipt.CREDIT_CHECK_APPROVED then
		return false;
	endif;
	
	return true;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="requiresBGPRequestForStatus" id="c832df16-177e-4348-9353-49a40a7f474e">
        <source>requiresBGPRequestForStatus() : Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
//11/07/2024	navkc1 CR 64837 Task 64851: Jade - New API putProformaForExternal

*/

vars
	terminal				: CM_Terminal;
	isConfigUseAdvBGP,
	isPayTypePrePay,
	isPayStatusDraft		: Boolean;
begin
	// Get terminal from Cash Receipt
	terminal := self.myTerminal;
	
	// If null then get terminal from bank
	if terminal = null then
		self.getMyTerminal();
		// If still null then return
		if terminal = null then 
			return false;
		endif;
	endif;
	
	isConfigUseAdvBGP := terminal.getConfig(UseCashStatusAdvBGP).Boolean;
	//isPayTypePrePay := self.paymentType = PaymentType_PrePay; // ### JIRA 35050 10JUN2025 NAVAB1
	isPayStatusDraft := self.paymentStatus = CM_CashReceipt.API_RECEIPT_DRAFT;
	
	// If ALL true, then return true
	// ### JIRA 35050 10JUN2025 NAVAB1 return isConfigUseAdvBGP and isPayTypePrePay and isPayStatusDraft;
	return isConfigUseAdvBGP and isPayStatusDraft; // ### JIRA 35050 10JUN2025 NAVAB1
	
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="sendRejectionEmail" id="03c11f20-16b3-49e3-9d22-e2bb1969c5ed">
        <source>sendRejectionEmail(_reasons : String);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 September 2019	jlger1	Initial creation moved from BGP_SAPWSRequest

*/

vars

	debtor  	: CM_Debtor;
	debtorEmail : String;
	financeEmail: String;
	terminal 	: CM_Terminal;
	subject  	: String;
	strNbr      : String;
	type        : String;
begin
	
	debtor      := self.getDebtor;
	terminal 	:= self.myTerminal;
	strNbr   	:= self.externalInvoiceNumber;
	type        := app.getErrorString(Cash_receipt);
			
	debtorEmail := debtor.getEmailAddress();
	financeEmail := terminal.getConfig(EmailForFinance).String;
	subject      := type &amp; ": " &amp; strNbr &amp;Tab &amp; app.getErrorString(Debtor_GC) &amp; ": "&amp; debtor.name &amp;Tab &amp; "Rejected";
	app.myTrxCA.trxCreateEmailSendRequest(app.getErrorString(Web) &amp; ' ' &amp; $User &amp; ' ' &amp; app.myPassport.getUserCode(),	// _alertDescription
										  debtorEmail,		// _toAddress
										  app.myRoot.getConfig(AutoSendersEmailAddress).String,					// _fromAddress
										  financeEmail,		// _ccAddresses
										  null,		// _bccAddresses
										  subject,			// _sendSubject
										  _reasons,				// _sendMessage
										  null,						// _allAttachedFilePaths
										  null,						// _allFileData
										  null,						// _blob
										  null,						// _blobFileName
										  EmailSource_System,		// _sourceOfEmail
										  null,						// _updateCallbackObj
										  app.myPassport);			// _passport
epilog

end;</source>
        <Parameter name="_reasons" type="String"/>
    </JadeMethod>
    <JadeMethod name="setAllCashPayments" id="c861c706-2147-4542-baa1-ddaf0c5300cc">
        <updating/>
        <source>setAllCashPayments(_allCashPayments : CM_CashPaymentDict) updating;

/*

Purpose:			Store the associated cash payments.

Parameters:			

Return Value:		


Date		Who		Reason
24 April 2014	cnwjre1	Initial creation

*/

vars

begin
	if _allCashPayments = null or _allCashPayments.isEmpty then
		global.setExtraData (self.allExtraData, self, "allCashPayments", null);
	else
		global.setExtraData (self.allExtraData, self, "allCashPayments", _allCashPayments);
	endif;

epilog

end;</source>
        <Parameter name="_allCashPayments" type="CM_CashPaymentDict"/>
    </JadeMethod>
    <JadeMethod name="setArchived" id="4bb49cb1-0eb2-41b0-91ac-e826a0277d02">
        <updating/>
        <source>setArchived(_forDebtorTerminal : CM_DebtorTerminal; _archive: Boolean) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
08 August 2012	cnwndl1	Initial creation	Par 29968

*/

vars

begin

	inheritMethod(_forDebtorTerminal,_archive);
	
	if _archive then
		self.myConsolidatedDebtorTerm := self.myDebtorTerminal;
		self.myDebtorTerminal := null;
	else
		self.myDebtorTerminal := self.myConsolidatedDebtorTerm;
		self.myConsolidatedDebtorTerm := null;
	endif;

epilog

end;</source>
        <Parameter name="_forDebtorTerminal" type="CM_DebtorTerminal"/>
