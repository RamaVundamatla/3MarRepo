    <JadeMethod name="resetButtonState" id="d1d370ec-57e1-4754-a358-6f6877cf6b7c">
        <updating/>
        <source>resetButtonState(_value : Boolean) updating;
// ---------------------------------------------------------------------------
// Created:     11 September 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	btn		: CMUI_ButtonForToolbar;
	tmpStyle	: Integer;

begin

	tmpStyle := self.style;
	btn 	 := self.myButtonForToolbar;

	if tmpStyle = Button.Style_Normal or
	   btn = null then
		return;
	endif;

	btn.value := _value;

	if tmpStyle = Button.Style_Auto2State then
		if _value then
			self.drawButtonDown();
			if self.myToolbar &lt;&gt; null then
				self.myToolbar.resetButtonStateForParent(self, btn.parent);
			endif;
		else
			self.drawButtonUp();
		endif;
	elseif self.style = Button.Style_2State then
		if _value then
			self.drawButtonDown();
		else
			self.drawButtonNormal();
		endif;
	endif;

	if btn.pictureDown &lt;&gt; null then
		if _value then 
			self.myToolbarPicture.picture := btn.pictureDown;
			self.myToolbarPictureCaption.picture := btn.pictureDown;
		else 
			self.myToolbarPicture.picture := btn.picture;
			self.myToolbarPictureCaption.picture := btn.picture;
		endif;
	endif;

end;</source>
        <Parameter name="_value" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="resetButtonsInGroup" id="10d18e14-e9c0-490e-88c3-ed19939a8955">
        <updating/>
        <source>resetButtonsInGroup(_value : Boolean; _parent : Window) updating;
// ---------------------------------------------------------------------------
// Created:     11 September 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	btn			: CMUI_ButtonForToolbar;
	tmpStyle	: Integer;

begin

	btn := self.myButtonForToolbar;
	tmpStyle := self.style;
	
	if btn.style &lt;&gt; Button.Style_Auto2State and
	   btn = null then
		return;
	endif;
	
	if btn.parent &lt;&gt; _parent then
		return;
	endif;
	
	self.resetButtonState(false);
	self.clearGraphics;

end;</source>
        <Parameter name="_value" type="Boolean"/>
        <Parameter name="_parent" type="Window"/>
    </JadeMethod>
    <JadeMethod name="setCaption" id="4b5b36dd-7196-4717-a500-e00499d6327d">
        <updating/>
        <source>setCaption(_str : String; _showCaptions : Boolean) : Real updating;
// ---------------------------------------------------------------------------
// Created:     25 August 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
constants
	MAXNUMLETTERS = 8;
	PIXELSPERLETTER = 11;
vars
	idx,
	maxLength,
	strLength	: Integer;
	tmpStr, line		: String;
	lines : StringArray;
	maxWidth, width : Real;
begin

	if (not _showCaptions) then
		return 0;
	endif;

	if self.myToolbar &lt;&gt; null and
	   (not self.myToolbar.showCaptions) then
		return 0;
	endif;

//	if (not self.myToolbar.showCaptions) then
//		return;
//	endif;
	
	if _str = null then
		self.caption := null;
		return 0;
	endif;
	

	tmpStr := _str.replaceString('&amp;', '');
	tmpStr := tmpStr.replaceString(" / ", "/ ");		 // CNWAB1 METRO - 2 spaces with 1
	tmpStr := tmpStr.replaceString("  ", " ");		 // CNWAB1 METRO - 2 spaces with 1
	tmpStr := tmpStr.replaceString(" ", CrLf);		 // CNWAB1 METRO
	tmpStr := tmpStr.replaceString("-", CrLf);		 // CNWAB1 METRO
	tmpStr := CrLf &amp; CrLf &amp; CrLf &amp; tmpStr; // CNWAB1 METRO
	
	maxLength := self.MaxCaptionLength;
	strLength := tmpStr.length;
	
//	if strLength &lt;= maxLength then
		 //length OK
//		self.caption := tmpStr;
		
	
//		return;
//	endif;
	
	//too long to fit so truncate and ... it
/* // CNWAB1 METRO
	tmpStr := tmpStr[1:maxLength];
	
	foreach idx in (maxLength - 2) to maxLength do
		tmpStr[idx] := '.';
	endforeach;
	*/

	create lines transient;
	tmpStr.getTokensForDelimiter(CrLf, lines);
	
	maxWidth := self.WidthTotalWithCaption;
	
	foreach  line in lines do
		
		if line.length &gt; MAXNUMLETTERS then
			width := width.max((line.length - MAXNUMLETTERS) * PIXELSPERLETTER);
		endif;
			
	endforeach;
	
	self.caption := tmpStr;

	
	return maxWidth + width; // width is the widest over 12 characters.
epilog
	delete lines;
end;</source>
        <Parameter name="_str" type="String"/>
        <Parameter name="_showCaptions" type="Boolean"/>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="setForPermission" id="9959ddaa-bc46-4bf4-af0a-49bbb5cb0483">
        <updating/>
        <source>setForPermission(_user: CM_User; _terminal: CM_Terminal) updating;
// ---------------------------------------------------------------------------
// Created:     20 August 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	permValue	: Integer;
	
begin

	if self.referenceType &lt;&gt; ReferenceType_MenuUserToolbar then
		return;
	endif;
	
	permValue := self.userObjectName.Integer;
	if permValue &lt;&gt; null then
		if (not _user.canDo(_terminal, permValue)) then
			self.enabled := false;
		else
			self.enabled := true;
		endif;
	endif;

end;</source>
        <Parameter name="_user" type="CM_User"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="setShowCaptions" id="9c6d663a-3b5f-4ccc-bfea-b33e892717bd">
        <updating/>
        <source>setShowCaptions(_showCaptions : Boolean) updating;
// ---------------------------------------------------------------------------
// Created:     30 July 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
vars
	theCaption		: String;
	tmpWidth,
	tmpHeight		: Real;
	btn				: CMUI_ButtonForToolbar;
	btnValue		: Boolean;
	invalidToolbar : Boolean;
begin
	//18/09/2009 cnwdz2 20591
	on Exception do app.handleDeletedObject(exception, self.myMenuUserToolbar, invalidToolbar);
	
	
	if self.referenceType = self.ReferenceType_Button then
		btn := self.myButtonForToolbar;
		if btn &lt;&gt; null then
			theCaption 	:= btn.caption.replaceString('&amp;', '');
			btnValue	:= btn.value;	
		endif;

	elseif self.referenceType = self.ReferenceType_MenuUserToolbar then
		theCaption := self.myMenuUserToolbar.heading;
	endif;

	
	tmpWidth := self.getWidth(_showCaptions);

	if _showCaptions then
		tmpHeight := CMUI_Toolbar.ControlHeightWithCaptions;
		self.myToolbarPictureCaption.visible := true;
		self.myToolbarPicture.visible := false;
	
		self.alignment := CMUI_Toolbar.Alignment_Center_Top; // CNWAB1 METRO
		tmpWidth := self.setCaption(theCaption, _showCaptions);
		self.myToolbarPictureCaption.left := ((tmpWidth / 2) - (CMUI_ToolbarButton.WidthPictureWithCaption / 2) + 2).Integer; // centre the picture in the button with caption

	else
		self.caption := null;
		tmpHeight := CMUI_Toolbar.ControlHeightWithoutCaptions;
		self.myToolbarPictureCaption.visible := false;
		self.myToolbarPicture.visible := true;
		
	endif;	
	
	

	
	self.height := tmpHeight;
	self.width	:= tmpWidth;

	self.myToolbarOverlay.move(0, 0, tmpWidth, tmpHeight);
	
	if self.style &gt; Button.Style_Normal and btnValue then
		self.clearGraphics();
		self.drawButtonDown();
	endif;
	
	
	
end;</source>
        <Parameter name="_showCaptions" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="updateSelf" id="295d99cc-722e-43d9-8825-e24953306e44">
        <updating/>
        <source>updateSelf(_showCaptions : Boolean) updating;
// ---------------------------------------------------------------------------
// Created:     28 July 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
vars

begin
	
	if self.myButtonForToolbar &lt;&gt; null then
		if _showCaptions then
			self.setCaption(self.myButtonForToolbar.caption, _showCaptions);
		endif;
		
		if self.myButtonForToolbar.enabled &lt;&gt; self.enabled then
			self.enabled := self.myButtonForToolbar.enabled;
		endif;
	endif;
	
end;</source>
        <Parameter name="_showCaptions" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="windowCreated" id="a8c90d67-35cb-4a01-81e9-381783ec1ee5">
        <updating/>
        <source>windowCreated(cntrl: Control input; persistCntrl: Control) updating;
// ---------------------------------------------------------------------------
// Created:     25 July 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
vars

begin
	inheritMethod(cntrl, persistCntrl);
	self.transparent := false;
	self.wordWrap 	:= false;
	self.autoRedraw	:= true;
	self.createToolbarPicture();
	self.createClickAreaOverlay();

	self.origBackColor		:= self.getSystemColor(Color_3DFace); // CNWAB1 METRO
	
end;</source>
        <Parameter name="cntrl" type="Control" usage="input"/>
        <Parameter name="persistCntrl" type="Control"/>
    </JadeMethod>
