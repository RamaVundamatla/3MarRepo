    <JadeMethod name="updateTableColumnFilters" id="928d8319-87d4-483a-9126-107a2fd983e4">
        <updating/>
        <source>updateTableColumnFilters(_table: Table; _allFilterColumns: CM_ColumnFilterDict) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
31 October 2013	cnwjre1	Initial creation

*/

vars

begin

	if self.allColumnFilters = null then
		create self.allColumnFilters transient;  // this is a non exclusive collection.
	endif;
	
	self.allColumnFilters.replaceAllFiltersForTable( _table, _allFilterColumns );

epilog

end;</source>
        <Parameter name="_table" type="Table"/>
        <Parameter name="_allFilterColumns" type="CM_ColumnFilterDict"/>
    </JadeMethod>
    <JadeMethod name="userNotificationUpdate" id="d3aa2fd4-ccae-45ad-8106-43aaecbd2d6e">
        <updating/>
        <source>userNotificationUpdate(_event: Integer; _noteobj : CM_Object; _obj: CM_Object) updating;
// ---------------------------------------------------------------------------
// Created:		March 2004 By Andrew Bishop cnwab1
//
// Purpose:		
// 23 Jul 2025	navnk30	JIRA 35279: CPL - After auditing invoice, status change post does not show up in Invoice List
// ---------------------------------------------------------------------------

vars
	theInvoice : CM_Invoice;
	theDataLine : String;
	idx : Integer;
	isAvailabe : Boolean; 
begin
	isAvailabe := true;
	if _obj &lt;&gt; null and _event = Event_InvoiceUpdate then
		theInvoice := _obj.CM_Invoice;
		isAvailabe := self.includeObject(theInvoice);
		self.tblData.findObjectInRow(theInvoice,idx);
	
		if idx &gt; self.tblData.fixedRows then
			if isAvailabe then
				theDataLine := theInvoice.getAttributeStringForDefArray(self.tblData.allTblDataEntRows);
				self.tblData.accessCell(idx,1).text := theDataLine;
// ### TFS BUG 62926 02APR2024 NAVAB1				self.setEnableObjects();					
				self.setStatusColour(theInvoice,idx); // ### TFS 59699 07AUG2023 NAVAB1
			else
				self.tblData.deleteRow(idx);
			endif;
		endif;
		if theInvoice = self.myCurrentInvoice then		//23JUL2025 navnk30 JIRA-35279
			self.setEnableObjects();
		endif;
	elseif _obj &lt;&gt; null and _event = Event_InvoiceCreate then
		theInvoice := _obj.CM_Invoice;
		isAvailabe := self.includeObject(theInvoice);
		if isAvailabe then
			self.doQueryAddItem(theInvoice);
		endif;
	endif;

end;</source>
        <Parameter name="_event" type="Integer"/>
        <Parameter name="_noteobj" type="CM_Object"/>
        <Parameter name="_obj" type="CM_Object"/>
    </JadeMethod>
    <JadeMethod name="userNotify" id="34721893-0e02-4bc2-a140-ea3372052259">
        <controlMethod name="Form::userNotify"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>userNotify(eventType: Integer; theObject: Object; eventTag: Integer; userInfo: Any) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 May 2025	jlier1	Initial creation MTN-34725

*/

vars

begin
		
	//29/05/2025	jlier1 JIRA MTN-34725
	if self.notificationLevel = self.NoteLevelDoNotes then
		self.beginTimerForNotifications(theObject, eventType, eventTag, userInfo);
	endif;
epilog

end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
        <Parameter name="userInfo" type="Any"/>
    </JadeMethod>
</GUIClass>
