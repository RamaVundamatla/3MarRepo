	self.helpFileName := HelpFile_Invoicing;

end;</source>
    </JadeMethod>
    <JadeMethod name="doBaseFormCancel" id="0a06fc31-e588-49eb-b96f-853db12bec98">
        <updating/>
        <source>doBaseFormCancel() updating, protected;
// ---------------------------------------------------------------------------
// Created:		May 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

begin
	inheritMethod();
	self.allInvoiceLines.purge; // these are proxies
	self.unloadForm();
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doBaseFormSave" id="98c9d263-faf5-42f8-84e4-442dc54f78db">
        <updating/>
        <source>doBaseFormSave() updating, protected;
// ---------------------------------------------------------------------------
// Created:		May 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	theController : CMIF_InvoiceLineConvert;
	theForm : INV_ListLines;
	theReturn : Integer;
begin
	if self.myCurrentInvLineDesc = null then
		app.msgBox("Please select a invoice line description to convert to.","COnvert Error", MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
		return;
	endif;

	if self.frmLineConvertOp.enabled then
		if self.chkLineConvert.value = false then
			if app.msgBox("The selected invoice lines are using more than one invoice line description." &amp; Cr
							&amp; "Do you want to convert them all to " &amp; self.myCurrentInvLineDesc.narration &amp; "?", 
							"Confirm Convertion", MsgBox_Yes_No + MsgBox_Question_Mark_Icon) = MsgBox_Return_No then
				return;
			endif;
		endif;
	endif;
	
	create theController transient;
	
	self.allInvoiceLines.copy(theController.allInvoiceLines); // these are proxies
	
	if not theController.allInvoiceLines.isEmpty then
		theController.myInvoiceLineDesc := self.myCurrentInvLineDesc;
		while true do
			app.myTrxUA.trxUpdateInvoiceLineConvert(theController, app.myPassport);
			if app.myPassport.trxCompletedOK then
				// Clear errors/warnings from form and err/warnings window
				self.clearErrorWarnings();
				global.beep;
				self.unloadForm();
			else
				theReturn := app.showErrorWarningDialog(app.getErrorString(INV_Invoice_Line_Convert), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
				if app.myPassport.noErrors 
				and theReturn = IDOK then
					// there must have just been warnings that the user has acknoledged so ..
					app.myPassport.warningsAcknowledged	:= true;
					continue;
				endif;
				self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
				return;
			endif;
			break;
		endwhile;
	endif;
epilog
	self.allInvoiceLines.purge; // these are proxies
	delete theController;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doQuery" id="b504c258-85c7-4142-9e21-f72f3607aee2">
        <source>doQuery();
// ---------------------------------------------------------------------------
// Created:		May 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	lineD:     CM_InvoiceLineDesc;
begin
	foreach lineD in self.myCurrentBank.invoiceLineDescriptors where not lineD.isNotAvailableForEntry do
		self.lstLineDescs.addItem(lineD.narration);
		self.lstLineDescs.itemObject[self.lstLineDescs.newIndex] := lineD;
	endforeach;

end;</source>
    </JadeMethod>
    <JadeMethod name="doResize" id="b5a18f0f-e4f3-4094-8716-9925ad332637">
        <updating/>
        <source>doResize() updating;
// ---------------------------------------------------------------------------
// Created:		May 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

begin
	inheritMethod();
	self.lstLineDescs.move(5,self.frmToolbar.clientHeight + 5,self.clientWidth - 10,self.clientHeight - 10 - self.frmToolbar.clientHeight);
end;</source>
    </JadeMethod>
