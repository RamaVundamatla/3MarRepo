    <JadeMethod name="addAdditionalCalendarDays" id="e71a6e34-ebc6-4a5d-a2f6-17e329d7f19e">
        <source>addAdditionalCalendarDays(_receivalDate : Date; _freeStorageDays : Integer ; _freeDaysType : Integer) : Date;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
// 31/05/2023	navkc1	CR 57999 Task 58000: JADE - Storage Config - Storage Detail Addition Calendars

*/

vars
	freeStorageEndDate	: Date;
	calendar			: CM_Calendar;
	count				: Integer;
	include				: Boolean;
	storageConfig		: CM_StorageConfig;
	workCal,
	compCal				: CM_Calendar;
	eofWeekDt			: Date;
	isWorkAndCompulsory	: Boolean;
	isWorking			: Boolean;
	doneRemove			: Boolean;
	allCalendars 		: CM_CalendarByCodeDict;
begin
	
	create allCalendars transient;
	
	self.allAdditionalCalendars.copy(allCalendars);
	
	storageConfig := self.myStorageConfig;
	
	isWorking := _freeDaysType = CM_StorageDetail.Working_Days;
	isWorkAndCompulsory := _freeDaysType = CM_StorageDetail.Working_Compulsory_Days;
	
	// Get working calendar
	if isWorking then
		if storageConfig &lt;&gt; null then
			calendar := storageConfig.myWorkingDaysCalendar;
			if calendar &lt;&gt; null then
				allCalendars.addNoDuplicates(calendar, false);
			endif;
		endif;
	// Get working and compulsory calendar
	elseif isWorkAndCompulsory then
		
		workCal := storageConfig.myWorkingDaysCalendar;
		compCal := storageConfig.getMyCompulsoryCalendar();
		
		if workCal &lt;&gt; null then
			allCalendars.addNoDuplicates(workCal, false);
		endif;
		if compCal &lt;&gt; null then
			allCalendars.addNoDuplicates(compCal, false);
		endif;
		
		// Some logic here for Work and compulsory
		if workCal &lt;&gt; null then
			if workCal.getFirstCalendarDateForDay(_receivalDate) &lt;&gt; null then
				eofWeekDt := _receivalDate + 2;
			else
				eofWeekDt := _receivalDate + 7;
			endif;
		endif;
	endif;
	
	freeStorageEndDate := _receivalDate;
	
	if 	_freeStorageDays = 0 or
		allCalendars.isEmpty() then
		return freeStorageEndDate;
	endif;
	
	// Calculate when the free storage ends
	while true do
		freeStorageEndDate += 1;
		
		include := false;
		
		// Some logic here for Work and compulsory
		if isWorkAndCompulsory and not doneRemove then
			if freeStorageEndDate &gt; eofWeekDt and allCalendars.includes(workCal) then
				allCalendars.remove(workCal);
				doneRemove := true;
			endif;
		endif;
		
		// Go through all calendar to check whether we need to exlcude this date from counter
		foreach calendar in allCalendars do : checkDate
			
			if calendar.doesCalendarIncludeDate(freeStorageEndDate) then
				include := true;
				break checkDate;
			endif;
			
		endforeach;
		
		if not include then
			count += 1;
		endif;
		
		// We have reached the number of free days
		if count &gt;= _freeStorageDays then
			
			// For Working and Compulsory, if next day is holiday, keep going
			if isWorkAndCompulsory then
				if compCal.getFirstCalendarDateForDay(freeStorageEndDate + 1) &lt;&gt; null then
					continue;
				endif;
				break;
			endif;
			
			break;
		endif;
	endwhile;
	
	return freeStorageEndDate;
epilog
	delete allCalendars;
end;</source>
        <Parameter name="_receivalDate" type="Date"/>
        <Parameter name="_freeStorageDays" type="Integer"/>
        <Parameter name="_freeDaysType" type="Integer"/>
        <ReturnType type="Date"/>
    </JadeMethod>
