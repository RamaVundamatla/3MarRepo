    <JadeMethod name="doUpdateCriteriaLine" id="07f3da65-a8ae-4184-a4de-af0fd7106968">
        <source>doUpdateCriteriaLine(	_qDef : CM_QueryDefinition;
						_criteriaHolder : CM_QueryCriteriaLineHolder io;
						_propName : String;
						_qOperatorStr : String;
						_value : Any
						);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 January 2014	cnwndl1	Initial creation	Par 33347

*/

vars

	iter : Iterator;
	criteriaLine : CM_SelectorCriteriaLine;

begin

	iter := _criteriaHolder.allCriteriaLines.createIterator;
	while iter.next( criteriaLine ) do
		if criteriaLine.propName = _propName then
			delete criteriaLine;
			break;
		endif;
	endwhile;

	criteriaLine := _qDef.createCriteriaLine(_propName, _qOperatorStr, _value);
	criteriaLine.setMyCriteriaLineHolder(_criteriaHolder);

epilog

	delete iter;

end;</source>
        <Parameter name="_qDef" type="CM_QueryDefinition"/>
        <Parameter name="_criteriaHolder" type="CM_QueryCriteriaLineHolder" usage="io"/>
        <Parameter name="_propName" type="String"/>
        <Parameter name="_qOperatorStr" type="String"/>
        <Parameter name="_value" type="Any"/>
    </JadeMethod>
    <JadeMethod name="findBooking" id="3c409f23-0831-4c3b-89a7-01acbf611685">
        <options>4</options>
        <source>findBooking(_bookingId, _operatorId, _voyageId : String; _terminal : CM_Terminal) : CM_BookingRef typeMethod;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
22 March 2023	navpw1	Initial creation TFS: 56850 (56871)
30 March 2023	navpw1	Defect 57394: Fixed if statement to be an "or" not an "and" condition

*/

vars
	iter : Iterator;
	realBooking : CM_BookingRef;
	
begin
	iter := _terminal.allBookingRefsByRef.createIterator;
	_terminal.allBookingRefsByRef.startKeyGeq(_bookingId, iter);
	
	while iter.next(realBooking) do
		if realBooking.bookingReference &lt;&gt; _bookingId then
			break;
		endif;
		
		if realBooking.operatorCode &lt;&gt; _operatorId or realBooking.voyageCode &lt;&gt; _voyageId then
			continue;
		endif;
		
		return realBooking;
	endwhile;
	
	return null;
	
epilog
	delete iter;
	
end;</source>
        <Parameter name="_bookingId" type="String"/>
        <Parameter name="_operatorId" type="String"/>
        <Parameter name="_voyageId" type="String"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <ReturnType type="CM_BookingRef"/>
    </JadeMethod>
    <JadeMethod name="findCargo" id="aa538d4a-cf52-4f79-8779-37f85eafe7c8">
        <source>findCargo(_cargoId, _cargoType, _voyage : String) : CM_TrackedItem;
/*
Purpose:			
	Find cargo that is either onsite or onship
Parameters:			

Return Value:		

Date		Who		Reason
05 January 2012	cnwdw1	
*/
vars
	terminal	: CM_Terminal;
	cargoType 	: CM_CargoType;
	
begin
	if _cargoId = null or _cargoType = null then
		return null;
	endif;
	
	terminal := app.myPassport.myTerminal;
	
	//cnwmc5 - 20 July 2015
	cargoType := terminal.myRoot.getCargoTypeFromAbbrevOrDescr(_cargoType);
	if cargoType = null and _cargoType.isInteger then
		cargoType := terminal.myRoot.getCargoTypeForID(_cargoType.Integer);
	endif;
	
	return terminal.lookupTrackedItem(_cargoId, cargoType.id, null, _voyage, false);
epilog

end;</source>
        <Parameter name="_cargoId" type="String"/>
        <Parameter name="_cargoType" type="String"/>
        <Parameter name="_voyage" type="String"/>
        <ReturnType type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="findReleaseRequest" id="98d61434-5424-4d42-9dcb-df00195d8ea5">
        <options>4</options>
        <source>findReleaseRequest(_terminal : CM_Terminal; _requestDT : TimeStamp; _releaseRequestId : String ) : CM_BulkRelease typeMethod;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
12 April 2023	navlw1	Initial creation CR 56852 CUX - MTN-EDBIC - 100 - Process Release Request

*/

vars
	iter 			: Iterator;
	releaseRequest 	: CM_BulkRelease;
	foundReleaseReq : Boolean;
begin
	
	iter := _terminal.allBulkReleasesByCodeDate.createIterator;
	_terminal.allBulkReleasesByCodeDate.startKeyGeq(_releaseRequestId, _requestDT, iter);
	
	while iter.next(releaseRequest) do
		if releaseRequest.code &lt;&gt; _releaseRequestId then
			break;
		endif;
		return releaseRequest;
	endwhile;
	
	delete iter;
	
	iter := _terminal.allBulkReleasesByCodeDate.createIterator;
	_terminal.allBulkReleasesByCodeDate.startKeyLeq(_releaseRequestId, _requestDT, iter);
	
	while iter.next(releaseRequest) do
		if releaseRequest.code &lt;&gt; _releaseRequestId then
			break;
		endif;
		return releaseRequest;
	endwhile;
	
	// we did not find the release request so return null
	return null;
epilog
	delete iter;
end;</source>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_requestDT" type="TimeStamp"/>
        <Parameter name="_releaseRequestId" type="String"/>
        <ReturnType type="CM_BulkRelease"/>
    </JadeMethod>
    <JadeMethod name="findVoyage" id="86468ad1-ec76-4be2-812d-369998847bf1">
        <options>4</options>
        <source>findVoyage(_terminal : CM_Terminal; _voyageId : String; _arrivalDateTime : TimeStamp; _archived : Boolean) : CM_Voyage typeMethod;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
24 March 2023		navlw1	Initial creation TFS 57245 (57246) CR CUX - MTN-EDBIC - 160 - Put Voyage
13 December 2023	navmd1	TFS 60597 Changed to use standard terminal lookup method
10 September 2025	navlw1	JIRA-35882: Support External Voyage Code

*/

vars
	voy : CM_Voyage;
begin
	voy := _terminal.lookupVoyage(_voyageId, _arrivalDateTime, _archived);
	if voy = null then
		// look voyage up by inwards code
		voy := _terminal.allVoyagesByInwardCode[_voyageId];
	endif;
	if voy = null then
		// look voyage up by external code if we cannot find the voyage
		voy := _terminal.allVoyagesByExternalCode[_voyageId];
	endif;
	return voy;
epilog
	
end;</source>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_voyageId" type="String"/>
        <Parameter name="_arrivalDateTime" type="TimeStamp"/>
        <Parameter name="_archived" type="Boolean"/>
        <ReturnType type="CM_Voyage"/>
    </JadeMethod>
    <JadeMethod name="findWorkPointJobSheet" id="430b42ec-f195-4b89-84e5-e974648fc99e">
        <options>4</options>
        <source>findWorkPointJobSheet(_id :String;_statusCode   : Integer io):CM_WorkPointJobSheet typeMethod;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25 Jun 2023 navma1 ChangeRequest 58589[58595]: EUP | LMS Gang API - Endpoint

*/

vars
	workPointJobSheet : CM_WorkPointJobSheet;
	term			  : CM_Terminal;
begin
	
	term := app.myPassport.myTerminal;
	
	workPointJobSheet := term.getWorkPointJobSheet(_id);
	
	return workPointJobSheet;
epilog

end;</source>
        <Parameter name="_id" type="String"/>
        <Parameter name="_statusCode" type="Integer" usage="io"/>
        <ReturnType type="CM_WorkPointJobSheet"/>
    </JadeMethod>
    <JadeMethod name="getBRProspectiveChildCargo" id="b71af700-2a5a-4823-b87a-c24e5b66e4e2">
        <source>getBRProspectiveChildCargo(	_bulkRelease 	  : CM_BulkRelease;
							_reserveSelection : CM_ReserveSelection;
							_targetLocation   :  CM_LocationsController;
							_tiArray 		  : CM_TIArray io
							);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 August 2014	cnwndl1	Initial creation	Par 34717 CCMS 2384
19 May 2015	NDL	Par 36127 - Treat assigned cargo on a Release by type as if its a release by id, untill there is none left.
                       I.e choose from the assigned list before we allow generic search.
07 Apr	2017	cnwma1	TFS #4017:PAR38663 STWR - Error 1090 when loading outbound truck
19 May 2017		NDL		TFS 4016		
23/06/2023	navkc1	CR 58406 Task 58408: Jade - Release Request All Tracked Items
07/11/2024	jlizm1	MTN-33027 Cargo group id issues in Truck Loader Unloader
25/11/2024  navma1	MTN-33508 MTN - 11501 - Application has been aborted exception on the truck loader and unloader app
*/

vars

	ti 					: CM_TrackedItem;
	reserve 			: CM_ReserveDetail;
	tiSet 				: CM_TISet;
	allowOtherReleases	: Boolean;
	lc					: CM_LocationsController;
begin

	if _tiArray = null then
		return;
	endif;
	
	if _bulkRelease = null then				//25.11.2024 navma1 #MTN-33508						
		return;
	endif;
	
	allowOtherReleases := _bulkRelease.allowCargoOnMultipleReleases;
	
	create tiSet transient; //23/06/2023	navkc1	CR 58406 Task 58408
	
	// Release by id or release by type with assigned items
	// get the nominated child cargo
	foreach reserve in _bulkRelease.allReserveDetails do
		if _reserveSelection &lt;&gt; null and reserve &lt;&gt; _reserveSelection then	//03 Oct 2016	NDL	TFS 
			continue;
		endif;
		reserve.getAllTrackedItems(tiSet, true); //23/06/2023	navkc1	CR 58406 Task 58408

		foreach ti in tiSet do //23/06/2023	navkc1	CR 58406 Task 58408
			// 30 Apr 2015	NDL	Par 36140 
			if _bulkRelease.isPackingType then
				if ti.isContainer or ti.isChassis then
					//will be associated so as to be a parent not a child.
					continue;
				endif;
			endif;
			if ti.isChild then
				//already packed
				continue;
			endif; 
			
			if not ti.isOnSite then
				continue;
			endif;
			
			lc := ti.myPrimaryActualLocation;
			
			if lc = null then
				continue;
			endif;

			if lc = _targetLocation then
				continue;
			elseif ( _targetLocation &lt;&gt; null and _targetLocation.isWagon ) then	//26 Jan 2017	NDL	TFS 3198/2877
				if lc.isWagon and ( lc.CM_WagonController.myWagon = _targetLocation.CM_WagonController.myWagon ) then
					continue;
				endif;
			endif;
			
			if _bulkRelease.isRoadType then    // 36127
				if lc.isVehicle then
					continue;
				elseif lc.isTILCController then
					continue;
				endif;
			endif;
			
			_tiArray.tryAdd( ti );
		endforeach;
	endforeach;
epilog

	delete tiSet;
end;</source>
        <Parameter name="_bulkRelease" type="CM_BulkRelease"/>
        <Parameter name="_reserveSelection" type="CM_ReserveSelection"/>
        <Parameter name="_targetLocation" type="CM_LocationsController"/>
        <Parameter name="_tiArray" type="CM_TIArray" usage="io"/>
    </JadeMethod>
    <JadeMethod name="getConfigOptionValue" id="8576b7bc-77d2-4a59-894c-567396665713">
        <source>getConfigOptionValue(_xmlRequest : String) : String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 July 2017	jlgab1	Initial creation

*/
		/* to test SOAPUI
		&amp;lt;MKVALUE&amp;gt;Well%t@ckedP1Rate5!&amp;lt;/MKVALUE&amp;gt;&amp;lt;MODE&amp;gt;4&amp;lt;/MODE&amp;gt;&amp;gt;&amp;lt;OptionCode&amp;gt;C&amp;lt;/OptionCode&amp;gt;
		*/

vars	
    
    pos : Integer;
	configOptionCode : String;
    configOptionValue : String;
	terminal : CM_Terminal;
	xmlString : String;
    
begin
	
	terminal := app.myPassport.myTerminal;
		
	pos := 1;
	configOptionCode := _xmlRequest.getNextTagValueForName("OptionCode",pos).trimBlanks();
	if configOptionCode &lt;&gt; "" then
        configOptionValue := terminal.getConfig(configOptionCode.trimBlanks).String;
		
		if configOptionValue = null then
		
			configOptionValue := app.myRoot.getConfig(configOptionCode.trimBlanks).String;
			if configOptionValue = null then
				return "&lt;OptionCode&gt;" &amp; configOptionCode &amp; " - Possible Invalid Option&lt;/OptionCode&gt;";
			else
				return "&lt;OptionCode&gt;" &amp; configOptionValue &amp; "&lt;/OptionCode&gt;";
			endif;
		else
			return "&lt;OptionCode&gt;" &amp; configOptionValue &amp; "&lt;/OptionCode&gt;";
		endif;
	else
		return "&lt;OptionCode&gt;INVALID OPTION&lt;/OptionCode&gt;";
	endif;
	
	return "&lt;OptionCode&gt;NO ACTION&lt;/OptionCode&gt;" &amp; _xmlRequest;
epilog

end;</source>
        <Parameter name="_xmlRequest" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getProductVersionNumber" id="1dd378b2-93c3-4c7e-a98b-b4442bdbd3a4">
        <source>getProductVersionNumber(_xmlRequest : String) : String;
/*
Purpose:			
Date				Who			Reason
APRIL 2015		CNWAB1		Initial creation
*/

vars

begin
	if app.myRoot = null then
		return "";
	endif;
	if app = null then
		return "";
	endif;
	
	return "&lt;ProductVersion&gt;" &amp; app.myRoot.versionString &amp;  "&lt;/ProductVersion&gt;";
epilog


end;</source>
        <Parameter name="_xmlRequest" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getSearchEventRequestIter" id="4a6fc268-c439-4594-aaf9-9ac4976d0162">
        <source>getSearchEventRequestIter(request : CMIF_SearchEventRequest) : Iterator;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 Sep 2008	cnwkao1	Initial creation
23/09/2009	cnwdad1	PAR #19974 (event collections moved from Root to Terminal.
*/
vars
	iter		: Iterator;
	isStops		: Boolean;
	
begin
	isStops := request.type &lt;&gt; EventRequestTypeNotify;
	
	if request.cargoId &lt;&gt; null then
		if isStops then

			iter := app.getMyTerminalDO_NOT_USE().allEventRequestStopsByCargoID.createIterator;
			app.getMyTerminalDO_NOT_USE().allEventRequestStopsByCargoID.startKeyGeq(request.cargoId, iter);
		else

			iter := app.getMyTerminalDO_NOT_USE().allEventRequestNotifyByCargoID.createIterator;
			app.getMyTerminalDO_NOT_USE().allEventRequestNotifyByCargoID.startKeyGeq(request.cargoId, iter);
		endif;
	else
		if isStops then
			iter := app.getMyTerminalDO_NOT_USE().allEventRequestsStops.createIterator;
			if request.status &gt; EventRequestStatusAny then	
				app.getMyTerminalDO_NOT_USE().allEventRequestsStops.startKeyGeq(request.status, null, iter);				
			endif;
		else

			iter := app.getMyTerminalDO_NOT_USE().allEventRequestsNotify.createIterator;
			if request.status &gt; EventRequestStatusAny then		
				app.getMyTerminalDO_NOT_USE().allEventRequestsNotify.startKeyGeq(request.status, null, iter);				
			endif;			
		endif;
	endif;
	
	return iter;
end;</source>
        <Parameter name="request" type="CMIF_SearchEventRequest"/>
        <ReturnType type="Iterator"/>
    </JadeMethod>
    <JadeMethod name="getTIsForCargoEnquiryOld" id="7905e44c-f884-4143-b52b-4dc3c195afa4">
        <source>getTIsForCargoEnquiryOld(requestObj : WS_TrackedItemQueryRequest) : WS_TrackedItemQueryResponse;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
15 Sep 2008	cnwkao1	Initial creation - effectively copied and pasted from CM_ContainerEnqForm::addObjectsToTable.
					JMT should refactor their original method - then update this (ideally these methods would be in a central
					place - not on a form).					
03 Feb 2009	cnwkpd1	PAR #17754 - Tidy up Terminal Area search
13 Mar 2009	cnwkpd1	PAR #19049 - Change to return only onsite cargo
31 Mar 2008	cnwkpd1	PAR #19311 - Ensure search only returns each cargo item once, even if it appears in multiple
					collections
07 May 2013	NDL		Part of par 31506, was breaking one too soon if maxResults was used.
21 Jan 2014	NDL		Par 33347, re-named and replaced by search using selector query.
// 06 Sep 2016	cnwrs1	TFS 2586 dont always include archived voyages and lookup reveresed even if we found data in non reverese lookup
12 Aug 2022 navtnr20 Bug 52451: MTN - WebServices not using getObjectOfTypeFromOid
14/07/2025		naviv1	MTN-35226	MTN - Usage of Iterator.getCurrentKeys  	
*/

vars
	response		: WS_TrackedItemQueryResponse;
	completedOK		: Boolean;
	
	iter			: Iterator;
	
	terminal		: CM_Terminal;
	obj				: Object;
	ti				: CM_TrackedItem;
	proxyTI			: WS_TrackedItem;
	
	startFrom		: Integer;
	matches			: Integer;
	maxResults		: Integer;
	
	idLength,
	tmpCargoType 	: Integer;
	tmpId			: String;
	altId			: String;
	coll 			: Collection;
	dict			: Dictionary;
	state		 	: Integer;
	
	haveId			: Boolean;
	idKey			: String;
	cargoTypeKey	: Integer;
	dictHasDate		: Boolean;
	dateKey			: TimeStamp;
	
	tiSet			: CM_TISet;
	opTerm			: CM_OperatorTerminal;
	
	theTerminal		: CM_Terminal;
	tisAddedToTbl	: CM_TIByIdCargoTypeDict;
	
	term			: CM_Terminal;
	request			: WS_TrackedItemQueryRequest;
	matchedTIs		: CM_TISet;							// PAR #19311
	terminalArea	: CM_TerminalArea;
	
	lc				: CM_LocationsController;
	
	operator		: CM_Operator;
	
begin
	/*
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);
	
	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	
	// Initialise the passport for the new transaction
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	*/
	// Create the response
	create response transient;

	// Check security access to this message
	app.checkCurrentUserHasAccess(PmAdmCargoEnquiryView);
	if app.myPassport.hasErrors then
		completedOK := true;
		return response;
	endif;
	
	// Start populating response - cloned from CMUI_Assistant::getBookingRefFromCode
	terminal := app.myPassport.myTerminal;
	
	request := requestObj;
	
	maxResults	:= requestObj.maxReturnedItems;
	startFrom	:= requestObj.startFrom;
	
	matches := null;
	
	tmpCargoType	:= request.filterTiType.Integer;

	//04/08/2010 cnwdz2 24696 the state option is reinstated
	// PAR #19049 - hard code state to be TI_STATE_NORMAL as per request.  Note that 
	// some therefore redundant following code has been retained, in case the state option is
	// reinstated
	state			:= request.filterSite.Integer;
	//state			:= TI_STATE_NORMAL;				

	haveId			:= request.filterId &lt;&gt; null;
	term			:= app.myPassport.myTerminal;
	
	if haveId then
		tmpId := request.filterId.toUpper();
		altId := tmpId;
	endif;
	
	create matchedTIs transient;		// PAR #19311
	
	if (state = null) or 
	   ((state = TI_STATE_ONSHIP or state = TI_STATE_OFFLOADED) and 
	   request.filterVoyage.length() &lt; 1) then
		// need to search the world ...
	   		
		create tiSet transient;
		if state = null then
			term.lookupAllTIsOfIdCargoType(tmpId,
											tmpCargoType,
											tiSet, false, false,
											null);		
		else 
		   	term.lookupAllOnShipTrackedItems(tmpId,
												tmpCargoType,
												state = TI_STATE_OFFLOADED,  //other alternative is TI_STATE_ON_SHIP
												false, //include archived voyages = determined in JMT thinclient by whether or not the ship icon on the searcher is depressed
												false, //self.searchReversed
												tiSet,
												null);
		endif;
		
		foreach ti in tiSet do
			if ti &lt;&gt; null and ti.isValid then//added by cnwyl1 for par15723
				if not matchedTIs.includes(ti) and self.includeTIForCargoEnq(request, ti) then					
					matches := matches + 1;				
					if matches &lt; startFrom then 
						continue;
					endif;
						
				//	if matches - startFrom = maxResults then
				//		completedOK := true;
				//		return response; //found enough items
				//	endif;
					
					create proxyTI transient;
					proxyTI.setProxyFromObject(ti);
					response.allTrackedItems.add(proxyTI);
					
					matchedTIs.add(ti);
					
					if maxResults &gt; 0 and matches - startFrom = maxResults then
						completedOK := true;
						return response; //found enough items
					endif;
					
				endif;
			endif;			
		endforeach;	
		completedOK := true;
		return response;
	endif;

	if request.filterTerminalArea &lt;&gt; null then
	
		if state &lt;&gt; TI_STATE_NORMAL then
			//app.msgBox(app.getErrorString(SearchByLocationNotOnSite), app.getErrorString(Warning), MsgBox_OK_Only + MsgBox_Information_Icon);
			// raise appropriate web service area - as above not sure that its appropriate??
		endif;
				
		if request.filterYardLocation &lt;&gt; null then
			//Start 30.09.2022 navtnr20 52451
			//obj := request.filterYardLocation.asOid;
			lc := app.myPassport.getObjectOfTypeFromOid(request.filterYardLocation,CM_LocationsController).CM_LocationsController;
			/*if obj.isKindOf(CM_LocationsController) then	
				lc := obj.CM_LocationsController;			
			endif;*/
			//End 30.09.2022 navtnr20 52451
			if lc &lt;&gt; null then
				iter := lc.allTrackedItemsById.createIterator();
				lc.allTrackedItemsById.startKeyGeq(tmpId,
													request.filterTiType.Integer,
													iter);
				
				while iter.next(ti) do
					if matchedTIs.includes(ti) or not self.includeTIForCargoEnq(request, ti) then
						continue;
					endif;
					
					matches := matches + 1;				
					if matches &lt; startFrom then 
						continue;
					endif;
						
				//	if matches - startFrom = maxResults then
				//		completedOK := true;
				//		return response; //found enough items
				//	endif;
					
					create proxyTI transient;
					proxyTI.setProxyFromObject(ti);
					response.allTrackedItems.add(proxyTI);
					
					matchedTIs.add(ti);
					
					if maxResults &gt; 0 and matches - startFrom = maxResults then
						completedOK := true;
						return response; //found enough items
					endif;
					
				endwhile;
				
			endif;
			
			completedOK := true;
			return response;

		else
			
			terminalArea := term.allTerminalAreas[request.filterTerminalArea];
			
			if terminalArea &lt;&gt; null then
				foreach lc in terminalArea.allLocationsControllers discreteLock do
					//self.getTIsForLocationsController(lc, _numItems, tisAddedToTbl, app.myPassport); - ko - code is reproduced below
					
					foreach ti in lc.allTrackedItems discreteLock do
						if matchedTIs.includes(ti) or not self.includeTIForCargoEnq(request, ti) then
							continue;
						endif;
						
						matches := matches + 1;				
						if matches &lt; startFrom then 
							continue;
						endif;
							
				//		if matches - startFrom = maxResults then
				//			completedOK := true;
				//			return response; //found enough items
				//		endif;
						
						create proxyTI transient;
						proxyTI.setProxyFromObject(ti);
						response.allTrackedItems.add(proxyTI);	
						
						matchedTIs.add(ti);
						
						if maxResults &gt; 0 and matches - startFrom = maxResults then
							completedOK := true;
							return response; //found enough items
						endif;
						
					endforeach;
				endforeach;
			endif;
		endif;

		completedOK := true;	
		return response;
	endif;
	
	if (state &lt;&gt; TI_STATE_ONSHIP) and request.filterOperator.length() &gt; 0 then
	
		operator := app.myRoot.allOperators[request.filterOperator];
		if operator &lt;&gt; null then
			opTerm := operator.allOperatorTerminals[term];
		endif;
		if opTerm &lt;&gt; null then
			coll := opTerm.getDictForTIState(state, haveId);
		endif;
	endif;

	if coll = null then		
		coll := term.getDictForTIState(	state,
										null,//self.filterVoyage, - KO Temporary
										haveId,
										false);
	endif;

	if coll &lt;&gt; null then
		if (not Dictionary.hasInstance(coll)) then
			if ObjectArray.hasInstance(coll) then
				foreach obj in coll.ObjectArray do
					if not matchedTIs.includes(ti) and self.includeTIForCargoEnq(request, obj.CM_TrackedItem) then
						matches := matches + 1;				
						if matches &lt; startFrom then 
							continue;
						endif;
							
				//		if matches - startFrom = maxResults then
				//			completedOK := true;
				//			return response; //found enough items
				//		endif;
						
						create proxyTI transient;
						proxyTI.setProxyFromObject(obj.CM_TrackedItem);
						response.allTrackedItems.add(proxyTI);	
						
						matchedTIs.add(obj.CM_TrackedItem);
						
						if maxResults &gt; 0 and matches - startFrom = maxResults then
							completedOK := true;
							return response; //found enough items
						endif;
						
					endif;					
				endforeach;
			else
				// If this occurs then need to add a clause as above for ObjectArray
				app.raiseUnexpectedProgramError(class.name, method.name, 'Unhandled collection type (' &amp; coll.String &amp; ')');
			endif;

		elseif haveId then
			// We have an id or part id so look for this
			dict := coll.Dictionary;
			
			create tiSet transient;

			idLength	:= tmpId.length;
			iter 		:= dict.createIterator;

			if CM_TIsInTransitToByFromTypeId.hasInstance(dict) or CM_TIsInTransitFromByToTypeId.hasInstance(dict) then
				dict.startKeyGeq(null, tmpCargoType, null, iter);
				while iter.next(ti) do
					iter.getCurrentKeys(theTerminal, cargoTypeKey, idKey);  //MTN-35226
					//if ti.cargoType &lt;&gt; self.filterCargoType then
					if tmpCargoType &lt;&gt; TI_CargoType_Null and
					   cargoTypeKey &lt;&gt; tmpCargoType then
						break;
					endif;
					
					if idKey[1 : idLength] &lt;&gt; tmpId and
						idKey.reverse[1 : idLength] &lt;&gt; tmpId then
						continue;
					endif;
					
					if not matchedTIs.includes(ti) and self.includeTIForCargoEnq(request, ti) then
						matches := matches + 1;				
						if matches &lt; startFrom then 
							continue;
						endif;
							
					//	if matches - startFrom = maxResults then
					//		completedOK := true;
					//		return response; //found enough items
					//	endif;
						
						create proxyTI transient;
						proxyTI.setProxyFromObject(ti);
						response.allTrackedItems.add(proxyTI);	
						
						matchedTIs.add(ti);
						
						if maxResults &gt; 0 and matches - startFrom = maxResults then
							completedOK := true;
							return response; //found enough items
						endif;
						
					endif;
				endwhile;			
			else
				if CM_TIDictByIdCargoTypeDate.hasInstance(dict) then
			   		dictHasDate := true;
					dict.startKeyGeq(tmpId, tmpCargoType, null, iter);
				else
					dictHasDate := false;
					dict.startKeyGeq(tmpId, tmpCargoType, iter);
				endif;
	
				while iter.next(ti) do
					/* KO - dont need this 
					if dictHasDate then
						dict.getIteratorKeys(idKey, cargoTypeKey, dateKey, iter);
					else
						dict.getIteratorKeys(idKey, cargoTypeKey, iter);
					endif;
					*/
					
					idKey := iter.getCurrentKey(1).String;
					if idKey[1 : idLength] &lt;&gt; tmpId then
						break;
					endif;
					if not matchedTIs.includes(ti) and self.includeTIForCargoEnq(request, ti) then
						matches := matches + 1;				
						if matches &lt; startFrom then 
							continue;
						endif;
							
				//		if matches - startFrom = maxResults then
				//			completedOK := true;
				//			return response; //found enough items
				//		endif;
						
						create proxyTI transient;
						proxyTI.setProxyFromObject(ti);
						response.allTrackedItems.add(proxyTI);
						
						matchedTIs.add(ti);	
						
						if maxResults &gt; 0 and matches - startFrom = maxResults then
							completedOK := true;
							return response; //found enough items
						endif;
						
					endif;
				endwhile;
				delete iter;
				
				// now check the reversed dicts if there is one
				coll := term.getDictForTIState(state,
												null, //request.filterVoyage, //KO - same deal as above
												haveId,
												true).Dictionary;
				if coll &lt;&gt; null and Dictionary.hasInstance(coll) then
				
					tmpId := tmpId.reverse;
					dict := coll.Dictionary;
					
					iter := dict.createIterator;
	
					if CM_TIDictByIdCargoTypeDate.hasInstance(dict) then
					   	dictHasDate := true;
						dict.startKeyGeq(tmpId, tmpCargoType, null, iter);
					else
						dictHasDate := false;
						dict.startKeyGeq(tmpId, tmpCargoType, iter);
					endif;
					
					while iter.next(ti) do
						/* KO - again don't need this - this loop code should be in its own method (its already implemented earlier in the method)
						if dictHasDate then
							dict.getIteratorKeys(idKey, cargoTypeKey, dateKey, iter);
						else
							dict.getIteratorKeys(idKey, cargoTypeKey, iter);
						endif;
						*/
						idKey := iter.getCurrentKey(1).String;
						
						//if ti.idReversed[1 : idLength] &lt;&gt; tmpId then
						if idKey[1 : idLength] &lt;&gt; tmpId then
							break;
						endif;
						if tiSet.includes(ti) then
							// check to see we have not already added this ti
							continue;
						endif;
												
						if not matchedTIs.includes(ti) and self.includeTIForCargoEnq(request, ti) then
							matches := matches + 1;				
							if matches &lt; startFrom then 
								continue;
							endif;
								
						//	if matches - startFrom = maxResults then
						//		completedOK := true;
						//		return response; //found enough items
						//	endif;
							
							create proxyTI transient;
							proxyTI.setProxyFromObject(ti);
							response.allTrackedItems.add(proxyTI);
							
							matchedTIs.add(ti);
							
							if maxResults &gt; 0 and matches - startFrom = maxResults then
								completedOK := true;
								return response; //found enough items
							endif;
							
						endif;							

					endwhile;
				endif;
			endif;
		else
			dict := coll.Dictionary;
			iter := dict.createIterator;

			if CM_TIsInTransitToByFromTypeId.hasInstance(dict) or CM_TIsInTransitFromByToTypeId.hasInstance(dict) then
				dict.startKeyGeq(null, tmpCargoType, null, iter);
				while iter.next(ti) do
					iter.getCurrentKeys(theTerminal, cargoTypeKey, idKey);  //MTN-35226
					//if ti.cargoType &lt;&gt; self.filterCargoType then
					if tmpCargoType &lt;&gt; TI_CargoType_Null and
					   cargoTypeKey &lt;&gt; tmpCargoType then
						break;
					endif;
					if not matchedTIs.includes(ti) and self.includeTIForCargoEnq(request, ti) then
						matches := matches + 1;				
						if matches &lt; startFrom then 
							continue;
						endif;
							
					//	if matches - startFrom = maxResults then
					//		completedOK := true;
					//		return response; //found enough items
					//	endif;
						
						create proxyTI transient;
						proxyTI.setProxyFromObject(ti);
						response.allTrackedItems.add(proxyTI);
						
						matchedTIs.add(ti);
						
						if maxResults &gt; 0 and matches - startFrom = maxResults then
							completedOK := true;
							return response; //found enough items
						endif;
						
					endif;
				endwhile;
				
			elseif CM_TIDictByCargoTypeIdDate.hasInstance(dict) then
				dict.startKeyGeq(tmpCargoType, null, null, iter);
				while iter.next(ti) do
					iter.getCurrentKeys(cargoTypeKey, idKey, dateKey);  //MTN-35226
					//if ti.cargoType &lt;&gt; self.filterCargoType then
					if tmpCargoType &lt;&gt; TI_CargoType_Null and
					   cargoTypeKey &lt;&gt; tmpCargoType then
						break;
					endif;
				
					if not matchedTIs.includes(ti) and self.includeTIForCargoEnq(request, ti) then
						matches := matches + 1;				
						if matches &lt; startFrom then 
							continue;
						endif;
							
					//	if matches - startFrom = maxResults then
					//		completedOK := true;
					//		return response; //found enough items
					//	endif;
						
						create proxyTI transient;
						proxyTI.setProxyFromObject(ti);
						response.allTrackedItems.add(proxyTI);
						
						matchedTIs.add(ti);
						
						if maxResults &gt; 0 and matches - startFrom = maxResults then
							completedOK := true;
							return response; //found enough items
						endif;
						
					endif;
				endwhile;
			else
				dict.startKeyGeq(tmpCargoType, null, iter);
				while iter.next(ti) do
					iter.getCurrentKeys(cargoTypeKey, idKey);  //MTN-35226
					//if ti.cargoType &lt;&gt; self.filterCargoType then
					if tmpCargoType &lt;&gt; TI_CargoType_Null and
					   cargoTypeKey &lt;&gt; tmpCargoType then
						break;
					endif;

					if not matchedTIs.includes(ti) and self.includeTIForCargoEnq(request, ti) then
						matches := matches + 1;				
						if matches &lt; startFrom then 
							continue;
						endif;
							
					//	if matches - startFrom = maxResults then
					//		completedOK := true;
					//		return response; //found enough items
					//	endif;
						
						create proxyTI transient;
						proxyTI.setProxyFromObject(ti);
						response.allTrackedItems.add(proxyTI);
						
						matchedTIs.add(ti);
						
						if maxResults &gt; 0 and matches - startFrom = maxResults then
							completedOK := true;
							return response; //found enough items
						endif;
						
					endif;					
				endwhile;
			endif;
			delete iter;
		endif;
	endif;
	
	//03 May 2013	NDL	Par 31506
	if altId &lt;&gt; null and (state = null or state = TI_STATE_NORMAL) then
		//check the on-site cargo with matching alternate id as well...
			//21/4/22 jlier1 TFS 53249
		self.addOnsiteAltIdTis(	term.allOnsiteTIsByAlternativeId,	//_term : CM_Terminal;
								altId,	//_altId : String;
								matchedTIs,	//_matchedTIs : CM_TISet input;
								request,	//_request : WS_TrackedItemQueryRequest;
								matches,	//_matches : Integer io;
								startFrom,	//_startFrom : Integer;
								maxResults,	//_maxResults : Integer;
								completedOK,	//_completedOK : Boolean io;
								response,	//_response : WS_TrackedItemQueryResponse input
								JMTUserInterfaceService::findCargo.name	//_from : String
								);
	endif;

	// Got to here, everything is ok
	completedOK := true;
	return response;
	

epilog
	// Tidy up local transients
	delete tiSet;
	delete tisAddedToTbl;
	delete iter;
	delete matchedTIs;		// PAR #19311
	
	if not completedOK then
	//	cnSetTransactionError(true);
		delete response;				// prevent transient leaks
	endif;
	
	// Copy any errors and warnings to the response before returning it
	//if response &lt;&gt; null then
	//	response.setErrorsFromPassport();
	//endif;
	//cnEndTransaction;
	
end;

</source>
        <Parameter name="requestObj" type="WS_TrackedItemQueryRequest"/>
        <ReturnType type="WS_TrackedItemQueryResponse"/>
    </JadeMethod>
    <JadeMethod name="getTIsForImportReleaseOld" id="d79858e4-7b27-4461-925f-9e81643b315a">
        <source>getTIsForImportReleaseOld(importRequest : WS_TrackedItemQueryRequest) : WS_TrackedItemQueryResponse;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
12 September 2008	cnwkao1	Initial creation - based on GTE_FullReleaseForm::addObjectsToTable
07 May 2013	NDL		Part of par 31506, was breaking one too soon if maxResults was used.
21 Jan 2014	NDL		Par 33347, re-named and replaced by search using selector query.
14/07/2025		naviv1	MTN-35226	MTN - Usage of Iterator.getCurrentKeys  	

*/
vars
    tiDict		:  CM_TIByIdCargoTypeDict;
	ti				: CM_TrackedItem;
	operTerminal	: CM_OperatorTerminal;
	pin				: CM_PinNo;
 	obj				: Object;
	iter			: Iterator;
	tmpId			: String;
	idLength		: Integer;
	idKey			: String;
	cargoTypeKey	: Integer;
	
	filterOperator	: CM_Operator;	
	response		: WS_TrackedItemQueryResponse;
	terminal		: CM_Terminal;
	maxResults		: Integer;
	startFrom		: Integer;
	matches 		: Integer;
	proxyTI			: WS_TrackedItem;
	filterVoyage	: CM_Voyage;
	
	completedOK		: Boolean;
	
	matchedTIs		: CM_TISet;	//03 May 2013	NDL	Par 31506

begin
	/*
	// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);
	
	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	
	// Initialise the passport for the new transaction
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	*/
	
	// Create the response
	create response transient;
	
	// Check security access to this message
	app.checkCurrentUserHasAccess(PmGteFullReleaseView);
	if app.myPassport.hasErrors then
		completedOK := true;
		return response;
	endif;
	
	// Start populating response - cloned from CMUI_Assistant::getBookingRefFromCode
	terminal := app.myPassport.myTerminal;
	
	maxResults	:= importRequest.maxReturnedItems;
	startFrom	:= importRequest.startFrom;
	
	matches := null;

	if importRequest.filterPIN &lt;&gt; null then
		pin := terminal.allPinNos.getAtKey(importRequest.filterPIN);
		if pin &lt;&gt; null then
			foreach obj in pin.allItems do
				if CM_TrackedItem.hasInstance(obj) and
					self.includeTIForReleaseImports(importRequest, obj.CM_TrackedItem) then
					
					matches := matches + 1;				
					if matches &lt; startFrom then 
						continue;
					endif;
						
				//	if matches - startFrom = maxResults then
				//		completedOK := true;
				//		return response; //found enough items
				//	endif;
					
					create proxyTI transient;
					proxyTI.setProxyFromObject(obj.CM_TrackedItem);
					response.allTrackedItems.add(proxyTI);
					
					if maxResults &gt; 0 and matches - startFrom = maxResults then		//cnwmc5 - 25 Sep 2014 - PAR 34927
						completedOK := true;
						return response; //found enough items
					endif;
					
				endif;
			endforeach;
		endif;		
		
		completedOK := true;
		return response;
	endif;
	
	//find the appropriate collection
	if importRequest.filterOperator &lt;&gt; null and importRequest.filterOperator.length() &gt; 0  then
		filterOperator := app.myRoot.allOperators.getAtKey(importRequest.filterOperator);
		if filterOperator &lt;&gt; null then
			operTerminal := filterOperator.allOperatorTerminals.getAtKey(terminal);
		endif;
	endif;
	
	if importRequest.filterVoyage &lt;&gt; null and importRequest.filterVoyage.length() &gt; 0 then
		filterVoyage := terminal.lookupVoyage(importRequest.filterVoyage, null, false);
	endif;
	
	if operTerminal &lt;&gt; null then
		tiDict := operTerminal.allOnsiteTIsByIdCargoType;
	elseif filterVoyage &lt;&gt; null then
		tiDict := filterVoyage.allOnsiteTIsByIdCargoType;				
	else
		tiDict := terminal.allOnsiteTIsByIdCargoType;
	endif;
	
	iter		:= tiDict.createIterator();
	tmpId		:= importRequest.filterId.toUpper();
	idLength	:= tmpId.length;
	tiDict.startKeyGeq(tmpId, 0, iter);
	
	create matchedTIs transient;	//03 May 2013	NDL	Par 31506
	
	while iter.next(ti) do
		if tmpId &lt;&gt; null then
			iter.getCurrentKeys(idKey, cargoTypeKey);  //MTN-35226
			if idKey[1 : idLength] &lt;&gt; tmpId then
				break;
			endif;
		endif;
		if (not ti.isImport) then
			continue;
		endif;	
		
		if self.includeTIForReleaseImports(importRequest,ti) then
			matches := matches + 1;				
			if matches &lt; startFrom then 
				continue;
			endif;
				
		//	if matches - startFrom = maxResults then
		//		break; //found enough items
		//	endif;
			
			create proxyTI transient;
			proxyTI.setProxyFromObject(ti);
			response.allTrackedItems.add(proxyTI);
			
			matchedTIs.add(ti);	//03 May 2013	NDL	Par 31506
			
			if maxResults &gt; 0 and matches - startFrom = maxResults then		//cnwmc5 - 25 Sep 2014 - PAR 34927
				break; //found enough items
			endif;
			
		endif;
	endwhile;
	
	//03 May 2013	NDL	Par 31506
	if tmpId &lt;&gt; null and not (matches - startFrom = maxResults) then
		//check the on-site cargo with matching alternate id as well...
			//21/4/22 jlier1 TFS 53249
		self.addOnsiteAltIdTis(	terminal.allOnsiteTIsByAlternativeId,	//_term : CM_Terminal;
								tmpId,	//_altId : String;
								matchedTIs,	//_matchedTIs : CM_TISet input;
								importRequest,	//_request : WS_TrackedItemQueryRequest;
								matches,	//_matches : Integer io;
								startFrom,	//_startFrom : Integer;
								maxResults,	//_maxResults : Integer;
								completedOK,	//_completedOK : Boolean io;
								response,	//_response : WS_TrackedItemQueryResponse input
								JMTUserInterfaceService::findImportReleaseCargo.name	//_from : String
								);
	endif;
	
	completedOK := true;
	return response;
	
	
epilog
	delete iter;
	delete matchedTIs;
	
	if not completedOK then
	//	cnSetTransactionError(true);
		delete response;				// prevent transient leaks
	endif;
	
	// Copy any errors and warnings to the response before returning it
	//if response &lt;&gt; null then
	//	response.setErrorsFromPassport();
	//endif;
	//cnEndTransaction;
	
end;</source>
        <Parameter name="importRequest" type="WS_TrackedItemQueryRequest"/>
        <ReturnType type="WS_TrackedItemQueryResponse"/>
    </JadeMethod>
    <JadeMethod name="getTIsForPreNotesOld" id="163457b6-5048-4947-9051-6e59da4e285e">
        <source>getTIsForPreNotesOld(preNoteRequest: WS_TrackedItemQueryRequest) : WS_TrackedItemQueryResponse;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
28 August 2008	cnwkao1	Initial creation
07 May 2013	NDL		Part of par 31506, was breaking one too soon if maxResults was used.
21 Jan 2014	NDL		Par 33347, re-named and replaced by search using selector query.

*/

vars
	response		: WS_TrackedItemQueryResponse;
	completedOK		: Boolean;
	
	iter			: Iterator;
//	bookingRef		: CM_BookingRef;
	
	terminal		: CM_Terminal;
	pin				: CM_PinNo;
	obj				: Object;
	ti				: CM_TrackedItem;
	proxyTI			: WS_TrackedItem;
	
	startFrom		: Integer;
	matches			: Integer;
	maxResults		: Integer;
	
	skipPreNotesById : Boolean;
	doPreNotesByAltId : Boolean;
	doByPreNoteId : Boolean;
	matchedTis : CM_TISet;

begin
	/*
	// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);
	
	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	
	// Initialise the passport for the new transaction
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	*/
	
	// Create the response
	create response transient;
	
	// Check security access to this message
	app.checkCurrentUserHasAccess(PmGtePreNoteView);
	if app.myPassport.hasErrors then
		completedOK := true;
		return response;
	endif;
	
	terminal := app.myPassport.myTerminal;
	
	maxResults	:= preNoteRequest.maxReturnedItems;
	startFrom	:= preNoteRequest.startFrom;
		
	matches := null;
	if preNoteRequest.filterPIN &lt;&gt; null then
		pin := terminal.allPinNos[preNoteRequest.filterPIN];
		if pin &lt;&gt; null then
			foreach obj in pin.allItems do
				if CM_TrackedItem.hasInstance(obj) and
		   	       self.includeTIForPreNotes(preNoteRequest, obj.CM_TrackedItem) then
					
					matches := matches + 1;
					if matches &lt; startFrom then 
						continue;
					endif;
					
					create proxyTI transient;
					proxyTI.setProxyFromObject(obj.CM_TrackedItem);
					response.allTrackedItems.add(proxyTI);	
					
					if maxResults &gt; 0 and matches - startFrom = maxResults then		//cnwmc5 - 25 Sep 2014 - PAR 34927
						break; //found enough items
					endif;
					
				endif;	
			endforeach;
		endif;
	else
	
		create matchedTis transient;
		skipPreNotesById := false;
		doByPreNoteId := false;
		doPreNotesByAltId := false;
		iter := terminal.allNotifiedTIsByIdCargoType.createIterator();
		
		//03 May 2013	NDL	Par 31506
		if preNoteRequest.filterId &lt;&gt; null then
			// we are filtering by cargo id.
			doPreNotesByAltId := true;
			doByPreNoteId := true;
			obj := terminal.allNotifiedTIsByIdCargoType.getAtKeyGeq( preNoteRequest.filterId, null);
			if obj &lt;&gt; null then
				if obj.CM_TrackedItem.id = preNoteRequest.filterId or obj.CM_TrackedItem.id.startsWith( preNoteRequest.filterId ) then
					iter.startAtObject( obj );
				else
					skipPreNotesById := true;
				endif;
			endif;
		endif;
		
		if not skipPreNotesById then
			while iter.next(ti) do
				if doByPreNoteId then
					if ti.id &lt;&gt; preNoteRequest.filterId then
						if not ti.id.startsWith( preNoteRequest.filterId ) then
							break;
						endif;
					endif;
				endif;
				if self.includeTIForPreNotes(preNoteRequest, ti) then
					matches := matches + 1;				
					if matches &lt; startFrom then 
						continue;
					endif;
						
					create proxyTI transient;
					proxyTI.setProxyFromObject(ti);
					response.allTrackedItems.add(proxyTI);
					matchedTis.add( ti );
					
					if maxResults &gt; 0 and matches - startFrom = maxResults then		//cnwmc5 - 25 Sep 2014 - PAR 34927
						break; //found enough items
					endif;
					
				endif;			
			endwhile;
		endif;
		
		delete iter;
		
		if doPreNotesByAltId then
			obj := terminal.allNotifiedTIsByAlternativeId.getAtKeyGeq( preNoteRequest.filterId );
			if obj &lt;&gt; null then
				iter := terminal.allNotifiedTIsByAlternativeId.createIterator();
				iter.startAtObject( obj );
				while iter.next(ti) do
					if ti.alternativeId &lt;&gt; preNoteRequest.filterId then
						if not ti.alternativeId.startsWith( preNoteRequest.filterId ) then
							break;
						endif;
					endif;
					if matchedTis.includes( ti ) then
						continue;
					endif;
					if self.includeTIForPreNotes(preNoteRequest, ti) then
						matches := matches + 1;				
						if matches &lt; startFrom then 
							continue;
						endif;
					
						create proxyTI transient;
						proxyTI.setProxyFromObject(ti);
						response.allTrackedItems.add(proxyTI);
						matchedTis.add( ti );
						
						if maxResults &gt; 0 and matches - startFrom = maxResults then		//cnwmc5 - 25 Sep 2014 - PAR 34927
							break; //found enough items
						endif;
						
					endif;			
				endwhile;
				delete iter;
			endif;
		endif;
		
	endif;
		

	// Got to here, everything is ok
	completedOK := true;
	return response;
	

epilog
	// Tidy up local transients
	delete iter;
	delete matchedTis;
	
	if not completedOK then
	//	cnSetTransactionError(true);
		delete response;				
	endif;
	
	// Copy any errors and warnings to the response before returning it
	//if response &lt;&gt; null then
	//	response.setErrorsFromPassport();
	//endif;
	//cnEndTransaction;
	
end;
</source>
        <Parameter name="preNoteRequest" type="WS_TrackedItemQueryRequest"/>
        <ReturnType type="WS_TrackedItemQueryResponse"/>
    </JadeMethod>
    <JadeMethod name="getTerminalAreaStats" id="8c086d96-4160-4a07-8baa-c80771e7e765">
        <source>getTerminalAreaStats(_xmlRequest : String) : String;
/*
Purpose:			
Date		Who		Reason
27 February 2015	cnwab1	Initial creation
*/

vars
	pos : Integer;
	terminalAreaId : String;
	terminal : CM_Terminal;
	termarea : CM_TerminalArea;
	controller : CMIF_TerminalAreaStats;
	xmlString : String;
begin
	
	terminal := app.myPassport.myTerminal;
		
	pos := 1;
	terminalAreaId := _xmlRequest.getNextTagValueForName("Code",pos);
	if terminalAreaId &lt;&gt; "" then
		if terminal&lt;&gt; null then
			termarea := terminal.allTerminalAreas.getAtKeyGeq(terminalAreaId);
			if termarea &lt;&gt; null then
				create controller transient;
				controller.init(termarea);
				if controller.getStats() then
				
					xmlString := controller.returnAsXMLString();
//					xmlString := self.formatAsJSONValue(controller.totalNumActual);
					return xmlString;
				else
					return "&lt;TermArea&gt;NOT FOUND no TA&lt;/TermArea&gt;";
				endif;
			else
				return "&lt;TermArea&gt;NOT FOUND&lt;/TermArea&gt;";
			endif;
		else
			return "&lt;TermArea&gt;NO CODE&lt;/TermArea&gt;";
		endif;
	else
		return "&lt;TermArea&gt;NO ID&lt;/TermArea&gt;";
	endif;
	
	return "&lt;TermArea&gt;NO ACTION&lt;/TermArea&gt;" &amp; _xmlRequest;
epilog
	delete controller;

end;</source>
        <Parameter name="_xmlRequest" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getVoyageStats" id="9b2c9181-7548-44af-8939-00c2080b5b55">
        <source>getVoyageStats(_xmlRequest : String) : String;
/*
Purpose:			
Date		Who		Reason
27 February 2015	cnwab1	Initial creation
*/

vars
	pos : Integer;
	voyageCode : String;
	terminal : CM_Terminal;
	voyage : CM_Voyage;
	controller : CMIF_VoyageStats;
	xmlString : String;
begin
	

	// Initialise the passport for the new transaction
	// In particular this sets passport myUser and myTerminal
//	self.initialisePassport();
	terminal := app.myPassport.myTerminal;
		
	pos := 1;
	voyageCode := _xmlRequest.getNextTagValueForName("Code",pos);
	if voyageCode &lt;&gt; "" then
		if terminal&lt;&gt; null then
			voyage := terminal.allVoyagesByCode.getAtKeyGeq(voyageCode,null);
			if voyage &lt;&gt; null then
				create controller transient;
				controller.init(voyage);
				controller.getStats(true);
				
				xmlString := controller.returnAsXMLString();
				
				return xmlString;
			else
				return "&lt;Voyage&gt;NOT FOUND&lt;/Voyage&gt;";
			endif;
		else
			return "&lt;Voyage&gt;NO CODE&lt;/Voyage&gt;";
		endif;
	endif;
	
	return "&lt;Voyage&gt;NO ACTION&lt;/Voyage&gt;";
epilog
	delete controller;

end;</source>
        <Parameter name="_xmlRequest" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getWorkPointForType" id="5d3c1f10-2fbd-427e-ab42-fb3ef05c1525">
        <options>4</options>
        <source>getWorkPointForType(_workPoint	: CM_WorkPoint output; _workPointType : CM_WorkPointType output; _wpTypeCode : String) typeMethod;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 Nov 2023	navnk30	Bug 61097: EUP | LMS Interface - POST with no Work Point ID
27 Feb 2024	navdap1	TFS 62646 EUP | LMS Gang API - Work Point Type Changes
*/

vars
	workPointType	: CM_WorkPointType;
	term			: CM_Terminal;
begin
	term := app.myPassport.myTerminal;
	foreach workPointType in term.allWorkPointTypes do
		if workPointType.code &lt;&gt; _wpTypeCode then			// TFS 62646
			continue;
		endif;
		
		if _workPointType = null then
			_workPointType := workPointType;
		endif;
		
		_workPoint := workPointType.getFirstUnallocatedWorkPoint();
		if _workPoint &lt;&gt; null then
			break;
		endif;
	endforeach;
	
	if _workPointType &lt;&gt; null and _workPoint = null then
		_workPoint := WS_WebServiceAgent@createWorkPoint(_workPointType);
	endif;
epilog

end;</source>
        <Parameter name="_workPoint" type="CM_WorkPoint" usage="output"/>
        <Parameter name="_workPointType" type="CM_WorkPointType" usage="output"/>
        <Parameter name="_wpTypeCode" type="String"/>
    </JadeMethod>
    <JadeMethod name="includeBulkRelease" id="9e515591-f83a-4ce2-b38b-addc66de8821">
        <source>includeBulkRelease(request : WS_BulkReleaseQueryRequest input; 
				   bulkRelease : CM_BulkRelease input; 
				   passport : CM_Passport input) : Boolean;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
03 Oct 2008	cnwkao1	Initial creation - from GTE_ReleaseRequestForm::includeObject
10 Feb 2009 cnwdz2	updated according to RIA.doc specified by KD
06 Mar 2009	cnwkpd1	PAR #19039 - remove isValidObject reference
09 May 2018 cnwma1	ChangeRequest 38519: PEL1 - WP Cargo Release
12 July 2018		jlgrh7 TFS #39309  Release Request Search based on data access group


*/

vars
	carrier 		: CM_Carrier;
	filterAvGrade, 
	brAvGrade 		: CM_MTGrade;
	filterISOGrp, 
	brISOGrp 		: CM_ISOTypeGroup;
	tmpConsignee	: CM_ConsigneeConsignor;
	failedDAC  		: CM_DataAccessController;
	typeDescr		: String;
	avaGrades		: IntegerArray;
	operator		: CM_Operator;
	forwarder		: CM_ConsigneeConsignor;
	time			: Time;
	date			: Date;
	vessel			: CM_Vessel;
	invalidRelease	: Boolean;
	iter 			: Iterator;
	ti			   	: CM_TrackedItem;

begin
	if bulkRelease = null then 
		return false;
	endif;
	
	on Exception do app.handleDeletedObject(exception, bulkRelease, invalidRelease);
	
	if bulkRelease.myTerminal &lt;&gt; app.myPassport.myTerminal then 
		return false;
	endif;
	
	if not bulkRelease.canUserAccessSelf(null,failedDAC,passport) then			//+TFS39309
		return false;
	endif;
	

	if invalidRelease then
		return false;
	endif;
	
	if bulkRelease.type = null then
		return false;
	endif;
	
	if request.view = 4 or request.filterForWorkOrders  then
		if bulkRelease.status &lt;&gt; BR_ACTIVE and bulkRelease.status &lt;&gt; BR_PENDING then
			return false;
		endif;
	elseif request.view = 5 then
		if bulkRelease.status &lt;&gt; BR_ACTIVE and 
		   bulkRelease.status &lt;&gt; BR_PENDING and 
		   bulkRelease.status &lt;&gt; BR_COMPLETE and
		   bulkRelease.status &lt;&gt; BR_ARCHIVE then
			return false;
		endif;
	else 
		if request.view &lt;&gt; bulkRelease.status then
			return false;
		endif;
	endif;
	
	// KO - field doesnt exist for web service spec
	//see JMTUserInterfaceService:getReleaseRequestTypes
	if request.type &lt;&gt; 1000 and request.type &lt;&gt; bulkRelease.type then
		return false;
	endif;

	if request.filterOperator.length() &gt; 0 then 
		operator := app.myRoot.allOperators.getAtKey(request.filterOperator);
		if operator &lt;&gt; null and operator &lt;&gt; bulkRelease.myOperator then
			if bulkRelease.myOperator &lt;&gt; null then
				return false;
			else
				if not bulkRelease.myOperatorGroup.allOperators.includes(operator) then
					return false;
				endif;
			endif;
		endif;
	endif;
	
	if (request.filterCarrier &lt;&gt; null and request.filterCarrier.length() &gt; 0 and 
	    bulkRelease.carrierId.trimRight &lt;&gt; request.filterCarrier) or
	   (request.filterConsignor &lt;&gt; null and request.filterConsignor.length() &gt; 0 and bulkRelease.consigneeCode.trimRight &lt;&gt; request.filterConsignor ) then
	   	return false;
	endif;
	
	if (request.filterFreightForwarder &lt;&gt; null and request.filterFreightForwarder.length() &gt; 0 and 
	    bulkRelease.freightForwarderCode &lt;&gt; request.filterFreightForwarder) then			// PAR 20646
	   	return false;
	endif;

//	if request.filterDateRequestFrom.xasDate().isValid() and request.filterDateRequestTo.xasDate().isValid() then
	if request.filterDateRequestFrom.asDateFromWebInterface().isValid() and request.filterDateRequestTo.asDateFromWebInterface().isValid() then
//		if (not br.createdTime.date.cnEcIsBetween(self.filterDateFrom, self.filterDateTo)) then
		 // ### PAR 10574 should be using requested date
//		if (not bulkRelease.dateRequested.date.cnEcIsBetween(request.filterDateRequestFrom.xasDate(), request.filterDateRequestTo.xasDate())) then
		if (not bulkRelease.dateRequested.date.cnEcIsBetween(request.filterDateRequestFrom.asDateFromWebInterface(), request.filterDateRequestTo.asDateFromWebInterface())) then
			return false;
		endif;
	endif;
	
	// cnwma1 TFS # 38519 09/05/2018
	if request.filterVessel &lt;&gt; null  then
			if bulkRelease.myVoyage = null then
				return false;
			endif;
			vessel := app.myRoot.allVessels[request.filterVessel.toUpper.trimBlanks];
			
			if vessel &lt;&gt; null  then
				if  (not vessel.canUserAccessSelf(null, failedDAC,  passport)) then
					return false;
				endif;
				if bulkRelease.myVoyage.getMyVessel &lt;&gt; vessel then
					return false;
				endif;
			else
				return false;
			endif;
	endif;
	// cnwma1 TFS # 38519 09/05/2018
	if request.filterExternalVoyageCode &lt;&gt; null  then
		if bulkRelease.myVoyage = null then
			return false;
		else
			if (not bulkRelease.myVoyage.canUserAccessSelf(null, failedDAC,  passport)) then
				return false;
			endif;
					
			if bulkRelease.myVoyage.voyageCodeExternal &lt;&gt; request.filterExternalVoyageCode then
				return false;
			endif;
		endif;
	endif;
		
	// PAR 13466
	tmpConsignee := bulkRelease.getConsignee();
	if tmpConsignee &lt;&gt; null and (not tmpConsignee.canUserAccessSelf(null, failedDAC,  passport)) then
		return false;
	endif;
	

	if bulkRelease.carrierId &lt;&gt; null then
		carrier := app.myRoot.allCarriers[bulkRelease.carrierId];
		if carrier &lt;&gt; null then
			if (not carrier.canUserAccessSelf(null, failedDAC, passport)) then
				return false;
			endif;
		endif;
	endif;
	
	if bulkRelease.myOperator &lt;&gt; null then
		if (not bulkRelease.myOperator.canUserAccessSelf(null, failedDAC,  passport)) then
			return false;
		endif;
		
		
	elseif bulkRelease.myOperatorGroup &lt;&gt; null then
		if (not bulkRelease.myOperatorGroup.canUserAccessSelf(null, failedDAC, passport)) then
			return false;
		endif;
	endif;

	//epr TFS 39320 21/6/18
	if request.filterForWorkOrders then
		iter:=  bulkRelease.allTrackedItemsAssigned.createIterator;
		while iter.next(ti) do
			if ti.getWorkOrderDetailOfType( WO_TASK_RELEASE) = null then
				return true;
			endif;					
		endwhile;
		return false;
	endif;
	
	return true;
epilog
	delete iter;
end;</source>
        <Parameter name="request" type="WS_BulkReleaseQueryRequest" usage="input"/>
        <Parameter name="bulkRelease" type="CM_BulkRelease" usage="input"/>
        <Parameter name="passport" type="CM_Passport" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="includeTIForCargoEnq" id="f2e3e716-17d8-4b9c-82fd-43330689b99c">
        <source>includeTIForCargoEnq(request : WS_TrackedItemQueryRequest; 
					 _ti : CM_TrackedItem): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
17 Sep 2008	cnwkao1	Initial creation 
12 Feb 2009 cnwdz2	updated implementation according to RIA.doc
28/06/2022	navsrk20	Task 53922: Implement shipping line in WS_TrackedItemQueryRequest

*/

vars
	failedDAC : CM_DataAccessController;
	invalidTI : Boolean;

begin
	/*
	Date		Who		Reason
	8 Aug. 2008	cnwdz2	Par16734 - Use app.handleDeletedObject() to handle invalid object reference.
	*/
	on Exception do app.handleDeletedObject(exception, _ti, invalidTI);
		
	if request.filterIMEX &lt;&gt; null and _ti.getImExStatus() &lt;&gt; request.filterIMEX.Integer then
		return false;
	endif;
	
	if request.filterTiType &lt;&gt; null and  _ti.cargoType &lt;&gt; request.filterTiType.Integer then
		return false;
	endif;
		
	if request.filterOperator &lt;&gt; null and _ti.operatorCode &lt;&gt; request.filterOperator then
		return false;
	endif;
	
	if request.filterShippingLine &lt;&gt; null and _ti.getShippingLineCode() &lt;&gt; request.filterShippingLine then	//28.06.2022 navsrk20 TFS 53922	// 13/07/2022 navgm20 Tfs 53195
		return false;
	endif;
	
	//Check ISO and ID filters here. Other filters were resolved when
	//entries were copied to the dyna dict
	if request.filterVoyage &lt;&gt; null and _ti.voyageCode &lt;&gt; request.filterVoyage then
		return false;	
	endif;
	
	if request.filterISOType &lt;&gt; null and request.filterISOType &lt;&gt; _ti.getISOType() then
		return false;
	endif;
	
	if request.filterBOL &lt;&gt; null and request.filterBOL &lt;&gt; _ti.billOfLading then
		return false;
	endif;
	
	//10/06/2009 cnwdz2 par19868
	if request.filterBookingRef &lt;&gt; null and not _ti.getBookingReference().isBookingRefMatch(request.filterBookingRef, true)	then
		return false;
	endif;
	
	//cnwmc5 - 16 Sep 2014 - PAR 34888
	if request.filterProduct &lt;&gt; null and request.filterProduct &lt;&gt; _ti.getCargoSubTypeCode() then
		return false;
	endif;
	
	//jlier1 TFS 53644 18/5/22
	if request.filterReeferOnly and not _ti.isReefer then
		return false;
	endif;
	if request.filterDisconnectedOnly and not _ti.getDisconnected then
		return false;
	endif;
	if  request.filterMT &lt;&gt; null then
		if request.filterMT = "true" then	
			if not _ti.isEmpty then
				return false;
			endif;
		elseif request.filterMT = "false" then
			if _ti.isEmpty then
				return false;
			endif;
		endif;
	endif;
	//_ti.billOfLading
	if (not _ti.canUserAccessSelf(null, failedDAC, app.myPassport)) then
		return false;
	endif;
	
	if invalidTI then
		return false;
	endif;
	
	return true;
end;</source>
        <Parameter name="request" type="WS_TrackedItemQueryRequest"/>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="includeTIForCargoQuickView" id="dcefc5ba-b653-4021-8ae7-a15c57afbf5b">
        <source>includeTIForCargoQuickView(request : WS_TrackedItemQueryRequest; 
					 _ti : CM_TrackedItem): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
17 Sep 2008	cnwkao1	Initial creation 
12 Feb 2009 cnwdz2	updated implementation according to RIA.doc

*/

vars
	failedDAC : CM_DataAccessController;
	invalidTI : Boolean;
	checkAccess		: Boolean;
begin
	/*
	Date		Who		Reason
	8 Aug. 2008	cnwdz2	Par16734 - Use app.handleDeletedObject() to handle invalid object reference.
	*/
	on Exception do app.handleDeletedObject(exception, _ti, invalidTI);
		
	if request.filterIMEX &lt;&gt; null and _ti.getImExStatus() &lt;&gt; request.filterIMEX.Integer then
		return false;
	endif;
	
	if request.filterTiType &lt;&gt; null and  _ti.cargoType &lt;&gt; request.filterTiType.Integer then
		return false;
	endif;
	
	//epr TFS 7725 8/11/17 should check this permission before checking access
	checkAccess := not app.getMyUser.canDo(app.myPassport.myTerminal, PmCargoQuickViewNoDAC);

	if checkAccess and (not _ti.canUserAccessSelf(null, failedDAC, app.myPassport)) then
		return false;
	endif;
	
	if invalidTI then
		return false;
	endif;
	
	return true;
end;</source>
        <Parameter name="request" type="WS_TrackedItemQueryRequest"/>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="includeTIForPreNotes" id="cff25b11-f466-4266-9ed1-724d1c19df2f">
        <source>includeTIForPreNotes(request : WS_TrackedItemQueryRequest;
					 _ti : CM_TrackedItem) : Boolean;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
12 September 2008	cnwkao1	Initial creation 
28/06/2022	navsrk20	Task 53922: Implement shipping line in WS_TrackedItemQueryRequest

*/

vars
	failedDAC	: CM_DataAccessController;
    	
begin

	if _ti.state &lt;&gt; TI_STATE_NOTIFIED then
		return false;
	endif;
	
	//epr TFS 378932 22/2/18 transport mode can be null but still need to check the other stuff
	if (request.filterTransportMode = TI_TRANSMODE_ROAD_STR &amp; ' &amp; ' &amp; TI_TRANSMODE_RAIL_STR) then
		if _ti.receiptTransportMode &lt;&gt; TI_TRANSMODE_ROAD and _ti.receiptTransportMode &lt;&gt;  TI_TRANSMODE_RAIL then
			return false;
		endif;
	endif;
	
	if request.filterTransportMode = TI_TRANSMODE_ROAD_STR and _ti.receiptTransportMode &lt;&gt; TI_TRANSMODE_ROAD then
		return false;
	endif;
	
	if request.filterTransportMode = TI_TRANSMODE_RAIL_STR and _ti.receiptTransportMode &lt;&gt; TI_TRANSMODE_RAIL  then
		return false;
	endif;
		
	
	if (request.filterDateFrom.asDateFromWebInterface().isValid() and _ti.createdTime.date &lt; request.filterDateFrom.asDateFromWebInterface() )	//26 Oct 2012	NDL	Par 30622
	or (request.filterDateTo.asDateFromWebInterface().isValid() and _ti.createdTime.date &gt; request.filterDateTo.asDateFromWebInterface() ) then	//26 Oct 2012	NDL	Par 30622
		return false;
	//elseif request.filterId &lt;&gt; null and not _ti.id.startsWith(request.filterId.toUpper()) then
	//	return false;
	//03 May 2013	NDL	Par 31506 - id or alternate id match
	elseif request.filterId &lt;&gt; null and (  not _ti.id.startsWith( request.filterId.toUpper ) and not _ti.alternativeId.startsWith( request.filterId.toUpper ) ) then
		return false;
		
	elseif request.filterOperator &lt;&gt; null and request.filterOperator &lt;&gt; _ti.operatorCode then
		return false;
	elseif request.filterBookingRef &lt;&gt; null and (not _ti.bookingReference.startsWith(request.filterBookingRef.toUpper())) then
		return false;
	elseif request.filterConsignee &lt;&gt; null and request.filterConsignee &lt;&gt; _ti.consignee.trimBlanks then
		return false;
	elseif request.filterConsignor &lt;&gt; null and request.filterConsignor &lt;&gt; _ti.consignor.trimBlanks then			
		return false;
	elseif request.filterExcludeLocation &lt;&gt; null and request.filterExcludeLocation = _ti.locationId then
		return false;
	//KO - not offering this filter option
	//elseif request.filtFreightForwarderCode &lt;&gt; null and request.filtFreightForwarderCode &lt;&gt; _ti.freightForwarderCode.trimBlanks then			
	//	return false;	
	elseif (request.filterIMEX &lt;&gt; null and _ti.getImExStatus() &lt;&gt; request.filterIMEX.Integer) then
		return false;
	elseif request.filterShippingLine &lt;&gt; null and _ti.getShippingLineCode() &lt;&gt; request.filterShippingLine then	//28.06.2022 navsrk20 TFS 53922  //13/07/2022 navgm20 Tfs 53195
		return false;
	endif;

	
	
	return _ti.canUserViewMe(null, app.myPassport, true, true, false, true, false, failedDAC);	//08 Nov 2017	NDL	Unit Test picked up this was in the wrong place.
	
	//return false;
		

end;</source>
        <Parameter name="request" type="WS_TrackedItemQueryRequest"/>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="includeTIForReleaseImports" id="9bff4091-7da2-4de0-bbeb-c61c6f944814">
        <source>includeTIForReleaseImports(request : WS_TrackedItemQueryRequest;
						   ti : CM_TrackedItem) : Boolean;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
12 September 2008	cnwkao1	Initial creation - based on GTE_FullReleaseForm::includeObject
16 feb 2009 cnwdfz2 updated the implementation
28/06/2022	navsrk20	Task 53922: Implement shipping line in WS_TrackedItemQueryRequest
*/

vars
	failedDAC	: CM_DataAccessController;
begin	
	if ti = null then
		return false;
	endif;
	
	if (not ti.canUserViewMe(null, app.myPassport, true, true, true, false, true, failedDAC)) then
		return false;
	endif;

	//if not ti.isImport then
	//	return false;	
	//endif;
	
	if ti.site &lt;&gt; TI_SITE_ONSITE then
		return false;
	endif;

	if ti.isChild() then
		return false;
	endif;
	
	//if request.filterId &lt;&gt; null and not ti.id.startsWith(request.filterId.toUpper()) then
	//	return false;
	//endif;
	//03 May 2013	NDL	Par 31506 - id or alternate id match
	if request.filterId &lt;&gt; null then
		if not ti.id.startsWith( request.filterId.toUpper )
		and not ti.alternativeId = request.filterId.toUpper
		then
			return false;
		endif;
	endif;
	
	if request.filterCarrier &lt;&gt; null and ti.releaseCarrier.trimRight &lt;&gt; request.filterCarrier then
		return false;
	endif;
	
	if request.filterConsignee &lt;&gt; null and ti.consignee.trimRight &lt;&gt; request.filterConsignee then 
		return false;
	endif;
	
	if request.filterOperator &lt;&gt; null and ti.operatorCode.trimRight &lt;&gt; request.filterOperator then
		return false;
	endif;
	
	if request.filterTiType.Integer &lt;&gt; TI_CargoType_Null and ti.cargoType &lt;&gt; request.filterTiType.Integer then 
		return false;
	endif;
	
	if  request.filterVoyage &lt;&gt; null and ti.voyageCode.trimRight &lt;&gt; request.filterVoyage then
	   	return false;
	endif;
	
	if request.filterShippingLine &lt;&gt; null and ti.getShippingLineCode() &lt;&gt; request.filterShippingLine then		//28.06.2022 navsrk20 TFS 53922  //13/07/2022 navgm20 Tfs 53195
		return false;
	endif;

	return true;
end;</source>
        <Parameter name="request" type="WS_TrackedItemQueryRequest"/>
        <Parameter name="ti" type="CM_TrackedItem"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="postCustomerCheckEntities" id="950d8e4a-0417-4617-98fc-0950dce012dc">
        <options>4</options>
        <source>postCustomerCheckEntities(_entity: WS_CustomerObject; _entityType: Type; _realDebtor: CM_Debtor; _cmifDebtor: CMIF_DebtorNode io;
								_isUpdate: Boolean; _blankEntityFound: Boolean io; _updateExistingEntity: Boolean; _proxiesToDelete: CM_ObjectArray input) typeMethod;
/*

Purpose:			Check and Create any Related Entities for the Debtor provided

Parameters:			

Return Value:		

Date			Who		Reason
13 June 2023	navmd1	Initial creation TFS 57447 Simplify POST /Customer method

*/

vars
	description,
	code,
	niceName			: String;
	realEntity			: CM_Object;
	collectionSize		: Integer;
	realEntityCode		: String;
	isOk				: Boolean;
	
	pxyCarrier			: CM_Carrier;
	wsCarrier			: WS_RestCarrierObject;
	
	pxyConsigneeor		: CM_ConsigneeConsignor;
	wsConsigneeor		: WS_RestConsignee_orObject;
	
	pxyCustomsAgent		: CM_CustomsAgent;
	wsCustomsAgent		: WS_RestCustomsAgentObject;
	
	pxyOperator			: CM_Operator;
	wsOperator			: WS_RestOperatorObject;
	
	pxyShippingLine		: CM_ShippingLine;
	wsShippingLine		: WS_RestShippingLineObject;
	
	pxyStevedore		: CM_Stevedore;
	wsStevedore			: WS_RestStevedoreObject;
begin
	if _entityType = null then
		app.raiseUnexpectedProgramError(selfType.class.name, method.name, "Entity Type is mandatory but was not provided");
		return;
	endif;
	
	if _entityType = WS_RestCarrierObject then
		wsCarrier := _entity.WS_RestCarrierObject;
		code := wsCarrier.id;
		description := wsCarrier.description;
		niceName := app.getErrorString(Carrier);
	elseif _entityType = WS_RestConsignee_orObject then
		wsConsigneeor := _entity.WS_RestConsignee_orObject;
		code := wsConsigneeor.id;
		description := wsConsigneeor.description;
		niceName := app.getErrorString(Consignee_Consignor);
	elseif _entityType = WS_RestCustomsAgentObject then
		wsCustomsAgent := _entity.WS_RestCustomsAgentObject;
		code := wsCustomsAgent.id;
		description := wsCustomsAgent.description;
		niceName := app.getErrorString(CM_Customs_Agent);
	elseif _entityType = WS_RestOperatorObject then
		wsOperator := _entity.WS_RestOperatorObject;
		code := wsOperator.id;
		description := wsOperator.description;
		niceName := app.getErrorString(Operator);
	elseif _entityType = WS_RestShippingLineObject then
		wsShippingLine := _entity.WS_RestShippingLineObject;
		code := wsShippingLine.id;
		description := wsShippingLine.description;
		niceName := app.getErrorString(ShippingLine);
	elseif _entityType = WS_RestStevedoreObject then
		wsStevedore := _entity.WS_RestStevedoreObject;
		code := wsStevedore.id;
		description := wsStevedore.description;
		niceName := app.getErrorString(Stevedore);
	endif;
	
	if description = null then
		app.raiseCMException2(ERR_INVALID_VALUE,niceName &amp; " Description","Description must be entered.", null, null);
		return;
	endif;
	
	// If the debtor already exists, then check any existing related entities
	if code = null and _isUpdate then
		if _blankEntityFound then
			process.isMPD;	// TODO: Raise proper error
			app.writeLog("More than one " &amp; niceName &amp; " with a blank id, but one or more " &amp; niceName &amp; "(s) already exists on this debtor. Unable to determine which one to update, and which one to create", LogERROR);
			return;
		endif;
		_blankEntityFound := true;
		
		if _entityType = WS_RestCarrierObject then
			collectionSize := _realDebtor.allCarriers.size;
			realEntity := _realDebtor.allCarriers.first;
			if realEntity &lt;&gt; null then
				realEntityCode := realEntity.CM_Carrier.code;
			endif;
		elseif _entityType = WS_RestConsignee_orObject then
			collectionSize := _realDebtor.consignors.size;
			realEntity := _realDebtor.consignors.first;
			if realEntity &lt;&gt; null then
				realEntityCode := realEntity.CM_ConsigneeConsignor.code;
			endif;
		elseif _entityType = WS_RestCustomsAgentObject then
			collectionSize := _realDebtor.allCustomsAgents.size;
			realEntity := _realDebtor.allCustomsAgents.first;
			if realEntity &lt;&gt; null then
				realEntityCode := realEntity.CM_CustomsAgent.code;
			endif;
		elseif _entityType = WS_RestOperatorObject then
			collectionSize := _realDebtor.operators.size;
			realEntity := _realDebtor.operators.first;
			if realEntity &lt;&gt; null then
				realEntityCode := realEntity.CM_Operator.code;
			endif;
		elseif _entityType = WS_RestShippingLineObject then
			collectionSize := _realDebtor.allShippingLines.size;
			realEntity := _realDebtor.allShippingLines.first;
			if realEntity &lt;&gt; null then
				realEntityCode := realEntity.CM_ShippingLine.code;
			endif;
		elseif _entityType = WS_RestStevedoreObject then
			collectionSize := _realDebtor.allStevedores.size;
			realEntity := _realDebtor.allStevedores.first;
			if realEntity &lt;&gt; null then
				realEntityCode := realEntity.CM_Stevedore.code;
			endif;
		endif;
		
		if collectionSize &gt; 1 then
			//raise an exception
			app.raiseCMException(No_matches_found, null, null);
			app.writeLog(method.qualifiedName &amp; "Rule Failed : Code is null and more than one linked related entity", LogDEBUG);
			return;
		else
			if realEntity &lt;&gt; null then
				// If we have a 1-to-1 match (aka, EUP) then just update the existing carrier
				code := realEntityCode;
			endif;
		endif;
	endif;
	
	// do we have a real entity already
	if _entityType = WS_RestCarrierObject then
		realEntity := app.myRoot.allCarriers[code];
		if realEntity = null then
			app.writeLog(method.qualifiedName &amp; Tab &amp; "Creating a new Carrier " &amp; code &amp; ":" &amp; description, LogDEBUG);
			create pxyCarrier transient;
			pxyCarrier.setProxy(code, description, null, false, wsCarrier.rail, wsCarrier.road, wsCarrier.subCarrier,
									_cmifDebtor.myPxyDebtorNode.CM_Debtor, 0, null, null);
		else
			app.writeLog(method.qualifiedName &amp; Tab &amp; "Updating an existing Carrier " &amp; code &amp; ":" &amp; description, LogDEBUG);
			pxyCarrier := app.createUpdateProxy(realEntity).CM_Carrier;
			pxyCarrier.setDebtor(_cmifDebtor.myPxyDebtorNode.CM_Debtor);
			if _updateExistingEntity then
				pxyCarrier.setDescriptionAndFlags(description, wsCarrier.rail, wsCarrier.road, wsCarrier.subCarrier);
			endif;
		endif;
		
		realEntity := _cmifDebtor.allCarriers[code];
		if realEntity &lt;&gt; null then
			_cmifDebtor.allCarriers.remove(realEntity.CM_Carrier);
		endif;
		_cmifDebtor.allCarriers.add(pxyCarrier);
		_proxiesToDelete.add(pxyCarrier);
	
	elseif _entityType = WS_RestConsignee_orObject then
		realEntity := app.myRoot.allConsigneeConsignors[code];
		if realEntity = null then
			app.writeLog(method.qualifiedName &amp; Tab &amp; "Creating a new Consignee/Consignor " &amp; code &amp; ":" &amp; description, LogDEBUG);
			create pxyConsigneeor transient;
			pxyConsigneeor.setProxy(code, description, false, false, null, null, 0, 0, null, _cmifDebtor.myPxyDebtorNode.CM_Debtor, false,
									wsConsigneeor.consignee, wsConsigneeor.consignor, false, null, null, null, false, false,false);
		else
			app.writeLog(method.qualifiedName &amp; Tab &amp; "Updating an existing Consignee/Consignor " &amp; code &amp; ":" &amp; description, LogDEBUG);
			pxyConsigneeor := app.createUpdateProxy(realEntity).CM_ConsigneeConsignor;
			pxyConsigneeor.setDebtor(_cmifDebtor.myPxyDebtorNode.CM_Debtor);	
			if _updateExistingEntity then
				pxyConsigneeor.setDescriptionAndFlags(description, wsConsigneeor.consignee, wsConsigneeor.consignor);
			endif;
		endif;
		
		realEntity := _cmifDebtor.allConsignors[code];
		if realEntity &lt;&gt; null then
			_cmifDebtor.allConsignors.remove(realEntity.CM_ConsigneeConsignor);
		endif;
		_cmifDebtor.allConsignors.add(pxyConsigneeor);
		_proxiesToDelete.add(pxyConsigneeor);
		
	elseif _entityType = WS_RestCustomsAgentObject then
		realEntity := app.myRoot.allCustomsAgents[code];
		if realEntity = null then
			app.writeLog(method.qualifiedName &amp; Tab &amp; "Creating a new Customs Agent " &amp; code &amp; ":" &amp; description, LogDEBUG);
			create pxyCustomsAgent transient;
			pxyCustomsAgent.setProxy(code, description, false, _cmifDebtor.myPxyDebtorNode.CM_Debtor);
		else
			app.writeLog(method.qualifiedName &amp; Tab &amp; "Updating an existing Customs Agent " &amp; code &amp; ":" &amp; description, LogDEBUG);
			pxyCustomsAgent := app.createUpdateProxy(realEntity).CM_CustomsAgent;					
			if _updateExistingEntity then
				pxyCustomsAgent.setProxy(code, description, false, _cmifDebtor.myPxyDebtorNode.CM_Debtor);
			else
				pxyCustomsAgent.setProxy(code, pxyCustomsAgent.name, false, _cmifDebtor.myPxyDebtorNode.CM_Debtor);
			endif;
		endif;
		
		realEntity := _cmifDebtor.allCustomsAgents[code];
		if realEntity &lt;&gt; null then
			_cmifDebtor.allCustomsAgents.remove(realEntity.CM_CustomsAgent);
		endif;
		_cmifDebtor.allCustomsAgents.add(pxyCustomsAgent);
		_proxiesToDelete.add(pxyCustomsAgent);
		
	elseif _entityType = WS_RestOperatorObject then
		realEntity := app.myRoot.allOperators[code];
		if realEntity = null then
			app.writeLog(method.qualifiedName &amp; Tab &amp; "Creating a new Operator " &amp; code &amp; ":" &amp; description, LogDEBUG);
			create pxyOperator transient;
			pxyOperator.setProxy( code, description, false,	null, null, _cmifDebtor.myPxyDebtorNode.CM_Debtor,
								false, false, false, false, false, false, false, false, false, false, null, null, null, 
								false, false, false, null, null, null, false, false	);
		else
			app.writeLog(method.qualifiedName &amp; Tab &amp; "Updating an existing Operator " &amp; code &amp; ":" &amp; description, LogDEBUG);
			pxyOperator := app.createUpdateProxy(realEntity).CM_Operator;
			pxyOperator.setDebtor(_cmifDebtor.myPxyDebtorNode.CM_Debtor);
			if _updateExistingEntity then
				pxyOperator.setDescription(description);
			endif;
		endif;
		
		realEntity := _cmifDebtor.allOperators[code];
		if realEntity &lt;&gt; null then
			_cmifDebtor.allOperators.remove(realEntity.CM_Operator);
		endif;
		_cmifDebtor.allOperators.add(pxyOperator);
		_proxiesToDelete.add(pxyOperator);
	
	elseif _entityType = WS_RestShippingLineObject then
		realEntity := app.myRoot.allShippingLines[code];
		if realEntity = null then
			app.writeLog(method.qualifiedName &amp; Tab &amp; "Creating a new Shipping Line " &amp; code &amp; ":" &amp; description , LogDEBUG);
			create pxyShippingLine transient;
			pxyShippingLine.setProxy(code, description, false, 0, _cmifDebtor.myPxyDebtorNode.CM_Debtor);
		else
			app.writeLog(method.qualifiedName &amp; Tab &amp; "Updating an existing Shipping Line " &amp; code &amp; ":" &amp; description, LogDEBUG);
			pxyShippingLine := app.createUpdateProxy(realEntity).CM_ShippingLine;
			if _updateExistingEntity then
				pxyShippingLine.setProxy(code, description, pxyShippingLine.isNotAvailableForEntry, pxyShippingLine.colour, _cmifDebtor.myPxyDebtorNode.CM_Debtor);
			else
				pxyShippingLine.setProxy(code, pxyShippingLine.description, pxyShippingLine.isNotAvailableForEntry, pxyShippingLine.colour, _cmifDebtor.myPxyDebtorNode.CM_Debtor);
			endif;
		endif;
		
		realEntity := _cmifDebtor.allShippingLines[code];
		if realEntity &lt;&gt; null then
			_cmifDebtor.allShippingLines.remove(realEntity.CM_ShippingLine);
		endif;
		_cmifDebtor.allShippingLines.add(pxyShippingLine);
		_proxiesToDelete.add(pxyShippingLine);
		
	elseif _entityType = WS_RestStevedoreObject then
		realEntity := app.myRoot.allStevedores[code];
		if realEntity = null then
			app.writeLog(method.qualifiedName &amp; Tab &amp; "Creating a new Stevedore " &amp; code &amp; ":" &amp; description, LogDEBUG);
			create pxyStevedore transient;
			pxyStevedore.setProxy(code, description, false, _cmifDebtor.myPxyDebtorNode.CM_Debtor);
		else
			app.writeLog(method.qualifiedName &amp; Tab &amp; "Updating an existing Stevedore " &amp; code &amp; ":" &amp; description, LogDEBUG);
			pxyStevedore := app.createUpdateProxy(realEntity).CM_Stevedore;
			if _updateExistingEntity then
				pxyStevedore.setProxy(code, description, pxyStevedore.notAvailableForEntry, _cmifDebtor.myPxyDebtorNode.CM_Debtor);
			else
				pxyStevedore.setProxy(code, pxyStevedore.description, pxyStevedore.notAvailableForEntry, _cmifDebtor.myPxyDebtorNode.CM_Debtor);
			endif;
		endif;
		
		realEntity := _cmifDebtor.allStevedores[code];
		if realEntity &lt;&gt; null then
			_cmifDebtor.allStevedores.remove(realEntity.CM_Stevedore);
		endif;
		_cmifDebtor.allStevedores.add(pxyStevedore);
		_proxiesToDelete.add(pxyStevedore);
	endif;
	
	isOk := true;
epilog
	if not isOk then
		delete pxyCarrier;
		delete pxyConsigneeor;
		delete pxyCustomsAgent;
		delete pxyOperator;
		delete pxyShippingLine;
		delete pxyStevedore;
	endif;
end;</source>
        <Parameter name="_entity" type="WS_CustomerObject"/>
        <Parameter name="_entityType" type="Type"/>
        <Parameter name="_realDebtor" type="CM_Debtor"/>
        <Parameter name="_cmifDebtor" type="CMIF_DebtorNode" usage="io"/>
        <Parameter name="_isUpdate" type="Boolean"/>
        <Parameter name="_blankEntityFound" type="Boolean" usage="io"/>
        <Parameter name="_updateExistingEntity" type="Boolean"/>
        <Parameter name="_proxiesToDelete" type="CM_ObjectArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setupTiSelectorQuery" id="7006e304-1578-41ed-ae54-be9b2766d8d4">
        <source>setupTiSelectorQuery( 	_request : WS_TrackedItemQueryRequest;
						_exactId : Boolean;
						_enqController : CM_EnqControllerTI input;
						_qDef : CM_QueryDefinition output
						);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29/01/2014	cnwndl1	Initial creation	Par 33347
24/08/2018	jlgdap1	TFS 39964 PEL1 Hold Job Ops Loading Changes
06/09/2018	jlgdap1	TFS 40157 PEL1 Change Voyage Work Order
12/02/2019	jlgdap1	TFS 43062 PEL1 Container Services - Changed in Web Portal
1/05/2019 	JLGNS1	ChangeRequest 42504: SPT - Reefer Monitoring Display MT Filtering
09/05/2019	jlgdap1	TFS 44653 SNO Missing Tranship cargo in Job Lander application
21/10/2019	jlgdap1	TFS 46728 JMT Web Portal - Cargo Requests
06/07/2020  cnwma1  Bug 49718: MTN - Rail Lander - Load - Cargo Display
25/11/2020	jlizm1	TFS 52028 Work hold jobs in handheld app
28/06/2022	navsrk20	Task 53922: Implement shipping line in WS_TrackedItemQueryRequest
12 Aug 2022 navtnr20 Bug 52451: MTN - WebServices not using getObjectOfTypeFromOid
14 Feb 2023	navak20 ChangeRequest 56459: MTN - add mark number to filter
*/

vars
	
	terminal		: CM_Terminal;
	obj				: Object;
	
	cargoTypeId 	: Integer;
	tmpId 			: String;
	terminalArea 	: CM_TerminalArea;
	lc 				: CM_LocationsController;
	cargoType 		: CM_CargoType;
	operator 		: CM_Operator;
	isoType 		: CM_ISOType;
	imexCode 		: CM_IMEXStatus;
	imexString		: String;
	imexStatuses 	: StringArray;
	allIMEXs		: IntegerArray;
	voyage 			: CM_Voyage;
	stateArray 		: IntegerArray;
	criteriaHolder	: CM_QueryCriteriaLineHolder;
	product 		: CM_Product;
	train			: CM_Train;
	availGrades		: IntegerArray;
	availGrade		: String;
	cmifID 			: CMIF_IDConversion;	//06 Jul 2016	NDL	TFS 2275
	dateFrom	 	: Date;
	dateTo			: Date;
	dateArray		: DateArray;
	filterAVGrade 	: Boolean;
	voyageJob 		: CM_VoyageJob;
	shippingLine	: CM_ShippingLine;	//28.06.2022 navsrk20 TFS 53922
begin
	
	//get the filter values
	terminal := app.myPassport.myTerminal;
	cargoTypeId := _request.filterTiType.Integer;
	if cargoTypeId &lt;&gt; null then
		cargoType := app.myRoot.allCargoTypesById[ cargoTypeId ];
	endif;
	
	
	if _request.filterTerminalArea &lt;&gt; null then
		terminalArea := terminal.allTerminalAreas[_request.filterTerminalArea];
	endif;
	if _request.filterOperator &lt;&gt; null then
		operator := app.myRoot.allOperators[_request.filterOperator];
	endif;
	if _request.filterShippingLine &lt;&gt; null then		//TFS 53922
		shippingLine := app.myRoot.allShippingLines[_request.filterShippingLine];
	endif;
	if _request.filterYardLocation &lt;&gt; null then
	//Start 30.09.2022 navtnr20 52451
		//obj := _request.filterYardLocation.asOid;
		lc := app.myPassport.getObjectOfTypeFromOid(_request.filterYardLocation,CM_LocationsController).CM_LocationsController;
		/*if obj &lt;&gt; null then		
			if obj.isKindOf(CM_LocationsController) then
				lc := obj.CM_LocationsController;
				
				if _request.filterTerminalArea = null then
					terminalArea := lc.myTerminalArea;
				endif;
			endif;
		endif;*/
		if _request.filterTerminalArea = null then
			terminalArea := lc.myTerminalArea;
		endif;
		//End 12.08.2022 navtnr20 52451
	endif;
	if _request.filterId &lt;&gt; null then
		
		if _exactId then
		//	tmpId:=_request.filterId.toUpper();
			tmpId:=_request.filterId.toUpper()[1:30];	//26 Feb 2020	NDL	TFS 48700
		else
	//	tmpId := _request.filterId.toUpper();
		//06 Jul 2016	NDL	TFS 2275
			create cmifID transient;
			cmifID.scannedValue :=  _request.filterId.toUpper();
			cmifID.myTerminal := terminal;
			cmifID.cargoType := cargoTypeId;
			//if app.name = "JMTUnitTest" then
			if app.isJMTUnitTest() then								// 18/10/2016 cnwmh5
				cmifID.callerName := "UT";	//18 Aug 2016	NDL	TFS 2567 
			else
				cmifID.callerName := null;	//18 Aug 2016	NDL	TFS 2567 - in 8.4.2.120, if we keep this crap, populate this.
			endif;
		//	tmpId := app.convertScannedCargoId( null, null, false, cmifID );
			tmpId := app.convertScannedCargoId( null, null, false, cmifID )[1:30];	//26 Feb 2020	NDL	TFS 48700
		endif;
	endif;
	if _request.filterISOType &lt;&gt; null then
		isoType := app.myRoot.allISOTypes[_request.filterISOType];
		if isoType &lt;&gt; null then
			cargoTypeId := TI_CargoType_Container;
			cargoType := app.myRoot.allCargoTypesById[ cargoTypeId ];
		endif;
	endif;
	//epr tfs 38646 24/5/18 if no cargo type specified would use trackedItem mode and get errors
	filterAVGrade:=_request.filterAvailabilityGrades &lt;&gt; null and _request.filterAvailabilityGrades.size &gt; 0;
	if cargoType = null and filterAVGrade then
		cargoTypeId := TI_CargoType_Container;
		cargoType := app.myRoot.allCargoTypesById[ cargoTypeId ];
	elseif cargoType &lt;&gt; null and filterAVGrade then
		if cargoType.id &lt;&gt; TI_CargoType_Container then
			filterAVGrade:=false;
		endif;
		
	endif;
	
	
	create allIMEXs transient;
	if _request.filterIMEX &lt;&gt; null then
		//epr TFS 7800 cargo lander wanted filter on more than one status i,e export/tranship or import/tranship
		create imexStatuses transient;
		_request.filterIMEX.getTokensForDelimiter(",",imexStatuses);
		foreach imexString in imexStatuses do
			if imexString = null then
				continue;
			endif;
			imexCode := app.myRoot.allImexStatuses[ imexString.Integer ];
			if imexCode &lt;&gt; null and imexCode.code &lt;&gt; TI_IMEX_STATUS_NULL  then
				allIMEXs.add(imexCode.code);
			endif;
		endforeach;
		
	endif;
	if _request.filterVoyage &lt;&gt; null then
		voyage := terminal.lookupVoyage(_request.filterVoyage, null, false);
	endif;
	
	//cnwmc5 - 16 Sep 2014 - PAR 34888
	if _request.filterProduct &lt;&gt; null and cargoType &lt;&gt; null then
		product := cargoType.getProductFromCode(_request.filterProduct);
	endif;
	
	if _request.filterAssignedTrain &lt;&gt; null then
		//Start 30.09.2022 navtnr20 52451
		//obj := _request.filterAssignedTrain.asOid;
		train := app.myPassport.getObjectOfTypeFromOid(_request.filterAssignedTrain,CM_Train).CM_Train;
		/*if obj &lt;&gt; null and obj.isKindOf(CM_Train) then
			train := obj.CM_Train;
		endif;*/
		//End 30.09.2022 navtnr20 52451
	endif;
	
	
	//create criteria stuff on the selector query object.
	create _enqController.allObjects as CM_TIArray transient;			//cnwmc5 - 24 Sep 2014 - PAR 34927
	create criteriaHolder transient;
	_enqController.myTerminal := terminal;
	_enqController.myCriteriaLineHolder := criteriaHolder;
	
	//cnwmc5 - 19 Sep 2014 - PAR 34927
	if _request.maxReturnedItems &gt; 0 then
		_enqController.numItemsFoundLimit := _request.startFrom + _request.maxReturnedItems;
	endif;
	
	if cargoTypeId = TI_CargoType_Container  then 
		_qDef := app.myRoot.allQueryDefinitionObjects[CM_QueryDefinition.TrackedItem_Query_Type,TI_CargoType_Container];
	else
		
		_qDef := app.myRoot.allQueryDefinitionObjects[CM_QueryDefinition.TrackedItem_Query_Type,null];
	
	endif;
	
	
	//create the individual criteria query lines
	self.doCreateCriteriaLine(_qDef, criteriaHolder, CM_TrackedItem::myTerminal.name, CM_QueryOperator.Operator_Equal, terminal);
	if cargoType &lt;&gt; null then 
		self.doCreateCriteriaLine(_qDef, criteriaHolder, CM_TrackedItem::cargoType.name, CM_QueryOperator.Operator_Equal, cargoType);
	endif;
	if tmpId &lt;&gt; null then
		//epr TFS 7380 16/10/17 
		if _exactId then
			self.doCreateCriteriaLine(_qDef, criteriaHolder, CM_TrackedItem::id.name, CM_QueryOperator.Operator_Equal, tmpId);
		else
			self.doCreateCriteriaLine(_qDef, criteriaHolder, CM_TrackedItem::id.name, CM_QueryOperator.Operator_StartsOrEndsWith, tmpId);
		endif;
	endif;	
	if lc &lt;&gt; null then
		if lc.isWagon then
			// 1/11/2017 - copied code from MOB_HHCargoFind to make searches for wagon cargo the same when requesting via web service
			// so it finds all cargo on the wagon. 02 Oct 2014	NDL - Par 34981  // 13 Mar 2015	NDL	Par 35828
			// TFS 2450 28/07/2016 take the RailDefaultWCIdFormat configuration setting into account - is either location id or wagon id
			//epr TFS 37241 5/3/17 tfs 2450 never fixed the problem doesn't look like it was ever tested
			//jlier1 TFS 65100 9/7/24 - noticed this wasn't working
			if terminal.getConfig( RailDefaultWCIdFormat ).Integer = Rail_UPSP_Int then	
				self.doCreateCriteriaLine(_qDef, criteriaHolder,CM_TrackedItem::locationId.name, CM_QueryOperator.Operator_StartsWith,lc.CM_WagonController.myWagon.id);
			else
				self.doCreateCriteriaLine(_qDef, criteriaHolder,CM_TrackedItem::locationId.name, CM_QueryOperator.Operator_StartsWith, lc.CM_WagonController.myWagon.getLocationId());
			endif;
		else	
			self.doCreateCriteriaLine(_qDef, criteriaHolder, CM_TrackedItem::locationId.name, CM_QueryOperator.Operator_Equal, lc.getFullId);
		endif;
	else
		//epr TFS 44093 9/7/19 helping JBL run get cargo on yard location id
		if _request.filterYardLocation &lt;&gt; null then
			self.doCreateCriteriaLine(_qDef, criteriaHolder, CM_TrackedItem::locationId.name, CM_QueryOperator.Operator_Equal, _request.filterYardLocation);
		endif;
	endif;
	if terminalArea &lt;&gt; null then
		self.doCreateCriteriaLine(_qDef, criteriaHolder, CM_TrackedItem::myTerminalArea.name, CM_QueryOperator.Operator_Equal, terminalArea);
	endif;
	if operator &lt;&gt; null then
		self.doCreateCriteriaLine(_qDef, criteriaHolder, CM_TrackedItem::operatorCode.name, CM_QueryOperator.Operator_Equal, operator);
	endif;
	if shippingLine &lt;&gt; null then	//TFS 53922
		self.doCreateCriteriaLine(_qDef, criteriaHolder, CM_TrackedItem::getShippingLineCode.name, CM_QueryOperator.Operator_Equal, shippingLine);
	endif;
	if train &lt;&gt; null then
		self.doCreateCriteriaLine(_qDef, criteriaHolder, CM_TrackedItem::myTrainAssigned.name, CM_QueryOperator.Operator_Equal, train);
	endif;
	if _request.filterIntendedReleaseMode &lt;&gt; null then
		self.doCreateCriteriaLine(_qDef, criteriaHolder, CM_TrackedItem::intendedReleaseMode.name, CM_QueryOperator.Operator_Equal, _request.filterIntendedReleaseMode);
	endif;
	
	//epr TFS 2626 19/10/16 - bug where we are passing in the site but was searching by state
	//
 	if _request.filterSite.Integer &gt; 0 then
		// TFS 39964 For Cargo Lander / Job Lander Load on a PEL or Inaportnet voyage, we want onsite and prenoted cargo
		if _request.filterSite.Integer = TI_STATE_NORMAL 
		and _request.context.isOneOf(_request.Context_CargoLanderLoad, _request.Context_JobLanderLoad) 
		and voyage &lt;&gt; null 
		and ( voyage.isMTNWOVoyageProcess) then //11 Oct 2021 jlier1	TFS 51963 removed inaportnet
			create stateArray transient;
			stateArray.add(TI_STATE_NORMAL);
			stateArray.add(TI_STATE_NOTIFIED);
			self.doCreateCriteriaLine(_qDef, criteriaHolder, CM_TrackedItem::state.name, CM_QueryOperator.Operator_IsOneOf, stateArray);
		elseif _request.filterSite.Integer = TI_STATE_NORMAL and _request.context = _request.Context_ChangeVoyage then						// TFS 40157
			create stateArray transient;																									// TFS 40157
			stateArray.add(TI_STATE_NORMAL);																								// TFS 40157
			stateArray.add(TI_STATE_NOTIFIED);																								// TFS 40157
			self.doCreateCriteriaLine(_qDef, criteriaHolder, CM_TrackedItem::state.name, CM_QueryOperator.Operator_IsOneOf, stateArray);	// TFS 40157
		else
			//05 Feb 2019 NDL - Eventhough the field is called "site" it is ACTUALLY 'state', the combo in the RIA is populated with the state integers
			// via CM_ContainerEnqForm::getSiteStateFromString and these values are different for pre-notes and on-ship values.
			// Also site can't do interterm transfer statuses
			self.doCreateCriteriaLine(_qDef, criteriaHolder, CM_TrackedItem::state.name, CM_QueryOperator.Operator_Equal,  _request.filterSite.Integer);
		endif;
	else
		create stateArray transient;
		stateArray.add(TI_STATE_NORMAL);
		stateArray.add(TI_STATE_NOTIFIED);
		stateArray.add(TI_STATE_ONSHIP);
		stateArray.add(TI_STATE_OFFSITE);			//cnwmc5 - 4 Feb 2015 - PAR 35615
		if app.myRoot.isInterTerminalTransferEnabled() then		
			stateArray.add(TI_STATE_TRANSFER_TO);
			stateArray.add(TI_STATE_TRANSFER_FROM);
		endif;
		self.doCreateCriteriaLine(_qDef, criteriaHolder, CM_TrackedItem::state.name, CM_QueryOperator.Operator_IsOneOf, stateArray);
	endif;

	if isoType &lt;&gt; null then
		self.doCreateCriteriaLine(_qDef, criteriaHolder, CM_Container::isoType.name, CM_QueryOperator.Operator_Equal, isoType);
	endif;
	//epr TFS 7800 21/11/17
	// TFS 44653 moved further down in the method to pick up a possible change to allIMEXs for Tranships and requires job filters
	//if allIMEXs &lt;&gt; null and allIMEXs.size &gt; 0 then
	//	self.doCreateCriteriaLine(_qDef, criteriaHolder, CM_TrackedItem::imexStatus.name, CM_QueryOperator.Operator_IsOneOf, allIMEXs);
	//endif;
	if voyage &lt;&gt; null then
		self.doCreateCriteriaLine(_qDef, criteriaHolder, CM_TrackedItem::voyageCode.name, CM_QueryOperator.Operator_Equal, voyage);
	endif;
	if _request.filterBOL &lt;&gt; null then
		self.doCreateCriteriaLine(_qDef, criteriaHolder, CM_TrackedItem::billOfLading.name, CM_QueryOperator.Operator_Equal, _request.filterBOL.toUpper);
	endif;
	if _request.filterBookingRef &lt;&gt; null then
		self.doCreateCriteriaLine(_qDef, criteriaHolder, CM_TrackedItem::bookingReference.name, CM_QueryOperator.Operator_Equal, _request.filterBookingRef.toUpper);
	endif;
	if _request.filterCarrier &lt;&gt; null then
		self.doCreateCriteriaLine(_qDef, criteriaHolder, CM_TrackedItem::releaseCarrier.name, CM_QueryOperator.Operator_Equal, _request.filterCarrier);
	endif;
	if _request.filterConsignee &lt;&gt; null then
		self.doCreateCriteriaLine(_qDef, criteriaHolder, CM_TrackedItem::consignee.name, CM_QueryOperator.Operator_Equal, _request.filterConsignee);
	endif;
	if _request.filterConsignor &lt;&gt; null then
		self.doCreateCriteriaLine(_qDef, criteriaHolder, CM_TrackedItem::consignor.name, CM_QueryOperator.Operator_Equal, _request.filterConsignor);
	endif;
	if _request.filterTransportMode &lt;&gt; null then
		self.doCreateCriteriaLine(_qDef, criteriaHolder, CM_TrackedItem::receiptTransportMode.name, CM_QueryOperator.Operator_Equal, _request.filterTransportMode);
	endif;
	//cnwmc5 - 12 May 2016
	if _request.filterDischargePort &lt;&gt; null then
		self.doCreateCriteriaLine(_qDef, criteriaHolder, CM_TrackedItem::dischargePort.name, CM_QueryOperator.Operator_Equal, _request.filterDischargePort);
	endif;
	if _request.filterExcludeLocation &lt;&gt; null then
		self.doCreateCriteriaLine(_qDef, criteriaHolder, CM_TrackedItem::locationId.name, CM_QueryOperator.Operator_NotEqual, _request.filterExcludeLocation);	
	endif;
	
	//cnwmc5 - 16 Sep 2014 - PAR 34888	
	if product &lt;&gt; null then
		self.doCreateCriteriaLine(_qDef, criteriaHolder, CM_TrackedItem::myProduct.name, CM_QueryOperator.Operator_Equal, product);
	endif;
	
	//cnwmc5 - 16 Sep 2016 - TFS 1190
	if _request.filterReeferOnly then
		self.doCreateCriteriaLine(_qDef, criteriaHolder, CM_TrackedItem::isReefer.name, CM_QueryOperator.Operator_Equal, AuditStringValue_Yes);
		//epr TFS 37425 5/3/18 
		//self.doCreateCriteriaLine(_qDef, criteriaHolder, CM_TrackedItem::getPowerRequired.name, CM_QueryOperator.Operator_Equal, AuditStringValue_Yes);
	endif;
	if _request.filterDisconnectedOnly then
		self.doCreateCriteriaLine(_qDef, criteriaHolder, CM_TrackedItem::getDisconnected.name, CM_QueryOperator.Operator_Equal, AuditStringValue_Yes);
	endif;
	
		//epr TFS 2526 4/10/16 - Mobile Pack
	if _request.filterHidePackeditems then		
		self.doCreateCriteriaLine(_qDef, criteriaHolder,CM_TrackedItem::isChild.name, CM_QueryOperator.Operator_Equal, null );
	endif;

	if filterAVGrade then
		create availGrades transient;
		foreach availGrade in _request.filterAvailabilityGrades do
			availGrades.add(availGrade.Integer);
		endforeach;
		self.doCreateCriteriaLine(_qDef, criteriaHolder,CM_Container::availabilityGrade.name, CM_QueryOperator.Operator_IsOneOf, availGrades );
	endif;
	
	if _request.filterTAType &lt;&gt; null then
	
		if _request.filterTAType.isInteger then
			self.doCreateCriteriaLine(_qDef, criteriaHolder, CM_TrackedItem::getTAType.name, CM_QueryOperator.Operator_Equal, _request.filterTAType.Integer);
		else
			self.doCreateCriteriaLine(_qDef, criteriaHolder, CM_TrackedItem::getTAType.name, CM_QueryOperator.Operator_Equal, _request.filterTAType);
		endif;
	
		
	endif;
	

	if _request.filterTrailerType &lt;&gt; null then
		self.doCreateCriteriaLine(_qDef, criteriaHolder, CM_TrackedItem::getTrailerType.name, CM_QueryOperator.Operator_Equal, _request.filterTrailerType);
	
	endif;
	
	//epr TFS 2732 16/1/16 Cargo Lander 
	if _request.doFilterVoyageRequiresJob and _request.filterSite.Integer &gt; 0 then
		//if onsite
		if  _request.filterSite.Integer = TI_STATE_NORMAL then
			if _request.filterVoyageRequiresJob then
				self.doCreateCriteriaLine(_qDef, criteriaHolder, CM_TrackedItem::loadJobNum.name, CM_QueryOperator.Operator_NotEqual, null);
			else
					self.doCreateCriteriaLine(_qDef, criteriaHolder, CM_TrackedItem::loadJobNum.name, CM_QueryOperator.Operator_Equal, null);
			endif;
		elseif _request.filterSite.Integer = TI_STATE_ONSHIP then
			if _request.filterVoyageRequiresJob then
				self.doCreateCriteriaLine(_qDef, criteriaHolder, CM_TrackedItem::dischargeJobNum.name, CM_QueryOperator.Operator_NotEqual, null);
				if not allIMEXs.isEmpty then
					// TFS 52028 want traship to be an extra imex to include, not the only one to include
					if not allIMEXs.includes(TI_IMEX_STATUS_TRANSHIP) then				// TFS 44653
						allIMEXs.add(TI_IMEX_STATUS_TRANSHIP);							// TFS 44653
					endif;																// TFS 44653
				endif;
			else
					self.doCreateCriteriaLine(_qDef, criteriaHolder, CM_TrackedItem::dischargeJobNum.name, CM_QueryOperator.Operator_Equal, null);
			endif;
			
		endif;
	endif;
	
	// TFS 44653 moved to here in case we added Tranship to allIMEXs above
	if allIMEXs &lt;&gt; null and allIMEXs.size &gt; 0 then
		self.doCreateCriteriaLine(_qDef, criteriaHolder, CM_TrackedItem::imexStatus.name, CM_QueryOperator.Operator_IsOneOf, allIMEXs);
	endif;
	
	// TFS 3814 28/3/17 - mobile apps adv search
	if _request.filterMark &lt;&gt; null then
		self.doCreateCriteriaLine(_qDef, criteriaHolder, CM_TrackedItem::mark.name, CM_QueryOperator.Operator_Contains, _request.filterMark);
	endif;
	
	// 14.02.2023 navak20 TFS 56459
	if _request.filterMarkNumber &lt;&gt; null then
		self.doCreateCriteriaLine(_qDef, criteriaHolder, CM_TrackedItem::markNumber.name, CM_QueryOperator.Operator_Contains, _request.filterMarkNumber);
	endif;
	// 14.02.2023 navak20 TFS 56459
	
	if _request.filterAlternativeId &lt;&gt; null then
		self.doCreateCriteriaLine(_qDef, criteriaHolder, CM_TrackedItem::alternativeId.name, CM_QueryOperator.Operator_Equal, _request.filterAlternativeId);
	endif;
	
	if _request.filterCustomsRef &lt;&gt; null then
		self.doCreateCriteriaLine(_qDef, criteriaHolder, CM_TrackedItem::customsReference.name, CM_QueryOperator.Operator_Equal, _request.filterCustomsRef);
	endif;
	
	if _request.filterColour &lt;&gt; null then 
		self.doCreateCriteriaLine(_qDef, criteriaHolder, CM_TrackedItem::getColour.name, CM_QueryOperator.Operator_Contains, _request.filterColour);
	elseif _request.filterColourList &lt;&gt; null then
		self.doCreateCriteriaLine(_qDef, criteriaHolder, CM_TrackedItem::getColour.name, CM_QueryOperator.Operator_IsOneOf, _request.filterColourList);
	endif;
		
	if _request.filterWeightCargo.Decimal &gt; 0 then 
		self.doCreateCriteriaLine(_qDef, criteriaHolder, "kg_" &amp; CM_TrackedItem::weightCargo.name, CM_QueryOperator.Operator_Equal, _request.filterWeightCargo);
	endif;
	
	if _request.filterWeightTare.Decimal &gt; 0 then 
		self.doCreateCriteriaLine(_qDef, criteriaHolder, "kg_" &amp; CM_TrackedItem::weightTare.name, CM_QueryOperator.Operator_Equal, _request.filterWeightTare);
	endif; 	
	
	//epr TFS 7402 16/10/17
	if _request.filterReadyStatus &lt;&gt; null then
		if _request.filterReadyStatus = ReadyStatusReady then
			//check the isAvailable selector query attribute
			self.doCreateCriteriaLine(_qDef, criteriaHolder,  CM_TrackedItem::isAvailable.name, CM_QueryOperator.Operator_Equal, AuditStringValue_Yes);

		elseif _request.filterReadyStatus = ReadyStatusStops then
			//check the HasStops selector query attribute
			self.doCreateCriteriaLine(_qDef, criteriaHolder,  CM_TrackedItem::hasStops.name, CM_QueryOperator.Operator_Equal, AuditStringValue_Yes);
		endif;
	endif;	
	
	//epr TFS 37283 22/2/18
	dateFrom:=_request.filterDateFrom .asDateFromWebInterface();
	dateTo:= _request.filterDateTo.asDateFromWebInterface();
	
	if dateFrom.isValid and not dateTo.isValid then
		self.doCreateCriteriaLine(_qDef, criteriaHolder,  CM_TrackedItem::getCreatedDT.name, CM_QueryOperator.Operator_GreaterThan, dateFrom.addDays(-1));
	endif;
	
	if _request.filterReleaseRequest &lt;&gt; null then
		self.doCreateCriteriaLine(_qDef, criteriaHolder,  CM_TrackedItem::bulkReleaseAssignedCode.name,CM_QueryOperator.Operator_Equal,_request.filterReleaseRequest);
		
	endif;
	
	if dateFrom.isValid and dateTo.isValid then
		create dateArray transient;
		dateArray.add(dateFrom);
		dateArray.add(dateTo);
		self.doCreateCriteriaLine(_qDef, criteriaHolder,  CM_TrackedItem::getCreatedDT.name, CM_QueryOperator.Operator_Between, dateArray);
	endif;
	
	if dateTo.isValid and not dateFrom.isValid then
		self.doCreateCriteriaLine(_qDef, criteriaHolder,  CM_TrackedItem::getCreatedDT.name, CM_QueryOperator.Operator_LessThan, dateTo.addDays(1));
	endif;
	
	// TFS 43062
	if _request.filterCustomsEntryNumber &lt;&gt; null then
		self.doCreateCriteriaLine(_qDef, criteriaHolder, CM_TrackedItem::customExportEntryNumber.name, CM_QueryOperator.Operator_Equal, _request.filterCustomsEntryNumber);
	endif;
	// TFS 43062 end
	
	if _request.filterMT &lt;&gt; null then																								//42504
		if _request.filterMT = "true" then																							//42504
			self.doCreateCriteriaLine(_qDef, criteriaHolder, CM_TrackedItem::isEmpty.name, CM_QueryOperator.Operator_Equal, "Yes");	//42504
		elseif _request.filterMT = "false" then																						//42504
			self.doCreateCriteriaLine(_qDef, criteriaHolder, CM_TrackedItem::isEmpty.name, CM_QueryOperator.Operator_Equal, "No");	//42504
		endif;																														//42504
	endif;																															//42504
	
	//epr TFS 44740 27/6/19
	if _request.context = WS_TrackedItemQueryRequest.Context_TruckLoaderUnloader then
		self.doCreateCriteriaLine(_qDef, criteriaHolder, CM_TrackedItem::isOnTruck.name, CM_QueryOperator.Operator_Equal, "No");
	endif;
	
	// 06.07.2020 cnwma1 #49718
	if _request.context = WS_TrackedItemQueryRequest.Context_RailLanderLoad then
		self.doCreateCriteriaLine(_qDef, criteriaHolder, CM_TrackedItem::isOnWagon.name, CM_QueryOperator.Operator_Equal, "No");
	endif;
	// TFS 46728
	if _request.filterPIN &lt;&gt; null then
		self.doCreateCriteriaLine(_qDef, criteriaHolder, CM_TrackedItem::getPinNumber.name, CM_QueryOperator.Operator_Equal, _request.filterPIN);
	endif;
	
	//jlier TFS 52028 18/11/21
	if _request.filterLoadJob &lt;&gt; null then
		//voyageJob:=_request.filterLoadJob.asOid.CM_VoyageJob;	//30.09.2022 navtnr20 52451
		voyageJob := app.myPassport.getObjectOfTypeFromOid(_request.filterLoadJob,CM_VoyageJob).CM_VoyageJob;	//30.09.2022 navtnr20 52451
		if voyageJob &lt;&gt; null then
			_enqController.myVoyageJob:=voyageJob;
		endif;
	elseif _request.filterDischargeJob &lt;&gt; null then
		//voyageJob:=_request.filterDischargeJob.asOid.CM_VoyageJob;	//30.09.2022 navtnr20 52451
		voyageJob := app.myPassport.getObjectOfTypeFromOid(_request.filterDischargeJob,CM_VoyageJob).CM_VoyageJob;	//30.09.2022 navtnr20 52451
		if voyageJob &lt;&gt; null then
			_enqController.myVoyageJob:=voyageJob;
		endif;
	endif;
	
	
epilog
	delete availGrades;
	delete stateArray;
	delete cmifID;
	delete imexStatuses;
	delete allIMEXs;
	delete dateArray;
	
end;
</source>
        <Parameter name="_request" type="WS_TrackedItemQueryRequest"/>
        <Parameter name="_exactId" type="Boolean"/>
        <Parameter name="_enqController" type="CM_EnqControllerTI" usage="input"/>
        <Parameter name="_qDef" type="CM_QueryDefinition" usage="output"/>
    </JadeMethod>
    <JadeMethod name="startInterruptRequest" id="89bcec93-b881-4458-9602-3724bdaa6e8f">
        <source>startInterruptRequest(_longRunning : Boolean);
/*

Purpose:			Cancel the 'normal' 60 second interrupt request, and replace it with a 300 second one instead

Parameters:			

Return Value:		

Date			Who		Reason
07 April 2021	navmd1	Initial creation TFS 42010 MTN - Early termination of Webservice responses

*/

vars
	wsSupportAgent : WS_WebServiceSupportAgent;
begin
	wsSupportAgent := WS_WebServiceSupportAgent.firstSharedTransientInstance;
	if wsSupportAgent = null then
		return;
	endif;
	
	wsSupportAgent.causeEvent(WS_WebServiceSupportAgent.WS_Cancel_Interrupt_Note, true, process);
	
	if _longRunning then
		wsSupportAgent.causeEvent(WS_WebServiceSupportAgent.WS_Start_Long_Interrupt_Note, true, process);
	else
		wsSupportAgent.causeEvent(WS_WebServiceSupportAgent.WS_Start_Interrupt_Note, true, process);
	endif;
epilog

end;</source>
        <Parameter name="_longRunning" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="updateBooking" id="949dd8f3-fc56-4b31-a117-9cdf06f65da4">
        <options>4</options>
        <source>updateBooking(_wsBooking : WS_RestBookingObject; _terminal : CM_Terminal; _statusCode : Integer io; _bookingId, _operatorId, _voyageId : String; _objectsToBeDeleted : ObjectArray input) typeMethod;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
22 March 2023	navpw1	Initial creation TFS: 56850 (56871)
03 April 2023	navpw1	TFS: 57264 (57296) - Made changes to support creation of release request for releasing empties
05 April 2023	navpw1	TFS: 56707 (56712) - Added extra critiera for a booking item to match against
19 April 2023	navpw1	TFS: 57608 - Fixed voyage code not being updated correctly
08 March 2024 	naviv1	TFS: 62796 - CR - CUX | EDBIC - Modify Booking API to be independent of Prenotes
20 March 2024   navsp1  TFS ChangeRequest 63028: CUX | TK 62942 | EDBIC BOOKING APIs - Add field GoLiveCrit 01
03 April 2024	navdap1	TFS 63392 CUX | Issues on PUT/booking API call on Special Stow field - Bug from GoLCrit 01*
*/

vars
	pxyBooking,
	realBooking					: CM_BookingRef;
	operator					: CM_Operator;
	consignor,
	consignee,
	freightForwarder			: CM_ConsigneeConsignor;
	carrier						: CM_Carrier;
	stevedore					: CM_Stevedore;
	transhipVoyage,
	voyage						: CM_Voyage;
	dischargePortsArr			: StringArray;
	bookRefHazardsArray			: ObjectArray;
	wsCargo						: WS_RestBookingCargoObject;
	cargoBolType				: CM_CargoBOLType;
	cargoType					: CM_CargoType;
	product						: CM_Product;
	isoType						: CM_ISOType;
	specialStow					: CM_SpecialStow;
	hazardsArr					: CM_HazardByCodeDict;
	hazardClass					: CM_HazardClass;
	wsHazard					: WS_RestHazardObject;
	hazardTi					: CM_TIHazard;
	existingBookingItem			: CM_BookingRefItem;
	existingBookingItemCont,
	pxyBookingItemCont			: CM_BRefItemContainer;
	undgString,
	carrierCode,
	consigneeCode,
	freightForwarderCode,
	releaseId					: String;
	createBookingRelease,
	limitQ						: Boolean;
	humidity,
	vent,
	carbonDioxide,
	oxygen						: Decimal[23,2];
	cargoTypeIdInt,
	marinePol,
	ventUnits,
	transportType				: Integer;
	hazard						: CM_Hazard;
	dictHaz						: CM_HazardByCodeDict;
	iter						: Iterator;
	pxyBulkRelease				: CM_BulkRelease;
	dischargePort				: CM_Port;
	releaseRequestData			: WS_RestBookingReleaseObject;
	temperature					: Real;
	height,
	length,
	width,
	gross,
	net							: Decimal[12,4];	// TFS 63392
	reason						: String; //05/04/2024	navkc1 Bug 63509
begin
	releaseRequestData := _wsBooking.releaseRequest;
	if releaseRequestData &lt;&gt; null then
		createBookingRelease := true;
		
	endif;
	
	realBooking := WS_WebServiceAgent@findBooking(_bookingId, _operatorId, _voyageId, _terminal);
	
	if realBooking = null then
		app.raiseCMException1(Err_No_Booking_Found, _bookingId, null, null);
		_statusCode := HttpResponseNotFound;
		return;
	endif;
	
	pxyBooking := app.createUpdateProxy(realBooking).CM_BookingRef;
	
	pxyBooking.setBookingReference(_wsBooking.id);
	
	operator := app.myRoot.allOperators[_wsBooking.operatorId];
	
	if operator = null or operator.code &lt;&gt; _wsBooking.operatorId then
		app.raiseCMException1(Operator_found, _wsBooking.operatorId, null, null);
		_statusCode := HttpResponseClientError;
		return;
	endif;
	
	voyage := _terminal.lookupVoyage(_wsBooking.voyageId, null, true);
	
	if voyage = null or voyage.code &lt;&gt; _wsBooking.voyageId then
		app.raiseCMException1(Voyage_code_found, _wsBooking.voyageId, null, null);
		_statusCode := HttpResponseClientError;
		return;
	endif;
	
	consignor := app.myRoot.allConsigneeConsignors[_wsBooking.consignorId];
	consignee := app.myRoot.allConsigneeConsignors[_wsBooking.consigneeId];
	carrier := app.myRoot.allCarriers[_wsBooking.carrierId];
	
	freightForwarder :=  app.myRoot.allConsigneeConsignors[_wsBooking.freightForwarderId];
	stevedore := app.myRoot.allStevedores[_wsBooking.stevedoreId];
	
	if _wsBooking.transhipOriginalVoyageId &lt;&gt; null then
		transhipVoyage := _terminal.lookupVoyage(_wsBooking.transhipOriginalVoyageId, null, true);
		
		if transhipVoyage = null or transhipVoyage.code &lt;&gt; _wsBooking.transhipOriginalVoyageId then
			app.raiseCMException1(Tranship_voyage_code_invalid, _wsBooking.transhipOriginalVoyageId, null, null);
			_statusCode := HttpResponseClientError;
			return;
		endif;
	endif;
	
	//Why does pxyBooking.setProxy have pDischargePorts : StringArray; &amp; pDischargePort; ????
	create dischargePortsArr transient;
	dischargePortsArr.add(_wsBooking.dischargePortId);
	
	create bookRefHazardsArray transient;
	
	pxyBooking.setProxy(pxyBooking.bookingReference, pxyBooking.cargoType, pxyBooking.clean, pxyBooking.commodity, _wsBooking.consignorId, pxyBooking.description, _wsBooking.destinationPortId, 
						_wsBooking.dischargePortId, pxyBooking.myTranshipToPort, dischargePortsArr, bookRefHazardsArray, pxyBooking.humidity, pxyBooking.inspected, pxyBooking.isoType,consignor,
						consignee, operator, voyage, pxyBooking.quantity, _wsBooking.remarks, pxyBooking.remarks, pxyBooking.temperature, pxyBooking.ventilation,
						pxyBooking.height, pxyBooking.length, pxyBooking.width, pxyBooking.heightString, pxyBooking.lengthString, pxyBooking.widthString, pxyBooking.typeString,
						pxyBooking.density, pxyBooking.volume, pxyBooking.productQuantity, pxyBooking.weight, pxyBooking.cubicMetres, app.myPassport.myTerminal, pxyBooking.myProduct,
						pxyBooking.isMultiItemBookingRef, _wsBooking.stockBooking, pxyBooking.myEDIBookingRefTI, pxyBooking.rawEDIData, _wsBooking.shippingReference, null, 
						pxyBooking.consignorDesc, pxyBooking.consigneeDesc, pxyBooking.myCustomerPriority, pxyBooking.mySpecialStow, pxyBooking.holdPartials, pxyBooking.noFullIsAllowedIn,
						createBookingRelease, pxyBooking.isMilitary, pxyBooking.vNumber, pxyBooking.overrideCutoff, pxyBooking.overDimension, pxyBooking.fumigationNeeded, 
						pxyBooking.isStopped, _wsBooking.status, pxyBooking.ediFileIssueDateTime, null, pxyBooking.allLinkedStockBookingItems, _wsBooking.receiveAsTranship,
						transhipVoyage, app.bookingPackAsStringToEnumb(_wsBooking.packAsType), _wsBooking.customsAgentId, null, null, _wsBooking.directDelivery, freightForwarder, carrier, stevedore);
	
	foreach wsCargo in _wsBooking.cargo do
		cargoBolType := app.myRoot.allCargoTypesById.getCargoTypeByAbbreviation(wsCargo.cargoTypeId);
		
		if cargoBolType &lt;&gt; null and cargoBolType.isCargoType then
			cargoTypeIdInt := cargoBolType.id;
			cargoType := cargoBolType.CM_CargoType;
		else
			app.raiseCMException1(Cargo_Type_Not_Found, wsCargo.cargoTypeId, null, null);
			_statusCode := HttpResponseClientError;
			return;
		endif;
		
		if cargoType.isSubCargoTypeRequired then
			product := cargoType.allProducts[_operatorId, wsCargo.cargoSubTypeId];
			
			if product = null then
				iter := cargoType.allProducts.createIterator;
				cargoType.allProducts.startKeyGeq(null, wsCargo.cargoSubTypeId, iter);
				while iter.next(product) do
					if product.code &lt;&gt; wsCargo.cargoSubTypeId then
						continue;
					elseif product.code = wsCargo.cargoSubTypeId then
						break;
					endif;
				endwhile;
				delete iter;
			endif;
			
			if product = null or product.code &lt;&gt; wsCargo.cargoSubTypeId then
				app.raiseCMException2(Cargo_SubType_Not_Found_CType, wsCargo.cargoSubTypeId, wsCargo.cargoTypeId, null, null);
				_statusCode := HttpResponseClientError;
				return;
			endif;
		endif;
		
		isoType := app.myRoot.allISOTypes[wsCargo.isoTypeId];
		
		specialStow := app.myRoot.allSpecialStows[wsCargo.specialStow];
		if specialStow = null and wsCargo.specialStow &lt;&gt; null then				// TFS 63392
			app.raiseCMException1(Special_stow_not_found, wsCargo.specialStow, null, null);
			_statusCode := HttpResponseClientError;
			return;
		endif;
		
		create hazardsArr transient;
		_objectsToBeDeleted.add(hazardsArr);
		if wsCargo.hazards.isNotEmpty then
			foreach wsHazard in wsCargo.hazards do
				//Find hazard code to validate??
				//Get a hazard class??
				hazardClass := app.myRoot.allHazardClasses[wsHazard.id];
				if hazardClass = null then
					app.raiseCMException1(Hazard_code_not_found, wsHazard.id, null, null);
					_statusCode := HttpResponseClientError;
					return;
				endif;
				
				create hazardTi transient;
				hazardTi.setProxy(hazardClass.code, hazardClass.description, wsHazard.undgNumber, null, wsHazard.limitedQuantity, wsHazard.packingGroupId,
								wsHazard.flashpointTemperature, wsHazard.marinePollutant, wsHazard.acidBase);
				hazardsArr.add(hazardTi);
				_objectsToBeDeleted.add(hazardTi);
			endforeach;
		endif;
		
		//Find existing booking item
		existingBookingItem := pxyBooking.getMatchingItem(cargoType, wsCargo.commodityId, isoType, wsCargo.cargoSubTypeId, wsCargo.marks, wsCargo.markNumber, wsCargo.colour, wsCargo.purchaseOrder, wsCargo.serviceOrder, reason); // ### TFS 56707 (56712) 05Apr2023 NAVPW1
		
		//Check if booking item is a container one (bookingRefItem.isContainer) so we can cast it to CM_BRefItemContainer below
		if existingBookingItem &lt;&gt; null and existingBookingItem.isContainer then
			existingBookingItemCont := existingBookingItem.CM_BRefItemContainer;
		endif;
		
		if existingBookingItemCont &lt;&gt; null then
			//Update
			foreach hazardTi in existingBookingItemCont.allTIHazards as CM_TIHazard do
				hazardsArr.add(hazardTi);
				_objectsToBeDeleted.add(hazardTi);
			endforeach;
			
			if cargoType.id = TI_CargoType_Container then
				//Container
				if wsCargo.reeferProperties &lt;&gt; null then
					humidity := wsCargo.reeferProperties.humidity;
					vent := wsCargo.reeferProperties.vent;
					ventUnits := wsCargo.reeferProperties.ventUnits;
					carbonDioxide := wsCargo.reeferProperties.carbonDioxide;
					oxygen := wsCargo.reeferProperties.oxygen;
					temperature := wsCargo.reeferProperties.temperature;
				else
					temperature := NULL_TEMPERATURE;
				endif;
				
				// TFS 63392
				gross := existingBookingItemCont.weight;
				if wsCargo.weights &lt;&gt; null then
					gross := wsCargo.weights.gross;
				endif;
				// TFS 63392 end of this bit
				
				existingBookingItemCont.setProxy(existingBookingItemCont.myCargoType.id, existingBookingItemCont.commodity, wsCargo.description, wsCargo.remarks, hazardsArr, existingBookingItemCont.isoType, wsCargo.quantity, gross, null, null, 
											humidity, temperature, vent, ventUnits, carbonDioxide, oxygen, wsCargo.curtains, null, null, specialStow, existingBookingItemCont.isoTypeGroup, null,
											null, wsCargo.purchaseOrder, wsCargo.serviceOrder, wsCargo.matchMode);//TFS 63028 - quantity replaced			//navra1 - CR 63764/Task 64227 - 22nd May 2024
			else
				// TFS 63392
				if wsCargo.weights &lt;&gt; null then
					gross := wsCargo.weights.gross;
					net := wsCargo.weights.net;
				endif;
				if wsCargo.dimensions &lt;&gt; null then
					height := wsCargo.dimensions.height;
					length := wsCargo.dimensions.length;
					width := wsCargo.dimensions.width;
				endif;
				// TFS 63392 end of this bit
				
				//Cargo Item
				existingBookingItemCont.setProxyForCargo(existingBookingItemCont.myCargoType.id, existingBookingItemCont.commodity, wsCargo.description, hazardsArr, wsCargo.quantity, wsCargo.remarks, height, length,
													width, null, null, null,
													null, wsCargo.density, wsCargo.volume, existingBookingItemCont.quantity, wsCargo.marks, gross, existingBookingItemCont.myProduct, null, null, wsCargo.generatorTypeId, specialStow,
													null, wsCargo.colour, wsCargo.markNumber, null, net, wsCargo.volume, wsCargo.trailerTypeId, wsCargo.purchaseOrder,
													wsCargo.serviceOrder,wsCargo.matchMode); //08.03.2024 naviv1 #62796 //TFS 63028 - quantity replaced			//navra1 - CR 63764/Task 64227 - 22nd May 2024
			endif;
			//existingBookingItem.increaseItemQuantity(1); //Allready added quantity in the setproxy call //26.Mar.24 navsp1 TFS 63028
			if pxyBooking.isReleaseEmptiesAllowed and createBookingRelease then //Only Applicable to ISO Containers
				existingBookingItem.setProxyReserveDetail(existingBookingItem.quantity, existingBookingItem.quantity, null, null);
			endif;
		else
			create pxyBookingItemCont transient;
			
			if cargoType.id = TI_CargoType_Container then
				//Container
				if wsCargo.reeferProperties &lt;&gt; null then
					humidity := wsCargo.reeferProperties.humidity;
					vent := wsCargo.reeferProperties.vent;
					ventUnits := wsCargo.reeferProperties.ventUnits;
					carbonDioxide := wsCargo.reeferProperties.carbonDioxide;
					oxygen := wsCargo.reeferProperties.oxygen;
					temperature := wsCargo.reeferProperties.temperature;
				else
					temperature := NULL_TEMPERATURE;
				endif;
				// TFS 63392
				if wsCargo.weights &lt;&gt; null then
					gross := wsCargo.weights.gross;
				endif;
				// TFS 63392 end of this bit
				
				pxyBookingItemCont.setProxy(cargoTypeIdInt, wsCargo.commodityId, wsCargo.description, wsCargo.remarks, hazardsArr, wsCargo.isoTypeId, wsCargo.quantity, wsCargo.weights.gross, wsCargo.quantity, null, 
											humidity, temperature, vent, ventUnits, carbonDioxide, oxygen, wsCargo.curtains, null, null, specialStow, wsCargo.isoGroupId, null,
											null, wsCargo.purchaseOrder, wsCargo.serviceOrder, wsCargo.matchMode);				//navra1 - CR 63764/Task 64227 - 22nd May 2024
				pxyBookingItemCont.setMyBookingRef(pxyBooking);
				if pxyBooking.isReleaseEmptiesAllowed and createBookingRelease then //Only Applicable to ISO Containers
					pxyBookingItemCont.setProxyReserveDetail(1, 1, null, null);
				endif;
			else
				// TFS 63392
				if wsCargo.weights &lt;&gt; null then
					gross := wsCargo.weights.gross;
					net := wsCargo.weights.net;
				endif;
				if wsCargo.dimensions &lt;&gt; null then
					height := wsCargo.dimensions.height;
					length := wsCargo.dimensions.length;
					width := wsCargo.dimensions.width;
				endif;
				// TFS 63392 end of this bit
				
				//Cargo Item
				pxyBookingItemCont.setProxyForCargo(cargoTypeIdInt, wsCargo.commodityId, wsCargo.description, hazardsArr, wsCargo.quantity, wsCargo.remarks, height, length,
													width, null, null, null,
													null, wsCargo.density, wsCargo.volume, 1, wsCargo.marks, gross, product, null, null, wsCargo.generatorTypeId, specialStow,
													null, wsCargo.colour, wsCargo.markNumber, null, net, wsCargo.volume, wsCargo.trailerTypeId, wsCargo.purchaseOrder,
													wsCargo.serviceOrder, wsCargo.matchMode); //08.03.2024 naviv1 #62796  --replaced cargo Id parameter with null			//navra1 - CR 63764/Task 64227 - 22nd May 2024
				pxyBookingItemCont.setMyBookingRef(pxyBooking);
			endif;
			
			_objectsToBeDeleted.add(pxyBookingItemCont);
		endif;
		
	endforeach;
	
	pxyBulkRelease := pxyBooking.allReleaseRequests.first;
	
	if pxyBooking.isReleaseEmptiesAllowed and pxyBulkRelease &lt;&gt; null and createBookingRelease then
		if consignee &lt;&gt; null then
			consigneeCode := consignee.code;
		endif;
		
		if freightForwarder &lt;&gt; null then
			freightForwarderCode := freightForwarder.code;
		endif;
		
		dischargePort := app.myRoot.allPorts[_wsBooking.dischargePortId];
		
		if releaseRequestData &lt;&gt; null then
			if releaseRequestData.id &lt;&gt; null then
				releaseId := releaseRequestData.id; //If we have a release id then use it
			else
				releaseId := pxyBooking.bookingReference;	//Otherwise default to booking reference
			endif;
			
			transportType := app.transportTypeStringToEnum(releaseRequestData.transportType);
			
			carrierCode := releaseRequestData.carrierId;
			
		endif;
		
		pxyBulkRelease.setProxy(	releaseId, //code same as this booking reference number unless we are giving a different one
									transportType,
									true, //(not self.chkReservedOnly.value),  //release by type - not chkIsReservedOnly Now always true adm 070710 Par 24741
									BR_ACTIVE,
									null, ///availability grades null set on reserve selections
									null,//booking confirmation 
									carrierCode, //carrier
									null, //cargo remarks
									consigneeCode,		//consigneeCode
									null,
									_wsBooking.consignorId,		//consignor Code
									null,
									null,//_consignorVoyageCode 
									null, //date requested
									null,//_dateEstimatedRequired
									null,//_deliveryReasonCode
									null,//_deliveryReasonDescr
									null,//_deliveryReleaseNumber
									null,//_doorsDirection
									null,//_freightPayerCode
									pxyBooking,//CM_BookingRef
									null,//_loadPort
									null,//_destinationPort	//04 Nov 2009	NDL Par 21519
									dischargePort,//_dischargePort
									freightForwarderCode,//_freightForwarder
									null,//_transferToTerminal
									pxyBooking.myTerminal,
									pxyBooking.myOperator,//_operator
									null,//_operatorGroup
									pxyBooking.myVoyage,//_voyage
									null,		//_businessUnit	
									null,		//_fullRelease	
									null,  //pack locations
									null,
									null,
									null,
									pxyBooking.myTerminal.getConfig(MySubTerminalForTargetBulk).CM_SubTerminal, // subterm target
									null,
									false,
									_wsBooking.customsAgentId,
									false,
									false,
									pxyBulkRelease.needsReview,	// don't change ot from here???
									pxyBulkRelease.blockEDIUpdates, 	// par 29481 - don't change from here par 29480 April 2012
									null,
									null,
									null,
									null
									);
		pxyBulkRelease.requests.purge();
	endif;
	
	//Update Hazards on parent booking for item
	//Requried otherwise hazard not saved on booking items
	dictHaz := pxyBooking.allTIHazards;
	foreach existingBookingItemCont in pxyBooking.allBookingRefItems as CM_BRefItemContainer do
		foreach hazard in existingBookingItemCont.allTIHazards do
			if dictHaz[hazard.code] = null then
				create hazardTi transient;
				hazardTi.setProxy(	hazard.code,
									hazard.description,
									hazard.CM_TIHazard.allUNDGCodes.asCSV(false),
									null,
									hazard.CM_TIHazard.limitedQuantity,
									hazard.CM_TIHazard.packingGroup,
									hazard.CM_TIHazard.flashpointTemperature,
									hazard.CM_TIHazard.isMarinePollutant,
									hazard.CM_TIHazard.acidsBases	);
				dictHaz.add(hazardTi);
			else
				hazardTi := dictHaz[hazard.code].CM_TIHazard;
				if hazard.CM_TIHazard.getUndgCodesAsString(false) &lt;&gt; null
				and not hazardTi.allUNDGCodes.includes(hazard.CM_TIHazard.getUndgCodesAsString(false)) then
					undgString:= hazardTi.allUNDGCodes.asCSV(false) &amp;','&amp; hazard.CM_TIHazard.allUNDGCodes.asCSV(false);
					hazardTi.setUNDGCodes(undgString);
				endif;
				limitQ := hazardTi.limitedQuantity and hazard.CM_TIHazard.limitedQuantity;
				hazardTi.setLimitedQuantity(limitQ);
				marinePol := hazardTi.isMarinePollutant;
				hazardTi.setIsMarinePollutant(marinePol);
				hazardTi.setAcidsBases(hazard.CM_TIHazard.acidsBases);
				hazardTi.setFlashpointTemperature(hazard.CM_TIHazard.flashpointTemperature);
			endif;
		endforeach;
	endforeach;
	
	app.myTrxUA.trxUpdateBookingBulkRel(pxyBooking, app.myPassport);
	
epilog
	if dischargePortsArr &lt;&gt; null then
		dischargePortsArr.clear();
	endif;
	delete dischargePortsArr;
	
	if bookRefHazardsArray &lt;&gt; null then
		bookRefHazardsArray.clear();
	endif;
	delete bookRefHazardsArray;
	
	delete pxyBooking;
	
	delete iter;
end;</source>
        <Parameter name="_wsBooking" type="WS_RestBookingObject"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_statusCode" type="Integer" usage="io"/>
        <Parameter name="_bookingId" type="String"/>
        <Parameter name="_operatorId" type="String"/>
        <Parameter name="_voyageId" type="String"/>
        <Parameter name="_objectsToBeDeleted" type="ObjectArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="updateInvoiceStatus" id="f30566eb-cc77-4185-a30d-3c6fd4933b16">
        <options>4</options>
        <source>updateInvoiceStatus(_ews : CM_EWSActivityInvoiceAPI; _status : Integer) : Boolean typeMethod;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 December 2023	navra1	Initial creation for TFS 54090 CR 61414 - Task 61416 &amp; 61415  - 5th Dec 2023

*/

vars
	pxyInvoice, realInvoice : CM_Invoice;	
	statuses : CMIF_Array;
	cmifStatus : CMIF_InvoiceStatus;	
begin	

	realInvoice :=_ews.myInvoice;
	
	if realInvoice = null then
		app.writeLog("The real invoice of the ews activity was null, returning..", LogERROR);
		return false;
	endif;
	
	pxyInvoice := app.createUpdateProxy(realInvoice).CM_Invoice;
	
	create statuses transient;
	create cmifStatus transient;
	cmifStatus.myInvoice := pxyInvoice;
	cmifStatus.newStatus := _status;
	if realInvoice.debtor &lt;&gt; null then
		cmifStatus.myTermsOfTrade := realInvoice.debtor.myTermsOfTrade;
	endif;
	
	cmifStatus.purchaseOrderNumber := realInvoice.purchaseOrderNumber;
	cmifStatus.debtorReference 	  := realInvoice.debtorReference;
	cmifStatus.myLocale			  := realInvoice.myLocale;
	cmifStatus.myAlternativeAddress:= realInvoice.myAlternativeAddress;
	cmifStatus.myBillingAddress 	  := realInvoice.myBillingAddress;
	cmifStatus.narration := realInvoice.narration;
	cmifStatus.toDT := realInvoice.toDT;
	cmifStatus.isZeroRatedTax := realInvoice.isZeroRatedTax;
	cmifStatus.myCurrencyType := realInvoice.myCurrencyType;
	cmifStatus.runPackages := realInvoice.runPackages;										//navra1 - CR 61910/Task 62303 - 19th Feb 2024
	
	statuses.add(cmifStatus);
	
	app.myTrxUA.trxUpdateInvoiceStatuses(statuses, app.myPassport);
	
	if app.myPassport.allErrorWarnings.size &lt;&gt; 0 then
		return false;
	endif;
	
	return true;
	
epilog
	delete pxyInvoice;
	delete cmifStatus;	
	delete statuses;
end;</source>
        <Parameter name="_ews" type="CM_EWSActivityInvoiceAPI"/>
        <Parameter name="_status" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="updateRequiredExtraInfo" id="4d8cec9b-cfe2-45e3-bbe0-43c22a51ecb3">
        <source>updateRequiredExtraInfo(_reqExtraInfoType : String; _reqExtraInfo : WS_RequiredExtraInfo; _pxyTI : CM_TrackedItem input; _tempParams : CMIF_TempReading input);
/*

Purpose:			

Parameters:			

Return Value:		
/* Changes

Date		Name	TFS#		Description
============================================================================
03/08/2016	cnwmc5				Initial creation
05/09/2016  cnwrh7  TFS2437    	Add VGM details to Weight data entry for Mobile Web apps
29/06/2017	cnwdap1	TFS 4492 	SNO VERMAS Changes
27/09/2021	navdap1	TFS 52081	MTN Cannot Add Reading for a Reefer for a time other than Now
============================================================================*/

vars
	specialLift 			: CM_SpecialLift;
	wssl 					: WS_SpecialLift;
	specialLifts 			: CM_SpecialLiftByCodeDict;
	updateController 		: CMIF_TIUpdateController;
	vgmDetails 				: CM_VGMDetails;			// TFS 4492
	authSig, commsType, 
	docDetails, ediTrans, 
	email, 												// TFS 4492
	mail, phone, fax, 
	telephone 				: String;					// TFS 4492
	docsIssued, 
	determination 			: TimeStamp;				// TFS 4492	
begin
	
	if _reqExtraInfoType = EXTRA_INFO_TEMPERATURE then
	/*	_tempParams.isRefConReading := false;
		_tempParams.isRefConAlarm := false;
		_tempParams.refConRawData := null;
		_tempParams.dateTime := app.actualTimeServer;
		_tempParams.noCharge := _pxyTI.noChargeForTemperature(false, _tempParams.dateTime);
		_tempParams.userId := app.getMyUserCode;
		_tempParams.myTerminal := app.myPassport.myTerminal;
		_tempParams.myTrackedItem := _pxyTI;
		
		// cnwmc5 - 19 May 2016 - Only accepting Celcius from web currently...
		//isCelcius := term.getConfig(TempFahForFahOperator).Boolean;
		//if isCelcius then
			_tempParams.temperature := _reqExtraInfo.temperature;
		//else
		//	tempParams.temperature := app.temperatureConversion(false, request.temperature);
		//endif;  */
		
		//01 Sep 2021	NDL	TFS 51874 - Use common code instead of 14 different variant copies....
		_tempParams.initialise(	_pxyTI,	//_reefer : CM_TrackedItem;
								false,	//_defaultNoChargeValue : Boolean;
								app.actualTimeServer,	//_dateTime : TimeStamp;	// TFS 52081
								_reqExtraInfo.temperature	//_temperature : Real
								);
									
	elseif _reqExtraInfoType = EXTRA_INFO_IS_OD then
		_pxyTI.setIsOverDimensions(_reqExtraInfo.isOD);
	elseif _reqExtraInfoType = EXTRA_INFO_HAZARD_SYMBOLS then
		// What to do?
	elseif _reqExtraInfoType = EXTRA_INFO_ALTERNATIVE_ID then
		_pxyTI.zSetPxyAlternativeId(_reqExtraInfo.alternativeId);	
	elseif _reqExtraInfoType = EXTRA_INFO_DIMENSION and _pxyTI.isContainer then
		_pxyTI.CM_Container.setOverWidthLeft(_reqExtraInfo.dimLeft, null, app.myPassport);
		_pxyTI.CM_Container.setOverWidthRight(_reqExtraInfo.dimRight, null, app.myPassport);
		_pxyTI.CM_Container.setOverLengthRear(_reqExtraInfo.dimBack, null, app.myPassport);
		_pxyTI.CM_Container.setOverLengthFront(_reqExtraInfo.dimFront, null, app.myPassport);
		_pxyTI.CM_Container.setOverHeight(_reqExtraInfo.dimHeight, null, app.myPassport);
	elseif _reqExtraInfoType = EXTRA_INFO_DIMENSION and not _pxyTI.isContainer then
		_pxyTI.setLength(_reqExtraInfo.dimLength);
		_pxyTI.setWidth(_reqExtraInfo.dimWidth);
		_pxyTI.setHeight(_reqExtraInfo.dimHeight);
	elseif _reqExtraInfoType = EXTRA_INFO_SPECIAL_LIFT then
		create specialLifts transient;
		foreach wssl in _reqExtraInfo.allSpecialLifts do
			create specialLift transient;
			specialLift.setProxy(wssl.code,wssl.description);
			specialLifts.addNoDuplicates(specialLift, false);
		endforeach;
		_pxyTI.zSetPxySpecialLifts(specialLifts);
		
	elseif _reqExtraInfoType = EXTRA_INFO_WEIGHT then
		updateController := app.createTIUpdateControl(TI_UPDMODE_NORMAL, app.myPassport.userCode, null);		
		_pxyTI.setTotalWeightAndCertified(_reqExtraInfo.weight, _pxyTI.weightCargo, _pxyTI.weightTare, false, null, app.myPassport);					
		_pxyTI.setIsWeightCertified(_reqExtraInfo.isWeightCertified,null, app.myPassport);						//+TFS2437							Is Weight Certified		
		
		// TFS 4492_pxyTI.setWeightCertifiedName  (_reqExtraInfo.weightCertifiedName,null, app.myPassport);		//+TFS2437							Weight Certified By	
		// TFS 4492_pxyTI.setWeightCertifiedReference(_reqExtraInfo.weightCertifiedReference,null, app.myPassport);		//+TFS2437					Authorised Person for Certified Weight
		vgmDetails := _pxyTI.getMyVGMDetails();															// TFS 4492
		if vgmDetails &lt;&gt; null then																		// TFS 4492
			authSig := vgmDetails.vgmAuthSignature;														// TFS 4492
			commsType := vgmDetails.vgmCommsType;														// TFS 4492
			docDetails := vgmDetails.vgmDocumentDetails;												// TFS 4492
			ediTrans := vgmDetails.vgmEDITransmission;													// TFS 4492
			email := vgmDetails.vgmElectronicMail;														// TFS 4492
			mail := vgmDetails.vgmMail;																	// TFS 4492
			phone := vgmDetails.vgmPhone;																// TFS 4492
			fax := vgmDetails.vgmTelefax;																// TFS 4492
			telephone := vgmDetails.vgmTelephone;														// TFS 4492
			docsIssued := vgmDetails.vgmDocsIssuedDT;													// TFS 4492
			determination := vgmDetails.vgmDeterminationDT;												// TFS 4492
		endif;																							// TFS 4492
		_pxyTI.setMyVGMDetails(	_reqExtraInfo.weightCertifiedReference,									// TFS 4492
								_reqExtraInfo.weightCertifiedName,										// TFS 4492
								authSig, commsType, docDetails, ediTrans, email, mail, 					// TFS 4492
								phone, fax, telephone, docsIssued, determination, updateController	);	// TFS 4492		
	endif;	
	
epilog
	delete updateController;
end;</source>
        <Parameter name="_reqExtraInfoType" type="String"/>
        <Parameter name="_reqExtraInfo" type="WS_RequiredExtraInfo"/>
        <Parameter name="_pxyTI" type="CM_TrackedItem" usage="input"/>
        <Parameter name="_tempParams" type="CMIF_TempReading" usage="input"/>
    </JadeMethod>
    <JadeMethod name="updateSealChecksTIEdit" id="b1229d28-f6f6-4651-8bfd-5574f158d40f">
        <source>updateSealChecksTIEdit(_cargo : CM_TrackedItem; pxySealTi : CM_SealTI; fieldsValues : HugeStringArray io ) protected;

/*
Purpose:			
/* Changes

Date		Name	TFS#		Description
============================================================================
MARCH 2016	CNWAB1				Initial creation
07 Jun 2017	cnwrs1	TFS 4462 	SNO add Terminal Operator, Unknown Seal and support multiple seals
29 Mar 2019 jlgka1	TFS 44020	Change StringArray to HugeStringArray.
============================================================================*/
vars

	realTi 			: CM_TrackedItem;
	oldSealTi 		: CM_SealTI;
	sealType 		: CM_SealType;
	newSealValue 	: String;
	prevSealValue 	: String;
	oldSealDt 		: TimeStamp;
	newSealDt 		: TimeStamp;
	tiTrxDetails 	: String;	
begin
	realTi := _cargo;
	
	sealType := app.myRoot.getSealType( pxySealTi.sealType );
	if sealType = null then
		return;
	endif;
	
	oldSealDt := null;
	newSealDt := null;
	if realTi &lt;&gt; null then
		prevSealValue := realTi.getSealValue(sealType);
		if sealType.sealType = SealType_Operator then
			oldSealTi := realTi.getSealTI(sealType);
			if oldSealTi &lt;&gt; null then
				oldSealDt := oldSealTi.sealedDT;
			endif;
		endif;
	endif;
	newSealValue := pxySealTi.getSealValueAsString;
	
	if prevSealValue &lt;&gt; newSealValue then
		if sealType.isSystemSealType then
		
			if sealType.sealType = SealType_Operator then
				tiTrxDetails := app.formatForEditTransaction( SealNum, prevSealValue, newSealValue );
				fieldsValues.add(tiTrxDetails);
				newSealDt := pxySealTi.sealedDT;
				if newSealDt &lt;&gt; oldSealDt then
					tiTrxDetails := app.formatForEditTransaction( SealDT, oldSealDt.asStringJMT, newSealDt.asStringJMT );
					fieldsValues.add(tiTrxDetails);
				endif;
				
			elseif sealType.sealType = SealType_Shipper then
				tiTrxDetails := app.formatForEditTransaction( SealNumShippers, prevSealValue, newSealValue );
				fieldsValues.add(tiTrxDetails);
				
			elseif sealType.sealType = SealType_Customs then
				tiTrxDetails := app.formatForEditTransaction( SealNumCustoms, prevSealValue, newSealValue );
				fieldsValues.add(tiTrxDetails);
				
			elseif sealType.sealType = SealType_Vent then
				tiTrxDetails := app.formatForEditTransaction( SealNumVent, prevSealValue, newSealValue );
				fieldsValues.add(tiTrxDetails);
				
			elseif sealType.sealType = SealType_TerminalOperator then
				tiTrxDetails := app.formatForEditTransaction(SealNumTerminalOperator, prevSealValue, newSealValue);
				fieldsValues.add(tiTrxDetails);
			endif;		
		
		else
			tiTrxDetails := app.formatForEditTransaction( sealType.description, prevSealValue, newSealValue );
			fieldsValues.add(tiTrxDetails);
			
		endif;
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="_cargo" type="CM_TrackedItem"/>
        <Parameter name="pxySealTi" type="CM_SealTI"/>
        <Parameter name="fieldsValues" type="HugeStringArray" usage="io"/>
    </JadeMethod>
    <JadeMethod name="updateSealChecksTITransaction" id="fe335610-4d9a-405a-9d6c-cbc390efbc23">
        <source>updateSealChecksTITransaction(_cargo 				: CM_TrackedItem; 	
							  _proxySealCheckTrx 	: CM_SealCheck io; 
							  _updateSealsArray 	: CM_ObjectArray; 
							  _passport 			: CM_Passport input) :  CM_SealCheck;
/*
Purpose:			
/* Changes

Date		Name	TFS#		Description
============================================================================
07 Mar 2016	cnwab1				Initial creation
29 Mar 2019 jlgka1	TFS 44020	Change StringArray to HugeStringArray.
============================================================================*/

vars
	trackedItem			: CM_TrackedItem;
	theTIProxy 			: CM_TrackedItem;
	mess 				: String;
	txnController 		: CMIF_TITransactionController;
	newTITxn 			: CM_TITransaction;
	toDoTaskDescToAdd 	: CM_ToDoTaskDesc;
	tiUpdateRequired 	: Boolean;
	sealCheckTrxProxy 	: CM_SealCheck;
	obj 				: Object;
	updateSealType 		: CM_SealType;
	pxySealCheckDetail 	: CM_SealCheckDetail;
	sealAfter		 	: String;
	sealBefore 			: String;
	pxySealTi 			: CM_SealTI;
	sealedDT 			: TimeStamp;
	loadState 			: Boolean;
	sealNumArray 		: HugeStringArray; //jlgka1 TFS 44020
	editFieldsValues 	: HugeStringArray; //jlgka1 TFS 44020
	
begin
	
	trackedItem := _cargo;	
	_proxySealCheckTrx.setMyTrackedItem(trackedItem,null);
	theTIProxy := trackedItem.pxyGetProxyObject;

	create txnController transient;
	txnController.type := TRANS_TYPE_SEAL_CHECK;
	txnController.noCharge := false; // TFS 3844 changed to false
	txnController.myTrackedItem := trackedItem;
	txnController.myTITransaction := _proxySealCheckTrx;

/*	
	//Add the to do task to the TI proxy if required.
	toDoTaskDescToAdd := self.getToDoTaskDescToAdd( ti );
	if toDoTaskDescToAdd &lt;&gt; null then
		tiUpdateRequired := true;
		theTIProxy.addToDoTask( toDoTaskDescToAdd.description, _passport );
	endif;
	*/
	
	
	//Update the seal values on the proxy TI, for the ones that the user said they wanted updated. (Can only happen in 'Full' mode) 
	if _updateSealsArray &lt;&gt; null and not _updateSealsArray.isEmpty then
	
		app.cmsBeginLoad(loadState);
		tiUpdateRequired := true;
		create editFieldsValues transient;

		foreach obj in _updateSealsArray do

			updateSealType := obj.CM_SealType;
			pxySealCheckDetail := _proxySealCheckTrx.getSealCheckDetailForSealType( updateSealType.sealType );
			if pxySealCheckDetail = null then
				// we had an object that we were supposed to make changes from and now its gone ???
				return null;
			endif;

			sealAfter := pxySealCheckDetail.sealAfter;
			sealBefore := pxySealCheckDetail.sealBefore;
			// find the existing seal data on the proxy ti. If its there, update it, otherwise create it.
			pxySealTi := theTIProxy.getSealTI(updateSealType);
			if pxySealTi = null then
				//create it.
				create pxySealTi transient;
				sealedDT := app.actualTimeServer();
			else
				sealedDT := pxySealTi.sealedDT;
			endif;
			
			if updateSealType.allowMultipleSealNums then
				if sealAfter.pos(",",1) &gt; 0 then
					create sealNumArray transient;					
					sealAfter.getTokensForDelimiterHuge(",",sealNumArray); //jlgka1 TFS 44020
				endif;
			endif;
		
			pxySealTi.setProxy(	sealAfter,	//_sealNum : String;
								sealNumArray,	//_sealNumArray : StringArray;
								sealBefore,	//_prevSeal : String;
								updateSealType.sealType,	//_sealType : String;
								sealedDT,	//_sealedDT : TimeStamp;
								theTIProxy	//_myTrackedItem : CM_TrackedItem
								);
								
			if sealNumArray &lt;&gt; null then
				delete sealNumArray;
			endif;
			
			//gather up the edit details for the CM_Edit transaction
			self.updateSealChecksTIEdit(trackedItem,  pxySealTi, editFieldsValues );
			
		endforeach;
		app.cmsEndLoad(loadState);
		
	endif;
	
//	app.myPassport.clearErrorsWarnings();
	
	app.myTrxCA.trxCreateSealsCheckTransaction( txnController, theTIProxy, tiUpdateRequired, null, newTITxn, editFieldsValues, app.myPassport);

	if app.myPassport.trxCompletedOK then
		app.myPassport.clearErrorsWarnings();
		return newTITxn.CM_SealCheck;
		
	else
		return null;
		
	endif;

epilog

	delete txnController;
	delete sealNumArray;
	delete editFieldsValues;
	app.cmsEndLoad(loadState);
	app.mousePointer :=	Idle;
end;</source>
        <Parameter name="_cargo" type="CM_TrackedItem"/>
        <Parameter name="_proxySealCheckTrx" type="CM_SealCheck" usage="io"/>
        <Parameter name="_updateSealsArray" type="CM_ObjectArray"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <ReturnType type="CM_SealCheck"/>
    </JadeMethod>
    <JadeMethod name="updateTrackedItem" id="19b4b955-88cc-472e-9338-582d75d80191">
        <options>4</options>
        <source>updateTrackedItem(_pxyTrackedItem		: CM_TrackedItem input; 
					_wsCargo			: WS_RestCargoObject;
					_cargoType			: CM_CargoType;
					_terminal			: CM_Terminal;
					_statusCode			: Integer io;
					_objectsToBeDeleted	: ObjectArray input;
					_isPost,
					_isChild			: Boolean) typeMethod;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 Apr 2023	navpw1	Initial creation TFS: 56851
05 Jan 2024	naviv1	Change Request-57211 - CUX - MTN-EDBIC - 070 &amp; 090 - PUT Cargo Update
06 Feb 2024	naviv1	BUG-62287 - CUX - HTTP 500 Errors in postCargo (1090 exception when processing a cargo item update)
07 Feb 2024 navsaa30 ChangeRequest 62323: CUX | POST cargo to allow bookingId
11 Mar 2024 naviv1	Bug 62829 - CUX | PUT CargoUpdate Issue on Prenotified Cargos
19 Mar 2023	naviv1	Bug 62971 - CUX FR | PUT /Cargo moves PreNote to Onsite - GoLCrit - 01 
22 Mar 2024	navcs2	ChangeRequest 63087: CUX FR* | Tk62873 CARGO APIs POST/PUT/GET - Additional Fields requested - GoLCrit - 01
08 May 2024	naviv1	TFS 63943 : CUX - Code 88778 when trying to create a Rail Prenote for a Wagon with the "Default" Train via POST /Cargo endpoint
21 May 2024	navdap1	TFS 63619 CUX | FR - POST and PUT /Cargo not saving Customs References for Onboard Cargo
05 Jun 2024 navsaa30	Bug 64390: CUX - Stowage Position Error when creating onship cargo via POST /Cargo
12 Jun 2024	navhn30	ChangeRequest 64067: CUX | Include additional fields in APIs (Free Text)
22 Jul 2024 navhn30 ChangeRequest 64906: CUX | EDBIC Stop type information on GET/ customs status
11 Sep 2024 navhn30 Bug 65980: CUX | PUT /cargo locationId should be read only
23 Sep 2024	navhn30	Bug 66239: CUX - API POST cargo with reefer Code 89407
26 Nov 2024 navhn30 Bug MTN-33183: CUX - API POST/PUT for packed container does not change voyage
09 Dec 2024	navpw1	JIRA: MTN-19348 - Added new parameter _isChild for setting whether this is child cargo so we can exclude hazards if there are issues with them.
07 Oct 2025	navdap1	MTN-36141 AAT } Rotaox Creation (EDI/API/Manual)
21 Nov 2025 navbk1  MTN-35982 CUX | API PUT /cargo not able to remove hazards or customsReferences
*/

vars
	hazard						: CM_TIHazard;
	wsCustomsReference			: WS_RestCustomsReferenceObject;
	operator					: CM_Operator;
	consignor,
	consignee					: CM_ConsigneeConsignor;
	product						: CM_Product;
	commodity					: CM_Commodity;
	iter						: Iterator;
	pxyCustomsReference,
	existingCustomsReference	: CM_CustomsReference;
	totalPackages,
	remainingPackages			: Integer;
	wsHazard					: WS_RestHazardObject;
	hazardClass					: CM_HazardClass;
	hazardsDict					: CM_HazardByCodeDict;
	receivalDetails				: WS_RestReceivalDetailObject;
	releaseDetails				: WS_RestReleaseDetailObject;
	vehicle						: CM_Vehicle;
	train						: CM_Train;
	wagon						: CM_Wagon;
	rootObject					: CM_Root;
	commodityCode				: String;
	priority					: CM_CustomerPriority;
	reeferDets					: WS_RestReeferObject;
	ventMeasure					: CM_MeasurementType;
	isoTypeObj					: CM_ISOType;			// MTN-36141
	contentsCargoType			: CM_CargoType;			// MTN-36141
	contentsCargoSubType		: CM_Product;			// MTN-36141
	
begin
	rootObject := app.myRoot;
	
	operator	:= rootObject.allOperators[_wsCargo.operatorId];
	consignor	:= rootObject.allConsigneeConsignors[_wsCargo.consignorId];
	consignee	:= rootObject.allConsigneeConsignors[_wsCargo.consigneeId];
	commodity	:= rootObject.allCommodities[_wsCargo.commodityId];
	priority	:= rootObject.allCustomerPriorities[_wsCargo.customerPriority];		// 12.06.24		navhn30		TFS #64067
	
	if operator = null then
		app.raiseCMException1(Operator_found, _wsCargo.operatorId, null, null);
		_statusCode := HttpResponseClientError;
		return;
	endif;
	
	if consignor = null and _wsCargo.consignorId &lt;&gt; null then
		app.raiseCMException1(Consignor_Not_Found, _wsCargo.consignorId, null, null);
		_statusCode := HttpResponseClientError;
		return;
	endif;
	
	if consignee = null and _wsCargo.consigneeId &lt;&gt; null then
		app.raiseCMException1(Consignee_Not_Found, _wsCargo.consigneeId, null, null);
		_statusCode := HttpResponseClientError;
		return;
	endif;
	
	if commodity = null and _wsCargo.commodityId &lt;&gt; null then
		app.raiseCMException1(Commodity_Not_Found, _wsCargo.commodityId, null, null);
		_statusCode := HttpResponseClientError;
		return;
	endif;
	
	if commodity &lt;&gt; null then
		commodityCode := commodity.code;
	endif;
	
	_pxyTrackedItem.setPxyFromDefaultTI(_terminal, _cargoType.id, _wsCargo.id.toUpper, commodityCode, operator);	// TFS 63619
	
	if _cargoType.isSubCargoTypeRequired then
		product := _cargoType.allProducts[_wsCargo.operatorId, _wsCargo.cargoSubTypeId];
		
		if product = null then
			iter := _cargoType.allProducts.createIterator;
			_cargoType.allProducts.startKeyGeq(null, _wsCargo.cargoSubTypeId, iter);
			while iter.next(product) do
				if product.code &lt;&gt; _wsCargo.cargoSubTypeId then
					continue;
				elseif product.code = _wsCargo.cargoSubTypeId then
					break;
				endif;
			endwhile;
			delete iter;
		endif;
		
		if product = null or product.code &lt;&gt; _wsCargo.cargoSubTypeId then
			app.raiseCMException2(Cargo_SubType_Not_Found_CType, _wsCargo.cargoSubTypeId, _wsCargo.cargoTypeId, null, null);
			_statusCode := HttpResponseClientError;
			return;
		endif;
		
		_pxyTrackedItem.setMyProduct(product);
	endif;
	
	_pxyTrackedItem.setOrderNumber(_wsCargo.orderNumber);					//22/03/2024	navcs2	ChangeRequest 63087
	_pxyTrackedItem.setDescription(_wsCargo.description);				//22/03/2024	navcs2	ChangeRequest 63087
	_pxyTrackedItem.setSecondaryBarcodeId(_wsCargo.secondaryBarcodeId);		//22/03/2024	navcs2	ChangeRequest 63087
	

	
	if _pxyTrackedItem.isBreakBulkGeneric then
		_pxyTrackedItem.CM_BreakBulk.setGrammage(_wsCargo.grammage);							//22/03/2024	navcs2	ChangeRequest 63087
		_pxyTrackedItem.CM_BreakBulk.setRollingLength(_wsCargo.rollingLength);					//22/03/2024	navcs2	ChangeRequest 63087
		_pxyTrackedItem.CM_BreakBulk.setDiameter(_wsCargo.diameter);							//22/03/2024	navcs2	ChangeRequest 63087
		_pxyTrackedItem.CM_BreakBulkGeneric.setGrade(_wsCargo.grade);							//22/03/2024	navcs2	ChangeRequest 63087
		_pxyTrackedItem.setTotalQuantity(_wsCargo.totalQuantity);								//12.Apr.24 navsp1 TFS 63630
	endif;																						//22/03/2024	navcs2	ChangeRequest 63087
	
	_pxyTrackedItem.setBookingReference(_wsCargo.bookingId);       // 07.02.24 navsaa30 #62323
	_pxyTrackedItem.setCommodity(commodityCode);
	
	if _wsCargo.isoTypeId &lt;&gt; null then
		_pxyTrackedItem.setISOType(_wsCargo.isoTypeId);
	endif;
	
	_pxyTrackedItem.zSetPxyDensity(_wsCargo.density);
	
	//volume
	_pxyTrackedItem.setTotalVolumeWithoutTrans(_wsCargo.volume);
	
	if _wsCargo.weights &lt;&gt; null then
		_pxyTrackedItem.setTotalWeight(_wsCargo.weights.gross, null, app.myPassport);
		_pxyTrackedItem.setWeightCargo(_wsCargo.weights.net);
		_pxyTrackedItem.setWeightTare(_wsCargo.weights.tare);
	else
		_pxyTrackedItem.setTotalWeight(null, null, app.myPassport);
		_pxyTrackedItem.setWeightCargo(null);
		_pxyTrackedItem.setWeightTare(null);
	endif;
	
	if _wsCargo.dimensions &lt;&gt; null then
		_pxyTrackedItem.setHeight(_wsCargo.dimensions.height);
		_pxyTrackedItem.setLength(_wsCargo.dimensions.length);
		_pxyTrackedItem.setWidth(_wsCargo.dimensions.width);
	endif;
	
	_pxyTrackedItem.zSetPxyAlternativeId(_wsCargo.alternativeId);
	
	if _isPost then				//11.09.24	navhn30	 TFS 65980
		_pxyTrackedItem.zSetPxyLocationId(_wsCargo.locationId);
	endif;
	
	if consignee &lt;&gt; null then
		_pxyTrackedItem.setConsignee(consignee.code, null, app.myPassport);
	else																		//13.1.2024 naviv1 57211
		_pxyTrackedItem.setConsignee(null, null, app.myPassport);
	endif;
	
	if consignor &lt;&gt; null then
		_pxyTrackedItem.setConsignor(consignor.code, null, app.myPassport);
	else																		//13.1.2024 naviv1 57211
		_pxyTrackedItem.setConsignor(null, null, app.myPassport);
	endif;
	
	_pxyTrackedItem.setContentsStatus(app.contentStatusStringToEnum(_wsCargo.contentsStatusId));
	_pxyTrackedItem.setImExStatus(app.imexStatusStringToEnum(_wsCargo.imexStatus));
	
	//hazards
	create hazardsDict transient;
	_objectsToBeDeleted.add(hazardsDict);
	
	if _wsCargo.hazards.isNotEmpty then
		foreach wsHazard in _wsCargo.hazards do
			//Find hazard code to validate??
			//Get a hazard class??
			hazardClass := app.myRoot.allHazardClasses[wsHazard.id];
			if hazardClass = null then
				app.raiseCMException1(Hazard_code_not_found, wsHazard.id, null, null);
				_statusCode := HttpResponseClientError;
				return;
			endif;
			
			create hazard transient;
			hazard.setProxy(hazardClass.code, hazardClass.description, wsHazard.undgNumber, null, wsHazard.limitedQuantity, wsHazard.packingGroupId,
							wsHazard.flashpointTemperature, wsHazard.marinePollutant, wsHazard.acidBase);
			// ### JIRA: MTN-19348 09Dec2024 NAVPW1
			if _isChild and not WS_WebServiceAgent@validateTIHazard(hazard, _terminal) then
				delete hazard; //If the hazard is not valid delete the proxy as we will not be able to create the tracked item if it has invalid hazards and we need to do this.
				continue;
			endif;
			// ### JIRA: MTN-19348 09Dec2024 NAVPW1
			hazardsDict.add(hazard);
			_objectsToBeDeleted.add(hazard);
		endforeach;
		
		//_pxyTrackedItem.zSetPxyTIHazards(hazardsDict);					//21.11.2025 navbk1 #35982
		
	endif;
	_pxyTrackedItem.zSetPxyTIHazards(hazardsDict);							//21.11.2025 navbk1 #35982
	
	//reeferProperties
	// TFS 66239 correct reefer details handling
	if _wsCargo.reeferProperties &lt;&gt; null then
		reeferDets := _wsCargo.reeferProperties;
		if reeferDets.carbonDioxide = null or reeferDets.carbonDioxide = NULL_CARBON_DIOXIDE then
			_pxyTrackedItem.setCarbonDioxide(NULL_CARBON_DIOXIDE);
		else
			_pxyTrackedItem.setCarbonDioxide(reeferDets.carbonDioxide);
		endif;
		
		if reeferDets.humidity = null or reeferDets.humidity = NULL_HUMIDITY then
			_pxyTrackedItem.setHumidity(NULL_HUMIDITY);
		else
			_pxyTrackedItem.setHumidity(reeferDets.humidity);
		endif;
		
		if reeferDets.oxygen = null or reeferDets.oxygen = NULL_OXYGEN then
			_pxyTrackedItem.setOxygen(NULL_OXYGEN);
		else
			_pxyTrackedItem.setOxygen(reeferDets.oxygen);
		endif;
		
		if reeferDets.vent = null or reeferDets.vent = NULL_VENTILATION then
			_pxyTrackedItem.setVentilation(NULL_VENTILATION);
		else
			if reeferDets.ventUnits = 2 then
				ventMeasure := app.myRoot.allMeasurementTypesByShortName["ft3/hr"];
				if ventMeasure &lt;&gt; null then
					_pxyTrackedItem.setVentilation(app.convertMeasurementForStorage(ventMeasure.shortName, reeferDets.vent));
				else
					_pxyTrackedItem.setVentilation(reeferDets.vent);
				endif;
			else
				_pxyTrackedItem.setVentilation(reeferDets.vent);
			endif;
		endif;
		
		if reeferDets.temperature = NULL_TEMPERATURE then
			_pxyTrackedItem.setTemperature(NULL_TEMPERATURE);
		else
			if reeferDets.fahrenheit then
				_pxyTrackedItem.setTemperature(app.myRoot.convFahrenheitToCelsius(reeferDets.temperature));
			else
				_pxyTrackedItem.setTemperature(reeferDets.temperature);
			endif;
		endif;
	endif;
	
	_pxyTrackedItem.setDischargePort(_wsCargo.dischargePortId);
	_pxyTrackedItem.setDestinationPort(_wsCargo.destinationPortId);
	_pxyTrackedItem.setLoadPort(_wsCargo.loadPortId);
	
	//receivalDetails
	if _wsCargo.receivalDetails &lt;&gt; null then								
		receivalDetails := _wsCargo.receivalDetails;
		
		if receivalDetails.type = receivalDetails.Receival_Ship then			//08-May-2024 naviv1 #63943
			//Sets the voyage code based off the id if it exists
			if receivalDetails.id &lt;&gt; null then
				_pxyTrackedItem.setVoyageCode(receivalDetails.id, app.myPassport);		//05/06/24   navsaa30  #64390
			endif;
			//if _pxyTrackedItem.myVoyage &lt;&gt; null then						//06.02.2024 naviv1 #62287
				_pxyTrackedItem.setReceiptTransportMode(TI_TRANSMODE_SHIP);
			//endif;
			
		elseif receivalDetails.type = receivalDetails.Receival_Truck then		//08-May-2024 naviv1 #63943
			//find truck/vehicle visit using id
			vehicle := _terminal.vehicles.getAtKey(receivalDetails.id, null);
			if vehicle &lt;&gt; null and vehicle.regNumber = receivalDetails.id then
				_pxyTrackedItem.setReceiveTruck(vehicle.regNumber);
			endif;
			_pxyTrackedItem.setReceiptTransportMode(TI_TRANSMODE_ROAD);			//06.02.2024 naviv1 #62287
			
		elseif receivalDetails.type = receivalDetails.Receival_Train then		//08-May-2024 naviv1 #63943
			//find train using id
			train := _terminal.allTrainsOnTerminal.getAtKeyGeq(receivalDetails.id, null);
			if train &lt;&gt; null and train.code = receivalDetails.id then
				_pxyTrackedItem.setMyTrainAssigned(train, app.myPassport);
			endif;
			_pxyTrackedItem.setReceiptTransportMode(TI_TRANSMODE_RAIL);			//06.02.2024 naviv1 #62287
			
		elseif receivalDetails.type = receivalDetails.Receival_Wagon then		//08-May-2024 naviv1 #63943
			//find wagon using id
			wagon := _terminal.allWagons.getAtKeyLeq(receivalDetails.id, null);
			if wagon &lt;&gt; null and wagon.id = receivalDetails.id then
				train := wagon.myTrainInwards;
				if train = null then
					train := wagon.myTrainOutwards;
				endif;
				_pxyTrackedItem.setMyTrainAssigned(train, app.myPassport);
				_pxyTrackedItem.setWagon(wagon.id, wagon, wagon.myWagonClass, false);
			endif;
			_pxyTrackedItem.setReceiptTransportMode(TI_TRANSMODE_RAIL);			//06.02.2024 naviv1 #62287
			
		else
			app.raiseCMException1(Receive_Detail_Type_Invalid, receivalDetails.type, null, null);	//06.02.2024 naviv1 #62287
			_statusCode := HttpResponseClientError;
			return;
			
		endif;
		
		_pxyTrackedItem.setCarrier(receivalDetails.carrierId);
		_pxyTrackedItem.setReceivedDT(receivalDetails.dateTime.asUTCTimeStamp.utcToLocalTime);
		
	endif;
	
	//releaseDetails
	if _wsCargo.releaseDetails &lt;&gt; null then
		releaseDetails := _wsCargo.releaseDetails;
		
		if releaseDetails.type = releaseDetails.Release_Ship then				//10-May-2024 naviv1 #63943
			//Sets the voyage code based off the id if it exists
			_pxyTrackedItem.setVoyageCode(releaseDetails.id, app.myPassport);
			//if _pxyTrackedItem.myVoyage &lt;&gt; null then							//06.02.2024 naviv1 #62287
				_pxyTrackedItem.setReleasedTransportMode(TI_TRANSMODE_SHIP);			
			//endif;
			
		elseif releaseDetails.type = releaseDetails.Release_Truck then			//10-May-2024 naviv1 #63943
			//find truck/vehicle visit using id
			vehicle := _terminal.vehicles.getAtKeyGeq(releaseDetails.id, null);
			if vehicle &lt;&gt; null and vehicle.regNumber = releaseDetails.id then
				_pxyTrackedItem.setReleaseTruck(vehicle.regNumber);
			endif;
			_pxyTrackedItem.setReleasedTransportMode(TI_TRANSMODE_ROAD);			//06.02.2024 naviv1 #62287
		elseif releaseDetails.type = releaseDetails.Release_Train then			//10-May-2024 naviv1 #63943
			//find train using id
			train := _terminal.allTrainsOnTerminal.getAtKeyGeq(releaseDetails.id, null);
			if train &lt;&gt; null and train.code = releaseDetails.id then
				_pxyTrackedItem.setMyTrainAssigned(train, app.myPassport);
			endif;
			_pxyTrackedItem.setReleasedTransportMode(TI_TRANSMODE_RAIL);			//06.02.2024 naviv1 #62287
		elseif releaseDetails.type = releaseDetails.Release_Wagon then			//10-May-2024 naviv1 #63943
			//find wagon using id
			wagon := _terminal.allWagons.getAtKeyLeq(releaseDetails.id, null);
			if wagon &lt;&gt; null and wagon.id = releaseDetails.id then
				train := wagon.myTrainInwards;
				if train = null then
					train := wagon.myTrainOutwards;
				endif;
				_pxyTrackedItem.setMyTrainAssigned(train, app.myPassport);
				_pxyTrackedItem.setWagon(wagon.id, wagon, wagon.myWagonClass, false);
			endif;
			_pxyTrackedItem.setReleasedTransportMode(TI_TRANSMODE_RAIL);			//06.02.2024 naviv1 #62287
		else
			app.raiseCMException1(Release_Detail_Type_Invalid, releaseDetails.type, null, null);
			_statusCode := HttpResponseClientError;
			return;
			
		endif;
		
		_pxyTrackedItem.setReleaseCarrier(releaseDetails.carrierId);
		_pxyTrackedItem.setReleasedDT(releaseDetails.dateTime.asUTCTimeStamp.utcToLocalTime);
		
	endif;
	
	_pxyTrackedItem.zSetPxyRemarks(_wsCargo.remarks);
	_pxyTrackedItem.setShipmentNumber(_wsCargo.shipmentNumber);		// 12.06.24		navhn30 	TFS 64067
	_pxyTrackedItem.setMyCustomerPriority(priority);				// 12.06.24		navhn30		TFS #64067
	
	//voyageId
	_pxyTrackedItem.setVoyageCode(_wsCargo.voyageId, app.myPassport); // 26.11.24	navhn30	 	MTN-33183	moved this line down, as the voyageId is getting overriden by ship type receivalDetails id
	
	//customsReferences
	foreach wsCustomsReference in _wsCargo.customsReferences do
		if _pxyTrackedItem.allCustomsReferences &lt;&gt; null then
			existingCustomsReference := _pxyTrackedItem.allCustomsReferences[wsCustomsReference.typeId, wsCustomsReference.id, wsCustomsReference.position];
		endif;
		
		if wsCustomsReference.packages &lt;&gt; null then
			totalPackages := wsCustomsReference.packages.total;
			remainingPackages := wsCustomsReference.packages.remaining;
		endif;
		
		if existingCustomsReference &lt;&gt; null then
			existingCustomsReference.setProxyForUpdate(wsCustomsReference.status, wsCustomsReference.alternateId , totalPackages, remainingPackages, 
													wsCustomsReference.remarks, wsCustomsReference.retentionPeriod);	// 22.07.24	 navhn30 TFS #64906	
			continue;
		endif;
		
		create pxyCustomsReference transient;
		_objectsToBeDeleted.add(pxyCustomsReference);
		
		pxyCustomsReference.setProxy(wsCustomsReference.typeId, wsCustomsReference.id, wsCustomsReference.position, wsCustomsReference.status, wsCustomsReference.alternateId,
										totalPackages, remainingPackages, wsCustomsReference.remarks, wsCustomsReference.retentionPeriod);	// 22.07.24	 navhn30 TFS #64906
		pxyCustomsReference.setTrackedItem(_pxyTrackedItem);
		_pxyTrackedItem.addProxyCustomsReference(pxyCustomsReference);
		
	endforeach;
	if _wsCargo.customsReferences = null or _wsCargo.customsReferences.isEmpty() then					//21.11.2025 navbk1 #35982
		_pxyTrackedItem.pxyDeleteCustomsReferences();													//21.11.2025 navbk1 #35982
	endif;																								//21.11.2025 navbk1 #35982
	
	// MTN-36141 Allow on site rotabox creation through the API
	if _cargoType.isContainer and _wsCargo.isoTypeId &lt;&gt; null then
		isoTypeObj := app.myRoot.allISOTypes[_wsCargo.isoTypeId];
		if isoTypeObj &lt;&gt; null and isoTypeObj.isRotatable() and _wsCargo.state = TI_STATE_NORMAL then
			// Set Contents Cargo Type / Cargo Sub Type details
			contentsCargoType := app.myRoot.getCargoTypeFromAbbrev(_wsCargo.contentsCargoTypeId);
			if contentsCargoType &lt;&gt; null then
				_pxyTrackedItem.setCargoTypeForContents(contentsCargoType);
				if contentsCargoType.isSubCargoTypeRequired then
					contentsCargoSubType := contentsCargoType.allProducts[_wsCargo.operatorId, _wsCargo.cargoSubTypeId];
					if contentsCargoSubType = null then
						contentsCargoSubType := contentsCargoType.allProducts[null, _wsCargo.cargoSubTypeId];
					endif;
					
					_pxyTrackedItem.setMyProduct(contentsCargoSubType);
				endif;
			endif;
		endif;
	endif;
	
	if _wsCargo.state &lt;&gt; null then			//11.03.2024 naviv1 #62829
		_pxyTrackedItem.setStatePxy(_wsCargo.state);
	//else										//19.03.2024 naviv1 #62971 -- removed this else block since its setting the state to Onsite when this method is called from putCargo 
		//_pxyTrackedItem.setStatePxy(TI_STATE_NORMAL);
	endif;
end;

</source>
        <Parameter name="_pxyTrackedItem" type="CM_TrackedItem" usage="input"/>
        <Parameter name="_wsCargo" type="WS_RestCargoObject"/>
        <Parameter name="_cargoType" type="CM_CargoType"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_statusCode" type="Integer" usage="io"/>
        <Parameter name="_objectsToBeDeleted" type="ObjectArray" usage="input"/>
        <Parameter name="_isPost" type="Boolean"/>
        <Parameter name="_isChild" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="updateVesselHoldSlotLinks" id="e0c430a6-5c86-40ad-b05e-c0c12f2b9982">
        <source>updateVesselHoldSlotLinks(pxyHold : CM_VesselHold);
/*

Purpose:			
	// PAR 33443 the WS bay objects have no references to other bays and the WS slot objects do not have refs to other slots.
	// This is all needed to set back end settings for 40s. 

Parameters:			

Return Value:		

Date		Who		Reason
01 February 2013	cnwer1	Initial creation HAT 2189

*/

vars
	lastBay, firstBay,	pxyBay : CM_Bay;
	middleBay : CM_Bay;
begin

	foreach pxyBay in pxyHold.allBays discreteLock do
		if firstBay = null then // 1st bay
			firstBay := pxyBay;
		elseif middleBay = null then // 2nd bay
			middleBay := pxyBay; // this is the fwd if we are in a triple bay hold
		endif;
		lastBay := pxyBay;
	endforeach;
 	if pxyHold.allBays.size = 2 then
		if firstBay &lt;&gt; null then
			if lastBay &lt;&gt; null then
				firstBay.setMyAftBay(lastBay);
			endif;
			firstBay.updateSlotLinks();
		endif;
	elseif pxyHold.allBays.size = 3 then
		if middleBay &lt;&gt; null then
			if lastBay &lt;&gt; null then
				middleBay.setMyAftBay(lastBay);
			endif;
			middleBay.updateSlotLinks();
		endif;
		if firstBay &lt;&gt; null then
			if middleBay &lt;&gt; null then
				firstBay.setMyAftBay(middleBay);
			endif;
			firstBay.updateSlotLinks();
		endif;
	endif;
	

epilog
end;</source>
        <Parameter name="pxyHold" type="CM_VesselHold"/>
    </JadeMethod>
    <JadeMethod name="updateVoyage" id="0eac5d6f-604a-4c7b-ba67-fa8e1409c240">
        <options>4</options>
        <source>updateVoyage(_request : WS_RestVoyageObject; _terminal : CM_Terminal; _voyageId : String; _statusCode : Integer io; _objectsToBeDeleted : ObjectArray input) typeMethod;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
24 March 2023	navlw1	Initial creation TFS 57245 (57246) CR CUX - MTN-EDBIC - 160 - Put Voyage
19 Dec 2023		navlw1	Bug 60597: 	CUX | EDBIC - Put /voyage/{id} RestAPI doesn't do what the swagger definition suggests
12 Feb 2024		naviv1	CR 62354: CUX | FR 56696 - Ticket 62329 - Populate Trade from API and add Ports of Call
04 Jul 2024 	navhn30  ChangeRequest 64828: CUX - Include Voyage Status in GET /voyage response
15 Jul 2024		navmd1	TFS 65226 fixed timestamps doing Local-&gt;UTC instead of UTC-&gt;Local conversion. Also moved validation to common method
19 Jul 2024		navmd1	TFS 64828 Simplify proxy setting by creating a new 'FromAPI' method with only the fields we need
22 Jul 2024		navdap1	TFS 65286 CUX | Include cargo structure flags in voyage API
08 Aug 2024		navhn30 Bug 65480: CUX | Issues on POST/PUT Voyage when includes Cargo structure flags
*/

vars
	voyageId 				: String;
	wsVesselObject			: WS_RestVesselObject;
	arrivalDateTime,
	departDateTime,
	estimatedArrivalDT,
	estimatedDepartDT		: TimeStamp;
	realVoyage,
	theProxyVoyage			: CM_Voyage;
	theProxyVessel,
	realVessel				: CM_Vessel;
	wsVoyageObject			: WS_RestVoyageObject;
	vesselOperator,
	voyageOperator			: CM_Operator;
	hmsConflict				: CMIF_HMS_ConflictsManager;
	trade					: CM_Trade;
	shippingLine			: CM_ShippingLine;
	theProxyVoyGlobal 		: CM_VoyageGlobal;
	newVoyageCode,
	callSign,
	imo,
	vesselName				: String;
	loa 					: Integer;
	hmsData 				: HMS_VesselData;
	voyageProcess			: CM_VoyageProcess;
	status					: Integer;
	validOperators			: CM_OperatorByCodeDict;
	pxyGCStructure			: CM_GeneralCargoVoyageStructure;
	pxyROROStructure		: CM_ROROVoyageStructure;
	pxyLOLOStructure		: CM_CellularVoyageStructure;
	voyageType				: WS_RestVoyageTypeObject;
begin
	wsVoyageObject := _request;
	wsVesselObject := wsVoyageObject.vessel;
	voyageId := wsVoyageObject.id;
	
	if not wsVoyageObject.validateRequest() then
		return;
	endif;
	
	if voyageId &lt;&gt; _voyageId then
		voyageId := _voyageId;
	endif;

	wsVoyageObject.getDatesAsLocalTime(arrivalDateTime, departDateTime, estimatedArrivalDT, estimatedDepartDT);
	
	realVoyage := WS_WebServiceAgent@findVoyage(_terminal, voyageId, arrivalDateTime, false);
	if realVoyage = null then
		app.raiseCMException1(Voyage_not_found, voyageId, null, null);
		_statusCode := HttpResponseNotFound;
		return;
	endif;
	
	if realVoyage.vesselCode &lt;&gt; wsVesselObject.id then
		_statusCode := HttpResponseNotFound;
		app.raiseCMException2(Voyage_current_vessel, voyageId, realVoyage.vesselName &amp; " and cannot be changed", null, null);
		return;
	endif;
	// voyageStatus validation
	voyageProcess := realVoyage.myVoyageProcess;								//04.07.24	 navhn30	TFS #64828
	if voyageProcess &lt;&gt; null then
		if wsVoyageObject.status &lt;&gt; null then 
			if voyageProcess.allStatusesById[wsVoyageObject.status] = null then
				app.raiseCMException1(Not_valid_voyage_status, wsVoyageObject.status.String ,null,null);
				_statusCode := HttpResponseNotFound;
				return;
			else
				status := wsVoyageObject.status;
			endif;
		else 
			status := voyageProcess.getInitialVoyageStatus.id;
		endif;
	else
			status := wsVoyageObject.status;
	endif;
	//trade := app.myRoot.allTradesByDescription.getByCode(wsVoyageObject.tradeId);
	trade := app.myRoot.allTradesByDescription[wsVoyageObject.tradeId];		//12.02.2024 naviv1	#62354
	newVoyageCode := wsVoyageObject.id;
	
	if wsVoyageObject.shippingLineId &lt;&gt; null then
		shippingLine := app.myRoot.allShippingLines[wsVoyageObject.shippingLineId];
	endif;
	
	//vesselName 	:= wsVesselObject.name;
	//imo			:= wsVesselObject.imo;
	
	theProxyVoyage := app.createUpdateProxy(realVoyage).CM_Voyage;
	
	create theProxyVoyGlobal transient;
	create theProxyVessel transient;
	
	_objectsToBeDeleted.add(theProxyVoyage);
	_objectsToBeDeleted.add(theProxyVoyGlobal);
	_objectsToBeDeleted.add(theProxyVessel);
	
	realVessel := app.myRoot.allVessels[wsVesselObject.id];
	voyageOperator := app.myRoot.allOperators[wsVoyageObject.operatorId];
	vesselOperator := app.myRoot.allOperators[wsVesselObject.operatorId];
	
	if voyageOperator = null then
		// Try and grab it off the passed in Vessel instead
		voyageOperator := app.myRoot.allOperators[wsVesselObject.operatorId];
		if voyageOperator = null and realVessel &lt;&gt; null then
			// Failing that, try and grab it off the *real* vessel
			voyageOperator := realVessel.myOperator;
		endif;
	endif;
	
	if voyageOperator = null then
		app.raiseCMException1(Operator_one, "cannot be found", null, null);
		return;
	endif;
	
	// check that the vessel exists
	if realVessel = null then
		// You can't change Vessels - so realVessel will never be null!
		app.raiseUnexpectedProgramError(selfType.class.name, method.name, "Trying to update a Voyage for a Vessel that doesn't exist");
		
		/*create hmsData transient;
		_objectsToBeDeleted.add(hmsData);
	
		theProxyVessel.setProxyForVessel(null, wsVesselObject.id, vesselName, wsVesselObject.callSign, null, null, null,
		imo,null,null,null,null,null,
		null,null,null,null,null,null,null,false,false,vesselOperator,null,false);
		
		// update HMS data to include LOA
		hmsData.setProxy(app.myRoot,false,false,false,false,false,false,false,false,null,null,null,null,null,null,wsVesselObject.loa,null,null,null,null,
		null,null,null,null,null,null);
		theProxyVessel.setHMSVesselData(hmsData);
		
		//create the vessel
		app.myTrxCA.trxCreateVessel(theProxyVessel,realVessel,hmsConflict,app.myPassport);
		*/
	else
		// create the proxy for the vessel
		theProxyVessel := app.createUpdateProxy(realVessel).CM_Vessel;
		
		// (Vessel) imo (customisable per Voyage)
		if wsVesselObject.imo = null then
			imo := theProxyVoyage.lloydsNumber;
		else
			imo := wsVesselObject.imo;
		endif;
		
		// (Vessel) name (customisable per Voyage)
		if wsVesselObject.name = null then
			vesselName := theProxyVoyage.vesselName;
		else
			vesselName 	:= wsVesselObject.name;
		endif;
		
		// (Vessel) call sign (customisable per Voyage)
		if wsVesselObject.callSign = null then
			callSign := theProxyVoyage.callSign;
		else
			callSign := wsVesselObject.callSign;
		endif;
		
		// Operator
		if vesselOperator = null then
			vesselOperator := voyageOperator;
		endif;
		
		// (Vessel) loa (customisable per Voyage)
		if wsVesselObject.loa = null then
			if theProxyVoyage.myHMSVoyageData &lt;&gt; null then
				loa := theProxyVoyage.myHMSVoyageData.dim_LengthOverall.Integer;
			elseif realVessel.myHMSVesselData &lt;&gt; null then
				loa := realVessel.myHMSVesselData.dim_LengthOverall.Integer;
			else
				loa := 0;	// If we fall in here, we probably don't care about LOA - but we shouldn't as HMS is always created now
			endif;
		else
			loa := wsVesselObject.loa;
		endif;
	
		theProxyVessel.setProxyForVessel(theProxyVessel.bitmap, theProxyVessel.code, vesselName, callSign, theProxyVessel.classLabel, theProxyVessel.remarks, theProxyVessel.clonedFromVessel, imo,
		theProxyVessel.dailyCost, theProxyVessel.despatchRate, theProxyVessel.craneClearance, theProxyVessel.vesselType, theProxyVessel.yearOfBuild, loa, theProxyVessel.airDraft, theProxyVessel.maxVesselBeam, theProxyVessel.draftBow,
		theProxyVessel.draftStern, theProxyVessel.draftMid, theProxyVessel.buildingLine, theProxyVessel.canCreateVoyages ,theProxyVessel.isDedicatedOrMulti, vesselOperator, trade, theProxyVessel.isBarge);
		
		hmsData := theProxyVessel.myHMSVesselData;
		// update HMS data to include LOA
		if hmsData &lt;&gt; null then
			hmsData.setProxy(app.myRoot,false,false,false,false,false,false,false,false,null,null,null,null,null,null,loa,null,null,null,null,
			null,null,null,null,null,null);
		endif;
		// update the vessel
		app.myTrxUA.trxUpdateVessel(theProxyVessel,false,false,hmsConflict,app.myPassport);
	endif;
	
	if shippingLine = null then
		shippingLine := theProxyVoyage.myShippingLine;
	endif;
	
	if not arrivalDateTime.isValid then
		arrivalDateTime := theProxyVoyage.arrivedDT;
	endif;
	
	if not departDateTime.isValid then
		departDateTime := theProxyVoyage.departedDT;
	endif;
	
	if not estimatedArrivalDT.isValid then
		estimatedArrivalDT := theProxyVoyage.estimatedArrivalDT;
	endif;
	
	if not estimatedDepartDT.isValid then
		estimatedDepartDT := theProxyVoyage.estimatedDepartureDT;
	endif;
	
	create validOperators transient;
	validOperators.add(vesselOperator);
	validOperators.tryAdd(voyageOperator);
	
	// TFS 65286 voyage structures
	if wsVoyageObject.voyageType &lt;&gt; null then
		voyageType := wsVoyageObject.voyageType;
		
		// Do we need a GC structure?
		if voyageType.holds and theProxyVoyage.myGeneralCargoVoyage = null then
			create pxyGCStructure transient;
			theProxyVoyage.setMyGeneralCargoVoyage(pxyGCStructure);
		// Do we need to get rid of the GC structure?
		elseif not voyageType.holds and theProxyVoyage.myGeneralCargoVoyage &lt;&gt; null then
			theProxyVoyage.setMyGeneralCargoVoyage(null);
		endif;
		
		// Do we need a LOLO structure?
		if voyageType.lolo and theProxyVoyage.myCellularVoyageStructure = null then
			create pxyLOLOStructure transient;				// 08.08.2024	navhn30	TFS #65480
			theProxyVoyage.setProxyVoyageCellullStructure(pxyLOLOStructure);
		// Do we need to get rid of the LOLO structure?
		elseif not voyageType.lolo and theProxyVoyage.myCellularVoyageStructure &lt;&gt; null then
			theProxyVoyage.setProxyVoyageCellullStructure(null);
		endif;
		
		// Do we need a RORO structure?
		if voyageType.roro and theProxyVoyage.myROROStructure = null then
			create pxyROROStructure transient;
			theProxyVoyage.setMyROROStructure(pxyROROStructure);
		// Do we need to get rid of the RORO structure?
		elseif not voyageType.roro and theProxyVoyage.myROROStructure &lt;&gt; null then		// 08.08.2024	navhn30	TFS #65480
			theProxyVoyage.setMyROROStructure(null);
		endif;
	endif;
	// TFS 65286 end
	
	// need to set the global voyage
	theProxyVoyGlobal.setProxy(newVoyageCode,vesselName,wsVesselObject.id,null,null,null,null,null,null,app.myRoot);
	
	theProxyVoyage.setProxyVoyageFromAPI(callSign, newVoyageCode, wsVoyageObject.inwardsCode, wsVoyageObject.externalCode, wsVoyageObject.remarks, vesselName, imo, status,
										arrivalDateTime, departDateTime, estimatedArrivalDT, estimatedDepartDT, voyageOperator, trade, shippingLine, theProxyVoyGlobal, realVoyage.myTerminal, validOperators);
	
	// purge the all port rotations before we add to it
	theProxyVoyage.allPortRotations.purge();
	wsVoyageObject.setPortRotationsForProxy(theProxyVoyage, trade);
	
	app.myTrxUA.trxUpdateVoyage(false, false, theProxyVoyage, hmsConflict, null, false, app.myPassport);
	
epilog
	delete theProxyVoyage;
	delete theProxyVessel;
	delete validOperators;
end;</source>
        <Parameter name="_request" type="WS_RestVoyageObject"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_voyageId" type="String"/>
        <Parameter name="_statusCode" type="Integer" usage="io"/>
        <Parameter name="_objectsToBeDeleted" type="ObjectArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="updateWorkPointJobSheet" id="f73467ba-a6a3-462e-a30c-cf3c509f40c1">
        <options>4</options>
        <source>updateWorkPointJobSheet(_realWorkPointJobSheet : CM_WorkPointJobSheet;
						_id 					   : String;
						_request			   : WS_RestWorkPointJSObject ; 
						_statusCode 		   : Integer io ) typeMethod;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25 Jun 2023 navma1 ChangeRequest 58589[58595]: EUP | LMS Gang API - Endpoint
14 Mar 2024 naviv1 Bug 62922 - EUP | FR - LMS to MTN Interface 
*/

vars
	pxyWorkPointSheet	: CM_WorkPointJobSheet;
	workPoint		    : CM_WorkPoint;
	term				: CM_Terminal;
	pxyShift			: CM_Shift;
	workPointId			: String;
begin

	term := app.myPassport.myTerminal;
		
	//workPoint := term.allWorkPointsByCode[_request.workPointId.toUpper];		//14.03.2024 naviv1 #62922
	workPointId := _realWorkPointJobSheet.myWorkPoint.code.toUpper;			//14.03.2024 naviv1 #62922
	workPoint := term.allWorkPointsByCode[workPointId];
	
	if workPoint = null then
		//app.raiseCMException1(Work_point_not_found, _request.workPointId,null,null);		//14.03.2024 naviv1 #62922
		app.raiseCMException1(Work_point_not_found, workPointId,null,null);		//14.03.2024 naviv1 #62922
		_statusCode := HttpResponseNotFound;
		return;
	endif;
	
	if not validateJobSheetShift(_request,_statusCode) then
		return;
	endif;
	create pxyShift transient;
	pxyShift.setProxy(null, 
					_request.shift.startDT.time, 
					_request.shift.endDT.time, 
					_request.shift.code, 
					_request.shift.description, 
					term,
					false);
					
	pxyShift.startDateTime := _request.shift.startDT;
	pxyShift.endDateTime   := _request.shift.endDT;
	
	pxyWorkPointSheet := app.createUpdateProxy(_realWorkPointJobSheet).CM_WorkPointJobSheet;
	
	pxyWorkPointSheet.setProxy(pxyShift,
							  term,
							  workPoint,
							  _request.shift.startDT,
							  _request.id,
							  _request.reference1,
							  _request.reference2,
							  _request.reference3);			
					
	app.myTrxUA.trxUpdateWorkPointJobSheet(pxyWorkPointSheet, app.myPassport);
	
epilog
	delete pxyWorkPointSheet;
	delete pxyShift;
end;</source>
        <Parameter name="_realWorkPointJobSheet" type="CM_WorkPointJobSheet"/>
        <Parameter name="_id" type="String"/>
        <Parameter name="_request" type="WS_RestWorkPointJSObject"/>
        <Parameter name="_statusCode" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="validateJWT" id="8dd058a4-fb04-4442-9dbd-7c9f58195721">
        <options>4</options>
        <source>validateJWT(_token: String; _isRefreshToken: Boolean; _user: CM_User output; _terminal: CM_Terminal output; _audience: String output; _jwtClaims : CMIF_WSClaimsObj input) typeMethod;
/*

Purpose:			Validates whether a passed in JWT token is valid or not.
					At this point in time, its only expected 1 audience claim will be included in any given JWT.
					(If more are added later, the 'revoke check' below will need to be changed)

Parameters:			_token				String	The JWT token string
					_isRefreshToken		Bool	true if the token should be verified by the 'Refresh' signing key. False for the 'Access' signing key.
					
					_user				CM_User	The validated user referenced in the JWT
					_terminal			CM_Terminal The terminal referenced in the JWT
					_audience			String	The audience for the JWT

Return Value:		Errors in the passport if something went wrong

Date			Who		Reason
15 April 2022	navmd1	Initial creation TFS 53378 REST Refactor / Generic API
01 Aug 2022   	navlw1  TFS 53854 MTN API Mapper
08 May 2025 	navnk30	JIRA 34701: SSO Implementation for Vehicle App - Jade Portion
29 May 2025 	navec1	JIRA 34701: SSO Implementation for Vehicle App - Add Issuers
16 Jan 2026     navsp1  MTN-36692 : [Generic] API Revoked/Replayed JWT Token allowed when accessing API
*/
vars
	terminalCode,	
	operatorId,
	complexId,
	yardId 			: String;
	terminal		: CM_Terminal;
	issuer			: String;
	subject			: String;
	userCode		: String;
	user			: CM_User;
	nonce			: String;
	nonceKeyName	: String;
	appName			: String;
	envName			: String;
	audiences		: StringArray;
	audience		: String;
	
	secret			: String;
	error			: String;
	hadError		: Boolean;
	
begin	
	app.writeLog(method.qualifiedName, LogTRACE);
	
	// Bail early if we don't even have a token
	if _token = null then
		app.raiseCMException1(ErrApiAuthInvalid, "Token Not Found", null, null);
	endif;
	
	appName := app.getNiceName;
	envName := app.getEnvName.toUpper;
	
	// A bit ass about face, but lets get the terminal from the token first
	terminalCode := JadeJWTParser@getClaimValue(_token, CMIF_WSClaimsObj.JWT_CLAIM_TERMINALID); // 01 Aug 2022 navlw1 tfs 53854
	if terminalCode &lt;&gt; null then
		terminal := app.myRoot.allTerminals[terminalCode];
	endif;
	if terminal = null then
		app.raiseCMException1(ErrApiAuthInvalid, "Invalid TerminalId '" &amp; terminalCode &amp; "'", null, null);
	endif;
	
	// then we can work out the secret to actually validate the thing!
	if not _isRefreshToken then
		secret := terminal.getConfig(JWTAccessKey).String;
	else
		secret := terminal.getConfig(JWTRefreshKey).String;
	endif;
	
	// 1. Make sure the token hasn't been tampered with
	if not JadeJWTValidator@validateSymmetricToken(_token, secret, error) then
		app.raiseCMException1(ErrApiAuthInvalid, "Unable to verify token. Token may be invalid or has been tampered with: " &amp; error, null, null);
	endif;
	
	// 2. Make sure the token hasn't expired
	if not JadeJWTValidator@verifyExpiryClaim(false, _token) or not JadeJWTValidator@verifyNotBeforeClaim(true, _token) then
		app.raiseCMException1(ErrApiAuthInvalid, "Token expired or for the future", null, null);
	endif;
	
	// 3. Make sure the token was issued by us	
	if not JadeJWTValidator@verifyIssuerClaim(_token, envName) or (not JadeJWTValidator@verifySubjectClaim(_token, appName) and not JadeJWTValidator@verifySubjectClaim(_token, InternalAPIService)) then
		issuer := JadeJWTParser@getIssuer(_token);
		on Exception do app.cnHandleNullOrInvObjectRef(exception, null, hadError);
		subject := JadeJWTParser@getSubject(_token);	// This currently results in a 1090 - Contact 68876 opened to fix
		on Exception do null;
		if hadError then
			subject := "**invalid**";
		endif;
		app.writeLog(method.qualifiedName &amp; " Token not issued by us. Got [" &amp; issuer &amp; "," &amp; subject &amp; "] expected [" &amp; envName &amp; "," &amp; appName &amp; "]", LogERROR);
		app.raiseCMException1(ErrApiAuthInvalid, "Token not issued by " &amp; appName, null, null);
	endif;
	
	// 4. Make sure the audience is someone we know
	// No way to know this at this pooint in time... so skipping
	create audiences transient;
	JadeJWTParser@getAudiences(_token, audiences);
	if audiences.size &lt; 1 then
		app.raiseCMException1(ErrApiAuthInvalid, "Token has no audience", null, null);
	endif;
	audience := audiences[1];
	
	// 5. Make sure the user is still valid
	userCode := JadeJWTParser@getClaimValue(_token, CMIF_WSClaimsObj.JWT_CLAIM_USERID); // 01 Aug 2022 navlw1 tfs 53854 
	if userCode &lt;&gt; null then
		user := app.myRoot.allUsers[userCode];
		if user &lt;&gt; null then
			if user.allUserTerminals[terminal] = null then
				user := null;
			elseif user.isSuspendedOrIsDisabled() then
				user := null;
			endif;
		endif;
	endif;
	if user = null then
		// We're not really leaking more info here, as both userCode and terminalCode are already present in the JWT
		app.raiseCMException1(ErrApiAuthInvalid, "User [" &amp; userCode &amp; "] not valid or no longer has access to Terminal [" &amp; terminalCode &amp; "]", null, null);
	endif;
	
	// 6. Make sure the token hasn't been revoked/replayed
	nonceKeyName := (WS_WebServiceAgent.JWT_NONCE_KEY &amp; "_" &amp; appName &amp; "_" &amp; audience)[1:CM_StateData::key.length];
	nonce := user.getStateData(ConfigGrp_Web, nonceKeyName).String;
	if nonce = null or not JadeJWTValidator@verifyJwtIdClaim(_token, nonce) then
		app.raiseCMException1(ErrApiAuthInvalid, "Token has been revoked", null, null);	//15.05.2025 navnk30 JIRA 34701         //MTN-36692 - uncommented
	endif;
	
	// 01 Aug 2022 navlw1 tfs 53854 
	// 7. Make sure Operator Id exists 
	operatorId := JadeJWTParser@getClaimValue(_token, CMIF_WSClaimsObj.JWT_CLAIM_OPERATORID);
	if operatorId = null then
		app.raiseCMException1(ErrApiAuthInvalid, "Token has no OperatorId", null, null);
	endif;
	
	// 01 Aug 2022 navlw1 tfs 53854 
	// 8. These are optional so no validation required
	complexId := JadeJWTParser@getClaimValue(_token, CMIF_WSClaimsObj.JWT_CLAIM_COMPLEXID);
	yardId := JadeJWTParser@getClaimValue(_token, CMIF_WSClaimsObj.JWT_CLAIM_YARDID);
	
	// So far, so good
	_user := user;
	_terminal := terminal;
	_audience := audience;
	
	// 01 Aug 2022 navlw1 tfs 53854 
	_jwtClaims.setScopeClaims(complexId, terminalCode, operatorId, yardId);
epilog
	delete audiences;
end;</source>
        <Parameter name="_token" type="String"/>
        <Parameter name="_isRefreshToken" type="Boolean"/>
        <Parameter name="_user" type="CM_User" usage="output"/>
        <Parameter name="_terminal" type="CM_Terminal" usage="output"/>
        <Parameter name="_audience" type="String" usage="output"/>
        <Parameter name="_jwtClaims" type="CMIF_WSClaimsObj" usage="input"/>
    </JadeMethod>
    <JadeMethod name="validateJobSheetShift" id="78ad9a71-3667-49f1-b2c4-2fec4520e735">
        <options>4</options>
        <source>validateJobSheetShift(_request: WS_RestWorkPointJSObject ; _statusCode : Integer io): Boolean typeMethod;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25 Jun 2023 navma1 ChangeRequest 58589[58595]: EUP | LMS Gang API - Endpoint
14 Mar 2024 naviv1 Bug 62922 - Bug 62922 - EUP | FR - LMS to MTN Interface 
*/

vars
	
begin
	
	if _request.shift.code = null then
		app.raiseCMException(Input_required_field_code,null, null); 
		_statusCode := HttpResponseClientError;
		return false;
		
	endif;
	
	/*if _request.shift.startDT &lt; app.actualTimeAppServer then			//14.03.2024 naviv1 #62922 --Removing the validation to allow the modification of start date in the past 
		app.raiseCMException(ERR_Shift_StartDT,null, null); 
		_statusCode := HttpResponseClientError;
		return false;
	endif; */
	
	if _request.shift.endDT &lt; _request.shift.startDT then
		app.raiseCMException(ERR_SHIFT_WRONG_TIME,null, null);  
		_statusCode := HttpResponseClientError;
		return false;
	endif;
	
	return true;
epilog

end;</source>
        <Parameter name="_request" type="WS_RestWorkPointJSObject"/>
        <Parameter name="_statusCode" type="Integer" usage="io"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validateReportOutputFormat" id="1a6a059e-a37b-4d31-91b5-dcddfc201d0c">
        <source>validateReportOutputFormat(report : CM_QryReport; reportFormat : Integer) : Boolean;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
29 Sep 2008	cnwkao1	Initial creation
19 Mar 2009	cnwkpd1	Corrected validation

*/	

vars
	reportFormats	: IntegerArray;	
	completedOK		: Boolean;
	
begin
	reportFormats := report.reportFormats;	
	//general check
	if not reportFormats.includes(reportFormat) then		
		return false;
	endif;
	
	//more specific checks
/*	if reportFormat = CM_QryReport.PDF_Format then
		if not app.myRoot.canDo(PmPDFBackground) then			
			return false;
		endif;
	endif; */	//07 Oct 2019	NDL	TFS 46169
	
//	KPD 19/03/2009 - removed as invalid
//	if report.isFormBasedReport then
//		if reportFormat &lt;&gt; JadeReportWriterReport.CSV or not report.canCSV then //form based is only allowed csv (but only if the report is marked as canCSV)
//			return false;
//		endif;
//	endif;	
	
	return true;
	
	
epilog
	
end;</source>
        <wsdlName>validateReportOutputFormat</wsdlName>
        <Parameter name="report" type="CM_QryReport"/>
        <Parameter name="reportFormat" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validateSSOJWT" id="1d8edd7b-de41-430a-8e03-c477c852aa81">
        <options>4</options>
        <source>validateSSOJWT(_token : String; _upn, _uid: String output) typeMethod;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
28 August 2022	navam1	ChangeRequest 53986: EUP - Azure Active Directory Single Sign On - Web
08 May 2025		navnk30	JIRA 34701: SSO Implementation for Vehicle App - Jade Portion

*/

constants
	Expiry_Seconds	: Integer = 60;
vars
	appId,
	tenantId,
	iss			: String;
	tokenNonce,
	localNonce	: String;
	pxyNonce,
	realNonce	: CM_RestAuthNonce;
	factory		: JadeMessagingFactory;
begin
	// Bail early if we don't even have a token
	if _token = null then
		app.raiseCMException1(ErrApiAuthInvalid, "SSO - Token Not Found", null, null);
	endif;
	
	/*
	//retrieve accessToken			//08.05.2025 navnk30 JIRA 34707
	accessToken := JadeJWTParser@getClaimValue(accessToken, CMIF_WSClaimsObj.JWT_CLAIMS_AZURE_AT);
	
	if accessToken = null then
		app.raiseCMException1(ErrApiAuthInvalid, "SSO - Access Token not found in the supplied token", null, null);
	endif;
	*/
	
	//1. validate nonce
	tokenNonce := JadeJWTParser@getClaimValue(_token, CMIF_WSClaimsObj.JWT_CLAIMS_AZURE_NONCE);
	
	if tokenNonce = null then
		app.raiseCMException1(ErrApiAuthInvalid, "SSO - Nonce wasn't supplied", null, null);
	endif;
	
	//realNonce := app.myRoot.allRestAuthNoncesByGuid[tokenNonce];		//08.05.2025 navnk30 JIRA 34701 START
	create factory transient;
	localNonce := factory.generateAccessPassword[1:30];
	
	create pxyNonce transient;
	pxyNonce.setNonce(localNonce, app.actualTimeServer.addSeconds(Expiry_Seconds), false);
	app.myTrxCA.trxCreateNonce(app.myPassport, pxyNonce, realNonce);	//08.05.2025 navnk30 JIRA 34701 END
	
	if realNonce = null then
		app.raiseCMException1(ErrApiAuthInvalid, "SSO - Nonce supplied was not found", null, null);
	endif;
	
	if (app.actualTimeServer() &gt; realNonce.expiry or realNonce.utilised) then
		app.raiseCMException1(ErrApiAuthInvalid, "SSO - Nonce supplied has either expired or has already been utilised", null, null);
	endif;
	
	if not realNonce.utilised then
		beginTransaction;
		realNonce.setUtilised();
		commitTransaction;
	endif;
	
	//2. Make sure the token hasn't expired
	//todo: This has been commented out because for some reason it doesn't work. And I missed debugging it (Ajit). Please fix it! Your help will be much appreciated!
	if not JadeJWTValidator@verifyExpiryClaim(false, _token) or not JadeJWTValidator@verifyNotBeforeClaim(true, _token) then
		app.raiseCMException1(ErrApiAuthInvalid, "SSO - Token expired or for the future", null, null);
	endif;
	
	//3. verify Application (client) ID 
	appId := JadeJWTParser@getClaimValue(_token, CMIF_WSClaimsObj.JWT_CLAIMS_AZURE_APPID);
	if appId &lt;&gt; app.myRoot.getConfig(SsoAzureClientId).asString then
		app.raiseCMException1(ErrApiAuthInvalid, "SSO - Application (client) ID doesn't match", null, null);
	endif;
	
	//4. verify token issuer
	iss := "https://sts.windows.net/" &amp; app.myRoot.getConfig(SsoAzureTenantId).asString &amp; "/";
	if not JadeJWTValidator@verifyIssuerClaim(_token, iss) then
		app.raiseCMException1(ErrApiAuthInvalid, "SSO - Token issuer doesn't match", null, null);
	endif;
	
	//5. verify Tenant ID
	tenantId := JadeJWTParser@getClaimValue(_token, CMIF_WSClaimsObj.JWT_CLAIMS_AZURE_TID);		//12.05.2025 navnk30 JIRA 34701	
	if tenantId &lt;&gt; app.myRoot.getConfig(SsoAzureTenantId).asString() then
		app.raiseCMException1(ErrApiAuthInvalid, "SSO - Tenant ID does ot match", null, null);
	endif;
	
	//retrieve upn claim
	_upn := JadeJWTParser@getClaimValue(_token, CMIF_WSClaimsObj.JWT_CLAIMS_AZURE_UPN);
	
	//retrieve uid claim
	_uid := JadeJWTParser@getClaimValue(_token, CMIF_WSClaimsObj.JWT_CLAIMS_AZURE_OID) &amp; "." &amp; JadeJWTParser@getClaimValue(_token, CMIF_WSClaimsObj.JWT_CLAIMS_AZURE_TID);
	
epilog
	delete factory;
	delete pxyNonce;
end;</source>
        <Parameter name="_token" type="String"/>
        <Parameter name="_upn" type="String" usage="output"/>
        <Parameter name="_uid" type="String" usage="output"/>
    </JadeMethod>
    <JadeMethod name="validateTIHazard" id="8fc4b70c-175e-449f-949a-b2095d7233d8">
        <options>4</options>
        <source>validateTIHazard(_hazard : CM_TIHazard; _terminal : CM_Terminal) : Boolean typeMethod;
/*

Purpose:			Validates whether a Hazard on a TI is valid or not and returns a boolean representing this.
					Techincally does the same as CM_TIHazard::validateTIHazard just does not raise exceptions.

Parameters:			_hazard		CM_TIHazard	Hazard to check
					_terminal	CM_Terminal	Terminal to use to check hazard

Return Value:		Boolean	Representing whether or not the hazard is valid

Date				Who		Reason
09 December 2024	navpw1	Initial creation JIRA: MTN-19348

*/

vars
	hazClass		: CM_HazardClass;
	strUNDG			: String;
	validateHazUNDG : Boolean;
	undgCode		: CM_UNDangerousGoods;
	hazTempRange	: CM_HazTempRange;			
	root			: CM_Root;
	rangeFound		: Boolean;
	
begin
	root := app.myRoot;
	if _hazard.code &lt;&gt; null then
		hazClass := root.allHazardClasses[_hazard.code];
	endif;
	
	if hazClass = null then
		return false;	
	endif;
	
	if _terminal = null then
		return false;
	endif;
	
	validateHazUNDG:=_terminal.getConfig(ValidateHazardousUNDG).Boolean;
	
	foreach strUNDG in _hazard.allUNDGCodes do
		undgCode := root.allUNDangerousGoodsCodes[strUNDG.trimBlanks];
		if undgCode = null then
			if validateHazUNDG then
				return false;
			endif;
		else
			if validateHazUNDG then
				if not hazClass.allUNDGCodes.includes(undgCode) then
					if not undgCode.allClassCodes.includes(hazClass.code) then
						return false;
					endif;
				endif;
				if _hazard.packingGroup &lt;&gt; null and not undgCode.allPackingGroups.includes(_hazard.packingGroup) then
					return false;
				endif;
			endif;
			if undgCode.isMarinePollutantMandatory and _hazard.isMarinePollutant = null then
				return false;
			endif;
		endif;
	endforeach;
	
	if _hazard.acidsBases &lt;&gt; null and _hazard.acidsBases &lt;&gt; _hazard.ACID and _hazard.acidsBases &lt;&gt; _hazard.BASE then
		return false;
	endif;
	
	if not root.allHazTempRanges.isEmpty and _hazard.flashpointTemperature &lt;&gt; NULL_TEMPERATURE then
		foreach hazTempRange in app.myRoot.allHazTempRanges do
			if  hazTempRange.lower &lt;= _hazard.flashpointTemperature and hazTempRange.upper &gt;= _hazard.flashpointTemperature then		
				rangeFound := true;
				break;
			endif;
		endforeach;
		
		if not rangeFound then
			return false;
		endif;
		
	endif;																												
	
	return true;
	
end;</source>
        <Parameter name="_hazard" type="CM_TIHazard"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
