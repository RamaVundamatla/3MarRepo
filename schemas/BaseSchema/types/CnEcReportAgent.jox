    <JadeMethod name="trxReportCategoryCreate" id="e9ee3dd2-da90-47fa-ab86-f34486f2c068">
        <updating/>
        <source>trxReportCategoryCreate(pCategoryName:String;
						pBaseRootObj:CnEcBaseRoot;
						pReportCategoryObj:CnEcReportCategory output):String updating;
// --------------------------------------------------------------------------------
// Created:		03 June 2000 by cnwdad2
//
// Purpose:		Transaction method to create a Report Category.
//
// Parameters:	The properties of the object to be created.
//              The newly created object is returned in the output parameter.
//
// Returns:		Null if the transaction is successful, otherwise an error message.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	errorMessage	: String;

begin
	// Always initialize the activity first.
	self.agentInitializeActivity();

	// Arm our base exception handlers
	on Exception do self.agentExceptionHandler(exception);
	on LockException do self.agentLockExceptionHandler(exception);

	errorMessage	:=	valReportCategoryCreate(pCategoryName);

	if errorMessage &lt;&gt; null then
		return errorMessage;
	endif;

	// Start the transaction.
	beginTransaction;

	// Perform the operation.
	pReportCategoryObj	:=	app.myBaseRoot.createReportCategory(pCategoryName);

	// If the "create" raises an exception, our handler will resume to here.
	if self.lastError = null then
		// No errors, so commit.
		commitTransaction;
	else
		// We got an error so abort the transaction. Although TransactionAgent
		// exception handlers abort the transaction before resuming, we do so
		// here as well for completeness and symmetry with the beginTransaction.
		// An abortTransaction when not in transaction state does nothing.
		abortTransaction;
	endif;
epilog
	// Always return the error code to the caller (which will be zero if no errors)
	return self.lastError;
end;</source>
        <Parameter name="pCategoryName" type="String"/>
        <Parameter name="pBaseRootObj" type="CnEcBaseRoot"/>
        <Parameter name="pReportCategoryObj" type="CnEcReportCategory" usage="output"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="trxReportCategoryDelete" id="43cc9ff1-6ac8-49b0-ad23-627db7aa2e52">
        <updating/>
        <source>trxReportCategoryDelete(pReportCategoryObj:CnEcReportCategory io):String updating;
// --------------------------------------------------------------------------------
// Created:		03 June 2000 by cnwdad2
//
// Purpose:		Deletes a Report Category.
//              In reality, we would probably have some application-level
//              validation for deletes prior to deleting an object. But even
//              without validation, JADE ensures referential integrity by
//              automatically maintaining relationships when an object is deleted
//              (any inverse references to an object are removed (set to null) when
//              an object is deleted). If a relationship is parent-child, related
//              child objects are deleted when the parent is deleted.
//
// Parameters:	The object to be deleted. This will be set to null by the delete.
//
// Returns:		Null if the transaction is successful, otherwise an error message.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	// Initialize the activity first.
	self.agentInitializeActivity();

	// Arm our base exception handlers.
	on Exception do self.agentExceptionHandler(exception);
	on LockException do self.agentLockExceptionHandler(exception);

	// Start the transaction.
	beginTransaction;

	// If object is invalid, we want our exception handler to return a message saying so.
	self.agentRegisterObjectAndError(pReportCategoryObj, "The Report Category being deleted is either null or is not valid.");

	// Perform the operation (this will set the object to null).
	// The delete will do nothing if the reference is already null.
	delete pReportCategoryObj;		

	// If the operation raises an exception, our handler will resume to here.
	if self.lastError = null then
		// No errors, so commit.
		commitTransaction;
	else
		// We got an error so abort the transaction. Although TransactionAgent
		// exception handlers abort the transaction before resuming, we do so
		// here as well for completeness and symmetry with the beginTransaction.
		// An abortTransaction when not in transaction state does nothing.
		abortTransaction;
	endif;
epilog
	// Always return the error to the caller (which will be null if there are no errors).
	return self.lastError;
end;</source>
        <Parameter name="pReportCategoryObj" type="CnEcReportCategory" usage="io"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="trxReportCategoryUpdate" id="4521e1b7-c8e6-442a-982e-8d971962f602">
        <updating/>
        <source>trxReportCategoryUpdate(pReportCategoryObj:CnEcReportCategory input;
						pRequiredEdition:Integer;
						pCategoryName:String):String updating;
// --------------------------------------------------------------------------------
// Created:		03 June 2000 by cnwdad2
//
// Purpose:		Update a Report Category.
//
// Parameters:	The first parameter is the object to be updated.
//              If pRequiredEdition is greater than zero, the method will check that
//              the latest edition of the object is equal to pRequiredEdition. If not
//              then an ObjectOutOfDate error will be returned.
//
//              The remaining parameters are the object properties to update.
//
// Returns:		Null if the transaction is successful, otherwise an error message.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	errorMessage	: String;

begin
	// Initialize the activity first.
	self.agentInitializeActivity();

	// Arm our base exception handlers (local exception handlers which are
	// disarmed when the method returns).
	on Exception do self.agentExceptionHandler(exception);
	on LockException do self.agentLockExceptionHandler(exception);

	errorMessage	:=	valReportCategoryUpdate(pReportCategoryObj, pCategoryName);

	if errorMessage &lt;&gt; null then
		return errorMessage;
	endif;

	// If the object is invalid, we want our exception handler to return the specified error.
	self.agentRegisterObjectAndError(pReportCategoryObj, "The Report Category being updated is either null or is not valid.");

	beginTransaction;

	// Exclusive transaction lock to obtain the latest edition of the object and
	// lock it. We need the latest edition to check it against requiredEdition.
	// This lock be released automatically at the next commit/abort transaction.
	// We obtain an exclusive lock (as opposed to a shared lock) as we're about
	// about to update the object, and JADE will automatically try to lock it
	// exclusively (if we don't already have it) before updating it. Getting an
	// exclusive lock up front avoids JADE having to upgrade the lock from shared
	// to exclusive at the point the object is updated.
	exclusiveLock(pReportCategoryObj);

	// If the exclusiveLock gets an exception, our handler will resume to here.
	if self.lastError = null and pRequiredEdition &gt; 0 then
		// We obtained the lock, now check the edition.
		if pReportCategoryObj.edition() &lt;&gt; pRequiredEdition then
			// The edition has changed, so the object on which the sender based
			// this update is out of date.
			self.agentSetError("The Report Category has been changed by another process.  Please refresh the Category and try again.");
		endif;
	endif;

	// If we're still error free, perform the operation.
	if self.lastError = null then
		pReportCategoryObj.updateMe(pCategoryName);
	endif;

	// If the operation raises an exception, our handler will resume to here.
	if self.lastError = null then
		// No errors, so commit.
		commitTransaction;
	else
		// We got an error so abort the transaction. Although TransactionAgent
		// exception handlers abort the transaction before resuming, we do so
		// here as well for completeness and symmetry with the beginTransaction.
		// An abortTransaction when not in transaction state does nothing.
		abortTransaction;
	endif;
epilog
	// Always return the error code to the caller (which will be zero if no errors).
	return self.lastError;
end;</source>
        <Parameter name="pReportCategoryObj" type="CnEcReportCategory" usage="input"/>
        <Parameter name="pRequiredEdition" type="Integer"/>
        <Parameter name="pCategoryName" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="trxReportDefinitionCreate" id="a9b5ed4e-199a-41a2-8786-bbd994af4085">
        <updating/>
        <source>trxReportDefinitionCreate(pReportName:String;
						pReportCategoryObj:CnEcReportCategory;
						pReportDescription:String;
						pFormName:String;
						pPrinterName:String;
						pCopies:Integer;
						pIsLocalAllowed:Boolean;
						pPaperSize:Integer;
						pOrientation:Integer;
						pMarginTop:Integer;
						pMarginBottom:Integer;
						pMarginLeft:Integer;
						pMarginRight:Integer;
						pParameterArray:CnEcReportParameterArray;
						pReportDefinitionObj:CnEcReportDefinition output):String updating;
// --------------------------------------------------------------------------------
// Created:		03 June 2000 by cnwdad2
//
// Purpose:		Transaction method to create a Report Definition.
//
// Parameters:	The properties of the object to be created.
//              The newly created object is returned in the output parameter.
//
// Returns:		Null if the transaction is successful, otherwise an error message.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	errorMessage	: String;

begin
	// Always initialize the activity first.
	self.agentInitializeActivity();

	// Arm our base exception handlers
	on Exception do self.agentExceptionHandler(exception);
	on LockException do self.agentLockExceptionHandler(exception);

	errorMessage	:=	valReportDefinitionCreate(	pReportName,
													pReportCategoryObj,
													pReportDescription,
													pFormName,
													pPrinterName,
													pCopies,
													pIsLocalAllowed,
													pPaperSize,
													pOrientation,
													pMarginTop,
													pMarginBottom,
													pMarginLeft,
													pMarginRight,
													pParameterArray);

	if errorMessage &lt;&gt; null then
		return errorMessage;
	endif;

	// Start the transaction.
	beginTransaction;

	// Perform the operation.
	pReportDefinitionObj	:=	app.myBaseRoot.createReportDefinition(	pReportName,
																		pReportCategoryObj,
																		pReportDescription,
																		pFormName,
																		pPrinterName,
																		pCopies,
																		pIsLocalAllowed,
																		pPaperSize,
																		pOrientation,
																		pMarginTop,
																		pMarginBottom,
																		pMarginLeft,
																		pMarginRight,
																		pParameterArray);

	// If the "create" raises an exception, our handler will resume to here.
	if self.lastError = null then
		// No errors, so commit.
		commitTransaction;
	else
		// We got an error so abort the transaction. Although TransactionAgent
		// exception handlers abort the transaction before resuming, we do so
		// here as well for completeness and symmetry with the beginTransaction.
		// An abortTransaction when not in transaction state does nothing.
		abortTransaction;
	endif;
epilog
	// Always return the error code to the caller (which will be zero if no errors)
	return self.lastError;
end;</source>
        <Parameter name="pReportName" type="String"/>
        <Parameter name="pReportCategoryObj" type="CnEcReportCategory"/>
        <Parameter name="pReportDescription" type="String"/>
        <Parameter name="pFormName" type="String"/>
        <Parameter name="pPrinterName" type="String"/>
        <Parameter name="pCopies" type="Integer"/>
        <Parameter name="pIsLocalAllowed" type="Boolean"/>
        <Parameter name="pPaperSize" type="Integer"/>
        <Parameter name="pOrientation" type="Integer"/>
        <Parameter name="pMarginTop" type="Integer"/>
        <Parameter name="pMarginBottom" type="Integer"/>
        <Parameter name="pMarginLeft" type="Integer"/>
        <Parameter name="pMarginRight" type="Integer"/>
        <Parameter name="pParameterArray" type="CnEcReportParameterArray"/>
        <Parameter name="pReportDefinitionObj" type="CnEcReportDefinition" usage="output"/>
        <ReturnType type="String"/>
    </JadeMethod>
