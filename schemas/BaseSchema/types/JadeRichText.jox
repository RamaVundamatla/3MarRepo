<GUIClass name="JadeRichText">
    <JadeMethod name="cnEcDoSpellCheck" id="f57f1e2f-da7b-4044-a2e2-9e48a173281a">
        <updating/>
        <source>cnEcDoSpellCheck():Boolean updating;
// --------------------------------------------------------------------------------
// Created:		08 December 2001 by cnwdad1
//
// Purpose:		Spell-Checks the receiver's text, and updates it if the prose has
//				been modified.
//
// Parameters:	None
//
// Returns:		True if the text was changed, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 10/07/2006	cnwdad1		Added a check for whether the updated text would fit in
//							the textbox.
// --------------------------------------------------------------------------------
vars
	spellCheckObj	: CnEcSpellCheck;
	lineOfText		: String;
	lineOfRTF		: String;
	checkedProse	: String;
	userResponse	: Integer;
	isAtEnd			: Boolean;
	linePointer		: Integer;
	firstChar		: Integer;
	lineLength		: Integer;
	lineHeight		: Integer;
	isChanged		: Boolean;
	newRTF			: String;
	
begin
	on Exception do self.xHandlerRow(exception, isAtEnd);
	
	create spellCheckObj transient;
	linePointer	:=	1;
	
	while true do
		lineOfText	:=	self.getLine(linePointer, JadeRichText.GetLine_PlainText, firstChar, lineLength, lineHeight);
		lineOfRTF	:=	self.getLine(linePointer, JadeRichText.GetLine_RTF, firstChar, lineLength, lineHeight);
		
		if isAtEnd then
			// We're reach the last line of text in the receiver.
			write "All done.";
			break;
		endif;
		
		if lineOfText &lt;&gt; null and spellCheckObj.isCheckProse(lineOfText, checkedProse) then
			isChanged	:=	true;
			newRTF		:=	self.updateRTFString(lineOfRTF, lineOfText, checkedProse);
			self.replace(lineOfText, newRTF, firstChar, (firstChar + lineLength), JadeRichText.Find_MatchCase);
			
		elseif spellCheckObj.isCancelSpellCheck then
			break;
			
		endif;
		
		linePointer	:=	linePointer + 1;
	endwhile;
	
	return isChanged;
epilog
	delete spellCheckObj;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="cnEcLoadFromFile" id="1eca98e3-a81b-4b9d-83aa-e248b5fd6d59">
        <source>cnEcLoadFromFile(pFileName:String; pReplaceOption:Integer; pFormat:Integer; pErrorMsg:String output):Integer;
// --------------------------------------------------------------------------------
// Created:		04 July 2008 by cnwdad1
//
// Purpose:		Calles the receiver's loadFromFile method, but arms an exception
//				handler first to trap any errors.
//
// Parameters:	Refer to Jade method parameters.
//				pErrorMsg - An error message if the load fails.
//
// Returns:		The result of the operation.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	isLoadFailed	: Boolean;
	loadResult		: Integer;
	
begin
	on Exception do self.xHandlerLoad(exception, isLoadFailed, pErrorMsg);
	
	loadResult	:=	self.loadFromFile(pFileName, pReplaceOption, pFormat);
	
	if isLoadFailed then
		// Do nothing - the error message will be returned by the output parameter.
	elseif loadResult &lt;&gt; 0 then
		pErrorMsg	:=	"The RTF load failed with error '" &amp; loadResult.String &amp; "':" &amp;
						CrLf &amp; CrLf &amp; process.getErrorText(loadResult);
	endif;
epilog
	return loadResult;
end;</source>
        <Parameter name="pFileName" type="String"/>
        <Parameter name="pReplaceOption" type="Integer"/>
        <Parameter name="pFormat" type="Integer"/>
        <Parameter name="pErrorMsg" type="String" usage="output"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="cnEcSet" id="67c6832e-946f-4d16-b247-0d67f9ff7bca">
        <updating/>
        <source>cnEcSet(pValue:String) updating;
// --------------------------------------------------------------------------------
// Created:		30 December 2005 by cnwdad1
//
// Purpose:		Updates the receiver's text with the specified value.
//
// Parameters:	pValue - The string value to set the text to.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if self.text &lt;&gt; pValue then
		self.text	:=	pValue;
	endif;
end;</source>
        <Parameter name="pValue" type="String"/>
    </JadeMethod>
    <JadeMethod name="cnEcSetRTF" id="eefd3d4f-af56-4059-ab73-25b4f454a523">
        <updating/>
        <source>cnEcSetRTF(pValue:String) updating;
// --------------------------------------------------------------------------------
// Created:		30 December 2005 by cnwdad1
//
// Purpose:		Updates the receiver's rich text with the specified value.
//
// Parameters:	pValue - The string value to set the rich text to.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if self.textRTF &lt;&gt; pValue then
		self.textRTF	:=	pValue;
	endif;
end;</source>
        <Parameter name="pValue" type="String"/>
    </JadeMethod>
    <JadeMethod name="updateRTFString" id="4d18d61a-1277-4a1f-b339-69ae5a2437f0">
        <source>updateRTFString(pOriginalRTF:String; pOriginalText:String; pNewText:String):String protected;
// --------------------------------------------------------------------------------
// Created:		24 April 2008 by cnwdad1
//
// Purpose:		Updates an RTF string with a spell checked string, and returns the
//				result.
//
// Parameters:	pOriginalRTF - 
//				pOriginalText - 
//				pNewText - 
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	newRTF		: String;
	rtfPointer	: Integer;
	oldPointer	: Integer;
	newPointer	: Integer;
	oldWord		: String;
	newWord		: String;
	firstPart	: String;
	lastPart	: String;
	
begin
	newRTF		:=	pOriginalRTF;
	rtfPointer	:=	1;
	oldPointer	:=	1;
	newPointer	:=	1;
	
	while true do
		oldWord	:=	pOriginalText.cnEcGetNextWord(oldPointer);
		
		if oldWord = null then
			break;
		endif;
		
		newWord	:=	pNewText.cnEcGetNextWord(newPointer);
		
		rtfPointer	:=	newRTF.pos(oldWord, rtfPointer);
		
		if rtfPointer &gt; 0 then
			if rtfPointer = 1 then
				firstPart	:=	null;
			else
				firstPart	:=	newRTF[1:rtfPointer - 1];
			endif;
			
			if rtfPointer + oldWord.length() = newRTF.length() then
				lastPart	:=	null;
			else
				lastPart	:=	newRTF[rtfPointer + oldWord.length():end];
			endif;
			
			newRTF	:=	firstPart &amp; newWord &amp; lastPart;
		endif;
	endwhile;
	
	return newRTF;
end;</source>
        <access>protected</access>
        <Parameter name="pOriginalRTF" type="String"/>
        <Parameter name="pOriginalText" type="String"/>
        <Parameter name="pNewText" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="xHandlerLoad" id="7add727f-347d-49ad-8798-fa434b95a7b5">
        <source>xHandlerLoad(pExceptionObj:Exception; pIsLoadFailed:Boolean output; pErrorMsg:String output):Integer protected;
// --------------------------------------------------------------------------------
// Created:		04 July 2008 by cnwdad1
//
// Purpose:		Handler to deal with the receiver getting an exception when loading
//				content from a file.
//
// Parameters:	pExceptionObj - A reference to the exception object.
//				pIsLoadFailed - True if the RTF load failed.
//				pErrorMsg - An error message if the load failed.
//
// Returns:		Two output parameters, one a boolean flag to indicate a failure, and
//				the error message about the failure.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
constants
	ERROR_14226	: Integer = 14226;
	
vars
	errorMsg	: String;
	
begin
	if pExceptionObj.errorCode = ERROR_14226 then
		pIsLoadFailed	:=	true;
		pErrorMsg		:=	"The file load failed with the following error:" &amp;
							CrLf &amp; CrLf &amp; pExceptionObj.extendedErrorText &amp;
							CrLf &amp; CrLf &amp; "Check that the file is a properly formatted RTF file.";
		
		return Ex_Resume_Next;
	else
		return Ex_Pass_Back;
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="pExceptionObj" type="Exception"/>
        <Parameter name="pIsLoadFailed" type="Boolean" usage="output"/>
        <Parameter name="pErrorMsg" type="String" usage="output"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="xHandlerRow" id="1b836750-4593-44e7-9c15-a40b62a6e941">
        <source>xHandlerRow(pException:Exception; pIsAtEnd:Boolean output):Integer protected;
// --------------------------------------------------------------------------------
// Created:		24 April 2008 by cnwdad1
//
// Purpose:		Exception handler used to handle the situation where the number of
//				text lines have been exceeded when doing a spell check.
//
// Parameters:	pException - A reference to the exception object.
//				pIsAtEnd - A boolean flag to indicate whether the exception was
//					raised because the last line has been reached.
//
// Returns:		A return value which indicates how Jade should proceed.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
constants
	INVALID_LINE	: Integer = 14225;
	
begin
	if pException.errorCode = INVALID_LINE then
		pIsAtEnd	:=	true;
		return Ex_Resume_Next;
	else
		pIsAtEnd	:=	false;
		return Ex_Pass_Back;
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="pException" type="Exception"/>
        <Parameter name="pIsAtEnd" type="Boolean" usage="output"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
</GUIClass>
