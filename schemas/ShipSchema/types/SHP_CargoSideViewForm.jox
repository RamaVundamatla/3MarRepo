    <JadeMethod name="setMoveControllerTarget" id="b2860150-29ae-49e8-b11d-32c681953f91">
        <updating/>
        <source>setMoveControllerTarget(_req : CM_RORORequest) updating;
/*
Purpose:			
Date				Who			Reason
AUGUST 2011		CNWAB1		Initial creation
*/


vars

	moveController	: CMIF_MoveController;
begin
	if _req = null then
		return;
	endif;
	
	create moveController transient;
	
	delete app.myMoveController;
	app.myMoveController := moveController;
	if _req.isLoad then
		moveController.setMyToPrimaryLocation(_req.myROROController);
	else
		moveController.setMyOriginatingLocation(_req.myROROController);
		moveController.setMyTrackedItem(app.myDraggedTrackedItem);
	endif;
	moveController.myVoyageRequest := _req;



	moveController.setMoveMode(PLANNING_MODE);	
epilog

end;</source>
        <Parameter name="_req" type="CM_RORORequest"/>
    </JadeMethod>
    <JadeMethod name="setMyCaption" id="ea041a24-26dc-42c5-be35-bb4780593a1a">
