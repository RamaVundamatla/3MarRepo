    <JadeMethod name="setupQueryRequestReferences" id="80488a33-b3d6-4c89-a508-2f5794b3e811">
        <updating/>
        <source>setupQueryRequestReferences() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
06 October 2008	cnwkao1	Initial creation - setup those references that would otherwise
				need to be derived/looked-up each iteration of the query

*/

vars

begin
	if self.filterOperator &lt;&gt; null then
		self.myFilterOperator := app.myRoot.allOperators.getAtKey(self.filterOperator);
	endif;
	
	if self.filterFreightForwarder &lt;&gt; null then
		self.myFilterFreightForwarder := app.myRoot.allConsigneeConsignors.getAtKey(self.filterFreightForwarder);
	endif;
	
	if self.isoGroup &lt;&gt; null then
		self.myFilterISOGrp := app.myRoot.allISOTypeGroups.getAtKey(self.isoGroup);
	endif;

epilog

end;</source>
    </JadeMethod>
</Class>
