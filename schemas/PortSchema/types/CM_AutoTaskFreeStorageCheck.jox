<Class name="CM_AutoTaskFreeStorageCheck" id="6d5d43d6-05af-4d25-bce7-53d9fd783e63">
    <superclass name="CM_AutoTask"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <access>protected</access>
    <text>&lt;display&gt;Check Free Storage Days Expiry&lt;/display&gt;</text>
    <DbClassMap file="backgroundprocess"/>
    <JadeMethod name="getEntryTableViewName" id="b21bd11a-b499-452a-ae97-9a8062966ced">
        <source>getEntryTableViewName(): String;
// --------------------------------------------------------------------------------
// Created:		02 May 2006 by cnwdad1
//
// Purpose:		Returns the name of the Entry Table view to use.
//
// Parameters:	None
//
// Returns:		The table view name.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return 'bgpAutoViewFreeStorageCheck';
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="1ed86374-1300-47cd-91e9-6c612d9b96d5">
        <updating/>
        <source>setForCreate(_pxyAutoTask: CM_AutoTask) updating;
// --------------------------------------------------------------------------------
// Created:		02 May 2006 by cnwdad1
//
// Purpose:		Sets the receiver's attributes and references upon creation.
//
// Parameters:	_pxyAutoTask - A reference to the proxy Auto Task object.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	inheritMethod(_pxyAutoTask);
	self.requestClassName	:=	BGP_FreeStorageCheckRequest.name;
end;</source>
        <Parameter name="_pxyAutoTask" type="CM_AutoTask"/>
    </JadeMethod>
    <JadeMethod name="validate" id="3f56e17b-32c3-4ce1-877c-5d9b39a59bdd">
        <source>validate();
// --------------------------------------------------------------------------------
// Created:		02 May 2006 by cnwdad1
//
// Purpose:		Validates the receiver's attributes and references.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 15/12/2014  cnwdb2	PAR 35364
// --------------------------------------------------------------------------------
begin
	inheritMethod();
	
	if self.myTerminal = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Terminal', ETRow_BgpAutoTerminals, null);
		app.raiseCMException(Input_required_field_terminal, ETRow_BgpAutoTerminals, null); // cnwdb2	PAR 35364


	endif;
end;</source>
    </JadeMethod>
</Class>
