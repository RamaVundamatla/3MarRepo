    </JadeMethod>
    <JadeMethod name="getSearchValueRange" id="ba5231e8-729a-4837-aee7-ddc061058af6">
        <source>getSearchValueRange(_prop: CM_QueryProperty): Any;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 May 2022	jlier1	Initial creation 53515

*/

vars
	timeArray : TimeArray;
begin
	
	create timeArray transient;
	timeArray.add(self.fromTime);
	timeArray.add(self.toTime);
	

	return timeArray;
epilog

end;</source>
        <Parameter name="_prop" type="CM_QueryProperty"/>
        <ReturnType type="Any"/>
    </JadeMethod>
    <JadeMethod name="getSearchValueStr" id="c2e96338-1a4a-4a1c-8bee-4b4147a82985">
        <source>getSearchValueStr(_prop: CM_QueryProperty): String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
14 May 2012	cnwndl1	Initial creation	Par 29532

*/

vars

	str : String;

begin
	str := self.fromTime.shortFormatJMT() &amp; ' and ' &amp; self.toTime.shortFormatJMT();
	return str;

epilog

end;</source>
        <Parameter name="_prop" type="CM_QueryProperty"/>
        <ReturnType type="String"/>
    </JadeMethod>
