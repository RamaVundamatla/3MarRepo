    <JadeMethod name="cnwdad1_JadeSkins_Unload" id="01d8359b-50d9-496c-88f2-0606a89b8e4e">
        <source>cnwdad1_JadeSkins_Unload();
// ---------------------------------------------------------------------------
// Created:     08 December 2000 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	theJadeSkin		: JadeSkin;
	theFile			: File;
	thePropertyFile	: File;
	fileDirectory	: String;
	thePropertyColl	: PropertyColl;
	theProperty		: Property;
	startTime		: Integer;
	
begin
	startTime		:=	app.clock();
	fileDirectory	:=	"c:\temp\TpSkins";
	theJadeSkin		:=	JadeSkin.firstInstance();

	if theJadeSkin = null then
		write "JadeSkin is null.";
		return;
	endif;

	create theFile transient;
	create thePropertyFile transient;

	theFile.mode				:=	File.Mode_Output;
	theFile.kind				:=	File.Kind_Binary;
	thePropertyColl				:=	JadeSkin.allProperties();

	thePropertyFile.mode		:=	File.Mode_Output;
	thePropertyFile.fileName	:=	fileDirectory &amp; "\JadeSkin.dat";
	thePropertyFile.open();

	foreach theProperty in thePropertyColl do
		if theProperty.name[1:3] = "img" then
			theFile.fileName	:=	fileDirectory &amp; "\" &amp; theProperty.name &amp; ".png";
			theFile.open();
			theFile.writeBinary(theJadeSkin.getPropertyValue(theProperty.name).Binary);
			theFile.close();
		elseif theProperty.name[1:1] &lt;&gt; "_" then
			thePropertyFile.writeLine(	theProperty.name &amp; Tab &amp;
										theJadeSkin.getPropertyValue(theProperty.name).String);
		endif;
	endforeach;

	thePropertyFile.close();
epilog
	delete theFile;
	delete thePropertyFile;
	
	write "Skins Unload completed in " &amp; startTime.jssClockDifference().String &amp; " seconds.";
end;</source>
    </JadeMethod>
    <JadeMethod name="cnwdad1_ListAllConstants" id="a89c240f-4788-44cd-818b-3da5873f5113">
        <source>cnwdad1_ListAllConstants();
// --------------------------------------------------------------------------------
// Created:		16 July 2000 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	startTime	: Integer;
	
begin
	startTime	:=	app.clock();
	
	self.cnwdad1_ListCategoryConstants("BaseSchema_Notifications");
	self.cnwdad1_ListCategoryConstants("JSSData_Load_Type");
	self.cnwdad1_ListCategoryConstants("JSSDocumentation");
	self.cnwdad1_ListCategoryConstants("JSSInitializationFile");
	self.cnwdad1_ListCategoryConstants("JSSReports");
	self.cnwdad1_ListCategoryConstants("JSSSerialInterface");
	self.cnwdad1_ListCategoryConstants("JSSTeach");
	self.cnwdad1_ListCategoryConstants("JSS_Keycode_Extras");
	self.cnwdad1_ListCategoryConstants("DOS_Environment_Variables");
	self.cnwdad1_ListCategoryConstants("Dialog_Modal_Results");
	self.cnwdad1_ListCategoryConstants("Exceptions");
	self.cnwdad1_ListCategoryConstants("General");
	self.cnwdad1_ListCategoryConstants("HostConnectivityConstants");
	self.cnwdad1_ListCategoryConstants("Literals");
	self.cnwdad1_ListCategoryConstants("MessageEvents");
	self.cnwdad1_ListCategoryConstants("Pattern_Matching");
	self.cnwdad1_ListCategoryConstants("Process_UserInfo_Field_Names");
	self.cnwdad1_ListCategoryConstants("XML_Default_Formats");
