    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>This class is only for reports pre dating September 6th 2002,
and should not be used. See th2 for info about using these classes
properly</text>
    <DbClassMap file="query"/>
    <ImplicitInverseRef name="allBOLs" id="49d65fe8-8680-4e1c-81bb-a2cb4e8a5d53">
        <memberTypeInverse/>
        <type name="CM_BOLSet"/>
    </ImplicitInverseRef>
