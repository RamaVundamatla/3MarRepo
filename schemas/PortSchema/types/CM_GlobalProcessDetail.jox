    <JadeMethod name="outputAsCSV" id="a341cbe7-74a7-4882-9a86-0223455fc65e">
        <source>outputAsCSV() : String;
// ---------------------------------------------------------------------------
// Created:     13 November 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
constants
	Delimiter : String  = ',';
	
vars
	outStr	: String;
		
begin
/*
			'Date' &amp; Delimiter &amp;
			'Time' &amp; Delimiter &amp;
			'Period' &amp; Delimiter &amp;

			'Nodes' &amp; Delimiter &amp;
			'Processes' &amp; Delimiter &amp;
			'ProcessLicenses' &amp; Delimiter &amp;
			'NonChargable' &amp; Delimiter &amp;

			'Background' &amp; Delimiter &amp;
			'Debugger' &amp; Delimiter &amp;
			'Dev' &amp; Delimiter &amp;
			'GUI' &amp; Delimiter &amp;
			'GUINoForms' &amp; Delimiter &amp;
			'HTMLSessions' &amp; Delimiter &amp;
			'Monitor' &amp; Delimiter &amp;
			'NonGUI' &amp; Delimiter &amp;
			'Painter' &amp; Delimiter &amp;
			'WebEnabled' &amp; Delimiter &amp;
			
			'avgAbortTransMin' &amp; Delimiter &amp;
			'avgBeginNotesMin' &amp; Delimiter &amp;
			'avgCommitTransMin' &amp; Delimiter &amp;
			'avgCreateObjectsMin' &amp; Delimiter &amp;
			'avgDeleteObjectsMin' &amp; Delimiter &amp;
			'avgDeliveredNotesMin' &amp; Delimiter &amp;
			'avgEndNotesMin' &amp; Delimiter &amp;
			'avgGetObjectsMin' &amp; Delimiter &amp;
			'avgGetQdLocksMin' &amp; Delimiter &amp;
			'avgLockObjectsMin' &amp; Delimiter &amp;
			'avgServerExecsMin' &amp; Delimiter &amp;
			'avgUnlockObjectsMin' &amp; Delimiter &amp;
			'avgUpdateObjectsMin';
*/
	outStr := 
			self.sampledDT.date.String &amp; Delimiter &amp;
			self.sampledDT.time.String &amp; Delimiter &amp;
			self.sampleTimeDifference.String &amp; Delimiter &amp;

			self.totalNodes.String &amp; Delimiter &amp;
			self.totalProcesses.String &amp; Delimiter &amp;
			self.numProcessLicenses.String &amp; Delimiter &amp;

			self.numDev.String &amp; Delimiter &amp;
			self.numFat.String &amp; Delimiter &amp;
			self.numHTMLSessions.String &amp; Delimiter &amp;
			self.numThin.String &amp; Delimiter &amp;

			self.avgAbortTransMin.String &amp; Delimiter &amp;
			self.avgBeginNotesMin.String &amp; Delimiter &amp;
			self.avgCommitTransMin.String &amp; Delimiter &amp;
			self.avgCreateObjectsMin.String &amp; Delimiter &amp;
			self.avgDeleteObjectsMin.String &amp; Delimiter &amp;
			self.avgDeliveredNotesMin.String &amp; Delimiter &amp;
			self.avgEndNotesMin.String &amp; Delimiter &amp;
			self.avgGetObjectsMin.String &amp; Delimiter &amp;
			self.avgGetQdLocksMin.String &amp; Delimiter &amp;
			self.avgLockObjectsMin.String &amp; Delimiter &amp;
			self.avgServerExecsMin.String &amp; Delimiter &amp;
			self.avgUnlockObjectsMin.String &amp; Delimiter &amp;
			self.avgUpdateObjectsMin.String &amp;
			self.details &amp; Delimiter &amp;
			
			self.statsBeginNotes.String &amp; Delimiter &amp;
			self.statsCreateObjects.String &amp; Delimiter &amp;
			self.statsDeleteObjects.String &amp; Delimiter &amp;
			self.statsDeliveredNotes.String &amp; Delimiter &amp;
			self.statsEndNotes.String &amp; Delimiter &amp;
			self.statsGetObjects.String &amp; Delimiter &amp;
			self.statsLockObjects.String &amp; Delimiter &amp;
			self.statsNumAbortedTrans.String &amp; Delimiter &amp;
			self.statsNumCommittedTrans.String &amp; Delimiter &amp;
			self.statsQueuedLocks.String &amp; Delimiter &amp;
			self.statsServerExecutions.String &amp; Delimiter &amp;
			self.statsUnlockObjects.String &amp; Delimiter &amp;
			self.statsUpdateObjects.String;

	return outStr;
	
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="outputAsXML" id="1772e843-dcb5-4b00-bcb9-18b857c466ae">
        <source>outputAsXML() : String;
// ---------------------------------------------------------------------------
// Created:     13 November 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
constants
	Delimiter : String  = ';';
	
vars
	numStr	: String;
		
begin

	numStr := 
			self.avgAbortTransMin.String &amp; Delimiter &amp;
			self.avgBeginNotesMin.String &amp; Delimiter &amp;
			self.avgCommitTransMin.String &amp; Delimiter &amp;
			self.avgCreateObjectsMin.String &amp; Delimiter &amp;
			self.avgDeleteObjectsMin.String &amp; Delimiter &amp;
			self.avgDeliveredNotesMin.String &amp; Delimiter &amp;
			self.avgEndNotesMin.String &amp; Delimiter &amp;
			self.avgGetObjectsMin.String &amp; Delimiter &amp;
			self.avgGetQdLocksMin.String &amp; Delimiter &amp;
			self.avgLockObjectsMin.String &amp; Delimiter &amp;
			self.avgServerExecsMin.String &amp; Delimiter &amp;
			self.avgUnlockObjectsMin.String &amp; Delimiter &amp;
			self.avgUpdateObjectsMin.String &amp;
			self.details &amp; Delimiter &amp;
			self.numDev.String &amp; Delimiter &amp;
			self.numFat.String &amp; Delimiter &amp;
			self.numHTMLSessions.String &amp; Delimiter &amp;
			self.numProcessLicenses.String &amp; Delimiter &amp;
			self.numThin.String &amp; Delimiter &amp;
			self.sampleTimeDifference.String &amp; Delimiter &amp;
			self.sampledDT.TimeStamp.String &amp; Delimiter &amp;
			self.statsBeginNotes.String &amp; Delimiter &amp;
			self.statsCreateObjects.String &amp; Delimiter &amp;
			self.statsDeleteObjects.String &amp; Delimiter &amp;
			self.statsDeliveredNotes.String &amp; Delimiter &amp;
			self.statsEndNotes.String &amp; Delimiter &amp;
			self.statsGetObjects.String &amp; Delimiter &amp;
			self.statsLockObjects.String &amp; Delimiter &amp;
			self.statsNumAbortedTrans.String &amp; Delimiter &amp;
			self.statsNumCommittedTrans.String &amp; Delimiter &amp;
			self.statsQueuedLocks.String &amp; Delimiter &amp;
			self.statsServerExecutions.String &amp; Delimiter &amp;
			self.statsUnlockObjects.String &amp; Delimiter &amp;
			self.statsUpdateObjects.String &amp; Delimiter &amp;
			self.totalNodes.String &amp; Delimiter &amp;
			self.totalProcesses.String;
			
	return self.formatAsXMLPrefix(CM_GlobalProcessRoot.XML_Dtl) &amp;
			self.formatAsXML(CM_GlobalProcessRoot.XML_Processes, self.details) &amp;
			self.formatAsXML(CM_GlobalProcessRoot.XML_Num, numStr) &amp;
			self.formatAsXMLSuffix(CM_GlobalProcessRoot.XML_Dtl);
	
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="162e2833-a3ba-47a7-aab1-bc2cf6acc27d">
        <updating/>
        <source>setForCreate(_root : CM_GlobalProcessRoot) updating;
/*
------------------------------------------------------------------------
Created:			27 March 2003 by cnwdwq1
Purpose:			Dave Q's code
Parameters:		
Returns:			
Changed On		Changed By		Reason
------------	------------	-----------------------------------------
														
------------------------------------------------------------------------
*/
vars
	pvDet : CM_GlobalProcessDetail;
	jli : JadeLicenceInfo;
begin

	create jli transient;
	jli.getLicenceInfo;

	self.numDev 				:= jli.developmentLicences;
	self.numHTMLSessions 		:= jli.nHtmlThinSessions;
	self.numThin 				:= jli.nJadeThinNonJadeDevProcesses;
	self.numFat 				:= jli.nNonJadeDevProcesses;
	self.numProcessLicenses 	:= jli.processLicences;
	self.numProcessesLeft		:= jli.nProcessesLeft;

	self.myGlobalProcessRoot	:= _root;
	//--------------------
	//Establish inverse for previous detail
	//--------------------
	self.myPreviousDetail := self.getPriorDetail();
	pvDet := self.myPreviousDetail;
	//--------------------
	//Set the properties from the system
	//--------------------
	self.getStats();
	
	if pvDet = null then
		return;
	endif;
	if pvDet.statsGetObjects &gt; self.statsGetObjects then
		self.myPreviousDetail := null;	//Break inverse, the Server has restarted and stats are less than last time.
	endif;
epilog
	delete jli;
end;</source>
        <Parameter name="_root" type="CM_GlobalProcessRoot"/>
    </JadeMethod>
    <JadeMethod name="setFromXML" id="0e8b0893-8588-413b-9785-ceb4a0729038">
        <updating/>
        <source>setFromXML(_str : String; _root : CM_GlobalProcessRoot) : Boolean updating;
// ---------------------------------------------------------------------------
// Created:     13 November 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
constants
	Delimiter : Character  = ';';

vars
	tmpStr	: String;
	array	: StringArray;	

begin

	tmpStr := _str.cnEcGetTagValueOfName(CM_GlobalProcessRoot.XML_Processes);
	self.details	:= tmpStr;

	tmpStr := _str.cnEcGetTagValueOfName(CM_GlobalProcessRoot.XML_Num);
	if tmpStr = null then
		app.writeStatement( class.name &amp; '::' &amp; method.name &amp; '  Error in load &gt;&gt;' &amp; _str);
		return false;
	endif;
	
	create array transient;
	tmpStr.getTokensForDelimiter(Delimiter, array);
	
	if array.size &lt; 27 then
		app.writeStatement( class.name &amp; '::' &amp; method.name &amp; '  Error in load &gt;&gt;' &amp; _str);
		return false;
	endif;

	self.avgAbortTransMin := array[1].Integer;
	self.avgBeginNotesMin := array[2].Integer;
	self.avgCommitTransMin := array[3].Integer;
	self.avgCreateObjectsMin := array[4].Integer;
	self.avgDeleteObjectsMin := array[5].Integer;
	self.avgDeliveredNotesMin := array[6].Integer;
	self.avgEndNotesMin := array[7].Integer;
	self.avgGetObjectsMin := array[8].Integer;
	self.avgGetQdLocksMin := array[9].Integer;
	self.avgLockObjectsMin := array[10].Integer;
	self.avgServerExecsMin := array[11].Integer;
	self.avgUnlockObjectsMin := array[12].Integer;
	self.avgUpdateObjectsMin := array[13].Integer;
	self.numDev := array[14].Integer;
	self.numFat := array[15].Integer;
	self.numHTMLSessions := array[16].Integer;
	self.numProcessLicenses := array[17].Integer;
	self.numThin := array[18].Integer;
	self.sampleTimeDifference := array[19].Integer;
	self.sampledDT := array[20].TimeStamp;
	self.statsBeginNotes := array[21].Integer64;
	self.statsCreateObjects := array[22].Integer64;
	self.statsDeleteObjects := array[23].Integer64;
	self.statsDeliveredNotes := array[24].Integer64;
	self.statsEndNotes := array[25].Integer64;
	self.statsGetObjects := array[26].Integer64;
	self.statsLockObjects := array[27].Integer64;
	self.statsNumAbortedTrans := array[28].Integer64;
	self.statsNumCommittedTrans := array[29].Integer64;
	self.statsQueuedLocks := array[30].Integer64;
	self.statsServerExecutions := array[31].Integer64;
	self.statsUnlockObjects := array[32].Integer64;
	self.statsUpdateObjects := array[33].Integer64;
	self.totalNodes := array[34].Integer;
	self.totalProcesses := array[35].Integer;

	self.myGlobalProcessRoot	:= _root;	

	self.myPreviousDetail 		:= self.getPriorDetail();

	return true;
	
epilog
	delete array;

end;</source>
        <Parameter name="_str" type="String"/>
        <Parameter name="_root" type="CM_GlobalProcessRoot"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
