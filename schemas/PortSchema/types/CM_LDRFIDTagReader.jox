    <JadeMethod name="getAuditText" id="52dee215-6441-4d00-a58e-d8ae04716a44">
        <source>getAuditText(): String;
// ---------------------------------------------------------------------------
// Created:     11 September 2009 by cnwcs5
// Purpose:     CCMS 1061 - gate config
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 20/04/2010	cnwcs5		gDansk gate problem
// ---------------------------------------------------------------------------
vars
	txt	:String;
begin
	txt := inheritMethod();
	
	if self.myRFIDTagReader = null then
		// this happened in testing but shouldnot happen in the real world
		txt := txt &amp; " " &amp; self.formatAuditText("RFID Tag Reader", app.getErrorString (Unknown));	// 20/04/2010 cnwcs5 gDansk gate problem
	else
		txt := txt &amp; " " &amp; self.formatAuditText("RFID Tag Reader", self.myRFIDTagReader.code);
	endif;
	
	return txt;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="hasDevice" id="e92d0bea-3686-4b3d-be67-c9e019fa54b5">
