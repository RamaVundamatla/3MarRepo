    <JadeMethod name="createDelaysDictionary" id="87c61baa-b1d4-4326-a2b5-8c86fdb1bc3c">
        <source>createDelaysDictionary(_dd: DynaDictionary output) protected;
/*
	Purpose:			
	Parameters:			
	Return Value:		

Date			Who		Reason
05 August 2008	concms1	Initial creation
*/

vars

begin
	create _dd transient; 
	_dd.setMembership (CM_Delay);
	_dd.addMemberKey (CM_Delay::startDT.name, null, null);
	_dd.addMemberKey (CM_Delay::myDelayType.name, null, null);
	_dd.endKeys (true);
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_dd" type="DynaDictionary" usage="output"/>
    </JadeMethod>
    <JadeMethod name="doLoad" id="997032c2-d574-4977-9400-5b0679ad7e1f">
        <source>doLoad() protected;
/*
	Purpose:			
	Parameters:			
	Return Value:		

Date		Who		Reason
01 August 2008	concms1	Initial creation
*/

vars

begin
	inheritMethod();
	
	// display voyage data
	self.setupTable_Main;
	
	// display data in delays table
	self.setupTable_Delay;
	
	// display data in times table
	self.setupTable_Times;
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="run" id="5c925c87-ea74-4539-83c5-11e964b77939">
        <updating/>
        <source>run(_isPrintPreview: Boolean; _isCSV: Boolean; _extraDetail: CM_ExtraDetail): Binary updating;
/*

Date			Who		Reason
22 July 2008	concms1	Par 17592 / 17593 Initial creation
*/

vars

begin
	app.printer.setMargins(Print_Landscape, 0, 0, 10, 10);

	return inheritMethod(_isPrintPreview, _isCSV, _extraDetail);
epilog

end;</source>
        <Parameter name="_isPrintPreview" type="Boolean"/>
        <Parameter name="_isCSV" type="Boolean"/>
        <Parameter name="_extraDetail" type="CM_ExtraDetail"/>
        <ReturnType type="Binary"/>
    </JadeMethod>
