//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 27/08/2019	jlgdap1		Initial creation TFS 45769 JMT Web Portal selector query parameters
//
vars

begin
	return ETRow_DischargePort;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="setComboValues" id="403c9ab9-a900-4b01-9735-48ff6a04fafa">
        <source>setComboValues(comboBox 				: ComboBox input; 
			   queryCriteriaLineHolder 	: CM_QueryCriteriaLineHolder; 
			   queryOperator 			: CM_QueryOperator; 
			   passport 				: CM_Passport);
/* ---------------------------------------------------------------------------
// Created:     06 March 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 29/6/2006	RBarr		CM_Port::codeDisplay attribute obsolete
   22/08/2018	jlgka1		Make the code readable, rename some parameter and local variables.
//--------------------------------------------------------------------------- */
vars
	port	 				: CM_Port;
	portDict 				: CM_PortByCodeDict;
	portCmbOrderDescrFirst 	: Boolean;
begin
	comboBox.clear();
	comboBox.addItem(null);//need to be able to search for null discharge port etc.
	portDict := app.myRoot.allActiveDestinations; //cnwrd1 par 20592 30.9.09 - all active destinations not just  all ports
	
	portCmbOrderDescrFirst := app.myRoot.getConfig(PortCmbOrderDescrFirst).Boolean;
	foreach	port in portDict do		
		comboBox.itemObject[comboBox.addItem(port.getDisplayFormatted(portCmbOrderDescrFirst))] := port;
	endforeach;

	if CM_QStringLookup.hasInstance(queryOperator) then
		comboBox.listObject := portDict[queryOperator.CM_QStringLookup.selectionValue];
	elseif CM_QStringLookupNotEqual.hasInstance(queryOperator) then
		comboBox.listObject := portDict[queryOperator.CM_QStringLookupNotEqual.selectionValue];
	endif;

end;</source>
        <Parameter name="comboBox" type="ComboBox" usage="input"/>
        <Parameter name="queryCriteriaLineHolder" type="CM_QueryCriteriaLineHolder"/>
        <Parameter name="queryOperator" type="CM_QueryOperator"/>
        <Parameter name="passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="setListValues" id="6a7e2a71-d22d-4eb0-a967-ca6715fa1692">
        <source>setListValues(table						: Table input; 
			  queryCriteriaLineHolder	: CM_QueryCriteriaLineHolder; 
			  queryOperator				: CM_QueryOperator; 
			  passport					: CM_Passport);
// ---------------------------------------------------------------------------
// Created:		10 March 2006  By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
/*

Date		Who					Reason
26 May 2008	cnwkpd1	PAR #16810	Change to table row limit for JADE 6.2
22 Aug 2018 jlgka1	TFS #40200	Add Description to the Selection List.

*/

vars
	port					: CM_Port;
	portDict				: CM_PortByCodeDict;
	idx						: Integer;
	selectionValue 			: Integer;
	portCmbOrderDescrFirst 	: Boolean;
begin
	table.rows := table.fixedRows;
	table.sortColumn[1] := 2;
	table.sortAsc[1] := true;
	
	if queryCriteriaLineHolder = null then
		return;
	endif;
	
	portCmbOrderDescrFirst := app.myRoot.getConfig(PortCmbOrderDescrFirst).Boolean;
	
	portDict := app.myRoot.allActiveDestinations;
	foreach	port in portDict do
		selectionValue := 0;
		if queryOperator &lt;&gt; null and queryOperator.CM_QStringIsOneOf.allSelectionValues.includes(port.code) then
			selectionValue := 1;
		endif;
		// to check
		if idx &gt;= JadeTableRowLimit then		// PAR #16810
			app.msgBox('Maximum number of entries in table exceeded.  Only the first ' &amp; JadeTableRowLimit.String &amp; ' will be shown', 'Error', MsgBox_OK_Only);
			break;
		endif;

		// 45000 plus ports in cnwdmast exceeds max table rows (16000), however customers have less than this
		// so not fixed. If it is addressed, the solution should be generic. RBarr 29/6/2006
		idx := table.addItem(selectionValue.String &amp; Tab &amp; port.getDisplayFormatted(portCmbOrderDescrFirst));		
		table.accessRow(idx).itemObject := port;
		table.row := idx;
		table.change(table);
	endforeach;
	table.resort();

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="queryCriteriaLineHolder" type="CM_QueryCriteriaLineHolder"/>
        <Parameter name="queryOperator" type="CM_QueryOperator"/>
        <Parameter name="passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="setValuesFromList" id="e22810c9-788c-4364-a4ef-899362c1e31b">
        <source>setValuesFromList(_tbl: Table input; _op: CM_QueryOperator input);
// ---------------------------------------------------------------------------
// Created:		10 March 2006  By Andrew Bishop cnwab1
//
// Purpose:		
// 	----------  		---------- 	---------- 	--------------------------------
/* 	Changed On  		 Changed By  TFS#		Reason
	25 November 2009	cnwndl1		CCMS 1028	Initial creation	
	17/09/2018			jlgka1		TFS# 40200	Add method call to get port code 
												from Port Display Description.
// ---------------------------------------------------------------------------*/

vars
	str						: String;
	numRows					: Integer;
	idx						: Integer;
	portCodeArray			: StringArray;
	portCode				: String;	
	portCmbOrderDescrFirst 	: Boolean;
begin
	portCmbOrderDescrFirst := app.myRoot.getConfig(PortCmbOrderDescrFirst).Boolean;
	
	create portCodeArray transient;
	
	numRows := _tbl.rows;
	foreach idx in (_tbl.fixedRows + 1) to numRows do
		str := _tbl.accessCell(idx, 1).text;
		if str = TableCheckBox_Selected then
			portCode := getPortCodeFromDescription(_tbl.accessCell(idx, 2).text, portCmbOrderDescrFirst);
			portCodeArray.add(portCode);
		endif;
	endforeach;
	
	_op.setSearchValue(portCodeArray);

epilog
	delete portCodeArray;
end;</source>
        <Parameter name="_tbl" type="Table" usage="input"/>
        <Parameter name="_op" type="CM_QueryOperator" usage="input"/>
    </JadeMethod>
    <JadeMethod name="translateToDisplayValue" id="28d2a435-4f02-41b8-bfef-98a22df5cafb">
        <source>translateToDisplayValue(_value: Any): String;
// ---------------------------------------------------------------------------
// Created:     06 March 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
vars

begin
	if _value.isKindOf(CM_Port) then
		if _value &lt;&gt; null then
			return _value.CM_Port.code;
		else
			return null;
		endif;
	else
		return _value.String;
	endif;

end;</source>
        <Parameter name="_value" type="Any"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="translateToSearchValue" id="6ae42e24-f01a-4e6d-a4c4-9cbff1ede691">
        <source>translateToSearchValue(_value: Any): Any;
// ---------------------------------------------------------------------------
// Created:     17 March 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
/*

Date		Who		Reason
06 Oct 2008	cnwkpd1	PAR #18099 - Correct Selector query processing
22 Oct 2008	cnwkpd1	PAR #18348 - Prevent 1002 exceptions in Selector query processing with isOneOf

*/

vars
	invalidObj 		: Boolean;
	object			: CM_Port;
	returnVal		: String;
	
begin
	if _value &lt;&gt; null then
		if _value.isKindOf(Collection) then			// PAR #18348
			return _value;
		endif;
	
		if _value.isKindOf(CM_Port) then
			object := _value.CM_Port;
		endif;
		
		if _value.isKindOf(String) then
			return _value;
		endif;
	endif;
	
	if object &lt;&gt; null then
		on Exception do app.handleDeletedObject(exception, object, invalidObj);
		
		returnVal := object.code;
	endif;
	
	return returnVal;
	
end;
</source>
        <Parameter name="_value" type="Any"/>
        <ReturnType type="Any"/>
    </JadeMethod>
    <JadeMethod name="translateToSearchValueForWeb" id="699f5d02-a6fc-42f8-b7f5-7b8d874c88c8">
        <source>translateToSearchValueForWeb(_value: Any; _sending : Boolean): Any;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 05/09/2019	jlgdap1		Initial creation TFS 45769 JMT Web Portal selector query parameters
//
vars
	port : CM_Port;
	str, returnVal : String;
	strArray : StringArray;

begin
	if _value.isKindOf(CM_Port) then
		port := _value.CM_Port;
		
	elseif _value.isKindOf(String) then
		if _value.String.cnContains("|") then
			str := _value.String;
			create strArray transient;
			str.getTokensForDelimiter("|", strArray);
			return strArray;
		endif;
		
		if not _sending then
			return _value.String;
		endif;
		
		port := app.myRoot.allPorts[_value.String];
		
	elseif _value.isKindOf(StringArray) then
		foreach str in _value.StringArray do
			port := app.myRoot.allPorts[str];
			if port &lt;&gt; null then
				returnVal := returnVal &amp; port.code &amp; CNEC_COMMA &amp; Space;
			endif;
		endforeach;
		returnVal := returnVal[1:returnVal.length-2];
		return returnVal;
		
	endif;
	
	if port &lt;&gt; null then
		if port.countryCode &lt;&gt; null then
			return port.portCode &amp; " (" &amp; port.countryCode &amp; ") " &amp; port.description;
		else
			return port.portCode &amp; " " &amp; port.description;
		endif;
	endif;
	
	return inheritMethod(_value, _sending);

epilog

end;</source>
        <Parameter name="_value" type="Any"/>
        <Parameter name="_sending" type="Boolean"/>
        <ReturnType type="Any"/>
    </JadeMethod>
</Class>
