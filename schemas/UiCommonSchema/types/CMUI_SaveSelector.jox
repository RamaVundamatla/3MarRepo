    <JadeMethod name="translateForm" id="3867492f-c9dc-45ec-9b71-59df3ca057f8">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 16 October 2023 13:46:42.
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0026488, locale);
	btnClose.translateCaption(Xlat_0026489, locale);
	btnNewFolder.translateCaption(Xlat_0026490, locale);
	btnSave.translateCaption(Xlat_0026491, locale);
	btnSaveAs.translateCaption(Xlat_0026492, locale);
	lblFolder.translateCaption(Xlat_0026493, locale);
	lblQuery.translateCaption(Xlat_0026494, locale);
	lblQueryDesc.translateCaption(Xlat_0026495, locale);
	lblQueryName.translateCaption(Xlat_0026496, locale);
end;</source>
    </JadeMethod>
</GUIClass>
