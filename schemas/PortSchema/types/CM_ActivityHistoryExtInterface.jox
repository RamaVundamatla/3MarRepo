    <JadeMethod name="setForCreate" id="97792964-4671-4f69-bcb7-8700dec25862">
        <updating/>
        <source>setForCreate( _proxy : CM_ActivityHistoryExtInterface ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 April 2018	jlgndl1	Initial creation`	TFS 38135
13 Jun 2018	jlgkpd	TFS 39164 - rework to use Strings for performance and database space optimisation
12 November 2018	cnwma1	ChangeRequest 41945: PEL1 - SAP - Invoice changes restriction
*/

vars

begin

	inheritMethod(_proxy);
	
	self.request     := _proxy.request;
	self.response    := _proxy.response;
	self.requestName := _proxy.requestName; //12.11.2018 cnwma1 TFS #41945
	self.setSuccess( _proxy.success );	//21 Nov 2018	NDL	TFS 42116
	self.setReferenceID( _proxy.referenceID );	//21 Nov 2018	NDL	TFS 42116
	self.myVoyage 		:= _proxy.myVoyage;  //epr TFS 42098 22/11/18
	self.interfaceName := _proxy.interfaceName;	//30 Sep 2019	NDL	TFS 46758
	self.reprocessDT := _proxy.reprocessDT;		//30 Sep 2019	NDL	TFS 46758
	self.setInvoiceLines( _proxy.allInvoiceLines );		//30 Sep 2019	NDL	TFS 46758
	self.errors:=_proxy.errors;	//01 Oct 2019	NDL	TFS 46758
	self.myCashReceipt := _proxy.myCashReceipt; 	//01 Oct 2019	NDL	TFS 46758
	self.myInvoice := _proxy.myInvoice; //01 Oct 2019	NDL	TFS 46758 
	
epilog

end;</source>
        <Parameter name="_proxy" type="CM_ActivityHistoryExtInterface"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="bac50126-ad16-44bf-8e0f-b2e01af84c89">
        <updating/>
        <source>setForUpdate(_proxy: CM_ActivityHistoryExtInterface) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 September 2018	jlger1	Initial creation
12 November  2018	cnwma1	ChangeRequest 41945: PEL1 - SAP - Invoice changes restriction
*/

vars

begin
	inheritMethod(_proxy);
	self.request:=_proxy.request;
	self.response:=_proxy.response;
	self.myCashReceipt := _proxy.myCashReceipt; //12.11.2018 cnwma1 TFS #41945
	self.myInvoice     := _proxy.myInvoice;    //12.11.2018 cnwma1 TFS #41945
	self.myVoyage 		:= _proxy.myVoyage;  //epr TFS 42098 22/11/18
	self.requestName   := _proxy.requestName;  //12.11.2018 cnwma1 TFS #41945
	self.errors:=_proxy.errors;
	self.setSuccess( _proxy.success );	//21 Nov 2018	NDL	TFS 42116
	self.setReferenceID( _proxy.referenceID );	//21 Nov 2018	NDL	TFS 42116
	self.isCargoTransaction:=_proxy.isCargoTransaction;
	self.debtorCode:=_proxy.debtorCode;
	self.voyageCode:=_proxy.voyageCode;
	self.interfaceName := _proxy.interfaceName;	//30 Sep 2019	NDL	TFS 46758
	self.reprocessDT := _proxy.reprocessDT;		//30 Sep 2019	NDL	TFS 46758
	self.setInvoiceLines( _proxy.allInvoiceLines );		//30 Sep 2019	NDL	TFS 46758
	
	
epilog


end;</source>
        <Parameter name="_proxy" type="CM_ActivityHistoryExtInterface"/>
    </JadeMethod>
