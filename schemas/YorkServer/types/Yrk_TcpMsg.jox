    <JadeMethod name="user_cnTcpExceptionHandler" id="4fa3bda9-cf42-49da-b72f-80a587148aaa">
        <updating/>
        <source>user_cnTcpExceptionHandler(_exObj: Exception): Integer updating;

vars
	tcpMsg : Yrk_TcpMsg;

begin
	tcpMsg := _exObj.ConnectionException.connection.Yrk_TcpMsg;
	self.myForm.staMain.caption := "Disconnected";
	self.myForm.setConnected(false);
	self.myForm.staMain.boundaryColor := Blue;
//	self.myForm.closeListern();
//	self.myForm.openListern();
	return Ex_Continue;
end;</source>
        <Parameter name="_exObj" type="Exception"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
</Class>
