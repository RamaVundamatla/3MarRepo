    <JadeMethod name="updateLoadOrder" id="720eb6e5-81d8-44cb-92ea-6c4edab546ad">
        <updating/>
        <source>updateLoadOrder() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
14 May 2010	cnwmh5	Initial creation #24129

*/

vars

	obj			: Object;
	cell		: JadeTableCell;
	entTableRow	: EntTableRow;

	startIdx	: Integer;
	endIdx		: Integer;
	idx2		: Integer;
	colIndex	: Integer;
	
begin
	
	// check to see if we are displaying LoadOrder column in table
	colIndex := 0;
	startIdx := 1;
	endIdx := self.tblData.allTblDataEntRows.size;
	foreach idx2 in startIdx to endIdx do
		entTableRow := self.tblData.allTblDataEntRows[idx2];
		if entTableRow.name = ETRow_LoadOrderStr then
			colIndex := idx2;
			break;
		endif;
	endforeach;
	
	// if column found then update the columns accordingly
	if colIndex &gt; 0 then
		// go through and update the values in the row
		startIdx := self.tblData.fixedRows + 1;
		endIdx := self.tblData.rows;
		foreach idx2 in startIdx to endIdx do
				obj := self.tblData.accessRow(idx2).itemObject;
				if obj &lt;&gt; null then
					cell := self.tblData.accessCell(idx2, colIndex);
					if cell = null then
						continue;
					endif;
					cell.text := obj.CM_TrackedItem.getDisplayStringForAttribute(ETRow_LoadOrderStr,false);
				endif;
		endforeach;
	endif;	

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="zDoEdit" id="b55d9292-6fb1-4244-b36c-7693a737014f">
        <updating/>
        <source>zDoEdit() updating, protected;
// ---------------------------------------------------------------------------
// Created:     13 September 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	ti			: CM_TrackedItem;

begin

	if self.useTxtThumb then
		ti := self.myCurrentObject.CM_TrackedItem;
		if ti = null then
			return;
		endif;
		
		if self.tblData.allSelectedObjects.size &gt; 1 then
			self.myAssistant.showCargoEnquiryForTIs(ti, self.tblData.allSelectedObjects, self.myMasterMenuAction, true);
			return;
		else
			self.myAssistant.showCargoEnquiryForm(ti, self.myMasterMenuAction, true, true);
			return;
		endif;
	endif;
	
	inheritMethod();

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="zDoSearch" id="d0eb16f5-9f4e-413a-91b0-279fee21594d">
        <updating/>
        <source>zDoSearch() updating, protected;
//--------------------------------------------------------------
//Created: 24 February 2003 By: cnwgd1
//--------------------------------------------------------------
vars
	fifoDate : Date;
	capStr : String;
	showFilter : Boolean;
begin

	if self.filterTerminalArea = null and self.filterVoyage = null then
		app.msgBox('A Terminal Area or Voyage must be selected.', 'Select Terminal Area', MsgBox_Information_Icon + MsgBox_OK_Only);
		return;
	endif;
	
	self.amInitialisingWithObject := false;

	inheritMethod();
	self.setFormHeading();
//Par7560 Added to prevent counter productivety of user having to hide the searcher in order to continue
//        with dragging and dropping containers into this area when it is empty.
//		  If the numOfItems shown was 0 then the searcher would automatically show
	self.zHideSearcher();
	
	if self.filterTerminalArea &lt;&gt; null then
		if self.filterTerminalArea.type = TA_TYPE_BULK then
			self.btnAdjustStock.enabled := true;
		else
			self.btnAdjustStock.enabled := false;	
		endif;
	endif;

	// TFS 2198 CNWAB1
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		self.btnAdjustStock.enabled := false;	
	endif;
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="zTblDataSysNotifyUpdate" id="8cd37010-32a1-4427-b391-b8ab72303340">
        <updating/>
        <source>zTblDataSysNotifyUpdate(eventType: Integer; theObject: Object; eventTag: Integer) updating, protected;
// -------------------------------------------
// Created 04 October 2005 by cnwdvb1
// -------------------------------------------
vars

begin
	inheritMethod(eventType, theObject, eventTag);
	self.numItemsShown := self.tblData.rows - self.tblData.fixedRows;
	if self.useNumRowsShown then
		self.showNumRowsShown();
	endif;
epilog
	endLoad;

end;</source>
        <access>protected</access>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
    </JadeMethod>
</GUIClass>
