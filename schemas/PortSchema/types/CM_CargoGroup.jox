    <JadeMethod name="validateWeightIncluding" id="d3904cbf-8b89-458c-89c6-1c9f4a547349">
        <source>validateWeightIncluding( _ti : CM_TrackedItem ):Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 July 2015	cnwndl1	Initial creation

*/

vars

	str1 : String;
	str2 : String;
	measureType : CM_MeasurementType;
	newWeight : Decimal[14,4];

begin

	if self.isPreAssigned then
		return true;
	endif;

	if self.maxWeight &gt; 0 then
	
		if _ti &lt;&gt; null then
			newWeight := self.totalWeight + _ti.totalWeight;
		else
			newWeight := self.totalWeight;
		endif;
		if newWeight&gt; self.maxWeight then
			measureType := app.getDefaultMeasurementForType(Type_Weight);
			if measureType = null then
				str1 := newWeight.asStringWeightJMT;
				str2 := self.maxWeight.asStringWeightJMT;
			else
				str1 := app.convertMeasurementForDisplay(measureType.shortName, newWeight);
				str2 := app.convertMeasurementForDisplay(measureType.shortName, self.maxWeight);
			endif;
			if _ti &lt;&gt; null then
				app.raiseCMException4(Would_exceed_total_weight, str1, str2, _ti.id, self.id, null, null);
				return false;
			else
				app.raiseCMException2(Total_weight_exceed_maximu_wei, str1, str2, null, null);
				return false;
			endif;
		endif;
	endif;
	
	return true;

epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
