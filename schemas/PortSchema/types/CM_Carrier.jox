vars

begin

	self.myRoot := app.myRoot;

end;</source>
    </JadeMethod>
    <JadeMethod name="setOperatorDARec" id="54798166-1c40-45b8-8a65-2100ff79118e">
        <updating/>
        <source>setOperatorDARec(_operatorDARec: CM_DataAccessController) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 September 2017	jlgmp6	Initial creation	TFS2749

*/

vars

begin
	if _operatorDARec = null then
		self.allDataAccessControllersRec.clear();
	elseif self.allDataAccessControllersRec.isEmpty() then
		self.allDataAccessControllersRec.add(_operatorDARec);
	elseif not self.allDataAccessControllersRec.includes(_operatorDARec) then
		self.allDataAccessControllersRec.clear();
		self.allDataAccessControllersRec.add(_operatorDARec);
	endif;
epilog

end;</source>
        <Parameter name="_operatorDARec" type="CM_DataAccessController"/>
    </JadeMethod>
    <JadeMethod name="setOperatorDARel" id="887ae39e-2ed7-4bcc-b1f3-9261b795f413">
        <updating/>
        <source>setOperatorDARel(_operatorDARel: CM_DataAccessController) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 September 2017	jlgmp6	Initial creation	TFS2749

*/

vars

begin
	if _operatorDARel = null then
		self.allDataAccessControllersRel.clear();
	elseif self.allDataAccessControllersRel.isEmpty() then
		self.allDataAccessControllersRel.add(_operatorDARel);
	elseif not self.allDataAccessControllersRel.includes(_operatorDARel) then
		self.allDataAccessControllersRel.clear();
		self.allDataAccessControllersRel.add(_operatorDARel);
	endif;
epilog

end;</source>
        <Parameter name="_operatorDARel" type="CM_DataAccessController"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="7f460631-f8f6-4098-acef-c3aa62aa9266">
        <updating/>
        <source>setProxy(pCode, pDescription : String; _pinEmailAddresses: CM_EmailEntityByTypeNameDict; _isNotAvailableForEntry, _isRail, _isRoad, _isSubCarrier : Boolean; _debtor : CM_Debtor;  _colour: Integer; _dacRel, _dacRec: CM_DataAccessController) updating;
//29/08/2018	JLGNS1	Bug 40008: PEN - Restrict Operator Issue - removed TFS2749
//12/05/2022 navhl20 TFS 53430  EUP - Sub Carrier registration in MTN
//23/08/2022 navlw1 TFS 53854 MTN Api Mapper Post Customer
vars

begin

	self.raiseExceptionIfNotTransient(method);
    
	self.code 						:= pCode[1:10];
	self.description 				:= pDescription[1:70]; //epr par 35304 2/12/14
	self.isNotAvailableForEntry		:= _isNotAvailableForEntry;
	self.isRail						:= _isRail;	//+ cnwmd1, CCMS 1067, Par 19710
	self.isRoad						:= _isRoad;	//+ cnwmd1, CCMS 1067, Par 19710
	self.isSubCarrier 				:= _isSubCarrier;  //12/05/2022 navhl20 TFS 53430
	self.setDebtor(_debtor); 					//+ cnwmd1, CCMS 1067
	self.colour						:= _colour;	// 12/6/17 MAP TFS4209
	
	self.allPINNotifyEmailAddresses.clear(); 
	if _pinEmailAddresses &lt;&gt; null then
		_pinEmailAddresses.copy(self.allPINNotifyEmailAddresses);
	endif;
	
	self.allDataAccessControllersRec.clear();
	if _dacRec &lt;&gt; null then
		self.allDataAccessControllersRec.add(_dacRec);
	endif;
	
	self.allDataAccessControllersRel.clear();
	if _dacRel &lt;&gt; null then
		self.allDataAccessControllersRel.add(_dacRel);
	endif;
	
	self.myRoot		 				:= app.myRoot;
	
end;</source>
        <Parameter name="pCode" type="String"/>
        <Parameter name="pDescription" type="String"/>
        <Parameter name="_pinEmailAddresses" type="CM_EmailEntityByTypeNameDict"/>
        <Parameter name="_isNotAvailableForEntry" type="Boolean"/>
        <Parameter name="_isRail" type="Boolean"/>
        <Parameter name="_isRoad" type="Boolean"/>
        <Parameter name="_isSubCarrier" type="Boolean"/>
        <Parameter name="_debtor" type="CM_Debtor"/>
        <Parameter name="_colour" type="Integer"/>
        <Parameter name="_dacRel" type="CM_DataAccessController"/>
        <Parameter name="_dacRec" type="CM_DataAccessController"/>
    </JadeMethod>
    <JadeMethod name="validateForCreate" id="fce36c0f-5a32-491d-8ca1-ad356eec822d">
        <source>validateForCreate();
// ---------------------------------------------------------------------------
// Created:     16 July 2001 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	
begin
	if app.myRoot.allCarriers[code] &lt;&gt; null then
		app.raiseCMException1(VB_DUPLICATED_ITEM, self.code, null, null);
	endif;

	self.validateMe();
/*	taken out for Par 14923

	if self.code &lt;&gt; null and self.code.hasInvalidChars()then 
		app.raiseCMException1(ERR_INVALID_CHARACTERS, 'Code ('&amp; self.code &amp; ') ', null, null);
	endif;
*/
end;</source>
    </JadeMethod>
    <JadeMethod name="validateForDelete" id="fbb746ea-5740-4b45-8a5f-a5049d182098">
        <source>validateForDelete();
// ---------------------------------------------------------------------------
// Created:     16 July 2001 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

	theID : String;
	aTerm : CM_Terminal;
	whereUsed : String;
	
begin
//	foreach aTerm in app.myRoot.allTerminals do
//		theID := aTerm.getConfig(DefRailCarrier).String;
//		if theID = self.code then
//			app.raiseCMException3(ERR_USED_IN_CONFIG,"Carrier",self.code, "Terminal " &amp; aTerm.code,null, null);
//		endif;
//	endforeach;

	if self.vehicles.size &gt; 0 then
		app.raiseCMException2(ObjectStillHasEntries, self.code, "vehicles", null, null);
	endif;
	
	//10 Nov 2020	NDL	TFS 50279
	if self.isUsedinConfig( whereUsed ) then
		app.raiseCMException2(ERR_CANNOT_DELETE, self.code, whereUsed, null, self);
	endif;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="validateForUpdate" id="b2bfca40-4755-46db-a3b8-c985e3c599a6">
        <source>validateForUpdate();
// ---------------------------------------------------------------------------
// Created:     16 July 2001 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	realCarrier	: CM_Carrier;
	whereUsed : String;
begin
	self.validateMe();

	//10 Nov 2020	NDL	TFS 50279
	if self.isNotAvailableForEntry then
		if self.isUsedinConfig( whereUsed ) then
			app.raiseCMException1(Not_make_not_availa_while, whereUsed, null, self);
		endif;
	endif;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="validateMe" id="acbf7d26-ac9d-4cf1-b2d0-e0719a136076">
        <source>validateMe() protected;

vars

begin
	if self.code = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Carrier Code', null, null);
		app.raiseCMException(Input_required_field_carCode, null, null); // cnwdb2	PAR 35364
	endif;

	if self.description = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Carrier Description', null, null);
		app.raiseCMException(Input_required_field_CarDesc, null, null); // cnwdb2	PAR 35364
	endif;

end;</source>
        <access>protected</access>
    </JadeMethod>
</Class>
