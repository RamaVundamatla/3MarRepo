    <JadeMethod name="createEditTransaction" id="81a9c1a6-9a60-4c96-a872-ec633698311e">
        <source>createEditTransaction(_theTI : CM_TrackedItem input;_details : String; _effectiveDT : TimeStamp; _passport : CM_Passport input) : CM_Edit;
// ---------------------------------------------------------------------------
// Created:     January 2009 ANDREW BISHOP
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
// 20 Feb 2024 navhl20 ChangeRequest 62525: EUP | Retrospective Operations - [54177.060] - Cargo &amp; Truck Checks
// ---------------------------------------------------------------------------
vars
	txnParams : CMIF_TITransactionController;
	trans : CM_Edit;
	userStr : String;
begin
	if _passport = null then
		app.raiseCMException2(MethodWithNullParam, method.name, '_passport', null, null);
		return null;
	endif;
	if _theTI = null then
		app.raiseCMException2(MethodWithNullParam, method.name, '_theTI', null, null);
		return null;
	endif;
	
	if _details = null then
		app.raiseCMException2(MethodWithNullParam, method.name, '_details', null, null);
		return null;
	endif;

	if _passport.userCode = null then
		userStr := app.getErrorString(UnknownUser);
	else
		userStr := _passport.userCode;
	endif;
	create txnParams transient;
	txnParams.userId := userStr;
	if _effectiveDT.isValid then													//20.02.2024 navhl20 #62525
		txnParams.dateTime := _effectiveDT;
	else
		txnParams.dateTime := app.serverTimestampAtTrxStart;
	endif;
	txnParams.noCharge := false; // TFS 3844 changed to false
	txnParams.type := TRANS_TYPE_EDIT;
	//------------------
	//Create the edited transaction
	//------------------
	trans := _theTI.createTransaction(txnParams, _passport).CM_Edit;
	
	//epr par 31557 15/5/13
	if trans &lt;&gt; null then
		trans.fieldsValues.add(_details);
	endif;
	
	return trans;
	
epilog
	delete txnParams;
end;</source>
        <Parameter name="_theTI" type="CM_TrackedItem" usage="input"/>
        <Parameter name="_details" type="String"/>
        <Parameter name="_effectiveDT" type="TimeStamp"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <ReturnType type="CM_Edit"/>
    </JadeMethod>
    <JadeMethod name="createEvent" id="2b7841e8-fcd2-4dcd-9510-db301a5e9fc7">
        <source>createEvent(_type 		: Integer;
			_dateTime 	: TimeStamp;
			_terminal 	: CM_Terminal;
			_userCode	: String;
			_transient 	: Boolean;
			_noCharge	: Boolean;
			_amount : Decimal
			) : CM_EventTransaction;
/*
----------   ----------  --------------------------------------------------
Created:	13 February 2007 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	eventType		: CM_EventType;
	event			: CM_EventTransaction;
begin
	eventType := app.myRoot.allEventTypesByType[_type];
	if eventType &lt;&gt; null then
		event := eventType.createEvent(_dateTime, _terminal, _userCode, _transient, _noCharge, _amount);
	endif;	
	
	return event;
	
end;


</source>
        <Parameter name="_type" type="Integer"/>
        <Parameter name="_dateTime" type="TimeStamp"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_userCode" type="String"/>
        <Parameter name="_transient" type="Boolean"/>
        <Parameter name="_noCharge" type="Boolean"/>
        <Parameter name="_amount" type="Decimal"/>
        <ReturnType type="CM_EventTransaction"/>
    </JadeMethod>
    <JadeMethod name="createEventUsingCMIF" id="ac682f8e-eaf2-4ce3-98b4-f8caf759ef43">
        <source>createEventUsingCMIF(_cmifEventTrx : CMIF_EventTransactionCtrl) : CM_EventTransaction;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17/02/2025	navkc1 JIRA Bug MTN-33582: MTN | Event Charging Refactor
24/07/2025	naviv1	MTN-34763 : MTN - Deferred Updates Required For Train Consist EDI
*/

vars
	eventType			: CM_EventType;
	eventTrx			: CM_EventTransaction;
	root				: CM_Root;
	
begin
	
	root := app.myRoot;
	
	if root = null then
		return null;
	endif;
	
	eventType := root.allEventTypesByType[_cmifEventTrx.type];
	
	if eventType = null or app.myPassport.isInEdiVerifyMode then	//MTN-34763
		return null;
	endif;
	
	eventTrx := _cmifEventTrx.createEventTransaction(eventType);
	
	return eventTrx;
	
epilog

end;</source>
        <Parameter name="_cmifEventTrx" type="CMIF_EventTransactionCtrl"/>
        <ReturnType type="CM_EventTransaction"/>
    </JadeMethod>
