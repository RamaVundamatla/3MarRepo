    <JadeMethod name="getColIdForUPSP" id="2aea852a-2cb8-4456-b955-6e9ae00b1b4b">
        <source>getColIdForUPSP( _ti : CM_TrackedItem; _wc : CM_WellcarWagonController ): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 December 2014	cnwndl1	Initial creation	Par 35346
*/
vars
	wcIndex : Integer;
	wc : CM_WellcarWagonController;
	lc : CM_LocationsController;
	index : Integer;
	tiArray : CM_TISet;
	heightIndex : Integer;
	tmpWc : CM_WagonController;
	tmpTi : CM_TrackedItem;
	lastTi : CM_TrackedItem;
	spaceCount : Integer;
	count : Integer;
	wcq : CM_WellcarWagonController;
	wcp : CM_WellcarWagonController;	//29 May 2015	NDL	Par 36169
	fm : CM_FutureMove;
begin
	create tiArray transient;
	//get the count of cargo from front of wagon to this cargo item / position at the same height
	// and including contiguous spaces
	
	if _ti = null then
		wc := _wc;
		wcq := wc;
		heightIndex := wc.allTrackedItems.size + 1;
	else
		lc := _ti.myPrimaryActualLocation;
		if lc &lt;&gt; null and lc.isKindOf( CM_WellcarWagonController ) and lc.CM_WellcarWagonController.myWellcarWellVisit = self then
			wc := lc.CM_WellcarWagonController;
			heightIndex := wc.allTrackedItems.indexOf( _ti );
		endif;
		if wc = null then
			lc := _ti.myPrimaryQueuedLocation;
			if lc &lt;&gt; null and lc.isKindOf( CM_WellcarWagonController ) and lc.CM_WellcarWagonController.myWellcarWellVisit = self then
				wcq := lc.CM_WellcarWagonController;
				wc := lc.CM_WellcarWagonController;
				heightIndex := wc.allTrackedItems.size + wc.allQueuedFutureMoves.getIndexOfTI( _ti );
			endif;
			//29 May 2015	NDL	Par 36169
			if wc = null and _wc &lt;&gt; null and _wc.allPlannedFutureMoves.containsTI( _ti ) then
				wcp := _wc;
				wc := _wc;
				heightIndex := wc.allTrackedItems.size + wc.allPlannedFutureMoves.getIndexOfTI( _ti );
			endif;
		endif;
		count := 1;
	endif;
	
	if wc &lt;&gt; null then
		
		wcIndex := self.allLocationsControllersArray.indexOf(wc);
		foreach index in 1 to self.allLocationsControllersArray.size do
			lastTi := tmpTi;
			tmpWc := self.allLocationsControllersArray[index];
			tmpTi := null;
			if tmpWc.allTrackedItems.size &gt;= heightIndex then
				tmpTi := tmpWc.allTrackedItems[heightIndex];
			endif;
			if index = wcIndex then
				if _ti = null then
					if index = 1 then
						spaceCount := 1;
					elseif lastTi &lt;&gt; tmpTi then
						count := count + 1;
					endif;
				endif;
				break;
			endif;

			if tmpTi = null and _ti &lt;&gt; null then
				if wcq &lt;&gt; null then
					fm := tmpWc.allQueuedFutureMoves.first;
					if fm &lt;&gt; null and fm.isKindOf(CM_FutureMoveQueued) then
						tmpTi := fm.CM_FutureMoveQueued.myTrackedItem;
					endif;
				elseif wcp &lt;&gt; null then
					fm := tmpWc.allPlannedFutureMoves.first;
					if fm &lt;&gt; null and fm.isKindOf(CM_FutureMovePlanned) then
						tmpTi := fm.CM_FutureMovePlanned.myTrackedItem;
					endif;
				endif;
			endif;
			if tmpTi &lt;&gt; null then
				tiArray.addNoDuplicates( tmpTi, false );
			else
				if lastTi &lt;&gt; tmpTi then
				// now a space and wasn't before.
					spaceCount := spaceCount + 1;
				elseif tmpTi = null and index = 1 then
					spaceCount := 1;
				endif;
			endif;
		endforeach;
		
		if _ti &lt;&gt; null then
			if tiArray.includes( _ti ) then
				count := count - 1;
			endif;
		endif;
		
		count := count + spaceCount + tiArray.size;
		
		return count.String;
	
	endif;
	
	return null;

epilog

	delete tiArray;

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_wc" type="CM_WellcarWagonController"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getTIDataForPosiRuleCheck" id="a3b9c335-8a5f-4a23-81ad-deba3bffee12">
        <source>getTIDataForPosiRuleCheck( wagPosiDataDict : CMIF_WagonPositionDataDict input );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 December 2014	cnwndl1	Initial creation	

*/

vars

	tiArray : CM_TIArray;
	cont : CM_LocationsController;
	ti : CM_TrackedItem;
	tiPosition : Integer; // 20 foot position.
	tiLength : Integer;
	wagPosiData : CMIF_WagonPositionData;
	futureMove : CM_FutureMove;
	futureMovePlanned : CM_FutureMovePlanned;
	futureMoveQueued : CM_FutureMoveQueued;
	
begin

	create tiArray transient;
	
	//foreach cont in self.allLocationsControllers discreteLock do
	foreach cont in self.allLocationsControllersArray discreteLock do	//04 Dec 2014	NDL	Par 35345
	
		tiPosition := ( ( self.allLocationsControllersArray.indexOf(cont.CM_WellcarWagonController) + 1) / 2 ) .Integer; // the position on the wagon
		
		foreach ti in cont.allTrackedItems discreteLock do
			if self.myWellcarVisit.isTIOutward(ti) then
				if cont &lt;&gt; ti.myPrimaryActualLocation then
					continue;
				endif;
				if (not tiArray.includes(ti)) then
					tiLength := ti.getActualLength().Integer;
					tiArray.add(ti);
					wagPosiDataDict.addTI(ti,tiPosition,tiLength);
				endif;
			endif;
		endforeach;
		
		foreach futureMove in cont.allPlannedFutureMoves do
			futureMovePlanned := futureMove.CM_FutureMovePlanned;
			ti := futureMovePlanned.myTrackedItem;
			if ti = null then
				continue;
			endif;
			if ti.myPrimaryPlannedLocation &lt;&gt; cont then
				// not the primary location for this ti.
				continue;
			endif;
			if (not tiArray.includes(ti)) then
				tiLength := ti.getActualLength().Integer;
				tiArray.add(ti);
				wagPosiDataDict.addTI(ti,tiPosition,tiLength);
			endif;
		endforeach;
		
		//30 Mar 2010	NDL	Par 23487
		foreach futureMove in cont.allQueuedFutureMoves do
			futureMoveQueued := futureMove.CM_FutureMoveQueued;
			ti := futureMoveQueued.myTrackedItem;
			if ti = null then
				continue;
			endif;
			if ti.myPrimaryQueuedLocation &lt;&gt; cont then
				// not the primary location for this ti.
				continue;
			endif;
			if (not tiArray.includes(ti)) then
				tiLength := ti.getActualLength().Integer;
				tiArray.add(ti);
				wagPosiDataDict.addTI(ti,tiPosition,tiLength);
			endif;
		endforeach;
		
	endforeach;
	
epilog

	delete tiArray;
	
end;</source>
        <Parameter name="wagPosiDataDict" type="CMIF_WagonPositionDataDict" usage="input"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="eeca4110-bbd1-4bcc-8284-3751f0dd8725">
        <source>pxyCreateUpdateProxy(): SelfType;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 December 2014	cnwndl1	Initial creation	Par 35346 / CCMS 1408

*/

vars

	pxy : CM_WellcarWellVisit;

begin
	pxy := inheritMethod();
	
	pxy.myWagonWellDefinition := self.myWagonWellDefinition;
	
	return pxy;

epilog

end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
