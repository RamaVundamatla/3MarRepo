    <JadeMethod name="initShtMultiSelect" id="2d7219b9-fc65-4026-b9f1-4b85a3c99e9f">
        <source>initShtMultiSelect();
//--------------------------------------------------------------
//Created: 10 July 2003 By: cnwgd1
//--------------------------------------------------------------
vars
	theForm		: SOP_TableMaintForm;
	
begin
	theForm	:=	self.myForm;
	
	inheritMethod();
	
	theForm.lblName.visible			:=	false;
	theForm.txtName.visible			:=	false;
	theForm.optAllow.visible		:=	false;
	theForm.optDisallow.visible		:=	false;
	theForm.lblName2.visible		:=	false;
	theForm.btnSetDefault1.visible	:=	false;
	theForm.btnSetDefault2.visible	:=	false;
	
	theForm.mulSelect1.visible		:=	true;
	
	theForm.mulSelect1.displayOrderBtns(true, true);
	theForm.mulSelect1.mySelectedListBox.sorted := false;
	theForm.mulSelect1.myBaseForm	:= theForm; //epr PAR 16928 18/6/08 for the multi select box need myBase form set to handle control callback method
	
	theForm.mulSelect2.visible		:=	true;
	theForm.shtMultiSelect1.visible	:=	true;
	theForm.shtMultiSelect2.visible	:=	false;
	theForm.shtMultiAlign.visible	:=	false;
end;</source>
    </JadeMethod>
