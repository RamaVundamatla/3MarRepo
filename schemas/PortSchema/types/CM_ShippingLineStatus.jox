    <JadeMethod name="pxyCreateUpdateProxy" id="b781d1ef-23d1-45ed-8de7-43f719706db5">
        <source>pxyCreateUpdateProxy(): SelfType;
//08/08/2023	navkc1	CR 59580	Task 59586: Jade - CustDocs Shipping Line Status TRX

vars
	pxySelf : SelfType;
	pxyCriteria : CM_ShippingLineStatusCriteria;
begin
	pxySelf :=  inheritMethod();
	
	pxySelf.myTerminal := self.myTerminal;
	
	if self.myCriteria &lt;&gt; null then
		pxyCriteria := self.myCriteria.pxyCreateUpdateProxy();
		pxyCriteria.setProxyBaseData(pxySelf.myTerminal, pxySelf);
	endif;
	
	return pxySelf;

epilog

end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="f5a812c5-21d2-4e32-91e1-bf36ce4a184f">
        <updating/>
        <source>setForCreate(_pxy : SelfType) updating;
//08/08/2023	navkc1	CR 59580	Task 59586: Jade - CustDocs Shipping Line Status TRX
vars

begin
	_pxy.raiseExceptionIfNotTransient(method);
	
	self.raiseExceptionIfTransient(method);
	
	self.setForUpdate(_pxy);
epilog

end;</source>
        <Parameter name="_pxy" type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="67351aed-4d69-4a6d-a6d1-da66042eb006">
        <updating/>
        <source>setForUpdate(_pxy : SelfType) updating;
//08/08/2023	navkc1	CR 59580	Task 59586: Jade - CustDocs Shipping Line Status TRX
vars

begin
	_pxy.raiseExceptionIfNotTransient(method);
	
	self.raiseExceptionIfTransient(method);
	
	self.code := _pxy.code;
	self.description := _pxy.description;
	self.notAvailForEntry := _pxy.notAvailForEntry;
	self.type := _pxy.type;
	self.myTerminal := _pxy.myTerminal;
	
	if _pxy.myCriteria &lt;&gt; null and _pxy.myCriteria.allCriteria.isNotEmpty() then
		// New Criteria
		if self.myCriteria = null then
			create self.myCriteria persistent;
			self.myCriteria.setForCreate(_pxy.myCriteria);
			self.myCriteria.setMyShippingLineStatus(self);
		// Update Criteria
		else
			self.myCriteria.setForUpdate(_pxy.myCriteria);
		endif;
	else
		delete self.myCriteria;
	endif;
	
epilog

end;</source>
        <Parameter name="_pxy" type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="1e299fe7-9a34-4f5b-886a-e133e3d5c06c">
        <updating/>
        <source>setProxy(_code, _desc : String; _notAvailForEntry : Boolean; _type : Integer; _myCriteria : CM_ShippingLineStatusCriteria; _myTerminal : CM_Terminal)  updating;
//08/08/2023	navkc1	CR 59580	Task 59586: Jade - CustDocs Shipping Line Status TRX
vars

begin
	
	self.code := _code;
	self.description := _desc;
	self.notAvailForEntry := _notAvailForEntry;
	self.type := _type;
	self.myCriteria := _myCriteria;
	self.myTerminal := _myTerminal;
	
epilog

end;</source>
        <Parameter name="_code" type="String"/>
        <Parameter name="_desc" type="String"/>
        <Parameter name="_notAvailForEntry" type="Boolean"/>
        <Parameter name="_type" type="Integer"/>
        <Parameter name="_myCriteria" type="CM_ShippingLineStatusCriteria"/>
        <Parameter name="_myTerminal" type="CM_Terminal"/>
    </JadeMethod>
