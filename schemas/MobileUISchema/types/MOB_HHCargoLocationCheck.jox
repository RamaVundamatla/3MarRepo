    <JadeMethod name="doResizeControls" id="e8d96fbb-4cb5-4ec6-b5e4-206786c4cf3a">
        <updating/>
        <source>doResizeControls(_initialSetup: Boolean) updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 August 2015	cnwndl1	Initial creation	Par 36608

*/

vars

	stdLeft : Real;
	top : Real;
	stdWidth : Real;
	stdHeight : Real;
	width : Real;
	tabIndex : Integer;

begin
	
	self.setResizeableMarginAndFontSize();
	tabIndex := 4000;
	stdLeft :=  self.resizedMargin;
	top := self.resizedMargin;
	stdWidth := self.clientWidth - self.resizedMargin - self.resizedMargin;
	stdHeight := self.getStdControlHeight;
	
	if _initialSetup then
		self.txtLocation.setAndIncrementTabIndex( tabIndex );
		self.txtLocation.visible := true;
	endif;
	self.txtLocation.move(	stdLeft,
							top,
							stdWidth,
							stdHeight );
							
	top := self.txtLocation.top + self.txtLocation.height + self.resizedMargin;
	
	if not app.isCargoGroupEnabled then	
		self.txtCargoGroupId.visible := false;
		self.lblCGroupDesc.visible := false;
		self.lblWeightValue.visible := false;
		self.lblCountValue.visible := false;
		
	else
		if _initialSetup then
			self.txtCargoGroupId.setAndIncrementTabIndex( tabIndex );
			self.txtCargoGroupId.visible := true;
		endif;
		self.txtCargoGroupId.move(	stdLeft,
									top,
									stdWidth,
									stdHeight );
								
		top := self.txtCargoGroupId.top + self.txtCargoGroupId.height + self.resizedMargin;
		if _initialSetup then
			self.lblCGroupDesc.visible := true;
			self.lblCGroupDesc.setAndIncrementTabIndex( tabIndex );
		endif;
		self.lblCGroupDesc.move(	stdLeft,
									top,
									stdWidth,
									stdHeight );
								
		top := top + self.lblCGroupDesc.height;	// + self.resizedMargin; 
		if _initialSetup then
			self.lblWeightValue.visible := true;
			self.lblWeightValue.setAndIncrementTabIndex( tabIndex );
		endif;
		self.lblWeightValue.move(	stdLeft,
									top,
									stdWidth,
									stdHeight );
									
		top := top + self.lblWeightValue.height;	// + self.resizedMargin;
		if _initialSetup then
			self.lblCountValue.visible := true;
			self.lblCountValue.setAndIncrementTabIndex( tabIndex );
		endif;
		self.lblCountValue.move(	stdLeft,
									top,
									stdWidth,
									stdHeight );
		
		top := top + self.lblCountValue.height + self.resizedMargin + self.resizedMargin;
	
	endif;
	
	inheritMethod(_initialSetup);

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_initialSetup" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="findLocationToCheck" id="e89d12dd-256c-43ae-841d-2912bdd90302">
        <source>findLocationToCheck(tmpFoundLC: CM_LocationsController output): Boolean protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 August 2015	cnwndl1	Initial creation	Par 36608

*/

vars

	dataString : String;
	tmpFoundHeight : Integer;
	errMess : String;

begin

	dataString := self.txtLocation.text.trimBlanks;
	
	if dataString = null then
		errMess := app.getErrorString( No_Location_entered );
	else
	
		if self.txtLocation.text = self.lblLocation.caption.toUpper then
			return false;
		endif;
		
		self.myTerminal.findLocationFromString(dataString, true, tmpFoundLC, tmpFoundHeight);
		
		if tmpFoundLC = null then
			errMess := app.getErrorString1(Location_NotFound, "'" &amp; dataString &amp; "'");
		endif;
		
	endif;
	
	if errMess &lt;&gt; null then
		self.msgBox( errMess, app.getErrorString(Error), MsgBox_OK_Only, true );
		return false;
	endif; 
	
	return true;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="tmpFoundLC" type="CM_LocationsController" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="handleBtnOne" id="83b47cee-c7e2-46a4-a562-af2b27ce568a">
        <updating/>
        <source>handleBtnOne() updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 August 2015	cnwndl1	Initial creation
*/

vars

	location : CM_LocationsController;
	errMsg : String;
	lcs : CM_LCSet;

begin

	location := self.txtLocation.userObject.CM_LocationsController;
	if location = null then
		self.findLocationToCheck( location );
		if location = null then
			errMsg := app.getErrorString(Input_required_field_locn);
			self.msgBox( errMsg, app.getErrorString(Error), MsgBox_OK_Only, true );
			return;
		endif;
	endif;
	
	if app.isCargoGroupEnabled and self.myCargoGroup &lt;&gt; null then
		create lcs transient;
		self.myCargoGroup.getAllLocations( lcs );
		if not lcs.includes( location ) then
			errMsg := app.getErrorString2(Does_not_inclu_cargo_that_curr,self.myCargoGroup.id,location.getFullId);
			self.msgBox( errMsg, app.getErrorString(Error), MsgBox_OK_Only, true );
			return;
		endif;
	endif;

	if app.isCargoGroupEnabled then
		self.myMobileGenericAgent.setMyNextTiToAction( self.myCargoGroup );
	else
		self.myMobileGenericAgent.setMyNextTiToAction( null );
	endif;
	self.myMobileGenericAgent.setMyLocationsController( location );
	
	self.gotoForm(MOB_HHCargoLocationScan, false);

epilog

	delete lcs;
	
end;</source>
        <access>protected</access>
    </JadeMethod>
