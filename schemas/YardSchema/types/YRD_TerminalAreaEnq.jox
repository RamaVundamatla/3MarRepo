        <source>btnShowSearcher_click(btn: Button input) updating;
// ---------------------------------------------------------------------------
// Created:     11 March 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars

begin
	if self.frmSearch.visible then
		if (not self.fldSearch.topSheet = self.shtCriteria) then
			self.fldSearch.topSheet := self.shtCriteria;
		else
			self.frmSearch.visible := false;
		endif;
	else
		if (not self.fldSearch.topSheet = self.shtCriteria) then
			self.fldSearch.topSheet := self.shtCriteria;
		endif;
		
		self.frmSearch.visible := true;
	endif;
	
end;</source>
