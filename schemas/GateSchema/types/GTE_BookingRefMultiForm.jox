    <JadeMethod name="setXMLStrForTextDisplay" id="14d3bbb2-eb8b-4f81-bf4b-6059f9b479fb">
        <updating/>
        <source>setXMLStrForTextDisplay(_theTable : CM_TextTable) updating, protected ;
/*
	Created on 05 February 2008
	
	by Debby Hutchison
	
	Purpose:
*/

vars
	tagPrefix,
	tagSuffix,
	tmpStr,	
	defName,
	replaceStr,
	tmpDefStr,
	tmpXMLStr 	: String;
	startPos	: Integer;
begin

	tmpXMLStr := _theTable.getXmlStrForDisplay();
	
	defName := _theTable.myEntTableDef.name;
	tagPrefix := J_key_LessThan.Character &amp; _theTable.XMLTag_EntTblDef &amp; defName &amp; J_key_GreaterThan.Character;
	tagSuffix := global.formatAsXMLSuffix(_theTable.XMLTag_EntTblDef &amp; defName).trimBlanks;

	startPos := 1;
	tmpDefStr := self.xmlStrTblText.cnEcGetNextTagValueOfName(_theTable.XMLTag_EntTblDef &amp; defName, startPos).trimBlanks;	

	if tmpDefStr &lt;&gt; null then
		startPos := 1;
		replaceStr := tagPrefix &amp; tmpXMLStr &amp; tagSuffix;
		startPos := 1;
		tmpDefStr := tagPrefix &amp; self.xmlStrTblText.cnEcGetNextTagValueOfName(_theTable.XMLTag_EntTblDef &amp; defName, startPos).trimBlanks &amp; tagSuffix;
		self.xmlStrTblText := self.xmlStrTblText.replaceString(tmpDefStr, replaceStr);
	else
		startPos := 1;
		tmpDefStr := tagPrefix &amp; tmpXMLStr.cnEcGetNextTagValueOfName(_theTable.XMLTag_EntTblDef &amp; defName, startPos).trimBlanks &amp; tagSuffix;
		startPos := 1;
		self.xmlStrTblText.scanWhile('&lt;'&amp; _theTable.XMLTag_Table &amp; _theTable.name &amp; '&gt;', startPos);
		self.xmlStrTblText := self.xmlStrTblText.cnEcInsertInto(tmpDefStr, startPos, startPos);
	endif;

end;</source>
        <access>protected</access>
        <Parameter name="_theTable" type="CM_TextTable"/>
    </JadeMethod>
    <JadeMethod name="setupContextMenuItems" id="bd9467b9-73c8-47f6-a182-2f2270986f06">
        <updating/>
        <source>setupContextMenuItems(_conwin: Window input) updating;
// ---------------------------------------------------------------------------
// Created:     23 January 2006	cnwhjg1
//
// Purpose:     
// ----------   ----------  --------------------------------------------------
// 10/03/2010	cnwcs5		par 22602 - disable split/roll menu items if booking closed or rolled
// 25/03/2010	cnwcs5		par 22602 - fix problem when &gt; 1 selected
// 25/03/2010	cnwcs5		par 22605 - fix incorrect enabling of menu items when in view mode (use self.allowUpdate)
// 12 Jun 2013	cnwcs5		par 31670 - qty/break bulk issues

	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	tmpMenu				: MenuItem;
	ediData 			: CM_EDIData;
	booking				: CM_BookingRef;	
	bookingItem			: CM_BookingRefItem;
	splitRollEnabled	: Boolean;			// par 22602
	coll				: ObjectArray;
	count				: Integer;
begin
	inheritMethod(_conwin);
		
	if self.myCurrentObject = null then 
		return;
	endif;
	
	self.mnuTblVViewEDIData.visible 	:= true;
	self.mnuBookingRefDiscrep.visible 	:= false;	//02 Sep 2009	NDL Par 20521 CCMS 1609
	
	if self.btnShowBookItms.value then
		//booking items
		self.mnuAdd.visible 			:= self.allowUpdate;	// 25/03/2010 cnwcs5 par 22605	:= true;	//+cnwml2 PAR19782 CCMS SFW 1079
		self.mnuEdit.visible 			:= self.allowUpdate;	// 25/03/2010 cnwcs5 par 22605	:= true;	//+cnwml2 PAR19782 CCMS SFW 1079
		self.mnuUpdateStatus.visible 	:= self.allowUpdate;	// 25/03/2010 cnwcs5 par 22605	:= true;	//+cnwml2 PAR19782 CCMS SFW 1079
		self.mnuCargoLabelPrint.visible := true; 				//22 Jan 2010 NDL CCMS MES 1004
		
		bookingItem := self.myCurrentObject.CM_BookingRefItem;
		booking		:= bookingItem.myBookingReference;
		
		if booking.getMyEDITrackedItem &lt;&gt; null then 			//cnwrs1 par 26044 testing
			ediData := booking.getMyEDITrackedItem.myEDIData; 	//cnwrs1 par 26044 testing
		endif;
		
		if ediData &lt;&gt; null then
			self.mnuTblVViewEDIData.enabled := true;
		else
			if booking.rawEDIData &lt;&gt; null then
				self.mnuTblVViewEDIData.enabled := true;
			else
				self.mnuTblVViewEDIData.enabled := false;
			endif;
		endif;
		
		//02 Sep 2009	NDL Par 20521 CCMS 1609
		if not booking.allBookingRefDiscreps.isEmpty then
			self.mnuBookingRefDiscrep.visible 		:= true;
			self.mnuBookingRefDiscrep.userObject 	:= booking;
		endif;
			
		if bookingItem.hasReceivedCargo then
			self.mnuReceived.visible := true;
			self.mnuReceived.enabled := true;
			self.mnuReceived.caption := "Show Received for Booking Item(s)...";
		else
			self.mnuReceived.visible := true;
			self.mnuReceived.enabled := false;
			self.mnuReceived.caption := "Show Received for Booking Item(s)...";
		endif;
		
		create coll transient;

		self.doMnuReleased(coll);

		if coll.size &gt; 0 then
			self.mnuReleased.visible := true;
			self.mnuReleased.enabled := true;
			self.mnuReleased.caption := "Show Released for Booking Item(s)...";
		else
			self.mnuReleased.visible := true;
			self.mnuReleased.enabled := false;
			self.mnuReleased.caption := "Show Released for Booking Item(s)...";
		endif;
		
		coll.clear;
		
		self.doMnuReserved(coll);
		
		if coll.size &gt; 0 then
			self.mnuReserved.visible := true;
			self.mnuReserved.enabled := true;
			self.mnuReserved.caption := "Show Reserved for Booking Item(s)...";
		else
			self.mnuReserved.enabled := true;
			self.mnuReserved.enabled := false;
			self.mnuReserved.caption := "Show Reserved for Booking Item(s)...";
		endif;
		
		if bookingItem.hasPrenotedCargo then
			self.mnuShowPrenoted.visible := true;
			self.mnuShowPrenoted.enabled := true;
		else
			self.mnuShowPrenoted.visible := true;
			self.mnuShowPrenoted.enabled := false;
		endif;
		
		self.mnuDelete.visible 			:= false;
		self.mnuUpdateStatus.visible 	:= false;
		self.mnuRoll.visible 			:= false;
		self.mnuSplit.visible 			:= false;
		self.mnuSeparator1.visible 		:= false;
		splitRollEnabled				:= not self.myCurrentObject.CM_BookingRefItem.myBookingReference.isRolledOrClosed;				//+cnwml2 PAR23272
	else
		self.mnuAdd.visible 			:= self.allowUpdate;	// 25/03/2010 cnwcs5 par 22605	:= true;														//+cnwml2 PAR19782 CCMS SFW 1079
		self.mnuEdit.visible 			:= self.allowUpdate;	// 25/03/2010 cnwcs5 par 22605	:= true;														//+cnwml2 PAR19782 CCMS SFW 1079
		self.mnuUpdateStatus.visible 	:= self.allowUpdate;	// 25/03/2010 cnwcs5 par 22605	:= true;											//+cnwml2 PAR19782 CCMS SFW 1079
		self.mnuCargoLabelPrint.visible := true; 				// 22 Jan 2010 NDL CCMS MES 1004
	
		booking := self.myCurrentObject.CM_BookingRef;
		
		if booking.getMyEDITrackedItem &lt;&gt; null then 			//cnwrs1 par 26044 testing
			ediData := booking.getMyEDITrackedItem.myEDIData; 	//cnwrs1 par 26044 testing
		endif;
		
		//02 Sep 2009	NDL Par 20521 CCMS 1609
		if not booking.allBookingRefDiscreps.isEmpty then
			self.mnuBookingRefDiscrep.visible 		:= true;
			self.mnuBookingRefDiscrep.userObject 	:= booking;
		endif;
		
		if ediData &lt;&gt; null then
			self.mnuTblVViewEDIData.enabled := true;
		else
			if booking.rawEDIData &lt;&gt; null then
				self.mnuTblVViewEDIData.enabled := true;
			else
				self.mnuTblVViewEDIData.enabled := false;
			endif;
		endif;
		
		create coll transient;
		
		count := booking.getRecievedCount;
		
		if count &gt; 0 then
			self.mnuReceived.visible := true;
			self.mnuReceived.enabled := true;
		else
			self.mnuReceived.visible := true;
			self.mnuReceived.enabled := false;
		endif;

		self.mnuReceived.translateCaption(Xlat_0011312, app.myCurrentLocale);
		
		coll.clear;
		
		self.doMnuReleased(coll);
		
		if coll.size &gt; 0 then
			self.mnuReleased.visible := true;
			self.mnuReleased.enabled := true;
			self.mnuReleased.caption := "Show Released for Booking(s)...";
		else
			self.mnuReleased.visible := true;
			self.mnuReleased.enabled := false;
			self.mnuReleased.caption := "Show Released for Booking(s)...";
		endif;
		
		coll.clear;
		self.doMnuReserved(coll);
		if coll.size &gt; 0 then
			self.mnuReserved.visible := true;
			self.mnuReserved.enabled := true;
			self.mnuReserved.caption := "Show Reserved for Booking(s)...";
		else
			self.mnuReserved.visible := true;
			self.mnuReserved.enabled := false;
			self.mnuReserved.caption := "Show Reserved for Booking(s)...";
		endif;
		
		count := booking.getPrenotedCount;
		
		if count &gt; 0 then
			self.mnuShowPrenoted.visible := true;
			self.mnuShowPrenoted.enabled := true;
		else
			self.mnuShowPrenoted.visible := true;
			self.mnuShowPrenoted.enabled := false;
		endif;
		
		self.mnuDelete.visible 			:= self.allowUpdate;	// 25/03/2010 cnwcs5 par 22605	:= true;
		self.mnuUpdateStatus.visible 	:= self.allowUpdate;	// 25/03/2010 cnwcs5 par 22605	:= true;
		// par 22605 - start (reworked)	
		self.mnuRoll.visible 			:= self.allowUpdate and app.myCurrentUserCan (self.myTerminal, PmGteBookingRefRollSplit);

		if self.tblData.allSelectedObjects.size &gt; 1 then
			self.mnuSplit.visible 		:= false;
			self.mnuReconcile.visible 	:= false;
		//		self.mnuSetReconciled.visible 	:= false; // TFS 2198
			self.mnuSetReconciled.visible 	:= self.allowUpdate and app.myCurrentUserCan (self.myTerminal, PmGteBookingRefRecon); // TFS 2855
		else
			self.mnuSplit.visible 		:= self.mnuRoll.visible;
			self.mnuReconcile.visible 	:= self.allowUpdate and app.myCurrentUserCan (self.myTerminal, PmGteBookingRefRecon);
			self.mnuSetReconciled.visible 	:= self.allowUpdate and app.myCurrentUserCan (self.myTerminal, PmGteBookingRefRecon); // TFS 2198
		endif;
		
		self.mnuSeparator1.visible 	:= mnuAdd.visible or mnuEdit.visible or mnuDelete.visible;	// 25/03/2010 cnwcs5 par 22605
		splitRollEnabled			:= self.canDoSplitOrRoll (self.tblData.allSelectedObjects);		// 25/03/2010 cnwcs5 par 22602 (***)
	endif;
	// par 22602 - start (note this had been commented out deliberately - not sure why)
	self.mnuRoll.enabled	:= splitRollEnabled;
	self.mnuSplit.enabled	:= splitRollEnabled;
	
	tmpMenu := self.zCloneMenu(self.mnuTblVCloneDataTbl, self.mnuSeparator, false);
	
	//24 Nov 2009	NDL	CCMS 1028
	tmpMenu := self.zCloneMenu(self.mnuTblVCloneDataTbl, self.mnuSummarise, false);

	self.zCloneMenu( tmpMenu, self.mnuSummariseAll, true );
	self.zCloneMenu( tmpMenu, self.mnuSummariseSelected, true );

	tmpMenu := self.zCloneMenu(self.mnuTblVCloneDataTbl, self.mnuLegend, false);					// TFS 2814
	tmpMenu := self.zCloneMenu(self.mnuTblVCloneDataTbl, self.mnuReserved, false);					//+cnwml2 PAR20173 SFW CCMS 1091
	tmpMenu := self.zCloneMenu(self.mnuTblVCloneDataTbl, self.mnuReleased, false);					//+cnwml2 PAR20173 SFW CCMS 1091
	tmpMenu := self.zCloneMenu(self.mnuTblVCloneDataTbl, self.mnuReceived, false);					//+cnwml2 PAR20173 SFW CCMS 1091
	tmpMenu := self.zCloneMenu(self.mnuTblVCloneDataTbl, self.mnuShowPrenoted, false);					//+cnwml2 PAR20173 SFW CCMS 1091
	tmpMenu := self.zCloneMenu(self.mnuTblVCloneDataTbl, self.mnuSeparator2, false);
	tmpMenu := self.zCloneMenu(self.mnuTblVCloneDataTbl, self.mnuSplit, false);						//+cnwml2 PAR20173 SFW CCMS 1091
	tmpMenu := self.zCloneMenu(self.mnuTblVCloneDataTbl, self.mnuReconcile, false);						//+cnwml2 PAR20173 SFW CCMS 1091	
	tmpMenu := self.zCloneMenu(self.mnuTblVCloneDataTbl, self.mnuSetReconciled, false);						//+cnwrd1 nfs 29365
	tmpMenu := self.zCloneMenu(self.mnuTblVCloneDataTbl, self.mnuRoll, false);						//+cnwml2 PAR20173 SFW CCMS 1091	
	tmpMenu := self.zCloneMenu(self.mnuTblVCloneDataTbl, self.mnuCargoLabelPrint, false); //22 Jan 2010 NDL CCMS MES 1004
	tmpMenu := self.zCloneMenu(self.mnuTblVCloneDataTbl, self.mnuBookingRefDiscrep, false);	//02 Sep 2009	NDL Par 20521 CCMS 1609
	tmpMenu := self.zCloneMenu(self.mnuTblVCloneDataTbl, self.mnuUpdateStatus, false);				//+cnwml2 PAR19782 CCMS SFW 1079
	tmpMenu := self.zCloneMenu(self.mnuTblVCloneDataTbl, self.mnuSeparator1, false);
	tmpMenu := self.zCloneMenu(self.mnuTblVCloneDataTbl, self.mnuDelete, false);					//+cnwml2 PAR20173 SFW CCMS 1091
	tmpMenu := self.zCloneMenu(self.mnuTblVCloneDataTbl, self.mnuEdit, false);						//+cnwml2 PAR19782 CCMS SFW 1079
	tmpMenu := self.zCloneMenu(self.mnuTblVCloneDataTbl, self.mnuAdd, false);						//+cnwml2 PAR19782 CCMS SFW 1079
epilog
	delete coll;
end;</source>
        <Parameter name="_conwin" type="Window" usage="input"/>
    </JadeMethod>
