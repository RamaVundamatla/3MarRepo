    <JadeMethod name="doSearch" id="d43ce951-d594-424b-aca4-439655b37dfc">
        <source>doSearch();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02/05/2024	navkc1 CR63400 Task 63401: Jade - New REST API getProformaHeadersForDebtor

*/

vars
	dr : CM_Debtor;
	allDebtors : CM_DebtorSet;
	cash : CM_Cash;
	allCashReceiptTrx : CM_CashDict;
	allCashTrx : CM_CashDict;
	startTSLocal,
	endTSLocal : TimeStamp;
	startDateServer : Date;
	endDateServer : Date;
	startDateLocal : Date;
	endDateLocal : Date;
	startDateIsValid : Boolean;
	endDateIsValid : Boolean;
	useDates : Boolean;
	
	isPaymentDetails : Boolean;
	cashPayment	: CM_CashPayment;
begin
	
	create allDebtors transient;
	create allCashReceiptTrx transient;
	create allCashTrx transient;
	
	//isPaymentDetails := self.receiptNumber &lt;&gt; null; //11/07/2024	navkc1 CR 64839 Task 64856
	
	startDateLocal := self.fromDate;
	endDateLocal := self.toDate;
	
	startDateIsValid := startDateLocal.isValid();
	endDateIsValid := endDateLocal.isValid();
	
	useDates := (startDateIsValid or endDateIsValid) and not isPaymentDetails;
	
	startTSLocal.cnEcSetDateAndTime(startDateLocal, TimeStartOfDay);
	endTSLocal.cnEcSetDateAndTime(endDateLocal, TimeEndOfDay);
	
	startDateServer := self.localToSystemTime(startTSLocal).date();
	endDateServer := self.localToSystemTime(endTSLocal).date();
	
	if useDates then
		if startDateIsValid and endDateIsValid then
			if startDateServer &gt; endDateServer then
				app.raiseCMException2(ERR_DateRangeInvalid, startDateLocal.asStringJMT(), endDateLocal.asStringJMT(), null, null);
				return;
			endif;
		endif;
	endif;
	
	if self.myDebtor &lt;&gt; null then
		allDebtors.add(self.myDebtor);
	endif;
	
	// Search by External Invoice number
	if self.externalInvoiceNumber &lt;&gt; null and self.myBusinessUnit &lt;&gt; null then
		self.doSearchByExternalInvoiceNum(allCashReceiptTrx);
	elseif self.myTerminal = null and useDates then
		self.getRawSearchData(	allCashReceiptTrx,
								self.myDebtor,
								self.myTerminal,
								startDateServer,
								endDateServer,
								startDateIsValid,
								endDateIsValid,
								useDates,
								self.myBusinessUnit
								);
	elseif allDebtors.isEmpty() and self.canSearchByCargoID then
		self.doSearchByCargoID(allCashReceiptTrx);
	else
		foreach dr in allDebtors do
			self.getRawSearchData(	allCashReceiptTrx,
									dr,
									self.myTerminal,
									startDateServer,
									endDateServer,
									startDateIsValid,
									endDateIsValid,
									useDates,
									self.myBusinessUnit
									);
		endforeach;
	endif;
	
	foreach cash in allCashReceiptTrx do
		allCashTrx.add(cash);
		self.allCashReceiptHeaders.add(cash);
	
		//if isPaymentDetails then
		if self.includePaymentDetails then //11/07/2024	navkc1 CR 64839 Task 64856
			foreach cashPayment in cash.CM_CashReceipt.allCashPayments discreteLock do
				// If not cash payment then ignore
				if not cashPayment.isProformaPayment() then
					//continue;
				endif;
				
				self.allCashPayments.add(cashPayment);
			endforeach;

		endif;
	endforeach;
	
	
epilog
	delete allDebtors;
	delete allCashReceiptTrx;
	delete allCashTrx;
end;</source>
    </JadeMethod>
    <JadeMethod name="doSearchByCargoID" id="fbb76f6e-26e4-4cd3-9241-6d17fc59ac19">
        <source>doSearchByCargoID(allCashTrx : CM_CashDict input);
/*

Purpose:			This method searches for cash receipt by using Cargo ID;
					It will search from termina.allOnsite and terminal.allActiveVoyage.allOnship

Parameters:			

Return Value:		

Date		Who		Reason
//11/07/2024	navkc1 CR 64839 Task 64856: Jade - Cash REST API getProformaReport

*/

vars
	terminal		: CM_Terminal;
	voyage			: CM_Voyage;
	allActiveVoys	: CM_VoyageSet;
	tiByCEN			: CM_TIByCustomsEntryNumber;
	ti				: CM_TrackedItem;
	iterator		: Iterator;
	sa				: StringArray;
	tisToProcess	: CM_TISet;
	cashPayment		: CM_CashPayment;
	cashReceipt		: CM_CashReceipt;
	allRecProcessed	: CM_CashReceiptSet;
	customsAgent	: CM_CustomsAgent;
	
begin
	create allActiveVoys transient;
	create tiByCEN transient;
	create sa transient;
	create tisToProcess transient;
	create allRecProcessed transient;
	
	terminal := self.myTerminal;
	
	if terminal = null then
		return;
	endif;
	
	self.cargoID.convertToDelimitedArray(Comma, sa);
	
	terminal.getAllCurrentVoyages(allActiveVoys, true, true, true);
	foreach voyage in allActiveVoys do
		voyage.allOnshipTIsByCargoTypeId.copyNoDuplicates(tiByCEN, false);
	endforeach;
	
	terminal.allOnsiteTIsByCargoTypeId.copyNoDuplicates(tiByCEN, false);
	
	iterator := tiByCEN.createIterator();
	
	ti := tiByCEN[self.customsEntryNumber];
	if ti &lt;&gt; null then
		iterator.startAtObject(ti);
	endif;
	
	while iterator.next(ti) do
		if ti.customsEntryNumber &lt;&gt; self.customsEntryNumber then
			break;
		endif;
		
		customsAgent := ti.myCustomsAgent;
		
		if self.customsAgentCode &lt;&gt; null and customsAgent &lt;&gt; null and customsAgent.code &lt;&gt; self.customsAgentCode then
			continue;
		endif;
		
		if sa.isNotEmpty() and sa.indexOf(ti.id) = null then
			continue;
		endif;
		
		tisToProcess.addNoDuplicates(ti, false);
	endwhile;
	
	foreach ti in tisToProcess do
		foreach cashPayment in ti.allCashPayments discreteLock do
			cashReceipt := cashPayment.myCashReceipt;
			
			// Don't check the same cash receipt more than once.
			if allRecProcessed.indexOf(cashReceipt) &lt;&gt; null then
				continue;
			endif;
			allRecProcessed.add(cashReceipt);
			
			if self.includeCashReceiptItem(cashReceipt, null, null) then
				allCashTrx.add(cashReceipt);
			endif;
		endforeach;
	endforeach;
	
epilog
	delete allActiveVoys;
	delete tiByCEN;
	delete iterator;
	delete sa;
	delete tisToProcess;
	delete allRecProcessed;
end;</source>
        <Parameter name="allCashTrx" type="CM_CashDict" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doSearchByExternalInvoiceNum" id="c13ea424-dfc0-44de-86bc-16bb64cdf27a">
        <source>doSearchByExternalInvoiceNum(allCashTrx : CM_CashDict input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
//11/07/2024	navkc1 CR 64839 Task 64856: Jade - Cash REST API getProformaReport

*/

vars
	cashReceipt : CM_CashReceipt;
	bank : CM_Bank;
	iterator	: Iterator;
begin
	
	bank := self.myBusinessUnit;
	
	iterator := bank.allCashReceiptsById.createIterator();
	cashReceipt := bank.allCashReceiptsById[self.externalInvoiceNumber];
	
	if cashReceipt &lt;&gt; null then
		iterator.startAtObject(cashReceipt);
	endif;
	
	while iterator.next(cashReceipt) do
		if cashReceipt.externalInvoiceNumber &lt;&gt; self.externalInvoiceNumber then
			break;
		endif;
		
		if not self.includeCashReceiptItem(cashReceipt, bank, self.myDebtor) then
			continue;
		endif;
		
		allCashTrx.add(cashReceipt);
		
	endwhile;
epilog
	delete iterator;
end;</source>
        <Parameter name="allCashTrx" type="CM_CashDict" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getRawSearchData" id="b7f0864d-3a7c-416c-9536-073d8834258a">
        <source>getRawSearchData(	allCashTrx : CM_CashDict input;
					dr : CM_Debtor;
					term : CM_Terminal;
					startDate : Date;
					endDate : Date;
					startDateIsValid : Boolean;
					endDateIsValid : Boolean;
					useDates : Boolean;
					bankObj : CM_Bank
					) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02/05/2024	navkc1 CR63400 Task 63401: Jade - New REST API getProformaHeadersForDebtor

*/

vars

	drTerm : CM_DebtorTerminal;
	cash : CM_Cash;
	iterExternalNumber,
	iter : Iterator;
	cashReceiptsByDate : CM_CashReceiptDateDict;
	cashReceipt,
	startObjectCR : CM_CashReceipt;
	startTimeStamp : TimeStamp;
begin
	if dr = null or term = null and useDates then
		//very generic date search, will use bank collections in date order, should be quicker than using all drs or all terms
		//dr = null - means any debtor
		//term = null means any terminal
		//bankObj = null means any bank ( business unit )
		self.searchBusUnitDateColls(	allCashTrx,	//allCashTrx : CM_CashDict input;
										dr,	//dr : CM_Debtor;
										term,	//term : CM_Terminal;
										startDate,	//startDate : Date;
										endDate,	//endDate : Date;
										startDateIsValid,	//startDateIsValid : Boolean;
										endDateIsValid,	//endDateIsValid : Boolean;
										bankObj	//bankObj : CM_Bank								
										);
		return;
	endif;
	
	//All non specific searches from here on
	create cashReceiptsByDate transient;
	
	foreach drTerm in dr.allDebtorTerminals do
	
		if term &lt;&gt; null then
			if term &lt;&gt; drTerm.myTerminal then
				continue;
			endif;
		endif;
		
		if not drTerm.allCashReceipts.isEmpty then
			if useDates then
				
				cashReceiptsByDate.clear();
				drTerm.allCashReceipts.copy( cashReceiptsByDate );
				
				iter := cashReceiptsByDate.createIterator();
				if startDateIsValid then
					startTimeStamp.setDate(startDate);
					startTimeStamp.setTime("00:00:00".Time);
					startObjectCR := cashReceiptsByDate.getAtKeyGeq( startTimeStamp );
					if startObjectCR &lt;&gt; null then
						iter.startAtObject( startObjectCR );
					endif;
				endif;
				
				if not startDateIsValid or startObjectCR &lt;&gt; null then
					while iter.next( cash ) do
						if endDateIsValid then
							if cash.dateTime.Date &gt; endDate then
								break;
							endif;
						endif;
						if not self.includeCashReceiptItem( 	cash.CM_CashReceipt,	//cash : CM_CashReceipt;
														bankObj,	//bank : CM_Bank
														dr	//dr : CM_Debtor
														) then
							continue;
						endif;
						allCashTrx.add( cash );
					endwhile;
				endif;
				delete iter;
				
			else
				iter := drTerm.allCashReceipts.createIterator();
				
				// We have a receipt number defined, get that.
				if self.receiptNumber &lt;&gt; null then
					cash := drTerm.allCashReceipts[self.receiptNumber.asIntegerJMT()];
					
					// If no cash receipt found by SequenceNumber, look for External Invoice Number
					if cash = null then
						
						iterExternalNumber := bankObj.allCashReceiptsById.createIterator();
						cashReceipt := bankObj.allCashReceiptsById[self.receiptNumber];
						
						if cashReceipt &lt;&gt; null then
							iterExternalNumber.startAtObject(cashReceipt);
							while iterExternalNumber.next(cashReceipt) do
								if cashReceipt.externalInvoiceNumber &lt;&gt; self.receiptNumber then
									break;
								endif;
								
								if cashReceipt.getDebtor() = self.myDebtor then
									allCashTrx.add(cashReceipt);
								endif;
							endwhile;
						endif;
					else
						if self.includeCashReceiptItem(cash.CM_CashReceipt, bankObj, dr) then
							allCashTrx.add(cash);
						endif;
					endif;
					return;
				endif;
				
				while iter.next( cash ) do
					if not self.includeCashReceiptItem( 	cash.CM_CashReceipt,	//cash : CM_CashReceipt;
													bankObj,	//bank : CM_Bank
													dr	//dr : CM_Debtor
													) then
						continue;
					endif;
					allCashTrx.add( cash );
				endwhile;
				delete iter;
				
			endif;
		endif;
	endforeach;

epilog
	delete iter;
	delete iterExternalNumber;
	delete cashReceiptsByDate;
end;</source>
        <access>protected</access>
        <Parameter name="allCashTrx" type="CM_CashDict" usage="input"/>
        <Parameter name="dr" type="CM_Debtor"/>
        <Parameter name="term" type="CM_Terminal"/>
        <Parameter name="startDate" type="Date"/>
        <Parameter name="endDate" type="Date"/>
        <Parameter name="startDateIsValid" type="Boolean"/>
        <Parameter name="endDateIsValid" type="Boolean"/>
        <Parameter name="useDates" type="Boolean"/>
        <Parameter name="bankObj" type="CM_Bank"/>
    </JadeMethod>
    <JadeMethod name="includeCashReceiptItem" id="2e30d1c5-865e-44f6-8d4f-6a63a66a0ef1">
        <source>includeCashReceiptItem( cash : CM_CashReceipt;
						bank : CM_Bank;
						dr : CM_Debtor
						):Boolean;
/*
Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
02/05/2024	navkc1 CR63400 Task 63401: Jade - New REST API getProformaHeadersForDebtor

*/
vars

begin
	
	//11/07/2024	navkc1 CR 64839 Task 64856
	if cash.paymentStatus &lt;&gt; CM_CashReceipt.API_RECEIPT_FINAL then
		if cash.paymentStatus &lt;&gt; CM_CashReceipt.PAID then  // ### JIRA 34937 23MAY2025 NAVAB1
			return false;
		endif;
	endif;
	
	if bank &lt;&gt; null and cash.CM_CashReceipt.myBank &lt;&gt; bank then
		return false;
	endif;
	if dr &lt;&gt; null and cash.myDebtorTerminal.myDebtor &lt;&gt; dr then
		return false;
	endif;
	if self.receiptNumber &lt;&gt; null and cash.sequenceNum.asStringJMT() &lt;&gt; self.receiptNumber then
		return false;
	endif;
	//8/07/2024	navkc1 CR 64835 Task 64850
	if self.externalRecNumber &lt;&gt; null and cash.externalReceiptNumber &lt;&gt; self.externalRecNumber then
		return false;
	endif;
	
	//11/07/2024	navkc1 CR 64839 Task 64856
	if self.externalInvoiceNumber &lt;&gt; null and cash.externalInvoiceNumber &lt;&gt; self.externalInvoiceNumber then
		return false;
	endif;
	
	return true;

epilog

end;</source>
        <Parameter name="cash" type="CM_CashReceipt"/>
        <Parameter name="bank" type="CM_Bank"/>
        <Parameter name="dr" type="CM_Debtor"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="initialize" id="a5032b94-dcc7-4eb9-a8d8-130b4395ae0c">
        <updating/>
        <source>initialize(	_debtorId : String;
			_bankId : String;
			_terminal : CM_Terminal;
			_fromDate : Date;
			_toDate : Date;
			_receiptNumber : String;
			_includePaymentDetails : Boolean; //8/07/2024	navkc1 CR 64835 Task 64850
			_externalRecNumber : String;	//8/07/2024	navkc1 CR 64835 Task 64850
			_customsEntryNumber : String; //11/07/2024	navkc1 CR 64839 Task 64856
			_customsAgentCode : String; //11/07/2024	navkc1 CR 64839 Task 64856
			_cargoID : String; //11/07/2024	navkc1 CR 64839 Task 64856
			_canSearchByCargo : Boolean; //11/07/2024	navkc1 CR 64839 Task 64856
			_externalInvoiceNumber : String //11/07/2024	navkc1 CR 64839 Task 64856
								) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02/05/2024	navkc1 CR63400 Task 63401: Jade - New REST API getProformaHeadersForDebtor

*/

vars
	terminal		: CM_Terminal;
	bank			: CM_Bank;
	debtor			: CM_Debtor;
	drTerm			: CM_DebtorTerminal;
	debtorNode		: CM_DebtorNode;
	ca				: CM_CustomsAgent;
	cc				: CM_ConsigneeConsignor;
	operator		: CM_Operator;
begin
	self.debtorId := _debtorId;
	self.bankId := _bankId;
	self.fromDate := _fromDate;
	self.toDate := _toDate;
	self.receiptNumber := _receiptNumber;
	self.externalRecNumber := _externalRecNumber; //8/07/2024	navkc1 CR 64835 Task 64850
	self.includePaymentDetails := _includePaymentDetails; //8/07/2024	navkc1 CR 64835 Task 64850
	self.customsEntryNumber := _customsEntryNumber; //11/07/2024	navkc1 CR 64839 Task 64856
	self.customsAgentCode := _customsAgentCode; //11/07/2024	navkc1 CR 64839 Task 64856
	self.cargoID := _cargoID; //11/07/2024	navkc1 CR 64839 Task 64856
	self.canSearchByCargoID := _canSearchByCargo; //11/07/2024	navkc1 CR 64839 Task 64856
	self.externalInvoiceNumber := _externalInvoiceNumber; //11/07/2024	navkc1 CR 64839 Task 64856
	terminal := _terminal;
	
	// Get Terminal
	if terminal &lt;&gt; null then
		self.myTerminal := terminal;
		
		// Set config
		self.myCashDebtorType := terminal.getConfig(CashDebtorType).CM_DebtorType;
		
		// Get Bank
		bank := terminal.companies[self.bankId];
		
		if bank &lt;&gt; null then
			self.myBusinessUnit := bank;
		else
			self.myBusinessUnit := terminal.getDefaultCompanyBank();
		endif;
		
		// Get Debtor
		// We have Customs Agent Code and Cash Debtor type defined, get Debtor from the custome agent code.
		//11/07/2024	navkc1 CR 64839 Task 64856
		if _customsAgentCode &lt;&gt; null and self.myCashDebtorType &lt;&gt; null then
			if self.myCashDebtorType.code = "SDT2" then
				// Consignee
				cc := app.myRoot.allConsigneeConsignors[_customsAgentCode];
				if cc &lt;&gt; null and cc.isConsignee then
					//self.myDebtorAgent := cc;
					debtor := cc.debtor;
				endif;
			elseif self.myCashDebtorType.code = "SDT3" then
				// Consignor
				cc := app.myRoot.allConsigneeConsignors[_customsAgentCode];
				if cc &lt;&gt; null and cc.isConsignor then
					//self.myDebtorAgent := cc;
					debtor := cc.debtor;
				endif;
			elseif self.myCashDebtorType.code = "SDT4" then
				// Votyage operator
				operator := app.myRoot.allOperators[_customsAgentCode];
				if operator &lt;&gt; null then
					//self.myDebtorAgent := operator;
					debtor := operator.debtor;
				endif;
			elseif self.myCashDebtorType.code = "SDT6" then
				// Customs Agent
				ca := app.myRoot.allCustomsAgents[_customsAgentCode];
				if ca &lt;&gt; null then
					//self.myDebtorAgent := ca;
					debtor := ca.myDebtor;
				endif;
			elseif self.myCashDebtorType.code = "SDT7" then
				// Freight Forwarder
				cc := app.myRoot.allConsigneeConsignors[_customsAgentCode];
				if cc &lt;&gt; null and cc.isFreightFwdr then
					//self.myDebtorAgent := cc;
					debtor := cc.debtor;
				endif;
			// ### TFS CR 65810 TASK 65811 27AUG2024 NAVAB1
			elseif self.myCashDebtorType.code = "SDT1" then
				// Cargo Operator
				operator := app.myRoot.allOperators[_customsAgentCode];
				if operator &lt;&gt; null  then
					debtor := operator.debtor;
				endif;
			endif;
			
			self.myDebtor := debtor;
		else
			foreach drTerm in terminal.allDebtorTerminals do
				debtor := drTerm.myDebtor;
				
				if not drTerm.isCashOnly or debtor = null then
					continue;
				endif;
				
				if debtor.code &lt;&gt; null and debtor.code = self.debtorId then
					self.myDebtor := debtor;
					break;
				endif;
			endforeach;
		endif;
		
	endif;
	
	// If Terminal is null, get Debtor from Root
	if terminal = null and debtor = null then
		foreach debtorNode in app.myRoot.myRootCompany.debtors where not debtorNode.isSuspended do
			if not debtorNode.isKindOf(CM_Debtor) then
				continue;
			endif;
			
			debtor := debtorNode.CM_Debtor;
			
			if debtor.code &lt;&gt; null and debtor.code = self.debtorId then
				self.myDebtor := debtor;
				break;
			endif;
		endforeach;
	endif;
	
	// NAVKC1 22/05/2024 - Defect 64230
	if self.myDebtor = null then //11/07/2024	navkc1 CR 64839 Task 64856
		// If we can search by Cargo, then it's fine if the debtor is null
		// but if the Cargo ID is also null, then we raise an error
		//11/07/2024	navkc1 CR 64839 Task 64856
		if self.canSearchByCargoID then
			if self.externalInvoiceNumber = null and self.customsEntryNumber = null then 
				app.raiseCMException(Debto_found_cargo_enter_unabl_, null, null);
			endif;
		else
			app.raiseCMException(Debto_found_pleas_enter_valid_, null, null);
		endif;
	endif;
epilog

end;</source>
        <Parameter name="_debtorId" type="String"/>
        <Parameter name="_bankId" type="String"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_fromDate" type="Date"/>
        <Parameter name="_toDate" type="Date"/>
        <Parameter name="_receiptNumber" type="String"/>
        <Parameter name="_includePaymentDetails" type="Boolean"/>
        <Parameter name="_externalRecNumber" type="String"/>
        <Parameter name="_customsEntryNumber" type="String"/>
        <Parameter name="_customsAgentCode" type="String"/>
        <Parameter name="_cargoID" type="String"/>
        <Parameter name="_canSearchByCargo" type="Boolean"/>
        <Parameter name="_externalInvoiceNumber" type="String"/>
    </JadeMethod>
    <JadeMethod name="searchBusUnitDateColls" id="7e04f2e9-091f-4d6e-abae-d64c4a67add8">
        <source>searchBusUnitDateColls(	allCashTrx : CM_CashDict input;
						selectedDebtor : CM_Debtor;
						selectedTerminal : CM_Terminal;
						startDate : Date;
						endDate : Date;
						startDateIsValid : Boolean;
						endDateIsValid : Boolean;
						bankObj : CM_Bank
						);
/*
Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
02/05/2024	navkc1 CR63400 Task 63401: Jade - New REST API getProformaHeadersForDebtor

*/
vars

	allBanks : CM_BankSet;
	bank : CM_Bank;
	debtorTerminal : CM_DebtorTerminal;
	term : CM_Terminal;
	iter : Iterator;
	cash : CM_Cash;
	startObjectCR : CM_CashReceipt;
	startTimeStamp : TimeStamp;	
	allDebtorTerminals : CM_DebtorTerminalSet;
	terms : CM_TerminalByCodeDict;

begin
	//selectedDebtor = null, means any debtor
	//term = null, means any terminal
	//bankObj = null, means any bank ( business unit )
	
	if startDateIsValid then
		startTimeStamp.setDate(startDate);
		startTimeStamp.setTime("00:00:00".Time);
	endif;
	
	create terms transient;
	app.getMyUser.getTerminals(terms);
	
	//Will be using bank collections for cash receipts, so find the Banks first..
	create allBanks transient;
	
	if bankObj &lt;&gt; null then
		allBanks.add( bankObj );
	elseif selectedTerminal &lt;&gt; null then
		//just terminal based get the associated BUs
		foreach bank in selectedTerminal.companies where bank.isBusinessUnit do
			allBanks.add( bank );
		endforeach;
	elseif selectedDebtor &lt;&gt; null then
		//just debtor based, find his terminals and then associated BUs
		foreach debtorTerminal in selectedDebtor.allDebtorTerminals do
			term := debtorTerminal.myTerminal;
			if not terms.includes( term ) then
				continue;
			endif;
			foreach bank in term.companies where bank.isBusinessUnit do
				allBanks.add( bank );
			endforeach;
		endforeach;
	else
		//completely open	
		foreach term in terms do
			foreach bank in term.companies where bank.isBusinessUnit do
				allBanks.add( bank );
			endforeach;
		endforeach;
	endif;

	//Use the banks we found to get the Cash Receipts	
	foreach bank in allBanks do
	
		iter := bank.allCashReceipts.createIterator();
		if startDateIsValid then
			startObjectCR := bank.allCashReceipts.getAtKeyGeq( startTimeStamp );
			if startObjectCR &lt;&gt; null then
				iter.startAtObject( startObjectCR );
			endif;
		endif;
		
		if not startDateIsValid or startObjectCR &lt;&gt; null then
			while iter.next( cash ) do
				if endDateIsValid then
					if cash.dateTime.Date &gt; endDate then
						break;
					endif;
				endif;
				
				if cash.CM_CashReceipt.myTerminal = null then
					//WTF! This happened in testing, probably crap data in DMAST 
					continue;
				endif;
				if not includeCashReceiptItem( 	cash.CM_CashReceipt,	//cash : CM_CashReceipt;
												bankObj,				//bank : CM_Bank
												selectedDebtor			//dr : CM_Debtor
												) then
					continue;
				endif;
				allCashTrx.add( cash );
			endwhile;
		endif;
		delete iter;
	
	endforeach;
	
epilog

	delete allBanks;
	delete allDebtorTerminals;
	delete iter;
	delete terms;

end;</source>
        <Parameter name="allCashTrx" type="CM_CashDict" usage="input"/>
        <Parameter name="selectedDebtor" type="CM_Debtor"/>
        <Parameter name="selectedTerminal" type="CM_Terminal"/>
        <Parameter name="startDate" type="Date"/>
        <Parameter name="endDate" type="Date"/>
        <Parameter name="startDateIsValid" type="Boolean"/>
        <Parameter name="endDateIsValid" type="Boolean"/>
        <Parameter name="bankObj" type="CM_Bank"/>
    </JadeMethod>
</Class>
