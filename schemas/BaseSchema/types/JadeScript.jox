    <JadeMethod name="test_NOF" id="8371c5d2-0cbc-46d2-8d4b-f1e2fc5b8d85">
        <updating/>
        <source>test_NOF() updating;

constants

	STX   =   #"02";
	ETX   =   #"03"; 

vars

	blnCheckForETX	:	 Boolean;
	blnCheckForMessage : Boolean;
	blnCheckForSTX 	: Boolean;

	strMessage		: String;
	strHoldBuffer	: String;
	intETXpos		: Integer;
	intSTXpos		: Integer;	
	intMsgLength	: Integer;

	readBuffer  : String;	


begin

	// set up read buffer here


	readBuffer := (STX &amp; "ABCDEFGHI" &amp; ETX &amp; ETX &amp; "AAA" &amp; STX &amp; ETX &amp; "!@#$%"  &amp; STX &amp; "004601APPLID0001LD&lt;&lt;This is the ispec data&gt;&gt;" &amp; ETX);
//	readBuffer := (STX);

	write ("*** at start *** " &amp; readBuffer);
	write ("Length = " &amp; readBuffer.length.String); 

    blnCheckForMessage := true;

	while blnCheckForMessage do
		blnCheckForSTX := true;

		while blnCheckForSTX do

        	// find out where the first STX is in the buffer

        	intSTXpos := readBuffer.pos(STX,1);

			// if there is no STX then hop out of here       	

        	if intSTXpos =  0 then
        		return ;
      		elseif intSTXpos =  1 then
      			break;   // we have found our STX
      		else 

      			// this means that there is data here before the STX
      			// so we will log and drop this data


    			write("Data received before STX" &amp; readBuffer[1:(intSTXpos -1)]);


				strHoldBuffer := readBuffer[intSTXpos : end];
				readBuffer := strHoldBuffer;
				break;

			endif;
		endwhile; // of checking for an STX

		// so now we have an STX .....if this is the only character then its not worth
		// doing any more 

		if readBuffer.length &lt; 2 then 
			return;
		endif;

		blnCheckForETX  := true;

		while blnCheckForETX do
			intETXpos := readBuffer.pos(ETX,1);
			intSTXpos := readBuffer.pos(STX,2);  	// skip over the first one 

			// check here to see if we have another STX  (before the ETX if one exists)

			if ( (intETXpos &lt;&gt; 0) and ((intSTXpos &lt;&gt; 0) and (intSTXpos &lt; intETXpos)) )
			or ( (intETXpos = 0) and (intSTXpos &lt;&gt; 0))     then

				// we have another STX  ... we need to log, drop and start again

   				write("STX with no ETX" &amp; readBuffer[1:(intSTXpos -1)]);


				strHoldBuffer := readBuffer[intSTXpos : end];
				readBuffer := strHoldBuffer;
				break;

			endif;  // of having another STX  

            // if we have an ETX then we have a 'message' as such .... otherwise
            // we have nothing more than the original STX... so we return with 
            // no message 

			if intETXpos  = 0 then 
				return;
			else

				// we have a message as such

				strMessage := readBuffer[1:intETXpos];

				if readBuffer.length &gt; intETXpos then
					strHoldBuffer := readBuffer[(intETXpos + 1) : end];
					readBuffer := strHoldBuffer;
				else
					readBuffer := null;
					blnCheckForMessage := false;  // no point checking any more if there is a problem
				endif;                           // with this message

				if strMessage.length &lt; 6 then 
					// we dont even have enough here for a valid message length


   					write("Message too short to include header" &amp; strMessage);


					break; // so we can start again looking for another message
   				endif;

   				// now check to see that the data length matches that in the header


   				if strMessage.length &lt;&gt; strMessage[2:4].Integer  then 

   					write("Length doesnt match header Length" &amp; strMessage);
   					strMessage := null;


					break; // so we can start again looking for another message
   				endif;
   					// okay  ... so we have a valid length message .......so lets return this
       				// 

       				return ;

			endif; // of having an ETX

		endwhile;  // of checking for an ETX 
	endwhile;	// of checking for a message

	// if we are here then we havent had a valid message and there is no more
	// data to process

	return;


epilog

	write " **** at the end *********";
	write ("strMessage = " &amp; strMessage);
	write ("readBuffer = " &amp; readBuffer);


end;</source>
    </JadeMethod>
    <JadeMethod name="z_cnwdad1_SetFont" id="87eeaac8-3062-4e84-abba-578d6a99d2ad">
        <source>z_cnwdad1_SetFont() protected;
// --------------------------------------------------------------------------------
// Created:		22 March 2006 by cnwdad1
//
// Purpose:     Sets the default font on all instances of the Application class for
//				apps that are in BaseSchema and below.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	applicationObj	: Application;
	schemaObj		: Schema;

begin
	foreach applicationObj in Application.instances do
		schemaObj	:=	applicationObj.getPropertyValue(Application::schema.name).Schema;
		
		if schemaObj = currentSchema or schemaObj.cnEcIsSubschemaOf(currentSchema) then
			write applicationObj.name &amp; Tab &amp; applicationObj.getPropertyValue(Application::schema.name).Schema.name;
			beginTransaction;
			applicationObj.fontName	:=	'Verdana';
			commitTransaction;
		endif;	

	endforeach;
end;</source>
        <access>protected</access>
    </JadeMethod>
</Class>
