Specifies the definition of a table.</text>
    <DbClassMap file="basehtml"/>
    <ExplicitInverseRef name="allRows" id="1deebd56-2e4b-431e-ab3c-7fc79b9e1582">
        <kind>parent</kind>
        <updateMode>automatic</updateMode>
        <type name="CnEcHtmlTableRowTagArray"/>
        <access>readonly</access>
        <text>Contains a set of all Table Row objects for this table.  Note that table
rows may also be created independantly of a table, which therefore will
not have a reference to any table object.</text>
        <Inverse name="CnEcHtmlTableRowTag::myTable"/>
    </ExplicitInverseRef>
    <PrimAttribute name="tableBorderWidth" id="6533c4e6-6c3f-4a01-8f97-03eef3d2b6b2">
        <embedded/>
        <type name="Integer"/>
        <text>Specifies the size, in pixels, of a border to be drawn around all cells in the table.</text>
    </PrimAttribute>
    <PrimAttribute name="tableCaption" id="18867879-4df7-4b28-9036-34bf9a9e8548">
        <type name="String"/>
        <text>Identitifies the caption for the table.  If this property is not
null, then a &lt;CAPTION&gt; tag will be generated for the tables HTML.</text>
    </PrimAttribute>
    <PrimAttribute name="tableCaptionAlign" id="43e2aab5-bf70-414b-9d84-b3dd1bd04938">
        <length>31</length>
        <embedded/>
        <type name="String"/>
        <access>readonly</access>
        <text>Specifies that the table's caption is aligned to the LEFT, CENTER or
RIGHT of the table.</text>
    </PrimAttribute>
    <PrimAttribute name="tableCaptionVAlign" id="9a0b90d0-67ea-4ead-8020-da4386b6256d">
        <length>31</length>
        <embedded/>
        <type name="String"/>
        <access>readonly</access>
        <text>Specifies that the table's caption should appear at the TOP or
BOTTOM of the table.</text>
    </PrimAttribute>
    <PrimAttribute name="tableCellPadding" id="56724033-ed81-4144-8bdb-d6169d8a6b29">
        <embedded/>
        <type name="Integer"/>
        <text>Specifies that amount of space, in pixels, between the cell wall an
its contents on all sides.</text>
    </PrimAttribute>
    <PrimAttribute name="tableCellSpacing" id="0fb1300f-4803-41e7-b1cd-7bd89b7542cf">
        <embedded/>
        <type name="Integer"/>
        <text>Specifies that amount of space, in pixels, between cells.</text>
    </PrimAttribute>
    <PrimAttribute name="tableColumns" id="5fff87a6-55c1-4b4c-8e7c-2c2aab8dae52">
        <embedded/>
        <type name="Integer"/>
        <text>Specifies the number of columns in the table.</text>
    </PrimAttribute>
    <PrimAttribute name="tableFrame" id="a2d86026-35d6-47df-b92a-07344ae13936">
        <length>31</length>
        <embedded/>
        <type name="String"/>
        <access>readonly</access>
        <text>Specifies which of the outside borders of a table are displayed - VOID (none),
ABOVE (only the top), BELOW (only the bottom), HSIDES (horizontal sides),
VSIDES (vertical sides), LHS (left-hand side), RHS (right-hand side) and
BOX (all).</text>
    </PrimAttribute>
    <PrimAttribute name="tableRule" id="5ad0bed4-2726-46d2-9c35-5675cdae36ee">
        <length>31</length>
        <embedded/>
        <type name="String"/>
        <access>readonly</access>
        <text>Specifies which if the inside borders of a table are displayed - NONE,
BASIC (horizontal rules between the heading, body and footer sections),
ROWS, COLS and ALL.</text>
    </PrimAttribute>
    <JadeMethod name="buildTagBody" id="a8361e9c-4edc-467d-8428-00c86cfb0774">
        <source>buildTagBody(): String protected;
// --------------------------------------------------------------------------------
// Created:		02 December 2001 by cnwdad1
//
// Purpose:		Refer to the CnEcHtmlTagObject implementation.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	htmlString	: String;
	tableRowObj	: CnEcHtmlTableRowTag;

begin
	// Build the opening table tag.

	htmlString	:=	' BORDER="' &amp; self.tableBorderWidth.String &amp; '"' &amp;
					' CELLPADDING="' &amp; self.tableCellPadding.String &amp; '"' &amp;
					' CELLSPACING="' &amp; self.tableCellSpacing.String &amp; '"';

	if self.tableColumns &lt;&gt; 0 then
		htmlString	:=	htmlString &amp; ' COLS="' &amp; self.tableColumns.String &amp; '"';
	endif;

	if self.tableFrame &lt;&gt; null then
		htmlString	:=	htmlString &amp; ' FRAME="' &amp; self.tableFrame &amp; '"';
	endif;

	if self.tableRule &lt;&gt; null then
		htmlString	:=	htmlString &amp; ' RULES="' &amp; self.tableRule &amp; '"';
	endif;

	if self.tableWidth &lt;&gt; null then
		htmlString	:=	htmlString &amp; ' WIDTH="' &amp; self.tableWidth &amp; '"';
	endif;

	htmlString	:=	htmlString &amp; inheritMethod() &amp; '&gt;';

	// Add the table's Caption tag (if specified).

	if self.tableCaption &lt;&gt; null then
		htmlString	:=	htmlString &amp; '&lt;CAPTION ALIGN="' &amp; self.tableCaptionAlign &amp; '"';

		if self.tableCaptionVAlign &lt;&gt; null then
			htmlString	:=	htmlString &amp; ' VALIGN="' &amp; self.tableCaptionVAlign &amp; '"';
		endif;

		htmlString	:=	htmlString &amp; '&gt;' &amp; self.tableCaption &amp; '&lt;/CAPTION&gt;';
	endif;

	// Now add the table's rows.

	foreach tableRowObj in self.allRows do
		htmlString	:=	htmlString &amp; tableRowObj.getHtml;
	endforeach;

	return htmlString;
end;</source>
        <access>protected</access>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="clearRows" id="395982e2-66f5-4b8c-ba62-919ffa28c530">
        <updating/>
        <source>clearRows() updating;
// --------------------------------------------------------------------------------
// Created:		02 May 2000 by cnwdad2
//
// Purpose:		Deletes all of the receiver's table row tag objects.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.allRows.purge();
end;</source>
    </JadeMethod>
    <JadeMethod name="createRow" id="6284c05c-6976-495e-9064-064f7314dc01">
        <source>createRow():CnEcHtmlTableRowTag;
// --------------------------------------------------------------------------------
// Created:		29 April 2000 by cnwdad1
//
// Purpose:		Creates a table row tag object.
//
// Parameters:	None
//
// Returns:		The newly created table row tag object.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	tableRowObj	: CnEcHtmlTableRowTag;

begin
	create tableRowObj transient;
	tableRowObj.setTable(self);
	
	return tableRowObj;
end;</source>
        <ReturnType type="CnEcHtmlTableRowTag"/>
    </JadeMethod>
    <JadeMethod name="getHtml" id="72d77bfb-2402-44e7-8e97-e1ba971b965d">
        <source>getHtml(): String;
// --------------------------------------------------------------------------------
// Created:		29 April 2000 by cnwdad1
//
// Purpose:		Refer to the CnEcHtmlTagObject implementation.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return '&lt;TABLE ' &amp; self.buildTagBody() &amp; CrLf &amp; '&lt;/TABLE&gt;' &amp; CrLf;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="isValidAlign" id="e1eabb26-490a-4526-b437-9b0e58fd353d">
        <source>isValidAlign(pAlign: String): Boolean protected;
// --------------------------------------------------------------------------------
// Created:		29 April 2000 by cnwdad1
//
// Purpose:		Validates the receiver's alignment setting.
//
// Parameters:	pAlign - The receiver's alignment setting.
//
// Returns:		True if the alignment setting is valid, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if pAlign = self.ALIGN_LEFT
	or pAlign = self.ALIGN_RIGHT
	then
		return true;
	else
		CnEcBaseHtmlException.raise_(CNEC_X_22000, '"' &amp; pAlign &amp; '" is not a valid Table tag alignment');
	endif;

	return false;
end;</source>
        <access>protected</access>
        <Parameter name="pAlign" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isValidCaptionAlign" id="c84e74a5-327d-4e89-b126-0b170759333e">
        <source>isValidCaptionAlign(pAlign:String):Boolean protected;
// --------------------------------------------------------------------------------
// Created:		29 April 2000 by cnwdad1
//
// Purpose:		Validates the receiver's caption alignment setting.
//
// Parameters:	pAlign - The receiver's caption alignment setting.
//
// Returns:		True if the caption alignment setting is valid, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if pAlign = self.ALIGN_LEFT
	or pAlign = self.ALIGN_CENTER
	or pAlign = self.ALIGN_RIGHT
	then
		return true;
	else
		CnEcBaseHtmlException.raise_(CNEC_X_22000, '"' &amp; pAlign &amp; '" is not a valid Table tag caption alignment');
	endif;

	return false;
end;</source>
        <access>protected</access>
        <Parameter name="pAlign" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isValidCaptionVAlign" id="9e8c325a-e007-436e-8251-b40372747858">
        <source>isValidCaptionVAlign(pVAlign: String): Boolean protected;
// --------------------------------------------------------------------------------
// Created:		29 April 2000 by cnwdad1
//
// Purpose:		Validates the receiver's caption vertical alignment setting.
//
// Parameters:	pAlign - The receiver's caption vertical alignment setting.
//
// Returns:		True if the caption vertical alignment setting is valid, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if pVAlign = self.ALIGN_TOP
	or pVAlign = self.ALIGN_BOTTOM
	then
		return true;
	else
		CnEcBaseHtmlException.raise_(CNEC_X_22000, '"' &amp; pVAlign &amp; '" is not a valid Table tag vertical caption alignment');
	endif;

	return false;
end;</source>
        <access>protected</access>
        <Parameter name="pVAlign" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isValidFrame" id="6f700c2e-0ed3-48e7-b8ca-12c502b3d85d">
        <source>isValidFrame(pFrame:String):Boolean protected;
// --------------------------------------------------------------------------------
// Created:		29 April 2000 by cnwdad1
//
// Purpose:		Validates the receiver's frame setting.
//
// Parameters:	pFrame - The receiver's frame setting.
//
// Returns:		True if the frame setting is valid, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if pFrame = self.FRAME_ABOVE
	or pFrame = self.FRAME_BELOW
	or pFrame = self.FRAME_BORDER
	or pFrame = self.FRAME_BOX
	or pFrame = self.FRAME_HSIDES
	or pFrame = self.FRAME_LHS
	or pFrame = self.FRAME_RHS
	or pFrame = self.FRAME_VOID
	or pFrame = self.FRAME_VSIDES
	then
		return true;
	else
		CnEcBaseHtmlException.raise_(CNEC_X_22004, '"' &amp; pFrame &amp; '" is not a valid Table tag Frame');
	endif;

	return false;
end;</source>
        <access>protected</access>
        <Parameter name="pFrame" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isValidRule" id="106a1c21-8f3f-4641-b65b-826e49c2e797">
        <source>isValidRule(pRule:String):Boolean protected;
// --------------------------------------------------------------------------------
// Created:		29 April 2000 by cnwdad1
//
// Purpose:		Validates the receiver's rule setting.
//
// Parameters:	pRule - The receiver's rule setting.
//
// Returns:		True if the rule setting is valid, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if pRule = self.RULE_ALL
	or pRule = self.RULE_BASIC
	or pRule = self.RULE_COLS
	or pRule = self.RULE_NONE
	or pRule = self.RULE_ROWS
	then
		return true;
	else
		CnEcBaseHtmlException.raise_(CNEC_X_22005, '"' &amp; pRule &amp; '" is not a valid Table tag rule');
	endif;

	return false;
end;</source>
        <access>protected</access>
        <Parameter name="pRule" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setTableCaptionAlign" id="da3fc6a9-8e05-412b-9e08-b1dc8e72ff31">
        <updating/>
        <source>setTableCaptionAlign(pCaptionAlign:String) updating;
// --------------------------------------------------------------------------------
// Created:		02 May 2000 by cnwdad2
//
// Purpose:		Set the receiver's caption alignment setting.
//
// Parameters:	pCaptionAlign - The caption alignment setting.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if self.isValidCaptionAlign(pCaptionAlign) then
		self.tableCaptionAlign	:=	pCaptionAlign;
	endif;
end;</source>
        <Parameter name="pCaptionAlign" type="String"/>
    </JadeMethod>
    <JadeMethod name="setTableCaptionVAlign" id="264190c8-0420-4326-a3d4-3c286abede3d">
        <updating/>
        <source>setTableCaptionVAlign(pCaptionVAlign:String) updating;
// --------------------------------------------------------------------------------
// Created:		02 May 2000 by cnwdad2
//
// Purpose:		Set the receiver's catpion vertical alignment setting.
//
// Parameters:	pCaptionVAlign - The caption vertical alignment setting.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if self.isValidCaptionVAlign(pCaptionVAlign) then
		self.tableCaptionVAlign	:=	pCaptionVAlign;
	endif;
end;</source>
        <Parameter name="pCaptionVAlign" type="String"/>
    </JadeMethod>
    <JadeMethod name="setTableFrame" id="002a7d25-a05b-443a-8adf-245425699957">
        <updating/>
        <source>setTableFrame(pFrame:String) updating;
// --------------------------------------------------------------------------------
// Created:		02 May 2000 by cnwdad2
//
// Purpose:		Set the receiver's table frame.
//
// Parameters:	pFrame - The table frame setting.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if self.isValidFrame(pFrame) then
		self.tableFrame		:=	pFrame;
	endif;
end;</source>
        <Parameter name="pFrame" type="String"/>
    </JadeMethod>
    <JadeMethod name="setTableRule" id="a42661ef-57fc-40eb-b0d5-86843b0032ee">
        <updating/>
        <source>setTableRule(pRule:String) updating;
// --------------------------------------------------------------------------------
// Created:		02 May 2000 by cnwdad2
//
// Purpose:		Set the receiver's table rule.
//
// Parameters:	pRule - The table rule.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if self.isValidRule(pRule) then
		self.tableRule		:=	pRule;
	endif;
end;</source>
        <Parameter name="pRule" type="String"/>
    </JadeMethod>
</Class>
