    <JadeMethod name="canUpdateTransaction" id="41e64654-5aa2-4157-bedb-98c90d327bdc">
        <source>canUpdateTransaction(): Boolean;
// ---------------------------------------------------------------------------
// Created:     02 September 2003	cnwth2
