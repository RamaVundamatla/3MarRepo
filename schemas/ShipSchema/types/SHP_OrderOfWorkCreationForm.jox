    <JadeMethod name="doMnuOOWShowBayClick" id="43964259-cdfc-4d20-bd68-e464a73f15dc">
        <updating/>
        <source>doMnuOOWShowBayClick(menuItem: MenuItem input) updating;
// ---------------------------------------------------------------------------
// Created:		04 May 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	disMode : Integer;
	oow		: CM_OOWCreation;
begin
	oow := menuItem.userObject.CM_OOWCreation;

	if oow = null then
		return;
	endif;
		
	if oow.myBay = null then
		return;
	endif;
		
	if oow.isDischarge() then
		disMode := ShpDisplayMode_ColCodeDisch;
	elseif oow.isLoad() then
		disMode := ShpDisplayMode_ColCodeLoad;
	else
		disMode := ShpDisplayMode_Actual;
	endif;
	self.myAssistant.SHP_Assistant.showVoyagePlanningForm(self.myCurrentVoyage, oow.myBay, disMode, self.myMasterMenuAction);


end;</source>
        <Parameter name="menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doMoveControlsForLargeCaptions" id="c84bbd29-603c-4efc-984b-312c3e981f3e">
        <updating/>
        <source>doMoveControlsForLargeCaptions() updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 25/09/2017		jlgdap1		Initial creation TFS 7009 JMT Fix display with large toolbar icons
//
vars

begin
	if self.frmToolbar.showCaptions then
		self.frmToolbarChk.top := 35;  // ### TFS 50421 27OCT2021 NAVAB1 24;
		self.frmToolbarChk.left := self.frmTBExtras.left;
		self.frmToolbarChk.height := 48;
		self.frmToolbarChk.width := self.chkShipTLHeight.width;
		self.chkShipTLHeight.top := 24;
		self.chkShipTLHeight.left := 0;
		self.chkShipTLWeight.left := 0;
		self.frmTBExtras.height := 24;
	else
		self.frmToolbarChk.top := 10; // ### TFS 50421 27OCT2021 NAVAB1 0;
		self.frmToolbarChk.left := self.frmTBExtras.left + self.frmTBExtras.width;
		self.frmToolbarChk.width := self.chkShipTLHeight.width + self.chkShipTLWeight.width;
		self.chkShipTLHeight.top := self.chkShipTLWeight.top;
		self.chkShipTLHeight.left := self.chkShipTLWeight.left + self.chkShipTLWeight.width;
		self.frmTBExtras.height := 24;
	endif;
	self.frmToolbarChk.visible := true;
	self.fldJobs.top:=self.frmHeading.top+self.frmHeading.clientHeight + 1;
	self.fldJobs.height:=self.clientHeight - (self.staStatusBar.clientHeight + self.fldJobs.top +8 );
epilog

end;</source>
    </JadeMethod>
