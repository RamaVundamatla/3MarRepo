    <JadeMethod name="validateMe" id="ccabbfd1-67d0-4806-be0a-91526e4adde7">
        <source>validateMe() protected;
// ---------------------------------------------------------------------------
// Created:     16 July 2001 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin
	if self.code = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Country Code', null, null);
		app.raiseCMException(Input_required_field_contCode, null, null); // cnwdb2	PAR 35364
	endif;
	if self.description = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Country Description', null, null);
		app.raiseCMException(Input_required_field_contDesc, null, null);// cnwdb2	PAR 35364
	endif;
	if self.code.length &gt; 2 then
		app.raiseCMException2(ERR_STRING_TO_LONG, 'Country Code', "2" , null, null);
	endif;

end;</source>
        <access>protected</access>
    </JadeMethod>
</Class>
