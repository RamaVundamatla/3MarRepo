    <JadeMethod name="validateForCreate" id="5e7ea67d-4b86-4ffa-b8e3-4415b6882de0">
        <source>validateForCreate();

// cnwdvb1 07 April 2003 

vars

begin
	inheritMethod();
	if self.myMachine = null then
		return;	//Its ok to remove the device.
	endif;
	if self.myMachine.myRTDevice &lt;&gt; null  then 
		app.raiseCMException2(ERR_DUPLICATE_CHILD, 'Machine ' &amp; self.myMachine.id, 'RT Device ' &amp; self.myMachine.myRTDevice.id, null, null);
	endif;

end;</source>
    </JadeMethod>
    <JadeMethod name="validateForDelete" id="e40af3e9-049c-47b2-ae9e-4dbece62b4e4">
        <source>validateForDelete();

/*

Purpose:			

Parameters:			

Return Value:		


Date			Who		Reason
11 July 2019	jlgns1	Initial creation
11/07/2019 		JLGNS1	Bug 45454: SPT - Error 4 in JMTUserInterfaceService machineGetControlMessages
*/

vars
	machine : CM_Machine;
	gotException	:Boolean;
begin
	inheritMethod();
	on Exception do app.handleDeletedObject (exception, machine, gotException);
	
	machine := self.myMachine;
	//Machine should always be valid at this stage, but...
	if machine &lt;&gt; null and machine.loggedOn then
		if gotException then
			return;
		endif;
		app.raiseCMException2(Radio_telem_devic_loggeed_on, self.id, machine.id, 'loggedOn', null);
	endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="validateForUpdate" id="a509d92d-5f47-420e-85d4-05f152b783fe">
        <source>validateForUpdate();

// cnwdvb1 07 April 2003 

vars

begin
	inheritMethod();
	if self.myMachine = null then
		return;	//Its ok to remove the device.
	endif;
	if self.myMachine.myRTDevice &lt;&gt; null and self.myMachine.myRTDevice &lt;&gt; self.pxyGetRealObject() then 
		app.raiseCMException2(ERR_DUPLICATE_CHILD, 'Machine ' &amp; self.myMachine.id, 'RT Device ' &amp; self.myMachine.myRTDevice.id, null, null);
	endif;

end;</source>
    </JadeMethod>
    <JadeMethod name="validateMe" id="7d4c2779-d1ac-4423-b45a-9e8548970775">
        <source>validateMe() protected;

// cnwdvb1 07 April 2003 

vars

begin

	inheritMethod();
	
	if self.myMachine = null then
		return;	//Its nbow quite ok for a device to NOT have a mchine for some reason.
	endif;	
	if not self.myMachine.hasRadioTelemetry then
		app.raiseCMException1(ERR_MACH_NO_RT, self.myMachine.id, null, null);
	endif;
	

end;</source>
        <access>protected</access>
    </JadeMethod>
</Class>
