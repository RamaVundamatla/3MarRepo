    <JadeMethod name="canDo" id="515d93e2-6218-4768-bc7a-2383e727546f">
        <source>canDo(_doWhat : Integer) : Boolean;
// ---------------------------------------------------------------------------
// Created:     16 July 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	if _doWhat &gt; Mod_BaseView then
		// belts and braces - should never happen
		return false;
	endif;

	if self.permissions.size &lt; _doWhat then
		return false;
	endif;

	return self.permissions[_doWhat];

end;</source>
        <Parameter name="_doWhat" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
