    <JadeMethod name="tblDeckItems_contextMenu" id="4e92cad0-f65e-44f2-9063-9f988ba68ead">
        <controlMethod name="Table::contextMenu"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblDeckItems_contextMenu(table: Table input; conwin: Window input; mouse: Boolean; x: Integer; y: Integer):Boolean updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
15 April 2011	cnwer1	Initial creation CCMS 1031

*/

vars
	xLeft 	: Real;
	yTop	: Real;
	deckItem : CM_DeckItem;
begin

	xLeft := x;
	yTop := y;


	conwin.windowToScreen(xLeft, yTop);
	self.screenToWindow(xLeft, yTop);   // convert x, y relative to form

	self.mnuDeckItemAudits.visible:=false;
	if table.row &gt; 1 and table.accessRow(table.row) &lt;&gt; null then
		deckItem:=table.accessRow(table.row).itemObject.CM_DeckItem;
		self.mnuDeckItemAudits.visible:= deckItem.hasAudits; //14 Jan 2021	NDL	TFS 50152
	endif;
	
	self.popupMenu(self.mnuDeckItems, xLeft.Integer, yTop.Integer);

	return false;

epilog

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="conwin" type="Window" usage="input"/>
        <Parameter name="mouse" type="Boolean"/>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="tblDeckItems_dblClick" id="48d3a3d8-a9e8-40ed-912a-d26e44ac1215">
        <controlMethod name="CM_DataTable::dblClick"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblDeckItems_dblClick(table: Table input) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
14 April 2011	cnwer1	Initial creation CCMS 1031

*/

vars

	deckItem : CM_DeckItem;
begin
	if table.accessRow(table.row) = null then
		return;
	endif;
	deckItem:=table.accessRow(table.row).itemObject.CM_DeckItem;

	self.myAssistant.SHP_Assistant.showRORODeckItemForm(self.myCurrentDeck,deckItem,SHP_ParentChildForm.Mode_View);
	
epilog

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="toolbarShowCaptions" id="99dcc8c1-2356-474a-91ac-7de75f5e69e5">
