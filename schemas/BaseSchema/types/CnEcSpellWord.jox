    <JadeMethod name="initializeMe" id="a007718a-daa8-4c70-83ed-2e6cb54aceea">
        <updating/>
        <source>initializeMe(pSpellRootObj:CnEcSpellRoot; pName:String) : String updating; 

// This method created by JediMethodGenerator at 17:00:46 on 07 June 2001

vars
	errorMessage	: String;

begin
	// Validation

	self.validateMe(pSpellRootObj, pName);

	// Attributes (Non Keys)


	// Attributes (Keys)

	self.name := 	pName;
	self.setSoundex();
	self.setMetaphone();

	// Singleton References

	self.myRoot := 	pSpellRootObj;
epilog
	return errorMessage;
end;</source>
        <Parameter name="pSpellRootObj" type="CnEcSpellRoot"/>
        <Parameter name="pName" type="String"/>
