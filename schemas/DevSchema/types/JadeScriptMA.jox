    <JadeMethod name="tsTest" id="66c61a7b-ddd4-4cb8-8734-b3efe290263e">
        <source>tsTest();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 July 2025		navma1	Initial creation

*/

vars
	ts : TimeStamp;
	now : TimeStamp;
begin
	now := app.actualTimeServer;
	ts	:= now.addDays(-1);
	if not ts.isValid or ts.date &lt; now.date then
		write ts.asStringJMT;
		write 'not Valid ';
	endif;
	
	write "End";
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="userScript" id="3f27589b-9a52-4c22-9830-b0239929ece0">
        <source>userScript();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 January 2024		navma1	Initial creation

*/

vars
	body		: String;
	autoDisabilityPeriod : Integer;
	userSet : CM_UserSet;
	user : CM_User;
	str : String;
	bgp : BGP_EmailSendRequest;
begin
	
	autoDisabilityPeriod := app.myRoot.getConfig(AutoDisabilityPeriod).Integer;
	str := 	app.myRoot.getConfig(AutoDisableEmailAddress).String;
	create userSet transient;
	foreach user in app.myRoot.allUsers discreteLock do
//		if user.code = 'VVV' then
			if user.allowAutomaticDisability  
			  and (user.status &lt;&gt; DisabledBySysAdminUser or not user.isNotAvailableForEntry) then
				if user.lastLoginTS.isValid  then //12/12/2014 cnwma1 PAR  35328
					if  (app.actualTimeServer.date - user.lastLoginTS.date) &gt; autoDisabilityPeriod then
						userSet.add(user);
					endif;
				elseif  user.lastLoginTS = null then			//12/12/2014 cnwma1 PAR  35328
					if  (app.actualTimeServer.date - user.dateCreated.date) &gt; autoDisabilityPeriod then
						userSet.add(user);
					endif;
				endif;
			endif;
//		endif;
	endforeach;
	write str;
	write userSet.size.String;
	
	beginTransaction;
	bgp :="5119.259673".asOid.BGP_EmailSendRequest;
	bgp.setPropertyValue(BGP_EmailSendRequest::fromAddress.name,'madwy@mtn.navis.com');
	commitTransaction;
epilog
delete userSet;
end;</source>
    </JadeMethod>
    <JadeMethod name="vbs1CreateVBSProcess" id="d3a1a942-29cd-426b-9874-b1a1203bd5b9">
        <source>vbs1CreateVBSProcess();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 Jun 2022 navma1 ChangeRequest 53697: EUP - VBS MTN - [1] - VBS Slot Types

*/

vars
	pxyVBSProcess : CM_VBSProcess;
	vBSProcess : CM_VBSProcess;
	terminal : CM_Terminal;
begin
	
	app.initialize();
	
	
	
	// Default process
	if not app.myRoot.allVBSProcesses.isEmpty then
		vBSProcess := app.myRoot.allVBSProcesses.getAtKey( CM_VBSProcess.VBS_STANDARD_CODE ).CM_VBSProcess;
	endif;
	
	beginTransaction;
	if vBSProcess = null then
		create pxyVBSProcess as CM_VBSProcessStandard transient;
		pxyVBSProcess.setProxy(CM_VBSProcess.VBS_STANDARD_CODE,CM_VBSProcess.VBS_STANDARD_DESC);
		
		create vBSProcess as CM_VBSProcessStandard persistent;
		vBSProcess.setForCreate( pxyVBSProcess );
		delete pxyVBSProcess;
		
		foreach terminal in CM_Terminal.instances do
			terminal.setDefaultVBSProcess( vBSProcess );
		endforeach;
	endif;
	
	
	delete pxyVBSProcess;
	vBSProcess := null;
	
	// Default process
	if not app.myRoot.allVBSProcesses.isEmpty then
		vBSProcess := app.myRoot.allVBSProcesses.getAtKey( CM_VBSProcess.VBS_SLVALIDATION_CODE ).CM_VBSProcess;
	endif;
	
	if vBSProcess = null then
		create pxyVBSProcess as CM_VBSProcessSlotValidation transient;
		pxyVBSProcess.setProxy(CM_VBSProcess.VBS_SLVALIDATION_CODE,CM_VBSProcess.VBS_SLVALIDATION_DESC);
		
		create vBSProcess as CM_VBSProcessSlotValidation persistent;
		vBSProcess.setForCreate( pxyVBSProcess );

	endif;
	commitTransaction;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="vbs2CopyVBSTypesToTerminals" id="678ee177-1288-470a-bc9e-5eaf9075632f">
        <source>vbs2CopyVBSTypesToTerminals();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 Jun 2022 navma1 ChangeRequest 53697: EUP - VBS MTN - [1] - VBS Slot Types
25 Nov 2024	navhl20 CR MTN-33483: TPT | Vehicle Truck Booking Auto Associate with Release Request
*/

vars
	term : CM_Terminal;
	vbs,
	vbsSlotType,
	newVBSlotYype,
	pxyVBSType : CM_VehicleBookingTimeSlotType;
	vbsTemplate: CM_VehicleBookingTimeTemplate;
	dyna       : DynaDictionary;
	obj 	   : Object;
	startTime : Time;	//22.06.2022 navtnr20 TFS 53697	
	duration : Integer;
	gracePeriod	: Integer;
	entryOutsideSlotType : Integer;
	pregateInCheck : Boolean;
	pregateOutCheck : Boolean;
	kioskCheck : Boolean;
	vbsProcess : String;
	externelReference	: Boolean;
begin

	// Create VBS Slots in each terminal 
	app.initialize();
	
	create dyna transient;
	dyna.setMembership(CM_VehicleBookingTimeSlotType);
	dyna.addMemberKey(CM_VehicleBookingTimeSlotType::code.name ,false,true);
	dyna.endKeys(true);
	
	foreach vbs in CM_VehicleBookingTimeSlotType.instances do
		if vbs.myTerminal &lt;&gt; null then
			continue;
		endif;
		
		dyna.add(vbs);
		
	endforeach;
	
	
	foreach term in app.getMyRoot.allTerminals do
		
		if term.myVehicleBookingTerminal = null then
			continue;
		endif;
		if  not term.myVehicleBookingTerminal.hasVbsSlotTemplate then
			continue;
		endif;
		
		
		write "Start-------------Term-------------- " &amp; term.code;
	
		foreach obj in dyna do
			vbsSlotType := obj.CM_VehicleBookingTimeSlotType;
			
			if term.allTerminalVBSSlotTypes[vbsSlotType.code] = null then
				
				write 'Need Slot Types  ' &amp; term.code &amp;'  '  &amp; vbsSlotType.code;
			
				
				beginTransaction;
				create pxyVBSType transient;
				//pxyVBSType.setForProxy(vbsSlotType.code,vbsSlotType.description,vbsSlotType.notAvailableForEntry,term)22-06-2022	navtnr20 53697
				pxyVBSType.setForProxy(vbsSlotType.code,vbsSlotType.description,vbsSlotType.notAvailableForEntry,term,startTime,duration,gracePeriod,
												entryOutsideSlotType,pregateInCheck,pregateOutCheck,kioskCheck,externelReference,//22-06-2022 navtnr20 53697
												false);																				//25.11.2024 navhl20 #33483
				app.myUtilityCA.utlCreateVBTimeSlotType(pxyVBSType, newVBSlotYype, app.myPassport);
				delete pxyVBSType;
				commitTransaction;
				
			
			else 
				write "Already created :"  &amp; term.code &amp; Tab &amp; vbsSlotType.code;
			endif;
			vbsSlotType := null;
		endforeach;
		
		
		write "END-------------Term-------------- " &amp; term.code;
		term := null;
	endforeach;
epilog
	delete dyna;
end;</source>
    </JadeMethod>
    <JadeMethod name="vbs3UpdateSlotTypeProcess" id="282a1c2a-f771-474c-aa48-ac645261da20">
        <source>vbs3UpdateSlotTypeProcess();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 Jun 2022 navma1 ChangeRequest 53697: EUP - VBS MTN - [1] - VBS Slot Types

*/

vars
	vBSProcess : CM_VBSProcess;
	term       : CM_Terminal;
	vbsSlotType: CM_VehicleBookingTimeSlotType;
begin
	app.initialize();
	
	if  app.myRoot.allVBSProcesses.isEmpty then
		return;
	endif;
	
	
	vBSProcess := app.myRoot.allVBSProcesses.getAtKey( CM_VBSProcess.VBS_STANDARD_CODE ).CM_VBSProcess;
	
	if vBSProcess = null then
		return;
	endif;
	
	beginTransaction;
	
	foreach term in app.myRoot.allTerminals do
		foreach vbsSlotType in  term.allTerminalVBSSlotTypes do
			
			vbsSlotType.setVbsProcess(vBSProcess);
		endforeach;
	endforeach;
	
	commitTransaction;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="vbs4UpdateTemplateSlotType" id="bb974b4f-8306-49f3-9474-6870d7381e34">
        <source>vbs4UpdateTemplateSlotType();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 Jun 2022 navma1 ChangeRequest 53697: EUP - VBS MTN - [1] - VBS Slot Types

*/

vars
	vbsDayTemplate : CM_VehicleBookingDayTemplate;
	slotTemplate   : CM_VehicleBookingTimeTemplate;
	term           : CM_Terminal;
	termVbsSlotType: CM_VehicleBookingTimeSlotType;
	lFile 		   : File;
begin
	
	create lFile transient;
	lFile.fileName := "C:\TEMP\MA\vbsDataDMASTAfter.csv";
    lFile.open;
	lFile.writeLine("Action"					&amp; "," &amp;
					"Term"   	        		&amp; "," &amp;
					"vbsDayTemplateName" 		&amp; "," &amp;
					"vbsDayTemplateOid"		    &amp; "," &amp;
					"TemplateOid" 				&amp; "," &amp; 
					"TemplateTypeCode" 			&amp; "," &amp;
					"TemplateTypeOid" 			&amp; "," 
					);
					
	beginTransaction;
	foreach term in app.myRoot.allTerminals do
		if term.myVehicleBookingTerminal = null then
			continue;
		endif;
		if term.myVehicleBookingTerminal.allVehicleBookingDayTemplates.isEmpty then
			continue;
		endif;
		
		foreach vbsDayTemplate in  term.myVehicleBookingTerminal.allVehicleBookingDayTemplates do
			
			if vbsDayTemplate.allTimeTemplates.isEmpty then
				continue;
			endif;

			foreach  slotTemplate in vbsDayTemplate.allTimeTemplates do
				if slotTemplate.myVBTimeslotType = null then
					continue;
				endif;
				
				termVbsSlotType := term.allTerminalVBSSlotTypes[slotTemplate.myVBTimeslotType.code];

				lFile.writeLine( 
								"Before"										 &amp; Comma &amp; 
								term.code			 						     &amp; Comma &amp; 
								vbsDayTemplate.name 				 		     &amp; Comma &amp;  
								vbsDayTemplate.getOidString	&amp;'-'  				 &amp; Comma &amp; 
								slotTemplate.getOidString 		&amp;'-'	     	 &amp; Comma &amp; 
								slotTemplate.myVBTimeslotType.code  			 &amp; Comma &amp; 
								slotTemplate.myVBTimeslotType.getOidString &amp;'-' );
				
				if termVbsSlotType &lt;&gt; null and  termVbsSlotType.code.toUpper = slotTemplate.myVBTimeslotType.code.toUpper then
				// matching update
					slotTemplate.setVbsSlotType(termVbsSlotType);
				endif;
				
				lFile.writeLine( 
							   "After"											 &amp; Comma &amp; 
								term.code			 						     &amp; Comma &amp; 
								vbsDayTemplate.name 				 		     &amp; Comma &amp;  
								vbsDayTemplate.getOidString	&amp;'-'  				 &amp; Comma &amp; 
								slotTemplate.getOidString 		&amp;'-'	     	 &amp; Comma &amp; 
								slotTemplate.myVBTimeslotType.code  			 &amp; Comma &amp; 
								slotTemplate.myVBTimeslotType.getOidString &amp;'-' );
						
								
				slotTemplate    := null;
				termVbsSlotType := null;
				/*
				if termVbsSlotType &lt;&gt; ull and  termVbsSlotType.code = slotTemplate.myVBTimeslotType.code then
					write  term.code &amp; Tab &amp; vbsDayTemplate.name &amp; Tab &amp;'Matched : ' &amp; termVbsSlotType.code &amp;' - '  &amp; termVbsSlotType.getOidString &amp;Tab&amp;  slotTemplate.myVBTimeslotType.code &amp;' - '  &amp; slotTemplate.myVBTimeslotType.getOidString;
				else
					write ' Not Matched';
				endif;
				*/
				
				slotTemplate    := null;
				termVbsSlotType := null;
			endforeach;
			vbsDayTemplate := null;
		endforeach;
		term := null;	
	endforeach;
	commitTransaction;
  lFile.close;
epilog

	delete lFile;
end;</source>
    </JadeMethod>
    <JadeMethod name="vbs5UpdateSlotTypeSlotTime" id="fc974e7e-e77f-4e55-b06c-089ccfb0387f">
        <source>vbs5UpdateSlotTypeSlotTime();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 Jun 2022 navma1 ChangeRequest 53697: EUP - VBS MTN - [1] - VBS Slot Types

*/

vars
	lFile 		   : File;
	beforeSlotType,
	termSlotType   : CM_VehicleBookingTimeSlotType;
	slotTime 	   : CM_VehicleBookingTimeSlot; 
	term		   : CM_Terminal;
begin
	create lFile transient;
	lFile.fileName := "C:\TEMP\MA\vbsSlotTyimeAfterUpdate.csv";
    lFile.open;
	lFile.writeLine( "Term"   	        		&amp; "," &amp;
					"VBS ID" 				    &amp; "," &amp;
					"VBS Oid"				    &amp; "," &amp;
					"Before Type Code"			&amp; "," &amp; 
					"Before Type Oid" 			&amp; "," &amp;
					"After Type Code" 			&amp; "," &amp;
					"After Type Oid" 			&amp; "," 
					);
					
	beginTransaction;			
	foreach  slotTime in  CM_VehicleBookingTimeSlot.instances do 
		
		beforeSlotType := slotTime.myVBTimeSlotType;
		
		if beforeSlotType = null then
			continue;
		endif;
		
		
		
		if slotTime.myVehicleBookingTerminal  = null then
			continue;
		endif;
		
		term := slotTime.myVehicleBookingTerminal.myTerminal;
		
		if term = null then
			continue;
		endif;
		
		termSlotType := term.allTerminalVBSSlotTypes[beforeSlotType.code];
		
		if termSlotType = null then
			continue;
		endif;
		
		if termSlotType.code.toUpper = beforeSlotType.code.toUpper then
			
			slotTime.setVBTimeSlotType(termSlotType);
		endif;
		
		lFile.writeLine( 
						slotTime.myVehicleBookingTerminal.myTerminal.code	     &amp; Comma &amp; 
						slotTime.id 				 		   				     &amp; Comma &amp; 
						slotTime.getOidAsString &amp;'-' 		   				     &amp; Comma &amp;  
						beforeSlotType.code 		   				  		     &amp; Comma &amp; 
						beforeSlotType.getOidAsString&amp;'-'			    		 &amp; Comma &amp;
						slotTime.myVBTimeSlotType.code							 &amp; Comma &amp;
						slotTime.myVBTimeSlotType.getOidAsString	&amp;'-'		 &amp; Comma 
		);
		
		slotTime 	   := null;
		beforeSlotType := null;
		termSlotType   := null;
	endforeach;
	
	commitTransaction;
  lFile.close;
epilog

	delete lFile;
end;</source>
    </JadeMethod>
    <JadeMethod name="vbs6UpdateTermprocess" id="8084ef30-8d6a-4b5e-a63e-04559c5742b7">
        <source>vbs6UpdateTermprocess();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 July 2022		navma1	Initial creation

*/

vars
	vBSProcess : CM_VBSProcess;
	term       : CM_Terminal;
	vbsSlotType: CM_VehicleBookingTimeSlotType;
begin
	app.initialize();
	
	if  app.myRoot.allVBSProcesses.isEmpty then
		return;
	endif;
	
	
	vBSProcess := app.myRoot.allVBSProcesses.getAtKey( CM_VBSProcess.VBS_SLVALIDATION_CODE ).CM_VBSProcess;
	
	if vBSProcess = null then
		return;
	endif;
	
	beginTransaction;
	
	term :=  app.myRoot.allTerminals['ALTM'];
	
	if term &lt;&gt; null then
		term.setDefaultVBSProcess(vBSProcess);
		
	endif;
	
	commitTransaction;
epilog

end;</source>
    </JadeMethod>
