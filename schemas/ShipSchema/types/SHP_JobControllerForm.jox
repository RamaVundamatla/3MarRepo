        <updating/>
        <source>getXMLSettingsForExit(): String updating;
/*

Purpose:			


Return Value:		


Date		Who		Reason
05 February 2007	cnwer1	Initial creation - PAR#xxxx

*/
vars

begin
	return inheritMethod();


epilog

