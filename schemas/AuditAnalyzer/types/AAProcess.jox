<Class name="AAProcess" id="ad98e59d-7760-4ae2-a32c-089bcbf62b3b">
    <superclass name="Object"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="auditor"/>
    <PrimAttribute name="name" id="ee850704-c408-4750-9c26-282749c93537">
        <length>31</length>
        <embedded/>
        <type name="String"/>
    </PrimAttribute>
    <PrimAttribute name="oid" id="9ba3dec2-2ecb-47d7-9e04-fa2f0a1e91b3">
        <length>21</length>
        <embedded/>
        <type name="String"/>
    </PrimAttribute>
    <ExplicitInverseRef name="reportNames" id="28896f29-5ba2-430b-881d-7ebc96becaa7">
        <kind>parent</kind>
        <updateMode>manual</updateMode>
        <type name="AAReportsByTimeDict"/>
        <Inverse name="AALINCReport::myProcess"/>
    </ExplicitInverseRef>
    <ExplicitInverseRef name="root" id="ebe2489a-e586-46da-a578-d3f6fe8983fb">
        <kind>child</kind>
        <updateMode>automatic</updateMode>
        <embedded/>
        <type name="AARoot"/>
        <access>protected</access>
        <Inverse name="AARoot::users"/>
        <Inverse name="AARoot::reports"/>
    </ExplicitInverseRef>
    <PrimAttribute name="type" id="45bf59f5-2c2b-4d62-b191-dd896a47854a">
        <embedded/>
        <type name="Integer"/>
    </PrimAttribute>
    <JadeMethod name="create" id="7a140fcc-30a5-4217-87fb-a880c74dcdc9">
        <updating/>
        <source>create() updating;

vars

begin
	name := "&lt;anon&gt;";
end;
</source>
    </JadeMethod>
    <JadeMethod name="load" id="c5d1da65-4896-46e9-b6b3-0bde763bc8e9">
        <updating/>
        <source>load(procOid : String; userName : String; typ : Integer) updating;

begin
	type := typ;
	oid := procOid;
	name  := userName;
end;
</source>
        <Parameter name="procOid" type="String"/>
        <Parameter name="userName" type="String"/>
        <Parameter name="typ" type="Integer"/>
    </JadeMethod>
</Class>
