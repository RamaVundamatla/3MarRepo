    <JadeMethod name="addToolbarControlsForYA" id="9eb7b242-ddbf-49ae-979d-67f7654bd44d">
        <source>addToolbarControlsForYA() protected;
//13 August 2008	cnwdw1	
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 30/10/2008	consw1		SFW1030 - Remove unused auto plan flags
// 04/11/2011	cnwdap1		PAR #28629 Make YA Delete button invisible if user has no YA Maint security access
// 26/06/2020	jlgdap1		TFS 49453 ASPA Satellite View Screen for Flexible Terminal Areas
vars
	toolbar: CMUI_Toolbar;
begin
	toolbar := self.frmToolbar;
	
	toolbar.addButton(self.btnPrint, CMUI_Toolbar.Control_Alignment_Left);		// TFS 49453
	toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);					// TFS 49453
	toolbar.addButton(self.btnSelect, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnSearchYAM, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnAddYA, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnViewYardAllEd, CMUI_Toolbar.Control_Alignment_Left);
	self.btnViewYardAllEd.enabled := false;
	if app.myCurrentUserCan(self.myTerminal, PmAdmYAMaint) then					// PAR #28629
		toolbar.addButton(self.btnDeleteYA, CMUI_Toolbar.Control_Alignment_Left);
	endif;																		// PAR #28629
	self.btnDeleteYA.enabled := true;
	toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnViewYardAlloc, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnOpenYAM, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnOpenYAMTmpl, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnViewAreaU, CMUI_Toolbar.Control_Alignment_Left);	//30 Jun 2016	NDL	TFS 1752
	
	toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);		//28 Feb 2014	NDL	Par 33607
	toolbar.addButton( self.btnVDS, CMUI_Toolbar.Control_Alignment_Left );	//28 Feb 2014	NDL	Par 33607
	
	// Setup searchToolbar
	toolbar := self.frmSearchToolbar;
	toolbar.addButton(self.btnSearchCollaps, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnSearchExpand, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnSearchTV, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnResetSearchTV, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.positionToolbarControls();
	toolbar.visible := true;


	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="allowsTableFilters" id="3082ffa4-041d-449e-ae92-b6b85e8cbeba">
        <source>allowsTableFilters(_table: Table): Boolean;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
21 December 2011	cnwndl1	Initial creation	Par 28889

*/

vars

begin

	return _table = self.tblFailAutoPlan or _table = self.tblFailRequest or _table = self.tblYAM;

epilog

end;</source>
