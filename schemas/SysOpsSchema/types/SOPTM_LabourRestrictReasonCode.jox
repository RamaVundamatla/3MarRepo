    <JadeMethod name="setControlsForAddEdit" id="f9be878f-cdfe-4a04-abc8-81fa24582fcd">
        <updating/>
        <source>setControlsForAddEdit() updating;
// ---------------------------------------------------------------------------
// Created:     25 May 2005	cnwhjg1
//
// Purpose:     
// ----------   ----------  --------------------------------------------------
vars
	theForm : SOP_TableMaintForm;
	tmpTblInput	: CM_EntryTable;

begin
	theForm := self.myForm;
	tmpTblInput := theForm.tblInput1;
	tmpTblInput.userInputEnabled := true;
	
			
	if theForm.mode = theForm.Mode_Add then
		tmpTblInput.clearValues;
		tmpTblInput.enableRowByName(ETRow_Code);
		tmpTblInput.enableRowByName(ETRow_Description);	
		tmpTblInput.moveFirst();	
		tmpTblInput.gotFocus(tmpTblInput);
	else
		// refresh the data from the newly created proxy
		self.showThumbnail(theForm.myProxyObject.CM_LabourRestrictionReasonCode);
		// cannot update code
		tmpTblInput.disableRowByName(ETRow_Code);
		tmpTblInput.enableRowByName(ETRow_Description);

	endif;
	tmpTblInput.cnEcResizeContents();

end;</source>
    </JadeMethod>
    <JadeMethod name="setCtrlsForView" id="47ab5bc8-8474-4f44-9179-9113b98c68b6">
        <updating/>
        <source>setCtrlsForView() updating;
// ---------------------------------------------------------------------------
// Created:     25 May 2005	cnwhjg1
//
// Purpose:     
// ----------   ----------  --------------------------------------------------
vars
	theForm : SOP_TableMaintForm;
begin
	//cnwmc5 - 17 Oct 2013 - PAR 32622
	inheritMethod();
	
	theForm := self.myForm;
	theForm.tblInput1.userInputEnabled := false;
	theForm.tblInput1.cnEcResizeContents();
end;</source>
    </JadeMethod>
    <JadeMethod name="setupThumbnailDetails" id="313ae1ab-ce74-4c48-be1c-23ae4e50a8a7">
        <updating/>
        <source>setupThumbnailDetails() updating;
// ---------------------------------------------------------------------------
// Created:     25 May 2005	cnwhjg1
//
// Purpose:     
// ----------   ----------  --------------------------------------------------
vars

	theForm : SOP_TableMaintForm;

begin

  
  	theForm := self.myForm;
  	theForm.tblData.userInputEnabled := false;
	theForm.useProxyObject := true;
	theForm.setTblDataEntRows(ETDef_CodeMaint);
	//12/01/2011 cnwdz2 25840
	//theForm.zClearSortColumns();
	//theForm.zAddSortColumn(ETRow_Code, false);

	theForm.shtTblInput1.caption := 'Details';
	theForm.initTblInput(theForm.tblInput1, ETDef_CodeMaint);
	theForm.shtTblInput1.visible := true;

	theForm.mulSelect1.formDisplayEntryMethodName := null;
	theForm.mulSelect2.formDisplayEntryMethodName := null;

end;</source>
    </JadeMethod>
    <JadeMethod name="showThumbnail" id="0b8a3a63-d916-4a33-aaa4-ca4dce84820a">
        <updating/>
        <source>showThumbnail(pObj: CM_LabourRestrictionReasonCode) updating;
// ---------------------------------------------------------------------------
// Created:     25 May 2005	cnwhjg1
//
// Purpose:     
// ----------   ----------  --------------------------------------------------
vars
	theForm : SOP_TableMaintForm;

begin
  
    theForm := self.myForm;
	theForm.tblInput1.clearValues;
	theForm.tblInput1.setValueByName(ETRow_Code, pObj.code);
	theForm.tblInput1.setValueByName(ETRow_Description,	pObj.description);
	theForm.tblInput1.setValueByName(ETRow_NotAvailableForEntry, pObj.notAvailableForEntry);
end;</source>
        <Parameter name="pObj" type="CM_LabourRestrictionReasonCode"/>
    </JadeMethod>
</Class>
