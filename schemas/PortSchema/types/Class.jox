    <JadeMethod name="allPsPropMethodsInFTreeUpTo" id="7e927fbb-b5fd-40fa-8212-4ae891991758">
        <source>allPsPropMethodsInFTreeUpTo(cls: Class; methds: MethodSet input);
/*
A "pseudo-property method" is one that takes zero parameters and has
a return value.
*/
vars
	methd:         Method;
begin
	self.allMethodsUpTo(cls, methds);

	getMethodsInSubclasses(methds);

	// now remove methods that don't meet the "pseudo-property method" criteria
	foreach methd in methds do
		if not methd.isPseudoProperty then
			methds.remove(methd);
		endif;
	endforeach;

epilog
end;</source>
        <Parameter name="cls" type="Class"/>
        <Parameter name="methds" type="MethodSet" usage="input"/>
    </JadeMethod>
