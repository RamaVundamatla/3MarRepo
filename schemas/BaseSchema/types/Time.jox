<PrimType name="Time">
    <JadeMethod name="cnEcAddHours" id="83c9641d-46f3-4070-a8f1-cfdd96fa42dc">
        <source>cnEcAddHours(pHours:Integer):Time;
// --------------------------------------------------------------------------------
// Created:		24 May 2001 by cnwdad1
//
// Purpose:		Add the specified number (positive or negative) of hours to the
//				receiver time.
//
// Parameters:	pHours (Integer) - The number of hours to add (or subtract).
//
// Returns:		The resulting time.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return self + (((pHours * 60) * 60) * 1000);
end;</source>
        <Parameter name="pHours" type="Integer"/>
        <ReturnType type="Time"/>
    </JadeMethod>
    <JadeMethod name="cnEcAddMinutes" id="a730312c-a289-4063-b5a0-175552e04451">
        <source>cnEcAddMinutes(pMinutes:Integer):Time;
// --------------------------------------------------------------------------------
// Created:		24 May 2001 by cnwdad1
//
// Purpose:		Add the specified number (positive or negative) of minutes to the
//				receiver time.
//
// Parameters:	pMinutes (Integer) - The number of minutes to add (or subtract).
//
// Returns:		The resulting time.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return self + ((pMinutes * 60) * 1000);
end;</source>
        <Parameter name="pMinutes" type="Integer"/>
        <ReturnType type="Time"/>
    </JadeMethod>
    <JadeMethod name="cnEcAddSeconds" id="85e17c2e-22c4-4bbc-ae51-853602fca3b8">
        <source>cnEcAddSeconds(pSeconds:Integer):Time;
// --------------------------------------------------------------------------------
// Created:		24 May 2001 by cnwdad1
//
// Purpose:		Add the specified number (positive or negative) of seconds to the
//				receiver time.
//
// Parameters:	pSeconds (Integer) - The number of seconds to add (or subtract).
//
// Returns:		The resulting time.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return self + (pSeconds * 1000);
end;</source>
        <Parameter name="pSeconds" type="Integer"/>
        <ReturnType type="Time"/>
    </JadeMethod>
    <JadeMethod name="cnEcDisplayMS" id="01ec1814-3676-4c80-b961-a9eeda8e7d6d">
        <source>cnEcDisplayMS():String;
// --------------------------------------------------------------------------------
// Created:		19 June 2000 by cnwdad2
//
// Purpose:		Returns the receiver as a string, with milliseconds.
//
// Parameters:	None
//
// Returns:		The receiver as a string.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return (self.display &amp; '.' &amp; (self.milliSecond + 1000).String[2:3]);
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="cnEcGetAnsiFormat" id="df969d0d-fc8e-4370-b0ba-adbb7b689ec3">
        <source>cnEcGetAnsiFormat():String;
// --------------------------------------------------------------------------------
// Created:		07 November 2000 by cnwdad1
//
// Purpose:		Convert a Time type to an ANSI type string "2000-12-31".
//
//				Refer to the String::cnEcGetAnsiTimeFormat method to retrieve an
//				ANSI time from a string.
//
// Parameters:	None
//
// Returns:		A string of the resulting date format.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return self.userFormat($CNEC_ANSI_TIME_FORMAT);
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="cnEcMax" id="14bffcc0-4a46-46ad-b9bf-76ad8b2272c0">
        <source>cnEcMax(pTime:Time):Time;
// --------------------------------------------------------------------------------
// Created:		15 March 2007 by cnwdad1
//
// Purpose:		Returns which ever is the latest time between the receiver and the
//				parameter.
//
// Parameters:	pTime - The time to compare the receiver to.
//
// Returns:		The latest time.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if self &gt; pTime then
		return self;
	else
		return pTime;
	endif;
end;</source>
        <Parameter name="pTime" type="Time"/>
        <ReturnType type="Time"/>
    </JadeMethod>
    <JadeMethod name="cnEcMin" id="188096a2-77ab-4843-80e1-c05c53a584d2">
        <source>cnEcMin(pTime:Time):Time;
// --------------------------------------------------------------------------------
// Created:		15 March 2007 by cnwdad1
//
// Purpose:		Returns which ever is the earliest time between the receiver and the
//				parameter.
//
// Parameters:	pTime - The time to compare the receiver to.
//
// Returns:		The earliest time.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if self &lt; pTime then
		return self;
	else
		return pTime;
	endif;
end;</source>
        <Parameter name="pTime" type="Time"/>
        <ReturnType type="Time"/>
    </JadeMethod>
</PrimType>
