    <JadeMethod name="validateWorkzone" id="e896a6c2-6cb5-4d3f-90c7-949b0c993a4a">
        <source>validateWorkzone(_startColumn, _endColumn : CM_RTGColumn;_type : Integer);
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
04 September 2009	cnwer1	Initial creation

*/

vars
	startRTGLane,
	endRTGLane : CM_RTGLane;
	typeString : String;
	
	needsNote : Boolean;
begin

	
	typeString:=app.getErrorString(_type);

	if self.machineType &lt;&gt; MACHINETYPE_RTG and
		self.machineType &lt;&gt; MACHINETYPE_RMG then
		app.raiseCMException(Machine_type_RTG_RMG,null,null);
	endif;

	if self.isBeforePhysicalLimitStart(_startColumn) or
			self.isAfterPhysicalLimitEnd(_endColumn) then
		app.raiseCMWarning1(Workzone_Out_Of_Sync,_startColumn.label &amp; "-" &amp; _endColumn.label,null,null,null);
	endif;
	
	if  _startColumn.myGridArea &lt;&gt; _endColumn.myGridArea then
		//check that they are in the same RTG Lane
		startRTGLane:=_startColumn.myGridArea.allTerminalAreaGroups.first.CM_RTGLane;
		if startRTGLane = null then
			app.raiseCMException2(Workzone_Span_Areas,typeString, app.getErrorString(Workzone_same_lane), null,null);
		endif;
		endRTGLane:=_endColumn.myGridArea.allTerminalAreaGroups.first.CM_RTGLane;
		if endRTGLane = null then
			app.raiseCMException2(Workzone_Span_Areas,typeString, app.getErrorString(Workzone_same_lane), null,null);
		endif;
		
		if startRTGLane &lt;&gt; endRTGLane then
			app.raiseCMException2(Workzone_Span_Areas,typeString, app.getErrorString(Workzone_same_lane), null,null);
		endif;
		
		//cnwjo3 par 24124.  errors have been raised.  Cannot continue with validation
		if startRTGLane = null then
			return;
		endif;
		
		if startRTGLane.allTAsByTypeId.indexOf(_endColumn.myGridArea) &lt; startRTGLane.allTAsByTypeId.indexOf(_startColumn.myGridArea) then
			app.raiseCMException2(Workzone_Start_End_Bays,typeString,typeString,null,null);
		endif;
	else
		//same area need 
		if _startColumn.myGridArea.allGridColumns.indexOf(_startColumn) &gt; _endColumn.myGridArea.allGridColumns.indexOf(_endColumn) then
			app.raiseCMException2(Workzone_Start_End_Bays,typeString,typeString,null,null);						
									
		endif;		
	endif;
epilog

end;</source>
        <Parameter name="_startColumn" type="CM_RTGColumn"/>
        <Parameter name="_endColumn" type="CM_RTGColumn"/>
        <Parameter name="_type" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="weighBox" id="fa651501-900b-48ca-a200-d48d69ae93c9">
        <source>weighBox(_weight : Integer; _isCertified : Boolean; _ti : CM_TrackedItem input);
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
28 Jan 2010	cnwer1	Initial creation CCMS 1083
03/08/2016  cnwma1  TFS 2475:PNL- Missing error relating to Loadrite interface
11/07/2017	cnwdap1	TFS 4492 SNO VERMAS Changes
*/
vars
	authorised,
	certified	: String;
	tiUpdateCntrlr		: CMIF_TIUpdateController; 	
	proxyTi				: CM_TrackedItem;	
	weighAuth			: CM_WeighAuthority;			// TFS 4492
	authTerm 			: CM_WeighAuthTerminal;			// TFS 4492

begin

	if _weight = 0 then
		return;
	endif;
	
	if not self.canWeighCargo then
		return;
	endif;

	if not _ti.isBoxToBeWeighed(self.myTerminal) then
		return;
	endif;
	


	tiUpdateCntrlr := app.createTIUpdateControl(TI_UPDMODE_RECEIPT, app.myPassport.userCode, null);
	tiUpdateCntrlr.transactionType := TRANS_TYPE_WEIGH;
	tiUpdateCntrlr.newWeight := _weight;
		// CCMS 1319
	tiUpdateCntrlr.machineId := self.id;
	// TFS 2357 need to set this now
	tiUpdateCntrlr.isWeightCertified := _isCertified;
	proxyTi := app.createUpdateProxy(_ti).CM_TrackedItem;
	proxyTi.setTotalWeight(_weight, tiUpdateCntrlr, app.myPassport);
	
	proxyTi.validateWeightForMachine( tiUpdateCntrlr);
		
	// TFS 2357 for certified weight from loadrite
	if _isCertified then
		//authorised := self.myTerminal.getConfig(DefaultAuthPersonWeight).String;	// TFS 4492
		//certified := self.myTerminal.getConfig(DefaultWeightCertifiedBy).String;	// TFS 4492
		authTerm := self.myTerminal.getDefaultWeighAuthority();						// TFS 4492
		if authTerm &lt;&gt; null then													// TFS 4492
			authorised := authTerm.myWeighAuthority.authorisedName;					// TFS 4492
			certified := authTerm.myWeighAuthority.certifiedName;					// TFS 4492
		endif;																		// TFS 4492
	endif;
	_ti.setWeightForRTSetdown(_weight, _isCertified, authorised, certified, tiUpdateCntrlr, app.myPassport);

epilog
	delete tiUpdateCntrlr;
	delete proxyTi;

end;</source>
        <Parameter name="_weight" type="Integer"/>
        <Parameter name="_isCertified" type="Boolean"/>
        <Parameter name="_ti" type="CM_TrackedItem" usage="input"/>
    </JadeMethod>
</Class>
