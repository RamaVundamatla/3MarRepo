    <JadeMethod name="getMeasurementStringForAttrib" id="719adbe3-383f-4e17-9b15-410f50510d35">
        <source>getMeasurementStringForAttrib(_attrName: String; _measureType: String; _short: Boolean): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23/10/2024	navkc1 JIRA Task MTN-19369: EUP | Ownership Change Enquiry missing fields - All Quantity, Weight, Volume fields

*/

vars

begin
	
	if _attrName = ETRow_TransferWeight then
		return app.convertMeasurementForDisplay(_measureType, self.getTransferWeightAccum());
	elseif _attrName = ETRow_TransferVolume then
		return app.convertMeasurementForDisplay(_measureType, self.getTransferVolumeAccum());
	elseif _attrName = ETRow_CurrentTotalWeight then
		return app.convertMeasurementForDisplay(_measureType, self.getCurrentWeightAccum());
	elseif _attrName = ETRow_CurrentTotalVolume then
		return app.convertMeasurementForDisplay(_measureType, self.getCurrentVolumeAccum());
	endif;
	
	return null;
	

epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_measureType" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getMyTrackedItem" id="4e4eda63-3faa-4940-9e6b-9888f986b7ef">
        <source>getMyTrackedItem() : CM_TrackedItem;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 July 2023	navmv20	58235

*/

vars
	myOwnershipDetail : CM_OwnershipChangeDetail;
	myTrackedItem : CM_TrackedItem;
begin
	if self.allDetails.isNotEmpty then
		myOwnershipDetail := self.allDetails.first;
	endif;
	if myOwnershipDetail&lt;&gt; null then
		myTrackedItem := myOwnershipDetail.myTrackedItem;
	endif;
	
	if myTrackedItem&lt;&gt; null 
	and myTrackedItem.isCargoGroupItem then
		myTrackedItem := myTrackedItem.CM_CargoGroup.allAssignedTrackedItems.first;
	endif;
	return myTrackedItem;
epilog

end;</source>
        <ReturnType type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="getObjectEmailBody" id="16a31f00-eebe-4f14-b1ee-79ba0511c141">
        <source>getObjectEmailBody(_objectEmail: CM_ObjectEmail): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
//19/08/2024	navkc1 CR 65246  Task 65697: Jade _ COO Derive Email Body

*/

vars
	emailBodyInvList,
	bodyStr 				: String;
	bank					: CM_Bank;
	terminal				: CM_Terminal;
	invoice					: CM_Invoice;
	invLine					: CM_InvoiceLine;
	cooFinancial			: CM_OwnershipChangeFinancial;
	doneFirstLine			: Boolean;
begin
	bodyStr := inheritMethod(_objectEmail);
	
	terminal := self.myTerminal;
	
	foreach cooFinancial in self.allFinancialIssues do
		invLine := cooFinancial.myInvoiceLine;
		invoice := invLine.invoice;
		
		if not doneFirstLine then
			bank := invoice.bank;
			emailBodyInvList := app.getErrorString(Terminal) &amp; " - " &amp; terminal.code &amp; CrLf &amp; app.getErrorString(Bank) &amp; " - " &amp; bank.code &amp; CrLf;
			doneFirstLine := true;
		endif;
		
		emailBodyInvList &amp;=
				"Invoice Number : " &amp; invoice.sequenceNum.asStringJMT() &amp; CrLf &amp;
				"Invoice External Number : " &amp; invoice.externalNumber &amp; CrLf &amp;
				"Invoice Line Seq Number : " &amp; invLine.sequenceNum.asStringJMT() &amp; CrLf &amp; 
				"Invoice Line External Reference : " &amp; invLine.externalRef1 &amp; CrLf &amp; CrLf;
		
	endforeach;
	
	return bodyStr &amp; CrLf &amp; emailBodyInvList &amp; CrLf &amp; CrLf &amp; _objectEmail.message &amp; CrLf;
epilog
	
end;</source>
        <Parameter name="_objectEmail" type="CM_ObjectEmail"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getTransferQtyAccum" id="6106f13d-6cc2-4d75-8174-81c4414adbfe">
        <source>getTransferQtyAccum() : Integer;
/*

Purpose:			This method go through all COO details and accumulate the transfer quantity

Parameters:			

Return Value:		

Date		Who		Reason
23/10/2024	navkc1 JIRA Task MTN-19369: EUP | Ownership Change Enquiry missing fields - All Quantity, Weight, Volume fields

*/

vars
	transferQty 		: Integer;
	subTi,
	ti					: CM_TrackedItem;
	
	subCooDetails,
	cooDetails			: CM_OwnershipChangeDetail;
begin
	
	foreach cooDetails in self.allDetails discreteLock where cooDetails.isIncluded() do
		
		ti := cooDetails.myTrackedItem;
		
		if ti = null then
			continue;
		endif;
		
		if ti.isCargoGroupItem() then
			foreach subCooDetails in cooDetails.allSubDetails discreteLock where subCooDetails.isIncluded() do
				transferQty += subCooDetails.transferredQuantity;
			endforeach;
		else
			transferQty += cooDetails.transferredQuantity;
		endif;
	endforeach;
	
	return transferQty;
	
epilog

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
