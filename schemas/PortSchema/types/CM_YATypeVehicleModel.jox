    <JadeMethod name="getDisplay" id="e8e46ef0-ecb0-452d-a49e-417a118a83d8">
        <source>getDisplay(dataObj: Object): String;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 17/09/2013	cnwdap1		Initial creation PAR #32215
//
vars

begin
	return dataObj.CM_VehicleModel.getYADisplay;

epilog

end;</source>
