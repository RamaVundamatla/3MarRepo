    <JadeMethod name="doShowFrmDamage" id="c6148ed3-deb6-4411-9c2b-37bb2cf97bd6">
        <updating/>
        <source>doShowFrmDamage() updating, protected;
/*
----------   ----------  --------------------------------------------------
Created:	13 September 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	theTI : CM_TrackedItem;
begin
	
	self.doHideFrm(self.frmMain);
	self.doShowFrm(self.frmDamage);
	self.doHideFrm(self.frmFowardCont);
	self.doHideFrm(self.frmAftCont);
	
	self.btnDamageOK.default := true;
	self.btnDamageCancel.cancel := true;
	if self.showingAftContainer then
		theTI := app.myHandHeldShipLanderGuiAgent.myHandHeldShipLanderAgent.myTI_AFT;
		self.lblDamage.caption := 'Damage (Aft)';
	elseif self.showingFowardContainer then
		theTI := app.myHandHeldShipLanderGuiAgent.myHandHeldShipLanderAgent.myTI_FWD;
		self.lblDamage.caption := 'Damage (Forward)';	
	endif;
	
	self.txtDamage.text := null;									// 05/09/2011 cnwmh5 #27399
	
	if theTI &lt;&gt; null then
	// 26/08/2009 	cnwsh3 		CCMS SFW1066 PAR20321 - Recording Damage Details Changes.
		//self.tblDamage.setTableFromTI(theTI.allDamageInstances);
		self.tblDamage.setTableFromTI(theTI.allDamageInstancesByPos);
		self.txtDamage.text := theTI.remarks;
	endif;
	
	self.setLogicalFocus();
end;



</source>
