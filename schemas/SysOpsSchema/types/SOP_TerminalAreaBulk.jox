04 August 2022	navhl20	ChangeRequest 53921: MTN - GC Area Terminal Area Defn Transfer Areas.

*/

vars

begin
	inheritMethod();
	
	self.handleMenusForModalDisplay();
	self.populateCmbICAreas();
epilog

end;</source>
