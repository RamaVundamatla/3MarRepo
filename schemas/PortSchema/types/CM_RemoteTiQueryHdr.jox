<Class name="CM_RemoteTiQueryHdr" id="c562e91e-22a1-4545-bc72-a615afb61d80">
    <superclass name="CM_RemoteDataHdr"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>&lt;display&gt;Tracked Item Query&lt;/display&gt;</text>
    <DbClassMap file="remoteDataProcessing"/>
    <CompAttribute name="allTis" id="967dc81a-1673-4ff9-8ae2-38a78dbf3ec2">
        <type name="StringArray"/>
        <access>readonly</access>
    </CompAttribute>
    <PrimAttribute name="tagAttributes" id="e7e1e4d1-e6ec-4307-ba2c-0c5fd85a9f3d">
        <length>31</length>
        <embedded/>
        <type name="String"/>
        <access>readonly</access>
    </PrimAttribute>
    <JadeMethod name="getMessageResponseType" id="b3d59041-06c4-4d28-8517-1b240c84d880">
        <source>getMessageResponseType(): String;

vars

begin
	return CM_RemoteDataManager.TIQUERYRSP;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getTiQueryResponse" id="e23e942d-d490-4233-b713-7f10b98cbe89">
        <source>getTiQueryResponse(_error : Integer output; _errorTxt : String output) : String protected;
// 29/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
vars
	errStr,
	ti				: String;
	item			: CM_TrackedItem;
	myTerminal		: CM_Terminal;
	theResponse		: String;
	type,
	class			: String;
	logConstant		: Integer;
	isFound			: Boolean;
	taType			: Integer;

begin

	self.getAttributes(self.tagAttributes, class, type);
	self.getLogConstant(class, logConstant, taType);
	if logConstant = 0 then
		_error := Err_InvalidClass;
		_errorTxt := app.getErrorString1(_error, class);
		return null;
	endif;
	
	if type &lt;&gt; Type_Ti then
		_error := Err_InvalidType;
		_errorTxt := app.getErrorString1(Err_InvalidType, type);
		return null;
	endif; 

	if self.allTis.size &gt; 0 then
		theResponse := 
		self.formatAsXMLPrefix(XML_BDY) &amp;
		self.formatAsXMLPrefix(XML_TIQRYRSP) &amp; 
		'&lt;' &amp; XML_TIDTLS &amp; ' class=' &amp; class &amp; ' type="FULL"' &amp; '&gt;' &amp; CrLf;
		myTerminal := app.myPassport.myTerminal;
		if myTerminal = null then
			_error 		:= Err_InvalidTerminal;
			_errorTxt	:= app.getErrorString1(Err_InvalidTerminal, self.terminal);
			return null;
		endif;
		foreach ti in self.allTis do
			item := myTerminal.lookupTrackedItem(ti, logConstant, TI_STATE_NORMAL, null, false);
			if item = null then
				errStr := errStr &amp; ', ' &amp; ti;
			else
				theResponse := theResponse &amp; self.formatAsXML(XML_TI, item.getDetailForRemoteQuery(Type_Full, self.theVersion));
				isFound := true;
			endif;
		endforeach;

		if errStr.length &gt; 2 then
			// We have not found tracked item(s).
			_error := Err_TrackedItemsNotFound;
			_errorTxt := app.getErrorString1(Err_TrackedItemsNotFound, null) &amp; errStr[3 : end];
		endif;
	endif;
	if isFound then
		return theResponse &amp; self.formatAsXMLSuffix(XML_TIDTLS) &amp; self.formatAsXMLSuffix(XML_TIQRYRSP) &amp; self.formatAsXMLSuffix(XML_BDY);
	endif;
	return null;
end;</source>
        <access>protected</access>
        <Parameter name="_error" type="Integer" usage="output"/>
        <Parameter name="_errorTxt" type="String" usage="output"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="processExternal" id="583cb741-d135-4b26-a07d-6067d6345178">
        <updating/>
        <source>processExternal(_parseAgent : CM_RemoteParseAgent io) : String updating;

vars

	err			: Integer;
	errTxt		: String;
	response	: String;
	detail		: CM_RemoteDataDtl;
	headerCast	: CM_RemoteDataHdr;

begin

	response := inheritMethod(_parseAgent);
	if response = null then
		if _parseAgent.createTiQueryDetail(self) then
			response := self.getTiQueryResponse(err, errTxt);
			return self.doBuildMessage(xmlResponse(err, errTxt) &amp; response);
		endif;
		response := app.getErrorString1(Err_XML, 'tracked item query');
		return self.doBuildMessage(self.xmlResponse(Err_XML , response));
	endif;
	headerCast := self;
	return self.doBuildMessage(self.xmlDefaultResponse(headerCast, Err_XML , response));
			
end;</source>
        <Parameter name="_parseAgent" type="CM_RemoteParseAgent" usage="io"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="setProxyForTiQueryHdr" id="9f2efd3f-caf0-4954-a620-2d6a0327e567">
        <updating/>
        <source>setProxyForTiQueryHdr(_transferType : String;  _allTis : StringArray) updating;

vars

begin

	self.raiseExceptionIfNotTransient(method);
	_allTis.copy(self.allTis);
	self.tagAttributes	:= _transferType;
	
end;</source>
        <Parameter name="_transferType" type="String"/>
        <Parameter name="_allTis" type="StringArray"/>
    </JadeMethod>
</Class>
