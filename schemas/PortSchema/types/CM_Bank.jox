    <JadeMethod name="addStorageTimes" id="fc61eb6d-44b6-4eed-940b-387be6d2488f">
        <updating/>
        <source>addStorageTimes(_ti : CM_TrackedItem; _end, _start : TimeStamp; _agent : CMIF_StorageDatesAgent input) updating;
/*
Purpose:			

Date		Who		Reason
28 May 2024	navab1	BUG 64177
*/

vars
	arrDateTimes : TimeStampArray;
	timeStamp : TimeStamp;

begin
	create arrDateTimes transient;
	
	self.getStorageTimes(_end, _start, _ti, arrDateTimes);
		
	foreach timeStamp in arrDateTimes do
		_agent.addDate(timeStamp, false, _ti.operatorCode);
	endforeach;

	

epilog
	delete arrDateTimes;
end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_end" type="TimeStamp"/>
        <Parameter name="_start" type="TimeStamp"/>
        <Parameter name="_agent" type="CMIF_StorageDatesAgent" usage="input"/>
    </JadeMethod>
    <JadeMethod name="auditClass" id="7966273e-eff4-4834-9d6a-b1c411b501bb">
        <options>4</options>
        <source>auditClass(): Class typeMethod;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 January 2021	jlgndl1	Initial creation	TFS 50152

*/

vars

begin
	return CM_Bank;

epilog

end;</source>
        <ReturnType type="Class"/>
    </JadeMethod>
    <JadeMethod name="auditId" id="19e715c6-b4a3-40ae-b5ce-5b41a1e3b4b5">
        <source>auditId(): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 Jan 2017	cnwma1	TFS #2643 :JMT - Audit of Invoice Maintenance Set-up

*/

vars

begin
	return self.code;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="auditIdDisplay" id="8fc4ee7a-e0bd-46d9-8d76-db9513871a98">
        <source>auditIdDisplay(): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 Jan 2017	cnwma1	TFS #2643 :JMT - Audit of Invoice Maintenance Set-up

*/
vars
	auditIdStr : String;
begin

	auditIdStr := self.auditId();
	
	if auditIdStr &lt;&gt; null then
		return app.getErrorString(CM_Business_Unit) &amp; " - " &amp; auditIdStr;
	else
		return app.getErrorString(CM_Business_Unit) ;
	endif;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
