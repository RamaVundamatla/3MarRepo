    </Constant>
    <JadeMethod name="th2SchemaFromView" id="b49c4f0b-97e6-438c-8611-246e2c175b77">
        <source>th2SchemaFromView();
/*
----------   ----------  --------------------------------------------------
Created:	11 December 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
constants
	ViewFileName			= 'C:\temp\CM_TrackedItemView.rwv';
	SchemaFileName			= 'C:\temp\JRWInterfaceSchema.scm';
vars
	schemaFile	: File;
	lineStr,
	str			: String;
	typeDefnAttr,
	featureDefnAttr,
	defn,
	rootNode	: JadeXMLNode;
	xmlDoc		: JadeXMLDocument;
	xmlParser	: JadeXMLDocumentParser;
	portSchema	: Schema;
	featureClass	: Class;
begin
	app.initialize();
	portSchema := rootSchema.getSchema(PortSchemaName);
	create schemaFile transient;
	create xmlParser transient;
	create xmlDoc transient;
	
	schemaFile.fileName := SchemaFileName;
	xmlParser.parseDocumentFile(xmlDoc, ViewFileName);
	
	str := self.SchemaHeader1 &amp; CrLf &amp; self.th2SchemaFromViewTypeHdrs(xmlDoc) &amp; self.SchemaHeader2;
	
//	schemaFile.writeString(str);

	
	rootNode := xmlDoc.childNodes.first;
	foreach defn in rootNode.childNodes do
		//either a type definition (class) or a feature definition (attr or method belonging to class above
		if defn.JadeXMLElement.tagName = 'JRDReportingTypeDefn' then
			featureClass := null;
			foreach typeDefnAttr in defn.childNodes do
				if typeDefnAttr.JadeXMLElement.tagName  = 'typeName' then
					featureClass := portSchema.getClass(typeDefnAttr.JadeXMLElement.textData);
					break;
				endif;
			endforeach;
			
			if featureClass = null then
				app.raiseUnexpectedProgramError(class.name, method.name, 'Class not found in PortSchema "' &amp; typeDefnAttr.JadeXMLElement.textData &amp; '"');
				return;
			else
				app.writeStatement(class.name &amp; '::' &amp; method.name &amp; '-new class ');
			endif;
			
			
			continue;
		endif;
		
		if defn.JadeXMLElement.tagName = 'JRDReportingFeatureDefn' then
			
			
		elseif defn.JadeXMLElement.tagName = 'JRDReportingCollectionDefn' then
		
		elseif defn.JadeXMLElement.tagName = 'JRDScriptPrimitiveMethod' then
			
		else
			app.writeStatement(class.name &amp; '::' &amp; method.name &amp; '-unexpected node:' &amp; defn.JadeXMLElement.tagName);
		endif;
		
	endforeach;
	
	xmlDoc.inspectModal;
	
epilog
	delete schemaFile;
	
	delete xmlDoc;
	delete xmlParser;
	
	
end;


</source>
    </JadeMethod>
    <JadeMethod name="th2SchemaFromViewTypeDefs" id="9bdf9d6b-ab56-413f-922d-11374fa36980">
        <source>th2SchemaFromViewTypeDefs(_xmlDoc : JadeXMLDocument) : String;
/*
----------   ----------  --------------------------------------------------
Created:	11 December 2006 By cnwth2

Purpose:	return the type definition section of the schema

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
constants
	
vars
	volatilityStr,
	str				: String;
	typeDefnAttr,
	typeDefn,
	rootNode		: JadeXMLNode;
	portSchema		: Schema;
	featureClass	: Class;
begin
	portSchema := rootSchema.getSchema(PortSchemaName);
	str[10000] := '*';
	str := null;
	rootNode := _xmlDoc.childNodes.first;
	foreach typeDefn in rootNode.childNodes do
		//either a type definition (class) or a feature definition (attr or method belonging to class above
		if typeDefn.JadeXMLElement.tagName = 'JRDReportingTypeDefn' then
			str := str &amp; CrLf &amp; ')';
			featureClass := null;
			foreach typeDefnAttr in typeDefn.childNodes do
				if typeDefnAttr.JadeXMLElement.tagName  = 'typeName' then
					featureClass := portSchema.getClass(typeDefnAttr.JadeXMLElement.textData);
					break;
				endif;
			endforeach;
			
			if featureClass = null then
				app.raiseUnexpectedProgramError(class.name, method.name, 'Class not found in PortSchema "' &amp; typeDefnAttr.JadeXMLElement.textData &amp; '"');
				return null;
			endif;
			
			str := str &amp; featureClass.name &amp; ' completeDefinition' &amp; CrLf &amp;
										'	(' &amp; 
										'	jadeMethodDefinitions';
			
		elseif typeDefn.JadeXMLElement.tagName = 'JRDReportingFeatureDefn' then
			
		elseif typeDefn.JadeXMLElement.tagName = 'JRDReportingCollectionDefn' then
		
		elseif typeDefn.JadeXMLElement.tagName = 'JRDScriptPrimitiveMethod' then
		
		endif;
		
	endforeach;
	
	app.writeStatement(class.name &amp; '::' &amp; method.name &amp; '-str = ' &amp; str);
	return str;
epilog
	
	
end;


</source>
        <Parameter name="_xmlDoc" type="JadeXMLDocument"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="th2SchemaFromViewTypeHdrs" id="8c4ccbee-d825-4300-9c5b-4844db08dbfa">
        <source>th2SchemaFromViewTypeHdrs(_xmlDoc : JadeXMLDocument) : String;
/*
----------   ----------  --------------------------------------------------
Created:	11 December 2006 By cnwth2

Purpose:	return the type definition section of the schema

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
constants
	
vars
	volatilityStr,
	str				: String;
	typeDefnAttr,
	typeDefn,
	rootNode		: JadeXMLNode;
	portSchema		: Schema;
	featureClass	: Class;
begin
	portSchema := rootSchema.getSchema(PortSchemaName);
	
	rootNode := _xmlDoc.childNodes.first;
	foreach typeDefn in rootNode.childNodes do
		//either a type definition (class) or a feature definition (attr or method belonging to class above
		if typeDefn.JadeXMLElement.tagName &lt;&gt; 'JRDReportingTypeDefn' then
			continue;
		endif;
		
		featureClass := null;
		foreach typeDefnAttr in typeDefn.childNodes do
			if typeDefnAttr.JadeXMLElement.tagName  = 'typeName' then
				featureClass := portSchema.getClass(typeDefnAttr.JadeXMLElement.textData);
				break;
			endif;
		endforeach;
		
		if featureClass = null then
			app.raiseUnexpectedProgramError(class.name, method.name, 'Class not found in PortSchema "' &amp; typeDefnAttr.JadeXMLElement.textData &amp; '"');
			return null;
		endif;
		//TestSchemaExtract subclassOf Object transient, highestSubId = 1, highestOrdinal = 3, number = 8270;
		if featureClass.transient then
			volatilityStr := 'transient';
		else
			volatilityStr := 'persistent';
		endif;	
		str := str &amp; Tab &amp; featureClass.name &amp; ' subclassOf ' &amp; featureClass.getSuperclass().name &amp; ' '  &amp; volatilityStr &amp; ',' &amp; ' number = ' &amp; featureClass.number.String &amp; CrLf;

	endforeach;
	
	app.writeStatement(class.name &amp; '::' &amp; method.name &amp; '-str = ' &amp; str);
	return str;
epilog
	
	
end;


</source>
        <Parameter name="_xmlDoc" type="JadeXMLDocument"/>
        <ReturnType type="String"/>
    </JadeMethod>
</Class>
