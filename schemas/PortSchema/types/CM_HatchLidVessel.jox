<Class name="CM_HatchLidVessel" id="b1640d66-b2be-4c82-8b2e-8a0e0da1bc2c">
    <superclass name="CM_HatchLid"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>see ship</text>
    <DbClassMap file="vessel"/>
    <ExplicitInverseRef name="myCellularVesselStructure" id="9ab80e4d-963a-4730-aff4-7ee090c7600a">
        <kind>child</kind>
        <transientToPersistentAllowed/>
        <updateMode>manual</updateMode>
        <embedded/>
        <type name="CM_CellularVesselStructure"/>
        <access>readonly</access>
        <Inverse name="CM_CellularVesselStructure::allHatchlids"/>
    </ExplicitInverseRef>
    <JadeMethod name="cloneMySelf" id="b8a7d907-38fb-4dff-a220-9c4597e50c75">
        <updating/>
        <source>cloneMySelf(_newVessel : CM_CellularVesselStructure) : CM_HatchLidVessel updating;
// ---------------------------------------------------------------------------
// Created:		December 2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	newMe : SelfType;
	realBay, proxyBay : CM_Bay;
begin
	newMe := self.cloneSelf(false);
	newMe.myCellularVesselStructure := _newVessel;

	// set up my bays
	foreach realBay in self.allBays do
		proxyBay := _newVessel.allBaysByOrdinal[realBay.ordinalBay];
		if proxyBay &lt;&gt; null then
			newMe.allBays.add(proxyBay);
		endif;
	endforeach;	

	// set up my holds
	
	return newMe;
end;</source>
        <Parameter name="_newVessel" type="CM_CellularVesselStructure"/>
        <ReturnType type="CM_HatchLidVessel"/>
    </JadeMethod>
    <JadeMethod name="erase" id="b8bb55b9-7f76-4856-a6f2-0740d698fc51">
        <updating/>
        <source>erase(_eraseLevel: Integer) updating;
// ---------------------------------------------------------------------------
// Created:     16 July 2001 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	bayDefn : CM_Bay;
	objectArray:ObjectArray;
	object:Object;
begin
	exclusiveLock(self);
	create objectArray transient;
	foreach bayDefn in allBays do
		objectArray.add(bayDefn);
	endforeach;
	foreach object in objectArray do
		self.allBays.remove(object.CM_BayDefn);
	endforeach;
	foreach object in objectArray do
		object.CM_BayDefn.setOutboardSlots();
	endforeach;
	inheritMethod(_eraseLevel);
	
epilog
	delete objectArray;		// PAR #27874
	
end;</source>
        <Parameter name="_eraseLevel" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getSide" id="68d27f63-710e-437e-8962-f58cdcfbe2c9">
        <source>getSide(): Integer;
/*
------------------------------------------------------------------------
Created:			07 October 2003 by cnwdwq1
Purpose:			Returns 1 for port, 2 for centre, or 3 for starboard.
Parameters:		None
Returns:			Nothing
Changed On		Changed By		Reason
--------------		--------------		-----------------------------------------
---------------------------------------------------------------------------
*/

vars
	hatch : CM_HatchLid;
	hatches : CM_HatchLidArray;
	selfPos : Integer; 
	numHatches : Integer;
begin
	create hatches transient;
	self.allBays.first.getSortedHatchLids(hatches);
	if hatches.isEmpty then
		return null;
	endif;
	numHatches := hatches.size;
	selfPos := hatches.indexOf(self);
	if selfPos = null then
		return null;	//!!! WTF???
	endif;
	if selfPos = 1 then
		if numHatches = 1 then
			return JobSideCentre;
		else
			return JobSidePort;
		endif;
		
	elseif selfPos = 2 then
		if numHatches = 2 then
			return JobSideStarboard;
		elseif numHatches = 3 then
			return JobSideCentre;
		endif;
		
	elseif selfPos = 3 then
		return JobSideStarboard;
	else
		return null;	//God knows!
	endif;
epilog
	delete hatches;
end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="importFromXMLDocReference" id="3df079e8-3de6-4a8a-8c2f-e778fe107a1a">
        <updating/>
        <source>importFromXMLDocReference(_property: Property; _xmlElement: JadeXMLElement input) updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
19 April 2012	cnwer1	Initial creation CCMS MES 1035

*/

vars
	bayElement,
	 childElement		: JadeXMLElement;
	allChildElements : JadeXMLElementArray;
	bay : CM_BayDefn;
begin

	if _property = CM_HatchLid::allBays then
		create allChildElements transient;
		_xmlElement.getAllElementsByTagName(CM_BayDefn.name,allChildElements);
		foreach childElement in  allChildElements do
			bayElement:=childElement.getElementByTagName(CM_BayDefn::id.name);
			if bayElement &lt;&gt; null then
				bay:=self.myCellularVesselStructure.allBaysByLabel[bayElement.textData];
				if bay &lt;&gt; null and not self.allBays.includes(bay) then
					self.allBays.add(bay);
				endif;
			endif;
		endforeach;
	elseif _property = CM_HatchLid::allHolds then
	
	else
		inheritMethod(_property, _xmlElement);
	endif;
epilog
	delete allChildElements;
end;</source>
        <access>protected</access>
        <Parameter name="_property" type="Property"/>
        <Parameter name="_xmlElement" type="JadeXMLElement" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="b5f834f1-78ee-4730-b40b-aaab71a8609f">
        <updating/>
        <source>setForCreate(	_proxy: SelfType;
				_realVesselVoyage : CM_Object; 
				_passport : CM_Passport input) updating;

vars
	 aProxyBay, aRealBay : CM_Bay;
	expectedEdition:Integer;
begin
	self.myCellularVesselStructure:=_realVesselVoyage.CM_CellularVesselStructure;
	
	if self.myCellularVesselStructure &lt;&gt; null then
		// link the ordinal bays
		foreach aRealBay in self.myCellularVesselStructure.allBaysByOrdinal do
			if aRealBay.ordinalBay &gt;= _proxy.ordinalStartBay  
			and aRealBay.ordinalBay &lt;= _proxy.ordinalEndBay  then
				self.allBays.add(aRealBay);
			endif;
		endforeach;
	endif;
	
	inheritMethod(_proxy, _realVesselVoyage, _passport);
	
end;</source>
        <Parameter name="_proxy" type="SelfType"/>
        <Parameter name="_realVesselVoyage" type="CM_Object"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="ca6738a5-97c5-4398-bda4-cc79010efd4a">
        <updating/>
        <source>setForUpdate(_proxy: SelfType; _passport : CM_Passport input) updating;

vars
	proxyBay,bayDefn:CM_Bay;
begin
	inheritMethod(_proxy,_passport);
	
	// add new bays
	foreach proxyBay in _proxy.allBays do
		bayDefn := proxyBay.pxyGetRealObject();
		if bayDefn = null then
			continue;
		endif;
		if not self.allBays.includes(bayDefn) then
			self.allBays.add(bayDefn);
			if not self.allHolds.includes(bayDefn.CM_BayDefn.myHold) then
				self.allHolds.add(bayDefn.CM_BayDefn.myHold);
			endif;
		endif;
	endforeach;
	
	foreach bayDefn in self.allBays do
		bayDefn.setOutboardSlots();
	endforeach;
end;</source>
        <Parameter name="_proxy" type="SelfType"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setMyVessel" id="b81c0ea5-21b9-4ef3-8920-947970164049">
        <updating/>
        <source>setMyVessel(_theVessel : CM_CellularVesselStructure ) updating;
// ---------------------------------------------------------------------------
// Created:		February 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin
	if _theVessel &lt;&gt; self.myCellularVesselStructure then
		self.myCellularVesselStructure := _theVessel;
	endif;
end;</source>
        <Parameter name="_theVessel" type="CM_CellularVesselStructure"/>
    </JadeMethod>
</Class>
