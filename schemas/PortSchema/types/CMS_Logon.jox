    <JadeMethod name="bExit_click" id="d0796590-3722-4b2e-8d1e-01308fa18336">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>bExit_click(btn: Button input) updating;

vars
    i:Integer;
   
begin
	if app.isDevelopmentSystem()
	and app.computerName().toUpper() = "CNWDAD1A"
	then
		self.modalResult	:=	IDCANCEL;
		self.unloadForm();
	else
	    i := app.msgBox(app.getErrorString(WARN_CLOSEDOWN),
	                    "Closing Down",
	                    MB_CRITICAL + MB_YESNO);
	    if i = MB_YES then
			self.modalResult:=IDCANCEL;
			self.unloadForm;
	    else
	        self.userID.setFocus;
	    endif;
	endif;
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="bOk_click" id="232ccc6b-780b-4255-97bc-28e803003891">
