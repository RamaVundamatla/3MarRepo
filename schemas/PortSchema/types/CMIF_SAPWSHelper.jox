    <JadeMethod name="setFromActivityHistory" id="a319da76-b686-4f90-8d06-add8d1100d10">
        <updating/>
        <source>setFromActivityHistory(_activityHistory : CM_ActivityHistoryExtInterface) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 April 2019	jlger1	Initial creation

*/

vars

begin
	if _activityHistory = null then
		return;
	endif;
	
	self.getExternalWebServiceCMIF(_activityHistory.request);
	
	self.getExternalWebServiceCMIF(_activityHistory.response);
	
epilog

end;</source>
        <Parameter name="_activityHistory" type="CM_ActivityHistoryExtInterface"/>
    </JadeMethod>
</Class>
