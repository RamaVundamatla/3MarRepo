    <JadeMethod name="getWODetails" id="05295e7d-af27-402d-8bb2-be4d22ffb4eb">
        <updating/>
        <source>getWODetails(_workorderName : String; _default : Boolean output; _trantype : CM_TransactionType output) updating, protected;
/*
Purpose:	TFS 39518		
Date				Who			Reason
JULY 2018		CNWAB1		Initial creation
*/

vars
	tranType : CM_TransactionType;
begin
	if _workorderName = CM_FinancialObject.Extract_Default then
		_default := true;
	else
		tranType := findWOType(_workorderName);
		if tranType = null then
			self.validationError("Invalid work order name", _workorderName);
		endif;
	endif;

	_trantype := tranType;
end;
</source>
