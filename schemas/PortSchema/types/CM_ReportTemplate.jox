    <JadeMethod name="cloneJadeReport" id="5f4cf0a6-d68b-47f8-971e-3d12deaa5d3d">
        <updating/>
        <source>cloneJadeReport(_pxyJadeReport : JadeReport) : JadeReport updating;
// ---------------------------------------------------------------------------
// Created:     22 October 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	pxyPrintData,
	realPrintData	: JadePrintData;
	
begin
	self.myJadeReport := _pxyJadeReport.cloneSelfAs(CM_JadeReport, false).CM_JadeReport;
	
	foreach pxyPrintData in _pxyJadeReport.printArray do
		if pxyPrintData.isKindOf(JadePrintPage) then
			realPrintData := pxyPrintData.cloneSelfAs(CM_JadePrintPage, false).JadePrintData;
			//PAR18472 - cnwsh3 Should not save the paper source at the time the report was printed
			//as this may printed to different printer at a later date.
			realPrintData.CM_JadePrintPage.paperSource := 0;
		else
			realPrintData := pxyPrintData.cloneSelfAs(CM_JadePrintDirect, false).JadePrintData;
		endif;
		self.myJadeReport.printArray.add(realPrintData);
	endforeach;
	
	self.completedDateTime := app.actualTimeServer();
	return self.myJadeReport;
	
end;</source>
        <Parameter name="_pxyJadeReport" type="JadeReport"/>
        <ReturnType type="JadeReport"/>
    </JadeMethod>
    <JadeMethod name="convertJadeRptToPDF" id="94bdb030-f95c-4947-98ff-c7fab3df5074">
        <source>convertJadeRptToPDF() : Binary;
// -------------------------------------------
// Created 19 April 2005 by cnwdvb1
// -------------------------------------------
vars

	printer 			: CM_PrinterDef;
	binary				: Binary;
	bgpReportRequest	: BGP_ReportRequest;
	tmpReportTemplate	: CM_ReportTemplate;
	
	//24 Oct 2012	NDL	Par 30580
	bgpCont : BGP_ReportController;
	now : TimeStamp;

begin

	printer := app.getPDFPrinter();
	now := app.actualTimeServer();	// 16 Sept 2016	cnwns1	TFS 488 - Multi Timezone Support
	if printer = null then
		app.raiseCMException(PDF_Printer_required, null, null);
		return null;
	endif;
	
	create tmpReportTemplate transient;
	create bgpReportRequest transient;
	
	create bgpCont transient;	//24 Oct 2012	NDL	Par 30580
	bgpCont.setForPre(now,bgpReportRequest);	//24 Oct 2012	NDL	Par 30580

//	create reportTemplate transient;
	binary := bgpReportRequest.doPrintPDF(printer, self.myJadeReport, tmpReportTemplate, true);

	return binary;

epilog
	delete tmpReportTemplate;
	delete bgpReportRequest;
	delete bgpCont;	//24 Oct 2012	NDL	Par 30580
end;</source>
        <ReturnType type="Binary"/>
    </JadeMethod>
    <JadeMethod name="createAndRunAdhocBGPReport" id="b3c767a2-bba1-4360-90e6-a84018601410">
        <updating/>
        <source>createAndRunAdhocBGPReport(	_name : String;
							_description : String;
							_printerName : String;
							_destination : Integer;
							_outputType : Integer;
							_filter : CMQF_AnyDataObject;
							_userCodeToRunAs : String
							) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 June 2013	cnwndl1	Initial creation	Par 31562

*/

vars

	queryRep : CM_QryReport;

begin

	self.name				:= _name[1:30];
	self.description		:= _description;
	self.outputDestination	:= _destination;	
	self.createdDateTime	:= app.actualTimeServer;
	self.userCodeToRunAs	:= _userCodeToRunAs;
	
	create self.myReportRequest persistent;

	create queryRep as CM_QryReportSystem;
	queryRep.CM_QryReportSystem.setForAdhocBGPReport( _name );

	// Initialise request. ( and clones the passed in filter )
	self.myReportRequest.init(_filter, queryRep, null, _destination, null, _printerName, _outputType);
	// copy the cloned filter back to the query rep.
	queryRep.setMyFilterObject(self.myReportRequest.myFilter);
	
		
end;</source>
        <Parameter name="_name" type="String"/>
        <Parameter name="_description" type="String"/>
        <Parameter name="_printerName" type="String"/>
        <Parameter name="_destination" type="Integer"/>
        <Parameter name="_outputType" type="Integer"/>
        <Parameter name="_filter" type="CMQF_AnyDataObject"/>
        <Parameter name="_userCodeToRunAs" type="String"/>
    </JadeMethod>
    <JadeMethod name="createAndRunBackgroundRpt" id="43dea708-26b1-406e-a1bd-107c12b7b730">
        <updating/>
        <source>createAndRunBackgroundRpt(	_isForPackage			: Boolean;
							_name,
							_description,
							_profileName,
							_printerName,
							_networkFilePath		: String;
							_destination,
							_outputType 			: Integer;
							_stopEmailWhenNoDataRpt	: Boolean;
							_filter					: CMQF_FilterReports;
							_reportDef 				: CM_QryReport; 
							_extraDetail 			: CM_ExtraDetail; 
							_emailTemplate			: CM_EmailTemplate input;
							_userCodeToRunAs		: String;
							_allUsersToGetOutput	: CM_UserSet;
                            _ftpEntity:CM_FTPEntity) updating;
// -------------------------------------------
// Created 10 December 2004 by cnwdvb1
// -------------------------------------------
vars

	user			: CM_User;
	email			: CM_EmailTemplate;

begin
 
 	// Copy over some of the basic details.
 //	if not _reportDef.canBeRunInBackground then
 //	if _reportDef.reportProcessType = CM_QryReport.ReportProcessType_Foreground then
//		app.raiseCMException1(Full_Replacement_Message, _reportDef.reportName &amp; ' cannot be run in the background', null, null);
//	endif;
 	
	self.name				:= _name[1:30]; // adm 010808 PAR 17648
	self.description		:= _description;
	
	// Store away destination so we know what 
	// output of report is after bgp is gone.
	self.outputDestination	:= _destination;
	
	self.stopEmailWhenNoDataRpt := _stopEmailWhenNoDataRpt;

	
	// Don't see background report inverse.
	//self.myQryReport		:= _reportDef;
	
	self.qryReportType := _reportDef.reportName;
	
	// myUserToRunAs isn't set because it is only used
	// by templates and we are running a background report here.
	self.myUserToRunAs		:= null;
	self.createdDateTime	:= app.actualTimeServer;
	self.networkFilepath	:= _networkFilePath;
	// Reports to be BGP run need the look up user code.
	self.userCodeToRunAs	:= _userCodeToRunAs;
	
    //Add FTP Entity mapping                //MTN-36668
    self.myFTPEntity  := _ftpEntity;        //MTN-36668
    
	// Clone the email stuff.
	if _emailTemplate &lt;&gt; null then
		email := _emailTemplate.cloneSelf(false);
		email.cloneReferences(_emailTemplate, false);
		email.setReportTemplate(self);
	endif;
	
	// Set who is getting the output.
	_allUsersToGetOutput.copy(self.allUsersToGetOutput);
	
	// Create menuUserReport objects for users to get output
	// and validate whether they are still allowed to see report.
	if not self.createMenuUserReportsForOutput(_filter, _reportDef) then
		app.raiseCMException(User_with_suffi_acces_send_out, null, null);
		return;
	endif;
	
	// Create the processing request.
	if _isForPackage then
		create self.myReportRequest as BGP_ReportRequestPackage persistent;
	else
		create self.myReportRequest persistent;
	endif;
	
	// Initialise request.
	self.myReportRequest.init(_filter, _reportDef, _profileName, _destination, _extraDetail, _printerName, _outputType);
		
end;</source>
        <Parameter name="_isForPackage" type="Boolean"/>
        <Parameter name="_name" type="String"/>
        <Parameter name="_description" type="String"/>
        <Parameter name="_profileName" type="String"/>
        <Parameter name="_printerName" type="String"/>
        <Parameter name="_networkFilePath" type="String"/>
        <Parameter name="_destination" type="Integer"/>
        <Parameter name="_outputType" type="Integer"/>
        <Parameter name="_stopEmailWhenNoDataRpt" type="Boolean"/>
        <Parameter name="_filter" type="CMQF_FilterReports"/>
        <Parameter name="_reportDef" type="CM_QryReport"/>
        <Parameter name="_extraDetail" type="CM_ExtraDetail"/>
        <Parameter name="_emailTemplate" type="CM_EmailTemplate" usage="input"/>
        <Parameter name="_userCodeToRunAs" type="String"/>
        <Parameter name="_allUsersToGetOutput" type="CM_UserSet"/>
        <Parameter name="_ftpEntity" type="CM_FTPEntity"/>
    </JadeMethod>
    <JadeMethod name="createMenuUserReportsForOutput" id="e83403ee-a39a-4005-b260-d2c4bde41961">
        <source>createMenuUserReportsForOutput(_filter	: CMQF_FilterReports; _qryReport : CM_QryReport) : Boolean;
// -------------------------------------------
// Created 13 December 2004 by cnwdvb1
// -------------------------------------------
vars

	root			: CM_MenuRoot;
	user			: CM_User;
	menuUserReport	: CM_MenuUserReport;
	rtnValue		: Boolean;
	parent			: CM_MenuEntity;

begin

	foreach user in self.allUsersToGetOutput do
		// Only do validation when we have a valid filter.
		if _filter &lt;&gt; null and not self.validateUserAgainstFilter(user, false, _filter, _qryReport) then
			continue;
		endif;
		
		root 	:= user.myMenuRootBGRCurrent;
		parent	:= root;
		
		if root &lt;&gt; null then
			create menuUserReport persistent;
			// Not a proxy today.
			menuUserReport.setForProxy(self, root, parent);	
			user.causeEvent(CM_User.BGP_REPORT_CREATED, false, menuUserReport);
			rtnValue := true;
		endif;
	endforeach;
	
	return rtnValue;


end;</source>
        <Parameter name="_filter" type="CMQF_FilterReports"/>
        <Parameter name="_qryReport" type="CM_QryReport"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="delete" id="59204e03-40e9-4873-b58a-f28f3d4244bc">
        <updating/>
        <source>delete() updating;
// -------------------------------------------
// Created 14 December 2004 by cnwdvb1
// -------------------------------------------
vars

begin

	if self.isTransient() then
		self.allMenuUserReports.purge;
		delete self.myReportRequest;
		return;
	endif;


end;</source>
    </JadeMethod>
    <JadeMethod name="emailNoDataRpt" id="aa6529e3-39fe-457c-9abc-c96afb1523c2">
        <source>emailNoDataRpt() : Boolean;
// -------------------------------------------
// Created 04 April 2005 by cnwdvb1
// -------------------------------------------
vars

begin

	return not self.stopEmailWhenNoDataRpt;

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="erase" id="7d6de2ed-6670-4138-9f83-3c262c9bde51">
        <updating/>
        <source>erase(_eraseLevel: Integer) updating;
// -------------------------------------------
// Created 17 December 2004 by cnwdvb1
// -------------------------------------------
vars

	user 	: CM_User;
	report	: CM_MenuUserItem;
	
begin

		// Persistent;
	if self.myReportRequest &lt;&gt; null then
		if (not self.tryLock(self.myReportRequest, Exclusive_Lock, Transaction_Duration, LockTimeout_Server_Defined)) then
			app.raiseCMException1(BGP_STILL_PROCESSING, self.name, null, null);
			return;
		endif;
		
		// Add check to make sure that we don't delete the request while the current
		// process is running this thread from the request itself.
		// Par 9999 DVB changed 15/04/05
		if self.myReportRequest.myProcessingController = null then
			delete self.myReportRequest;
		endif;
	endif;
	inheritMethod(_eraseLevel);


end;</source>
        <Parameter name="_eraseLevel" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getDataAsBinary" id="4da4acde-1943-44fc-b6ed-7057d10d9857">
        <source>getDataAsBinary() : Binary;
// -------------------------------------------
// Created 18 April 2005 by cnwdvb1
// -------------------------------------------
vars

begin

	if self.myJadeReport &lt;&gt; null then
		return self.convertJadeRptToPDF();
	else
		return self.allMenuCSVFileData.getDataAsBinary();
	endif;


end;</source>
        <ReturnType type="Binary"/>
    </JadeMethod>
    <JadeMethod name="getName" id="f49d5016-244f-475b-a651-5a5c444bf2df">
        <source>getName(): String;
// -------------------------------------------
// Created 28 October 2005 by cnwdvb1
// -------------------------------------------
vars

begin
	return inheritMethod() &amp; ' ' &amp; self.name;


end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getReportType" id="8e43c6c9-f1b2-472a-9fe5-94c2de0d5d53">
        <source>getReportType() : String;
// -------------------------------------------
// Created 18 April 2005 by cnwdvb1
// -------------------------------------------
vars

begin

	if self.myJadeReport &lt;&gt; null then
		return 'PDF';
	elseif not self.allMenuCSVFileData.isEmpty() then
		if self.outputDestination = JadeReportWriterReport.HTML then
			return 'HTML';
		elseif self.outputDestination = JadeReportWriterReport.CSV then
			return 'CSV';
		elseif self.outputDestination = JadeReportWriterReport.RTF then
			return 'RTF';
		elseif self.outputDestination = JadeReportWriterReport.XML then
			return 'XML';
		elseif self.outputDestination = CM_QryReport.PDF_Format then
			return 'PDF';
		endif;
	endif;
	
	return 'Unknown';
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getUserToRunAgainst" id="67fbccbf-0f02-498e-a8f5-0a66548154a8">
        <source>getUserToRunAgainst() : CM_User;
// -------------------------------------------
// Created 16 December 2004 by cnwdvb1
// -------------------------------------------
vars

begin

	if self.myUserToRunAs &lt;&gt; null then
		return self.myUserToRunAs;
	endif;
	
	return app.myRoot.allUsers[self.userCodeToRunAs];


end;</source>
        <ReturnType type="CM_User"/>
    </JadeMethod>
    <JadeMethod name="isReportTemplate" id="1161e9a0-7fdb-458f-bc91-d21f6d42da92">
        <source>isReportTemplate() : Boolean;
// -------------------------------------------
// Created 22 February 2005 by cnwdvb1
// -------------------------------------------
/*	Because a report template is used as a holder for 
	background reports as well as for static templates
	this method will tell us what its use is. */
vars
	mu : CM_MenuUserItem;
begin
	// Deliberately do not check for null here.  Assumption is that
	// should always have.  If we don't we want to know why.
	// Users can run report templates and save them.  In this case we don't want
	// we consider this a report template that we don't want to touch so return true.
	//Used the following script to confirm this.
	/*  foreach mu in  self.allMenuUserReports do
			if mu.myMenuRoot.isKindOf(CM_MenuRootUserBackgroundReps) then
				write mu.String &amp; ' ' &amp; mu.myMenuRoot.CM_MenuRootUserBackgroundReps.myUser.code &amp; ' ' ;
			endif;
		endforeach;*/
	if self.myReportRequest = null then
		return false;
	endif;
	
	return self.myReportRequest.isTemplate();
	
	/*
	if self.myUserToRunAs &lt;&gt; null then
		return true;
	endif;
	
	return false;
	*/
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="myUserToRunAs" id="40831240-7a57-4112-9521-c8a7c5ef84f1">
        <methodInvocation>mapping</methodInvocation>
        <source>myUserToRunAs(set: Boolean; _value: CM_User io) mapping;
// -------------------------------------------
// Created 16 December 2004 by cnwdvb1
// -------------------------------------------
vars

	autoTask : CM_AutoTask;

begin

	// This method removes this template from a autotask selected
	// reports for a user because the user to run as has changed.
	if set then
		if not self.isTransient() and _value &lt;&gt; null and _value &lt;&gt; self.myUserToRunAs then
			// Must be in transaction state
			foreach autoTask in self.allAutoTasks do
				self.exclusiveLock(autoTask);
				autoTask.CM_AutoTaskRunReports.removeReportTemplate(self);
			endforeach;
		endif;
	endif;


end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="CM_User" usage="io"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="5dd63b79-ab75-4aff-bbc5-a935af42fe54">
        <source>pxyCreateUpdateProxy(): SelfType;
// -------------------------------------------
// Created 13 December 2004 by cnwdvb1
// -------------------------------------------
// 20/04/2011	cnwmh5		PAR #27401 - Add code to handle prossible exceptions occurring when
//							trying to create the proxy

vars

	pxyMenuUserReport,
	menuUserReport		: CM_MenuUserItem;
	pxyReportTemplate	: CM_ReportTemplate;
	completedOK			: Boolean;
	
begin
	
	pxyReportTemplate := inheritMethod();
	
	foreach menuUserReport in self.allMenuUserReports do
		pxyMenuUserReport := menuUserReport.pxyCreateUpdateProxy();
		pxyMenuUserReport.CM_MenuUserReport.setReportTemplate(pxyReportTemplate);
	endforeach;
	
	self.allUsersToGetOutput.copy(pxyReportTemplate.allUsersToGetOutput);
	pxyReportTemplate.myUserToRunAs := self.myUserToRunAs;
	
	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return pxyReportTemplate;

epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete pxyReportTemplate;
	endif;
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="sendCreatedEvent" id="4a96f500-ea19-46f0-a8a9-13aacdd5fde1">
        <source>sendCreatedEvent(_immediate : Boolean);
// -------------------------------------------
// Created 13 December 2004 by cnwdvb1
// -------------------------------------------
vars

	user 	: CM_User;
	menu	: CM_MenuUserItem;

begin

	foreach menu in self.allMenuUserReports do
		user := menu.CM_MenuUserReport.getMyUser();
		if user = null then
			continue;
		endif;
		user.causeEvent(CM_User.BGP_REPORT_CREATED, _immediate, menu);	
	endforeach;


end;</source>
        <Parameter name="_immediate" type="Boolean"/>
    </JadeMethod>
