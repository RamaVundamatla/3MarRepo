/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 January 2025	navhn30	Initial creation

*/

vars
	tiSet	: CM_TISet;
	isoType	: CM_ISOType;
	ti 		: CM_TrackedItem;
	isoTypes: CM_ISOTypeByCodeDict;
begin
	if _yaData.isEmpty() then
		return true;
	endif;
	
	if self.myTrackedItem = null or not self.myTrackedItem.isTILC() then
		return false;
	endif;
	
	create tiSet transient;
	self.myTrackedItem.CM_TILC.getAllOnboardTIs(tiSet);
	
	create isoTypes transient;
	
	foreach ti in tiSet discreteLock do
		if ti.getISOTypeObject() &lt;&gt; null then
			isoTypes.add(ti.getISOTypeObject());
		endif;
	endforeach;
	
	
	foreach isoType in isoTypes do
		if _yaData.matches(isoType) then
			return true;
		endif;
	endforeach;
	
	return false;
	

epilog
	delete tiSet;
	delete isoTypes;

end;</source>
