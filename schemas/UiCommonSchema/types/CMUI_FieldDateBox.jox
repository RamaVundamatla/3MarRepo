    <JadeMethod name="buildSelf" id="a14946f2-c29b-4a58-b77f-2ebd7f6c0b54">
        <updating/>
        <source>buildSelf() updating, protected;
// --------------------------------------------------------------------------------
// Created:		16 February 2006 by cnwdad1
//
// Purpose:		Instantiates the appropriate controls, and sets them all up.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	controlWidth	: Real;
	controlLeft		: Real;
	editMaskObj		: CMUI_FieldDateMaskControl;
	
begin
	inheritMethod();
	
	create editMaskObj transient;
	
	self.myDateBox		:=	editMaskObj;
	editMaskObj.parent	:=	self;
	self.form.addControl(editMaskObj);
	controlLeft			:=	self.myLabel.left + self.myLabel.width + CMUI_FieldFrame.HORIZONTAL_SPACING;
	controlWidth		:=	self.clientWidth() - controlLeft;
	editMaskObj.move(controlLeft, 0, controlWidth, editMaskObj.height);
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="getDate" id="d6825324-3d47-4c01-a702-0c3221b2e598">
        <source>getDate(): Date;
// --------------------------------------------------------------------------------
// Created:		16 February 2006 by cnwdad1
//
// Purpose:		Refer to superclass implementation.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return self.myDateBox.getDate();
end;</source>
        <ReturnType type="Date"/>
    </JadeMethod>
    <JadeMethod name="getEmbeddedControl" id="81c866c0-317a-4c6c-9268-c34df9a3ee4a">
        <source>getEmbeddedControl(): Control;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
15 July 2009	cnwdap1	Initial creation

*/

vars

begin
	return self.myDateBox;
epilog

end;</source>
        <ReturnType type="Control"/>
    </JadeMethod>
    <JadeMethod name="setIsEnabled" id="49c4fc01-3b8d-4e47-ad50-8eafcbbc12ec">
        <updating/>
        <source>setIsEnabled(_isEnabled: Boolean) updating;
// --------------------------------------------------------------------------------
// Created:		01 March 2006 by cnwdad1
//
// Purpose:		Refer to the superclass implementation.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.myDateBox.enabled	:=	_isEnabled;
end;</source>
        <Parameter name="_isEnabled" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setTabOrder" id="bdbf067e-a9a2-427d-a69a-a5896fdd25bc">
        <source>setTabOrder(_tabOrder: Integer):Integer;
// --------------------------------------------------------------------------------
// Created:		27 February 2006 by cnwdad1
//
// Purpose:		Refer to superclass implementation.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	tabOrder	: Integer;
	
begin
	tabOrder	:=	inheritMethod(_tabOrder);
	tabOrder	:=	tabOrder + 1;
	self.myDateBox.tabIndex	:=	tabOrder;
	
	return tabOrder;
end;</source>
        <Parameter name="_tabOrder" type="Integer"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setValue" id="bee593f3-fcdd-43fc-a87d-f7f14661a34f">
        <updating/>
        <source>setValue(_value: Any) updating;
// --------------------------------------------------------------------------------
// Created:		22 February 2006 by cnwdad1
//
// Purpose:		Sets the receiver's field value.
//
// Parameters:	_value - The field value to set.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.myDateBox.setDate(_value.Date);
end;</source>
        <Parameter name="_value" type="Any"/>
    </JadeMethod>
    <JadeMethod name="setWidths" id="f54aefdb-3729-425e-a2f4-40c731a630a1">
        <updating/>
        <source>setWidths(_controlWidth: Integer; _labelWidth: Integer) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
10 July 2009	cnwdap1	Initial creation

*/

vars

begin
	inheritMethod(_controlWidth, _labelWidth);
	self.myDateBox.width	:= getTextExtent(self.TEXTEXTENT[1:self.myDateBox.text.length]);
//	self.myDateBox.width	:= getTextExtent(self.myDateBox.text);
	self.myDateBox.left		:= self.width - _controlWidth;
epilog

end;</source>
        <Parameter name="_controlWidth" type="Integer"/>
        <Parameter name="_labelWidth" type="Integer"/>
    </JadeMethod>
