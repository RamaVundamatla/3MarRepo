    </JadeMethod>
    <JadeMethod name="validateForUpdate" id="c6eaa1b8-7ce1-4580-87c1-9a97856a4c16">
        <source>validateForUpdate();
// ---------------------------------------------------------------------------
// Created:     16 July 2001 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 29/6/2006	RBarr		CM_Port::codeDisplay attribute obsolete, rename codeBayPlanDisplay to portCode
// ---------------------------------------------------------------------------
vars

begin
	if self.code = null then
//		app.raiseCMException1(REQUIRED_FIELD, 'Port Code', null, null);
		app.raiseCMException(Input_required_field_prtCode, null, null); // cnwdb2	PAR 35364


	endif;
	
	if self.portCode = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Port Code (3 Char)', null, null);
		app.raiseCMException(Input_required_field_prtCde3, null, null); // cnwdb2	PAR 35364


	endif;
	
	if self.description = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Port Description', null, null);
		app.raiseCMException(Input_required_field_portDesc, null, null); // cnwdb2	PAR 35364


	endif;
	if self.myCountry = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Country', null, null);
		app.raiseCMException(Input_required_field_country, null, null); // cnwdb2	PAR 35364


	endif;
	
	if self.code.length() &lt; 3 then	// Par17405. Port code (3 chars) should match code (5 characters = country code + code)
		app.raiseCMException(ERR_PortCodeMatching, app.getErrorString(Info_PortCode), null);
	elseif self.code[3:3] &lt;&gt; self.portCode then
		app.raiseCMException(ERR_PortCodeMatching, app.getErrorString(Info_PortCode), null);
	endif;
	
	
end;</source>
    </JadeMethod>
</Class>
