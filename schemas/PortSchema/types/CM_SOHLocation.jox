    <JadeMethod name="getTotalVolumeActual" id="9f82c133-dc12-46ad-b61c-b0f320cbd6ef">
        <source>getTotalVolumeActual() : Decimal;
//-----------------------------------------
//Created: October 2002 By: cnwgd1
//-----------------------------------------
vars
	ti			: CM_TrackedItem;
