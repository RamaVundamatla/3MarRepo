    <JadeMethod name="getVersionFull" id="1392e316-f085-4fef-94b0-a01b13841b24">
        <source>getVersionFull(): String;
// --------------------------------------------------------------------------------
// Created:		16 September 2002 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
