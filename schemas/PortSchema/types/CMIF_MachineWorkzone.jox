    <JadeMethod name="delete" id="c61b3489-8092-4877-83fb-7c6f4ee99d6f">
        <updating/>
        <source>delete() updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
28 August 2009	cnwer1	Initial creation

*/

vars

begin
	if self.myWorkzoneFrame &lt;&gt; null and
		self.myWorkzoneFrame.userObject = self then
		self.myWorkzoneFrame.userObject:=null;
		
	endif;
epilog

end;</source>
    </JadeMethod>
