Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 March 2016	cnwndl1	Initial creation	TFS 1407

*/

vars

begin

	self.location := _location;

epilog

end;</source>
        <Parameter name="_location" type="String"/>
    </JadeMethod>
