    <JadeMethod name="idFilter" id="61a89710-ca69-4e8c-8177-50135b67788b">
        <source>idFilter(_filterID : String; _tiID : String) : Boolean;

vars
	pos : Integer;
begin
	if _filterID &lt;&gt; null and _tiID &lt;&gt; null then
		pos := _tiID.pos(_filterID, 1);
		if pos &lt;&gt; 1 then
			return false;
		endif;
	endif;
	return true;
end;</source>
        <Parameter name="_filterID" type="String"/>
        <Parameter name="_tiID" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="includeObject" id="00efc669-6ba7-46f8-947a-cff8d044f194">
        <updating/>
        <source>includeObject(_vehicleVisit : CM_VehicleVisitRecord; _passport : CM_Passport): Boolean updating;
/*
----------   ----------  --------------------------------------------------
Created:	28 June 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
----------   ----------  --------------------------------------------------
13/05/2022  navhl20  	TFS 53430  EUP - Sub Carrier registration in MTN
13 Dec 2022 navmp20     ChangeRequest 55580: EUP - Inspection App checks - Interface and MTN changes
17 Nov 2023 navlc30     ChangeRequest 61254: EUP | FR | 54329 | VBS - Pending issues - Issue 8
11 Apr 2025 navma1  	MTN-34621 MTN - 1081 dead lock on CM_EIRNumberDict
06 Aug 2025	naviv1		MTN-35545: FR 35007.020 Display Release Request ID in Vehicle Visit Enquiry
*/
vars
	ti 					   : CM_TrackedItem;
	tiSet 				   : CM_TISet;
	failedDAC  		       : CM_DataAccessController;	// par 19715
	vvrAGateVRD			   : CM_VehicleVisitRecordDetail;
	vehicle 			   : CM_Vehicle;
	checkEIR 			   : Boolean;
	vehicleBookingTimeslot : CM_VehicleBookingTimeSlot;
	vehicleRegNum		   : String;
	releaseRequestID       : String;
begin
	
	//epr par 35090 20/11/14
	if self.filterRegNumber &lt;&gt; null then
		vehicle := _vehicleVisit.getVehicle;
		if  vehicle = null then
			return false;
		else
			vehicleRegNum := vehicle.regNumber.toUpper;			//11.04.2025 navma1 #MTN-34621
			if not (vehicleRegNum.startsWith(self.filterRegNumber ) 
				or vehicleRegNum = self.filterRegNumber  
				or vehicleRegNum.endsWith(self.filterRegNumber )) then
				return false;
			endif;
		endif;	
	endif;
	
	if self.filterReleaseRequestID &lt;&gt; null then			//12-08-2025 naviv1 #MTN-35545
		releaseRequestID := _vehicleVisit.getReleaseNumber().toUpper;
		if releaseRequestID = null then
			return false;
		elseif not releaseRequestID.cnContains(self.filterReleaseRequestID) then
			return false;
		endif;
	endif;
	
	//23 Nov 2020	NDL TFS 50391
	if self.filterStevedore &lt;&gt; null then
		if self.filterTimeIn.isValid then
			if  _vehicleVisit.timeOut.isValid and _vehicleVisit.timeOut &lt; self.filterTimeIn then
				return false;
			endif;
		endif;
		if self.filterTimeOut.isValid then
			if _vehicleVisit.timeIn &gt; self.filterTimeOut then
				return false;
			endif;
		endif;
	endif;
	
	// par 19715 - end
	create tiSet transient;

	if (self.filterTimeOut.isValid and _vehicleVisit.timeIn &gt; self.filterTimeOut) or
	   (self.filterCarrier &lt;&gt; null and _vehicleVisit.carrierCode &lt;&gt; self.filterCarrier)  then
	   return false;
	endif;	
	
	//Start 13/05/2022 navhl20 TFS 53430 
	if (self.filterTimeOut.isValid and _vehicleVisit.timeIn &gt; self.filterTimeOut) or
	   (self.filterSubCarrier &lt;&gt; null and _vehicleVisit.subCarrierCode &lt;&gt; self.filterSubCarrier)  then
	   return false;
	endif;
	//End 13/05/2022 navhl20 TFS 53430 
	
	if (self.filterGatePass &lt;&gt; null and self.filterGatePass &lt;&gt; _vehicleVisit.visitNumber) then
		return false;
	endif;
	
	//cnwrd1 ccms 1862 par 27435 2.5.2011
	if self.filterAGateUserCode &lt;&gt; null then //filtering by AGate user.
		vvrAGateVRD := _vehicleVisit.getArrivalAGateVRD();
		
		if vvrAGateVRD = null then
			return false;
		endif;
		
		if vvrAGateVRD.userCode &lt;&gt; self.filterAGateUserCode  then
			return false;
		endif;
	endif;
	
	// par 19715 - check user access before displaying
	/*
	22.04.2025 navma1 #MTN-34621
	Moved Down
	*/
	if not _vehicleVisit.canUserAccessSelf (null, failedDAC, _passport) then
		return false;
	endif;
	
	//epr 21/1/15 CCMS 1409 par 35553 
	checkEIR:=  self.filterEIR &lt;&gt; null and not self.myTerminal.getConfig(UseReceiveReleaseEIR).Boolean;		//11.04.2025 navma1 #MTN-34621
	
	if self.filterDirection &lt;&gt; Direction_Both or 
		self.filterCargoID &lt;&gt; null or 
		self.filterCargoType &lt;&gt; null or 	// cnwrd1 ccms 1695 23.1.09
		self.filterCargoSubType &lt;&gt; null or	//14 Oct 2020	NDL	tFS 49189
		self.filterBOL &lt;&gt; null or 
		self.filterBookingRef &lt;&gt; null or 
		self.filterVoyageCode &lt;&gt; null or
		checkEIR then
		
		if self.filterDirection = Direction_In then
			_vehicleVisit.allReceivedTrackedItems.copy(tiSet);
		elseif self.filterDirection = Direction_Out then
			_vehicleVisit.allReleasedTrackedItems.copy(tiSet);
		elseif self.filterDirection = Direction_Both then
			_vehicleVisit.allReceivedTrackedItems.tryCopy(tiSet);					//22.04.2025 navma1 #MTN-34621
			_vehicleVisit.allReleasedTrackedItems.tryCopy(tiSet);					//22.04.2025 navma1 #MTN-34621
			/*
			foreach ti in _vehicleVisit.allReleasedTrackedItems discreteLock do		//11.04.2025 navma1 #MTN-34621
				if not tiSet.includes(ti) then //In case the ti has been added in the receiveTrack item list.
					tiSet.add(ti);
				endif;
			endforeach;
			*/
		endif;
		
		if not tiSet.isEmpty() then
			foreach ti in tiSet do
				if includeObjectTI(ti) then
					return true;
				else
					continue;
				endif;
			endforeach;
			return false;
		else
			return false;
		endif;
	endif;
	
	//Start 13.12.2022  navmp20 TFS 55580
	if filterInStatus &lt;&gt; null and filterInStatus &lt;&gt; _vehicleVisit.gateInCheckStatus then
		return false;
	endif;
	if filterOutStatus &lt;&gt; null and filterOutStatus &lt;&gt; _vehicleVisit.gateOutCheckStatus then
		return false;
	endif;
	//End 13.12.2022  navmp20 TFS 55580
	
	if self.filterExternalReference &lt;&gt; null then																											//17.11.2023 navlc30 #61254
		vehicleBookingTimeslot := _vehicleVisit.myTerminal.myVehicleBookingTerminal.allVBTimeslotsByExtRef.getAtKeyGeq(self.filterExternalReference);
		if vehicleBookingTimeslot = null or not _vehicleVisit.allVehicleBookingSlots.includes(vehicleBookingTimeslot) then
			return false;
		endif;
	endif;
	
	if self.filterVBSId &lt;&gt; null then																														//17.11.2023 navlc30 #61254
		vehicleBookingTimeslot := _vehicleVisit.myTerminal.myVehicleBookingTerminal.allVBTimeslotsById.getAtKeyGeq(self.filterVBSId);
		if vehicleBookingTimeslot = null or not _vehicleVisit.allVehicleBookingSlots.includes(vehicleBookingTimeslot) then
			return false;
		endif;
	endif;
	
	return true; //par 13945

epilog
	delete tiSet;	
end;</source>
        <Parameter name="_vehicleVisit" type="CM_VehicleVisitRecord"/>
        <Parameter name="_passport" type="CM_Passport"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="includeObjectTI" id="3d8afae3-0457-4e0d-9924-87d285fe712c">
        <source>includeObjectTI(_ti : CM_TrackedItem) : Boolean;
/*
11 Apr 2025 navma1  MTN-34621 MTN - 1081 dead lock on CM_EIRNumberDict
*/
vars

begin
	if self.filterCargoID &lt;&gt; null and not self.idFilter (self.filterCargoID, _ti.id) then
		return false;				
	endif;

	if self.filterBOL &lt;&gt; null and self.filterBOL &lt;&gt; _ti.billOfLading then
		return false;
	endif;
	
	if self.filterBookingRef &lt;&gt; null and self.filterBookingRef &lt;&gt; _ti.bookingReference then
		return false;
	endif;
	
	if self.filterVoyageCode &lt;&gt; null and self.filterVoyageCode &lt;&gt; _ti.voyageCode then
		return false;
	endif;
	
	if self.filterCargoType &lt;&gt; null and self.filterCargoType &lt;&gt; _ti.cargoType then // cnwrd1 ccms 1695 23.1.09
		return false;
	endif;
	if self.filterCargoSubType &lt;&gt; null and self.filterCargoSubType &lt;&gt; _ti.myProduct then //3 Oct 2020	NDL	TFS 49189
		return false;
	endif;
	
	//epr CCMS 1409 22/01/15 par 35553
	if self.filterEIR &lt;&gt; null and not self.myTerminal.getConfig(UseReceiveReleaseEIR).Boolean then	//11.04.2025 navma1 #MTN-34621
		if self.filterEIR &lt;&gt; _ti.eirNumber then
			return false;
		endif;
	endif;
	
	return true;
end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="initDataTable" id="f1aeb3c3-0eab-4b43-b8d6-5d4623b6e26b">
        <updating/>
        <source>initDataTable() updating;
// ---------------------------------------------------------------------------
// Created:     08 December 2000 by cnwrs2
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	row 		: EntTableRow;
	entTableDef : EntTableDef;
begin

	self.allowMultiSelectEdit 		:= true;

	entTableDef := app.myController.getEntTableDef(ETDef_VisitRecordForEnquir);
	
	if entTableDef = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Def (' &amp; ETDef_VisitRecordForEnquir &amp; ') not found');
		return;
	endif;

	if self.myTerminal &lt;&gt; null then
		if self.myTerminal.hasDualGateVTA then
			self.tblData.setTblDataEntRowsFromView(entTableDef, "ViewDualGate");
		else
			self.tblData.setTblDataEntRowsFromView(entTableDef, CM_DataTable.SystemDefault);
		endif;
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="initFilterTable" id="566aae05-dfb9-4188-9481-534409c17761">
        <updating/>
        <source>initFilterTable() updating;
// ---------------------------------------------------------------------------
// Created:     08 December 2000 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 14/4/16		cnwmp6		TFS 488 - Multi Timezone Support
// 13 Dec 2022  navmp20     ChangeRequest 55580: EUP - Inspection App checks - Interface and MTN changes
// 17 Nov 2023  navlc30     ChangeRequest 61254: EUP | FR | 54329 | VBS - Pending issues - Issue 8
// ---------------------------------------------------------------------------
vars
	entTableDef		: EntTableDef;
	theRow			: Integer;
	theTable		: CM_EntryTable;
	assistant		: CMUI_Assistant;
	localNow		: TimeStamp;
	terminal	    : CM_Terminal;
	vbsProcess	    : CM_VBSProcess;
begin
	localNow := self.systemToLocalTime(app.actualTimeServer());

	theTable := self.tblSearch;
	
	entTableDef := app.myController.getEntTableDef(ETDef_VisitRecordForFind);
	
	if entTableDef &lt;&gt; null then
		theTable.setEntTableDef(entTableDef, null, 'entTableDefSetupWarning');
	else
		app.raiseUnexpectedProgramError(class.name, method.name, 'EntTableDef ETDef_VisitRecordForFind not found');
	endif;
	
	terminal := self.myTerminal;														//17.11.2023 navlc30 #61254
	if terminal &lt;&gt; null then															//17.11.2023 navlc30 #61254
		vbsProcess := terminal.getMyVBSProcess();
	endif;
	
	if vbsProcess &lt;&gt; null and not vbsProcess.isVbsSlotValidation then					//17.11.2023 navlc30 #61254
		theTable.hideRowByName(ETRow_FilterExternalReference,false);
	endif;
	
	theTable.setValueByName(ETRow_FilterDateIn, localNow.Date);
	theTable.setValueByName(ETRow_FilterTimeIn, '00:00'.Time);
	
	theTable.setValueByName(ETRow_FilterDateOut, localNow.Date);
	theTable.setValueByName(ETRow_FilterTimeOut, '23:59'.Time);	
	self.loadDirectionCombox();
	theTable.setValueByName(ETRow_FilterDirection, Direction_Both);
	
	//Start 14.12.2022 navmp20 TFS 55580
	self.cmbFiltInStatus.clear();
	self.cmbFiltInStatus.addItem(null);
	self.cmbFiltInStatus.addItem(CM_VehicleVisitRecord.InspectionFailed);
	self.cmbFiltInStatus.addItem(CM_VehicleVisitRecord.InspectionCompleted);
	self.cmbFiltInStatus.addItem(CM_VehicleVisitRecord.InspectionNA);
	self.cmbFiltInStatus.addItem(CM_VehicleVisitRecord.InspectionPending);
	
	self.cmbFiltOutStatus.clear();
	self.cmbFiltOutStatus.addItem(null);
	self.cmbFiltOutStatus.addItem(CM_VehicleVisitRecord.InspectionFailed);
	self.cmbFiltOutStatus.addItem(CM_VehicleVisitRecord.InspectionCompleted);
	self.cmbFiltOutStatus.addItem(CM_VehicleVisitRecord.InspectionNA);
