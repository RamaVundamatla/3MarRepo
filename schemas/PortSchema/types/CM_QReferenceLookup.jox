    <JadeMethod name="allowsSnapShotEdit" id="cd09b858-4d2f-4dfc-9e02-cb3f94698344">
        <source>allowsSnapShotEdit(): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 February 2021	navndl1	Initial creation	TFS 

*/

vars

begin

	if mySelectionValue.isKindOf(CM_EventType) then
		return mySelectionValue.CM_EventType.allowsSnapShotEdit();
	endif;
	
	return false;
	
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="cloneReferences" id="0ad5f205-839f-4b6d-9dd2-1a5878e688e0">
        <updating/>
        <source>cloneReferences(_targetReceiver : SelfType input) updating;
// ---------------------------------------------------------------------------
// Created:     17 April 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
vars
	invalid : Boolean;
	ed		: Integer;
begin
	inheritMethod(_targetReceiver);
	//epr TFS 47132 25/11/19
	on Exception do app.handleDeletedObject(exception,self.mySelectionValue, invalid);
	if self.mySelectionValue &lt;&gt; null then
		ed:=self.mySelectionValue.edition;
		if not invalid then
			_targetReceiver.mySelectionValue := self.mySelectionValue;
		endif;
	endif;

end;</source>
        <Parameter name="_targetReceiver" type="SelfType" usage="input"/>
    </JadeMethod>
    <JadeMethod name="create" id="ec8be4bf-8074-45a6-8da1-d8d566c99d6d">
        <updating/>
        <source>create() updating;
// -----------------------------------------------------------------------------
// Created:		09 May 2002 by cnwka1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	---------------------------------------------
//
// -----------------------------------------------------------------------------
begin
	self.description := self.Operator_Equal;
end;</source>
    </JadeMethod>
    <JadeMethod name="doMatch" id="9bad593a-e559-4e32-a4c3-17eabebccb47">
        <source>doMatch(_value: Object): Boolean;
// -----------------------------------------------------------------------------
// Created:		09 May 2002 by cnwka1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	---------------------------------------------
//
// -----------------------------------------------------------------------------
begin
	return _value = self.mySelectionValue;
end;</source>
        <Parameter name="_value" type="Object"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getCriteriaLineDefinitionForRT" id="55391b87-b4ec-4d3a-8aa7-7750d38dbde8">
        <source>getCriteriaLineDefinitionForRT( _prop : CM_QueryProperty;
								_searchValueA, _searchValueB : String output; _searchValueBoolean : Boolean output;
								_isStringProperty, _isStringBetweenProperty, _isBooleanProperty : Boolean output);
// -------------------------------------------
// Created 03 may 2008 by cnwvu1
// -------------------------------------------

vars
//	obj	: CM_Object;
	
begin
	
//	obj := self.mySelectionValue.CM_Object;
	
//	_searchValueA			:= obj.auditId().asStringJMT();
	_searchValueA			:= self.getSearchValueStr( _prop );
	_searchValueB			:= null;
	_searchValueBoolean		:= null;
	_isStringProperty		:= true;
	_isStringBetweenProperty:= false;
	_isBooleanProperty		:= false;
	
end;
</source>
        <Parameter name="_prop" type="CM_QueryProperty"/>
        <Parameter name="_searchValueA" type="String" usage="output"/>
        <Parameter name="_searchValueB" type="String" usage="output"/>
        <Parameter name="_searchValueBoolean" type="Boolean" usage="output"/>
        <Parameter name="_isStringProperty" type="Boolean" usage="output"/>
        <Parameter name="_isStringBetweenProperty" type="Boolean" usage="output"/>
        <Parameter name="_isBooleanProperty" type="Boolean" usage="output"/>
    </JadeMethod>
    <JadeMethod name="getSearchValue" id="a7b535fc-63ea-458e-9322-37bd33f16680">
        <source>getSearchValue(): Object;
// ---------------------------------------------------------------------------
// Created:     18 February 2003 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	return self.mySelectionValue;

end;</source>
        <ReturnType type="Object"/>
    </JadeMethod>
    <JadeMethod name="getSearchValueAsObjectSet" id="030aa52d-e6b4-454a-b5df-48b05b01b535">
        <source>getSearchValueAsObjectSet(_set: ObjectSet input);
// ---------------------------------------------------------------------------
// Created:     18 February 2003 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 22 Oct 2008	cnwkpd1		PAR #18099 - Handle null objects in selector queries
// ---------------------------------------------------------------------------

vars
	ut : CM_UserTerminal;
begin
	//cnwjo3 par 21231
	if self.mySelectionValue.isKindOf(CM_Terminal) then
		foreach ut in app.myPassport.myUser.allUserTerminals do
			if self.mySelectionValue = ut.getMyTerminal then
				if self.mySelectionValue &lt;&gt; null then
					_set.add(self.mySelectionValue);
				endif;
			endif;
		endforeach;
	else
		if self.mySelectionValue &lt;&gt; null then
			_set.add(self.mySelectionValue);
		endif;
	endif;
	

end;</source>
        <Parameter name="_set" type="ObjectSet" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getSearchValueStr" id="008584b1-1c82-4a7a-9e1d-d636cc4b4d4e">
        <source>getSearchValueStr(_prop : CM_QueryProperty): String;
// ---------------------------------------------------------------------------
// Created:     18 February 2003 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	// need to check if selection value is a CM_Object then
	// have a generic method on CM_Object to return a
	// meaningful str
	if self.mySelectionValue = null
	or global.isValidObject(self.mySelectionValue) then
		return _prop.translateToDisplayValue(self.mySelectionValue);
	else
		//invalid
		return "**" &amp; app.getErrorString(Object_Deleted) &amp; "**";
	endif;
end;</source>
        <Parameter name="_prop" type="CM_QueryProperty"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="isEnquiryForCargoRelRecTrans" id="01655322-ff64-400d-b784-f12a123a3946">
        <source>isEnquiryForCargoRelRecTrans(): Boolean;
/*

Purpose:			TFS 40336

Parameters:			

Return Value:		

Date		Who		Reason
12 September 2018	jlgab1	Initial creation

*/

vars

begin
	if mySelectionValue.isKindOf(CM_TransactionType) then
		return mySelectionValue.CM_TransactionType.isEnquiryForCargoRelRecTrans();
	endif;
	
	return false;

epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
