    <JadeMethod name="doNotableClear" id="19f6d335-8e5f-4292-b828-890a33354ed3">
        <source>doNotableClear();
// ---------------------------------------------------------------------------
// Created:		23 February 2010 cnwjo3
//
// Purpose:		par 21915.  Each form should implement doNotableClear without an inheritMethod();
//
vars
	removedNotification : Integer;
	anObject : Object;
begin

	foreach anObject in self.allNotableObjects do
		/*if anObject.isKindOf(____OBJECT TYPE____) then
			endNotification(anObject, self.myTerminal.getTerminalEvent(____EVENT_NAME_____));
			removedNotification := removedNotification + 1;
		endif;*/
	endforeach;

	validateNotificationRemoval(removedNotification,self.allNotableObjects.size);
	
	self.allNotableObjects.clear;
end;</source>
    </JadeMethod>
    <JadeMethod name="doOpenLineMappings" id="77dcbc6e-cfe6-4625-b06c-466a30115312">
        <source>doOpenLineMappings();
/*

Purpose:			Opens the Invoice Line Mappings form

Parameters:			NONE

Return Value:		NONE

Date		Who		Reason
07 October 2022	navpw1	Initial creation TFS: 54566
20 March 2023	navmk20	Bug 56954: FR | 53978 - EUP - Invoicing - Configuration Enhancements - User Story 050 issues

*/

vars
	form : INV_InvoiceLineMappingDesc;
	selectedInvLineTypes : CM_InvLineDescByNarrDupsADict; 	// 20.3.2023 navmk20 TFS 56954
	selectedDebtors	: CM_DebtorNodeByNameDict;				// 20.3.2023 navmk20 TFS 56954
	
begin
	// Start - 20.3.2023 navmk20 TFS 56954
	create selectedDebtors transient;
	self.mulDebtors.getSelected(selectedDebtors); 
	create selectedInvLineTypes transient;
	self.mulInvLineTypes.getSelected(selectedInvLineTypes);
	// End - 20.3.2023 navmk20 TFS 56954
	form := app.loadForm(INV_InvoiceLineMappingDesc, 
					INV_Assistant, 
					false, 
					false,
					false, 
					self.myTerminal,
					null).INV_InvoiceLineMappingDesc;	
	
	if form = null then
		return;
	endif;
	
	form.createMyAssistant(INV_Assistant);
	form.setMyCurrentBank(self.myCurrentBank);
	form.setMyCurrentDebtor(selectedDebtors);			// 20.3.2023 navmk20 TFS 56954
	form.setMyCurrentInvLine(selectedInvLineTypes);		// 20.3.2023 navmk20 TFS 56954
	form.showModal();
epilog
	delete selectedDebtors;// 20.3.2023 navmk20 TFS 56954
	delete selectedInvLineTypes;// 20.3.2023 navmk20 TFS 56954
end;</source>
    </JadeMethod>
    <JadeMethod name="doPrint" id="3cb29ee0-a308-4fc7-81fd-8f20a1b67f03">
        <updating/>
        <source>doPrint() updating;
// ---------------------------------------------------------------------------
// Created:		September 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
// 11/10/2022	navpw1	TFS: 54566 - Changed the title of the report to support the selection of multiple debtors
vars
	mess, head	: String;
	bank		: CM_Bank;
	theDebtors	: CM_DebtorNodeByNameDict;	// ### TFS 54566 10Oct2022 NAVPW1
	debtor		: CM_DebtorNode;			// ### TFS 54566 10Oct2022 NAVPW1
	
begin
	bank := self.myCurrentBank;
	
	create theDebtors transient;
	self.mulDebtors.getSelected(theDebtors);
	
	//if self.cmbDebtor.listObject &lt;&gt; null then	// ### TFS 54566 10Oct2022 NAVPW1
	if not theDebtors.isEmpty then				// ### TFS 54566 10Oct2022 NAVPW1
		//mess := "Printing Mapping Table for Debtor " &amp; self.cmbDebtor.listObject.CM_DebtorNode.name;			// ### TFS 54566 10Oct2022 NAVPW1
		//head := bank.mailingName &amp; " Map Table for Debtor "  &amp; self.cmbDebtor.listObject.CM_DebtorNode.name;	// ### TFS 54566 10Oct2022 NAVPW1
		
		// ### TFS 54566 10Oct2022 NAVPW1
		mess := "Printing Mapping Table for Debtor ";
		head := bank.mailingName &amp; " Map Table for Debtor ";
		
		foreach debtor in theDebtors do
			mess &amp;= debtor.name &amp; ", ";
			head &amp;= debtor.name &amp; ", ";
		endforeach;
		
		mess := mess.stripTrailingChar(",");
		head := head.stripTrailingChar(",");
		
		mess := mess.formatWithEllipsis(1, 80, true);
		head := head.formatWithEllipsis(1, 80, true);
		// ### TFS 54566 10Oct2022 NAVPW1
		
	else
		mess := "Printing Mapping Table for All Debtors ";
		head := bank.mailingName &amp; " Map Table for All Debtors " ; 
	endif;

	self.doTblDataPrint(mess,head,"Map Table");

epilog
	delete theDebtors;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="doQuery" id="75b67f81-c4f4-4f53-a841-e894a75d8fea">
        <updating/>
        <source>doQuery() updating;
// ---------------------------------------------------------------------------
// Created:		September 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	bank	: CM_Bank;
begin
	//self.myCurrentDebtor := self.cmbDebtor.listObject.CM_DebtorNode;
	bank := self.cmbBank.listObject.CM_Bank;
	if bank = null then
		return;
	endif;
	// 35872 refresh lists and combos on charge of bank
	if bank &lt;&gt; self.myCurrentBank then
		// clear these as they will be for the prior bacnk
		self.myCurrentInvLineType := null;
		self.myCurrentInvType := null;
		self.myCurrentBank := bank;
		self.doCmbInvTypesBuild();
		self.doCmbLinesBuild();
		self.loadLines();
	endif;

	self.doQueryDebtor();
	inheritMethod();
end;</source>
    </JadeMethod>
    <JadeMethod name="doQueryDebtor" id="0f57068b-b0a4-4bdb-9129-7b9421ffe1ef">
        <updating/>
        <source>doQueryDebtor() updating;
// ---------------------------------------------------------------------------
// Created:		September 2004 By Andrew Bishop cnwab1
// ---------------------------------------------------------------------------
// 24/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
// 06/10/2022	navpw1		TFS: 54566 - Extended to query by a selection of debtors and selection of invoice line types. Changed caption to support multiple debtor selection
// 20/3/2023	navmk20		Bug 56954: FR | 53978 - EUP - Invoicing - Configuration Enhancements - User Story 050 issues
vars
	theDebtors			: CM_DebtorNodeByNameDict;
	dn					: CM_DebtorNode;
	invoiceLineDesc		: CM_InvoiceLineDesc;
	invType				: CM_InvoiceDesc;
	row,
	column,
	count				: Integer;
	pd					: CMS_Progress;
	ls					: Boolean;
	mapTable			: Table;
	bank				: CM_Bank;
	rdg					: CM_RootDebtorGroup;
	invLineTypeArray	: CM_InvLineDescByNarrDupsADict;	// ### TFS 54566 06Oct2022 NAVPW1
	caption				: String;							// ### TFS 54566 10Oct2022 NAVPW1
	debtor				: CM_DebtorNode;					// ### TFS 54566 10Oct2022 NAVPW1
	
begin
	bank := self.myCurrentBank;
	rdg := bank.getRootDebtorGroup();
	
	self.loadLines();	// ### TFS 54566 06Oct2022 NAVPW1
	
	// ### TFS 54566 10Oct2022 NAVPW1
	create theDebtors transient;
	self.mulDebtors.getSelected(theDebtors);
	// ### TFS 54566 10Oct2022 NAVPW1
	
	mapTable := self.tblData;
	//if self.myCurrentDebtor &lt;&gt; null then	// ### TFS 54566 10Oct2022 NAVPW1
	if not theDebtors.isEmpty then			// ### TFS 54566 10Oct2022 NAVPW1
	//	TFS 2682	self.setCaption(bank.code &amp; " Mapping Table - " &amp; self.myCurrentDebtor.name );
		//self.setCaption("Mapping Table - " &amp; self.myCurrentDebtor.name &amp; " " &amp; bank.code );
		
		// ### TFS 54566 10Oct2022 NAVPW1
		caption := "Mapping Table - ";
		foreach debtor in theDebtors do
			caption &amp;= debtor.name &amp; ", ";
		endforeach;
		caption := caption.stripTrailingChar(",");
		caption := caption.formatWithEllipsis(1, 80, true);
		self.setCaption(caption &amp; " - " &amp; bank.code );
		// ### TFS 54566 10Oct2022 NAVPW1
		
	else
//	TFS 2682		self.setCaption(bank.code &amp; " Mapping Table - All Debtors" );
		self.setCaption("Mapping Table - All Debtors " &amp; bank.code );
		
	endif;
	
	self.setNavigatorHeading(self.caption);
	
	on CM_ProgressException do haltProgress(exception, ls);
	
	create pd;
	pd.setBackground(self.backColor);
	pd.show;
	pd.setAction("Loading Debtors...");
	
	app.cmsBeginLoad(ls);
	
	mapTable.columns := 1;
	mapTable.column := 1;
	mapTable.row := 1;
	mapTable.fixedRows := 1;
	
	/*if self.myCurrentDebtor &lt;&gt; null then
		// CCMS-1604
		self.myCurrentDebtor.getDebtors(theDebtors);
		
	else
		// CCMS-1604
		rdg.getDebtors(theDebtors);
	endif;*/
	
	// ### TFS 54566 06Oct2022 NAVPW1
	if theDebtors.isEmpty then
		rdg.getDebtors(theDebtors);
	endif;
	
	create invLineTypeArray transient;
	self.mulInvLineTypes.getSelected(invLineTypeArray);
	
	if invLineTypeArray.isEmpty then
		bank.invoiceLineDescriptors.copy(invLineTypeArray);
	endif;
	
	mapTable.columns := theDebtors.size + 1;
	column := 1;
	pd.progress.partsInJob := theDebtors.size;
	
	foreach dn in theDebtors do
		if dn.isKindOf(CM_DebtorGroup) then
			continue;
		endif;
		
		if not global.isValidObject(dn) then
			continue;
		endif;
		
		column := column + 1;
		
		row := 1;
		mapTable.accessCell(row,column).text := dn.name;
		mapTable.accessColumn(column).itemObject := dn;
		
		//foreach invoiceLineDesc in bank.invoiceLineDescriptors where not invoiceLineDesc.isNotAvailableForEntry do
		foreach invoiceLineDesc in invLineTypeArray where not invoiceLineDesc.isNotAvailableForEntry do	// ### TFS 54566 06Oct2022 NAVPW1
			row := row + 1;
			
			invType := invoiceLineDesc.getInvoiceType(dn.CM_Debtor);
			if invType &lt;&gt; null then
				mapTable.accessCell(row,column).text := invType.description;
				if (invoiceLineDesc.invoiceType &lt;&gt; invType) then
					mapTable.accessedCell.fontBold	:= true;
					mapTable.accessedCell.foreColor	:= Black;
				else
					mapTable.accessedCell.fontBold	:= false;
					mapTable.accessedCell.foreColor	:= DarkGray;
				endif;
				
				mapTable.accessedCell.itemObject	:= invType;
 			else
				mapTable.accessCell(row,column).text	:= "UNKNOWN";
				mapTable.accessedCell.fontBold			:= false;
				mapTable.accessedCell.foreColor			:= DarkGray;
				mapTable.accessedCell.itemObject		:= null;
			
			endif;
		endforeach;
		
		count := count + 1;
		pd.progress.partsDone := count;
		app.doWindowEvents(0);
		
	endforeach;
	
	self.doComboDebtorUpdateBuild(theDebtors);
	
	mapTable.row	:= 1;
	mapTable.column	:= 1;
	
//	self.setTableAlignment();
	
	self.setEnableObjects();	
	if mapTable.columns &gt; 1 then	//03 Jun 2016	NDL	TFS 2097
		mapTable.accessColumn(2).width := 100;
		// Start-  20.3.2023 navmk20 TFS 56954
		self.btnExportCSVMap.enabled := true;
		self.btnRefresh.enabled := true;
		self.btnEditItem.enabled := true;
		self.btnOpenLineMappings.enabled := true;
		self.btnPropDelete.enabled := true;
		self.mnuInvUpdate.enabled := true;
		self.btnImportCSVMap.enabled := true;
	else 
		self.btnExportCSVMap.enabled := false;
		self.btnRefresh.enabled := false;
		self.btnEditItem.enabled := false;
		self.btnOpenLineMappings.enabled := false;
		self.btnPropDelete.enabled := false;
		self.mnuInvUpdate.enabled := false;
		self.btnImportCSVMap.enabled := false;
		// End - 20.3.2023 navmk20 TFS 56954
	endif;
	
epilog
	app.cmsEndLoad(ls);
	delete pd;
	delete theDebtors;
	delete invLineTypeArray;	// ### TFS 54566 06Oct2022 NAVPW1
	
end;</source>
    </JadeMethod>
    <JadeMethod name="doQuerySheetChange" id="87c96d30-6282-4146-8d68-0575e3842c3e">
        <updating/>
        <source>doQuerySheetChange() updating;
// ---------------------------------------------------------------------------
// Created:		September 2004 By Andrew Bishop cnwab1
//
// Purpose:		
