    <JadeMethod name="txtLocation_lostFocus" id="fa737cba-b02f-45ff-b6ca-4a168ad40319">
        <controlMethod name="TextBox::lostFocus"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>txtLocation_lostFocus(textbox: TextBox input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 June 2015	cnwndl1	Initial creation

*/

vars

	location : CM_LocationsController;

begin

	if self.txtLocation.text.trimBlanks = null then
		self.txtLocation.text := self.lblLocation.caption.toUpper;
		self.txtLocation.userObject := null;
	else
		if self.findLocationToMoveTo( location ) then
			self.txtLocation.text := location.getFullId;
			self.txtLocation.userObject := location;
		else
			self.txtLocation.userObject := null;
		endif;
	endif;
	
	self.txtLocation.selStart := 0;
	self.txtLocation.selLength := 0;

epilog

end;</source>
        <Parameter name="textbox" type="TextBox" usage="input"/>
    </JadeMethod>
</GUIClass>
