    <JadeMethod name="setupThumbnailDetails" id="57b31ea8-2801-4d18-a463-8d31a9b4fd5c">
        <updating/>
        <source>setupThumbnailDetails() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
19 July 2012	cnwndl1	Initial creation	Par 29968

*/

vars
	theForm : SOP_TableMaintForm;
begin
  
  	theForm := self.myForm;
	theForm.useProxyObject := true;
	
	theForm.setTblDataEntRows(ETDef_PaymentMethod);

	theForm.shtTblInput1.caption := 'Details';
	theForm.initTblInput(theForm.tblInput1, ETDef_PaymentMethod);
	theForm.shtTblInput1.visible := true;

	theForm.mulSelect1.formDisplayEntryMethodName := null;
	theForm.mulSelect2.formDisplayEntryMethodName := null;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="showThumbnail" id="3da860ec-5448-4899-8981-58a36ff1ae08">
        <updating/>
        <source>showThumbnail(pPaymentMethod: CM_PaymentMethod) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
19 July 2012	cnwndl1	Initial creation	Par 29968

*/

vars
	theForm : SOP_TableMaintForm;
begin
  
    theForm := self.myForm;
	theForm.tblInput1.clearValues;

	theForm.tblInput1.setValueByName(ETRow_Code, pPaymentMethod.code);
	theForm.tblInput1.setValueByName(ETRow_Description,	pPaymentMethod.description);
	theForm.tblInput1.setValueByName(ETRow_IsCheque, pPaymentMethod.isCheque);
	theForm.tblInput1.setValueByName(ETRow_IsPOS, pPaymentMethod.isPOS);
end;</source>
        <Parameter name="pPaymentMethod" type="CM_PaymentMethod"/>
    </JadeMethod>
</Class>
