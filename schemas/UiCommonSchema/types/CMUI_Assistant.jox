    <JadeMethod name="validateMasterListObjects" id="1f02d88a-ce9a-439d-9b09-2d2d09607d55">
        <source>validateMasterListObjects( _listTable : CMUI_ListTable; _masterIds : IntegerArray; _field : String) : Integer protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
21 September 2009	cnwjk3	sfw1035

*/

vars
	obj			: Object;
	differ		: Boolean;
	id			: Integer;
begin
	if _listTable.allSelectedObjects.size() = 0 then
		// No stops on GUI are selected, so who cares if we overwrite
		return MsgBox_Return_OK;
	endif;
	if _listTable.allSelectedObjects.size() &lt;&gt; _masterIds.size() then
		// The number of selected objects does not match the number selected in the master record
		
		return self.showMasterDifferenceWarning( app.getErrorString1(WARNING_FIELD_DIFFERENCE,_field),app.getErrorString1(WARNING_NUMBER_SELECTED_ITEMS,_listTable.allSelectedObjects.size().String), 
															 app.getErrorString1(WARNING_NUMBER_SELECTED_ITEMS,_masterIds.size().String));
	else
		foreach obj in _listTable.allSelectedObjects do 
			if obj.isKindOf(CM_ToDoTaskDesc) then
				id := obj.CM_ToDoTaskDesc.code;
			elseif obj.isKindOf(CM_StopsTable) then
				id := obj.CM_StopsTable.id;
			else
				
				app.raiseUnexpectedProgramError(class.name, method.name, app.getErrorString(ERROR_UNSUPORTED_TYPE));
				return MsgBox_Return_Cancel;
			endif;
			if not _masterIds.includes(id) then 
				differ := true;
				break;
			endif;
		endforeach;
	endif;
	
	if differ then		
		return self.showMasterDifferenceWarning( app.getErrorString1(WARNING_FIELD_DIFFERENCE,_field) , app.getErrorString(WARNING_CODES_DIFFER), app.getErrorString(WARNING_CODES_DIFFER));
	endif;
	
	return MsgBox_Return_OK;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_listTable" type="CMUI_ListTable"/>
        <Parameter name="_masterIds" type="IntegerArray"/>
        <Parameter name="_field" type="String"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
