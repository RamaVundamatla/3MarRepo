<Class name="CM_QRefMeasureWtsProperty" id="d6940326-be08-4b44-9137-b7bfd244eb33">
    <superclass name="CM_QRefMeasureWeightProperty"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="query"/>
    <JadeMethod name="create" id="1b1dcf57-ccdf-4793-8f94-42015b0635fd">
        <updating/>
        <source>create() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 November 2023 navmv20 Bug 61113: FR | 54089 - EUP - Invoice contracts - Selector query - Missing fields

*/


vars
	oper	: CM_QueryOperator;
	
begin
	if self.isTransient then 
		return;
	endif;
	
	self.allAllowedOperators.purge;
	
	create oper as CM_QDecimalArrEquals persistent;
	self.allAllowedOperators.add(oper);
	

	create oper as CM_QDecArrGreaterThan persistent;
	self.allAllowedOperators.add(oper);
	
	create oper as CM_QDecArrLessThan persistent;
	self.allAllowedOperators.add(oper);
	
	create oper as CM_QDecArrLessThanEquals persistent;
	self.allAllowedOperators.add(oper);
	
	create oper as CM_QDecArrGreaterEquals persistent;
	self.allAllowedOperators.add(oper);
	
	create oper as CM_QDecArrInRange persistent;
	self.allAllowedOperators.add(oper);

	create oper as CM_QDecArrNotInRange persistent;
	self.allAllowedOperators.add(oper);
	
end;</source>
    </JadeMethod>
    <JadeMethod name="getValueForObject" id="03fb5195-fd8b-45c3-ab06-dda34c822b5a">
        <source>getValueForObject(_obj: Object; _op: CM_QueryOperator input): Any;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 November 2023 navmv20 Bug 61113: FR | 54089 - EUP - Invoice contracts - Selector query - Missing fields

*/

vars
	pos 		: Integer;
	propName 	: String;
	measure 	: String;
	prop		: Property;
	value, newArr 	: DecimalArray;
	decimalVal, newVal : Decimal[23,4];

begin
	pos := self.propertyName.pos(CN_UNDERSCORE, 1);
	if pos = null then
		return inheritMethod(_obj, _op);
	endif;
	
	measure := self.propertyName[1:pos-1];		// get measurement type from prefix
	propName := self.propertyName[pos+1:end]; 	// remove measurement type prefix to get property name
	prop := _obj.class.getPropertyInHTree(propName);
	if prop &lt;&gt; null then
		value := _obj.getPropertyValue(propName).DecimalArray;
	else
		value := _obj.sendMsgWithParams(propName).DecimalArray;
	endif;
	create newArr transient;
	
	foreach decimalVal in value do
		newVal := app.convertMeasurementForDisplay(measure, decimalVal).Decimal;
		if not newArr.includes(newVal) then
			newArr.add(newVal);
		endif;
	endforeach;
	return newArr;
epilog

end;</source>
        <Parameter name="_obj" type="Object"/>
        <Parameter name="_op" type="CM_QueryOperator" usage="input"/>
        <ReturnType type="Any"/>
    </JadeMethod>
    <JadeMethod name="translateToDisplayValue" id="8243f058-3ba9-46e5-9166-5b0b842a0c72">
        <source>translateToDisplayValue(_value: Any): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 November 2023 navmv20 Bug 61113: FR | 54089 - EUP - Invoice contracts - Selector query - Missing fields

*/

vars
	weight : Decimal[23,4];
	returnVal : String;
begin
	if _value.String.isDecimalJMT then
		return _value.asStringJMT;
	elseif _value.isKindOf(DecimalArray) then
		foreach weight in _value.DecimalArray do
			if returnVal = null then
				returnVal := weight.asStringJMT;
			else
				returnVal := returnVal &amp; ", " &amp; weight.asStringJMT;
			endif;
		endforeach;
	endif;
	return returnVal;

epilog

end;</source>
        <Parameter name="_value" type="Any"/>
        <ReturnType type="String"/>
    </JadeMethod>
</Class>
