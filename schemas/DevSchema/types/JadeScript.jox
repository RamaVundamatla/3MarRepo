epilog
end;</source>
    </JadeMethod>
    <JadeMethod name="sh3_DayOfMonth" id="723c6d5e-2b13-4877-94f0-f5848b6f3146">
        <source>sh3_DayOfMonth();
//----------------------------------------------------------------------
// Created by 	cnwsh3 - 23 October 2012
//
// Implemented version: JMT 8.2.1
// Date  		User  		Change
//----------------------------------------------------------------------
vars
	result	: Integer;
	dayNum	: Integer;
	theDate : Date;
	dateAsInt,
	dateMax,
	int		: Integer;
	
begin
	theDate := '01/10/2012'.asDate();
	dateAsInt := theDate.Integer;
	dateMax := dateAsInt + 32;
	while dateAsInt &lt; dateMax do
		write dateAsInt;
		//write dateAsInt.Date.format("dd.MM.yyyy");
	
		theDate := dateAsInt.Date;
		write theDate;
		dayNum := theDate.day();
		if dayNum &lt; 8 then
			result := 1;
		elseif dayNum &lt; 15 then
			result := 2;
		elseif dayNum &lt; 22 then
			result := 3;
		elseif dayNum &lt; 29 then
			result := 4;
		else
			result := 5;
		endif;
		write result;
		write ' ';
		dateAsInt := dateAsInt + 1;
	endwhile;
end;</source>
    </JadeMethod>
    <JadeMethod name="sh3_checkSystemReportParams" id="85ae4673-d874-4268-9f9b-a62c50ad25e7">
        <source>sh3_checkSystemReportParams();
//----------------------------------------------------------------------
// Created by 	cnwsh3 - 05 September 2012
//
// Implemented version: JMT 7.9.2
// Date  		User  		Change
//----------------------------------------------------------------------
vars
	sysReport	: CM_QryReportSystem;
	userReport : CM_QryReportUser;
begin
	foreach sysReport in CM_QryReportSystem.instances do
		if sysReport.allQueryReportParams.isNotEmpty() then
			write sysReport;
			
		endif;
	endforeach;
	
	foreach userReport in CM_QryReportUser.instances do
		if userReport.allQueryReportParams.isNotEmpty() then
			write userReport;
			
		endif;
	endforeach;
epilog
	write 'terminado';
end;</source>
    </JadeMethod>
