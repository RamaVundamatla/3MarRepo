    <JadeMethod name="setTransactionDetails" id="be001b1e-dcc8-42be-8030-77c2fecf8fdf">
        <updating/>
        <source>setTransactionDetails(_txn : CM_VentilationReading input) updating, protected;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 17/03/2015	cnwdap1		Initial creation PAR #35874 TFS 265
