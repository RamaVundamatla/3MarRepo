    <JadeMethod name="auditIdDisplay" id="4468345e-dfcf-473c-99be-797d56a79e5a">
        <source>auditIdDisplay(): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 May 2018	jlgmp6	Initial creation	TFS 37718

*/

vars
	auditIdStr : String;
begin
	
	auditIdStr := self.auditId();
	
	if auditIdStr &lt;&gt; null then
		return app.getErrorString(Charge) &amp; Space &amp; Hyphen &amp; Space &amp; auditIdStr;
