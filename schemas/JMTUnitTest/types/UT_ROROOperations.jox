    <JadeMethod name="uCheckGetCargoDetailsCorrect" id="4ec957f7-10dd-41cc-b1ca-8d9d65325d4d">
        <updating/>
        <source>uCheckGetCargoDetailsCorrect() updating;

/*

Purpose:		Check that CM_ROROLocnDefnVoyage::getCargoDetails returns the correct information


									ACTUAL	PROPOSED	DISCHARGE 	LOAD
4X20ROB, 2X40ROB 					Y 		Y 			Y 			Y
4X20ROB, 2X40IMP 					Y 		Y 			Y 			Y
4X20ROB, 1X40ROB, 1X40IMP 			Y 		Y 			Y 			Y
2X20IMP, 2X40IMP  					Y 		Y 			Y 			Y
4X20ROB, 1X40ROB, 1X40EXP Planned 	Y 		Y 			Y 			Y
2X20IMP, 2X40EXP Planned 			Y 		Y 			Y 			Y
2X20EXP, 2X40EXP 					Y 		Y 			Y 			Y
4X20ROB, 2X40EXP 					Y 		Y 			Y 			Y
1X20ROB 							Y 		Y 			Y 			Y
1X20EXP Planned 					Y 		Y 			Y 			Y
1X20IMP 							Y 		Y 			Y 			Y
1X40ROB 							Y 		Y 			Y 			Y
1X40EXP Planned 					Y 		Y 			Y 			Y
1X40IMP 							Y 		Y 			Y 			Y
4X20ROB, 1X40ROB, 1X40EXP Actual 	Y 		Y 			Y 			Y
2X20IMP, 2X40EXP Actual 			Y 		Y 			Y 			Y
1X20EXP Actual 						Y 		Y 			Y 			Y
1X40EXP Actual 						Y 		Y 			Y 			Y



Date			Who		Reason
06/09/2012		cnwmh5	Initial creation

*/

constants

	VesselId				: String = "DIAM";
	VoyageId				: String = "UT_MDHVOY11";
	OperatorId				: String = "UTOP";
	DeckName 				: String = "4";   						// MAIN DECK

vars

	voyage					: CM_Voyage;
	voyageDeck				: CM_DeckVoyage;
	voyageJob				: CM_VoyageJob;
	locnDefnVoyage			: CM_ROROLocnDefnVoyage;
	tempTI					: CM_TrackedItem;
	bs						: CM_BlockStack;
	locnDefn				: CM_ROROLocnDefn;

	slots					: CM_LCArray;
	tiArray					: CM_TIArray;
	
	strs 					: StringArray;
	failedArray				: HugeStringArray;		//cnwmc5 - 8/10/2012
	
	detailsToCheck			: String;
	str1, str2				: String;				//cnwmc5 - 8/10/2012
	idx						: Integer;
	
begin

	// setup non ship cargo
	bs := self.addBlockStack("UTMHBSE", 100, null);
	self.assertNotNull(bs);

	// Create the voyage
	self.deleteVoyage(VoyageId);
	voyage := self.addVoyageWithConRORO(VoyageId, VesselId, OperatorId, "UTSL", "Chief Tasman", 0, false, true);
	self.assertNotNullMsg(voyage, 'Add voyage failed');
	
	create slots transient;
	create tiArray transient;
	create failedArray transient;		//cnwmc5 - 8/10/2012
	
	// set up the areas and containers on the voyage
	if voyage.myROROStructure &lt;&gt; null then
		voyageDeck := voyage.myROROStructure.allDecksByCode[DeckName];
		if voyageDeck &lt;&gt; null then
						
			// setup and check OOTL 20'
			//voyageDeck.myVoyageStructure.createQuickCargoOOTL(null, false, 12, 0, voyageDeck, 2); // 2 X 20
			self.createQuickCargoOOTL(voyageDeck.myVoyageStructure, locnDefn, false, 12, 0, voyageDeck, 2);
			self.assertNoTrxErrorsOrWarnings();
								
			// setup OOTL 40'
			//voyageDeck.myVoyageStructure.createQuickCargoOOTL(
			self.createQuickCargoOOTL(voyageDeck.myVoyageStructure, locnDefn, true, 12, 3, voyageDeck, 1); // 1 X 40
			self.assertNoTrxErrorsOrWarnings();
						
			// setup the cargo
			self.setupCargoForGCDC(voyage, voyageDeck, slots, tiArray);
					
		endif;
		
		if voyageDeck &lt;&gt; null then
			// create the discharge jobs
			self.createGCDCDischJobs(voyage, voyageDeck);
			self.planGCDCDischageItems(voyage);
			
			self.opts.purge;
			self.opts.addAssoc("Sleep", 5000);
			self.opts.addAssoc("WPOpHrs", 2);	//10 Apr 2012	NDL	Par 29369.
			self.expectedTrxErrors.clear();
			self.moveAllCargoOnVoyage(voyage, REAL_MODE);
			
			// create the load jobs
			self.createGCDCLoadJobsPlan(voyage, voyageDeck);

			// loading jobs to job ops
			self.loadAllJobsToOps(voyage, true);
		
			// check that the details are correct
			self.checkGCDCorrect(ShpDisplayMode_Actual, 0, voyageDeck, failedArray);
			self.checkGCDCorrect(ShpDisplayMode_Proposed, 0, voyageDeck, failedArray);
			self.checkGCDCorrect(ShpDisplayMode_Actual, ShpDisplayMode_ColCodeDisch, voyageDeck, failedArray);
			self.checkGCDCorrect(ShpDisplayMode_Proposed, ShpDisplayMode_ColCodeLoad, voyageDeck, failedArray);
			
		endif;
		
	endif;
	
	//cnwmc5 - 8/10/2012 - added new style of error handling
	foreach str1 in failedArray do
		str2 := str2 &amp; str1 &amp; CrLf;
	endforeach;

	self.assertEqualMsg(failedArray.size, 0, str2);
	
epilog
	
	delete failedArray;			//cnwmc5 - 8/10/2012
	
	delete slots;
	delete tiArray;
	
end;</source>
        <text>&lt;?xml version="1.0"?&gt;
&lt;UT_Additional&gt;
  &lt;Categories&gt;
    &lt;Category CanDelete="true"&gt;MichaelAllocChange&lt;/Category&gt;
  &lt;/Categories&gt;
&lt;/UT_Additional&gt;</text>
