    <JadeMethod name="setupForm" id="55c7cc5c-d05e-4d09-9f95-c89372f500c1">
        <updating/>
        <source>setupForm() updating;
/*

Purpose:			


Return Value:		


Date		Who		Reason
08 Mar 2008	cnwer1	Initial creation - PAR#xxxx
05 Jun 2014	cnwkpd1	PAR #34210 - CCMS SFW 1350 - Online Documentation

*/
vars

begin
	inheritMethod();

	self.frmToolbar.alignContainer	:=	Frame.AlignContainer_Top; // this will make the dkcMain line up its top	
	self.toolbarStyle := self.ToolbarStyle_ShowNoHide;	
	self.showToolbar := true;
	self.initTblData();	
	self.caption:="Saved Conflict Reports";
	self.helpKeyword:="Saved Conflict Reports";			// PAR #34210

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="tblConflicts_contextMenu" id="51868828-a581-42a8-aabe-34acb2ee2229">
        <controlMethod name="Table::contextMenu"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblConflicts_contextMenu(table: Table input; conwin: Window input; mouse: Boolean; x: Integer; y: Integer):Boolean updating;
/*

Purpose:			


Return Value:		


Date		Who		Reason
26 March 2008	cnwer1	Initial creation - PAR#xxxx

*/
vars
	x1, y1 : Real;

begin

	x1 := x;
	y1 := y;
	if not mouse then  // if keyboard, use current listIndex value
	    x1 := 1;
	    y1 := 1;
	endif;

	conwin.windowToScreen(x1, y1);
	self.screenToWindow(x1, y1);   // convert x, y relative to form
	
	popupMenu(self.mnuContext, x1.Integer, y1.Integer);
	return false;
epilog

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="conwin" type="Window" usage="input"/>
        <Parameter name="mouse" type="Boolean"/>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
