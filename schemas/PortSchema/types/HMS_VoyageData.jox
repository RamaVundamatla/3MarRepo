    <JadeMethod name="setMyTowingVoyage" id="7a6a0863-e985-4acf-9cb4-3643f0f329d2">
        <updating/>
        <source>setMyTowingVoyage(	_towingVoyage : CM_Voyage ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 June 2018	jlgndl1	Initial creation	TFS 39248

*/

vars

begin

	self.myTowingVoyage := _towingVoyage;

epilog

end;</source>
