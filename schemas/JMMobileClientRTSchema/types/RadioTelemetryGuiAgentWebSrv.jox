    <JadeMethod name="updateToDoTasksForTI" id="c122ff6f-363c-4ecd-bc5a-0280dc189dc5">
        <source>updateToDoTasksForTI(	_form 			: JMMobileClient_BaseForm input;
						_toDoTaskSet	: ObjectSet input;
						_errorString	: String output;
						_state			: Integer output;
						_warnings		: Boolean io): Boolean;
// -------------------------------------------
// Created 30 January 2006 by cnwdvb1
// -------------------------------------------
vars

	updateToDoTasks			: WebSrv_ToDoTasksForTI;
	updateToDoTasksResp		: WebSrv_ToDoTasksTIResp;
	dtoResponseIn,
	dtoResponseOut			: WebSrv_DTO_EnquiryGradingTasks;
	dtoStateOut				: WebSrv_DTO_StateInfo;
	rtnValue				: Boolean;
	mbToDoTask				: Object;
	dtoToDoTask				: WebSrv_DTO_ToDoTask;

begin

	on Exception do xHandlerInterface(exception);
	
	create updateToDoTasks transient;
	create dtoResponseIn transient;
	
	self.clearStateObject();
	
	foreach mbToDoTask in _toDoTaskSet do
		create dtoToDoTask transient;
		mbToDoTask.MB_ToDoTask.translateToWebServices(dtoToDoTask);
		dtoResponseIn.allToDoTasks.add(dtoToDoTask);
	endforeach;
	
	updateToDoTasks.dto		:= dtoResponseIn;
	updateToDoTasks.stateInfo	:= self.myStateObjIn;
	
	updateToDoTasksResp	:=	self.myWebSrvProvider.updateToDoTasksForTI(updateToDoTasks);
	
	dtoResponseOut		:= updateToDoTasksResp.dto;
	dtoStateOut			:= updateToDoTasksResp.stateInfo;
	
	if dtoResponseOut = null then
		self.mbRaiseException($MB_INVALID_RESPONSE);
		return false;
	endif;
	
	if dtoStateOut = null then
		self.mbRaiseException($MB_INVALID_RESPONSE);
		return false;
	endif;
	
	rtnValue := updateToDoTasksResp.updateToDoTasksForTIResult;

	_errorString	:= dtoStateOut.errorString;
	_state			:= dtoStateOut.guiState;
	
	if rtnValue then
		_form.loadFormFromWebSrvObj(dtoResponseOut);
	endif;
	
	return rtnValue;

epilog

	delete updateToDoTasks;
	delete updateToDoTasksResp;
	// Get rid of transients created in this method.
	dtoResponseIn.allGrades.purge();
	dtoResponseIn.allToDoTasks.purge();
	delete dtoResponseIn;
	delete dtoResponseOut;
	delete dtoStateOut;
end;</source>
        <Parameter name="_form" type="JMMobileClient_BaseForm" usage="input"/>
        <Parameter name="_toDoTaskSet" type="ObjectSet" usage="input"/>
        <Parameter name="_errorString" type="String" usage="output"/>
        <Parameter name="_state" type="Integer" usage="output"/>
        <Parameter name="_warnings" type="Boolean" usage="io"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="xHandlerInterface" id="e94eabd7-9aa1-47f9-b5dc-2a96612831b9">
        <source>xHandlerInterface(pExceptionObj:Exception):Integer protected;
// --------------------------------------------------------------------------------
// Created:		14 October 2005 by cnwdad1
//
// Purpose:		General exception handler which allows the Service Provider to respond
//				(in the event of an exception) with the details of what went wrong.
//
// Parameters:	pExceptionObj - A Reference to the exception object.
//
// Returns:		The exception flag indicating how to dispose of the exception.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
constants
	NO_RESPONSE		: Integer = 11051;
	REMOTE_ERROR	: Integer = 11052;
	
vars
	errorCode		: Integer;
	errorMessage	: String;
	titleMsg		: String;
	
begin
	errorCode	:=	pExceptionObj.errorCode;
	
	if errorCode = NO_RESPONSE then
		titleMsg		:=	"The Mobile Server database is not available";
		errorMessage	:=	"Connection to Mobile Server database cannot be established. Contact your system administrator.";
	elseif errorCode = REMOTE_ERROR then
		titleMsg		:=	"The Mobile Server database encountered an error";
		errorMessage	:=	"An error occurred on the Mobile Server database:" &amp; CrLf &amp; CrLf &amp;
							process.getErrorText(errorCode) &amp; CrLf &amp; CrLf &amp;
							"Contact your system administrator.";
	else
		errorMessage := process.getErrorText(errorCode);
	endif;
	
	errorMessage	:=	errorMessage &amp; CrLf &amp; pExceptionObj.extendedErrorText;
	
	// if called from the app
	abortTransaction;
	
	if pExceptionObj.isAppError() then
		app.msgBox(errorMessage, "Application Error", MsgBox_Exclamation_Mark_Icon + MsgBox_OK_Only);
		return Ex_Abort_Action;	
	elseif pExceptionObj.isSoapError() then
		app.msgBox(errorMessage, "SOAP Error", MsgBox_Exclamation_Mark_Icon + MsgBox_OK_Only);
		return Ex_Abort_Action;	
	else
		return Ex_Pass_Back;
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="pExceptionObj" type="Exception"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
</Class>
