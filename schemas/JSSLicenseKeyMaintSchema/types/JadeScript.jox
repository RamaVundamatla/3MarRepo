<Class name="JadeScript">
    <JadeMethod name="initializeDatabase" id="97e38ff1-a51b-4a80-ba38-883f1c9694f0">
        <source>initializeDatabase();
// --------------------------------------------------------------------------------
// Created:		31 January 2003 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	theRoot		: JSSLKProductRoot;
	theProduct	: JSSLKProduct;
	
begin
	self.purgeDatabase();
	
	beginTransaction;
	
	create theRoot;
	
	theRoot.createCustomer("Jade Software Corporation");
	theRoot.createCustomer("JADE Star");
	theRoot.createCustomer("JADE Portec");
	theRoot.createCustomer("Skipton Building Society");
	theRoot.createCustomer("Northern Territory Health");
	theRoot.createCustomer("Air New Zealand");
	theRoot.createCustomer("English, Wales and Scotland Railways (EWS)");
	theRoot.createCustomer("Christchurch Polytech");
	theRoot.createCustomer("Waikato University");
	
	theProduct	:=	theRoot.createProduct("Core Schema", "JSSCore", "1.0", null);
	
	theProduct	:=	theRoot.createProduct("File Manager (Peer) Schema", "JSSFileMgr", "1.0", null);
	theProduct.createComponent(1, "Schema Interface");
	theProduct.createComponent(2, "Form Interface");
	
	theProduct	:=	theRoot.createProduct("Internet (Peer) Schema", "JSSINet", "1.0", null);
	theProduct.createComponent(1, "Schema Interface");
	
	theProduct	:=	theRoot.createProduct("Messaging (Peer) Schema", "JSSMessage", "1.0", null);
	theProduct.createComponent(1, "Schema Interface");
	
	theProduct	:=	theRoot.createProduct("Security Registry (Peer) Schema", "JSSSecReg", "1.0", null);
	theProduct.createComponent(1, "Schema Interface");
	
	theProduct	:=	theRoot.createProduct("License Key (Peer) Schema", "JSSLicKey", "1.0", null);
	theProduct.createComponent(1, "Schema Interface");
	
	theProduct	:=	theRoot.createProduct("XML Tree (Peer) Schema", "JSSXmlTree", "1.0", null);
	theProduct.createComponent(1, "Schema Interface");
	
	commitTransaction;
end;</source>
    </JadeMethod>
    <JadeMethod name="purgeDatabase" id="5fd71d73-bac6-4c11-b795-52d49b888076">
        <source>purgeDatabase();
// --------------------------------------------------------------------------------
// Created:		31 January 2003 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	beginTransaction;
	JSSLKProductRoot.instances.purge();
	commitTransaction;
end;</source>
    </JadeMethod>
    <JadeMethod name="test_LicenseKey" id="9ada8ebb-3c52-4656-a39f-f63c26681c2b">
        <source>test_LicenseKey();
// --------------------------------------------------------------------------------
// Created:		25 March 2003 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
constants
	CUSTOMER_NAME	: String = "General Services and Standards";
	MAX_COMPONENTS	: Integer = 25;
	PRODUCT_CODE	: String = "TestProd";
	
vars
	theKey			: JSSLKey;
	expiryDate		: Date;
	allOptions		: BooleanArray;
	optionFlag		: Boolean;
	loopCounter		: Integer;
	licenseKey		: String;
	bitMask			: Binary;
	maskBits		: String;
	
begin
	create allOptions transient;
	
	foreach loopCounter in 1 to MAX_COMPONENTS do
		allOptions.add(app.random(1) = 1);
	endforeach;
	
	foreach optionFlag in allOptions do
		if optionFlag then
			maskBits	:=	maskBits &amp; "1";
		else
			maskBits	:=	maskBits &amp; "0";
		endif;
	endforeach;
	
	create theKey transient;
	expiryDate.setDate(10, 07, 2010);
	write "Building License Key:";
	
	if theKey.generateKey(CUSTOMER_NAME, PRODUCT_CODE, expiryDate, allOptions ) then
		licenseKey	:=	theKey.data1;
		write "License key is " &amp; licenseKey.length().String &amp; " characters long.";
		write "License key: " &amp; licenseKey;
		write "Bitmask: " &amp; maskBits;
		write "Expiry date: " &amp; expiryDate.shortFormat();
		write "Product code: " &amp; PRODUCT_CODE;
	else
		write "License key generator failed.";
	endif;
	
	delete theKey;
	
	create theKey transient;
	write CrLf &amp; "Registering License Key:";
	
	if theKey.decompose(CUSTOMER_NAME, licenseKey) then
		write "License key is " &amp; theKey.data1.length().String &amp; " characters long.";
		write "License key: " &amp; theKey.data1;
		bitMask		:=	theKey.data2;
		maskBits	:=	null;
		
		foreach loopCounter in 1 to MAX_COMPONENTS do
			if bitMask.jssIsBit(loopCounter) then
				maskBits	:=	maskBits &amp; "1";
			else
				maskBits	:=	maskBits &amp; "0";
			endif;
		endforeach;
		
		write "Bitmask: " &amp; bitMask.String &amp; " (" &amp; maskBits &amp; ")";
		write "Expiry date: " &amp; theKey.data3.Date.shortFormat();
		write "Product Code: " &amp; theKey.data4.String;
		write CrLf &amp; "Successfully registered!";
	else
		write CrLf &amp; "Registration failed!";
	endif;
epilog
	delete theKey;
	delete allOptions;
end;</source>
    </JadeMethod>
</Class>
