    <JadeMethod name="showChooseColour" id="1694c38b-0a4a-4b1b-9ac6-ec862154c6e3">
        <source>showChooseColour(_col : Integer);
// ---------------------------------------------------------------------------
// Created:		November 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

	cmdColor	: CMDColor;
	tmpCell	: JadeTableCell;
	tmpText	: String;
	theTable : Table;
begin
	theTable := self.tblDim;

	create cmdColor transient;
	cmdColor.preventFullOpen := false;
	
	if _col = self.COLUMN_COLOUR then
		cmdColor.color := self.lblColour.backColor;
	else
		cmdColor.color := self.lblColourFill.backColor;
	
	endif;

	if cmdColor.open = 0 then
		if _col = self.COLUMN_COLOUR then
			self.lblColour.backColor := cmdColor.color;
			self.lblColour.foreColor := self.lblColour.backColor.getInverseColour();
		else
			self.lblColourFill.backColor := cmdColor.color;
			self.lblColourFill.foreColor := self.lblColourFill.backColor.getInverseColour();
		
		endif;		
		theTable.accessCell(theTable.row,_col).backColor := cmdColor.color;
	endif;


end;</source>
        <Parameter name="_col" type="Integer"/>
    </JadeMethod>
