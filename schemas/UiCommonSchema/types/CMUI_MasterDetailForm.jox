    <JadeMethod name="getDataRowForDef" id="b01e0836-88f9-4ce4-a4a0-a7c29b0f88ff">
        <source>getDataRowForDef(_obj : Object; _entDef : EntTableDef) : String;
// ---------------------------------------------------------------------------
// Created:     30 March 2004	cnwth2
//
// Purpose:     Developer to re-implement if the following not sufficient
//			 
//			 
// ----------   ----------  --------------------------------------------------
vars
	entRow		: EntTableRow;
	rowStr		: String;
begin
	if CM_Object.hasInstance(_obj) then
		foreach entRow in _entDef.allEntTableRows do
			rowStr := rowStr &amp; _obj.CM_Object.getDisplayStringForAttribute(entRow.name, false) &amp; Tab;
		endforeach;
	elseif CMIF_Object.hasInstance(_obj) then
		foreach entRow in _entDef.allEntTableRows do
			rowStr := rowStr &amp; _obj.CMIF_Object.getDisplayStringForAttribute(entRow.name, false) &amp; Tab;
		endforeach;	
	else
		return null;
	endif;
	
	return rowStr;
end;</source>
        <Parameter name="_obj" type="Object"/>
        <Parameter name="_entDef" type="EntTableDef"/>
        <ReturnType type="String"/>
    </JadeMethod>
