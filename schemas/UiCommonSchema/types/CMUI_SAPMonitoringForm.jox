    <JadeMethod name="initTableData" id="ee1582db-9d23-4f26-8a7e-6a493690dc0a">
        <updating/>
        <source>initTableData(_theEntDef: String) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 November 2018	jlgndl1	Initial creation

*/

vars

	tbl		: CM_DataTable;
	entTableDef	: EntTableDef;

begin
	
	tbl := self.tblData;
	
	self.totalJMT := 0;
	self.totalSAP := 0;
		
	entTableDef := app.myController.getEntTableDef(ETDef_SapServiceMon);
	if entTableDef = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Def (' &amp; ETDef_SapServiceMon &amp; ') not found');
		return;
	endif;
	self.tblData.setTblDataEntRowsArray(entTableDef, null, null);
	self.tblData.accessRow(1).height := 32;
	self.tblData.accessRow(1).wordWrap := true; 
	self.tblData.sortColumn[1] := null;
	return;

epilog

end;</source>
        <Parameter name="_theEntDef" type="String"/>
    </JadeMethod>
    <JadeMethod name="positionQueryFrame" id="b9c0df96-5b8c-4c12-9b52-55f86be8326f">
        <source>positionQueryFrame() protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 November 2018	jlgndl1	Initial creation	TFS 42116

*/

vars

begin

	self.frmQuery.left		:=	(self.width / 2) - (self.frmQuery.width / 2);
	self.frmQuery.top		:=	100;
	self.frmQuery.height	:=	320;
	self.frmQuery.width		:= 320;
	
	self.fldQuery.top		:=	self.frmQueryToolbar.clientHeight()+2;
	self.fldQuery.left		:=	0;
	self.fldQuery.height	:=	frmQuery.clientHeight() - (self.frmQueryToolbar.height + 30);
	self.fldQuery.width		:=	self.frmQuery.clientWidth();

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
