    <JadeMethod name="pxyCreateUpdateProxy" id="0dfb52dd-c506-4d7a-ab55-0775aa78ecc3">
        <source>pxyCreateUpdateProxy(): SelfType;
// --------------------------------------------------------------------------------
// Created:		25 August 2006 by cnwdad1
//
// Purpose:		Standard method to instantiate a proxy of the receiver.
//
// Parameters:	None
//
// Returns:		A reference to the proxy object.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 20/04/2011	cnwmh5		PAR #27401 - Add code to handle prossible exceptions occurring when
//							trying to create the proxy
// --------------------------------------------------------------------------------
vars
	proxyObj	: SelfType;
	completedOK		: Boolean;
	
begin
	proxyObj			:=	inheritMethod();
	proxyObj.myTerminal	:=	self.myTerminal;
	
	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return proxyObj;
	
epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete proxyObj;
	endif;	
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="bd08af43-3926-4686-88ae-496f4858c80f">
        <updating/>
        <source>setForCreate(_proxyObj:SelfType) updating;
// --------------------------------------------------------------------------------
// Created:		25 August 2006 by cnwdad1
//
// Purpose:		Standard transaction create method.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	_proxyObj.raiseExceptionIfNotTransient(method);
	self.setForUpdate(_proxyObj);
end;</source>
        <Parameter name="_proxyObj" type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="bef02f68-368b-4afa-94da-c37f7598a2ac">
        <updating/>
        <source>setForUpdate(_proxyObj:SelfType) updating;
// --------------------------------------------------------------------------------
// Created:		25 August 2006 by cnwdad1
//
// Purpose:		Standard transaction update method.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.isUseTerminalDefaults	:=	_proxyObj.isUseTerminalDefaults;
	self.nonChargeTime			:=	_proxyObj.nonChargeTime;
	self.stopChargingAt			:=	_proxyObj.stopChargingAt;
	self.grossLoadingTime		:=	_proxyObj.grossLoadingTime;
	self.grossDischargeTime		:=	_proxyObj.grossDischargeTime;
	self.vesselDownTime			:=	_proxyObj.vesselDownTime;
	self.vesselLoadRate			:=	_proxyObj.vesselLoadRate;
	self.vesselDischargeRate	:=	_proxyObj.vesselDischargeRate;
	self.defaultDraftArrival	:=	_proxyObj.defaultDraftArrival;
	self.defaultDraftDeparture	:=	_proxyObj.defaultDraftDeparture;
	self.nextNumber				:= 	_proxyObj.nextNumber;
	self.myPreferredBerth		:= 	_proxyObj.myPreferredBerth;
	
	self.myTerminal				:=	_proxyObj.myTerminal;
end;</source>
        <Parameter name="_proxyObj" type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setNextNumber" id="11e16c87-4679-40cd-bcac-1624d8e8e816">
        <updating/>
        <source>setNextNumber(_number : Integer) updating;
// ---------------------------------------------------------------------------
// Created:     02 June 2007 by cnwrs2
