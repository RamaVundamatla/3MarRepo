<Class name="CMQF_WarehouseStorage" id="2a9e8b27-675e-40c8-a390-344ba017a6e9">
    <superclass name="CMQF_BreakBulk"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="query"/>
    <PrimAttribute name="outwardsTIs" id="6093d701-119a-48ed-aad7-3f2fac775569">
        <embedded/>
        <type name="Integer"/>
    </PrimAttribute>
    <JadeMethod name="filterObjects" id="c4d0472b-9903-47ba-8ab9-d4e30fd03417">
        <updating/>
        <source>filterObjects(_collection  : Collection input; _passport : CM_Passport) updating;
// ---------------------------------------------------------------------------
// Created:     12 September 2002 by cnwth2
//
// Purpose:     
//
// ----------   ----------  --------------------------------------------------
vars
	op					: CM_Operator;
	opTerm				: CM_OperatorTerminal;
	onsiteIter,
	offsiteIter,
	onShipIter			: Iterator;
	onsiteDict			: CM_TIByCargoTypeIdDict;
	offsiteDict			: CM_TIByCargoTypeIdRelseDict;
	onShipDict			: CM_TIByCargoTypeIdDict;
	voyage				: CM_Voyage;
	ti					: CM_TrackedItem;
	storageLine 		: CMIF_WHStorageLine;
	totalCharge 		: Decimal[10,4];
	breakOut,
	loadStateSet		: Boolean;
	terminal			: CM_Terminal;
	startDT,
	endDT				: TimeStamp;
	failedDAC  :CM_DataAccessController;
begin
	op := self.myOperator;
	if op &lt;&gt; null and
	   (not op.canUserAccessSelf(null, failedDAC,_passport)) then
		return;
	endif;

	startDT.setDate(self.startDate);
	startDT.setTime("00:00:00".Time);
	endDT.setDate(self.endDate);
	endDT.setTime("23:59:59.999".Time);
	
	foreach terminal in self.allTerminals do :terminalLoop
		
		//onsite
		if op = null then
			onsiteDict := terminal.allOnsiteTIsByCargoTypeId;
		else
			opTerm := op.allOperatorTerminals[terminal];
			if opTerm = null then
				continue;
			endif;
	
			onsiteDict := opTerm.allOnsiteTIsByCargoTypeId;
		endif;
		
		delete onsiteIter;
		onsiteIter := onsiteDict.createIterator;
		onsiteDict.startKeyGeq(BOLType_Max, null, onsiteIter);
		
		while onsiteIter.next(ti) do :tiWhile
			if not self.checkStatusIncludesObject(ti, _passport, breakOut) then
//			if not self.includesObject(ti, _passport, breakOut) then
		//		if breakOut then
	//				break terminalLoop;
	//			endif;
				continue tiWhile;
			endif;
			
			totalCharge := ti.CM_BreakBulk.getStorageChargeForPeriod(self.startDate, self.endDate);
			if totalCharge &gt; 0 then
				create storageLine transient;
				storageLine.daysOnSiteForPeriod := ti.CM_BreakBulk.getDaysOnsiteForPeriod(self.startDate, self.endDate);
				storageLine.charge := totalCharge;
				storageLine.myTrackedItem := ti;
				_collection.add(storageLine);
			endif;
		endwhile;
		
		//Offsite
		if op = null then
			offsiteDict := terminal.allOffsiteTIsByCargoTypeId;
		else
			opTerm := op.allOperatorTerminals[terminal];
			if opTerm = null then
				continue;
			endif;
	
			offsiteDict := opTerm.allOffsiteTIsByCargoTypeId;
		endif;
		
		delete offsiteIter;
		offsiteIter := offsiteDict.createIterator;
		offsiteDict.startKeyGeq(BOLType_Max, null, null, offsiteIter);
		
		while offsiteIter.next(ti) do :tiWhile
			self.outwardsTIs := self.outwardsTIs + 1;
			if not self.checkStatusIncludesObject(ti, _passport, breakOut) then
//			if not self.includesObject(ti, _passport, breakOut) then
//				if breakOut then
//					break terminalLoop;
//				endif;
				continue tiWhile;
			endif;
			
			totalCharge := ti.CM_BreakBulk.getStorageChargeForPeriod(self.startDate, self.endDate);
			if totalCharge &gt; 0 then
				create storageLine transient;
				storageLine.daysOnSiteForPeriod := ti.CM_BreakBulk.getDaysOnsiteForPeriod(self.startDate, self.endDate);
				storageLine.charge := totalCharge;
				storageLine.myTrackedItem := ti;
				_collection.add(storageLine);
			endif;	
		endwhile;
		
		
		//onship stuff???
		//voyages
		foreach voyage in terminal.allVoyagesByCode discreteLock do : voyLoop

			if voyage.departedDT.isValid
			and voyage.departedDT.cnEcIsLessThanOrEqual(startDT) then
				continue voyLoop;
			endif;

			onShipDict := voyage.allOnshipTIsByCargoTypeId;
			
			delete onShipIter;
			onShipIter := onShipDict.createIterator;
			onShipDict.startKeyGeq(BOLType_Max, null, onShipIter);
 			
			while onShipIter.next(ti) do :tiWhile
				self.outwardsTIs := self.outwardsTIs + 1;
				if not self.checkStatusIncludesObject(ti, _passport, breakOut) then
//				if not self.includesObject(ti, _passport, breakOut) then
//					if breakOut then
//						break terminalLoop;
//					endif;
					continue tiWhile;
				endif;
				
				totalCharge := ti.CM_BreakBulk.getStorageChargeForPeriod(self.startDate, self.endDate);
				if totalCharge &gt; 0 then
					create storageLine transient;
					storageLine.daysOnSiteForPeriod := ti.CM_BreakBulk.getDaysOnsiteForPeriod(self.startDate, self.endDate);
					storageLine.charge := totalCharge;
					storageLine.myTrackedItem := ti;
					_collection.add(storageLine);
				endif;	
			endwhile;
			
		endforeach;
		
		//... and archived voyages
		foreach voyage in terminal.allVoyagesArchived discreteLock do : aVoyLoop

			if voyage.departedDT.isValid
			and voyage.departedDT.cnEcIsLessThanOrEqual(startDT) then
				continue aVoyLoop;
			endif;

			onShipDict := voyage.allOnshipTIsByCargoTypeId;
			
			delete onShipIter;
			onShipIter := onShipDict.createIterator;
			onShipDict.startKeyGeq(BOLType_Max, null, onShipIter);
 			
			while onShipIter.next(ti) do :tiWhile
				self.outwardsTIs := self.outwardsTIs + 1;
				if not self.checkStatusIncludesObject(ti, _passport, breakOut) then
//				if not self.includesObject(ti, _passport, breakOut) then
//					if breakOut then
//						break terminalLoop;
//					endif;
					continue tiWhile;
				endif;
				
				totalCharge := ti.CM_BreakBulk.getStorageChargeForPeriod(self.startDate, self.endDate);
				if totalCharge &gt; 0 then
					create storageLine transient;
					storageLine.daysOnSiteForPeriod := ti.CM_BreakBulk.getDaysOnsiteForPeriod(self.startDate, self.endDate);
					storageLine.charge := totalCharge;
					storageLine.myTrackedItem := ti;
					_collection.add(storageLine);
				endif;	
			endwhile;
			
		endforeach;
		
	endforeach;	
epilog

	app.cmsEndLoad(loadStateSet);
	delete onShipIter;
	delete onsiteIter;
	delete offsiteIter;	
end;</source>
        <Parameter name="_collection" type="Collection" usage="input"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="includesObject" id="4661962b-35d0-4555-9df2-9deef03551aa">
        <updating/>
        <source>includesObject(_ti: CM_TrackedItem; _passport : CM_Passport; _breakOut : Boolean output): Boolean updating, protected;
// ---------------------------------------------------------------------------
// Created:     12 September 2002 by cnwth2
//
// Purpose:     
//
// ----------   ----------  --------------------------------------------------
vars
	querySelf		: CMQF_WarehouseStorage;
	failedDAC		:CM_DataAccessController;
	
begin
	querySelf := self;
	querySelf.numSearched := querySelf.numSearched + 1;
	
	if (not CM_BreakBulkGeneric.hasInstance(_ti))
	or (self.getMyCargoType &lt;&gt; null and _ti.cargoType &lt;&gt; self.getMyCargoType.id)
	or (self.getMyProduct &lt;&gt; null and _ti.myProduct &lt;&gt; self.getMyProduct)
	or (self.getMySubTerminal &lt;&gt; null and _ti.mySubTerminal &lt;&gt; self.getMySubTerminal) //29/04/2009 cnwdz2 ccms1735
	or _ti.state = TI_STATE_DELETED
	or (not _ti.canUserAccessSelf(null, failedDAC,_passport))
	then
		return false;
	endif;
	
	self.numFound := self.numFound + 1;
	return true;
end;</source>
        <access>protected</access>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_passport" type="CM_Passport"/>
        <Parameter name="_breakOut" type="Boolean" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="initialize" id="023dbf90-907b-427b-97e9-9d13f1d38cfc">
        <updating/>
        <source>initialize() updating;
// ---------------------------------------------------------------------------
// Created:     12 September 2002 by cnwth2
//
// Purpose:     
//
// ----------   ----------  --------------------------------------------------
/*

Date		Who		Reason
10 Jun 2008	cnwkpd1	PAR #16753 - CCMS SFW 1003 - General Cargo Graphical Screens

*/

vars

begin
	inheritMethod();
	self.terminalAreaTypes.add(TA_TYPE_IRREGULAR_BLOCK_AREA);			// was TA_TYPE_GENERAL_CARGO_AREA
end;</source>
    </JadeMethod>
</Class>
