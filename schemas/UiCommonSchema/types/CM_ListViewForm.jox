    <JadeMethod name="showThumbnailData" id="b64ee9fa-655a-4ce5-a074-9d6b2a8a5471">
        <updating/>
        <source>showThumbnailData(obj : Object) updating;
// ---------------------------------------------------------------------------
// Created:     16 November 2000 by cnwrs2
//
// Purpose:     Display the data in the thumbnail table.  This should be reimplemented.
//				Refer to the sample code below.
//
// Parameters:  The object to be displayed in the thumbnail.
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	if app.isDevelopmentSystem then
		app.writeStatement( class.name &amp; '::' &amp; method.name &amp; '  WARNING - you need to reimplement this method in your own form.');

		self.lstData.addItem('Developer needs to reimplement ' &amp; method.name &amp; ' at the form level');
	endif;

/* 
Sample code for reimplimentation:

	br := obj.CM_BulkRelease;
	
	tblThumb.rows := 0;
	
	tblThumb.addItem('Release No' &amp; Tab &amp; br.code);
	tblThumb.addItem('Operator' &amp; Tab &amp; br.supplier);
	tblThumb.addItem('');			// adds a blank row
	tblThumb.addItem('Date' &amp; Tab &amp; br.releaseDate.String);

*/
end;</source>
        <Parameter name="obj" type="Object"/>
    </JadeMethod>
    <JadeMethod name="sysNotify" id="e4c8b7c4-280c-4658-988f-124d702ecac4">
        <controlMethod name="Form::sysNotify"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>sysNotify(eventType: Integer; theObject: Object; eventTag: Integer) updating;
// ---------------------------------------------------------------------------
// Created:     11 May 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	if eventType = Object_Update_Event then
		self.zLstDataSysNotifyUpdate(eventType, theObject, eventTag);
	elseif eventType = Object_Create_Event then
		self.zLstDataSysNotifyCreate(eventType, theObject, eventTag);
	elseif eventType = Object_Delete_Event then
		self.zLstDataSysNotifyDelete(eventType, theObject, eventTag);
	endif;

end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
    </JadeMethod>
