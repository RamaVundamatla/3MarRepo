    <JadeMethod name="initTable" id="e2df22a0-662b-4ab1-ae3f-f167d32ad396">
        <source>initTable();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
29 December 2009	cnwndl1	Initial creation	CCMS MES 1006

*/

vars

	entTableDef		: EntTableDef;
		
begin

	self.tblResources.fixedRows := 1;
	self.tblResources.rows := 1;
	self.tblResources.userInputEnabled := false;
	self.tblResources.selectMode := CM_EntryTable.SelectMode_FixedRow;
	self.tblResources.selectionType := CM_EntryTable.SelectionType_Row;
	
	entTableDef := app.myController.getEntTableDef(ETDef_ToDoUsage);
	if entTableDef &lt;&gt; null then
		self.tblResources.setTblDataEntRowsFromDef(entTableDef);
	endif;
	
	self.tblResources.cnEcResizeContents();
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="loadDataForFirstTime" id="851697a8-459d-497b-a74b-0f8c68ecc30e">
        <updating/>
        <source>loadDataForFirstTime() updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
29 December 2009	cnwndl1	Initial creation	CCMS MES 1006

*/

vars

	type : CM_ResourceType;
	index : Integer;
	taskDescCode : Integer;
	taskDesc : CM_ToDoTaskDesc;
	cmObj : CM_Object;
	todo : CM_ToDoTask;
begin

	inheritMethod();
	
	initTable();
	
	cmbResourceType.clear();
	
	
	 // ### TFS CR 54345 TASK 58281 01JUN2023 NAVAB1
	if self.myTransaction &lt;&gt; null then
		todo := self.myTransaction.getToDoTask();
	elseif self.myToDoTransaction &lt;&gt; null then
		todo := self.myToDoTransaction.getToDoTask();
	endif;
	if todo &lt;&gt; null then
		taskDesc := todo.toDoTaskDesc;
	else
		taskDesc := self.myToDoTaskDesc;
	endif;
	
		/* // ### TFS CR 54345 TASK 58281 01JUN2023 NAVAB1
	if self.myTransaction &lt;&gt; null then
		if self.myTransaction.myToDoTask &lt;&gt; null then
			taskDesc := self.myTransaction.myToDoTask.getMyToDoTaskDesc;
		else
			taskDesc := app.myRoot.allToDoTaskDescriptions.getAtKey(self.myTransaction.type);
		endif;

	else
		taskDesc := self.myToDoTaskDesc;
	endif;
*/
	if taskDesc &lt;&gt; null then
		foreach cmObj in taskDesc.allResourceTypes do
			if cmObj.isKindOf(CM_ResourceType) then
				type := cmObj.CM_ResourceType;
				if not type.isAvailable and self.myTransaction = null then	// 25 Mar 2010	NDL	Par 22725
					continue;
				endif;
				index := cmbResourceType.addItem( type.description );
				cmbResourceType.itemObject[index] := type;
				if not type.isAvailable then	// 25 Mar 2010	NDL	Par 22725	
					cmbResourceType.itemEnabled[index] := false;
				endif;
			endif;
		endforeach;
	else
		foreach type in app.myRoot.allTaskResourceTypes
			where type.type = TODO_TYPE_GROUP_TI or type.type = TODO_TYPE_GROUP_ALL do // ### TFS #56635[54261] 22NOV2022 NAVAB1

			if not type.isAvailable then	// 25 Mar 2010	NDL	Par 22725
				continue;
			endif;
			index := cmbResourceType.addItem( type.description );
			cmbResourceType.itemObject[index] := type;
		endforeach;
	endif;
	
	//clearGrpResource();	// 11/01/2011 cnwar2 #26691 - resource group will now be enabled/disabled depending on where the form loaded from
	if self.cmbResourceType.listCount = 1 then	//Start navtnr20 26-07-2023 Bug 59313
		self.cmbResourceType.listIndex := 1;
	else
		self.cmbResourceType.listIndex := -1; //End navtnr20 26-07-2023 Bug 59313
	endif;
	loadTableData();

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="loadTableData" id="ec9dbea1-04ff-45ef-ac58-e6d2fcfa81c3">
        <source>loadTableData();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
29 December 2009	cnwndl1	Initial creation	CCMS MES 1006

*/

vars

	usage : CM_ResourceTypeUsage;
	
begin

	self.tblResources.rows := self.tblResources.fixedRows;
	self.tblResources.allSelectedObjects.clear();

	foreach usage in self.allProxyResourceTypeUsages do
		addUsageToTblResources(usage);
	endforeach;
	
	foreach usage in self.allNewProxyResourceTypeUsages do
		addUsageToTblResources(usage);
	endforeach;
	
	self.tblResources.row := self.tblResources.fixedRows;
	
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="makePalletStuffVisible" id="8869bb0b-aca6-42b8-bbf3-d76d45f1d09f">
        <source>makePalletStuffVisible( _type : CM_ResourceType );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 April 2017	cnwndl1	Initial creation	TFS 3414

*/

vars

	ti : CM_TrackedItem;
	handlingType : CM_HandlingType;

begin

	self.frmPallet.visible := false;
	
	self.chkHeatTreated.value := false;
	self.chkStoreOnP.value := false;
	self.cmbPalletType.clear();
	self.allPalletTypes.clear();
	
	if _type = null or not _type.additionalInfoIs( EXTRA_INFO_PALLET ) then
		return;
	endif;
	
	if self.myTrackedItem = null and self.myCurrentProxyUsage = null then
		return;
	endif;
	
	if self.myTrackedItem &lt;&gt; null then
		handlingType := self.myTrackedItem.getHandlingType;
		
	elseif self.myCurrentProxyUsage &lt;&gt; null then
		if self.myCurrentProxyUsage.myTransaction = null then
			return;
		endif;
		
		if self.myCurrentProxyUsage.myTransaction.isCargoTrx() then  // ### TFS 53812 04AUG2022 NAVAB1
			ti := self.myCurrentProxyUsage.myTransaction.CM_TITransaction.myTrackedItem;
			if ti = null then
				return;
			endif;
			handlingType := ti.getHandlingType;
		endif;
		
	endif;
	
	if handlingType = null or not handlingType.isPallet then
		return;
	endif;
	
	handlingType.getValidSubTypes( self.allPalletTypes, false );
	self.cmbPalletType.listCollection( self.allPalletTypes, false , 0 );
	
	self.frmPallet.visible := not self.allPalletTypes.isEmpty;
	
	self.clickStoreOnPallet();	//21 Jan 2020	NDL	TFS 48248

epilog

end;</source>
        <Parameter name="_type" type="CM_ResourceType"/>
    </JadeMethod>
