    <JadeMethod name="addBoxcarLoadPosition" id="03e72f21-3137-4f64-b8f6-279f4e49fa4b">
        <source>addBoxcarLoadPosition( _row, _col : Integer; _lc : CM_LocationsController ) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26 March 2013	cnwndl1	Initial creation	Par 31278

*/

vars

	key : String;
	gl  : CMIF_RDTGridLocation;
	
begin

	if _lc = null then
		return;
	endif;
	create gl transient;
	gl.row := _row;
	gl.col := _col;
	
	key := _lc.getOidAsString();
	self.addObjectForKey(self.allBoxcarLoadPositions, key, gl);
	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_row" type="Integer"/>
        <Parameter name="_col" type="Integer"/>
        <Parameter name="_lc" type="CM_LocationsController"/>
    </JadeMethod>
    <JadeMethod name="addTrack" id="b4639275-f418-4f2e-bdf6-118c7fdc6314">
        <source>addTrack(_row, _col : Integer; _track : CMIF_RDTTrackDrawElement input) protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
25 May 2010	cnwjk3	Initial creation

*/

vars
	key : String;
begin
	key := self.getRowColKey(_row, _col);
    _track.setKey(key);
	_track.initSizesOffsets(self.trackLeftGridOffsetFt, self.trackTopGridOffsetFt, self.trackWidthFt, self.trackHeightFt);
	self.addObjectForKey(self.allTracksByGridPos, key, _track);
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_row" type="Integer"/>
        <Parameter name="_col" type="Integer"/>
        <Parameter name="_track" type="CMIF_RDTTrackDrawElement" usage="input"/>
    </JadeMethod>
    <JadeMethod name="addWagonPart" id="77ac8565-e433-4187-8229-97c7bc5968b6">
        <source>addWagonPart(_row, _col : Integer; _wp : CMIF_RDTWagonPartDrawElement input) protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
25 May 2010	cnwjk3	Initial creation

*/

vars
	key : String;
begin
	key := self.getRowColKey(_row, _col);		
	_wp.setKey(key);
	_wp.initSizesOffsets(self.wagonLeftGridOffsetFt, self.wagonTopGridOffsetFt, self.wagonWidthFt, self.wagonHeightFt);
	self.addObjectForKey(self.allWagonPartsByGridPos, key, _wp);
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_row" type="Integer"/>
        <Parameter name="_col" type="Integer"/>
        <Parameter name="_wp" type="CMIF_RDTWagonPartDrawElement" usage="input"/>
    </JadeMethod>
    <JadeMethod name="build" id="773cf5d2-8bf9-4795-9c9f-a430f3dcfd76">
        <updating/>
        <source>build(_mode : Integer; _lc : CM_LocationsController; _ta: CM_TerminalArea; _leftCol: Integer; _rightCol: Integer; _topRow: Integer; _bottomRow: Integer; _scaleFactor : Real; _isLandscape, _flipH, _flipV : Boolean) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
25 May 2010	cnwjk3	Initial creation

*/

vars

begin
	if not _ta.isKindOf(CM_Rail) then
		app.raiseUnexpectedProgramError(class.name, method.name, "Expecting rail area type");
		return;
	endif;
	
	//if not _lc.isKindOf(CM_WagonController) then
	if not _lc.isWagon then//27 May 2013	NDL	Part of Boxcar conversion
		app.raiseUnexpectedProgramError(class.name, method.name, "Expecting wagon controller type");
		return;
	endif;
	
	self.maxGridCol := 0;
	self.maxGridRow := 0;
	inheritMethod(_mode, _lc, _ta, _leftCol, _rightCol, _topRow, _bottomRow, _scaleFactor, _isLandscape, _flipH, _flipV);
epilog

end;</source>
        <Parameter name="_mode" type="Integer"/>
        <Parameter name="_lc" type="CM_LocationsController"/>
        <Parameter name="_ta" type="CM_TerminalArea"/>
        <Parameter name="_leftCol" type="Integer"/>
        <Parameter name="_rightCol" type="Integer"/>
        <Parameter name="_topRow" type="Integer"/>
        <Parameter name="_bottomRow" type="Integer"/>
        <Parameter name="_scaleFactor" type="Real"/>
        <Parameter name="_isLandscape" type="Boolean"/>
        <Parameter name="_flipH" type="Boolean"/>
        <Parameter name="_flipV" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="buildLandscapeFace" id="216b07da-74bc-4b4c-9205-165e74140cad">
        <updating/>
        <source>buildLandscapeFace(_lc: CM_LocationsController; _ta: CM_TerminalArea; _leftCol: Integer; _rightCol: Integer; _topRow: Integer; _bottomRow: Integer; _scaleFactor: Real) updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
01 June 2010	cnwjk3	Initial creation

*/

vars
	col				: Integer;
	wagonController	: CM_WagonController;
	railArea 		: CM_Rail;
	railLine		: CM_RailLine;
begin
	wagonController := _lc.CM_WagonController;
	railLine := wagonController.getRailLine();
	col := self.buildRailLineSide(railLine, 1);
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_lc" type="CM_LocationsController"/>
        <Parameter name="_ta" type="CM_TerminalArea"/>
        <Parameter name="_leftCol" type="Integer"/>
        <Parameter name="_rightCol" type="Integer"/>
        <Parameter name="_topRow" type="Integer"/>
        <Parameter name="_bottomRow" type="Integer"/>
        <Parameter name="_scaleFactor" type="Real"/>
    </JadeMethod>
    <JadeMethod name="buildLandscapeTopDown" id="0aa754cb-ae23-4e0e-a9b1-c1dab3829904">
        <updating/>
        <source>buildLandscapeTopDown(_lc : CM_LocationsController; _ta: CM_TerminalArea; _leftCol: Integer; _rightCol: Integer; _topRow: Integer; _bottomRow: Integer; _scaleFactor : Real) updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
25 May 2010	cnwjk3	Initial creation

*/

vars
	col,
	row		 		: Integer;
	railArea 		: CM_Rail;
	railLine		: CM_RailLine;
	trackDraw		: CMIF_RDTTrackDrawElement;
	trackLengths	: IntegerArray;
	length,
	longestTrack	: Integer;
begin

	create trackLengths transient;
	
	// We will be building from left to right, a rake at a time
	
	// Note that in the case of rail areas, we build a map of the whole area, NOT just the area subset as defined
	// by the col/row parameters passed into this method
	
	
	railArea := _ta.CM_Rail;
	
	foreach row in 1 to railArea.allRailLinesByIndex.size() do
		railLine := railArea.allRailLinesByIndex[row];
		col := self.buildRailLineTopView(railLine, row, true);
		if col &gt; self.maxGridCol then
			self.setMaxGridCol(col);
		endif;
		
		// Stuff to help pad out the track lengths for rakes with less wagons present
		if col &gt; longestTrack then
			longestTrack := col -1;
		endif;
		
		trackLengths.add(col);
	
	endforeach;
	
	// Pad out the tracks 
	row := 1;
	foreach length in trackLengths do
		if length &lt; longestTrack then
			foreach col in length to longestTrack do
				create trackDraw transient;
				trackDraw.type := trackDraw.NORMAL;
				self.addTrack(row, col, trackDraw);				
			endforeach;
		endif;
		row := row + 1;
	endforeach;
	
	
	self.setMaxGridRow(railArea.allRailLinesByIndex.size());
	
	
epilog
	delete trackLengths;
end;</source>
        <access>protected</access>
        <Parameter name="_lc" type="CM_LocationsController"/>
        <Parameter name="_ta" type="CM_TerminalArea"/>
        <Parameter name="_leftCol" type="Integer"/>
        <Parameter name="_rightCol" type="Integer"/>
        <Parameter name="_topRow" type="Integer"/>
        <Parameter name="_bottomRow" type="Integer"/>
        <Parameter name="_scaleFactor" type="Real"/>
    </JadeMethod>
    <JadeMethod name="buildPortraitFace" id="56123263-db15-420a-ac20-3c5b7d11dd9c">
        <updating/>
        <source>buildPortraitFace(_lc: CM_LocationsController; _ta: CM_TerminalArea; _leftCol: Integer; _rightCol: Integer; _topRow: Integer; _bottomRow: Integer; _scaleFactor: Real) updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
01 June 2010	cnwjk3	Initial creation

*/

vars
	row				: Integer;
	wagonController	: CM_WagonController;
	railArea 		: CM_Rail;
	railLine		: CM_RailLine;
begin
	wagonController := _lc.CM_WagonController;
	railLine := wagonController.getRailLine();
	row := self.buildRailLineTopView(railLine, 1, false);
	self.setMaxGridCol(row);
	self.setMaxGridRow(1);
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_lc" type="CM_LocationsController"/>
        <Parameter name="_ta" type="CM_TerminalArea"/>
        <Parameter name="_leftCol" type="Integer"/>
        <Parameter name="_rightCol" type="Integer"/>
        <Parameter name="_topRow" type="Integer"/>
        <Parameter name="_bottomRow" type="Integer"/>
        <Parameter name="_scaleFactor" type="Real"/>
    </JadeMethod>
    <JadeMethod name="buildPortraitTopDown" id="71fdd419-30ef-40bd-8847-ece2bfd4a595">
        <updating/>
        <source>buildPortraitTopDown(_lc : CM_LocationsController; _ta: CM_TerminalArea; _leftCol: Integer; _rightCol: Integer; _topRow: Integer; _bottomRow: Integer; _scaleFactor : Real) updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
25 May 2010	cnwjk3	Initial creation

*/

vars
	col,
	row		 		: Integer;
	railArea 		: CM_Rail;
	railLine		: CM_RailLine;
	trackDraw		: CMIF_RDTTrackDrawElement;
	trackLengths	: IntegerArray;
	length,
	longestTrack	: Integer;
begin

	create trackLengths transient;
	
	// We will be building from top to bottom, a rake at a time
	
	// Note that in the case of rail areas, we build a map of the whole area, NOT just the area subset as defined
	// by the col/row parameters passed into this method
	
	
	// Portrait, so row = col and col = row
	
	railArea := _ta.CM_Rail;
	
	foreach col in 1 to railArea.allRailLinesByIndex.size() do
		railLine := railArea.allRailLinesByIndex[col];
		row := self.buildRailLineTopView(railLine, col, false);
		if row &gt; self.maxGridCol then
			self.setMaxGridCol(row);
		endif;
		
		// Stuff to help pad out the track lengths for rakes with less wagons present
		if row &gt; longestTrack then
			longestTrack := row -1;
		endif;
		
		trackLengths.add(row);
	
	endforeach;
	
	// Pad out the tracks 
	col := 1;
	foreach length in trackLengths do
		if length &lt; longestTrack then
			foreach row in length to longestTrack do
				create trackDraw transient;
				trackDraw.type := trackDraw.NORMAL;
				self.addTrack(row, col, trackDraw);				
			endforeach;
		endif;
		col := col + 1;
	endforeach;
	
	
	self.setMaxGridRow(railArea.allRailLinesByIndex.size());
	
	
epilog
	delete trackLengths;
end;</source>
        <access>protected</access>
        <Parameter name="_lc" type="CM_LocationsController"/>
        <Parameter name="_ta" type="CM_TerminalArea"/>
        <Parameter name="_leftCol" type="Integer"/>
        <Parameter name="_rightCol" type="Integer"/>
        <Parameter name="_topRow" type="Integer"/>
        <Parameter name="_bottomRow" type="Integer"/>
        <Parameter name="_scaleFactor" type="Real"/>
    </JadeMethod>
    <JadeMethod name="buildRailLineSide" id="52b80a63-11b7-4ae2-a315-14ee13528c74">
        <updating/>
        <source>buildRailLineSide(_railLine : CM_RailLine; _row : Integer) : Integer updating, protected;

/*

Purpose:			

Parameters:	 

Return Value:		


Date		Who		Reason
01 June 2010	cnwjk3	Initial creation

*/

vars
//	numMidSections,
	tiRow,
	trackRow,
	lcRow,
	wagonRow,
//	row,
	maxCargoHeight,
//	lcCount,
	count,
	col 			: Integer;
	wagon			: CM_Wagon;
//	lc				: CM_LocationsController;	
//	wagonPart		: CMIF_RDTWagonPartDrawElement;
//	lcDraw			: CMIF_RDTLocationDrawElement;
	trackDraw		: CMIF_RDTTrackDrawElement;
//	tiDraw			: CMIF_RDTTIDrawElement;
//	ti				: CM_TrackedItem;
begin
	
	// We are only supporting landscape for the side view.
	
	// A note about locations for wagons.
	// JMT allows wagons to hold cargo stacked more than one high.  Unfortunately, findLocation() appears to ignore the stack height 
	// portion of the location string.  For example, for the location string RR1 0101 01 02  (RailArea WagonPosition LCposition stackHeight),
	// 02 on the end (height) is ignored.
	// If we ever want to support this properly, findLocation() will first need fixing, then we will need to key the location controllers
	// in on the full id.  At present, CM_WagonController::getFullId() also omits the stack height. - JK
	
	
//	row := _row;
	col := 1;
	_railLine.getMaxStackHeight(maxCargoHeight);
	
	// Work out the rows we need to start drawing from
	lcRow 		:= maxCargoHeight;
	tiRow 		:= maxCargoHeight;
	wagonRow 	:= lcRow + 1;
	trackRow	:= wagonRow;
	
	// Start off with a bit of track
	create trackDraw transient;
	trackDraw.type := trackDraw.NORMAL;
	self.addTrack(trackRow, col, trackDraw);
			
	col := col + 1;
	
	
	foreach wagon in _railLine.allWagons do
		// note - wagon can be null which indicates and empty position
		// need to handle this. Could just put 5 bits of track in for now;
		if wagon = null then
			foreach count in 1 to 5 do
				create trackDraw transient;
				trackDraw.type := trackDraw.NORMAL;
				self.addTrack(trackRow, col, trackDraw);
				col := col + 1; 
			endforeach;
			
		else
			self.buildWagonSideView( wagon, wagonRow, col, lcRow, tiRow, trackRow );
		/*	lcCount := 1;
			numMidSections := 0;
			foreach lc in wagon.allLocationsControllersArray do
				
				// Create the wagon parts
				if lcCount = 1 then
					// start the wagon off
					create wagonPart transient;
					wagonPart.partType := wagonPart.FRONT;
					wagonPart.setWagon(wagon);
					self.addWagonPart(wagonRow, col, wagonPart);
				elseif lcCount = wagon.allLocationsControllersArray.size() then
					// end the wagon 
					create wagonPart transient;
					wagonPart.partType := wagonPart.BACK;
					wagonPart.setWagon(wagon);
					self.addWagonPart(wagonRow, col, wagonPart);
				else
					// mid section of the wagon
					create wagonPart transient;
					wagonPart.partType := wagonPart.MID;
					wagonPart.setWagon(wagon);
					if numMidSections = 0 then
						wagonPart.setDisplayWagonPos(true);
					endif;					
					self.addWagonPart(wagonRow, col, wagonPart);					
					numMidSections := numMidSections + 1;
				endif;
										
				// Add the location
				create lcDraw transient;
				lcDraw.setLocationsController(lc);
				
				self.addLocation(lcRow, col, lcDraw);
		
				lcCount := lcCount + 1; 

				// Add the TIs if any
				row := tiRow;
				foreach ti in lc.allTrackedItems do
					if ti.myPrimaryActualLocation = lc then
						create tiDraw transient;
						tiDraw.setTI(ti);
						self.addTI(row, col, tiDraw);
					endif;
					row := row - 1;
				endforeach;
				
					
				create trackDraw transient;
				trackDraw.type := trackDraw.NORMAL;
				self.addTrack(trackRow, col, trackDraw);

				col := col + 1;

			endforeach;
			
			// Add a piece of track at the end of each wagon 
			create trackDraw transient;
			trackDraw.type := trackDraw.NORMAL;
			self.addTrack(trackRow, col, trackDraw);
			
			col := col + 1; */
		endif;
					
	endforeach;
	self.setMaxGridCol(col);
	self.setMaxGridRow(maxCargoHeight + 1 ); // + 1 = 1 row to hold wagon and track
	
	return col;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_railLine" type="CM_RailLine"/>
        <Parameter name="_row" type="Integer"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="buildRailLineTopView" id="e142bf8d-14cd-4c37-9b43-2fd7bc0d7340">
        <source>buildRailLineTopView(_railLine : CM_RailLine; _col : Integer; _isLandscape : Boolean) : Integer protected;

/*

Purpose:			

Parameters:	 _col column number when in portrait mode

Return Value:		


Date		Who		Reason
01 June 2010	cnwjk3	Initial creation

*/

vars
	numMidSections,
	lcCount,
	count,
	row 			: Integer;
	wagon			: CM_Wagon;
	lc				: CM_LocationsController;	
	wagonPart		: CMIF_RDTWagonPartDrawElement;
	lcDraw			: CMIF_RDTLocationDrawElement;
	trackDraw		: CMIF_RDTTrackDrawElement;
	tiDraw			: CMIF_RDTTIDrawElement;
	ti				: CM_TrackedItem;
begin
	row := 1;
	
	// Start off with a bit of track
	create trackDraw transient;
	trackDraw.type := trackDraw.NORMAL;
	if _isLandscape then
		self.addTrack(_col, row, trackDraw);
	else
		self.addTrack(row, _col, trackDraw);
	endif;
			
	row := row + 1;

	foreach wagon in _railLine.allWagons do
		// note - wagon can be null which indicates and empty position
		// need to handle this. Could just put 5 bits of track in for now;
		if wagon = null then
			foreach count in 1 to 5 do
				create trackDraw transient;
				trackDraw.type := trackDraw.NORMAL;
				if _isLandscape then 
					self.addTrack(_col, row, trackDraw);
				else
					self.addTrack(row, _col, trackDraw);
				endif;
				row := row + 1; 
			endforeach;
			
		else
			lcCount := 1;
			numMidSections := 0;
			
			self.buildWagonTopView( _isLandscape, wagon, row, _col );
			
		/*	foreach lc in wagon.allLocationsControllersArray do
				
				// Create the wagon parts
				if lcCount = 1 then
					// start the wagon off
					create wagonPart transient;
					wagonPart.partType := wagonPart.FRONT;
					wagonPart.setWagon(wagon);
					if _isLandscape then
						self.addWagonPart(_col, row, wagonPart);
					else
						self.addWagonPart(row, _col, wagonPart);
					endif;
				elseif lcCount = wagon.allLocationsControllersArray.size() then
					// end the wagon 
					create wagonPart transient;
					wagonPart.partType := wagonPart.BACK;
					wagonPart.setWagon(wagon);
					if _isLandscape then
						self.addWagonPart(_col, row, wagonPart);
					else
						self.addWagonPart(row, _col, wagonPart);
					endif;
				else
					// mid section of the wagon
					create wagonPart transient;
					wagonPart.partType := wagonPart.MID;
					wagonPart.setWagon(wagon);
					if numMidSections = 0 then
						wagonPart.setDisplayWagonPos(true);
					endif;
					
					if _isLandscape then
						self.addWagonPart(_col, row, wagonPart);					
					else
						self.addWagonPart(row, _col, wagonPart);					
					endif;
					numMidSections := numMidSections + 1;
				endif;
					
				//write "Keying in lc: " &amp; lc.ident &amp; " at pos (row, col): " &amp; row.String &amp; "," &amp; col.String;
					
				// Add the location
				create lcDraw transient;
				lcDraw.setLocationsController(lc);
				
				if _isLandscape then
					self.addLocation(_col, row, lcDraw);
				else
					self.addLocation(row, _col, lcDraw);
				endif;
		
				lcCount := lcCount + 1; 

				// Add TI if any
				//ti := lc.getTopTI(REAL_MODE);
				ti := lc.allTrackedItems.last;
				if ti &lt;&gt; null and ti.myPrimaryActualLocation = lc then
					create tiDraw transient;
					tiDraw.setTI(ti);
					if _isLandscape then
						self.addTI(_col, row, tiDraw);
					else
						self.addTI(row, _col, tiDraw);
					endif;
				endif;

				row := row + 1;

			endforeach; */
			
			// Add a piece of track at the end of each wagon 
			create trackDraw transient;
			trackDraw.type := trackDraw.NORMAL;
			if _isLandscape then
				self.addTrack(_col, row, trackDraw);
			else
				self.addTrack(row, _col, trackDraw);						
			endif;
			
			row := row + 1;
		endif;
					
	endforeach;

	return row;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_railLine" type="CM_RailLine"/>
        <Parameter name="_col" type="Integer"/>
        <Parameter name="_isLandscape" type="Boolean"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="buildWagonSideView" id="3eab7ae9-27b3-4f3e-ba28-9376e1a0952c">
        <source>buildWagonSideView( _wagon : CM_Wagon; wagonRow : Integer io; col : Integer io; lcRow : Integer io; tiRow : Integer; trackRow : Integer io )protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25 March 2013	cnwndl1	Initial creation	Par 31278 - migrated and rehashed for boxcars.

*/

vars

	lcCount : Integer;
	numMidSections : Integer;
	row : Integer;
	lc : CM_LocationsController;
	wagonPart : CMIF_RDTWagonPartDrawElement;
	lcDraw : CMIF_RDTLocationDrawElement;
	ti : CM_TrackedItem;
	tiDraw : CMIF_RDTTIDrawElement;
	trackDraw : CMIF_RDTTrackDrawElement;
	
	length : Decimal [16,4];
	height : Decimal [5,1];
	maxLengthUnits : Integer;
	doorPosArray : IntegerArray;
	loadPosition : Integer;
	
	well : CM_WellcarWellVisit;
	maxNumInStack : Integer;
	heightIndex : Integer;

begin

	lcCount := 1;
	numMidSections := 0;
	
	if _wagon.isBoxcar then
	
		lc := _wagon.allLocationsControllersArray.first;
		create doorPosArray transient;
		_wagon.CM_BoxcarVisit.getBoxcarLengthAndDoorPosition( maxLengthUnits, doorPosArray );
		loadPosition := doorPosArray.first;
		
		foreach lcCount in 1 to maxLengthUnits do
			
			// Create the wagon parts
			if lcCount = 1 then
				// start the wagon off
				create wagonPart transient;
				wagonPart.partType := wagonPart.FRONT;
				wagonPart.setWagon(_wagon, lc);
				self.addWagonPart(wagonRow, col, wagonPart);
			elseif lcCount = maxLengthUnits then
				// end the wagon 
				create wagonPart transient;
				wagonPart.partType := wagonPart.BACK;
				wagonPart.setWagon(_wagon, lc );
				self.addWagonPart(wagonRow, col, wagonPart);
			else
				// mid section of the wagon
				create wagonPart transient;
				wagonPart.partType := wagonPart.MID;
				wagonPart.setWagon(_wagon, lc);
				if numMidSections = 0 then
					wagonPart.setDisplayWagonPos(true);
				endif;					
				self.addWagonPart(wagonRow, col, wagonPart);					
				numMidSections := numMidSections + 1;
				
			endif;
			
			// Add the location
			create lcDraw transient;
			lcDraw.setLocationsController(lc);
			self.addLocation(lcRow, col, lcDraw);
			lcDraw.boxcarLocIndex := lcCount;
			if lcCount = 1 then
				lcDraw.isBoxcarFront := true;
				lcDraw.setShowCargoCount(true);
			elseif lcCount = maxLengthUnits then
				lcDraw.isBoxcarBack := true;
			endif;
			if lcCount = loadPosition then
				self.addBoxcarLoadPosition( lcRow, col, lc );
				lcDraw.isBoxcarDoor := true;
			elseif doorPosArray.includes(lcCount) then
				lcDraw.isBoxcarDoor := true;
			endif;
			
				
			create trackDraw transient;
			trackDraw.type := trackDraw.NORMAL;
			self.addTrack(trackRow, col, trackDraw);
	
			col := col + 1;
	
		endforeach;

	
	elseif _wagon.isFlatcar or  _wagon.isWellcarVisit then
		maxNumInStack := _wagon.myWagonClass.maxNumInStack;
		foreach lc in _wagon.allLocationsControllersArray do
			
			// Create the wagon parts
			if lcCount = 1 then
				// start the wagon off
				create wagonPart transient;
				wagonPart.partType := wagonPart.FRONT;
				wagonPart.setWagon(_wagon, lc);
				self.addWagonPart(wagonRow, col, wagonPart);
			elseif lcCount = _wagon.allLocationsControllersArray.size() then
				// end the wagon 
				create wagonPart transient;
				wagonPart.partType := wagonPart.BACK;
				wagonPart.setWagon(_wagon, lc);
				self.addWagonPart(wagonRow, col, wagonPart);
			else
				// mid section of the wagon
				create wagonPart transient;
				if lc.isEndOfWell then
					wagonPart.partType := wagonPart.EndOfWell;
				elseif lc.isStartOfWell then
					wagonPart.partType := wagonPart.StartOfWell;
				else
					wagonPart.partType := wagonPart.MID;
				endif;
				wagonPart.setWagon(_wagon, lc);
				if numMidSections = 0 then
					wagonPart.setDisplayWagonPos(true);
				endif;					
				self.addWagonPart(wagonRow, col, wagonPart);					
				numMidSections := numMidSections + 1;
			endif;
			
			if maxNumInStack &gt; 1 then
				row := 1;
				foreach heightIndex in 1 to maxNumInStack reversed do
					create lcDraw transient;
					lcDraw.setLocationsController(lc);
					lcDraw.setStackHeight(heightIndex);
					self.addLocationWithHeight(row, col, heightIndex, lcDraw);
					row := row + 1;
				endforeach;
			else 
				create lcDraw transient;
				lcDraw.setLocationsController(lc);
				
				self.addLocation(lcRow, col, lcDraw);
			endif;

			lcCount := lcCount + 1; 
	
			// Add the TIs if any
			row := tiRow;
			foreach ti in lc.allTrackedItems do
				if ti.myPrimaryActualLocation = lc then
					create tiDraw transient;
					tiDraw.setTI(ti);
					self.addTI(row, col, tiDraw);
				endif;
				row := row - 1;
			endforeach;
			
				
			create trackDraw transient;
			trackDraw.type := trackDraw.NORMAL;
			self.addTrack(trackRow, col, trackDraw);
	
			col := col + 1;
	
		endforeach;
		
	elseif _wagon.isSkeletonCar then
		lc := _wagon.allLocationsControllersArray.first;
		create wagonPart transient;
		wagonPart.partType := wagonPart.FRONT;
		wagonPart.setWagon(_wagon, lc);
		self.addWagonPart(wagonRow, col, wagonPart);
	
	endif;
	
	// Add a piece of track at the end of each wagon 
	create trackDraw transient;
	trackDraw.type := trackDraw.NORMAL;
	self.addTrack(trackRow, col, trackDraw);
	
	col := col + 1;

epilog

	delete doorPosArray;

end;</source>
        <access>protected</access>
        <Parameter name="_wagon" type="CM_Wagon"/>
        <Parameter name="wagonRow" type="Integer" usage="io"/>
        <Parameter name="col" type="Integer" usage="io"/>
        <Parameter name="lcRow" type="Integer" usage="io"/>
        <Parameter name="tiRow" type="Integer"/>
        <Parameter name="trackRow" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="buildWagonTopView" id="18fa8127-28a9-42b4-9c32-4115d61191b7">
        <source>buildWagonTopView( _isLandscape : Boolean; _wagon : CM_Wagon; row : Integer io; _col : Integer )protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25 March 2013	cnwndl1	Initial creation	Par 31278 - migrated and rehashed for boxcars.


*/

vars

	lcCount : Integer;
	numMidSections : Integer;
	lc : CM_LocationsController;
	wagonPart : CMIF_RDTWagonPartDrawElement;
	lcDraw : CMIF_RDTLocationDrawElement;
	ti : CM_TrackedItem;
	tiDraw : CMIF_RDTTIDrawElement;
	trackDraw : CMIF_RDTTrackDrawElement;
	
	maxLengthUnits : Integer;
	loadPosition : Integer;
	doorPosArray : IntegerArray;

begin

	lcCount := 1;
	numMidSections := 0;
	
	if _wagon.isBoxcar then
	
		lc := _wagon.allLocationsControllersArray.first;
		create doorPosArray transient;
		_wagon.CM_BoxcarVisit.getBoxcarLengthAndDoorPosition( maxLengthUnits, doorPosArray );
		loadPosition := doorPosArray.first;
		
		foreach lcCount in 1 to maxLengthUnits do
			
			// Create the wagon parts
			if lcCount = 1 then
				// start the wagon off
				create wagonPart transient;
				wagonPart.partType := wagonPart.FRONT;
				wagonPart.setWagon(_wagon, lc);
				if _isLandscape then
					self.addWagonPart(_col, row, wagonPart);
				else
					self.addWagonPart(row, _col, wagonPart);
				endif;
			elseif lcCount = maxLengthUnits then
				// end the wagon 
				create wagonPart transient;
				wagonPart.partType := wagonPart.BACK;
				wagonPart.setWagon(_wagon, lc);
				if _isLandscape then
					self.addWagonPart(_col, row, wagonPart);
				else
					self.addWagonPart(row, _col, wagonPart);
				endif;
			else
				// mid section of the wagon
				create wagonPart transient;
				wagonPart.partType := wagonPart.MID;
				wagonPart.setWagon(_wagon, lc);
				if numMidSections = 0 then
					wagonPart.setDisplayWagonPos(true);
				endif;					
				if _isLandscape then
					self.addWagonPart(_col, row, wagonPart);					
				else
					self.addWagonPart(row, _col, wagonPart);					
				endif;					
				numMidSections := numMidSections + 1;
			endif;
									
			// Add the location
			create lcDraw transient;
			lcDraw.setLocationsController(lc);
			lcDraw.boxcarLocIndex := lcCount;
			lcDraw.isBoxcarPortrait := not _isLandscape;
			if _isLandscape then
				self.addLocation(_col, row, lcDraw);
			else
				self.addLocation(row, _col, lcDraw);
			endif;
			if lcCount = 1 then
				lcDraw.isBoxcarFront := true;
				lcDraw.setShowCargoCount(true);
			elseif lcCount = maxLengthUnits then
				lcDraw.isBoxcarBack := true;
			endif;
			if lcCount = loadPosition then
				if _isLandscape then
					self.addBoxcarLoadPosition( _col, row, lc );
				else
					self.addBoxcarLoadPosition( row, _col, lc );
				endif;
				lcDraw.isBoxcarDoor := true;
			elseif doorPosArray.includes(lcCount) then
				lcDraw.isBoxcarDoor := true;
			endif;
		
			create trackDraw transient;
			trackDraw.type := trackDraw.NORMAL;
			self.addTrack(row, _col, trackDraw);
	
			row := row + 1;
	
		endforeach;
	
	
	elseif _wagon.isFlatcar or _wagon.isWellcarVisit then

		foreach lc in _wagon.allLocationsControllersArray do
					
			// Create the wagon parts
			if lcCount = 1 then
				// start the wagon off
				create wagonPart transient;
				wagonPart.partType := wagonPart.FRONT;
				wagonPart.setWagon(_wagon, lc);
				if _isLandscape then
					self.addWagonPart(_col, row, wagonPart);
				else
					self.addWagonPart(row, _col, wagonPart);
				endif;
			elseif lcCount = _wagon.allLocationsControllersArray.size() then
				// end the wagon 
				create wagonPart transient;
				wagonPart.partType := wagonPart.BACK;
				wagonPart.setWagon(_wagon, lc);
				if _isLandscape then
					self.addWagonPart(_col, row, wagonPart);
				else
					self.addWagonPart(row, _col, wagonPart);
				endif;
			else
				// mid section of the wagon
				create wagonPart transient;
				if lc.isEndOfWell then
					wagonPart.partType := wagonPart.EndOfWell;
				elseif lc.isStartOfWell then
					wagonPart.partType := wagonPart.StartOfWell;
				else
					wagonPart.partType := wagonPart.MID;
				endif;
				wagonPart.setWagon(_wagon, lc);
				if numMidSections = 0 then
					wagonPart.setDisplayWagonPos(true);
				endif;
				
				if _isLandscape then
					self.addWagonPart(_col, row, wagonPart);					
				else
					self.addWagonPart(row, _col, wagonPart);					
				endif;
				numMidSections := numMidSections + 1;
			endif;
				
			//write "Keying in lc: " &amp; lc.ident &amp; " at pos (row, col): " &amp; row.String &amp; "," &amp; col.String;
				
			// Add the location
			create lcDraw transient;
			lcDraw.setLocationsController(lc);
			
			if _isLandscape then
				self.addLocation(_col, row, lcDraw);
			else
				self.addLocation(row, _col, lcDraw);
			endif;
	
			lcCount := lcCount + 1; 
	
			// Add TI if any
			//ti := lc.getTopTI(REAL_MODE);
			ti := lc.allTrackedItems.last;
			if ti &lt;&gt; null and ti.myPrimaryActualLocation = lc then
				create tiDraw transient;
				tiDraw.setTI(ti);
				if _isLandscape then
					self.addTI(_col, row, tiDraw);
				else
					self.addTI(row, _col, tiDraw);
				endif;
			endif;
	
			row := row + 1;
	
		endforeach;
	
	endif;
	
	// Add a piece of track at the end of each wagon 
	create trackDraw transient;
	trackDraw.type := trackDraw.NORMAL;
	if _isLandscape then
		self.addTrack(_col, row, trackDraw);
	else
		self.addTrack(row, _col, trackDraw);						
	endif;

epilog

	delete doorPosArray;

end;</source>
        <access>protected</access>
        <Parameter name="_isLandscape" type="Boolean"/>
        <Parameter name="_wagon" type="CM_Wagon"/>
        <Parameter name="row" type="Integer" usage="io"/>
        <Parameter name="_col" type="Integer"/>
    </JadeMethod>
