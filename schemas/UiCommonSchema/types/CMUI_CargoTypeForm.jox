    <JadeMethod name="initForm" id="ba330f96-faef-420a-935d-a5e012c63bd3">
        <updating/>
        <source>initForm() updating;
// ---------------------------------------------------------------------------
// Created:     01 October 2002 by cnwth2
//
// Purpose:     
//
// Changed On	By			Reason
// ----------   ----------  --------------------------------------------------
// 20/03/2014	cnwdap1		PAR #33606 CCMS SFW 1366 Bulk
vars

begin
	self.showFilterOnStartup:= true; 	// Show the filter frame
	self.showDataOnStartup 	:= true; 	// Do not populate the data table with data
	self.allowPrint		:= false;
	self.allowExportCSV	:= false;
	self.useNumRowsShown	:= true;
	self.tblData.autoSize := Table.AutoSize_Column;
	if self.sptMainRatioSaved = 0 then
		self.sptMainRatioSaved := 50;
	endif;
	
	//self.initTblThumb();
	self.initTblEntDetail();
	self.initTblDefaultValues();
	self.initTblAttributes();	//PAR19704, CCMS 1080 May 2009
	self.setMyDataClass();
	self.loadHandlingTypes();
	self.loadOperators();
	self.loadFonts();
	self.loadChars(self.cmbFont.text);
	self.loadTerminals() ; 
	self.loadProductType();
	self.loadMeasurementCombos();						// PAR #33606
	self.allowTblDataSearch := true;
	
	self.tblThumb.parent := self.tblEntDetail.parent;	//PAR 19704, CCMS 1080 May 2009
	self.frmPolygon.visible := false;
end;</source>
    </JadeMethod>
    <JadeMethod name="initMultiSelect" id="7b13feb3-7ae6-47fc-a50e-cbe1baf0c361">
        <source>initMultiSelect() protected;
/* ---------------------------------------------------------------------------
Created:	19 May 2009	by cnwvu1

Purpose:	
   
Change Date		Who		Reason

------------------------------------------------------------------------------*/
vars
	tmpMulSel : CMUI_MultiSelectGroupBox;

begin

	// multi select for terminals
	tmpMulSel := self.mulSelectTerm;
	tmpMulSel.availableHeading := app.getErrorString(Available_terminals);
	tmpMulSel.selectedHeading := app.getErrorString(Selected_terminals);
	tmpMulSel.formDisplayEntryMethodName := CMUI_CargoTypeForm::displayMultiSelectTerminal.name; 
	tmpMulSel.myBaseForm := self;
	tmpMulSel.myAvailableListBox.sorted := true;		
	tmpMulSel.mySelectedListBox.sorted := true;
	tmpMulSel.mySelectedListBox.allowDragDrop := true;
	tmpMulSel.multiSelect := ListBox.MultiSelect_Extended;

	// multi select for commodities
	tmpMulSel := self.mulSelectCommod;
	tmpMulSel.availableHeading := app.getErrorString(Available_commodities);
	tmpMulSel.selectedHeading := app.getErrorString(Selected_commodities);
	tmpMulSel.formDisplayEntryMethodName := CMUI_CargoTypeForm::displayMultiSelectCommodity.name; 
	tmpMulSel.myBaseForm := self;
	tmpMulSel.myAvailableListBox.sorted := true;		
	tmpMulSel.mySelectedListBox.sorted := true;
	tmpMulSel.mySelectedListBox.allowDragDrop := true;	
	tmpMulSel.multiSelect := ListBox.MultiSelect_Extended;
	
	// 30/07/2009 cnwsh3 CCMS SFW1066 PAR20321 - Recording Damage Position .-------------------------
	tmpMulSel := self.mulDmgePosition;
	tmpMulSel.availableHeading := app.getErrorString(AvailableDamagePositions);
	tmpMulSel.selectedHeading := app.getErrorString(SelectedDamagePositions);
	tmpMulSel.formDisplayEntryMethodName := CMUI_CargoTypeForm::displayDamagePositionEntry.name; 
	tmpMulSel.myBaseForm := self;
	tmpMulSel.myAvailableListBox.sorted := true;		
	tmpMulSel.mySelectedListBox.sorted := true;
	tmpMulSel.mySelectedListBox.allowDragDrop := true;	
	tmpMulSel.multiSelect := ListBox.MultiSelect_Extended;
	
	//Multiselect for damage codes.
	tmpMulSel := self.mulDmgeDefCode;
	tmpMulSel.availableHeading := app.getErrorString(AvailableDamageCodes);
	tmpMulSel.selectedHeading :=  app.getErrorString(SelectedDamageCodes);
	tmpMulSel.formDisplayEntryMethodName := CMUI_CargoTypeForm::displayDamageDefinitionCode.name; 
	tmpMulSel.myBaseForm := self;
	tmpMulSel.myAvailableListBox.sorted := true;		
	tmpMulSel.mySelectedListBox.sorted := true;
	tmpMulSel.mySelectedListBox.allowDragDrop := true;	
	tmpMulSel.multiSelect := ListBox.MultiSelect_Extended;
	//30/07/2009 cnwsh3 CCMS SFW1066 PAR20321 - Recording Damage Details Changes. Ends.-------------------
	self.resizeShtDamageContents();
	
	//Multi select for Seal Types
	//+cnwml2 PAR23715 SFW CCMS 1131
	tmpMulSel := self.mulSeals;
	tmpMulSel.availableHeading := "Available Seal Types";
	tmpMulSel.selectedHeading := "Selected Seal Types";
	tmpMulSel.formDisplayEntryMethodName := CMUI_CargoTypeForm::displaySealTypes.name; 
	tmpMulSel.myBaseForm := self;
	tmpMulSel.myAvailableListBox.sorted := true;		
	tmpMulSel.mySelectedListBox.sorted := true;
	tmpMulSel.mySelectedListBox.allowDragDrop := true;	
	tmpMulSel.multiSelect := ListBox.MultiSelect_Extended;
end;</source>
        <access>protected</access>
    </JadeMethod>
