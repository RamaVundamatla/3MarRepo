    <JadeMethod name="findEDIFileReceivedEvent" id="eb0d2155-0962-451f-b54d-23a86b7a46c6">
        <source>findEDIFileReceivedEvent(_fileNumber : String; _camFile : CM_EDIFile; _terminal : CM_Terminal) : Boolean;
//
//04 Sep 2015	cnwrs1	Par 36865 dont create multiple EDI File Received if file reloaded
// 
vars
	transaction	: CM_EventTransaction;
	result : Boolean;
	iterStartTS : TimeStamp;
	iter : Iterator;
begin
	iter := _terminal.allEventTransactionsByCamsTS.createIterator;
	iterStartTS	:= _camFile.fileCreatedTs;	
	_terminal.allEventTransactionsByCamsTS.startKeyGeq(iterStartTS, iter);
	while iter.next(transaction) do
		if transaction.type = EVT_EDIFileReceived then
			if transaction.CMEVT_EDIFileReceived.fileNumber = _fileNumber then
				result := true;
				break;
			endif;
		endif;
	endwhile;
	return result;
epilog
	delete iter;
end;
</source>
        <Parameter name="_fileNumber" type="String"/>
        <Parameter name="_camFile" type="CM_EDIFile"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="findExistingEDIFile" id="80da7c64-13af-49d1-a1b1-4aced30a480d">
        <source>findExistingEDIFile(_reference : String; _newEdiFile : CM_EDIFile; _existEdiFile : CM_EDIFile output);
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 17/07/2023	navdap1		Initial creation TFS 58923 EUP Calloff EDI Data Type / EDI Load
//
vars
	ediFile : CM_EDIFile;
	iter : Iterator;
	ediConfig : CM_EDIConfig;
begin
	// Assumption: TODO - check this
	// allEDIFilesByEdiClientRef is sorted internally by clientRef and THEN oid/creation time
	// if its not order can't be determined/assumed	
	ediConfig := _newEdiFile.ediConfig;
	iter := ediConfig.allEDIFilesByEdiClientRef.createIterator();
	ediConfig.allEDIFilesByEdiClientRef.startKeyGeq(_reference, iter);
	while iter.next(ediFile) do
		
		if ediFile.ediClientRef &lt;&gt; _reference then
			break;//TFS 63174
		endif;
		// Ignore ourselves!
		if ediFile = _newEdiFile then
			continue;
		endif;
		
		// Previous file has already been cancelled
		if ediFile.fileStatus = CM_EDIFile.EDI_STATUS_CANCELLED then
			continue;
		endif;
		
		// Otherwise there can only be one EDI File in an "active" state
		_existEdiFile := ediFile;
		break;
		
	endwhile;
	
epilog
	delete iter;
end;</source>
        <Parameter name="_reference" type="String"/>
        <Parameter name="_newEdiFile" type="CM_EDIFile"/>
        <Parameter name="_existEdiFile" type="CM_EDIFile" usage="output"/>
    </JadeMethod>
    <JadeMethod name="getAllEDIDataTypes" id="8f4f052c-03c3-4f56-b6bd-2010cf12075a">
        <source>getAllEDIDataTypes(_coll :IntegerArray input);
/*
Date		Who		Reason
06 December 2011	cnwcs5	Initial creation - CCMS POL 2122 / par 28696 - Empty Releases via COPARN
*/
vars
	type	: Integer;
begin
	type := self.getEDIDataType;
	
	if not _coll.includes (type) then
		_coll.add (type);
	endif;
epilog

end;</source>
        <Parameter name="_coll" type="IntegerArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getColourForRow" id="0aaaa23c-f354-4625-a898-f047019b6b02">
        <options>4</options>
        <source>getColourForRow(_ediBundle : Integer) : Integer typeMethod;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23/12/2024	navkc1 JIRA Story MTN-33491: MTN | License - EDI Bundles Methods

*/

vars
	
begin
	
	if _ediBundle = CM_EDIFileType.EDI_Bundle_BASE then
		return PalePink;
	elseif _ediBundle = CM_EDIFileType.EDI_Bundle_EDIFACT then
		return PaleGreen;
	elseif _ediBundle = CM_EDIFileType.EDI_Bundle_X12 then
		return Cn_WedgeWoodBlue;
	elseif _ediBundle = CM_EDIFileType.EDI_Bundle_SUZANO then
		return Cn_PaleBlue;
	elseif _ediBundle = CM_EDIFileType.EDI_Bundle_CUSTOM then
		return White;
	endif;
	
	return Red;
	
epilog

end;</source>
        <Parameter name="_ediBundle" type="Integer"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getCustomActionsName" id="28840bab-2a43-4055-aa31-d24a0ab2d84a">
        <source>getCustomActionsName():String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26 September 2018	jlgndl1	Initial creation	TFS 40940

*/

vars

begin

	
	if self.type = EDIFileType_XMLOneStopCust then
		if self.name &lt;&gt; "One Stop Customs" then
			 return "AUS Customs Response";
		endif;
	elseif self.type = EDIFileType_CusRes then
		if self.name &lt;&gt; "CUSRES - Customs Response" then
			return "NZ Customs Response";
		endif;
	elseif self.type = EDIFileTypeCAMIR_CustomsStatus then
		return "US Customs Status Message";
	elseif self.type = EDIFileType_JMTInternal then
		return "NZ Customs TSW Response"; 
	endif;
	
	return self.name;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
