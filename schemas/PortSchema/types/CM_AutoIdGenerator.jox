    <JadeMethod name="auditIdDisplay" id="c22869b6-994f-4239-b755-c2ae6c55e661">
        <source>auditIdDisplay(): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 December 2022	navkc1	Initial creation TFS CR 55300 TASK 55524

*/

vars
	
	idDisplay		: String;
	terminal		: CM_Terminal;
	
begin
	
	idDisplay := app.getErrorString(Auto) &amp; " " &amp; self.getDisplayStringForId(self.idType);
	
	terminal := self.myTerminal;
	
	if terminal &lt;&gt; null then
		idDisplay := idDisplay &amp; " - " &amp; terminal.code;
	endif;
	
	return idDisplay;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
