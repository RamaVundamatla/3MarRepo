    <JadeMethod name="setupPermissionColumns" id="118bdf69-d45a-450e-bf57-f0ba54f88248">
        <updating/>
        <source>setupPermissionColumns() updating, protected;
// ---------------------------------------------------------------------------
// Created:     20 May 2002 by cnwth2
//
// Purpose:     
// 
// Date			Name	TFS#		Description
// ============================================================================
// 04 Sep 2019	jlgdi1	45802	Added new column for Form Type attribute
// 23 Sep 2019 	jlgka1 	TFS 45614 	JMT - Refactoring remove Voyage Commodity Scenario mode
// ---------------------------------------------------------------------------
vars
	licPerm 		: CM_PermissionObject;
	hdrStr			: String;
	colStr : String;
begin

	if self.currentMode &lt;&gt; Mode_SpecialPermissions then
		tblData.columns := Min_Columns + self.allLicensePermsByName.size;
	else
		tblData.columns := Min_Columns;
	endif;
	
	tblData.columnWidth[1] := 170;		// Name
	tblData.columnWidth[2] :=  50;		// Value
	tblData.columnWidth[3] := 170;		// Descr
	tblData.columnWidth[4] := 100;		// Category
	tblData.columnWidth[5] :=  70;		// Type
	tblData.columnWidth[6] :=  50;		// Internal
	tblData.columnWidth[7] :=  50;		// Menu ID
	tblData.columnWidth[8] := 100;		// Heading
	tblData.columnWidth[9] := 100;	// Window
	tblData.columnWidth[10] := 100;	// Schema
	tblData.columnWidth[11] := 50;	// Icon Up	tfs 50421
	tblData.columnWidth[12] := 70;	// Icon Down	tfs 50421
	tblData.columnWidth[13] := 60;	// Icon Leaf	tfs 50421
	tblData.columnWidth[14] := 150;	// Has Explaination?	
	tblData.columnWidth[15] := 100;	// 45802
	
	tblData.accessColumn(3).inputType	:= Table.InputType_None;
	tblData.accessColumn(4).inputType	:= Table.InputType_None;
	tblData.accessColumn(5).inputType	:= Table.InputType_None;
	
	hdrStr := "Name" &amp; Tab &amp; 
			"Value" &amp; Tab &amp; 
			"Description" &amp; Tab &amp; 
			"Catagory" &amp; Tab &amp;
			"Type" &amp; Tab &amp; 
			"Internal" &amp; Tab &amp; 
			"MenuID" &amp; Tab &amp; 
			"Heading" &amp; Tab &amp; 
			"Window" &amp; Tab &amp;
			"Schema" &amp; Tab &amp;
			"Icon UP" &amp; Tab &amp; 
			"Icon DOWN" &amp; Tab &amp; 
			"Icon LEAF" &amp; Tab &amp; 
			//"Expl?";
			"Expl?" &amp; Tab &amp; 
			"Form Type";
	
	if self.currentMode &lt;&gt; Mode_SpecialPermissions then
		foreach licPerm in self.allLicensePermsByName do
		
		// ### JIRA 33501 04DEC2024 NAVAB1
			if licPerm.permType = PermType_Subscriptions then // SUBSCRIPTION LICENSE
				colStr := "SUB " &amp; licPerm.description;
			elseif licPerm.permType = PermType_Special then // SYSTEM LICENSE
				colStr := "SYS " &amp; licPerm.description;
			else	
				colStr := "XXX " &amp; licPerm.description;
			endif;
			
			hdrStr := hdrStr &amp; Tab &amp; colStr;
		endforeach;
	endif;
	
	tblData.accessCell(1,1).text := hdrStr;

	tblData.accessColumn(11).alignment := Table.Alignment_Center_Middle; // TFS 50421
	tblData.accessColumn(12).alignment := Table.Alignment_Center_Middle; // TFS 50421
	tblData.accessColumn(13).alignment := Table.Alignment_Center_Middle; // TFS 50421
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setupSubsColumns" id="87011db1-b8f5-491e-a638-6103ff1d580b">
        <updating/>
        <source>setupSubsColumns() updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 June 2020	jlgndl1	Initial creation	TFS 49569

*/

vars

	licPerm : CM_PermissionObject;
	hdrStr : String;

begin

	self.tblData.columns := 5;

	tblData.columnWidth[1] := 200;		// Name
	tblData.columnWidth[2] :=  75;		// Value
	tblData.columnWidth[3] := 200;		// Descr
	tblData.columnWidth[4] := 100;		// Category
	tblData.columnWidth[5] := 150;		// Type
	
	tblData.accessColumn(3).inputType	:= Table.InputType_None;
	tblData.accessColumn(4).inputType	:= Table.InputType_None;
	tblData.accessColumn(5).inputType	:= Table.InputType_None;

	hdrStr := "Name" &amp; Tab &amp; 
			"Value" &amp; Tab &amp; 
			"Description" &amp; Tab &amp; 
			"Catagory" &amp; Tab &amp;
			"Type"; 
	
	tblData.accessCell(1,1).text := hdrStr;

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="showConfig" id="b5ce3de7-4150-42da-99c4-1fe19f8ee087">
        <updating/>
        <source>showConfig() updating;
// ---------------------------------------------------------------------------
// Created:     24 May 2002 by cnwth2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	xmlStr,
	tmpStr,
	catName	 : String;
	category : ConstantCategory;
	constant : Constant;
	lvlOperator,
	lvlRoot,
	lvlTerminal	: Boolean;
	idx			: Integer;
	
begin

	catName := ConfigConstants;
	
	self.maxNumber := 0;
	
	tblData.clear;
	tblData.rows := 1;
	tblData.columns := 5;
	tblData.column := 1;
	category := currentSchema.getCategory(catName);		
	
	tblData.columnWidth[1] := 200;
	tblData.columnWidth[2] := 200;
	tblData.columnWidth[3] := 100;
	tblData.columnWidth[4] := 100;
	tblData.columnWidth[5] := 100;
	
	tblData.accessCell(1,1).text := "Name" &amp; Tab &amp; 'Value' &amp; Tab &amp; "Root" &amp; Tab &amp; "Terminal" &amp; Tab &amp; "Operator";
	tblData.sortColumn[1] := 1;
	tblData.accessColumn(3).inputType := Table.InputType_CheckBox;
	tblData.accessColumn(4).inputType := Table.InputType_CheckBox;
	tblData.accessColumn(5).inputType := Table.InputType_CheckBox;
	
	foreach constant in category.getConstants do
		xmlStr := constant.text.cnEcGetTagValueOfName(CMIF_Config.XMLTag_ConstDtls);
		if xmlStr = null then
			lvlRoot		:= false;
			lvlTerminal	:= false;
		else
			tmpStr := xmlStr.cnEcGetTagValueOfName(CMIF_Config.XMLTag_LvlRoot);
			if tmpStr = null then
				lvlRoot		:= false;
			else
				lvlRoot		:= tmpStr.Boolean;
			endif;
			tmpStr := xmlStr.cnEcGetTagValueOfName(CMIF_Config.XMLTag_LvlTerminal);
			if tmpStr = null then
				lvlTerminal	:= false;
			else
				lvlTerminal	:= tmpStr.Boolean;
			endif;
			tmpStr := xmlStr.cnEcGetTagValueOfName(CMIF_Config.XMLTag_LvlOperator);
			if tmpStr = null then
				lvlOperator	:= false;
			else
				lvlOperator	:= tmpStr.Boolean;
			endif;
		endif;
		idx := tblData.addItem(constant.name &amp; Tab &amp; constant.valueAsString &amp; Tab &amp; 
									lvlRoot.cnEcGetTableCheckBoxValue &amp; Tab &amp; 
									lvlTerminal.cnEcGetTableCheckBoxValue &amp; Tab &amp;
									lvlOperator.cnEcGetTableCheckBoxValue);
		tblData.accessRow(idx).itemObject := constant;
	endforeach;
	
	txtNextNumber.text := null;

	tblData.resort();

end;</source>
    </JadeMethod>
    <JadeMethod name="showExceptions" id="f187ef41-9db9-40ef-b206-9ec06fd8c18a">
        <updating/>
        <source>showExceptions() updating;
// ---------------------------------------------------------------------------
// Created:     24 May 2002 by cnwth2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	catName	 	: String;
	category 	: ConstantCategory;
	constant 	: Constant;
	idx		 	: Integer;
	locale1	 	: CM_Locale;	
	locale2	 	: CM_Locale;
	str1, str2	: String;
begin

	catName := XLAT_Permissions;

	self.maxNumber := 0;
	
	tblData.clear;
	tblData.rows := 1;

	locale1	 := app.myRoot.allLocales[StandardTextLocaleStr];	
	str1 := '(' &amp; locale1.localeId &amp; ')';

	tblData.columns := 4;
	tblData.accessCell(1,1).text := "Name	Value	Message " &amp; str1 &amp; "	Short Msg " &amp; str1;
	tblData.accessColumn(3).partialTextIndication := true;
	tblData.accessColumn(4).partialTextIndication := true;
	tblData.columnWidth[1] := 170;
	tblData.columnWidth[2] := 60;
	tblData.columnWidth[3] := 400;
	tblData.columnWidth[4] := 300;

	tblData.column := 1;
	category := currentSchema.getCategory(catName);		
	
	tblData.accessColumn(3).inputType	:= Table.InputType_None;
	tblData.accessColumn(4).inputType	:= Table.InputType_None;
	tblData.accessColumn(3).visible	:= true;
	tblData.accessColumn(4).visible	:= true;
	//tblErrorMsgs.accessColumn(5).inputType	:= Table.InputType_None;

	tblData.sortColumn[1] := 1;
	
	foreach constant in category.getConstants do
		idx := tblData.addItem(self.getDisplayStringForEx(constant, StandardTextLocaleStr, null));
		tblData.accessRow(idx).itemObject := constant;

		if constant.valueAsInteger &gt; self.maxNumber then
			self.maxNumber := constant.valueAsInteger;
		endif;
	endforeach;
	
	txtNextNumber.text := (maxNumber + 1).String;

	tblData.resort();

end;</source>
    </JadeMethod>
    <JadeMethod name="showPermissionObject" id="773574e5-6c0b-441f-b83b-3dcd2a883a6d">
        <updating/>
        <source>showPermissionObject(_permObj : CM_PermissionObject; _row : Integer) updating, protected;
/* ---------------------------------------------------------------------------
Created:     20 May 2002 by cnwth2

Purpose:     
 
Date		Name	TFS#		Description
============================================================================
04 Sep 2019	jlgdi1	45802		Added formType attribute
23 Sep 2019 jlgka1 	TFS 45614 	JMT - Refactoring remove Voyage Commodity Scenario mode
============================================================================*/
vars
	licPerm			: CM_PermissionObject;
	tmpStr,
	isInternStr,
	valueStr		: String;
	tmpChildValue,
	licCol,
	idx				: Integer;	
	formTypeString 	: String;	
	root : CM_Root;
	pic : Binary;
begin
	
	if _row &gt; 0 and self.tblData.accessRow(_row).itemObject &lt;&gt; _permObj then
		app.msgBox('Object for row is not the one passed in', 'Error', 0);
		//process.debug;
		return;
	endif;

	
	if _permObj.isInternal then
		isInternStr := "True";
	else
		isInternStr := "False";
	endif;

	if self.currentMode = Mode_Permissions then
		valueStr := _permObj.constValue.String;
	else
		valueStr := _permObj.constValue.String &amp; ' (' &amp; 
					(_permObj.constValue - Mod_BaseView).String &amp; ')';
	endif;
	
	// dpi
	if _permObj.formType = 0 then 
		formTypeString := ' ';
	else
		formTypeString := global.formTypeToString(_permObj.formType);
	endif;
	
	tmpStr := _permObj.constName &amp; Tab &amp; 
			valueStr &amp; Tab &amp; 
			_permObj.description &amp; Tab &amp; 
			_permObj.category &amp; Tab &amp;
			global.permTypeToString(_permObj.permType) &amp; Tab &amp;
			isInternStr &amp; Tab &amp;
			_permObj.id &amp; Tab &amp;
			_permObj.heading &amp; Tab &amp;
			_permObj.windowClass &amp; Tab &amp;
			_permObj.schemaName &amp; Tab &amp; 
			Tab &amp; Tab &amp; Tab &amp; // TFS 50421 ICONS 
			_permObj.explanation &amp; Tab &amp;
			//	TFS 2198 (_permObj.explanation &lt;&gt; null).Boolean.getYesNo &amp; Tab &amp;			
			formTypeString;

	if _row = 0 then
		idx := tblData.addItem(tmpStr);
		tblData.accessRow(idx).itemObject := _permObj;
	else
		idx := _row;
		tblData.accessCell(idx, 1).text := tmpStr;
	endif;
	
	root := CM_Root.firstInstance;  // ### TFS 50421 20OCT2021 NAVAB1
	pic := root.getConfig(_permObj.pictureStringButton).Binary;  // ### TFS 50421 20OCT2021 NAVAB1
	if pic &lt;&gt; null then // ### TFS 50421 20OCT2021 NAVAB1
		tblData.accessCell(idx,11).picture := pic; // ### TFS 50421 20OCT2021 NAVAB1
		tblData.accessRow(idx).height := 32;
	endif;
	pic := root.getConfig(_permObj.pictureStringButtonDown).Binary;  // ### TFS 50421 20OCT2021 NAVAB1
	if pic &lt;&gt; null then // ### TFS 50421 20OCT2021 NAVAB1
		tblData.accessCell(idx,12).picture := pic; // ### TFS 50421 20OCT2021 NAVAB1
		tblData.accessRow(idx).height := 32;
	endif;
	pic := root.getConfig(_permObj.pictureStringIcon).Binary;  // ### TFS 50421 20OCT2021 NAVAB1
	if pic &lt;&gt; null then // ### TFS 50421 20OCT2021 NAVAB1
		tblData.accessCell(idx,13).picture := pic; // ### TFS 50421 20OCT2021 NAVAB1
		tblData.accessRow(idx).height := 32;
	endif;
	
	foreach tmpChildValue in _permObj.allChildValues do
		licPerm := self.myLicensePermissionAgent.allPermissionsByConstValue[tmpChildValue];
		if licPerm &lt;&gt; null then
			licCol := self.allLicensePermsByName.indexOf(licPerm);
			if licCol &gt; 0 then
				tblData.accessCell(idx, Min_Columns + licCol).text := 'true';
			endif;
		endif;
	endforeach;
end;</source>
        <access>protected</access>
        <Parameter name="_permObj" type="CM_PermissionObject"/>
        <Parameter name="_row" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="showPermissions" id="fa3e2ef0-3df5-4a2b-a919-97a705aaf07e">
        <updating/>
        <source>showPermissions() updating;
// ---------------------------------------------------------------------------
// Created:     20 May 2002 by cnwth2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	permObj,
	licPerm 		: CM_PermissionObject;
	licPermAgent	: CM_PermissionAgent;
	licGrpStr,
	isInternStr,
	valueStr		: String;
	tmpChildValue,
	licCol,
	idx				: Integer;	
	
	debug : Boolean;
begin

	if self.myPermissionAgent &lt;&gt; null then
		self.createPermissionAgent();
	else
		app.msgBox("transient instance of Permissions agent has been lost","Error",1);
	endif;

	if self.currentMode = Mode_Permissions then
		// this agent is used for the permission add app
		self.myPermissionAgent.populatePermissionDict(true, false, 0); 
		licPermAgent := self.myLicensePermissionAgent;
		if licPermAgent = null then
			// This agent is used for the columns
			create licPermAgent transient;
			self.myLicensePermissionAgent := licPermAgent;
			licPermAgent.populatePermissionDict(false, false, 55); // ### JIRA 33501 04DEC2024 NAVAB1
			licPermAgent.getPermDictWithoutNumbers(self.allLicensePermsByName,true);
		endif;
	else
		// self.currentMode = Mode_SpecialPermissions
		self.myPermissionAgent.populatePermissionDict(false, false, 0);
	endif;
		
	self.maxNumber := 0;
	
	tblData.rows := 1;

	self.setupPermissionColumns();

	tblData.column := 1;

	foreach permObj in self.myPermissionAgent.allPermissionsByName do
	
		
		
		if permObj.permType = PermType_NoLongerUsed then	//08 Oct 2019	NDL	TFS 46169
			continue;
		endif;
		//09 Oct 2019	NDL	TFS 46169 - Don't show these either
		if ( permObj.constValue &gt;= PmNum01 and permObj.constValue &lt;= PmNum10 ) then
			continue;
		endif;
		if permObj.constValue = PmSite then	//09 Oct 2019	NDL	TFS 46169
			continue;
		endif;
		if permObj.constValue = PmAdmInternal then	//09 Oct 2019	NDL	TFS 46169
			continue;
		endif;
		
		
		if permObj.constValue = PmAdmYAConfigMaint then
			debug := true;
		endif;
		
		if permObj.constValue = Mod_BaseView then
			continue;
		endif;
		
		if self.currentMode = Mode_Permissions and permObj.permType = PermType_Special then
			continue;
		elseif self.currentMode = Mode_SpecialPermissions and permObj.permType &lt;&gt; PermType_Special then
			continue;
		endif;
		
		if permObj.constValue.Integer &gt; self.maxNumber then
			self.maxNumber := permObj.constValue.Integer;
		endif;
		
		self.showPermissionObject(permObj, 0);
		
	endforeach;
	
	if self.currentMode = Mode_SpecialPermissions then
		maxNumber := self.myPermissionAgent.getMaxModuleNumber();
	endif;
	
	txtNextNumber.text := (maxNumber + 1).String;

	tblData.resort();

end;</source>
    </JadeMethod>
    <JadeMethod name="showSubscriptions" id="8a5701e6-9996-4747-8a1e-21d128649a47">
        <updating/>
        <source>showSubscriptions()updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 June 2020	jlgndl1	Initial creation	TFS 49569

*/

vars

	permObj,
	subsPerm 		: CM_PermissionObject;
	subsPermAgent	: CM_PermissionAgent;
	subsGrpStr,
	isInternStr,
	valueStr		: String;
	tmpChildValue,
	licCol,
	idx				: Integer;	
	
	debug : Boolean;

begin

	if self.myPermissionAgent &lt;&gt; null then
		self.createPermissionAgent();
	else
		app.msgBox("transient instance of Permissions agent has been lost","Error",1);
	endif;


	self.myPermissionAgent.populatePermissionDict(true, false, PermType_Subscriptions);
	subsPermAgent := self.mySubsPermissionAgent;
	if subsPermAgent = null then
		create subsPermAgent transient;
		self.mySubsPermissionAgent := subsPermAgent;
		subsPermAgent.populatePermissionDict(true, false, PermType_Subscriptions);
		subsPermAgent.getPermDictWithoutNumbers(self.allSubsPermsByName,true);
	endif;
		
	tblData.rows := 1;
	self.setupSubsColumns();
	tblData.column := 1;

	foreach permObj in self.myPermissionAgent.allPermissionsByName do
			
		if permObj.permType &lt;&gt; PermType_Subscriptions then
			continue;
		endif;
		
		self.showSubscriptionsObject(permObj, 0);
		
	endforeach;
	
	maxNumber := self.myPermissionAgent.getMaxModuleNumber(); // Has to check PermType_Subscriptions and PermType_Special
	txtNextNumber.text := (maxNumber + 1).String;

	tblData.resort();

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="showSubscriptionsObject" id="fa46c5cc-664e-4d8d-95ee-8aedc4004e08">
        <updating/>
        <source>showSubscriptionsObject(_permObj : CM_PermissionObject; _row : Integer) updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 June 2020	jlgndl1	Initial creation	TFS 49569

*/

vars
	licPerm			: CM_PermissionObject;
	tmpStr,
	isInternStr,
	valueStr		: String;
	tmpChildValue,
	licCol,
	idx				: Integer;	
	formTypeString 	: String;	
begin
	if _row &gt; 0 and self.tblData.accessRow(_row).itemObject &lt;&gt; _permObj then
		app.msgBox('Object for row is not the one passed in', 'Error', 0);
		//process.debug;
		return;
	endif;

	valueStr := _permObj.constValue.String;
		
	tmpStr := _permObj.constName &amp; Tab &amp; 
			valueStr &amp; Tab &amp; 
			_permObj.description &amp; Tab &amp; 
			_permObj.category &amp; Tab &amp;
			global.permTypeToString(_permObj.permType);

	if _row = 0 then
		idx := tblData.addItem(tmpStr);
		tblData.accessRow(idx).itemObject := _permObj;
	else
		idx := _row;
		tblData.accessCell(idx, 1).text := tmpStr;
	endif;
	
	foreach tmpChildValue in _permObj.allChildValues do
		licPerm := self.myLicensePermissionAgent.allPermissionsByConstValue[tmpChildValue];
		if licPerm &lt;&gt; null then
			licCol := self.allLicensePermsByName.indexOf(licPerm);
			if licCol &gt; 0 then
				tblData.accessCell(idx, Min_Columns + licCol).text := 'true';
			endif;
		endif;
	endforeach;
end;</source>
        <access>protected</access>
        <Parameter name="_permObj" type="CM_PermissionObject"/>
        <Parameter name="_row" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="showTblDataContextMenu" id="3e11cd47-35b1-4ac5-945c-f7120ca35e58">
        <updating/>
        <source>showTblDataContextMenu(table: Table input; conwin: Window input; mouse: Boolean; x: Integer; y: Integer) updating, protected;
// ---------------------------------------------------------------------------
// Created:     23 November 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	x1, y1		: Real;
	tmpMenu,
	menuItem	: MenuItem;
	showTblDataMenus,
	makeVisible,
	tblDataValidRow	: Boolean;
begin

	if self.currentMode &lt;&gt; Mode_Permissions then
		return;
	endif;

	tblDataValidRow := (tblData.row &gt; tblData.fixedRows);
	if (not tblDataValidRow) then
		self.mnuEdit.enabled := false;
	else
		self.mnuEdit.enabled := true;
	endif;
	if tblData.row = 1 then
		self.mnuHideColumn.caption := 'Hide Column';
		self.mnuHideColumn.visible := true;
	else
		self.mnuHideColumn.visible := false;
	endif;

	tmpMenu := self.mnuTblData;
	
	x1 := x;
	y1 := y;
	if (not mouse) then  // if keyboard, use current listIndex value
	    x1 := 1;
	    y1 := 1;
	endif;

	conwin.windowToScreen(x1, y1);
	self.screenToWindow(x1, y1);   // convert x, y relative to form
	
	self.popupMenu(self.mnuTblData, x1.Integer, y1.Integer);

end;</source>
        <access>protected</access>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="conwin" type="Window" usage="input"/>
        <Parameter name="mouse" type="Boolean"/>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="showTermEvents" id="d2c7ab9f-afec-46de-a4fc-89a740bf409f">
        <updating/>
        <source>showTermEvents() updating;
// ---------------------------------------------------------------------------
// Created:     24 May 2002 by cnwth2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	catName	 : String;
	category : ConstantCategory;
	constant : Constant;
	tmpValue,
	idx		 : Integer;
	
begin

	catName := EventsTerminal;
	
	self.maxNumber := 0;
	
	tblData.clear;
	tblData.rows := 1;
	tblData.columns := 4;
	tblData.column := 1;
	category := currentSchema.getCategory(catName);		
	
	tblData.columnWidth[1] := 170;
	tblData.columnWidth[2] := 300;
	
	tblData.accessColumn(1).inputType	:= Table.InputType_None;
	tblData.accessColumn(2).inputType	:= Table.InputType_None;
	//tblErrorMsgs.accessColumn(5).inputType	:= Table.InputType_None;

	tblData.accessCell(1,1).text := "Name" &amp; Tab &amp; "Value" ;
	
	tblData.sortColumn[1] := 2;
	
	foreach constant in category.getConstants do
		tmpValue := constant.valueAsInteger;
		if tmpValue = TERMINAL_EVENTS_FACTOR then
			continue;
		endif;
		idx := tblData.addItem(constant.name &amp; Tab &amp; tmpValue.String);
		tblData.accessRow(idx).itemObject := constant;

		self.maxNumber := self.maxNumber.max(constant.valueAsInteger);
	endforeach;
	
	txtNextNumber.text := (maxNumber + 1).String;

	tblData.resort();
	if tblData.columns &gt;= 3 then
	foreach idx in 3 to tblData.columns do
		tblData.accessColumn(idx).visible := false;
	endforeach;
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="sortTable" id="801ea19a-cd95-4979-a5d9-88f31aac7569">
        <source>sortTable() protected;
// ---------------------------------------------------------------------------
// Created:     21 August 2006 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	sortType,
	tmpCol	: Integer;

begin

	if tblData.row &lt;&gt; 1 then	//or tblErrorMsgs.column = 3 then
		return;
	endif;

	tmpCol := tblData.column;
	if tmpCol = 2 then
		sortType := Table.SortType_Numeric;
	else
		sortType := Table.SortType_Alpha;
	endif;

	if tblData.sortColumn[1] = tmpCol then
		tblData.sortAsc[1] := (not tblData.sortAsc[1]);
	else
		tblData.sortAsc[1] := true;
	endif;
	tblData.sortColumn[1] := tmpCol;
	tblData.sortType[1] := sortType;

	tblData.resort;

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="specialScript" id="b8eeccd0-e30d-4397-845a-ea4942348b69">
