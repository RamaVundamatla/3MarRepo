<Class name="CM_Probe" id="ba81e3d3-054e-452d-8d4c-1c5f10d718f6">
    <superclass name="CM_TITransaction"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="misc"/>
    <JadeMethod name="getEnquiryRow" id="1ed4e831-fbd9-40b0-bdbe-95dc628b1ec5">
        <source>getEnquiryRow(): String;
//----------------------------------------------------------------
//	Created:	31 October 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin

	return inheritMethod() &amp; self.getCompletedTaskString;

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="updateTI" id="6b0e2a2e-0e81-4667-839a-ab4301ff0b1b">
        <updating/>
        <source>updateTI(_passport : CM_Passport input) updating;

vars
begin
	inheritMethod(_passport);
	if self.myTrackedItem = null then
		return;
	endif;
	
	self.myTrackedItem.CM_Container.setProbedDetails();
	
end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="validateCMIF_TITransCntrl" id="f823cd09-c335-4913-aaf7-7c76ad4ea10f">
        <source>validateCMIF_TITransCntrl(_tiTransCntrl: CMIF_TITransactionController): Boolean;
//--------------------------------------------------------------
//Created: 11 October 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	rtnCode	: Boolean;
	
begin
	if (not inheritMethod(_tiTransCntrl)) then
		return false;
	endif;
	if (not _tiTransCntrl.myTrackedItem.isKindOf(CM_Container)) then
		app.raiseCMException1(ProbedTransactionForNonProbeTI, _tiTransCntrl.myTrackedItem.cargoTypeDescr, null, null);
		return false;
	endif;

	rtnCode := true;
epilog
	return rtnCode;
end;</source>
        <Parameter name="_tiTransCntrl" type="CMIF_TITransactionController"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validateForCreate" id="601c6e42-1c80-4ce7-b29a-9f2614deab76">
        <source>validateForCreate(): Boolean;
// ---------------------------------------------------------------------------
// Created:     21 September 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	
begin

	if (not inheritMethod()) then
		return false;
	endif;
	
	if (not self.myTrackedItem.isKindOf(CM_Container)) then
		app.raiseCMException1(ProbedTransactionForNonProbeTI, self.myTrackedItem.cargoTypeDescr, null, null);
		return false;
	endif;
	
	return true;

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
