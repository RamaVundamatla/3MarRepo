    <JadeMethod name="doScrollToCorners" id="39dd64c2-3c4a-4fbc-ae61-755797e88bee">
        <source>doScrollToCorners(pCorner : Integer) protected;

vars
	lHLabHeight, lVLabHeight,lFarRight, lFarBottom : Integer;
	lScrollBarV, lScrollBarH : Integer;
	theSDF : CMUI_ScrollableDrawingFrame;
	drawingFrame : CMUI_DrawingFrame;

begin
	theSDF := self.mySDF;
	if theSDF = null then
		return;
	endif;
	
	drawingFrame := theSDF.myDrawingFrame;
	if drawingFrame = null then
		return;
	endif;
	
	lFarBottom := drawingFrame.height.Integer - theSDF.height.Integer;
	lScrollBarV := drawingFrame.height.Integer;
	if theSDF.myHLabels.visible then
		lHLabHeight := theSDF.myHLabels.height.Integer;
	else
		lHLabHeight := 0;
	endif;
	lFarBottom := 1 - (lFarBottom + lHLabHeight);

	lFarRight := drawingFrame.width.Integer - theSDF.width.Integer;
	lScrollBarH := drawingFrame.width.Integer;
	if theSDF.myVLabels.visible then
		lVLabHeight := theSDF.myVLabels.width.Integer;
	else
		lVLabHeight := 0;
	endif;
	lFarRight := 1 - (lFarRight + lVLabHeight);

	if pCorner = VIEW_LEFT_TOP then
		lFarBottom := lHLabHeight;
		lScrollBarV := 1;
		lFarRight := lVLabHeight;
		lScrollBarH := 1;
	elseif pCorner = VIEW_RIGHT_TOP then
		lFarBottom := lHLabHeight;
		lScrollBarV := 1;
	elseif pCorner = VIEW_LEFT_BOTTOM then
		lFarRight := lVLabHeight;
		lScrollBarH := 1;
	elseif pCorner = VIEW_RIGHT_BOTTOM then
		// use defaults
	endif;
	// VERTICAL
	drawingFrame.top := lFarBottom;
	if theSDF.myVLabels &lt;&gt; null then
		theSDF.myVLabels.top := lFarBottom;
		theSDF.myHScroll.value := lScrollBarH;
	endif;
	// HORIZONTAL
	drawingFrame.left := lFarRight;
	if theSDF.myHLabels &lt;&gt; null then
		theSDF.myHLabels.left := lFarRight;
		theSDF.myVScroll.value := lScrollBarV;
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="pCorner" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="doShowHideExtraInfo" id="632d3202-faff-4e62-b834-412d8de8b4cd">
        <updating/>
        <source>doShowHideExtraInfo() updating;
// ---------------------------------------------------------------------------
// Created:     11 June 2009 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	ratio : Integer;
begin
	if self.xmlShowMacroInfo then
		if not self.xmlShowMacroInfo then
			ratio := 100;
		else
			ratio := 50;
		endif;
		self.splExtraInfo.showRightControl(ratio, true);
		self.mnuToggleExtraInfo.caption := app.getErrorString(Hide_macro_info); //self.MNU_EXTRAINFO_HIDE;
	else
		self.splExtraInfoRatio := self.splExtraInfo.leftToRightRatio;
		self.splExtraInfo.hideRightControl(true);
		self.mnuToggleExtraInfo.caption := app.getErrorString(Show_macro_info); //self.MNU_EXTRAINFO_SHOW;
	endif;
	
	self.doResizeGridContainer;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doShowTrainRail" id="ce3da984-b2ab-4a68-af48-ec3464784a93">
        <updating/>
        <source>doShowTrainRail() updating;
// ---------------------------------------------------------------------------
// Created:     26 May 2009 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

	obj : CM_Object;
begin
	if self.myCurrentRailArea = null and self.myCurrentTrain = null then
		app.msgBox(app.getErrorString(Pleas_selec_train_rail_area_vi), app.getErrorString(Query_selection), MsgBox_Exclamation_Mark_Icon);
		return;
	endif;
	
	obj := self.myCurrentRailArea;
	
	if obj = null then
		obj := self.myCurrentTrain;
		self.optDirInTB.value := false;
		self.optDirOutTB.value := true;
		self.setCaption(self.myCurrentTrain.getName() &amp; " - " &amp; self.myCurrentTrain.getSiteDescription() &amp; " " &amp; app.getErrorString(Train) ); // PAR 20834
	else
		self.setCaption(obj.getName() &amp; " - " &amp; app.getErrorString(Actual).toUpper() &amp; " "  &amp; app.getErrorString(Rail_operations) ); // PAR 20834
	endif;
	
	if obj = null then
		return;
	endif;
	
	self.setMyCurrentListObjects(obj);
	self.doChangeInOut();
	
	
	self.frmSelectAreas.visible := false;
epilog


end;</source>
