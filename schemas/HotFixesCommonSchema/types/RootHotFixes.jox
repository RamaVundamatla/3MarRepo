    <JadeMethod name="copyDirectory" id="847b81d7-7ec7-41fd-8377-ba7d356bf472">
        <source>copyDirectory( sourceDir : String; destDir : String; pFailIfExists : Boolean) : Boolean;

vars
	fileFld	: FileFolder;
	fileOne	: FileNode;
	sName	: String;		// dest file name without patch
	pErrTxt : String;
	dDir	: String;
	
	//cnwmc5 - 10 April 2014
	isSuper : Boolean;
begin
	//cnwmc5 - 10 April 2014
	isSuper := false;
	if self.myRootHotFixSuper &lt;&gt; null then
		isSuper := true;
	endif;
	
	create fileFld transient;
	fileFld.fileName := sourceDir;
	
	dDir := destDir;
	if dDir[ dDir.length : 1] &lt;&gt; '\' then 
		dDir := dDir &amp; '\';
	endif;
	
	if not fileFld.isAvailable then
		//cnwmc5 - 10 April 2014
		if isSuper and sourceDir[sourceDir.length-4:end] = '\bin\' then
			return true;
		endif;
		
		app.writeLogMessage('Cannot copy files. Directory not found ' &amp; sourceDir);
		return false;
	endif;
	
	// JMT variant of copying
	if not self.ZJade_Local_Mode_For_File_Copy then	
		foreach fileOne in fileFld.files do
			if fileOne.isKindOf(File) then
				self.copyFile(fileOne.File.fileName, destDir, false);
			endif;
		endforeach;
	else
	// Jade local variant of copying	
		foreach fileOne in fileFld.files do
			sName := fileOne.fileName[ sourceDir.length+1 : fileOne.fileName.length - sourceDir.length ];
			if fileOne.isKindOf(File) then
				if not fileOne.File.cnCopyFile( dDir&amp;sName, pFailIfExists, pErrTxt) then
					app.writeLogMessage('pErrTxt = ' &amp; pErrTxt);
					return false;
				endif;
			endif;
		endforeach;
	endif;
	
	return true;
	
epilog
	delete fileFld;

end;
</source>
        <Parameter name="sourceDir" type="String"/>
        <Parameter name="destDir" type="String"/>
        <Parameter name="pFailIfExists" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="copyDirectoryExtraFiles" id="b7776da1-e4b2-46f0-b72a-8e006fb3c65c">
        <source>copyDirectoryExtraFiles( sourceDir : String; destDir : String; pFailIfExists : Boolean ) : Boolean;
// ---------------------------------------------------------------------------
// Created:    16 June 2008		cnwvu1	
// ---------------------------------------------------------------------------
vars
	fileFld	: FileFolder;
	fileOne	: FileNode;
	sName	: String;		// dest file name without path
	pErrTxt : String;
	dDir	: String;
begin

	create fileFld transient;
	fileFld.fileName := sourceDir;
	
	dDir := destDir;
	if dDir[ dDir.length : 1] &lt;&gt; '\' then 
		dDir := dDir &amp; '\';
	endif;
	
	if not fileFld.isAvailable then
		app.writeLogMessage('Cannot copy files. Directory not found ' &amp; sourceDir);
		return false;
	endif;
	
	// JMT variant of copying
	if not self.ZJade_Local_Mode_For_File_Copy then	
		foreach fileOne in fileFld.files do
			if fileOne.isKindOf(File) then
				if (fileOne.name &lt;&gt; RootHotFixes.FILE_JMT_INSTALL_NAME) and (fileOne.name &lt;&gt; RootHotFixes.FILE_README_NAME) then
					self.copyFile(fileOne.File.fileName, destDir, false);
					app.writeLogMessage(' ' &amp; fileOne.name &amp; ' copied extra file');
				endif;
			endif;
		endforeach;
	else
	// Jade local variant of copying	
		foreach fileOne in fileFld.files do
			sName := fileOne.fileName[ sourceDir.length+1 : fileOne.fileName.length - sourceDir.length ];
			if fileOne.isKindOf(File) then
				if (fileOne.name &lt;&gt; RootHotFixes.FILE_JMT_INSTALL_NAME) and (fileOne.name &lt;&gt; RootHotFixes.FILE_README_NAME) then
					if not fileOne.File.cnCopyFile( dDir&amp;sName, pFailIfExists, pErrTxt) then
						app.writeLogMessage('pErrTxt = ' &amp; pErrTxt);
						return false;
					endif;
				endif;
			endif;
		endforeach;
	endif;
	
	return true;
	
epilog
	delete fileFld;

end;
</source>
        <Parameter name="sourceDir" type="String"/>
        <Parameter name="destDir" type="String"/>
        <Parameter name="pFailIfExists" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="copyFile" id="10b41bdd-94ca-43f2-bfc9-632702bdb3c2">
        <source>copyFile( _sourceFile: String; _destFolder : String; _failIfExists : Boolean) : Boolean;

vars
	result		: Integer;
	int			: Integer;
//	kc			: CnKarmaCntrl;
	errortext	: String;
	header		: CM_FileDataStorageHeader;
	_destFldr	: String;
begin

	if _destFolder[ _destFolder.length ] = '\' then
		_destFldr := _destFolder;
	else
		_destFldr := _destFolder &amp; '\';
	endif;
	
//	kc	:= app.myCnKarmaCntrl;
	if app.myCnCntrl = null then
		app.writeLogMessage('Karma is empty... Look at app.initialiseKarma (Schema HotFixesCommonSchema)');
		return false;
	endif;
	
	header := app.writeFileToBinary(_sourceFile, false, true, null,true);
	
	if header = null then
		//process.debug; commented out PAR 19975
		return false;
	endif;
	
	app.writeBinaryToFile(header, _destFldr);
	
	return true;
	
epilog	

	delete header;
end;</source>
        <Parameter name="_sourceFile" type="String"/>
        <Parameter name="_destFolder" type="String"/>
        <Parameter name="_failIfExists" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="createDirsForHotFix" id="d9378e57-02d4-4e8f-b2b7-3aca6d37a3bf">
        <source>createDirsForHotFix( _spec: Integer; _mainName: String; _mainDir: String; _patchNo: String; _webPatch, _priorityA: Boolean ) : Boolean;
// creates directories for:
// spec = 1 - for PAR - uses patchNo
// spec = 2 - for Hotfix
// spec = 3 - for Hotfix Super, uses dir _mainDir
// mainName = 023_PAR12345; 742Hotfix_012; 742Hotfix_001_to_012

vars
	fMain, 				// main dir
	fJd, 				// JadeMaster dir
	fJdS,				// JadeMaster Schemas dir
	fJdB,				// JadeMaster bin dir			//cnwmc5 - 10 April 2014 
	fCl,				// Client dir
	fClS,				// Client Schemas dir
	fClB,				// Client bin dir				//cnwmc5 - 10 April 2014 
	fMISC,		    	// misc dir  				    //13/07/2017 cnwma1 TFS#4847
	fCheck: FileFolder;	// check Patch's Number uniquity
	sDir : String;

begin
	create fMain	transient;
	create fJd		transient;
	create fJdS		transient;
	create fCl		transient;
	create fClS		transient;
	create fMISC	transient;  //1307/2017 cnwma1 TFS #4847
	create fCheck	transient;
	//cnwmc5 - 10 April 2014 
	create fJdB		transient;
	create fClB		transient;
	
	app.writeLogMessage(' Creating directories');
	
// Main directory
	if _spec = 1 then
		// For creating patch's directories we have to check about Patch's Number uniquity	
		fCheck.mask		:= _patchNo &amp; '*';
		fCheck.fileName := self.getDirOfPatches();
		if fCheck.files.size = 0 then
			fCheck.fileName := self.getDirHotFixes();
		endif;
		if fCheck.files.size &gt; 0 then
			app.writeLogMessage(' The Patch already exists - ' &amp; _patchNo); 
			return false;
		endif;
		if not _priorityA then
			// P2, goes via QA, so put somewhere else and not in the 'Released' patches dir
			sDir := self.getDirOfPatches() &amp; _mainName;
		else
			// P1, bypass QA (at the time) and put straight into the 'Released' patches dir for csys
			sDir := self.getDirHotFixes() &amp; _mainName;
		endif;
	elseif _spec = 2 then
		sDir := self.getDirHotFixes() &amp; _mainName;
	elseif _spec = 3 then
		sDir := _mainDir &amp; _mainName;
	else
		app.writeLogMessage(self.class.name &amp;'&gt;&gt;'&amp; method.name &amp; ' - spec = 1,2,3 only.');
		return false;
	endif;
	
	sDir := sDir &amp; '\';
	fMain.fileName := sDir;

	if fMain.isAvailable then
		app.writeLogMessage(' Directory exists ' &amp; fMain.fileName);
		app.writeLogMessage(' Please delete it');
		return false;
	else
		fMain.make;
		app.writeLogMessage(' created ' &amp; fMain.fileName);
	endif;
	
	if _webPatch then
		return true;			
	endif;

// JadeMaster
	fJd.fileName := sDir &amp; self.DIR_JADE_NAME;

	if not fJd.allowCreate then
		app.writeLogMessage(' Directory exists ' &amp; fJd.fileName);
		app.writeLogMessage(' Please delete it');
		return false;
	else
		fJd.make;
		app.writeLogMessage(' created ' &amp; fJd.fileName);
	endif;
	// JadeMaster Schemas
	fJdS.fileName := sDir &amp; self.DIR_JADE_NAME &amp;'\'&amp; self.DIR_SCHEMAS_NAME;

	if not fJdS.allowCreate then
		app.writeLogMessage(' Directory exists ' &amp; fJdS.fileName);
		app.writeLogMessage(' Please delete it');
		return false;
	else
		fJdS.make;
		app.writeLogMessage(' created ' &amp; fJdS.fileName);
	endif;
	
// Client directory
	if _spec &lt;&gt; 1 then
		fCl.fileName := sDir &amp; _mainName;
	else
		fCl.fileName := sDir &amp; _patchNo;
	endif;
	if not fCl.allowCreate then
		app.writeLogMessage(' Directory exists ' &amp; fCl.fileName);
		app.writeLogMessage(' Please delete it');
		return false;
	else
		fCl.make;
		app.writeLogMessage(' created ' &amp; fCl.fileName);
	endif;
// Client Schemas
	if _spec &lt;&gt; 1 then
		fClS.fileName := sDir &amp; _mainName &amp;'\'&amp; self.DIR_SCHEMAS_NAME;
	else
		fClS.fileName := sDir &amp; _patchNo &amp;'\'&amp; self.DIR_SCHEMAS_NAME;
	endif;

	if not fClS.allowCreate then
		app.writeLogMessage(' Directory exists ' &amp; fClS.fileName);
		app.writeLogMessage(' Please delete it');
		return false;
	else
		fClS.make;
		app.writeLogMessage(' created ' &amp; fClS.fileName);
	endif;
	
	//13.07.2017 cnwma1 TFS #4847
	fMISC.fileName := sDir &amp; _patchNo &amp;'\'&amp; self.DIR_MISC_NAME;

	if not fMISC.allowCreate then
		app.writeLogMessage(' Directory exists ' &amp; fMISC.fileName);
		app.writeLogMessage(' Please delete it');
		return false;
	else
		fMISC.make;
		app.writeLogMessage(' created ' &amp; fMISC.fileName);
	endif;
	//13.07.2017 cnwma1 TFS #4847
	//cnwmc5 - 10 April 2014 - Create bin dirs
	if _spec = 3 then
		//JadeMaster
		fJdB.fileName := sDir &amp; self.DIR_JADE_NAME &amp;'\'&amp; 'bin';
		if fJdB.allowCreate then
			fJdB.make();
			app.writeLogMessage(' created ' &amp; fJdB.fileName);
		endif;
		//Client
		fClB.fileName := sDir &amp; _mainName &amp;'\'&amp; 'bin';
		if fClB.allowCreate then
			fClB.make();
			app.writeLogMessage(' created ' &amp; fClB.fileName);
		endif;
	endif;
	
	
	return true;

epilog
	delete fMain;
	delete fJd;
	delete fJdS;
	delete fCl;
	delete fClS;
	delete fCheck;
	delete fJdB;
	delete fClB;	
	delete fMISC;
	
end;
</source>
        <Parameter name="_spec" type="Integer"/>
        <Parameter name="_mainName" type="String"/>
        <Parameter name="_mainDir" type="String"/>
        <Parameter name="_patchNo" type="String"/>
        <Parameter name="_webPatch" type="Boolean"/>
        <Parameter name="_priorityA" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
