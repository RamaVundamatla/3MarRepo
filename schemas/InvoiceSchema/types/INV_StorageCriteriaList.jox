    <JadeMethod name="doDelete" id="04abfd27-f172-4530-97bd-53cd31bbbf01">
        <updating/>
        <source>doDelete() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 September 2012	cnwer1	Initial creation SFW 1295

*/

vars

	storageDetail : CM_StorageDetail;
	theReturn : Integer;
begin
	if self.tblData.row &lt;= self.tblData.fixedRows then
		return;
	endif;
	
	storageDetail := self.tblData.accessRow(self.tblData.row).itemObject.CM_StorageDetail;
	if storageDetail = null then
		return;
	endif;
	
	if app.msgBox(app.getErrorString(ConfirmDeleteItems), app.getErrorString(Confirm_Delete), MsgBox_Yes_No) = MsgBox_Return_No then
		return;
	endif;
	
	while true do

		app.myTrxDA.trxDeleteStorageDetail(storageDetail, app.myPassport );
	
		if not app.myPassport.trxCompletedOK then
			theReturn := app.showErrorWarningDialog(app.getErrorString(Errors), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors 
			and theReturn = IDOK then
				// there must have just been warnings that the user has acknowledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			return;
		endif;
		break;
	endwhile;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doEditItem" id="8a2190c6-e58a-41d0-b2d2-f6024766f5bb">
