    <JadeMethod name="populateWithErrorCodes" id="ada2840d-0cc3-4563-b446-3fa120d73e52">
        <updating/>
        <source>populateWithErrorCodes(_errorList : ObjectArray) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
06 August 2008	cnwrd1	Initial creation

*/
vars
	selectedDict		: XLAT_TranslationByNumberDict;
	interestedError		: CM_Error;
	errorObj			: XLAT_Translation;
	dict				: XLAT_TranslationByCatAndNumber;
	
begin
	self.mulSelect1.visible	:= true;
	
	self.mulSelect1.availableHeading := 'Available Messages';
	self.mulSelect1.selectedHeading  := 'Selected Messages';
	self.mulSelect1.formDisplayEntryMethodName := 'displayEntryErrorCode';

	self.mulSelect1.myBaseForm	:= self;
	self.mulSelect1.mySelectedListBox.sorted := false;
	self.mulSelect1.cnEcResizeContents();
	self.mulSelect1.myAvailableListBox.listObject := null;
	
	//Load the multi select box with the exception messages from locale '0000'
	self.myAssistant.multiSelectExceptions(self.mulSelect1);

	self.mulSelect1.clearSelected();

	self.mulSelect1.setSorted(true);
	self.mulSelect1.setSelected(_errorList);
end;</source>
        <Parameter name="_errorList" type="ObjectArray"/>
    </JadeMethod>
    <JadeMethod name="setForDateFileType" id="8db041ce-cd68-4b90-8571-f38269f6a364">
        <updating/>
        <source>setForDateFileType(_fileDataType : Integer; _errorList : ObjectArray) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 August 2008	cnwrd1	Initial creation

*/
vars
	agent	:CM_EDIControllerAgent;
begin
	
	//01 Apr 2016	NDL	TFS 1748
	create agent transient;
	self.caption := app.getErrorString(File_setting_1);
	if _fileDataType &gt; 0 then
		self.caption := agent.getEDIDisplayStrForType(_fileDataType) &amp; app.getErrorString(File_settings_2);
	endif;
	
	//epr par 37430 21/1/16
	if _fileDataType = EDIDataType_Prenote or _fileDataType = EDIDataType_LoadList then
	//	self.caption := 'Prenote file settings';
		self.chkPinReqd.visible := true;
		self.chkSkipDuplicate.visible := _fileDataType = EDIDataType_Prenote;
		self.chkCreateBookings.visible := _fileDataType = EDIDataType_Prenote; //epr TFS 38518
		self.chkInvalidVoyage.visible := _fileDataType = EDIDataType_Prenote;	//03 Jan 2019	NDL	TFS 42303
		self.mulSelect1.visible := false;
		self.lwarnings.visible := false;
		self.height := 175;
	elseif _fileDataType = EDIDataType_Tranship then
	//	self.caption := 'Tranship file settings';
		self.chkPinReqd.visible := false;
		self.chkSkipDuplicate.visible := false;
		self.mulSelect1.visible := true;
		self.lwarnings.visible := true;
// cnwdad1 13/01/2010 - PAR #22078.
//		self.height := 400;
		self.height := 370;
		self.width	:= 500;
		self.populateWithErrorCodes(_errorList);
	endif;
	
end;</source>
        <Parameter name="_fileDataType" type="Integer"/>
        <Parameter name="_errorList" type="ObjectArray"/>
    </JadeMethod>
    <JadeMethod name="translateForm" id="e02796cb-671c-4d6d-8ddd-cac036b55949">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 03 January 2019 15:54:56.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
//	self.translateCaption(Xlat_0009852, locale);
	chkCreateBookings.translateCaption(Xlat_0022434, locale);
	chkInvalidVoyage.translateCaption(Xlat_0023144, locale);
	chkPinReqd.translateCaption(Xlat_0009853, locale);
	chkSkipDuplicate.translateCaption(Xlat_0009854, locale);
	lwarnings.translateCaption(Xlat_0009855, locale);
end;</source>
    </JadeMethod>
</GUIClass>
