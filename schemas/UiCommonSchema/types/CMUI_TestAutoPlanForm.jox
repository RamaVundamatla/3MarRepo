    <JadeMethod name="clearWouldPlanAndFailed" id="179b6506-b612-4691-9a16-82426500e3b6">
        <source>clearWouldPlanAndFailed();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
28 February 2012	cnwndl1	Initial creation	Par 29195

*/

vars

begin

	// set up the Would Plan table.
	self.tblWouldPlan.clear();
	self.tblWouldPlan.fixedRows := 1;
	self.tblWouldPlan.rows := self.tblWouldPlan.fixedRows;
	self.tblWouldPlan.selectionType := CM_BaseTable.SelectionType_Row;
	self.tblWouldPlan.multiSelect := CM_BaseTable.MultiSelect_Simple;
	self.tblWouldPlan.setForm (self);
	
	self.tblWouldPlan.setTblDataEntRowsFromDef(app.myController.getEntTableDef(ETDef_WouldPlan));
	self.shtResults.caption := app.getErrorString(Would_plan);
	
	
	
	// set up the failed to Plan table.
	self.tblFailed.clear();
	self.tblFailed.fixedRows := 1;
	self.tblFailed.rows := self.tblFailed.fixedRows;
	self.tblFailed.selectionType := CM_BaseTable.SelectionType_Row;
	self.tblFailed.multiSelect := CM_BaseTable.MultiSelect_Simple;
	self.tblFailed.setForm (self);
	
	self.tblFailed.setTblDataEntRowsFromDef(app.myController.getEntTableDef(ETDef_FailedToPlan));
	self.shtFail.caption := app.getErrorString(Failed_test_plan);
	
	self.shtSelected.setFocus();
	

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="cmbTerminal_click" id="a89ba892-1fb0-4c1d-a9b9-cefa2977afcd">
        <controlMethod name="CMUI_ComboBox::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbTerminal_click(combobox: ComboBox input) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
02 March 2012	cnwndl1	Initial creation	Par 29195

*/

vars

begin

	self.isLocalTerminal := ( self.cmbTerminal.listObject = self.myTerminal );
	self.clearWouldPlanAndFailed();
	
	if self.isLocalTerminal or self.cmbTerminal.listObject = null then
		self.setCaption( app.getErrorString( Test_auto_planNN ) );
	else
		self.caption := app.getErrorString2( Test_auto_plan_from, self.myTerminal.name, self.cmbTerminal.listObject.CM_Terminal.name );
	endif;
	

epilog

end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
    </JadeMethod>
