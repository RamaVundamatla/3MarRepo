    <JadeMethod name="cloneReferences" id="40d672e3-a886-41da-82c5-f62ff12b7dd4">
        <updating/>
        <source>cloneReferences( _obj: CMQF_ASPAReports; _transient: Boolean ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 August 2019	jlgndl1	Initial creation	TFS 46131

*/

vars

begin

	inheritMethod(_obj, _transient);
	
	self.myWeightMeasureType := _obj.getMyWeightMeasureType;
	
	self.myEventFinish := _obj.getMyEventFinish;
	self.myEventPlaced := _obj.getMyEventPlaced;
	self.myEventPulled := _obj.getMyEventPulled;
	self.myEventStart := _obj.getMyEventStart;
	
	self.allBargeVessels.clear();
	_obj.allBargeVessels.copy(self.allBargeVessels);

	self.allNonBargeVessels.clear();
	_obj.allNonBargeVessels.copy(self.allNonBargeVessels);
	
	self.allUnloadEvents.clear();
	_obj.allUnloadEvents.copy(self.allUnloadEvents);
	
	
epilog

end;</source>
        <Parameter name="_obj" type="CMQF_ASPAReports"/>
        <Parameter name="_transient" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="filterForBargeUnloads" id="85a7061f-d25c-467b-bff2-1b660c058306">
        <updating/>
        <source>filterForBargeUnloads(_collection: Collection input; _passport: CM_Passport) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		TFS		Reason
20 Aug 2019	jlgdi1	45678		Initial creation

*/

vars
	cmif_header : CMIF_ASPABargeUnloadHeader;
	cmif_details : CMIF_ASPABargeUnloadsDetail;
	
begin

	//12 Nov 2019	NDL	TFS 47247 - Protect against spurious 1403 errors etc.
	if not self.validateInputFields() then
		return;
	endif;
	
	 if self.myEventStart = null then
		return;
	 endif;
	 if self.myEventFinish = null then
		return;
	 endif;
	 if self.myEventPlaced = null then
		return;
	 endif;	 
	 if self.myEventPulled = null then
		return;
	 endif;
	 
	create cmif_header transient;
	cmif_header.init(self.dateToRun,
					 self.timeToRun,
					 self.dateYearStart,
					 self.allTerminals,
					 self.allBargeVessels,
					 self.allUnloadEvents,
					 self.myEventStart,
					 self.myEventFinish,
					 self.myEventPlaced,
					 self.myEventPulled);
	
	cmif_header.processBargeVessels();
	
	// transfer the details to JRW
	foreach cmif_details in cmif_header.allASPABargeUnloadDetails do 
		_collection.add(cmif_details);
	endforeach;

epilog
	delete cmif_header;
end;</source>
        <Parameter name="_collection" type="Collection" usage="input"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
