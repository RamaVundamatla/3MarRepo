    <JadeMethod name="setupForm" id="f6215164-08bf-432f-bba9-ebc5d9266e6e">
        <updating/>
        <source>setupForm() updating;
/****Changes

Date		Name	TFS#			Description
============================================================================
21 Nov 2011	cnwcs5					Initial creation - CCMS POL 2122 / par 28696 - Empty Releases via COPARN
13/09/2012	cnwcs5	CCMS POL 2216 - changes for functional spec
15/10/2012	cnwcs5	par 30483 - 	tab key does not work when table has no data
14/12/2012  cnwgb1  CCMS POL 2216 	Uncomment above
19/02/2013	cnwcs5	CCMS PNL 2243 / par 31185
28/02/2013	cnwcs5	CCMS POL 2220 - changes for functional spec
03/07/2013	cnwcs5	par 31942 - 	FTX segment processing for Coparn/IFTMCS bookings
22 Jul 2013	cnwcs5	par 31942 - 	check EDI licenses
11 Sep 2014	cnwma1	PAR#34855 CCMS 2351: Hapag-Lloyd Release Request Enhancements
14 Jun 2016 cnwma1	TFS #2048 		POL - HSD EDI Empty Release Request
09 Sep 2016	cnwdap1	TFS 2566 		AAT EDI IFCSUM - consignee / vehicle make rules
21 Aug 2017	jlgrs1	TFS 6564 		add Coparn and Coreor RFF and NAD translation
31 Aug 2017	jlgrs1	TFS 6797 		SNO SpecialStow
23 Nov 2017	jlgrs1	TFS 5705 - 		SNO - EDIDataBooking Prenote release Req
18 Apr 2018	jlgrs1	TFS 8296 		add release req and prenotes to X12 301
23 May 2018	jlgrs1	TFS 38357 		SNO Fix Xlations from TFS 6797
25 Jun 2018	jlgrs1	TFS 39018 		SNO Cargo Operator in COPRAR
06/11/2018	jlgka1	39185,39187		Add action table for the IFCSUM Action rules.
22/05/2019	jlgka1	TFS 42732		PNL - CUSCAR Bayplan Style.
01/08/2019	jlgka1 	TFS 45467		SNO - Clean attribute in release request
14/04/2021	navmd1	TFS 51071		Rejig license checks, so they are consistent between view and maint forms
14 Aug 2023	jlirs1	TFS 59845 (57770) Port of Origin BOP
25 Sep 2023 jlirs1	TFS 59170 Port Authority Config
04 Mar 2024	jlirs1	TFS 57192 - 57193, 62335 Pen Support Import Voyage Translation
24 Aug 2024 navlw1	TFS 65152: NSW | IFCSUM Enhancements 
============================================================================*/
vars
	validLicenses	: BooleanArray;
	party			:CM_EDIParty;
	canDoUpdates	:Boolean;
	assistant		:CMUI_Assistant;
	combo			:CMUI_ComboBox;
	heading			:String;
	tmpTypeId		:Integer;
begin
	// TFS 51071 Make license checks consistent between view and maint forms
	// (and checking them only once should make the form open a little bit faster)
	if self.myParentForm &lt;&gt; null then
	
		validLicenses := self.myParentForm.CMUI_EDIPartyEnquiryForm.validEDILicenses;
	
		self.shtRulesCoparn.visible	:= validLicenses[EDIFileType_Coparn] or validLicenses[EDIFileType_CoparnRelease];	// Tab 1
		self.shtRulesIFTMCS.visible	:= validLicenses[EDIFileType_IFTMCS03A];											// Tab 2
		self.shtRulesX12315.visible	:= validLicenses[EDIFileTypeX12_315_4010];											// Tab 3
		self.shtRulesCuscar.visible	:= validLicenses[EDIFileType_CusCar];												// Tab 4
		self.shtRuleX12301.visible	:= validLicenses[EDIFileTypeX12_301_4010];											// Tab 5
		self.shtRuleQatar.visible	:= validLicenses[EDIFileType_XML_Milaha_Customs];									// Tab 6
		self.shtRulesBaplie.visible	:= validLicenses[EDIFileType_Baplie20] or validLicenses[EDIFileType_Baplie22];		// Tab 7
		self.shtRulesIFCSUM.visible	:= validLicenses[EDIFileType_IFCSUM94B];											// Tab 8
		self.shtRulesCoreor.visible	:= validLicenses[EDIFileType_Coreor];												// Tab 9
		self.shtRulesCoprar.visible	:= validLicenses[EDIFileType_Coprar];												// Tab 10
		self.shtRulesCamir.visible := validLicenses[EDIFileTypeCAMIR_CustomsStatus];									// Tab 11	
	endif;
	
	// This should never happen, but you never know...
	// In case something goes wrong though, always let superuser continue
	if not app.isSpecial() and (self.myParentForm = null or not self.myParentForm.CMUI_EDIPartyEnquiryForm.isLicensed) then
		app.msgBox(app.getErrorString1(NotLicensedToPerformAction, self.caption), self.caption, MsgBox_OK_Only);
		self.unloadForm;
		return;
	endif;
	
	
	inheritMethod();
	
	self.myAssistant.comboBoxToDoTasks(self.cmbToDoTask,null);
	self.myAssistant.comboBoxTermnialStopsTable(self.cmbStopTable,null); //cnwrd1 par #36184
	self.myAssistant.comboBoxTermnialStopsTable(self.cmbQatarStops,null);	//29 Jun 2015	NDL	Par 36543

	canDoUpdates	:= app.getMyUser.canDo(self.myTerminal, self.permissionMaint);
	self.canUpdate	:= canDoUpdates;
	party			:= self.myCurrentEDIParty;
	heading			:= app.getErrorString(EDI_Rule_Item) &amp; Tab &amp; app.getErrorString(EDI_Rule_Value) &amp; Tab &amp; app.getErrorString(EDI_Rule_Function);
	
	self.setupActionsTable(self.tblActionsCoparn, canDoUpdates, heading,
								null.String &amp; Tab &amp; 
                                CM_EDIEDIFactRule.Item_BGM_1_1 &amp; Tab &amp; 
                                CM_EDIEDIFactRule.Item_UNH_1_1 &amp; Tab &amp;   //cnwma1 TFS #2048 14/06/2016 
								CM_EDIEDIFactRule.Item_DTM_1_1 &amp; Tab &amp; 
								CM_EDIEDIFactRule.Item_FTX_1_1 &amp; Tab &amp;	
								CM_EDIEDIFactRule.Item_FTX_3_1 &amp; Tab &amp;	//07 Jun 2017	NDL	TFS 4454
                                CM_EDIEDIFactRule.Item_FTX_4_1 &amp; Tab &amp;	
                                CM_EDIEDIFactRule.Item_MEA_3_2 &amp; Tab &amp;
								CM_EDIEDIFactRule.Item_TMP_1_1 &amp; Tab &amp; 
								CM_EDIEDIFactRule.Item_NAD_1_1 &amp; Tab &amp; 
								CM_EDIEDIFactRule.Item_NAD_2_1 &amp; Tab &amp; 
								CM_EDIEDIFactRule.Item_NAD_3_1 &amp; Tab &amp; 
								CM_EDIEDIFactRule.Item_RFF_1_1);       //11/09/2014 cnwma1 PAR#34855  CCMS POL 2351

	self.setupActionsTable(self.tblActionsIFTMCS, canDoUpdates, heading,
								null.String &amp; Tab &amp; 
                                CM_EDIEDIFactRule.Item_FTX_1_1 &amp; Tab &amp;	
                                CM_EDIEDIFactRule.Item_FTX_4_1);
	self.setupActionsTable(self.tblActionsCoreor, canDoUpdates, heading,
								null.String &amp; Tab &amp; 
                                CM_EDIEDIFactRule.Item_RFF_1_1 &amp; Tab &amp;	
 								CM_EDIEDIFactRule.Item_NAD_1_1); 
	self.setupActionsTable(self.tblActionsCoprar, canDoUpdates, heading,
								null.String &amp; Tab &amp; 
                                CM_EDIEDIFactRule.Item_FTX_3_1 &amp; Tab &amp; 
                                CM_EDIEDIFactRule.Item_NAD_1_1 &amp; Tab &amp;
								CM_EDIEDIFactRule.Item_NAD_2_1 &amp; Tab &amp; 
								CM_EDIEDIFactRule.Item_NAD_3_1); 
	
	
	//cnwrd1 par 34193
	heading			:= app.getErrorString(EDI_Rule_Item) 
						&amp; Tab 
						&amp; app.getErrorString(EDI_Rule_Value) 
						&amp; Tab 
						&amp; app.getErrorString(EDI_Rule_Function)
						&amp; Tab 
						&amp; "Match Text" 
						&amp; Tab  
						&amp; "ToDo Task";
	
	self.setupActionsTableCuscar(self.tblActionsCuscar, canDoUpdates, heading,
								null.String &amp; Tab &amp; 
                                CM_EDICUSCARRule.Item_LOC_1_1 &amp; Tab &amp;
								CM_EDICUSCARRule.Item_FTX_1_1 &amp; Tab &amp;
								CM_EDICUSCARRule.Item_NAD_1_1);								
	
	 //cnwrd1 par #36184
	 
	heading			:= app.getErrorString(EDI_Rule_Item) 
						&amp; Tab 
						&amp; app.getErrorString(EDI_Rule_Value) 
						&amp; Tab 
						&amp; app.getErrorString(EDI_Rule_Function)
						&amp; Tab  
						&amp; "Stop";	 
	self.setupActionsTable315(self.tblActions315,canDoUpdates,heading,
									null.String &amp; Tab 
									&amp; CM_EDI315Rule.Item_B403 &amp; Tab
									&amp; CM_EDI315Rule.Item_N903 &amp; Tab);
									
	//29 Jun 2015	NDL	Par 36543
	heading			:= app.getErrorString(EDI_Rule_Item) 
						&amp; Tab 
						&amp; app.getErrorString(EDI_Rule_Value) 
						&amp; Tab 
						&amp; app.getErrorString(EDI_Rule_Function)
						&amp; Tab  
						&amp; "Stop";
	self.setupActionsTableQatar(self.tblActionsQatar,canDoUpdates,heading,
									null.String &amp; Tab &amp; 
									CM_QatarRule.Item_Qatar &amp; Tab
									);
	
	// jlgka1 TFS 39187, 39185 --&gt;
	heading			:= app.getErrorString(EDI_Rule_Item) 
					&amp; Tab 
					&amp; app.getErrorString(EDI_Rule_Value) 
					&amp; Tab 
					&amp; app.getErrorString(EDI_Rule_Function);
	self.setupActionsTable(self.tblActionsIFCSUMDet, canDoUpdates, heading,
								null.String &amp; Tab &amp;                                 
								CM_EDIEDIFactRule.Item_FTX_21_1);  
	
	// jlgka1 TFS 39187, 39185 &lt;--
	
	heading := app.getErrorString(Consignee) &amp; Tab &amp; app.getErrorString(CM_Cargo_Type) &amp; Tab &amp; app.getErrorString(Vehicle_make);	// TFS 2566
	self.setupActionsTableIFCSUM(self.tblActionsIFCSUM, canDoUpdates, heading, null.String);									// TFS 2566
	
	heading := app.getErrorString(HS_codes) &amp; Tab &amp; app.getErrorString(CM_Cargo_Type) &amp; Tab &amp; app.getErrorString(Cargo_subtype);	// navlw1 #65152
	self.setupActionsTableIFCSUMHS(self.tblActionIFCSUMHS, canDoUpdates, heading, null.String);
	
	assistant := self.myAssistant;
	
	assistant.comboBoxSubTerminal(self.cmbSubTerminal, null, self.myTerminal);
	assistant.comboBoxSubTerminal(self.cmbSubTerminal_1, null, self.myTerminal);
	assistant.comboBoxCarrier(self.cmbCarrier, null);
	assistant.comboBoxCarrier(self.cmbCarrier_1, null);
	assistant.comboBoxReleaseType(self.cmbReleaseType, true, true, true, true, true, false);
	assistant.comboBoxReleaseType(self.cmbReleaseTypeX12301, true, true, true, true, true, false);
	
	 //cnwrd1 par 34193
	self.cmbChildCargoTyp.sorted := true;
	self.myAssistant.comboBoxCargoBolType(self.cmbChildCargoTyp, tmpTypeId, true, true, true, true);
	
	// jlgka1 TFS 39185 --&gt;
	self.cmbIFCSUMISOType.sorted := true;
	self.myAssistant.comboBoxISOTypeGroup(self.cmbIFCSUMISOType, null);
	// jlgka1 TFS 39185 &lt;--
	
	// load up status combo - we only want Active &amp; Pending(par 31185)
	combo := self.cmbReleaseStatus;
	combo.cnEcAddItemDataObject(app.releaseStatusEnumToString(BR_ACTIVE), BR_ACTIVE, null);
	combo.cnEcAddItemDataObject(app.releaseStatusEnumToString(BR_PENDING), BR_PENDING, null);
	combo.cnEcSetItemData(BR_PENDING);
	combo := self.cmbReleaseStatusX12301;
	combo.cnEcAddItemDataObject(app.releaseStatusEnumToString(BR_ACTIVE), BR_ACTIVE, null);
	combo.cnEcAddItemDataObject(app.releaseStatusEnumToString(BR_PENDING), BR_PENDING, null);
	combo.cnEcSetItemData(BR_PENDING);
	
	assistant.comboBoxVoyageObject(self.cmbVoyage, null);
	assistant.comboBoxVoyageObject(self.cmbVoyage_1, null);
	assistant.comboBoxDeliveryReasonCombo(self.cmbDeliveryReaso, null);
	assistant.comboBoxDeliveryReasonCombo(self.cmbDeliveryReaso_1, null);
	assistant.comboBoxAvailabilityGrade(self.cmbGradeDry, null);
	assistant.comboBoxAvailabilityGrade(self.cmbGradeDry_1, null);
	assistant.comboBoxAvailabilityGrade(self.cmbGradeReefer, null);
	assistant.comboBoxAvailabilityGrade(self.cmbGradeReefer_1, null);
	assistant.comboBoxISOTypeForCargoType(self.cmbGenType, app.myRoot.allCargoTypesById[TI_CargoType_Generator], null);
	assistant.comboBoxCargoTypes(self.cmbIFCSUMCargoType, null);		//14 Aug 2023	jlirs1	TFS 59845 (57770) Port of Origin BOP

	self.cmbGenType_1.visible := false;
	self.lblGenType_1.visible := false;
//	assistant.comboBoxISOTypeForCargoType(self.cmbGenType_1, app.myRoot.allCargoTypesById[TI_CargoType_Generator], null);
	if app.myPassport.myTerminal.getConfig(EdiUseOldCoparn).Boolean then
		self.chkUseGateDoc.enabled := false;
	else
		self.chkUseGateDoc.enabled := true;
	endif;
	if not canDoUpdates then
		// buttons
		self.btnAddCoparn.enabled			:= false;
		self.btnDeleteCoparn.enabled		:= false;
		self.btnSave.enabled				:= false;
		// details
		self.txtName.readOnly				:= true;
		self.txtDescription.readOnly		:= true;
		self.txtSenders.readOnly			:= true;
		// Coparn sheet
		self.chkEmailUpdate.enabled			:= false;
		self.chkEmailDelete.enabled			:= false;
		self.chkUseISOGrpRR.enabled			:= false;
		self.chkCreateGenRR.enabled			:= false;
		self.cmbSubTerminal.enabled			:= false;
		self.cmbCarrier.enabled				:= false;
		self.cmbReleaseType.enabled			:= false;
		self.cmbVoyage.enabled				:= false;
		self.cmbDeliveryReaso.enabled		:= false;
		self.cmbGradeDry.enabled			:= false;
		self.cmbGradeReefer.enabled			:= false;
		self.cmbGenType.enabled				:= false;
		self.chkRelByType.enabled			:= false; //cnwrd1 33790
		self.chkUseGateDoc.enabled 			:= false;
		self.chkReleaseIncNonClean.enabled	:= false; //jlgka1 TFS 45467
	endif;		
	//jlier1 TFS 57056 17/3/23
	self.btnFTXTransform.enabled:=false;
	self.btnNADTransform.enabled:=false;
	if party &lt;&gt; null then
		// display EDI Party Details
		self.loadData(party);

		self.beginNotification(party, EDI_PARTY_UPDATE_EVENT, Response_Continuous, null);
		self.beginNotification(party, Object_Delete_Event, Response_Cancel, null);
	endif;
	
	// TFS 2198 CNWAB1
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		self.grpDetails.enabled:= false;
		
		self.shtRulesCoparn.disableAllChildren();	// Tab 1
		self.shtRulesIFTMCS.disableAllChildren();	// Tab 2
		self.shtRulesX12315.disableAllChildren();	// Tab 3
		self.shtRulesCuscar.disableAllChildren();	// Tab 4
		self.shtRuleX12301.disableAllChildren();	// Tab 5
		self.shtRuleQatar.disableAllChildren();		// Tab 6
		self.shtRulesBaplie.disableAllChildren();	// Tab 7
		self.shtRulesIFCSUM.disableAllChildren();	// Tab 8 TFS3658 MAP 13/4/17
		self.shtRulesCoreor.disableAllChildren();	// Tab 9
		self.shtRulesCoprar.disableAllChildren();	// Tab 10
		self.shtRulesCamir.disableAllChildren();	// Tab 11			//04 Mar 2024	jlirs1	TFS 57192 - 57193, 62335 Pen Support Import Voyage Translation
	endif;
	self.addFrmLoadFileToolbar();	//MTN-33228
	self.minimumHeight := 790;		// 26 Sep 2023 	jlirs1	TFS 59170 Port Authority Config
epilog

end;</source>
    </JadeMethod>
