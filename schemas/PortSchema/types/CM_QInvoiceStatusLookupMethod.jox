    <JadeMethod name="getInvStatusMaxLength" id="e8243829-9943-4705-9e4b-821382b85cd9">
        <source>getInvStatusMaxLength() : Integer;
/*

Purpose: Returns the length of the longest description of an Invoice Status 
extracted from 'App.Root.AllInvoiceStatuses'. At the time of writing, 
myInvoiceProcess reference never gets updated, reason for it to be always null.
Being null makes the external key length of a DynaDict always set to 1 
which introduce string too long error (1035 error code) when adding an entry 
in the dynadict.

Parameters: None

Return Value: Integer

Date		Who		Reason
06 May 2019	jlgdi1	Initial creation
*/

vars
	invoiceStatus : CM_InvoiceStatus;
	length : Integer;
	maxLength : Integer;
	
begin
	maxLength := 1;
	
	foreach invoiceStatus in app.myRoot.allInvoiceStatuses do
		length := invoiceStatus.description.length();
		if length &gt; maxLength then 
			maxLength := length;
		endif;
	endforeach;
	
	return maxLength;
end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getKeyLengthForXTABDictionary" id="8defbfed-681d-4a8e-a7dc-45e9c8afd02c">
        <source>getKeyLengthForXTABDictionary(): Integer;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 May 2014	cnwndl1	Initial creation	Par 34142
13 Jun 2018	jlgsl4	TFS 39070 - STWO - Posted_Returned too long, causes Summary error
06 May 2019	jlgdi1	TFS	44598 Added null reference checking
					Determines the length of the longest invoice status description to be used when adding an 
					external key specification to a dyna dictionary.
*/

vars
	length, lengthToCheck : Integer; // TFS 39070
	invStatus : CM_InvoiceStatus;
	invoiceProcess : CM_InvoiceProcess;
	
begin
	
	/*  // TFS 39618 PATCH 1 
	length := app.getInvoiceStatusString(self.myInvoiceProcess, CM_Invoice.INVOICE_OPEN).length; //app.getErrorString(Suspense).length; // TFS 39618
	lengthToCheck := CM_Invoice.INVOICE_PENDING; // TFS 39070 - does nothing, but will show in references for INVOICE_PENDING
	length := length.max (app.getInvoiceStatusString(self.myInvoiceProcess, CM_Invoice.INVOICE_OPEN).length); //getErrorString(Open_GC).length); // TFS 39618
	length := length.max (app.getInvoiceStatusString(self.myInvoiceProcess, CM_Invoice.INVOICE_PENDING).length); //getErrorString(Pending).length); // TFS 39618
	length := length.max (app.getInvoiceStatusString(self.myInvoiceProcess, CM_Invoice.INVOICE_POSTED).length); //getErrorString(Posted).length); // TFS 39618
	length := length.max (app.getInvoiceStatusString(self.myInvoiceProcess, CM_Invoice.INVOICE_VOID).length); //getErrorString(Void).length); // TFS 39618
	length := length.max (app.getInvoiceStatusString(self.myInvoiceProcess, CM_Invoice.INVOICE_POSTED_REVERSE).length); //getErrorString(Posted_returned).length); // TFS 39070 // TFS 39618
	length := length.max (app.getInvoiceStatusString(self.myInvoiceProcess, CM_Invoice.INVOICE_POSTED_CREDIT).length); //getErrorString(Posted_credit).length); // TFS 39070 // TFS 39618
	length := length.max (app.getErrorString(CM_Any_Status).length); // TFS 39070 - matches INVOICE_ALL_STATUS
	length := length.max (app.getInvoiceStatusString(self.myInvoiceProcess, CM_Invoice.INVOICE_DISPUTED).length); //app.getErrorString(Disputed).length); // TFS 39070 // TFS 39618
	length := length.max (app.getInvoiceStatusString(self.myInvoiceProcess, CM_Invoice.INVOICE_SUSPENSE).length); //app.getErrorString(Suspense).length); // TFS 39070 // TFS 39618
	length := length.max (app.getInvoiceStatusString(self.myInvoiceProcess, CM_Invoice.INVOICE_DISPUTED).length); //app.getErrorString(Prepend).length); // TFS 39070 // TFS 39618	
	 
	 
	 NOW // TFS 39618 PATCH 1  */
	 
	length := 1;
	invoiceProcess := self.myInvoiceProcess;
	
	if invoiceProcess &lt;&gt; null then 
		foreach invStatus in self.myInvoiceProcess.allStatuses	discreteLock do
			length := length.max (invStatus.description.length);
		endforeach;
	else
		length := getInvStatusMaxLength();
	endif;
	
	return length;
end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
