//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	message	: String;
begin
	message := "XAHRFR";
	return message[1:15];
end;</source>
