	tbl_cache.text   := 'Class' &amp; Tab &amp; 'Hits' &amp; Tab &amp; 'Edition' &amp; Tab &amp; 'Size' &amp; Tab &amp; 'Flag' &amp; Tab &amp; 'Process';
	tbx_cacheStats.text := '';
end;</source>
