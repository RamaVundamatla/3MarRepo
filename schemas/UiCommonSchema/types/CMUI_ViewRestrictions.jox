    <JadeMethod name="setMultiGroupBox" id="bc9cbca0-d5e5-4167-ae41-1d4ce151679a">
        <source>setMultiGroupBox(_multi : CMUI_MultiSelectGroupBox input; _displayString, _caption : String; _coll : Collection);
vars
begin
	_multi.distanceFromBottom 			:= 5;
	_multi.distanceFromRight 			:= 5;
	_multi.lockBottom 					:= false;
	_multi.lockRight					:= false;
	_multi.stretchHeight 				:= true;
	_multi.stretchWidth 				:= true;
	_multi.multiSelect 					:= ListBox.MultiSelect_Extended;
	_multi.formDisplayEntryMethodName 	:= 'display' &amp; _displayString;
	_multi.availableHeading 			:= 'Available restrictions';
	_multi.selectedHeading 				:= 'Selected restrictions';
	_multi.setAvailable(_coll, true);
	
	_multi.parent.CMUI_Sheet.caption 	:= _caption;
	_multi.parent.CMUI_Sheet.cnEcResizeContents();
	_multi.parent.CMUI_Sheet.visible 	:= true;

end;</source>
        <Parameter name="_multi" type="CMUI_MultiSelectGroupBox" usage="input"/>
        <Parameter name="_displayString" type="String"/>
        <Parameter name="_caption" type="String"/>
        <Parameter name="_coll" type="Collection"/>
    </JadeMethod>
