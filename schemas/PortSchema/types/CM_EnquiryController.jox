    <JadeMethod name="addObjectToSet" id="dcbfc841-f41d-40a5-98be-4a16ffb2f4c6">
        <updating/>
        <source>addObjectToSet(_obj : CM_Object) updating;
// ---------------------------------------------------------------------------
// Created:     18 February 2003 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	
begin

	// When self.numItemsFoundLimit &lt;&gt; null then it is possible to interrupt a searching procedure. Par17107	cnwvu1	June 2008
	if self.numItemsFoundLimit &gt;= 1 and self.numItemsFound &gt;= self.numItemsFoundLimit then
		self.breakOutOfSearch := true;
		return;
	endif;
	
	//specifically handles a 1309 (obj already in set) - faster than doing an 'includes' every time
	on Exception do self.queryExHandler(exception);

	self.allObjects.add(_obj);	
	self.numItemsFound := self.numItemsFound + 1;
end;</source>
        <Parameter name="_obj" type="CM_Object"/>
    </JadeMethod>
