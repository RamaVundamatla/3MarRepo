    <JadeMethod name="createLogEntry" id="949deb5e-d891-44d5-bf80-78a76bc0ca76">
        <source>createLogEntry(_controller: CnEcReleaseController;
			   _methodName : String;
			   _message : String);
/*

Purpose: To minimize redundant lines of code.
         I have observed that the same code below are used in the create/delete/set method of this class 
		 (ex. createStevedoreDebtorType, deleteMvmtPilotDetlsOrphans, setBGPMonthlyRecurUnitAndValue) which 
		 seems to be redundant.

Parameters:			

Return Value:		

Date		Who		TFS		Reason
22 Jul 2019	jlgdi1	45301	Initial creation

*/

begin
	app.writeLog(_methodName &amp; _message, LogINFO);
	if _controller &lt;&gt; null then
		_controller.logEntry(_message);
	endif;
end;</source>
        <Parameter name="_controller" type="CnEcReleaseController"/>
        <Parameter name="_methodName" type="String"/>
        <Parameter name="_message" type="String"/>
    </JadeMethod>
    <JadeMethod name="createMTPoolPartyDebtorType" id="2066db4b-f124-4e7f-9f25-0d65fa84fad7">
        <source>createMTPoolPartyDebtorType(_updController : CnEcReleaseController);
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 16/01/2017	cnwdap1		Initial creation TFS 3042 SNO Empty Container Pool Management
//
vars
	debtorType : CM_DebtorType;

begin
	if self.hasScriptBeenRunAtAll(method.name, _updController) then
		return;
	endif;
	// create the new Debtor Type of "Empty Pool Party"
	if app.myRoot.allDebtorTypes["SDT0"] &lt;&gt; null then
		return;
	endif;
	
	app.writeLog(method.qualifiedName &amp; " Creating Empty Pool Party Debtor Type", LogINFO);
	if _updController &lt;&gt; null then
		_updController.logEntry(" Creating Empty Pool Party Debtor Type") ;	
	endif;
	
	beginTransaction;
	create debtorType;
	debtorType.setForCreateParam("SDT0", "Empty Pool Party");
	commitTransaction;
	
	app.writeLog(method.qualifiedName &amp; " Creating Empty Pool Party Debtor Type complete", LogINFO);
	if _updController &lt;&gt; null then
		_updController.logEntry(" Creating Empty Pool Party Debtor Type complete") ;	
	endif;
	
	self.addScriptRun(method.name);
epilog

end;</source>
