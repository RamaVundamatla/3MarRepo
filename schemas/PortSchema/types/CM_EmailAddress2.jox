    <JadeMethod name="getDisplayStringForAttribute" id="89ea3e23-9aca-4c1c-8cfe-e896ef9441b3">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
//----------------------------------------------------------------
//	Created:	04 March 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	eg	: CM_EmailGroup;
	str : String;
	
begin
	if _attrName = ETRow_Groups then
		foreach eg in self.allEmailGroups do
			if str = null then
				str := eg.name;
			else
				str := str &amp; ", " &amp; eg.name;
			endif;
		endforeach; 
		return str;
	//epr par 35304 2/12/14
	elseif _attrName = ETRow_MobilePhone then
		return self.mobilePhone;
	elseif _attrName = ETRow_BusinessPhone then
		return self.businessPhone;
	elseif _attrName = ETRow_FaxNumber then
		return self.faxNumber;
	elseif _attrName = ETRow_HomePhone then
		return self.homePhone;
	elseif _attrName = ETRow_AutoReplyOption then
		if self.autoReplyOption = EmailReplyType_None then
			return EmailReplyTypeStr_None;
		elseif self.autoReplyOption = EmailReplyType_HeaderOnly then
			return EmailReplyTypeStr_HeaderOnly;
		endif;
		return null;
	else
		return inheritMethod(_attrName, _short);
	endif;


end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
