    <JadeMethod name="getBank" id="09e30820-176e-4923-92ba-de0d4896a7d4">
        <source>getBank(): CM_Bank;
// CCMS 1043 Snapshot Summary Invoicing 	Oct 2010 	cnwjre1
vars

begin
	if self.myTransactionMap &lt;&gt; null then
		return self.myTransactionMap.myBank;
	else
		return null;
	endif;
	
end;
</source>
        <ReturnType type="CM_Bank"/>
    </JadeMethod>
    <JadeMethod name="getMyAllocation" id="71dacce8-f25a-425f-930c-0e17bd4448f1">
        <source>getMyAllocation() : CM_InvoiceCargoAllocation;
/*
Purpose:			
Date		Who		Reason
25 March 2015	cnwab1	Initial creation
*/

vars

begin
	if self.allInvoiceAllocations.isEmpty() then
		return null;
	endif;
	
	return self.allInvoiceAllocations.first.CM_InvoiceCargoAllocation;
epilog

end;</source>
        <ReturnType type="CM_InvoiceCargoAllocation"/>
    </JadeMethod>
    <JadeMethod name="initialiseYA" id="316a7e7b-4e40-4a25-8f22-d1f366497f04">
        <updating/>
        <source>initialiseYA() updating;
/*
Purpose:			
Date			Who		Reason
17 March 2015	cnwab1	Initial creation
28 Nov	2017	jlgmd1	TFS7496 Qual - truncate description to 100 characters
*/

vars
	alloc : CM_InvoiceCargoAllocation;
	c : CM_YACriteria;
	t : CM_TransactionType;
	desc : String;
	qrm : CM_QuantityMap;
begin
	self.allYACriteriaTypes.clear();
	self.allTransactionTypes.clear();
	
	alloc := self.allInvoiceAllocations.first.CM_InvoiceCargoAllocation;
	
	if alloc &lt;&gt; null then
		desc := "";
		
		foreach c  in alloc.allCriteria discreteLock do
			self.allYACriteriaTypes.add(c.myYACriteriaType.type);
		endforeach;
		
		c := alloc.allCriteriaByType[YACriteriaType_TransactionType];
		
		if c &lt;&gt; null then
			c.myYAData.CM_YADataObjects.allObjects.copy(self.allTransactionTypes);
			
			foreach t  in self.allTransactionTypes discreteLock do
				if desc = "" then
					desc := t.description;
				else
					desc := desc &amp; ", " &amp; t.description;
				endif;

			endforeach;
		endif;
		self.description := desc[1:100];
	endif;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="cf19dd9a-1df9-452a-b819-6cd7b7ee514d">
        <updating/>
        <source>setForCreate(_pxySB: SelfType) updating;
/*
Purpose:			
Date				Who			Reason
MARCH 2015		CNWAB1		Initial creation
*/

vars
	bank : CM_Bank;
begin
	inheritMethod(_pxySB);
	
	self.initialise(self.getBank());

	self.initialiseYA();
	
	

end;
</source>
        <Parameter name="_pxySB" type="SelfType"/>
    </JadeMethod>
</Class>
