    <JadeMethod name="setProxy" id="c855bb95-efcf-4ae6-a350-ffb02c6bfcb5">
        <updating/>
        <source>setProxy(_categoryContext : Integer;
		 _code            : String;
		 _description     : String;
		 _myRoot      : CM_Root; // ### TFS CR 55299 TASK 55985 28DEC2022 NAVAB1
		 _external	  : Boolean // 24 Jan 2023 navvt20 TFS 56206
		 ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29/11/2022 navmv20 TFS CR 55299 TASK 55516: Jade - Write TRX for new file category
24/01/2023 navvt20 TFS CR 56204 Task 56206: UI - File Category Maintenance
*/

vars

begin
	self.categoryContext := _categoryContext;
	self.code := _code;
	self.description := _description;
	
	self.myRoot := _myRoot;  // ### TFS CR 55299 TASK 55985 28DEC2022 NAVAB1
	self.external := _external; // 24 Jan 2023 navvt20 TFS 56206
	 // ### TFS CR 55299 TASK 55985 28DEC2022 NAVAB1self.myTerminal := _myTerminal;
epilog

end;

</source>
        <Parameter name="_categoryContext" type="Integer"/>
