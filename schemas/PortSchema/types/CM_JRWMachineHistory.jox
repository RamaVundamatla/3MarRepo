    <JadeMethod name="getDateFromLocalTZ" id="4ecaee2b-b3ed-4165-a09b-8c49c8962f93">
        <source>getDateFromLocalTZ() : Date ;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 June 2016	cnwns1	Initial creation
// 02 June 2016	cnwns1	TFS 488 - Multi Timezone Support
*/

vars

	sysTS : TimeStamp;
begin
	sysTS.cnEcSetDateAndTime(dateFrom,timeFrom);
	return self.systemToLocalTime(sysTS).date();
epilog

end;</source>
        <ReturnType type="Date"/>
    </JadeMethod>
