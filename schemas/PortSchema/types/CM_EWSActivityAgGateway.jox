    <JadeMethod name="setForCreate" id="2133800d-db57-49b3-a6db-a1950f8e1c06">
        <updating/>
        <source>setForCreate(_proxy: SelfType) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15th July 2025	navra1	Initial creation for //navra1 - MTN-34782 - 15th July 2025

*/

vars

begin
	inheritMethod(_proxy);
	
	self.myExtWebserviceDef := _proxy.myExtWebserviceDef;
	self.myRoot := _proxy.myRoot;
	self.myTerminal :=  _proxy.myTerminal;
	self.sendRecvMessage:= _proxy.sendRecvMessage;
	self.direction:= _proxy.direction;
	self.messageType := _proxy.messageType;								//navra1 - MTN-35875- 5th Sep 2025-1
	self.interactionPartyName := _proxy.interactionPartyName;
	self.request := _proxy.request;
	self.response := _proxy.response;
	self.responseCode := _proxy.responseCode;	
	
epilog

end;</source>
        <Parameter name="_proxy" type="SelfType"/>
    </JadeMethod>
