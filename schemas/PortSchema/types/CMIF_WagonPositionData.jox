        <access>readonly</access>
    </PrimAttribute>
    <JadeMethod name="getHeight" id="88d3faf9-df3a-4035-be37-9eab4cb16998">
        <source>getHeight():Decimal;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
27 July 2009	cnwndl1	Initial creation

*/

vars
	totalHeight	: Decimal [12,2];
	ti			: CM_TrackedItem;	
begin

	totalHeight := 0;
	foreach ti in self.allTrackedItems do
		totalHeight := totalHeight + ti.getActualHeightRaw();
	endforeach;

	return totalHeight;
	
end;</source>
        <ReturnType type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="getWeight" id="663cbd8a-4316-4552-9aa4-3d6686495c59">
        <source>getWeight():Decimal;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
27 July 2009	cnwndl1	Initial creation

*/

vars
	totalWeight	: Decimal [12,2];
	ti			: CM_TrackedItem;	
begin

	totalWeight := 0;
	foreach ti in self.allTrackedItems do
		totalWeight := totalWeight + ti.totalWeight;
	endforeach;

	return totalWeight;
	
end;</source>
        <ReturnType type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="setBaseData" id="3db4ecb5-afa2-4775-86e5-55038d13b948">
        <updating/>
        <source>setBaseData( 	_position : Integer;
				_length : Integer
				) updating;

/*

Purpose:			

Parameters:			

