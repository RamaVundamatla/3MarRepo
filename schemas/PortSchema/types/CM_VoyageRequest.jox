    <JadeMethod name="getAttrFlatRackEnds" id="e0cda041-b496-4cdf-9137-dd5ac0491949">
        <source>getAttrFlatRackEnds(_up : Boolean) : Boolean;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 08/11/2019	jlgdap1		Initial creation TFS 46405 AAT Flat Rack and OOG in LOLO Planning Screen
//
vars
	criteria : CM_YACriteria;	

begin
	criteria := self.getAttrByType(YACriteriaType_FlatRackStatus);
	if criteria &lt;&gt; null then
		if _up then
			return criteria.myYAData.CM_YADataPattern.pattern = app.flatRackEndsEnumToString(TI_DOORSDIRN_ENDUP).toUpper;
		else
			return criteria.myYAData.CM_YADataPattern.pattern = app.flatRackEndsEnumToString(TI_DOORSDIRN_ENDDOWN).toUpper;
		endif;
	endif;
	
	return false;

epilog

end;</source>
        <Parameter name="_up" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
