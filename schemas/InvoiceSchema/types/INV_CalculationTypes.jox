    <JadeMethod name="doCmbBuildCalendars" id="6e1c6d0a-917c-41a4-8c3c-a926beea0a65">
        <source>doCmbBuildCalendars();
/*
Purpose:			
Date		Who		Reason
03 December 2012	cnwab1	Initial creation
*/

vars
	dt1, dt2 : CM_DayType;
	cal1 : CM_Calendar;
begin
	self.cmbCalNormal.clear();
	self.cmbCalExclusion.clear();
	
	self.cmbCalNormal.sorted := true;
	self.cmbCalExclusion.sorted := true;
	
	dt1 := app.myRoot.getConfig(MyInvBusHrsDayTypeNorm).CM_DayType;
	dt2 := app.myRoot.getConfig(MyInvBusHrsDayTypeExcl).CM_DayType;
	
	
	foreach cal1 in app.myRoot.allCalendars  discreteLock do
		if cal1.myDayType = dt1 then
			self.cmbCalNormal.addItemObject(cal1.description, cal1);
		endif;
		
		if cal1.myDayType = dt2 then
			self.cmbCalExclusion.addItemObject(cal1.description, cal1);
		endif;
	endforeach;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doCmbCalcTypesBuild" id="a378bff8-cb30-4335-8183-92905f05a396">
        <source>doCmbCalcTypesBuild();
// ---------------------------------------------------------------------------
// Created:		January 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//	July 2012 29755    user-defined calc types are valid for cargo and HMS - only show HMS if enabled
//	06 Oct 2017		   cnwma1  TFS #7257 JMT - Refactoring - Commodity Planning
//  280Mar 2019			jlgdap1	TFS 43694 PEL1 Charging for vessels that use a Ramp
// ---------------------------------------------------------------------------

vars
	canDoVTMIS	: Boolean;
	cargoLabels : StringArray; 
	cargoValues : IntegerArray;
	vtmisValues : IntegerArray;
	vtmisLabels : StringArray;
	woValues : IntegerArray;
	woLabels : StringArray;
	eventValues : IntegerArray;
	eventLabels : StringArray;
	bolValues : IntegerArray;	//31 Oct 2019	NDL	TFS 47100
	bolLabels : StringArray;	//31 Oct 2019	NDL	TFS 47100
	tot, idx : Integer;
	idxc	: Integer;
begin

	canDoVTMIS := app.myRoot.canDo(Mod_Harbour); //	cnwma1  TFS #7257

	create cargoLabels transient;
	create cargoValues transient;
	create vtmisLabels transient;
	create vtmisValues transient;
	create woLabels transient;
	create woValues transient;
	create bolLabels transient;	//31 Oct 2019	NDL	TFS 47100
	create bolValues transient;	//31 Oct 2019	NDL	TFS 47100
	create eventLabels transient;
	create eventValues transient;
	
	self.cmbCalcTypes.clear;
	self.cmbCalcTypes.sorted := true;
	
	//31 Oct 2019	NDL	TFS 47100
	app.getAllInvoiceCalcTypes(true,true,bolLabels,bolValues,"BOL");	
	tot := 	bolValues.size;
	foreach idx in 1 to tot do
		idxc := self.cmbCalcTypes.addItem(bolLabels[idx]);
		self.cmbCalcTypes.itemData[idxc] := bolValues[idx];
	endforeach;

	
	// ### WO CALC TYPES TFS 39198
	app.getAllInvoiceCalcTypes(true,true,woLabels,woValues,"WORKORDER");	
	tot := 	woValues.size;
	foreach idx in 1 to tot do
		idxc := self.cmbCalcTypes.addItem(woLabels[idx]);
		self.cmbCalcTypes.itemData[idxc] := woValues[idx];
	endforeach;
	
	// ### HMS CALC TYPES
	if canDoVTMIS then
		app.getAllInvoiceCalcTypes(true,true,vtmisLabels,vtmisValues,"VTMIS");	// 29755 make conditional
		tot := 	vtmisValues.size;
		foreach idx in 1 to tot do
			idxc := self.cmbCalcTypes.addItem("HMS - " &amp; vtmisLabels[idx]);
			self.cmbCalcTypes.itemData[idxc] := vtmisValues[idx];
		endforeach;
	endif;
	
	// ### CARGO CALC TYPES
	app.getAllInvoiceCalcTypes(true,true,cargoLabels,cargoValues,"CARGO");	// include for CCMS 1151, par 24024
	self.cargoCalcTypes.clear();
	cargoValues.copy(self.cargoCalcTypes);		// save for later use

	tot := 	cargoValues.size;
	foreach idx in 1 to tot do
		idxc := self.cmbCalcTypes.addItem("Cargo - " &amp; cargoLabels[idx]);
		
		self.cmbCalcTypes.itemData[idxc] := cargoValues[idx];
	endforeach;
	
	// ### EVENT CALC TYPES TFS 39198
	app.getAllInvoiceCalcTypes(true,true,eventLabels,eventValues,"EVENT");	
	tot := 	eventValues.size;
	foreach idx in 1 to tot do
		idxc := self.cmbCalcTypes.addItem(eventLabels[idx]);
		
		self.cmbCalcTypes.itemData[idxc] := eventValues[idx];
	endforeach;
	
	
	// ### INVENTORY CALC TYPES TFS 51219
	app.getAllInvoiceCalcTypes(true,true,eventLabels,eventValues,"INVENTORY");	
	tot := 	eventValues.size;
	foreach idx in 1 to tot do
		idxc := self.cmbCalcTypes.addItem(eventLabels[idx]);
		
		self.cmbCalcTypes.itemData[idxc] := eventValues[idx];
	endforeach;
	
	//21 Mar 2019	NDL	TFS 43687
	self.cmbRateType.clear();
	self.cmbRateType.itemData[ self.cmbRateType.addItem( app.getCalcRateTypeStr(CM_CalculationType.RateTypeSingle) ) ] :=  CM_CalculationType.RateTypeSingle;
	self.cmbRateType.itemData[ self.cmbRateType.addItem( app.getCalcRateTypeStr(CM_CalculationType.RateTypeHMSMovementType) ) ] :=  CM_CalculationType.RateTypeHMSMovementType;
	self.cmbRateType.itemData[self.cmbRateType.addItem(app.getCalcRateTypeStr(CM_CalculationType.RateTypeRamp))] :=  CM_CalculationType.RateTypeRamp;		// TFS 43694
	self.cmbRateType.listIndex := -1;
	

epilog
	delete cargoLabels;
	delete cargoValues;
	delete vtmisLabels;
	delete vtmisValues;
	delete woLabels;
	delete woValues;
	delete eventLabels;
	delete eventValues;
	delete bolLabels;	//31 Oct 2019	NDL	TFS 47100
	delete bolValues;	//31 Oct 2019	NDL	TFS 47100
end;</source>
    </JadeMethod>
    <JadeMethod name="doCmbEventBlockUnitBuild" id="43cc2aea-8c3d-453b-acd7-28e822aa8e08">
        <source>doCmbEventBlockUnitBuild();
/*****************************************************
Author		: jlika1 (Karen Alexander)
Date		: 22 August 2022
TFS#		: 54420
Function	:

*** Changes ***
Date			Name		TFS#		Description

****************************************************/

vars
