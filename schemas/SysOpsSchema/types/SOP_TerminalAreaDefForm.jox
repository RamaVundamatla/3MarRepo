    <JadeMethod name="clearDesignArea" id="6329a652-1bde-4744-8fe3-0bf9e31f4de5">
        <updating/>
        <source>clearDesignArea() updating, protected;

vars

begin
	// Clear Grid Area
	self.frmMain.allGridAreasByColumnRow.purge;
	self.frmMain.allGridAreasByRowColumn.purge;
	self.myCurrentSOPGridArea := null;

	// Clear Block Area
	self.frmBlkArea.visible := false;
	self.btnAssocIC.enabled:=false;
	self.frmAssocICArea.visible:=false;
	self.frmTBICAreas.visible:=false;

	

end;</source>
