    <JadeMethod name="setListValues" id="18b3bdb6-156e-4335-b44c-1f4a2913cce8">
        <source>setListValues(_tbl: Table input; _params: CM_QueryCriteriaLineHolder; _operator: CM_QueryOperator; _passport: CM_Passport);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
06 January 2012	cnwndl1	Initial creation	Par 28889

*/

vars

	term : CM_Terminal;
	ya : CM_YardAllocation;
	iter : Iterator;
	idx : Integer;
	selectionValue : Integer;

begin

	_tbl.rows := _tbl.fixedRows;
	_tbl.sortColumn[1] := 2; // TFS 7821

	
	if _params = null then
		return;
	endif;
	
	term := _passport.myTerminal;
	if term = null then
		return;
	endif;
	
//	iter := term.allYardAllocations.createIterator;	
	iter := term.allYardAllocatonsByCode.createIterator;
	
	while iter.next(ya) do
		// TFS 1775 Apr 2016 cnwjre1 stop invoice allocations as showing as yard allocations
		if ya.isDisabled or
		   ya.isInvoiceAllocation then
			continue;
		endif;
		selectionValue := 0;
		if _operator &lt;&gt; null and _operator.CM_QReferenceIsOneOf.allSelectionValues.includes(ya) then
			selectionValue := 1;
		endif;
		
		idx := _tbl.addItem(selectionValue.String &amp; Tab &amp; ya.getListDisplay);
		_tbl.accessRow(idx).itemObject := ya;
		_tbl.row := idx;
		_tbl.change(_tbl);
	endwhile;

epilog

	delete iter;

end;</source>
        <Parameter name="_tbl" type="Table" usage="input"/>
        <Parameter name="_params" type="CM_QueryCriteriaLineHolder"/>
        <Parameter name="_operator" type="CM_QueryOperator"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="setTextValues" id="aef7e55a-ec9c-44e5-a61a-4a5ed75561f7">
        <source>setTextValues(_txt: TextBox input; _params: CM_QueryCriteriaLineHolder; _operator: CM_QueryOperator; _passport: CM_Passport);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
06 January 2012	cnwndl1	Initial creation

*/

vars

begin

	
	inheritMethod(_txt, _params, _operator, _passport);

epilog

