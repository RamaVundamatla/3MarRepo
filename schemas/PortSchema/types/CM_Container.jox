    <JadeMethod name="setShipLanderSeals" id="40e81f56-506f-4ca9-8912-0bd29e0de462">
        <updating/>
        <source>setShipLanderSeals(	pxyTI : SelfType;
					_checkSealsForDischarge : Boolean) updating;
/* Changes

Date		Name	TFS#		Description
============================================================================
29 Mar 2019 jlgka1	TFS 44020	Change Seals to Maximum.
20 Feb 2024 navhl20 ChangeRequest 62525: EUP | Retrospective Operations - [54177.060] - Cargo &amp; Truck Checks
============================================================================*/					

vars
	oldSealNum,
	oldSealNumCust,
	oldSealNumShipper,
	oldSealDT			: String;
	sealTxnController	: CMIF_SealTransController;
	tiTrxDetails		: String;
	editTransaction 	: CM_Edit;
begin
	
	if not _checkSealsForDischarge then
		//15 Sep 2010	NDL	Par 25608 - change to using methods to access seals
		if pxyTI.getSealNum = app.getErrorString(Seal_Present) then
			//if there are already seal nums anywhere will keep what is there and return
			if self.getSealNum &lt;&gt; null or
				self.getSealNumCustomsFirst  &lt;&gt; null or
				self.getSealNumShipper &lt;&gt; null then
				return;
			endif;
		endif;
		//everthing else updates the seals with the pxys string
	endif;
	
	//16 Sep 2010	NDL	Par 25608 - change to using get methods to access seals data
	
	oldSealNum:=self.getSealNum;
	oldSealNumCust:=self.getSealNumCustoms;
	oldSealNumShipper:=self.getSealNumShipper;
	oldSealDT:=self.getSealDT.asStringJMT;
	if oldSealNum &lt;&gt; pxyTI.getSealNum then
		create sealTxnController transient;
		sealTxnController.type := TRANS_TYPE_SEALED;
		sealTxnController.sealNum := pxyTI.getSealNum(); // jlgka1 TFS 44020
		self.createTransaction(sealTxnController, app.myPassport);
	endif;
	
	self.setSealDetails(pxyTI.getSealNum, pxyTI.getSealDT, false);	//17 Sep 2010	NDL	Par 25608
	self.setSealNumCustoms(pxyTI.getSealNumCustoms);	//17 Sep 2010	NDL	Par 25608
	self.setSealNumShippers(pxyTI.getSealNumShipper);	//17 Sep 2010	NDL	Par 25608

	//tiTrxDetails:=app.formatForEditTransaction(CM_Container::sealNum.name,oldSealNum,self.getSealNum);
	tiTrxDetails:=app.formatForEditTransaction(SealNum,oldSealNum,self.getSealNum);	//17 Sep 2010	NDL	Par 25608
	editTransaction:=app.createEditTransaction(self,tiTrxDetails,null,app.myPassport);		//20.02.2024 navhl20 #62525
	//tiTrxDetails:=app.formatForEditTransaction(CM_Container::sealDT.name,oldSealDT,self.getSealDT.asStringJMT);
	tiTrxDetails:=app.formatForEditTransaction(SealDT,oldSealDT,self.getSealDT.asStringJMT);	//17 Sep 2010	NDL	Par 25608
	editTransaction.fieldsValues.add(tiTrxDetails);
	//tiTrxDetails:=app.formatForEditTransaction(CM_Container::sealNumCustoms.name,oldSealNumCust,self.getSealNumCustoms);
	tiTrxDetails:=app.formatForEditTransaction(SealNumCustoms,oldSealNumCust,self.getSealNumCustoms);	//17 Sep 2010	NDL	Par 25608
	editTransaction.fieldsValues.add(tiTrxDetails);
	//tiTrxDetails:=app.formatForEditTransaction(CM_Container::sealNumShippers.name,oldSealNumShipper,self.getSealNumShipper);
	tiTrxDetails:=app.formatForEditTransaction(SealNumShippers,oldSealNumShipper,self.getSealNumShipper);	//17 Sep 2010	NDL	Par 25608
	editTransaction.fieldsValues.add(tiTrxDetails);

epilog
	delete sealTxnController;
end;
</source>
        <Parameter name="pxyTI" type="SelfType"/>
        <Parameter name="_checkSealsForDischarge" type="Boolean"/>
    </JadeMethod>
