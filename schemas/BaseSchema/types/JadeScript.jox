    <JadeMethod name="cnwndl_Test_Soundex" id="1136a427-58eb-42bf-b0e0-7f16ec54b7db">
        <source>cnwndl_Test_Soundex();

vars
	theSoundexValue		: CnEcSoundex;
	theMetaphoneValue	: CnEcMetaphone;
	
begin
	create theSoundexValue transient;
	create theMetaphoneValue transient;
	
	theSoundexValue.updateMe("backroomm");
	theMetaphoneValue.updateMe("backroomm");
	write theSoundexValue.getTransform(0);
	write theMetaphoneValue.getTransform(0);
	
	theSoundexValue.updateMe("Pane");
	theMetaphoneValue.updateMe("Pane");
	write theSoundexValue.getTransform(0);
	write theMetaphoneValue.getTransform(0);
	
	theSoundexValue.updateMe("darrell");
	theMetaphoneValue.updateMe("darrell");
	write theSoundexValue.getTransform(0);
	write theMetaphoneValue.getTransform(0);
epilog
	delete theSoundexValue;
	delete theMetaphoneValue;
end;</source>
    </JadeMethod>
    <JadeMethod name="map_Script" id="038a3355-41b8-4343-a01f-40f9c95c9a83">
        <source>map_Script();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 March 2016	cnwmp6	Initial creation

*/

vars
	b1, b2: Binary;
	b3, b4: Binary;
	ch: Character;
	st1, st2: String;
begin

	b1 := #[01 02 03 00 04 05 06 00 07 08 09 0A 00 0B 0C 00];
	b2 := b1.cnEcUnpackCString(1);
	b3 := #[65 66 67 31 32 33];
	write b2;
	write b2.length();
	st1 := "My dog has fleas";
	write st1.Binary;
	write st1.asANSI(0);
	st2 := b3.ansiToString;
	write st2.Binary;
	write " ".Binary.length();
epilog

end;</source>
    </JadeMethod>
