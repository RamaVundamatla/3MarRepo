    <JadeMethod name="tblView2_dragDrop" id="0bf1cb99-02fc-4c28-b95a-227aa78f3ea0">
        <controlMethod name="Table::dragDrop"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblView2_dragDrop(table: Table input; win: Window input; x: Real; y: Real) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 April 2023	navkc1	Initial creation CR 57036 Task 57589: UI - Cargo Enquiry Drag Drop

*/

vars
	entDef		: EntTableDef;
	terminal	: CM_Terminal;
	ti			: CM_TrackedItem;
	
begin
	entDef := table.CM_DataTable.myEntTableDef;
	
	ti := self.myCurrentObject.CM_TrackedItem;
	
	if ti = null or not ti.isMAFI() then
		return;
	endif;
	
	terminal := self.myTerminal;
	
	if terminal &lt;&gt; null and terminal.getConfig(MoveTIToParentTrailer).Boolean then
		self.doTblDataDragDropEvent(table, win, x, y);
	endif;
epilog

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="win" type="Window" usage="input"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
