    <JadeMethod name="initShtMultiSelect" id="64b9537f-91d9-40f7-827a-71913770dc42">
        <source>initShtMultiSelect();
// ---------------------------------------------------------------------------
// Created:      13 May 2003 by cnwsgp1
// ---------------------------------------------------------------------------
vars
	theForm		: SOP_TableMaintForm;
	terminology	: String;
	
begin
	theForm := self.myForm;
	inheritMethod;
	
	theForm.shtSingleSelect1.visible		:= true;
	theForm.shtSingleSelect1.caption		:= app.getErrorString( Ports_of_call );
	theForm.lstSingleSelect1.visible		:= true;
	theForm.btnSingle1Edit.visible			:= false;
	theForm.btnSingle1Up.visible			:= true;
	theForm.btnSingle1Down.visible			:= true;
	theForm.lstSingleSelect1.hasTreeLines	:= true;
	theForm.lstSingleSelect1.hasPlusMinus	:= true;
	
	terminology := app.getTerminologyAlternate(null, null, CM_TerminologyOperator, CM_TermExpressionPlural, 'Operators');
	self.setupMultiSelect1(terminology,app.myRoot.allOperators,SOP_TableMaintForm::displayEntryOperator.name);	
	
	self.setupMultiSelect2(app.getErrorString(Shipping_lines),app.myRoot.allShippingLines,SOP_TableMaintForm::displayEntryShippingLine.name);
	
end;
</source>
    </JadeMethod>
