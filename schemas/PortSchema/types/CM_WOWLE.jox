    <JadeMethod name="erase" id="8ed03c29-1896-450c-9cf1-d42b8d872b20">
        <updating/>
        <source>erase(_eraseLevel: Integer) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
14/06/2022	navcs2	ChangeRequest 53038: MTN - Work Order Maintenance Refactor - PortSchema

*/


vars
begin
	
	// Lock all for update
	exclusiveLock(self);
	sharedLock(myRequest);
	if self.myRequest.myJob &lt;&gt; null then
		sharedLock(self.myRequest.myJob);
	endif;

	self.causeEvent(self.job.getMyTerminal.getTerminalEvent(WLE_Delete_Event), false, self);				  	

  	inheritMethod(_eraseLevel);
epilog

end;</source>
        <Parameter name="_eraseLevel" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="a40451e4-1a25-44e5-bd88-785aee73c6c0">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 Jun 2023 navma1 	ChangeRequest 58339: EUP | Delivery Dispatch Screen - Road Operation
21 Jun 2023 navma1	Defect 58687: MTN - Job's Cargo details are not populating correctly on the Work Order Operations form
03 Jul 2023 navma1 ChangeRequest 58849: EUP | Delivery Dispatch Screen - Unpack Operation
18 Oct 2023 navhl20 Bug 60931: EUP - Delivery Dispatch Remedial [2]
25 Mar 2024 navhl20 ChangeRequest 62300: EUP | 53729 - Delivery Dispatch Screen - outstanding issues - 2
11 Sep 2024 navma1  Bug 65777: EUP | 53729 - Delivery Dispatch Screen - wrong WO info when multiple in one Job
*/

vars
	ti			: CM_TrackedItem;
	str			: String;
	workOrder	: CM_WorkOrder;
	bulkRelease : CM_BulkRelease;
	request     : CM_Request;
	type 		: String;
begin
	if  _attrName = ETRow_Id				 or 
		_attrName = ETRow_IsoGroup			 or
		_attrName = ETRow_ISOType			  
	then
		ti		 := self.getTi();							//26.10.2023 navhl20 #60931
		request	 := self.myRequest;
		
		if ti &lt;&gt; null then
			return ti.getDisplayStringForAttribute(_attrName,_short);
		elseif request &lt;&gt; null then
			return request.getDisplayStringForAttribute(_attrName,_short);
		endif;
		return null;

	elseif _attrName = ETRow_ReleaseRequest then
		ti		 := self.myTrackedItem;
		request	 := self.myRequest;
		
		if ti &lt;&gt; null then
			bulkRelease := ti.allBulkReleasesAssigned.first;
			if bulkRelease &lt;&gt; null then
				return bulkRelease.code;
			endif;
		elseif request &lt;&gt; null then
			return  request.getDisplayStringForAttribute(_attrName,_short);
		endif;
		return null;
	elseif _attrName = ETRow_WorkOrder then
		
		
		if self.job &lt;&gt; null then
			workOrder := self.job.getWorkOrder();
			if workOrder &lt;&gt; null then
				str := workOrder.id.asStringJMT();
			else
				workOrder := self.getWorkOrder();										//11.09.2024 navma1 #65777
				if workOrder &lt;&gt; null then
					str := workOrder.id;
				endif;
			endif;
		endif;
	
		return str;
	elseif _attrName = ETRow_Type then													//25.03.2024 navhl20 #62300
		return null;
	elseif _attrName.isMeasurementType then												//18.10.2023 navhl20 #60931
		_attrName.getRowNameMeasureType(str, type);
		return self.getMeasurementStringForAttrib(str, type, _short);
	else
		return inheritMethod(_attrName, _short);
	endif;
epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getExtraInfo" id="2707ae23-3711-4c99-b12c-fada76551c72">
        <source>getExtraInfo(_dataContainer: CM_DataContainer);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 Mar 2023	navma1	ChangeRequest 56318:[56319] EUP - Enable ToDo Work Order job on Yard Operation Screen

*/

vars
	block : CM_DataContainerBlock;
begin
	
	inheritMethod(_dataContainer);
	
	block := _dataContainer.addNewBlock;

	block.addNewItem('Status', DC_Label, 1, self);
	block.addNewItem(self.statusString, DC_Data, 1, self);
epilog

end;</source>
        <Parameter name="_dataContainer" type="CM_DataContainer"/>
    </JadeMethod>
    <JadeMethod name="getLinkedJob" id="1aa9e82b-d078-4a9a-bf6b-27e72012dc5b">
