    <JadeMethod name="cnwdad1_Test_EncodeWebData" id="66f808fe-c0dd-443d-8e20-4d3608b672be">
        <source>cnwdad1_Test_EncodeWebData();
// --------------------------------------------------------------------------------
// Created:		30 January 2001 by cnwdad1
//
// Purpose:		This method will test the String::cnEcUrlEncode method.
//
//	*****************************************************************************
//	** Refer to the text of this method for a sample XML message for testing. ***
//	*****************************************************************************
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	theDataFile		: File;
	dataString		: String;
	startTime		: Integer;
	
begin
	create theDataFile transient;
	
//	theDataFile.kind		:=	File.Kind_ANSI;			// 26/2/16  cnwns1 PAR 36286 unicode version	
	theDataFile.kind		:=	File.Kind_Unknown_Text; // 26/2/16  cnwns1 PAR 36286 unicode version	
	theDataFile.mode		:=	File.Mode_Input;
	theDataFile.fileName	:=	"c:\temp\tradehub\292830.txt";
	
	if theDataFile.isAvailable() then
		write "Reading the data file...";
		
		while not theDataFile.endOfFile() do
			if dataString = null then
				dataString	:=	theDataFile.readLine;
			else
				dataString	:=	dataString &amp; theDataFile.readLine;
			endif;
		endwhile;
		
		theDataFile.close();
		
		if dataString = null then
			write "The data string is empty !";
		else
			write "Encoding the data string of " &amp; dataString.length.String &amp; " bytes...";
			startTime	:=	app.clock();
			dataString	:=	dataString.cnEcUrlEncode(String.CNEC_URL_ENCODE_JADE);
			write "Size of result string = " &amp; dataString.length.String &amp; " bytes.";
			write "String encoded in " &amp; startTime.cnEcClockDifference().numberFormat() &amp; " seconds.";
		endif;
	else
		write "Cannot open the data file.";
	endif;
epilog
	delete theDataFile;
end;</source>
        <text>&lt;?xml version='1.0'?&gt;&lt;REQUEST&gt;&lt;HEADER&gt;&lt;MESSAGE_TYPE&gt;REP_ORDER&lt;/MESSAGE_TYPE&gt;&lt;SOURCE_URL&gt;tcp/ip&lt;/SOUR
CE_URL&gt;&lt;SESSION_ID&gt;DD5BD1FE3F47F6FECD9FC7D09F8B99F8A8EA&lt;/SESSION_ID&gt;&lt;CLIENT_MESSAGE_NO&gt;3&lt;/CLIENT_MES
SAGE_NO&gt;&lt;SERVER_MESSAGE_NO&gt;4&lt;/SERVER_MESSAGE_NO&gt;&lt;TIMEDATE_STAMP&gt;29/01/2001 11:53&lt;/TIMEDATE_STAMP&gt;&lt;GE
T_ZONE&gt;10&lt;/GET_ZONE&gt;&lt;LOCALE&gt;27&lt;/LOCALE&gt;&lt;LANGUAGE&gt;ENGUK&lt;/LANGUAGE&gt;&lt;COUNTRY_CODE&gt;USA&lt;/COUNTRY_CODE&gt;&lt;CU
RRENCY_CODE&gt;USD&lt;/CURRENCY_CODE&gt;&lt;CURRENCY_PREFIX&gt;'$'&lt;/CURRENCY_PREFIX&gt;&lt;DEBUG&gt;TRUE&lt;/DEBUG&gt;&lt;MESSAGE_STA
