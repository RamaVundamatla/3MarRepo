    <JadeMethod name="organiseMenu" id="7dfdf016-4662-439a-a9d8-505fb913c2d1">
        <updating/>
        <source>organiseMenu() updating, protected;
// ---------------------------------------------------------------------------
// Created:     09 January 2003		cnwth2	
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	menuRootSet : CM_MenuEntitySet;
	user		: CM_User;
	ut			: CM_UserTerminal;
	menuEntity	: CM_MenuEntity;
begin

	if (not self.checkOpenWindows()) then
		return;
	endif;
	
	create menuRootSet transient;
	self.getMenuRootSetForItem(menuRootSet);
	if menuRootSet.isEmpty then
		return;
	endif;
	self.lstTest.organizeMenu(menuRootSet);
	
epilog
	delete menuRootSet;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="organiseTerminals" id="9c071b98-db6a-43a7-9cc1-4d722184270d">
        <updating/>
        <source>organiseTerminals() updating, protected;
// ---------------------------------------------------------------------------
// Created:     09 June 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	frm			: CMUI_OrganizeMenuRoots;
begin
	if (not self.checkOpenWindows()) then
		return;
	endif;
	
	create frm transient;
	frm.showModal();	
	if frm.modalResult &lt;&gt; IDOK then
		return;
	endif;
	self.isTerminalMenuInitialised := false;
	self.loadNavData();
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="resetAllUserMenus" id="6e46ff64-e12d-4dea-ad82-a19a34ab8f80">
        <source>resetAllUserMenus() protected;
// ---------------------------------------------------------------------------
// Created:     13 January 2003		cnwth2	
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	menuAgent			: CM_MenuAgent;
	user		: CM_User;
	fromEntity	: CM_MenuEntity;
	terminal	: CM_Terminal;
	menuRoot	: CM_MenuRoot;
begin
	create menuAgent transient;
	fromEntity := self.lstTest.listObject.CM_MenuEntity;
	
	user := app.getMyUser;
	terminal := fromEntity.getMyTerminal;

	if terminal = null then
		menuRoot := fromEntity.getMyMenuRoot;
		if menuRoot.isKindOf(CM_MenuRootForUser) then //we are dealing with the user's system item menu root
			if not app.msgBox("Are you sure you wish to reset all users' 'System Items' menus?",'Are you sure?', MsgBox_OK_Cancel) = MB_OK then
				return;
			endif;

			menuAgent.trxResetSysEntMenusForAllUsers(true);	
			return;
		endif;
	endif;

	if not app.msgBox("Are you sure you wish to reset all users' 'Navigator' menus?",'Are you sure?', MsgBox_OK_Cancel) = MB_OK then
		return;
	endif;
	
	menuAgent.trxResetNavMenusForAllUsers(false);	

epilog
	delete menuAgent;
end;</source>
        <access>protected</access>
    </JadeMethod>
