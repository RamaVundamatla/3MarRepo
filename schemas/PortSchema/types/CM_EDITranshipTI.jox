    <JadeMethod name="create" id="101e140a-0b4c-4ef1-b64a-794989129f05">
        <updating/>
        <source>create() updating;
/*
----------   ----------  --------------------------------------------------
Created:	18 September 2007 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars

begin
	self.messageMode := CM_EDITrackedItem.EDI_ACTION_ADD;
	self.temperature := NULL_TEMPERATURE;
end;


</source>
    </JadeMethod>
    <JadeMethod name="delete" id="e3b8a1b4-2a81-4a5a-aeca-7b5ab4c17391">
        <updating/>
        <source>delete() updating;

/*
Date			Who		Reason
14 June 2010	cnwrl1	Initial creation as part of PAR 24299 - SFW 1118 EDI Form to allow searching of EDI file by Container / Voyage
*/
	
vars
	voyageCodeStr	: String;
	
begin
	// remove this EDITrackedItem from the manual collection on myEDIConfig if it is there
	if self.myEDIConfig = null then
		return;
	endif;
	
	voyageCodeStr	:= self.getExportVoyageCode();
	if voyageCodeStr &lt;&gt; null then
		if self.myEDIConfig.allEDITrackedItemsByVoyageCode.includesKey( voyageCodeStr.toUpper, self ) then
			self.myEDIConfig.allEDITrackedItemsByVoyageCode.removeKeyEntry( voyageCodeStr.toUpper, self, self );
		endif;
	endif;
	
epilog
	
end;
</source>
    </JadeMethod>
    <JadeMethod name="getCommodityGroupCode" id="929c5c16-a883-48fd-b283-278d203eafd4">
        <source>getCommodityGroupCode() : String;
// ---------------------------------------------------------------------------
// Created:     20 April 2009 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	commG : CM_CommodityGroup;
begin
	commG := self.getCommodityGroupObject();
	
	if commG = null then
		return null;
	endif;
	
	return commG.code;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getCommodityGroupObject" id="913e83d4-a3e9-4717-8eb2-f3298912bb8a">
        <source>getCommodityGroupObject() : CM_CommodityGroup;
// ---------------------------------------------------------------------------
// Created:     20 April 2009 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	comm : CM_Commodity;
begin
	comm := app.myRoot.allCommodities[self.commodity];
	
	if comm = null then
		return null;
	endif;
	
	return  comm.myCommodityGroup;
epilog

end;</source>
        <ReturnType type="CM_CommodityGroup"/>
    </JadeMethod>
