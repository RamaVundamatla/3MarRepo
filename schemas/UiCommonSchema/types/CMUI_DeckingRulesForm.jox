    <JadeMethod name="updateSelectedLocns" id="43af84c5-caa5-4f0e-b2c7-d3dd8f44b74f">
        <source>updateSelectedLocns(_yaLocnCell: CM_YALocationCell; _shift: Integer);
//----------------------------------------------------------------
//	Created:	22 April 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	yaLocnCell	: CM_YALocationCell;
	intRow,
	idx,
	intStart,
	intEnd		: Integer;
	blnSelected	: Boolean;
begin

	self.allSelectedLocnCells.clear;
	if _yaLocnCell = null then
		return;
	endif;

	foreach idx in 1 to self.lstDeckingLocns.itemSelected.size do
		blnSelected := self.lstDeckingLocns.itemSelected[idx];
		if blnSelected then
			yaLocnCell := self.lstDeckingLocns.itemObject[idx].CM_YALocationCell;
			self.allSelectedLocnCells.add(yaLocnCell);
		endif;
	endforeach;

end;</source>
        <Parameter name="_yaLocnCell" type="CM_YALocationCell"/>
        <Parameter name="_shift" type="Integer"/>
    </JadeMethod>
</GUIClass>
