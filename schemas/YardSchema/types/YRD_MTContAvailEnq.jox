    <JadeMethod name="doMnuRelaseReqsEnq" id="3ca150cc-ba09-4e38-ba2e-bb0134ff46ed">
        <source>doMnuRelaseReqsEnq( menuItem: MenuItem input );

/*

Purpose:			

Parameters:			Calls the form "GTE_ReleaseRequestForm" in "GateSchema" 
					and populates with the Bulk releases in the collection.

Return Value:		


Date		Who		Reason
20 June 2011	cnwndl1	Initial creation	Par 27331

*/

vars

	form : CM_TableViewForm;
	menuAction 	: CMUI_MenuAction;
	brSet : CM_BulkReleaseSet;

begin

//	GTE_ReleaseRequestForm
	if not app.getMyUser.canDo(self.myTerminal, PmGteMTReleaseView) then
		return;
	endif;
	
	if menuItem.userObject = null or not menuItem.userObject.isKindOf( CM_BulkReleaseSet ) then
		return;
	endif;
	
	brSet := menuItem.userObject.CM_BulkReleaseSet;
	if brSet.isEmpty then
		return;
	endif;
	
	menuAction := app.myController.createMenuAction(PmGteMTReleaseView, null, self.myMasterMenuAction, self.myTerminal);
	if menuAction = null then
		return;
	endif;
	
	form := menuAction.goToObject(null, null, false, null).CM_TableViewForm;
	if form = null then
		return;
	endif;
	
	form.show;
	form.sendMsgWithParams("setFromMTContAvailEnq", brSet);

epilog

end;</source>
        <Parameter name="menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
