    <JadeMethod name="cmbPortDestBuild" id="22ff5ffb-b9ec-4f33-8a2c-49cf866e0750">
        <source>cmbPortDestBuild() protected;
// ---------------------------------------------------------------------------
// Created:		June 2006 cnsrs1 ccms 1031
// ---------------------------------------------------------------------------
vars
	port : CM_Port;
	idx : Integer;
	str : String;
begin
	self.cmbPortDest.clear;

	foreach port in app.myRoot.allActiveDestinations do
		str := port.getDisplayFormatted(self.portCmbOrderDescrFirst);
		idx := self.cmbPortDest.addItem(str);
		self.cmbPortDest.itemObject[idx] := port;
	endforeach;

	self.cmbPortDest.listIndex := -1;
end;</source>
        <access>protected</access>
    </JadeMethod>
