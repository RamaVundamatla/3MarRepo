<CollClass name="CM_DocumentStopsDict" id="888a6355-9021-4bb3-b1b4-4ce562620b72">
    <loadFactor>66</loadFactor>
    <memberType name="CM_DocumentStops"/>
    <superclass name="MemberKeyDictionary"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="docActions"/>
    <MemberKey>
        <property name="CM_DocumentStops::myTrackedItem"/>
    </MemberKey>
    <MemberKey>
        <property name="CM_DocumentStops::myStopsTable"/>
    </MemberKey>
    <JadeMethod name="getTotalAmountForId" id="e277cefa-0131-4174-a3d7-7b921dfea9d4">
        <source>getTotalAmountForId( _id : String; _stop : CM_StopsTable ):Real;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 September 2016	cnwndl1	Initial creation	TFS 2647 / 2001

*/

vars

	docStop : CM_DocumentStops;
	total : Real;

	invalidObject	: Boolean;

	ti : CM_TrackedItem;
begin
	on Exception do app.handleDeletedObject(exception, ti, invalidObject); // ### TFS 53851 14JUN2022 NAVAB1
	
	foreach docStop in self do
		ti := docStop.myTrackedItem; // ### TFS 53851 14JUN2022 NAVAB1
		if docStop.myTrackedItem.id &lt;&gt;_id then
			continue;
		endif;
		if docStop.myStopsTable &lt;&gt; _stop then
			continue;
		endif;
		total := total + docStop.amount;
	endforeach;
	
	return total;

epilog

end;</source>
        <Parameter name="_id" type="String"/>
        <Parameter name="_stop" type="CM_StopsTable"/>
        <ReturnType type="Real"/>
    </JadeMethod>
</CollClass>
