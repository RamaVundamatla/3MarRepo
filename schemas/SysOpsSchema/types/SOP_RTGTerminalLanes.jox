    <JadeMethod name="doChangeZoom" id="1b5aee28-edf1-42e0-9750-ddbddea81821">
        <updating/>
        <source>doChangeZoom(_newZoom : Integer) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
23 July 2008	cnwer1	Initial creation
14/07/2025	naviv1	MTN-35226	MTN - Usage of Iterator.getCurrentKeys  	
*/

vars
	iter : Iterator;
	oldGridSize : Integer;
	obj  : Object;
	x1,y1,x2,y2 : Real;
	newX,
	newY : Integer;
	newDict : CMUI_GridObjectByX1Y1X2Y2Dict;
	frame : Frame;
begin
	
	if _newZoom = 0 then
		return;
	endif;
	oldGridSize:=self.getTotalGridSize;
	self.frmScrollingMain.clearGraphics;
	self.frmRTGTemplate.clearGraphics;
	zoom:=_newZoom;
	self.drawBaseGrid();
	create newDict transient;
	iter := self.allRTGAreasInGrid.createIterator;
	while iter.next(obj) do
		iter.getCurrentKeys(x1,y1,x2,y2); //MTN-35226
		newX:= ((x1/oldGridSize) * self.getTotalGridSize).Integer;
		newY:=((y1/oldGridSize) * self.getTotalGridSize).Integer;
		newDict.putAtKey(newX,newY,0,0,obj);
		frame:=obj.Frame;
		frame.left:=newX;
		frame.top:=newY;
	endwhile;
	
	delete iter;
	self.allRTGAreasInGrid.clear;
	newDict.copy(self.allRTGAreasInGrid);
	
	foreach obj in self.allRTGAreasInGrid do
		frame:=obj.Frame;
		//self.drawRTGArea(frame.userObject.CM_RTGArea,frame);
		
	
	endforeach;
	
epilog
	delete iter;
	delete newDict;
end;</source>
        <Parameter name="_newZoom" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="doResize" id="68963f4d-acbd-4e81-b969-4519ea1f9236">
        <updating/>
        <source>doResize() updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
23 July 2008	cnwer1	Initial creation

*/

vars

begin
	inheritMethod();

	self.frmScrollablMain.height:=self.dkcGridArea.height-10;
	self.frmScrollablMain.width:=self.dkcGridArea.width;
	self.frmScrollablMain.resizeScrollingFrame(2000,2000);
	self.frmScrollablMain.repositionScrollBars();

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="drawBaseGrid" id="95d38704-a2af-445a-a9e0-53bf4cf6c619">
        <source>drawBaseGrid();
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
23 July 2008	cnwer1	Initial creation

*/

vars
	stepSize,
	lineSize,
	i: Integer;
begin
	//draw dotted grid  800 x 800 
	stepSize:=self.getTotalGridSize;
	lineSize:=self.frmScrollingMain.width.Integer;
	foreach i in 0 to lineSize step stepSize do
		self.frmScrollingMain.drawStyle:=Frame.DrawStyle_Solid;

		self.frmScrollingMain.drawLine(1,i,lineSize,i,Grey);
		self.frmScrollingMain.drawLine(i,1,i,lineSize,Grey);
	endforeach;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="drawRTGArea" id="8f2369fc-3dbd-41c5-9031-f61e4b6ef77f">
        <updating/>
        <source>drawRTGArea( _rtgArea : CM_RTGArea input; _frame : Frame input) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
21 July 2008	cnwer1	Initial creation

*/

vars
	numBays,
	numRows,
	rowsPerLane,
	numLanes,
	tmpWidth,
	tmpHeight,
	gridSize,
	i,rowCount,rowNum: Integer;
	rtgRow : CM_RTGRow;
	topOffset,
	leftOffset : Integer;
begin
	_frame.clearGraphics;
	if _rtgArea = null then
		return;
	endif;
	
	numBays := _rtgArea.numberOfColumns;
	numRows := _rtgArea.numberOfRows;
	gridSize := self.getTotalGridSize;
	//width is numBays  * gridSize 
	tmpWidth := numBays * gridSize;
	
	tmpHeight:= numRows * gridSize;
	if _frame.userObject = null then
		_frame.left:=0;
		_frame.top:=0;
	else
	
	endif;
	leftOffset:=10*zoom;
	topOffset:=10*zoom;
	_frame.width:=tmpWidth + (leftOffset*2) ;
	_frame.height:=tmpHeight + (topOffset*2) ;
	//self.frmRTGTemplate.transparent:=false;
	_frame.autoRedraw:=true;
	_frame.ignoreSkin:=true;
	_frame.borderStyle:=self.BorderStyle_None;
	_frame.userObject:=_rtgArea;
	_frame.drawStyle:=Frame.DrawStyle_Solid;
	_frame.drawFontSize:=gridSize;
	_frame.drawTextAt(_rtgArea.id,(tmpWidth/2).Integer,0,Black);
	
//	self.frmRTGTemplate.drawLine(1,1,tmpWidth,1,Blue);
	foreach i in topOffset to tmpHeight+leftOffset step gridSize do
		_frame.drawLine(leftOffset,i,leftOffset+tmpWidth,i,Grey);
		_frame.drawLine(i,topOffset,i,topOffset+tmpHeight,Grey);
	endforeach;
	
	_frame.drawLine(leftOffset,topOffset,leftOffset+tmpWidth,topOffset,Black);
	_frame.drawLine(leftOffset,topOffset,leftOffset,topOffset+tmpHeight,Black);
	
	_frame.drawLine(leftOffset,topOffset+tmpHeight,leftOffset+tmpWidth,topOffset+tmpHeight,Black);
	_frame.drawLine(leftOffset+tmpWidth,topOffset,leftOffset+tmpWidth,topOffset+tmpHeight,Black);
	
	_frame.drawFillStyle:=DrawFillStyle_Solid;
	_frame.drawFillColor:=app.convertRGBToColor(128,255,128);

	i:=0;
	rowCount:=0;
	rowNum:=_rtgArea.allGridRows.first.CM_RTGRow.row;
	foreach i in topOffset to tmpHeight+leftOffset step gridSize do
		
		
		if rowCount = 2 then
			_frame.drawLine(leftOffset,i,leftOffset+tmpWidth,i,Black);
			_frame.drawFloodFill(tmpWidth-1,i-1,0,Black);
			rtgRow:=_rtgArea.allGridRows[rowNum-2].CM_RTGRow;
			
			_frame.drawTextAt(rtgRow.label,(tmpWidth/2).Integer,i-(gridSize*1.5),Black);
		
		endif;
		
		if rowCount = (rowsPerLane + 2) then
			_frame.drawLine(leftOffset,i,leftOffset+tmpWidth,i,Black);
			
			rowCount:=0;
		endif;
		rowCount:=rowCount+1;
		rowNum:=rowNum+1;
	endforeach;
	
	if self.allRTGAreasInGrid.getAtKey(_frame.left.Integer,_frame.top.Integer,0,0) = null then
		self.allRTGAreasInGrid.putAtKey(_frame.left.Integer,_frame.top.Integer,0,0,_frame);
	endif;
	
epilog

end;</source>
        <Parameter name="_rtgArea" type="CM_RTGArea" usage="input"/>
        <Parameter name="_frame" type="Frame" usage="input"/>
    </JadeMethod>
    <JadeMethod name="frmRTGTemplate_mouseDown" id="75ad6449-9682-48e1-ae0a-df19eddaa1f6">
        <controlMethod name="CMUI_MoveableFrame::mouseDown"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>frmRTGTemplate_mouseDown(frame: Frame input; button: Integer; shift: Integer; x: Real; y: Real) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
23 July 2008	cnwer1	Initial creation

*/

vars

begin
	self.currentX:=frame.left.Integer;
	self.currentY:=frame.top.Integer;
epilog

end;</source>
        <Parameter name="frame" type="Frame" usage="input"/>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="frmRTGTemplate_mouseUp" id="fa1c613b-0c58-4c0d-baec-6ac006565d13">
        <controlMethod name="CMUI_MoveableFrame::mouseUp"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>frmRTGTemplate_mouseUp(frame: Frame input; button: Integer; shift: Integer; x: Real; y: Real) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
23 July 2008	cnwer1	Initial creation

*/

vars

begin
	self.snapToGrid(frame.top);
	self.snapToGrid(frame.left);
	
	if self.allRTGAreasInGrid.getAtKey(self.currentX,self.currentY,0,0) &lt;&gt; null then
		self.allRTGAreasInGrid.removeKeyEntry(self.currentX,self.currentY,0,0,frame);
		self.allRTGAreasInGrid.putAtKey(frame.left.Integer,frame.top.Integer,0,0,frame);
	endif;
	
epilog

end;</source>
        <Parameter name="frame" type="Frame" usage="input"/>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="getTotalGridSize" id="2939a860-de0f-4326-b2eb-382ecaa22019">
        <source>getTotalGridSize() : Integer;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
23 July 2008	cnwer1	Initial creation

*/

vars
	
begin
	
	return gridSize * zoom;
epilog

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="keyDown" id="222962ed-15c9-47ce-b4ed-34670dcdf161">
        <controlMethod name="Form::keyDown"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>keyDown(keyCode: Integer io; shift: Integer) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
23 July 2008	cnwer1	Initial creation

*/

vars

begin
		inheritMethod(keyCode, shift);
	if keyCode = J_key_F6 then
		self.frame3.visible:=not self.frame3.visible;
		self.frame3.zOrder(1);
	endif;
epilog

end;</source>
        <Parameter name="keyCode" type="Integer" usage="io"/>
