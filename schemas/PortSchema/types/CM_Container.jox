    <JadeMethod name="canBoxBeReweighed" id="f6a10cef-45e7-46f2-bfd9-4f03f0235449">
        <source>canBoxBeReweighed(_terminal: CM_Terminal): Boolean;

// Created by cnwdvb1 on 11 October 2006

vars

	operatorTerminal : CM_OperatorTerminal;

begin

	// Not able to weigh this cargo type.
	if not self.myCargoType.isWeighable then
		return false;
	endif;
		
	// Already getting weighed.
	if self.hasToDoTasksWithTransClass(TRANS_TYPE_WEIGH, false) then	// 04/11/2010 cnwar2 #26198
	//if self.hasToDoTasksWithTransClass(CM_Weighed, false) then
		return false;
		// Already getting weighed.
	elseif self.weighStatus = WEIGH_STATUS_FORCED then
		return false;
	else
		if self.myOperator &lt;&gt; null and _terminal &lt;&gt; null then
			operatorTerminal := self.myOperator.allOperatorTerminals[_terminal];
		endif;

		// CCMS 1489
		if self.isTranshipItem then
			if operatorTerminal = null or operatorTerminal.weighTranships then
				return true;
			endif;
		elseif self.isExport then
			if self.contentsStatus = TI_CONTENTS_STATUS_FCL then
				if self.myOperator = null or (operatorTerminal &lt;&gt; null and operatorTerminal.weighExports) then
					return true;
				endif;
			elseif self.contentsStatus = TI_CONTENTS_STATUS_EMPTY then
				if self.myOperator = null or (operatorTerminal &lt;&gt; null and operatorTerminal.weighMTExports) then
					return true;
				endif;
			endif;
		elseif self.isImport then
			if self.contentsStatus = TI_CONTENTS_STATUS_FCL then
				if self.myOperator = null or (operatorTerminal &lt;&gt; null and operatorTerminal.weighImports) then
					return true;
				endif;
			elseif self.contentsStatus = TI_CONTENTS_STATUS_EMPTY then
				if self.myOperator = null or (operatorTerminal &lt;&gt; null and operatorTerminal.weighMTImports) then
					return true;
				endif;
			endif;
		endif;
	endif;

	return false;

end;</source>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="canHaveGeneratorAttached" id="71a1cac9-2fe3-4929-97fe-5235d5f31a5f">
        <source>canHaveGeneratorAttached(): Boolean;
/* ---------------------------------------------------------------------------
Created:	16 December 2008	by cnwvu1

Purpose:	
   
Change Date		Who		Reason

------------------------------------------------------------------------------*/
vars
	isoType	: CM_ISOType;

begin

	isoType := self.getISOTypeObject();
	
	if isoType = null then	//When loading EDI files, ISO Type can be null here, later a user will get an error message. PAR19852 June 2009
		return false;
	endif;
	
	return isoType.isReefer();	//More universal approach. Par 18790 April 2009.
	//return self.isReefer;		// not good in container Editting mode

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
