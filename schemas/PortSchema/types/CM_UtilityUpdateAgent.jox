    <JadeMethod name="utlUpdateThreshold" id="a480f698-1771-4c3e-b737-237a7cd22f21">
        <source>utlUpdateThreshold(pProxyThreshold:CM_MTThreshold; _passport : CM_Passport input);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
16 June 2011	cnwndl1	Initial creation

*/

vars
	realThreshold:CM_MTThreshold;
	expectedEdition:Integer;
	
begin

	self.initialiseActivity();

	pProxyThreshold.raiseExceptionIfNotProxy(method);

	app.setContinueCMExceptions(true);

	pProxyThreshold.pxyGetRealObjectAndEdition(realThreshold, expectedEdition);
	
	if realThreshold = null then	
		app.raiseCMException1(ProxyMgrCannotLocateReal, CM_MTThreshold.name, null, null);
		return;
	endif;

	app.myValUA.valThreshold(realThreshold, pProxyThreshold);
	
	if (not self.checkValidationWithPassport(_passport)) then
		return;
	endif;


	app.setContinueCMExceptions(false);

	exclusiveLock(realThreshold);

	if _passport.noErrors and realThreshold.edition &lt;&gt; expectedEdition then
		app.raiseCMException1(ObjectUpdatedByAnotherUserSave, 'SealType', null, null);
		return;
	endif;
	
	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realThreshold, true);
	endif;
	
	if _passport.noErrors then
		realThreshold.setForUpdate(pProxyThreshold);
	endif;

	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realThreshold, false);
	endif;

epilog
	
end;</source>
        <Parameter name="pProxyThreshold" type="CM_MTThreshold"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
