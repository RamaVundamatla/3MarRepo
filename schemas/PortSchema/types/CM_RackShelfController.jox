epilog

end;</source>
        <Parameter name="_maxCapacity" type="Integer"/>
        <Parameter name="_maxWeight" type="Real"/>
        <Parameter name="_defaultCapacity" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setHazardLocationsForMode" id="1536ff23-b8c8-47ce-b3bc-98262831aa6d">
        <updating/>
        <source>setHazardLocationsForMode(_ti: CM_TrackedItem; _mode: Integer) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 July 2015	cnwndl1	Initial creation	Par 36660

*/

vars
	vertSpan,
	horzSpan,
	depthSpan			: Integer;
	notSameArea			: Boolean;
	lc					: CM_LocationsController;
	tiCol : CM_TISet;
	tmpStr : String;
begin
	if _ti = null or (not _ti.isHazardous) then
		return;
	endif;
	
	if _mode = REAL_MODE then
		lc := _ti.myPrimaryActualLocation;
		tmpStr := "actual";
	elseif _mode = PLANNING_MODE then
		lc := _ti.myPrimaryPlannedLocation;
		tmpStr := "planned";
	elseif _mode = QUEUE_MODE then
		lc := _ti.myPrimaryQueuedLocation;
		tmpStr := "queued";
	endif;

	if self &lt;&gt; lc then
		app.raiseUnexpectedProgramError(class.name, method.name, 'self. does not equal the TIs primary ' &amp; tmpStr &amp; ' location (' &amp; self.String &amp; ')');
		return;
	endif;
	
	_ti.getLargestHazardArea(self.getHazardSegregationRuleType(), vertSpan, horzSpan, depthSpan, notSameArea);
	
	if notSameArea then
		if _mode = REAL_MODE then
			if (not self.myLocation.allHazardousTIs.includes(_ti)) then
				self.myLocation.allHazardousTIs.add(_ti);
			endif;		
		elseif _mode = QUEUE_MODE then
			if (not self.myLocation.allHazardousTIsQueued.includes(_ti)) then
				self.myLocation.allHazardousTIsQueued.add(_ti);
			endif;		
		elseif _mode = PLANNING_MODE then
			if (not self.myLocation.allHazardousTIsPlanned.includes(_ti)) then
				self.myLocation.allHazardousTIsPlanned.add(_ti);
			endif;		
		endif;
	endif;
	
epilog

end;


</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_mode" type="Integer"/>
    </JadeMethod>
