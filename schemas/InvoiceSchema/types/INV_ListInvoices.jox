    <JadeMethod name="doOpenEventScheduleSelector" id="18c88e48-d739-4a13-8533-b2f97b8a8d13">
        <source>doOpenEventScheduleSelector() protected;
//--------------------------------------------------
// Created:	11 August 2005 By: cnwgd1
//--------------------------------------------------
vars

	attachFrm 		: CMUI_EventScheduleSelector;
	sender			: String;
	allSchedules	: CM_AutoSchedulesByStartTsDict;
	schedule		: CM_AutoSchedule;
	strArray		: StringArray;
begin

	app.mousePointer := MousePointer_Default;
				
	attachFrm := app.loadForm(CMUI_EventScheduleSelector, self.myAssistant.class, false, false, false, self.myTerminal, null).CMUI_EventScheduleSelector;

	if attachFrm = null then
		return;
	endif;
	
	create allSchedules transient;
	if self.myCurrentInvoice = null then
//		app.msgBox(app.getErrorString(PleaseSelectAVoyage) ,app.getErrorString(PleaseSelectAVoyage), MsgBox_OK_Only + MsgBox_Information_Icon);
		app.msgBox(app.getErrorString(INV_Please_Select_An_Invoice) ,app.getErrorString(Problem), MsgBox_OK_Only + MsgBox_Information_Icon);  // ### JIRA 35469 04AUG2025 NAVAB1
		return;
	endif;
	
	attachFrm.setupSelector(EventDataInvoicing, allSchedules,app.getErrorString2(EventScheduleCaption, "Invoice", self.myCurrentInvoice.sequenceNum.String), self.myCurrentInvoice, null);
	
	attachFrm.showModal;

	app.mousePointer := MousePointer_HourGlass;
	foreach schedule in allSchedules do
		app.runEventScheduleInvoice(schedule, self.myCurrentInvoice, null);
	endforeach;
	return;
	
epilog
	if attachFrm &lt;&gt; null then
		delete attachFrm;
	endif;
	delete allSchedules;
	app.mousePointer := MousePointer_Default;
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doPaginatedNoteAdd" id="c5236248-b137-4240-b6db-30b568fafce6">
