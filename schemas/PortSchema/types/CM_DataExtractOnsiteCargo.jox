    <JadeMethod name="initDataExtractFields_GCVoy" id="3f6c179d-c9f8-4fff-b188-38836474c853">
        <source>initDataExtractFields_GCVoy(_fields : CM_DataExtractFieldSet input);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
13 May 2011	cnwkpd1	PAR #27436 - CCMS DCT 2073 - Product Transition Services
26 May 2011 cnwdz2  PAR #27598 Reviewed.
*/

vars
	fieldName		: String;
	
begin
	fieldName := "billOfLading";
	self.initDataExtractField(_fields, CM_TrackedItem.name, "billOfLading", fieldName, STRING, "Bill Of Lading", "Bill of Lading or Docket Number this cargo item is assigned to", STRING, "String field of max length 20 characters");

	//fieldName := "purchaseOrder";
	//self.initDataExtractField(_fields, CM_TrackedItem.name, "purchaseOrder", fieldName, STRING, "Purchase Order", "**** fill in with field description ****", STRING, "**** fill in with possible values description ****");

