    <JadeMethod name="jssGetServerLocaleInfo" id="72d1b5cd-ebe5-4048-9f46-5550d491d395">
        <executionLocation>server</executionLocation>
        <source>jssGetServerLocaleInfo(pTheLocaleInfo:LocaleFullInfo io) serverExecution;
// -----------------------------------------------------------------------------
// Created:		24 December 2001 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//
// -----------------------------------------------------------------------------
begin
	pTheLocaleInfo.jssCopyInfo(app.currentLocaleInfo);
end;</source>
        <Parameter name="pTheLocaleInfo" type="LocaleFullInfo" usage="io"/>
    </JadeMethod>
    <JadeMethod name="jssInitialize" id="5a7fc633-37c1-4795-b77a-14b2d05d16dc">
        <updating/>
        <source>jssInitialize() updating;
// --------------------------------------------------------------------------------
// Created:		05 September 2002 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	theRoot		: JSSRoot;
	
begin
	app.cnActivateKarmaControl(Cn_Fat_Client, null, null);
	
	theRoot	:=	JSSRoot.firstInstance();
	
	if theRoot = null then
		beginTransaction;
		create theRoot;
		commitTransaction;
	endif;
	
	self.jssMyRoot	:=	theRoot;
end;</source>
    </JadeMethod>
    <JadeMethod name="jssInitializeDictionary" id="76aeeec9-3b4c-4715-ae04-0dfeb55c9dff">
        <updating/>
        <source>jssInitializeDictionary() updating;
// --------------------------------------------------------------------------------
// Created:		05 September 2002 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	theDictionary	: JSSWordDictionary;
	theDictionaryTA	: JSSWordDictionaryAgent;
	
begin
	self.jssInitialize();
	
	foreach theDictionary in self.jssMyRoot.allDictionaries do
		break;
	endforeach;
	
	if theDictionary = null then
		create theDictionaryTA transient;
		theDictionaryTA.trxCreateDictionary(self.jssMyRoot, JSSWordDictionary.DEFAULT_NAME, theDictionary);
	endif;
epilog
	delete theDictionaryTA;
end;</source>
    </JadeMethod>
    <JadeMethod name="jssNotImplemented" id="57972b3c-bfd8-4f58-9371-5461c5e0f499">
        <source>jssNotImplemented();
// --------------------------------------------------------------------------------
// Created:		11 February 2001 by cnwdad1
//
// Purpose:		Displays a dialog informing the User that the function they just
//				tried is not yet implemented.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 22/04/2002	cnwdad1		Changed to fetch the second element of the call stack,
//							not the first.
// --------------------------------------------------------------------------------
vars
	theCallStack:ProcessStackArray;
	
begin
	create theCallStack transient;
	self.jssGetPreviousMethods(theCallStack);
	
	app.msgBox(	"Sorry, this functionality has not yet been implemented.",
				theCallStack[2].MethodCallDesc.display,
				MsgBox_OK_Only + MsgBox_Information_Icon);
epilog
	delete theCallStack;
end;</source>
    </JadeMethod>
    <JadeMethod name="msgBox" id="736ccd71-6c81-4fd0-953a-bc70bed2b2ec">
        <source>msgBox(msg: String; title: String; flags: Integer): Integer;
// --------------------------------------------------------------------------------
// Created:		30 January 2000 by cnwndl1
//
// Purpose:		Re-implementation of app.msgBox to allow auto-close by a timer.
//
//				If the 'flags' parameter value is positive, then the normal
//				app.msgBox will be presented.
//
//				If the 'flags' value is negative, then the JSSMsgBoxForm will be
//				presented with the normal message and title, but just an OK button.
//				The JSSMsgBoxForm will then wait until either the OK button is
//				depressed, or until the timer limit is reached, at which time the
//				dialog form will close.  The timer period is determined by the flags
//				parameter's (absolute) value.
//
// Parameters:	Refer to the "msgBox" method in the JADE Online Help.
//
// Returns:		Refer to the "msgBox" method in the JADE Online Help.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	theMessageForm	: JSSMsgBoxForm;
	returnValue		: Integer;
	
begin
	if flags &lt; 0 then
		create theMessageForm;
		theMessageForm.aCloseSeconds	:=	flags.abs();
		theMessageForm.caption			:=	title;
	    theMessageForm.aDialogMessage	:=	msg;
		//theMessageForm.centreWindow;
		theMessageForm.showModal;
		returnValue						:=	1; // 1 = Ok button response.
	else
		returnValue	:=	inheritMethod(msg, title, flags);
	endif;		

	return returnValue;
end;</source>
        <Parameter name="msg" type="String"/>
        <Parameter name="title" type="String"/>
        <Parameter name="flags" type="Integer"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
</Class>
