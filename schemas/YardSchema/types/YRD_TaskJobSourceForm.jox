// -----------------------------------------------------------------------------
// Created:		05 August 2009 by consw1
//
// Purpose:		Restore initial proxy values and exit form.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//
// -----------------------------------------------------------------------------

vars
	
begin
	self.myProxySource.setProxy( self.initialCargoType, self.initialTiTextList );
	
	self.myProxySource.setProxyCollections(	self.initialBookings,
											self.initialBulkReleases,
