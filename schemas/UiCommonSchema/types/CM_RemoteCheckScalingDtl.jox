<Class name="CM_RemoteCheckScalingDtl">
    <JadeMethod name="loadRemoteTable" id="749fea77-e9dc-4d29-8b63-0f5d93688911">
        <updating/>
        <source>loadRemoteTable(_table: CM_EntryTable io) updating;

// cnwdvb1 07 April 2003 

vars

	extra	: CM_RemoteDataExtra;

begin

	inheritMethod(_table);
	_table.setColumnHeadings('Item', 'Value');
	self.addRemoteRow(_table, 'Scaling Time', self.scalingTime, null);
	foreach extra in self.allRemoteDataExtra do
		self.addRemoteRow(_table, 'Check Scaled Item ' &amp; extra.CM_RemoteCheckScalingExtra.id, Click, extra);
	endforeach;
	

end;</source>
        <Parameter name="_table" type="CM_EntryTable" usage="io"/>
    </JadeMethod>
</Class>
