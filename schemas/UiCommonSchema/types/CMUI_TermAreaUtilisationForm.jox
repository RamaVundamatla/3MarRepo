    <JadeMethod name="doQuery" id="545ab319-0984-4409-8046-bd5dbe7fa630">
        <updating/>
        <source>doQuery() updating;
// ---------------------------------------------------------------------------
// Created:		10 November 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//26 Feb 2015  cnwma1 PAR # 33352 Space Utilisation functionality for Block Stacks
// ---------------------------------------------------------------------------
vars
	aTI : CM_TrackedItem;
begin
	if self.lstTermArea.allSelectedObjects.isEmpty() then
		app.msgBox( app.getErrorString(YoMustSelectATerminalArea), app.getErrorString(Terminal_area_utilisatio), MsgBox_Exclamation_Mark_Icon);
		self.fldQuery.topSheet := shtQuery1;
		return;
	endif;

	app.mousePointer := Window.MousePointer_HourGlass;
	
	self.createMonitor();
	
	// ### DO QUERY
	self.setQueryAgent();
	self.myQueryAgent.doQuery();
	
	self.displaySpaceTable( false );
	
	self.frmQuery.visible := (self.tblData.rows = self.tblData.fixedRows); 
	app.mousePointer := Window.MousePointer_Default;
	
epilog

	self.deleteMonitor();
	
end;</source>
