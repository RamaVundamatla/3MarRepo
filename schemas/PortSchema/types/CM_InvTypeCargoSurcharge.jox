    <JadeMethod name="setForUpdate" id="1d22dafb-3f48-4c5f-8573-fe117afaa9c1">
        <updating/>
        <source>setForUpdate( _proxy : CM_InvTypeCargoSurcharge ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 April 2018	jlgndl1	Initial creation	TFS 37822

*/

begin
	self.myCargoSurchargeInvLineType	:= _proxy.myCargoSurchargeInvLineType;
	self.surchargeRate					:= _proxy.surchargeRate;
	self.myCargoType					:= _proxy.myCargoType;
	self.mySubCargoType					:= _proxy.mySubCargoType;
	self.myCommodity					:= _proxy.myCommodity;
	
	self.allSelectedInvLineTypes.clear();
	if _proxy.allSelectedInvLineTypes &lt;&gt; null and not _proxy.allSelectedInvLineTypes.isEmpty then
		_proxy.allSelectedInvLineTypes.copy( self.allSelectedInvLineTypes );
	endif;
	
	self.mySurchargesAndExemptions		:= _proxy.mySurchargesAndExemptions;
	
end;</source>
        <Parameter name="_proxy" type="CM_InvTypeCargoSurcharge"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="1cd78acf-16dd-45be-973c-58e1e6caf31d">
        <updating/>
        <source>setProxy(	_cargoType					: CM_CargoType;
			_mySurAndExempt				: CM_InvoiceTypeSurchargeExempt;
			_mySurInvLineType			: CM_InvoiceLineDesc;
			_surchargeRate				: Decimal;
			_cargoSubType				: CM_Product;
			_commodity					: CM_Commodity;
			_allSelectedInvLineDescs	: CM_InvoiceLineDescSet
			) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 April 2018	jlgndl1	Initial creation	37822

*/

begin
	self.myCargoType					:= _cargoType;
	self.myCargoSurchargeInvLineType	:= _mySurInvLineType;
	self.surchargeRate					:= _surchargeRate;
	self.mySubCargoType					:= _cargoSubType;
	self.myCommodity					:= _commodity;
	
	self.allSelectedInvLineTypes.clear();
	if _allSelectedInvLineDescs &lt;&gt; null and not _allSelectedInvLineDescs.isEmpty then
		_allSelectedInvLineDescs.copy( self.allSelectedInvLineTypes );
	endif;
	
	self.mySurchargesAndExemptions		:= _mySurAndExempt;
	
end;</source>
        <Parameter name="_cargoType" type="CM_CargoType"/>
        <Parameter name="_mySurAndExempt" type="CM_InvoiceTypeSurchargeExempt"/>
        <Parameter name="_mySurInvLineType" type="CM_InvoiceLineDesc"/>
        <Parameter name="_surchargeRate" type="Decimal"/>
        <Parameter name="_cargoSubType" type="CM_Product"/>
        <Parameter name="_commodity" type="CM_Commodity"/>
        <Parameter name="_allSelectedInvLineDescs" type="CM_InvoiceLineDescSet"/>
    </JadeMethod>
