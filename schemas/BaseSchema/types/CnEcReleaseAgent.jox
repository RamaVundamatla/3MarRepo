    <DbClassMap file="baserel"/>
    <JadeMethod name="trxHistoryDetailCreate" id="0e9894d1-af9b-404b-a57d-a4bfce248b21">
        <updating/>
        <source>trxHistoryDetailCreate(	pTimestamp:TimeStamp;
						pText:String;
						pMasterObj:CnEcReleaseHistoryMaster;
						pHistoryDetailObj:CnEcReleaseHistoryDetail output):String updating;
// --------------------------------------------------------------------------------
// Created:		03 June 2000 by cnwdad2
//
// Purpose:		Transaction method to create a Release History Detail.
//
// Parameters:	The properties of the object to be created.
//              The newly created object is returned in the output parameter.
//
// Returns:		Null if the transaction is successful, otherwise an error message.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	errorMessage	: String;

begin
	// Always initialize the activity first.
	self.agentInitializeActivity();

	// Arm our base exception handlers
	on Exception do self.agentExceptionHandler(exception);
	on LockException do self.agentLockExceptionHandler(exception);

	errorMessage	:=	valHistoryDetailCreate(pTimestamp, pText);

	if errorMessage &lt;&gt; null then
		return errorMessage;
	endif;

	// Start the transaction.
	beginTransaction;

	// Perform the operation.
	pMasterObj.createHistoryDetail(pTimestamp, pText);

	// If the "create" raises an exception, our handler will resume to here.
	if self.lastError = null then
		// No errors, so commit.
		commitTransaction;
	else
		// We got an error so abort the transaction. Although TransactionAgent
		// exception handlers abort the transaction before resuming, we do so
		// here as well for completeness and symmetry with the beginTransaction.
		// An abortTransaction when not in transaction state does nothing.
		abortTransaction;
	endif;
epilog
	// Always return the error code to the caller (which will be zero if no errors)
	return self.lastError;
end;</source>
        <Parameter name="pTimestamp" type="TimeStamp"/>
        <Parameter name="pText" type="String"/>
        <Parameter name="pMasterObj" type="CnEcReleaseHistoryMaster"/>
        <Parameter name="pHistoryDetailObj" type="CnEcReleaseHistoryDetail" usage="output"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="trxHistoryDetailCreateMultiple" id="58ba7d10-0a5f-4a03-8360-6152704f941a">
