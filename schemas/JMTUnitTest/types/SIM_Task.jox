    <JadeMethod name="getNextMachineFirstTask" id="8d96bee9-a80d-48bb-8227-67a5bf98c481">
        <source>getNextMachineFirstTask(): SIM_Task;

vars
	nextTask: SIM_Task;
begin
	
	nextTask := self.myNextTask;
	while nextTask &lt;&gt; null do
		if nextTask.getMachine &lt;&gt; self.getMachine then
			break;
		endif;
		nextTask := nextTask.myNextTask;
	endwhile;
	return nextTask;
	
epilog

end;</source>
        <ReturnType type="SIM_Task"/>
    </JadeMethod>
    <JadeMethod name="getNextTaskId" id="52c9413d-a916-4d43-ba9e-de562b3f5c02">
        <source>getNextTaskId() : String;
vars

begin
	if self.myNextTask &lt;&gt; null then
		return self.myNextTask.getId.String;
	endif;
	
	return "";
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
