    <JadeMethod name="setJob" id="ddc201e6-4f16-476d-b86e-c2da705585c8">
        <updating/>
        <source>setJob(_job : CM_Job) updating;
/*
 ------------------------------------------------------------------------
Created:			26 August 2002 by cnwdwq1
Purpose:			
Parameters:		None
Returns:			Nothing
Changed On		Changed By		Reason
21 Sep 2020 	cnwma1 			ChangeRequest 49906: MTN - Ops View External Webservice
---------------------------------------------------------------------------
*/
vars

begin
	self.job := _job;
 
 	/* // ### TFS 50669 24AUG2021 NAVAB1 we must send a CREATE for the creation of the WLE, followed by UPDATE. We cannot send UPDATE all the time.

	//21.09.2020 cnwma1 TFS #49906
	if _job &lt;&gt; null and _job.isOpsViewData() then  // ### TFS 50669 24AUG2021 NAVAB1  _job.isVoyageJob() then
		if app.myPassport.isOpsViewEnabled(_job.getMyTerminal()) then
			self.createOpsViewEWSActivity(BGP_OpsViewWSRequest.OPS_ACTION_UPDATE,BGP_OpsViewWSRequest.OPS_TYPE_WLE,self);
		endif;
	endif;
	//21.09.2020 cnwma1 TFS #49906
		*/
end;</source>
        <Parameter name="_job" type="CM_Job"/>
    </JadeMethod>
    <JadeMethod name="setLocations" id="f0be7343-d04c-4c0d-b2e4-746472c63d61">
        <updating/>
        <source>setLocations(_source, _target : String) updating;
// ---------------------------------------------------------------------------
// Created:		May 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

begin
	//epr 23/5/13 working on CCMS 2274 noticed for discharge jobs when wle unloaded on machine wle is complete and
	// wle location target will be the machine then when it is set in yard the wle location target never gets updated
	// because of return if wle complete so changed to only return if wle complete and passed in values are null
	if self.status = WLE_COMPLETED and (_source = null or _target = null) then
		return;
	endif;
	self.locationSource := _source;
	self.locationTarget := _target;
	if self.job &lt;&gt; null
// TFS 4859	and self.job.isVoyageJob() then // PAR 21740
	and self.job.isVoyageTypeJob() then // PAR 21740 TFS 4859
		if self.job.getMyTerminal &lt;&gt; null then	//19 Jun 2019	NDL	TFS 42876
			self.job.causeTerminalEvent(CM_Job.Event_Mode_Update);
			app.myEventManager.createSingleObjInfoNoteEvt(self, self.job.getMyTerminal.getTerminalEvent(WLE_Update_Event), self); //+ cnwmd1, Par 24257 
		endif;
	endif;
end;</source>
        <Parameter name="_source" type="String"/>
        <Parameter name="_target" type="String"/>
    </JadeMethod>
    <JadeMethod name="setMoveControllerAllOtherTIs" id="44555ad4-1d0d-4ad2-9e64-18693f876671">
        <source>setMoveControllerAllOtherTIs(_moveController : CMIF_MoveController input);
//--------------------------------------------------------------
//Created: 18 April 2002 By: cnwgd1
//--------------------------------------------------------------
//Glenys - need some code here along the lines of (BUT - this also needs to
//be called from where-ever the move to complete wle can be done.
//Can I leave you to find and put an appropriate method on the wle to
//do this move and then call it from the appropriate places).
vars
	tmpTI 			: CM_TrackedItem;
	cargoType		: Integer;
	lc				: CM_LocationsController;
	ti				: CM_TrackedItem;
	coll			: Collection;
	obj				: Any;
begin
	if _moveController = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Null move controller, contact developer');	
		return;		//error
	endif;
	
	// PAR 9847. not always a brand new moveController here - so clean it out first
	_moveController.allOtherTrackedItems.clear;
	
	if self.myBOL &lt;&gt; null then
		coll := self.myBOL.getTICollectionForTerminal(self.myRequest.myTerminal);
		if self.myBOL.isKindOf(CM_BOLIn) and (self.myBOL.bolType = BOLType_GeneralDocket or self.myBOL.bolType = BOLType_GeneralBillOfLading) then
			//just get the TIs with the same cargoType/location as the WLE - not the bol.allTrackedItems
			ti := self.myTrackedItem;
			cargoType := ti.cargoType;
			lc := ti.getPrimaryLocation(PLANNING_MODE);
			
			foreach obj in coll do
				tmpTI := obj.CM_TrackedItem;
				if self.job.isTrackedItemOnTransport(tmpTI) then
					if tmpTI &lt;&gt; ti and 
						tmpTI.cargoType = ti.cargoType and 
						tmpTI.getPrimaryLocation(PLANNING_MODE) = lc then
						_moveController.allOtherTrackedItems.add(tmpTI);
					endif;
				endif;
			endforeach;
		else
			foreach obj in coll do
				tmpTI := obj.CM_TrackedItem;
				if self.job.isTrackedItemOnTransport(tmpTI) then
					if tmpTI &lt;&gt; self.myTrackedItem then
						_moveController.allOtherTrackedItems.add(tmpTI);
					endif;
				endif;
			endforeach;
		endif;
	endif;
end;</source>
        <Parameter name="_moveController" type="CMIF_MoveController" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setMyDirectDeliveryParentWLE" id="995c1df4-c4b4-4607-97b3-39e969993725">
        <updating/>
        <source>setMyDirectDeliveryParentWLE(_wle : CM_WorkListEntry) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 18/10/2021	navdap1		Initial creation TFS 51935 SAL Direct Loading Partial Prenoted Cargo from Truck to Vessel
//
vars

begin
	self.myDirectDeliveryParentWLE := _wle;
epilog

end;</source>
        <Parameter name="_wle" type="CM_WorkListEntry"/>
    </JadeMethod>
    <JadeMethod name="setMyTrackedItem" id="5b11e71b-6dd0-49c6-823d-1819e00a48f3">
        <updating/>
        <source>setMyTrackedItem(_ti : CM_TrackedItem) updating;
/*
------------------------------------------------------------------------
Created:			24 March 2003 by cnwdwq1
Purpose:			Dave Q's code
Parameters:		
Returns:			
Changed On		Changed By		Reason
------------	------------	-----------------------------------------
15/12/2010		cnwdap1			PAR #26426 CCMS MES 1102 if the WLE has a TBA TI, delete it
22/01/2014		cnwjre1			Par 33080 only do the TBA TI delete if there is a new cargo item to replace it
17/03/2025 		navma1 			MTN-34120 MTN | Dead Lock (1081) on CM_OfflineFutureActorParentDct
------------------------------------------------------------------------
*/
vars
	wle 			 : CM_WorkListEntry;
	chassisLC		 : CM_TILCController;
	unknownChassisLC : CM_TILCRow;
	chassis			 : CM_TILC;
	hasChassis 		 : Boolean;
	wleID			 : String;
	targetParent 	 : CM_TrackedItem;
	rrpTI			 : CM_TrackedItem;

begin
	// PAR #26426 check if we have a TBA ti - if so, get rid of it, as _ti is now replacing it
	// 33080 Jan 2014 don't delete the TBA if ti parameter is null, as this is just removing the current TBA from the WLE
	//	and not replacing it with an actual real cargo item.  Deleting it here for a remove gets a 1072 later in the code.
	if  _ti &lt;&gt; null and self.myTrackedItem &lt;&gt; null and self.myTrackedItem.isRRPforVoyage then //23 Mar 2020	NDL	TFS 47004
		rrpTI := self.myTrackedItem;
		// TFS 3190 - Assign release to a hold. Now it is complete, unplan the TBA so it can be deleted.
		if self.myRequest.isHoldRequest() and self.myRequest.CM_HoldRequest.myBulkReleaseReserveDetail &lt;&gt; null then 
			if rrpTI.isPlanned(PLANNING_MODE) then
				rrpTI.doForcedUnplan(app.myPassport);
			endif;
			rrpTI.erase(NORMAL_ERASE);
		else	
			rrpTI.erase(NORMAL_ERASE);	
		endif;
	endif;
	
	// PAR #26426 end
	self.myTrackedItem := _ti;
	
	if _ti &lt;&gt; null then
		self.setLocations(_ti.locationId,self.locationTarget);
		
		//assigning the chassis to be released
		//epr par 33302 15/1/14
		if _ti.isKindOf(CM_TILC) and self.isChassisToRelease   then				//17.03.2025 navma1 #MTN-34120
			foreach wle in self.job.workListEntries where wle &lt;&gt; self and wle.isReleaseTypeRequest do
				//epr par 33333
				if wle.status = WLE_COMPLETED then
					continue;
				endif;
				chassisLC:=_ti.CM_TILC.getNextFreeLC();
				//epr par 33333
				if chassisLC = null then
					//raise error
					wleID:=null;
					if wle.myTrackedItem &lt;&gt; null then
						wleID:=wle.myTrackedItem.id;
						//epr par 33718 18/3/14
						if  _ti.CM_TILC.hasTIonChassis(wle.myTrackedItem) then
							continue;
						endif;
					endif;
					app.raiseCMException2(Assign_Trailer_No_Space,_ti.id,wleID,null,null);
					return;
				endif;
				wle.setNewLocationTarget(chassisLC);
			endforeach;
		endif;	
	else	
		self.setLocations(null,self.locationTarget);	
			//epr par 33302 15/1/14
		if  self.isChassisToRelease then		
			unknownChassisLC:=self.job.CM_RoadJob.myVehicle.myUnknownChassis;
			foreach wle in self.job.workListEntries where wle &lt;&gt; self and wle.isReleaseTypeRequest do			
				wle.setNewLocationTarget(unknownChassisLC);
			endforeach;
		endif;		
	endif;
	
	//epr par 33302 15/1/14
	if self.isReleaseToChassis then
		chassis:=self.job.CM_RoadJob.getChassis(false,hasChassis);
		if chassis &lt;&gt; null then
			chassisLC:=chassis.getNextFreeLC();
			if chassisLC = null then
				chassisLC:= chassis.allLCs.first;
			endif;
			self.setNewLocationTarget(chassisLC);
		else
			unknownChassisLC:=self.job.CM_RoadJob.myVehicle.myUnknownChassis;
			self.setNewLocationTarget(unknownChassisLC);
		endif;
	endif;

	if self.isReleaseToPack then
		targetParent:=self.getTargetTIForPack();
		if targetParent &lt;&gt; null then
			self.locationTarget:=targetParent.id;
		endif;
		
	endif;
	
end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="setMyWorkOrderWLE" id="0bb192ae-5ea0-4349-8e60-7d5a351daeff">
        <updating/>
        <source>setMyWorkOrderWLE(_workOrderWLE: CM_WOWLE) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 Sep 2023	navnk30	Bug 60531: MTN - Deleting Road Work list entry delete work order wles

*/

vars

begin
	self.myWorkOrderWLE := _workOrderWLE;
epilog

end;</source>
        <Parameter name="_workOrderWLE" type="CM_WOWLE"/>
    </JadeMethod>
    <JadeMethod name="setNewLocationTarget" id="f82203a5-b64b-47ff-b1ce-cdb21489f23a">
        <updating/>
        <source>setNewLocationTarget(_targetLocation : CM_LocationsController) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
16 November 2011	cnwer1	Initial creation CCMS MES 1033

*/

vars
	queuedFutureMove	: CM_FutureMoveQueued;
	plannedFutureMove	: CM_FutureMovePlanned;
	allToLCs			: CM_LCArray;
	rtQEntry			: CM_RTQueueEntry;
	moveController 	: CMIF_MoveController ;
begin
	//epr par 34634 3/9/14 can set the target to null
	if _targetLocation &lt;&gt; null then
		self.locationTarget :=_targetLocation.getFullIdForTI(true);
	else
		self.locationTarget:=null;
	endif;
	
	
	if self.myFutureMove &lt;&gt; null then
		if self.myFutureMove.isKindOf(CM_FutureMoveQueued) then
			queuedFutureMove:=self.myFutureMove.CM_FutureMoveQueued;
			plannedFutureMove:=queuedFutureMove.myFutureMovePlanned;
		else
			plannedFutureMove:=self.myFutureMove.CM_FutureMovePlanned;
		endif;
	endif;
	
	create allToLCs transient;
	if _targetLocation &lt;&gt; null then
		allToLCs.add(_targetLocation);
	endif;	
	if plannedFutureMove &lt;&gt; null then
		plannedFutureMove.setLocations(allToLCs);
		plannedFutureMove.myTrackedItem.refreshMyFutureLocations(PLANNING_MODE,null);
	endif;
	
	if queuedFutureMove &lt;&gt; null then
		queuedFutureMove.setLocations(allToLCs);
		queuedFutureMove.myTrackedItem.refreshMyFutureLocations(QUEUE_MODE,null);
	endif;
	
	rtQEntry:=self.allRTQueueEntries.last;
	if rtQEntry &lt;&gt; null and rtQEntry.allTasks.size &gt; 0 then
		
			create moveController transient;
			moveController.setMyToPrimaryLocation(_targetLocation);
			//epr 33302 15/1/14
			if self.myTrackedItem &lt;&gt; null then //cnwrd1 par 30819
				moveController.setMyTrackedItem(self.myTrackedItem);
			endif;
			moveController.setMoveMode( QUEUE_MODE);
			moveController.setMyPassport(app.myPassport);
		
		rtQEntry.allTasks.last.changeTargetLocation(moveController,false);
	endif;
	
epilog
	delete allToLCs;
	delete moveController;
end;</source>
        <Parameter name="_targetLocation" type="CM_LocationsController"/>
    </JadeMethod>
