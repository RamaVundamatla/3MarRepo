  hmsMove : HMS_Movement;
  kinerja : CMIF_Kinerja;

begin
	voy := "4480.1906".asOid().CM_Voyage; //KLIQ1906 in PELBJMT
	
	if voy &lt;&gt; null then
		hmsVoy := voy.myHMSVoyageData;
		if hmsVoy &lt;&gt; null then
			create kinerja transient;
			kinerja.setMyVoyage(voy);
			foreach hmsMove in hmsVoy.allVoyageMovements do
				write hmsMove.moveType;
