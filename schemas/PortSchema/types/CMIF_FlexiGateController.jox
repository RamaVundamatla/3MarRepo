    <JadeMethod name="setFromExistingPrenote" id="a25de009-1099-43c8-bf83-c6b115a988b7">
        <updating/>
        <source>setFromExistingPrenote( _preNote : CM_TrackedItem ) updating;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19/11/2014	cnwndl1	Initial creation	Par 35146
29/04/2015	cnwdap1	PAR #36094 CCMS SFW 1413 TFS 313 Cold Store Enhancements
03/05/2018 	JLGNS1	Bug 38457: DQM - Dry Bulk - ( Gate in and Merge )
02/10/2020  cnwma1  ChangeRequest 50112: ASPA - GCI Stevedores
26/05/2022	navak20	ChangeRequest 53204: EUP - GEN/REP/INB - Additional Cargo Field – Shipping Line - UI
18/08/2022	navak20	TFS ChangeRequest 54441: EUP - Additional Field - Country of Origin
02/10/2025	navdap1	MTN-36141 AAT | RotaBox Creation (EDI/API/Manual)
*/
vars

	obj : Object;
	sealTi : CM_SealTI;
	sealType : CM_SealType;
	hazard : CM_Hazard;
	invalidHazard : Boolean;
	cargoTypeObj : CM_CargoType;	// MTN-36141

begin

	self.id := _preNote.id;
	self.cargoType := _preNote.cargoType;
	self.myTerminal := _preNote.myTerminal;
	
	self.bookingNumber := _preNote.bookingReference;
	self.myBookingRefItem := _preNote.myBookingRefItem;
	
	
	self.myProduct := _preNote.myProduct;
	
	self.volumeTotal := _preNote.totalVolume;
	
	
	obj := _preNote.mySubTerminal;
	if obj &lt;&gt; null then
		self.subTerminalCode := obj.CM_SubTerminal.code;
	endif;

	obj := _preNote.getISOTypeObject;
	if obj &lt;&gt; null then
		self.isoTypeCode := obj.CM_ISOType.code;
	endif;

	obj := _preNote.getCommodityObject;
	if obj &lt;&gt; null then
		self.commodity := obj.CM_Commodity.code;
	endif;

	self.weightTotal := _preNote.totalWeight;
	if _preNote.isWeightCertified then
		self.isWeightCertified := true;
	endif;
	
	if _preNote.myCargoType.useTareCargoWeight then	//Bug 38457
		self.weightCargo := _preNote.weightCargo;	//Bug 38457
		self.weightTare  := _preNote.weightTare;	//Bug 38457
	endif;											//Bug 38457
	
	if _preNote.isKindOf(CM_TILC) then
		self.myChassisType 	:= _preNote.CM_TILC.myTILCType;
	elseif _preNote.isKindOf(CM_Generator) then
		self.myGeneratorType := _preNote.CM_Generator.myGeneratorType;
	endif;

	obj := _preNote.getImExStatusObject;
	if obj &lt;&gt; null then
		self.imexStatus := obj.CM_IMEXStatus.code;
	endif;
	
	self.voyageCode := _preNote.voyageCode;
	self.operatorCode := _preNote.operatorCode;
	self.destinationPort := _preNote.destinationPort;
	self.dischargePort 	:= _preNote.dischargePort;
	
	obj := _preNote.myTranshipToPort;
	if obj &lt;&gt; null then
		self.myTranshipToPort	:=	obj.CM_Port;
	endif;
	
	self.consignorCode 	:= _preNote.consignor;
	self.consigneeCode 	:= _preNote.consignee;
	self.stevedoreCode  := _preNote.stevedoreCodeRecieve;  //02.10.2020 cnwma1 TFS #50112
	
	self.length  := _preNote.length;					
	self.width   := _preNote.width;			
	self.height  := _preNote.height;					
	self.density := _preNote.density; // ### TFS 52193 22Nov2021 NAVPW1
	self.volume  := _preNote.totalVolume;

	self.description := _preNote.description;
	self.alternativeId := _preNote.alternativeId;
	self.mark := _preNote.mark;
	self.colour := _preNote.getColour;
	self.markNumber := _preNote.markNumber;
		
	foreach obj in _preNote.allSeals do
		sealTi := obj.CM_SealTI;
		sealType := app.getMyRoot.allSealTypes.getAtKey(sealTi.sealType);
		if sealType &lt;&gt; null then
			if not sealType.notAvailableForEntry then
				self.setSealNumberValueDirect( sealType,  sealTi.getSealValueAsString, null );
			endif;
		endif;
	endforeach;
	
	self.operatorExportReleaseNumber := _preNote.getOperatorExpReleaseNo();
	self.customEntryNumber := _preNote.customsEntryNumber;
	self.clientRef := _preNote.clientRef; 
	
	self.purchaseOrder := _preNote.purchaseOrder;	
	self.serviceOrder := _preNote.serviceOrder;
	self.directDelivery := _preNote.directDelivery;	
	self.availabilityGrade := _preNote.getAvailabilityGrade;
	self.remarks := _preNote.remarks;
	
	self.isOverDimensions := _preNote.isOverDimensions;
	
	on Exception do app.handleDeletedObject(exception, hazard, invalidHazard);
	foreach hazard in _preNote.allTIHazards do
		invalidHazard := false;
		hazard.edition();
		if invalidHazard then
			continue;
		endif;
		self.allTIHazards.add(hazard.CM_Hazard);
	endforeach;
	
	self.specialStow  := _preNote.specialStow;
	if _preNote.myShippingLine &lt;&gt; null then						// 26.05.2022 navak20 TFS 53204
		//self.shippingLineCode := _preNote.myShippingLine.code;	// 26.05.2022 navak20 TFS 53204
		self.shippingLineCode := _preNote.getShippingLineCode();	// 14.07.2022 navsrk20 53195
	endif;														// 26.05.2022 navak20 TFS 53204
	
	// 18.08.2022 navak20 TFS 54441
	if _preNote.myCountryOfOrigin &lt;&gt; null then
		self.countryOfOriginCode := _preNote.getCountryOfOriginCode();
	endif;
	// 18.08.2022 navak20 TFS 54441
	
	if not _preNote.allSpecialLifts.isEmpty then
		_preNote.allSpecialLifts.copy(self.allSpecialLifts);
	endif;
	
	foreach obj in _preNote.getAllStops do
		self.allStops.add(obj.CM_Stops.id);
	endforeach;
	
	foreach obj in _preNote.allToDoTasksToDo do
		self.allToDoTasks.add(obj.CM_ToDoTask.toDoTaskDesc);
	endforeach;
	
	self.freightForwarderCode := _preNote.freightForwarderCode;
	
	obj := _preNote.myCustomsAgent;
	if obj &lt;&gt; null then
		self.customsAgentCode := obj.CM_CustomsAgent.code;
	endif;
	self.billOfLading := _preNote.billOfLading;
	self.consignorVoyageCode := _preNote.consignorVoyageCode;
	self.eirNumber := _preNote.eirNumber;
	self.companyCode := _preNote.companyCode;
	
	self.allowableTimeOffPower := _preNote.getAllowableTimeOffPower;
	self.carriageTempF := _preNote.temperatureInFahrenheit;
	self.carriageTempC := _preNote.getTemperature;
	self.packTempF := _preNote.packTempF.Real;
	self.packTempC := _preNote.packTempC.Real;
	self.setCarbonDioxide( _preNote.getCarbonDioxide );
	self.setOxygen( _preNote.getOxygen );
	self.setHumidity( _preNote.getHumidity );
	self.ventilation := _preNote.getVentilation;
	self.packDate := _preNote.getPackDateLast.Date;
	self.packTime := _preNote.getPackDateLast.Time;
	self.coolingType := _preNote.getCoolingType;
	self.expiryDate := _preNote.getExpiryDate();			// PAR #36094
	self.isExternallyMonitored	:= _preNote.getExternalMonitoring(); // epr TFS 3581 15/3/17
	
	if _preNote.isCar then
		self.make := _preNote.CM_Car.make;
		self.model := _preNote.CM_Car.model;
		self.carType := _preNote.CM_Car.carType;
		self.year  := _preNote.CM_Car.year;			
		self.trackingNumber1 := _preNote.CM_Car.trackingNumber1;
		self.trackingNumber2 := _preNote.CM_Car.trackingNumber2;
		self.docsReceived.setDate( _preNote.CM_Car.docsReceived.Date );
		self.docsSent.setDate( _preNote.CM_Car.docsSent.Date );	
		self.docsCleared.setDate( _preNote.CM_Car.docsCleared.Date );	
		self.docsReturned.setDate( _preNote.CM_Car.docsReturned.Date );
		self.nbrDoors := _preNote.CM_Car.nbrDoors;	
		self.isNew := _preNote.CM_Car.isNew;
	endif;
	
	// MTN-36141 new attribute
	cargoTypeObj := _preNote.getCargoTypeForContents();
	if cargoTypeObj &lt;&gt; null then
		self.cargoTypeContents := cargoTypeObj.id;
	endif;
	
	self.tiEdition := _preNote.edition;

epilog

end;</source>
        <Parameter name="_preNote" type="CM_TrackedItem"/>
    </JadeMethod>
