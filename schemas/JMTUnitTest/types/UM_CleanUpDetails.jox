    <JadeMethod name="create" id="8ebd0dad-e832-4109-b501-7a8a7649d8c5">
        <updating/>
        <source>create() updating;

/*

Purpose:		

Date			Who		Reason
16 April 2015	cnwmh5	Initial creation

*/

vars

	root 					: UM_Root;

begin

	root := UM_Root.firstInstance;
	
	if root &lt;&gt; null then
		self.myRoot := root;
	endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="isCompact" id="9e7a3078-da2c-4922-b665-07efff504194">
        <condition/>
        <source>isCompact():Boolean condition;

/*

Purpose:		

Date			Who		Reason
16 April 2015	cnwmh5	Initial creation

*/


begin
	return self.isKindOf(UM_CleanUpDetailsCompact);
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="outputFormatted" id="6ef476d9-589a-4e43-9169-eb15f30d873a">
        <source>outputFormatted(_formatObject : Any; _dontFormat : Boolean) : String;

/*

Purpose:		

Date			Who		Reason
11/06/2015		cnwmh5	Initial creation

*/

vars

	rtnValue				: String;
	
begin

	rtnValue := null;
	if _formatObject.isKindOf(Integer) then
		if _formatObject.Integer &lt;&gt; 0 then
			rtnValue := _formatObject.Integer.asStringJMTWithOptionalCommas(true, true);
		endif;
	elseif _formatObject.isKindOf(Decimal) then
		if _formatObject.Decimal &lt;&gt; 0.00 then
			rtnValue := _formatObject.Decimal.asStringJMTWithPrecision(0, true);
		endif;
	endif;
	if _dontFormat then
		rtnValue := rtnValue.replaceString(",", "");
	endif;
	return rtnValue;

epilog

end;</source>
        <Parameter name="_formatObject" type="Any"/>
        <Parameter name="_dontFormat" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="timeTaken" id="c660f519-cc19-48fa-806a-7a7959060d9b">
        <source>timeTaken() : Time;

/*

Purpose:		Return the time taken

Date			Who		Reason
17/04/2015		cnwmh5	Initial creation

*/

vars

	posNeg						: Integer;
	numOfDays					: Integer;

begin

	return self.endTS.differenceAsTime(self.startTS, posNeg, numOfDays);

epilog

end;</source>
        <ReturnType type="Time"/>
    </JadeMethod>
    <JadeMethod name="updateDetails" id="24516f57-0368-411c-8624-26a63b3d5c4f">
        <updating/>
        <source>updateDetails(_startTS, _endTS: TimeStamp; _numberDone : Integer; _taskDescription, _details : String) updating;

/*

Purpose:		

Date			Who		Reason
02/06/2015		cnwmh5	Initial creation

*/

vars

begin

	self.startTS := _startTS;
	self.endTS := _endTS;
	
	self.details := _details;
	self.numberDone := _numberDone;
	self.taskDescription := _taskDescription;	

epilog

end;</source>
        <Parameter name="_startTS" type="TimeStamp"/>
        <Parameter name="_endTS" type="TimeStamp"/>
        <Parameter name="_numberDone" type="Integer"/>
        <Parameter name="_taskDescription" type="String"/>
        <Parameter name="_details" type="String"/>
    </JadeMethod>
</Class>
