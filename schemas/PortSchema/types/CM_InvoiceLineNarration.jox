    <ExplicitInverseRef name="myLocale" id="704d4676-fb9d-427b-b5eb-41011c424879">
        <transientToPersistentAllowed/>
        <updateMode>manual</updateMode>
        <embedded/>
        <type name="CM_Locale"/>
        <access>readonly</access>
        <Inverse name="CM_Locale::allInvoiceLineNarrations"/>
    </ExplicitInverseRef>
    <PrimAttribute name="narration" id="79522e5f-74e6-4789-aef9-5b0c1c4fd275">
