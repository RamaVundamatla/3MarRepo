Specifies that path and file name, or URL, as well as a number of attributes
such as size, positioning, margins and border size.

Note that specifying the HEIGHT and WIDTH speeds up loading, because a quick
placeholder will be drawn for the image, allowing the text to continue to be
loaded while the image is drawn.  Without these dimensions, the loading of
the text must wait for the image to be drawn and thereby determine where the
remaining text will go.</text>
    <DbClassMap file="basehtml"/>
    <PrimAttribute name="imageAlign" id="e9dfc3a1-c716-4dfd-91f5-632018365320">
        <length>31</length>
        <embedded/>
        <type name="String"/>
        <access>readonly</access>
        <text>Positions text at the TOP, MIDDLE or BOTTOM of the image, or positions the
image on the LEFT or RIGHT of the text.</text>
    </PrimAttribute>
    <PrimAttribute name="imageAlternativeText" id="040c8e63-2ec1-4b89-bec3-e127bf6b3d71">
        <type name="String"/>
        <text>Identifies alternative text that is displayed if the image cannot be displayed.</text>
    </PrimAttribute>
    <PrimAttribute name="imageBorderWidth" id="d31c6c6a-fd97-4dea-a5f7-de1c17e8001b">
        <embedded/>
        <type name="Integer"/>
        <text>Specifies that a border of this many pixels be drawn around the image.</text>
    </PrimAttribute>
    <PrimAttribute name="imageHSpace" id="d31d6279-4a8b-4f74-b34a-a4c5a2b9f3e3">
        <embedded/>
        <type name="Integer"/>
        <text>Specifies the amount of blank space on the left and right of the image.</text>
    </PrimAttribute>
    <PrimAttribute name="imageHeight" id="4af6a223-6599-496a-866e-b59723e7c662">
        <embedded/>
        <type name="Integer"/>
        <text>Specifies the height, in pixels, of the image.

Note that specifying the HEIGHT and WIDTH speeds up loading, because a quick
placeholder will be drawn for the image, allowing the text to continue to be
loaded while the image is drawn.  Without these dimensions, the loading of
the text must wait for the image to be drawn and thereby determine where the
remaining text will go.</text>
    </PrimAttribute>
    <PrimAttribute name="imageIsMap" id="0492e0cb-5908-4b0b-a2d4-da0cef1351b1">
        <embedded/>
        <type name="Boolean"/>
        <text>Indicates whether the image has an image map.</text>
    </PrimAttribute>
    <PrimAttribute name="imageSource" id="58769df7-042e-4e83-a63f-c7b24a2c6b85">
        <type name="String"/>
        <text>Identifies that path and file name, or URL, of the image.</text>
    </PrimAttribute>
    <PrimAttribute name="imageUseMap" id="5f0fbd16-b7bf-4e28-82dc-dbd29c37d24f">
        <type name="String"/>
        <text>Identifies that name of the image map that is to be used.</text>
    </PrimAttribute>
    <PrimAttribute name="imageVSpace" id="1727fa88-a32a-46e4-a74e-8b3829b8e3f5">
        <embedded/>
        <type name="Integer"/>
        <text>Specifies the amount of blank space on the top and bottom of the image.</text>
    </PrimAttribute>
    <PrimAttribute name="imageWidth" id="8b385a9f-cff2-493d-b7a7-c092e71a9680">
        <embedded/>
        <type name="Integer"/>
        <text>Specifies the width, in pixels, of the image.

Note that specifying the HEIGHT and WIDTH speeds up loading, because a quick
placeholder will be drawn for the image, allowing the text to continue to be
loaded while the image is drawn.  Without these dimensions, the loading of
the text must wait for the image to be drawn and thereby determine where the
remaining text will go.</text>
    </PrimAttribute>
    <JadeMethod name="buildTagBody" id="212ef0c7-8737-4a01-93e8-f5195f5175fb">
        <source>buildTagBody(): String protected;
// --------------------------------------------------------------------------------
// Created:		02 December 2001 by cnwdad1
//
// Purpose:		Refer to the CnEcHtmlTagObject implementation.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	htmlString	: String;

begin
	htmlString	:=	' SRC="' &amp; self.imageSource &amp; '"';

	if self.imageAlign &lt;&gt; null then
		htmlString	:=	htmlString &amp; ' ALIGN="' &amp; self.imageAlign &amp; '"';
	endif;

	if self.imageAlternativeText &lt;&gt; null then
		htmlString	:=	htmlString &amp; ' ALT="' &amp; self.imageAlternativeText &amp; '"';
	endif;

	if self.imageBorderWidth &lt;&gt; 0 then
		htmlString	:=	htmlString &amp; ' BORDER="' &amp; self.imageBorderWidth.String &amp; '"';
	endif;

	if self.imageHSpace &lt;&gt; 0 then
		htmlString	:=	htmlString &amp; ' HSPACE="' &amp; self.imageHSpace.String &amp; '"';
	endif;

	if self.imageIsMap then
		htmlString	:=	htmlString &amp; ' ISMAP';

		if self.imageUseMap &lt;&gt; null then
			htmlString	:=	htmlString &amp; ' USEMAP="' &amp; self.imageUseMap &amp; '"';
		endif;
	endif;

	if self.imageVSpace &lt;&gt; 0 then
		htmlString	:=	htmlString &amp; ' VSPACE="' &amp; self.imageVSpace.String &amp; '"';
	endif;

	if self.imageWidth &lt;&gt; 0 then
		htmlString	:=	htmlString &amp; ' WIDTH="' &amp; self.imageWidth.String &amp; '"';
	endif;
	
	htmlString	:=	htmlString &amp; inheritMethod();
	
	return htmlString;
end;</source>
        <access>protected</access>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getHtml" id="90a60409-dd44-454b-8243-9581d3bb173e">
        <source>getHtml(): String;
// --------------------------------------------------------------------------------
// Created:		01 May 2000 by cnwdad2
//
// Purpose:		Refer to the CnEcHtmlTagObject implementation.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return '&lt;IMG' &amp; self.buildTagBody() &amp; '&gt;' &amp; CrLf;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="isValidAlign" id="885e4424-69ba-421c-86d9-7ac67d84ef78">
        <source>isValidAlign(pAlign:String):Boolean protected;
// --------------------------------------------------------------------------------
// Created:		01 May 2000 by cnwdad2
//
// Purpose:		Validates the receiver's alignment setting.
//
// Parameters:	pAlign - The receiver's alignment setting.
//
// Returns:		True if the alignment setting is valid, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if pAlign = self.ALIGN_TOP
	or pAlign = self.ALIGN_MIDDLE
	or pAlign = self.ALIGN_BOTTOM
	or pAlign = self.ALIGN_LEFT
	or pAlign = self.ALIGN_RIGHT
	then
		return true;
	else
		CnEcBaseHtmlException.raise_(CNEC_X_22000, '"' &amp; pAlign &amp; '" is not a valid Image tag alignment');
	endif;

	return false;
end;</source>
        <access>protected</access>
        <Parameter name="pAlign" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setImageAlign" id="e993f00c-2f5a-419d-8729-9bc10479f6cc">
        <updating/>
        <source>setImageAlign(pAlign:String) updating;
// --------------------------------------------------------------------------------
// Created:		02 May 2000 by cnwdad2
//
// Purpose:		Set the receiver's alignment setting.
//
// Parameters:	pAlign - The alignment setting.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if self.isValidAlign(pAlign) then
		self.imageAlign	:=	pAlign;
	endif;
end;</source>
        <Parameter name="pAlign" type="String"/>
    </JadeMethod>
</Class>
