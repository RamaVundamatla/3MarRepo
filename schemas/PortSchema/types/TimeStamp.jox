end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="differenceAsTime" id="b314780a-80ea-4ef5-a752-8a6cc01a11b0">
        <source>differenceAsTime(ts1: TimeStamp; posNeg: Integer io; numOfDays: Integer io):Time;

vars
 	midnight:	Time;
 	tsA:		TimeStamp;
 	tsB:		TimeStamp;
begin
	// This method calculates the difference between two timestamps and returns the 
	// value as a time type ie: hrs, mins, secs, millisecs and an integer that is
	// +1 if ts1&gt;self and -1 if ts1&lt;self
	// ie. ts1.TimeStamp - self.TimeStamp
	midnight.setTime(0,0,0,0);

	if self.Date&lt;&gt;ts1.Date then 
		if self&lt;ts1 then
			// Difference is a positive number of hours
			tsA:=ts1;
			tsB:=self;
			numOfDays:=(tsA.Date-tsB.Date);
			posNeg:=1;
			return (midnight-tsB.Time)+(tsA.Time);
		elseif  self&gt;ts1 then 
			// Difference is a negative number of hours
			tsA:=self;
			tsB:=ts1;
			numOfDays:=(tsA.Date-tsB.Date);
			posNeg:=-1;
			return (midnight-tsB.Time)+(tsA.Time);
		endif;
	elseif self.Date=ts1.Date and self.Time&lt;ts1.Time then
		// Difference is a positive number of hours
		numOfDays:=0; // ### TFS 51853 10DEC2021 NAVAB1 was after the return so was not set
		posNeg:=1; // ### TFS 51853 10DEC2021 NAVAB1 was after the return so was not set
		return (ts1.Time-self.Time).Time;
	else
		// Difference is a negative number of hours
		posNeg:=-1; // ### TFS 51853 10DEC2021 NAVAB1 was after the return so was not set
		numOfDays:=0; // ### TFS 51853 10DEC2021 NAVAB1 was after the return so was not set
		return ((self.Time-ts1.Time).Time);

	endif;
end;</source>
        <Parameter name="ts1" type="TimeStamp"/>
        <Parameter name="posNeg" type="Integer" usage="io"/>
        <Parameter name="numOfDays" type="Integer" usage="io"/>
        <ReturnType type="Time"/>
    </JadeMethod>
    <JadeMethod name="differenceInHours" id="7ea5e128-227c-47e3-b39f-43bdb88de457">
        <source>differenceInHours(ts1: TimeStamp):Integer;

vars

begin
	// This method calculates the difference between two timestamps in hours
	// ie. ts1.TimeStamp - self.TimeStamp
	if self.Date&lt;ts1.Date then
		// Difference is a positive number of hours
		return (((24-self.Time.hour)+(ts1.Time.hour))+(((ts1.Date-self.Date)-1)*24));
	elseif  self.Date&gt;ts1.Date then 
		// Difference is a negative number of hours
		return ((((24-ts1.Time.hour)+(self.Time.hour))+(((self.Date-ts1.Date)-1)*24))*-1);
	elseif self.Date=ts1.Date and self.Time&lt;ts1.Time then
		// Difference is a positive number of hours
		return (ts1.Time-self.Time).Time.hour;
	else
		// Difference is a negative number of hours
		return ((self.Time-ts1.Time).Time.hour*-1);
	endif;
end;</source>
        <Parameter name="ts1" type="TimeStamp"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="differenceInHoursFullDay" id="b038e736-260d-4879-ad76-7b539a6b87fa">
        <source>differenceInHoursFullDay(_timeStamp: TimeStamp):Integer;
/*****************************************************
Author		: jlika1 (Karen Alexander)
Date		: 27 September 2022
TFS#		: 54897
Function	:

*** Changes ***
Date			Name		TFS#		Description

****************************************************/

vars
	startTS, 
	endTS		: TimeStamp;
	localTime	: Time;
begin
	if not self.Date.isValid then
		return 0;
	endif;
	if _timeStamp = null or not _timeStamp.Date.isValid then
		return 0;
	endif;
	
	startTS := self;
	endTS := _timeStamp;
	if endTS &lt; startTS then
		startTS:= _timeStamp;
		endTS := self;
	endif;
	
	localTime.setTime(0,0,0,0);
	startTS.setTime(localTime);
	endTS := endTS.addDays(1);
	endTS.setTime(localTime);
	
	return (endTS-startTS).cnDays;
end;
</source>
        <Parameter name="_timeStamp" type="TimeStamp"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="differenceInHoursReal" id="4a91ab47-412c-46cc-b771-a95768f2a33b">
        <source>differenceInHoursReal(ts1: TimeStamp):Real;

vars
	minutes, hours, days : Integer;
	grossHours, minReal : Real;
	a, b : TimeStamp;
	diffTime : Time;
begin

	//05 Apr 2012	NDl	Par 29369
	if not self.Date.isValid then
		return 0;
	endif;
	if ts1 = null or not ts1.Date.isValid then
		return 0;
	endif;

	a:= self;
	b := ts1;
	
	if b &lt; a then
		a:= ts1;
		b := self;
	endif;
	minutes :=  (b.Time-a.Time).Time.minute;
	
	minReal := (minutes / 60);
	
	if minReal &gt; 1 then 
		minReal := minReal - 1;
	endif;
	
	hours :=  (b.Time-a.Time).Time.hour;
	
	if a.Time.hour &gt; b.Time.hour
	or a.Time.hour = b.Time.hour and a.Time &gt; b.Time then	// 10/06/2009 cnwar2
		days := (b.Date- a.Date) - 1;
	else
		days := (b.Date- a.Date);	
	endif;
	if days &lt; 0 then
		days := 0;
	endif;
	
	grossHours := hours + minReal + (days * 24);

	return grossHours;

end;</source>
        <Parameter name="ts1" type="TimeStamp"/>
        <ReturnType type="Real"/>
    </JadeMethod>
