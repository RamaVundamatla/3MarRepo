        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnViewInclAll_click(btn: Button input) updating;
// ---------------------------------------------------------------------------
// Created:     15 January 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	entTableRow	: EntTableRow;
	
begin

	if self.myCurrentView = null then
		return;
	endif;
	
	tblView.clear;

	foreach entTableRow in myCurrentDef.allEntTableRows do
		self.addViewRow(entTableRow);
	endforeach;
	
end;</source>
