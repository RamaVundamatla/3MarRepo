    <JadeMethod name="cmbProcess_click" id="634fe590-8ffe-48d1-8c3d-22a58e0f318e">
        <controlMethod name="CMUI_ComboBox::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbProcess_click(combobox: ComboBox input) updating;
// ---------------------------------------------------------------------------
// Created:     02 May 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
vars
	entTableDef		: EntTableDef;
	str 			: String;
	index : Integer;
begin
	str	 := combobox.text;
	self.tblPrintOptions.setValueByControlName(combobox.name, str);
	
	//01 Jul 2021	NDL	TFS 51405
	index := cmbFormat.findStringExact(1,"PDF");
	if index &gt; 0 then
		if self.cmbFormat.itemEnabled[index] = false then
			self.cmbFormat.itemEnabled[index] := true;
		endif;
	endif;
	
	if str = self.PROCESS_TEMPLATE then
		self.myReportAgent.setState(self.myReportAgent.STATE_TEMPLATE_SAVE);
		//01 Jul 2021	NDL	TFS 51405 - If we are creating a template hid this sucker
		index := cmbFormat.findStringExact(1,"PDF");
		if index &gt; 0 then
			self.cmbFormat.itemEnabled[index] := false;
			if self.cmbFormat.listIndex = index then
				self.cmbFormat.listIndex := -1;
				self.tblPrintOptions.setValueByControlName(self.cmbFormat.name, self.cmbFormat.text);	//06 Jul 2021	NDL TFS 51405
			endif;
		endif;

	elseif self.myReportAgent.state = self.myReportAgent.STATE_TEMPLATE_SAVE then
		self.myReportAgent.setState(myReportAgent.STATE_QRYREPORT);
		//changed this to not reload self.cmbProcess when called from here
		//self.showTableForReport(self.myReportAgent.myMenuEntity, false);
		//self.setDateFieldsCmbProcessClick();  // pos7.4.1 change re par 10746
	endif;
	
	self.setPrintOptionsView();

end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
    </JadeMethod>
