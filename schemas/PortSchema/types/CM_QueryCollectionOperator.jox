*/

vars

begin
	return false;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setSearchValue" id="ce244681-a64b-477f-87dc-cbc4cc1adc52">
        <updating/>
        <source>setSearchValue(_value: Any) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 April 2013	cnwpjs1	Initial creation

*/

vars

begin
	self.allSelectionValues.clear;
	if _value &lt;&gt; null then 	// par 18123
		if _value.isKindOf( Collection ) then	//17 Junn 2015	NDL	Par 36338
			_value.Collection.copy(self.allSelectionValues);
		elseif _value.isKindOf( Object ) then
			self.allSelectionValues.add(_value.Object);
		endif;
	endif;

epilog

end;</source>
        <Parameter name="_value" type="Any"/>
    </JadeMethod>
</Class>
