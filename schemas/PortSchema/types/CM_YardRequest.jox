    <JadeMethod name="getVoyage" id="35529e55-ad7b-41cb-b071-f5bd566e0934">
        <source>getVoyage(): CM_Voyage;
// ---------------------------------------------------------------------------
// Created:
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  -----------------------------------------------------------------------------------------------------
// 20 Oct 2025	navlw1		JIRA-35699:STWO - Missing Key Details in OM_DriverDetails2-NF Report when released by Any Id/amount
// ----------------------------------------------------------------------------------------------------------------------------------

vars

begin
	if self.voyageCode = null then
		if self.myOriginatingBulkRelease &lt;&gt; null and self.myOriginatingBulkRelease.myVoyage &lt;&gt; null then
			return self.myOriginatingBulkRelease.myVoyage;
		endif;
		return null;
	else
		return self.myTerminal.lookupVoyage(self.voyageCode, null, false);
	endif;	
end;</source>
