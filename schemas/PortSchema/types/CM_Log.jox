    <JadeMethod name="validateConsignorForLog" id="d23e8bd2-2b04-454c-8d11-d6dc39d4eb1f">
        <source>validateConsignorForLog();
/* ---------------------------------------------------------------------------
Created:	27 January 2011	by cnwvu1

Purpose:	ccms 1116, #26786. Consignor on alog and a consignor on its CM_BOLIn
			should be the same unconditionaly.
   
Change Date		Who		Reason

------------------------------------------------------------------------------*/
vars
	bolIn,
	pxyBOLIn: CM_BOLIn;
	pxyLog	: CM_Log;
	
begin

	bolIn	:= self.myReceivalBOL;
	if bolIn = null then
		return;
	endif;

	if not self.isTransient then	// if this is called from Docket Maintenance, there are no transient logs at all.
		return;	
	endif;
	
	// next, transient log should have the same consignor as in CM_BOLIn
	if self.consignor &lt;&gt; bolIn.consignor then
		app.raiseUnexpectedProgramError( class.name, method.name, 'Consignor ' &amp; bolIn.consignor &amp; ' on the Bill Of Lading ' &amp; bolIn.number &amp; ' and consignor ' &amp;self.consignor &amp; ' on the log ' &amp; self.id &amp; ' are different.');
	endif;

end;</source>
    </JadeMethod>
    <JadeMethod name="validateForDefault" id="433b9fa8-6e38-48c1-a130-0c599de7efc1">
        <updating/>
        <source>validateForDefault(pControl: CMIF_TIUpdateController input; _passport : CM_Passport input) updating, protected;

vars
	tmpProdCode	: String;
	pxyProduct	: CM_ProductLog;

begin

	inheritMethod(pControl, _passport);

	self.validateSED(pControl);				
	self.validateLength(pControl);
	self.validateId(pControl);
	self.validateConsignorForLog();	// ccms 1116, #26786 27/01/2011
	// 31785 June 2013 only if the log is still on-ship
	if self.isOnShip() then
		self.validateLogVoyage();	// 28082 Sep 2011 error on closed voyages
	endif;
	
	tmpProdCode := self.buildProductCode();
	// need to create a pxy product to do the validation
	create pxyProduct transient;
	pxyProduct.setProxyLogProductFromCodes(tmpProdCode, self.myOperator,
											self.speciesCode, self.gradeCode,
											self.typeCode, self.treatmentCode,
											self.lengthCode, _passport,
											pControl.myUserObject);
											
epilog
	delete pxyProduct;
end;</source>
        <access>protected</access>
        <Parameter name="pControl" type="CMIF_TIUpdateController" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="validateGrade" id="0fe25142-313b-4e69-af77-24a58c4226b6">
        <source>validateGrade(pControl: CMIF_TIUpdateController) protected;
//--------------------------------------------------------------
//Created: 05 February 2002 By: cnwgd1
//--------------------------------------------------------------
vars

begin
	if self.gradeCode = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Log Grade', ETRow_LogGradeCode, pControl.myUserObject);
		app.raiseCMException(Input_required_field_logGrade, ETRow_LogGradeCode, pControl.myUserObject); // cnwdb2	PAR 35364
		return;
	endif;

	if self.myOperator &lt;&gt; null and self.myOperator.getLogGrade(self.speciesCode, self.gradeCode) = null then
		app.raiseCMException2(ERR_FIELD_GRADE, self.gradeCode, 'grade code', 'gradeCode', pControl.myUserObject);
	endif;

end;</source>
        <access>protected</access>
        <Parameter name="pControl" type="CMIF_TIUpdateController"/>
    </JadeMethod>
    <JadeMethod name="validateLength" id="bad14a6a-8fc7-4c04-a59c-6b75e57f3666">
        <source>validateLength(pControl: CMIF_TIUpdateController) protected;
//--------------------------------------------------------------
//Created: 05 February 2002 By: cnwgd1
//--------------------------------------------------------------
vars

begin

	if self.lengthCode = null then
//		app.raiseCMException1(REQUIRED_FIELD, 'Length code', 'lengthCode', pControl.myUserObject);
		app.raiseCMException(Input_required_field_lengthCod, 'lengthCode', pControl.myUserObject); // cnwdb2	PAR 35364
		return;
	endif;

	if self.myOperator &lt;&gt; null and self.myOperator.getLogLength(self.lengthCode) = null then
		app.raiseCMException2(ERR_FIELD_LENGTH, self.lengthCode, 'Length code', 'lengthCode', pControl.myUserObject);
	endif;
	
end;</source>
