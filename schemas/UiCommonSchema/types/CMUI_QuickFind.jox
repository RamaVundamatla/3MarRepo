    <JadeMethod name="setUpForm" id="53fd2c38-f2cc-4c2c-aa44-6421e8f61e5d">
        <updating/>
        <source>setUpForm( _term : CM_Terminal ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 January 2014	cnwndl1	Initial creation	Par 33350

*/

vars

	user : CM_User;
	iter : Iterator;
	userTerm : CM_UserTerminal;
	term : CM_Terminal;
	index : Integer;

begin

	user := app.getMyUser;
	
	if user = null then
		app.msgBox("No user found", app.getErrorString(Error), MsgBox_OK_Only );
		self.unloadForm;
		return;
	endif;
	if user.allUserTerminals.isEmpty then
		app.msgBox("No user terminals found", app.getErrorString(Error), MsgBox_OK_Only );
		self.unloadForm;
		return;
	endif;
	
	iter := user.allUserTerminals.createIterator;
	while iter.next( userTerm ) do
		term := userTerm.myTerminal;
		index := self.cmbTerminal.addItem( term.name );
		self.cmbTerminal.itemObject[ index ] := term;
	endwhile;
	
	if _term &lt;&gt; null then
		self.cmbTerminal.listIndex := self.cmbTerminal.findObject( _term );
	else
		term := app.myPassport.myTerminal;
		if term &lt;&gt; null then
			self.cmbTerminal.listIndex := self.cmbTerminal.findObject( term );
		else
			self.cmbTerminal.listIndex := 1;
		endif;
	endif;
	if self.cmbTerminal.listCount = 1 then
		self.cmbTerminal.enabled := false;
	endif;
	
	self.setMyTerminal();
	
	self.setStatusCaption( null, 0 );
	
	self.txtFind.text := "?";

epilog

	delete iter;
	
end;</source>
        <Parameter name="_term" type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="showUserPref" id="a90d36e9-2564-4dc7-8171-e42c37a7b714">
