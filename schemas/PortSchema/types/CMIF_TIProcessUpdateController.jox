<Class name="CMIF_TIProcessUpdateController" id="d03273cd-8dfc-4f7d-bb58-babb4fabf365">
    <superclass name="CMIF_Object"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="cmtrans"/>
    <ImplicitInverseRef name="allAddPrxyCargo" id="0daf5394-e737-42d1-b1d7-5610074e65d6">
        <memberTypeInverse/>
        <type name="CM_TISet"/>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="allDelRealCargo" id="cf90d664-108e-4885-98fb-beb3e288068a">
        <memberTypeInverse/>
        <type name="CM_TISet"/>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="allPersistentTIs" id="d01622f6-2deb-4871-8003-10fd28e677f1">
        <memberTypeInverse/>
        <type name="CM_TIByCargoTypeIdDict"/>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="allUpdPrxyCargo" id="ce3f06e7-7252-4b92-a2c7-bd93f4db3108">
        <memberTypeInverse/>
        <type name="CM_TISet"/>
    </ImplicitInverseRef>
    <PrimAttribute name="armEDIContextExceptionHandler" id="43ff5a49-b9c2-46dc-834c-5e15c3a00961">
        <embedded/>
        <type name="Boolean"/>
        <text>par 29747 - indicates whether proxy cargo items have linkes to the originating EDI Tracked Item
			if so then an exception handler can be armed  to ensure context is set correctly</text>
    </PrimAttribute>
    <ImplicitInverseRef name="myEDIData" id="72d90eec-f86d-42bb-ac57-bbd948073da3">
        <embedded/>
        <type name="CM_EDIData"/>
    </ImplicitInverseRef>
    <PrimAttribute name="site" id="1b4aa1ce-c3c9-4f52-a150-6b55deb2714f">
        <embedded/>
        <type name="Integer"/>
        <text>The category of location that thea tis will haves.
			This can be TI_SITE_ONSITE, TI_SITE_OFFSITE, TI_SITE_ONSHIP not TI_SITE_UNDEFINED
		the values are from the TI site attribute</text>
    </PrimAttribute>
    <JadeMethod name="isEmpty" id="9d54a24d-1060-4aa5-9dba-4a6b2e65479e">
        <source>isEmpty() : Boolean;

vars

begin
	if self.allAddPrxyCargo.isEmpty and
	   self.allDelRealCargo.isEmpty and
	   self.allUpdPrxyCargo.isEmpty then
		return true;
	else
		return false;
	endif;
end;
</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="purge" id="bd10659a-5c03-42d5-bd7a-5835b2c54430">
        <source>purge();

vars

begin
	self.allAddPrxyCargo.purge();
	self.allUpdPrxyCargo.purge();
end;
</source>
    </JadeMethod>
</Class>
