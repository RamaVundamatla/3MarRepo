    <JadeMethod name="getAllWLEs" id="2c84d41a-0945-4da9-8a48-0d1c7417ca43">
        <source>getAllWLEs()protected;
/*

Purpose:			


Return Value:		


Date		Who		Reason
14 August 2006	cnwer1	Initial creation - PAR#xxxx

*/
vars
 vm : CM_VehicleMachine;
	 vehicle : CM_Vehicle;
begin

	foreach vm  in self.allVehicles discreteLock do
		if vm.isKindOf(CM_Machine) then
			continue;
		else
			vehicle:=vm.CM_Vehicle;
		endif;
		
		vehicle.getAllWLEs(self.allWLEs);
	endforeach; 
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="getAreaCaption_NameAndTotal" id="d32ce4e0-3303-43cf-8908-3d50b477d274">
        <source>getAreaCaption_NameAndTotal(_area	:CM_TerminalArea):String;
// ---------------------------------------------------------------------------
// Created:     09 September 2009 by cnwcs5
// Purpose:     CCMS 1061 - gate config
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	str			:String;
	rec, rel,
	vehicles	:Integer;
begin
	//changed to getNiceName because gantry interchange want there parents id
	str :=	_area.getDisplayName(true);
	//epr TFS 7828 24/11/17
	self.getWLECountForArea (_area,vehicles, rec, rel);
	
	str := str &amp; app.getErrorString3 (XLAT_RoadOps_V_Rec_Rel, vehicles.String, rec.String, rel.String);
	
	return str;
epilog

end;</source>
        <Parameter name="_area" type="CM_TerminalArea"/>
        <ReturnType type="String"/>
    </JadeMethod>
