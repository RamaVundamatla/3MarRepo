    <JadeMethod name="createCMIFForTrackedItem" id="76ee4506-786c-4ef7-ac0f-ffddd9c52e2c">
        <source>createCMIFForTrackedItem(item: CM_TrackedItem;  _action : Integer): CMIF_TIGenCargo;
/*
	Created on 16 April 2008
	
	by Debby Hutchison
	
	Purpose:
*/

vars
	cmifTI 		: CMIF_TIGenCargo;
	cmifRec 	: CMIF_Receival;
	cmifRel		: CMIF_ReleaseById;
	loc 		: CM_LocationsController;
begin
	create cmifTI transient;
	if _action = cmifTI.Action_Move then
		cmifTI.setMyTrackedItem(item);
		cmifTI.setMyNewLocation(self.getDefaultLocationForTI(item));

	elseif _action = cmifTI.Action_ReceivePrenote then
		create cmifRec transient;
		cmifRec.setBasicFieldsFromPrenote(item);
		cmifRec.setPreservePrenoteData(true);
		cmifRec.myTerminal := myTerminal;
		createCMIFInOutCommon(cmifRec);
		cmifTI.setMyNewLocation(self.getDefaultLocationForTI(item));
		cmifTI.setMyRefPrenote(item);
		cmifTI.setMyCMIFReceival(cmifRec);
		
	elseif _action = cmifTI.Action_ReleaseByID then
		create cmifRel transient;
		cmifRel.id := item.id;
		cmifRel.myTerminal := self.myTerminal;
		cmifRel.cargoType := item.cargoType;
		cmifRel.consigneeCode := item.consignee;
		cmifRel.myBulkRelease := item.getBulkReleaseAssignedOfType(BR_TYPE_ROAD, BR_ACTIVE);
		if cmifRel.myBulkRelease &lt;&gt; null then
			cmifRel.deliveryReleaseNumber := cmifRel.myBulkRelease.code;
		else
			cmifRel.deliveryReleaseNumber := item.deliveryRelease;
		endif;
		createCMIFInOutCommon(cmifRel);
		cmifTI.setMyCMIFRelease(cmifRel);
	endif;
	cmifTI.action := _action;
	if not _action = cmifTI.Action_ReleaseByID then
		allCMIFs.add(cmifTI);
		cmifTI.setLoadCount(self.getLoadCount);
	endif;
	return cmifTI;
end;</source>
        <Parameter name="item" type="CM_TrackedItem"/>
        <Parameter name="_action" type="Integer"/>
        <ReturnType type="CMIF_TIGenCargo"/>
    </JadeMethod>
    <JadeMethod name="createCMIFInOutCommon" id="f76e13a0-3bd1-4cf2-b104-bf181006545f">
        <source>createCMIFInOutCommon(_cmifRec : CMIF_TIObject input);
/*
	Created on 02 May 2008
	
	by Debby Hutchison
	
	Purpose:
*/

vars
	cmifCommon : CMIF_InOutCommon;
begin
	create cmifCommon transient;
	cmifCommon.setFromRoadJob(myRoadJob, myTerminal);
	_cmifRec.setMyInOutCommon(cmifCommon);
end;</source>
        <Parameter name="_cmifRec" type="CMIF_TIObject" usage="input"/>
    </JadeMethod>
    <JadeMethod name="createCMIFforCMIFReceival" id="7d16aeb1-9a54-4d36-8697-67b3bc514fc4">
        <source>createCMIFforCMIFReceival(_cmifRec : CMIF_Receival input;_action : Integer): CMIF_TIGenCargo;
/*
	Created on 16 April 2008
	
	by Debby Hutchison
	
	Purpose:
*/

vars
	cmifTI : CMIF_TIGenCargo;
begin
	create cmifTI transient;
	cmifTI.setMyCMIFReceival(_cmifRec);
	cmifTI.setMyNewLocation( _cmifRec.getPlannedLocation);
	cmifTI.action := _action;
	self.allCMIFs.add(cmifTI);
	cmifTI.setLoadCount(self.getLoadCount);
	
	return cmifTI;
end;</source>
        <Parameter name="_cmifRec" type="CMIF_Receival" usage="input"/>
        <Parameter name="_action" type="Integer"/>
        <ReturnType type="CMIF_TIGenCargo"/>
    </JadeMethod>
    <JadeMethod name="createDefaultRoadJob" id="d92f5ff2-ff63-4beb-a858-32eac2a4dbae">
        <source>createDefaultRoadJob(roadJob: CM_RoadJob output; truck: CM_Vehicle);
/*
	Created on 14 April 2008
	
	by Debby Hutchison
	
	Purpose:
*/

vars
	strTermArea 	: String;
	proxyRoadJob 	: CM_RoadJob;
	passport 		: CM_Passport;
	invalid			: Boolean;
begin
	passport := app.myPassport;
	strTermArea := self.myTerminal.getConfig(DefWarehouseArea).String.trimRight();

	create proxyRoadJob transient;
	// cnwjk3 PAR 20977 09/10/09
	//proxyRoadJob.setProxyRoadJob(self.myTerminal,
	//						null,
	//						truck.carrierCode,
	//						truck.regNumber,
	//						strTermArea,
	//						false,
	//						true,
	//						null, null, null, null); // PAR 17703
	proxyRoadJob.setProxyRoadJob(self.myTerminal,
							null,
							truck.carrierCode,
							truck.regNumber,
							null,
							strTermArea,
							false,
							true,
							null, null, null, null); // PAR 17703
	app.myTrxCA.trxCreateRoadJob(proxyRoadJob, roadJob, app.myPassport);
	// following added for par 16983
	if roadJob &lt;&gt; null then
		//cnwjo3 par 24884.  Added exception handling for invalid objects.
		on Exception do app.handleDeletedObject(exception,roadJob,invalid);
		roadJob.creationTime; //cause exception
		if not invalid then
			roadJob.causeEvent(roadJob.myTerminal.getTerminalEvent(RoadJob_Create_Event), false, roadJob);			
		endif;
	endif;

end;</source>
        <Parameter name="roadJob" type="CM_RoadJob" usage="output"/>
        <Parameter name="truck" type="CM_Vehicle"/>
    </JadeMethod>
    <JadeMethod name="createMoveController" id="2e5d7685-2241-4215-a75f-cf9a68491da5">
        <source>createMoveController(_ti : CM_TrackedItem; _lc : CM_LocationsController): CMIF_MoveController;

vars
	theMoveController : CMIF_MoveController;
begin
	create theMoveController transient;
	theMoveController.setMyToPrimaryLocation(_lc);
	theMoveController.setMyOriginatingLocation(_ti.getPrimaryLocation(REAL_MODE));
	theMoveController.setMoveMode(REAL_MODE);
	theMoveController.isSystemMove := true;
	theMoveController.isForcedMove := true;
	return theMoveController;
end;
</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_lc" type="CM_LocationsController"/>
        <ReturnType type="CMIF_MoveController"/>
    </JadeMethod>
