    <JadeMethod name="getMeasurementStringForAttrib" id="4de24643-1443-4a55-a5f8-29cc3ac0056c">
        <source>getMeasurementStringForAttrib(_attrName: String; _measureType: String; _short: Boolean): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
19 July 2024		jlizm1	Initial creation TFS 65150 Add over-dimension fields to column organiser

*/

vars

begin
	if _attrName = ETRow_OverHeight then
		return app.convertMeasurementForDisplay(_measureType, self.overHeight);
	elseif _attrName = ETRow_OverLength then
		return app.convertMeasurementForDisplay(_measureType, self.overLength);
	elseif _attrName = ETRow_OverWidth then
		return app.convertMeasurementForDisplay(_measureType, self.overWidth);
	endif;

	return inheritMethod(_attrName, _measureType, _short);

epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_measureType" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
