    <JadeMethod name="doLoadConsignees" id="255cf016-e4e1-4a09-9a40-5b2273872ba5">
        <updating/>
        <source>doLoadConsignees() updating;
/*
Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
02 February 2010	conkc1	Initial creation

*/
vars
	consign			: CM_ConsigneeConsignor;
	index           : Integer;
begin

	self.cmbConsignee.clear;

	foreach consign in app.myRoot.allConsigneeConsignors do 

		if consign.isConsignee then
		
			index := self.cmbConsignee.addItem(consign.code);
			self.cmbConsignee.itemObject[index] := consign;

		endif;

	endforeach;

epilog

end;</source>
    </JadeMethod>
