    </JadeMethod>
    <JadeMethod name="translateToSearchValue" id="5881604c-b72a-4993-9810-2e662b826949">
        <source>translateToSearchValue(_value: Any): Any;
// ---------------------------------------------------------------------------
// Created:     06 March 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
vars

begin

	if _value.isKindOf(IntegerArray) then
		return _value;
	elseif _value.isKindOf(Integer) then	//21 Jan 2014	NDL
		return _value.String;
	endif;
	
	return app.stateStringToEnum(_value.String);
end;</source>
        <Parameter name="_value" type="Any"/>
        <ReturnType type="Any"/>
    </JadeMethod>
    <JadeMethod name="translateToSearchValueForWeb" id="8dfe3cf9-9c28-464b-a027-fd2cdc7aecd2">
        <source>translateToSearchValueForWeb(_value: Any; _sending : Boolean): Any;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 05/09/2019	jlgdap1		Initial creation TFS 45769 JMT Web Portal selector query parameters
//
vars
	int : Integer;
	retVal, collStr, str : String;
	strArray : StringArray;
	coll : IntegerArray;

begin
	if _value.isKindOf(Integer) then
		return app.stateEnumToString(_value.Integer);
		
	elseif _value.isKindOf(String) then
		if _value.String.cnContains("|") then
			collStr := _value.String;
			create strArray transient;
			create coll transient;
			collStr.getTokensForDelimiter("|", strArray);
			foreach str in strArray do
				coll.add(app.stateStringToEnum(str));
			endforeach;
			return coll;
		endif;
		
		if not _sending then
			return app.stateStringToEnum(_value.String);
		endif;
		
		return _value.String;
		
	elseif _value.isKindOf(IntegerArray) then
		foreach int in _value.IntegerArray do
			retVal := retVal &amp; app.stateEnumToString(int) &amp; CNEC_COMMA &amp; Space;
		endforeach;
		retVal := retVal[1:retVal.length-2];
		return retVal;
		
	endif;
	
	return inheritMethod(_value, _sending);

epilog
	delete strArray;
end;</source>
        <Parameter name="_value" type="Any"/>
        <Parameter name="_sending" type="Boolean"/>
        <ReturnType type="Any"/>
    </JadeMethod>
</Class>
