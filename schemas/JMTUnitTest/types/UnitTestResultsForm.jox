    <JadeMethod name="initTableResults" id="db9b1d71-a2b8-4989-8085-a08c3d46c150">
        <updating/>
        <source>initTableResults() updating;

/*

Purpose:		Initialise the table	

Date			Who		Reason
02/05/2012		cnwmh5	Initial creation
16 Oct 2025		navbs1	Story MTN-34979: MTN - Unit Test Results App - Add Jira Item Column - Phase2

*/

vars
	tempWidth					: Integer;
begin

	self.tblResults.rows		:= 1;
	self.tblResults.columns 	:= 11;	// ### NOTE - if changing columns see tblResults::dblClick()		//16.10.2025 navbs1  #34979

	self.tblResults.accessCell(1, 1).text := 
		'Result ' &amp; Tab &amp; 
		'Class ' &amp; Tab &amp;
		'Method' &amp; Tab &amp;
		'Runs Failing ' &amp; Tab &amp; 
		'1st Failed ' &amp; Tab &amp; 
		'Owner ' &amp; Tab &amp;
		'Emailed To ' &amp; Tab &amp;	
		'Run Time ' &amp; Tab &amp; 
		'Elapsed (secs) ' &amp; Tab &amp;
		'Jira Item ';																					//16.10.2025 navbs1  #34979

	self.tblResults.accessColumn(1).width := 70;
	tempWidth := tempWidth + self.tblResults.accessColumn(1).width;
	self.tblResults.accessColumn(2).width := 200;
	tempWidth := tempWidth + self.tblResults.accessColumn(2).width;
	self.tblResults.accessColumn(3).width := 210;
	tempWidth := tempWidth + self.tblResults.accessColumn(3).width;
	self.tblResults.accessColumn(4).width := 70;
	tempWidth := tempWidth + self.tblResults.accessColumn(4).width;
	self.tblResults.accessColumn(4).alignment := Table.Alignment_Right;
	self.tblResults.accessColumn(5).width := 90;
	self.tblResults.accessColumn(5).alignment := Table.Alignment_Right;
	self.tblResults.accessColumn(6).width := 70;
	tempWidth := tempWidth + self.tblResults.accessColumn(5).width;
	self.tblResults.accessColumn(7).width := 100; 
	tempWidth := tempWidth + self.tblResults.accessColumn(6).width;
	//self.tblResults.accessColumn(7).width := self.tblResults.width.Integer - tempWidth;
	self.tblResults.accessColumn(8).width := 80; 
	self.tblResults.accessColumn(8).alignment := Table.Alignment_Right;
	self.tblResults.accessColumn(9).width := 90; 
	self.tblResults.accessColumn(9).alignment := Table.Alignment_Right;
	self.tblResults.accessColumn(10).width := 80; 								//16.10.2025 navbs1  #34979
	self.tblResults.accessColumn(10).alignment := Table.Alignment_Right;		//16.10.2025 navbs1  #34979
	self.tblResults.accessColumn(11).visible := false;							// failure details
	
	self.tblResults.selectMode := Table.SelectMode_WholeRows;
	
epilog

end;</source>
