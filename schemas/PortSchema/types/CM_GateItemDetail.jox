    <JadeMethod name="setItemDetails" id="8972f8ad-2fa0-428d-8609-49e1c6b107fb">
        <updating/>
        <source>setItemDetails(_interface : CMIF_TIObject) updating;
// ---------------------------------------------------------------------------
// Created:     09 September 2008 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	item : CMIF_TIObject;
	tmpID : String;
	tmpCT : Integer;
begin
	_interface.setGateItemDetail(self);
	
	foreach item in _interface.allSubItems do
		item.setGateItemDetail(self);
	endforeach;
epilog

end;</source>
        <Parameter name="_interface" type="CMIF_TIObject"/>
    </JadeMethod>
