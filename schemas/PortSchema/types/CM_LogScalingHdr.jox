    <JadeMethod name="pxyCreateUpdateProxy" id="fdfcd5f2-c0aa-4d5d-9a33-7b3f9a3ce608">
        <source>pxyCreateUpdateProxy(): SelfType;
// ---------------------------------------------------------------------------
// Created:     23 March 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 20/04/2011	cnwmh5		PAR #27401 - Add code to handle prossible exceptions occurring when
//							trying to create the proxy
// ---------------------------------------------------------------------------
vars
	pxyHdr		: CM_LogScalingHdr;
	pxyDtl,
	realDtl		: CM_LogScalingDtl;
	pxyExtra,
	realExtra	: CM_LogScalingExtra;
	completedOK		: Boolean;
	
begin

	pxyHdr := inheritMethod();

	pxyHdr.myTerminal	:= self.myTerminal;

	foreach realDtl in self.allLogScalingDtls do
		pxyDtl := realDtl.pxyCreateUpdateProxy();
		pxyDtl.setHdrForProxy(pxyHdr);
	endforeach;

	foreach realExtra in self.allLogScalingExtra do
		pxyExtra := realExtra.pxyCreateUpdateProxy();
		pxyExtra.setHdrForProxy(pxyHdr);
	endforeach;	
	
	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return pxyHdr;
	
epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete pxyHdr;
	endif;	
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="resetAverages" id="01ef5cdf-a559-4d2c-ae6f-55ad7c6ef0e5">
        <updating/>
        <source>resetAverages()updating;
// ---------------------------------------------------------------------------
// Created:     23 March 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	dtl		: CM_LogScalingDtl;
	tmpMaxSed,
	tmpMinSed,
	tmpMeanSed	: Decimal[12,2];
	numDtls		: Integer;

begin

	foreach dtl in self.allLogScalingDtls do
		//accumulate total min/max/mean seds
		tmpMaxSed := (tmpMaxSed + dtl.maxSED);
		tmpMinSed := (tmpMinSed + dtl.minSED);
		tmpMeanSed := (tmpMeanSed + global.calcSEDMean(dtl.minSED, dtl.maxSED));
	endforeach;	
	
	numDtls := self.allLogScalingDtls.size;

	//Now set the averages for this header
	self.averageMaxSed := (tmpMaxSed / numDtls);
	self.averageMinSed := (tmpMinSed / numDtls);
	self.averageMeanSed := (tmpMeanSed / numDtls);

end;</source>
    </JadeMethod>
