    <JadeMethod name="deleteCargoForecast" id="495efdc6-1a62-4084-b1b2-7492811232c5">
        <updating/>
        <source>deleteCargoForecast(_obj : CM_Object)updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 April 2022	navak20	Initial creation	TFS 53142 Cargo Forecast on Voyage &amp; Train

*/

vars
	cargoObj : CM_CargoForecast;
	result : Integer;
	msgString : String;
begin
	cargoObj := _obj.CM_CargoForecast;
	if cargoObj.myCargoType &lt;&gt; null and cargoObj.myCommodity = null then
		msgString := cargoObj.myCargoType.description;
	elseif cargoObj.myCargoType = null and cargoObj.myCommodity &lt;&gt; null then
		msgString := cargoObj.myCommodity.description;
	else
		msgString := cargoObj.myCargoType.description &amp; "/" &amp; cargoObj.myCommodity.description;
	endif;
	if myObject.isKindOf(CM_Voyage) then
		if app.msgBox(app.getErrorString2(CONF_CF_MSG, msgString, self.myObject.CM_Voyage.code.String), 
							app.getErrorString(CONFIRM_REMOVAL), MsgBox_Yes_No + MsgBox_Question_Mark_Icon) = MsgBox_Return_No then
			return;
		endif;
	else
		if app.msgBox(app.getErrorString2(CONF_CF_MSG, msgString, self.myObject.CM_Train.code.String ), 
							app.getErrorString(CONFIRM_REMOVAL), MsgBox_Yes_No + MsgBox_Question_Mark_Icon) = MsgBox_Return_No then
			return;
		endif;
	endif;
	while true do
		app.myTrxDA.trxDeleteCargoForecast(cargoObj, app.myPassport);
			if app.myPassport.trxCompletedOK then
					self.clearErrorWarnings();
					if tblCargoForecast &lt;&gt; null then
						tblCargoForecast.clearAllData();
					endif;
					self.loadCargoForecastTable();
					self.clearCmbData();
					self.disableCmbControls();
					break;
			else
				result := app.showErrorWarningDialog(app.getErrorString(Cargo_Forecast_Delete), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
				if app.myPassport.noErrors and
				   result = IDOK then
					app.myPassport.warningsAcknowledged	:= true;
					continue;
				endif;
				self.setAllErrorWarnings(app.myPassport);
			endif;
			break;
	endwhile;
epilog

end;</source>
        <Parameter name="_obj" type="CM_Object"/>
    </JadeMethod>
    <JadeMethod name="disableCmbControls" id="0ee08239-f3b2-45f8-acaf-c63b10d51276">
        <source>disableCmbControls();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 April 2022	navak20	Initial creation	TFS 53142 Cargo Forecast on Voyage &amp; Train

*/

vars

begin
	self.btnSave.enabled := false;
	
	self.lblType.enabled := false;
	self.cmbCargoType.enabled := false;
	
	self.lblCommodity.enabled := false;
	self.cmbCommodity.enabled := false;
	
	self.lblOperator.enabled := false;
	self.cmbOperator.enabled := false;
	
	self.lblMode.enabled := false;
	self.cmbMode.enabled := false;
	
	self.txtQuantity.enabled := false;
	self.lblQuantity.enabled := false;
	
	self.lblVolume.enabled := false;
	self.txtCargoVolume.enabled := false;
	
	self.lblWeight.enabled := false;
	self.txtCargoWeight.enabled := false;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="displayCargoForecast" id="7cdee53a-c571-4164-8997-ad2f82df18ce">
        <updating/>
        <source>displayCargoForecast(_obj : CM_Object)updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 April 2022	navak20	Initial creation	TFS 53142 Cargo Forecast on Voyage &amp; Train
06 June 2022    navds20  53728 EUP - Cargo Forecast Issues

*/

vars
	cargoType : CM_CargoType;
	commodity : CM_Commodity;
	operator : CM_Operator;
	operatorIndex : Integer;
	weight, volume : String;
	weightMeasurement, volumeMeasurement : CM_MeasurementType;
	defaultedCargoType : CM_CargoType;     //06-06-2022 navds20 TFS 53728
	
begin
	if _obj &lt;&gt; null then
		if _obj.isKindOf(CM_CargoForecast) then
		
			self.enableCmbControls();
			
			cargoType := _obj.CM_CargoForecast.myCargoType;
			commodity := _obj.CM_CargoForecast.myCommodity;
			operator :=  _obj.CM_CargoForecast.myOperator;
			
			if  operator &lt;&gt; null and operator.description &lt;&gt; null then
				operatorIndex := self.cmbOperator.findString(1, operator.description);
			else
				operatorIndex := -1;
			endif;
			
			weightMeasurement := app.getDefaultMeasurementForType(Type_Weight);
			volumeMeasurement := app.getDefaultMeasurementForType(Type_Volume);
			
			if cargoType &lt;&gt; null and cargoType.description &lt;&gt; null then		//17.05.2022 navsrk20 53142
				self.cmbCargoType.listIndex := self.cmbCargoType.findString(1, cargoType.description);
				weightMeasurement := cargoType.getMeasurementTypeFor(Type_Weight, true);	//17.05.2022 navsrk20 53142
				volumeMeasurement := cargoType.getMeasurementTypeFor(Type_Volume, true);	//17.05.2022 navsrk20 53142
				self.cmbCargoType_click(self.cmbCargoType);				// 06-06-2022 navds20 TFS 53728
			else
				self.cmbCargoType.listIndex := -1;
			endif;
			
			if commodity &lt;&gt; null and commodity.description &lt;&gt; null then
				// 06-06-2022 navds20 TFS 53728 starts
				if cargoType = null then
					self.cmbCommodity.clear();
					self.doCommodity;
				endif;
				// 06-06-2022 navds20 TFS 53728 ends
				self.cmbCommodity.listIndex := self.cmbCommodity.findString(1, commodity.description);	
			else
				self.cmbCommodity.listIndex := -1;
			endif;
			
			weight := app.convertMeasurementForDisplay(weightMeasurement.shortName, _obj.CM_CargoForecast.totalWeight);
			volume := app.convertMeasurementForDisplay(volumeMeasurement.shortName, _obj.CM_CargoForecast.totalVolume);
			
			self.cmbOperator.listIndex := operatorIndex;
			self.cmbMode.listIndex := self.cmbMode.findString(1, _obj.CM_CargoForecast.mode);
			self.txtQuantity.text := _obj.CM_CargoForecast.totalQuantity.String;
			self.txtCargoVolume.setValues(volume &amp; Space &amp; volumeMeasurement.shortName);
			self.txtCargoWeight.setValues(weight &amp; Space &amp; weightMeasurement.shortName);
		endif;
	endif;
epilog

end;</source>
        <Parameter name="_obj" type="CM_Object"/>
    </JadeMethod>
    <JadeMethod name="doCargoType" id="773f816e-1283-4ece-bd1a-9fd57d1459ac">
        <source>doCargoType();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 April 2022	navtnr20	Initial creation	TFS 53142 Cargo Forecast on Voyage &amp; Train

*/
vars
    cargoType : CM_CargoType;
	assistant           : CMUI_Assistant;
begin
	/*foreach cargoType in app.myRoot.allCargoTypesById do
		if cargoType &lt;&gt; null then
			cmbCargoType.addItemObject(cargoType.description ,cargoType);
		endif;
	endforeach;*/
	
	assistant := self.myAssistant;
	assistant.comboBoxCargoBolType(cmbCargoType, null, true, false, true, true);
end;</source>
    </JadeMethod>
    <JadeMethod name="doCommodity" id="45944113-f203-430a-a0d2-5387821523ff">
        <source>doCommodity();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 April 2022	navak20	Initial creation	TFS 53142 Cargo Forecast on Voyage &amp; Train

*/

vars
	commodity : CM_Commodity;
begin
	foreach commodity in app.myRoot.allCommodities do
		if commodity &lt;&gt; null then
			cmbCommodity.addItemObject(commodity.description, commodity);
		endif;
	endforeach;
epilog

end;</source>
