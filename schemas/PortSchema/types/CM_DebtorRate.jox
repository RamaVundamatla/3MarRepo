    <JadeMethod name="getTimeRate" id="4895ede9-7a1a-4860-a7a5-afaf3826497e">
        <source>getTimeRate(bank : CM_Bank; t : TimeStamp) : CM_RateEntry;

vars
	retVal : CM_RateEntry;
	rdg : CM_RootDebtorGroup;
	theBank : CM_Bank;
	found	: Boolean;
	iter	: Iterator;
begin
	theBank := bank;
	rdg := theBank.getRootDebtorGroup();

	// 23582 add expiry date and ignore checks
	iter := self.rateEntries.createIterator;
	self.rateEntries.startKeyLeq(t, iter);
	found := false;
	while iter.back(retVal) do
		if retVal.ignoreThisEntry then
			continue;
		endif;
		if retVal.expiryTimestamp &lt;&gt; null and
		   retVal.expiryTimestamp &lt;= t then  
			continue;
		endif;
		found := true;
		break;
	endwhile;
	if not found then
		retVal := null;
	endif;
	if bank.retrospectiveRates then
		if debtorNode = rdg then
			if retVal = null then
				retVal := rateEntries.first;
			endif;
		endif;
	endif;

	return retVal;
epilog
	delete iter;
end;</source>
        <Parameter name="bank" type="CM_Bank"/>
        <Parameter name="t" type="TimeStamp"/>
        <ReturnType type="CM_RateEntry"/>
    </JadeMethod>
