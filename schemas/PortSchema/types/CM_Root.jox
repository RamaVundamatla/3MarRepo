    <JadeMethod name="createTerminal" id="83c9a1ef-fa1c-457e-8998-55d264ec1c0e">
        <source>createTerminal(_terminalCode, _terminalName,_timeZoneID,_timeZoneShortID : String; pCargoBolTypeArray : CM_CargoBOLTypeArray; 
		_dfltCargoType, _dfltBolType, _dfltCargoBolType, _dfltCargoGroupType, _dfltTrailerCargoype : Integer; pKeyValue : Any) : CM_Terminal;
// ---------------------------------------------------------------------------
// Created:     07 January 2003 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 27/05/2016	cnwmh5		Create prenote validation
// 22 June 2016	cnwns1	TFS 488 - Multi Timezone Support
// 04/07/2017	cnwdap1		TFS 4492 SNO VERMAS Changes
// 21/06/2023	navdap1		TFS 56747 EUP Manifest Load - Internal (Zimmer) - Cresate
// 01/08/2025   navsp1      JIRA-35530 Solution Implementation - COPRAR Trailer Support
// ---------------------------------------------------------------------------
vars
	ls	: Boolean;
	proxyTerm,
	newTerm		: CM_Terminal;
	cmif_Config	: CMIF_ConfigTerminal;
	pxyPrenoteValidation : CM_TermPrenoteWeightCriteria;
begin

	create proxyTerm transient;
	create cmif_Config transient;
	// 22 June 2016	cnwns1	TFS 488 - Multi Timezone Support
	proxyTerm.setProxy(_terminalCode, _terminalName,_timeZoneID,_timeZoneShortID, pCargoBolTypeArray, _dfltCargoType, _dfltBolType, _dfltCargoBolType, _dfltCargoGroupType, _dfltTrailerCargoype, null);	// TFS 56747
	
	// 27/05/2016 cnwmh5
	create pxyPrenoteValidation transient;
	pxyPrenoteValidation.setMyTerminal(proxyTerm);
	
	//app.myTrxCA.trxCreateTerminal(proxyTerm, pKeyValue, null, newTerm, app.myPassport);
	app.myTrxCA.trxCreateTerminal(proxyTerm, pKeyValue, cmif_Config, newTerm, app.myPassport);
	
	return newTerm;

epilog
	app.cmsEndLoad(ls);
	delete proxyTerm;
	delete cmif_Config;
end;</source>
        <Parameter name="_terminalCode" type="String"/>
