    <JadeMethod name="displayForXlation" id="b23f2487-3304-4fe4-b283-a3aeab979bc3">
        <source>displayForXlation(_codeFirst : Boolean) : String;

vars

begin
	if _codeFirst then
		return self.code.trimBlanks&amp;' ['&amp;self.description.trimBlanks&amp;']';
	else
		return self.description.trimBlanks&amp;' ['&amp;self.code.trimBlanks&amp;']';
	endif;
end;
</source>
        <Parameter name="_codeFirst" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="erase" id="283af00d-2ec2-451a-a555-231394f8a1c9">
        <updating/>
        <source>erase(_eraseLevel: Integer) updating;
// 25/03/2013	cnwcs5	CCMS POL 2097 / par 31259
vars

	//15 Jul 2016	NDL	TFS 2329
	iter : Iterator;
	cmqfTT : CMQF_TerminalTIs;
	cmqfVCS : CMQF_VoyageGeneralCargoSummary;
	cmqfVS : CMQF_VoyageSummary;

begin
	self.exclusiveLock(self);

	self.eraseXlations(self.allXlations, NORMAL_ERASE);
	
	//15 Jul 2016	NDL	TFS 2329
	iter := CMQF_TerminalTIs.instances.createIterator;
	while iter.next(cmqfTT) do
		if cmqfTT.allPortsDischarge.includes(self) then
			cmqfTT.allPortsDischarge.remove(self);
		endif;
	endwhile; 
	delete iter;
	
	iter := CMQF_VoyageGeneralCargoSummary.instances.createIterator;
	while iter.next(cmqfVCS) do
		if cmqfVCS.allPortsLoad.includes(self) then
			cmqfVCS.allPortsLoad.remove(self);
		endif;
	endwhile; 
	delete iter;
	
	iter := CMQF_VoyageSummary.instances.createIterator;
	while iter.next(cmqfVS) do
		if cmqfVS.allPortsDischarge.includes(self) then
			cmqfVS.allPortsDischarge.remove(self);
		endif;
	endwhile; 
	delete iter;

	inheritMethod(_eraseLevel);

epilog
	delete iter;
end;</source>
        <Parameter name="_eraseLevel" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getCountryCodeForDisplay" id="86062f11-5ef0-44c3-8e5a-72a275f7ab63">
        <source>getCountryCodeForDisplay( _delimiter : String ) : String;

/*
	cnwrl1	29/05/2009		PAR 19672 - Have added a delimiter parameter because if using this method
							in a table display do not want to add an extra Tab to the display string
							as this shifts the subsequent columns to the right.
 
*/

vars
	tmpCountry	: CM_Country;
	
begin
	tmpCountry := self.myCountry;
	if tmpCountry &lt;&gt; null then
		return tmpCountry.code;
	else
//		return Tab;			// cnwrl1 27/05/2009 PAR 19672 - what it was
		if _delimiter = null then
			return Tab;
		else
			return _delimiter;
		endif;
	endif;
	
end;</source>
        <Parameter name="_delimiter" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDisplayDetails" id="897ed4a8-455a-4cad-b0f1-fe84b3062b45">
        <source>getDisplayDetails(_short: Boolean): String;
// ---------------------------------------------------------------------------
// Created:     Aug 2004	cnwrs1
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars

begin

	if _short then
		return self.code;
	else
		//return self.code&amp;'  '&amp;self.description;
		return self.description &amp; '  (' &amp; self.code &amp; ')';		
	endif;

end;</source>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDisplayFormatted" id="65230893-f99f-45e4-af20-3167d68c1171">
        <source>getDisplayFormatted(_portCmbOrderDescrFirst : Boolean): String;
//
// cnwrs1 June 2006 Port code 3 to 5 upgrade
//
vars
	
begin
	if _portCmbOrderDescrFirst = true then
		return self.description &amp; ' - (' &amp; self.code &amp; ')';
	else
		if self.myCountry &lt;&gt; null then
			return self.portCode &amp; ' (' &amp; self.myCountry.code &amp; ') ' &amp; self.description; // note myCountry is mandatory, can't be null
		else
			return self.portCode &amp; ' ' &amp; self.description; // note myCountry is mandatory, can't be null
		endif;
	endif;		

end;</source>
        <Parameter name="_portCmbOrderDescrFirst" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="121a57e5-3ef2-4701-83e4-1d37d4625df4">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
// ---------------------------------------------------------------------------
// Created:     15 April 2014 by cnwdb2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 15 Apr 2014	cnwdb2		PAR #33977  
// ---------------------------------------------------------------------------

vars

begin

	if _attrName = ETRow_IsPort then
		return self.bIsPort.String ; 
	elseif _attrName = ETRow_IsRail then
		return self.bIsRail.String ; 
	elseif _attrName = ETRow_IsRoad then
		return self.bIsRoad.String	;
	elseif _attrName = ETRow_IsAirport then
		return self.bIsAirport.String  ;
	elseif _attrName = ETRow_IsPostalExchange then
		return self.bIsPostalExchange.String  ;
	elseif _attrName = ETRow_IsMultiModal then
		return self.bIsMultiModal.String  ;
	elseif _attrName = ETRow_IsFixedTransport then
		return self.bIsFixedTransport.String  ;
	elseif _attrName = ETRow_IsBorderCrossing then
		return self.bIsBorderCrossing.String  ;
	endif ; 



	return inheritMethod(_attrName, _short);

epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getName" id="b587c319-757e-4445-b720-e930233916e3">
        <source>getName(): String;
// ---------------------------------------------------------------------------
// Created:		August  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin
	return inheritMethod &amp; '  ' &amp; self.code;


end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getYADisplay" id="31bc1dca-ef0d-467a-a9d1-2ea4c5df1c13">
        <source>getYADisplay(): String;
// --------------------------------------------------------------------------------
// Created:		08 March 2005 by cnwdad1:2
//
// Purpose:		Refer to superclass implementation.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 16/12/2008	consw1		SFW1030 - Changed display to be consistant with other forms
// --------------------------------------------------------------------------------
begin
//	return self.description &amp; ' - (' &amp; self.code &amp; ')';

	if self.myCountry &lt;&gt; null then
		return self.portCode &amp; ' (' &amp; self.myCountry.code &amp; ')' &amp; Tab &amp; self.description;
	endif;

	return self.code &amp; Tab &amp; self.description;

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
