<PrimType name="Time">
    <JadeMethod name="displayWithMilliseconds" id="0fa2615b-e727-4867-8d16-bebb77af496b">
        <source>displayWithMilliseconds() : String;

/*

Purpose:			


Return Value:		


Date		Who		Reason
02 November 2004	cnwkpd1	PAR #4801 - Web Service application

*/

vars

begin
	return self.String &amp; "." &amp; self.milliSecond.String.padLeadingZeros(3);


epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
</PrimType>
