    <JadeMethod name="updateTI" id="fc5850ca-37ec-43c2-b2a8-3b320a5a2ace">
        <updating/>
        <source>updateTI(_passport: CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:     27 August 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
// 26/09/2008	concms1	par 16130 - new parameter for clearPIN method
// 06/11/2019	jlgsl4	TFS 46767 - PEN - GenSet Trailer Linking

vars
	ti, parentTI : CM_TrackedItem; // --&gt; TFS 46767
	generator : CM_Generator;
	parentTIMaster, generatorTIMaster : CM_TIMaster;
	txnParameters : CMIF_MoveTransactionController; // &lt;-- TFS 46767
begin
	inheritMethod(_passport);
	
	// store PIN here (ccms-1037)
	ti := self.myTrackedItem;
	if ti &lt;&gt; null
	and ti.myPinNo &lt;&gt; null then
		if self.pinNo = null then
			self.pinNo := ti.myPinNo.pinNo;
		endif;
		
		// cnwrd1 par 22624 3.5.2010 
		/*
		// 18/05/2009 cnwar2 CCMS1723/#???
		if ti.myTerminal.getConfig(PinEmbargoDays).Integer &lt;&gt; 0 then
			ti.embargoPIN(true);
		else
			ti.clearPIN(true);	// par 16130
		endif;
		*/
	endif;
/*	if ti &lt;&gt; null and app.myRoot.getConfig(AutoLinkRefTraGen).Boolean and not app.isInProformaMode then // --&gt; TFS 46767
		if ti.isA(CM_TILC) then
			generator := ti.CM_TILC.myGenerator;
		elseif ti.isA(CM_Container) and ti.CM_Container.myReeferProperties &lt;&gt; null then // it's a real reefer not a ti.isReefer...
			generator := ti.CM_Container.myReeferProperties.generator;
		endif;
		if generator &lt;&gt; null then
			if app.myRoot.findTIMasterByCargoType(generator.cargoType, generator.id) = null then // no TIMasterGenerator exists
				create txnParameters transient;
				txnParameters.type := TRANS_TYPE_REC_ROAD; // so create ReceiveRoad against generator
				generator.createTransaction(txnParameters, app.myPassport); // which'll create the TIMaster
				return;
			endif;
		endif;
		if ti.isA(CM_Generator) then // ti's a generator
			parentTI := ti.CM_Generator.myChassis; // is its parent a TILC?
			if parentTI = null and ti.CM_Generator.reefersRelatedTo.size = 1 then // parent isn't a TILC, is it a reefer?
				parentTI := ti.CM_Generator.reefersRelatedTo.first.myParent.CM_TrackedItem;
			endif;
			if parentTI &lt;&gt; null then // parent's either a TILC or reefer
				parentTIMaster := app.myRoot.findTIMasterByCargoType(parentTI.cargoType, parentTI.id);
				if parentTIMaster &lt;&gt; null then // parent TIMaster exists
					generatorTIMaster := app.myRoot.findTIMasterByCargoType(ti.cargoType, ti.id);
					if generatorTIMaster &lt;&gt; null then // generator's TIMaster exists =&gt; attach generator TIMaster to parent TIMaster
						parentTIMaster.allTIMasterAttachees.clear(); // remove any currently attached generator
						parentTIMaster.allTIMasterAttachees.add(generatorTIMaster);
					endif;
				endif;
			endif;
		endif; 
	endif; */
	
	//21 July 2021	NDL	TFS 51570
//	if ti &lt;&gt; null and not ti.isKindOf(CM_Generator) and not app.isInProformaMode then
	if ti &lt;&gt; null and ( ti.isKindOf(CM_TILC) or ti.isKindOf(CM_Container) ) and not app.isInProformaMode then	//31 Aug 2021	NDL	TSF 51570
		if not ti.isKindOf(CM_Generator) then //because a generator can be a container...
			generator := ti.getGenerator;
		endif;
		if generator &lt;&gt; null then
			create txnParameters transient;
			txnParameters.type := TRANS_TYPE_REC_ROAD; // so create ReceiveRoad against generator
			generator.createTransaction(txnParameters, app.myPassport); 	
			ti.doAutoLinkDelinkGeneratorCont(	true,	//_attach : Boolean;	
												generator,	//_generator : CM_TrackedItem input;
												ti	//_containerOrTILC : CM_TrackedItem input
												);
		endif;
	endif;
	
epilog
	delete txnParameters; // &lt;-- TFS 46767
end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
</Class>
