    <JadeMethod name="cnEcGetDuplicate" id="9a279031-f5a8-442b-9c07-3f14a55e75c2">
        <source>cnEcGetDuplicate(pFormat: CnEcXmlFormat; pInput: CnEcXmlStructureInstance): Object;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 September 2014	cnwndl1	Initial creation	Par 34893

*/

vars

	code : String;
	damage : CM_DamagePosition;

begin

	code := self.cnEcXMLGetTheAttributeValue( pFormat, pInput, self.class.name, "code" ).String; 
	
	if code &lt;&gt; null then
		damage := app.myRoot.allDamagePositionsByCode.getAtKey( code );
	endif;

epilog

	return damage;

end;</source>
        <Parameter name="pFormat" type="CnEcXmlFormat"/>
        <Parameter name="pInput" type="CnEcXmlStructureInstance"/>
        <ReturnType type="Object"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="6527a047-eca9-4cdb-8d20-c0c740357b7a">
        <updating/>
        <source>setForCreate(_pxyDamagePosition : CM_DamagePosition) updating;
//----------------------------------------------------------------------
//  Created by cnwsh3
//	Date 03 July 2009
//
// Implemented version: 7.7.3
// CCMS SFW1066  - Recording Damage Details Changes.
//----------------------------------------------------------------------
vars
	cargoType : CM_CargoType;
begin
	self.setForUpdate(_pxyDamagePosition);
epilog
end;</source>
        <Parameter name="_pxyDamagePosition" type="CM_DamagePosition"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="000f1219-abd2-4dd8-96f1-700e3a57b0eb">
        <updating/>
        <source>setForUpdate(_pxyDamagePosition : CM_DamagePosition)updating;
//----------------------------------------------------------------------
//  Created by cnwsh3
//	Date 22 July 2009
//
// Implemented version: 7.7.3

//----------------------------------------------------------------------
vars

begin
	self.allActiveCargoTypes.clear();
	self.allMachineTypes.clear();
	
	self.description 			:= _pxyDamagePosition.description;
	self.code 					:= _pxyDamagePosition.code;
	self.isNotAvailableForEntry := _pxyDamagePosition.isNotAvailableForEntry;
	
	self.myRoot					:= app.myRoot;
	
	_pxyDamagePosition.allMachineTypes.copy(self.allMachineTypes);
	_pxyDamagePosition.allActiveCargoTypes.copy(self.allActiveCargoTypes);
epilog
end;</source>
        <Parameter name="_pxyDamagePosition" type="CM_DamagePosition"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="ebd92a88-a665-4bc6-aa4d-29be893e115b">
        <updating/>
        <source>setProxy( _code, 
		  _description : String;
		  _isNotAvailableForEntry : Boolean;
		  _cargoTypes : ObjectSet;
		  _machineTypes : ObjectSet) updating;
//----------------------------------------------------------------------
//  Created by cnwsh3
//	Date 03 July 2009
//
// Implemented version: 7.7.3
// CCMS SFW1066  - Recording Damage Details Changes.
//----------------------------------------------------------------------
vars
	obj : Object;
	cargoType : CM_CargoType;
begin
	self.raiseExceptionIfNotTransient(method);
	//write null;	// 06/01/2010 cnwar2 #22094
	self.code 			:= _code;
	self.description 	:= _description;
	self.isNotAvailableForEntry := _isNotAvailableForEntry;

	self.allMachineTypes.clear();
	self.allActiveCargoTypes.clear();

	//Copy collections of machine types
	_machineTypes.copy(self.allMachineTypes);
	//Copy collections of cargo types
	_cargoTypes.copy(self.allActiveCargoTypes);
epilog
end;</source>
        <Parameter name="_code" type="String"/>
        <Parameter name="_description" type="String"/>
        <Parameter name="_isNotAvailableForEntry" type="Boolean"/>
        <Parameter name="_cargoTypes" type="ObjectSet"/>
        <Parameter name="_machineTypes" type="ObjectSet"/>
    </JadeMethod>
    <JadeMethod name="validateForCreate" id="597500bf-1b36-4e7c-b6ed-048adeab1a15">
        <source>validateForCreate();
//----------------------------------------------------------------------
//  Created by cnwsh3
//	Date 03 July 2009
//
// Implemented version: 7.7.3
//
// CCMS SFW1066  - Recording Damage Details Changes. 
//----------------------------------------------------------------------
vars
	
begin
	if self.code = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Code', ETRow_Code, self);
		app.raiseCMException(Input_required_field_code, ETRow_Code, self);

	endif;
	
	if self.description = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Description', ETRow_Description, self);
		app.raiseCMException(Input_required_field_Desc, ETRow_Description, self);
	endif;
epilog
end;</source>
    </JadeMethod>
    <JadeMethod name="validateForDelete" id="dd36fe44-0da3-461f-972c-728e6cd2a1dd">
        <source>validateForDelete();
//----------------------------------------------------------------------
//  Created by cnwsh3
//	Date 07 July 2009
//
// Implemented version: 7.7.3
// CCMS SFW1066  - Recording Damage Details Changes.
//----------------------------------------------------------------------
vars
	damageEntity : Object;
	cargoCode : String;
begin
	//If I'm used in any damage instances then I can't be deleted.
	if self.allDamageInstances.isNotEmpty then
		app.raiseCMException1(Cannot_Delete_DamagePos, self.code, null, null);
	endif;
	
	if self.allActiveCargoTypes.isNotEmpty then
		app.raiseCMException2(DamagePosAllocatedCargoType, self.code, self.allActiveCargoTypes.first.abbreviation, null, null);
	endif;
	
	if self.allMachineTypes.isNotEmpty then
		app.raiseCMException2(DamagePositAllocMachType, self.code, self.allMachineTypes.first.description, null, null);
	endif;

epilog
end;</source>
    </JadeMethod>
