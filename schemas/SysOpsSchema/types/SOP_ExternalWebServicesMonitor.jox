    <JadeMethod name="setEntTableDef" id="ed01a568-896c-4c25-8a41-38446b5458fa">
        <source>setEntTableDef() protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 November 2022	navpw1	Initial creation TFS: 55215
02 December 2024	navrv30	JIRA 33578 EUP | Incoming API Logging
*/

vars
	table : CM_DataTable;
	entDef : EntTableDef;
	colCompareValue : Integer;
	entDefName : String;
	
begin
	table := self.tblData;

	table.clear();
	table.fixedRows := 1;
	table.rows := 1;
	
	if self.isEDBIC then
		entDefName := ETDef_EWSActivityEDBIC;
	elseif self.isAPILog then
		entDefName := ETDef_EWSActivityAPILog;  //02 December 2024	navrv30	JIRA 33578
	else
		entDefName := ETDef_EWSActivityMonitor;
	endif;
	
	entDef := app.myController.getEntTableDef(entDefName);
	table.setTblDataEntRowsFromDef(entDef);
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setFormObject" id="d924b800-f08a-4517-8330-34cc0c937896">
