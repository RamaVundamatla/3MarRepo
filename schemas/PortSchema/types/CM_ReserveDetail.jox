    <JadeMethod name="getInstructionsForContext" id="061bed04-b82d-48db-bd63-325af9e364fb">
        <source>getInstructionsForContext(_instructions: CM_InstructionsIssuedSet io; _passingObject: Object; _context: String);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 Oct 2023	navnk30	ChangeRequest 59946: EUP - Additional Operational Instructions on the Order - Enhancement 2
19 Oct 2023	navma1 Defect 60923: MTN - Exception when selecting the Job Type as Truck Load on the Work Order Operations app
07 Nov 2023 navnk30 ChangeRequest 60646: EUP | Mobile DD - [53891.060] - Special Instructions in the Mobile App
10 Nov 2023 navnk30 ChangeRequest 60646: EUP | Mobile DD - [53891.060] - Special Instructions in the Mobile App
25 Mar 2025 navbs1 Bug MTN-34396: EUP | Additional Operational Instructions - more issues (part 2)
*/

vars
	bulk 	: CM_BulkRelease;
	wodDtl	: CM_WorkOrderDtl;
	wo		: CM_WorkOrder;
	parentReserveDtl  : CM_ReserveDetail;
begin
	_instructions.tryAddIfNotNull(self.myInstructions);			//07.11.2023 navnk30 #60646
	if _context = Truck_Load then
		
		bulk := self.myReserveHeader;
		
		//if _instructions.isEmpty then							//10.11.2023 navnk30 #60646
		if bulk &lt;&gt; null then									//10.11.2023 navnk30 #60646
			_instructions.tryAddIfNotNull(bulk.myInstructions);
		endif;
		
		//if _instructions.isEmpty then							//10.11.2023 navnk30 #60646
		wodDtl := self.allWodReleases.first;
		
		if wodDtl &lt;&gt; null then
			wo := wodDtl.myParent;
			_instructions.tryAddIfNotNull(wodDtl.myInstructions);
			
//			if _instructions.isEmpty then						//10.11.2023 navnk30 #60646
			if wo &lt;&gt; null then									//10.11.2023 navnk30 #60646
				_instructions.tryAddIfNotNull(wo.myInstructions);
			endif;
		endif;
		//endif;						//10.11.2023 navnk30 #60646	
		
	//elseif _context = Pack_by_Request then						//07.11.2023 navnk30 #60646
	elseif _context = Pack_Cargo then								//10.04.2025 navbs1 #34396				
		bulk := self.myReserveHeader;
		if bulk = null then
			return;
		endif;
		_instructions.tryAddIfNotNull(bulk.myInstructions);		//10.11.2023 navnk30 #60646
		
		//get the parent reserve Detail
		parentReserveDtl := bulk.allReserveDetails.first;							//25.03.2025 navbs1 #34396
		if parentReserveDtl &lt;&gt; null then 											//25.03.2025 navbs1 #34396
			_instructions.tryAddIfNotNull(parentReserveDtl.myInstructions);			//25.03.2025 navbs1 #34396
		endif;
		
		//wodDtl := bulk.allWOReleases.first;						//10.11.2023 navnk30 #60646
		wodDtl := bulk.allWOPacks.first;						//10.11.2023 navnk30 #60646
		if wodDtl= null then
			return;
		endif;
		
		wo := wodDtl.myParent;
		if wo &lt;&gt; null then
			_instructions.tryAddIfNotNull(wo.myInstructions);
		endif;
	endif;
	
	/*if self.isKindOf(CM_ReserveTI) then						//10.11.2023 navnk30 #60646
		ti := self.CM_ReserveTI.getTI();
		if ti &lt;&gt; null then
			_instructions.tryAddIfNotNull(ti.myInstructions);
		endif;
	endif;
	*/
epilog

end;</source>
        <Parameter name="_instructions" type="CM_InstructionsIssuedSet" usage="io"/>
        <Parameter name="_passingObject" type="Object"/>
        <Parameter name="_context" type="String"/>
    </JadeMethod>
