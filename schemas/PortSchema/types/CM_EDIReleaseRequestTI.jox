    <JadeMethod name="assignValueSpecial" id="44298f0b-3347-4d6b-84f3-99168d1ac040">
        <updating/>
        <source>assignValueSpecial(_propName: String; _processedValue: String; _xlationOperator: CM_Operator): Boolean updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 Feb 2017	cnwndl1	Initial creation	TFS 3386
13 Jun 2022	jlika1	TFS 53316 - EUP - GEN - Additional Dimensions For Cargo - PortSchema
4 sept 2024 	navsaa30 Bug 63853: EUP | FR 53158 (CARGO ON SHIP) - Additional Fields - EDI loaded dimensions are not processed correctly (Precision issue)
*/

vars

begin

	if _propName = ETRow_ExpiryDate then
		if  _processedValue.Date.isValid then
			self.expiryTimeStamp.setDate( _processedValue.Date );
		endif;
		return true;
		
	elseif _propName = ETRow_ExpiryTime then
		if  _processedValue.Time.isValid then
			self.expiryTimeStamp.setTime( _processedValue.Time );
		endif;
		return true;
	// jlika1 TFS 53316 --&gt;
	elseif _propName = ETRow_Diameter then
		self.diameter := _processedValue.asDecimalJMT;			//4/9/24  navsaa30  #63853
		return true;
	elseif _propName = ETRow_RollingLength then
		self.rollingLength := _processedValue.asDecimalJMT;			//4/9/24  navsaa30  #63853
		return true;	
	// jlika1 TFS 53316 &lt;--	
	endif;

	return inheritMethod(_propName, _processedValue, _xlationOperator);

epilog

end;</source>
        <Parameter name="_propName" type="String"/>
        <Parameter name="_processedValue" type="String"/>
        <Parameter name="_xlationOperator" type="CM_Operator"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="canUserSet" id="c1995213-789f-4af6-b090-74ec4af689fd">
        <source>canUserSet(_propName: String): Boolean;
//
// 15 Jun 2017	cnwrs1	TFS 4462 SNO add Terminal Operator, Unknown Seal and support multiple seals
//
vars

begin
	if _propName = CM_EDIReleaseRequestTI::directDelivery.name or	// Booking Item/Release Request is allowed to use this field
	   _propName = CM_EDITrackedItem::subTerminalCode.name then	// Booking Item/Release Request is allowed to use this field
		return true;
	else
		return inheritMethod(_propName);
	endif;
end;
</source>
        <Parameter name="_propName" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="createWarningForReleaseByID" id="da01e83e-4f64-4f70-a6e2-ebf197282ed6">
        <source>createWarningForReleaseByID()  : Boolean;
/*

Date		Who		Reason
06 September 2016	cnwer1	Initial creation TFS 2606
// 04 Mar 2019	jlgrs1	TFS 41913 STWR - Reconfiguration of the EDI Operation form to better handle EDI collection locks while loading 
*/

vars
	coparnRules					:CM_EDIPartyCoparnRules;
begin	 

	
	if self.releaseByType then //cnwrd1 par 34035
		return false;
	endif;
	
	if self.myEDIData = null then
		return false;
	endif;
	
	if self.myEDIData.myEDIFile = null then
		return false;
	endif;
	
	if not self.myEDIData.myEDIFile.myEDIFileType.isKindOf(CM_EDIFileTypeCoparn) then
		return false;
	endif;
	
	coparnRules := self.myEDIData.CM_EDIDataReleaseRequest.getEDIPartyCoparnRules (self.senderCode);

	if coparnRules = null then
		return false;
	endif;
	

	return coparnRules.getRelByTypeOnly();

epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="delete" id="b11be725-6adf-47a6-aacd-7706496b3766">
        <updating/>
        <source>delete() updating;
/*
Date			Who		Reason
14 June 2010	cnwrl1	Initial creation as part of PAR 24299 - SFW 1118 EDI Form to allow searching of EDI file by Container / Voyage
18/02/2013		cnwcs5	Minor re-work
*/
	
vars
	config	: CM_EDIConfig;
	code	: String;
	coll	: CM_EDITIsByVoyageCodeDict;
begin
	// remove this EDITrackedItem from the manual collection on myEDIConfig if it is there
	config := self.myEDIConfig;
	
	if config = null then
		return;
	endif;
	
	code	:= self.getConsignorVoyage().toUpper;
	
	if code &lt;&gt; null then
		coll := config.allEDITrackedItemsByVoyageCode;
		
		if coll.includesKey( code, self ) then
			coll.removeKeyEntry( code, self, self );
		endif;
	endif;
	
epilog
	
end;
</source>
    </JadeMethod>
    <JadeMethod name="destinationPort" id="21777fb7-b03a-4aad-8346-ffb5de3bb6a4">
        <methodInvocation>mapping</methodInvocation>
        <source>destinationPort( set : Boolean; _value : String io ) mapping;
/*
Purpose:	protected the old 3 digit codes

Date				Who		Reason
31 August 2009		cnwrl1	Initial creation as part of PAR 20318 - MES 1011 Web EDI Link
*/
	
vars
	port	: CM_Port;
	
begin
	if set then
		return;
	endif;
	
	if self.destinationPort.length = 3 then
		port	:= app.myRoot.allLocodesByShortCode.getAtKeyGeq( self.destinationPort, null );
		
		if port &lt;&gt; null and port.portCode = self.destinationPort then
			_value	:= port.code;
		else
			_value	:= self.destinationPort;
		endif;
	else
		_value		:= self.destinationPort;
	endif;
	
epilog
	
end;
</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="dischargePort" id="25ff3bf4-bc68-4582-b169-0891a7a2a0b4">
        <methodInvocation>mapping</methodInvocation>
        <source>dischargePort( set : Boolean; _value : String io ) mapping;

/*
Purpose:	protected the old 3 digit codes

Date				Who		Reason
31 August 2009		cnwrl1	Initial creation as part of PAR 20318 - MES 1011 Web EDI Link
*/
	
vars
	port	: CM_Port;
	
begin
	if set then
		return;
	endif;
	
	if self.dischargePort.length = 3 then
		port	:= app.myRoot.allLocodesByShortCode.getAtKeyGeq( self.dischargePort, null );
		if port &lt;&gt; null and port.portCode = self.dischargePort then
			_value	:= port.code;
		else
			_value	:= self.dischargePort;
		endif;
	else
		_value		:= self.dischargePort;
	endif;
	
epilog
	
end;
</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="doTranslations" id="6e426c5f-145b-47b5-ad34-9267500ea1aa">
        <updating/>
        <source>doTranslations(_xlationOperator: CM_Operator) updating;
//25 Jun 2015	cnwrs1	Par 33901/36027 - Default booking commodity
// 19 Mar 2019	jlgrs1	TFS 41913 STWR - Reconfiguration of the EDI Operation form to better handle EDI collection locks while loading 
// 28 May 2025	naviv1	MTN-34391 - POL - EDI Data Translation - Availability Grade Temperature Issue
//
vars
	criteria : String;
	grade : String;
	text : String;
	code : String;
	foundMatch : Boolean;
	temp : Real;
	isZeroTemp : Boolean;
begin
	inheritMethod(_xlationOperator);
	
	grade := self.availabilityGrades;
	if grade = null then 
		return;
	endif;
	
	global.getExtraData(self.getAllExtraData, ETRow_AvailabilityGrade, text);	
	
	global.getExtraData(self.getAllExtraData, ETRow_Temperature, criteria);
	
	isZeroTemp := self.remarks.cnContains("CEL") or self.remarks.cnContains("FAH"); //MTN-34391

	if criteria = null then
		if isZeroTemp then	//MTN-34391
			temp := null;
		else
			temp := NULL_TEMPERATURE;
		endif;
		if text &lt;&gt; null then
			grade := text;
			text := null;
		endif;
	else
		temp := criteria.Real;
	endif;

	// currently there is only one MT Grade stored
	if _xlationOperator &lt;&gt; null then
		code := _xlationOperator.getXlationSystemCode_MTGrade(grade, foundMatch, temp, text); 
		if foundMatch then
			self.availabilityGrades := code;
		else
			//epr TFS 4275 8/5/17 there was something stored in the text that was different to the grade
			//and there was a temp
			if text &lt;&gt; null and text &lt;&gt; grade then
				grade := text;
				text := null;
				code := _xlationOperator.getXlationSystemCode_MTGrade(grade, foundMatch, temp, text); 
				if foundMatch then
					self.availabilityGrades := code;
				endif;
			endif;
			
		endif;
	endif;
end;
</source>
        <Parameter name="_xlationOperator" type="CM_Operator"/>
    </JadeMethod>
    <JadeMethod name="findReserveDetail" id="ae0a684c-f7f5-45c3-b063-12e6c98c90d2">
        <source>findReserveDetail() : CM_ReserveDetail;
/*

Date		Who		Reason
15 September 2016	cnwer1	Initial creation TFS 2606

*/

vars
	bulkRelease : CM_BulkRelease;
	reserveDetail : CM_ReserveDetail;
	ti : CM_TrackedItem;
begin

	bulkRelease := self.getBulkRelease();
	if bulkRelease = null then
		return null;
	endif;
	
	foreach reserveDetail in bulkRelease.allReserveDetails discreteLock do
		if bulkRelease.releaseByType then
			if reserveDetail.CM_ReserveSelection.isEDIMatch(self,true) then
				return reserveDetail;
			endif;
		else
			ti:=reserveDetail.CM_ReserveTI.getTI;
			if ti &lt;&gt; null and ti.id = self.id then
				return reserveDetail;
			endif;
		endif;
			
	endforeach;
	
	if bulkRelease.releaseByType then	
		foreach reserveDetail in bulkRelease.allReserveDetails discreteLock do			
				if reserveDetail.CM_ReserveSelection.isEDIMatch(self,false) then
					return reserveDetail;
				endif;						
		endforeach;
	endif;
	
	return null;
epilog

end;</source>
        <ReturnType type="CM_ReserveDetail"/>
    </JadeMethod>
    <JadeMethod name="findTrackedItem" id="c80a00a4-4f47-4d17-a655-ab1a77b2c3c4">
        <source>findTrackedItem(_release :CM_BulkRelease):CM_TrackedItem;
/*

Date		Who		Reason
06 September 2016	cnwer1	Initial creation TFS 2606

*/

vars

	ti	:CM_TrackedItem;
begin
	ti := self.getMyTerminal.lookupTrackedItem(self.id, self.cargoType, TI_STATE_UNDEFINED, null, false);
	
	if ti &lt;&gt; null then
		return ti;
	endif;
	
	if _release = null then
		return null;
	endif;
	
	//maybe it has already been released
	foreach ti in _release.allTrackedItemsReleased do
		if ti.id = self.id and ti.cargoType = self.cargoType then
			return ti;
		endif;
	endforeach;
	
	return null;
	
epilog

end;</source>
        <Parameter name="_release" type="CM_BulkRelease"/>
        <ReturnType type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="getAllAvailabilityGrades" id="58b0ff1b-1fa1-4805-9c6a-2b0b51f78f1e">
        <source>getAllAvailabilityGrades(_allAvailabilityGrades:IntegerArray input);
// --------------------------------------------------------------------------------
// Created:		13 October 2010
//
// Purpose:		Attempt to break up the receiver's string of availability grades into
//				the appropriate integers, and then add these integers to the array
//				parameter.
//
// Parameters:	_allAvailabilityGrades - An array of Availability Grades.
//
// Returns:		The populated integer array.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//				cnwdad1		Initial creation.
// --------------------------------------------------------------------------------
vars
	allStrings	: HugeStringArray;
	element		: String;
	availGrade	: Integer;
	
begin
	create allStrings transient;
	
	if self.availabilityGrades.trimBlanks() &lt;&gt; null then
		_allAvailabilityGrades.clear();
		self.availabilityGrades.trimBlanks().getHugeTokensForDelimiter(Space.Character, allStrings);
		
		foreach element in allStrings do
			if element.trimBlanks() = null then
				continue;
			endif;
			
			if element.isInteger() then
				availGrade	:=	element.Integer;
				_allAvailabilityGrades.add(availGrade);
			else
				app.raiseCMException1(Avail_Grade_Must_B_Integer, element, ETRow_AvailabilityGrades, self);
			endif;
		endforeach;
	endif;
epilog
	delete allStrings;
end;</source>
        <Parameter name="_allAvailabilityGrades" type="IntegerArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getBulkRelease" id="b956116c-4cc4-46cd-af87-7b1a50064ee6">
        <source>getBulkRelease() : CM_BulkRelease;
/*

Date		Who		Reason
07 Sep 2016	cnwer1	Initial creation TFS 2606
28 Jul 2025 navma1 MTN-35577  MTN - Error 1081 While doing Road Receive Transaction with CM_BulkReleaseByCodeDict
*/

vars
	term       : CM_Terminal;
begin
	term := self.getMyTerminal;
	
	if self.requestDate &lt;&gt; null and self.requestDateDoUpdate and term.getConfig(AllowDuplicateReleaseNos).Boolean then //28.07.2025 navma1 #MTN-35577
		return term.getBulkReleaseFromCodeDate(self.releaseRequestNumber,self.requestDate);
	else
		return  term.getBulkReleaseFromCode(self.releaseRequestNumber);
	endif;
epilog

end;</source>
        <ReturnType type="CM_BulkRelease"/>
    </JadeMethod>
