    <JadeMethod name="camsRunAdhoc" id="bcfd6ca3-1254-4393-8299-c582e5506756">
        <source>camsRunAdhoc();
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 13 March 2023	navdap1		Initial creation TFS 
//
constants
	//CAMProtocol : String = "STW_CAms_receiveShip";
	//CAMProtocol : String = "Suzano Delivery Confirmation";
	CAMProtocol : String = "ag gateway test";
	/*StartDate	: Date = '20/10/2023'.Date;// setup start and end dates/time and protocol to use
	EndDate1	: Date = '20/10/2023'.Date;
	StartTime	: Time = '13:00:00:000'.Time;
	EndTime		: Time = '15:00:00:000'.Time;*/
	StartDate	: Date = '01/09/2025'.Date;// setup start and end dates/time and protocol to use
	EndDate1	: Date = '01/09/2025'.Date;
	StartTime	: Time = '10:30:00:000'.Time;
	EndTime		: Time = '23:59:00:000'.Time;
	//Terminal1	: String = 'SPT';
	Terminal1	: String = 'RAM';
vars
	camProtocol		: CM_CamProtocol;
	runDateTime		: TimeStamp;
	startDateTime	: TimeStamp;
	endDateTime		: TimeStamp;
	valDate			: Date;
	valTime			: Time;
	terminal		: CM_Terminal;
	camsController : CM_CamControllerAgent;
begin
	app.initialize();
	app.changeLogLevel(LogDEBUG);
	// setup start and end dates/time and protocol to use
	valDate := StartDate;
	valTime := StartTime;
	startDateTime.setDate(valDate);
	startDateTime.setTime(valTime);
	if not startDateTime.isValid() then
		write 'startDateTime is not valid';
		return;
	endif;
	
	valDate := EndDate1;
	valTime := EndTime;
	endDateTime.setDate(valDate);
	endDateTime.setTime(valTime);
	if not endDateTime.isValid() then
		write 'endDateTime is not valid';
		return;
	endif;
	
	runDateTime := app.actualTimeServer;
	app.hideDebug	:= false;			// false implies do not hide debugging - helps with display messages
	terminal		:= app.myRoot.allTerminals[Terminal1];
	if terminal = null then
		app.writeStatement('Can not find required terminal ' &amp; Terminal1);
		return;
	endif;
	app.myPassport.setMyTerminal(terminal);
	
	camProtocol := terminal.camProtocols[CAMProtocol];
	if camProtocol = null then
		app.writeStatement("Cannot find required cam protocol description");
		return;
	endif;
	
	app.myPassport.setMyUserFromCode(SUPERUSER_Str);
	
	on Exception do null global;
	
	app.setPassBackExceptions(true, true);
	create camsController transient;
	camsController.setMyTerminal(terminal);
	camsController.adhocTask(camProtocol, startDateTime, endDateTime, runDateTime, true, true);	//this does runs the adhoc cams
epilog
	delete camsController;
end;</source>
    </JadeMethod>
    <JadeMethod name="changeCamsHistoryDT" id="7db54666-12bf-4c12-bcc0-7478a40aad92">
        <source>changeCamsHistoryDT();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 September 2025	navnk30	Initial creation

*/

vars
	str			: String;
	camHistory	: CM_CamTaskHistory;
	ts			: TimeStamp;
begin
	ts.setDate("01-08-2025".Date);
	read str;
	app.closeWriteWindow();
	camHistory := str.asOid().CM_CamTaskHistory;
	write camHistory.endDateTime;
	write camHistory.startDateTime;
	write camHistory.runDateTime;
	beginTransaction;
		camHistory.set(ts, ts, ts, camHistory.logExcludedTransactions, camHistory.camProtocol, camHistory.seqNumber, camHistory.dailySeqNumber, "NW_Script", camHistory.status, camHistory.errorMessage);
epilog
	commitTransaction;
	
	write camHistory.endDateTime;
	write camHistory.startDateTime;
	write camHistory.runDateTime;
end;</source>
    </JadeMethod>
    <JadeMethod name="createReqs" id="17a0ec87-be55-441b-9321-d298345a7412">
        <source>createReqs();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 September 2025	navnk30	Initial creation

*/

vars
	ewsType			: CM_EWS_Type_AgGateway;
	epShipNotice	: CM_EWSEP_ShipNotice;
	epOrderResp		: CM_EWSEP_OrderResponse;
begin
	app.initialize();
	
	beginTransaction;
		create ewsType;
		create epShipNotice;
		create epOrderResp;
		ewsType.setMyRoot();
		epShipNotice.setMyRoot();
		epOrderResp.setMyRoot();
epilog
	commitTransaction;
end;</source>
    </JadeMethod>
    <JadeMethod name="createYaraProductsNPK" id="d7e810a5-7403-4390-bb27-d955a60339fa">
        <source>createYaraProductsNPK();
vars
    npkList 		: StringArray;  // dynamic array of strings
    i       		: Integer;
	prodCode		: String;
	cargoType		: CM_CargoType;
	pxyProd,
	realProd		: CM_Product;
	allPxyProds,
	allRealProds	: CM_ProductArray;
	handlingType	: CM_HandlingType;
begin
    create npkList transient;

    // Straight / Balanced Blends
    npkList.add("NPK-10-10-10");
    npkList.add("NPK-12-12-12");
    npkList.add("NPK-15-15-15");
    npkList.add("NPK-16-16-16");
    npkList.add("NPK-20-20-20");

    // High Nitrogen
    npkList.add("NPK-23-10-5");
    npkList.add("NPK-25-5-5");
    npkList.add("NPK-30-10-10");

    // Phosphorus-focused
    npkList.add("NPK-10-26-26");
    npkList.add("NPK-12-32-16");
    npkList.add("NPK-16-20-0");

    // Potassium-rich
    npkList.add("NPK-15-15-30");
    npkList.add("NPK-12-24-24");

    // Specialized / regional blends
    npkList.add("NPK-17-17-17");
    npkList.add("NPK-18-24-12");
    npkList.add("NPK-27-6-6");
    npkList.add("NPK-6-24-24");
	
	 // Straight Nitrogen Fertilizers (like NH3, Urea)
    npkList.add("NPK-82-0-0");  // Anhydrous Ammonia
    npkList.add("NPK-46-0-0");  // Urea
    npkList.add("NPK-34-0-0");  // Ammonium Nitrate

	
	cargoType := "2083.27987".asOid().CM_CargoType;
	handlingType := "4950.576".asOid().CM_HandlingType;
	create allPxyProds transient;
	create allRealProds transient;
	app.initialize();
	app.myPassport.setMyTerminal("2351.1561".asOid().CM_Terminal);
    foreach i in 1 to npkList.size() do
		prodCode := npkList[i];
		beginLoad;
			create pxyProd transient;
			pxyProd.setProxy(cargoType, null, null, null, handlingType, null, null, prodCode, "Nitrogen-Phosphorus-Potassium", null, null, false, false, false, false, false, false);
		endLoad;
		app.myTrxCA.trxCreateProduct(pxyProd, realProd, app.myPassport);
		allPxyProds.add(pxyProd);
		allRealProds.add(realProd);
    endforeach;

    delete npkList;

epilog
	delete allRealProds;
	delete allPxyProds;
end;
</source>
    </JadeMethod>
