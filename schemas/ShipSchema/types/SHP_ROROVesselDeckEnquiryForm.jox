    <JadeMethod name="doShowDeckSortingForm" id="cbd362a9-47d8-4688-a362-d69d723d48f6">
        <source>doShowDeckSortingForm();
/*
Date		    Who			Reason
Dec 2011		cnwjre1		Par 28687 after CCMS 1035, implement RORO vessel deck re-ordering
*/

vars

begin
	if self.myROROVesselStructure &lt;&gt; null and not self.myROROVesselStructure.allDecks.isEmpty() then
		self.myAssistant.SHP_Assistant.showROROVesselDeckSortingForm(self, self.myROROVesselStructure);	
	endif;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doUserNotify" id="162fcaff-c5ff-4082-8a2a-e9d9e2b3eab9">
        <updating/>
        <source>doUserNotify(eventType: Integer; theObject: Object; eventTag: Integer; userInfo: Any) protected, updating;

vars

begin
	inheritMethod(eventType, theObject, eventTag, userInfo);
	// from 28687 vessel deck re-order, refresh self
	if eventType = EVENT_LOCATION_REFRESH and 
	   userInfo.isKindOf(CM_ROROVesselStructure) and
	   userInfo.CM_ROROVesselStructure = self.myROROVesselStructure then
		self.doRefresh();
	endif;
end;
</source>
        <access>protected</access>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
        <Parameter name="userInfo" type="Any"/>
    </JadeMethod>
