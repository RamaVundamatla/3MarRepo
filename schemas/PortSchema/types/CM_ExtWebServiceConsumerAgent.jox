    </JadeMethod>
    <JadeMethod name="doLogWebServiceCall" id="bc48382d-6147-48ed-9a09-b09d42266185">
        <updating/>
        <source>doLogWebServiceCall(_consumer : JadeWebServiceConsumer;
					_methodName : String) protected , updating;
/*

Purpose:			Perform any logging required of the input and output messages, following a call to the
					Web Service

Parameters:			Web Service consumer that has just processed the web service call
					Web Service method name that was called

Return Value:		None

Date		Who		Reason
13 Jun 2018	jlgkpd1	TFS #37190 - Pelindo 1 INAPORTNET Integration

*/

vars
	xmlHelper		: CM_XmlHelperAgent;
	requestString,
	responseString	: String;
		
begin
	// Get the request and response strings from the consumer
	requestString := _consumer.getPropertyValue(JadeWebServiceConsumer::soapRequest.name).String;
	responseString := _consumer.getPropertyValue(JadeWebServiceConsumer::soapResponse.name).String;
	
	// Log the sanitised versions of the request and response
	create xmlHelper transient;
	requestString := xmlHelper.hidePasswordFieldsForLogging(requestString);
	responseString := xmlHelper.hidePasswordFieldsForLogging(responseString);
	
	app.writeLog(method.qualifiedName &amp; " soapRequest=" &amp; requestString, LogDEBUG);	//25 Nov 2019	NDL	TFS 47053
	app.writeLog(method.qualifiedName &amp; " soapResponse=" &amp; responseString, LogDEBUG);	//25 Nov 2019	NDL	TFS 47053
	
	// If required, then create Activity History for this call as well
	if self.createActivityHistory then
		self.doCreateActivityHistory(_consumer, _methodName, requestString, responseString, 0);
	endif;
	
epilog
	delete xmlHelper;
	
end;</source>
        <access>protected</access>
        <Parameter name="_consumer" type="JadeWebServiceConsumer"/>
        <Parameter name="_methodName" type="String"/>
    </JadeMethod>
    <JadeMethod name="doSendHTTPRequest" id="56d91762-37b7-4d8a-aa24-8a89fc49204f">
        <updating/>
        <source>doSendHTTPRequest(_url : String;
				  _verb : String;
				  _additionalHeaders : String;
				  _putPostData : String;
				  _resultCode: Integer output) : String updating;
/*

Purpose:			Wrapper method for sending a single http request, handling any exceptions.  Sends the 
					request as defined, and returns the read response as a String

Parameters:			URL to send the request to
					HTTP Verb (GET, POST, etc)
					Any additional headers required
					Optional data for a PUT/POST request

Return Value:		String value returned if successful, or null if unsuccessful

Date		Who			Reason
21 Jun 2018	jlgkpd1		TFS #37190 - Pelindo 1 INAPORTNET Integration
15 Oct 2019 jlgrr1  	TFS 47042 - Cargo Chain Integration - Support valid empty responses
01 Mar 2022	navmd1		TFS 52952 - Log responses in Activity History, even if they aren't JSON
14 May 2024 navsaa30	ChangeRequest 61187: EUP | Error Message column in CAMS history tab not shown as expected
21 Oct 2024 navmd1		TFS 59895 / MTN-14636 Change JSON sanitisation from XML to Regex so value types are not lost
*/

vars
	conn				: JadeHTTPConnection;
	returnVal			: String;
	sendSuccess			: Boolean;
	messageDesc			: String;
	temp				: String;
	pos					: Integer;
	requestString		: String;
	postDataLogging		: String;
	jsonHelper			: CMIF_JsonHelper;
	timeoutMS			: Integer;
	formattedReturnVal	: String;
	errors				: StringArray;
begin
	// Get a sanitised version of the put data for logging	
	if _putPostData &lt;&gt; null then
		postDataLogging := JMTJadeJson@sanitiseSensitiveFields4Loging(_putPostData);
	else
		postDataLogging := null;
	endif;
	
	app.writeLog(method.qualifiedName &amp; 
				   " _url=" &amp; _url &amp;
				   ", _verb=" &amp; _verb &amp;
				   ", _additionalHeaders=" &amp; _additionalHeaders &amp;
				   ", _putPostData=" &amp; postDataLogging, LogDEBUG);	//25 Nov 2019	NDL	TFS 47053

	create conn transient;
	create errors transient;			
	
	// Set timeouts of required
	if self.timeoutSeconds &lt;&gt; 0 then
		timeoutMS := self.timeoutSeconds * 1000;
		conn.connectTimeout := timeoutMS;
		conn.sendTimeout := timeoutMS;
		conn.receiveTimeout := timeoutMS;
	endif;
	
	conn.url := _url;
	
	sendSuccess := conn.sendRequest(_verb, _additionalHeaders, _putPostData);
	_resultCode := conn.queryStatusCode();		// 9/7/19 MAP TFS45230
	if sendSuccess then
		conn.readBody(0);
		returnVal := conn.responseBody.StringUtf8.String;
		app.writeLog(method.qualifiedName &amp; " returnVal=" &amp; returnVal, LogDEBUG);	//25 Nov 2019	NDL	TFS 47053
	else
		app.writeLog(method.qualifiedName &amp; " sendRequest failed. Check firewall or timeout settings.", LogERROR);	// TFS 52461 navmd1 26/11/2021
		
		//13.feb.24 navsp1 TFS 62068
		//Raise system alert when message fails to send
		if self.raiseAlertOnFailure then
			errors.add("Request failed. Check firewall or timeout settings");
			pos := 1;
			self.createAlert("Error sending HTTP request for "&amp; self.definitionName &amp;" - "&amp; _verb &amp;" "&amp; _url.reverse().scanUntil('/', pos).reverse(), errors);			
		endif;
		
	endif;
	
	if self.createActivityHistory or self.raiseAlertOnFailure then					//16.Feb.24 navsp1 TFS 62068
		create jsonHelper transient;
			
		// TFS47042 - Ensure a valid empty response does not throw a parsing error
		if (returnVal &lt;&gt; "") then
			formattedReturnVal := jsonHelper.formatJsonString(returnVal);
			// If the response isn't JSON, then still log it
			if formattedReturnVal = null then			// TFS 52952 navmd1 
				formattedReturnVal := returnVal;		// TFS 52952 navmd1
			endif;
		elseif (sendSuccess) then
			formattedReturnVal := "EMPTY";
		else
			formattedReturnVal := "Connection Failure or Timeout";	// TFS 52461 navmd1 26/11/2021
		endif;
		// END TFS47042
	endif;
	
	if self.createActivityHistory then
		
		temp := _url.reverse();
		if _putPostData &lt;&gt; null then												// This is a POST
			requestString := postDataLogging;										// Log sanitised version of data
			pos := 1;
			messageDesc := _verb &amp; " " &amp; temp.scanUntil('/', pos).reverse();		// description is the last part of the url
		else
			pos := 1;
			requestString := temp.scanUntil('/', pos).reverse();					// request is everything after the final '/'
			pos := pos + 1;
			messageDesc := _verb &amp; " " &amp; temp.scanUntil('/', pos).reverse();		// description is the next part 
		endif;
		
		self.doCreateActivityHistory(null, 
									 messageDesc, 
									 requestString, 
									 formattedReturnVal,
									 _resultCode);
		
	endif;
	
	//16.feb.24 navsp1 TFS 62068		
	if self.raiseAlertOnFailure then					
		if _resultCode &lt;&gt; 0 and  (_resultCode &lt; 200 or _resultCode &gt;= 300) then
			create errors transient;
			errors.add(formattedReturnVal);
			errors.add("HTTP Response code: "&amp;_resultCode.String);
			errors.add("Check the External Web Service Monitor for more information");
			pos := 1;
			self.createAlert("Error sending HTTP request for "&amp; self.definitionName &amp;" - "&amp; _verb &amp;" "&amp; _url.reverse().scanUntil('/', pos).reverse(), errors);		
		endif;
	endif;	
	
	app.writeLog(method.qualifiedName &amp; Tab &amp; "formattedReturnVal is " &amp; formattedReturnVal, LogDEBUG);
	
	if _resultCode = 0 and returnVal = null then
		// Return a nicer error text if something went wrong
		returnVal := formattedReturnVal;
	endif;
	
	return returnVal;
	
epilog
	delete conn;
	delete jsonHelper;
	delete errors;
end;</source>
        <Parameter name="_url" type="String"/>
        <Parameter name="_verb" type="String"/>
        <Parameter name="_additionalHeaders" type="String"/>
        <Parameter name="_putPostData" type="String"/>
        <Parameter name="_resultCode" type="Integer" usage="output"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="doSendWebServiceRequest" id="4a64bcab-162d-48bc-a661-403b2890f77f">
        <updating/>
        <source>doSendWebServiceRequest(_consumer : JadeWebServiceConsumer input;
						_methodName : String;
						_request : ImportedWebServiceProxy input;
						_soapFaultReturned : Boolean io) : ImportedWebServiceProxy protected, updating;
/*

Purpose:			Send a single web service request to the passed in consumer, trapping SOAP
					exceptions and performing some basic logging

Parameters:			Web Service consumer
					Method name to call
					Parameter to send in the call

Return Value:		Return value from the web service call
					Also _soapFaultReturned set to true if the response from the Web Service was a SOAP Fault

Date		Who		Reason
11 Jun 2018	jlgkpd1	TFS #37190 - Pelindo 1 INAPORTNET Integration

*/

vars
	response		: ImportedWebServiceProxy;
	soapExcOccurred	: Boolean;
	tranId			: String;
	statistics		: String;
	xmlHelper		: CM_XmlHelperAgent;
	xml				: JadeXMLDocument;
	element			: JadeXMLElement;
	
begin
	tranId := _consumer.class.name &amp; "::" &amp; _methodName;
	self.cnStartTransaction(tranId);
	
	on JadeSOAPException do self.handleSOAPException(exception, _consumer, soapExcOccurred);
	
	// Reset to tidy up transients from previous call
	_consumer.reset();
	_consumer.logStatistics := true;
	
	// Framework callout for subclass reimplemetation
	self.doSetupForWebServiceRequest(_consumer, _request);
	
	// Call the Web Service
	app.writeLog("Calling Web Service " &amp; tranId &amp; "  " &amp; _consumer.getEndpointURL, LogDEBUG);	//25 Nov 2019	NDL	TFS 47053
	response := _consumer.sendMsgWithParams(_methodName, _request).ImportedWebServiceProxy;

	// Log SOAP request and response
	self.doLogWebServiceCall(_consumer, _methodName);
	
	// And return the result
	if soapExcOccurred then
		// If a SOAP exception has occurred, then log all the available info from the consumer statistics
		statistics := _consumer.getLastStatistics(false);
		self.doLogStatisticsInfo(statistics);
		
		// Now parse the statistics to determine if the exception was a SOAP Fault
		// SOAP faults result in an HTTP error 500
		create xml transient;
		create xmlHelper transient;
		if xmlHelper.tryParseToXMLDocument(statistics, xml) then
			element := xml.findElementByTagName("errorCode");
			if element &lt;&gt; null and element.text = "500" then
				_soapFaultReturned := true;
			endif;
		endif;
		
		// Return a null response for any exception
		delete response;
		return null;
	else
		return response;
	endif;

epilog
	delete xml;
	delete xmlHelper;
	
	self.cnEndTransaction();
	
end;</source>
        <access>protected</access>
        <Parameter name="_consumer" type="JadeWebServiceConsumer" usage="input"/>
        <Parameter name="_methodName" type="String"/>
        <Parameter name="_request" type="ImportedWebServiceProxy" usage="input"/>
        <Parameter name="_soapFaultReturned" type="Boolean" usage="io"/>
        <ReturnType type="ImportedWebServiceProxy"/>
    </JadeMethod>
    <JadeMethod name="doSetupForWebServiceRequest" id="4a5d56c7-ed23-470b-b9e3-facfb077e29d">
        <source>doSetupForWebServiceRequest(_consumer : JadeWebServiceConsumer input;
							_request : ImportedWebServiceProxy input) protected;
/*

Purpose:			Do any pre-request setup of the passed in _consumer and _request before initiating
					the send

Parameters:			Consumer instance for this call
					Request parameter

Return Value:		None

Date		Who		Reason
11 Jun 2018	jlgkpd1	TFS #37190 - Pelindo 1 INAPORTNET Integration

*/

vars
	timeoutMS		: Integer;
	
begin
	// Set timeouts for the call if non-default is being used
	if self.timeoutSeconds &lt;&gt; null then
		timeoutMS := self.timeoutSeconds * 1000;
		_consumer.setTimeouts(timeoutMS, timeoutMS, timeoutMS);
	endif;
	
epilog

end;</source>
        <access>protected</access>
