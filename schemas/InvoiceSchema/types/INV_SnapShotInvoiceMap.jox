    <JadeMethod name="deleteInvoiceAllocation" id="559c7ae8-d1da-4a60-a738-9a4c8f8fa482">
        <updating/>
        <source>deleteInvoiceAllocation() : Boolean updating;
// 08/12/2014 cnwdb2 PAR 35364

vars
	result 					: Integer;
begin	
	if self.myInvoiceAllocation = null or
	   self.myQuantityRangeMap = null or
	   self.myInvoiceLineDesc = null then
		return false;
	endif;
		
//	if app.msgBox(app.getErrorString2(CONF_DELETE,"this mapping", null), app.getErrorString(Confirm_Delete), MsgBox_Yes_No + MsgBox_Question_Mark_Icon) = MsgBox_Return_No then

	if app.msgBox(app.getErrorString(Sure_want_delete), app.getErrorString(Confirm_Delete), MsgBox_Yes_No + MsgBox_Question_Mark_Icon) = MsgBox_Return_No then // PAR 35364
		return false;
	endif;

	while true do
		app.myTrxDA.trxDeleteInvoiceAllocation(self.myInvoiceAllocation, self.myQuantityRangeMap, self.myInvoiceLineDesc, app.myPassport);
		if app.myPassport.trxCompletedOK then
			self.clearErrorWarnings();
			self.populateTable();
			break;
		else
			result := app.showErrorWarningDialog(app.getErrorString(Voyage_load_colour_coding), app.myPassport, ErrWarnMode_Add + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   result = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;

			self.setAllErrorWarnings(app.myPassport);
		endif;
		
		break;
	endwhile;	

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
