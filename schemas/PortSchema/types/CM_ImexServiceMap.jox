    <JadeMethod name="shouldAuditProperty" id="2c9f3a2a-3fbe-4582-a90f-e766fc15dc74">
        <source>shouldAuditProperty(_rootClass: Class; _property: Property): Boolean protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 December 2016	cnwma1	Initial creation

*/

vars
		propName	: String;
begin
	if _property = null then
		return false;
	endif;
	
	propName := _property.name;
	
	if	propName = CM_ImexServiceMap::myChildQuantityMap.name or 
		propName = CM_ImexServiceMap::imexStatusString.name or
		propName = CM_ImexServiceMap::imexStatus.name or
		propName = CM_ImexServiceMap::myProductMap.name 
		then
		return false;
	else
		return inheritMethod(_rootClass, _property);
	endif;
epilog
end;
</source>
        <access>protected</access>
        <Parameter name="_rootClass" type="Class"/>
        <Parameter name="_property" type="Property"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
