<Class name="WS_PrenoteFromBookRef" id="2dda4267-cfa8-4c1e-af40-04ccc833165a">
    <superclass name="WS_ProxyObject"/>
    <transient/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>
Get prenote data according to the input Booking Reference Number. </text>
    <DbClassMap file="webservice"/>
    <ImplicitInverseRef name="allDischargePorts" id="934a2efb-c01d-4641-b17e-ac42cff30fb8">
        <embedded/>
        <type name="WS_Port"/>
        <access>readonly</access>
        <text>All the possible discharge ports for the cargo based on the trade route for the voyage.</text>
    </ImplicitInverseRef>
    <PrimAttribute name="allTIHazards" id="34df1875-f2a2-448c-aec8-276ddf812dc6">
        <type name="String"/>
        <access>readonly</access>
        <text>A string representing all the Hazards on Booking. The format is &lt;Hazard code&gt; &amp; ( &lt;UN dangerous good codes&gt; ) &amp;  &lt;L -if it is limited&gt; if there are more than one Hazard it will be seperated by ; </text>
    </PrimAttribute>
    <PrimAttribute name="bookingReference" id="6283108e-03d2-4a61-89f3-90445a679628">
