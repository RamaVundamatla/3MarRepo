    <JadeMethod name="populateClassesTable" id="c15bf5f9-6f59-488f-9a72-ec9e0cbf4958">
        <updating/>
        <source>populateClassesTable() protected, updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 September 2014	cnwndl1	Initial creation

*/

vars

	classArray : CnClassArray;
	class : Class;
	objSet : ObjectSet;
	schema : Schema;
	formClass : Class;
	index : Integer;
	rowIndex : Integer;

begin

	schema := rootSchema.getSchema("SysOpsSchema");
	formClass := schema.getClass("SOP_TableMaintForm");

	self.tblClasses.clear();
	self.tblClasses.rows := 1;
	self.tblClasses.fixedRows := 1;
	self.tblClasses.columns := 2;
	self.tblClasses.setCellText( 1,1,"Nice Name" &amp; Tab &amp; "Selected Count");
	self.tblClasses.accessRow(1).fontBold := true;

	create classArray transient;			
	classArray.add(CM_CargoType);	
	classArray.add(CM_Carrier);	
	classArray.add(CM_Commodity);			
	classArray.add(CM_ConsigneeConsignor);	
	classArray.add(CM_CustomsAgent);		
	classArray.add(CM_DamageDefinitionCode);
	classArray.add(CM_DamagePosition);
	classArray.add(CM_UNDangerousGoods);
	classArray.add(CM_DriverDetails);
	classArray.add(CM_EmailAddress2);		
	classArray.add(CM_HazardClass);			
	classArray.add(CM_ISOType);				
	classArray.add(CM_ISOTypeGroup);
	classArray.add(CM_Machine);
	classArray.add(CM_Operator);			
	classArray.add(CM_OperatorGroup);		
	classArray.add(CM_Organisation);		
	classArray.add(CM_Port);				
	classArray.add(CM_PrinterDef);	
	classArray.add(CM_RadioTelemetryDevice);
	classArray.add(CM_ShippingAgent);		
	classArray.add(CM_ShippingLine);		
	classArray.add(CM_Stevedore);
	classArray.add(CM_StopsTable);
	classArray.add(CM_TemperatureConversion);
	classArray.add(CM_TempRange);			
	classArray.add(CM_ToDoTaskDesc);
	classArray.add(CM_TransactionType);
	classArray.add(CM_ResourceType);
	classArray.add(CM_Trade);					
	classArray.add(CM_VehicleColour);		
	classArray.add(CM_VehicleMake);			
	classArray.add(CM_VehicleModel);		
	classArray.add(CM_VehicleType);			
	classArray.add(CM_WagonClass);
	classArray.add(CM_WeightRange);
		
	foreach class in classArray do
		index := index + 1;
		self.getSelectedObjects( class, objSet );
		if objSet = null then
			rowIndex := self.tblClasses.addItem( self.getNiceDisplay(class,null) &amp; Tab &amp; "  ");
		else
			rowIndex := self.tblClasses.addItem( self.getNiceDisplay(class,null) &amp; Tab &amp; objSet.size.String);
			self.tblClasses.accessRow( rowIndex ).backColor := Yellow;
		endif;
		self.tblClasses.accessRow( rowIndex ).itemObject := class;
	endforeach;
	
	self.myCurrentClass := null;
	self.populateInstances( null, null );
	
	self.fldBaseCode.topSheet := self.shtClasses;
	
epilog

	delete classArray;
	

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="populateCombo" id="27c54b70-1eae-4837-bdc0-04fc161de6a5">
        <updating/>
        <source>populateCombo() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
12 July 2012	cnwndl1	Initial creation

*/

vars

	term : CM_Terminal;
	userTerm : CM_UserTerminal;

begin

	term := self.myTerminal;
	if term = null then
		if app.myPassport &lt;&gt; null then
			term := app.myPassport.myTerminal;
		endif;
	endif;
	if term = null then
		foreach userTerm in app.getMyUser.allUserTerminals do
			term := userTerm.myTerminal;
			if term &lt;&gt; null then
				break;
			endif;
		endforeach;
		if term &lt;&gt; null then
			self.setMyTerminal( term );
		endif;
	endif; 
	self.myAssistant.comboBoxTerminal( self.cmbTerminal, term, null);

	if self.allowConfigCompare then
		self.myAssistant.comboBoxTerminal( self.cmbExpTerm, term, null);
		if self.cmbExpTerm.listCount &lt; 2 then
			self.cmbExpTerm.enabled := false;
		endif;
		self.myAssistant.comboBoxTerminal( self.cmbCompTerm, null, null);
		if self.cmbCompTerm.listCount &lt; 2 then
			self.frmCompTerm.enabled := false;
		endif;
	endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="populateFormats" id="bb26b788-fa6f-4703-be5f-4a7999ce4248">
        <updating/>
        <source>populateFormats() protected, updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 September 2014	cnwndl1	Initial creation

*/

vars

	schema : Schema;
	format : CnEcXmlFormat;
	xmlFormatColl : CnEcXmlFormatDict;
	msg : String;

begin

	self.cmbFormat.clear();
	
	schema := app.myCnEcXmlSchema;
	create xmlFormatColl transient;
	app.myBaseRoot.getAllFormatsForSchema( xmlFormatColl, schema.name );
	
	foreach format in xmlFormatColl do
		if format.schemaName &lt;&gt; schema.name then
			continue;
		endif;
		if format.formatName = "Default OID" then
			continue;
		endif;
		if format.formatName = "Default Full Attribute" then
			continue;
		endif;
		if format.formatName = "UserCompare" then
			continue;
		endif;
		if format.formatName = "RoleParent" then
			continue;
		endif;
		self.cmbFormat.addItem( format.formatName );
	endforeach;
	
	if self.cmbFormat.listCount = 1 then
		self.cmbFormat.listIndex := 1;
		self.cmbFormat.enabled := false;
	elseif self.cmbFormat.listCount = 0 then
		msg := "XMLUtility / formats not loaded.  See attachments on Par 35619";	// See pars 34893, 35619, 36350
		app.msgBox( msg, "Error", MsgBox_OK_Only );
	endif;

epilog

	delete xmlFormatColl;

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="populateInstances" id="d0541924-e038-4268-9e84-cd1e9f2cc6cf">
        <updating/>
        <source>populateInstances( _class : Class; _niceName : String ) protected, updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 September 2014	cnwndl1	Initial creation

*/

vars

	objSet : ObjectSet;
	obj : Object;
	index : Integer;
	transObjSet : ObjectSet;
	str : String;
	allSelected : Boolean;

begin

	self.chkSelectAll.value := false;
	self.myCurrentClass := _class;

	self.tblObjects.clear();
	self.shtObjects.enabled := true;
	
	if _class = null then
		self.shtObjects.enabled := false;
		return;
	endif;
	
	self.tblObjects.rows := 1;
	self.tblObjects.fixedRows := 1;
	self.tblObjects.columns := 2;
	self.tblObjects.sortColumn[1] := 2;
	self.tblObjects.accessColumn( 1 ).width := 50;
	self.tblObjects.setCellText(1,1, " " &amp; Tab &amp; _niceName );
	self.tblObjects.accessRow(1).fontBold := true;
	
	self.getSelectedObjects( _class, objSet );
	
	if objSet &lt;&gt; null and not objSet.isEmpty then
		allSelected := true;
		
		create transObjSet transient;
		if _class = CM_Organisation then
			CM_ExternalOrganisation.instances.copy(transObjSet);
			CM_InternalOrganisation.instances.copy(transObjSet);
		elseif _class = CM_RadioTelemetryDevice then
			CM_RTDeviceHandHeld.instances.copy(transObjSet);
			CM_RTDeviceVehicleMount.instances.copy(transObjSet);
		else
			_class.instances.copy(transObjSet);
		endif;
		
		foreach obj in transObjSet do
			if objSet.includes( obj ) then
				str := self.getNiceDisplay( _class, obj );
				index := self.tblObjects.addItem( '1' &amp; Tab &amp; str );
				self.tblObjects.accessRow(index).itemObject := obj;
			else
				str := self.getNiceDisplay( _class, obj );
				index := self.tblObjects.addItem( '0' &amp; Tab &amp; str );
				self.tblObjects.accessRow(index).itemObject := obj;
				allSelected := false;
			endif;
			if self.tblObjects.rows &gt;= 31999 then
				app.msgBox("More than 32000 items in collection, only 32000 displayed.","Warning",MsgBox_OK_Only);
				break;
			endif;
		endforeach;
		
		self.chkSelectAll.value := allSelected;

	else
	
		create transObjSet transient;
		if _class = CM_Organisation then
			CM_ExternalOrganisation.instances.copy(transObjSet);
			CM_InternalOrganisation.instances.copy(transObjSet);
		elseif _class = CM_RadioTelemetryDevice then
			CM_RTDeviceHandHeld.instances.copy(transObjSet);
			CM_RTDeviceVehicleMount.instances.copy(transObjSet);
		else
			_class.instances.copy(transObjSet);
		endif;
		
		foreach obj in transObjSet do
			str := self.getNiceDisplay( _class, obj );
			index := self.tblObjects.addItem( '0' &amp; Tab &amp; str );
			self.tblObjects.accessRow(index).itemObject := obj;
			if self.tblObjects.rows &gt;= 31999 then
				app.msgBox("More than 32000 items in collection, only 32000 displayed.","Warning",MsgBox_OK_Only);
				break;
			endif;
		endforeach;	
		
	endif;

epilog

	delete transObjSet;

end;</source>
        <access>protected</access>
        <Parameter name="_class" type="Class"/>
        <Parameter name="_niceName" type="String"/>
    </JadeMethod>
    <JadeMethod name="populateRoleTable" id="c6e38032-e299-4533-9b49-4e1a1beff25d">
        <source>populateRoleTable();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 September 2014	cnwndl1	Initial creation

*/

vars

	role : CM_SecurityRole;
	iter : Iterator;
	index : Integer;

begin

	self.tblRoles.rows := 1;
	iter := app.myRoot.allRoles.createIterator;
	
	self.lblRoleHeading.caption := null;
	
	while iter.next( role ) do
		index := self.tblRoles.addItem( role.name &amp; Tab &amp; role.getParentHeirarchyString );
		self.tblRoles.accessRow( index ).itemObject := role;
	endwhile;

epilog

	delete iter;

end;</source>
    </JadeMethod>
    <JadeMethod name="populateTable" id="66e6ca69-cce0-445e-b143-0533fce9fefb">
        <updating/>
        <source>populateTable() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
12 July 2012	cnwndl1	Initial creation

*/

vars

	cmif : CMIF_ConfigOptionsDisplay;
	colCompareValue : Integer;
	
begin

	self.tblConfigOptions.rows := 1;
	
	if self.myConfigDisplayAgent = null then
		create self.myConfigDisplayAgent transient;
	endif;
	
	self.myConfigDisplayAgent.setMyTerminal( self.myTerminal );
	self.myConfigDisplayAgent.populateDisplayLineObjects();
	
	foreach cmif in self.myConfigDisplayAgent.allDisplayLineObjects do
		self.tblConfigOptions.addItemObject(cmif, cmif.getAttributeStringForDefArray(self.tblConfigOptions.allTblDataEntRows));
	endforeach;
	
	if self.allowConfigCompare then
		if self.myTerminal = null then
			self.lblCurrTerm.caption := "Current Terminal = Unknown";
		else
			self.lblCurrTerm.caption := "Current Terminal = " &amp; self.myTerminal.code;
		endif;
		self.tblCompare.rows := 1;
		foreach cmif in self.myConfigDisplayAgent.allDisplayLineObjects do
			self.tblCompare.addItemObject(cmif, cmif.getAttributeStringForDefArray(self.tblCompare.allTblDataEntRows));
		endforeach;
		colCompareValue := self.tblCompare.getColumnByRowName(ETRow_CompareValue);
		if colCompareValue &gt; 0 then
			self.tblCompare.setCellText( 1, colCompareValue, self.compareValueRowName );
		endif;
	endif;
	
	self.tblConfigOptions.visible := ( self.myTerminal &lt;&gt; null );
	self.lblSelectTerm.visible := ( self.myTerminal = null );
	
	self.setCompHeading( null );
	self.doCompareConfigOptionsClick( null );

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="populateUserTable" id="ca7e46cd-24d4-4031-9722-a9980989b7c4">
        <source>populateUserTable();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 September 2014	cnwndl1	Initial creation

*/

vars

	iter : Iterator;
	user : CM_User;
	index : Integer;

begin

	self.tblUsers.rows := 1;
	iter := app.myRoot.allUsers.createIterator;
	
	self.lblUserHeading.caption := null;
	
	while iter.next( user ) do
		index := self.tblUsers.addItem( user.code &amp; "/" &amp; user.userName );
		self.tblUsers.accessRow( index ).itemObject := user;
	endwhile;

epilog

	delete iter;

end;</source>
    </JadeMethod>
    <JadeMethod name="redisplayCMIFsMatching" id="05d53678-d390-4c3c-99ec-9be7c077e9e6">
        <source>redisplayCMIFsMatching( _cmif : CMIF_ConfigOptionsDisplay );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 August 2014	cnwndl1	Initial creation

*/

vars

	colCurrentValue : Integer;
	colUpdateValue : Integer;
	colCompareValue : Integer;
	cmif : CMIF_ConfigOptionsDisplay;
	updatedCmifs : CMIF_ConfigOptionsDisplaySet;
	rowIndex : Integer;

begin

	create updatedCmifs transient;
	updatedCmifs.add( _cmif );
	colCurrentValue := self.tblCompare.getColumnByRowName(ETRow_CurrentValue);
	colUpdateValue := self.tblCompare.getColumnByRowName(ETRow_UpdateValue);
	colCompareValue := self.tblCompare.getColumnByRowName(ETRow_CompareValue);

	//foreach cmif in self.allDisplayLines do
	foreach cmif in self.myConfigDisplayAgent.allDisplayLineObjects do
		if cmif = _cmif then
			continue;
		endif;
		if cmif.optionName &lt;&gt; _cmif.optionName then
			continue;
		endif;
		if cmif.appliesToTerm &lt;&gt; _cmif.appliesToTerm then
			continue;
		endif;
		updatedCmifs.add( cmif );
		cmif.setValues(	cmif.appliesToTerm,	//_appliesToTerm : Boolean;
						cmif.constantName,	//_constantName : String;
						_cmif.currentValue,	//_currentValue : String;
						cmif.maintFormName,	//_maintFormName : String;
						cmif.optionName,	//_optionName : String;
						cmif.position,	//_position : String;
						cmif.sheetName	//_sheetName : String
						);
	endforeach;
	
	foreach rowIndex in 2 to self.tblCompare.rows do
		cmif := self.tblCompare.accessRow(rowIndex).itemObject.CMIF_ConfigOptionsDisplay;
		if updatedCmifs.includes( cmif ) then
			self.tblCompare.setCellText( rowIndex, colCurrentValue, cmif.currentValue );
			self.tblCompare.setCellText( rowIndex, colUpdateValue, "0" );
			self.doColourConfigTable( colCurrentValue, colCompareValue, rowIndex );
		endif;
	endforeach;
	
	colCurrentValue := self.tblConfigOptions.getColumnByRowName(ETRow_CurrentValue);
	foreach rowIndex in 2 to self.tblConfigOptions.rows do
		cmif := self.tblConfigOptions.accessRow(rowIndex).itemObject.CMIF_ConfigOptionsDisplay;
		if updatedCmifs.includes( cmif ) then
			self.tblConfigOptions.setCellText( rowIndex, colCurrentValue, cmif.currentValue );
		endif;
	endforeach;

epilog

	delete updatedCmifs;

end;</source>
        <Parameter name="_cmif" type="CMIF_ConfigOptionsDisplay"/>
    </JadeMethod>
    <JadeMethod name="resizeColumns" id="c95c753b-5bd3-43b1-b520-9df5e26ed33b">
        <source>resizeColumns( _inSetup : Boolean );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 August 2014	cnwndl1	Initial creation

*/

vars

	totalWidth : Integer;
	columnIndex : Integer;
	minWidth : Integer;
	currentColsWidth : Integer;

begin


	totalWidth := self.tblConfigOptions.width.Integer;
	totalWidth := totalWidth - 17; // to allow for scroll bar.
	
	columnIndex := self.tblConfigOptions.getColumnByRowName(ETRow_OptionName);
	if columnIndex &gt; 0 then
		minWidth := minWidth + 380;
		currentColsWidth := currentColsWidth + self.tblConfigOptions.accessColumn( columnIndex ).width;
	endif;
	columnIndex := self.tblConfigOptions.getColumnByRowName(ETRow_MaintFormName);
	if columnIndex &gt; 0 then
		minWidth := minWidth + 115;
		currentColsWidth := currentColsWidth + self.tblConfigOptions.accessColumn( columnIndex ).width;
	endif;
	columnIndex := self.tblConfigOptions.getColumnByRowName(ETRow_SheetName);
	if columnIndex &gt; 0 then
		minWidth := minWidth + 80;
		currentColsWidth := currentColsWidth + self.tblConfigOptions.accessColumn( columnIndex ).width;
	endif;
	columnIndex := self.tblConfigOptions.getColumnByRowName(ETRow_Position);
	if columnIndex &gt; 0 then
		minWidth := minWidth + 80;
		currentColsWidth := currentColsWidth + self.tblConfigOptions.accessColumn( columnIndex ).width;
	endif;
	columnIndex := self.tblConfigOptions.getColumnByRowName(ETRow_AppliesToTerm);
	if columnIndex &gt; 0 then
		minWidth := minWidth + 80;
		currentColsWidth := currentColsWidth + self.tblConfigOptions.accessColumn( columnIndex ).width;
	endif;
	columnIndex := self.tblConfigOptions.getColumnByRowName(ETRow_CurrentValue);
	if columnIndex &gt; 0 then
		minWidth := minWidth + 200;
		currentColsWidth := currentColsWidth + self.tblConfigOptions.accessColumn( columnIndex ).width;
	endif;
	columnIndex := self.tblConfigOptions.getColumnByRowName(ETRow_ConstantName);
	if columnIndex &gt; 0 then
		minWidth := minWidth + 200;
		currentColsWidth := currentColsWidth + self.tblConfigOptions.accessColumn( columnIndex ).width;
	endif;
	
	//	380,115,80,80,80,200,200
	
	if _inSetup or ( currentColsWidth + 25 &lt; totalWidth ) or currentColsWidth &gt; totalWidth then
		columnIndex := self.tblConfigOptions.getColumnByRowName(ETRow_OptionName);
		if columnIndex &gt; 0 then
			self.tblConfigOptions.accessColumn( columnIndex ).width := ( ( totalWidth / minWidth ) * 380 ).Integer;
		endif;
		columnIndex := self.tblConfigOptions.getColumnByRowName(ETRow_MaintFormName);
		if columnIndex &gt; 0 then
			self.tblConfigOptions.accessColumn( columnIndex ).width := ( ( totalWidth / minWidth ) * 115 ).Integer;
		endif;
		
		columnIndex := self.tblConfigOptions.getColumnByRowName(ETRow_SheetName);
		if columnIndex &gt; 0 then
			self.tblConfigOptions.accessColumn( columnIndex ).width := ( ( totalWidth / minWidth ) * 80 ).Integer;
		endif;
		columnIndex := self.tblConfigOptions.getColumnByRowName(ETRow_Position);
		if columnIndex &gt; 0 then
			self.tblConfigOptions.accessColumn( columnIndex ).width := ( ( totalWidth / minWidth ) * 80 ).Integer;
		endif;
		columnIndex := self.tblConfigOptions.getColumnByRowName(ETRow_AppliesToTerm);
		if columnIndex &gt; 0 then
			self.tblConfigOptions.accessColumn( columnIndex ).width := ( ( totalWidth / minWidth ) * 80 ).Integer;
		endif;
		columnIndex := self.tblConfigOptions.getColumnByRowName(ETRow_CurrentValue);
		if columnIndex &gt; 0 then
			self.tblConfigOptions.accessColumn( columnIndex ).width := ( ( totalWidth / minWidth ) * 200 ).Integer;
		endif;
		columnIndex := self.tblConfigOptions.getColumnByRowName(ETRow_ConstantName);
		if columnIndex &gt; 0 then
			self.tblConfigOptions.accessColumn( columnIndex ).width := ( ( totalWidth / minWidth ) * 200 ).Integer;
		endif;
	endif;
	
	if self.allowConfigCompare then
	
		totalWidth := self.tblCompare.width.Integer;
		totalWidth := totalWidth - 17; // to allow for scroll bar.
		currentColsWidth := 0;
		minWidth := 0;
		
		columnIndex := self.tblCompare.getColumnByRowName(ETRow_OptionName);
		if columnIndex &gt; 0 then
			minWidth := minWidth + 380;
			currentColsWidth := currentColsWidth + self.tblCompare.accessColumn( columnIndex ).width;
		endif;
		columnIndex := self.tblCompare.getColumnByRowName(ETRow_MaintFormName);
		if columnIndex &gt; 0 then
			minWidth := minWidth + 115;
			currentColsWidth := currentColsWidth + self.tblCompare.accessColumn( columnIndex ).width;
		endif;
		columnIndex := self.tblCompare.getColumnByRowName(ETRow_SheetName);
		if columnIndex &gt; 0 then
			minWidth := minWidth + 115;
			currentColsWidth := currentColsWidth + self.tblCompare.accessColumn( columnIndex ).width;
		endif;
		columnIndex := self.tblCompare.getColumnByRowName(ETRow_Position);
		if columnIndex &gt; 0 then
			minWidth := minWidth + 115;
			currentColsWidth := currentColsWidth + self.tblCompare.accessColumn( columnIndex ).width;
		endif;
		columnIndex := self.tblCompare.getColumnByRowName(ETRow_CurrentValue);
		if columnIndex &gt; 0 then
			minWidth := minWidth + 250;
			currentColsWidth := currentColsWidth + self.tblCompare.accessColumn( columnIndex ).width;
		endif;
		columnIndex := self.tblCompare.getColumnByRowName(ETRow_CompareValue);
		if columnIndex &gt; 0 then
			minWidth := minWidth + 250;
			currentColsWidth := currentColsWidth + self.tblCompare.accessColumn( columnIndex ).width;
		endif;
		columnIndex := self.tblCompare.getColumnByRowName(ETRow_UpdateValue);
		if columnIndex &gt; 0 then
			minWidth := minWidth + 75;
			currentColsWidth := currentColsWidth + self.tblCompare.accessColumn( columnIndex ).width;
		endif;
		columnIndex := self.tblCompare.getColumnByRowName(ETRow_Differs);
		if columnIndex &gt; 0 then
			minWidth := minWidth + 50;
			currentColsWidth := currentColsWidth + self.tblCompare.accessColumn( columnIndex ).width;
		endif;
		
		if _inSetup or ( currentColsWidth + 25 &lt; totalWidth ) or currentColsWidth &gt; totalWidth then
			columnIndex := self.tblCompare.getColumnByRowName(ETRow_OptionName);
			if columnIndex &gt; 0 then
				self.tblCompare.accessColumn( columnIndex ).width := ( ( totalWidth / minWidth ) * 380 ).Integer;
			endif;
			columnIndex := self.tblCompare.getColumnByRowName(ETRow_MaintFormName);
			if columnIndex &gt; 0 then
				self.tblCompare.accessColumn( columnIndex ).width := ( ( totalWidth / minWidth ) * 115 ).Integer;
			endif;
			columnIndex := self.tblCompare.getColumnByRowName(ETRow_SheetName);
			if columnIndex &gt; 0 then
				self.tblCompare.accessColumn( columnIndex ).width := ( ( totalWidth / minWidth ) * 115 ).Integer;
			endif;
			columnIndex := self.tblCompare.getColumnByRowName(ETRow_Position);
			if columnIndex &gt; 0 then
				self.tblCompare.accessColumn( columnIndex ).width := ( ( totalWidth / minWidth ) * 115 ).Integer;
			endif;
			columnIndex := self.tblCompare.getColumnByRowName(ETRow_CurrentValue);
			if columnIndex &gt; 0 then
				self.tblCompare.accessColumn( columnIndex ).width := ( ( totalWidth / minWidth ) * 250 ).Integer;
			endif;
			columnIndex := self.tblCompare.getColumnByRowName(ETRow_CompareValue);
			if columnIndex &gt; 0 then
				self.tblCompare.accessColumn( columnIndex ).width := ( ( totalWidth / minWidth ) * 250 ).Integer;
			endif;
			columnIndex := self.tblCompare.getColumnByRowName(ETRow_UpdateValue);
			if columnIndex &gt; 0 then
				self.tblCompare.accessColumn( columnIndex ).width := ( ( totalWidth / minWidth ) * 75 ).Integer;
			endif;
			columnIndex := self.tblCompare.getColumnByRowName(ETRow_Differs);
			if columnIndex &gt; 0 then
				self.tblCompare.accessColumn( columnIndex ).width := ( ( totalWidth / minWidth ) * 50 ).Integer;
			endif;
		endif;
	endif;

epilog

end;</source>
        <Parameter name="_inSetup" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="selectClass" id="89303dad-56ea-4453-a313-545439932dc7">
        <updating/>
        <source>selectClass() updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 September 2014	cnwndl1	Initial creation

*/

vars

	class : Class;
	niceName : String;

begin

	class := self.tblClasses.accessRow( self.tblClasses.row ).itemObject.Class;
	if class &lt;&gt; null then
		niceName := self.tblClasses.getCellText( self.tblClasses.row, 1 );
		self.populateInstances( class, niceName &amp; "(s)" );
		self.fldBaseCode.topSheet := self.shtObjects;
	endif;

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="selectFile" id="c81dd2d4-3a96-443b-831d-515fbb2df5a0">
        <updating/>
        <source>selectFile(pTextBox : TextBox io) updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 September 2014	cnwndl1	Initial creation

*/

vars
 	fileSaveObj	: CMDFileSave;
	fileOpenObj	: CMDFileOpen;
 	textboxObj	: TextBox;
	type : String;
 	
begin

	textboxObj	:=	pTextBox;
	
	if textboxObj.parent = self.shtExtract then
		create fileSaveObj transient;
		
		if textboxObj = self.txtLog then
			type := "Log";
		elseif textboxObj = self.txtMain then
			type := "Main";
		elseif textboxObj = self.txtNoid then
			type := "Noid";
		endif;
		
		fileSaveObj.dialogTitle := 'Extract ' &amp; type &amp; ' File';
		fileSaveObj.fileName := type &amp; '.txt';
		fileSaveObj.defaultExt := "*.txt";
		fileSaveObj.filter := type &amp; ' File (*.txt)|*.txt|Txt Files(*.txt)|*.txt';
		if fileSaveObj.open() = 0 then
			textboxObj.text := fileSaveObj.fileName;
		else
			textboxObj.text := "";
		endif;
		
	elseif textboxObj.parent = self.shtImport then
		create fileOpenObj transient;
		
		if textboxObj = self.txtLog then
			type := "Errors";
		elseif textboxObj = self.txtMain then
			type := "Main";
		elseif textboxObj = self.txtNoid then
			type := "Noid";
		endif;
		
		fileOpenObj.dialogTitle := 'Import ' &amp; type &amp; ' File';
		fileOpenObj.filter := type &amp; ' File (*.txt)|*.txt|Txt Files(*.txt)|*.txt';
		if fileOpenObj.open() = 0 then
			textboxObj.text := fileOpenObj.fileName;
		else
			textboxObj.text := "";
		endif;
		
	endif;
	
epilog

	delete fileOpenObj;
	delete fileOpenObj;
	
end;</source>
        <access>protected</access>
        <Parameter name="pTextBox" type="TextBox" usage="io"/>
    </JadeMethod>
    <JadeMethod name="setCompHeading" id="28b56c70-190f-431c-8c30-53136a233900">
        <updating/>
        <source>setCompHeading( _str : String ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 August 2014	cnwndl1	Initial creation

*/

vars

	toolbar	: CMUI_Toolbar;
	colUpdateValue : Integer;
	colCompareValue : Integer;

begin

	self.frmCurrTerm.backColor := White;
	self.frmCompHeading.visible := _str.trimBlanks &lt;&gt; null;
	self.lblCompHeading.caption := _str;
	self.frmCompHeading.backColor := Yellow;
	colUpdateValue := self.tblCompare.getColumnByRowName(ETRow_UpdateValue);
	colCompareValue := self.tblCompare.getColumnByRowName(ETRow_CompareValue);
	if colUpdateValue &gt; 0 then
		 self.tblCompare.accessColumn( colUpdateValue ).enabled := false;
	endif;
	
	if self.frmCompHeading.visible then
		self.frmCurrTerm.backColor := Yellow;
		toolbar := self.frmCompareTool;
		toolbar.positionToolbarControls();
		if colUpdateValue &gt; 0 then
			 self.tblCompare.accessColumn( colUpdateValue ).enabled := true;
		endif;
	endif;
	
	if _str = null and colCompareValue &gt; 0 then
		 self.tblCompare.setCellText( 1, colCompareValue, " " );
	endif;

epilog

end;</source>
        <Parameter name="_str" type="String"/>
    </JadeMethod>
    <JadeMethod name="setCorrectComboStyle" id="5b77c011-ac9d-4b35-9a91-0b9c81e1d8e5">
        <updating/>
        <source>setCorrectComboStyle() updating;
/*
Purpose:	During the change to 22.0.24 some combo boxes had their STYLE set to zero, this is a patchable way to fix that.				

Date		Who		Reason
11 June 2024	navab1	BUG 64462
*/

vars

begin
	inheritMethod();

	self.cmbCompTerm.style := 2;
	self.cmbExpTerm.style := 2;
	self.cmbFormat.style := 2;
	self.cmbTerminal.style := 2;

epilog

end;</source>
    </JadeMethod>
