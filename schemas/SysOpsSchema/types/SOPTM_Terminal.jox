	endif;
	theForm := self.myForm;
  		
	theForm.mulSelect41.formDisplayEntryMethodName := null;  
	theForm.mulSelect42.formDisplayEntryMethodName := null;  
	
	theForm.shtMultiSelect4.caption := 'Auto Configuration';
	theForm.mulSelect41.formDisplayEntryMethodName := 'displayEntryEDITypes';
	theForm.mulSelect41.availableHeading := 'EDI File Types available';
	theForm.mulSelect41.selectedHeading  := 'EDI File Types selected';
	theForm.mulSelect42.formDisplayEntryMethodName := 'displayEntryOperators';
	theForm.mulSelect42.availableHeading := 'Available Operators';
	theForm.mulSelect42.selectedHeading  := 'selected Operators';
/*	create col transient;
	foreach cargo in app.myRoot.allCargoTypesById do
		col.add(cargo);
	endforeach;
	foreach bol in app.myRoot.allBOLTypes do
		col.add(bol);
	endforeach;	
	theForm.mulSelect2.setAvailable(col, true);
*/

end;</source>
    </JadeMethod>
    <JadeMethod name="setControllerFromTable" id="2837e897-7995-4e39-a66a-ff9c63311d6d">
        <updating/>
        <source>setControllerFromTable(_controller : CMIF_InvoiceSystemDefaults input) : Boolean updating;
/*
Purpose:	NFS PAR 33572		
Date				Who			Reason
FEBRUARY 2015		CNWAB1		Initial creation
04/08/2016			cnwdap1		TFS #2396 Correct settings of "Storage Invoice Auto End Of Period" and "Storage Invoice Auto Operator Close"
19 Mar 2021 		cnwma1 		ChangeRequest 50925: ASPA - New Total Column in Invoice Form
2/11/2022			navcs2		Bug 54898 - EUP - Invoice currency symbol - Euro
16 March 2023  navmv20 TFS 56128 Task 56129: UI - Manual Invoice Lines - Multi TI Invoice Line Type
23 November 2023 navra1 TFS 54090 - EUP | EUP | Interface - MTN Invoicing Oracle &lt;&lt;54090&gt;&gt;(CR 61386/Task - 61389)
30 Nov 2024			navnk30		Bug 63894: MTN - Stop Creating Unqualified Audits for invoices Config not showing correct setting
11 Jun 2024         navbk1  Bug 64564: MTN - Invoice Configuration Screen doesn't show correct values
*/

vars
	tmpNum   : String;
	ioObject : CM_ExtFinanceIO; 
	theForm	 : SOP_TableMaintForm;
	theTable : CM_EntryTable;
begin
	theForm  := self.myForm; 
	theTable := theForm.tblInput2;
	
	
	// some Financial configuration is saved on the CM_ExtFinanceIO object, not on the terminal config.
	// these CM_ExtFinanceIO configs are saved on to the CMIF_InvoiceSystemDefaults object and passed into the TRX for the terminal update
	// However the table for the financial stuff is only populated when the financial sheet is displayed.
	// if the financial sheet is not the top sheet then ETRow_FinancialsEnabled is not in the table and so we should pass in a NULL CMIF_InvoiceSystemDefaults to the terminal update TRX
	
	
	if theTable.getRowByName(ETRow_FinancialsEnabled) = 0 then
		return false;
	endif;

	_controller.myCalendar 				   := theForm.cmbCalendar.listObject.CM_Calendar;
	_controller.chargeFirstTemperatureOnly := theForm.cmbReeferOptions.listIndex = 2;
	_controller.defCompany 				   := theForm.cmbBUs.listObject.CM_Bank;
	_controller.storageConfigType 		   := theForm.cmbStorConType.listObject.CM_StorageConfigType;	//02 Nov 2017	NDL	TFS 7032
	_controller.defDebtor 				   := theForm.cmbDebtor.listObject.CM_Debtor;
	_controller.exportPath 				   := theTable.getValueByName(ETRow_ExternalExportPath).String;
	
	ioObject 				     := theForm.cmbFinancialIO.listObject.CM_ExtFinanceIO;
	_controller.financialIOClass := ioObject;
	
	//navra1 - TFS 54090(CR 61386/Task - 61389) - 23th Nov 2023 - start
	if ioObject &lt;&gt; null and ioObject .isKindOf(CM_InvoiceAPI) then
		_controller.invoiceAPIOutputMode := theTable.getValueByName(ETRow_InvoiceAPIOutputMode).String;				
		//navra1 - TFS 54090(CR-61386/Task-61389)  - 13 Dec 2023 - this is configured in the BGP, should not be a term config - start
		/*if theForm.cmbExtWebService.listObject &lt;&gt; null then
			_controller.externalWebService := theForm.cmbExtWebService.listObject.CM_InvoiceAPIServiceDef;		
		endif;*/
		//navra1 - TFS 54090(CR-61386/Task-61389)  - 13 Dec 2023 - this is configured in the BGP, should not be a term config - end
	endif;
	//navra1 - TFS 54090(CR 61386/Task - 61389) - 23th Nov 2023 - end
	
	if _controller.financialIOClass = null then //on new database this may not be setup
		_controller.financialIOClass := CM_DefaultFinanceIO.firstInstance;
	endif;
	
	_controller.financialsEnabled 		:= theTable.getValueByName(ETRow_FinancialsEnabled).Boolean;
	_controller.invPostWithoutAuditQual := theTable.getValueByName(ETRow_AllowInvPostUnqualAudits).Boolean;	
	_controller.firstMonthOfFinYear 	:= theTable.getValueByName(ETRow_FirstMonthFinancialYear).Integer;
	_controller.glPeriod 				:= theTable.getValueByName(ETRow_CurrentGLPeriod).Integer;
	_controller.glYear 				    := theTable.getValueByName(ETRow_CurrentGLYear).Integer;
	_controller.mTsByDebtor 			:= theTable.getValueByName(ETRow_MTsByDebtor).Boolean;
	_controller.mTsByDebtorExport 		:= theTable.getValueByName(ETRow_MTsByDebtorExport).Boolean;
	_controller.invoiceMultiTaxRates 	:= theTable.getValueByName(ETRow_InvoiceMultiTaxRates).Boolean;
	_controller.currencySymbol 			:= theForm.cmbCurrency.itemData[theForm.cmbCurrency.listIndex].Integer;  // 2/11/2022 navcs2 Bug 54898
	_controller.invUseInvoiceCargoAlloc := theTable.getValueByName(ETRow_InvUseInvoiceCargoAlloc).Boolean;	// PAR 35833
	_controller.invInvoicePrintJRW 		:=  theTable.getValueByName(ETRow_InvInvoicePrintJRW).String;		// PAR 36180
	_controller.invWOVoyageTranOnAction := theTable.getValueByName(ETRow_InvWOVoyageTranOnAction).Boolean;	// TFS 42161
	_controller.invShowAllSeparation    := theTable.getValueByName(ETRow_InvShowAllSeparation).Boolean;		//16/03/2023  navmv20 TFS 56128 Task 56129
	
	_controller.multiCompany 			:= theTable.getValueByName(ETRow_MultiCompany).Boolean;
	_controller.name 					:= theTable.getValueByName(ETRow_ExternalFinancialName).String;
	_controller.financialRateDPlaces 	:= theTable.getValueByName(ETRow_FinancialRateDPlaces).Integer;
	
	tmpNum := theTable.getValueByName(ETRow_NextInvoiceNumber).String;
	if tmpNum.length &gt; 9 then
		_controller.nextInvoiceNumber := tmpNum[1:9].Integer;
	else
		_controller.nextInvoiceNumber := tmpNum.Integer;
	endif;
	_controller.remarks 				:= theTable.getValueByName(ETRow_ExternalFinSysRemarks).String;
	_controller.cashProcessingEnabled 	:= theTable.getValueByName(ETRow_CashProcessingEnabled).Boolean;
	_controller.dotMatrixInvoiceRep 	:= theTable.getValueByName(ETRow_DotMatrixInvoiceRep).String;	
	_controller.autoNormalReefers 		:= theTable.getValueByName(ETRow_AutoNormalReefers).Boolean;
	_controller.autoVoidExternalReefers := theTable.getValueByName(ETRow_AutoVoidExternalReefers).Boolean;
	_controller.cashOnlyInDebtOption 	:= theForm.cmbDebtAction.listData;											//30 May 2018	NDL	TFS 38952
	_controller.invoiceHMSNoShiftCharge := theTable.getValueByName(ETRow_InvoiceHMSNoShiftCharge).Boolean;			// TFS #2396
	//_controller.invoiceRoundLineTotal := theTable.getValueByName(ETRow_InvoiceRoundLineTotal).Boolean;			// 20/8/18 MAP TFS40270      // 19.03.2021 cnwma1 #50925	
	_controller.invoiceRoundLineTotal   := theForm.cmbRoundInvLine.listData;                                        // 19.03.2021 cnwma1 #50925	
	_controller.invoiceRoundDownLineTax := theTable.getValueByName(ETRow_InvoiceRoundDownLineTax).Boolean;			// 20/8/18 MAP TFS40272
	_controller.invAuditCargoEdits		:= theTable.getValueByName(ETRow_InvAuditCargoEdits).Boolean;				//30/04/2024 navnk30 #63894
	_controller.invoiceDeferredCharging := theTable.getValueByName(ETRow_DeferredCharging).Boolean;					//11/06/2024 navbk1  #64564
	
	return true;
end;</source>
        <Parameter name="_controller" type="CMIF_InvoiceSystemDefaults" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setControlsForAddEdit" id="94db8c70-2e46-4699-8c53-5fdf920a1f60">
        <updating/>
        <source>setControlsForAddEdit() updating;
//
// Changed On		By			Reason
// ----------		--------	----------------------------------------------------------
// 04/07/2017		cnwdap1		TFS 4492 SNO VERMAS Changes
// 2 Aug 2022		navvt20 	Bug 52421: MTN - System Configuration first row not selected when loading form
// 17 Oct 2022		navpw1		TFS: 55144 - Restored old commented out code
// 02 Nov 2022		navdap1		TFS 54899 PEN Reefer Monitor App Changes
// 21 Jun 2023		navdap1		TFS 56747 EUP Manifest Load - Internal (Zimmer) - Create
// 01 Aug 2025      navsp1      JIRA-35530 Solution Implementation - COPRAR Trailer Support
// 12 Nov 2025		navlw1		JIRA-35995 MTN - Getting a 14051 exception on Terminal config form
vars
	theForm 			: SOP_TableMaintForm;
	lastObj 			: Object;
	rowDifference		: Integer;
	row,
	rows				: Integer;
	entRow 				: EntTableRowTransient;
	firstRow 			: Boolean;
	lastMeasurementRow 	: Integer;
	
begin
	if self.myIntFaceConfig = null then
		create self.myIntFaceConfig transient;
	endif;
	
	//epr tfs 1882 17/5/16
	self.setPrenoteCriteria();
	
	theForm := self.myForm;
	theForm.mulSelect2.userInputEnabled := true;
	theForm.mulSelect41.userInputEnabled := true;
	theForm.mulSelect42.userInputEnabled := true;
	theForm.comboBox1.enabled := true;
	theForm.cmbCargoBOLType.enabled := true;
	theForm.cmbCargoType2.enabled := true;	
	theForm.cmbBOLType.enabled := true;
	theForm.cmbCargoGroup.enabled := true;		// TFS 56747
    theForm.cmbTrailerCargoType.enabled    := true;  //JIRA-35530
	theForm.mnuContext1.visible := true;
	theForm.mnuContext2.visible := true;
	theForm.mnuContext3.visible := true;
	
	//12 Mar 2014	NDL	Par 33268
	if theForm.tblInput2.myEntTableDef &lt;&gt; null then
		theForm.loadMeasurementTypes(	theForm.tblInput2,	
										theForm.tblInput2.myEntTableDef.name,
										theForm.tblInput2.myEntTableDef.allEntTableRows,
										theForm.mode.isOneOf(theForm.Mode_Add, theForm.Mode_Update)	);
	endif;

	if theForm.mode = theForm.Mode_Add then
		if (not app.myRoot.allowMultiTerminal) then
			app.raiseCMException(ERR_TERMINAL_ADD,null,null);
			return;
		endif;
			
		// clear and recreate the config data
		delete self.myIntFaceConfig;
		create self.myIntFaceConfig transient;
		
		theForm.tblInput1.clearValues();
		theForm.tblInput2.clearValues();
		theForm.cmbCommodityGrp.setObject(null);
	   	theForm.cmbDebtor.setObject(null);
		theForm.cmbCalendar.setObject(null);
	   	theForm.cmbEmailAddress.setObject(null);
		
		// copy data from last selected terminal
		lastObj := theForm.getMyLastCurrentObject();
		self.showThumbnail(lastObj.CM_Terminal);
	
		// clear the code and name fields
		theForm.tblInput1.setValueByName(ETRow_Code, null);
		theForm.tblInput1.setValueByName(ETRow_Name, null);	
		theForm.tblInput1.cnEcResizeContents; //2/12/2008 cnwdz2 par18484
		theForm.tblInput1.setFocus;//2/12/2008 cnwdz2 par18484
		theForm.tblInput1.moveFirst();			
		theForm.tblInput1.gotFocus(theForm.tblInput1);	// sets case etc.
		
		theForm.lstTermRelease.clearAllSelected();
		theForm.lstTermVoyInland.clearAllSelected();
		
	else
		// refresh the data from the newly created proxy
		// this is done in the superclass
		self.myIntFaceConfig.setFromPersistentData(theForm.myCurrentObject.CM_Terminal);
		
		//epr TFS 8211 19/12/17 removing old drawing code
		theForm.lstTermRelease.setSelected(self.myIntFaceConfig.allTerminalsForRelease);

	endif;
	
	theForm.tblInput1.userInputEnabled := true;
	theForm.tblInput1.enableRowByName(ETRow_Name);
	theForm.tblInput2.userInputEnabled := true;

	//+cnwml2 PAR23715 SFW CCMS1131
	theForm.tblFldSheet1.userInputEnabled := true;
	theForm.tblFldSheet2.userInputEnabled := true;
	
	self.setWeightAuthDetails();						// TFS 4492
	
	// TFS 54899 if Show All Terminal Reefer jobs is ticked, disable Include Jobless Reefers
	if self.myIntFaceConfig.allReeferJobsForTerminal then
		theForm.tblInput2.disableRowByName(ETRow_IncludeJoblessReefers);
	endif;
	
	// TFS 52235 19NOV2021 NAVLW1
	if self.selectedConfigRow &gt; 0 then
		rowDifference := getRowDifference(selectedConfigRow);
		row := self.selectedConfigRow + rowDifference;
		// 12/11/2025 navlw1 JIRA-35995
		rows := theForm.tblInput2.rows;
		if row &gt; rows then
			row := rows;
		endif;
		// 12/11/2025 navlw1 JIRA-35995
		theForm.tblInput2.topRow := row;
		theForm.tblInput2.accessRow(row).selected := true;
		//theForm.tblInput2.accessRow(1).selected := true;   			//  2 August 2022 navvt20 TFS 52421
		theForm.tblInput2.cnEcSetCellBackColor(row, 1, LightRed);
		//theForm.tblInput2.cnEcSetCellBackColor(1, 1, LightRed); 	//  2 August 2022 navvt20 TFS 52421
	elseif (theForm.currentRowNumber &gt; 0) then
		rowDifference := getRowDifference(theForm.currentRowNumber);
		row := theForm.currentRowNumber + rowDifference;
		// 12/11/2025 navlw1 JIRA-35995
		rows := theForm.tblInput2.rows;
		if row &gt; rows then
			row := rows;
		endif;
		// 12/11/2025 navlw1 JIRA-35995
		theForm.tblInput2.topRow := row;
		theForm.tblInput2.accessRow(row).selected := true;
		theForm.tblInput2.cnEcSetCellBackColor(row, 1, LightRed);
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="setCtrlsForView" id="489cd747-78ce-409c-8604-70a57fbb34ef">
        <updating/>
        <source>setCtrlsForView() updating;

/*

Date		Who		Reason
01 Sep 2009	cnwkpd1	PAR #20398 - Add Booking Reference cross reference functionality
21 Jun 2023	navdap1	TFS 56747 EUP Manifest Load - Internal (Zimmer) - Create
01 Aug 2025 navsp1  JIRA-35530 Solution Implementation - COPRAR Trailer Support
*/

vars

	theForm : SOP_TableMaintForm;

begin
	inheritMethod();    
	//epr tfs 8211 removed old drawing stuff
	theForm := self.myForm;
	theForm.tblInput1.userInputEnabled := false;
	theForm.cmbCargoBOLType.enabled := false;
	theForm.cmbCargoType2.enabled := false;
	theForm.cmbBOLType.enabled := false;
	theForm.cmbCargoGroup.enabled := false;		// TFS 56747
    theForm.cmbTrailerCargoType.enabled    := false; //JIRA-35530
	theForm.comboBox1.enabled := false;

 	theForm.tblInput2.userInputEnabled := false;

	theForm.btnAdvanced.visible := not theForm.getPropertyValue(SOP_TableMaintForm::amInitialisingWithObject.name).Boolean;		// PAR #20398 // CNWAB1 METRO JMT
	
	theForm.mnuContext1.visible := false;
	theForm.mnuContext2.visible := false;
	theForm.mnuContext3.visible := false;
	
	//+cnwml2 PAR23715 SFW CCMS1131
	theForm.tblFldSheet1.userInputEnabled := false;
	theForm.tblFldSheet2.userInputEnabled := false;
	
	
end;</source>
    </JadeMethod>
    <JadeMethod name="setObjectFromTableSpecial" id="e304a36e-4098-4c0b-b051-66a0e431d33d">
        <source>setObjectFromTableSpecial(_attrName   : String;
						  _strValue   : String;
						  _obj 		  : Object input;
						  _tbl 	      : CM_EntryTable input) : Boolean;
/* ---------------------------------------------------------------------------
// Created:		01 April 2003  by Jason Chapman  (cnwjc2)
// ---------------------------------------------------------------------------
// 25/02/2010	consw1		PAR #22337 - Correct setting of 'Default Contents Status for Pack Complete' option
// 24/06/2010	cnwcs5		par 24292 - changed defTurnaroundArea to be CM_TerminalArea
// 26/10/2010	cnwdap1		PAR #23794 CCMS MES 1102 added rail and ship load list release request options
// 12 Jun 2013		cnwrs1	ccms 1336 Par 31389 separate BGP EmailRequest to seperate read and send
//14/07/16		cnwns1		TFS 2300 	Multi-timezone not set by default - gives error	 
//12 Dec 2017	cnwrs1	TFS 3148/2866 use new HH config matchFindCargoConsignee
//25 September 2018	cnwma1	ChangeRequest 41080: PEL1 - Assigning Operators ID to Cranes/Work-Points
// 18 Mar 2019	jlgdi1		TFS# 41721 Added ETRow_RoadGateCargoCheck
// 17/10/2019	jlgdap1		TFS 46854 SNO Driver Identity Checking fo Cargo Releases
// 30/10/2019	jlgdi1		TFS 46578 Added Road Operations Delete Current Entry option
// 19 Mar 2021  cnwma1 		ChangeRequest 50925: ASPA - New Total Column in Invoice Form
//01/06/2022   navds20      TFS 52720 - Delivery Requests - All Release Types
//22/06/2022  	navhl20 	TFS 53862 EUP - WMS - Damage Recording Extra Details
//23 /06/2022 	navtnr20	TFS	53697: EUP - VBS MTN - [1] - VBS Slot Types
// 07 Sep 2022	navak20	TFS ChangeRequest 54505: MTN - Optional fields for Cargo Forecast on Voyage and Train
// 14 Sep 2022	navak20	TFS ChangeRequest 54628: MTN - Default IMEX for New Yard Allocations Forecast on Voyage and Train
//27Sep2022		navsp1 		TFS 54899: PEN - Reefer Monitor App Changes
// 20 Oct 2022 	navvt20		ChangeRequest 53424: MTN - MOB - Input Remarks - Jade
// 22 Feb 2023	jlika1		TFS 56385 - POB - IFCSUM Tranship
// 29/03/2023	navkc1		CR# 56430  Task 56439: Jade - Terminal Configuration
// 01/05/2023   navsp1      TFS ChangeRequest 57146: MTN - Prevent CAMS directory ending in a slash
//18/05/2023	jlika1	TFS 56398 EUP - OUT - Overlanded Cargo Handling - Web
  14/02/2024	jlika1	TFS 62427 CUX | FLP - Voyage Status Summary sheet access 
// 06 Dec 2024	navhl20 	Bug MTN-33627: MTN - 1090 exception on the Vehicle Booking Time Slot Maintenance form when saving the vbs slot
// 20 Jan 2025  naviv1	 	JIRA MTN-19155 - AAT - Swire Gate Out EDI Mapping
// 25 Mar 2025  naviv1		JIRA-19185 - PNL - Custom Stops not Added/Cleared for Motor Vehicles - DTR
// 31/03/2025	naviv1		MTN-33684 SNO | CUSRES EDI - UNH03 Segment field length Dev Changes
// 16/06/2025	jlizm1		MTN 34950 Add config to set if consignee must match release
// 14/08/2025	navdap1		MTN-35604 NSW - Partial Load Voyage EDI
// 29.10.25		Navcs2		MTN-36399	CUX | Booking with Release empties - Dev Changes
*/
vars
	theForm		 : SOP_TableMaintForm;
	rtnCode		 : Boolean;
	table 		 : CMUI_ListTable; 	// 07.09.2022 navak20 TFS 54505
	row			 : Integer; 	// 07.09.2022 navak20 TFS 54505
	str			 : String;		// 07.09.2022 navak20 TFS 54505
	url  		 : String;
begin

	if _tbl.name = SOP_TableMaintForm::tblInput1.name then
		return false;
	endif;
	
	rtnCode := true;
	
	theForm := self.myForm;
	if _attrName = ETRow_DefCommodityMT then	//09 Mar 2012	NDL	Par 28817
		if theForm.cmbMTCommodity.listObject = null then
			self.myIntFaceConfig.emptyCommodity := null;
		else
			self.myIntFaceConfig.emptyCommodity := theForm.cmbMTCommodity.listObject.CM_Commodity.code;
		endif;
	elseif _attrName = ETRow_AutoPop3Password then
		if theForm.enteredPassword &lt;&gt; null then
			/* 25 Aug 2021	NDL	TSF 51632
			//07 Jul 2017	NDL	TFS 5235
			if theForm.enteredPassword.length &gt; 64 then
				msg := app.getErrorString2( ERR_STRING_TO_LONG, app.getErrorString(Password), '64');
				app.msgBox( msg, app.getErrorString(Warning), MsgBox_OK_Only );
			endif;
			*/
			//self.myIntFaceConfig.autoPop3Password := theForm.enteredPassword[1:64];//_tbl.getValueByName(ETRow_AutoPop3Password).String;
			self.myIntFaceConfig.autoPop3Password := theForm.enteredPassword;
		endif;
	elseif _attrName = ETRow_AutoInwardSSLUsage then
		self.myIntFaceConfig.autoInwardSSLUsage		:= theForm.cmbInwardSSL.itemData[theForm.cmbInwardSSL.listIndex];
	elseif _attrName = ETRow_AutoEmailSoftware then
		if theForm.cmbSoftware.listIndex &gt; 0 then
			self.myIntFaceConfig.autoEmailSoftware := theForm.cmbSoftware.itemData[theForm.cmbSoftware.listIndex];
		endif;
	elseif _attrName = ETRow_EmailLicenseType then			// PAR 22506
		self.myIntFaceConfig.emailLicenseType := app.emailLicenseType_StrToEnum(_strValue);
		return true;
	elseif _attrName = ETRow_CamsTraceLevel then
		self.myIntFaceConfig.camsTraceLevel := theForm.cmbTraceLevel.getCurrentItemData();
	elseif _attrName = ETRow_DefaultContentsStatus then
		self.myIntFaceConfig.defaultContentsStatus := theForm.cmbContentStatus.text;
	elseif _attrName = ETRow_DefOperator then
		self.myIntFaceConfig.defOperator := theForm.cmbOperator.listObject.CM_Operator;
		
	elseif _attrName = ETRow_DefRecTrailIMEX then	//26 May 2017	NDL	TFS 4452
		if theForm.cmbDefTrailImex.listObject = null then
			self.myIntFaceConfig.defRecTrailIMEX := TI_IMEX_STATUS_STORAGE;
		else
			self.myIntFaceConfig.defRecTrailIMEX := theForm.cmbDefTrailImex.listObject.CM_IMEXStatus.code;
		endif;
		
	elseif _attrName = ETRow_DefRecTrailOper then	//22 Oct 2020	NDL	TFS 50113
		self.myIntFaceConfig.defRecTrailOper := theForm.cmbTrailDefOper.listObject.CM_Operator;
			
	elseif _attrName = ETRow_DefVoyage then
		self.myIntFaceConfig.defVoyage := theForm.cmbVoyage.listObject.CM_Voyage;
	elseif _attrName = ETRow_DefTAType then
		self.myIntFaceConfig.defTAType := theForm.cmbTAType.listObject.CM_TerminalAreaType;
	elseif _attrName = ETRow_StartupMoveMode then
		self.myIntFaceConfig.setStartupMoveMode(_tbl.getValueByName(ETRow_StartupMoveMode).String);
	elseif _attrName = ETRow_FinancialIOClass then // PAR 1215
		if theForm.cmbFinancialIO.listObject &lt;&gt; null then	//11 Mar 2016	NDL	TFS 1655
			self.myIntFaceConfig.setFinancialIOClass(theForm.cmbFinancialIO.listObject.CM_ExtFinanceIO.class);  // PAR 1215 
		endif;
	elseif _attrName = ETRow_FinancialsCalendar then // added for VTMIS invoicing HG 2/02/05
		self.myIntFaceConfig.myCalendar := theForm.cmbCalendar.myObject.CM_Calendar;  
		
//	elseif _attrName = ETRow_ExternalFinancialName 
	elseif _attrName = ETRow_CraneLaneDescription then
		self.myIntFaceConfig.craneLaneDescription := app.craneLaneDescStringToEnum(theForm.cmbCraneDesc.text);
	elseif _attrName = ETRow_ReportGrpDescriptionType then // PAR 34184
		self.myIntFaceConfig.reportGrpDescriptionType := app.repGrpDescTypeStringToEnum(theForm.cmbRepGrpDescTyp.text); // PAR 34184
		
	elseif _attrName = ETRow_VoyAllocSortOrder then // PAR 34184
		self.myIntFaceConfig.voyAllocSortOrder := app.voyAllocSortOrderStringToEnum(theForm.cmbVoyAllocSort.text); // PAR 34184
		
		
	elseif _attrName = ETRow_DefTurnaroundArea then
		self.myIntFaceConfig.defTurnaroundArea:=theForm.cmbTurnaround.listObject.CM_TerminalArea;			// 24/06/2010 cnwcs5 par 24292
//	elseif _attrName = ETRow_FillOption then																// SFW1030 30/10/2008
//		self.myIntFaceConfig.fillOption := app.fillOptionDescStringToEnum(theForm.cmbFillOption.text);		// SFW1030 30/10/2008
	elseif _attrName = ETRow_SelectorQueriesForRT then // ccms 1593 16 April 2008	cnwvu1
		self.myIntFaceConfig.mySelectorQueriesForRT := theForm.cmbSelectorQuery.listObject.CM_SelectorQueryAccess; 
	elseif _attrName = ETRow_SnapshotSummOnsiteCargo then	// Feb 2013 cnwjre1 CCMS HAT 2205
		self.myIntFaceConfig.snapshotSummOnsiteCargo := theForm.cmbSnapshotDefin.listObject.CM_OutputFormat_SS;
	elseif _attrName = ETRow_Is30IncludedForReports then // ccms 1029 21 May 2008	cnwvu1
		self.myIntFaceConfig.is30IncludedForReports := theForm.cmb30ForReports.getCurrentItemData();
	elseif _attrName = ETRow_Is45IncludedForReports then // ccms 1029 21 May 2008	cnwvu1
		self.myIntFaceConfig.is45IncludedForReports := theForm.cmb45ForReports.getCurrentItemData();
	elseif _attrName = ETRow_Is53IncludedForReports then // ccms 1029 21 May 2008	cnwvu1
		self.myIntFaceConfig.is53IncludedForReports := theForm.cmb53ForReports.getCurrentItemData();

	elseif _attrName = ETRow_TerminalsForRelease then
		self.myIntFaceConfig.allTerminalsForRelease.clear();
		theForm.lstTermRelease.allSelectedObjects.copy(self.myIntFaceConfig.allTerminalsForRelease);
	elseif _attrName = ETRow_TerminalsForVoyInland then
		self.myIntFaceConfig.allTerminalsForVoyageInland.clear();
		theForm.lstTermVoyInland.allSelectedObjects.copy(self.myIntFaceConfig.allTerminalsForVoyageInland);
	elseif _attrName = ETRow_WeipaSSReportEnabled then  //CCMS 1869 cnwjo3
		self.myIntFaceConfig.weipaSSReportEnabled := _tbl.getValueByName(ETRow_WeipaSSReportEnabled).Boolean;
	elseif _attrName = ETRow_DischargeHHLanderOption then
		self.myIntFaceConfig.dischargeHHLanderOption := theForm.cmbDisHHLandOpt.listData;
	elseif _attrName = ETRow_DefVoyCraneQDischMode then
		self.myIntFaceConfig.defVoyCraneQDischMode := theForm.cmbDefVCQDis.listData;
	elseif _attrName = ETRow_DefVoyCraneQLoadMode then
		self.myIntFaceConfig.defVoyCraneQLoadMode := theForm.cmbDefVCQLoad.listData;	
	elseif _attrName = ETRow_BookingRefRequired then		//+cnwml2 PAR23763 MSL PAR1078
		self.myIntFaceConfig.bookingRefRequired := app.bookingRequiredStringToEnum(theForm.cmbBookingReq.text);
	//Start 20 October 2022 navvt20 TFS 53424
	elseif _attrName = ETRow_WebWPRemarksOptions then 
		self.myIntFaceConfig.webWPRemarksOptions := app.remarksRequiredStringToEnum(theForm.cmbWPRRemarksOptions.text);
	elseif _attrName = ETRow_WebMOBRemarksOptions then 
		self.myIntFaceConfig.webMOBRemarksOptions := app.remarksRequiredStringToEnum(theForm.cmbMOBRemarksOptions.text); 
	//End 20 October 2022 navvt20 TFS 53424
	elseif _attrName = ETRow_HiCubePlanningWarning then		// 31/08/2010 +cnwmh5 #23453
		self.myIntFaceConfig.hiCubePlanningWarning := app.hiCubePlanWarnStringToEnum(theForm.cmbHCPlanWarning.text);
	// PAR #23794 CCMS MES 1102
	elseif _attrName = ETRow_RelReqOnRailLoadList then
		self.myIntFaceConfig.showRelReqOnRailLoadList := _tbl.getValueByName(ETRow_RelReqOnRailLoadList).Boolean;
	elseif _attrName = ETRow_RelReqOnShipLoadList then
		self.myIntFaceConfig.showRelReqOnShipLoadList := _tbl.getValueByName(ETRow_RelReqOnShipLoadList).Boolean;
	// PAR #23794 CCMS MES 1102 end
	elseif _attrName = ETRow_HhDelayTypeGroup then		// par 27755 June 2011 cnwjre1
		self.myIntFaceConfig.hhDelayTypeGroup := theForm.cmbDelayTypeGrp.listObject.CM_DelayTypeGroup;
	
	elseif _attrName = ETRow_DefNoInfoToDo then	//28 Jun 2011	NDL	Par 27003
		self.myIntFaceConfig.toDoTaskNoInfo := theForm.cmbToDoTask.listObject.CM_ToDoTaskDesc;
		
	elseif _attrName = ETRow_GridAreaSelectorSet then	//20 Jul 2011	NDL	Par 27890
		self.myIntFaceConfig.gridAreaSelectorSet := theForm.cmbGridAreaSel.listObject.CM_SelectorQueryAccess;
			
	elseif _attrName = ETRow_HhLanderGroundingOpt then	//10 Jul 2012	NDL	Par 29961
		if theForm.cmbGrounding.listIndex &gt; 0 then
			self.myIntFaceConfig.hhLanderGroundingOpt := theForm.cmbGrounding.itemData[theForm.cmbGrounding.listIndex];
		else
			self.myIntFaceConfig.hhLanderGroundingOpt := 0;
		endif;
		
	elseif _attrName = ETRow_HhTruckLoadScan then	// 19 Dec 2016	NDL	TFS 3129
		if theForm.cmbScanning.listIndex &gt; 0 then
			self.myIntFaceConfig.hhTruckLoadScan := theForm.cmbScanning.itemData[theForm.cmbScanning.listIndex];
		else
			self.myIntFaceConfig.hhTruckLoadScan := 0;
		endif;
		
	//11 May 2017	NDL	TFS 4016
	elseif _attrName = ETRow_UseAltSelectRulesTL then
		self.myIntFaceConfig.useAltSelectRulesTL := _tbl.getValueByName(ETRow_UseAltSelectRulesTL).Boolean;
		
	//cnwmc5 - PAR 31238
	elseif _attrName = ETRow_DefRailCarrier then
		if theForm.cmbRailCarrier.listObject = null then	//17 Oct 2013	NDL	Par 32608
			self.myIntFaceConfig.defRailCarrier := null;
		else
			self.myIntFaceConfig.defRailCarrier := theForm.cmbRailCarrier.listObject.String;
		endif;
		
	elseif _attrName = ETRow_VsBookingRule then	//17 May 2013	NDL	Par 31393
		self.myIntFaceConfig.vsBookingRule := app.vehicleBookingRuleInteger(theForm.cmbBookRule.text);
	
	elseif _attrName = ETRow_DefWeightTruck then	//12 Mar 2104	NDL	Par 33268
		self.myIntFaceConfig.defWeightTruck := self.getConvertedDisplayValue( ETRow_DefWeightTruck, weightType ).Integer;
	
	elseif _attrName = ETRow_DefWeightTrailer then	//12 Mar 2104	NDL	Par 33268
		self.myIntFaceConfig.defWeightTrailer := self.getConvertedDisplayValue( ETRow_DefWeightTrailer, weightType ).Integer;
	
	//cnwmc5 - 18 July 2014 - CCMS 2353
	elseif _attrName = ETRow_EdiCustomsStopsTable then	
		self.myIntFaceConfig.ediCustomsStopsTable := theForm.cmbStopsTable.listObject.CM_StopsTable;
	
	//07 Jan 2015	NDL	Par 35346
	elseif _attrName = ETRow_RailDefaultWCIdFormat then	
		self.myIntFaceConfig.railDefaultWCIdFormat := app.railLocationFormatStringToEnum(_tbl.getValueByName(ETRow_RailDefaultWCIdFormat).String);
		
	elseif _attrName = ETRow_TimeZoneID then
		if theForm.cmbTerminalTZone.listObject = null then													//TFS 2300 NDS 14/07/16
			self.myIntFaceConfig.timeZoneID := app.systemTimeZoneID;										//TFS 2300 NDS 14/07/16
		else																								//TFS 2300 NDS 14/07/16
			self.myIntFaceConfig.timeZoneID := theForm.cmbTerminalTZone.listObject.CMIF_TimeZoneInfo.id;
		endif;																								//TFS 2300 NDS 14/07/16
	elseif _attrName = ETRow_IgnoreFindCargoConsignee then	
		self.myIntFaceConfig.ignoreHHFindCargoConsignee := _tbl.getValueByName(ETRow_IgnoreFindCargoConsignee).Boolean;
	
	elseif _attrName = ETRow_CashOnlyInDebtOption then	//30 May 2018	NDL	TFS 38952
		self.myIntFaceConfig.cashOnlyInDebtOption := self.myForm.cmbDebtAction.listData;
		
	elseif _attrName = ETRow_TotDaysReqRoundedToHours then	//14 Aug 2018	NDL	TFS 40267
		if self.myForm.cmbRoundHrs.listIndex &lt; 1 then
			self.myIntFaceConfig.totDaysReqRoundedToHours := 0;
		else
			self.myIntFaceConfig.totDaysReqRoundedToHours := self.myForm.cmbRoundHrs.listData;
		endif;
	elseif _attrName = ETRow_ShipCraneOpHrsSecRole then	//25.09.2018 cnwma1 TFS #41080
		self.myIntFaceConfig.shipCraneOpHrsSecRole := theForm.cmbCraneOpSR.listObject.CM_SecurityRole;	
	elseif _attrName = ETRow_UpdateReleasedCargo then
		self.myIntFaceConfig.updateReleasedCargo := app.updateReleasedCgoStringToEnum(theForm.cmbUpdateRelCargo.text);		// 29/1/18 MAP TFS40701
	elseif _attrName = ETRow_RoadGateCargoCheckOption then  // TFS# 41721
		self.myIntFaceConfig.roadGateCargoCheckOption := getCargoCheckOption(theForm.cmbCargoCheckOption.text);		
	
	//start 01/06/2022 navds20 TFS 52720
	elseif _attrName = ETRow_YardOpsDelReqTypes then
		self.myIntFaceConfig.yardOpsDelReqTypes := app.yardOpsDeliveryTypeStrToEnum(theForm.cmbYardOpsDelReqTypes.text);
	//end 01/06/2022 navds20 TFS 52720
	
	// Start 10.02.2023 navpw1 TFS 53697
	elseif _attrName = ETRow_VsDefaultProcess then
		//self.myIntFaceConfig.myVBSProcess := theForm.cmbDefaultVbsProcess.listObject.CM_VBSProcess;						//06.12.2024 navhl20 #33627
		if theForm.cmbDefaultVbsProcess.listObject &lt;&gt; null then																//06.12.2024 navhl20 #33627
			self.myIntFaceConfig.myVBSProcess := theForm.cmbDefaultVbsProcess.listObject.CM_VBSProcess;
		else
			self.myIntFaceConfig.myVBSProcess := theForm.myTerminal.myRoot.allVBSProcesses[CM_VBSProcess.VBS_STANDARD_CODE];
		endif;
	// end 10.02.2023 navpw1 TFS 53697
	
	// start navhl20 22/06/2022  TFS 53862
	elseif _attrName = ETRow_DamageSizeDMType then
		self.myIntFaceConfig.damageSizeDMType := theForm.cmbMeasureType.listObject.CM_MeasurementType;
	// end navhl20 22/06/2022  TFS 53862
	// ### TFS BUG 58862 27JUN2023 NAVAB1	
	elseif _attrName = ETRow_DamageSeverityDefault then
		self.myIntFaceConfig.damageSeverityDefault := theForm.cmbDamageSeverity.listObject.CM_DamageSeverity;
	elseif _attrName = ETRow_RoadGateDriverIDCheck then															// TFS 46854
		self.myIntFaceConfig.roadGateDriverIDCheck := _tbl.getValueByName(ETRow_RoadGateDriverIDCheck).String;	// TFS 46854
		
	elseif _attrName = ETRow_RoadOpsDelCurEntryOption then
		self.myIntFaceConfig.roadOpsDelCurEntryOption := self.getDelCurrentEntryOption(theForm.cmbDelCurEntryOpt.text);
	elseif _attrName = ETRow_InvoiceRoundLineTotal then															// 19.03.2021 cnwma1 #50925
		self.myIntFaceConfig.invoiceRoundLineTotal := theForm.cmbRoundInvLine.listData;	
	
	elseif _attrName = ETRow_LocActRailYardCount  then	//02 Jun 2021	NDL	TFS 51245
		self.myIntFaceConfig.myLocActRailToYard := theForm.cmbRailYardEType.listObject.CM_EventType;
		
	elseif _attrName = ETRow_LocActVesselRailCount  then	//18 Jun 2021	NDL	TFS 51245
		self.myIntFaceConfig.myLocActVesselToRail := theForm.cmbVoyRailEType.listObject.CM_EventType;
		
	elseif _attrName = ETRow_LocActYardRailCount  then	//18 Jun 2021	NDL	TFS 51245
		self.myIntFaceConfig.myLocActYardToRail := theForm.cmbYardRailEType.listObject.CM_EventType;
		
	elseif _attrName = ETRow_LocActRailVesselCount  then	//18 Jun 2021	NDL	TFS 51245
		self.myIntFaceConfig.myLocActRailToVessel := theForm.cmbRailVoyEType.listObject.CM_EventType;
	
		
	elseif _attrName = ETRow_RoadGateRelReqVal then	//16 Aug 2021	NDL	TFS 51785
		if theForm.cmbRelReqVal.listIndex &lt; 1 then
			self.myIntFaceConfig.roadGateRelReqVal := 0;
		else
			self.myIntFaceConfig.roadGateRelReqVal := theForm.cmbRelReqVal.itemData[ theForm.cmbRelReqVal.listIndex ];
		endif;
		
	elseif _attrName = ETRow_RelReqConsigneeValidate then
		if theForm.cmbRReqConsigneeVal.listIndex &lt; 1 then
			self.myIntFaceConfig.relReqConsigneeValidate := 0;
		else
			self.myIntFaceConfig.relReqConsigneeValidate := theForm.cmbRReqConsigneeVal.itemData[ theForm.cmbRReqConsigneeVal.listIndex ];
		endif;
		
	elseif _attrName = ETRow_RelReqConsignorValidate then
		if theForm.cmbRReqConsignorVal.listIndex &lt; 1 then
			self.myIntFaceConfig.relReqConsignorValidate := 0;
		else
			self.myIntFaceConfig.relReqConsignorValidate := theForm.cmbRReqConsignorVal.itemData[ theForm.cmbRReqConsignorVal.listIndex ];
		endif;

	elseif _attrName = ETRow_ToDoTaskMAFILashing then	// 2/9/22 TFS 54700 jlier1
		self.myIntFaceConfig.toDoTaskMAFILashing := theForm.cmbToDoTaskLashing.listObject.CM_ToDoTaskDesc;
	
	//Start 07.09.2022 navak20 TFS 54505
	elseif _attrName = ETRow_CargoForecastReqdFields then
		table := self.myForm.tblForecastReqd;
		foreach row in table.fixedRows + 1 to table.rows do
			if table.accessCell(row, 1).text = "1" then
				if str = null then
					str := table.accessRow(row).itemObject.EntTableRow.name;
				else
					str := str &amp; "," &amp; table.accessRow(row).itemObject.EntTableRow.name;
				endif;
			endif;
		endforeach;
		self.myIntFaceConfig.cargoForecastReqdFields := str;
	//End 07.09.2022 navak20 TFS 54505
	
	// 14.09.2022 navak20 TFS 54628
	elseif _attrName = ETRow_DefaultIMEXStatusForYA then
		self.myIntFaceConfig.defYAIMEXForNew := theForm.cmbIMEX.listObject.CM_IMEXStatus;
	// 14.09.2022 navak20 TFS 54628
	elseif _attrName = ETRow_ReeferJobGrouping then //27Sep2022 navsp1 TFS 54899
		if theForm.cmbSortOrder.listIndex = 1 then
			self.myIntFaceConfig.reeferJobGrouping := null;
		else
			self.myIntFaceConfig.reeferJobGrouping := theForm.cmbSortOrder.text;
		endif;
	elseif _attrName = ETRow_DefTranshipInwardVoyage then
		self.myIntFaceConfig.defTranshipInwardVoyage := theForm.cmbDefTranInVoy.listObject.CM_Voyage;
	elseif _attrName = ETRow_DefTranshipOutwardVoyage then
		self.myIntFaceConfig.defTranshipOutwardVoyage := theForm.cmbDefTranOutVoy.listObject.CM_Voyage;
	
	//20Mar2023 navsp1 TFS 56275
	elseif _attrName = ETRow_EDIEnforceVeslMatchExprt then
		self.myIntFaceConfig.eDIEnforceVeslMatchExprt :=  _tbl.getValueByName(ETRow_EDIEnforceVeslMatchExprt).Boolean;
	//29/03/2023	navkc1	CR# 56430 TASK 56439
	elseif _attrName = ETRow_StateShortlandZeroQtyWgt then
		self.myIntFaceConfig.stateShortlandZeroQtyWgt := self.getStateShortlandInt(_tbl.getValueByName(ETRow_StateShortlandZeroQtyWgt).String);
	
	//01.May.2023 navsp1 TFS 57146
	elseif _attrName = ETRow_CamsFileDirectory then
		//Remove the end slash from cams file directory url.
		url :=	_tbl.getValueByName(ETRow_CamsFileDirectory).String.trimRight;
		if url[url.length:1] = "\" then
			url := url[1:url.length - 1];
		endif;		
		self.myIntFaceConfig.camsFileDirectory := url;
		
	elseif _attrName = ETRow_IsOverlandedDefaultValue then
		self.myIntFaceConfig.isOverlandedDefaultValue := _tbl.getValueByName(ETRow_IsOverlandedDefaultValue).Boolean;
	
	elseif _attrName = ETRow_CooSplittingOperator then
		self.myIntFaceConfig.cooSplitOperator := _tbl.getValueByName(ETRow_CooSplittingOperator).Boolean;	//navtnr20 19-07-2023 58234
	elseif _attrName = ETRow_ShowVoyStatSumInVoyOps then
		self.myIntFaceConfig.showVoyStatSumInVoyOps := _tbl.getValueByName(ETRow_ShowVoyStatSumInVoyOps).Boolean;
	elseif _attrName = ETRow_UseAddRemInOneStop then	//20-Jan-2025 naviv1 #19155
		self.myIntFaceConfig.useAddRemInOneStop := _tbl.getValueByName(ETRow_UseAddRemInOneStop).Boolean;
	elseif _attrName = ETRow_ProcOnSiteForBOLDTR then	//JIRA-19185
		self.myIntFaceConfig.procOnSiteForBOLDTR := _tbl.getValueByName(ETRow_ProcOnSiteForBOLDTR).Boolean;
	elseif _attrName = ETRow_CusresUNHIsCondition then	//JIRA-33684
		self.myIntFaceConfig.cusresUNHIsCondition := _tbl.getValueByName(ETRow_CusresUNHIsCondition).Boolean;
		
	// MTN-35604 start
	elseif _attrName = ETRow_EdiVoyagePartialWarning then
		self.myIntFaceConfig.ediVoyagePartialWarning := _tbl.getValueByName(ETRow_EdiVoyagePartialWarning).Boolean;
	elseif _attrName = ETRow_EdiVoyagePartialWarnDays then
		self.myIntFaceConfig.ediVoyagePartialWarnDays := _tbl.getValueByName(ETRow_EdiVoyagePartialWarnDays).Integer;
	// MTN-35604 end
	// 29.10.25	Navcs2	MTN-36399 Start
	elseif
		_attrName = ETRow_BookingAutoRelReqVoyage then	
		self.myIntFaceConfig.bookingAutoRelReqVoyage := app.bookingAutoRelStringToEnum(_tbl.getValueByName(ETRow_BookingAutoRelReqVoyage).String);
	// 29.10.25	Navcs2	MTN-36399 End
	else
		rtnCode := false;
	endif;

	return rtnCode;
end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_strValue" type="String"/>
        <Parameter name="_obj" type="Object" usage="input"/>
        <Parameter name="_tbl" type="CM_EntryTable" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setPrenoteCriteria" id="908c3e0d-02cd-4994-b3af-dea3e8efbf97">
        <source>setPrenoteCriteria() protected;
/*

Date		Who		Reason
13 May 2016	cnwer1	Initial creation TFS 1882

*/

vars
	terminal : CM_Terminal;
	crit, proxyCriteria		: CM_YACriteria;
	cmifCriteria			: CMIF_YACriteriaPriority;
	itemCode				: String;
	value					: Any;
begin
	self.allCriteria.purge;
	
	terminal:=self.getTerminal();
	
	if terminal = null or  terminal.myPrenoteWeightCriteria = null then
		return;
	endif;
	
	foreach crit in terminal.myPrenoteWeightCriteria.allCriteria do
		create proxyCriteria transient;
		itemCode := crit.myYACriteriaType.description.cnEcUpto(CM_YACriteriaPriority::code.length -1);
		value := crit.myYAData.getDataValue();
		proxyCriteria.setProxy(crit.myYACriteriaType, value, itemCode);
		cmifCriteria := proxyCriteria.getTransient();
		self.allCriteria.add(cmifCriteria);
	endforeach;
	
	self.displayCriteriaDesc(CM_TableViewForm.Mode_Update);
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setTableFromObjectSpecial" id="b2ead2b3-8e72-4683-8cfc-b527a5c4c4dc">
        <updating/>
        <source>setTableFromObjectSpecial(_tbl: CM_EntryTable input; _attrName: String; _row: Integer; _obj: Object): Boolean updating;
/* ---------------------------------------------------------------------------
   Created:     09 August 2002 by cnwrs2

   Purpose:     Call back method from setTableFromObject
   ---------------------------------------------------------------------------
   11/02/2010	cnwdap1		PAR #22332 Change Warehouse Area type from "General Cargo Area" to "Interchange Area"
   26/10/2010	cnwdap1		PAR #23794 CCMS MES 1102 added "Show Release Request on Rail/Ship Load List" options
   28/05/2013	cnwrs1		ccms 1336 Par 31389 separate BGP EmailRequest to seperate read and send
   03/06/2016	cnwdap1		TFS #1949 VGM Process Requirements - Allocations
   14/07/2016	cnwns1		TFS 2300 	Multi-timezone not set by default - gives error	 
   12/12/2017	cnwrs1		TFS 3148/2866 use new HH config matchFindCargoConsignee
   04/07/2017	cnwdap1		TFS 4492 SNO VERMAS Changes
   06/10/2017	cnwma1  	TFS #7257 JMT - Refactoring - Commodity Planning
   12/03/2018	jlgdap1		TFS 37427 PEl1 Voyage Status Enhancements
   25/09/2018	cnwma1		ChangeRequest 41080: PEL1 - Assigning Operators ID to Cranes/Work-Points
   05/11/2018	jlgrs1		TFS 38414 Remain on Board defaults
   18/03/2019	jlgdi1		TFS# 41721 Added ETRow_RoadGateCargoCheck
   17/10/2019	jlgdap1		TFS 46854 SNO Driver Identity Checking for Cargo Releases
   30/10/2019	jlgdi1		TFS 46578 Added Road Operations Delete Current Entry option
   24/07/2020	jlgdap1		TFS 49764 MTN Retire Basic Authentication to Exchange Online
   19/03/2021   cnwma1 		ChangeRequest 50925: ASPA - New Total Column in Invoice Form
   01/06/2022   navds20		TFS 52720 - Delivery Requests - All Release Types
   22/06/2022  	navhl20 	TFS 53862 EUP - WMS - Damage Recording Extra Details
   23/06/2022 	navtnr20	TFS	53697: EUP - VBS MTN - [1] - VBS Slot Types
   06/09/2022	navtnr20	ChangeRequest 54505: MTN - Optional fields for Cargo Forecast on Voyage and Train
   14/09/2022	navak20		TFS ChangeRequest 54628: MTN - Default IMEX for New Yard Allocations Forecast on Voyage and Train
   27/09/2022	navsp1 		TFS 54899: PEN - Reefer Monitor App Changes
   21/10/2022	navvt20		ChangeRequest 53424: MTN - MOB - Input Remarks - Jade
   02/11/2022	navcs2		Bug 54898 - EUP - Invoice currency symbol - Euro
   20/12/2022	navak20		Task 55978: EUP - VBS MTN - [1] - VBS Slot Types - Review Changes
   25/01/2023   navdp20 	Task 56236:[54344]- New Terminal Config Options for Auto Action Tasks 
   22/02/2023	jlika1		TFS 56385 - POB - IFCSUM Tranship
   16/03/2023	navmv20		TFS 56128 Task 56129: UI - Manual Invoice Lines - Multi TI Invoice Line Type
   29/03/2023	navkc1		CR# 56430  Task 56439: Jade - Terminal Configuration
   18/05/2023	jlika1		TFS 56398 EUP - OUT - Overlanded Cargo Handling - Web
   23/11/2023	navnk30		ChangeRequest 59299: MTN - Stop Creating Unqualified Audits for invoices when editing cargo items [Performance Improvement]
   10/04/2024	navdap1		TFS 63307 EUP | Performance - Cargo Enquiry Bulk Updates
   30/04/2024	navnk30		Bug 63894: MTN - Stop Creating Unqualified Audits for invoices Config not showing correct setting
   20/08/2024	navnk30		Bug 65567: MTN - Invoice API Consolidation Config
   26/11/2024	navdap1		MTN-33516 NSW | OnePort - Voyage Already Exists With External Code Error
   20 Jan 2025	naviv1		JIRA MTN-19155 - AAT - Swire Gate Out EDI Mapping
   20/03/2025   navsp1      JIRA-32985 LNX - Unable to create voyage due to previously existing voyage code
   25/03/2025   naviv1		JIRA-19185 - PNL - Custom Stops not Added/Cleared for Motor Vehicles - DTR
   31/03/2025	naviv1		MTN-33684 SNO | CUSRES EDI - UNH03 Segment field length Dev Changes
   16/06/2025	jlizm1		MTN 34950 Add config to set if consignee must match release
   14/08/2025	navdap1		MTN-35604 NSW - Partial Load Voyage EDI
   29.10.25		Navcs2		MTN-36399	CUX | Booking with Release empties - Dev Changes
*/
vars
	theForm			: SOP_TableMaintForm;
	theConfig		: CMIF_ConfigTerminal;
	rtnValue		: Boolean;
	emlEnt			: CM_EmailEntity;
	str				: String;
	proxyTerminal	: CM_Terminal;
	int 			: Integer;
	currSymbol 		: Integer;
	timezoneInfo	: CMIF_TimeZoneInfo;
	defImex 		: Integer;
	imex 			: CM_IMEXStatus;
	selectedImex 	: CM_IMEXStatus;
	weighAuthTerm	: CM_WeighAuthTerminal;		// TFS 4492
	weighAuth 		: CM_WeighAuthority;				// TFS 4492
	vbsProcess		: CM_VBSProcess;
	forecastFields  : StringArray;		//06.09.2022 navtnr20 54505
	values			: String;		   //06.09.2022 navtnr20 54505
	sortOrder 		: String;
	allJobs			: Boolean;
	extDef			: CM_ExternalWebServiceDef;		// MTN-35604
begin


	if _tbl.name = SOP_TableMaintForm::tblInput1.name then
		return false;
	endif;
	
	theForm		:=	self.myForm;
	theConfig	:=	self.myIntFaceConfig;
	rtnValue	:=	true;
	proxyTerminal := theForm.myProxyObject.CM_Terminal;
	
//	if _attrName = ETRow_AutoPlanDefaultMoveMap then						//SFW1030 30/10/2008
//		if theConfig.autoPlanDefaultMoveMap &lt;&gt; null then
//			_tbl.setValue(_row, theConfig.autoPlanDefaultMoveMap.id);
//		endif;
	// PAR 17412
	if _attrName[1:11] = "zTableBreak" then // PAR 33572
/*	if (_attrName = ETRow_ZTableBreak1 
	or _attrName = ETRow_ZTableBreak2
	or _attrName = ETRow_ZTableBreak3
	or _attrName = ETRow_ZTableBreak4
	or _attrName = ETRow_ZTableBreak5 or
		_attrName = ETRow_ZTableBreak6 or
		_attrName = ETRow_ZTableBreak7 or
		_attrName = ETRow_ZTableBreak8)	then*/
		_tbl.accessCell(_row,1).fontBold := true;
	elseif _attrName = ETRow_AutoEmailSoftware then
		self.myForm.cmbSoftware.listIndex := self.getEmailSoftwareListIndex(self.myIntFaceConfig.CMIF_ConfigTerminal.autoEmailSoftware);
		_tbl.setValue(_row, self.myForm.cmbSoftware.text);
		self.myForm.cmbSoftware_click(self.myForm.cmbSoftware);		// TFS 49764
		return true;
	elseif _attrName = ETRow_AutoInwardSSLUsage then
		self.myForm.cmbInwardSSL.listIndex := self.getSSLListIndex(self.myIntFaceConfig.CMIF_ConfigTerminal.autoInwardSSLUsage);
		_tbl.setValue(_row, self.myForm.cmbInwardSSL.text);
		return true;
	elseif _attrName = ETRow_EmailLicenseType then			// PAR 22506
		//self.initEmailLicenseTypeCombo();																// TFS 49764
		self.initEmailLicenseTypeCombo(self.myIntFaceConfig.emailLicenseType = EmailLicenseType_2);		// TFS 49764
		_tbl.setValue(_row, app.emailLicenseType_EnumToStr(self.myIntFaceConfig.CMIF_ConfigTerminal.emailLicenseType));
		return true;
	elseif _attrName = ETRow_CamsEmailAddress then
		_tbl.setValue(_row, theConfig.camsEmailAddress);
		emlEnt	:=	app.myRoot.allEmailEntities.getAtKeyGeq(Email_Address, self.myIntFaceConfig.camsEmailAddress);
		
		if emlEnt = null then
			emlEnt	:=	app.myRoot.allEmailEntities.getAtKeyGeq(Email_Group, self.myIntFaceConfig.camsEmailAddress);
		endif;
		
	   	theForm.cmbEmailAddress.setObject(emlEnt);

	elseif _attrName = ETRow_CamsTraceLevel then
		_tbl.setValue(_row, global.getCAMSTraceLevelDescr(theConfig.camsTraceLevel));
		theForm.myAssistant.comboBoxTraceLevel(theForm.cmbTraceLevel, self.myIntFaceConfig.camsTraceLevel);
	elseif _attrName = ETRow_ChkScalingPrint then
		_tbl.setValue(_row, theConfig.chkScalingPrint);
		// cnwrs1 Sept 2008 obsolete
//	elseif _attrName = ETRow_ChkScalingByScaler then
//		_tbl.setValue(_row, theConfig.chkScalingByScalerPrint);
	elseif _attrName = ETRow_DefCompany	then
		_tbl.setValue(_row, theConfig.defCompanyCode);
	   	theForm.myAssistant.comboBoxBank(theForm.cmbBank, theConfig.defCompany);
	elseif _attrName = ETRow_DefCommodity then
		_tbl.setValue(_row, theConfig.defCommodity);		
	   	theForm.myAssistant.comboBoxCommodity(theForm.cmbCommodity, app.myRoot.allCommodities[theConfig.defCommodity]);	
	elseif _attrName = ETRow_DefCommodityMT then	//09 Mar 2012	NDL	Par 28817
		_tbl.setValue(_row, theConfig.emptyCommodity);		
	   	theForm.myAssistant.comboBoxCommodity(theForm.cmbMTCommodity, app.myRoot.allCommodities[theConfig.emptyCommodity]);
	elseif _attrName = ETRow_DefWarehouseArea then
		//_tbl.setValue(_row, theConfig.defWarehouseArea);		  // cnwdad1 14/10/2009 - PAR #21312.
		
		//if proxyTerminal &lt;&gt; null then							//-cnwml2 PAR21304 
		// PAR #22332 theForm.myAssistant.comboBoxTerminalArea(theForm.cmbWarehouseArea,TA_TYPE_IRREGULAR_BLOCK_AREA, theForm.myAssistant.myTerminal.allTerminalAreas[theConfig.defWarehouseArea]);	// PAR 21304
		theForm.myAssistant.comboBoxTerminalArea(theForm.cmbWarehouseArea,TA_TYPE_YARD_INTERCHANGE, theForm.myAssistant.myTerminal.allTerminalAreas[theConfig.defWarehouseArea]);	// PAR 21304	// PAR #22332
		//endif;
		
// cnwdad1 14/10/2009 - - PAR #21312.  Moved to here an added condition because, if the above combobox doesn't contain
// the specified Terminal Area, then shouldn't set the table cell as this causes a conflict when editing.
		if theForm.cmbWarehouseArea.listIndex &lt;&gt; CNEC_NULL_INDEX then
			_tbl.setValue(_row, theConfig.defWarehouseArea);
		endif;
		
	elseif _attrName = ETRow_DefRoadOpsArea then
		_tbl.setValue(_row, theConfig.defRoadOpsArea);
		
		if proxyTerminal &lt;&gt; null then
			// par 21044 - road ops area is now an interchange area
			theForm.myAssistant.comboBoxTerminalArea(theForm.cmbRoadOpsArea,TA_TYPE_YARD_INTERCHANGE, theForm.myAssistant.myTerminal.allTerminalAreas[theConfig.defRoadOpsArea]);		
		endif;
	elseif _attrName = ETRow_StopCharging then
		_tbl.hideRowByName(ETRow_StopCharging, false);
		
	elseif _attrName = ETRow_DefReeferComdty then
		_tbl.setValue(_row, theConfig.defReeferComdty);
	   	theForm.myAssistant.comboBoxCommodityReefer(theForm.cmbReeferCmdty, app.myRoot.allCommodities[theConfig.defReeferComdty]);
	elseif _attrName = ETRow_DefHazCommodity then
		_tbl.setValue(_row, theConfig.defHazCommodity);
	   	theForm.myAssistant.comboBoxCommodity(theForm.cmbHazCmdty, app.myRoot.allCommodities[theConfig.defHazCommodity]);
	elseif _attrName = ETRow_DefDischargePort then
		_tbl.setValue(_row, theConfig.defDischargePortCode);
	   	theForm.myAssistant.comboBoxPort(theForm.cmbDischargePort, self.myIntFaceConfig.defDischargePort, null);
	elseif _attrName = ETRow_DefLoadPort then
		_tbl.setValue(_row, theConfig.defLoadPortCode);
	   	theForm.myAssistant.comboBoxPort(theForm.cmbLoadPort, self.myIntFaceConfig.defLoadPort, null);
	elseif _attrName = ETRow_DefCommodityGroup then		
		_tbl.setValue(_row, theConfig.defCommodityGroup);
   		theForm.cmbCommodityGrp.setObject(app.myRoot.allCommodityGroups[theConfig.defCommodityGroup]);
	elseif _attrName = ETRow_DefDebtor	then
		_tbl.setValue(_row, theConfig.defDebtorName);
		theForm.cmbDebtor.setObject(theConfig.defDebtor);
	elseif _attrName = ETRow_DefISOType	then
		_tbl.setValue(_row, theConfig.defISOTypeCode);
	   	theForm.myAssistant.comboBoxISOType(theForm.cmbISOType, self.myIntFaceConfig.defISOType);
	elseif _attrName = ETRow_DefISOType40	then
		_tbl.setValue(_row, theConfig.defISOType40Code);
	   	theForm.myAssistant.comboBoxISOType(theForm.cmbISOType40, self.myIntFaceConfig.defISOType40);
	elseif _attrName = ETRow_DefReeferISOType then
		_tbl.setValue(_row, theConfig.defReeferISOTypeCode);
	   	theForm.myAssistant.comboBoxISOType(theForm.cmbReeferISOType, self.myIntFaceConfig.defReeferISOType);
	elseif _attrName = ETRow_DefReeferISOType40 then
		_tbl.setValue(_row, theConfig.defReeferISOType40Code);
	   	theForm.myAssistant.comboBoxISOType(theForm.cmbReefISOTy40, self.myIntFaceConfig.defReeferISOType40);
	elseif _attrName = ETRow_DefOperator then
		_tbl.setValue(_row, theConfig.defOperatorCode);
	   	theForm.myAssistant.comboBoxOperator(theForm.cmbOperator, self.myIntFaceConfig.defOperator, null);
	//26 May 2017	NDL	TFS 4452
	elseif _attrName = ETRow_DefRecTrailIMEX then
		defImex := theConfig.defRecTrailIMEX;
		if defImex = 0 then
			defImex := TI_IMEX_STATUS_STORAGE;
		endif;
		selectedImex := app.myRoot.allImexStatuses.getAtKey( defImex );
		theForm.cmbDefTrailImex.clear();
		foreach imex in app.myRoot.allImexStatuses where 										
			imex.code = TI_IMEX_STATUS_STORAGE or
			imex.code = TI_IMEX_STATUS_REMAINONBOARD  do
			theForm.cmbDefTrailImex.addItemObject(imex.description, imex);
		endforeach;
		if selectedImex &lt;&gt; null then
			theForm.cmbDefTrailImex.listIndex := theForm.cmbDefTrailImex.findObject(selectedImex);
		endif;
		_tbl.setValue(_row, theForm.cmbDefTrailImex.text);
		return true;
	
	elseif _attrName = ETRow_DefRecTrailOper then	//21 Oct 2020	NDL	TFS 50113
		if theConfig.defRecTrailOper &lt;&gt; null then
			_tbl.setValue(_row, theConfig.defRecTrailOper.code);
			theForm.myAssistant.comboBoxOperator(theForm.cmbTrailDefOper, self.myIntFaceConfig.defRecTrailOper, null);
		endif;		
	elseif _attrName = ETRow_ReeferLabelPrinter then
		_tbl.setValue(_row, theConfig.reeferLabelPrinter);
	   	theForm.myAssistant.comboBoxPrinterDefs(theForm.cmbPrinters, false, self.myIntFaceConfig.reeferLabelPrinter);
	elseif _attrName = ETRow_Printer then
		_tbl.setValue(_row, theConfig.hhLabelPrinter);
	   	theForm.myAssistant.comboBoxPrinterDefs(theForm.cmbPrinters, false, self.myIntFaceConfig.hhLabelPrinter);
	elseif _attrName = ETRow_DefStevedore then
		_tbl.setValue(_row, theConfig.defStevedoreCode);
   		theForm.myAssistant.comboBoxStevedore(theForm.cmbStevedore, self.myIntFaceConfig.defStevedore);
	elseif _attrName = ETRow_TranshipConsign then
	  	theForm.cmbTranshipConsi.setObject(theConfig.transhipConsign);
		_tbl.setValue(_row, theForm.cmbTranshipConsi.text);	  	
	elseif _attrName = ETRow_DefTAType then
		_tbl.setValue(_row, theConfig.defTATypeDesc);
		theForm.myAssistant.comboBoxTAType(theForm.cmbTAType, self.myIntFaceConfig.defTAType, false);
	elseif _attrName = ETRow_DefVoyage then
		_tbl.setValue(_row, theConfig.defVoyageCode);
		
		if self.myIntFaceConfig.defVoyage = null then
			theForm.myAssistant.comboBoxVoyageObject(theForm.cmbVoyage, null);
			theForm.cmbVoyage.text := null;
		else
			theForm.myAssistant.comboBoxVoyageObject(theForm.cmbVoyage, self.myIntFaceConfig.defVoyage.code);
		endif;

	elseif _attrName = ETRow_DefaultContentsStatus then
		_tbl.setValue(_row, theConfig.defaultContentsStatus);
		theForm.myAssistant.comboBoxDefContentsStatus(theForm.cmbContentStatus, self.myIntFaceConfig.defaultContentsStatus);
	elseif _attrName = ETRow_DefWagonClass then
		_tbl.setValue(_row, theConfig.defWagonClass);
		theForm.myAssistant.comboBoxWagonClass(theForm.cmbWagonClass, app.myRoot.allWagonClasses[self.myIntFaceConfig.defWagonClass]);	
	elseif _attrName = ETRow_FinancialsCalendar then // added for VTMIS invoicing HG 2/02/05

		if theConfig.myCalendar &lt;&gt; null then 
			_tbl.setValue(_row, theConfig.myCalendar.code);
			theForm.cmbCalendar.setObject(theConfig.myCalendar);
		else 
			_tbl.setValue(_row, null);
			theForm.cmbCalendar.setObject(null);
		endif;

//	elseif _attrName = ETRow_FillOption then 								// SFW1030 30/10/2008
//		str :=app.fillOptionDescEnumToString(theConfig.fillOption);
//		_tbl.setValue(_row, str);
//		theForm.populateFillOptionCombo(theForm.cmbFillOption, str);
	elseif _attrName = ETRow_FinancialIOClass	then // CCMS 1215
		if theConfig.financialIOClass = null then
 			_tbl.setValue(_row, null); // CCMS 1215
	   		theForm.myAssistant.comboBoxFinancialIOClass(theForm.cmbFinancialIO, null); // CCMS 1215
	   	else
 			_tbl.setValue(_row, theConfig.financialIOClass.CM_ExtFinanceIO.getNiceName()); // CCMS 1215
	   		theForm.myAssistant.comboBoxFinancialIOClass(theForm.cmbFinancialIO, theConfig.financialIOClass.class); // CCMS 1215
	   	endif;
	elseif _attrName = ETRow_AllowInvPostUnqualAudits then // PAR 33572
		if theForm.myCurrentObject&lt;&gt; null then
			_tbl.setValue(_row, theForm.myCurrentObject.CM_Terminal.getConfig(InvPostWithoutAuditQual));
		endif;
	elseif _attrName = ETRow_DefaultBusinessUnitCargo then // PAR 33572
		self.doCmbBUsBuild(); 
		_tbl.setValue(_row, theForm.cmbBUs.text);
		
	elseif _attrName = ETRow_StorageConfigType then	//02 Nov 2017	NDL	TFS 7032
		self.doCmbStorConfigTypeBuild(); 
		_tbl.setValue(_row, theForm.cmbStorConType.text);	
	 // ### TFS BUG 58862 27JUN2023 NAVAB1
	elseif _attrName = ETRow_DamageSeverityDefault then
		self.doCmbDamageSeverityBuild(theConfig.damageSeverityDefault); 
		if theConfig.damageSeverityDefault &lt;&gt; null then
			_tbl.setValueByName(ETRow_DamageSeverityDefault, theConfig.damageSeverityDefault.description);
		endif;
	elseif _attrName = ETRow_InvReeferTempReadings then // PAR 33572
	
		self.doCmbReeferOptionsBuild(); 
		if self.myIntFaceConfig.CMIF_ConfigTerminal.chargeFirstTemperatureOnly then
			theForm.cmbReeferOptions.listIndex := 2;
		else
			theForm.cmbReeferOptions.listIndex := 1;
		endif;
		_tbl.setValue(_row, theForm.cmbReeferOptions.text);
	
	elseif _attrName = ETRow_InvoiceCurrencySymbol then // PAR 33572
		theForm.cmbCurrency.init();

		currSymbol := app.myRoot.getInvoiceCurrencySymbol();
		theForm.cmbCurrency.setIndexForItemData(currSymbol); // 4/11/2022   navcs2 ChangeRequest 54898
		_tbl.setValue(_row, currSymbol.Character);

	elseif _attrName = ETRow_DefaultDebtor then // PAR 33572
		_tbl.setValue(_row, theConfig.defDebtorName);
		theForm.cmbDebtor.setObject(theConfig.defDebtor);
		

	elseif _attrName = ETRow_InvUseInvoiceCargoAlloc then // PAR 35833
		_tbl.setValue(_row, theConfig.invUseInvoiceCargoAlloc);	// PAR 35833
		
		
		
	elseif _attrName = ETRow_InvWOVoyageTranOnAction then // TFS 42161
		_tbl.setValue(_row, theConfig.invWOVoyageTranOnAction);	// TFS 42161
	
	elseif _attrName = ETRow_InvShowAllSeparation then //16/032023  navmv20 TFS 56128 Task 56129
		_tbl.setValue(_row, theConfig.invShowAllSeparation); //16/032023  navmv20 TFS 56128 Task 56129
	elseif _attrName = ETRow_InvAuditCargoEdits then		//23.11.2023 navnk30 #59299
		_tbl.setValue(_row, theConfig.invAuditCargoEdits);	//30.04.2024 navnk30 #63894
		if app.myPassport.myUser.canDo(app.myPassport.myTerminal, PmAdmCargoChangeInvAudits) then
			_tbl.showRowByName(ETRow_InvAuditCargoEdits, false);
		else
			_tbl.hideRowByName(ETRow_InvAuditCargoEdits, false);
		endif;
	elseif _attrName = ETRow_ExternalExportPath then // PAR 33572
		if theConfig.financialIOClass &lt;&gt; null then	//22 Jul 2015	NDL	Par 36583 
			_tbl.setValue(_row, theConfig.financialIOClass.exportPath);
		endif;
	elseif _attrName = ETRow_FirstMonthFinancialYear then // PAR 33572
		if theConfig.financialIOClass &lt;&gt; null then	//22 Jul 2015	NDL	Par 36583 
			_tbl.setValue(_row, theConfig.financialIOClass.firstMonthOfFinYear);
		endif;
	elseif _attrName = ETRow_CurrentGLPeriod then // PAR 33572
		if theConfig.financialIOClass &lt;&gt; null then	//22 Jul 2015	NDL	Par 36583 
			_tbl.setValue(_row, theConfig.financialIOClass.glPeriod);
		endif;
	elseif _attrName = ETRow_CurrentGLYear then // PAR 33572
		if theConfig.financialIOClass &lt;&gt; null then	//22 Jul 2015	NDL	Par 36583 
			_tbl.setValue(_row, theConfig.financialIOClass.glYear);
		endif;
	elseif _attrName = ETRow_ExternalFinSysRemarks then // PAR 33572
		if theConfig.financialIOClass &lt;&gt; null then	//22 Jul 2015	NDL	Par 36583 
			_tbl.setValue(_row, theConfig.financialIOClass.remarks);
		endif;
	elseif _attrName = ETRow_ExternalFinancialName then // PAR 33572
		if theConfig.financialIOClass &lt;&gt; null then	//22 Jul 2015	NDL	Par 36583 
			_tbl.setValue(_row, theConfig.financialIOClass.name);
		endif;
	/* TFS 39618 Next Invoice Number is now on BU Maint
	elseif _attrName = ETRow_NextInvoiceNumber then // PAR 33572
		if theForm.myCurrentObject.CM_Terminal = null then	//02 Jun 2016	NDL	TFS 1968
			//do nothing, there is no terminal yet...
		else
			bu := theForm.myCurrentObject.CM_Terminal.getDefaultCompanyBank();		// 35872
			keyseries := bu.keySeries[SN_INVOICE];
