<Class name="CMQF_ContBtwnTerms">
    <JadeMethod name="setFromAgent" id="918f88d4-9466-460c-a170-4f506144d483">
        <updating/>
        <source>setFromAgent(_agent: CMUI_ReportAgent input) updating;

vars
	terminal : String;
	dateTo, 
	dateFrom : Date;
	timeTo,
	timeFrom : Time;
begin
	inheritMethod(_agent);
	
	if _agent.isRowIncluded(ETRow_DateTimeFrom) then
		dateFrom := _agent.getValueByNameIfVisible(ETRow_DateTimeFrom).Date;
	endif;
	
	if _agent.isRowIncluded(ETRow_TimeFrom) then
		timeFrom := _agent.getValueByNameIfVisible(ETRow_TimeFrom).Time;
	endif;
	
	self.dateTimeFrom.setDate(dateFrom);
	self.dateTimeFrom.setTime(timeFrom);
	
	if _agent.isRowIncluded(ETRow_DateTimeTo) then
		dateTo := _agent.getValueByNameIfVisible(ETRow_DateTimeTo).Date;
	endif;
	
	if _agent.isRowIncluded(ETRow_TimeTo) then
		timeTo := _agent.getValueByNameIfVisible(ETRow_TimeTo).Time;
	endif;
	
	self.dateTimeTo.setDate(dateTo);
	self.dateTimeTo.setTime(timeTo);
	
	if _agent.isRowIncluded(ETRow_FromTerminal) then
		terminal := _agent.getValueByNameIfVisible(ETRow_FromTerminal).String;
		self.fromTerminal := app.myRoot.allTerminals[terminal];
	endif;
	
	if _agent.isRowIncluded(ETRow_ToTerminal) then
		terminal := _agent.getValueByNameIfVisible(ETRow_ToTerminal).String;
		self.toTerminal := app.myRoot.allTerminals[terminal];
	endif;

epilog
end;</source>
        <Parameter name="_agent" type="CMUI_ReportAgent" usage="input"/>
    </JadeMethod>
</Class>
