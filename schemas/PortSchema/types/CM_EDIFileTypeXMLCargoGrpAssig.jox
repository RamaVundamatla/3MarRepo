    <JadeMethod name="create" id="cc34193b-2d98-4f63-a329-4675ff8c69f2">
        <updating/>
        <source>create() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
31 July 2015	cnwndl1	Initial creation	Par 36608

*/

vars

begin

	self.name := "Cargo Group Assignment";
	self.type := EDIFileType_XML_CargoGrpAssign;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="findEDIDataType" id="af470083-bd9f-4a58-bdec-7e77a601749d">
        <source>findEDIDataType(_ediDataClass: Class io; _dataType: Integer io; _fileTypeCode: Integer io);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
31 July 2015	cnwndl1	Initial creation	Par 36608

*/

vars

begin

	_ediDataClass := CM_EDIDataCargoGroupAssign;
	_dataType := EDIDataType_CargoGroupAssign;
	_fileTypeCode := self.type;

epilog

end;</source>
        <Parameter name="_ediDataClass" type="Class" usage="io"/>
