    <JadeMethod name="validateForDelete" id="ac19d8f7-d61f-4522-add1-d449d44e59b3">
        <source>validateForDelete();
// ---------------------------------------------------------------------------
// Created:		August  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin
	if self.allChildren.size &lt;&gt; 0 then
		app.raiseCMException2(ObjectStillHasEntries, self.heading, "sub items", null, null);
	endif;
end;</source>
