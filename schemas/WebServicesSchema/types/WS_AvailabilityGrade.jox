<Class name="WS_AvailabilityGrade" id="11118fa3-4197-4563-b5e0-ab37a9f186ff">
    <superclass name="WS_ProxyObject"/>
    <transient/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>Availability grade used to describe the state of a container. User definable.</text>
    <DbClassMap file="webservice"/>
    <PrimAttribute name="code" id="d6f090d2-65eb-4403-b835-c174d78770e2">
        <length>31</length>
        <embedded/>
        <type name="String"/>
        <text>Availability grade code.</text>
    </PrimAttribute>
    <PrimAttribute name="description" id="459abbf0-6a6e-46cc-b65a-2d4d7825b910">
        <length>101</length>
        <embedded/>
        <type name="String"/>
        <access>readonly</access>
        <text>Availability grade description.</text>
    </PrimAttribute>
    <JadeMethod name="setFromAvaGradeCodeDesc" id="fe3cbd9d-c713-49df-825b-f58f03194233">
        <updating/>
        <source>setFromAvaGradeCodeDesc(_code, _desc : String) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
27 March 2009	#cnwdz2	 PAR 19014 - correct selection of ava grade

*/

vars

begin
	self.cmObjectId := _code;
	self.code := _code;				//cnwmc5 - 12 May 2014
	self.description := _desc;
epilog

end;</source>
        <Parameter name="_code" type="String"/>
        <Parameter name="_desc" type="String"/>
    </JadeMethod>
    <JadeMethod name="setProxyFromObject" id="3628b943-ad96-4832-96c1-d7a6d422244e">
        <updating/>
        <source>setProxyFromObject( _grade : CM_MTGrade ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 May 2014	cnwmc5	Initial creation

*/

vars

begin

	inheritMethod(_grade);
	
	self.code := _grade.code.String;
	self.description := _grade.description;
	
epilog

end;</source>
        <Parameter name="_grade" type="CM_MTGrade"/>
    </JadeMethod>
</Class>
