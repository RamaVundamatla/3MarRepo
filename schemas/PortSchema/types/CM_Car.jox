    <JadeMethod name="getPicture" id="279a1bdb-eae1-4ee5-8a98-62730858e458">
        <source>getPicture(): Binary;
// ---------------------------------------------------------------------------
// Created:		June  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 28 May 2024 navma1	Bug 64224: MTN - DeadLocks Caused by Future Actors
// ---------------------------------------------------------------------------

constants
	FrameWidth = 200;																			// cnwjk3 PAR 23608 16/04/2010
	FrameHeight = 80;																			// cnwjk3 PAR 23608 16/04/2010
vars
	thePicture	: Binary;																		
	tmpFrame 	: Frame;																		// cnwjk3 PAR 23608 16/04/2010
	tmpForm 	: Form;																			// cnwjk3 PAR 23608 16/04/2010
	tmpPic 		: Binary;																		// cnwjk3 PAR 23608 16/04/2010
	cargoType   : CM_CargoType;
begin
	cargoType := self.myCargoType;																//28.05.2024 navma1 #64224
	
	if cargoType = null or cargoType.myTIBehaviourType = null then								// cnwjk3 PAR 23608 16/04/2010
		if not self.myTerminal.getConfig(ShowCargoPicture).Boolean then
			return null;
		endif;

		thePicture := app.myRoot.getConfig(PicCargoCar).Binary; 
		return thePicture;
	else																						// cnwjk3 PAR 23608 16/04/2010
		tmpForm := app.activeForm();															// cnwjk3 PAR 23608 16/04/2010		
		if tmpForm = null then																	// cnwjk3 PAR 23608 16/04/2010
			return null;																		// cnwjk3 PAR 23608 16/04/2010			
		endif;																					// cnwjk3 PAR 23608 16/04/2010

		create tmpFrame transient;																// cnwjk3 PAR 23608 16/04/2010
		tmpFrame.visible := true;																// cnwjk3 PAR 23608 16/04/2010
		tmpFrame.caption := null;															// cnwjk3 PAR 23608 16/04/2010
		tmpFrame.left:= -FrameWidth;
		tmpFrame.width := FrameWidth;															// cnwjk3 PAR 23608 16/04/2010
		tmpFrame.height := FrameHeight;															// cnwjk3 PAR 23608 16/04/2010
	
		tmpForm.addControl(tmpFrame);															// cnwjk3 PAR 23608 16/04/2010
		tmpFrame.autoRedraw := true;															// cnwjk3 PAR 23608 16/04/2010
	
		if cargoType.myTIBehaviourType &lt;&gt; null then										// cnwjk3 PAR 23608 16/04/2010
			cargoType.myTIBehaviourType.myGraphic.drawGraphic(tmpFrame, 1 ,0,0,false,0, true,self.id,self, self.getDefaultColour); 	// cnwjk3 PAR 23608 16/04/2010
		endif;																					// cnwjk3 PAR 23608 16/04/2010	
		tmpPic := tmpFrame.createPicture(false,false,24);										// cnwjk3 PAR 23608 16/04/2010

		return tmpPic;																			// cnwjk3 PAR 23608 16/04/2010				
	endif;
epilog
	delete tmpFrame;																			// cnwjk3 PAR 23608 16/04/2010
end;</source>
        <ReturnType type="Binary"/>
    </JadeMethod>
    <JadeMethod name="getShortDescriptions" id="b2fef3cd-0ba1-48b9-8954-e1374f9b90ee">
        <source>getShortDescriptions(desc1: String output; desc2: String output);
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 23/09/2013	cnwdap1		Initial creation PAR #32215 CCMS DPH 2290 New Car Attributes
//
vars
	retStr1, retStr2	: String;
	hazDets : String;

begin
	// if we have make and model, put these on line 1 and don't bother with cargo type
	// if we only have one of make or model, put this on line 1 with cargo type
	if self.make &lt;&gt; null and self.model &lt;&gt; null then
		retStr1 := self.make &amp; Space &amp; self.model;
	else
		retStr1 := app.myRoot.allCargoTypesById[self.cargoType].description &amp; Space;
		if self.make &lt;&gt; null then
			retStr1 := retStr1 &amp; self.make;
		elseif self.model &lt;&gt; null then
			retStr1 := retStr1 &amp; self.model;
		endif;
	endif;
	
	if self.year &lt;&gt; null then
		retStr2 := self.year.String &amp; Space;
	endif;
	if self.carType &lt;&gt; null then
		retStr2 := retStr2 &amp; self.carType &amp; Space;
	endif;
	if self.colour &lt;&gt; null then
		retStr2 := retStr2 &amp; self.colour;
	endif;
	
	//19 Jun 2017	NDL	TFS 4587
	if self.myTerminal &lt;&gt; null and self.myTerminal.getConfig( HhIncludeHazDet ).Boolean then
		hazDets := self.getDisplayStringForAttribute( ETRow_AllTIHazards, false );
	endif;
	if hazDets &lt;&gt; null then
		retStr2 := hazDets &amp; ", " &amp; retStr2;
	endif;
	
	desc1 := retStr1;
	desc2 := retStr2;
	
epilog

end;</source>
        <Parameter name="desc1" type="String" usage="output"/>
        <Parameter name="desc2" type="String" usage="output"/>
    </JadeMethod>
