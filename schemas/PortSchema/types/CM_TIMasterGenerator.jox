    <JadeMethod name="validateMe" id="537ddd61-a451-48ba-aad0-16f385e31a1e">
        <source>validateMe();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
12 August 2008	cnwrd1	Initial creation
//     required fields for GenSet are ID Operator, GenSet Type, ISO Type
15 May 2018 cnwma1	Bug 38671: Clip on Gen Set with an ISO Type?
*/

vars
	isoType	: CM_ISOType;
	
begin

	inheritMethod();
	
	if self.cargoType &lt;&gt; TI_CargoType_Generator then
		app.raiseUnexpectedProgramError( class.name, method.name, 'Cargo type is not the generator' );
	endif;
	
	if self.isoType = null then
			// ISO Type required.
	//	app.raiseCMException1(REQUIRED_FIELD, app.getErrorString(ISO_Type), 'isoType', null);
	//	app.raiseCMException1(Input_required_field_Required, app.getErrorString(ISO_Type), 'isoType', null); // cnwdb2	PAR 35364 //15.5.2018 cnwma1 Bug #38671
		app.raiseCMWarning1(Input_required_field_Required,app.getErrorString(ISO_Type),null,null,null);		//15.5.2018 cnwma1 Bug #38671
	endif;

	
	/*
	if self.description = null then
		app.raiseCMException1(REQUIRED_FIELD, app.getErrorString( Description ), null, null);
	endif;
	*/

	if self.myGeneratorType = null then
	//	app.raiseCMException1(REQUIRED_FIELD, app.getErrorString( Generator_type ), null, null);	
		app.raiseCMException1(Input_required_field_Required, app.getErrorString( Generator_type ), null, null);	// cnwdb2	PAR 35364
	else
		if self.myGeneratorType.isNoseMounted or self.myGeneratorType.isStandAlone() then	//Generator designed for containers
			// the question - according to ccms1045, Par17775 isoType is not mandatory
			//if self.isoType = null then
			//	app.raiseCMException1(REQUIRED_FIELD, app.getErrorString(ISO_Type), null, null);
			//endif;
			if self.isoType &lt;&gt; null then
				isoType := app.myRoot.allISOTypes[ self.isoType ];
				if not isoType.isReefer() then
					app.raiseUnexpectedProgramError( class.name, method.name, 'ISO type should be reefer for generators' );			
				endif;
			endif;
		endif;
	endif;

	/* moved up
	if self.myOperatorNew = null or self.myOperatorNew.isKindOf(CM_NullOperator) then
		app.raiseCMException1(REQUIRED_FIELD, app.getErrorString(Operator), null, null);
	endif;
	*/

	
end;</source>
    </JadeMethod>
