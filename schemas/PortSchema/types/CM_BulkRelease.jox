    <JadeMethod name="setStatus" id="51b8e18a-4dd7-4568-8de0-85854ca5949f">
        <updating/>
        <source>setStatus(_newStatus : Integer; _isEmailChanged : Boolean; _suppressPin : Boolean) updating;
// ---------------------------------------------------------------------------
// Created:     01 August 2002 by cnwrs2
//
// Purpose:  
//    
// ---------------------------------------------------------------------------
// 13/02/2012	cnwcs5	par 28756 - changed methode signature (noPINforHazardousODProcess)
vars
	oldStatus	: Integer;
	resDetail : CM_ReserveDetail;
	docActions : CM_DocumentActions;
	reason : String;
begin
	// we do not want to do any associated updates if this is a transient
	if self.isTransient then
		self.status 	:= _newStatus;
		return;
	endif;
	
	//25 Oct 2016	NDL	TFS 2648 / 2419
	if _newStatus = BR_COMPLETE and self.status &lt;&gt; _newStatus then
		foreach resDetail in self.allReserveDetails do
			docActions := resDetail.myReserveDetailActions;
			if docActions &lt;&gt; null then
// TFS 4052				if not docActions.areAllActionsComplete(reason) then
				if not docActions.areAllActionsCompleted(reason) then // TFS 4052
					app.raiseCMWarning2(Relea_canno_compl_while_out, self.code, reason, null, null, null);
					break;
				endif;
			endif;
		endforeach;
		//24 Mar 2020	NDL	TFS 47004
		foreach resDetail in self.allReserveDetails do
			if not resDetail.allRRPs.isEmpty then
				resDetail.allRRPs.purge();	
			endif;
		endforeach;
	endif;

	exclusiveLock(self);

	oldStatus := self.status;	//Par 19408, ccms 1769. April 2009
	self.emailNotifyForStatusChanged(oldStatus, _newStatus);
	
	if self.status &lt;&gt; _newStatus then
		self.status 	:= _newStatus;
		self.statusDate	:= app.serverTimestampAtTrxStart;
	endif;
	
	if self.status = BR_COMPLETE or self.status = BR_ARCHIVE then
		self.detachUnusedTIs();
	endif;
	
	// 15/05/2009 cnwar2 CCMS1723/#19725
	if not _suppressPin then
		if self.type = BR_TYPE_ROAD then
			if self.status &lt;&gt; BR_ACTIVE then
				// changing from ACTIVE to other - embargo pin but leave attached to br
				//epr TFS 6644 24/8/17
				if self.status &lt;&gt; BR_ARCHIVE and self.myTerminal.getConfig(PinEmbargoDays).Integer &lt;&gt; 0 then
					if self.myPinNo &lt;&gt; null then
						self.myPinNo.isEmbargoed := true;
						self.myPinNo.embargoedTS := app.serverTimestampAtTrxStart;
					endif;
				else
					self.removePin(null);
				endif;
			else
				// changing to ACTIVE
				if self.myPinNo = null then
					self.generatePinNo(_isEmailChanged);
				else
					if self.noPINforHazardousODProcess(self.myPinNo, app.myPassport) then
						return;	// 22/07/2009 cnwar2 #20333 - pin deleted for Haz/OD cargo
					endif;
					
					// unembargo existing pin
					self.myPinNo.isEmbargoed := false;
					self.myPinNo.embargoedTS := null;
					
					if _isEmailChanged = true then
						self.emailNotify(null, false, self.myPinNo);
					endif;
				endif;
			endif;
		else	//31 Jan 2011	NDL Par 26787
			self.removePin(null);
		endif;
	endif;
	
end;</source>
        <Parameter name="_newStatus" type="Integer"/>
        <Parameter name="_isEmailChanged" type="Boolean"/>
        <Parameter name="_suppressPin" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setSubTerminal" id="be5a798f-93e7-4d3f-842d-39838933b301">
        <updating/>
        <source>setSubTerminal(_subTerminalObj:CM_SubTerminal) updating;
// --------------------------------------------------------------------------------
// Created:		02 July 2009 by cnwdad1
//
// Purpose:		Sets a reference to the reciver's Sub-Terminal.
//
// Parameters:	_subTerminalObj - A reference to the Sub-Terminal object.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.mySubTerminal	:=	_subTerminalObj;
end;</source>
        <Parameter name="_subTerminalObj" type="CM_SubTerminal"/>
    </JadeMethod>
    <JadeMethod name="setSubTerminalDefault" id="441e207b-5555-4535-9e0b-7477097c5f41">
        <updating/>
        <source>setSubTerminalDefault(	_stForBulkSourceObj:CM_SubTerminal;
						_stForBulkTargetObj:CM_SubTerminal) updating;
// --------------------------------------------------------------------------------
// Created:		09 April 2009 by cnwdad1
//
// Purpose:		Sets the default appropriate Sub-Terminal for the receiver.
//
//	This method was implemented primarily for when Sub-Terminals is enabled for a
//	Terminal, when all of the Tracked Items need to have their default set.
//
//	If the receiver's Sub-Terminal is already set, then do nothing.
//
// Parameters:	_stForBulkSourceObj - Sub-Terminal for Bulk source location.
//				_stForBulkTargetObj - Sub-Terminal for Bulk target location.
//
// Returns:		A reference to the receiver's Sub-Terminal default.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if self.mySubTerminal = null then
		self.mySubTerminal	:=	_stForBulkSourceObj;
	endif;
	
	if self.type = BR_TYPE_PACKING and self.mySubTerminalTarget = null then
		self.mySubTerminalTarget	:=	_stForBulkTargetObj;
	endif;
end;</source>
        <Parameter name="_stForBulkSourceObj" type="CM_SubTerminal"/>
        <Parameter name="_stForBulkTargetObj" type="CM_SubTerminal"/>
    </JadeMethod>
    <JadeMethod name="setType" id="6c301cd7-4a44-4396-869d-4aac869cc665">
        <updating/>
        <source>setType(_type : Integer) updating;
// ---------------------------------------------------------------------------
// Created:		November 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

begin
	if _type &lt;&gt; self.type then
		self.type := _type;
	endif;
end;</source>
        <Parameter name="_type" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="shouldAuditProperty" id="cf3e580a-5e68-4484-a647-f6f01033ba19">
        <source>shouldAuditProperty(_rootClass: Class; _property: Property): Boolean protected;
// ---------------------------------------------------------------------------
// Created:		24 June 2003  by Jason Chapman  (cnwjc2)
// ---------------------------------------------------------------------------

vars
	propName	: String;

begin

	if _property = null then
		return false;
	endif;
	
	propName := _property.name;
	
	if propName = CM_BulkRelease::allTrackedItemsAssigned.name or
	   propName = CM_BulkRelease::allTrackedItemsReleased.name or
	   propName = CM_BulkRelease::myCargoType.name or		// 04/02/2008 cnwar2 - 	audited from reserve, these attributes 
	   propName = CM_BulkRelease::myISOGroup.name then		//						do not seem to be used
		return false;
	else
		return inheritMethod(_rootClass, _property);
	endif;


end;</source>
        <access>protected</access>
        <Parameter name="_rootClass" type="Class"/>
        <Parameter name="_property" type="Property"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="statusString" id="cbbbb94a-4fa0-4e78-9ae1-0554dc67f49f">
        <methodInvocation>mapping</methodInvocation>
        <updating/>
        <source>statusString(set: Boolean; _value: String io) updating, mapping;
// ---------------------------------------------------------------------------
// Created:     22 February 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	newStatus	: Integer;

begin

	if set then
		app.raiseSetVirtualError(class.name, method.name);
	else
		if self.status = BR_PENDING then
			_value := BR_PENDING_STRING;
		elseif self.status = BR_ACTIVE then
			_value := BR_ACTIVE_STRING;
		elseif self.status = BR_COMPLETE then
			_value := BR_COMPLETE_STRING;
		elseif self.status = BR_ARCHIVE then
			_value := BR_ARCHIVE_STRING;			
		else
			_value := null;
		endif;
	endif;
	
end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="testCandidateTI" id="4c89dc0b-a3b2-4032-882e-1a39c5637c8e">
        <source>testCandidateTI(_ti : CM_TrackedItem);
//--------------------------------------------------
// Created:	27 November 2003 By: cnwgd1
//--------------------------------------------------
vars

begin

	if _ti = null then
		app.raiseCMException2(MethodWithNullParam, method.name, 'Tracked Item',null, null);
		return;
	endif;
	//th2 - changed to only check ti inclusion in the releases allTrackedItems collection if
	//its a release by ID
	if (not self.releaseByType) and (not self.allTrackedItemsAssigned.isEmpty) then
		if (not self.allTrackedItemsAssigned.includes(_ti)) then
			if  not _ti.myCargoType.isBreakBulkMulti or not hasTIAssignedMatchesID(_ti) then //epr par 32330 29/8/13
			
				// This is always and ERROR, not a warning regardless of number requested and number assigned - Sheryl 27/11/03
				app.raiseCMException2(TINotAllocatedToRelease, _ti.id, self.code, 'Bulk Release', app.getMyUser());
			endif;
		endif;
	endif;
	//CCMS 1028
	// theBulkRelease.allTrackedItems is a collection of allocated TIs. If there is anything in the collection then only those TIs can be used.
	if (not _ti.allBulkReleasesAssigned.isEmpty())
	and (not _ti.allBulkReleasesAssigned.includes(self)) and  (not _ti.myCargoType.isBreakBulkMulti) then
		app.raiseCMException2(ERR_TI_ALREADY_ALLOCATED, _ti.id, _ti.allBulkReleasesAssigned.first.code, null, null);
	endif;

	self.testCandidateTIBeingActioned(_ti);			
end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="testCandidateTIBeingActioned" id="a9ea90ee-07f5-411c-b14c-edc5324eefc8">
        <source>testCandidateTIBeingActioned(_ti : CM_TrackedItem) protected;
//-----------------------------------------
// Created: November 2003 By: cnwgd1
//-----------------------------------------
//15/07/2022 navmv20    Bug 54076: CUX - Swapping Release Cargo and Road Exit Issues
//28 May 2024 navma1	Bug 64224: MTN - DeadLocks Caused by Future Actors
//17 Mar 2025 navma1 	MTN-34120 MTN | Dead Lock (1081) on CM_OfflineFutureActorParentDct
//------------------------------
vars
	req	 : CM_Request;
	ct	 : CM_CargoType;
begin
	
	if _ti = null then
		app.raiseCMException2(MethodWithNullParam, method.name, 'Tracked Item',null, null);
		return;
	endif;

	if _ti.releaseRequest = null then
		return;
	endif;
	
	//epr par 34406 25/6/14
	ct := _ti.myCargoType;							//28.05.2024 navma1 #64224
	if ct.isBreakBulkMulti or ct.isBulkMulti then	//28.05.2024 navma1 #64224
		return;
	endif;

	if app.isSubTerminalsOn(self.myTerminal) then
		_ti.validateForBulkReleaseSubTerm(self);
	endif;
	
	foreach req in self.allRequestsBeingActioned do
		if req.isDeliveryRequest then				//17.03.2025 navma1 #MTN-34120
			sharedLock(req);
			
			if req.CM_DeliveryRequest.allTrackedItemsAllocated.includes(_ti) then
				app.raiseCMException2(ERR_TI_ALREADY_ALLOCATED, _ti.id, req.myJob.jobId, null, null);
				return;								
			endif;
		else
			//epr par 35024 8/10/14 
			if req.getTrackedItem() = _ti and _ti.releaseRequest &lt;&gt; req then //15/07/2022 navmv20 54076
				// already allocated
				app.raiseCMException2(ERR_TI_ALREADY_ALLOCATED, _ti.id, req.myJob.jobId, null, null);
				return;					
			endif;		
		endif;
	endforeach;
end;</source>
        <access>protected</access>
        <Parameter name="_ti" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="updateStatus" id="2e2ee692-874b-4520-a20a-6785c82df3f9">
        <updating/>
        <source>// 12/01/2024 navcs2 Bug 62030: MTN - Release Requests Completing with weight outstanding

updateStatus() updating;

vars
	
begin
	
	if self.releasedItemStrings.isEmpty() then	
		// nothing has been released yet
		// NOTE: totalRequested can be zero if releasing break bulk cargo
		// therefore need to check that something has actually been released
		// before doing the following
		return;
	endif;
	
	
	//epr par 36061 29/4/15 removed code below will be correctly checked in getTotalOutstanding	
	
	//epr par 34406 25/6/14 include weight aswell
	if self.getTotalOutstanding() &lt;= 0 and self.getWeightOutstanding() &lt;= 0 then									//cnwmc5 - PAR 32473 - replacement		// 12/01/2024 navcs2 Bug 62030
		//th2 30/05/2007 - in the event this is a split release, the releasedItemStrings is cleared
		//and the previously released TIs are preseved in the self.allTrackedItemsReleased collection
		if self.status = BR_ACTIVE or self.status = BR_PENDING then
			self.setStatus(BR_COMPLETE, false, false);
		endif;
		//Release is complete, detach unused TIs so they can be used elsewhere
		self.detachUnusedTIs();
	endif;

end;</source>
    </JadeMethod>
    <JadeMethod name="validate" id="057aeb5c-4ea6-40ad-9800-4bf261f1cd98">
        <source>validate(_passport : CM_Passport input) :Boolean protected;
// ---------------------------------------------------------------------------
// Created:     22 February 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 01/07/2008	cnwdad1		PAR #17171 - Added validation to check that if a
//							Booking Reference is attached tothe receiver, its
//							isStockBookingRef flag is true.
// 18/09/2009	consw1		SFW1035 - get info from ReserveDetail rather than Yard Request.
// 23/11/2011	cnwcs5		CCMS POL 2122 / par 28696 - new type of UNKNWON
// 13/02/2012	cnwcs5		par 28756 - removed updating from method signature
// 15/12/2014  cnwdb2	PAR 35364
// 10/04/2015   cnwma1      PAR 35933 Vehicle Bookings - Release Requests
// 03/04/2017   cnwma1		TFS #3766:POL - Release does not have any requests associated with it error
// 30/06/2017   cnwma1		TFS #4728:POL - [Fwd: ##4623## : Pack Plan problem - missing releases not flagged]
// 02/08/2017	cnwma1		TFS #5209:PEN - Release Request Stop
// 21 Aug 2018	jlgrs1	TFS 39619 PEN - Approved Carriers For Operator 
//29/08/2018	JLGNS1	Bug 40008: PEN - Restrict Operator Issue - removed TFS2749
// 19 Aug 2019	jlgdap1		TFS 45836 PEN Approved Carrier for ISO Type and Trailer Type
// 30 Jan 2024	navhn30		Bug 61952: EUP - EstimatedDateTimeOfArrival issue in Call Off file sent via RestAPI
// 05 Feb 2024	jlirs1	TFS 61640 EUP Release Request by Type by Weight
// ---------------------------------------------------------------------------
vars
	tmpBR					: CM_BulkRelease;
	tmpStr					: String;
	numReleased,
	numRequested,
	numCurrentlyActioned,
	numShouldReceive,
	totalRequestedThisJob	: Integer;
	bookRefObj				: CM_BookingRef;
	voyageObj				: CM_Voyage;
	refVoyageObj			: CM_Voyage;
	nullVoyageObj			: CM_Voyage;
	realBulkRelease			: CM_BulkRelease;	
	expectedEdition			: Integer;
	tmpPinNo				: CM_PinNo;
	tmpConsignee			: CM_ConsigneeConsignor;
	tmpPortDestCode			: String;
	ti						: CM_TrackedItem;
	brCode					: String;
	hasBOL					: Boolean;	//18 Feb 2014	NDL	Par 33524
	carrier					: CM_Carrier;
	operator				: CM_Operator;
	dac						: CM_DataAccessController;
	operatorStr				: String;
	train					: CM_Train;
	cargoTypeObj : CM_CargoType;
	reserveDetail		: CM_ReserveDetail;
	isoType, cargoSubType	: String;					// TFS 45836
	ct : CM_CargoType;
	prodCode : String;
	configSetting : String;
	entDef : EntTableDef;
	entRow : EntTableRow;
begin
	if OldReleaseRequestScreen and self.getMyCargoType = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Cargo Type', ETRow_CargoType, null);
		app.raiseCMException(Input_required_field_cargoType, ETRow_CargoType, null); // cnwdb2	PAR 35364
		return false;
	endif;
	
// NEEDED for EasyGate
	// cnwrl1 09/08/2009 PAR 20320 - MES 1011 Web EDI Link - start of coding
	if self.type &lt;&gt; BR_TYPE_ROAD	and
	   self.type &lt;&gt; BR_TYPE_RAIL	and
	   self.type &lt;&gt; BR_TYPE_PACKING	and
	   self.type &lt;&gt; BR_TYPE_BOL 	and
	   self.type &lt;&gt; BR_TYPE_SHIP	and
	   self.type &lt;&gt; BR_TYPE_UNKNOWN then	// par 28696
		app.raiseCMException1( Invalid_Release_Request_Type, self.type.display, ETRow_Type, null );
		return false;
	endif;
	// cnwrl1 09/08/2009 PAR 20320 - MES 1011 Web EDI Link - end of coding
	if self.type = BR_TYPE_UNKNOWN and self.status &lt;&gt; BR_PENDING then 
		app.raiseCMException (ERR_RR_Pending_Unknown, null, null);
	endif;
	
	// They can now choose one or the other or both: CCMS-1133.
	//if self.myOperator = null and self.myOperatorGroup = null then
	hasBOL := ( not self.allReserveDetails.isEmpty and self.allReserveDetails.first.myBOLIn &lt;&gt; null );	//18 Feb 2014	NDL	Par 33524
	if self.myOperator = null and self.myOperatorGroup = null and not hasBOL then	//18 Feb 2014	NDL	Par 33524 
		tmpStr := app.getTerminologyAlternate(self.myCargoType, self.myTerminal, CM_TerminologyOperator, CM_TermExpressionSingular, 'Operator');
		app.raiseCMException1(Input_required_field_tmpStr, tmpStr , ETRow_Operator, null);

	endif;

	// NEEDED for EasyGate
	if self.code = null then
		app.raiseCMException(Input_required_field_realNumb, ETRow_Code, null); // cnwdb2	PAR 35364
	endif;	
	
	if self.code.pos(' ', 1) &gt; 0 then  //cnwma1 10/04/2015 PAR #35933
		app.raiseCMException1(VB_BAD_RELEASE_NO, self.code, null, self);
	endif;
	
// NEEDED for EasyGate (need to add source sub-terminal to screen)
	// cnwdad1 02/07/2009 - CCMS 1735
	if app.isSubTerminalsOn(self.myTerminal)
	and self.mySubTerminal = null
	and not self.myTerminal.getConfig(IsSubTerminalAreaDefined).Boolean	//28 Nov 2014	NDL	Par 35295
	then
		app.raiseCMException(Input_required_field_subTerm, ETRow_MySubTerminal, null); // cnwdb2	PAR 35364
	endif;
	
	self.validateOperatorRequirements();
	
	tmpPortDestCode := self.myTerminal.getConfig(PortDestCode).String;
	
	if self.myLoadPort &lt;&gt; null //par19891 cnwrs1 June 2009
	and self.myLoadPort.code &lt;&gt; tmpPortDestCode
	and self.myBookingRefStock &lt;&gt; null
	and not self.myBookingRefStock.allBookingRefItems.first.myBookingReference.noFullIsAllowedIn
	then
		app.raiseCMException1(Fulls_shoul_check_when_load_po, tmpPortDestCode, ETRow_Code, null);
	endif;
	
	//cnwjo3 par 22239.  There is no reason to validate that the load port for the release request
	//is the current load port.  There are 3 situations where the load port of a release request
	//could be the current load port.  Packing Release Requests, Road Release Requests where
	//the reason is 'Repack' and Tranships.

	if self.status = BR_NOTSET then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Status', ETRow_Status, null);
		app.raiseCMException(Input_required_field_status, ETRow_Status, null); // cnwdb2	PAR 35364
	endif;

	if self.type = BR_TYPE_PACKING then
		if self.deliveryReleaseNumber &lt;&gt; null then
			if self.myTerminal.getConfig(BrPackReqDelvRelNum).Boolean then
				tmpBR := self.myTerminal.allBulkReleasesByDelRelNo[self.deliveryReleaseNumber];
				if tmpBR &lt;&gt; null and tmpBR &lt;&gt; self.pxyGetRealObject() then
					app.raiseCMException2(ERR_INVALID_VALUE, 'Delivery Release Number', "'" &amp; self.deliveryReleaseNumber &amp; "' is already in use by release " &amp; tmpBR.code, null, null);
				
				endif;
			endif;
		endif;
	endif;
	
	// cnwdad1 30/05/2007 - PAR #14132.
	if self.myVoyage &lt;&gt; null and self.dateEstimatedRequired &lt;&gt; null and self.dateEstimatedRequired.isValid() and self.context &lt;&gt; RelReqContext_Calloff then		//	30.01.24	navhn30		TFS #61952
		if self.dateEstimatedRequired &gt; self.myVoyage.arrivedDT then
			app.raiseCMWarning1(Estimated_Date_Before_Arrive, "Required Date", null, null, self);
		endif;
	endif;
	
	//ccms 1676. Feb 20096
	self.pxyGetRealObjectAndEdition(realBulkRelease, expectedEdition);
	if realBulkRelease &lt;&gt; null then	// when update mode
		tmpPinNo := realBulkRelease.myPinNo;
	endif;
	self.validateForPIN(tmpPinNo, _passport);	// No PIN Generation for hazardous or over dimension cargo when Terminal Config / Gate is setup. ccms 1676, Feb 2009
	
	if _passport.hasErrors() then
		return false;
	endif;

	self.validateAvailabilityGrades();	//22 May 2012	NDL	Par 29381


	if self.validateReserveDetails() = false then
		return false;
	endif;

//		SFW1035 - most of the validation that was being done from the delivery request has been done above

		if self.consigneeCode &lt;&gt; null then
			tmpConsignee := app.myRoot.allConsigneeConsignors[self.consigneeCode];
			if not self.isReceipt then
				if not app.myRoot.getConfig(Consignor_ee_AsText).Boolean then
					//tmpConsignee := app.myRoot.allConsigneeConsignors[self.consigneeCode]; // 2.8.2017 cnwma1 TFS #5209
					if tmpConsignee = null then
						app.raiseCMException1(ERR_INVALID_CONSIGN, self.consigneeCode, ETRow_Consignee, null);
					endif;
				endif;
			endif;
			// 3.8.2017 cnwma1 TFS #5209
			if tmpConsignee &lt;&gt; null  then
				if tmpConsignee.isRestricted then 
					app.raiseCMException2(ERR_RESTRICTED_CONSIGNEE, app.getErrorString(Consignee), tmpConsignee.description,null ,null);
				endif;
			endif;
		endif;
		if self.myOperator &lt;&gt; null then
			if not self.myTerminal.getConfig(UseBookingSummView).Boolean then
				if self.myOperator.requiresCVC and self.consignorVoyageCode = null then
					app.raiseCMWarning2(OPERATOR_REQUIRES_CONSIGN_VOY, self.myOperator.code, 'to be released', ETRow_ConsignorVoyageCode, null, self);
				endif;	
				if self.myOperator.requiresConsigneeConsignor and self.consigneeCode = null then
					app.raiseCMWarning2(OPERATOR_REQUIRES_CONSIGNEE, self.myOperator.code, 'to be released', ETRow_Consignee, null, self);
				endif;
			endif;
		endif;

		numReleased := self.getTotalReleased();
		numRequested := self.getTotalRequested();
		numCurrentlyActioned := self.getNumItemsBeingActioned();
		
		if numRequested &lt;= null then
			return true;
		endif;
			
		numShouldReceive := numRequested - (numReleased + numCurrentlyActioned);
		if totalRequestedThisJob &gt; numShouldReceive then
			//Par 15487 - when editing a release request, we have to protect for having outstanding = -1 in the release request. I.e. there should be exception instead of warning
			app.raiseCMException4(Relea_items_alrea_relea_actd, self.code, numReleased.String, numCurrentlyActioned.String, numRequested.String, ETRow_Quantity, self);//+ cnwmd1, Par 20524
		endif;
	//endif;
	
	// If a Booking Reference has been entered, and the Release's Voyage is not the same as the Booking Reference's
	// Voyage, then warn the User.  Note that if either Voyage is null, or if either Voyage is "The Null Voyage",
	// then don't bother warning the User.
	
	if self.myBookingRefStock &lt;&gt; null then
		bookRefObj		:=	self.myBookingRefStock;
	
		// Changes for US Booking Ref / Release Request to allow link from non-stock booking ref to
		// a release request for release of containers out the gate
		
		if bookRefObj.isStockBookingRef then
			voyageObj		:=	self.myVoyage;
			nullVoyageObj	:=	app.getMyTerminalDO_NOT_USE().getNullVoyage();
			refVoyageObj	:=	bookRefObj.myVoyage;
			
			if voyageObj &lt;&gt; null
			and refVoyageObj &lt;&gt; null
			and voyageObj &lt;&gt; nullVoyageObj
			and refVoyageObj &lt;&gt; nullVoyageObj
			and voyageObj &lt;&gt; refVoyageObj
			then
				app.raiseCMWarning2(ERR_INVALID_VALUE,
									"Booking Reference Voyage",
									"This Release's Voyage is not the same as the Booking Reference Voyage.",
									ETRow_MyBookingRef,
									null,
									self);
			endif;
		endif;
	endif;
	
	if realBulkRelease &lt;&gt; null then
		brCode := realBulkRelease.code;
	else
		brCode := self.code;
	endif;
	//+cnwml2 MSL CCMS 1012 make sure that tis are multiply assigned to waybill releases
	foreach ti in self.allTrackedItemsAssigned do
		foreach tmpBR in ti.allBulkReleasesAssigned do
			//cnwjo3 par 23578.  Does an existing Bulk Release allow for cargo on multiple releases?  Does the current BR allow for multiples?  Are we editing BR associated with the TI?
			//if (tmpBR.allowCargoOnMultipleReleases = false or self.allowCargoOnMultipleReleases = false) and tmpBR.code &lt;&gt; self.code then
			if (tmpBR.allowCargoOnMultipleReleases = false or self.allowCargoOnMultipleReleases = false) and tmpBR.code &lt;&gt; brCode then	// 02/02/2012 cnwar2 #28113 - need to check original code in case it has been changed
				app.raiseCMException2(ERR_CARGO_MULTIPLE_REL, self.code, tmpBR.code, null, self);
			endif;	
		endforeach;
	endforeach;
	
	if self.type &lt;&gt; BR_TYPE_ROAD then
		if self.expiryTimeStamp &lt;&gt; null and 
		   self.expiryTimeStamp.date.isValid then		// 05 Feb 2024	jlirs1	TFS 61640 EUP Release Request by Type by Weight
			//"Expiry Date/Time is only valid for 'Road' type Releases."
			app.raiseCMException(Expir_datet_only_valid_road_ty, null, self);
		endif;
	endif;

	carrier := self.getCarrier();		// 20/9/17 MAP TFS2749
	operator := self.myOperator;
	if operator &lt;&gt; null then
		operatorStr := operator.description;
	endif;
	if self.type &lt;&gt; BR_TYPE_SHIP and self.type &lt;&gt; BR_TYPE_PACKING and carrier &lt;&gt; null and not carrier.canCarrierAccessForOperator(operator, dac, true) then
		app.raiseCMException2(Carri_does_not_have_acces_oper, carrier.description, operatorStr, null, null);
	endif;

	if self.type = BR_TYPE_RAIL and self.myAssignedTrain &lt;&gt; null then		// 18/9/17 MAP TFS2749
		train := self.myAssignedTrain;
		if train.myCarrier &lt;&gt; null then
			carrier := train.myCarrier;
			if not carrier.canCarrierAccessForOperator(operator, dac, true) then
				app.raiseCMException2(Carri_does_not_have_acces_oper, carrier.description, operatorStr, null, null);
			endif;
		endif;
	endif;
	// 16 Aug 2018	jlgrs1	TFS 39619 PEN - Approved Carriers For Operator 
	foreach reserveDetail in self.allReserveDetails do
		if reserveDetail &lt;&gt; null then
			cargoTypeObj := reserveDetail.getMyCargoType;
			isoType := reserveDetail.getISOTypeCode;																	// TFS 45836
			cargoSubType := reserveDetail.getProductCode;																// TFS 45836
			if self.type &lt;&gt; BR_TYPE_SHIP and 
			   self.type &lt;&gt; BR_TYPE_PACKING and 
			   operator &lt;&gt; null and 
			   carrier &lt;&gt; null and 
			   cargoTypeObj &lt;&gt; null and
			   //not operator.canOpAccessCarrierForCargoType(carrier, cargoTypeObj.id) then								// TFS 45836
			   not operator.canOpAccessCarrierForCargoType(carrier, cargoTypeObj.id, cargoSubType, isoType, null) then	// TFS 45836
				app.raiseCMException3(Opera_denie_carri_acces_cargo_, operator.description, carrier.description, cargoTypeObj.description, null, self);
			endif;
		endif;
	endforeach;
	
	//19 May 2020	NDL	TFS 49167
	if self.type = BR_TYPE_ROAD
	and ( not  self.releaseByType )
	and self.myTerminal.getConfig( OneCargoTypeRelReqById ).Boolean
	then
		configSetting := "Release Request By Id - One Cargo Type";
		entDef := app.myRoot.myEntTableDataRoot.allEntTableDefs[ETDef_GateConfig];
		if entDef &lt;&gt; null then
			entRow := entDef.allEntTableRows.getEntRowNamed(ETRow_OneCargoTypeRelReqById);
			if entRow &lt;&gt; null then
				configSetting := entRow.getRawHeadingValue;
			endif;
		endif;
		if self.allowCargoOnMultipleReleases then
			app.raiseCMException1( No_allow_cargo_multi_release, configSetting, null, null);
		endif;
		foreach reserveDetail in self.allReserveDetails do
			if ct = null then
				ct := reserveDetail.getCargoType();
				prodCode := reserveDetail.getProductCode();
			elseif ct &lt;&gt; reserveDetail.getCargoType() then
				app.raiseCMException1( No_mix_cargo_types, configSetting, null, null);
				break;
			elseif prodCode &lt;&gt; reserveDetail.getProductCode() then
				app.raiseCMException1( No_mix_cargo_types, configSetting, null, null);
				break;
			endif;
		endforeach;
	endif;
	
	//jlier1 TFS 53678 15/6/22
	self.validateDeliveryParty();
	
epilog
	return _passport.noErrors();
end;</source>
        <access>protected</access>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validateAvailabilityGrades" id="86107d1a-7c49-4ae7-9621-3dd9793ad76e">
        <source>validateAvailabilityGrades();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
22 May 2012	cnwndl1	Initial creation	Par 29381

*/

vars

	grade : Integer;
	availGrade : CM_MTGrade;
	code : CM_MTGradeCode;
	canDisplay : Boolean;
	intArray : IntegerArray;

begin

	if self.allAvailabilityGrades.size &gt; 1
	and (not self.myTerminal.getConfig(GateAllowMultipleMTGrades).Boolean)
	then
		app.raiseCMException2(ERR_INVALID_VALUE, "Availability Grades", "You may only enter 1 MT Grade",ETRow_AllMTGrades, null);
	endif; 
	
	if self.myOperator &lt;&gt; null then
		intArray := self.getAllAvailabilityGrades();
		if intArray &lt;&gt; null then
			foreach grade in intArray do
				availGrade := app.myRoot.allAvailabilityGrades[grade];
				if availGrade = null then
					// invalid availability grade
					app.raiseCMException1(Invalid_AvailabilityGrade, grade.String, ETRow_AvailabilityGrade, null);
					continue;
				endif;
				availGrade.getTranslationForOperator(null, self.myOperator, null, code, canDisplay);
				if not canDisplay then
					app.raiseCMWarning2(AvailabilityTranslationErr, " '" &amp; grade.String &amp; "' ", ' for Operator ' &amp; self.myOperator.code, null, null, self);
				endif;
			endforeach;
		endif;
	endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="validateCanReleaseTI" id="6169567b-910b-43c6-a83e-a1f74186e8a2">
        <source>validateCanReleaseTI(_ti : CM_TrackedItem);
/*
----------   ----------  --------------------------------------------------
Created:	11 October 2007 By cnwth2

Purpose:	PAR 14873 - Incorrect containers been delivered out

Changed On	Changed By	Reason
----------	----------	--------------------------------------------------
18/09/2009	consw1		SFW1035 - get info from ReserveDetail rather than Yard Request.
23/06/2023	navkc1	CR 58406 Task 58408: Jade - Release Request All Tracked Items
*/
vars
	assigned,
	outstanding			: Integer;
	reserveDetail		: CM_ReserveDetail;
begin

	// is the cargo items being attached must be one of the ones assigned
	foreach reserveDetail in self.allReserveDetails do
		//if reserveDetail.allTrackedItems.includes(_ti) then
		if reserveDetail.includeTrackedItem(_ti, false) then //23/06/2023	navkc1	CR 58406 Task 58408
			return;//no problem
		endif;
	endforeach;
			
	if (not self.releaseByType) then//easy
		if (not self.allTrackedItemsAssigned.includes(_ti)) then

			//cnwjo3 par 20460.  Go through all the requests for the bulk release
			//and check if the ti is on the list
//			tiExistsInRequest := false;
//			foreach request in self.requests do
//				if request.isKindOf(CM_TIRequest) then
//					tiRequest := request.CM_TIRequest;
//					if tiRequest.trackedItem &lt;&gt; null then
//						if tiRequest.trackedItem = _ti then
//							tiExistsInRequest := true;
//						endif;
//					endif;
//				endif;
//			endforeach;
		
			//cnwjo3 par 20460, if TI is not in the request then raise warning
//			if tiExistsInRequest = false then
				app.raiseCMWarning2(Cargo_item_assig_relea_again_r, _ti.id, self.code, null,self,self);//06/12/2010 cnwdz2 25485
//			endif;
		endif;
	else//not so easy
		assigned := self.getTotalAssigned();
		if assigned &lt;= 0 then
			return;
		endif;
		
		outstanding := self.getTotalOutstanding();
		if outstanding &lt;= assigned then
			//the cargo items being attached must be one of the ones assigned
//			foreach reserveDetail in self.allReserveDetails do
//				if reserveDetail.allTrackedItems.includes(_ti) then
//					return;//no problem
//				endif;
//			endforeach;
				//Par 15487 - clients need a red warning to avoid of releasing wrong containers, that haven't been added in attachment list of a release
			/*app.raiseCMException1(Full_Replacement_Message, 'Release request ' &amp; self.code &amp; ' has an outstanding balance of ' &amp; outstanding.String &amp; 
									', and there are still ' &amp; assigned.String &amp; " item(s) assigned that have not yet been released, of which " &amp; _ti.id &amp; ' is not one.'&amp;
									'You must release one of the items assigned to the release.', null, self ); */ //- cnwmd1, Par 20524
			app.raiseCMException4(Relea_reque_outst_balan_rel, self.code, outstanding.String, assigned.String, _ti.id, null, self ); //+ cnwmd1, Par 20524
		else
			//the cargo item only has to match the release criteria, but it can be any item
			//warnings raised elsewhere for this
		endif;
	endif;

end;


</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="validateCargoOperatorPins" id="ae7d00e5-0a5b-4839-a53f-92428418860f">
        <source>validateCargoOperatorPins( _allTIPins : CM_StringDict);

/*

Purpose:	 //cnwrd1 CCMS POL 2032 par 25594 10.12.2010		

Parameters:			

Return Value:		


Date		Who		Reason
10 December 2010	cnwrd1	Initial creation

*/

vars
	strObj 		: CM_String;
	theTI 		: CM_TrackedItem;
	thePin		: String;
begin
	
	if _allTIPins = null then
		return;
	endif;
	
	foreach strObj in _allTIPins do
		theTI := strObj.myObject.CM_TrackedItem;
		thePin := strObj.string;
		 
		 theTI.validateOpImpReleasePIN( thePin);
	endforeach;
	 


epilog

end;</source>
        <Parameter name="_allTIPins" type="CM_StringDict"/>
    </JadeMethod>
    <JadeMethod name="validateDeliveryParty" id="9aa47ded-8b69-43a9-af71-58e3b5f165bf">
        <source>validateDeliveryParty();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 June 2022	jlier1	Initial creation 53678

*/

vars
	reserve : CM_ReserveDetail;
	countDelivery,
	countNoDelivery	: Integer;
	missingRS : String;
begin	
	foreach reserve in self.allReserveDetails discreteLock do
		if reserve.myDeliveryParty &lt;&gt; null or reserve.myDeliveryAddress &lt;&gt; null or reserve.deliveryTo &lt;&gt; null   then
			countDelivery:=countDelivery +1;
		else
			countNoDelivery:=countNoDelivery  + 1;
			if countNoDelivery = 0 then
				missingRS:=reserve.getDescription;
			else
				missingRS:=missingRS &amp;Comma &amp; reserve.getDescription;
			endif;
		endif;
	endforeach;
	
	if countDelivery &gt; 0 and countDelivery &lt; self.allReserveDetails.size  then
		//raise Warning 
		app.raiseCMWarning2(Relea_reque_missi_some_deliv_d,self.code,missingRS,null,null,null);
	endif;
		
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="validateExpiryDateNow" id="7a36b1c9-7c11-4393-83fa-fdd44f36d270">
        <source>validateExpiryDateNow( _returnMsg : String output ):Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 February 2017	cnwndl1	Initial creation	TFS 3368

*/

vars

begin

	_returnMsg := null;
	
	if self.expiryTimeStamp.date.isValid and self.expiryTimeStamp &lt; app.actualTimeAppServer then
		_returnMsg := "Code " &amp; Release_expired.String &amp; ". " &amp; app.getErrorString1(Release_expired, self.code );
	else
		return true;
	endif;
	
	if self.myTerminal.getConfig(ReleaseReqExpiredIsError).Boolean then
		return false;
	else
		return true;
	endif;

epilog

end;</source>
        <Parameter name="_returnMsg" type="String" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validateForCreate" id="2cf4909b-816d-4641-b165-417188e0ad42">
        <source>validateForCreate(_passport : CM_Passport input) :Boolean;
// ---------------------------------------------------------------------------
// Created:     22 February 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 13/02/2012	cnwcs5		par 28756 - removed updating from method signature
// 15/12/2014  cnwdb2	PAR 35364
// ---------------------------------------------------------------------------
vars
begin
	self.raiseExceptionIfNotTransient(method);

	
	if self.myTerminal = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Terminal', ETRow_Terminal, null);
		app.raiseCMException(Input_required_field_terminal, ETRow_Terminal, null);
		return false;
	endif;

	self.myTerminal.validateBulkReleaseNumber(self, 'Bulk Release');
	self.validate(_passport);
	
epilog
	return _passport.noErrors;
end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validateForDelete" id="a3c1a11e-132c-4c18-a2f8-3436a5b3cd0f">
        <updating/>
        <source>validateForDelete(_passport : CM_Passport input) updating;
//-----------------------------------------
// Created: August 2004 By: cnwgd1
//-----------------------------------------
//14/03/2018	JLGNS1	Bug 37610: Error 4 in Bulk Gate Out
//15 January 2025	navcs2	MTN-19832 SNO - Cannot delete single items with COPARN in a Relese Request Actioned

vars
	coparnEDIRules 	: 	CM_EDIPartyCoparnRules;
	canDelActive	:	Boolean;
begin

epilog

//	if app.isJMTUnitTest then														//Bug 37610
//		return;																		//Bug 37610
//	endif;																			//Bug 37610

	coparnEDIRules := self.getCoparnRules();						//15 January 2025	navcs2	MTN-19832
	if coparnEDIRules &lt;&gt; null then									//15 January 2025	navcs2	MTN-19832
		canDelActive := coparnEDIRules.allowDelActioned;			//15 January 2025	navcs2	MTN-19832
	endif;															//15 January 2025	navcs2	MTN-19832
	
	if self.allTrackedItemsReleased.size &gt; 0 and self.status = BR_ACTIVE and not canDelActive then		//Bug 37610   //15 January 2025	navcs2	MTN-19832
		app.raiseCMException1(ReleaseRequestAlreadyHasItems, self.code, null, self);
	endif;
	
	if self.allRequestsBeingActioned.size &gt; 0 and self.status = BR_ACTIVE then		//Bug 37610
		app.raiseCMException1(ReleaseRequest_InUse, self.code, null, self);			//Bug 37610
	endif;																			//Bug 37610
end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="validateForPIN" id="6c82183b-c8bf-4c10-9ee7-f7052eb78494">
        <source>validateForPIN( _pin : CM_PinNo input; _passport : CM_Passport input);
/* ---------------------------------------------------------------------------
Created:	04 February 2009	by cnwvu1

Purpose:	
12/02/2012	cnwcs5	par 28756 - include PIN validation code from noPINforHazardousODProcess
								and changed method to not updating
------------------------------------------------------------------------------*/
vars
	tiSetNoPin		: CM_TISet;
	ti				: CM_TrackedItem;
	tiStr			: String;
begin
	// No PIN Generation for release with hazardous or over dimension cargo attached. ccms 1676, Feb 2009
	// No PIN Genration setup - Terminal Config / Gate.
	
	create tiSetNoPin transient;
	
	if self.noPINforHazardousOD(tiSetNoPin) then	
		// for hazardous or over dimension cargo, we should not to create ( or should delete existing) PIN
		
		foreach ti in tiSetNoPin do
			tiStr := tiStr &amp; " " &amp; ti.id &amp; ", ";
		endforeach;
		
		if tiStr.length &gt; 2 then
			tiStr := tiStr[1: tiStr.length()-2];	// removing the last commma
		endif;
		
		app.raiseCMWarning2(Warn_NoPINforHazarODRelease, self.code, tiStr , null, null, self);
	endif;
epilog
	delete tiSetNoPin;
end;</source>
        <Parameter name="_pin" type="CM_PinNo" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="validateForUpdate" id="42473512-1de3-43fb-9beb-c3c2e517499d">
        <source>validateForUpdate(_passport : CM_Passport input) :Boolean;
// ---------------------------------------------------------------------------
// Created:     22 February 2001 by cnwrs2
//
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 29 Jul 2013	cnwcs5		CCMS POL 2221 / par 32094 - signature change
// 08/12/2014   cnwdb2		PAR 35364
// 21 Feb 2025	navah1		Bug 12560: MTN - Unable to change the transport mode from Rail to Ship/Road for the Part Complete status
// ---------------------------------------------------------------------------
vars
	terminal		: CM_Terminal;	
	existingRelease,
	realRelease		: CM_BulkRelease;
	count			: Integer;
	str 			: String;
	iter 			: Iterator;
begin

	self.raiseExceptionIfNotTransient(method);

	terminal := self.myTerminal;
	
	if terminal = null then
		app.raiseCMException(Input_required_field_terminal, ETRow_Terminal, null); // cnwdb2	PAR 35364
		return false;
	endif;				
	
	if self.isTransient then
		realRelease := self.pxyGetRealObject();
		
		if realRelease &lt;&gt; null then
		
			if not realRelease.myTerminal.isUseYardJobsForCargoWo then			  // 21.02.2025 navah1 #12560
				if realRelease.code &lt;&gt; self.code or  realRelease.isInRailOps then // AKB2004DEC
					// Change to the code
					count := realRelease.getNumItemsBeingActioned();
					
					if count &gt; 0 or  realRelease.isInRailOps then
						// can't update code while there are requests being actioned - PAR2735
						str := count.String; // AKB2004DEC
						
						if count = 0 and  realRelease.isInRailOps then // AKB2004DEC
							str := "Some"; // AKB2004DEC
						endif;
						
						app.raiseCMException2(ReleaseBeingActioned, realRelease.code, str, null, null);
						
						return false;
					endif;
				endif;
			endif;
			
			if terminal.getConfig(AllowDuplicateReleaseNos).Boolean then 
				existingRelease := terminal.allBulkReleasesByCodeDate[self.code,self.dateRequested];
				
				if existingRelease &lt;&gt; null and existingRelease &lt;&gt; realRelease then
				// if there is a bulk Release in the dict and it is not proxy's real obj then must be duplicate. 
					app.raiseCMException2(Already_exists_bulk_release, self.code, self.dateRequested.String,'code', null); //cnwdb2 PAR 35364
					
				endif;	
			else						
				
				iter := terminal.allBulkReleasesByCodeDate.createIterator;
				
				terminal.allBulkReleasesByCodeDate.startKeyLeq(self.code, null, iter);			
				
				while iter.back(existingRelease) do 
					if existingRelease.code &lt;&gt; self.code then
						// is different code so no need to check any more. 
						break;
					else
						if existingRelease &lt;&gt; realRelease then 
						// if not real obect then check if code is same. if so must be duplicate.  
							if existingRelease.code = self.code then 
									app.raiseCMException1(Already_exists_bulk_releaseb, self.code, 'code', null); //cnwdb2	08/12/2014
								break;
							endif;
						endif;
					endif;
				endwhile;		
			endif;
		endif;
	endif;
	
	self.validate(_passport);
epilog
	delete iter;
	return _passport.noErrors;
end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validateOperatorRequirements" id="4bd1da5a-9bbc-4db4-b626-0bcf5488284b">
        <source>validateOperatorRequirements() protected;
// ---------------------------------------------------------------------------
// Created:		November 2004 By Andrew Bishop cnwab1
//
// Purpose:		This tests the request against the operators requirements esp wrt CAMS configuration
//
// ---------------------------------------------------------------------------
vars
	
begin
	
	if self.myOperator = null then 
		return; 			
	endif;
	//th2 22/06/2007 - changed to be warnings on request by Tony Quayle
	//th2 for PAR14847 - loose this warning as requested by Jayne in Port Otago
	/*
	if self.myOperator.requiresDeliveryRelease and self.deliveryReleaseNumber = null then
		app.raiseCMWarning2(OPERATOR_REQUIRES_DELIVERY_REL, self.myOperator.code, 'to be released', ETRow_DeliveryRelease, self, self);
	endif;
	
	
	if self.myOperator.requiresCVC and consignorVoyageCode = null then
	    app.raiseCMWarning2(OPERATOR_REQUIRES_CONSIGN_VOY, self.myOperator.code, 'to be released', ETRow_ConsignorVoyageCode, self, self);
	endif;	
	
	// check the consignee
	if self.myOperator.requiresConsigneeConsignor and self.consigneeCode = null then
		app.raiseCMWarning2(OPERATOR_REQUIRES_CONSIGNEE, self.myOperator.code, 'to be released', ETRow_Consignee, self, self);
	endif;
	*/
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="validatePackComplete" id="5b2f5b01-619f-4044-88d4-d29be15aac8d">
        <source>validatePackComplete():Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 Jul 2024 navhl20	ChangeRequest 61368: EUP* | Adding Pack Reserve Child to Packing Work order Release Request
09 Aug 2024 navhl20	Bug 65573: Pack work order issues - Unable to perform Pack Complete
*/

vars
	requested,
	packed		: Integer;
	resDtl		: CM_ReserveDetail;
begin
	if not app.myPassport.isVASEnabled then
		return false;
	endif;
	
	if self &lt;&gt; null and self.allWOPacks.isNotEmpty then   //12.11.2024 navma1 
		requested 	:= self.getTotalPackRequested();
		packed		:= self.getTotalPackedQuant();
		resDtl		:= self.allReserveDetails.first;
		
		//If 1 parent line
		if self.allReserveDetails.size = 1 then
			//If one child line and Parent line total requested is 1
			if self.allReservePackingChildren.size = 1 and resDtl.totalRequested = 1 then
				if requested &gt; packed then									//09.08.2024 navhl20 #65573
					app.raiseCMException(There_still_more_cargo_packe_c, null, null);
					return false;
				endif;
			endif;
		
			//If more than one child line and Parent line total requested is 1
			if self.allReservePackingChildren.size &gt; 1 and resDtl.totalRequested = 1 then
				if requested &gt; packed then									//09.08.2024 navhl20 #65573
					app.raiseCMException(There_still_more_cargo_packe_c, null, null);
					return false;
				endif;
			endif;
			
			//If one child line and Parent line total requested is more than 1
			//If more than one child line and Parent line total requested is more than 1
			if (self.allReservePackingChildren.size = 1 or self.allReservePackingChildren.size &gt; 1) and resDtl.totalRequested &gt; 1 then
				if requested &gt; packed then									//09.08.2024 navhl20 #65573
					if self.getRemainingPackCont() = 1 then
						app.raiseCMException(There_still_more_cargo_packe_c, null, null);
						return false;
					endif;
					app.raiseCMWarning(There_still_more_cargo_packe_w, null, null,self);
					return false;
				endif;
			endif;
		else
			//If one child line and more than one parent line
			//If more than one child line and more than one Parent line
			if self.allReservePackingChildren.size = 1 or self.allReservePackingChildren.size &gt; 1 then
				if requested &gt; packed then									//09.08.2024 navhl20 #65573
					if self.getRemainingPackCont() = 1 then
						app.raiseCMException(There_still_more_cargo_packe_c, null, null);
						return false;
					endif;
					app.raiseCMWarning(There_still_more_cargo_packe_w, null, null,self);
					return false;
				endif;
			endif;
		endif;
	endif;
	
	return true;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validateReserveDetails" id="796d94fb-dfea-49fd-8c1a-a8c1ea82467b">
        <source>validateReserveDetails() : Boolean;
// --------------------------------------------------------------------------------
// Created:		3 April 2009 by cnwjo3
//
// Purpose:		To verify that all Reserve Details (CM_ReserveSelection, or CM_ReserveTI) are correct
//				Best to do it here than on the individual objects to avoid multiple warnings/errors
//				This method is to deal with par 19033
//
// Changed On	By			Reason
// ----------	--------	--------------------------------------------------------
// 27/03/2014	cnwdap1		PAR #33606 CCMS SFW 1366 Bulk - totalRequested can be 0 for Bulk items
//							(which release a certain weight / volume instead of a quantity)
// 14/12/2016	cnwdap1		TFS 3039 SNO Emty Container Pool Management
//19/07/2022	navtnr20	ChangeRequest 53974: EUP - OUT - Additional Fields on Release Line Level
// 11 Aug 2022	navsrk20	Bug 54509: EUP - Unit test issue (CM_BulkRelease::validateReserveDetails Dynadict)
// 22 Aug 2022  navrk21     Bug 54527: AAT - Unable to Process a truck (Error 1090 Attended access via null object reference)
// 11 Nov 2022	navds20		Bug 54801: MTN - Web Portal - cannot add a reserve detail tracked by volume to release request
// 22/06/2023	navkc1		CR 57496 Task 58405: UI - Release Request Cargo Group
// 23/06/2023	navkc1		CR 58406 Task 58408: Jade - Release Request All Tracked Items
//23 August 2023	navmv20	CR 59440 Task 59441: Jade - Ownership Change Release Request Validation
// 22/08/2023	navkc1		CR 59610 Task 59611: Jade - Stop Prevention
// 24 November 2023 navmv20 Bug 61267: FR | EUP - Release Request by Type - Cargo Group &lt;&lt;53383&gt;&gt;
// 6/12/2023	navcs2	ChangeRequest 57537: EUP | Release Request By Type - with Weight
//24/04/2025	navrv30	MTN 34319 EUP | Creating a Release Request from Cargo Review - Validation
vars
	rd : CM_ReserveDetail;
	rs, firstMatch : CM_ReserveSelection;
	dynaDict : DynaDictionary;
	isReserveTI : Boolean;
	ti : CM_TrackedItem;
	hasBOL : Boolean;	//18 Feb 2014	NDL	Par 33524
	poolParty : CM_MTPoolingParty;							// TFS 3039
	allTis	: CM_TISet;
	hasCustDocs : Boolean;
begin

	if self.allReserveDetails.size &gt; 0 then
	
		// ### JIRA 34756 27MAY2025 NAVAB1
		hasCustDocs :=  app.myPassport.myUser.canDo(self.myTerminal, Sub_CustomDocuments);

		create allTis transient; //23/06/2023	navkc1	CR 58406 Task 58408
		//check that all reserve details are the same type on the bulk release
		//this might actually be impossible to do on the form.
		//possibly remove code
		rd := self.allReserveDetails.first();
		isReserveTI := rd.isKindOf(CM_ReserveTI);
		//Start 11.08.2022	navsrk20	TFS 53974
		create dynaDict transient;
		dynaDict.setMembership(CM_ReserveSelection);
		dynaDict.addExternalKey(Integer,9,false,false);
		dynaDict.endKeys(false);
		//End 11.08.2022	navsrk20	TFS 53974
		foreach rd in self.allReserveDetails do
			//cnwmc5 - 25 Feb 2015 - PAR 35750 - added for web services.. this is implicitly covered on a form level in JMT
			if (rd.isKindOf(CM_ReserveTI) and self.releaseByType) 
			or (rd.isKindOf(CM_ReserveSelection) and not self.releaseByType) then
				app.raiseCMException1(Attempting_Release_ByTypeAndId, self.code, null, null);
				return false;
			endif;
			
			//cnwmc5 - 25 Feb 2015 - PAR 35750 - this should now be covered by the new error handling above..
			/*
			if rd.isKindOf(CM_ReserveTI) &lt;&gt; isReserveTI then
				app.raiseUnexpectedProgramError(class.name, method.name,
						"Attempting to do a Release by TI and Release by ISO on same Release");
				//app.msgBox("Attempting to do a Release by TI and Release by ISO on same Release?","Error",0);  //this needs to be a translatable string
				return false;
			endif;
			*/
			//10 Oct 2016	NDL	TFS 2001 / 2792
			if rd.myReserveDetailActions &lt;&gt; null then
				rd.myReserveDetailActions.validateForUpdate();
			endif;
			
			//jlier1 TFS 53678 15/6/22
			/* // 24/11/2023 navmv20 Bug 61267
			if rd.myDeliveryParty &lt;&gt; null and rd.deliveryTo = null then
				app.raiseCMException1(Deliv_datet_requi_when_deliv_p,rd.getDescription(), null,null);
			endif;*/
			
			if not isReserveTI then
				rs := rd.CM_ReserveSelection;
				hasBOL := rd.myBOLIn &lt;&gt; null;	//18 Feb 2014	NDL	Par 33524
				//Start // 14-07-2022 navtnr20 53974
				if rs.lineNumber &lt;&gt; null then	
					if rs.lineNumber &lt;0 or rs.lineNumber &gt; 999999999 then
						app.raiseCMException1(Line_numbe_shoul_grate_less_th, null, null, null); 
						return false;	
					endif;
					dynaDict.clear;		//11.08.2022	navsrk20	TFS 54509
					foreach firstMatch in self.allReserveDetails as CM_ReserveSelection do
						if dynaDict[firstMatch.lineNumber] = null then
							dynaDict.putAtKey(firstMatch.lineNumber, firstMatch);
						else
							//app.raiseCMException1(Line_number_unique, null, null, null); //navtnr20 53974 08-08-2022
							app.raiseCMException1(Line_number_already_exists, firstMatch.lineNumber.String, null, null); //navtnr20 53974 08-08-2022
							return false;
						endif;
					endforeach;
					
				endif;
				// End 14-07-2022 navtnr20  53974
				//if rs.myCargoType = null then					//18 Feb 2014	NDL	Par 33524
				if rs.myCargoType = null and not hasBOL then	//18 Feb 2014	NDL	Par 33524
				//	app.raiseCMException1(REQUIRED_FIELD, app.getString( CargoType ), ETRow_TotalRequested, null);
					app.raiseCMException1(Input_required_field_Required, app.getString( CargoType ), ETRow_TotalRequested, null); // cnwdb2	PAR 35364
					return false;
				endif;

				//if you are going to release by ISO you need to specify more than 1 TI
				if rs.totalRequested &lt; 1 and (rs.myCargoType = null or (not rs.myCargoType.isBulkMulti and not rs.myCargoType.isBreakBulkMulti)) and not rs.byTypeByWeight then
				//	app.raiseCMException1(REQUIRED_FIELD, app.getString( Total_Requested ), ETRow_TotalRequested, null);
					app.raiseCMException1(Input_required_field_Required, app.getString( Total_Requested ), ETRow_TotalRequested, null); // cnwdb2	PAR 35364
					return false;
				endif;
				
				// if you are releasing bulk that's tracked by weight/volume, make sure the correct value is entered
				if rs.myCargoType &lt;&gt; null and rs.myCargoType.isBulkMulti then	
						if rs.myCargoType.isTrackByWeight and rs.weightRequested = null  then
							app.raiseCMException1(Input_required_field_Required, app.getString(Weight), ETRow_Weight, null); // cnwdb2	PAR 35364
							return false;
						//elseif  rs.myCargoType.isTrackByVolume and rs.weightRequested = null then	//11/11/2022 navds20 TFS 54801
						elseif  rs.myCargoType.isTrackByVolume and rs.volumeSelection = null then	//11/11/2022 navds20 TFS 54801
							app.raiseCMException1(Input_required_field_Required, app.getString(Volume), ETRow_Volume, null); // cnwdb2	PAR 35364
							return false;
						endif;	
				endif;
				
				if rs.myCargoType &lt;&gt; null and rs.myCargoType.isBreakBulkMulti then
					if rs.byTypeByWeight and rs.weightRequested = 0 then
						app.raiseCMException1(Input_required_field_Required, "Weight Requested", ETRow_WeightRequested, null); // cnwdb2	PAR 35364
						return false;
					elseif not rs.byTypeByWeight and rs.totalRequested &lt; 1 then		// 6/12/2023 navcs2 ChangeRequest 57537														
						app.raiseCMException1(Input_required_field_Required, app.getString( Total_Requested ), ETRow_TotalRequested, null); // cnwdb2	PAR 35364
						return false;
					endif;
				endif;
				
				if rs.byTypeByWeight and not rs.enoughCargoOnsite(rs.getCargoType.id, rs.myReserveHeader.myOperator.code, false, true)  then					// 6/12/2023 navcs2 ChangeRequest 57537
					app.raiseCMException1(Not_enoug_cargo_onsit_this_bul, self.allReserveDetails.indexOf(rs).asStringJMT, ETRow_WeightRequested, null);			// 6/12/2023 navcs2 ChangeRequest 57537
					return false;																																// 6/12/2023 navcs2 ChangeRequest 57537
				endif;																																			// 6/12/2023 navcs2 ChangeRequest 57537

				// 15/02/2010	cnwjre1	CCMS 1101 validate destination terminal area if entered
				if rs.getTerminalAreaId() &lt;&gt; null then
					if self.myTerminal.lookupTerminalArea(rs.getTerminalAreaId()) = null then
						app.raiseCMException2(ERR_INVALID_TA_ID, rs.getTerminalAreaId(), null, null, self);
					endif;
				endif;

				rs.validateCargoGroup(); //22/06/2023	navkc1	CR 57496 Task 58405
				rs.validateCommodity();  //24/04/2025	navrv30	MTN 34319

				//jlier1 TFS  53678 27/6/22
				if self.context = RelReqContext_CargoGroupReview or self.context = RelReqContext_Calloff then //JIRA 33484
					
					//24/04/2025	navrv30	MTN 34319
					//20 Aug 2025 navrv30 MTN 35150
					rs.validateBOLAssigned();
					if not app.myPassport.hasErrors() then 
						rs.validateCargoGroupAssigned();
					endif;
					if not app.myPassport.hasErrors() then 
						rs.validateVoyageAssigned();
					endif;
					if not app.myPassport.hasErrors() then 
						rs.validateCommodityAssigned();
					endif;
					if not app.myPassport.hasErrors() then 
						rs.validateAgainstOwnershipChange(); //11/07/2024	navkc1 Bug 65177 - Moved from below;
					endif;
				endif;
				
				//rs.validateAgainstOwnershipChange(); //23/08/2023	navmv20	CR 59440 Task 59441
				
				//if rs.myCargoType.id &lt;&gt; TI_CargoType_Container then
				if rs.myCargoType = null or rs.myCargoType.id &lt;&gt; TI_CargoType_Container then		//18 Feb 2014	NDL	Par 33524
					continue;
				endif;

				if rs.myISOType = null and rs.myISOGroup = null then
					app.raiseCMException( MustEnter_ISO_Type_AndOr_Group, ETRow_IsoType, null );
					return false;
				endif;
				
				//all the attached TIs to a request need to have the same ISO Type
				// TFS 3039 check pooling party for release operator											// TFS 3039
				poolParty := self.myPoolingParty;																// TFS 3039
				rs.getAllTrackedItems(allTis, false); //23/06/2023	navkc1	CR 58406 Task 58408
				//foreach ti in rs.allTrackedItems do
				foreach ti in allTis do //23/06/2023	navkc1	CR 58406 Task 58408
					if not rs.isMatchForISOTypeProduct(ti, true) then // PAR 20619
						//8/12/2009 cnwdz2 par21840
//						app.raiseCMException3(ERR_ISO_ATTACH_MISMATCH, isoType,ti.id,rs.myISOType.code, ETRow_TotalRequested, null);
						return false;
					endif;
					
					if poolParty &lt;&gt; null and ti.myPoolingParty &lt;&gt; poolParty then								// TFS 3039
						app.raiseCMException2(Cont_Not_In_Pooling_Party, ti.id, poolParty.code, null, null);	// TFS 3039
					endif;																						// TFS 3039
				endforeach;
				
				rs.validateExtraCriteriaFilters();	//02 Nov 2015	NDL	Par 37094
			
			else
				//epr 32418 13/9/13 require a total request if break bulk multi
				if rd.getCargoType &lt;&gt; null and rd.getCargoType.isBreakBulkMulti then
					if rd.totalRequested = 0 then
					//	app.raiseCMException1(REQUIRED_FIELD,app.getErrorString(CM_Total_Quantity),null,null);
						app.raiseCMException1(Input_required_field_Required,app.getErrorString(CM_Total_Quantity),null,null); // cnwdb2	PAR 35364
					endif;		
				endif;
				
				//cnwmc5 - 11 Feb 2015 - PAR 35649
				if rd.CM_ReserveTI.getTI() = null then
					app.raiseCMException(At_Least_One_CargoItem, null, null);
					return false;
				endif;
				
				// Start 22.08.2022 navrk21 TFS 54527
				//ti := rd.CM_ReserveDetail.allTrackedItems.first;
				ti := rd.CM_ReserveDetail.getFirstTI(false); //23/06/2023	navkc1	CR 58406 Task 58408
				if ti &lt;&gt; null then
					if ti.isOffSite then
						app.raiseCMException1(ERR_TI_NOT_ONSITE, ti.id, null, null);
					endif;
				endif;
				// End 22.08.2022 navrk21 TFS 54527
				// TFS 3039 check pooling party for release operator											// TFS 3039
				poolParty := self.myPoolingParty;																// TFS 3039
				// 22/08/2023	navkc1		CR 59610 Task 59611
				//if poolParty &lt;&gt; null then																		// TFS 3039
					rd.getAllTrackedItems(allTis, false); //23/06/2023	navkc1	CR 58406 Task 58408
					//foreach ti in rd.allTrackedItems do															// TFS 3039
					foreach ti in allTis do																		//23/06/2023	navkc1	CR 58406 Task 58408
						if poolParty &lt;&gt; null and ti.myPoolingParty &lt;&gt; poolParty then							// TFS 3039
							app.raiseCMException2(Cont_Not_In_Pooling_Party, ti.id, poolParty.code, null, null);// TFS 3039
						endif;																					// TFS 3039
						// ### JIRA 34756 27MAY2025 NAVAB1
						if hasCustDocs then
							// 22/08/2023	navkc1		CR 59610 Task 59611
							ti.checkStopsToBePrevented(StopPreventRelReqAssign, null, true);
						endif;
					endforeach;																					// TFS 3039
				// 22/08/2023	navkc1		CR 59610 Task 59611
				//endif;																							// TFS 3039
				//if rd &lt;&gt; null then
				if rs &lt;&gt; null and self.context = RelReqContext_CargoGroupReview then //11/07/2024	navkc1 Bug 65177
					rd.validateAgainstOwnershipChange(); //23/08/2023	navmv20	CR 59440 Task 59441
				endif;
			endif;
		endforeach;
	endif;
	
	return true;
epilog
	delete dynaDict;
	delete allTis; //23/06/2023	navkc1	CR 58406 Task 58408
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validateReserves" id="c32dd601-bb9a-4bad-8e11-aeef676fd734">
        <source>validateReserves();
// ---------------------------------------------------------------------------
// Created:		November 2004 By Andrew Bishop cnwab1
//
// Purpose:		
// 15/12/2014  cnwdb2	PAR 35364
// 14 Dec 2015	NDL	Par 37288 - make sure we validate the child reserve details too if we have a parent reserve details!
// ---------------------------------------------------------------------------
vars
	reserveDetail : CM_ReserveDetail;
begin
	if not self.allReserveDetails.isEmpty then
		foreach reserveDetail in self.allReserveDetails do
			reserveDetail.validate(null);
		endforeach;
	endif;
	if not self.allReservePackingChildren.isEmpty then 			//27/05/08 Anca Par 16830
		foreach reserveDetail in self.allReservePackingChildren do	//27/05/08 Anca Par 16830
			reserveDetail.validate(null);							//27/05/08 Anca Par 16830
		endforeach;													//27/05/08 Anca Par 16830
	endif;
	if self.allReserveDetails.isEmpty and self.allReservePackingChildren.isEmpty then
		// A bulk release must contain at least 1 request
		if (not self.releaseByType) and self.getMyCargoType &lt;&gt; null and self.getMyCargoType.isISOType() then
		//	app.raiseCMException1(REQUIRED_FIELD, 'Tracked Item/Attachment', ETRow_AddTI, null);
			app.raiseCMException(Input_required_field_trckItem, ETRow_AddTI, null); // cnwdb2	PAR 35364
		else 
			app.raiseCMException1(ERR_BULKREL_MissingRequest, self.code, ETRow_Code, null);
		endif;
	endif;

end;</source>
    </JadeMethod>
    <JadeMethod name="validateStagedToOneArea" id="627bcb74-e5c2-4d7e-8bcf-2763ec132c38">
        <source>validateStagedToOneArea( _stagedAreas : CM_LCSet input ):Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 October 2015	cnwndl1	Initial creation	Par 37033

*/

vars

	iter : Iterator;
	ti : CM_TrackedItem;
	lc : CM_LocationsController;
	ta : CM_TerminalArea;

begin

	iter := self.allTrackedItemsAssigned.createIterator;
	while iter.next( ti ) do
		if not ti.isOnSite then
			continue;
		endif;
		lc := ti.myPrimaryActualLocation;
		if lc = null then
			continue;
		endif;
		ta := lc.myTerminalArea;
		if ta = null then
			continue;
		endif;
		if ta.type &lt;&gt; TA_TYPE_YARD_INTERCHANGE then
			continue;
		endif;
		_stagedAreas.addNoDuplicates(lc,false);
	endwhile;
	
	return _stagedAreas.size &lt; 2;

epilog

	delete iter;

end;</source>
        <Parameter name="_stagedAreas" type="CM_LCSet" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
