<Class name="BGP_BackupJournal" id="c813519d-2c4f-4b1d-bc9f-2a16c66e99ed">
    <superclass name="BGP_Controller"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>&lt;display&gt;Backup Journal Controller&lt;/display&gt;</text>
    <DbClassMap file="backup"/>
    <PrimAttribute name="loggingLevel" id="87dafab1-d6ac-47e7-ba0f-e486450d1063">
        <embedded/>
        <type name="Integer"/>
        <access>readonly</access>
    </PrimAttribute>
    <JadeMethod name="finish" id="c3c3e7f9-54b5-4b68-b34d-22da9bf78f8f">
        <updating/>
        <source>finish() updating;
// ---------------------------------------------------------------------------
// Created:     Aug 2004 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 15 Jul 2008	cnwkpd1		PAR #17543 - Prevent 1090 exceptions during shutdown
// ---------------------------------------------------------------------------
begin
	if app.myBackupBGPJournalAgent &lt;&gt; null then				// PAR #17543
		app.myBackupBGPJournalAgent.finalizeAgent;
		delete app.myBackupBGPJournalAgent;
	endif;
	inheritMethod();
	
end;</source>
    </JadeMethod>
    <JadeMethod name="getFields" id="bfd53c94-92ee-4286-829f-7bbea51e7887">
        <source>getFields(_allFields: StringArray input);
// --------------------------------------------------------------------------------
// Created:		23 February 2006 by cnwdad1
//
// Purpose:		Refer to superclass implementation.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	inheritMethod(_allFields);
	_allFields.add(ETRow_LoggingLevel);
end;</source>
        <Parameter name="_allFields" type="StringArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="initApp" id="86b12c56-698d-47f8-b83c-f20f42dc8c41">
        <updating/>
        <source>initApp() updating;
// ---------------------------------------------------------------------------
// Created:     Aug 2004 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 12 Aug 2008	cnwkpd1		PAR #17713 - Set alias based on controller class for JSM moitoring of
//							critical applications
// 23 Sep 2008	cnwkpd1		PAR #18009 - Allow ini file control of transient check
//03 Jan 2013	cnwrs1	32983 crash after user deleted.
// ---------------------------------------------------------------------------
vars
	ls: Boolean;
	str: String;
	errorText: String;
	errorCode: Integer;
	msg : String;
begin

//	on Exception do app.alertExceptionHandler(exception, null, 'BGP Controller', errorCode, errorText, true, false) global;
	on Exception do self.xHandlerGlobal(exception) global;
	on LockException do app.alertLockExceptionHandler(exception) global;
	str := self.getOidString();
	str.replaceChar('.' , '_');
	app.logFileNameSpecific := 'BGPController_' &amp; self.logFileName() &amp; '_' &amp; str; //cnwrs1 par 17287 June 2008 
	
	app.setCnAppAlias(self.class.name);		// PAR #17713 //epr TFS 36655 29/4/19
	
	app.initialize();
	app.setIsBackGroundApp(true);

 	app.cmsBeginLoad(ls);
	exclusiveLock(self);
	if self.isRunning() then
		app.isBGPAppAbort := true;
		msg := 'ERR &gt;&gt; app is already running';
		app.writeLog(msg, LogFATAL);	//25 Nov 2019	NDL	TFS 47053
		app.exitLogFile();
		terminate;
	endif;
	
	if app.myPassport &lt;&gt; null then
 		app.myPassport.setMyUser(self.myUser);
  	endif;
	app.myTrxUA.trxUpdateBGPControllerProcess(self, process, process.signOnTime, true, app.myPassport);
	self.beginNotification(self, BGP_Object.BGP_TerminateAppRequest, Response_Cancel , null);
	self.beginNotification(self, BGP_Object.BGP_DebugLevelChangeEvent, Response_Continuous , null);
	self.beginNotification(self, BGP_Object.BGP_OutputInfo, Response_Continuous , null);
	self.beginNotification(self, BGP_Object.BGP_ApplicationStartRequest, Response_Continuous , null);

	create app.myBackupBGPJournalAgent transient;
	app.myBackupBGPJournalAgent.initializeAgent;
epilog
	app.cmsEndLoad(ls);
end;</source>
    </JadeMethod>
    <JadeMethod name="setAttributesForCreate" id="700b6f7d-9cda-4acb-999b-af7d2edeab23">
        <updating/>
        <source>setAttributesForCreate() updating, protected;
// ---------------------------------------------------------------------------
// Created:     Aug 2004 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	self.name := 'Journal Backup';
	self.schemaName := 'UiCommonSchema';
	self.isEditable	:= true;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setCMIF" id="0ca896b8-2935-499c-833f-5afce37397c3">
        <source>setCMIF(_cmif: CMIF_BGPManagerChildren input);
// ---------------------------------------------------------------------------
// Created:     Aug 2004 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	inheritMethod(_cmif);
	_cmif.loggingLevel := self.loggingLevel.String;
end;</source>
        <Parameter name="_cmif" type="CMIF_BGPManagerChildren" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="b1822748-ace6-4777-8ca2-ee50f8116a60">
        <updating/>
        <source>setForUpdate(_cmif: CMIF_BGPManagerChildren) updating;
// ---------------------------------------------------------------------------
// Created:     Aug 2004 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	inheritMethod(_cmif);
	self.loggingLevel := _cmif.loggingLevel.Integer;
end;</source>
        <Parameter name="_cmif" type="CMIF_BGPManagerChildren"/>
    </JadeMethod>
</Class>
