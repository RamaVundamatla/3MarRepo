						params.releaseRequestNumber := bookingRefId;
					endif;
					//11/09/2014 cnwma1 PAR#34855  CCMS POL 2351
	/*				foreach idx in 1 to params.currentBrID.length do								
						charFounded := params.currentBrID[idx:1];
						if not charFounded.isInteger and not charFounded.toUpper.isUppercaseAlpha then
							//charFounded:= charFounded;
							pos := params.currentBrID.pos(charFounded,1);
							if _ediPartyRules &lt;&gt; null then				
								ruleFunction := _ediPartyRules.getFunctionForItemValue(CM_EDIEDIFactRule.Item_RFF_1_1, charFounded, segmentValue);
								if ruleFunction = CM_EDIEDIFactRule.Function_RFF_1_1_RelNo then // Ignore Release No After Charchter
									if pos &gt; 0 then
										params.currentBrID :=_msgHelper.currentSubItem[1:30].truncatedAt(pos-1);
										//pos :=0;
										break;
									else
										params.currentBrID := _msgHelper.currentSubItem[1:30];
									endif;
								endif;
							endif;
						//break;
						endif;
					endforeach;*/
					//11/09/2014 cnwma1 PAR#34855  CCMS POL 2351	
					if releaseHeaderTI = null or 
					   (params.releaseRequestNumber &lt;&gt; null and
					   releaseHeaderTI.releaseRequestNumber &lt;&gt; params.releaseRequestNumber) and
					   (params.releaseRequestNumber = null and
					   params.currentBrID = null and
					   releaseHeaderTI.releaseRequestNumber &lt;&gt; params.currentBrID) then
						create releaseHeaderTI persistent; 
						params.myEDIRequestHeaderTI := releaseHeaderTI;
						releaseHeaderTI.setForCreateNew(_ediData);
						releaseHeaderTI.releaseRequestNumber := params.releaseRequestNumber;
					endif;
				endif;
			elseif _msgHelper.currentGroup = 1 then
				if rff1_1Code = "VON" then // voyage number
				endif;
				
			elseif _msgHelper.currentGroup = 7 then
				if rff1_1Code = "BN" then //booking ref
					_msgHelper.setNextSubItem();
					bookingRefId := _msgHelper.currentSubItem[1:30];
					releaseHeaderTI.releaseRequestNumber := bookingRefId;
					releaseItemTI.releaseRequestNumber := bookingRefId;
					self.processBookingRefID(_msgHelper.currentSubItem[1:30], bookingRefId, _ediPartyRules);
					if bookingRefId &lt;&gt; null then
						releaseHeaderTI.releaseRequestNumber := bookingRefId;
						releaseItemTI.releaseRequestNumber := bookingRefId;
					endif;
	//                params.currentBrID := _msgHelper.currentSubItem[1:30]; //cnwgb1 PAR 33637 24.3.2014           
	// 				releaseHeaderTI.releaseRequestNumber := params.currentBrID;
	//				if releaseItemTI &lt;&gt; null then
	//					releaseItemTI.releaseRequestNumber := params.currentBrID;
	//				endif;	
				elseif rff1_1Code = "SQ" then //container seq number
					_msgHelper.setNextSubItem();
					releaseItemTI.sequence := _msgHelper.currentSubItem[1:12]; 
				endif;
			endif;
		endif;
//SEL
	
//TDT	
	elseif _msgHelper.currentTag = "TDT" then
		if _msgHelper.currentGroup = 0 then
			_msgHelper.setCurrentGroup(1);
		endif;
		if _msgHelper.currentGroup = 7 then
			_msgHelper.setCurrentGroup(9);
		endif;
		_msgHelper.setNextField();
		if _msgHelper.currentGroup = 1 then
			if _msgHelper.currentField = "20" then
				self.getVoyageDetailsFromTDT(	_msgHelper, params.voyageCode, params.voyageOperatorCode, params.myVoyageOperator, params.vesselName, params.lloydsNumber, params.callsign );
				
				// Because some port clients (ANL and COS in particular) do not send
				// through the mandatory UNB record the operator is not getting set up.
				// To cater for this we will use the first valid TDT+20 operator
				// if and only if the operator is not already set up.
				if params.mySenderOperator = null then
					params.mySenderOperator	:= params.myVoyageOperator;
					params.senderOperatorCode := params.voyageOperatorCode;
				endif;
				
				_ediData.operatorCode	:= params.senderOperatorCode;
				
				if params.mySenderOperator &lt;&gt; null then
				//cnwrs1 par 26022 19 Oct 2010 now we have the vessel and the xlation operator try the vesselname xlation
					vesselCode := params.mySenderOperator.getXlationSystemCode(params.vesselName, XLATION_TYPE_VESSEL_BYOP, foundMatch);
					if not foundMatch then	//14 Mar 2014	cnwrs1	Par 33619 if not match the vesselName is returned
						vessel := app.myRoot.allVesselsByName[vesselCode];
					else
						vessel := app.myRoot.allVessels[vesselCode];
					endif;
					if vessel &lt;&gt; null then
						params.vesselName := vessel.name;
					endif;
					params.voyageCode	:= self.getXlationOperatorVoyageCode(params.mySenderOperator, params.myVoyageOperator, params.voyageCode, params.vesselName, params.lloydsNumber, params.callsign );
				endif;
			endif;
		elseif _msgHelper.currentGroup = 9 then //Tranships
			if _msgHelper.currentField = "30" then
				_msgHelper.setCurrentGroup(1);
				
				//If the discharge port (LOC+11) matches this port then we're a tranship.
				thisPortCode := app.myPassport.myTerminal.getConfig(PortDestCode).String; //PAR24467 cnwsh3 17/06/2010
				
				if params.dischargePort = thisPortCode then
					params.transVoyageCode := params.voyageCode;
					
					self.getVoyageDetailsFromTDT(	_msgHelper,
													params.voyageCode,
													params.voyageOperatorCode,
													params.myVoyageOperator,				// cnwrl1 26/07/2010 PAR 25093
													params.vesselName,
													params.lloydsNumber,
													params.callsign );
					
					releaseHeaderTI.vesselName := params.vesselName; //PAR24680 - cnwsh3 28/6/2010.
					releaseHeaderTI.setVoyageCode(params.voyageCode.trimBlanks()[1:30]);
					//releaseTI.setConsignorVoyage(params.voyageCode.trimBlanks()[1:30]);
					
					if params.mySenderOperator &lt;&gt; null then
						// make sure the manual collection on CM_EDIConfig gets maintained
						params.voyageCode	:= self.getXlationOperatorVoyageCode(params.mySenderOperator,
																			params.myVoyageOperator,
																			params.voyageCode,
																			params.vesselName,
																			params.lloydsNumber,
																			params.callsign );
						releaseHeaderTI.setVoyageCode( params.voyageCode );
					else
						// make sure the manual collection on CM_EDIConfig gets maintained
						releaseHeaderTI.setVoyageCode( releaseHeaderTI.getVoyageCode );
					endif;
				endif;
			endif;
		endif;
//TMP
    elseif _msgHelper.currentTag = "TMP" then // jlggb1 TFS 6574 18.8.17 This case revised to create Remark
		if _ediPartyRules &lt;&gt; null then
			_msgHelper.setNextField();
			ruleFunction := _ediPartyRules.getFunctionForItemValue(CM_EDIEDIFactRule.Item_TMP_1_1, _msgHelper.currentField, segmentValue);
			_msgHelper.setNextField();
			// TFS#53294 NAVSP1 31MAR2022 - START
			if _msgHelper.currentSubItem = null then    
				_msgHelper.setNextField();				
			endif;										
			// TFS#53294 NAVSP1 31MAR2022 - END
			tValueStr := _msgHelper.currentSubItem; 
            _msgHelper.setNextSubItem();
			
			tScaleStr := _msgHelper.currentSubItem;
			
			remark := 'TEMP ' &amp; tValueStr &amp; tScaleStr;
			
			//11 Jan 2018	NDL	TFS 36400
			if remark &lt;&gt; null and releaseItemTI &lt;&gt; null then
				reefTypeObj := app.myRoot.allISOTypes[releaseItemTI.isoType];
				if reefTypeObj = null or not reefTypeObj.isReefer then
					remark := null;
				endif;
			endif;
				
			if releaseHeaderTI.remarks = null then
				releaseHeaderTI.remarks := remark;
			else
				releaseHeaderTI.remarks := releaseHeaderTI.remarks &amp; CrLf &amp; remark;
			endif;	
			
			// TFS#53294 NAVSP1 31MAR2022
			if releaseItemTI.remarks = null then
				releaseItemTI.remarks := remark;		//+TFS38149	
			else
				releaseItemTI.remarks := releaseItemTI.remarks &amp; CrLf &amp; remark;
			endif;
			// TFS#53294 NAVSP1 31MAR2022 - END
			
			if  ruleFunction = CM_EDIEDIFactRule.Function_TMP_1_1_MTGradeTemp then
				// segment contains temperature to use as part of the MT grade xlation criteria.
				// we need to save this off for later
				temperature := tValueStr.asEDIReal();
                if tScaleStr = "CEL" then
                    self.setMTGradeXlatCrit_TempMulti (releaseItemTI, temperature);
                elseif tScaleStr = "FAH" then
                    self.setMTGradeXlatCrit_TempMulti (releaseItemTI, app.temperatureConversion(false,temperature));
                endif;
			endif;		
		endif;
	endif;
epilog

	delete ftxArray; 
	
end;</source>
        <access>protected</access>
        <Parameter name="_msgHelper" type="CMIF_EDIFACTHelper" usage="io"/>
        <Parameter name="_ediFile" type="CM_EDIFile" usage="input"/>
        <Parameter name="_ediData" type="CM_EDIData" usage="input"/>
        <Parameter name="_ediOperator" type="CM_Operator"/>
        <Parameter name="_ediPartyRules" type="CM_EDIPartyCoparnRules"/>
    </JadeMethod>
    <JadeMethod name="processEDIFACTSegment" id="93cc216e-dc68-4134-96f2-041022204e8e">
        <source>processEDIFACTSegment(_msgHelper: CMIF_EDIFACTHelper io; _ediFile : CM_EDIFile input; _ediData : CM_EDIData io;
						_ediOperator: CM_Operator; _ediPartyRules :CM_EDIPartyCoparnRules; _reload : Boolean;_version :String) protected;
/*
Purpose:
    For CCMS 2122 Processing of the EDIFACT segments has been enhanced so that the EDIData type is determined by
    EDIParty rules on the BGM segment. Only the BGM segment is processed in this routine. The processing for segments 
    in the message are handled by the processEDIFACTRelease and processEDIFACTBooking methods
    
    Note that this method is called from within a loop over lines in the message
    Variables declared here only last for one line of the file!

Date		Who		Reason
21 Nov 2011	cnwgb1	Initial creation
23 Feb 2012	cnwrs1	Par 29181 Fix up Coparn reprocess
14 Apr 2013	cnwcs5	CCMS pol 2097 / par 31259
02 Jul 2013	cnwcs5	par 31893 - use currentSubItem not currentFiel for BGM1.1 rule
04 Jul 2013	cnwcs5	par 31942 - signature change
//12 Jan 2015	cnwrs1	Par 35504 - Refactor EDI file load for .NET
//06 May 2016	cnwrs1	TFS 1600 COPARN VGM
14 Jun 2016 cnwma1	TFS #2048 POL - HSD EDI Empty Release Request Adding version to the signature
// 18 Aug 2016	cnwrs1	TFS 2553 remove COPARN VGM processing
21 Feb 2017 	cnwer1  TFS 2744 new edi party rule can just create prenotes 
14 Jul 2017	cnwdap1		TFS 5294 If a booking file contains cargo IDs in the EQD, create prenotes instead of booking items
22 Aug 2017	jlgdap1		TFS 6632 Make the creation of prenotes optional
// 26 Oct 2017	jlgrs1	TFS 5705 - SNO - EDIDataBooking Prenote release Req
// 29 Nov 2017	jlgrs1	TFS 5705A - SNO - EDIDataBooking Prenote release Req
// 18 Dec 2017	jlgdap1	TFS 8191 MES Give an error if not licesned for COPARN Releases (otherwise a COPARN release falls in to the booking code and gets horribly confused)
// 01 Jun 2018	jlgrs1	TFS 38992 JMT Booking and ReleaseReq for GateDoc
// 14 Jun 2018	jlgrs1	TFS 39018 SNO Cargo Operator in COPRAR
// 18 Jul 2018	jlgrs1	TFS 39297 SNO reload reTranslate from EDI Message Admin is crashing with dump
// 29 Jan 2019	jlgrs1	TFS 43144 CusCar not working after changes for TFS 41659 42276
// 07 Apr 2019	jlgrs1	TFS 41913 STWR - Reconfiguration of the EDI Operation form to better handle EDI collection locks while loading 
// 08 Apr 2020	jlgdap1	TFS 49084 MSL COPARN and VGM
*/
vars
    ruleFunction 	: Integer; 	// BGM local variable
	oldEdiData,
    ediData 		: CM_EDIData; 				// BGM local variable
    params 			: CMIF_EDIFACTParams; 		// BGM local variable
    ediType 		: Integer;
	segmentValue	: String;
	ediFileType : CM_EDIFileType;
	createPrenote : Boolean;
	prenoteParams : CMIF_EDIFACTParams;
begin
    params := _msgHelper.myCurrentParams;
	if app.myPassport.myTerminal.getConfig(EdiUseOldCoparn).Boolean then
		params.oldCoparnTypes := true;
	else
		if _ediPartyRules &lt;&gt; null then
			params.oldCoparnTypes := _ediPartyRules.getCoparnEDIDataStyle;
		else
			params.oldCoparnTypes := false;
		endif;
	endif;
	if params.oldCoparnTypes then
		if _ediData = null and
		   not _ediFile.ediData.isKindOf(CM_EDIDataBooking) then
			oldEdiData := _ediFile.ediData;
			_ediFile.ediData := null;
			app.myUtilityCA.utlCreateEDIData(ediData, CM_EDIDataBooking, ediType, EDIFileType_Coparn, _ediFile.ediConfig, _ediFile, ediFileType, app.myPassport);
			ediData.setStatus(CM_EDIFile.EDI_STATUS_LOADED);
			delete oldEdiData;
		endif;
	else
		if _ediData = null and
		   not _ediFile.ediData.isKindOf(CM_EDIDataGateDoc) then
			oldEdiData := _ediFile.ediData;
			_ediFile.ediData := null;
			app.myUtilityCA.utlCreateEDIData(ediData, CM_EDIDataGateDoc, ediType, EDIFileType_Coparn, _ediFile.ediConfig, _ediFile, ediFileType, app.myPassport);
			ediData.setStatus(CM_EDIFile.EDI_STATUS_LOADED);
			delete oldEdiData;
		endif;
	endif;
	if not params.oldCoparnTypes then
		_ediData := _ediFile.ediData;
	endif;
//rs	createPrenote := false; //impletment later maybe required for salerno 
//BGM
    if _msgHelper.currentTag = "BGM" then
        _msgHelper.setCurrentGroup(0);
        _msgHelper.setNextField();
        if params &lt;&gt; null then
            params.clearAll();
        endif;
        ruleFunction := CM_EDIEDIFactRule.Function_Undefined;
        //Determine the kind of Data to return.
		if _ediPartyRules &lt;&gt; null then
			ruleFunction := _ediPartyRules.getFunctionForItemValue(CM_EDIEDIFactRule.Item_BGM_1_1, _msgHelper.currentSubItem, segmentValue);	// par 31893
		endif;
		
		if  ruleFunction = CM_EDIEDIFactRule.Function_Undefined then   //cnwma1 TFS #2048 14/06/2016 
			if _ediPartyRules &lt;&gt; null then
				ruleFunction := _ediPartyRules.getFunctionForItemValue(CM_EDIEDIFactRule.Item_UNH_1_1, _version, segmentValue);	
			endif;
		endif;
		
        if ruleFunction = CM_EDIEDIFactRule.Function_BGM_1_1_Booking or 
		   ruleFunction = CM_EDIEDIFactRule.Function_Undefined or
		   ruleFunction = CM_EDIEDIFactRule.Function_UNH_1_1_Booking then   //cnwma1 TFS #2048 14/06/2016 
			if params.oldCoparnTypes then
				if not _reload then	//23 Feb 2012	cnwrs1	Par 29181 Fix up Coparn reprocess
					_ediData := _ediFile.ediData;
				else
					if _ediData.isKindOf(CM_EDIDataReleaseRequest) then
						params.skipTillNextBGM := true;
					else
						params.skipTillNextBGM := false;
					endif;
				endif;
				
				_msgHelper.myCurrentParams.ediDataType := _ediData.ediDataType;
				
/*rs				if createPrenote then
					// (This will only happen if there are multiple Release Request BGMs in the file.
					if _ediFile.allEDIData.size &gt; 0 then
						foreach ediData in _ediFile.allEDIData do
							if ediData.isKindOf(CM_EDIDataPrenote) then
								prenoteEdiData := ediData;
								break;
							endif;
						endforeach;
					endif;
					// If we don't have a prexisting Release Request EDI Data, create one.
					if prenoteEdiData = null then
						app.myUtilityCA.utlCreateEDIData(prenoteEdiData, CM_EDIDataPrenote, ediType, EDIFileType_Coparn, _ediFile.ediConfig, _ediFile, ediFileType, app.myPassport);
						prenoteEdiData.setStatus(CM_EDIFile.EDI_STATUS_LOADED);
					endif;
				endif;*/
			else
				params.createBooking := true;
				params.createReleaseRequest := false;
				params.skipTillNextBGM := false;
				if ruleFunction = CM_EDIEDIFactRule.Function_Undefined and
				   _ediPartyRules &lt;&gt; null and
				   (_ediPartyRules.isFunctionForItem(CM_EDIEDIFactRule.Item_BGM_1_1) or 
				    _ediPartyRules.isFunctionForItem(CM_EDIEDIFactRule.Item_UNH_1_1)) then
					params.skipTillNextBGM := true;
				endif;
/*				if not params.createReleaseRequest then
					params.createBooking := true;
				endif;
				if params.createReleaseRequest then
					params.skipTillNextBGM := true;
				else
					params.skipTillNextBGM := false;
				endif;*/
			endif;
        elseif ruleFunction = CM_EDIEDIFactRule.Function_BGM_1_1_Release or
			   ruleFunction = CM_EDIEDIFactRule.Function_UNH_1_1_Release	then         //cnwma1 TFS #2048 14/06/2016 
			if params.oldCoparnTypes then
				if not _reload then	//23 Feb 2012	cnwrs1	Par 29181 Fix up Coparn reprocess			
					ediType := EDIDataType_ReleaseRequest;
					_ediData := null;		
					// See if we have already got a Release Request EDI Data for this file. If so use it
					// (This will only happen if there are multiple Release Request BGMs in the file.
					if _ediFile.allEDIData.size &gt; 0 then
						foreach ediData in _ediFile.allEDIData do
							if ediData.isKindOf(CM_EDIDataReleaseRequest) then
								_ediData := ediData;
								break;
							endif;
						endforeach;
					endif;
					// If we don't have a prexisting Release Request EDI Data, create one.
					if _ediData = null then
						app.myUtilityCA.utlCreateEDIData(_ediData, CM_EDIDataReleaseRequest, ediType, EDIFileType_Coparn, _ediFile.ediConfig, _ediFile, ediFileType, app.myPassport);
						_ediData.setStatus(CM_EDIFile.EDI_STATUS_LOADED);
					endif;
					_msgHelper.myCurrentParams.ediDataType := _ediData.ediDataType;
				else
					if _ediData.isKindOf(CM_EDIDataReleaseRequest) then
						params.skipTillNextBGM := false;
					else
						params.skipTillNextBGM := true;
					endif;
				endif;
			else
				params.createBooking := false;
				params.createReleaseRequest := true;
				params.skipTillNextBGM := false;
/*				if not params.createBooking then
					params.createReleaseRequest := true;
				endif;
				if params.createReleaseRequest then
					params.skipTillNextBGM := false;
				else
					params.skipTillNextBGM := true;
				endif;*/
			endif;
		elseif ruleFunction = CM_EDIEDIFactRule.Function_BGM_1_1_Prenote then
			if params.oldCoparnTypes then
				self.changeToPreNoteProcessing(_reload, _ediData, _ediFile, params, _msgHelper);			// TFS 5294
				createPrenote := true;
			else
				if _ediPartyRules &lt;&gt; null then //and _ediPartyRules.createPrenotesForEQDWithID then	// TFS 6632
					params.createPrenote := true;
				endif;
			endif;
        endif;

        _msgHelper.setNextField();
        _msgHelper.setNextField();
        if _msgHelper.currentField = "1" then
            _msgHelper.setCurrentMessageMode(CM_EDITrackedItem.EDI_ACTION_DELETE);
        elseif _msgHelper.currentField = "5" then
            _msgHelper.setCurrentMessageMode(CM_EDITrackedItem.EDI_ACTION_UPDATE);
        elseif _msgHelper.currentField = "9" then
            _msgHelper.setCurrentMessageMode(CM_EDITrackedItem.EDI_ACTION_ADD);
        else
            // Behaviour as previous 
             _msgHelper.setCurrentMessageMode(CM_EDITrackedItem.EDI_ACTION_ADD);
        endif;
			
        // get default commodity codes to use for EQD, DGS &amp; TMP segments
       // app.getTerminalDefCmdty(params.mtCmdty, params.defCmdty, params.refCmdty, params.hazCmdty);
        params.mySenderOperator := _ediOperator;
		
        if _ediOperator &lt;&gt; null then
            params.senderOperatorCode := _ediOperator.code;
        endif;
		
		if _reload then	//23 Feb 2012	cnwrs1	Par 29181 Fix up Coparn reprocess
			_ediData.setStatus(CM_EDIFile.EDI_STATUS_LOADED);
		endif;
	else
		if not params.skipTillNextBGM then
			if params.oldCoparnTypes then
				// TFS 5294 Check if this next line is a EQD segment - if so, check it for a cargo id			// TFS 5294
				// If we're processing as a booking, and it has a cargo ID, process this section as a prenote, 	// TFS 5294
				// not a booking item																			// TFS 5294
				// TFS 6632 Only do this if the COPARN party rule says to						// TFS 6632
				if _ediPartyRules &lt;&gt; null and createPrenote then //rs _ediPartyRules.createPrenotesForEQDWithID then	// TFS 6632
					if _ediData &lt;&gt; null 																			// TFS 5294
					and _ediData.ediDataType &lt;&gt; EDIDataType_Prenote  												// TFS 5294
					and not _ediData.isKindOf(CM_EDIDataReleaseRequest) 											// TFS 5294
					and _msgHelper.currentTag = "EQD" then															// TFS 5294
						_msgHelper.setNextField();																	// TFS 5294
						_msgHelper.setNextField();																	// TFS 5294
						if _msgHelper.currentField &lt;&gt; null then														// TFS 5294
							_ediFile.ediData := null;																// TFS 5294
							self.changeToPreNoteProcessing(_reload, _ediData, _ediFile, params, _msgHelper);		// TFS 5294
						endif;																						// TFS 5294
						_msgHelper.setFirstField();																	// TFS 5294
					endif;																							// TFS 5294
				endif;																			// TFS 6632
				
				//if _ediData.isKindOf(CM_EDIDataRequestMultiLine) and													// TFS 8191
				//   app.myRoot.canDoEDIFileType(EDIFileType_CoparnRelease) then										// TFS 8191
				if _ediData.isKindOf(CM_EDIDataRequestMultiLine) then													// TFS 8191
					if not app.myRoot.canDoEDIFileType(EDIFileType_CoparnRelease) then									// TFS 8191
						app.raiseCMException1(NotLicensedToPerformAction, "COPARN - Container Release", null, null);	// TFS 8191
						return;																							// TFS 8191
					endif;																								// TFS 8191
					self.processEDIFACTReleaseMulti(_msgHelper, _ediFile, _ediData, _ediOperator, _ediPartyRules);	//23 Feb 2012	cnwrs1	Par 29181 Fix up Coparn reprocess
				//elseif _ediData.isKindOf(CM_EDIDataReleaseRequest) and												// TFS 8191
				//   app.myRoot.canDoEDIFileType(EDIFileType_CoparnRelease) then										// TFS 8191
				elseif _ediData.isKindOf(CM_EDIDataReleaseRequest) then													// TFS 8191
					if not app.myRoot.canDoEDIFileType(EDIFileType_CoparnRelease) then									// TFS 8191
						app.raiseCMException1(NotLicensedToPerformAction, "COPARN - Container Release", null, null);	// TFS 8191
						return;																							// TFS 8191
					endif;																								// TFS 8191
					self.processEDIFACTRelease(_msgHelper, _ediFile, _ediData, _ediOperator, _ediPartyRules);	//23 Feb 2012	cnwrs1	Par 29181 Fix up Coparn reprocess
				elseif _ediData.isKindOf(CM_EDIDataPrenote) then
					self.processEDIFACTPrenote(_msgHelper, _ediFile, _ediData, _ediOperator, _ediPartyRules);
				else
/*rs					if createPrenote then
						// (This will only happen if there are multiple Release Request BGMs in the file.
						if _ediFile.allEDIData.size &gt; 0 then
							foreach ediData in _ediFile.allEDIData do
								if ediData.isKindOf(CM_EDIDataPrenote) then
									prenoteEdiData := ediData;
									break;
								endif;
							endforeach;
						endif;
						
						if prenoteEdiData &lt;&gt; null then
							prenoteParams:=_msgHelper.getParamsForDataType(prenoteEdiData.ediDataType);
							if prenoteParams = null then
								prenoteParams:= _msgHelper.myCurrentParams.cloneSelf(true);
								prenoteParams.ediDataType :=prenoteEdiData.ediDataType;
								prenoteParams.mySenderOperator:=_msgHelper.myCurrentParams.mySenderOperator;
								_msgHelper.allParams.add(prenoteParams);
							endif;
							
							_msgHelper.setCurrentParam(prenoteParams);
							self.processEDIFACTPrenote(_msgHelper, _ediFile, prenoteEdiData, _ediOperator, _ediPartyRules);	
							_msgHelper.setCurrentParam(_msgHelper.allParams.first.CMIF_EDIFACTParams);
						endif;
					endif;*/
					_msgHelper.setFirstField();
					params.weightCertifiedName := null;					// TFS 49084
					params.weightCertifiedReference := null;			// TFS 49084
					self.processEDIFACTBooking(_msgHelper, _ediFile, _ediData, _ediOperator, _ediPartyRules);	//23 Feb 2012	cnwrs1	Par 29181 Fix up Coparn reprocess
				endif;
			else
				if params.createPrenote then
					if _msgHelper.currentTag = "EQD" then
						_msgHelper.setNextField();
						_msgHelper.setNextField();
						_msgHelper.setFirstField();
					endif;
				endif;
				
				if params.createReleaseRequest and
				   app.myRoot.canDoEDIFileType(EDIFileType_CoparnRelease) then
					self.processEDIFACTReleaseMulti(_msgHelper, _ediFile, _ediData, _ediOperator, _ediPartyRules);
				endif;
				if params.createPrenote then	// TFS 6632
					self.processEDIFACTPrenote(_msgHelper, _ediFile, _ediData, _ediOperator, _ediPartyRules);
				endif;
				if params.createBooking then
					_msgHelper.setFirstField();
					params.weightCertifiedName := null;					// TFS 49084
					params.weightCertifiedReference := null;			// TFS 49084
					self.processEDIFACTBooking(_msgHelper, _ediFile, _ediData, _ediOperator, _ediPartyRules);	//23 Feb 2012	cnwrs1	Par 29181 Fix up Coparn reprocess
				endif;								
			endif;
		endif;
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="_msgHelper" type="CMIF_EDIFACTHelper" usage="io"/>
        <Parameter name="_ediFile" type="CM_EDIFile" usage="input"/>
        <Parameter name="_ediData" type="CM_EDIData" usage="io"/>
        <Parameter name="_ediOperator" type="CM_Operator"/>
        <Parameter name="_ediPartyRules" type="CM_EDIPartyCoparnRules"/>
        <Parameter name="_reload" type="Boolean"/>
        <Parameter name="_version" type="String"/>
    </JadeMethod>
    <JadeMethod name="processFile" id="9fbd97ca-746d-45b5-9936-a52a15079a23">
        <updating/>
        <source>processFile(_ediFile: CM_EDIFile input) protected, updating;
/*

Purpose:
    For CCMS 2122, Processing of the EDIFACT segments has been enhanced so that the EDIData type is determined by
    EDIParty rules on the BGM segment. Only the BGM segment is processed in this routine. The processing for segments 
    in the message are handled by the processEDIFACTRelease and processEDIFACTBooking methods
    

//Date		Who		Reason

//05/12/2011  cnwrs1  CCMS POL 2122 / PAR 28696 - add support for EDI Release Request processing
//23 Feb 2012	cnwrs1	Par 29181 Fix up Coparn reprocess
// 01 Nov 2017	jlgrs1	TFS 5705 - SNO - EDIDataBooking Prenote release Req
// 18 Jan 2019	jlgrs1	TFS 41659 42276 STWR Make EDI MultiThreaded Stage 8
// 29 Jan 2019	jlgrs1	TFS 43144 CusCar not working after changes for TFS 41659 42276
// 07 Apr 2019	jlgrs1	TFS 41913 STWR - Reconfiguration of the EDI Operation form to better handle EDI collection locks while loading 
*/
vars
	ediData : CM_EDIData;
begin
    self.processEDIFACTFile(_ediFile, ediData, false);	//23 Feb 2012	cnwrs1	Par 29181 Fix up Coparn reprocess
	
	self.cleanupEDIData(_ediFile);

    return;
epilog
end;</source>
        <access>protected</access>
        <Parameter name="_ediFile" type="CM_EDIFile" usage="input"/>
    </JadeMethod>
    <JadeMethod name="reprocessFile" id="2fa372b9-7352-4abd-88b1-c725429ce81b">
        <updating/>
        <source>reprocessFile(_ediFile: CM_EDIFile input; _ediData: CM_EDIData) updating;
//
//23 Feb 2012	cnwrs1	Par 29181 Fix up Coparn reprocess
//
// 29 Jan 2019	jlgrs1	TFS 43144 CusCar not working after changes for TFS 41659 42276
// 07 Apr 2019	jlgrs1	TFS 41913 STWR - Reconfiguration of the EDI Operation form to better handle EDI collection locks while loading 
// 19 May 2023  navsp1  TFS Bug 58053: PNL - EDI Operations - Translations fail to apply when a file is reloaded/retranslated
vars
	ediData : CM_EDIData;
	ediUserDefinedAssist  : CMIF_EDIUserDefinedAssist;
begin
	ediData := _ediData;
    self.processEDIFACTFile(_ediFile, ediData, true);
	
	//18.May.2023 navsp1 TFS 58053
	if _ediData.allEDITrackedItems.size &gt; 0 then
		if not tryLock(_ediData.ediConfig, Exclusive_Lock, Transaction_Duration, LockTimeout_Server_Defined) then
			self.exclusiveLock(_ediData.ediConfig);
		endif;
		if not tryLock(_ediData.ediConfig.allEDITrackedItemsByIdStatus, Exclusive_Lock, Transaction_Duration, LockTimeout_Server_Defined) then
			self.exclusiveLock(_ediData.ediConfig.allEDITrackedItemsByIdStatus);
		endif;
		create ediUserDefinedAssist transient;
		_ediData.addEDIConfigToEDITis(ediUserDefinedAssist);		
	endif;
	
//	_ediFile.ediData.doTranslations();	//19 Jan 2016	NDL	Par 37413
epilog
	delete ediUserDefinedAssist;
end;
</source>
        <Parameter name="_ediFile" type="CM_EDIFile" usage="input"/>
        <Parameter name="_ediData" type="CM_EDIData"/>
    </JadeMethod>
    <JadeMethod name="setEDIPartyDefaults" id="c74eeea4-e772-41e8-b65a-b4058b7c0533">
        <source>setEDIPartyDefaults(_rules :CM_EDIPartyCoparnRules; _terminal :CM_Terminal; _params : CMIF_EDIFACTParams; _releaseTI :CM_EDIReleaseRequestTI input;
					_isGenerator :Boolean)protected;
/*
Date		Who		Reason
15/02/2012	cnwcs5	Initial creation - par 29137 Coparn release requests
05/03/2012	cncs5	par 29210 - include vessel code in consignor voyage
03/05/2012	cnwcs5	par 29402 - don't set default voyage here. set it during verify/load (if we need to )
19/02/2012	cnwcs5	CCMS pnl 2243 / PAR 31185
02/07/2013	cnwcs5	par 31893	
28/08/2013	cnwcs5	CCMS POL 2221 / par 32094(3) - things found during qual
*/
vars
	ediParty	: CM_EDIParty;
	voyage		: CM_Voyage;
	str			: String;
begin
	if _rules = null then
		return;
	endif;
	
	// default release type (probably Unknown)
	_releaseTI.releaseType 		:= _rules.defaultReleaseType;
	_releaseTI.releaseTypeStr 	:= app.releaseRequestTypeEnumToString(_releaseTI.releaseType);
	
	// default release status (Active or Pending)
	_releaseTI.statusBulkRelease	:= app.releaseStatusEnumToString (_rules.defaultReleaseStatus);	// par 31185
	
	// default sub-terminal (not included in file)
	if _rules.myDefaultSubTerminal &lt;&gt; null then
		_releaseTI.subTerminalCode := _rules.myDefaultSubTerminal.code;
	endif;
	
	if _isGenerator then
		_releaseTI.isoType 			:= _rules.getISOTypeForGenerator;	// par 32094(3)
	else
		_releaseTI.checkISOGroup 	:= _rules.useISOGroupForReleaseRequests;
	endif;
	
	if _rules.myDefaultCarrier &lt;&gt; null then	// par 31893
		_releaseTI.carrierCode 		:= _rules.myDefaultCarrier.code;
	endif;
	
	_releaseTI.deliveryReason 	:= _rules.defaultDeliveryReasonCode;
	
	// set consignor voyage to code from file before we (maybe) overwrite voyage
	str := _releaseTI.getVoyageCode;			// par 29210 - March 2012
	str := str &amp; ' ' &amp; _releaseTI.vesselName;	// par 29210 - March 2012
		
	if str.length &gt; 20  then					// par 29210 - March 2012
		str := str [1:20];						// par 29210 - March 2012
	endif;										// par 29210 - March 2012
	
	_releaseTI.setConsignorVoyage (str);		// par 29210 - March 2012
	
	// we used to set the default voyage for the EDI party here but this has
	// been taken out and it will be set if needed in the verify/loadDB
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_rules" type="CM_EDIPartyCoparnRules"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_params" type="CMIF_EDIFACTParams"/>
        <Parameter name="_releaseTI" type="CM_EDIReleaseRequestTI" usage="input"/>
        <Parameter name="_isGenerator" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setEDIPartyDefaultsMulti" id="3f27b2a8-efa6-4dff-9768-fb47f627f8bb">
        <source>setEDIPartyDefaultsMulti(_rules :CM_EDIPartyCoparnRules; _terminal :CM_Terminal; _params : CMIF_EDIFACTParams; _releaseHeaderTI :CM_EDIRequestHeaderTI input; _releaseItemTI :CM_EDIRequestDetailTI input;
					_isGenerator :Boolean)protected;
/*
Date		Who		Reason
15/02/2012	cnwcs5	Initial creation - par 29137 Coparn release requests
05/03/2012	cncs5	par 29210 - include vessel code in consignor voyage
03/05/2012	cnwcs5	par 29402 - don't set default voyage here. set it during verify/load (if we need to )
19/02/2012	cnwcs5	CCMS pnl 2243 / PAR 31185
02/07/2013	cnwcs5	par 31893	
28/08/2013	cnwcs5	CCMS POL 2221 / par 32094(3) - things found during qual
// 17 Oct 2017	jlgrs1	TFS 5705 - SNO - EDIDataBooking Prenote release Req
*/
vars
	ediParty	: CM_EDIParty;
	voyage		: CM_Voyage;
	str			: String;
begin
	if _rules = null then
		return;
	endif;
	
	// default release type (probably Unknown)
	_releaseHeaderTI.releaseType 		:= _rules.defaultReleaseType.String;
	_releaseHeaderTI.releaseTypeStr 	:= app.releaseRequestTypeEnumToString(_releaseHeaderTI.releaseType.Integer);
	
	// default release status (Active or Pending)
	_releaseHeaderTI.statusBulkRelease	:= app.releaseStatusEnumToString (_rules.defaultReleaseStatus);	// par 31185
	
	// default sub-terminal (not included in file)
	if _rules.myDefaultSubTerminal &lt;&gt; null then
		_releaseHeaderTI.subTerminalCode := _rules.myDefaultSubTerminal.code;
	endif;
	
	if _isGenerator then
		_releaseItemTI.isoType 			:= _rules.getISOTypeForGenerator;	// par 32094(3)
	else
		_releaseItemTI.checkISOGroup 	:= _rules.useISOGroupForReleaseRequests;
	endif;
	
	if _rules.myDefaultCarrier &lt;&gt; null then	// par 31893
		_releaseHeaderTI.carrierCode 		:= _rules.myDefaultCarrier.code;
	endif;
	
	_releaseHeaderTI.deliveryReason 	:= _rules.defaultDeliveryReasonCode;
	
	// set consignor voyage to code from file before we (maybe) overwrite voyage
	str := _releaseHeaderTI.getVoyageCode;			// par 29210 - March 2012
	str := str &amp; ' ' &amp; _releaseHeaderTI.vesselName;	// par 29210 - March 2012
		
	if str.length &gt; 20  then					// par 29210 - March 2012
		str := str [1:20];						// par 29210 - March 2012
	endif;										// par 29210 - March 2012
	
	_releaseHeaderTI.consignorVoyage := str;		// par 29210 - March 2012
	
	// we used to set the default voyage for the EDI party here but this has
	// been taken out and it will be set if needed in the verify/loadDB
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_rules" type="CM_EDIPartyCoparnRules"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_params" type="CMIF_EDIFACTParams"/>
        <Parameter name="_releaseHeaderTI" type="CM_EDIRequestHeaderTI" usage="input"/>
        <Parameter name="_releaseItemTI" type="CM_EDIRequestDetailTI" usage="input"/>
        <Parameter name="_isGenerator" type="Boolean"/>
    </JadeMethod>
