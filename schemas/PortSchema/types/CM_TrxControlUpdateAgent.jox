    <JadeMethod name="trxUpdateVoyageProcStatusAll" id="b5c3611d-8882-463b-89e9-d7717ba75013">
        <updating/>
        <source>trxUpdateVoyageProcStatusAll(_passport : CM_Passport input) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 05/06/2018	jlgdap1		Initial creation TFS 38851 PEL1 Voyage Statuses INAPORTNET
// 21/09/2021	jlizm1		TFS 51963 SAL Voyage Request Changes
// 16/08/2022	jlizm1		TFS 54298 EUP - Simplified Voyage Work Order Process
// 20/06/2024	navkc1 		CR 64611 Task 64623: Jade - New Voyage Process
//
vars
	realStatus : CM_VoyageStatus;
	pxyProcess, realProcess, defaultProcess : CM_VoyageProcess;

begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	app.setContinueCMExceptions(false);

	beginTransaction;

	// First off, delete statuses that we need to renumber. These are:
	// Voyage_Status_IDepServApproved (id was 217, is now 245)
	realStatus := app.myRoot.allVoyageStatuses[217];
	if realStatus &lt;&gt; null and realStatus.description = "Departure Marine Services Approved" then
		app.writeLog(method.qualifiedName &amp; " Deleted Voyage Status " &amp; realStatus.description, LogINFO);
		delete realStatus;
	endif;
	// Voyage_Status_IServPreInvGen (id was 218, is now 217)
	realStatus := app.myRoot.allVoyageStatuses[218];
	if realStatus &lt;&gt; null and realStatus.description = "Marine Pre-Invoice Generated" then
		app.writeLog(method.qualifiedName &amp; " Deleted Voyage Status " &amp; realStatus.description, LogINFO);
		delete realStatus;
	endif;
	// Voyage_Status_IServTaxInvGen (id was 219, is now 218)
	realStatus := app.myRoot.allVoyageStatuses[219];
	if realStatus &lt;&gt; null and realStatus.description = "Marine Tax Invoice Generated" then
		app.writeLog(method.qualifiedName &amp; " Deleted Voyage Status " &amp; realStatus.description, LogINFO);
		delete realStatus;
	endif;
	// Voyage_Status_IVesselArchived (id was 221, is now 251)
	realStatus := app.myRoot.allVoyageStatuses[221];
	if realStatus &lt;&gt; null and realStatus.description = "Vessel Archived" then
		app.writeLog(method.qualifiedName &amp; " Deleted Voyage Status " &amp; realStatus.description, LogINFO);
		delete realStatus;
	endif;
	// Voyage_Status_IVesselDeparted (id was 220, is now 219)
	realStatus := app.myRoot.allVoyageStatuses[220];
	if realStatus &lt;&gt; null and realStatus.description = "Vessel Departed" then
		app.writeLog(method.qualifiedName &amp; " Deleted Voyage Status " &amp; realStatus.description, LogINFO);
		delete realStatus;
	endif;
	// check if any statuses need their voyage process key reset (error in initial declaration of allStatusesById collection)
	foreach realProcess in app.myRoot.allVoyageProcesses where realProcess.allStatuses.size &lt;&gt; realProcess.allStatusesById.size do
		foreach realStatus in realProcess.allStatuses do
			realStatus.setPropertyValue(CM_VoyageStatus::myProcess.name, null);
			realStatus.setPropertyValue(CM_VoyageStatus::myProcess.name, realProcess);
		endforeach;
	endforeach;
	
	// create the default voyage process and its statuses
	app.myUtilityUA.utlUpdateVoyageProcDefault(_passport);
	if not app.myPassport.noErrors then
		return;
	endif;
	
	// create the work order voyage process and its statuses
	app.myUtilityUA.utlUpdateVoyageProcWO(_passport);
	if not app.myPassport.noErrors then
		return;
	endif;
	
	// create the EUP Default voyage process and its statuses
	app.myUtilityUA.utlUpdateVoyageProcEUP();
	if not app.myPassport.noErrors then
		return;
	endif;
	
	//20/06/2024	navkc1 CR 64611 Task 64623
	app.myUtilityUA.utlUpdateVoyageProcAuto(_passport);
	if not app.myPassport.noErrors() then
		return;
	endif;
	
epilog
	self.finaliseActivityWithPassport(_passport);
end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
