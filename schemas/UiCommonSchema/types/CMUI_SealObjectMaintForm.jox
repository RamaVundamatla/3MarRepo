    <JadeMethod name="doSave" id="329a4c01-5701-402b-86ce-c80140703743">
        <source>doSave():Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
10 March 2015	cnwndl1	Initial creation	Par 
18 May 2016		cnwns1	TFS 488 - Multi Timezone Support
06 April 2023	jlizm1	TFS 57098 EUP Seal numbers on trucks
01 Mar 2024 	navhl20 ChangeRequest 62705: EUP | Ship Operations in DD - [54176.070] - [Road] Retrospective Operations Remedial
*/

vars

	sealType : CM_SealType;
	sealValue : String;
	sealDate : Date;
	sealTime : Time;
	localSealTS,
	sealTimeStamp : TimeStamp;
	msg : String;
	index : Integer;
	strValue : String;

begin

	if self.cmbTypes.listObject = null then
		msg := app.getErrorString(Please_select_seal_type);
		app.msgBox( msg, app.getErrorString(Error), MsgBox_OK_Only );
		return false;
	endif;
	sealType := self.cmbTypes.listObject.CM_SealType;
	
	if sealType &lt;&gt; null and sealType.allowMultipleSealNums then	//30 Jul 2015	NDL	Par 36658
		foreach index in 2 to self.tblValues.rows do
			strValue := self.tblValues.getCellText(index,1).trimBlanks;
			if strValue &lt;&gt; null then
				if sealValue &lt;&gt; null then
					sealValue := sealValue &amp; ",";
				endif;
				sealValue := sealValue &amp; strValue;
			endif;
		endforeach;
	else
		sealValue := self.txtValues.text.trimBlanks;
	endif;
			
	sealDate := self.txtSealDate.getDate;
	if not sealDate.isValid then
		msg := app.getErrorString(Invalid_seal_date);
		app.msgBox( msg, app.getErrorString(Error), MsgBox_OK_Only );
		return false;
	endif;
	
	sealTime := self.txtSealTime.getTime;
	localSealTS.setDate( sealDate );						// 18 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	localSealTS.setTime( sealTime );						// 18 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	sealTimeStamp := self.localToSystemTime(localSealTS);	// 18 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	
	if self.retrospectiveDT.isValid and self.retrospectiveDT &gt; sealTimeStamp then		//01.03.2024 navhl20 #62705
		msg := app.getErrorString(Seal_date_time_shoul_after_ret);
		app.msgBox( msg, app.getErrorString(Error), MsgBox_OK_Only );
		return false;
	endif;
	
	if self.mySealedObject.isKindOf( CM_Wagon ) then
		return self.doSaveWagonSeal(sealType, sealValue, sealTimeStamp);
	elseif self.mySealedObject.isKindOf(CM_VehicleVisitRecord) then
		return self.doSaveTruckSeal(sealType, sealValue, sealTimeStamp);
	endif;
	
	return false;

epilog
	
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doSaveTruckSeal" id="01aa82f7-1d30-4c3c-8d83-25cc85aa4c65">
        <source>doSaveTruckSeal(_sealType : CM_SealType; _sealValue : String; _sealTimeStamp : TimeStamp) : Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
06 April 2023		jlizm1	Initial creation TFS 57098 EUP Seal numbers on trucks
20 Feb 2024 navhl20 ChangeRequest 62525: EUP | Retrospective Operations - [54177.060] - Cargo &amp; Truck Checks
*/

vars
	load			: Boolean;
	result 			: Integer;
	pxySealObject 	: CM_TruckSeal;
	realSealObject 	: CM_TruckSeal;
	previousValue 	: String;
	msg 			: String;
	sealTimeStamp 	: TimeStamp;
	
begin

	if not self.mySealedObject.isKindOf(CM_VehicleVisitRecord) then
		return false;
	endif;
	
	realSealObject := self.mySealedObject.CM_VehicleVisitRecord.allTruckSeals.getTruckSeal(_sealType);
	
	if realSealObject &lt;&gt; null then
		app.cmsBeginLoad(load);
		pxySealObject := realSealObject.pxyCreateUpdateProxy();
		app.cmsEndLoad(load);
		previousValue := realSealObject.getSealValueAsString.trimBlanks;
		if _sealValue &lt;&gt; previousValue then
			pxySealObject.setPreviousSeal(_sealType, previousValue);
		endif;
		pxySealObject.setMyVehicleVisit(self.mySealedObject.CM_VehicleVisitRecord);
		
	else
		if _sealValue = null then
			msg := app.getErrorString(Seal_value_entered_seal);
			app.msgBox( msg, app.getErrorString(Error), MsgBox_OK_Only);
			return false;
		endif;
		
		create pxySealObject as CM_TruckSeal transient;
		pxySealObject.setSealType(_sealType.sealType);
		pxySealObject.setMyVehicleVisit(self.mySealedObject.CM_VehicleVisitRecord);
		
	endif;
	
	pxySealObject.setSealValue(_sealType,_sealValue);
	pxySealObject.setSealedDT(_sealTimeStamp);					//20.02.2024 navhl20 #62525
	
	while true do
	
		app.myTrxUA.trxUpdateTruckSeal(pxySealObject, realSealObject, app.myPassport);
		
		if app.myPassport.trxCompletedOK then
			return true;
		else
			result := app.showErrorWarningDialog(app.getErrorString(Wagon_seals_update), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and result = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			return false;
		endif;
		
	endwhile;
	
epilog
	app.cmsEndLoad(load);
	delete pxySealObject;
	
end;</source>
        <Parameter name="_sealType" type="CM_SealType"/>
        <Parameter name="_sealValue" type="String"/>
        <Parameter name="_sealTimeStamp" type="TimeStamp"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doSaveWagonSeal" id="dee420cb-bf03-42d1-a802-c343bffcf10d">
        <source>doSaveWagonSeal(_sealType : CM_SealType; _sealValue : String; _sealTimeStamp : TimeStamp) : Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
06 April 2023		jlizm1	Initial creation TFS 57098 EUP Seal numbers on trucks

*/

vars
	load			: Boolean;
	result 			: Integer;
	pxySealObject 	: CM_WagonSeal;
	realSealObject 	: CM_WagonSeal;
	previousValue 	: String;
	msg 			: String;
	sealTimeStamp 	: TimeStamp;
	
begin

	if not self.mySealedObject.isKindOf(CM_Wagon) then
		return false;
	endif;

	realSealObject := self.mySealedObject.CM_Wagon.allWagonSeals.getWagonSeal( _sealType );
	if realSealObject &lt;&gt; null then
		app.cmsBeginLoad(load);
		pxySealObject := realSealObject.pxyCreateUpdateProxy();
		app.cmsEndLoad(load);
		previousValue := realSealObject.getSealValueAsString.trimBlanks;
		if _sealValue &lt;&gt; previousValue then
			pxySealObject.setPreviousSeal( _sealType, previousValue );
		endif;
		pxySealObject.setMyWagonVisit( self.mySealedObject.CM_Wagon );
	else
		if _sealValue = null then
			msg := app.getErrorString(Seal_value_entered_seal);
			app.msgBox( msg, app.getErrorString(Error), MsgBox_OK_Only );
			return false;
		endif;
		create pxySealObject as CM_WagonSeal transient;
		pxySealObject.setSealType(_sealType.sealType);
		pxySealObject.setMyWagonVisit( self.mySealedObject.CM_Wagon );
	endif;
	
	pxySealObject.setSealValue(_sealType,_sealValue);
	pxySealObject.setSealedDT(sealTimeStamp);
	
	while true do
	
		app.myTrxUA.trxUpdateWagonSeal(pxySealObject, realSealObject, app.myPassport);
		
		if app.myPassport.trxCompletedOK then
			return true;
		else
			result := app.showErrorWarningDialog(app.getErrorString(Wagon_seals_update), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and result = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			return false;
		endif;
		
	endwhile;
		
epilog

	app.cmsEndLoad(load);
	delete pxySealObject;
	
end;</source>
        <Parameter name="_sealType" type="CM_SealType"/>
        <Parameter name="_sealValue" type="String"/>
        <Parameter name="_sealTimeStamp" type="TimeStamp"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="loadTblSeals" id="9aac7a0d-0716-4220-82d5-bd5a61c4aa3e">
        <updating/>
        <source>loadTblSeals() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
10 March 2015	cnwndl1	Initial creation
18 May 2016		cnwns1	TFS 488 - Multi Timezone Support
06 April 2023	jlizm1	TFS 57098 EUP Seal numbers on trucks
*/

vars

	headings : String;
	sealObj : CM_SealObject;
	sealType : CM_SealType;
	sealTypeDict : CM_SealTypeSet;
	rowIndex : Integer;

begin

	self.tblSeals.rows := 1;
	self.tblSeals.fixedRows := 1;
	self.tblSeals.columns := 3;
	self.tblSeals.fixedColumns := 1;
	
	headings := app.getErrorString(Seal_type) &amp; Tab &amp; app.getErrorString(Seal_number) &amp; Tab &amp; app.getErrorString(Sealed_date);
	
	self.tblSeals.setCellText(1,1,headings);
	
	create sealTypeDict transient;
	
	if self.mySealedObject.isKindOf( CM_Wagon ) then
	
		self.mySealedObject.CM_Wagon.getSelectableSealTypes( sealTypeDict );
		foreach sealType in sealTypeDict do
			sealObj := self.mySealedObject.CM_Wagon.allWagonSeals.getWagonSeal( sealType );
			if sealObj = null then
				rowIndex := self.tblSeals.addItem( sealType.sealType &amp; Tab &amp; " " &amp; Tab &amp; " " );
				self.tblSeals.accessRow(rowIndex).itemObject := sealType;
			else
				rowIndex := self.tblSeals.addItem( sealType.sealType &amp; Tab &amp; sealObj.getSealValueAsString &amp; Tab &amp; self.systemToLocalTime(sealObj.sealedDT).asStringJMT );// 18 May 2016	cnwns1	TFS 488 - Multi Timezone Support
				self.tblSeals.accessRow(rowIndex).itemObject := sealObj;
			endif;
		endforeach;
	
	elseif self.mySealedObject.isKindOf(CM_VehicleVisitRecord) then
			
		foreach sealType in app.myRoot.allTruckSealTypes do
			if sealType.notAvailableForEntry then
				continue;
			endif;

			sealObj := self.mySealedObject.CM_VehicleVisitRecord.allTruckSeals.getTruckSeal(sealType);
			if sealObj = null then
				rowIndex := self.tblSeals.addItem( sealType.sealType &amp; Tab &amp; " " &amp; Tab &amp; " " );
				self.tblSeals.accessRow(rowIndex).itemObject := sealType;
			else
				rowIndex := self.tblSeals.addItem( sealType.sealType &amp; Tab &amp; sealObj.getSealValueAsString &amp; Tab &amp; self.systemToLocalTime(sealObj.sealedDT).asStringJMT );
				self.tblSeals.accessRow(rowIndex).itemObject := sealObj;
			endif;
		endforeach;
	endif;
	
	self.selectItem( 0 );
	
epilog

	delete sealTypeDict;

end;</source>
    </JadeMethod>
    <JadeMethod name="populateForm" id="f164dc07-3114-4890-864a-f57e76887ee5">
        <updating/>
        <source>populateForm() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
10 March 2015		cnwndl1	Initial creation	Par 35828
06 April 2023		jlizm1	TFS 57098 EUP Seal numbers on trucks

*/

vars

	sealType : CM_SealType;
	index : Integer;
	allSealTypes : CM_SealTypeSet;

begin

	self.setCaption( app.getErrorString(Seals_maintenance) );
	
	self.loadTblSeals();

	if self.mySealedObject.isKindOf( CM_Wagon ) then
		self.lblMainObj.caption := app.getErrorString1( SealsFor, self.mySealedObject.CM_Wagon.id );
		self.cmbTypes.clear();
		self.cmbTypes.addItem(" ");
		create allSealTypes transient;
		self.mySealedObject.CM_Wagon.getSelectableSealTypes( allSealTypes );
		foreach sealType in allSealTypes do
			index := self.cmbTypes.addItem(sealType.description);
			self.cmbTypes.itemObject[ index ] := sealType;
		endforeach;
	
	elseif self.mySealedObject.isKindOf(CM_VehicleVisitRecord) then
		self.lblMainObj.caption := app.getErrorString1( SealsFor, self.mySealedObject.CM_VehicleVisitRecord.regNumber );
		self.cmbTypes.clear();
		self.cmbTypes.addItem(" ");
		
		foreach sealType in app.myRoot.allTruckSealTypes do
			if sealType.notAvailableForEntry then
				continue;
			endif;
			index := self.cmbTypes.addItem(sealType.description);
			self.cmbTypes.itemObject[ index ] := sealType;
		endforeach;
	endif;
	
epilog

	delete allSealTypes;

end;</source>
    </JadeMethod>
    <JadeMethod name="selectItem" id="a5426651-1332-4f8d-bfad-42b8914e2340">
        <updating/>
        <source>selectItem( _row : Integer) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 March 2015	cnwndl1	Initial creation
// 18 May 2016	cnwns1	TFS 488 - Multi Timezone Support
20 Feb 2024 navhl20 ChangeRequest 62525: EUP | Retrospective Operations - [54177.060] - Cargo &amp; Truck Checks
*/

vars

	selectedItem : CM_Object;
	sealType : CM_SealType;
	localSealedDT,
	now : TimeStamp;

begin

	self.txtPrevValue.visible := false;
	self.lblPrevValue.visible := false;
	self.setForMultiSealValues( false );	//30 Jul 2015	NDL	Par 36658

	if _row = 0 then
		self.lblAction.caption := app.getErrorString(Please_select_line_table_above);
		self.cmbTypes.listIndex := -1;
		self.displaySealValues(null);	//30 Jul 2015	NDL	Par 36658
		self.txtSealDate.setDate(null);
		self.txtSealTime.setTime(null);
		self.txtPrevValue.text := null;
		
	else
		selectedItem := self.tblSeals.accessRow(_row).itemObject.CM_Object;
		if selectedItem.isKindOf( CM_SealObject ) then
			self.lblAction.caption := app.getErrorString(Update);
			sealType := selectedItem.CM_SealObject.getMySealTypeObj;
			self.displaySealValues(selectedItem.CM_SealObject);	//30 Jul 2015	NDL	Par 36658
			localSealedDT := self.systemToLocalTime(selectedItem.CM_SealObject.sealedDT);// 18 May 2016	cnwns1	TFS 488 - Multi Timezone Support
			self.txtSealDate.setDate(localSealedDT.Date);								// 18 May 2016	cnwns1	TFS 488 - Multi Timezone Support
			self.txtSealTime.setTime(localSealedDT.Time);								// 18 May 2016	cnwns1	TFS 488 - Multi Timezone Support
			if sealType.savePreviousSeal then
				self.txtPrevValue.visible := true;
				self.lblPrevValue.visible := true;
				self.txtPrevValue.text := selectedItem.CM_SealObject.previousSeal;
			else
				self.txtPrevValue.text := null;
			endif;
			
		elseif selectedItem.isKindOf( CM_SealType ) then
			now := self.systemToLocalTime(app.actualTimeServer());// 18 May 2016	cnwns1	TFS 488 - Multi Timezone Support
			self.lblAction.caption := app.getErrorString(Add);
			sealType := selectedItem.CM_SealType;
			self.displaySealValues(null);	//30 Jul 2015	NDL	Par 36658
			if self.retrospectiveDT.isValid then					//20.02.2024 navhl20 #62525
				self.txtSealDate.setDate(self.retrospectiveDT.Date);
				self.txtSealTime.setTime(self.retrospectiveDT.Time);
			else
				self.txtSealDate.setDate(now.Date);
				self.txtSealTime.setTime(now.Time);
			endif;
			self.txtPrevValue.text := null;
			
		endif;
		self.cmbTypes.listIndex := self.cmbTypes.findObject( sealType );
		
		//30 Jul 2015	NDL	Par 36658
		if sealType &lt;&gt; null and sealType.allowMultipleSealNums then
			self.setForMultiSealValues( true );	//30 Jul 2015	NDL	Par 36658
			self.tblValues.setFocus();
		else
			self.txtValues.setFocus();
		endif;
		
	endif;

epilog

end;</source>
        <Parameter name="_row" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setForMultiSealValues" id="21fe5561-e797-4caa-a048-3bc1c8732b5b">
        <updating/>
        <source>setForMultiSealValues( _multi : Boolean ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 July 2015	cnwndl1	Initial creation	Par 36658

*/

vars

begin

	if _multi then
		self.height := 482;
		self.grpMain.height := 444;
		self.lblSealValues.caption := app.getErrorString(Seal_values);
		self.tblValues.visible := true;
		self.txtValues.visible := false;
		
	else
		self.tblValues.visible := false;
		self.txtValues.visible := true;
		self.height := 402;
		self.grpMain.height := 364;
		self.lblSealValues.caption := app.getErrorString(Seal_value);
	
	endif;

epilog

end;</source>
        <Parameter name="_multi" type="Boolean"/>
    </JadeMethod>
