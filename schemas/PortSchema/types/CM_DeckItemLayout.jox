    <JadeMethod name="isResizeable" id="998e0b18-c1ab-4992-b288-8bc47ae25dcd">
        <source>isResizeable() : Boolean;
// ---------------------------------------------------------------------------
// Created:     15 August 2011 by cnwab1 PAR 28013
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin
	if not self.myDeckLayer.myDeckLayout.myDeck.isVoyageDeck() then
		// 28763 Dec 2011 vessel definition, RORO containers are not resizable
		if self.myDeckItem &lt;&gt; null and
		   self.myDeckItem.isKindOf(CM_ROROLocnDefn) then
			return false;
		endif;
		return true;
	endif;
	if self.isPillar()  then
		return false;
	endif;

	if self.myDeckItem = null then
		return true;
	endif;
	
	if self.myDeckItem.isKindOf(CM_ROROLaneDefnVoyage) then
		return false;
	endif;

	if self.myDeckItem.isKindOf(CM_ROROLocnDefn) then
		return false;
	endif;
	
	
	return true;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
