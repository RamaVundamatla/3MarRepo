    <JadeMethod name="tAddSealOperatorConfig" id="dd4bca77-291b-4879-8365-2125cc4c8e34">
        <source>tAddSealOperatorConfig();
// cnwndl1
//26 August 2010	cnwml2


vars
	operator 	: CM_Operator;
begin
	operator := app.myRoot.allOperators["UTOP"];
	self.addSealOperatorConfig(operator, 
								SEAL_CHECK_STRICT, 						//ship Receival
								SEAL_CHECK_FULL, 						//ship Release
								SEAL_CHECK_VIEW, 						//rail Receival
								SEAL_CHECK_NONE, 						//rail Release
								SEAL_CHECK_DEFAULT, 						//road Receival
								SEAL_CHECK_STRICT);						//rail Release
	
	self.assertEqual(operator.sealCheckShipReceival, SEAL_CHECK_STRICT);
	self.assertEqual(operator.sealCheckShipRelease, SEAL_CHECK_FULL);
	self.assertEqual(operator.sealCheckRailReceival,SEAL_CHECK_VIEW);
	self.assertEqual(operator.sealCheckRailRelease, SEAL_CHECK_NONE);
	self.assertEqual(operator.sealCheckRoadReceival, SEAL_CHECK_DEFAULT);
	self.assertEqual(operator.sealCheckRoadRelease, SEAL_CHECK_STRICT);


	
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="tAddSealTI" id="2f8bde6c-fcc0-472d-86e2-4e1f23fb04ab">
        <source>tAddSealTI();
// cnwndl1
//20 August 2010	cnwml2
/* Changes

Date		Name	TFS#		Description
============================================================================
20 Aug 2010	cnwml2 	PAR23715 
					SFW CCMS1131
29 Mar 2019 jlgka1	TFS 44020	Change StringArray to HugeStringArray.
============================================================================*/
vars

	sealType	: CM_SealType;
	cargoType	: CM_CargoType;
	sealTI 	 	: CM_SealTI;
	trackedItem	: CM_TrackedItem;
	strArray 	: HugeStringArray; //jlgka1 TFS 44020
begin	
	self.deleteSealType("MATSEAL", true);
	sealType := self.addSealType("MATSEAL", "UT_Matt Seal", "CONT", true, false, false);
	assertNotNull(sealType);
	assertEqual(sealType.sealType, "MATSEAL");
	assertEqual(sealType.description, "UT_Matt Seal");
	assertTrue(sealType.allowMultipleSealNums);
	assertFalse(sealType.showSealOnCheck);
	cargoType := self.getCargoType("CONT");
	assertEqual(sealType.allCargoTypes.size, 1);
	assertEqual(sealType.allCargoTypes.first, cargoType);
	
	self.deleteContainer("UT_MAT001");
	trackedItem := self.addContainer("UT_MAT001", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString),"2200","MT",TI_IMEX_STATUS_STORAGE);
	
	create strArray transient;
	strArray.add("111");
	strArray.add("222");
	strArray.add("333");
	
	self.addSealTI(strArray, trackedItem, sealType.sealType);
	
	assertEqual(trackedItem.allSeals.size, 1);
	assertEqual(trackedItem.allSeals.first.CM_SealTI.allSealNums.size, 3);
	assertEqual(trackedItem.allSeals.first.CM_SealTI.myTrackedItem, trackedItem);
	assertEqual(trackedItem.allSeals.first.CM_SealTI.sealType, sealType.sealType);

epilog
	delete strArray;
end;</source>
    </JadeMethod>
    <JadeMethod name="tAddSealTIGC" id="51fc52d4-3d9d-409e-9ec2-642da8a3b6ff">
        <source>tAddSealTIGC();
// cnwndl1
/* Changes

Date		Name	TFS#		Description
============================================================================
20 Aug 2010	cnwml2 	PAR23715 
					SFW CCMS1131
29 Mar 2019 jlgka1	TFS 44020	Change StringArray to HugeStringArray.					
============================================================================*/
vars

	sealType	: CM_SealType;
	cargoType	: CM_CargoType;
	sealTI 		: CM_SealTI;
	trackedItem	: CM_TrackedItem;
	strArray 	: HugeStringArray;			// jlgka1 TFS 44020
	bs			: CM_BlockStack;			// 25/01/2017 cnwmh5
begin

	// 25/01/2017 cnwmh5 create bs
	bs := self.addBlockStack("SATGC1", 99, null);
	self.assertNotNull(bs);
	
	self.deleteSealType("MATCANNON", true);
	sealType := self.addSealType("MATCANNON", "UT_Matt Cannon Seal", "CANNON", true, false, false);
	assertNotNull(sealType);
	assertEqual(sealType.sealType, "MATCANNON");
	assertEqual(sealType.description, "UT_Matt Cannon Seal");
	assertTrue(sealType.allowMultipleSealNums);
	assertFalse(sealType.showSealOnCheck);
	cargoType := self.getCargoType("CANNON");
	assertEqual(sealType.allCargoTypes.size, 1);
	assertEqual(sealType.allCargoTypes.first, cargoType);
	
	self.deleteCargo("UT_MAT001", cargoType);		// 13/05/2011 cnwmh5
	trackedItem := self.createTrackedItem("UT_MAT001", cargoType.id, null, self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString),  false, 
		bs.myLocationsController);
	
	create strArray transient;
	strArray.add("111");
	strArray.add("222");
	strArray.add("333");
	
	self.addSealTI(strArray, trackedItem, sealType.sealType);
	
	assertEqual(trackedItem.allSeals.size, 1);
	assertEqual(trackedItem.allSeals.first.CM_SealTI.allSealNums.size, 3);
	assertEqual(trackedItem.allSeals.first.CM_SealTI.myTrackedItem, trackedItem);
	assertEqual(trackedItem.allSeals.first.CM_SealTI.sealType, sealType.sealType);

epilog
	delete strArray;
end;</source>
        <text>&lt;?xml version="1.0"?&gt;
&lt;UT_Additional&gt;
  &lt;Categories&gt;
    &lt;Category CanDelete="true"&gt;CreateTrackedItemFixed&lt;/Category&gt;
  &lt;/Categories&gt;
&lt;/UT_Additional&gt;</text>
    </JadeMethod>
    <JadeMethod name="tAddSealTerminalConfig" id="caccd4f7-4a36-4b17-95e6-b5417c96ba15">
        <source>tAddSealTerminalConfig();
// cnwndl1
//26 August 2010	cnwml2


vars
	pxyTerminal : CM_Terminal;
	terminal 	: CM_Terminal;
begin
	terminal := self.getTerminal();
	
	self.addSealTerminalConfig(terminal, 
								SEAL_CHECK_STRICT, 						//ship Receival
								SEAL_CHECK_FULL, 						//ship Release
								SEAL_CHECK_VIEW, 						//rail Receival
								SEAL_CHECK_NONE, 						//rail Release
								SEAL_CHECK_DEFAULT, 						//road Receival
								SEAL_CHECK_STRICT,						//rail Release
								SEAL_CHECK_FULL,
								SEAL_CHECK_VIEW,
								SEAL_CHECK_VIEW,
								SEAL_CHECK_VIEW,
								SEAL_CHECK_VIEW,
								SEAL_CHECK_VIEW
								);
	
	self.assertEqual(terminal.sealCheckShipReceival, SEAL_CHECK_STRICT);
	self.assertEqual(terminal.sealCheckShipRelease, SEAL_CHECK_FULL);
	self.assertEqual(terminal.sealCheckRailReceival, SEAL_CHECK_VIEW);
	self.assertEqual(terminal.sealCheckRailRelease, SEAL_CHECK_NONE);
	self.assertEqual(terminal.sealCheckRoadReceival, SEAL_CHECK_DEFAULT);
	self.assertEqual(terminal.sealCheckRoadRelease, SEAL_CHECK_STRICT);
	self.assertEqual(terminal.sealCheckPack, SEAL_CHECK_FULL);
	self.assertEqual(terminal.sealCheckUnpack, SEAL_CHECK_VIEW);
	self.assertEqual(terminal.sealCheckWagonLoad, SEAL_CHECK_VIEW);	// 10 Mar 2015	NDL	Par 35828
	self.assertEqual(terminal.sealCheckWagonDischarge, SEAL_CHECK_VIEW);	// 10 Mar 2015	NDL	Par 35828
	self.assertEqual(terminal.sealCheckTruckLoad, SEAL_CHECK_VIEW);
	self.assertEqual(terminal.sealCheckTruckDischarge, SEAL_CHECK_VIEW);


	
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="tAddSealTruck" id="3cd1f27f-7af5-4622-a16f-91298280a56e">
        <source>tAddSealTruck();
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
12 April 2023		jlizm1	Initial creation TFS 57098 EUP Seal numbers on trucks
02 Apr 2025			navah1	Story 34454: MTN - Deferred Updates For Event - For Create And Update Truck Seals
*/

constants
	TRUCKSEALTYPE	: String = "UT_TRUCK";
	TI_ID			: String = "UCAN1000";
	
vars
	sealType		: CM_SealType;
	vvr				: CM_VehicleVisitRecord;
	vvrd			: CM_VehicleVisitRecordDetail;
	truckName		: String;
	driverName		: String;
	bookingRef		: String;
	yic 			: CM_YardInterchangeArea;
	ti 				: CM_TrackedItem;
	operator 		: CM_Operator;
	dualGate 		: CM_Gate;
	pin 			: CM_GateArea;
	pxySealObject 	: CM_TruckSeal;
	realSealObject	: CM_TruckSeal;
	pxySealCheckDetail	: CM_SealCheckDetail;
	pxySealCheckDetails : CM_SealCheckDetailSet;
	eventTrans		: CM_EventTransaction; //02.04.2025 navah1 #34454
	sealTrans		: CM_EventTransaction; //02.04.2025 navah1 #34454
begin
	// Get base data
	operator := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);
	dualGate := self.getGate(self.getProfileSetting(UT_Profile.P_DGATE).asString);
	pin := self.getPGate(self.getProfileSetting(UT_Profile.P_DGATE_PIN).asString);
	yic := self.getTerminalArea(self.getProfileSetting(UT_Profile.P_YIC).asString).CM_YardInterchangeArea;
	truckName := getTruckName();
	driverName := getDriverName();
	
	// Clean up any old data
	self.deleteVehicle(truckName);
	self.deleteCargo(TI_ID, "CANNON");
	self.deleteSealType(TRUCKSEALTYPE, true);
	
	// Create Truck seal type
	sealType := self.addSealType(TRUCKSEALTYPE, "UT_TRUCK Seal", null, true, false, true);
	assertNotNull(sealType);
	
	// Gate in a truck
	vvr := gateInGC(truckName, "", driverName, TI_ID, "CANNON", operator.code, "", dualGate, 1);
	ti := self.getTrackedItem(TI_ID);
	assertNotNull(ti);
	assertNotNull(ti.getPrimaryLocation(QUEUE_MODE));
	
	// Move truck to yard and unload cargo to complete road job
	self.moveVehicleToLane(vvr.vehicle, pin, 1);
	self.assertEqual(vvr.vehicle.myPrimaryActualLocation, self.getGateLane(pin, 1));
	self.moveVehicleToYard(vvr.vehicle);
	self.moveCargo(ti, null, ti.getPrimaryLocation(QUEUE_MODE), app.myPassport);
	
	// Register Seal number to the truck
	create pxySealObject transient;
	pxySealObject.setSealType(TRUCKSEALTYPE);
	pxySealObject.setMyVehicleVisit(vvr);
	pxySealObject.setSealValue(sealType, "TruckSeal1");
	pxySealObject.setSealedDT(app.actualTimeServer);
	app.myTrxUA.trxUpdateTruckSeal(pxySealObject, realSealObject, app.myPassport);
	self.assertTrueMsg(app.myPassport.trxCompletedOK(), app.myPassport.getAllErrorsWarningsAsString());
	self.assertNotNullMsg(realSealObject, "Seal");
	self.assertEqualMsg(realSealObject.myVehicleVisit, vvr, "vvr not linked to seal");
	
	//02.04.2025 navah1 #34454 - Start
	eventTrans := vvr.allEventTransactions.last.CM_EventTransaction; 
	self.assertTrueMsg(eventTrans.type = EVT_TruckSealAdd, "seal add transaction not created."); 
	sealTrans := self.getTerminal.allEventTransactionsByCamsTS.getAtKey(eventTrans.camsTimeStamp);
	assertNotNullMsg(sealTrans, "Event transaction is not found in terminal EventTransactions dictionary");
	assertTrueMsg(sealTrans = eventTrans, "The event transaction is not the expected one");
	//02.04.2025 navah1 #34454 - End
	
	// Do Seal Check
	create pxySealCheckDetails transient;
	create pxySealCheckDetail transient;
	pxySealCheckDetail.setProxy(null,
								"TruckSeal1",
								realSealObject.getSealValueAsString,
								SEAL_CHECK_STRICT,
								TRUCKSEALTYPE,
								0
								);
								
	pxySealCheckDetails.add(pxySealCheckDetail);
	app.myTrxCA.trxCreateTruckSealCheckTrans(pxySealCheckDetails, vvr, null, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
	//02.04.2025 navah1 #34454 - Start
	eventTrans := vvr.allEventTransactions.last.CM_EventTransaction; 
	self.assertTrueMsg(eventTrans.type = EVT_TruckSealCheck, "seal check transaction not created.");
	sealTrans := self.getTerminal.allEventTransactionsByCamsTS.getAtKey(eventTrans.camsTimeStamp);
	assertNotNullMsg(sealTrans, "Event transaction is not found in terminal EventTransactions dictionary");
	assertTrueMsg(sealTrans = eventTrans, "The event transaction is not the expected one");
	//02.04.2025 navah1 #34454 - End
	
	vvrd := vvr.getLastDetailOfType(VisitRecord_SealCheck);
	self.assertTrueMsg(vvrd &lt;&gt; null, "missing seal check vvr detail");
	
	// Clean up after ourselves
	self.deleteCargo(TI_ID, "CANNON");
	self.deleteSealType(TRUCKSEALTYPE, true);
	
epilog
	delete pxySealObject;
	if pxySealCheckDetails &lt;&gt; null then
		pxySealCheckDetails.purge();
		delete pxySealCheckDetails;
	endif;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="tAddSealType" id="e01c9d34-be0b-4a6c-a182-6e50fa8db1a5">
        <source>tAddSealType();
// cnwndl1
//10 August 2010	cnwdw1	
//
// 12/04/2023	jlizm1	TFS 57098 EUP Seal numbers on trucks
vars
	sealType: CM_SealType;
	cargoType: CM_CargoType;
begin
	
	self.deleteSealType("CANSEAL", true);
	sealType := self.addSealType("CANSEAL", "Cannon Seal", "CANNON", true, false, true);
	assertNotNull(sealType);
	assertEqual(sealType.sealType, "CANSEAL");
	assertEqual(sealType.description, "Cannon Seal");
	assertTrue(sealType.allowMultipleSealNums);
	assertFalse(sealType.showSealOnCheck);
	cargoType := self.getCargoType("CANNON");
	assertTrue(cargoType.allSealTypes.includes(sealType));
	assertTrue(sealType.allCargoTypes.includes(cargoType));

	// Should get error if try to add again
	self.expectTrxError(ERR_SEALTYPE_EXISTS);
	sealType := self.addSealType("CANSEAL", "Cannon Seal", "CANNON", true, false, false);

end;</source>
    </JadeMethod>
    <JadeMethod name="tMSKSealCheck" id="58302771-4896-4d71-b073-9b81cfa26620">
        <source>tMSKSealCheck();
// cnwns1
/*

Purpose:			

Parameters:			

Return Value:		

/* Changes

Date		Name	TFS#		Description
============================================================================
23 Jan 2013	cnwmc5	Initial creation
30 Jan 2015	cnwrs1	Par 35544 - Refactor Cams file storage to string
22 Jan 2016	cnwrs1	37444 Use Cams controller rundate time rathyer than current date time
29 Mar 2019 jlgka1	TFS 44020	Change StringArray to HugeStringArray.
============================================================================*/
constants
	VoyageName		= 'MJCVOYCAMS';				// all upper case!
	BoatName		= 'MJCVESCAMS';
	ContainerName	= 'MJCCONTCAMS';
	TestOperator	= 'MSK';
	CamGroup 		= "MSK_GRP";
	CamProtocol 	= "MSK_Prot";
vars
	runDateTime : TimeStamp;
	lRegisteredCargoTypes : IntegerArray;
	container 				: CM_Container;
	operator 				: CM_Operator;
	vessel 					: CM_Vessel;
	voyage 					: CM_Voyage;
	passport 				: CM_Passport;
	terminal 				: CM_Terminal;
	camGroup 				: CM_CamGroup;
	camProtocol				: CM_CamProtocol;
	camTaskHistory 			: CM_CamTaskHistory;
	operatorDict 			: CM_OperatorByCodeDict;
	emailEntity 			: CM_EmailEntity;
	camProtocolDesc 		: CM_CamProtocolDesc;
	freightForwarders		: CM_ConsigneeConsignorSet;
	allCoarriExportPorts 	: CM_PortByCodeDict;
	emailCopyAddresses 		: CM_EmailEntityByTypeNameDict;
	packOperators 			: CM_OperatorByCodeDict;
	packExportConsignees 	: CM_ConsignByCodeDict;
	camEditTriggerFields 	: CM_CamEditTriggerFieldDict;
	camTrainEventTypes 		: CM_EventTypeByNameDict;
	allPackAreas 			: CM_TAByIdDict;
	transObj 				: CM_TITransaction;
	
	scheduleTimes 			: TimeArray;
	now 					: TimeStamp;
	startDateTime 			: TimeStamp;
	endDateTime 			: TimeStamp;
	
	registeredTransactions 	: StringArray;
	strArray 				: HugeStringArray;
	str 					: String;
	tempStr					: String;
	idx 					: Integer;
	theLines : HugeStringArray;
begin
	create theLines transient;
	startDateTime := app.actualTimeServer;
	passport := app.myPassport;
	operator := self.getOperator(TestOperator);
	self.assertNotNullMsg(operator, 'Failed to get operator ' &amp; TestOperator.display);
	
	// delete required voyages and vessels
	self.deleteVoyage(VoyageName);
	voyage := self.getVoyage(VoyageName);
	self.assertIsDeleted(voyage);
	
	self.deleteVessel(BoatName);
	vessel := self.getVessel(BoatName);
	self.assertIsDeleted(vessel);
	
	// delete the cargo - this should have already been done if on the voyage, but just in case.
	self.deleteContainer(ContainerName);
	container := self.getTrackedItem(ContainerName).CM_Container;
	self.assertIsDeleted(container);

	// Now create the required voyages and vessels
	vessel := self.addVesselCellular(BoatName, operator);
	self.assertNotNullMsg(vessel, 'Add vessel ' &amp; BoatName.display &amp; ' failed');
	
	voyage := self.addVoyageNonPlannedNonWorked(VoyageName,
													BoatName,
													TestOperator, 
													self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString);
	self.assertNotNullMsg(voyage, 'Add voyage ' &amp; VoyageName &amp; ' failed');
	
	
	// PAR 33644 removed the bays as not used, keep the cellular structure object.
	// This test was using the old 'is non planned', but it had bays defined. 
	// In the UI it was not possible to do this, if fact saying is non planned deleted the bays, so I am doing the same for this test.
	// This test was failing because of the PAR 33644 change in CM_VoyageController::getTiTxnTypesForMoveToFromNULL
	// This test wants a ROAD RECEIVE transaction that is only created if the voyage was non planned which actually means it had no bays.
	// Removing the whole celluarStructure would then fail in CM_CamCODECODesc::includeVoyage so need the structure but not the bays.
	beginTransaction;
	voyage.myCellularVoyageStructure.allBayVoyagesById.purge();
	commitTransaction;

	// Add the container to the voyage
	container := self.addContainerForExport(ContainerName,
										operator,
										"2232",					// ISOType is not needed
										"REEF",					// commodity is not needed
										TI_IMEX_STATUS_EXPORT,	// import not export
										null,					// booking id
										voyage.code,
										null,					// dischargePort
										null).CM_Container;			// transhipToPort
	
	create strArray transient;
	strArray.purge();
	strArray.add("MLNZ000000");
	strArray.add("df34edf000");
	strArray.add("NZFSA000000");
	strArray.add("NZMAF000000");
	strArray.add("qweas0000");
	self.addSealTI(strArray, container, SealType_Customs);
	
	strArray.purge();
	strArray.add("VENT001234");
	self.addSealTI(strArray, container, SealType_Vent);
	
	strArray.purge();
	strArray.add("SHIP001234");
	self.addSealTI(strArray, container, SealType_Shipper);
	
	strArray.purge();
	strArray.add("ML-NZ7898678686787");
	self.addSealTI(strArray, container, SealType_Operator);
	
	
	tempStr	:= 'Adding Container ' &amp; ContainerName.display &amp; ' failed.' &amp; CrLf &amp; passport.getAllErrorsWarningsAsString;
	self.assertNotNullMsg(container, tempStr);
	self.assertNotNull(voyage.myShipBlockStack);
	self.move(container, voyage.myShipBlockStack);
	self.deleteCamProtocol(CamProtocol);
	camProtocol := self.getCamProtocol(CamProtocol);
	self.assertIsDeleted(camProtocol);
	
	self.deleteCamGroup(CamGroup);
	camGroup := self.getCamGroup(CamGroup);
	self.assertIsDeleted(camGroup);
	create operatorDict transient;
	create freightForwarders transient;
	operatorDict.add(operator);
	camGroup := self.addCamGroup(CamGroup, CamGroup, "REP", "UT", "NZCHC", "FAC", false, false, false, operatorDict, freightForwarders, 16, "SHIP");
	self.assertNotNull(camGroup);
	
	camProtocol := self.getCamProtocol(CamProtocol);
	self.deleteCamProtocol(CamProtocol);
	self.assertIsDeleted(camProtocol);
	create allCoarriExportPorts transient;
	create emailCopyAddresses transient;
	create packOperators transient;
	create packExportConsignees transient;
	create registeredTransactions transient;
	registeredTransactions.add(global.getTiTxnTypeForClass(CM_ReceiveRoad).asStringJMT);
	create scheduleTimes transient;
	create camEditTriggerFields transient;
	create camTrainEventTypes transient;
	create allPackAreas transient;
	create lRegisteredCargoTypes transient;
	lRegisteredCargoTypes.add(TI_CargoType_Container);
	
	camProtocolDesc := app.myRoot.allCamProtocolDescs["Maersk Codeco"];
	emailEntity := app.myRoot.allEmailEntities[1, "Mr. Testing"];
	camProtocol := self.addCamProtocol(CamProtocol, CamProtocol, allCoarriExportPorts, camGroup, "NZCHC", emailEntity, false, emailCopyAddresses, false, "CamMessage", "CamSubject",
	                                   startDateTime, startDateTime, false, null, "txt", TestOperator, packOperators, packExportConsignees, '', camProtocolDesc, registeredTransactions,
									   false, 1, false, scheduleTimes, false, false, false, false, false, false, false, false, false, false, false, false, 
									   false, false, false, false,  false, false, false, false, false, false, false, false, 
									   0, 0, 0, 0, '', '', '', camEditTriggerFields, camTrainEventTypes, null, false, 0, self.getTerminal, true, true, false, false, false, false, false, false, true, 
									   allPackAreas, null, null, lRegisteredCargoTypes);
	tempStr	:= 'Add failed ' &amp; CrLf &amp; app.myPassport.getAllErrorsWarningsAsString();
	self.assertNotNullMsg(camProtocol, tempStr);
	self.assertNotNull(camProtocol);
	endDateTime := endDateTime.addHours(1);

	self.runCamsAdhoc(startDateTime, endDateTime, runDateTime, camProtocol);
	camTaskHistory := camProtocol.taskHistoryByProtocolSeq.first;
	self.assertNotNull(camTaskHistory);
	//foreach tempStr in camTaskHistory.fileData do
	//	write tempStr;
	//endforeach;
	idx := 0;

	strArray.clear();
	
	strArray.add("UNB+UNOA:");
	strArray.add("UNH+1+CODECO:D:95B:UN:SMDG16'");	
	strArray.add("BGM+34+1+9'");
	strArray.add("TDT+20+"&amp;VoyageName&amp;"+1+++++:146::"&amp;BoatName&amp;"'");
	strArray.add("LOC+9+DUN:139:6'");
	strArray.add("NAD+CF+SHIP:160:20'");
	strArray.add("NAD+SLS+NZCHC:172:20'");
	strArray.add("GID+1'");
	strArray.add("TMP+2+4.0:CEL'");
	strArray.add("SGP+"&amp;ContainerName&amp;"'");
	strArray.add("EQD+CN+"&amp;ContainerName&amp;"+2232:102:5++2+5'");
	strArray.add("DTM+7:");
	strArray.add("LOC+165+DUN:160:20'");
	strArray.add("MEA+AAE+G+KGM:4000'");
	strArray.add("SEL+NZ7898678+CA'");
	strArray.add("SEL+SHIP001234+SH'");	
	strArray.add("SEL+NZFSA000000+CU'");
	strArray.add("CNT+16:1'");
	strArray.add("UNT+18+1'");
	strArray.add("UNZ+1+0'");

	theLines.clear();
	camTaskHistory.rawDataToHSA(theLines);
	foreach tempStr in theLines do
		idx := idx + 1;
		str := strArray[idx];
		self.assertEqual(tempStr[1:str.length], str);
	endforeach;

epilog
	delete strArray;
	delete operatorDict;
	delete freightForwarders;
	delete allCoarriExportPorts;
	delete emailCopyAddresses;
	delete packOperators;
	delete packExportConsignees;
	delete registeredTransactions;
	delete scheduleTimes;
	delete camEditTriggerFields;
	delete camTrainEventTypes;
	delete allPackAreas;
	delete lRegisteredCargoTypes;
	delete theLines;
end;</source>
    </JadeMethod>
    <JadeMethod name="tMSKSealCheckOther" id="21cb7b03-c2cd-41b5-8cda-b15d059aa4a1">
        <source>tMSKSealCheckOther();
// cnwns1
/*

Purpose:			

Parameters:			

Return Value:		
/* Changes

Date		Name	TFS#		Description
============================================================================
16 Sep 2013	cnwmc5				Initial creation
30 Jan 2015	cnwrs1	Par 35544	Refactor Cams file storage to string
22 Jan 2016	cnwrs1	37444 		Use Cams controller rundate time rathyer than current date time
29 Mar 2019 jlgka1	TFS 44020	Change StringArray to HugeStringArray.
============================================================================*/
constants
	VoyageName		= 'MJCVOYCAMS';				// all upper case!
	BoatName		= 'MJCVESCAMS';
	ContainerName	= 'MJCCONTCAMS';
	TestOperator	= 'MSK';
	CamGroup 		= "MSK_GRP";
	CamProtocol 	= "MSK_Prot";
vars
	runDateTime : TimeStamp;
	lRegisteredCargoTypes : IntegerArray;
	container 				: CM_Container;
	operator 				: CM_Operator;
	vessel 					: CM_Vessel;
	voyage 					: CM_Voyage;
	passport 				: CM_Passport;
	terminal 				: CM_Terminal;
	camGroup 				: CM_CamGroup;
	camProtocol				: CM_CamProtocol;
	camTaskHistory 			: CM_CamTaskHistory;
	operatorDict 			: CM_OperatorByCodeDict;
	emailEntity 			: CM_EmailEntity;
	camProtocolDesc 		: CM_CamProtocolDesc;
	freightForwarders		: CM_ConsigneeConsignorSet;
	allCoarriExportPorts 	: CM_PortByCodeDict;
	emailCopyAddresses 		: CM_EmailEntityByTypeNameDict;
	packOperators 			: CM_OperatorByCodeDict;
	packExportConsignees 	: CM_ConsignByCodeDict;
	camEditTriggerFields 	: CM_CamEditTriggerFieldDict;
	camTrainEventTypes 		: CM_EventTypeByNameDict;
	allPackAreas 			: CM_TAByIdDict;
	transObj 				: CM_TITransaction;
	
	scheduleTimes 			: TimeArray;
	now 					: TimeStamp;
	startDateTime 			: TimeStamp;
	endDateTime 			: TimeStamp;
	
	registeredTransactions 	: StringArray;
	strArray 				: HugeStringArray; //jlgka1 TFS 44020
	str 					: String;
	tempStr					: String;
	idx 					: Integer;
	theLines : HugeStringArray;
begin
	create theLines transient;
	startDateTime := app.actualTimeServer;
	passport := app.myPassport;
	operator := self.getOperator(TestOperator);
	self.assertNotNullMsg(operator, 'Failed to get operator ' &amp; TestOperator.display);
	
	// delete required voyages and vessels
	self.deleteVoyage(VoyageName);
	voyage := self.getVoyage(VoyageName);
	self.assertIsDeleted(voyage);
	
	self.deleteVessel(BoatName);
	vessel := self.getVessel(BoatName);
	self.assertIsDeleted(vessel);
	
	// delete the cargo - this should have already been done if on the voyage, but just in case.
	self.deleteContainer(ContainerName);
	container := self.getTrackedItem(ContainerName).CM_Container;
	self.assertIsDeleted(container);

	// Now create the required voyages and vessels
	vessel := self.addVesselCellular(BoatName, operator);
	self.assertNotNullMsg(vessel, 'Add vessel ' &amp; BoatName.display &amp; ' failed');
	
	voyage := self.addVoyageNonPlannedNonWorked(VoyageName,
													BoatName,
													TestOperator, 
													self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString);
	self.assertNotNullMsg(voyage, 'Add voyage ' &amp; VoyageName &amp; ' failed');
	
	// PAR 33644 removed the bays as not used, keep the cellular structure object.
	// This test was using the old 'is non planned', but it had bays defined. 
	// In the UI it was not possible to do this, if fact saying is non planned deleted the bays, so I am doing the same for this test.
	// This test was failing because of the PAR 33644 change in CM_VoyageController::getTiTxnTypesForMoveToFromNULL
	// This test wants a ROAD RECEIVE transaction that is only created if the voyage was non planned which actually means it had no bays.
	// Removing the whole celluarStructure would then fail in CM_CamCODECODesc::includeVoyage so need the structure but not the bays.
	beginTransaction;
	voyage.myCellularVoyageStructure.allBayVoyagesById.purge();
	commitTransaction;

	// Add the container to the voyage
	container := self.addContainerForExport(ContainerName,
										operator,
										"2232",					// ISOType is not needed
										"REEF",					// commodity is not needed
										TI_IMEX_STATUS_EXPORT,	// import not export
										null,					// booking id
										voyage.code,
										null,					// dischargePort
										null).CM_Container;			// transhipToPort
	
	create strArray transient;
	strArray.purge();
	strArray.add("NZMPI00506142");		//cnwmc5 - PAR 32467 - testing for nelson
	self.addSealTI(strArray, container, SealType_Operator);
	
	
	tempStr	:= 'Adding Container ' &amp; ContainerName.display &amp; ' failed.' &amp; CrLf &amp; passport.getAllErrorsWarningsAsString;
	self.assertNotNullMsg(container, tempStr);
	self.assertNotNull(voyage.myShipBlockStack);
	self.move(container, voyage.myShipBlockStack);
	self.deleteCamProtocol(CamProtocol);
	camProtocol := self.getCamProtocol(CamProtocol);
	self.assertIsDeleted(camProtocol);
	
	self.deleteCamGroup(CamGroup);
	camGroup := self.getCamGroup(CamGroup);
	self.assertIsDeleted(camGroup);
	create operatorDict transient;
	create freightForwarders transient;
	operatorDict.add(operator);
	camGroup := self.addCamGroup(CamGroup, CamGroup, "REP", "UT", "NZCHC", "FAC", false, false, false, operatorDict, freightForwarders, 16, "SHIP");
	self.assertNotNull(camGroup);
	
	camProtocol := self.getCamProtocol(CamProtocol);
	self.deleteCamProtocol(CamProtocol);
	self.assertIsDeleted(camProtocol);
	create allCoarriExportPorts transient;
	create emailCopyAddresses transient;
	create packOperators transient;
	create packExportConsignees transient;
	create registeredTransactions transient;
	registeredTransactions.add(global.getTiTxnTypeForClass(CM_ReceiveRoad).asStringJMT);
	create scheduleTimes transient;
	create camEditTriggerFields transient;
	create camTrainEventTypes transient;
	create allPackAreas transient;
	create lRegisteredCargoTypes transient;
	lRegisteredCargoTypes.add(TI_CargoType_Container);
	
	camProtocolDesc := app.myRoot.allCamProtocolDescs["Maersk Codeco"];
	emailEntity := app.myRoot.allEmailEntities[1, "Mr. Testing"];
	camProtocol := self.addCamProtocol(CamProtocol, CamProtocol, allCoarriExportPorts, camGroup, "NZCHC", emailEntity, false, emailCopyAddresses, false, "CamMessage", "CamSubject",
	                                   startDateTime, startDateTime, false, null, "txt", TestOperator, packOperators, packExportConsignees, '', camProtocolDesc, registeredTransactions,
									   false, 1, false, scheduleTimes, false, false, false, false, false, false, false, false, false, false, false, false, 
									   false, false, false, false,  false, false, false, false, false, false, false, false, 
									   0, 0, 0, 0, '', '', '', camEditTriggerFields, camTrainEventTypes, null, false, 0, self.getTerminal, true, true, false, false, false, false, false, false, true, 
									   allPackAreas, null, null, lRegisteredCargoTypes);
	tempStr	:= 'Add failed ' &amp; CrLf &amp; app.myPassport.getAllErrorsWarningsAsString();
	self.assertNotNullMsg(camProtocol, tempStr);
	self.assertNotNull(camProtocol);
	endDateTime := endDateTime.addHours(1);

	self.runCamsAdhoc(startDateTime, endDateTime, runDateTime, camProtocol);
	camTaskHistory := camProtocol.taskHistoryByProtocolSeq.first;
	self.assertNotNull(camTaskHistory);
	//foreach tempStr in camTaskHistory.fileData do
	//	write tempStr;
	//endforeach;
	idx := 0;

	strArray.clear();
	
	strArray.add("UNB+UNOA:");
	strArray.add("UNH+1+CODECO:D:95B:UN:SMDG16'");	
	strArray.add("BGM+34+1+9'");
	strArray.add("TDT+20+"&amp;VoyageName&amp;"+1+++++:146::"&amp;BoatName&amp;"'");
	strArray.add("LOC+9+DUN:139:6'");
	strArray.add("NAD+CF+SHIP:160:20'");
	strArray.add("NAD+SLS+NZCHC:172:20'");
	strArray.add("GID+1'");
	strArray.add("TMP+2+4.0:CEL'");
	strArray.add("SGP+"&amp;ContainerName&amp;"'");
	strArray.add("EQD+CN+"&amp;ContainerName&amp;"+2232:102:5++2+5'");
	strArray.add("DTM+7:");
	strArray.add("LOC+165+DUN:160:20'");
	strArray.add("MEA+AAE+G+KGM:4000'");
	strArray.add("SEL+NZMPI00506142+SH");		//cnwmc5 - PAR 32467 - testing for nelson (will need to comment out other SH seal)
	strArray.add("CNT+16:1'");
	strArray.add("UNT+16+1'");
	strArray.add("UNZ+1+0'");

	theLines.clear();
	camTaskHistory.rawDataToHSA(theLines);
	foreach tempStr in theLines do
		idx := idx + 1;
		str := strArray[idx];
		self.assertEqual(tempStr[1:str.length], str);
	endforeach;

epilog
	delete strArray;
	delete operatorDict;
	delete freightForwarders;
	delete allCoarriExportPorts;
	delete emailCopyAddresses;
	delete packOperators;
	delete packExportConsignees;
	delete registeredTransactions;
	delete scheduleTimes;
	delete camEditTriggerFields;
	delete camTrainEventTypes;
	delete allPackAreas;
	delete lRegisteredCargoTypes;
	delete theLines;
end;</source>
    </JadeMethod>
    <JadeMethod name="tSealCheckTransaction" id="0b0fa442-24e5-4b82-8221-f2b5081923e4">
        <source>tSealCheckTransaction();

/*

Purpose:		trxCreateSealCheckTransaction

Date			Who		Reason
23/06/2015		cnwmh5	Initial creation

*/

vars

	ti 							: CM_TrackedItem;
	pxyTI						: CM_TrackedItem;
	txnController				: CMIF_TITransactionController;
	newTITxn					: CM_TITransaction;
	bs							: CM_BlockStack;
	pxySealCheckTrx 			: CM_SealCheck;
	pxySealCheckDetail 			: CM_SealCheckDetail;
	sealType					: CM_SealType;
	
	tiUpdateRequired			: Boolean;
	sealCheckType 				: Integer;
	viewed						: Integer;
	sealBefore 					: String;
	sealAfter 					: String;

begin

	ti := self.getTrackedItem("UTMH0000191");
	self.deleteTrackedItem(ti, false);
	
	bs := self.addBlockStack("UTMHBSO", 10, null);
	self.assertNotNull(bs);
		
	ti := self.addContainerAtLocation("UTMH0000191", app.myRoot.allOperators[self.getProfileSetting(UT_Profile.P_OPERATOR).asString], 
		"UT20", "GENL", TI_IMEX_STATUS_EXPORT, bs);
	self.assertNotNull(ti);

	beginLoad;
	pxyTI := ti.pxyCreateUpdateProxy();
	endLoad;
	
	sealType := app.myRoot.allSealTypes["OPERATOR"];
	self.assertNotNull(sealType);
	
	sealCheckType := SEAL_CHECK_FULL;
	
	create pxySealCheckTrx transient;
	create pxySealCheckDetail transient;
	pxySealCheckDetail.setProxy(	pxySealCheckTrx,	//_sealCheck : CM_SealCheck;
									sealAfter,	//_sealAfter : String;
									sealBefore,	//_sealBefore : String;
									sealCheckType,	//_sealCheckType : Integer;
									sealType.sealType,	//_sealType : String;
									viewed	//_viewed : Integer;
									);
	
	create txnController transient;
	txnController.type := TRANS_TYPE_SEAL_CHECK;
	txnController.noCharge := true;
	txnController.myTrackedItem := ti;
	txnController.myTITransaction := pxySealCheckTrx;
	
	app.myTrxCA.trxCreateSealsCheckTransaction(txnController, pxyTI, tiUpdateRequired, null, newTITxn, null, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
	self.assertTrue(ti.allTransactions.last.isKindOf(CM_SealCheck));

epilog

	delete pxyTI;
	delete pxySealCheckDetail;
	delete pxySealCheckTrx;
	delete txnController;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="tUpdateSealTI" id="04afef1e-9ef1-48e7-b838-9beff4629d8a">
        <source>tUpdateSealTI();
// cnwndl1
/* Changes

Date		Name	TFS#		Description
============================================================================
20 Aug 2010	cnwml2	PAR23715 SFW CCMS1131
29 Mar 2019 jlgka1	TFS 44020	Change StringArray to HugeStringArray.
============================================================================*/
vars
	sealType	: CM_SealType;
	cargoType	: CM_CargoType;
	sealTI 		: CM_SealTI;
	trackedItem	: CM_TrackedItem;
	strArray 	: HugeStringArray;   //jlgka1 TFS 44020
begin	
	self.deleteSealType("MATSEAL", true);
	sealType := self.addSealType("MATSEAL", "UT_Matt Seal", "CONT", true, false, false);
	assertNotNull(sealType);
	assertEqual(sealType.sealType, "MATSEAL");
	assertEqual(sealType.description, "UT_Matt Seal");
	assertTrue(sealType.allowMultipleSealNums);
	assertFalse(sealType.showSealOnCheck);
	cargoType := self.getCargoType("CONT");
	assertEqual(sealType.allCargoTypes.size, 1);
	assertEqual(sealType.allCargoTypes.first, cargoType);
	
	self.deleteContainer("UT_MAT001");
	trackedItem := self.addContainer("UT_MAT001", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString),"2200","MT",TI_IMEX_STATUS_STORAGE);
	
	create strArray transient;
	strArray.add("111");
	strArray.add("222");
	strArray.add("333");
	
	self.addSealTI(strArray, trackedItem, sealType.sealType);
	
	assertEqual(trackedItem.allSeals.size, 1);
	assertEqual(trackedItem.allSeals.first.CM_SealTI.allSealNums.size, 3);
	assertEqual(trackedItem.allSeals.first.CM_SealTI.myTrackedItem, trackedItem);
	assertEqual(trackedItem.allSeals.first.CM_SealTI.sealType, sealType.sealType);
	
	strArray.clear();
	strArray.add("444");
	strArray.add("555");
	
	self.addSealTI(strArray, trackedItem, sealType.sealType);
	assertEqual(trackedItem.allSeals.size, 1);
	assertEqual(trackedItem.allSeals.first.CM_SealTI.allSealNums.size, 2);
	assertEqual(trackedItem.allSeals.first.CM_SealTI.myTrackedItem, trackedItem);
	assertEqual(trackedItem.allSeals.first.CM_SealTI.sealType, sealType.sealType);
	assertEqual(trackedItem.allSeals.first.CM_SealTI.previousSeal, "111, 222, 333");

epilog
	delete strArray;
end;</source>
    </JadeMethod>
    <JadeMethod name="tUpdateSealType" id="e8d12bce-f133-47e5-8617-2c9cac425a67">
        <source>tUpdateSealType();
// cnwndl1
//10 August 2010	cnwdw1	
//
// 12/04/2023	jlizm1	TFS 57098 EUP Seal numbers on trucks
vars
	sealType: CM_SealType;
begin
	
	self.deleteSealType("CANSEAL", true);
	
	sealType := self.addSealType("CANSEAL", "Cannon Seal", "CANNON", true, false, false);
	assertNotNull(sealType);
	
	self.updateSealType(sealType, "CANSEAL", "Cannon Sealxx", "CANNON", false, true, true);
	assertEqual(sealType.sealType, "CANSEAL");
	assertEqual(sealType.description, "Cannon Sealxx");
	assertFalse(sealType.allowMultipleSealNums);
	assertTrue(sealType.showSealOnCheck);
	
	self.expectTrxError(ERR_CANNOT_RENAME);
	self.updateSealType(sealType, "CANSEALX", "Cannon Sealxx", "CANNON", false, true, false);
	self.assertNoTrxErrorsOrWarnings();	

end;</source>
    </JadeMethod>
    <JadeMethod name="tUpdateSeallTIGC" id="e82519e1-fe55-41de-9a5a-93161eb9e6e1">
        <source>tUpdateSeallTIGC();
// cnwndl1
//20 August 2010	cnwml2
//+cnwml2 PAR23715 SFW CCMS1131
/* Changes

Date		Name	TFS#		Description
============================================================================
29 Mar 2019 jlgka1	TFS 44020	Change StringArray to HugeStringArray.
============================================================================*/

vars
	sealType	: CM_SealType;
	cargoType	: CM_CargoType;
	sealTI 		: CM_SealTI;
	trackedItem	: CM_TrackedItem;
	strArray 	: HugeStringArray;			// jlgka1 TFS 44020
	blockStack	: CM_BlockStack;			// 25/01/2017 cnwmh5
begin
	// 25/01/2017 cnwmh5 create bs
	blockStack := self.addBlockStack("SUTG1", 99, null);
	self.assertNotNull(blockStack);

	self.deleteSealType("MATCANNON", true);
	sealType := self.addSealType("MATCANNON", "UT_Matt Cannon Seal", "CANNON", true, false, false);
	assertNotNull(sealType);
	assertEqual(sealType.sealType, "MATCANNON");
	assertEqual(sealType.description, "UT_Matt Cannon Seal");
	assertTrue(sealType.allowMultipleSealNums);
	assertFalse(sealType.showSealOnCheck);
	cargoType := self.getCargoType("CANNON");
	assertEqual(sealType.allCargoTypes.size, 1);
	assertEqual(sealType.allCargoTypes.first, cargoType);
	
	self.deleteCargo("UT_MAT001", cargoType);		// 13/05/2011 cnwmh5
	trackedItem := self.createTrackedItem("UT_MAT001", cargoType.id, null, self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString),  false, 
		blockStack.myLocationsController);
	
	create strArray transient;
	strArray.add("111");
	strArray.add("222");
	strArray.add("333");
	
	self.addSealTI(strArray, trackedItem, sealType.sealType);
	
	assertEqual(trackedItem.allSeals.size, 1);
	assertEqual(trackedItem.allSeals.first.CM_SealTI.allSealNums.size, 3);
	assertEqual(trackedItem.allSeals.first.CM_SealTI.myTrackedItem, trackedItem);
	assertEqual(trackedItem.allSeals.first.CM_SealTI.sealType, sealType.sealType);
	
	strArray.clear();
	strArray.add("444");
	strArray.add("555");
	
	self.addSealTI(strArray, trackedItem, sealType.sealType);

	assertEqual(trackedItem.allSeals.size, 1);
	assertEqual(trackedItem.allSeals.first.CM_SealTI.allSealNums.size, 2);
	assertEqual(trackedItem.allSeals.first.CM_SealTI.myTrackedItem, trackedItem);
	assertEqual(trackedItem.allSeals.first.CM_SealTI.sealType, sealType.sealType);
	assertEqual(trackedItem.allSeals.first.CM_SealTI.previousSeal, "111, 222, 333");

epilog
	delete strArray;
end;</source>
        <text>&lt;?xml version="1.0"?&gt;
