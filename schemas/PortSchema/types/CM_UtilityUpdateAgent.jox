    <JadeMethod name="utlUpdateTower" id="b3e39b8f-7693-46ca-836c-842a0c7fe1dc">
        <source>utlUpdateTower(pProxyTower:CM_Tower input; _tiRemarksNext,_tiRemarksPrev : String;_passport : CM_Passport input);
// ---------------------------------------------------------------------------
// Created:     16 July 2001 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	cancelSave:Boolean;
	realTower:CM_Tower;
	expectedEdition:Integer;
	proxyContainer : CM_TrackedItem;
	reallContainer : CM_Container;
	tiUpdateCntrl : CMIF_TIUpdateController;
begin

	self.initialiseActivity();

	pProxyTower.raiseExceptionIfNotProxy(method);

	app.setContinueCMExceptions(true);

	pProxyTower.pxyGetRealObjectAndEdition(realTower, expectedEdition);
	
	if realTower = null then	
		app.raiseCMException1(ProxyMgrCannotLocateReal, CM_Tower.name, null, null);
		return;
	endif;

//	app.myValUA.valTower(realTower, pProxyTower);
	
	if (not self.checkValidationWithPassport(_passport)) then
		return;		// note that this gets "ignored" in the eplog
	endif;


	app.setContinueCMExceptions(false);

	exclusiveLock(realTower);

	if _passport.noErrors and realTower.edition &lt;&gt; expectedEdition then
		app.raiseCMException1(ObjectUpdatedByAnotherUserSave, 'Tower', null, null);
		return;
	endif;
	
	/*if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realTower, true);
	endif;*/

	tiUpdateCntrl := app.createTIUpdateControl(TI_UPDMODE_NORMAL, _passport.userCode, null);
	pProxyTower.validateTrackedItem(tiUpdateCntrl, _passport);
	
	if _passport.noErrors then
		realTower.setForUpdate(pProxyTower, tiUpdateCntrl, null , false, _passport); //cnwrd1 28.8.09 par 20545
	endif;
	
	/*if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realTower, false);
	endif;*/

epilog
	if proxyContainer &lt;&gt; null then
	delete proxyContainer;
	endif;
	
	delete tiUpdateCntrl;
	
end;</source>
        <Parameter name="pProxyTower" type="CM_Tower" usage="input"/>
        <Parameter name="_tiRemarksNext" type="String"/>
        <Parameter name="_tiRemarksPrev" type="String"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateTrackClearance" id="b5cf6dd0-924d-4fd4-bc1e-167cdde7d853">
        <source>utlUpdateTrackClearance(_proxyTrackClearance:CM_TrackClearance; _passport : CM_Passport input);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
25 June 2009	cnwndl1	Initial creation

*/

vars
	cancelSave : Boolean;
	realTrackClearance : CM_TrackClearance;
	expectedEdition : Integer;
	
begin

	self.initialiseActivity();

	_proxyTrackClearance.raiseExceptionIfNotProxy(method);

	app.setContinueCMExceptions(true);

	_proxyTrackClearance.pxyGetRealObjectAndEdition(realTrackClearance, expectedEdition);
	
	if realTrackClearance = null then	
		app.raiseCMException1(ProxyMgrCannotLocateReal, CM_WagonClass.name, null, null);
		return;
	endif;

	app.myValUA.valTrackClearance(realTrackClearance, _proxyTrackClearance);
	
	if (not self.checkValidationWithPassport(_passport)) then
		return;		// note that this gets "ignored" in the eplog
	endif;


	app.setContinueCMExceptions(false);

	exclusiveLock(realTrackClearance);
	
	if _passport.noErrors and realTrackClearance.edition &lt;&gt; expectedEdition then
		app.raiseCMException1(ObjectUpdatedByAnotherUserSave, app.getErrorString(Gauge_clearance), null, null);
		return;
	endif;
	
	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realTrackClearance, true);
	endif;
	
	if _passport.noErrors then
		realTrackClearance.setForUpdate(_proxyTrackClearance);
	endif;

	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realTrackClearance, false);
	endif;

epilog
	
	
end;</source>
        <Parameter name="_proxyTrackClearance" type="CM_TrackClearance"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateTrackedItem" id="68f970b6-dd2a-44f3-9737-40efc73a1f53">
        <updating/>
        <source>utlUpdateTrackedItem(	pProxyTI	: CM_TrackedItem input;
						pComment	: String;
						pUpdateMode : Integer;
						_txnControllerDict : CMIF_TITxnContrlrByTypeDTDict;
						_extraParams : CMIF_TIUpdateExtraParams; //cnwrd1 28.8.09 par 20545						
						_errLinkObject : Object;		// cnwrs2 10 Mar 2010 - so can link errs in EDI
						_passport : CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:     30 January 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//	14/6/01	   AA			Edition checking removed. Now done in setForUpdate
// 26/06/2012  cnwdap1		PAR #29735 Pass extra params "use supplied booking item" setting to update controller
// 12/01/2018  jlgmd1		TFS #36406 - Editing Prenote doesn't change the Wagon Number
// 20 Feb 2024 navhl20 		ChangeRequest 62525: EUP | Retrospective Operations - [54177.060] - Cargo &amp; Truck Checks
// 23 May 2024 navma1		Bug 64224: MTN - DeadLocks Caused by Future Actors
// ---------------------------------------------------------------------------
vars
	realTI					: CM_TrackedItem;
	expectedEdition			: Integer;
	valUpdateCntrl,
	tiUpdateCntrlr			: CMIF_TIUpdateController;
begin
	
	self.initialiseActivity();

	pProxyTI.raiseExceptionIfNotProxy(method);
	pProxyTI.pxyGetRealObjectAndEdition(realTI, expectedEdition);

	if realTI = null then	
		app.raiseCMException1(ProxyMgrCannotLocateReal, CM_TrackedItem.name, null, _errLinkObject);
		return;
	endif;
	
	// VALIDATION
	app.setContinueCMExceptions(true);

	//14/04/2009 cnwdz2 ccms1735
	if app.isSubTerminalsOn(pProxyTI.myTerminal) then
		if pProxyTI.mySubTerminal &lt;&gt; realTI.mySubTerminal then
			pProxyTI.checkStopsToBePrevented(StopPreventSubTerminalEdit,null,true);
		endif;
	endif;
	
	// do the validation here
	
	valUpdateCntrl := app.createTIUpdateControl(pUpdateMode, null, _errLinkObject);
	app.myValUA.valTrackedItem(pProxyTI, valUpdateCntrl, _passport);
	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	
	app.setContinueCMExceptions(false);

	self.exclusiveLock(realTI);
	
	tiUpdateCntrlr := app.createTIUpdateControl(pUpdateMode, _passport.userCode, _errLinkObject);
	
	tiUpdateCntrlr.comment := pComment;
	if _extraParams &lt;&gt; null then														// PAR #29735
		tiUpdateCntrlr.useSelectedBookingItem := _extraParams.useSelectedBookingItem;	// PAR #297356
		tiUpdateCntrlr.isAuditTextRequired	  := not _extraParams.isAuditNotRequired;
		tiUpdateCntrlr.dontCreateTransCM_Edit := _extraParams.dontCreateTransCM_Edit;
		tiUpdateCntrlr.doWagonMove 			  := _extraParams.doWagonMove;				// TFS #36406
		tiUpdateCntrlr.dateTime := _extraParams.dateTime; //20.02.2024 navhl20 #62525 // ### TFS BUG 65978 05SEP2024 NAVAB1
	endif;																				// PAR #29735
	
	if _txnControllerDict &lt;&gt; null then
		_txnControllerDict.copy(tiUpdateCntrlr.allTITxnControllers);
	endif;
	
	if not _passport.noErrors then
		return;
	endif;

	realTI.setForUpdate(pProxyTI, tiUpdateCntrlr, _extraParams, true, _passport); //cnwrd1 28.8.09 par 20545
	
	//TH2 CCMS 1032 - CusCar for centreport - ugly hack to auto create a BOL for each car entered
	if realTI.isCar and realTI.myTerminal.getConfig(AutoCreateCusCarBOL).Boolean then	//23.05.2024 navma1 #64224
		app.myUtilityUA.utlUpdateBOLInCusCar(realTI.CM_Car, _passport);
	endif;
epilog

	delete tiUpdateCntrlr;
	delete valUpdateCntrl;
end;</source>
        <Parameter name="pProxyTI" type="CM_TrackedItem" usage="input"/>
        <Parameter name="pComment" type="String"/>
        <Parameter name="pUpdateMode" type="Integer"/>
        <Parameter name="_txnControllerDict" type="CMIF_TITxnContrlrByTypeDTDict"/>
        <Parameter name="_extraParams" type="CMIF_TIUpdateExtraParams"/>
        <Parameter name="_errLinkObject" type="Object"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateTrackedItems" id="a10fb79d-4007-4dd2-a6b5-50e9286e195e">
        <updating/>
        <source>utlUpdateTrackedItems(control : CMIF_TIUpdateController input; _passport : CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:     14 February 2001 by cnwdwq1
//
// Purpose:			Creates persistent trackeditems for each transient in 
//							the control struct
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  
//				
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	ti : CM_TrackedItem;
	newTI : CM_TrackedItem;
	expectedEdition : Integer;
begin

	// Always initialize the activity first
	self.initialiseActivity;
	app.setContinueCMExceptions(true);
	//-------------------------------------------------------------
	//   V A L I D A T I O N    S E C T I O N
	// Methods to validate data here
	//-------------------------------------------------------------
	app.myValCA.valTrackedItems(control, _passport);

	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;

	//-------------------------------------------------------------
	//   U P D A T E    S E C T I O N
	// Methods to update data here, controlled by begin/endTransaction
	//-------------------------------------------------------------
	app.setContinueCMExceptions(false);

//	beginTransaction;
	foreach ti in control.allTransientTIs do
		ti.pxyGetRealObjectAndEdition(newTI, expectedEdition);
		app.myUtilityUA.utlUpdateTrackedItem(ti, null, TI_UPDMODE_NORMAL, null, null, null, _passport); //cnwrd1 28.8.09 par 20545
		if not _passport.noErrors() then
			break;
		endif;
		control.addMyPersistentTI(newTI);
	endforeach;
	
end;</source>
        <Parameter name="control" type="CMIF_TIUpdateController" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateTrade" id="807d2145-da5a-4310-a32f-f78bc21ba054">
        <source>utlUpdateTrade(pProxyTrade : CM_Trade; _passport : CM_Passport input);
// ---------------------------------------------------------------------------
// Created:      12 May 2003 by cnwsgp1
//21 Sep 2020 cnwma1 ChangeRequest 49906: MTN - Ops View External Webservice
// ---------------------------------------------------------------------------
vars
	cancelSave : Boolean;
	realTrade : CM_Trade;
	expectedEdition : Integer;
	
begin
	self.initialiseActivity();

	pProxyTrade.raiseExceptionIfNotProxy(method);

	app.setContinueCMExceptions(true);

	pProxyTrade.pxyGetRealObjectAndEdition(realTrade, expectedEdition);
	
	if realTrade = null then	
		app.raiseCMException1(ProxyMgrCannotLocateReal, CM_Trade.name, null, null);
		return;
	endif;

	app.myValUA.valTrade(realTrade, pProxyTrade);
	
	if (not self.checkValidationWithPassport(_passport)) then
		return;
	endif;

	app.setContinueCMExceptions(false);

	exclusiveLock(realTrade);

	if _passport.noErrors and realTrade.edition &lt;&gt; expectedEdition then
		app.raiseCMException1(ObjectUpdatedByAnotherUserSave, 'trade', null, null);
		return;
	endif;
	
	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realTrade, true);
	endif;
	
	if _passport.noErrors then
		realTrade.setForUpdate(pProxyTrade);
	endif;

	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realTrade, false);
	endif;
	
	//21.09.2020 cnwma1 TFS #49906
	if _passport.isOpsViewEnabled(null) then
		realTrade.createOpsViewEWSActivity(BGP_OpsViewWSRequest.OPS_ACTION_UPDATE,
								 BGP_OpsViewWSRequest.OPS_TYPE_TRADE,
								 realTrade);
	endif;
	//21.09.2020 cnwma1 TFS #49906
end;</source>
        <Parameter name="pProxyTrade" type="CM_Trade"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateTradeCopyToTrade" id="435d2b5b-2d94-49f6-9170-aad47bd3bb56">
        <updating/>
        <source>utlUpdateTradeCopyToTrade(
	_pxyObject			: CM_Trade;
	_passport			: CM_Passport input;
	_selectedPorts		: ObjectArray;
	_selectedDebtors	: ObjectArray ) updating;

/*

Purpose:		
Parameters:		
Return Value:	

Date				Who		Reason
24 June 2009		cnwrl1	Initial creation as part of PAR 19998 - Copy To Trade

*/
	
vars
	realObject			: CM_Trade;
	expectedEdition		: Integer;
	
begin
	self.initialiseActivity();
	
	// do any pre-validation locks
	
	// do validation
	self.raiseExceptionIfNull( _pxyObject, app.getErrorString( Trade ) );
	
	app.setContinueCMExceptions( true );
	
	app.myValUA.valTradeCopyToTrade( _pxyObject );
	
	if not self.checkValidationWithPassport( _passport ) then
		return;
	endif;
	
	realObject	:= self.getRealObjectAndEditionCheck(	_pxyObject,
														app.getErrorString( Trade ),
														_passport ).CM_Trade;
	
	if _passport.noErrors then
		// This is only required if the class is being audited
		self.myUpdateAuditAgent.audUpdateGeneric( realObject, true );
	endif;
	
	if _passport.noErrors then
		// do updates
		realObject.setCopyToTrade( _pxyObject, _selectedPorts, _selectedDebtors );
	endif;
	
	if _passport.noErrors then
		// This is only required if the class is being audited
		self.myUpdateAuditAgent.audUpdateGeneric( realObject, false );
	endif;
	
epilog
	
end;
</source>
        <Parameter name="_pxyObject" type="CM_Trade"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <Parameter name="_selectedPorts" type="ObjectArray"/>
        <Parameter name="_selectedDebtors" type="ObjectArray"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateTrain" id="a49e1515-7d82-4cad-a00a-5296c657f820">
        <updating/>
        <source>utlUpdateTrain(_pxyTrain : CM_Train input; _isValidate : Boolean; _isInitialise : Boolean; _passport : CM_Passport input) updating;
/*
----------   ----------  --------------------------------------------------
Created:	06 November 2006 By cnwth2

Purpose:	

Changed On  Changed By	Reason
15/06/2009	consw1		PAR 19913 - SFW1067 Rail Simplifications
----------	----------	--------------------------------------------------
28/07/2010	cnwdad1		PAR #25120, added parameter for calling "initialiseActivity".
//16 Dec 2013	cnwrs1	Par 33035 - add CamsDateTime to CM_EventTransaction
--------------------------------------------------------------------------
*/
vars
	cancelSave : Boolean;
	realTrain : CM_Train;
	expectedEdition : Integer;
	codeChanged	: Boolean;
	eventStr : String;
	trainArrivalEvent, trainDepartEvent : CMEVT_TrainTransaction;
begin
	if _isInitialise then
		self.initialiseActivity();
	endif;
	
	_pxyTrain.raiseExceptionIfNotProxy(method);
	app.setContinueCMExceptions(true);
	_pxyTrain.pxyGetRealObjectAndEdition(realTrain, expectedEdition);
	
	if realTrain = null then	
		app.raiseCMException1(ProxyMgrCannotLocateReal, CM_Train.name, null, null);
		return;
	endif;
	app.myValUA.valTrain(realTrain, _pxyTrain);
	
	if (not self.checkValidationWithPassport(_passport)) or _isValidate then
		return;
	endif;

	if _passport.noErrors() then //+ cnwmd1, CCMS 1067, Par 19710
		self.myUpdateAuditAgent.audUpdateGeneric(realTrain, true);
	endif;
	
	app.setContinueCMExceptions(false);

	exclusiveLock(realTrain);

	if _passport.noErrors() and realTrain.edition &lt;&gt; expectedEdition then
		app.raiseCMException1(ObjectUpdatedByAnotherUserSave, 'Train', null, null);
		return;
	endif;

	codeChanged := (realTrain.colour &lt;&gt; _pxyTrain.colour);

	realTrain.setForUpdate(_pxyTrain, trainArrivalEvent, trainDepartEvent);
	
	if _passport.noErrors() then //+ cnwmd1, CCMS 1067, Par 19710
		if codeChanged then
			eventStr := "&lt;" &amp; GridXML_ColourCode &amp; "&gt;" &amp; realTrain.code  &amp; "&lt;/" &amp; GridXML_ColourCode &amp; "&gt;" &amp;
						"&lt;" &amp; GridXML_Colour &amp; "&gt;" &amp; realTrain.colour.String  &amp; "&lt;/" &amp; GridXML_Colour &amp; "&gt;";
			realTrain.causeEvent(EVENT_CODE_COLOUR_CHANGE, false, eventStr);
		endif;
		self.myUpdateAuditAgent.audUpdateGeneric(realTrain, false);
		if trainArrivalEvent &lt;&gt; null then	//16 Dec 2013	cnwrs1	Par 33035 - add CamsDateTime to CM_EventTransaction
			trainArrivalEvent.setCAMSTimeStamp(app.actualTimeServer);	
		endif;
		if trainDepartEvent &lt;&gt; null then	//16 Dec 2013	cnwrs1	Par 33035 - add CamsDateTime to CM_EventTransaction
			trainDepartEvent.setCAMSTimeStamp(app.actualTimeServer);	
		endif;
	endif;
end;</source>
        <Parameter name="_pxyTrain" type="CM_Train" usage="input"/>
        <Parameter name="_isValidate" type="Boolean"/>
        <Parameter name="_isInitialise" type="Boolean"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateTrainEvent" id="01c404f8-7748-462c-b999-d4d20344ceba">
        <updating/>
        <source>utlUpdateTrainEvent(_pxyEvent : CM_EventTransaction input; _passport : CM_Passport input) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
30 October 2009	cnwndl1	Initial creation	Par 21519

*/

vars

	realEvent : CM_EventTransaction;
	expectedEdition : Integer;
	
begin
	self.initialiseActivity();

	_pxyEvent.raiseExceptionIfNotProxy(method);

	app.setContinueCMExceptions(true);

	_pxyEvent.pxyGetRealObjectAndEdition(realEvent, expectedEdition);
	
	if realEvent = null then	
		app.raiseCMException1(ProxyMgrCannotLocateReal, CM_EventTransaction.name, null, null);
		return;
	endif;

	app.myValUA.valTrainEvent(realEvent, _pxyEvent);
	
	if (not self.checkValidationWithPassport(_passport)) then
		return;
	endif;

	app.setContinueCMExceptions(false);

	exclusiveLock(realEvent);

	if _passport.noErrors and realEvent.edition &lt;&gt; expectedEdition then
		app.raiseCMException1(ObjectUpdatedByAnotherUserSave, CM_EventTransaction.name, null, null);
		return;
	endif;
	
	//29 Jan 2021	NDL	TFS 50152
	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realEvent, true);
	endif;

	if _passport.noErrors then 
		realEvent.setForUpdate(_pxyEvent);
	endif;
	
	//29 Jan 2021	NDL	TFS 50152
	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realEvent, false);
	endif;
	
end;


</source>
        <Parameter name="_pxyEvent" type="CM_EventTransaction" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateTrainRemarks" id="cabcf148-ad03-419c-86b6-2541f03d3834">
        <source>utlUpdateTrainRemarks(_train : CM_Train input; _remarks : String; _passport : CM_Passport input);
//-----------------------------------------
//Created: January 2003 By: cnwgd1
//-----------------------------------------
vars
begin

	self.initialiseActivity();
	
	if _train = null then	
		app.raiseCMException1(ProxyMgrCannotLocateReal, _train.getName, null, null);
		return;
	endif;

	exclusiveLock(_train);

	if (not _passport.noErrors) then
		app.raiseCMException1(ObjectUpdatedByAnotherUserSave, 'YardJob', null, null);
		return;
	endif;
	
	_train.setRemarks(_remarks);

end;</source>
        <Parameter name="_train" type="CM_Train" usage="input"/>
        <Parameter name="_remarks" type="String"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateTrainWagonDamageOnly" id="47d07b57-3c9c-42c0-8169-5afbfa7075b0">
        <updating/>
        <source>utlUpdateTrainWagonDamageOnly(_pxyWagon : CM_Wagon input; _passport : CM_Passport input) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
29 June 2009	cnwmd1	Initial creation

*/

vars
	realWagon : CM_Wagon;
	expectedEdition : Integer;
	wagMoveController : CMIF_WagonMoveController;
begin
	self.initialiseActivity();

	_pxyWagon.raiseExceptionIfNotProxy(method);

	app.setContinueCMExceptions(true);

	_pxyWagon.pxyGetRealObjectAndEdition(realWagon, expectedEdition);
	
	if realWagon = null then	
		app.raiseCMException1(ProxyMgrCannotLocateReal, CM_Wagon.name, null, null);
		return;
	endif;

	app.myValUA.valWagon(_pxyWagon);
	
	if (not self.checkValidationWithPassport(_passport)) then
		return;
	endif;

	if _passport.noErrors then //+ cnwmd1, CCMS 1067, Par 19710
		self.myUpdateAuditAgent.audUpdateGeneric(realWagon, true);
	endif;
	
	app.setContinueCMExceptions(false);

	exclusiveLock(realWagon);

	if _passport.noErrors and realWagon.edition &lt;&gt; expectedEdition then
		app.raiseCMException1(ObjectUpdatedByAnotherUserSave, 'Wagon', null, null);
		return;
	endif;
	
	//26 Feb 2021	NDL	TF S50837
	create wagMoveController transient;
	wagMoveController.autoSetEffectiveTimeStamp();

	realWagon.setForUpdate(wagMoveController, _pxyWagon);
	
	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realWagon, false);
	endif;
epilog
	delete wagMoveController;
end;</source>
        <Parameter name="_pxyWagon" type="CM_Wagon" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateTrainsDeparture" id="9847377d-5e35-4d27-8d4e-c16c9b118a07">
        <updating/>
        <source>utlUpdateTrainsDeparture(_allTrains : CM_TrainSet input; _passport : CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:     June 2009 ANDREW BISHOP
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//16 Dec 2013	cnwrs1	Par 33035 - add CamsDateTime to CM_EventTransaction
//22/08/2023	navkc1	CR 59610 Task 59611: Jade - Stop Prevention
// ---------------------------------------------------------------------------


vars
	realTrain : CM_Train;
	trainDepartEvent : CMEVT_TrainTransaction;
begin
	self.initialiseActivity();
	
	//22/08/2023	navkc1	CR 59610 Task 59611
	foreach realTrain in _allTrains discreteLock do
		realTrain.validateDepartureProcess();
	endforeach;
	
	//22/08/2023	navkc1	CR 59610 Task 59611
	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;	
	
	foreach realTrain in _allTrains discreteLock do
	
		if realTrain.isNullTrain then	//10 Dec 2009	NDL	Par 21923
			continue;
		endif;
		
		exclusiveLock(realTrain);
		
		realTrain.departureProcess( null, trainDepartEvent);
		
		if _passport.hasErrorsOrWarnings then
			return;
		endif;
		if trainDepartEvent &lt;&gt; null then	//16 Dec 2013	cnwrs1	Par 33035 - add CamsDateTime to CM_EventTransaction
			trainDepartEvent.setCAMSTimeStamp(app.actualTimeServer);	
		endif;
	endforeach;
	
end;


</source>
        <Parameter name="_allTrains" type="CM_TrainSet" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateTranMap" id="b0af088b-a4ee-41e3-a7f2-3604a57a738a">
        <source>utlUpdateTranMap(pProxyTranMap : CM_TranMap; 	_passport : CM_Passport input);
// ---------------------------------------------------------------------------
// Created:		May 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	cancelSave		: Boolean;
	realTranMap	: CM_TranMap;
	expectedEdition	: Integer;
	
begin

	self.initialiseActivity();

	pProxyTranMap.raiseExceptionIfNotProxy(method);

	app.setContinueCMExceptions(true);

	pProxyTranMap.pxyGetRealObjectAndEdition(realTranMap, expectedEdition);
	
	if realTranMap = null then	
		app.raiseCMException1(ProxyMgrCannotLocateReal, CM_TranMap.name, null, null);
		return;
	endif;

	app.myValUA.valTranMap(realTranMap, pProxyTranMap);
	
	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	
	app.setContinueCMExceptions(false);

	exclusiveLock(realTranMap);

	if _passport.noErrors and realTranMap.edition &lt;&gt; expectedEdition then
		app.raiseCMException1(ObjectUpdatedByAnotherUserSave, 'Invoice Line Desc', null, null);
		return;
	endif;
	
	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realTranMap, true);
	endif;
	
	if _passport.noErrors then
		realTranMap.setForUpdate(pProxyTranMap);
		if _passport.noErrors then
			_passport.myTerminal.causeEvent(_passport.myTerminal.getTerminalEvent(EVENT_TRANSACTIONMAP_UPDATE),false,realTranMap);
		endif;
	endif;

	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realTranMap, false);
	endif;

end;</source>
        <Parameter name="pProxyTranMap" type="CM_TranMap"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateTranMapBOL" id="51120dd6-0003-475f-852f-58ff9c7811db">
        <source>utlUpdateTranMapBOL( pxyTranMapBOL : CM_TranMapBOL; _passport : CM_Passport input );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 November 2019	jlgndl1	Initial creation	TFS 47100

*/

vars
	cancelSave : Boolean;
	realTranMapBOL : CM_TranMapBOL;
	expectedEdition	: Integer;
	
begin

	self.initialiseActivity();

