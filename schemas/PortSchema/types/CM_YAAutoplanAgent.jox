    <JadeMethod name="getYABlockForTILocation" id="3c7f6350-bccc-40f7-baff-a3a5ff419fd5">
        <updating/>
        <source>getYABlockForTILocation(_ti : CM_TrackedItem ;
						_locationsController : CM_LocationsController) : CM_YABlock updating;
/*

Purpose:		returns the out YABlock that was used to plan the passed in container to
				if none was found can assume it was manually queued

Parameters:			

Return Value:		


Date		Who		Reason
22 December 2009	cnwer1	Initial creation

*/

vars
terminal 	: CM_Terminal;
	ta 			: CM_TerminalArea;
	priority : Real;
	startYA,
	ya : CM_YardAllocation;
	yaBlock	: CM_YABlock;
	iter 	: Iterator;
	
begin
	if _ti = null then
		return null;
	endif;

	if _locationsController= null then
		return null;
	endif;
	if not  _locationsController.isKindOf(CM_YardController) then
		return null;
	endif;
	terminal:=_ti.myTerminal;
	
	ta:=_locationsController.myTerminalArea;
	self.initialiseSearchForAutoPlan(_ti,terminal,ta,null,null);
	self.myCMIFYAAutoPlan.attachTI(_ti);
	priority:=self.getYAPriorityValueForCMIF(terminal,self.myCMIFYAAutoPlan);
	
	startYA:=self.getYardAllocation(terminal,ta,priority);
	if startYA = null then
		return null;
	endif;
	iter:=ta.allYardAllocations.createIterator;
	iter.startAtObject(startYA);
	
	while iter.next(ya) do
		foreach yaBlock in ta.allYABlocks do
			if not yaBlock.allYardControllers.includes(_locationsController.CM_YardController) then
				continue;
			endif;
			if ya.allYABlocksOut.includes(yaBlock) then
				return yaBlock;
			endif;
		endforeach;
	endwhile;
	
	return null;
epilog
	delete iter;
	delete self.myCMIFYAAutoPlan;
end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_locationsController" type="CM_LocationsController"/>
        <ReturnType type="CM_YABlock"/>
    </JadeMethod>
    <JadeMethod name="getYAPriorityValueForCMIF" id="2fa2fde1-b94b-4e15-9ed7-3df49323498b">
        <updating/>
        <source>getYAPriorityValueForCMIF(_terminal  : CM_Terminal; _cmifAutoPlan : CMIF_YAAutoPlan) : Real protected, updating;
// -------------------------------------------
// Created 14 March 2005 by cnwdvb1
// 13 Sep 2024	navhn30  Bug 66053: CUX - Error 4 is showing on all screens
// -------------------------------------------
// This method returns the priority value of a tracked Item

vars
	cmifTerm			: CMIF_YATerminal;
	priority			: CM_YAPriority;
	priorityValue		: Real;
	tmpCMIF_YAAutoPlan	: CMIF_YAAutoPlan;
begin

	if self.getUsePriorityLookup then
		cmifTerm := self.getCMIFTermWrapper(_terminal);
		
		if cmifTerm = null then
			// Raise exception. Should have a transient;
			return 0;
		endif;
		
		cmifTerm.allYAPriorities.rebuild;	// 13.09.24	 navhn30  TFS 66053
		tmpCMIF_YAAutoPlan := _cmifAutoPlan;
		tmpCMIF_YAAutoPlan.setMyTerminal(_terminal);
		
		foreach priority in cmifTerm.allYAPriorities discreteLock do
			priorityValue := priorityValue + priority.getYAPriorityValueForCMIF(_cmifAutoPlan, self);
		endforeach;
		self.addLogEntry(AP_Log_YA_Default,"Item has received priority value of " &amp; priorityValue.String, false);
		self.addLogEntry(AP_Log_YA_Default,"Priority Lookup is in use", false);
	else
		priorityValue := 999999999999999;    // PAR 24673 This is greater than any priority value (which is limited to int)
		//self.addLogEntry(AP_Log_YA_Default,"Priority Lookup is not in use", false);
	endif;
	
	return priorityValue;

end;</source>
        <access>protected</access>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_cmifAutoPlan" type="CMIF_YAAutoPlan"/>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="getYardAllocation" id="a7081dd3-c890-4175-b8ac-6c73e5e07984">
        <source>getYardAllocation(_terminal : CM_Terminal; _terminalArea : CM_TerminalArea; _priorityValue : Real) : CM_YardAllocation  protected;
// YA are sorted by priority from high to low. This method will return the the YA that has the highest priority that is less
// than _priorityValue. This is for performance reasons, as in theory only YA with a priority less than or equal _priorityValue
// can match criteria of the TI being planned.
vars
	yardAllocation : CM_YardAllocation;
begin
	// Even though the greater than equal to looks wrong, it's not, because
	// of the way the priority dict is keyed.
	if _terminalArea &lt;&gt; null then
		yardAllocation := _terminalArea.allYardAllocations.getAtKeyGeq(_priorityValue);
	else
		yardAllocation := _terminal.allYardAllocations.getAtKeyGeq(_priorityValue);
	endif;
	
	return yardAllocation;
end;</source>
        <access>protected</access>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_terminalArea" type="CM_TerminalArea"/>
        <Parameter name="_priorityValue" type="Real"/>
        <ReturnType type="CM_YardAllocation"/>
    </JadeMethod>
    <JadeMethod name="getYardAllocationUsed" id="ff153e0e-debd-4b4b-b4dc-5fa783b8bc1b">
        <source>getYardAllocationUsed():CM_YardAllocation;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
28 February 2012	cnwndl1	Initial creation	Par 29195

*/

vars

begin

	if self.myCMIFYAAutoPlan &lt;&gt; null then
		return self.myCMIFYAAutoPlan.myFirstUsedYA;
	endif;
	
	return null;

epilog

end;</source>
        <ReturnType type="CM_YardAllocation"/>
    </JadeMethod>
    <JadeMethod name="hasFoundAvailableLoc" id="5dace707-6a03-48f2-8ebb-ad129f468d00">
        <source>hasFoundAvailableLoc() : Boolean;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
14 March 2012	cnwrd1	Initial creation
//cnwrd1 par 29269 14.3.2012
*/

vars
	loc : CM_LocationsController;
begin
	foreach loc in self.myCMIFYAAutoPlan.allPassedLocations do
		if not self.myCurrentCMIFYAAutoPlan.allPassedLocationsRestricted.includes(loc) then
			return true;
		endif;
	endforeach;
	
	
	return false;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="initSearchForTwinAutoPlan" id="31d3ed15-4523-4759-91a2-632064ea46c8">
        <updating/>
        <source>initSearchForTwinAutoPlan(_currentTi,		
							_twinTi			: CM_TrackedItem;
							_terminal		: CM_Terminal;
							_ta				: CM_TerminalArea) updating, protected;
// 01 December 2008	cnwer1	Initial creation
vars
	cmifYA: CMIF_YAAutoPlanNormal;
begin
	self.initialise();
	
	self.myCurrentTerminal := _terminal;
	self.myCurrentSpecificTA := _ta;
	self.isFindLocationForBox := true;
	self.myCurrentJob := null;
	self.getTiDesc(_currentTi);

	create self.myLinkedYAAutoPlan as CMIF_YAAutoPlanNormal transient;

	create cmifYA transient;
	self.setYAAutoPlan(cmifYA);
	self.setCurrentYAAutoPlan(cmifYA);

	self.addLogEntry(AP_Log_YA_Global,"Attempting twin lift auto plan of containers " &amp; _currentTi.id &amp; " &amp; " &amp; _twinTi.id, true);
end;</source>
        <access>protected</access>
        <Parameter name="_currentTi" type="CM_TrackedItem"/>
        <Parameter name="_twinTi" type="CM_TrackedItem"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_ta" type="CM_TerminalArea"/>
    </JadeMethod>
    <JadeMethod name="initTerminal" id="1669d12e-19e4-46bc-b9d2-a58aae5a8200">
        <source>initTerminal(_terminal : CM_Terminal) : CMIF_YATerminal protected;
// -------------------------------------------
// Created 14 March 2005 by cnwdvb1
// -------------------------------------------
/*	This method is called during startup and if anything
	changes in the priority collection on terminal. */
vars

	cmifTerm	: CMIF_YATerminal;

begin

	on LockException do self.xLockHandler(exception);
	
	if _terminal = null then
		// Raise Exception.
		return null;
	endif;
	
	create cmifTerm transient;
	cmifTerm.myTerminal := _terminal;
	self.allCMIFTerminals.add(cmifTerm);
	
	self.resetCMIFTerminal(cmifTerm);

	return cmifTerm;	
end;</source>
        <access>protected</access>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <ReturnType type="CMIF_YATerminal"/>
    </JadeMethod>
