    <JadeMethod name="setForCreate" id="fc79dfe9-0280-47af-891e-306cc0bdb10d">
        <updating/>
        <source>setForCreate(_proxy: SelfType) updating;
/*

Purpose:			Sets our real object, we are creating, to our proxy objects values

Parameters:			_proxy	SelfType	Our proxy to base our real object off of

Return Value:		NONE

Date		Who		Reason
21 February 2022	navpw1	Initial creation TFS: 52773

*/

begin
	inheritMethod(_proxy);
	self.setForUpdate(_proxy);

end;</source>
        <Parameter name="_proxy" type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="2d138b82-6607-4da9-956f-0526eb3444dc">
        <updating/>
        <source>setForUpdate(_proxy: SelfType) updating;
/*

Purpose:			Sets our real object, we are creating, to our proxy objects values

Parameters:			_proxy	SelfType	Our proxy to base our real object off of

Return Value:		NONE

Date		Who		Reason
21 February 2022	navpw1	Initial creation TFS: 52773

*/

vars
	jsonHelper 	: JadeJson;
	json		: String;
	
begin
	inheritMethod(_proxy);
	
	self.dataAction := _proxy.dataAction;
	self.dataType := _proxy.dataType;
	self.objectOid := _proxy.objectOid;
	

	
end;</source>
        <Parameter name="_proxy" type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setSequence" id="ffff9275-b588-4e3e-b4b0-5f82fc2373fe">
