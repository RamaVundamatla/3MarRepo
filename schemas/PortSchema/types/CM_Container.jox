	columns := 4;
	int := 0;
	logString := "";
	   	
	foreach dayReefTemp in self.allTempReadings do
		logString := logString &amp; CrLf;
		if dayReefTemp.date = null then
			dateString := 	"        ";
		else
			dateString :=  dayReefTemp.date.shortFormatJMT();
		endif;
		if inFahrenheit then
			logString := logString &amp; dateString &amp; Tab &amp; dayReefTemp.earlyTempFahrenheit.String &amp; DegF &amp; Tab &amp; dayReefTemp.lateTempFahrenheit.String &amp; DegF;
		else
			logString := logString &amp; dateString &amp; Tab &amp; dayReefTemp.earlyTemp.String &amp; DegC &amp; Tab &amp; dayReefTemp.lateTemp.String &amp; DegC;
		endif;
			 	
	endforeach;		
	return logString;	*/
end;</source>
