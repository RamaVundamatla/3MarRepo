    <JadeMethod name="getInternalMoveDetails" id="ee80cd76-3e7a-4770-b954-d9e0efdd1b75">
        <updating/>
        <source>getInternalMoveDetails(_fromLoc,
						_toLoc : String io;
						_canEditLoc,
						_toLocIsVehicle: Boolean io;
						_errorMsgs: DTO_HandHeldGateErrorDict input) updating, protected;
/*

Purpose:			


Return Value:		


Date		Who		Reason
31 October 2006	cnwer1	Initial creation - PAR#xxxx

*/
vars
	task,
	relatedTask,
	pickup,
	setdown : CM_RTQueueTask;
	load,hasIMV : Boolean;
	vehicleId : String;
	entry : CM_RTQueueEntry;
begin
	//current task should be the internal move task
	task:=self.getCurrentTask;
	self.getRelatedTask();
	entry:=task.myEntry;
	hasIMV:=entry.machineTypeGroup = MACHINETYPEGRP_IMV;
	vehicleId:=task.machine.code;

	if self.myRelatedTask = null then
		//it is a move task we are expecting a related task
		if entry.allTasks.size = 1  and not app.isDevelopmentSystem then
			self.addError(UNEXPECTED_PROGRAM_ERROR,app.getErrorString3(UNEXPECTED_PROGRAM_ERROR,self.class.name,method.name,"This IMV task does not have a related task"),_errorMsgs);
			return;
		else 
		//epr par 21459 28/10/09  only in dev enviroment was added for a demo so IMVS can move chassis around
			foreach task in entry.allTasks discreteLock do
				if task.taskType = TASK_MOVE then
					pickup:=task;
					setdown:=task;
				elseif task.taskType = TASK_PICKUP then
					pickup:=task;
				elseif task.taskType = TASK_SETDOWN then
					setdown:=task;
				endif;
			endforeach;
		
		endif;
	else
		pickup:=self.myRelatedTask;
		setdown:=self.myRelatedTask;
	endif;

	
	if isLoad then

		_fromLoc:=pickup.sourceLocationId;
		_toLoc:=vehicleId;
		_toLocIsVehicle:=true;
	else
		_fromLoc:=vehicleId;
		_toLoc:=setdown.targetLocationId;
		_canEditLoc:=true;
	endif;
	

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_fromLoc" type="String" usage="io"/>
        <Parameter name="_toLoc" type="String" usage="io"/>
        <Parameter name="_canEditLoc" type="Boolean" usage="io"/>
        <Parameter name="_toLocIsVehicle" type="Boolean" usage="io"/>
        <Parameter name="_errorMsgs" type="DTO_HandHeldGateErrorDict" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getMoveMachine" id="ad0c6c09-11ec-438b-a63b-333b918146f6">
        <source>getMoveMachine(): CM_Machine protected;
/*

Purpose:			


Return Value:		


Date		Who		Reason
31 October 2006	cnwer1	Initial creation - PAR#xxxx

*/
vars
	
begin
	//epr par 21459 28/10/09 -changed move machine will be self when moving a chassis there won't be a related task
	if self.myRelatedTask &lt;&gt; null and self.myRelatedTask.machine &lt;&gt; null  then
		return self.myRelatedTask.machine;
	endif;
	
	//epr par 21459 28/10/09 -changed move machine will be self when moving a chassis there won't be a related task
	return self.myMachine;


epilog

end;</source>
        <access>protected</access>
        <ReturnType type="CM_Machine"/>
    </JadeMethod>
    <JadeMethod name="getRelatedTask" id="4718a426-c2c8-406f-91a9-5893d8265103">
        <updating/>
        <source>getRelatedTask() updating, protected;
/*

Purpose:			


Return Value:		


Date		Who		Reason
31 October 2006	cnwer1	Initial creation - PAR#xxxx

*/
vars
	task: CM_RTQueueTask;
	entry : CM_RTQueueEntry;
begin
	task := self.getCurrentTask;
	entry := task.myEntry;
	//if is Load then get the prior entry task 
	if isLoad then
		self.myRelatedTask:=entry.getPreviousEntryFirstTask;
	else
		self.myRelatedTask:=entry.getNextEntryFirstTask;
	endif;


epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="getSelectedTasks" id="a79e3ed5-f810-4377-84ad-8663807bd2e0">
        <source>getSelectedTasks(_rtQueueEntry : CM_RTQueueEntry input; _selectedTasks : CM_RTQueueTaskArray io );
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
30 October 2009	cnwer1	Initial creation

*/

vars
	invalidObject : Boolean;
	rtQueueTask,
	twinTask : CM_RTQueueTask;
begin
	on Exception do app.handleDeletedObject(exception, _rtQueueEntry, invalidObject);
		
	if _rtQueueEntry.allTasks.size &gt; 0 and not invalidObject then
		rtQueueTask	:=_rtQueueEntry.allTasks.first;
	endif;
	if invalidObject or rtQueueTask = null then
		return;
	endif;	
	
	_selectedTasks.add(rtQueueTask);
	
	twinTask:=self.myMachine.findOtherTwinTask(rtQueueTask);
	if twinTask &lt;&gt; null then
		_selectedTasks.add(twinTask);
	endif;

epilog

end;</source>
        <Parameter name="_rtQueueEntry" type="CM_RTQueueEntry" usage="input"/>
        <Parameter name="_selectedTasks" type="CM_RTQueueTaskArray" usage="io"/>
    </JadeMethod>
