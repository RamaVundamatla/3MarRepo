        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="setComboValues" id="154d11cf-5528-4a73-981d-4f6293d31e73">
        <source>setComboValues(_combo: ComboBox input; _params: CM_QueryCriteriaLineHolder; _queryOperator: CM_QueryOperator; _passport: CM_Passport);
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 30/05/2019	jlgdap1		Initial creation TFS 44554 AAT Stevedore Data Access
// 23/06/2022	navdap1		TFS 53362 EUP Master Data Interface Customers Between TOS and ERP
//
vars
	stevedore : CM_Stevedore;
	dict : CM_StevedoreByCodeDict;
	byName : Boolean;			// TFS 53362

begin
	_combo.clear;
	dict := app.myRoot.allStevedores;
	byName := app.myRoot.getConfig(ComboByNameStevedore).Boolean;		// TFS 53362
	
	foreach stevedore in dict discreteLock do
		if byName then																						// TFS 53362
			_combo.itemObject[_combo.addItem(stevedore.description &amp; Tab &amp; stevedore.code)] := stevedore;	// TFS 53362
		else																								// TFS 53362
			_combo.itemObject[_combo.addItem(stevedore.code &amp; Tab &amp; stevedore.description)] := stevedore;
		endif;																								// TFS 53362
	endforeach;
	
	if CM_QStringLookup.hasInstance(_queryOperator) then
		_combo.listObject := dict[_queryOperator.CM_QStringLookup.selectionValue];
	elseif CM_QStringLookupNotEqual.hasInstance(_queryOperator) then
		_combo.listObject := dict[_queryOperator.CM_QStringLookupNotEqual.selectionValue];
	endif;

epilog

end;</source>
        <Parameter name="_combo" type="ComboBox" usage="input"/>
        <Parameter name="_params" type="CM_QueryCriteriaLineHolder"/>
        <Parameter name="_queryOperator" type="CM_QueryOperator"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="setListValues" id="97032671-43aa-44e0-979e-7b24c4410c8b">
        <source>setListValues(_tbl: Table input; _params: CM_QueryCriteriaLineHolder; _operator: CM_QueryOperator; _passport: CM_Passport);
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 31/05/2019	jlgdap1		Initial creation TFS 44554 AAT Stevedore Data Access
//
vars
	stevedore : CM_Stevedore;
	steveDict : CM_StevedoreByCodeDict;
	selectionValue, idx : Integer;
	array : ObjectArray;

begin
	steveDict := app.myRoot.allStevedores;
	
	_tbl.rows := _tbl.fixedRows;
	array := _tbl.getPropertyValue("allSelectedObjects").ObjectArray;
	array.clear;
	
	foreach stevedore in steveDict discreteLock do
		selectionValue := 0;
		if _operator &lt;&gt; null and _operator.CM_QStringIsOneOf.allSelectionValues.includes(stevedore.code) then
			selectionValue := 1;
			array.add(stevedore);
		endif;
		idx := _tbl.addItem(selectionValue.String &amp; Tab &amp; stevedore.code &amp; " (" &amp; stevedore.description &amp; ")");
		_tbl.accessRow(idx).itemObject := stevedore;
	endforeach;

epilog

end;</source>
        <Parameter name="_tbl" type="Table" usage="input"/>
        <Parameter name="_params" type="CM_QueryCriteriaLineHolder"/>
        <Parameter name="_operator" type="CM_QueryOperator"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="setValuesFromList" id="d13f4c45-a1ed-4f6e-a9c0-ea9bafca30f6">
        <source>setValuesFromList(_tbl: Table input; _op: CM_QueryOperator input);
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 31/05/2019	jlgdap1		Initial creation TFS 44554 AAT Stevedore Data Access
//
vars
	stevedore : CM_Stevedore;
	str : String;
	numRows, idx : Integer;
	sa : StringArray;

begin
	create sa transient;
	
	numRows := _tbl.rows;
	foreach idx in _tbl.fixedRows + 1 to numRows do
		str := _tbl.accessCell(idx, 1).text;
		if str = TableCheckBox_Selected then
			stevedore := _tbl.accessRow(idx).itemObject.CM_Stevedore;
			sa.add(stevedore.code);
		endif;
	endforeach;
	
	_op.setSearchValue(sa);

epilog

end;</source>
        <Parameter name="_tbl" type="Table" usage="input"/>
        <Parameter name="_op" type="CM_QueryOperator" usage="input"/>
    </JadeMethod>
    <JadeMethod name="translateToDisplayValue" id="3edf8ae2-646d-4303-8972-9d36eba43ddf">
        <source>translateToDisplayValue(_value: Any): String;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 31/05/2019	jlgdap1		Initial creation TFS 44554 AAT Stevedore Data Access
//
vars

begin
	if _value.isKindOf(CM_Stevedore) then
		if _value &lt;&gt; null then
			return _value.CM_Stevedore.code;
		else
			return null;
		endif;
	else
		return _value.String;
	endif;
epilog

end;</source>
        <Parameter name="_value" type="Any"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="translateToSearchValue" id="85dabda2-94a4-49f7-8173-ff61077bdf08">
        <source>translateToSearchValue(_value: Any): Any;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 31/05/2019	jlgdap1		Initial creation TFS 44554 AAT Stevedore Data Access
//
vars
	invalidObj : Boolean;
	object : CM_Stevedore;
	returnVal : String;
	
begin
	if _value &lt;&gt; null then
		if _value.isKindOf(Collection) then
			return _value;
		endif;
		
		if _value.isKindOf(CM_Stevedore) then
			object := _value.CM_Stevedore;
		endif;
	endif;
	
	if object &lt;&gt; null then
		on Exception do app.handleDeletedObject(exception, object, invalidObj);
		
		returnVal := object.code;
	endif;
	
	return returnVal;

epilog

end;</source>
        <Parameter name="_value" type="Any"/>
        <ReturnType type="Any"/>
    </JadeMethod>
    <JadeMethod name="translateToSearchValueForWeb" id="d9d6e2d3-68f1-4147-a4c9-63ab1b593f0a">
        <source>translateToSearchValueForWeb(_value: Any; _sending : Boolean): Any;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 24/09/2019	jlgdap1		Initial creation TFS 45769 JMT Web Portal selector query parameters
//
vars
	str, returnVal : String;
	strArray : StringArray;

begin
	if _value.isKindOf(String) then		
		if _value.String.cnContains("|") then
			str := _value.String;
			create strArray transient;
			str.getTokensForDelimiter("|", strArray);
			return strArray;
		endif;
		
		return _value.String;
		
	elseif _value.isKindOf(StringArray) then
		foreach str in _value.StringArray do
			returnVal := returnVal &amp; str &amp; CNEC_COMMA &amp; Space;
		endforeach;
		returnVal := returnVal[1:returnVal.length-2];
		return returnVal;
		
	endif;
	
	return inheritMethod(_value, _sending);

epilog

end;</source>
        <Parameter name="_value" type="Any"/>
        <Parameter name="_sending" type="Boolean"/>
        <ReturnType type="Any"/>
    </JadeMethod>
</Class>
