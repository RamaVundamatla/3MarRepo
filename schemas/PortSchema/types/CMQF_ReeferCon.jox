<Class name="CMQF_ReeferCon" id="9e29509d-4cee-424b-8f5d-e3f7949efa41">
    <superclass name="CMQF_Reefer"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="query"/>
    <JadeMethod name="includesObject" id="2a14eb92-70b6-4aaf-8712-344b394a464b">
        <updating/>
        <source>includesObject(_ti: CM_TrackedItem; _passport : CM_Passport; _breakOut : Boolean output): Boolean updating, protected;
// ---------------------------------------------------------------------------
// Created:		30 January 2003  by Jason Chapman  (cnwjc2)
// ---------------------------------------------------------------------------

vars
	cont	: CM_Container;
begin
	
	if not _ti.isContainer then
		return false;
	endif;
	
	cont := _ti.CM_Container;
	
	if (not cont.isConnected)	// not connected
	and cont.monitorConnection	// requires monitoring
//	and ((not cont.isAboutToBeLoaded) or (not cont.firstConnectDT.isValid))		//not about to be loaded OR first connDT is not valid
	and inheritMethod(cont, _passport, _breakOut) then
		return true;
	endif;
	
	return false;
end;

/* from v6
Monitor Connection = Yes
Is Connected = No
  -- OR --
Temperature &gt; -200
Is Connected = No
*/</source>
        <access>protected</access>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_passport" type="CM_Passport"/>
        <Parameter name="_breakOut" type="Boolean" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
