    <JadeMethod name="setupCargoList" id="82260176-b772-41b3-a8c6-46ee576cb155">
        <updating/>
        <source>setupCargoList() updating;
// --------------------------------------------------------------------------------
// Created:		31 August 2010 by cnwjo3
//
// Purpose:		Set up all the entries in the tblCargoList table (from the voyageJob)
//
vars
	tbl : CM_DataTable;
	entTableDef : EntTableDef;
	rowIdx : Integer;
	totalSelected : Integer;
	startSelecting : Boolean;
begin
	
	
	tbl := self.tblCargoList;
	
	tbl.rows := 0;
	tbl.clear();
	tbl.selectMode := Table.SelectMode_WholeRows;

	entTableDef := app.myController.getEntTableDef(ETDef_ShipOperations);
	tbl.setTblDataEntRowsFromDef(entTableDef);
	
	totalSelected:=self.loadCargoList;
	
	if totalSelected &lt; 2 then  //they have selected nothing or just 1 WLE.  So we want to go into SELECT TO END mode
		self.wleSelectMode := self.WLE_SELECTTOEND;
	else
		self.wleSelectMode := self.WLE_SELECTINDIVIDUAL;
	endif;
	
	self.doSort();
	
	//we want to do a select to end (to make it easier), so find the first selected item in the table (set above)
	//and continue to select to the bottomw/end
	if self.wleSelectMode = self.WLE_SELECTTOEND then
		foreach rowIdx in 1 to tbl.rows do
			if tbl.accessRow(rowIdx).selected = true or startSelecting then
				startSelecting := true;
				tbl.accessRow(rowIdx).selected := true;
			endif;
		endforeach;
	endif;	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setupCraneCombo" id="3ec59fec-fda9-4381-84eb-f3bfca2df6eb">
        <source>setupCraneCombo();
// --------------------------------------------------------------------------------
// Created:		31 August 2010 by cnwjo3
//
// Purpose:		Setup the combo box with all the Cranes for the Voyage
//
vars
	idx : Integer;
	voyageJobSheet : CM_VoyageJobSheet;
	workPoint : CM_Object;
	selectIndex : Integer;
	voyage : CM_Voyage;
	wpCrane : CM_Crane;
	isForCrane : Boolean;
begin
	
	voyage := self.myVoyageJob.myVoyage;
	
	isForCrane:=self.myVoyageJob.getJobCrane &lt;&gt; null;
	
	//get all the cranes from the voyage jobs
	foreach voyageJobSheet in voyage.allJobSheets discreteLock do
		workPoint := voyageJobSheet.getMyWorkPointObject();
		if workPoint = null then
			continue;
		endif;
		wpCrane:=workPoint.IF_VoyageWorkPoint.getCrane;
		if isForCrane and wpCrane = null then
			continue;
		elseif not isForCrane and wpCrane &lt;&gt; null then
			continue;				
		endif;
		
		idx := self.cmbCrane.addItemObject(workPoint.IF_VoyageWorkPoint.getID,workPoint);
		//the current crane we are adding to the listbox is the selected crane so
		//set index so combo is automatically selected
		if workPoint = self.myWorkPoint then
			selectIndex := idx;
		endif;
		
	endforeach;
	

	if selectIndex &gt; 0 then
		self.cmbCrane.listIndex := selectIndex;
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="setupForm" id="fc4742aa-1cb6-4190-aee6-97766e4c77e3">
        <updating/>
        <source>setupForm() updating;
// --------------------------------------------------------------------------------
// Created:		31 August 2010 by cnwjo3
//
// Purpose:		
//
vars
	voyageCode : String;
begin
	inheritMethod();
	
	self.minimumWidth := 430;
	self.minimumHeight := 300;
	
	self.handleMenusForModalDisplay();
	
	self.openWithSavedSettings();
		
	if not self.myVoyageJob.isDischarge then
		//we should never get to here, but just in case!
		if self.myVoyageJob.myVoyage &lt;&gt; null then
			voyageCode := self.myVoyageJob.myVoyage.code;
		endif;
		app.msgBox(app.getErrorString2(Err_MoveCargoFormInvalidJob,self.myVoyageJob.id,voyageCode),"Error",16);
		self.unloadForm();
	endif;
	
	self.displayJobDetails();
	self.setupCraneCombo();
	self.setupJobCombo();
	self.setupCargoList();
end;</source>
    </JadeMethod>
    <JadeMethod name="setupJobCombo" id="2aae521d-b12e-44d0-840e-951224b3ce75">
        <source>setupJobCombo();
// --------------------------------------------------------------------------------
// Created:		31 August 2010 by cnwjo3
//
// Purpose:		
//
vars
	idx : Integer;
	voyageJobSheet : CM_VoyageJobSheet;
	crane : CM_Crane;
	selectIndex : Integer;
	voyage : CM_Voyage;
	voyageJob : CM_VoyageJob;
	workPoint	: CM_Object;
begin
	self.cmbJob.clear();


	voyage := self.myVoyageJob.myVoyage;
	
			
	workPoint:=self.cmbCrane.listObject.CM_Object;
	voyageJobSheet:=voyage.allJobSheets[workPoint.IF_VoyageWorkPoint.getID];
	//get all the cranes from the voyage jobs
	foreach voyageJob in voyageJobSheet.allJobsByJobNum do
		if voyageJob.isDischarge then
			idx := self.cmbJob.addItemObject(voyageJob.id,voyageJob);
			//the current crane we are adding to the listbox is the selected crane so
			//set index so combo is automatically selected
			if voyageJob = self.myVoyageJob then
				selectIndex := idx;
			endif;
		endif;
	endforeach;

	if selectIndex &gt; 0 then
		self.cmbJob.listIndex := selectIndex;
	elseif self.cmbJob.listCount &gt; 0 then
		self.cmbJob.listIndex := 1;
	endif;
end;</source>
    </JadeMethod>
