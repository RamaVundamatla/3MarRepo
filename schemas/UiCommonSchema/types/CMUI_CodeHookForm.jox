    <JadeMethod name="loadLstTblLinks" id="c1bb83cd-abda-4e20-978d-19a034e79be1">
        <source>loadLstTblLinks(_hookType : CM_HookType) protected;
// -------------------------------------------
// Created 04 February 2005 by cnwdvb1
// -------------------------------------------
vars

	tmpStr,
	className	: String;
	theClass	: Class;
	obj			: Object;

begin

	self.allPossibleLinkObjects.clear();
	foreach className in _hookType.allAvailableLinkObjects do
		theClass := currentSchema.getClass(className);
		if theClass = null then
			tmpStr := 'Cannnot locate Link Class ' &amp; className;
				app.raiseUnexpectedProgramError(class.name, method.name, tmpStr);
				return;
		endif;
		foreach obj in theClass.instances do
			self.allPossibleLinkObjects.add(obj);
		endforeach;
	endforeach;
	
	self.lstTblLinks.displayCollection(self.allPossibleLinkObjects, false, 0, null);


end;</source>
        <access>protected</access>
        <Parameter name="_hookType" type="CM_HookType"/>
    </JadeMethod>
    <JadeMethod name="lstTblLinks_displayRow" id="65bbe6a4-5470-4540-a582-f4f286a688d1">
        <controlMethod name="Table::displayRow"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>lstTblLinks_displayRow(table: Table input; theSheet: Integer; obj: Object; theRow: Integer; bcontinue: Boolean io):String updating;
// -------------------------------------------
// Created 04 February 2005 by cnwdvb1
// -------------------------------------------
vars

	selected	: Boolean;

	
begin

	selected := table.CMUI_ListTable.allSelectedObjects.includes(obj);
	if selected then
		return TableCheckBox_Selected  &amp; Tab &amp; obj.CM_Object.getDisplayDetails(false);
	else
		return  TableCheckBox_NotSelected &amp; Tab &amp; obj.CM_Object.getDisplayDetails(false);
	endif;	

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="theSheet" type="Integer"/>
        <Parameter name="obj" type="Object"/>
        <Parameter name="theRow" type="Integer"/>
        <Parameter name="bcontinue" type="Boolean" usage="io"/>
        <ReturnType type="String"/>
    </JadeMethod>
