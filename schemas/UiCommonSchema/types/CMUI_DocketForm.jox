    <JadeMethod name="addObjectsToTable" id="5c151370-cd24-4974-ae46-8bf7f4d378fe">
        <updating/>
        <source>addObjectsToTable(_numItems: Integer io) updating;
// ---------------------------------------------------------------------------
// Created:     22 October 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
// 18 Aug 2011 cnwjre1	par 27881 do BOL items within the main loop for efficiency and to minimise locking
// 29/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
vars
	iter 	: Iterator;
	docket 	: CM_BOL;
	bolDtl 	: CM_BOLDtl;
	opTerm	: CM_OperatorTerminal;
	dict	: CM_BOLByTypeNumberDTDict;
	typeKey	: Integer;
	numKey	: String;
	dtKey	: TimeStamp;
	breakOut	: Boolean;
	gotException	: Boolean;
	edTest	: Integer;
//	coll : Collection;
begin

	self.changeTableTerminology();

	on Exception do app.handleDeletedObject (exception, docket, gotException);
//	if self.btnShowBOLItems.value then
//		coll := self.findBOLItems();
//		self.copyCollectionToTable(coll.Collection, _numItems);
//	else


		if self.myFilterOperator &lt;&gt; null then
			opTerm := self.myFilterOperator.getOperatorTerminal(self.myTerminal, false);
			if opTerm = null then
				// there are no BOLS for this operator in this terminal
				return;
			endif;
			dict := opTerm.allBOLByTypeNumber;
		else
			dict := self.myTerminal.allBOLsReceivedByTypeNumberDT;
		endif;
	
		iter := dict.createIterator();
		if self.filterDocketType &lt;&gt; null and 
		   self.filterDocketNumber &lt;&gt; null then
			dict.startKeyGeq(self.filterDocketType, self.filterDocketNumber, null, iter);
		elseif self.filterDocketType &lt;&gt; null then
			dict.startKeyGeq(self.filterDocketType, self.filterDocketNumber, null, iter);
		endif;
	
		while iter.next(docket) do
			// 6/7/2006 dict for operatorTerminals contains CM_BOLOut objects however the terminal dict does not as tempary fix don't load CM_BOLOut object as cause 1086 when editing
			if docket.isKindOf(CM_BOLOut) then
				continue;
			endif;
		
			dict.getIteratorKeys(typeKey, numKey, dtKey, iter);
	
			if (self.filterDocketType &lt;&gt; null and self.filterDocketType &lt;&gt; typeKey) or
			   (self.filterDocketNumber &lt;&gt; null and (not numKey.startsWith(self.filterDocketNumber))) then
				break;
			endif;
			
			// invalid object check
			gotException := false;
			edTest := docket.edition;
			if gotException then
				continue;
			endif;
	
			if self.includeObject(docket, app.myPassport) then
				if self.btnShowBOLItems.value then
					foreach bolDtl in docket.allBOLDtls do
						self.addObjectToTable(bolDtl, _numItems, breakOut);
					endforeach;
				else
					self.addObjectToTable(docket, _numItems, breakOut);
				endif;
				if breakOut then
					break;
				endif;
			endif;
		endwhile;
//	endif;
	


	
epilog
	delete iter;
//	delete coll;		// PAR #27874
end;</source>
        <Parameter name="_numItems" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="addToolbarControls" id="305af5c7-fc29-493b-897f-627c79bcf082">
        <source>addToolbarControls() protected;
//13 January 2010	cnwml2
//+cnwml2 SFW CCMS 1071

vars

begin
	inheritMethod();
	//if self.myMasterMenuAction.myMenuDtl.heading = app.getString(Bol_maintenance) then
	if self.myMasterMenuAction.myMenuDtl.constantValue = 1152 then	//07 Feb 2011	NDL	Par 26738
		self.frmToolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);		
		self.frmToolbar.addButton(self.btnShowBOLItems, CMUI_Toolbar.Control_Alignment_Left);
		self.frmToolbar.addButton(self.btnReconciled, CMUI_Toolbar.Control_Alignment_Left);
	else
		self.btnNewTV.visible := false;		//+cnwml2 PAR22842
	endif;
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="btnReconciled_click" id="d91190ae-fb50-4afd-95b0-e195aea9dd21">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnReconciled_click(btn: Button input) updating;
//14 January 2010	cnwml2


vars

begin
	if self.myCurrentObject.isKindOf(CM_BOLDtl) then
		self.doOpenBOLReconForm(self.myCurrentObject.CM_BOLDtl.myBOL);
	else
		self.doOpenBOLReconForm(self.myCurrentObject.CM_BOL);
	endif;
epilog

end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="btnShowBOLItems_click" id="ff6e672c-3e46-48d9-b1ed-4dd819b6ddbb">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnShowBOLItems_click(btn: Button input) updating;
//13 January 2010	cnwml2


vars

begin
	if btn.value then
		btn.bubbleHelp := "Display BOLs";
	else
		btn.bubbleHelp := "Display BOL Items";
	endif;
	
	self.doBtnShowBOLItems(self.filterDocketType, self.filterDocketNumber, self.filterVoyage, self.filterOperatorCode, self.filterStatus, self.filterReconciled);
	//need to update initDataTable with another Ent Table Def for BOL Items
epilog

end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="canDoAdd" id="2e88816b-3139-4ea1-9d44-084e8ebc06fb">
        <source>canDoAdd(): Boolean;

vars

begin
	if self.myCurrentObject.isKindOf(CM_BOLDtl) then											//+cnwml2 SFW CCMS 1071
		if self.myCurrentObject.CM_BOLDtl.myBOL.bolType = BOLType_Log or self.myCurrentObject.CM_BOLDtl.myBOL.bolType = BOLType_GeneralDocket then
			return false;
		else
			return true;
		endif;
	else
		if self.myCurrentObject.CM_BOL.bolType = BOLType_Log or self.myCurrentObject.CM_BOL.bolType = BOLType_GeneralDocket then
			return false;
		else
			return true;
		endif;
	endif;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="canDoEdit" id="34175a36-b010-478f-bd98-0c1ea9c9a335">
        <source>canDoEdit(): Boolean;

vars

begin
	if self.myCurrentObject.isKindOf(CM_BOLDtl) then												//+cnwml2 SFW CCMS 1071
		if self.myCurrentObject.CM_BOLDtl.myBOL.bolType = BOLType_GeneralDocket then
			return false;
		else
			//return false;
			return true;				//+cnwml2 SFW CCMS 1071  can now edit anything
		endif;
	else
		if self.myCurrentObject.CM_BOL.bolType = BOLType_GeneralDocket then
			return false;
		else
			//return false;
			return true;				//+cnwml2 SFW CCMS 1071  can now edit anything
		endif;
	endif;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="changeTableTerminology" id="6dd57e0e-1a92-4a69-abcb-61183f98d079">
        <updating/>
        <source>changeTableTerminology()updating;
// ---------------------------------------------------------------------------
// Created:     12 May 2005	cnwhjg1
//
// Purpose:     
// ----------   ----------  --------------------------------------------------
vars
	cargoType	:	CM_CargoBOLType;
	terminal 	: 	CM_Terminal;

begin

	cargoType := app.myRoot.allBOLTypes[self.filterDocketType];
	terminal := self.myTerminal;
	
	self.tblData.setTerminologyRelevant(cargoType, terminal);
//	self.tblData.setColumnHeadingsFromDef(self.tblData.myEntTableDef.name, false);	// Par 13725
	
	self.tblSearch.setTerminologyRelevant(cargoType, terminal);
	self.tblSearch.setRowNamesFromTerminology();
end;</source>
    </JadeMethod>
