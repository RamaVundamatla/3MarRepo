    <JadeMethod name="getWorkDurationTime" id="50229d9c-2f7e-4682-b200-5f25893d1780">
        <source>getWorkDurationTime(entTS : TimeStamp) : Integer;
// ---------------------------------------------------------------------------
// Created:		January 2004 By Andrew Bishop cnwab1
//
// Purpose:		
// 14 Dec 2024 navma1	MTN-33673 SNO - Unable to Discharge any container
// ---------------------------------------------------------------------------

vars
	now 		: TimeStamp;
	day 		: Integer;
	duration 	: Time;
	seconds 	: Integer;
	sinceMN,
	pos 		: Integer;
 	midnight	:	Time;
begin
	now := entTS;
	
	midnight.setTime(24,0,0,0);
	
	if self.workStarted.isValid  then									//14.12.2024 navma1 #MTN-33673
		duration := now.differenceAsTime(self.workStarted,pos,day);
		seconds  := (day * SecondsPerDay);
		sinceMN  := duration - midnight;
		sinceMN  := (sinceMN / 1000).Integer;
		seconds  := seconds + sinceMN;
		return seconds;
	endif;
	
	return null;
end;</source>
        <Parameter name="entTS" type="TimeStamp"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
