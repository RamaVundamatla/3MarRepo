    <JadeMethod name="bOk_click" id="69250ab5-6d1e-494f-bf77-4319a25b31db">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>bOk_click(btn: Button input) updating;

begin
	unloadForm;
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="load" id="fa329005-1909-4e53-bb18-1694c7995084">
        <controlMethod name="Form::load"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>load() updating;

vars
	s:String;
	i,j:Integer;
begin
	lHost.caption:=app.computerNameAppServer.toLower;
	s:=app.dbPath;
	i:=s.pos("\",1);
	j:=s.pos("\",i+1);
	lEnvironment.caption:=s[i+1:j-i-1];
	lApplication.caption:=process.persistentApp.name;
	lAppVersion.caption:=process.persistentApp.appVersion;
	lPatchVersion.caption:=process.schema.patchVersion.String;
end;</source>
    </JadeMethod>
</GUIClass>
