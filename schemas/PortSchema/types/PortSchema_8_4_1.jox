	a : Integer;
begin
	app.writeLog( method.qualifiedName &amp; "Converting yard TBA to use the new inversed reference for 8.4.1", LogINFO);
	root := CM_Root.firstInstance;
	
	a := (1/ 0).Integer;
	
	/* tbaMatch removed in 842.
	foreach term in root.allTerminals discreteLock do
		foreach ti in term.allTbaTIsByCargoTypeId discreteLock do
			if ti.tbaMatch &lt;&gt; null and ti.myMatchedActual= null then
				beginTransaction;
					ti.myMatchedActual := null;
					ti.tbaMatch.myMatchedTBA := null;
					ti.myMatchedActual := ti.tbaMatch;
					ti.tbaMatch.setPropertyValue("tbaMatch",null);
					ti.setPropertyValue("tbaMatch",null);
				commitTransaction;
			endif;
		endforeach;
 
	endforeach;
*/
end;

</source>
    </JadeMethod>
    <JadeMethod name="ediDataLinesConversion" id="aae2a6de-5987-445e-84d0-bad9b14be69b">
        <source>ediDataLinesConversion();
//
//16 Jan 2015	cnwrs1	Par 35504 - Refactor EDI file load for .NET
//
vars
	ediFile : CM_EDIFile;
	binaryLine : Binary;
	str : String;
	strMsg : String;
	count : Integer;
	file : File;
begin
	app.writeLog(method.qualifiedName &amp; " Converting EDI Compressed Data.", LogINFO);
	create file transient;
	file.fileName := 'c:\testdb\logs\Testout.txt';
	file.mode := File.Mode_Output;
	file.open();
	foreach ediFile in CM_EDIFile.instances do
		count := count + 1;
		if count &gt; 1000 then
//			break;
		endif;
//		if ediFile.allDataLines &lt;&gt; null then
//			continue;
//		endif;
		app.writeLog(class.name&amp;'::'&amp;method.name&amp;' '&amp;ediFile.String&amp;' '&amp;ediFile.fileName&amp; ' '&amp;ediFile.myEDIFileType.String, LogINFO);
		strMsg := null;
		foreach binaryLine in ediFile.allCompressedFileLines do
			str	:=	binaryLine.uncompressToString();
			str := str.replaceString(CrLf, null);
			str := str.replaceString(Cr, null);
			str := str.replaceString(Lf, null);
			if str = "EOF" then
				continue;
			endif;
			if ediFile.myEDIFileType.isKindOf(CM_EDIFileTypeUNEDIFACT) then
				strMsg := strMsg &amp; str &amp; "'" &amp; CrLf;
			else
				strMsg := strMsg &amp; str &amp; CrLf;
			endif;
		endforeach;
		if ediFile.myEDIFileType &lt;&gt; null then
			if not ediFile.myEDIFileType.isKindOf(CM_EDIFileTypeUNEDIFACT) and
			   not ediFile.myEDIFileType.isKindOf(CM_EDIFileTypeX12) then
				file.writeLine(strMsg);
			endif;
		endif;
		app.writeLog(class.name&amp;'::'&amp;method.name&amp;' '&amp;ediFile.String&amp;' '&amp;ediFile.fileName&amp; ' '&amp;ediFile.myEDIFileType.String, LogINFO);
		beginTransaction;
		ediFile.setRawDataString(strMsg);
		commitTransaction;
	endforeach;
	file.close();
epilog
	delete file;
end;
</source>
    </JadeMethod>
    <JadeMethod name="fixCashPaymentInvoice" id="b7c7fedb-9a22-4649-ba26-62cfff00d5b0">
        <source>fixCashPaymentInvoice();
/*

Purpose:			In case the 831/832 hot fix was missed

Parameters:			

Return Value:		

Date		Who		Reason
5/12/2014	cnwjre1	Initial creation	Par 35232

*/

vars
	count	: Integer;
	cashPayment	: CM_CashPayment;
	invoice		: CM_Invoice;

begin

	app.writeLog( method.qualifiedName &amp; " Setting cash payment invoice", LogINFO);

	beginTransaction;
	foreach cashPayment in CM_CashPayment.instances do
		if cashPayment.myInvoice = null and
		   cashPayment.myInvoiceLine &lt;&gt; null then
			if global.isValidObject(cashPayment.myInvoiceLine) then
				invoice := cashPayment.myInvoiceLine.invoice;
				if global.isValidObject(invoice) then
					cashPayment.pxySetInvoice(invoice);
					count := count + 1;
				endif;
			endif;
		endif;
	endforeach;
	commitTransaction;
	
	app.writeLog( method.qualifiedName &amp; " Cash payment invoice setting complete, " &amp; count.String &amp; " updated.", LogINFO);
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="fixUserConfig" id="e3b27d05-b727-4f76-a9ac-5ff5cec7b894">
        <source>fixUserConfig();
/*

Purpose:			Delete cargo enquiry user config entries with null user.
					Creation of these was fixed in 34529 but the patch for that did not include deleting any already present.
					This deletion is being done now as Penn found 3 - the subject of this par.
					832 JadeScript::rel832_par35344 covers this but done again here in case this was missed.

Parameters:			

Return Value:		

Date		Who		Reason
30 January 2015	cnwjre1	Initial creation par 35344

*/

vars

	uct		: CM_UserConfigCargoType;
	count	: Integer;

begin

	app.writeLog( method.qualifiedName &amp; " Removing cargo enquiry configuration with no user", LogINFO);

	beginTransaction;
	foreach uct in CM_UserConfigCargoType.instances do
		if uct.myUser = null then
			delete uct;
			count := count + 1;
		endif;
	endforeach;
	commitTransaction;

	app.writeLog( method.qualifiedName &amp; " Removing cargo enquiry configuration with no user complete, " &amp;  count.String &amp; " removed.", LogINFO);
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="fixupVehicleBookingRoot" id="6d7875d3-d11e-4a91-b1b7-5a4a7c15fc62">
        <source>fixupVehicleBookingRoot();
/*

Purpose:			Ensure that the Vehicle Booking Root and Terminal objects are created for
					all systems upgrading to 8.4.1

Parameters:			None

Return Value:		None

Date		Who		Reason
23 Feb 2015	cnwkpd1	PAR #35342 - vehicle Booking root object creation

*/

vars
	term : CM_Terminal;
	vbTerm : CM_VehicleBookingTerminal;
	vbRoot : CM_VehicleBookingRoot;

begin
	app.writeLog( method.qualifiedName &amp; " Checking VBS Root and Terminal objects", LogINFO);

	if CM_VehicleBookingRoot.firstInstance = null then
		beginTransaction;
		create vbRoot;
		commitTransaction;
		
		app.writeLog( method.qualifiedName &amp; " Vehicle Booking Root object created", LogINFO);
	else
		app.writeLog( method.qualifiedName &amp; " Vehicle Booking Root object already exists", LogINFO);
	endif;
	
	app.setMyVehicleBookingRoot();
	
	foreach term in CM_Terminal.instances do
		if term.myVehicleBookingTerminal &lt;&gt; null then
			app.writeLog( method.qualifiedName &amp; " Vehicle Booking Terminal object for '" &amp; term.code &amp; "' already exists", LogINFO);
		else
			beginTransaction;
			vbTerm := term.createVehicleBookingTerm();
			commitTransaction;
			app.writeLog( method.qualifiedName &amp; " Vehicle Booking Terminal object for '" &amp; term.code &amp; "' created", LogINFO);
		endif;
	endforeach;

	app.writeLog( method.qualifiedName &amp; " Processing completed normally", LogINFO);
	
epilog
	
end;
</source>
    </JadeMethod>
    <JadeMethod name="populateVBSTimeslotIds" id="205f200f-c002-47e5-8d6a-acc907cd8775">
        <source>populateVBSTimeslotIds();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 October 2014	cnwndl1	Initial creation	Par 35008

*/

vars

	term : CM_Terminal;
	index : Integer;
	iter : Iterator;
	vbSlot : CM_VehicleBookingTimeSlot;

begin

	app.writeLog( method.qualifiedName &amp; " Populating VBS Timeslots 'Id' for 8.3.2/8.4.1", LogINFO);

	foreach term in app.myRoot.allTerminals where term.myVehicleBookingTerminal &lt;&gt; null do
		if term.getConfig(VsUseVehicleScheduling).Boolean then
			index := 0;
			iter := term.myVehicleBookingTerminal.allBookingsByTS.createIterator;
			while iter.next( vbSlot ) do
				if index &gt; 9990 then
					index := 0;
				endif;
				vbSlot.setIdForConversion( index );
			endwhile;
			delete iter;
		endif;
	endforeach;
	
	app.writeLog( method.qualifiedName &amp; " VBS Timeslots 'Id' population complete", LogINFO);
	
epilog

	delete iter;

end;</source>
    </JadeMethod>
    <JadeMethod name="setTEUConversionDefaults" id="783dce35-119d-499f-8f49-fc13814351a1">
        <source>setTEUConversionDefaults();
/*
Purpose:			
Date			Who		Reason
05 March 2015	cnwab1	Initial creation
05/03/2015		cnwmh5	Tranisent Leak
*/

vars
	oArray : ObjectArray;
	ct : CM_CargoType;
	iter01 : Iterator;
	conv : DecimalArray;
begin
	app.writeLog( method.qualifiedName &amp; " Set TEU Conversion Defaults for 8.4.1", LogINFO);
	create oArray transient;
	create conv transient;
	
	CM_CargoType.allInstances(oArray,0,false);
	iter01 := oArray.createIterator;
	beginTransaction;
	
	while iter01.next(ct) do
		conv.clear();
	
		if ct.id = TI_CargoType_Container then
			conv[TEUConversionIndex20] := 1;
			conv[TEUConversionIndex30] := 2;
			conv[TEUConversionIndex40] := 2;
			conv[TEUConversionIndex45] := 2;
			conv[TEUConversionIndex53] := 2;
		else
			conv[TEUConversionIndexGC] := 1;
		endif;
		
		ct.setForUpdateTEUSettings(1,conv);
	endwhile;
	commitTransaction;
epilog
	delete iter01;
	delete oArray;
	delete conv;
end;</source>
    </JadeMethod>
    <JadeMethod name="specificPostStandard" id="c6fecb98-8b57-485a-8642-9e63397c9d27">
        <updating/>
        <source>specificPostStandard( _controller : CnEcReleaseController ) updating;

vars
	file	: File;
	str		: String;
begin
	create file transient;
	
	file.usePresentationFileSystem	:= false;
	//file.kind						:= File.Kind_ANSI;	// 1/3/16 cnwmp6 PAR 36286 unicode version
	file.mode						:= File.Mode_Output;
	file.fileName					:= app.myCnCntrl.logPath &amp; '\app_upgrade.log';
	
	if file.isAvailable then
		file.purge();
	endif;
	
	str	:= 'Performing Upgrade for JMT ' &amp; CM_Version.VERSION;
	self.logMessage( str, _controller, file );
	
	inheritMethod(_controller);
	
	self.fixupVehicleBookingRoot();		// 23 Feb 2015 KPD PAR #35342

	self.populateVBSTimeslotIds();	//24 Oct 2014 NDL	Par 35008
	
	self.fixCashPaymentInvoice();	// 5/12/2014 cnwjre1	35232
	
	self.fixUserConfig();			// 30/01/2015 cnwjre1	35344

	self.cCMS1405Conversion();
	
	self.setTEUConversionDefaults();
	
	self.convertTBAMatch();
	
	//*************** this is the last thing that should happen
	str	:= 'Finished Upgrade for JMT ' &amp; CM_Version.VERSION;
	self.logMessage(str, _controller, file);
	
epilog
	delete file;
end;</source>
        <Parameter name="_controller" type="CnEcReleaseController"/>
    </JadeMethod>
</Class>
