    <JadeMethod name="showThumbnailData" id="b902e87f-ab3b-4f56-8541-1794970af39a">
        <updating/>
        <source>showThumbnailData(_header : CM_StockOrderHeaderGeneric) updating;
// ---------------------------------------------------------------------------
// Created:     30 March 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	
	order		: CM_StockOrderProductLine;
	idx			: Integer;
	str			: String;

begin

	if _header.allStockOrderLines.size &lt;&gt; 1 then
		return;
	endif;
	
		
	order := _header.allStockOrderLines.first.CM_StockOrderProductLine;
		
	self.tblThumb.rows := 0;
	
	self.myCargoType := _header.getCargoType();
	self.tblThumb.addItem('Cargo Type' &amp; Tab &amp; self.myCargoType.description.toUpper);
	self.tblThumb.addItem('Release Number' &amp; Tab &amp; _header.orderNo);
		
	if self.myCargoType.id = TI_CargoType_Log then
		self.doThumbnailForLogs(_header, order);
	else
		self.tblThumb.addItem('Quantity' &amp; Tab &amp; order.reqdQuantity.Integer.String);
		self.tblThumb.addItem('Supplier' &amp; Tab &amp; _header.myOperator.code);
		if _header.myConsignee &lt;&gt; null then
			self.tblThumb.addItem('Consignee' &amp; Tab &amp; _header.myConsignee.code);
		endif;
		self.tblThumb.addItem(app.getErrorString(Cargo_subtype) &amp; Tab &amp; order.myProduct.code);
		self.tblThumb.addItem('Comments' &amp; Tab &amp; order.comments);
	endif;

	
	self.setNavigatorHeading(_header.orderNo);

end;</source>
        <Parameter name="_header" type="CM_StockOrderHeaderGeneric"/>
    </JadeMethod>
    <JadeMethod name="tblInput1_click" id="f13e4e47-2fa0-4f71-8be7-ef66d28ad1c1">
