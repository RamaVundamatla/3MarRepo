    <JadeMethod name="tValidateReportViews" id="3593835a-8c2c-49c0-a962-f62fadc7d28a">
        <source>tValidateReportViews();
// jlgmd1

/*

Purpose:			Perform a JRW validate against all the release JRW views to check for errors that might
					have been caused by model changes in the JMT schemas
					
Parameters:			None

Return Value:		None


Date		Who		Reason
20 Apr 2015	cnwkpd1	JMT 8.4.1 release testing
23 Aug 2019	jlgmd1	Change to run nightly
10 Oct 2019 jlgmd1	TFS 46972 - Moved UT_DSL::validateView to PortSchema::validateJRWView

*/

vars
	badViews,
	releaseViews,
	releaseTemplates,
	releaseReports	: StringArray;
	releaseAgent	: Class;
	view			: String;
	message			: String;
	errors			: HugeStringArray;
	count			: Integer;
begin
	create releaseViews transient;
	create releaseTemplates transient;
	create releaseReports transient;
	
	releaseAgent := rootSchema.getSchema('DevSchema').getClass('DEV_ReleaseExtractAgent');
	releaseAgent.sendTypeMsgWithIOParams('getJRWDetails', releaseViews, releaseTemplates, releaseReports);
	
	create badViews transient;
	create errors transient;
	
	foreach view in releaseViews do
		errors.clear();
		count := app.validateJRWView(view, errors);
		
		if count &gt; 0 then
			message := view &amp; ' has ' &amp; errors.size().String &amp; ' validation errors';
			badViews.add(message);
			
			self.logMessage(message);
			
			foreach message in errors do
				self.logMessage(message);
			endforeach;
			
			self.logMessage(" ");	// Makes multiple errors easier to read
		endif;
	endforeach;
	
	self.assertEqual(badViews.size(), 0);
	
epilog
	delete releaseViews;
	delete releaseTemplates;
	delete releaseReports;
	delete badViews;
	delete errors;
end;</source>
    </JadeMethod>
    <JadeMethod name="uCheckForUncompiledMethods" id="5e610e49-7142-4510-81e7-90a15827b402">
        <source>uCheckForUncompiledMethods();

/*

Purpose:		Check all methods in error across all schemas

Date			Who		Reason
20/10/2014		cnwmh5	Initial creation

*/

vars
	oSchema				: Schema;
	oType				: Type;
	oMethod				: Method;
	
	oAllClasses			: ClassColl;
	oAllMethods			: MethodNDict;
	
	iErrorsFound		: Integer;
	iErrorsTotal		: Integer;
	tempStr				: String;
	
begin
	
	tempStr	:= "Starting checking for Methods in Error";
	app.writeLog(tempStr, LogINFO);
	
	foreach oSchema in Schema.instances do : schema_loop
		tempStr	:= "Checking Schema " &amp; oSchema.name;
		//app.writeLog(tempStr, LogAlways);
		
		oAllClasses	:= oSchema.getAllClasses( true );
		
		foreach oType in oAllClasses do : class_loop
			oAllMethods  := oType.cnGetMethods() ;
			foreach oMethod in oAllMethods do : method_loop
				if oMethod.getSchema &lt;&gt; oSchema then
					continue method_loop;
				endif;
				// display if in error and this method is actually in this schema not a super schema
				if oMethod.inError or oMethod.notCompiled then
					iErrorsFound := iErrorsFound + 1;
					tempStr	:= oSchema.name &amp; Tab &amp; oType.name &amp; Tab &amp; oMethod.name &amp; Tab &amp; oMethod.cnGetModifierName();
					app.writeLog(tempStr, LogINFO);
				endif;
			endforeach method_loop;
		endforeach class_loop;
		
		iErrorsTotal	:= iErrorsTotal + iErrorsFound;
		iErrorsFound	:= null;
		delete oAllClasses;
	endforeach schema_loop;
	
epilog

	self.assertEqualMsg(iErrorsTotal, 0,  "Completed - " &amp; iErrorsTotal.display &amp; " Errors Found" &amp; CrLf &amp; "Finished checking for Methods in Error");
	
	delete oAllClasses;
	
end;
</source>
        <text>&lt;?xml version="1.0"?&gt;
&lt;UT_Additional&gt;
  &lt;Categories&gt;
    &lt;Category CanDelete="true"&gt;fails02122014&lt;/Category&gt;
  &lt;/Categories&gt;
&lt;/UT_Additional&gt;</text>
    </JadeMethod>
    <JadeMethod name="uCheckForUnusedVesselVoyages" id="7f5c8a83-29dc-48ce-8530-f7e4fa114559">
        <source>uCheckForUnusedVesselVoyages();

/*

Purpose:		Check for any unused Vessels and Voyages

Date			Who		Reason
26/01/2015		cnwmh5	Initial creation

*/

constants

	DELIM						: String = "    ";

vars

	vessel						: CM_Vessel;
	voyage						: CM_Voyage;
	outFile						: File;
	fileXML						: File;
	
	vesselVoyagesToIgnore		: StringArray;
	tiSet						: CM_TISet;
	vesselsDone					: StringArray;
	
	dict						: DynaDictionary;
	voyageDict					: DynaDictionary;
	

	iter						: Iterator;

	voyageFound					: Boolean;
	vesselCode					: String;
	voyageCode					: String;
	currentVesselCode			: String;
	voyageCount					: Integer;
	canDelete					: Boolean;
	terminalCode				: String;
	voyageOid					: String;
	currentTerminal				: String;
	reason						: String;
	text						: String;
	errorStr					: String;
	
begin

	// get the dat file sizes at the start to compare with when finished
	create dict transient;
	dict.setMembership(CM_Vessel);
	dict.addExternalKey(String, 25, false, true);				// Vessel name
	dict.addExternalKey(String, 25, false, true);				// Reason
	dict.endKeys(false);
	
	create voyageDict transient;
	voyageDict.setMembership(CM_Voyage);
	voyageDict.addExternalKey(String, 25, false, true);			// Terminal
	voyageDict.addExternalKey(String, 25, false, true);			// Vessel name
	voyageDict.addExternalKey(String, 20, false, true);			// Voyage name
	voyageDict.addExternalKey(String, 50, false, true);			// Voyage oid
	voyageDict.endKeys(false);
	
	create vesselVoyagesToIgnore transient;
	//vesselVoyagesToIgnore.add("");
	
	create tiSet transient;	
	foreach vessel in CM_Vessel.instances discreteLock do
		voyageFound := false;
		voyageCount := 0;
		
		// read through the arrived voyages to see if any don't empty
		foreach voyage in vessel.allVoyagesByTermCodeArrival discreteLock do
			voyageFound := true;
			
			// read all the ti collections to see if any ti's exist for the voyage
			tiSet.clear();
			voyage.allOnsiteTIsByCargoTypeId.copyNoDups(tiSet);
			voyage.allDeletedTIsByCargoTypeId.copyNoDups(tiSet);
			voyage.allOnshipTIsByCargoTypeId.copyNoDups(tiSet);
			voyage.allNotifiedTIsByCargoTypeId.copyNoDups(tiSet);
			voyage.allOffsiteTIsByCargoTypeId.copyNoDups(tiSet);
			voyage.allTranshipTIsImport.copyNoDups(tiSet);
			voyage.allTranshipTIsExport.copyNoDups(tiSet);
			voyage.allTbaTIsByIdCargoType.copyNoDups(tiSet);
			voyage.allRRPTIsByIdCargoType.copyNoDups(tiSet);	//16 Mar 2020	NDL	TFS 47004
			voyage.allTisByHouseBol.copyNoDups(tiSet);
			
			if tiSet.isEmpty() then
				voyageCount := voyageCount + 1;
				voyageDict.putAtKey(voyage.myTerminal.code, vessel.code, voyage.code, voyage.getOidString(), voyage);
			endif;
			
		endforeach;
		
		if not voyageFound then
			dict.putAtKey(vessel.code, "No Voyages", vessel);
		elseif voyageCount = vessel.allVoyagesByTermCodeArrival.size then
			dict.putAtKey(vessel.code, "No Voyage(s) with Cargo", vessel);
		else
			dict.putAtKey(vessel.code, null, vessel);
		endif;
		
	endforeach;
	
	errorStr := null;
	
	iter := voyageDict.createIterator;
	while iter.next(voyage) do
	
		voyageDict.getIteratorKeys(terminalCode, vesselCode, voyageCode, voyageOid, iter);
		
		if currentTerminal &lt;&gt; terminalCode then
			errorStr := errorStr &amp; CrLf &amp; "Terminal (" &amp; terminalCode &amp; ") ";
			if not canDelete then
				text := "has the following voyages that can be deleted as they have no assigned TI's:";
			else
				text := "has had the following voyages deleted:";
			endif;
			errorStr := errorStr &amp; text;
			currentTerminal := terminalCode;
		endif;
		
		if currentVesselCode &lt;&gt; vesselCode then
			vessel := dict.getAtKeyGeq(vesselCode, reason).CM_Vessel;
			currentVesselCode := vesselCode;
			//write Tab &amp; vessel.code &amp; Tab &amp; vessel.creationTime.date.format("dd/MM/yyyy") &amp; Tab &amp; vessel.creationTime.time.String;
			errorStr := errorStr &amp; CrLf &amp; DELIM &amp; vessel.code &amp; DELIM &amp; vessel.creationTime.date.format("dd/MM/yyyy") &amp; DELIM &amp; vessel.creationTime.time.String;
		endif;
	
		//write Tab &amp; Tab &amp; voyageCode &amp; Tab &amp; voyage.creationTime.date.format("dd/MM/yyyy") &amp; Tab &amp; voyage.creationTime.time.String;
		errorStr := errorStr &amp; CrLf &amp; DELIM &amp; DELIM &amp; voyageCode &amp; DELIM &amp; voyage.creationTime.date.format("dd/MM/yyyy") &amp; DELIM &amp; 
			voyage.creationTime.time.String;
			
	endwhile;
	
	//write CrLf &amp; CrLf &amp; "The following vessels can be deleted: ";
	errorStr := errorStr &amp; CrLf &amp; CrLf &amp; "The following vessels can be deleted: ";
	delete iter;
	iter := dict.createIterator;
	while iter.next(vessel) do
		dict.getIteratorKeys(vesselCode, reason, iter);
		if reason &lt;&gt; null then
			//write Tab &amp; vessel.code &amp; Tab &amp; vessel.creationTime.date.format("dd/MM/yyyy") &amp; Tab &amp;
			//	vessel.creationTime.time.String &amp; Tab &amp; reason;
			errorStr := errorStr &amp; CrLf &amp; DELIM &amp; vessel.code &amp; DELIM &amp; vessel.creationTime.date.format("dd/MM/yyyy") &amp; DELIM &amp;
				vessel.creationTime.time.String &amp; DELIM &amp; reason;
		endif;
	endwhile;
	
	self.assertNullMsg(errorStr, errorStr);
	
epilog

	delete iter;
	delete vesselVoyagesToIgnore;
	delete tiSet;
	delete dict;
	delete voyageDict;
	delete vesselsDone;
	
end;



/*
vars

	vessel						: CM_Vessel;
	voyage						: CM_Voyage;
	obj							: Object;
	
	vesselVoyagesToIgnore		: StringArray;
	tiSet						: CM_TISet;
	
	dict						: DynaDictionary;

	iter						: Iterator;

	voyageFound					: Boolean;
	errorStr					: String;
	vesselCode					: String;
	voyageCode					: String;
	currentVesselCode			: String;
	dummy						: String;
	voyageCount					: Integer;
	vesselDetails				: String;
	
begin
	
	// get the dat file sizes at the start to compare with when finished
	create dict transient;
	dict.setMembership(Object);
	dict.addExternalKey(String, 25, false, true);			// Vessel name
	dict.addExternalKey(String, 20, false, true);			// Voyage name
	dict.addExternalKey(String, 50, false, true);			// Voyage oid
	dict.endKeys(false);
	
	create vesselVoyagesToIgnore transient;
	//vesselVoyagesToIgnore.add("");
	
	create tiSet transient;	
	foreach vessel in CM_Vessel.instances discreteLock do
		voyageFound := false;
		voyageCount := 0;
		
		// read through the arrived voyages to see if any don't empty
		foreach voyage in vessel.allVoyagesByTermCodeArrival discreteLock do
			voyageFound := true;
			voyageCount := voyageCount + 1;

			// read all the ti collections to see if any ti's exist for the voyage
			tiSet.clear();
			voyage.allOnsiteTIsByCargoTypeId.copyNoDups(tiSet);
			voyage.allDeletedTIsByCargoTypeId.copyNoDups(tiSet);
			voyage.allOnshipTIsByCargoTypeId.copyNoDups(tiSet);
			voyage.allNotifiedTIsByCargoTypeId.copyNoDups(tiSet);
			voyage.allOffsiteTIsByCargoTypeId.copyNoDups(tiSet);
			voyage.allTranshipTIsImport.copyNoDups(tiSet);
			voyage.allTranshipTIsExport.copyNoDups(tiSet);
			voyage.allTbaTIsByIdCargoType.copyNoDups(tiSet);
			voyage.allTisByHouseBol.copyNoDups(tiSet);
			
			if tiSet.isEmpty() then
				dict.putAtKey(vessel.code, voyage.code, voyage.getOidString(), voyage);
			endif;
			
		endforeach;
		
		if not voyageFound or voyageCount = vessel.allVoyagesByTermCodeArrival.size then
			dict.putAtKey(vessel.code, null, null, vessel);
		endif;
		
	endforeach;
	
	iter := dict.createIterator;
	while iter.next(obj) do
		dict.getIteratorKeys(vesselCode, voyageCode, dummy, iter);
		
		// check to see if first time through
		if currentVesselCode &lt;&gt; vesselCode then
			errorStr := errorStr &amp; CrLf &amp; vesselCode &amp; "," &amp; vessel.creationTime.date.format("dd/MM/yyyy") &amp; "," &amp; 
				vessel.creationTime.time.String &amp; ",,,,";
			currentVesselCode := vesselCode;
		endif;
	
		if voyageCode &lt;&gt; null then
			voyage := obj.CM_Voyage;
			errorStr := errorStr &amp; CrLf &amp; vesselCode &amp; "," &amp; vessel.creationTime.date.format("dd/MM/yyyy") &amp; "," &amp; 
				vessel.creationTime.time.String &amp; ',' &amp; voyage.code &amp; "," &amp; voyage.creationTime.date.format("dd/MM/yyyy") &amp; "," &amp; 
				voyage.creationTime.time.String &amp; "," &amp; voyage.myTerminal.code;
		endif;
	
	endwhile;
	
	if errorStr.length &gt; 0 then
		errorStr := "The following vessels / voyages can be deleted: " &amp; CrLf &amp; errorStr &amp; CrLf &amp;
			"Please run DevSchema::JadeScript::deleteUnReqVesselVoyages";
		app.writeLog(errorStr, LogAlways);
	endif;
	
	self.assertEqual(errorStr.length, 0);
	
	
epilog

	delete iter;
	delete vesselVoyagesToIgnore;
	delete tiSet;
	delete dict;
	
end;
*/</source>
    </JadeMethod>
    <JadeMethod name="uCheckTrackedItems" id="8c87aefc-d5da-4ab4-a598-bdedc69900f6">
        <source>uCheckTrackedItems();
// cnwdw1
// Check the YA Criteria Objects for invalid data
vars
	oa 				: ObjectArray;
	ti 			: CM_TrackedItem;
	o 				: Object;
	iter 			: Iterator;
	invalidCount 	: Integer;
	badOnes			: ObjectSet;
	str				: String;
begin
	create oa transient;
	CM_TrackedItem.allInstances(oa, 0, true);
	
	create badOnes transient;
	
	iter := oa.createIterator();
	while iter.next(ti) do
		if ti.myPrimaryActualLocation &lt;&gt; null and not app.isValidObject(ti.myPrimaryActualLocation) then
			invalidCount := invalidCount + 1;
			badOnes.addNoDuplicates(ti, false);
			beginTransaction;
			   ti.setPropertyValue("myPrimaryActualLocation", null);
			commitTransaction;
		endif;
	endwhile;
	
/*	if app.cnwkpd1_IsUser() then
		badOnes.inspectModal();
	endif;
*/	
	self.assertEqual(str, null);
	self.assertEqual(invalidCount, 0);
	
epilog
	delete oa;
	delete badOnes;
	delete iter;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="uCheckYACriteriaTypes" id="c83791bd-a180-46a7-a890-4282db30e641">
        <source>uCheckYACriteriaTypes();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 June 2015	cnwndl1	Initial creation
20 June 2023	navpw1	TFS: 58429 (58517) - Added Sorting Method Yard Allocation Criteria Type
02 Feb 2023 	navhl20 ChangeRequest 61960: FR | 57937 - [TKT: 61898] - Kiosk - US.080 'c' - Coded Instructions Missing from Additional question Criteria 
*/

vars

//	term : CM_Terminal;
	iter : Iterator;
//	seal : CM_WagonSeal;
	typeArray : IntegerArray;
	strNameArray : StringArray;
	yaTypeKey : Integer;
	queryProp : CM_QueryProperty;
	index : Integer;
	strName : String;
begin

	create typeArray transient;
