    <JadeMethod name="setForUpdateCreate" id="f56fed49-d1c5-46ed-85fb-7dd2733cad79">
        <updating/>
        <source>setForUpdateCreate(	_ti : CM_TrackedItem;
					_gte : CMGTE_Entity;	//07 May 2014	NDL	Par 34076
					_checkedObject : CM_Object;
					_checkItem : CM_CargoCheckItem;
					_value : String
					) updating;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 February 2010	cnwdap1	Initial creation
*/
vars

begin
	self.selection			:= _value;
	self.myCargoCheckItem	:= _checkItem;
	self.myTrackedItem		:= _ti;
	self.myGTE := _gte;	//07 May 2014	NDL	Par 34076
	self.myCheckedObject := _checkedObject; //11 Mar 2015	NDL	Par 35828
epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_gte" type="CMGTE_Entity"/>
        <Parameter name="_checkedObject" type="CM_Object"/>
        <Parameter name="_checkItem" type="CM_CargoCheckItem"/>
        <Parameter name="_value" type="String"/>
    </JadeMethod>
    <JadeMethod name="setSelection" id="c2d3bfef-99b0-4eb9-b195-adf96b953849">
        <updating/>
        <source>setSelection(_value : String) updating;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 February 2010	cnwdap1	Initial creation
*/
vars

begin
	if _value &lt;&gt; "" then
		self.selection	:= _value[1:1];
	endif;
epilog

end;</source>
        <Parameter name="_value" type="String"/>
    </JadeMethod>
