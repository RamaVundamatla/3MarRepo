        <Parameter name="_toDoTask" type="CM_ToDoTask"/>
        <Parameter name="_requiredExtraInfo" type="String"/>
        <Parameter name="_required" type="Boolean"/>
        <Parameter name="_cargoCheck" type="CM_CargoCheck"/>
    </JadeMethod>
    <JadeMethod name="validateCriteria" id="d0c5cc0b-5afb-4cd6-9d70-56cfbf744be3">
        <source>validateCriteria();
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 February 2010	cnwdap1	Initial creation
*/
vars
	criteriaTypeColl	: ObjectSet;
	criteria			: CM_YACargoCheckCriteria;
	criteriaType		: CM_YACriteriaType;

begin
	//  Ensure there is only one criteria object for any criteria type
	create criteriaTypeColl transient;
	
	foreach criteria in self.allCriteria do
		criteriaType := criteria.myYACriteriaType;
		if criteriaTypeColl.includes(criteriaType) then
			app.raiseCMException1(Err_YA_CriteriaWithSameType, criteriaType.description, null, null);
		else
			criteriaTypeColl.add(criteriaType);
		endif;
	endforeach;

epilog
	delete criteriaTypeColl;
end;</source>
    </JadeMethod>
    <JadeMethod name="validateForCreate" id="f657a574-cbcb-4164-960d-ed049b1fe692">
