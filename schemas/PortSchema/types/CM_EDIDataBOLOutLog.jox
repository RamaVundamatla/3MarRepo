    <JadeMethod name="canUserSet" id="9c92b46b-ffaf-46e1-87bf-0104f3282122">
        <source>canUserSet(_propName: String): Boolean;
//
// 05 Nov 2014	cnwrs1	Par 34702 - Add support for JMT XML with implied header
//
vars

begin
	if _propName = CM_EDIDataBOLOutLog::fileShortName.name or
	   _propName = CM_EDIDataBOLOutLog::loadStartDT.name or
	   _propName = CM_EDIDataBOLOutLog::logOutFileName.name then
		return false;
	else
		return inheritMethod(_propName);
	endif;
end;
</source>
        <Parameter name="_propName" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="copyFileToServer" id="5cbba714-f523-49ee-919d-0b041e5d88a9">
        <source>copyFileToServer(_logOutFile : File input; _passport : CM_Passport input) : Boolean protected;
//--------------------------------------------------------------
//Created: 26 August 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	clientFile		: File;
	cmifMonitor		: CMIF_Monitor;
	serverFileName	: String;

begin

	create clientFile transient;
	clientFile.kind := File.Kind_Unknown_Text; // 3/3/16  cnwns1 PAR 36286 unicode version
	clientFile.mode 		:= File.Mode_Input;
	clientFile.shareMode 	:= File.Share_Read;
	clientFile.fileName 	:= self.logOutFileName;

	if (not clientFile.isAvailable) then 
		app.raiseCMException1(FileUnavailable, 'logOutFile', null, null);
		return false;
	endif;

	if _passport.myCMIFMonitor &lt;&gt; null then
		cmifMonitor := _passport.myCMIFMonitor;
	endif;
	
	if cmifMonitor &lt;&gt; null then
		cmifMonitor.updateProgress('Copying file to server', 0, 0);
	endif;

	clientFile.close;
	
	// Copy the file to the application server
	app.writeLog('  Copying file to AppServer', LogINFO);
	serverFileName := app.copyFileToAppServer(self.logOutFileName);
	app.writeLog('  Copied file to AppServer as (' &amp; serverFileName &amp; ')', LogINFO);
	
	// Now load the file from the AppServer
	_logOutFile.kind := File.Kind_Unknown_Text; // 3/3/16  cnwns1 PAR 36286 unicode version
	_logOutFile.mode := File.Mode_Input;
	_logOutFile.shareMode := File.Share_Read;
	_logOutFile.usePresentationFileSystem := false;
	_logOutFile.fileName := serverFileName;

	if (not _logOutFile.isAvailable) then 
		app.raiseCMException1(FileUnavailable, 'logOutFile', null, null);
		return false;
	endif;
	
	return true;
	
epilog
	delete clientFile;
end;</source>
        <access>protected</access>
        <Parameter name="_logOutFile" type="File" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="createBOLs" id="4461e71c-28d2-4d69-8f97-dd8ae86bddf9">
        <source>createBOLs(_passport : CM_Passport input) : Boolean;
//--------------------------------------------------------------
//Created: 10 December 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	pxyLogVoyCntrl 	: CM_LogVoyageController;
	realLogVoyCntrl : CM_VoyageController;
	ediLog, lastLog : CM_EDIBOLOutLogTI;
	logLot, lastLot : CM_LogLot;
	intFaceItem 	: CMIF_BOLOut;
	iter 			: Iterator;
	next,
	isEOF,
	firstTime 		: Boolean;
	now 			: TimeStamp;
	voyOper 		: CM_VoyageOperator;
	terminal 		: CM_Terminal;
	globalVoy 		: CM_VoyageGlobal;
	stevedore 		: CM_Stevedore;
	operator 		: CM_Operator;	
	logVoyage 		: CM_Voyage;
	hatch, place 	: Integer;
	operCode,
	productCode		: String;
	voy				: CM_Voyage;
	voySet			: CM_VoyageSet;
	cmifMonitor		: CMIF_Monitor;
	numDone			: Integer;
	str				: String;
	err				: CM_Error;
	
begin

	create intFaceItem transient;
	create voySet transient;	
	iter := self.allEDILogsByLotHatchPlace.createIterator;
	firstTime := true;
	now := app.serverTimestampAtTrxStart;

	if _passport.myCMIFMonitor &lt;&gt; null then
		cmifMonitor := _passport.myCMIFMonitor;
		if (not cmifMonitor.updateProgress(cmifMonitor.message, self.allEDILogsByLotHatchPlace.size, 0)) then
			app.raiseCMException(VB_USER_CANCELED_TRANS, null, null);			
			return false;
		endif;
	endif;
	
	while true do
		isEOF := (not iter.next(ediLog));
		
		numDone := numDone + 1;

		if (not isEOF) then
			if ediLog.myLogLot = null or
			   ediLog.hatch = null or
			   ediLog.place = null or
			   ediLog.productCode = null or
			   ediLog.operatorCode = null then
				continue;
			endif;

			logLot := ediLog.myLogLot;
			if firstTime then
				intFaceItem.hatch := ediLog.hatch;
				intFaceItem.place := ediLog.place;		
				intFaceItem.myLogLot := logLot;
				intFaceItem.allEDILogsById.add(ediLog);
				lastLog := ediLog;
				lastLot := logLot;
				productCode := ediLog.productCode;
				operCode	:= ediLog.operatorCode;
				firstTime := false;
			elseif logLot = intFaceItem.myLogLot and
			   ediLog.hatch = intFaceItem.hatch and
			   ediLog.place = intFaceItem.place and
			   ediLog.productCode = productCode and
			   ediLog.operatorCode = operCode then
				intFaceItem.allEDILogsById.add(ediLog);
			else 
				next := true;				
			endif;
		endif;
		
		if next or isEOF then
			operator 	:= lastLog.myOperator;
//			logVoyage	:= lastLot.myLogVoyage;
			logVoyage	:= lastLot.myLogVoyageStructure.myVoyage;
			terminal 	:= logVoyage.myTerminal;
			globalVoy 	:= logVoyage.myVoyageGlobalArrival;
			voyOper 	:= globalVoy.allVoyOpsByOpTerm[operator.code, terminal.code];
			stevedore 	:= globalVoy.myRoot.allStevedores[voyOper.stevedoreCode1];
			hatch		:= intFaceItem.hatch;
			place		:= intFaceItem.place;
			intFaceItem.bolType	  := BOLType_Log;
			intFaceItem.bolNumber := terminal.bolOutNextSeqNumber;
			if lastLot.myConsignee &lt;&gt; null then
				intFaceItem.consignorCode		:= lastLot.myConsignee.code;
			endif;
			if lastLot.myDischargePort &lt;&gt; null then
				intFaceItem.dischargePort		:= lastLot.myDischargePort.code;
			endif;
			intFaceItem.loadStartDT			:= self.loadStartDT;
			intFaceItem.logGradeCode		:= lastLog.logGradeCode;
			intFaceItem.logSpeciesCode		:= lastLog.logSpeciesCode;
			intFaceItem.lengthRandom		:= lastLog.logLengthCode;
			intFaceItem.logTreatmentCode	:= lastLog.logTreatmentCode;
			intFaceItem.logTypeCode			:= lastLog.logTypeCode;				
			intFaceItem.myConsignee			:= lastLot.myConsignee;									
			intFaceItem.myLogLot 			:= lastLot;
			intFaceItem.myTerminal			:= terminal;
			intFaceItem.myOperator			:= operator;
			intFaceItem.myStevedore			:= stevedore;
			intFaceItem.myVoyage	 		:= logVoyage;				
			intFaceItem.numItems			:= intFaceItem.allEDILogsById.size;
			intFaceItem.operatorCode		:= operator.code;
			intFaceItem.remarks				:= self.fileShortName;
			intFaceItem.myEDIDataBOLOutLog	:= self;
			intFaceItem.unitOfMeasure		:= BOL_UOM_PIECE_COUNT;
			intFaceItem.userCode			:= app.getMyUserCode;
			intFaceItem.transportMode 		:= TI_TRANSMODE_SHIP;				
			intFaceItem.myPlannedLocation 	:= logVoyage.myLogVoyageStructure.getLogVoyController(lastLot.lotNo, hatch, place);
			if intFaceItem.myPlannedLocation = null then
				if pxyLogVoyCntrl = null then
					create pxyLogVoyCntrl transient;
				endif;
				app.writeLog('Creating onship details for ' &amp; lastLot.lotNo &amp; ' H' &amp; hatch.String &amp; ' ' &amp; app.vesselPlaceEnumToStr(place), LogINFO);
				pxyLogVoyCntrl.setProxy(lastLot, logVoyage.myLogVoyageStructure, hatch, place);
				app.myUtilityCA.utlCreateVoyageController(pxyLogVoyCntrl, realLogVoyCntrl, _passport);
				if (not _passport.noErrors()) then
					return false;
				endif;				
				intFaceItem.myPlannedLocation := realLogVoyCntrl;
			endif;
			if cmifMonitor &lt;&gt; null then
				if (not cmifMonitor.updateProgress('Creating Docket ' &amp;intFaceItem.bolNumber &amp;' for ' &amp; intFaceItem.allEDILogsById.size.String &amp; ' logs.', cmifMonitor.partsInJob, numDone)) then
					app.raiseCMException(VB_USER_CANCELED_TRANS, null, null);						
					return false;
				endif;
			endif;
			app.writeLog('Creating bol (' &amp; intFaceItem.bolNumber &amp; ')', LogINFO);
			app.myUtilityCA.utlCreateBOLOutLog(intFaceItem, _passport);
			if (not _passport.noErrors()) then
			
				// code added to give more info to identify the problem

				foreach err in _passport.allErrorWarnings do
					if str = null then
						str := err.text; 
					else
						str := str &amp; '; ' &amp; err.text;
					endif;
				endforeach;
				app.raiseCMException2(EDILogInvalid, lastLog.id, 'unknown (' &amp; str &amp; ')', null, null);		

				return false;
			endif;
			if (not voySet.includes(logVoyage)) then
				voySet.add(logVoyage);
			endif;
			app.writeLog('    BOL ' &amp; intFaceItem.bolNumber &amp; ') created', LogINFO);
			if (not isEOF) then
				intFaceItem.hatch := ediLog.hatch;
				intFaceItem.place := ediLog.place;		
				intFaceItem.myLogLot := ediLog.myLogLot;
				productCode := ediLog.productCode;
				operCode := ediLog.operatorCode;							
				intFaceItem.allEDILogsById.clear();
				intFaceItem.allEDILogsById.add(ediLog);
				lastLog := ediLog;
				lastLot := logLot;				
				next := false;		
			endif;
		endif;
		
		if isEOF then
			break;
		endif;
	endwhile;
	
	foreach voy in voySet do
		if voy.myLogVoyageStructure &lt;&gt; null then 
			if (not self.allLogVoyageStructures.includes(voy.myLogVoyageStructure)) then
				self.allLogVoyageStructures.add(voy.myLogVoyageStructure);
			endif;
		endif;
	endforeach;
	
	return true;
epilog
	delete iter;
	delete voySet;
	delete intFaceItem;
	delete pxyLogVoyCntrl;
end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getAuditText" id="ee672f4e-ee36-46f1-bf68-adaf05f0225c">
        <source>getAuditText(): String;
//
// 05 Aug 2016	cnwrs1	Par 38117 make deleted EDI for finable
//
vars
	auditStr : String;
	tmpStr : String;
	terminal : CM_Terminal;
begin
	auditStr := inheritMethod();
	terminal := self.myTerminal;
	if terminal &lt;&gt; null then
		tmpStr := terminal.auditId;
		auditStr := auditStr &amp; "terminal" &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp; tmpStr;
	endif;
	return auditStr;
end;
</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="7a197680-ce52-4e4d-94bf-94be22d5884d">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
//--------------------------------------------------------------
//Created: 11 December 2002 By: cnwgd1
//--------------------------------------------------------------
vars

begin

	if _attrName = ETRow_SssLOFile then
		return self.fileShortName;	
	elseif _attrName = ETRow_SssDateTime then
		return self.systemToLocalTime(self.createdTime).shortCurrentLocaleFormat();	// 22/4/16 cnwmp6 TFS 488 - Multi timezone support
	elseif _attrName = ETRow_SssEDIStatus then
		return null;			
	elseif _attrName = ETRow_SssUserCode then
		return self.userCode;				
	else
		return inheritMethod(_attrName, _short);
	endif;

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
