    <JadeMethod name="getRemarksString" id="a260e427-99dc-4d79-80e9-bfd11eea99d1">
        <source>getRemarksString():String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 Mar 2020 cnwma1 ChangeRequest 48524: CPL - Credit Invoice Details for Print

*/

constants
	 NoPerLine  = 1;
vars
	invRep   	: CM_ReportInvoiceItem;
	tmp,
	str	   	    : String;
	strArr      : StringArray;
	ti          : CM_TrackedItem;
	size        : Integer;
begin
	create strArr  transient;
	foreach invRep in self.allInvoiceItems do
	
		if invRep.myInvoiceLine &lt;&gt; null then
			if invRep.myInvoiceLine.remarks &lt;&gt; null then
				if not strArr.includes(invRep.myInvoiceLine.remarks) then
					strArr.add(invRep.myInvoiceLine.remarks);
				endif;
			endif;
		endif;
	endforeach;
	
	foreach  tmp in strArr do
		
		if str = null then
			str := tmp;
		else
			str :=  str  &amp; CrLf &amp;tmp ;
		endif;
	endforeach;
	
	
	return str;
epilog
	delete strArr;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getXMLItemCost" id="8bf098a1-e467-47ba-824d-8dbe473ec89c">
        <source>getXMLItemCost() : String;
// 28218 CCMS 2120 Oct 2011 electronic invoicing, method used in report writer
//20 Feb 2018	jlgmd1	TFS 36954 SNO - Error in SCT2 Rate Table  (Swap $CM_RateEntry.decimalPlaces for terminal config)
vars
	result	: String;
	gst,
	net,
	total	: Decimal[18,2];
	dps		: Integer;
begin
	if self.myInvoice &lt;&gt; null then
		dps := self.myInvoice.getRateEntryDecimalPlaces();
	endif;

	result := '&lt;itemcost&gt;' &amp; CrLf &amp;
			  '&lt;currency&gt;NZD&lt;/currency&gt;' &amp; CrLf &amp;
			  //'&lt;unitprice&gt;' &amp; self.rate.asStringJMTWithPrecision($CM_RateEntry.decimalPlaces, false) &amp; '&lt;/unitprice&gt;' &amp; CrLf &amp;
			  '&lt;unitprice&gt;' &amp; self.rate.asStringJMTWithPrecision(dps, false) &amp; '&lt;/unitprice&gt;' &amp; CrLf &amp;		// TFS 36954 MPD 20 Feb 2018
			  '&lt;quantity&gt;' &amp; self.quantity.String &amp; '&lt;/quantity&gt;' &amp; CrLf &amp;
			  '&lt;netamount&gt;' &amp; self.netAmount.String &amp; '&lt;/netamount&gt;' &amp; CrLf &amp;
			  '&lt;gst&gt;' &amp; self.taxAmount.String &amp; '&lt;/gst&gt;' &amp; CrLf &amp;
			  '&lt;totalamount&gt;' &amp; self.totalAmount.String &amp; '&lt;/totalamount&gt;' &amp; CrLf &amp;
			  '&lt;/itemcost&gt;';
	result.encodeUTF8();
	return result;
end;
</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getXMLItemDetails" id="5996f6f7-67c7-4c02-b8bc-b519d27d223d">
        <source>getXMLItemDetails() : String;
// 28218 CCMS 2120 Oct 2011 electronic invoicing, method used in report writer
vars
	result	: String;
begin
	result := '&lt;itemdetails&gt;' &amp; CrLf &amp;
			  '&lt;itemidentifier&gt;' &amp; self.itemIdentifier.xmlReplaceReservedChars(true) &amp; '&lt;/itemidentifier&gt;' &amp; CrLf &amp;
			  '&lt;itemdescription&gt;' &amp; self.itemDescription.xmlReplaceReservedChars(true) &amp; '&lt;/itemdescription&gt;' &amp; CrLf &amp;
			  '&lt;/itemdetails&gt;';
	result.encodeUTF8();
	return result;
end;
</source>
        <ReturnType type="String"/>
    </JadeMethod>
</Class>
