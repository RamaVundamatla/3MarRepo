    <JadeMethod name="populateCriteriaFrames" id="7979f73b-2654-4682-93dd-e6b51d8167be">
        <updating/>
        <source>populateCriteriaFrames() updating;
/*
Purpose:			Populate the individual criteria values and the corresponding free storage options.

Parameters:			

Return Value:		

Date		Who		Reason
24/07/2012	cnwndl1	Initial creation
07/09/2016	cnwdap1	TFS 2570 Stop Completion Free Storage Days
21 Jul 2017	cnwma1	TFS #5409:STWO - Storage Slab Auto Commercial Hold
29/05/2023	navkc1	CR 58011 Task 58012: UI - Storage Config - Storage Detail Receival Date
30/05/2023	navkc1	CR 58013 Task 58014: UI - Storage Config - Storage Detail – Free Storage
16/06/2023	navkc1	CR 58221 Task 58222: UI - Ownership Change Free Days
29/02/2023	navkc1 	CR 61899 Task 61905: UI - Storage Detail
*/
vars
	freeWorkingDays,
	freeCalendarDays,
	freeCalendarMonths	: Boolean;
	chargeWorkingDays,
	chargeCalendarDays,
	chargeCalendarMonths	: Boolean;
	criteria : CM_YACriteriaPriority;
	criteriaFrame : CMUI_YACriteriaCntl;
	storageDetail	: CM_StorageDetail;
	i : Integer;
	propCount : Integer;
	critType : CM_YACriteriaType;
	allCriteria : CM_YACriteriaTypeArray;
	
	freeCompulsoryDays : Boolean;	//20 Sep 2017	NDL	TFS 7032
	chargeCompulsoryDays : Boolean;	//20 Sep 2017	NDL	TFS 7032
	
	storageConfig	: CM_StorageConfig; // 29/05/2023	navkc1	CR 58011 Task 58012
	
begin

	storageDetail := self.myStorageDetail;
	if self.frmCriteria.getControl(1) = null then
		self.loadCriteriaFrames();
	endif;
	
	allCriteria:=self.myTerminal.myStorageConfig.allYACriteriaTypes;
	propCount := allCriteria.size;
	
	foreach i in 1 to propCount do 
		criteriaFrame := self.frmCriteria.getControl(i).CMUI_YACriteriaCntl;
		criteriaFrame.setMasterControl(self.frmCriteria);	//cnwmc5 - PAR 31255
		criteriaFrame.formCriteriaChangeMethodName := null;
		critType := allCriteria[i];
		if critType &lt;&gt; null then
			criteriaFrame.setCriteriaType( critType );
			criteriaFrame.setLabelVisible(true);
			if storageDetail &lt;&gt; null then
				criteria := storageDetail.getCriteriaOfType(critType);
				if criteria &lt;&gt; null then
					criteriaFrame.setCriteria( criteria );
				endif;
			endif;
		endif;
		criteriaFrame.formCriteriaChangeMethodName := CMUI_YACriteriaMaintForm::doCriteriaChanged.name;
	endforeach;
	
	self.isModified := false;
	
	if storageDetail = null then
		// defaults for new storage
		self.setComboIndex(self.cmbFutureStoChrgPeriod, CM_StorageDetail.Calendar_Days);	// 30/05/2023	navkc1	CR 58013 Task 58014
		self.setComboIndex(self.cmbFreeStoPeriod, CM_StorageDetail.Calendar_Days); 			// 30/05/2023	navkc1	CR 58013 Task 58014
		self.setComboIndex(self.cmbRelStoChrgPeriod, CM_StorageDetail.Calendar_Days); 		// 30/05/2023	navkc1	CR 58013 Task 58014
		self.setComboIndex(self.cmbCooFreeDaysType, CM_StorageDetail.Calendar_Days); 		//16/06/2023	navkc1	CR 58221 Task 58222
		
		// 29/05/2023	navkc1	CR 58011 Task 58012
		storageConfig := self.myTerminal.myStorageConfig;
		
		// 29/05/2023	navkc1	CR 58011 Task 58012
		// Same as storage config by default when creating new storage details
		if storageConfig &lt;&gt; null then
			self.setComboIndex(self.cmbShipReceival, storageConfig.shipReceivalType);
			self.setComboIndex(self.cmbTruckReceival, storageConfig.roadReceivalType);
			self.setComboIndex(self.cmbWagonReceival, storageConfig.railReceivalType);
			self.setComboIndex(self.cmbChildReceival, storageConfig.unpackReceivalType);
			
			self.chkIncFirstDay.value := storageConfig.includeFirstDay; //29/02/2023	navkc1 CR 61899 Task 61905
			self.chkIncLastDay.value := storageConfig.includeLastDay; //29/02/2023	navkc1 CR 61899 Task 61905
		endif;
		
	else
		self.txtDesc.text := storageDetail.description[1:200]; // TFS 5225
		
		// existing values
		if storageDetail.freeStorageDays &gt; 999 then // PAR 36275 have set max length of 3 on txt
			self.txtFreeDays.text := "999";
		else
			self.txtFreeDays.text := storageDetail.freeStorageDays.asStringJMT();
		endif;
		
		self.txtChargeDays.text := storageDetail.chargeDays.asStringJMT(); // PAR 36275 new field
		
		self.txtStopFreeDays.text := storageDetail.stopCompletionFreeDays.asStringJMT();	// TFS 2570
		
		// Future Storage tab - Charge day
		self.setComboIndex(self.cmbFutureStoChrgPeriod, storageDetail.chargedDaysType); // 30/05/2023	navkc1	CR 58013 Task 58014
		
		// Free Storage tab - Free storage days
		self.setComboIndex(self.cmbFreeStoPeriod, storageDetail.freeDaysType); // 30/05/2023	navkc1	CR 58013 Task 58014
		
		// Release Storage tab - Release period
		if storageDetail.allFutureStorageMappings.isNotEmpty() and storageDetail.chargedDaysType = CM_StorageDetail.Calendar_Months then
			self.setComboIndex(self.cmbRelStoChrgPeriod, CM_StorageDetail.Calendar_Days); // 30/05/2023	navkc1	CR 58013 Task 58014
		else
			self.setComboIndex(self.cmbRelStoChrgPeriod, storageDetail.chargedDaysType); // 30/05/2023	navkc1	CR 58013 Task 58014
		endif;
		// TFS 4271 self.txtPriority.text := storageDetail.priorityValue.String;
// TFS 5225 reuse for description		self.txtDesc.visible := false; // TFS 4271
// TFS 5225 reuse for description		self.lblDesc.visible := false; // TFS 4271
		
		//epr TFS 2884 19/12/16
		self.optFirstTerminal.value :=storageDetail.receivalDateRule =  CM_StorageDetail.RecievalDateRuleFirstByTerm;
		self.optFirstLocation.value :=storageDetail.receivalDateRule =  CM_StorageDetail.RecievalDateRuleFirstByLocn;
		self.optLastTerminal.value :=storageDetail.receivalDateRule =  CM_StorageDetail.RecievalDateRuleLastByTerm;
		self.optLastLocation.value :=storageDetail.receivalDateRule =  CM_StorageDetail.RecievalDateRuleLastByLocn;
		self.chkNoStorageReceived.value := storageDetail.noStorageIfNotFullyReceived;
		
		//21.07.2017 cnwma1 TFS #5409
		if storageDetail.myFutureStorageStop &lt;&gt; null then
			self.cmbStop.listObject :=storageDetail.myFutureStorageStop;	
		endif;
		
		//30/05/2023	navkc1	CR 58013 Task 58014
		if storageDetail.allFutureStorageMappings.isEmpty() then
			self.cmbRelStoChrgPeriod.enabled := true;
			self.cmbFutureStoChrgPeriod.enabled := false;
		else
			self.cmbRelStoChrgPeriod.enabled := false;
			self.cmbFutureStoChrgPeriod.enabled := true;
		endif;
		
		// 29/05/2023	navkc1	CR 58011 Task 58012
		self.setComboIndex(self.cmbShipReceival, storageDetail.shipReceivalType);
		self.setComboIndex(self.cmbTruckReceival, storageDetail.roadReceivalType);
		self.setComboIndex(self.cmbWagonReceival, storageDetail.railReceivalType);
		self.setComboIndex(self.cmbChildReceival, storageDetail.unpackReceivalType);
		self.setComboIndex(self.cmbCooFreeDaysType, storageDetail.cooFreeDaysType);		//16/06/2023	navkc1	CR 58221 Task 58222
		
		self.txtCooFreeDays.text := storageDetail.cooFreeStorageDays.asStringJMT(); 	//16/06/2023	navkc1	CR 58221 Task 58222
		
		self.chkIncFirstDay.value := storageDetail.includeFirstDay; //29/02/2023	navkc1 CR 61899 Task 61905
		self.chkIncLastDay.value := storageDetail.includeLastDay; //29/02/2023	navkc1 CR 61899 Task 61905
	endif;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setComboIndex" id="a004d3c1-385f-4f5e-ba96-87d0cebd1350">
        <source>setComboIndex(_combo : ComboBox input; _value : Integer);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29/05/2023	navkc1	CR 58011 Task 58012: UI - Storage Config - Storage Detail Receival Date

*/

vars
	idx, tot	: Integer;
begin

epilog
	tot := _combo.listCount();
	
	foreach idx in 1 to tot do
		if _combo.itemData[idx] = _value then
			_combo.listIndex := idx;
			break;
		endif;
	endforeach;
	
end;</source>
        <Parameter name="_combo" type="ComboBox" usage="input"/>
        <Parameter name="_value" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setHeight" id="bbf8a183-7823-4146-aaed-0242b3262329">
        <updating/>
        <source>setHeight( _maxUsed : Integer ) updating;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24/07/2012	cnwndl1	Initial creation	Par 29968
06/09/2016	cnwdap1	TFS 2570 Stop Completion Free Storage Days and rewrite move code
30/05/2023	navkc1	CR 58013 Task 58014: UI - Storage Config - Storage Detail – Free Storage
*/
vars

	newTop	: Real;
	extra	: Real;

begin
	self.fldData.top := 10;
	self.fldData.left := 5;
	self.fldData.width := self.width - 20;
	self.fldData.height := 250;
	self.grpAllCriteria.parent := self.shtCriteria;
	self.lblDesc.parent := self.shtCriteria;
	self.txtDesc.parent := self.shtCriteria;
	self.lblMessage.parent := self.shtCriteria;
	
	self.grpAllCriteria.top := 30;
	self.grpAllCriteria.height := self.shtCriteria.clientHeight - 30; // _maxUsed + 20;
	self.grpAllCriteria.parentAspect := Sheet.ParentAspect_StretchBoth;
	newTop := (_maxUsed + self.grpAllCriteria.top + 10);
	
	
	//18 May 2016	NDL	TFS 1981
	self.lblDesc.top := newTop;
	self.lblDesc.left := 10;
	self.txtDesc.top := newTop;
	self.txtDesc.left := 140; // TFS 5225
	
	//29/02/2023	navkc1 CR 61899 Task 61905
	self.fldData.height := (newTop + 75).max((self.grpFSChargedDays.top + self.grpFSChargedDays.clientHeight + 30) );
	

	self.btnCancel.top := self.fldData.top + self.fldData.height + 10;
	self.btnOK.top := self.fldData.top + self.fldData.height + 10;

	self.btnNext.visible := self.myStorageDetail = null; // TFS 5225
	self.btnNext.top := self.fldData.top + self.fldData.height + 10; // TFS 5225

	newTop := self.btnOK.top + self.btnOK.height + 50; // PAR 36275
	self.height := newTop;

	self.btnNext.zOrder(1); // TFS 5225
	self.btnCancel.zOrder(1);
	self.btnOK.zOrder(1);

	
	// 30/05/2023	navkc1	CR 58013 Task 58014
	self.minimumHeight := self.height.Integer;
	self.minimumWidth := self.width.Integer;
	self.fldData.parentAspect := #3; 	// StretchBoth
	self.btnCancel.parentAspect := #c;	// AnchorBoth
	self.btnOK.parentAspect := #8;		// AnchorBottom
	self.btnNext.parentAspect := #8;	// AnchorBottom
	self.btnCancel.parentRightOffset := 3;
	self.btnOK.left := self.btnCancel.left - 65;
	self.btnNext.left := btnOK.left - 65;
	
	

epilog

end;</source>
        <Parameter name="_maxUsed" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setStorageDetail" id="030ea361-cbfc-4337-9fca-9dce6be75642">
        <updating/>
        <source>setStorageDetail(_storageDetail : CM_StorageDetail) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 September 2012	cnwer1	Initial creation SFW 1295

*/

vars

begin
	self.myStorageDetail :=_storageDetail;
epilog

end;</source>
        <Parameter name="_storageDetail" type="CM_StorageDetail"/>
    </JadeMethod>
    <JadeMethod name="setupForm" id="d7bb2d8f-8e9f-47be-ba60-02516e3a6f0b">
        <updating/>
        <source>setupForm() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 September 2012	cnwer1	Initial creation SFW 1295
21 Jul 2017	cnwma1	TFS #5409:STWO - Storage Slab Auto Commercial Hold
29/05/2023	navkc1	CR 58011 Task 58012: UI - Storage Config - Storage Detail Receival Date
30/05/2023	navkc1	CR 58013 Task 58014: UI - Storage Config - Storage Detail – Free Storage
*/

vars

begin

	self.handleMenusForModalDisplay();
	
	if self.myStorageDetail = null then
		self.caption := app.getErrorString(New_Storage_Detail);
	else
		self.caption := app.getErrorString(Edit_Storage_Detail);
	endif;
	//if self.myStorageDetail &lt;&gt; null and								// TFS 2570
	//   self.myStorageDetail.allFutureStorageMappings.size &gt; 0 then	// TFS 2570
	//	self.chkUseFS.value := true;									// TFS 2570
	//endif;															// TFS 2570
	//self.txtChargeDays.visible := chkUseFS.value;						// TFS 2570
	self.initStopsCombo();		//21.07.2017 cnwma1 TFS #5409
	
	self.lblReceivalOpts.width := 600; // TFS 44933
	self.chkNoStorageReceived.width := 600; // TFS 44933
	
	self.initReceivalCombo(); 	// 29/05/2023	navkc1	CR 58011 Task 58012
	self.initChargeDayCombo(); 	// 30/05/2023	navkc1	CR 58013 Task 58014
	self.initCalendarMsg(); 	// 30/05/2023	navkc1	CR 58013 Task 58014
	inheritMethod();
	
	

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="showMappingForm" id="2c90e5b7-d0e2-40db-9d53-295b24a33996">
        <source>showMappingForm();

vars

begin
	// don't show if no storage detail created yet
	if self.myStorageDetail &lt;&gt; null then
		self.myAssistant.INV_Assistant.showFutureStorageMapping(self.myTerminal, self.myStorageDetail);
	endif;
end;
</source>
    </JadeMethod>
    <JadeMethod name="translateForm" id="91870bab-617f-4d44-b52d-0bc0e19bb2e7">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 04 March 2024 15:49:21.
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0022925, locale);
	btnApply.translateCaption(Xlat_0026099, locale);
	btnFSMapping.translateCaption(Xlat_0022105, locale);
	btnViewAudit.translateCaption(Xlat_0026100, locale);
	chkIncFirstDay.translateCaption(Xlat_0026759, locale);
	chkIncLastDay.translateCaption(Xlat_0026760, locale);
