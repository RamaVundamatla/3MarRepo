    <JadeMethod name="getMatchPriority" id="19ad9287-06f7-4dbe-b194-84420e4c3f76">
        <source>getMatchPriority(arbiter: CM_RTQueueArbiter io; _fromLocation: CM_LocationsController; _toLocation: CM_LocationsController): Integer;
/*

Purpose:			

Parameters:			

Return Value:		


Date				Who		Reason
11 August 2011		cnwer1	Initial creation CCMS MES 1033
// ### JIRA 35862 08SEP2025 NAVAB1 added Tab for collapsible View
07 November 2025	jlizm1	MTN 36328 Rotabox Assign Release To Vessel Unit Test
*/

vars

	voyageJob:  CM_VoyageJob;
	loggingText	: String;
	isForVoyageAlloc : Boolean;
	tmpWP : CM_Object;
	
begin

	if arbiter.job.allRequests.size &gt; 0 then
		isForVoyageAlloc := arbiter.job.isVoyageAllocLoad; //cnwrd1 ccms 1303
	endif;


	if not arbiter.job.hasBulkReleaseItem and 
		not isForVoyageAlloc and
		inheritMethod(arbiter,_fromLocation,_toLocation) = Match_Fail then
		// voyage doesn't match
		arbiter.writeLoggingText(Tab &amp; "Priority Final: " &amp; Match_Fail.String &amp; " (Voyage does not match)");
		return Match_Fail;
	endif;

	// check job is for this crane
// TFS 4859	if not (arbiter.job.isKindOf(CM_VoyageDeckJob) 
// TFS 4859	or arbiter.job.isKindOf(CM_VoyageROROJob)) then // PAR 34743
	
	if arbiter.job.isVoyageJob() then // TFS 4859 this means LOLO job
// TFS 4859		arbiter.writeLoggingText("Priority Final: " &amp; Match_Fail.String &amp; " (Job not a Voyage Deck Job)");
		arbiter.writeLoggingText(Tab &amp; "Priority Final: " &amp; Match_Fail.String &amp; " (Job not a Work Point Job)"); // TFS 4859
		return Match_Fail;
	endif;

	
	if arbiter.job.isKindOf(CM_VoyageDeckJob) then
		voyageJob := arbiter.job.CM_VoyageDeckJob;
		// PAR 24866
		if voyageJob.myVoyage &lt;&gt; self.myVoyage then
			arbiter.writeLoggingText(Tab &amp; "Priority Final: " &amp; Match_Fail.String &amp; " (Voyages do not match)");
			return Match_Fail;
		endif;
	
		if voyageJob.CM_VoyageDeckJob.getMyWorkPoint = self.myWorkPoint then
			arbiter.writeLoggingText(Tab &amp; "Priority Final: " &amp; Match_Crane.String &amp; " (Work Point found for voyage)");
			return Match_Crane;
		endif;
	else // PAR 34743
		if arbiter.job.isKindOf(CM_VoyageROROJob) then
			voyageJob := arbiter.job.CM_VoyageROROJob;
			if voyageJob.myVoyage &lt;&gt; self.myVoyage then
				arbiter.writeLoggingText(Tab &amp; "Priority Final: " &amp; Match_Fail.String &amp; " (Voyages do not match)");
				return Match_Fail;
			endif;
		
			if voyageJob.CM_VoyageROROJob.craneId = self.myWorkPoint.code then
				arbiter.writeLoggingText(Tab &amp; "Priority Final: " &amp; Match_Crane.String &amp; " (Work Point found for voyage)");
				return Match_Crane;
			endif;
		elseif arbiter.job.isVoyageHoldJob() then // TFS 4859
			voyageJob := arbiter.job.CM_VoyageHoldJob;
			if voyageJob.myVoyage &lt;&gt; self.myVoyage then
				arbiter.writeLoggingText(Tab &amp; "Priority Final: " &amp; Match_Fail.String &amp; " (Voyages do not match)");
				return Match_Fail;
			endif;
		
			if voyageJob.CM_VoyageHoldJob.craneId = self.myWorkPoint.code then
				arbiter.writeLoggingText(Tab &amp; "Priority Final: " &amp; Match_Crane.String &amp; " (Work Point found for voyage)");
				return Match_Crane;
			endif;
			
			tmpWP := self.myVoyage.allCranesWPByHolds.getAtKey(_toLocation);
			if tmpWP &lt;&gt; null and tmpWP.isKindOf(CM_WorkPoint) and tmpWP.CM_WorkPoint.code = self.myWorkPoint.code then
				arbiter.writeLoggingText(Tab &amp; "Priority Final: " &amp; Match_Crane.String &amp; " (Work Point found for voyage)");
				return Match_Crane;
			endif;
		endif;
	
	endif;
	
	arbiter.writeLoggingText(Tab &amp; "Priority Final: " &amp; Match_Fail.String &amp; " (Work Point not found)");
	return Match_Fail;
epilog
end;</source>
        <Parameter name="arbiter" type="CM_RTQueueArbiter" usage="io"/>
        <Parameter name="_fromLocation" type="CM_LocationsController"/>
        <Parameter name="_toLocation" type="CM_LocationsController"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
