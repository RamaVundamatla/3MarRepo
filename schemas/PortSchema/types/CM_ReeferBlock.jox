        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getAuditTextDescription" id="b6801b18-8ce0-46b4-8350-f9ce677e7a37">
        <source>getAuditTextDescription():String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 July 2020	jlgndl1	Initial creation	TFS 49579

*/

vars

	str	: String;
	reeferWalkPosition : CM_ReeferBlockPosition;
	addComma : Boolean;
	rtnStr : String;

begin

	str := 'locations -';	
	foreach reeferWalkPosition in self.allReeferPositions do
		if addComma then
			str :=  str &amp; ", " &amp; reeferWalkPosition.getDisplay(false);
		else
			addComma := true;
			str :=  str &amp; reeferWalkPosition.getDisplay(false);
		endif;
	endforeach;	
	
	rtnStr := self.auditIdDisplay &amp;  AuditStringSeparator &amp; str.length.String &amp; AuditStringSeparator &amp; str &amp; AuditStringSeparator;
	return rtnStr;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getCurrentTis" id="7be88b23-16bf-440e-91be-418e56e7233a">
        <source>getCurrentTis( _tisInWalk : CM_TIArray input );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 July 2020	jlgndl1	Initial creation	TFS 49579

*/

vars

	reeferPos : CM_ReeferBlockPosition;
	ti : CM_TrackedItem;

begin

	_tisInWalk.clear();
	
	foreach reeferPos in self.allReeferPositions do
		ti := reeferPos.getCurrentTi();
		if ti &lt;&gt; null then
			_tisInWalk.addExclusive( ti );
		endif;
	endforeach;


epilog

end;</source>
        <Parameter name="_tisInWalk" type="CM_TIArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getReeferJobs" id="8ad838f7-0726-4ba7-b38d-8cec2b307fab">
        <source>getReeferJobs( 	_yardActivityType : Integer; 
				_includeFutureActivity : Boolean;
				_yardActivities : CM_YardActivityArray input
				);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 July 2020	jlgndl1	Initial creation	TFS 49581

*/

vars

	tisInWalk : CM_TIArray;
	ti : CM_TrackedItem;

begin

	create tisInWalk transient;
	self.getCurrentTis( tisInWalk );

	foreach ti in tisInWalk do
		ti.getReeferActivity( _yardActivityType, _includeFutureActivity, _yardActivities );
	endforeach;

epilog

	delete tisInWalk;

end;</source>
        <Parameter name="_yardActivityType" type="Integer"/>
        <Parameter name="_includeFutureActivity" type="Boolean"/>
        <Parameter name="_yardActivities" type="CM_YardActivityArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getReefersWithCurrentJobs" id="aa1591bd-9930-487d-9d70-6e00182aa2b6">
        <source>getReefersWithCurrentJobs( _tiArray : CM_TIArray input );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 July 2020	jlgndl1	Initial creation	TFS 49581

*/

vars

	tisInWalk : CM_TIArray;
	ti : CM_TrackedItem;

begin

	create tisInWalk transient;
	self.getCurrentTis( tisInWalk );

	foreach ti in tisInWalk do
		if ti.hasCurrentReeferJob() then
			_tiArray.add( ti );
		endif;
	endforeach;

epilog

	delete tisInWalk;

end;</source>
        <Parameter name="_tiArray" type="CM_TIArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getReefersWithJobs" id="e163f2c2-29ac-4f5e-852c-20d28fff2c36">
        <source>getReefersWithJobs( _tiArray : CM_TIArray input );
/*

Purpose:			

Parameters:			Same as getReefersWithCurrentJobs BUT for  future jobs too.

Return Value:		

Date		Who		Reason
10 August 2020	jlgndl1	Initial creation	TFS 49581

*/

vars

	tisInWalk : CM_TIArray;
	ti : CM_TrackedItem;

begin

	create tisInWalk transient;
	self.getCurrentTis( tisInWalk );

	foreach ti in tisInWalk do
		if ti.hasAnyReeferJob() then
			_tiArray.add( ti );
		endif;
	endforeach;

epilog

	delete tisInWalk;

end;</source>
        <Parameter name="_tiArray" type="CM_TIArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getReefersWithoutJobs" id="8705960a-5258-4341-aa95-c4db3a21e9b6">
        <source>getReefersWithoutJobs(_tiArray : CM_TIArray input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 October 2022	navsp1	Initial creation - ChangeRequest 54899: PEN - Reefer Monitor App Changes

*/

vars

	tisInWalk : CM_TIArray;
	ti : CM_TrackedItem;

begin

	create tisInWalk transient;
	self.getCurrentTis( tisInWalk );

	foreach ti in tisInWalk where ti.isReefer do
		if not ti.hasAnyReeferJob() then
			_tiArray.add( ti );
		endif;
	endforeach;

epilog

	delete tisInWalk;

end;</source>
        <Parameter name="_tiArray" type="CM_TIArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="hasReeferWalkIncluding" id="2abf370a-3b98-47d5-a7b0-cdcccae8dbc0">
        <source>hasReeferWalkIncluding( _lc : CM_LocationsController; _tier : Integer ):Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 July 2020	jlgndl1	Initial creation	TFS 49579

*/

vars

begin

	return self.allReeferPositions.getReeferWalkIncluding( _lc, _tier ) &lt;&gt; null;

epilog

end;</source>
        <Parameter name="_lc" type="CM_LocationsController"/>
        <Parameter name="_tier" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="96ab42a4-a59f-4bc4-a42b-68318d2fea7c">
        <updating/>
        <source>setForCreate( _pxyReeferBlock : CM_ReeferBlock; _reeferWalkPositionArray : CM_ReeferBlockPositionArray ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
