    <JadeMethod name="rstEst1" id="6c213592-ee03-4aa2-9da3-4fc675bc3613">
        <source>rstEst1();

vars
	ts : TimeStamp;
	logPath : String;
	pos : Integer;
begin
	ts := app.actualTimeServer();
	pos := 1;
	logPath	:= app.getProfileString(app.getIniFileName, "CardLog", "LogPath", app.dbPath[1 : pos -1] &amp; "/logs");
	write logPath;
end;
</source>
    </JadeMethod>
    <JadeMethod name="setAuditLogNumberToCurrent" id="2211a766-f37f-4abf-a747-b20e12bbbc54">
        <source>setAuditLogNumberToCurrent();
vars
	mgr, mgrT: JSSCTNibblerManager;
	num: Integer;
	currentLogNumber : Integer;
	dBAdminObject : JadeDatabaseAdmin;
begin
	create dBAdminObject transient;
	mgr := JSSCTNibblerManager.firstInstance;

	if mgr &lt;&gt; null then
		num := mgr.lastAuditFileNumber;
		currentLogNumber := dBAdminObject.getCurrentLogNumber();
		beginTransaction;
		exclusiveLock (mgr);
		mgr.setPropertyValue("lastAuditFileNumber", currentLogNumber);
		mgr.setPropertyValue("lastJade5Log", 0);
		commitTransaction;
//		mgr.inspect;

		write "audit number was "&amp;num.String&amp;" is now  " &amp; mgr.lastAuditFileNumber.String;
	else
	 	write "Nibbler manager not found";
	endif;
epilog
	delete dBAdminObject;
end;
</source>
    </JadeMethod>
    <JadeMethod name="setForUpgrade" id="56ebcfe7-3e64-4ef3-8e2c-5b0ec5615ea8">
        <source>setForUpgrade();

vars
	root: JSSCTChangeTrackingRoot;
	timeDict: JSSCTChangeByTimeDict;
	classObject: JSSCTChangeTrackingClass;
	changeTrackingObject: JSSCTChangeTrackingObject;
	count1,count2,count3: Integer;
begin
	root := JSSCTChangeTrackingRoot.firstInstance;
	beginTransaction;
	foreach timeDict in root.allChangesByTimeDicts do
		count1 := count1 + 1;
		create classObject;
		count2 := count2 + 1;
		classObject.setClassName(timeDict.className);
		classObject.setInitializing(timeDict.initializing);
		classObject.setIsDelete(timeDict.isDelete);
		root.addClassObject(classObject, false);
		foreach changeTrackingObject in timeDict.allChangesByOidDict do
			if global.isValidObject(changeTrackingObject) then
				classObject.addTrackingObject(changeTrackingObject);
//				changeTrackingObject.setMyCTOidClass(classObject);
//				changeTrackingObject.setItsDelete(timeDict.isDelete);
				count3 := count3 + 1;
				if (count3 mod 50000 = 0) then
					commitTransaction;
					write class.name&amp;"::"&amp;method.name&amp;' '&amp;timeDict.className&amp;" &lt;&lt; "&amp;count3.String;
					beginTransaction;		
				endif;
			endif;
		endforeach;
	endforeach;
	foreach timeDict in root.allDeletesByTimeDicts do
		count1 := count1 + 1;
		create classObject;
		classObject.setClassName(timeDict.className);
		classObject.setInitializing(timeDict.initializing);
		classObject.setIsDelete(timeDict.isDelete);
		root.addClassObject(classObject, true);
		count2 := count2 + 1;
		foreach changeTrackingObject in timeDict.allChangesByOidDict do
			if global.isValidObject(changeTrackingObject) then
				classObject.addTrackingObject(changeTrackingObject);
				changeTrackingObject.setIsDelete(true);
//				changeTrackingObject.setMyCTOidClass(classObject);
//				changeTrackingObject.setItsDelete(timeDict.isDelete);
				count3 := count3 + 1;
				if (count3 mod 50000 = 0) then
					commitTransaction;
					write class.name&amp;"::"&amp;method.name&amp;' '&amp;timeDict.className&amp;" &lt;&lt; "&amp;count3.String;
					beginTransaction;		
				endif;
			endif;
		endforeach;
	endforeach;
	commitTransaction;
	write class.name&amp;"::"&amp;method.name&amp;" &lt;&lt; "&amp;count1.String&amp;" &lt;&lt; "&amp;count2.String&amp;" &lt;&lt; "&amp;count3.String;
end;</source>
    </JadeMethod>
