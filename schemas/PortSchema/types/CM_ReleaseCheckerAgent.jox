<Class name="CM_ReleaseCheckerAgent" id="85823603-22ca-4aaa-b895-e2a0bbdbf39c">
    <superclass name="CM_Transient"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="cmtrans"/>
    <JadeMethod name="ignoreScenarioRootMappings" id="dc2f3bca-d9ec-4053-ad0e-27b9d0de38c1">
        <source>ignoreScenarioRootMappings(_sa : StringArray input) protected;
// ---------------------------------------------------------------------------
// Created:     07 April 2008 by cnwrs2
//
// Purpose:     Returns a string array of CM_Root properties that do not need
//				to be mapped on CM_RootScenario so can be ignored by the check
// ---------------------------------------------------------------------------
/* Changes

Date		Name	TFS#		Description
============================================================================
24/09/2019 	jlgka1 	TFS 45614 	JMT - Refactoring remove Voyage Commodity Scenario mode
============================================================================*/

begin

	_sa.add(CM_Root::_persistentImpRefs.name);
	_sa.add(CM_Root::_transientImpRefs.name);
	_sa.add(CM_Root::coloursForTALevels.name);
	_sa.add(CM_Root::createdTime.name);
	_sa.add(CM_Root::oidAsBin.name);
	_sa.add(CM_Root::oidAsHex.name);
	
	
	// the following references/collections are specifically left
	// as null/empty in the scenario
	_sa.add(CM_Root::myRootCompany.name);	// do not want any possibility of invoicing occuring from a scenario
	_sa.add(CM_Root::allEventsByDateTime.name);
	_sa.add(CM_Root::allEventsByTypeDateTime.name);
	_sa.add(CM_Root::allMessages.name);
	_sa.add(CM_Root::allStateObjects.name);	// getConfig method handles this lookup.
	_sa.add(CM_Root::allSystemAlerts.name);
	
	// The classes in the following collections are cloned, or should be cloned if required
	_sa.add(CM_Root::allDebtors.name);
	_sa.add(CM_Root::allHarbours.name);
	_sa.add(CM_Root::allMachines.name);	// need to add a scenerio link class if required
	//_sa.add(CM_Root::allScenarios.name); //jlgka1 TFS 45614
	_sa.add(CM_Root::allTerminals.name);
	_sa.add(CM_Root::allTiMasters.name);	// need to add a scenerio link class if required
	//_sa.add(CM_Root::allTIMasterGroups.name);	//Par 17769
	_sa.add(CM_Root::allVoyagesGlobal.name);
	_sa.add(CM_Root::allVoyagesGlobalArchived.name);
	
	


end;</source>
        <access>protected</access>
        <Parameter name="_sa" type="StringArray" usage="input"/>
    </JadeMethod>
</Class>
