    <JadeMethod name="addLocationForSplitQ" id="f7023bee-6233-4430-ad3f-1b2bfa38bc2e">
        <source>addLocationForSplitQ( _ya : CM_YardAllocation; _location : CM_LocationsController ):Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 June 2016	cnwndl1	Initial creation	TFS 2172

*/

vars

begin

	if not self.tiIsSplittable() then
		return false;
	endif;
	
	if _ya &lt;&gt; null and _ya.allowMultiRangeSplit = 0 then
		return false;
	endif;

	self.allLocationsForSplit.addExclusive(_location);

epilog

end;</source>
        <Parameter name="_ya" type="CM_YardAllocation"/>
        <Parameter name="_location" type="CM_LocationsController"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="addToFoundLocations" id="c18f19a1-319b-4d49-8abe-07280598243e">
        <updating/>
        <source>addToFoundLocations( _location : CM_LocationsController ) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
29 February 2012	cnwndl1	Initial creation	Par 29195

*/

vars

begin

	self.allFoundLCs.add( _location );
	
	if app.myYAAgent &lt;&gt; null then
		if self.allFoundLCs.size = 1 then
			self.myFirstUsedYA := app.myYAAgent.myCurrentAllocation;
		endif;
	endif;

epilog

end;</source>
        <Parameter name="_location" type="CM_LocationsController"/>
    </JadeMethod>
