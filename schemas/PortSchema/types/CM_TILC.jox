    <JadeMethod name="getNextFreeLC" id="c46a7736-ade4-44c7-be77-6d72831343d6">
        <source>getNextFreeLC() : CM_TILCController;

/*

Purpose:			

Parameters:			

Return Value:		


 cnwjk3 CCMS1035 04/10/09
 Code added to move cargo to chassis when chassis is moved
*/

vars
	lc : CM_TILCController; 
begin

	//25 Nov 2020	NDL`TFS 50430 - ASPA process always uses the 1st position.
	if self.myTerminal.roadProcessIsASPA then
		return  self.allLCs.first;
	endif;

	//jlier1 TFS 54700 
	if self.myTerminal.getConfig(IgnoreTrailerTypeTEUCap).Boolean then
		return self.allLCs.first;
	endif;
	
	foreach lc in self.allLCs do
		//epr par 34576 18/7/14
		if not lc.hasContainers(true,true) then
			return lc;
		endif;
	endforeach;
	return null;
epilog

end;</source>
        <ReturnType type="CM_TILCController"/>
    </JadeMethod>
    <JadeMethod name="getODDescription" id="43a2d80e-b2b2-4b4b-8e1d-e8972af1d96f">
        <source>getODDescription(): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25 January 2024	jlier1	Initial creation 61809

*/

vars
	tmpString : String;
begin
	if not self.isOverDimensions then
		return null;
	endif;
	
	if self.overHeight &gt; 0 then
		tmpString := tmpString &amp; " H: " &amp; self.overHeight.asStringMeasurementJMT();
	endif;
	
	if self.overWidth &gt; 0 then
		tmpString := tmpString &amp; " W: " &amp; self.overWidth.asStringMeasurementJMT();
	endif;

	if self.overLength &gt; 0 then
		tmpString := tmpString &amp; " L: " &amp; self.overLength.asStringMeasurementJMT();
	endif;
	
	tmpString := tmpString.trimBlanks();
	
	return tmpString;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getOnboardCargoId" id="f315ab74-6f02-4e18-becf-094eac571b18">
        <source>getOnboardCargoId(): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
28 March 2023	navmk20	Task 57224: Jade - New MAFI Columns
14 Mar 2024	jlika1	TFS 62803 CUX | Onboard cargo - new get methods and additional locations
*/

vars
	lc : CM_LocationsController;
	ti : CM_TrackedItem;
	tmpStr, cargoId : String;
    failedDAC       :CM_DataAccessController;       //JIRA-34864 
begin
	foreach lc in self.allLCs do
		foreach ti in lc.allTrackedItems do
			
            if not ti.canUserAccessSelf(null, failedDAC, app.myPassport) then           //JIRA-34864 
                continue;                                                               //JIRA-34864
            endif;                                                                      //JIRA-34864
            
            cargoId := ti.id;
			
			/*
			if tmpStr = null then
				tmpStr := cargoId;
			elseif tmpStr.pos(cargoId, 1) = 0 then
				tmpStr := tmpStr &amp; ', ' &amp; cargoId;
			endif;
			*/
			
			tmpStr.addStringToList(cargoId, ", "); //04/04/2025	navkc1 JIRA Story MTN-33940
			
			if ti.isKindOf( CM_TILC ) then
				cargoId := ti.getOnboardCargoId();
				if cargoId &lt;&gt; null then
					tmpStr := tmpStr &amp; ', ' &amp; cargoId;
				endif;
			endif;
		endforeach;
	endforeach;
	return tmpStr;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getOnboardCargoTypes" id="06738d86-33bf-4f7f-add5-bfe6789e94ba">
        <source>getOnboardCargoTypes() : String;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
28 March 2023	navmk20	Task 57224: Jade - New MAFI Columns
14 Mar 2024	jlika1	TFS 62803 CUX | Onboard cargo - new get methods and additional locations
*/

vars
	lc : CM_LocationsController;
	ti : CM_TrackedItem;
	tmpStr, cargoType : String;
    failedDAC       :CM_DataAccessController;       //JIRA-34864 
begin
	foreach lc in self.allLCs do
		foreach ti in lc.allTrackedItems do
            if not ti.canUserAccessSelf(null, failedDAC, app.myPassport) then           //JIRA-34864 
                continue;                                                               //JIRA-34864
            endif;                                                                      //JIRA-34864
			cargoType := ti.cargoTypeDescr;
			/*
			if tmpStr = null then
				tmpStr := cargoType;
			elseif tmpStr.pos(cargoType, 1) = 0 then
				tmpStr := tmpStr &amp; ', ' &amp; cargoType;
			endif;
			*/
			
			tmpStr.addStringToList(cargoType, ", "); //04/04/2025	navkc1 JIRA Story MTN-33940
			
			if ti.isKindOf( CM_TILC ) then
				cargoType := ti.getOnboardCargoTypes();
				if cargoType &lt;&gt; null then
					tmpStr := tmpStr &amp; ', ' &amp; cargoType;
				endif;
			endif;
		endforeach;
	endforeach;
	return tmpStr;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getOnboardCommodities" id="3f6f9bab-d0e1-499f-8957-2c4a89e878ca">
        <source>getOnboardCommodities(): String;
/*****************************************************
Author		: jlika1 (Karen Alexander)
Date		: 08 March 2024
TFS#		: 62803
Function	: Onboard Commodities - a deduplicated list of commodities onboard the MAFI/trailer

*** Changes ***
Date			Name		TFS#		Description

****************************************************/
vars
	locationController	: CM_LocationsController;
	trackedItem			: CM_TrackedItem;
	tmpStr, 
	commodities 		: String;
    failedDAC           :CM_DataAccessController;       //JIRA-34864 
begin
	foreach locationController in self.allLCs do
		foreach trackedItem in locationController.allTrackedItems do
			if not trackedItem.canUserAccessSelf(null, failedDAC, app.myPassport) then  //JIRA-34864 
                continue;                                                               //JIRA-34864
            endif;                                                                      //JIRA-34864
            commodities := trackedItem.commodity;
			
			/*
			if commodities &lt;&gt; null then
				if tmpStr = null then
					tmpStr := commodities;
				elseif tmpStr.pos(commodities, 1) = 0 then
					tmpStr := tmpStr &amp; ', ' &amp; commodities;
				endif;
			endif;
			*/
			
			tmpStr.addStringToList(commodities, ", "); //04/04/2025	navkc1 JIRA Story MTN-33940
			
			if trackedItem.isKindOf( CM_TILC ) then 
				commodities := trackedItem.getOnboardCommodities();
				if commodities &lt;&gt; null then
					tmpStr := tmpStr &amp; ', ' &amp; commodities;
				endif;
			endif;
		endforeach;
	endforeach;
	
	return tmpStr;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getOnboardConsignee" id="910b61e4-47ea-4559-94e4-66e1e5075dfa">
        <source>getOnboardConsignee(): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
27 Jan 2025		navcs2	MTN-33832 CUX | Selector queries based on Onboard fields - changes required

*/

vars
	locationController	: CM_LocationsController;
	trackedItem			: CM_TrackedItem;
	tmpStr, 
	consignee			: String;
	consignor			: String;
    failedDAC           :CM_DataAccessController;       //JIRA-34864 
begin
	foreach locationController in self.allLCs do
		foreach trackedItem in locationController.allTrackedItems do
            if not trackedItem.canUserAccessSelf(null, failedDAC, app.myPassport) then  //JIRA-34864 
                continue;                                                               //JIRA-34864
            endif;                                                                      //JIRA-34864
            consignee := trackedItem.consignee;
			
			/*
			if consignee &lt;&gt; null then
				if tmpStr = null then
					tmpStr := consignee;
				elseif tmpStr.pos(consignee, 1) = 0 then
					tmpStr := tmpStr &amp; ', ' &amp; consignee;
				endif;
			endif;
			*/
			
			tmpStr.addStringToList(consignee, ", "); //04/04/2025	navkc1 JIRA Story MTN-33940
			
			if trackedItem.isKindOf( CM_TILC ) then 
				consignee := trackedItem.getOnboardConsigneeConsignor();
				if consignee &lt;&gt; null then
					tmpStr := tmpStr &amp; ', ' &amp; consignee;
				endif;
			endif;
		endforeach;
	endforeach;
	
	return tmpStr;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getOnboardConsigneeConsignor" id="9af9587e-5cfd-473a-8dae-39f5bff08e96">
        <source>getOnboardConsigneeConsignor(): String;
/*****************************************************
Author		: jlika1 (Karen Alexander)
Date		: 08 March 2024
TFS#		: 62803
Function	: Onboard Consignor/Consignee - a deduplicated list of both consignees and consignors for cargo items onboard a MAFI/trailer

*** Changes ***
Date			Name		TFS#		Description

****************************************************/
vars
	locationController	: CM_LocationsController;
	trackedItem			: CM_TrackedItem;
	tmpStr, 
	consignee			: String;
	consignor			: String;
    failedDAC           :CM_DataAccessController;
begin
	foreach locationController in self.allLCs do
		foreach trackedItem in locationController.allTrackedItems do
			
            if not trackedItem.canUserAccessSelf(null, failedDAC, app.myPassport) then  //JIRA-34864 
                continue;                                                               //JIRA-34864
            endif;                                                                      //JIRA-34864
            
            consignee := trackedItem.consignee;
			
			/* 
			if consignee &lt;&gt; null then
				if tmpStr = null then
					tmpStr := consignee;
				elseif tmpStr.pos(consignee, 1) = 0 then
					tmpStr := tmpStr &amp; ', ' &amp; consignee;
				endif;
			endif;
			*/
			
			tmpStr.addStringToList(consignee, ", "); //04/04/2025	navkc1 JIRA Story MTN-33940
			
			consignor := trackedItem.consignor;			
			
			/*
			if consignor &lt;&gt; null then
				if tmpStr = null then
					tmpStr := consignor;
				elseif tmpStr.pos(consignor, 1) = 0 then
					tmpStr := tmpStr &amp; ', ' &amp; consignor;
				endif;
			endif;
			*/
			
			tmpStr.addStringToList(consignor, ", "); //04/04/2025	navkc1 JIRA Story MTN-33940
			
			if trackedItem.isKindOf( CM_TILC ) then 
				consignee := trackedItem.getOnboardConsigneeConsignor();
				if consignee &lt;&gt; null then
					tmpStr := tmpStr &amp; ', ' &amp; consignee;
				endif;
			endif;
		endforeach;
	endforeach;
	
	return tmpStr;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
