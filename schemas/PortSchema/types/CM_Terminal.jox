<Class name="CM_Terminal" id="67d9aa8a-dea8-4db4-9a7d-29641934e977">
    <superclass name="CM_Object"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>This is the Root object class for the System. It is responsible for providing the entry points to
most of the major dictionaries, apart from the locations dictionaries, that are
held under the terminal areas.

RJS - need to add allUnmatchedLogBOLs  CM_BOLExtLogInByTypeNumDTDict</text>
    <DbClassMap file="terminal"/>
    <Constant name="RT_CriteriaLimit" id="2ba84a34-16fd-41cf-86fa-8b84b55e15e7">
        <source>4</source>
        <type name="Integer"/>
        <text>This class constant indicates the maximum number of Allocation Criteria that can be allocated to any one Terminal for the purposes of the RT mobile screens.</text>
    </Constant>
