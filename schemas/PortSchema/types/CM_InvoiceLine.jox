//		taxRate := self.charges.first().getTaxRateForCharge();			//18.8.2023 navlc30 #59481
		charge := self.charges.first();									//18.8.2023 navlc30 #59481				
		if charge &lt;&gt; null then											//18.8.2023 navlc30 #59481
			taxRate := charge.getTaxRateForCharge();
