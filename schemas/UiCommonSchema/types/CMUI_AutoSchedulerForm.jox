        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblTaskDisplay_click(table: Table input) updating;

// cnwdvb1 11 February 2003 

vars

	task : CM_AutoTask;

begin

	task := self.getSelectedDisplayTask();
	if task &lt;&gt; null and (self.state = State_View or self.state = State_EditTask or self.state = State_NewTask) then
		self.selectedTaskRow := self.tblTaskDisplay.row;
		self.mySelectedAutoTask := task;
		self.tblTaskCreation.userInputEnabled := false;
		self.doLoadTaskTable(task);
		
	endif;

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
