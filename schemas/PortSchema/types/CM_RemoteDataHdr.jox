    <JadeMethod name="xmlResponse" id="d7d3f8e0-f50d-436e-82a6-57b388dd5909">
        <updating/>
        <source>xmlResponse(_err : Integer; _errText : String) : String updating;

vars

	response	: String;
	theTimeStr	: String;
	theDate		: Date;
	theTime		: Time;
	device		: String;
	

begin

	if self.myRadioTelemetryDevice &lt;&gt; null then
		device := self.myRadioTelemetryDevice.id;
	else
		device := 'Invalid(' &amp; self.deviceId &amp; ')';
	endif;	

	theTimeStr	:= 	theDate.formatAsYYYYMMDD() &amp; theTime.format('HHmmss');
	response 	:= 	self.formatAsXMLPrefix(XML_HDR) &amp;	
					self.formatAsXML(XML_MSGTYPE, self.getMessageResponseType) &amp;
					self.formatAsXML(XML_MSGID, self.messageId) &amp; 
					self.formatAsXML(XML_DEVICEID, device);

	response := response &amp; 
				self.formatAsXML(XML_ERRNO, _err.String);
				
	if _err &lt;&gt; 0 then
		self.setError(_err,_errText[1:100]);
		response := response &amp; self.formatAsXML(XML_ERRTXT, _errText);
	endif;
	response := response &amp;
				self.formatAsXML(XML_TIME, theTimeStr) &amp; 
				self.formatAsXML(XML_VERSION, self.theVersion.String) &amp;
				self.formatAsXMLSuffix(XML_HDR);				
			
	return response;

end;</source>
        <Parameter name="_err" type="Integer"/>
        <Parameter name="_errText" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
</Class>
