    <JadeMethod name="getHelpFileNames" id="b646937e-ec61-47c3-9cf7-4b9a484730f1">
        <source>getHelpFileNames(_fileNameArray : StringArray input);
// ---------------------------------------------------------------------------
// Created:     23 April 2004	cnwth2
//
// Purpose:     Returns the help file names the user should have access to
//			 
// ----------   ----------  --------------------------------------------------
// 26/04/2018	jlgdap1		TFS 38023 JMT New Web Portal User's Guide
// 29/01/2019	jlgdi1		TFS 42424 Added JMT Tallyman App Guide
begin
	if _fileNameArray = null then
		return;
	endif;
	
	_fileNameArray.add(HelpFile_IndexFolder);
	_fileNameArray.add(HelpFile_Index);
	_fileNameArray.add(HelpFile_UsersGuide);
	
	_fileNameArray.add(HelpFile_GeneralGuide);	//07 Nov 2017	NDL	TFS 7276
	
	// 22/9/2006 (PAR12495)
	_fileNameArray.add(HelpFile_JMTReleaseInfo);
	
	if self.isAdministrator then
		_fileNameArray.add(HelpFile_Admin);
	endif;
	
	//07 Nov 2017	NDL	TFS 7276
	// ### JIRA 33505 03DEC2024 NAVAB1if self.canDo(null, Mod_EventStream) then
	if self.canDo(null,Sub_EventStream) then
		_fileNameArray.add(HelpFile_EventStream);
	endif;

	_fileNameArray.add(HelpFile_Gate);
	
	if self.canDo(null, Mod_GeneralCargo) then
		_fileNameArray.add(HelpFile_GeneralCargo);
	endif;
	
	//07 Nov 2017	NDL	TFS 7276
	_fileNameArray.add(HelpFile_HandHeldApps);

	if self.canDo(null, Mod_Harbour) then
		_fileNameArray.add(HelpFile_Harbour);
	endif;
		
	if self.canDo(null, Mod_Invoicing) then
		_fileNameArray.add(HelpFile_Invoicing);
		_fileNameArray.add(HelpFile_CashModule);	// 31919
	endif;
	
	if self.canDo(null, Mod_Logs) then
		_fileNameArray.add(HelpFile_Logs);
	endif;
	if self.canDo(null, Mod_Queuing) then //par17693 cnwrs1 aug 2008
		_fileNameArray.add(HelpFile_RTUserGuide);
	endif;
//	if self.canDo(null, PmReeferMonitorMod) then
	if self.canDo(null, Mod_BaseSystem) then	//07 Oct 2019	NDL	TFS 46169
		_fileNameArray.add(HelpFile_ReeferMonitor);
	endif;
	
	//epr par 30601 17/10/12
	if self.canDo(null, Mod_VesselRORO) then
		_fileNameArray.add(HelpFile_RORO);
	endif;
	
	_fileNameArray.add(HelpFile_SystemCodes);
	
	//07 Nov 2017	NDL	TFS 7276
	if self.canDo(null, Mod_Queuing) then
		_fileNameArray.add(HelpFile_VehicleApp);
	endif;
	
