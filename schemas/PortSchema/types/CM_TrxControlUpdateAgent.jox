    <JadeMethod name="trxUpdateUnpackCargo" id="a83de269-8ebb-4e94-87b5-95f0fbf11c89">
        <updating/>
        <source>trxUpdateUnpackCargo(	_childCargo 			     : CM_TrackedItem io;
						_targetLocation 		 	 : CM_LocationsController input;
						_unpackQuantity 			 : Integer;
						_unpackWeight 				 : Decimal;
						_addUnPackCompleteIfRequired : Boolean;
						_retroDate					 : TimeStamp;
						_passport 					 : CM_Passport input) updating;
/*

Purpose:			
	_addUnPackCompleteIfRequired :: Added for scanning app to add the complete unpack if the the container is fully unpacked 
Return Value:	
Date		Who		Reason
26 Jun 2014	cnwer1	Initial creation PAR 34472
18 Jul 2018	jlgmd1	TFS 38937 STWO - Performance enhancements
09 Jan 2024	navma1  Bug 60947: EUP - Cargo Scanning - Work order is not completed on unpacking all the child cargo items from scanning App
09 Jan 2023 navhl20 Bug 60947: EUP - Cargo Scanning - Work order is not completed on unpacking all the child cargo items from scanning App
14 Mar 2024 navhl20 ChangeRequest 62861: EUP | Retrospective Operations - [54177.090] - UnPack
*/

vars
	cmifStateControler : CMIF_StateChangeController;
	parent,
	pxyParent		   : CM_TrackedItem;
begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	_passport.useTIDictDeferUpdate 		  := true;				// TFS 38937
	_passport.useTITransactionDeferUpdate := true;				// TFS 38937

	app.setContinueCMExceptions(false);
	
	cmifStateControler := _passport.myStateChangeController;
	
	if cmifStateControler &lt;&gt; null then
		cmifStateControler.initForObject(_childCargo);				 //jlier1 TFS 61676 14/12/23 
		if _childCargo &lt;&gt; null then
			cmifStateControler.initForObject(_childCargo.myParent);
		endif;
	endif;
	
	parent  := _childCargo.myParent;									//09.01.2023 navhl20 #60947
	beginTransaction;

	//app.myUtilityUA.utlUpdateUnpackCargo(_childCargo ,	_targetLocation,_unpackQuantity,_unpackWeight, _passport);  //09.01.2023 navma1 #60947	//14.03.2024 navhl20 #62861
	app.myUtilityUA.utlUpdateUnpackCargo(_childCargo ,	_targetLocation,_unpackQuantity,_unpackWeight ,_retroDate, _passport);  //14.03.2024 navhl20 #62861
	
	if _passport.noErrors then
		_passport.doDeferredUpdates();					// TFS 38937
	endif;
	
	//09.01.2023 navma1 #60947
	if _passport.noErrors then 
		if _addUnPackCompleteIfRequired and parent.allChildren.isEmpty() then			//09.01.2023 navhl20 #60947
			if parent &lt;&gt; null then														//09.01.2023 navhl20 #60947
				pxyParent := app.myProxyManager.getProxyObject(parent).CM_TrackedItem;
				if pxyParent = null then
					pxyParent :=  app.createUpdateProxy(parent).CM_TrackedItem;
				endif;
			endif;
			app.myUtilityUA.utlUpdateTIUnpackComplete(pxyParent, parent, _retroDate, _passport);	//14.03.2024 navhl20 #62861
		endif;
	endif;

epilog
	delete pxyParent;
	self.finaliseActivityWithPassport(_passport);

end;</source>
        <Parameter name="_childCargo" type="CM_TrackedItem" usage="io"/>
        <Parameter name="_targetLocation" type="CM_LocationsController" usage="input"/>
        <Parameter name="_unpackQuantity" type="Integer"/>
        <Parameter name="_unpackWeight" type="Decimal"/>
        <Parameter name="_addUnPackCompleteIfRequired" type="Boolean"/>
        <Parameter name="_retroDate" type="TimeStamp"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxUpdateUnpackCargos" id="74f2985b-7250-42dd-a4de-1b7831628531">
        <updating/>
        <source>trxUpdateUnpackCargos(	_childTiSet 			     : CM_TISet io;
						_targetLocation 		 	 : CM_LocationsController input;
						_unpackQuantity 			 : Integer;
						_unpackWeight 				 : Decimal;
						_addUnPackCompleteIfRequired : Boolean;
						_retroDate					 : TimeStamp;
						_passport 					 : CM_Passport input)updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 Jul 2024 navhl20	Defect 64923: 1308 exception when completing the unpack work order

*/

vars
	cmifStateControler : CMIF_StateChangeController;
	parent,
	pxyParent,
	ti					: CM_TrackedItem;
begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	_passport.useTIDictDeferUpdate 		  := true;
	_passport.useTITransactionDeferUpdate := true;

	app.setContinueCMExceptions(false);
	
	cmifStateControler := _passport.myStateChangeController;
	
	parent  := _childTiSet.first.myParent;
	beginTransaction;

	foreach ti in _childTiSet do
		if cmifStateControler &lt;&gt; null then
			cmifStateControler.initForObject(ti);
			if ti &lt;&gt; null then
				cmifStateControler.initForObject(ti.myParent);
			endif;
		endif;
		
		app.myUtilityUA.utlUpdateUnpackCargo(ti, _targetLocation, _unpackQuantity, _unpackWeight, _retroDate, _passport);
		
		if _passport.hasErrorsOrWarnings then
			break;
		endif;
		
	endforeach;
	
	if _passport.noErrors then
		_passport.doDeferredUpdates();
	endif;
	
	if _passport.noErrors then 
		if _addUnPackCompleteIfRequired and parent.allChildren.isEmpty() then
			if parent &lt;&gt; null then
				pxyParent := app.myProxyManager.getProxyObject(parent).CM_TrackedItem;
				if pxyParent = null then
					pxyParent :=  app.createUpdateProxy(parent).CM_TrackedItem;
				endif;
			endif;
			app.myUtilityUA.utlUpdateTIUnpackComplete(pxyParent, parent, _retroDate, _passport);
		endif;
	endif;

epilog
	delete pxyParent;
	self.finaliseActivityWithPassport(_passport);
end;</source>
        <Parameter name="_childTiSet" type="CM_TISet" usage="io"/>
        <Parameter name="_targetLocation" type="CM_LocationsController" usage="input"/>
        <Parameter name="_unpackQuantity" type="Integer"/>
        <Parameter name="_unpackWeight" type="Decimal"/>
        <Parameter name="_addUnPackCompleteIfRequired" type="Boolean"/>
        <Parameter name="_retroDate" type="TimeStamp"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
