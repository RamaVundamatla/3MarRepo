    <JadeMethod name="mnuCancelVVR_click" id="2cd99675-5604-4e1f-99bd-d15dd529b1a9">
        <controlMethod name="MenuItem::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>mnuCancelVVR_click(menuItem: MenuItem input) updating;
/*
Date		Who		Reason
24 February 2012	cnwrd1	Initial creation
01 Apr 2024 navlc30 ChangeRequest 63191: FR - 53429 - VBS - Dis-association of a VBS slot upon cancelling a VVR

*/
vars
	terminal	: CM_Terminal;
	vbsProcess	: CM_VBSProcess;
begin

	terminal	:= self.myTerminal;										//04.04.2024 navlc30 #63191
	
	if terminal &lt;&gt; null then											//04.04.2024 navlc30 #63191
		vbsProcess := terminal.getMyVBSProcess();
	endif;
	
	if vbsProcess &lt;&gt; null and vbsProcess.isVbsSlotValidation then		//04.04.2024 navlc30 #63191
		self.doDisAssocBooking(null);
	endif;
	
	self.doCancelVVR();
epilog

end;</source>
