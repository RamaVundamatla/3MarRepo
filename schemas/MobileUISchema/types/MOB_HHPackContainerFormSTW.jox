    <JadeMethod name="populateLstRelItems" id="f87c8c59-a2fd-4895-83cc-18e8371f119a">
        <source>populateLstRelItems();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 April 2018	jlgndl1	Initial creation	TFS 38083

*/

vars

	vehicle : CM_Vehicle;
	trailerLoc : CM_LocationsController;
	isPack : Boolean;
	jobReserveDetails : CM_ReserveDetailSet;
	roadJob : CM_Job;
	req : CM_Request;
	iter : Iterator;
	reserveDetail : CM_ReserveDetail;
	index : Integer;
	packInto : CM_Container;
	

begin

	if self.myMobileGenericAgent.myTruck &lt;&gt; null then
		vehicle := self.myMobileGenericAgent.myTruck;
	endif;
	packInto := self.myPackContainer.CM_Container;
	
	self.lstRelItems.clear();
	
	reserveDetail := self.myMobileGenericAgent.myReserveSelection;
	if reserveDetail &lt;&gt; null then
		//Just display this sucker;
		index := self.lstRelItems.addItem( reserveDetail.getStwHHHDetailsView2( vehicle, packInto ) );
		self.lstRelItems.itemObject[index] := reserveDetail;

	else
		// Show the whole shooting box for any reserve details included in the trucks delivery request.
		if vehicle &lt;&gt; null then	
			if self.myMobileGenericAgent.myBulkRelease.isPackingType then
				isPack := true;
			endif;
			roadJob := vehicle.allRoadJobs.first;
			create jobReserveDetails transient;
			if roadJob &lt;&gt; null then
				foreach req in roadJob.allRequests do
					if req.myReserveDetail &lt;&gt; null then
						jobReserveDetails.addNoDuplicates(req.myReserveDetail,false);
					endif;
				endforeach;
				if not jobReserveDetails.isEmpty then
					iter := jobReserveDetails.createIterator;
				endif;
			endif;
		endif;
		
		if iter = null then //will only be if no road job was found or no associated res details
			if self.myMobileGenericAgent.myBulkRelease.isPackingType then
				isPack := true;
				iter := self.myMobileGenericAgent.myBulkRelease.allReservePackingChildren.createIterator;
			else
				iter := self.myMobileGenericAgent.myBulkRelease.allReserveDetails.createIterator;
			endif;
		endif;
		
		if iter &lt;&gt; null then
			while iter.next( reserveDetail ) do
				index := self.lstRelItems.addItem( reserveDetail.getStwHHHDetailsView2( vehicle, packInto ) );
				self.lstRelItems.itemObject[index] := reserveDetail;
				
			endwhile;
				
		endif;
		
	endif;

epilog

	delete jobReserveDetails;
	delete iter;

end;</source>
    </JadeMethod>
