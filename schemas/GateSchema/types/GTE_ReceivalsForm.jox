        <source>lstHazard_displayRow(table: Table input; theSheet: Integer; obj: Object; theRow: Integer; bcontinue: Boolean io):String updating;
// ---------------------------------------------------------------------------
// Created:     01 February 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	selected	: Boolean;
	
begin

	selected := table.CMUI_ListTable.allSelectedObjects.includes(obj);
	return self.myAssistant.displayEntryHazard(obj.CM_HazardClass, selected);
	
end;</source>
