    <JadeMethod name="doLoadAllBargVessels" id="5aba15b6-daf2-4447-83c5-a8a957b52afc">
        <source>doLoadAllBargVessels( _list : CMUI_ListTable; _defaultValueStr : String );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 August 2019	jlgndl1	Initial creation	TFS 46131
*/

vars

	iter : Iterator;
	vessel : CM_Vessel;
	index : Integer;
	list : CMUI_ListTable;
	strArray : CnStringArray;
	str : String;
	strTrimmed : String;

begin

	list := _list;
	list.clear();
	list.allSelectedObjects.clear();
	list.rows := 0;
	
	iter := app.myRoot.allVesselsByName.createIterator;
	while iter.next( vessel ) do
		if not vessel.isBarge then
			continue;
		endif;
		if vessel.name = null then
			continue;
		endif;
		index := list.addItemObject( vessel.name, vessel );
	endwhile;
	
	if _defaultValueStr &lt;&gt; null then
		strArray := _defaultValueStr.cnGetTokens(",");
		foreach str in strArray do
			strTrimmed := str.trimBlanks;
			if strTrimmed &lt;&gt; null then
				list.setSelectedString( strTrimmed );
				vessel := app.myRoot.allVesselsByName[strTrimmed];
				if vessel &lt;&gt; null then
					list.allSelectedObjects.addExclusive( vessel );
				endif;
			endif;
		endforeach;
	endif;

epilog

	delete strArray;

end;</source>
        <Parameter name="_list" type="CMUI_ListTable"/>
        <Parameter name="_defaultValueStr" type="String"/>
    </JadeMethod>
    <JadeMethod name="doLoadAllNonBargVessels" id="e7ae43ea-09d8-4adc-ad80-53fdf5ac191f">
        <source>doLoadAllNonBargVessels( _list : CMUI_ListTable; _defaultValueStr : String );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 August 2019	jlgndl1	Initial creation	TFS 46131
*/

vars

	iter : Iterator;
