    <JadeMethod name="doResize" id="86280c6b-e180-421c-a772-851e8a1266c4">
        <source>doResize();
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 10/08/2016	cnwdap1		Initial creation TFS #1832 TSW Changes
//
vars
	table : CM_DataTable;

begin
	inheritMethod();
	table := self.myForm.tblData4;
	table.fitColumnWidths;
	table.accessColumn(1).width := (table.width * 2/3).Integer -1;
	table.accessColumn(2).width := (table.width * 1/3).Integer -1;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doSave" id="ef24a276-6706-429a-90bd-9bb35ce7c319">
        <updating/>
        <source>doSave(): Boolean updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 10/08/2016	cnwdap1		Initial creation TFS @1832 TSW Changes
// 10/03/2022	navdap1		TFS 52746 PNL Custom Hold Clearance for Export Units using BOL with TSW EDI
//
vars
	errObj : CM_Error;
	idx	: Integer;
	ignoreWarnings, rtnValue : Boolean;
	pxyTswWebService : CM_TSWWebService	;
	name, submitter	: String;
	form : SOP_TableMaintForm;
	table : CM_DataTable;
	pxyTswWebServiceTerminal, checkWebServTerm : CM_TSWWebServiceTerminal;
	partnerCode : String;
	cmifConfig : CMIF_ConfigRoot;		// TFS 52746
	expectedEdition : Integer;			// TFS 52746

begin
    form := self.myForm;
	table := form.tblData4;
	name := form.tblInput1.getValueByName(ETRow_Name).String;
	submitter := form.tblInput1.getValueByName(ETRow_Submitter).String;
	
	if form.myProxyObject = null then
		if form.mode = form.Mode_Add then
			create form.myProxyObject as CM_TSWWebService transient;
		else
			app.raiseUnexpectedProgramError(class.name, method.name, 'Proxy object is null for update');
			return false;
		endif;
	endif;
	
	// TFS 52746 "Allow BOL to be used as Customs Export Clearance" is a Root Config option
	create cmifConfig transient;
	cmifConfig.setFromPersistentData(app.myRoot);
	cmifConfig.allowBOLForExports := form.tblInput1.getValueByName(ETRow_AllowBOLForExports).Boolean;
	expectedEdition := app.myRoot.edition;
	// TFS 52746 end of this bit

	pxyTswWebService := form.myProxyObject.CM_TSWWebService;
	pxyTswWebService.setProxy(name, submitter);
	foreach idx in table.fixedRows + 1 to table.rows do
		partnerCode := table.accessCell(idx, 2).text;
		if partnerCode &lt;&gt; null then
			checkWebServTerm := pxyTswWebService.allTSWWebServiceTerminals[partnerCode];
			if checkWebServTerm &lt;&gt; null and checkWebServTerm &lt;&gt; table.accessRow(idx).itemObject.CM_TSWWebServiceTerminal then
				app.raiseCMException1(Duplicate_code_must_unique, partnerCode, "partnerCode", null);
			endif;
			create pxyTswWebServiceTerminal transient;
			pxyTswWebServiceTerminal.setProxy(pxyTswWebService, table.accessCell(idx, 1).itemObject.CM_Terminal, partnerCode);
		endif;
	endforeach;

	if form.mode = form.Mode_Add then
		//app.myTrxCA.trxCreateTSWWebService(pxyTswWebService, form.myCurrentObject, app.myPassport);								// TFS 52746
		app.myTrxCA.trxCreateTSWWebService(pxyTswWebService, form.myCurrentObject, cmifConfig, expectedEdition, app.myPassport);	// TFS 52746
		rtnValue := app.myPassport.trxCompletedOK;
	elseif form.mode = form.Mode_Update then
		//app.myTrxUA.trxUpdateTSWWebService(pxyTswWebService, app.myPassport);														// TFS 52746
		app.myTrxUA.trxUpdateTSWWebService(pxyTswWebService, cmifConfig, expectedEdition, app.myPassport);							// TFS 52746
		rtnValue := app.myPassport.trxCompletedOK;
	endif;

epilog
	return rtnValue;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
