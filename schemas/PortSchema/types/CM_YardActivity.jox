    <JadeMethod name="getProxyClassForType" id="8066be40-1c4c-42ec-b159-3ab9cfe6a035">
        <options>4</options>
        <source>getProxyClassForType( _type : Integer ):Class typeMethod;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 July 2020	jlgndl1	Initial creation	TFS 49581

*/

vars

begin

	if _type = CM_YardActivity.ReeferAlarm then
		return CM_ReeferAlarmActivity;
	elseif _type = CM_YardActivity.ReeferConnect then
		return CM_ReeferConnectActivity;
	elseif _type = CM_YardActivity.ReeferDisconnect then
		return CM_ReeferDisconnectActivity;
	elseif _type = CM_YardActivity.ReeferMonitor then
		return CM_ReeferMonitorActivity;
	endif; 

	return null;

epilog

end;</source>
        <Parameter name="_type" type="Integer"/>
        <ReturnType type="Class"/>
    </JadeMethod>
