    <JadeMethod name="getRowRule" id="02fb27b8-8700-49b4-894d-bbff9f4ce94d">
        <source>getRowRule(_direction: Integer): Integer;
//08 February 2010	cnwml2


vars

begin

	if _direction = DeckingDirectionIn then
		if self.optRowIncreasIn.value then
			return DeckingRule_Increasing;
		else
			return DeckingRule_Decreasing;
		endif;
	endif;
	
	return inheritMethod(_direction);

epilog

end;</source>
        <Parameter name="_direction" type="Integer"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
