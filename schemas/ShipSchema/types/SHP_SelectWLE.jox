    <JadeMethod name="displayTI" id="23b5234a-748b-4848-ad25-604ec0f339af">
        <source>displayTI(_theObject : Object) : String;
// ---------------------------------------------------------------------------
// Created:		March 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	aBay : CM_Bay;
	aTrackedItem : CM_TrackedItem;
	theString : String;
begin
	if _theObject &lt;&gt; null then
		aTrackedItem := _theObject.CM_TrackedItem;
		theString := aTrackedItem.id;

		return  theString;
	else
		return null;
	endif;
end;</source>
        <Parameter name="_theObject" type="Object"/>
        <ReturnType type="String"/>
    </JadeMethod>
