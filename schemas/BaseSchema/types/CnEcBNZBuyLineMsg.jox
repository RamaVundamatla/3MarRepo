    <JadeMethod name="isTransactionSuccess" id="5661c3b6-9781-4da3-9ba7-5ee72e295658">
        <updating/>
        <source>isTransactionSuccess(pErrorText : String io):Boolean updating;

vars
	isSuccessful	: Boolean;
	
begin
	if self.respCode = "00"
	or self.respCode = "97"
	or self.respCode = "OK" then
		isSuccessful	:=	true;
		self.setRespApprovalNumber(); // reimplemented on Authorisation, Purchase and Refund.			
	else
		isSuccessful	:=	false;
		pErrorText		:=	self.getStringForRespCode();
	endif;
epilog
	return isSuccessful;
end;</source>
        <Parameter name="pErrorText" type="String" usage="io"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="sendMessage" id="935e7731-3be0-4f12-b3e0-6d8ece6708b4">
        <updating/>
        <source>sendMessage(pTransactionAccepted : Boolean io):String updating;

constants
	HEADER_CHAR		: Character = #02.Character;	//stx char (0x02)
	TRAILER_CHAR	: Character = #03.Character;	//etx char (0x03)
	
vars
	errorMessage	: String;
	vMessage		: String;		// initially set to the BuyLine transaction body in its raw state
	vResponse		: String;		// result back from the message
	vWasSent		: Boolean;		// the message was sent
	vTcpConnection	: CnEcBNZBuyLineTcpConnection;  // reimplementation of CnEcTcpConnection using port 1997
	packetLength	: Integer;
	theTA			: CnEcBuyLineAgent;
	messageToVoid	: CnEcBNZBuyLineMsg;
	messageToDelete	: CnEcBNZBuyLineMsg;
	messageToUpdate	: CnEcBNZBuyLineMsg;
	newVoid			: CnEcBNZBuyLineVoid;
	voidToUpdate	: CnEcBNZBuyLineVoid;
	
begin
	errorMessage := buildMessage(vMessage);
			
	if errorMessage = "" then
		// open TCP port , send message.
		
		create theTA transient;
		create vTcpConnection transient;
		
		packetLength	:= vMessage.length + 5;
		vMessage := HEADER_CHAR.String &amp; packetLength.String.padLeadingZeros(3) &amp; vMessage &amp; TRAILER_CHAR.String;

		vWasSent := vTcpConnection.cnEcDoWebGetRequest(		self.myManager.buyLineServer,
															self.myManager.buyLinePath,
															vMessage,
															self.myManager.timeOut,
															vResponse
															);
		
		if not vWasSent or  vResponse = "" then		// no repsonse from the BNZBuyLine, so don't know if it worked or not.
			pTransactionAccepted := false;
			
			if vWasSent then
				errorMessage := "Connection established, but no response received from BuyLine.  ";
				
				if self.isKindOf(CnEcBNZBuyLineVoid) then
					// no problem, create another to be submitted to the queue then delete the old one
					
					messageToVoid := self.CnEcBNZBuyLineVoid.myMessageToVoid; 
					theTA.trxBNZBuyLineVoidCreate(	self.myManager,	//pBuyLineMgr : BNZBuyLineMgr io; 
													messageToVoid,	//pBuyLineMessageToVoid : BNZBuyLineMsg io; 
													newVoid	//pBNZBuyLineVoidNew : BNZBuyLineVoid output
													); 
	
					messageToDelete := self;
					theTA.trxBNZBuyLineMsgDelete( messageToDelete ); 
					
				elseif 	( self.isKindOf(CnEcBNZBuyLinePurchase)
				or self.isKindOf(CnEcBNZBuyLineRefund)
				or self.isKindOf(CnEcBNZBuyLineAuthorisation)
				or self.isKindOf(CnEcBNZBuyLineCompletion))
				then
					messageToVoid := self;
					theTA.trxBNZBuyLineVoidCreate(	self.myManager,	//pBuyLineMgr : BNZBuyLineMgr io; 
													messageToVoid,	//pBuyLineMessageToVoid : BNZBuyLineMsg io; 
													newVoid	//pBNZBuyLineVoidNew : BNZBuyLineVoid output
													);
				endif;
			else
				errorMessage := "Failed to establish connection to BuyLine.  ";
				
				if self.isKindOf(CnEcBNZBuyLineVoid) then
					newVoid := self.CnEcBNZBuyLineVoid;
				endif;
			endif;
		else
		// got through and got a response, so decipher it, and check result
			
			messageToUpdate := self;
			errorMessage := theTA.trxBNZBuyLineMsgSetResponse(	messageToUpdate,	//pBNZBuyLineMsgToUpdate : BNZBuyLineMsg io;
																messageToUpdate.edition(),	//pRequiredEdition : Integer;
																vResponse,	//pResponse : String;
																pTransactionAccepted	//pTransactionAccepted : Boolean io
																); 
			
			if errorMessage = null then
				errorMessage := self.getStringForRespCode();
			endif;
			
			if self.isKindOf(CnEcBNZBuyLineVoid) then
			
				if pTransactionAccepted then
					
					messageToDelete := self.CnEcBNZBuyLineVoid.myMessageToVoid;
					theTA.trxBNZBuyLineMsgDelete(messageToDelete); 
					
					messageToDelete := self;
					theTA.trxBNZBuyLineMsgDelete(messageToDelete);
					 
				else
					emailTheAdministrator(self,errorMessage);	 
					voidToUpdate := self.CnEcBNZBuyLineVoid;
					theTA.trxBNZBuyLineVoidNotify(	voidToUpdate,	//pBNZBuyLineVoidToUpdate : BNZBuyLineVoid io;
													voidToUpdate.edition(),	//pRequiredEdition : Integer;
													true	//pNotified:Boolean
													); 		
				endif;
				
			elseif self.isKindOf(CnEcBNZBuyLineAuthorisation) then
			
				if pTransactionAccepted then
					messageToUpdate := self.CnEcBNZBuyLineAuthorisation;
					theTA.trxBNZBuyLineMsgSetTimeSent( 	messageToUpdate,
														messageToUpdate.edition());
					// don't delete a successfull one till Authorisation is processed.
				else
					messageToDelete := self;
					theTA.trxBNZBuyLineMsgDelete(messageToDelete);
				endif;
				
			elseif self.isKindOf(CnEcBNZBuyLineCompletion) then
			
				if pTransactionAccepted then
					if self.CnEcBNZBuyLineCompletion.myAuthorisation &lt;&gt; null then
						messageToDelete := self.CnEcBNZBuyLineCompletion.myAuthorisation;
						theTA.trxBNZBuyLineMsgDelete(messageToDelete);
					endif;	
					
					messageToDelete := self;
					theTA.trxBNZBuyLineMsgDelete(messageToDelete);						
				else
					messageToDelete := self;
					theTA.trxBNZBuyLineMsgDelete(messageToDelete);	
				endif;
			else
				messageToDelete := self;
				theTA.trxBNZBuyLineMsgDelete(messageToDelete);
			endif;			
		endif;
	else
		//got an error building the message.
		//Will just return the message for the user to correct.
		pTransactionAccepted := false;
	endif;
epilog
	if newVoid &lt;&gt; null then
		CnEcBNZBuyLineMgr.causeClassEvent(SEND_VOID_TO_BUYLINE, false, newVoid);
	endif;
	
	delete theTA;
	delete vTcpConnection; 
	return errorMessage;	
end;</source>
        <Parameter name="pTransactionAccepted" type="Boolean" usage="io"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="setCurrency" id="75beb580-175c-448d-a72d-ea0d5f006da5">
        <updating/>
        <source>setCurrency(pCurrency : String):String updating;

constants
	AUD	= 036;	// Australian Dollar
	CAD	= 124;	// Canadian Dollar
	CHF	= 756;	// Swiss Franc
	DEM	= 280;	// Deutsche Mark
	FRF	= 250;	// French Franc
	GBP	= 826;	// Pound Sterling
	HKD	= 344;	// Hong Kong Dollar
	JPY	= 392;	// Yen
	NZD	= 554;	// New Zealand Dollar
	SGD	= 702;	// Singapore Dollar
	USD	= 840;	// US Dollar
	EUR	= 978;	// Euro
	ZAR	= 710;	// Rand
	
vars
	errorMessage : String;
	
begin
	if pCurrency = "" then
		self.currency := NZD;
	else
		if pCurrency = "AUD" then
			self.currency := AUD;
		elseif pCurrency = "CAD" then
			self.currency := CAD;
		elseif pCurrency = "CHF" then
			self.currency := CHF;
		elseif pCurrency = "DEM" then
			self.currency := DEM;
		elseif pCurrency = "FRF" then
			self.currency := FRF;
		elseif pCurrency = "GBP" then
			self.currency := GBP;
		elseif pCurrency = "HKD" then
			self.currency := HKD;
		elseif pCurrency = "JPY" then
			self.currency := JPY;
		elseif pCurrency = "NZD" then
			self.currency := NZD;
		elseif pCurrency = "SGD" then
			self.currency := SGD;
		elseif pCurrency = "USD" then
			self.currency := USD;
		elseif pCurrency = "EUR" then
			self.currency := EUR;
		elseif pCurrency = "ZAR" then
			self.currency := ZAR;
		else
			errorMessage := "'" &amp; pCurrency &amp; "' Unknown Currency";			
		endif;
	endif;
epilog
	return errorMessage;				
end;</source>
        <Parameter name="pCurrency" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
