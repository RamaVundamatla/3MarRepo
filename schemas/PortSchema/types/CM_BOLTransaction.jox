    <JadeMethod name="getDebtorFromShipOperator" id="13e43796-dc17-4783-b56f-5bb9fdb54696">
        <source>getDebtorFromShipOperator():CM_Debtor;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
