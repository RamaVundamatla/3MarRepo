        <source>setProxyForRecvOrderCreateUpd(_sendRecvMessage:String; _terminal : CM_Terminal; _responseCode : Integer io; _response : String io) updating;			//navra1 - MTN-35875- 5th Sep 2025-1
/*

Purpose:			

