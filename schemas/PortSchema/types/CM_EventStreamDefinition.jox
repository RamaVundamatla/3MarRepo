    <JadeMethod name="getDisplayStringForAttribute" id="9f5ca207-e1d9-4a26-b9e0-78e4345dab0d">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
24 January 2020		jlgzm1	Initial creation TFS 47920 Event Stream Admin JMT UI

*/

vars
begin
	if _attrName = ETRow_Target then
		return self.targetURL;
		
	elseif _attrName = ETRow_IsActive then
		return self.isActive.asStringJMT;
		
	elseif _attrName = ETRow_NumberOfRetries then
		return self.numRetries.asStringJMT;
		
	elseif _attrName = ETRow_EmailAddress then
		return self.email;
	endif;
	
	return inheritMethod(_attrName, _short);

epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getPwForUse" id="9ad4c894-eec1-4c9d-93de-de74b742be63">
