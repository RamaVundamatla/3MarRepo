    <JadeMethod name="zCoparn_mtrel_withid" id="8555473e-87ed-4b80-976e-19cc9469cbfe">
        <source>zCoparn_mtrel_withid(_sender, _voyageCode, _vesselName, _consignorCode, _release, _extraText, _isoType, _quantity :String;
							_reqTS, _estReqTS :TimeStamp; _mt :Character):String protected;
/*
Purpose:	Coparn file for MT release with pre-assigned container number

Date		Who		Reason
01 December 2011	cnwcs5	Initial creation - CCMS POL 2122 / par 28696 - Empty Releases via COPARN
*/
//PREASSIGNED CONTAINER TCLU2214123
vars
	str,	strTS1, strTS2	:String;
begin
	strTS1 := _reqTS.date.format ('yyyyMMdd') &amp; _reqTS.time.format ('HHmm');
	strTS2 := _estReqTS.date.format ('yyyyMMdd') &amp; _estReqTS.time.format ('HHmm');
	
	str := 	
"UNA:+,? '
UNB+UNOA:1+" &amp; _sender &amp; "+NZPOE+110901:2107+1342'
UNH+134200001+COPARN:D:95B:UN:ITG14'
