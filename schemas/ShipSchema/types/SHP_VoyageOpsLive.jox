    <JadeMethod name="addCargoToCollection" id="3db309eb-e4f0-4d7c-bdf5-db5e148761cf">
        <source>addCargoToCollection(_ti : CM_TrackedItem; _checkRelRec : Boolean);
/*
Purpose:			

Date				Who		Reason
01 March 2023		navab1	TFS CR 56806 TASK 56807
21 November 2023	jlizm1	TFS 61272 CUX voyage ops live booking list content
30 November 2023	jlizm1	TFS 61542 Voyage Ops Live tab filter adjustments
19 March 2024		jlizm1	TFS 62763 Table auto updates
12 Sepcteber 2024	jlizm1	TFS 66095 Don't show non operational reefers in VOL
24 October  2024	navsp1  JIRA Bug MTN-19339: CUX - Go Live 02 issue - Onboard cargo is showing along with parent trailer
13 Jan 2025 		navlc30 JIRA 33396 CUX- Voyage Operations Live - Tab "Reefer" is not showing Trailers
21 May 2025 		navlc30 JIRA 34931 CUX | Voyage Operations Live Reefer TAb
*/

vars
	ti : CM_TrackedItem;
	isHAZ, isReefer : Boolean;
	notOnMAFI : Boolean;
begin
	ti := _ti;
	
	// ## this note covers updates and deletion. The update covers moves, confirmation, queueing, unqueueing of a TI, plus tranship changes.
	self.beginNotification(ti, Any_System_Event, Response_Continuous, 0);

		
	if self.includeObject(ti, false) then
		if not ti.isBulkOrBreakBulkGeneric and
			not ti.isChild and
			not (ti.isOnTrailer and not (ti.isMAFI or ti.isContainer)) then
			// TFS 61272 dont show breakbulk, or cargo loaded in containers or on/in trailers (except mafis and containers on mafis)
			self.allCargoBooked.addNoDuplicates(ti,false); // ### CUX BUG 57417 30MAR2023 NAVAB1
		endif;
	endif;

	
	if not self.includeObject(ti, _checkRelRec) then
		return;
	endif;
	
	
		
	// All cargo list is all cargo that is left to be worked, checked and confirmed.
	if ti.isContainer and ti.myPrimaryActualLocation &lt;&gt; null and ti.myPrimaryActualLocation.isSlotController then
		if not ti.isROB and ti.isBeingWorkedOnShip then
			self.allCargoToBeWorked.addNoDuplicates(ti,false);
		endif;
	elseif not ti.isOnTrailer then
		self.allCargoToBeWorked.addNoDuplicates(ti,false); // ### CUX BUG 57417 30MAR2023 NAVAB1
	endif;
	
	isHAZ := ti.isHazardous;
	notOnMAFI := not ti.isOnTrailer;// or ti.isPreNote;					//JIRA 19339
	/*if ti.isTILC and not ti.isReefer then								//13.01.2025 navlc30 #33396		//21.07.2025 navlc30 #34931
		isReefer := ti.CM_TILC.hasMonitoredOnboardTIs();
	else
		isReefer := ti.monitorConnection;
	endif;*/
	
	isReefer := ti.isReefer;																			//21.07.2025 navlc30 #34931
	
	if (isHAZ and ti.isMAFI) // MAFI with HAZ cargo
	or (isHAZ and ti.isChassis) // or TRAILER with HAZ cargo
	or (isHAZ and notOnMAFI) then // or HAZ cargo not on a MAFI
		self.allHazardous.addNoDuplicates(ti,false); // ### CUX BUG 57417 30MAR2023 NAVAB1
	endif;
	
	if (isReefer and ti.isMAFI) // MAFI with REEFER commodity
	or (isReefer and ti.isChassis) // TRAILER with REEFER commodity
	or (isReefer and notOnMAFI) then // or REEFER cargo not on a MAFI
		self.allReefers.addNoDuplicates(ti,false); // ### CUX BUG 57417 30MAR2023 NAVAB1
	endif;
	
	if ti.isMAFI then
		self.allMAFI.addNoDuplicates(ti,false); // ### CUX BUG 57417 30MAR2023 NAVAB1
	elseif ti.isChassis then
		self.allTrailer.addNoDuplicates(ti,false); // ### CUX BUG 57417 30MAR2023 NAVAB1
	endif;

epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_checkRelRec" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="addCargoToTable" id="d5c6d95c-fed2-4fdf-8d3b-7de0bfbd4d9b">
        <updating/>
        <source>addCargoToTable(_ti : CM_TrackedItem; _table : CM_DataTable input; _sheet : CMUI_Sheet input) updating;
/*
Purpose:			

Date				Who		Reason
01 Mar 2023		navab1	TFS CR 56806 TASK 56807
18 Oct 2023		jlizm1	TFS 60661 CUX Voyage Ops live RT column not working
04 Jul 2024		jlier1  TFS 65046 - moved to doQueryColourUps so coloring RT column would work from notes 
*/

vars
	str : String;
	rowIdx : Integer;	
begin
	str := _ti.getAttributeStringForDefArray(_table.allTblDataEntRows);
	rowIdx := _table.addItem(str);
	_table.accessRow(rowIdx).itemObject := _ti;
	
	
	self.doQueryColourUp(_table, _ti, rowIdx);


epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_table" type="CM_DataTable" usage="input"/>
        <Parameter name="_sheet" type="CMUI_Sheet" usage="input"/>
    </JadeMethod>
    <JadeMethod name="btnAdditionalConfigs_click" id="9d56b988-b17b-4603-8295-474fb3b3c3cc">
        <controlMethod name="CMUI_Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnAdditionalConfigs_click(btn: Button input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date					Who		Reason
06 December 2023		jlizm1	Initial creation TFS 61426 CUX FLP Screen Enhancements
19 Feb 2024				jlika1	TFS 62137 CUX | Shortlanded cargo
03 October 2024			navdap1	MTN-32969 CUX | Issues on Voyage Ops Live Form - Options Button
*/

vars

begin
	if self.myCurrentVoyage &lt;&gt; null then	
		self.btnShortlandManiCargo.visible := app.myCurrentUserCan(self.myTerminal, PmShipVoyageOpsShrtLandMaint) and self.myCurrentVoyage.isClosedOrDeparted;		
	else 
		self.btnShortlandManiCargo.visible := false;		
	endif;
	
	if self.btnShortlandManiCargo.visible then
		self.frmAdditionalConfigs.height := 123;
	else 
		self.frmAdditionalConfigs.height := 100;
	endif;
	
	if self.frmAdditionalConfigs.visible then
		self.frmAdditionalConfigs.visible := false;		
	else
		self.frmAdditionalConfigs.visible := true;
		self.frmAdditionalConfigs.zOrder(1);			// MTN-32969
	endif;	
epilog

end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
