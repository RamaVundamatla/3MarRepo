	VOYAGE1 = "UTVB_108";
	CONTID1 = "CNTU230126";
	CONTID2 = "ODCU2301261";
	CARGOID1 = "VB230126";

	InvType = "UT_InvTypeGrouping";

	InvLine01 = "Highest 1 - 01";
	InvLine02 = "Highest 1 - 02";
	InvLine03 = "Highest 1 - DEF";

	InvLine04 = "Highest 2 - 01";
	InvLine05 = "Highest 2 - 02";
	InvLine06 = "Highest 2 - DEF";

	InvLine07 = "Highest 3 - 01";
	InvLine08 = "Highest 3 - 02";
	InvLine09 = "Highest 3 - DEF";

	InvLine10 = "OD Highest 1 - 01";
	InvLine11 = "OD Highest 1 - 02";
	InvLine12 = "OD Highest 1 - DEF";

	InvLine13 = "OD Highest 2 - 01";
	InvLine14 = "OD Highest 2 - 02";
	InvLine15 = "OD Highest 2 - DEF";

	InvLine16 = "OD Highest 3 - 01";
	InvLine17 = "OD Highest 3 - 02";
	InvLine18 = "OD Highest 3 - DEF";

	InvLine19 = "ALL - 01";
	InvLine20 = "ALL - 02";
	InvLine21 = "ALL - 03";
	
vars
	cargoType, contType : CM_CargoType;
	bs1 : CM_BlockStack;
	services : CM_ServiceByNameDict;
	calcType : CM_CalculationType;
	voyage : CM_Voyage;
	bs : CM_TerminalArea;
	location : CM_LocationsController;
	operator : CM_Operator;
	service100 : CM_Service;
	invType: CM_InvoiceDesc;
	invLineType100: CM_InvoiceLineDesc;
	product : CM_Product;
	terminal: CM_Terminal;
	vessel : CM_Vessel;
	port : CM_Port;
	ti1, ti2, ti3 : CM_TrackedItem;
	trans : CM_TITransaction;
	invLine : CM_InvoiceLine;
	rateEntry : CM_RateEntry;
	contOverHeight : Decimal[23,4];
	idx : Integer;
begin
	
	self.deleteInvoiceType(InvType);
	self.deleteInvoiceService(InvLine01,0);
	self.deleteInvoiceLineType(InvLine01,0);
	
	self.deleteInvoiceService(InvLine02,0);
	self.deleteInvoiceLineType(InvLine02,0);
	
	self.deleteInvoiceService(InvLine03,0);
	self.deleteInvoiceLineType(InvLine03,0);

	self.deleteInvoiceService(InvLine04,0);
	self.deleteInvoiceLineType(InvLine04,0);

	self.deleteInvoiceService(InvLine05,0);
	self.deleteInvoiceLineType(InvLine05,0);

	self.deleteInvoiceService(InvLine06,0);
	self.deleteInvoiceLineType(InvLine06,0);

	self.deleteInvoiceService(InvLine07,0);
	self.deleteInvoiceLineType(InvLine07,0);

	self.deleteInvoiceService(InvLine08,0);
	self.deleteInvoiceLineType(InvLine08,0);

	self.deleteInvoiceService(InvLine09,0);
	self.deleteInvoiceLineType(InvLine09,0);

	self.deleteInvoiceService(InvLine10,0);
	self.deleteInvoiceLineType(InvLine10,0);

	self.deleteInvoiceService(InvLine11,0);
	self.deleteInvoiceLineType(InvLine11,0);

	self.deleteInvoiceService(InvLine12,0);
	self.deleteInvoiceLineType(InvLine12,0);

	self.deleteInvoiceService(InvLine13,0);
	self.deleteInvoiceLineType(InvLine13,0);

	self.deleteInvoiceService(InvLine14,0);
	self.deleteInvoiceLineType(InvLine14,0);

	self.deleteInvoiceService(InvLine15,0);
	self.deleteInvoiceLineType(InvLine15,0);

	self.deleteInvoiceService(InvLine16,0);
	self.deleteInvoiceLineType(InvLine16,0);

	self.deleteInvoiceService(InvLine17,0);
	self.deleteInvoiceLineType(InvLine17,0);

	self.deleteInvoiceService(InvLine18,0);
	self.deleteInvoiceLineType(InvLine18,0);

	self.deleteInvoiceService(InvLine19,0);
	self.deleteInvoiceLineType(InvLine19,0);

	self.deleteInvoiceService(InvLine20,0);
	self.deleteInvoiceLineType(InvLine20,0);

	self.deleteInvoiceService(InvLine21,0);
	self.deleteInvoiceLineType(InvLine21,0);



 	calcType := app.myRoot.allCalculationTypesByCode["CCT01"]; // Value of 1
	invType := self.createInvoiceType(InvType, InvoiceTypeGeneral);
	self.assertNotNullMsg(invType, "Invoice type " &amp; InvType &amp; " not created");

	create services transient;
	
	service100 := self.createInvoiceService(InvLine01,InvLine01, calcType, null);
	self.assertNotNullMsg(service100, InvLine01 &amp; " not created");
	services.add(service100);
	invLineType100 := self.createInvoiceLineType(InvLine01, calcType, invType, services,"SDT1"); // SDT1 - Operator
	self.assertNotNullMsg(invLineType100, InvLine01 &amp; " not created");
	// set up rate entry for service
	rateEntry := service100.debtorNodeRates.first.rateEntries.first;
	beginTransaction;
	rateEntry.setCostPerUnit(1000);
	commitTransaction;
	
	services.clear();
	service100 := self.createInvoiceService(InvLine02,InvLine02, calcType, null);
	self.assertNotNullMsg(service100, InvLine02 &amp; " not created");
	services.add(service100);
	invLineType100 := self.createInvoiceLineType(InvLine02, calcType, invType, services,"SDT1"); // SDT1 - Operator
	self.assertNotNullMsg(invLineType100, InvLine02 &amp; " not created");
	// set up rate entry for service
	rateEntry := service100.debtorNodeRates.first.rateEntries.first;
	beginTransaction;
	rateEntry.setCostPerUnit(50);
	commitTransaction;

	services.clear();
	service100 := self.createInvoiceService(InvLine03,InvLine03, calcType, null);
	self.assertNotNullMsg(service100, InvLine03 &amp; " not created");
	services.add(service100);
	invLineType100 := self.createInvoiceLineType(InvLine03, calcType, invType, services,"SDT1"); // SDT1 - Operator
	self.assertNotNullMsg(invLineType100, InvLine03 &amp; " not created");
	


	services.clear();
	service100 := self.createInvoiceService(InvLine04,InvLine04, calcType, null);
	self.assertNotNullMsg(service100, InvLine04 &amp; " not created");
	services.add(service100);
	invLineType100 := self.createInvoiceLineType(InvLine04, calcType, invType, services,"SDT1"); // SDT1 - Operator
	self.assertNotNullMsg(invLineType100, InvLine04 &amp; " not created");
	// set up rate entry for service
	rateEntry := service100.debtorNodeRates.first.rateEntries.first;
	beginTransaction;
	rateEntry.setCostPerUnit(2000);
	commitTransaction;


	services.clear();
	service100 := self.createInvoiceService(InvLine05,InvLine05, calcType, null);
	self.assertNotNullMsg(service100, InvLine05 &amp; " not created");
	services.add(service100);
	invLineType100 := self.createInvoiceLineType(InvLine05, calcType, invType, services,"SDT1"); // SDT1 - Operator
	self.assertNotNullMsg(invLineType100, InvLine05 &amp; " not created");
	// set up rate entry for service
	rateEntry := service100.debtorNodeRates.first.rateEntries.first;
	beginTransaction;
	rateEntry.setCostPerUnit(60);
	commitTransaction;


	services.clear();
	service100 := self.createInvoiceService(InvLine06,InvLine06, calcType, null);
	self.assertNotNullMsg(service100, InvLine06 &amp; " not created");
	services.add(service100);
	invLineType100 := self.createInvoiceLineType(InvLine06, calcType, invType, services,"SDT1"); // SDT1 - Operator
	self.assertNotNullMsg(invLineType100, InvLine06 &amp; " not created");


	services.clear();
	service100 := self.createInvoiceService(InvLine07,InvLine07, calcType, null);
	self.assertNotNullMsg(service100, InvLine07 &amp; " not created");
	services.add(service100);
	invLineType100 := self.createInvoiceLineType(InvLine07, calcType, invType, services,"SDT1"); // SDT1 - Operator
	self.assertNotNullMsg(invLineType100, InvLine07 &amp; " not created");


	services.clear();
	service100 := self.createInvoiceService(InvLine08,InvLine08, calcType, null);
	self.assertNotNullMsg(service100, InvLine08 &amp; " not created");
	services.add(service100);
	invLineType100 := self.createInvoiceLineType(InvLine08, calcType, invType, services,"SDT1"); // SDT1 - Operator
	self.assertNotNullMsg(invLineType100, InvLine08 &amp; " not created");


	services.clear();
	service100 := self.createInvoiceService(InvLine09,InvLine09, calcType, null);
	self.assertNotNullMsg(service100, InvLine09 &amp; " not created");
	services.add(service100);
	invLineType100 := self.createInvoiceLineType(InvLine09, calcType, invType, services,"SDT1"); // SDT1 - Operator
	self.assertNotNullMsg(invLineType100, InvLine09 &amp; " not created");


	services.clear();
	service100 := self.createInvoiceService(InvLine10,InvLine10, calcType, null);
	self.assertNotNullMsg(service100, InvLine10 &amp; " not created");
	services.add(service100);
	invLineType100 := self.createInvoiceLineType(InvLine10, calcType, invType, services,"SDT1"); // SDT1 - Operator
	self.assertNotNullMsg(invLineType100, InvLine10 &amp; " not created");
	// set up rate entry for service
	rateEntry := service100.debtorNodeRates.first.rateEntries.first;
	beginTransaction;
	rateEntry.setCostPerUnit(3000);
	commitTransaction;


	services.clear();
	service100 := self.createInvoiceService(InvLine11,InvLine11, calcType, null);
	self.assertNotNullMsg(service100, InvLine11 &amp; " not created");
	services.add(service100);
	invLineType100 := self.createInvoiceLineType(InvLine11, calcType, invType, services,"SDT1"); // SDT1 - Operator
	self.assertNotNullMsg(invLineType100, InvLine11 &amp; " not created");
	// set up rate entry for service
	rateEntry := service100.debtorNodeRates.first.rateEntries.first;
	beginTransaction;
	rateEntry.setCostPerUnit(70);
	commitTransaction;


	services.clear();
	service100 := self.createInvoiceService(InvLine12,InvLine12, calcType, null);
	self.assertNotNullMsg(service100, InvLine12 &amp; " not created");
	services.add(service100);
	invLineType100 := self.createInvoiceLineType(InvLine12, calcType, invType, services,"SDT1"); // SDT1 - Operator
	self.assertNotNullMsg(invLineType100, InvLine12 &amp; " not created");


	services.clear();
	service100 := self.createInvoiceService(InvLine13,InvLine13, calcType, null);
	self.assertNotNullMsg(service100, InvLine13 &amp; " not created");
	services.add(service100);
	invLineType100 := self.createInvoiceLineType(InvLine13, calcType, invType, services,"SDT1"); // SDT1 - Operator
	self.assertNotNullMsg(invLineType100, InvLine13 &amp; " not created");
	// set up rate entry for service
	rateEntry := service100.debtorNodeRates.first.rateEntries.first;
	beginTransaction;
	rateEntry.setCostPerUnit(6000);
	commitTransaction;


	services.clear();
	service100 := self.createInvoiceService(InvLine14,InvLine14, calcType, null);
	self.assertNotNullMsg(service100, InvLine14 &amp; " not created");
	services.add(service100);
	invLineType100 := self.createInvoiceLineType(InvLine14, calcType, invType, services,"SDT1"); // SDT1 - Operator
	self.assertNotNullMsg(invLineType100, InvLine14 &amp; " not created");
	// set up rate entry for service
	rateEntry := service100.debtorNodeRates.first.rateEntries.first;
	beginTransaction;
	rateEntry.setCostPerUnit(80);
	commitTransaction;


	services.clear();
	service100 := self.createInvoiceService(InvLine15,InvLine15, calcType, null);
	self.assertNotNullMsg(service100, InvLine15 &amp; " not created");
	services.add(service100);
	invLineType100 := self.createInvoiceLineType(InvLine15, calcType, invType, services,"SDT1"); // SDT1 - Operator
	self.assertNotNullMsg(invLineType100, InvLine15 &amp; " not created");


	services.clear();
	service100 := self.createInvoiceService(InvLine16,InvLine16, calcType, null);
	self.assertNotNullMsg(service100, InvLine16 &amp; " not created");
	services.add(service100);
	invLineType100 := self.createInvoiceLineType(InvLine16, calcType, invType, services,"SDT1"); // SDT1 - Operator
	self.assertNotNullMsg(invLineType100, InvLine16 &amp; " not created");


	services.clear();
	service100 := self.createInvoiceService(InvLine17,InvLine17, calcType, null);
	self.assertNotNullMsg(service100, InvLine17 &amp; " not created");
	services.add(service100);
	invLineType100 := self.createInvoiceLineType(InvLine17, calcType, invType, services,"SDT1"); // SDT1 - Operator
	self.assertNotNullMsg(invLineType100, InvLine17 &amp; " not created");


	services.clear();
	service100 := self.createInvoiceService(InvLine18,InvLine18, calcType, null);
	self.assertNotNullMsg(service100, InvLine18 &amp; " not created");
	services.add(service100);
	invLineType100 := self.createInvoiceLineType(InvLine18, calcType, invType, services,"SDT1"); // SDT1 - Operator
	self.assertNotNullMsg(invLineType100, InvLine18 &amp; " not created");

	services.clear();
	service100 := self.createInvoiceService(InvLine19,InvLine19, calcType, null);
	self.assertNotNullMsg(service100, InvLine19 &amp; " not created");
	services.add(service100);
	invLineType100 := self.createInvoiceLineType(InvLine19, calcType, invType, services,"SDT1"); // SDT1 - Operator
	self.assertNotNullMsg(invLineType100, InvLine19 &amp; " not created");


	services.clear();
	service100 := self.createInvoiceService(InvLine20,InvLine20, calcType, null);
	self.assertNotNullMsg(service100, InvLine20 &amp; " not created");
	services.add(service100);
	invLineType100 := self.createInvoiceLineType(InvLine20, calcType, invType, services,"SDT1"); // SDT1 - Operator
	self.assertNotNullMsg(invLineType100, InvLine20 &amp; " not created");


	services.clear();
	service100 := self.createInvoiceService(InvLine21,InvLine21, calcType, null);
	self.assertNotNullMsg(service100, InvLine21 &amp; " not created");
	services.add(service100);
	invLineType100 := self.createInvoiceLineType(InvLine21, calcType, invType, services,"SDT1"); // SDT1 - Operator
	self.assertNotNullMsg(invLineType100, InvLine21 &amp; " not created");


	
	

	

	operator := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);
	
	contType := app.myRoot.getCargoTypeFromAbbrev("CONT"); // ### TFS CR 55624 TASK 55700 27JAN2023 NAVAB1
	cargoType := app.myRoot.getCargoTypeFromAbbrev(CargoTypeStr);
	
	self.tranMapLoadLineGrouping("UTLineGroup");

	// ### CREATE CARGO ONSHIP FOR VOYAGE ONE READY FOR RECEIVAL
	bs1     		:= self.addBlockStack(BLOCKSTACK, 999999, null);
	product         := cargoType.allProducts.first;
	operator 		:= self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);
	terminal		:= self.getTerminal();
	vessel 			:= self.addVesselWithHolds(VESSEL, 2, 2);
	voyage 			:= self.addVoyageWithGeneralCargoStruc(VOYAGE1, vessel.name, vessel.myOperator.code,	self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString(), 0);
	port 			:= app.myRoot.allPorts[voyage.myTerminal.getConfig(PortDestCode).String];
	
	ti1 := self.createContainerOnShip("", CONTID1 &amp; 1.String, operator, voyage, port,15000);
	ti2 := self.createGCOnShip("", CARGOID1 &amp; "001", cargoType, operator, voyage, port,15000);

	// ### OverDimensional
	contOverHeight := 1.1;
	self.opts.purge();
	self.opts.addAssoc("overHeight", contOverHeight);
	ti3 := self.createContainerOnShip("", CONTID2, operator, voyage, port,15000);
	self.assertTrueMsg(ti3.isOverDimensions, "TI1 should be OD");
	
	self.moveAllCargo(voyage,bs1.myLocationsController);

	trans := ti1.getTransactionOfType(TRANS_TYPE_REC_SHIP);
	self.assertTrueMsg(trans &lt;&gt; null,"TI1 no recieve ship transaction");
	
	assertTrueMsg(trans.allInvoiceLines.size = 5, "TI1 should be 5 invoice lines for transaction");
	
	// TESTING
	idx := 1;
	foreach invLine in trans.allInvoiceLines do
//		write ti1.id &amp; " " &amp;  invLine.sequenceNum.String &amp; " " &amp; invLine.invoiceLineDesc.narration &amp; " " &amp; invLine.lineTotal.String;
		if idx = 1 then
			assertTrueMsg(invLine.invoiceLineDesc.narration = InvLine19, "TI1 first line should be " &amp; InvLine19 &amp; ", is " &amp; invLine.invoiceLineDesc.narration);
		elseif idx = 2 then
			assertTrueMsg(invLine.invoiceLineDesc.narration = InvLine20, "TI1 last line should be " &amp; InvLine20 &amp; ", is " &amp; invLine.invoiceLineDesc.narration);
		elseif idx = 3 then
			assertTrueMsg(invLine.invoiceLineDesc.narration = InvLine01, "TI1 last line should be " &amp; InvLine01 &amp; ", is " &amp; invLine.invoiceLineDesc.narration);
		elseif idx = 4 then
			assertTrueMsg(invLine.invoiceLineDesc.narration = InvLine04, "TI1 last line should be " &amp; InvLine04 &amp; ", is " &amp; invLine.invoiceLineDesc.narration);
		else
			assertTrueMsg(invLine.invoiceLineDesc.narration = InvLine07, "TI1 last line should be " &amp; InvLine07 &amp; ", is " &amp; invLine.invoiceLineDesc.narration);
		endif;
		idx := idx + 1;
	endforeach;
	
	// ### OverDimensional
	trans := ti3.getTransactionOfType(TRANS_TYPE_REC_SHIP);
	self.assertTrueMsg(trans &lt;&gt; null,"TI1 OD no recieve ship transaction");
	
	assertTrueMsg(trans.allInvoiceLines.size = 5, "TI1 OD should be 5 invoice lines for transaction");
	
	idx := 1;
	foreach invLine in trans.allInvoiceLines do
//		write ti3.id &amp; " " &amp;  invLine.sequenceNum.String &amp; " " &amp; invLine.invoiceLineDesc.narration &amp; " " &amp; invLine.lineTotal.String;
		if idx = 1 then
			assertTrueMsg(invLine.invoiceLineDesc.narration = InvLine20, "TI1 first line should be " &amp; InvLine20 &amp; ", is " &amp; invLine.invoiceLineDesc.narration);
		elseif idx = 2 then
			assertTrueMsg(invLine.invoiceLineDesc.narration = InvLine21, "TI1 last line should be " &amp; InvLine21 &amp; ", is " &amp; invLine.invoiceLineDesc.narration);
		elseif idx = 3 then
			assertTrueMsg(invLine.invoiceLineDesc.narration = InvLine10, "TI1 last line should be " &amp; InvLine10 &amp; ", is " &amp; invLine.invoiceLineDesc.narration);
		elseif idx = 4 then
			assertTrueMsg(invLine.invoiceLineDesc.narration = InvLine13, "TI1 last line should be " &amp; InvLine10 &amp; ", is " &amp; invLine.invoiceLineDesc.narration);
		else
			assertTrueMsg(invLine.invoiceLineDesc.narration = InvLine16, "TI1 last line should be " &amp; InvLine13 &amp; ", is " &amp; invLine.invoiceLineDesc.narration);
		endif;
		idx := idx + 1;
	endforeach;
	
		
epilog
	self.resetDefaultTranMap();
	delete services;
end;</source>
    </JadeMethod>
    <JadeMethod name="tTranMapLoad1" id="1f2bc203-d4a5-4c2f-85bd-8ffaa306cdb7">
        <source>tTranMapLoad1();
// cnwma1
// cnwjre1 test invoice line description mapping method load
vars
	fileContent : String;
	fileName	: String;
	mapName		: String;
	methodName	: String;
	count		: Integer;
	key			: Integer;
	bank		: CM_Bank;
	cargoMap	: CM_TranMap;
	serviceMap	: CM_TIServiceMap;
	productGroupMap	: CM_ProductGroupMap;
	productMap	: CM_ProductMap;
	imexMap		: CM_ImexServiceMap;
	contentsMap	: CM_ContentsMap;
	commodityMap	: CM_CommodityMap;
	transService	: CM_TransServiceBroker;
	quantityMap		: CM_QuantityMap;
	quantityRangeMap : CM_QuantityRangeMap;
	invLineDesc		: CM_InvoiceLineDesc;
	iter		: Iterator;
	mapping : CM_TranMapInvoiceLineMapping;
begin
	fileName := "CargoLoaded";
	mapName := "Loaded";
// TFS 40620	fileContent := 'TranMap Type,TranMap Name,CargoType,Cargo Subtype Group,Cargo Subtype,IMEX,Contents Status,Commodity,Transaction,MoveType,Debtor,Quantity Type,Quantity Range,Invoice Line,Over Dimsn?,Trans Ship?,Is 40?,Is Reefer?,Req Temp?,Is 45?,Is 30?,Is 53?,Is Child?' &amp; CrLf &amp;
	fileContent := 'TranMap Type,TranMap Name,CargoType,Cargo Subtype Group,Cargo Subtype,IMEX,Contents Status,Commodity,Transaction,MoveType,Debtor,Quantity Type,Quantity Range,Quantity Sub Type,Quantity Sub Range,Transfer Type,Grouping,Invoice Line,Over Dimsn?,Trans Ship?,Is 40?,Is Reefer?,Req Temp?,Is 45?,Is 30?,Is 53?,Is Child?' &amp; CrLf &amp;
		'Cargo,'&amp;mapName&amp;',CONT ISO Container,(Default),(Default),(Default),MT,(Default),Container Requires Painting,Resource Mappings:Paint Blue,(Default),CCT02 Transaction Units ›,(Default),,,**Any**,All,VOID' &amp; CrLf &amp;
		'Cargo,'&amp;mapName&amp;',CONT ISO Container,(Default),(Default),(Default),MT,(Default),Container Requires Painting,Resource Mappings:Paint Blue,(Default),CCT02 Transaction Units ›,(Default),,,**Any**,All,UT_ILD01,X,,,,,,,,' &amp; CrLf &amp;
		'Cargo,'&amp;mapName&amp;',CONT ISO Container,(Default),(Default),(Default),MT,(Default),Container Requires Painting,Resource Mappings:Paint Blue,(Default),CCT02 Transaction Units ›,(Default),,,**Any**,All,UT_ILD02,,X,,,,,,,' &amp; CrLf &amp;
		'Cargo,'&amp;mapName&amp;',CONT ISO Container,(Default),(Default),(Default),MT,(Default),Container Requires Painting,Resource Mappings:Paint Blue,(Default),CCT02 Transaction Units ›,(Default),,,**Any**,All,UT_ILD03,,,X,,,,,,' &amp; CrLf &amp;
		'Cargo,'&amp;mapName&amp;',CONT ISO Container,(Default),(Default),(Default),MT,(Default),Container Requires Painting,Resource Mappings:Paint Blue,(Default),CCT02 Transaction Units ›,(Default),,,**Any**,All,UT_ILD04,,,,X,,,,,' &amp; CrLf &amp;
		'Cargo,'&amp;mapName&amp;',CONT ISO Container,(Default),(Default),(Default),MT,(Default),Container Requires Painting,Resource Mappings:Paint Blue,(Default),CCT02 Transaction Units ›,(Default),,,**Any**,All,UT_ILD05,,,,,X,,,,' &amp; CrLf &amp;
		'Cargo,'&amp;mapName&amp;',CONT ISO Container,(Default),(Default),(Default),MT,(Default),Container Requires Painting,Resource Mappings:Paint Blue,(Default),CCT02 Transaction Units ›,(Default),,,**Any**,All,UT_ILD07,,,,,,X,,,' &amp; CrLf &amp;
		'Cargo,'&amp;mapName&amp;',CONT ISO Container,(Default),(Default),(Default),MT,(Default),Container Requires Painting,Resource Mappings:Paint Blue,(Default),CCT02 Transaction Units ›,(Default),,,**Any**,All,UT_ILD08,,,,,,,X,,' &amp; CrLf &amp;
		'Cargo,'&amp;mapName&amp;',CONT ISO Container,(Default),(Default),(Default),MT,(Default),Container Requires Painting,Resource Mappings:Paint Blue,(Default),CCT02 Transaction Units ›,(Default),,,**Any**,All,UT_ILD09,,,,,,,,X,' &amp; CrLf &amp;
		'Cargo,'&amp;mapName&amp;',CONT ISO Container,(Default),(Default),(Default),MT,(Default),Container Requires Painting,Resource Mappings:Paint Blue,(Default),CCT02 Transaction Units ›,(Default),,,**Any**,All,UT_ILD10,,,,,,,,,X' &amp; CrLf &amp;
		'Cargo,'&amp;mapName&amp;',CONT ISO Container,(Default),(Default),(Default),MT,(Default),Container Requires Painting,Resource Mappings:Paint Blue,(Default),CCT02 Transaction Units ›,(Default),,,**Any**,All,UT_ILD11,X,X,X,X,X,,,,,X' &amp; CrLf;
	
	self.deleteInvoiceTransactionMap(1, mapName);
	
	self.transactionMapLoad(fileContent, fileName);
	self.assertNoTrxErrorsOrWarnings();
	
	//bank := app.myPassport.myTerminal.getConfig(DefCompany).CM_Bank;
	bank := app.myPassport.myTerminal.getDefaultCompanyBank();	//17 Apr 2012	NDL	Par 29393
	cargoMap := bank.myCurrentTranMapCargo[mapName];
	self.assertNotNullMsg(cargoMap,"cargo map should not be null");
	// where there are more than instance in the child collections, the required one is always the last (he said hopefully ...)
	serviceMap := cargoMap.allTIServices.last;
	productGroupMap := serviceMap.allProductGroupMaps.last;
	productMap := productGroupMap.allProductMaps.last;
	imexMap := productMap.allImExMaps.last;
	contentsMap := imexMap.contentsMaps.last;
	commodityMap := contentsMap.commoditiesMap.last;
	transService := commodityMap.allTransServiceBrokersByType.last;
	quantityMap := transService.myChildQuantityMap;
	quantityRangeMap := quantityMap.allQuantityRanges.last;
// TFS 40620	self.assertEqualMsg(quantityRangeMap.allInvoiceLineMaps.size, 11, "invoice lines");
// TFS 40620	self.assertEqualMsg(quantityRangeMap.allInvoiceLinesUsed.size, 11, "invoice lines");
	self.assertEqualMsg(quantityRangeMap.allTMInvoiceLineMappings.size, 11, "invoice lines");
	self.assertEqualMsg(quantityRangeMap.allRegisteredMethods.size, 10, "methods");
	// check the external key for each invoice line entry, which is an encoded list of methods
// TFS 40620	iter := quantityRangeMap.allInvoiceLineMaps.createIterator();
	iter := quantityRangeMap.allTMInvoiceLineMappings.createIterator();// TFS 40620
// TFS 40620	while iter.next(invLineDesc) do
// TFS 40620		quantityRangeMap.allInvoiceLineMaps.getIteratorKeys(key, iter);
	while iter.next(mapping) do
		invLineDesc := mapping.myTMInvoiceLineDesc; // TFS 40620
		quantityRangeMap.allTMInvoiceLineMappings.getIteratorKeys(key, iter);// TFS 40620
		count := count + 1;
		if count = 1 then
			self.assertEqualMsg(key, 0, "invoice map key 1");
			self.assertEqualMsg(invLineDesc.narration, "VOID", "invoice map 1");
		elseif count = 2 then
			self.assertEqualMsg(key, 1, "invoice map key 2");
			self.assertEqualMsg(invLineDesc.narration, "UT_ILD01", "invoice map 2");
		elseif count = 3 then
			self.assertEqualMsg(key, 2, "invoice map key 3");
			self.assertEqualMsg(invLineDesc.narration, "UT_ILD02", "invoice map 3");
		elseif count = 4 then
			self.assertEqualMsg(key, 4, "invoice map key 4");
			self.assertEqualMsg(invLineDesc.narration, "UT_ILD03", "invoice map 4");
		elseif count = 5 then
			self.assertEqualMsg(key, 8, "invoice map key 5");
			self.assertEqualMsg(invLineDesc.narration, "UT_ILD04", "invoice map 5");
		elseif count = 6 then
			self.assertEqualMsg(key, 16, "invoice map key 6");
			self.assertEqualMsg(invLineDesc.narration, "UT_ILD05", "invoice map 6");
		//elseif count = 7 then
		//	self.assertEqualMsg(key, 16, "invoice map key 7");
			//self.assertEqualMsg(invLineDesc.narration, "UT_ILD06", "invoice map 7");
		elseif count = 7 then
			self.assertEqualMsg(key, 32, "invoice map key 8");
			self.assertEqualMsg(invLineDesc.narration, "UT_ILD07", "invoice map 8");
		elseif count = 8 then
			self.assertEqualMsg(key, 64, "invoice map key 9");
			self.assertEqualMsg(invLineDesc.narration, "UT_ILD08", "invoice map 9");
		elseif count = 9 then
			self.assertEqualMsg(key, 128, "invoice map key 10");
			self.assertEqualMsg(invLineDesc.narration, "UT_ILD09", "invoice map 10");
		elseif count = 10 then
			self.assertEqualMsg(key, 256, "invoice map key 11");
			self.assertEqualMsg(invLineDesc.narration, "UT_ILD10", "invoice map 11");
		elseif count = 11 then
			self.assertEqualMsg(key, 543, "invoice map key 12");
			self.assertEqualMsg(invLineDesc.narration, "UT_ILD11", "invoice map 12");
		endif;
	endwhile;
	//self.assertEqualMsg(count, 12, "invoice map count");
	self.assertEqualMsg(count, 11, "invoice map count");
	count := 0;
	foreach methodName in quantityRangeMap.allRegisteredMethods do
		count := count + 1;
		if count = 1 then
			self.assertEqualMsg(methodName, "isOverDimensions", "invoice method 1");
		elseif count = 2 then
			self.assertEqualMsg(methodName, "isTranshipItem", "invoice method 2");
		elseif count = 3 then
			self.assertEqualMsg(methodName, "is40", "invoice method 3");
		elseif count = 4 then
			self.assertEqualMsg(methodName, "isReefer", "invoice method 4");
		elseif count = 5 then
			self.assertEqualMsg(methodName, "requiresTemperature", "invoice method 5");
		//elseif count = 6 then
			//self.assertEqualMsg(methodName, "isRORO", "invoice method 6");
		elseif count = 7 then
			self.assertEqualMsg(methodName, "is45", "invoice method 7");
		elseif count = 8 then
			self.assertEqualMsg(methodName, "is30", "invoice method 8");
		elseif count = 9 then
			self.assertEqualMsg(methodName, "is53", "invoice method 9");
		elseif count = 10 then
			self.assertEqualMsg(methodName, "isChild", "invoice method 9");
		endif;
	endforeach;
	self.assertEqualMsg(count, 10, "registered method count");

epilog
	self.resetDefaultTranMap();															// 17/04/2013 cnwmh5
	delete iter;
end;
</source>
    </JadeMethod>
    <JadeMethod name="tTranMapResourceLoad" id="663cbd7d-2305-42da-8614-7499212c5b86">
        <source>tTranMapResourceLoad();
// cnwma1
// cnwjre1 test 36559 load of resource types
vars
	 resourceType : CM_ResourceType;
	 toDoTaskList	: CM_ToDoTaskDescBySortKey;
	 toDoTaskDesc1,
	 toDoTaskDesc2,
	 toDoTaskDesc3 :CM_ToDoTaskDesc ;

	fileContent : String;
	fileName	: String;
	mapName		: String;
	bank		: CM_Bank;
	cargoMap	: CM_TranMap;
	
	tiMap : CM_TIServiceMap;
	pgm : CM_ProductGroupMap;
	mapProduct : CM_ProductMap;
	imexsm : CM_ImexServiceMap;
	csn : CM_ContentsMap;
	commodityMap:      CM_CommodityMap;
	tsb : CM_TransServiceBroker;
	qm	: CM_QuantityMap;
	qrm	: CM_QuantityRangeMap;
	ild	: CM_InvoiceLineDesc;
	
	count1, count2,
	count3, count4,
	count5			: Integer;
mapping : CM_TranMapInvoiceLineMapping;
begin
	// transaction to create ToDoTask Completed
	self.opts.addAssoc(ETRow_TransactionToCreate, 97);

	toDoTaskDesc1 := app.myRoot.allToDoTaskDescsByShortDesc["UT_ToDo1"];
	if toDoTaskDesc1 = null then
		toDoTaskDesc1 := self.createToDoTaskDesc("UT_ToDo1");
	endif;
	self.assertNotNull(toDoTaskDesc1);

	// transaction to create ToDoTask Added
	self.opts.purge();
	self.opts.addAssoc(ETRow_TransactionToCreate, 96);
	toDoTaskDesc2 := app.myRoot.allToDoTaskDescsByShortDesc["UT_ToDo2"];
	if toDoTaskDesc2 = null then
		toDoTaskDesc2 := self.createToDoTaskDesc("UT_ToDo2");
	endif;
	self.assertNotNull(toDoTaskDesc2);

	toDoTaskDesc3 := app.myRoot.allToDoTaskDescsByShortDesc["UT_ToDo3"];
	if toDoTaskDesc3 = null then
		toDoTaskDesc3 := self.createToDoTaskDesc("UT_ToDo3");
	endif;
	self.assertNotNull(toDoTaskDesc3);
	
	create toDoTaskList transient;
	toDoTaskList.add(toDoTaskDesc1);
	toDoTaskList.add(toDoTaskDesc2);
	toDoTaskList.add(toDoTaskDesc3);
	
	resourceType := app.myRoot.allTaskResourceTypes["UTResA"];
	if resourceType = null then
		resourceType := self.addToDoTaskResource("UTResA",
											 "UT Resource A",
											 "UNIT",
											 0,
											 false,
											 true,
											 toDoTaskList);
	endif;
	self.assertNotNull(resourceType);
	
	resourceType := app.myRoot.allTaskResourceTypes["UTResB"];
	if resourceType = null then
		resourceType := self.addToDoTaskResource("UTResB",
											 "UT Resource B",
											 "UNIT",
											 0,
											 false,
											 true,
											 toDoTaskList);
	endif;
	self.assertNotNull(resourceType);
	
	fileName := "ResourceLoad";
	mapName := "Map36559";
	
	fileContent := 	'TranMap Type,TranMap Name,CargoType,Cargo Subtype Group,Cargo Subtype,IMEX,Contents Status,Commodity,Transaction,MoveType,Debtor,Quantity Type,Quantity Range,Grouping,Invoice Line,Over Dimsn?,Trans Ship?,Is 40?,Is Reefer?,Req Temp?,RORO?,Is 45?,Is 30?,Is 53?,Is Child?,Is Haz?,Direct Delivery?' &amp; CrLf &amp;
					'Cargo,Map36559,(Default),(Default),(Default),(Default),(Default),(Default),(Default),,(Default),(Default) ›,(Default),All,VOID' &amp; CrLf &amp;
					'Cargo,Map36559,CONT| ISO Container,(Default),(Default),(Default),(Default),(Default),(Default),,(Default),(Default) ›,(Default),All,VOID' &amp; CrLf &amp;
					'Cargo,Map36559,CONT| ISO Container,(Default),(Default),Import,(Default),(Default),(Default),,(Default),(Default) ›,(Default),All,VOID' &amp; CrLf &amp;
					'Cargo,Map36559,CONT| ISO Container,(Default),(Default),Import,FCL,(Default),(Default),,(Default),(Default) ›,(Default),All,VOID' &amp; CrLf &amp;
					'Cargo,Map36559,CONT| ISO Container,(Default),(Default),Import,FCL,UT_1,(Default),,(Default),(Default) ›,(Default),All,VOID' &amp; CrLf &amp;
					'Cargo,Map36559,CONT| ISO Container,(Default),(Default),Import,FCL,UT_1,Todo Task Added,,(Default),CCT02 TODO Resource Quantity ›,(Default),All,VOID' &amp; CrLf &amp;
					'Cargo,Map36559,CONT| ISO Container,(Default),(Default),Import,FCL,UT_1,Todo Task Added,Resource Mappings:UTResA,(Default),CCT02 TODO Resource Quantity ›,(Default),All,UT_ILD01' &amp; CrLf &amp;
					'Cargo,Map36559,CONT| ISO Container,(Default),(Default),Import,FCL,UT_1,Todo Task Added,Resource Mappings:UTResB,(Default),CCT02 TODO Resource Quantity ›,(Default),All,UT_ILD02' &amp; CrLf &amp;
					'Cargo,Map36559,CONT| ISO Container,(Default),(Default),Import,FCL,UT_1,Todo Task Completed,,(Default),(Default) ›,(Default),All,VOID' &amp; CrLf &amp;
					'Cargo,Map36559,CONT| ISO Container,(Default),(Default),Import,FCL,UT_1,Todo Task Completed,Resource Mappings:UTResA,(Default),(Default) ›,(Default),All,UT_ILD03' &amp; CrLf &amp;
					'Cargo,Map36559,CONT| ISO Container,(Default),(Default),Import,FCL,UT_1,Todo Task Completed,Resource Mappings:UTResB,(Default),(Default) ›,(Default),All,UT_ILD04' &amp; CrLf;

	
	self.transactionMapLoad(fileContent, fileName);
	self.assertNoTrxErrorsOrWarnings();
	
	bank := self.getTerminal.getDefaultCompanyBank();
	cargoMap := bank.myCurrentTranMapCargo[mapName];
	self.assertNotNullMsg(cargoMap,"cargo map should not be null");
	
	// check the map
	foreach tiMap in cargoMap.tiServiceMap do
		count1 := count1 + 1;
		if count1 = 2 then		// first entry is all default
		foreach pgm in tiMap.allProductGroupMaps do
			foreach mapProduct in pgm.allProductMaps do
				foreach imexsm in mapProduct.allImExMaps do
					count2 := count2 + 1;
					if count2 = 2 then		// first entry is all default
					foreach csn in imexsm.contentsMaps do
						count3 := count3 + 1;
						if count3 = 2 then	// first entry is all default
						foreach commodityMap in csn.commoditiesMap do
							count4 := count4 + 1;
							if count4 = 2 then	// first entry is all default
							foreach tsb in commodityMap.allTransServiceBrokersByType do
								count5 := count5 + 1;
								qm := tsb.myChildQuantityMap;
								if count5 = 2 or count5 = 3 or count5 = 4 then
									self.assertEqualMsg(qm.myCalculationType.code, "CCT02",count5.String &amp; " calculation type");
								else
									self.assertNullMsg(qm.myCalculationType,count5.String &amp; " calculation type");
								endif;
								foreach qrm in qm.allQuantityRanges do 
									// TFS 40620 self.assertEqualMsg(qrm.allInvoiceLineMaps.size, 1, "receive allInvoiceLineMaps size");
									self.assertEqualMsg(qrm.allTMInvoiceLineMappings.size, 1, "receive allInvoiceLineMaps size"); // TFS 40620
									// TFS 40620 foreach ild in qrm.allInvoiceLineMaps do
									foreach mapping in qrm.allTMInvoiceLineMappings do // TFS 40620
										ild := mapping.myTMInvoiceLineDesc; // TFS 40620
									
									
									
									
										if count5 = 1 or count5 = 2 or count5 = 5 then
											self.assertEqualMsg(ild.narration, "VOID",count5.String &amp; " invoice line type");
										elseif count5 = 3 then	
											self.assertEqualMsg(ild.narration, "UT_ILD01",count5.String &amp; " invoice line type");
										elseif count5 = 4 then	
											self.assertEqualMsg(ild.narration, "UT_ILD02",count5.String &amp; " invoice line type");
										elseif count5 = 6 then	
											self.assertEqualMsg(ild.narration, "UT_ILD03",count5.String &amp; " invoice line type");
										elseif count5 = 7 then	
											self.assertEqualMsg(ild.narration, "UT_ILD04",count5.String &amp; " invoice line type");
										endif;
									endforeach;
								endforeach;
							endforeach;
							endif;
						endforeach;
						endif;
					endforeach;
					endif;
				endforeach;
			endforeach;
		endforeach;
		endif;
	endforeach;
	self.assertEqualMsg(count5, 7, "Resource entries found");
	
epilog
	delete toDoTaskList;
	if cargoMap &lt;&gt; null then
		self.deleteInvoiceTransactionMap(1, mapName);
	endif;
	self.resetDefaultTranMap();						// 13/07/2015 cnwmh5
end;
</source>
    </JadeMethod>
    <JadeMethod name="tTransactionMapCopy" id="2d0eda09-9e93-400d-a688-5ae4b5646da1">
        <updating/>
        <source>tTransactionMapCopy() updating;
// cnwma1
//	cnwjre1	CCMS 1297 testing
constants
	TranMap = "CopyMap";
	CargoType1 = "UT_STUFF1";
	CargoType2 = "UT_STUFF2";
	GroupId1 = "UGA";
	GroupId2 = "UGB";
	ProductId1 = "UTPRODA";
	ProductId2 = "UTPRODB";
vars
	tranMap	: CM_TranMap;
	cargoType1, cargoType2,
	cargoType3	: CM_CargoType;
	productGroup1, productGroup2	: CM_ProductGroup;
	product1, product2	: CM_Product;
	operator	: CM_Operator;
	root	: CM_Root;
	serviceMap1,
	serviceMap2,
	serviceMap3	: CM_TIServiceMap;
	productGroupMap	: CM_ProductGroupMap;
	productMap	: CM_ProductMap;
	
	id	: String;
	count	: Integer;
begin
	
	root := app.myRoot;
	self.deleteInvoiceTransactionMap(1, TranMap);
	tranMap := self.createTransactionMap(TranMap);
	
	// set up cargo types, product groups and products to have two of each to copy in the transaction map
	cargoType1 := root.getCargoTypeFromAbbrevOrDescr(CargoType1);
	if cargoType1 = null then
		cargoType1 := self.addCargoType(CargoType1, true);
	endif;
	cargoType2 := root.getCargoTypeFromAbbrevOrDescr(CargoType2);
	if cargoType2 = null then
		cargoType2 := self.addCargoType(CargoType2, true);
	endif;
	
	self.setupProductGroup(cargoType1, 2, GroupId1, 2, ProductId1);
	self.setupProductGroup(cargoType2, 2, GroupId2, 2, ProductId2);
	
	// create a transaction map entry for cargo type 1 with one product group and one product and copy it to cargo type 2.
	// just the default entry should be copied, not the specific groups or products
	serviceMap1 := self.createTranMapService(tranMap, cargoType1);
	productGroup1 := cargoType1.allProductGroups.first;
	productGroupMap := self.createTranMapProductGroup(serviceMap1, productGroup1);
	product1 := productGroup1.allProducts.first;
	productMap := self.createTranMapProduct(productGroupMap, product1);
	self.assertNotNullMsg(productMap, "Service map 1 specific product map not null");

	serviceMap2 := self.copyTranMapService(serviceMap1, tranMap, cargoType2);
	count := 0;
	foreach productGroupMap in serviceMap2.allProductGroupMaps do
		count := count + 1;
		self.assertEqualMsg(productGroupMap.myProductGroup, null, "Copied service map is default only");
	endforeach;
	self.assertEqualMsg(count, 1, "Copied service map is default only");
	
	// create map entries for ISO Container, to get content status and commodity
	cargoType3 := app.myRoot.getCargoTypeFromAbbrevOrDescr("CONT");
	serviceMap3 := self.createTranMapService(tranMap, cargoType3);
end;
</source>
    </JadeMethod>
    <JadeMethod name="tTransactionMapExtractLoad" id="7ec49709-fc21-433c-81ba-cffe51b0f46d">
        <updating/>
        <source>tTransactionMapExtractLoad() updating;
// cnwma1
//	cnwjre1	33095 testing
//	create and extract a transaction map for a cargo type with spaces in the code, and an invoice line description with commas in the narration
//		to test the revised extract and load code.
constants
	TranMap = "LoadMap";
	CargoType1 = "UT STUFF1";
	GroupId1 = "U A";
	ProductId1 = "UTPROD A";
	InvoiceLineType1 = "UT invoice, line, description";
	FileName = "c:\temp\TM_LOAD_LoadMap.csv";

vars
	tranMap	: CM_TranMap;
	cargoType1	: CM_CargoType;
	root	: CM_Root;
	bank	: CM_Bank;
	newILD,
	invoiceLineDesc : CM_InvoiceLineDesc;
	invoiceType : CM_InvoiceDesc;
	
	fileContent : String;
	fileName	: String;
	mapName		: String;
	cargoMap	: CM_TranMap;
	
	tiMap : CM_TIServiceMap;
	pgm : CM_ProductGroupMap;
	mapProduct : CM_ProductMap;
	imexsm : CM_ImexServiceMap;
	csn : CM_ContentsMap;
	commodityMap:      CM_CommodityMap;
	tsb : CM_TransServiceBroker;
	qm	: CM_QuantityMap;
	qrm	: CM_QuantityRangeMap;

	ildFound	: Boolean;
	count	: Integer;
	count2	: Integer;
	mapping : CM_TranMapInvoiceLineMapping;
begin
	bank := self.myBank;
	
	root := app.myRoot;
	self.deleteInvoiceTransactionMap(1, TranMap);
	tranMap := self.createTransactionMap(TranMap);
	
	// set up cargo type, product group and product
	cargoType1 := root.getCargoTypeFromAbbrevOrDescr(CargoType1);
	if cargoType1 = null then
		cargoType1 := self.addCargoType(CargoType1, true);
	endif;
	
	self.setupProductGroup(cargoType1, 1, GroupId1, 1, ProductId1);
	
	// invoice line type
	invoiceType := self.getInvoiceType("UT_InvType");		// cash receipt invoice type
	self.addIfNewServiceILD("UT_ServiceX8", "CCT01", InvoiceLineType1, null, invoiceType);
	newILD := bank.invoiceLineDescriptors[InvoiceLineType1];
	
	// load - content from file extract using the 33095 code and the cargo types etc set up here
	mapName := "LoadMap";
	fileContent := 'TranMap Type,TranMap Name,CargoType,Cargo Subtype Group,Cargo Subtype,IMEX,Contents Status,Commodity,Transaction,MoveType,Debtor,Quantity Type,Quantity Range,Grouping,Invoice Line,Over Dimsn?,Trans Ship?,Is 40?,Is Reefer?,Req Temp?,RORO?,Is 45?,Is 30?,Is 53?,Is Child?,Is Haz?,Direct Delivery?' &amp; CrLf &amp;
					'Cargo,LoadMap,(Default),(Default),(Default),(Default),(Default),(Default),(Default),,(Default),(Default) ›,(Default),All,VOID' &amp; CrLf &amp;
					'Cargo,LoadMap,UT STUFF1| UT STUFF1,(Default),(Default),(Default),(Default),(Default),(Default),,(Default),(Default) ›,(Default),All,VOID' &amp; CrLf &amp;
					'Cargo,LoadMap,UT STUFF1| UT STUFF1,U A1| U A1 for unit testing,(Default),(Default),(Default),(Default),(Default),,(Default),(Default) ›,(Default),All,VOID' &amp; CrLf &amp;
					'Cargo,LoadMap,UT STUFF1| UT STUFF1,U A1| U A1 for unit testing,U A1UTPROD A1,(Default),(Default),(Default),(Default),,(Default),(Default) ›,(Default),All,"UT invoice, line, description"' &amp; CrLf;

	
	self.transactionMapLoad(fileContent, fileName);
	self.assertNoTrxErrorsOrWarnings();
	
	cargoMap := bank.myCurrentTranMapCargo[mapName];
	self.assertNotNullMsg(cargoMap,"cargo map should not be null");

	// check the map
	foreach tiMap in cargoMap.tiServiceMap do
		count := count + 1;
		if count = 1 then
			self.assertEqualMsg(tiMap.myCargoType, null, "First cargo type null for default");
		elseif count = 2 then
			self.assertEqualMsg(tiMap.myCargoType.abbreviation, "UT STUFF1", "Second cargo type");
		endif;
		count2 := 0;
		foreach pgm in tiMap.allProductGroupMaps do
			count2 := count2 + 1;
			if count = 2 then
				if count2 = 1 then
					self.assertEqualMsg(pgm.myProductGroup, null, "First cargo group null for default");
				elseif count2 = 2 then
					self.assertEqualMsg(pgm.myProductGroup.code, "U A1", "Second cargo group");
				endif;
			endif;
			foreach mapProduct in pgm.allProductMaps do
				foreach imexsm in mapProduct.allImExMaps do
					foreach csn in imexsm.contentsMaps do
						foreach commodityMap in csn.commoditiesMap do
							foreach tsb in commodityMap.allTransServiceBrokersByType do
								qm := tsb.myChildQuantityMap;
								foreach qrm in qm.allQuantityRanges do
									// TFS 40620 foreach invoiceLineDesc in qrm.allInvoiceLineMaps do 
									foreach mapping in qrm.allTMInvoiceLineMappings do // TFS 40620
										invoiceLineDesc := mapping.myTMInvoiceLineDesc; // TFS 40620
									
									
									
									
										if not invoiceLineDesc.isVoid then
											ildFound := true;
											self.assertEqualMsg(invoiceLineDesc.narration, "UT invoice, line, description", "Non-null ILD");
										endif;
									endforeach;
								endforeach;
							endforeach;
						endforeach;
					endforeach;
				endforeach;
			endforeach;
		endforeach;
	endforeach;
	
	self.assertEqualMsg(count, 2, "Cargo type tran map entries");
	self.assertTrueMsg(ildFound, "Specific invoice line type found");
epilog
	self.resetDefaultTranMap();	
end;</source>
    </JadeMethod>
    <JadeMethod name="tTransactionMapLoadTest" id="d8f3aceb-b8bd-4fde-b9ad-9f34b6c9f030">
        <updating/>
        <source>tTransactionMapLoadTest() updating;
// cnwma1
//	cnwjre1	34477 testing
//	load a transaction map with multiple entries for the same invoice line types but different method flags to check that all gets loaded.
constants
	TranMap = "LoadMap2";
	InvoiceLineType1 = "UT_ILTFSD1";
	InvoiceLineType2 = "UT_ILTFSD2";
	InvoiceLineType3 = "UT_ILTFSD3";

vars
	tranMap	: CM_TranMap;
	root	: CM_Root;
	bank	: CM_Bank;
	invoiceType : CM_InvoiceDesc;
	
	fileContent : String;
	fileName	: String;
	mapName		: String;
	cargoMap	: CM_TranMap;
	
	tiMap : CM_TIServiceMap;
	pgm : CM_ProductGroupMap;
	mapProduct : CM_ProductMap;
	imexsm : CM_ImexServiceMap;
	csn : CM_ContentsMap;
	commodityMap:      CM_CommodityMap;
	tsb : CM_TransServiceBroker;
	qm	: CM_QuantityMap;
	qrm	: CM_QuantityRangeMap;

	recFound,
	relFound	: Boolean;
	
begin
	bank := self.myBank;
	
	root := app.myRoot;
	self.deleteInvoiceTransactionMap(1, TranMap);
	tranMap := self.createTransactionMap(TranMap);
	
	// invoice line types
	invoiceType := self.getInvoiceType("UT_InvType");
	self.addIfNewServiceILD("UT_ServiceX8", "CCT01", InvoiceLineType1, null, invoiceType);
	self.addIfNewServiceILD("UT_ServiceX8", "CCT01", InvoiceLineType2, null, invoiceType);
	self.addIfNewServiceILD("UT_ServiceX8", "CCT01", InvoiceLineType3, null, invoiceType);
	
	// load - content from file extract
	mapName := TranMap;

	fileContent := 'TranMap Type,TranMap Name,CargoType,Cargo Subtype Group,Cargo Subtype,IMEX,Contents Status,Commodity,Transaction,MoveType,Debtor,Quantity Type,Quantity Range,Grouping,Invoice Line,Over Dimsn?,Trans Ship?,Is 40?,Is Reefer?,Req Temp?,RORO?,Is 45?,Is 30?,Is 53?,Is Child?,Is Haz?,Direct Delivery?' &amp; CrLf &amp;
					'Cargo,LoadMap2,(Default),(Default),(Default),(Default),(Default),(Default),(Default),,(Default),(Default) ›,(Default),All,VOID' &amp; CrLf &amp;
					'Cargo,LoadMap2,CONT| ISO Container,(Default),(Default),(Default),(Default),(Default),(Default),,(Default),(Default) ›,(Default),All,VOID' &amp; CrLf &amp;
					'Cargo,LoadMap2,CONT| ISO Container,(Default),(Default),Export,(Default),(Default),(Default),,(Default),(Default) ›,(Default),All,VOID' &amp; CrLf &amp;
					'Cargo,LoadMap2,CONT| ISO Container,(Default),(Default),Export,FCL,(Default),(Default),,(Default),(Default) ›,(Default),All,VOID' &amp; CrLf &amp;
					'Cargo,LoadMap2,CONT| ISO Container,(Default),(Default),Export,FCL,(Default),Released - Ship,,(Default),CCT01 Cargo Quantity ›,(Default),All,UT_ILTFSD3' &amp; CrLf &amp;
					'Cargo,LoadMap2,CONT| ISO Container,(Default),(Default),Export,FCL,(Default),Released - Ship,,(Default),CCT01 Cargo Quantity ›,(Default),All,UT_ILTFSD3,X,,,,,,,,X,' &amp; CrLf &amp;
					'Cargo,LoadMap2,CONT| ISO Container,(Default),(Default),Export,FCL,(Default),Released - Ship,,(Default),CCT01 Cargo Quantity ›,(Default),All,UT_ILTFSD3,,,,,,,,,,X,X' &amp; CrLf &amp;
					'Cargo,LoadMap2,CONT| ISO Container,(Default),(Default),Import,(Default),(Default),(Default),,(Default),(Default) ›,(Default),All,VOID' &amp; CrLf &amp;
					'Cargo,LoadMap2,CONT| ISO Container,(Default),(Default),Import,FCL,(Default),(Default),,(Default),(Default) ›,(Default),All,VOID' &amp; CrLf &amp;
					'Cargo,LoadMap2,CONT| ISO Container,(Default),(Default),Import,FCL,(Default),Received - Ship,,(Default),CCT01 Cargo Quantity ›,(Default),All,UT_ILTFSD1' &amp; CrLf &amp;
					'Cargo,LoadMap2,CONT| ISO Container,(Default),(Default),Import,FCL,(Default),Received - Ship,,(Default),CCT01 Cargo Quantity ›,(Default),All,UT_ILTFSD2,X,,,,,,,,,' &amp; CrLf &amp;
					'Cargo,LoadMap2,CONT| ISO Container,(Default),(Default),Import,FCL,(Default),Received - Ship,,(Default),CCT01 Cargo Quantity ›,(Default),All,UT_ILTFSD1,,,X,,,,,,,' &amp; CrLf &amp;
					'Cargo,LoadMap2,CONT| ISO Container,(Default),(Default),Import,FCL,(Default),Received - Ship,,(Default),CCT01 Cargo Quantity ›,(Default),All,UT_ILTFSD2,X,,,X,,,,,,' &amp; CrLf &amp;
					'Cargo,LoadMap2,CONT| ISO Container,(Default),(Default),Import,FCL,(Default),Received - Ship,,(Default),CCT01 Cargo Quantity ›,(Default),All,UT_ILTFSD1,,,X,X,,,,,,' &amp; CrLf &amp;
					'Cargo,LoadMap2,CONT| ISO Container,(Default),(Default),Import,FCL,(Default),Received - Ship,,(Default),CCT01 Cargo Quantity ›,(Default),All,UT_ILTFSD2,X,,,X,,X,,,,' &amp; CrLf &amp;
					'Cargo,LoadMap2,CONT| ISO Container,(Default),(Default),Import,FCL,(Default),Received - Ship,,(Default),CCT01 Cargo Quantity ›,(Default),All,UT_ILTFSD2,X,,,,,,,X,,' &amp; CrLf &amp;
					'Cargo,LoadMap2,CONT| ISO Container,(Default),(Default),Import,FCL,(Default),Received - Ship,,(Default),CCT01 Cargo Quantity ›,(Default),All,UT_ILTFSD1,,,X,X,,,,,,,,X' &amp; CrLf;
	
	self.transactionMapLoad(fileContent, fileName);
	self.assertNoTrxErrorsOrWarnings();
	
	cargoMap := bank.myCurrentTranMapCargo[mapName];
	self.assertNotNullMsg(cargoMap,"cargo map should not be null");

	// check the map
	foreach tiMap in cargoMap.tiServiceMap do
		foreach pgm in tiMap.allProductGroupMaps do
			foreach mapProduct in pgm.allProductMaps do
				foreach imexsm in mapProduct.allImExMaps do
					foreach csn in imexsm.contentsMaps do
						foreach commodityMap in csn.commoditiesMap do
							foreach tsb in commodityMap.allTransServiceBrokersByType do
								if tsb.className = "CM_ReceiveShip" then
									recFound := true;
									qm := tsb.myChildQuantityMap;
									foreach qrm in qm.allQuantityRanges do 
										// TFS 40620 self.assertEqualMsg(qrm.allInvoiceLineMaps.size, 8, "receive allInvoiceLineMaps size");
										self.assertEqualMsg(qrm.allTMInvoiceLineMappings.size, 8, "receive allTMInvoiceLineMappings size");
										// TFS 40620 self.assertEqualMsg(qrm.allInvoiceLinesUsed.size, 2, "receive allInvoiceLinesUsed size");
									endforeach;
								elseif tsb.className = "CM_ReleaseShip" then
									relFound := true;
									qm := tsb.myChildQuantityMap;
									foreach qrm in qm.allQuantityRanges do
										// TFS 40620 self.assertEqualMsg(qrm.allInvoiceLineMaps.size, 3, "release allInvoiceLineMaps size");
										self.assertEqualMsg(qrm.allTMInvoiceLineMappings.size, 3, "release allTMInvoiceLineMappings size");
										// TFS 40620 self.assertEqualMsg(qrm.allInvoiceLinesUsed.size, 1, "release allInvoiceLinesUsed size");
									endforeach;
								endif;
							endforeach;
						endforeach;
					endforeach;
				endforeach;
			endforeach;
		endforeach;
	endforeach;
	
	self.assertEqualMsg(recFound, true, "Receive Ship entries found");
	self.assertEqualMsg(relFound, true, "Release Ship entries found");
epilog
	self.resetDefaultTranMap();	
end;</source>
    </JadeMethod>
    <JadeMethod name="tTrxMisc" id="54c982c1-1408-4543-9c99-db8edfd93ddc">
        <source>tTrxMisc();

/*

Purpose:		Misc Invoicing Trx

				trxCreateInvoiceLineDescDebtor
				trxCreateInvoiceLineDescGroup
				trxCreateInvoiceLineDescMap
				trxDeleteInvoiceLineDescDebtor
				trxDeleteInvoiceLineDescForce
				trxDeleteInvoiceLineDescGroup
				trxDeleteInvoiceLineDescMap
				trxUpdateInvoiceLineDesc
				trxUpdateInvoiceLineDescDebtor
				trxUpdateInvoiceLineDescGroup
				trxCreateInvoiceLineChargeMap
				trxUpdateInvoiceLineChargeMap
				trxUpdateGLCode
				trxUpdateMeasurementType
				trxUpdateInvoiceLineMove
				trxUpdateInvoiceLineRemarks
				trxUpdateInvoiceLineDesc
				trxUpdateInvoice
				trxUpdateInvoiceStatus
				trxUpdateInvoiceLineConvert
				trxInvoiceRecalculate

Date			Who		Reason
20/05/2015		cnwmh5	Initial creation
17/09/2015		cnwdap1	PAR #36909 CCMS ADP 2537 Minimum Charge Changes
31/01/2023  	navvt20 TFS 56132 Task 56134: UI - Invoice Line Type - UOM
*/
constants

	Narration							: String = "UTMDH_Narration";
	Remarks1							: String = "UTMDH_Remarks";
	DebtorId							: String = "UTMHDEBTOR";
	LineDesc1							: String = "UTMHLineDesc1";
	LineDesc2							: String = "UTMHLineDesc2";
	DebtorName							: String = "UTMDHDebtor";
	InvoiceServiceId					: String = "UT_MDHService1";
vars

	pxyDebtorInvoiceLineDesc			: CM_DebtorInvoiceLineDesc;
	debtorInvoiceLineDesc				: CM_DebtorInvoiceLineDesc;
	theController 						: CMIF_InvoiceLineDescDebtor;
	lineDesc1							: CM_InvoiceLineDesc;
	lineDesc2							: CM_InvoiceLineDesc;
	debtorNodeController				: CMIF_DebtorNode;
	debtorNode							: CM_DebtorNode;
	proxyDebtor							: CM_Debtor;
	calcType							: CM_CalculationType;
	service								: CM_Service;
	mesType 							: CM_MeasurementType;
	proxyMeasurementType				: CM_MeasurementType;
	glCode 								: CM_GLCode;
	pxyGLCode							: CM_GLCode;
	invType								: CM_InvoiceDesc;
	theController2						: CMIF_InvoiceLineDescGroup;
	pxyInvoiceLineDesc					: CM_InvoiceLineDescGroup;
	invoiceLineDescGroup				: CM_InvoiceLineDescGroup;
	obj									: Object;
	pxyMapping							: CM_InvoiceLineDescMapping;
	realMapping 						: CM_InvoiceLineDescMapping;
	invoice2							: CM_Invoice;
	controller							: CMIF_InvoiceLineMove;
	pxyInvoiceLine 						: CM_InvoiceLine;
	lineConvController 					: CMIF_InvoiceLineConvert;
	invoice								: CM_Invoice;
	invLineType							: CM_InvoiceLineDesc;
	debtor								: CM_Debtor;
	invoiceLine							: CM_InvoiceLine;
			
	services							: CM_ServiceByNameDict;

	tempStr								: String;
	date								: Date;
	recalcd								: Boolean;
	calType1							: CM_CalculationType;
	formatPrecision						: Integer;
begin
	
	invType := self.getInvoiceType("UT_DPHINVTYPE");
	self.assertNotNull(invType);
	
	self.deleteInvoiceService(InvoiceServiceId, FORCED_ERASE);
	debtorInvoiceLineDesc := self.myBank.allInvoiceLineDescDebtors[Narration].CM_DebtorInvoiceLineDesc;
	if debtorInvoiceLineDesc &lt;&gt; null then
		app.myTrxDA.trxDeleteInvoiceLineDescDebtor(debtorInvoiceLineDesc, app.myPassport);
		self.assertNoTrxErrorsOrWarnings();
	endif;
	
	invoiceLineDescGroup := self.myBank.invLineDescGroups["UTMHLineDesc3A"].CM_InvoiceLineDescGroup;
	if invoiceLineDescGroup &lt;&gt; null then
		beginTransaction;
		foreach obj in invoiceLineDescGroup.lineDescriptions do
			delete obj;
		endforeach;
		commitTransaction;
		app.myTrxDA.trxDeleteInvoiceLineDescGroup(invoiceLineDescGroup, app.myPassport);
		self.assertNoTrxErrorsOrWarnings();
	endif;
	invoiceLineDescGroup := self.myBank.invLineDescGroups["UTMHLineDesc3"].CM_InvoiceLineDescGroup;
	if invoiceLineDescGroup &lt;&gt; null then
		beginTransaction;
		foreach obj in invoiceLineDescGroup.lineDescriptions do
			delete obj;
		endforeach;
		commitTransaction;
		app.myTrxDA.trxDeleteInvoiceLineDescGroup(invoiceLineDescGroup, app.myPassport);
		self.assertNoTrxErrorsOrWarnings();
	endif;
	
	// create debtor
	debtorNode := app.myRoot.myRootCompany.debtors[DebtorName];
	if debtorNode &lt;&gt; null then
		realMapping := self.myBank.allInvoiceLineDescMappings[debtorNode.CM_Debtor, self.getInvoiceLineType(LineDesc1), invType];
		if realMapping &lt;&gt; null then
			self.clearExpectedTrxErrors();
			self.expectedTrxErrors.add(CONFIRM_REMOVE);
			app.myTrxDA.trxDeleteInvoiceLineDescMap(realMapping, app.myPassport);
			self.assertNoTrxErrorsOrWarnings();
			self.clearExpectedTrxErrors();
		endif;
		self.deleteDebtor(debtorNode);
	endif;
	
	// new debtor
	create debtorNodeController transient;
	create proxyDebtor transient;
	self.setDebtorNodeController(DebtorName, "666600", "", "", debtorNodeController, proxyDebtor);
	
	app.myTrxCA.trxCreateDebtorNode(debtorNodeController, debtorNode, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	self.assertNotNull(debtorNode);
	debtor := debtorNode.CM_Debtor;
	
	create services transient;
	
	// create line desc 1
	self.deleteInvoiceLineType(LineDesc1, FORCED_ERASE);
	
	self.deleteInvoiceService(LineDesc1, FORCED_ERASE);
	self.deleteCalculationType("UT_MDHCONVW", NORMAL_ERASE);
	self.deleteMeasurementType("UTMWeight");
	mesType := self.createMeasurementType(0.5, 6.3, false, false, false, false, "UTMWeight", Type_Weight, "UT MDH Weight Units");
	self.assertNotNullMsg(mesType, "Measurement type UTMWeight not created");
	calcType := self.createInvoiceCalcType(null, INV_CALC_TYPE_CARGOWEIGHTCONVT, "UT_MDHCONVW", "UT_MDHCONVW", 0, 0,0,0,null, false, null, null, 0, 0, INV_CALC_TYPE_UNITY,
		null, null, null, "SUPERUSER", true, false, false, null, null, null, mesType);
	
	self.assertNotNullMsg(calcType, "Calculation type UT_MDHCONVW not created");

	glCode := self.myBank.glCodes["5321-45666"];
	if glCode &lt;&gt; null then
		beginLoad;
		pxyGLCode := glCode.pxyCreateUpdateProxy();
		pxyGLCode.setProxy(self.myBank, pxyGLCode.code, "UnitTest MDH 3AAA", pxyGLCode.isNotAvailableForEntry, null);
		endLoad;
		
		app.myTrxUA.trxUpdateGLCode(pxyGLCode, app.myPassport);
		self.assertNoTrxErrorsOrWarnings();
		self.assertEqual(glCode.remarks, "UnitTest MDH 3AAA");
	endif;
	
	self.deleteInvoiceGLCode("5321-45666");
	glCode := self.createInvoiceGLCode("5321-45666", "UnitTest MDH 3");
	service := self.createInvoiceService(LineDesc1, "MDH Qty3", calcType, glCode);
	self.assertNoTrxErrorsOrWarnings();
	services.add(service);
	
	lineDesc1 := self.createInvoiceLineType(LineDesc1, calcType, invType, services, "SDT1");
	self.assertNoTrxErrorsOrWarnings();
	self.assertNotNull(lineDesc1);
	
	// create line desc 2
	self.deleteInvoiceLineType(LineDesc2, NORMAL_ERASE);  //FORCED_ERASE);
	
	self.deleteInvoiceService(LineDesc2, FORCED_ERASE);
	self.deleteCalculationType("UT_MDHCONVW1", NORMAL_ERASE);
	self.deleteMeasurementType("UTMWeight1");
	mesType := self.createMeasurementType(0.5, 6.3, false, false, false, false, "UTMWeight1", Type_Weight, "UT MDH Weight1 Units");
	self.assertNotNullMsg(mesType, "Measurement type UTMWeight1 not created");
	
	beginLoad;
	proxyMeasurementType := mesType.pxyCreateUpdateProxy();
	
	formatPrecision := proxyMeasurementType.calculateFormatPrecision(mesType.format);															//14.11.2022 navma1 #55381
	
	proxyMeasurementType.setProxy(mesType.conversionRate, mesType.format, mesType.isAvailableForEntry, mesType.isDefault, 
		mesType.isDisplay, mesType.isSystemType, mesType.shortName, mesType.measurementType, "UT MDH Weight1 Units AAA",formatPrecision);		//14.11.2022 navma1 #55381	
	endLoad;
	app.myTrxUA.trxUpdateMeasurementType(proxyMeasurementType, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	self.assertEqual(mesType.name, "UT MDH Weight1 Units AAA");	

	calcType := self.createInvoiceCalcType(null, INV_CALC_TYPE_CARGOWEIGHTCONVT, "UT_MDHCONVW1", "UT_MDHCONVW1", 0, 0,0,0,null, false, null, null, 0, 0, INV_CALC_TYPE_UNITY,
		null, null, null, "SUPERUSER", true, false, false, null, null, null, mesType);
	
	self.assertNotNullMsg(calcType, "Calculation type UT_MDHCONVW1 not created");

	self.deleteInvoiceGLCode("5321-45667");
	glCode := self.createInvoiceGLCode("5321-45667", "UnitTest MDH 4");
	service := self.createInvoiceService(LineDesc2, "MDH Qty4", calcType, glCode);
	self.assertNoTrxErrorsOrWarnings();
	services.add(service);
	
	lineDesc2 := self.createInvoiceLineType(LineDesc2, calcType, invType, services, "SDT1");
	self.assertNoTrxErrorsOrWarnings();
	self.assertNotNull(lineDesc2);
	
	create pxyDebtorInvoiceLineDesc transient;
	pxyDebtorInvoiceLineDesc.setPropertyValue("bank", self.myBank);
	//pxyDebtorInvoiceLineDesc.setProxy(false, false, null, null, null, null, Narration, null, Remarks1, null, null, false);					// PAR #36909
	//pxyDebtorInvoiceLineDesc.setProxy(false, false, null, null, null, null, Narration, null, Remarks1, null, null, false, null, null, null, false, false,null);	// PAR #36909 // 31 Jan 2023 navvt20 TFS 56134
	pxyDebtorInvoiceLineDesc.setProxy(false, false, null, null, null, null, Narration, null, Remarks1, null, null, false, null, null, null, false, false,null,null); // PAR #36909 // 31 Jan 2023 navvt20 TFS 56134
	pxyDebtorInvoiceLineDesc.setProxyBank(self.myBank);
	
	create theController transient;
	theController.allInvoiceLineDescriptions.add(lineDesc1);
	theController.allConsolidatingDebtor.add(debtorNode.CM_Debtor);
	theController.myBank := self.myBank;
	theController.myProxyInvoiceLineDebtor := pxyDebtorInvoiceLineDesc;
	
	app.myTrxCA.trxCreateInvoiceLineDescDebtor(theController, debtorInvoiceLineDesc, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	self.assertNotNull(debtorInvoiceLineDesc);
	self.assertEqual(debtorInvoiceLineDesc.allConsolidatingInvLineDesc.size, 1);
	
	delete pxyDebtorInvoiceLineDesc;
	beginLoad;
	pxyDebtorInvoiceLineDesc := debtorInvoiceLineDesc.pxyCreateUpdateProxy();
	pxyDebtorInvoiceLineDesc.setProxyBank(debtorInvoiceLineDesc.myBankDebtor);
	endLoad;
	theController.myProxyInvoiceLineDebtor := pxyDebtorInvoiceLineDesc;
	
	theController.allInvoiceLineDescriptions.add(lineDesc2);
	app.myTrxUA.trxUpdateInvoiceLineDescDebtor(theController, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	self.assertEqual(debtorInvoiceLineDesc.allConsolidatingInvLineDesc.size, 2);
	
	// trxCreateInvoiceLineDescGroup, trxDeleteInvoiceLineDescGroup, trxUpdateInvoiceLineDescGroup
	
	create pxyInvoiceLineDesc transient;
	pxyInvoiceLineDesc.setProxy("UTMHLineDesc3",null,null);
	pxyInvoiceLineDesc.bank := self.myBank;
	
	create theController2 transient;
	theController2.allInvoiceLineDesc.add(lineDesc1);
	theController2.myPxyLineDescGroup := pxyInvoiceLineDesc;
	theController2.myBank := self.myBank;
	
	app.myTrxCA.trxCreateInvoiceLineDescGroup(theController2,  invoiceLineDescGroup, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
	// change the calculation type of the invoice line types													//cnwmk3 PAR 37395
	calType1 := app.myRoot.allCalculationTypesByCode['CCT06'];	// INV_CALC_TYPE_DAYS_SINCE_RECVL;
	self.assertNotNullMsg(calType1, "Calculation type INV_CALC_TYPE_DAYS_SINCE_RECVL not found");
	self.updateInvoiceLineType(lineDesc1, lineDesc1.narration, calType1, lineDesc1.invoiceType, lineDesc1.services, lineDesc1.myDebtorType.code);
	
	delete pxyInvoiceLineDesc;
	beginLoad;
	pxyInvoiceLineDesc := invoiceLineDescGroup.pxyCreateUpdateProxy();
	endLoad;
	theController2.myPxyLineDescGroup := pxyInvoiceLineDesc;
		
	pxyInvoiceLineDesc.setPropertyValue("description", "UTMHLineDesc3A");
	app.myTrxUA.trxUpdateInvoiceLineDescGroup(theController2, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	self.assertEqual(invoiceLineDescGroup.description, "UTMHLineDesc3A");	
	
	// trxCreateInvoiceLineDescMap, trxDeleteInvoiceLineDescMap
	
	create pxyMapping transient;
	pxyMapping.setProxy(self.myBank, debtorNode.CM_Debtor, self.getInvoiceLineType(LineDesc1), invType);
	app.myTrxCA.trxCreateInvoiceLineDescMap(pxyMapping, realMapping, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	self.assertNotNull(realMapping);
	
	// 26/05/2015 cnwmh5 - trxUpdateInvoiceLineMove / trxUpdateInvoiceLineRemarks
	
	date := app.cnGetServerTime().date;
	invType := self.getInvoiceType("UT_InvType");
	invoice := self.createManualInvoice(self.myBank, debtor, null, invType, null);
	invLineType := self.getInvoiceLineType("UT_ILD01");
	invoiceLine := self.createManualInvoiceLine(invLineType, invoice, 10, "Line 1", date);
	invoiceLine := self.createManualInvoiceLine(invLineType, invoice, 5, "Line 2", date);
	invLineType := self.getInvoiceLineType("UT_ILD02");
	invoiceLine := self.createManualInvoiceLine(invLineType, invoice, 10, "Line 3", date);
	invoiceLine := self.createManualInvoiceLine(invLineType, invoice, 5, "Line 4", date);
	invLineType := self.getInvoiceLineType("UT_LineTypeLastLoad");
	invoiceLine := self.createManualInvoiceLine(invLineType, invoice, 10, "Line 5", date);
	invoiceLine := self.createManualInvoiceLine(invLineType, invoice, 5, "Line 6", date);
	
	invoice2 := self.createManualInvoice(self.myBank, debtor, null, invType, null);
	self.assertEqual(invoice2.invoiceLines.size, 0);
	
	create controller transient;
	controller.allInvoiceLines.add(invoice.invoiceLines.first);
	controller.allInvoiceLines.add(invoice.invoiceLines.last);
	controller.myInvoice := invoice2;
	app.myTrxUA.trxUpdateInvoiceLineMove(controller, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	self.assertEqual(invoice.invoiceLines.size, 4);
	self.assertEqual(invoice2.invoiceLines.size, 2);	
	
	invoiceLine := invoice2.invoiceLines.first;
	beginLoad;
	pxyInvoiceLine := invoiceLine.pxyCreateUpdateProxy();
	endLoad;
	
	pxyInvoiceLine.setRemarks("Line 1AAAA");
	pxyInvoiceLine.setTrackedItemOnly(invoiceLine.trackedItem);
	app.myTrxUA.trxUpdateInvoiceLineRemarks(pxyInvoiceLine, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
	foreach invoiceLine in invoice2.invoiceLines do
		if not invoiceLine.remarks &lt;&gt; "Line 1" and not invoiceLine.remarks &lt;&gt; "Line 6" then
			self.assertEqual(true, true);		
		endif;
	endforeach;	
	
	tempStr := invType.description &amp; "DDD";
	self.opts.purge();
	self.opts.addAssoc("Description", tempStr);
	self.xTrxUpdateInvoiceLineDesc(invType);
	self.assertEqual(invType.description, tempStr);
	tempStr := tempStr[1:tempStr.length-3];
	self.opts.purge();
	self.opts.addAssoc("Description", tempStr);
	self.xTrxUpdateInvoiceLineDesc(invType);
	
	self.opts.purge();
	self.opts.addAssoc("PurchaseOrderNumber", "POUT1000");
	self.xTrxUpdateInvoice(invoice2);
	self.assertEqual(invoice2.purchaseOrderNumber, "POUT1000");
	
	invoice2 := self.createManualInvoice(self.myBank, debtor, null, invType, null);
	invLineType := self.getInvoiceLineType("UT_ILD01");
	invoiceLine := self.createManualInvoiceLine(invLineType, invoice2, 7, "Line Status", date);
	
	self.xTrxUpdateInvoiceStatus(invoice2, CM_InvoiceLine.STATUS_VOIDED);
	self.assertEqual(invoice2.invoiceLines.first.status, CM_InvoiceLine.STATUS_VOIDED);
	
	invoice2 := self.createManualInvoice(self.myBank, debtor, null, invType, null);
	invLineType := self.getInvoiceLineType("UT_ILD01");
	invoiceLine := self.createManualInvoiceLine(invLineType, invoice2, 17, "Line Convert", date);
	invLineType := self.getInvoiceLineType("UT_LineTypeLastLoad");
	self.xTrxUpdateInvoiceLineConvert(invoice2, invLineType);
	self.assertEqual(invoice2.invoiceLines.first.invoiceLineDesc, invLineType);
	
	if not invoice2.isPostedOrReversal then
		app.myTrxUA.trxInvoiceRecalculate(invoice2, app.myPassport);
		self.assertNoTrxErrorsOrWarnings();
		recalcd := true;
	endif;
	self.assertEqual(recalcd, true);
	
epilog

	delete theController;
	delete pxyDebtorInvoiceLineDesc;
	delete services;
	delete debtorNodeController;
	delete proxyDebtor;
	delete pxyInvoiceLineDesc;
	delete theController2;
	delete pxyMapping;
	delete pxyGLCode;
	delete proxyMeasurementType;
	delete controller;
	delete pxyInvoiceLine;
	delete lineConvController;
	delete debtorNodeController;
	delete proxyDebtor;

end;</source>
    </JadeMethod>
    <JadeMethod name="tUpdateInvoiceToCredit" id="9b0d5eae-3192-47ea-b540-87770101fc74">
        <source>tUpdateInvoiceToCredit();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 January 2023	navkc1	Initial creation TFS CR 55305 Task 55534

*/
constants
	DebtorName	= "UT_Debtor1";
	InvoiceType = "UT_INV";
	VoyageId	= "UT_VOY1";
	
vars
	bank		: CM_Bank;
	terminal	: CM_Terminal;
	debtor		: CM_Debtor;
	invType		: CM_InvoiceDesc;
	voyage		: CM_Voyage;
	invoice,
	invoice2,
	pxyInvoice,
	pxyInvoice2	: CM_Invoice;
	allInvoices : CM_InvoiceSet;
	
begin
	
	terminal := self.getTerminal();
	self.assertNotNull(terminal);
	
	bank := terminal.getDefaultCompanyBank();
	self.assertNotNull(bank);
	
	debtor := self.getDebtor(DebtorName);
	self.assertNotNull(debtor);
	
	invType := self.getInvoiceType(InvoiceType);
	self.assertNotNull(invType);
	
	voyage := self.getVoyage(VoyageId);
	self.assertNotNull(voyage);
	
	invoice := self.createManualInvoice(bank, debtor, voyage, invType, null);
	self.assertNotNull(invoice);
	self.assertEqual(invoice.category, InvoiceCategory_Invoice);
	
	invoice2 := self.createManualInvoice(bank, debtor, voyage, invType, null);
	self.assertNotNull(invoice2);
	self.assertEqual(invoice2.category, InvoiceCategory_Invoice);
	
	beginLoad;
	pxyInvoice  := invoice.pxyCreateUpdateProxy();
	pxyInvoice2 := invoice2.pxyCreateUpdateProxy();
	endLoad;
	
	create allInvoices transient;
	
	pxyInvoice.setCategory(InvoiceCategory_CreditNote);
	pxyInvoice2.setCategory(InvoiceCategory_CreditNote);
	
	allInvoices.add(pxyInvoice);
	allInvoices.add(pxyInvoice2);
	
	app.myTrxUA.trxUpdateInvoiceToCredit(allInvoices, app.myPassport);
	
	self.assertEqual(invoice.category, InvoiceCategory_CreditNote);
	self.assertEqual(invoice2.category, InvoiceCategory_CreditNote);
	
	self.deleteInvoice(invoice);
	self.deleteInvoice(invoice2);
	
epilog
	delete pxyInvoice;
	delete pxyInvoice2;
	delete allInvoices;
end;</source>
    </JadeMethod>
    <JadeMethod name="tUsedVehicleCleaningBase" id="3b998e57-edd8-4a0a-acee-76d1b1a6ed78">
        <updating/>
        <source>tUsedVehicleCleaningBase() updating;
// cnwdap1
// cnwjre1 TFS 2570 AAT Used Vehicle CLeaning, don't charge storage while the vehicle is being cleaned and 2 days later
//	BASE test, create transactions as per the Business Requirements
vars
	triggers : CM_StorageTriggerByType;
	includeFirstDay : Boolean;
	includeLastDay : Boolean;
	storageConfig : CM_StorageConfig;
	calendar : CM_Calendar;
	shipReceivalType : Integer;
	shipReleaseType	: Integer;
	chargedDaysWorking : Boolean;
	freeDaysWorking	: Boolean;

	theService : CM_Service;
	calType1		: CM_CalculationType;
	invLine			: CM_InvoiceLine;
	invType			: CM_InvoiceDesc;
	invLineType1,
	invLineType2,
	invLineType3  	: CM_InvoiceLineDesc;
	services : CM_ServiceByNameDict;
	bs: CM_BlockStack;
	voy : CM_Voyage;
	cargo : CM_TrackedItem;
	aPort : CM_Port;
	tran : CM_TITransaction;
	tranTS : TimeStamp;
	tranDate	: Date;
	quantity	: Real;
	id		: String;
begin
	self.deleteStorageConfig( false );
	// set the options
	includeFirstDay := false;
	includeLastDay := true;
	storageConfig := self.setupStorageConfig2(calendar, includeFirstDay, includeLastDay, shipReceivalType, shipReleaseType, chargedDaysWorking, freeDaysWorking, null, triggers, true, 2, 0, 2);

	bs:= self.getTerminalArea("UTSTORE3").CM_BlockStack;
	if bs &lt;&gt; null then
		self.deleteInvoiceLines(bs.myLocationsController);
	endif;
	self.deleteTerminalArea("UTSTORE3");
	self.deleteInvoiceType("UT_InvTypeStore3");
	self.deleteInvoiceService("UT_ServiceStore13", FORCED_ERASE);
	self.deleteInvoiceLineType("UT_LineTypeStoreFree1", FORCED_ERASE);
	self.deleteInvoiceLineType("UT_LineTypeStoreFree2", FORCED_ERASE);
	self.deleteInvoiceLineType("UT_LineTypeStoreFree3", FORCED_ERASE);

	create services transient;

	////////////////////////////////////////////////////////////////////
	// Create Invoice Type, Services and Invoice Line Type
	////////////////////////////////////////////////////////////////////
	invType := self.createInvoiceType("UT_InvTypeStore3", InvoiceTypeStorage);
	self.assertNotNullMsg(invType, "Invoice type UT_InvTypeStore3 not created");

	calType1 := app.myRoot.allCalculationTypesByCode['CCT06'];	// INV_CALC_TYPE_DAYS_SINCE_RECVL;
	self.assertNotNullMsg(calType1, "Calculation type INV_CALC_TYPE_DAYS_SINCE_RECVL not found");
	
	
	theService := self.createInvoiceService("UT_ServiceStore13","UT Store1", calType1, null);
	self.assertNotNullMsg(theService, "UT_ServiceStore13 not created");
 	services.add(theService);
	
	invLineType1 := self.createInvoiceLineType("UT_LineTypeStoreFree1", calType1, invType, services,"SDT1");
	invLineType2 := self.createInvoiceLineType("UT_LineTypeStoreFree2", calType1, invType, services,"SDT1");
	invLineType3 := self.createInvoiceLineType("UT_LineTypeStoreFree3", calType1, invType, services,"SDT1");
	
	self.assertNotNullMsg(invLineType1, "UT_LineTypeStoreFree1 not created");
	self.assertNotNullMsg(invLineType2, "UT_LineTypeStoreFree2 not created");
	self.assertNotNullMsg(invLineType3, "UT_LineTypeStoreFree3 not created");
	if invLineType1 &lt;&gt; null then
		self.assertNotNullMsg(invLineType1.invoiceType, "UT_LineTypeStoreFree1 has null INV TYPE");
	endif;
	if invLineType2 &lt;&gt; null then
		self.assertNotNullMsg(invLineType2.invoiceType, "UT_LineTypeStoreFree2 has null INV TYPE");
	endif;
	if invLineType3 &lt;&gt; null then
		self.assertNotNullMsg(invLineType3.invoiceType, "UT_LineTypeStoreFree3 has null INV TYPE");
	endif;

	// Need to map to above invoice line types, using quantity ranges
	self.tranMapLoadStorageClean();
	
	// create a container 
	voy :=self.createVesselVoyage3();
	aPort := app.myRoot.allPorts["NZAKL"];
	bs:= addBlockStack("UTSTORE3", 100, null);

	// original TFS is for cars but it doesn't matter for these tests
	cargo := self.addContainerAtLocnDisch("STOR4300111", "2200", "MT", TI_IMEX_STATUS_IMPORT, bs.myLocationsController, aPort, voy);
	
	// date transactions to 01/06 and delete an Receive
	tranDate := "01/06/2016".Date;
	tranTS.setDate(tranDate);
	foreach tran in cargo.allTransactions do
		tranTS.setDate(tranDate);
		tranTS.setTime(tran.dateTime.time);
		
		beginTransaction;
		if tran.class.name = CM_Receive.name then
			delete tran;
		else
			tran.setPropertyValue("dateTime", tranTS);
		endif;
		commitTransaction;
	endforeach;
	
	// Create a Receive Ship
	tranDate := "01/06/2016".Date;
	tranTS.setDate(tranDate);
	self.createDatedChargedTransaction(cargo, tranTS, TRANS_TYPE_REC_SHIP, true);

	// Letter of Authorisation received 06/06, set the StorageCharges stop which creates a storage
	// back-date this a day so that the day of authorisation is not charged
	tranDate := "05/06/2016".Date;
	tranTS.setDate(tranDate);
	self.createDatedChargedTransaction(cargo, tranTS, TRANS_TYPE_STORAGE, true);
	// with 2 free days get two storage transactions, the first no-charge and the second with 2 lines qty=3 Free1 and qty=0 (!!) Free2
	//  otherwise one storage transaction with 2 lines, qty=3 ILD=Free1 and qty=2 ILD=Free2 (first qty=2 with back-dating)
	
	// clean the car on 08/06, clear the StorageCharges stop which creates a non-charge storage [and 2 days free storage from here]
	//  simulate the free days by forward-dating the no-charge storage
	tranDate := "10/06/2016".Date;
	tranTS.setDate(tranDate);
	self.createDatedChargedTransaction(cargo, tranTS, TRANS_TYPE_STORAGE, false);
	// no lines (now)
	
	// Release the car on 12/06 which also creates a storage
	tranDate := "12/06/2016".Date;
	tranTS.setDate(tranDate);
	self.createDatedChargedTransaction(cargo, tranTS, TRANS_TYPE_STORAGE, true);
	// with the second storage dated 08/06 1 line qty=4 ILD=Free3
	// with the second storage dated 10/06 1 line qty=2 ILD=Free3
	
	// so the total quantity of the storage charges is 3 + 2 or 5 (4 in the business requirement)
	
	
	id := cargo.id;	// debug line
	foreach tran in cargo.allTransactions do
		foreach invLine in tran.allInvoiceLines do
			quantity := quantity + invLine.quantity;
		endforeach;
	endforeach;
	
	self.assertEqualMsg(quantity, 4.Real, "total storage days charged");
epilog
	self.resetDefaultTranMap();
	self.deleteStorageConfig( true );
	delete services;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="tUsedVehicleCleaningWithStops" id="aa0b262b-f6aa-4296-b4c7-0472b1aa2666">
        <updating/>
        <source>tUsedVehicleCleaningWithStops() updating;
// cnwdap1
// cnwjre1 TFS 2570 AAT Used Vehicle CLeaning, don't charge storage while the vehicle is being cleaned and 2 days later.
//	More complete test, create transactions as per the Business Requirements by applying and clearing stops
vars
	triggers : CM_StorageTriggerByType;
	includeFirstDay : Boolean;
	includeLastDay : Boolean;
	storageConfig : CM_StorageConfig;
	calendar : CM_Calendar;
	shipReceivalType : Integer;
	shipReleaseType	: Integer;
	chargedDaysWorking : Boolean;
	freeDaysWorking	: Boolean;

	theService : CM_Service;
	calType1		: CM_CalculationType;
	invLine			: CM_InvoiceLine;
	invType			: CM_InvoiceDesc;
	invLineType1,
	invLineType2,
	invLineType3  	: CM_InvoiceLineDesc;
	services : CM_ServiceByNameDict;
	bs: CM_BlockStack;
	voy : CM_Voyage;
	cargo : CM_TrackedItem;
	aPort : CM_Port;
	tran : CM_TITransaction;
	tranTS : TimeStamp;
	tranDate	: Date;
	quantity	: Real;
	id		: String;
	selectedTypes	: CM_CargoBOLTypeSet;
	stopsTable	: CM_StopsTable;
	preventAreas	: IntegerArray;
	opts : CM_AssociationDict;
	now	: Date;
	count	: Integer;
begin

	// set the options
	includeFirstDay := false;
	includeLastDay := true;
	storageConfig := self.setupStorageConfig2(calendar, includeFirstDay, includeLastDay, shipReceivalType, shipReleaseType, chargedDaysWorking, freeDaysWorking, null, triggers, true, 2, 0, 2);

	bs:= self.getTerminalArea("UTSTORE3").CM_BlockStack;
	if bs &lt;&gt; null then
		self.deleteInvoiceLines(bs.myLocationsController);
	endif;
	self.deleteTerminalArea("UTSTORE3");
	self.deleteInvoiceType("UT_InvTypeStore3");
	self.deleteInvoiceService("UT_ServiceStore13", FORCED_ERASE);
	self.deleteInvoiceLineType("UT_LineTypeStoreFree1", FORCED_ERASE);
	self.deleteInvoiceLineType("UT_LineTypeStoreFree2", FORCED_ERASE);
	self.deleteInvoiceLineType("UT_LineTypeStoreFree3", FORCED_ERASE);

	create services transient;

	////////////////////////////////////////////////////////////////////
	// Create Invoice Type, Services and Invoice Line Type
	////////////////////////////////////////////////////////////////////
	invType := self.createInvoiceType("UT_InvTypeStore3", InvoiceTypeStorage);
	self.assertNotNullMsg(invType, "Invoice type UT_InvTypeStore3 not created");

	calType1 := app.myRoot.allCalculationTypesByCode['CCT06'];	// INV_CALC_TYPE_DAYS_SINCE_RECVL;
	self.assertNotNullMsg(calType1, "Calculation type INV_CALC_TYPE_DAYS_SINCE_RECVL not found");
	
	
	theService := self.createInvoiceService("UT_ServiceStore13","UT Store1", calType1, null);
	self.assertNotNullMsg(theService, "UT_ServiceStore13 not created");
 	services.add(theService);
	
	invLineType1 := self.createInvoiceLineType("UT_LineTypeStoreFree1", calType1, invType, services,"SDT1");
	invLineType2 := self.createInvoiceLineType("UT_LineTypeStoreFree2", calType1, invType, services,"SDT1");
	invLineType3 := self.createInvoiceLineType("UT_LineTypeStoreFree3", calType1, invType, services,"SDT1");
	
	self.assertNotNullMsg(invLineType1, "UT_LineTypeStoreFree1 not created");
	self.assertNotNullMsg(invLineType2, "UT_LineTypeStoreFree2 not created");
	self.assertNotNullMsg(invLineType3, "UT_LineTypeStoreFree3 not created");
	if invLineType1 &lt;&gt; null then
		self.assertNotNullMsg(invLineType1.invoiceType, "UT_LineTypeStoreFree1 has null INV TYPE");
	endif;
	if invLineType2 &lt;&gt; null then
		self.assertNotNullMsg(invLineType2.invoiceType, "UT_LineTypeStoreFree2 has null INV TYPE");
	endif;
	if invLineType3 &lt;&gt; null then
		self.assertNotNullMsg(invLineType3.invoiceType, "UT_LineTypeStoreFree3 has null INV TYPE");
	endif;

	// Need to map to above invoice line types, using quantity ranges
	self.tranMapLoadStorageClean();
	
	// Create a Stop Type for containers and StopPreventStorageCharges
	self.deleteStopsTable(99);
	create selectedTypes transient;
	selectedTypes.add(app.myRoot.allCargoTypesById[TI_CargoType_Container]);
	create preventAreas transient;
	preventAreas.add(StopPreventStorageCharges);
	create opts transient;
	opts.addAssoc(ETRow_CheckStopAreas, preventAreas);
	opts.addAssoc( ETRow_IsMT, true );
	opts.addAssoc( ETRow_IsFull, true );
	stopsTable := self.addStopsTable(99, "UT", "Unit Test", selectedTypes, opts);

	// create a container 
	voy :=self.createVesselVoyage3();
	aPort := app.myRoot.allPorts["NZAKL"];
	bs:= addBlockStack("UTSTORE3", 100, null);

	// original TFS is for cars but it doesn't matter for these tests
	cargo := self.addContainerAtLocnDisch("STOR4300111", "2200", "MT", TI_IMEX_STATUS_IMPORT, bs.myLocationsController, aPort, voy);
	
	// date transactions to 01/06 and delete an Receive
	tranDate := "01/06/2016".Date;
	tranTS.setDate(tranDate);
	foreach tran in cargo.allTransactions do
		tranTS.setDate(tranDate);
		tranTS.setTime(tran.dateTime.time);
		
		beginTransaction;
		if tran.class.name = CM_Receive.name then
			delete tran;
		else
			tran.setPropertyValue("dateTime", tranTS);
		endif;
		commitTransaction;
	endforeach;
	
	// Create a Receive Ship
	tranDate := "01/06/2016".Date;
	tranTS.setDate(tranDate);
	self.createDatedChargedTransaction(cargo, tranTS, TRANS_TYPE_REC_SHIP, true);

	// when Letter of Authorisation is received a stop of type StopPreventStorageCharges is added
	// this should create a storage transaction back-dated one day
	self.addStop(cargo, stopsTable);
	
	// when the car is cleaned the StopPreventStorageCharges stop is cleared
	// this should create a no-charge storage transaction the configured number of days [2] into the future
	self.deleteStop(cargo, stopsTable);

	now := app.actualTimeServer.date;
	foreach tran in cargo.allTransactions do
		if tran.isKindOf(CM_Storage) then
			count := count + 1;
			if count = 1 then
				// this is the 2 days free storage
				self.assertEqualMsg(tran.dateTime.date, "03/06/2016".Date, "First storage date");
				self.assertEqualMsg(tran.noCharge, true, "First storage noCharge");
			elseif count = 2 then
				// this is from setting the stop
				self.assertEqualMsg(tran.dateTime.date, now - 1, "Second storage date");
				self.assertEqualMsg(tran.noCharge, false, "Second storage noCharge");
			elseif count = 3 then
				// this is from clearing the stop
				self.assertEqualMsg(tran.dateTime.date, now + 2, "Third storage date");
				self.assertEqualMsg(tran.noCharge, true, "Third storage noCharge");
			endif;
		endif;
	endforeach;
	
	self.assertEqualMsg(3, count, "Storage transactions");
epilog
	self.resetDefaultTranMap();
	self.deleteStorageConfig( true );
	delete services;
	delete selectedTypes;
	delete preventAreas;
	delete opts;
end;</source>
    </JadeMethod>
    <JadeMethod name="tVehicleCleaningWithShortStops" id="4887fd6d-f6ff-451d-bd01-dc4648bf03ff">
        <updating/>
        <source>tVehicleCleaningWithShortStops() updating;
// cnwdap1
// Purpose:			TFS 2570 AAT Used Vehicle CLeaning, don't charge storage while the vehicle is being cleaned and 2 days later.
//					This test has a shortened time period between receival and applying the cleaning stop
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 21/10/2016	cnwdap1		Initial creation TFS AAT 2570
vars
	triggers : CM_StorageTriggerByType;
	includeFirstDay : Boolean;
	includeLastDay : Boolean;
	storageConfig : CM_StorageConfig;
	calendar : CM_Calendar;
	shipReceivalType : Integer;
	shipReleaseType	: Integer;
	chargedDaysWorking : Boolean;
	freeDaysWorking	: Boolean;

	theService : CM_Service;
	calType1		: CM_CalculationType;
	invLine			: CM_InvoiceLine;
	invType			: CM_InvoiceDesc;
	invLineType1,
	invLineType2,
	invLineType3  	: CM_InvoiceLineDesc;
	services : CM_ServiceByNameDict;
	bs: CM_BlockStack;
	voy : CM_Voyage;
	cargo : CM_TrackedItem;
	aPort : CM_Port;
	tran : CM_TITransaction;
	tranTS : TimeStamp;
	tranDate	: Date;
	quantity	: Real;
	id		: String;
	selectedTypes	: CM_CargoBOLTypeSet;
	stopsTable	: CM_StopsTable;
	preventAreas	: IntegerArray;
	opts : CM_AssociationDict;
	now	: Date;
	count	: Integer;
	oid : String;
	vvr : CM_VehicleVisitRecord;
	singleGate : CM_Gate;
	storageDetail : CM_StorageDetail;
begin

	self.deleteStorageConfig( false );
	// set the options
	includeFirstDay := false;
	includeLastDay := true;
	storageConfig := self.setupStorageConfig2(calendar, includeFirstDay, includeLastDay, shipReceivalType, shipReleaseType, chargedDaysWorking, freeDaysWorking, null, triggers, true, 2, 0, 2);

	bs:= self.getTerminalArea("UTSTORE3").CM_BlockStack;
	if bs &lt;&gt; null then
		self.deleteInvoiceLines(bs.myLocationsController);
	endif;
	self.deleteTerminalArea("UTSTORE3");
	self.deleteInvoiceType("UT_InvTypeStore3");
	self.deleteInvoiceService("UT_ServiceStore13", FORCED_ERASE);
	self.deleteInvoiceLineType("UT_LineTypeStoreFree1", FORCED_ERASE);
	self.deleteInvoiceLineType("UT_LineTypeStoreFree2", FORCED_ERASE);
	self.deleteInvoiceLineType("UT_LineTypeStoreFree3", FORCED_ERASE);

	create services transient;

	////////////////////////////////////////////////////////////////////
	// Create Invoice Type, Services and Invoice Line Type
	////////////////////////////////////////////////////////////////////
	invType := self.createInvoiceType("UT_InvTypeStore3", InvoiceTypeStorage);
	self.assertNotNullMsg(invType, "Invoice type UT_InvTypeStore3 not created");

	calType1 := app.myRoot.allCalculationTypesByCode['CCT06'];	// INV_CALC_TYPE_DAYS_SINCE_RECVL;
	self.assertNotNullMsg(calType1, "Calculation type INV_CALC_TYPE_DAYS_SINCE_RECVL not found");
	
	
	theService := self.createInvoiceService("UT_ServiceStore13","UT Store1", calType1, null);
	self.assertNotNullMsg(theService, "UT_ServiceStore13 not created");
 	services.add(theService);
	
	invLineType1 := self.createInvoiceLineType("UT_LineTypeStoreFree1", calType1, invType, services,"SDT1");
	invLineType2 := self.createInvoiceLineType("UT_LineTypeStoreFree2", calType1, invType, services,"SDT1");
	invLineType3 := self.createInvoiceLineType("UT_LineTypeStoreFree3", calType1, invType, services,"SDT1");
	
	self.assertNotNullMsg(invLineType1, "UT_LineTypeStoreFree1 not created");
	self.assertNotNullMsg(invLineType2, "UT_LineTypeStoreFree2 not created");
	self.assertNotNullMsg(invLineType3, "UT_LineTypeStoreFree3 not created");
	if invLineType1 &lt;&gt; null then
		self.assertNotNullMsg(invLineType1.invoiceType, "UT_LineTypeStoreFree1 has null INV TYPE");
	endif;
	if invLineType2 &lt;&gt; null then
		self.assertNotNullMsg(invLineType2.invoiceType, "UT_LineTypeStoreFree2 has null INV TYPE");
	endif;
	if invLineType3 &lt;&gt; null then
		self.assertNotNullMsg(invLineType3.invoiceType, "UT_LineTypeStoreFree3 has null INV TYPE");
	endif;

	// Need to map to above invoice line types, using quantity ranges
	self.tranMapLoadStorageClean();
	
	// Create a Stop Type for containers and StopPreventStorageCharges
	self.deleteStopsTable(99);
	create selectedTypes transient;
	selectedTypes.add(app.myRoot.allCargoTypesById[TI_CargoType_Container]);
	create preventAreas transient;
	preventAreas.add(StopPreventStorageCharges);
	create opts transient;
	opts.addAssoc(ETRow_CheckStopAreas, preventAreas);
	opts.addAssoc( ETRow_IsMT, true );
	opts.addAssoc( ETRow_IsFull, true );
	stopsTable := self.addStopsTable(99, "UT", "Unit Test", selectedTypes, opts);

	// create a container 
	voy :=self.createVesselVoyage3();
	aPort := app.myRoot.allPorts["NZAKL"];
	bs:= addBlockStack("UTSTORE3", 100, null);

	// original TFS is for cars but it doesn't matter for these tests
	cargo := self.addContainerAtLocnDisch("STOR4300112", "2200", "MT", TI_IMEX_STATUS_IMPORT, bs.myLocationsController, aPort, voy);
	oid := cargo.getOidString;
	
	// Test 1 - Free storage is set at 2 days - add a Vehicle Wash stop after 3 days, should get 1 day charged storage
	// date transactions to (today-3) and delete any Receive transaction
	beginTransaction;
	storageConfig.setPropertyValue(CM_StorageConfig::includeFirstDay.name, true);
	foreach storageDetail in storageConfig.allStorageDetails do
		storageDetail.setPropertyValue(CM_StorageDetail::includeFirstDay.name, true);
	endforeach;
	commitTransaction;
	now := app.actualTimeServer.Date;
	tranDate := (now - 4);
	tranTS.setDate(tranDate);
	foreach tran in cargo.allTransactions do
		tranTS.setDate(tranDate);
		tranTS.setTime(tran.dateTime.time);
		
		beginTransaction;
		if tran.class.name = CM_Receive.name then
			delete tran;
		else
			tran.setPropertyValue("dateTime", tranTS);
		endif;
		commitTransaction;
	endforeach;
	
	// Create a Receive Ship
	tranDate := (now - 3);
	tranTS.setDate(tranDate);
	self.createDatedChargedTransaction(cargo, tranTS, TRANS_TYPE_REC_SHIP, true);

	// when Letter of Authorisation is received a stop of type StopPreventStorageCharges is added
	// this should create a storage transaction back-dated one day
	self.addStop(cargo, stopsTable);
	
	// when the car is cleaned the StopPreventStorageCharges stop is cleared
	// this should create a no-charge storage transaction the configured number of days [2] into the future
	self.deleteStop(cargo, stopsTable);

	now := app.actualTimeServer.date;
	foreach tran in cargo.allTransactions do
		if tran.isKindOf(CM_Storage) then
			count := count + 1;
			if count = 1 then
				// this is the 2 days free storage
				self.assertEqualMsg(tran.dateTime.date, now - 2, "Test 1: First storage date");
				self.assertEqualMsg(tran.noCharge, true, "Test 1: First storage should be noCharge");
			elseif count = 2 then
				// this is from setting the stop
				self.assertEqualMsg(tran.dateTime.date, now - 1, "Test 1: Second storage date");
				self.assertEqualMsg(tran.noCharge, false, "Test 1: Second storage should be Charged");
			elseif count = 3 then
				// this is from clearing the stop
				self.assertEqualMsg(tran.dateTime.date, now + 2, "Test 1: Third storage date");
				self.assertEqualMsg(tran.noCharge, true, "Test 1: Third storage should be noCharge");
			endif;
		endif;
	endforeach;
	
	self.assertEqualMsg(3, count, "Test 1: Storage transactions");
	beginTransaction;
	storageConfig.setPropertyValue(CM_StorageConfig::includeFirstDay.name, false);
	foreach storageDetail in storageConfig.allStorageDetails do
		storageDetail.setPropertyValue(CM_StorageDetail::includeFirstDay.name, false);
	endforeach;
	commitTransaction;
	
	// Test 2 - Free storage is set at 2 days - add a Vehicle Wash stop after 4 days, should get 2 days charged storage
	if not self.deleteCargo("STOR4300112", "ISO Container") then
		self.assertDeleted(oid);
	endif;
	cargo := self.addContainerAtLocnDisch("STOR4300112", "2200", "MT", TI_IMEX_STATUS_IMPORT, bs.myLocationsController, aPort, voy);
	count := null;
	
	// Date transactions to (today-4) and delete any Receive transaction
	now := app.actualTimeServer.Date;
	tranDate := (now - 4);
	tranTS.setDate(tranDate);
	foreach tran in cargo.allTransactions do
		tranTS.setDate(tranDate);
		tranTS.setTime(tran.dateTime.time);
		
		beginTransaction;
		if tran.class.name = CM_Receive.name then
			delete tran;
		else
			tran.setPropertyValue("dateTime", tranTS);
		endif;
		commitTransaction;
	endforeach;
	
	// Create a Receive Ship
	tranDate := (now - 4);
	tranTS.setDate(tranDate);
	self.createDatedChargedTransaction(cargo, tranTS, TRANS_TYPE_REC_SHIP, true);

	// when Letter of Authorisation is received a stop of type StopPreventStorageCharges is added
	// this should create a storage transaction back-dated one day
	self.addStop(cargo, stopsTable);
	
	// when the car is cleaned the StopPreventStorageCharges stop is cleared
	// this should create a no-charge storage transaction the configured number of days [2] into the future
	self.deleteStop(cargo, stopsTable);

	now := app.actualTimeServer.date;
	foreach tran in cargo.allTransactions do
		if tran.isKindOf(CM_Storage) then
			count := count + 1;
			if count = 1 then
				// this is the 2 days free storage
				self.assertEqualMsg(tran.dateTime.date, now - 2, "Test 2: First storage date");
				self.assertEqualMsg(tran.noCharge, true, "Test 2: First storage should be noCharge");
			elseif count = 2 then
				// this is from setting the stop
				self.assertEqualMsg(tran.dateTime.date, now - 1, "Test 2: Second storage date");
				self.assertEqualMsg(tran.noCharge, false, "Test 2: Second storage should be Charged");
			elseif count = 3 then
				// this is from clearing the stop
				self.assertEqualMsg(tran.dateTime.date, now + 2, "Test 2: Third storage date");
				self.assertEqualMsg(tran.noCharge, true, "Test 2: Third storage should be noCharge");
			endif;
		endif;
	endforeach;
	
	self.assertEqualMsg(3, count, "Test 2: Storage transactions");
	
	// Test 3 - Free storage is set at 2 days 
	// Receive cargo yesterday, set wash stop today, gate it out tomorrow.
	// Should not be charged any storage
	if not self.deleteCargo("STOR4300112", "ISO Container") then
		self.assertDeleted(oid);
	endif;
	cargo := self.addContainerAtLocnDisch("STOR4300112", "2200", "MT", TI_IMEX_STATUS_IMPORT, bs.myLocationsController, aPort, voy);
	count := null;
	
	// Date transactions to (today-1) and delete any Receive transaction
	now := app.actualTimeServer.Date;
	tranDate := (now - 1);
	tranTS.setDate(tranDate);
	foreach tran in cargo.allTransactions do
		tranTS.setDate(tranDate);
		tranTS.setTime(tran.dateTime.time);
		
		beginTransaction;
		if tran.class.name = CM_Receive.name then
			delete tran;
		else
			tran.setPropertyValue("dateTime", tranTS);
		endif;
		commitTransaction;
	endforeach;
	
	// Create a Receive Ship
	tranDate := (now - 1);
	tranTS.setDate(tranDate);
	self.createDatedChargedTransaction(cargo, tranTS, TRANS_TYPE_REC_SHIP, true);

	// when Letter of Authorisation is received a stop of type StopPreventStorageCharges is added
	// this should create a storage transaction back-dated one day
	self.addStop(cargo, stopsTable);
	
	// when the car is cleaned the StopPreventStorageCharges stop is cleared
	// this should create a no-charge storage transaction the configured number of days [2] into the future
	self.deleteStop(cargo, stopsTable);
	
	// Gate out the container 
	tranDate := (now + 1);
	tranTS.setDate(tranDate);
	self.deleteStops(cargo);
	singleGate := self.getGate(self.getProfileSetting(UT_Profile.P_SGATE).asString);
	self.deleteVehicle("UTMAT");
	self.opts.addAssoc("deliveryNumber", "999");	// to prevent more stops being added at release
	vvr := self.gateOutContainer("UTMAT", "", "UTMATDRIVER", cargo.CM_Container, false, singleGate , null); 
	self.workVehicle(vvr);
	self.roadExit(vvr);
	//self.createDatedChargedTransaction(cargo, tranTS, TRANS_TYPE_REL_ROAD, true);

	now := app.actualTimeServer.date;
	foreach tran in cargo.allTransactions do
		if tran.isKindOf(CM_Storage) then
			count := count + 1;
			if count = 1 then
				// should only be one - this is the 2 days free after the wash stop was cleared
// ### TFS CR 58263 TASK 58264 22JAN2024 NAVAB1				self.assertEqualMsg(tran.dateTime.date, now + 2, "Test 3: First storage date");
				self.assertEqualMsg(tran.dateTime.date, now + 1, "Test 3: First storage date");
			elseif count = 2 then
				self.assertEqualMsg(tran.dateTime.date, now + 2, "Test 3: Second storage date");
				self.assertEqualMsg(tran.noCharge, true, "Test 3: First storage should be noCharge");
			endif;
		endif;
	endforeach;
	
// ### TFS CR 58263 TASK 58264 22JAN2024 NAVAB1	self.assertEqualMsg(1, count, "Test 3: Storage transactions");
	self.assertEqualMsg(2, count, "Test 3: Storage transactions");
	
epilog
	self.resetDefaultTranMap();
	self.deleteStorageConfig( true );
	delete services;
	delete selectedTypes;
	delete preventAreas;
	delete opts;
end;</source>
    </JadeMethod>
    <JadeMethod name="tVerifyColour" id="a7385969-0d71-4f5a-9bce-1b38e30be446">
        <source>tVerifyColour();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 November 2022	navmv20	Task 55546: Jade - Write change TRX and unit test to create and update new colour attribute on CM_InvoiceStatus

*/

vars

	defaultProcess : CM_InvoiceProcess;
	pxyInvStatus,
	realInvStatus,
	realInvStatus1,
	invStatus		: CM_InvoiceStatus;
	color 			: Integer;
	
begin
	
	defaultProcess := app.myRoot.allInvoiceProcesses[InvoiceProcessDefault];
	invStatus := defaultProcess.allStatuses[1];
	color := invStatus.getStatusColour();
	
	//Update new color to Invoice status
	pxyInvStatus := app.createUpdateProxy(invStatus).CM_InvoiceStatus;
	pxyInvStatus.setProxy(invStatus.id,invStatus.priority,invStatus.description,defaultProcess,Blue.Integer,null);
	app.myTrxUA.trxUpdateInvoiceStatusNew(pxyInvStatus, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	realInvStatus := app.myProxyManager.getRealObject(pxyInvStatus).CM_InvoiceStatus;
	self.assertEqual(realInvStatus.colour, Blue.Integer);
	delete pxyInvStatus;
	
	//Update old color to Invoice Status
	pxyInvStatus := app.createUpdateProxy(realInvStatus).CM_InvoiceStatus;
	pxyInvStatus.setProxy(realInvStatus.id,realInvStatus.priority,realInvStatus.description,defaultProcess,color,null);
	app.myTrxUA.trxUpdateInvoiceStatusNew(pxyInvStatus, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	realInvStatus1 := app.myProxyManager.getRealObject(pxyInvStatus).CM_InvoiceStatus;
	self.assertEqual(realInvStatus1.colour, color);
epilog
	delete pxyInvStatus;
end;</source>
    </JadeMethod>
    <JadeMethod name="tVerifyFileCategory" id="804a5202-1a7d-4afa-a9cb-ecf9e2b874a4">
        <source>tVerifyFileCategory();
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who			Reason
29 November 2022	navvt20		TFS CR 55299 TASK 55517: Jade - Write unit tests for new file category TRXs

*/

vars
realFileCategory,
pxyFileCategory : CM_FileDataCategory;
terminal : CM_Terminal;

begin
    create pxyFileCategory transient;
	terminal := self.getTerminal();
	
	//Create File Category
	pxyFileCategory.setProxy(FileCategoryContext_WorkOrder,"abc","abcd",app.myRoot,true); // ### TFS CR 55299 TASK 55985 28DEC2022 NAVAB1
	self.createFileCategory(pxyFileCategory,realFileCategory);
	self.assertEqual(realFileCategory.code,"abc");
	self.assertEqual(realFileCategory.description,"abcd");
	self.assertEqual(realFileCategory.categoryContext, FileCategoryContext_WorkOrder);
	self.assertEqual(realFileCategory.myRoot,app.myRoot); // ### TFS CR 55299 TASK 55985 28DEC2022 NAVAB1
	delete pxyFileCategory;
	
	//Update File Category
	pxyFileCategory := app.createUpdateProxy(realFileCategory).CM_FileDataCategory;
	pxyFileCategory.setProxy(FileCategoryContext_Other, "abcd", "abcde",app.myRoot,true); // ### TFS CR 55299 TASK 55985 28DEC2022 NAVAB1
	self.updateFileCategory(pxyFileCategory);
	realFileCategory := app.myProxyManager.getRealObject(pxyFileCategory).CM_FileDataCategory;
	self.assertEqual(realFileCategory.code,"abcd");
	self.assertEqual(realFileCategory.description,"abcde");
	self.assertEqual(realFileCategory.categoryContext, FileCategoryContext_Other);
	self.assertEqual(realFileCategory.myRoot,app.myRoot); // ### TFS CR 55299 TASK 55985 28DEC2022 NAVAB1
	
	//Delete File Category
	self.deleteFileCategory(realFileCategory);
	
epilog
     delete pxyFileCategory;
end;</source>
    </JadeMethod>
    <JadeMethod name="tVerifyInvoiceUnitOfMeasure" id="40545624-9535-4672-9816-e89d88cd6a6f">
        <source>tVerifyInvoiceUnitOfMeasure();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who			Reason
6 Dec 2022 	navvt20		TFS CR 55621 Task 55694: Jade - UOM Unit Tests

*/
constants
	UOM1 = "UT_Linear";
	UOM2 = "UT_Spacial";
vars
	realInvoiceUnitOfMeasure,
	pxyInvoiceUnitOfMeasure : CM_InvoiceUnitOfMeasure;
begin
	//Delete Invoice Unit Of Measure
	self.deleteInvoiceUnitOfMeasure(UOM1);
	self.deleteInvoiceUnitOfMeasure(UOM2);
	
	//Create Invoice Unit Of Measure
    create pxyInvoiceUnitOfMeasure transient;
	pxyInvoiceUnitOfMeasure.setProxy(null,UOM1,UOM1 &amp; " description");
	self.createInvoiceUnitOfMeasure(pxyInvoiceUnitOfMeasure,realInvoiceUnitOfMeasure);
	self.assertEqual(realInvoiceUnitOfMeasure.code,UOM1);
	self.assertEqual(realInvoiceUnitOfMeasure.description,UOM1 &amp; " description");
	
	delete pxyInvoiceUnitOfMeasure;
	
	//Update Invoice Unit Of Measure
	beginTransaction;
	pxyInvoiceUnitOfMeasure := realInvoiceUnitOfMeasure.pxyCreateUpdateProxy();
	commitTransaction;
	pxyInvoiceUnitOfMeasure.setProxy(null, UOM2,UOM2 &amp; " description");
	
	self.clearExpectedTrxErrors();
	self.expectedTrxErrors.add(Input_required_field_code);
	self.expectedTrxErrors.add(Input_required_field_root);
	self.expectedTrxErrors.add(Input_required_field_desc);
	self.updateInvoiceUnitOfMeasure(pxyInvoiceUnitOfMeasure);
	self.assertNotEqualMsg(self.checkErrorWarningHasOccurred(), true, "Unexpected UOM input field errors");

    realInvoiceUnitOfMeasure := app.myProxyManager.getRealObject(pxyInvoiceUnitOfMeasure).CM_InvoiceUnitOfMeasure;
	self.assertEqual(realInvoiceUnitOfMeasure.code,UOM2);
	self.assertEqual(realInvoiceUnitOfMeasure.description,UOM2 &amp; " description");
	
	delete pxyInvoiceUnitOfMeasure;
	
	//Create Invoice Unit Of Measure with same code
	create pxyInvoiceUnitOfMeasure transient;
	pxyInvoiceUnitOfMeasure.setProxy(null,UOM1,UOM1 &amp; " description");
	self.clearExpectedTrxErrors();
	self.expectedTrxErrors.add(Invoice_uom_already_exists);
	self.createInvoiceUnitOfMeasure(pxyInvoiceUnitOfMeasure,realInvoiceUnitOfMeasure);
	self.assertNotEqualMsg(self.checkErrorWarningHasOccurred(), true, "Unexpected UOM code already exist error");
	
	//Delete Invoice Unit Of Measure
	self.deleteInvoiceUnitOfMeasure(UOM1);
	self.deleteInvoiceUnitOfMeasure(UOM2);
	
epilog
     delete pxyInvoiceUnitOfMeasure;
end;</source>
    </JadeMethod>
    <JadeMethod name="tVerifyTax" id="020a5381-9fdb-4725-8756-2ccd8c8c3555">
        <source>tVerifyTax();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 October 2022	navmv20		ChangeRequest 55005: EUP - Invoicing - Invoice Line TAX Maintenance
26 April 2023 	navnmk20	Bug 57663: EUP - Incorrect Statuses Available when copying an invoice
23 May 2023 navtnr20 	Bug 58089: FR | EUP 54086 - Invoicing - Maintenance Enhancements - 070.b
*/

vars
	calcType1	    : CM_CalculationType;
	service		  	: CM_Service;
	ild			  	: CM_InvoiceLineDesc;
	invType		  	: CM_InvoiceDesc;
	services	  	: CM_ServiceByNameDict;
	operator	  	: CM_Operator;
	bu			  	: CM_Bank;
	taxCode       	: CM_TaxCode;
	pxyInvoice,
	realInvoice,
	realInvoice2  	: CM_Invoice;
	roundDecimalOpt : Integer;
	taxRate 		: Real;
	isAudit, multiTax 			: Boolean;
begin
	roundDecimalOpt := self.getTerminalConfig(InvoiceRoundLineTotal).Integer;
	multiTax := self.getTerminalConfig(InvoiceMultiTaxRates).Boolean;

	self.setTerminalConfig(InvoiceRoundLineTotal,roundDecimalOpt);
	self.setTerminalConfig(InvoiceMultiTaxRates,true);
	
	self.deleteInvoiceService("UT_ASPA50925" , FORCED_ERASE);
	self.deleteInvoiceLineType("UT_ASPA50925", FORCED_ERASE);
	self.deleteInvoiceType("UT_ASPA50925");
	self.deleteContainer("UTAS50925111");
	self.assertNoTrxErrorsOrWarnings();
	
	bu := self.getTerminal().getDefaultCompanyBank();
	
	calcType1 := app.myRoot.allCalculationTypesByCode['CCT00'];	// INV_CALC_TYPE_UNITY;
	self.assertNotNullMsg(calcType1, "Calculation type INV_CALC_TYPE_UNITY not found");

	// create new instances
	create services transient;
	invType := self.createInvoiceType("UT_ASPA50925", InvoiceTypeGeneral);
	self.assertNotNullMsg(invType, "Invoice type UT_InvRounding not created");
	
	taxCode := bu.allTaxCodes["UT_TAX_1"];
	if taxCode = null then
		taxCode:=self.addTaxCode("UT_TAX_1","UT_TAX_1", null);
	endif;
	self.assertEqual(taxCode.code, "UT_TAX_1");
	
	self.opts.addAssoc(UTTI_TaxCode,taxCode);
	service := self.createInvoiceService("UT_ASPA50925", "UT_InvRounding", calcType1, null);
	self.assertNoTrxErrorsOrWarnings();
	
	services.add(service);
	ild := self.createInvoiceLineType("UT_ASPA50925", calcType1, invType, services, "SDT1");
	self.assertNoTrxErrorsOrWarnings();
	
	operator := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);	
	
	// ### MANUAL INVOICE
	create pxyInvoice transient;
	pxyInvoice.setProxyForCreate(bu,
								operator.debtor, 
								null, 
								null,
								invType,
								//false,					 // 26.4.2023 navmk20 TFS 57663
								CM_Invoice.INVOICE_PENDING, // 26.4.2023 navmk20 TFS 57663		
								true,	
								null,
								null,	
								null,	
								null,	
								null,
								0,
								null,  // ### BUG 56925 07MAR2023 NAVAB1
								bu.myInvoiceProcess,	// 26.4.2023 navmk20 TFS 57663	
								null, //navtnr20 23-05-2023 BUG 58089
								null, //14/08/2023	navkc1	Bug 59803
								null, //14/08/2023	navkc1	Bug 59803
								null, //14/08/2023	navkc1	Bug 59803
								null, //14/08/2023	navkc1	Bug 59803
								null, //14/08/2023	navkc1	Bug 59803
								null //14/08/2023	navkc1	Bug 59803
								);
	app.myTrxCA.trxCreateInvoiceManual(pxyInvoice,realInvoice, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
	beginTransaction;
	realInvoice.setPropertyValue("status",0); // OPEN
	commitTransaction;
	
	self.createManualInvoiceLine(ild,realInvoice,1.0,"Unit Test",null);
	self.assertNoTrxErrorsOrWarnings();
	self.assertEqual(realInvoice.invoiceLines.first.getTaxCode(false),"UT_TAX_1");	
	
	if service.myTaxCode&lt;&gt; null and service.myTaxCode.allTaxRates.first&lt;&gt; null then
		taxRate:= service.myTaxCode.allTaxRates.first.rate.Real;
	endif;
	
	self.assertEqual(realInvoice.invoiceLines.first.getTaxRateForLine(),taxRate);
	
	taxCode := bu.allTaxCodes["UT_TAX_2"];
	if taxCode = null then
		taxCode:=self.addTaxCode("UT_TAX_2","UT_TAX_2", null);
	endif;
	self.assertEqual(taxCode.code, "UT_TAX_2");
	
	self.opts.addAssoc(UTTI_TaxCode,taxCode);
	isAudit := self.updateManualInvoiceLineTax(realInvoice, ild, taxCode,null);
	self.assertNoTrxErrorsOrWarnings();
	self.assertEqual(realInvoice.invoiceLines.first.getTaxCode(false),"UT_TAX_2");
	
	if taxCode.allTaxRates.first&lt;&gt; null then
		taxRate:= taxCode.allTaxRates.first.rate.Real;
	endif;
	
	self.assertTrue(isAudit);
	
	self.assertEqual(realInvoice.invoiceLines.first.getTaxRateForLine(),taxRate);
	
epilog
	self.setTerminalConfig(InvoiceRoundLineTotal,roundDecimalOpt);
	self.setTerminalConfig(InvoiceMultiTaxRates,multiTax);
	
	self.resetDefaultTranMap();
	delete pxyInvoice;
	delete services;
end;
</source>
    </JadeMethod>
    <JadeMethod name="tranMapLoadAATStorage" id="427fe46c-794d-4f01-858c-06fb76c5a04e">
        <source>tranMapLoadAATStorage();
// load transaction map for AAT storage test

vars
	fileContent : String;
	fileName	: String;
	mapName		: String;
	bank		: CM_Bank;
	cargoMap	: CM_TranMap;

begin
	fileName := "AATStorage";
	mapName := "UT_AATS";
	
	fileContent := 'TranMap Type,TranMap Name,CargoType,Cargo Subtype Group,Cargo Subtype,IMEX,Contents Status,Commodity,Transaction,MoveType,Debtor,Quantity Type,Quantity Range,Quantity Sub Type,Quantity Sub Range,Grouping,Invoice Line,Over Dimsn?,Trans Ship?,Is 40?,Is Reefer?,Req Temp?,RORO?,Is 45?,Is 30?,Is 53?,Is Child?,Is Haz?,Direct Delivery?' &amp; CrLf &amp;
		'Cargo,'&amp;mapName&amp;',(Default),(Default),(Default),(Default),(Default),(Default),(Default),,(Default),(Default) ›,(Default),,,All,VOID' &amp; CrLf &amp;
		'Cargo,'&amp;mapName&amp;',(Default),(Default),(Default),Import,(Default),(Default),(Default),,(Default),(Default) ›,(Default),,,All,VOID' &amp; CrLf &amp;
		'Cargo,'&amp;mapName&amp;',(Default),(Default),(Default),Import,(Default),(Default),Storage,,(Default),CCT06 Days Since Receival »,01 to 3,,,All,VOID' &amp; CrLf &amp;
		'Cargo,'&amp;mapName&amp;',(Default),(Default),(Default),Import,(Default),(Default),Storage,,(Default),CCT06 Days Since Receival »,04 to 6,,,All,UT_AATStorage1' &amp; CrLf &amp;
		'Cargo,'&amp;mapName&amp;',(Default),(Default),(Default),Import,(Default),(Default),Storage,,(Default),CCT06 Days Since Receival »,07 to 9,,,All,UT_AATStorage2' &amp; CrLf &amp;
		'Cargo,'&amp;mapName&amp;',(Default),(Default),(Default),Import,(Default),(Default),Storage,,(Default),CCT06 Days Since Receival »,10 to MAX,,,All,UT_AATStorage3' &amp; CrLf &amp;
		'Cargo,'&amp;mapName&amp;',(Default),(Default),(Default),Export,(Default),(Default),(Default),,(Default),(Default) ›,(Default),,,All,VOID' &amp; CrLf &amp;
		'Cargo,'&amp;mapName&amp;',(Default),(Default),(Default),Export,(Default),(Default),Storage,,(Default),CCT06 Days Since Receival »,01 to 3,,,All,VOID' &amp; CrLf &amp;
		'Cargo,'&amp;mapName&amp;',(Default),(Default),(Default),Export,(Default),(Default),Storage,,(Default),CCT06 Days Since Receival »,04 to 6,,,All,UT_AATStorage1' &amp; CrLf &amp;
		'Cargo,'&amp;mapName&amp;',(Default),(Default),(Default),Export,(Default),(Default),Storage,,(Default),CCT06 Days Since Receival »,07 to 9,,,All,UT_AATStorage2' &amp; CrLf &amp;
		'Cargo,'&amp;mapName&amp;',(Default),(Default),(Default),Export,(Default),(Default),Storage,,(Default),CCT06 Days Since Receival »,10 to MAX,,,All,UT_AATStorage3';

	self.transactionMapLoad(fileContent, fileName);
	self.assertNoTrxErrorsOrWarnings();
	
	bank := app.myPassport.myTerminal.getDefaultCompanyBank();
	cargoMap := bank.myCurrentTranMapCargo[mapName];
	self.assertNotNullMsg(cargoMap,"cargo map should not be null");

	app.myTrxUA.trxUpdateBankTMActive(cargoMap, app.myPassport);

epilog

end;
</source>
    </JadeMethod>
