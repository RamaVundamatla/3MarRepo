    <JadeMethod name="setForCreate" id="4071f4a6-9251-4091-91d7-3a65e93f9ef5">
        <updating/>
        <source>setForCreate(_ti: CM_TrackedItem; _passport: CM_Passport input) updating;
//
// 04/02/2010	cnwdap1	PAR # 21867 add in selfPropelled
// 12/09/2013	cnwdap1	PAR #32215 New attributes for Cars
//
vars
	pxyCar	: CM_Car;					// PAR #32215

begin
	inheritMethod(_ti, _passport);
	self.hasRadio := _ti.CM_Car.hasRadio;
	self.selfPropelled := _ti.CM_Car.selfPropelled;	// PAR #21867
	
	pxyCar := _ti.CM_Car;									// PAR #32215
	self.colour				:= pxyCar.colour;				// PAR #32215
	self.make				:= pxyCar.make;					// PAR #32215
	self.model				:= pxyCar.model;				// PAR #32215
	self.carType			:= pxyCar.carType;				// PAR #32215
	self.year				:= pxyCar.year;					// PAR #32215
	self.trackingNumber1	:= pxyCar.trackingNumber1;		// PAR #32215
	self.trackingNumber2	:= pxyCar.trackingNumber2;		// PAR #32215
	self.docsReceived		:= pxyCar.docsReceived;			// PAR #32215
	self.docsSent			:= pxyCar.docsSent;				// PAR #32215
	self.docsCleared		:= pxyCar.docsCleared;			// PAR #32215
	self.docsReturned		:= pxyCar.docsReturned;			// PAR #32215
	self.nbrDoors			:= pxyCar.nbrDoors;				// PAR #32215
	self.isNew				:= pxyCar.isNew;				// PAR #32215
	
	// 04/12/2014 cnwar2 #3303
	self.engineNo			:= pxyCar.engineNo;
	self.certificate1		:= pxyCar.certificate1;
	self.certificate1Expiry	:= pxyCar.certificate1Expiry;
	self.certificate2		:= pxyCar.certificate2;
	self.certificate2Expiry	:= pxyCar.certificate2Expiry;
	self.chassisNo			:= pxyCar.chassisNo;
	self.registration		:= pxyCar.registration;
	self.vin				:= pxyCar.vin;
end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
