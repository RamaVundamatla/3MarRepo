    <JadeMethod name="setReportDialog" id="f6a0c493-df9c-4d3d-8474-e8c12e9984b2">
        <updating/>
        <source>setReportDialog() protected, updating;
/*
----------   ----------  --------------------------------------------------
Created:	30 January 2007 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	val			: Boolean;
begin
	if self.optReport.value then
		self.grpReportOptions.enabled := true;
		if self.cmbReport.listCount &lt; 1 then
			self.loadCmbReport();
		endif;
	else
		self.grpReportOptions.enabled := false;
	endif;
	val := self.optCSV.value;
	self.lblFile.enabled 		:= val;
	self.txtFileName.enabled 	:= val;
	self.btnBrowse.enabled 		:= val;
	
	
end;

</source>
