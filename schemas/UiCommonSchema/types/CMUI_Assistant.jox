    <JadeMethod name="comboBoxHMSVessel" id="c90044c8-91df-4c83-9c8b-f280c4a736d9">
        <source>comboBoxHMSVessel(pCmb : ComboBox input; pVessel : CM_Vessel);
//-----------------------------------------
//Created: July 2003 By: cnwgd1
//-----------------------------------------
vars
	listPointer		: Integer;
	vesselObj		: CM_Vessel;
	allVesselsObj	: CM_VesselByCodeDict;
	passportObj		: CM_Passport;
	failedDAC  :CM_DataAccessController;
	
begin
	pCmb.clear();
	allVesselsObj	:=	app.myRoot.allVessels;
	
	foreach vesselObj in allVesselsObj do
		if not vesselObj.canUserAccessSelf(null, failedDAC,passportObj) then
			continue;
		endif;
		
		if vesselObj.myHMSVesselData &lt;&gt; null then
			listPointer	:=	pCmb.addItem(vesselObj.name);
			pCmb.itemObject[listPointer]	:=	vesselObj;
		endif;
	endforeach;

	if pVessel &lt;&gt; null then
		listPointer	:=	pCmb.findObject(pVessel);
		
		if listPointer &gt; -1 then
			pCmb.listIndex	:=	listPointer;
		endif;
	endif;
end;</source>
        <Parameter name="pCmb" type="ComboBox" usage="input"/>
        <Parameter name="pVessel" type="CM_Vessel"/>
    </JadeMethod>
