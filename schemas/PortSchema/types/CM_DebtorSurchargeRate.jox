			) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 March 2018	jlgndl1	Initial creation	TFS 37818

*/

vars

begin

	
	
	self.mySurchargeInvoiceLineType := _mySurInvLineType;
	self.surchargeRate := _surchargeRate;
	self.myDebtor := _dr;
	self.mySurchargeAndExemptions := _mySurAndExempt;

epilog

end;</source>
