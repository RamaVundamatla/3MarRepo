<Class name="JSSIniSection" id="32e89d06-6d5a-4b3d-8626-75637a34502f">
    <superclass name="JSSFormattedFile"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
