    <JadeMethod name="comboBoxTurnaroundArea" id="54c13d93-57f8-412b-9da6-de44f8d6c693">
        <source>comboBoxTurnaroundArea(	_cmb : ComboBox input; _terminalArea : CM_TerminalArea);
/*
Purpose:		A turnaround area can be any area that is a CM_BlockStack or its subclass
				i'm not worry about it actually being of type Block Stack
Return Value:		

Date				Who		Reason
10 November 2006	cnwer1	Initial creation - PAR#xxxx
24/06/2010			cnwcs5	par 24292 - turnaround areas can also be Yard interchange areas
									  - also they should not be a swap-stack
*/
vars
	iter 	: Iterator;
	ta		: CM_TerminalArea;
begin

	_cmb.clear();
	_cmb.sorted := false;

	if self.myTerminal = null then
		return;
	endif;
	
	iter:=self.myTerminal.allTerminalAreas.createIterator;
	
	while iter.next(ta) do 
		if not ta.isKindOf(CM_BlockStack) and
			not ta.isKindOf (CM_YardInterchangeArea) then	// 24292
			continue;
		endif;
		// we will no longer include swap stacks in the combo - if a client does already have
		// a turnaround area that is a swap stack we will include it so as not  to cause errors
		if ta.isKindOf (CM_SwapStack) and					// 24292
			ta &lt;&gt; _terminalArea then						// 24292
			continue;										// 24292
		endif;												// 24292
		_cmb.itemObject[_cmb.addItem(ta.id)] := ta;
	endwhile;

	if _terminalArea &lt;&gt; null then
		_cmb.listObject := _terminalArea;
	endif;
epilog
	delete iter;
end;</source>
        <Parameter name="_cmb" type="ComboBox" usage="input"/>
        <Parameter name="_terminalArea" type="CM_TerminalArea"/>
    </JadeMethod>
    <JadeMethod name="comboBoxUpdateAutoRelReqVoy" id="e55affe0-a40e-4148-8d46-7d53d75ac679">
        <source>comboBoxUpdateAutoRelReqVoy(pCmb : CMUI_ComboBox input; _mode: Integer);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29.10.25	Navcs2	MTN-36399	CUX | Booking with Release empties - Dev Changes

*/

vars
	idx : Integer;
	
begin	
	pCmb.clear;
	pCmb.sorted := false;
	pCmb.addItemWithData(NoVoyageStr, NoVoyage);
	pCmb.addItemWithData(UseBookingVoyageStr, UseBookingVoyage);
	
	idx := pCmb.findString(1, app.bookingAutoRelEnumToString(_mode));
	if idx = 1 then
		pCmb.listIndex := 1;
	else
		pCmb.listIndex := idx;
	endif;

epilog	
	
end;</source>
        <Parameter name="pCmb" type="CMUI_ComboBox" usage="input"/>
        <Parameter name="_mode" type="Integer"/>
    </JadeMethod>
