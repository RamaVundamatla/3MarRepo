<PrimType name="Real">
    <JadeMethod name="cnEcAdd" id="093abbdd-ea47-4007-a319-0eed3e12512a">
        <updating/>
        <source>cnEcAdd(pIncrement:Real):Real updating;
// --------------------------------------------------------------------------------
// Created:		06 May 2001 by cnwdad1
//
// Purpose:		Increments the receiver by the value specified by the parameter,
//				and returns the result.
//
//				*************************************************************
//				* NOTE: Do not use this method to increment a loop counter. *
//				*************************************************************
//
// Parameters:	pIncrement (Integer) - The amount by which to increment the receiver.
//
// Returns:		The result of the increment.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self := self + pIncrement;
epilog
	return self;
end;</source>
        <Parameter name="pIncrement" type="Real"/>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="cnEcAsKilobytes" id="a0faba67-2b4f-45c1-aa7a-78a5acb7eba9">
        <source>cnEcAsKilobytes():Real;
// -----------------------------------------------------------------------------
// Created:		21 January 2002 by cnwdad1
//
// Purpose:		Converts the receiver's value into its equivalent kilobytes.
//
// Parameters:	None
//
// Returns:		The receiver converted into kilobytes.
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//
// -----------------------------------------------------------------------------
constants
	BYTES_PER_KILOBYTE	: Integer = 1024;
	
begin
	return self / BYTES_PER_KILOBYTE;
end;</source>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="cnEcAsMM" id="4b5abcfc-6b09-435c-9248-c5817469d59f">
        <source>cnEcAsMM():Real;
// --------------------------------------------------------------------------------
// Created:		07 November 2000 by cnwdad1
//
// Purpose:		Returns the number of printed mm for the (receiver's) pixels.
//
// Parameters:	None
//
// Returns:		A real value of the mm's for the number of pixels.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return self / 3.77;
end;</source>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="cnEcAsMegabytes" id="d540249c-c555-46fe-9a65-b172a744e49f">
        <source>cnEcAsMegabytes():Real;
// -----------------------------------------------------------------------------
// Created:		21 January 2002 by cnwdad1
//
// Purpose:		Converts the receiver's value into its equivalent megabytes.
//
// Parameters:	None
//
// Returns:		The receiver converted into megabytes.
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//
// -----------------------------------------------------------------------------
constants
	BYTES_PER_MEGABYTE	: Integer = 1048576;
	
begin
	return self / BYTES_PER_MEGABYTE;
end;</source>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="cnEcAsPixels" id="8c0adcf4-a637-4b6a-b093-be14e89fb70f">
        <source>cnEcAsPixels():Real;
// --------------------------------------------------------------------------------
// Created:		07 November 2000 by cnwdad1
//
// Purpose:		Returns the number of pixels for the receiver's mm.
//
// Parameters:	None
//
// Returns:		A real value of the number of pixels for the mm's.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return self * 3.77;
end;</source>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="cnEcAsWords" id="710b7e9a-004c-4a70-bbcb-f81e70008219">
        <source>cnEcAsWords(pFullLocaleObj:LocaleFullInfo; pWordedWholeAmount:String io; pWordedDecimalAmount:String io);
// --------------------------------------------------------------------------------
// Created:		21 August 2001 by cnwdad1
//
// Purpose:		Converts the receiver into a string, expressed in words.
//
// Parameters:	pFullLocaleObj - The locale of the number format information to
//					apply to the receiver, for example, the US "Billion" versus the
//					UK "Thousand Million".
//
//					If the locale is null, the default will be used.
//
//				pWordedWholeAmount - The receiver's whole amount expressed in words.
//				pWordedDecimalAMount - The receiver's decimal amount expressed in words.
//
// Returns:		The whole and decimal amount parameters, expressed in words.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	theFullLocale		: LocaleFullInfo;
	wholeAmount			: Real;
	decimalAmount		: Real;
	stringValue			: String;
	decimalSeparator	: String;
	separatorPosition	: Integer;
	
begin
	if pFullLocaleObj = null then
		theFullLocale	:=	app.currentLocaleInfo;
	else
		theFullLocale	:=	pFullLocaleObj;
	endif;

	stringValue			:=	self.String;
	decimalSeparator	:=	theFullLocale.numericInfo.decimalSeparator;
	separatorPosition	:=	stringValue.reversePos(decimalSeparator);
	
	if separatorPosition = 0 then
		wholeAmount		:=	self;
		decimalAmount	:=	0;
	else
		wholeAmount		:=	(stringValue.String[1:(separatorPosition - 1)]).Real;
		decimalAmount	:=	(stringValue.String[(separatorPosition + 1):end]).Real;
	endif;
	
	pWordedWholeAmount		:=	wholeAmount.cnEcParseWholeAmountForWords(theFullLocale);
	
	if decimalAmount = 0 then
		pWordedDecimalAmount	:=	$CNEC_NUM_ZERO;
	else
		pWordedDecimalAmount	:=	decimalAmount.cnEcParseWholeAmountForWords(theFullLocale);
	endif;
end;</source>
        <Parameter name="pFullLocaleObj" type="LocaleFullInfo"/>
        <Parameter name="pWordedWholeAmount" type="String" usage="io"/>
        <Parameter name="pWordedDecimalAmount" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="cnEcAsWordsWhole" id="603848ab-6aa5-4580-a34d-112f01c12483">
        <source>cnEcAsWordsWhole(pFullLocaleObj:LocaleFullInfo):String;
// --------------------------------------------------------------------------------
// Created:		21 August 2001 by cnwdad1
//
// Purpose:		Converts the receiver into a string, expressed in words.
//
// Parameters:	pFullLocaleObj - The locale of the number format information to
//					apply to the receiver, for example, the US "Billion" versus the
//					UK "Thousand Million".
//
// Returns:		The whole amount, expressed in words.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	fullLocaleObj		: LocaleFullInfo;
	wholeAmount			: Real;
	stringValue			: String;
	decimalSeparator	: String;
	separatorPosition	: Integer;
	
begin
	if pFullLocaleObj = null then
		fullLocaleObj	:=	app.currentLocaleInfo;
	else
		fullLocaleObj	:=	pFullLocaleObj;
	endif;

	stringValue			:=	self.String;
	decimalSeparator	:=	fullLocaleObj.numericInfo.decimalSeparator;
	separatorPosition	:=	stringValue.reversePos(decimalSeparator);
	
	if separatorPosition = 0 then
		wholeAmount		:=	self;
	else
		wholeAmount		:=	(stringValue.String[1:(separatorPosition - 1)]).Real;
	endif;
	
	return wholeAmount.cnEcParseWholeAmountForWords(fullLocaleObj);
end;</source>
        <Parameter name="pFullLocaleObj" type="LocaleFullInfo"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="cnEcCircleArea" id="02d99353-837c-4b0e-b09c-aa2db942c9d4">
        <source>cnEcCircleArea(pIsRadius:Boolean):Real;
// --------------------------------------------------------------------------------
// Created:		03 May 2006 by cnwdad1
//
// Purpose:		Returns the area of a circle.
//
// Parameters:	pIsRadius - True if the receiver is the radius of the circle,
//					otherwise it is assumed the receiver is the diameter.
//
// Returns:		The area of the circle.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if pIsRadius then
		return CNEC_PI * (self ^ 2);
	else
		return CNEC_PI * ((self / 2) ^ 2);
	endif;
end;</source>
        <Parameter name="pIsRadius" type="Boolean"/>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="cnEcCircleCircumference" id="baf15c31-9fcb-40e0-af2e-d47ff3a75f2e">
        <source>cnEcCircleCircumference(pIsRadius:Boolean):Real;
// --------------------------------------------------------------------------------
// Created:		03 May 2006 by cnwdad1
//
// Purpose:		Returns the circumference of a circle.
//
// Parameters:	pIsRadius - True if the receiver is the radius of the circle,
//					otherwise it is assumed the receiver is the diameter.
//
// Returns:		The circumference of the circle.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if pIsRadius then
		return 2 * CNEC_PI * self;
	else
		return CNEC_PI * self;
	endif;
end;</source>
        <Parameter name="pIsRadius" type="Boolean"/>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="cnEcCircleDiameter" id="30d7104b-ece8-4fc4-9a35-49cd64523b2e">
        <source>cnEcCircleDiameter():Real;
// --------------------------------------------------------------------------------
// Created:		09 May 2006 by cnwdad1
//
// Purpose:		Returns the diameter of a circle, assuming that the receiver is the
//				radius.
//
// Parameters:	None
//
// Returns:		The diameter of the circle.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return self * 2;
end;</source>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="cnEcCylinderSurface" id="c56e3c7c-23b4-4376-8ee1-ac2222a2c1af">
        <source>cnEcCylinderSurface(pHeight:Real; pRadius:Real):Real;
// --------------------------------------------------------------------------------
// Created:		09 May 2006 by cnwdad1
//
// Purpose:		Returns the surface area of a cylinder.  If one of the parameters
//				is zero, this method will assume that the receiver is that value.
//
// Parameters:	pHeight - The height of the cylinder.
//				pRadius - The radius of the cylinder.
//
// Returns:		The volume of the cylinder.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if pHeight = 0 then
		return (2 * CNEC_PI * pRadius * self) + (2 * CNEC_PI * (pRadius ^ 2));
	elseif pRadius = 0 then
		return (2 * CNEC_PI * self * pHeight) + (2 * CNEC_PI * (self ^ 2));
	else
		return (2 * CNEC_PI * pRadius * pHeight) + (2 * CNEC_PI * (pRadius ^ 2));
	endif;
end;</source>
        <Parameter name="pHeight" type="Real"/>
        <Parameter name="pRadius" type="Real"/>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="cnEcCylinderVolume" id="9c8be024-08da-4949-85ea-b9a5acdb6646">
        <source>cnEcCylinderVolume(pHeight:Real; pRadius:Real):Real;
// --------------------------------------------------------------------------------
// Created:		09 May 2006 by cnwdad1
//
// Purpose:		Returns the volume of a cylinder.  If one of the parameters is zero,
//				this method will assume that the receiver is that value.
//
// Parameters:	pHeight - The height of the cylinder.
//				pRadius - The radius of the cylinder.
//
// Returns:		The volume of the cylinder.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if pHeight = 0 then
		return (CNEC_PI * (pRadius ^ 2)) * self;
	elseif pRadius = 0 then
		return (CNEC_PI * (self ^ 2)) * pHeight;
	else
		return (CNEC_PI * (pRadius ^ 2)) * pHeight;
	endif;
end;</source>
        <Parameter name="pHeight" type="Real"/>
        <Parameter name="pRadius" type="Real"/>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="cnEcGetWordForTeen" id="95d7ef0c-e275-4a4f-afc4-234826412409">
        <source>cnEcGetWordForTeen():String protected;
// --------------------------------------------------------------------------------
// Created:		21 August 2001 by cnwdad1
//
// Purpose:		Converts the receiver into it's equivalent word.  This method only
//				handles values between 11 and 19.
//
// Parameters:	None
//
// Returns:		The worded receiver.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	value	: Real;
	
begin
	value	:=	self;
	
	if value = 10 then
		return $CNEC_NUM_TEN;
	elseif value = 11 then
		return $CNEC_NUM_ELEVEN;
	elseif value = 12 then
		return $CNEC_NUM_TWELVE;
	elseif value = 13 then
		return $CNEC_NUM_THIRTEEN;
	elseif value = 14 then
		return $CNEC_NUM_FOURTEEN;
	elseif value = 15 then
		return $CNEC_NUM_FIFTEEN;
	elseif value = 16 then
		return $CNEC_NUM_SIXTEEN;
	elseif value = 17 then
		return $CNEC_NUM_SEVENTEEN;
	elseif value = 18 then
		return $CNEC_NUM_EIGHTEEN;
	elseif value = 19 then
		return $CNEC_NUM_NINETEEN;
	endif;
end;</source>
        <access>protected</access>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="cnEcGetWordForTens" id="6009523d-90de-4598-989b-8c6a2fac6983">
        <source>cnEcGetWordForTens(pTensDigit:Real; pUnitDigit:Real):String protected;
// --------------------------------------------------------------------------------
// Created:		21 August 2001 by cnwdad1
//
// Purpose:		Returns the worded amount for a two-digit amount.
//
// Parameters:	pTensDigit - The tens value of the amount.
//				pUnitDigit - The unit digit of the amount.
//
// Returns:		The worded amount.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	wordedAmount	: String;
	teenValue		: Real;
	
begin
	if pTensDigit = 1 then
		teenValue		:=	(pTensDigit * 10) + pUnitDigit;
		wordedAmount	:=	teenValue.cnEcGetWordForTeen();
	else
		if pTensDigit = 2 then
			wordedAmount	:=	$CNEC_NUM_TWENTY;
		elseif pTensDigit = 3 then
			wordedAmount	:=	$CNEC_NUM_THIRTY;
		elseif pTensDigit = 4 then
			wordedAmount	:=	$CNEC_NUM_FORTY;
		elseif pTensDigit = 5 then
			wordedAmount	:=	$CNEC_NUM_FIFTY;
		elseif pTensDigit = 6 then
			wordedAmount	:=	$CNEC_NUM_SIXTY;
		elseif pTensDigit = 7 then
			wordedAmount	:=	$CNEC_NUM_SEVENTY;
		elseif pTensDigit = 8 then
			wordedAmount	:=	$CNEC_NUM_EIGHTY;
		elseif pTensDigit = 9 then
			wordedAmount	:=	$CNEC_NUM_NINETY;
		endif;
		
		if pUnitDigit &gt; 0 then
			wordedAmount	:=	wordedAmount &amp; " " &amp; pUnitDigit.cnEcGetWordForUnit();
		endif;
	endif;
epilog
	return wordedAmount;
end;</source>
        <access>protected</access>
        <Parameter name="pTensDigit" type="Real"/>
        <Parameter name="pUnitDigit" type="Real"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="cnEcGetWordForUnit" id="913410e6-b502-449f-bf48-7ae4bccea1cc">
        <source>cnEcGetWordForUnit():String protected;
// --------------------------------------------------------------------------------
// Created:		21 August 2001 by cnwdad1
//
// Purpose:		Converts the receiver into it's equivalent word.  This method only
//				handles values between 1 and 9.
//
// Parameters:	None
//
// Returns:		The receiver as a word.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	value	: Real;
	
begin
	value	:=	self;
	
	if value = 1 then
		return $CNEC_NUM_ONE;
	elseif value = 2 then
		return $CNEC_NUM_TWO;
	elseif value = 3 then
		return $CNEC_NUM_THREE;
	elseif value = 4 then
		return $CNEC_NUM_FOUR;
	elseif value = 5 then
		return $CNEC_NUM_FIVE;
	elseif value = 6 then
		return $CNEC_NUM_SIX;
	elseif value = 7 then
		return $CNEC_NUM_SEVEN;
	elseif value = 8 then
		return $CNEC_NUM_EIGHT;
	elseif value = 9 then
		return $CNEC_NUM_NINE;
	endif;
end;</source>
        <access>protected</access>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="cnEcGetWordForWhole" id="faae1797-e345-4509-81af-25a98c10fbd7">
        <source>cnEcGetWordForWhole(pFullLocaleObj:LocaleFullInfo; pGroupingCount:Integer):String protected;
// --------------------------------------------------------------------------------
// Created:		21 August 2001 by cnwdad1
//
// Purpose:		Returns the appropriate word for the grouping with an amount.  For
//				example, the grouping of positions three-to-four in "4000" would
//				return the word "Thousand", as in "Four Thousand".
//				
//				In order to determine the appropriate word to return, the original
//				number is broken up into groupings, which are then parsed and
//				converted into words one-at-a-time.  The number of digits within
//				a grouping are determined from the NumberInfo class (a reference
//				on the LocaleFullInfo class).  Almost all locales have a grouping
//				value of "3".  For example, take the value 1,200,300.  This value,
//				assuming a grouping value of "3", will yield the following groupings:
//				
//					Grouping Count 1 = "300" (will yield "Hundred")
//					Grouping Count 2 = "200" (will Yield "Thousand")
//					Grouping Count 3 = "1"   (will yield "Million")
//				
//				Therefore, when these groupings are parsed (from right-to-left), we
//				get "Three Hundred", then "Two Hundred Thousand" and finally "One
//				Million".
//				
//				The LocaleFullInfo reference is also used in order to detemine what
//				wording to use, for example, 1,000,000,000 is "One Billion" in US
//				terminology, while it is "One Thousand Million", or "One Milliard",
//				in UK terminology.  Country Code "1" is always assumed to represent
//				the US.
//
// Parameters:	pFullLocaleObj - The locale for which to return the appropriate word.
//				pGroupingCount - The number of the grouping from the originating amount.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars	
	countryCode	: Integer;
	
begin
	countryCode	:=	pFullLocaleObj.defaultCountryCode;
	
	if pGroupingCount = 1 then
		return $CNEC_LIT_AND;

	elseif pGroupingCount = 2 then
		return $CNEC_LIT_THOUSAND;

	elseif pGroupingCount = 3 then
		return $CNEC_LIT_MILLION;

	elseif pGroupingCount = 4 then
		if countryCode = 1 then
			return $CNEC_LIT_BILLION;
		else
			return $CNEC_LIT_MILLIARD;
		endif;

	elseif pGroupingCount = 5 then
		if countryCode = 1 then
			return $CNEC_LIT_TRILLION;
		else
			return $CNEC_LIT_BILLION;
		endif;

	elseif pGroupingCount = 6 then
		if countryCode = 1 then
			return $CNEC_LIT_QUADRILLION;
		else
			return $CNEC_LIT_BILLIARD;
		endif;

	elseif pGroupingCount = 7 then
		if countryCode = 1 then
			return $CNEC_LIT_QUINTILLION;
		else
			return $CNEC_LIT_TRILLION;
		endif;

	endif;
end;</source>
        <access>protected</access>
        <Parameter name="pFullLocaleObj" type="LocaleFullInfo"/>
        <Parameter name="pGroupingCount" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="cnEcGetWordedAmount" id="41deeed7-3caf-40fe-8936-f831bb161191">
        <source>cnEcGetWordedAmount():String protected;
// --------------------------------------------------------------------------------
// Created:		21 August 2001 by cnwdad1
//
// Purpose:		Converts the requested string (of an integer value) into words,
//				for the hundreds, tens and single units.
//
// Parameters:	None
//
// Returns:		The worded amount.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	wordedAmount	: String;
	stringValue		: String;
	valueLength		: Integer;
	tensDigit		: Real;
	unitDigit		: Real;
	digitIndex		: Integer;
	allSubvalues	: StringArray;
	subvalue		: String;
	subvalueCount	: Integer;
	subvalueWords	: String;
	
begin
	stringValue	:=	self.String;
	valueLength	:=	stringValue.length;
	
	if valueLength = 1 then
		wordedAmount	:=	self.cnEcGetWordForUnit();
	else
		create allSubvalues transient;
		
		// Break the number grouping up into two-character elements.
		
		foreach digitIndex in valueLength to 1 step -1 do
			subvalue	:=	stringValue[digitIndex:1] &amp; subvalue;
			
			if subvalue.length = 2 then
				allSubvalues.insert(1, subvalue);
				subvalue	:=	null;
			endif;
		endforeach;
		
		if subvalue &lt;&gt; null then
			allSubvalues.insert(1, subvalue);
		endif;
		
		// Now build the words, doing each two-character element at a time.
		
		foreach subvalue in allSubvalues reversed do
			subvalueCount	:=	subvalueCount + 1;
			
			if subvalue.Integer &gt; 0 then
				
				if subvalue.length = 1 then
					unitDigit		:=	subvalue.Real;
					subvalueWords	:=	unitDigit.cnEcGetWordForUnit();
				else
					tensDigit		:=	subvalue[1:1].Real;
					unitDigit		:=	subvalue[2:1].Real;
					subvalue		:=	null;
					subvalueWords	:=	self.cnEcGetWordForTens(tensDigit, unitDigit);
				endif;
			
				if subvalueCount = 1 then
					wordedAmount	:=	subvalueWords;
				else
					if wordedAmount = null then
						wordedAmount	:=	subvalueWords &amp; " " &amp;
											$CNEC_LIT_HUNDRED;
					else
						wordedAmount	:=	subvalueWords &amp; " " &amp;
											$CNEC_LIT_HUNDRED &amp; " " &amp;
											$CNEC_LIT_AND &amp; " " &amp;
											wordedAmount;
					endif;
				endif;
			endif;
		endforeach;
	endif;
epilog
	delete allSubvalues;
	return wordedAmount;
end;</source>
        <access>protected</access>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="cnEcParseWholeAmountForWords" id="d9c89ddf-a814-4c1f-8b19-3b6215c4a43d">
        <source>cnEcParseWholeAmountForWords(pFullLocaleObj:LocaleFullInfo):String protected;
// --------------------------------------------------------------------------------
// Created:		21 August 2001 by cnwdad1
//
// Purpose:		Returns the receiver expressed in words.
//
// Parameters:	pFullLocaleObj - The locale of the number format information to
//				apply to the receiver, for example, the US "Billion" versus the UK
//				"Thousand Million".
//
// Returns:		The receiver expressed in words.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	fullLocaleObj		: LocaleFullInfo;
	wordedAmount		: String;
	stringValue			: String;
	wordsForGrouping	: String;
	allValueGroupings	: StringArray;
	groupCount			: Integer;
	
begin
	fullLocaleObj		:=	pFullLocaleObj;
	
	if fullLocaleObj = null then
		fullLocaleObj	:=	app.currentLocaleInfo;
	endif;

	create allValueGroupings transient;
	self.String.cnEcGetNumberGroupings(fullLocaleObj.numericInfo, allValueGroupings);
	
	foreach stringValue in allValueGroupings reversed do
		groupCount			:=	groupCount + 1;
		
		if stringValue.Real = 0 then
			wordsForGrouping	:=	null;
		else
			if groupCount = 1 then
				if wordedAmount = null then
					wordedAmount	:=	stringValue.Real.cnEcGetWordedAmount();
				else
					wordedAmount	:=	stringValue.Real.cnEcGetWordedAmount() &amp; " " &amp;
										wordsForGrouping &amp; " " &amp; wordedAmount;
				endif;
			else
				wordsForGrouping	:=	self.cnEcGetWordForWhole(fullLocaleObj, groupCount);
				
				if wordedAmount = null then
					wordedAmount	:=	stringValue.Real.cnEcGetWordedAmount() &amp; " " &amp;
										wordsForGrouping;
				else
					wordedAmount	:=	stringValue.Real.cnEcGetWordedAmount() &amp; " " &amp;
										wordsForGrouping &amp; ", " &amp;
										wordedAmount;
				endif;
			endif;
		endif;
	endforeach;
epilog
	delete allValueGroupings;
	return wordedAmount;
end;</source>
        <access>protected</access>
        <Parameter name="pFullLocaleObj" type="LocaleFullInfo"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="cnEcPrismSurface" id="8f738f98-0a71-421c-b46b-6bddae830126">
        <source>cnEcPrismSurface(pBase:Real; pHeight:Real):Real;
// --------------------------------------------------------------------------------
// Created:		03 May 2006 by cnwdad1
//
// Purpose:		Returns the surface area of a Prism.  If any of the parameter values
//				is zero, then this method will assume that the receiver is that value.
//
//				Surface = 2b + Ph
//
//				b = area of base, P = perimeter of base.
//
// Parameters:	pBase - The length of the Prism's base.
//				pHeight - The height of the Prism.
//
// Returns:		The surface area of the Prism.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
global.cnwdad1();
	if pBase = 0 then
		return self * pHeight;
	elseif pHeight = 0 then
		return pBase * self;
	else
		return pBase * pHeight;
	endif;
end;</source>
        <Parameter name="pBase" type="Real"/>
        <Parameter name="pHeight" type="Real"/>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="cnEcPrismVolume" id="c8625dcf-9321-462d-ba14-3b0f54f9e421">
        <source>cnEcPrismVolume(pBase:Real; pHeight:Real):Real;
// --------------------------------------------------------------------------------
// Created:		03 May 2006 by cnwdad1
//
// Purpose:		Returns the volume of a Prism.  If any of the parameter values is
//				zero, then this method will assume that the receiver is that value.
//
//				V = b * h
//
// Parameters:	pBase - The length of the Prism's base.
//				pHeight - The height of the Prism.
//
// Returns:		The volume of the Prism.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if pBase = 0 then
		return self * pHeight;
	elseif pHeight = 0 then
		return pBase * self;
	else
		return pBase * pHeight;
	endif;
end;</source>
        <Parameter name="pBase" type="Real"/>
        <Parameter name="pHeight" type="Real"/>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="cnEcRectangleArea" id="258367a3-574c-440f-801a-97acd6fcd05f">
        <source>cnEcRectangleArea(pLength:Real):Real;
// --------------------------------------------------------------------------------
// Created:		03 May 2006 by cnwdad1
//
// Purpose:		Returns the area of a rectangle, assuming that the receiver is the
//				length of the other side.
//
// Parameters:	pLength - The length of the other side of the rectangle.
//
// Returns:		The area of the rectangle.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return self * pLength;
end;</source>
        <Parameter name="pLength" type="Real"/>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="cnEcSphereSurface" id="02e56352-e8e1-4813-8ba4-8ee2827948b4">
        <source>cnEcSphereSurface():Real;
// --------------------------------------------------------------------------------
// Created:		09 May 2006 by cnwdad1
//
// Purpose:		Returns the surface area of a sphere, assuming that the receiver is
//				the radius of the sphere.
//
// Parameters:	None
//
// Returns:		The surface area of the sphere.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return 4 * CNEC_PI * (self ^ 2);
end;</source>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="cnEcSphereVolume" id="3ad39510-7c27-45bf-b8f6-8b5f3a5de5dc">
        <source>cnEcSphereVolume():Real;
// --------------------------------------------------------------------------------
// Created:		09 May 2006 by cnwdad1
//
// Purpose:		Returns the volume of a sphere, assuming that the receiver is
//				the radius of the sphere.
//
// Parameters:	None
//
// Returns:		The volume of the sphere.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return (4 / 3) * (CNEC_PI * (self ^ 3));
end;</source>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="cnEcSquareArea" id="ac533ae6-71a2-4402-98d0-9d9320081f5e">
        <source>cnEcSquareArea():Real;
// --------------------------------------------------------------------------------
// Created:		03 May 2006 by cnwdad1
//
// Purpose:		Returns the area of a square, assuming that the receiver is the
//				length of a side.
//
// Parameters:	None
//
// Returns:		The area of the square.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return self * self;
end;</source>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="cnEcTake" id="49d14362-657f-4647-85f5-2b96c6944291">
        <updating/>
        <source>cnEcTake(pDecrement:Real):Real updating;
// --------------------------------------------------------------------------------
// Created:		06 May 2001 by cnwdad1
//
// Purpose:		Decrements the receiver by the value specified by the parameter,
//				and returns the result.
//
//				*************************************************************
//				* NOTE: Do not use this method to decrement a loop counter. *
//				*************************************************************
//
// Parameters:	pDecrement (Integer) - The amount by which to decrement the receiver.
//
// Returns:		The result of the decrement.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self := self - pDecrement;
epilog
	return self;
end;</source>
        <Parameter name="pDecrement" type="Real"/>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="cnEcTrapezoidArea" id="599df2f4-c6e3-4def-aaff-b235184f7f1b">
        <source>cnEcTrapezoidArea(pHeight:Real; pLength1:Real; pLength2:Real):Real;
// --------------------------------------------------------------------------------
// Created:		03 May 2006 by cnwdad1
//
// Purpose:		Returns the area of a trapezoid.  If any of the parameter values is
//				zero, then this method will assume that the receiver is that value.
//
//					{b1 + b2}
//				A = {-------}h
//					{   2   }
//
//				          b1
//				    +------------+
//				   /|             \
//				a / | h            \ c
//				 /  |               \
//				+---+----------------+
//				          b2
//
// Parameters:	pHeight - The height of the Trapezoid.
//				pLength1 - The b1 length.
//				pLength2 - The b2 length.
//
// Returns:		The area of the trapezoid.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if pHeight = 0 then
		return ((pLength1 + pLength2) / 2) * self;
	elseif pLength1 = 0 then
		return ((self + pLength2) / 2) * pHeight;
	elseif pLength2 = 0 then
		return ((pLength1 + self) / 2) * pHeight;
	else
		return ((pLength1 + pLength2) / 2) * pHeight;
	endif;
end;</source>
        <Parameter name="pHeight" type="Real"/>
        <Parameter name="pLength1" type="Real"/>
        <Parameter name="pLength2" type="Real"/>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="cnEcTriangleArea" id="f1318046-35af-4b71-9af4-53a2a9ff131d">
        <source>cnEcTriangleArea(pBase:Real; pHeight:Real):Real;
// --------------------------------------------------------------------------------
// Created:		03 May 2006 by cnwdad1
//
// Purpose:		Returns the area of a Triangle.  If any of the parameter values is
//				zero, then this method will assume that the receiver is that value.
//
//				A = (b / 2} * h
//
//				    +
//				   /|\
//				a / | \ c
//				 /  |h \
//				+---+---+
//				    b
//
// Parameters:	pBase - The length of the triangle's base.
//				pHeight - The height of the Triangle.
//
// Returns:		The area of the Triangle.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if pBase = 0 then
		return (self / 2) * pHeight;
	elseif pHeight = 0 then
		return (pBase / 2) * self;
	else
		return (pBase / 2) * pHeight;
	endif;
end;</source>
        <Parameter name="pBase" type="Real"/>
        <Parameter name="pHeight" type="Real"/>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="cnEcTrianglePerimeter" id="10496da1-c431-484e-841f-643ddd62f551">
        <source>cnEcTrianglePerimeter(pSideA:Real; pSideB:Real; pSideC:Real):Real;
// --------------------------------------------------------------------------------
// Created:		03 May 2006 by cnwdad1
//
// Purpose:		Returns the perimeter of a Triangle.  If any of the parameter values
//				is zero, then this method will assume that the receiver is that value.
//
//				P = a + b + c
//
//				    +
//				   /|\
//				a / | \ c
//				 /  |h \
//				+---+---+
//				    b
//
// Parameters:	pSideA - The length of side A of the triangle.
//				pSideB - The length of side B of the triangle.
//				pSideC - The length of side C of the triangle.
//
// Returns:		The perimeter of the Triangle.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if pSideA = 0 then
		return self + pSideB + pSideC;
	elseif pSideB = 0 then
		return pSideA + self + pSideC;
	elseif pSideC = 0 then
		return pSideA + pSideB + self;
	else
		return pSideA + pSideB + pSideC;
	endif;
end;</source>
        <Parameter name="pSideA" type="Real"/>
        <Parameter name="pSideB" type="Real"/>
        <Parameter name="pSideC" type="Real"/>
        <ReturnType type="Real"/>
    </JadeMethod>
</PrimType>
