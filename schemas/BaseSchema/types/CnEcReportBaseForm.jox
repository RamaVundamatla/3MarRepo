        <source>unload() updating;
// --------------------------------------------------------------------------------
// Created:		27 July 2000 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	delete self.aMyTA;
end;</source>
    </JadeMethod>
</GUIClass>
