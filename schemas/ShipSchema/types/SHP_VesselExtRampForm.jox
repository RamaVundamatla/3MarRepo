    <JadeMethod name="loadChildCombo" id="481c7838-d32f-481d-b1b9-6f736a250d75">
        <updating/>
        <source>loadChildCombo(_child: CM_Object) updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
20 April 2011	cnwer1	Initial creation CCMS 1031

*/

vars

begin

	if self.myParent =  null then
	
		return;
	endif;
	
	if self.myParent.isKindOf(CM_VesselStructuralElements) then
		self.myAssistant.comboBoxROROVesselExtRamps(self.cmbChild,self.myParent.CM_VesselStructuralElements,_child.CM_DeckItem);
	elseif self.myParent.isKindOf(CM_VoyageStructuralElements) then
		self.myAssistant.comboBoxROROVoyageExtRamps(self.cmbChild,self.myParent.CM_VoyageStructuralElements,_child.CM_DeckItem);
	endif;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_child" type="CM_Object"/>
    </JadeMethod>
    <JadeMethod name="loadChildFields" id="38f3066c-251c-4807-adb2-5dd7f05a9ab9">
        <source>loadChildFields(_child: CM_Object);
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
20 April 2011	cnwer1	Initial creation CCMS 1031

*/

vars
	deckItemRamp : CM_RORORampExternal; 
begin
	

	deckItemRamp:=_child.CM_RORORampExternal;
	
	self.txtCode.text:=deckItemRamp.code;
	self.txtDescription.text:=deckItemRamp.description;
	self.txtRemarks.text:=deckItemRamp.remarks;
	
	self.txtClearHeight.text:=deckItemRamp.maxClearHeight.asStringJMT();
	self.txtLength.text:=deckItemRamp.length.asStringJMT();
	self.txtMaxTotalWeigh.text:=deckItemRamp.maxLoadTotal.asStringJMT();
	self.txtMaxAxelWeight.text:=deckItemRamp.maxLoadAxel.asStringJMT();
	self.txtMaxLoadM2.text:=deckItemRamp.maxLoadM2.asStringJMT();
	self.txtWidth.text:=deckItemRamp.width.asStringJMT();
	self.chkIsMovable.value:=deckItemRamp.isMovable;
	
	self.cmbExtPosition.setIndexFromObject(deckItemRamp.myRampPosition);

	
epilog

end;</source>
        <Parameter name="_child" type="CM_Object"/>
    </JadeMethod>
    <JadeMethod name="loadParentCombo" id="3fe9ffd9-2d4b-4e1f-b8b5-783b60a1fb56">
        <source>loadParentCombo(_parent : CM_Object) protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
21 April 2011	cnwer1	Initial creation CCMS 1031

*/

vars

begin

	if _parent.isKindOf(CM_VesselStructuralElements) then
		self.myAssistant.comboBoxROROVesselStructure(self.cmbParent,null);
	elseif _parent.isKindOf(CM_VoyageStructuralElements) then
		self.myAssistant.comboBoxROROVoyageStructure(self.cmbParent,null,self.myTerminal);
	endif;
	
	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_parent" type="CM_Object"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="b331a512-2048-4039-8c97-1d44e2f5b254">
        <updating/>
        <source>setProxy() updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
20 April 2011	cnwer1	Initial creation CCMS 1031

*/

vars
	code,
	description,
	remarks  :String;
	isMovable : Boolean;
	length,
	maxClearHeight,
	maxLoadAxel ,
	maxLoadM2,
	maxLoadTotal ,
	width : Decimal[12,2];
	proxyRamp : CM_RORORampExternal;
	rampPosition : CM_VesselRampPositionType;
begin
	if self.mode = self.Mode_New then
		if self.myParent.isKindOf(CM_VesselStructuralElements) then
			create self.myProxyChild as CM_RORORampExternalVessel transient;
		elseif self.myParent.isKindOf(CM_VoyageStructuralElements) then
			create self.myProxyChild as CM_RORORampExternalVoyage transient;
		endif;
	endif;
	
	proxyRamp:=self.myProxyChild.CM_RORORampExternal;
	
	code:=self.txtCode.text;
	description:=self.txtDescription.text;
	remarks:=self.txtRemarks.text;
	isMovable:=self.chkIsMovable.value;
	length:=self.txtLength.text.asDecimalJMT();
	width:=self.txtWidth.text.asDecimalJMT();
	maxClearHeight:=self.txtClearHeight.text.asDecimalJMT();
	maxLoadAxel:=self.txtMaxAxelWeight.text.asDecimalJMT();
	maxLoadM2:=self.txtMaxLoadM2.text.asDecimalJMT();
	maxLoadTotal:=self.txtMaxTotalWeigh.text.asDecimalJMT();
	
	proxyRamp.setProxyDeckItem(code,description,remarks,null,null);
	proxyRamp.setProxyRamp(isMovable,length,maxClearHeight,maxLoadAxel,maxLoadM2,maxLoadTotal,width);
		

	rampPosition:=self.cmbExtPosition.listObject.CM_VesselRampPositionType; 
	proxyRamp.setMyRampPosition(rampPosition);
	
	if self.myParent.isKindOf(CM_VesselStructuralElements) then
		proxyRamp.CM_RORORampExternalVessel.setMyROROStructure(self.myParent.CM_VesselStructuralElements);	
	elseif self.myParent.isKindOf(CM_VoyageStructuralElements) then
		proxyRamp.CM_RORORampExternalVoyage.setMyVoyageStructure(self.myParent.CM_VoyageStructuralElements);	
	endif;
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setupForm" id="68b41373-618e-4283-832e-043a926c2d41">
        <updating/>
        <source>setupForm() updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
21 April 2011	cnwer1	Initial creation CCMS 1031

*/

vars

begin
	inheritMethod();

	self.lblChild.caption:=app.getErrorString(Ramp);
	self.lblParent.caption:=app.getErrorString(CM_Vessel_GC);
	
	self.btnDeleteChild.bubbleHelp := app.getErrorString(Delete).cnEcFirstToUpper &amp; " " &amp; app.getErrorString(Ramp);
	self.btnEditChild.bubbleHelp := app.getErrorString(Edit) &amp; " " &amp; app.getErrorString(Ramp);
	self.btnNewChild.bubbleHelp := app.getErrorString(New) &amp; " " &amp; app.getErrorString(Ramp);
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="translateForm" id="0ec19fbf-cc92-4791-931f-fc47922fae93">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 10 August 2018 11:51:08.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0022877, locale);
	lblClearHeight.translateCaption(Xlat_0015726, locale);
	lblCode.translateCaption(Xlat_0015727, locale);
	lblDescription.translateCaption(Xlat_0015728, locale);
	lblExtPosition.translateCaption(Xlat_0015729, locale);
	lblIsMovable.translateCaption(Xlat_0015730, locale);
	lblLength.translateCaption(Xlat_0015731, locale);
	lblMaxAxelWeight.translateCaption(Xlat_0015732, locale);
	lblMaxLoadAxel.translateCaption(Xlat_0016557, locale);
	lblMaxLoadM2.translateCaption(Xlat_0015734, locale);
	lblRemarks.translateCaption(Xlat_0015735, locale);
	lblWidth.translateCaption(Xlat_0015736, locale);
end;</source>
    </JadeMethod>
    <JadeMethod name="unload" id="21f7ce39-eafc-4d6c-8e64-89bb6427d821">
        <controlMethod name="Form::unload"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>unload() updating;
/*
Date		    Who			Reason
06 May 2011	cnwas3	  Initial creation: CCMS 1031
*/

vars

begin
		
	if self.myCurrentChild &lt;&gt; null then
		if self.myCurrentChild.isTransient() then
			delete self.myCurrentChild;
		endif;
	endif;	
	
	if self.myParent &lt;&gt; null then
		if self.myParent.isTransient() then
			delete self.myParent;
		endif;
	endif;	
	
	if self.myProxyChild &lt;&gt; null then
		if self.myProxyChild.isTransient() then
			delete self.myProxyChild;
		endif;
	endif;	
	
	inheritMethod();
	
epilog

end;</source>
    </JadeMethod>
</GUIClass>
