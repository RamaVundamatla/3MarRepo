*/
vars

begin
	self.unloadForm();

end;


</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="timerEvent" id="89163975-91fc-45a3-8541-a26be20c4eed">
        <updating/>
        <source>timerEvent(eventTag: Integer) updating;
/*
----------   ----------  --------------------------------------------------
Created:	18 July 2007 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars

begin
	if self.frmEventInfoOff.visible then
		self.frmEventInfoOff.visible := false;
		self.frmEventInfoOn.visible := true;
	else
		self.frmEventInfoOff.visible := true;
		self.frmEventInfoOn.visible := false;
	endif;

end;


</source>
        <Parameter name="eventTag" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="translateForm" id="cf1c9686-9159-4adb-b89d-8c570cbcfa56">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
//	self.translateCaption(Xlat_0017360, locale);
end;</source>
    </JadeMethod>
</GUIClass>
