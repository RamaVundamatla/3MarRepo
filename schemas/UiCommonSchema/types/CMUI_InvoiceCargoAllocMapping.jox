    <JadeMethod name="create" id="adea7fa2-38f2-40c1-8c5a-3373ff349179">
        <updating/>
        <source>create() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04/05/2023	navkc1	Bug 57484: EUP - Cargo Allocation Transaction Map Permissions

*/

