    <JadeMethod name="allowAddToTruck" id="f5db77fc-b9b9-4219-a5cc-b206a656f9f7">
        <updating/>
        <source>allowAddToTruck(tmpVVR	: CM_VehicleVisitRecord) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
07/09/2011	cnwas3	Initial creation par 28028
25/02/2020	jlgdap1	TFS 48688 SNO Driver Identity Check for some variances in road gate process
*/

vars

	truck : CM_Vehicle;
	location : CM_LocationsController;
	termArea : CM_TerminalArea;
	gateArea : CM_GateArea;
	enable : Boolean;

begin

	// so are we allowed to add to this truck.
	truck := tmpVVR.vehicle;
	if truck = null or ( self.myRealVVR &lt;&gt; truck.visitRecords.last ) then
		// we don't have a trcuk, or are trying to look at a previous visit record,
		// we certainly shouldn't be able to add to this.
		return;
	endif;
	
	location := truck.myPrimaryActualLocation;	
	if location = null then
		// the truck has left, too late.
		return;
	endif;
	
	if location.isGateAreaLocation then
		// make sure its not an exit gate, cos that's too late as well.
		if location.isKindOf( CM_GateAreaLaneController ) then
			if location.CM_GateAreaLaneController.isOut then
				return;
			endif;
		elseif location.isKindOf( CM_BlockController ) then
			termArea := location.CM_BlockController.myTerminalArea;
			gateArea := termArea.CM_GateArea;
			if gateArea.isOutGate and not gateArea.isInGate then
				return;
			endif;
		endif;
	endif;

	// Ok the truck is still on this visit and still either entering the yard or in the yard, we can add items
	// but not maintain thos already on the visit.
	
	enable := app.myPassport.myUser.canDo(self.myTerminal, self.permissionMaint);
	
	btnInFull.enabled := enable;
	btnInMT.enabled := enable;
	btnInOther.enabled := enable;
	btnOutFull.enabled := enable;
	btnOutMT.enabled := enable;
	btnOutOther.enabled := enable;
	self.txtPIN.enabled := enable;
	self.lblPIN.enabled := enable;
	
	self.btnSave.enabled := enable;

	// TFS 48688 See if we need to do a driver ID check
	self.releaseRequiresDriverIDCheck();
end;</source>
        <Parameter name="tmpVVR" type="CM_VehicleVisitRecord"/>
    </JadeMethod>
    <JadeMethod name="applyRFIDtoJob" id="518b06f5-1a46-4117-a90f-9e3ef8ff022b">
        <updating/>
        <source>applyRFIDtoJob( roadJob : CM_RoadJob input):Boolean updating;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 April 2012	cnwndl1	Initial creation	Par 29417  If we are displaying the  BAT / RFID combo
													and the users have entered one, update the sucker.
19 Dec 2013		cnwdap1						PAR #32849 CCMS PEN 2321 Security Gate - the bat number may be 
													on the vehicle visit detail record
*/
vars
	rfid 	: CM_RFIDTag;
	detail	: CM_VehicleVisitRecordDetail;						// PAR #32849
	bat		: String;											// PAR #32849
	theResult : Integer;	//14 Jan 2020 NDL	TFS 46815
	
begin

	if roadJob = null then
		return true;
	endif;
	
	// PAR #32849 Do we have a bat number / rfid tag number in the Arrival at Security Gate visit detail?
	detail := roadJob.myVehicleVisit.getSecurityGateArrivedDetail;				// PAR #32849
	if detail &lt;&gt; null then 														// PAR #32849
		bat := detail.getExtraInfo_AssignRFIDTag;								// PAR #32849
	endif;																		// PAR #32849
	
	//if not self.cmbRFID.visible then											// PAR #32849
	if not self.cmbRFID.visible and bat = null then								// PAR #32849
		// option is turned off.... all is good.
		return true;
	endif;
	
	rfid := self.cmbRFID.listObject.CM_RFIDTag;
	if rfid = null then
		rfid := self.myTerminal.allRFIDTagsByCode[bat];							// PAR #32849
		if rfid = null then														// PAR #32849
			// no tag selected, this is ok too. (if they wanted it compulsory they can select to be prompted on te Gate definition.)
			return true;
		endif;																	// PAR #32849
	endif;
	
	//14 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
	while true do
	
		app.myTrxUA.trxUpdateRoadJobRFIDTag(roadJob,rfid,app.myPassport);

		// ### TFS CR 64297 TASK 64299 28MAY2024 NAVAB1
		if app.myPassport.hadDeadlock = true then
			return false;
		endif;
	
		if app.myPassport.trxCompletedOK then
			return true;
		else
			theResult := app.showErrorWarningDialog('RFID Tag', app.myPassport, ErrWarnMode_Update);
			if app.myPassport.noErrors and theResult = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		
		return false;
		
	endwhile;

epilog

end;</source>
        <Parameter name="roadJob" type="CM_RoadJob" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="btnCancel_click" id="76afb077-a1d4-4c1d-8d37-a3da58cdb73b">
        <controlMethod name="CMUI_Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnCancel_click(btn: Button input) updating;
// ---------------------------------------------------------------------------
// Created:     24 July 2008 by cnwab1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin
	self.doBtnCancelClick();
epilog

end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="btnCheckID_click" id="cfc837f3-2ba0-41a2-b9b8-bb9b394bda20">
        <controlMethod name="CMUI_Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnCheckID_click(btn: Button input) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 21/10/2019	jlgdap1		Initial creation TFS 46854 SNO Driver Identity Checking for Cargo Release
// 13/04/2023	jlizm1		TFS 56985 Recording driver id check
//
vars
	driverID : String;
	driver : CM_DriverDetails;

begin
	driverID := self.getDriverSecureId();
	if driverID &lt;&gt; null then
		driver := self.myTerminal.allDriversByExternalID[driverID];
		if driver = null then
			app.raiseCMException(Entered_ID_Not_Match_Driver, null, null);
			return;
		endif;
		
		if self.myTerminal.getConfig(KnownTruckDriverRequired).Boolean then
			self.cmbDriver.listIndex := self.cmbDriver.findObject(driver);
		else
			self.txtDriverCode.text := driver.code;
			self.txtDriverName.text := driver.name;
		endif;
		
		if not self.doUpdateVVRec() then
			return;
		endif;
		
		self.btnCheckID.visible := false;
		self.driverIDScanned := true;
	endif;
epilog

end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="btnClear_click" id="1396cddd-ae8d-435f-af20-4d2a34a508c6">
        <controlMethod name="CMUI_Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnClear_click(btn: Button input) updating;
// ---------------------------------------------------------------------------
// Created:     09 December 2008 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin
	if self.hasChanged then
		if app.msgBox("Do you want to clear this data?", "Confirmation", MsgBox_Question_Mark_Icon + MsgBox_Yes_No) = MsgBox_Return_Yes then
			self.clearForm();
		endif;
	else
		self.clearForm();
	endif;
epilog

end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="btnFindCarrier_click" id="7e5bc732-363c-418e-a57d-a81de37869bb">
