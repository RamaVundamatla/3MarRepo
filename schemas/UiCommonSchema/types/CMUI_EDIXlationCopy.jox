    <JadeMethod name="doCmbOperatorClick" id="21f3b21c-602d-48bd-a6ae-9aed7eebbf68">
        <source>doCmbOperatorClick() protected;
/*
Date		Who		Reason
03 April 2013	cnwcs5	Initial Creation - CCMS POL 2097/par 31259
*/
vars
	operator	:CM_Operator;
	
begin
	operator := self.cmbOperator.listObject.CM_Operator;
	
	self.enableXlationTypes (operator);
	self.enableTerminals (operator);
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doCmbTypeClick" id="3df76735-f775-458e-85f8-0d80c469e1dc">
        <source>doCmbTypeClick(_combo :CMUI_ComboBox) protected;
/*
Date			Who		Reason
03 April 2013	cnwcs5	Initial Creation - CCMS POL 2097/par 31259
12 June 2023	jlizm1	TFS 58500 add EDI Xlation for Operational Instruction and trailer type
*/
vars
	
begin
	if _combo.getCurrentItemData = XLATION_TYPE_VOYAGETERMINAL or
		_combo.getCurrentItemData = XLATION_TYPE_INSTRUCTTERMINAL then
		self.lblTerminal.enabled	:= true;
		self.cmbTerminal.enabled	:= true;
		
		self.enableTerminals (self.cmbOperator.listObject.CM_Operator);
	else
		self.lblTerminal.enabled	:= false;
		self.cmbTerminal.enabled	:= false;
		self.cmbTerminal.listIndex	:= -1;
	endif;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_combo" type="CMUI_ComboBox"/>
    </JadeMethod>
    <JadeMethod name="doOK" id="1eea9eb1-df61-479a-bd93-59d6d9ef11dd">
        <updating/>
        <source>doOK() updating;
/*
Date			Who		Reason
04 Apr 2013		cnwcs5	Initial Creation - CCMS POL 2097/par 31259
//13 May 2016	cnwrs1	TFS 1987 CargoSubType EDI Xlation
12 Jun 2023		jlizm1	TFS 58500 add EDI Xlation for Operational Instruction and trailer type
*/
vars
	type			: Integer;
	operator, 
	operatorTo		: CM_Operator;
	terminal		: CM_Terminal;
	opTerm			: CM_OperatorTerminal;
	xlationTable	: CM_XlationTable;
	theResult : Integer;	//13 Jan 2020 NDL	TFS 46815
begin
	// need to select operator, type and maybe voyage
	operator := self.cmbOperator.listObject.CM_Operator;
	
	if operator = null then
		app.msgBox (app.getErrorString (Please_select_operator), app.getErrorString (Error), MsgBox_OK_Only);
		self.cmbOperator.setFocus;
		return;
	endif;
	
	type := self.cmbType.getCurrentItemData;
	
	if type = null then
		app.msgBox (app.getErrorString (Please_select_type), app.getErrorString (Error), MsgBox_OK_Only);

		self.cmbType.setFocus;
		return;
	endif;
	
	if type = XLATION_TYPE_VOYAGETERMINAL or
		type = XLATION_TYPE_INSTRUCTTERMINAL  then
		terminal := self.cmbTerminal.listObject.CM_Terminal;
		
		if terminal = null then
			app.msgBox (app.getErrorString (Select_Terminal), app.getErrorString (Error), MsgBox_OK_Only);
			self.cmbTerminal.setFocus;
			return;
		endif;
		
		opTerm := operator.allOperatorTerminals[terminal];
		
		if opTerm = null then
			app.raiseUnexpectedProgramError (self.class.name, method.name, 'Invalid xlation table terminal');
		endif;
		
		xlationTable := opTerm.allXlationTables [type, null];
	else
		xlationTable := operator.allXlationTables[type, null];
	endif;
	
	if xlationTable = null then
		app.raiseUnexpectedProgramError (self.class.name, method.name, 'Invalid xlation table');
	endif;
		
	operatorTo := self.cmbOperatorTo.listObject.CM_Operator;
	
	if operatorTo = null then
		app.msgBox (app.getErrorString (Please_select_operator), app.getErrorString (Error), MsgBox_OK_Only);
		self.cmbOperatorTo.setFocus;
		return;
	endif;
	
	//13 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
	while true do
	
		app.myTrxUA.trxCopyToXlationTable(xlationTable, operatorTo, app.myPassport);
	
		if app.myPassport.trxCompletedOK then
			break;
		else
			theResult := app.showErrorWarningDialog(self.caption, app.myPassport, ErrWarnMode_AddUpdate);
			if app.myPassport.noErrors and theResult = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		
		return;
		
	endwhile;
	
	inheritMethod;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="enableTerminals" id="52447386-85e8-40c3-b27c-a7c4b905fb03">
        <source>enableTerminals(_operator :CM_Operator) protected;
/*
Date			Who		Reason
03 April 2013	cnwcs5	Initial Creation - CCMS POL 2097/par 31259
//13 May 2016	cnwrs1	TFS 1987 CargoSubType EDI Xlation
12 Jun 2023		jlizm1	TFS 58500 add EDI Xlation for Operational Instruction and trailer type
*/
vars
	combo		:CMUI_ComboBox;
	int, type	:Integer;
	terminal	:CM_Terminal;
	opTerm		:CM_OperatorTerminal;
begin
	type	:= self.cmbType.getCurrentItemData;
	combo 	:= self.cmbTerminal;
	
	if (type = XLATION_TYPE_VOYAGETERMINAL or 
		type = XLATION_TYPE_INSTRUCTTERMINAL) and 
		_operator &lt;&gt; null then
	
		combo.enabled				:= true;
		
		while int &lt; combo.listCount do
			int 		:= int + 1;
			terminal	:= combo.itemObject [int].CM_Terminal;
			opTerm 		:= _operator.allOperatorTerminals[terminal];
			
			combo.itemEnabled[int] := opTerm &lt;&gt; null and 
										opTerm.allXlationTables[type, null] &lt;&gt; null; 
		endwhile;
		
		self.lblTerminal.enabled	:= true;
		
	else
		combo.listIndex 			:= -1;
		combo.enabled				:= false;
		self.lblTerminal.enabled	:= false;
	endif;
	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_operator" type="CM_Operator"/>
    </JadeMethod>
    <JadeMethod name="enableXlationTypes" id="2ad70e06-47b6-440e-a312-883a980eac00">
        <source>enableXlationTypes(_operator :CM_Operator) protected;
/*
Date			Who		Reason
03 April 2013	cnwcs5	Initial Creation - CCMS POL 2097/par 31259
//13 May 2016	cnwrs1	TFS 1987 CargoSubType EDI Xlation
12 June 2023	jlizm1	TFS 58500 add EDI Xlation for Operational Instruction and trailer type
*/
vars
	combo		:CMUI_ComboBox;
	int, type	:Integer;
	opTerm		:CM_OperatorTerminal;
begin
	combo	:= self.cmbType;
	
	if _operator = null then
		combo.listIndex 	:= -1;
		combo.enabled		:= false;
	else
		combo.enabled		:= true;
		
		while int &lt; combo.listCount do
			int		:= int + 1;
			type	:= combo.itemData[int];
			
			if type = XLATION_TYPE_VOYAGETERMINAL or
			type =  XLATION_TYPE_INSTRUCTTERMINAL then
				// they only need one of these
				foreach opTerm in _operator.allOperatorTerminals do
					if opTerm.allXlationTables[type, null] &lt;&gt; null then
						break;
					endif;
					
					opTerm := null;
				endforeach;
				
				combo.itemEnabled[int] := opTerm &lt;&gt; null;	// at least 1
			else
				combo.itemEnabled[int] := _operator.allXlationTables[type, null] &lt;&gt; null; 
			endif;
		endwhile;
		
		int := combo.listIndex;
		
		if int &gt; 0 and not combo.itemEnabled[int] then			
			combo.listIndex := -1;
		endif;
	endif;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_operator" type="CM_Operator"/>
    </JadeMethod>
    <JadeMethod name="setupForm" id="2a822d99-4f2f-4d68-ab5a-b23a8a886c30">
        <updating/>
        <source>setupForm() updating;
/*
Date		Who		Reason
03 April 2013	cnwcs5	Initial Creation - CCMS POL 2097/par 31259
*/
constants
	SPACING = 10;
vars
	assistant	:CMUI_Assistant;
	operator	:CM_Operator;
	combo		:CMUI_ComboBox;
	terminal	:CM_Terminal;
begin
	inheritMethod();

	if not app.isUsingSkin then
		// set borderstyle to fixed single in painter so now need this code to make groupbox look OK
		self.grpCopyFrom.borderColorSingle := app.convertRGBToColor(141, 141, 141);
		self.grpCopyTo.borderColorSingle := app.convertRGBToColor(141, 141, 141);
	endif;
	
	operator := self.myInitialOperator;
	
	if operator &lt;&gt; null and self.cmbOperator.visible then 
		self.cmbOperator.setObject (operator);
	endif;

	assistant := self.myAssistant;
	
	assistant.comboBoxEDIXlationTypes (self.cmbType, false, false, self.initialXlationType);
	
	self.cmbTerminal.style := ComboBox.Style_DropDownComboList;
	
	assistant.comboBoxTerminalAll (self.cmbTerminal, self.myInitialTerminal);

	self.enableXlationTypes (operator);
	self.enableTerminals(operator);
	
	if self.cmbOperator.listObject = null then
		self.cmbOperator.setFocus;
	elseif self.cmbType.listIndex = -1 then
		self.cmbType.setFocus;
	elseif self.cmbTerminal.enabled and self.cmbTerminal.listObject = null then
		self.cmbTerminal.setFocus;
	else
		self.cmbOperatorTo.setFocus;
	endif;
	
	self.clientHeight := (self.grpCopyTo.top + self.grpCopyTo.height + SPACING + self.btnOk.height + SPACING).Integer;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="translateForm" id="d1450f33-b6eb-41e8-88dd-fb18fc70a7a6">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0018735, locale);
	grpCopyFrom.translateCaption(Xlat_0018736, locale);
	grpCopyTo.translateCaption(Xlat_0018737, locale);
	lblOperator.translateCaption(Xlat_0018738, locale);
	lblOperatorTo.translateCaption(Xlat_0018739, locale);
	lblTerminal.translateCaption(Xlat_0018740, locale);
	lblType.translateCaption(Xlat_0018741, locale);
end;</source>
    </JadeMethod>
</GUIClass>
