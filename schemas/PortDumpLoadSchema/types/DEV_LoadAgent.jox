    <JadeMethod name="loadTemperatureConversion" id="83798373-8000-4864-bae9-5c8a3ae048e6">
        <source>loadTemperatureConversion(_proxyObject:CM_Object io):Boolean protected;

vars
	realObject, proxyObject: CM_TemperatureConversion;
	error: CM_Error;
	theUser: CM_User;
	result: Boolean;

begin
	result := false;
	proxyObject := _proxyObject.CM_TemperatureConversion;
	app.myTrxCA.trxCreateTemperatureConversion(proxyObject, realObject, app.myPassport);
	if app.myPassport.trxCompletedOK and
	   app.myPassport.allErrorWarnings.size = 0 then
		beginTransaction;
		realObject.setMyRoot;
		commitTransaction;
//		write class.name&amp;'::'&amp;method.name&amp;' '&amp;proxyObject.celsius.String&amp;" OK";
		result := true;
	else
		foreach error in app.myPassport.allWarnings do
			write class.name&amp;'::'&amp;method.name&amp;' '&amp;proxyObject.celsius.String&amp;" WARNING: "&amp;error.text;
		endforeach;
		foreach error in app.myPassport.allErrors do
			write class.name&amp;'::'&amp;method.name&amp;' '&amp;proxyObject.celsius.String&amp;" ERROR: "&amp;error.text;
		endforeach;
	endif;
