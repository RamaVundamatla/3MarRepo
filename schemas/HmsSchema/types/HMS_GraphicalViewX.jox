    <JadeMethod name="setCurrentSelectedDragPicture" id="3c20e879-d9b2-4407-9681-fe025d6f00a7">
        <updating/>
        <source>setCurrentSelectedDragPicture(pict: HMS_GraphicalDragPicture input; button: Integer; x: Real; y: Real) updating;
//-----------------------------------------
// Created: May 2004 By: cnwgd1
//-----------------------------------------
vars
	now : TimeStamp;
	workingMove : CMIF_HMS_WorkingMovement;
begin

	now := app.actualTimeServer();	// 16 Sept 2016	cnwns1	TFS 488 - Multi Timezone Support
	self.myCurrentDragPicture := null;
	workingMove := pict.myWorkingMovement;
	if workingMove = null then
		return;
	endif;
	
	self.myCurrentDragPicture 		:= pict;
	self.lastSpritePosnUpdateTime 	:= now;
	self.lastSelectedBerth 			:= workingMove.myBerth;
		
	// adjust the pointers that are shown on the wharf and time control	
	self.myDrawTimeLabel.movePointer(true, pict.top, pict.top + pict.height);
	
	// Update time and position indicators
	self.showSelectedPosDetails();
	
end;</source>
        <Parameter name="pict" type="HMS_GraphicalDragPicture" usage="input"/>
        <Parameter name="button" type="Integer"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="setCurrentWorkMoveFromCntrler" id="36b2dd71-5584-41ca-a37a-24d02e47e7a9">
        <updating/>
        <source>setCurrentWorkMoveFromCntrler(_movement : CMIF_HMS_WorkingMovement) updating;
//--------------------------------------------------
// Created:	11 May 2004 By: cnwgd1
// THIS METHOD SHOULD ONLY BE CALLED FROM HMSIF_ViewControllerNEW:setMySelectedMovement
//--------------------------------------------------
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------
// 10/02/2014	cnwdap1		PAR #33337 CCMS PTR 2214 HMS Enhancements
// 21/09/20263	navdap1		TFS 59472 EUP | FR 56588 Berth planning by bollards Remedial
vars
	tmpWharfControl	: HMS_WharfDrawControl;
	
begin
	self.vesselSideTo := null;
	self.myCurrentVoyageData := null;
	self.myCurrentWorkingMovement := _movement;			
	self.setMoveDirection();	// Par 16281 May 2009 cnwvu1

	if _movement &lt;&gt; null then
		self.vesselSideTo := _movement.sideTo;		
		self.myCurrentVoyageData := _movement.myWorkingVoyage.myHMSVoyageData;
		// update the map view
		if self.myAerialMapForm &lt;&gt; null then
			self.myAerialMapForm.snapAerialView(_movement.myBerth);
		endif;
		if self.frmMarksRemarks.visible then
			self.frmMarksRemarks.visible := false;
			self.showHideMarksRemarks(false, null, true);
		endif;
		// show the resource allocation for the currently selected movement
		self.setResourceButtons();						
	else
		lblShowBerth.caption:= '';
		lblShowBow.caption:= '';
		lblShowStern.caption:= '';
		lblShowBridge.caption:= '';		
		lblShowTime.caption	:= '';
		lblShowLoa.caption := '';
		lblShowOrient.caption := '';			// TFS 59472
		lblContainerFore.caption := '';
		lblContainerAft.caption	:= '';
		self.setCaption(self.getViewCaption());
		self.resetResourceButtons();
		self.btnRoadStead.caption := "Vessels at Anchor";
		self.btnRoadStead.bubbleHelp := "Vessels at Anchor";		
		
		self.myDrawTimeLabel.movePointer(false, null, null);
		
		foreach tmpWharfControl in self.allWharfDrawControls do
			tmpWharfControl.showHideLabels(false, null, null);
		endforeach;

		self.myCurrentDragPicture := null;
		
		if self.frmMarksRemarks.visible then
			self.frmMarksRemarks.visible := false;				
			self.txtRemarks.text := null;
			self.tblMeterMarks.clearValues();
			self.txtRemarks.visible := false;
			self.tblMeterMarks.visible := false;
			self.tblExtraInfo.visible := false;		
			self.btnSaveExtra.enabled := false;
			self.btnCancel.enabled := false;
			if (not self.isReadOnly) then	
				self.btnSaveBase.enabled := true;
			endif;
			self.btnCancelBase.enabled := true;
			self.btnSelectrSearch.enabled := true;
			//Clear selected fields of the table
			self.tblMeterMarks.clearAllSelected();								
		endif;
		
	endif;

	if self.myTidalSummaryForm &lt;&gt; null then
		self.myTidalSummaryForm.applyMovementChange(_movement);
	endif;
	
	if self.myTidalModelForm &lt;&gt; null then													// PAR #33337
		self.myTidalModelForm.handleNotificationRefreshView(null, _movement, null, null);	// PAR #33337
	endif;																					// PAR #33337
	
	if global.isValidObject(self.myAdditionalInfoForm) then
		if _movement = null then
			self.showAdditionalInfoForm(null);	
		else
			self.showAdditionalInfoForm(_movement.myWorkingVoyage);
		endif;
	endif;

end;</source>
        <Parameter name="_movement" type="CMIF_HMS_WorkingMovement"/>
    </JadeMethod>
