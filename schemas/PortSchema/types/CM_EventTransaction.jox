    <JadeMethod name="createCharge" id="69ff97b9-3406-4cb1-8ef8-4bf58d8cb19c">
        <updating/>
        <source>createCharge(_passport : CM_Passport) : Boolean updating;

// ##########
// ##########
// ### DO NOT CALL THIS DIRECTLY
// ### CALL CM_Passport::addEventTransactionForDeferUpd()
// ##########
// ##########

// ---------------------------------------------------------------------------
// Created:		October 2007 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
/*

Date		Who		Reason
19 May 2010	cnwkpd1	PAR #20728 - remove isValidObject calls for performance
19 Dec 2024	navlw1	JIRA-33692: MTN | Terminal Config for Financials Enabled Minor Issues
31 Jan 2025	navlw1 	JIRA-33865: MTN | Logging only displays that financials aren't enabled in logging level is TRACE
25 Feb 2025	navah1	Story 34141: MTN - Performance Improvements - Review for invLog() Methods
*/

vars
	co	      : CM_Bank;
	term      : CM_Terminal;
	theDebtor : CM_DebtorNode;
	aMess     : String;
	canLogExtra			: Boolean;	//26.02.2025 navah1	#34141
begin

	canLogExtra	:= app.canLogExtraDetail();				//26.02.2025 navah1	#34141
/* // ### JIRA 33567 03DEC2024 NAVAB1
	// ### TFS CR 63938 TASK 63942 02MAY2024 NAVAB1
	if app.myPassport.useEventDeferUpdate then
		return false;
	endif;
*/

	if self.myEventType = null then		// not global.isValidObject(self.myEventType) then
		app.raiseUnexpectedProgramError(class. name, method.name, 'null event type used');
		return false;
	endif;
	
	term := self.getTerminal();
	if term = null then
		//app.raiseUnexpectedProgramError(class.name, method.name, 'null self.myTerminal');// ### JIRA 33567 03DEC2024 NAVAB1 some events are system level like logon
		return false;
	endif;

	// Start navlw1 #JIRA-33865 31/01/2025
	if self.noCharge then
		if canLogExtra then	//26.02.2025 navah1	#34141
			app.invLog("Transaction is not chargeable",LogINFO.String); // navlw1 #JIRA-33692
		endif;
		return false;
	endif;
	if not term.getConfig(FinancialsEnabled).Boolean then
		if canLogExtra then	//26.02.2025 navah1	#34141
			app.invLog("Financials Are Not Enabled, No Charging Will Occur",LogTRACE.String); // navlw1 #JIRA-33692  // ### JIRA 35228 11JUL2025 NAVAB1
		endif;
		return false;
	endif;
	if not app.myRoot.canDo(Mod_Invoicing) then
		if canLogExtra then	//26.02.2025 navah1	#34141
			app.invLog("Invoice Module is not licensed",LogINFO.String); // navlw1 #JIRA-33692
		endif;
		return false;
	endif;
	// End navlw1 #JIRA-33865 31/01/2025

	theDebtor := self.getDebtor(); 
	
	if theDebtor = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'null Debtor');
		return false;
	endif;
	
	co := self.getBank();
	if co = null then	
		//co := _passport.myTerminal.getConfig(DefCompany).CM_Bank;
		co := _passport.myTerminal.getDefaultCompanyBank();	//17 Apr 2012	NDL	Par 29393
	endif;

	if co = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'null business unit');
		return false;
	endif;
	
	self.myDebtor := theDebtor.CM_Debtor;
	co.createChargeEvent(self);
	

end;</source>
        <Parameter name="_passport" type="CM_Passport"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doCreateCharge" id="41eb1952-c336-4c63-a3b9-8b656ab8bb7f">
        <updating/>
        <source>doCreateCharge(_passport: CM_Passport): Boolean updating;
/*

Purpose:			CM_Transaction::doCreateCharge() is called from the DEFFERRED TRANSACTION code on passport

Parameters:			

Return Value:		

Date		Who		Reason
06 Jul 2021	navndl1	Initial creation	TFS 51443
16 Jul 2025	navhl20 Bug MTN-35336: Failed Deferred Charging BGP spamming System Alerts
*/

vars

begin
	if app.myPassport.isInEdiVerifyMode then				//16.07.2025 navhl20 #35336
		return true;
	endif;

	self.createCharge( _passport );
	return not _passport.hasErrorsOrWarnings();				//16.07.2025 navhl20 #35336
epilog

end;</source>
        <Parameter name="_passport" type="CM_Passport"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doResyncInvoiceLines" id="c7b57f8d-375c-4bf2-abfd-347072f8024b">
        <source>doResyncInvoiceLines(_sbController : CMIF_ServiceBroker input);
// Date			Who		Reason
// Feb 2012		CCMS 	1262 Transaction Enquiry, do event transaction resync
// 23 Oct 2024	navlw1	JIRA-33107: Invoice Logging Use Levels
// 19 Dec 2024	navlw1	JIRA-33692: MTN | Terminal Config for Financials Enabled Minor Issues
// 31 Jan 2025	navlw1 	JIRA-33865: MTN | Logging only displays that financials aren't enabled in logging level is TRACE
// 25 Feb 2025	navah1	Story 34141: MTN - Performance Improvements - Review for invLog() Methods
vars
	invLine : CM_InvoiceLine;
	invLineTypes : CM_InvoiceLineDescArray;
	invLineDesc : CM_InvoiceLineDesc;
	reject : Boolean;
	bu : CM_Bank;
	term      : CM_Terminal;
	canLogExtra	: Boolean;	//26.02.2025 navah1	#34141
begin
	canLogExtra	:= app.canLogExtraDetail();				//26.02.2025 navah1	#34141
	bu := self.getBank();
	
	create invLineTypes transient;
	
	term := self.getTerminal();
	if term = null then
		return;
	endif;
	
	// Start navlw1 #JIRA-33865 31/01/2025
	if self.noCharge then
		if canLogExtra then	//26.02.2025 navah1	#34141
			app.invLog("Transaction is not chargeable",LogINFO.String); // navlw1 #JIRA-33692
		endif;
		return;
	endif;
	if not term.getConfig(FinancialsEnabled).Boolean then
		if canLogExtra then	//26.02.2025 navah1	#34141
			app.invLog("Financials Are Not Enabled, No Charging Will Occur",LogTRACE.String); // navlw1 #JIRA-33692  // ### JIRA 35228 11JUL2025 NAVAB1
		endif;
		return;
	endif;
	if not app.myRoot.canDo(Mod_Invoicing) then
		if canLogExtra then	//26.02.2025 navah1	#34141
			app.invLog("Invoice Module is not licensed",LogINFO.String); // navlw1 #JIRA-33692
		endif;
		return;
	endif;
	// End navlw1 #JIRA-33865 31/01/2025
	
	foreach invLine in self.allInvoiceLines discreteLock where invLine.status &lt;&gt; CM_InvoiceLine.STATUS_VOIDED do
		
		reject := true;
		
		// if the business unit has changed then void all the invoice lines
		// i.e. if the CM_Bank has changed we wont get in this bit...
		if bu = null or (_sbController.myBank = bu) then
			invLineTypes.clear;
			_sbController.allInvoiceLineTypes.copy(invLineTypes);
			foreach invLineDesc in invLineTypes discreteLock do
				if invLine.invoiceLineDesc = invLineDesc then
					// take out any invoiceline type that we have already charged correctly for
					_sbController.allInvoiceLineTypes.remove(invLineDesc);
					reject := false;
					invLine.setFromQuantityRangeMap(_sbController.getQRMFromLineType(invLineDesc));
					if canLogExtra then	//26.02.2025 navah1	#34141
						app.invLog(invLine.invoiceLineDesc.narration.removeCrLfs &amp; " - existing invoice line " &amp; invLine.sequenceNum.String &amp; " of invoice " &amp; invLine.invoice.sequenceNum.String, LogINFO.String);
					endif;
				endif;
			endforeach;
		endif;
		
		if reject then
			// should not have been charged so void it
			if canLogExtra then	//26.02.2025 navah1	#34141
				app.invLog("Invoice line " &amp; invLine.sequenceNum.String &amp; " of invoice " &amp; invLine.invoice.sequenceNum.String &amp; " voided", LogINFO.String);
			endif;
			invLine.changeStatus(CM_InvoiceLine.STATUS_VOIDED);
		endif;
	endforeach;

epilog 

	delete invLineTypes;
	
end;</source>
        <Parameter name="_sbController" type="CMIF_ServiceBroker" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getAmount" id="c171d1d7-4b2e-4c29-a0d9-f6a830137e3f">
