    <JadeMethod name="unload" id="77f6f858-873f-418f-ac1e-a85c9580636e">
        <controlMethod name="Form::unload"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>unload() updating;
// ---------------------------------------------------------------------------
// Created:		May 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

begin
	if self.startedTimer then
		self.endTimer(1);	// safety check against closing form less than 2 seconds after load
	endif;
	inheritMethod();
	delete self.myTMCRoot;
end;</source>
    </JadeMethod>
    <JadeMethod name="xHandlerFile" id="90e52da2-e300-4957-9c71-55ba90ffd75a">
        <source>xHandlerFile(_exceptionObj:FileException):Integer protected;
// --------------------------------------------------------------------------------
// Created:		April 2010, par 23659, copied from INV_RateTable
//
// Purpose:		General file exception handler to report any errors and abort the
//				current action.
//
// Parameters:	_exceptionObj - A reference to the file exception object.
//
// Returns:		The abort action code.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	errorMsg	: String;
	
begin
	errorMsg	:=	process.getErrorText(_exceptionObj.errorCode) &amp; ".";
	
	app.msgBox(errorMsg, app.getString(Error), MsgBox_Information_Icon + MsgBox_OK_Only);
	
	return Ex_Abort_Action;
end;</source>
        <access>protected</access>
        <Parameter name="_exceptionObj" type="FileException"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
</GUIClass>
