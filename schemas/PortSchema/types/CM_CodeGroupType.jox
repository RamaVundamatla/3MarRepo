    <JadeMethod name="setForCreate" id="9d75f84b-5b30-400f-937b-0e1bded7e68e">
        <updating/>
        <source>setForCreate(_proxyCodeGroupType : CM_CodeGroupType) updating;
// ---------------------------------------------------------------------------
// Created:     03 June 2002 by cnwsb1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	self.setForUpdate(_proxyCodeGroupType);
	// Don't set root as this is the automatic end of the inverse
	//self.myRoot := _root;
end;</source>
        <Parameter name="_proxyCodeGroupType" type="CM_CodeGroupType"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="8f843a53-44c3-4d46-b31a-90000a73a5bc">
        <updating/>
        <source>setForUpdate(proxy: CM_CodeGroupType) updating;
// ---------------------------------------------------------------------------
// Created:     06 June 2002 by cnwsb1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	self.codeClassNameToCreate	:= proxy.codeClassNameToCreate;
	self.description			:= proxy.description;
	self.groupClassNameToCreate	:= proxy.groupClassNameToCreate;
	self.id						:= proxy.id;
	self.codeLengthMax			:= proxy.codeLengthMax;
	self.codeLengthMin			:= proxy.codeLengthMin;
	self.parentType				:= proxy.parentType;
end;</source>
        <Parameter name="proxy" type="CM_CodeGroupType"/>
    </JadeMethod>
    <JadeMethod name="setProxyForCodeGroupType" id="8c21bcb4-525a-49ea-affb-7a440c14edf6">
        <updating/>
        <source>setProxyForCodeGroupType(_id : Integer;
		_groupClassName, _codeClassName, _descr: String;
		_minCodeLength, _maxCodeLength, _parentType: Integer) updating, protected;
// ---------------------------------------------------------------------------
// Created:     06 June 2002 by cnwsb1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	self.id				 			:= _id;
	self.description	 			:= _descr;
	self.groupClassNameToCreate		:= _groupClassName;
	self.codeClassNameToCreate		:= _codeClassName;
	self.codeLengthMin				:= _minCodeLength;
	self.codeLengthMax				:= _maxCodeLength;
	self.parentType					:= _parentType;
end;</source>
        <access>protected</access>
        <Parameter name="_id" type="Integer"/>
        <Parameter name="_groupClassName" type="String"/>
        <Parameter name="_codeClassName" type="String"/>
        <Parameter name="_descr" type="String"/>
        <Parameter name="_minCodeLength" type="Integer"/>
        <Parameter name="_maxCodeLength" type="Integer"/>
        <Parameter name="_parentType" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setProxyFromXML" id="d06fdf6b-7cc4-480b-9148-f13063c1cc7b">
        <updating/>
        <source>setProxyFromXML(_id: Integer; _xml: String; _root: CM_Root) updating;
// ---------------------------------------------------------------------------
// Created:     06 June 2002 by cnwsb1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	pos			: Integer;
	tmpDefName	: String;
	
begin
	self.setProxyForCodeGroupType(
			_id,
			_xml.cnEcGetTagValueOfName('GroupClass'),
			_xml.cnEcGetTagValueOfName('CodeClass'),
			_xml.cnEcGetTagValueOfName('Descr'),
			_xml.cnEcGetTagValueOfName('MinLength').Integer,
			_xml.cnEcGetTagValueOfName('MaxLength').Integer,
			_xml.cnEcGetTagValueOfName('ParentType').Integer);

	// Don't set root as this is the automatic end of the inverse
	// (also, inverse maintenance is not carried out on transients).
	//self.myRoot := _root;
	
//epilog
//	delete tmpEnqDefs;
end;</source>
        <Parameter name="_id" type="Integer"/>
        <Parameter name="_xml" type="String"/>
        <Parameter name="_root" type="CM_Root"/>
    </JadeMethod>
    <JadeMethod name="validateCode" id="ef3a2a73-63d1-48b4-a617-80d6ab2e24a8">
        <source>validateCode(_code: String);
// ---------------------------------------------------------------------------
// Created:     11 June 2002 by cnwsb1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	trimmedCode	: String;
	len			: Integer;

begin
	trimmedCode := _code;
	len := trimmedCode.length;
	
	if len &lt; self.codeLengthMin or len &gt; self.codeLengthMax then
		app.raiseCMException2(CodeInvalid,
				"Code length must be in range " &amp; self.codeLengthMin.String &amp;
				"-" &amp; self.codeLengthMax.String, _code, null, null);
	endif;
end;</source>
        <Parameter name="_code" type="String"/>
    </JadeMethod>
    <JadeMethod name="validateForCreate" id="ab888c4d-0f4a-4b56-ae36-8c2213559745">
        <source>validateForCreate();
// ---------------------------------------------------------------------------
// Created:     06 June 2002 by cnwsb1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	if app.myRoot.allCodeGroupTypes[self.id] &lt;&gt; null then
		app.raiseCMException1(VB_DUPLICATED_ITEM, self.id.String, null, null);
	endif;
	
	self.validateForUpdate;
end;</source>
    </JadeMethod>
    <JadeMethod name="validateForUpdate" id="cc9ff453-1129-4ee9-9d17-ef81c4ffbc35">
        <source>validateForUpdate();
// ---------------------------------------------------------------------------
// Created:     06 June 2002 by cnwsb1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 16/12/2014   cnwdb2	    PAR 35364
// ---------------------------------------------------------------------------
vars
	realObjForProxy	: CM_CodeGroupType;
	realObjFound	: CM_CodeGroupType;

begin
	self.raiseExceptionIfNotTransient(method);
	
	if self.id = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'id', 'id', null);
		app.raiseCMException(Input_required_field_id, 'id', null); // cnwdb2	PAR 35364
	else
		realObjFound	:= app.myRoot.allCodeGroupTypes[self.id];
		realObjForProxy	:= self.pxyGetRealObject;
		if realObjFound &lt;&gt; null and realObjFound &lt;&gt; realObjForProxy then
			app.raiseCMException1(VB_DUPLICATED_ITEM, self.id.String, null, null);
		endif;
	endif;
	
	if self.description = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'description', 'description', null);
		app.raiseCMException(Input_required_field_Desc, 'description', null); // cnwdb2	PAR 35364
	endif;

	// Optional - if there is more than one class to create this is left blank
	//if self.myCodeClassToCreate = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'code class to create', null, null);
	//	return;
	//endif;
	if self.myGroupClassToCreate = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'group class to create', null, null);
		app.raiseCMException(Input_required_field_grpClsCrt, null, null); // cnwdb2	PAR 35364
		return;
	endif;
end;</source>
    </JadeMethod>
</Class>
