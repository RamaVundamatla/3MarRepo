    <JadeMethod name="doSave" id="eee60ba6-29b2-4ca6-829a-2a5e25399cb6">
        <updating/>
        <source>doSave() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26/03/2024	navkc1 CR62696 Task 62944: UI - Retrospective UI Stop Start Option
08 Oct 2024 navhl20 Bug 12389 FR | 54883 - Start and End Times for Operations in Mobile App - Retrospective Ops
19 Nov 2024	navhl20 Bug MTN-23340: MTN - Performance issues and locks when completing the Retrospective Pack jobs 
*/

vars
	now,
	startTS,
	completeTS	: TimeStamp;
	theResult	: Integer;
	done		: Boolean;
begin
	
	
	startTS.setDate(self.mskStartDate.getDate());
	startTS.setTime(self.mskStartTime.getTime());
	startTS := self.localToSystemTime(startTS);
	
	completeTS.setDate(self.mskCompleteDate.getDate());
	completeTS.setTime(self.mskCompleteTime.getTime());
	completeTS := self.localToSystemTime(completeTS);
	
	if not startTS.isValid and not completeTS.isValid then		//08.10.2024 navhl20 #12389
		self.getJobStartStopTS(startTS,completeTS);
	endif;
	
	if not startTS.isValid() or not completeTS.isValid() then
		if not self.visible then								//19.11.2024 navhl20 #23340
			return;
		endif;
		app.msgBox("Please enter valid Start/Complete date time.", app.getErrorString(Error), MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
		return;
	endif;
	
	if now.date().differenceInMonths(startTS.date) &gt; 120 or // Start date is more than 10 years old
		now.date().differenceInMonths(completeTS.date) &gt; 120 // End date is 10 years in the future
															then
		app.msgBox("Date cannot be more than 10 years in the past/future.", app.getErrorString(Error), MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
		return;
	endif;
	
	while true do
		app.myTrxUA.trxUpdateStopStartJobActivty(self.myJob, startTS, completeTS, self.myTrackedItem, app.myPassport);			//08.10.2024 navhl20 #12389
		
		if app.myPassport.trxCompletedOK() then
			done := true;
			global.beep();
			break;
		else
			theResult := app.showErrorWarningDialog("Start Complete Job Activity", app.myPassport, ErrWarnMode_Add);
			if app.myPassport.noErrors() and theResult = IDOK then
				app.myPassport.warningsAcknowledged := true;
				continue;
			endif;
			self.setAllErrorWarnings(app.myPassport);
			break;
		endif;
		break;
	endwhile;
	
	if done then
		self.unloadForm();
	endif;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="getJobStartStopTS" id="ea01dd6e-9e4c-4f0a-8e65-ee96762c11bc">
        <source>getJobStartStopTS(_startTS, _completeTS : TimeStamp output);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 Oct 2024 navhl20 Bug 12389 FR | 54883 - Start and End Times for Operations in Mobile App - Retrospective Ops

*/

vars
	wo				: CM_WorkOrder;
	wodtl			: CM_WorkOrderDtl;
	woTxn			: CM_WOTransaction;
	ts				: TimeStamp;
begin
	wodtl := self.myJob.getMyWorkOrderDtl();
	
	if wodtl = null then
		return;
	endif;
	
	wo := wodtl.myParent;
	
	if wo = null then
		return;
	endif;
	
	ts := null;
	
	foreach woTxn in wo.allTransactions discreteLock do
		if not woTxn.isTypeOfJobActivity() then
			continue;
		endif;
		
		if self.myJob.getJobId() &lt;&gt; woTxn.CM_WOJobDetail.jobId then
			continue;
		endif;
		
		if woTxn.type = TRANS_TYPE_WOJOBSTART then
			ts := woTxn.getJobStart();
			if ts.isValid then
				_startTS := ts;
			endif;
		endif;
		
		if woTxn.type = TRANS_TYPE_WOJOBSTOP or woTxn.type = TRANS_TYPE_WOJOBCOMPLETE then
			ts := woTxn.getJobEnd();
			if ts.isValid then
				_completeTS := ts;
			endif;
		endif;
	endforeach;
	
	if not ts.isValid then
		_startTS := null;
		_completeTS := null;
	endif;
epilog

end;</source>
        <Parameter name="_startTS" type="TimeStamp" usage="output"/>
        <Parameter name="_completeTS" type="TimeStamp" usage="output"/>
    </JadeMethod>
    <JadeMethod name="initDateTime" id="94dc0d52-47d3-4403-bc92-0262f8f19583">
        <source>initDateTime();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26/03/2024	navkc1 CR62696 Task 62944: UI - Retrospective UI Stop Start Option
08 Oct 2024 navhl20 Bug 12389 FR | 54883 - Start and End Times for Operations in Mobile App - Retrospective Ops
*/

vars
	job 		: CM_Job;
	jobSheet	: CM_WorkPointJobSheet;
	shift		: CM_Shift;
	startTS,
	completeTS	: TimeStamp;
begin
	
	job := self.myJob;
	
	if job = null then
		return;
	endif;
	
	jobSheet := job.myJobSheetForWorkPoint;
	
	if jobSheet = null then
		return;
	endif;
	
	shift := jobSheet.myShift;
	
	if shift = null then
		return;
	endif;
	
	self.getJobStartStopTS(startTS,completeTS);			//08.10.2024 navhl20 #12389
	
	if not startTS.isValid then							//08.10.2024 navhl20 #12389
		startTS := shift.startDateTime;
	endif;
	if not completeTS.isValid then						//08.10.2024 navhl20 #12389
		completeTS := shift.endDateTime;
	endif;
	
	self.mskStartDate.setDate(self.systemToLocalTime(startTS).date());
	self.mskStartTime.setTime(self.systemToLocalTime(startTS).time);
	
	self.mskCompleteDate.setDate(self.systemToLocalTime(completeTS).date());
	self.mskCompleteTime.setTime(self.systemToLocalTime(completeTS).time);
	
epilog

end;</source>
    </JadeMethod>
