/*

Purpose:			


Return Value:		


Date		Who		Reason
16 May 2008	cnwkpd1	PAR #16753 - CCMS SFW 1003 - General Cargo Graphical Screens

*/

vars
	obj				: Object;
	
begin
	app.mousePointer	:=	Busy;
	
	menuItem.checked := not menuItem.checked;
	
	obj := self.tblGridAreaInfo.userObject ;
	if obj &lt;&gt; null and obj.isKindOf(CM_LocationsController) then
		self.showExtraInforForLocation(obj.CM_LocationsController);
	endif;
	
	
epilog
	app.mousePointer	:=	Idle;
end;</source>
