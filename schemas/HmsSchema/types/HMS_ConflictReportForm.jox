    <JadeMethod name="doResize" id="c9052b62-3970-45dd-b64a-5a1d7238d85e">
        <updating/>
        <source>doResize() updating;
//--------------------------------------------------
// Created:	09 February 2004 By: cnwgd1
//--------------------------------------------------
vars
	tmpTop : Real;
begin
	inheritMethod();
	
	tmpTop := self.frmToolbar.height + VerticalSpacing;
	self.lblConflictsTitle.top := tmpTop;
	self.picConflict.top := tmpTop;
	
	tmpTop := self.lblConflictsTitle.top+self.lblConflictsTitle.height+VerticalSpacing;
	self.tblData.top := tmpTop;
	self.tblData.height := self.clientHeight - tmpTop - self.statusLine.height;

end;</source>
    </JadeMethod>
    <JadeMethod name="doRunConflictCheck" id="080c3915-173e-4051-a963-3be76e47ed01">
        <source>doRunConflictCheck();
//--------------------------------------------------
// Created:	13 October 2005 By: cnwgd1
//--------------------------------------------------
vars
	managerObj		: CMIF_HMS_ConflictsManager;
	fromDT			: TimeStamp;
	endDT			: TimeStamp;
	productObj		: CM_Product;
	listboxObj		: ListBox;
	rowPointer		: Integer;
	lastRow			: Integer;
	
begin
	managerObj	:=	self.myConflictManager;
	
	if managerObj = null then
		return;
	endif;
	
	if self.myAssistant.HMS_Assistant.myHarbour = null then
		app.raiseCMException1(HMSNoHarbourForTerminal, self.myTerminal.name, null, null);
		return;
	endif;
	
	fromDT.setDate(self.txtDateFrom.getDate());
	endDT.setDate(self.txtDateTo.getDate());
	
	if (not fromDT.isValid()) then
		app.msgBox("Please select a valid 'Date From'.", self.caption, MsgBox_OK_Only + MsgBox_Information_Icon);
		return;
	elseif fromDT.date() &gt; endDT.date() then
		app.msgBox("The 'Date From' cannot be later than the 'Date To'.", self.caption, MsgBox_OK_Only + MsgBox_Information_Icon);
		return;
	endif;	
	
	if (not endDT.isValid()) then
		app.msgBox("Please select a valid 'Date To'.", self.caption, MsgBox_OK_Only + MsgBox_Information_Icon);
		return;
	elseif endDT.date() &lt; app.actualTimeServer.date() then
		app.msgBox("Please select at 'Date To' that is after todays date.", self.caption, MsgBox_OK_Only + MsgBox_Information_Icon);
		return;
	endif;	
	
	if chkStockpile.value and lstProducts.selectedCount() = 0 then
		app.msgBox(app.getErrorString(SelectCargoSubtypeToValidate), self.caption, MsgBox_OK_Only + MsgBox_Information_Icon);
		return;
	endif;
	
	managerObj.allValidationTypes.clear();
	managerObj.allProducts.clear();
	
	if self.chkBerthDepths.value then
		managerObj.allValidationTypes.add(ValidateBerthDepths);
	endif;

	if self.chkLockouts.value then
		managerObj.allValidationTypes.add(ValidateWharfLockout);
	endif;	

	if self.chkWharfOverhang.value then
		managerObj.allValidationTypes.add(ValidateWharfOverhang);
	endif;

	if self.chkTidalWindow.value then
		managerObj.allValidationTypes.add(ValidateTidalClass);
		managerObj.allValidationTypes.add(ValidateTidalWindow);
	endif;		

	if self.chkClearances.value then
		managerObj.buildMoveCollToValidate();
		managerObj.allValidationTypes.add(ValidateClearances);
	endif;
	
	if self.chkPilotMaster.value then
		managerObj.allValidationTypes.add(ValidatePilotMaster);
	endif;
	
	if self.chkStockpile.value then
		managerObj.allValidationTypes.add(ValidateStockpile);
		
		listboxObj	:=	lstProducts;
		lastRow		:=	listboxObj.listCount();
		
		foreach rowPointer in 1 to lastRow do
			if listboxObj.itemSelected[rowPointer] then
				productObj	:=	listboxObj.itemObject[rowPointer].CM_Product;
				managerObj.allProducts.add(productObj);
			endif;
		endforeach;
	endif;
	
	if self.chkSteamTime.value then
		managerObj.allValidationTypes.add(ValidateSteamTime);
	endif;
	
	if self.chkVesselUnavail.value then
		managerObj.allValidationTypes.add(ValidateVesselUnavail);
	endif;
	
	if managerObj.allValidationTypes.isEmpty() then
		app.msgBox('Please select at least one conflict type.', self.caption, MsgBox_OK_Only + MsgBox_Information_Icon);
		return;
	endif;
	
	managerObj.allCMIFConflicts.purge();
	managerObj.isAllHarbours	:=	chkAllHarbours.value;
	managerObj.fromDT	:=	fromDT;
	managerObj.endDT	:=	endDT;
	managerObj.runConflictReport();

	self.loadConflictTable();

	if self.tblData.rows &gt; self.tblData.fixedRows then
		self.showHideConflictOptions();
	else
		app.msgBox("No conflicts were found to report.", "Conflicts Report", MsgBox_OK_Only + MsgBox_Information_Icon);
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="getXMLSettingsForSave" id="ecb6fc3b-473f-47ec-882d-f0798f574c69">
        <updating/>
        <source>getXMLSettingsForSave(): String updating;

/*

Purpose:            Gets XML settings of window state for saving windows on closing the form.		

Parameters:			

Return Value:		

Date		Who		Reason
12 September 2008	#cnwdz2	 par 16283

*/
vars
	xmlStr	: String;
begin
	xmlStr := inheritMethod();

	xmlStr := xmlStr &amp; 
			self.tblData.getXmlStrForColumns(true) &amp;
			global.formatAsXML(self.XML_ChkAllHarbours, self.chkAllHarbours.value.String) &amp;
			global.formatAsXML(self.XML_ChkBerthDepths, self.chkBerthDepths.value.String)&amp;
			global.formatAsXML(self.XML_ChkClearances, self.chkClearances.value.String)&amp;
			global.formatAsXML(self.XML_ChkTidalWindow, self.chkTidalWindow.value.String)&amp;
			global.formatAsXML(self.XML_ChkLockouts, self.chkLockouts.value.String)&amp;
			global.formatAsXML(self.XML_ChkWharfOverhang, self.chkWharfOverhang.value.String)&amp;
			global.formatAsXML(self.XML_ChkPilotMaster, self.chkPilotMaster.value.String)&amp;
			global.formatAsXML(self.XML_ChkSteamTime, self.chkSteamTime.value.String)&amp;
			global.formatAsXML(self.XML_ChkStockpile, self.chkStockpile.value.String)&amp;
			global.formatAsXML(self.XML_ChkVesselUnavail, self.chkVesselUnavail.value.String);

	return xmlStr;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="initFromUserWindow" id="59341946-20ce-42e8-bfb4-c24a3ea10779">
        <updating/>
        <source>initFromUserWindow(_userWindow: CM_UserWindow) updating;
/* ---------------------------------------------------------------------------
Created:     12 September 2008 by cnwrs2

Purpose:     
        
Change Date	Who		Reason

------------------------------------------------------------------------------*/
vars

begin
	inheritMethod(_userWindow);
	
	/*		
	Date		Who		Reason
	12 September 2008	#cnwdz2	 par 16283
	*/
	// set check boxes
	self.chkAllHarbours.value := _userWindow.xmlInfo.cnEcGetTagValueOfName(self.XML_ChkAllHarbours).Boolean;
	self.chkBerthDepths.value := _userWindow.xmlInfo.cnEcGetTagValueOfName(self.XML_ChkBerthDepths).Boolean;
	self.chkClearances.value := _userWindow.xmlInfo.cnEcGetTagValueOfName(self.XML_ChkClearances).Boolean;
	self.chkTidalWindow.value := _userWindow.xmlInfo.cnEcGetTagValueOfName(self.XML_ChkTidalWindow).Boolean;
	self.chkLockouts.value := _userWindow.xmlInfo.cnEcGetTagValueOfName(self.XML_ChkLockouts).Boolean;
	self.chkWharfOverhang.value := _userWindow.xmlInfo.cnEcGetTagValueOfName(self.XML_ChkWharfOverhang).Boolean;
	self.chkPilotMaster.value := _userWindow.xmlInfo.cnEcGetTagValueOfName(self.XML_ChkPilotMaster).Boolean;
	self.chkSteamTime.value := _userWindow.xmlInfo.cnEcGetTagValueOfName(self.XML_ChkSteamTime).Boolean;
	self.chkStockpile.value := _userWindow.xmlInfo.cnEcGetTagValueOfName(self.XML_ChkStockpile).Boolean;
	self.chkVesselUnavail.value := _userWindow.xmlInfo.cnEcGetTagValueOfName(self.XML_ChkVesselUnavail).Boolean;

epilog

end;</source>
        <Parameter name="_userWindow" type="CM_UserWindow"/>
    </JadeMethod>
    <JadeMethod name="keyDown" id="6a2ee9cd-4317-463d-9469-a3be30472755">
        <controlMethod name="Form::keyDown"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>keyDown(keyCode: Integer io; shift: Integer) updating;
//--------------------------------------------------
// Created:	14 October 2005 By: cnwgd1
//--------------------------------------------------
begin
	app.mousePointer	:=	Busy;
	
	if keyCode = CMUI_Key_F3 then
		self.showHideConflictOptions();
	elseif keyCode = J_key_Enter then
		if self.frmConflictOptio.visible then
			self.doRunConflictCheck();
		endif;		
	else
		inheritMethod(keyCode, shift);
	endif;
epilog
	app.mousePointer	:=	Idle;
end;</source>
        <Parameter name="keyCode" type="Integer" usage="io"/>
        <Parameter name="shift" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="listProductsPopulate" id="1ebc51b8-e2d7-47ce-ad58-058228b2e622">
        <source>listProductsPopulate() protected;
// --------------------------------------------------------------------------------
// Created:		04 March 2008 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	cargoTypeObj	: CM_CargoType;
	allProductsObj	: CM_ProductArray;
	productObj		: CM_Product;
	listPointer		: Integer;
	
begin
	create allProductsObj transient;
	
	foreach cargoTypeObj in app.myRoot.allCargoTypesById do
		cargoTypeObj.getAllProducts(allProductsObj);
	endforeach;
	
	foreach productObj in allProductsObj do
		listPointer	:=	lstProducts.addItem(productObj.code);
		lstProducts.itemObject[listPointer]	:=	productObj;
	endforeach;
epilog
	delete allProductsObj;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="loadConflictTable" id="434db117-eed4-4500-afbb-fb193b2a37b5">
        <source>loadConflictTable();
//-----------------------------------------
// Created: October 2005 By: cnwgd1
//-----------------------------------------
vars
	rowDisplay	: String;
	conflict	: CMIF_HMS_Conflict;
	rowPointer	: Integer;
	
begin
	self.tblData.rows := self.tblData.fixedRows;
	self.statusLine.caption := null;
	
	if self.myConflictManager = null then
		return;
	endif;
	
	foreach conflict in self.myConflictManager.allCMIFConflicts do
		rowDisplay	:=	conflict.getAttributeStringForDefArray(self.tblData.allTblDataEntRows);
		rowPointer	:=	self.tblData.addItem(rowDisplay);
		self.tblData.accessRow(rowPointer).itemObject	:=	conflict;
	endforeach;
	
	self.tblData.colourRows(self.colorRow1, self.colorRow2);
	self.statusLine.caption := self.myConflictManager.allCMIFConflicts.size.String &amp; ' rows found';
	if self.myConflictManager.allCMIFConflicts.size &gt; 0 then
		self.btnSaveBase.enabled:=true;
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="loadDataForFirstTime" id="605e1b15-e3d5-4a67-bcdf-f09e5cf8f9fc">
        <updating/>
        <source>loadDataForFirstTime() updating, protected;
//--------------------------------------------------
// Created:	09 February 2004 By: cnwgd1
//03 Oct 2017	cnwma1  TFS #7257 JMT - Refactoring - Commodity Planning
//--------------------------------------------------
begin
	self.setDefaults();
	self.loadConflictTable();
	
	if self.tblData.rows &lt;= self.tblData.fixedRows then
		self.showHideConflictOptions();
	endif;
	
	chkStockpile.cnEcSet(false);
	chkStockpile.visible	:=	false;

	
	self.doResize();
end;</source>
        <access>protected</access>
    </JadeMethod>
