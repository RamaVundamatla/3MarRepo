    <JadeMethod name="getConsignGroupCode" id="79df62dc-35f4-4485-a9af-b5310b2bf9f7">
        <source>getConsignGroupCode() : String;
/*****************************************************
Author		: jlgka1 (Karen Alexander)
Date		: 9 November 2018
TFS#		: 40670
Function	: Return concatenated string of Consignee Group.

*** Changes ***
Date			Name		TFS#		Description

****************************************************/

vars
	consigneeConsignorGroup : String;
	consigneeConsignor		: CM_ConsigneeConsignor;
begin
	if self.myTrackedItem = null then
		return null;
	endif;
	
	if self.myTrackedItem.myConsignee &lt;&gt; null then
		consigneeConsignor := app.myRoot.allConsigneeConsignors[self.myTrackedItem.myConsignee.code];
		if consigneeConsignor &lt;&gt; null then
			if consigneeConsignor.myConsignGroup &lt;&gt; null then
				consigneeConsignorGroup := consigneeConsignor.myConsignGroup.code;
			endif;
		endif;
	endif;
	
	return consigneeConsignorGroup;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
