    <JadeMethod name="textBox1_lostFocus" id="20ed7e32-ca0f-4f4b-87b4-0272f17f46f6">
        <controlMethod name="TextBox::lostFocus"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>textBox1_lostFocus(textbox: TextBox input) updating;
// ---------------------------------------------------------------------------
// Created:     03 September 2008 by concms1
// Purpose:     User definable forms - CCMS 1011
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	control	:Control;
begin
	control := self.getSelectedControl;
	
	if control = null then
		return;	// oops
	endif;
	
	if control.isKindOf (Label) and textbox.text &lt;&gt; control.Label.caption then
		self.getFormParent.SOP_FormConfigCustomiseForm.setControlCaption (control, textbox.text);
	elseif control.isKindOf (Button) and textbox.text &lt;&gt; control.Button.caption then
		self.getFormParent.SOP_FormConfigCustomiseForm.setControlCaption (control, textbox.text);
	endif;
epilog

end;</source>
        <Parameter name="textbox" type="TextBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="translateForm" id="465460e4-6adc-46ef-81cb-94e05d9af618">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0009655, locale);
	chkVisible.translateCaption(Xlat_0009656, locale);
	folder1Sheet2.translateCaption(Xlat_0009657, locale);
	label1.translateCaption(Xlat_0009658, locale);
	lblControl.translateCaption(Xlat_0009659, locale);
	shtGeneral.translateCaption(Xlat_0009660, locale);
	shtLayout.translateCaption(Xlat_0009661, locale);
end;</source>
    </JadeMethod>
    <JadeMethod name="unload" id="533ee2e6-9e8e-4d52-b5e5-692f90c6732a">
        <controlMethod name="Form::unload"/>
