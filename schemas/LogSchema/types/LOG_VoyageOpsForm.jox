    <JadeMethod name="listPortsLoadAll" id="bb8be1da-bb3c-4dd9-a639-d5da6d35cb4a">
        <updating/>
        <source>listPortsLoadAll() updating;
//--------------------------------------------------------------
//Created: August 2002 By: cnwgd1
//--------------------------------------------------------------
// 11/04/2011	cnwcs5	par 27367 - use clearAllData instead of setting rows to fixed rows
vars
	allGlobalVoy	: CM_VoyageGlobalByCodeDict;
	voyGlobal		: CM_VoyageGlobal;
	voy				: CM_Voyage;
	voyOper			: CM_VoyageOperator;
	saveListObj		: Object;
	cnt,
	idx				: Integer;
	port			: CM_Terminal;
	theUser			: CM_User;
	passport		: CM_Passport;
	picVesselLogs	: Binary;
	root			: CM_Root;
begin

	saveListObj := self.lstPorts.listObject;
	self.lstPorts.clear;
	self.myCurrentVoyageGlobal := null;
	
	self.tblOrderData.clearAllData;	// par 27367

	idx := self.lstPorts.addItem('Global Voyages Ports');
	self.lstPorts.itemLevel[idx] := 1;		
		
	root := app.myRoot;
	if root = null then
		return;
	endif;
	
	self.lstPorts.itemPicture[idx] := root.getConfig(PicGlobe).Binary;		
	
	create allGlobalVoy transient;
	root.allVoyagesGlobal.copy(allGlobalVoy);
	if self.modeView = Mode_ArchiveView then
		root.allVoyagesGlobalArchived.copy(allGlobalVoy);	
	endif;

	if allGlobalVoy.isEmpty then
		return;
	endif;

	passport := app.myPassport;
	theUser := passport.myUser;	
	picVesselLogs := root.getConfig(PicVesselLogs).Binary;	
		
	foreach voyGlobal in allGlobalVoy do
		if (not self.includeGlobalVoyage(voyGlobal, passport)) then
			continue;
		endif;
		idx := lstPorts.addItem(voyGlobal.code &amp; '  ' &amp; voyGlobal.vesselName);
		lstPorts.itemObject[idx] := voyGlobal;
		lstPorts.itemLevel[idx] := 2;
		lstPorts.itemPicture[idx] := picVesselLogs;
		
		foreach voy in voyGlobal.allVoyages do
			if (not self.includeVoyage(voy, theUser)) then
				continue;
			endif;
			port := voy.myTerminal;
			
		
			// we need to add the terminal and arrival date if necessary
			idx := lstPorts.addItem(voy.getComboBoxDisplayString(true));
			lstPorts.itemObject[idx] := voy;
			lstPorts.itemLevel[idx] := 3;
			foreach voyOper in voy.allVoyageIOperators reversed do
				if (not self.includeOperator(voyOper.myOperator)) then
					continue;
				endif;
				idx := lstPorts.addItem(voyOper.myOperator.code);
				lstPorts.itemObject[idx] := voyOper;
				lstPorts.itemLevel[idx] := 4;
			endforeach;
		endforeach;
	endforeach;
	
	lstPorts.itemExpanded[1] := true;
	self.listsSetSelected(lstPorts, saveListObj);

epilog
	delete allGlobalVoy;
end;</source>
    </JadeMethod>
    <JadeMethod name="listPortsSetBelowVoyGlobal" id="3678e271-dbd7-48ba-8a27-f8cf1a784037">
        <updating/>
        <source>listPortsSetBelowVoyGlobal(_voyGlobal : CM_VoyageGlobal; _idx : Integer) updating;
//--------------------------------------------------------------
//Created: November 2002 By: cnwgd1
//--------------------------------------------------------------

vars
	voy		: CM_Voyage;
	idx		: Integer;
	term	: CM_Terminal;
	voyOper : CM_VoyageOperator;
	theUser	: CM_User;
begin

	if _voyGlobal = null then
		return;
	endif;
	
	idx := _idx + 1;
	theUser := app.getMyUser();
	foreach voy in _voyGlobal.allVoyages do
		if (not self.includeVoyage(voy, theUser)) then
			continue;
		endif;
		
		term := voy.myTerminal;
		// we need to add the terminal and arrival date if necessary
		lstPorts.addItemAt(voy.getComboBoxDisplayString(true), idx);
		lstPorts.itemObject[idx] := voy;
		lstPorts.itemLevel[idx] := 3;
		foreach voyOper in voy.allVoyageIOperators reversed do
			if (not self.includeOperator(voyOper.myOperator)) then
				continue;
			endif;		
			idx := (idx+1);
			lstPorts.addItemAt(voyOper.myOperator.code, idx);
			lstPorts.itemObject[idx] := voyOper;
			lstPorts.itemLevel[idx] := 4;
		endforeach;
		idx := _idx + 1;
	endforeach;

	lstPorts.itemExpanded[1] := true;	

end;</source>
        <Parameter name="_voyGlobal" type="CM_VoyageGlobal"/>
        <Parameter name="_idx" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="listPortsSetBelowVoyage" id="f63bb18c-274a-47f6-b683-969065f509ba">
        <updating/>
        <source>listPortsSetBelowVoyage(_voyage : CM_Voyage; _idx : Integer) updating;
//--------------------------------------------------------------
//Created: August 2002 By: cnwgd1
//--------------------------------------------------------------

vars
	voyOper	: CM_VoyageOperator;
	idx		: Integer;
begin

	if _voyage = null then
		return;
	endif;

	idx := _idx + 1;
	foreach voyOper in _voyage.allVoyageIOperators do
		lstPorts.addItemAt(voyOper.myOperator.code, idx);
		lstPorts.itemObject[idx] := voyOper;
		lstPorts.itemLevel[idx] := 4;
	endforeach;

	lstPorts.itemExpanded[1] := true;	

end;</source>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_idx" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="listSupplierRemoveOperator" id="df280f43-1f8b-41c6-b0b4-10107858ad8b">
        <source>listSupplierRemoveOperator(_idx : Integer) protected;
// ---------------------------------------------------------------------------
// Created:      15 May 2003 by cnwsgp1
// ---------------------------------------------------------------------------
//
// Remove the operator if its last voyage operator has been removed

vars
	idx : Integer;
	operator : CM_Operator;
	voyGlobal : CM_VoyageGlobal;
	operatorIdx : Integer;

begin
	// need to go back up the tree to find the operator and voyage global
	idx := _idx - 1;
	while idx &gt; 1 do
		if self.lstSuppliers.itemLevel[idx] = 3 then
			operator := self.lstSuppliers.itemObject[idx].CM_Operator;
			operatorIdx := idx;
		elseif self.lstSuppliers.itemLevel[idx] = 2 then
			voyGlobal := self.lstSuppliers.itemObject[idx].CM_VoyageGlobal;
			break;
		endif;
		idx := idx -1;
	endwhile;

	if operator = null or voyGlobal = null then
		return;
	endif;
	
	idx := operatorIdx + 1;
	
	if idx &gt; self.lstSuppliers.listCount or self.lstSuppliers.itemLevel[idx] &lt;&gt; 4 then
		self.lstSuppliers.removeItem(operatorIdx);
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="_idx" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="listSupplierSetBelowVoyGlobal" id="e47b9d3d-70bb-4c61-b526-f32f55ebef0f">
        <source>listSupplierSetBelowVoyGlobal(_voyGlobal : CM_VoyageGlobal; _idx : Integer);
//--------------------------------------------------------------
//Created: 08 November 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	voyOper : CM_VoyageOperator;
	term	: CM_Terminal;
	idx		: Integer;
	lastOperator : CM_Operator;
	theUser	: CM_User;
begin
	if _voyGlobal = null then
		return;
	endif;
	
	idx := _idx;
	theUser := app.getMyUser();
	foreach voyOper in _voyGlobal.allVoyOpsByOpTerm do
		if (not self.includeVoyage(voyOper.myVoyage, theUser)) then
			continue;
		endif;
		if (not self.includeOperator(voyOper.myOperator)) then
			continue;
		endif;												
		if voyOper.myOperator &lt;&gt; lastOperator then
			idx := idx + 1;
			lstSuppliers.addItemAt(voyOper.myOperator.code, idx);
			lstSuppliers.itemObject[idx] := voyOper.myOperator;
			lstSuppliers.itemLevel[idx] := 3;
		endif;

		idx := idx + 1;
		term := voyOper.myVoyage.myTerminal;
		lstSuppliers.addItemAt(term.name, idx);
		lstSuppliers.itemObject[idx] := voyOper;
		lstSuppliers.itemLevel[idx] := 4;
		lastOperator := voyOper.myOperator;
	endforeach;
	
	lstSuppliers.itemExpanded[1] := true;	
	
end;</source>
        <Parameter name="_voyGlobal" type="CM_VoyageGlobal"/>
        <Parameter name="_idx" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="listSuppliersLoadAll" id="1193941e-0662-4b2d-a4e8-c80008829fca">
        <updating/>
        <source>listSuppliersLoadAll() updating;
//--------------------------------------------------------------
//Created: August 2002 By: cnwgd1
//--------------------------------------------------------------
// 11/04/2011	cnwcs5	par 27367 - use clearAllData instead of setting rows to fixed rows
vars
	allGlobalVoy	: CM_VoyageGlobalByCodeDict;
	voyGlobal		: CM_VoyageGlobal;
	voy				: CM_Voyage;
	voyOper			: CM_VoyageOperator;
	saveListObj		: Object;
	idx				: Integer;
	port			: CM_Terminal;
	tmpOperator		: CM_Operator;
	lastOperator	: CM_Operator;
	theUser			: CM_User;
	passport		: CM_Passport;
	root			: CM_Root;
	picVesselLogs	: Binary;
begin

	saveListObj := self.lstSuppliers.listObject;
	self.lstSuppliers.clear;
	self.myCurrentVoyageGlobal := null;
	
	self.tblOrderData.clearAllData;	// par 27367

	idx := self.lstSuppliers.addItem('Global Voyages Suppliers');
	self.lstSuppliers.itemLevel[idx] := 1;	
		
	root := app.myRoot;
	if root = null then
		return;
	endif;

	self.lstSuppliers.itemPicture[idx] := root.getConfig(PicGlobe).Binary;	
	
	create allGlobalVoy transient;
	root.allVoyagesGlobal.copy(allGlobalVoy);
	if self.modeView = Mode_ArchiveView then
		root.allVoyagesGlobalArchived.copy(allGlobalVoy);	
	endif;
	
	if allGlobalVoy.isEmpty then
		return;
	endif;
	
	passport := app.myPassport;
	theUser := passport.myUser;	
	picVesselLogs := root.getConfig(PicVesselLogs).Binary;	
	
	foreach voyGlobal in allGlobalVoy do
		if (not self.includeGlobalVoyage(voyGlobal, passport)) then
			continue;
		endif;
	
		idx := lstSuppliers.addItem(voyGlobal.code &amp; '  ' &amp; voyGlobal.vesselName);
		lstSuppliers.itemObject[idx] := voyGlobal;
		lstSuppliers.itemLevel[idx] := 2;
		lstSuppliers.itemPicture[idx] := picVesselLogs;	
		lastOperator := null;
		foreach voyOper in voyGlobal.allVoyOpsByOpTerm do
			if (not self.includeOperator(voyOper.myOperator)) then
				continue;
			endif;
			if (not self.includeVoyage(voyOper.myVoyage, theUser)) then
				continue;
			endif;

			if voyOper.myOperator &lt;&gt; lastOperator then
				idx := lstSuppliers.addItem(voyOper.myOperator.code);
				lstSuppliers.itemObject[idx] := voyOper.myOperator;
				lstSuppliers.itemLevel[idx] := 3;
			endif;
			port := voyOper.myVoyage.myTerminal;
			idx := lstSuppliers.addItem(port.name);
			lstSuppliers.itemObject[idx] := voyOper;
			lstSuppliers.itemLevel[idx] := 4;
			lastOperator := voyOper.myOperator;
		endforeach;
	endforeach;

	lstSuppliers.itemExpanded[1] := true;
	self.listsSetSelected(lstSuppliers, saveListObj);

epilog
	delete allGlobalVoy;
end;</source>
    </JadeMethod>
    <JadeMethod name="listTreeViewChange" id="87e58eda-b5ed-4603-84da-016d3cb982ee">
        <updating/>
        <source>listTreeViewChange(listbox: ListBox input)updating;
//--------------------------------------------------------------
//Created: 09 July 2002 By: cnwgd1
//--------------------------------------------------------------
// 11/04/2011	cnwcs5	par 27367 - use clearAllData instead of setting rows to fixed rows
vars
	obj 			: Object;
	idx, lvl		: Integer; 
	origVoyGlob 			: CM_VoyageGlobal;
	origVoyage				: CM_Voyage;
	origVoyOper				: CM_VoyageOperator;
	origOperator 			: CM_Operator;
	statusClosed 			: Boolean;
	invalidVoyageOperator 	: Boolean;			// 12/05/2010 cnwmh5 #24141
begin

	on Exception do app.handleDeletedObject(exception, self.myCurrentVoyageOperator, invalidVoyageOperator);	// 12/05/2010 cnwmh5 #24141
	
	self.tblOrderData.clearAllData;	// par 27367
	self.viewMode := self.Mode_View;	// default setting
	statusClosed := false;
	
	origVoyGlob 	:= self.myCurrentVoyageGlobal;
	origOperator	:= self.myCurrentOperator;
	origVoyage		:= self.myCurrentVoyage;
	origVoyOper		:= self.myCurrentVoyageOperator;

	obj := listbox.listObject;
	if listbox.listIndex &lt;&gt; -1 then
		 lvl := listbox.itemLevel[listbox.listIndex];
	endif;

	if obj = null then
		self.clearAllTables();	
		self.listVoyTerminalsPopulate();				
	else
		if obj.isKindOf(CM_VoyageGlobal) then
			self.myCurrentVoyageGlobal := obj.CM_VoyageGlobal;
		//	if self.myCurrentVoyageGlobal &lt;&gt; origVoyGlob then // par#14308 Mohammad 25/6/2007
				// if changed global voyage then
				self.myCurrentOperator	:= null;
				self.myCurrentVoyage	:= null;
				self.myCurrentVoyageOperator	:= null;
		//endif;
			self.loadAllOrdersByVoyageGlobal(self.myCurrentVoyageGlobal);
			//	Sep 2011	cnwjre1		CCMS 1120 Par 28082 Log voyage operations changes, set up viewMode
			statusClosed := self.isGlobalVoyageClosed();
//			self.clearTblLotDetails;
		elseif obj.isKindOf(CM_VoyageOperator) then
			self.myCurrentVoyageOperator := obj.CM_VoyageOperator;
			self.myCurrentOperator		 := self.myCurrentVoyageOperator.myOperator;
			self.myCurrentVoyageGlobal 	 := self.myCurrentVoyageOperator.myVoyageGlobal;
			//	Sep 2011	cnwjre1		CCMS 1120 Par 28082 Log voyage operations changes, set up viewMode
			statusClosed := self.isGlobalVoyageClosed();
			if lvl = 4 then
				self.myCurrentVoyage   := self.myCurrentVoyageOperator.myVoyage;
				// 28082
				if self.myCurrentVoyage &lt;&gt; null then
					statusClosed := self.myCurrentVoyage.isClosedStatus();
				endif;
			endif;
			self.loadAllOrdersByVoyageOperator(self.myCurrentVoyageOperator);
			
		elseif obj.isKindOf(CM_Voyage) then
			self.myCurrentVoyage 	:= obj.CM_Voyage;
			self.myCurrentVoyageGlobal	 := self.myCurrentVoyage.myVoyageGlobalArrival;
			self.myCurrentOperator := null;
			self.myCurrentVoyageOperator := null;
			// 28082
			statusClosed := self.myCurrentVoyage.isClosedStatus();

			self.loadAllOrdersByVoyageTerminal(self.myCurrentVoyage, self.myCurrentOperator);
			
		elseif obj.isKindOf(CM_Operator) then
			self.myCurrentOperator := obj.CM_Operator;
			//if self.myCurrentOperator &lt;&gt; origOperator then	// 03/04/2009 cnwar2 CCMS-1099 #19395
				self.myCurrentVoyageOperator := null;
				self.myCurrentVoyage := null;
			//endif;

			if lvl = 3 then
				// need to go back up the tree to find the current global voyage
				idx := listbox.listIndex -1;
				while idx &gt; 1 do
					if listbox.itemLevel[idx] = 2 then
						self.myCurrentVoyageGlobal := listbox.itemObject[idx].CM_VoyageGlobal;
						if self.myCurrentVoyageGlobal &lt;&gt; null then
							//	Sep 2011	cnwjre1		CCMS 1120 Par 28082 Log voyage operations changes, set up viewMode
							statusClosed := self.isGlobalVoyageClosed();
						endif;
						break;
					endif;
					idx := idx -1;
				endwhile;
			endif;
			self.loadAllOrdersByVoyGlobOperator(self.myCurrentOperator, self.myCurrentVoyageGlobal);
		endif;
	endif;
	//	Aug 2011	cnwjre1		CCMS 1120 Par 28082 Log voyage operations changes	
	if statusClosed then
		self.viewMode := Mode_LimitedEdit;
	else
		self.viewMode := Mode_View;
	endif;
	if self.modeView &lt;&gt; Mode_ArchiveView then
		self.modeView := self.viewMode;
	endif;


	if self.myCurrentVoyageGlobal &lt;&gt; null then 
		self.showAllocToDetail();
		self.setNavigatorHeading(self.myCurrentVoyageGlobal.code);
	else
		self.setNavigatorHeading('Voyages');
	endif;

	if self.myCurrentVoyage &lt;&gt; null then
		self.showSupplierDetails();
		app.myPassport.setMyTerminal(self.myCurrentVoyage.myTerminal);				
	else
		app.myPassport.setMyTerminal(self.myTerminal);
	endif;

	self.voyageOperatorShow(self.myCurrentVoyageOperator);
	
	self.showAdditionalInfo(obj);	   
	self.clearSearchResults();
	self.detailsDisplaySelected();	
	//if self.myCurrentVoyageGlobal &lt;&gt; origVoyGlob then		// 06/04/2009 cnwar2 CCMS-1099 #19395
	if self.myCurrentVoyageOperator &lt;&gt; origVoyOper then		// 06/04/2009 cnwar2 CCMS-1099 #19395
		self.clearTblLotDetails();	// need to clear the details from this table, as can allow a user to enter incorrect data otherwise.
	endif;
	
	// 29/10/2009 cnwar2 #21507 - moved out of above condition
	self.myCurrentStockOrderLine 	:= null;
	self.myCurrentStockOrderObject 	:= null;	// 06/04/2009 cnwar2 CCMS-1099 #19395
	
	self.setEnableObjects();
	tblSupplierEnt.disableRowByName(ETRow_Port); // Mohammad par13527 17/4/2007
	
	self.sssShowLogRowsForDownload();	// 03/04/2009 cnwar2 CCMS-1099 #19395
end;</source>
        <Parameter name="listbox" type="ListBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="listVoyTerminalsPopulate" id="3ce9fbe2-ba40-44ef-8068-1318c110c497">
        <source>listVoyTerminalsPopulate();
// ---------------------------------------------------------------------------
// Created:     13 April 2005	cnwhjg1
//
// Purpose:     Par 9608
// ----------   ----------  --------------------------------------------------
vars
	allTerminals : CM_TerminalByCodeDict;
	lstTerminal	: CM_Terminal;
	user		: CM_User;
	row			: Integer;
begin

	self.lbxVoyTerminals.clear();
	self.lbxUnassTerminal.clear();

	allTerminals := app.myRoot.allTerminals;
	user := app.getMyUser();
	foreach lstTerminal in allTerminals do
		if user.canDo(lstTerminal, self.permissionMaint) then			
			if self.tblVoyTermDtlIncludesTerm(lstTerminal) then  // only show in list box if not in table 
				row := self.lbxVoyTerminals.addItem(lstTerminal.name);
				self.lbxVoyTerminals.itemObject[row] := lstTerminal;
			else
				row := self.lbxUnassTerminal.addItem(lstTerminal.name);
				self.lbxUnassTerminal.itemObject[row] := lstTerminal;
			endif;
		endif;
	endforeach;

end;</source>
    </JadeMethod>
    <JadeMethod name="listsAddItem" id="5bc74e71-a664-4fe0-8060-4d4b32bf2ad5">
        <updating/>
        <source>listsAddItem(_obj : Object)updating;
//--------------------------------------------------------------
//Created: 07 November 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	idx 		: Integer;
	voyGlobal	: CM_VoyageGlobal;
	voy			: CM_Voyage;
	terminal	: CM_Terminal;
	tmpStartDate,
	tmpEndDate	: Date;
begin
	
	if _obj = null then
		return;
	endif;

	if _obj.isKindOf(CM_VoyageOperator) then
		self.listsSetBelowVoyOper(_obj.CM_VoyageOperator);
		return;
	elseif _obj.isKindOf(CM_VoyageGlobal) then
		voyGlobal := _obj.CM_VoyageGlobal;
		if self.modeView = Mode_ArchiveView then
			terminal := self.cmbTerminal.listObject.CM_Terminal;
//			tmpStartDate := self.tblArchiveSearch.getValueByName(ETRow_FilterStartDate).Date;
//			tmpEndDate := self.tblArchiveSearch.getValueByName(ETRow_FilterEndDate).Date;
			tmpStartDate := self.tblArchiveSearch.getValueAsDate(ETRow_FilterStartDate);
			tmpEndDate := self.tblArchiveSearch.getValueAsDate(ETRow_FilterEndDate);
			if (not voyGlobal.hasArchivedVoyages(terminal, tmpStartDate, tmpEndDate, app.myPassport, self.permissionView)) then
				return;
			endif;
		endif;
		if (not self.includeGlobalVoyage(voyGlobal, app.myPassport)) then
			return;
		endif;				
	else
		return;		//For now - TEMP
	endif;
	
	if lstPorts.listCount = 0 then //par 15538
		return;
	endif;	

	idx := lstPorts.addItem(voyGlobal.code &amp; '  ' &amp; voyGlobal.vesselName);
	lstPorts.itemObject[idx] := voyGlobal;
	lstPorts.itemLevel[idx] := 2;
	lstPorts.itemPicture[idx] := app.myRoot.getConfig(PicVesselLogs).Binary;
	lstPorts.itemExpanded[idx] := true;							

	foreach voy in voyGlobal.allVoyages do
		if (not self.includeVoyage(voy, app.getMyUser)) then
			continue;
		endif;
		terminal := voy.myTerminal;
		// we need to add the terminal and arrival date if necessary
		idx := lstPorts.addItem(voy.getComboBoxDisplayString(true));
		lstPorts.itemObject[idx] := voy;
		lstPorts.itemLevel[idx] := 3;
	endforeach;	
	
	idx := lstSuppliers.addItem(voyGlobal.code &amp; '  ' &amp; voyGlobal.vesselName);
	lstSuppliers.itemObject[idx] := voyGlobal;
	lstSuppliers.itemLevel[idx] := 2;
	lstSuppliers.itemPicture[idx] := app.myRoot.getConfig(PicVesselLogs).Binary;				
	lstSuppliers.itemExpanded[idx] := true;							
end;</source>
        <Parameter name="_obj" type="Object"/>
    </JadeMethod>
    <JadeMethod name="listsSetBelowVoyOper" id="223414bf-d9ac-4032-ae97-cad10f6c76f2">
        <updating/>
        <source>listsSetBelowVoyOper(_voyOper : CM_VoyageOperator)updating;
//--------------------------------------------------------------
//Created: 16 August 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	idx : Integer;
	voyGlobal : CM_VoyageGlobal;
	theVoyage : CM_Voyage;
begin
	if _voyOper = null then
		return;
	endif;

	theVoyage := _voyOper.myVoyage;
	
	if theVoyage = null then
		return;
	endif;
	if (not self.includeOperator(_voyOper.myOperator)) then
		return;
	endif;
//	if self.fldTreeView.topSheet = self.shtListPorts then Par 15465
		idx := lstPorts.findObject(theVoyage);
		if idx &lt;&gt; -1 then
			lstPorts.clearBelowLevel(idx);
			self.listPortsSetBelowVoyage(theVoyage, idx);					
		endif;
//	else //top sheet must be suppliers
		idx := lstSuppliers.findObject(theVoyage.myVoyageGlobalArrival);
		if idx &lt;&gt; -1 then
			lstSuppliers.clearBelowLevel(idx);
			voyGlobal := theVoyage.myVoyageGlobalArrival;
			self.listSupplierSetBelowVoyGlobal(voyGlobal, idx);			
		endif;
//	endif;

end;</source>
        <Parameter name="_voyOper" type="CM_VoyageOperator"/>
    </JadeMethod>
    <JadeMethod name="listsSetSelected" id="d88a1675-f3b9-4451-96c7-148d145656d5">
        <source>listsSetSelected(_listBox : CM_QueueListBox input; _object : Object);
//--------------------------------------------------------------
//Created: 07 November 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	idx : Integer;
begin
	if _listBox = null then
		return;
	endif;
	
	if _object &lt;&gt; null then
		idx := _listBox.findObject(_object);
	endif;

	if idx &lt; 1 then
		idx := _listBox.topIndex;
	endif;

	if _listBox.listCount &gt;= idx then
		_listBox.listIndex := idx; 
		_listBox.itemEnabled[idx] := true;
		_listBox.itemExpanded[idx] := true;
	endif;
	
end;</source>
        <Parameter name="_listBox" type="CM_QueueListBox" usage="input"/>
        <Parameter name="_object" type="Object"/>
    </JadeMethod>
