    <JadeMethod name="txtFind_gotFocus" id="b41d3aa8-172c-499c-be57-f05ae29093fc">
        <controlMethod name="TextBox::gotFocus"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>txtFind_gotFocus(textbox: TextBox input) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 17 March 2020	jlgdap1		Initial creation TFS 
