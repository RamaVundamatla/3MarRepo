<Class name="EntTableSignedNumeric" id="664e5752-4df0-4504-861f-b7f22023e176">
    <superclass name="EntTableCellControl"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="cmtrans"/>
    <PrimAttribute name="decimals" id="bfc4f0d0-61a6-4169-a446-4b273c8ba106">
        <embedded/>
        <type name="Integer"/>
    </PrimAttribute>
    <PrimAttribute name="maxLength" id="2cf464ce-774a-4ac4-b8ba-82f46985cbe0">
        <embedded/>
        <type name="Integer"/>
    </PrimAttribute>
