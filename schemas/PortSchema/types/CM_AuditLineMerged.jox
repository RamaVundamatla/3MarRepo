end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="setRemarks" id="a6561756-9acf-46ed-aa3f-d61950da836c">
        <updating/>
        <source>setRemarks() updating;
/*
Purpose - 	
Who - NAVAB1
Date - 08JAN2024
ADO -  CR 58085 TASK 61342
*/

begin
	remarks := "Line " &amp; self.invoiceLineSeqNum.String &amp; " merged from Invoice Number " &amp; self.fromInvoiceSeqNum.String &amp; " into " &amp; self.toInvoiceSeqNum.String;
end;</source>
    </JadeMethod>
</Class>
