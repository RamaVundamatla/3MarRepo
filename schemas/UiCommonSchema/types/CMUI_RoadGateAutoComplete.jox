    <JadeMethod name="translateForm" id="6045634d-f9a0-4065-a36b-07b49e362424">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 26 June 2024 11:18:27.
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0026630, locale);
	btnNew.translateCaption(Xlat_0026631, locale);
	lblType.translateCaption(Xlat_0026865, locale);
	optReceive.translateCaption(Xlat_0026866, locale);
	optRelease.translateCaption(Xlat_0026867, locale);
end;</source>
    </JadeMethod>
    <JadeMethod name="updateAddObjectInTable" id="c2d1c22f-f28a-4788-a249-802990819000">
        <updating/>
        <source>updateAddObjectInTable(_eventType : Integer; _detail : CM_RoadGateAutoComplete) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
24th Jan 2024 	navra1  TFS 62081 - CUX | Auto-setdown of cargo that doesn't require a machine move

*/

vars
	theDataLine : String;
	row : Integer;
begin
	if not _eventType = Object_Delete_Event then
		theDataLine := _detail.getAttributeStringForDefArray(self.tblData.allTblDataEntRows);
	endif;
	if _eventType = Object_Create_Event then
		if _detail.myTerminal &lt;&gt; self.getMyTerminal then	//TFS 38467
			return;	//TFS 38467 - if created Transition belongs to another terminal,
		endif;	//TFS 38467	- don't add it to the data table
		self.tblData.addItemObject(_detail, theDataLine);
	else // update/delete
		self.tblData.findObjectInRow(_detail, row);
		
		if row &lt;= self.tblData.fixedRows then
			return;
		endif;
		
		self.tblData.removeItem(row);
		if _eventType = Object_Update_Event then
			self.tblData.addItemObject(_detail, theDataLine);
		endif;
	endif;

end;</source>
        <Parameter name="_eventType" type="Integer"/>
        <Parameter name="_detail" type="CM_RoadGateAutoComplete"/>
    </JadeMethod>
</GUIClass>
