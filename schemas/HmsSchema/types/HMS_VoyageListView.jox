    <JadeMethod name="keyDown" id="224c5dc3-09f5-42ee-bbae-e5677de5c86a">
        <controlMethod name="Form::keyDown"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>keyDown(keyCode: Integer io; shift: Integer) updating;

constants
	Esc_Key = 27;
vars

begin
 	if keyCode = Esc_Key then
 		self.unloadForm;
 	else
 		inheritMethod(keyCode, shift);
 	endif;	
end;</source>
        <Parameter name="keyCode" type="Integer" usage="io"/>
        <Parameter name="shift" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="lbxVoyageTree_click" id="cd3a240b-3f53-4d4d-9057-7f3f8a5e1cc2">
        <controlMethod name="ListBox::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>lbxVoyageTree_click(listbox: ListBox input) updating;

vars
	obj:	Object;
begin
	if lbxVoyageTree.listIndex&gt;0 then
		obj:=lbxVoyageTree.itemObject[lbxVoyageTree.listIndex];
		if obj&lt;&gt;null then
			if obj.isKindOf(CMIF_HMS_WorkingVoyage) then
				myViewController.view_NewCurrentVoyage(obj.CMIF_HMS_WorkingVoyage);
			elseif obj.isKindOf(CMIF_HMS_WorkingMovement) then
				myViewController.view_NewSelectedMovement(obj.CMIF_HMS_WorkingMovement, true);
			endif;
		endif;
	endif;
end;</source>
        <Parameter name="listbox" type="ListBox" usage="input"/>
    </JadeMethod>
