    <JadeMethod name="setStatus" id="14a0b667-6033-434c-ac60-abd355795dd1">
        <updating/>
        <source>setStatus(_status:Integer) updating;
// --------------------------------------------------------------------------------
// Created:		03 June 2008 by cnwdad1:2
//
// Purpose:		Updates the receiver's Status flag.
//
// Parameters:	_status - The new status value.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if _status = LC_Status_Closed
	or _status = LC_Status_Open
	or _status = LC_Status_PhysicallyEmpty
	or _status = LC_Status_Archived
	then
		self.status	:=	_status;
	endif;
end;</source>
        <Parameter name="_status" type="Integer"/>
    </JadeMethod>
