    <JadeMethod name="addToolbarControls" id="9fdb8da8-d21f-4a75-accf-be53feade9f9">
        <updating/>
        <source>addToolbarControls() updating, protected;
//------------------------------------------------
// Created: 17 May 2006 By: cnwgd1
//------------------------------------------------
vars
	frm	: CMUI_Toolbar;
begin

	inheritMethod();
	frm := self.frmToolbar;

	// 35872 show searcher if more than one company
	if self.cmbBank.listCount &gt; 1 then
		frm.addButton(self.btnSearch, CMUI_Toolbar.Control_Alignment_Left);
	endif;
	frm.addButton(self.btnNew, CMUI_Toolbar.Control_Alignment_Left);
	frm.addButton(self.btnEdit, CMUI_Toolbar.Control_Alignment_Left);
	frm.addButton(self.btnDelete, CMUI_Toolbar.Control_Alignment_Left);
	frm.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	frm.addButton(self.btnRefresh, CMUI_Toolbar.Control_Alignment_Left);

	self.frmPropToolbar.addButton(self.btnPropNext, CMUI_Toolbar.Control_Alignment_Left);		
	self.btnSaveBase.visible := false;
	
	// 35872 setup search toolbar for business unit
	frm := self.frmSeachToolbar;
	frm.addButton(self.btnSearchSearch, CMUI_Toolbar.Control_Alignment_Left);
	frm.addButton(self.btnSearchCancel, CMUI_Toolbar.Control_Alignment_Left);
	frm.positionToolbarControls();
	frm.visible := true;
	
end;</source>
        <access>protected</access>
    </JadeMethod>
