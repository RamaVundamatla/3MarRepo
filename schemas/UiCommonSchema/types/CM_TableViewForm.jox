    </JadeMethod>
    <JadeMethod name="doSptDataFilterMove" id="295157fb-a782-4814-8a6f-83f899a5fadb">
        <source>doSptDataFilterMove();
// ---------------------------------------------------------------------------
// Created:     25 June 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
vars
	toolbarHeight,
	tmpHeight		: Real;

begin

	if self.isSearcherFloating then
		return;
	endif;

	self.sptDataFilter.cnEcResizeContents();
	self.tblSearch.adjustHeight(2000);
	toolbarHeight := self.frmSearchToolbar.height;
	
	tmpHeight := self.frmSearch.clientHeight - toolbarHeight;
	if self.tblSearch.height &gt; tmpHeight then
		self.tblSearch.height := tmpHeight;
	endif;
	
end;</source>
    </JadeMethod>
