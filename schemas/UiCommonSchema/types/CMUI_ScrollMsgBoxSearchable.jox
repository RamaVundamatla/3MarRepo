    <JadeMethod name="setupForm" id="32fa2b92-fa50-4791-a530-765dd1514ea2">
        <updating/>
        <source>setupForm() updating;
//----------------------------------------------------------------
//	Created:	20 May 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
begin
	inheritMethod();
	
	self.addRegisteredKey(J_key_F);
	
	self.toolbarStyle	:=	self.ToolbarStyle_ShowNoHide;	
	self.showToolbar	:=	true;
	self.width			:=	450;
	self.height			:=	450;
	
	// the background frame should fill the entire client area below the toolbar - after this parentAspect will take care of things
	self.frmBackground.move (0, self.frmToolbar.top + self.frmToolbar.height, self.clientWidth, self.clientHeight - self.frmToolbar.height);
	
	// the text area should fill the entire bottom frame - after this parentAspect will take care of things
	self.txtData.move (0, 20, self.jdbBottom.clientWidth, self.jdbBottom.clientHeight - 20); // ### TFS 50421 05NOV2021 NAVAB1 changed to '20'
	
	// the top frame may be visible in subclasses but it is up to the sub form to handle it
	txtData.contextMenuOptions	:=	JadeRichText.MenuOption_Custom;
end;</source>
    </JadeMethod>
    <JadeMethod name="toolbarShowCaptions" id="2409af0b-a064-46c4-8faa-ae12d2a06471">
        <updating/>
        <source>toolbarShowCaptions(_showCaptions: Boolean) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 February 2017	cnwrh7	Initial creation TFS3303

*/
vars
	currentHeight : Real;
	newHeight : Real;
	heightDiff : Real;
	diff : Integer;
begin
	currentHeight := self.frmToolbar.height;
	inheritMethod(_showCaptions);
	newHeight := self.frmToolbar.height;
	heightDiff := newHeight - currentHeight;
	self.txtData.top := self.txtData.top + heightDiff;
	
	// ### TFS 50421 05NOV2021 NAVAB1
	if _showCaptions then
		diff := 70;
	else
		diff := 20;
	endif;
	self.txtData.height := self.jdbBottom.clientHeight - diff;
epilog

end;</source>
        <Parameter name="_showCaptions" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="translateForm" id="3910f6db-7276-43bc-87c4-e47fec822071">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0008069, locale);
	btnFind.translateBubbleHelp(Xlat_0000822, locale);
	btnFind.translateCaption(Xlat_0000823, locale);
	mnuContext.translateCaption(Xlat_0008070, locale);
	mnuCopy.translateCaption(Xlat_0016187, locale);
	mnuFind.translateCaption(Xlat_0008071, locale);
end;</source>
    </JadeMethod>
    <JadeMethod name="txtData_contextMenu" id="0239b4d3-a403-4fef-8c9a-ca2ef1413365">
        <controlMethod name="JadeRichText::contextMenu"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>txtData_contextMenu(textbox: JadeRichText input; conwin: Window input; mouse: Boolean; x: Integer; y: Integer):Boolean updating;
// ---------------------------------------------------------------------------
// Created:     06 March 2006 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	x1, y1		: Real;

begin
	x1 := x;
	y1 := y;
	
	if (not mouse) then  // if keyboard
	    x1 := 20;
	    y1 := 20;
	endif;

	conwin.windowToScreen(x1, y1);
	self.screenToWindow(x1, y1);   // convert x, y relative to form
	
	self.popupMenu(self.mnuContext, x1.Integer, y1.Integer);
	return false;
end;</source>
        <Parameter name="textbox" type="JadeRichText" usage="input"/>
        <Parameter name="conwin" type="Window" usage="input"/>
        <Parameter name="mouse" type="Boolean"/>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</GUIClass>
