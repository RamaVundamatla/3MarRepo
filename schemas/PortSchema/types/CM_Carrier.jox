    <JadeMethod name="canCarrierAccessForOperator" id="01e6d802-688f-49c6-84d3-d3c0fc7df399">
        <source>canCarrierAccessForOperator(_operator: CM_Operator; _failedDAC: CM_DataAccessController output; _checkRelease: Boolean): Boolean;

/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 September 2017	jlgmp6	Initial creation	TFS2749

*/

vars
	dac: CM_DataAccessController;
	tmpOperator: CM_Operator;
 
begin
	if _checkRelease  then
		dac := self.allDataAccessControllersRel[CM_Operator.name];
	else
		dac := self.allDataAccessControllersRec[CM_Operator.name];
	endif;
 
	if dac = null then
		return true;
	endif;
 
	if _operator = null and (not dac.includeIfNull) then
		_failedDAC := dac;
		return false;
	elseif (not dac.canAccess(_operator)) then
		_failedDAC := dac;
		return false;
	endif;
 
	return true;
end;
</source>
        <Parameter name="_operator" type="CM_Operator"/>
        <Parameter name="_failedDAC" type="CM_DataAccessController" usage="output"/>
        <Parameter name="_checkRelease" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
