    <JadeMethod name="enableDisablePostConf" id="6758fe71-5309-403a-9613-d12aab33c832">
        <source>enableDisablePostConf();
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
27 June 2023	navcs2	ChangeRequest 58433: [58454]: EUP | TAS Invoicing - Invoice Posting Confirmation Message
// ### TFS BUG 63257 28MAR2024 NAVAB1

*/

vars

begin
	//if self.myCurrentInvoice &lt;&gt; null and not self.myCurrentInvoice.isWebInvoice then
	if self.myCurrentInvoice &lt;&gt; null then
		if self.myCurrentInvoice.isTASInvoice() then
			self.mnuInvoicePostConf.visible := true; // ### TFS CR 58085 TASK 61346 08JAN2024 NAVAB1
			self.mnuInvoicePostConf.enabled := true;
			// ### TFS BUG 63257 28MAR2024 NAVAB1 self.mnuInvoicePostConf.caption := "Post Invoice Confirmation";
		else
			self.mnuInvoicePostConf.visible := false;// ### TFS CR 58085 TASK 61346 08JAN2024 NAVAB1
		endif;
	endif;
epilog

end;</source>
