    <JadeMethod name="multiSelect" id="b8333096-4ba1-47f1-bd78-c59b8bdcaee0">
        <methodInvocation>mapping</methodInvocation>
        <updating/>
        <source>multiSelect(set: Boolean; _value: Integer io) mapping, updating;
// ---------------------------------------------------------------------------
// Created:     28 March 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	if set then
		self.multiSelect := _value;
		if self.myAvailableListBox &lt;&gt; null then
			self.myAvailableListBox.multiSelect := _value;
		endif;
		if self.mySelectedListBox &lt;&gt; null then
			self.mySelectedListBox.multiSelect := _value;
		endif;
	else
		_value := self.multiSelect;
	endif;

end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="paint" id="132bd7bf-a2e0-44a2-8229-15c8476c17b6">
        <updating/>
        <source>paint(groupbox: GroupBox input) updating;
// ---------------------------------------------------------------------------
// Created:     28 March 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	inheritMethod(groupbox);

	if isInPainter then
		if not self.isBuilt then
			self.isBuilt := true;
			self.buildSelf;
		endif;

	elseif not isBuilt then
		self.isBuilt := true;
		self.buildSelf;
	endif;

end;</source>
        <Parameter name="groupbox" type="GroupBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="readOnly" id="b4679e6a-1fbc-4929-80dc-2f571ea7d6d6">
        <methodInvocation>mapping</methodInvocation>
        <updating/>
        <source>readOnly(set: Boolean; _value: Boolean io) mapping, updating;
// ---------------------------------------------------------------------------
// Created:     02 April 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	if set then
		self.readOnly := _value;
		if self.myAddSelectedBtn &lt;&gt; null then
			self.myAddSelectedBtn.enabled := (not _value);
		endif;
		if self.myRemoveSelectedBtn &lt;&gt; null then
			self.myRemoveSelectedBtn.enabled := (not _value);
		endif;
		if self.myUpSelectedBtn &lt;&gt; null then
			self.myUpSelectedBtn.enabled := (not _value);
		endif;
		if self.myDownSelectedBtn &lt;&gt; null then
			self.myDownSelectedBtn.enabled := (not _value);
		endif;
		if self.myAddAllBtn &lt;&gt; null then
			self.myAddAllBtn.enabled := (not _value);
		endif;
		if self.myRemoveAllBtn &lt;&gt; null then
			self.myRemoveAllBtn.enabled := (not _value);
		endif;
		//cnwmc5 - 10/12/2012
		if self.myTopSelectedBtn &lt;&gt; null then
			self.myTopSelectedBtn.enabled := (not _value);
		endif;
		if self.myBottomSelectedBtn &lt;&gt; null then
			self.myBottomSelectedBtn.enabled := (not _value);
		endif;
	else
		_value := self.readOnly;
	endif;
	
end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="Boolean" usage="io"/>
    </JadeMethod>
    <JadeMethod name="refresh" id="ffc98b46-3f82-453e-ba1c-cff8b7e85bca">
        <updating/>
        <source>refresh() updating;
// ---------------------------------------------------------------------------
// Created:     28 March 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	inheritMethod();

	if not isInPainter then
		self.buildSelf();
	endif;

end;</source>
    </JadeMethod>
    <JadeMethod name="refreshListbox" id="46b7c803-9bdc-492a-8183-d8f40d8c0d53">
        <updating/>
        <source>refreshListbox( _listBox : ListBox input) updating;

/*

Purpose:	Refreshes the text for items in the listbox		

Parameters:			

Return Value:		


Date		Who		Reason
27 May 2010	cnwrd1	Initial creation

*/

vars
	i	: Integer;
	obj	: Object;
begin

	foreach i in 1 to self.mySelectedListBox.listCount do
		obj := self.mySelectedListBox.itemObject[i];
		self.mySelectedListBox.itemText[i] := self.displayEntry(obj);
	endforeach;

epilog

end;</source>
        <Parameter name="_listBox" type="ListBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="refreshOwnListboxes" id="6de30d20-9477-4f1d-859e-2170f9c978a3">
        <updating/>
        <source>refreshOwnListboxes() updating;
// force the re-creation of each list box text, which may in different sequence from before
//  done July 2010 cnwjre1 for 24019 Rate Table services by group or name
vars
	i	: Integer;
	obj	: Object;
	oa : ObjectArray;
begin
	create oa transient;
	foreach i in 1 to self.myAvailableListBox.listCount do
		obj := self.myAvailableListBox.itemObject[i];
		oa.tryAddIfNotNull(obj); // ### JIRA 35154 11JUL2025 NAVAB1
	endforeach;
	self.myAvailableListBox.clear();
	foreach obj in oa do
		self.addItem(self.myAvailableListBox, obj);
	endforeach;

	oa.clear;
	foreach i in 1 to self.mySelectedListBox.listCount do
		obj := self.mySelectedListBox.itemObject[i];
		oa.tryAddIfNotNull(obj); // ### JIRA 35154 11JUL2025 NAVAB1
	endforeach;
	self.mySelectedListBox.clear();
	foreach obj in oa do
		self.addItem(self.mySelectedListBox, obj);
	endforeach;
epilog
	delete oa;
end;</source>
    </JadeMethod>
    <JadeMethod name="removeItem" id="1a0a229a-746c-424a-b6db-42fc52b9802e">
        <updating/>
        <source>removeItem( pIdx : Integer; pObj : Object ) protected, updating;
// ---------------------------------------------------------------------------
// Created:     29 March 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 28/07/2010	cnwrl1		PAR 24415 - EDI Admin form does not handle deleted of EDI File Types.
// ---------------------------------------------------------------------------
vars
	isInvalid		: Boolean;
	ed				: Integer;
	idx				: Integer;
	origIdx			: Integer;
	coll			: Collection;
	itemBackColor : Integer;
begin
	on Exception do app.handleDeletedObject( exception, pObj, isInvalid );	// cnwrl1 28/07/2010 PAR 24415
	
	if pIdx &gt; 0 and pObj &lt;&gt; null then
		// cnwrl1 28/07/2010 PAR 24415 - start of coding
		// Check that the object is still valid do this by assumming
		// it is valid and using an exception handler if it is not.
		isInvalid	:= false;
		ed			:= pObj.edition();		// if invalid will trigger the armed exceptionHandler
		if isInvalid then
			return;
		endif;
		// cnwrl1 28/07/2010 PAR 24415 - end of coding
		// remove from the selected list box
		//jlier1 TFS 53515 2/6/22
		itemBackColor:=self.mySelectedListBox.itemBackColor[pIdx];
		self.mySelectedListBox.removeItem(pIdx);
		//epr par 19579 1/5/09 changed from .class.implementsInterface to .respondsTo
		if self.myBaseForm &lt;&gt; null and  self.myBaseForm.respondsTo(IF_CMUI_MultiSelectGroupBox) and self.myBaseForm.IF_CMUI_MultiSelectGroupBox.getOriginalCollection &lt;&gt; null  then
			coll :=self.myBaseForm.IF_CMUI_MultiSelectGroupBox.getOriginalCollection;
			origIdx:=coll.indexOf(pObj);
			idx:=origIdx-pIdx + 1;
			self.myAvailableListBox.addItemAt(self.displayEntry(pObj),idx);
			
		else
			// add into the available list box
			idx := self.myAvailableListBox.addItem(self.displayEntry(pObj));
			if itemBackColor &gt; 0 then
				self.myAvailableListBox.itemBackColor[idx]:=itemBackColor;
			endif;
		endif;
		self.myAvailableListBox.itemObject[idx] := pObj;
	endif;
	
epilog
	
end;
</source>
        <access>protected</access>
        <Parameter name="pIdx" type="Integer"/>
        <Parameter name="pObj" type="Object"/>
    </JadeMethod>
    <JadeMethod name="repositionAfterResize" id="61e882d4-a18e-418c-90ee-efe199590903">
        <updating/>
        <source>repositionAfterResize() updating;
// ---------------------------------------------------------------------------
// Created:     28 March 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
   	newLeft, newTop, newWidth, newHeight	: Real;
   	parentWidth,
   	parentHeight	: Real;

begin



	inheritMethod();

	if self.parent.isKindOf(Form) then
		parentWidth  := self.parent.Form.clientWidth;
		parentHeight := self.parent.Form.clientHeight;
	elseif self.parent.isKindOf(Control) then
		parentWidth  := self.parent.Control.clientWidth;
		parentHeight := self.parent.Control.clientHeight;
	else
		parentWidth  := self.parent.width;
		parentHeight := self.parent.height;
	endif;



	newLeft 	:= self.left;
	newTop 		:= self.top;
	newWidth 	:= self.width;
	newHeight 	:= self.height;

	if lockRight then
		newLeft := (parentWidth - newWidth - self.distanceFromRight).max(0);
	endif;
	if lockBottom then
		newTop := (parentHeight - newHeight - self.distanceFromBottom).max(0);
	endif;
	if stretchWidth then
		newWidth := (parentWidth - newLeft - self.distanceFromRight).max(0);
	endif;
	if stretchHeight then
		newHeight := (parentHeight - newTop - self.distanceFromBottom).max(0);
	endif;

	if newLeft &lt;&gt; self.left or newTop &lt;&gt; self.top or newWidth &lt;&gt; self.width or newHeight &lt;&gt; self.height then

		self.move(newLeft, newTop, newWidth, newHeight);
	endif;

	// do this regardless as in some cases the control is
	// the correct size already, but sub-controls have
	// not been setup correctly.
	self.cnEcResizeContents();

end;</source>
    </JadeMethod>
    <JadeMethod name="resetAvailListBoxExHandler" id="6e056dcb-f755-431b-a683-2d7967ba3c18">
        <source>resetAvailListBoxExHandler(exObj : Exception) : Integer protected;
// ---------------------------------------------------------------------------
// Created:     29 March 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	if exObj.errorCode = 14011 then	// Invalid Property Array Index
		return Ex_Resume_Next;
	endif;
	
	return Ex_Pass_Back;

end;</source>
        <access>protected</access>
        <Parameter name="exObj" type="Exception"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
