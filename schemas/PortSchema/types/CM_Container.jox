    <JadeMethod name="canUserViewMyChildren" id="0ba3c86d-a85f-461e-85ed-9a26c204d97d">
        <source>canUserViewMyChildren(_user: CM_User; _passport: CM_Passport; checkOperator: Boolean; checkConsignor: Boolean; checkConsignee: Boolean; checkCarrier: Boolean; checkCarrierRelease: Boolean; _dacFailedOn: CM_DataAccessController output): Boolean;
/*

Purpose:	Check whether the user can access the packed children, if they can, then the user can access me as well	

Parameters:			

Return Value:		

Date		Who		Reason
22 May 2025	navsp1	Initial creation JIRA-34864 CUX | Data Access Groups for MAFIs and Trailers - Development

*/

vars
	locationController	: CM_LocationsController;
	trackedItem			: CM_TrackedItem;
begin
    foreach trackedItem in self.allChildren do
        if trackedItem.canUserViewMe(_user, _passport, checkOperator, checkConsignor, checkConsignee, checkCarrier, checkCarrierRelease, _dacFailedOn) then
            return true;
        endif;
    endforeach;
    return false;
epilog

end;</source>
        <Parameter name="_user" type="CM_User"/>
        <Parameter name="_passport" type="CM_Passport"/>
        <Parameter name="checkOperator" type="Boolean"/>
        <Parameter name="checkConsignor" type="Boolean"/>
        <Parameter name="checkConsignee" type="Boolean"/>
        <Parameter name="checkCarrier" type="Boolean"/>
        <Parameter name="checkCarrierRelease" type="Boolean"/>
        <Parameter name="_dacFailedOn" type="CM_DataAccessController" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="canWashDTExpire" id="1bffdc66-b4b4-46b8-9b8a-1cf23597197c">
        <source>canWashDTExpire() : Boolean;
// --------------------------------------------------------------------------------
// Created:		14 April 2010 by cnwjo3
//
// Purpose:		If a container is washed on tuesday.  Do we care that its now thursday?
//				from pars like 20761 and CCMS 1892 (par 23587) it seems we only care about
//				the wash DT if the container is an integral reefer.  Not if its a dry container.
//				This method is for par 23587
//
vars
	isoType : CM_ISOType;
begin
	isoType := self.getISOTypeObject();
	
	if isoType = null then
		return false;  //container has no ISO (for some reason).  We don't care about it being washed again
	endif;
	
	if (isoType.isReefer and isoType.isIntegral) then
		return true;  //its a reefer container.  its probably had meat in it.  wash time!
	else
		return false;
	endif;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
