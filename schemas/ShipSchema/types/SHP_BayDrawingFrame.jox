    <JadeMethod name="redrawSelf" id="030f4b1e-3869-4fd6-ae11-7ad3c6cff1a1">
        <updating/>
        <source>redrawSelf() updating;
// ---------------------------------------------------------------------------
// Created:     08 January 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	tmpBay		: CM_Bay;
	tmpDrawingController	: SHP_BayDrawingController;
begin

	tmpBay := self.myBay;
	tmpDrawingController := self.myBayDrawingController;
	
	self.allObjectsOnDeck.clear;
	self.allObjectsUnderDeck.clear;

	tmpDrawingController.setDefaultFont(self);

	self.drawCells(tmpBay.allCellsOnDeckByOrdinal, 
				self.leftSideMargin, 
				self.getOnDeckOffset(tmpBay, tmpDrawingController), 	//cnwmc5 - 25 Oct 2013 - PAR 32847
				self.allObjectsOnDeck, tmpDrawingController);

	self.drawCells(tmpBay.allCellsUnderDeckByOrdinal, 
				self.leftSideMargin, 
				self.getUnderDeckOffSet(tmpDrawingController) + 15, //04 Nov 2015	NDL	Par 36722
				self.allObjectsUnderDeck, tmpDrawingController);

end;</source>
    </JadeMethod>
    <JadeMethod name="selectBlockOfHatchLids" id="186d9c3b-0320-4701-8188-3bb1cff35072">
        <updating/>
        <source>selectBlockOfHatchLids(_thisHatch : CM_HatchLid; _startHatch : CM_HatchLid io; 
					_isAlt : Boolean) protected, updating;
// ---------------------------------------------------------------------------
// Created:     03 February 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	tmpObj	: Object;
	tmpController	: SHP_BayDrawingController;
begin

	tmpController := self.myBayDrawingController;

	if _startHatch = null then
		self.selectHatchLid(_thisHatch, _startHatch, _isAlt);
	else
		self.allTempObjects.clear();
		self.myBay.getHatchLidsBetween(_startHatch, _thisHatch, self.allTempObjects); 
		_startHatch := _thisHatch;
		
		foreach tmpObj in self.allTempObjects do
			if _isAlt then
				tmpController.selectObjectAlt(tmpObj, self, true);
			else
				tmpController.selectObject(tmpObj, self, true);
			endif;
		endforeach;
	endif;

end;</source>
        <access>protected</access>
        <Parameter name="_thisHatch" type="CM_HatchLid"/>
        <Parameter name="_startHatch" type="CM_HatchLid" usage="io"/>
        <Parameter name="_isAlt" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="selectBlockOfSlots" id="7a4f8d28-2ea4-4139-8fb1-8f26006ae824">
        <updating/>
        <source>selectBlockOfSlots(_thisObj : Object; _startObj : Object io; 
				_isAlt : Boolean) protected, updating;
// ---------------------------------------------------------------------------
// Created:     03 February 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	tmpObj	: Object;
	tmpController	: SHP_BayDrawingController;
begin

	if _thisObj = null then
		app.raiseCMException1(MethodWithNullParam, 'thisObj', null, null);
		return;
	endif;

	if _startObj = null then
		self.selectObject(_thisObj, _startObj, _isAlt);
	else
		if _thisObj.class &lt;&gt; _startObj.class then
			app.raiseUnexpectedProgramError(class.name, method.name, 'class of objects do no match ' &amp; _thisObj.String &amp; ' &lt;&gt; ' &amp; _startObj.String);
			return;
		endif;

		tmpController := self.myBayDrawingController;

		self.allTempObjects.clear();
		if _startObj.isKindOf(CM_SlotController) then
			self.myBay.getSlotControllersBetween(_startObj.CM_SlotController, _thisObj.CM_SlotController, 
												tmpController.includeUnavailableSlots, self.allTempObjects); 
		else
			self.myBay.getSlotDefnsBetween(_startObj.CM_SlotDefn, _thisObj.CM_SlotDefn, self.allTempObjects); 
		endif;
		_startObj := _thisObj;

		foreach tmpObj in self.allTempObjects do
			if _isAlt then
				tmpController.selectObjectAlt(tmpObj, self, true);
			else
				tmpController.selectObject(tmpObj, self, true);
			endif;
		endforeach;
	endif;

end;</source>
        <access>protected</access>
        <Parameter name="_thisObj" type="Object"/>
        <Parameter name="_startObj" type="Object" usage="io"/>
        <Parameter name="_isAlt" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="selectBlockOfSlotsFromXYs" id="0391a15d-ccb0-40cf-9f1b-9f72e5db733e">
        <updating/>
        <source>selectBlockOfSlotsFromXYs(_x1,_y1,_x2,_y2 : Integer) updating;
// ---------------------------------------------------------------------------
// Created:		29 July 2005  By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	objs : ObjectArray ;
	startObj, anObj : Object;
begin
	create objs transient;
	if _y1 &lt;= self.myBayDrawingController.yHatchPos then
		self.allObjectsOnDeck.findObjectsInDict(_x1,_y1,_x2,_y2, objs, CM_SlotController,true,false);
		
		
	else //if _y1 &lt;= self.myBayDrawingController.yUnderDeckPos then
		self.allObjectsUnderDeck.findObjectsInDict(_x1,_y1,_x2,_y2, objs, CM_SlotController,true,false);
	endif;
	
	if objs.isEmpty then
		return;
	endif;
	
	foreach anObj in objs do
		self.selectObject(anObj,startObj,false);	
	endforeach;
	
epilog
	delete objs;

end;</source>
        <Parameter name="_x1" type="Integer"/>
        <Parameter name="_y1" type="Integer"/>
        <Parameter name="_x2" type="Integer"/>
        <Parameter name="_y2" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="selectHatchLid" id="5a38459b-966c-4a52-b628-6fc0e3ff0b88">
        <updating/>
        <source>selectHatchLid(_obj : CM_HatchLid; _startObj : CM_HatchLid io; 
			_isAlt : Boolean) protected, updating;
// ---------------------------------------------------------------------------
// Created:     03 February 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin

	if _obj = null then
		return;
	endif;

	if _isAlt then
		self.myBayDrawingController.selectObjectAlt(_obj, self, true);
	else
		self.myBayDrawingController.selectObject(_obj, self, true);
	endif;
	
	_startObj := _obj;

end;</source>
        <access>protected</access>
        <Parameter name="_obj" type="CM_HatchLid"/>
        <Parameter name="_startObj" type="CM_HatchLid" usage="io"/>
        <Parameter name="_isAlt" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="selectObject" id="a52a0e71-7c8f-4303-a93f-f847848f8603">
        <updating/>
        <source>selectObject(_obj : Object; _startObj : Object io; 
			_isAlt : Boolean) protected, updating;
// ---------------------------------------------------------------------------
// Created:     03 February 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin

	if _obj = null then
		return;
	endif;

	if _isAlt then
		self.myBayDrawingController.selectObjectAlt(_obj, self, true);
	else
		self.myBayDrawingController.selectObject(_obj, self, true);
	endif;
	
	_startObj := _obj;

end;</source>
        <access>protected</access>
        <Parameter name="_obj" type="Object"/>
        <Parameter name="_startObj" type="Object" usage="io"/>
        <Parameter name="_isAlt" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setDrawingPositions" id="a862efa4-5a16-41c4-a1c9-a7f9e3376e2d">
        <updating/>
        <source>setDrawingPositions(_controller : SHP_BayDrawingController) updating;
// ---------------------------------------------------------------------------
// Created:     05 July 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	theColWidth,
	totCellWidth,
	theSideMargin	: Integer;
	tmpCell			: CM_CellDefn;

begin
	if self.myBay = null then
		return;
	endif;

	theColWidth	 	:= _controller.columnWidth;
	theSideMargin	:= _controller.sideDrawingMargin;
	totCellWidth := self.myBay.getStarboardMostDrawingPos(theColWidth);
	self.leftSideMargin := theSideMargin + ((self.clientWidth - theSideMargin - totCellWidth - theSideMargin) / 2).Integer;

	// handle the On-Deck values
	tmpCell := self.myLeftCellDefnOD;
	if tmpCell &lt;&gt; null then
		self.startPosOD := tmpCell.getDrawingPosX(theColWidth);
	else
		self.startPosOD := 0;
	endif;

	tmpCell := self.myRightCellDefnOD;
	if tmpCell &lt;&gt; null then
		self.endPosOD := tmpCell.getDrawingPosX(theColWidth) + theColWidth;
	else
		self.endPosOD := 0;
	endif;

	// handle the Under-Deck values
	tmpCell := self.myLeftCellDefnUD;
	if tmpCell &lt;&gt; null then
		self.startPosUD := tmpCell.getDrawingPosX(theColWidth);
	else
		self.startPosUD := 0;
	endif;

	tmpCell := self.myRightCellDefnUD;
	if tmpCell &lt;&gt; null then
		self.endPosUD := tmpCell.getDrawingPosX(theColWidth) + theColWidth;
	else
		self.endPosUD := 0;
	endif;

		// 	if people make a big left gap in The Bay Definition Vessel screen, Bay Layout
		//	this code divides this gap in two pieces and we will have centered picture in Actual Bay View screen  cnwvu1
	self.leftSideMargin := self.leftSideMargin - ( startPosOD.min(startPosUD) div 2);	// cnwvu1 15/09/2006

end;</source>
        <Parameter name="_controller" type="SHP_BayDrawingController"/>
    </JadeMethod>
    <JadeMethod name="setLeftRightCell" id="67a98ae2-42d2-4bdc-a68f-fd3a8b23ad7a">
        <updating/>
        <source>setLeftRightCell(_onDeck : Boolean; _rCellDefn : CM_CellDefn; _lCellDefn : CM_CellDefn) updating;
// ---------------------------------------------------------------------------
// Created:		July 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

begin
	if _onDeck then
		self.myLeftCellDefnOD := _lCellDefn;
		self.myRightCellDefnOD := _rCellDefn;
	else
		self.myLeftCellDefnUD := _lCellDefn;
		self.myRightCellDefnUD := _rCellDefn;
	endif;
end;</source>
        <Parameter name="_onDeck" type="Boolean"/>
        <Parameter name="_rCellDefn" type="CM_CellDefn"/>
        <Parameter name="_lCellDefn" type="CM_CellDefn"/>
    </JadeMethod>
    <JadeMethod name="windowCreated" id="4ec510a4-8c84-43c5-815f-36acc537e86e">
        <updating/>
        <source>windowCreated(cntrl: Control input; persistCntrl: Control) updating;
// ---------------------------------------------------------------------------
// Created:     28 January 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin

	cntrl.autoRedraw := true;

	inheritMethod(cntrl, persistCntrl);

	self.myHatchesIterator 			:= self.allHatches.createIterator;
	self.myObjectsOnDeckIterator 	:= self.allObjectsOnDeck.createIterator;
	self.myObjectsUnderDeckIterator	:= self.allObjectsUnderDeck.createIterator;

end;</source>
        <Parameter name="cntrl" type="Control" usage="input"/>
        <Parameter name="persistCntrl" type="Control"/>
    </JadeMethod>
    <DevControlTypes name="SHP_BayDrawingFrame">
        <bitmap></bitmap>
        <windowClass>AlFrame</windowClass>
        <DevControlProperties name="alignChildren">
            <cntrlType>list</cntrlType>
            <optionsList>
                <value>0 - None</value>
                <value>1 - Align Width</value>
                <value>2 - All</value>
            </optionsList>
        </DevControlProperties>
        <DevControlProperties name="alignContainer">
            <cntrlType>list</cntrlType>
            <optionsList>
                <value>0 - None</value>
                <value>1 - Align Top</value>
                <value>2 - Align Bottom</value>
                <value>3 - Align Width</value>
                <value>4 - Stretch to next control below</value>
