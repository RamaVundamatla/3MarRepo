    <JadeMethod name="lstTblIMEX_displayRow" id="25acd378-18dd-4fc2-b8ae-b13aefc94686">
        <controlMethod name="Table::displayRow"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>lstTblIMEX_displayRow(table: Table input; theSheet: Integer; obj: Object; theRow: Integer; bcontinue: Boolean io):String updating;
//----------------------------------------------------------------
//	Created:	12 October 2003	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	selected	: Boolean;
	desc		: String;
begin
	
	selected := table.CMUI_ListTable.allSelectedObjects.includes(obj);
	desc := obj.CM_IMEXStatus.description.trimBlanks;
	if desc = null then
		desc := "Unknown";
	endif;
	//process.debug;
	if selected then
		return TableCheckBox_Selected &amp; Tab &amp; desc;
	else
		return TableCheckBox_NotSelected &amp; Tab &amp; desc;
	endif;
	self.setTblParameterHeight();
end;</source>
