    <JadeMethod name="addGridAreaAndFrame" id="b54eb912-738e-4ffa-92f3-82d32ad2c9e9">
        <source>addGridAreaAndFrame(pGridArea : CMUI_GridArea input; pFrame : CMUI_GridAreaFrame input);
// ---------------------------------------------------------------------------
// Created:     30 January 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

	lScale : Real;
begin

	if self.scaleFactor &gt; 0 then
		lScale := self.scaleFactor;
	else
		lScale := 1.5;
	endif;

	self.allGridAreasByColumnRow.add(pGridArea);
	self.allGridAreasByRowColumn.add(pGridArea);

	if lScale &lt;&gt; pGridArea.scaleXFactor then
		pGridArea.setZoomFactorTo(lScale);
	endif;
	pGridArea.myGridAreaFrame	:= pFrame;
	pGridArea.myHLabelsFrame	:= self.myHLabels;
	pGridArea.myVLabelsFrame	:= self.myVLabels;

	pFrame.parent := self.myDrawingFrame;
	pFrame.autoRedraw := true;
	pFrame.visible := true;
	pFrame.boundaryColor := White;
	pFrame.bevelColor := White;
	pFrame.borderStyle := BorderStyle_None;
	pFrame.bevelInner := Frame.Bevel_None;
	pFrame.bevelInner := 0;
	pFrame.bevelOuter := 0;
	// Setup the row/col end position arrays
	if self.allRowEndPositions.size &lt; pGridArea.row then
		self.allRowEndPositions.atPut(pGridArea.row, 0);
	endif;
	if self.allColumnEndPositions.size &lt; pGridArea.column then
		self.allColumnEndPositions.atPut(pGridArea.column, 0);
	endif;

end;</source>
        <Parameter name="pGridArea" type="CMUI_GridArea" usage="input"/>
        <Parameter name="pFrame" type="CMUI_GridAreaFrame" usage="input"/>
    </JadeMethod>
    <JadeMethod name="changeBackColor" id="95a2b039-f8f6-4d67-b7a4-a14d49ecc50a">
        <updating/>
        <source>changeBackColor(_newColor : Integer) updating;
// ---------------------------------------------------------------------------
// Created:		October 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

begin
	if self.allGridAreasByRowColumn.isEmpty then	
		return;
	endif;
	
	self.allGridAreasByRowColumn.first.myGridAreaFrame.backColor := _newColor;
	self.myHLabels.backColor := _newColor;
	self.myVLabels.backColor := _newColor;
	self.myTopLeftFillerFrame.backColor := _newColor;
	self.backColor := _newColor;
	self.myDrawingFrame.backColor := _newColor;
end;</source>
        <Parameter name="_newColor" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="clearAll" id="d35f35e2-4b1e-4cb8-b349-810a9f8251e1">
        <source>clearAll();
//--------------------------------------------------------------
//Created: 21 March 2003 By: cnwgd1
//--------------------------------------------------------------
vars
	gridArea : CMUI_GridArea;

begin
	self.allGridAreasByRowColumn.purge;
	self.allGridAreasByColumnRow.purge;
	self.allRowEndPositions.clear;
	self.allColumnEndPositions.clear;
	self.myDrawingAttrController.clear();

end;</source>
    </JadeMethod>
    <JadeMethod name="clearAllSelectedPoints" id="ab074761-0b77-4f2f-8107-6656b944940b">
        <updating/>
        <source>clearAllSelectedPoints() updating;
// ---------------------------------------------------------------------------
// Created:		January 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

	gridArea	: CMUI_GridArea;
	aPoint : CMUI_GridPoint;
begin

	foreach gridArea in self.allGridAreasByRowColumn do

		if gridArea.allSelectedPoints.isEmpty then
			continue;
		endif;
		gridArea.clearAllSelectedItems();
/*		
		while true do
			if gridArea.allSelectedPoints.isEmpty then
				break;
			endif;
			aPoint := gridArea.allSelectedPoints.last;
			gridArea.allSelectedPoints.remove(aPoint);

			aPoint.drawSelf(gridArea.myGridAreaFrame);
		endwhile;	
*/
	endforeach;

	foreach gridArea in self.allGridAreasByRowColumn do
		if gridArea.allSelectedPointsAlt.isEmpty then
			continue;
		endif;
		
		while true do
			if gridArea.allSelectedPointsAlt.isEmpty then
				break;
			endif;
			aPoint := gridArea.allSelectedPointsAlt.last;
			gridArea.allSelectedPointsAlt.remove(aPoint);
			aPoint.drawSelf(gridArea.myGridAreaFrame);
			
		endwhile;	
	endforeach;

end;</source>
    </JadeMethod>
    <JadeMethod name="clearUpDragDrop" id="19f3c7e2-bc4a-4062-80aa-42b5b46086c0">
        <source>clearUpDragDrop();
// ---------------------------------------------------------------------------
// Created:		July 2003 By Andrew Bishop cnwab1
//
// Purpose:		
// ---------------------------------------------------------------------------
vars
	theGrid : CMUI_GridArea;
begin
	if not self.allGridAreasByRowColumn.isEmpty then
		foreach theGrid in self.allGridAreasByRowColumn do
			theGrid.myGridAreaFrame.dragMode := DragMode_None;
			theGrid.myGridAreaFrame.enableEvent("mouseMove",false);
		endforeach;
	endif;

end;</source>
    </JadeMethod>
    <JadeMethod name="click" id="9c7a783c-81d1-45e1-b26b-16c1e091d457">
        <updating/>
        <source>click(frame: Frame input) updating;
// ---------------------------------------------------------------------------
// Created:		August 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
begin
	inheritMethod(frame);
	
	if self.myParentForm = null then
		return;
	endif;
	
	if not self.myParentForm.isKindOf(CMUI_GridAreaForm) then
		return;
	endif;
	
	self.myParentForm.CMUI_GridAreaForm.setMyCurrentSDF(self,true);
	self.myParentForm.CMUI_GridAreaForm.doBuildMnuZoom(self.myParentForm.CMUI_GridAreaForm.mnuZoomSub);
end;</source>
        <Parameter name="frame" type="Frame" usage="input"/>
    </JadeMethod>
    <JadeMethod name="cnEcResizeContents" id="127a67e2-80b7-4a84-a169-344ca2380c33">
        <updating/>
        <source>cnEcResizeContents() updating;
// ---------------------------------------------------------------------------
// Created:     29 January 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
begin
	inheritMethod();

	if self.myHLabels &lt;&gt; null then
		self.myHLabels.repositionAfterResize();
	endif;
	
	if self.myVLabels &lt;&gt; null then
		self.myVLabels.repositionAfterResize();
	endif;
	
	if self.myHScroll &lt;&gt; null then
		self.myHScroll.repositionAfterResize();
	endif;
	
	if self.myVScroll &lt;&gt; null then
		self.myVScroll.repositionAfterResize();
	endif;
	
	if self.myBottomRightFillerFrame &lt;&gt; null then
		self.myBottomRightFillerFrame.repositionAfterResize();
	endif;
	
	if self.myTopLeftFillerFrame &lt;&gt; null then
		self.myTopLeftFillerFrame.repositionAfterResize();
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="contextMenu" id="77e77c25-b70f-4a3e-9a46-f05632f2ed6f">
        <updating/>
        <source>contextMenu(cntrl: Frame input; conwin: Window input; mouse: Boolean; x: Integer; y: Integer): Boolean updating;
// ---------------------------------------------------------------------------
// Created:		June 2003 By Andrew Bishop cnwab1
//
// Purpose:		
// ---------------------------------------------------------------------------
vars
	tmpX, tmpY : Integer;
begin
	tmpX := x;
	tmpY := y;
	// sgp 7 July 2003 : The windowToScreen, screenToWindow methods in the 
	// called showContectMenu method get the correct position so subtracting
	// the scroll height/width here is incorrect.
/*	if self.myHScroll &lt;&gt; null then
		tmpX := tmpX - self.myHScroll.value;
	endif;
	if self.myVScroll &lt;&gt; null then
		tmpY := tmpY - self.myVScroll.value;
	endif;
*/
/*	if self.myParentForm.isKindOf(CMUI_GridAreaForm) then
		return self.myParentForm.CMUI_GridAreaForm.doMnuContext(cntrl,conwin,mouse, tmpX, tmpY);
	elseif self.myParentForm.isKindOf(CMUI_OpsForm) then
		return self.myParentForm.CMUI_OpsForm.doMnuContext(cntrl,conwin,mouse, tmpX, tmpY);
	elseif self.myParentForm.name = "SOP_TableMaintForm" then
		self.myParentForm.sendMsgWithParams("contextMenuSDF",cntrl, conwin, mouse, tmpX, tmpY);
	elseif self.myParentForm.isKindOf(CMUI_YardOverView) then // do nothing
//		app.writeStatement( "AKB " &amp; self.class.name &amp; "::" &amp; method.name &amp; " 1. YARD OVER VIEW ");
	elseif self.myParentForm.name = "YRD_WagonForm" then
		self.myParentForm.sendMsgWithParams("doMnuContext",cntrl, conwin, mouse, tmpX, tmpY);
*/			
	// sgp 29 July 2003 : all parent forms are a subclass of CM_BaseForm and have doMnuContext
	// reimplemented so only one call required

	if self.myParentForm = null then
		return true;
	endif;

	if self.myParentForm.isKindOf(CM_BaseForm) then
		if self.myParentForm.isKindOf(CMUI_GridAreaForm) then
			self.myParentForm.CMUI_GridAreaForm.setMyCurrentSDF(self,true);
			self.myParentForm.CMUI_GridAreaForm.doBuildMnuZoom(self.myParentForm.CMUI_GridAreaForm.mnuZoomSub);
		endif;

		return self.myParentForm.CM_BaseForm.doMnuContext(cntrl,conwin,mouse, tmpX, tmpY);
	else
		app.writeStatement(self.class.name &amp; "::" &amp; method.name &amp; " Unknown Parent Form - " &amp; self.myParentForm.String &amp; "  name " &amp; self.myParentForm.name);
	endif;
end;</source>
        <Parameter name="cntrl" type="Frame" usage="input"/>
        <Parameter name="conwin" type="Window" usage="input"/>
        <Parameter name="mouse" type="Boolean"/>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="create" id="2d7ba0a5-8b74-4e0a-9dc0-4be72742a0cf">
        <updating/>
        <source>create() updating;
// ---------------------------------------------------------------------------
// Created:     29 January 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
begin
	self.scrollBars	:=	Window.ScrollBars_Both;
	self.labels		:=	Window.ScrollBars_Both;
	self.ignoreSkin := true;
	

end;</source>
    </JadeMethod>
    <JadeMethod name="createDrawingFrame" id="18e5d393-3745-4101-953b-ab8fd42e8021">
        <updating/>
        <source>createDrawingFrame() updating, protected;
// ---------------------------------------------------------------------------
// Created:     29 January 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
begin
	if self.caption = "PointDrawing" then
		create self.myDrawingFrame as CMUI_PointDrawingFrame transient;
	else
		create self.myDrawingFrame transient;
	endif;
	
	self.myDrawingFrame.parent 	:= self;
   	self.myDrawingFrame.move(self.myVLabels.width + 1, self.myHLabels.height + 1, self.width - self.myVScroll.width - self.myVLabels.width, self.height - self.myHScroll.height - self.myHLabels.height);
	self.myDrawingFrame.parentAspect := self.parentAspect;
	
	self.myDrawingFrame.visible := true;
	self.myDrawingFrame.autoRedraw := true;
	self.setFrameDefaults(self.myDrawingFrame);
	self.form.addControl(self.myDrawingFrame);
	self.myDrawingFrame.zOrder(0);		// send to the back
	self.myDrawingFrame.borderStyle := Window.BorderStyle_None;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="createFillerFrames" id="5feb4272-2681-4e84-a2d3-d4d95f8888f3">
        <updating/>
        <source>createFillerFrames() updating, protected;
// ---------------------------------------------------------------------------
// Created:     29 January 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
begin
	create self.myBottomRightFillerFrame transient;
	self.myBottomRightFillerFrame.parent := self;
	self.myBottomRightFillerFrame.lockBottom := true;
	self.myBottomRightFillerFrame.lockRight	 := true;
	self.myBottomRightFillerFrame.distanceFromBottom := 0;
	self.myBottomRightFillerFrame.distanceFromRight := 0;
	self.myBottomRightFillerFrame.height := ScrollBarWidth;
	self.myBottomRightFillerFrame.width := ScrollBarWidth;
	self.setFrameDefaults(self.myBottomRightFillerFrame);
	self.myBottomRightFillerFrame.visible := false;
	self.form.addControl(self.myBottomRightFillerFrame);
	self.myBottomRightFillerFrame.zOrder(1);		// send to the front
	self.myBottomRightFillerFrame.borderStyle := BorderStyle_None;

	// Top Left Frame
	create self.myTopLeftFillerFrame transient;
	self.myTopLeftFillerFrame.parent := self;
	self.myTopLeftFillerFrame.visible := false;
	self.setFrameDefaults(self.myTopLeftFillerFrame);
	self.form.addControl(self.myTopLeftFillerFrame);
	self.myTopLeftFillerFrame.zOrder(1);		// send to the front
	self.myTopLeftFillerFrame.borderStyle := BorderStyle_None;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="createHScroll" id="044e94c2-6f68-44a9-9df8-657e9b1d2bf6">
        <updating/>
        <source>createHScroll() updating, protected;
// ---------------------------------------------------------------------------
// Created:     29 January 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
begin
	create self.myHScroll transient;
	self.myHScroll.parent 	:= self;
   	self.myHScroll.min		:= 1;
	self.myHScroll.max		:= 100;
   	self.myHScroll.smallChange	:= 5;
   	self.myHScroll.largeChange 	:= 20;
	self.myHScroll.visible 	:= true;
	self.myHScroll.tabStop := false;
//	self.myHScroll.lockBottom := true;
//	self.myHScroll.lockRight := true;
//	self.myHScroll.stretchWidth := true;

	self.form.addControl(self.myHScroll);
	self.positionHScrollBar();
	self.myHScroll.zOrder(1);		// bring to the front
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="createLabelFrames" id="5a830824-c607-4c3d-b4e2-6d34aaa90b6d">
        <updating/>
        <source>createLabelFrames() updating, protected;
// ---------------------------------------------------------------------------
// Created:     29 January 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
begin
	create self.myHLabels transient;
	self.myHLabels.parent := self;
	self.form.addControl(self.myHLabels);
	self.setFrameDefaults(self.myHLabels);
   	self.myHLabels.move(0, 0, self.clientWidth, 16);
	self.myHLabels.zOrder(1);		// send to the front
	self.myHLabels.caption := null;
	self.myHLabels.borderStyle		:= BorderStyle_None;


	// Top Left Frame
	create self.myVLabels transient;
	self.myVLabels.parent := self;
	self.form.addControl(self.myVLabels);
	self.setFrameDefaults(self.myVLabels);
   	self.myVLabels.move(0, 0, 16, self.clientHeight);
	self.myVLabels.zOrder(1);		// send to the front
	self.myVLabels.caption := null;
	self.myVLabels.borderStyle		:= BorderStyle_None;

	// Call this to set show/hide
	self.labels := self.labels;
end;</source>
        <access>protected</access>
    </JadeMethod>
