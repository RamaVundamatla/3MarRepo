<Class name="CM_UserInternal">
    <JadeMethod name="importPLXMLCollections" id="0ee1b04f-f91d-4e8f-a6bf-b8eb77676577">
        <source>importPLXMLCollections(_name: String; _collectionsBlock: String);

vars

begin
	inheritMethod(_name, _collectionsBlock);
end;
</source>
        <Parameter name="_name" type="String"/>
        <Parameter name="_collectionsBlock" type="String"/>
    </JadeMethod>
    <JadeMethod name="importPLXMLReference" id="029ed7b9-06d6-4fff-81ef-bb1b84cd979b">
        <source>importPLXMLReference(_name, _theCode, _referencesBlock: String): Object;

vars

begin
	if _name = CM_User::myRoot.name then
		return app.myRoot;
	elseif _name = CM_User::myOrganisation.name then
		return app.myRoot.allOrganisations[_theCode];
	else
		return null;
	endif;
end;</source>
        <Parameter name="_name" type="String"/>
        <Parameter name="_theCode" type="String"/>
        <Parameter name="_referencesBlock" type="String"/>
        <ReturnType type="Object"/>
    </JadeMethod>
</Class>
