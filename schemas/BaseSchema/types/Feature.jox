<Class name="Feature">
    <JadeMethod name="cnEcGetAccessType" id="2e577643-2290-4b9d-bf85-337a310b954e">
        <source>cnEcGetAccessType():String;
// --------------------------------------------------------------------------------
// Created:		07 April 2005 by cnwdad1
//
// Purpose:		Returns a description of the type of access to the receiver.
//
// Parameters:	None
//
// Returns:		A description of the receiver's type of access.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	accessType	: Character;
	
begin
	accessType	:=	self.access;
	
	if accessType = 0.Character then
		return "Public";
	elseif accessType = 1.Character then
		return "Read only";
	elseif accessType = 2.Character then
		return "Protected" ;
	endif;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="cnEcIsProperty" id="ddcd907c-f051-4e90-b175-d18be7218cf2">
        <source>cnEcIsProperty():Boolean;
// -----------------------------------------------------------------------------
// Created:		01 November 2001 by cnwdad1
//
// Purpose:		Returns a flag to indicate whether the receiver is a Property.
//
// Parameters:	None
//
// Returns:		True if the receiver is a Property, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//
// -----------------------------------------------------------------------------
begin
	return false;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
