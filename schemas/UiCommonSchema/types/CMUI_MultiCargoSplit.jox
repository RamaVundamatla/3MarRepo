        <source>setSelectedLine();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 June 2020	jlgndl1	Initial creation	TFS 49401

*/

vars

	size : Integer;
	row : Integer;
	rowIndex : Integer;
	voyage : CM_Voyage;
	weightVolumeString : String;
	qty : Integer;

begin

	size := self.tblSplits.rows;
	
	if size = 1 then
		return;
	endif;

	foreach row in 1 to size do
		if self.tblSplits.accessRow( row ).selected then
			rowIndex := row;
			break;
		endif;
	endforeach;

	if rowIndex &lt; self.tblSplits.fixedRows then
		return;
	endif;
	
	voyage := self.cmbVoyage.listObject.CM_Voyage;
	self.tblSplits.accessCell( row, 1 ).itemObject := voyage;
	if voyage &lt;&gt; null then
		self.tblSplits.accessCell( row, 1 ).text := voyage.code &amp; " / " &amp; voyage.myVessel.name;
	else
		self.tblSplits.accessCell( row, 1 ).text := null;
	endif;
	
	if self.txtTotQuantity.visible then
		if self.txtTotQuantity.text.Integer &lt; 1 then
			self.tblSplits.accessCell( row, 2 ).text := null;
		else
			self.tblSplits.accessCell( row, 2 ).text := self.txtTotQuantity.text;
		endif;
	else
		self.tblSplits.accessCell( row, 2 ).text := self.tblTotalWeight.getRawValue &amp; " " &amp; self.tblTotalWeight.getUnit;
	endif;
	
	self.tblSplits.accessCell( row, 3 ).text := self.txtNewCargoId.text.trimBlanks;
	
	self.enableButtons();

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setupForm" id="444b1c09-05fd-4519-9059-223bee7c33bc">
