    </JadeMethod>
    <JadeMethod name="getSnapshotCargo" id="444f53f7-e471-4fea-b6ca-d0aa52c10385">
        <source>getSnapshotCargo(_snapshotData : CM_SnapshotData; _onsiteCargo : CM_TIArray input) protected;

/*

Purpose:			Get all of the cargo that was onsite at the time this snapshot summary was run

Parameters:			

Return Value:		


Date		Who		Reason
15 February 2013	cnwjre1	Initial creation

*/

vars
	data	: CM_DynamicObject_Snapshot;
	ti		: CM_TrackedItem;
	obj		: Object;
	coll	: CM_ObjectSet;
begin
	create coll transient;
	foreach data in _snapshotData.allSnapshotData do
		foreach obj in data.allObjects do
			coll.addNoDuplicates (obj, false); 
		endforeach;
	endforeach;
	
	_onsiteCargo.clear();
	foreach obj in coll do
		if obj.isKindOf(CM_TrackedItem) then
			_onsiteCargo.add(obj.CM_TrackedItem);
		endif;
	endforeach;
epilog
	delete coll;
end;</source>
        <access>protected</access>
        <Parameter name="_snapshotData" type="CM_SnapshotData"/>
        <Parameter name="_onsiteCargo" type="CM_TIArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="updateOnsiteCargo" id="51819346-cecd-43a5-8cd4-d39cf77df895">
        <source>updateOnsiteCargo(_runTime : TimeStamp; _onsiteCargo : CM_TIArray input; _releases : CM_TIArray; _received : CM_TIArray) protected;

/*

Purpose:			update the onsite cargo list from the releases and receipts for the day

Parameters:			

Return Value:		


Date		Who		Reason
15 February 2013	cnwjre1	Initial creation

*/

vars
	ts		: TimeStamp;
	ti		: CM_TrackedItem;
	toRemove	: CM_TIArray;

begin
	foreach ti in _releases do
		if not _onsiteCargo.includes(ti) then
			_onsiteCargo.add(ti);
		endif;
	endforeach;
	foreach ti in _received do
		if _onsiteCargo.includes(ti) then
			_onsiteCargo.remove(ti);
		endif;
	endforeach;
	// check for the date going before the cargo item create date
	create toRemove transient;
	foreach ti in _onsiteCargo do
		ts := ti.getFirstDateTime();
		if ts &gt; _runTime then
			toRemove.add(ti);
		endif;
	endforeach;
	if toRemove.size = _onsiteCargo.size then
		_onsiteCargo.clear();
	else
		foreach ti in toRemove do
			_onsiteCargo.remove(ti);
		endforeach;
	endif;
epilog
	delete toRemove;
end;</source>
        <access>protected</access>
        <Parameter name="_runTime" type="TimeStamp"/>
        <Parameter name="_onsiteCargo" type="CM_TIArray" usage="input"/>
        <Parameter name="_releases" type="CM_TIArray"/>
        <Parameter name="_received" type="CM_TIArray"/>
    </JadeMethod>
</Class>
