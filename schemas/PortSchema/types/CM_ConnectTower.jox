    <JadeMethod name="listFlags" id="e1aa59b1-5220-49cf-b3a4-598a2204612e">
        <source>listFlags(): String;
// ---------------------------------------------------------------------------
// Created:     Oct 2004 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	str: String;
begin
	str := str&amp;inheritMethod();
	if self.secondary then
		str := str&amp;"/Secondary ";
	endif; 
	return str;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="saveVersionCopyRefs" id="126e7ee4-7690-4fe3-ab7d-8eebc295e039">
        <source>saveVersionCopyRefs(toClone: CM_ConnectTower input) protected;
/*
 ------------------------------------------------------------------------
Created:			13 September 2002 by cnwdwq1
Purpose:			
Parameters:		None
Returns:			Nothing
Changed On		Changed By		Reason
--------------		--------------		-----------------------------------------
---------------------------------------------------------------------------
*/
vars

begin
	inheritMethod(toClone);
	toClone.otherTrackedItem := self.otherTrackedItem;
	
end;</source>
        <access>protected</access>
        <Parameter name="toClone" type="CM_ConnectTower" usage="input"/>
    </JadeMethod>
    <JadeMethod name="secondary" id="61f42583-fd23-4ecd-900b-af70cce90ca9">
        <methodInvocation>mapping</methodInvocation>
        <updating/>
        <source>secondary(set: Boolean; _value: Boolean io) mapping, updating;
/*
 ------------------------------------------------------------------------
Created:			05 April 2002 by cnwdwq1
Purpose:			
Parameters:		None
Returns:			Nothing
Changed On		Changed By		Reason
--------------		--------------		-----------------------------------------
---------------------------------------------------------------------------
*/
begin
	if set then
		if _value then
			flags := flags.bitOr(SecondaryFlag);
		else
			flags := flags.getValueWithBitUnset(SecondaryFlag);
		endif;
	else
		_value := (flags.bitAnd(SecondaryFlag) &lt;&gt; 0);
	endif;
end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="Boolean" usage="io"/>
    </JadeMethod>
    <JadeMethod name="setOtherTrackedItem" id="6e38b549-f2c2-4290-9747-edd39048f195">
        <updating/>
        <source>setOtherTrackedItem(pTI : CM_TrackedItem) updating;
// ---------------------------------------------------------------------------
// Created:     13 September 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	self.otherTrackedItem		:= pTI;
	self.otherTrackedItemId		:= pTI.id;
	self.otherTrackedItemCargoType	:= pTI.cargoType;
	
end;</source>
        <Parameter name="pTI" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="updateTI" id="198eff4c-77c0-4ed0-9c10-350d0ee52307">
        <updating/>
        <source>updateTI(_passport : CM_Passport input) updating;
//
// 10/12/2009	cnwdap1		CCMS MES 1007 Any TI can now be a reefer
// 11/03/2010	cnwdap1		PAR #22938 Correct reefer checking
//
vars

begin
	inheritMethod(_passport);
	if self.myTrackedItem = null then
		return;
	endif;
	
	//if not self.myTrackedItem.isKindOf(CM_Container) then		// CCMS 1007
	if self.myTrackedItem.isKindOf(CM_Container) or (self.myTrackedItem.isReefer) then	// PAR #22938
	else
		return;
	endif;
	
	//self.myTrackedItem.CM_Container.updateConnection;		// CCMS 1007
	self.myTrackedItem.updateConnection(self);					// CCMS 1007 //cnwrs1 10 May 2010 par 23815
end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
</Class>
