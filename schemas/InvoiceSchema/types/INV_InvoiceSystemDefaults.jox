    <JadeMethod name="getObjectFromClass" id="3bbf64b3-6044-44c3-a7b6-3233756de9b5">
        <source>getObjectFromClass(_ioClass : Class) : CM_ExtFinanceIO;
// ---------------------------------------------------------------------------
// Created:     25 July 2008 by cnwab1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	ioClass : CM_ExtFinanceIO;
	clsCol : ClassColl;
	cls : Class;
	aFIO : CM_ExtFinanceIO;
	str : String;
begin
	if _ioClass &lt;&gt; null then
		foreach ioClass in app.myRoot.myRootCompany.ioClasses do
			if ioClass.class = _ioClass then
				return ioClass;
			endif;
		endforeach;
	endif;

	cls := _ioClass;
	if cls = null then
		cls := CM_DefaultFinanceIO;
	endif;	
	aFIO := cls.firstInstance().CM_ExtFinanceIO;
	if aFIO = null then
		aFIO := app.myTrxCA.trxCreateExternalFinanceClass(_ioClass);
/* PAR 31601
		beginTransaction;
		create aFIO as cls persistent;
		aFIO.initialise(app.myRoot.myRootCompany, cls.getNiceName());
		app.cmsCommitTransaction(app.myPassport);
		*/
	endif;
	
	return aFIO;

epilog

end;</source>
        <Parameter name="_ioClass" type="Class"/>
        <ReturnType type="CM_ExtFinanceIO"/>
    </JadeMethod>
    <JadeMethod name="initTblDataEntry" id="b2e5aed2-b2b4-4821-8773-bac7095ca2f7">
        <source>initTblDataEntry();
// ---------------------------------------------------------------------------
// Created:		May 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

	entTableDef		: EntTableDef;
	theRow			: Integer;
	theTable		: CM_EntryTable;
	idx : Integer;
	
begin
	theTable := self.tblDataEntry;
	theTable.warningMethod := 'entTableWarning';
	
	theTable.stretchToParent := true;
	theTable.optimiseRowHeight := true;
		
//	entTableDef := app.myController.getEntTableDef(	ETDef_InvMaintSys);
	entTableDef := app.myController.getEntTableDef(	ETDef_TerminalFinancial); // PAR 33572

	theTable.setEntTableDef(entTableDef, null, 'entTableDefSetupWarning');
	theTable.changeMode := theTable.ChangeMode_FirstOnly;
	
	// PAR 33572
	idx := theTable.getRowByName(ETRow_ZTableBreak9);
	if idx &gt; 0 then
		theTable.accessCell(idx,1).fontBold := true;
	endif;
	
	idx := theTable.getRowByName(ETRow_ZTableBreak10);
	if idx &gt; 0 then
		theTable.accessCell(idx,1).fontBold := true;
	endif;
	
	idx := theTable.getRowByName(ETRow_ZTableBreak11);
	if idx &gt; 0 then
		theTable.accessCell(idx,1).fontBold := true;
	endif;
	
	idx := theTable.getRowByName(ETRow_ZTableBreak5);
	if idx &gt; 0 then
		theTable.accessCell(idx,1).fontBold := true;
	endif;
	
	
epilog
	
end;</source>
    </JadeMethod>
