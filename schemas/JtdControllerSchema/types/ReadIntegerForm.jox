<GUIClass name="ReadIntegerForm" id="6f48e7d5-5234-48c2-9a2d-3750cac6d0ea">
    <superclass name="Form"/>
    <transient/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>************************************************************************

