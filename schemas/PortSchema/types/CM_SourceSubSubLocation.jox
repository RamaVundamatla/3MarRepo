    <JadeMethod name="isCertified" id="4d8018d0-7b8a-46fe-b907-fcf840d2a84c">
        <source>isCertified() : Boolean;
/* ---------------------------------------------------------------------------
Created:	05 November 2009	by cnwvu1

Purpose:	
   
Change Date		Who		Reason

------------------------------------------------------------------------------*/
vars

begin
	
	if self.isFSC then
		return true;
	endif;

	return false;

end;</source>
