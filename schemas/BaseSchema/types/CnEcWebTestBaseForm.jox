    <JadeMethod name="menuDisplay" id="b7fff6c7-44fa-4851-918d-f3a28684a61a">
        <source>menuDisplay(pMessage:String; pClosed:Boolean) protected;
// --------------------------------------------------------------------------------
// Created:		12 January 2000 by cnwdad1
//
// Purpose:		Displays a message in the status bar when a menu item is selected.
//
// Parameters:	Message (String) - The message to display (ie. a description of the menu item).
//				Closed (Boolean) - Whether or not the menu item is closed.
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if (pClosed) then
		staStatusLine.caption	:=	" Ready.";
	else
		staStatusLine.caption	:=	" " &amp; pMessage;
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="pMessage" type="String"/>
        <Parameter name="pClosed" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="resize" id="c50132b9-16fb-4736-af1f-749aa5a60122">
