    <JadeMethod name="setupForm" id="15dddae7-8673-4787-9f26-8176bb562054">
        <updating/>
        <source>setupForm() updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 August 2015	cnwndl1	Initial creation

*/

vars

begin

	self.myHandHeldCheckerAgent := app.myHandHeldCheckerAgent;

	if app.isCargoGroupEnabled then	
		self.myCargoGroup := self.myMobileGenericAgent.myNextTiToAction.CM_CargoGroup;
	endif;
	self.myLocation := self.myMobileGenericAgent.myLocationsController;
	if self.myLocation &lt;&gt; null then
		self.lblLocation.caption := self.myLocation.getFullId();
	else
		self.lblLocation.caption := "Unknown";
	endif;
	
	inheritMethod();
	
	self.setupCmdButtons( 2, app.getErrorString(Save), app.getErrorString(Cancel), null, null, null );
	self.setupControls();

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setupTable" id="8d2c281f-8a9a-4018-8312-19a600f14563">
        <updating/>
        <source>setupTable() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 August 2015	cnwndl1	Initial creation

*/

vars

	array : CM_TIArray;
	ti : CM_TrackedItem;
	aplhaSorted : CM_TIByIdCargoTypeDict;

begin

	self.tblCargo.parentAspect:=Table.ParentAspect_StretchBoth;
	self.tblCargo.columns := 3;
	self.tblCargo.accessColumn(2).inputType := Table.InputType_CheckBox;
	self.tblCargo.accessColumn(2).alignment := Table.Alignment_Center_Top;
	self.tblCargo.accessColumn(3).inputType := Table.InputType_CheckBox;
	self.tblCargo.accessColumn(3).alignment := Table.Alignment_Center_Top;
	self.tblCargo.accessCell(1,1).text := app.getErrorString(CargoId);
	self.tblCargo.accessCell(1,2).text := app.getErrorString(DB_String);
	self.tblCargo.accessCell(1,3).text := app.getErrorString(Scan);
	self.tblCargo.accessRow(1).fontBold := true;
	self.tblCargo.accessColumn(2).enabled := false;
	self.tblCargo.accessColumn(3).enabled := false;
	
	create array transient;
	if self.myLocation &lt;&gt; null then
		self.myLocation.getTIs(array, REAL_MODE, true);
	endif;
	
	create aplhaSorted transient;
	array.copy(aplhaSorted);
	
	foreach ti in aplhaSorted do
		if self.myCargoGroup &lt;&gt; null then
			if ti.myCargoGroup &lt;&gt; self.myCargoGroup then
				continue;
			endif;
		endif;
		self.addUpdateCargoConfirmed( ti, true, false );
	endforeach;
	
	self.resetProgressCaptions();

epilog

	delete array;
	delete aplhaSorted;

end;</source>
    </JadeMethod>
    <JadeMethod name="translateForm" id="41be74f5-0523-46f7-b208-e5e3221db1d6">
        <updating/>
        <source>translateForm(locale : CM_Locale) updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 23 September 2015.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	
begin
	// Determine the locale for translations.
	inheritMethod(locale);
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0020784, locale);
	btnConfirm.translateCaption(Xlat_0020785, locale);
	lblCargoGrpId.translateCaption(Xlat_0020972, locale);
	lblCargoId.translateCaption(Xlat_0020786, locale);
	lblExtras.translateCaption(Xlat_0020787, locale);
	lblMissing.translateCaption(Xlat_0020788, locale);
	lblVerified.translateCaption(Xlat_0020789, locale);
end;</source>
        <Parameter name="locale" type="CM_Locale"/>
    </JadeMethod>
    <JadeMethod name="txtCargoId_gotFocus" id="8c427860-109f-43c6-a7e5-257e6450b788">
        <controlMethod name="TextBox::gotFocus"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>txtCargoId_gotFocus(textbox: TextBox input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 August 2015	cnwndl1	Initial creation	Par 36608

*/

vars

begin

	if self.txtCargoId.text = self.lblCargoId.caption.toUpper then
		self.txtCargoId.selStart := 0;
		self.txtCargoId.selLength := self.lblCargoId.caption.length;
	endif;


epilog

end;</source>
        <Parameter name="textbox" type="TextBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="txtCargoId_lostFocus" id="7dba9eeb-13f6-4f6c-af53-cdc6e86f2ef0">
        <controlMethod name="TextBox::lostFocus"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>txtCargoId_lostFocus(textbox: TextBox input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 August 2015	cnwndl1	Initial creation	Par 36608

*/

vars

begin

	app.convertScannedCargoId( self.myTerminal, textbox, false, null );	//06 Jul 2016	NDL	TFS 2275

	if self.txtCargoId.text.trimBlanks = null then
		self.txtCargoId.text := self.lblCargoId.caption.toUpper;
		self.setMyCargo(null);	
	else
		if ( self.myCargo &lt;&gt; null and self.myCargo.id &lt;&gt; self.txtCargoId.text )
		or ( self.myCargo = null and self.txtCargoId.text &lt;&gt; self.lblCargoId.caption.toUpper )	//01 Aug 2013	NDL	Par 32140
		then
			self.selectCargoItem( false );
		endif;
	endif;
	
	self.txtCargoId.selStart := 0;
	self.txtCargoId.selLength := 0;

epilog

end;</source>
        <Parameter name="textbox" type="TextBox" usage="input"/>
    </JadeMethod>
</GUIClass>
