<PrimType name="Integer">
    <JadeMethod name="asStringOrBlank" id="5ae53ea1-d678-481d-972d-2329707e9d92">
        <source>asStringOrBlank():String;
/*
	Purpose:		Output receiver as string only if it has a value.
					Used in reporting
	Parameters:			
	Return Value:	The receiver as a string - blank string if self = null	

Date			Who		Reason
05 August 2008	concms1	Initial creation
*/

vars

begin
	if self &lt;&gt; null then
		return self.asStringJMT;
	endif;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
</PrimType>
