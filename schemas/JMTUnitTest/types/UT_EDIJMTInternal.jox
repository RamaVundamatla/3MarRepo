    <JadeMethod name="tTransManifestGateDocInt" id="bff0a7cf-9a4a-4cb4-ab6d-6f6bbb9f7e9c">
        <source>tTransManifestGateDocInt();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 Dec 2023	jlirs1	TFS 59171 User Defined Transport Manifest 
14 Apr 2025	navdap1	MTN-14781 CPL| Increase BOL Field Length
*/

constants
	USER_DEF_NAME : String = "JMTInternalTransManifest";
	BOOKING001 : String = "BK100001";
	CONTAINERID : String = "SARG1234543";
	VOYAGECODE = 'VOY27418';
	VESSELNAME = 'SHIP27418';
	OPERATORCODE = 'MSK';
	RELEASE_001 : String = "UT_REL2221011";
vars
	ediFileObj : CM_EDIFile;
	ediDataObj : CM_EDIData;
	container : CM_Container;
	operator : CM_Operator;
	vessel : CM_Vessel;
	voyage : CM_Voyage;
	bookingRef : CM_BookingRef;
	relRequest : CM_BulkRelease;
	passportObj : CM_Passport;
	ediText : String;
	errorMsg : String;
	truckArrDate : Date;
begin
	self.setTerminalConfig(EdiGateDocInvConsignor, false);
	passportObj := app.myPassport;
	operator := self.getOperator(OPERATORCODE);
	self.deleteBooking(BOOKING001);
	bookingRef := self.getBooking(BOOKING001);
	self.assertIsDeleted(bookingRef);
	self.deleteReleaseRequest(RELEASE_001);
	relRequest := self.getReleaseRequest(RELEASE_001);
	self.assertIsDeleted(relRequest);
	self.deleteVoyage(VOYAGECODE);
	voyage := self.getVoyage(VOYAGECODE);
	self.assertIsDeleted(voyage);
	self.deleteVessel(VESSELNAME);
	vessel := self.getVessel(VESSELNAME);
	self.assertIsDeleted(vessel);
	self.deleteContainer(CONTAINERID);
	container := self.getTrackedItem(CONTAINERID).CM_Container;
	self.assertIsDeleted(container);
	vessel := self.addVesselCellular(VESSELNAME,
										operator);
	self.assertNotNullMsg(vessel, 'Add vessel failed');
	
	voyage := self.addVoyageWithContainerStructur(VOYAGECODE,
													VESSELNAME,
													OPERATORCODE,
													self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString);
	self.assertNotNullMsg(voyage, 'Add voyage failed');
	ediText :=
'&lt;?xml version="1.0"?&gt;
&lt;JMTInternalTransManifest xmlns:xsi="http://www.jademasterterminallogistics.com/JMTInternal" xsi:noNamespaceSchemaLocation="JMTInternalTransManifest.xsd"&gt;
	&lt;AllDataTransManifest&gt;
	&lt;DataTransManifest&gt;
		&lt;statusString&gt;Create&lt;/statusString&gt;
		&lt;guid&gt;"bd32cfne-24eb-495e-98d2-df19db66dd8&lt;/guid&gt;
		&lt;type&gt;GateDocument&lt;/type&gt;
		&lt;manifestNumber&gt;Mannumber12345&lt;/manifestNumber&gt;
		&lt;receiver&gt;EBTA&lt;/receiver&gt;
		&lt;sender&gt;Sarge&lt;/sender&gt;
		&lt;transportReferenceCustomer&gt;246813579&lt;/transportReferenceCustomer&gt;
		&lt;estimatedDateTimeOfArrival&gt;'&amp;truckArrDate.addDays(4).asStringJMT&amp;'&lt;/estimatedDateTimeOfArrival&gt;
	&lt;AllPrenote&gt;
		&lt;Prenote&gt;
			&lt;curtainsIn/&gt;
			&lt;hasRadio/&gt;
			&lt;isControlledAtmosphere/&gt;
			&lt;isNew/&gt;
			&lt;isWeightCertified/&gt;
			&lt;offsiteCleaned/&gt;
			&lt;offsitePreTrip/&gt;
			&lt;selfPropelled/&gt;
			&lt;updateVGMOnly/&gt;
			&lt;certificate1Expiry/&gt;
			&lt;certificate2Expiry/&gt;
			&lt;docsCleared/&gt;
			&lt;docsReceived/&gt;
			&lt;docsReturned/&gt;
			&lt;docsSent/&gt;
			&lt;expectedArrivalDate/&gt;
			&lt;expiryDate/&gt;
			&lt;receiveDate/&gt;
			&lt;transitOnPowerDate/&gt;
			&lt;cargoWeight/&gt;
			&lt;height/&gt;
			&lt;length/&gt;
			&lt;overHeight/&gt;
			&lt;overLengthBack/&gt;
			&lt;overLengthFront/&gt;
			&lt;overWidthLeft/&gt;
			&lt;overWidthRight/&gt;
			&lt;tareWeight/&gt;
			&lt;timeAllowedOffPower/&gt;
			&lt;vent/&gt;
			&lt;volume/&gt;
			&lt;weight&gt;40000&lt;/weight&gt;
			&lt;width/&gt;
			&lt;availabilityGrade/&gt;
			&lt;carbonDioxide/&gt;
			&lt;coolingType/&gt;
