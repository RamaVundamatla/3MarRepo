    <JadeMethod name="getAllCriteriaValues" id="b5b563f8-a0b7-49d8-9a21-82da6e2787c4">
        <source>getAllCriteriaValues(_terminalObj:CM_Terminal; _allCriteriaValues: ObjectSet input; _filter : Integer; _allDependentObjs : CM_ObjectArray);
// --------------------------------------------------------------------------------
// Created:		24 November 2009 by cnwjo3
//
// Purpose:		Populate the collection parameter with instances of the CM_SpecialStow
//				class.  CCMS 1028
//
// Parameters:	pAllCriteriaValues - A reference to the object set to populate.
//
//17 September 2013	cnwmc5	PAR 31255 - allowing dependent objects the criteria is based on.
begin
	app.myRoot.allSpecialStows.copy(_allCriteriaValues);
end;</source>
        <Parameter name="_terminalObj" type="CM_Terminal"/>
        <Parameter name="_allCriteriaValues" type="ObjectSet" usage="input"/>
        <Parameter name="_filter" type="Integer"/>
        <Parameter name="_allDependentObjs" type="CM_ObjectArray"/>
    </JadeMethod>
    <JadeMethod name="getCriteriaObjectForTi" id="1751c6f9-ca4b-4223-94f1-4462d6a6cd6d">
