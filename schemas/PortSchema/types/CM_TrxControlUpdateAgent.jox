    <JadeMethod name="trxUpdateBOL" id="fa5cf2cc-2528-4207-b163-3c69cb0fcfb3">
        <updating/>
        <source>trxUpdateBOL(	_proxyBOL : CM_BOL input;
				_ignoreWarnings : Boolean;
				_context : Object; //06 Nov 2019	NDL	TFS 47100
				_passport : CM_Passport input) updating;
// -----------------------------------------------------------------------------
// Created:		12 April 2002 by cnwka1
//
// Purpose:		
// -----------------------------------------------------------------------------
vars
	realBOL			: CM_BOL;
	tmpEvent,
	expectedEdition	: Integer;
	ao				: CM_AuditObject;
	ext				: CM_BOLExtLogIn;
	terminal		: CM_Terminal;
	st	: Integer;
	allNewBOLDtlProxies : CM_ObjectArrayActual;
	proxy			: CM_Object;


begin 

	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);
	
	app.setContinueCMExceptions(false);

	_proxyBOL.raiseExceptionIfNotProxy(method);
	
	//validate and update the proxy docket first as attachments are set from the docket
	app.myValUA.valBOL(_proxyBOL, false, _passport);

	endLoad;	// free up any validation locks
	
	create allNewBOLDtlProxies transient;
	
	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	
	
	_proxyBOL.pxyGetRealObjectAndEdition(realBOL, expectedEdition);
	app.setContinueCMExceptions(true);
	

	if realBOL = null then	
		app.raiseCMException1(ProxyMgrCannotLocateReal, CM_BOL.number.String, null, null);
		return;
	endif;
	

	app.writeLog(method.name &amp; '  start with BOL ' &amp; _proxyBOL.number, LogINFO);
	st := app.clock;
	
	beginTransaction;
	terminal := _passport.myTerminal;
	exclusiveLock(realBOL);

	if _passport.noErrors and realBOL.edition &lt;&gt; expectedEdition then
		app.raiseCMException1(ObjectUpdatedByAnotherUserSave, 'Docket', null, null);
		return;
	endif;
	
	
	
	if _passport.noErrors then
		app.myUtilityUA.myUpdateAuditAgent.audUpdateGeneric(realBOL, true);		
	endif;

	if _passport.noErrors then
		if _context &lt;&gt; null then
			realBOL.createUpdOperatorBOLTrx(_proxyBOL, app.myPassport);
		endif;
		realBOL.setForUpdate(_proxyBOL, app.myPassport);		
	endif;
	
	
	if realBOL.bolType = BOLType_Log and realBOL.isInward then
		if realBOL.CM_BOLIn.isMatched then
			ext := realBOL.myExtension.CM_BOLExtLogIn;
			if (not ext.isMatchedAndMoved) then
				// docket was matched but not moved into the yard, move them to new location
				app.writeLog(method.name &amp; '  moving BOL to planned location', LogINFO);
				ext.completeRoadInProcessForBOL(_passport);
			endif;
		endif;
	endif;
	
	if _passport.noErrors then
		realBOL.setForUpdateBOLDtl(_proxyBOL, allNewBOLDtlProxies, _context);
	endif;
	
	if _passport.noErrors then 
		app.myUtilityUA.myUpdateAuditAgent.audUpdateGeneric(realBOL, false);		
		tmpEvent := realBOL.myTerminal.getTerminalEvent(BOLRecon_Update_Event);
		terminal.causeEvent(tmpEvent, false, realBOL);
		tmpEvent := realBOL.myTerminal.getTerminalEvent(Event_BOLUpdate); 
		terminal.causeEvent(tmpEvent, false, realBOL);
		
		
		realBOL.handleOpsView(BGP_OpsViewWSRequest.OPS_ACTION_UPDATE); // ### TFS 53105 30MAY2022 NAVAB1
	endif;
	


epilog
	self.finaliseActivityWithPassport(_passport);
	app.writeLog(method.name &amp; '  complete (' &amp; (app.clock - st).String &amp; ') numLogs = ' &amp; _proxyBOL.numItems.String, LogINFO);
//these proxies have not been committed yet so if there was an exception then need to remove proxy link
	
	if allNewBOLDtlProxies &lt;&gt; null then
		foreach proxy in allNewBOLDtlProxies do
			app.myProxyManager.deleteProxyLink(proxy);
		endforeach;
		
		delete allNewBOLDtlProxies;
	endif;
	
	
end;</source>
        <Parameter name="_proxyBOL" type="CM_BOL" usage="input"/>
        <Parameter name="_ignoreWarnings" type="Boolean"/>
        <Parameter name="_context" type="Object"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxUpdateBOLCustomStop" id="64793663-31ad-4900-ac52-6374dbce5ff8">
        <updating/>
        <source>trxUpdateBOLCustomStop(_pxyBOL : CM_BOL; _ediData : CM_EDIDataCustomStop; _ediCusStopTI : CM_EDICustomStopTI input; _passport : CM_Passport input) updating;
//----------------------------------------------------------------------
//
//  Created by cnwsh3
//
//	Date 08 May 2008
//
//	At this stage we are only creating a message transaction for the US as
//  we currently need more info on whether a stop should be applied to a bol 
//  and if so, is it the same type as it's cargo items.
//----------------------------------------------------------------------

vars
	passport 		: CM_Passport;
	tmpCustomStopTI : CM_EDICustomStopTI;
	bol				: CM_BOL;
begin
	passport := _passport;
	// Always initialize the activity first
	self.initialiseActivityWithPassport(passport, method);
	
	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, passport);
	on LockException do agtPassportLockExHandler(exception, passport);

	passport.useTIDictDeferUpdate := true; //Feb 2008 cnwrs1 to try and cleanup deadlocks
	passport.useTITransactionDeferUpdate := true;

	app.setContinueCMExceptions(true);
	
	//validate the stop or message if required.
	
	if not self.checkValidationWithPassport(passport) then
		return;
	endif;
	
	tmpCustomStopTI := _ediCusStopTI;
	bol := _pxyBOL.pxyGetRealObject();
		
	beginTransaction;
	
	if tmpCustomStopTI.responseStatus = CustomsX12_Hold1C then	
		bol.createStatusMessageTransaction(tmpCustomStopTI, passport);
	endif;
	
	app.myPassport.doDeferredUpdates();
epilog
	self.finaliseActivityWithPassport(passport);
end;</source>
        <Parameter name="_pxyBOL" type="CM_BOL"/>
        <Parameter name="_ediData" type="CM_EDIDataCustomStop"/>
        <Parameter name="_ediCusStopTI" type="CM_EDICustomStopTI" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxUpdateBOLHeader" id="0f03162b-1547-438d-aec1-6842958fd01b">
        <updating/>
        <source>trxUpdateBOLHeader(_ifaceBOLOut: CMIF_BOLOut input; _passport : CM_Passport input) updating;
//--------------------------------------------------------------
//Created: 11 July 2002 By: cnwsb1
//--------------------------------------------------------------
vars
	newBOLEdition	: Integer;
	pxyParentTI		: CM_TrackedItem;
begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);
		
	// Start the transaction
	beginTransaction;
	
	// Perform the operation
	app.myUtilityUA.utlUpdateBOLHeader(_ifaceBOLOut, _passport);
	
	if _ifaceBOLOut.doUpdateParentContainer and _ifaceBOLOut.myMasterTI &lt;&gt; null then
		pxyParentTI := app.createUpdateProxy(_ifaceBOLOut.myMasterTI).CM_TrackedItem;
		pxyParentTI.setPxyFromCMIF_BOLOut(_ifaceBOLOut, _passport);
		app.myUtilityUA.utlUpdateTrackedItem(pxyParentTI, null, TI_UPDMODE_NORMAL, null, null, null, _passport); //cnwrd1 28.8.09 par 20545
	endif;
	
epilog
	delete pxyParentTI;
	self.finaliseActivityWithPassport(_passport);
end;</source>
        <Parameter name="_ifaceBOLOut" type="CMIF_BOLOut" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxUpdateBOLIn" id="2d4142e8-7a4c-4fcc-98b5-b9491c0db8e3">
        <updating/>
        <source>trxUpdateBOLIn(_pxyBOlIn : CM_BOLIn input; _passport : CM_Passport input) updating;
//
// 03 Jan 2018	jlgrs1	TFS 36430 Penn Ship Manifest too many locks
//
// 02 Dec 2018	jlgrs1	TFS 42276 STWR Make EDI MultiThreaded Stage 7
//
vars

begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	if _pxyBOlIn = null then
		app.raiseCMException1(ERR_DEL_NULLOBJECT, 'BOL In', null, null);
		return;
	endif;

	_passport.useTIDictDeferUpdate := true;
	_passport.useTITransactionDeferUpdate := true;

	// Start the transaction
	beginTransaction;

	app.myUtilityUA.utlUpdateBOLIn(_pxyBOlIn, _passport);
		
	if _passport.noErrors then
		_passport.doDeferredUpdates();
	endif;
epilog
	self.finaliseActivityWithPassport(_passport);
