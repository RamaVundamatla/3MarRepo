    <JadeMethod name="fldPurge_querySheetChg" id="e4f2496e-407b-4ed3-a525-ce2679d38df4">
        <controlMethod name="CMUI_Folder::querySheetChg"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>fldPurge_querySheetChg(folder: Folder; newSheet: Sheet):Boolean updating;
// -------------------------------------------
// Created 23 August 2004 by cnwdvb1
// -------------------------------------------
vars

begin
	if newSheet = self.fldPurgeSheet1 then
		self.btnDelete.enabled	:= false;
		self.btnAbort.enabled	:= false;
	else
		self.btnDelete.enabled	:= true;
		self.btnAbort.enabled	:= true;
	endif;
	// TFS 2198 CNWAB1
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		self.btnDelete.enabled	:= false;
		self.btnAbort.enabled	:= false;

	endif;

	return true;
end;</source>
        <Parameter name="folder" type="Folder"/>
        <Parameter name="newSheet" type="Sheet"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="fldPurge_sheetChg" id="5122e001-de86-4270-9236-4cf197cfd5f2">
