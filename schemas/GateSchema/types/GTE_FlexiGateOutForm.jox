    <JadeMethod name="addCargoTypeControl" id="5dde6917-6051-4e00-b452-90623f2d3bad">
        <updating/>
        <source>addCargoTypeControl(_row, _newIdx : Integer; isReceiveTable : Boolean ) updating, protected;
//----------------------------------------------------------------------
//
//  Created by cnwsh3
//
//	Date 29 June 2007
//
//----------------------------------------------------------------------

vars
	newCombo 	: CMUI_ComboBox;
	textBox : CMUI_TextBox;
	idx			: Integer;
begin
	if _newIdx = 0 then
		self.newIndex := self.newIndex + 1;
		idx := self.newIndex;
	else
		idx := _row;
	endif;
	
	newCombo := self.cmbCargoType.loadControl(idx).CMUI_ComboBox;
	if isReceiveTable then
		self.tblReceivals.accessCell(_row, self.cargoTypeColumn).cellControl := newCombo;
	else 
		self.tblReleases.accessCell(_row, self.cargoTypeColumnReleaseTable).cellControl := newCombo;
	endif;
	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_row" type="Integer"/>
        <Parameter name="_newIdx" type="Integer"/>
        <Parameter name="isReceiveTable" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="addControlToTable" id="3040189f-697c-469d-96e1-dabe92f4f0e5">
        <updating/>
        <source>addControlToTable(_row, _newIdx : Integer; _tbl : CM_DataTable io; _isForCargoID : Boolean; _isForCargoType : Boolean; _wle : CM_WorkListEntry)  updating, protected ;
//----------------------------------------------------------------------
//
//  Created by cnwsh3
//
//	Date 05 June 2007
//
//----------------------------------------------------------------------

vars
	newCombo 	: CMUI_ComboBox;
	textBox : CMUI_TextBox;
	idx			: Integer;
begin

	if _newIdx = 0 then
		self.newIndex := self.newIndex + 1;
		idx := self.newIndex;
	else
		idx := _row;
	endif;
	
	if _isForCargoType then
		newCombo := self.cmbCargoType.loadControl(idx).CMUI_ComboBox;
		_tbl.accessCell(_row, self.cargoTypeColumn).cellControl := newCombo;
	endif;
	
	if _isForCargoID then
//16224	not being used just causes exception	textBox := self.txtCargoId.loadControl(idx).CMUI_TextBox;
		_tbl.accessCell(_row, self.cargoIdColumnRelease).inputType := Table.InputType_TextBox;
		_tbl.accessCell(_row, self.cargoIdColumnRelease).cellControl.TextBox.case := TextBox.Case_Upper;
		_tbl.accessCell(_row, self.cargoIdColumnRelease).cellControl.TextBox.selectionStyle := TextBox.SelectionStyle_SelectAll;
	else
		//I MUST BE A RECEIVAL SO LOAD ME A LOCATION TEXT BOX
//16224				textBox := self.txtLocationTo.loadControl(idx).CMUI_TextBox;
		_tbl.accessCell(_row, self.cargoIdColumnRelease).inputType := Table.InputType_TextBox;
		_tbl.accessCell(_row, self.cargoIdColumnRelease).cellControl.TextBox.case := TextBox.Case_Upper;
		_tbl.accessCell(_row, self.cargoIdColumnRelease).cellControl.TextBox.selectionStyle := TextBox.SelectionStyle_SelectAll;
		//IF IT'S COMPLETE DON'T ALLOW UPDATES
		if _wle &lt;&gt; null and _wle.status = WLE_COMPLETED then
			_tbl.accessCell(_row, self.cargoIdColumnRelease).cellControl.TextBox.enabled := false;
		endif;
	endif;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_row" type="Integer"/>
        <Parameter name="_newIdx" type="Integer"/>
        <Parameter name="_tbl" type="CM_DataTable" usage="io"/>
        <Parameter name="_isForCargoID" type="Boolean"/>
        <Parameter name="_isForCargoType" type="Boolean"/>
        <Parameter name="_wle" type="CM_WorkListEntry"/>
    </JadeMethod>
    <JadeMethod name="addReceiveWorkEntry" id="823c4684-d47c-45ab-9759-ff3beb408152">
        <updating/>
        <source>addReceiveWorkEntry(_wle : CM_WorkListEntry) protected, updating;
//----------------------------------------------------------------------
//
//  Created by cnwsh3
//
//	Date 31 May 2007
//
//----------------------------------------------------------------------

vars
	rowStr			: String;
	entRow			: EntTableRow;
	entDef			: EntTableDef;
	col				: Integer;
	idx				: Integer;
	wle 			: CM_WorkListEntry;
	combo			: CMUI_ComboBox;
	tbl 			: CM_DataTable;
begin
	if not CM_YardWLE.hasInstance(_wle) then
		app.writeStatement(self.class.name &amp; ' &gt;&gt;' &amp; method.name &amp; " 1. Receiving non Yard WLEs here");
		return;
	endif;
	
	wle := _wle;
	
	//if wle.isReceipt then
		tbl := self.tblReceivals;
	//else
	//	tbl := self.tblReleases;
	//endif;
	
	rowStr := self.displayRowForDataTable(wle, tbl);
	idx := tbl.rows + 1;
	tbl.addItemAt(rowStr, idx);
	//idx := tbl.addItem(rowStr);
	tbl.accessRow(idx).itemObject := wle;
	
	if wle.myTrackedItem = null then
//		idx := tbl.rows;
		self.addControlToTable(idx, self.newIndex, tbl, true, false, wle);
	endif;
	
	//if wle.isReceipt then
		idx := tbl.rows;
		self.addControlToTable(idx, self.newIndex, tbl, false, false, wle);
	//else
	//	if wle.myTrackedItem = null then
	//		self.addCargoTypeControl(idx, self.newIndex, false);
	//	endif;
	//endif;
	
	self.allReceiveWLEs.add(_wle);

	//self.addWorkEntryToCollection(wle);
	
	self.tblWorkEntryColor(tbl, wle, idx);
end;</source>
        <access>protected</access>
        <Parameter name="_wle" type="CM_WorkListEntry"/>
    </JadeMethod>
    <JadeMethod name="addReleaseWorkEntry" id="bb5ec2f4-78ff-4c45-89d1-65ed9c374c4f">
        <updating/>
        <source>addReleaseWorkEntry(_wle : CM_WorkListEntry) protected, updating;
//----------------------------------------------------------------------
//
//  Created by cnwsh3
//
//	Date 31 May 2007

//	15 Nov 2011	NDl	Par 28367
//
//----------------------------------------------------------------------

vars

	rowStr			: String;
	idx				: Integer;
	wle 			: CM_WorkListEntry;
	tbl 			: CM_DataTable;
	
begin

	if not CM_YardWLE.hasInstance(_wle) then
		app.writeStatement(self.class.name &amp; ' &gt;&gt;' &amp; method.name &amp; " 1. Receiving non Yard WLEs here");
		return;
	endif;
	
	wle := _wle;
	tbl := self.tblReleases;
	
	rowStr := self.displayRowForDataTable(wle, tbl);
	idx := tbl.rows + 1;
	tbl.addItemAt(rowStr, idx);
	
	tbl.accessRow(idx).itemObject := wle;
	
	if wle.myTrackedItem = null then
		self.addControlToTable(idx, self.newIndex, tbl, true, false, wle);
	endif;
	
	if wle.myTrackedItem = null then
		self.addCargoTypeControl(idx, self.newIndex, false);
	endif;
	
	self.allReleaseWLEs.add(_wle);
	
	self.tblWorkEntryColor(tbl, wle, idx);
	
end;</source>
        <access>protected</access>
        <Parameter name="_wle" type="CM_WorkListEntry"/>
    </JadeMethod>
