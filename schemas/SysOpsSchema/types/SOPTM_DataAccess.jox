    <JadeMethod name="initShtMultiSelect" id="60588ddf-d429-4e96-a444-6b020dbd407f">
        <source>initShtMultiSelect();
// ---------------------------------------------------------------------------
// Created:     23 January 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	theForm	: SOP_TableMaintForm;
	
begin

	theForm := self.myForm;
	inheritMethod;
	theForm.lblName.visible		:= true;
	theForm.lblName.caption		:= "Name";
	theForm.txtName.visible		:= true;
	theForm.txtName.width		:= 100;
	theForm.txtName.readOnly	:= true;
	theForm.txtName.case		:= TextBox.Case_Upper;
	
	theForm.optAllow.visible	:= true;
	theForm.optDisallow.visible	:= true;

	theForm.mulSelect1.visible	:= true;
	theForm.mulSelect2.visible  := false;
	
	
	theForm.shtMultiSelect1.visible := true;
	theForm.shtMultiSelect2.visible := false;
	theForm.shtMultiAlign.visible 	:= false;
end;</source>
    </JadeMethod>
