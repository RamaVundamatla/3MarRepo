<Class name="WS_VesselDefn" id="2ba1e500-cf7a-48a6-a723-41cf34ce4ef9">
    <superclass name="WS_ProxyObject"/>
    <transient/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>The Vessel Definition for a LOLO structure vessel.</text>
    <DbClassMap file="webservice"/>
    <ImplicitInverseRef name="allHolds" id="a2b47b52-e215-478e-a5bb-6fc76a9e0649">
        <memberTypeInverse/>
        <type name="WS_HoldDefnArray"/>
        <text>Internal use only. No external support</text>
    </ImplicitInverseRef>
    <PrimAttribute name="bridgeAfterBay" id="5cd66bae-ea31-4a5b-add1-8e4e25bbbef5">
        <length>4</length>
        <embedded/>
        <type name="String"/>
        <text>For LOLO vessels the bay after the bridge</text>
    </PrimAttribute>
    <PrimAttribute name="code" id="69294a52-7e06-406e-9dda-1ae38615b6dc">
        <length>31</length>
        <embedded/>
        <type name="String"/>
        <text>The Vessel Code.</text>
    </PrimAttribute>
    <PrimAttribute name="name" id="88c7daeb-0d14-42d2-bc01-10b4580c34b5">
        <length>31</length>
        <embedded/>
        <type name="String"/>
        <text>The Vessel Name.</text>
    </PrimAttribute>
    <PrimAttribute name="numDefined" id="bedb14ec-4c99-4d11-ae83-bb73df3f52bd">
        <embedded/>
        <type name="Integer"/>
        <text>The number of LOLO slots defined.</text>
    </PrimAttribute>
    <PrimAttribute name="numExpected" id="5d086d38-e621-46b8-b7cf-16b87b719e09">
        <embedded/>
        <type name="Integer"/>
        <text>The number of LOLO slots expected.</text>
    </PrimAttribute>
    <PrimAttribute name="use40BayIds" id="b517e2b4-f09e-4906-83c2-35762e805b49">
        <embedded/>
        <type name="Boolean"/>
        <text>Use 40 ft bay IDs for 40ft containers.</text>
    </PrimAttribute>
    <PrimAttribute name="useBayCellTier" id="23498d4c-1578-4c9f-bfd3-75a5125ae8a9">
        <embedded/>
        <type name="Boolean"/>
        <text>If true stowage numbering is in Bay/Cell/Tier. If false stowage numbering is in Bay/Tier/Cell.</text>
    </PrimAttribute>
    <JadeMethod name="createProxy" id="a6a35336-038e-4fb6-9272-8bbb8caa7778">
        <source>createProxy() : CM_CellularVesselStructure;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 January 2013	cnwer1	Initial creation HAT 2189

*/

vars
	vessel	 		: CM_Vessel;
	wsHold			: WS_HoldDefn;
	pxyVessel 		: CM_CellularVesselStructure;
	completedOK 	: Boolean;
begin

	vessel:=app.myRoot.allVessels[self.code];
	if vessel = null then
		return null;
	endif;
	//
		

	if vessel.myCellularVesselStructure = null then
		// should already have one if vessel was created as type that supported LOLO structure
		// obvoiusly not a LOLO type vessel should raise error and return
		return null;
	endif;

	//create pxy LOLO structure from the request
	beginLoad;
	pxyVessel:= vessel.myCellularVesselStructure.cloneSelf(true); //pxyCreateUpdateProxy();
	app.myProxyManager.createProxyLink(vessel.myCellularVesselStructure, pxyVessel);
	endLoad;
	
	pxyVessel.setProxyCellularVessel(pxyVessel.bridgeAfterBay,self.use40BayIds,self.useBayCellTier,pxyVessel.isoHalfHeights, self.numExpected);
	
	// update bridge after bay, use40ftIDs default to true, bay cell tier numbering defaults to true, iso half heights default to false
// PAR 32286 831	pxyVessel.setProxyCellularVessel(self.bridgeAfterBay,true,true,false, 0); // PAR 32286
	
	foreach wsHold in self.allHolds discreteLock do
		wsHold.createProxy(pxyVessel,0);
	endforeach;
	
	completedOK:=true;
	return pxyVessel;
epilog
	if not completedOK then	
		delete pxyVessel;
	endif;
end;</source>
        <ReturnType type="CM_CellularVesselStructure"/>
    </JadeMethod>
    <JadeMethod name="delete" id="832f772e-9257-4688-bec6-5f32b37b72f3">
        <updating/>
        <source>delete() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 November 2017	jlger1	Initial creation 7521

*/

vars

begin
	self.allHolds.purge;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setProxyFromObject" id="75ba84f7-5a14-4bd2-814a-8c222775e365">
        <updating/>
        <source>setProxyFromObject(_object: CM_Vessel) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 January 2013	cnwer1	Initial creation HAT 2189

*/

vars
	hold : CM_Hold;
	wsHold : WS_HoldDefn;
begin
	if _object = null then
		return;
	endif;
	
	inheritMethod(_object);
	
	self.code	:= _object.code;
	self.name	:= _object.name;
	self.useBayCellTier := _object.myCellularVesselStructure.useBayCellTierNumbering;
	self.use40BayIds := _object.myCellularVesselStructure.use40Id;
	self.numExpected := _object.myCellularVesselStructure.numSlotsExpected;
	self.numDefined := _object.myCellularVesselStructure.numSlotsDefined;
	
	
	_object.validateUpdateForSLWS();

	
	if _object.myCellularVesselStructure = null then
		return;
	endif;
	self.bridgeAfterBay := _object.myCellularVesselStructure.bridgeAfterBay;
	
	foreach hold in _object.myCellularVesselStructure.allHolds discreteLock do
		create wsHold transient;
		wsHold.setProxyFromObject(hold);
		self.allHolds.add(wsHold);
	endforeach;
	
epilog

end;</source>
        <Parameter name="_object" type="CM_Vessel"/>
    </JadeMethod>
    <JadeMethod name="setProxyFromObjectBays" id="7de38407-2fe0-46c9-bad5-0634bb80ef7a">
        <updating/>
        <source>setProxyFromObjectBays(_object: CM_Vessel) updating;
/*
Purpose:			
Date				Who			Reason
AUGUST 2015		CNWAB1		Initial creation
*/


vars
	hold : CM_Hold;
	wsHold : WS_HoldDefn;
begin
	if _object = null then
		return;
	endif;
	
	
	self.code	:= _object.code;
	self.name	:= _object.name;
	self.useBayCellTier := _object.myCellularVesselStructure.useBayCellTierNumbering;
	self.use40BayIds := _object.myCellularVesselStructure.use40Id;
	self.numExpected := _object.myCellularVesselStructure.numSlotsExpected;
	self.numDefined := _object.myCellularVesselStructure.numSlotsDefined;
	
	
	_object.validateUpdateForSLWS();

	
	if _object.myCellularVesselStructure = null then
		return;
	endif;
	self.bridgeAfterBay := _object.myCellularVesselStructure.bridgeAfterBay;
	
	foreach hold in _object.myCellularVesselStructure.allHolds discreteLock do
		create wsHold transient;
		wsHold.setProxyFromObjectBay(hold);
		self.allHolds.add(wsHold);
	endforeach;
	
epilog

end;</source>
        <Parameter name="_object" type="CM_Vessel"/>
    </JadeMethod>
</Class>
