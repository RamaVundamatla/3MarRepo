    <JadeMethod name="deactivate" id="0bc333a1-650e-4c9c-9078-1624f9eee317">
        <controlMethod name="Form::deactivate"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>deactivate() updating;
/*
Purpose:			
Date		Who		Reason
11 July 2011	cnwab1	Initial creation
*/

vars

	doShow : Boolean;
	doShowCargoSideView : Boolean;
begin
	doShow := (self.modeView = ShpDisplayMode_ColCodeLoad or  self.modeView = ShpDisplayMode_ColCodeDisch); // and self.workingMode = self.WorkMode_None ; 
	doShowCargoSideView := app.activeForm.isKindOf(SHP_CargoSideViewForm) and self.mySideViewForm &lt;&gt; null;
	if app.activeForm.isKindOf(CMUI_VoyageAllocationsListForm) or app.activeForm.isKindOf(CMUI_VoyageAllocsLoadListForm) or app.activeForm.isKindOf(CMUI_YAMaintVoyForm) or app.activeForm.isKindOf(SHP_CargoSideViewForm) then
		self.amActive := true;
		self.causeEvent(self.myTerminal.getTerminalEvent(ShowHide_VoyageAllocationsCC),true,doShow);
		// ### Adrian I have turned this off as the screen needs to be visible to interact with the Load List and the Yard Grid Areas form
//		self.causeEvent(self.myTerminal.getTerminalEvent(ShowHide_CargoSideView),true,self.mySideViewForm &lt;&gt; null);
	else
		self.amActive := false;
		if self.myCurrentVoyage &lt;&gt; null then
			self.causeEvent(self.myTerminal.getTerminalEvent(ShowHide_VoyageAllocationsCC),true,false);			
		endif;
		// ### Adrian I have turned this off as the screen needs to be visible to interact with the Load List and the Yard Grid Areas form
//		self.causeEvent(self.myTerminal.getTerminalEvent(ShowHide_CargoSideView),true,false);
	endif;		

epilog

end;</source>
    </JadeMethod>
