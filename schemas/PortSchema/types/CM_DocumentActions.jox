    <JadeMethod name="areAllActionsCompleted" id="eec6a05e-4309-464a-86be-9eacb67b570d">
        <source>areAllActionsCompleted(_reason : String output ): Boolean;
/*
Purpose:		this method works the same way as 'getTaskList' which is used to display the tasks and how many are completed.	
Date				Who			Reason
APRIL 2017		CNWAB1		Initial creation // TFS 4052 // TFS 4052
*/


vars

	retString : String;
	invalidObj : Boolean;
	task : CM_ToDoTaskDesc;
	attrStr : String;
	completed : Real;
	applied : Real;
	stop : CM_StopsTable;
begin

	on Exception do app.handleDeletedObject(exception, task, invalidObj);
	
	foreach task in self.allTaskDescsToAdd do
		self.getTotalsForTask( task, completed, applied );
		if completed &lt;&gt; applied then
			_reason :=  app.getErrorString(Task) &amp; " " &amp; task.shortDescription.String &amp; " (" &amp; completed.String &amp; "/" &amp; applied.String &amp; ")";
			return false;
		endif;
	endforeach;
	
	foreach stop in self.allStopTablesToAdd do
		self.getTotalsForStop( stop, completed, applied );
		if completed &lt;&gt; applied then
			_reason :=  app.getErrorString(Stop) &amp; " " &amp; stop.shortHeading.String &amp; " (" &amp; completed.String &amp; "/" &amp; applied.String &amp; ")";
			return false;
		endif;
	endforeach;
	
	return true;

epilog

end;</source>
        <Parameter name="_reason" type="String" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="areAllActionsCompletedFor" id="84230dcd-6ce3-4561-a8be-4e590cd2f6ef">
        <source>areAllActionsCompletedFor( _ti : CM_TrackedItem; _reason : String output ):Boolean;
/*

Purpose:		 // TFS 4052	

Parameters:			this method works the same way as 'getTaskList' which is used to display the tasks and how many are completed.	

Return Value:		

Date		Who		Reason
27 September 2016	cnwndl1	Initial creation	TFS 

*/

vars

	amount : Real;
	
	stop : CM_StopsTable;
	task : CM_ToDoTaskDesc;
	docTask : CM_DocumentToDoTask;
	docStop : CM_DocumentStops;
	trx : CM_TITransaction;
	trxStopCleared : CM_StopClearedDocAction;
	trxTaskCompleted : CM_TaskCompleteDocAction;
	ti : CM_TrackedItem;
	actionAmount : Real;
	retValue, invalid : Boolean;

begin
	on Exception do app.handleDeletedObject(exception, ti, invalid); 
	on Exception do app.handleDeletedObject(exception, trx, invalid);  // ### TFS 53851 14JUN2022 NAVAB1

	retValue := true;


	foreach stop in self.allStopTablesToAdd discreteLock do	
		actionAmount := 0;
		amount := 0;
		
		foreach docStop in self.allDocumentStopsApplied discreteLock do
			if docStop.myStopsTable.id &lt;&gt; stop.id then
				continue;
			endif;
			
			ti := docStop.myTrackedItem; // ### TFS 51219 28MAY2021 NAVAB1
			if ti.id &lt;&gt; _ti.id then // TFS 4052 added ID
				continue;
			endif;
			
			if invalid then // ### TFS 51219 28MAY2021 NAVAB1
				invalid := false;
				continue;
			endif;
			if docStop.myTrackedItem.cargoType &lt;&gt; _ti.cargoType then // TFS 4052 added CARGOTYPE
				continue;
			endif;
			amount := amount + docStop.amount;
		endforeach;

		foreach trx in self.allCompletedStopTrx discreteLock do
			trxStopCleared := trx.CM_StopClearedDocAction;
			if trxStopCleared.stopID &lt;&gt; stop.id then
				continue;
			endif;
			if trxStopCleared.myTrackedItem.id &lt;&gt; _ti.id then // TFS 4052 added ID
				continue;
			endif;
			if trxStopCleared.myTrackedItem.cargoType &lt;&gt; _ti.cargoType then // TFS 4052 added CARGOTYPE
				continue;
			endif;
			actionAmount := actionAmount + trxStopCleared.amount;
		endforeach;
		
		
		
		if actionAmount &lt; amount then
			retValue := false;
			if _reason &lt;&gt; null then
				_reason := _reason &amp; ", ";
			endif;
			_reason := _reason &amp; app.getErrorString(Stop) &amp; " " &amp; stop.shortHeading.String &amp; " (" &amp; actionAmount.String &amp; "/" &amp; amount.String &amp; ")";
		endif;
	endforeach;
	
	
	foreach task in self.allTaskDescsToAdd discreteLock do
		actionAmount := 0;
		amount := 0;
		
		foreach docTask in self.allDocumentTasksApplied discreteLock do
			if docTask.toDoTaskDescCode &lt;&gt; task.code then
				continue;
			endif;
			ti := docTask.myTrackedItem; // ### TFS 51219 28MAY2021 NAVAB1
			if ti.id &lt;&gt; _ti.id then // TFS 4052 added ID
				continue;
			endif;
			
			if invalid then // ### TFS 51219 28MAY2021 NAVAB1
				invalid := false;
				continue;
			endif;
			
			if docTask.myTrackedItem.cargoType &lt;&gt; _ti.cargoType then // TFS 4052 added CARGOTYPE
				continue;
			endif;
			amount := amount + docTask.amount;
		endforeach;

		foreach trx in self.allCompletedTaskTrx discreteLock do
			trxTaskCompleted := trx.CM_TaskCompleteDocAction;
			if trxTaskCompleted.todoTaskCode &lt;&gt; task.code then
				continue;
			endif;
			
			ti := trxTaskCompleted.myTrackedItem; // ### TFS 51219 28MAY2021 NAVAB1
			if ti.id &lt;&gt; _ti.id then // TFS 4052 added ID
				continue;
			endif;
			
			if invalid then // ### TFS 51219 28MAY2021 NAVAB1
				invalid := false;
				continue;
			endif;
			
			if trxTaskCompleted.myTrackedItem.cargoType &lt;&gt; _ti.cargoType then // TFS 4052 added CARGOTYPE
				continue;
			endif;
			actionAmount := actionAmount + trxTaskCompleted.amount;
		endforeach;
		
		if actionAmount &lt;&gt; amount then
			retValue := false;
			if _reason &lt;&gt; null then
				_reason := _reason &amp; ", ";
			endif;
			_reason := _reason &amp; app.getErrorString(Task) &amp; " " &amp; task.shortDescription.String &amp; " (" &amp; actionAmount.String &amp; "/" &amp; amount.String &amp; ")";
		endif;
	endforeach;
	
	return retValue;

epilog
	
end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_reason" type="String" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="assignTasksAndStops" id="c402e05d-2fa4-4a8c-872a-8695ee173e4a">
        <source>assignTasksAndStops( _tiArray : CM_TIArray; _amountArray : RealArray );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 September 2016	cnwndl1	Initial creation	TFS 2644

*/

vars

	index : Integer;
	ti : CM_TrackedItem;
	taskDesc : CM_ToDoTaskDesc;
	stopTable : CM_StopsTable;
	amount : Real;
	subIndex : Integer;
	remarks : String;
	
begin

	foreach index in 1 to _tiArray.size do
		
		ti := _tiArray[index];
		amount := _amountArray[index];
		
		if not self.allTaskDescsToAdd.isEmpty then
			//05 Oct 2016	NDL	TFS 2001 / 2792
			foreach subIndex in 1 to self.allTaskDescsToAdd.size do	
				taskDesc := self.allTaskDescsToAdd[subIndex];
				remarks := null;
				if self.allTaskRemarkToAdd &lt;&gt; null
				and self.allTaskRemarkToAdd.size &gt;= subIndex
				then
					remarks := self.allTaskRemarkToAdd[ subIndex ];
				endif;
				self.createDocumentTaskForTi( ti, amount, taskDesc, remarks );
			endforeach;
		endif;
		
		foreach stopTable in self.allStopTablesToAdd do
			self.createDocumentStopForTi( ti, amount, stopTable );
		endforeach;
		
	endforeach;

epilog

end;</source>
        <Parameter name="_tiArray" type="CM_TIArray"/>
        <Parameter name="_amountArray" type="RealArray"/>
    </JadeMethod>
    <JadeMethod name="createDocumentStopForTi" id="8208a1f2-ef50-48a6-a2b6-784cc63f9397">
        <source>createDocumentStopForTi( _ti : CM_TrackedItem input; _amount : Real; _stopTable : CM_StopsTable ):CM_DocumentStops protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 September 2016	cnwndl1	Initial creation	TFS 2644

*/

vars

	docStop : CM_DocumentStops;
	cmifDAC : CMIF_DocumentActionTrxCont;

begin

	docStop :=  self.allDocumentStopsApplied[ _ti, _stopTable ];

	if docStop = null then
		create docStop;
		docStop.setDetails( _ti, _amount, _stopTable, self );
	else
		docStop.setDetails( _ti, docStop.amount + _amount, _stopTable, self );
	endif;
	
	create cmifDAC transient;
	cmifDAC.type := TRANS_TYPE_STOPADD_DA;
	cmifDAC.myStopsTable := _stopTable;
	cmifDAC.noCharge := false; //TFS 3844 changed to false
	cmifDAC.myTerminal := _ti.myTerminal;
	cmifDAC.myTrackedItem := _ti;
	cmifDAC.amount := docStop.amount;
	cmifDAC.myDocumentActions := self;
	
	_ti.createTransaction(cmifDAC, app.myPassport);
	
	return docStop;

epilog

	delete cmifDAC;

end;</source>
        <access>protected</access>
        <Parameter name="_ti" type="CM_TrackedItem" usage="input"/>
        <Parameter name="_amount" type="Real"/>
        <Parameter name="_stopTable" type="CM_StopsTable"/>
        <ReturnType type="CM_DocumentStops"/>
    </JadeMethod>
    <JadeMethod name="createDocumentTaskForTi" id="a7f1f543-1bbe-4e33-9d76-6d59927af781">
        <source>createDocumentTaskForTi( _ti : CM_TrackedItem input; _amount : Real; _taskDesc : CM_ToDoTaskDesc; _remarks : String ) : CM_DocumentToDoTask protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 September 2016	cnwndl1	Initial creation	TFS 2644

*/

vars

	docTask : CM_DocumentToDoTask;
	cmifDAC : CMIF_DocumentActionTrxCont;

begin

	docTask :=  self.allDocumentTasksApplied.getDocTask( _ti, _taskDesc );	//05 Oct 2016	NDL	TFS 2001 / 2792

	if docTask = null then
		create docTask;
		docTask.setDetails( _ti, _amount, _taskDesc, _remarks, self );
	else
		docTask.setDetails( _ti, docTask.amount + _amount, _taskDesc, _remarks, self );
	endif;
	
	create cmifDAC transient;
	cmifDAC.type := TRANS_TYPE_TASKADD_DA;
	cmifDAC.myToDoTaskDesc := _taskDesc;
	cmifDAC.noCharge := false; //TFS 3844 changed to false
	cmifDAC.myTerminal := _ti.myTerminal;
	cmifDAC.myTrackedItem := _ti;
	cmifDAC.amount := docTask.amount;
	cmifDAC.myDocumentActions := self;
	
	_ti.createTransaction(cmifDAC, app.myPassport);
	
	return docTask;

epilog

	delete cmifDAC;

end;</source>
        <access>protected</access>
        <Parameter name="_ti" type="CM_TrackedItem" usage="input"/>
        <Parameter name="_amount" type="Real"/>
        <Parameter name="_taskDesc" type="CM_ToDoTaskDesc"/>
        <Parameter name="_remarks" type="String"/>
        <ReturnType type="CM_DocumentToDoTask"/>
    </JadeMethod>
    <JadeMethod name="findMatchingStopApplied" id="e50a1adc-4374-4bb7-a700-87deb40b9c68">
        <source>findMatchingStopApplied( _docStop : CM_DocumentStops ):CM_DocumentStops;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 November 2016	cnwndl1	Initial creation	TFS 2968

*/

vars

	docStop : CM_DocumentStops;

begin

	foreach docStop in self.allDocumentStopsApplied do
		if docStop.myTrackedItem &lt;&gt; _docStop.myTrackedItem then
			continue;
		endif;
		if docStop.myStopsTable &lt;&gt; _docStop.myStopsTable then
			continue;
		endif;
		return docStop;
	endforeach;
	
	return null;

epilog

end;</source>
        <Parameter name="_docStop" type="CM_DocumentStops"/>
        <ReturnType type="CM_DocumentStops"/>
    </JadeMethod>
    <JadeMethod name="findMatchingTaskApplied" id="7bc5427d-03d5-4dc2-99db-1f709c52c47d">
        <source>findMatchingTaskApplied( _docTask : CM_DocumentToDoTask ):CM_DocumentToDoTask;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 November 2016	cnwndl1	Initial creation	TFS 2968
05 Jan 2017	NDL	TFS 3156

*/

vars

	docTask : CM_DocumentToDoTask;

begin

	foreach docTask in self.allDocumentTasksApplied do
		if docTask.myTrackedItem &lt;&gt; _docTask.myTrackedItem then
			continue;
		endif;
		if docTask.toDoTaskDesc &lt;&gt; _docTask.toDoTaskDesc then
			continue;
		endif;
		return docTask;
	endforeach;
	
	return null;

epilog

end;</source>
        <Parameter name="_docTask" type="CM_DocumentToDoTask"/>
        <ReturnType type="CM_DocumentToDoTask"/>
    </JadeMethod>
    <JadeMethod name="getActionsSummary" id="bbb2acfb-69aa-4055-a90a-d5a4d5cb35bb">
        <source>getActionsSummary( _short : Boolean ):String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 September 2016	cnwndl1	Initial creation	TFS 2647 / 2001

*/

vars

	retStr : String;

begin

	if not self.allStopTablesToAdd.isEmpty then
		if self.allStopTablesToAdd.size = 1 then
			retStr := "1 stop";
		else
			retStr := self.allStopTablesToAdd.size.String &amp; " stops";
		endif;
	endif;
	if not self.allTaskDescsToAdd.isEmpty then
		if retStr &lt;&gt; null then
			retStr := retStr &amp; ", ";
		endif;
		if self.allTaskDescsToAdd.size = 1 then
			retStr := retStr &amp; "1 task";
		else
			retStr := retStr &amp; self.allTaskDescsToAdd.size.String &amp; " tasks";
		endif;
		
	endif;
	
	if retStr &lt;&gt; null then
		retStr := "(" &amp; retStr &amp; ")";
	endif;
	
	return retStr;

epilog

end;</source>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getAllTis" id="c961dff1-6a1b-438b-9bf2-6f250538d68b">
        <source>getAllTis(	_tiArray : CM_TIArray input );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 September 2016	cnwndl1	Initial creation	TFS 2649 / 2001

*/

vars

	iter : Iterator;
	docStop : CM_DocumentStops;
	docTask : CM_DocumentToDoTask;
	ti : CM_TrackedItem;

begin

	_tiArray.clear();

	iter := self.allDocumentStopsApplied.createIterator;
	while iter.next(docStop) do
		ti := docStop.myTrackedItem;
		_tiArray.addExclusive( ti );
	endwhile;
	delete iter;
	
	iter := self.allDocumentTasksApplied.createIterator;
	while iter.next(docTask) do
		ti := docTask.myTrackedItem;
		_tiArray.addExclusive( ti );
	endwhile;
	
epilog

	delete iter;

end;</source>
        <Parameter name="_tiArray" type="CM_TIArray" usage="input"/>
    </JadeMethod>
