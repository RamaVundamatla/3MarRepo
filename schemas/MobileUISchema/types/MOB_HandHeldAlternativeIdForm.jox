    <JadeMethod name="doResizeControls" id="3b402067-c883-44e9-b739-7bfaf73ca163">
        <updating/>
        <source>doResizeControls(_initialSetup: Boolean) updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 February 2015	cnwndl1	Initial creation	Par 35604

*/

vars

	top 		: Real;
	stdWidth 	: Real;
	stdHeight 	: Real;

begin

	self.setResizeableMarginAndFontSize();
	top := self.resizedMargin;
	stdWidth := self.clientWidth - ( self.resizedMargin * 2 );
	stdHeight := self.getStdControlHeight;
	
	if _initialSetup then
		self.lblAlternativeId.visible := true;
	endif;
	self.lblAlternativeId.move(	self.resizedMargin,
								top,
								stdWidth,
								stdHeight
								);
					 
	top := lblAlternativeId.top + lblAlternativeId.height + self.resizedMargin;
	if _initialSetup then
	self.txtAlternativeId.visible := true;
	endif;
	self.txtAlternativeId.move(	self.resizedMargin,
								top,
								stdWidth - self.resizedMargin,
								stdHeight
								);
								
	if _initialSetup then
		if self.myTrackedItem &lt;&gt; null then
			self.txtAlternativeId.text := self.myTrackedItem.alternativeId;
		endif;
	endif;
	
	top := self.txtAlternativeId.top + self.txtAlternativeId.height + self.resizedMargin;
	self.chkToDo.move(	self.resizedMargin,
						top,
						((stdWidth * 2) / 3),
						stdHeight
						);

	inheritMethod(_initialSetup);

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_initialSetup" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doSave" id="0c888f90-31c9-458d-bc7b-8897b37ffd78">
        <source>doSave() : Boolean;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 15/07/2014	cnwdap1		Initial creation PAR #34568 CCMS SFW 1389 Alternative Id Cargo Check
//
vars
	sessionAgent 	: CM_MobileAgent;
	proxyTi 		: CM_TrackedItem;
	realTi 			: CM_TrackedItem;
	addingToDo		: Boolean;
	alternativeId	: String;
	toDoTaskDesc	: CM_ToDoTaskDesc;
	updateRequired	: Boolean;
	errors			: String;

begin
	app.mousePointer := self.MousePointer_HourGlass;
	
	sessionAgent := self.getSessionAgent;
	proxyTi := sessionAgent.getMyProxyObject.CM_TrackedItem;
	if proxyTi = null then
		return false;
	endif;
	realTi := proxyTi.pxyGetRealObject().CM_TrackedItem;
	
	addingToDo := self.chkToDo.value;
	alternativeId := self.txtAlternativeId.text.trimBlanks;
	
	if self.myCargoCheckItem &lt;&gt; null then			
		toDoTaskDesc := self.myCargoCheckItem.myToDoTaskDesc;
	endif;
	
	if realTi = null then
		updateRequired := true;
	else
		if addingToDo then
			if toDoTaskDesc &lt;&gt; null and not realTi.allToDoTasksToDo.includesToDoDesc(toDoTaskDesc.code) then
				// its not there and we want it added.
				updateRequired := true;
			endif;
		else
			if toDoTaskDesc &lt;&gt; null and realTi.allToDoTasksToDo.includesToDoDesc(toDoTaskDesc.code) then
				// it is there and we no longer want it.
				updateRequired := true;
			endif;
		endif;
		if not updateRequired then
			if alternativeId &lt;&gt; null and alternativeId &lt;&gt; realTi.alternativeId then
				updateRequired := true;
			endif;
		endif;
	endif;
	
	if not updateRequired then
		// no updating to do.
		return true;
	endif;
	
	if sessionAgent.updateAlternativeId(	alternativeId,
											toDoTaskDesc,
											addingToDo	) then
		return true;
	else
		errors := app.myPassport.getAllErrorsWarningsAsString.trimBlanks;
		if errors &lt;&gt; null then
			self.msgBox(errors, app.getErrorString(Error), MsgBox_OK_Only, true);
		endif;
		return false;
	endif;
	
epilog
	app.mousePointer := self.MousePointer_Default;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="handleBtnOne" id="4a5236cf-8a78-475f-8ca9-d8c918de3b5f">
        <updating/>
        <source>handleBtnOne() updating, protected;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 15/07/2014	cnwdap1		Initial creation PAR #34568 CCMS SFW 1389 Alternative Id Cargo Check
//
vars

begin
	if self.doSave() then
		self.doBackButtonClick();
	endif;

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
