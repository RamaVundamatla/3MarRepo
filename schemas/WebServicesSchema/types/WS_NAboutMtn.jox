<Class name="WS_NAboutMtn" id="a6de5388-5f26-4b8d-9d46-9473cfc3b5fb">
    <superclass name="WS_NAPIObject"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="restwebservice"/>
    <PrimAttribute name="appName" id="79984039-77b4-452f-be67-d9cc5df1472d">
        <type name="String"/>
    </PrimAttribute>
    <PrimAttribute name="currentTerminal" id="4225b932-7b1d-41dc-810a-5dfb1d961466">
        <type name="String"/>
    </PrimAttribute>
    <PrimAttribute name="mtnBuild" id="2544897c-2da0-4f0a-b258-d327df50654f">
        <type name="String"/>
    </PrimAttribute>
    <PrimAttribute name="mtnVersion" id="a3e91c66-c0f7-406c-946d-bd8ab360f9fd">
        <type name="String"/>
    </PrimAttribute>
    <PrimAttribute name="userName" id="9e536b7a-da87-4806-b995-ee64b9025cc9">
        <type name="String"/>
    </PrimAttribute>
    <JadeMethod name="create" id="91a818bb-775c-4d20-9ce4-adeaa01ffff6">
        <updating/>
        <source>create() updating;
/*

Purpose:			
	Set default application details on create
Parameters:			

Return Value:		

Date		Who		Reason
30 April 2020	jlgrr1	Initial creation

*/

vars

begin
	self.setDetails();
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setDetails" id="b721e143-2060-4724-b08b-1b37d50d0a72">
        <updating/>
        <source>setDetails() updating;
/*

Purpose:			
	Set current About Details
Parameters:			
	None
Return Value:
	None

Date		Who		Reason
30 April 2020	jlgrr1	Initial creation based on WS_AboutMtm setDetails

*/

vars

begin

	self.appName 		:= app.niceName;
	if self.appName = null then
		self.appName := app.name;
	endif;
	
	self.mtnBuild		:= app.getJMTReleaseExtractTime.asStringForWebInterface();
	self.mtnVersion 	:= app.myRoot.getVersionAndPatchLevelDisplay();
	
	if app.myPassport &lt;&gt; null then
			
		if app.myPassport.myTerminal &lt;&gt; null then
			self.currentTerminal := app.myPassport.myTerminal.code;
		endif;
		if app.myPassport.myUser &lt;&gt; null then
			self.userName := app.myPassport.myUser.userName;
		endif;
	endif;
	
epilog

end;</source>
    </JadeMethod>
</Class>
