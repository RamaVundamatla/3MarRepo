    <JadeMethod name="handleDestinationPort" id="9fd3677e-c958-49be-bc20-6c5462260e0a">
        <source>handleDestinationPort(_portCode : String; _code : String output; _color :Integer output; _object : Object output) protected;
/*

Purpose:			


Return Value:		


Date		Who		Reason
22 March 2007	cnwer1	Initial creation - PAR#13694

*/
vars
	iter		: Iterator;
	trimCode,
	theCode,
	codeKey		: String;
	theColor,
	colorKey	: Integer;
	tmpPort		: CM_Port;
	theObject : Object;
begin
	trimCode := _portCode.trimBlanks;
	
	if trimCode = null then
		_code	:= null;
		_color	:= NullColour;
		return;
	endif;

	iter := self.allDestinationPorts.createIterator;
	self.allDestinationPorts.startKeyGeq(trimCode, 0, iter);
	self.allDestinationPorts.getIteratorKeys(codeKey, colorKey, iter);
	
	if codeKey = trimCode then
		// found the right one
		theCode		:= _portCode;
		theColor	:= colorKey;
		iter.next(theObject);
	else
		//tmpPort := self.myRoot.allPorts[trimCode];
		tmpPort := self.myRoot.allPorts[trimCode];
		if tmpPort &lt;&gt; null then
		
			self.allDestinationPorts.addNoDuplicates(tmpPort,false);
			self.beginNotification(tmpPort, EVENT_CODE_COLOUR_CHANGE, Response_Continuous, null);
			theCode		:= trimCode;
			theColor	:= tmpPort.colour;
			theObject := tmpPort;
		else
			theCode		:= null;
			theColor	:= NullColour;
			theObject := null;
		endif;
	endif;

	_code	:= theCode;
	_color	:= theColor;
	_object := theObject;

	
epilog
	delete iter;
end;</source>
