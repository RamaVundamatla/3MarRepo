    <JadeMethod name="buildContextMenu" id="326641fb-6bef-47d6-98d9-feeff3991388">
        <updating/>
        <source>buildContextMenu(table: Table input; conwin: Window input; mouse: Boolean; x: Integer; y: Integer): Boolean updating, protected;
// ---------------------------------------------------------------------------
// Created:	09 January 2009 By Graeme Black cnwgb1
// Status: 	Unfinished
// Purpose:	
// ---------------------------------------------------------------------------
vars
begin
	if not self.isMenuBuilt then
		self.setupMenu();
		self.isMenuBuilt := true;
	endif;
	if isMenuItemsVisible then
		return self.showContextMenu( self.mnuContext, table, conwin, mouse, x, y);
	endif;
	return false;
epilog
end;</source>
        <access>protected</access>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="conwin" type="Window" usage="input"/>
        <Parameter name="mouse" type="Boolean"/>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doDisplay" id="da7e448a-60c3-4d28-bca3-607c6a6f4b05">
        <source>doDisplay() protected;
// ---------------------------------------------------------------------------
// Created:	30 December 2008 By Graeme Black cnwgb1
// Status: 	Unfinished
// Purpose:	
// ---------------------------------------------------------------------------
// Changed On	By			Reason
// ----------	--------	--------------------------------------------------
// 16/11/2016	cnwdap1		TFS 2842 STWR Hazardous Details Enhancements
vars

	row : EntTableRow;
	dataValue : String;
	rowIndex : Integer;
	rowName : String;
	skip : Boolean;
	msg : String;
	group : EntTableGroup;
	
begin

	if self.myHandHeldConfig &lt;&gt; null then
	
		tblResults.rows := 1;
	
		self.tblResults.setCellText( 1,1, app.getErrorString(Heading_Attribute) &amp; Tab &amp; app.getErrorString(Value) );
	
		on Exception do self.handleUnknownPropertyValue( exception, rowName, skip );
	
		foreach row in self.myHandHeldConfig.allVisibleViewRows do
			rowName := row.name;
			skip := false;
			if self.myTrackedItem &lt;&gt; null then
				dataValue := self.myTrackedItem.getDisplayStringForAttribute( rowName, true );
			endif;
			if not skip then
				rowIndex := self.tblResults.addItem( row.getRawHeadingValue &amp; Tab &amp; dataValue );
			endif;
		endforeach;
		
		if self.tblResults.rows = self.tblResults.fixedRows then
			group := app.myRoot.myEntTableDataRoot.allEntTableGroups.getAtKey(ETGrp_CargoDetails);
			row := group.allEntTableRowsByName.getAtKey(ETRow_CargoId);
			rowName := row.name;
			skip := false;
			if self.myTrackedItem &lt;&gt; null then
				dataValue := self.myTrackedItem.getDisplayStringForAttribute( rowName, true );
			endif;
			if not skip then
				rowIndex := self.tblResults.addItem( row.getRawHeadingValue &amp; Tab &amp; dataValue );
			endif;
		endif;
	
	else

	// fast way of clearing the column
		tblResults.columns := 1;
		tblResults.columns := 2;	
		
		if self.myTrackedItem &lt;&gt; null then
			self.tblResults.accessCell(1,2).text := self.myTrackedItem.alternativeId;
			if self.myTrackedItem.myOperator &lt;&gt; null then
				self.tblResults.accessCell(2,2).text := self.myTrackedItem.myOperator.description;
			else
				self.tblResults.accessCell(2,2).text := null;
			endif;
			self.tblResults.accessCell(3,2).text := self.systemToLocalTime(self.myTrackedItem.receivedDT).asStringJMT();	// 9/6/16 cnwmp6 TFS 488 - Multi timezone support
			if self.myTrackedItem.isCargoGroupItem then	//28 Sep 2015	NDL	Par 36338
				self.tblResults.accessCell(4,2).text := self.myTrackedItem.CM_CargoGroup.getDisplayStringForAttribute(ETRow_GroupLocation,false);
			else
				self.tblResults.accessCell(4,2).text := self.myTrackedItem.locationId;
			endif;
			self.tblResults.accessCell(5,2).text := self.myTrackedItem.getISOType();
			self.tblResults.accessCell(6,2).text := self.myTrackedItem.remarks;
			self.tblResults.accessCell(7,2).text := self.myTrackedItem.commodity;
			self.tblResults.accessCell(8,2).text := self.myTrackedItem.voyageCode;
			self.tblResults.accessCell(9,1).text := app.getErrorString(CM_Weight) &amp; self.myMobileDataAgent.getMeasureLabelUnit(self.myTrackedItem.getProductForMeasurementConv(),Type_Weight);
			self.tblResults.accessCell(9,2).text :=  self.myMobileDataAgent.getMeasureConvertedForDisplay(self.myTrackedItem.getProductForMeasurementConv(), Type_Weight, self.myTrackedItem.totalWeight); //cnwerd1 ccms 1321 
			self.tblResults.accessCell(10,2).text := self.myTrackedItem.getImExStatusString();
			self.tblResults.accessCell(11,2).text := self.myTrackedItem.dischargePort;
			self.tblResults.accessCell(12,2).text := self.myTrackedItem.getStopsDesc;
			self.tblResults.accessCell(13,2).text := self.myTrackedItem.toDoRemarks;
			self.tblResults.accessCell(14,2).text := self.myTrackedItem.getAvailGradeCodeAndDesc;	//24 Mar 2011	NDl	Par 27277
			self.tblResults.accessCell(15,2).text := self.myTrackedItem.getHazardsAsString;			// TFS 2842
					
		endif;
	
	endif;

epilog
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="getHelpDescr" id="2e7ffa0c-1614-4c6c-a04f-b4ffdf5393d5">
        <source>getHelpDescr(): String;
/*
Date		Who		Reason
03 February 2009	cnwcp2	Initial creation
*/

vars

begin
	return self.HELP_DESCRIPTION;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="handleUnknownPropertyValue" id="88a12abe-7a1a-43cc-baab-c39823a22b57">
        <source>handleUnknownPropertyValue(_exc : Exception; _attr : String; _skip : Boolean output) : Integer;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 December 2016	cnwndl1	Initial creation	TFS 3052/2420

*/

constants
	InvalPropertyValue	= 1011;
vars
	returnVal : Integer;
begin
	returnVal := Ex_Pass_Back;
	
	if _exc.errorCode = InvalPropertyValue then
		if _exc.resumable then
			_skip := true;
			returnVal := Ex_Resume_Next;
		endif;
	endif;
epilog
	return returnVal;
end;</source>
        <Parameter name="_exc" type="Exception"/>
        <Parameter name="_attr" type="String"/>
        <Parameter name="_skip" type="Boolean" usage="output"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="mnuDocActions_click" id="0bbbe9cb-21c3-4504-ba99-0c097b843652">
        <controlMethod name="MenuItem::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>mnuDocActions_click(menuItem: MenuItem input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 September 2016	cnwndl1	Initial creation

*/

vars

	resDetailSet : CM_ReserveDetailSet;
	bookingItemSet : CM_BookingRefItemSet;

begin

	create resDetailSet transient;
	create bookingItemSet transient;
	
	if self.myTrackedItem &lt;&gt; null and self.myTrackedItem.hasDocumentActions( resDetailSet, bookingItemSet ) then
	
		self.myMobileGenericAgent.setAllReserveDetails( resDetailSet );
		self.myMobileGenericAgent.setAllBookingRefItems( bookingItemSet );
		self.myMobileGenericAgent.setMyNextTiToAction( self.myTrackedItem );
		self.gotoForm( MOB_HHDocumentActions, false );
		
	endif;

epilog

	delete resDetailSet;
	delete bookingItemSet;

end;</source>
        <Parameter name="menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
