    <JadeMethod name="setDownloadFileRemoteCopy" id="074ec8af-c238-419d-bd78-30b71ccfb593">
        <updating/>
        <source>setDownloadFileRemoteCopy(_downloadFileRemoteCopy:Boolean) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
03 August 2010	#cnwdz2	 

*/

vars

begin
	self.downloadFileRemoteCopy := _downloadFileRemoteCopy;
epilog

end;</source>
        <Parameter name="_downloadFileRemoteCopy" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setForProxy" id="cabe9669-83a7-498b-819a-34151706d08d">
        <updating/>
        <source>setForProxy(	_login,	
				_currentReports,
				_changePassword,	
				_download,
				_info,
				_list,
				_output,
				_criteria,
				_headerIn,
				_headerOut,
				_footer,
				_schema,
// cnwdad1 25/10/2005 - PAR #10900.
//				_directory,
				_name:String;
				_isSecure:Boolean;
				_userCode,
				_virtualDirectory,
				_machineName,
				_eventReqStopMaintPage,
				_eventReqStopViewPage,
				_eventNotifyMaintPage,
				_eventNotifyViewPage,
				_prenoteMaintPage,
				_prenoteViewPage	: String;
				_sessionTimeout		: Integer;
				_pdfPrinter			: CM_PrinterDef;
				_webApplicationName : String;
				_root				: CM_Root;
				_downloadFileDirPath,			// cnwrd1
				_downloadFileDirURL	: String; 	// cnwrd1
				_downloadFileTimeout : Integer;	// cnwrd1	
				_helpFileURL : String; //cnwrd1
				_downloadFileRemoteCopy : Boolean; // 27/07/2010 cnwdz2 24674
				_defaultLoggingLevel,			// TFS 51054 navmd1 01/04/21
				_responseTimeout	: Integer	// TFS 42010 navmd1 07/04/21
				) updating;
// -------------------------------------------
// Created 24 November 2004 by cnwdvb1
// -------------------------------------------
vars

begin

	self.loginPage 				:= _login;
	self.currentReportsPage		:= _currentReports;
	self.changePasswordPage		:= _changePassword;
	self.infoPage				:= _info;
	self.listPage				:= _list;
	self.outputPage				:= _output;
	self.criteriaPage			:= _criteria;
	self.headerInPage			:= _headerIn;
	self.headerOutPage			:= _headerOut;
	self.footerPage				:= _footer;
	self.schemaName				:= _schema;
// cnwdad1 25/10/2005 - PAR #10900.
//	self.directoryPath			:= _directory;
	self.name					:= _name;
	self.isSecure				:= _isSecure;
	self.publicUser				:= _userCode;
	self.sessionTimeoutMinutes	:= _sessionTimeout;
	self.virtualDirectory		:= _virtualDirectory;
	self.machineName			:= _machineName;
	self.myPDFPrinter			:= _pdfPrinter;
	self.eventReqStopMaintPage := _eventReqStopMaintPage;
	self.eventReqStopViewPage := _eventReqStopViewPage;
	self.eventNotifyMaintPage := _eventNotifyMaintPage;
	self.eventNotifyViewPage := _eventNotifyViewPage;
	self.prenoteMaintPage		:= _prenoteMaintPage;
	self.prenoteViewPage		:= _prenoteViewPage;
	self.webApplicationName		:= _webApplicationName;
	self.myRoot					:= _root;
	
	//web service
	self.downloadFileDirectoryPath 	:= _downloadFileDirPath;
	self.downloadFileDirectoryURL 	:= _downloadFileDirURL;
	self.downloadFileTimeout		:= _downloadFileTimeout;
	self.helpFileURL				:= _helpFileURL;
	
	self.downloadFileRemoteCopy := _downloadFileRemoteCopy; //27/07/2010 cnwdz2 24674
	self.defaultLoggingLevel := _defaultLoggingLevel;	// TFS 51054 navmd1 01/04/21
	self.responseTimeoutSecs := _responseTimeout;		// TFS 42010 navmd1 07/04/21
end;</source>
