//showDamageEntryForm(_parentForm: CM_BaseForm; _mode : Integer; _term : CM_Terminal; _pxy, _real : CM_Object; _damage : CM_DamageInstanceByDmgePos; _masterMenuAction : CMUI_MenuAction);

