<Class name="CM_BackgroundNodeAgent" id="258f6b90-4250-4cd5-82aa-a4df2337be18">
    <superclass name="CM_Agent"/>
    <transient/>
    <sharedTransientAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="cmtrans"/>
    <Constant name="IniFileSectionName" id="890ae784-e7bf-4422-a120-ef31e10d6410">
        <source>"CM_BackgroundNodeAgent"</source>
        <type name="String"/>
    </Constant>
    <Constant name="LogStableCollectionInfo" id="541e1042-48b6-46dc-a23c-c16aebc25c81">
        <source>"LogStableCollectionInfo"</source>
        <type name="String"/>
    </Constant>
    <Constant name="TimerDelay" id="6618093b-027a-4e2b-b604-aa4606105fcf">
        <source>"TimerDelay"</source>
        <type name="String"/>
    </Constant>
    <Constant name="TimerTag" id="15ee23cf-8571-4738-8f20-d6c747f6c360">
        <source>29384</source>
        <type name="Integer"/>
    </Constant>
    <PrimAttribute name="logCollectionInfo" id="cdcc0ff1-f5c5-4451-b9ce-91a477ac3a79">
        <embedded/>
        <type name="Boolean"/>
        <access>readonly</access>
    </PrimAttribute>
    <CompAttribute name="stableRootCollNames" id="b12dd694-90d3-4e12-ad1a-41cc2507c79c">
        <type name="StringArray"/>
        <access>readonly</access>
    </CompAttribute>
    <CompAttribute name="stableTerminalCollNames" id="4ceea4e7-c510-4323-b2f7-0866efbef1b8">
        <type name="StringArray"/>
        <access>readonly</access>
    </CompAttribute>
    <PrimAttribute name="timeLastCheckComplete" id="6eb83367-bfa7-4a69-ab42-9f82c1186b34">
        <embedded/>
        <type name="TimeStamp"/>
        <access>readonly</access>
    </PrimAttribute>
    <PrimAttribute name="timerDelayMinutes" id="2ca4065d-48e2-40e9-ba6b-3e04104f9736">
