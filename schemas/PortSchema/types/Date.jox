//
//	Purpose:	Nice name in report writer	
//
//----------------------------------------------------------------
vars

begin

	if self &lt;&gt; null and self.isValid then
		return (self.year - self.format("yy").Integer) div 100;
	else
		return 0;
	endif;
	
end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getFirstBusinessDayOfMonth" id="f5193f24-8552-41c9-b45c-ef1cc7a04f75">
        <source>getFirstBusinessDayOfMonth():Date;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
27 October 2010	cnwndl1	Initial creation	Par 25530 - As per Bishs instructions.
														until a configurable option is created.

*/

vars

	date : Date;
	pos : Integer;
	terminal : CM_Terminal;
	
begin

	if app.myPassport &lt;&gt; null then
		terminal := app.myPassport.myTerminal;
	endif;

	date.setDate( pos, self.month, self.year );
	
	foreach pos in 1 to 31 do
		date.setDate( pos, self.month, self.year );
		if not date.isValid then
			return null;
		endif;
		if date.dayOfWeek = 6 or date.dayOfWeek = 7 then
			// can't be a saturday or sunday.
			continue;
		endif;
		if terminal &lt;&gt; null then
			if terminal.isDateAHoliday(date) then
				// can't be a day declared as a holiday
				continue;
			endif;
		endif;
		return date;
	endforeach;

	return null;
	
epilog

end;</source>
        <ReturnType type="Date"/>
    </JadeMethod>
    <JadeMethod name="getISOWeekNumber" id="10658935-f027-4a05-a387-616bac476a93">
        <source>getISOWeekNumber() : Integer;

/*

Purpose:		Return ISO week number from passed in date	

Date			Who		Reason
17/09/2015		cnwmh5	Initial creation

*/
constants

	MnthDayCount						: String = "0,31,59,90,120,151,181,212,243,273,304,334";

vars

	monthDayCountArray					: StringArray;
	
	dayOfYearNumber						: Integer;
	jan1WeekDay							: Integer;
	weekNumber							: Integer;
	weekDay								: Integer;
	tempInt1							: Integer;
	tempInt2							: Integer;
	tempInt3							: Integer;
	yearNumber							: Integer;
	yyyy								: Integer;

begin

	create monthDayCountArray transient;
	MnthDayCount.getTokensForDelimiter(",", monthDayCountArray);
	
	yyyy := self.year;
	
	// Set DayofYear Number for yyyy mm dd
	dayOfYearNumber := self.day + monthDayCountArray[self.month].Integer;
	
	// Increase of Dayof Year Number by 1, if year is leapyear and month is february
	if isLeapYear() and self.month = 2 then
		dayOfYearNumber := dayOfYearNumber + 1;
	endif;
	
	// Find the Jan1WeekDay for year 
	tempInt1 := (yyyy - 1) mod 100;
	tempInt2 := (yyyy - 1) - tempInt1;
	tempInt3 := tempInt1 + (tempInt1 / 4).Integer;
	jan1WeekDay := 1 + (((((tempInt2 / 100) mod 4).Integer * 5) + tempInt3) mod 7).Integer;
	
	  // Calcuate the WeekDay for the given date
	tempInt1 := dayOfYearNumber + (jan1WeekDay - 1);
	weekDay := 1 + ((tempInt1 - 1) mod 7).Integer;
	
	// Find if the date falls in YearNumber set WeekNumber to 52 or 53
	if ((dayOfYearNumber &lt;= (8 - jan1WeekDay)) and (jan1WeekDay &gt; 4)) then
		yearNumber := yyyy - 1;
		if ((jan1WeekDay = 5) or ((jan1WeekDay = 6) and (jan1WeekDay &gt; 4))) then
			weekNumber := 53;
		else
			weekNumber := 52;
		endif;
	else
		yearNumber := yyyy;
	endif;
	
	// Set WeekNumber to 1 to 53 if date falls in YearNumber
	if yearNumber = yyyy then
		if isLeapYear() then
			tempInt1 := 366;
		else
			tempInt1 := 365;
		endif;
		if ((tempInt1 - dayOfYearNumber) &lt; (4 - weekDay)) then
			yearNumber := yyyy + 1;
			weekNumber := 1;
		endif;
	endif;
	
	if yearNumber = yyyy then
		tempInt1 := dayOfYearNumber + (7 - weekDay) + (jan1WeekDay - 1);
		weekNumber := (tempInt1 / 7).Integer;
		if jan1WeekDay &gt; 4 then
			weekNumber := weekNumber - 1;
		endif;
	endif;
		
	return weekNumber;
	
epilog

	delete monthDayCountArray;

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getLastBusinessDayOfMonth" id="ddfc5d0e-60a4-433e-91b6-53958a4a572f">
        <source>getLastBusinessDayOfMonth():Date;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
27 October 2010	cnwndl1	Initial creation	Par 25530 - As per Bishs instructions.
														until a configurable option is created.

*/

vars

	date : Date;
	pos : Integer;
	terminal : CM_Terminal;
	
begin

	if app.myPassport &lt;&gt; null then
		terminal := app.myPassport.myTerminal;
	endif;

	date.setDate( pos, self.month, self.year );
	
	foreach pos in 1 to 31 reversed do
		date.setDate( pos, self.month, self.year );
		if not date.isValid then
			continue;
		endif;
		if date.dayOfWeek = 6 or date.dayOfWeek = 7 then
			// can't be a saturday or sunday.
			continue;
		endif;
		if terminal &lt;&gt; null then
			if terminal.isDateAHoliday(date) then
				// can't be a day declared as a holiday
				continue;
			endif;
		endif;
		return date;
	endforeach;

	return null;
	
epilog

end;</source>
        <ReturnType type="Date"/>
    </JadeMethod>
    <JadeMethod name="getNearestDay" id="3f015b8a-cf84-43b5-bab2-c883f2ad3be1">
        <source>getNearestDay(_day : Integer) : Date;
// ### TFS BUG 65740 23AUG2024 NAVAB1
vars
	dayNum, daysDiff, dayOfWeek : Integer;
begin
	dayOfWeek := _day;
	if dayOfWeek &gt; 7 then
		dayOfWeek := _day - 84588; // SHIFT_Monday constant
	endif;
	
	dayNum := self.dayOfWeek();
	daysDiff := dayOfWeek - dayNum;
	
	return self.addDays(daysDiff);

	
epilog

end;</source>
        <Parameter name="_day" type="Integer"/>
        <ReturnType type="Date"/>
    </JadeMethod>
    <JadeMethod name="getValidSQLDate" id="afc60c4e-742e-4013-94fa-ef0b053fa259">
        <source>getValidSQLDate() : Date;
/*
Purpose:			Check that Date is valid before using
					it in SQL Bulk data extract

Parameters:			

Return Value:		a valid time or a null time

Date			Who		Reason
01 June 2010	conkc1	Initial creation
*/
vars

begin
	if self.isValid = false then
		return null;
	endif;
		
	if self &lt; "1901/01/01".Date then
		return "1901/01/01".Date;
	endif;
	
	return self;
epilog

end;</source>
        <ReturnType type="Date"/>
    </JadeMethod>
    <JadeMethod name="getValidSQLDate2005" id="b50b04d1-c5e5-4001-a8b0-5d943a151085">
        <source>getValidSQLDate2005() : TimeStamp;
//
//  Converts a Date into a Timestamp for SQL 2005 and below releases
// PAR 24641
vars
	ts   : TimeStamp;
	date : Date;
begin
	date := getValidSQLDate;
	if date = null then
		date := "1900/01/01".Date;
	endif;

	ts.setDate(date);
	ts.setTime(null);
	return ts;

end;
</source>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="getWeek" id="f8066734-03ee-4e5c-9174-1a8a009b3808">
        <source>getWeek(): Integer;
//----------------------------------------------------------------
//	Created:	25 November 2005	by Jason Chapman  (cnwjc2)
//
//	Purpose:	Nice name in report writer	

//	05 Feb 2019	NDL	TFS 43235
//
//----------------------------------------------------------------
vars

	jan01 : Date;
	dayOfWeekJan1 : Integer;
	offset : Integer;
	totalDays : Integer;
	week : Integer;
	remainder : Real;

begin

	// get the day of the week for the first day of the year
	jan01.setDate(01, 01, self.year);	
	dayOfWeekJan1 := jan01.dayOfWeek;
	
	//if '01 jan' is a tuesday, the first week only has 6 days in it etc. 
	// So work out the offset for the year based on the first day
	offset := ( dayOfWeekJan1 - 1 ); // mon= 0, tue = 1, wed = 2... sun = 6
	
	totalDays := self.dayOfYear + offset;

	week :=  totalDays div 7;
	remainder := totalDays mod 7;
	if remainder &gt; 0 then
		week := week + 1;
	endif;
	
	return week;
	
end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
