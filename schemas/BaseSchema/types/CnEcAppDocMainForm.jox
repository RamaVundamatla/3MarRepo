    <JadeMethod name="queryUnload" id="3bf383e1-d70f-4f07-9668-a10e8cd5f981">
        <controlMethod name="Form::queryUnload"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>queryUnload(cancel: Integer io; reason: Integer) updating;
// --------------------------------------------------------------------------------
// Created:		23 December 2007 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if not self.doCheckForSave() then
		cancel	:=	1;
	endif;
end;</source>
        <Parameter name="cancel" type="Integer" usage="io"/>
        <Parameter name="reason" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="resetIsChanged" id="b221f91e-741f-465a-bf75-5e29be815eb8">
        <updating/>
        <source>resetIsChanged() updating, protected;
// --------------------------------------------------------------------------------
// Created:		23 December 2007 by cnwdad1
//
// Purpose:		Resets the flag which indicates that the form details have been
//				changed.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.aIsChanged	:=	false;
	btnSave.enabled	:=	false;
	self.resetFirstChange();
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="rtfDocumentation_firstChange" id="da0de20e-881c-44f5-8d41-b6735181dd2b">
        <controlMethod name="JadeRichText::firstChange"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>rtfDocumentation_firstChange(textbox: JadeRichText input) updating;
// --------------------------------------------------------------------------------
// Created:		23 December 2007 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	btnSave.enabled	:=	true;
	self.aIsChanged	:=	true;
end;</source>
        <Parameter name="textbox" type="JadeRichText" usage="input"/>
    </JadeMethod>
</GUIClass>
