    <DbClassMap file="basehtml"/>
    <ExplicitInverseRef name="myHead" id="8a7f7e45-ab12-40d2-acfd-68001a6c2463">
        <kind>child</kind>
        <embedded/>
        <type name="CnEcPageHead"/>
        <access>readonly</access>
        <Inverse name="CnEcPageHead::myScriptTag"/>
    </ExplicitInverseRef>
    <PrimAttribute name="scriptCode" id="cf96e94f-4fec-4bf8-a644-879542d2a281">
        <type name="String"/>
        <access>readonly</access>
        <text>The script's program code.</text>
    </PrimAttribute>
    <PrimAttribute name="scriptSource" id="1743c39d-cdff-4af4-9a4d-23acd0666b9f">
        <type name="String"/>
        <text>Specifies the relative or absolute location of a script to include
in the document.</text>
    </PrimAttribute>
    <PrimAttribute name="scriptType" id="2d85fe28-fe6f-4842-b7a1-00092dfef180">
        <type name="String"/>
        <text>Indicates the MIME type of the script.  This is a preferred alternative
to the &lt;LANGUAGE&gt; tag for declaring the type of scripting.  For example:

&lt;SCRIPT TYPE="text/javascript"&gt;
	document.write("&lt;EM&gt;Bewdy Newk!&lt;\/EM&gt;")
&lt;/SCRIPT&gt;</text>
    </PrimAttribute>
    <JadeMethod name="buildTagBody" id="d3c8fa1d-6205-4c96-aa67-2d8762f0d9cf">
        <source>buildTagBody(): String protected;
// --------------------------------------------------------------------------------
// Created:		02 December 2001 by cnwdad1
//
// Purpose:		Refer to the CnEcHtmlTagObject implementation.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	htmlString	: String;
	
begin
	htmlString	:=	'TYPE="' &amp; self.scriptType &amp; '"';
	
	if self.scriptSource &lt;&gt; null then
		htmlString	:=	htmlString &amp; ' SRC="' &amp; self.scriptSource &amp; '"';
	endif;
	
	htmlString	:=	htmlString &amp; inheritMethod() &amp; '&gt;' &amp;
					self.scriptCode;
	
	return htmlString;
end;</source>
        <access>protected</access>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getHtml" id="051ab4ae-59af-439e-9f61-409edcc5f2b5">
        <source>getHtml(): String;
// --------------------------------------------------------------------------------
// Created:		02 December 2001 by cnwdad1
//
// Purpose:		Refer to the CnEcHtmlTagObject implementation.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return '&lt;SCRIPT ' &amp; self.buildTagBody() &amp; '&lt;/SCRIPT&gt;' &amp; CrLf;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="setScriptCode" id="ad31d6bb-edae-4f1b-b63a-34941bcc9055">
        <updating/>
        <source>setScriptCode(pScriptCode:String) updating;
// -----------------------------------------------------------------------------
// Created:		05 December 2001 by cnwdad1
//
// Purpose:		Set the source code for the receiver tag.
//
// Parameters:	pScriptCode - The script source code.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//
// -----------------------------------------------------------------------------
begin
	self.scriptCode	:=	"&lt;!--" &amp; CrLf &amp; pScriptCode &amp; CrLf &amp; "--&gt;";
end;</source>
        <Parameter name="pScriptCode" type="String"/>
    </JadeMethod>
</Class>
