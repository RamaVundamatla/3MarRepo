    <JadeMethod name="doQueryUnload" id="4b658720-2f6b-456b-a1ff-323a3aa05ccc">
        <updating/>
        <source>doQueryUnload(cancel: Integer io; reason: Integer) updating;
//------------------------------------------------
// Created: 17 May 2006 By: cnwgd1
//------------------------------------------------
constants
	CANCEL_UNLOAD = 1;
vars
	result : Integer;
begin

	if self.frmProperties.visible then
		if reason = QueryUnload_User
		or reason = QueryUnload_UnloadMethod
		or reason = QueryUnload_MdiChild then
			result := app.msgBox(app.getErrorString(EditChangedAndClosing), self.caption &amp; " Window Closing !", MsgBox_Yes_No + MsgBox_Question_Mark_Icon);
			if result = MsgBox_Return_No then
				cancel := CANCEL_UNLOAD;	//Do not close form
			endif;			
		endif;
	endif;
end;</source>
        <Parameter name="cancel" type="Integer" usage="io"/>
        <Parameter name="reason" type="Integer"/>
    </JadeMethod>
