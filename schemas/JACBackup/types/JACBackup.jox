//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin
	inheritMethod();

	self.jacInitializeApp();	

end;</source>
    </JadeMethod>
    <JadeMethod name="installScript" id="71045574-d3b7-4238-8b0d-78cbc79d2c9e">
        <updating/>
        <source>installScript() updating;
// ---------------------------------------------------------------------------
// Created:     
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 17/03/2015	cnwmh5		Tranisent Leak
// ---------------------------------------------------------------------------

vars
	file: File;
	fileFolder: FileFolder;
begin
	create file transient;
	file.kind := File.Kind_Unknown_Text; // 2/3/16  cnwns1 PAR 36286 unicode version
	file.mode := File.Mode_IO;
	file.fileName := app.dbPath&amp;"\..\completed.txt";
	if file.isAvailable then
		file.purge;
	endif;
	file.close;
	delete file;

	self.myServerAppObject := JACServerAppObject.firstInstance;
	beginTransaction;
	app.myServerAppObject.setLogCompress(true);
	app.myServerAppObject.setLogVerify(true);
	commitTransaction;
	create fileFolder transient;
	fileFolder.fileName := app.dbPath;
	if fileFolder.isAvailable then
		create file transient;
		file.mode := File.Mode_Output;
		file.fileName := app.dbPath &amp; "\..\completed.txt";
		file.open;
		file.writeLine("Completed");
		file.close;
		delete file;
	endif;
	
epilog
	delete fileFolder;
	terminate;
end;</source>
    </JadeMethod>
    <JadeMethod name="isSDSDatabase" id="eb49542e-bcb1-43c4-84c6-795d7241507a">
        <source>isSDSDatabase():Boolean;
// ---------------------------------------------------------------------------
// Created:     
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
// only return true if the database is SDS configured and licensed
vars

begin
	if self.myDBA.sdsIsInitialized and
	   self.myDBA.sdsIsRunning then
		return true;
	else
		return false;
	endif;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isSDSSecondaryAlive" id="7b5dc6ea-2abd-4905-a079-604b6e7bec45">
        <source>isSDSSecondaryAlive():Boolean;
// ---------------------------------------------------------------------------
// Created:     
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
// return true if the last time we looked the secondary was up and running
vars

begin
	// if we are the secondary we must be alive
	if isSDSSecondaryDB then
		return true;
	endif;
	if not isSDSDatabase then
		return false;
	else
		return true;
	endif;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isSDSSecondaryBackup" id="4857927c-dd7f-4683-acca-bc76300bf786">
        <source>isSDSSecondaryBackup() : Boolean;
/// ---------------------------------------------------------------------------
// Created:     
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
// return true if the database is configured for SD and the user wants to use
// the secondary database to do the backups
vars

begin
	if self.myServerAppObject &lt;&gt; null then
		if self.myServerAppObject.useSDSSecondary
		and self.isSDSDatabase
		then
			return true;
		endif;
	endif;
	
	return false;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isSDSSecondaryDB" id="0da99150-6d04-4dd3-b3ee-a03df96985d4">
        <source>isSDSSecondaryDB(): Boolean;
// ---------------------------------------------------------------------------
// Created:     
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
// return true if this application is running on the SDS secondary database
vars

begin
	// we dont need to check that we are alive
	if self.isSDSDatabase and
	   not app.myDBA.sdsGetDatabaseRole = SDS_PrimaryType then
		return true;
	else
		return false;
	endif;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="jacBackupControlAppInit" id="c302210e-c22f-482a-8115-dccfae02489d">
        <updating/>
        <source>jacBackupControlAppInit() updating;
// ---------------------------------------------------------------------------
// Created:     
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	sched: JACBackupSchedule;
	cont: JACBackupController;
begin

	app.writeLog(class.name&amp;'::'&amp;method.name, LogDebug);
	self.jacInitializeApp();	

	sched := self.myServerAppObject.jacBackupScheduleObjects.getAtKeyGeq(JACBackupActivated, null);
	if sched = null or 
	   sched.status &lt;&gt; JACBackupActivated then
		app.writeLog(class.name&amp;'::'&amp;method.name&amp;" Backup control application started but no schedule object found.", LogAlways);	
		terminate;
	endif;

	beginTransaction;
	process.userInfo:="Backup control application ("&amp;app.name&amp;") running.";
	commitTransaction;

	beginTransientTransaction;
	create cont sharedTransient;
	if app.isSDSSecondaryBackup then
		cont.setBackupPath(sched.splitSecPaths[1]);
	else
		cont.setBackupPath(sched.splitPaths[1]);
	endif;
	cont.setBooleans(sched.verify, sched.compress, sched.overwrite, sched.quiesce, sched.exclude);
	cont.setNumSplits(sched.numSplits);
	cont.setMySchedule(sched);
	commitTransientTransaction;
	sched.setStatusNotify(JACBackupRunning);
	if app.isSDSSecondaryDB then
		sched.setRunOnSecondaryNotify(true);
	endif;
	cont.startBackup;
end;</source>
    </JadeMethod>
    <JadeMethod name="jacBackupServerAppFinalize" id="81408641-40f2-4de7-af0c-ddb355b5f325">
        <updating/>
        <source>jacBackupServerAppFinalize() updating;
// ---------------------------------------------------------------------------
// Created:     
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin
	if app.myServerAppObject &lt;&gt; null then
		app.writeLog(class.name&amp;'::'&amp;method.name&amp;' causeEvent NotifyBackupServerTerminated='&amp;NotifyBackupServerTerminated.String, LogDebug);
		app.myServerAppObject.causeEvent(NotifyBackupServerTerminated, true, null);
		if app.isSDSSecondaryDB then
			// secondary tell primary the control app has stopped
			app.writeLog(class.name&amp;'::'&amp;method.name&amp;' sdsCauseEvent NotifyBackupServerTerminated='&amp;NotifyBackupServerTerminated.String, LogDebug);
			app.myServerAppObject.sdsCauseEvent(NotifySecServerAppStopped, false, null);
		endif;
	endif;

	self.jacFinalizeApp();
epilog
	beginTransientTransaction;
	delete self.myDBA;
	self.myDBA := null;
	commitTransientTransaction;
end;</source>
    </JadeMethod>
    <JadeMethod name="jacBackupServerAppInit" id="2dbac69f-50ea-45af-9b93-5c3ab2d16417">
        <updating/>
        <source>jacBackupServerAppInit() updating;
// ---------------------------------------------------------------------------
// Created:     
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	serv: JACServerAppObject;
begin
	self.jacInitializeApp();	
	serv := self.myServerAppObject;
	if serv &lt;&gt; null then
		app.writeLog(class.name&amp;'::'&amp;method.name&amp;' causeEvent NotifyBackupServerStarted='&amp;NotifyBackupServerStarted.String, LogDebug);
		serv.causeEvent(NotifyBackupServerStarted, true, null);
		if app.isSDSSecondaryDB then
			// secondary tell primary the control app has started
			app.writeLog(class.name&amp;'::'&amp;method.name&amp;' sdsCauseEvent NotifyBackupServerStarted='&amp;NotifyBackupServerStarted.String, LogDebug);
			serv.sdsCauseEvent(NotifySecServerAppStarted, false, null);
		endif;
	endif;
	beginTransaction;
	process.userInfo := "Backup server application ("&amp;app.name&amp;") running.";
	commitTransaction;
	app.writeLog("Backup server application ("&amp;app.name&amp;' '&amp;JACVersion.VERSION&amp;") started.", LogAlways);
	if serv.logLocalBackupPath = null and
	   not app.isSDSSecondaryDB then
		beginTransaction;
		serv.setLocalLogBackupPath("C:\temp");		//the default...
		commitTransaction;
	endif;
	serv.initBackupServerApp();
end;</source>
    </JadeMethod>
    <JadeMethod name="jacBackupSplitAppStart" id="6bbb0278-4f2f-4845-b632-b9bd0a45109d">
        <updating/>
        <source>jacBackupSplitAppStart(_jacSplit:JACBackupSplitInfo input) updating;
// ---------------------------------------------------------------------------
// Created:     
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin

	self.jacInitializeApp();	

	self.allowZeroForms();
	_jacSplit.splitStart();

end;</source>
        <Parameter name="_jacSplit" type="JACBackupSplitInfo" usage="input"/>
    </JadeMethod>
    <JadeMethod name="jacFinalizeApp" id="8f00a836-5354-4491-b4de-809881c35814">
        <updating/>
        <source>jacFinalizeApp() updating;
// ---------------------------------------------------------------------------
// Created:     
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin
	if self.myLogFile &lt;&gt; null then
		app.writeLog(class.name &amp; '::' &amp; method.name &amp; ' Application '&amp;app.name&amp;' terminating', LogDebug);
	endif;
	self.exitLogFile();
end;</source>
    </JadeMethod>
    <JadeMethod name="jacInitializeApp" id="20854a19-be86-4cd4-b3d9-bf5676953379">
        <updating/>
        <source>jacInitializeApp() updating;
// ---------------------------------------------------------------------------
// Created:     
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin

	self.cnActivateKarmaControl(Cn_Fat_Client, null, null);	//for dumps

	app.myCnCntrl.setSuppressManagementDialogs(true);

	on Exception do globalExceptionHandler(exception) global;
	on LockException do globalLockExceptionHandler(exception) global;
	
	self.initLogFile();
	app.writeLog(class.name &amp; '::' &amp; method.name &amp; ' Application starting', LogDebug);
	self.myServerAppObject := self.getSingleton(JACServerAppObject).JACServerAppObject;

	if self.myServerAppObject.debug then
		self.logLevel := LogDebug;
	else
		self.logLevel := LogNormal;
	endif;

	if self.myDBA = null then
		beginTransientTransaction;
		create self.myDBA sharedTransient;
		commitTransientTransaction;
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="jacIsAppRunning" id="fe515fde-845d-4580-b030-fb5f31a4125a">
        <source>jacIsAppRunning(_appName : String) : Boolean;
// ---------------------------------------------------------------------------
// Created:     
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 03 Apr 2008	cnwkpd1		PAR #16421 - Rework to remove locking on system
//							collections				
// ---------------------------------------------------------------------------

vars
//	tmpNode			: Node;
	tmpProcess		: Process;
	invalidProcess	: Boolean;
	
begin
	on Exception do handleDeletedObject(exception, tmpProcess, invalidProcess);
	
	foreach tmpProcess in Process.instances do
		if tmpProcess.persistentApp.name = _appName then
			return true;
		endif;
	endforeach;
	
/*	PAR #16421 - Old code replaced
	
	foreach tmpNode in system.nodes do
		foreach tmpProcess in tmpNode.processes do
			if tmpProcess.persistentApp.name = _appName then
				return true;
			endif;
		endforeach;
	endforeach;
*/

	return false;
end;</source>
        <Parameter name="_appName" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="logUnhandledNotification" id="e304d274-63be-449a-8126-0ba176e26052">
        <source>logUnhandledNotification(_className, _methodName : String; _eventType : Integer; _eventTag : Integer; _userInfo : Any);
// ---------------------------------------------------------------------------
// Created:     
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin
	app.writeLog(class.name &amp; '::' &amp; method.name &amp; " ERROR: Unhandled Notification in " &amp; _className &amp; '::' &amp; _methodName, LogAlways);
	app.writeLog("       eventType=" &amp; _eventType.String, LogAlways);			
	app.writeLog("       eventTag=" &amp; _eventTag.String, LogAlways);			
	app.writeLog("       userInfo=" &amp; _userInfo.String, LogAlways);		
	app.writeLog(class.name &amp; '::' &amp; method.name &amp; " ERROR: Unhandled Notification in " &amp; _className &amp; '::' &amp; _methodName, LogDebug);
end;</source>
        <Parameter name="_className" type="String"/>
        <Parameter name="_methodName" type="String"/>
        <Parameter name="_eventType" type="Integer"/>
        <Parameter name="_eventTag" type="Integer"/>
        <Parameter name="_userInfo" type="Any"/>
    </JadeMethod>
    <JadeMethod name="writeLog" id="5ee70bde-b359-4c5e-8b6d-335cc86a8a8c">
        <updating/>
        <source>writeLog(_message: String; _messageLevel: Integer) updating;
// ---------------------------------------------------------------------------
// Created:     15 December 2000 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin
	if _messageLevel &gt; self.logLevel then
		return;
	endif;
	if self.myLogFile = null then
		self.initLogFile;
	endif;
	self.myLogFile.logServer(app.name &amp; ' &gt;&gt; ' &amp; _message);
end;</source>
        <Parameter name="_message" type="String"/>
        <Parameter name="_messageLevel" type="Integer"/>
    </JadeMethod>
</Class>
