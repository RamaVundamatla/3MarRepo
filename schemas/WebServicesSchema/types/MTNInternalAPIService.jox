    <JadeMethod name="deleteCargoDamage" id="8a6a2c6b-4e48-4663-a380-84725c0bb237">
        <updating/>
        <source>deleteCargoDamage(_cargoDamageRequest : WS_CargoDamageRequest) : WS_Response updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 Oct 2022	navlw1	Initial creation tfs 53880 to delete damage for a cargo item
19/05/2023	navcs2	Defect 58062: MTN - Mobile Apps from cargo damage deleted the cargo still flagged as damage in client
30/06/2023	navcs2	Bug 58965: EUP - When deleting damage in Mobile apps it does not remove the DamagedDT
14/08/2023	navkc1	Bug 59764: MTN - 404 response for Delete and PUT requests for Cargo Damage
*/

vars
	response 		: WS_Response;
	terminal 		: CM_Terminal;
	wsDamageObject 	: WS_RestDamageObject;
	damage,		
	damageToDelete,
	pxyDamage		: CM_DamageInstance;
	ti,
	pxyTI			: CM_TrackedItem;
	cargoUid 		: String;
	isLoadState		: Boolean;
begin
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	on LockException do self.handleLockExceptions(exception);
	
	create response transient;
	
	// Set app.mypassport - user / terminal &amp; machine
	self.initialisePassport();
	
	self.setIgnoreWarnings(_cargoDamageRequest.warningsAcknowledged);
	
	if self.httpStatusCode &lt;&gt; HttpResponseOK then
		//user has not validated
		app.writeLog(method.qualifiedName &amp; Tab &amp; self.httpStatusCode.String, LogERROR);
		return response;
	endif;	
	
	terminal := app.myPassport.myTerminal;
	
	// Check security access to this message, if required
	app.checkCurrentUserHasAccess(PmHHDamageReport); // Replace with appropriate permission
	if app.myPassport.hasErrors then
		return response;
	endif;	
	
	// damage checks
	wsDamageObject := _cargoDamageRequest.damage;
	if wsDamageObject = null then
		app.raiseCMException1(Invalid_Damage_Details, "No Damage Details Supplied", null, null);
		return response;
	endif;
	
	if wsDamageObject.damageUid &lt;&gt; null or wsDamageObject.damageUid &lt;&gt; "" then
		damageToDelete := app.myPassport.getObjectOfTypeFromOid(wsDamageObject.damageUid,CM_DamageInstance).CM_DamageInstance;
		if app.myPassport.hasErrors then
			return response;
		endif;
		if damageToDelete = null then
			app.raiseCMException1(Damage_not_found,wsDamageObject.damageUid, null, null);
			return response;
		endif;
	endif;
	
	// Tracked item checks
	cargoUid := _cargoDamageRequest.cargoUid;
	//14/08/2023	navkc1	Bug 59764
	if cargoUid = null then
		app.raiseCMException(InvalidCargoUid, null, null);
		self.httpStatusCode := HttpResponseNotFound;
		return response;
	endif;
	ti := app.myPassport.getObjectOfTypeFromOid(cargoUid, CM_TrackedItem).CM_TrackedItem;
	if app.myPassport.hasErrors then
		return response;
	endif;
	if ti = null then
		app.raiseCMException1(Cargo_item_not_found, cargoUid , null, null);
		self.httpStatusCode := HttpResponseNotFound;
		return response;
	endif;
	
	app.cmsBeginLoad(isLoadState);
	pxyTI		:=	ti.pxyCreateUpdateProxy();
	app.cmsEndLoad(isLoadState);
	
	pxyTI.purgeAllDamageInstance();
	
	// find the damage we want to delete
	foreach damage in ti.allDamageInstances do
		if damage = damageToDelete then
			continue;
		endif;
		
		app.cmsBeginLoad(isLoadState);
		pxyDamage := damage.pxyCreateUpdateProxy();
		app.cmsEndLoad(isLoadState);
		
		pxyDamage.setMyTrackedItem(pxyTI);
	endforeach;
	
	if pxyTI.allDamageInstances.isEmpty then		// 19/05/2023	navcs2	Defect 58062
		pxyTI.setDamaged(false);					// 19/05/2023	navcs2	Defect 58062
		pxyTI.setDamagedDT(false);					// 30/06/2023	navcs2	Bug 58965
	endif;											// 19/05/2023	navcs2	Defect 58062

	// do the deleting of the damage
	app.myTrxUA.trxUpdateTIDamage(pxyTI, app.myPassport);
	
	return response;
epilog
	app.cmsEndLoad(isLoadState);
	delete pxyTI;
	finaliseResponse(response);
end;</source>
        <Parameter name="_cargoDamageRequest" type="WS_CargoDamageRequest"/>
        <ReturnType type="WS_Response"/>
    </JadeMethod>
    <JadeMethod name="deleteCargoQueuedMove" id="4d97acee-ddac-435d-b0eb-9f146d99c1ab">
        <updating/>
        <source>deleteCargoQueuedMove(request : WS_CargoLocationRequest; cargoOid : String )  : WS_Response updating;
/*

Purpose:			???
					07/04/2022 navmd1 Doesn't look like this is actually used by Release Staging ?

Parameters:			

Return Value:		

Date			Who		Reason
06 August 2019	jlgns1	Initial creation
06 August 2019 	JLGNS1	ChangeRequest 45293: JMT Handheld Apps - Release Staging Jade
07 April 2022 	navmd1	TFS 53371 Moved/Copied from JMTHandheldService to MTNInternalAPIService
*/

vars
	cargo 			: CM_TrackedItem;
	targetLocation 	: CM_LocationsController;
	response 		: WS_Response;
	moveAgent 		: CMIF_MobileGenericAgent;
	location 		: String;
	dummyHeight 	: Integer;
	failedDAC  		: CM_DataAccessController;
begin
// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	on LockException do self.handleLockExceptions(exception);
	
	create response transient;
	// Set app.mypassport - user / terminal &amp; machine
	self.initialisePassport();
	
	if self.httpStatusCode &lt;&gt; HttpResponseOK then
		//user has not validated
		app.writeLog(method.qualifiedName &amp; Tab &amp; self.httpStatusCode.String, LogERROR);	//25 Nov 2019	NDL	TFS 47053	//navra1 - 24th Aug 2022 - TFS 50365
		return response;
	endif;	
	
	if app.myPassport.hasErrors then
		return response;
	endif;
	
	app.checkCurrentUserHasAccess(PmWebCargoDelQueuedMove);		
	if app.myPassport.hasErrors then
		self.httpStatusCode := HttpResponseForbidden;
		return response;
	endif;	
	
	// Get the parameters
	location := request.location;
	
	
	
	
	
	
	// Check for errrors
	if app.myPassport.hasErrors then
		return response;
	endif;	

	app.writeLog(location, LogDEBUG);	//25 Nov 2019	NDL	TFS 47053
	
	
	
	if cargoOid.trimBlanks = "" then
		app.raiseCMException(Input_required_field_cargoId, null,null);
		return response;
	endif;	
		
		
	cargo := app.myPassport.getObjectOfTypeFromOid(cargoOid, CM_TrackedItem).CM_TrackedItem;
	if cargo = null then
		app.raiseCMException(Input_required_field_cargoItem,null,null);
		return response;
	endif;
	
	if location.trimBlanks = "" then
		app.raiseCMException(Input_Required_For_TA, null,null);
		return response;
	endif;	
	
	app.myPassport.myTerminal.findLocationFromString(location,true,targetLocation,dummyHeight);
	
	if targetLocation = null or  not targetLocation.canUserAccessSelf(app.getMyUser,failedDAC ,app.myPassport) then
		app.raiseCMException1(Location_invalid,location, null,null);
		return response;
	endif;	
	
	app.myPassport.setWarningsIgnored(request.warningsAcknowledged);
	
	create moveAgent transient;	
	moveAgent.doUnqueueTI(cargo, targetLocation);
	
	return response;
epilog
	delete moveAgent;
	self.finaliseResponse(response);
end;</source>
        <Parameter name="request" type="WS_CargoLocationRequest"/>
        <Parameter name="cargoOid" type="String"/>
        <ReturnType type="WS_Response"/>
    </JadeMethod>
    <JadeMethod name="deleteDamageOnWagon" id="ca4f90cd-782c-4b7a-b6cd-2d9f36bdfb55">
        <updating/>
        <source>deleteDamageOnWagon(request : WS_UpdateRequest; damageOid : String) : WS_Response updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 July 2022	jlier1	Initial creation 53971

*/

vars
	response : WS_Response;
	wagon : CM_Wagon;
	damage  : CM_DamageInstance;
	deleteObj : CM_Object;
begin
	on CM_Exception do self.handleCMException(exception);
	on LockException do self.handleLockExceptions(exception);
	
	create response transient;
	
	self.initialisePassport();
	
	if self.httpStatusCode &lt;&gt; HttpResponseOK then
		//user has not validated
		app.writeLog(method.qualifiedName &amp; Tab &amp; self.httpStatusCode.String, LogERROR);	//25 Nov 2019	NDL	TFS 47053	//navra1 - 24th Aug 2022 - TFS 50365
		return response;
	endif;	
	
	if app.myPassport.hasErrors then
		return response;
	endif;
	
	app.checkCurrentUserHasAccess(PmAdmHHRailConfirm);		
	
	if app.myPassport.hasErrors then
		self.httpStatusCode := HttpResponseForbidden;
		return response;
	endif;	
	
	

	damage:=app.myPassport.getObjectOfTypeFromOid(damageOid,CM_DamageInstance).CM_DamageInstance;
	
	if app.myPassport.hasErrors then
		return response;
	endif;
	
	if damage = null then
		app.raiseCMException1(Damage_not_found,damageOid,null,null);
		//raise exception
		return response;
	endif;
	
	deleteObj:=damage;
	app.myPassport.setWarningsIgnored(request.warningsAcknowledged);
	app.myTrxDA.trxDeleteCMObject(deleteObj,app.myPassport);
	
	
	return response;
epilog
	self.finaliseResponse(response);
	
end;</source>
        <Parameter name="request" type="WS_UpdateRequest"/>
        <Parameter name="damageOid" type="String"/>
        <ReturnType type="WS_Response"/>
    </JadeMethod>
    <JadeMethod name="doDisconnectCargo" id="701bb1e0-459c-463f-aaf9-d2a61ef33184">
        <source>doDisconnectCargo(cargo : CM_TrackedItem; request : WS_Request ) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 February 2022	jlier1	Initial creation
07 Jan 2025	navtr3	JIRA 19368 CUX - Vehicle App - Reefer Container on a MAFI

*/

vars
	doDisconnect : Boolean;
	connectParams		: CMIF_ConnectParams;
	terminal : CM_Terminal;
	containerIsConnected : Boolean;
	tiSet 	: CM_TISet;
	ti 		: CM_TrackedItem;
	connectParamsContainer		: CMIF_ConnectParams;
begin
	app.writeLog(method.qualifiedName &amp; " - " &amp; request.ignoreErrorCodes, LogDEBUG);

	if cargo = null then
		//if we are accepting director tasks let it go through
		app.myPassport.errorsToIgnore.add(MACH_LIFT_POWER);
		return;
	endif;


	if cargo = null or request = null then
		return;
	endif;
	
	containerIsConnected := cargo.isOnboardCargoConnected(); //07.01.2025 navtr3 #19368
	
	if not cargo.isConnected and not containerIsConnected then //07.01.2025 navtr3 #19368
		return;
	endif;
	
	terminal:=cargo.myTerminal;
	
	if not terminal.getConfig(SetConnectedTIToHeld).Boolean then
		if request.ignoreErrorCodes.Integer = Machine_disconnect_power then
			app.myPassport.errorsToIgnore.add(MACH_LIFT_POWER);
			if request.warningsAcknowledged then
				doDisconnect := true;
			endif;
		endif;
	endif;
		
	//20.03.2020 cnwma1 #48757
	if doDisconnect then 
		create connectParams transient;
		connectParams.allTrackedItems.add(cargo);
		connectParams.dateTime      			   := app.actualTimeServer;
		connectParams.myTerminal    			   := terminal;
		connectParams.myTrackedItem 			   := cargo;
		connectParams.userId       				   := app.getMyUserCode();
		connectParams.action      				   := ACTION_DISCONNECT;
		connectParams.radioTelemetryIgnoreWarnings := true;
		app.myTrxUA.trxUpdateDisconnect(connectParams, app.myPassport);
		
		//07.01.2025 navtr3 #19368
		if cargo.isTrailer or cargo.isMAFI then		
			create tiSet transient;
			cargo.getAllOnboardTIs(tiSet);
			
			foreach ti in tiSet discreteLock do
				if ti.isConnected then
					create connectParamsContainer transient;
						connectParamsContainer.allTrackedItems.add(ti);
						connectParamsContainer.dateTime      			    := app.actualTimeServer;
						connectParamsContainer.myTerminal    			    := terminal;
						connectParamsContainer.myTrackedItem 			    := ti;
						connectParamsContainer.userId       				:= app.getMyUserCode();
						connectParamsContainer.action      				    := ACTION_DISCONNECT;
						connectParamsContainer.radioTelemetryIgnoreWarnings := true;
						app.myTrxUA.trxUpdateDisconnect(connectParamsContainer, app.myPassport);
				endif;
			endforeach;
		endif;
	endif;

epilog
	delete connectParams;
	delete connectParamsContainer;
	delete tiSet;
end;</source>
        <access>protected</access>
        <Parameter name="cargo" type="CM_TrackedItem"/>
        <Parameter name="request" type="WS_Request"/>
    </JadeMethod>
    <JadeMethod name="finaliseBooleanResponse" id="0cacd520-a05b-482a-a5ff-fc7b87e4a030">
        <updating/>
        <source>finaliseBooleanResponse(boolResponse : Boolean io) updating, protected;
/*

Purpose: 

Parameters:

			
Return Value: 


Date		Name	TFS#		Description
============================================================================
23 Feb 2021	jlika1	49429		Initial creation
============================================================================*/
vars
	response 	 : WS_Response;		
begin
	create response transient;
	response.setErrorsFromPassport();	
	
	if response.result &lt;&gt; 0 then
		if response.result = 1 and self.httpStatusCode = HttpResponseOK then
			self.httpStatusCode := HttpResponseClientError;
		endif;		
	endif;
		
	// this will avoid the annoying 100010 exception 
	if self.startCnTrx &lt;&gt; null then
		self.cnEndTransactionEx(self.startCnTrx);
	endif;
	
epilog
	delete response;
end;</source>
        <access>protected</access>
        <Parameter name="boolResponse" type="Boolean" usage="io"/>
    </JadeMethod>
    <JadeMethod name="finaliseJSONResponse" id="2c6595ab-0a34-43a0-b15d-e408f69fcaff">
        <updating/>
        <source>finaliseJSONResponse(jsonResponse : String io) updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 February 2021	jlier1	Initial creation 49429

*/

vars
	response : WS_Response;	
	responseJSON : String;
	writeErrors : Boolean;
begin
	create response transient;
	writeErrors:= app.myPassport.hasErrorsOrNonIgnoredWarnings();
	response.setErrorsFromPassport();
	response.deserializeJSON(responseJSON);
		
	if responseJSON &lt;&gt; null and writeErrors then
		jsonResponse:=responseJSON;	
	endif;
	
	
	if responseJSON &lt;&gt; null and response.result &lt;&gt; 0 then
		if response.result = 1  and self.httpStatusCode = HttpResponseOK then
			self.httpStatusCode := HttpResponseClientError;
		endif;	
	endif;
		
	
		// this will avoid the annoying 100010 exception 
	if self.startCnTrx &lt;&gt; null then
		self.cnEndTransactionEx(self.startCnTrx);
	endif;
epilog
	delete response;
end;</source>
        <access>protected</access>
        <Parameter name="jsonResponse" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="forceOffOldSessions" id="065b7035-0261-4cf2-97a9-742a4c2a564b">
        <source>forceOffOldSessions(_passport: CM_Passport input) protected;
/*

Purpose:			Allows log on of users with "Single User Session" enabled, by forcing off any existing sessions they may have.
					NB. This should not apply to "external" web service calls made via the 'logon' request - we only want this for our .net apps.
					Users require the "Single User Session Allow Override" config set to use this method.
					
					***This method has been created from JMTSecureService::forceOffOldSessions()***

Parameters:			

Return Value:		

Date			Who		Reason
12 May 2025		navnk30 JIRA 34701: SSO Implementation for Vehicle App - Jade Portion

*/

vars
	user			: CM_User;
	oldWebSession	: WebSession;
	invalidSession	: Boolean;
	oldWSAppName,
	sessionId		: String;
	result			: Integer;
	resultStr		: String;
	proc			: Process;
	machine			: CM_Machine;
begin
	user := _passport.myUser;
	
	if user &lt;&gt; null and user.getUserSingleSignAllowOverride() then
		// Ignore sessions that might be killed while we're working with them
		on Exception do app.handleDeletedObject(exception, oldWebSession, invalidSession);

		while app.myRoot.hasCurrentWebSession(user, oldWSAppName, oldWebSession) do
			sessionId := oldWebSession.getPropertyValue('_encryptedSessionId').String;
			app.writeLog(user.code &amp; " is forcing off Old Web Session " &amp; sessionId, LogWARN);
			machine := oldWebSession.SWebServiceSchema.myCurrentMachine;
			app.myTrxUA.trxUpdateLogoff(machine, _passport);			
			
			// Next, try and reset any process names that match our machine
			// ... this may or may not be a good idea - although setting the process name on a web service doesn't make much sense either
			if machine &lt;&gt; null then
				beginTransaction;
				foreach proc in node.processes do
					if proc.userCode = machine.code then
						proc.changeUserCode(proc.signOnUserCode);
					endif;
				endforeach;
				commitTransaction;
			endif;
			
			oldWebSession.removeSession();
		endwhile;
	else
		app.writeLog("User (" &amp; user.code &amp; ") requested to Force Off old sessions, but doesn't have permission to do so", LogERROR);
		result := Err_InsufficientPermission;
		resultStr := app.getErrorString(result);
		_passport.addErrorFull(result, resultStr, null, null, null);
	endif;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getApplicationConfig" id="21c52798-1f98-4ba2-acc4-88fdb18cd652">
        <updating/>
        <source>getApplicationConfig(_applicationName, _sectionName: String): String updating;
/*

Purpose:			A placeholder method to get .NET application configuration out of Master Terminal.
					This is just a placeholder method at the moment to enable development to continue for 55077

Parameters:			

Return Value:		

Date				Who		Reason
17 October 2022		navmd1	Initial creation TFS 55077

*/

constants
	// Applications
	MobileApps 				: String = "MobileApps";
	
	// Config Sections
	EverythingSection		: String = "All";
	CargoDetailsSection		: String = "CargoDetails";
vars
	response				: String;				// TODO: Make me an actual object	
	found					: Boolean;
begin
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	on LockException do self.handleLockExceptions(exception);
	
	//create response transient;
	
	// Set app.mypassport - user / terminal &amp; machine
	self.initialisePassport();
	
	if self.httpStatusCode &lt;&gt; HttpResponseOK then
		//user has not validated
		app.writeLog(method.qualifiedName &amp; Tab &amp; self.httpStatusCode.String, LogERROR);	//25 Nov 2019	NDL	TFS 47053	//navra1 - 24th Aug 2022 - TFS 50365
		return response;
	endif;	
	
	if _applicationName = MobileApps then
		if _sectionName.isOneOf(CargoDetailsSection, EverythingSection) then
		
			response := '{
						"applicationName": "' &amp; MobileApps &amp; '",
						"cargoDetails": {
							"primary": [ "imex", "operator", "weight", "tasks", "received", "location" ],
							"expander": [ "voyage", "commodity", "availablityGrade", "stops", "shippingLine" ]
						}
					}';
			
			found := true;
		endif;
	endif;
	
	if not found then
		app.writeLog("No matching configuration found for [" &amp; _applicationName &amp; "/" &amp; _sectionName &amp;"]", LogERROR);
		self.httpStatusCode := HttpResponseClientError;	// HTTP 400
	endif;
	
	// Remove whitespace
	response := response.replace(CrLf, null).replace(Tab, null);
	
	return response;
epilog
	
end;</source>
        <Parameter name="_applicationName" type="String"/>
        <Parameter name="_sectionName" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getCargoAvailableForPicking" id="c4387e7e-a3f9-4b24-b867-fd6abd46c0e5">
        <updating/>
        <source>getCargoAvailableForPicking(reserveDetailOid :String ): WS_CargoSummaryResponse updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
26 July 2021	jlier1	Initial creation TFS 51626 - Order Picking app
07 April 2022 	navmd1	TFS 53371 Moved/Copied from JMTHandheldService to MTNInternalAPIService

*/

vars
	response : WS_CargoSummaryResponse;
	realResDet 		 : CM_ReserveDetail;
	tiSet 	: CM_TISet;
	ti : CM_TrackedItem;
	firstStagedLC , lc: CM_LocationsController;
	failedDAC  		 : CM_DataAccessController ;
	wsCargo 		 : WS_CargoSummary;
begin
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	on LockException do self.handleLockExceptions(exception);
	
	create response transient;
	
	// Set app.mypassport - user / terminal &amp; machine
	self.initialisePassport();
	
	if self.httpStatusCode &lt;&gt; HttpResponseOK then
		//user has not validated
		app.writeLog(method.qualifiedName &amp; Tab &amp; self.httpStatusCode.String, LogERROR);	//25 Nov 2019	NDL	TFS 47053	//navra1 - 24th Aug 2022 - TFS 50365
		return response;
	endif;	
	
	realResDet := app.myPassport.getObjectOfTypeFromOid(reserveDetailOid, CM_ReserveDetail).CM_ReserveDetail;
	
	
	if app.myPassport.hasErrors then
		return response;
	endif;
	
	if realResDet = null then
		app.raiseCMException(Input_required_field_delReleas,null,null);
		return response;
	endif;
	
	
	create tiSet transient;
	realResDet.getStagingLocationSummary(tiSet,firstStagedLC);
	
	foreach ti in tiSet discreteLock do
		lc := ti.myPrimaryActualLocation;
		if lc = null or lc.isMachineController then
			continue;
		endif;
		if not ti.canUserAccessSelf(app.getMyUser,failedDAC ,app.myPassport) then
			continue;
		endif;
		create wsCargo transient;
		wsCargo.setProxyFromObject(ti);
	
		response.allCargoSummaries.add(wsCargo);
					
	endforeach;
	
	return response;
	
epilog
	delete tiSet;
	self.finaliseResponse(response);

end;</source>
        <Parameter name="reserveDetailOid" type="String"/>
        <ReturnType type="WS_CargoSummaryResponse"/>
    </JadeMethod>
    <JadeMethod name="getCargoDamageConfigData" id="3cd40218-981b-421d-81a2-624dcabba7e9">
        <updating/>
        <source>getCargoDamageConfigData() : WS_DamageConfigResponse updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 Oct 2022	navlw1	Initial creation tfs 53880 Web extra damage details task 54812
18 May 2023 navma1	Defect 57971: MTN - Mobile Apps cargo damage doesn't give configured damage and position based on the cargo type in advance cargo damage 
*/

vars
	damRequest : WS_DamageConfigRequest;
begin
	create damRequest transient;
	damRequest.includeCodes 	 := true;
	damRequest.includePositions  := true;
	damRequest.includeSeverity   := true;
	damRequest.cargoTypeDesc     := self.qsData.getValue("cargoTypeDesc").asStringJMT(); //18.05.2023 navma1 #57971
	
	return self.getCargoDamageData(damRequest);
epilog

end;</source>
        <ReturnType type="WS_DamageConfigResponse"/>
    </JadeMethod>
    <JadeMethod name="getCargoDamageData" id="684d5e80-2a62-4373-890c-e381e897e0be">
        <updating/>
        <source>getCargoDamageData(_damRequest : WS_DamageConfigRequest) : WS_DamageConfigResponse updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
10 Oct 2022		navlw1 	Initial creation tfs 53880 Web extra damage details task 54812
13 Jan 2023     navlw1	TFS 55162 EUP - WMS-Advanced Repair Details
19 Mar 2024		jlizm1	MTN 34270 Default damage severity on web apps
*/

vars
	response 		: WS_DamageConfigResponse;
	damRequest 		: WS_DamageConfigRequest;
	damageCode 		: CM_DamageDefinitionCode;
	damagePos 		: CM_DamagePosition;
	wsDamCode 		: WS_DamageCode;
	wsDamPos 		: WS_DamagePosition;
	wsDamSev 		: WS_DamageSeverity;
	cargoType 		: CM_CargoType;
	severity  		: CM_DamageSeverity;
	damPlace		: CM_DamagePlace;
	wsDamPlace		: WS_DamagePlace;
	wsDamReason 	: WS_DamageReason;
	damReason 		: CM_DamageReason;
	wsDamParty 		: WS_ResponsibleParty;
	damParty		: CM_DamageParty;
	advanceDamPerm,
	advancedRepPerm	: Boolean;
	repairReason 	: CM_RepairReason;
	wsRepairReason	: WS_RepairReason;
	terminal		: CM_Terminal;
	myRoot 			: CM_Root;
	
begin
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	on LockException do self.handleLockExceptions(exception);
	
	// Set app.mypassport - user / terminal &amp; machine
	self.initialisePassport();
	
	create response transient;
	
	if self.httpStatusCode &lt;&gt; HttpResponseOK then
		app.writeLog(method.qualifiedName &amp; Tab &amp; self.httpStatusCode.String, LogERROR);
		return response;
	endif;	

	terminal := app.myPassport.myTerminal;
	myRoot := app.myRoot;

	advanceDamPerm := app.myCurrentUserCan(terminal,PmAdmDamageCodeAdvancedMaint);
	advancedRepPerm := 	app.myCurrentUserCan(terminal,PmAdmTIRepairMaint);

	damRequest := _damRequest;
	if damRequest = null then
		self.httpStatusCode := HttpResponseNotFound;
		return response;
	endif;
		
	if damRequest.cargoTypeDesc &lt;&gt; null then 
		cargoType := myRoot.getCargoTypeFromAbbrevOrDescr(damRequest.cargoTypeDesc);
	endif;
	
	// Populate Validate response 
	if damRequest.includeCodes then
		foreach damageCode in myRoot.allDamageDefinitionCodes discreteLock do
						
			if damageCode.isNotAvailableForEntry then
				continue;
			endif;
			
			if damageCode.allCargoTypes.isEmpty then
				continue;
			endif;
			
			if cargoType &lt;&gt; null then 
				if not damageCode.allCargoTypes.includes(cargoType)then
					continue;
				endif;
			endif;
			app.writeLog(damageCode.code &amp; " pass cargo type", LogINFO);
			create wsDamCode transient;
			wsDamCode.setProxyFromObject(damageCode);
			wsDamCode.setAllCargoTypes(damageCode);
			response.allDamageCodes.add( wsDamCode );
		endforeach;
	endif;
	
	if damRequest.includePositions then
		foreach damagePos in myRoot.allDamagePositionsByCode discreteLock do
			if damagePos.isNotAvailableForEntry then
				continue;
			endif;
			if damagePos.allActiveCargoTypes.isEmpty then
				continue;
			endif;
			
			if cargoType &lt;&gt; null then
				if not damagePos.allActiveCargoTypes.includes(cargoType)then
					continue;
				endif;
			endif;
			
			create wsDamPos transient;
			wsDamPos.setProxyFromObject(damagePos);
			wsDamPos.setAllCargoTypes(damagePos);
			response.allDamagePositions.add( wsDamPos );
		endforeach;
	endif;
	
	if damRequest.includeSeverity then
		foreach severity in terminal.allDamageSeverities do		
			create wsDamSev transient;
			wsDamSev.setProxyFromObject(severity);
			//wsDamSev.setProxyFromValue(severity.level);	
			response.allDamageSeverities.add( wsDamSev );
		endforeach;
		
		severity := terminal.getConfig(DamageSeverityDefault).CM_DamageSeverity;
		if severity &lt;&gt; null then
			create wsDamSev transient;
			wsDamSev.setProxyFromObject(severity);
			response.defaultDamageSeverity := wsDamSev;
		endif;
	endif;
	
	// advanced details only if we have the advanced permission
	if advanceDamPerm then
		foreach damPlace in terminal.allDamagePlaces do
			create wsDamPlace transient;
			wsDamPlace.setProxyFromObject(damPlace);
			response.allDamagePlaces.add(wsDamPlace);
		endforeach;
		
		foreach damReason in terminal.allDamageReasons do
			create wsDamReason transient;
			wsDamReason.setProxyFromObject(damReason);
			response.allDamageReasons.add(wsDamReason);
		endforeach;
		
		foreach damParty in terminal.allDamageParties do
			create wsDamParty transient;
			wsDamParty.setProxyFromObject(damParty);
			response.allDamageParties.add(wsDamParty);
		endforeach;
	endif;
	
	// 13 Jan 2023 navlw tfs 55162 Repair Reasons
	if advancedRepPerm then
		foreach repairReason in terminal.allRepairReasons do
			if repairReason.isNotAvalableForEntry then
				continue;
			endif;
			create wsRepairReason transient;
			wsRepairReason.setProxyFromObject(repairReason);
			response.allRepairReasons.add(wsRepairReason);
		endforeach;
	endif;
	
	return response;
epilog
	finaliseResponse(response);
end;</source>
        <Parameter name="_damRequest" type="WS_DamageConfigRequest"/>
        <ReturnType type="WS_DamageConfigResponse"/>
    </JadeMethod>
    <JadeMethod name="getCargoForCargoGroupAssign" id="ff4fca10-e410-4e0e-acde-fc9030a519d0">
        <updating/>
        <source>getCargoForCargoGroupAssign(cargoId : String; groupAssignOid : String;optionalParam : ParamListType) : WS_CargoForGroupAssignResponse updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
06 August 2021	jlier1	Initial creation 51683
07 April 2022 	navmd1	TFS 53371 Moved/Copied from JMTHandheldService to MTNInternalAPIService

*/

vars

	response : WS_CargoForGroupAssignResponse;
	terminal : CM_Terminal;
	cmifID			: CMIF_IDConversion;	
	altId	,convertedID, cgOid		: String;
	cga : CM_CargoGroupAssignment;
	cg 	: CM_CargoGroup;
	ti : CM_TrackedItem;
	obj : Object;
	cargoIdLength,altIdLength : Integer;	
	wsCargoSummary : WS_CargoSummary;
	info 	: String;
	desc1, desc2 : String;
	pos : Integer;
begin
		// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	on LockException do self.handleLockExceptions(exception);
	
	create response transient;
	// Set app.mypassport - user / terminal &amp; machine
	
	self.initialisePassport();
	
	if self.httpStatusCode &lt;&gt; HttpResponseOK then
		//user has not validated
		app.writeLog(method.qualifiedName &amp; Tab &amp; self.httpStatusCode.String, LogERROR);	//25 Nov 2019	NDL	TFS 47053	//navra1 - 24th Aug 2022 - TFS 50365
		return response;
	endif;	
	
	terminal := app.myPassport.myTerminal;
	
	if cargoId.trimBlanks = "" then
	//need to change to appriopriate error
		app.raiseCMException(Input_required_field_cargoId, null, null);
		return response;
	endif;
	
	cga:=app.myPassport.getObjectOfTypeFromOid(groupAssignOid,CM_CargoGroupAssignment).CM_CargoGroupAssignment;
	if app.myPassport.hasErrors then
		return response;
	endif;
	
	if cga = null then
		//need to change to appriopriate error
		app.raiseCMException(Input_requir_cargo_group_assig, null, null);
		return response;
	endif;
	cgOid := parseParameterList(optionalParam, 1, String).String;
	if cgOid &lt;&gt; null then
		cg:=app.myPassport.getObjectOfTypeFromOid(cgOid,CM_CargoGroup).CM_CargoGroup;
	endif;
	

	create cmifID transient;
	cmifID.scannedValue :=  cargoId.asStringRESTFUL.toUpper();
	cmifID.myTerminal := terminal;
	convertedID:=app.convertScannedCargoId( null, null, false, cmifID );
	if convertedID = null then
		convertedID:=cargoId;
	endif;
	altId := app.convertScannedCargoId( null, null, true, cmifID );
	
	
	cargoIdLength := convertedID.length;
	
	ti:=terminal.allOnsiteTIsByIdCargoType.getAtKeyGeq( convertedID, null );
	if ti &lt;&gt; null and ti.id[1:cargoIdLength] &lt;&gt; convertedID then	
		ti := null;
	endif;
	altIdLength := altId.length;
	if ti = null and altIdLength &gt; 0 then
		ti := terminal.allOnsiteTIsByAlternativeId.getAtKeyGeq(altId);
		if ti &lt;&gt; null and ti.alternativeId[1:altIdLength] &lt;&gt; altId then	
			ti := null;
		endif;
	endif;
	
	if ti = null then
		 app.raiseCMException1( Cargo_item_not_found_site, convertedID,null,null );
		 return response;
	endif;
	
	obj := cga.getAssignedObject( ti.id );
	if obj = null then
		//new exception Cargo %1 not part of Cargo Group Assignment
		app.raiseCMException1(Cargo_not_cargo_group_assign,convertedID, null, null);
		return response;
	endif;
	
	
	if ti &lt;&gt; null and cga &lt;&gt; null and  ti.myCargoGroup &lt;&gt; null and   cga.allProcessedTis.includes(ti) then
		info:= app.getErrorString2( Cargo_item_already_assigne, ti.id, ti.myCargoGroup.id);
	endif;
	
	if cg = null then
		obj   :=cga.getAssignedObject( ti.id );
		if obj &lt;&gt; null and obj.isKindOf(CM_CargoGroup) then
			cg:=obj.CM_CargoGroup;
		endif;
		if cg = null and info = null then
			info:= app.getErrorString( Must_select_notifi_cargo_group);
		endif;
	endif;
	
	
	
	create wsCargoSummary transient;
	wsCargoSummary.setProxyFromObject(ti);
	response.myCargo:=wsCargoSummary;
	//jlier1 24/9/21 from functional review
	ti.getShortDescriptions(desc1,desc2);
	if desc1 &lt;&gt; null   then
		pos:=desc1.pos("(",1);
		if pos &gt; 0 then
			desc1:=desc1[1:pos-1];
		endif;
		wsCargoSummary.productDescription:=desc1;
	endif;
	
	if cg = null then
		cg:= ti.myCargoGroup;
	endif;
	
	if  info = null and  ti.myCargoGroup &lt;&gt; null then 
		info:= app.getErrorString2( Cargo_item_already_assigne, ti.id, ti.myCargoGroup.id);
	endif;
	
	if cg &lt;&gt; null  then		
		response.selectedCargoGroupOid:=obj.getOidAsString;
	endif;
	
	return response;
epilog
	response.addInfo(info);
	self.finaliseResponse(response);


end;</source>
        <Parameter name="cargoId" type="String"/>
        <Parameter name="groupAssignOid" type="String"/>
        <Parameter name="optionalParam" type="ParamListType"/>
        <ReturnType type="WS_CargoForGroupAssignResponse"/>
    </JadeMethod>
    <JadeMethod name="getCargoForDischarge" id="12c3d217-9617-41b7-8ec2-004c84950ad0">
        <updating/>
        <source>getCargoForDischarge(cargoId: String; optionalParam: ParamListType): String updating;
/*

Purpose: This is the REST version of machineGetDischargeCargo

Parameters:

			
Return Value: 


Date		Name	TFS#		Description
============================================================================
22 Feb 2021	jlika1	49429		Initial creation
06 May 2021 jlika1	49531		Add the ability to do a load more
20 Mar 2023 jlier1  57064       Refactored JSON returned - changes so numbers are returned as numbers, timestamp and  measurement fields as objects
============================================================================*/

vars
	machine 			: CM_Machine;
	response			: String;	
	allDischargeCargo 	: CM_TISet;
	twinCargoId			: String;
	index				: Integer;	
	limit				: Integer;
	iter 				: Iterator;
	count 				: Integer;
	cargo 				: CM_TrackedItem;
	filteredCargo		: CM_TIArray;
	cmifVehicleAppJSON : CMIF_VehicleAppJSON;
begin	
	on CM_Exception do self.handleCMException(exception);
	on LockException do self.handleLockExceptions(exception);
	
	self.initialisePassportMachine();
	
	app.writeLog(method.qualifiedName, LogTRACE);	
	
	// Initialises user and checks request has valid headers deletes and recreates the passport
	if self.httpStatusCode &lt;&gt; HttpResponseOK then
		//user has not validated
		app.writeLog(method.qualifiedName &amp; Tab &amp; self.httpStatusCode.String, LogERROR);	//25 Nov 2019	NDL	TFS 47053	//navra1 - 24th Aug 2022 - TFS 50365
		return response;
	endif;	
	
	machine := app.myPassport.myMachine;
	machine.validateForVehicleApp(true);
	if app.myPassport.hasErrors then	
		self.httpStatusCode := HttpResponseForbidden;
		return response;
	endif;	
		
	twinCargoId := parseParameterList(optionalParam, 1, String).String;
	
	// Get the parameters
	index := parseParameterList(optionalParam, 2, Integer).Integer;
	limit := parseParameterList(optionalParam, 3, Integer).Integer;
	
	// Set Defaults
	if limit = 0 then
		limit := 50;
	endif;
	if limit &gt; 250 then
		limit := 250;
	endif;
	if index = 0 then
		index := 1;
	endif;
	
	create allDischargeCargo transient;
	create filteredCargo transient;
	
	machine.isValidOnQueueVoyageTIID(cargoId.asStringRESTFUL.trimBlanks, allDischargeCargo);
	
	if twinCargoId &lt;&gt; null then
		machine.isValidOnQueueVoyageTIID(twinCargoId.asStringRESTFUL.trimBlanks, allDischargeCargo);
	endif;	
	
	iter := allDischargeCargo.createIterator;		
	
	while iter.next(cargo) and count &lt; ((index-1) + limit) do	
	
		count := count + 1;
		if index &gt; 1 then
			if count &lt; index then
				continue;
			endif;
		endif;		
		
		filteredCargo.add(cargo);
	endwhile;
	
	create 	cmifVehicleAppJSON transient;
	response := cmifVehicleAppJSON.getCargoAsJSON(machine,filteredCargo);
		
	return response;
	
epilog
	delete allDischargeCargo;	
	delete filteredCargo;
	delete iter;
	delete cmifVehicleAppJSON;
	
	finaliseJSONResponse(response);	
	return response;
end;
	
</source>
        <Parameter name="cargoId" type="String"/>
        <Parameter name="optionalParam" type="ParamListType"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getCargoForDriverMove" id="0c538107-3ccc-4b9f-bc65-1a3b9d678d47">
        <updating/>
        <source>getCargoForDriverMove(cargoId: String; optionalParam: ParamListType): String updating;
/*

Purpose: This is the REST version of machineGetDriverMoveCargo

Parameters:

			
Return Value: 


Date		Name	TFS#		Description
============================================================================
22 Feb 2021	jlika1	49429		Initial creation
06 May 2021 jlika1	49531		Fixed the bug in getting the config which is sending self instead of the machine which resulted in getting the terminal default config instead of the vehicle.
13 May 2021	jlika1	49579		Make the code work for the load more feature.
22 Apr 2022	jlier1	53023		Driver Mode Multi Move.
1 Dec 2022	jlier1 	55475 		if second id is entered but not the first search by the first
20 Mar 2023 jlier1  57064       Refactored JSON returned - changes so numbers are returned as numbers, timestamp and  measurement fields as objects
============================================================================*/

vars
	response			: String;	
	machine 			: CM_Machine;
	twinCargoId,theCargoId			: String;
	limit				: Integer;
	startIndex			: Integer;
	isMultiMove 		: Boolean;
	enqController : CM_EnqControllerTI;
	critLine 	: CM_SelectorCriteriaLine;
	qDef  : CM_QueryDefinition;
	allowedCargoTypes : IntegerArray;
	cargoType : CM_CargoType;
	allFoundTIs : CM_TIArray;
	iter : Iterator;
	matchedTIs		: CM_TISet;	
	included			: Integer;
	ti			: CM_TrackedItem;
	cmifVehicleAppJSON : CMIF_VehicleAppJSON;
begin
	on CM_Exception do self.handleCMException(exception);
	on LockException do self.handleLockExceptions(exception);
	
	self.initialisePassportMachine();
	
	app.writeLog(method.qualifiedName, LogTRACE);	
	
	// Initialises user and checks request has valid headers deletes and recreates the passport
	if self.httpStatusCode &lt;&gt; HttpResponseOK then
		//user has not validated
		app.writeLog(method.qualifiedName &amp; Tab &amp; self.httpStatusCode.String, LogERROR);	//25 Nov 2019	NDL	TFS 47053	//navra1 - 24th Aug 2022 - TFS 50365
		return response;
	endif;	
	
	self.setIgnoreWarnings(true);
	
	machine := app.myPassport.myMachine;
	machine.validateForVehicleApp(true);
	if app.myPassport.hasErrors then	
		self.httpStatusCode := HttpResponseForbidden;
		return response;
	endif;	
	
	theCargoId:=cargoId;
	twinCargoId := parseParameterList(optionalParam, 1, String).String;
	if twinCargoId &lt;&gt; null and cargoId = null then
		theCargoId:=twinCargoId;
		twinCargoId:=null;
	endif;
	startIndex := parseParameterList(optionalParam, 2, Integer).Integer;
	limit := parseParameterList(optionalParam, 3, Integer).Integer;		
	isMultiMove :=parseParameterList(optionalParam, 4, Boolean).Boolean;		
	if limit = 0 or limit &gt; 50 then	
		limit := 50;						
	endif;	
	
	enqController := self.setupCargoSearchEnquiry(qDef,startIndex,limit );	
	if enqController = null then
		app.writeLog("enq controller = null", LogINFO);
		return response;
	endif;

	critLine:=enqController.myCriteriaLineHolder.findCriteriaByName( CM_TrackedItem::id.name);
	if critLine = null and theCargoId.trimBlanks &lt;&gt; null then
		critLine:=qDef.createCriteriaLine(CM_TrackedItem::id.name,CM_QueryOperator.Operator_StartsOrEndsWith, theCargoId);
		if critLine &lt;&gt; null then
			critLine.setMyCriteriaLineHolder(enqController.myCriteriaLineHolder);
		endif;
	endif;
	//still deciding if it needs to always be on site
	critLine:=enqController.myCriteriaLineHolder.findCriteriaByName(CM_TrackedItem::state.name);
	if critLine = null then
		critLine:=qDef.createCriteriaLine( CM_TrackedItem::state.name, CM_QueryOperator.Operator_Equal, TI_STATE_NORMAL);
		if critLine &lt;&gt; null then
			critLine.setMyCriteriaLineHolder(enqController.myCriteriaLineHolder);
		endif;
	endif;
	//
	critLine:=enqController.myCriteriaLineHolder.findCriteriaByName( CM_TrackedItem::cargoType.name);
	if critLine = null then
		create allowedCargoTypes transient;
		foreach cargoType in machine.allAllowedCargoTypes discreteLock do
			allowedCargoTypes.add(cargoType.id);
		endforeach;
	endif;
	
	//jlier1 TFS 54192 25/7/22
	if isMultiMove and theCargoId = null then
		app.raiseCMException(Input_required_field_cargoId,null,null);
		return response;
		
	endif;
	enqController.doQuery( qDef );
	//do the alt id search - not doing it for twin cargo
	if enqController.id &lt;&gt; null and enqController.site = SEL_QUERYSITE_ONSITE  then
		//check onsite alt id
		critLine := enqController.myCriteriaLineHolder.findCriteriaByName(CM_TrackedItem::id.name);	
		if critLine &lt;&gt; null then
			critLine.setMyCriteriaLineHolder(null);
			delete critLine;
		endif;
		qDef.createCriteriaLine( CM_TrackedItem::alternativeId.name, CM_QueryOperator.Operator_StartsWith,  enqController.id);
		if critLine &lt;&gt; null then
			critLine.setMyCriteriaLineHolder(enqController.myCriteriaLineHolder);
		endif;
		enqController.altId:= enqController.id;
		enqController.doOnSiteAltIdSearch();	
	endif;
	
	
	create allFoundTIs transient;
	enqController.allObjects.copy(allFoundTIs);
	
	if twinCargoId &lt;&gt; null then
		critLine:=enqController.myCriteriaLineHolder.findCriteriaByName( CM_TrackedItem::id.name);
		if critLine &lt;&gt; null then
			critLine.setMyCriteriaLineHolder(null);
			delete critLine;
		endif;
		
		critLine:=qDef.createCriteriaLine(CM_TrackedItem::id.name,CM_QueryOperator.Operator_StartsOrEndsWith, twinCargoId);
		if critLine &lt;&gt; null then
			critLine.setMyCriteriaLineHolder(enqController.myCriteriaLineHolder);
		endif;
		
		enqController.doQuery( qDef );
		enqController.allObjects.copyNoDups(allFoundTIs);
	endif;
	
	iter := allFoundTIs.createIterator;
	if startIndex &gt; 0 and startIndex &lt; allFoundTIs.size then
		iter.startAtIndex(startIndex);
	else
		if startIndex &gt; allFoundTIs.size then
			iter.startAtIndex(allFoundTIs.size);
		endif;
	endif;
	app.writeLog("Found num results  " &amp; allFoundTIs.size().String , LogINFO);
	
	create matchedTIs transient;
	
	while iter.next( ti ) do
		if not matchedTIs.includes(ti) then
			if isMultiMove then
				app.myPassport.clearErrorsWarnings();
				machine.validateForMultiMove(ti);
				 if app.myPassport.hasErrors then
					break;
				endif;
			endif;
			
			if included &gt; limit then
				app.writeLog("Return max results " , LogDEBUG);	
				break; //found enough items
			endif;
			included:=included+1;
			
			matchedTIs.add(ti);
		endif;
	endwhile;
	
	if (matchedTIs.size &gt; 0) then
		app.myPassport.clearErrorsWarnings();
	endif;
	
		
	//jlier1 TFS 57064 20/3/23
	create 	cmifVehicleAppJSON transient;
	response := cmifVehicleAppJSON.getCargoAsJSON(machine,matchedTIs);
	
	return response;
epilog
	delete allowedCargoTypes;
	delete matchedTIs;
	delete iter;
	delete allFoundTIs;
	if enqController &lt;&gt; null then
		if enqController.myCriteriaLineHolder &lt;&gt; null then
			delete enqController.myCriteriaLineHolder;
		endif;
	endif;
	delete enqController;
	delete cmifVehicleAppJSON;
	finaliseJSONResponse(response);	
	return response;
end;
	
</source>
        <Parameter name="cargoId" type="String"/>
        <Parameter name="optionalParam" type="ParamListType"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getCargoForMoveByType" id="224deb6c-db22-4c2e-a3b8-33a47c3a3b38">
        <updating/>
        <source>getCargoForMoveByType(cargoId: String; twinCargoId: String; optionalParam: ParamListType): String updating;
/*

Purpose: This is the REST version of machineGetDirectorCargo

Parameters:

			
Return Value: 


Date		Name	TFS#		Description
============================================================================
18 Feb 2021	jlika1	49429		Initial creation
30 Mar 2021 jlika1	49480		Add the capability to do a Load More option in the .Net side
============================================================================*/

vars
	machine 	: CM_Machine;
	response	: String;	
	index		: Integer;	
	limit		: Integer;
	
begin	
	on CM_Exception do self.handleCMException(exception);
	on LockException do self.handleLockExceptions(exception);
	
	self.initialisePassportMachine();
	
	app.writeLog(method.qualifiedName, LogTRACE);	
	
	// Initialises user and checks request has valid headers deletes and recreates the passport
	if self.httpStatusCode &lt;&gt; HttpResponseOK then
		//user has not validated
		app.writeLog(method.qualifiedName &amp; Tab &amp; self.httpStatusCode.String, LogERROR);	//25 Nov 2019	NDL	TFS 47053	//navra1 - 24th Aug 2022 - TFS 50365
		return response;
	endif;	
	
	machine := app.myPassport.myMachine;
	machine.validateForVehicleApp(true);
	if app.myPassport.hasErrors then	
		self.httpStatusCode := HttpResponseForbidden;
		app.writeLog(method.qualifiedName &amp; Tab &amp; self.httpStatusCode.String, LogERROR);	//25 Nov 2019	NDL	TFS 47053	//navra1 - 24th Aug 2022 - TFS 50365
		return response;
	endif;	
	
	// Get the parameters
	index := parseParameterList(optionalParam, 1, Integer).Integer;
	limit := parseParameterList(optionalParam, 2, Integer).Integer;
	
	// Set Defaults

	if limit = 0 then
		limit := 50;
	endif;
	if limit &gt; 250 then
		limit := 250;
	endif;
	if index = 0 then
		index := 1;
	endif;
	
	self.setIgnoreWarnings(true);
	response := machine.getDirectorCargoAsJSON(cargoId.asStringRESTFUL.trimBlanks, twinCargoId.asStringRESTFUL.trimBlanks, index, limit);
	
	app.myPassport.clearErrorsWarnings();
	
	return response;
	
epilog
		
	finaliseJSONResponse(response);	
	return response;
end;
	
</source>
        <Parameter name="cargoId" type="String"/>
        <Parameter name="twinCargoId" type="String"/>
        <Parameter name="optionalParam" type="ParamListType"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getCargoForRelease" id="bbe6ce63-43a7-4a40-96e2-27bba089dcdd">
        <updating/>
        <source>getCargoForRelease(releaseOid :String ; reserveDetailOid : String; sourceAreaId : String; ordering : String; optionalParam : ParamListType) : WS_CargoSummaryResponse updating;
/*

Purpose:			

Parameters:			

Return Value:		
/* Changes

Date		Who		Reason
02/08/2019	jlgns1	Initial creation
06/08/2019 	JLGNS1	ChangeRequest 45293: JMT Handheld Apps - Release Staging Jade
15/08/2019	jlgka1	45924		JMT - Pack by Request - Webservice. 
								BA decided to change the logic to use CM_TerminalArea instead of the yard interchanged
								and use a Dictionary instead of TIArray.
21/08/2019	jlgrr1	45924		Change to method structure for JMT REST Apis to support the fact
								optional parameters can not be passed in the middle of the parameter list	
30/08/2019	jlger1	45291       Fixed searching with a starting index 
07/04/2022	navmd1	53371		Moved/Copied from JMTHandheldService to MTNInternalAPIService
05/03/2025	navdap1	MTN-34024 PRP | Deadlock 1081, Yard Allocation &amp; Release Request Performance
18/03/2025	navdap1	MTN-34394 MTN - getCargoForRelease Internal API not returning any cargo items
*/

constants
	All_STR = "-1";
vars
	limit 			 : Integer ;
	index 			 : Integer ;
	realRelease		 : CM_BulkRelease;
	realResDet 		 : CM_ReserveDetail;
	iter 			 : Iterator;
	cargo 			 : CM_TrackedItem;
	count 			 : Integer;
	rsCargo 		 : WS_CargoSummary;
	response 		 : WS_CargoSummaryResponse ;
	tiDD 			 : DynaDictionary;					// jlgka1 TFS 45924 --&gt;
	realArea 		 : CM_TerminalArea;
	failedDAC  		 : CM_DataAccessController ;
begin

	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	on LockException do self.handleLockExceptions(exception);
	
	create response transient;
	
	// Set app.mypassport - user / terminal &amp; machine
	self.initialisePassport();
	
	if self.httpStatusCode &lt;&gt; HttpResponseOK then
		//user has not validated
		app.writeLog(method.qualifiedName &amp; Tab &amp; self.httpStatusCode.String, LogERROR);	//25 Nov 2019	NDL	TFS 47053	//navra1 - 24th Aug 2022 - TFS 50365
		return response;
	endif;	

	// Get the parameters
	limit 			:= parseParameterList(optionalParam, 1, Integer).Integer;
	index 			:= parseParameterList(optionalParam, 2, Integer).Integer;

	app.writeLog("param list length ="   &amp; app.getParamListTypeLength(optionalParam) .String, LogDEBUG);	//26 Nov 2019	NDL	TFS 47053
	
	app.writeLog("param list ="   &amp; releaseOid &amp; ",/" &amp; reserveDetailOid &amp; ",/" &amp; sourceAreaId &amp; ",/" &amp; ordering&amp; ",/" &amp; limit.String, LogDEBUG);	//26 Nov 2019	NDL	TFS 47053		
	
	// Check for errrors
	if app.myPassport.hasErrors then
		return response;
	endif;
		
	// Set Defaults
	if limit = 0 then
		limit := 50;
	endif;
	if limit &gt; 250 then
		limit := 250;
	endif;
	if index = 0 then
		index := 1;
	endif;
		
	realRelease := app.myPassport.getObjectOfTypeFromOid(releaseOid, CM_BulkRelease).CM_BulkRelease;	
	
	if realRelease = null then
		app.raiseCMException(Input_required_field_delReleas,null,null);
		return response;
	endif;

	realResDet := app.myPassport.getObjectOfTypeFromOid(reserveDetailOid, CM_ReserveDetail).CM_ReserveDetail;
	
	if app.myPassport.hasErrors then
		return response;
	endif;
		
	if sourceAreaId &lt;&gt; All_STR then
		realArea :=	app.myPassport.myTerminal.allTerminalAreas.getAtKey(sourceAreaId);
				
		if realArea &lt;&gt; null then
			if not realArea.canUserAccessSelf(app.getMyUser,failedDAC ,app.myPassport) then
				app.raiseCMException3(ERR_USER_NO_ACCESS,app.getMyUser.identity,app.getErrorString(TerminalArea),sourceAreaId, null,null);
				return response;
			endif;
				
		endif;
	endif;
	// jlgka1 TFS 45924 --&gt;	
	create tiDD  transient; 
	tiDD.setMembership(CM_TrackedItem);
	
	if ordering = "FIFO" then
		tiDD.addMemberKey(CM_TrackedItem::receivedDT.name, false, false);
		tiDD.addMemberKey(CM_TrackedItem::id.name, false, true);
		tiDD.addMemberKey(CM_TrackedItem::oidAsBin.name,false,false);
	else
		tiDD.addMemberKey(CM_TrackedItem::id.name, false, true);
		tiDD.addMemberKey(CM_TrackedItem::receivedDT.name, false, false);
		tiDD.addMemberKey(CM_TrackedItem::oidAsBin.name,false,false);
	endif;
	tiDD.endKeys(true);
	
	realRelease.getProspectiveCargo(realResDet, realArea, null,null, tiDD, ordering &lt;&gt; "FIFO", limit, index, count);	// MTN-34024
	// MTN-34394 reset count so we get all the items in the TI set (should only be limit)
	if ordering &lt;&gt; "FIFO" then
		count := null;
	endif;
	// jlgka1 TFS 45924 &lt;--
	
	iter := tiDD.createIterator;	
	while iter.next(cargo) and count &lt; ((index-1) + limit) do
	
		if not cargo.canUserAccessSelf(app.getMyUser,failedDAC ,app.myPassport) then
			continue;
		endif;
		count := count + 1;
		if index &gt; 1 then
			if count &lt; index then
				continue;
			endif;
		endif;
	
		create rsCargo transient;
		rsCargo.setProxyFromObject(cargo);
		response.allCargoSummaries.add(rsCargo);
				
	endwhile;
		
	return response;

epilog
	delete tiDD;
	delete iter;
	finaliseResponse(response);
end;</source>
        <Parameter name="releaseOid" type="String"/>
        <Parameter name="reserveDetailOid" type="String"/>
        <Parameter name="sourceAreaId" type="String"/>
        <Parameter name="ordering" type="String"/>
        <Parameter name="optionalParam" type="ParamListType"/>
        <ReturnType type="WS_CargoSummaryResponse"/>
    </JadeMethod>
    <JadeMethod name="getCargoForWarehouseMulti" id="512cd308-8607-45ad-ad7d-56317fe191fe">
        <updating/>
        <source>getCargoForWarehouseMulti(voyageOid : String; cargoTypeID : String; optionalParam : ParamListType) : WS_CargoSummaryResponse updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 Nov 2022	jlier1	Initial creation 55404
17 Jan 2023 jlier1 	TFS 56087 - changed from mark to mark number
19 Oct 2023	jlizm1	TFS 60944 warehouse multi move search by alt id
*/

vars	
	response : WS_CargoSummaryResponse;
	startIndex : Integer;
	enqController : CM_EnquiryController;
	qDef  : CM_QueryDefinition;
	critLine 	: CM_SelectorCriteriaLine;
	voyage : CM_Voyage;
	cargoType : CM_CargoType;
	iter 	: Iterator;
	matchedTIs		: CM_TISet;	
	obj : Object;
	wsCargoSummary : WS_CargoSummary;
	cargoID,
	cargoGroupId	: String;
	cargo : CM_TrackedItem;
	cargoGroup	: CM_CargoGroup;
	ti : CM_TrackedItem;
	useAltId 	: Boolean;
begin
	on CM_Exception do self.handleCMException(exception);
	on LockException do self.handleLockExceptions(exception);
	
	create response transient;
	
	self.initialisePassport();
	
	app.writeLog(method.qualifiedName, LogTRACE);	
	
	// Initialises user and checks request has valid headers deletes and recreates the passport
	if self.httpStatusCode &lt;&gt; HttpResponseOK then
		//user has not validated
		app.writeLog(method.qualifiedName &amp; Tab &amp; self.httpStatusCode.String, LogERROR);	//25 Nov 2019	NDL	TFS 47053	//navra1 - 24th Aug 2022 - TFS 50365
		return response;
	endif;	
	
	if voyageOid = null then
		app.raiseCMException(Input_required_field_voyage,null,null);
		return response;
	endif;
	
	voyage := app.myPassport.getObjectOfTypeFromOid(voyageOid, CM_Voyage).CM_Voyage;	
	if voyage = null then
		app.raiseCMException(Input_required_field_voyage,null,null);
		return response;
	endif;
	
	if cargoTypeID = null then
		app.raiseCMException(Input_required_field_cargoType,null,null);
		return response;
	endif;
	
	cargoType:=app.myRoot.allCargoTypesById[cargoTypeID.Integer];
	if cargoTypeID = null then
		app.raiseCMException(Input_required_field_cargoType,null,null);
		return response;
	endif;
	
	startIndex:=1;
	enqController := self.setupCargoSearchEnquiry(qDef,startIndex,null );	
	if enqController = null then
		app.writeLog("enq controller = null", LogINFO);
		return response;
	endif;

	// needs to always be on site
	critLine:=enqController.myCriteriaLineHolder.findCriteriaByName(CM_TrackedItem::state.name);
	if critLine = null then
		critLine:=qDef.createCriteriaLine( CM_TrackedItem::state.name, CM_QueryOperator.Operator_Equal, TI_STATE_NORMAL);
		if critLine &lt;&gt; null then
			critLine.setMyCriteriaLineHolder(enqController.myCriteriaLineHolder);
		endif;
	endif;
	
	//set the voyage
	critLine:=enqController.myCriteriaLineHolder.findCriteriaByName( CM_TrackedItem::voyageCode.name);
	if critLine &lt;&gt; null then
		critLine.setMyCriteriaLineHolder(null);
		delete critLine;
	endif;
	critLine:=qDef.createCriteriaLine(CM_TrackedItem::voyageCode.name, CM_QueryOperator.Operator_Equal, voyage);
	if critLine &lt;&gt; null then
		critLine.setMyCriteriaLineHolder(enqController.myCriteriaLineHolder);
	endif;
	
	//set the cargo Type
	critLine:=enqController.myCriteriaLineHolder.findCriteriaByName( CM_TrackedItem::cargoType.name);
	if critLine &lt;&gt; null then
		critLine.setMyCriteriaLineHolder(null);
		delete critLine;
	endif;
	critLine:=qDef.createCriteriaLine( CM_TrackedItem::cargoType.name, CM_QueryOperator.Operator_Equal, cargoType);
	if critLine &lt;&gt; null then
		critLine.setMyCriteriaLineHolder(enqController.myCriteriaLineHolder);
	endif;
	
	cargoID := parseParameterList(optionalParam, 1, String).String;
	
	if cargoID &lt;&gt; null then
	
		//find the cargo onsite if it exists get the cargo group and mark from it and set up the search criteria with that
		
		cargo:=app.myPassport.myTerminal.allOnsiteTIsByIdCargoType[cargoID,cargoTypeID.Integer];
		if cargo = null then
			// cargo id not found, try by alternative id
			cargo := app.myPassport.myTerminal.allOnsiteTIsByAlternativeId[cargoID];
			if cargo &lt;&gt; null then
				useAltId := true;
				iter:=app.myPassport.myTerminal.allOnsiteTIsByAlternativeId.createIterator;
			endif;
		else
			useAltId := false;
			iter:=app.myPassport.myTerminal.allOnsiteTIsByIdCargoType.createIterator;
		endif;
		
		//jlier1 TFS 58471 16/6/23
		if cargo &lt;&gt; null then
			iter.startAtObject(cargo);
			cargo:=null;
			while iter.next(ti) do
				//should match voyage
				if useAltId and ti.alternativeId &lt;&gt; cargoID then
					break;
				elseif not useAltId and ti.id &lt;&gt; cargoID then
					break;
				endif;
				if ti.cargoType &lt;&gt; cargoTypeID.Integer then
					break;
				endif;
				if ti.myVoyage = voyage then
					cargo:=ti;
					break;
				endif;
			endwhile;
			delete iter;
		endif;
		if cargo &lt;&gt; null then
			//set the cargo Type
			critLine:=enqController.myCriteriaLineHolder.findCriteriaByName( CM_TrackedItem::markNumber.name); //jlier1 TFS 56087 changed to mark Number
			if critLine &lt;&gt; null then
				critLine.setMyCriteriaLineHolder(null);
				delete critLine;
			endif;
			critLine:=qDef.createCriteriaLine( CM_TrackedItem::markNumber.name, CM_QueryOperator.Operator_Equal, cargo.markNumber);
			if critLine &lt;&gt; null then
				critLine.setMyCriteriaLineHolder(enqController.myCriteriaLineHolder);
			endif;	
				//set the cargo Type
			critLine:=enqController.myCriteriaLineHolder.findCriteriaByName( CM_TrackedItem::getMyCargoGroupId.name);
			if critLine &lt;&gt; null then
				critLine.setMyCriteriaLineHolder(null);
				delete critLine;
			endif;
			
			critLine:=qDef.createCriteriaLine( CM_TrackedItem::getMyCargoGroupId.name, CM_QueryOperator.Operator_Equal, cargo.getMyCargoGroupId);
			if critLine &lt;&gt; null then
				critLine.setMyCriteriaLineHolder(enqController.myCriteriaLineHolder);
			endif;	
			
		else
			//jlier1 TFS 58469 15/6/23
			app.raiseCMException1(Cargo_item_not_found_site,cargoID ,null,null);
			return response;
		endif;
	else
		// jlier1 TFS 58469guess we will check if cargo group is valid
		critLine:=enqController.myCriteriaLineHolder.findCriteriaByName( CM_TrackedItem::getMyCargoGroupId.name);
		if critLine &lt;&gt; null then
			cargoGroupId:=critLine.myQueryOperator.getSearchValue().String;
			if cargoGroupId &lt;&gt; null then
				cargoGroup:=app.myPassport.myTerminal.allCargoGroupsByIdCargoType.getAtKeyGeq(cargoGroupId,null).CM_CargoGroup;
				if cargoGroup = null or cargoGroup.id &lt;&gt; cargoGroupId then
					app.raiseCMException1(Cargo_group_not_found ,cargoGroupId,null,null);
				endif;
			endif;
		endif;
	endif;
		
	enqController.doQuery( qDef );
	
	create matchedTIs transient;
	
	iter := enqController.allObjects.createIterator;
	
	while iter.next( obj ) do
		if not matchedTIs.includes(obj.CM_TrackedItem) then	
			create wsCargoSummary transient;
			wsCargoSummary.setProxyFromObject(obj.CM_TrackedItem);
			response.allCargoSummaries.add(wsCargoSummary);
			matchedTIs.add(obj.CM_TrackedItem);
		endif;
	endwhile;
	
	return response;
epilog
	delete iter;
	if enqController &lt;&gt; null then
		if enqController.myCriteriaLineHolder &lt;&gt; null then
			delete enqController.myCriteriaLineHolder;
		endif;
	endif;
	delete enqController;
	delete matchedTIs;
	self.finaliseResponse(response);
end;</source>
        <Parameter name="voyageOid" type="String"/>
        <Parameter name="cargoTypeID" type="String"/>
        <Parameter name="optionalParam" type="ParamListType"/>
        <ReturnType type="WS_CargoSummaryResponse"/>
    </JadeMethod>
    <JadeMethod name="getCargoGroupAssignById" id="db986bd0-b5fa-4ca2-8e74-2565c6bf29ff">
        <updating/>
        <source>getCargoGroupAssignById(groupAssignId : String) : WS_CargoGroupAssignResponse updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
05 August 2021	jlier1	Initial creation 51683
07 April 2022 	navmd1	TFS 53371 Moved/Copied from JMTHandheldService to MTNInternalAPIService

*/

vars
	response 	: WS_CargoGroupAssignResponse;
	terminal 	: CM_Terminal;
	cargoGroupAssign : CM_CargoGroupAssignment;
	wsCargoGroupAssign : WS_CargoGroupAssign;
begin
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	on LockException do self.handleLockExceptions(exception);
	
	create response transient;
	
	// Set app.mypassport - user / terminal &amp; machine
	self.initialisePassport();
	
	if self.httpStatusCode &lt;&gt; HttpResponseOK then
		//user has not validated
		app.writeLog(method.qualifiedName &amp; Tab &amp; self.httpStatusCode.String, LogERROR);	//25 Nov 2019	NDL	TFS 47053	//navra1 - 24th Aug 2022 - TFS 50365
		return response;
	endif;	

	terminal := app.myPassport.myTerminal;
	
	if groupAssignId.trimBlanks = "" then
	//need to change to appriopriate error
		app.raiseCMException(Input_requir_cargo_group_assig, null, null);
		return response;
	endif;
	
	cargoGroupAssign:= terminal.findCargoGroupAssignment( groupAssignId.asStringRESTFUL.trimBlanks );	
	
	if cargoGroupAssign = null then
		//need to change to appriopriate error
		app.raiseCMException1(Not_find_cargo_group_assig_wit,groupAssignId.asStringRESTFUL.trimBlanks , null, null);
		return response;
	endif;
	
	if cargoGroupAssign &lt;&gt; null then
		create wsCargoGroupAssign transient;
		wsCargoGroupAssign.setProxyFromObject(cargoGroupAssign);	
		response.myCargoGroupAssign:= wsCargoGroupAssign;
	endif;
	
	return response;
epilog
	self.finaliseResponse(response);

end;</source>
        <Parameter name="groupAssignId" type="String"/>
        <ReturnType type="WS_CargoGroupAssignResponse"/>
    </JadeMethod>
    <JadeMethod name="getCargoGroupById" id="5758b750-0a60-4966-9287-8dc96d90ad8a">
        <updating/>
        <source>getCargoGroupById(groupId : String; optionalParam : ParamListType) : WS_CargoGroupResponse updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
12 August 2021	jlier1	Initial creation 51684
07 April 2022 	navmd1	TFS 53371 Moved/Copied from JMTHandheldService to MTNInternalAPIService
*/

vars
	response 	: WS_CargoGroupResponse;
	terminal 	: CM_Terminal;
	cargoGroup : CM_CargoGroup;
	wsCargoGroup : WS_CargoGroup;
	locationOid : String;
	location	: CM_LocationsController;
	lcs : CM_LCSet;
begin
		// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	on LockException do self.handleLockExceptions(exception);
	
	create response transient;
	// Set app.mypassport - user / terminal &amp; machine
	
	self.initialisePassport();
	
	if self.httpStatusCode &lt;&gt; HttpResponseOK then
		//user has not validated
		app.writeLog(method.qualifiedName &amp; Tab &amp; self.httpStatusCode.String, LogERROR);	//25 Nov 2019	NDL	TFS 47053	//navra1 - 24th Aug 2022 - TFS 50365
		return response;
	endif;	
	
	terminal := app.myPassport.myTerminal;
	
	if groupId.trimBlanks = "" then
		app.raiseCMException(Cargo_group_required, null, null);
		return response;
	endif;
	cargoGroup:= terminal.getCargoGroupItem( groupId.asStringRESTFUL );
	if cargoGroup = null then
		app.raiseCMException1(Cargo_group_not_found,groupId.asStringRESTFUL, null, null);
		return response;
	endif;
	
	// Get the optional parameters
	locationOid := parseParameterList(optionalParam, 1, String).String;
	if locationOid.trimBlanks &lt;&gt; "" then
		location:=app.myPassport.getObjectOfTypeFromOid(locationOid,CM_LocationsController).CM_LocationsController;
	endif;
		 
	if cargoGroup &lt;&gt; null then
		if location &lt;&gt; null then
			//check location part of cargo group
			create lcs transient;
			cargoGroup.getAllLocations( lcs );
			if not lcs.includes( location ) then
				 app.raiseCMException2(Does_not_inclu_cargo_that_curr,cargoGroup.id,location.getFullId,null,null);
				 return response;
			endif;
		endif;
	
		create wsCargoGroup transient;
		wsCargoGroup.setProxyFromObject(cargoGroup);
		response.myCargoGroup:= wsCargoGroup;
	endif;
	
	return response;
epilog
	delete lcs;
	self.finaliseResponse(response);

end;</source>
        <Parameter name="groupId" type="String"/>
        <Parameter name="optionalParam" type="ParamListType"/>
        <ReturnType type="WS_CargoGroupResponse"/>
    </JadeMethod>
    <JadeMethod name="getCargoGroupItemsbyId" id="f7f47fa5-7196-40d7-b24a-2a7515e59169">
        <updating/>
        <source>getCargoGroupItemsbyId(cargoGroupId : String) : WS_CargoGroupItemsResponse updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 Jan 2023	navak20 Task 55838: New Rest end point to return cargo group detail
24 Mar 2023	navpw1	Defect 57204: Added offSite and prenote to response
29 Aug 2023 navma1	Bug 59910: EUP | Cargo Group - OffSite location should show OffSite instead of empty string - FR 53422 | Ticket 59683
12 Sep 2023 navlc30 Bug 59889: EUP | Cargo Group - special stow should be grouped by description instead of true/false - FR 53422 | Ticket 59683
12 Sep 2023 navlc30 Bug 59886: EUP | Cargo Group - Quantity not showing total quantity of cargo - FR 53422 | Ticket 59683
12 Sep 2023 navlc30 Bug 59888: EUP | Cargo Group - not showing summary values correctly FR 53422 | Ticket 59683
12 Jan 2024 navbk1  CR  62005:  FR | 53422 - Cargo Group overview in Mobile Apps (part II)
*/

vars
	response		: WS_CargoGroupItemsResponse;
	cargoGroup		: CM_CargoGroup;
	terminal 		: CM_Terminal;
	ti				: CM_TrackedItem;
	itemObject		: WS_CargoGroupItemObject;
	locationObj 	: WS_CargoGroupLocationObject;
	locationDesc	: String;
	
begin
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	on LockException do self.handleLockExceptions(exception);
	
	create response transient;
	
	// Set app.mypassport - user / terminal &amp; machine
	self.initialisePassport();
	
	if self.httpStatusCode &lt;&gt; HttpResponseOK then
		//user has not validated
		app.writeLog(method.qualifiedName &amp; Tab &amp; self.httpStatusCode.String, LogERROR);
		return response;
	endif;
	
	// Check for errrors
	if app.myPassport.hasErrors then
		return response;
	endif;
	
	if cargoGroupId.trimBlanks = "" then
		app.raiseCMException(Cargo_group_required, null, null);
		return response;
	endif;
	
	terminal := app.myPassport.myTerminal;
	cargoGroup := terminal.getCargoGroupItem(cargoGroupId.asStringRESTFUL );
	if cargoGroup = null then
		app.raiseCMException1(Cargo_group_not_found,cargoGroupId.asStringRESTFUL, null, null);
		return response;
	endif;
	
	foreach ti in cargoGroup.allAssignedTrackedItems do
		if ti.isOffSite then													//29.08.2023 navma1 #59910
			locationDesc := TI_SITE_OFFSITE_str;
		elseif ti.isPreNote then												//29.08.2023 navma1 #59910
			locationDesc := app.getErrorString(Notified_tracked_item);
		else
			locationDesc := ti.getPrimaryLocationId(REAL_MODE);
		endif;
		
		//itemObject := response.allCargoItems[locationDesc];												//12.9.2023 navlc30 #59888
		
		//if itemObject = null then																			//12.9.2023 navlc30 #59888
			create itemObject transient;
			itemObject.grade 		:= ti.getGrade();
			itemObject.grammage 	:= ti.getGrammage().asStringJMT();
			itemObject.height 		:= ti.height.String;
			itemObject.length 		:= ti.length.String;
			itemObject.location 	:= locationDesc;
			itemObject.markNumber 	:= ti.markNumber;
			
			if ti.state = TI_STATE_ONSHIP then
				itemObject.onShip := ti.totalQuantity;														//20.9.2023 navlc30 #59886
			elseif ti.state = TI_STATE_OFFSITE then
				itemObject.offSite := ti.totalQuantity;	// ### TFS 57204 24Mar2023 NAVPW1					//20.9.2023 navlc30 #59886
			elseif ti.state = TI_STATE_NOTIFIED then
				itemObject.prenote :=ti.totalQuantity;	// ### TFS 57204 24Mar2023 NAVPW1					//20.9.2023 navlc30 #59886
			elseif ti.isOnSite() then																		//12.9.2023 navlc30 #59886
				itemObject.onSite := ti.totalQuantity;
			endif;
			if ti.specialStow &lt;&gt; null then																	//12.9.2023 navlc30 #59889
				itemObject.specialStowCode := ti.specialStow;
				itemObject.specialStowDesc := app.myRoot.allSpecialStows[ti.specialStow].description;
			endif;
			
			if ti.isKindOf(CM_BreakBulkGeneric) then														//12.9.2023 navlc30 #59888
				itemObject.diameter := ti.CM_BreakBulkGeneric.getDiameter().asStringJMT();
				itemObject.rollingLength := ti.CM_BreakBulkGeneric.getRollingLength().asStringJMT();
			endif;	
			//itemObject.specialStow 	:= ti.specialStow &lt;&gt; null;											//12.9.2023 navlc30 #59889
			itemObject.totalVolume  := ti.totalVolume.String;
			itemObject.totalWeight  := ti.totalWeight.String;
			itemObject.width        := ti.width.String;
			
			response.allCargoItems.add(itemObject);
			self.objectsToBeDeleted.add(itemObject);
		/*else																								//12.9.2023 navlc30 #59888
			if ti.state = TI_STATE_ONSHIP then
				itemObject.onShip  += 1;
			elseif ti.state = TI_STATE_OFFSITE then
				itemObject.offSite += 1;
			elseif ti.state = TI_STATE_NOTIFIED then
				itemObject.prenote += 1;
			endif;
		endif;*/
		
		locationObj := response.allCargoGroupLocations[locationDesc];
		
		if locationObj = null then
			create locationObj transient;
			locationObj.location := locationDesc;
			locationObj.quantity := ti.totalQuantity;														//12.9.2023 navlc30 #59886
			if ti.damaged then																				//12.1.2024 navbk1  #62005
				locationObj.damagedQuantity := ti.totalQuantity;
			endif;
			response.allCargoGroupLocations.add(locationObj);
			self.objectsToBeDeleted.add(locationObj);
		else
			locationObj.quantity += ti.totalQuantity;														//12.9.2023 navlc30 #59886
			if ti.damaged then																				//12.1.2024 navbk1  #62005
				locationObj.damagedQuantity += ti.totalQuantity;
			endif;
		endif;
    endforeach;
	return response;
epilog
	self.finaliseResponse(response);
end;</source>
        <Parameter name="cargoGroupId" type="String"/>
        <ReturnType type="WS_CargoGroupItemsResponse"/>
    </JadeMethod>
    <JadeMethod name="getCargoGroupLocations" id="120db793-7b8c-419f-ae30-ed633d3a3659">
        <updating/>
        <source>getCargoGroupLocations(): WS_CargoGroupsLocationResponse updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
06 March 2023	navak20	CR 56299: MTN - Add Cargo Group to Search component (Jade) - Make changes to reponse
*/

vars
	response		: WS_CargoGroupsLocationResponse;
	locObject,
	locationObject	: WS_CargoGroupLocationObject;
	locationDesc,
	pOperatorCode,
	pCargoGroupId,
	cargoGroupId	: String;
	quantity		: Integer;
	cargoGroup		: CM_CargoGroup;
	qsOperator,
	qsCargoGroupId	: WS_NameValuePair;
	terminal		: CM_Terminal;
	allCargoGroupsByCargoTypeId : CM_TIByCargoTypeIdDict;
	
begin
	qsCargoGroupId := self.qsData[self.QueryParam_CargoGroupId];
	if qsCargoGroupId &lt;&gt; null then
		pCargoGroupId := qsCargoGroupId.value;
	endif;
	
	qsOperator := self.qsData[self.QueryParam_OperatorCode];
	if qsOperator &lt;&gt; null then
		pOperatorCode := qsOperator.value;
	endif;
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	on LockException do self.handleLockExceptions(exception);
	
	create response transient;
	
	// Set app.mypassport - user / terminal &amp; machine
	self.initialisePassport();
	
	if self.httpStatusCode &lt;&gt; HttpResponseOK then
		//user has not validated
		app.writeLog(method.qualifiedName &amp; Tab &amp; self.httpStatusCode.String, LogERROR);
		return response;
	endif;
	
	// Check for errrors
	if app.myPassport.hasErrors then
		return response;
	endif;
	
	terminal := app.myPassport.myTerminal;
	allCargoGroupsByCargoTypeId := terminal.allCargoGroupsByCargoTypeId;
	
	foreach cargoGroup in allCargoGroupsByCargoTypeId as CM_CargoGroup do
		cargoGroupId := cargoGroup.id;
		//Filter Cargo Group Id if it is specified
		if pCargoGroupId &lt;&gt; null and not cargoGroupId.startsWith(pCargoGroupId) and not cargoGroupId.endsWith(pCargoGroupId) then
			continue;
		endif;
		
		//Filter Operator Code if it is specified
		if not pOperatorCode = null and not cargoGroup.operatorCode.startsWith(pOperatorCode) and not cargoGroup.operatorCode.endsWith(pOperatorCode) then 
			continue;
		endif;
		
		locationDesc	:= cargoGroup.getAllLocations(null).formatWithEllipsis(1, 240, true);
		quantity		:= cargoGroup.totalQuantity;
		
		locObject		:= response.allCargoGroupLocations[cargoGroupId, locationDesc];
		
		if locObject &lt;&gt; null then
			continue;
		endif;
		
		create locationObject transient;
		locationObject.cargoGroupId	:= cargoGroupId;
		locationObject.location		:= locationDesc;
		locationObject.quantity		:= quantity;
		response.allCargoGroupLocations.add(locationObject);
		self.objectsToBeDeleted.add(locationObject);
		
	endforeach;
	
	return response;
	
epilog
	self.finaliseResponse(response);
	
end;</source>
        <ReturnType type="WS_CargoGroupsLocationResponse"/>
    </JadeMethod>
    <JadeMethod name="getCargoInArea" id="07d767fb-1230-4eb6-9ab8-d552889632ab">
        <updating/>
        <source>getCargoInArea(areaID : String; optionalParam : ParamListType) : WS_CargoSummaryResponse updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 July 2019	jlgrr1	Initial creation
6/08/2019 	JLGNS1	ChangeRequest 45293: JMT Handheld Apps - Release Staging Jade
21/08/2019 jlgrr1	45924		Change to method structure for JMT REST Apis to support the fact
								optional parameters can not be passed in the middle of the parameter list
07/04/2022 navmd1	TFS 53371 Moved/Copied from JMTHandheldService to MTNInternalAPIService
*/

vars
	limit : Integer;
	index : Integer;
	iter : Iterator;
	cargo : CM_TrackedItem;
	count : Integer;
	rsCargo : WS_CargoSummary;
	response : WS_CargoSummaryResponse;
	realArea : CM_TerminalArea;
	tiDD : DynaDictionary;
	cargoItems : ObjectSet;
	failedDAC  :CM_DataAccessController ;
	
begin
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	on LockException do self.handleLockExceptions(exception);
	
	create response transient;
	
	// Set app.mypassport - user / terminal &amp; machine
	self.initialisePassport();
	
	if self.httpStatusCode &lt;&gt; HttpResponseOK then
		//user has not validated
		app.writeLog(method.qualifiedName &amp; Tab &amp; self.httpStatusCode.String, LogERROR);	//25 Nov 2019	NDL	TFS 47053	//navra1 - 24th Aug 2022 - TFS 50365
		return response;
	endif;	

	// Get the optional parameters
	limit := parseParameterList(optionalParam, 1, Integer).Integer;
	index := parseParameterList(optionalParam, 2, Integer).Integer;
	
	// Check for errrors
	if app.myPassport.hasErrors then
		return response;
	endif;
		
	// Set Defaults
	if limit = 0 then
		limit := 50;
	endif;
	if limit &gt; 250 then
		limit := 250;
	endif;
	if index = 0 then
		index := 1;
	endif;
	

	// ======================
	// Actually get the cargo
	
	create cargoItems transient;
	create tiDD transient;
	tiDD.setMembership(CM_TrackedItem);
	tiDD.addMemberKey(CM_TrackedItem::id.name, false, true);
	tiDD.addMemberKey(CM_TrackedItem::oidAsHex.name, false,false);
	tiDD.endKeys(false);
	
	if areaID.trimBlanks = "" then
		app.raiseCMException(Input_Required_For_TA, null,null);
		return response;
	endif;	
	
	
	realArea :=	app.myPassport.myTerminal.allTerminalAreas.getAtKey(areaID);
	
	
	if realArea = null then
		app.raiseCMException1(Location_invalid,areaID, null,null);
		return response;
	endif;	
	
	
	if not realArea.canUserAccessSelf(app.getMyUser,failedDAC ,app.myPassport) then
		app.raiseCMException3(ERR_USER_NO_ACCESS,app.getMyUser.identity,app.getErrorString(TerminalArea),areaID, null,null);
		return response;
	endif;
	
		
	realArea.getAllLocationsTrackedItems(cargoItems);
	cargoItems.copy(tiDD);
	iter := tiDD.createIterator;	
		
	
	while iter.next(cargo) and count &lt; ((index-1) + limit) do
		
		if not cargo.canUserAccessSelf(app.getMyUser,failedDAC ,app.myPassport) then
			continue;
		endif;
		count := count + 1;
		if index &gt; 1 then
			if count &lt; index then
				continue;
			endif;
		endif;		
		
		create rsCargo transient;
		rsCargo.setProxyFromObject(cargo);
		response.allCargoSummaries.add(rsCargo);
		
	endwhile;
	// =========================
	
	return response;

epilog
	delete cargoItems;
	delete tiDD;
	delete iter;
	finaliseResponse(response);
end;</source>
        <Parameter name="areaID" type="String"/>
        <Parameter name="optionalParam" type="ParamListType"/>
        <ReturnType type="WS_CargoSummaryResponse"/>
    </JadeMethod>
    <JadeMethod name="getCargoInLocation" id="3f6ed018-bd95-4668-9376-4809eacebeb6">
        <updating/>
        <source>getCargoInLocation(locationId : String; optionalParam : ParamListType) : WS_CargoSummaryResponse updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
13 Aug 2021	jlier1	Initial creation TFS  51684
07 Apr 2022 navmd1	TFS 53371 Moved/Copied from JMTHandheldService to MTNInternalAPIService
03 Jun 2025	navhl20 CR MTN-35026: MTN - Optimize Performance of getCargoInLocation Web Service in Location Check Mobile App
*/

vars
	iter 			: Iterator;
	cargo 			: CM_TrackedItem;
	rsCargo 		: WS_CargoSummary;
	response 		: WS_CargoSummaryResponse;
	failedDAC  		: CM_DataAccessController ;
	terminal 		: CM_Terminal;
	foundLC 		: CM_LocationsController;
	foundHeight 	: Integer;
	tiArray 		: CM_TIArray;
	cargoGroup 		: CM_CargoGroup;
	cargoGroupOid 	: String;
	skipAccessCheck	: Boolean;
	user			: CM_User;
begin
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	on LockException do self.handleLockExceptions(exception);
	
	create response transient;
	
	// Set app.mypassport - user / terminal &amp; machine
	self.initialisePassport();
	
	if self.httpStatusCode &lt;&gt; HttpResponseOK then
		//user has not validated
		app.writeLog(method.qualifiedName &amp; Tab &amp; self.httpStatusCode.String, LogERROR);	//25 Nov 2019	NDL	TFS 47053	//navra1 - 24th Aug 2022 - TFS 50365
		return response;
	endif;	

	// Check for errrors
	if app.myPassport.hasErrors then
		return response;
	endif;
	
	// ======================
	// Actually get the cargo
		
	if locationId.trimBlanks = "" then
		app.raiseCMException(Input_Required_For_Location,null,null);
		return response;
	endif;	
	
	terminal := app.myPassport.myTerminal;
	
	terminal.findLocationFromString(locationId.asStringRESTFUL ,true,foundLC,foundHeight);
	
	if foundLC = null then
		app.raiseCMException1(Location_NotFound,locationId.asStringRESTFUL,null,null);
		return response;
	endif;	
	
	// Get the optional parameters
	cargoGroupOid:=parseParameterList(optionalParam, 1, String).String;
	if cargoGroupOid &lt;&gt; null then
		cargoGroup:=app.myPassport.getObjectOfTypeFromOid(cargoGroupOid,CM_CargoGroup).CM_CargoGroup;
	endif;
	
	create tiArray transient;
	foundLC.getTIs(tiArray, REAL_MODE, true);
	
	iter := tiArray.createIterator;	
	
	user := app.getMyUser;														//03.06.2025 navhl20 #35026
	if user &lt;&gt; null then														//03.06.2025 navhl20 #35026
		skipAccessCheck := user.allDataAccessControllers.isEmpty or 
						   app.isSpecial();
	endif;
		
	while iter.next(cargo)   do
		if cargoGroup &lt;&gt; null then
			if cargo.myCargoGroup &lt;&gt; cargoGroup then
				continue;
			endif;
		endif;
		
		if not skipAccessCheck then												//03.06.2025 navhl20 #35026
			if not cargo.canUserAccessSelf(user,failedDAC ,app.myPassport) then
				continue;
			endif;
		endif;
			
		create rsCargo transient;
		//rsCargo.setProxyFromObject(cargo);									//03.06.2025 navhl20 #35026
		rsCargo.setPxyFromObjCargoLocation(cargo);								//03.06.2025 navhl20 #35026
		response.allCargoSummaries.add(rsCargo);
		
	endwhile;
	// =========================
	
	return response;

epilog
	delete iter;
	delete tiArray;
	finaliseResponse(response);

end;</source>
        <Parameter name="locationId" type="String"/>
        <Parameter name="optionalParam" type="ParamListType"/>
        <ReturnType type="WS_CargoSummaryResponse"/>
    </JadeMethod>
    <JadeMethod name="getCargoOnMachine" id="bbd6c2b2-2855-44cc-9e9d-7a7e49fd778f">
        <updating/>
        <source>getCargoOnMachine(machineOid : String) : WS_CargoSummaryResponse updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
26 July 2021	jlier1	Initial creation TFS 51626
07 April 2022 	navmd1	TFS 53371 Moved/Copied from JMTHandheldService to MTNInternalAPIService

*/

vars
	machine : CM_Machine;
	wsCargo : WS_CargoSummary;
	response : WS_CargoSummaryResponse;
	cargo : CM_TrackedItem;
	iter  : Iterator;
	failedDAC  :CM_DataAccessController ;
begin	
// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	on LockException do self.handleLockExceptions(exception);
	
	create response transient;
	
	// Set app.mypassport - user / terminal &amp; machine
	self.initialisePassport();
	
	if self.httpStatusCode &lt;&gt; HttpResponseOK then
		//user has not validated
		app.writeLog(method.qualifiedName &amp; Tab &amp; self.httpStatusCode.String, LogERROR);	//25 Nov 2019	NDL	TFS 47053	//navra1 - 24th Aug 2022 - TFS 50365
		return response;
	endif;	

	machine:=app.myPassport.getObjectOfTypeFromOid(machineOid,CM_Machine).CM_Machine;
		
	if machine = null then
		return response;
	endif;
			
	// ======================
	// Actually get the cargo

	iter:=machine.myMachineController.allTrackedItems.createIterator;
	
	while iter.next(cargo)  do
	
		if not cargo.canUserAccessSelf(app.getMyUser,failedDAC ,app.myPassport) then
			continue;
		endif;
		
		
		create wsCargo transient;
		wsCargo.setProxyFromObject(cargo);	
	
		response.allCargoSummaries.add(wsCargo);
		
	endwhile;
	// =========================
	
	return response;

epilog

	delete iter;
	finaliseResponse(response);

end;</source>
        <Parameter name="machineOid" type="String"/>
        <ReturnType type="WS_CargoSummaryResponse"/>
    </JadeMethod>
    <JadeMethod name="getCargoOnSite" id="c0d927cc-ae92-4669-8edf-ace9815ebaf2">
        <updating/>
        <source>getCargoOnSite(cargoId : String ;optionalParam : ParamListType) : WS_CargoSummaryResponse updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26 Aug 2019	cnwma1	ChangeRequest 46185: PNL - Tasks, Grades and Marks via REST API
12 Nov 2020 cnwma1  Bug 50299: MTN - CargoOnSite API (JMTAppHandHeld) not allowing lowercase cargo ID
07 Apr 2022 navmd1	TFS 53371 Moved/Copied from JMTHandheldService to MTNInternalAPIService

*/

vars
	response 	: WS_CargoSummaryResponse;
	wsCargo 	: WS_CargoSummary;
	failedDAC	: CM_DataAccessController ;
	cargoTypeID : Integer;
	terminal 	: CM_Terminal;
	cargoType	: CM_CargoType;
	allTIs		: CM_TISet;
	ti			: CM_TrackedItem;
	
begin
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	on LockException do self.handleLockExceptions(exception);
	
	create response transient;
	// Set app.mypassport - user / terminal &amp; machine
	
	self.initialisePassport();
	
	if self.httpStatusCode &lt;&gt; HttpResponseOK then
		//user has not validated
		app.writeLog(method.qualifiedName &amp; Tab &amp; self.httpStatusCode.String, LogERROR);	//25 Nov 2019	NDL	TFS 47053	//navra1 - 24th Aug 2022 - TFS 50365
		return response;
	endif;	
	
	// Get the parameters
	cargoTypeID := parseParameterList(optionalParam, 1, Integer).Integer;
	
	if app.myPassport.hasErrors then
		return response;
	endif;
	
	
	
	terminal := app.myPassport.myTerminal;
	
	if cargoId.trimBlanks = "" then
		app.raiseCMException(Input_required_field_cargoId, null, null);
		return response;
	endif;
	
	if cargoTypeID &lt;&gt; null then
		cargoType := app.myRoot.allCargoTypesById[cargoTypeID.Integer];
		if cargoType = null then
			app.raiseCMException1(Cargo_Type_Invalid, cargoTypeID.String, null, null);
			return response;
		endif;
	endif;
	
	create allTIs transient;
	
	terminal.lookupAllOnsiteTrackedItems(cargoTypeID, cargoId.toUpper, allTIs, false, null);	//12.11.2020 cnwma1 #50299
	
	foreach ti in allTIs discreteLock do
		
		if ti.id.toUpper &lt;&gt; cargoId.toUpper then
			continue;
		endif;
		
		
		if not ti.canUserAccessSelf(app.getMyUser,failedDAC ,app.myPassport) then
			continue;
		endif;
				
		create wsCargo transient;
		wsCargo.setProxyFromObject(ti);
		response.allCargoSummaries.add(wsCargo);
		
	endforeach;
	
	return response;
epilog
	delete allTIs;
	self.finaliseResponse(response);
end;</source>
        <Parameter name="cargoId" type="String"/>
        <Parameter name="optionalParam" type="ParamListType"/>
        <ReturnType type="WS_CargoSummaryResponse"/>
    </JadeMethod>
    <JadeMethod name="getCargoOnTrailer" id="1608d06f-41b7-41a4-8c35-a3fede454530">
        <updating/>
        <source>getCargoOnTrailer(trailerOid : String): WS_CargoOnTrailerResponse updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
20 September 2021	jlier1	Initial creation 51879
07 April 2022 		navmd1	TFS 53371 Moved/Copied from JMTHandheldService to MTNInternalAPIService
12 Oct 2022			jlier1 TFS 54703 changed the response to include weightLoaded
*/

vars
	trailer : CM_TILC;
	wsCargo : WS_CargoSummary;
	response : WS_CargoOnTrailerResponse;
	cargo : CM_TrackedItem;
	iter  : Iterator;
	failedDAC  :CM_DataAccessController ;
	lc : CM_TILCController;
begin
// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	on LockException do self.handleLockExceptions(exception);
	
	create response transient;
	
	// Set app.mypassport - user / terminal &amp; machine
	self.initialisePassport();
	
	if self.httpStatusCode &lt;&gt; HttpResponseOK then
		//user has not validated
		app.writeLog(method.qualifiedName &amp; Tab &amp; self.httpStatusCode.String, LogERROR);	//25 Nov 2019	NDL	TFS 47053	//navra1 - 24th Aug 2022 - TFS 50365
		return response;
	endif;	

	trailer:=app.myPassport.getObjectOfTypeFromOid(trailerOid,CM_TILC).CM_TILC;
		
	if trailer = null then
		return response;
	endif;
	// ======================
	// Actually get the cargo
	
	foreach lc in trailer.allLCs discreteLock do
		
		foreach cargo in lc.allTrackedItems discreteLock do
			if not cargo.canUserAccessSelf(app.getMyUser,failedDAC ,app.myPassport) then
				continue;
			endif;
			
			
			create wsCargo transient;
			wsCargo.setProxyFromObject(cargo);	
			response.allCargoSummaries.add(wsCargo);
		endforeach;
	endforeach;
	// =========================
	
	response.weightLoaded :=  app.getWeightForDefaultDisplay(trailer.weightCargo); //jlier1 TFS 54703 23/9/22
	
	return response;

epilog
	delete iter;
	finaliseResponse(response);

end;</source>
        <Parameter name="trailerOid" type="String"/>
        <ReturnType type="WS_CargoOnTrailerResponse"/>
    </JadeMethod>
    <JadeMethod name="getCargoOnTruck" id="8a0ae71e-26b6-413b-90e4-3ceda3e5ed3b">
        <updating/>
        <source>getCargoOnTruck(truckOid : String): WS_CargoSummaryResponse updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
20 September 2021	jlier1	Initial creation 51879
07 April 2022 		navmd1	TFS 53371 Moved/Copied from JMTHandheldService to MTNInternalAPIService
08 Apr 2025			navhl20 Bug MTN-34586: DPH - Error 1309 When Calling MTNInternalAPIService::getCargoOnTruck
*/

vars
	truck 		: CM_Vehicle;
	wsCargo 	: WS_CargoSummary;
	response 	: WS_CargoSummaryResponse;
	cargo 		: CM_TrackedItem;
	tiArr  		: CM_TIArray;
	failedDAC  	: CM_DataAccessController ;
	user		: CM_User;
begin
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	on LockException do self.handleLockExceptions(exception);
	
	create response transient;
	
	// Set app.mypassport - user / terminal &amp; machine
	self.initialisePassport();
	
	if self.httpStatusCode &lt;&gt; HttpResponseOK then
		//user has not validated
		app.writeLog(method.qualifiedName &amp; Tab &amp; self.httpStatusCode.String, LogERROR);	//25 Nov 2019	NDL	TFS 47053	//navra1 - 24th Aug 2022 - TFS 50365
		return response;
	endif;	

	truck:=app.myPassport.getObjectOfTypeFromOid(truckOid,CM_Vehicle).CM_Vehicle;

	if truck = null then
		return response;
	endif;

	// ======================
	// Actually get the cargo
	create tiArr transient;																			//08.04.2025 navhl20 #34586
	truck.locationsController.allTrackedItems.tryCopy(tiArr);										//08.04.2025 navhl20 #34586
	
	user := app.getMyUser();
	
	foreach cargo in tiArr discreteLock do															//08.04.2025 navhl20 #34586
	
		if not cargo.canUserAccessSelf(user,failedDAC ,app.myPassport) then
			continue;
		endif;
		
		
		create wsCargo transient;
		wsCargo.setProxyFromObject(cargo);	
		response.allCargoSummaries.add(wsCargo);
		
	endforeach;																						//08.04.2025 navhl20 #34586
	// =========================
	
	return response;

epilog

	delete tiArr;																					//08.04.2025 navhl20 #34586
	finaliseResponse(response);

end;</source>
        <Parameter name="truckOid" type="String"/>
        <ReturnType type="WS_CargoSummaryResponse"/>
    </JadeMethod>
    <JadeMethod name="getCargoOnWagon" id="9db95d6f-b42b-4249-aa0d-f1b23540d89b">
        <updating/>
        <source>getCargoOnWagon(wagonOid : String) : WS_WagonCargoSummaryResponse updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
12 August 2019	jlger1	Initial creation TFS 45291
07 April 2022 	navmd1	TFS 53371 Moved/Copied from JMTHandheldService to MTNInternalAPIService
25 July	 2022	jlika1	TFS 54050 - EUP- Max Wagon Payload
18 Aug 2022	jlika1	TFS 54549 - EUP - Max Wagon Payload
*/

vars
	response 			: WS_WagonCargoSummaryResponse;
	wagon 				: CM_Wagon;
	wc 					: CM_WagonController;
	tiArray				: CM_TIArray;
	ti 					: CM_TrackedItem;
	wsCargoSummary 		: WS_CargoSummary;
	failedDAC 			: CM_DataAccessController;	
	cargoWeight			: Decimal[12, 2];
	wagonMaxCargoWeight : Decimal[12, 2];
	allowWagonWeights	: Boolean;
	measureType			: CM_MeasurementType;
begin
// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	on LockException do self.handleLockExceptions(exception);
	
	create response transient;
	
	//gets username password and validates the user then gets terminal and sets all that against the passport
	self.initialisePassport();
	
	if self.httpStatusCode &lt;&gt; HttpResponseOK then
		//user has not validated
		app.writeLog(method.qualifiedName &amp; Tab &amp; self.httpStatusCode.String, LogERROR);	//25 Nov 2019	NDL	TFS 47053	//navra1 - 24th Aug 2022 - TFS 50365
		// this will return the rest faults
		return response;
	endif;	
	
	wagon:=app.myPassport.getObjectOfTypeFromOid(wagonOid,CM_Wagon).CM_Wagon;
	
	if wagon = null then
		return response;
	endif;
	
	if app.myPassport.myTerminal &lt;&gt; null then
		allowWagonWeights := app.myPassport.myTerminal.getConfig(AllowWagonWeightsToBeUpd).Boolean;
	endif;
	
	if allowWagonWeights then
		measureType := app.getDefaultMeasurementForType(Type_Weight);
		wagonMaxCargoWeight := wagon.maxCargoWeight;
	endif;
	
	create tiArray transient;
	foreach wc in wagon.allLocationsControllersArray do
		foreach ti in wc.allTrackedItems discreteLock do
			if not ti.canUserAccessSelf(app.getMyUser,failedDAC ,app.myPassport) then
				continue;
			endif;	
			
			if not tiArray.includes(ti) then	
				create wsCargoSummary transient;
				wsCargoSummary.setProxyFromObject(ti);				
				response.allCargoSummaries.add(wsCargoSummary);		
				tiArray.add(ti);
				
				if allowWagonWeights then
					cargoWeight := cargoWeight + ti.totalWeight;
				endif;
			endif;
		endforeach;
	endforeach;
	
	if allowWagonWeights then
		response.remainingCargoWeight := app.convertMeasurementForDisplay(measureType.shortName, wagonMaxCargoWeight - cargoWeight) &amp; " " &amp; measureType.shortName;
	endif;
	
	return response;
epilog
	delete tiArray;
	
	self.finaliseResponse(response);

end;</source>
        <Parameter name="wagonOid" type="String"/>
        <ReturnType type="WS_WagonCargoSummaryResponse"/>
    </JadeMethod>
    <JadeMethod name="getCargoPacked" id="58354959-056a-4d74-bb11-114cf2abb84d">
        <updating/>
        <source>getCargoPacked(cargoOid : String) : WS_CargoSummaryResponse updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
03 September 2021	jlier1	Initial creation 51879
07 April 2022 		navmd1	TFS 53371 Moved/Copied from JMTHandheldService to MTNInternalAPIService

*/

vars
	response	: WS_CargoSummaryResponse;
	terminal  : CM_Terminal;	
	parent , ti : CM_TrackedItem;
	failedDAC	: CM_DataAccessController ;
	wsCargo 	: WS_CargoSummary;
begin	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	on LockException do self.handleLockExceptions(exception);
	
	create response transient;
	// Set app.mypassport - user / terminal &amp; machine
	
	self.initialisePassport();
	
	if self.httpStatusCode &lt;&gt; HttpResponseOK then
		//user has not validated
		app.writeLog(method.qualifiedName &amp; Tab &amp; self.httpStatusCode.String, LogERROR);	//25 Nov 2019	NDL	TFS 47053	//navra1 - 24th Aug 2022 - TFS 50365
		return response;
	endif;	
	
	terminal := app.myPassport.myTerminal;
	
	if cargoOid.trimBlanks = "" then
		app.raiseCMException(Input_required_field_cargoId, null, null);
		return response;
	endif;

	parent := app.myPassport.getObjectOfTypeFromOid(cargoOid,CM_TrackedItem).CM_TrackedItem;
	
	if app.myPassport.hasErrors then
		return response;
	endif;
	
	if parent = null then
		app.raiseCMException(Input_required_field_cargoItem,null,null);
		return response;
	endif;
	
	
	
	foreach ti in parent.allChildren discreteLock do			
		if not ti.canUserAccessSelf(app.getMyUser,failedDAC ,app.myPassport) then
			continue;
		endif;
				
		create wsCargo transient;
		wsCargo.setProxyFromObject(ti);
		response.allCargoSummaries.add(wsCargo);
		
	endforeach;
	
	return response;
epilog
	self.finaliseResponse(response);
end;</source>
        <Parameter name="cargoOid" type="String"/>
        <ReturnType type="WS_CargoSummaryResponse"/>
    </JadeMethod>
    <JadeMethod name="getCargoPickedForRelease" id="e62f9995-dae2-4bf5-bbce-8df78b040b0d">
        <updating/>
        <source>getCargoPickedForRelease(reserveDetailOid : String) : WS_CargoSummaryResponse updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
26 July 2021	jlier1	Initial creation TFS 51626 - Release Staging STW
07 April 2022 	navmd1	TFS 53371 Moved/Copied from JMTHandheldService to MTNInternalAPIService
23/06/2023	navkc1	CR 58406 Task 58408: Jade - Release Request All Tracked Items
*/

vars
	response : WS_CargoSummaryResponse;
	reserveDetail : CM_ReserveDetail;
	reserveTI 	 : CM_ReserveTI;
	ti : CM_TrackedItem;
	failedDAC  		 : CM_DataAccessController ;
	wsCargo 		 : WS_CargoSummary;
	release : CM_BulkRelease;
	allTis	: CM_TISet;
	
begin
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	on LockException do self.handleLockExceptions(exception);
	
	create response transient;
	create allTis transient; //23/06/2023	navkc1	CR 58406 Task 58408
	// Set app.mypassport - user / terminal &amp; machine
	self.initialisePassport();
	
	if self.httpStatusCode &lt;&gt; HttpResponseOK then
		//user has not validated
		app.writeLog(method.qualifiedName &amp; Tab &amp; self.httpStatusCode.String, LogERROR);	//25 Nov 2019	NDL	TFS 47053	//navra1 - 24th Aug 2022 - TFS 50365
		return response;
	endif;	
	
	
	reserveDetail := app.myPassport.getObjectOfTypeFromOid(reserveDetailOid, CM_ReserveDetail).CM_ReserveDetail;
	
	if app.myPassport.hasErrors then
		return response;
	endif;
	
	if reserveDetail = null then
		app.raiseCMException(Input_required_field_delReleas,null,null);
		return response;
	endif;
	release:=reserveDetail.myReserveHeader;
	if reserveDetail.isKindOf( CM_ReserveTI ) then
		reserveTI:=reserveDetail.CM_ReserveTI;
	endif;
	
	reserveDetail.getAllTrackedItems(allTis, false); //23/06/2023	navkc1	CR 58406 Task 58408
	//foreach ti in reserveDetail.allTrackedItems discreteLock do
	foreach ti in allTis discreteLock do //23/06/2023	navkc1	CR 58406 Task 58408
		if not release.allTrackedItemsAssigned.includes(ti) then
			continue;
		endif;
		if ti.isStagedFor( release ) then
			
			if reserveTI &lt;&gt; null and reserveTI.getTI &lt;&gt; ti then
				continue;
			endif;
			if not ti.canUserAccessSelf(app.getMyUser,failedDAC ,app.myPassport) then
				continue;
			endif;
					
			create wsCargo transient;
			wsCargo.setProxyFromObject(ti);
			response.allCargoSummaries.add(wsCargo);
		
		
		endif;
	endforeach;
	
	return response;
	
epilog

	self.finaliseResponse(response);
	delete allTis; 
end;</source>
        <Parameter name="reserveDetailOid" type="String"/>
        <ReturnType type="WS_CargoSummaryResponse"/>
    </JadeMethod>
    <JadeMethod name="getCargoPreviousLocation" id="80ee9a15-8c37-495d-a608-953c7b8ca5a0">
        <updating/>
        <source>getCargoPreviousLocation(cargoOid : String) : WS_LocationResponse updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
03 September 2021	jlier1	Initial creation 51879
07 April 2022 		navmd1	TFS 53371 Moved/Copied from JMTHandheldService to MTNInternalAPIService

*/

vars
	terminal : CM_Terminal;
	response : WS_LocationResponse;
	foundLC : CM_LocationsController;
	foundHeight : Integer;
	wsLC : 	WS_LocationsController;
	cargo : CM_TrackedItem;
begin
// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	on LockException do self.handleLockExceptions(exception);
	
	//gets username password and validates the user then gets terminal and sets all that against the passport
	self.initialisePassport();
	
	if self.httpStatusCode &lt;&gt; HttpResponseOK then
		//user has not validated
		app.writeLog(method.qualifiedName &amp; Tab &amp; self.httpStatusCode.String, LogERROR);	//25 Nov 2019	NDL	TFS 47053	//navra1 - 24th Aug 2022 - TFS 50365
		// this will return the rest faults
		return null;
	endif;	
	
	if app.myPassport.hasErrors then
		self.httpStatusCode := HttpResponseForbidden;
		app.writeLog(method.qualifiedName &amp; Tab &amp; self.httpStatusCode.String, LogERROR);	//25 Nov 2019	NDL	TFS 47053	//navra1 - 24th Aug 2022 - TFS 50365
		return response;
	endif;	
	create response transient;
	
	cargo := app.myPassport.getObjectOfTypeFromOid(cargoOid, CM_TrackedItem).CM_TrackedItem;
	if app.myPassport.hasErrors then
		return response;
	endif;
	if cargo = null then
		app.raiseCMException1(Cargo_item_not_found,cargoOid, null,null);
		return response;
	endif;
	
	foundLC:=cargo.getPriorLocationLC;
	
	if foundLC &lt;&gt; null  then
		create wsLC transient;
		wsLC.setProxyFromObject(foundLC);
		response.myLocation:=wsLC;
	endif;
	return response;
epilog
	self.finaliseResponse(response);

end;</source>
        <Parameter name="cargoOid" type="String"/>
        <ReturnType type="WS_LocationResponse"/>
    </JadeMethod>
    <JadeMethod name="getCargoQueuedToArea" id="5af8977a-44c6-423b-b4ba-40ef1249e347">
        <updating/>
        <source>getCargoQueuedToArea(areaID : String; optionalParam : ParamListType) : WS_CargoSummaryResponse updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 August 2019	jlgns1	Initial creation
6/08/2019 	JLGNS1	ChangeRequest 45293: JMT Handheld Apps - Release Staging Jade
21/08/2019 	jlgrr1	45924		Change to method structure for JMT REST Apis to support the fact
								optional parameters can not be passed in the middle of the parameter list
07/04/2022 	navmd1	53371		Moved/Copied from JMTHandheldService to MTNInternalAPIService
*/

vars
	limit 	: Integer;
	index 	: Integer;

	iter 	: Iterator;
	cargo 	: CM_TrackedItem;
	count 	: Integer;
	rsCargo : WS_CargoSummary;
	response : WS_CargoSummaryResponse;
	realArea : CM_TerminalArea;
	tiDD 	: DynaDictionary;
	lcArray : ObjectArray;
	obj 	: Object;
	lc 		: CM_LocationsController;
	tiArray : CM_TIArray;
	failedDAC : CM_DataAccessController ;
begin
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	on LockException do self.handleLockExceptions(exception);
	
	create response transient;
	
	// Set app.mypassport - user / terminal &amp; machine
	self.initialisePassport();
	
	if self.httpStatusCode &lt;&gt; HttpResponseOK then
		//user has not validated
		app.writeLog(method.qualifiedName &amp; Tab &amp; self.httpStatusCode.String, LogERROR);	//25 Nov 2019	NDL	TFS 47053	//navra1 - 24th Aug 2022 - TFS 50365
		return response;
	endif;	
		
	// Get the parameters
	limit := parseParameterList(optionalParam, 1, Integer).Integer;
	index := parseParameterList(optionalParam, 2, Integer).Integer;
	
	// Check for errrors
	if app.myPassport.hasErrors then
		return response;
	endif;
		
	// Set Defaults

	if limit = 0 then
		limit := 50;
	endif;
	if limit &gt; 250 then
		limit := 250;
	endif;
	if index = 0 then
		index := 1;
	endif;
	
	if areaID.trimBlanks = "" then
		app.raiseCMException(Input_Required_For_TA, null,null);
		return response;
	endif;	
	
	
	realArea :=	app.myPassport.myTerminal.allTerminalAreas.getAtKey(areaID);
	
	
	if realArea = null then
		app.raiseCMException1(Location_invalid,areaID, null,null);
		return response;
	endif;	
	
	if not realArea.canUserAccessSelf(app.getMyUser,failedDAC ,app.myPassport) then
		app.raiseCMException3(ERR_USER_NO_ACCESS,app.getMyUser.identity,app.getErrorString(TerminalArea),areaID, null,null);
		return response;
	endif;
	
	
	
	// ======================
	// Actually get the cargo
	
	create tiArray transient;
	create tiDD transient;
	tiDD.setMembership(CM_TrackedItem);
	tiDD.addMemberKey(CM_TrackedItem::id.name, false, false);
	tiDD.addMemberKey(CM_TrackedItem::oidAsHex.name, false,false);
	tiDD.endKeys(false);
	

			
	create lcArray transient;		
	realArea.getAllLocationsControllers(lcArray);
	foreach obj in lcArray do
		lc := obj.CM_LocationsController;
		lc.getAllQueuedTrackedItems(tiArray	,true);
		tiArray.copyNoDups(tiDD);
	endforeach;
	
	iter := tiDD.createIterator;	
	
	
	while iter.next(cargo) and count &lt; ((index-1) + limit) do
		if not cargo.canUserAccessSelf(app.getMyUser,failedDAC ,app.myPassport) then
			continue;
		endif;	
	
		count := count + 1;
		if index &gt; 1 then
			if count &lt; index then
				continue;
			endif;
		endif;		
		
		create rsCargo transient;
		rsCargo.setProxyFromObject(cargo);
		response.allCargoSummaries.add(rsCargo);
	endwhile;
	// =========================
	
	return response;

epilog
	delete tiArray;
	delete tiDD;
	delete iter;
	delete lcArray;
	finaliseResponse(response);
end;
</source>
        <Parameter name="areaID" type="String"/>
        <Parameter name="optionalParam" type="ParamListType"/>
        <ReturnType type="WS_CargoSummaryResponse"/>
    </JadeMethod>
    <JadeMethod name="getCargoSubtypes" id="82332014-3b3d-4f6e-b3ab-7227b5edcbbd">
        <updating/>
        <source>getCargoSubtypes(cargoTypeOid : String)  : WS_ProductResponse updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 May 2022	jlier1	Initial creation 53022

*/

vars
	response : WS_ProductResponse;
	cargoTypeObj	: CM_CargoType;
	product			: CM_Product;
	proxyProduct	: WS_Product;
begin
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	on LockException do self.handleLockExceptions(exception);
	
	create response transient;
	
	// Set app.mypassport - user / terminal &amp; machine
	self.initialisePassport();
	
	if self.httpStatusCode &lt;&gt; HttpResponseOK then
		//user has not validated
		app.writeLog(method.qualifiedName &amp; Tab &amp; self.httpStatusCode.String, LogERROR);	//25 Nov 2019	NDL	TFS 47053	//navra1 - 24th Aug 2022 - TFS 50365
		return response;
	endif;	
	
	// Check for errrors
	if app.myPassport.hasErrors then
		return response;
	endif;
	
	
	cargoTypeObj := app.myPassport.getObjectOfTypeFromOid( cargoTypeOid,CM_CargoType).CM_CargoType;
	if app.myPassport.hasErrors then
		return response;
	endif;
	
	if cargoTypeObj = null then
		//lets try the id
		cargoTypeObj := app.myRoot.allCargoTypesById[cargoTypeOid.Integer];
	endif;
	
	if cargoTypeObj = null then
		app.raiseCMException1(Cargot_not_valid_cargot_system, cargoTypeOid, null, null);
		return response;
	endif;
	
	foreach product in cargoTypeObj.allProducts discreteLock where not product.isNotActive  do //epr TFS 1846
		create proxyProduct transient;
		proxyProduct.setProxyFromObject(product);
		response.allProducts.add(proxyProduct);
	endforeach;	
	
	
	return response;
epilog
	self.finaliseResponse(response);
end;</source>
        <Parameter name="cargoTypeOid" type="String"/>
        <ReturnType type="WS_ProductResponse"/>
    </JadeMethod>
    <JadeMethod name="getCargoTasks" id="cad0a8f9-1c93-4ef9-a94b-bdd0ce3f0f76">
        <updating/>
        <source>getCargoTasks(_cargoUid : String; optionalParam : ParamListType) : WS_RestIntCargoTasksResponse updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 November 2023	navpw1	Initial creation TFS: 58761 (60739)

*/

vars
	response		: WS_RestIntCargoTasksResponse;
	terminal		: CM_Terminal;
	user			: CM_User;
	cargo 			: CM_TrackedItem;
	isSetOnly		: Boolean;
	tasks			: CM_ToDoTaskDescBySortKey;
	task			: CM_ToDoTask;
	taskDesc		: CM_ToDoTaskDesc;
	wsCargoTask		: WS_RestIntCargoTask;
	toDoTaskDesc	: CM_ToDoTaskDesc;
	taskCriteria	: CM_TaskCriteria;
	//lineStr		: String;
	
begin
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	on LockException do self.handleLockExceptions(exception);
	
	create response transient;
	
	// Set app.mypassport - user / terminal &amp; machine
	self.initialisePassport();
	
	if self.httpStatusCode &lt;&gt; HttpResponseOK then
		//user has not validated
		app.writeLog(method.qualifiedName &amp; Tab &amp; self.httpStatusCode.String, LogERROR);	//25 Nov 2019	NDL	TFS 47053	//navra1 - 24th Aug 2022 - TFS 50365
		return response;
	endif;	
	
	// Check for errrors
	if app.myPassport.hasErrors then
		return response;
	endif;
	
	terminal	:= app.myPassport.myTerminal;
	user		:= app.myPassport.myUser;
	
	cargo := app.myPassport.getObjectOfTypeFromOid(_cargoUid,CM_TrackedItem).CM_TrackedItem;
	
	if cargo = null then
		app.raiseCMException(Input_required_field_cargo, null, null);
		return response;
	endif;
	
	isSetOnly := self.parseParameterList(optionalParam, 1, String).Boolean;
	
	// Check security access to this message, if required
	app.checkCurrentUserHasAccess(PmAdmTodotableMaint);		// Replace with appropriate permission
	if app.myPassport.hasErrors then
		return response;
	endif;
	
	// STUFF
	// Load the descriptions 
	if isSetOnly then
		foreach task in cargo.allToDoTasksToDo do
			create wsCargoTask transient;
			wsCargoTask.setProxyFromObject(task);
			wsCargoTask.isSet := true;
			
			toDoTaskDesc := task.toDoTaskDesc;
			if toDoTaskDesc &lt;&gt; null then
				taskCriteria := toDoTaskDesc.allTaskCriteria.getAtKeyGeq(terminal, toDoTaskDesc.code);	// ### TFS 62186 (62196) 02Feb2024 NAVPW1
				// ### TFS 62186 (62196) 02Feb2024 NAVPW1
				if taskCriteria = null or terminal.code &lt;&gt; taskCriteria.myTerminal.code or taskCriteria.myToDoTaskDesc = null or taskCriteria.myToDoTaskDesc.code &lt;&gt; toDoTaskDesc.code then
					taskCriteria := null;
				endif;
				// ### TFS 62186 (62196) 02Feb2024 NAVPW1
			endif;
			
			if taskCriteria &lt;&gt; null then
				wsCargoTask.setResourceGroups(taskCriteria.allAvailableResourceGroups, taskCriteria.allMandatoryResourceGroups, self.objectsToBeDeleted);
			endif;
			
			response.allCargoTasks.add(wsCargoTask);
			
		endforeach;
		
	else
		tasks := terminal.myRoot.allToDoTaskDescsBySortOrder;
		
		foreach taskDesc in tasks do
			// Only those tasks for this kind of cargo
			if not taskDesc.isAvailableForCargoType( cargo.cargoType ) then
				continue;
			endif;
			
			//TFS 45392 - Return tasks that the user has permission to add/remove
			if not user.canAddRemoveTodoTask(terminal,taskDesc) then
				continue;
			endif;
			
			/*lineStr := "";
			if taskDesc.shortDescription = null then
				lineStr := taskDesc.description;
			else
				lineStr := taskDesc.shortDescription;
			endif;*/
			
			create wsCargoTask transient;
			//cargoTask.description := lineStr;
			// change made to reflect full string description rather than code, 9/3/17
			wsCargoTask.description := taskDesc.description;
			wsCargoTask.code := taskDesc.code;
			wsCargoTask.requiredExtraInfo := taskDesc.requiredExtraInfo;
			wsCargoTask.hasResources := taskDesc.allResourceTypes.isNotEmpty();
			
			// Put the date in for each completed task
			foreach task in cargo.allToDoTasksCompleted where task.toDoTaskDescDesc = taskDesc.description do
				wsCargoTask.completedDate := task.dtLastUpdate.asStringForWebInterface;
				//cargoTask.remarks := task.remarks; //jlier1 TFS 53661 15/7/22
			endforeach;
			
			// Mark set tasks
			foreach task in cargo.allToDoTasksToDo where task.toDoTaskDescDesc = taskDesc.description do
				wsCargoTask.isSet := true;
				wsCargoTask.remarks := task.remarks;
				
				toDoTaskDesc := task.toDoTaskDesc;
				
				if toDoTaskDesc &lt;&gt; null then
					taskCriteria := toDoTaskDesc.allTaskCriteria[terminal, toDoTaskDesc.code];	// ### TFS 62186 (62196) 02Feb2024 NAVPW1
				endif;
				
				if taskCriteria &lt;&gt; null then
					wsCargoTask.setResourceGroups(taskCriteria.allAvailableResourceGroups, taskCriteria.allMandatoryResourceGroups, self.objectsToBeDeleted);
				endif;
			endforeach;
			
			response.allCargoTasks.add(wsCargoTask);
		endforeach;
	endif;
	
	return response;

epilog
	self.finaliseResponse(response);
	
end;</source>
        <Parameter name="_cargoUid" type="String"/>
        <Parameter name="optionalParam" type="ParamListType"/>
        <ReturnType type="WS_RestIntCargoTasksResponse"/>
    </JadeMethod>
    <JadeMethod name="getCargoToLoadForRelease" id="1babba13-06b3-494d-9284-19c13281c059">
        <updating/>
        <source>getCargoToLoadForRelease(releaseOid :String ;   targetLocOid : String; optionalParam : ParamListType) :WS_CargoToLoadResponse updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
30 August 2021		jlier1	Initial creation 51879
07 April 2022 		navmd1	TFS 53371 Moved/Copied from JMTHandheldService to MTNInternalAPIService
19 Dec 2023 		navhl20 ChangeRequest 61092:[61621] EUP | Ship Operations in DD - [54176.050] Mobile App changes - Pack Load by Request
11 January 2024		navcs2	ChangeRequest 61549: EUP | Release Request by Weight - Pack/Load, Rail Lander
06 Aug 2024			navpw1	TFS: 65623 (65624) - VBS Weight Limit
22 Nov 2024			navpw1	JIRA: MTN-14770 - Added a boolean return for isAnyAmount to help display whether this is an any amount load or not.
*/

vars
	realRelease			: CM_BulkRelease;
	realResDet			: CM_ReserveDetail;
	iter				: Iterator;
	cargo				: CM_TrackedItem;
	rsCargo				: WS_CargoSummary;
	response			: WS_CargoToLoadResponse;
	tiArray				: CM_TIArray;
	tiSet				: CM_TISet;
	sourceLC, targetLC	: CM_LocationsController;
	failedDAC			: CM_DataAccessController ;
	cmifMobile			: CMIF_MobileGenericAgent;
	stwRule				: Integer;
	sourceLocOid,
	truckOid			: String;
	resSelection		: CM_ReserveSelection;
	reserveDetailOid	: String;
	truck				: CM_Vehicle;
	trailer				: CM_TILC;
	wagon				: CM_Wagon;
	checkContext		: Integer;
	terminal			: CM_Terminal;
	forEUP				: Boolean;
	voyageProcess		: CM_VoyageProcess;
	vehicleVisit		: CM_VehicleVisitRecord;			// ### TFS 65623 (65624) 06Aug2024 NAVPW1
	allGateEntities		: CM_GTEEntityByJobQueueNum;		// ### TFS 65623 (65624) 06Aug2024 NAVPW1
	gateEntity			: CMGTE_Entity;						// ### TFS 65623 (65624) 06Aug2024 NAVPW1
	gateEntityRelease	: CMGTE_Release;					// ### TFS 65623 (65624) 06Aug2024 NAVPW1
	vbsti				: CM_VehicleBookingTimeSlotItem;	// ### TFS 65623 (65624) 06Aug2024 NAVPW1
	allRailWles			: CM_WLEArray;						// ### JIRA: MTN-14770 27Nov2024 NAVPW1
	railWle				: CM_WorkListEntry;					// ### JIRA: MTN-14770 27Nov2024 NAVPW1
	isVasEnabled		: Boolean;
begin
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	on LockException do self.handleLockExceptions(exception);
	
	create response transient;
	
	// Set app.mypassport - user / terminal &amp; machine
	self.initialisePassport();
	
	if self.httpStatusCode &lt;&gt; HttpResponseOK then
		//user has not validated
		app.writeLog(method.qualifiedName &amp; Tab &amp; self.httpStatusCode.String, LogERROR);	//25 Nov 2019	NDL	TFS 47053	//navra1 - 24th Aug 2022 - TFS 50365
		return response;
	endif;	

	// Get the parameters
	reserveDetailOid := parseParameterList(optionalParam, 1, String).String;
	sourceLocOid 	 := parseParameterList(optionalParam, 2, String).String;
	isVasEnabled	 := app.myPassport.isVASEnabled();
	
	app.writeLog("param list length ="   &amp; app.getParamListTypeLength(optionalParam) .String, LogDEBUG);	//26 Nov 2019	NDL	TFS 47053
	app.writeLog("param list ="   		 &amp; releaseOid &amp; ",/" &amp; reserveDetailOid &amp; ",/" &amp; sourceLocOid &amp; ",/" &amp; truckOid &amp; ",/"  , LogDEBUG);	//26 Nov 2019	NDL	TFS 47053
	
	// Check for errrors
	if app.myPassport.hasErrors then
		return response;
	endif;

	realRelease := app.myPassport.getObjectOfTypeFromOid(releaseOid, CM_BulkRelease).CM_BulkRelease;	
	
	if realRelease = null then
		app.raiseCMException(Input_required_field_delReleas,null,null);
		return response;
	endif;

	realResDet := app.myPassport.getObjectOfTypeFromOid(reserveDetailOid, CM_ReserveDetail).CM_ReserveDetail;
	
	if app.myPassport.hasErrors then
		return response;
	endif;
		
	sourceLC := app.myPassport.getObjectOfTypeFromOid(sourceLocOid, CM_LocationsController).CM_LocationsController;
	
	if app.myPassport.hasErrors then
		return response;
	endif;
	
	terminal := app.myPassport.myTerminal;																					//19.12.2023 navhl20 #61092[61621]
	voyageProcess := terminal.getDefaultVoyageProcess();																	//18.12.2023 navhl20 #61092[61621]
	forEUP := voyageProcess.isEUPDefaultProcess;																			//19.12.2023 navhl20 #61092[61621]
	
	if forEUP and realRelease.type = BR_TYPE_SHIP then																		//19.12.2023 navhl20 #61092[61621]
		targetLC := app.myPassport.getObjectOfTypeFromOid(targetLocOid, CM_LocationsController).CM_LocationsController;		//15.12.2023 navhl20 #61092[61621]
	endif;
	
	if targetLC = null then																									//15.12.2023 navhl20 #61092[61621]
		truck:= app.myPassport.getObjectOfTypeFromOid(targetLocOid, CM_Vehicle).CM_Vehicle;
		if truck &lt;&gt; null then
			targetLC:=truck.locationsController;
			checkContext :=CARGO_CHECK_CONTEXT_TRUKLOAD;
		else
			if app.myPassport.hasErrors then 
				app.myPassport.clearErrorsWarnings;
			endif;
			trailer:=app.myPassport.getObjectOfTypeFromOid(targetLocOid, CM_TILC).CM_TILC;
			if trailer &lt;&gt; null then
				targetLC:=trailer.allLCs.first;
				checkContext :=CARGO_CHECK_CONTEXT_TRUKLOAD;
			else
				if app.myPassport.hasErrors then 
					app.myPassport.clearErrorsWarnings;
				endif;	
				wagon:=app.myPassport.getObjectOfTypeFromOid(targetLocOid, CM_Wagon).CM_Wagon;
				if wagon &lt;&gt; null then
					targetLC:=wagon.allLocationsControllersArray.first;
					checkContext :=CARGO_CHECK_CONTEXT_RAIL_REL;
				endif;
				if app.myPassport.hasErrors then 
					app.myPassport.clearErrorsWarnings;
				endif;	
			endif;
		endif;
	endif;
	if targetLC = null then
		app.raiseCMException(No_Target_location_found,null,null);
		return response;
	endif;
	
	create tiArray transient; 	
	
	create cmifMobile transient;
	cmifMobile.setMyTerminal( app.myPassport.myTerminal);
	if realResDet.isKindOf(CM_ReserveSelection) then
		resSelection:=realResDet.CM_ReserveSelection;
	endif;
	cmifMobile.getCargoBasedOnSTW12Rules(realRelease,resSelection, sourceLC, targetLC,stwRule,tiArray);
	
	create tiSet transient;
	
	iter := tiArray.createIterator;	
	while iter.next(cargo) do
		
		if not cargo.canUserAccessSelf(app.getMyUser,failedDAC ,app.myPassport) then
			continue;
		endif;
		if  tiSet.includes(cargo) then
			continue;
		endif;
		
		create rsCargo transient;
		rsCargo.setProxyFromObject(cargo);
	
		response.allCargoSummaries.add(rsCargo);
		tiSet.add(cargo);		
	endwhile;
	
	// ### TFS 65623 (65624) 06Aug2024 NAVPW1
	if truck &lt;&gt; null then
		vehicleVisit := truck.getCurrentVisit;
		
	endif;
	
	if vehicleVisit &lt;&gt; null then
		allGateEntities := vehicleVisit.allGateEntities;
	endif;
	
	if allGateEntities &lt;&gt; null and realResDet &lt;&gt; null then
		foreach gateEntity in allGateEntities do
			if not gateEntity.isRelease then
				continue;
			endif;
			
			gateEntityRelease := gateEntity.CMGTE_Release;
			
			vbsti := gateEntityRelease.myVbsti;
			
			//We need to set is any amount for euroports if it is any amount
			if isVasEnabled then
				response.isAnyAmount := gateEntityRelease.getIsAnyAmount;	// ### JIRA: MTN-14770 22Nov2024 NAVPW1
			endif;
			
			if gateEntityRelease.myReserveDetail = realResDet and vbsti &lt;&gt; null then
				break;
			endif;
			
		endforeach;
	elseif wagon &lt;&gt; null and isVasEnabled then
		//Get all rail wles for wagon to check for any amount
		allRailWles := wagon.allLocationsControllers.first.allRailWLELoad;
		foreach railWle in allRailWles do
			if not railWle.myRequest.isDeliveryRequest or not railWle.isAnyAmount() or railWle.status = WLE_COMPLETED then
				continue;
			endif;
			
			response.isAnyAmount := true;	// ### JIRA: MTN-14770 22Nov2024 NAVPW1
			
		endforeach;
	endif;
	
	// ### TFS 65623 (65624) 06Aug2024 NAVPW1
	
	response.setCanLoadAll(checkContext,tiSet);
	
	// ### TFS 65623 (65624) 06Aug2024 NAVPW1
	if vbsti &lt;&gt; null and vbsti.maxWeight &gt; 0 and realResDet &lt;&gt; null then
		response.setByWeight(true);
	// ### TFS 65623 (65624) 06Aug2024 NAVPW1
	elseif realResDet &lt;&gt; null then							//11 January 2024	navcs2	ChangeRequest 61549
		response.setByWeight(realResDet.byTypeByWeight);	//11 January 2024	navcs2	ChangeRequest 61549
	endif;													//11 January 2024	navcs2	ChangeRequest 61549
	response.setWeightAndCounts(realRelease,targetLC);

	return response;

epilog
	delete tiArray;
	delete iter;
	delete cmifMobile;
	delete tiSet;
	finaliseResponse(response);
end;</source>
        <Parameter name="releaseOid" type="String"/>
        <Parameter name="targetLocOid" type="String"/>
        <Parameter name="optionalParam" type="ParamListType"/>
        <ReturnType type="WS_CargoToLoadResponse"/>
    </JadeMethod>
    <JadeMethod name="getCargoToPackForRelease" id="09d3d85b-2bef-411d-8714-c12547e0b580">
        <updating/>
        <source>getCargoToPackForRelease(releaseOid :String ;  parentCargoOid : String; optionalParam : ParamListType) : WS_CargoToPackResponse updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
02 September 2021	jlier1	Initial creation 51879
07 April 2022 		navmd1	TFS 53371 Moved/Copied from JMTHandheldService to MTNInternalAPIService
*/

vars
	realRelease		 	: CM_BulkRelease;
	realResDet 		 	: CM_ReserveDetail;
	iter 			 	: Iterator;
	cargo , 
	ti	,
	ultParent, 
	parentCargo		 	: CM_TrackedItem;
	count 			 	: Integer;
	rsCargo 		 	: WS_CargoSummary;
	response 		 	: WS_CargoToPackResponse ;
	tiArray 			: CM_TIArray;	
	tempTiArray 		: CM_TIArray;
	sourceLC 			: CM_LocationsController;
	failedDAC  		 	: CM_DataAccessController ;
	cmifMobile 			: CMIF_MobileGenericAgent;
	stwRule 			: Integer;
	sourceLocOid , 
	targetLocOid		: String;
	reserveDetailOid 	: String; 
	tiSet				: CM_TISet;
	reason				: String;
	job					: CM_Job;
	woDtl				: CM_WorkOrderDtl;
	woPackWle			: CM_WorkListEntry;
	actionTS			: TimeStamp;
	packReserve			: CM_ReserveSelection;
	packRequest			: CM_Request;
begin
// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	on LockException do self.handleLockExceptions(exception);
	
	create response transient;
	
	// Set app.mypassport - user / terminal &amp; machine
	self.initialisePassport();
	
	if self.httpStatusCode &lt;&gt; HttpResponseOK then
		//user has not validated
		app.writeLog(method.qualifiedName &amp; Tab &amp; self.httpStatusCode.String, LogERROR);	//25 Nov 2019	NDL	TFS 47053	//navra1 - 24th Aug 2022 - TFS 50365
		return response;
	endif;	

	// Get the parameters
	reserveDetailOid:=parseParameterList(optionalParam, 1, String).String;
	sourceLocOid := parseParameterList(optionalParam, 2, String).String;
	

	app.writeLog("param list length ="   &amp; app.getParamListTypeLength(optionalParam) .String, LogDEBUG);	//26 Nov 2019	NDL	TFS 47053
	
	app.writeLog("param list ="   &amp; releaseOid &amp; ",/" &amp; reserveDetailOid &amp; ",/" &amp; sourceLocOid , LogDEBUG);	//26 Nov 2019	NDL	TFS 47053		
	
	// Check for errrors
	if app.myPassport.hasErrors then
		return response;
	endif;
		
		
	realRelease := app.myPassport.getObjectOfTypeFromOid(releaseOid, CM_BulkRelease).CM_BulkRelease;	
	
	if realRelease = null then
		app.raiseCMException(Input_required_field_delReleas,null,null);
		return response;
	endif;

	realResDet := app.myPassport.getObjectOfTypeFromOid(reserveDetailOid, CM_ReserveDetail).CM_ReserveDetail;
	
	if app.myPassport.hasErrors then
		return response;
	endif;
		
	sourceLC := app.myPassport.getObjectOfTypeFromOid(sourceLocOid, CM_LocationsController).CM_LocationsController;
	
	if app.myPassport.hasErrors then
		return response;
	endif;
	
	parentCargo:= app.myPassport.getObjectOfTypeFromOid(parentCargoOid, CM_TrackedItem).CM_TrackedItem;
	
	if parentCargo = null then
		app.raiseCMException(Input_required_field_cargoItem,null,null);
		return response;
	endif;
	
	create tiArray transient; 	
	
	create cmifMobile transient;
	cmifMobile.setMyTerminal( app.myPassport.myTerminal);
	cmifMobile.setPackContainerDetails(null,null,null,null,parentCargo);
	cmifMobile.getCargoBasedOnSTW12Rules(realRelease,realResDet, sourceLC, null,stwRule,tiArray);
	
	create tiSet transient;

	iter := tiArray.createIterator;	
	while iter.next(cargo) do
		
		if not cargo.canUserAccessSelf(app.getMyUser,failedDAC ,app.myPassport) then
			continue;
		endif;
		if  tiSet.includes(cargo) then
			continue;
		endif;
		
		create rsCargo transient;
		rsCargo.setProxyFromObject(cargo);
		
		response.allCargoSummaries.add(rsCargo);
				
		tiSet.add(cargo);
	endwhile;
	
	response.setCanPackAll(tiSet);
	response.setWeightAndCounts(realRelease,parentCargo);
		
	return response;

epilog
	delete tiArray;
	delete iter;
	delete cmifMobile;
	delete tiSet;
	finaliseResponse(response);

end;</source>
        <Parameter name="releaseOid" type="String"/>
        <Parameter name="parentCargoOid" type="String"/>
        <Parameter name="optionalParam" type="ParamListType"/>
        <ReturnType type="WS_CargoToPackResponse"/>
    </JadeMethod>
    <JadeMethod name="getCargoToScanForGroup" id="19fd7d34-de27-425e-9b34-182227c2f868">
        <updating/>
        <source>getCargoToScanForGroup(cargoGroupOid : String; _mode : String) : WS_CargoToScanForCargoGroupRes updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 October 2023	jlier1	Initial creation 59948
22 Feb 2024 navhl20 ChangeRequest 62406:[62535] EUP | Scanning App Cargo Group Overview Changes
*/

vars
	response : WS_CargoToScanForCargoGroupRes;
	cargoGroup : CM_CargoGroup;
	cargoAssignmentNotYetScanned : StringArray;
	cargoId : String;
	entityId : String;
begin
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	on LockException do self.handleLockExceptions(exception);
	
	create response transient;
	
	// Set app.mypassport - user / terminal &amp; machine
	self.initialisePassport();
	
	if self.httpStatusCode &lt;&gt; HttpResponseOK then
		//user has not validated
		app.writeLog(method.qualifiedName &amp; Tab &amp; self.httpStatusCode.String, LogERROR);	
		return response;
	endif;	

	cargoGroup:=app.myPassport.getObjectOfTypeFromOid(cargoGroupOid,CM_CargoGroup).CM_CargoGroup;
	
	if cargoGroup = null or app.myPassport.hasErrors then
		return response;
	endif;
	
	if _mode = "All" then															//22.02.2024 navhl20 #62406[62535]
		cargoGroup.getPreAssignedToScan(response.cargoIDsToScan);
		if cargoGroup.myCargoGroupAssignment &lt;&gt; null then
			create cargoAssignmentNotYetScanned transient;
			cargoGroup.myCargoGroupAssignment.getNotYetScanned(cargoAssignmentNotYetScanned, false);
			
			foreach cargoId in cargoAssignmentNotYetScanned do
				if not response.cargoIDsToScan.includes(cargoId) then
					response.cargoIDsToScan.add(cargoId);
				endif;
			endforeach;
		endif;
	else
		if _mode = "ship" then
			entityId:=self.qsData.getValue(QueryParam_VoyageId).asStringJMT();
		elseif _mode = "road" then
			entityId:=self.qsData.getValue(QueryParam_TruckId).asStringJMT;
		elseif _mode = "rail" then
			entityId:=self.qsData.getValue(QueryParam_WagonId).asStringJMT;
		elseif _mode = "unpack" then
			entityId:=self.qsData.getValue(QueryParam_WorkOrderId).asStringJMT;
		endif;
		cargoGroup.getCargoToBeScanned(response.cargoIDsToScan,_mode,entityId);
	endif;
	
	return response;
	
epilog
	delete cargoAssignmentNotYetScanned;
	self.finaliseResponse(response);
end;</source>
        <Parameter name="cargoGroupOid" type="String"/>
        <Parameter name="_mode" type="String"/>
        <ReturnType type="WS_CargoToScanForCargoGroupRes"/>
    </JadeMethod>
    <JadeMethod name="getCargoToScanForGroupAssign" id="af2ebe4d-7ee2-4704-9a27-12ab0eb65f63">
        <updating/>
        <source>getCargoToScanForGroupAssign(groupAssignId : String ) : WS_CargoToScanForCargoGroupRes updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
06 August 2021		jlier1	Initial creation 51683
07 April 2022 		navmd1	TFS 53371 Moved/Copied from JMTHandheldService to MTNInternalAPIService

*/

vars
	response : WS_CargoToScanForCargoGroupRes;
	terminal : CM_Terminal;
	cga : CM_CargoGroupAssignment;
begin
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	on LockException do self.handleLockExceptions(exception);
	
	create response transient;
	
	// Set app.mypassport - user / terminal &amp; machine
	self.initialisePassport();
	
	if self.httpStatusCode &lt;&gt; HttpResponseOK then
		//user has not validated
		app.writeLog(method.qualifiedName &amp; Tab &amp; self.httpStatusCode.String, LogERROR);	//25 Nov 2019	NDL	TFS 47053	//navra1 - 24th Aug 2022 - TFS 50365
		return response;
	endif;	
	terminal := app.myPassport.myTerminal;
	
	cga:= terminal.findCargoGroupAssignment( groupAssignId.asStringRESTFUL.trimBlanks );
	
	if cga = null then
		//need to change to appriopriate error
		app.raiseCMException(Input_requir_cargo_group_assig, null, null);
		return response;
	endif;
	
	cga.getNotYetScanned( response.cargoIDsToScan, true );
	
	return response;
epilog
	self.finaliseResponse(response);

end;</source>
        <Parameter name="groupAssignId" type="String"/>
        <ReturnType type="WS_CargoToScanForCargoGroupRes"/>
    </JadeMethod>
    <JadeMethod name="getCargoToStageForRelease" id="4788f4a2-14ad-47a8-94f4-58d4e1862ad7">
        <updating/>
        <source>getCargoToStageForRelease(releaseOid :String ; reserveDetailOid : String; sourceAreaId : String; ordering : String; optionalParam : ParamListType) : WS_CargoSummaryResponse updating;
/*

Purpose:			

Parameters:			

Return Value:		
/* Changes

Date		Who		Reason
02/08/2019	jlgns1	Initial creation
06/08/2019 	JLGNS1	ChangeRequest 45293: JMT Handheld Apps - Release Staging Jade
15/08/2019	jlgka1	45924		JMT - Pack by Request - Webservice. 
								BA decided to change the logic to use CM_TerminalArea instead of the yard interchanged
								and use a Dictionary instead of TIArray.
21/08/2019	jlgrr1	45924		Change to method structure for JMT REST Apis to support the fact
								optional parameters can not be passed in the middle of the parameter list
07/04/2022	navmd1	53371		Moved/Copied from JMTHandheldService to MTNInternalAPIService
05/03/2025	navdap1	MTN-34024 PRP | Deadlock 1081, Yard Allocation &amp; Release Request Performance
*/

constants
	All_STR = "-1";
vars
	limit 			 : Integer ;
	index 			 : Integer ;
	realRelease 	 : CM_BulkRelease;
	realResDet 		 : CM_ReserveDetail;
	iter 			 : Iterator;
	cargo 			 : CM_TrackedItem;
	count 			 : Integer;
	rsCargo 		 : WS_CargoSummary;
	response 		 : WS_CargoSummaryResponse ;
	tiDD 			 : DynaDictionary;					//jlgka1 TFS 45924
	tiArea 			 : CM_TerminalArea;
	realArea 		 : CM_TerminalArea;	
	failedDAC  		 : CM_DataAccessController ;
	mode			 : String;
	isQueueMode		 : Boolean;
begin

	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	on LockException do self.handleLockExceptions(exception);
	
	create response transient;
	
	// Set app.mypassport - user / terminal &amp; machine
	self.initialisePassport();
	
	if self.httpStatusCode &lt;&gt; HttpResponseOK then
		//user has not validated
		app.writeLog(method.qualifiedName &amp; Tab &amp; self.httpStatusCode.String, LogERROR);	//25 Nov 2019	NDL	TFS 47053	//navra1 - 24th Aug 2022 - TFS 50365
		return response;
	endif;	
	
	// Get the parameters
	limit 			:= parseParameterList(optionalParam, 1, Integer).Integer;
	index 			:= parseParameterList(optionalParam, 2, Integer).Integer;
	mode			:= parseParameterList(optionalParam, 3, String).String;
		
	// Check for errrors
	if app.myPassport.hasErrors then
		return response;
	endif;
		
	// Set Defaults
	if limit = 0 then
		limit := 50;
	endif;
	if limit &gt; 250 then
		limit := 250;
	endif;
	if index = 0 then
		index := 1;
	endif;
	if mode	 = "queued" then
		isQueueMode := true;
	endif;
	
	
	
	realRelease := app.myPassport.getObjectOfTypeFromOid(releaseOid, CM_BulkRelease).CM_BulkRelease;	
	
	if realRelease = null then
		app.raiseCMException(Input_required_field_delReleas,null,null);
		return response;
	endif;
			
	realResDet := app.myPassport.getObjectOfTypeFromOid(reserveDetailOid, CM_ReserveDetail).CM_ReserveDetail;
	if realResDet = null then		// MTN-34024
		return response;			// MTN-34024
	endif;							// MTN-34024
		
	if app.myPassport.hasErrors then
		return response;
	endif;
		
	if sourceAreaId &lt;&gt; All_STR then
		realArea :=	app.myPassport.myTerminal.allTerminalAreas.getAtKey(sourceAreaId);
		if realArea &lt;&gt; null then
			if not realArea.canUserAccessSelf(app.getMyUser,failedDAC ,app.myPassport) then
				app.raiseCMException3(ERR_USER_NO_ACCESS,app.getMyUser.identity,app.getErrorString(TerminalArea),sourceAreaId, null,null);
				return response;
			endif;		
		
		endif;
	endif;
	// jlgka1 TFS 45924 --&gt;		
	create tiDD  transient;
	tiDD.setMembership(CM_TrackedItem);
	
	if ordering = "FIFO" then
		tiDD.addMemberKey(CM_TrackedItem::receivedDT.name, false, false);
		tiDD.addMemberKey(CM_TrackedItem::id.name, false, true);
		tiDD.addMemberKey(CM_TrackedItem::oidAsBin.name,false,false);
	else
		tiDD.addMemberKey(CM_TrackedItem::id.name, false, true);
		tiDD.addMemberKey(CM_TrackedItem::receivedDT.name, false, false);
		tiDD.addMemberKey(CM_TrackedItem::oidAsBin.name,false,false);
	endif;
	tiDD.endKeys(true);					
	
	app.writeLog(method.qualifiedName &amp; Tab &amp; "index is " &amp; index.String &amp; ", limit is " &amp; limit.String, LogDEBUG);
	realRelease.getProspectiveCargo(realResDet, realArea, null,null, tiDD, ordering &lt;&gt; "FIFO", limit, index, count);	// MTN-34024
	// MTN-34024 reset count so we get all the items in the TI set (should only be limit)
	if ordering &lt;&gt; "FIFO" then
		count := null;
	endif;
	// jlgka1 TFS 45924 &lt;--
	
	iter := tiDD.createIterator;	
	
	while iter.next(cargo) and count &lt; ((index-1) + limit) do
		if not cargo.canUserAccessSelf(app.getMyUser,failedDAC ,app.myPassport) then
			continue;
		endif;	
		
		if cargo.myPrimaryActualLocation = null then
			continue;
		endif;
		tiArea := cargo.myPrimaryActualLocation.myTerminalArea;	
		if tiArea &lt;&gt; null and tiArea.isInterchangeArea then	
			continue;
		endif;
		
		if isQueueMode then
			if cargo.myPrimaryQueuedLocation &lt;&gt; null then
				tiArea := cargo.myPrimaryQueuedLocation.myTerminalArea;	
				if tiArea &lt;&gt; null and tiArea.isInterchangeArea then
					continue;
				endif;	
			endif;	
		endif;
		
		if ordering = "FIFO" then		// MTN-34024 ordering by Cargo ID already only has index in the TI dict
			count := count + 1;
			if index &gt; 1 then
				if count &lt; index then
					continue;
				endif;
			endif;		
		endif;
		create rsCargo transient;
		rsCargo.setProxyFromObject(cargo);
		response.allCargoSummaries.add(rsCargo);
	endwhile;
			
	return response;

epilog	
	delete tiDD;
	delete iter;
	finaliseResponse(response);
end;</source>
        <Parameter name="releaseOid" type="String"/>
        <Parameter name="reserveDetailOid" type="String"/>
        <Parameter name="sourceAreaId" type="String"/>
        <Parameter name="ordering" type="String"/>
        <Parameter name="optionalParam" type="ParamListType"/>
        <ReturnType type="WS_CargoSummaryResponse"/>
    </JadeMethod>
    <JadeMethod name="getCargoTypes" id="2448a085-de8a-43ed-9656-034e19c059c7">
        <updating/>
        <source>getCargoTypes() : WS_CargoTypesResponse updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 May 2022	jlier1	Initial creation 53022

*/

vars

	response 		: WS_CargoTypesResponse;
	cargoBOLType	: CM_CargoBOLType;
	cargoType 		: CM_CargoType;
	wsCargoType       : WS_CargoType;
begin
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	on LockException do self.handleLockExceptions(exception);
	
	create response transient;
	// Set app.mypassport - user / terminal &amp; machine
	
	self.initialisePassport();
	
	if self.httpStatusCode &lt;&gt; HttpResponseOK then
		//user has not validated
		app.writeLog(method.qualifiedName &amp; Tab &amp; self.httpStatusCode.String, LogERROR);	//25 Nov 2019	NDL	TFS 47053	//navra1 - 24th Aug 2022 - TFS 50365
		return response;
	endif;	
	
	
	
	if app.myPassport.hasErrors then
		return response;
	endif;
	
	self.initMachineOptional();
	
	if app.myPassport.myMachine &lt;&gt; null then
		//if called from vehicle apps logged on as machine then only get cargo types valid for machine
		foreach cargoType in app.myPassport.myMachine.allAllowedCargoTypes  discreteLock where (not cargoType.isNotAvailableForEntry)    do
			create wsCargoType transient;
			wsCargoType.setProxyFromObject(cargoType);
			response.allCargoTypes.add(wsCargoType);	
		
		endforeach;
	else
	
		foreach cargoBOLType in app.myPassport.myTerminal.allCargoBOLTypes discreteLock do
			if (not CM_CargoType.hasInstance(cargoBOLType)) then 
				continue;
			endif;
			
			if cargoBOLType.CM_CargoType.isNotAvailableForEntry then
				continue;
			endif;
			
			create wsCargoType transient;
			wsCargoType.setProxyFromObject(cargoBOLType.CM_CargoType);
			
			response.allCargoTypes.add(wsCargoType);
			
		endforeach;
	endif;
	
	
	return response;
	
epilog
	self.finaliseResponse(response);

end;</source>
        <ReturnType type="WS_CargoTypesResponse"/>
    </JadeMethod>
    <JadeMethod name="getCargoTypesForVoyage" id="69e47aa2-6810-4747-9d2d-b84506cbf748">
        <updating/>
        <source>getCargoTypesForVoyage(voyageOid : String) : WS_CargoTypesResponse updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 November 2022	jlier1	Initial creation 55404

*/

vars
	response 		: WS_CargoTypesResponse;
	cargoType 		: CM_CargoType;
	wsCargoType       : WS_CargoType;
	voyage : CM_Voyage;
	iter: Iterator;
	cargoTypeID : Integer;
	ti ,nextTi: CM_TrackedItem;
	allCargoTypes : IntegerArray;
begin
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	on LockException do self.handleLockExceptions(exception);
	
	create response transient;
	// Set app.mypassport - user / terminal &amp; machine
	
	self.initialisePassport();
	
	if self.httpStatusCode &lt;&gt; HttpResponseOK then
		//user has not validated
		app.writeLog(method.qualifiedName &amp; Tab &amp; self.httpStatusCode.String, LogERROR);	//25 Nov 2019	NDL	TFS 47053	//navra1 - 24th Aug 2022 - TFS 50365
		return response;
	endif;	
	
	if app.myPassport.hasErrors then
		return response;
	endif;
	
	if voyageOid = null then
		app.raiseCMException(Input_required_field_voyage,null,null);
		return response;
	endif;
	
	voyage := app.myPassport.getObjectOfTypeFromOid(voyageOid, CM_Voyage).CM_Voyage;	
	if voyage = null then
		app.raiseCMException(Input_required_field_voyage,null,null);
		return response;
	endif;
	
	create allCargoTypes transient;
	
	iter:=voyage.allOnsiteTIsByCargoTypeId.createIterator;
	while iter.next(ti) do
		cargoTypeID:=iter.getCurrentKey(1).Integer;
	
		cargoType:=app.myRoot.allCargoTypesById[cargoTypeID];
		if cargoType &lt;&gt; null then
			if not cargoType.isNotAvailableForEntry then
				create wsCargoType transient;
				wsCargoType.setProxyFromObject(cargoType);
			
				response.allCargoTypes.add(wsCargoType);
				allCargoTypes.add(cargoTypeID);
			endif;
		endif;
		
		nextTi:=voyage.allOnsiteTIsByCargoTypeId.getAtKeyGeq(cargoTypeID+1,null);
		if nextTi = null or nextTi.cargoType = cargoTypeID  then
			break;
		endif;
		iter.startAtObject(nextTi);	
	endwhile;
		
	delete iter;
	iter:=voyage.allOnshipTIsByCargoTypeId.createIterator;
	
	while iter.next(ti) do
		cargoTypeID:=iter.getCurrentKey(1).Integer;
		if not allCargoTypes.includes(cargoTypeID) then
			cargoType:=app.myRoot.allCargoTypesById[cargoTypeID];
			if cargoType &lt;&gt; null then
				if not cargoType.isNotAvailableForEntry then
					create wsCargoType transient;
					wsCargoType.setProxyFromObject(cargoType);
					response.allCargoTypes.add(wsCargoType);
					allCargoTypes.add(cargoTypeID);
				endif;
			endif;
		endif;
		nextTi:=voyage.allOnshipTIsByCargoTypeId.getAtKeyGeq(cargoTypeID+1,null);
		if nextTi = null or nextTi.cargoType = cargoTypeID  then
			break;
		endif;
		iter.startAtObject(nextTi);	
	endwhile;
		
		
	return response;
	
epilog
	delete iter;
	delete allCargoTypes;
	self.finaliseResponse(response);


end;</source>
        <Parameter name="voyageOid" type="String"/>
        <ReturnType type="WS_CargoTypesResponse"/>
    </JadeMethod>
    <JadeMethod name="getCargoValidForRelease" id="9262497d-1488-4592-a5c4-3918875cc009">
        <updating/>
        <source>getCargoValidForRelease(cargoID : String; releaseOid : String; optionalParam : ParamListType) : WS_CargoSummaryResponse updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 August 2019	jlgns1	Initial creation
6/08/2019 	JLGNS1	ChangeRequest 45293: JMT Handheld Apps - Release Staging Jade
21/08/2019 jlgrr1	45924		Change to method structure for JMT REST Apis to support the fact
								optional parameters can not be passed in the middle of the parameter list
07/04/ 2022 navmd1	53371		Moved/Copied from JMTHandheldService to MTNInternalAPIService
23/06/2023	navkc1	CR 58406 Task 58408: Jade - Release Request All Tracked Items
*/

vars
	reserveDetailOid : String;
	realRelease 	: CM_BulkRelease;
	realResDet 		: CM_ReserveDetail;
	otherResDet 	: CM_ReserveDetail;
	iter 			: Iterator;
	cargo 			: CM_TrackedItem;
	rsCargo 		: WS_CargoSummary;
	response 		: WS_CargoSummaryResponse;
	tiDD 			: DynaDictionary;
	trItem			: CM_TrackedItem;
	startTi 		: CM_TrackedItem;
	reason 			: String;
	errorReason 	: String;
	failedDAC  		: CM_DataAccessController ;
	allTis			: CM_TISet;
begin

	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	on LockException do self.handleLockExceptions(exception);
	
	create response transient;
	create allTis transient; //23/06/2023	navkc1	CR 58406 Task 58408
	// Set app.mypassport - user / terminal &amp; machine
	self.initialisePassport();
	
	if self.httpStatusCode &lt;&gt; HttpResponseOK then
		//user has not validated
		app.writeLog(method.qualifiedName &amp; Tab &amp; self.httpStatusCode.String, LogERROR);	//25 Nov 2019	NDL	TFS 47053	//navra1 - 24th Aug 2022 - TFS 50365
		return response;
	endif;	
	
	//app.checkCurrentUserHasAccess(PmGteMTReleaseView);		
	if app.myPassport.hasErrors then
		self.httpStatusCode := HttpResponseForbidden;
		return response;
	endif;
	
	// Get the parameters
	reserveDetailOid:= parseParameterList(optionalParam, 1, String).String;


	if cargoID = null then
		app.raiseCMException(Input_required_field_cargoId,null,null);
		return response;
	endif;
	
		
	realRelease := app.myPassport.getObjectOfTypeFromOid(releaseOid, CM_BulkRelease).CM_BulkRelease;	
	if app.myPassport.hasErrors then
		return response;
	endif;
	if realRelease = null then
		app.raiseCMException(Input_required_field_delReleas,null,null);
		return response;
	endif;
				
	realResDet := app.myPassport.getObjectOfTypeFromOid(reserveDetailOid, CM_ReserveDetail).CM_ReserveDetail;
	if app.myPassport.hasErrors then
		return response;
	endif;
		
	create tiDD transient;
	tiDD.setMembership(CM_TrackedItem);
	tiDD.addMemberKey(CM_TrackedItem::id.name, false, false);
	tiDD.addMemberKey(CM_TrackedItem::oidAsHex.name,false,false);
	tiDD.endKeys(false);
	
	
	foreach otherResDet in realRelease.allReserveDetails do
		if realResDet &lt;&gt; null and otherResDet &lt;&gt; realResDet then
			continue;
		endif;
		
		
		if otherResDet.isComplete then	
			continue;
		endif;
		
		otherResDet.getAllTrackedItems(allTis, false); //23/06/2023	navkc1	CR 58406 Task 58408
		//foreach trItem in otherResDet.allTrackedItems do
		foreach trItem in allTis do //23/06/2023	navkc1	CR 58406 Task 58408
		
			if trItem.id &lt;&gt; cargoID then
				continue;
			endif;
		
		
			if realRelease.isPackingType then
				if trItem.isContainer or trItem.isChassis then
					//will be associated so as to be a parent not a child.
					continue;
				endif;
			endif;
			if trItem.isChild then
				//already packed
				continue;
			endif; 
			if trItem.myPrimaryActualLocation = null or not trItem.isOnSite then	
				if errorReason = null then
					errorReason := app.getErrorString1( ERR_TI_NOT_ONSITE,trItem.id);
				endif;	
				continue;
			endif;
			
			if realRelease.isRoadType then    
				if trItem.myPrimaryActualLocation.isVehicle then
					continue;
				elseif trItem.myPrimaryActualLocation.isTILCController then
					continue;
				endif;
			endif;
			
			tiDD.add( trItem );
		endforeach;
		
		if tiDD.size = 0 then			
			if otherResDet.isKindOf(CM_ReserveSelection) then
				iter := app.myPassport.myTerminal.allOnsiteTIsByIdCargoType.createIterator;
				startTi := app.myPassport.myTerminal.allOnsiteTIsByIdCargoType.getAtKeyGeq( cargoID, null );
				if startTi &lt;&gt; null and startTi.id = cargoID then
					iter.startAtObject( startTi );
					while iter.next(trItem) do
						if trItem.id &lt;&gt; cargoID then
							break;
						endif;
						if not trItem.isOnSite then
							// protect against crap data in DMAST
							continue;
						endif;
									
						if not trItem.testAgainstReserveSelection( otherResDet.CM_ReserveSelection, reason, true, null ) then
							if errorReason = null then
								errorReason := reason;
							endif;
							continue;
						endif;
				
					
						if trItem.myPrimaryActualLocation.isVehicle then	
							if not trItem.allBulkReleasesAssigned.isEmpty then
								//apparently assigned and already loaded...
								if errorReason = null then
									errorReason := app.getErrorString1( Cargo_already_assigned_load,trItem.getBulkReleaseAssignedCode);
								endif;	
								continue;
							endif;
						endif;
						tiDD.addNoDuplicates( trItem, false );
					endwhile;
				endif;
				delete iter;
			else
				if realResDet &lt;&gt; null and otherResDet = realResDet then
					app.raiseCMException1(Relea_not_relas_type_not_match,realResDet.myReserveHeader.code ,null,null); 
				endif;	
			endif;
		endif;
	endforeach;	
		
	// Check for errrors
	if app.myPassport.hasErrors then
		return response;
	endif;	
			
	iter := tiDD.createIterator;	
	
	while iter.next(cargo)  do
		if not cargo.canUserAccessSelf(app.getMyUser,failedDAC ,app.myPassport) then
			continue;
		endif;		
	
		create rsCargo transient;
		rsCargo.setProxyFromObject(cargo);
		response.allCargoSummaries.add(rsCargo);
	endwhile;
		
	if response.allCargoSummaries.size = 0 then
		if trItem = null then
			app.raiseCMException1(Follow_cargo_items_could_found,cargoID,null,null);
		else
			app.raiseCMException2(Warn_Request_Line_Match, errorReason, cargoID,null,null);
		endif;
	endif;
			
	return response;

epilog
	delete tiDD;
	delete iter;
	finaliseResponse(response);
	delete allTis; //23/06/2023	navkc1	CR 58406 Task 58408
end;</source>
        <Parameter name="cargoID" type="String"/>
        <Parameter name="releaseOid" type="String"/>
        <Parameter name="optionalParam" type="ParamListType"/>
        <ReturnType type="WS_CargoSummaryResponse"/>
    </JadeMethod>
    <JadeMethod name="getCargosForStage" id="b14e5f7c-0215-45b4-b699-33059eb189c7">
        <updating/>
        <source>getCargosForStage(releaseOid :String; reserveDetailOid : String) : WS_CargoToStageResponse updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 Jan 2023 navhl20 ChangeRequest 58760:[61583] EUP | VAS Mobile App - [53813.050] VAS Tasks for Release Cargo Work Order
25 Sep 2024 navhl20	ChangeRequest 62456:[66078] EUP* | VAS Mobile App - [53813.040] VAS Tasks in other Operational Mobile Apps - Flow Integration - 2
*/

vars
	realRelease		 : CM_BulkRelease;
	realResDet 		 : CM_ReserveDetail;
	iter 			 : Iterator;
	cargo 		 	 : CM_TrackedItem;
	rsCargo 		 : WS_CargoSummary;
	response 		 : WS_CargoToStageResponse ;
	tiArray 		 : CM_TIArray;	
	sourceLC 		 : CM_LocationsController;
	failedDAC  		 : CM_DataAccessController ;
	cmifMobile 		 : CMIF_MobileGenericAgent;
	stwRule 		 : Integer;
begin
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	on LockException do self.handleLockExceptions(exception);
	
	create response transient;
	
	// Set app.mypassport - user / terminal &amp; machine
	self.initialisePassport();
	
	if self.httpStatusCode &lt;&gt; HttpResponseOK then
		//user has not validated
		app.writeLog(method.qualifiedName &amp; Tab &amp; self.httpStatusCode.String, LogERROR);
		return response;
	endif;	
	
	realRelease := app.myPassport.getObjectOfTypeFromOid(releaseOid, CM_BulkRelease).CM_BulkRelease;	
	
	if realRelease = null then
		app.raiseCMException(Input_required_field_delReleas,null,null);
		return response;
	endif;

	realResDet := app.myPassport.getObjectOfTypeFromOid(reserveDetailOid, CM_ReserveDetail).CM_ReserveDetail;
	
	if app.myPassport.hasErrors then
		return response;
	endif;
	
	create tiArray transient; 	
	
	if realRelease.type = BR_TYPE_PACKING then						//25.09.2024 navhl20 #62456:[66078]
		realRelease.getProspectiveParentCargo(tiArray,false);
	else
		create cmifMobile transient;
		cmifMobile.setMyTerminal( app.myPassport.myTerminal);
		cmifMobile.getCargoBasedOnSTW12Rules(realRelease,realResDet, sourceLC, null,stwRule,tiArray);
	endif;

	iter := tiArray.createIterator;	
	while iter.next(cargo) do
		if not cargo.canUserAccessSelf(app.getMyUser,failedDAC ,app.myPassport) then
			continue;
		endif;
		
		if not cargo.isAvailable then
			continue;
		endif;
		
		create rsCargo transient;
		rsCargo.setProxyFromObject(cargo);
		response.allCargoSummaries.add(rsCargo);
	endwhile;
	response.setWeightAndCounts(realResDet);
		
	return response;
epilog
	delete tiArray;
	delete iter;
	delete cmifMobile;
	self.finaliseResponse(response);
end;</source>
        <Parameter name="releaseOid" type="String"/>
        <Parameter name="reserveDetailOid" type="String"/>
        <ReturnType type="WS_CargoToStageResponse"/>
    </JadeMethod>
    <JadeMethod name="getCargosStaged" id="c0627c96-9ba7-4ac4-a895-2c325d18e9bf">
        <updating/>
        <source>getCargosStaged(reserveDetailOid : String) : WS_CargoSummaryResponse updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 Jan 2023 navhl20 ChangeRequest 58760:[61583] EUP | VAS Mobile App - [53813.050] VAS Tasks for Release Cargo Work Order

*/

vars
	response 		: WS_CargoSummaryResponse;
	reserveDetail 	: CM_ReserveDetail;
	ti 				: CM_TrackedItem;
	failedDAC  		: CM_DataAccessController ;
	wsCargo 		: WS_CargoSummary;
	release 		: CM_BulkRelease;
	allTis			: CM_TISet;
begin
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	on LockException do self.handleLockExceptions(exception);
	
	create response transient;
	create allTis transient;
	// Set app.mypassport - user / terminal &amp; machine
	self.initialisePassport();
	
	if self.httpStatusCode &lt;&gt; HttpResponseOK then
		//user has not validated
		app.writeLog(method.qualifiedName &amp; Tab &amp; self.httpStatusCode.String, LogERROR);
		return response;
	endif;	
	
	reserveDetail := app.myPassport.getObjectOfTypeFromOid(reserveDetailOid, CM_ReserveDetail).CM_ReserveDetail;
	
	if app.myPassport.hasErrors then
		return response;
	endif;
	
	if reserveDetail = null then
		app.raiseCMException(Input_required_field_delReleas,null,null);
		return response;
	endif;
	
	release:=reserveDetail.myReserveHeader;
	
	reserveDetail.getAllTrackedItems(allTis, false);
	
	foreach ti in allTis discreteLock do
		if not release.allTrackedItemsAssigned.includes(ti) then
			continue;
		endif;
		if not ti.canUserAccessSelf(app.getMyUser,failedDAC ,app.myPassport) then
			continue;
		endif;
				
		create wsCargo transient;
		wsCargo.setProxyFromObject(ti);
		response.allCargoSummaries.add(wsCargo);
	endforeach;
	
	return response;
epilog
	self.finaliseResponse(response);
	delete allTis; 
end;</source>
        <Parameter name="reserveDetailOid" type="String"/>
        <ReturnType type="WS_CargoSummaryResponse"/>
    </JadeMethod>
    <JadeMethod name="getConsignees" id="6511649f-c219-4a33-9dd3-5cc9e49d840e">
        <updating/>
        <source>getConsignees(): WS_ConsigneesResponse updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 May 2022	jlier1	Initial creation

*/

vars
	cons			: CM_ConsigneeConsignor;
	proxyCons		: WS_ConsigneeConsignor;
	response		: WS_ConsigneesResponse;
	failedDAC		: CM_DataAccessController;
begin
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	on LockException do self.handleLockExceptions(exception);
	
	create response transient;
	// Set app.mypassport - user / terminal &amp; machine
	
	self.initialisePassport();
	
	if self.httpStatusCode &lt;&gt; HttpResponseOK then
		//user has not validated
		app.writeLog(method.qualifiedName &amp; Tab &amp; self.httpStatusCode.String, LogERROR);	//25 Nov 2019	NDL	TFS 47053	//navra1 - 24th Aug 2022 - TFS 50365
		return response;
	endif;	
	
	if app.myPassport.hasErrors then
		return response;
	endif;
	
	foreach cons in app.myRoot.allConsigneeConsignors discreteLock where
				(cons.isConsignee and cons.isNotAvailableForEntry = false) do
				
		if not cons.canUserAccessSelf(null, failedDAC, app.myPassport) then
			continue;
		endif;
		
		create proxyCons transient;
		proxyCons.setProxyFromObject(cons);
		response.allConsignees.add(proxyCons);
	endforeach;
	return response;
epilog
	self.finaliseResponse(response);
end;</source>
        <ReturnType type="WS_ConsigneesResponse"/>
    </JadeMethod>
    <JadeMethod name="getCountries" id="9e045af8-2e78-42f1-a107-5c7944686b8c">
        <updating/>
        <source>getCountries() : WS_CountriesResponse updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 Nov 2022	navlw1	Initial creation TFS 55417 EUP - Country of Origin

*/

vars
	response 	: WS_CountriesResponse;
	country		: CM_Country;
	wsCountry	: WS_Country;
begin

	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	on LockException do self.handleLockExceptions(exception);
	
	// Set app.mypassport - user / terminal &amp; machine
	self.initialisePassport();
	
	create response transient;
	
	if self.httpStatusCode &lt;&gt; HttpResponseOK then
		app.writeLog(method.qualifiedName &amp; Tab &amp; self.httpStatusCode.String, LogERROR);
		return response;
	endif;	
	
	if app.myPassport.hasErrors then
		return response;
	endif;	
	
	foreach country in app.myRoot.allCountries discreteLock do
		if not country.isNotAvailableForEntry then
			create wsCountry transient;
			wsCountry.setProxyFromObject(country);
			response.allCountries.add(wsCountry);
		endif;
	endforeach;
	
	return response;
epilog
	finaliseResponse(response);
end;</source>
        <ReturnType type="WS_CountriesResponse"/>
    </JadeMethod>
    <JadeMethod name="getCurrentVoyages" id="89ec28c3-346a-445a-99c2-e335fad2d16f">
        <updating/>
        <source>getCurrentVoyages() : WS_VoyagesResponse updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 May 2022	jlier1	Initial creation

*/

vars
	response		: WS_VoyagesResponse;
	proxyVoyage		: WS_Voyage;
	selectedVoyages	: CM_VoyageSet;
	voy				: CM_Voyage;
	thePassport		: CM_Passport;
begin
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	on LockException do self.handleLockExceptions(exception);
	
	create response transient;
	// Set app.mypassport - user / terminal &amp; machine
	
	self.initialisePassport();
	
	if self.httpStatusCode &lt;&gt; HttpResponseOK then
		//user has not validated
		app.writeLog(method.qualifiedName &amp; Tab &amp; self.httpStatusCode.String, LogERROR);	//25 Nov 2019	NDL	TFS 47053	//navra1 - 24th Aug 2022 - TFS 50365
		return response;
	endif;	
	
	if app.myPassport.hasErrors then
		return response;
	endif;
	create selectedVoyages transient;
	app.myPassport.myTerminal.getAllCurrentVoyages(selectedVoyages,true,true,false);
	
	foreach voy in selectedVoyages discreteLock do
		create proxyVoyage transient; 
		proxyVoyage.setProxyFromObject(voy);
		response.allVoyages.add(proxyVoyage); 
	endforeach;
	
	return response;
epilog
	delete selectedVoyages;
	self.finaliseResponse(response);
end;</source>
        <ReturnType type="WS_VoyagesResponse"/>
    </JadeMethod>
