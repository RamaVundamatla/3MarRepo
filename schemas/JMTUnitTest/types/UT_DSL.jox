    <JadeMethod name="deleteToDoTaskDescription" id="c324e94a-af55-4c46-8b31-dc0d648f5cf0">
        <source>deleteToDoTaskDescription( toDoTaskDesc : CM_ToDoTaskDesc io);

/*

Purpose:			

Parameters:			

Return Value:		


Date			Who		Reason
15 October 2010	cnwndl1	Initial creation
18 January 2023	navcs2	ChangeRequest 54344: EUP - VAS Work Orders - Jobs (54263)

*/

vars

	toDoSet    : Cm_ToDoTaskSet;
	toDoTask   : CM_ToDoTask;
	tiToDoTask : CM_TiToDoTask;
	woToDo     : CM_WodToDo;
	transaction: CM_Transaction;
	resourceUsageProxys : CM_ResourceTypeUsageSet;
begin

	if toDoTaskDesc &lt;&gt; null and CM_ToDoTaskDesc.hasInstance(toDoTaskDesc) then
	
		if not toDoTaskDesc.allToDoTasks.isEmpty then
			create toDoSet transient;
			toDoTaskDesc.allToDoTasks.copy( toDoSet );
			foreach toDoTask in toDoSet where toDoTask.isKindOf(CM_TiToDoTask) do
				tiToDoTask := toDoTask.CM_TiToDoTask;
				beginTransaction;
				toDoTaskDesc.actionTI( tiToDoTask.myTrackedItem, EDIAction_Remove, app.myPassport);
				commitTransaction;
			endforeach;
			
		endif;
		
		//04.11.2021 navma1 #52248
		if not toDoTaskDesc.allWorkOrdersToDo.isEmpty then
			beginTransaction;
			foreach woToDo in toDoTaskDesc.allWorkOrdersToDo do
				
				woToDo.setProxyWodToDo(null);
			endforeach;
			commitTransaction;
		endif;
		//04.11.2021 navma1 #52248
		
		//04.11.2021 navma1 #52248
		// 18 January 2023	navcs2	ChangeRequest 54344 (54263)
		app.myTrxDA.trxDeleteToDoTaskDescNoVal(toDoTaskDesc, app.myPassport);
		self.assertNoTrxErrorsOrWarnings();
	endif;

epilog

	delete toDoSet;

end;</source>
        <Parameter name="toDoTaskDesc" type="CM_ToDoTaskDesc" usage="io"/>
    </JadeMethod>
    <JadeMethod name="deleteToDoTemplate" id="223af771-3cdb-43dd-9de5-91b53d49bb8e">
        <source>deleteToDoTemplate(_toDoTemplateID : String);
/*

Purpose:			

Date		Who		Reason
10/04/2014	cnwma1	Initial creation

*/

vars
	
	toDoTemplate : CM_ToDoTemplate;
	terminal  : CM_Terminal;
	
	toDoTemplateArray : CM_ToDoTemplateArray;
		
begin

	create toDoTemplateArray transient;
	self.getTerminal().allToDoTaskTemplates.copy(toDoTemplateArray);
	
	foreach toDoTemplate in toDoTemplateArray do
		if toDoTemplate.id &lt;&gt; _toDoTemplateID then
			continue;
		endif;
		
		app.myTrxDA.trxDeleteToDoTemplate(toDoTemplate, app.myPassport);
		self.assertNoTrxErrorsOrWarnings();
	endforeach;

epilog
	delete toDoTemplateArray;
end;</source>
        <Parameter name="_toDoTemplateID" type="String"/>
    </JadeMethod>
    <JadeMethod name="deleteTrackClearance" id="0f484c1f-aee9-48c8-96c6-91ceff2bf3e8">
        <source>deleteTrackClearance(_trackClearance : CM_TrackClearance);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
15 July 2009	cnwndl1	Initial creation

*/

vars

	trackClearance : CM_TrackClearance;
	
begin

	trackClearance := _trackClearance;
	
	if app.isValidObject( trackClearance ) then
		self.ignoreTrxWarnings(true);
		//app.myPassport.setWarningsIgnored(true);
		app.myTrxDA.trxDeleteTrackClearance(trackClearance, app.myPassport);
		self.assertTrueMsg(app.myPassport.trxCompletedOK(), app.myPassport.getAllErrorsWarningsAsString());
		self.assertTrueMsg(not app.isValidObject(trackClearance), "Track Clearance deletion failed");
	endif; 
	
epilog

end;</source>
        <Parameter name="_trackClearance" type="CM_TrackClearance"/>
    </JadeMethod>
    <JadeMethod name="deleteTrackedItem" id="af2aa232-3e8b-45cc-ba91-ac0f39c8d7b8">
        <source>deleteTrackedItem(_ti: Any input; _fixUp : Boolean);
//29 August 2008	cnwdw1	
//
//cnwas3 - commented out the "children" part as it was redundant after the previous commenting out 
// 21/11/2014 	cnwmh5	Change so that will now delete all ti's with the id in the terminal.
//						Fixes the issue where you have 2 test that create ti's with the same id
//						and the latter one calls getTrackedItem which returns the ti for the 1st test
// 14/07/2015	cnwdap1	PAR #36041 Remove this TI from the terminal's chilledTIsOffPower set if it's in there
//						(chilledTIsOffPower is not inversed)
//	
// 22/05/2017	cnwkpd1	Add diagnostic check for JADE PAR #60207
// 03 Jan 2018	jlgrs1	TFS 36430 Penn Ship Manifest too many locks
// 11 May 2018	jlgrs1	make delete Terminal work

vars
	children: CM_TIArray;
	child: CM_TrackedItem;
	parent: CM_TrackedItem;
	wle: CM_WorkListEntry;
	oldSetting: Boolean;
	job : CM_Job;
	request : CM_Request;
	bulkRelease	: CM_BulkRelease;
	ts : TimeStamp;
	iter : Iterator;
	requestSet : CM_RequestSet;
	tiSet				: CM_TISet;
	ti					: CM_TrackedItem;
	addAlreadyGot		: Boolean;
	lastTI				: CM_TrackedItem;
	tempTISet			: CM_TISet;
	mergeIterTI			: MergeIterator;
	maxLiftWeightWarnOnly : Boolean;
	dummySubt : CM_SubTerminal;
	theLocationController : CM_LocationsController;
	cashPayment				: CM_CashPayment;
	tba : CM_TrackedItem;
	
begin
	
	///if _ti = null or not global.isValidObject(_ti) then
	///	return;
	///endif;
	
	if _ti = null then
		return;
	endif;
	
	create tiSet transient;
	create tempTISet transient;
	//create mergeIterTI transient;
	
	if _ti.isKindOf(String) then
		self.findTIsWithIDInTerminalQuick(_ti.String, tempTISet);
		tempTISet.copy(tiSet);
		addAlreadyGot := true;
	elseif _ti.isKindOf(CM_TrackedItem) then
		tiSet.add(_ti.CM_TrackedItem);
	elseif _ti.isKindOf(CM_TISet) then
		_ti.CM_TISet.copy(tiSet);
	elseif _ti.isKindOf(CM_TIArray) then
	//	_ti.CM_TIArray.copy(tiSet);
		foreach ti in  _ti.CM_TIArray do
			tiSet.tryAdd(ti);
		endforeach;
	else
		return;
	endif;
	
	lastTI := tiSet.last;
	
	if lastTI &lt;&gt; null and
	   global.isValidObject(lastTI) then
		if app.isSubTerminalsOn(lastTI.myTerminal) then
			if not lastTI.myTerminal.getConfig(IsSubTerminalAreaDefined).Boolean then
				dummySubt := lastTI.myTerminal.allSubTerminals.first;
			endif;
		endif;
	endif;
	
	//19 Mar 2020	NDL	TFS 47004
	foreach ti in tiSet do
		if not global.isValidObject(ti) then
			continue;
		endif;
		tba := ti.myMatchedTBA;
		if tba &lt;&gt; null and global.isValidObject(tba) and not tiSet.includes(tba) then
			tempTISet.tryAdd( tba);
		endif;
	endforeach;
	if not tempTISet.isEmpty then
		tempTISet.copyNoDups(tiSet);
		tempTISet.clear();
	endif;
	
	// 17/08/2015 cnwmh5 - To stop tripping up if weight &gt; max	
	maxLiftWeightWarnOnly := self.getTerminal.getConfig(MaxLiftWeightWarnOnly).Boolean;
	beginTransaction;
	self.getTerminal().setConfig(MaxLiftWeightWarnOnly, true);		
	commitTransaction;

	create requestSet transient;
	create children transient;													// 07/09/2015 cnwmh5

	foreach ti in tiSet do
	
		if not global.isValidObject(ti) then
			continue;
		endif;
		
		// get any ti's with same id for ti if nto already done
		if not addAlreadyGot then
			tempTISet.clear();
			self.findTIsWithIDInTerminalQuick(ti.id, tempTISet);
			tempTISet.copyNoDups(tiSet);
			if ti = lastTI then
				addAlreadyGot := true;
			endif;
		endif;
	
		if _fixUp then
			self.xFixUpTrackedItem(ti);
		endif;
	
		if not global.isValidObject(ti.myProduct) and ti.myProduct &lt;&gt; null then
			beginTransaction;
			ti.setPropertyValue("myProduct", null);
			commitTransaction;
		endif;
		if ti.mySubTerminal = null and dummySubt &lt;&gt; null then
			beginTransaction;
			ti.setPropertyValue("mySubTerminal", dummySubt);
			commitTransaction;
		endif;
		self.ignoreTrxWarnings(true);
		
		// because deleteStops ends up calling setForUpdate on the ti, delete the TI's VGM details
		// now to stop inadvertent updating of Weigh Authorities with details from a TI that's
		// about to get deleted
		beginTransaction;
		ti.deleteVGMDetails();
		commitTransaction;
		
		if ti.myReeferProperties &lt;&gt; null then
			if ti.myReeferProperties.packTempDetails &lt;&gt; null and
			   not global.isValidObject(ti.myReeferProperties.packTempDetails) then
				beginTransaction;
				ti.myReeferProperties.setPropertyValue(CM_TIReeferProperties::packTempDetails.name, null);
				commitTransaction;
			endif;
		endif;
		foreach child in ti.allChildren do
			if child.myReeferProperties &lt;&gt; null and
			   child.myReeferProperties.packTempDetails &lt;&gt; null and
			   not global.isValidObject(child.myReeferProperties.packTempDetails) then
				beginTransaction;
				child.myReeferProperties.setPropertyValue(CM_TIReeferProperties::packTempDetails.name, null);
				commitTransaction;
			endif;
		endforeach;

		self.deleteStops(ti); // AKB	
		
		// 09/05/2014 cnwmh5 - Check Road job and remove request if road job.allRequests empty remove job
		///create requestSet transient;
		requestSet.clear();
		if ti.jobRailReceive &lt;&gt; null then
			ti.jobRailReceive.allRequests.copyNoDups(requestSet);
		endif;
		if ti.jobRailRelease &lt;&gt; null then
			ti.jobRailRelease.allRequests.copyNoDups(requestSet);
		endif; 
		if ti.jobRoadReceive &lt;&gt; null then
			 ti.jobRoadReceive.allRequests.copyNoDups(requestSet);
		endif;
		if ti.jobRoadRelease &lt;&gt; null then
			ti.jobRoadRelease.allRequests.copyNoDups(requestSet);
		endif;
		
		// 07/05/2014 cnwmh5 - Check the delivery release and if request is for this ti then remove request
		// if bulk release reqeusts = null then remove bulk release
		if ti.deliveryRelease &lt;&gt; null then
			delete iter;
			ts := null;
			iter := self.getTerminal().allBulkReleasesByCodeDate.createIterator;
			self.getTerminal().allBulkReleasesByCodeDate.startKeyLeq(ti.deliveryRelease, ts, iter);
			while iter.back(bulkRelease) do
				if bulkRelease.code &lt;&gt; ti.deliveryRelease then
					break;
				endif;
				bulkRelease.requests.copyNoDups(requestSet);
			endwhile;
		endif;
		delete iter;
		self.deleteRequest(ti, requestSet);
		
		self.unqueueTI(ti);
		self.unplanTI(ti);
		
		self.expectTrxError(Cargo_that_locat_colou_coded_d);
		self.setTaskStatus(TASK_COMPLETE, self.getQueueTask(ti));
		self.clearExpectedTrxErrors();
		
		//self.unqueueTI(_ti);
		//self.unplanTI(_ti);
		self.zapQueueTask(ti.queueTask);
		if not ti.isNotified and ti.isOnSite then   // prenoted cargo automatically has children removed
			if ti.isChild then
				//create children transient;
				children.clear();																// 07/09/2015 cnwmh5
				children.add(ti);
				parent := ti.getParent;
				app.myPassport.setWarningsIgnored(true);
				oldSetting := self.getTerminal().getConfig(BulkReleaseReqdForPack).Boolean;
				beginTransaction;
				self.getTerminal().setConfig(BulkReleaseReqdForPack, false);
				if parent.weightTare = 0 then
					parent.setPropertyValue(CM_TrackedItem::weightTare.name, 100.Decimal);
				endif;
				commitTransaction;
				self.unpackContainer(parent, children);
				beginTransaction;
				self.getTerminal().setConfig(BulkReleaseReqdForPack, oldSetting);
				commitTransaction;
			else
			/*
				beginTransaction;
				ti.setPropertyValue("carrier",null);
				self.deleteVVR(ti.getVehicleVisit());
				commitTransaction;
				*/
				self.deleteTrackedItemChildren(ti);
			endif;
		else
			if ti.isChild then  // Notified child so delete parent which will delete the child as well)
				self.deleteTrackedItem(ti.myParent, false); // AKB added false
				continue;															// 18/08/2015 cnwmh5
			endif;
		endif;
		
		if ti.myTerminal &lt;&gt; null and ti.myTerminal.chilledTIsOffPower.includes(ti) then		// PAR #36041
			beginTransaction;																// PAR #36041
			ti.myTerminal.chilledTIsOffPower.remove(ti);									// PAR #36041
			commitTransaction;																// PAR #36041
		endif;																				// PAR #36041
			
		self.deleteTIInvoiceLines(ti);
		self.ignoreTrxWarnings(true);
		//app.myPassport.setWarningsIgnored(true);
		tiSet.remove(ti);																	// 18/08/2015 cnwmh5
		theLocationController := ti.getPrimaryLocation(REAL_MODE);
		
		///* 08/08/2019 Clear cash payments
		if ti.allCashPayments.isNotEmpty() then
			beginTransaction;
			foreach cashPayment in ti.allCashPayments do
				delete cashPayment;
			endforeach;
			commitTransaction;		
		endif;
		//*/
		
		app.myTrxDA.trxDeleteTI(ti, false, app.myPassport);
		self.assertNoTrxErrorsOrWarnings;
		
		// KPD Testing for JADE issue #60207
		if not app.isValidObject(ti) and app.isValidObject(theLocationController) then
			if theLocationController.allTrackedItems.includes(ti) then
				node.processDump();
				theLocationController.allTrackedItems.dump(app.myCnCntrl.logPath &amp; "\coll_dump_" &amp; theLocationController.allTrackedItems.getOidString.replace('.','_') &amp; '_' &amp; app.actualTimeAppServer.getNumeralString &amp; '.log');
			endif;
		endif;
		
	endforeach;
	
epilog
	if not process.isInTransactionState then
		beginTransaction;
	endif;
	self.getTerminal().setConfig(BulkReleaseReqdForPack, oldSetting);
	self.getTerminal().setConfig(MaxLiftWeightWarnOnly, maxLiftWeightWarnOnly);		// 17/08/2015 cnwmh5 - To stop tripping up if weight &gt; max	
	commitTransaction;
	delete children;
	delete requestSet;
	delete tiSet;
	delete tempTISet;
	delete mergeIterTI;
	delete iter;
end;
</source>
        <Parameter name="_ti" type="Any" usage="input"/>
        <Parameter name="_fixUp" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="deleteTrackedItemChildren" id="ec06a7f4-9e2f-4d15-822b-7f1482d3230e">
        <source>deleteTrackedItemChildren(_ti: CM_TrackedItem) ;
//29 August 2008	cnwdw1	
// 11 May 2018	jlgrs1	make delete Terminal work
//
vars
	children: CM_TIArray;
	child: CM_TrackedItem;
	parent: CM_TrackedItem;
	oldSetting: Boolean;
	dummySubt : CM_SubTerminal;
begin

	if app.isSubTerminalsOn(_ti.myTerminal) then
		if not _ti.myTerminal.getConfig(IsSubTerminalAreaDefined).Boolean then
			dummySubt := _ti.myTerminal.allSubTerminals.first;
		endif;
	endif;

	create children transient;
	foreach child in _ti.allChildren do
		if not global.isValidObject(child.myProduct) then
			beginTransaction;
			child.setPropertyValue("myProduct", null);
			commitTransaction;
		endif;
		if child.mySubTerminal = null and dummySubt &lt;&gt; null then
			beginTransaction;
			child.setPropertyValue("mySubTerminal", dummySubt);
			commitTransaction;
		endif;
		children.add(child);
	endforeach;
	if children.size &gt; 0 then
		parent := _ti;
		app.myPassport.setWarningsIgnored(true);
		oldSetting := self.getTerminal().getConfig(BulkReleaseReqdForPack).Boolean;
		beginTransaction;
		self.getTerminal().setConfig(BulkReleaseReqdForPack, false);
		if parent.weightTare = 0 then
			parent.setPropertyValue(CM_TrackedItem::weightTare.name, 100.Decimal);
		endif;
		commitTransaction;
		self.unpackContainer(parent, children);
		beginTransaction;
		self.getTerminal().setConfig(BulkReleaseReqdForPack, oldSetting);
		commitTransaction;
	endif;
	foreach child in children do
		self.deleteTrackedItem(child, false); // AKB added false
	endforeach;
	
epilog
	beginTransaction;
	self.getTerminal().setConfig(BulkReleaseReqdForPack, oldSetting);
	commitTransaction;
	delete children;
end;
</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="deleteTrackedItem_OLD" id="99e56f3e-bfa6-4933-84d4-9fa3d28533fe">
        <source>deleteTrackedItem_OLD(_ti: CM_TrackedItem input; _fixUp : Boolean);
//29 August 2008	cnwdw1	
//
//cnwas3 - commented out the "children" part as it was redundant after the previous commenting out 
// 03 Jan 2018	jlgrs1	TFS 36430 Penn Ship Manifest too many locks
vars
	children: CM_TIArray;
	child: CM_TrackedItem;
	parent: CM_TrackedItem;
	wle: CM_WorkListEntry;
	oldSetting: Boolean;
	job : CM_Job;
	request : CM_Request;
	bulkRelease	: CM_BulkRelease;
	ts : TimeStamp;
	iter : Iterator;
	requestSet : CM_RequestSet;
begin
	if _ti = null or not global.isValidObject(_ti) then
		return;
	endif;
	
	if _fixUp then
		self.xFixUpTrackedItem(_ti);
	endif;

	if not global.isValidObject(_ti.myProduct) and _ti.myProduct &lt;&gt; null then
		beginTransaction;
		_ti.setPropertyValue("myProduct", null);
		commitTransaction;
	endif;
	self.ignoreTrxWarnings(true);
	
	self.deleteStops(_ti); // AKB	
	
	// 09/05/2014 cnwmh5 - Check Road job and remove request if road job.allRequests empty remove job
	create requestSet transient;
	if _ti.jobRailReceive &lt;&gt; null then
		_ti.jobRailReceive.allRequests.copyNoDups(requestSet);
	endif;
	if _ti.jobRailRelease &lt;&gt; null then
		_ti.jobRailRelease.allRequests.copyNoDups(requestSet);
	endif; 
	if _ti.jobRoadReceive &lt;&gt; null then
		 _ti.jobRoadReceive.allRequests.copyNoDups(requestSet);
	endif;
	if _ti.jobRoadRelease &lt;&gt; null then
		_ti.jobRoadRelease.allRequests.copyNoDups(requestSet);
	endif;
	
	// 07/05/2014 cnwmh5 - Check the delivery release and if request is for this ti then remove request
	// if bulk release reqeusts = null then remove bulk release
	if _ti.deliveryRelease &lt;&gt; null then
		delete iter;
		ts := null;
		iter := self.getTerminal().allBulkReleasesByCodeDate.createIterator;
		self.getTerminal().allBulkReleasesByCodeDate.startKeyLeq(_ti.deliveryRelease, ts, iter);
		while iter.back(bulkRelease) do
			if bulkRelease.code &lt;&gt; _ti.deliveryRelease then
				break;
			endif;
			bulkRelease.requests.copyNoDups(requestSet);
		endwhile;
	endif;
	delete iter;
	self.deleteRequest(_ti, requestSet);
	
	self.unqueueTI(_ti);
	self.unplanTI(_ti);
	
	self.expectTrxError(Cargo_that_locat_colou_coded_d);
	self.setTaskStatus(TASK_COMPLETE, self.getQueueTask(_ti));
	self.clearExpectedTrxErrors();
	
	//self.unqueueTI(_ti);
	//self.unplanTI(_ti);
	self.deleteTIInvoiceLines(_ti);
	self.zapQueueTask(_ti.queueTask);
	if not _ti.isNotified and _ti.isOnSite then   // prenoted cargo automatically has children removed
		if _ti.isChild then
			create children transient;
			children.add(_ti);
			parent := _ti.getParent;
			app.myPassport.setWarningsIgnored(true);
			oldSetting := self.setTerminalConfig(BulkReleaseReqdForPack, false).Boolean;
			self.unpackContainer(parent, children);
			self.setTerminalConfig(BulkReleaseReqdForPack, oldSetting);		
		else
			self.deleteTrackedItemChildren(_ti);
		endif;
	else
		if _ti.isChild then  // Notified child so delete parent which will delete the child as well)
			self.deleteTrackedItem(_ti.myParent, false); // AKB added false
			return;
		endif;
	endif;
	self.ignoreTrxWarnings(true);
	//app.myPassport.setWarningsIgnored(true);
	app.myTrxDA.trxDeleteTI(_ti, true, app.myPassport);
	self.assertNoTrxErrorsOrWarnings;
epilog
	self.setTerminalConfig(BulkReleaseReqdForPack, oldSetting);		
	delete children;
	delete requestSet;
	delete iter;
end;
</source>
        <Parameter name="_ti" type="CM_TrackedItem" usage="input"/>
        <Parameter name="_fixUp" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="deleteTrackedItems" id="8682ebb8-309c-4032-b240-d965c3d228cc">
