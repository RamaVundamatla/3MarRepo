    <JadeMethod name="drawBackground" id="780e4f1e-20ff-4360-9053-dae182e47a1b">
        <updating/>
        <source>drawBackground(_frame: CMUI_GridAreaDrawingFrame input; _x1: Real; _y1: Real; _x2: Real; _y2: Real) updating, protected;
/*
Purpose:	PAR 26858 draw selected end on TIs the same as the side on view draws selected TIs.		
Date				Who			Reason
JUNE 2011		CNWAB1		Initial creation
*/

constants
	Rim = 4;
vars
	theFrame: CMUI_GridAreaDrawingFrame;
	tmpColour,
	lOuterColourUpper,
	lOuterColourLower, 
	tmpDrawFillColor	: Integer;
	myX2, myX1, myY1, myY2	: Real;
	drawTI 	: Boolean;
	theTI	: CM_TrackedItem;
begin
	theTI := self.myTrackedItem;
	if theTI = null then
		return;
	endif; 

	theFrame := _frame;
	drawTI := true;

	if self.viewMode = VIEW_HEIGHT then
		tmpColour := self.myLocationsController.CM_GridController.getStackHeightOfTIsColour();
		tmpDrawFillColor := self.myDrawingAttrController.yardStackColours[tmpColour];
	else
		tmpDrawFillColor:= self.getFillColourForTI(theTI);
		if self.useSelectorObjects and not self.allSelectorTIs.includes(theTI) then
			tmpDrawFillColor := White;
		endif;
	endif;
	if tmpDrawFillColor = NullColour then
		tmpDrawFillColor := White;
	endif;
	theFrame.drawFillStyle := Frame.DrawFillStyle_Solid;
	theFrame.drawStyle := Frame.DrawFillStyle_Solid;
	theFrame.drawWidth := 1;

	lOuterColourLower := DarkGray;
	lOuterColourUpper := White;

	theFrame.drawFillColor := tmpDrawFillColor;

	myX1 := _x1;
	myX2 := _x2;
	myY1 := _y1;
	myY2 := _y2;
	
	if self.allSelectedObjects.includes(theTI) then
		theFrame.drawFillColor := White;
		theFrame.drawFilledRectangle(myX1, myY1, myX2, myY2,  White); 
		theFrame.drawFillColor := tmpDrawFillColor;
		theFrame.drawFilledRectangle(myX1 + Rim, myY1 + Rim, myX2 - Rim, myY2 - Rim,  tmpDrawFillColor); 
	else
		theFrame.drawFillColor := tmpDrawFillColor;
		theFrame.drawFilledRectangle(myX1, myY1, myX2, myY2,  tmpDrawFillColor); 
		self.drawTIBox(theFrame,lOuterColourUpper, lOuterColourLower, myX1.Integer, myY1.Integer, myX2.Integer, myY2.Integer);
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="_frame" type="CMUI_GridAreaDrawingFrame" usage="input"/>
        <Parameter name="_x1" type="Real"/>
        <Parameter name="_y1" type="Real"/>
        <Parameter name="_x2" type="Real"/>
        <Parameter name="_y2" type="Real"/>
    </JadeMethod>
    <JadeMethod name="drawCurrentObject" id="90becc96-e47d-41cb-a4fd-f43cbe666a76">
        <updating/>
        <source>drawCurrentObject(_frame: CMUI_GridAreaDrawingFrame input) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
25 May 2010	cnwndl1	Initial creation	Par 24044

*/

vars

	theTI : CM_TrackedItem;
	theDisplayMode : Integer;
	myLC : CM_LocationsController;
	drawSolid : Boolean;
	isFlipped : Boolean;
	drawingEndOn : Boolean;
	tmpLC : CM_GridController;
	colIdx : Integer;
	
begin
	if self.myYardGridEnqForm &lt;&gt; null then
		if self.myCurrentObject.isKindOf(CM_TrackedItem) then
			theTI := self.myCurrentObject.CM_TrackedItem;
		elseif self.myCurrentObject.isKindOf(CM_LocationsController) then
			myLC := self.myCurrentObject.CM_LocationsController;
		endif;
		if theTI &lt;&gt; null then
			theDisplayMode := self.displayMode;
			if theDisplayMode = DISPLAY_MODE_ACTUAL then
				myLC := theTI.myPrimaryActualLocation;
			elseif theDisplayMode = DISPLAY_MODE_QUEUE then
				myLC := theTI.myPrimaryQueuedLocation;
			elseif theDisplayMode = DISPLAY_MODE_PLAN then
				myLC := theTI.myPrimaryPlannedLocation;
			endif;
		endif;
		
		if not self.myYardGridEnqForm.isAllDrawSideOn then // PAR 26858 Possibly user wants to see all side on, no end views
			if myLC &lt;&gt; null and myLC.myTerminalArea &lt;&gt; null then
				if myLC.myTerminalArea.isForkliftStack or myLC.myTerminalArea.isRTGArea then
					drawingEndOn := true;
				endif;
			endif;
		endif;
	endif;

	if drawingEndOn then
		tmpLC := myLC.CM_GridController;
		self.drawLCEndOn(myLC.CM_GridController);
		
	else
		inheritMethod(_frame);
		
	endif;

epilog

end;</source>
        <Parameter name="_frame" type="CMUI_GridAreaDrawingFrame" usage="input"/>
    </JadeMethod>
    <JadeMethod name="drawLC" id="a794ce9e-a0e8-4648-820d-096b31ea5e3b">
