    <JadeMethod name="getWOForReport" id="68bcfa99-26dc-473e-b9ba-d5ac349a963a">
        <source>getWOForReport(_objArray : ObjectArray input; _selectedOnly : Boolean);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 Aug 2023 navhl20 ChangeRequest 58568: EUP - Delivery Dispatch – Reporting

*/

vars

begin
	if _selectedOnly then
		self.tblData.allSelectedObjects.copy(_objArray);
	else
		self.tblData.getAllRowObjects(_objArray);
	endif;
epilog

end;</source>
        <Parameter name="_objArray" type="ObjectArray" usage="input"/>
        <Parameter name="_selectedOnly" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getXMLSettingsForSave" id="ee5bc3aa-71d9-4da1-abd8-6ddbb480a950">
        <updating/>
        <source>getXMLSettingsForSave(): String updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
24/07/2009	cnwmd1	Initial creation
26/06/2018	jlgdap1	TFS 39440 PEL1 Work Order Enquiry Parameters
29/09/21 	navma1  ChangeRequest 51925: SAL - Web Portal Cargo Work Orders
*/

vars
	workOrderXML, 
	taskXML,
	searchXML,
	typeTag, 
	typeXML,
	rtnStr,
	str,
	transModeXML,
	transModeTag,
	woCargoTypesXML,
	woCargoTypesTag,
	woVoyageTypesXML, 
	woVoyageTypesTag 	: String;	
	idx 				: Integer;	
	allAttributeNames	: StringArray;
begin

	create allAttributeNames transient;

	
	rtnStr := inheritMethod();

	str := self.tblData.getXmlStrForColumns(true);
	
	//Get stored columns
	workOrderXML := global.formatAsXMLPrefix(self.EnqType_WorkOrder.String) &amp; 
					self.enquiryTypeDef_WorkOrder 						    &amp; 
					global.formatAsXMLSuffix(self.EnqType_WorkOrder.String);

	taskXML := global.formatAsXMLPrefix(self.EnqType_Task.String ) &amp; 
	           self.enquiryTypeDef_Task 						   &amp; 
			   global.formatAsXMLSuffix(self.EnqType_Task.String );
			   
	searchXML := global.formatAsXMLPrefix(self.SearchStatusList.String ) &amp; 
				self.searchStatusDef 									 &amp; 
				global.formatAsXMLSuffix(self.SearchStatusList.String );  // seach info as of old
	
	typeTag := self.enquiryType.String;
		
	if self.isEnqType_WorkOrder() then //overwrite the current option - just in case columns were changed in the current view
		workOrderXML := global.formatAsXMLPrefix(typeTag) &amp; str &amp; global.formatAsXMLSuffix(typeTag);
	elseif self.isEnqType_Task() then
		taskXML := global.formatAsXMLPrefix(typeTag) &amp; str &amp; global.formatAsXMLSuffix(typeTag);
	endif;
	
	allAttributeNames.add( CM_Association::integerValue.name );
	
	typeTag   := self.SearchStatusList.String;
	str 	  := self.mltWOStatus.getXMLStringForSelected(allAttributeNames);
	searchXML := global.formatAsXMLPrefix(typeTag) &amp; str &amp; global.formatAsXMLSuffix(typeTag);
	
	// TFS 39440 Store off teh selected Cargo and Voyage work order types
	woCargoTypesTag := self.SearchWOCargoTypes.String;
	str 		    := self.chkCargoWO.value.cnEcGetTableCheckBoxValue;
	
	foreach idx in 1 to self.tblCargoWO.rows do
		str := str &amp; self.tblCargoWO.accessCell(idx, 1).text;
	endforeach;
	
	woCargoTypesXML  := global.formatAsXMLPrefix(woCargoTypesTag) &amp; str &amp; global.formatAsXMLSuffix(woCargoTypesTag);
	woVoyageTypesTag := self.SearchWOVoyageTypes.String;
	str 			 := self.chkVoyageWO.value.cnEcGetTableCheckBoxValue;
	
	foreach idx in 1 to self.tblVoyageWO.rows do
		str := str &amp; self.tblVoyageWO.accessCell(idx, 1).text;
	endforeach;
	
	woVoyageTypesXML := global.formatAsXMLPrefix(woVoyageTypesTag) &amp; str &amp; global.formatAsXMLSuffix(woVoyageTypesTag);
	// TFS 39440 end of bulding XML
	
	//26/11/2024	navkc1 JIRA Story MTN-19092
	transModeTag 	:= self.SearchTransModes.String;
	str				:= self.chkTransportMode.value.cnEcGetTableCheckBoxValue();
	
	foreach idx in 1 to self.tblTransportMode.rows do
		str := str &amp; self.tblTransportMode.accessCell(idx, 1).text;
	endforeach;
	transModeXML := global.formatAsXMLPrefix(transModeTag) &amp; str &amp; global.formatAsXMLSuffix(transModeTag);
	
	//typeXML := workOrderXML &amp; taskXML &amp; searchXML &amp; woCargoTypesXML &amp; woVoyageTypesXML;		// TFS 39440
	typeXML := workOrderXML &amp; taskXML &amp; searchXML &amp; woCargoTypesXML &amp; woVoyageTypesXML &amp; transModeXML; //26/11/2024	navkc1 JIRA Story MTN-19092
	
	return rtnStr &amp; typeXML;
	
epilog
	delete allAttributeNames;	
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="handleNotifications" id="fa58f1e6-d336-4b6e-8431-fc956be96051">
        <updating/>
        <source>handleNotifications(eventType: Integer; theObject: Object; eventTag: Integer) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
01 May 2025 jlier1	MTN-
*/

vars
	invalid : Boolean;
	obj		: Object;
	termEvent	: Integer;
begin
	on Exception do app.handleDeletedObject(exception, theObject, invalid);	
	
	theObject.edition;
	
	if invalid then
		self.tblDataSysNotifyDelete(eventType, theObject, eventTag);			// 22/11/2023	navcs2	ChangeRequest 60866
		return;
	endif;
	
	/*
	23.05.2024 navma1 #64255
	*/
	if theObject.isKindOf(CM_WorkOrderTIDtl) then
		if theObject.CM_WorkOrderTIDtl.getTransport = TI_TRANSMODE_SHIP then
			return;
		endif;
	endif;
	obj := theObject;	
	//I don't think this is needed the notifications should update the parent if needed
	/*																			//15.04.2024 navhl20 #62758
	if self.enquiryType = self.EnqType_WorkOrder and theObject.isKindOf(CM_WorkOrderDtl) then			//15.04.2024 navhl20 #62758
		obj := theObject.CM_WorkOrderDtl.myParent;
	endif;
	
	*/
	
	if self.myTerminal &lt;&gt; null then
		termEvent := self.myTerminal.getEventFromTerminalEvent(eventType);
	endif;
	
	
	if ( self.enquiryType = self.EnqType_Task  	   and obj.isKindOf( CM_WorkOrderDtl)) or
	   ( self.enquiryType = self.EnqType_WorkOrder and obj.isKindOf( CM_WorkOrder)) then
	
		if termEvent = Event_WorkOrder_Update or termEvent = Event_WODtl_Update then
			self.tblDataSysNotifyUpdate(termEvent, obj, eventTag);
		elseif termEvent = Event_WorkOrder_Create or termEvent = Event_WODtl_Create then
			self.tblDataSysNotifyCreate(termEvent, obj, eventTag);
		elseif termEvent = Event_WorkOrder_Delete or termEvent = Event_WODtl_Delete then
			self.tblDataSysNotifyDelete(termEvent, obj, eventTag);
		endif;
	endif;

epilog

end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="includeObject" id="efeb6085-3b1c-4a00-825c-aebd4b0356b2">
        <updating/>
        <source>includeObject(_workOrder : CM_WorkOrder) : Boolean updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
03/08/2009	cnwmd1	Initial creation
29/04/2016	cnwns1	TFS 488 - Multi Timezone Support
06/06/2018	jlgdap1	TFS 38560 PEL1 Voyage Work Orders
20/06/2018	jlgdap1	TFS 39286 PEL1 Work Order Enquiry Vogage Requests
27/06/2018	jlgdap1	TFS 39440 PEL1 Work Order Enquiry Parameters
09/10/2018  cmnwma1	Bug 46965: PEL1 : Removing beginLoad and endLoad from WorkOrder Enquiry
31/05/2021  navma1  ChangeRequest 51002: MTN - Web Portal Cargo Work Orders
29/09/2021 	navma1 	ChangeRequest 51925: SAL - Web Portal Cargo Work Orders
16/08/2022	navcs2	Bug 54237: MTN - Work Order Maintenance - Lookup Work Order Type
15/12/2022  navcs2	54698:[54264] EUP - [Framework] - Enable VAS Work Order in Work Order Enquiry Screen
12/12/2023	navma1  ChangeRequest 56141: EUP - Refactor and Remove CM_WorkOrderTISource from CM_WorkOrderTI
03/06/2025  navsp1  JIRA-34585 MTN | Work Order Enquiry Query Refactor
17/06/2025  navsp1  JIRA-35146 1090 exception on the work order enquiry when creating an unpack work order
*/

vars
	organisation : CM_Organisation;
	hsarr 		 : HugeStringArray;
	sysReqFromTS,sysReqToTS, sysCompFromTS, sysCompToTS : TimeStamp;
	locReqFromTS, locReqToTS, locCompFromTS, locCompToTS : TimeStamp;
	reqByFromTS,
	reqByToTS    : TimeStamp;
	woDtl 		 : CM_WorkOrderDtl;				// TFS 39440
	idx			 : Integer;						// TFS 39440
	isOK,										// TFS 39440
	isDtlOK		 : Boolean;						//10/01/2025	navkc1 JIRA Bug MTN-33778
	voyage 		 : CM_Voyage;
	invalid      : Boolean;
	edition      : Integer;
	user		 : CM_User;
	vessel		 : CM_Vessel;
	
begin
	if self.isSearchValuesNotSet() then     //JIRA-35146
        self.setSearchValues();             //JIRA-35146
    endif;                                  //JIRA-35146
	
	on Exception do app.handleDeletedObject(exception, _workOrder, invalid);
	
	if _workOrder = null then
		return false;
	endif;
	
	edition := _workOrder.edition;  // 09.10.2019 cnwma1 #46965
	
	if invalid then
		return false;
	endif;
	
	organisation := self.filterOrganisation;                                                    //JIRA-34585
	if organisation &lt;&gt; null then
		if _workOrder.myOrganisation &lt;&gt; organisation then
			return false;
		endif;
		
		if not app.getMyUser().canUserAccessObj(_workOrder.myOrganisation , _workOrder.myOrganisation.class ) then
			return false;
		endif;
	endif;
	
	// TFS 41026
	voyage := self.filterVoyage;                                                                //JIRA-34585
	if voyage &lt;&gt; null then
		if _workOrder.getMyVoyageObject()  &lt;&gt; voyage then
			return false;
		endif;
	endif;
	
	// TFS 38560 Check if the work order is for this terminal	// TFS 38560
	if _workOrder.myTerminal &lt;&gt; self.myTerminal then			// TFS 38560
		return false;											// TFS 38560
	endif;														// TFS 38560
	
	// TFS 39286 Work orders with details of type CM_WodMarineServiceDetail,
	// CO_WodVoyageCargoRequest or CM_WodVoyageRequest should never be shown
	if not _workOrder.canShowInEnquiry then
		return false;
	endif;
	
	if not self.allSelectedStatus.includes( _workOrder.taskStatus ) then
		return false;
	endif;
	
	//13/06/2025	navkc1 JIRA MTN 35077
	if self.filterWorkOrderNum &lt;&gt; null then
		if _workOrder.id[1:self.filterWorkOrderNum.length].toUpper() &lt;&gt; self.filterWorkOrderNum then
			return false;
		endif;
	endif;
	
	if self.filterCustomerRef &lt;&gt; null then                                                 //JIRA-34585
		if _workOrder.customerReference &lt;&gt; self.filterCustomerRef then                     //JIRA-34585
			return false;
		endif;
	endif;
	
	//29 Apr 2016	cnwns1	TFS 488 - Multi Timezone Support
	locReqFromTS := self.filterMskRequestTS;                                               //JIRA-34585	
	if locReqFromTS.isValid() then
		sysReqFromTS 	:= self.localToSystemTime(locReqFromTS);
		if _workOrder.requiredByDT &lt; sysReqFromTS then 
			return false;
		endif;
	endif;
    
	locReqToTS := self.filterMskRequestToTS;                                               //JIRA-34585	
	if locReqToTS.isValid() then	
		sysReqToTS		:= self.localToSystemTime(locReqToTS);
		if _workOrder.requiredByDT &gt; sysReqToTS then
			return false;
		endif;	
	endif;
	
	//29.09.2021 navma1 #51925
   	reqByFromTS := self.filterMskRequestedByFromTS;                                        //JIRA-34585
	if reqByFromTS.isValid() then
		sysReqFromTS 	:= self.localToSystemTime(reqByFromTS);
		if _workOrder.enteredByDT &lt; sysReqFromTS then 
			return false;
		endif;
	endif;
    
	reqByToTS := self.filterMskRequestedByToTS;                                            //JIRA-34585	
	if reqByToTS.isValid() then	
		sysReqToTS		:= self.localToSystemTime(reqByToTS);
		if _workOrder.enteredByDT &gt; sysReqToTS then
			return false;
		endif;	
	endif;	
    
	//29.09.2021 navma1 #51925
    locCompFromTS := self.filterMskCompletedTS;                                            //JIRA-34585
	if locCompFromTS.isValid() then
		sysCompFromTS	:= self.localToSystemTime(locCompFromTS);	
		if _workOrder.completedDT &lt; sysCompFromTS then 
			return false;
		endif;
	endif;
    
	locCompToTS := self.filterMskCompletedToTS;	                                           //JIRA-34585		
	if locCompToTS.isValid() then	
		sysCompToTS		:= self.localToSystemTime(locCompToTS);
		if _workOrder.completedDT &gt; sysCompToTS then
			return false;
		endif;	
	endif;
	
	// TFS 39440 Check against selected work order types
	isOK := false;
	
	//10.09.2021 navma1 #51002
	foreach woDtl in _workOrder.allWoDtls do
		//idx := woDtl.getDtlType;             			//29.09.2021 navma1 #51925
		idx   := woDtl.getWorkOrderTaskIdByClass();		//29.09.2021 navma1 #51925
		
		if _workOrder.isVoyageWorkOrder then
			isOK := self.filterVoyWOdtlTaskNos.includes( idx );                                             //JIRA-34585
		elseif _workOrder.isToDoWorkOrder then
			isOK := self.filterToDoWOdtlTasksNos.includes( idx );	// 15.12.2022 navcs2 #54698:[54264]     //JIRA-34585
		else
			// cargo work order
			isOK := self.filterCargoWOdtlTaskNos.includes( idx ); //22 Aug 2018	NDL	TFS 40157               //JIRA-34585
		endif;
		
		//26/11/2024	navkc1 JIRA Story MTN-19092 - further checking for Work order details
		isDtlOK := self.includeObjectWODtl(woDtl, true);                                                    //JIRA-34585
		
		//if isOK then 	// 16/08/2022 navcs2 54237
		if isOK and isDtlOK then //10/01/2025	navkc1 JIRA Bug MTN-33778
			break; 		// 16/08/2022 navcs2 54237
		endif;			// 16/08/2022 navcs2 54237
		
	endforeach;
	
	user := self.filterUser;		//29.09.2021 navma1 #51925                                  //JIRA-34585
	if user &lt;&gt; null then
		if  _workOrder.myEnteredByUser &lt;&gt; user then
			return false;
		endif;	
	endif;
	
	isOK := isOK and isDtlOK; //10/01/2025	navkc1 JIRA Bug MTN-33778
	
	//10.09.2021 navma1 #51002
	if not isOK then
		return false;
	endif;
	
	return true;
epilog
	delete hsarr;
end;</source>
        <access>protected</access>
        <Parameter name="_workOrder" type="CM_WorkOrder"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="includeObjectWODtl" id="f0b3becc-cbd7-4ea1-97fe-eb81d1e65a7a">
        <updating/>
        <source>includeObjectWODtl(_workOrderDtl : CM_WorkOrderDtl; _isFromWO : Boolean) : Boolean updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26/11/2024	navkc1 JIRA Story MTN-19092: EUP | 54014 - Work Orders Enhancements - Improved Search and usability
03/06/2025  navsp1 JIRA-34585 MTN | Work Order Enquiry Query Refactor
17/06/2025  navsp1 JIRA-35146 1090 exception on the work order enquiry when creating an unpack work order
*/


vars
	cen,
	bolID,
	relReqID,
	bookingID,
	contractID,
	vbs,
	cargoGroupID	: String;
	transMode,
	taskType 		: Integer;
	bol				: CM_BOL;
	toDoTaskDesc	: CM_ToDoTaskDesc;
	toDoTaskDescSet	: CM_ToDoTaskDescSet;
	operator		: CM_Operator;
	debtor			: CM_Debtor;
	train			: CM_Train;
	allTrains		: CM_TrainSet;
	vvr				: CM_VehicleVisitRecord;
	allVVRs			: CM_VehicleVisitRecordSet;
	wagon			: CM_Wagon;
	allWagons		: CM_WagonSet;
	vessel			: CM_Vessel;
	voyage			: CM_Voyage;
	sa				: StringArray;
	vbsSlot			: CM_VehicleBookingTimeSlot;
begin
	if self.isSearchValuesNotSet() then     //JIRA-35146
        self.setSearchValues();             //JIRA-35146
    endif;                                  //JIRA-35146
	
	create sa transient;
	
	// Vessel
	vessel := self.filterVessel;                                    //JIRA-34585
	if vessel &lt;&gt; null then
		voyage := _workOrderDtl.getMyVoyageObject();
		
		if voyage = null then
			return false;
		endif;
		
		if vessel &lt;&gt; voyage.getMyVessel() then
			return false;
		endif;
	endif;
	
	// To Do Task Desc
	toDoTaskDesc := self.filterToDoTask;                            //JIRA-34585
	if toDoTaskDesc &lt;&gt; null then
		
		toDoTaskDescSet := _workOrderDtl.getTodoTaskDescObj();
		
		if toDoTaskDescSet = null then
			return false;
		endif;
		
		if not toDoTaskDescSet.includes(toDoTaskDesc) then
			return false;
		endif;
		
	endif;
	
	// Transport Mode - Release/Receive
	if _workOrderDtl.isWodRelease() or _workOrderDtl.isWodReceive() then
		if self.filterTransportModes.isNotEmpty() and not self.filterTransportModes.includes(_workOrderDtl.getTransportMode()) then     //JIRA-34585
			return false;
		endif;
	endif;
	
	if not _isFromWO then
		// Task Type
		taskType := _workOrderDtl.getWorkOrderTaskIdByClass();
		if _workOrderDtl.isKindOf(CM_WorkOrderVoyageDtl) then
			if not self.filterVoyWOdtlTaskNos.includes(taskType) then           //JIRA-34585
				return false;
			endif;
		elseif _workOrderDtl.isKindOf(CM_WorkOrderToDoDtl) then
			if not self.filterToDoWOdtlTasksNos.includes(taskType) then         //JIRA-34585
				return false;
			endif;
		else
			if not self.filterCargoWOdtlTaskNos.includes(taskType) then         //JIRA-34585
				return false;
			endif;
		endif;
	endif;
	
	// Cargo Group ID
	cargoGroupID := self.filterCargoGroupID;                        //JIRA-34585
	if cargoGroupID &lt;&gt; null then
		if _workOrderDtl.getCargoGroupID() &lt;&gt; cargoGroupID then
			return false;
		endif;
	endif;
	
	// Operator
	operator := self.filterOperator;                                //JIRA-34585
	if operator &lt;&gt; null then
		if _workOrderDtl.getTIOperator() &lt;&gt; operator then
			return false;
		endif;
	endif;
	
	// Booking ID
	bookingID := self.filterBookingID;                              //JIRA-34585
	if bookingID &lt;&gt; null then
		if _workOrderDtl.getBookingID() &lt;&gt; bookingID then
			return false;
		endif;
	endif;
	
	// Release Request ID
	relReqID := self.filterReleaseReqNum;                           //JIRA-34585
	if relReqID &lt;&gt; null then
		if _workOrderDtl.getReleaseRequestID() &lt;&gt; relReqID then
			return false;
		endif;
	endif;
	
	// Bill of Landing
	bol := self.filterBOL;                                          //JIRA-34585
	if bol &lt;&gt; null then
		if _workOrderDtl.getBOLID() &lt;&gt; bol.number then
			return false;
		endif;
	endif;
	
	// Train
	train := self.filterTrain;                                      //JIRA-34585
	if train &lt;&gt; null then
		create allTrains transient;
		
		_workOrderDtl.getTrains(allTrains);
		
		if not allTrains.includes(train) then
			return false;
		endif;
	endif;
	
	// Debtor
	debtor := self.filterDebtor;                                    //JIRA-34585
	if debtor &lt;&gt; null then
		if _workOrderDtl.getDebtor() &lt;&gt; debtor then
			return false;
		endif;
	endif;
	
	// Contract ID
	contractID := self.filterContractID;                            //JIRA-34585
	if contractID &lt;&gt; null then
		if _workOrderDtl.getContractID() &lt;&gt; contractID then
			return false;
		endif;
	endif;
	
	// Vehicle Visit Record
	vvr := self.filterVehicleVisit;                                 //JIRA-34585
	if vvr &lt;&gt; null then
		create allVVRs transient;
		
		_workOrderDtl.getAllVehicleVisits(allVVRs);
		
		if not allVVRs.includes(vvr) then
			return false;
		endif;
	endif;
	
	// Wagon
	wagon := self.filterWagon;                                      //JIRA-34585
	if wagon &lt;&gt; null then
		create allWagons transient;
		
		_workOrderDtl.getWagons(allWagons);
		
		if not allWagons.includes(wagon) then
			return false;
		endif;
	endif;
	
	// VBS external ref
	vbs := self.filterVBSExtRef;                                    //JIRA-34585
	if vbs &lt;&gt; null then
		_workOrderDtl.getVBSExternalRef().csvToStringArray(sa, Comma);
		if not sa.includes(vbs) then
			return false;
		endif;
	endif;
	
	// Load Permit Number / CEDO / Customs Entry Number
	cen := self.filterCustomsEntryNumber;                           //JIRA-34585
	if cen &lt;&gt; null then
		if _workOrderDtl.getCustomEntryNumber() &lt;&gt; cen then
			return false;
		endif;
	endif;
	
	return true;
epilog
	delete allVVRs;
	delete allWagons;
	delete allTrains;
	delete sa;
end;</source>
        <access>protected</access>
        <Parameter name="_workOrderDtl" type="CM_WorkOrderDtl"/>
        <Parameter name="_isFromWO" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="initAllSelectedStatus" id="865bfd84-6d7f-4da7-b145-9e15c6f3033f">
        <source>initAllSelectedStatus();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
15 December 2009	cnwrd1	Initial creation

*/

vars

	keyValue	: String;
	lastPos		: Integer;
	terminalObj	: CM_Terminal;
	
begin
	lastPos	:=	1;
	self.allSelectedStatus.clear();
	
	
	while true do
		keyValue	:=	self.searchStatusDef.cnEcGetNextTagValueOfName(CMUI_MultiSelectGroupBox.XMLTag_SelectedValue, lastPos);
		
		if keyValue = null then
			break;
		endif;
		
		self.allSelectedStatus.add( keyValue.Integer);
		 
		if lastPos = 0 then
			break;
		endif;
	endwhile;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="initFromUserWindow" id="70eb1233-1ae7-4437-b413-a868a78bf384">
        <updating/>
        <source>initFromUserWindow(_userWindow: CM_UserWindow) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
24/07/2009	cnwmd1	Initial creation
27/06/2018	jlgdap1	TFS 39440 PEL1 Work Order Enquiry Parameters
11/09/2021  navma1  ChangeRequest 51002: MTN - Web Portal Cargo Work Orders
22/11/2021	navmd1	TFS 52430 - Fix 4031 when opening the form
*/

vars
	tmpTypeStr	: String;
	index 	    : Integer;
begin
	inheritMethod(_userWindow);
	
	tmpTypeStr := _userWindow.xmlInfo.cnEcGetTagValueOfName( self.EnqType_WorkOrder.String );
	self.enquiryTypeDef_WorkOrder := tmpTypeStr.trimCharacters(CrLf);

	tmpTypeStr := _userWindow.xmlInfo.cnEcGetTagValueOfName( self.EnqType_Task.String );
	self.enquiryTypeDef_Task := tmpTypeStr.trimCharacters(CrLf);
	
	tmpTypeStr := _userWindow.xmlInfo.cnEcGetTagValueOfName( self.SearchStatusList.String );
	self.searchStatusDef := tmpTypeStr.trimCharacters(CrLf);
	self.initAllSelectedStatus();
	
	// TFS 39440 set saved cargo and voyage work order types
	self.initWorkOrderTypes();
	tmpTypeStr            := _userWindow.xmlInfo.cnEcGetTagValueOfName(self.SearchWOCargoTypes.String);
	tmpTypeStr 		      := tmpTypeStr.trimCharacters(CrLf);
	self.chkCargoWO.value := tmpTypeStr[1:1].asBooleanJMT;
	if tmpTypeStr.length &gt; 1 then
		foreach index in 2 to tmpTypeStr.length do
			self.tblCargoWO.accessCell(index-1,1).text := tmpTypeStr[index:1];
		endforeach;
	endif;
	
	tmpTypeStr := _userWindow.xmlInfo.cnEcGetTagValueOfName(self.SearchWOVoyageTypes.String);
	tmpTypeStr := tmpTypeStr.trimCharacters(CrLf);
	self.chkVoyageWO.value := tmpTypeStr[1:1].asBooleanJMT;
	if tmpTypeStr.length &gt; 1 then
		foreach index in 2 to tmpTypeStr.length do
			self.tblVoyageWO.accessCell(index-1,1).text := tmpTypeStr[index:1];
		endforeach;
	endif;
	
	self.initTransportMode(); //26/11/2024	navkc1 JIRA Story MTN-19092
	tmpTypeStr            := _userWindow.xmlInfo.cnEcGetTagValueOfName(self.SearchTransModes.String);
	tmpTypeStr 		      := tmpTypeStr.trimCharacters(CrLf);
	self.chkTransportMode.value := tmpTypeStr[1:1].asBooleanJMT();
	if tmpTypeStr.length() &gt; 1 then
		foreach index in 2 to tmpTypeStr.length() do
			self.tblTransportMode.accessCell(index-1, 1).text := tmpTypeStr[index:1];
		endforeach;
	endif;
	
	/* 10.09.2021 navma1 #51002
	if self.myTerminal.getDefaultVoyageProcess = null or self.myTerminal.getDefaultVoyageProcess.isDefaultProcessJMT then
		self.doSelectUnselectWOTypes(false, self.tblVoyageWO);
	endif;
	*/
epilog

end;</source>
        <Parameter name="_userWindow" type="CM_UserWindow"/>
    </JadeMethod>
    <JadeMethod name="initQueryFrame" id="7dd7f277-c6ea-4039-a129-23f790180ce9">
        <updating/>
        <source>initQueryFrame() updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
28/07/2009	cnwmd1	Initial creation
