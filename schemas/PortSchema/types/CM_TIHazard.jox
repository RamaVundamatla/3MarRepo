    <JadeMethod name="isSameAs" id="97341b55-1786-4e5d-ba6a-f907d53b65d4">
        <source>isSameAs(_hazard: CM_TIHazard): Boolean;
//----------------------------------------------------------------
//	Created:	14 February 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	undgCode	: String;
begin
	
	if not inheritMethod(_hazard) then
		return false;
	endif;

	foreach undgCode in self.allUNDGCodes do
		if _hazard.allUNDGCodes.includes(undgCode) then
			continue;
		endif;
		return false;
	endforeach;
	
	foreach undgCode in _hazard.allUNDGCodes do
		if self.allUNDGCodes.includes(undgCode) then
			continue;
		endif;
		return false;
	endforeach;
	
	if limitedQuantity &lt;&gt; _hazard.limitedQuantity then
		return false;
	endif;
	return true;
	
end;</source>
        <Parameter name="_hazard" type="CM_TIHazard"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
