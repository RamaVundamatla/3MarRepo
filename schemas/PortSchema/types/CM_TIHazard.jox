    <JadeMethod name="addUNCode" id="ad9fed25-7105-4a42-ba0c-3510a8443f86">
        <source>addUNCode(_unCode: String);
//----------------------------------------------------------------
//	Created:	06 April 2004	by Jason Chapman  (cnwjc2)
//
//	Add a single UN Number to an existing Hazard
//----------------------------------------------------------------
vars
	newCode	: String;
	strUN	: String;
begin
	newCode := _unCode.trimBlanks;
	
	if newCode &lt;&gt; null then
		foreach strUN in self.allUNDGCodes do	//check for duplicates
			if strUN = newCode then
				return;
			endif;
		endforeach;
		self.allUNDGCodes.add(newCode);
	endif; 

end;</source>
        <Parameter name="_unCode" type="String"/>
    </JadeMethod>
    <JadeMethod name="codesToIgnore" id="3a671cea-1a51-4b97-a97e-e9462b90482d">
        <source>codesToIgnore() : Boolean;

/*

Purpose:		The following codes can be used to denote item is hazardous but are not hazardous codes.
				Y, N, Yes, No, True, False, 0, 1

Date			Who		Reason
08/07/2013		cnwmh5	Initial creation

*/

vars

	ignoreCode				: Boolean;

begin

	ignoreCode := false;
	
	if self.code.toUpper() = "Y" or self.code.toUpper() = "N" or self.code.toUpper() = "YES" or 
			self.code.toUpper() = "NO" or self.code.toUpper() = "TRUE" or 
			self.code.toUpper() = "FALSE" or self.code.toUpper() = "1" or self.code.toUpper() = "0" then
		ignoreCode := true;
	endif;
	
	return ignoreCode;

epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="ac88f9bb-5833-4f4d-9135-6a2d4f345aec">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 14/11/2016	cnwdap1		Initial creation TFS 2842 Hazardous Details Enhancements
//2/8/24  		navsaa30	Bug 65355: MTN - Flashpoint Temperature Field behaviour
//
vars
	hazTemp : CM_HazTempRange;

begin
	if _attrName = ETRow_HazardClass then
		return self.code;
	elseif _attrName = ETRow_HazardCode then
		return self.getUndgCodesAsString(true);	//25 Sep 2019	NDL	TFS 46633 - Leave as truncated version, but use new method
	elseif _attrName = ETRow_Limited then
		return self.limitedQuantity.getYes;
	elseif _attrName = ETRow_PackingGroup then
		return self.packingGroup;
	elseif _attrName = ETRow_Flashpoint then
		if self.flashpointTemperature &lt;&gt; NULL_TEMPERATURE then
			/*hazTemp := app.myRoot.allHazTempRanges.getAtKeyLeq(self.flashpointTemperature);
			if hazTemp &lt;&gt; null and hazTemp.upper &gt;= self.flashpointTemperature and hazTemp.lower &lt;= self.flashpointTemperature then			//2/8/24   navsaa30 #65355
				return self.flashpointTemperature.asStringJMT &amp; Space &amp; Left_Round_Bracket &amp; hazTemp.getDisplayDetails(false) &amp; Right_Round_Bracket;
			else
				hazTemp := app.myRoot.allHazTempRanges.getAtKeyGeq(self.flashpointTemperature);
				if hazTemp &lt;&gt; null and hazTemp.upper &gt;= self.flashpointTemperature and hazTemp.lower &lt;= self.flashpointTemperature then			//2/8/24   navsaa30 #65355
					return self.flashpointTemperature.asStringJMT &amp; Space &amp; Left_Round_Bracket &amp; hazTemp.getDisplayDetails(false) &amp; Right_Round_Bracket;
				//else
					//return self.flashpointTemperature.asStringJMT;						//12/8/24   navsaa30 #65355
				endif;
			endif;
		else
			return null;
		endif;*/
			foreach hazTemp in app.myRoot.allHazTempRanges do						//12/8/24   navsaa30 #65355
			if  hazTemp.lower &lt;= self.flashpointTemperature  and hazTemp.upper &gt;= self.flashpointTemperature then
				return self.flashpointTemperature.asStringJMT &amp; Space &amp; Left_Round_Bracket &amp; hazTemp.getDisplayDetails(false) &amp; Right_Round_Bracket;
			endif;
			endforeach;
		else
			return null;
		endif;
	elseif _attrName = ETRow_IsMarinePollutant then
		return app.isMarinePollutantEnumToString(self.isMarinePollutant);
	elseif _attrName = ETRow_AcidsBases then
		return self.acidsBases;
	endif;
	
	return inheritMethod(_attrName, _short);
epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForListTable" id="0aa37e4b-08d6-4efc-957d-e93a61bf0c94">
        <source>getDisplayStringForListTable(): String;
//----------------------------------------------------------------
//	Created:	31 March 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
// Changed On	By			Reason
// ----------	--------	--------------------------------------
// 08/07/2015	cnwdap1		PAR #36421 Hazardous Materials Handling - add Packing Group column
//25 Sep 2019	NDL	TFS 46633 - Leave as truncated version, but use new method
vars

begin
	//default display strign for HazardListTable
	//return '0' &amp; Tab &amp; self.code &amp; Tab &amp; self.description &amp; Tab &amp; undgCodes &amp; Tab &amp; self.limitedQuantity.cnEcGetTableCheckBoxValue;							// PAR #36421
	return '0' &amp; Tab &amp; self.code &amp; Tab &amp; self.description &amp; Tab &amp; getUndgCodesAsString(true) &amp; Tab &amp; self.limitedQuantity.cnEcGetTableCheckBoxValue &amp; Tab &amp; self.packingGroup;	// PAR #36421
	
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getFirstUNDG" id="251b0b22-5ebc-4e93-bcc6-20e4f636a093">
        <source>getFirstUNDG() : CM_UNDangerousGoods ;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 April 2013	cnwer1	Initial creation CCMS DPH 2280

*/

vars
	undgString : String;
	undg 		: CM_UNDangerousGoods;
begin

	foreach undgString in self.allUNDGCodes do
		undg:= app.myRoot.allUNDangerousGoodsCodes[undgString];
		if undg &lt;&gt; null then
			return undg;
		endif;
	endforeach;
	
	return null;
epilog

end;</source>
        <ReturnType type="CM_UNDangerousGoods"/>
    </JadeMethod>
    <JadeMethod name="getSelectionString" id="e4c222ec-69b5-4f92-a464-b66a4b3a9e52">
        <source>getSelectionString() : String;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 10/06/2015	cnwdap1		Initial creation PAR #36421 Hazardous Materials Handling
//
vars
	str : String;
	undg : CM_UNDangerousGoods;
begin
	if self.packingGroup &lt;&gt; null then
		str := self.packingGroup &amp; Space;
	endif;
	
	str := str &amp; self.code;
	
	//epr TFS 2269 12/7/16
	undg:= self.getFirstUNDG();
	if undg &lt;&gt; null then
		str := str &amp; Space &amp; undg.description;
	endif;
	return str;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getTableDisplay" id="1d9d60a7-5f18-4502-89ca-55deb473dfbf">
        <source>getTableDisplay(_altCode: Boolean; _showUNDGCodes : Boolean ): String;
//----------------------------------------------------------------
//	Created:	01 April 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
//	Display for one TIHazard in an Entry Table
// Changed On	By			Reason
// ----------	--------	--------------------------------------
// 08/07/2015	cnwdap1		PAR #36421 Hazardous Materials Handling
// 09/11/2016	cnwdap1		TFS 2842 Hazardous Details Enhancements
vars
	unCodes	: String;
	result : String;
	packing : String;
begin
	
	if not self.allUNDGCodes.isEmpty then
		unCodes := ' (' &amp; self.getUndgCodesAsString(false) &amp; ')';	//25 Sep 2019	NDL	TFS 46633 - use full string not truncated version
	endif;
	
	if self.packingGroup &lt;&gt; null then											// PAR #36421
		packing := Space &amp; self.packingGroup;									// PAR #36421
	endif;																		// PAR #36421
	
	if self.limitedQuantity then
		//return inheritMethod(_altCode, _showUNDGCodes) &amp; unCodes &amp; " L";		// PAR #36421
		result := unCodes &amp; " L" &amp; packing;										// PAR #36421
	else
		//return inheritMethod(_altCode, _showUNDGCodes) &amp; unCodes;				// PAR #36421
		result := unCodes &amp; packing;											// PAR #36421
	endif;
	
	if self.flashpointTemperature &lt;&gt; NULL_TEMPERATURE then						// TFS 2842
		result := result &amp; Space &amp; self.flashpointTemperature.asStringJMT;		// TFS 2842
	endif;																		// TFS 2842
	if self.isMarinePollutant = MarinePollutant_Yes then						// TFS 2842
		result := result &amp; Space &amp; "MP";										// TFS 2842
	elseif self.isMarinePollutant = MarinePollutant_No then						// TFS 2842
		result := result &amp; Space &amp; "N-MP";										// TFS 2842
	endif;																		// TFS 2842
	if self.acidsBases &lt;&gt; null then												// TFS 2842
		result := result &amp; Space &amp; self.acidsBases;								// TFS 2842
	endif;																		// TFS 2842
	
	return inheritMethod(_altCode, _showUNDGCodes) &amp; result;					// PAR #36421
	
end;</source>
        <Parameter name="_altCode" type="Boolean"/>
        <Parameter name="_showUNDGCodes" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
