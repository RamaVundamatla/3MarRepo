    <JadeMethod name="mnuAudits_click" id="d6e220d1-ed3c-48c9-8403-83e1f39a1903">
        <controlMethod name="MenuItem::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>mnuAudits_click(menuItem: MenuItem input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 January 2021	jlgndl1	Initial creation	TFS 50152

*/

vars

	form : CM_AuditViewForm;

begin

	if self.mySelectedAuditConfig &lt;&gt; null then
	
		if self.myAssistant = null then
			create self.myAssistant transient;
		endif;
		
		form := app.loadForm(CM_AuditViewForm, self.myAssistant.class, false, false, false, null, null).CM_AuditViewForm;
		
		form.myAudittedObject := self.mySelectedAuditConfig;
		
		form.show();
		
	endif;
	

epilog

end;</source>
        <Parameter name="menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="mnuInspect_click" id="3fe98023-33ff-4744-8b0a-8f5dfeb00a80">
