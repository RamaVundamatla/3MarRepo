<GUIClass name="Table">
    <JadeMethod name="asString" id="255f7c46-7a38-4c3e-9f9f-e29ecd49766f">
        <updating/>
        <source>asString(startRow : Integer; colGap : Integer; colWidths : IntegerArray input) : String updating;

vars
	r, c, n, selfRows, selfCols, len, gapChars : Integer;
	ia : IntegerArray;
	s : String;
		
begin
	if colWidths &lt;&gt; null then
		colWidths.clear;
	endif;

	selfRows := self.rows;
	selfCols := self.columns;

	if selfRows &lt; 1 or selfCols &lt; 1 or startRow &lt; 1 or startRow &gt; selfRows then
		return null;
	endif;

	if colGap &lt; 1 then
		gapChars := 0;
	else
		gapChars := colGap;
	endif;
	
	create ia transient;
	// initialize the array with a zero element per column
	ia[selfCols] := 0;

	// first pass: work out the maximum width of each column
	foreach r in startRow to selfRows do
		foreach c in 1 to selfCols do
			s := self.accessCell(r, c).text.trimBlanks;
			len := s.length;
			if len &gt; ia[c] then
				ia[c] := len;
			endif;
		endforeach;
	endforeach;

	// second pass: build the return string
	s := null;
	foreach r in startRow to selfRows do
		if s &lt;&gt; null then
			s := s &amp; CrLf;
		endif;
		foreach c in 1 to selfCols do
			if c &lt; selfCols then
				n := ia[c] + gapChars;
				s := s &amp; self.accessCell(r, c).text.trimBlanks.padBlanks(n);
			else
				s := s &amp; self.accessCell(r, c).text.trimBlanks;
			endif;
		endforeach;
	endforeach;

	if colWidths &lt;&gt; null then
		ia.copy(colWidths);
	endif;	

	return s;
	
epilog
	delete ia;
end;</source>
        <Parameter name="startRow" type="Integer"/>
        <Parameter name="colGap" type="Integer"/>
        <Parameter name="colWidths" type="IntegerArray" usage="input"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="asStringTabDelimited" id="cbc30894-85ef-447f-a5c6-33289e479950">
        <updating/>
        <source>asStringTabDelimited(startRow : Integer) : String updating;

vars
	r, c, selfRows, selfCols : Integer;
	s : String;
		
begin
	selfRows := self.rows;
	selfCols := self.columns;

	if selfRows &lt; 1 or selfCols &lt; 1 or startRow &lt; 1 or startRow &gt; selfRows then
		return null;
	endif;

	s := null;
	
	foreach r in startRow to selfRows do
		if s &lt;&gt; null then
			s := s &amp; CrLf;
		endif;

		foreach c in 1 to selfCols do
			if c &lt; selfCols then
				s := s &amp; self.accessCell(r, c).text.trimBlanks &amp; Tab;
			else
				s := s &amp; self.accessCell(r, c).text.trimBlanks;
			endif;
		endforeach;
	endforeach;

	return s;
end;</source>
        <Parameter name="startRow" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
</GUIClass>
