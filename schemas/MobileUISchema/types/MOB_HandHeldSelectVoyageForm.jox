    <JadeMethod name="handleF2Key" id="7c3be05c-ee3b-45cf-8bd4-7687ae1b95d7">
        <updating/>
        <source>handleF2Key() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
22 November 2010	cnwndl1	Initial creation	Par 25074

*/

vars

	vehicleConfig : CM_RTVehicleConfig;
	form : MOB_HandHeldForm;

begin

	vehicleConfig := self.myMobileGenericAgent.myTerminal.getRTVehicleConfigForObject(null);

	if self.myMobileGenericAgent.myScreenConfig = vehicleConfig.myDayScreenConfig then
		//changing from day to night
		self.myMobileGenericAgent.setMyScreenConfig( vehicleConfig.myNightScreenConfig );
		
	else
		//changing from night to day or setting up from null
		self.myMobileGenericAgent.setMyScreenConfig( vehicleConfig.myDayScreenConfig );
		
	endif;
	
	form := self;
	self.myHandHeldCheckerAgent.doApplyConfigColours( form );
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="loadBays" id="849e7583-6b41-4018-a38f-622ea248ef63">
        <source>loadBays(voyage : CM_Voyage; job : CM_VoyageJob; selectedBay : CM_BayVoyage);
// 
vars
	bays : CM_BayByOrdinalDict;
	bay : CM_Bay;
begin
	cmbBays.clear();
	
	create bays transient;
	if job &lt;&gt; null then
		self.getDataAgent().getIncompleteVoyageJobBays(job, bays);
	else
		self.getDataAgent().getAllVoyageBays(voyage, bays);
	endif;
	foreach bay in bays discreteLock do
		cmbBays.itemObject[cmbBays.addItem(bay.id)] := bay;
	endforeach;
	if selectedBay &lt;&gt; null then
		cmbBays.listIndex := cmbBays.findObject(selectedBay);
	elseif cmbBays.listCount &gt; 0 then
		cmbBays.listIndex := 1;
	endif;
	
	self.autoSelectDeck(self.cmbBays.listObject.CM_BayVoyage);

epilog	
	delete bays;
end;
</source>
        <Parameter name="voyage" type="CM_Voyage"/>
        <Parameter name="job" type="CM_VoyageJob"/>
        <Parameter name="selectedBay" type="CM_BayVoyage"/>
    </JadeMethod>
    <JadeMethod name="loadDeck" id="fe71dc42-922c-4be0-a2b9-d18a40b2c5dd">
        <source>loadDeck(selectedDeck : Integer);
begin
	optUnderDeck.value := false;
	optOnDeck.value := false;
	if selectedDeck = DeckUnderDeck then
		optUnderDeck.value := true;
	else
		optOnDeck.value := true;
	endif;
			
end;
</source>
        <Parameter name="selectedDeck" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="loadJobs" id="5e9f644c-bcd8-44be-ba19-2bec2d0471e7">
        <source>loadJobs(voyage : CM_Voyage ; selectedJob : CM_VoyageJob ; selectJob : Boolean);
// Load the incomplete jobs for this voyage into the job selection combobox
vars
	jobs : CM_VoyageJobArray;
	job : CM_VoyageJob;
begin
	cmbJobs.clear();
	if voyage = null then
		return;
	endif;

	cmbJobs.addItem("");	// add empty item so they can select no job
	cmbJobs.listIndex := 1;
	create jobs transient;
	self.getDataAgent.getIncompleteVoyageJobs(voyage, jobs);
	foreach job in jobs discreteLock do
		if job.hasBulkReleaseItem() then
			cmbJobs.itemObject[cmbJobs.addItem(job.id)] := job;
		endif;
	endforeach;
	if selectJob then
		if selectedJob &lt;&gt; null then
			cmbJobs.listIndex := cmbJobs.findObject(selectedJob);
		elseif cmbJobs.listCount &gt; 1 then
			cmbJobs.listIndex := 2;
			self.getSessionAgent.myJob := cmbJobs.itemObject[2].CM_VoyageJob;	//22 Nov 2010	NDL Par 25074
		endif;
	endif;
	
epilog	
	delete jobs;
end;
</source>
        <Parameter name="voyage" type="CM_Voyage"/>
        <Parameter name="selectedJob" type="CM_VoyageJob"/>
        <Parameter name="selectJob" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="loadVoyages" id="40ed68e8-ed04-43cb-be20-66dd2101cb69">
        <source>loadVoyages(selectedVoyage : CM_Voyage);
// Load the voyages currently being worked on into the voyage selection combo box
vars
	voyages : CM_VoyageSet;
	voyage : CM_Voyage;
begin
	create voyages transient;
	self.getDataAgent.getVoyagesCurrentlyBeingWorked(voyages);
	cmbVoyages.clear();
	foreach voyage in voyages discreteLock do
	
		if self.myMobileGenericAgent.myTerminal.getConfig(VesselNameOnVoyageCombo).Boolean then //cnwrd1 nfs 31095
			cmbVoyages.itemObject[cmbVoyages.addItem(voyage.code &amp; Tab &amp; voyage.vesselName )] := voyage;
		else
			cmbVoyages.itemObject[cmbVoyages.addItem(voyage.code)] := voyage;
		endif;
	endforeach;
	if selectedVoyage &lt;&gt; null then
		cmbVoyages.listIndex := cmbVoyages.findObject(selectedVoyage);
	elseif cmbVoyages.listCount &gt; 0 then
		cmbVoyages.listIndex := 1;
		self.getSessionAgent.myVoyage := cmbVoyages.itemObject[1].CM_Voyage;
	endif;
		
epilog	
	delete voyages;
end;
</source>
        <Parameter name="selectedVoyage" type="CM_Voyage"/>
    </JadeMethod>
