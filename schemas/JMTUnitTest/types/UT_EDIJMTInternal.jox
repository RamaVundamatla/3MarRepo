';
	ediFileObj := self.ediLoadFileName(ediText, EDIFileType_Unknown, USER_DEF_NAME, USER_DEF_NAME&amp;method.name);

	self.assertNotNull(ediFileObj);
	self.assertEqualMsg(true, passportObj.allErrors.isEmpty(), passportObj.getAllErrorsWarningsAsString());	// cnwrl1 25/08/2010 PAR 25559
	self.assertNotNull(ediFileObj.ediData);		// cnwrl1 25/08/2010 PAR 25559
	self.ediVerify(ediFileObj);
	errorMsg := "Verify Failed" &amp; CrLf &amp; passportObj.getErrorsAsString();
	// Status 3 is verify status and 14 is verified with warnings.
//	self.assertIsOneOf(	ediFileObj.fileStatus,
//						errorMsg,
//						CM_EDIFile.EDI_STATUS_VERIFIED,
//						CM_EDIFile.EDI_STATUS_VERIFIED_WARNINGS);
	self.assertEqualMsg(ediFileObj.fileStatus, CM_EDIFile.EDI_STATUS_VERIFIED, errorMsg);
	ediDataObj := ediFileObj.ediData;
	self.ediDBLoad(ediFileObj);
//	self.assertIsOneOf(	ediFileObj.fileStatus,
//						"Load Failed",
//						CM_EDIFile.EDI_STATUS_DBLOADED,
//						CM_EDIFile.EDI_STATUS_DBLOADED_PARTIAL);
	errorMsg := "DB Load Failed" &amp; CrLf &amp; passportObj.getErrorsAsString();
	self.assertEqualMsg(ediFileObj.fileStatus, CM_EDIFile.EDI_STATUS_DBLOADED, errorMsg);
	
	if ediFileObj.fileStatus = CM_EDIFile.EDI_STATUS_DBLOADED_PARTIAL then
		write "EDI message not fully loaded - needs a re-run.";
	endif;
	self.assertEqualMsg(ediDataObj.allEDITrackedItems.size, 54, "incorrect number of EDI trackedItems");
	voyage := self.getVoyage(VoyageName);
	self.assertNotNull(voyage);
	self.assertEqualMsg(voyage.allBOLInByTypeStatusNumDT.size, 4, "");
	self.assertEqualMsg(voyage.allOnshipTIsByIdCargoType.size, 42, "");
	bol := self.getBOL("BOLVOYSHIPGENXX1", 5003, "MSK");
	self.assertNotNull(bol);
	self.assertEqualMsg(bol.allBOLDtls.size, 1, "");
	self.assertEqualMsg(bol.allTrackedItems.size, 0, "");
	bol := self.getBOL("BOLVOYSHIPGENXX12345678901234567890123890123"[1:35], 5003, "MSK");		// MTN-14781
	self.assertNotNull(bol);
	self.assertEqualMsg(bol.allBOLDtls.size, 3, "");
	self.assertEqualMsg(bol.allTrackedItems.size, 18, "");
	bol := self.getBOL("BOLVOYSHIPGENXX2", 5003, "MSK");
	self.assertNotNull(bol);
	self.assertEqualMsg(bol.allBOLDtls.size, 1, "");
	self.assertEqualMsg(bol.allTrackedItems.size, 8, "");
	bol := self.getBOL("BOLVOYSHIPGENXX3", 5003, "MSK");
	self.assertNotNull(bol);
	self.assertEqualMsg(bol.allBOLDtls.size, 1, "");
	self.assertEqualMsg(bol.allTrackedItems.size, 16, "");
	
	//09 Jun 2017	NDL	TFS 4331
	ti := voyage.allOnshipTIsByIdCargoType.getAtKey("ZGHJ8063793",1);
	self.assertNotNull(ti);
	self.assertTrueMsg( ti.clientRef = "12345", "clientRef should be '12345'");
	ti := voyage.allOnshipTIsByIdCargoType.getAtKey("XGHJ8063770",1);
	self.assertNotNull(ti);
	self.assertEqualMsg(ti.getSealNumShipper(), "SHSEAL1,SHSEAL2", "Incorrect Terminal Operator Seal");
	self.assertEqualMsg(ti.getPortOfOrigin(), "AUBNE", "Incorrect Port Of Origin");
	self.assertEqualMsg(ti.getContainerNumberText(), "Container Number Text Stuff", "Incorrect Container Number Text");
end;
</source>
    </JadeMethod>
    <JadeMethod name="tShipManifestAction" id="13b5348c-e7de-4874-85af-a79653204a12">
        <source>tShipManifestAction();
//
//14 August 2017	jlgrs1	Initial creation
//
// 21 Jun 2018	jlgrs1	TFS 39298 (TFS 36430) Penn Ship Manifest too many locks
//04 Sep 2023	jlirs1	TFS 59148 (57770) IFCSUM Port of Origin BOP
constants
	USER_DEF_NAME : String = "JMTInternalShipManifest";
	BOL_ID : String = "BOL_ID1";
	CONTAINERID : String = "SARG1234543";
	VOYAGECODE = 'VOY27418';
	VESSELNAME = 'SHIP27418';
	OPERATORCODE = 'MSK';
vars
	ediFileObj : CM_EDIFile;
	ediDataObj : CM_EDIData;
	vessel : CM_Vessel;
	voyage : CM_Voyage;
	operator : CM_Operator;
	container : CM_Container;
	passportObj : CM_Passport;
	ediText : String;
	errorMsg : String;
begin
	self.setTerminalConfig(EdiShipManAllowPartial, true);
	self.setTerminalConfig(ProcIFCSUMPortAuthority, false);	//30.jan25 navsp1 JIRA-33888 UT fixes
//return;
	passportObj := app.myPassport;
	operator := self.getOperator(OPERATORCODE);
	self.deleteVoyage(VOYAGECODE);
	voyage := self.getVoyage(VOYAGECODE);
	self.assertIsDeleted(voyage);
	self.deleteVessel(VESSELNAME);
	vessel := self.getVessel(VESSELNAME);
	self.assertIsDeleted(vessel);
	self.deleteContainer(CONTAINERID);
	container := self.getTrackedItem(CONTAINERID).CM_Container;
	self.assertIsDeleted(container);
	vessel := self.addVesselCellular(VESSELNAME,
										operator);
	self.assertNotNullMsg(vessel, 'Add vessel failed');
	
	voyage := self.addVoyageWithContainerStructur(VOYAGECODE,
													VESSELNAME,
													OPERATORCODE,
													self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString);
	self.assertNotNullMsg(voyage, 'Add voyage failed');
	ediText :=
'&lt;?xml version="1.0"?&gt;
&lt;JMTInternalShipManifest xmlns:xsi="http://www.jademasterterminallogistics.com/JMTInternal" xsi:noNamespaceSchemaLocation="JMTInternalShipManifest.xsd"&gt;
	&lt;AllBOLHeader&gt;
		&lt;BOLHeader&gt;
			&lt;bolType&gt;5003&lt;/bolType&gt;
			&lt;numItems/&gt;
			&lt;carrierCode/&gt;
			&lt;description/&gt;
			&lt;destinationPort/&gt;
			&lt;dischargePort/&gt;
			&lt;fullOrMT/&gt;
			&lt;id&gt;'&amp;BOL_ID&amp;'&lt;/id&gt;
			&lt;loadPort/&gt;
			&lt;messageMode&gt;A&lt;/messageMode&gt;
			&lt;notifyParty/&gt;
			&lt;operatorCode&gt;MSK&lt;/operatorCode&gt;
			&lt;remarks&gt;&lt;/remarks&gt;
			&lt;subTerminalCode/&gt;
			&lt;transportMode/&gt;
			&lt;voyageCode/&gt;
			&lt;clientRef1/&gt;
			&lt;clientRef2/&gt;
			&lt;vehicle/&gt;
			&lt;AllBOLDetails&gt;
				&lt;BOLDetails&gt;
					&lt;height/&gt;
					&lt;length/&gt;
					&lt;volume/&gt;
					&lt;weight/&gt;
					&lt;width/&gt;
					&lt;quantity/&gt;
					&lt;cargoTypeDescr/&gt;
					&lt;colour/&gt;
					&lt;commodity/&gt;
					&lt;consignee/&gt;
					&lt;consignor/&gt;
					&lt;description/&gt;
					&lt;dtlDescription/&gt;
					&lt;fullOrMT/&gt;
					&lt;id/&gt;
					&lt;mark/&gt;
					&lt;messageMode&gt;A&lt;/messageMode&gt;
					&lt;remarks/&gt;
				&lt;/BOLDetails&gt;
			&lt;/AllBOLDetails&gt;
			&lt;AllCargoOnShip&gt;
				&lt;CargoOnShip&gt;
	  &lt;portOfOrigin&gt;AUBNE&lt;/portOfOrigin&gt;
					&lt;directDelivery/&gt;
					&lt;hasRadio/&gt;
					&lt;isNew/&gt;
					&lt;isWeightCertified/&gt;
					&lt;preSlung/&gt;
					&lt;selfPropelled/&gt;
					&lt;wet/&gt;
					&lt;certificate1Expiry/&gt;
					&lt;certificate2Expiry/&gt;
					&lt;docsCleared/&gt;
					&lt;docsReceived/&gt;
					&lt;docsReturned/&gt;
					&lt;docsSent/&gt;
					&lt;expiryDate/&gt;
					&lt;cargoWeight/&gt;
					&lt;height/&gt;
					&lt;length/&gt;
					&lt;overHeight/&gt;
					&lt;overLengthBack/&gt;
					&lt;overLengthFront/&gt;
					&lt;overWidthLeft/&gt;
					&lt;overWidthRight/&gt;
					&lt;tareWeight/&gt;
					&lt;vent/&gt;
					&lt;volume/&gt;
					&lt;weight/&gt;
					&lt;width/&gt;
					&lt;availabilityGrade/&gt;
					&lt;carbonDioxide/&gt;
					&lt;contentsStatus/&gt;
					&lt;doors/&gt;
					&lt;humidity/&gt;
					&lt;oxygen/&gt;
					&lt;parentCargoTypeCode/&gt;
					&lt;quantity/&gt;
					&lt;receiptTransportMode/&gt;
					&lt;site/&gt;
					&lt;totalQuantity/&gt;
					&lt;year/&gt;
					&lt;temperature/&gt;
					&lt;alternativeId/&gt;
					&lt;bol/&gt;
					&lt;bookingRef/&gt;
					&lt;breakBulkType/&gt;
					&lt;carType/&gt;
					&lt;cargoGroupId/&gt;
					&lt;cargoTypeDescr&gt;ISO Container&lt;/cargoTypeDescr&gt;
					&lt;carrierCode/&gt;
					&lt;certificate1/&gt;
					&lt;certificate2/&gt;
					&lt;chassisNo/&gt;
					&lt;colour/&gt;
					&lt;commodity/&gt;
					&lt;commodityDescription/&gt;
					&lt;companyCode/&gt;
					&lt;consignee/&gt;
					&lt;consignor/&gt;
					&lt;customsAgent/&gt;
					&lt;customsReference/&gt;
					&lt;description/&gt;
					&lt;destinationPort&gt;SOMEWHERE&lt;/destinationPort&gt;
					&lt;dischargePort&gt;HKHKG&lt;/dischargePort&gt;
					&lt;engineNo/&gt;
					&lt;freightForwarder/&gt;
					&lt;fullOrMT/&gt;
					&lt;generatorID/&gt;
					&lt;generatorType/&gt;
					&lt;heatTreated/&gt;
					&lt;heightString/&gt;
					&lt;id&gt;'&amp;CONTAINERID&amp;'&lt;/id&gt;
					&lt;imexStatus/&gt;
					&lt;invoiceNumber/&gt;
					&lt;isoType&gt;2210&lt;/isoType&gt;
					&lt;isoTypeGroup/&gt;
					&lt;lengthString/&gt;
					&lt;loadPort/&gt;
					&lt;locationId&gt;'&amp;VOYAGECODE&amp;' 010682&lt;/locationId&gt;
					&lt;make/&gt;
					&lt;mark/&gt;
					&lt;markNumber/&gt;
					&lt;messageMode/&gt;
					&lt;model/&gt;
			&lt;operatorCode&gt;MSK&lt;/operatorCode&gt;
					&lt;orderNumber/&gt;
					&lt;palletType/&gt;
					&lt;parentCargoID/&gt;
					&lt;parentCargoType/&gt;
					&lt;product/&gt;
					&lt;purchaseOrder/&gt;
					&lt;registration/&gt;
					&lt;remarks/&gt;
					&lt;sealCustoms/&gt;
					&lt;sealNum/&gt;
					&lt;sealNumberVent/&gt;
					&lt;sealShipper/&gt;
					&lt;sealTerminalOperator/&gt;
					&lt;sealUnknown/&gt;
					&lt;serviceOrder/&gt;
					&lt;storeOnPallet/&gt;
					&lt;trackingNumber1/&gt;
					&lt;trackingNumber2/&gt;
					&lt;trailerType/&gt;
					&lt;vgmAuthSignature/&gt;
					&lt;vgmCommsType/&gt;
					&lt;vgmDocumentDetails/&gt;
					&lt;vgmEDITransmission/&gt;
					&lt;vgmElectronicMail/&gt;
					&lt;vgmMail/&gt;
					&lt;vgmPhone/&gt;
					&lt;vgmTelefax/&gt;
					&lt;vgmTelephone/&gt;
					&lt;vin/&gt;
					&lt;voyageCode&gt;'&amp;VOYAGECODE&amp;'&lt;/voyageCode&gt;
					&lt;weightCertifiedName/&gt;
					&lt;weightCertifiedReference/&gt;
					&lt;widthString/&gt;
					&lt;receiveDate/&gt;
					&lt;vgmDeterminationDT/&gt;
					&lt;vgmDocsIssuedDT/&gt;
					&lt;salesOrderNbr/&gt;
					&lt;AllToDoTask&gt;
						&lt;ToDoTask&gt;
							&lt;isComplete&gt;false&lt;/isComplete&gt;
							&lt;cargoTypeDescr&gt;ISO Container&lt;/cargoTypeDescr&gt;
							&lt;description/&gt;
							&lt;fullOrMT/&gt;
							&lt;id&gt;'&amp;BOL_ID&amp;'&lt;/id&gt;
							&lt;messageMode&gt;A&lt;/messageMode&gt;
							&lt;taskCode&gt;MISCELL&lt;/taskCode&gt;
							&lt;toDoRemarks/&gt;
						&lt;/ToDoTask&gt;
					&lt;/AllToDoTask&gt;
					&lt;AllHazardousDetails&gt;
						&lt;HazardousDetails&gt;
							&lt;limitedQuantity/&gt;
							&lt;isMarinePollutant/&gt;
							&lt;flashpointTemperature/&gt;
							&lt;acidsBases/&gt;
							&lt;bookingId/&gt;
							&lt;bookingItemSeq/&gt;
							&lt;cargoSubType/&gt;
							&lt;cargoTypeDescr&gt;ISO Container&lt;/cargoTypeDescr&gt;
							&lt;code&gt;7&lt;/code&gt;
							&lt;description/&gt;
							&lt;fullOrMT/&gt;
							&lt;id&gt;'&amp;CONTAINERID&amp;'&lt;/id&gt;
							&lt;messageMode&gt;A&lt;/messageMode&gt;
							&lt;packingGroup/&gt;
							&lt;releaseRequestNumber/&gt;
							&lt;requestDetailID/&gt;
							&lt;undgCodes&gt;3166&lt;/undgCodes&gt;
							&lt;allUNDGCodes/&gt;
						&lt;/HazardousDetails&gt;
					&lt;/AllHazardousDetails&gt;
					&lt;AllSealDetails&gt;
						&lt;SealDetails&gt;
							&lt;id&gt;'&amp;CONTAINERID&amp;'&lt;/id&gt;
							&lt;messageMode&gt;A&lt;/messageMode&gt;
							&lt;sealEDINum&gt;SEAL01&lt;/sealEDINum&gt;
							&lt;sealEDIType&gt;SHIP&lt;/sealEDIType&gt;
						&lt;/SealDetails&gt;
					&lt;/AllSealDetails&gt;
				&lt;/CargoOnShip&gt;
			&lt;/AllCargoOnShip&gt;
		&lt;/BOLHeader&gt;
	&lt;/AllBOLHeader&gt;
	&lt;AllLayout&gt;
		&lt;Layout&gt;
		&lt;/Layout&gt;
	&lt;/AllLayout&gt;
	&lt;AllCargoOnShip&gt;
		&lt;CargoOnShip&gt;
		&lt;/CargoOnShip&gt;
	&lt;/AllCargoOnShip&gt;
	&lt;AllToDoTask&gt;
		&lt;ToDoTask&gt;
		&lt;/ToDoTask&gt;
	&lt;/AllToDoTask&gt;
 &lt;/JMTInternalShipManifest&gt;';

	ediFileObj := self.ediLoadFileName(ediText, EDIFileType_Unknown, USER_DEF_NAME, USER_DEF_NAME&amp;method.name);

	self.assertNotNull(ediFileObj);
	self.assertEqualMsg(true, passportObj.allErrors.isEmpty(), passportObj.getAllErrorsWarningsAsString());	// cnwrl1 25/08/2010 PAR 25559
	self.assertNotNull(ediFileObj.ediData);		// cnwrl1 25/08/2010 PAR 25559
	self.ediVerify(ediFileObj);
	errorMsg := "Verify Failed" &amp; CrLf &amp; passportObj.getErrorsAsString();
	// Status 3 is verify status and 14 is verified with warnings.
	self.assertIsOneOf(	ediFileObj.fileStatus,
						errorMsg,
						CM_EDIFile.EDI_STATUS_VERIFIED,
						CM_EDIFile.EDI_STATUS_VERIFIED_WARNINGS);
//	self.assertEqualMsg(ediFileObj.fileStatus, CM_EDIFile.EDI_STATUS_VERIFIED, errorMsg);
	ediDataObj := ediFileObj.ediData;
	self.ediDBLoad(ediFileObj);
//	self.assertIsOneOf(	ediFileObj.fileStatus,
//						"Load Failed",
//						CM_EDIFile.EDI_STATUS_DBLOADED,
//						CM_EDIFile.EDI_STATUS_DBLOADED_PARTIAL);
	errorMsg := "DB Load Failed" &amp; CrLf &amp; passportObj.getErrorsAsString();
	self.assertEqualMsg(ediFileObj.fileStatus, CM_EDIFile.EDI_STATUS_DBLOADED, errorMsg);
	if ediFileObj.fileStatus = CM_EDIFile.EDI_STATUS_DBLOADED_PARTIAL then
		write "EDI message not fully loaded - needs a re-run.";
	endif;
	self.assertEqualMsg(ediDataObj.allEDITrackedItems.size, 6, "incorrect number of EDI trackedItems");
	container := self.getTrackedItem(CONTAINERID).CM_Container;
	self.assertNotNull(container);
	self.assertEqualMsg(container.dischargePort, "HKHKG", "wrong discharge Port");
	self.assertEqualMsg(container.getHazardsAsString(), "7".String, "wrong hazards");
end;
</source>
