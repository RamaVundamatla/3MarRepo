    <JadeMethod name="processReeferInfo" id="fa32302f-a750-46b1-9ea9-343d53b7cd36">
        <source>processReeferInfo(	_xmlElementReefer : JadeXMLElement;
					_ediFile: CM_EDIFile input;
					_ediPreNote : CM_EDIPrenoteTI input
					):Boolean protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
31 August 2016	cnwndl1	Initial creation	TFS 2276 / 2565

*/

vars

	xmlElementControl : JadeXMLElement;
	xmlSubElement : JadeXMLElement;
	str : String;
	carrierObj : CM_Carrier;
	

begin


	xmlElementControl := _xmlElementReefer.getElementByTagName(self.TagControlTemperature);
	if xmlElementControl &lt;&gt; null then

		xmlSubElement := null;
		xmlSubElement := xmlElementControl.getElementByTagName(self.TagTemperature);
		if xmlSubElement &lt;&gt; null then
			str := xmlSubElement.textData.trimBlanks;
			if str &lt;&gt; null and str.isDecimal then
				_ediPreNote.temperature := str.Real;
			endif;
			
		endif;
		
		
	endif;
	


	return true;

epilog

end;</source>
        <access>protected</access>
