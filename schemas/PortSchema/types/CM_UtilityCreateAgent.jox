	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	
	app.setContinueCMExceptions(false);

	create _camsMoveTAType persistent;
	_camsMoveTAType.setForCreate(_proxyCamsMoveTAType);

	/*
	31.03.2025 navma1 #MTN-34387
