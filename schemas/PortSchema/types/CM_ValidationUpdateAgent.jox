    <JadeMethod name="valVoyage" id="6f6cd46e-e030-4814-aef1-d4d49257483d">
        <source>valVoyage(_existingVoyage,_proxyVoyage:CM_Voyage; _passport : CM_Passport input;_includeStructures : Boolean);
// ---------------------------------------------------------------------------
// Created:     16 July 2001 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	self.raiseExceptionIfNull(_proxyVoyage, 'Voyage Proxy');
	self.raiseExceptionIfNull(_existingVoyage, "Voyage Existing");
	_proxyVoyage.raiseExceptionIfNotProxy(method);
	if _existingVoyage.code = _proxyVoyage.code then
		_proxyVoyage.validateForUpdate(_passport,_includeStructures);
	else
		_proxyVoyage.validateForCreate(_passport);
	endif;

epilog
	
end;</source>
