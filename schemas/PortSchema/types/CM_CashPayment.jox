        <source>isCancelled() : Boolean;
/*
Purpose:	

Date		Who		Reason
23 JUNE 2025	navab1	JIRA 35178
*/

vars

begin
	if self.myCashReceipt = null then
		return false;
	endif;
	
	if self.isTaxPayment() then // tax payments ignore
		return false;
	endif;
	
	return self.myCashReceipt.paymentStatus = CM_CashReceipt.API_RECEIPT_CANCELLED;
	
epilog

end;</source>
