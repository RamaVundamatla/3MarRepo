    </JadeMethod>
    <JadeMethod name="newIdNotAlreadyUsed" id="09c0fb6f-3d0c-45aa-abe8-5d4d90d21250">
        <source>newIdNotAlreadyUsed(_newId: String): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 August 2018	jlgndl1	Initial creation	TFS 40249

*/

vars

	existingWO : CM_WorkOrder;

begin

	existingWO := self.myTerminal.allWorkOrders[ _newId];
	if existingWO = null then
		// no Work Order with the same id.
		return true;
	endif;

	return false;

epilog

end;</source>
        <Parameter name="_newId" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
