    <JadeMethod name="getStopsDescr" id="f7794575-4a0f-4cf2-a97f-79befce21ad2">
        <source>getStopsDescr() : String;
// ---------------------------------------------------------------------------
// Created:     27 July 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	str		: String;
	idx			: Integer;
	theStopTable 	: CM_StopsTable;
	root		: CM_Root;
	user	: CM_User;
	term	: CM_Terminal;
begin

	if app.myPassport &lt;&gt; null then
		user := app.myPassport.myUser;
		term := app.myPassport.myTerminal;
	endif;
	
	root := app.myRoot;
	
	foreach idx in self.stops do
		theStopTable := root.allStopsTable[idx];
		
		if user &lt;&gt; null then
			if not user.canViewStop(term, theStopTable) then
				continue;
			endif;
		endif;
		
		str := str &amp; theStopTable.code;
	endforeach;
	
	return str;
	
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
