    <JadeMethod name="setFrameDefaults" id="96f4fa8a-ca7a-4704-a190-ea257062cd2c">
        <updating/>
        <source>setFrameDefaults(pFrame : Frame input) updating ,protected;
// ---------------------------------------------------------------------------
// Created:     29 January 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	pFrame.bevelInner		:= 0;
	pFrame.bevelInnerWidth	:= 0;
	pFrame.bevelOuter		:= 0;
	pFrame.bevelOuterWidth	:= 0;
	pFrame.boundaryBrush	:= BoundaryBrush_Solid; //pFrame.BoundaryBrush_Dotted;//BoundaryBrush_Solid;
	pFrame.boundaryWidth	:= 0;
	pFrame.left				:= 0;
//	pFrame.borderStyle		:= self.BorderStyle_None;
	
	
	//pFrame.caption			:= null;
	pFrame.autoRedraw 		:= true;

end;</source>
        <access>protected</access>
        <Parameter name="pFrame" type="Frame" usage="input"/>
    </JadeMethod>
