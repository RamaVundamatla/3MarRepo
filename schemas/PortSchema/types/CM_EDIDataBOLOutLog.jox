    <JadeMethod name="attemptLoadOut" id="ff376a53-b944-4249-b980-08d0a49bed85">
        <source>attemptLoadOut(_passport : CM_Passport input) : Boolean;
//--------------------------------------------------------------
//Created: 26 August 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	pxyLogVoyCntrl 	: CM_LogVoyageController;
	realLogVoyCntrl : CM_VoyageController;
	ediLog, lastLog : CM_EDIBOLOutLogTI;
	logLot, lastLot : CM_LogLot;
	intFaceItem 	: CMIF_BOLOut;
	iter 			: Iterator;
	next,
	isEOF,
	firstTime 		: Boolean;
	now 			: TimeStamp;
	voyOper 		: CM_VoyageOperator;
	terminal 		: CM_Terminal;
	globalVoy 		: CM_VoyageGlobal;
	stevedore 		: CM_Stevedore;
	operator 		: CM_Operator;	
	logVoyage 	: CM_Voyage;
	hatch, place 	: Integer;
	ls				: Boolean;
	operCode,
	productCode		: String;	

begin
	create intFaceItem transient;	
	iter := self.allEDILogsByLotHatchPlace.createIterator;
	firstTime := true;
	now := app.serverTimestampAtTrxStart;
	
	app.cmsBeginLoad(ls);
	while true do
		isEOF := (not iter.next(ediLog));

		if (not isEOF) then
			if ediLog.myLogLot = null or
			   ediLog.hatch = null or
			   ediLog.place = null or
			   ediLog.productCode = null or
			   ediLog.operatorCode = null then
				continue;
			endif;	
	
			logLot := ediLog.myLogLot;
			if firstTime then
				intFaceItem.hatch := ediLog.hatch;
				intFaceItem.place := ediLog.place;		
				intFaceItem.myLogLot := logLot;
				intFaceItem.allEDILogsById.add(ediLog);
				lastLog := ediLog;
				lastLot := logLot;
				productCode := ediLog.productCode;
				operCode	:= ediLog.operatorCode;
				firstTime := false;
			elseif logLot = intFaceItem.myLogLot and
			   ediLog.hatch = intFaceItem.hatch and
			   ediLog.place = intFaceItem.place and
			   ediLog.productCode = productCode and
			   ediLog.operatorCode = operCode then
				intFaceItem.allEDILogsById.add(ediLog);
			else 
				next := true;				
			endif;
		endif;
		
		if next or isEOF then
			operator 	:= lastLog.myOperator;
//			logVoyage	:= lastLot.myLogVoyage;
			logVoyage	:= lastLot.myLogVoyageStructure.myVoyage;
			terminal 	:= logVoyage.myTerminal;
			globalVoy 	:= logVoyage.myVoyageGlobalArrival;
			voyOper 	:= globalVoy.allVoyOpsByOpTerm[operator.code, terminal.code];
			stevedore 	:= globalVoy.myRoot.allStevedores[voyOper.stevedoreCode1];
			hatch		:= intFaceItem.hatch;
			place		:= intFaceItem.place;
			intFaceItem.bolType	  := BOLType_Log;
			intFaceItem.bolNumber := terminal.bolOutNextSeqNumber;
			if lastLot.myConsignee &lt;&gt; null then
				intFaceItem.consignorCode		:= lastLot.myConsignee.code;
			endif;
			if lastLot.myDischargePort &lt;&gt; null then
				intFaceItem.dischargePort		:= lastLot.myDischargePort.code;
			endif;
			intFaceItem.logGradeCode		:= lastLog.logGradeCode;
			intFaceItem.logSpeciesCode		:= lastLog.logSpeciesCode;
			intFaceItem.lengthRandom		:= lastLog.logLengthCode;
			intFaceItem.logTreatmentCode	:= lastLog.logTreatmentCode;
			intFaceItem.logTypeCode			:= lastLog.logTypeCode;				
			intFaceItem.myConsignee			:= lastLot.myConsignee;									
			intFaceItem.myLogLot 			:= lastLot;
			intFaceItem.myTerminal			:= terminal;
			intFaceItem.myOperator			:= operator;
			intFaceItem.myStevedore			:= stevedore;
			intFaceItem.myVoyage	 		:= logVoyage;				
			intFaceItem.numItems			:= intFaceItem.allEDILogsById.size;
			intFaceItem.operatorCode		:= operator.code;
			intFaceItem.unitOfMeasure		:= BOL_UOM_PIECE_COUNT;
			intFaceItem.userCode			:= app.getMyUserCode;
			intFaceItem.transportMode 		:= TI_TRANSMODE_SHIP;				
			intFaceItem.myPlannedLocation 	:= logVoyage.myLogVoyageStructure.getLogVoyController(lastLot.lotNo, hatch, place);
			if intFaceItem.myPlannedLocation = null then
				if pxyLogVoyCntrl = null then
					create pxyLogVoyCntrl transient;
				endif;
				app.writeLog('Creating onship details for ' &amp; lastLot.lotNo &amp; ' H' &amp; hatch.String &amp; ' ' &amp; app.vesselPlaceEnumToStr(place), LogINFO);
				pxyLogVoyCntrl.setProxy(lastLot, logVoyage.myLogVoyageStructure, hatch, place);
				app.myUtilityCA.utlCreateVoyageController(pxyLogVoyCntrl, realLogVoyCntrl, _passport);
				if _passport.hasErrors then
					return false;
				endif;				
				intFaceItem.myPlannedLocation := realLogVoyCntrl;
			endif;
			app.writeLog('Creating bol (' &amp; intFaceItem.bolNumber &amp; ')', LogINFO);
			app.myUtilityCA.utlCreateBOLOut(intFaceItem, _passport);
			if _passport.hasErrors then
				return false;
			endif;
			app.writeLog('    BOL ' &amp; intFaceItem.bolNumber &amp; ') created', LogINFO);
			if (not isEOF) then
				intFaceItem.hatch := ediLog.hatch;
				intFaceItem.place := ediLog.place;		
				intFaceItem.myLogLot := ediLog.myLogLot;
				productCode := ediLog.productCode;
				operCode := ediLog.operatorCode;								
				intFaceItem.allEDILogsById.clear();
				intFaceItem.allEDILogsById.add(ediLog);
				lastLog := ediLog;
				lastLot := logLot;				
				next := false;		
			endif;
		endif;
		
		if isEOF then
			break;
		endif;
	endwhile;
	
	return true;
epilog
	app.cmsEndLoad(ls);
	delete iter;
	delete intFaceItem;
	delete pxyLogVoyCntrl;
end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
