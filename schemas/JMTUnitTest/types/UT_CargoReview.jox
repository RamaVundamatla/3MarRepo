    <JadeMethod name="tCargoReview_Scenario04" id="14bc0441-426e-4df2-b2d1-6cdc65663c59">
        <source>tCargoReview_Scenario04();
/*

Purpose:			

Parameters:			

Return Value:	
SCENARIO-4	Grouping: Voyage, Cargo Type, Cargo Subtype, Commodity						
								
Voyage		Cargo Type		Cargo Subtype		Commodity			  	Total Qty	Qty Reserved	Reservations
VOYAGE_A	Paper			Reel				 NEWS						25			12				REL01 (5), REL02 (4), REL03 (3)
VOYAGE_A	Paper			Reel				 COPY					 	45			20				REL04 (12),REL05 (8)
Date		Who		Reason
23 Aug 2025 navrv30 MTN 35150 MTN | Unit Tests for Cargo Review Release Requests and COO Validation	

*/
constants	
	VOYAGE= "VOYAGE_Q";	
vars

	term : CM_Terminal;
	pxyBOL : CM_BOLIn;
	//tis : CM_TIArray;
	qDef : CM_QueryDefinition;
