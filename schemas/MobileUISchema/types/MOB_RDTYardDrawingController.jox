    <JadeMethod name="drawRowsLandscapeOLDER" id="e1a2b218-6c2c-43d3-91da-2a68a21a670a">
        <source>drawRowsLandscapeOLDER(_y1 : Real; _gridWidth : Real; _gridHeight : Real; _gridRow : CM_GridRow) protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
20 April 2010	cnwjk3	Initial creation

*/

vars
	lcx1, lcy1,
	lcx2, lcy2,
	x1 				: Real;
	col 			: Integer;
	finishedCols 	: Boolean;
	lc 				: CM_GridController;
	notEmpty 		: Boolean;
	topTI			: CM_TrackedItem;
	drawTI			: Boolean;
begin
		// Note that I draw these in separate loops to avoid flicker issues, when drawing TIs that span more than one location
		
		// Draw the Locations
		if self.flipH then
			x1 := self.myDrawingFrame.width + self.xDrawOffset - self.rightOffset;	
		else
			x1 := self.xDrawOffset + self.leftOffset;
		endif;		
		
		if self.flipH then
			col := self.rightGridColDraw;
		else
			col := self.leftGridColDraw;
		endif;
		
		finishedCols := false;
		while not finishedCols do
			lc := _gridRow.allControllersByColumn[col];
			
			// Draw the location
			if self.flipH then
				if self.flipV then
					//self.drawLocation(x1 - _gridWidth, _y1 - _gridHeight, x1, _y1, lc);				
				else
					//self.drawLocation(x1 - _gridWidth, _y1, x1, _y1 + _gridHeight, lc);
				endif;
			else
				if self.flipV then
					//self.drawLocation(x1, _y1 - _gridHeight, x1 + _gridWidth, _y1, lc);			
				else
					//self.drawLocation(x1, _y1, x1 + _gridWidth, _y1 + _gridHeight, lc);			
				endif;
			endif;
			
			col := col + 1;
			if self.flipH then
				finishedCols := col &gt; self.leftGridColDraw;
			else
				finishedCols := col &gt; self.rightGridColDraw;
			endif;	
			
			// Move across
			if self.flipH then
				x1 := x1 - _gridWidth;
			else
				x1 := x1 + _gridWidth;
			endif;
						
		endwhile;

		// Draw the TIs
		if self.flipH then
			x1 := self.myDrawingFrame.width + self.xDrawOffset - self.rightOffset;	
		else
			x1 := self.xDrawOffset + self.leftOffset;
		endif;

		
		if self.flipH then
			col := self.rightGridColDraw;
		else
			col := self.leftGridColDraw;
		endif;
		
		finishedCols := false;
		while not finishedCols do
			drawTI := true;
			lc := _gridRow.allControllersByColumn[col];
			topTI := lc.getTopTI(REAL_MODE);
				
			//notEmpty := self.locationContainsTIs(lc);
			notEmpty := topTI &lt;&gt; null and topTI.myPrimaryActualLocation = lc;
			if notEmpty and drawTI then
				// Draw it
				if self.flipH then
					if self.flipV then
						//self.drawTI(x1 - _gridWidth, _y1 - _gridHeight, x1, _y1, lc.getTopTI(REAL_MODE), lc, false); 
					else
						//self.drawTI(x1 - _gridWidth, _y1, x1, _y1 + _gridHeight, lc.getTopTI(REAL_MODE), lc, false); 
					endif;
				else
					if self.flipV then
						//self.drawTI(x1, _y1 - _gridHeight, x1 + _gridWidth, _y1, lc.getTopTI(REAL_MODE), lc, false); 
					else
						//self.drawTI(x1, _y1, x1 + _gridWidth, _y1 + _gridHeight, lc.getTopTI(REAL_MODE), lc, false); 
					endif;
				endif;
			endif;

			if self.flipH then
				lcx1 := x1 - _gridWidth;
				lcx2 := x1;
			else			
				lcx1 := x1;
				lcx2 := x1 + _gridWidth;
			endif;
			
			if self.flipV then
				lcy1 := _y1 - _gridHeight;
				lcy2 :=  _y1;
			else
				lcy1 := _y1;
				lcy2 :=  _y1 + _gridHeight;
			endif;

			
			self.gridPointsToLCPoints(lcx1, lcy1, lcx2, lcy2);

			if lc = self.myTargetLocation then
				// Highlight the location
				self.highlightSelectedLocation(lcx1, lcy1, lcx2, lcy2, lc.getTopTI(REAL_MODE)); 					
			endif;
			
			 
			self.drawLocationID(lc, lcx1, lcy1, lcx2, lcy2, lc.getTopTI(REAL_MODE), self.myTIFrame);
			
			col := col + 1;
			if self.flipH then
				finishedCols := col &gt; self.leftGridColDraw;
			else
				finishedCols := col &gt; self.rightGridColDraw;
			endif;	
			
			// Move across
			if self.flipH then
				x1 := x1 - _gridWidth;
			else
				x1 := x1 + _gridWidth;
			endif;
						
		endwhile;
		
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_y1" type="Real"/>
        <Parameter name="_gridWidth" type="Real"/>
        <Parameter name="_gridHeight" type="Real"/>
        <Parameter name="_gridRow" type="CM_GridRow"/>
    </JadeMethod>
    <JadeMethod name="drawRowsPortrait" id="8b89fef8-b2d0-4847-9561-c4c7c7fc1e32">
        <source>drawRowsPortrait(_x1 : Real; _gridWidth : Real; _gridHeight : Real; _col : Integer) protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
20 April 2010	cnwjk3	Initial creation

*/

vars
	lcx1, lcy1,
	lcx2, lcy2,
	y1 				: Real;
	row 			: Integer;
	finishedRows 	: Boolean;
	lc 				: CM_LocationsController;
	lcDraw			: CMIF_RDTLocationDrawElement;
	tiDraw			: CMIF_RDTTIDrawElement;
	wagonDraw		: CMIF_RDTWagonPartDrawElement;
	trackDraw 		: CMIF_RDTTrackDrawElement;
	notEmpty 		: Boolean;
	theTI			: CM_TrackedItem;
begin		
		// Note that I draw these in separate loops to avoid flicker issues, when drawing TIs that span more than one location
		
		// Draw the Locations
		if self.flipV then
			y1 := self.myDrawingFrame.clientHeight + self.yDrawOffset - self.bottomOffset;	
		else
			y1 := self.yDrawOffset + self.topOffset;
		endif;
		
		if self.flipV then
			row := self.bottomGridRowDraw;
		else
			row := self.topGridRowDraw;
		endif;
		
		finishedRows := false;	
		while not finishedRows do
			lcDraw := self.myDisplayBuilder.getLocationDraw(row, _col);
			if lcDraw &lt;&gt; null then 
				lc := lcDraw.getLocationController();
			else
				lc := null;
			endif;
						
			// New wagon handling
			wagonDraw := self.myDisplayBuilder.getWagonPart(row, _col);
			if wagonDraw &lt;&gt; null then
				self.drawWagon(_x1, y1, _gridWidth, _gridHeight, wagonDraw); 		
			endif;
			//
			
			// New train track handling
			trackDraw := self.myDisplayBuilder.getTrack(row, _col);
			if trackDraw &lt;&gt; null then
				self.drawTrack(_x1, y1, _gridWidth, _gridHeight, trackDraw); 		
			endif;			
			//			
			
			if lcDraw &lt;&gt; null then 
				self.drawLocation(_x1, y1, _gridWidth, _gridHeight, lcDraw); 				
			endif;

			row := row + 1;
			if self.flipV then
				finishedRows := row &gt; self.topGridRowDraw;
			else
				finishedRows := row &gt; self.bottomGridRowDraw;
			endif;	
			
			// Move up/down
			if self.flipV then
				y1 := y1 - _gridHeight;			
			else
				y1 := y1 + _gridHeight;			
			endif;
			
		endwhile;

		// Draw the TIs
		if self.flipV then
			y1 := self.myDrawingFrame.height + self.yDrawOffset - self.bottomOffset;	
		else
			y1 := self.yDrawOffset + self.topOffset;
		endif;

		if self.flipV then
			row := self.bottomGridRowDraw;
		else
			row := self.topGridRowDraw;
		endif;

		finishedRows := false;	
		while not finishedRows do
			lcDraw := self.myDisplayBuilder.getLocationDraw(row, _col);
			if lcDraw &lt;&gt; null then 
				lc := lcDraw.getLocationController();
			else
				lc := null;
			endif;

			tiDraw := self.myDisplayBuilder.getTI(row, _col);
			if tiDraw &lt;&gt; null then
				theTI := tiDraw.getTI();
			else
				theTI := null;
			endif;
			
			if  tiDraw &lt;&gt; null then
				// Draw it
				self.drawTI(_x1, y1, _gridWidth, _gridHeight, tiDraw); 	
			endif;
			
			if lcDraw &lt;&gt; null then 
				if self.flipH then
					lcx1 := _x1 - _gridWidth;
					lcx2 := _x1;
				else
					lcx1 := _x1;
					lcx2 := _x1 + _gridWidth;
				endif;
	
				if self.flipV then
					lcy1 := y1 - _gridHeight;
					lcy2 :=  y1;
				else
					lcy1 := y1;
					lcy2 :=  y1 + _gridHeight;
				endif;
	
				lcDraw.gridPointsToElementPoints(lcx1, lcy1, lcx2, lcy2, self.scaleFactor, self.isLandscape, self.flipH, self.flipV);
				
				
				if self.allHighlightLCsByID.includesKey(lc.getFullId()) then
					self.highlightLocation(lcx1, lcy1, lcx2, lcy2);
				endif;
					
				if lc = self.myTargetLocation then
					// Highlight the location
					self.highlightSelectedLocation(lcx1, lcy1, lcx2, lcy2, theTI); 					
				endif;
				
				lcDraw.drawLocationId(lcx1, lcy1, lcx2, lcy2, self.scaleFactor, self.flipV, self.flipH, tiDraw, self.myTIFrame,self.drawMode);
			
			endif;
			
			
			row := row + 1;
			
			if self.flipV then
				finishedRows := row &gt; self.topGridRowDraw;
			else
				finishedRows := row &gt; self.bottomGridRowDraw;
			endif;	
			
			// Move up/down
			if self.flipV then
				y1 := y1 - _gridHeight;			
			else
				y1 := y1 + _gridHeight;			
			endif;
			
		endwhile;
		
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_x1" type="Real"/>
        <Parameter name="_gridWidth" type="Real"/>
        <Parameter name="_gridHeight" type="Real"/>
        <Parameter name="_col" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="drawRowsPortraitOLD" id="83c433a4-defd-4d2e-b7bb-1e695200b313">
        <source>drawRowsPortraitOLD(_x1 : Real; _gridWidth : Real; _gridHeight : Real; _gridRow : CM_GridRow) protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
20 April 2010	cnwjk3	Initial creation

*/

vars
	lcx1, lcy1,
	lcx2, lcy2,
	y1 				: Real;
	row 			: Integer;
	finishedRows 	: Boolean;
	lc 				: CM_GridController;
	notEmpty 		: Boolean;
	topTI			: CM_TrackedItem;
	drawTI			: Boolean;
begin		
		// Note that I draw these in separate loops to avoid flicker issues, when drawing TIs that span more than one location
		
		// Draw the Locations
		if self.flipV then
			y1 := self.myDrawingFrame.height + self.yDrawOffset - self.bottomOffset;	
		else
			y1 := self.yDrawOffset + self.topOffset;
		endif;
		
		if self.flipV then
			row := self.bottomGridRowDraw;
		else
			row := self.topGridRowDraw;
		endif;
		
		finishedRows := false;	
		while not finishedRows do
			lc := _gridRow.allControllersByColumn[row];
	
			// Draw the location
			if self.flipH then
				if self.flipV then
					//self.drawLocation(_x1 - _gridWidth, y1 - _gridHeight, _x1, y1, lc);
				else
					//self.drawLocation(_x1 - _gridWidth, y1, _x1, y1 + _gridHeight, lc);
				endif;
			else
				if self.flipV then
					//self.drawLocation(_x1, y1 - _gridHeight, _x1 + _gridWidth, y1, lc);
				else
					//self.drawLocation(_x1, y1, _x1 + _gridWidth, y1 + _gridHeight, lc);
				endif;
			endif;

			notEmpty := self.locationContainsTIs(lc);

			row := row + 1;
			if self.flipV then
				finishedRows := row &gt; self.topGridRowDraw;
			else
				finishedRows := row &gt; self.bottomGridRowDraw;
			endif;	
			
			// Move up/down
			if self.flipV then
				y1 := y1 - _gridHeight;			
			else
				y1 := y1 + _gridHeight;			
			endif;
			
		endwhile;

		// Draw the TIs
		if self.flipV then
			y1 := self.myDrawingFrame.height + self.yDrawOffset - self.bottomOffset;	
		else
			y1 := self.yDrawOffset + self.topOffset;
		endif;

		//row := topGridRowDraw;
		if self.flipV then
			row := self.bottomGridRowDraw;
		else
			row := self.topGridRowDraw;
		endif;

		finishedRows := false;	
		while not finishedRows do
			drawTI := true;
			lc := _gridRow.allControllersByColumn[row];
			
			topTI := lc.getTopTI(REAL_MODE);
			
			//notEmpty := self.locationContainsTIs(lc);
			notEmpty := topTI &lt;&gt; null and topTI.myPrimaryActualLocation = lc;

			if notEmpty and drawTI then
				// Draw it
				if self.flipH then
					if self.flipV then
						//self.drawTI(_x1 - _gridWidth, y1 - _gridHeight, _x1, y1, topTI, lc, false); 
					else
						//self.drawTI(_x1 - _gridWidth, y1, _x1, y1 + _gridHeight, topTI, lc, false); 
					endif;
				else
					if self.flipV then
						//self.drawTI(_x1, y1 - _gridHeight, _x1 + _gridWidth, y1, topTI, lc, false); 					
					else
						//self.drawTI(_x1, y1, _x1 + _gridWidth, y1 + _gridHeight, topTI, lc, false); 
					endif;
				endif;
			endif;
			
			if self.flipH then
				lcx1 := _x1 - _gridWidth;
				lcx2 := _x1;
			else
				lcx1 := _x1;
				lcx2 := _x1 + _gridWidth;
			endif;

			if self.flipV then
				lcy1 := y1 - _gridHeight;
				lcy2 :=  y1;
			else
				lcy1 := y1;
				lcy2 :=  y1 + _gridHeight;
			endif;

			
			self.gridPointsToLCPoints(lcx1, lcy1, lcx2, lcy2);
				
			if lc = self.myTargetLocation then
				// Highlight the location
				self.highlightSelectedLocation(lcx1, lcy1, lcx2, lcy2, topTI); 					
			endif;
			
			self.drawLocationID(lc, lcx1, lcy1, lcx2, lcy2, topTI, self.myTIFrame);
			
			row := row + 1;
			
			if self.flipV then
				finishedRows := row &gt; self.topGridRowDraw;
			else
				finishedRows := row &gt; self.bottomGridRowDraw;
			endif;	
			
			// Move up/down
			if self.flipV then
				y1 := y1 - _gridHeight;			
			else
				y1 := y1 + _gridHeight;			
			endif;
			
		endwhile;
		
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_x1" type="Real"/>
        <Parameter name="_gridWidth" type="Real"/>
        <Parameter name="_gridHeight" type="Real"/>
        <Parameter name="_gridRow" type="CM_GridRow"/>
