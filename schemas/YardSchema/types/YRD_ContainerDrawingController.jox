        <source>drawBackendAttForFM(_theTI: CM_TrackedItem; _frame: CMUI_GridAreaDrawingFrame input; _x1: Real; _y1: Real; _x2: Real; _y2: Real; _colour: Integer) protected;
// ---------------------------------------------------------------------------
// Created:     02 September 2009 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_theTI" type="CM_TrackedItem"/>
        <Parameter name="_frame" type="CMUI_GridAreaDrawingFrame" usage="input"/>
