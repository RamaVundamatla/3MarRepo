    <JadeMethod name="doHandleNotification" id="dc176499-1b9d-49b2-a61e-7f3fa5567d58">
        <updating/>
        <source>doHandleNotification(eventType: Integer; theObject: Object; eventTag: Integer; userInfo: Any) updating, protected;
/*
----------   ----------  --------------------------------------------------
Created:	05 September 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	event		: Integer;
	rfidTag		: CM_RFIDTag;
	idx			: Integer;
	
begin

	event := self.myTerminal.getEventFromTerminalEvent(eventType);
	
	if CM_RFIDTag.hasInstance(userInfo.Object) then
		rfidTag := userInfo.CM_RFIDTag;
		if event = Event_RFIDTagRead then
			if (not rfidTag.isAvailableForEntry) then
				self.addPreGateAlert('Tag "' &amp; rfidTag.code &amp; '" (' &amp; rfidTag.serialNumber &amp; 
								') was read but it is currently flagged as not available for entry.');
			
				self.readTagSuccessful := false;
			elseif rfidTag.myRoadJob &lt;&gt; null and rfidTag.myRoadJob&lt;&gt; self.myJob then
				self.addPreGateAlert('Tag "' &amp; rfidTag.code &amp; '" (' &amp; rfidTag.serialNumber &amp; 
								') was read but it is currently assigned to job "' &amp; rfidTag.myRoadJob.jobId &amp; '".');
				self.readTagSuccessful := false;
				
			else
				if self.cmbRFID.findObject(rfidTag) &lt; 1 then
					self.cmbRFID.itemObject[self.cmbRFID.addItem(rfidTag.code)] := rfidTag;
				else
					self.cmbRFID.listObject := rfidTag;
				endif;
				self.zOrder(1);//bring to front
				self.readTagSuccessful := true;	
			endif;
			
		elseif event = Event_RFIDTagFree then
			if self.cmbRFID.findObject(rfidTag) &lt; 1 then
				self.cmbRFID.itemObject[self.cmbRFID.addItem(rfidTag.code)] := rfidTag;
			endif;
			
		elseif event = Event_RFIDTagInUse then
			idx := self.cmbRFID.findObject(rfidTag);
			if idx &gt; 0 then
				self.cmbRFID.removeItem(idx);
			endif;	
		endif;
	endif;
	
	self.loadJobInfo();
end;



</source>
        <access>protected</access>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
        <Parameter name="userInfo" type="Any"/>
    </JadeMethod>
