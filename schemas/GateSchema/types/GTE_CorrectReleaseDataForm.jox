    <JadeMethod name="buildCmbSubCarrier" id="a78e79fc-7f94-4a05-ad69-b40799c1b4ff">
        <source>buildCmbSubCarrier();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 January 2024	navcs2	ChangeRequest 57088: EUP | Correct Info on Departed Transport for Itemized Cargo

*/

vars
	aCarrier 		: CM_Carrier;
	combo 			: CMUI_ComboBox;
	vehicleVisit	: CM_VehicleVisitRecord;
begin
	combo := self.cmbSubHaulier;
	combo.clear();
	foreach aCarrier in app.myRoot.allSubCarriersRoad discreteLock do
		combo.addItemObject(aCarrier.code &amp; Tab &amp; aCarrier.description, aCarrier);
	endforeach;
	
	vehicleVisit := self.myVehicleVisitRecord;
	
	if vehicleVisit &lt;&gt; null then
		combo.listIndex := combo.findObject(vehicleVisit.getMySubCarrier);
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="buildCmbSubTerminalAreas" id="14d138fc-1f1c-479b-90fa-64d9a689a290">
        <source>buildCmbSubTerminalAreas(_terminalArea : CM_TerminalArea);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 January 2024	navcs2	ChangeRequest 57088: EUP | Correct Info on Departed Transport for Itemized Cargo
14 May 2024		navhn30	Bug 63874: EUP | FR 59098 - Corrected Details on Transport - Sub Area Selection Not Possible
*/

vars
	locationController 	: CM_LocationsController;
	combo 				: CMUI_ComboBox;
	vehicleVisit		: CM_VehicleVisitRecord;
begin
	combo := self.cmbTerminalSubArea;
	combo.clear();
	if _terminalArea &lt;&gt; null and  _terminalArea.allLocationsControllers.size &gt; 1 then
		foreach locationController in _terminalArea.allLocationsControllers discreteLock do		// 14.05.24		navhn30		TFS #63874
			combo.addItemObject(locationController.getID, locationController);
		endforeach;
	endif;
epilog

end;</source>
        <Parameter name="_terminalArea" type="CM_TerminalArea"/>
    </JadeMethod>
    <JadeMethod name="buildCmbTerminalAreas" id="ce835e2d-6866-45da-bd45-f627428885a1">
        <source>buildCmbTerminalAreas();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 January 2024	navcs2	ChangeRequest 57088: EUP | Correct Info on Departed Transport for Itemized Cargo
16 May 2024		navhn30	Bug 63874: EUP | FR 59098 - Corrected Details on Transport - Sub Area Selection Not Possible
*/

vars
	aTerminalArea, aBlockStack : CM_TerminalArea;
	idx : Integer;
	theFilter		: CMQF_TerminalAreas;
	theQryReport	: CM_QryReport;
	terminalArea 	: CM_TerminalArea;
	combo 			: CMUI_ComboBox;
	vehicleVisit	: CM_VehicleVisitRecord;
begin
	combo := self.cmbTerminalArea;
	combo.clear();
/*	foreach terminalArea in self.myTerminal.allTerminalAreas discreteLock do
		combo.addItemObject(terminalArea.id &amp; Tab &amp; terminalArea.getAreasDescr, terminalArea);
	endforeach;*/
	theQryReport := app.myRoot.myReportMenuRoot.getReportByConstantValue(CM_RepTerminalArea);		// 16.05.24		navhn30		TFS #63874
	
	create theFilter transient;
	theFilter.allTerminals.add(self.myTerminal);
	theFilter.terminalAreaTypes.add(TA_TYPE_DEPOT_LCL);
	theFilter.terminalAreaTypes.add(TA_TYPE_BLOCK_STACK);
	theFilter.terminalAreaTypes.add(TA_TYPE_SUBBLOCK_STACK);	
	theFilter.terminalAreaTypes.add(TA_TYPE_WASH_AREA);			
	theFilter.terminalAreaTypes.add(TA_TYPE_PTI);				
	theFilter.terminalAreaTypes.add(TA_TYPE_REPAIR);				
	theFilter.terminalAreaTypes.add(TA_TYPE_IRREGULAR_BLOCK_AREA);		
	theFilter.terminalAreaTypes.add(TA_TYPE_FORK_LIFT_STACK); 
	theFilter.terminalAreaTypes.add(TA_TYPE_STRADDLE_STACK);
	theFilter.terminalAreaTypes.add(TA_TYPE_RTG);
	theFilter.terminalAreaTypes.add(TA_TYPE_RMG);
	theFilter.terminalAreaTypes.add(TA_TYPE_RORO_LANE_AREA);
	theFilter.terminalAreaTypes.add(TA_TYPE_BULK);
	theFilter.terminalAreaTypes.add(TA_TYPE_RELTRANS);
	theFilter.terminalAreaTypes.add(TA_TYPE_GEN_CARGO_ALLOC_ROW);
	theFilter.terminalAreaTypes.add(TA_TYPE_MAFI);		
	// Does not handle straddle stacks, only single controller areas
	theQryReport.doFilter(theFilter, app.myPassport);
	
	foreach aTerminalArea in theFilter.allQryTerminalAreas do	
		idx := self.cmbTerminalArea.addItem(aTerminalArea.id);
		self.cmbTerminalArea.itemObject[idx] := aTerminalArea;	
	endforeach;
	
epilog
	delete theFilter;

end;</source>
    </JadeMethod>
    <JadeMethod name="buildComboBoxes" id="f566a621-5aca-44d8-bec7-691ac488a349">
        <source>buildComboBoxes();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 January 2024	navcs2	ChangeRequest 57088: EUP | Correct Info on Departed Transport for Itemized Cargo

*/

vars

begin
	self.cmbCarrier.setObject(self.myVehicleVisitRecord.getCarrier);
	self.buildCmbSubCarrier();
	self.buildCmbTerminalAreas();
	self.buildCmbSubTerminalAreas(null);
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="buildTableCargoReleased" id="c9cab129-37a6-4f0b-8f68-276e74610f46">
        <source>buildTableCargoReleased(first : Boolean);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 January 2024	navcs2	ChangeRequest 57088: EUP | Correct Info on Departed Transport for Itemized Cargo
13.10.25	Navcs2	MTN-36202	MTN | Invoice Form displaying empty rows when rows are added from Selector form

*/

vars
	entTableDef : EntTableDef;
	tbl			: CM_DataTable;
	trackedItem	: CM_TrackedItem;
	idx			: Integer;
	theDataLine	: String;
	xmlStr		: String;
	vvr			: CM_VehicleVisitRecord;
	tiCMIF		: CMIF_MoveQuantityTI;
	cmif		: CMIF_Object;
begin
	tbl			:= self.tblReleasedTrackedItems;	

	entTableDef := app.myController.getEntTableDef(ETDef_DefaultDataTable);	
	xmlStr := self.enquiryTypeDef_Cargo;
	
	if xmlStr &lt;&gt; null then
		tbl.setTblDataEntRowsFromXML(entTableDef, xmlStr);	
	else	
		tbl.setTblDataEntRowsFromDef(entTableDef);
	endif;
	
	// 13.10.25	Navcs2	MTN-36202	Start
	if first then						
		foreach trackedItem in self.myVehicleVisitRecord.allReleasedTrackedItems do
			if trackedItem &lt;&gt; null then
				create tiCMIF transient;
				tiCMIF.myTI := trackedItem;
				tiCMIF.moveQuantity := trackedItem.totalQuantity;
				tiCMIF.moveWeight := trackedItem.weight;
				theDataLine := tiCMIF.getAttributeStringForDefArray(tbl.allTblDataEntRows);
				tbl.accessRow(tbl.addItem(theDataLine)).itemObject := tiCMIF;
			endif;
		endforeach;
	else 
		foreach cmif in self.releasedCMIFs do
			tiCMIF := cmif.CMIF_MoveQuantityTI;
			if tiCMIF &lt;&gt; null then
				theDataLine := tiCMIF.getAttributeStringForDefArray(tbl.allTblDataEntRows);
				tbl.accessRow(tbl.addItem(theDataLine)).itemObject := tiCMIF;
			endif;
		endforeach;
	endif;
	// 13.10.25	Navcs2	MTN-36202 End
	
	tbl.setMyDataClass(CM_TrackedItem);
	tbl.fixedColumns    := 0;
	tbl.fixedRows 	    := 1;
	tbl.selectMode 		:= CM_DataTable.SelectMode_FixedRow;
	tbl.selectionType   := CM_DataTable.SelectionType_Row;
	tbl.multiSelect 	:= CM_BaseTable.MultiSelect_Simple;	
	self.setColorsForTable(tbl);
epilog

end;</source>
        <Parameter name="first" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="buildTblOnsiteCargo" id="62116b45-1110-4596-a0c8-4fbd7c3cdce6">
        <updating/>
        <source>buildTblOnsiteCargo(first : Boolean) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 January 2024	navcs2	ChangeRequest 57088: EUP | Correct Info on Departed Transport for Itemized Cargo
13.10.25	Navcs2	MTN-36202	MTN | Invoice Form displaying empty rows when rows are added from Selector form

*/

vars
	entTableDef : EntTableDef;
	tbl			: CM_DataTable;
	trackedItem	: CM_TrackedItem;
	idx			: Integer;
	theDataLine	: String;
	xmlStr		: String;
	tiCMIF		: CMIF_MoveQuantityTI;
	cmif		: CMIF_Object;
begin
	tbl			:= self.tblOnsiteTrackedItems;	

	entTableDef := app.myController.getEntTableDef(ETDef_DefaultDataTable);	
	xmlStr := self.enquiryTypeDef_OnsiteCargo;
	
	
	if xmlStr &lt;&gt; null then
		tbl.setTblDataEntRowsFromXML(entTableDef, xmlStr);	
	else	
		tbl.setTblDataEntRowsFromDef(entTableDef);
	endif;
	
	// 13.10.25	Navcs2	MTN-36202 Start
	if first then
		foreach trackedItem in self.onsiteTrackedItems do
			if trackedItem &lt;&gt; null then
				create tiCMIF transient;
				tiCMIF.myTI := trackedItem;
				theDataLine := tiCMIF.getAttributeStringForDefArray(tbl.allTblDataEntRows);
				tbl.accessRow(tbl.addItem(theDataLine)).itemObject := tiCMIF;
			endif;
		endforeach;
	else 
		foreach cmif in self.onsiteCMIFs do
			tiCMIF := cmif.CMIF_MoveQuantityTI;
			if tiCMIF &lt;&gt; null then
				theDataLine := tiCMIF.getAttributeStringForDefArray(tbl.allTblDataEntRows);
				tbl.accessRow(tbl.addItem(theDataLine)).itemObject := tiCMIF;
			endif;
		endforeach;
	endif;
	// 13.10.25	Navcs2	MTN-36202 End
	
	//self.onsiteTrackedItems.clear();
	
	tbl.setMyDataClass(CM_TrackedItem);
	tbl.fixedColumns    := 0;
	tbl.fixedRows 	    := 1;
	tbl.selectMode 		:= CM_DataTable.SelectMode_FixedRow;
	tbl.selectionType   := CM_DataTable.SelectionType_Row;
	tbl.multiSelect 	:= CM_BaseTable.MultiSelect_Simple;	
	self.setColorsForTable(tbl);
epilog

end;</source>
        <Parameter name="first" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="buildTblReleasedCargo" id="4dab1df6-52be-4d64-891f-57ff7c56616a">
        <updating/>
        <source>buildTblReleasedCargo() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 January 2024	navcs2	ChangeRequest 57088: EUP | Correct Info on Departed Transport for Itemized Cargo

*/

vars
	entTableDef : EntTableDef;
	tbl			: CM_DataTable;
	trackedItem	: CM_TrackedItem;
	idx			: Integer;
	theDataLine	: String;
	xmlStr		: String;
	tiCMIF		: CMIF_MoveQuantityTI;
begin
	tbl			:= self.tblReleasedTrackedItems;	

	entTableDef := app.myController.getEntTableDef(ETDef_DefaultDataTable);	
	xmlStr := self.enquiryTypeDef_Cargo;
	
	
	if xmlStr &lt;&gt; null then
		tbl.setTblDataEntRowsFromXML(entTableDef, xmlStr);	
	else	
		tbl.setTblDataEntRowsFromDef(entTableDef);
	endif;
	
	foreach trackedItem in self.onsiteTrackedItems do
		if trackedItem &lt;&gt; null then
			create tiCMIF transient;
			tiCMIF.myTI := trackedItem;
			theDataLine := tiCMIF.getAttributeStringForDefArray(tbl.allTblDataEntRows);
			tbl.accessRow(tbl.addItem(theDataLine)).itemObject := tiCMIF;
		endif;
	endforeach;
	
	self.onsiteTrackedItems.clear();
	
	tbl.setMyDataClass(CM_TrackedItem);
	tbl.fixedColumns    := 0;
	tbl.fixedRows 	    := 1;
	tbl.selectMode 		:= CM_DataTable.SelectMode_FixedRow;
	tbl.selectionType   := CM_DataTable.SelectionType_Row;
	tbl.multiSelect 	:= CM_BaseTable.MultiSelect_Simple;	
	self.setColorsForTable(tbl);
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="cmbTerminalArea_click" id="1932064e-4944-481a-bcad-a38494418ced">
