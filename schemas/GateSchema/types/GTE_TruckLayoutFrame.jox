    <JadeMethod name="swapContainers" id="c4912753-cfc7-440f-8051-7a61ccfe80a5">
        <source>swapContainers(pFrom, pTo : Integer) protected;
// ---------------------------------------------------------------------------
// Created:     19 March 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	fromContainer,
	toContainer		: GTE_ContainerFrame;
	fromMenuAction,
	toMenuAction		: CMUI_MenuAction;
	navForm			: CMUI_Navigator;
	
begin

	if pTo &gt; 0 and pTo &lt;= self.allContainerFrames.size and
	   pFrom &gt; 0 and pFrom &lt;= self.allContainerFrames.size then
		// Swap the containers.  This is done in this convulated fashion as a straight swap got
		// the inverses screwed and left one container with its inverse not set.

		fromContainer 	:= self.allContainerFrames[pFrom];
		toContainer 	:= self.allContainerFrames[pTo];
		
		// RJS code to swap navigator window ??
		if fromContainer.mySheet &lt;&gt; null then
			fromMenuAction := fromContainer.mySheet.myMenuAction;
		endif;
		if toContainer.mySheet &lt;&gt; null then
			toMenuAction := toContainer.mySheet.myMenuAction;
		endif;
		
		navForm := app.getForm('CMUI_Navigator').CMUI_Navigator;
		if navForm &lt;&gt; null then
			navForm.lstTest.swap(fromMenuAction, toMenuAction);
		endif;
		
		// code to swap pictures

		// clear the inverses
		self.allContainerFrames[pFrom] 	:= null;
		self.allContainerFrames[pTo] 	:= null;
		
		// add into the new positions
		self.allContainerFrames[pFrom] 	:= toContainer;
		self.allContainerFrames[pTo] 	:= fromContainer;
	endif;
	
end;</source>
        <access>protected</access>
        <Parameter name="pFrom" type="Integer"/>
        <Parameter name="pTo" type="Integer"/>
    </JadeMethod>
