    <JadeMethod name="btnSetdownOK_click" id="35a3c9ef-6ad9-4be2-9501-2d7c17fa3368">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnSetdownOK_click(btn: Button input) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
02 February 2009	cnwer1	Initial creation

*/

vars
	hasTwinRTEntry : Boolean;
	rtTask,twinRTTask : CM_RTQueueTask;
	
begin
	
	hasTwinRTEntry:=(self.tblJobs.rows - self.tblJobs.fixedRows) = 2;
	
	rtTask:=self.tblJobs.accessRow(2).itemObject.CM_RTQueueTask;
	
	
	if hasTwinRTEntry then
		twinRTTask:=self.tblJobs.accessRow(3).itemObject.CM_RTQueueTask;
	endif;

	self.clearErrors;
	app.myVehicleMountedSTRADGuiAgent.doSetdown(rtTask,twinRTTask,self.txtSetdownLoc.text,self.txtSetdownTwin.text, self.allErrorMsgs);
	if self.checkErrors then
		return;
	else 
		self.frmSetdown.visible:=false;
	endif;
epilog

end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
