    <JadeMethod name="setForUpdate" id="b68b92cd-c624-4ea4-b9bf-caa83f6a67ff">
        <updating/>
        <source>setForUpdate(_proxy : CM_PushEventsRoot) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 Mar 2017	cnwkpd1	TFS 3369 - Push Events application
01 Nov 2017	jlgkpd1	TFS 7141 - Add in replay identifier mechanism
25 Oct 2019	jlgzm1	TFS 47239 Event stream subscriptions being overridden
27 Jan 2020	jlgzm1	TFS 47920 Event Stream Admin JMT UI - removed code that handled config versions

*/
vars

begin

	self.configurationDetails := _proxy.configurationDetails;
	self.replayStartTS := _proxy.replayStartTS;
	self.replayEndTS := _proxy.replayEndTS;
	self.replayIdentifier := _proxy.replayIdentifier;
	
epilog

end;</source>
        <Parameter name="_proxy" type="CM_PushEventsRoot"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="8f52ecfd-7383-4f37-bcbc-bc6906ab1d23">
        <updating/>
        <source>setProxy(_config : String;
		 _replayStartTS, _replayEndTS : TimeStamp;
		 _replayIdentifier : String) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 Mar 2017	cnwkpd1	TFS 3369 - Push Events application
01 Nov 2017	jlgkpd1	TFS 7141 - Add in replay identifier mechanism

*/

vars

begin
	self.raiseExceptionIfNotTransient(method);
	
	self.configurationDetails := _config;
	self.replayStartTS := _replayStartTS;
	self.replayEndTS := _replayEndTS;
	self.replayIdentifier := _replayIdentifier.truncatedAt(50);
	
epilog

end;</source>
        <Parameter name="_config" type="String"/>
        <Parameter name="_replayStartTS" type="TimeStamp"/>
        <Parameter name="_replayEndTS" type="TimeStamp"/>
        <Parameter name="_replayIdentifier" type="String"/>
    </JadeMethod>
</Class>
