    <JadeMethod name="setForCreate" id="34287bdd-35ac-4819-a296-028d0d4ad6d9">
        <updating/>
        <source>setForCreate(_proxy: SelfType) updating;
/*
Purpose:			

Date		Who		Reason
26 July 2021	navab1	TFS 50669
*/

vars
	agent : CM_OpsViewWSAgent;
begin
	inheritMethod(_proxy);
	
	self.dataAction := _proxy.dataAction;
	self.dataType := _proxy.dataType;
	self.isSnapshot := _proxy.isSnapshot;
	self.myOpsviewObject := _proxy.myOpsviewObject;
	self.objectOid := _proxy.objectOid;
	
	if self.myExtWebserviceDef = null then
		self.myExtWebserviceDef := app.myRoot.getFirstActiveExtWebService(CM_OpsViewServiceDef).CM_OpsViewServiceDef;
	endif;
	// This is done here so that we have the correct sequence number
	create agent transient;
	self.request := agent.getOpsViewDataOnActivity(self);
	
epilog
	delete agent;

end;</source>
        <Parameter name="_proxy" type="SelfType"/>
    </JadeMethod>
