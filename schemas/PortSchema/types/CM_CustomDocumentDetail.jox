    <JadeMethod name="applyStops" id="bcb74d0a-7990-440b-a5a8-ee79840e16ee">
        <updating/>
        <source>applyStops(_proxyTI : CM_TrackedItem input; _stopsToApply : CM_StopsTableSet; _updateAppliedBy : Boolean) updating;
/*) updating;
/*
Purpose - 	incoming proxy TIs, add proxy stops to apply.
Who - NAVAB1
Date - 25AUG2023
ADO - CR 60052 TASK 60053 
*/


vars
	stop : CM_StopsTable;
	docType : CM_CustomDocumentType;
	ti, cgti : CM_TrackedItem;
	cg : CM_CargoGroup;
	pxyStop : CM_Stops;
begin

	
	foreach stop in _stopsToApply discreteLock do
		if stop.requiresInfo then
			// reset any requires information fields that have been previously set
			// eg for Delivery Release number - this field must be null prior to the stop being added.
			_proxyTI.setRequiresInformation( stop.requiresInfoType, null );
		endif;
		
		pxyStop	:= _proxyTI.getStop( stop.id );
		
		if pxyStop = null then 
			create pxyStop transient;
			
			pxyStop.id	:= stop.id;
			// checks that the cargo type is OK - should not fail because we checked when we loaded the form
			if not pxyStop.setMyTrackedItem( _proxyTI ) then
				// we will never get here as the method raises an exception
				delete pxyStop; 
				return;
			endif;
		else
			pxyStop.pxySetUpdateStop();// ### TFS CR 59942 TASK 59943 14SEP2023 NAVAB1
		endif;
		
		if _updateAppliedBy then // if thsi is false it is becasue the stop has the APPLIED BY as the preceeding cust doc i.e. the 126
			pxyStop.setProxyCustDocApplied(self); // ### TFS CR 59942 TASK 59943 29AUG2023 NAVAB1
		endif;
		pxyStop.setProxyCustDocCleared(null); // ### TFS CR 60424 TASK 60549 26SEP2023 NAVAB1
		// expiry date should be null for a new stop
		pxyStop.setClearanceExpiryDate( null );
		
		// stop override reason should be null if adding a stop, it might have been set previously.
		pxyStop.setPxyStopOverrideReason( null );

	endforeach;
epilog

end;</source>
        <Parameter name="_proxyTI" type="CM_TrackedItem" usage="input"/>
        <Parameter name="_stopsToApply" type="CM_StopsTableSet"/>
        <Parameter name="_updateAppliedBy" type="Boolean"/>
    </JadeMethod>
