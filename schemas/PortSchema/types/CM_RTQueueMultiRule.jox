    <JadeMethod name="validateUpdate" id="ba95408d-c901-4db8-823a-851273952579">
        <source>validateUpdate(_passport: CM_Passport input);

// Created by cnwdvb1 on 05 September 2006

vars

begin
	
	if self.allDefaultRTMoveMethodRules.isEmpty then
		app.raiseCMException(Default_move_method_required,null,null);
	endif;
	
end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
</Class>
