<CollClass name="CMIF_DocketLogDefByLocation" id="1c291e23-8bcd-49cd-8d22-c94a0f7cc19e">
    <memberType name="CMIF_DocketLogDef"/>
    <superclass name="CM_MemberKeyDictionary"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="cmtrans"/>
    <MemberKey>
        <property name="CMIF_DocketLogDef::id"/>
    </MemberKey>
    <MemberKey>
        <property name="CMIF_DocketLogDef::myLocationsController"/>
    </MemberKey>
    <MemberKey>
        <property name="CMIF_DocketLogDef::myOperator"/>
    </MemberKey>
    <MemberKey>
        <property name="CMIF_DocketLogDef::species"/>
    </MemberKey>
    <MemberKey>
        <property name="CMIF_DocketLogDef::grade"/>
    </MemberKey>
    <MemberKey>
        <property name="CMIF_DocketLogDef::type"/>
    </MemberKey>
    <MemberKey>
        <property name="CMIF_DocketLogDef::treatment"/>
    </MemberKey>
    <MemberKey>
        <property name="CMIF_DocketLogDef::length"/>
    </MemberKey>
    <MemberKey>
        <property name="CMIF_DocketLogDef::isNoNumber"/>
    </MemberKey>
    <MemberKey>
        <property name="CMIF_DocketLogDef::myBol"/>
    </MemberKey>
    <JadeMethod name="logSummary" id="1affa7c3-63f4-4910-b940-b5e9ffcb92d3">
        <lockReceiver/>
        <updating/>
        <source>logSummary(_log : CM_Log) updating;

vars

	location		: CM_LocationsController;
	tmpDef			: CMIF_DocketLogDef;
	iter			: Iterator;


begin

	
	location := _log.getPrimaryLocation(REAL_MODE);

	if location &lt;&gt; null then
		tmpDef := self.getAtKey(location.getID(), location, _log.myOperator, _log.speciesCode, _log.gradeCode, _log.typeCode, _log.treatmentCode, _log.lengthCode, _log.isNoNumber, null);
		if tmpDef = null then
			create tmpDef transient;
			tmpDef.init(location, _log.myOperator, _log.speciesCode, _log.gradeCode, _log.typeCode, _log.treatmentCode, _log.lengthCode, _log.isNoNumber, 0, 0, null);
			self.add(tmpDef);
		endif;
		tmpDef.addTi(_log, true);
	endif;

epilog
	delete iter;
end;</source>
        <Parameter name="_log" type="CM_Log"/>
    </JadeMethod>
</CollClass>
