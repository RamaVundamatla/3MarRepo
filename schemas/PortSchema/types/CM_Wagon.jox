    <JadeMethod name="hasJobs" id="62442e28-00a0-4128-be22-f43938e748e4">
        <source>hasJobs() : Boolean;
// ---------------------------------------------------------------------------
// Created:		January  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 29/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
// ---------------------------------------------------------------------------

vars
	lTIArray : CM_TIArray;
	hasJob : Boolean;
	ti	: CM_TrackedItem;
begin
	create lTIArray transient;
	self.getAllTrackedItems(true, lTIArray, false);

	//Check for empty wagon
	if lTIArray.isEmpty then		
		return hasJob;
	endif;
	
	foreach ti in lTIArray do // includes nulls for empty controllers (10 foot spaces on the wagon)
		if ti.jobRailReceive &lt;&gt; null then
			hasJob := true;
			break;
		endif;
	endforeach;
	
	return hasJob;	
epilog
	delete lTIArray;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="hasMasterCargoRestriction" id="997bfe5d-6620-4ddc-b791-2103d4e80419">
