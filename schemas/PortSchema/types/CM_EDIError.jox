<Class name="CM_EDIError" id="40d7e5c9-e257-4bef-9062-ed65cfde8c3c">
    <superclass name="CM_Object"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>Persistent errors from EDI verify</text>
    <DbClassMap file="edi"/>
    <PrimAttribute name="errorCode" id="909f9a99-bc33-46a9-b3b0-0d0efa590dec">
        <embedded/>
        <type name="Integer"/>
        <access>readonly</access>
    </PrimAttribute>
    <PrimAttribute name="fieldName" id="56435fd6-b37e-4572-8066-4caed010ca68">
        <length>31</length>
        <embedded/>
        <type name="String"/>
        <access>readonly</access>
    </PrimAttribute>
    <ExplicitInverseRef name="myEDIData" id="a000b55c-d5eb-4bce-afbb-7720e727cdcd">
        <kind>child</kind>
        <transientToPersistentAllowed/>
        <embedded/>
        <type name="CM_EDIData"/>
        <access>readonly</access>
        <Inverse name="CM_EDIData::allErrorWarnings"/>
    </ExplicitInverseRef>
    <ImplicitInverseRef name="myUserObject" id="13d8d8fc-fbee-4025-98b4-fcdd69eb2c82">
        <embedded/>
        <type name="Object"/>
        <access>readonly</access>
    </ImplicitInverseRef>
    <PrimAttribute name="text" id="3d40ac27-f42e-458f-9f7d-6e1c519f8a3b">
        <type name="String"/>
        <access>readonly</access>
    </PrimAttribute>
    <PrimAttribute name="warningOnly" id="ec09ee4e-0d3b-4cfc-af6f-d35d2af004f7">
        <embedded/>
        <type name="Boolean"/>
        <access>readonly</access>
    </PrimAttribute>
    <JadeMethod name="set" id="7a69f74a-6ede-43a9-94ce-d27199dc6252">
        <updating/>
        <source>set(_errorCode : Integer; _text : String; _warningOnly : Boolean; _fieldName : String; _userObject : Object) updating;
//
// cnwrs1 par27392 13 Apr 2011
//
vars

begin
	self.errorCode := _errorCode;
	self.fieldName := _fieldName;
	
	if global.isValidObject(_userObject) and not _userObject.isTransient then
		self.myUserObject := _userObject;
	endif;
	
	self.text 			:= _text;
	self.warningOnly 	:= _warningOnly;
end;
</source>
        <Parameter name="_errorCode" type="Integer"/>
        <Parameter name="_text" type="String"/>
        <Parameter name="_warningOnly" type="Boolean"/>
        <Parameter name="_fieldName" type="String"/>
        <Parameter name="_userObject" type="Object"/>
    </JadeMethod>
    <JadeMethod name="setMyEDIData" id="297e63c4-bbb3-4a60-8302-615a2f647bbe">
        <updating/>
        <source>setMyEDIData(_ediData : CM_EDIData) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 June 2023	jlirs1	Initial creation ChangeRequest 57074: EUP - Ship Manifest EDI

*/

vars

begin
	self.myEDIData := _ediData;
epilog

end;</source>
        <Parameter name="_ediData" type="CM_EDIData"/>
    </JadeMethod>
</Class>
