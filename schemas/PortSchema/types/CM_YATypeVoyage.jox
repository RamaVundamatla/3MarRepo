    <JadeMethod name="isCMIFDataMatch" id="267f432d-644d-4aee-813d-846caa33abb4">
        <source>isCMIFDataMatch(_cmifRequest: CMIF_YAAutoPlan; _yaData: CM_YADataObjects): Boolean;
// -------------------------------------------
// Created 10 May 2005 by cnwdvb1
// -------------------------------------------
vars

begin
	
	return _cmifRequest.isVoyage_Match(_yaData);


end;</source>
