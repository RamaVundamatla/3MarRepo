    <JadeMethod name="getSelectedTableItem" id="d0f07872-f9a1-468e-b7f5-6233d49b6ae1">
        <source>getSelectedTableItem():Object;
/*
Date		Who		Reason
12 Mar 2013	cnwcs5	Initial Creation - CCMS POL 2097/par 31259
*/
vars
	table	:CM_DataTable;
	row		:Integer;
	result	:Object;
begin
	table	:= self.tblData;
	row		:= table.row;
	
	if row &lt;= table.fixedRows then
		return null;
	endif;
	
	result := table.accessRow (row).itemObject.Object;
	
	return result;
epilog

end;</source>
        <ReturnType type="Object"/>
    </JadeMethod>
