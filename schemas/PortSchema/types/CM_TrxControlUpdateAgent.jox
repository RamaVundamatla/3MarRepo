    <JadeMethod name="trxUpdatePartialVoyagEDIStatus" id="77c15a29-d38b-4254-93d9-9b3baf350b75">
        <updating/>
        <source>trxUpdatePartialVoyagEDIStatus(_ediData : CM_EDIDataVoyage; _validateOnly : Boolean; _failedVoyages, _successfulVoyages : StringArray; _errors : CM_ErrorSet; _passport : CM_Passport input) updating;
//
// Purpose:			Derive the correct status to set on EDI TIs for a Voyage object that has partial updates allowed
//					1. If there are any passport errors on individual EDI TIs, status is VERIFIED_ERRORS
//					2. If the voyage code from an individual EDI TI matches one of our successful voyage udpates.
//					   status is VERIFIED or DBLOADED (depending on _validateOnly setting)
//					3. For Qships / OnePort voyage EDI TIs, set the same status on all linked movements and vessel EDI TIs
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 11/08/2025	navdap1		Initial creation MTN-35604 NSW - Load Partial Voyage EDI
//
vars

begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	app.setContinueCMExceptions(true);
	
	beginTransaction;
	
	app.myUtilityUA.utlUpdatePartialVoyagEDIStatus(_ediData, _validateOnly, _failedVoyages, _successfulVoyages, _errors, _passport);
	
epilog
	self.finaliseActivityWithPassport(_passport);
end;</source>
        <Parameter name="_ediData" type="CM_EDIDataVoyage"/>
        <Parameter name="_validateOnly" type="Boolean"/>
        <Parameter name="_failedVoyages" type="StringArray"/>
        <Parameter name="_successfulVoyages" type="StringArray"/>
        <Parameter name="_errors" type="CM_ErrorSet"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxUpdatePassword" id="44809984-db18-4e9c-9343-6bc67a9ed3e2">
        <updating/>
        <source>trxUpdatePassword(pCheckOld : Boolean; pUserCode, pOldPass, pNewPass, pNewPass2 : String;
				_passport : CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:     07 March 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	tmpUser		: CM_User;
	userEdition	: Integer;
	
begin

	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	app.setContinueCMExceptions(true);
	
	app.myValUA.valUserPassword(pCheckOld, pUserCode, pOldPass, pNewPass, pNewPass2, tmpUser, userEdition);
	
	if (not _passport.noErrors()) then
		return;
	endif;

/* There are no warnings at this stage	
	if (not app.noWarnings()) then
		if (not app.showWarnings()) then
			cancelSave := true;
			return false;		// note that this gets "ignored" in the eplog
		endif;
	endif;
*/

	app.setContinueCMExceptions(false);
		
	beginTransaction;

	app.myUtilityUA.utlUpdatePassword(tmpUser, userEdition, pNewPass, _passport);
	
epilog	
	self.finaliseActivityWithPassport(_passport);
end;</source>
        <Parameter name="pCheckOld" type="Boolean"/>
        <Parameter name="pUserCode" type="String"/>
        <Parameter name="pOldPass" type="String"/>
        <Parameter name="pNewPass" type="String"/>
        <Parameter name="pNewPass2" type="String"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
