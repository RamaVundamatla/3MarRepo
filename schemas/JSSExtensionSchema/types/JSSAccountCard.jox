    <PrimAttribute name="cardNumber" id="1987e620-0406-455b-8ac7-258c566a0799">
        <length>51</length>
        <embedded/>
        <type name="String"/>
        <access>readonly</access>
    </PrimAttribute>
    <JadeMethod name="doValidateCardNumber" id="a80e36a3-a76a-4f84-9bad-6bba144d16ed">
        <source>doValidateCardNumber():Boolean protected, abstract;</source>
        <abstract/>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isValidNumber" id="22f530c2-307e-4834-aa6e-d7b326124314">
        <source>isValidNumber():Boolean;
// --------------------------------------------------------------------------------
// Created:		06 August 2002 by cnwdad2
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return self.doValidateCardNumber();
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="updateMe" id="8aab94da-8c8a-446b-9de1-b15cbd587609">
        <updating/>
        <source>updateMe(pCardNumber:String) updating;
// --------------------------------------------------------------------------------
// Created:		06 August 2002 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if self.cardNumber &lt;&gt; pCardNumber then
		self.cardNumber	:=	pCardNumber;
	endif;
end;</source>
        <Parameter name="pCardNumber" type="String"/>
    </JadeMethod>
</Class>
