    <JadeMethod name="colourRows" id="60c0092f-e711-4927-b08c-28cf0f061cbd">
        <source>colourRows() protected;
// colour each pair of rows the same colour to show that they are for the same delay
vars
	rowColour1,
	rowColour2	: Integer;
	backColour,
	idx, idx2, idx3	: Integer;
begin
	rowColour1			:= app.convertRGBToColor(255, 255, 232);
	rowColour2			:= app.convertRGBToColor(242, 242, 225);

	idx2 := (self.tblDelays.fixedRows + 1);
	foreach idx in idx2 to self.tblDelays.rows do
		idx3 := (idx+1) div 2;
		if idx3 mod 2 = 0 then
			backColour := rowColour1;
		else
			backColour := rowColour2;
		endif;			
		self.tblDelays.accessRow(idx).backColor := backColour;
	endforeach;
end;
</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doAddToTable" id="4d29ff6e-51fe-4e68-b68f-2de6b52635a1">
        <updating/>
        <source>doAddToTable(_row : Integer io; _delay : CM_Delay) updating, protected;
// add delay to table, using two rows. Also add delay to list of objects for notifications.
vars

begin
	_row := _row + 1;
	self.tblDelays.accessCell(_row,1).text := _delay.myDelayType.description;
	self.tblDelays.accessCell(_row,2).text := self.systemToLocalTime(_delay.startDT).asStringJMT();	// 9/6/16 cnwmp6 TFS 488 - Multi timezone support
	if _delay.myVoyage &lt;&gt; null then
		self.tblDelays.accessCell(_row,3).text := _delay.myVoyage.code;
	endif;
	self.tblDelays.accessRow(_row).itemObject := _delay;
	_row := _row + 1;
	self.tblDelays.accessCell(_row,1).text := self.systemToLocalTime(_delay.estEndDT).asStringJMT();	// 9/6/16 cnwmp6 TFS 488 - Multi timezone support
	self.tblDelays.accessCell(_row,2).text := self.systemToLocalTime(_delay.endDT).asStringJMT();	// 9/6/16 cnwmp6 TFS 488 - Multi timezone support
//	if _delay.myDriver &lt;&gt; null then
//		self.tblDelays.accessCell(_row,3).text := _delay.myDriver.code;
//	endif;
	self.tblDelays.accessCell(_row,3).text := _delay.getDriverWorkPointString;	//21 June 2012	NDL Par 29689
	self.tblDelays.accessRow(_row).itemObject := _delay;

	self.doNotableAdd(_delay);
end;
</source>
        <access>protected</access>
        <Parameter name="_row" type="Integer" usage="io"/>
        <Parameter name="_delay" type="CM_Delay"/>
    </JadeMethod>
    <JadeMethod name="doEndTime" id="c05bd18a-d7e9-4d46-8b6d-c77676febbe0">
        <updating/>
        <source>doEndTime() updating, protected;

vars
	row		: Integer;
	delay	: CM_Delay;
begin
	row := self.tblDelays.row;
	if row &lt; 3 then
		return;
	endif;
	delay := self.tblDelays.accessRow(row).itemObject.CM_Delay;
	self.doSave(delay);
end;
</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doNotableAdd" id="6545c5d8-a6ef-4e81-9b9a-3bc1639e53ce">
        <source>doNotableAdd(_delay :CM_Delay) protected;
// add delay to objects for notification
vars

begin
	// need to allow for notes already being registered for object
	self.allNotableObjects.addNoDuplicates(_delay, false);
	// using class notifications for adds/updates
	beginNotification(_delay, Object_Delete_Event, Response_Continuous, null);
epilog

end;
</source>
        <access>protected</access>
        <Parameter name="_delay" type="CM_Delay"/>
    </JadeMethod>
    <JadeMethod name="doNotableRemove" id="1d5508cd-a78c-494c-82aa-4852f2a851c3">
        <source>doNotableRemove(_delay :CM_Delay) protected;
// remove delay from list for notification
vars
	
begin
	if  self.allNotableObjects.includes(_delay) then
		self.allNotableObjects.remove(_delay);				// no exception even if invalid object
		self.endNotification(_delay, Object_Delete_Event);	// no exception even if invalid object
	endif;

end;</source>
        <access>protected</access>
        <Parameter name="_delay" type="CM_Delay"/>
    </JadeMethod>
    <JadeMethod name="doResizeControls" id="913b8974-45f9-4688-bead-f7db61d9e841">
        <updating/>
        <source>doResizeControls(_initialSetup: Boolean) updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 February 2015	cnwndl1	Initial creation	Par 35604

*/

vars

	stdWidth : Real;
	stdHeight : Real;
	cTop : Real;
	cHeight : Real;

begin

	self.setResizeableMarginAndFontSize();
	
	stdWidth := self.clientWidth - self.resizedMargin - self.resizedMargin;
	stdHeight := self.getStdControlHeight;
	
	
	self.lblVoyageMachine.move( 	self.resizedMargin,
									self.resizedMargin,
									stdWidth,
									stdHeight );
	
	cTop := self.lblVoyageMachine.top + self.lblVoyageMachine.height + self.resizedMargin;
	cHeight := self.clientHeight - cTop - ( 3 * self.resizedMargin ) - self.getCMDButtonsHeight();
	self.tblDelays.move(	self.resizedMargin, 
							cTop, 
							stdWidth, 
							cHeight
							);
	
	self.tblDelays.cnAdjustColumnWidths();
	
	inheritMethod(_initialSetup);

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_initialSetup" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doSave" id="31ac4412-ba6d-4cf5-b90c-b377b8e502ac">
        <updating/>
        <source>doSave(_delay : CM_Delay) : Boolean updating, protected;
// 'End Time' button click
vars
	errMess		: String;
	result		: Integer;
	delayProxy  : CM_Delay;
	theReturn 	: Integer;
	selectedObj : CM_Delay;
begin
	app.mousePointer := Window.MousePointer_HourGlass;
	
	delayProxy  := app.createUpdateProxy(_delay).CM_Delay;
	
	self.populateDelayForSave(delayProxy, _delay);
	
	while true do
		app.myTrxUA.trxUpdateDelay(delayProxy, app.myPassport);
		
		if app.myPassport.trxCompletedOK then
			return true;
		else
			//If there were warnings, give the user a chance to see them. If there are no errors they may decide to acknowledge
			//them and update anyway.
			result := app.showErrorWarningDialog(self.caption, app.myPassport, ErrWarnMode_Add + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   result = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		return false;
	endwhile;
	return true;
epilog	
	delete delayProxy;
	app.mousePointer := Window.MousePointer_Default;
end;
</source>
        <access>protected</access>
        <Parameter name="_delay" type="CM_Delay"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doSystemNotification" id="b44c9bab-5dac-4bdf-98f9-dac1870a9b44">
        <updating/>
        <source>doSystemNotification(_event : Integer; _object : Object; eventTag : Integer) updating, protected;
// on notificaiton receipt, use if in the list or if a new delay for the current voyage/machine
vars
	delay	: CM_Delay;
begin

	if _object.isKindOf(CM_Delay) then
		delay := _object.CM_Delay;
	else
		return;
	endif;

	if _event = Object_Delete_Event then
		self.updateObjectInTable(_event, delay, self.tblDelays);
		
		self.doNotableRemove (delay);	
	else		
		if self.allNotableObjects.includes (delay) or self.includeObject (delay) then 
			self.updateObjectInTable(_event, delay, self.tblDelays);
		endif;
	endif;
	
end;
</source>
        <access>protected</access>
        <Parameter name="_event" type="Integer"/>
        <Parameter name="_object" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getTableSize" id="922ae75a-d79d-4b9d-bf24-6915f5325b6e">
        <source>getTableSize(delayTypeGroup	: CM_DelayTypeGroup) : Integer protected;
// count the number of delays to be shown
vars
	size	: Integer;
	delay	: CM_Delay;
	filterDate	: TimeStamp;
begin
	filterDate := app.actualTimeServer().addHours(-24);	// 24 hours back
	if self.myVoyage &lt;&gt; null then
		foreach delay in self.myVoyage.allDelays do
			if delayTypeGroup &lt;&gt; null then
				if not delayTypeGroup.allDelayTypes.includes(delay.myDelayType) then
					continue;
				endif;
			endif;
			if self.myMachine &lt;&gt; null and
			   delay.myMachine &lt;&gt; self.myMachine then
				continue;
			endif;
			size := size + 1;
		endforeach;
	elseif self.myMachine &lt;&gt; null then
		foreach delay in self.myMachine.allDelays do
			if delayTypeGroup &lt;&gt; null then
				if not delayTypeGroup.allDelayTypes.includes(delay.myDelayType) then
					continue;
				endif;
			endif;
			if delay.endDT &lt;&gt; null and
			   delay.endDT &lt; filterDate then
				continue;
			endif;
			size := size + 1;
		endforeach;
	endif;
	
	return size;
end;</source>
        <access>protected</access>
        <Parameter name="delayTypeGroup" type="CM_DelayTypeGroup"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
