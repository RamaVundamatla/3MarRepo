    <JadeMethod name="getAuditText" id="19bd9e51-4a24-4950-80d3-235160366dc9">
        <source>getAuditText(): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03/08/2023	navkc1	CR 59552   Task 59554: Jade CustDocs - Country Region TRX

*/

vars
	audTxt, 
	tmpStr			: String;	
	tmpCountry		: CM_Country;
begin
	
	audTxt[10000] 	:= '*';
	audTxt			:= null;
	
	audTxt := inheritMethod();
	
	// Audit the Countries selected
	if self.allCountries.size() &gt; 0 then
		audTxt := audTxt &amp; self.allCountries.getName() &amp; AuditStringSeparator;
		
		foreach tmpCountry in self.allCountries do
			if tmpCountry &lt;&gt; null then
				tmpStr := tmpCountry.code &amp; " - " &amp; tmpCountry.description &amp; Cr &amp; tmpStr;
			endif;
		endforeach;
		
		audTxt := audTxt &amp; CM_CountryRegion::allCountries.name &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp;tmpStr &amp; AuditStringSeparator;
		
	endif;
	
	return audTxt;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="1f34e866-5e20-4f21-b066-942298e7246f">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03/08/2023	navkc1	CR 59552   Task 59555: UI CustDocs - Country Region Maint

*/

vars

begin
	if _attrName = ETRow_HomeRegionList then
		return self.homeRegion.getYesNo();
	elseif _attrName = ETRow_NafeList then
		return self.notAvailForEntry.getYesNo();
	else
		return inheritMethod(_attrName, _short);
	endif;

epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
