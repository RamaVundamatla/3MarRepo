    <JadeMethod name="generateSlotsFromTemplate" id="eeacc348-b45a-47f9-b945-67b757ea5d9b">
        <source>generateSlotsFromTemplate( _startDate, _endDate : Date);
/*

Purpose:			Generates vehicle booking time slots for the start date, end date and the user

Parameters:			_startDate	Date	The start date to use when generating slots
					_endDate	Date	The end date to use when generating slots
					_user		CM_User	The user who created the slots

Return Value:		NONE

Date				Who		Reason
10 April 2013		cnwndl1	Initial creation	Par 31393
*/

vars
	date				: Date;
	dayTemplate			: CM_VehicleBookingDayTemplate;
	existingTS			: TimeStamp;
	existingTimeSlot	: CM_VehicleBookingTimeSlot;

begin
	if not _startDate.isValid then
		app.raiseCMException(Invalid_start_date, null, null);
		return;
	endif;
	if not _endDate.isValid then
		app.raiseCMException(Invalid_end_date, null, null);
		return;
	endif;
	
	if self.allVehicleBookingDayTemplates.isEmpty then
		app.raiseCMException(Vehicl_schedu_templa_found_ter, null, null);
		return;
	endif;
	
	date := _startDate;
	existingTS.setTime("00:00".Time);
	
	while true do
		dayTemplate := self.allVehicleBookingDayTemplates.getFirstTemplateFor(date);
		
		if dayTemplate = null then
			app.raiseCMException1(No_Vehicl_schedu_defaul_templa, date.asStringJMT, null, null);
			return;
		endif;
		
		existingTS.setDate(date);
		existingTimeSlot :=  self.allBookingsByTS.getAtKeyGeq(existingTS,null);
		
		if existingTimeSlot = null or existingTimeSlot.bookingTSstart.Date &lt;&gt; date then
			if not dayTemplate.generateSlotsFromTemplate(date) then
				return;
			endif;
		endif;
		
		if date &gt;= _endDate then
			break;
		endif;
		
		date := date + 1;
	endwhile;
	
end;</source>
        <Parameter name="_startDate" type="Date"/>
        <Parameter name="_endDate" type="Date"/>
    </JadeMethod>
    <JadeMethod name="getAllMyDayTemplates" id="5af327bf-0234-4422-81a4-c4cfe69d08d1">
        <source>getAllMyDayTemplates( _all : CM_VehicleBookingDayTempDict input );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 April 2013	cnwndl1	Initial creation	Par 31393
Temporary until we get a reorg

*/

vars

	iter : Iterator;
	dayTemp : CM_VehicleBookingDayTemplate;
	
begin

	iter := CM_VehicleBookingDayTemplate.instances.createIterator;
	while iter.next( dayTemp ) do
		if dayTemp.myVehicleBookingTerminal = self then
			_all.add( dayTemp );
		endif;
	endwhile;

epilog

	delete iter;

end;</source>
        <Parameter name="_all" type="CM_VehicleBookingDayTempDict" usage="input"/>
    </JadeMethod>
