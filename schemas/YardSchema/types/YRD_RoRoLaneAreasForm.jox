    <JadeMethod name="moveTrackedItemSource" id="d59e5edc-d2b2-4e31-a7ed-4863ffc0ff7c">
        <updating/>
        <source>moveTrackedItemSource() updating; 
// ---------------------------------------------------------------------------
// Created:		January 2003 By Andrew Bishop cnwab1
//
// Purpose:		NOTE the TI and the Source Location are set in somewhere like frmGridArea_contextMenu on YRD_GridForm
//				NOTE this code is duplicated in CM_ContainerEnqForm
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	self.mousePointer := Window.MousePointer_HourGlass;
	if app.myMoveController = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'app.myMoveController = null');
		return;
	endif;
	
	app.myMoveController.moveTrackedItemSource(self.myTerminal);
	
epilog
	self.mousePointer := Window.MousePointer_Default;
end;</source>
    </JadeMethod>
    <JadeMethod name="moveTrackedItemsSource" id="2070923b-64a2-48ee-9968-5b9683eec439">
        <updating/>
        <source>moveTrackedItemsSource(_ydc : YRD_RoRoLaneDrawingController) updating; 
// ---------------------------------------------------------------------------
// Created:		7 September 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	theTIs : CM_TIArray;
begin
	
	self.mousePointer := Window.MousePointer_HourGlass;
	if app.myMoveController = null then
		return;
	endif;
	create theTIs transient;
	_ydc.allSelectedObjects.copy(theTIs);
	
	app.myMoveController.moveTrackedItemsSource(self.myTerminal,theTIs);
	
epilog
	delete theTIs;

	self.mousePointer := Window.MousePointer_Default;
end;</source>
        <Parameter name="_ydc" type="YRD_RoRoLaneDrawingController"/>
    </JadeMethod>
    <JadeMethod name="reArrangeTrackedItems" id="9ec9c222-0114-4a27-a930-61ddf491cb77">
        <updating/>
        <source>reArrangeTrackedItems(_rc : CM_RoRoController) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
13 January 2010	cnwjk3	Initial creation

*/

vars
	index,
	result			: Integer;
	ti				: CM_TrackedItem;
	arrTIs			: CM_TIArray;
	ordersDiffer,
	addedTI			: Boolean;
begin
	if self.myDroppedTI = null or _rc = null then
		return;
	endif;
	
	create arrTIs transient;
	
	// Re-order so that the dropped TI ends up before the one it 
	// landed on, or, at the end if it didn't land on one.
	foreach ti in _rc.allTrackedItems do
		if ti = self.myDroppedOntoTI then 
			arrTIs.add(self.myDroppedTI);
			addedTI := true;
		endif;
		if ti &lt;&gt; self.myDroppedTI then
			arrTIs.add(ti);
		endif;
	endforeach;

	if not addedTI then
		arrTIs.add(self.myDroppedTI);	
	endif;
	
	// check the order has actually changed before we bother with a move transaction.
	foreach index in 1 to arrTIs.size() do
		if arrTIs[index] &lt;&gt; _rc.allTrackedItems[index] then
			ordersDiffer := true;
		endif;
	endforeach;
	
	if not ordersDiffer then 
		return;
	endif;
	
	// Now do the Trx stuff
	while true do
		app.myTrxUA.trxUpdateSlotControllerShuffle(arrTIs, app.myPassport);			

		if app.myPassport.trxCompletedOK then
			// Clear errors/warnings from form and err/warnings window
			self.clearErrorWarnings();
			break;
		else
			result := app.showErrorWarningDialog('Re-order Cargo', app.myPassport, ErrWarnMode_Update + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and  result = IDOK then
				// there must have just been warnings that the user has acknowledged so ..
				app.myPassport.warningsAcknowledged	:= true;

				continue;
			endif;
			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
		endif;
		break;
	endwhile;
	
epilog
	delete arrTIs;
end;</source>
        <Parameter name="_rc" type="CM_RoRoController"/>
    </JadeMethod>
