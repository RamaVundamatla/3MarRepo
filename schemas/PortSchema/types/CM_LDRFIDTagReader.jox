    <JadeMethod name="pxyCreateUpdateProxy" id="c09fc285-372b-41a2-bf8d-dafca3b53204">
        <source>pxyCreateUpdateProxy(): SelfType;
// ---------------------------------------------------------------------------
// Created:     28 July 2009 by cnwcs5
// Purpose:     CCMS 1061 - gate config
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 20/04/2011	cnwmh5		PAR #27401 - Add code to handle prossible exceptions occurring when
//							trying to create the proxy
// ---------------------------------------------------------------------------
vars
	proxy	:SelfType;
	completedOK		: Boolean;
begin
	proxy :=  inheritMethod();

	proxy.myRFIDTagReader := self.myRFIDTagReader;
	
	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return proxy;
epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete proxy;
	endif;

end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="ece30d52-a56f-4afa-9976-f0c7ef3041a2">
        <updating/>
        <source>setForUpdate(_proxy: CM_LDRFIDTagReader) updating;
// ---------------------------------------------------------------------------
// Created:     28 July 2009 by cnwcs5
// Purpose:     CCMS 1061 - gate config
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	reader	:CM_RFIDTagReader;
begin
	inheritMethod(_proxy);

	if not _proxy.myRFIDTagReader.isTransient then
		self.myRFIDTagReader	:= _proxy.myRFIDTagReader;
	else
		reader := _proxy.myRFIDTagReader.pxyGetRealObject.CM_RFIDTagReader;
		
		if reader &lt;&gt; null then
			self.myRFIDTagReader := reader;
		else
			app.raiseUnexpectedProgramError (self.class.name, method.name, 'No tag reader');
		endif;
	endif;
epilog

end;</source>
        <Parameter name="_proxy" type="CM_LDRFIDTagReader"/>
    </JadeMethod>
    <JadeMethod name="setRFIDTagReader" id="0b610427-85e0-43f2-af9d-05b4946f4bd4">
        <updating/>
        <source>setRFIDTagReader(_reader :CM_RFIDTagReader)updating;
// ---------------------------------------------------------------------------
// Created:     29 June 2009 by concms1
// Purpose:     CCMS 1061 - Gate Config Changes  
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	self.raiseExceptionIfNotTransient (method);
	
	if self.myRFIDTagReader &lt;&gt; _reader then
		self.myRFIDTagReader := _reader;
	endif;
epilog

end;</source>
        <Parameter name="_reader" type="CM_RFIDTagReader"/>
    </JadeMethod>
    <JadeMethod name="setType" id="f5cfd3f7-4389-4fb9-9e66-5c50334561c8">
        <updating/>
        <source>setType(_type : Integer) updating;

/*
Date			Who		Reason
08 July 2009	cnwar2	Initial creation

*/
vars

begin
	self.raiseExceptionIfNotTransient (method);
	
	self.type := _type;
end;</source>
        <Parameter name="_type" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="validate" id="6c2c115b-5e47-419f-8592-59daeba69879">
        <source>validate(_passport: CM_Passport input)protected;
// ---------------------------------------------------------------------------
// Created:     22 June 2009 by concms1:1
// Purpose:     CCMS SFW 1047 - Totals Only Lists
// Parameters:  None
// Returns:     Nothing
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//2/9/2009		cnwjo3		change for par 20582 ccms 1061
// ---------------------------------------------------------------------------
vars
	ld				: CM_LaneDevice;
	readerArea, 
	laneArea		: CM_TerminalArea;
begin
	inheritMethod(_passport);

	if self.myRFIDTagReader = null then
		app.raiseUnexpectedProgramError (self.class.name, method.name, 'RFID Tag Reader required');
	endif;
	
	// the rfid tag reader must have the correct context - GUI should have taken care of this
	if self.myRFIDTagReader.context &lt;&gt; TagReaderContext_LaneDevice then
		app.raiseUnexpectedProgramError (self.class.name, method.name, 'Invalid context for RFID lane device');
	endif;
	
	/* rfid readers should probably only be used in one place -otherwise how will we
		know which location they area at */
	ld := self.pxyGetRealObject;
	
	if self.myRFIDTagReader.isTransient then
		// coming from rfid maintenance
		
	else
		// coming from gate/interchange area maintenance
		if self.myLaneController = null then
			app.raiseUnexpectedProgramError (self.class.name, method.name, 'Lane controller required');
		endif;
		// we should have already called CM_LaneController::validateRFIDTagReaderUsage to check that 
		// a reader is not referenced by &gt; 1 lane for the gate/interchange area.  
		// Check - the reader does not have any lane devices for other terminal areas (easy)
		readerArea := self.myRFIDTagReader.getLaneDeviceTerminalArea;
		
		if readerArea &lt;&gt; null then
			// persistent RFID tag reader is used somewhere it is used somewhere
			laneArea := self.myLaneController.myTerminalArea;
			
			// expect laneArea to be transient
			if laneArea &lt;&gt; null and laneArea.pxyIsProxy then 
				laneArea := laneArea.pxyGetRealObject;	// persistant
			endif;
			
			if laneArea = null or				// part of create of new area
				laneArea &lt;&gt; readerArea then		// this area not the same as area reader is used in
				// error
				app.raiseCMException1(RFID_reader_in_use, self.myRFIDTagReader.description, null, null);
			endif;
		endif;
	endif;
	
	return;	// added by christina 11/09/2009
	
	//cnwjo3 par 20582, the lane controller that the rfid tag reader is currently set to
/*	if self.myRFIDTagReader &lt;&gt; null then
		if self.myRFIDTagReader.allLaneDevices.size &gt; 0 then
			if self.myRFIDTagReader.allLaneDevices.first.myLaneController &lt;&gt; null then
				if self.myRFIDTagReader.allLaneDevices.first.myLaneController.isKindOf(CM_YardICAreaLaneController) then
					yicalc1 := self.myRFIDTagReader.allLaneDevices.first.myLaneController.CM_YardICAreaLaneController;
				endif;
			endif;
		endif;
	endif;
	
	//cnwjo3 par 20582, the current lane controller we are editing
	if self.myLaneController &lt;&gt; null then
		if self.myLaneController.isKindOf(CM_YardICAreaLaneController) then
			yicalc2 := self.myLaneController.CM_YardICAreaLaneController;
		endif;
	endif;
	
	if yicalc1 &lt;&gt; null and yicalc2 &lt;&gt; null then
		if yicalc1.myTerminalArea.id = yicalc2.myTerminalArea.id then  //making the assumption terminal areas can't have the same id
			inSameTA := true;
		endif;
	endif;
	
	if ld = null and not self.myRFIDTagReader.allLaneDevices.isEmpty then
		//added condition here so it works better for CM_YardICAreaLaneController, cnwjo3 ccms 1061 par 20522
		if not inSameTA then
			// we are adding new lane device and the rfid tag reader is already used somewhere else
			app.raiseCMException1(RFID_reader_in_use, self.myRFIDTagReader.description, null, null);
		endif;
	endif;
	*/
epilog
	
end;</source>
        <access>protected</access>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
</Class>
