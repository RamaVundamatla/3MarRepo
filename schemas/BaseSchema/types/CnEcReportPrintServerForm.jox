//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
//	tblQueue.loadCollectionEntries;
	tblQueue.displayCollection(app.myBaseRoot.allReportQueueEntries, true, 0, null);
end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="tblQueue_click" id="8c3c995e-6901-4111-9126-17352142c26f">
        <controlMethod name="Table::click"/>
