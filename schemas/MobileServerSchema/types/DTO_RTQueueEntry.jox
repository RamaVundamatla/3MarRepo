    <JadeMethod name="isForDirectorTask" id="12f5a0f2-31fb-4c10-bf4b-eab3531b6a30">
        <source>isForDirectorTask() : Boolean;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
07 May 2010	cnwer1	Initial creation
11/03/2011	cnwmh5	PAR #27142 - Change to local variable rather than self for handleDeleteObject exception
*/

vars
	invalidObject : Boolean;
	rtQueueEntry   :  CM_RTQueueEntry;
	objEdition		: Integer;
begin

	rtQueueEntry:=self.myRealQueueEntry.CM_RTQueueEntry;
	if rtQueueEntry = null then
		return false;
	endif;
	
	on Exception do app.handleDeletedObject(exception, rtQueueEntry,invalidObject);
	
	objEdition:=rtQueueEntry.edition;
	if invalidObject then
		return false;
	endif;
	
	return rtQueueEntry.getTaskOfType(TASK_DIRECTOR,TASK_ACCEPTED) &lt;&gt; null;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="loadToTable" id="c9c7a962-5c34-47f2-a1ae-ef68279c0725">
        <updating/>
        <source>loadToTable(_table : Table input;
			_view 	: EntTableView;
			_headerIsTopRow : Boolean;
			_newPostion,
			_rtOrder : Integer;
			_visible : Boolean) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
27 August 2010	cnwer1	Initial creation

*/

vars

begin
	//if there is a package we know this is the gdansk app
	if appContext.initialPackage &lt;&gt; null then
		self.loadToTablePackage(_table,_newPostion,_rtOrder);
	else
		self.loadToTableVMApp(_table,_view,	_headerIsTopRow ,_newPostion,_rtOrder,_visible);	
	endif;
epilog

end;</source>
        <Parameter name="_table" type="Table" usage="input"/>
        <Parameter name="_view" type="EntTableView"/>
        <Parameter name="_headerIsTopRow" type="Boolean"/>
        <Parameter name="_newPostion" type="Integer"/>
        <Parameter name="_rtOrder" type="Integer"/>
        <Parameter name="_visible" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="loadToTablePackage" id="a2351b0b-04fb-42d8-b1c7-12673417ae3a">
        <updating/>
        <source>loadToTablePackage(	_table : Table input;
					_newPostion,
					_rtOrder : Integer	) updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
27 August 2010	cnwer1	Initial creation

*/

vars

	tableLine : String;
	row : JadeTableRow;
	cell	: JadeTableCell;
begin
	

	tableLine:=self.type &amp; Tab &amp; 
				self.moveVehicleID &amp; Tab &amp; 
				self.containerID &amp; Tab &amp; 
				self.queuedLocationID &amp; Tab &amp; 
				self.timeElapsedInMins.asStringJMT  &amp; Tab &amp; 
				self.isOverstow.getYesNo &amp; Tab &amp;
				self.isHazardous.getYesNo  &amp; Tab &amp; _rtOrder.String;
	row:=_table.accessRow(_newPostion);
	cell:=_table.accessCell(_newPostion,1);
	cell.text:=tableLine;
	//_table.addItemAt(tableLine,_newPostion);
	if row &lt;&gt; null then
		row.itemObject:=self;
	endif;	

	self.oldRow:=self.newRow;
	self.newRow:=_newPostion;	

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_table" type="Table" usage="input"/>
        <Parameter name="_newPostion" type="Integer"/>
        <Parameter name="_rtOrder" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="loadToTableVMApp" id="8041970d-5a3e-4733-a75e-f35a759ba1ab">
        <updating/>
        <source>loadToTableVMApp(_table : Table input;
				_view 	: EntTableView;
				_headerIsTopRow : Boolean;
				_newPostion,
				_rtOrder : Integer;
				_visible : Boolean) updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
25 August 2010	cnwer1	Initial creation

*/

vars
	entTableRow : EntTableRow;
	i			: Integer;
	cellText : String;
	highlightRed : Boolean;
	accessedRow	: JadeTableRow;
	accessedColumn	: JadeTableColumn;
	accessedCell : JadeTableCell;
begin
	
	if _table = null then
		return;
	endif;

	i:=1;
	foreach entTableRow in _view.allEntTableRows do
	
		cellText:=self.getDisplayStringForAttribute(entTableRow.name,false);
		highlightRed:=false;
		if entTableRow.name = ETRow_Ostow then
			if cellText &lt;&gt; null then
				highlightRed:=true;
			endif;
		endif;

		if _headerIsTopRow then
			if i &lt;= _table.columns  then						// 25/11/2011 cnwmh5 #28685
				accessedCell:=_table.accessCell(_newPostion,i);
				accessedCell.text:=cellText;
				if highlightRed then
					accessedCell.foreColor:=Red;
				endif;
				accessedRow:=_table.accessRow(_newPostion);
				accessedRow.itemObject:=self;
				accessedRow.fontBold:=false;
				accessedRow.marginTop:=2;
				accessedRow.marginBottom:=2;
				accessedRow.visible:=_visible;
			endif;
		else
			if i &lt;= _table.rows then						// 25/11/2011 cnwmh5 #28685
				accessedCell:=_table.accessCell(i,_newPostion);
				accessedCell.text:=cellText;
				if highlightRed then
					accessedCell.foreColor:=Red;
				endif;
				accessedColumn:=_table.accessColumn(_newPostion);
				accessedColumn.itemObject:=self;
				accessedColumn.fontBold:=true;
				accessedColumn.marginLeft:=5;
				accessedColumn.marginRight:=5;
				accessedColumn.visible:=_visible;
			endif;
		endif;
		self.oldRow:=self.newRow;
		self.newRow:=_newPostion;
		i:=i+1;
	endforeach;
	
	if _rtOrder &lt;&gt; 0  then
		if _headerIsTopRow then
		
			//epr PAR 28458 14/10/11
		
			if i &lt;= _table.columns then
				_table.accessCell(_newPostion,i).text:=_rtOrder.String;
			endif;
			
		else
			if i &lt;= _table.rows then
				_table.accessCell(i,_newPostion).text:=_rtOrder.String;
			endif;
		endif;
	endif;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_table" type="Table" usage="input"/>
        <Parameter name="_view" type="EntTableView"/>
        <Parameter name="_headerIsTopRow" type="Boolean"/>
        <Parameter name="_newPostion" type="Integer"/>
        <Parameter name="_rtOrder" type="Integer"/>
        <Parameter name="_visible" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setFromPersistent" id="d8f8fbdd-b8cb-4a29-a054-92ff4e1ac024">
        <updating/>
        <source>setFromPersistent(_obj: CM_RTQueueEntry) updating;

/*

Purpose:			


Return Value:		


Date		Who		Reason
29 Feb 2008	cnwkpd1	PAR #16010 - CCMS Otago 1502 - Thin Client RT Enhancements

*/

vars
	task			: CM_RTQueueTask;
	ti				: CM_TrackedItem;
	type,
	doorDirection	: String;
	vehicleId : String;
	containerId : String;
	locationId : String;
	time  : Integer;
	ostow ,
	ostowMoveTime,
	hazard: Boolean;
	job : CM_Job;
	wle : CM_WorkListEntry;
	vvr : CM_VehicleVisitRecord;
	setdownRTTask,
	rtTask : CM_RTQueueTask;
	targetLocation: CM_LocationsController;
	imvTwinFlag	: Integer;
	imvTwinPosition : String;
	terminal 	: CM_Terminal;
	container 	: CM_Container;
	stmp : String;
	relCarrier : CM_Carrier;
	invalidObj : Boolean;
	edition : Integer;
begin
	on Exception do app.handleDeletedObject(exception, _obj, invalidObj);
	//machine := 
	edition:=_obj.edition;
	if invalidObj then
		return;
	endif;
	
	inheritMethod(_obj);
	

	
	job:=_obj.myJob;
	wle:=_obj.myWorkListEntry;
	
	rtTask:=_obj.getDirectorOrPickupTask();
	
	
	if rtTask.isPickUp then
		setdownRTTask:=_obj.getDirectorOrSetDownTask(); 
	else
		setdownRTTask:=	rtTask;
	endif;
		
	self.jobID:=job.jobId;
	terminal:=_obj.getMyTerminal();
	
	self.taskStatus:=rtTask.statusString;
	if wle &lt;&gt; null then
		ti:=wle.myTrackedItem;
				
		if wle.myRequest &lt;&gt; null then
			doorDirection:=wle.myRequest.getDoorDirectionDescription(wle.getTargetLocation(), wle.myTrackedItem);
		endif;
		
		type:=job.getJobTypeForWLE(wle);
		
		if job.isKindOf(CM_RoadJob) then
			vvr:=job.CM_RoadJob.myVehicleVisit;
			vehicleId:=job.CM_RoadJob.myVehicle.regNumber;
			if vvr &lt;&gt; null then
				time := vvr.getElapsedTime();		// PAR 16390
			endif;
			//17 Oct 2012	NDL	Par 30110
			if job.CM_RoadJob.isRelease then
				relCarrier := job.CM_RoadJob.myCarrier;
				if relCarrier &lt;&gt; null then
					self.carrier := relCarrier.code;
				else
					self.carrier := job.CM_RoadJob.carrierId;
				endif;
			endif;
			
		else
			time := (app.actualTimeServer.getDifferenceInMinutes(rtTask.createdTime) + 1);	// PAR 16390
		endif;
		
		containerId:=null;
		self.isHazardous:=false;
		self.isoType:=null;
		if ti &lt;&gt; null then
			self.isHazardous:=ti.isHazardous;
			self.description := ti.getQueueTaskID(); 
			if self.carrier = null then	//17 Oct 2012	NDL	Par 30110
				self.carrier := ti.carrier;//20/12/2010 cnwdz2 26582
			endif;
			self.isoType:=ti.getISOType;
			self.operator:=ti.operatorCode;
			self.remarks:=ti.remarks[1:30];
			self.imexStatus:=ti.getImExStatusString();
			self.commodity:=ti.commodity;
			self.dischargePort:=ti.dischargePortDescription[1:30];  // PAR 25095
			self.consignee:=ti.consignee;
			self.subTerminal:=ti.subTerminalCode;
			//self.todoTasks:=ti.getToDoTasksToDo();
			self.todoTasks:=ti.getToDoTasksToDo()[1:30];	// 18 May 2011	NDL	Par 27562
			self.tempC:=ti.getDisplayTemperature(false, true);
			self.tempF:=ti.getDisplayTemperature(false, false);
			//self.weight:=ti.getTotalWeightDisplay();
			self.weight:=ti.getDefaultTotalWeightDisplay();	//06 Dec 2013	NDL	Par 33135
			if ti.canSetAvailabilityGrade then
				self.grade:=ti.getAvailabilityGradeDesc;
			endif;
	
			self.isOverstow:=ti.isOverStowed(REAL_MODE); //epr TFS 37584 10/5/18
		else
			self.description := rtTask.tiId;			
			
			//cnwrd1 par 25441 17.8.2010
			stmp := wle.myRequest.getAVGrade();  
			if stmp.length &gt; self.grade.maxLength then
				self.grade := stmp[1:self.grade.maxLength];
				self.grade[self.grade.maxLength] := '.';
				self.grade[self.grade.maxLength -1] := '.';
				self.grade[self.grade.maxLength -2] := '.';
			else
				self.grade := stmp;
			endif;
			
			self.isoType:= wle.myRequest.getISOType();
			self.operator:= wle.myRequest.getOperatorCode();
			//cnwrd1 par 25441 17.8.2010
			self.remarks := wle.myRequest.getRemarks[1:30]; // 08 Feb 2018	NDL	TFS 36946
		endif;	
		
		if vehicleId = null then
			if _obj.isSourceAMachine then
				vehicleId:=rtTask.getSpecialTargetDisplay(true);
				if terminal.machines[vehicleId] = null then
					vehicleId:=null;
				endif;
			elseif _obj.isTargetAMachine then
				vehicleId:=rtTask.getSpecialTargetDisplay(false);
				if terminal.machines[vehicleId] = null then
					vehicleId:=null;
				endif;
			elseif rtTask.sourceLocation &lt;&gt; null and  rtTask.sourceLocation.isKindOf(CM_VehicleController) then
				vehicleId:=rtTask.sourceLocation.getFullId;
			elseif rtTask.targetLocation &lt;&gt; null and  rtTask.targetLocation.isKindOf(CM_VehicleController) then
				vehicleId:=rtTask.targetLocation.getFullId;
			endif;
		endif;
		
		//epr par 25392 12/8/10
		self.originalSourceLocID:=wle.getOriginalTaskSourceLocId;
		self.finalTargetLocID:=wle.getFinalTaskTargetLocId;
	endif;
		
	
	
	self.containerID:=rtTask.getTaskId()[1:30];  //epr par 31707
	self.currentLocationID:=rtTask.getSourceLocationExtra;    // epr par 30007 23/10/12 was getSourceLocationId;
	if setdownRTTask &lt;&gt; null then //cnwrd1 par 26734 CCMS 2014 plan on pickup
		self.queuedLocationID:=setdownRTTask.getTargetLocationForDisplay; //getTargetLocationExtra; // epr par 30007 23/10/12 was getTargetLocationForDisplay;
	else
		self.queuedLocationID := app.getErrorString(Autoplan);
	endif;
	self.type:=type;
	self.moveVehicleID:=vehicleId;
	//self.isOverstow:=ostow;
	self.timeElapsedInMins:=time;
	if rtTask.status = TASK_COMPLETE and setdownRTTask &lt;&gt; null then
		self.taskStatus:= setdownRTTask.statusString;
	else
		self.taskStatus:= rtTask.statusString;
	endif;
	self.doorDirection :=doorDirection;
	self.queueID:=rtTask.queueId;
	self.myRealQueueEntry := _obj;

	
epilog
	
end;
</source>
        <Parameter name="_obj" type="CM_RTQueueEntry"/>
    </JadeMethod>
    <JadeMethod name="setOverstowForMachine" id="e0ba7e3a-a9a3-40bc-a122-cd76a2a67af5">
        <updating/>
        <source>setOverstowForMachine(_machine : CM_Machine input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 May 2018	jlger1	Initial creation 37584 

*/

vars
	ti : CM_TrackedItem;
	overstowController : CMIF_OverstowController;
begin
	if _machine = null then
		return;
	endif;
	ti:=self.getTI();
	if ti = null then
		return;
	endif;
	
	create overstowController transient;
	overstowController.setParams(null,ti,false,null,_machine);
	self.isOverstow:=overstowController.getAllOverstows();
epilog
	delete overstowController;
end;</source>
        <Parameter name="_machine" type="CM_Machine" usage="input"/>
    </JadeMethod>
</Class>
