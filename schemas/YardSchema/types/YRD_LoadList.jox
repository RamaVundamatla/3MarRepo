    <JadeMethod name="updateProgress" id="d60300df-f21e-4624-ab28-30ca0c8b168d">
        <updating/>
        <source>updateProgress(_cmifMonitor: CMIF_Monitor input) updating;
// ---------------------------------------------------------------------------
// Created:     31 October 2003	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars

begin
	if self.frmModalDialog.visible then
		self.modalDialogShow(null,app.getErrorString(ReturnData),app.getErrorString(Cancel),null,
						_cmifMonitor.message,
						app.getErrorString(Searched) &amp; _cmifMonitor.partsInJob.String &amp; '  ' &amp; app.getErrorString(Found) &amp; ' ' &amp; _cmifMonitor.partsDone.String);
	endif;
		
	self.btnModalDefault.doWindowEvents(0);
	if self.modalDialogReturnValue = ModalDialogReturn_Null then
		// see if the user has pressed the Cancel button
		self.btnModalOpt1.doWindowEvents(0);
		self.btnModalOpt2.doWindowEvents(0);
		
	endif;

	if self.modalDialogReturnValue = self.ModalDialogReturn_Default then
		_cmifMonitor.monitorReturnValue := _cmifMonitor.MonitorReturnValue_Return;
	elseif self.modalDialogReturnValue = self.ModalDialogReturn_Option1 then
		_cmifMonitor.monitorReturnValue := _cmifMonitor.MonitorReturnValue_Cancel;
	endif;

end;</source>
        <Parameter name="_cmifMonitor" type="CMIF_Monitor" usage="input"/>
    </JadeMethod>
    <JadeMethod name="updateShtCaptions" id="f9f90db2-f021-48ee-97ba-95233a7b996d">
        <source>updateShtCaptions();
// ---------------------------------------------------------------------------
// Created:		25 August 2005  By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
//	08 Dec 2011	NDL	Par 28797

vars
	rows			: String;
	intRow,
	visRows,
	tmpInt			: Integer;
begin

	if self.mode &lt;&gt; self.Mode_SummarySelection then
		self.shtPlanned.caption :=app.getErrorString(Planned) &amp; " (" &amp; (self.tblPlanned.rows - self.tblPlanned.fixedRows).String &amp; ")";
		self.shtNonplanned.caption := app.getErrorString(SHP_Non_Plann01) &amp; " (" &amp; (self.tblData.rows - self.tblData.fixedRows).String &amp; ")";
		tmpInt := self.tblAll.rows - self.tblAll.fixedRows;
		if tmpInt &lt;&gt; 0 then
			self.shtAll.caption := app.getErrorString(LOADLIST_ALL) &amp; " (" &amp; (self.tblAll.rows - self.tblAll.fixedRows).String &amp; ")";
		else
			self.shtAll.caption := app.getErrorString(LOADLIST_ALL);
		endif;
	else
		//planned
		rows := (self.tblPlanned.rows - self.tblPlanned.fixedRows).asStringJMT;
		visRows := 0;
		foreach intRow in self.tblPlanned.fixedRows+1 to self.tblPlanned.rows do
			if self.tblPlanned.accessRow(intRow).visible then
				visRows := visRows + 1;
			endif;
		endforeach;
		self.shtPlanned.caption :=app.getErrorString(Planned) &amp; " (" &amp; visRows.String &amp; "/" &amp; rows &amp; ")";
		
		//unplanned
		rows := (self.tblData.rows - self.tblData.fixedRows).asStringJMT;
		visRows := 0;
		foreach intRow in self.tblData.fixedRows+1 to self.tblData.rows do
			if self.tblData.accessRow(intRow).visible then
				visRows := visRows + 1;
			endif;
		endforeach;
		self.shtNonplanned.caption := app.getErrorString(SHP_Non_Plann01) &amp; " (" &amp; visRows.String &amp; "/" &amp; rows &amp; ")";
		
		//all
		if self.tblAll.rows &gt; self.tblAll.fixedRows then
			rows := (self.tblAll.rows - self.tblAll.fixedRows).asStringJMT;
			visRows := 0;
			foreach intRow in self.tblAll.fixedRows +1 to self.tblAll.rows do
				if self.tblAll.accessRow(intRow).visible then
					visRows := visRows + 1;
				endif;
			endforeach;
			self.shtAll.caption := app.getErrorString(LOADLIST_ALL) &amp; " (" &amp; visRows.String &amp; "/" &amp; rows &amp; ")";		
		else
			self.shtAll.caption := app.getErrorString(LOADLIST_ALL);
		endif;
	endif;

	if self.fldMain.topSheet = self.shtNonplanned then
		self.frmStatLine.caption := self.statusStub &amp; " " &amp; app.getErrorString(SHP_Selected) &amp; self.tblData.allSelectedObjects.size.asStringJMT;
	elseif self.fldMain.topSheet = self.shtPlanned then
		self.frmStatLine.caption := self.statusStub &amp; " " &amp; app.getErrorString(SHP_Selected) &amp; self.tblPlanned.allSelectedObjects.size.asStringJMT;
	elseif self.fldMain.topSheet = self.shtAll then
		self.frmStatLine.caption := self.statusStub &amp; " " &amp; app.getErrorString(SHP_Selected) &amp; self.tblAll.allSelectedObjects.size.asStringJMT;
	endif;

end;</source>
    </JadeMethod>
    <JadeMethod name="updateSummaryBulkRelFromNote" id="a8be1535-85e9-460a-a199-e0d47978613e">
        <updating/>
        <source>updateSummaryBulkRelFromNote(_release : CM_BulkRelease) updating;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18/11/2010	cnwdap1	Initial creation PAR #23794 CCMS MES 1102
20/07/2018	jlgmd1	TFS #39261 SNO - Show Reserve Detail lines on Load List
*/
vars
	release				: CM_BulkRelease;
	invalid				: Boolean;
	code				: String;
	trainCode			: String;
	destinationPort		: String;
	sumDict				: CMIF_LoadListSumByTrainDestISO;
	sumObjectOld		: CMIF_LoadListSummaryObject;
	sumObjectCurrent	: CMIF_LoadListSummaryObject;
	sumObjectNew		: CMIF_LoadListSummaryObject;
	detail				: CM_ReserveDetail;
	goodSumSet			: CMIF_LoadListSummaryObjectSet;

begin
	if self.mySummaryReport = null 
	or self.mySummaryReport.allGroupedObjects.isEmpty 
	or _release = null then
		return;
	endif;
	release := _release;

	on Exception do app.handleDeletedObject(exception, release, invalid);
	code := release.code;
	if invalid then
		return;
	endif;
	
	sumDict := self.summarySortDictTrain;
	sumDict.clear();
	self.mySummaryReport.allGroupedObjects.copy(sumDict);
	create goodSumSet transient;
	
	if release.myAssignedTrain = null then
		trainCode := app.getErrorString(Not_Assigned);
	else
		trainCode := release.myAssignedTrain.code;
	endif;
	if release.myDestinationPort &lt;&gt; null then
		destinationPort := release.myDestinationPort.code;
	endif;
	
	foreach detail in release.allReserveDetails discreteLock do
	
		sumObjectCurrent := sumDict[trainCode, destinationPort, detail.getPlannerReportGroup];
		
		// ADD new Reserve Detail lines
		if sumObjectCurrent = null then
			if trainCode &lt;&gt; app.getErrorString(Not_Assigned) then
				create sumObjectNew transient;
				sumObjectNew.train				:= trainCode;
				sumObjectNew.destinationPort	:= destinationPort;
				sumObjectNew.isoGroupingKey		:= detail.getPlannerReportGroup;
				sumObjectNew.isoGroupingCode	:= detail.getPlannerReportGroupDesc;
				
				sumDict.add(sumObjectNew);
				sumObjectNew.allReserveDetails.add(detail);
				sumObjectNew.totalsForBulkRelease(detail, CMIF_LoadListSummaryObject.MODE_ADD);
				self.mySummaryReport.addObject(sumObjectNew);
				
				sumObjectCurrent := sumObjectNew;
			endif;
		else
		// UPDATE existing Reserve Detail lines
			sumObjectCurrent.totalsForBulkRelease(detail, CMIF_LoadListSummaryObject.MODE_UPDATE);
		endif;
		
		// Keep track of all the current summary objects so we can remove old ones later
		if sumObjectCurrent &lt;&gt; null and not goodSumSet.includes(sumObjectCurrent) then
			goodSumSet.add(sumObjectCurrent);
		endif;
		
	endforeach;
	
	// DELETE any removed Reserve Detail lines
	foreach sumObjectOld in sumDict discreteLock do
		if not goodSumSet.includes(sumObjectOld) then
			self.mySummaryReport.removeObject(sumObjectOld);
		endif;
	endforeach;
	sumDict.clear();
	self.mySummaryReport.allGroupedObjects.copy(sumDict);
	
epilog

end;</source>
        <Parameter name="_release" type="CM_BulkRelease"/>
    </JadeMethod>
    <JadeMethod name="updateSummaryFromEDI" id="9edb5d11-c3f6-4527-bb1e-824a53385559">
        <updating/>
        <source>updateSummaryFromEDI() updating, protected;
//----------------------------------------------------------------
//	Created:	30 September 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	sumDict				: CMIF_LoadListSumByTrainDestISO;	//CMIF_LoadListSumByImexDischISO;
	sumObjectOld,
	sumObject			: CMIF_LoadListSummaryObject;
	deleteSum			: Boolean;
	sr					: CM_SlotRequest;
begin
	//remove the SR

	if self.mySummaryReport = null 
	or self.mySummaryReport.allGroupedObjects.isEmpty then
		return;
	endif;
	
	create sumDict transient;	//think about keeping this on the form

	self.mySummaryReport.allGroupedObjects.copy(sumDict);
	
	//search for it (also see if old sumObj is still required)
	foreach sumObject in sumDict do
		deleteSum := (sumObject.allTrackedItems.isEmpty) and (sumObject.allLoadRequests.isEmpty);
		if deleteSum then
			self.mySummaryReport.removeObject(sumObject);
		endif;
	endforeach;
	
epilog
	delete sumDict;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="updateSummaryTI" id="845740a0-4c8e-4659-ad60-0663e75d138e">
        <updating/>
        <source>updateSummaryTI(_ti : CM_TrackedItem; _waitForNotes : Boolean)updating, protected;
//----------------------------------------------------------------
//	Created:	21 September 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	sumDict			: CMIF_LoadListSumByTrainDestISO;	//CMIF_LoadListSumByImexDischISO;
	sumObjectNew,
	sumObjectCurrent,
	sumObjectOld,
	sumObject		: CMIF_LoadListSummaryObject;
	deleteSum,
	breakOut,
	foundTI,
	newSum,
	matchesCriteria	: Boolean;
//	imexKey 	: Integer;
	intRow	: Integer;
	ti				: CM_TrackedItem;
	startTime		: TimeStamp;
	trainCode : String;
	
begin
	if self.mySummaryReport = null 
	or self.mySummaryReport.allGroupedObjects.isEmpty then
		return;
	endif;

	if self.mySummaryFilterTrain = null then
		return;
	endif;
	//
	//  Replaced by cnStartTransaction in doCentralisedTINoteUpdate PAR 21787
	//
	//startTime := app.actualTimeServer();
	//app.lockKeeperNotifyStartActivity(startTime, method, null, 'Updating loadlist summary', app.myPassport);
	
	self.resetSummaryCriteria();
	sumDict := self.summarySortDictTrain;
	sumDict.clear();
	self.mySummaryReport.allGroupedObjects.copy(sumDict);

	foreach ti in self.allTIsSummaryUpdate do	
		if not global.isValidObject(ti) then
			self.allTIsSummaryUpdate.remove(ti);
			continue;
		endif;
		
		matchesCriteria := self.mySummaryFilterTrain.checkStatusIncludesObject(ti, app.myPassport, breakOut);
		sumObjectOld := null;
		deleteSum := false;
		foundTI := false;
		newSum := false;
		
		if ti.myTrainAssigned = null then
			trainCode := app.getErrorString(Not_Assigned);
		else
			trainCode := ti.myTrainAssigned.code;
		endif;
		
		sumObjectCurrent := sumDict[trainCode, ti.destinationPort,ti.getPlannerReportGroup];
		
		// par 11095 - summary is being updated when ANY new pre-note is created. 
		if not ti.includeOnLoadListTrain(self.myCurrentTrain, self.myTerminal) then 
			// now need to check if in table if so, summary will need to be updated. (will be removed from table in by calling code.) 
			if self.tblData.findObjectInRow(ti, intRow) then
				sumObjectOld := sumObjectCurrent; // setting this will remove ti from summary.
			else		
				continue; 

			endif;
		endif;
		
		if sumObjectCurrent = null then
			//either changed or new
			newSum := true;
		else
			//changed?
			if sumObjectCurrent.allTrackedItems.includes(ti) then
				if sumObjectCurrent.imexStatus = 6 and not ti.isRehandle then // PAR 11070
					deleteSum := (sumObjectCurrent.allTrackedItems.size = 1) and (sumObjectCurrent.allLoadRequests.isEmpty); // PAR 11070
					sumObjectOld := sumObjectCurrent; // PAR 11070
					foundTI := true;
				else
					foundTI := true;
				endif;
			endif;
		endif;
	
		if not foundTI then
			//search for it (also see if old sumObj is still required)
			foreach sumObject in sumDict do
				if sumObject.allTrackedItems.includes(ti) then
					deleteSum := (sumObject.allTrackedItems.size = 1) and (sumObject.allLoadRequests.isEmpty);
					sumObjectOld := sumObject;
					break;	
				endif;
			endforeach;
		endif;
		
		if newSum and matchesCriteria then
			create sumObjectNew transient;
			//sumObjectNew.setFromTI(ti, imexKey);
			sumObjectNew.train := trainCode;
			sumObjectNew.destinationPort := ti.destinationPort;
			sumObjectNew.isoGroupingKey := ti.getPlannerReportGroup();
			sumObjectNew.isoGroupingCode := ti.getPlannerReportGroupDesc();
			
			sumDict.add(sumObjectNew);
			sumObjectNew.allTrackedItems.add(ti);
			sumObjectNew.totalsForTi(ti, CMIF_LoadListSummaryObject.MODE_ADD);
			self.mySummaryReport.addObject(sumObjectNew);
		endif;
	
		if sumObjectCurrent &lt;&gt; null then
			//this will pickup change in planning state
			if (not foundTI) and matchesCriteria then
				sumObjectCurrent.allTrackedItems.add(ti);
			endif;
			sumObjectCurrent.totalsForTi(ti, CMIF_LoadListSummaryObject.MODE_UPDATE);
		endif;
		
		if sumObjectOld &lt;&gt; null then
			//ti does not belong here
			sumObjectOld.allTrackedItems.remove(ti);
			sumObjectOld.totalsForTi(ti, CMIF_LoadListSummaryObject.MODE_REMOVE);
			if deleteSum then
				sumDict.removeIfPresent(sumObjectOld);	//need to keep this up to date
				self.mySummaryReport.removeObject(sumObjectOld);
			endif;
		endif;

	endforeach;

epilog
	//
	//  Replaced by cnEndTransaction in doCentralisedTINoteUpdate PAR 21787
	//
	//app.lockKeeperNotifyEndActivity(startTime, true, app.myPassport);
end;</source>
        <access>protected</access>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_waitForNotes" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="updateSummaryTIFromNote" id="b7cad88c-7ecf-4283-8334-924ab8d095dd">
        <updating/>
        <source>updateSummaryTIFromNote(_ti : CM_TrackedItem)updating, protected;
//----------------------------------------------------------------
//	Created:	21 September 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	sumDict			: CMIF_LoadListSumByTrainDestISO;	//CMIF_LoadListSumByImexDischISO;
	sumObjectNew,
	sumObjectCurrent,
	sumObjectOld,
	sumObject		: CMIF_LoadListSummaryObject;
	deleteSum,
	breakOut,
	foundTI,
	newSum,
	matchesCriteria	: Boolean;
//	imexKey	: Integer;
	intRow	: Integer;
	ti				: CM_TrackedItem;
	startTime		: TimeStamp;
	trainCode : String;
	invalid 		: Boolean;
	id				: String;
	
begin
	
	if self.mySummaryReport = null 
	or self.mySummaryReport.allGroupedObjects.isEmpty 
//	or not app.isValidObject(_ti) then
	or _ti = null then
		return;
	endif;
	ti := _ti;

	on Exception do app.handleDeletedObject(exception, ti, invalid);
	id := ti.id;
	if invalid then
		return;
	endif;
	
//	if self.mySummaryFilterTrain = null then
//		return;
//	endif;
	//
	//  Replaced by cnStartTransaction in doCentralisedTINoteUpdate PAR 21787
	//
	//startTime := app.actualTimeServer();
	//app.lockKeeperNotifyStartActivity(startTime, method, null, 'Updating loadlist summary', app.myPassport);
	
	sumDict := self.summarySortDictTrain;
	sumDict.clear();
	self.mySummaryReport.allGroupedObjects.copy(sumDict);

		
	matchesCriteria := self.mySummaryFilterTrain.checkStatusIncludesObject(ti, app.myPassport, breakOut);
	sumObjectOld := null;
	deleteSum := false;
	foundTI := false;
	newSum := false;
	
//	imexKey := ti.getImExStatus;
	
	// par 11095 - summary is being updated when ANY new pre-note is created. 
	if not ti.includeOnLoadListTrain(self.myCurrentTrain, self.myTerminal) then 
		// now need to check if in table if so, summary will need to be updated. (will be removed from table in by calling code.) 
		if self.tblData.findObjectInRow(ti, intRow) then
			sumObjectOld := sumObjectCurrent; // setting this will remove ti from summary.
		else		
			return; 

		endif;
	endif;
	
	if ti.myTrainAssigned = null then
		trainCode := app.getErrorString(Not_Assigned);
	else
		trainCode := ti.myTrainAssigned.code;
	endif;
	
	//sumObjectCurrent := sumDict[imexKey,ti.dischargePort,ti.getPlannerReportGroup];
	sumObjectCurrent := sumDict[trainCode, ti.destinationPort,ti.getPlannerReportGroup];
	
	if sumObjectCurrent = null then
		//either changed or new
		newSum := true;
	else
		//changed?
		if sumObjectCurrent.allTrackedItems.includes(ti) then
			if sumObjectCurrent.imexStatus = TI_IMEX_STATUS_REMAINONBOARD and not ti.isRehandle then // PAR 11070
				deleteSum := (sumObjectCurrent.allTrackedItems.size = 1) and (sumObjectCurrent.allLoadRequests.isEmpty); // PAR 11070
				sumObjectOld := sumObjectCurrent; // PAR 11070
				foundTI := true;
			else
				foundTI := true;
			endif;
		endif;
	endif;

	if not foundTI then
		//search for it (also see if old sumObj is still required)
		foreach sumObject in sumDict do
			if sumObject.allTrackedItems.includes(ti) then
				deleteSum := (sumObject.allTrackedItems.size = 1) and (sumObject.allLoadRequests.isEmpty);
				sumObjectOld := sumObject;
				break;	
			endif;
		endforeach;
	endif;
	
	if newSum and matchesCriteria then
		create sumObjectNew transient;
		//sumObjectNew.setFromTI(ti, imexKey);
		sumObjectNew.train := trainCode;
		//sumObjectNew.imexStatusDescription := ti.myTrainAssigned.code;
		sumObjectNew.destinationPort := ti.destinationPort;
		sumObjectNew.isoGroupingKey := ti.getPlannerReportGroup();
		sumObjectNew.isoGroupingCode := ti.getPlannerReportGroupDesc();
		
		sumDict.add(sumObjectNew);
		sumObjectNew.allTrackedItems.add(ti);
		sumObjectNew.totalsForTi(ti, CMIF_LoadListSummaryObject.MODE_ADD);
		self.mySummaryReport.addObject(sumObjectNew);
	endif;

	if sumObjectCurrent &lt;&gt; null then
		//this will pickup change in planning state
		if (not foundTI) and matchesCriteria then
			sumObjectCurrent.allTrackedItems.add(ti);
		endif;
		sumObjectCurrent.totalsForTi(ti, CMIF_LoadListSummaryObject.MODE_UPDATE);
	endif;
	
	if sumObjectOld &lt;&gt; null then
		//ti does not belong here
		sumObjectOld.allTrackedItems.remove(ti);
		sumObjectOld.totalsForTi(ti, CMIF_LoadListSummaryObject.MODE_REMOVE);
		if deleteSum then
			sumDict.removeIfPresent(sumObjectOld);	//need to keep this up to date
			self.mySummaryReport.removeObject(sumObjectOld);
		endif;
	endif;
	
		
epilog
	//
	//  Replaced by cnEndTransaction in doCentralisedTINoteUpdate PAR 21787
	//
	//app.lockKeeperNotifyEndActivity(startTime, true, app.myPassport);
end;</source>
        <access>protected</access>
        <Parameter name="_ti" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="updateSummaryWLE" id="a98d2025-7c89-43fa-b7ce-95c0f2318ea5">
        <updating/>
        <source>updateSummaryWLE(_wle : CM_WorkListEntry; _waitForNotes : Boolean) updating, protected;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08/11/2010	cnwdap1	Initial creation PAR #23794 CCMS MES 1102
*/
vars
	sumDict			: CMIF_LoadListSumByTrainDestISO;
	sumObjectNew,
	sumObjectCurrent,
	sumObjectOld,
	sumObject		: CMIF_LoadListSummaryObject;
	deleteSum,
	breakOut,
	foundWLE,
	newSum,
	matchesCriteria	: Boolean;
	intRow			: Integer;
	wle				: CM_WorkListEntry;
	startTime		: TimeStamp;
	trainCode 		: String;
	destinationPort	: String;
	
begin
	if self.mySummaryReport = null 
	or self.mySummaryReport.allGroupedObjects.isEmpty then
		return;
	endif;

	if self.mySummaryFilterTrain = null then
		return;
	endif;
	
	self.resetSummaryCriteria();
	sumDict := self.summarySortDictTrain;
	sumDict.clear();
	self.mySummaryReport.allGroupedObjects.copy(sumDict);

	foreach wle in self.allWLEsSummaryUpdate do	
		if not global.isValidObject(wle) then
			self.allWLEsSummaryUpdate.remove(wle);
			continue;
		endif;
		
		matchesCriteria := self.mySummaryFilterTrain.checkStatusIncludesObject(wle, app.myPassport, breakOut);
		sumObjectOld := null;
		deleteSum := false;
		foundWLE := false;
		newSum := false;
		
		if wle.getTrainObject = null then
			trainCode := app.getErrorString(Not_Assigned);
		else
			trainCode := wle.getTrainString;
		endif;
		if CM_YardDeliveryRequest.hasInstance(wle.myRequest) then
			if wle.myRequest.CM_YardDeliveryRequest.myRelease &lt;&gt; null then
				destinationPort := wle.myRequest.CM_YardDeliveryRequest.myRelease.myDestinationPort.code;
			endif;
		endif;
		
		sumObjectCurrent := sumDict[trainCode, destinationPort, wle.getPlannerReportGroup];
		
		if not wle.getTrainObject = self.myCurrentTrain then 
			continue; 
		endif;
		
		if sumObjectCurrent = null then
			//either changed or new
			newSum := true;
		else
			//changed?
			if sumObjectCurrent.allWorkListEntries.includes(wle) then
				if sumObjectCurrent.imexStatus = TI_IMEX_STATUS_REMAINONBOARD and not wle.isRehandle then 
					deleteSum := (sumObjectCurrent.allWorkListEntries.size = 1); 
					sumObjectOld := sumObjectCurrent;
					foundWLE := true;
				else
					foundWLE := true;
				endif;
			endif;
		endif;
	
		if not foundWLE then
			//search for it (also see if old sumObj is still required)
			foreach sumObject in sumDict do
				if sumObject.allWorkListEntries.includes(wle) then
					deleteSum := (sumObject.allWorkListEntries.size = 1);
					sumObjectOld := sumObject;
					break;	
				endif;
			endforeach;
		endif;
		
		if newSum and matchesCriteria then
			create sumObjectNew transient;
			//sumObjectNew.setFromTI(ti, imexKey);
			sumObjectNew.train := trainCode;
			sumObjectNew.destinationPort := destinationPort;
			sumObjectNew.isoGroupingKey := wle.myRequest.getPlannersGroup();
			sumObjectNew.isoGroupingCode := wle.myRequest.getPlannersGroupDesc();
			
			sumDict.add(sumObjectNew);
			sumObjectNew.allWorkListEntries.add(wle);
			sumObjectNew.totalsForWle(wle, CMIF_LoadListSummaryObject.MODE_ADD);
			self.mySummaryReport.addObject(sumObjectNew);
		endif;
	
		if sumObjectCurrent &lt;&gt; null then
			//this will pickup change in planning state
			if (not foundWLE) and matchesCriteria then
				sumObjectCurrent.allWorkListEntries.add(wle);
			endif;
			sumObjectCurrent.totalsForWle(wle, CMIF_LoadListSummaryObject.MODE_UPDATE);
		endif;
		
		if sumObjectOld &lt;&gt; null then
			//ti does not belong here
			sumObjectOld.allWorkListEntries.remove(wle);
			sumObjectOld.totalsForWle(wle, CMIF_LoadListSummaryObject.MODE_REMOVE);
			if deleteSum then
				sumDict.removeIfPresent(sumObjectOld);	//need to keep this up to date
				self.mySummaryReport.removeObject(sumObjectOld);
			endif;
		endif;

	endforeach;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_wle" type="CM_WorkListEntry"/>
        <Parameter name="_waitForNotes" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="updateSummaryWLEFromNote" id="e5f746a5-1fa3-4048-8104-1d55f7ebf016">
        <updating/>
        <source>updateSummaryWLEFromNote(_wle : CM_WorkListEntry) updating, protected;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08/11/2010	cnwdap1	Initial creation PAR #23794 CCMS MES 1102
*/
vars
	sumDict			: CMIF_LoadListSumByTrainDestISO;
	sumObjectNew,
	sumObjectCurrent,
	sumObjectOld,
	sumObject		: CMIF_LoadListSummaryObject;
	deleteSum,
	breakOut,
	foundWLE,
	newSum,
	matchesCriteria	: Boolean;
	wle				: CM_WorkListEntry;
	trainCode 		: String;
	invalid 		: Boolean;
	id				: String;
	destinationPort	: String;
	bulkRelease		: CM_BulkRelease;
	
begin
	if self.mySummaryReport = null 
	or self.mySummaryReport.allGroupedObjects.isEmpty 
	or _wle = null then
		return;
	endif;
	wle := _wle;

	on Exception do app.handleDeletedObject(exception, wle, invalid);
	id := wle.id;
	if invalid then
		return;
	endif;
	
	sumDict := self.summarySortDictTrain;
	sumDict.clear();
	self.mySummaryReport.allGroupedObjects.copy(sumDict);
		
	matchesCriteria := self.mySummaryFilterTrain.checkStatusIncludesObject(wle, app.myPassport, breakOut);
	sumObjectOld := null;
	deleteSum := false;
	foundWLE := false;
	newSum := false;
	
	if wle.getTrainObject = null then
		trainCode := app.getErrorString(Not_Assigned);
	else
		trainCode := wle.getTrainObject.code;
	endif;
	if CM_YardDeliveryRequest.hasInstance(wle.myRequest) then
		//destinationPort := wle.myRequest.CM_YardDeliveryRequest.myRelease.myDestinationPort.code;
		//26 Jan 2015	NDL	Par 35559
		bulkRelease := wle.myRequest.CM_YardDeliveryRequest.myRelease;
		if bulkRelease &lt;&gt; null and bulkRelease.myDestinationPort &lt;&gt; null then
			destinationPort := bulkRelease.myDestinationPort.code;
		endif;
		
	elseif CM_DeliveryRequest.hasInstance(wle.myRequest) then
		if wle.myRequest.CM_DeliveryRequest.myOriginatingBulkRelease &lt;&gt; null then
			bulkRelease := wle.myRequest.CM_DeliveryRequest.myOriginatingBulkRelease;
		elseif wle.myRequest.CM_DeliveryRequest.bulkRelease &lt;&gt; null then
			bulkRelease := wle.myRequest.CM_DeliveryRequest.bulkRelease;
		endif;
		if bulkRelease &lt;&gt; null and bulkRelease.myDestinationPort &lt;&gt; null then
			destinationPort := wle.myRequest.CM_DeliveryRequest.myOriginatingBulkRelease.myDestinationPort.code;
		endif;
	endif;
	
	sumObjectCurrent := sumDict[trainCode, destinationPort, wle.getPlannerReportGroup];
	
	if sumObjectCurrent = null then
		//either changed or new
		newSum := true;
	else
		//changed?
		if sumObjectCurrent.allWorkListEntries.includes(wle) then
			if sumObjectCurrent.imexStatus = TI_IMEX_STATUS_REMAINONBOARD and not wle.isRehandle then
				deleteSum := (sumObjectCurrent.allWorkListEntries.size = 1);
				sumObjectOld := sumObjectCurrent;
				foundWLE := true;
			else
				foundWLE := true;
			endif;
		endif;
	endif;

	if not foundWLE then
		//search for it (also see if old sumObj is swlell required)
		foreach sumObject in sumDict do
			if sumObject.allWorkListEntries.includes(wle) then
				deleteSum := (sumObject.allWorkListEntries.size = 1);
				sumObjectOld := sumObject;
				break;	
			endif;
		endforeach;
	endif;
	
	if newSum and matchesCriteria then
		create sumObjectNew transient;
		sumObjectNew.train 				:= trainCode;
		sumObjectNew.destinationPort 	:= destinationPort;
		sumObjectNew.isoGroupingKey 	:= wle.myRequest.getPlannersGroup();
		sumObjectNew.isoGroupingCode 	:= wle.myRequest.getPlannersGroupDesc();
		
		sumDict.add(sumObjectNew);
		sumObjectNew.allWorkListEntries.add(wle);
		sumObjectNew.totalsForWle(wle, CMIF_LoadListSummaryObject.MODE_ADD);
		self.mySummaryReport.addObject(sumObjectNew);
	endif;

	if sumObjectCurrent &lt;&gt; null then
		//this will pickup change in planning state
		if (not foundWLE) and matchesCriteria then
			sumObjectCurrent.allWorkListEntries.add(wle);
		endif;
		sumObjectCurrent.totalsForWle(wle, CMIF_LoadListSummaryObject.MODE_UPDATE);
	endif;
	
	if sumObjectOld &lt;&gt; null then
		//wle does not belong here
		sumObjectOld.allWorkListEntries.remove(wle);
		sumObjectOld.totalsForWle(wle, CMIF_LoadListSummaryObject.MODE_REMOVE);
		if deleteSum then
			sumDict.removeIfPresent(sumObjectOld);	//need to keep this up to date
			self.mySummaryReport.removeObject(sumObjectOld);
		endif;
	endif;
	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_wle" type="CM_WorkListEntry"/>
    </JadeMethod>
    <JadeMethod name="updateTableItem" id="0e4050b6-a4f4-4e7d-b3d6-6a38fb352982">
        <updating/>
        <source>updateTableItem(_table : CM_DataTable input; _ti : CM_TrackedItem) updating;
//--------------------------------------------------
// Created:	16 September 2005 By: cnwgd1
//--------------------------------------------------
vars
	numZeros,
	rowIdx	: Integer;
o	: Object;
begin
	if _table = null then
		return;
	endif;

	if _table.allTableObjects &lt;&gt; null
	and (not _table.allTableObjects.noKeys()) then
		// sorting by more than 3 columns update dynaDict to sort
		//_table.setSortColumnTableObjects();
		
		if not _table.allTableObjects.includes(_ti) then
			_table.allTableObjects.addObject(_ti);
		endif;
		
		rowIdx := _table.allTableObjects.indexOf(_ti) + _table.fixedRows;
		
		self.doQueryAddItem(_table, rowIdx, _ti, 0);
		
	else
		rowIdx := self.doQueryAddItem(_table, 0, _ti, numZeros);
	endif;
	
end;</source>
        <Parameter name="_table" type="CM_DataTable" usage="input"/>
        <Parameter name="_ti" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="updateTblAllTi" id="c4be0176-976d-4aab-b0ac-519fcf714f0a">
        <updating/>
        <source>updateTblAllTi( aTI : CM_TrackedItem ) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
08 December 2011	cnwndl1	Initial creation	Par 28797

*/

vars

begin

	self.tblAll.removeItemObject(aTI);
	if self.tblAll.rows &gt; 1 then //don't add to tblAll if not setup
		self.updateTableItem(self.tblAll,aTI);
	else
		// but still needs to be added to the table objects so it can populate when user clicks on the tab without a full refresh....
		if self.tblAll.allTableObjects &lt;&gt; null and (not self.tblAll.allTableObjects.noKeys()) then
			// sorting by more than 3 columns update dynaDict to sort
			//_table.setSortColumnTableObjects();
			
			if not self.tblAll.allTableObjects.includes(aTI) then
				self.tblAll.allTableObjects.addObject(aTI);
			endif;
		endif;
	
	endif;

epilog

end;</source>
        <Parameter name="aTI" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="userNotify" id="86ad36a2-bd75-4f81-a173-4e532a5ad865">
        <controlMethod name="Form::userNotify"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>userNotify(eventType: Integer; theObject: Object; eventTag: Integer; userInfo: Any) updating;
// ---------------------------------------------------------------------------
// Created:		June 2003 By Andrew Bishop cnwab1
//
// Purpose:		
// ---------------------------------------------------------------------------
begin
	app.mousePointer	:=	Busy;
//app.writeStatement( "AKB " &amp; self.class.name &amp; "::" &amp; method.name &amp; " 1. eventType : " &amp; eventType.String &amp; " theObject: " &amp; theObject.String &amp; " userInfo: " &amp; userInfo.String);
	self.doNotableNotification(eventType, theObject, eventTag, userInfo);
epilog

	app.mousePointer	:=	Idle;
end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
        <Parameter name="userInfo" type="Any"/>
    </JadeMethod>
    <JadeMethod name="waitForNotesTI" id="d3bef198-9ee6-44bf-9e47-31fc9249f4fa">
        <updating/>
        <source>waitForNotesTI(_ti: CM_TrackedItem): Boolean updating;
//----------------------------------------------------------------
//	Created:	29 September 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	clockNow		: Integer;
begin

	clockNow := app.clock;
	
	if _ti &lt;&gt; null then
		self.allTIsSummaryUpdate.addNoDuplicates(_ti, false);
	else
		//called by timerEvent
 //app.writeStatement('CNWJC2 ' &amp; class.name &amp; " " &amp; method.name &amp;  " TIMER EVENT"  );
	endif;
	
	if self.noteTimes[TI_Note_Tag] = null then
		self.noteTimes[TI_Note_Tag] := clockNow;
		self.beginTimer(2000, Timer_OneShot, TI_Note_Tag);
		return true;
	endif;		
	
	if self.noteTimes[TI_Note_Tag] &gt; clockNow
	or self.noteTimes[TI_Note_Tag] &lt; (clockNow-2000) then
		//two seconds with no new notes!
		//time to do updates
		self.endTimer(TI_Note_Tag);
		self.noteTimes[TI_Note_Tag] := null;
		return false;
	endif;
	
	//to soon, wait - timer is running
	return true;
	

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
