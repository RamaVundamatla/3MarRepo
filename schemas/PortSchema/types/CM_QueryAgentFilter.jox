    <JadeMethod name="qryVoyage" id="c7396f9e-f9d0-4e04-bd52-81b1ec956df6">
        <updating/>
        <source>qryVoyage(_filter : CMQF_FilterReports input; _passport : CM_Passport) : Integer updating;
// -------------------------------------------
// Created 24 February 2005 by cnwdvb1
// -------------------------------------------
vars
	numSelected 	: Integer;
	jrwTrans		: CM_JRWVoyages;
	filter			: CMQF_VoyageSummary;
begin

	on CM_BreakOutException do self.xHandlerBreakOut(exception);
	
	
	filter := _filter.CMQF_VoyageSummary;
	jrwTrans := self.createJRWTransient(CM_JRWVoyages).CM_JRWVoyages;

	// Par 10146
	jrwTrans.setAllTerminals(filter.allTerminals);
	
//	filter.filterObjects(jrwTrans.allVoyages, _passport);
	jrwTrans.allVoyages.add(filter.getMyVoyage);
	
	numSelected := jrwTrans.allVoyages.size;

epilog
	return numSelected;
end;</source>
