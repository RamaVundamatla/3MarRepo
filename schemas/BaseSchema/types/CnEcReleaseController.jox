    <JadeMethod name="create" id="a971d30d-4fdc-4f44-855d-6e9a93a84502">
        <updating/>
        <source>create() updating;
// ---------------------------------------------------------------------------
// Created:     10 July 2001 by cnwrs2
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
begin
	create self.myTA;
	
	self.myTA.trxHistoryMasterCreate(app.myBaseRoot, self.myHistoryMaster);
	self.initializeLogFile();
	self.logEntry('History being recorded in (' &amp; self.myHistoryMaster.String &amp; ')');
end;</source>
    </JadeMethod>
    <JadeMethod name="createTransientHistoryDetail" id="c8d275c6-fdc0-4e8c-8026-b8f43333dea9">
        <source>createTransientHistoryDetail(pTimeStamp : TimeStamp; pMsg : String) protected;
// ---------------------------------------------------------------------------
// Created:     11 July 2001 by cnwrs2
//
// Purpose:     Create a transient History Detail object.
//
// Parameters:  pTimeStamp - Timestamp of the history event.
//				pMsg - String - Description of the history event.
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	historyDetailObj	: CnEcReleaseHistoryDetail;
	
begin
	create historyDetailObj transient;
	historyDetailObj.updateMe(pTimeStamp, pMsg, null);

	self.allTransientHistoryDetails.add(historyDetailObj);
end;</source>
        <access>protected</access>
        <Parameter name="pTimeStamp" type="TimeStamp"/>
        <Parameter name="pMsg" type="String"/>
    </JadeMethod>
    <JadeMethod name="delete" id="95cbd3d9-e29f-4e90-a8ad-3eb71a727959">
        <updating/>
        <source>delete() updating;
// ---------------------------------------------------------------------------
// Created:     10 July 2001 by cnwrs2
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
begin
	if self.myLogFile &lt;&gt; null then
		self.logEntry('Logfile closed');
		delete self.myLogFile;
	endif;

	delete self.myTA;
end;</source>
    </JadeMethod>
    <JadeMethod name="flushTransientHistory" id="57cedb93-804b-4390-989c-2c2eb2b34066">
        <source>flushTransientHistory() protected;
// ---------------------------------------------------------------------------
// Created:     11 July 2001 by cnwrs2
//
// Purpose:     All transient history details are persisted and then purged.
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
begin
	if (not self.allTransientHistoryDetails.isEmpty()) then
		self.myTA.trxHistoryDetailCreateMultiple(self.myHistoryMaster, self.allTransientHistoryDetails);
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="getProcessClass" id="3e4d0def-7e4a-442d-b895-3259f6cdfb64">
        <source>getProcessClass(pInitialClassObj : Class; pNextReleaseMajor, pNextReleaseMinor, pNextReleaseInternal : Integer output) : Class protected;
// ---------------------------------------------------------------------------
// Created:     10 July 2001 by cnwrs2
//
// Purpose:     Locate the latest subclass of the specified initial class and
//				return it.  This assumes that all earlier subclasses have
//				already been processed for release.
//
// Parameters:  pInitialClassObj - The abstract super-class of the release classes.
//				pNextReleaseMajor - The major release number.
//				pNextReleaseMinor - The minor release number.
//				pNextReleaseInternal - The patch release number.
//
// Returns:     The release class to process.  The release version numbers are
//				returned as output method parameters.
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	allSubclasses			: ClassColl;
	subclassObj				: Class;
	processClassObj			: Class;
	isRemoved				: Boolean;

	classReleaseMajor		: Integer;
	classReleaseMinor		: Integer;
	classReleaseInternal	: Integer;

	subclassName			: String;
	nextPos					: Integer;
			
begin
	create allSubclasses transient;
	pInitialClassObj.getSubclasses(allSubclasses);

	// We only process sub-classes which have no sub-classes so
	// remove all sub-classes from the collection that have
	// sub-classes.
	isRemoved := true;
	
	while isRemoved do
		isRemoved := false;
		
		foreach subclassObj in allSubclasses do
			if subclassObj.hasSubclasses then
//				write class.name &amp; '::' &amp; method.name &amp; ' - removing ' &amp; theSubclass.name;
				allSubclasses.remove(subclassObj);
				isRemoved := true;
				break;
			endif;
		endforeach;
	endwhile;

	pNextReleaseMajor	:= 0; 
	pNextReleaseMinor	:= 0;
	pNextReleaseInternal:= 0;

	// Determine the latest NewReleaseUpgrades sub-class to run
	foreach subclassObj in allSubclasses do
		subclassName := subclassObj.name;

		
		// write class.name &amp; '::' &amp; method.name &amp; ' - checking ' &amp; subclassName;
		if (not self.getVersionFromClassName(subclassName, classReleaseMajor, classReleaseMinor, classReleaseInternal)) then
			continue;
		endif;
		/*
		nextPos := subclassName.pos('_', 1);
		if nextPos = 0 then
			// subclass name in incorrect format - should be xxx_1_2_3
			write self.class().name &amp; '::' &amp; method.name &amp; '  incorrect format';
			continue;
		endif;
		
		self.splitVersionString(subclassName[nextPos+1 : end], '_', classReleaseMajor, classReleaseMinor, classReleaseInternal);
		*/

		//	Change in major release
		if classReleaseMajor &gt; pNextReleaseMajor then
			pNextReleaseMajor 		:= classReleaseMajor;
			pNextReleaseMinor 		:= classReleaseMinor;
			pNextReleaseInternal	:= classReleaseInternal;
			processClassObj			:= subclassObj;

		elseif classReleaseMajor = pNextReleaseMajor then
			//	Change in minor release
			if classReleaseMinor &gt; pNextReleaseMinor then
				pNextReleaseMajor		:= classReleaseMajor;
				pNextReleaseMinor		:= classReleaseMinor;
				pNextReleaseInternal	:= classReleaseInternal;
				processClassObj			:= subclassObj;
				
			elseif classReleaseMinor = pNextReleaseMinor then
				//	Change in internal release
				if classReleaseInternal &gt; pNextReleaseInternal then
					pNextReleaseMajor		:= classReleaseMajor;
					pNextReleaseMinor		:= classReleaseMinor;
					pNextReleaseInternal	:= classReleaseInternal;
					processClassObj			:= subclassObj;
				endif;
			endif;
		endif;
	endforeach;

	return processClassObj;
epilog
	delete allSubclasses;
end;</source>
        <access>protected</access>
        <Parameter name="pInitialClassObj" type="Class"/>
        <Parameter name="pNextReleaseMajor" type="Integer" usage="output"/>
        <Parameter name="pNextReleaseMinor" type="Integer" usage="output"/>
        <Parameter name="pNextReleaseInternal" type="Integer" usage="output"/>
        <ReturnType type="Class"/>
    </JadeMethod>
    <JadeMethod name="getVersionFromClassName" id="ddc20ae4-3cd7-41e7-868d-221e0db26672">
        <source>getVersionFromClassName(pClassName : String;
						pMajor:Integer output;
						pMinor:Integer output;
						pInternal:Integer output) : Boolean protected;
// ---------------------------------------------------------------------------
// Created:     27 March 2003 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	nextPos	: Integer;
	
begin

	pMajor		:= 0;
	pMinor		:= 0;
	pInternal	:= 0;

	nextPos := pClassName.pos('_', 1);
	if nextPos = 0 then
		// subclass name in incorrect format - should be xxx_1_2_3
		self.logEntry('ClassName is of incorrect format (' &amp; pClassName &amp; ')');
		return false;
	endif;
	
	return self.splitVersionString(pClassName[nextPos+1 : end], '_', pMajor, pMinor, pInternal);

end;</source>
        <access>protected</access>
        <Parameter name="pClassName" type="String"/>
        <Parameter name="pMajor" type="Integer" usage="output"/>
        <Parameter name="pMinor" type="Integer" usage="output"/>
        <Parameter name="pInternal" type="Integer" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getVersionString" id="4a974841-eef7-4297-b7bb-72c86c36b978">
        <source>getVersionString(pMajor:Integer; pMinor:Integer; pInternal:Integer) : String protected;
// ---------------------------------------------------------------------------
// Created:     11 July 2001 by cnwrs2
//
// Purpose:     Assembles the specified release version numbers as a string.
//
// Parameters:  pMajor - The major release number.
//				pMinor - The minor release number.
//				pInternal - The patch release number.
//
// Returns:     The release version string.
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
begin
	return pMajor.String &amp; '.' &amp; pMinor.String &amp; '.' &amp; pInternal.String;
end;</source>
        <access>protected</access>
        <Parameter name="pMajor" type="Integer"/>
        <Parameter name="pMinor" type="Integer"/>
        <Parameter name="pInternal" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="initializeLogFile" id="28542fc4-92fe-46ca-9300-623bebdbe36b">
        <updating/>
        <source>initializeLogFile() updating, protected;
// ---------------------------------------------------------------------------
// Created:     10 July 2001 by cnwrs2
//
// Purpose:     Initialize the log data file.
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ---------------------------------------------------------------------------
vars
	cardSchemaControllerObj	: CnCntrl;
	theJadeLog				: JadeLog;
	filePath				: String;
	filename				: String;
	date					: Date;
	logStr					: String;
	
begin
	cardSchemaControllerObj := app.myCnCntrl;
	
	if cardSchemaControllerObj &lt;&gt; null then
		filePath := cardSchemaControllerObj.logPath;
	else
		filePath := app.getJadeInstallDir();
	endif;

	if self.myLogFile = null then
		create theJadeLog;
		theJadeLog.filePath	:= filePath;

		if process.isUsingThinClient then
			filename	:= app.name &amp; "_" &amp; app.computerName() &amp; "_ltl_" &amp; date.userFormat($CnCCYYMMDD_ns);
		else
			filename	:= app.name &amp; "_ltl_" &amp; date.userFormat($CnCCYYMMDD_ns);
		endif;	

		theJadeLog.fileName		:= filename;

		theJadeLog.versionFile	:= true;
		theJadeLog.maxFileSize	:= 200000;
		theJadeLog.formatOutput	:= false;
		theJadeLog.bufferOutput	:= true;

		self.myLogFile := theJadeLog;
	endif;
	
	self.logEntry('Logfile created as (' &amp; self.myLogFile.fileName &amp; ') in (' &amp; self.myLogFile.filePath &amp; ')');
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="logEntry" id="b3c4a7f0-b0f3-449a-a8b5-4550715b508e">
        <source>logEntry(pMessage : String);
// ---------------------------------------------------------------------------
// Created:     10 July 2001 by cnwrs2
//
// Purpose:     Write an entry to the log file.
//
// Parameters:  pMessage - The information to write to the log file.
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	historyDetailObj	: CnEcReleaseHistoryDetail;
	currentTimestamp	: TimeStamp;
	logMessage			: String;

begin
	logMessage	:=	currentTimestamp.Date.format("ddMMMyy") &amp; ' ' &amp;  
					currentTimestamp.Time.format("HH:mm:ss") &amp; '.' &amp;
					currentTimestamp.Time.milliSecond.cnEcPadTrailingZeros(3) &amp; ' ' &amp;
					pMessage;

	self.myLogFile.log(logMessage);

	if process.isInTransactionState() then
		self.createTransientHistoryDetail(currentTimestamp, pMessage);
	else
		// Write the current message to the database.
		self.myTA.trxHistoryDetailCreate(currentTimestamp, pMessage, self.myHistoryMaster, historyDetailObj);
		// Write any transient messages out to the database
		self.flushTransientHistory();
	endif;
end;</source>
        <Parameter name="pMessage" type="String"/>
    </JadeMethod>
    <JadeMethod name="processPatchRelease" id="df3581a1-fc6e-49c6-811d-6466868b38c8">
        <updating/>
        <source>processPatchRelease(pClass : Class;
				pPatchNumber : String;
				pCurrentRelease : String;
				pMasterObj : CnEcReleaseHistoryMaster output) : Boolean updating;
// ---------------------------------------------------------------------------
// Created:     10 July 2001 by cnwrs2
//
// Purpose:     Process the a specific method on a release class.
//
// Parameters:  pClass - The release class to create.
//				pMethodName - The method on pClass to run.
//				pMasterObj - The history master object for the current release.
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 20 Sep 2011	cnwkpd1		Fixed spelling error in "Processing patch..." message
// 13 June 2016	cnwns1	TFS 488 - Multi Timezone Support
// ---------------------------------------------------------------------------
vars
	upgraderClassObj		: Class;
	upgraderObj				: CnEcReleaseUpgrader;

	currReleaseMajor		: Integer;
	currReleaseMinor		: Integer;
	currReleaseInternal		: Integer;

	nextReleaseMajor		: Integer;
	nextReleaseMinor		: Integer;
	nextReleaseInternal		: Integer;

	isSuccessful			: Boolean;
	clsName					: String;
	nextPos					: Integer;
			
begin
	on Exception do self.xHandlerNewRelease(exception);

	// set the master so that it can be returned to the calling application
	// to be used there if required.
	pMasterObj	:=	self.myHistoryMaster;

	self.logEntry('Processing patch release for class (' &amp; pClass.name &amp; '). Patch (' &amp; pPatchNumber &amp; ').  Current version is (' &amp; pCurrentRelease &amp; ')');

	if pCurrentRelease &lt;&gt; null then
		if (not self.splitVersionString(pCurrentRelease, '.', currReleaseMajor, currReleaseMinor, currReleaseInternal)) then
			// need exception
			self.logEntry('Error in splitting current release version (' &amp; pCurrentRelease &amp; ')');
			return false;
		endif;
	else
		currReleaseMajor	:= 0;
		currReleaseMinor	:= 0;
		currReleaseInternal	:= 0;
	endif;
	
	if (not self.getVersionFromClassName(pClass.name, nextReleaseMajor, nextReleaseMinor, nextReleaseInternal)) then
		return false;
	endif;
	
	if currReleaseMajor = 0 and
	   currReleaseMinor = 0 and
	   currReleaseInternal = 0 then
		self.logEntry('Invalid current release for patching (' &amp; pCurrentRelease &amp; ')');
		return false;
	endif;

	// Must be on the same major/minor and internal release for a patch release
	if currReleaseMajor &lt;&gt; nextReleaseMajor or
	   currReleaseMinor &lt;&gt; nextReleaseMinor or
	   currReleaseInternal &lt;&gt; nextReleaseInternal then
		self.logEntry('Invalid patch release version class (' &amp; pClass.name &amp; ') for current version (' &amp; pCurrentRelease &amp; ')');
		return false;
	endif;

	upgraderClassObj := pClass;

	self.logEntry('Attempting to create upgrader for class (' &amp; upgraderClassObj.name &amp; ')');
	if (not self.myTA.trxReleaseUpgraderCreate(upgraderClassObj, upgraderObj) = null) then
		self.logEntry('Error in creating upgrader for class (' &amp; upgraderClassObj.name &amp; ')');
		return false;
	endif;
	
	self.logEntry('Attaching upgrader (' &amp; upgraderObj.String &amp; ') to history master');
	self.myTA.trxHistoryMasterUpdateUpgrader(self.myHistoryMaster, 0, upgraderObj);

	self.logEntry('Processing patch (' &amp; pPatchNumber &amp; ') for (' &amp; upgraderObj.String &amp; ')');
	upgraderObj.processPatchRelease(pPatchNumber, self);
	self.logEntry('Processing patch (' &amp; pPatchNumber &amp; ') complete for (' &amp; upgraderObj.String &amp; ')');

	self.myTA.trxHistoryMasterCompleted(self.myHistoryMaster, 0, app.actualTimeServer(), true);// 13 June 2016	cnwns1	TFS 488 - Multi Timezone Support

	self.logEntry('Patch Release complete (' &amp; pPatchNumber &amp; ')');
	
	isSuccessful := true;
epilog
	self.flushTransientHistory();
	return isSuccessful;	
end;</source>
        <Parameter name="pClass" type="Class"/>
        <Parameter name="pPatchNumber" type="String"/>
        <Parameter name="pCurrentRelease" type="String"/>
        <Parameter name="pMasterObj" type="CnEcReleaseHistoryMaster" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="processRelease" id="e883b36a-e81f-42e4-b323-c14f9daac971">
        <updating/>
        <source>processRelease(	pInitialClass : Class;
				pCurrentRelease : String io;
				pMasterObj : CnEcReleaseHistoryMaster output) : Boolean updating;
// ---------------------------------------------------------------------------
// Created:     10 July 2001 by cnwrs2
//
// Purpose:     Process the latest release class.
//
// Parameters:  pInitialClass - The abstract super-class of the release classes.
//				pCurrentRelease - The version number of the new release.
//				pMasterObj - The history master object for the current release.
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//// 13 June 2016	cnwns1	TFS 488 - Multi Timezone Support
// ---------------------------------------------------------------------------
vars
	nextReleaseMajor		: Integer;
	nextReleaseMinor		: Integer;
	nextReleaseInternal		: Integer;

	currReleaseMajor		: Integer;
	currReleaseMinor		: Integer;
	currReleaseInternal		: Integer;

	upgraderClassObj		: Class;
	upgraderObj				: CnEcReleaseUpgrader;
	
	isSuccessful			: Boolean;
			
begin
	on Exception do self.xHandlerNewRelease(exception);

	// set the master so that it can be returned to the calling application
	// to be used there if required.
	pMasterObj	:=	self.myHistoryMaster;

	self.logEntry('Processing release for initial class (' &amp; pInitialClass.name &amp; ').  Current version is (' &amp; pCurrentRelease &amp; ')');

	if pCurrentRelease &lt;&gt; null then
		if (not self.splitVersionString(pCurrentRelease, '.', currReleaseMajor, currReleaseMinor, currReleaseInternal)) then
			// need exception
			self.logEntry('Error in splitting current release version (' &amp; pCurrentRelease &amp; ')');
			return false;
		endif;
	else
		currReleaseMajor	:= 0;
		currReleaseMinor	:= 0;
		currReleaseInternal	:= 0;
	endif;
	
	
	upgraderClassObj := self.getProcessClass(pInitialClass, nextReleaseMajor, nextReleaseMinor, nextReleaseInternal);

	if upgraderClassObj = null then
		self.logEntry('Unable to determine upgrader class');
		return false;
	endif;
	
	self.logEntry('Upgrader class is (' &amp; upgraderClassObj.name &amp; ')');

	if pCurrentRelease &lt;&gt; null then
		// can check if current version is later than next release version
		if nextReleaseMajor &lt; currReleaseMajor
		or (nextReleaseMajor = currReleaseMajor and nextReleaseMinor &lt; currReleaseMinor)
		or (nextReleaseMajor = currReleaseMajor and nextReleaseMinor = currReleaseMinor and nextReleaseInternal &lt; currReleaseInternal)
		then
			self.logEntry(	'Current Release (' &amp;
							self.getVersionString(currReleaseMajor, currReleaseMinor, currReleaseInternal) &amp;
							') is greater then next release (' &amp;
							self.getVersionString(nextReleaseMajor, nextReleaseMinor, nextReleaseInternal) &amp;
							')');
		   	return false;
		endif;
		
		// epr TFS 336 monthly release can rerun with the same version
	
	endif;

	self.logEntry('Attempting to create upgrader for class (' &amp; upgraderClassObj.name &amp; ')');
	if (not self.myTA.trxReleaseUpgraderCreate(upgraderClassObj, upgraderObj) = null) then
		self.logEntry('Error in creating upgrader for class (' &amp; upgraderClassObj.name &amp; ')');
		return false;
	endif;	
	
	self.logEntry('Attaching upgrader (' &amp; upgraderObj.String &amp; ') to history master');
	self.myTA.trxHistoryMasterUpdateUpgrader(self.myHistoryMaster, 0, upgraderObj);

	self.logEntry('Processing upgrade for (' &amp; upgraderObj.String &amp; ')');
	upgraderObj.processRelease(self);
	self.logEntry('Processing complete for (' &amp; upgraderObj.String &amp; ')');

	self.myTA.trxHistoryMasterCompleted(self.myHistoryMaster, 0, app.actualTimeServer(), true);// 13 June 2016	cnwns1	TFS 488 - Multi Timezone Support

	pCurrentRelease := self.getVersionString(nextReleaseMajor, nextReleaseMinor, nextReleaseInternal);
	self.logEntry('Current Release returned as (' &amp; pCurrentRelease &amp; ')');
	
	isSuccessful := true;
epilog
	self.flushTransientHistory();
	return isSuccessful;	
end;</source>
        <Parameter name="pInitialClass" type="Class"/>
        <Parameter name="pCurrentRelease" type="String" usage="io"/>
        <Parameter name="pMasterObj" type="CnEcReleaseHistoryMaster" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="splitVersionString" id="791121ae-7e9c-4fe5-a907-af664fd94d17">
        <source>splitVersionString(	pVersionString:String;
					pDelimiter:Character;
					pMajor:Integer output;
					pMinor:Integer output;
					pInternal:Integer output) : Boolean;
// ---------------------------------------------------------------------------
// Created:     10 July 2001 by cnwrs2
//
// Purpose:     Split the version string into its constituent parts, and return
//				them via output parameters.
//
// Parameters:  pVersionString - The version string to extract the parts from.
//				pDelimiter - The version delimiter character.
//				pMajor - The major release number.
//				pMinor - The minor release number.
//				pInternal - The patch release number.
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	tmpStr	: String;
	nextPos	: Integer;
	
begin
	tmpStr		:= pVersionString;
	nextPos		:= 1;
	
	pMajor		:= tmpStr.scanUntil(pDelimiter, nextPos).Integer;
	nextPos		:= nextPos + 1;
	pMinor		:= tmpStr.scanUntil(pDelimiter, nextPos).Integer;
	nextPos		:= nextPos + 1;
	pInternal	:= tmpStr.scanUntil(pDelimiter, nextPos).Integer;

	return true;
end;</source>
        <Parameter name="pVersionString" type="String"/>
        <Parameter name="pDelimiter" type="Character"/>
        <Parameter name="pMajor" type="Integer" usage="output"/>
        <Parameter name="pMinor" type="Integer" usage="output"/>
        <Parameter name="pInternal" type="Integer" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="xHandlerNewRelease" id="8de883e3-1301-42a3-98b5-1fa7c3fb3a0d">
        <updating/>
        <source>xHandlerNewRelease(pExceptionObj : Exception) : Integer updating, protected;
// ---------------------------------------------------------------------------
// Created:     11 July 2001 by cnwrs2
//
// Purpose:     Just record the bare details and pass back to the application
//				exception handler
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
begin
	if self.isInExceptionState then
		// An exception must have occured while we were trying to record the
		// details of a previous exception.
		return Ex_Pass_Back;
	endif;
	
	self.isInExceptionState	:=	true;
	
	self.logEntry('******************* EXCEPTION *************************');
	self.logEntry(pExceptionObj.cnEcGetDetails());
	self.logEntry('*******************************************************');

	return Ex_Pass_Back;
end;</source>
        <access>protected</access>
        <Parameter name="pExceptionObj" type="Exception"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
</Class>
