    <JadeMethod name="getBank" id="ce7fe013-8510-4a95-9dea-e8bb11e342b2">
        <source>getBank(): CM_Bank;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15/05/2023	navkc1	CR 57927 Task 54268 - Transaction Map

*/

vars

begin
	if self.myServiceBroker = null then
		return null;
	endif;
	
	return self.myServiceBroker.getBank();

epilog

end;</source>
        <ReturnType type="CM_Bank"/>
    </JadeMethod>
    <JadeMethod name="getInvoiceLineDesc" id="db4fd51c-e3a9-4f15-b0c1-b0ac9664b60a">
        <source>getInvoiceLineDesc(_aSBController : CMIF_ServiceBroker input);
// ### TFS CR 57927 TASK 54268 22MAY2023 NAVAB1
// 23 Oct 2024	navlw1	JIRA-33107: Invoice Logging Use Levels
// 25 Feb 2025	navah1	Story 34141: MTN - Performance Improvements - Review for invLog() Methods
vars
	lineDescription:   CM_InvoiceLineDesc;
	tmpDebtor : CM_Debtor;
	aDM : CM_DebtorMap;
	ti:CM_TrackedItem;
	trans : CM_EventTransaction;
	canLogExtra	: Boolean;	//28.02.2025 navah1	#34141
begin
	canLogExtra	:= app.canLogExtraDetail();				//28.02.2025 navah1	#34141

	// Event?
	trans := _aSBController.myEventTransaction;
	if trans &lt;&gt; null then
		tmpDebtor := trans.myDebtor;
		if tmpDebtor &lt;&gt; null then
			if canLogExtra then	//28.02.2025 navah1	#34141
				app.invLog("Debtor " &amp; tmpDebtor.name, LogTRACE.String);
			endif;
			aDM := self.allDebtorMapsByDebtor[tmpDebtor.name];		
			if aDM &lt;&gt; null then
				if canLogExtra then	//28.02.2025 navah1	#34141
					app.invLog("Debtor map for " &amp; tmpDebtor.name, LogTRACE.String);
				endif;
				aDM.getInvoiceLineDesc(_aSBController);
				return;
			endif;
		endif;
	else // WO Transactions
		inheritMethod(_aSBController);
		return;
	endif;
	if canLogExtra then	//28.02.2025 navah1	#34141
		app.invLog("Debtor map for DEFAULT", LogTRACE.String);
	endif;
	self.myChildQuantityMap.getInvoiceLineDesc(_aSBController);
	
end;</source>
        <Parameter name="_aSBController" type="CMIF_ServiceBroker" usage="input"/>
    </JadeMethod>
