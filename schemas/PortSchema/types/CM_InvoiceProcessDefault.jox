/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 Oct 2018	jlgsl4	TFS 39618 - LNX - Initial creation

*/

vars

begin
	return true;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validateForUpdateStatus" id="ad350ce5-33ee-4cc0-8b09-1cce18750eb4">
        <source>validateForUpdateStatus(_invoice: CM_Invoice; _status: CMIF_InvoiceStatus);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 Dec 2018	jlgsl4	TFS 39618 - Linx Invoice Approved Status
*/

vars
 	proxyInvoice : CM_Invoice;
begin
	inheritMethod(_invoice, _status);
	if _status.newStatus = CM_Invoice.INVOICE_POSTED then
		proxyInvoice := _invoice.pxyGetProxyObject().CM_Invoice;
		_invoice.validateDateForStatusPost(proxyInvoice.toDT);// PAR 10090
		if not _invoice.canBePosted() then	// ccms 1773. Allows invoice posting without audits qualify
			app.raiseCMException1(ERR_CANTPOST_UNQUAL, _invoice.sequenceNum.String,null, null);
		endif;
		// cnwjk3 PAR 18434 - Date - 06/11/2008
		if _invoice.debtor.isPurchaseOrderMandatory then
			// Make sure that this invoice has one...
			if _status.purchaseOrderNumber = null then
				app.raiseCMException3(ERR_No_PO_Number, _invoice.debtor.name, _invoice.sequenceNum.String, null, null, null);
			endif;
		endif;
	endif;
epilog

end;</source>
        <Parameter name="_invoice" type="CM_Invoice"/>
        <Parameter name="_status" type="CMIF_InvoiceStatus"/>
    </JadeMethod>
</Class>
