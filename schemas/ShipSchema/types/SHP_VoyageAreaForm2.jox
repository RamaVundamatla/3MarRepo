    <JadeMethod name="getBayDrawingFrame" id="99268314-5566-433c-9036-6b2ebbd2ac42">
        <source>getBayDrawingFrame(maxFrames : Integer io) : SHP_BayDrawingFrame;
// ---------------------------------------------------------------------------
// Created:     04 September 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	tmpFrame	: SHP_BayDrawingFrame;

begin

	maxFrames := maxFrames + 1;
	tmpFrame := self.frmBay.getControl(maxFrames).SHP_BayDrawingFrame;
	if tmpFrame = null then
		tmpFrame := self.frmBay.loadControl(maxFrames).SHP_BayDrawingFrame;
	endif;
	tmpFrame.caption := null;

	return tmpFrame;

end;</source>
        <Parameter name="maxFrames" type="Integer" usage="io"/>
