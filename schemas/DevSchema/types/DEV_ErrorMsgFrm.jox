    <JadeMethod name="updateExceptionXml" id="9e76fbda-1a19-4928-9a75-a869efdc3152">
        <source>updateExceptionXml(locale1, locale2 : String; fields : StringArray):Boolean;

// update the text (xml) for the appropriate global constant (Exceptions category) 
// based on the fields from the csv fields (in stringArray) from the import file.
// will contain one, and optionally two sets of messages, for locales 1 and 2.

vars
	constantName 	: String;
	constantSource	: String;
	category 		: ConstantCategory;
	constant 		: Constant;
	msg1, shortMsg1	: String;
	msg2, shortMsg2	: String;
	xmlDoc			: CM_XMLDocument;
	xmlElement		: JadeXMLElement;
	xmlArray		: JadeXMLElementArray;
	xmlElem			: JadeXMLElement;
	hasChanged		: Boolean;
	xml				: String;
begin
	constantName 	:= fields[1];
	constantSource	:= fields[2];
	msg1			:= fields[3];
	shortMsg1		:= fields[4];
	if locale2 &lt;&gt; null then
		msg1			:= fields[3];
		shortMsg1		:= fields[4];
	endif;
	
	constant := currentSchema.getCategory(XLAT_Exceptions).getConstants[constantSource];

	if constant = null then
		app.writeStatement( "A new message (" &amp; constantName &amp; ") has been detected. Please create a new global constant for this message and re-run the import");
		return false;
	endif;
		
	create xmlDoc transient;
	create xmlArray transient;

	xmlDoc.parseString(constant.text);
	xmlDoc.getElementsByTagName(XMLTag_LocaleMsg, xmlArray);

	foreach xmlElem in xmlArray where xmlElem.attributes.size &gt; 0 and xmlElem.attributes[1].value = locale1 do
		if msg1 &lt;&gt; xmlElem.getTagValueOfName(XMLTag_Msg) then
			xmlElem.setText(global.formatAsXMLPrefix(XMLTag_Msg) &amp; msg1 &amp; global.formatAsXMLSuffix(XMLTag_Msg));
			xmlElem.setText(global.formatAsXMLPrefix(XMLTag_ShortMsg) &amp; shortMsg1 &amp; global.formatAsXMLSuffix(XMLTag_ShortMsg));
			hasChanged := true;
		endif;
	endforeach;

	if locale2 &lt;&gt; null then
		foreach xmlElem in xmlArray where xmlElem.attributes.size &gt; 0 and xmlElem.attributes[1].value = locale2 do
			if msg2 &lt;&gt; xmlElem.getTagValueOfName(XMLTag_Msg) then
				xmlElem.setText(global.formatAsXMLPrefix(XMLTag_Msg) &amp; msg2 &amp; global.formatAsXMLSuffix(XMLTag_Msg));
				xmlElem.setText(global.formatAsXMLPrefix(XMLTag_ShortMsg) &amp; shortMsg2 &amp; global.formatAsXMLSuffix(XMLTag_ShortMsg));
				hasChanged := true;
			endif;
		endforeach;
	endif;

	xml := xmlDoc.writeToString;
	
	app.writeStatement( hasChanged.String &amp;Tab&amp; xml);
	
	if hasChanged then
		//beginTransaction;
		constant.setText(xml);
		//commitTransaction;
	endif;
		
	return true;
		
end;</source>
        <Parameter name="locale1" type="String"/>
        <Parameter name="locale2" type="String"/>
        <Parameter name="fields" type="StringArray"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</GUIClass>
