    <JadeMethod name="cnEcInitializeReportAppHandler" id="7b7da07c-eb1b-40b1-a98c-54288f5995e3">
        <updating/>
        <source>cnEcInitializeReportAppHandler() updating;
// --------------------------------------------------------------------------------
// Created:		08 August 2000 by cnwdad1
//
