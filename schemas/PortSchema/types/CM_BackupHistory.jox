vars

begin
	if _set then
		// set code here
	else
		_value := self.myBackup.getDisplayStatus(self.status);
	endif;

end;</source>
        <Parameter name="_set" type="Boolean"/>
        <Parameter name="_value" type="String" usage="io"/>
    </JadeMethod>
