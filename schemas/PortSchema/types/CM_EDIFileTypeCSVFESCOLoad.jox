<Class name="CM_EDIFileTypeCSVFESCOLoad" id="a6eef696-4d00-40e0-a905-1f2624438119">
    <superclass name="CM_EDIFileTypeCSV"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>
Used by Port Everett for loading FESCO single line bookings

Operator is hardcode - FESC - so if you don't have that opertaor you can't run it.</text>
    <DbClassMap file="edi"/>
    <JadeMethod name="completeEDITIUpdates" id="a156811c-d035-4fc5-91cf-dff1d943460d">
        <source>completeEDITIUpdates(_ediBookingRef :CM_EDIBookingRefTI input; _weight, _volume: Decimal; _lineRemarks :String;
					_quantityTitle, _quantityHaz, _quantityStd20, _quantityOT20, _quantityRFH20, _quantityStd40, _quantityOT40,
					_quantityISO40, _quantityFRK40, _quantityBBLK, _quantityRORO :Integer) protected;
/*
Date		Who		Reason
21 Nov 2012	cnwcs5	Initial creation - par 30722 - refactored code
*/
vars
	lineRemarks	:String;
	strLength	:Integer;
begin
	if _volume &lt;&gt; null then
		_ediBookingRef.volume := _volume;
	endif;
	
	if _weight &lt;&gt; null then
		_ediBookingRef.weight := (_weight * 1000).Integer; //always in tons so convert to kg
	endif;
	
	lineRemarks := _lineRemarks;
	
	if _quantityTitle &lt;&gt; null then
		lineRemarks := lineRemarks &amp; _quantityTitle.String &amp; 'xTitle!, ';
	endif;
	
	if _quantityHaz &lt;&gt; null then
		lineRemarks := lineRemarks &amp; _quantityHaz.String &amp; 'xHaz!, ';
	endif;
	
	if _quantityStd20 &lt;&gt; null then
		lineRemarks := lineRemarks &amp; _quantityStd20.String &amp; 'xStd20ft, ';
	endif;
	
	if _quantityOT20 &lt;&gt; null then
		lineRemarks := lineRemarks &amp; _quantityOT20.String &amp; 'xOT20ft, ';
	endif;
	
	if _quantityRFH20 &lt;&gt; null then
		lineRemarks := lineRemarks &amp; _quantityRFH20.String &amp; 'xRFH20ft, ';
	endif;
	
	if _quantityStd40 &lt;&gt; null then
		lineRemarks := lineRemarks &amp; _quantityStd40.String &amp; 'xStd40ft, ';
	endif;
	
	if _quantityOT40 &lt;&gt; null then
		lineRemarks := lineRemarks &amp; _quantityOT40.String &amp; 'xOT40ft, ';
	endif;
	
	if _quantityISO40 &lt;&gt; null then
		lineRemarks := lineRemarks &amp; _quantityISO40.String &amp; 'xISO40ft, ';
	endif;
	
	if _quantityFRK40 &lt;&gt; null then
		lineRemarks := lineRemarks &amp; _quantityFRK40.String &amp; 'xFRK40ft, ';
	endif;
	
	if _quantityBBLK &lt;&gt; null then
		lineRemarks := lineRemarks &amp; _quantityBBLK.String &amp; 'xBBLK, ';
	endif;
	
	if _quantityRORO &lt;&gt; null then
		lineRemarks := lineRemarks &amp; _quantityRORO.String &amp; 'xRORO, ';
	endif;
	
	_ediBookingRef.bookingRemarks 	:= _ediBookingRef.bookingRemarks &amp; ' ' &amp; lineRemarks.trimBlanks;
	strLength 						:= _ediBookingRef.bookingRemarks.length;
	
	if _ediBookingRef.bookingRemarks[strLength:end] = ',' then
		_ediBookingRef.bookingRemarks := _ediBookingRef.bookingRemarks[1:strLength -1];
	endif;

	// par 30722 - if we don't have a cargo type then default to ISo Container
	if _ediBookingRef.cargoType = null then
		_ediBookingRef.setCargoType (TI_CargoType_Container);
	endif;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_ediBookingRef" type="CM_EDIBookingRefTI" usage="input"/>
        <Parameter name="_weight" type="Decimal"/>
        <Parameter name="_volume" type="Decimal"/>
        <Parameter name="_lineRemarks" type="String"/>
        <Parameter name="_quantityTitle" type="Integer"/>
        <Parameter name="_quantityHaz" type="Integer"/>
        <Parameter name="_quantityStd20" type="Integer"/>
        <Parameter name="_quantityOT20" type="Integer"/>
        <Parameter name="_quantityRFH20" type="Integer"/>
        <Parameter name="_quantityStd40" type="Integer"/>
        <Parameter name="_quantityOT40" type="Integer"/>
        <Parameter name="_quantityISO40" type="Integer"/>
        <Parameter name="_quantityFRK40" type="Integer"/>
        <Parameter name="_quantityBBLK" type="Integer"/>
        <Parameter name="_quantityRORO" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="create" id="2633f7ee-2494-4a75-8487-522f9a555b51">
        <updating/>
        <source>create() updating;
/*
----------   ----------  --------------------------------------------------
Created:	10 July 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars

begin
	self.name	:= "FESCO Booking Ref";
	self.type	:= EDIFileType_CSVFESCOBookRef;

end;</source>
    </JadeMethod>
    <JadeMethod name="findEDIDataType" id="9a85a6d0-fb4f-49c0-88c4-6366e8fd5003">
        <source>findEDIDataType(_ediDataClass: Class io; _dataType, _fileTypeCode: Integer io); // cnwrs1 Par 24207 ccms 1117 11 May 2010
/*
----------   ----------  --------------------------------------------------
Created:	10 July 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars

begin
	_ediDataClass := CM_EDIDataBookingRef;
	_dataType := EDIDataType_BookingSingleLine;
	_fileTypeCode := self.type;

end;</source>
        <Parameter name="_ediDataClass" type="Class" usage="io"/>
        <Parameter name="_dataType" type="Integer" usage="io"/>
        <Parameter name="_fileTypeCode" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="processFile" id="e44c8f20-6379-4728-90ec-6d5f3910d633">
        <updating/>
        <source>processFile(_ediFile: CM_EDIFile input) updating, protected;
/*
----------   ----------  --------------------------------------------------
Created:	17 August 2006 By cnwth2

Purpose:	

Changed On  Changed By  Reason
----------  ----------  --------------------------------------------------
21/11/2012	cnwcs5		par 30722 - default cargo type to ISO Container
21/11/2012	cnwcs5		par 30724 - translation of discharge port/consignor
07/03/2013	cnwcs5		CCMS POL 2097 / par 31259 - include foundMatch in method signatures
*/
//12 Jan 2015	cnwrs1	Par 35504 - Refactor EDI file load for .NET
//08 Oct 2015	cnwrs1	Par 36863 - make EDI consistant times when refreshing progress bar
// 13 May 2016	cnwns1	TFS 488 - Multi Timezone Support
// 08 May 2018	jlgrs1	TFS 36425 SingleLine Booking partial processing not working
// 18 Jan 2019	jlgrs1	TFS 41659 42276 STWR Make EDI MultiThreaded Stage 8
// 08 Apr 2019	jlgrs1	TFS 41913 STWR - Reconfiguration of the EDI Operation form to better handle EDI collection locks while loading 
//
constants
	ProgressBarRefresh	: Integer = 2000;	
	Delim		= ',';
	FESCO		= 'FESC';
vars
	passport	: CM_Passport;
	monitor		: CMIF_Monitor;
	operator	: CM_Operator;
	
	line, consignor, currentDisPort, disPort, bookingNumber, 
	hazTitleStr, ignoreField,lineRemarks			: String;
	ediBookingRef									: CM_EDIBookingRefTI;
	quantityTitle, quantityHaz, quantityStd20, quantityOT20, quantityRFH20, quantityStd40, quantityOT40, quantityISO40, 
	quantityFRK40, quantityBBLK, quantityRORO		: Integer;
	pos, count, numLines, length, width, height 	: Integer;
	weight, volume									: Decimal[22,3];
//	binaryLine										: Binary;
	foundMatch										: Boolean;
	theLines : HugeStringArray;
	progressInt	: TimeStampInterval;
	progressTS : TimeStamp;
begin
	progressTS := app.actualTimeServer();// 13 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	passport	:=	app.myPassport;
	monitor		:= passport.myCMIFMonitor;
	
	operator	:= app.myRoot.allOperators [FESCO];
	
	if operator = null then
		app.raiseUnexpectedProgramError (self.class.name, method.name, "Operator FESCO has not been set-up");
	endif;
	
	create theLines transient;
	self.rawDataToHSA(_ediFile, theLines);
	numLines	:= theLines.size;
	foreach line in theLines do
		count	:=	count + 1;
		
		progressInt := app.actualTimeServer() - progressTS;// 13 May 2016	cnwns1	TFS 488 - Multi Timezone Support
		if monitor &lt;&gt; null  and (progressInt.getMilliseconds &gt;= ProgressBarRefresh) then
			monitor.updateProgressWithCaption("Processing File Data", numLines, count, "Loading EDI file Step 3 of 3.");
			progressTS := app.actualTimeServer();// 13 May 2016	cnwns1	TFS 488 - Multi Timezone Support
		endif;
		
		pos 	:= 1;
		disPort := line.cnEcNextDelimitedField(Delim, pos).trimBlanks();//field 1
		
		if disPort = 'VESSEL TOTALS' then
			break;
		endif;
	
		if disPort &lt;&gt; null and disPort &lt;&gt; currentDisPort and disPort &lt;&gt; currentDisPort &amp; ' TOT' then
			currentDisPort := disPort;//change of discharge port
			continue;
		endif;
		
		consignor 		:= line.cnEcNextDelimitedField(Delim, pos).trimBlanks(); 			// field #2
		bookingNumber 	:= line.cnEcNextDelimitedField(Delim, pos).trimBlanks().toUpper; 	// field #3
		
		if consignor &lt;&gt; null and bookingNumber &lt;&gt; null or disPort = currentDisPort &amp; ' TOT' then // we have a booking ref line, or have reach the end of a booking ref
			//we're on a booking reference line - finish up with the current one
			if ediBookingRef &lt;&gt; null then
				self.completeEDITIUpdates (ediBookingRef, weight, volume, lineRemarks, quantityTitle, quantityHaz, quantityStd20, quantityOT20, 
											quantityRFH20, quantityStd40, quantityOT40, quantityISO40, quantityFRK40, quantityBBLK, quantityRORO);	// par 30724 nov 2012
			endif;
			
			quantityTitle	:= null;
			quantityHaz		:= null;
			quantityStd20	:= null;
			quantityOT20	:= null;
			quantityRFH20	:= null;
			quantityStd40	:= null;
			quantityOT40	:= null;
			quantityISO40	:= null;
			quantityFRK40	:= null;
			quantityBBLK	:= null;
			quantityRORO	:= null;
			length			:= null;
			width			:= null;
			height			:= null;
			volume			:= null;
			weight			:= null;
			lineRemarks		:= null;
			
			ediBookingRef 	:= null;
			
			if bookingNumber = 'PENDING' or bookingNumber = null then//don't load
				continue;
			endif;
			
			// lines underneith will be appended to 
			// this guy until the consignor and booking number change again
			create ediBookingRef persistent;
			ediBookingRef.setMyEDIFile(_ediFile);
			ediBookingRef.setMyEDIData(_ediFile.ediData);
			ediBookingRef.setId(bookingNumber);
			// no translation of operator code - it is hard coded
			ediBookingRef.operatorCode 		:= FESCO;
			// par 30724 - translate discharge port
			ediBookingRef.dischargePort 	:= operator.getXlationSystemCode (currentDisPort, XLATION_TYPE_PORT_BYOP, foundMatch);
			// par 30274 - translate consignor
			ediBookingRef.consignor 		:= operator.getXlationSystemCode (consignor, XLATION_TYPE_CONSIGNEE_BYOP, foundMatch)[1:30];
			ediBookingRef.bookingRemarks 	:= line.cnEcNextDelimitedField(Delim, pos).trimBlanks();//field #4
			
			self.resolveCargoType(ediBookingRef.bookingRemarks, ediBookingRef);
			
			ignoreField 			:= line.cnEcNextDelimitedField(Delim, pos).trimBlanks();//field #5
			ignoreField 			:= line.cnEcNextDelimitedField(Delim, pos).trimBlanks();//field #6
			ediBookingRef.number 	:= line.cnEcNextDelimitedField(Delim, pos).trimBlanks().Integer;//field #7 total quantity
			
			continue;
			
		elseif ediBookingRef = null then//we havn't come accross a booking reference yet
			continue;
		endif;
		
		lineRemarks 		:= line.cnEcNextDelimitedField(Delim, pos).trimBlanks();//field #4
		
		if lineRemarks &lt;&gt; null and ediBookingRef.cargoType = null then
			self.resolveCargoType(lineRemarks, ediBookingRef);
		endif;
		
		ignoreField 		:= line.cnEcNextDelimitedField(Delim, pos).trimBlanks();//field #5
		hazTitleStr 		:= line.cnEcNextDelimitedField(Delim, pos).trimBlanks();//field #6
		
		if hazTitleStr.toUpper.cnContains('TITLE') then
			quantityTitle := quantityTitle + 1;
			
		elseif hazTitleStr.toUpper.cnContains('HAZ') then
			quantityHaz := quantityHaz + 1;
		endif;
		
		ignoreField 		:= line.cnEcNextDelimitedField(Delim, pos).trimBlanks();//field #7
		ignoreField 		:= line.cnEcNextDelimitedField(Delim, pos).trimBlanks();//field #8
		ignoreField 		:= line.cnEcNextDelimitedField(Delim, pos).trimBlanks();//field #9
		
		quantityStd20 		:= quantityStd20 + line.cnEcNextDelimitedField(Delim, pos).trimBlanks().Integer;//field #10
		quantityOT20 		:= quantityOT20 + line.cnEcNextDelimitedField(Delim, pos).trimBlanks().Integer;//field #11
		quantityRFH20 		:= quantityRFH20 + line.cnEcNextDelimitedField(Delim, pos).trimBlanks().Integer;//field #12
		quantityStd40		:= quantityStd40 + line.cnEcNextDelimitedField(Delim, pos).trimBlanks().Integer;//field #13
		quantityOT40		:= quantityOT40 + line.cnEcNextDelimitedField(Delim, pos).trimBlanks().Integer;//field #14
		quantityISO40		:= quantityISO40 + line.cnEcNextDelimitedField(Delim, pos).trimBlanks().Integer;//field #15
		quantityFRK40		:= quantityFRK40 + line.cnEcNextDelimitedField(Delim, pos).trimBlanks().Integer;//field #16
		quantityBBLK		:= quantityBBLK + line.cnEcNextDelimitedField(Delim, pos).trimBlanks().Integer;//field #17
		quantityRORO		:= quantityRORO + line.cnEcNextDelimitedField(Delim, pos).trimBlanks().Integer;//field #18
		
		ignoreField			:= line.cnEcNextDelimitedField(Delim, pos).trimBlanks();//field #19
		ignoreField			:= line.cnEcNextDelimitedField(Delim, pos).trimBlanks();//field #20
		ignoreField			:= line.cnEcNextDelimitedField(Delim, pos).trimBlanks();//field #21
		
		volume				:= volume + line.cnEcNextDelimitedField(Delim, pos).trimBlanks().Decimal;//field #22
		weight				:= weight + line.cnEcNextDelimitedField(Delim, pos).trimBlanks().Decimal;//field #23
		
	endforeach;

	if ediBookingRef &lt;&gt; null then
		self.completeEDITIUpdates (ediBookingRef, weight, volume, lineRemarks, quantityTitle, quantityHaz, quantityStd20, quantityOT20, 
									quantityRFH20, quantityStd40, quantityOT40, quantityISO40, quantityFRK40, quantityBBLK, quantityRORO);	// par 30724 nov 2012
	endif;
epilog
	delete theLines;
end;</source>
        <access>protected</access>
        <Parameter name="_ediFile" type="CM_EDIFile" usage="input"/>
    </JadeMethod>
    <JadeMethod name="resolveCargoType" id="1515246f-c533-4ddb-bb2a-7e14a61c7c95">
        <updating/>
        <source>resolveCargoType(_fieldValue : String; _ediBookingRef : CM_EDIBookingRefTI input) updating, protected;
/*
----------   ----------  --------------------------------------------------
Created:	17 August 2006 By cnwth2

Changed On   Changed By  Reason
----------   ----------  --------------------------------------------------
*/
vars
	terminal		: CM_Terminal;
	cargoBOLType	: CM_CargoBOLType;
	cargoType		: CM_CargoType;
	product			: CM_Product;
	value			:String;
begin
	terminal 	:= app.myPassport.myTerminal;
	value 		:= _fieldValue.toUpper;	
	
	if value.cnContains('CONTAINER') or value.cnContains('CTR') then
		_ediBookingRef.setCargoType(TI_CargoType_Container);

	else
		foreach cargoBOLType in terminal.allCargoBOLTypes do
			if CM_BOLType.hasInstance(cargoBOLType) then
				continue;
			endif;
	
			cargoType := cargoBOLType.CM_CargoType;
			
			foreach product in cargoType.allProducts do
				if product.code.toUpper = value or product.description.toUpper = value then
					_ediBookingRef.product := product.code;
					
					_ediBookingRef.setCargoType(cargoType.id);
					
					return;
				endif;
			endforeach;
		endforeach;
	endif;	
end;</source>
        <access>protected</access>
        <Parameter name="_fieldValue" type="String"/>
        <Parameter name="_ediBookingRef" type="CM_EDIBookingRefTI" usage="input"/>
    </JadeMethod>
</Class>
