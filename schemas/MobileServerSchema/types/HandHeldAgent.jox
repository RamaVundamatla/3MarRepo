    <JadeMethod name="comboBoxDamageDef" id="5c449a93-a420-4a13-9a09-ce6443f68c66">
        <source>comboBoxDamageDef(_cmb: ComboBox input; _damageInstance: CM_DamageInstance);
/*
----------   ----------  --------------------------------------------------
Created:	20 September 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	damageDef			: CM_DamageDefinitionCode;
	damageCodeDict		: CM_DamageDefinitionByCodeDict;
begin
	_cmb.clear();
	_cmb.sorted := true;
	damageCodeDict := app.myRoot.allDamageDefinitionCodes;
	foreach damageDef in damageCodeDict do
		_cmb.itemObject[_cmb.addItem(damageDef.code)] := damageDef;
	endforeach;
	
	if _damageInstance &lt;&gt; null and damageCodeDict.includes(_damageInstance.myDamageDefinition) then
		_cmb.listObject := _damageInstance.myDamageDefinition;
	endif;
	
end;


</source>
        <Parameter name="_cmb" type="ComboBox" usage="input"/>
        <Parameter name="_damageInstance" type="CM_DamageInstance"/>
    </JadeMethod>
    <JadeMethod name="comboBoxDamageSeverity" id="51719336-6425-45ab-b7cb-dbbb338b4613">
        <source>comboBoxDamageSeverity(_cmb: ComboBox input; _severity: Integer);
/*
----------   ----------  --------------------------------------------------
Created:	20 September 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
28 June 2022 navhl20 TFS 53862 EUP - WMS - Damage Recording Extra Details
----------   ----------  --------------------------------------------------
*/
vars
	damageSeverity : CM_DamageSeverity;		// 28 June 2022 navhl20 TFS 53862
begin
	_cmb.clear();
	_cmb.sorted := true;
	
	//Start 28 June 2022 navhl20 TFS 53862
	foreach damageSeverity in self.myTerminal.allDamageSeverities do
		_cmb.cnEcAddItemDataObject(damageSeverity.description,damageSeverity.level,damageSeverity);
	endforeach;
	/*_cmb.itemData[_cmb.addItem(DamageSeverity_1.String)] := DamageSeverity_1;
	_cmb.itemData[_cmb.addItem(DamageSeverity_2.String)] := DamageSeverity_2;
	_cmb.itemData[_cmb.addItem(DamageSeverity_3.String)] := DamageSeverity_3;
	_cmb.itemData[_cmb.addItem(DamageSeverity_4.String)] := DamageSeverity_4;
	_cmb.itemData[_cmb.addItem(DamageSeverity_5.String)] := DamageSeverity_5;*/
	//End  28 June 2022 navhl20 TFS 53862
	
	if _cmb.findString(1, _severity.String) &gt; 0 then
		_cmb.text := _severity.String;
	endif;
	
end;







</source>
        <Parameter name="_cmb" type="ComboBox" usage="input"/>
        <Parameter name="_severity" type="Integer"/>
    </JadeMethod>
