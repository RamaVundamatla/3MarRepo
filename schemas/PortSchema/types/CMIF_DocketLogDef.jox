    <JadeMethod name="getTIsToValue" id="cfdb1234-02ea-476d-8cd3-b4ac354ef1ca">
        <source>getTIsToValue(_tiSet : CM_TISet input; _totalRequired, _meanSED : Real; _comparisonOperator, _uom : String; _subTotal : Real io) : Boolean;
//--------------------------------------------------
// Created:	20 January 2006 By: cnwgd1
//--------------------------------------------------
// CCMS 1083
// Return "True" when total required is met
vars
	tmpLog : CM_Log;
	tmpTI : CM_TrackedItem;
begin

	if _tiSet = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Null parameter "_tiSet"');
		return false;
	endif;
	
	if _totalRequired &lt;&gt; null
	and _subTotal &gt;= _totalRequired then
		return true;
	endif;
		
	// Do not re-set values (_tiSet, _subTotal) as _tiSet is being populated from many occurances
	if _totalRequired = null and _meanSED = null then
		//supply all of the tracked items
		self.allTi.copy(_tiSet);
		return false;

	elseif _uom = BOL_UOM_PIECE_COUNT then
		//supply tracked items by piece count upto the required total
		foreach tmpTI in self.allTi do
			_tiSet.add(tmpTI);
			_subTotal := _subTotal+1;
			if _subTotal = _totalRequired then
				return true;
			endif;			
		endforeach;

	elseif _uom = BOL_UOM_VOLUME then
		//supply tracked items by volume upto the required total
		foreach tmpTI in self.allTi do
			if _subTotal + tmpTI.getMyTotalVolume &gt; _totalRequired then
				//try to find a smaller log
				continue;
			endif;
			
			_subTotal := _subTotal + tmpTI.getMyTotalVolume;
			_tiSet.add(tmpTI);
			if _subTotal = _totalRequired then
				return true;
			endif;			
		endforeach;			

	elseif _uom = BOL_UOM_WEIGHT then
		//supply tracked items by weight upto the required total
		foreach tmpTI in self.allTi do
			tmpLog := tmpTI.CM_Log;
			if _subTotal + tmpLog.weightTonnes &gt; _totalRequired then
				//try to find a smaller log
				continue;
			endif;		
			_subTotal := _subTotal + tmpLog.weightTonnes;
			_tiSet.add(tmpLog);
			if _subTotal = _totalRequired then
				return true;
			endif;			
		endforeach;					

	else
		//supply tracked items by mean SED upto the required total
		foreach tmpTI in self.allTi do
			if _comparisonOperator = app.getErrorString(Less_Than) then
				//use TI's with a mean SED less than the supplied SED
				if tmpTI.CM_Log.sedMean &gt;= _meanSED then
					continue;
				endif;

			elseif _comparisonOperator = app.getErrorString(Equal_To) then	
				//use TI's with a mean SED equal to the supplied SED			
				if tmpTI.CM_Log.sedMean &lt;&gt; _meanSED then
					continue;
				endif;			
			else
				//default is to use TI's with a mean SED greater than the supplied SED
				if tmpTI.CM_Log.sedMean &lt;= _meanSED then
					continue;
				endif;				
			endif;
			
			_tiSet.add(tmpTI);
			_subTotal := _subTotal+1;
			if _subTotal = _totalRequired then
				return true;
			endif;					
		endforeach;							
		
	endif;
	
	if _totalRequired = null then
		//all the logs are being supplied
		return false;
	else
		return _subTotal = _totalRequired;
	endif;
end;</source>
        <Parameter name="_tiSet" type="CM_TISet" usage="input"/>
        <Parameter name="_totalRequired" type="Real"/>
        <Parameter name="_meanSED" type="Real"/>
        <Parameter name="_comparisonOperator" type="String"/>
        <Parameter name="_uom" type="String"/>
        <Parameter name="_subTotal" type="Real" usage="io"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
