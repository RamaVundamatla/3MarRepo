    <JadeMethod name="utlDeleteInvoiceLineChargeMap" id="b108a6b2-a4b1-43a2-980f-8c0a05b31805">
        <source>utlDeleteInvoiceLineChargeMap(_invoiceLineChargeMap : CM_InvoiceLineChargeMapping io; _passport : CM_Passport input);
// ---------------------------------------------------------------------------
// Created:		February 2008 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	toDelete : CM_InvoiceLineChargeMapping;
	theLine : CM_InvoiceLineDesc;
	theParent, theCombination : CM_Object;
	passBack : String;
begin

	self.initialiseActivity();

	app.setContinueCMExceptions(true);

	app.myValDA.valInvoiceLineChargeMap(_invoiceLineChargeMap);
	
	if (not self.checkValidationWithPassport(_passport)) then // Show any Errors and Warnings in a list
		return;
	endif;


	app.setContinueCMExceptions(false);

	if _passport.noErrors then
		self.myDeleteAuditAgent.audDeleteGeneric(_invoiceLineChargeMap);
	endif;

	if _passport.noErrors then
		toDelete := _invoiceLineChargeMap;
		theLine := _invoiceLineChargeMap.myInvoiceLineDesc;
		theParent := _invoiceLineChargeMap.myParentMappingObject;
		 theCombination := _invoiceLineChargeMap.myCombinationMappingObject;
		 passBack := theLine.getOidString &amp; "~" &amp; theParent.getOidString() &amp; "^" &amp; theCombination.getOidString();
		_invoiceLineChargeMap.erase(NORMAL_ERASE);
	endif;
	if _passport.noErrors then
		_passport.myTerminal.causeEvent(_passport.myTerminal.getTerminalEvent(EVENT_MAPPING_DELETE),false,passBack);
	endif;

epilog
	return;

end;</source>
        <Parameter name="_invoiceLineChargeMap" type="CM_InvoiceLineChargeMapping" usage="io"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlDeleteInvoiceLineChargeMaps" id="934cf143-66c0-44d4-acca-d238b6db8fd3">
        <updating/>
        <source>utlDeleteInvoiceLineChargeMaps(_bank : CM_Bank; _maps : CM_InvLineChargingMapsDict; _passport : CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:		20 February 2008 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	parent : CM_Object;
begin
	self.initialiseActivity();

	if _maps.isEmpty then
		return;
	endif;
	
	parent := _maps.first.myParentMappingObject;
	
	_maps.purge;

	if _passport.noErrors then
		_passport.myTerminal.causeEvent(_passport.myTerminal.getTerminalEvent(EVENT_MAPPING_PURGE),false,parent);
	endif;

end;</source>
        <Parameter name="_bank" type="CM_Bank"/>
        <Parameter name="_maps" type="CM_InvLineChargingMapsDict"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
