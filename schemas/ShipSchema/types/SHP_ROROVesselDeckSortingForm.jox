<GUIClass name="SHP_ROROVesselDeckSortingForm" id="4a5a6101-76af-4d01-9eda-1b64b2b2ba62">
    <superclass name="SHP_RORODeckSortingForm"/>
    <transient/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <ImplicitInverseRef name="myCurrentROROVesselStructure" id="cfd524bd-f8ab-4e57-a9a5-6c06059f41eb">
        <embedded/>
        <type name="CM_ROROVesselStructure"/>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="pxyDecks" id="8e5d037e-1bfa-4d65-b407-d1096f243417">
        <memberTypeInverse/>
        <type name="CM_DeckVesselByOrdinalDIct"/>
        <access>readonly</access>
