    <JadeMethod name="prepareAuditDetail" id="820a636b-2278-483e-a959-40176fcc548b">
        <source>prepareAuditDetail(_str : String io);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 April 2023	navhl20	ChangeRequest 57301:[57303] EUP - [Framework] - Improve Audits on Work orders
21/04/2023	navcs2	Bug 57691: MTN - WO - Audits are missing for the totalActioned
*/

vars
	tmpStr	 	: String;
	train		: CM_Train;
begin
	inheritMethod(_str);
	tmpStr := null;
	if self.allTrains.isNotEmpty then
		foreach train in self.allTrains do
			if tmpStr = null then
				tmpStr := tmpStr &amp; train.code;
			else
				tmpStr :=tmpStr &amp; Comma &amp; train.code;
			endif;
		endforeach;
		_str := _str &amp; app.getErrorString(Trains) &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp;tmpStr &amp; AuditStringSeparator;
	endif;
	
	// 21/04/2023	navcs2	Bug 57691 Start
	tmpStr := null;
	if self.allTrainsActioned.isNotEmpty then
		tmpStr := self.allTrainsActioned.size.String;
		_str := _str &amp; "Number Actioned" &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp;tmpStr &amp; AuditStringSeparator;
	else
		tmpStr := 0.String;
		_str := _str &amp; "Number Actioned" &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp;tmpStr &amp; AuditStringSeparator;
	endif;
	// 21/04/2023	navcs2	Bug 57691 End
epilog

end;</source>
        <Parameter name="_str" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="cdf8cc8c-4721-477d-a612-253b4548851d">
        <source>pxyCreateUpdateProxy(): SelfType;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
19 December 2022	navcs2	ChangeRequest 56833:[56834] EUP - VAS Train Work Order

*/

vars
	pxy 		: SelfType;
	completedOK : Boolean;
begin
	pxy := inheritMethod();
	
	self.allTrains.copy(pxy.allTrains);
	self.allTrainsActioned.copy(pxy.allTrainsActioned);
	self.allTrainsCompleted.copy(pxy.allTrainsCompleted);
	
	completedOK := true;
	return pxy;
epilog
	
	if not completedOK then
		delete pxy;
	endif;
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="7e5f1e31-808f-4d1c-a95a-ae66eb920a57">
        <updating/>
        <source>setForUpdate(_pxyWoDDtl: CM_WodToDoTrain) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
03 October 2022	navcs2	ChangeRequest 54344: EUP - VAS Work Orders - Jobs
20 Mar 2023  	navhl20 Defect 57233: MTN - Editing Vas Tasks is not working correctly
*/

vars

begin
	inheritMethod(_pxyWoDDtl);
	self.allTrains.clear();																//20.3.2023 navhl20	#57233
	_pxyWoDDtl.CM_WodToDoTrain.allTrains.copyNoDuplicates(self.allTrains, false);
epilog

end;</source>
        <Parameter name="_pxyWoDDtl" type="CM_WodToDoTrain"/>
    </JadeMethod>
