    <JadeMethod name="getTemplateCalendarString" id="15374735-9fd1-4f35-aaf3-f681af3531ad">
        <source>getTemplateCalendarString( _date : Date ):String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 April 2013	cnwndl1	Initial creation	Par 31393
// 18 May 2016	cnwns1	TFS 488 - Multi Timezone Support
*/

vars

	dayTemplate : CM_VehicleBookingDayTemplate;
	systemTS,
	localTS: TimeStamp;
begin

	if not _date.isValid then
		return "No Date";
	endif;
	
	if self.allVehicleBookingDayTemplates.isEmpty then
		return app.getErrorString(Vehicl_schedu_templa_found_ter);
	endif;
	
	systemTS.cnEcSetDateAndTime(_date,TimeStartOfDay);										// 18 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	localTS := self.systemToLocalTime(systemTS);											// 18 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	dayTemplate := self.allVehicleBookingDayTemplates.getFirstTemplateFor( localTS.date() );// 18 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	if dayTemplate &lt;&gt; null then
		return dayTemplate.name;
	else
		return app.getErrorString1(No_Vehicl_schedu_defaul_templa,null);
	endif;

epilog

end;</source>
        <Parameter name="_date" type="Date"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getTimeslotGraceTimeInterval" id="f99d6da4-80c9-42e3-81f2-815120ea9190">
