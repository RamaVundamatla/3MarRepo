    <JadeMethod name="doChangeBay" id="57164588-e276-4feb-8dcc-1f7e24723379">
        <source>doChangeBay(_bay : CM_Bay);
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
11 May 2009	cnwer1	Initial creation

*/

vars

begin	
	// if it is already this bay return
	if _bay = self.myBayDisplay.myBay then
		return;
	endif;
	self.myBayDisplay.setBay(_bay);
	self.frmGridArea.doDrawBay(self.myBayDisplay.myBay, self.frmScrollDraw,3, null);
		
epilog

end;</source>
        <Parameter name="_bay" type="CM_Bay"/>
    </JadeMethod>
    <JadeMethod name="doEnablePens" id="c676b30e-825c-4112-a87c-564476fd0ad5">
        <updating/>
        <source>doEnablePens() updating;
// ---------------------------------------------------------------------------
// Created:		July 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	enabledPens : Boolean;
begin
	enabledPens := self.mode &lt;&gt; self.Mode_View;
	self.btnPen30.enabled := enabledPens;// PAR 16415 CCMS 1029
	self.btnPen40.enabled := enabledPens;// PAR 16415 CCMS 1029
	self.btnPen45.enabled := enabledPens;// PAR 16415 CCMS 1029
	self.btnPen53.enabled := enabledPens;// PAR 16415 CCMS 1029
	self.btnPenAftDoors20.enabled := enabledPens;
	self.btnPenAftDoors40.enabled := enabledPens;
	self.btnPenAftMotor20.enabled := enabledPens;
	self.btnPenAftMotor40.enabled := enabledPens;
	self.btnPenCellShiftL.enabled := enabledPens;
	self.btnPenCellShiftR.enabled := enabledPens;
	self.btnPenClearSel.enabled := enabledPens;
	self.btnPenEmpty.enabled := enabledPens;
	self.btnPenHeavy.enabled := enabledPens;
	self.btnPenVoltage.enabled := enabledPens;
	self.btnPenLidCreate.enabled := enabledPens;
	self.btnPenLidDelete.enabled := enabledPens;
	self.btnPenLidDelete.enabled := enabledPens;
	self.btnPenLidMidEnd.enabled := enabledPens;
	self.btnPenLidMidSt.enabled := enabledPens;
	self.btnPenPower.enabled := enabledPens;
	self.btnPenReefer.enabled := enabledPens;
	self.btnPenUnavail.enabled := enabledPens;
	self.btnPenWaterCool.enabled := enabledPens;
end;</source>
    </JadeMethod>
    <JadeMethod name="doResize" id="d15bb4f8-bf2a-4073-9038-56dd913f0a6e">
        <updating/>
        <source>doResize() updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
12 May 2009	cnwer1	Initial creation

*/

vars
	aW,
	aH : Real;
begin
	inheritMethod();
	if self.frmScrollDraw.allGridAreasByRowColumn.isEmpty then
		aW :=self.frmScrollDraw.width;
		aH := self.frmScrollDraw.height;
	else
		aW := self.frmScrollDraw.getWidthOfAllFrames();
		aH := self.frmScrollDraw.getHeightOfAllFrames();
	endif;

	self.frmScrollDraw.resizeDrawingFrame(aW,aH);
	self.frmScrollDraw.repositionScrollBars;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="initScrollableDrawFrame" id="2e214f3f-b77b-47af-a53f-21f6c7ae7b57">
        <source>initScrollableDrawFrame();
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
08 May 2009	cnwer1	Initial creation

*/

vars

	scrollDrawFrame : CMUI_ScrollableDrawingFrame;
	
begin
	scrollDrawFrame:= self.frmScrollDraw;
	scrollDrawFrame.allGridAreasByColumnRow.clear;
	scrollDrawFrame.allGridAreasByRowColumn.clear;
	scrollDrawFrame.setupDrawingAttributes();
	scrollDrawFrame.myHLabels.visible := false;
	scrollDrawFrame.myVLabels.visible := false;
	scrollDrawFrame.myParentForm := self;
	
	scrollDrawFrame.setHLabelDetails(0);
	scrollDrawFrame.setVLabelDetails(0);
	scrollDrawFrame.labels := ScrollBars_None;
	
	self.frmGridArea.initForBayLayout();


epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="loadDetails" id="ad6af17b-63c0-4d77-968a-55500b88d18d">
        <updating/>
        <source>loadDetails() updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
08 May 2009	cnwer1	Initial creation

*/

vars
	tmpTerm : CM_Terminal;
	tmpUser : CM_User;
	tmpUserT : CM_UserTerminal;
	displayByName : Boolean;
begin

	// Prioritise self.myTerminal over the application call as this can result in the incorrect terminal being returned due
	// to notes changing the terminal in the passport - cnwcp2 - 20/2/2009 - PAR#18073
	tmpTerm := self.myTerminal;
	if tmpTerm = null then
		tmpTerm := app.getMyTerminalDO_NOT_USE();
		if tmpTerm = null then
			tmpTerm := self.myBayDisplay.getTerminal;
			if tmpTerm = null then
				tmpUser := app.getMyUser();
				if tmpUser &lt;&gt; null then
					tmpUserT := tmpUser.allUserTerminals.first;
					if tmpUserT &lt;&gt; null then
						tmpTerm := tmpUserT.getRealTerminal;
					endif;
				endif;
			endif;
		endif;
	endif;
	self.myTerminal:=tmpTerm;
	if self.myTerminal &lt;&gt; null then
		displayByName:=self.myTerminal.getConfig(VesselComboByName).Boolean;
	endif;
	self.myBayDisplay.initSelectBayCombo(self.cmbSelBay);
	self.myBayDisplay.initSelectVoyVesselCombo(self.cmbSelVoyVes,displayByName);
	if self.myBayDisplay.myBay &lt;&gt; null then
		//draws the default bay
		self.frmGridArea.doDrawBay(self.myBayDisplay.myBay, self.frmScrollDraw,3, null);
		self.doEnablePens();
	endif;
	

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setBay" id="75efc096-b990-473a-8c3b-a3e44c0073ad">
        <updating/>
        <source>setBay(_bay : CM_Bay) updating;
/*

Purpose:			

Parameters:		To get the mode we are running in i.e. voyage or vessel also must
				be done before load Form cause it will set the different permissions

Return Value:		


Date		Who		Reason
08 May 2009	cnwer1	Initial creation

*/

vars
	theForm : CM_BaseForm;
begin
	if _bay.isKindOf(CM_BayDefn) then
		create self.myBayDisplay as SHP_VesselBayDisplay;
	else
		create self.myBayDisplay as SHP_VoyageBayDisplay;
	endif;
		
	self.myBayDisplay.setBay(_bay);
	theForm:=self;
	self.myBayDisplay.setFormPermissions(theForm);
epilog

end;</source>
        <Parameter name="_bay" type="CM_Bay"/>
    </JadeMethod>
    <JadeMethod name="setupBtnPens" id="209c3c10-a2e0-4920-8a84-9ca62faf8593">
        <source>setupBtnPens() protected;
// ---------------------------------------------------------------------------
// Created:     12 September 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	atttDict	: CM_DrawingAttributesByCodeDict;
	drawAttr	: CM_DrawingAttribute;
	ls			: Boolean;
	
begin

	atttDict := app.myRoot.allDrawingAttributes;

	
	drawAttr := atttDict[PicTIDoorsAft];
	if drawAttr &lt;&gt; null then
		self.btnPenAftDoors20.setFontFromDrawingAttr(drawAttr);
	endif;
	drawAttr := atttDict[PicTIDoorsAft40];
	if drawAttr &lt;&gt; null then
		self.btnPenAftDoors40.setFontFromDrawingAttr(drawAttr);
	endif;
	drawAttr := atttDict[PicTIMotorAft];
	if drawAttr &lt;&gt; null then
		self.btnPenAftMotor20.setFontFromDrawingAttr(drawAttr);
	endif;
	drawAttr := atttDict[PicTIMotorAft40];
	if drawAttr &lt;&gt; null then
		self.btnPenAftMotor40.setFontFromDrawingAttr(drawAttr);
	endif;

	// PAR 18682 CCMS SFW 1055
	drawAttr := atttDict[PicTI45Footer];
	if drawAttr &lt;&gt; null then
		self.btnPen45.setFontFromDrawingAttr(drawAttr);
	endif;
	drawAttr := atttDict[PicTI40Footer];
	if drawAttr &lt;&gt; null then
		self.btnPen40.setFontFromDrawingAttr(drawAttr);
	endif;
	// PAR 16415 CCMS 1029
	drawAttr := atttDict[PicTI30Footer];
	if drawAttr &lt;&gt; null then
		self.btnPen30.setFontFromDrawingAttr(drawAttr);
	endif;
	// PAR 16415 CCMS 1029
	drawAttr := atttDict[PicTI53Footer];
	if drawAttr &lt;&gt; null then
		self.btnPen53.setFontFromDrawingAttr(drawAttr);
	endif;

	drawAttr := atttDict[PicTIMTOnly];
	if drawAttr &lt;&gt; null then
		self.btnPenEmpty.setFontFromDrawingAttr(drawAttr);
	endif;

	drawAttr := atttDict[PicTIHeavy];
	if drawAttr &lt;&gt; null then
		self.btnPenHeavy.setFontFromDrawingAttr(drawAttr);
	endif;

	drawAttr := atttDict[PicTIVoltageSingle];
	if drawAttr &lt;&gt; null then
		self.btnPenVoltage.setFontFromDrawingAttr(drawAttr);
	endif;

	drawAttr := atttDict[PicTIConnected];
	if drawAttr &lt;&gt; null then
		self.btnPenPower.setFontFromDrawingAttr(drawAttr);
	endif;

	drawAttr := atttDict[PicTIReefer];
	if drawAttr &lt;&gt; null then
		self.btnPenReefer.setFontFromDrawingAttr(drawAttr);
	endif;

	drawAttr := atttDict[PicTIUnavail];
	if drawAttr &lt;&gt; null then
		self.btnPenUnavail.setFontFromDrawingAttr(drawAttr);
	endif;

	drawAttr := atttDict[PicTIWaterCooled];
	if drawAttr &lt;&gt; null then
		self.btnPenWaterCool.setFontFromDrawingAttr(drawAttr);
	endif;
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setupForm" id="3138f99b-677f-463c-ae75-56cf6bc1ab05">
        <updating/>
        <source>setupForm() updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
08 May 2009	cnwer1	Initial creation

*/

vars
	tmpTerm : CM_Terminal;
	tmpUser : CM_User;
begin
	inheritMethod();
	//until we have created the nav item and loaded correctly via self.loadForm need to create assistant
	self.createMyAssistant(SHP_Assistant);
	self.myBayDisplay.setMyAssitant(self.myAssistant.SHP_Assistant);
	self.setupBtnPens();
	self.addToolbarControls();
	self.dkcGridArea.parentAspect:=Control.ParentAspect_StretchBoth;
	self.dkcMain.parentAspect:=Control.ParentAspect_StretchBoth;
	self.initScrollableDrawFrame();

	self.loadDetails;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="translateForm" id="2e428f6c-edf4-4add-adc6-4f8db7bd326d">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0017626, locale);
	btnBaySeqBay.translateBubbleHelp(Xlat_0010743, locale);
	btnBaySeqBay.translateCaption(Xlat_0010744, locale);
	btnBaySeqBay40.translateBubbleHelp(Xlat_0010745, locale);
