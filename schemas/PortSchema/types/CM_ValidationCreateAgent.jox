	self.raiseExceptionIfNull(pProxyLogRegradeCode, 'LogRegradeCode Proxy');
	pProxyLogRegradeCode.raiseExceptionIfNotTransient(method);
	
	if not self.canDo(_passport, PmAdmLogRegradeCodeTableMaint,
