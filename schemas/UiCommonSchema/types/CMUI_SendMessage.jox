    <JadeMethod name="doBaseFormSave" id="1c80630c-1708-4a0f-a4e5-9b806a351cbd">
        <updating/>
        <source>doBaseFormSave() updating, protected;
/*
------------------------------------------------------------------------
Created:			26 November 2003 by cnwdwq1
Purpose:			
Parameters:		None
Returns:			Nothing
Changed On		Changed By		Reason
--------------		--------------		-----------------------------------------
---------------------------------------------------------------------------
*/

vars
	msg, userNames:	String;
	i : Integer;
	ts : TimeStamp;
	length : Integer;
begin

	self.mousePointer := MousePointer_HourGlass;
	msg := messageToSend.text;
	if msg = null then
		app.msgBox(app.getErrorString(Send_MsgEnterTxt), 'Error', MsgBox_Exclamation_Mark_Icon);
		messageToSend.setFocus;
		return;
	endif;
		
	if sendToOpt_1.value then	//Specific users
		foreach i in 1 to usersToSendTo.listCount do
			if usersToSendTo.itemSelected[i] then
				userNames := userNames &amp; '&amp;&amp;' &amp; usersToSendTo.itemText[i];
			endif;
		endforeach;
		if userNames = null then
			app.msgBox(app.getErrorString(Send_MsgSelectUser), 'Error', MsgBox_Exclamation_Mark_Icon);
			return;
		endif;
		userNames := userNames &amp; '&amp;&amp;' &amp; '%^%';	//We look for this tag in the receival event, if its there it means
										//the event is for specific users, else we display to all users
										//(as long as they are running JMTerminal)
	endif;
	ts := app.actualTimeServer();

	if  msg.length() &gt;= 48000 then//par 14196
		app.msgBox(app.getErrorString(MSG_TOO_LONG), 'Error', MsgBox_Exclamation_Mark_Icon);
		messageToSend.setFocus;
		return;
	endif;
	
	msg := userNames &amp; app.getErrorString2(Send_MessageSentBy, process.userCode, ts.String) &amp; msg;
	self.label1.caption := app.getErrorString(NewMessageSent);
	system.causeEvent(Event_SendMessage, true, msg);
	global.beep;
	messageToSend.text := null;
epilog
	self.mousePointer := MousePointer_Default;

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doRefresh" id="a8fd4cbb-f1b0-465f-99b3-dbac222bc5c0">
