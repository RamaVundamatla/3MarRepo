    <JadeMethod name="filterForActual" id="2cd866c5-17e6-4474-b8b4-1828a417215d">
        <updating/>
        <source>filterForActual(_voySummaryDict : CMIF_VoyageSummaryByValueDict input; _passport : CM_Passport) protected, updating;
// ---------------------------------------------------------------------------
// Created:     11 November 2003	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	tiDict 				: CM_TIByCargoTypeIdDict;
	ti					: CM_TrackedItem;
	iter				: Iterator;
	breakOut			: Boolean;
	querySelf			: CMQF_VoyageSummary;
	summaryObj			: CMIF_VoyageSummary;
	loadPortCode		: String;
	terminal			: CM_Terminal;
begin

	querySelf := self;
	if self.getMyVoyage = null then
		app.raiseCMException1(ERR_INVALID_VOYAGE, 'NULL', null, null);
		return;
	endif;
	tiDict := self.getMyVoyage.allOnshipTIsByCargoTypeId;
	iter := tiDict.createIterator;
	tiDict.startKeyGeq(TI_CargoType_Container, null, iter);
	//assume this is always run for a single terminal
	foreach terminal in self.allTerminals do
		self.allFilterLoadPorts.add(terminal.getConfig(PortDestCode).String.trimBlanks);
	endforeach;

	while iter.next(ti) do
		if ti.cargoType &lt;&gt; TI_CargoType_Container then
			break;
		endif;
		
		if ti.isChild then
			continue;
		endif;
		
		if not querySelf.checkStatusIncludesObject(ti, _passport, breakOut) then	
//		if not querySelf.includesObject(ti, _passport, breakOut) then
			continue;
		endif;
		
//		if breakOut then
//			return;
//		endif;
		
		summaryObj := querySelf.getSummaryObjectForOrder(_voySummaryDict, ti, null, null);
		
		if summaryObj &lt;&gt; null then
			summaryObj.totalSelf(ti.CM_Container);
		endif;
		
		if querySelf.useTotalSummaryObject then
			summaryObj := querySelf.getSummaryObjectForOrder(_voySummaryDict, ti, querySelf.TOTALS_ID, null);
			if summaryObj &lt;&gt; null then
				summaryObj.totalSelf(ti.CM_Container);
			endif;
		endif;
	endwhile;
	
	
epilog
	delete iter;	
end;</source>
        <access>protected</access>
        <Parameter name="_voySummaryDict" type="CMIF_VoyageSummaryByValueDict" usage="input"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="filterForDateRange" id="678a7847-67f0-4acc-a5e4-986851a473f6">
        <updating/>
        <source>filterForDateRange(_voySummaryDict : CMIF_VoyageSummaryByValueDict input; _passport : CM_Passport) protected, updating;
// ---------------------------------------------------------------------------
// Created:     11 November 2003	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
/*

Date		Who		Reason
11 Jan 2011	cnwkpd1	PAR #26678 - Tidy up transient leaks

*/

vars
	tiDict 				: CM_TIByCargoTypeIdDict;
	ti					: CM_TrackedItem;
	iter				: Iterator;
	breakOut			: Boolean;
	querySelf			: CMQF_VoyageSummary;
	summaryObj			: CMIF_VoyageSummary;
	loadPortCode		: String;
	voyage				: CM_Voyage;
	terminal			: CM_Terminal;
	txn					: CM_TITransaction;	
	txnDict				: CM_TITransactionByTypeDateDict;
	startDT				: TimeStamp;
begin
	querySelf := self;

	if querySelf.allTerminals.isEmpty then
		app.raiseUnexpectedProgramError(class.name, method.name, 'no terminals selected');
		return;
	endif;
//app.writeStatement('CNWJC2 ' &amp; class.name &amp; " " &amp; method.name &amp;  " " &amp; self.departDateFrom.String);
//app.writeStatement('CNWJC2 ' &amp; class.name &amp; " " &amp; method.name &amp;  " " &amp; self.departDateTo.String);

	startDT.setDate(self.departDateFrom);
	startDT.setTime(self.departTimeFrom);

	//assume this is always run for a single terminal
	foreach terminal in self.allTerminals do
//app.writeStatement('CNWJC2 ' &amp; class.name &amp; " " &amp; method.name &amp;  " " &amp; terminal.name);
		txnDict := terminal.allTITransactionsByTypeDate;
		delete iter;
		iter := txnDict.createIterator;
		txnDict.startKeyGeq(TRANS_TYPE_REC_SHIP, startDT, iter);
		
		while iter.next(txn) do
//		foreach txn in terminal.allTITransactionsByTypeDate do
			if txn.dateTime.date &gt; self.departDateTo then
				break;
			endif;
			if txn.type &lt;&gt; TRANS_TYPE_REC_SHIP then
				break;
			endif;
			ti := txn.myTrackedItem;
			if ti = null then
				continue;
			endif;
			if ti.isChild then
//			or (not CM_Container.hasInstance(ti)) then
				continue;
			endif;
//			if not querySelf.checkStatusIncludesObject(ti, _passport, breakOut) then	
//				continue;
//			endif;
			summaryObj := querySelf.getSummaryObjectForOrder(_voySummaryDict, ti, ti.voyageCode, null);
			if summaryObj &lt;&gt; null then
				summaryObj.totalSelf(ti);
			endif;
			/*
			if querySelf.useTotalSummaryObject then
				summaryObj := querySelf.getSummaryObjectForOrder(_voySummaryDict, ti, querySelf.TOTALS_ID, null);
				if summaryObj &lt;&gt; null then
					summaryObj.totalSelf(ti.CM_Container);
				endif;
			endif;
			*/
		endwhile;

		txnDict.startKeyGeq(TRANS_TYPE_REL_SHIP, startDT, iter);
		
		while iter.next(txn) do
//		foreach txn in terminal.allTITransactionsByTypeDate do
			if txn.dateTime.date &gt; self.departDateTo then
				break;
			endif;
			if txn.type &lt;&gt; TRANS_TYPE_REL_SHIP then
				break;
			endif;
			ti := txn.myTrackedItem;
			if ti = null then
				continue;
			endif;
			if ti.isChild then
				continue;
			endif;
			/*PAR 32179
			if not querySelf.checkStatusIncludesObject(ti, _passport, breakOut) then	
				continue;
			endif;
			*/
			summaryObj := querySelf.getSummaryObjectForOrder(_voySummaryDict, ti,  ti.voyageCode, null); // PAR 32179 added the voyage code, again copied from somewhere else and had bugs in it.
			if summaryObj &lt;&gt; null then
				summaryObj.totalSelf(ti);
			endif;
			/* PAR 32179
			if querySelf.useTotalSummaryObject then
				summaryObj := querySelf.getSummaryObjectForOrder(_voySummaryDict, ti, querySelf.TOTALS_ID, null);
				if summaryObj &lt;&gt; null then
					summaryObj.totalSelf(ti.CM_Container);
				endif;
			endif;
			*/
		endwhile;

	endforeach;
		

epilog
	delete iter;		// PAR #26678
	
end;</source>
        <access>protected</access>
        <Parameter name="_voySummaryDict" type="CMIF_VoyageSummaryByValueDict" usage="input"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="filterForProposed" id="6951f3eb-89ec-4eda-abd8-06413ea86ce6">
        <updating/>
        <source>filterForProposed(_voySummaryDict : CMIF_VoyageSummaryByValueDict input; _passport : CM_Passport) updating, protected;
// ---------------------------------------------------------------------------
// Created:     11 November 2003	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars

	hold				: CM_Hold;
	bay					: CM_Bay;
	slotController		: CM_SlotController;
	sotRequest			: CM_SlotRequest;
	ti					: CM_TrackedItem;
	summaryObj			: CMIF_VoyageSummary;
	futureMove			: CM_FutureMove;
	querySelf			: CMQF_VoyageSummary;
	breakOut			: Boolean;
	terminal			: CM_Terminal;
	tiArray				: CM_TIArray;
begin
	querySelf := self;
	foreach terminal in self.allTerminals do
		self.allFilterLoadPorts.add(terminal.getConfig(PortDestCode).String);
	endforeach;
	//may have only specific holds, or entire voyage - if latter then populate holds collection
	if querySelf.allHolds.isEmpty then
		if querySelf.getMyVoyage &lt;&gt; null and querySelf.getMyVoyage.myCellularVoyageStructure &lt;&gt; null then//added by cnwyl1 25052006
			querySelf.getMyVoyage.myCellularVoyageStructure.allHolds.copy(querySelf.allHolds);
		endif;
	endif;
	
	create tiArray transient;
	
	if querySelf.allHolds &lt;&gt; null then //added by cnwyl1 25052006
	
		querySelf.allHolds.removeInvalidObjects();	//18 July 2016	NDL	TFS 2329
		
		foreach hold in querySelf.allHolds do :holdLoop
			foreach bay in hold.allBays do
				if not bay.isKindOf(CM_BayVoyage) then
					continue;
				endif;
		
				foreach slotController in bay.CM_BayVoyage.allSlotControllersByOrdinal discreteLock do
					slotController.getProposedTIs(tiArray);
					foreach ti in tiArray do : tiLoop
					//	ti := futureMove.CM_FutureMovePlanned.myTrackedItem;
						if (not CM_Container.hasInstance(ti)) then
							continue;
						endif;
						
						if (not slotController.isTIBackEndForProposed(ti))
						or ti.isChild then
							continue;
						endif;
						
						if querySelf.checkStatusIncludesObject(ti, _passport, breakOut) then	
	//					if querySelf.includesObject(ti, _passport, breakOut) then
							summaryObj := querySelf.getSummaryObjectForOrder(_voySummaryDict, ti, null, null);
							if summaryObj &lt;&gt; null then
								summaryObj.totalSelf(ti.CM_Container);
							endif;
							if querySelf.useTotalSummaryObject then
								summaryObj := querySelf.getSummaryObjectForOrder(_voySummaryDict, ti, querySelf.TOTALS_ID, null);
								if summaryObj &lt;&gt; null then
									summaryObj.totalSelf(ti.CM_Container);
								endif;
							endif;
						endif;
						
	//					if breakOut then
	//						break holdLoop;
	//					endif;
					endforeach;
				endforeach;
			endforeach;
		endforeach;
	endif;//added by cnwyl1 25052006
epilog
	delete tiArray;
end;</source>
        <access>protected</access>
        <Parameter name="_voySummaryDict" type="CMIF_VoyageSummaryByValueDict" usage="input"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="filterObjects" id="9026930b-7266-4690-bc1e-d6a39523dc64">
        <updating/>
        <source>filterObjects(_collection : Collection input; _passport : CM_Passport) updating;
// ---------------------------------------------------------------------------
// Created:     01 May 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
vars
	voySummaryDict		: CMIF_VoyageSummaryByValueDict;


begin
	if not _collection.isKindOf(CMIF_VoyageSummaryByValueDict) then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Invalid collection type for query method');
		return;
	endif;

	voySummaryDict := _collection.CMIF_VoyageSummaryByValueDict;
//	self.createPreDefinedSummaryObj(voySummaryDict);
	self.initFields();


	if self.getMyVoyage = null then
		self.filterForDateRange(voySummaryDict, _passport);
	elseif self.actualProposedOption = self.MODE_OPT_PROPOSED then
		self.filterForProposed(voySummaryDict, _passport);
	else
		self.filterForActual(voySummaryDict, _passport);	 
	endif; 


end;</source>
        <Parameter name="_collection" type="Collection" usage="input"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="dd0c59fc-7fe4-427d-889a-ae4616b55b90">
        <source>getDisplayStringForAttribute(_attrName: String; _getCalculatedDate: Boolean): String;
// ---------------------------------------------------------------------------
// Created:     19/07/2010 cnwdz2	
//
// Purpose:     PAR24513 extend the current existing getDisplayStringForAttribute method to return an object's oid.	
vars
	oid : String;
begin
	return self.getOIDAndDescForAttribute(_attrName, _getCalculatedDate, oid);
/*
	if _attrName = ETRow_OrderedBy then
		return self.orderKey1;
	elseif _attrName = ETRow_OrderedBy2 then
		return self.orderKey2;
	elseif _attrName = ETRow_Mode then
		if self.modeDescr = null then // ## PAR 9502
			return self.actualProposedOption; // ## PAR 9502
		endif;
		return self.modeDescr;
	elseif _attrName = ETRow_State then
		return self.planningStateDescr;
	elseif _attrName = ETRow_Voyage then
		if self.myVoyage &lt;&gt; null then
			return self.myVoyage.code;
		else
			return Any_String;
		endif;
	endif;
	
	return inheritMethod(_attrName, _getCalculatedDate);

*/
end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_getCalculatedDate" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getExtraInfoString" id="9b4ece9d-0c62-42c2-9547-02a68f766335">
        <source>getExtraInfoString(): String;
// -------------------------------------------
// Created 01 April 2005 by cnwdvb1
// -------------------------------------------
vars

begin

	// CCMS 1327
	
	if self.getMyVoyage &lt;&gt; null then
		return self.getMyVoyage.getId();
	endif;
	return inheritMethod();


end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getKeyFromTI" id="27e63bc1-309d-456c-9ced-cb2d7f6dfe07">
        <source>getKeyFromTI(_orderKey : String; _ti : CM_TrackedItem) : String protected;
// ---------------------------------------------------------------------------
// Created:     07 November 2003	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	bayId				: String;
	slotController		: CM_SlotController;
	lc					: CM_LocationsController;
	consignCode			: String;

begin

	if _orderKey = null then
		return null;
	endif;
	
	if _orderKey = self.ORDERED_BY_BAY then
		if self.actualProposedOption = self.MODE_OPT_ACTUAL then
			lc := _ti.getPrimaryLocation(REAL_MODE);
		elseif self.actualProposedOption = self.MODE_OPT_PROPOSED then
			lc := _ti.getPrimaryLocation(PLANNING_MODE);
		endif;
		
		if (not CM_SlotController.hasInstance(lc)) then
			return 'No Bay defined';
		endif;
		
		return lc.CM_SlotController.myBayVoyage.id;
	elseif _orderKey = self.ORDERED_BY_CONSIGNEE then
		if _ti.consignee.trimBlanks = null then
			return 'No Consignee';
		else
			return _ti.consignee.trimBlanks;
		endif;
	elseif _orderKey = self.ORDERED_BY_OPERATOR then
		if _ti.operatorCode.trimBlanks = null then
			return 'No Operator';
		else
			return _ti.operatorCode.trimBlanks;		
		endif;
	elseif _orderKey = self.ORDERED_BY_LOADPORT then
		if _ti.loadPort.trimBlanks = null then
			return 'No Load Port';
		else
			return _ti.loadPort.trimBlanks;		
		endif;

	elseif _orderKey = self.ORDERED_BY_DISCHARGEPORT then
		if _ti.dischargePort.trimBlanks = null then
			return 'No Discharge Port';
		else
			return _ti.dischargePort.trimBlanks;		
		endif;
	endif;

end;</source>
        <access>protected</access>
        <Parameter name="_orderKey" type="String"/>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getKeyFromTxn" id="ceaebc72-8871-4126-9f3c-4647c04ac7a0">
        <source>getKeyFromTxn(_orderKey : String; _txn : CM_TITransaction) : String protected;
// ---------------------------------------------------------------------------
// Created:     07 November 2003	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	bayId				: String;
	slotController		: CM_SlotController;
	lc					: CM_LocationsController;
	consignCode			: String;
	ti					: CM_TrackedItem;
begin
	if _orderKey = null then
		return null;
	endif;
	
	if _orderKey = self.ORDERED_BY_BAY then
		ti := _txn.myTrackedItem;
		if ti &lt;&gt; null then
			if self.actualProposedOption = self.MODE_OPT_ACTUAL then
				lc := ti.getPrimaryLocation(REAL_MODE);
			elseif self.actualProposedOption = self.MODE_OPT_PROPOSED then
				lc := ti.getPrimaryLocation(PLANNING_MODE);
			endif;
		endif;
		
		if (not CM_SlotController.hasInstance(lc)) then
			return 'No Bay defined';
		endif;
		
		return lc.CM_SlotController.myBayVoyage.id;
	elseif _orderKey = self.ORDERED_BY_CONSIGNEE then
		if _txn.consignee.trimBlanks = null then
			return 'No Consignee';
		else
			return _txn.consignee.trimBlanks;
		endif;
	elseif _orderKey = self.ORDERED_BY_OPERATOR then
		if _txn.operatorCode.trimBlanks = null then
			return 'No Operator';
		else
			return _txn.operatorCode.trimBlanks;		
		endif;
	elseif _orderKey = self.ORDERED_BY_LOADPORT then
		if _txn.loadPort.trimBlanks = null then
			return 'No Load Port';
		else
			return _txn.loadPort.trimBlanks;		
		endif;

	elseif _orderKey = self.ORDERED_BY_DISCHARGEPORT then
		if _txn.dischargePort.trimBlanks = null then
			return 'No Discharge Port';
		else
			return _txn.dischargePort.trimBlanks;		
		endif;
	endif;

end;</source>
        <access>protected</access>
        <Parameter name="_orderKey" type="String"/>
        <Parameter name="_txn" type="CM_TITransaction"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getMyShippingLine" id="c7bb18d8-7420-4427-a694-bf91d0722078">
        <source>getMyShippingLine() : CM_ShippingLine;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 11/05/2023	navdap1		Initial creation TFS 
//
vars
	object : CM_ShippingLine;
	edition : Integer;
	invalidObj : Boolean;
begin

	object := self.myShippingLine;

	if object = null then
		return null;
	endif;
	
	on Exception do app.handleDeletedObject( exception, object, invalidObj );
	edition := object.edition;
	
	if invalidObj then
		return null;
	endif;
	
	return object;
epilog

end;</source>
        <ReturnType type="CM_ShippingLine"/>
    </JadeMethod>
    <JadeMethod name="getMyVoyage" id="071c9e6b-c7c4-4386-8e7a-5dcfea708ec8">
        <source>getMyVoyage():CM_Voyage;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 July 2016	cnwndl1	Initial creation	TFS 2329

*/

vars

	voyage : CM_Voyage;
	edition : Integer;
	invalidObj : Boolean;

begin

	voyage := self.myVoyage;

	if voyage = null then
		return null;
	endif;
	
	on Exception do app.handleDeletedObject( exception, voyage, invalidObj );
	edition := voyage.edition;
	
	if invalidObj then
		return null;
	endif;
	
	return voyage;

epilog

end;</source>
        <ReturnType type="CM_Voyage"/>
    </JadeMethod>
    <JadeMethod name="getOIDAndDescForAttribute" id="7e23aa83-ee43-4cc4-b0bd-2219691a4441">
        <source>getOIDAndDescForAttribute(_attrName: String; _getCalculatedDate: Boolean; _oid : String output): String;
// ---------------------------------------------------------------------------
// Created:     19/07/2010 cnwdz2	
//
// Purpose:     PAR24513 extend the current existing getDisplayStringForAttribute method to return an object's oid.	
vars

begin
	if _attrName = ETRow_OrderedBy then
		return self.orderKey1;
	elseif _attrName = ETRow_OrderedBy2 then
		return self.orderKey2;
	elseif _attrName = ETRow_Mode then
		if self.modeDescr = null then // ## PAR 9502
			return self.actualProposedOption; // ## PAR 9502
		endif;
		return self.modeDescr;
	elseif _attrName = ETRow_State then
		return self.planningStateDescr;
	elseif _attrName = ETRow_Voyage then
		if self.getMyVoyage &lt;&gt; null then
			_oid := self.getMyVoyage.getOidAsString(); //20/07/2010 cnwdz2 24513
			return self.getMyVoyage.code;
		else
			return Any_String;
		endif;
	endif;
	
	return inheritMethod(_attrName, _getCalculatedDate, _oid);


end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_getCalculatedDate" type="Boolean"/>
        <Parameter name="_oid" type="String" usage="output"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getSummaryObjectForOrder" id="9b84722e-b578-4492-9128-22f892ec93b2">
        <source>getSummaryObjectForOrder(_voySummaryDict : CMIF_VoyageSummaryByValueDict input; 
					_ti : CM_TrackedItem;
					_predefinedKey1,
					_predefinedKey2 : String) : CMIF_VoyageSummary;
// ---------------------------------------------------------------------------
// Created:     01 May 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
vars
	summaryObj			: CMIF_VoyageSummary;
	key1,
	key2				: String;
		
begin
	if _predefinedKey1 &lt;&gt; null then
		key1 := _predefinedKey1;
	else
		key1 := self.getKeyFromTI(self.orderKey1, _ti);
	endif;
	
	if _predefinedKey2 &lt;&gt; null then
		key2 := _predefinedKey2;
	else
		key2 := self.getKeyFromTI(self.orderKey2, _ti);
	endif;
	
	summaryObj := _voySummaryDict[key1, key2];
		
	if summaryObj = null then
		create summaryObj transient;
		summaryObj.keyValue1 := key1;
		summaryObj.keyValue2 := key2;
		_voySummaryDict.add(summaryObj);
	endif;

	return summaryObj;

end;</source>
        <Parameter name="_voySummaryDict" type="CMIF_VoyageSummaryByValueDict" usage="input"/>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_predefinedKey1" type="String"/>
        <Parameter name="_predefinedKey2" type="String"/>
        <ReturnType type="CMIF_VoyageSummary"/>
    </JadeMethod>
    <JadeMethod name="includesObject" id="27d9fcc7-8659-4ceb-a290-f282ce36e48e">
        <updating/>
        <source>includesObject(_obj : CM_Object; _passport : CM_Passport; _breakOut : Boolean output): Boolean updating, protected;
// ---------------------------------------------------------------------------
// Created:     01 May 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
vars
	querySelf			: CMQF_VoyageSummary;
	ti					: CM_TrackedItem;
	failedDAC  :CM_DataAccessController;
	
begin
	if (not CM_TrackedItem.hasInstance(_obj)) then
		return false;
	endif;
	
	ti := _obj.CM_TrackedItem;
	
	querySelf := self;
	querySelf.numSearched := querySelf.numSearched + 1;
	
	if (self.myOperator &lt;&gt; null and ti.myOperator &lt;&gt; self.myOperator)
	or (self.getMySubTerminal &lt;&gt; null and ti.mySubTerminal &lt;&gt; self.getMySubTerminal) //29/04/2009 cnwdz2 ccms1735
	or (self.doFilterLoadPorts and (not self.allFilterLoadPorts.includes(ti.loadPort.trimBlanks)))
	then
		return false;
	endif;
	
	if not ti.canUserAccessSelf(null, failedDAC, _passport) then
		return false;
	endif;
	
	querySelf.numFound := querySelf.numFound + 1;
	return true;
end;</source>
        <access>protected</access>
        <Parameter name="_obj" type="CM_Object"/>
        <Parameter name="_passport" type="CM_Passport"/>
        <Parameter name="_breakOut" type="Boolean" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="initFields" id="d68d2448-37b2-476f-a3fe-eec3f2990eec">
        <updating/>
        <source>initFields() updating;
// ---------------------------------------------------------------------------
// Created:     06 May 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
vars

begin
	if self.actualProposedOption = self.MODE_OPT_PROPOSED then
		self.modeDescr := 'Proposed';
	else
		self.modeDescr := 'Actual';
	endif;
	
	if self.loadDischargeOption  = self.MODE_OPT_DISCHARGE then
		self.modeDescr := 'Discharge';	
	elseif self.loadDischargeOption = self.MODE_OPT_LOAD then
		self.modeDescr := 'Load';
	endif;
	
	self.doFilterLoadPorts := true;
	self.useTotalSummaryObject := true;
end;</source>
    </JadeMethod>
    <JadeMethod name="reset" id="010ea751-f0e6-4271-a957-c6188a05450e">
