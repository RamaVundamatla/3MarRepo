	   self.myReceivalBOL.myExtension &lt;&gt; null then
		logGrade := self.myReceivalBOL.myExtension.myLogGrade;
	endif;
	if logGrade &lt;&gt; null then
		return (self.sedMin &lt; logGrade.minSED or self.sedMax &gt; logGrade.maxSED);
	else
		return false;
	endif;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
