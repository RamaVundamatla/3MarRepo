    <JadeMethod name="setControlsForAddEdit" id="63c885df-b631-4a54-873a-65baabc56566">
        <updating/>
        <source>setControlsForAddEdit() updating;

vars
	maxCodeLength: Integer;
	row: Integer;
	column: Integer;
begin
	inheritMethod();
	maxCodeLength := self.myObject.CM_SourceLocation.myCodeGroup.myCodeGroupType.codeLengthMax;
	row := self.myForm.tblInput1.getRowByName(ETRow_Code);
	if row &gt; 0 then
		column := CM_EntryTable.ColumnValue;
		self.myForm.tblInput1.accessCell(row, column).maxLength := maxCodeLength;
	endif;
end;</source>
    </JadeMethod>
