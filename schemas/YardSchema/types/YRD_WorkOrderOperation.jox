    <JadeMethod name="buildCmbCommodity" id="d42a8cf0-6780-4b57-8beb-02a5ce77d434">
        <source>buildCmbCommodity();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 Oct 2023 navhl20 ChangeRequest 60033: EUP | Ship Operations in DD - [54176.010] - [Receive] Ship Job List 

*/

vars
	iter		 	: Iterator;
	commodity		: CM_Commodity;
begin
	iter := app.myRoot.allCommodities.createIterator;
	
	self.cmbCommodity.clear;
	
	self.cmbCommodity.addItemObject("", null);

	while iter.next(commodity) do
		self.cmbCommodity.addItemObject(commodity.code &amp; Tab &amp; commodity.description, commodity);
	endwhile; 
epilog
	delete iter;
end;</source>
    </JadeMethod>
    <JadeMethod name="buildCmbFirstWarehouse" id="4c522e11-0992-46ef-b34b-cad6f879a947">
        <source>buildCmbFirstWarehouse();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 Jun 2023	navhl20	ChangeRequest 58543: EUP - Delivery Dispatch – Allocation List - VAS

*/

vars
	tArea 	: CM_TerminalArea;
	iter	: Iterator;
	cmb		: CMUI_ComboBox;
begin
	iter := self.myTerminal.allTerminalAreas.createIterator;
	cmb := self.cmbFirstWarehouse;
	cmb.clear;
	
	cmb.addItemObject("", null);

	while iter.next(tArea) do
		if tArea.isKindOf(CM_GateArea) or tArea.isKindOf(CM_SwapStack) then
			continue;
		endif;
		cmb.addItemObject(tArea.id, tArea);
	endwhile; 
epilog
	delete iter;
end;</source>
    </JadeMethod>
