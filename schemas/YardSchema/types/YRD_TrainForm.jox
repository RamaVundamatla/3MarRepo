    <JadeMethod name="setTblDataXML" id="752568f1-4e23-4743-bb2f-509b9cc9ff5a">
        <source>setTblDataXML(): String protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
01 July 2009	cnwmd1	Initial creation

*/

vars
	str : String;
	tagStr,typeTag	: String;
	inwardXML, outwardXML : String;
begin
	tagStr := self.tblWagons.XMLTag_Table &amp; self.tblWagons.name;

	str := self.tblWagons.getXmlStrForColumns(true);

	if xmlStrTblDataArray.size &gt;= 1 then
		inwardXML := global.formatAsXMLPrefix(ETView_TrainInward) &amp; self.xmlStrTblDataArray[1]&amp; global.formatAsXMLSuffix(ETView_TrainInward);
	endif;
	if xmlStrTblDataArray.size &gt;= 2 then
		outwardXML := global.formatAsXMLPrefix(ETView_TrainOutward) &amp; self.xmlStrTblDataArray[2]&amp; global.formatAsXMLSuffix(ETView_TrainOutward);
	endif;

	typeTag := self.getTypeMode();
	if typeTag = ETView_TrainOutward then //Over-ride the current option
		outwardXML := global.formatAsXMLPrefix(ETView_TrainOutward) &amp; str &amp; global.formatAsXMLSuffix(ETView_TrainOutward);
	elseif typeTag = ETView_TrainInward then
		inwardXML := global.formatAsXMLPrefix(ETView_TrainInward) &amp; str &amp; global.formatAsXMLSuffix(ETView_TrainInward);
	endif;

	str := inwardXML &amp; outwardXML;

	return str;
end;</source>
        <access>protected</access>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="setTrainPxy" id="30f47e1f-6118-4459-bfa5-3fadc96b0143">
        <source>setTrainPxy(_pxyTrain : CM_Train input) protected;
/*
----------   ----------  --------------------------------------------------
Created:	07 November 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
02 Oct 2020  cnwma1 	 ChangeRequest 50112: ASPA - GCI Stevedores	
----------   ----------  --------------------------------------------------
*/
vars
	departureDT,
	arrivalDT,
	portArrivalDT,
	shunterInDT,
	shunterOutDT,
	schArrivalDT,
	schDepartureDT,
	cargoExchStartDT,
	cargoExchEndDT: TimeStamp;
	height : Decimal [14,4];
	weight : Decimal [14,4];
	width : Decimal [14,4];
	trainStatus	: Integer; //navsp1 17MAY2022 TFS#53619
begin

	arrivalDT.setDate(self.txtArrivalDate.text.asDateJMT());
	arrivalDT.setTime(self.txtArrivalTime.text.asTimeJMT());
	departureDT.setDate(self.txtDepartureDate.text.asDateJMT());
	departureDT.setTime(self.txtDepartureTime.text.asTimeJMT());
	
	//cnwrd1 par 19710 20.5.09 -  ccms 1067
	portArrivalDT.setDate(self.txtPortArrivalDt.text.asDate());
	portArrivalDT.setTime(self.txtPortArrivalTm.text.asTimeJMT());
	shunterInDT.setDate(self.txtShunterInDt.text.asDateJMT());
	shunterInDT.setTime(self.txtShunterInTm.text.asTimeJMT());
	shunterOutDT.setDate(self.txtShunterOutDt.text.asDateJMT());
	shunterOutDT.setTime(self.txtShunterOutTm.text.asTimeJMT());
	
	//+ 26/05/2009, cnwmd1, CCMS 1067, Par 19710
	schArrivalDT.setDate(self.txtSchArrivalDt.text.asDateJMT());
	schArrivalDT.setTime(self.txtSchArrivalTm.text.asTimeJMT());
	schDepartureDT.setDate(self.txtSchDepartDt.text.asDateJMT());
	schDepartureDT.setTime(self.txtSchDepartTm.text.asTimeJMT());
	cargoExchStartDT.setDate(self.txtCargoXStartDt.text.asDateJMT());
	cargoExchStartDT.setTime(self.txtCargoXStartTm.text.asTimeJMT());
	cargoExchEndDT.setDate(self.txtCargoXEndDt.text.asDate());
	cargoExchEndDT.setTime(self.txtCargoXEndTm.text.asTimeJMT());
	
	// 09 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	arrivalDT		:= self.localToSystemTime(arrivalDT);	
	departureDT		:= self.localToSystemTime(departureDT);		
	portArrivalDT	:= self.localToSystemTime(portArrivalDT);	
	shunterInDT		:= self.localToSystemTime(shunterInDT);	
	shunterOutDT	:= self.localToSystemTime(shunterOutDT);
	schArrivalDT	:= self.localToSystemTime(schArrivalDT);
	schDepartureDT	:= self.localToSystemTime(schDepartureDT);
	cargoExchStartDT:= self.localToSystemTime(cargoExchStartDT);
	cargoExchEndDT	:= self.localToSystemTime(cargoExchEndDT);


	
	
	height := self.tblHeight.getConvertedValue;
	width := self.tblWidth.getConvertedValue;
	weight := self.tblWeight.getConvertedValue;
	if self.cmbStatus.listIndex &gt; 0 then									//navsp1 20MAY2022 TFS#53619
		trainStatus	:=  self.cmbStatus.itemData[self.cmbStatus.listIndex]; 	//navsp1 16MAY2022 TFS#53619
	endif;
	_pxyTrain.setProxy(self.txtCode.text.toUpper.trimBlanks(),
						self.txtDescription.text.trimBlanks(),
						arrivalDT,
						departureDT,
						self.cmbOriginPort.listObject.CM_Port,
						self.cmbDestPort.listObject.CM_Port,						
						self.myTerminal,
						self.clColour.getColor(),
						trainStatus,			  //navsp1 16MAY2022 TFS#53619,
						height,	//self.txtMaxHeight.text.asDecimalJMT(),
						width,	//self.txtMaxWidth.text.asDecimalJMT(),
						weight.Integer,	//self.txtMaxWeight.text.Integer,
						self.txtScheduleCode.text,
						portArrivalDT,
						shunterInDT,
						shunterOutDT,
						self.cmbCarrier.listObject.CM_Carrier,
						schArrivalDT,
						schDepartureDT,
						cargoExchStartDT,
						cargoExchEndDT,
						self.txtRemaks.text,
						self.cmbGaugeClear.listObject.CM_TrackClearance, //_myTrackClearance : CM_TrackClearance	//26 Jun 2009	NDL	CCMS 1067
						self.chkNoEmptyWagons.value,
						self.cmbRecStevedore.listObject.CM_Stevedore,   //02.10.2020 cnwma1 TFS #50112
						self.cmbRelStevedore.listObject.CM_Stevedore);  //02.10.2020 cnwma1 TFS #50112
end;</source>
        <access>protected</access>
        <Parameter name="_pxyTrain" type="CM_Train" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setupForm" id="2d8ed255-2082-4972-9711-04a11924f35f">
        <updating/>
        <source>setupForm() updating;
/*
----------   ----------  --------------------------------------------------
Created:	07 November 2006 By cnwth2

Purpose:	

Changed On	Changed By	Reason
	
----------	---------- 	--------------------------------------------------
03 Jun 2009	concms1		par 19013 - 
12/12/2017	jlgns1 		TFS 8179 ChangeRequest 8179: Copy Train button causes a 75768 error
18 Aug 2022 navhl20 	ChangeRequest 54281: EUP - Wagon Track Planning
24 Aug 2022 navsj20		ChangeRequest 54281: EUP - Wagon Track Planning

*/
vars
	initMode : Integer;
	extra : String;
begin

	self.displayMeasurementFields();

	initMode := self.mode;
	self.initialLoadMode := self.mode;
	
	self.beginClassNotification(CM_Train, false, Any_System_Event, Response_Continuous, null);
// PAR 21740	self.beginClassNotification(CM_Wagon, false, Any_System_Event, Response_Continuous, null);
	self.beginClassNotification(CM_WagonClass, false, Any_System_Event, Response_Continuous, null);	// 23 Jul 2009	NDL	CCMS 1067
	self.beginClassNotification(CM_TrackClearance, false, Any_System_Event, Response_Continuous, null);	// 23 Jul 2009	NDL	CCMS 1067
	self.beginClassNotification(CM_Wagon, false, self.myTerminal.getTerminalEvent(Wagon_Update_Event), Response_Continuous, null);
	self.beginClassNotification(CM_Wagon, false, self.myTerminal.getTerminalEvent(Wagon_Create_Event), Response_Continuous, null);
	self.beginClassNotification(CM_Wagon, false, self.myTerminal.getTerminalEvent(Wagon_Delete_Event), Response_Continuous, null);
	
	self.cmbOriginPort.myAssistant 	:= self.myAssistant;
	self.cmbOriginPort.isRail		:= true; 	// par 19013
	self.cmbOriginPort.showAllDestinations := true; // otherwise we don't see the ones that are only marked as 'Is rail' and not 'Is port'
	self.cmbDestPort.myAssistant 	:= self.myAssistant;
	self.cmbDestPort.isRail			:= true;	// par 19013
	self.cmbDestPort.showAllDestinations := true;
	self.myAssistant.comboBoxTrackClearance(cmbGaugeClear, null);	//26 Jun 2009 NDL CCMS 1067
	self.optInwards.value 			:= true; //+ cnwmd1, CCMS 1067, Par 19913 - Default value
	
	self.doBuildComboTrainStatus();//navsp1 17MAY2022 TFS#53619
	
	self.addToolbarControls();
	self.initTblWagon();
	self.initTblTrans();
	self.initStatsTables();
	if self.mySelectedTrain &lt;&gt; null and self.mySelectedTrain.isDeparted then
		self.chkIncDeparted.value := true;
	endif;

	self.frmPrnQuery.visible := false;		//+ cnwmd1, CCMS 1067, Par 19710
	
	inheritMethod();
	
	if self.mySelectedTrain &lt;&gt; null and self.mySelectedTrain.hasAdvancedOptionsBeenSet(self.getSystemColor(Window.Color_3DFace)) then	//+ cnwmd1, CCMS 1067, Par 19710
		self.chkAdvanced.value := true;
	else
		self.chkAdvanced.value := false; 	//+ cnwmd1, CCMS 1067, Par 19710
	endif;
	
	self.resize;
	
	self.setControlsForView();
	//self.showTrainInfo((initMode = self.Mode_Copy));		//+ cnwmd1, CCMS 1067, Par 19710
	self.showTrainInfo((initMode = self.Mode_Copy or initMode = self.Mode_Add),initMode);//TFS 8179
	self.setControlsForView();
	if initMode = self.Mode_Copy then
		extra := app.getErrorString(Copy);
	endif;
	self.setMyCaption();
	self.buildComboAreas();

	if initMode &lt;&gt; self.Mode_View then
		//self.mode := initMode;
		self.setMode( initMode );	//18 Apr 2012	NDL	Par 27704
		if initMode = self.Mode_Copy then
			//self.mode := self.Mode_Add;
			self.setMode( self.Mode_Add );	//18 Apr 2012	NDL	Par 27704
		endif;
		if self.mode = self.Mode_Add then
			self.mySelectedTrain := null;
			self.cmbTrain.listObject := null;
		endif;

		if (initMode = self.Mode_Update and self.mySelectedTrain &lt;&gt; null) or ((initMode = self.Mode_Add or initMode = self.Mode_Copy) and self.mySelectedTrain = null) then
			self.setControlsForAddEdit();
		endif;
	endif;
	
	if self.mySelectedTrain &lt;&gt; null then
		self.doEnableForTrain(not self.mySelectedTrain.isNullTrain(), self.mySelectedTrain);
	endif;
	
	self.tblWarnings.ignoreSkin := true;	//01 Apr 2015	NDL	TFS 1769 - Jade bug with table backColor and skins...

	// TFS 2198 CNWAB1
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		self.btnNewTrain.enabled:= false;
		self.btnEditTrain.enabled:= false;
		self.btnSaveBase.enabled:= false;
		self.btnSaveNext.enabled:= false;
		self.btnCopyTrain.enabled:= false;
		self.btnDeleteTrain.enabled:= false;
		self.btnConfirmTrainO.enabled:= false;
		self.btnConfirmTrainI.enabled:= false;
		self.btnConfirmOut.enabled:= false;
		self.btnConfirmIn.enabled:= false;
		self.btnDeparture.enabled:= false;
		self.btnOutOrder.enabled:= false;
		self.btnMoveToRail.enabled:= false;
		
		self.btnNewWagon.enabled:= false;
		self.btnMoveWagon.enabled 		:= false;		//18.8.2022 navhl20 TFS 54281
		self.btnWagonUnplan.enabled		:= false;		//18.8.2022 navhl20 TFS 54281
		self.btnDeleteWagon.enabled:= false;
		self.btnCCWagon.enabled:= false;

		self.btnWagonDown.enabled:= false;
		self.btnWagonUp.enabled:= false;
		self.btnIntransitNO.enabled:= false;
		self.btnIntransit.enabled:= false;
		self.btnRailAllocRem.enabled:= false;
		
	endif;
end;


</source>
    </JadeMethod>
    <JadeMethod name="setupMoveModeCtrl" id="8b19eb9e-03c4-4cd6-a165-c4179e6a12de">
        <updating/>
        <source>setupMoveModeCtrl() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23/08/2022 navsj20	ChangeRequest 54281: EUP - Wagon Track Planning


*/

vars

	index : Integer;
	cntrl : Control;
	staLineMoveMode : CMUI_GridAreaStatusLine;
	top : Real;

begin
	foreach index in 1 to controlCount do
		cntrl := controls(index);
		if cntrl.isKindOf(CMUI_GridAreaStatusLine) then
			staLineMoveMode :=  cntrl.CMUI_GridAreaStatusLine;
			break;
		endif;
	endforeach;
	
	if staLineMoveMode = null then

		create staLineMoveMode transient;

		self.addControl(staLineMoveMode);
		staLineMoveMode.name := "frmStaMoveMode";
		
		staLineMoveMode.doBuildMenuMove();
		staLineMoveMode.sendMsg("createGraphics");
		
		staLineMoveMode.transparent := true;
		staLineMoveMode.myFrameMoveMode.transparent := false;
		staLineMoveMode.myFrameDisplayMode.transparent := true;
		staLineMoveMode.myFrameCaption.transparent := true;
		
		staLineMoveMode.alignContainer := 0;
		staLineMoveMode.myFrameMoveMode.alignContainer := 0;
		staLineMoveMode.myFrameDisplayMode.alignContainer := 0;
		staLineMoveMode.myFrameCaption.alignContainer := 0;
		
		staLineMoveMode.bevelInnerWidth := 0;
		staLineMoveMode.myFrameMoveMode.bevelInnerWidth := 0;
		staLineMoveMode.myFrameDisplayMode.bevelInnerWidth := 0;
		staLineMoveMode.myFrameCaption.bevelInnerWidth := 0;
		
		staLineMoveMode.bevelOuterWidth := 0;
		staLineMoveMode.myFrameMoveMode.bevelOuterWidth := 0;
		staLineMoveMode.myFrameDisplayMode.bevelOuterWidth := 0;
		staLineMoveMode.myFrameCaption.bevelOuterWidth := 0;
		
		staLineMoveMode.boundaryWidth := 0;
		staLineMoveMode.myFrameMoveMode.boundaryWidth := 0;
		staLineMoveMode.myFrameDisplayMode.boundaryWidth := 0;
		staLineMoveMode.myFrameCaption.boundaryWidth := 0;
				
		staLineMoveMode.myFrameMoveMode.enabled := true;
		staLineMoveMode.myFrameDisplayMode.enabled := false;
		staLineMoveMode.myFrameCaption.enabled := false;
		
		staLineMoveMode.myFrameMoveMode.visible := true;		
		staLineMoveMode.myFrameDisplayMode.visible := false;
		staLineMoveMode.myFrameCaption.visible := false;
		
		staLineMoveMode.myFrameMoveMode.height := 13;
		staLineMoveMode.myFrameDisplayMode.height := 10;
		staLineMoveMode.myFrameCaption.height := 10;
		staLineMoveMode.height := 13;
		
		staLineMoveMode.parent := self.frmStatus;
		
		staLineMoveMode.myFrameMoveMode.top := 0;
		staLineMoveMode.myFrameMoveMode.left := staLineMoveMode.myFrameMoveMode.left - 15;		
	
	else
		staLineMoveMode.width := frmStatus.width;
		staLineMoveMode.myFrameMoveMode.left := staLineMoveMode.width - 110;
			
	endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="showCargo" id="abd33075-f3ad-4516-a18c-e99fcc0f0222">
        <source>showCargo(_inward : Boolean);
// ---------------------------------------------------------------------------
// Created:     21 May 2009 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	wagon : CM_Wagon;
	obj : Object;
	objArray : CM_TIArray;
	train : CM_Train;
begin


	create objArray transient;
	
	train := self.mySelectedTrain;
	if train = null then
		return;
	endif;
	train.getAllTrackedItems(_inward,objArray);
	
	if objArray.isEmpty() then
		app.msgBox(app.getErrorString(No_Cargo_For_Train), app.getErrorString(Cargo_summary), MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
	else
		self.myAssistant.showCargoEnquiryForTIs(objArray[1].CM_TrackedItem, objArray, self.myMasterMenuAction, false);
	endif;

epilog
	delete objArray;
end;</source>
        <Parameter name="_inward" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="showColumnOrganiser" id="1911014a-bb2e-4ae0-8760-634a32bdf1c8">
        <updating/>
        <source>showColumnOrganiser(_dataTable : CM_DataTable input)updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
08 June 2009	cnwmd1	Initial creation

*/

vars
	defBefore, defAfter, typeTag : String;
begin

	if _dataTable = null then
		return;
	endif;
	
	defBefore := _dataTable.getXmlStrForColumns(true);
	_dataTable.showColumnOrganiserFrm(self.myTerminal, null);
	defAfter := _dataTable.getXmlStrForColumns(true);

	if defBefore &lt;&gt; defAfter then //Update the array if columns have changed via the column organiser.  The array is saved when form is closed
		if _dataTable = tblTrans then
			self.xmlStrTblTrans := defAfter;
			return;
		endif;
		typeTag := self.getTypeMode();
		if typeTag = ETView_TrainOutward then //Over-ride the current option
			self.xmlStrTblDataArray[2] := defAfter;
		elseif typeTag = ETView_TrainInward then
			self.xmlStrTblDataArray[1] := defAfter;
		endif;
	endif;
	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_dataTable" type="CM_DataTable" usage="input"/>
    </JadeMethod>
    <JadeMethod name="showConfirmFrame" id="8f8c750f-4f5a-4c5b-a594-648f50effc78">
        <updating/>
        <source>showConfirmFrame() updating;
// ---------------------------------------------------------------------------
// Created:     08 June 2009 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	theColumn : Integer;
begin
	//epr TFS 2462 1/8/16
	if self.mySelectedTrain = null then	
		app.msgBox(app.getErrorString(Please_select_train_confirm),app.getErrorString(Train_confirmation), MsgBox_Exclamation_Mark_Icon);
		return;
	endif;

	if not self.optDirInTB.value then	// 15/01/2010 cnwar2 #22129
		self.optDirInTB.value := true;
		self.optDirInTB.change(self.optDirInTB);
	endif;
	self.doEnableForConfirm(false);
	self.cmbPosition.clear;
	if self.cmbAreas.listObject &lt;&gt; null then
		self.buildComboPosition(self.cmbAreas.listObject.CM_Rail);
	endif;

	self.frmConfirmIN.zOrder(1);
	self.frmConfirmIN.visible := true;
	self.frmConfirmIN.centreHorizontallyInParent();
	self.frmConfirmIN.top := 100;
	self.txtWagonRange1.text := null;
	self.txtWagonRange2.text := null;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="showDamage" id="41488788-45ee-403e-a59b-891314340115">
        <source>showDamage();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
16 November 2009	cnwas3	Initial creation PAR21447 CCMS SFW 1067

*/
vars
	wagon : CM_Wagon;
	obj : Object;
begin
	obj := self.tblWagons.allSelectedObjects.first;
	wagon := obj.CM_Wagon;
	
	if wagon &lt;&gt; null then
		self.myAssistant.showDamageEntryForm(self, CMUI_DamageCodesAdvanceForm.Mode_Update, self.myTerminal, null, wagon, null, self.myMasterMenuAction, false);
	endif;

epilog

end;
</source>
    </JadeMethod>
    <JadeMethod name="showDepartureForm" id="dd0264db-3011-4bfa-9ffc-50e43bf6fe48">
        <updating/>
        <source>showDepartureForm() updating;
// ---------------------------------------------------------------------------
// Created:     August 2009 ANDREW BISHOP
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin
	if self.mySelectedTrain = null then
		return;
	endif;
	//self.mode := self.Mode_Departure;
	self.setMode( self.Mode_Departure );	//18 Apr 2012	NDL	Par 27704
	app.mousePointer := MousePointer_HourGlass;
	if not self.myAssistant.YRD_Assistant.showTrainDepartureForm(null, self.mySelectedTrain, self,  self.myMasterMenuAction, self.myTerminal) then
		//self.mode := self.Mode_View;
		self.setMode( self.Mode_View );	//18 Apr 2012	NDL	Par 27704
	endif;
	
epilog
	app.mousePointer := MousePointer_Default;
end;</source>
    </JadeMethod>
    <JadeMethod name="showExportFrame" id="ccd34ad1-ab9e-4215-b81c-de7bbca8bd2f">
        <updating/>
        <source>showExportFrame() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
28 August 2009	cnwndl1	Initial creation	CCMS 1094

*/

vars

begin

	self.frmExport.zOrder(1);
	self.frmExport.visible := true;
	self.frmExport.centreHorizontallyInParent();
	self.frmExport.top := 100;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="showTrainArriveFrame" id="60fc2f94-ef54-4b7f-b518-d8f234b0a8fe">
        <source>showTrainArriveFrame();
// ---------------------------------------------------------------------------
// Created:     31 July 2009 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	now : TimeStamp;
	form : YRD_TrainArrivalForm;
begin

	if self.mySelectedTrain = null then	
		app.msgBox(app.getErrorString(Please_select_train),app.getErrorString(Train), MsgBox_Exclamation_Mark_Icon);
		return;
	endif;

	form := app.getForm(YRD_TrainArrivalForm.name).YRD_TrainArrivalForm;
	
	if form = null then
		form := app.loadForm(YRD_TrainArrivalForm, CMUI_Assistant, false, false, false, self.myTerminal, null).YRD_TrainArrivalForm;
	endif;
	
	form.setParentForm(self);
	form.myCurrentTrain := self.mySelectedTrain;
	form.showModal();
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="showTrainInfo" id="66db9ff4-17e6-4801-86a0-3fbd8337a2d7">
        <updating/>
        <source>showTrainInfo(_isForNew : Boolean ; _mode : Integer) protected , updating;
/*
----------   ----------  --------------------------------------------------
Created:	07 November 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
----------   ----------  --------------------------------------------------
26/05/2009	cnwmd1		Place null into new date/time fields, instead of app.actualTimeServer.date/time.  Otherwise these default values get saved (even when the advanced panel has not been displayed).
12/12/2017  jlgns1		TFS 8179 ChangeRequest 8179: Copy Train button causes a 75768 error If we are copying a train then none of the timestamp fields of the old train are relevant so set them to null
19/04/2018	jlgrh7 		TFS #38133 POL - [Fwd: ##RE-7616## : Save next Train removes dates]
02 Oct 2020 cnwma1 		ChangeRequest 50112: ASPA - GCI Stevedores
18 Aug 2022 navhl20		ChangeRequest 54281: EUP - Wagon Track Planning
*/
vars
	train			: CM_Train;
	wagon			: CM_Wagon;
	foundIdx		: Integer;
	defCarrier		: CM_Carrier;
	carrierCode		: String;
	feetInches		: String;
	departureDT,
	arrivalDT,
	portArrivalDT,
	shunterInDT,
	shunterOutDT,
	schArrivalDT,
	schDepartureDT,
	cargoExchStartDT,
	cargoExchEndDT	: TimeStamp;
	timeNull 		: Time;
begin
	train := self.mySelectedTrain;
	
	if self.isWarningsVisible then		// 18 Feb 2010 - RJS - PAR 21951
		if _isForNew then
			self.hideTableWarnings();
		else
			self.getWarnings(train);	//17 July 2009	NDL	CCMS 1067
		endif;
	endif;
	
	if train = null then
		self.frmStatus.caption := null;
		self.doEnableForTrain(true, train);
		self.txtCode.text 				:= null;
		self.txtDescription.text 		:= null;
		self.txtArrivalDate.setDate(null);
		self.txtArrivalTime.setTime(null);
		self.txtDepartureDate.setDate(null);
		self.txtDepartureTime.setTime(null);
		self.cmbDestPort.listObject 	:= null;
		self.cmbOriginPort.listObject 	:= null;
		self.cmbGaugeClear.listObject := null;
		self.tblWagons.rows 			:= self.tblWagons.fixedRows;
		self.doBuildComboTrainStatus();		//navsp1 17MAY2022 TFS#53619
		//cnwrd1 par 19710 20.5.09 -  ccms 1067 - new fields
		self.clColour.setColor(self.getSystemColor(Window.Color_3DFace));
	//	self.txtMaxHeight.text 			:= null;
		self.tblHeight.setValues(app.convertMeasurementForDisplay(self.heightType.shortName, 0) &amp; Space &amp; self.heightType.shortName);	//09 Sep 2013	NDL	Par 32172
	//	self.txtMaxWidth.text 			:= null;
		self.tblWidth.setValues(app.convertMeasurementForDisplay(self.widthType.shortName, 0) &amp; Space &amp; self.widthType.shortName);	//09 Sep 2013	NDL	Par 32172
	//	self.txtMaxWeight.text 			:= null;
		self.tblWeight.setValues(app.convertMeasurementForDisplay(self.weightType.shortName, 0) &amp; Space &amp; self.weightType.shortName);	//09 Sep 2013	NDL	Par 32172

		self.txtScheduleCode.text		:= null;
		self.txtPortArrivalDt.setDate(null);
		self.txtPortArrivalTm.setTime(null);
		self.txtShunterInDt.setDate(null);
		self.txtShunterInTm.setTime(null);
		self.txtShunterOutDt.setDate(null);
		self.txtShunterOutTm.setTime(null);
		
		carrierCode := self.myTerminal.getConfig(DefRailCarrier).String;
		
		defCarrier	:= app.myRoot.allCarriers[carrierCode];
		self.cmbCarrier.setObject(defCarrier);
		
		//+ 26/05/2009, cnwmd1, CCMS 1067, Par 19710 - New fields
		self.txtSchArrivalDt.setDate(null);
		self.txtSchArrivalTm.setTime(null);
		self.txtSchDepartDt.setDate(null);
		self.txtSchDepartTm.setTime(null);
		self.txtCargoXStartDt.setDate(null);
		self.txtCargoXStartTm.setTime(null);
		self.txtCargoXEndDt.setDate(null);
		self.txtCargoXEndTm.setTime(null);
		self.txtRemaks.text := null;
		
		if _isForNew then //+ cnwmd1, CCMS 1067, Par 19710 - moved from the end of the method
			self.txtDepartureDate.setDate(null);
			self.txtDepartureTime.setTime(null);

			if  self.myTerminal.getConfig(TrainAutoNumber).Boolean then
				self.txtCode.text := self.getSystemAutoTrainNumber();	//+ cnwmd1, CCMS 1067, Par 19710 - set default value for new
			else
				self.txtCode.text := null;
			endif;
			self.txtDescription.text 		:= self.txtCode.text;		//+ cnwmd1, CCMS 1067, Par 19710 - set default value for new
		endif;
	else
		self.doEnableForTrain(not train.isNullTrain(), train);
		
		self.frmStatus.caption := train.getStatusLineStats();

		self.txtCode.text 				:= train.code;
		self.txtDescription.text 		:= train.description;
		self.doBuildComboTrainStatus();													//navsp1 17MAY2022 TFS#53619
		self.cmbStatus.text	:=	app.trainStatusEnumToString(train.status.Integer);		//navsp1 17MAY2022 TFS#53619
		if train.scheduledArrivalDT.isValid() then																		//+TFS38078 To keep previous tranis's scheduled arrival/depature dts
				// 09 May 2016	cnwns1	TFS 488 - Multi Timezone Support
			schArrivalDT := self.systemToLocalTime(train.scheduledArrivalDT);
			self.txtSchArrivalDt.setDate(schArrivalDT.date);
			self.txtSchArrivalTm.setTime(schArrivalDT.time);
		else
			self.txtSchArrivalDt.text := null;
			self.txtSchArrivalTm.setTime(timeNull);
		endif;
	
		if train.scheduledDepartureDT.isValid() then
			schDepartureDT := self.systemToLocalTime(train.scheduledDepartureDT);
			self.txtSchDepartDt.setDate(schDepartureDT.date);
			self.txtSchDepartTm.setTime(schDepartureDT.time);
		else
			self.txtSchDepartDt.text := null;
			self.txtSchDepartTm.setTime(timeNull);
		endif;																																				//+TFS38078
		
		
		if train.myOriginPort &lt;&gt; null then
			self.cmbOriginPort.setObject(train.myOriginPort);
		else
			self.cmbOriginPort.listObject := null;
		endif;
		
		if train.myDestinationPort &lt;&gt; null then
			self.cmbDestPort.setObject(train.myDestinationPort);
		else
			self.cmbDestPort.listObject := null;
		endif;
						
		//cnwrd1 par 19710 20.5.09 -  ccms 1067 - new fields
		self.clColour.setColor(train.colour);
		//self.txtMaxHeight.text 			:= train.maxHeight.asStringMeasurementJMT();
		//09 Sep 2013	NDL	Par 32172
		self.tblHeight.setValues(app.convertMeasurementForDisplay(self.heightType.shortName, train.maxHeight) &amp; Space &amp; self.heightType.shortName);	//09 Sep 2013	NDL	Par 32172
		//self.txtMaxWidth.text 			:= train.maxWidth.asStringMeasurementJMT();
		self.tblWidth.setValues(app.convertMeasurementForDisplay(self.widthType.shortName, train.maxWidth.Decimal) &amp; Space &amp; self.widthType.shortName);	//09 Sep 2013	NDL	Par 32172
		//self.txtMaxWeight.text 			:= train.maxWeight.asStringJMT();
		self.tblWeight.setValues(app.convertMeasurementForDisplay(self.weightType.shortName, train.maxWeight.Decimal) &amp; Space &amp; self.weightType.shortName);	//09 Sep 2013	NDL	Par 32172
		
		self.chkNoEmptyWagons.value := train.noEmptyWagons; // PAR 23176
		self.txtScheduleCode.text		:= train.scheduleCode;
		
		timeNull := '00:00'.asTimeJMT();					//TFS 8179
															//TFS 8179
		if _mode = self.Mode_Copy then						//TFS 8179
															//TFS 8179
				self.txtArrivalDate.text	:= null;		//TFS 8179
				self.txtArrivalTime.setTime(timeNull);		//TFS 8179
															//TFS 8179
				self.txtDepartureDate.text	:= null;		//TFS 8179
				self.txtDepartureTime.setTime(timeNull);	//TFS 8179
															//TFS 8179
				self.txtPortArrivalDt.text	:= null;		//TFS 8179
				self.txtPortArrivalTm.setTime(timeNull);	//TFS 8179
															//TFS 8179
				self.txtShunterInDt.text	:= null;		//TFS 8179
				self.txtShunterInTm.setTime(timeNull);		//TFS 8179
															//TFS 8179
				self.txtShunterOutDt.text	:= null;		//TFS 8179
				self.txtShunterOutTm.setTime(timeNull);		//TFS 8179
															//TFS 8179
			/*	self.txtSchArrivalDt.text := null;			//TFS 8179												//-TFS38078
				self.txtSchArrivalTm.setTime(timeNull);		//TFS 8179
															//TFS 8179
				self.txtSchDepartDt.text := null;			//TFS 8179											
				self.txtSchDepartTm.setTime(timeNull);		//TFS 8179*/
															//TFS 8179
				self.txtCargoXStartDt.text := null;			//TFS 8179
				self.txtCargoXStartTm.setTime(timeNull);	//TFS 8179
															//TFS 8179
				self.txtCargoXEndDt.text := null;			//TFS 8179
				self.txtCargoXEndTm.setTime(timeNull);		//TFS 8179
		else												//TFS 8179
				
			if train.arrivalDT.isValid then
				// 09 May 2016	cnwns1	TFS 488 - Multi Timezone Support
				arrivalDT := self.systemToLocalTime(train.arrivalDT);
				self.txtArrivalDate.setDate(arrivalDT.date);
				self.txtArrivalTime.setTime(arrivalDT.time);
			else
				self.txtArrivalDate.text	:= null;
				self.txtArrivalTime.setTime(timeNull);//TFS 8179
			endif;
		
			if train.departureDT.isValid then
				// 09 May 2016	cnwns1	TFS 488 - Multi Timezone Support
				departureDT := self.systemToLocalTime(train.departureDT);
				self.txtDepartureDate.setDate(departureDT.date);
				self.txtDepartureTime.setTime(departureDT.time);
			else
				self.txtDepartureDate.text	:= null;
				self.txtDepartureTime.setTime(timeNull);//TFS 8179
			endif;
			
			if train.portArrivalDT.isValid then
				// 09 May 2016	cnwns1	TFS 488 - Multi Timezone Support
				portArrivalDT := self.systemToLocalTime(train.portArrivalDT);
				self.txtPortArrivalDt.setDate(portArrivalDT.date);
				self.txtPortArrivalTm.setTime(portArrivalDT.time);
			else
				self.txtPortArrivalDt.text	:= null;
				self.txtPortArrivalTm.setTime(timeNull);//TFS 8179
			endif;
		
			if train.shunterInDT.isValid then
				// 09 May 2016	cnwns1	TFS 488 - Multi Timezone Support
				shunterInDT := self.systemToLocalTime(train.shunterInDT);
				self.txtShunterInDt.setDate(shunterInDT.date);
				self.txtShunterInTm.setTime(shunterInDT.time);
			else
				self.txtShunterInDt.text	:= null;
				self.txtShunterInTm.setTime(timeNull);//TFS 8179		
			endif;
			
			if train.shunterOutDT.isValid then
				// 09 May 2016	cnwns1	TFS 488 - Multi Timezone Support
				shunterOutDT := self.systemToLocalTime(train.shunterOutDT);
				self.txtShunterOutDt.setDate(shunterOutDT.date);
				self.txtShunterOutTm.setTime(shunterOutDT.time);
			else
				self.txtShunterOutDt.text	:= null;
				self.txtShunterOutTm.setTime(timeNull);//TFS 8179		
			endif;
				
			//+ 26/05/2009, cnwmd1, CCMS 1067, Par 19710 - New fields
			if train.scheduledArrivalDT.isValid() then
				// 09 May 2016	cnwns1	TFS 488 - Multi Timezone Support
				schArrivalDT := self.systemToLocalTime(train.scheduledArrivalDT);
				self.txtSchArrivalDt.setDate(schArrivalDT.date);
				self.txtSchArrivalTm.setTime(schArrivalDT.time);
			else
				self.txtSchArrivalDt.text := null;
				self.txtSchArrivalTm.setTime(timeNull);//TFS 8179
			endif;
	
			if train.scheduledDepartureDT.isValid() then
				// 09 May 2016	cnwns1	TFS 488 - Multi Timezone Support
				schDepartureDT := self.systemToLocalTime(train.scheduledDepartureDT);
				self.txtSchDepartDt.setDate(schDepartureDT.date);
				self.txtSchDepartTm.setTime(schDepartureDT.time);
			else
				self.txtSchDepartDt.text := null;
				self.txtSchDepartTm.setTime(timeNull);//TFS 8179
			endif;
		
			if train.cargoExchangeStartTS.isValid() then
				// 09 May 2016	cnwns1	TFS 488 - Multi Timezone Support
				cargoExchStartDT := self.systemToLocalTime(train.cargoExchangeStartTS);
				self.txtCargoXStartDt.setDate(cargoExchStartDT.date);
				self.txtCargoXStartTm.setTime(cargoExchStartDT.time);
			else
				self.txtCargoXStartDt.text := null;
				self.txtCargoXStartTm.setTime(timeNull);//TFS 8179
			endif;
	
			if train.cargoExchangeEndTS.isValid() then
				// 09 May 2016	cnwns1	TFS 488 - Multi Timezone Support
				cargoExchEndDT := self.systemToLocalTime(train.cargoExchangeEndTS);
				self.txtCargoXEndDt.setDate(cargoExchEndDT.date);
				self.txtCargoXEndTm.setTime(cargoExchEndDT.time);
			else
				self.txtCargoXEndDt.text := null;
				self.txtCargoXEndTm.setTime(timeNull);//TFS 8179
			endif;
		
		endif;
		
		if train.myCarrier &lt;&gt; null then
			self.cmbCarrier.setObject(train.myCarrier);
		else
			self.cmbCarrier.listObject := null;
		endif;
		
		if train.myStevedoreReceive &lt;&gt; null then                      //02.10.2020 cnwma1 TFS #50112
			self.cmbRecStevedore.setObject(train.myStevedoreReceive);
		else
			self.cmbRecStevedore.listObject := null;
		endif;
		
		if train.myStevedoreRelease &lt;&gt; null then                      //02.10.2020 cnwma1 TFS #50112
			self.cmbRelStevedore.setObject(train.myStevedoreRelease);
		else
			self.cmbRelStevedore.listObject := null;
		endif;
		
		//26 Jun 2009 NDL CCMS 1067 
		self.myAssistant.comboBoxTrackClearance(cmbGaugeClear, train.myTrackClearance);
		
		
		self.txtRemaks.text := train.remarks;
		
		self.loadWagons(); 	//+ cnwmd1, CCMS 1067, Par 19710	//05 Oct 2009	NDL	Par 20796 - change signature
		
	endif;
	
	self.setMyCaption();
	
	//17 July 2009	NDL	CCMS 1067
	self.displayWarnings();
//	self.hideShowAdvanced(self.chkAdvanced.value);
	self.resize();
	self.loadTblTrans(); // 14 Aug 2009	NDL CCMS 1094
//	self.loadStatsTables();	// 14 Aug 2009	NDL CCMS 1094
	self.loadStatsTables2();	// 09 Nov 2009	NDL	Par 21519
	
	/* 						//- cnwmd1, CCMS 1067, Par 19710
	if _isForNew then
		self.txtDepartureDate.setDate(null);
		self.txtDepartureTime.setTime(null);
		if  self.myTerminal.getConfig(TrainAutoNumber).Boolean then
			self.txtCode.text := self.getSystemAutoTrainNumber();	//+ cnwmd1, CCMS 1067, Par 19710 - set default value for new
		else
			self.txtCode.text := null;
		endif;
		self.txtDescription.text 		:= self.txtCode.text;		//+ cnwmd1, CCMS 1067, Par 19710 - set default value for new
	else
		self.loadWagons(true);
	endif;
	*/
	
	

	// TFS 2198 CNWAB1
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		self.btnNewTrain.enabled:= false;
		self.btnEditTrain.enabled:= false;
		self.btnSaveBase.enabled:= false;
		self.btnSaveNext.enabled:= false;
		self.btnCopyTrain.enabled:= false;
		self.btnDeleteTrain.enabled:= false;
		self.btnConfirmTrainO.enabled:= false;
		self.btnConfirmTrainI.enabled:= false;
		self.btnConfirmOut.enabled:= false;
		self.btnConfirmIn.enabled:= false;
		self.btnDeparture.enabled:= false;
		self.btnOutOrder.enabled:= false;
		self.btnMoveToRail.enabled:= false;
		
		self.btnNewWagon.enabled:= false;
		self.btnMoveWagon.enabled 		:= false;		//18.8.2022 navhl20 TFS 54281
		self.btnWagonUnplan.enabled		:= false;		//18.8.2022 navhl20 TFS 54281
		self.btnDeleteWagon.enabled:= false;
		self.btnCCWagon.enabled:= false;

		self.btnWagonDown.enabled:= false;
		self.btnWagonUp.enabled:= false;
		self.btnIntransitNO.enabled:= false;
		self.btnIntransit.enabled:= false;
		self.btnRailAllocRem.enabled:= false;
	endif;
	
end;


</source>
        <access>protected</access>
        <Parameter name="_isForNew" type="Boolean"/>
        <Parameter name="_mode" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="showTransactions" id="c8a4a71f-b414-4b15-a149-a1cb660e328b">
        <source>showTransactions();
// ---------------------------------------------------------------------------
// Created:     21 May 2009 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

	wagon	 : CM_Wagon;
	wagonForm : YRD_WagonTransactionForm;
begin
	wagon := self.tblWagons.allSelectedObjects.first.CM_Wagon;
	
	if wagon = null then
		return;
	endif;


	wagonForm := app.loadForm(YRD_WagonTransactionForm, YRD_Assistant, false, false, false, self.myTerminal, self.myMasterMenuAction).YRD_WagonTransactionForm;
	wagonForm.myCurrentWagon := wagon;
	wagonForm.show();
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="showWagon" id="59f84572-88d8-4307-aad4-5eab4d9fd354">
        <source>showWagon(_in : Boolean; _confirmInMode : Boolean);
// ---------------------------------------------------------------------------
// Created:     21 May 2009 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	train : CM_Train;
	wagon : CM_Wagon;
	obj : Object;
	objSet : ObjectSet;
begin


	create objSet transient; // deleted by assistant
	if _in then
		self.mySelectedTrain.allWagonsByIdInward.copy(objSet);
	else
		self.mySelectedTrain.allWagonsByIdOutward.copy(objSet);
	endif;
	if objSet.isEmpty() then
		app.msgBox(app.getErrorString(No_Wagons_For_Train), app.getErrorString(Cargo_Enquiry), MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
	else
		self.myAssistant.YRD_Assistant.showWagonEnquiry(objSet, self.mySelectedTrain, _in, _confirmInMode, self.myMasterMenuAction, self);
	endif;

epilog
	//delete objSet;
end;</source>
        <Parameter name="_in" type="Boolean"/>
        <Parameter name="_confirmInMode" type="Boolean"/>
    </JadeMethod>
