    <JadeMethod name="getMessageType" id="cb5f0585-452f-4c08-ae1d-6d2b18e80f71">
        <source>getMessageType(	_transaction: CM_TITransaction; 
				_messageTypeArray: IntegerArray input;
				_camProtocol: CM_CamProtocol;
				_camAgent : CM_CamControllerAgent input);
//
// 10/02/2011	cnwcs5	CCMS JMT 1977/PAR 26531 - changed parameter usage from io to input
// 11/01/2012	cnwrs1	PAR 28961 process Marine export MTs
//03 Jun 2014	cnwrs1	Par 34298 change order gate out and gate in are created
// 19 Jul 2016	cnwer1	TFS 2387 lots more logging
//12 July 2017	jlgrs1	TFS 4465 SNO standard Codedo/Coarri
vars
	taSource, taTarget : CM_TerminalArea;
	ti : CM_TrackedItem;
	contentsStatus : Integer;
	subTo, subFrom : CM_SubTerminal;
	tr : CM_TITransaction;
	exclusionReason : String;
begin
	_messageTypeArray.clear;
	ti := _transaction.myTrackedItem; //par16936 cnwrs1 june 2008

	contentsStatus := _transaction.contentsStatus;

	if _transaction.isCamsRoadReceiveType() then
		if (contentsStatus = TI_CONTENTS_STATUS_EMPTY and _camProtocol.isDepotActivity()) or
		   ((not contentsStatus = TI_CONTENTS_STATUS_EMPTY or _transaction.imExStatus = TI_IMEX_STATUS_EXPORT) and // par 28961
		   _camProtocol.isTerminalActivity()) then
			_messageTypeArray.add(CODECO_GATEIN);
		else
			if _camProtocol.isDepotActivity then
				exclusionReason := "Depot Activity only include empty cargo";
			elseif _camProtocol.isTerminalActivity then
				exclusionReason := "Terminal Activity only include non empty export cargo";
			else
				exclusionReason := "Cam protocol not set for depot or terminal activity";
			endif;
		endif;
	elseif _transaction.isCamsRailReceiveType() then
		if (contentsStatus = TI_CONTENTS_STATUS_EMPTY and _camProtocol.isDepotActivity()) or
		   ((not contentsStatus = TI_CONTENTS_STATUS_EMPTY or _transaction.imExStatus = TI_IMEX_STATUS_EXPORT) and 	//par 28961
		   _camProtocol.isTerminalActivity()) then
			_messageTypeArray.add(CODECO_GATEIN);
		else
			if _camProtocol.isDepotActivity then
				exclusionReason := "Depot Activity only include empty cargo";
			elseif _camProtocol.isTerminalActivity then
				exclusionReason := " Terminal Activity only include non empty export cargo";
			else
				exclusionReason := "Cam protocol not set for depot or terminal activity";
			endif;
		endif;
	elseif _transaction.isCamsPackType() then
		if _camProtocol.getPackUnpackStatusChange() then
			_messageTypeArray.add(CODECO_PACK);
		else
			//epr TFS 2512 10/8/16 pack areas not used
			if _camProtocol.packGateOutMT then
				_messageTypeArray.add(CODECO_GATEOUT);	//03 Jun 2014	cnwrs1	Par 34298 change order gate out and gate in are created
			endif;
			if _camProtocol.packGateInFull then
				_messageTypeArray.add(CODECO_GATEIN);
			endif;
		endif;
		if _messageTypeArray.isEmpty then
			exclusionReason:= "Cam Protocol not set for Pack complete create Gate In or Gate Out";
		endif;
	elseif _transaction.isCamsRoadReleaseType() then
		if (contentsStatus = TI_CONTENTS_STATUS_EMPTY and _camProtocol.isDepotActivity()) or
		   (not contentsStatus = TI_CONTENTS_STATUS_EMPTY and _camProtocol.isTerminalActivity()) then
			_messageTypeArray.add(CODECO_GATEOUT);
		else
			if _camProtocol.isDepotActivity then
				exclusionReason := "Depot Activity only include empty cargo";
			elseif _camProtocol.isTerminalActivity then
				exclusionReason := "Terminal Activity only include non empty cargo";
			else
				exclusionReason := "Cam protocol not set for depot or terminal activity";
			endif;
		endif;
	elseif _transaction.isCamsRailReleaseType() then
		if (contentsStatus = TI_CONTENTS_STATUS_EMPTY and _camProtocol.isDepotActivity()) or
		   (not contentsStatus = TI_CONTENTS_STATUS_EMPTY and _camProtocol.isTerminalActivity()) then
			_messageTypeArray.add(CODECO_GATEOUT);
		else
			if _camProtocol.isDepotActivity then
				exclusionReason := "Depot Activity only include empty cargo";
			elseif _camProtocol.isTerminalActivity then
				exclusionReason := "Terminal Activity only include non empty cargo";
			else
				exclusionReason := "Cam protocol not set for depot or terminal activity";
			endif;
		endif;
	elseif _transaction.isCamsUnpackType() then
		if _camProtocol.getPackUnpackStatusChange() then
			_messageTypeArray.add(CODECO_UNPACK); //ccms1499 cnwrs1 nov 2006
		else
		//epr TFS 2512 10/8/16 pack areas not used
			if _camProtocol.unpackGateOutFull then
				_messageTypeArray.add(CODECO_GATEOUT);	//03 Jun 2014	cnwrs1	Par 34298 change order gate out and gate in are created
			endif;
			if _camProtocol.unpackGateInMT then
				_messageTypeArray.add(CODECO_GATEIN);
			endif;
		endif;
		if _messageTypeArray.isEmpty then
			exclusionReason:= "Cam Protocol not set for Unpack create Gate In or Gate Out";
		endif;
	elseif _transaction.isCamsMoveType() then 
		
	   if    _transaction.CM_Move.mode = REAL_MODE then //par 16040 cnwrs1 Mar 2008
			if (_transaction.contentsStatus = TI_CONTENTS_STATUS_EMPTY and
				_camProtocol.isDepotActivity()) or
			   (_transaction.contentsStatus &lt;&gt; TI_CONTENTS_STATUS_EMPTY and
				_camProtocol.isTerminalActivity()) then
				taSource := _transaction.CM_Move.getSourceTA();
				taTarget := _transaction.CM_Move.getTargetTA();
				if taSource &lt;&gt; null and //par16555 cnwrs1 Apr 2008 ignore moves within the pack areas
				   taTarget &lt;&gt; null and (_camProtocol.allPackAreas.includes(taSource) and
					   _camProtocol.allPackAreas.includes(taTarget)) then
					exclusionReason :="Source and Target areas included in pack areas";
				else			
					if taTarget &lt;&gt; null and
					   _camProtocol.allPackAreas.includes(taTarget) then	//03 Jun 2014	cnwrs1	Par 34298 change order gate out and gate in are created
						_messageTypeArray.add(CODECO_GATEOUT);
					endif;
					if taSource &lt;&gt; null and
					   _camProtocol.allPackAreas.includes(taSource) then
					   if self.special_MSCForNZPOE and _camProtocol.special_MSCForNZPOE and _transaction.isEmpty and
						   ti.consignee = "POW" and
						   ti.getAvailabilityGrade &gt; 0 then
						  exclusionReason:="Special MSC Codeco for NZPOE excluded MT for POW consignee with AV grade";
						else
						  _messageTypeArray.add(CODECO_GATEIN);
						endif;					 		
					endif;
					if _messageTypeArray.isEmpty then
						exclusionReason:= "Source or Target areas not included in pack areas";
					endif;
				endif;
			else
				if _camProtocol.isDepotActivity then
					exclusionReason := "Depot Activity only include empty cargo";
				elseif _camProtocol.isTerminalActivity then
					exclusionReason := "Terminal Activity only include non empty cargo";
				else
					exclusionReason := "Cam protocol not set for depot or terminal activity";
				endif;
			endif;
		else
			exclusionReason := "move not a done in real mode";
		endif;
	elseif _transaction.isCamsShipReceiveType() then //CCMS 1670 Apr 2008 cnwrs1
		if not ti.isRehandle then //par18543 cnwrs1 Nov 2008
			if _transaction.contentsStatus = TI_CONTENTS_STATUS_EMPTY then//par16936 cnwrs1 june 2008
				if _camProtocol.isDepotActivity() and 
				   not _camProtocol.isTerminalActivity() then
					_messageTypeArray.add(CODECO_GATEIN);
				endif;
				if _camProtocol.isTerminalActivity() and
				   not _camProtocol.isDepotActivity() then
				    if self.special_MSCForNZPOE and _camProtocol.special_MSCForNZPOE and _transaction.isEmpty and
						   ti.consignee = "POW" and
						   ti.getAvailabilityGrade &gt; 0 then
						  exclusionReason:="Special MSC Codeco for NZPOE excluded MT for POW consignee with AV grade";
					else
				   				   
						_messageTypeArray.add(CODECO_GATEOUT);
					endif;
				endif;
				if _messageTypeArray.isEmpty then
					exclusionReason:= "Cam Protocol has either both or neither of depot or terminal activity set";
				endif;
			else
				exclusionReason :="Not empty";
			endif;
		else
			exclusionReason := "Is Rehandle";
		endif;
	elseif _transaction.isCamsShipReleaseType() then //CCMS 1670 Apr 2008 cnwrs1
		if not ti.isRehandle then //par18543 cnwrs1 Nov 2008
		   if _transaction.contentsStatus = TI_CONTENTS_STATUS_EMPTY then	//par16936 cnwrs1 june 2008
				if _camProtocol.isDepotActivity() and
				   not _camProtocol.isTerminalActivity()then
					_messageTypeArray.add(CODECO_GATEOUT);
				endif;
				
				if _camProtocol.isTerminalActivity() and
				   not _camProtocol.isDepotActivity() then
					_messageTypeArray.add(CODECO_GATEIN);
				endif;
				if _messageTypeArray.isEmpty then
					exclusionReason:= "Cam Protocol has either both or neither of depot or terminal activity set";
				endif;
			else
				exclusionReason :="Not empty";	
			endif;
		else
			
			exclusionReason := "Is Rehandle";
		endif;
	
	elseif _transaction.isKindOf(CM_SubTerminalReceive) then
		subTo	:=	_transaction.CM_SubTerminalReceive.mySubTerminal;
		subFrom	:=	_transaction.CM_SubTerminalReceive.mySubTerminalFrom;
		if subTo &lt;&gt; null then		// shouldn't happen in production - KPD 13/11/2017
			if (subTo.type = SubTermType_Marine_Int and _camProtocol.isTerminalActivity()) or
			   (subTo.type = SubTermType_Depot_Int and _camProtocol.isDepotActivity()) then
				// Moving to marine and terminal activity flag set OR
				// Moving to depot and depot activity set
				if (_camProtocol.packGateInFull or _camProtocol.unpackGateInMT) and //ccms1912 cnwrs1 26 jan 2010
				   subFrom &lt;&gt; null and subFrom.type = SubTermType_Warehouse_Int then 
				   //	Coming from warehouse - do nothing the gatein will be produced by the pack/unpack (old way)
				   exclusionReason := "Packing or Unpacking from a warehouse sub terminal";
				else
					_messageTypeArray.add(CODECO_GATEIN);
				endif;
			else
				if _camProtocol.isTerminalActivity then
					exclusionReason := "Depot Activity only includes receiving to a depot sub terminal"; 
				elseif _camProtocol.isDepotActivity then
					exclusionReason := "Terminal Activity only includes receiving to a marine sub terminal"; 
				else
					exclusionReason := "Cam protocol not set for depot or terminal activity";
				endif;
			endif;
		else
			exclusionReason := "no subterminal received into.";
		endif;
		
	elseif _transaction.isKindOf(CM_SubTerminalRelease) then
		subTo	:=	_transaction.CM_SubTerminalRelease.mySubTerminalTo;
		subFrom	:=	_transaction.CM_SubTerminalRelease.mySubTerminal;
		if subFrom &lt;&gt; null then		// should never happen in production! // cnwrl1 05/08/2010 PAR 21961
			if (subFrom.type = SubTermType_Marine_Int and _camProtocol.isTerminalActivity()) or
			   (subFrom.type = SubTermType_Depot_Int and _camProtocol.isDepotActivity()) then
				// Moving from marine and terminal activity flag set OR
				// Moving from depot and depot activity set
				if (_camProtocol.packGateOutMT or _camProtocol.unpackGateOutFull) and //ccms1912 cnwrs1 26 jan 2010
				   (subTo &lt;&gt; null and  subTo.type = SubTermType_Warehouse_Int) then  //epr TFS 5106 25/7/17
				   // Going to warehouse - do nothing the gateout will be produced by the pack/unpack (old way)
				     exclusionReason := "Packing or Unpacking to a warehouse sub terminal";
				else
					_messageTypeArray.add(CODECO_GATEOUT);
				endif;
			else
			
				if _camProtocol.isTerminalActivity then
					exclusionReason := "Depot Activity only includes receiving to a depot sub terminal"; 
				elseif _camProtocol.isDepotActivity then
					exclusionReason := "Terminal Activity only includes receiving to a marine sub terminal"; 
				else
					exclusionReason := "Cam protocol not set for depot or terminal activity";
				endif;
			endif;
		else
			exclusionReason := "no subterminal released from.";
		endif;
	elseif _transaction.isKindOf(CM_Weighed) then
		
		if _camProtocol.useVGM then
			if app.myRoot.canDo(Mod_EDIVGM) then
				if _transaction.CM_Weighed.isWeightCertified then
					_messageTypeArray.add(CODECO_VGM);
				else
					exclusionReason:="Not certified";
				endif;
			else
				exclusionReason:="Not licensed to use VGM";
			endif;
		else
			exclusionReason:="Cam protocol does not use VGM";
		endif;
		
	elseif _transaction.isKindOf(CM_ReceiveRoadCancelled) then
		if self.hasRoadReceiveBeenProcessed(_transaction) then 
			_messageTypeArray.add(CODECO_CANCEL);
		else
			exclusionReason := "InfoSent Transaction must be present for the Receive Road";
		endif;
		
	else
		exclusionReason:="transaction not supported";
	endif;
	
	//epr TFS 2387 19/7/16 more logging
	if _messageTypeArray.isEmpty then
		//log reasons why this transaction has no messages
		if _camAgent&lt;&gt; null and  exclusionReason &lt;&gt; null then
			_camAgent.logReasonForExclusion(_transaction,exclusionReason);
		endif;
	endif;
	
end;
</source>
        <Parameter name="_transaction" type="CM_TITransaction"/>
        <Parameter name="_messageTypeArray" type="IntegerArray" usage="input"/>
        <Parameter name="_camProtocol" type="CM_CamProtocol"/>
        <Parameter name="_camAgent" type="CM_CamControllerAgent" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getMessageTypeString" id="341f0fc1-4525-4ec6-b4b3-fbeab59ec424">
        <source>getMessageTypeString(_messageType : Integer) : String;

vars

begin

	if _messageType = CODECO_DAMAGED then
		return "Codeco Damaged";
	elseif _messageType = CODECO_REPAIRED then
		return "Codeco Repaired";
	elseif _messageType = CODECO_GATEIN then
		return "Codeco Gate In";
	elseif _messageType = CODECO_GATEOUT then
		return "Codeco Gate Out";
	else
		return "Unknown Codeco Message!";
	endif;


end;</source>
        <Parameter name="_messageType" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getRoadReceiveTrxBookingRef" id="5ff6c2cc-534f-48a1-9823-028368cc536d">
        <source>getRoadReceiveTrxBookingRef(_ti : CM_TrackedItem) : String;
/*****************************************************
Author		: jlgka1 (Karen Alexander)
Date		: 18 February 2019
TFS#		: 48550
Function	:  As we added a booking reference in the external reference id and we added || as the separator we need to get anything after the || as a booking number.

*** Changes ***
Date			Name		TFS#		Description

****************************************************/
vars
	trans 		: CM_TITransaction;
	receiveTrx 	: CM_Receive;
	bookingRef	: String;
	pos 		: Integer;
begin
	if _ti = null then
		return null;
	endif;
	
	foreach trans in _ti.allTransactions reversed, discreteLock do 
		if trans.deleted and global.isTiTxnOfType(trans.type, TRANS_TYPE_RECEIVE) then
			receiveTrx := trans.CM_Receive;
			if receiveTrx.externalReferenceId = null then	//24 Mar 2020	NDL	TFS 48961
				continue;
			endif;
			pos := receiveTrx.externalReferenceId.pos("|", 1);  // we are using a double pipe so we just need to look for first pipe location			
			
			if pos = 0 then
				return null;
			endif;
			
			pos := pos + 2; //increment by 2 as we know that we are using a double pipe
			if pos &lt; receiveTrx.externalReferenceId.length then
				bookingRef := receiveTrx.externalReferenceId.scanUntil("|", pos); // we are using a double pipe but the scanUntil will return a position of the first pipe so no need to look for the next pipe
			endif;
			
			return bookingRef;
		endif;
	endforeach;
	
	return null;
epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getRoadReceiveTrxSeqNum" id="fbaa210b-a031-4969-88e5-a7252aaf2c28">
        <source>getRoadReceiveTrxSeqNum(_ti : CM_TrackedItem) : String;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 09/01/2020	jlgdap1		Initial creation TFS 48016 SNO Deletion CODECO
// 20/02/2020	jlgka1		TFS 48550 As we added a booking reference in the external reference id and we added || as the separator we need to get anything before that || as a sequence number.
vars
	trans 			: CM_TITransaction;
	receiveTrx 		: CM_Receive;
	sequenceNumber 	: String;
	pos 			: Integer;
begin
	if _ti = null then
		return null;
	endif;
	
	foreach trans in _ti.allTransactions reversed, discreteLock do 
		if trans.deleted and global.isTiTxnOfType(trans.type, TRANS_TYPE_RECEIVE) then
			receiveTrx := trans.CM_Receive;
			if receiveTrx.externalReferenceId = null then	//24 Mar 2020	NDL	TFS 48961
				continue;
			endif;
			pos := 1;
			sequenceNumber := receiveTrx.externalReferenceId.scanUntil("|", pos); // we are using a double pipe but the scanUntil will return a position of the first pipe so no need to look for the next pipe
			return sequenceNumber;
		endif;
	endforeach;
	
	return null;
epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getSenderCode_UNB" id="8777ccba-636f-4b7c-9e0d-9a2187720019">
        <source>getSenderCode_UNB(_protocol :CM_CamProtocol):String protected;
/*	
Return Value:	sender code to use in UNB segment

Date		Who		Reason
16 May 2011	cnwcs5	Initial creation - CCMS SCT 2058/par 27460
04 Jan 2012 cnwrs1	Par 28928 not using senderCodeDepot
*/
vars
	code		:String;
	terminal	:CM_Terminal;
	camGroup : CM_CamGroup;
begin
	camGroup := _protocol.camGroup;
	code 		:= camGroup.senderCode.trimBlanks;
	
	if _protocol.depotActivity and	// Par 28928 cnwrs1 4 Jan 2012
	   not _protocol.terminalActivity and
	   camGroup.senderCodeDepot &lt;&gt; null then
		code := camGroup.senderCodeDepot.trimBlanks;
	endif;
	terminal	:= _protocol.terminal;
	
	// 09/03/2012 cnwar2 #29175
	if code = null then
		code := _protocol.camISOPortDesc.trimBlanks;
	endif;
	
	if code = null then
		code := terminal.getConfig(PortDestCode).String.trimBlanks;
	endif;
	
	// for some reason no translation
	
	return code;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_protocol" type="CM_CamProtocol"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getTimeForUNB" id="23a533d1-7f29-4d1b-9d27-f56ab5bafee0">
        <source>getTimeForUNB(	_dateTime : TimeStamp;	
				_camProtocol : CM_CamProtocol;
				_tiTrans : CM_TITransaction;
				_camMessage: CM_CamMessage
				):TimeStamp;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26 April 2018	jlgndl1	Initial creation

*/

vars 

	dateTime: TimeStamp;

begin

	dateTime := _dateTime;
	
	if not _camProtocol.singleContainerPerUNB
	or _camMessage = null
	or _tiTrans = null
	then
		return dateTime;
	endif;
	
	if _camMessage.activity &lt;&gt; CODECO_GATEOUT
	and _camMessage.activity &lt;&gt; CODECO_GATEIN
	then
		return dateTime;
	endif;
	

	if _tiTrans.isCamsPackType then
	
		if _camMessage.activity = CODECO_GATEOUT then
			// Gating out am Enpty
			dateTime := dateTime.addMinutes(-1);
			
		elseif _camMessage.activity = CODECO_GATEIN then
			//Gating in a Full
			dateTime := dateTime.addMinutes(1);
			
		endif;
	
	elseif _tiTrans.isCamsUnpackType then
	
		if _camMessage.activity = CODECO_GATEOUT then
			// Gating out a full
			dateTime := dateTime.addMinutes(-1);
			
		elseif _camMessage.activity = CODECO_GATEIN then
			//Gating in an empty
			dateTime := dateTime.addMinutes(1);
			
		endif;
	
	endif;
	
	return dateTime;

epilog

end;</source>
        <Parameter name="_dateTime" type="TimeStamp"/>
        <Parameter name="_camProtocol" type="CM_CamProtocol"/>
        <Parameter name="_tiTrans" type="CM_TITransaction"/>
        <Parameter name="_camMessage" type="CM_CamMessage"/>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="getTransactionTypesToProcess" id="3e5af0cf-75da-4edb-b69d-235172a0db21">
        <source>getTransactionTypesToProcess(_protocol: CM_CamProtocol; _coll: IntegerArray input) protected;
/*
Date		Who		Reason
21 Mar 2013	cnwcs5	Initial Creation - CCMS SFW 1294/par 30855
03 Apr 2017 cnwma1	TFS #3772:POL - MSK Codeco generated by Edit Transaction ##3765##
*/
vars

begin
	inheritMethod(_protocol, _coll);
	
	if (_protocol.gateInForNullVoyageChange and not _protocol.prcNullVoyageTransaction) then
		//or _protocol.gateInForNullOperatorChange then  //03/04/2017 cnwma1 TFS #3772
		 
		if not _coll.includes (TRANS_TYPE_EDIT) then
			_coll.add (TRANS_TYPE_EDIT);
		endif;
		
	/*	if not _coll.includes (TRANS_TYPE_OperatorChange) then  //03/04/2017 cnwma1 TFS #3772
			_coll.add (TRANS_TYPE_OperatorChange);
		endif;
	*/
		if not _coll.includes (TRANS_TYPE_ProductCodeChange) then
			_coll.add (TRANS_TYPE_ProductCodeChange);
		endif;				
	endif;
	
	if  _protocol.gateInForNullOperatorChange then            //03/04/2017 cnwma1 TFS #3772
		if not _coll.includes (TRANS_TYPE_OperatorChange) then
			_coll.add (TRANS_TYPE_OperatorChange);
		endif;
	endif;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_protocol" type="CM_CamProtocol"/>
        <Parameter name="_coll" type="IntegerArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getTransactionVoyageCode" id="eeabe021-59b5-4a3f-99fc-d54013d23e82">
        <source>getTransactionVoyageCode(_transaction: CM_TITransaction; _camProtocol: CM_CamProtocol; _vesselName : String io) : String;
//
// 30 May 2014	cnwrs1	Par 34265 use transaction voyage for gate out full for unpack complete
// 08 Apr 2022	jlika1	TFS 53181	GPHA - Voyage Code Translation for Multiple Terminals and Co-Loaders
vars
	voyageId : String;
	xlVoyageId: String;
	voyage : CM_Voyage;
begin

	_vesselName := null;
	voyage := _transaction.getVoyage();
	if voyage = null then
		return null;
	endif;

	if _transaction.imExStatus = TI_IMEX_STATUS_EXPORT then
		voyageId := voyage.code;

	elseif _transaction.imExStatus = TI_IMEX_STATUS_IMPORT then
		voyageId := voyage.inwardCode;
		if voyageId = null then
			voyageId := voyage.code;
		endif;
	elseif _transaction.imExStatus = TI_IMEX_STATUS_STORAGE then
		voyageId := voyage.inwardCode;
		if voyageId = null then 
			voyageId := voyage.code;
		endif;
	else
		voyageId := voyage.code;
	endif;
	_vesselName := voyage.vesselName;

	//translate the voyage Code
	if (self.isKindOf(CM_CamStandardCODECODesc) or self.isKindOf(CM_CamStandardCODECOSMDG213)) 
	and _camProtocol.getIsCustomsProtocol() and voyage.customsManifest &lt;&gt; null then
		xlVoyageId := voyage.customsManifest;
	else
		xlVoyageId := self.getXlatedForeignCode(_camProtocol.operatorXlationCode.trimBlanks, voyageId, XLATION_TYPE_VOYAGETERMINAL, _camProtocol.terminal);
	endif;
	
	if xlVoyageId = NULL_VOYAGE_CODE then
		xlVoyageId := null;
	endif;
	return xlVoyageId;
end;
</source>
        <Parameter name="_transaction" type="CM_TITransaction"/>
        <Parameter name="_camProtocol" type="CM_CamProtocol"/>
        <Parameter name="_vesselName" type="String" usage="io"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getVoyageCode" id="ddb3e658-a2cc-4876-a451-2da2caab9be3">
        <source>getVoyageCode(_transaction: CM_TITransaction; _camProtocol: CM_CamProtocol; _vesselName : String io):String;
//
// 14/07/2010	cnwdap1		PAR #25021 reveiew use of isImport/isExport for tranships
//
vars
	voyageId,xlVoyageId: String;
	theTI : CM_TrackedItem;

begin

	theTI := _transaction.myTrackedItem;

	//get the voyage code
	//if theTI.isExport then								// PAR #25021
	if theTI.isExport or theTI.isTranshipOutbound then		// PAR #25021
		voyageId := theTI.myVoyage.code;
	//elseif theTI.isImport then							// PAR #25021
	elseif theTI.isImport or theTI.isTranshipInbound then	// PAR #25021
		voyageId := theTI.myVoyage.inwardCode;
		if voyageId = null then //cnwrs1 par16600 Mar 2008
			voyageId := theTI.myVoyage.code;
		endif;
	elseif theTI.isStorage then
		voyageId := theTI.myVoyage.inwardCode;
		if voyageId = null then //cnwrs1 par16600 Mar 2008
			voyageId := theTI.myVoyage.code;
		endif;
	else
		voyageId := theTI.myVoyage.code;
	endif;
	_vesselName := theTI.myVoyage.vesselName; //par18987 cnwrs1 Mar 2009

	//translate the voyage Code
	xlVoyageId := self.getXlatedForeignCode(_camProtocol.operatorXlationCode.trimBlanks, voyageId, XLATION_TYPE_VOYAGETERMINAL, _camProtocol.terminal);
	if xlVoyageId = NULL_VOYAGE_CODE then //cmwrs1 Mar 2007 CCMS 1050
		xlVoyageId := null;
	endif;
	return xlVoyageId;
end;</source>
        <Parameter name="_transaction" type="CM_TITransaction"/>
        <Parameter name="_camProtocol" type="CM_CamProtocol"/>
        <Parameter name="_vesselName" type="String" usage="io"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="hasRoadReceiveBeenProcessed" id="6cd745f0-f468-473e-a4ff-64a9b94ebfff">
        <source>hasRoadReceiveBeenProcessed(_transaction: CM_TITransaction) : Boolean;
/*
Purpose: Determines if CAM has processed a ReceiveRoad transaction type.
		 This condition determines if a Cancellation CODECO is necessary to produce 
		 when a ReceiveRoadCancelled transaction is present 
		 (container has been deleted in the Road Operation screen)

Parameters:			

Return Value:

Date		Who		TFS		Reason
01 Nov 2019	jlgdi1	46578	Initial creation

*/

vars
	trackedItem : CM_TrackedItem;
	transaction : CM_TITransaction;
	infoEDISent : CM_InfoEDISent;
	processed : Boolean;
	
begin
	trackedItem := _transaction.myTrackedItem;
	foreach transaction in trackedItem.allTransactions reversed do  // start from the most recent transaction
		if transaction.isKindOf(CM_ReceiveRoad) then  // There was no Info Sent after the Receive Road
			break;
		endif;
		if not transaction.isKindOf(CM_InfoEDISent) then 
			continue;
		endif;
		infoEDISent := transaction.CM_InfoEDISent;
		if (infoEDISent.myOtherTransaction &lt;&gt; null) and infoEDISent.myOtherTransaction.isKindOf(CM_ReceiveRoad) then
			processed := true;
			break;
		endif;
	endforeach;

	return processed;
end;</source>
        <Parameter name="_transaction" type="CM_TITransaction"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
