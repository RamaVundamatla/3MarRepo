    <JadeMethod name="isNotPaidByAPI" id="3558b64f-1427-494e-928c-04c67c6ea45c">
        <source>isNotPaidByAPI() : Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30/04/2025	navkc1 JIRA Bug MTN-34734: QTS | UAT - Hard stop for Cancelled Additional charges cash receipt.

*/

vars
	cashPayment 		: CM_CashPayment;
	checked 			: Boolean;
	cashPaymentTotal 	: Decimal[23,6];
begin
	
	foreach cashPayment in self.allCashPayments discreteLock do
		
		checked := true;
		
		if cashPayment.isNotPaidByAPI() then
			continue;
		endif;
		
		cashPaymentTotal += cashPayment.cashValue;
	endforeach;
	
	
	return checked and cashPaymentTotal &lt; self.lineTotal;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isPaidFor" id="347ecde1-d0c2-41cd-941d-8f2eb07febca">
        <source>isPaidFor() : Boolean;
/*

Purpose:			
		return true if the non-zero total allCashPayments.cashValue is at least equal to the current lineTotal
		used to avoid resynching this invoice line from a subsequent cash receipt
Parameters:			

Return Value:		

Date		Who		Reason
29 Jun 2017 cnwma1 TFS #4549 ADP - Issue in Cash collectiion
07 Feb 2019 cnwma1 Bug 43300: PKT - Cash Collection Module Issue
 // ### JIRA 35502 18JUL2025 NAVAB1  use static value totalAmount not lineTotal()
*/
vars
	result		: Boolean;
	payment		: CM_CashPayment;
	cashTotal,payAmount, lineAmount	: Decimal[23, 6];	//11 May 2018	NDL	TFS 38528
	
begin
	foreach payment in self.allCashPayments do
		
		// 35232 skip voided payments
		if payment.voided or
			payment.isNotPaidByAPI() //30/04/2025	navkc1 JIRA Bug MTN-34734
			then
			/*
				if the payment is manual and the tracked item attched to it is been merged we don't need to skip this payment
				otherwise it will appear in the cash collection screen as not paid
			*/
			if payment.isManual then                   //07.02.2019 cnwma1 Bug #43300
				if payment.myTrackedItem &lt;&gt; null then
					if payment.myTrackedItem.state &lt;&gt; TI_STATE_MERGED then
						continue;
					endif;
				else
					continue;
				endif;
			else
				continue;
			
			endif;
		endif;
		cashTotal := cashTotal + payment.cashValue;
	endforeach;
	
	// from TFS 1808 testing round the values before comparing (was 880.00 paid, 880.000032 invoice line value so not showing as paid)
	lineAmount := self.totalAmount;
	
	if not self.isNegativeAmount then
		
		if cashTotal &lt;&gt; 0 or lineAmount &lt;&gt; 0  then //29/06/2017 cnwma1 TFS #4549
			result := (cashTotal.roundedTo(2) &gt;= lineAmount.roundedTo(2));
		endif;
	else
		cashTotal := cashTotal*-1;
		if cashTotal &lt;&gt; 0 or lineAmount &gt; 0  then //29/06/2017 cnwma1 TFS #4549
			result := (cashTotal.roundedTo(2) &gt;= lineAmount.roundedTo(2)*-1);
		endif;
	
	endif;
	return result;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
