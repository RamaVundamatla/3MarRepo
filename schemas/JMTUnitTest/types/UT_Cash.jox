					'Cargo,'&amp;mapName&amp;',CONT ISO Container,(Default),(Default),Import,(Default),(Default),(Default),,(Default),(Default) ›,(Default),All,VOID' &amp; CrLf &amp;
					'Cargo,'&amp;mapName&amp;',CONT ISO Container,(Default),(Default),Import,FCL,(Default),(Default),,(Default),(Default) ›,(Default),All,VOID' &amp; CrLf &amp;
					'Cargo,'&amp;mapName&amp;',CONT ISO Container,(Default),(Default),Import,FCL,(Default),Released - Road,,(Default),(Default) ›,(Default),All,UT_ILT9' &amp; CrLf &amp;
					'Cargo,'&amp;mapName&amp;',CONT ISO Container,(Default),(Default),Import,FCL,(Default),Received,,(Default),(Default) ›,(Default),All,UT_ILT8' &amp; CrLf &amp;
					'Cargo,'&amp;mapName&amp;',CONT ISO Container,(Default),(Default),Import,FCL,(Default),Storage,,(Default),CCT06 Days Since Receival »,0 to 5,All,UT_ILT10' &amp; CrLf &amp;
					'Cargo,'&amp;mapName&amp;',CONT ISO Container,(Default),(Default),Import,FCL,(Default),Storage,,(Default),CCT06 Days Since Receival »,6 to MAX,All,UT_ILT11' &amp; CrLf &amp;
					'Cargo,'&amp;mapName&amp;',CONT ISO Container,(Default),(Default),Import,FCL,(Default),Washed,,(Default),(Default) ›,(Default),All,UT_ILT9' &amp; CrLf &amp;
					'Cargo,'&amp;mapName&amp;',CONT| ISO Container,(Default),(Default),Import,FCL,(Default),(Move),Yard -&gt; Yard,(Default),(Default) ›,(Default),All,UT_ILT9' &amp; CrLf;
					
	
	self.transactionMapLoad(fileContent, fileName);
	self.assertNoTrxErrorsOrWarnings();
	
	bank := app.myPassport.myTerminal.getDefaultCompanyBank();
	cargoMap := bank.myCurrentTranMapCargo[mapName];
	self.assertNotNullMsg(cargoMap,"cargo map should not be null");

	app.myTrxUA.trxUpdateBankTMActive(cargoMap, app.myPassport);

epilog

end;
</source>
    </JadeMethod>
    <JadeMethod name="tranMapLoadSplitMergeVolume" id="28256e1c-00ce-4d04-82ee-c763dc09b6e0">
        <source>tranMapLoadSplitMergeVolume();
// cnwjre1 
// set up tran map with cargo weight invoice line types
vars
	fileContent : String;
	fileName	: String;
	mapName		: String;
	bank		: CM_Bank;
	cargoMap	: CM_TranMap;

begin
	fileName := "SplitMerge";
	mapName := "UT_SplitMerge";
	fileContent := 'TranMap Type,TranMap Name,CargoType,Cargo Subtype Group,Cargo Subtype,IMEX,Contents Status,Commodity,Transaction,MoveType,Debtor,Quantity Type,Quantity Range,Invoice Line,Over Dimsn?,Trans Ship?,Is 40?,Is Reefer?,Req Temp?,RORO?,Is 45?,Is 30?,Is 53?,Is Child?' &amp; CrLf &amp;
						'Cargo,'&amp;mapName&amp;',(Default),(Default),(Default),(Default),(Default),(Default),(Default),,(Default),(Default) ›,(Default),VOID' &amp; CrLf &amp;
						'Cargo,'&amp;mapName&amp;',UTREBAR,(Default),(Default),Import,(Default),(Default),Received - Ship,,(Default),CCT04 Cargo Weight Kilos ›,00 to MAX,UT_LineTypeVolume1,,,,,,,,,,' &amp; CrLf &amp;
						'Cargo,'&amp;mapName&amp;',UTREBAR,(Default),(Default),Import,(Default),(Default),Received - Ship,,(Default),CCT04 Cargo Weight Kilos ›,00 to MAX,UT_ILT9,,,,,,,,,,' &amp; CrLf &amp;
						'Cargo,'&amp;mapName&amp;',UTREBAR,(Default),(Default),Import,(Default),(Default),Storage,,(Default),CCT04 Cargo Weight Kilos ›,00 to MAX,UT_LineTypeVolume1,,,,,,,,,,';

	
	self.transactionMapLoad(fileContent, fileName);
	self.assertNoTrxErrorsOrWarnings();
	
	bank := app.myPassport.myTerminal.getDefaultCompanyBank();
	cargoMap := bank.myCurrentTranMapCargo[mapName];
	self.assertNotNullMsg(cargoMap,"cargo map should not be null");

	app.myTrxUA.trxUpdateBankTMActive(cargoMap,app.myPassport);

epilog

end;
</source>
    </JadeMethod>
    <JadeMethod name="tranMapLoadSplitToDoResQty" id="2eb9dbc8-5fff-4d52-a9d8-f236bb4dd652">
        <source>tranMapLoadSplitToDoResQty();
/*
Purpose - 	
Who - NAVAB1
Date - 08AUG2025
ADO - JIRA 35638
*/

vars
	ct			: String;
	fileContent : String;
	fileName	: String;
	mapName		: String;
	bank		: CM_Bank;
	cargoMap	: CM_TranMap;

begin
	if self.opts.includesKey("CargoType") then
		ct := self.opts.obj("CargoType").CM_CargoType.abbreviation;
	endif;
	self.assertNotNullMsg(ct, "Failed to get cargo type abbr");
	fileName := "BBlkResQty";
	mapName := "UT_BBlkResQty";
						
	fileContent :=  "TranMap Type,TranMap Name,CargoType,Cargo Subtype Group,Cargo Subtype,IMEX,Contents Status,Commodity,Transaction,MoveType,Debtor,Quantity Type,Quantity Range,Quantity Sub Type,Quantity Sub Range,Transfer Type,Grouping,Invoice Line,Over Dimsn?,Trans Ship?,Is 40?,Is Reefer?,Req Temp?,,Is 45?,Is 30?,Is 53?,Is Child?,Is Haz?,Direct Delivery?,Is Work Order Requested?" &amp; CrLf &amp; 
"Cargo,UT_BBlkResQty,(Default),(Default),(Default),(Default),(Default),(Default),(Default),,(Default),(Default) ›,(Default),,,**Any**,All,VOID,,,,,,,,,,,,," &amp; CrLf &amp; 
"Cargo,UT_BBlkResQty,(Default),(Default),(Default),(Default),(Default),(Default),UTResTrans,,(Default),(Default) ›,(Default),,,**Any**,All,VOID,,,,,,,,,,,,," &amp; CrLf &amp; 
"Cargo,UT_BBlkResQty,(Default),(Default),(Default),(Default),(Default),(Default),UTResTrans,Resource Mappings:UTPall,(Default),(Default) ›,(Default),,,**Any**,All,UT_LneSplitRes,,,,,,,,,,,,," &amp; CrLf &amp; 
"Cargo,UT_BBlkResQty,(Default),(Default),(Default),(Default),(Default),(Default),(Move),Ship -&gt; Yard,(Default),CCT05 Revenue Tonnes ›,00 to MAX,,,**Any**,All,UT_LneSplitDis,,,,,,,,,,,,,";						

	
	self.transactionMapLoad(fileContent, fileName);
	self.assertNoTrxErrorsOrWarnings();
	
	bank := app.myPassport.myTerminal.getDefaultCompanyBank();
	cargoMap := bank.myCurrentTranMapCargo[mapName];
	self.assertNotNullMsg(cargoMap,"cargo map should not be null");

	app.myTrxUA.trxUpdateBankTMActive(cargoMap,app.myPassport);

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="transMapLoad" id="4b814f4b-355e-47bf-ae29-5d92a3e64831">
        <source>transMapLoad();
/*

Purpose:			

Date		Who		Reason
10 May 2016	cnwmk3	Initial creation

*/
constants

	FileName					: String = "MMC";
	MapName						: String = "UT_MMC";

vars

	bank						: CM_Bank;
	cargoMap					: CM_TranMap;
		
	fileContent					: String;
	fileName					: String;


begin

	//fileContent := 'TranMap Type,TranMap Name,CargoType,Cargo Subtype Group,Cargo Subtype,IMEX,Contents Status,Commodity,Transaction,MoveType,Debtor,Quantity Type,Quantity Range,Grouping,Invoice Line,Over Dimsn?,Trans Ship?,Is 40?,Is Reefer?,Req Temp?,RORO?,Is 45?,Is 30?,Is 53?,Is Child?,Is Haz?,Direct Delivery?' &amp; CrLf &amp;
	//	'Cargo,'&amp;MapName&amp;',CANNONBALL| Cannon Balls,(Default),12POUNDER-12,Import,(Default),(Default),(Move),Road -&gt; Yard,(Default),(Default) ›,(Default),All,UT_MDHInvLineType1' &amp; CrLf;
	
	fileContent := 'TranMap Type,TranMap Name,CargoType,Cargo Subtype Group,Cargo Subtype,IMEX,Contents Status,Commodity,Transaction,MoveType,Debtor,Quantity Type,Quantity Range,Grouping,Invoice Line,Over Dimsn?,Trans Ship?,Is 40?,Is Reefer?,Req Temp?,RORO?,Is 45?,Is 30?,Is 53?,Is Child?,Is Haz?,Direct Delivery?' &amp; CrLf &amp;
					'Cargo,'	 &amp;MapName&amp;	',(Default),(Default),(Default),(Default),(Default),(Default),Washed,,(Default),(Default) ›,(Default),All,UT_MMC1' &amp; CrLf &amp;
					'Cargo,'	 &amp;MapName&amp;	',(Default),(Default),(Default),(Default),(Default),(Default),Damaged.,,(Default),(Default) ›,(Default),All,UT_MMC2';
					
	self.transactionMapLoad(fileContent, fileName);
	self.assertNoTrxErrorsOrWarnings();
	
