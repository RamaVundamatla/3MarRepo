    <JadeMethod name="setDisplayMode" id="d45f6dcf-4513-4232-ac1f-cafed0728200">
        <updating/>
        <source>setDisplayMode(_mode : Integer) updating;
// ---------------------------------------------------------------------------
// Created:     June 2009 - form cloned from YRD_RailOpsForm and YRD_GridAreasForm
//
// Purpose:		
//
// Parameters:  
//
// Returns:     
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 23/06/2009	consw1		PAR 19913 - SFW1067 Rail Simplifications
// ---------------------------------------------------------------------------
vars
	dockBar : YRD_RailDockBar;
	obj : Object;
begin
	if self.displayMode &lt;&gt; _mode then
		self.displayMode := _mode;
		self.frmModeStatusBar.displayMode := _mode;
		foreach obj in self.allGridAreaDockBars do
			dockBar := obj.YRD_RailDockBar;
			dockBar.mySDF.displayMode := _mode;
			if dockBar.visible then
				dockBar.mySDF.drawSelf();
			endif;
		endforeach;
	endif;
end;</source>
        <Parameter name="_mode" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setDisplayedObject" id="58051b1c-e78d-4628-bf8f-b5c6fd049e41">
        <updating/>
        <source>setDisplayedObject( _obj : Object ) updating;
// ---------------------------------------------------------------------------
// Created:     June 2009 - form cloned from YRD_RailOpsForm and YRD_GridAreasForm
//
// Purpose:     
//
// Parameters:  
//
// Returns:     
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 17/06/2009	consw1		PAR 19913 - SFW1067 Rail Simplifications
// ---------------------------------------------------------------------------

vars

	firstObject : Object;
	train : CM_Train;
	emptyTrain : CM_Train;
	str : String;
	
begin
	self.allTrains.clear();
	self.allRailAreas.clear();

	if _obj &lt;&gt; null then
		if _obj.isKindOf(CM_Train) then
			self.allTrains.add(_obj.CM_Train);
		elseif _obj.isKindOf(CM_Rail) then
			self.allRailAreas.add(_obj.CM_Rail);
		elseif _obj.isKindOf(Collection) then
			firstObject := _obj.Collection.first.Object;
			if firstObject.isKindOf(CM_Train) then
				_obj.Collection.copy(self.allTrains);
			elseif firstObject.isKindOf(CM_Rail) then
				_obj.Collection.copy(self.allRailAreas);
			endif;
		endif;
	endif;

	self.isDisplayedTrains := not self.allTrains.isEmpty();
	self.isDisplayedRailAreas := not self.allRailAreas.isEmpty();
	
	if isDisplayedTrains then
		//28 July 2009	NDL
		foreach train in self.allTrains do
			emptyTrain := null;
			if optDirInTB.value then
				if train.allWagonsByIdInward.isEmpty then
					emptyTrain := train;
				endif;
			else
				if train.allWagonsByIdOutward.isEmpty then
					emptyTrain := train;
				endif;
			endif;
			if emptyTrain &lt;&gt; null then
				if str = null then
					str := train.code;
				else
					str := str &amp; ", " &amp; train.code;
				endif;
			endif;
		endforeach;
		
		if str &lt;&gt; null then
			app.msgBox( app.getErrorString1(Train_have_wagons,str), app.getErrorString(Empty) &amp; " " &amp; app.getErrorString(Train),MsgBox_OK_Only);
		endif;
		if self.allTrains.size = 1 then
			self.myFilterTrain := self.allTrains.first;
		else
			self.myFilterTrain := null;
		endif;
	endif;
	
	self.myCurrentWagon := null;
	self.myCurrentTrackedItem := null;
	self.myCurrentLocation := null;
	self.myCurrentRailLine := null;
	
epilog

end;</source>
        <Parameter name="_obj" type="Object"/>
    </JadeMethod>
    <JadeMethod name="setGridAreaContextMenu" id="488fb508-31b7-43ff-b18b-221c116623cb">
        <updating/>
        <source>setGridAreaContextMenu(_gridPoint : CMUI_GridPoint input; _x, _y : Integer)updating;
// ---------------------------------------------------------------------------
// Created:     June 2009 - form cloned from YRD_RailOpsForm and YRD_GridAreasForm
//
// Purpose:     
//
// Parameters:  
//
// Returns:     
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 22/06/2009	consw1		PAR 19913 - SFW1067 Rail Simplifications
// ---------------------------------------------------------------------------
vars
	ti	: CM_TrackedItem;
	theWagon	: CM_Wagon;

begin
	self.mnuCargo.visible := false;

	self.mnuCargoEnquiry.visible := true;
	self.mnuCargoEdit.visible := true;

	self.mnuCargoConnectDis.visible := false;
	self.mnuCargoAttach.visible := false;
	self.mnuCargoAttachGenSet.visible := false;
	self.mnuCargoDetachGenSet.visible := false;
	self.mnuCargoMoveIt.visible := false;
	self.mnuCargoTestAP.visible := false;
	self.mnuCargoAP.visible := false;
	self.mnuCargoPositionSwap.visible := false;	// 12 Aug 2009	NDL	CCMS 0194
	self.mnuCargoUnplan.visible := false;
	self.mnuCargoUnqueue.visible := false;
	self.mnuCargoLCL.visible := false;
	self.mnuCargoRemarks.visible := false;
	self.mnuCargoSetGrade.visible := false;
	self.mnuTaskAdd.visible := false;
	self.mnuTaskComplete.visible := false;
	self.mnuTaskRemove.visible := false;
	self.mnuCargoTaskAdd.visible := false;	//07 Oct 2015	NDL	Par 37011
	self.mnuCargoTaskComplete.visible := false;	//07 Oct 2015	NDL	Par 37011
	self.mnuCargoTaskRemove.visible := false;	//07 Oct 2015	NDL	Par 37011
	self.mnuCargoTaskRemarks.visible := false;	//07 Oct 2015	NDL	Par 37011
	self.mnuStops.visible := false;
		
	self.mnuTrainEnquiry.visible := false;
	self.mnuWagonEnquiry.visible := false;
	self.mnuWagonConfirm.visible := false;
	self.mnuWagonCC.visible := false;
	self.mnuConfirmWagonOut.visible := false;
	self.mnuUnconfirmWagonOut.visible := false;
	self.mnuWagonEdit.visible := false;
	self.mnuWagonDelete.visible := false;
	self.mnuWagonTwistlock.visible := false;
	self.mnuTwistNA.visible := true;
	self.mnuTwistAvail.visible := true;
	self.mnuTwistLocked.visible := false;
	self.mnuTwistUp.visible := true;
	self.mnuInTransitNO.visible := false; //24 July 2009 NDL
	self.mnuInTransit.visible := false;	//24 July 2009 NDL
	self.mnuRemColour.visible := false;	//27 July 2009 NDL
	
	self.mnuClearRailLine.visible := self.isDisplayedRailAreas and _gridPoint &lt;&gt; null;

	if self.mnuClearRailLine.visible then
		self.mnuClearRailLine.userObject := _gridPoint.myGridArea.YRD_WagonArea.myRailLine.myRailArea;
	endif;
	
	self.doBuildMnuZoom();

	// always visible
	self.mnuToggleToolbar.visible := true;
	self.mnuToggleLegend.visible := true;
	self.mnuToggleMacro.visible := true;

	self.mnuMove.visible := false;		//
	self.mnuDisplay.visible := false;	// sgp 29 July 2003 : never used ???
	self.mnuOther.visible := false;		//
	
	if _gridPoint &lt;&gt; null then
		ti := _gridPoint.getTI(_x,_y);
	endif;

	if self.isDisplayedRailAreas and ( _gridPoint = null or self.myCurrentLocation = null ) then
		self.doBuildMenuNullWagon(self.myCurrentGridAreaFrame, _x, _y);		

	elseif ti = null then
		// display wagon menu options if clicked any part of the wagon except the cargo
		if _gridPoint &lt;&gt; null and _gridPoint.myLocationsController &lt;&gt; null then
			theWagon := _gridPoint.myLocationsController.CM_WagonController.myWagon;
		endif;
		self.doBuildMenuWagon(theWagon);
		if _gridPoint &lt;&gt; null and _gridPoint.isKindOf(YRD_WagonBody) then
			self.doBuildMenuWgnBody(_gridPoint.YRD_WagonBody);
		endif;
		
	else
		self.doBuildMenuCargo(ti);
	endif;
	
	if (mnuCargo.visible or mnuWagonConfirm.visible or mnuWagonEdit.visible or
			mnuWagonDelete.visible or mnuWagonEnquiry.visible) and
			(mnuZoomSub.visible or mnuToggleToolbar.visible or
			mnuToggleLegend.visible or mnuToggleMacro.visible) then
		mnuGridContextSep.visible := true;
	else
		mnuGridContextSep.visible := false;
	endif;
	
	mnuClearSep.visible := self.mnuClearRailLine.visible or self.mnuTrainEnquiry.visible;

	self.popupMenu(self.mnuGridAreaContext, _x, _y);
end;</source>
        <Parameter name="_gridPoint" type="CMUI_GridPoint" usage="input"/>
        <Parameter name="_x" type="Integer"/>
        <Parameter name="_y" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setMoveMode" id="dd1c87bb-4519-4a2f-98f1-44b17d588986">
        <updating/>
        <source>setMoveMode(_mode : Integer) updating;
// ---------------------------------------------------------------------------
// Created:     June 2009 - form cloned from YRD_RailOpsForm and YRD_GridAreasForm
//
// Purpose:		
//
// Parameters:  
//
// Returns:     
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 23/06/2009	consw1		PAR 19913 - SFW1067 Rail Simplifications
// ---------------------------------------------------------------------------
vars
	dockBar : YRD_RailDockBar;
	obj : Object;
begin

	self.moveModeForm := _mode;
	
	foreach obj in self.allGridAreaDockBars do
		dockBar := obj.YRD_RailDockBar;
		dockBar.mySDF.moveMode := _mode;
		if dockBar.visible then
			dockBar.mySDF.drawSelf();
		endif;
	endforeach;
end;</source>
        <Parameter name="_mode" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setMyCurrentSDF" id="4933f577-af9c-4176-ac33-fac940964c7a">
        <updating/>
        <source>setMyCurrentSDF(_sdf : CMUI_ScrollableDrawingFrame input) updating;
// ---------------------------------------------------------------------------
// Created:     June 2009
//
// Purpose:		
//
// Parameters:  
//
// Returns:     
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 22/06/2009	consw1		PAR 19913 - SFW1067 Rail Simplifications
// ---------------------------------------------------------------------------

vars

begin
	if self.myCurrentSDF = _sdf then
		return;
	endif;
	
	if self.myCurrentSDF &lt;&gt; null then
		self.myCurrentSDF.changeBackColor(self.myTerminal.getConfig(DefYardBackColUnselected).Integer);
	endif;

	self.myCurrentSDF := _sdf;

	if self.myCurrentSDF &lt;&gt; null then
		self.myCurrentSDF.changeBackColor(self.myTerminal.getConfig(DefYardBackColSelected).Integer);
	endif;

	self.myCurrentWagon := null;
	self.myCurrentTrackedItem := null;
	self.myCurrentLocation := null;
	self.myCurrentRailLine := null;

epilog

end;</source>
        <Parameter name="_sdf" type="CMUI_ScrollableDrawingFrame" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setNavigator" id="05c6b5a9-bed2-4d5f-b281-3c8628fe8db0">
        <updating/>
        <source>setNavigator() updating;
// ---------------------------------------------------------------------------
// Created:     June 2009 - form cloned from YRD_RailOpsForm and YRD_GridAreasForm
//
// Purpose:     
//
// Parameters:  
//
// Returns:     
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 17/06/2009	consw1		PAR 19913 - SFW1067 Rail Simplifications
// ---------------------------------------------------------------------------

vars
	gridAreaDockBar : Object;
	lNavString : String;
	railArea : CM_TerminalArea;
	train : CM_Train;

begin
	self.mousePointer := Window.MousePointer_HourGlass;
	
	if self.isDisplayedTrains then
		if self.outwardsTrain then
			lNavString := app.getErrorString(Outwards_train);//"Outwards Train";
		else
			lNavString := app.getErrorString(Inwards_train);//"Inwards Train";
		endif;
		foreach train in self.allTrains reversed do
			lNavString := train.code &amp; ", " &amp; lNavString;
		endforeach;
	elseif self.isDisplayedRailAreas then
		lNavString := app.getErrorString(CM_Rail_Area);//"Rail Area"; 
		foreach railArea in self.allRailAreas reversed do
			lNavString := railArea.id &amp; ", " &amp; lNavString;
		endforeach;
//	else
//		lNavString := "Rail Planning"; 
	endif;
	
	if lNavString.trimBlanks &lt;&gt; null then
		lNavString := lNavString &amp; " - ";
	endif;
	
	if self.isDisplayedTrains then
		lNavString := lNavString &amp; app.getErrorString(Rail_planning);
	else
		lNavString := lNavString &amp; app.getErrorString(Actual).toUpper();
	endif;
			
	lNavString := lNavString &amp; ", " &amp; self.myTerminal.code;
	
	// Update the navigator
	self.setNavigatorHeading(lNavString); 

	self.caption := lNavString;

epilog
	self.mousePointer := Window.MousePointer_Default;
end;</source>
    </JadeMethod>
    <JadeMethod name="setStatusBarCaption" id="c463293a-c113-48b9-8973-5883e16ef0f3">
