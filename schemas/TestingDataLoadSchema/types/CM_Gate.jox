<Class name="CM_Gate">
    <JadeMethod name="pxyAddNewGateAreaUT" id="5cd281f9-6648-4ea1-96c0-3bca31298cfb">
        <updating/>
        <source>pxyAddNewGateAreaUT(_id , _comment:String; _areaType :Integer; _in, _out :Boolean; _lanes: Integer; _activeLanes : String):CM_GateArea updating;

// 06/11/2017	jlgmh5		Portschema method is missing a parameter so adding at this level for autmoated tests

vars
	pxyGateArea		: CM_GateArea;
	pxyUsage		: CM_GateAreaUsage;
	count			: Integer;
	lc				: CM_LaneController;
	laneCapacityArray : IntegerArray;
	activeLanesArray	: BooleanArray;
	tempStr				: String;
	tokens				: StringArray;
	setLaneTo			: Boolean;
	
begin

	self.raiseExceptionIfNotTransient (method);
	
	// create gate area
	create pxyGateArea transient;
	
	pxyGateArea.setProxy (_id, _comment, self.myTerminal,_areaType, _in, _out, _lanes);	// 06/11/2017 jlgmh5 _lanes parameter
   	
	if _lanes = 0 then
		if not pxyGateArea.pxyHasLanesDefined then
			pxyGateArea.pxyCreateNewLane (true);
			pxyGateArea.pxyCreateNewLane (false);
		endif;
	elseif _lanes &gt; 0 then
	
		/*
		if self.opts.includesKey("laneCapacities") then						// 17/02/2016 cnwns1
			laneCapacityArray := self.opts.intArray("laneCapacities");
			self.assertEqualMsg(_laneCount, laneCapacityArray.size, "Lane Capticity (" &amp; laneCapacityArray.size.String &amp; 
				") is not the same size as lane count (" &amp; _laneCount.String &amp; ").");
		endif;
		*/
		
		// get the active lanes in and out
		create activeLanesArray transient;
		
		if _activeLanes &lt;&gt; null then
			create tokens transient;
			_activeLanes.getTokensForDelimiter(",", tokens);
			foreach tempStr in tokens do
				activeLanesArray.add(tempStr.Boolean);
			endforeach;
		endif;
		
		setLaneTo := true;
				
		foreach count in 1 to _lanes step 1 do
			
			//pxyGateArea.pxyCreateNewLane (true);
			
			if activeLanesArray = null or activeLanesArray.isEmpty() then
				if _out then
					setLaneTo := false;
				endif;
			else
				setLaneTo := activeLanesArray[count].Boolean;
			endif;
			pxyGateArea.pxyCreateNewLane(setLaneTo);
			
			/*
			lc := proxy.pxyCreateNewLane (true);
			//lc.setCapacity (_capacity);
			if laneCapacityArray = null or laneCapacityArray.isEmpty() then			// 17/02/2016 cnwns1
				lc.setCapacity (_capacity);
			else
				lc.setCapacity (laneCapacityArray[int]);
			endif;
			*/
		
		endforeach;
		
	endif;
	
	// create a usage for the gate area	
	self.pxyAddGateArea (pxyGateArea, _in, _out);
	
	return pxyGateArea;
epilog

	delete activeLanesArray;
	delete tokens;

end;</source>
        <Parameter name="_id" type="String"/>
        <Parameter name="_comment" type="String"/>
        <Parameter name="_areaType" type="Integer"/>
        <Parameter name="_in" type="Boolean"/>
        <Parameter name="_out" type="Boolean"/>
        <Parameter name="_lanes" type="Integer"/>
        <Parameter name="_activeLanes" type="String"/>
        <ReturnType type="CM_GateArea"/>
    </JadeMethod>
</Class>
