    <JadeMethod name="forceSelection" id="9f3a91d7-cc3d-4f40-8d89-e2038be397ef">
        <updating/>
        <source>forceSelection(control : Control input) updating;
//-----------------------------------------------------------------------
//	Created:	13 April 2006 Lorcan Bolster  (cnwlb1/lorcan)
//-----------------------------------------------------------------------
vars
	rowFrm : CMUI_RowFrameGCBOLItem;
begin
	// 25/5/2006 Lorcan Scroll row if gone off screen
	if control.parent.isKindOf(CMUI_RowFrameGCBOLItem) then
		rowFrm :=  control.parent.CMUI_RowFrameGCBOLItem;
		rowFrm.handleInputDisplayFrmClick(control.parent.CMUI_RowFrameGCBOLItem.frmInput);
		if control.top + rowFrm.top + rowFrm.myScrollableFrame.myScrollingFrame.top &gt;=  rowFrm.myScrollableFrame.height - 5 then
			rowFrm.myScrollableFrame.scrollTo (0,rowFrm.top.Integer - rowFrm.height.Integer + control.height.Integer);
		endif;
	endif;
	
epilog

end;</source>
        <Parameter name="control" type="Control" usage="input"/>
    </JadeMethod>
    <JadeMethod name="initForm" id="6123d209-7041-4893-9bf4-4a9b818dcd81">
        <updating/>
        <source>initForm()updating;
// ---------------------------------------------------------------------------
// Created:     31 January 2006	cnwhjg1
//
// Purpose:     
// ----------   ----------  --------------------------------------------------
vars
	man : CM_Manifest;
begin

	self.frmRowScroll.autoRedraw := true;
	self.frmRowFrameGCBOL.autoRedraw := true;
	self.frmScrolling.autoRedraw := true;
	self.frmScrolling.width := 800;
	
	self.frmRowScroll.setMasterRowFrame(self.frmRowFrameGCBOL);
	self.frmRowScroll.setPictures(picOpen.picture, picClose.picture);
	self.frmRowScroll.setScrollingFrame(self.frmScrolling);
	self.frmRowScroll.labels := Frame.ScrollBars_None;
	self.frmRowScroll.scrollBars := Frame.ScrollBar_Vertical;

	self.cmbLoadPort.myAssistant := self.myAssistant;


	//self.toolbarStyle := self.ToolbarStyle_ShowNoHide;
	//self.showToolbar := true;
	self.grpHeader.backColor := self.backColor;
	self.loadCombos();
	
	if self.mode = self.Mode_Edit then // must have been set on form load
		self.myPxyBOL := app.createUpdateProxy(self.myCurrentBOL).CM_BOLIn;
		self.setControlsFromBOL(self.myPxyBOL);
	else
		// add a blank row for the first cargo item
		self.addScrollRow(null);
	endif;
	self.autoRedraw := true;


end;</source>
    </JadeMethod>
    <JadeMethod name="keyDown" id="b00376d5-eaa3-4381-ad0a-3801ca5a1186">
        <controlMethod name="Form::keyDown"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>keyDown(keyCode: Integer io; shift: Integer) updating;
// ---------------------------------------------------------------------------
// Created:     17 May 2006 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	theActiveControl	: Control;
	
begin
	if keyCode = J_key_Tab then

		theActiveControl := app.activeControl;

		if theActiveControl.parent.isKindOf(CM_EntryTable) then
			theActiveControl := theActiveControl.parent.CM_EntryTable;
		endif;

		if theActiveControl.parent.isKindOf(CMUI_RowFrameGCBOLItem) then
			theActiveControl.parent.CMUI_RowFrameGCBOLItem.handleFormKeyDown(theActiveControl, keyCode, shift);
		endif;

		if theActiveControl.isKindOf(CM_EntryTable) then
			theActiveControl.CM_EntryTable.handleTableTab(shift);
		endif;

	endif;
	
	inheritMethod(keyCode, shift);
end;</source>
        <Parameter name="keyCode" type="Integer" usage="io"/>
        <Parameter name="shift" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="loadCargoTypesCombo" id="fa02aa43-a947-4869-8d74-ef3b32989712">
        <source>loadCargoTypesCombo(_cmb: CMUI_ComboBox);
// ---------------------------------------------------------------------------
// Created:     10 February 2006	cnwhjg1
//
// Purpose:     
// ----------   ----------  --------------------------------------------------
// 30 Sep 2008	consw1		Par 17090 Replace app.getMyTerminal with self.myTerminal
// 07 May 2020	jlgdap1		TFS 49252 CPL Cargo Types not showing in System Admin

vars
	cargoTypeArray,
	tmpCargoTypeArray	: CM_CargoBOLTypeArray;
	handlingTypeDict	: CM_HandlingTypesByIdDict;
	cargoTypeObj		: CM_CargoType;
	cargoBOLType		: CM_CargoBOLType;
	op					: CM_Operator;
	listPointer			: Integer;
	terminal			: CM_Terminal;
	
begin
	terminal := self.myTerminal;
	if terminal = null then
		terminal := app.getMyTerminalDO_NOT_USE;
	endif;

	//////////CARGO TYPES/////////////////////////////
	create tmpCargoTypeArray transient;
	cargoTypeArray := terminal.allCargoBOLTypes;	
	foreach cargoBOLType in cargoTypeArray where cargoBOLType.id &gt; TI_CargoBOLType_Max do
		//if cargoBOLType.id &lt; TI_CargoBOLType_JMTMax then									// TFS 49252
		if cargoBOLType.id &lt; TI_CargoBOLType_JMTMax or app.myRoot.isClientCentrePort then	// TFS 49252
			// Added change to take care of behaviour types.
			cargoTypeObj :=	cargoBOLType.CM_CargoType;
			
			
			tmpCargoTypeArray.add(cargoBOLType.CM_CargoType);
			/*
			if (cargoTypeObj.myTIBehaviourType &lt;&gt; null
				and cargoTypeObj.myTIBehaviourType.class = CM_TIBehaviourBreakBulkGeneric)
				or cargoTypeObj.class = CM_BreakBulk then
					tmpCargoTypeArray.add(cargoBOLType.CM_CargoType);
			endif;
			*/
			
		endif;
	endforeach;
	
	cargoTypeObj	:=	null;
	
	if not tmpCargoTypeArray.isEmpty() then
		_cmb.clear();
		
		foreach cargoBOLType in tmpCargoTypeArray do
			listPointer	:=	_cmb.addItem(cargoBOLType.description);
			_cmb.itemObject[listPointer]	:=	cargoBOLType;
//			self.cmbCargoType.itemData[listPointer]		:=	self.LIST_ENTRY_OBJECT;
		endforeach;
	endif;
epilog
	delete tmpCargoTypeArray;
end;</source>
        <Parameter name="_cmb" type="CMUI_ComboBox"/>
    </JadeMethod>
    <JadeMethod name="loadCmbHatch" id="11578822-2e8f-4557-946c-51bb989d769f">
        <source>loadCmbHatch(_cmb: CMUI_ComboBox input);
//----------------------------------------------------------------
//	Created:	06 April 2006	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	voy 		: CM_Voyage;
	voyCenCargo : CM_GeneralCargoVoyageStructure;
	gcLoc		: CM_GeneralCargoController;
	idx			: Integer;
	
begin

	_cmb.clear;
	if self.useShipBlockStack
	and self.myCurrentVoyage &lt;&gt; null
	and self.myCurrentVoyage.myShipBlockStack &lt;&gt; null then
		idx := _cmb.addItem("Ship");
		_cmb.itemObject[idx] := self.myCurrentVoyage.myShipBlockStack;
		_cmb.listObject := self.myCurrentVoyage.myShipBlockStack;
		_cmb.enabled := false;
	else
		_cmb.enabled := true;
		if self.myCurrentVoyage &lt;&gt; null then 
			_cmb.listCollection(self.myCurrentVoyage.myGeneralCargoVoyage.allLocationsByHatchPlace, true, 0);
		endif;
	endif;
		
end;</source>
        <Parameter name="_cmb" type="CMUI_ComboBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="loadCombos" id="d9b550a6-c35d-427d-bc9e-728ff498fa67">
        <updating/>
        <source>loadCombos()updating;
// ---------------------------------------------------------------------------
// Created:     07 February 2006	cnwhjg1
//
// Purpose:     
// ----------   ----------  --------------------------------------------------
vars
	voy : CM_Voyage;
begin
	if self.myCurrentVoyage &lt;&gt; null then 
		voy := self.myCurrentVoyage;
			
		self.cmbOperator.setObjectAndVoyage(null,voy);

		self.caption := 'Create BOL for Voyage ' &amp; voy.getId;
		
	endif;
		
end;</source>
    </JadeMethod>
    <JadeMethod name="setCMIFObj" id="d4b6dfaf-7cb5-433e-98fb-939db0667d35">
        <updating/>
        <source>setCMIFObj(_intFaceBOL : CMIF_BOLIn input) updating;
// ---------------------------------------------------------------------------
// Created:     09 February 2006	cnwhjg1
//
// Purpose:     
// ----------   ----------  --------------------------------------------------
vars
	operator		: CM_Operator;
	voyage			: CM_GeneralCargoVoyageStructure;
	hatch 	: Integer;
	strCode,
	idStr			: String;
begin

	voyage := self.myCurrentVoyage.myGeneralCargoVoyage;

	if self.cmbOperator.myObject &lt;&gt; null then 
		operator := self.cmbOperator.myObject.CM_Operator;
	endif;

	_intFaceBOL.myOperator := operator;
	if operator &lt;&gt; null then 
		_intFaceBOL.operatorCode := 	operator.code;
	endif;
	if self.cmbLoadPort.myObject &lt;&gt; null then 
		strCode := self.cmbLoadPort.myObject.CM_Port.code; 
	endif;
	
	if self.cmbConsignee.myObject &lt;&gt; null then 
		_intFaceBOL.consigneeCode := self.cmbConsignee.myObject.CM_ConsigneeConsignor.code;
	endif; 

	if self.cmbNotifyParty.myObject &lt;&gt; null then 
		_intFaceBOL.notifyPartyCode := self.cmbNotifyParty.myObject.CM_ConsigneeConsignor.code;
	endif; 
	
	_intFaceBOL.loadPortCode := strCode;
	_intFaceBOL.bolNumber := self.txtBOLNum.text;
	_intFaceBOL.myTerminal := self.myTerminal;
	_intFaceBOL.bolType := BOLType_GeneralBillOfLading;

	//	_intFaceBOL.numItems := 	0;	// this gets set correctly later


	_intFaceBOL.transportMode := TI_TRANSMODE_SHIP;
	//_intFaceBOL.myPlannedLocation := null;	// this is not set as could be in several places
	_intFaceBOL.myVoyage := self.myCurrentVoyage;
	_intFaceBOL.remarks := self.txtRemarks.text;
	_intFaceBOL.purchaseOrder := self.txtPurchaseOrder.text;
	if _intFaceBOL.mySubTerminal = null then
		_intFaceBOL.setSubTerminalDefault(); 
	endif;
	
end;</source>
        <Parameter name="_intFaceBOL" type="CMIF_BOLIn" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setControlsFromBOL" id="b91c1349-0e92-4355-affa-5eeaae78f7a1">
        <updating/>
        <source>setControlsFromBOL(_bol : CM_BOLIn) updating;
// ---------------------------------------------------------------------------
// Created:     09 February 2006	cnwhjg1
//
// Purpose:     
// ----------   ----------  --------------------------------------------------
vars
	port : CM_Port;
	con : CM_ConsigneeConsignor;
	intFaceAttach	: CMIF_InOutAttachment;
	ti : CM_TrackedItem;
begin
	
	self.cmbOperator.setObject(_bol.myOperator);
	
	//port := app.myRoot.allPorts[_bol.loadPortCode];
	port := app.myRoot.allPorts[_bol.loadPortCode];
	self.cmbLoadPort.setObject(port);
	self.txtBOLNum.text := 	_bol.number;
	self.txtRemarks.text := _bol.remarks;
	self.txtQuantity.text := _bol.numItems.String;

	con := app.myRoot.allConsigneeConsignors[_bol.consignee];
	self.cmbConsignee.setObject(con);
	
	con := app.myRoot.allConsigneeConsignors[_bol.notifyParty];
	self.cmbNotifyParty.setObject(con);

	foreach ti in _bol.allTrackedItems do

		create intFaceAttach transient;
		//intFaceAttach.set(self.myTerminal, ti.cargoType, ti.id, ti.getISOType, ti.weight);
		intFaceAttach.setFromTI(ti, self.myTerminal);
		
		//intFaceAttach.setMasterItem();
		intFaceAttach.setMyProxyTrackedItem(app.createUpdateProxy(ti).CM_TrackedItem);

		self.addScrollRow(intFaceAttach);

/*
		self.cmbCargoType.listObject := ti.myCargoType;
//		self.doComboCargoClick(); // to set products
		self.cmbProduct.setObject(ti.myProduct);
		self.txtMarks.text := ti.mark;
		self.txtMarksNo.text := ti.markNumber;
		self.txtDescription.text := ti.description;
		self.txtWeight.text := 	ti.weight.String;
		self.txtVolume.text := 	ti.volume.roundedTo(2).String;
*/
	endforeach;	

	
end;</source>
        <Parameter name="_bol" type="CM_BOLIn"/>
    </JadeMethod>
