        <Parameter name="pIORake" type="CM_RailJSInOutRake"/>
        <Parameter name="pDoAutoPlan" type="Boolean"/>
        <Parameter name="pType" type="Integer"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
