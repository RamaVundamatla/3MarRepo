    <JadeMethod name="getCargoItem" id="b6960fa5-44e3-4213-8e2e-a35796e4f301">
        <source>getCargoItem(_ediTi : CM_EDITrackedItem) : CM_TrackedItem;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 July 2023	navra1	Initial creation

*/

vars
	ti : CM_TrackedItem;
begin
	//First look up in the TI_STATE_NORMAL list to see if its in the yard, its much smaller than looking at TI_STATE_UNDEFINED
	ti := app.myPassport.myTerminal.lookupTrackedItem(_ediTi.id, null, TI_STATE_NORMAL, null, false);
	if ti &lt;&gt; null then
		if not ti.isCargoGroupItem then
			return ti;
		endif;		
	else
		ti := app.myPassport.myTerminal.lookupTrackedItem(_ediTi.id, null, TI_STATE_UNDEFINED, null, false);
		if not ti.isCargoGroupItem then
			return ti;
		endif;		
	endif;
	
	return null;
epilog

end;</source>
        <Parameter name="_ediTi" type="CM_EDITrackedItem"/>
        <ReturnType type="CM_TrackedItem"/>
    </JadeMethod>
