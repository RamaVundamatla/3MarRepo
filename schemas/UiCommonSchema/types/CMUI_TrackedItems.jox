    <JadeMethod name="doBtnRetrieve" id="a8d274eb-80e1-4323-8bf6-08bc81bd1c25">
        <updating/>
        <source>doBtnRetrieve() updating;
// ---------------------------------------------------------------------------
// Created:		November 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	anObject : Object;
	idx, theRow : Integer;
begin
	app.mousePointer := Window.MousePointer_HourGlass;
	
	self.isEmptyOnly := self.chkEmpties.value; 
	self.includeOnShip := self.chkIncludeOnShip.value;
	
	//self.checkISOGroup :=self.chkISOGroup.value;
	//al other filter criteria attributes set on combo click methods
	self.doFilter();
	
	foreach idx in 2 to self.tblList.rows do
		anObject := self.tblList.accessRow(idx).itemObject;
		theRow := 0;
		
		self.tblListAll.findObjectInRow(anObject, theRow);
	
		if theRow &gt; 0 then
			self.tblListAll.removeItem(theRow);
		endif;
	 endforeach;
	 

epilog
	app.mousePointer := Window.MousePointer_Default;

end;</source>
    </JadeMethod>
    <JadeMethod name="doComboVoyageBuild" id="2869a107-d525-473f-a364-84f21cce8fc1">
        <source>doComboVoyageBuild();
// ---------------------------------------------------------------------------
// Created:		November 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	theCombo : CMUI_ComboBox;
	aVoyage : CM_Voyage;
	theVoyages : CM_VoyageSet;
begin

	create theVoyages transient;
	
	theCombo := self.cmbVoyage;
	theCombo.clear;
	// we don't care if its cellular or not
	self.myTerminal.getAllCurrentCellularVoyages(theVoyages,true, false);
	
	foreach aVoyage in theVoyages do
		theCombo.addItemObject(aVoyage.code,aVoyage);
	endforeach;

	theCombo.sorted := false;
	
	theCombo.addItemAt("All",1)	;
	
	if self.myVoyage &lt;&gt; null then
	// ### PAR 10264. is possible that the voyage has departed and so is not in the combo list.
		if theCombo.findObject(self.myVoyage) = -1 then 
			theCombo.addItemObject(self.myVoyage.code,self.myVoyage);
		endif;
	endif;
	
	theCombo.listObject := self.myVoyage;
		
epilog
	delete theVoyages;
end;</source>
    </JadeMethod>
    <JadeMethod name="doFilter" id="44e421fa-ce91-4427-bd17-3d618066e222">
        <updating/>
        <source>doFilter() updating;
/*
----------   ----------  --------------------------------------------------
Created:	26 September 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	
begin
	self.tblListAll.rows := self.tblListAll.fixedRows;
	self.tblListAll.allSelectedObjects.clear();
	self.setFilterAttributes();
	
	if self.myVoyage &lt;&gt; null then
		if 	self.includeOnShip then
			self.doFilterDict(self.myVoyage.allOnshipTIsByCargoTypeId, self.tblListAll);
		endif;
		self.doFilterDict(self.myVoyage.allOnsiteTIsByCargoTypeId, self.tblListAll);
	
	else
		self.doFilterDict(self.myTerminal.allOnsiteTIsByCargoTypeId, self.tblListAll);
	endif;
	
epilog
	
	
end;

</source>
    </JadeMethod>
    <JadeMethod name="doFilterDict" id="c1f32e9d-8574-434d-ba5b-5fb39b00f1b5">
        <source>doFilterDict(_dict			: CM_TIByCargoTypeIdDict;
			_tbl 			: CM_BaseTable input) protected;
/*
----------   ----------  --------------------------------------------------
Created:	26 September 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
14/07/2025		naviv1	MTN-35226	MTN - Usage of Iterator.getCurrentKeys  		
----------   ----------  --------------------------------------------------
*/
vars
	ti			: CM_TrackedItem;
	iter		: Iterator;
	idStrKey,
	str			: String;
	cargoType,
	cargoTypeKey	: Integer;
	
begin
	
	beginLoad;
	cargoType := self.currentCargoType;
	iter := _dict.createIterator;
	_dict.startKeyGeq(cargoType, null, iter);
	while iter.next(ti) do
		iter.getCurrentKeys(cargoTypeKey, idStrKey);  //MTN-35226
		if cargoType &lt;&gt; null and cargoTypeKey &lt;&gt; cargoType then
			break;
		endif;
		
		if not self.doFilterTI(ti) then
			continue;
		endif;
		
		str := ti.id &amp; Tab &amp;
			   ti.cargoTypeDescr &amp; Tab &amp;
			   ti.isoTypeGroup &amp; Tab &amp;
			   ti.getISOType &amp; Tab &amp;
			   ti.voyageCode &amp; Tab &amp;
			   ti.operatorCode;
		_tbl.accessRow(_tbl.addItem(str)).itemObject := ti;
	endwhile;
	

epilog
	endLoad;
	delete iter;
end;

</source>
        <access>protected</access>
        <Parameter name="_dict" type="CM_TIByCargoTypeIdDict"/>
        <Parameter name="_tbl" type="CM_BaseTable" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doFilterDictForCargoNums" id="6b236137-51b5-459c-b256-f90903cb9352">
        <source>doFilterDictForCargoNums(	_dict			: CM_TIByCargoTypeIdDict;
							_cargoNums		: StringArray input;
							_allFoundTIs	: CM_TIArray input;
							_tbl 			: CM_BaseTable input) protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
24 November 2008	cnwer1	Initial creation

*/

vars

	ti			: CM_TrackedItem;
	iter		: Iterator;
	idStrKey,
	str	,
	cargoNum: String;
	cargoType,
	cargoTypeKey	: Integer;
	notFoundNums : StringArray;
begin
	create notFoundNums transient;
	//beginLoad;
	cargoType := self.currentCargoType;
	iter := _cargoNums.createIterator;
	while iter.next(cargoNum) do
		ti			:=_dict.getAtKey(cargoType,cargoNum);
		if ti = null then
			notFoundNums.add(cargoNum);
			continue;
		endif;
		
		if not self.doFilterTI(ti) then
			notFoundNums.add(cargoNum);
			continue;
		endif;
		
		_allFoundTIs.add(ti);
	endwhile;
	
	_cargoNums.clear;
	notFoundNums.copy(_cargoNums);
	
epilog
	delete notFoundNums;
	delete iter;

end;</source>
        <access>protected</access>
        <Parameter name="_dict" type="CM_TIByCargoTypeIdDict"/>
        <Parameter name="_cargoNums" type="StringArray" usage="input"/>
        <Parameter name="_allFoundTIs" type="CM_TIArray" usage="input"/>
        <Parameter name="_tbl" type="CM_BaseTable" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doFilterTI" id="a3836235-473e-4171-84fd-1a1106a23207">
        <source>doFilterTI(_ti : CM_TrackedItem) : Boolean;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
19 November 2008	cnwer1	Initial creation

*/

vars
	
begin
	
	//th2 added 02/08/2007 for PAR 14505
		if self.myISOType &lt;&gt; null then
			if _ti.getISOType &lt;&gt; self.myISOType.code then
				if self.myIsoTypeGroup &lt;&gt; null then
					if not _ti.isoTypeIsSameGroupAs(self.myISOType) then
						return false;
					endif;
				else
					return false;
				endif;
			endif;
		endif;
		
		
		if self.myOperator &lt;&gt; null then
			if self.myOperator.code.trimBlanks &lt;&gt; _ti.operatorCode.trimBlanks then
				if self.myOperatorGroup &lt;&gt; null then
					if (not self.myOperatorGroup.allOperators.includes(_ti.myOperator)) then
						return false;
					endif;
				else
					return false;
				endif;
			endif;
		endif;
		
		if self.myIMEXStatus &lt;&gt; null and _ti.getImExStatus() &lt;&gt; self.myIMEXStatus.code then
			return false;
		endif;
		
		if self.myFiltDestination &lt;&gt; null and _ti.destinationPort &lt;&gt; self.myFiltDestination.code then
			return false;
		endif;
		
		if self.myFiltFreightFwdr &lt;&gt; null and _ti.freightForwarderCode &lt;&gt; self.myFiltFreightFwdr.code then
			return false;
		endif;
		
		//th2 for PAR 14847
		//th2 PAR 14915 - consignee match if null
		//th2 PAR 14915 - 08/10/07 - original change backed out as requested
		if self.myFiltConsignee &lt;&gt; null and _ti.consignee &lt;&gt; self.myFiltConsignee.code then
			return false;
		endif;
		
		if _ti.cargoType = TI_CargoType_Container then
			if self.isEmptyOnly and _ti.CM_Container.isFull then
				return false;
			endif;
			if not self.allMTGrades.isEmpty then
				if not self.allMTGrades.includes(_ti.CM_Container.availabilityGrade) then
					return false;
				endif;
			endif;
		endif;
		
		//PAR 4666 dont display allocated ti's
		if _ti.isHeldForRelease or _ti.releaseRequest &lt;&gt; null then
			return false;
		endif;
		
		return true;
epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doOK" id="e4836fcd-c8a5-4575-993f-d3ba11ccb11e">
