    <JadeMethod name="doDeleteJob" id="a2ae1ded-9e5e-4cf7-b5b1-cf5fc5b1b31d">
        <updating/>
        <source>doDeleteJob() updating;
// ---------------------------------------------------------------------------
// Created:     28 May 2009 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	result : Integer;
	jobs : CM_JobSet;
	wle : CM_WorkListEntry;
	obj : Object;
	job : CM_Job;	//02 Dec 2020	NDL	TFS 50164
	wagon : CM_Wagon;	//02 Dec 2020	NDL	TFS 50164
	wagons : CM_WagonSet;	//02 Dec 2020	NDL	TFS 50164
	wc : CM_WagonController;	//02 Dec 2020	NDL	TFS 50164
	lc : CM_LocationsController;	//02 Dec 2020	NDL	TFS 50164
	allWles : CM_WLESet;	//03 Dec 2020	NDL	TFS 50164
begin

	if self.myCurrentJob = null then
		return;	
	endif;

	app.mousePointer := MousePointer_HourGlass;	

	create jobs transient;
	create wagons transient;	//02 Dec 2020	NDL	TFS 50164
	create allWles transient;	//03 Dec 2020	NDL	TFS 50164
	
	foreach obj in self.tblWorkEntries.allSelectedObjects discreteLock do
		wle := obj.CM_WorkListEntry;
		if not jobs.includes(wle.job) then
			jobs.add(wle.job);
		endif;
	endforeach;
		
	//03 Dec 2020	NDL	TFS 50164
	foreach job in jobs do
		//there can be multiple wles across multiple wagons for a single BB or Bulk job
		foreach wle in job.workListEntries do
			allWles.addNoDuplicates( wle, false );	
		endforeach;
	endforeach;
	foreach wle in allWles do
		if wle.getSourceLocation &lt;&gt; null and wle.getSourceLocation.isWagon then
			wc := wle.getSourceLocation.CM_WagonController;
		elseif wle.getTargetLocation &lt;&gt; null and wle.getTargetLocation.isWagon then
			wc := wle.getTargetLocation.CM_WagonController;
		else
			wc := null;
		endif;
		if wc &lt;&gt; null then
			wagon := wc.myWagon;
			if wagon &lt;&gt; null then
				wagons.addNoDuplicates( wagon, false );
			endif;
		elseif wle.isRail then
			foreach lc in wle.CM_YardWLE.allLocationControllers where lc.isWagon do
				wc := lc.CM_WagonController;
				wagon := wc.myWagon;
				if wagon &lt;&gt; null then
					wagons.addNoDuplicates( wagon, false );
				endif;
			endforeach;
		endif;	
	endforeach;

	while true do
		app.myTrxDA.trxDeleteJobs(jobs, app.myPassport);
		if app.myPassport.trxCompletedOK then
			// Clear errors/warnings from form and err/warnings window
			self.clearErrorWarnings();
			break;
		else
			result := app.showErrorWarningDialog(app.getErrorString(ERASE_JOB_TXT), app.myPassport,  ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   result = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
		endif;
		break;
	endwhile;

	self.myCurrentJob := null;
	
	//02 Dec 2020	NDL	TFS 50164 - refresh the graphic
	foreach wagon in wagons do
		self.updateWagonArea( wagon, Wagon_Update_Event );
	endforeach;

epilog 
	delete jobs;
	delete wagons;
	app.mousePointer := MousePointer_Default;	


end;</source>
    </JadeMethod>
    <JadeMethod name="doDeleteWLE" id="9c3ce7a2-186d-4bc7-9cca-d65a48ff808b">
        <updating/>
        <source>doDeleteWLE(menuItem: MenuItem) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
18 November 2009	cnwndl1	Initial creation

*/

vars

	obj : Object;
	wle : CM_WorkListEntry;
	result : Integer;
	
begin

	obj := menuItem.userObject;
	if obj &lt;&gt; null and CM_YardWLE.hasInstance(obj) then
		wle := obj.CM_WorkListEntry;
	endif;
	
	if wle &lt;&gt; null then
	
		while true do
		
			app.myTrxDA.trxDeleteJobEntry(wle,null,  app.myPassport);// cnwrd1 par 22624 3.5.2010 
			if app.myPassport.trxCompletedOK then
				// Clear errors/warnings from form and err/warnings window
				self.clearErrorWarnings();
				break;
			else
				result := app.showErrorWarningDialog(app.getErrorString(Delete_selected_entry), app.myPassport, ErrWarnMode_Delete + ErrWarnMode_CanAckWarnings);
				if app.myPassport.noErrors and
				   result = IDOK then
					// there must have just been warnings that the user has acknoledged so ..
					app.myPassport.warningsAcknowledged	:= true;
					continue;
				endif;
				self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
			endif;
			break;
			
		endwhile;
	
	endif;
	

epilog

end;</source>
        <Parameter name="menuItem" type="MenuItem"/>
    </JadeMethod>
    <JadeMethod name="doDragOverLstJobs" id="75581a62-2060-490d-91ca-b8b4cc37ceac">
        <updating/>
        <source>doDragOverLstJobs(listbox: CM_QueueListBox input; win: Window input; x: Real; y: Real; state: Integer) updating;
//--------------------------------------------------
// Created:	12 February 2004 By: cnwgd1
//--------------------------------------------------
vars
	lstCount,
	dragOverIdx,
	idx			: Integer;
begin
	dragOverIdx := listbox.dragOverIndex;
	
	if dragOverIdx &lt; 1 then
		return;
	endif;
	
	lstCount := listbox.listCount;
	
	foreach idx in 1 to lstCount do
		listbox.itemSelected[idx] := (idx = dragOverIdx);
	endforeach;
	//th2 - changed to the above to avoid the truely insane code that was being called below
	//listbox.doDragOverSelect(x,y, self.origYPos);
end;</source>
        <Parameter name="listbox" type="CM_QueueListBox" usage="input"/>
        <Parameter name="win" type="Window" usage="input"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
        <Parameter name="state" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="doDragOverLstJobsOld" id="eee82420-83d9-41c3-9086-51dd114651e5">
        <updating/>
        <source>doDragOverLstJobsOld(listbox: CM_QueueListBox input; win: Window input; x: Real; y: Real; state: Integer) updating;
//--------------------------------------------------
// Created:	12 February 2004 By: cnwgd1
//--------------------------------------------------
vars

begin
	listbox.doDragOverSelect(x,y, self.origYPos);
end;</source>
        <Parameter name="listbox" type="CM_QueueListBox" usage="input"/>
        <Parameter name="win" type="Window" usage="input"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
        <Parameter name="state" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="doEditWagon" id="da2548b0-f72b-4e49-8178-29dd0adfc24d">
        <source>doEditWagon();
/*
----------   ----------  --------------------------------------------------
Created:	09 November 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	wagonForm : YRD_TrainWagonForm;
	wagon : CM_Wagon;
	trainForWagonCombo : CM_Train;
	mode : Integer;
begin
	wagon := self.myCurrentWagon;
	
	if wagon = null then
		app.msgBox(app.getErrorString(Please_select_wagon), app.getErrorString(No_Wagon_selected), MsgBox_Exclamation_Mark_Icon);
		return;
	endif;
	
	mode := YRD_TrainWagonForm.Mode_Update;
	

	trainForWagonCombo := wagon.myTrainInwards;
	if trainForWagonCombo = null then
		trainForWagonCombo := wagon.myTrainOutwards;
	endif;
	
	app.mousePointer := MousePointer_HourGlass;
	
	wagonForm := app.getForm(YRD_TrainWagonForm.name).YRD_TrainWagonForm;
	if wagonForm = null then
		wagonForm := app.loadForm(YRD_TrainWagonForm, YRD_Assistant, false, false, false, self.myTerminal, self.myMasterMenuAction).YRD_TrainWagonForm;
	endif;
	
	if wagonForm = null then
		return;
	endif;
	
	self.setNavigatorHeading(app.getErrorString(Wagon_maintenance)); 
	wagonForm.setParentForm(self);
	wagonForm.setMyTerminal(self.myTerminal);
	wagonForm.setMyTrainForWagonCombo(trainForWagonCombo);
	wagonForm.initialiseForm(self.myCurrentTrain, wagon, mode);
	wagonForm.show;
		
epilog
	app.mousePointer := MousePointer_Default;
end;





</source>
    </JadeMethod>
    <JadeMethod name="doGridAreaDragDropMulti" id="ba71f886-22b7-4bdc-999a-516fd9ad670b">
        <updating/>
        <source>doGridAreaDragDropMulti(	_win: Window input;
							_wagon: CM_Wagon;
							_moveMode : Integer;
							_theTIs : CM_TIArray input;
							_theDragTI : CM_TrackedItem;
							_x : Real;
							_y : Real
							):Boolean updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
23 August 2011	cnwndl1	Initial creation	Par 28035

*/

vars

	allCargoUNSorted : CM_TIArray;
	allCargoSorted : CM_TIArray;	// Selected cargo to be moved sorted into the outward decking order or equivalent.
	msg : String;
	processedMoves : CM_TIArray;
	targetLocns : CM_LCArray;
	targetLocationStr : String;
	theObj : Object;
	anLC : CM_LocationsController;
	targetTermArea : CM_TerminalArea;
//	sourceTermArea : CM_TerminalArea;
	wagon : CM_Wagon;
	wc : CM_WagonController;
	wagons : CM_WagonArray;

begin

	create allCargoUNSorted transient;
	
	//filter out any cargo with existing moves of this mode
	if not self.gridAreaMultiDragUnsortedFilta(	allCargoUNSorted,	//_allCargoUNSorted : CM_TIArray io;
												_theTIs,	//_theTIs : CM_TIArray input;
												_theDragTI,	//_theDragTI : CM_TrackedItem;
												_moveMode	//_moveMode : Integer
												) then
		return true;
	endif;
	
	
	create targetLocns transient;
	//get the Target Locations  and Target Location name for the messages
	if self.mnuMultiMove.checked then
		// Use the pre-selected targets only, regardless of where the user does the drop.
		create wagons transient;
		self.getSelectedWagons(wagons, null);
		foreach wagon in wagons do
			if targetLocationStr = null then
				targetLocationStr := wagon.id;
			else
				targetLocationStr := targetLocationStr &amp; ", " &amp; wagon.id;
			endif;
			foreach wc in wagon.allLocationsControllersArray do
				if wc.isAvailForMultiMove then
					targetLocns.add( wc );
				endif;
			endforeach;
		endforeach;
		
		if wagons.isEmpty or targetLocns.isEmpty then
			if wagons.isEmpty then
				msg := app.getErrorString1(No_wagons_Selected, self.mnuMultiMove.caption);
			else
				msg := app.getErrorString(None_wagon_locations_avail);
			endif;
			app.msgBox(msg, app.getErrorString(Multi_move), MsgBox_OK_Only);
			return true; 	// Yes returning 'true' is right, we don't want to move any cargo.
							// Returning false would lead to the form trying 
							// to move the first piece of cargo to the drag/drop position.
		endif;
	
	else
		// get the locations for the wagon only at the drop point.
		if _wagon &lt;&gt; null then
			targetLocationStr := _wagon.id;
			foreach wc in _wagon.allLocationsControllersArray do
				if wc.isAvailForMultiMove then
					targetLocns.add( wc );
				endif;
			endforeach;
		endif;
		
	endif;	
	
	create allCargoSorted transient;
	
	// sort the source cargo into the order we want to process it.
	self.gridAreaMultiDragCargoSort( 	_win,	//_win: Window input;
										allCargoUNSorted,	//_allCargoUNSorted : CM_TIArray;
										allCargoSorted	//_allCargoSorted : CM_TIArray io
										);
										
	
	create processedMoves transient;
	return self.myAssistant.doBulkMoveToGridArea(	false,	//_noChargeMove : Boolean;
													null,	//_userAuthorityCode : String;
													_moveMode,	//moveMode : Integer;
													allCargoSorted,	//_allTrackedItems : CM_TIArray;
													targetLocns,	//_targetLocns : CM_LCArray;
													targetLocationStr,	//_targetLocationStr : String;
													processedMoves	//_processedMoves : CM_TIArray io
													);
											

epilog

	delete processedMoves;
	delete targetLocns;
	delete wagons;
	
end;</source>
        <Parameter name="_win" type="Window" usage="input"/>
        <Parameter name="_wagon" type="CM_Wagon"/>
        <Parameter name="_moveMode" type="Integer"/>
        <Parameter name="_theTIs" type="CM_TIArray" usage="input"/>
        <Parameter name="_theDragTI" type="CM_TrackedItem"/>
