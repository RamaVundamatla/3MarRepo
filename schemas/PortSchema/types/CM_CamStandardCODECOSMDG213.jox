    <JadeMethod name="includeVoyage" id="46e53c6c-3f19-4ea2-9897-4539c1937fc5">
        <source>includeVoyage(_camProtocol: CM_CamProtocol; _voyage: CM_Voyage; _trx: CM_Transaction; _camAgent: CM_CamControllerAgent; _logExcluded: Boolean): Boolean protected;

/*****************************************************
Date			Name		TFS#		Description
08 April 2019	jlgns1					Initial creation
8/04/2019 		JLGNS1	ChangeRequest 	39725: JMT - CODECO 00B

****************************************************/
begin
	if _voyage.isBarge then 
		return true;
	else
		return inheritMethod(_camProtocol, _voyage, _trx, _camAgent, _logExcluded);
	endif;
end;</source>
