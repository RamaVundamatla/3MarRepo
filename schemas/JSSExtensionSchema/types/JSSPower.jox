    <JadeMethod name="convertBaseToTarget" id="4a412e59-affe-459d-97d2-56cc1e38f418">
        <source>convertBaseToTarget(pMeasure: Real; pUnitTo: Integer): Real protected;
// --------------------------------------------------------------------------------
// Created:		02 June 2001 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	convertedMeasure	: Real;
	
begin
	if pUnitTo = self.BTU_PER_HOUR then
		convertedMeasure	:=	pMeasure / 0.293071;

	elseif pUnitTo = self.BTU_PER_MINUTE then
		convertedMeasure	:=	pMeasure / 17.584267;
		
	elseif pUnitTo = self.BTU_PER_SECOND then
		convertedMeasure	:=	pMeasure / 1055.056;

	elseif pUnitTo = self.CALORIES_PER_HOUR then
		convertedMeasure	:=	pMeasure / 0.001639;

	elseif pUnitTo = self.CALORIES_PER_MINUTE then
		convertedMeasure	:=	pMeasure / 0.06978;

	elseif pUnitTo = self.CALORIES_PER_SECOND then
		convertedMeasure	:=	pMeasure / 4.1868;

	elseif pUnitTo = self.FT_LB_FORCE_PER_MINIUTE then
		convertedMeasure	:=	pMeasure / 0.022597;

	elseif pUnitTo = self.FT_LB_FORCE_PER_SECOND then
		convertedMeasure	:=	pMeasure / 1.35582;

	elseif pUnitTo = self.GIGAWATTS then
		convertedMeasure	:=	pMeasure / 1000000000;

	elseif pUnitTo = self.HORSEPOWER_ELECTRIC then
		convertedMeasure	:=	pMeasure / 746;

	elseif pUnitTo = self.HORSEPOWER_METRIC then
		convertedMeasure	:=	pMeasure / 735.499;

	elseif pUnitTo = self.JOULES_PER_HOUR then
		convertedMeasure	:=	pMeasure * 3600;

	elseif pUnitTo = self.JOULES_PER_MINUTE then
		convertedMeasure	:=	pMeasure * 60;

	elseif pUnitTo = self.JOULES_PER_SECOND then
		convertedMeasure	:=	pMeasure;

	elseif pUnitTo = self.KG_FORCE_METRES_PER_HOUR then
		convertedMeasure	:=	pMeasure / 0.002724;

	elseif pUnitTo = self.KG_FORCE_METRES_PER_MINUTE then
		convertedMeasure	:=	pMeasure / 0.163444;

	elseif pUnitTo = self.KG_FORCE_METRES_PER_SECOND then
		convertedMeasure	:=	pMeasure / 9.80665;

	elseif pUnitTo = self.KILOCALORIES_PER_HOUR then
		convertedMeasure	:=	pMeasure / 1.163;

	elseif pUnitTo = self.KILOCALORIES_PER_MINUTE then
		convertedMeasure	:=	pMeasure / 69.78;

	elseif pUnitTo = self.KILOWATTS then
		convertedMeasure	:=	pMeasure / 1000;

	elseif pUnitTo = self.MEGAWATTS then
		convertedMeasure	:=	pMeasure / 1000000;

	elseif pUnitTo = self.WATTS then
		convertedMeasure	:=	pMeasure;
		
	else
		JSSException.raise_(JSS_X_03004, "[" &amp; pUnitTo.String &amp; "] is an unknown unit of power to convert to.");

	endif;
epilog
	return convertedMeasure;
end;</source>
        <access>protected</access>
        <Parameter name="pMeasure" type="Real"/>
        <Parameter name="pUnitTo" type="Integer"/>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="convertToBaseUnit" id="71a9a695-aa9b-4211-818e-b4437ec3d193">
        <source>convertToBaseUnit(pUnitFrom: Integer): Real protected;
// --------------------------------------------------------------------------------
// Created:		02 June 2001 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	convertedMeasure	: Real;
	
begin
	if pUnitFrom = self.BTU_PER_HOUR then
		convertedMeasure	:=	self.measure * 0.293071;

	elseif pUnitFrom = self.BTU_PER_MINUTE then
		convertedMeasure	:=	self.measure * 17.584267;
		
	elseif pUnitFrom = self.BTU_PER_SECOND then
		convertedMeasure	:=	self.measure * 1055.056;

	elseif pUnitFrom = self.CALORIES_PER_HOUR then
		convertedMeasure	:=	self.measure * 0.001639;

	elseif pUnitFrom = self.CALORIES_PER_MINUTE then
		convertedMeasure	:=	self.measure * 0.06978;

	elseif pUnitFrom = self.CALORIES_PER_SECOND then
		convertedMeasure	:=	self.measure * 4.1868;

	elseif pUnitFrom = self.FT_LB_FORCE_PER_MINIUTE then
		convertedMeasure	:=	self.measure * 0.022597;

	elseif pUnitFrom = self.FT_LB_FORCE_PER_SECOND then
		convertedMeasure	:=	self.measure * 1.35582;

	elseif pUnitFrom = self.GIGAWATTS then
		convertedMeasure	:=	self.measure * 1000000000;

	elseif pUnitFrom = self.HORSEPOWER_ELECTRIC then
		convertedMeasure	:=	self.measure * 746;

	elseif pUnitFrom = self.HORSEPOWER_METRIC then
		convertedMeasure	:=	self.measure * 735.499;

	elseif pUnitFrom = self.JOULES_PER_HOUR then
		convertedMeasure	:=	self.measure / 3600;

	elseif pUnitFrom = self.JOULES_PER_MINUTE then
		convertedMeasure	:=	self.measure / 60;

	elseif pUnitFrom = self.JOULES_PER_SECOND then
		convertedMeasure	:=	self.measure;

	elseif pUnitFrom = self.KG_FORCE_METRES_PER_HOUR then
		convertedMeasure	:=	self.measure * 0.002724;

	elseif pUnitFrom = self.KG_FORCE_METRES_PER_MINUTE then
		convertedMeasure	:=	self.measure * 0.163444;

	elseif pUnitFrom = self.KG_FORCE_METRES_PER_SECOND then
		convertedMeasure	:=	self.measure * 9.80665;

	elseif pUnitFrom = self.KILOCALORIES_PER_HOUR then
		convertedMeasure	:=	self.measure * 1.163;

	elseif pUnitFrom = self.KILOCALORIES_PER_MINUTE then
		convertedMeasure	:=	self.measure * 69.78;

	elseif pUnitFrom = self.KILOWATTS then
		convertedMeasure	:=	self.measure * 1000;

	elseif pUnitFrom = self.MEGAWATTS then
		convertedMeasure	:=	self.measure * 1000000;

	elseif pUnitFrom = self.WATTS then
		convertedMeasure	:=	self.measure;

	else
		JSSException.raise_(JSS_X_03003, "[" &amp; pUnitFrom.String &amp; "] is an unknown unit of power to convert from.");

	endif;
epilog
	return convertedMeasure;
end;</source>
        <access>protected</access>
        <Parameter name="pUnitFrom" type="Integer"/>
        <ReturnType type="Real"/>
    </JadeMethod>
</Class>
