    <JadeMethod name="clearAllInfo" id="88874aac-af49-48ea-9fbd-2434eef442bf">
        <updating/>
        <source>clearAllInfo() updating, protected;
/*
----------   ----------  --------------------------------------------------
Created:	13 September 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars

begin
	self.clearClonedButtons();
	self.allContainerInfo.purge();
	self.numButtons := 0;
	self.lblJobInfo.caption := 'Waiting for vehicle ID match...';
	self.clearDamage();
	
	self.txtId.text 		:= null;
	self.txtSealCust.text 	:= null;
	self.txtSealOp.text 	:= null;
	self.txtSealShip.text 	:= null;
	self.chkHaz.value 		:= false;
	
	

end;


</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="clearClonedButtons" id="da931a2c-fefc-4840-963a-9adbd27609e3">
        <updating/>
        <source>clearClonedButtons() protected, updating;
/*
----------   ----------  --------------------------------------------------
Created:	24 October 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	obj			: Object;
begin
	foreach obj in self.allClonedControls do
		if (not app.isValidObject(obj)) then
			continue;
		endif;
		
		obj.Control.visible := false;
	endforeach;
	self.allClonedControls.purge();
	self.maxCloneButtons := 1;

end;


</source>
        <access>protected</access>
    </JadeMethod>
