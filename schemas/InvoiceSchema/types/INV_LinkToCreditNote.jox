    <JadeMethod name="translateForm" id="4f800d44-ded1-4a6c-b30c-06a214383cfc">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 28 June 2023 08:38:25.
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0025479, locale);
	//btnClearFilter.translateBubbleHelp(Xlat_0026173, locale);
	btnClose.translateCaption(Xlat_0025480, locale);
	btnLink.translateCaption(Xlat_0025481, locale);
	mnuColumnOrganiser.translateCaption(Xlat_0025482, locale);
	mnuMenuContext.translateCaption(Xlat_0025483, locale);
	//txtFilterBox.translateBubbleHelp(Xlat_0026174, locale);
end;</source>
    </JadeMethod>
