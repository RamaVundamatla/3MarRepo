    <JadeMethod name="doSystemNotification" id="6b8f0c68-ee6d-44fc-af9b-7f64fc2092a9">
        <updating/>
        <source>doSystemNotification(_event: Integer; _delay :CM_Delay; eventTag: Integer) updating;
/*
----------   ----------  --------------------------------------------------
Created:	16 February 2007 By cnwmo1

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
21/08/2008	concms1		par 17731
*/
vars
	filterVoyage	:CM_Voyage;
begin
	if _event = Object_Delete_Event  then
		self.updateObjectInTable(_event, _delay, self.tblData);
		
		if _delay = self.myCurrentDelay then	
			self.myCurrentDelay := null;		
		endif;	
		
		self.doNotableRemove (_delay);	
	else		
		if self.allNotableObjects.includes (_delay) or self.includeObject (_delay) then 
			self.updateObjectInTable(_event, _delay, self.tblData);
		endif;
	endif;
	
	filterVoyage := self.myFilterVoyage;

	if filterVoyage &lt;&gt; null then
		self.staStatusBar.caption := filterVoyage.CM_Voyage.allDelays.size().String &amp; ' rows found' ; 
	endif;
end;
</source>
        <Parameter name="_event" type="Integer"/>
        <Parameter name="_delay" type="CM_Delay"/>
        <Parameter name="eventTag" type="Integer"/>
    </JadeMethod>
