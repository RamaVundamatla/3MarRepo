    <JadeMethod name="xCreateJobSheet" id="c6be6daa-f881-4a0e-bab7-106e1f3f54aa">
        <source>xCreateJobSheet():CM_WorkPointJobSheet;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 Aug 2023 navhl20 ChangeRequest 58158: EUP | [Framework] - Delivery Dispatch Garbage Collection

*/
constants
	WPJS: String  =  	"UT58158JSS";
vars
	myPxyWorkPointJobSheet,
	realJobSheet				: CM_WorkPointJobSheet;
	workPoint					: CM_WorkPoint;
	pxyWorkOrder,
	workOrder					: 	CM_WorkOrder;
	startDT,
	now,
	endDT	  					: 	TimeStamp;
	tmpTime   					: 	Time;
	allShiftsDays				: 	CM_ShiftStartDateCodeDict;
	shift						: 	CM_Shift;
	allJobArr					: 	CM_JobSet;
begin
	
	self.xDeleteJobSheet(WPJS);
	now := app.actualTimeServer();
	
	startDT.setDate(now.date.addYears(-12));
	tmpTime.setTime(0,0,0,0);
	startDT.setTime(tmpTime);
	
	
	endDT.setDate(now.date.addYears(-12) + 30);
	tmpTime.setTime(23,59,59,0);
	endDT.setTime(tmpTime);
	
	create allShiftsDays transient;
	allShiftsDays.purge;
	self.getMyTerminal().getShiftsFromRange(allShiftsDays, startDT, endDT);
	
	//Create JobSheet
	if allShiftsDays.isNotEmpty then
		shift := allShiftsDays.first;
	endif;
	workPoint := self.getMyTerminal.allWorkPointsByCode["UT_WPROAD"];
	
	realJobSheet := self.getMyTerminal.allJobSheetsForWorkPoints[shift.startDateTime];
	if realJobSheet &lt;&gt; null then
		app.myTrxDA.trxDeleteWorkPointJobSheet(realJobSheet, app.myPassport);
	endif;
	
	
	create myPxyWorkPointJobSheet transient;
	myPxyWorkPointJobSheet.setProxy(shift,self.getMyTerminal,workPoint,shift.startDateTime,WPJS,"","","");
	
	app.myTrxCA.trxCreateWorkPointJobSheet(myPxyWorkPointJobSheet, realJobSheet, app.myPassport);
	
	self.assertTrueMsg(app.myPassport.trxCompletedOK(), app.myPassport.getAllErrorsWarningsAsString());
	
	return realJobSheet;
epilog
	delete myPxyWorkPointJobSheet;
	if allShiftsDays &lt;&gt; null then
		allShiftsDays.purge;
		delete allShiftsDays;
	endif;
end;</source>
        <ReturnType type="CM_WorkPointJobSheet"/>
    </JadeMethod>
    <JadeMethod name="xDeleteJobSheet" id="f6146cc6-6304-4dac-bdd9-6b22df2511c7">
        <source>xDeleteJobSheet(_id :String);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 Aug 2023 navhl20 ChangeRequest 58158: EUP | [Framework] - Delivery Dispatch Garbage Collection

*/

vars
	wpJobSheet : CM_WorkPointJobSheet;
begin
	wpJobSheet := self.getMyTerminal.getWorkPointJobSheet(_id);
	
	if wpJobSheet&lt;&gt; null then
		app.myTrxDA.trxDeleteWorkPointJobSheet(wpJobSheet,app.myPassport);
		self.assertTrueMsg(app.myPassport.trxCompletedOK(), app.myPassport.getAllErrorsWarningsAsString());
	endif;
epilog

end;</source>
        <Parameter name="_id" type="String"/>
    </JadeMethod>
