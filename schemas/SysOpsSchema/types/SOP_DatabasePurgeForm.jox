    <JadeMethod name="setTerminalNotes" id="7135e6c5-b2a2-4b66-838b-b496a3cf4cbd">
        <source>setTerminalNotes() protected;
// -------------------------------------------
// Created 23 August 2004 by cnwdvb1
// -------------------------------------------

vars
	terminal : CM_Terminal;

begin
	// Terminal needs to be set from  combo.
	terminal := self.cmbTerminals.listObject.CM_Terminal;

	if terminal = null then
		return;
	endif;
	
	self.endNotificationForSubscriber(self);
	
	self.beginNotification(terminal, terminal.getTerminalEvent(EventTerminalActivityAdd), Response_Continuous, null);
	self.beginNotification(terminal, terminal.getTerminalEvent(EventTerminalActivityDelete), Response_Continuous, null);
	
	self.beginClassNotification(BGP_Object, false, BGP_Object.BGP_DisplayUpdate, Response_Continuous, null);
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setupForm" id="114b7fe4-d379-4414-9cd1-bc66bd111272">
        <updating/>
        <source>setupForm() updating;
// -------------------------------------------
// Created 20 August 2004 by cnwdvb1
// -------------------------------------------
// 06/05/2013	cnwcs5		par 29777 - imporve performance.  
// 9/11/17 		jlgns1 		TFS 6960 QNS - Disk space issues and house keeping inside JMT
// 16 Sep 2025 	navhl20 	Defect MTN-36050: The page goes blank after clicking on the Photo Checks on the Truck Unloader app
// 08 Oct 2025 	navhl20 	Story MTN-36217: TPT | Enable Uploading of Photos into MTN Production
vars

	etDef				: EntTableDef;
	date				: Date;
	tableBGP, tableAct	: CM_DataTable;
	tableDBP			: CM_EntryTable;
begin
	inheritMethod();
	
	tableBGP	:= self.tblBGP;
	tableDBP	:= self.tblDatabasePurge;
	tableAct	:= self.tblActivity;
	
	self.pbProgressBar.visible 	:= true; 
	etDef 						:= app.myController.getEntTableDef(ETDef_DatabasePurge);
	
	tableDBP.setEntTableDef(etDef, null, 'entTableDefSetupWarning');
	
	//21 Dec 2012	NDL	Par 30901
	if not app.isDutyDocEnabled then
		tableDBP.hideRowByName(ETRow_DutyDocs,false);
	endif;
	
	self.toolbarStyle 	:= self.ToolbarStyle_ShowNoHide;
	self.showToolbar 	:= true;
	self.topMargin		:= 10;
	
	self.fldPurge.useSheetBackColors := true;
	
	self.fldPurge.setDefaultSheetBackColors();
	self.fldPurge.initSheetBackColors();
		
	self.setCmbs();
	
	date :=  app.actualTimeServer().cnEcAddMonths(-12).Date;
	
	tableDBP.setValueByName(ETRow_Date, date);
	
	tableDBP.setValueByName( ETRow_MaxDurationMinutes,0);
		
	etDef := app.myController.getEntTableDef(ETDef_DatabasePurgeActivity);
	
	if etDef &lt;&gt; null then	
		self.setSortColumnsForFirstTime();	//This sets default sort columns for a new  user. Par 18316 Mar 2009
		tableAct.setTblDataEntRowsFromDef(etDef);
	endif;
	
	etDef := app.myController.getEntTableDef(ETDef_BgpClassRequests);
	
	if etDef &lt;&gt; null then	
		tableBGP.setTblDataEntRowsFromDef(etDef);
	endif;
	
	tableAct.selectMode 	:= Table.SelectMode_Row;
	tableAct.accessMode 	:= Table.AccessMode_Row;
	tableAct.multiSelect 	:= CM_BaseTable.MultiSelect_Simple;
	tableAct.selectionType 	:= CM_BaseTable.SelectionType_Row;
	
	tableAct.allSelectedObjects.clear;
	
	tableBGP.selectMode 	:= Table.SelectMode_Row;
	tableBGP.accessMode 	:= Table.AccessMode_Row;
	tableBGP.multiSelect 	:= CM_BaseTable.MultiSelect_Simple;
	tableBGP.selectionType 	:= CM_BaseTable.SelectionType_Row;
	
	tableBGP.allSelectedObjects.clear;
	
	self.sptActivity.setLeftToRightRatio(50);
	self.sptActivity.cnEcResizeContents();
	
	self.btnDelete.enabled	:= false;
	self.btnAbort.enabled	:= false;
	
	self.showRequest();
	
	if self.myCurrentRequest &lt;&gt; null then
		self.loadParametersTable();
	endif;

	self.doRefresh;					// cnwdad1 13/10/2008 - PAR #16936.
	self.setTerminalNotes();		// cnwdad1 13/10/2008 - PAR #16936.
	
	tableDBP.moveFirst();
	tableDBP.setFocus();	
	
		// TFS 2198 CNWAB1
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		self.btnRun.enabled:= false;
		self.tblDatabasePurge.userInputEnabled := false;
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="showColumnOrganiserActivity" id="53fc4be6-16ab-4682-8ea3-799c2ae201b5">
        <source>showColumnOrganiserActivity() protected;
// -------------------------------------------
// Created 07 July 2004 by cnwdvb1
// -------------------------------------------
vars

begin

	//self.myAssistant.showColumnOrganiser(self.tblActivity, self.myMasterMenuAction, null);
	self.tblActivity.showColumnOrganiserFrm(self.myTerminal, null);


end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="showRequest" id="968a9799-f2a6-4c42-b480-a904c3a142d5">
        <updating/>
        <source>showRequest() protected, updating;
// -------------------------------------------
// Created 23 August 2004 by cnwdvb1
// -------------------------------------------
// 29/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
// 30/04/2013	cnwcs5		par 29777 - improve efficiency
vars
	table			: CM_DataTable;
	request			: BGP_DatabasePurgeRequest;
	iter			: Iterator;
	row				: Integer;
	gotException	: Boolean;
begin
	table := self.tblBGP;
	
	table.clearAllData();

	iter := BGP_DatabasePurgeRequest.instances.createIterator();
	
	on Exception do app.handleDeletedObject (exception, request, gotException);
	
	while iter.next(request) do
		row := table.addItem(request.getDisplay);
		
		if gotException then
			gotException := false;
			continue;
		endif;
		
		table.accessRow(row).backColor 	:= self.ColourYellowLight;
		table.accessedRow.itemObject	:= request;
		
		self.myCurrentRequest 			:= request;
		// *** not sure why we are only looking for the 1st request ***
		break;
	endwhile;
epilog
	delete iter;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="tblActivity_contextMenu" id="bc3350e8-99ba-432d-a566-f524cf1f4991">
        <controlMethod name="Table::contextMenu"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblActivity_contextMenu(table: Table input; conwin: Window input; mouse: Boolean; x: Integer; y: Integer):Boolean updating;
// -------------------------------------------
// Created 23 August 2004 by cnwdvb1
// -------------------------------------------
vars
	x1 : Real;
	y1 : Real;
begin

	x1 := x;
	y1 := y;
	if (not mouse) then  // if keyboard, use current listIndex value
	    x1 := 20;
	    if table.row &lt; 0 then
	        y1 := 5;
	    else
	        y1 := table.positionTop();
	    endif;
	endif;

	conwin.windowToScreen(x1, y1);
	self.screenToWindow(x1, y1);   // convert x, y relative to form
	self.popupMenu(self.mnuContext, x1.Integer, y1.Integer);
	return false;                  // cancel further processing

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="conwin" type="Window" usage="input"/>
        <Parameter name="mouse" type="Boolean"/>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
