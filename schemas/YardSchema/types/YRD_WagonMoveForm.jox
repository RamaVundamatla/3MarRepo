    <JadeMethod name="setCollection" id="60925d29-b3c6-43c1-8db3-ee465fe5e4d8">
        <updating/>
        <source>setCollection(_coll : ObjectArray; _wagon : CM_Wagon; _mode:Integer) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 August 2022	navhl20 ChangeRequest 54281: EUP - Wagon Track Planning

*/

vars
	obj : CM_Wagon;
begin
	if _coll &lt;&gt; null then
		foreach obj in _coll as CM_Wagon do
			self.allSelectedWagons.add(obj);
		endforeach;
	else
		self.allSelectedWagons.add(_wagon);
	endif;
	self.moveMode := _mode; 
epilog

end;</source>
        <Parameter name="_coll" type="ObjectArray"/>
        <Parameter name="_wagon" type="CM_Wagon"/>
        <Parameter name="_mode" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setMoveWagons" id="975f78bb-6a5d-47bf-a340-6739f028fd4f">
        <updating/>
        <source>setMoveWagons() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
18 August 2022	navgm20	ChangeRequest 54281: EUP - Wagon Track Planning

*/

vars
	moveWagons : CM_Wagon;
	int 	 : Integer; 
begin
	foreach moveWagons in allSelectedWagons do
		int := self.lstMoveWagons.addItem(moveWagons.id);
		self.lstMoveWagons.itemObject[int] := moveWagons;
	endforeach;
end;</source>
    </JadeMethod>
