    <JadeMethod name="rel842_par36753" id="eedd4975-d9e8-46e2-b022-7e0042fdd545">
        <source>rel842_par36753();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 November 2015	cnwma1	Initial creation

*/

vars
	ya : CM_YACriteria;
	count : Integer;
begin
	app.initialize();
	beginTransaction;
	foreach ya in CM_YACriteria.instances do
			if ya.myYardAllocation.isKindOf(CM_VoyageAllocation)then
				if ya.myYardAllocation.CM_VoyageAllocation.myVoyage = null then
					ya.erase(NORMAL_ERASE);
					count := count + 1;
					if count &gt; 5000 then
						commitTransaction;
						count := 0;
						beginTransaction;
					endif;
					//write ya.getOidString;
					//if count &lt;=5000 then
					//	ya.erase(NORMAL_ERASE);
					//count := count+1;
					//else 
					//	count := 0;
					//	commitTransaction;
					//endif;
					
				endif;
			endif;
	endforeach;

	if count &gt;= 0 then
		commitTransaction;
	endif;
	
	write "Count="&amp;count.String;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="rel842_par36766" id="386930d3-bace-461a-a1fe-9034590dbb74">
        <source>rel842_par36766();
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 29/10/2015	cnwdap1		Initial creation PAR #36766 Bulk Voyage Graphical Representation
//
vars
	array : StringArray;
	transAgent 	: CM_TranslationAgent;
	newPerms : IntegerArray;
	termRole : CM_SecurityRoleTerminalRoot;
	sysRole	: CM_SecurityRoleSystemRoot;
	menuItem : CM_MenuToolbar;
	menuAgent : CM_MenuAgent;
	
begin	
	app.initialize;
		
	create transAgent transient;
	create array transient;

	array.add('Select_hold_print');
	array.add('Hold_definition');
	transAgent.trxLoadSpecificErrors(array);
	
	create newPerms transient;
	newPerms.add(PmVoyageBulkPlanningView);
	termRole := CM_SecurityRoleTerminalRoot.firstInstance;
	sysRole := CM_SecurityRoleSystemRoot.firstInstance;
	beginTransaction;
	termRole.setPermissionsFromIntArray(newPerms, true);	//true if terminal permission
	sysRole.setPermissionsFromIntArray(newPerms, false);	//true if system permission
	commitTransaction;
	
	// ### RESET MENUS
	beginTransaction;
	app.myRoot.resetRootSecurityRoles(null);
	commitTransaction;
	create menuAgent transient;
	menuAgent.resetAllMenuDetails();
	
	menuItem := app.myRoot.allToolbarEntities["_TB1262"];
	if menuItem &lt;&gt; null then
		beginTransaction;
		menuItem.setPropertyValue(CM_MenuToolbar::pictureStringButton.name, P16SecurGate);
		menuItem.setPropertyValue(CM_MenuToolbar::pictureStringButtonDown.name, P16SecurGate);
		commitTransaction;
	endif;
	menuItem := app.myRoot.allToolbarEntities["_TB1299"];
	if menuItem &lt;&gt; null then
		beginTransaction;
		menuItem.setPropertyValue(CM_MenuToolbar::pictureStringButton.name, P16VoyageOps);
		menuItem.setPropertyValue(CM_MenuToolbar::pictureStringButtonDown.name, P16VoyageOps);
		commitTransaction;
	endif;
	
	app.loadIcons;
	
	return;
	write PmVoyageBulkPlanningView;
	write ShpDisplayMode_Ops;
	write ShpDisplayMode_Queued;
	write MenuHdr_26;
	write Select_hold_print;
	write Hold_definition;
	
epilog
	delete array;
	delete transAgent;
	delete newPerms;
	app.finalize;
end;</source>
    </JadeMethod>
