    <JadeMethod name="updateBankCMIFfromForm" id="c842628d-6e4b-47b4-9fd4-4f46ae85ac7e">
        <source>updateBankCMIFfromForm();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 January 2019	jlgndl1	Initial creation	TFS 40010

*/

vars

	row : Integer;
	col : Integer;
	
	cashInvoiceTypeIndex : Integer;
	cashRoundInvLineTypeIndex : Integer;
	cashRoundUpAmountIndex : Integer;
	cashRoundingTypeIndex : Integer;
	cashTaxInvLineTypeIndex : Integer;
	proXtraInvLineGrpIndex : Integer;

	bank : CM_Bank;
	myConfigBank : CMIF_ConfigBank;

begin


	row := self.tblBankConfig.row;
	col := self.tblBankConfig.column;
	
	if col = 2 then
		bank := self.cmbBusUnitConfig.listObject.CM_Bank; 
	
		if bank &lt;&gt; null then
			myConfigBank:= self.allConfigBanks.getAtKey( bank );
		endif;
	
	endif;
	
	if myConfigBank &lt;&gt; null then
	
	
		cashInvoiceTypeIndex := self.tblBankConfig.getRowByName( ETRow_CashInvoiceType );
		cashRoundInvLineTypeIndex := self.tblBankConfig.getRowByName( ETRow_CashRoundInvLineType );
		cashRoundUpAmountIndex := self.tblBankConfig.getRowByName( ETRow_CashRoundUpAmount );
		cashRoundingTypeIndex := self.tblBankConfig.getRowByName( ETRow_CashRoundingType );
		cashTaxInvLineTypeIndex := self.tblBankConfig.getRowByName( ETRow_CashTaxInvLineType );
		proXtraInvLineGrpIndex := self.tblBankConfig.getRowByName( ETRow_ProXtraInvLineGrp ); //28 Jan 2019	NDL	TFS 42940
		
		if row = cashInvoiceTypeIndex then
			myConfigBank.cashInvoiceType := self.cmbCashInvType.listObject.CM_InvoiceDesc;
			
		elseif row = cashRoundInvLineTypeIndex then
			myConfigBank.cashRoundInvLineType := self.cmbRoundInvLineT.listObject.CM_InvoiceLineDesc;
			
		elseif row = cashRoundUpAmountIndex then
			myConfigBank.cashRoundUpAmount := self.tblBankConfig.getValueByName(ETRow_CashRoundUpAmount).Real;
			
		elseif row = cashRoundingTypeIndex then
			myConfigBank.cashRoundingType := app.roundingTypeStringToEnum(self.cmbRoundingType.text);
			
		elseif row = cashTaxInvLineTypeIndex then
			myConfigBank.cashTaxInvLineType := self.cmbTaxInvLineTyp.listObject.CM_InvoiceLineDesc;
			
		elseif row = proXtraInvLineGrpIndex then	 //28 Jan 2019	NDL	TFS 42940
			myConfigBank.proXtraInvLineGrp := self.cmbInvLineGrp.listObject.CM_InvoiceLineDescGroup;
			
		endif;
		
	endif;
	

epilog


end;</source>
    </JadeMethod>
    <JadeMethod name="validateInput" id="4cfbc068-1229-4294-93e8-3c115424b90d">
        <updating/>
        <source>validateInput() : Boolean updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
20 August 2012	cnwndl1	Initial creation	Par 29968

*/

vars

	bank : CM_Bank;

begin
	// no attribute selection
	if self.mulBUProCirt.mySelectedListBox.listCount = 0 then
		app.msgBox(app.getErrorString(Please_select_attribute), app.getErrorString(Selected_attributes), MsgBox_OK_Only+MsgBox_Information_Icon);	
		return false;
	endif;
	
	bank := self.cmbBusUnits.listObject.CM_Bank;
	if bank = null then
	//	app.msgBox(app.getErrorString1(REQUIRED_FIELD, lblBusUnit.caption), app.getErrorString(Selected_attributes), MsgBox_OK_Only+MsgBox_Information_Icon);	
		app.msgBox(app.getErrorString1(Input_required_field_Required, lblBusUnit.caption), app.getErrorString(Selected_attributes), MsgBox_OK_Only+MsgBox_Information_Icon);	// cnwdb2	PAR 35364
		self.cmbBusUnits.setFocus();
		return false;
	endif;
	
	return true;
	
epilog

end;
</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</GUIClass>
