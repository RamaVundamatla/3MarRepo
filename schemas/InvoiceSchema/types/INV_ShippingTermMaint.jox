    <JadeMethod name="initTblShipMapping" id="20fc0070-c9cc-4419-a6b0-f916330df6e0">
        <source>initTblShipMapping(_theEntDef :String );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 Jan 2023 navtnr20	TFS CR 55622 Task 55692: UI - Shipping Terms Maint

*/

vars
	theTable		: CM_DataTable;
	entTableDef		: EntTableDef;
begin
	theTable := self.tblData;
	theTable.allSelectedObjects.clear;
	
	if _theEntDef &lt;&gt; null then
		theTable.userInputEnabled := false;
		theTable.selectMode := CM_EntryTable.SelectMode_FixedRow;
		theTable.selectionType := CM_EntryTable.SelectionType_Row;
		theTable.rows := theTable.fixedRows;		
		entTableDef := app.myController.getEntTableDef(_theEntDef);
		theTable.setTblDataEntRowsFromDef(entTableDef);
		theTable.setMyDataClass(CM_InvoiceShipTermMapping);
		theTable.readOnly := false;	
		theTable.fixedColumns := 0;
		theTable.fixedRows := 1;
		self.setColorsForTable(self.tblData);	
		//self.setFieldAlignmentOnTable(theTable);
	else
		theTable.rows := 1;	
	endif;
end;</source>
        <Parameter name="_theEntDef" type="String"/>
    </JadeMethod>
    <JadeMethod name="loadMsgInvoiceTypes" id="e4376c95-e9ac-49f8-a96a-6a9ecd7b811e">
        <source>loadMsgInvoiceTypes();
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
06 October 2023	navmv20 Bug 60635: FR | 54089 EUP -Invoice Contracts - Shipping Terms
07/02/2025		navlw1	JIRA-33945: MTN | Add Filter MSG to Some Forms

*/

vars
	invoicelines : CM_InvoiceLineDescSet;
	invoiceline : CM_InvoiceLineDesc;
begin
	if self.myCurrentBank &lt;&gt; null then
		create invoicelines transient;
		foreach invoiceline in self.myCurrentBank.invoiceLineDescriptors discreteLock do
			invoicelines.add(invoiceline);
		
		endforeach;
	endif;
	
	self.msgInvlistTypes.myAvailableListBox.sorted 	:= true;
	self.msgInvlistTypes.mySelectedListBox.sorted 	:= true;
	self.msgInvlistTypes.setupControl(null, invoicelines, INV_ShippingTermMaint::getLineTypeDescription.name);
	self.msgInvlistTypes.availableHeading	:= app.getErrorString(Available);
	self.msgInvlistTypes.selectedHeading	:= app.getErrorString(Selected);
	self.msgInvlistTypes.myBaseForm	:= self;
	self.msgInvlistTypes.setSelected(null);
	
	// navlw1 Start #JIRA-33945 07/02/2025
	self.msgInvlistTypes.height := 190;
	self.msgInvlistTypes.myAvailableListBox.stretchHeight	:= false;
	self.msgInvlistTypes.myAvailableListBox.stretchWidth	:= false;
	self.msgInvlistTypes.myAvailableListBox.integralHeight	:= false;

	self.msgInvlistTypes.mySelectedListBox.stretchHeight	:= false;
	self.msgInvlistTypes.mySelectedListBox.stretchWidth		:= false;
	self.msgInvlistTypes.mySelectedListBox.integralHeight	:= false;
	// navlw1 End #JIRA-33945 07/02/2025
	

epilog

end;</source>
    </JadeMethod>
