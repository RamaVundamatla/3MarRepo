    <JadeMethod name="getExtraInfo" id="82fce972-d71b-40bd-852e-77902b911f4e">
        <source>getExtraInfo(_dataContainer: CM_DataContainer) ;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 Jan 2019	cnwma1	Initial creation	Bug 42984: QNS - RE: Report - Revenues by Service Lines
30 Jan 2020 cnwma1  Bug 48416: ADP - Invoice lines not going to expected cash invoice
*/
vars
	debtor	: CM_Debtor;
	block	: CM_DataContainerBlock;

begin
	
	block := _dataContainer.addNewBlock;
	block.addNewItem("Paid on", DC_Label, 1, self);
	block.addNewItem(self.systemToLocalTime(self.dateTime).asStringJMT(), DC_Data, 1, self);	// 24/6/2016 cnwmp6 TFS 488 - Multi timezone support

	if self.myInvoice &lt;&gt; null then
		block := _dataContainer.addNewBlock;
		block.addNewItem(app.getErrorString(CM_Invoice_Number), DC_Label, 1, self.myInvoice);
		block.addNewItem(self.myInvoice.sequenceNum.String, DC_Data, 1, self.myInvoice);
	endif;

	if self.getDebtorTerminal() &lt;&gt; null then
		block := _dataContainer.addNewBlock;
		debtor := self.getDebtorTerminal().myDebtor;
		block.addNewItem(app.getErrorString(Debtor_GC), DC_Label, 1, debtor);
		block.addNewItem(debtor.name, DC_Data, 1, debtor);
	endif;

	if self.myCarrier &lt;&gt; null then
		block := _dataContainer.addNewBlock;
		block.addNewItem(app.getErrorString(Carrier), DC_Label, 1, self.myCarrier);
		block.addNewItem(self.myCarrier.description, DC_Data, 1, self.myCarrier);
	endif;
	if self.myDriver &lt;&gt; null then
		block := _dataContainer.addNewBlock;
		block.addNewItem(app.getErrorString(Driver), DC_Label, 1, self.myDriver);
		block.addNewItem(self.myDriver.name, DC_Data, 1, self.myDriver);
	endif;
	if self.myUser&lt;&gt; null then
		block := _dataContainer.addNewBlock;
		block.addNewItem(app.getErrorString(User), DC_Label, 1, self.myUser);
		block.addNewItem(self.myUser.code, DC_Data, 1, self.myUser);
	endif;

	block := _dataContainer.addNewBlock;
	block.addNewItem(app.getErrorString(PaymentStatus_Void), DC_Label, 1, self);   // 20.02.2020 cnwma1 #48513
	block.addNewItem(self.voided.getYesNo, DC_Data, 1, self);

	if self.myTrackedItem &lt;&gt; null then
		block := _dataContainer.addNewBlock;
		block.addNewItem(app.getErrorString(CM_Tracked_Item), DC_Label, 1, self.myTrackedItem);
		block.addNewItem(self.getCargoDetails(), DC_Data, 1, self.myTrackedItem);
	endif;

	block := _dataContainer.addNewBlock;
	block.addNewItem("Payment", DC_Label, 1, self);
	//block.addNewItem(self.cashValue.userCurrencyFormat($CM_InvoiceMoney), DC_Data, 1, self); //30.01.2020 cnwma1 #48416
	block.addNewItem((-self.cashValue).asStringJMTWithPrecision(2, true), DC_Data, 1, self);   //30.01.2020 cnwma1 #48416
	
	if self.taxAmount &lt;&gt; 0 then
		block := _dataContainer.addNewBlock;
		block.addNewItem(app.getErrorString(Tax), DC_Label, 1, self);
		block.addNewItem(self.taxAmount.userCurrencyFormat($CM_InvoiceMoney), DC_Data, 1, self);
	endif;
	
	//21.01.2019 Bug 42984
	if self.getServiceName &lt;&gt; null then
		block := _dataContainer.addNewBlock;
		block.addNewItem(app.getErrorString(Services), DC_Label, 1, self);
		block.addNewItem(self.getServiceName(), DC_Data, 1, self);
	endif;
	
end;</source>
        <Parameter name="_dataContainer" type="CM_DataContainer"/>
    </JadeMethod>
    <JadeMethod name="getGLRateSummaryStats" id="30d94ccc-c75a-4019-b27c-02c08cde298f">
        <source>getGLRateSummaryStats(_glSumm : CM_GLSummaryByGLCodeRateDict input);
// Feb 2016 TFS 985 Milaha credit/receipt export, copy of CM_Charge method
vars
	glCode	: String;
	rate	: Real;
	charge	: CM_Charge;
	profDetail	: CM_ProformaDetails;
	gl : CM_GLSummary;

begin
	// regular payments
	if self.myProformaDetail &lt;&gt; null then
		self.myProformaDetail.getGLRateSummaryStats(_glSumm);
		return;
	elseif self.myInvoiceLine &lt;&gt; null then
		foreach charge in self.myInvoiceLine.charges do
			charge.getGLRateSummaryStats(_glSumm);
		endforeach;
		return;
	endif;
	
	// manual payment, use a null service name and the configured Cash GL code
	glCode := self.myTerminal.getConfig(CashACforGL).String;
	rate := self.cashValue;
	
	gl := _glSumm[glCode, rate, null];
	if gl = null then
		create gl;
		gl.glCode := glCode;
		gl.rate := rate;
		gl.serviceName := null;
		_glSumm.add(gl);
	endif;

	gl.quantity := gl.quantity + 1;
	gl.amount := gl.amount + self.cashValue;
	gl.myInvoiceLine := null;			// not used in the export
end;</source>
        <Parameter name="_glSumm" type="CM_GLSummaryByGLCodeRateDict" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getInvoiceForManualAssign" id="e1b75fab-f49b-4788-b4e2-5c0d84f34a58">
