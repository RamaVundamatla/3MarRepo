    <JadeMethod name="create" id="a5725c9a-fc6a-4509-9425-8a357a9ad6af">
        <updating/>
        <source>create() updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 03/03/2023	navdap1		Initial creation TFS 56796 PRP Suzano EDI - Delivery Confirmation
//
vars

begin
	self.name := "Suzano Delivery Communication";
	self.type := EDIFileTypeCams_SuzanoDelivery;
epilog

end;</source>
