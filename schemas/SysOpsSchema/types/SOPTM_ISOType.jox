    <JadeMethod name="create" id="69b98906-d5eb-4bbf-a9f8-41e705b1e92c">
        <updating/>
        <source>create() updating;
// ---------------------------------------------------------------------------
// Created:     03 January 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	self.name := SOP_TableMaintForm.Table_ISOType;
	self.permissionView	 := PmAdmIsotypetableView;
	self.permissionMaint := PmAdmIsotypetableMaint;
	self.myDataClass := CM_ISOType;
	
	self.weightType := app.getDefaultMeasurementForType(Type_Weight);	//18 Mar 2014	NDL	Par 33268

end;</source>
