<Class name="UT_RoadProcess" id="0f6076ce-a6c9-4034-806a-3cd0ec5abc43">
    <superclass name="UT_Gate"/>
    <transient/>
    <sharedTransientAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="unitTest"/>
    <JadeMethod name="createGTEforASPAtest" id="6115588f-ba42-4d0c-a263-946aab0dc470">
        <source>createGTEforASPAtest(	_index : Integer;
						_vvr : CM_VehicleVisitRecord input
						):CMGTE_Entity;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 October 2020	jlgndl1	Initial creation	TFS 50113

*/

constants

	TrailerType1 : String = "MSC20";
	TrailerType2 : String = "MSC40";

vars

	controller : CMIF_FlexiGateController;
	pxyGTEEntity : CMGTE_Entity;
	gte : CMGTE_Entity;
	operator : CM_Operator;
	cargoType : CM_CargoType;
	terminal : CM_Terminal;
	ti : CM_TrackedItem;
	
begin

	terminal := self.getTerminal;
	operator := app.myRoot.allOperators[self.getProfileSetting(UT_Profile.P_OPERATOR).asString].CM_Operator;

	
	create controller transient;
	
	if _index = 1 then  //Rebar in 
		cargoType := terminal.getCargoTypeFromAbbrevOrDescr("UTREBAR");
		create pxyGTEEntity as CMGTE_Receival transient;
		controller.id := "UTREBAR48189IN";
		controller.jobType := CMGTE_Entity.JobType_GeneralIN;
		controller.weightTotal := 100.0;
		controller.imexStatus := TI_IMEX_STATUS_STORAGE;
		
	elseif _index = 2 then //cargo out
		cargoType := terminal.getCargoTypeFromAbbrevOrDescr("UTREBAR");
		create pxyGTEEntity as CMGTE_Release transient;
		controller.id := "UTREBAR48189IN";
		controller.jobType := CMGTE_Entity.JobType_GeneralOUT;
		controller.weightTotal := 100.0;
		controller.mtOnly := false;	
		controller.imexStatus := TI_IMEX_STATUS_STORAGE;
		ti := terminal.allOnsiteTIsByCargoTypeId.getAtKey( cargoType.id, "UTREBAR48189IN" );
		controller.myTrackedItem := ti;
		
	elseif _index = 3 then //trailer in
		create pxyGTEEntity as CMGTE_TILC transient;
		pxyGTEEntity.setIsChassisIn(true);
		pxyGTEEntity.setJobQueueNum(1);
		controller.myChassisType := app.myRoot.allTILCTypes.getAtKey(null,TrailerType1);
		controller.id := _vvr.visitNumber;
		controller.jobType := CMGTE_Entity.JobType_ChassisIN;
		controller.weightTare := controller.myChassisType.tareWeight;
		controller.imexStatus := TI_IMEX_STATUS_REMAINONBOARD;
		cargoType := controller.myChassisType.myCargoType;
		
	elseif _index = 4 then //trailer in
		create pxyGTEEntity as CMGTE_TILC transient;
		pxyGTEEntity.setIsChassisIn(true);
		pxyGTEEntity.setJobQueueNum(1);
		controller.myChassisType := app.myRoot.allTILCTypes.getAtKey(null,TrailerType2);
		controller.id := _vvr.visitNumber;
		controller.jobType := CMGTE_Entity.JobType_ChassisIN;
		controller.weightTare := controller.myChassisType.tareWeight;
		controller.imexStatus := TI_IMEX_STATUS_REMAINONBOARD;
		cargoType := controller.myChassisType.myCargoType;
	
	endif;
	
	controller.cargoType := cargoType.id;	
	controller.myTerminal := terminal;
	controller.myVehicleVisitRecord := _vvr;
	controller.numItems := 1;
	controller.myCarrier := app.myRoot.allCarriers.getAtKey( _vvr.carrierCode );
	controller.voyageCode := terminal.getNullVoyage.code;
	controller.operatorCode := operator.code;	
	controller.carriageTempF := app.temperatureConversion(true, NULL_TEMPERATURE);
	controller.carriageTempC := NULL_TEMPERATURE;
	controller.packTempF := NULL_TEMPERATURE;
	controller.packTempC := app.temperatureConversion(true, NULL_TEMPERATURE); 
	controller.setCarbonDioxide( NULL_CARBON_DIOXIDE );
	controller.setOxygen( NULL_OXYGEN );
	controller.setHumidity( NULL_HUMIDITY );
	controller.ventilation := NULL_VENTILATION;
	
	pxyGTEEntity.setPXYFromController(controller); 
	
	if _index = 2 then
		pxyGTEEntity.CMGTE_Release.setIsReleaseById(true);
	endif;
	
	app.myTrxCA.trxCreateInOutFlexiGateEntity( _vvr, pxyGTEEntity, gte, app.myPassport );
	
	return gte;
	
epilog

	delete pxyGTEEntity;
	delete controller;
	
end;
	
</source>
        <Parameter name="_index" type="Integer"/>
        <Parameter name="_vvr" type="CM_VehicleVisitRecord" usage="input"/>
        <ReturnType type="CMGTE_Entity"/>
    </JadeMethod>
    <JadeMethod name="createStorConfigForTrailerType" id="fbee4bbc-a5b4-46ed-82e2-6cd5104eb189">
        <source>createStorConfigForTrailerType();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 November 2020	jlgndl1	Initial creation	TFS 50113

*/

vars

	storageConfig	: CM_StorageConfig;
	pxyStorageDetail : CM_StorageDetail;
	storageDetail	: CM_StorageDetail;
	criteriaTypes : CM_YACriteriaTypeArray;
	firstDayTimeCutoff	: Time;
	lastDayTimeCutoff	: Time;
	nullTime		: Time;

	triggers : CM_StorageTriggerByType;
	includeFirstDay : Boolean;
	includeLastDay : Boolean;
	shipReceivalType : Integer;
	shipReleaseType : Integer;

begin

	self.setTerminalConfig( StorageConfigType, null );
	self.deleteStorageConfig( false );
	
	nullTime := "00:00".Time;
	firstDayTimeCutoff := nullTime;
	lastDayTimeCutoff := nullTime;
	create criteriaTypes transient;
	criteriaTypes.add(app.myRoot.allYACriteriaTypes[YACriteriaType_TrailerType]);
	
	create triggers transient;
	includeFirstDay := false;
	includeLastDay := true;
	shipReceivalType := CM_StorageConfig.ShipReceivalActualDischarge;
	shipReleaseType := CM_StorageConfig.ShipReleaseActualLoad;
	
	storageConfig := self.createStorageConfig(criteriaTypes, triggers, null, firstDayTimeCutoff, includeFirstDay, includeLastDay,
											  lastDayTimeCutoff, shipReceivalType, shipReleaseType, null, null,null, -1, -1, -1);
	self.assertTrueMsg( storageConfig &lt;&gt; null, "No Storage config created");
	
	create pxyStorageDetail transient;
	pxyStorageDetail.setValues(	CM_StorageDetail.Working_Compulsory_Days,	//_chargedDaysType : Integer;
								CM_StorageDetail.Working_Compulsory_Days,	//_freeDaysType : Integer;
								0,	//_freeStorageDays : Integer;
								storageConfig,	//_config : CM_StorageConfig;
								0,	//_chargeDays : Integer;
								1,	//_priorityValue : Real;
								0,	//_stopFreeDays : Integer;
								0,	//_recievalDateRule : Integer;
								false, //_noStorageIfNotFullyReceived : Boolean;
								null,	//_futureStorageStop : CM_StopsTable;
								"UT TFS 50113",	//_desc : String
								-1, //_roadReceival : Integer;
								-1, //_shipReceival : Integer;
								-1, //_railReceival : Integer;
								-1, //_unpackReceival : Integer;
								null, //_allAdditionalCalendars : CM_CalendarByCodeDict
								-1, //_cooFreeStorageDays : Integer;
								-1, // _cooFreeDaysType : Integer
								false, //_includeFirstDay : Boolean;
								false	//_includeLastDay : BOolean
								);
	
	app.myTrxCA.trxCreateStorageDetail( pxyStorageDetail, null, storageDetail, app.myPassport );
	self.assertTrueMsg( storageDetail &lt;&gt; null, "No Storage detail on the config created");

epilog

	delete criteriaTypes;
	delete triggers;
	delete pxyStorageDetail;

end;</source>
    </JadeMethod>
    <JadeMethod name="createTFS50113TransMapStuff" id="d0356895-9a60-4359-af94-63ea19389b36">
        <source>createTFS50113TransMapStuff();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 November 2020	jlgndl1	Initial creation	TFS 50113

*/

constants

	TrailerType1 : String = "MSC20";
	TrailerType2 : String = "MSC40";

vars

	cargoMap	: CM_TranMapCargoAllocation;
	services : CM_ServiceByNameDict;
	invType : CM_InvoiceDesc;
	calType1 : CM_CalculationType;
	service100 : CM_Service;
	service50 : CM_Service;
	service150 : CM_Service;
	invLineType100 : CM_InvoiceLineDesc;
	invLineType50 : CM_InvoiceLineDesc;
	invLineType150 : CM_InvoiceLineDesc;
	debtor : CM_DebtorNode;
	
	fileContent : String;
	fileName : String;
	mapName : String;
	bank : CM_Bank;
	
	realTM : CM_TranMapCargoAllocation;
	pxyTM : CM_TranMapCargoAllocation;
	realYAConfig : CM_InvoiceAllocationConfig;
	pxyYAConfig : CM_InvoiceAllocationConfig;
	opCriteriaColl : CM_YACriteriaTypeArray;
	
	allTransientCriteriaObj	: CMIF_Array;
	objs : ObjectSet;
	proxyCriteria: CM_YACriteria;
	itemCode : String;
	cmifCriteria : CMIF_YACriteriaPriority;
	proxyYAObj : CM_InvoiceCargoAllocation;
	realAlloc : CM_InvoiceCargoAllocation;

begin

	bank := self.getTerminal.getDefaultCompanyBank();
	mapName := "UT_TFS50113";

	if bank.myCurrentTranMapCargoAlloc &lt;&gt; null and bank.myCurrentTranMapCargoAlloc.CM_TranMapCargoAllocation.name = mapName then
		//make some other map current
		foreach realTM in bank.allCargoAllocTranMaps where realTM.name &lt;&gt; mapName do
			app.myTrxUA.trxUpdateBankTMCAActive(realTM); 
			break;
		endforeach;
	endif;
	
	realTM := bank.allCargoAllocTranMaps[mapName];
	if realTM &lt;&gt; null then
		app.myTrxDA.trxDeleteInvoiceTranMapCA(realTM);
	endif;
	
	self.deleteInvoiceType("UT_InvType50113");

	self.deleteInvoiceService("UT_Service50113_50", FORCED_ERASE);
	self.deleteInvoiceService("UT_Service50113_100", FORCED_ERASE);
	
	self.deleteInvoiceLineType("UT_LineType50113_100", FORCED_ERASE);
	self.deleteInvoiceLineType("UT_LineType50113_50", FORCED_ERASE);
	
	invType := self.createInvoiceType("UT_InvType50113", InvoiceTypeStorage);
	self.assertNotNullMsg(invType, "Invoice type UT_InvType50113 not created");
	
//	calType1 := app.myRoot.allCalculationTypesByCode['CCT06'];	// INV_CALC_TYPE_DAYS_SINCE_RECVL;
//	self.assertNotNullMsg(calType1, "Calculation type INV_CALC_TYPE_DAYS_SINCE_RECVL not found");
	calType1 := app.myRoot.allCalculationTypesByCode['CCT01'];	 //INV_CALC_TYPE_UNITY;
	self.assertNotNullMsg(calType1, "Calculation type INV_CALC_TYPE_UNITY not found");
	
	
	service100 := self.createInvoiceService("UT_Service50113_100","Unit test for TFS 50113", calType1, null);
	self.assertNotNullMsg(service100, "UT_Service50113_100 not created");
	service50 := self.createInvoiceService("UT_Service50113_50","Unit test for TFS 50113", calType1, null);
	self.assertNotNullMsg(service50, "UT_Service50113_50 not created");
	
	beginTransaction;
	delete service100.debtorNodeRates.first.rateEntries.first;
	delete service50.debtorNodeRates.first.rateEntries.first;
	commitTransaction;
	
	debtor := CM_RootDebtorGroup.firstInstance;
	self.setServiceRate(service100, debtor, "02/01/2017".Date, 100.00);
	self.setServiceRate(service50, debtor, "02/01/2017".Date, 50.00);
	
	create services transient;
	
 	services.add(service100);
	invLineType100 := self.createInvoiceLineType("UT_LineType50113_100", calType1, invType, services,"SDT1");
	self.assertNotNullMsg(invLineType100, "UT_LineType50113_100 not created");
	services.clear();
	
	services.add(service50);
	invLineType50 := self.createInvoiceLineType("UT_LineType50113_50", calType1, invType, services,"SDT1");
	self.assertNotNullMsg(invLineType50, "UT_LineType50113_50 not created");
	services.clear();
	
	// Need to map to above invoice line types
	
	//creat the base map
	create opCriteriaColl transient;
	
	create pxyTM transient;
	pxyTM.setProxy(bank, mapName, mapName);		
	app.myTrxCA.trxCreateInvoiceTranMapCAlloc(pxyTM,realTM);
	self.assertTrueMsg( realTM &lt;&gt; null, "Trans map nopt created " &amp; app.myPassport.getErrorsAndWarningsAsString);
	
	//set up the config bit
	realYAConfig := realTM.myInvoiceAllocationConfig;
	pxyYAConfig := app.createUpdateProxy(realYAConfig).CM_InvoiceAllocationConfig;
	
	opCriteriaColl.add(app.myRoot.allYACriteriaTypes[YACriteriaType_TrailerType]);	
	pxyYAConfig.setProxyInvoiceAllocation(opCriteriaColl, null, realTM, null);
	
	app.myTrxUA.trxUpdateYAIMEXConfig(pxyYAConfig, app.myPassport);
	
	//now add the MSC20 mapping line
	create allTransientCriteriaObj transient;
	create objs transient;
	objs.add(app.myRoot.allTILCTypes[null,TrailerType1]);
	create proxyCriteria transient;
	itemCode := app.myRoot.allYACriteriaTypes[YACriteriaType_TrailerType].description.cnEcUpto(CM_YACriteriaPriority::code.length -1);
	proxyCriteria.setProxy(app.myRoot.allYACriteriaTypes[YACriteriaType_TrailerType], objs, itemCode);
	cmifCriteria := proxyCriteria.getTransient();
	cmifCriteria.setFlag(true, false, false);
	allTransientCriteriaObj.add(cmifCriteria);
	
	objs.clear;
	objs.add(app.myRoot.allTransactionTypes[TRANS_TYPE_REC_ROAD]);
	objs.add(app.myRoot.allTransactionTypes[TRANS_TYPE_REL_ROAD]);
	create proxyCriteria transient;
	itemCode := app.myRoot.allYACriteriaTypes[YACriteriaType_TransactionType].description.cnEcUpto(CM_YACriteriaPriority::code.length -1);
	proxyCriteria.setProxy(app.myRoot.allYACriteriaTypes[YACriteriaType_TransactionType], objs, itemCode);
	cmifCriteria := proxyCriteria.getTransient();
	cmifCriteria.setFlag(true, false, false);
	allTransientCriteriaObj.add(cmifCriteria);
	
	create proxyYAObj transient;
	proxyYAObj.setProxy(TrailerType1, TrailerType1,
								null,
								YAFillOption_InOrder,
								YAFillOption_InOrder,
								YAExpiryType_Never,
								null,
								null,
								
								null, 
								YAOverlap_Never,
								YANoLocation_Continue,
								null,
								0, 
								false,
								false,
								null,
								null,
								true,
								self.getTerminal());

	proxyYAObj.initialiseProxy( realTM );
	
	app.myTrxUA.trxUpdateInvoiceCargoAlloc( false, false, false, false, allTransientCriteriaObj, realTM, proxyYAObj, realAlloc ); 
	self.assertTrueMsg( realAlloc &lt;&gt; null, "INV Cargo Allocation " &amp; TrailerType1 &amp; " not created " &amp; app.myPassport.getAllErrorsWarningsAsString );
	
	self.addInvoiceCargoAllocationLines(realAlloc,"CCT01","UT_LineType50113_50","",0,CM_QuantityRangeMap.MAX_RANGE.Integer, false);
	
	if allTransientCriteriaObj &lt;&gt; null then
		if not allTransientCriteriaObj.isEmpty then
			allTransientCriteriaObj.purge;	
		endif;
		delete allTransientCriteriaObj;
	endif;
	delete opCriteriaColl;
	delete proxyYAObj;
	delete objs;
	
	
	//now add the MSC40 mapping line
	create allTransientCriteriaObj transient;
	create objs transient;
	objs.add(app.myRoot.allTILCTypes[null,TrailerType2]);
	create proxyCriteria transient;
	itemCode := app.myRoot.allYACriteriaTypes[YACriteriaType_TrailerType].description.cnEcUpto(CM_YACriteriaPriority::code.length -1);
	proxyCriteria.setProxy(app.myRoot.allYACriteriaTypes[YACriteriaType_TrailerType], objs, itemCode);
	cmifCriteria := proxyCriteria.getTransient();
	cmifCriteria.setFlag(true, false, false);
	allTransientCriteriaObj.add(cmifCriteria);
	
	objs.clear;
	objs.add(app.myRoot.allTransactionTypes[TRANS_TYPE_REC_ROAD]);
	objs.add(app.myRoot.allTransactionTypes[TRANS_TYPE_REL_ROAD]);
	create proxyCriteria transient;
	itemCode := app.myRoot.allYACriteriaTypes[YACriteriaType_TransactionType].description.cnEcUpto(CM_YACriteriaPriority::code.length -1);
	proxyCriteria.setProxy(app.myRoot.allYACriteriaTypes[YACriteriaType_TransactionType], objs, itemCode);
	cmifCriteria := proxyCriteria.getTransient();
	cmifCriteria.setFlag(true, false, false);
	allTransientCriteriaObj.add(cmifCriteria);
	
	create proxyYAObj transient;
	proxyYAObj.setProxy(TrailerType2, TrailerType2,
								null,
								YAFillOption_InOrder,
								YAFillOption_InOrder,
								YAExpiryType_Never,
								null,
								null,
								
								null, 
								YAOverlap_Never,
								YANoLocation_Continue,
								null,
								0, 
								false,
								false,
								null,
								null,
								true,
								self.getTerminal());

	proxyYAObj.initialiseProxy( realTM );
	
	app.myTrxUA.trxUpdateInvoiceCargoAlloc( false, false, false, false, allTransientCriteriaObj, realTM, proxyYAObj, realAlloc ); 
	self.assertTrueMsg( realAlloc &lt;&gt; null, "INV Cargo Allocation " &amp; TrailerType2 &amp; " not created " &amp; app.myPassport.getAllErrorsWarningsAsString );
	
	self.addInvoiceCargoAllocationLines(realAlloc,"CCT01","UT_LineType50113_100","",0,CM_QuantityRangeMap.MAX_RANGE.Integer, false);
	
	//now make it active

	app.myTrxUA.trxUpdateBankTMCAActive(realTM);
	cargoMap := bank.myCurrentTranMapCargoAlloc.CM_TranMapCargoAllocation;
	self.assertNotNullMsg(cargoMap,"cargo map should not be null");


epilog

	if allTransientCriteriaObj &lt;&gt; null then
		if not allTransientCriteriaObj.isEmpty then
			allTransientCriteriaObj.purge;	
		endif;
		delete allTransientCriteriaObj;
	endif;
	delete opCriteriaColl;
	delete proxyYAObj;
	delete objs;
	delete pxyYAConfig;

	delete services;
	delete pxyTM;

end;</source>
    </JadeMethod>
    <JadeMethod name="doSaveAdditions" id="eb165495-ffee-4fc8-811b-b1a9ec5935f4">
        <source>doSaveAdditions(_pxyVVR : CM_VehicleVisitRecord;
				_realVVR : CM_VehicleVisitRecord io;
				_allProformaLines : ObjectSet input;
				_passport : CM_Passport input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 October 2020	jlgndl1	Initial creation	TFS 50113

*/

vars
	realEntities,
	entityArray : CMGTE_EntityArray;
	gteEntity : CMGTE_Entity;
begin

	if _realVVR &lt;&gt; null and not _realVVR.isUpdatable and _realVVR.myRoadJob &lt;&gt; null then //15/05/2018 cnwma1 Bug 38547
		//epr changes for CCMS 1386 ROB gate cargo

		// find the entities that need saving 
		create entityArray transient;
		foreach gteEntity in _pxyVVR.allGateEntities do
			if gteEntity = _pxyVVR.myInCMGTE_Chassis or
			   gteEntity = _pxyVVR.myOutCMGTE_Chassis then
				continue;
			endif;
			if (gteEntity.myYardRequest &lt;&gt; null and 				//cnwas3 28028
				gteEntity.status = CMGTE_Entity.Status_Unactioned) then
				
				continue;
			endif;
			entityArray.add(gteEntity);
		endforeach;
		
	
		app.myTrxCA.trxCreateInOutFlexiGateEntitys(_realVVR, entityArray,realEntities, true, _passport);
		
	else
		app.myTrxCA.trxCreateInOutFlexiJob(_pxyVVR, _realVVR,_allProformaLines, _passport);
		
	endif;
	
epilog
	delete entityArray;
	delete realEntities;
end;
</source>
        <Parameter name="_pxyVVR" type="CM_VehicleVisitRecord"/>
        <Parameter name="_realVVR" type="CM_VehicleVisitRecord" usage="io"/>
        <Parameter name="_allProformaLines" type="ObjectSet" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doSavePrenotes" id="095a8c58-c9d5-4989-8735-54b8a503e164">
        <source>doSavePrenotes(_pxyVVR : CM_VehicleVisitRecord);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 October 2020	jlgndl1	Initial creation	TFS 50113

*/

vars
	pxyTI ,ti: CM_TrackedItem;
	gteEntity, realGTE 	: CMGTE_Entity;
	pxyTISet : CM_TISet;
	result : Integer;
	gteChildEntity	: CMGTE_Entity;
	childTi : CM_TrackedItem;
begin


	create pxyTISet transient;
	
	foreach gteEntity in _pxyVVR.allGateEntities discreteLock do
		if not gteEntity.isKindOf(CMGTE_Receival) then
			continue;
		endif;
		ti:=gteEntity.CMGTE_Receival.myTrackedItem;
		if ti = null then
			continue;
		endif;
		
		if not ti.isPreNote() then
			continue;
		endif;
		
		
		if ti.canSplitTotalQuantity and 
		((ti.myCargoType.isBreakBulkMulti and ti.totalQuantity &gt; gteEntity.CMGTE_Receival.totalQuantity) or
		(ti.myCargoType.isBulkMulti and ti.myCargoType.isTrackByWeight and ti.totalWeight &gt; gteEntity.CMGTE_Receival.weightTotal) or	// PAR #33606
		(ti.myCargoType.isBulkMulti and ti.myCargoType.isTrackByVolume and ti.totalVolume &gt; gteEntity.CMGTE_Receival.volumeTotal)) then	// PAR #33606
			continue;
		endif;
	
		pxyTI := app.createUpdateProxy(ti).CM_TrackedItem;
		pxyTISet.add(pxyTI);								
		pxyTI.setPxyFromCMGTE_Receival(gteEntity.CMGTE_Receival, app.myPassport);   
		
	endforeach;	
	
	if  pxyTISet.isEmpty then
		return;
	endif;
	
	app.myPassport.setWarningsAcknowledged(true);	
	
	
	while true do

		app.myTrxUA.trxUpdateTrackedItems(pxyTISet, TI_UPDMODE_NORMAL, null, app.myPassport);

		if app.myPassport.trxCompletedOK then		
			break;
		else
			if app.myPassport.noErrors then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
	
		break;
	endwhile;
	
	// update successful have to go round and update the gte tiEdition to stop object edition mis match error
	
	foreach gteEntity in _pxyVVR.allGateEntities discreteLock do
		if not gteEntity.isKindOf(CMGTE_Receival) then
			continue;
		endif;
		ti:=gteEntity.CMGTE_Receival.myTrackedItem;
		if ti = null then
			continue;
		endif;
		
		gteEntity.CMGTE_Receival.updatetTIEdition();
		
		//18 Feb 2016	NDL	Par 37559
		foreach gteChildEntity in gteEntity.CMGTE_Receival.allChildren do
			childTi := gteChildEntity.CMGTE_Receival.myTrackedItem;
			if childTi = null then
				continue;
			endif;
			gteChildEntity.CMGTE_Receival.updatetTIEdition();
		endforeach;
		
		realGTE:=gteEntity.pxyGetRealObject();
		
	endforeach;
	
	return;
	
epilog
	pxyTISet.purge;
	delete pxyTISet;
		
end;</source>
        <Parameter name="_pxyVVR" type="CM_VehicleVisitRecord"/>
    </JadeMethod>
    <JadeMethod name="tASPARoadProcess1" id="6d5149ee-8871-4656-b8ab-2a8baa82a94b">
        <source>tASPARoadProcess1();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 October 2020	jlgndl1	Initial creation	TFS 49189 / 50113 / 50114 / 50329 / 50430
	NOTE this road process does not use wles or Jobs.
13/05/2022 		navhl20 TFS 53430  EUP - Sub Carrier registration in MTN
*/

constants

	TruckId : String = "49189";
	BSID : String = "BS49189";
	TrailerType1 : String = "MSC20";
	TrailerType2 : String = "MSC40";
	SubTerm = "SUBTASPA";

vars

	roadProcess : CM_RoadProcess;
	term : CM_Terminal;
	gate : CM_Gate;
	lane : CM_YardController;
	pxyVVR : CM_VehicleVisitRecord;
	realVVR : CM_VehicleVisitRecord;
	realVVR2 : CM_VehicleVisitRecord;
	now : TimeStamp;
	tsi : TimeStampInterval;
	lastHour : TimeStamp;
	carrierCode : String;
	gte : CMGTE_Entity;
	allProformaLines : ObjectSet;
	proxyAutoIdGen : CM_AutoIdGenerator;
	autoIdGen : CM_AutoIdGenerator;
	cargoType : CM_CargoType;
	moveController : CMIF_MoveController;
	allMoveControllers : ObjectArray;
	roadReceive : CM_ReceiveRoad;
	roadRelease : CM_ReleaseRoad;
	ti : CM_TrackedItem;
	bs : CM_BlockStack;
	trailerDischarge : CM_TrailerDischarge;
	trailerLoad : CM_TrailerLoad;
	selectedAreas : ObjectSet;
	subtOn : Boolean;
	subtAreaDef : Boolean;
	subTerminal : CM_SubTerminal;
	subTerminalAreaDef : CM_SubTerminalAreaDef;
	useSubTermAreaDefined : Boolean;

begin

	now := app.actualTimeAppServer();

	useSubTermAreaDefined := now.Date.day.isOdd;  // So it flip flops daily, therfore checking both current possibilities

	if useSubTermAreaDefined then
		subtOn := self.setTerminalConfig(IsSubTerminalsOn,true).Boolean;
		subtAreaDef := self.setTerminalConfig(IsSubTerminalAreaDefined,true).Boolean;
	endif;

	//cleanup the old data
	self.deleteVehicle( TruckId );
	self.deleteSubTerminal(SubTerm);
	self.deleteTerminalArea( BSID );
	create allMoveControllers transient;
	
	term := self.getTerminal;
	tsi.set( 1, ( 60 * 60000 ) );		// 1 day and 1 hour
	lastHour := now - tsi;
	
	if term.getMyAutoIdGenerator( CM_AutoServiceOrderGen ) = null then
		create proxyAutoIdGen as CM_AutoServiceOrderGen transient;
		proxyAutoIdGen.setProxy(	"SON",	//_idPrefix : String ;
									4,	//_idSeqNumLength : Integer;
									AutoIdStyle_P_SSS,	//_idStyle : Integer;
									term,	//_myTerminal : CM_Terminal; 
									1,	//_nextSequenceNum : Real;
									0	//_resetSeqOn : Integer
									);
		app.myTrxCA.trxCreateAutoIdGenerator( proxyAutoIdGen, autoIdGen, app.myPassport);
		delete proxyAutoIdGen;
	endif;

	//set the config
	beginTransaction;
	term.setMyRoadProcess( app.myRoot.allRoadProcesses.getAtKey( CM_RoadProcess.ASPA_GCI ).CM_RoadProcess );
	term.setConfig(InvUseInvoiceCargoAlloc, true);
	commitTransaction;
	
	bs := self.addBlockStack( BSID, 10, null );
	if useSubTermAreaDefined then
		create selectedAreas transient;
		selectedAreas.add(bs);
		subTerminal := self.addSubTerminal(SubTerm,SubTermType_Marine_Int);
		self.assertTrueMsg( subTerminal &lt;&gt; null, "Sub Terminal not created");
		subTerminalAreaDef := self.addSubTerminalWorkAreaDef( subTerminal, selectedAreas );
	endif;
	gate := self.getGate(self.getProfileSetting(UT_Profile.P_SGATE).asString);
	lane := gate.getFirstAGateLane_IN;
	carrierCode := "UT_CA1";
	
	self.createStorConfigForTrailerType();
	self.createTFS50113TransMapStuff();
	
	//Gate in a truck using the ASAP trxs bringing in a prenote
	
	//create the VVR simulating Road Gate form
	create pxyVVR transient;
	pxyVVR.setAutoComplete(false);
	pxyVVR.setTimeIn( lastHour.date, lastHour.time);
	//pxyVVR.setProxyFlexiGate(null, null, carrierCode, TruckId, null, null, term, gate, lane, null);		//13/05/2022 navhl20 TFS 53430
	pxyVVR.setProxyFlexiGate(null, null, carrierCode, null, TruckId, null, null, term, gate, lane, null);		//13/05/2022 navhl20 TFS 53430  
	pxyVVR.setVisitNumber( term.getNextGateTransactionNumber() );
	app.myTrxCA.trxCreateVehicleVisitFlexi(pxyVVR, realVVR, app.myPassport);
	
	delete pxyVVR;
	
	//Add GTE's simulating Road Gate form process
	gte := self.createGTEforASPAtest( 1, realVVR );	 //Rebar in
	gte := self.createGTEforASPAtest( 3, realVVR );	// Trailer in
	
	pxyVVR := app.createUpdateProxy( realVVR ).CM_VehicleVisitRecord;
	self.doSavePrenotes( pxyVVR );
	
	app.myTrxCA.trxCreateInOutFlexiJob( pxyVVR, realVVR, null, app.myPassport);
	
	delete pxyVVR;
	
	//unload the rebar using the trx from Vehicle VisitRecordMaint form
	
	cargoType := term.getCargoTypeFromAbbrevOrDescr("UTREBAR");
	ti := term.allOnsiteTIsByCargoTypeId.getAtKey( cargoType.id, "UTREBAR48189IN");		//"UTREBAR48189IN" );

	allMoveControllers.clear();				
	create moveController transient;
	moveController.setMyTrackedItem( ti );	
	moveController.setMyToPrimaryLocation( bs.myLocationsController );
	moveController.setMyOriginatingLocation( ti.myPrimaryActualLocation );
	moveController.setMoveMode( REAL_MODE );
	moveController.setEffectiveTimeStampOverride( lastHour );	
	moveController.myAssociatedVVR := realVVR;
	moveController.setWeight( ti.totalWeight ); 
	moveController.setQuantity( ti.totalQuantity );
	allMoveControllers.add( moveController );
	
	app.myTrxUA.trxMoveMultiTrackedItems( allMoveControllers, app.myPassport );
	
	delete moveController;
	
	roadReceive := ti.getLastTransOfClass( CM_ReceiveRoad ).CM_ReceiveRoad;
	self.assertTrueMsg( roadReceive &lt;&gt; null, "Failed to Find Road Receive trx for TI, post gate in and unload");
	self.assertTrueMsg( roadReceive.trailerTypeCode = TrailerType1, "Trailer Type on Road Receive trx s/be '" &amp; TrailerType1 &amp; "'");
	self.assertTrueMsg( not roadReceive.allInvoiceLines.isEmpty, "The Road Receive trx should have an invoice line" );
	self.assertTrueMsg( roadReceive.allInvoiceLines.first.lineTotal = 50, "Should have charged $50.00 for Trailer type = '" &amp; TrailerType1 &amp; "'");
	
	trailerDischarge := ti.getFirstTransOfType( TRANS_TYPE_TRAILER_DIS ).CM_TrailerDischarge;
	self.assertTrueMsg( trailerDischarge &lt;&gt; null, "Failed to Find Trailer Discharge trx for TI, post gate in and unload");
	self.assertTrueMsg( trailerDischarge.trailerTypeCode = TrailerType1, "Trailer Type on Trailer Discharge trx s/be '" &amp; TrailerType1 &amp; "'");	
	
	//Gate in the same truck a second time (in parallel) to release an onsite cargo item 
	
	tsi.set( 0, ( 30 * 60000 ) );  // half an hour
	lastHour := now - tsi;
	
	//create the VVR simulating Road Gate form
	create pxyVVR transient;
	pxyVVR.setAutoComplete(false);
	pxyVVR.setTimeIn( lastHour.date, lastHour.time);
	//pxyVVR.setProxyFlexiGate(null, null, carrierCode, TruckId, null, null,term, gate, lane, null);	//13/05/2022 navhl20 TFS 53430 
	pxyVVR.setProxyFlexiGate(null, null, carrierCode, null, TruckId, null, null,term, gate, lane, null);	//13/05/2022 navhl20 TFS 53430 
	pxyVVR.setVisitNumber( term.getNextGateTransactionNumber() );
	app.myTrxCA.trxCreateVehicleVisitFlexi(pxyVVR, realVVR2, app.myPassport);
	
	delete pxyVVR;
	
	//Add GTE's simulating Road Gate form process
	gte := self.createGTEforASPAtest( 2, realVVR2 );	 //Rebar out
	gte := self.createGTEforASPAtest( 4, realVVR2 );	// Trailer in
	
	pxyVVR := app.createUpdateProxy( realVVR2 ).CM_VehicleVisitRecord;
	self.doSavePrenotes( pxyVVR );
	
	app.myTrxCA.trxCreateInOutFlexiJob( pxyVVR, realVVR2, null, app.myPassport);
	
	//Load the ti  using the same style move trx from the Vehicle VisitRecordMaint form
	
	cargoType := term.getCargoTypeFromAbbrevOrDescr("UTREBAR");
	ti := term.allOnsiteTIsByCargoTypeId.getAtKey( cargoType.id, "UTREBAR48189IN" );
	
	allMoveControllers.clear();				
	create moveController transient;
	moveController.setMyTrackedItem( ti );	
	moveController.setMyToPrimaryLocation( realVVR.myOutCMGTE_Chassis.CMGTE_Release.myTrackedItem.CM_TILC.allLCs.first );
	moveController.setMyOriginatingLocation( ti.myPrimaryActualLocation );
	moveController.setMoveMode( REAL_MODE );
	moveController.setEffectiveTimeStampOverride( lastHour );	
	moveController.myAssociatedVVR := realVVR2;
	moveController.setWeight( ti.totalWeight ); 
	moveController.setQuantity( ti.totalQuantity );
	allMoveControllers.add( moveController );
	
	app.myTrxUA.trxMoveMultiTrackedItems( allMoveControllers, app.myPassport );
	
	delete moveController;
	
	//Now gate the truck out using the gate out trx from the Vehicle VisitRecordMaint form 
	
	app.myTrxUA.trxUpdateVVRRoadExit( realVVR2, lastHour, app.myPassport );
	
	//now check the road release trx
	
	roadRelease := ti.getLastTransOfClass( CM_ReleaseRoad ).CM_ReleaseRoad;
	self.assertTrueMsg( roadRelease &lt;&gt; null, "Failed to Find Road Release trx for TI, post Gate Out");
	self.assertTrueMsg( roadRelease.trailerTypeCode = TrailerType2, "Trailer Type on Road Release trx s/be '" &amp; TrailerType2 &amp; "'");
	self.assertTrueMsg( roadRelease.dateTime.Time.minute = lastHour.Time.minute, "Gate out time s/be '" &amp; lastHour.Time.String &amp; "'");
	self.assertTrueMsg( not roadRelease.allInvoiceLines.isEmpty, "The Road Release trx should have an invoice line" );
	self.assertTrueMsg( roadRelease.allInvoiceLines.first.lineTotal = 100, "Should have charged $100.00 for Trailer type = '" &amp; TrailerType2 &amp; "'");
	
	trailerLoad := ti.getLastTransOfClass(CM_TrailerLoad).CM_TrailerLoad;
	self.assertTrueMsg( trailerLoad &lt;&gt; null, "Failed to Find Trailer Load trx for TI, post Gate Out");
	self.assertTrueMsg( trailerLoad.trailerTypeCode = TrailerType2, "Trailer Type on Trailer Load trx s/be '" &amp; TrailerType2 &amp; "'");
	
	//Now gate the truck out the original VVR using the gate out trx from the Vehicle VisitRecordMaint form 
	
	app.myTrxUA.trxUpdateVVRRoadExit( realVVR, lastHour, app.myPassport );

epilog

	abortTransaction;

	if useSubTermAreaDefined then
		self.setTerminalConfig(IsSubTerminalsOn,subtOn);
		self.setTerminalConfig(IsSubTerminalAreaDefined,subtAreaDef);
	endif;

	self.resetDefaultTranMap();	
	self.deleteStorageConfig( true );

	//reset the config
	beginTransaction;
	term.setMyRoadProcess( app.myRoot.allRoadProcesses.getAtKey( CM_RoadProcess.DEFAULT ).CM_RoadProcess );
	term.setConfig(InvUseInvoiceCargoAlloc, false);
	commitTransaction;
	delete allProformaLines;
	delete pxyVVR;
	delete moveController;
	delete allMoveControllers;
	delete selectedAreas;

end;</source>
    </JadeMethod>
</Class>
