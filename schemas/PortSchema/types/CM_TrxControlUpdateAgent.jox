    <JadeMethod name="trxClearFromMultiMoveGroup" id="aca00b04-31b7-4438-a9f6-fdf8d90f6d78">
        <updating/>
        <source>trxClearFromMultiMoveGroup( _ti : CM_TrackedItem input; _passport : CM_Passport input) updating;

/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 September 2015	cnwndl1	Initial creation	Par 36906

*/

vars

	mmg : CM_MultiMoveGroup;

begin

// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);
	
	app.setContinueCMExceptions(false);
	
	if _ti = null then
		return;
	endif;

	mmg := _ti.myMultiMoveGroup;
	if mmg = null then
		return;
	endif;
	
	mmg.exclusiveLock( mmg );
	_ti.exclusiveLock( _ti );

	beginTransaction;

	app.myUtilityUA.utlClearFromMultiMoveGroup( mmg, _ti, _passport );
	
epilog

	self.finaliseActivityWithPassport(_passport);
	
end;</source>
        <Parameter name="_ti" type="CM_TrackedItem" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
