// ---------------------------------------------------------------------------
// Created:     23 January 2003		cnwth2	
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
constants
	TheWidth = 150;
vars

begin
 // ### TFS 50421 21OCT2021 NAVAB1	self.cmbClosePicture.width := self.width - TheWidth;
 // ### TFS 50421 21OCT2021 NAVAB1	self.cmbOpenPicture.width := self.width - TheWidth;
 // ### TFS 50421 21OCT2021 NAVAB1	self.cmbLeafPicture.width := self.width - TheWidth;
	

end;</source>
    </JadeMethod>
    <JadeMethod name="findMatchingPic" id="d8333c2e-1571-423a-bb05-2cf15067a13b">
        <source>findMatchingPic(_str : String);
// ---------------------------------------------------------------------------
// Created:     11 June 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
vars
	cmb				: CMUI_ComboBox;
	searchStr		: String;
	upPos,
	idx,
	listCount		: Integer;
begin
	if _str = null then
		return;
	endif;
	searchStr := _str.toUpper;
	///take off 'up' ifi it's there
	upPos := searchStr.pos('UP', (searchStr.length - 2));
	if upPos &lt;&gt; 0 then
		searchStr := searchStr[1:upPos -1];
	endif;
	
	searchStr := (searchStr &amp; 'DOWN').toUpper;
	cmb :=  self.cmbClosePicture;
	listCount := cmb.listCount;
	
	foreach idx in 1 to listCount do
		if cmb.itemText[idx].toUpper = searchStr then
			cmb.listIndex := idx;
			break;
		endif;
	endforeach;

end;</source>
        <Parameter name="_str" type="String"/>
    </JadeMethod>
    <JadeMethod name="loadDataForFirstTime" id="f45c7ebe-6f2c-4118-8f3a-577b901df444">
        <updating/>
        <source>loadDataForFirstTime() updating, protected;
// ---------------------------------------------------------------------------
// Created:      29 May 2003 by cnwsgp1
// ---------------------------------------------------------------------------
begin
 // ### TFS 50421 20OCT2021 NAVAB1	self.doLoadCombos;
	
	self.doLoadCombos2021(); // ### TFS 50421 20OCT2021 NAVAB1
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setupForm" id="7b44e3ea-d864-4df8-8b22-51998f3ba1ea">
        <updating/>
        <source>setupForm() updating;
// ---------------------------------------------------------------------------
// Created:     10 January 2003		cnwth2	
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
begin
	inheritMethod();
	
	if not self.isForHeader then
		self.lblClose.caption		:=	'Toolbar down pic';
		self.lblOpen.caption		:=	'Toolbar up pic';
	else
		self.lblClose.caption		:=	'Closed folder pic';
		self.lblOpen.caption		:=	'Open folder pic';
		self.cmbLeafPicture.enabled	:=	false;
		self.lblLeaf.enabled		:=	false;
	endif;
	
	
	/* ### TFS 50421 21OCT2021 NAVAB1 - WAS
	
	self.cmbClosePicture.fontSize	:=	20;
	self.cmbLeafPicture.fontSize	:=	20;
	self.cmbOpenPicture.fontSize	:=	20;
	
	NOW */
	
	self.cmbClosePicture.fontSize	:=	10;
	self.cmbLeafPicture.fontSize	:=	10;
	self.cmbOpenPicture.fontSize	:=	10;
	self.cmbClosePicture.defaultLineHeight := 30;
	self.cmbLeafPicture.defaultLineHeight := 30;
	self.cmbOpenPicture.defaultLineHeight := 30;
	
	
	self.cmbOpenPicture.setFocus();
end;</source>
    </JadeMethod>
    <JadeMethod name="translateForm" id="77a82e89-e681-4df0-b091-a71640557e15">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0007944, locale);
	lblClose.translateCaption(Xlat_0000636, locale);
	lblHeading.translateCaption(Xlat_0000637, locale);
	lblLeaf.translateCaption(Xlat_0000638, locale);
	lblOpen.translateCaption(Xlat_0000639, locale);
end;</source>
    </JadeMethod>
</GUIClass>
