    <JadeMethod name="create" id="1d6111f9-b6c9-4bce-bdd2-4afb70ff2092">
        <updating/>
        <source>create() updating;
// ---------------------------------------------------------------------------
// Created:		21 November 2005  By Andrew Bishop cnwab1
//
// Purpose:		
//
// 25 Oct 12 	PJS		PAr #30631 - Voyage Rationalisation
// ---------------------------------------------------------------------------

vars

begin

	//  permissions rolled into OOW  now creation is no longer a seperate menu item
	
	self.permissionView  := PmAdmOrdworkView;
	self.permissionMaint := PmAdmOrdworkMaint;
	self.helpFileName := HelpFile_Voyage;

end;</source>
    </JadeMethod>
    <JadeMethod name="doBtnAutoJobsClick" id="70cc7e32-7f42-4a08-8167-65f623c01ff4">
        <updating/>
        <source>doBtnAutoJobsClick() updating;
// ---------------------------------------------------------------------------
// Created:		03 May 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	controller : CMIF_OOWCreationAutoUpdate;
	theReturn : Integer;
begin
	if not self.doCheckVoyage(true) then
		return;
	endif;
	if not self.doCheckOOWJobs() then
		return;
	endif;
	if app.msgBox("Do you want to auto assign OOW Creation details to Work Points for voyage " &amp; self.myCurrentVoyage.code &amp; "?", 
					app.getErrorString(Confirmation),MsgBox_Yes_No + MsgBox_Question_Mark_Icon) = MsgBox_Return_No then
		return;
	endif;

	create controller transient;
	controller.splitHolds := self.xmlSplit; //self.chkSplit.value;
	self.myCurrentVoyage.myCellularVoyageStructure.getOOWCreationPopController(controller);
	controller.myROROStructure := self.myCurrentVoyage.myROROStructure; //epr CCMS 1033 19/9/11

	
	
	while true do
		app.myTrxUA.trxUpdateVoyageOOWAuto(self.xmlShowLiftColumn, controller, app.myPassport);
		if app.myPassport.trxCompletedOK then
			global.beep;
			break;
		else
			theReturn := app.showErrorWarningDialog("OOW Voyage Details Auto", app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   theReturn = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			return;
		endif;
		break;
	endwhile;
	
epilog
	delete controller;
end;</source>
    </JadeMethod>
    <JadeMethod name="doBtnResetClick" id="d165f521-1c68-4a3c-b286-58aaf090604c">
        <updating/>
        <source>doBtnResetClick() updating;
// ---------------------------------------------------------------------------
// Created:		01 May 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
begin
