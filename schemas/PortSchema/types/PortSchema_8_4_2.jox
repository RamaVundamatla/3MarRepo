    <JadeMethod name="checkChilledTIsOffPowerSet" id="cc3dd425-147b-468d-b40d-511d2d5cf908">
        <source>checkChilledTIsOffPowerSet();
//
// Purpose:			Check CM_Terminal::chilledTIsOffPower set for connected TIs and remove them
//					from the set
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 14/07/2015	cnwdap1		Initial creation PAR #36041
//
vars
	terminal : CM_Terminal;
	ti : CM_TrackedItem;
	invalid, count : Integer;

begin
	app.writeLog(method.qualifiedName &amp; " Checking Terminal chilled TIs Off Power collections", LogINFO);
	
	beginTransaction;
	foreach terminal in CM_Terminal.instances do
		foreach ti in terminal.chilledTIsOffPower do
			if not app.isValidObject(ti) then
				terminal.chilledTIsOffPower.remove(ti);
				invalid := invalid + 1;
				continue;
			endif;
			if ti.isConnected then
				terminal.chilledTIsOffPower.remove(ti);
				count := count + 1;
			endif;
		endforeach;
	endforeach;
	commitTransaction;
				
	app.writeLog(method.qualifiedName &amp; " Checking Terminal chilled TIs Off Power collections Completed - " &amp; invalid.String &amp; " invalid references removed, " &amp; count.String &amp; " connected reefers removed", LogINFO);
epilog
	
end;</source>
    </JadeMethod>
    <JadeMethod name="cleanUpOrphanedCMStrings" id="e3517b7f-2c51-4ae4-a6af-b3d62d63599e">
        <source>cleanUpOrphanedCMStrings();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 Jul 2015	cnwkpd1	PAR #36578 - Tidy up leaked CM_Strings objects

*/

vars
	stringObj		: CM_Strings;
	deleteCount		: Integer;
	
begin
	if self.hasScriptBeenRunThisRelease(method.name, null) then
		return;
	endif;
	
	app.writeLog(method.qualifiedName &amp; " Cleaning up orphaned CM_Strings objects", LogINFO);

	beginTransaction;
	foreach stringObj in CM_Strings.instances do
		if stringObj.myObject = null then
			delete stringObj;
			
			deleteCount := deleteCount + 1;
			if deleteCount mod 2000 = 0 then		// Don't want too many deletes in a single transaction
				commitTransaction;
				beginTransaction;
			endif;
		endif;
	endforeach;
	commitTransaction;
	
	self.addScriptRun(method.name);
	
	app.writeLog(method.qualifiedName &amp; " Cleaning up orphaned CM_Strings objects complete, " &amp; deleteCount.String &amp; " objects deleted", LogINFO);

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="clearHazardCodesFromUNDG" id="6d9257e6-363e-469f-93b6-74d339983117">
        <updating/>
        <source>clearHazardCodesFromUNDG() updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 10/06/2015	cnwdap1		Initial creation PAR #36421 Hazadrous Materials Handling
//
vars
	undg 		: CM_UNDangerousGoods;
	code, str 	: String;
	
begin
	app.writeLog(method.qualifiedName &amp; " Clearing allClassCodes array on CM_UNDangerousGoods instances", LogINFO);
	
	beginTransaction;
	foreach undg in CM_UNDangerousGoods.instances where not undg.allClassCodes.isEmpty do
		undg.allClassCodes.clear;
	endforeach;
	commitTransaction;
	
	app.writeLog(method.qualifiedName &amp; " Completed clearing allClassCodes array on CM_UNDangerousGoods instances", LogINFO);
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="convertCashReceiptReleaseDate" id="9b07a7f1-f2ec-426b-aa5e-262aebf108fb">
        <source>convertCashReceiptReleaseDate();
//
// Purpose:			Convert object extension data to new attribute on CM_CashReceipt
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 22/06/2015	cnwjre1		From 36457, cash receipt ship release date was saved in allExtraData, now in attribute shipReleaseDate
//
vars
	cashReceipt	: CM_CashReceipt;
	count		: Integer;
	releaseDate	: Date;

begin
	app.writeLog(method.qualifiedName &amp; " Upgrading cash receipt ship release date from 8.4.1 to 8.4.2", LogINFO);
	
	beginTransaction;
	foreach cashReceipt in CM_CashReceipt.instances do
		releaseDate := cashReceipt.getShipReleaseDateCONV;
		if releaseDate &lt;&gt; null then
			cashReceipt.setShipReleaseDate(releaseDate);
			cashReceipt.setShipReleaseDateCONV(null);
			count := count + 1;
		endif;
	endforeach;
	commitTransaction;
	
	app.writeLog(method.qualifiedName &amp; " Completed upgrading cash receipt ship release date from 8.4.1 to 8.4.2, " &amp; count.String &amp; " updates", LogINFO);	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="convertEDIVoyageTIHMSdata" id="2c4f448c-bf24-4791-b058-2912acd71c16">
        <source>convertEDIVoyageTIHMSdata();

/*

Purpose:	par 36509 		we used allExtraData for some elements in 8.4.1 ( tidalClassArrival, TidalClassDeparture ) now we need to convert to standard data

Parameters:			

Return Value:		


Date		Who		Reason
14 July 2015	cnwrd1	Initial creation

*/

vars
	aVoyageTi : CM_EDIVoyageTI;
	tca,
	tcd : String;
	count : Integer;
	
begin

	app.writeLog(method.qualifiedName &amp; " Converting CM_EDIVoyageTI extra data for tidalClassArrival, TidalClassDeparture ", LogINFO);

	beginTransaction;
	
// need to loop through all CM_EDIVoyageTI and set the values from the extra data
	foreach aVoyageTi in CM_EDIVoyageTI.instances do
		
		count := count +1;
		
		tca := aVoyageTi.getTidalClassArrival();
		tcd := aVoyageTi.getTidalClassDeparture();
		
		if tca &lt;&gt; null then
			aVoyageTi.tidalClassArrival := tca;
		endif;
		
		if tcd &lt;&gt; null then
			aVoyageTi.tidalClassDeparture := tcd;	
		endif;
	

		
	endforeach;

	commitTransaction;
	
	app.writeLog(method.qualifiedName &amp; " Converting CM_EDIVoyageTI extra data  Completed - " &amp; count.String &amp; " objects checked", LogINFO);
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="convertFutureStorageMappings" id="c6a5a1b9-b6af-4538-994e-73f98fe7b0df">
        <source>convertFutureStorageMappings();
/*
Purpose:		CCMS 2490 TFS 333	
Date		Who		Reason
21 May 2015	cnwab1	Initial creation
*/

vars
	iter01 : Iterator;
	fsm : CM_FutureStorageMapping;
	oArray : ObjectArray; 
	ftm : CM_FutureStorageMapping;
	sd : CM_StorageDetail;
	sg : CM_TerminalAreaStorageGroup;
begin
	app.writeLog(method.qualifiedName &amp; " Updating future storage mappings to have quantity ranges", LogINFO);

	create oArray transient;
	CM_FutureStorageMapping.allInstances(oArray,0,false);
	iter01 := oArray.createIterator;
	
	while iter01.next(fsm) do
	
		if fsm.myQuantityMap = null then
			beginTransaction;
			fsm.initialise();
			commitTransaction;
		endif;
		
		
	endwhile;
	
	oArray.clear();
	CM_StorageDetail.allInstances(oArray,0,false);
	iter01 := oArray.createIterator;
	
	while iter01.next(sd) do
	
		if sd.chargeDays = 0 then
			if app.myRoot.isClientDPH then
				beginTransaction;
				sd.setPropertyValue("chargeDays",30);
				commitTransaction;
			else
				beginTransaction;
				sd.setPropertyValue("chargeDays",sd.freeStorageDays);
				commitTransaction;
			endif;
		endif;
		
		
	endwhile;
	
	oArray.clear();
	CM_TerminalAreaStorageGroup.allInstances(oArray,0,false);
	iter01 := oArray.createIterator;
	
	while iter01.next(sg) do
	
		beginTransaction;
		sg.initialise();
		commitTransaction;
	endwhile;
	
	
epilog
	delete oArray;

end;




</source>
    </JadeMethod>
    <JadeMethod name="convertGTETemperatures" id="623b66aa-93b0-4343-9421-7a314394f2f1">
        <source>convertGTETemperatures();
//
// Purpose:			Convert object extension data to new attribute on CMGTE_Receivel
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 01/05/2015	cnwdap1		Initial creation PAR #36094 CCMS SFW 1413 TFS 313 Cold Store Enhancements
//
vars
	receival : CMGTE_Receival;

begin
	app.writeLog(method.qualifiedName &amp; " Upgrading receival temperature from 8.4.1 to 8.4.2", LogINFO);
	
	beginTransaction;
	foreach receival in CMGTE_Receival.instances do
		receival.convertExtensionObjectValue(Obj_Extn_receivalTemperature, CMGTE_Receival::receivalTemperature);
	endforeach;
	commitTransaction;
	
	app.writeLog(method.qualifiedName &amp; " Completed upgrading receival temperature from 8.4.1 to 8.4.2", LogINFO);	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="fixInvoiceReportTemplates" id="34b072a2-ee7c-4068-b222-2eeddc1de781">
        <source>fixInvoiceReportTemplates();
/*

Purpose:			Fix any Invoice Report Templates which have been corrupted by the Report
					Runner UI bug reported in PARs #36903 &amp; 36755

Parameters:			None

Return Value:		None

Date		Who		Reason
02 Dec 2015	cnwkpd1	PAR #36903 - Templated invoice reports not working correctly

*/

vars
	ci				: CMQF_Invoice;
	oa				: ObjectArray;
	iter			: Iterator;
	firstBank		: CM_Bank;
	firstTerminal	: CM_Terminal;
	msg				: String;
	templates,
	badCount		: Integer;
	
begin
	if self.hasScriptBeenRunAtAll(method.name, null) then
		return;
	endif;
	
	app.writeLog(method.qualifiedName &amp; " checking Invoice Report Templates", null);
	
	create oa transient;
	CMQF_Invoice.allInstances(oa, 0, true);

	beginTransaction;
	
	iter := oa.createIterator();
	while iter.next(ci) do
		if ci.myBGPRequest &lt;&gt; null and ci.myBGPRequest.myReportTemplate &lt;&gt; null then
		
			templates := templates + 1;
			
			// Can only have one company, but checking anyway
			if ci.allCompaniesByCode.size() = 1 and ci.allTerminals.size() = 1 then
			
				firstBank := ci.allCompaniesByCode.first();
				firstTerminal := ci.allTerminals.first();
			
				msg := "No company";
				if app.isValidObject(firstBank) then
					if firstBank.terminal = firstTerminal then
						msg := "Company matches first Terminal";
					else
						msg := "&gt;&gt;&gt;&gt; Company does not match first Terminal, updated";
						ci.allCompaniesByCode.clear();
						ci.allCompaniesByCode.add(firstTerminal.companies.first());
						badCount := badCount + 1;
					endif;
				endif;
			
				app.writeLog(ci.myBGPRequest.myReportTemplate.name &amp; " " &amp; firstBank.String &amp; " " &amp; firstTerminal.String &amp; " " &amp; msg, 0);
			endif;
		endif;	
	endwhile;
	
	commitTransaction;
	
	app.writeLog(method.qualifiedName &amp; templates.String &amp; " templates checked, " &amp; badCount.String &amp; " errors found and fixed", 0);
	
	self.addScriptRun(method.name);

		
epilog
	delete oa;

end;</source>
    </JadeMethod>
    <JadeMethod name="fixUserDefinedEDIMeasureTypes" id="308cdfc3-50bc-41f9-82ad-dfab3631ff4b">
        <source>fixUserDefinedEDIMeasureTypes();
// TFS 2134 when user-defined EDI file types were exported and loaded they used the default measurement type rather than 
//   the actual measurement type, resulting in incorrect data values for these fields.
// This code 
//
vars
	entTableGroup		: EntTableGroup;
	ediFileType			: CM_EDIFileType;
	fileTypeUser		: CM_EDIFileTypeUser;
	fieldMappingType	: CM_EDIFieldMappingType;
	fieldMapping		: CM_EDIFieldMapping;
	len,
	pos					: Integer;
	shortName			: String;
	fieldDesc			: String;
	propNameStr			: String;
	entTableRow			: EntTableRow;
	measure				: CM_MeasurementType;

begin
	if self.hasScriptBeenRunAtAll(method.name, null) then
		return;
	endif;
	
	entTableGroup := app.myRoot.myEntTableDataRoot.allEntTableGroups[ETGrp_EdiMaint];
	if entTableGroup = null then
		return;
	endif;
	app.writeLog(method.qualifiedName &amp; ": updating user-defined EDI file measurement types", LogINFO);

	beginTransaction;
	foreach ediFileType in app.myRoot.allEDIFileTypes do
		if ediFileType.type &lt;&gt; EDIFileType_UserDefined then
			continue;
		endif;
		fileTypeUser := ediFileType.CM_EDIFileTypeUser;
		foreach fieldMappingType in fileTypeUser.allEDIFieldMappingTypes do
		
			if fieldMappingType.allEDIFieldMappings.isEmpty() then
				// no field mapings to process
				continue;
			endif;
			
			foreach fieldMapping in fieldMappingType.allEDIFieldMappings do
				if fieldMapping.myMeasurementType = null then
					continue;
				endif;
				propNameStr	:= fieldMapping.propName;
				
				shortName := "";
				pos := 0;
				// TFS 2134 get the measurement type short name from the end of the field description and use this to get the measurement type
				fieldDesc := fieldMapping.fieldDescr;
				if fieldDesc[fieldDesc.length:1] = ")" then
					pos := fieldDesc.reversePos("(");
					if pos &gt; 0 then
						len := fieldDesc.length-(pos+1);
						if len &gt; 0 then
							shortName := fieldDesc[pos+1:len];
						endif;
					endif;
				endif;
				measure := null;
				if shortName &lt;&gt; "" then
					measure := app.myRoot.allMeasurementTypesByShortName[shortName];
				endif;
				// if not found then use the default measurement type
				if measure = null then
					// find the ent table row for this propName in the EDIMaint Ent Table Group 
					// and see if it has a measurement type
					entTableRow := entTableGroup.allEntTableRowsByName[propNameStr];
					if entTableRow = null or entTableRow.measurementType = null then
						continue;
					endif;
					measure := app.getDefaultMeasurementForType(entTableRow.measurementType);
					// if the default one is used, change the field description to match to make it clear what has happened
					if measure &lt;&gt; null then
						if pos &gt; 1 then
							fieldDesc := fieldDesc[1:pos] &amp; measure.shortName &amp; ")";
							fieldMapping.setFieldDescr(fieldDesc);
						endif;
					endif;
				endif;
				if measure = null then
					continue;
				endif;
				
				// update the field mapping with the found measurement type, if different
				if measure &lt;&gt; fieldMapping.myMeasurementType then
					fieldMapping.setMeasurementType(measure);
					app.writeLog("File type '" &amp; ediFileType.name &amp; "' Field Mapping '" &amp; fieldMapping.fieldDescr &amp; "' measurement type changed to " &amp; measure.name, LogINFO);
				endif;
			endforeach;
			
		endforeach;
	endforeach;
	commitTransaction;
	
	app.writeLog(method.qualifiedName &amp; ": updating user-defined EDI file measurement types complete.", LogINFO);
	
	self.addScriptRun(method.name);

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="fixupMaintViewPermission" id="ea3be669-2843-4b94-b201-aa4e9704182f">
        <source>fixupMaintViewPermission();
/*
Purpose:			
Date		Who		Reason
12 July 2016	cnwab1	Initial creation
*/



vars
	root : CM_Root;
	termSecRole : CM_SecurityRole;
	sysSecRole : CM_SecurityRole;
begin
	if self.hasScriptBeenRunThisRelease(method.name, null) then
		return;
	endif;

	app.writeLog(method.qualifiedName &amp; " Cleaning up View Only Maint Permissions", LogINFO);


	// #### TERMINAL NEW MAINT PERMISSIONS
	root := CM_Root.firstInstance();
	termSecRole := root.mySecurityRoleTerminal;
	
	beginTransaction;
		termSecRole.zfixupMaintViewPermission(PmAdmActivityHistoryMaint, PmAdmActivityHistoryView, false);
		termSecRole.zfixupMaintViewPermission(PMJobRequestMaint, PmJobRequestView, false);
		termSecRole.zfixupMaintViewPermission(PmAdmBBLKCEDOMaint, PmAdmBBLKCEDO, false);
		termSecRole.zfixupMaintViewPermission(PmEventReqNotifyView, PmEventReqNotifyMaint, false);
		termSecRole.zfixupMaintViewPermission(PmLogDocketReconMaint, PmLogDocketRecon, false);
		termSecRole.zfixupMaintViewPermission(PmAdmRejectTrackedItemMaint, PmAdmRejectTrackedItem, false);
		termSecRole.zfixupMaintViewPermission(PmAdmInvLDebtrConMaint, PmAdmInvLDebtrConView, false);
		termSecRole.zfixupMaintViewPermission(PmAdmCashConfigMaint , PmAdmCashConfig, false);
		termSecRole.zfixupMaintViewPermission(PmGteCashCollectionMaint, PmGteCashCollection, false);
		termSecRole.zfixupMaintViewPermission(PmAdmInvCashDrTrxMaint , PmAdmInvCashDrTrx, false);
		termSecRole.zfixupMaintViewPermission(PmGteDutyDocEnquiryMaint, PmGteDutyDocEnquiry, false);
		termSecRole.zfixupMaintViewPermission(PmGteDutyDocItemEnquiryMaint, PmGteDutyDocItemEnquiry, false);
		termSecRole.zfixupMaintViewPermission(PmLogLoadOutReconView, PmLogLoadOutReconMaint, false);
		termSecRole.zfixupMaintViewPermission(PmLogRegradeView, PmLogRegradeMaint, false);
		termSecRole.zfixupMaintViewPermission(PmLogDisassembleMaintMaint, PmLogDisassembleMaint, false);
		termSecRole.zfixupMaintViewPermission(PmLogTransitTransferMaintMaint, PmLogTransitTransferMaint, false);
		termSecRole.zfixupMaintViewPermission(PmLogTransitTransferMaintMaint, PmLogTransitTransferMaint, false);
		termSecRole.zfixupMaintViewPermission(PmLogTransitTransferMaintMaint, PmLogTransitTransferMaint, false);
		termSecRole.zfixupMaintViewPermission(PmShipCargoCounterMaint, PmShipCargoCounterView, false);
		termSecRole.zfixupMaintViewPermission(PmAdmSatelliteViewDefnMaint, PmAdmSatelliteViewDefinition, false);
		termSecRole.zfixupMaintViewPermission(PmAdmAuditTALocationMaint, PmAdmAuditTALocationView, false);
		termSecRole.zfixupMaintViewPermission(PmAdmSpaceUtiliMaint, PmAdmSpaceUtiliView, false);
		termSecRole.zfixupMaintViewPermission(PmAdmStorageConfigMaint, PmAdmStorageConfig, false);
		termSecRole.zfixupMaintViewPermission(PmAdmVehicleAppConfigMaint, PmAdmVehicleAppConfigView, false);
		termSecRole.zfixupMaintViewPermission(PmAdmEDISenderMaintMaint, PmAdmEDISenderMaint, false);
		termSecRole.zfixupMaintViewPermission(PmRTDeviceMaintMaint, PmRTDeviceMaint, false);
		//termSecRole.zfixupMaintViewPermission(PmRTINterfaceMaint, PmRTInterface, false);			// TFS 43007 Remove Teklogix jlgmd1 04/02/2019
		termSecRole.zfixupMaintViewPermission(PmVoyageSelectorMaint, PmVoyageSelector, false);
		termSecRole.zfixupMaintViewPermission(PmAdmCandhsummaryMaint, PmAdmCandhsummaryView, false);
		termSecRole.zfixupMaintViewPermission(PmShipOperationsMaint, PmShipOperationsView, false);
		termSecRole.zfixupMaintViewPermission(PmAdmShipProfileMaint, PmAdmShipProfile, false);
		termSecRole.zfixupMaintViewPermission(PmVoyageBulkPlanningMaint, PmVoyageBulkPlanningView, false);
		termSecRole.zfixupMaintViewPermission(PmTerminalAreaEnqMaint, PmTerminalAreaEnq, false);
		termSecRole.zfixupMaintViewPermission(PmAdmTrainEnquiryMaint, PmAdmTrainEnquiryView, false);
		termSecRole.zfixupMaintViewPermission(PmFaultEnquiryMaint, PmFaultEnquiryView, false);
		termSecRole.zfixupMaintViewPermission(PmAdmRoadopsdualMaint, PmAdmRoadopsdualView, false);
		termSecRole.zfixupMaintViewPermission(PmAdmWorkOrderEnqMaint, PmAdmWorkOrderEnquiry, false);
		termSecRole.zfixupMaintViewPermission(PmAdmWorkManagerMaint, PmAdmWorkManagerView, false);
	commitTransaction;

	// #### SYSTEM NEW MAINT PERMISSIONS
	root := CM_Root.firstInstance();
	sysSecRole := root.mySecurityRoleSystem;
	
	beginTransaction;
		sysSecRole.zfixupMaintViewPermission(PmWebPageLoaderMaint, PmWebPageLoaderView, false);
