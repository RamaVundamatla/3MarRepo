    <JadeMethod name="setProxy" id="0777b069-3d47-43da-9242-4963f3580887">
        <updating/>
        <source>setProxy(_dischargePort		: String;
		 _operator 			: CM_Operator;
		 _terminal 			: CM_Terminal;
		 _voyage			: CM_Voyage;
		_orderDate			: Date;
	    _orderNo			: String;
		_transportMode		: Integer;
		_type				: Integer) updating;
//--------------------------------------------------------------
//Created: 23 July 2002 By: cnwgd1
//--------------------------------------------------------------
vars

begin
	self.setProxyForStockOrderHdr(_dischargePort, _operator, _terminal, _voyage, _orderDate, null, _orderNo, _transportMode, _type, Process_Direct_Loadout, false,false);
		
end;</source>
        <Parameter name="_dischargePort" type="String"/>
        <Parameter name="_operator" type="CM_Operator"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_orderDate" type="Date"/>
        <Parameter name="_orderNo" type="String"/>
        <Parameter name="_transportMode" type="Integer"/>
        <Parameter name="_type" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="validateDetailsUnique" id="c2765ecd-1a45-4dde-8f76-6bf9647f7d06">
