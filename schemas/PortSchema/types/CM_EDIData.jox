    <JadeMethod name="canBeCancelled" id="13995e97-d854-4afd-9d89-7e2570bd4448">
        <source>canBeCancelled() : Boolean;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 17/11/2022	navdap1		Initial creation TFS 55084 EUP - EDI Administration Usability Requirements
//
vars

begin
	return self.status.isOneOf(	CM_EDIFile.EDI_STATUS_LOADED, 
								CM_EDIFile.EDI_STATUS_LOADED_ERRORS,
								CM_EDIFile.EDI_STATUS_VERIFIED,
								CM_EDIFile.EDI_STATUS_VERIFIED_ERRORS,
								CM_EDIFile.EDI_STATUS_VERIFIED_WARNINGS,
								CM_EDIFile.EDI_STATUS_VERIFY_ERRORS_X,
								CM_EDIFile.EDI_STATUS_REVOKED,
								CM_EDIFile.EDI_STATUS_UNPROCESSED	);
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="canBeDBLoaded" id="0c4867ed-5abd-4324-a635-24599cba19df">
        <source>canBeDBLoaded():Boolean;
/*
Date		Who		Reason
01 Aug 2012	cnwcs5	Initial creation - par 30136
// 08 Jan 2018	jlgrs1	TFS 36430 Penn Ship Manifest too many locks
//20 Mar 2023 	navra1 	TFS 57125 - A revoked EDI should be DB loadable
//05 Sep 2023	jlirs1	TFS 55282 MTN - EDI Load DB from EDI Ops Screen via BGP
*/
vars
	status	:Integer;
	result	:Boolean;
begin
	status := self.status;
	
	result := status = CM_EDIFile.EDI_STATUS_VERIFIED or	
				status = CM_EDIFile.EDI_STATUS_VERIFIED_WARNINGS or
				status = CM_EDIFile.EDI_STATUS_LOCKERROR or
				status = CM_EDIFile.EDI_STATUS_DBLOADED_PARTIAL or
				status = CM_EDIFile.EDI_STATUS_DBLOADED_ERRORS or
				status = CM_EDIFile.EDI_STATUS_REVOKED or						//navra1 - TFS 57125 - 20th Mar 2023
				status = CM_EDIFile.EDI_STATUS_QUEUED_FOR_BGP;					//05 Sep 2023	jlirs1	TFS 55282 MTN - EDI Load DB from EDI Ops Screen via BGP

	return result;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
