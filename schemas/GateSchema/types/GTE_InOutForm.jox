        <updating/>
        <source>initTblInMain(pTbl : CM_EntryTable input) updating;
// ---------------------------------------------------------------------------
// Created:     07 November 2000 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
begin
	self.myAssistant.GTE_Assistant.receival_InitTblMain(pTbl);
	pTbl.hideRowByName(ETRow_TransportMode, true);
	pTbl.hideRowByName(ETRow_ReceiptTransportMode, true);
	
	self.setColorsForEntryTable(pTbl);
end;</source>
        <Parameter name="pTbl" type="CM_EntryTable" usage="input"/>
    </JadeMethod>
    <JadeMethod name="initTblInOutCommon" id="4690fd49-ffc0-4c98-a1e5-4a38c7529583">
        <updating/>
        <source>initTblInOutCommon(_tbl : CM_EntryTable input) updating;
// ---------------------------------------------------------------------------
// Created:     09 November 2000 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	entTableDef		: EntTableDef;
	theRow			: Integer;
	ta	: CM_TerminalArea;
	str				: String;
	hideBat			: Boolean;
	hideArea		: Boolean;
	gate, gateDefaultEntry: CM_Gate;
begin

	_tbl.warningMethod := 'entTableWarning';
	entTableDef := app.myController.getEntTableDef(ETDef_InOutCommon);

	_tbl.setEntTableDef(entTableDef, 'getCellControl', 'entTableDefSetupWarning');
	_tbl.adjustHeight(200);
	_tbl.optimiseHeadingColumn();
	_tbl.disableRowByName(ETRow_TareWeight);
	_tbl.enableEvent('lostFocus', false);
	_tbl.enableEvent('change', true);
	_tbl.enableEvent('queryRowColChg', false);
	
//	_tbl.enableEvent('rowColumnChg', false);

//	self.myAssistant.comboBoxCarrier(cmbCarrier, null);	
	//th2 PAR 14254 - don't clear out the carrier
	//self.cmbCarrier.setObject(null);
//	self.cmbCarrier.style := ComboBox.Style_DropDownComboList;
	self.cmbTILCTypes.includeOffsite := true;
	self.cmbTILCTypes.myTerminal := self.myTerminal;
	self.cmbTILCTypes.setObject(null);
	
	self.cmbTILCOut.myTerminal := self.myTerminal;
	self.cmbTILCOut.setObject(null);
	self.cmbTILCOut.checkOperator := true;
	self.cmbTILCOut.includeOnsite := true;
		
	self.myAssistant.comboBoxTILCType(self.cmbTILCType, null);	// par 30852 Dec 2012 Change of signature
	
	hideBat := self.myTerminal.getConfig(GateInOutHideBatNumber).Boolean;
	if hideBat then
		theRow := _tbl.getRow(ETRow_BatNumber);
		_tbl.hideRow(theRow);
	else
		self.myAssistant.comboBoxBatNumber(self.tblCommon, ETRow_BatNumber, null);	
	endif;

	// Setup the Gate Entry field. This is always hidden
	theRow := _tbl.getRow(ETRow_GateEntry);
	_tbl.hideRow(theRow);
	gateDefaultEntry := self.myTerminal.getConfig(GateDefaultEntry).CM_Gate;
	
// cnwdad1 18/01/2010 - PAR #22152.
	if gateDefaultEntry &lt;&gt; null then
		_tbl.setValue(theRow, gateDefaultEntry.name);
	endif;
	
	// Setup Interchange Area
	hideArea := self.myTerminal.getConfig(GateInOutHideArea).Boolean;
	theRow := _tbl.getRow(ETRow_RoadTransAreaId);
	if hideArea then 
		_tbl.hideRow(theRow);
		_tbl.setValue(theRow, "");
	else
		// 21313 - Show all the Yard Interchange Areas
		foreach ta in self.myTerminal.allTerminalAreas where ta.type = TA_TYPE_YARD_INTERCHANGE do
			if str &lt;&gt; null then
				str := str &amp; Tab;
			endif;
			str := str &amp; ta.id.trimRight;
		endforeach;
	
		_tbl.setComboValues(theRow, str);
		if gateDefaultEntry &lt;&gt; null and gateDefaultEntry.myDefaultInterchangeArea &lt;&gt; null then
			_tbl.setValue(theRow, gateDefaultEntry.myDefaultInterchangeArea.id);  // 21313
		endif;
	endif;
	
	if (not self.myTerminal.getConfig(GateInAllowAutoComplete).Boolean) or
	   (self.myTerminal.getConfig(GateIOHideAutoComplete).Boolean) then
		_tbl.hideRowByName(ETRow_AutoComplete, true);	
	endif;
	
	// DVB changed to use new flags 05/04/05
	if not app.isInterTerminalTransferEnabled() then
		_tbl.hideRowByName(ETRow_MyTransferToTerminal, true);	
	endif;

	if (not self.myTerminal.getConfig(GateInVehicleTareWeight).Boolean) then
		_tbl.hideRowByName(ETRow_TareWeight, false);	
	endif;
	
	if _tbl.accessRow(_tbl.getRow(ETRow_IsReceiptRequired)).visible then
		_tbl.setValueByName(ETRow_IsReceiptRequired, self.myTerminal.getConfig(GateReceiptRequired).String.trimRight);
	endif;
	
	_tbl.hideRowByName(ETRow_ChassisOutType, false);
	_tbl.hideRowByName(ETRow_ChassisNumOut, false);
	_tbl.hideRowByName(ETRow_ChassisOperator, false);
	
	//CCMS1015 Adding Chassis through Gate
// Do NOT show chassis in Gate In/Out form for anyone - use new FlexiGate instead
//	if not app.myRoot.canDo(PmTrailer) then
		_tbl.hideRowByName(ETRow_ChassisNoIn, false);
		_tbl.hideRowByName(ETRow_ChassisNumReq, false);
//	endif;
	
	if app.isSubTerminalsOn(self.myTerminal) then
		self.myAssistant.comboBoxSubTerminal(cmbSubTerminal, null, self.myTerminal);
	else
		_tbl.hideRowByName(ETRow_MySubTerminal, false);
	endif;
end;</source>
        <Parameter name="_tbl" type="CM_EntryTable" usage="input"/>
    </JadeMethod>
    <JadeMethod name="initTblOutEmptyMain" id="99e28a92-01f2-41f0-8e7e-2ff747a7670e">
        <updating/>
        <source>initTblOutEmptyMain(tbl : CM_EntryTable input) updating;
// ---------------------------------------------------------------------------
// Created:     11 January 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
begin

//	tbl.setValueByName('releaseByType', true);

	tbl.setComboValues(tbl.getRow(ETRow_DeliveryReason), 
						DELSTR_SNT &amp; Tab &amp;
						DELSTR_IST &amp; Tab &amp;
						DELSTR_NIB);

	tbl.setValue(tbl.getRow(ETRow_DeliveryReason), DELSTR_SNT);						

	self.myAssistant.comboBoxPowerRequirements(tbl, ETRow_PowerRequirements, POWER_NONE, true);
	
	tbl.setValueByName(ETRow_QuantityTxt, 1);

end;</source>
        <Parameter name="tbl" type="CM_EntryTable" usage="input"/>
