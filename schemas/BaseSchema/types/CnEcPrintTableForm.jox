    <JadeMethod name="addRowToTable" id="e5707cf6-10f1-43da-beb1-56c2bc256789">
        <source>addRowToTable(pCellValue:String);
// --------------------------------------------------------------------------------
// Created:		05 April 2006 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	rowPointer	: Integer;
	colPointer	: Integer;
	accessMode	: Integer;
	cellText	: String;
	
begin
	rowPointer	:=	self.tblPrint.addItem(pCellValue);
	accessMode	:=	self.tblPrint.accessMode;
	self.tblPrint.accessMode	:=	Table.AccessMode_Cell;
	
	foreach colPointer in 1 to tblPrint.columns do
		if (not self.tblPrint.columnVisible[colPointer]) then
			self.tblPrint.columnWidth[colPointer]	:=	0;
			continue;
		endif;
		
		cellText	:=	self.tblPrint.accessCell(rowPointer, colPointer).text;
		
		if rowPointer = 1 then
			self.tblPrint.columnWidth[colPointer]	:=	self.tblPrint.getTextExtent(cellText) + 4;
		else
			self.tblPrint.columnWidth[colPointer]	:=	self.tblPrint.columnWidth[colPointer].max(self.tblPrint.getTextExtent(cellText) + 4);
		endif;
	endforeach;
epilog
	self.tblPrint.accessMode	:=	accessMode;
end;</source>
        <Parameter name="pCellValue" type="String"/>
    </JadeMethod>
    <JadeMethod name="copyTable" id="d921e21f-8b3d-4bff-950d-59192841f128">
        <updating/>
        <source>copyTable(pTableInObj:Table input; pInvisibleFixedRows:Integer; pInvisibleFixedCols:Integer) updating, protected;
// --------------------------------------------------------------------------------
// Created:		05 April 2006 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	tableObj		: Table;
	sheetObj		: JadeTableSheet;
	cellObj			: JadeTableCell;
	saveRow			: Integer;
	saveCol			: Integer;
	saveAccessMode	: Integer;
	rowPointer		: Integer;
	colPointer		: Integer;
	colOffset		: Integer;
	rowOffset		: Integer;
	tmpTextExtent	: Integer;
	magicNumber		: Integer;
	frameObj		: Frame;
	
begin
	create frameObj transient;
	
	sheetObj	:=	pTableInObj.accessSheet(pTableInObj.topSheet);
	
	tableObj				:=	tblPrint;
	tableObj.rows			:=	sheetObj.rows;
	tableObj.columns		:=	sheetObj.columns;
	tableObj.fixedRows		:=	sheetObj.fixedRows - pInvisibleFixedRows;
	tableObj.fixedColumns	:=	sheetObj.fixedColumns - pInvisibleFixedCols;
	tableObj.alignment		:=	pTableInObj.alignment;
	
	saveRow					:=	sheetObj.row;
	saveCol					:=	sheetObj.column;
	saveAccessMode			:=	pTableInObj.accessMode;
	pTableInObj.accessMode	:=	Table.AccessMode_Cell;
	tableObj.accessMode		:=	Table.AccessMode_Cell;
	
	rowPointer	:=	1;
	colPointer	:=	1;
	rowOffset	:=	0;
	
//	while row &lt;= tblIn.rows do : rowLoop  // changed as would cause an error if printing a sheet that had less rows than parent table
//		if not tblIn.rowVisible[row] then
	while rowPointer &lt;= sheetObj.rows do : rowLoop
		if not sheetObj.accessRow(rowPointer).visible then
			rowOffset	:=	rowOffset + 1;
			rowPointer	:=	rowPointer + 1;
			continue;
		endif;
	
		colPointer	:=	1;
		colOffset	:=	0;
		
//		while column &lt;= tblIn.columns do : columnLoop  // changed as would cause an error if printing a sheet that had less columns than parent table
//			if not  tblIn.columnVisible[column] then
		while colPointer &lt;= sheetObj.columns do : columnLoop
			if not sheetObj.accessColumn(colPointer).visible then
				colOffset	:=	colOffset + 1;
				colPointer	:=	colPointer + 1;
				continue;
			endif;
			
			tableObj.row	:=	rowPointer - rowOffset;			//rowOffset should be the number of invisible rows encountered
			tableObj.column	:=	colPointer - colOffset;		//colOffset should be the number of invisible columns encountered
			sheetObj.row	:=	rowPointer;
			sheetObj.column	:=	colPointer;

			// Text
			cellObj					:=	sheetObj.accessCell(rowPointer, colPointer);
			tableObj.text			:=	cellObj.text;
			// Alignment
			tableObj.alignment		:=	cellObj.alignment;
			// Font
			tableObj.fontBold		:=	cellObj.fontBold;
			tableObj.fontItalic		:=	cellObj.fontItalic;
			tableObj.fontName		:=	cellObj.fontName;
			tableObj.fontSize		:=	cellObj.fontSize;
			tableObj.fontStrikethru	:=	cellObj.fontStrikethru;
			tableObj.fontUnderline	:=	cellObj.fontUnderline;
			
			// Colour
			if self.aIsWhiteBackground then
				tableObj.foreColor	:=	Black;
				tableObj.backColor	:=	White;
			else
				tableObj.foreColor	:=	cellObj.foreColor;
				tableObj.backColor	:=	cellObj.backColor;
			endif;
			
			// GridLines
			tableObj.gridLines	:=	sheetObj.gridLines;
			tableObj.gridColor	:=	sheetObj.gridColor;
			// Picture
			tableObj.picture	:=	cellObj.picture;

			// ### AKB2004OCT added this to print Yes/No for check boxes
			if ( cellObj.cellControl &lt;&gt; null and cellObj.cellControl.isKindOf(CheckBox))
			or cellObj.inputType = Table.InputType_CheckBox
			then
				if cellObj.text.Integer = 0 then 
					tableObj.text	:=	"  No";
				else
					tableObj.text	:=	"  Yes";
				endif;
			endif;
			
			//magicNumber := 15;	//was 4  - changed for unknown reason			Jul 04
			//magicNumber := 12;	//was 15 but columns are spilling over			Dec 04
			//magicNumber := 7;		//was 12 but columns are still spilling over	Jan 05
			magicNumber	:=	5;		//was 7 - saving space							Feb 06

			// done the following way as table.getTextExtent does not return the correct value
			frameObj.fontItalic	:=	cellObj.fontItalic;
			frameObj.fontName	:=	cellObj.fontName;
			frameObj.fontSize	:=	cellObj.fontSize;
			frameObj.fontBold	:=	cellObj.fontBold;
			tmpTextExtent		:=	frameObj.getTextExtent(tableObj.text) + magicNumber;
			
//			tmpTextExtent := table.getTextExtent(table.text);
			
			if rowPointer = 1 then
				if pTableInObj.columnWidth[colPointer] = 1 then	//formatting - leave as is
					tableObj.columnWidth[colPointer - colOffset]	:=	1;
				elseif self.aIsOrigTableColumnWidths then
					tableObj.columnWidth[colPointer - colOffset]	:=	pTableInObj.columnWidth[colPointer].max(tmpTextExtent);
				else
					tableObj.columnWidth[colPointer - colOffset]	:=	tmpTextExtent;
				endif;
			else
				if pTableInObj.columnWidth[colPointer] = 1 then	//formatting - leave as is
					tableObj.columnWidth[colPointer - colOffset]	:=	1;
				else
					tableObj.columnWidth[colPointer - colOffset]	:=	tableObj.columnWidth[colPointer-colOffset].max(tmpTextExtent);
				endif;
			endif;

			colPointer	:=	colPointer + 1;
		endwhile;
		
		tableObj.rowHeight[rowPointer - rowOffset]	:=	sheetObj.accessRow(rowPointer).height;
		tableObj.accessRow(rowPointer - rowOffset).itemObject	:=	sheetObj.accessRow(rowPointer).itemObject;
		rowPointer	:=	rowPointer + 1;
	endwhile;
	
	//remove empty cols/rows
	tableObj.columns		:=	sheetObj.columns-colOffset;
	tableObj.rows			:=	sheetObj.rows-rowOffset;
	
	pTableInObj.accessMode	:=	saveAccessMode;
	sheetObj.column			:=	saveCol;
	sheetObj.row			:=	saveRow;
epilog
	delete frameObj;
end;</source>
        <access>protected</access>
        <Parameter name="pTableInObj" type="Table" usage="input"/>
        <Parameter name="pInvisibleFixedRows" type="Integer"/>
        <Parameter name="pInvisibleFixedCols" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="create" id="729bfd12-e830-4b61-8b59-8638660a4a2a">
        <updating/>
        <executionLocation>client</executionLocation>
        <source>create() updating, clientExecution;
// --------------------------------------------------------------------------------
// Created:		05 April 2006 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.aIsOrigTableColumnWidths	:=	true;
end;</source>
    </JadeMethod>
    <JadeMethod name="getNextTablePos" id="853af271-f7b8-45ae-bc2f-5e20df94b0ca">
        <updating/>
        <source>getNextTablePos(pFrameObj:Frame input;
				pTableObj:Table input;
				pNextTopRow:Integer io; 
				pNextLeftColumn:Integer io;
				pFixedRows:Integer;
				pFixedColumns:Integer) updating, protected;
// --------------------------------------------------------------------------------
// Created:		05 April 2006 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
constants
	Height_Correction	: Real = 2;
	Width_Correction	: Real= 15;
	
vars
	rowPointer		: Integer;
	colPointer		: Integer;
	rowHeight		: Integer;
	colWidth		: Integer;
	advanceTopRow:   Boolean;
	
begin
	if (pNextTopRow = pFixedRows + 1)
	and (pNextLeftColumn = pFixedColumns + 1)
	then
		advanceTopRow	:=	true;
	endif;

	colWidth	:=	self.aFixedColumnWidth;
	
	if pNextLeftColumn &gt; pTableObj.columns then
		colPointer		:=	pFixedColumns + 1;
		advanceTopRow	:=	true;
	else
		colPointer	:=	pNextLeftColumn;
	endif;
    
	pTableObj.leftColumn	:=	colPointer;
	
	while colPointer &lt;= pTableObj.columns and colWidth + pTableObj.columnWidth[colPointer] &lt;= self.aMaxTableWidth do
		if pTableObj.columnVisible[colPointer] then
			colWidth	:=	colWidth + pTableObj.columnWidth[colPointer];
		endif;
		
		colPointer	:=	colPointer + 1;
	endwhile;
	
	pNextLeftColumn	:=	colPointer;	
	pFrameObj.width	:=	colWidth + Width_Correction;
   
	if advanceTopRow then
		rowHeight			:=	self.aFixedRowHeight;
		rowPointer			:=	pNextTopRow;
		pTableObj.topRow	:=	pNextTopRow;
		
		while rowPointer &lt;= pTableObj.rows and rowHeight + pTableObj.rowHeight[rowPointer] &lt;= self.aMaxTableHeight do
			rowHeight	:=	rowHeight + pTableObj.rowHeight[rowPointer];
			rowPointer	:=	rowPointer + 1;
		endwhile;
		
		pNextTopRow			:=	rowPointer;	
		pFrameObj.height	:=	rowHeight + Height_Correction;
		pTableObj.height	:=	pFrameObj.height;
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="pFrameObj" type="Frame" usage="input"/>
        <Parameter name="pTableObj" type="Table" usage="input"/>
        <Parameter name="pNextTopRow" type="Integer" usage="io"/>
        <Parameter name="pNextLeftColumn" type="Integer" usage="io"/>
        <Parameter name="pFixedRows" type="Integer"/>
        <Parameter name="pFixedColumns" type="Integer"/>
    </JadeMethod>
