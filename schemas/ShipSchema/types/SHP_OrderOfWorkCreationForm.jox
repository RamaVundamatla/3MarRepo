    <JadeMethod name="addToolbarControls" id="39934ad4-32c2-4d07-b10e-8c7778b001e3">
        <updating/>
        <source>addToolbarControls() updating, protected;
// ---------------------------------------------------------------------------
// Created:		21 November 2005  By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	frm				: CMUI_Toolbar;
begin	
	frm := self.frmToolbar;

	frm.addButton(self.btnPrint, CMUI_Toolbar.Control_Alignment_Left);
	frm.addButton(self.btnAlloc, CMUI_Toolbar.Control_Alignment_Left);
	frm.addButton(self.btnUserColours, CMUI_Toolbar.Control_Alignment_Left);
	frm.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	
	frm.addButton(self.btnReset, CMUI_Toolbar.Control_Alignment_Left);
	frm.addButton(self.btnAutoJobs, CMUI_Toolbar.Control_Alignment_Left);
	frm.addButton(self.btnOOW, CMUI_Toolbar.Control_Alignment_Left);
	frm.addSeperator(CMUI_Toolbar.Control_Alignment_Left);

	frm.addButton(self.btnShowLift, CMUI_Toolbar.Control_Alignment_Left);
	frm.addSeperator(CMUI_Toolbar.Control_Alignment_Left);

	frm.addFrame(self.frmTBExtras, CMUI_Toolbar.Control_Alignment_Left);
	
	frm.addFrame(self.frmToolbarChk, CMUI_Toolbar.Control_Alignment_Left);
	frm.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	frm.addButton(self.btnJobPriority, CMUI_Toolbar.Control_Alignment_Left);

	inheritMethod();

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="addToolbarControlsQuery" id="b92e5189-60fa-43ae-a7b4-789a3287316c">
        <source>addToolbarControlsQuery() protected;
// ---------------------------------------------------------------------------
// Created:		21 November 2005  By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	queryToolbar			: CMUI_Toolbar;
begin

	queryToolbar := self.frmQueryToolbar;
	queryToolbar.addButton(self.btnQuery, CMUI_Toolbar.Control_Alignment_Left);
	queryToolbar.addButton(self.btnResetSearch, CMUI_Toolbar.Control_Alignment_Left);
	queryToolbar.addButton(self.btnSelectAll, CMUI_Toolbar.Control_Alignment_Left);
	queryToolbar.addButton(self.btnHideSearcher, CMUI_Toolbar.Control_Alignment_Left);

end;</source>
        <access>protected</access>
    </JadeMethod>
