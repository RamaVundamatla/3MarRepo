    <JadeMethod name="doTblCalendarClick" id="2a55f39b-d050-4c48-bc6e-48eff0d16354">
        <updating/>
        <source>doTblCalendarClick() updating;
// ---------------------------------------------------------------------------
// Created:     cnwyl1  Yi Liu
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	tbl : CM_CalendarTable; 
	r, c, day  : Integer;
begin
	tbl := self.tblCalendar;
	
	c := tbl.column;
	r := tbl.row;
	
	if r = tbl.fixedRows then
		return;
	endif;
	
	day := tbl.accessCell(r, c).text.Integer;
	if day &lt;&gt; null then
		tbl.selectedDate.setDate(day, cmbMonth.itemData[cmbMonth.listIndex], txtYear.text.Integer);
	endif;
epilog

end;</source>
