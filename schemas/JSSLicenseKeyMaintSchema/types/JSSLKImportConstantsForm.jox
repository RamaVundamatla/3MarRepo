        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="cmbSchema_click" id="ae961b34-da50-40d6-bbb7-d01b133f1d37">
        <controlMethod name="ComboBox::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbSchema_click(combobox: ComboBox input) updating;
// --------------------------------------------------------------------------------
// Created:		03 April 2003 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	app.mousePointer	:=	Busy;
	
	cmbCategory.clear();
	self.listboxClear(lstConstants);
	
	if combobox.listIndex &lt;&gt; JSS_NULL_INDEX then
		self.populateConstantCategories(combobox.listObject.Schema, cmbCategory);
	endif;
epilog
	app.mousePointer	:=	Idle;
end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="cmbSchema_displayEntry" id="4b115ecb-7cde-4ff4-b70c-6881abbf5477">
        <controlMethod name="ComboBox::displayEntry"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbSchema_displayEntry(combobox: ComboBox input; obj: Any; lstIndex: Integer):String updating;
// --------------------------------------------------------------------------------
// Created:		03 April 2003 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return obj.getName();
end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
        <Parameter name="obj" type="Any"/>
        <Parameter name="lstIndex" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="doFormLoad" id="8265bb63-1546-40d1-babe-377547f0b588">
        <updating/>
        <source>doFormLoad() updating, protected;
// --------------------------------------------------------------------------------
// Created:		03 April 2003 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	allSchemas		: SchemaColl;
	
begin
	inheritMethod();
	
	create allSchemas transient;
	rootSchema.allSubschemas(allSchemas);
	cmbSchema.listCollection(allSchemas, false, 0);
	lstProducts.listCollection(app.myRoot.allProducts, true, 0);
epilog
	delete allSchemas;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doFormUnload" id="908a2599-acc7-45a8-a4df-bf2285714282">
        <updating/>
        <source>doFormUnload() updating, protected;
// --------------------------------------------------------------------------------
// Created:		04 April 2003 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.listboxClear(lstConstants);
	
	inheritMethod();
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doFormUpdate" id="902af825-ba34-413c-8b4e-5ce41faa657a">
        <updating/>
        <source>doFormUpdate(pIsDelete: Boolean): Boolean updating, protected;
// --------------------------------------------------------------------------------
// Created:		03 April 2003 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	theImportConstant		: JSSLKImportConstant;
	allImportConstants		: JSSLKImportConstantArray;
	theListbox				: ListBox;
	listPointer				: Integer;
	constantCount			: Integer;
	isUpdateExisting		: Boolean;
	
begin
	isUpdateExisting	:=	chkIsUpdate.value;
	theListbox			:=	lstConstants;
	constantCount		:=	theListbox.listCount();
	create allImportConstants transient;
	
	foreach listPointer in 1 to constantCount do
		theImportConstant	:=	theListbox.itemObject[listPointer].JSSLKImportConstant;
		
		if theImportConstant.myProduct = null then
			continue;
		endif;
		
		allImportConstants.add(theImportConstant);
	endforeach;
	
	app.doImportGlobalConstants(allImportConstants, isUpdateExisting);
	
	return inheritMethod(pIsDelete);
epilog
	delete allImportConstants;
end;</source>
        <access>protected</access>
        <Parameter name="pIsDelete" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getAllConstantCategories" id="23f60f87-12b4-4487-b9fa-f9c6fc731587">
        <executionLocation>server</executionLocation>
        <source>getAllConstantCategories(pTheSchema:Schema; pAllCategories:StringArray input) protected, serverExecution;
// --------------------------------------------------------------------------------
// Created:		03 April 2003 by cnwdad1
//
// Purpose:		Fetches an array of Global Constant Category names.
//
// Parameters:	pTheSchema - The schema who's categories to get.
//				pAllCategories - A string array of category names.
//
// Returns:		The string array (parameter) of category names.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	theCategory	: ConstantCategory;
	
begin
	foreach theCategory in ConstantCategory.instances do
		if theCategory.getPropertyValue("schema").Schema = pTheSchema then
			pAllCategories.add(theCategory.name);
		endif;
	endforeach;
end;</source>
        <access>protected</access>
        <Parameter name="pTheSchema" type="Schema"/>
        <Parameter name="pAllCategories" type="StringArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="listboxClear" id="3e65e20c-627d-4ea5-a7a6-dfbc88832356">
        <source>listboxClear(pTheListbox:ListBox input) protected;
// --------------------------------------------------------------------------------
// Created:		04 April 2003 by cnwdad1
//
// Purpose:		Clears all list rows, while deleting the itemObject of each row as
//				it goes.
//
// Parameters:	pTheListbox - The listbox to clear.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	theImportConstant	: JSSLKImportConstant;
	
begin
	while pTheListbox.listCount() &gt; 0 do
		delete pTheListbox.itemObject[1];
		pTheListbox.removeItem(1);
	endwhile;
end;</source>
        <access>protected</access>
        <Parameter name="pTheListbox" type="ListBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="lstConstants_click" id="8f3b94cc-5385-4877-bda2-987ec11eb1b9">
        <controlMethod name="ListBox::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>lstConstants_click(listbox: ListBox input) updating;
// --------------------------------------------------------------------------------
// Created:		04 April 2003 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	theImportConstant	: JSSLKImportConstant;
	theProduct			: JSSLKProduct;
	
begin
	app.mousePointer	:=	Busy;
	
	if listbox.listIndex &lt;&gt; JSS_NULL_INDEX then
		theImportConstant	:=	listbox.itemObject[listbox.listIndex].JSSLKImportConstant;
		theProduct			:=	theImportConstant.myProduct;
		
		if theProduct = null then
			lstProducts.listIndex	:=	JSS_NULL_INDEX;
		else
			lstProducts.listIndex	:=	lstProducts.findObject(theProduct);
		endif;
	endif;
epilog
	app.mousePointer	:=	Idle;
end;</source>
        <Parameter name="listbox" type="ListBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="lstConstants_mouseDown" id="830255e5-283d-48b4-9197-33406e59a124">
        <controlMethod name="ListBox::mouseDown"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>lstConstants_mouseDown(listbox: ListBox input; button: Integer; shift: Integer; x: Real; y: Real) updating;
// --------------------------------------------------------------------------------
// Created:		04 April 2003 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	xPosition	: Real;
	yPosition	: Real;
	
begin
	if button = Window.MouseButton_Right then
		xPosition	:=	x;
		yPosition	:=	y;
		self.jssGetRelativePosition(listbox, xPosition, yPosition);
		self.popupMenu(mnuReset, xPosition.Integer, yPosition.Integer);
	endif;
end;</source>
        <Parameter name="listbox" type="ListBox" usage="input"/>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="lstProducts_click" id="06a06e9e-a805-410d-b1ea-317ac7cf91e5">
        <controlMethod name="ListBox::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>lstProducts_click(listbox: ListBox input) updating;
// --------------------------------------------------------------------------------
// Created:		04 April 2003 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	theImportConstant	: JSSLKImportConstant;
	theProduct			: JSSLKProduct;
	
begin
	app.mousePointer	:=	Busy;
	
	if lstConstants.listIndex = JSS_NULL_INDEX then
		listbox.listIndex	:=	JSS_NULL_INDEX;
		return;
	else
		if listbox.listIndex &lt;&gt; JSS_NULL_INDEX then
			theImportConstant	:=	lstConstants.itemObject[lstConstants.listIndex].JSSLKImportConstant;
			theProduct			:=	listbox.itemObject[listbox.listIndex].JSSLKProduct;
			
			if theProduct = null then
				lstProducts.listIndex	:=	JSS_NULL_INDEX;
			else
				theImportConstant.setProduct(theProduct);
				lstConstants.itemForeColor[lstConstants.listIndex]	:=	Blue;
			endif;
		endif;
	endif;
epilog
	app.mousePointer	:=	Idle;
end;</source>
        <Parameter name="listbox" type="ListBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="lstProducts_displayEntry" id="0d80c951-9688-4f41-9e7c-c36d4c293529">
        <controlMethod name="ListBox::displayEntry"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>lstProducts_displayEntry(listbox: ListBox input; obj: Any; lstIndex: Integer):String updating;
// --------------------------------------------------------------------------------
// Created:		04 April 2003 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return obj.JSSLKProduct.getDisplay();
end;</source>
        <Parameter name="listbox" type="ListBox" usage="input"/>
        <Parameter name="obj" type="Any"/>
        <Parameter name="lstIndex" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="lstProducts_mouseDown" id="46b7c057-90b5-4f5b-964b-9dd16a61e7c4">
        <controlMethod name="ListBox::mouseDown"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>lstProducts_mouseDown(listbox: ListBox input; button: Integer; shift: Integer; x: Real; y: Real) updating;
// --------------------------------------------------------------------------------
// Created:		04 April 2003 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	xPosition	: Real;
	yPosition	: Real;
	
begin
	if button = Window.MouseButton_Right then
		xPosition	:=	x;
		yPosition	:=	y;
		self.jssGetRelativePosition(listbox, xPosition, yPosition);
		self.popupMenu(mnuReset, xPosition.Integer, yPosition.Integer);
	endif;
end;</source>
        <Parameter name="listbox" type="ListBox" usage="input"/>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="mnuResetClear_click" id="23db2e2b-3241-4398-9009-0d2f9f3e0fa5">
        <controlMethod name="MenuItem::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>mnuResetClear_click(menuItem: MenuItem input) updating;
// --------------------------------------------------------------------------------
// Created:		04 April 2003 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	theImportConstant	: JSSLKImportConstant;
	theListbox			: ListBox;
	
begin
	app.mousePointer	:=	Busy;
	theListbox			:=	lstConstants;
	
	if theListbox.listIndex &lt;&gt; JSS_NULL_INDEX then
		theImportConstant	:=	theListbox.itemObject[theListbox.listIndex].JSSLKImportConstant;
		theImportConstant.setProduct(null);
		theListbox.itemForeColor[theListbox.listIndex]	:=	Window.Color_WindowText;
		lstProducts.listIndex	:=	JSS_NULL_INDEX;
	endif;
epilog
	app.mousePointer	:=	Idle;
end;</source>
        <Parameter name="menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
