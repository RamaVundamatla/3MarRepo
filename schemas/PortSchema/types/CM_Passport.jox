    <JadeMethod name="addErrorFull" id="8c83b713-ecfd-4de9-b6f5-99cc645ff05f">
        <updating/>
        <source>addErrorFull(pErrorCode : Integer; pText, pField : String; pObject : Object; _exObj : Exception) updating;
// ---------------------------------------------------------------------------
// Created:     14 December 2000 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	err	: CM_Error;

begin

	create err transient;
	err.set(pErrorCode, pText, false, pField, pObject, null);
	err.setMyErrorPassport(self);
	
	if app.myLoggingForm &lt;&gt; null then
		app.doFormLogging( method , "Error " &amp; pErrorCode.String &amp; " : " &amp; pText, null);
	endif;
	//jlier1 TFS 59732 28/9/23
	if _exObj &lt;&gt; null and _exObj.isKindOf(CM_Exception) then
		err.setSecondaryText(_exObj.CM_Exception.secondaryText);
	endif;
	
	if _exObj &lt;&gt; null 
	and app.addStackToErrorObjForJadeEx 
	and _exObj.errorCode &lt; app.baseErrorNum then	// (not exObj.isKindOf(CM_Exception)) then
		app.doDumpStackAsHugeStingArray(_exObj, err.allDumpDetails);
	endif;
	
end;</source>
        <Parameter name="pErrorCode" type="Integer"/>
        <Parameter name="pText" type="String"/>
        <Parameter name="pField" type="String"/>
        <Parameter name="pObject" type="Object"/>
        <Parameter name="_exObj" type="Exception"/>
    </JadeMethod>
    <JadeMethod name="addErrorsFromSet" id="52c39120-3174-40de-be96-b70bb326a03c">
        <updating/>
        <source>addErrorsFromSet(_errorSet : CM_ErrorSet input) updating;
// -------------------------------------------
// Created 20 May 2004 by cnwdvb1
// -------------------------------------------
//03 Apr 2012	cnwrs1		Par 29077 - EDI RORO Stowage Advice errors
vars
	error : CM_Error;
begin
	if _errorSet = null then	//03 Apr 2012	cnwrs1		Par 29077 - EDI RORO Stowage Advice errors
		return;
	endif;
	foreach error in _errorSet do
		error.addToPassport(self);
	endforeach;
end;</source>
        <Parameter name="_errorSet" type="CM_ErrorSet" usage="input"/>
    </JadeMethod>
    <JadeMethod name="addEventTransactionForDeferUpd" id="0bd0813e-cf16-4350-8a9c-b14ce35ef10e">
        <updating/>
        <source>addEventTransactionForDeferUpd(_event : CM_EventTransaction input; _terminal : CM_Terminal) updating;
/*
Purpose - 	
Who - NAVAB1
Date - 02MAY2024
ADO -  CR 63938 TASK 63942
*/

vars
	
begin

	if not self.useEventDeferUpdate then
		
		app.writeLog('***No Deferred Updates*** Event Transaction *** : ' &amp; self.testDescription, LogINFO);  //12.04.2024 navma1
		
		_event.setCAMSTimeStamp (app.actualTimeServer);	
		if _terminal &lt;&gt; null then
			_event.setMyTerminal(_terminal);
			_event.setMyRootValue(null);
		else
			_event.setMyTerminal(null);
			_event.setMyRoot();
		endif;
		
		// ### TFS BUG 64545 10JUNE024 NAVAB1
		if _terminal &lt;&gt; null then
			_terminal.causeEvent(_terminal.getTerminalEvent(EVENT_EVENT_TRANSACTION), false, self);
		elseif _event.myEventType &lt;&gt; null then
			_event.myEventType.causeEvent(EVENT_EVENT_TRANSACTION, false, self);
		endif;
		
		// ### JIRA 33567 03DEC2024 NAVAB1
		if not _event.isTransient then
			_event.createChargeDeferred(self); 
			//_event.createCharge(self); 
		endif;
		
		return;
	endif;

	if self.myTITransactionTerminal = null then
		// the first time we add a trx for deferred update the terminal needs to be set
		self.myTITransactionTerminal := _terminal;
		
		self.allEventsForDeferUpd.tryAdd(_event); // ### JIRA 33567 03DEC2024 NAVAB1 - tryAdd
		
	elseif self.myTITransactionTerminal = _terminal then
		// subsequent trx for same terminal can just be added for deferred update
		self.allEventsForDeferUpd.tryAdd(_event); // ### JIRA 33567 03DEC2024 NAVAB1 - tryAdd
		
	else
		// we have been adding deferred updates for a different terminal - we can't add this trx to the same
		// collection so do the update now.
		_event.setCAMSTimeStamp (app.actualTimeServer);
		_event.setMyTerminal(_terminal);
		// ### JIRA 33567 03DEC2024 NAVAB1
		if not _event.isTransient then
			_event.createChargeDeferred(self); 
			//_event.createCharge(self); 
		endif;
		
	endif;
end;</source>
        <Parameter name="_event" type="CM_EventTransaction" usage="input"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="addFutureActorsForDeferDel" id="aa7ecbe6-1191-400b-b3c7-dbd9209d0517">
        <source>addFutureActorsForDeferDel(_futreActor : CM_OfflineFutureActor io);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 Mar 2025 navma1 MTN-34120 MTN | Dead Lock (1081) on CM_OfflineFutureActorParentDct

*/

vars

begin
	
	if not self.useOfflineFutureActorDeferDel then
		app.writeLog('***No Deferred Updates*** Delete Future Actors *** : ' &amp; self.testDescription, LogINFO);  //12.04.2024 navma1
		delete _futreActor;
	else
		self.allFutureActorForDefDel.tryAdd(_futreActor);
	endif;
epilog

end;</source>
        <Parameter name="_futreActor" type="CM_OfflineFutureActor" usage="io"/>
    </JadeMethod>
    <JadeMethod name="addFutureActorsForDeferUpd" id="24726c7d-2d33-41ad-a204-b0d88ce057e3">
        <source>addFutureActorsForDeferUpd(_futreActor : CM_OfflineFutureActor input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 May 2024 navma1	Bug 64224: MTN - DeadLocks Caused by Future Actors
*/

vars

begin
	
	if not app.myPassport.useOfflineFutureActorDeferUpd then		
		app.writeLog('***No Deferred Updates*** Update Future Actors*** : ' &amp; self.testDescription, LogINFO);
		_futreActor.setRoot(app.myRoot);
	else
		self.allFutureActorForDefUpd.tryAdd(_futreActor);
	endif;
epilog

end;</source>
        <Parameter name="_futreActor" type="CM_OfflineFutureActor" usage="input"/>
    </JadeMethod>
    <JadeMethod name="addReeferRunnerRequest" id="c05ac8fc-7d40-4adc-9f36-074932ed8ccd">
        <updating/>
        <source>addReeferRunnerRequest(_ti : CM_TrackedItem; _type : Integer) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 25/11/2025	navdap1		Initial creation MTN-36569 CPL | Reefer Runner Integration
//
vars
	ti : CM_TrackedItem;
	request : BGP_ReeferRunnerWSRequest;

begin
	// Not licensed for Reefer Runner? Nothing to do
	if not app.myRoot.canDo(Sub_ReeferRunner) then
		return;
	endif;
	
	// No TI? Nothing to do
	if _ti = null then
		return;
	endif;
	
	// Unit tests? Nothing to do
	if app.isJMTUnitTest() then
		return;
	endif;
	
	ti := _ti;
	
	// Not a reefer? Nothing to do
	if not ti.requiresPower then
		return;
	endif;
	
	// Create a BGP request to send details to Reefer Runner app
	create request persistent;
	request.setDetails(_ti, _type);
	if self.noErrors() then
		request.causeEvent(BGP_Object.BGP_ActionRequest, false, null);
	endif;
epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_type" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="addTITransactionForDeferUpd" id="91a3a80a-9b82-4c3e-992a-be69b1f219d6">
        <updating/>
        <source>addTITransactionForDeferUpd(_tiTransaction : CM_TITransaction input; _terminal : CM_Terminal) updating;
// ---------------------------------------------------------------------------
// Created:     24 June 2003 by cnwrs2
// ---------------------------------------------------------------------------
// 18/12/2012	cnwcs5	CCMS SFW 1294 / par 30855 - set CAMD timestamp
// 25/06/2013	cnwcs5	par 31895 - set camsTimeStamp for inter-terminal transactions
vars
	isSubTerminalsOn	: Boolean;
	subTerminal			: CM_SubTerminal;
	
begin
	isSubTerminalsOn := app.isSubTerminalsOn(_terminal);

	if isSubTerminalsOn then
		subTerminal := _tiTransaction.myTrackedItem.mySubTerminal;
	endif;
	
	// In the updates below always update _tiTransaction.myTerminal BEFORE updating
	// the _tiTransaction.mySubTerminal, as this will single-thread through the
	// updating of the CM_SubTerminal dicts, using the CM_Terminal dict.

	if (not self.useTITransactionDeferUpdate) then
		// par 30855 - set CAMS timestamp to the server timestamp.  Any transactions that use 
		// deferred updates will update this later at the end of the transaction
		
		//app.writeLog('***No Deferred Updates*** TI Transactions *** : ' &amp; self.testDescription, LogINFO);
		
		_tiTransaction.setCAMSTimeStamp (app.actualTimeServer);	
		_tiTransaction.setMyTerminal(_terminal);
		
		if isSubTerminalsOn then
			_tiTransaction.setMySubTerminal(subTerminal);
		endif;
		
		if app.isInProformaMode then
			_tiTransaction.createCharge(self);
		else
			_tiTransaction.createChargeDeferred(self);	//07 Jul 2021	TFS 51443 NDL - Potentially creates charges as part of a BGP instead of directly in-line
		endif;
		return;
		
	else	//28 Feb 2018	NDL	TFS 37278
			// We are using deferred updating. The sub terminal can change in the same trx,
			// record the current value, so we can use it later.
		if isSubTerminalsOn and not _tiTransaction.isSubTermRecOrRel then
			_tiTransaction.setMySubTermForDefUpd(subTerminal);
		endif;
		
	endif;

	if self.myTITransactionTerminal = null then
		// the first time we add a trx for deferred update the terminal needs to be set
		self.myTITransactionTerminal := _terminal;
		
		self.allTITransactionsForDeferUpd.add(_tiTransaction);
		
	elseif self.myTITransactionTerminal = _terminal then
		// subsequent trx for same terminal can just be added for deferred update
		self.allTITransactionsForDeferUpd.add(_tiTransaction);
		
	else
		// we have been adding deferred updates for a different terminal - we can't add this trx to the same
		// collection so do the update now.
		_tiTransaction.setCAMSTimeStamp (app.actualTimeServer);		// par 31895 cnwcs5 June 2013
		_tiTransaction.setMyTerminal(_terminal);
		
		if isSubTerminalsOn then
			_tiTransaction.setMySubTerminal(subTerminal);
		endif;
		
		if app.isInProformaMode then
			_tiTransaction.createCharge(self);
		else
			_tiTransaction.createChargeDeferred(self);	//07 Jul 2021	TFS 51443 NDL - Potentially creates charges as part of a BGP instead of directly in-line
		endif;
	endif;
end;</source>
        <Parameter name="_tiTransaction" type="CM_TITransaction" usage="input"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="addToAutoMove" id="c24fa22d-de29-4b66-a5d7-3eba2fad7d83">
        <source>addToAutoMove( _ti : CM_TrackedItem; _moveType : Integer );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 October 2017	jlgndl1	Initial creation	TFS 7283  These moves need to be queued or planneed
											after the ti is updated so that the auto plan/queue takes
											into account the changes made that may effect the auto allocation 
											matching.

*/

vars

	edition : Integer;
	invalidObj : Boolean;

begin

	if _ti = null then
		return;
	endif;
	
	on Exception do app.handleDeletedObject( exception, _ti, invalidObj );
	edition := _ti.edition;
	
	if invalidObj then
		return;
	endif;
	
	if _moveType &lt;&gt; PLANNING_MODE and  _moveType &lt;&gt; QUEUE_MODE then
		return;
		
	elseif _moveType = PLANNING_MODE then
		self.allTisToAutoPlan.addNoDuplicates( _ti, false );
		
	elseif _moveType = QUEUE_MODE then
		self.allTisToAutoQueue.addNoDuplicates( _ti, false );
		
	endif;

epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_moveType" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="addTrackedItemForDeferUpd" id="b7508b88-a6e3-46d1-acdd-1f65b04b3dc9">
