    <JadeMethod name="checkCriteria" id="512683f1-2b41-42e8-8470-1463b340bcdf">
        <source>checkCriteria(pObject:Object):Boolean protected;
// --------------------------------------------------------------------------------
// Created:		31 January 1999 by cnwdad1
//
// Purpose:		Validate selection criteria for the filtering of objects.
//
// Parameters:	pObject (Object) - The object against which to validate the criteria.
// Returns:		Boolean - Indicates whether the object should be excluded from the list.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 14/2/1998	cnwdad1		The object filter wasn't working properly if the length
//							of the values being evaluated weren't padded to the same
//							length.
//
// --------------------------------------------------------------------------------
vars
	criteriaParts	: StringArray;
	object			: Object;
	include			: String;
	propertyName	: String;
	operand			: String;
	value			: String;
	andOperator		: String;
	propertyValue	: String;
	blanks			: String;

begin
	foreach object in self.selectionCriteriaArray do
		criteriaParts	:=	object.StringArray;

		if (criteriaParts &lt;&gt; null) then
			propertyName	:=	criteriaParts[2];
			operand			:=	criteriaParts[3];
			value			:=	criteriaParts[4];
			propertyValue	:=	pObject.Object.getPropertyValue(propertyName).asString;

			if (value.length &lt; propertyValue.length) then
				blanks			:=	blanks.padBlanks(propertyValue.length - value.length);
				value			:=	blanks &amp; value;
			elseif (propertyValue.length &lt; value.length) then
				blanks			:=	blanks.padBlanks(value.length - propertyValue.length);
				propertyValue	:=	blanks &amp; propertyValue;
			endif;

			if (criteriaParts[1] = self.INCLUDE_LITERAL) then
				if (operand = "=") then
					if (not propertyValue = value) then
						return true;
					endif;
				elseif (operand = "&lt;") then
					if (not propertyValue &lt; value) then
						return true;
					endif;
				elseif (operand = "&gt;") then
					if (not propertyValue &gt; value) then
						return true;
					endif;
				elseif (operand = "&lt;&gt;") then
					if (not propertyValue &lt;&gt; value) then
						return true;
					endif;
				elseif (operand = "&lt;=") then
					if (not propertyValue &lt;= value.padBlanks(4)) then
						return true;
					endif;
				elseif (operand = "&gt;=") then
					if (not propertyValue &gt;= value) then
						return true;
					endif;
				endif;
			else
				if (operand = "=") then
					if (propertyValue = value) then
						return true;
					endif;
				elseif (operand = "&lt;") then
					if (propertyValue &lt; value) then
						return true;
					endif;
				elseif (operand = "&gt;") then
					if (propertyValue &gt; value) then
						return true;
					endif;
				elseif (operand = "&lt;&gt;") then
					if (propertyValue &lt;&gt; value) then
						return true;
					endif;
				elseif (operand = "&lt;=") then
					if (propertyValue &lt;= value) then
						return true;
					endif;
				elseif (operand = "&gt;=") then
					if (propertyValue &gt;= value) then
						return true;
					endif;
				endif;
			endif;
		endif;
	endforeach;

	return false;
end;</source>
        <access>protected</access>
        <Parameter name="pObject" type="Object"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="formDelete" id="b74a5958-4de2-4db5-b25e-f42fecd54258">
        <updating/>
        <source>formDelete() updating, protected;
// --------------------------------------------------------------------------------
// Created:		15 July 1999 by cnwdad1
//
// Purpose:		Standard form delete method.
//
// Parameters:	None
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	object		: Object;
	response	: Integer;

begin
	object	:=	tblObjects.getRowObject();

	if (object = null) then
		app.msgBox('Please select the class instance to delete.', 'Error', MsgBox_Stop_Icon + MsgBox_OK_Only);
		return;
	else
		response	:=	app.msgBox(	'Are sure you want to delete this instance of ' &amp; self.myClass.name &amp; ' ?',
									'Warning',
									MsgBox_Question_Mark_Icon + MsgBox_Yes_No);

		if (response = MsgBox_Return_Yes) then
			beginTransaction;
			delete object;
			commitTransaction;
			tblObjects.clearAllSelected;
		endif;
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="formEdit" id="a9cf927f-84aa-401e-92c2-6ed5ed43db81">
        <source>formEdit() protected;
// --------------------------------------------------------------------------------
// Created:		15 July 1999 by cnwdad1
//
// Purpose:		Standard form edit method.
//
// Parameters:	None
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	updateForm	: CnEcObjectUpdateForm;

begin
	create updateForm;
	updateForm.setMyObject(tblObjects.getRowObject());
	updateForm.setMyClass(self.myClass);
	updateForm.setIsNewObject(false);
	updateForm.setIsBrowseOnly(self.isBrowseOnly);
	updateForm.showModal();
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="formFilter" id="28660fde-1c61-4289-8e75-13b4da82d174">
        <source>formFilter() protected;
// --------------------------------------------------------------------------------
// Created:		15 July 1999 by cnwdad1
//
// Purpose:		Shows a form on which the user can specify object filter criteria.
//
// Parameters:	None
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	filterForm	: CnEcObjectFilterForm;

begin
	create filterForm;
	filterForm.setMyClass(self.myClass);
	filterForm.setSelectionCriteriaArray(self.selectionCriteriaArray);
	filterForm.showModal();

	if (filterForm.modalResult &lt;&gt; 0) then
		self.statusMsg('Applying the object selection criteria...');
		self.selectionCriteriaArray.clear();

		if (filterForm.getSelectionCriteriaArray().cnEcIsNotEmpty()) then
			filterForm.getSelectionCriteriaArray().copy(self.selectionCriteriaArray);
		endif;

		self.loadInstances(self.myClass);
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="formLoad" id="e04573ee-71df-4d6d-aece-b1538ad94431">
        <updating/>
        <source>formLoad() updating, protected;
// --------------------------------------------------------------------------------
// Created:		15 July 1999 by cnwdad1
//
// Purpose:		Standard form load method.
//
// Parameters:	None
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if self.myClass = null then
		app.msgBox("The reference to the class null.", "Error", MsgBox_Stop_Icon + MsgBox_OK_Only);
		unloadForm();
		return;
	endif;

	self.caption			:=	self.caption &amp; ': ' &amp; self.myClass.name;
	self.canUpdate			:=	self.isEditingAllowed();
	self.viewObjectsByOid	:=	self.getViewObjectsByOid();
	beginClassNotification(self.myClass, false, Any_System_Event, Response_Continuous, 1);
	self.loadInstances(self.myClass);

	if self.myClass.isSystemObject then
		btnNew.enabled	:=	false;
	endif;

	if (not self.canUpdate) or (self.isBrowseOnly) then
		btnDelete.visible	:=	false;
		btnNew.visible		:=	false;
		btnEdit.caption		:=	"&amp;View";
		btnEdit.enabled		:=	false;
	endif;

	if self.myClass.abstract then
		btnDelete.visible	:=	false;
		btnNew.visible		:=	false;
		btnEdit.visible		:=	false;
		btnFilter.visible	:=	false;
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="formNew" id="ce5e7b4b-cb34-4203-b758-681ed156a38b">
        <source>formNew() protected;
// --------------------------------------------------------------------------------
// Created:		15 July 1999 by cnwdad1
//
// Purpose:		Standard form new method.
//
// Parameters:	None
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	updateForm	: CnEcObjectUpdateForm;

begin
	create updateForm;
	updateForm.setMyObject(null);
	updateForm.setIsNewObject(true);
	updateForm.setMyClass(self.myClass);
	updateForm.setIsBrowseOnly(false);
	updateForm.showModal();
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="getMyClass" id="46eebb62-3825-4ccb-9cd0-93bd8de85ea5">
        <source>getMyClass() : Class;
// --------------------------------------------------------------------------------
// Created:		10 January 1999 by cnwdad1
//
// Purpose:		Returns a reference to the class who's instances are being browsed.
//
// Parameters:	None
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return self.myClass;
end;</source>
        <ReturnType type="Class"/>
    </JadeMethod>
    <JadeMethod name="load" id="e8a3cad0-8d4b-4278-b3ac-6ce6138b0acb">
        <controlMethod name="Form::load"/>
