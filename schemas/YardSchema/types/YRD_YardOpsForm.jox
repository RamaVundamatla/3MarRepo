    <JadeMethod name="doBtnPrint" id="b27f5761-6927-411c-b92c-45efa3dfe480">
        <updating/>
        <source>doBtnPrint() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
16 October 2009	cnwrd1	Initial creation

*/

vars

	theCode			: String;
	pxyJadeReport	: JadeReport;
//	tblPrintParams	: CMIF_PrintTableParams;
	bw : Boolean;
begin

	bw := false;
	/*
	if app.msgBox("Print in Colour (yes) or Black and White (no)?", "Print", MsgBox_Question_Mark_Icon + MsgBox_Yes_No) = MsgBox_Return_Yes then
		bw := false;
	else
		bw := true;
