    <JadeMethod name="getMyTerminal" id="5bcd6655-b602-40b4-900f-e98fc16a5568">
        <source>getMyTerminal() : CM_Terminal;
// ---------------------------------------------------------------------------
// Created:		21 May 2007 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
begin
	return self.myTerminal;
end;</source>
        <ReturnType type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="getNiceName" id="c9f5c540-5da6-40cb-a15b-8369709bfc76">
        <source>getNiceName(): String;
/*
Purpose:			
Date		Who		Reason
03/02/2017	cnwab1	Initial creation
05/05/2017	cnwdap1	TFS 4342 LNX Voyage Event Date Issues - don't timezone-convert shift dates/times
*/

vars

begin
	return self.code 
		&amp; ": " 
		//&amp; " " &amp; self.systemToLocalTime(self.startDateTime).asStringJMT()		// TFS 4342
		&amp; " " &amp; self.startDateTime.asStringJMT()								// TFS 4342
		&amp; " - " 
		//&amp; " " &amp; self.systemToLocalTime(self.endDateTime).asStringJMT();		// TFS 4342
		&amp; " " &amp; self.endDateTime.asStringJMT();									// TFS 4342

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getShiftDay" id="6689fd43-158d-460f-a17c-97fa0040ca38">
        <source>getShiftDay() : String;
/*

Date		Who		Reason
15 Apr 2016	cnwkpd1	TFS 488 - Multi Timezone Support
02 Mar 2017	cnwdap1	TFS 3619 Shift Dates display on Hold Planning	
*/

vars
	tempStr  : String;	
begin

	if self.startDateTime = null then //cnwrd1 #18213,  22.10.2008
		return '';
	endif;
	
	tempStr := self.myTerminal.getHolidayDesc(self.startDateTime.Date);		// TFS 3619
	if tempStr &lt;&gt; null then
		tempStr := " (" &amp; tempStr &amp; ")";
	endif;

	tempStr := self.startDateTime.Date.dayName()  &amp; tempStr;				// TFS 3619
	
	return tempStr;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getShiftLengthDesc" id="d0a5624a-9145-45e7-ad50-85df0a5445d5">
        <source>getShiftLengthDesc() : String;
// ---------------------------------------------------------------------------
// Created:		16 May 2007 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	posNeg, numOfDays, mins, millis : Integer;
	tmpStr : String;
	a,b : TimeStamp;
	tmpTime : Time;
begin
	a := self.startDateTime;
	b := self.endDateTime;
	tmpTime := a.differenceAsTime(b,posNeg, numOfDays);
	mins := (tmpTime.hour * 60 + tmpTime.minute ) * 60; 
	
	tmpStr := mins.getHMS();
	numOfDays := numOfDays - posNeg;
	if numOfDays &gt; 0 then
		tmpStr := numOfDays.String &amp; "d " &amp; tmpStr;
	endif;
	
	return tmpStr; 


end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getStartDateTimeLocalTZ" id="dced1348-8c4c-4ee5-8cb2-06e7f3cc43e8">
        <source>getStartDateTimeLocalTZ() : TimeStamp;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 June 2016	cnwns1	Initial creation
// 02 June 2016	cnwns1	TFS 488 - Multi Timezone Support
*/

vars

begin
	return self.systemToLocalTime(self.startDateTime);
epilog

end;</source>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="0ae35c9a-f782-4352-9ae7-91c34f8b0a99">
        <source>pxyCreateUpdateProxy(): SelfType;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 June 2023	navhl20	Defect 58611: MTN - 1090 Exception when defining a job sheet without entering Shift

*/

vars
	proxyObj	: SelfType;
	completedOk	: Boolean;
begin
	proxyObj := inheritMethod();
	
	proxyObj.myTerminal := self.myTerminal;
	
	completedOk := true;
	return proxyObj;
epilog
	if not completedOk then
		delete proxyObj;
	endif;
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="4e6b999e-dccc-4a7e-8be9-370f69305f09">
        <updating/>
        <source>setForCreate(pProxyShiftStd: CM_Shift) updating;
//
// Changed On	By			Reason
// ----------	---------	------------------------------------------------
// 31/01/2017	cnwdap1		TFS 3219 LNX Voyage Operations Enhancements
vars

begin
	pProxyShiftStd.raiseExceptionIfNotTransient(method);
	self.raiseExceptionIfTransient(method);

	
	self.ignore 					:= pProxyShiftStd.ignore;
	self.startDateTime 		:= pProxyShiftStd.startDateTime;
	self.endDateTime 		:= pProxyShiftStd.endDateTime;
	
	self.remarks			:= pProxyShiftStd.remarks;					// TFS 3219

	inheritMethod(pProxyShiftStd);
	self.myTerminal		:= pProxyShiftStd.myTerminal;
	
	self.causeEvent(self.myTerminal.getTerminalEvent(Event_Shift_Add), false, null);
end;
</source>
        <Parameter name="pProxyShiftStd" type="CM_Shift"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="a1bc9adc-0645-4b8f-a87c-2effcadd53ea">
        <updating/>
        <source>setForUpdate(pProxyShiftStd : CM_Shift) updating;
// ---------------------------------------------------------------------------
// Created:     04 May 2007 by cnwyl1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 02/02/2017	cnwdap1		TFS 3220 LNX Voyage Operations Enhancements
vars

begin
	pProxyShiftStd.raiseExceptionIfNotTransient(method);
	self.raiseExceptionIfTransient(method);
	
	self.startDateTime 		:= pProxyShiftStd.startDateTime;
	self.endDateTime 		:= pProxyShiftStd.endDateTime;
	self.code 			:= pProxyShiftStd.code;
	self.ignore 			:= pProxyShiftStd.ignore;
	self.description 	:= pProxyShiftStd.description;
	self.remarks			:= pProxyShiftStd.remarks;				// TFS 3220
	
	self.causeEvent(self.myTerminal.getTerminalEvent(Event_Shift_Update), false, null);	


end;
</source>
        <Parameter name="pProxyShiftStd" type="CM_Shift"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="591ac487-9ae5-4d27-a5bb-480eec6a1925">
        <updating/>
        <source>setProxy(pShiftDay : Integer; pStartTime : Time; pEndTime : Time; pCode : String; pDesc : String; pTerminal : CM_Terminal; _ignore : Boolean) updating;

vars

begin
	self.code			:= pCode;
	self.description	:= pDesc;
	self.myTerminal		:= pTerminal;
	self.ignore := _ignore;
end;
</source>
        <Parameter name="pShiftDay" type="Integer"/>
        <Parameter name="pStartTime" type="Time"/>
        <Parameter name="pEndTime" type="Time"/>
        <Parameter name="pCode" type="String"/>
        <Parameter name="pDesc" type="String"/>
        <Parameter name="pTerminal" type="CM_Terminal"/>
        <Parameter name="_ignore" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setRemarks" id="bb9872b1-1836-4bf8-a1d5-d55199c0aa72">
        <updating/>
        <source>setRemarks(_remarks : String) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 30/01/2017	cnwdap1		Initial creation TFS 3219 LNX Voyage Operations Enhancements
//
vars

begin
	self.remarks := _remarks;
epilog

end;</source>
        <Parameter name="_remarks" type="String"/>
    </JadeMethod>
    <JadeMethod name="validate" id="e899b689-7a0a-422a-bb43-e8aa3fc80400">
        <updating/>
        <source>validate(_passport: CM_Passport) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
22 October 2008	cnwrd1	Initial creation
//cnwrd1 #18213,  22.10.2008
*/

vars

begin
	
	if not self.startDateTime.isValid() then
		app.raiseCMException1(ERR_INVALID_TIMESTAMP, 'Start Date',null, null);
	endif;

	if not self.endDateTime.isValid() then
		app.raiseCMException1(ERR_INVALID_TIMESTAMP, 'End',null, null);
	endif;
	
	if self.endDateTime &lt; self.startDateTime then
//		app.raiseCMException1(ERR_SHIFT_WRONG_TIME, null,null, null); CAN have end before start
	endif;

	if self.code = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Code',null, null);
		app.raiseCMException(Input_required_field_code,null, null); // cnwdb2	PAR 35364
	endif;

epilog

end;</source>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="validateForCreate" id="e2de4ae4-fa73-45c8-b273-e472cb8385fa">
        <updating/>
        <source>validateForCreate(_passport: CM_Passport) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
22 October 2008	cnwrd1	Initial creation
//cnwrd1 #18213,  22.10.2008
// 09/12/2014   cnwdb2	PAR #35364

*/

vars
	existingShift : CM_Shift;

begin
	
	self.raiseExceptionIfNotTransient(method);
	
	self.validate(_passport);
	
	existingShift := self.myTerminal.allShiftsDay[self.startDateTime, self.code];
	if existingShift &lt;&gt; null then
	//	app.raiseCMException3(ERR_DUPLICATE_KEY, 'Worker Shift ', self.code &amp; " at " &amp; self.getShiftDay() &amp; ' ' &amp; self.startDateTime.String, null,'Worker Shift', null);
		app.raiseCMException2(Already_exists_worker_shift,self.code, self.getShiftDay() &amp; ' ' &amp; self.startDateTime.String,'Worker Shift', null); // cnwdb2 PAR 35364
	endif;

epilog

end;</source>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="validateForUpdate" id="0d4a3674-2936-410d-aa3e-202ad0499fc9">
        <updating/>
        <source>validateForUpdate(_passport: CM_Passport) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
22 October 2008	cnwrd1	Initial creation
//cnwrd1 #18213,  22.10.2008
// 09/12/2014   cnwdb2	PAR #35364

*/

vars
	existingShift,
	realFromPxyShift	: CM_Shift;
	expectedEdition		: Integer;
	
begin
	
	inheritMethod( _passport );
	
	self.validate( _passport );	

	// getting real from proxy
	self.pxyGetRealObjectAndEdition(realFromPxyShift, expectedEdition);
	// getting existing shift
	existingShift := self.myTerminal.allShiftsDay[self.startDateTime, self.code];
	if existingShift &lt;&gt; null
	and existingShift &lt;&gt; realFromPxyShift // there is another real shift different from updated one
	then
	//	app.raiseCMException3(ERR_DUPLICATE_KEY, 'Worker Shift ', self.code &amp; " at " &amp; self.getShiftDay() &amp; ' ' &amp; self.startDateTime.String, null,'Worker Shift', null);
		app.raiseCMException2(Already_exists_worker_shift,self.code, self.getShiftDay() &amp; ' ' &amp; self.startDateTime.String,'Worker Shift', null); // cnwdb2 PAR 35364
	endif;
	
epilog

end;</source>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
</Class>
