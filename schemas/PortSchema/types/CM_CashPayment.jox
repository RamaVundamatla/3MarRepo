	elseif self.myProformaDetail &lt;&gt; null then 										 		   // TFS 7357
		if self.myProformaDetail.myInvoiceLineType &lt;&gt; null then 							   // TFS 7357
			return self.myProformaDetail.myInvoiceLineType.getTaxCodeForPayment(_description); // TFS 7357 // TFS 44275 - getTaxCodeForPayment
