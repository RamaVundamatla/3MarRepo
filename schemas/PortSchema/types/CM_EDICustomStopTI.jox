    <JadeMethod name="myVoyageVerify" id="4c5136b8-5344-424a-819f-d90aac2d370f">
        <updating/>
        <source>myVoyageVerify(_terminal : CM_Terminal):String updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 June 2017	cnwndl1	Initial creation	TFS 4844

*/

vars

	value: Integer;
	message: String;
	vessel : CM_Vessel;
	operator : CM_Operator;
	voyage : CM_Voyage;
	voyageCode : String;
	lloydsNumber : String;
	xlVoyageCode : String;
	foundMatch : Boolean;

begin

	value := VALID;
	
	if self.isXMLOneStopCust then
		voyage := self.getMyVoyage;
		voyageCode := self.getVoyageCode;
		if voyage = null and voyageCode &lt;&gt; null then 
			voyage := _terminal.allVoyagesByCode.getAtKeyGeq(voyageCode, null);
			if voyage &lt;&gt; null and voyage.code &lt;&gt; voyageCode then
				voyage := null;
			endif;	
			if voyage = null and self.vesselName &lt;&gt; null then
				vessel := app.myRoot.allVesselsByName.getAtKey( self.vesselName );
				if vessel &lt;&gt; null then
					operator := vessel.myOperator;
					lloydsNumber := vessel.lloydsNumber;
				endif;
				if voyage = null and operator &lt;&gt; null then
					xlVoyageCode := operator.getXlationSystemCode_Voyage(voyageCode, null, lloydsNumber, null, foundMatch);
					voyage := _terminal.allVoyagesByCode.getAtKeyGeq(xlVoyageCode, null);
					if voyage &lt;&gt; null and voyage.code &lt;&gt; xlVoyageCode then
						voyage := null;
					endif;
				endif;
			endif;
			if voyage &lt;&gt; null then
				beginTransaction;
				self.setVoyage(voyage);
				commitTransaction;
			endif;
		endif;
	endif;

epilog

	return value.String &amp; message;

end;</source>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="packCountVerify" id="8662c947-2657-41d4-a37a-ba8c59f0491b">
        <source>packCountVerify(_terminal : CM_Terminal): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 Jun 2017	cnwndl1	Initial creation	TFS 4844
28 Nov 2024 navma1	MTN-19124 STWO - Uploading an EDI file 'freezes' MTN.
*/

vars

	value		: Integer;
	message		: String;
	bol 		: CM_BOL;
	selectedBol : CM_BOLIn;
	bolSet		: CM_BOLSet;
	voyage 		: CM_Voyage;
	iter 		: Iterator;
	tiCount 	: Integer;
	trackedItem : CM_TrackedItem;
	bolUpper	: String;
begin

	value := VALID;
	
	voyage := self.getMyVoyage;
	
	if self.isXMLOneStopCust and self.billOfLading &lt;&gt; null then
	
		voyage := self.getMyVoyage;
		
		if voyage &lt;&gt; null then
			
			bolUpper := self.billOfLading.toUpper;														//28.11.2024 navma1 #MTN-19124
			
			create bolSet transient;
			voyage.getBOLInsFromNumber( bolSet, BOLType_GeneralBillOfLading, bolUpper, true, null );	//28.11.2024 navma1 #MTN-19124
			foreach bol in bolSet do
				if bol.number.toUpper = bolUpper then													//28.11.2024 navma1 #MTN-19124
					selectedBol := bol.CM_BOLIn;
					break;
				endif;
			endforeach;
			
			if selectedBol &lt;&gt; null then
				iter := selectedBol.allTrackedItems.createIterator();
				while iter.next( trackedItem ) do
					tiCount := tiCount + trackedItem.totalQuantity.max(1);
				endwhile;
		
				if tiCount &lt;&gt; self.packCount then
					value := WARNING;
					message := "Packages doesn't match cargo count on BOL";
				endif;
			endif;
			
		endif;
			
	endif;
	
	
epilog

	delete bolSet;
	delete iter;
	return value.String &amp; message;

end;</source>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="propertyNotVerified" id="3c409f07-2057-4cef-b79e-df6f72aa7995">
        <source>propertyNotVerified(_propName: String): Boolean;

vars

begin
	if _propName = CM_EDICustomStopTI::billOfLading.name then
		return true;	
	elseif _propName = CM_EDICustomStopTI::consignee.name then
		return false;	//return true;	07 Sep 2021	NDL	TFS 51928
	elseif _propName = CM_EDICustomStopTI::consignor.name then
		return false;	//return true;	07 Sep 2021	NDL	TFS 51928		
	elseif _propName = CM_EDICustomStopTI::customsAgent.name then
		return true;
	elseif _propName = CM_EDICustomStopTI::mafInstructions.name then
		return true;
	elseif _propName = CM_EDICustomStopTI::myEDIFile.name then
		return true;
	elseif _propName = CM_EDICustomStopTI::myTrackedItem.name then
		return true;
	elseif _propName = CM_EDICustomStopTI::myUnprocEDIData.name then
		return true;
	elseif _propName = CM_EDICustomStopTI::quarantineInstructions.name then
		return true;
	elseif _propName = CM_EDICustomStopTI::sequenceNum.name then
		return true;
	elseif _propName = CM_EDICustomStopTI::userNotes.name then
		return true;
	elseif _propName = CM_EDICustomStopTI::allTrackedItems.name then
		return true;
	else
		return inheritMethod(_propName);
	endif;
end;
</source>
        <Parameter name="_propName" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
