    <JadeMethod name="myProduct" id="ab67ccee-1be5-42a1-83e7-55cb53eb7cf6">
        <methodInvocation>mapping</methodInvocation>
        <updating/>
        <source>myProduct(set: Boolean; _value: CM_Product io) mapping, updating;
// ---------------------------------------------------------------------------
// Created:     03 June 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
// 04/03/2010	cnwcs5	par 22762
vars

begin

	if set then
		if _value = null then
			self.productCode := null;
		else
			if not self.isTransient and 				// 04/03/2010 cnwcs5 par 22762
				_value &lt;&gt; null and 						// 04/03/2010 cnwcs5 par 22762
				_value &lt;&gt; self.myProduct then			// 04/03/2010 cnwcs5 par 22762
				_value.updateForNonInversedReference;	// 04/03/2010 cnwcs5 par 22762
			endif;										// 04/03/2010 cnwcs5 par 22762
		
			self.productCode := _value.code;
		endif;
	endif;

end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="CM_Product" usage="io"/>
    </JadeMethod>
    <JadeMethod name="numTIs" id="4eb44fc1-7aa9-4ded-b15d-15aefb35cdf7">
        <methodInvocation>mapping</methodInvocation>
        <updating/>
        <source>numTIs(set: Boolean; _value: Integer io) mapping, updating;
// ---------------------------------------------------------------------------
// Created:     24 June 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 21/11/2013	cnwdap1		PAR #32989 If I'm an inter-terminal offload, I have twice as many TIs in my allTrackedItems collection,
//								as the TIs are recreated in the destination terminal. This is why myOrigBOLTerminal is checked here.
//								But if I'm a proxy, I don't have a myOrigBOLTerminal, so I return the wrong value.
// ---------------------------------------------------------------------------
vars
	realBOL	: CM_BOLIn;

begin

	if set then
		app.raiseSetVirtualError(class.name, method.name);
		return;
	endif;
	
	if self.myOrigBOLTerminal &lt;&gt; null then
		_value := self.myOrigBOLTerminal.numTIs;
	else
		if self.isTransient then												// PAR #32989
			realBOL := self.pxyGetRealObject().CM_BOLIn;						// PAR #32989
			if realBOL &lt;&gt; null and realBOL.myOrigBOLTerminal &lt;&gt; null then		// PAR #32989
				_value :=  realBOL.myOrigBOLTerminal.numTIs;					// PAR #32989
			endif;																// PAR #32989
		else																	// PAR #32989
			_value := self.allTrackedItems.size;
		endif;																	// PAR #32989
	endif;

end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="numberOfLifts" id="dfa6b19c-8adc-45f6-9eef-d45fe6284b30">
        <methodInvocation>mapping</methodInvocation>
        <source>numberOfLifts(set: Boolean; _value: Integer io) mapping;
// ---------------------------------------------------------------------------
// Created:     24 June 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	if set then
		app.raiseSetVirtualError(class.name, method.name);
		return;
	endif;
	
	if self.myExtension = null then
		return;
	endif;
	
	if self.myExtension.isKindOf(CM_BOLExtLog) then
		_value := self.myExtension.CM_BOLExtLog.numberOfLifts;
	endif;

end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="populatePxyFromBooking" id="457eace0-5e1d-4156-90e3-4d528998c7e5">
        <updating/>
        <source>populatePxyFromBooking(_booking:CM_BookingRef) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
06 October 2022	navgm20	ChangeRequest 54979: EUP - Cargo Work Orders Enhancements
30 january 2023 navdp20 ChangeRequest 56969:[56288] EUP - [Framework] Constructing methods to populate booking, bill of lading, and release request conversion
*/

vars
	bolDtl		   : CM_BOLDtl;
	bookinfRefItem : CM_BookingRefItem;
begin
	
	self.bolType 			:= BOLType_GeneralBillOfLading;   			//30.01.2023 navdp20 #56969[56288]
	self.clientRef1			:= _booking.consignorReference;
	self.clientRef2			:= _booking.customerReference;
	self.destinationPort	:= _booking.destinationPort;
	self.directDelivery		:= _booking.directDelivery;
	self.dischargePort		:= _booking.dischargePort;
	self.myOperator			:= _booking.myOperator;
	self.myOperatorTerminal	:= _booking.myOperatorTerminal;
	self.number				:= _booking.bookingReference;
	self.myProduct			:= _booking.myProduct;
	self.remarks			:= _booking.remarks;
	self.weightGross		:= _booking.weight;
	self.weightTotal		:= _booking.weight;
	self.myTerminal     	:= _booking.myTerminal;    					//30.01.2023 navdp20 #56969[56288]
	
	if _booking.myProduct &lt;&gt; null then
		self.productCode	:=	_booking.myProduct.code;
	endif;
	
	if _booking.myConsignee &lt;&gt; null then
		self.consignee		:= _booking.myConsignee.code;
	endif;
	
	if _booking.myConsignor &lt;&gt; null then
		self.consignor		:= _booking.myConsignor.code;
	endif;
	
	if _booking.status	= BOOKING_REF_ACTIVE  then
		self.status 		:= BOL_STATUS_NORMAL;
	elseif	_booking.status	= BOOKING_REF_ARCHIVED  then
		self.status 		:= BOL_STATUS_ARCHIVED;
	endif;
	
	self.setSubTerminalDefault(_booking.myTerminal); 					//30.01.2023 navdp20 #56969[56288]
	
	foreach bookinfRefItem in _booking.allBookingRefItems do
		create bolDtl transient;
		bolDtl.populatePxyfromBookingItem(bookinfRefItem);
		self.allBOLDtls.add(bolDtl);
	endforeach;
epilog
	
end;</source>
        <Parameter name="_booking" type="CM_BookingRef"/>
    </JadeMethod>
    <JadeMethod name="populatePxyFromTi" id="be4cdc16-7fb6-4888-a7b4-4956f1efac8d">
        <updating/>
        <source>populatePxyFromTi(_ti : CM_TrackedItem) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 November 2022	navhl20	ChangeRequest 54979: EUP - Cargo Work Orders Enhancements
02 February 2023    navdp20 ChangeRequest 56969:[56288] EUP - [Framework] Constructing methods to populate booking, bill of lading, and release request conversion
*/

vars

begin
	self.carrierCode		:=	_ti.carrier;
	self.clientRef1			:=	_ti.clientRef;
	self.clientRef2			:=	_ti.clientRef;
	self.consignee			:=	_ti.consignee;
	self.consignor			:=	_ti.consignor;
	self.destinationPort	:=	_ti.destinationPort;
	self.directDelivery		:=	_ti.directDelivery;
	self.dischargePort		:=	_ti.dischargePort;
	self.generalLandingDate	:=	_ti.generalLandingDate;
	self.loadPortCode		:=	_ti.loadPort;
	self.myOperator			:=	_ti.myOperator;
	self.myProduct			:=	_ti.myProduct;
	self.mySubTerminal		:=	_ti.mySubTerminal;
	self.number				:=	_ti.bookingReference;
	self.productCode		:=	_ti.productCode;
	self.remarks			:=	_ti.remarks;
	self.vehicle			:=	_ti.vehicle;
	self.weightTare			:=	_ti.weightTare;
	self.myTerminal         :=  _ti.myTerminal; 					//02.02.2023 navdp20 TFS #56969[56288]
	self.bolType            :=  BOLType_GeneralBillOfLading; 		//02.02.2023 navdp20 TFS #56969[56288]
epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="populatePxyFromTrackedItem" id="60fbe24d-f7e7-4b61-a635-dc21275b567a">
        <updating/>
        <source>populatePxyFromTrackedItem(_tis	: CM_TISet ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
02 November 2022	navgm20	ChangeRequest 54979: EUP - Cargo Work Orders Enhancements

*/
vars
	ti : CM_TrackedItem;
	bolssByTi : DynaDictionary;
	iter : Iterator;
	pxyBolDtl,bolDtl : CM_BOLDtl;
begin
	create bolssByTi transient;
	bolssByTi.setMembership(CM_TrackedItem);
	bolssByTi.addMemberKey(CM_TrackedItem::cargoType.name,true,false);
	bolssByTi.addMemberKey(CM_TrackedItem::commodity.name,true,false);
	bolssByTi.endKeys(true);

	_tis.copy(bolssByTi);

	iter:=bolssByTi.createIterator;
	while iter.next(ti) do
		self.populatePxyFromTi(ti);
		
		pxyBolDtl := self.getMatchingItem( ti.myCargoType,ti.commodity);
		if pxyBolDtl = null then
			create bolDtl transient;						
			bolDtl.populatePxyFromTi(ti);
			self.allBOLDtls.add(bolDtl);	
		else
			pxyBolDtl.increaseItemQuantity(ti);
		endif;
	endwhile;
epilog
	delete iter;
	delete bolssByTi;
end;</source>
        <Parameter name="_tis" type="CM_TISet"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="5ca8c74a-0559-48cb-a5f6-af1027901035">
        <source>pxyCreateUpdateProxy(): SelfType;
//--------------------------------------------------------------
//Created: 28 January 2002 By: cnwgd1
//--------------------------------------------------------------
// 20/04/2011	cnwmh5		PAR #27401 - Add code to handle prossible exceptions occurring when
//							trying to create the proxy
vars
	proxyDocket : CM_BOL;
	ti : CM_TrackedItem;
	bolItem, pxyBOLItem : CM_BOLDtl;
	completedOK		: Boolean;
	stop : CM_Stops;
	pxyStop : CM_Stops;
begin

	proxyDocket := inheritMethod();

	foreach bolItem in self.allBOLDtls do
		pxyBOLItem	:=	bolItem.pxyCreateUpdateProxy();
		pxyBOLItem.setMyBOL(proxyDocket);
	endforeach;

	proxyDocket.mySubTerminal		:=	self.mySubTerminal;
	proxyDocket.myOperator			:=	self.myOperator;
	proxyDocket.myOperatorTerminal	:=	self.myOperatorTerminal;
	proxyDocket.myYardJob 			:=	self.myYardJob;
	proxyDocket.myPlannedLocation 	:=	self.myPlannedLocation;
	proxyDocket.myProduct 			:=	self.myProduct;
	proxyDocket.myTerminal 			:=	self.myTerminal;
	proxyDocket.myManifest			:=	self.myManifest;	
	
	if self.myExtension &lt;&gt; null then
		proxyDocket.myExtension := self.myExtension.pxyCreateUpdateProxy();
	endif;
	
	foreach stop in self.allStops do
		pxyStop := stop.pxyCreateUpdateProxy();
		pxyStop.setMyBOL(proxyDocket);
	endforeach;

	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return proxyDocket;

epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete proxyDocket;
	endif;	
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="qryFilter" id="d132f55a-e70f-48ee-b6af-755ff5a207d5">
        <source>qryFilter(_filter: CM_QFDocket ): Boolean;
// -----------------------------------------------------------------------------
// Created:		07 May 2002 by cnwka1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	---------------------------------------------
//
// -----------------------------------------------------------------------------
vars

	failedDAC  :CM_DataAccessController;
	
begin

	if self.myOperator &lt;&gt; null then
		if (not self.canUserAccessSelf(null, failedDAC, app.myPassport)) then
			return false;
		endif;
	endif;
	
	if (_filter.filterDocketNumber &lt;&gt; null and (not self.number.startsWith(_filter.filterDocketNumber))) or
	   (_filter.operatorCode &lt;&gt; null and self.getOperatorCode.trimRight &lt;&gt; _filter.operatorCode) or
	   (_filter.filterDocketType &lt;&gt; TI_CargoType_Null and self.bolType &lt;&gt; _filter.filterDocketType) then
	   	return false;
	endif;

	return true;
end;</source>
        <Parameter name="_filter" type="CM_QFDocket"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="qrySelectorCriteria" id="84dc4228-09f8-4b03-94f8-ac8606915e6d">
        <source>qrySelectorCriteria(_criteria: CM_SelectorCriteriaLine): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 May 2022	jlier1	Initial creation 53454

*/

vars
	propValue : Any; 
	retval : Boolean;
	oper : CM_QueryOperator;
	ti : CM_TrackedItem;
	bolTerminal : CM_BOLTerminal; // ### TFS 54043 01AUG2022 NAVPW1
begin
	if (_criteria.myQueryProperty.propertyName =  CM_TrackedItem::myPrimaryActualLocation.name) then
		oper := _criteria.myQueryOperator;
		if oper &lt;&gt; null and oper.description = CM_QueryOperator.Operator_Equal then		
			propValue := oper.getSearchValue;
			if propValue = null or not propValue.isKindOf(CM_LocationsController) then
				return false;
			endif;
			foreach ti in self.allTrackedItems discreteLock do
				if ti.myPrimaryActualLocation = propValue.CM_LocationsController then
					return true;
				endif;
			endforeach;
			return false;
		endif;
		
		return false;
	elseif (_criteria.myQueryProperty.propertyName =  CM_TrackedItem::myTerminalArea.name) then
		oper := _criteria.myQueryOperator;
		if oper &lt;&gt; null and oper.description = CM_QueryOperator.Operator_Equal then		
			propValue := oper.getSearchValue;
			if propValue = null or not propValue.isKindOf(CM_TerminalArea) then
				return false;
			endif;
			foreach ti in self.allTrackedItems discreteLock do
				if ti.myPrimaryActualLocation = null then
					continue;
				endif;
				if ti.myPrimaryActualLocation.myTerminalArea = propValue.CM_TerminalArea then
					return true;
				endif;
			endforeach;
			return false;
		endif;
		
		return false;
		
	// ### TFS 54043 01AUG2022 NAVPW1
	elseif (_criteria.myQueryProperty.propertyName = CM_TrackedItem::myTerminal.name) and self.bolType = BOLType_Log then
		oper := _criteria.myQueryOperator;
		if oper &lt;&gt; null and oper.description = CM_QueryOperator.Operator_Equal then
			propValue := oper.getSearchValue;
			if propValue = null or not propValue.isKindOf(CM_Terminal) then
				return false;
			endif;
			
			if self.allBOLTerminals.size = 1 and self.myTerminal = propValue.CM_Terminal then //Not an inter terminal transfer bol and matches terminal
				return true;
			elseif self.allBOLTerminals.size = 1 and self.myTerminal &lt;&gt; propValue.CM_Terminal then //Not an inter terminal transfer bol and doesn't match terminal -Shouldn't get here but just in case
				return false;
			endif;
			
			//Handles inter terminal bols
			foreach bolTerminal in self.allBOLTerminals discreteLock do
				//if bolTerminal.myTerminal = propValue.CM_Terminal and bolTerminal.myBOLIfOrig = null then 
				//bolTerminal.myBOLIfOrig = null was to stop the bol displaying in the soruce terminal.
				//If statement below is to check if it is an inter terminal bol and the bol has arrived at our terminal or not.
				//As per ticket 53605 whereby C3 wanted the bol to display in the source and target terminals
				if bolTerminal.myTerminal = propValue.CM_Terminal then
					return true;
				endif;
			endforeach;
			
			return false;
		endif;
		
		return false;
	// ### TFS 54043 01AUG2022 NAVPW1
	endif;
	return inheritMethod(_criteria);

epilog

end;</source>
        <Parameter name="_criteria" type="CM_SelectorCriteriaLine"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="receiveFromRoad" id="942fb033-5842-4345-ae44-56ff982959e6">
        <updating/>
        <source>receiveFromRoad(_job : CM_RoadJob; _passport : CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:     11 March 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	truck			: CM_Vehicle;
	regNumber,
	userId			: String;
	moveController 	: CMIF_MoveController;
	firstTime,
	cancelSave		: Boolean;
	ti				: CM_TrackedItem;
	coll			: Collection;
	obj				: Any;

begin
	exclusiveLock(self);
	
	self.myYardJob := _job;

	//Lookup the vehicle locations controller
	regNumber := _job.CM_RoadJob.regNumber;
	truck := _job.myVehicle;
	if truck.locationsController = null then
		app.raiseCMException1(Err_InvalidLocation, regNumber, null, null);
		return;
	endif;

	create moveController transient;
	firstTime := true;
	
	coll := self.getTICollectionForTerminal(_passport.myTerminal);
	
	foreach obj in coll do
		ti := obj.CM_TrackedItem;
		if ti.getPrimaryLocation(REAL_MODE) &lt;&gt; null or ti.site = TI_SITE_ONSITE then
			app.raiseCMException1(ERR_TI_NOT_OFFSITE, ti.id, null, null);
		else
			if firstTime then
				firstTime := false;
				moveController.setMyTrackedItem(ti);
			else
				moveController.allOtherTrackedItems.add(ti);
			endif;
		endif;
	endforeach;
	
	if (not _passport.noErrors) then
		return;
	endif;

	moveController.isForcedMove			:= true;
	moveController.isSystemMove 		:= true;
	moveController.setMoveMode(REAL_MODE);
	moveController.setJobForMove(self.myYardJob);		
	moveController.setMyToPrimaryLocation(truck.locationsController);

	app.myUtilityUA.utlUpdateMoveTrackedItem(moveController, _passport);
	if _passport.hasErrors then
		return;
	endif;
	
	if self.myPlannedLocation &lt;&gt; null then
		self.doUpdateLocation(PLANNING_MODE, self.myPlannedLocation, _passport);
	endif;
		
epilog

	delete moveController;

end;</source>
        <Parameter name="_job" type="CM_RoadJob"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="removeAStop" id="9c51a1f7-0fad-411b-9691-4f1e5f704510">
        <updating/>
        <source>removeAStop(_stopType : CM_StopsTable; _isManual : Boolean; _passport : CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:	01 October 2008 By Graeme Black cnwgb1
// Purpose:	Remove a Stop from a BOL
//			CCMS SFW 1012 Customs AMS Interface (PAR 17931)
// ---------------------------------------------------------------------------
/*

Date		Who		Reason
12 Oct 2016	cnwkpd1	TFS 2815 - JADE 7.1.08 causeEvent changes
15 Dec 2022 navma1	Defect 55852: MTN - 1090 exception while loading a Ship Manifest and BOL via EDI	
*/

vars
	theStop			: CM_Stops;
	txnParams 		: CMIF_TITransactionController;
	transObj		: CM_Transaction;

begin
	theStop := self.allStops[_stopType.id];
	if theStop = null then
		return;
	endif;
	
	create txnParams transient;
	txnParams.type     := TRANS_TYPE_BOL_STOP_CLEARED;
	txnParams.userId   := _passport.userCode;
	txnParams.myStop   := theStop;
	txnParams.isManual := _isManual;
	
	if not self.isTransient then
		transObj := self.createTransaction(txnParams, _passport);
		if transObj &lt;&gt; null then						//15.12.2022 navma1 #55852
			transObj.CM_BOLTransaction.createCharge();	//06 Nov 2019	NDL	TFS 47100
		endif;
	endif;
	
	self.updateObjectEdition(self);
	
	delete theStop;
	
epilog
	delete txnParams;
end;</source>
        <Parameter name="_stopType" type="CM_StopsTable"/>
        <Parameter name="_isManual" type="Boolean"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="removeJobEntry" id="98d20e17-8e2f-4f6c-ad84-b492c41ca4e3">
        <updating/>
        <source>removeJobEntry()updating;
//--------------------------------------------------------------
//Created: 02 July 2002 By: cnwgd1
//--------------------------------------------------------------
/*

Date		Who		Reason
19 May 2010	cnwkpd1	PAR #20728 - remove isValidObject calls for performance

*/
vars
	wle, toDoWLE : CM_WorkListEntry;
	req	: CM_Request;
begin

	if self.myYardJob = null then
		return;
	endif;

	wle := self.myYardJob.getWLEForBOL(self);
	if wle &lt;&gt; null then
		toDoWLE := wle.getRelatedWLE();
		
		//need to check for null as system may not be configured for toDoWLEs
		if toDoWLE &lt;&gt; null then
			self.myYardJob.removeWLE(toDoWLE, null ); // cnwrd1 par 22624 3.5.2010
		endif; 
		//need to check for null as job may have been erased when toDoWLE removed
		if self.myYardJob &lt;&gt; null then			// and global.isValidObject(self.myYardJob) then
			self.myYardJob.removeWLE(wle, null); // cnwrd1 par 22624 3.5.2010
		endif;
		
	endif;

end;</source>
    </JadeMethod>
