    <JadeMethod name="doInitializeSystem" id="4e706fb1-7c0d-49ac-a631-fecf196d514f">
        <updating/>
        <source>doInitializeSystem() : Boolean updating;
// -----------------------------------------------------------------------------
// Created:		18 February 2002 by cnwka1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	---------------------------------------------
// TFS 53592 Added Subscription License to Initialize App
//
// -----------------------------------------------------------------------------
constants
	Steps = 11;
vars
	manager: BGP_Manager;
	licenseKey,licenseName: String;
	returnCode: Boolean;	
	menuAgent: CM_MenuAgent;
	superUser: CM_User;
	userTerminal: CM_UserTerminal;
	jSSLPublicInterface: JSSLPublicInterface;
begin
	returnCode := false;
	mousePointer := MousePointer_HourGlass;
	if not self.valFormData() then
		return returnCode;
	endif;
	self.shtStatus.visible := true;
	self.btnOK.enabled := false;
	self.shtStatus.setFocus();
	self.refreshNow();

	self.showProgress(1,Steps,'Cleanup database...');
	if self.deleteAllObjects = false then
		return returnCode;
	endif;
	self.showProgress(2,Steps,'Creating Root...');
	
	if not self.myInitAgent.createRoot(self.txtCoyCode.text, self.txtCoyName.text, self.txtClientName.text.toUpper()) then
		return returnCode;
	endif;
	
	if app.myRoot = null then
		app.setPropertyValue(PortSchema::myRoot.name, CM_Root.firstInstance);
	endif;
	
	// now we have created root we can initialize the agents properly.
	app.initializeAgents();	

	self.showProgress(3,Steps,'Initializing Root...');
	if not self.myInitAgent.initializeRoot() then
		return returnCode;
	endif;

	// RBarr 1/9/2006 Superceded (localisation changes)
	//app.myRoot.loadErrMsgsFromGlbConstantsOLD();
	
	app.myPassport.setMyUserFromCode('SUPERUSER');

	self.showProgress(4,Steps,'Creating Terminal ' &amp; txtTermCode.text &amp; '  ' &amp; txtTermName.text);
	if not self.myInitAgent.createTerminal(txtTermCode.text, txtTermName.text) then
		return returnCode;
	endif;

	self.showProgress(5,Steps,'Creating Organisation ' &amp; app.myRoot.companyName);
	if not self.myInitAgent.createOrganisation(app.myRoot.companyName) then
		return returnCode;
	endif;
	superUser := app.myRoot.allUsers['SUPERUSER'];
	beginTransaction;
	superUser.setPropertyValue("myOrganisation", CM_InternalOrganisation.firstInstance);
	commitTransaction;

	self.showProgress(6, Steps, 'Setting up JMT License');
	create jSSLPublicInterface transient;
	app.setPropertyValue("myCheckerObject", jSSLPublicInterface);
	//if not self.doJMTLicense(txtLicName.text, txtLicense.text, txtEDILicName.text, txtEDILicense.text) then
	if not self.doJMTLicense(txtLicName.text, txtLicense.text, txtEDILicName.text, txtEDILicense.text, txtSubLicName.text, txtSubLicense.text) then		// navmd1 09/05/22 TFS 53592 
		return returnCode;
	endif;
	superUser := app.myRoot.allUsers['SUPERUSER'];
	beginTransaction;
	superUser.setPropertyValue("mySystemSecurityRole", CM_SecurityRoleSystemRoot.firstInstance);
	foreach userTerminal in superUser.allUserTerminals do
		userTerminal.setPropertyValue("mySecurityRole", CM_SecurityRoleTerminalRoot.firstInstance);
	endforeach;
	commitTransaction;

	self.showProgress(7, Steps, 'Creating BGP Manager');
	// Create default BGP set up.
	if not self.defaultBGPSetup() then
		return returnCode;
	endif;

	self.showProgress(8,Steps,'Creating ADMIN user ' &amp; self.txtUserName.text);
	if not self.createAdminSecurityRoles() then
		return returnCode;
	endif;
	if not self.createAdminUser() then
		return returnCode;
	endif;

	self.showProgress(9, Steps, 'Running JMT Current Release');
	if not self.doJMTRelease() then
		return returnCode;
	endif;
	
	// 15/09/2014 cnwmh5 #34692 - Set Toolbar to JMT Default
	superUser := app.myRoot.allUsers['SUPERUSER'];
	beginTransaction;
	superUser.resetToolbarMenuFromJMTDefault();								
	commitTransaction;

	self.showProgress(10, Steps, 'Running Special Release');
	if not self.doSpecialRelease() then
		return returnCode;
	endif;

	self.btnOK.enabled := false; //we must have completed
	self.btnReLicense.enabled := true;
	self.showProgress(Steps, Steps, 'Complete.');
	returnCode := true;
epilog
	// Actually log something if anything goes wrong (especially if running the batch app)
	if not returnCode then
		self.showProgress(0, Steps, "ERROR: " &amp; app.myPassport.getAllErrorsWarningsAsString);
	endif;
	
	mousePointer := MousePointer_Default;
	return returnCode;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doJMTLicense" id="90816c95-a5af-4ad5-aeb3-50f9fe0f0efb">
        <source>doJMTLicense(_licenseName, _licenseKey, _licenseNameEDI, _licenseKeyEDI, _licenseNameSubs, _licenseKeySubs: String) : Boolean;
// -----------------------------------------------------------------------------
// Created:		October 2004  by cnwrs1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	---------------------------------------------
// 09/05/2022	navmd1		TFS 53592 Added Subscription License to Initialize App
//
// -----------------------------------------------------------------------------
vars
	returnCode: Boolean;
begin
	returnCode := false;
	app.myTrxUA.trxUpdateLicense(CM_Root.firstInstance, _licenseName, _licenseKey, ProductCode_JMT, CM_Root.firstInstance.edition, app.myPassport);
	if not app.myPassport.noErrors then
		return returnCode;
	endif;
	if _licenseKeyEDI &lt;&gt; null then
		app.myTrxUA.trxUpdateLicense(CM_Root.firstInstance, _licenseNameEDI, _licenseKeyEDI, ProductCode_JMT_EDI, CM_Root.firstInstance.edition, app.myPassport);
		if not app.myPassport.noErrors then
			return returnCode;
		endif;
	endif;
	if _licenseKeySubs &lt;&gt; null then
		app.myTrxUA.trxUpdateLicense(CM_Root.firstInstance, _licenseNameSubs, _licenseKeySubs, ProductCode_Subs, CM_Root.firstInstance.edition, app.myPassport);
		if not app.myPassport.noErrors then
			return returnCode;
		endif;
	endif;
	
	returnCode := true;
epilog
	return returnCode;
end;</source>
        <Parameter name="_licenseName" type="String"/>
        <Parameter name="_licenseKey" type="String"/>
        <Parameter name="_licenseNameEDI" type="String"/>
        <Parameter name="_licenseKeyEDI" type="String"/>
        <Parameter name="_licenseNameSubs" type="String"/>
        <Parameter name="_licenseKeySubs" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doJMTRelease" id="5ce2e405-9357-41cd-9044-d4efa473d7e7">
        <source>doJMTRelease(): Boolean;
// ---------------------------------------------------------------------------
// Created:     4 March 2004 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	returnCode: Boolean;
begin
	returnCode := app.jmtReleaseApp();
epilog
	return returnCode;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doReLicense" id="7b4b69a9-922a-4bd5-a2ad-c2c2c9239ca7">
        <updating/>
        <source>doReLicense() updating;
// -----------------------------------------------------------------------------
// Created:		October 2004  by cnwrs1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	---------------------------------------------
// TFS 53592 Added Subscription License to Initialize App
// 
// -----------------------------------------------------------------------------
vars

begin
	mousePointer := MousePointer_HourGlass;
	app.initialize;
	self.btnOK.enabled := false; // since app.initialize has been run initialise will fail
	//if self.doJMTLicense(txtLicName.text, txtLicense.text, txtEDILicName.text, txtEDILicense.text) then
	if self.doJMTLicense(txtLicName.text, txtLicense.text, txtEDILicName.text, txtEDILicense.text, txtSubLicName.text, txtSubLicense.text) then		// TFS 53592 09/05/22 navmd1
//		beginTransaction;
//		CM_Root.firstInstance.setPropertyValue("versionString", null);
//		commitTransaction;
//		self.jmtRelease;	
		beginTransaction;
		CM_Terminal.firstInstance.setPropertyValue("name", txtLicName.text);
		commitTransaction;
	endif;
epilog
	mousePointer := MousePointer_Default;
end;</source>
