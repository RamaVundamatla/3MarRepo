    <JadeMethod name="setupContextMenuItems" id="b40e1da3-fe47-43f0-a922-25bfbd4fb7c7">
        <source>setupContextMenuItems(_table : CM_DataTable);
//06 November 2009	cnwml2
//+cnwml2 MSL CCMS 1012

vars

begin

	
	if _table.allSelectedObjects.size = 1 then
		self.mnuViewBooking.visible := true;
		self.mnuViewBooking.userObject := _table.allSelectedObjects.first;
	else
		self.mnuViewBooking.visible := false;
	endif;

	if self.isStock then
		self.mnuShowCargo.visible := true;
	else
		self.mnuShowCargo.visible := false;
	endif;
	
	if _table = self.tblLeft then
		mnuShowCargo.visible := false;
	endif;
	
epilog

end;</source>
        <Parameter name="_table" type="CM_DataTable"/>
    </JadeMethod>
    <JadeMethod name="setupDefaultHelpKeyword" id="41862d68-e921-418f-bfbc-47193ce62ef1">
        <updating/>
        <source>setupDefaultHelpKeyword() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 May 2014	cnwkpd1	PAR #34210 - CCMS SFW 1350 - Online Documentation

*/

vars

begin
	self.helpKeyword := HelpFile_SearchString &amp; 'Linking Stock Booking Items';

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setupForm" id="ae8ba4b6-3aa3-40b7-ab80-a99acf17c2e4">
        <updating/>
        <source>setupForm() updating;
//06 November 2009	cnwml2


vars

begin
	inheritMethod();
	frmMain.zOrder(1);
	self.toolbarStyle := ToolbarStyle_None;
	
	self.myParentForm.enabled := false;

	self.minimumWidth := 490;
	self.minimumHeight := 400;
	self.width := 490;
	self.height:= 400;
	
	
	if isStock then
		self.caption := app.getString(Stock_Caption) &amp; self.myProxyBooking.bookingReference;
		self.lblInstructions.caption := app.getString(Stock_Instructions);
		//self.lblLeftTbl.caption := app.getString(Stock_LeftTbl_Caption);
		//self.lblRightTbl.caption := app.getString(Stock_RightTbl_Caption);
		self.btnShowCargo.visible := true;
		self.btnShowCargo.enabled := true;
	else
		self.caption := app.getString(Export_Caption) &amp; self.myProxyBookingItem.getShortDisplay();
		self.lblInstructions.caption := app.getString(Export_Instructions);
	//	self.lblLeftTbl.caption := app.getString(Export_LeftTbl_Caption);
	//	self.lblRightTbl.caption := app.getString(Export_RightTbl_Caption);
		self.btnShowCargo.visible := false;
	endif;
	
	self.loadTables();
	
epilog

end;</source>
    </JadeMethod>
