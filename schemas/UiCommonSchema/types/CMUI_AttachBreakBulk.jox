    <JadeMethod name="addItem" id="01e66568-c286-4b6f-b856-4ef9e31d57b9">
        <updating/>
        <source>addItem() updating;
// ---------------------------------------------------------------------------
// Created:     16 October 2002		cnwth2	
//
// Purpose:     
//			 
// Changed On	Changed By	Reason
// ----------   ----------  --------------------------------------------------
// 20/06/2022	navdap1		TFS 53362 EUP Master Data interface customers between TOS and ERP
vars
	cmifAttach			: CMIF_InOutAttachment;
	table				: CM_DataTable;
	idx					: Integer;
	lc					: CM_LocationsController;
	terminalAreaStr		: String;
	lcStr				: String;
	idStr				: String;
	itemCount			: Integer;
	userResponse		: Integer;
	//cargoType			: CM_CargoType;
	operator			: CM_Operator;		// TFS 53362
	operatorCode		: String;			// TFS 53362
	
begin

	if not self.validateItemInput() then
		self.tblItem.setFocus();
		return;
	endif;
	
	//check existing attachments for duplicate id
	idStr := self.tblItem.getValueByName(ETRow_ItemId).String;
	// Check whether the expected number of Items has been exceeded.
	
	itemCount	:=	tblAll.rows - 1;	// -1 to exclude the headings row.
	
	if self.aNumberOfItems &gt; 0 and (itemCount + 1) &gt; self.aNumberOfItems then
		userResponse	:=	app.msgBox(	"Only " &amp; self.aNumberOfItems.cnEcNumberFormat() &amp; " items are expected - do you wish to increase this limit ?",
							"Item Limit",
							MsgBox_Question_Mark_Icon + MsgBox_Yes_No);
		
		if userResponse = MsgBox_Return_Yes then
			self.aNumberOfItems		:=	self.aNumberOfItems + 1;
			self.aIsItemsIncreased	:=	true;
		elseif userResponse = MsgBox_Return_No then
			return;
		endif;
	endif;
	
	// Now create the Item.
	create cmifAttach transient;
	
	if not self.setFromItemFromTable(cmifAttach) then
		return;
	endif;
	
	table := self.tblAll;
	self.aAllAttachments.add(cmifAttach);
	
	if self.aMyMasterTI &lt;&gt; null then
		if self.aMyMasterTI.myTerminalArea &lt;&gt; null then
			terminalAreaStr := self.aMyMasterTI.myTerminalArea.id;
			lc := self.aMyMasterTI.getPrimaryLocation(REAL_MODE);
		elseif self.aMyMasterTI.isOnShip() and //ccms 1093 cnwrs1 Mar 2008
			   self.aMyMasterTI.getPrimaryLocation(REAL_MODE) &lt;&gt; null then
				lc := self.aMyMasterTI.getPrimaryLocation(REAL_MODE);
		else
			app.msgBox(app.getErrorString(LocationForContainerNull), app.getErrorString(NoLocationOnContainer), MsgBox_OK_Only + MsgBox_Information_Icon);
		endif;
	else
		if cmifAttach.myTerminalArea &lt;&gt; null then
			terminalAreaStr := cmifAttach.myTerminalArea.id;
		endif;
		lc := cmifAttach.myLocationsController;
	endif;
	
	if lc &lt;&gt; null then
		lcStr := lc.getID();
	endif;
	
	// TFS 53362 start
	operatorCode := cmifAttach.operatorCode;
	if cmifAttach.operatorCode &lt;&gt; null then
		operator := app.myRoot.allOperators[cmifAttach.operatorCode];
		if operator &lt;&gt; null and app.myRoot.getConfig(ComboByNameOperator).Boolean then
			operatorCode := operator.description;
		endif;
	endif;
	// TFS 53362 end
	idx := table.addItem(cmifAttach.id &amp; Tab &amp;
							//cmifAttach.operatorCode &amp; Tab &amp;			// TFS 53362
							operatorCode &amp; Tab &amp;						// TFS 53362
							cmifAttach.myCargoType.description &amp; Tab &amp;
							terminalAreaStr &amp; Tab &amp;
							lcStr);
	
	table.accessRow(idx).itemObject := cmifAttach;
	self.tblItem.clearHasChanged();
	self.updateItemCount();
	self.tblItem.goToRowByName(ETRow_Id);	
	self.tblItem.setFocus();
end;</source>
    </JadeMethod>
    <JadeMethod name="autoCalcVolume" id="341e7351-27a6-40ca-a137-96b21ae11f3c">
        <source>autoCalcVolume(_table : CM_EntryTable input) protected;
/* ---------------------------------------------------------------------------
Created:	18 November 2010	by cnwvu1

Purpose:	
   
Change Date		Who			Reason
-----------		--------	--------------------------------------------------
27/03/2013		cnwdap1		PAR #31155 CCMS SFW 1321 Imperial Measurements
							myAssistant.autoCalcVolumeWhenNotNull parameters changed to Decimal
------------------------------------------------------------------------------*/
vars
	volume : Decimal[16,4];
	
begin

	//volume := self.myAssistant.autoCalcVolumeWhenNotNull(	_table.getValueByNameIfVisible(ETRow_MyLength).Integer,					// PAR #31155
	//														_table.getValueByNameIfVisible(ETRow_MyWidth).Integer,					// PAR #31155
	//														_table.getValueByNameIfVisible(ETRow_MyHeight).Integer,					// PAR #31155
	//														_table.getValueByNameIfVisible(ETRow_MyVolume).String.asDecimalJMT() );	// PAR #31155
	volume := self.myAssistant.autoCalcVolumeWhenNotNull(	_table.getValueByNameIfVisible(ETRow_MyLength).Decimal,					// PAR #31155
															_table.getValueByNameIfVisible(ETRow_MyWidth).Decimal,					// PAR #31155
															_table.getValueByNameIfVisible(ETRow_MyHeight).Decimal,					// PAR #31155
															_table.getValueByNameIfVisible(ETRow_MyVolume).String.asDecimalJMT() );	// PAR #31155
	
	_table.setValueByName(ETRow_MyVolume, volume);

end;</source>
        <access>protected</access>
        <Parameter name="_table" type="CM_EntryTable" usage="input"/>
    </JadeMethod>
    <JadeMethod name="cmbBookingItem_lostFocus" id="2efca600-0a31-4883-9a88-71919da02b7b">
        <controlMethod name="CMUI_ComboBoxObject::lostFocus"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbBookingItem_lostFocus(combobox: ComboBox input) updating;
//06 October 2010	cnwml2
//+cnwml2 PAR25895

vars

	bItem			: CM_BookingRefItem;	
	commodity		: CM_Commodity;
begin
	bItem := combobox.listObject.CM_BookingRefItem;
	if bItem &lt;&gt; null then
		self.tblItem.setValueByControlName(combobox.name, bItem.getShortDisplay);
			
		if bItem.commodity &lt;&gt; null then
			commodity := app.myRoot.allCommodities[bItem.commodity].CM_Commodity;
			self.tblItem.setValueByName(ETRow_Commodity, bItem.commodity);
			self.cmbCommodity.setObject(commodity);
		else
			self.cmbCommodity.setObject(null);
			self.tblItem.setValueByName(ETRow_Commodity, null);
		endif;
	endif;
	

	self.cmbImExStatus.setIndexFromObject(app.myRoot.allImexStatuses[TI_IMEX_STATUS_EXPORT]);
	self.tblItem.setValueByName(ETRow_ImexStatus, app.myRoot.allImexStatuses[TI_IMEX_STATUS_EXPORT].CM_IMEXStatus.description);
epilog

end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
    </JadeMethod>
