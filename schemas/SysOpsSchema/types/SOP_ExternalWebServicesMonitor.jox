    <JadeMethod name="setupForm" id="398f5e4c-f83d-4b00-aeac-d642e2bd591f">
        <updating/>
        <source>setupForm() updating;
/*
Purpose:			

Date		Who		Reason
23 Jul 2021	navab1	TFS 50669
23 Feb 2022	navdap1	TFS 52268 AAT 1-Stop VBS Integration
01/04/2022	navgm20	TFS 52777  EUP - INT - Generic API: record-scan
10/10/2022	jlika1	TFS 54892 - POB - Vessel, Voyage and Movement EDI Messages
08/12/2022	navdap1	TFS 55159 MTN Export CAMS to JSON API Endpoint
30/03/2023	jlier1 		TFS 56856
30/11/2023	navra1  TFS 54090 CR - 61380/Task
27/02/2024	navdap1	TFS 62641 Tidy up index out of bounds error
14/08/2024	navcs2	Bug 65590: EUP - EWS Monitor - Free text search not working
27 September 2024	navcs2	ChangeRequest 66181: MTN | External Webservice Monitor - Feedback
28/11/2024	navcs2	MTN-33423 MTN - External Web service monitor - Selected options are not saved when form is closed and reopened
02 December 2024	navrv30	JIRA 33578 EUP | Incoming API Logging
*/

vars

	wsDef				: CM_OpsViewServiceDef;
	ws1StopDef			: CM_1StopVBSWebServiceDef;
	fromTime, toTime 	: Time;						// 28/11/2024	navcs2	MTN-33423			
	tmpStr,											// 28/11/2024	navcs2	MTN-33423
	block			: String;						// 28/11/2024	navcs2	MTN-33423
	tmpDate,										// 28/11/2024	navcs2	MTN-33423
	today			: Date;							// 28/11/2024	navcs2	MTN-33423
begin
	create self.filterEWSActivities transient;
	
	self.doCmbInterfaceNameBuild();
	inheritMethod();
	
	self.frmTableFilter.setupControl(self.tblData, null);		// 14/08/2024	navcs2	Bug 65590

	self.doCmbTypeBuild();
	self.doCmbActionBuild();
	self.doCmbEWSBuild();				//navra1 - TFS 54090 CR - 61380/Task - 61385 - 30th Nov 2023
	self.buildTblResponses();
	self.buildTblTerminals();
	self.buildTblStatus();
	self.doInitTable();
	self.buildTblInterface();
	self.buildTblMessageTypes();					//navra1 - MTN-35875- 5th Sep 2025-4
	
	// 28/11/2024	navcs2	MTN-33423 Start
	block := self.selectedDates;
	
	today := self.systemToLocalTime(app.actualTimeServer).date;
	
	tmpStr := block.cnEcGetTagValueOfName(self.XML_FromDate);
	tmpDate := today + tmpStr.Integer;
	self.mskDateFrom.text := tmpDate.asStringJMT();
	
	//from time
	tmpStr := block.cnEcGetTagValueOfName(self.XML_FromTime);

	self.mskTimeFrom.setTime(tmpStr.asTimeJMT());
	
	//to date
	tmpStr := block.cnEcGetTagValueOfName(self.XML_ToDate);
	tmpDate := today + tmpStr.Integer;
	
	if tmpDate.isValid then
		if tmpDate = app.actualTimeServer.date then
			self.mskDateTo.text := null;
		else
			self.mskDateTo.text := tmpDate.asStringJMT();
		endif;
	endif;
	
	tmpStr := block.cnEcGetTagValueOfName(self.XML_ToTime);
	self.mskTimeTo.setTime(tmpStr.asTimeJMT());
	// 28/11/2024	navcs2	MTN-33423 End
	
	self.doShowQuery();
	self.frmQuery.zOrder(1);				// 28/11/2024	navcs2	MTN-12589
	
	/*	28/11/2024	navcs2	MTN-12589
	if self.filterInvoice &lt;&gt; null then
		self.cmbInterfaceName.listIndex:= self.cmbInterfaceName.findString(1,ExternalWebServiceFinanceOne);
		self.frmQuery.visible:=false;
	else
	
		/*
		if self.sheetOpsView.visible then
			self.cmbInterfaceName.listIndex := self.cmbInterfaceName.findString(1,self.Interface_OpsView);
		elseif self.sht1StopVBS.visible then
			self.cmbInterfaceName.listIndex := self.cmbInterfaceName.findString(1,self.Interface_1StopVBS);
		elseif self.shtGenericAPIScan.visible then
			self.cmbInterfaceName.listIndex := self.cmbInterfaceName.findString(1,self.Interface_GenericAPIScan);
		elseif self.sheetQships.visible then
			self.cmbInterfaceName.listIndex := self.cmbInterfaceName.findString(1,self.Interface_Qships);
		// ### TFS 55215 29Nov2022 NAVPW1
		elseif self.shtEdbic.visible then
			self.cmbInterfaceName.listIndex := self.cmbInterfaceName.findString(1,self.Interface_EDBIC);
		// ### TFS 55215 29Nov2022 NAVPW1
		elseif self.shtCams.visible then			// TFS 55159
			self.cmbInterfaceName.listIndex := self.cmbInterfaceName.findString(1,self.Interface_Cams);	// TFS 55159
		elseif self.shtAPIENDPOINT.visible then 	//06.April.2023 navsp1 TFS 57491
			self.cmbInterfaceName.listIndex := self.cmbInterfaceName.findString(1,self.Interface_APIENDPOINT);
		elseif self.shtFinanceOne.visible then
			self.cmbInterfaceName.listIndex := self.cmbInterfaceName.findString(1,ExternalWebServiceFinanceOne); // 30/03/2023	jlier1 		TFS 56856
		elseif self.shtInvoiceAPI.visible then		//navra1 - TFS 54090 CR - 61380/Task - 61385 - 30th Nov 2023
			self.cmbInterfaceName.listIndex := self.cmbInterfaceName.findString(1,self.Interface_InvoiceAPI);	//navra1 - TFS 54090 CR - 61380/Task - 61385 - 30th Nov 2023
		endif;										//navra1 - TFS 54090 CR - 61380/Task - 61385 - 30th Nov 2023
	*/ // 28/11/2024	navcs2	MTN-12589
	
	
	self.cmbInterfaceName.text := self.filterInterfaceName;		// 28/11/2024	navcs2	MTN-33423
	self.cmbInterfaceName.click(self.cmbInterfaceName);  //jlier1 TFS 56856 30/3/23
	
	self.getBGPStatusDetails();
	self.getProducerStatusDetails();
	
	self.beginClassNotification(CM_EWSActivityOpsview, false, Object_Create_Event, Response_Continuous, 0);
	self.beginClassNotification(CM_EWSActivityOpsview, false, Object_Update_Event, Response_Continuous, 0);
	self.beginClassNotification(CM_EWSActivityOpsview, false, Object_Delete_Event, Response_Continuous, 0);
	self.beginClassNotification(CM_EWSActivity1Stop, false, Object_Create_Event, Response_Continuous, 0);		// TFS 52268
	self.beginClassNotification(CM_EWSActivity1Stop, false, Object_Update_Event, Response_Continuous, 0);		// TFS 52268
	self.beginClassNotification(CM_EWSActivity1Stop, false, Object_Delete_Event, Response_Continuous, 0);		// TFS 52268
	self.beginClassNotification(CM_EWSActivityGenericScan, false, Object_Create_Event, Response_Continuous, 0);		// TFS 52777
	self.beginClassNotification(CM_EWSActivityGenericScan, false, Object_Update_Event, Response_Continuous, 0);		// TFS 52777
	self.beginClassNotification(CM_EWSActivityGenericScan, false, Object_Delete_Event, Response_Continuous, 0);		// TFS 52777
	self.beginClassNotification(CM_EWSActivityQships, false, Object_Create_Event, Response_Continuous, 0);		
	self.beginClassNotification(CM_EWSActivityQships, false, Object_Update_Event, Response_Continuous, 0);		
	self.beginClassNotification(CM_EWSActivityQships, false, Object_Delete_Event, Response_Continuous, 0);		
	self.beginClassNotification(CM_EWSActivityCams, false, Object_Create_Event, Response_Continuous, 0);		// TFS 55159
	self.beginClassNotification(CM_EWSActivityCams, false, Object_Update_Event, Response_Continuous, 0);		// TFS 55159
	self.beginClassNotification(CM_EWSActivityCams, false, Object_Delete_Event, Response_Continuous, 0);		// TFS 55159
	
	self.beginClassNotification(CM_EWSActivityInvoiceAPIParts, false, Object_Create_Event, Response_Continuous, 0);		//navra1 - TFS 54090 CR - 61380/Task - 61385 - 30th Nov 2023
	self.beginClassNotification(CM_EWSActivityInvoiceAPIParts, false, Object_Update_Event, Response_Continuous, 0);		//navra1 - TFS 54090 CR - 61380/Task - 61385 - 30th Nov 2023
	self.beginClassNotification(CM_EWSActivityInvoiceAPIParts, false, Object_Delete_Event, Response_Continuous, 0);		//navra1 - TFS 54090 CR - 61380/Task - 61385 - 30th Nov 2023
	
	self.beginClassNotification(CM_EWSActivityAgGateway, false, Object_Create_Event, Response_Continuous, 0);		//navra1 - MTN-34782 - 15th July 2025
	self.beginClassNotification(CM_EWSActivityAgGateway, false, Object_Update_Event, Response_Continuous, 0);		//navra1 - MTN-34782 - 15th July 2025
	self.beginClassNotification(CM_EWSActivityAgGateway, false, Object_Delete_Event, Response_Continuous, 0);		//navra1 - MTN-34782 - 15th July 2025	
	
	self.beginNotification(system,BGP_Object.BGP_NavisSmartProducerStarting, Response_Continuous, 0); // ### TFS 50669 19AUG2021 NAVAB1
	self.beginNotification(system,BGP_Object.BGP_NavisSmartProducerStopped, Response_Continuous, 0); // ### TFS 50669 19AUG2021 NAVAB1
	self.beginNotification(system,BGP_Object.BGP_NavisSmartProducerRunning, Response_Continuous, 0); // ### TFS 50669 19AUG2021 NAVAB1
	self.beginNotification(system,BGP_Object.BGP_NavisSmartProducerSnapshot, Response_Continuous, 0); // ### TFS 50669 19AUG2021 NAVAB1
	
	self.beginClassNotification(CM_EWSActivityFinanceOne, false, Object_Create_Event, Response_Continuous, 0);	//jlier1 TFS 56856 30/3/23
	self.beginClassNotification(CM_EWSActivityFinanceOne, false, Object_Update_Event, Response_Continuous, 0);		//jlier1 TFS 56856 30/3/23
	self.beginClassNotification(CM_EWSActivityFinanceOne, false, Object_Delete_Event, Response_Continuous, 0);		//jlier1 TFS 56856 30/3/23
	
	//02 December 2024	navrv30	JIRA 33578
	self.beginClassNotification(CM_EWSActivityAPILog, false, Object_Create_Event, Response_Continuous, 0);	
	self.beginClassNotification(CM_EWSActivityAPILog, false, Object_Update_Event, Response_Continuous, 0);		
	self.beginClassNotification(CM_EWSActivityAPILog, false, Object_Delete_Event, Response_Continuous, 0);	
	
	// TFS 52268 start
	if self.is1StopVBS then
		ws1StopDef := app.myRoot.getFirstActiveExtWebService(CM_1StopVBSWebServiceDef).CM_1StopVBSWebServiceDef;
		if ws1StopDef &lt;&gt; null then
			self.beginNotification(ws1StopDef, Object_Update_Event, Response_Continuous, 0);
		endif;
	endif;
	// TFS 52268 end
	wsDef := app.myRoot.getFirstActiveExtWebService( CM_OpsViewServiceDef ).CM_OpsViewServiceDef;
	if wsDef&lt;&gt; null then
		 self.beginNotification(wsDef, Object_Update_Event, Response_Continuous, 0);
	endif;
	
	self.doSetTimer();
	
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		self.mnuDelete.enabled := false;
	endif;
	
	//18 December 2024	navrv30	JIRA 33578
	self.frmTableFilter.setCallbackMethod(SOP_ExternalWebServicesMonitor::doFilterTable.name);
	self.frmTableFilter.setSkipControlFilter(true);
	//jlier1 TFS 56856 30/3/23
	if self.filterInvoice &lt;&gt; null then
		//self.txtInvoiceFO.text:=self.filterInvoice.sequenceNum.asStringJMT;
		//self.cmbTerminal.setIndexFromObject(self.filterInvoice.myTerminal);
		self.populateTableFinanceOne;
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setupGenericAPIScan" id="d12bb65e-5bf4-4c58-b0fd-674394890c60">
        <source>setupGenericAPIScan();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23/05/2024	navcs2	ChangeRequest 59188: EUP | API Search - External Webservice Monitor
14/08/2024	navcs2	Bug 65590: EUP - EWS Monitor - Free text search not working
25/11/2025	navdap1	MTN-36569 CPL | Reefer Runner Integration
*/

vars

begin
	self.shtBasicInfo.caption := self.Interface_GenericAPIScan;

	self.lblInvoiceFO.visible := false;
	self.txtInvoiceFO.visible := false;
	self.lblCreatedBy.visible := false;
	self.txtCreatedBy.visible := false;
	self.cmbEWSNameInvoiceAPI.visible := false;
	self.lblEWSName.visible := false;
	self.grpType.visible := false;
	self.lblCamsProtocol.visible := false;
	self.cmbProtocolCams.visible := false;
	
	self.lblDataAction.visible := true;
	self.cmbAction.visible := true;
	self.lblType.visible := true;
	self.cmbType.visible := true;
	self.lblType.top := self.TopLevel150;
	self.cmbType.top := self.TopLevel150;
	self.cmbAction.top := self.TopLevel180;
	self.lblDataAction.top := self.TopLevel180;
