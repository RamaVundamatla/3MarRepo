<Class name="CM_KioskTermsAndConditions" id="6bb02d02-de5d-4f2d-8c25-c2da792204ce">
    <superclass name="CM_KioskObject"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="location"/>
    <ExplicitInverseRef name="allTermsAndConditions" id="82691949-3ae5-4cd1-8d01-76d15e6d25d1">
        <kind>parent</kind>
        <transientToPersistentAllowed/>
        <updateMode>manual</updateMode>
        <type name="CM_KioskTranslationByLocale"/>
        <access>readonly</access>
        <Inverse name="CM_KioskTranslation::myKioskObject"/>
    </ExplicitInverseRef>
    <JadeMethod name="addTermsAndConditions" id="70c634e9-868a-4d5b-a19c-a0755cd91d2b">
        <source>addTermsAndConditions(_pxyTC : CM_KioskTranslation);
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
11 August 2023		jlizm1	Initial creation TFS 59549 Kiosk maintenance terms and conditions

*/

vars

begin
	if _pxyTC = null then
		return;
	endif;
	
	self.allTermsAndConditions.add(_pxyTC);

epilog

end;</source>
        <Parameter name="_pxyTC" type="CM_KioskTranslation"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="232ad05f-3dc1-4bae-a923-2bc03d8eb67a">
        <source>pxyCreateUpdateProxy(): SelfType;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 August 2023	jlier1	Initial creation 58511

*/

vars
	proxy			: SelfType;
	completedOK		: Boolean;
	kioskTranslation ,
	pxyKioskTranslation : CM_KioskTranslation;
begin
	proxy :=  inheritMethod();
	
	foreach  kioskTranslation in self.allTermsAndConditions discreteLock do
		pxyKioskTranslation := kioskTranslation.pxyCreateUpdateProxy(); 
		proxy.allTermsAndConditions.add(pxyKioskTranslation);
	endforeach;
	completedOK := true;			
	return proxy;
	
epilog
	if not completedOK then			
		delete proxy;
	endif;	

end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="removeTermsAndConditions" id="c9cb44b7-8a82-4983-a04e-4a83aa8e11b0">
        <source>removeTermsAndConditions(_pxyTC : CM_KioskTranslation);
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
11 August 2023		jlizm1	Initial creation TFS 59549 Kiosk maintenance terms and conditions

*/

vars

begin
	if _pxyTC = null then
		return;
	endif;
	
	if self.allTermsAndConditions.includes(_pxyTC) then
		self.allTermsAndConditions.remove(_pxyTC);
	endif;
	
epilog

end;</source>
        <Parameter name="_pxyTC" type="CM_KioskTranslation"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="53c1e1b8-54a6-4f41-b3c1-23882b7e4c23">
        <updating/>
        <source>setForUpdate(_proxy : CM_KioskTermsAndConditions) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 August 2023	jlier1	Initial creation 58511

*/

vars

begin
	inheritMethod(_proxy);
	self.updateTranslations(self.allTermsAndConditions,_proxy.allTermsAndConditions);

epilog
	
end;</source>
        <Parameter name="_proxy" type="CM_KioskTermsAndConditions"/>
    </JadeMethod>
</Class>
