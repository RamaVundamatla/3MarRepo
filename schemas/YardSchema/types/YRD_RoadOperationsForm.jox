    <JadeMethod name="saveGateEntity" id="9441d7d8-3635-4ff8-9194-ade42cf79bd7">
        <updating/>
        <source>saveGateEntity(_isUpdate: Boolean; _pxyGTE: Object input; _valdationOnly: Boolean; warningsToIgnore: IntegerArray): Boolean updating;
/*

Date		Who		Reason
24 November 2015	cnwer1	Initial creation PAR

*/

vars
	vvr : CM_VehicleVisitRecord;
	result : Integer;
begin
	
	if self.myCurrentRoadJob = null then
		return false;
	endif;
	vvr:=self.myCurrentRoadJob.myVehicleVisit;
	if not _isUpdate then
		return false;
	endif;
	
	while true do
		
		app.myTrxUA.trxUpdateGTEReleaseAndRequest(vvr, _pxyGTE.CMGTE_Release,self.myCurrentWLE.CM_YardWLE, app.myPassport);
		
		
		if app.myPassport.trxCompletedOK  then
			//epr changes for CCMS 1386 ROB gate cargo
			break;
		else	
			//18 Nov 2011	NDL	Par 28527
			result := IDOK;
			app.myPassport.deleteWarningsFor( warningsToIgnore );
			if app.myPassport.hasErrorsOrWarnings then
				result := app.showErrorWarningDialog(app.getErrorString(GateInOut), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			endif;
			
			//result := app.showErrorWarningDialog(app.getErrorString(GateInOut), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and result = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged := true;
				 continue;
			endif;
			return false;
		endif;
	
		return true;
	endwhile;
	
	return true;

epilog

end;</source>
        <Parameter name="_isUpdate" type="Boolean"/>
        <Parameter name="_pxyGTE" type="Object" usage="input"/>
        <Parameter name="_valdationOnly" type="Boolean"/>
        <Parameter name="warningsToIgnore" type="IntegerArray"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="selectISOSource" id="bd788bc9-ae87-4b25-86b0-4b268351e67b">
        <updating/>
        <source>selectISOSource()updating, protected;
// ---------------------------------------------------------------------------
// Created:		February  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
////nds TFS 2867 17/01/17 PKT - Bulk Process
// ---------------------------------------------------------------------------


vars
	sourceForm	: CMUI_SelectISOSourceMulti;
	wleArray : CM_WLEArray;
	table : CM_DataTable;
	obj : CMIF_RoadOpObject;
begin

	// cnwrd1 changed to use the multi form, par 25012 15.7.2010
	if self.myCurrentWLE = null or 
	   (not self.myCurrentWLE.myRequest.isKindOf(CM_DeliveryRequest)) then
		return;
	endif;
	
	create wleArray transient;
	//+cnwml2 PAR25702
	foreach obj in self.myRoadOpController.allCMIFRoadOpObjects do
		if obj.isKindOf(CMIF_RoadOpPreGate) and obj.CMIF_RoadOpObject.allWLEs.includes(self.myCurrentWLE) then
			table := obj.CMIF_RoadOpPreGate.myDataTable;
			break;
		elseif obj.isKindOf(CMIF_RoadOpYard) and obj.CMIF_RoadOpObject.allWLEs.includes(self.myCurrentWLE) then
			table := obj.CMIF_RoadOpYard.myDataTable;
			break;
		endif;
	endforeach;
	
	
	self.getAllWLEsInTableSelected(wleArray, table,false );	//nds TFS 2867 17/01/17 PKT - Bulk Process
	//wleArray.add(self.myCurrentWLE);

	/*
	if wleArray.isEmpty then
		return;
	endif;
	*/
	
	sourceForm := app.loadForm(CMUI_SelectISOSourceMulti, CMUI_Assistant, false, false, true, self.myTerminal, self.myMasterMenuAction).CMUI_SelectISOSourceMulti;
	sourceForm.centreWindow;

	sourceForm.setMyTerminal(self.myTerminal);
	//sourceForm.myCurrentWLE := self.myCurrentWLE;
	wleArray.copy ( sourceForm.allWLEs);
	
	sourceForm.myDeliveryRequest := self.myCurrentWLE.myRequest.CM_DeliveryRequest;

	sourceForm.showModal;

epilog 
	delete wleArray;
end;
/*
vars
	sourceForm	: CMUI_SelectISOSource;
begin

	if self.myCurrentWLE = null or 
	   (not self.myCurrentWLE.myRequest.isKindOf(CM_DeliveryRequest)) then
		return;
	endif;
	
	sourceForm := app.loadForm(CMUI_SelectISOSource, CMUI_Assistant, false, false, true, self.myTerminal, self.myMasterMenuAction).CMUI_SelectISOSource;
	// Update the navigator
	sourceForm.centreWindow;
	sourceForm.setMyTerminal(self.myTerminal);
	sourceForm.myCurrentWLE := self.myCurrentWLE;
	sourceForm.myDeliveryRequest := self.myCurrentWLE.myRequest.CM_DeliveryRequest;

	sourceForm.showModal;


end;
*/</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="selectWLEforObject" id="b971c9bb-9619-4d3c-b2be-6d301d57a487">
        <updating/>
        <source>selectWLEforObject(_object :CM_Object input;_wleTable :CM_DataTable input) updating, protected;
//--------------------------------------------------


//--------------------------------------------------
vars
	job 			: CM_Job;
	selectObject 	: CM_Object;
	rowIdx 			: Integer;
begin
	
	if _object &lt;&gt; null then
		if _wleTable.findObjectInRow(_object, rowIdx) then
			_wleTable.selectRow(rowIdx, false);
			_wleTable.row := rowIdx;					
		endif;
	endif;				

end;</source>
        <access>protected</access>
        <Parameter name="_object" type="CM_Object" usage="input"/>
        <Parameter name="_wleTable" type="CM_DataTable" usage="input"/>
    </JadeMethod>
