							continue;
						endif;
					endif;
					
					if self.myOperator &lt;&gt; null then
						if not ti.myOperator = self.myOperator then
							continue;
						endif;
					endif;
					
					if self.myCargoType &lt;&gt; null then
						if not ti.myCargoType = self.myCargoType then
							continue;
						endif;
					endif;
					
					//return in difference between expected and actual in minutes
					timeDiff := self.compareTimes(ti);
					
					//compare from report parameter
					if not timeDiff &lt; self.arrivedEarlierThan then
						continue;
					elseif not timeDiff &gt; self.arrivedLaterThan then
						continue;
					endif;
					
				//if self.includesObject(ti, _passport, breakOut) then
					if not _collection.includes(ti) then
						_collection.add(ti);
					endif;
				endif;
			//	if breakOut then
			//		return;
			//	endif;
			endforeach;
		endforeach;
		*/
	endif;
epilog

end;</source>
        <Parameter name="_collection" type="Collection" usage="input"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="includesObject" id="d492c8b5-b042-4307-a7ca-e824cbd39a93">
        <updating/>
        <source>includesObject(_ti: CM_TrackedItem; _passport: CM_Passport; _breakOut: Boolean output): Boolean updating, protected;
//12 February 2010	cnwml2


vars
	timeDiff : Integer;
	stamp : TimeStamp;
begin
	self.numSearched := self.numSearched + 1;
	
	//stamp.setDate(_ti.expectedArrivalDate);
	//stamp.setTime(_ti.expectedArrivalTime);
	//29 Jul 2013	NDL	Par 31763
	stamp.setDate(_ti.getExpectedArrivalDate);
	stamp.setTime(_ti.getExpectedArrivalTime);
	
	if stamp = null then
		return false;
	endif;

	//return in difference between expected and actual in minutes
	timeDiff := self.compareTimes(_ti);

	//compare from report parameter
	if self.arrivedEarlierThan = null and self.arrivedLaterThan = null then
		return false;
	elseif self.arrivedEarlierThan = null and self.arrivedLaterThan &lt;&gt; null then
		if (not (timeDiff * -1) &gt; self.arrivedLaterThan) then
			return false;
		endif;
	elseif self.arrivedEarlierThan &lt;&gt; null and self.arrivedLaterThan = null then
		if timeDiff &lt; (self.arrivedEarlierThan) then
			return false;
		endif;
	elseif self.arrivedEarlierThan &lt;&gt; null and self.arrivedLaterThan &lt;&gt; null then
		if timeDiff &lt; 0 then
			if (not (timeDiff * -1) &gt; self.arrivedLaterThan) then
				return false;
			endif;
		else
			if timeDiff &lt; (self.arrivedEarlierThan) then
				return false;
			endif;
		/*if not timeDiff &lt; (self.arrivedEarlierThan) or 
		  (not (timeDiff * -1) &gt; self.arrivedLaterThan) then
			return false;*/
		endif;
	endif;
	
	self.numFound := self.numFound + 1;
	return true;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_passport" type="CM_Passport"/>
        <Parameter name="_breakOut" type="Boolean" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
