<Class name="DEV_ClassConstant" id="9d092906-30a8-4d65-a4c1-78ece57cb88d">
    <superclass name="DEV_Constant"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="dev"/>
    <PrimAttribute name="delimiter" id="cd280da2-4b40-4767-a42f-95f6a72f5595">
        <length>2</length>
        <embedded/>
        <type name="String"/>
        <access>readonly</access>
    </PrimAttribute>
    <PrimAttribute name="miscData" id="a30ce956-b1a4-4e84-8572-740ddbef5edb">
        <type name="String"/>
        <access>readonly</access>
    </PrimAttribute>
    <ExplicitInverseRef name="myClass" id="9d3fec19-fdb7-4325-b3c1-e7e45344b3ff">
        <kind>child</kind>
        <updateMode>manual</updateMode>
        <embedded/>
        <type name="DEV_Class"/>
        <access>readonly</access>
        <Inverse name="DEV_Class::allConstants"/>
        <Inverse name="DEV_Class::allConstantsOrd"/>
    </ExplicitInverseRef>
    <JadeMethod name="create" id="dea57cb6-c9c2-4885-94b0-07cb9de46c78">
        <updating/>
        <source>create(_name,
		_type,
		_value, 
		_documentationTextData,
		_miscData,
		_delimiter			: String;
		_reason 			: Integer;
		_class 				: DEV_Class) ::super(_name, _type, _value, _documentationTextData) updating;
/*

Purpose:			Constructor for DEV_ClassConstant class

Parameters:			_name:					String		The name of the constant
					_type:					String		The type of constant
					_value:					String		The value of the constant
					_documentationTextData:	String		The documentation text on the class
					_miscData:				String		The data we are not interested in but needs to be written out
					_delimiter				String		The delimiter for a String constant either ' or "
					_reason:				Integer		Reason for adding the ClassConstant to the report either 1 (Missing) or 2 (Different)
					_class:					CM_Class	The class object the attribute belongs to

Return Value:		

Date		Who		Reason
08 December 2021	navpw1	Initial creation TFS: 52202

*/

begin
	//Set Attributes
	self.miscData				:= _miscData;
	self.delimiter				:= _delimiter;
	self.reason 				:= _reason;
	
	//Set References
	self.myClass				:= _class;
	
end;</source>
        <Parameter name="_name" type="String"/>
        <Parameter name="_type" type="String"/>
        <Parameter name="_value" type="String"/>
        <Parameter name="_documentationTextData" type="String"/>
        <Parameter name="_miscData" type="String"/>
        <Parameter name="_delimiter" type="String"/>
        <Parameter name="_reason" type="Integer"/>
        <Parameter name="_class" type="DEV_Class"/>
    </JadeMethod>
    <JadeMethod name="getMyClass" id="97214b73-97e0-4d99-a5bb-36362d78910a">
        <source>getMyClass(_scm : Schema) : Class;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 November 2023	navpw1	Initial creation

*/

begin
	return _scm.getClass(self.myClass.name);
	
end;</source>
        <Parameter name="_scm" type="Schema"/>
        <ReturnType type="Class"/>
    </JadeMethod>
    <JadeMethod name="getMySchema" id="a825276e-1e56-4d31-ab5a-e12b8f880966">
        <source>getMySchema(): Schema;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 November 2023	navpw1	Initial creation

*/

begin
	return rootSchema.getSchema(self.myClass.mySchema.name);
	
end;</source>
        <ReturnType type="Schema"/>
    </JadeMethod>
</Class>
