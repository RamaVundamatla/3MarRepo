        <updating/>
        <source>moveTI(_setDownLocation : String; _tandemTIid : String; _dto : DTO_EnquiryGradingTasks input; _stateInfo : DTO_StateInfo input) : Boolean updating;
// -------------------------------------------
// Created 01 February 2006 by cnwdvb1
// -------------------------------------------
vars

	passport	: CM_Passport;

begin

	passport := app.myPassport;
	passport.warningsAcknowledged := _stateInfo.warningsAcknowledged;
	
	app.myTrxRT.trxMoveTI(_setDownLocation, _tandemTIid, self.myMediator, passport);
	if not passport.trxCompletedOK then
		_stateInfo.errorString :=  passport.getAllErrorsWarningsAsString();
		_stateInfo.guiState	:= self.Error;
		return false;
	endif;
	
	_dto.setFromTI(self.myMediator.myCurrentTi);
	
	self.setMediatorState(self.ActionedMove);
	_stateInfo.guiState	:= self.ActionedMove;
		
	return true;
epilog
	_stateInfo.hasWarningsOnly := ((not passport.hasErrors) and (passport.hasWarnings));
end;</source>
