    <JadeMethod name="doRefresh" id="a6e4a362-711d-4033-b689-8870b5e3505f">
        <updating/>
        <source>doRefresh()updating, protected;
//--------------------------------------------------------------
//Created: 07 January 2003 By: cnwgd1
//--------------------------------------------------------------
vars

begin
	inheritMethod();

	self.listsTreeViewLoadAll();

	if self.fldTreeView.topSheet = self.shtListSuppliers then		
