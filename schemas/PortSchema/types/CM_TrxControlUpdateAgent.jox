    <JadeMethod name="trxMachineSetdownMultiTask" id="6330c88f-23d3-4f46-a739-becd0761d57a">
        <updating/>
        <source>trxMachineSetdownMultiTask(_machine 	    : CM_Machine io;
						   _allMoveItems    : CMIF_Array;
						   _passport 		: CM_Passport input) updating;

/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 Aug 2021 navma1 ChangeRequest 51485: PRP - Multi-Roll Pickup Enhancement

*/
vars
	obj  		: CMIF_Object;
	task 		: CM_RTQueueTask;
	targetLoc	: String;
	invalidTask : Boolean;
begin
	on Exception do app.handleDeletedObject(exception, task, invalidTask);
	
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportSilentLockExHandler(exception, 3, app.myPassport); 

	app.setContinueCMExceptions(false);
	
	self.raiseExceptionIfNull(_machine, app.getErrorString(Machine));
	
	if _passport.hasErrors() then
		return;
	endif;
	
	beginTransaction;
	
	_passport.useTIDictDeferUpdate 		  := true;
	_passport.useTITransactionDeferUpdate := true;
	
	foreach obj in _allMoveItems discreteLock do
		
		task      := obj.CMIF_MultiMoveItem.myRTQTask;
		targetLoc := obj.CMIF_MultiMoveItem.targetLocation;
		
		if task &lt;&gt; null then
			task.edition();
			if invalidTask then
				invalidTask := false;
				continue;
			endif;
		
			app.myUtilityUA.utlMachineSetdownTask(_machine,task,null,targetLoc,null,false,_passport);
			if  app.myPassport.hasErrors then
				return;
			endif;
		endif;
	endforeach;
	
	_passport.doDeferredUpdates();

epilog
	self.finaliseActivityWithPassport(_passport);
end;
</source>
        <Parameter name="_machine" type="CM_Machine" usage="io"/>
        <Parameter name="_allMoveItems" type="CMIF_Array"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxMachineSetdownTask" id="3886f005-05a6-4989-aad8-526883598f8b">
        <updating/>
        <source>trxMachineSetdownTask(	_machine 			   : CM_Machine input;
						_rtTask,
						_rtTwinTask			   : CM_RTQueueTask input;
						_setDownLocation,
						_rtTwinSetdownLocation : String; 
						_overrideToInterchange : Boolean;
						_isSwap 			   : Boolean;
						_weight 			   : Integer;
						_isCertified 		   : Boolean;
						_passport 			   : CM_Passport input) updating;
/*

Date		Who		Reason
09 May 2017	cnwer1	Initial creation TFS 995 moved from MobileServerSchema::CM_TrxControlRTAgent::trxSetdownTaskTwin
22 Jun 2022 jlika1	53830	PNL - Vehicle App - Swap Button Broken when Tandem Lifting to two trucks
27 Jul 2022 jlier1	53830  - there was a problem if setdown one task still want to swap with the other tandem task
16 Aug 2022 jlier1  54410	
25 Oct 2024 navma1  MTN-33231 MTN - Enable Deferred Updates For Train and Wagon Events 
29/10/2025	navkc1 JIRA 36186 PNL | Vehicle App Swap behaviour with Release Requests - DB Changes / Jade / Form
*/

vars
	oriTask,
	oriTwinTask,
	twinTask,
	task  	   : CM_RTQueueTask;
	rtConfig	: CM_RTVehicleConfig; //29/10/2025	navkc1 JIRA 36186
	setDownLoc,
	twinSetDownLoc : String; //29/10/2025	navkc1 JIRA 36186
	rtqEntry,
	twinRtqEntry	: CM_RTQueueEntry; //29/10/2025	navkc1 JIRA 36186
	job,
	twinJob			: CM_Job;			//29/10/2025	navkc1 JIRA 36186
begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportSilentLockExHandler(exception, 3, app.myPassport); //epr par 14718

	app.setContinueCMExceptions(false);

	self.raiseExceptionIfNull(_machine, app.getErrorString(Machine));
	
	if _passport.hasErrors() then
		return;
	endif;
	
	if _rtTask = null and _rtTwinTask = null then
		app.raiseCMException3(UNEXPECTED_PROGRAM_ERROR, class.name, method.name, 'RT Queue Tasks are null.', null, null);
	endif;
	
	if _passport.hasErrors() then
		return;
	endif;
	
	beginTransaction;
	
	// This is the task we received in the request
	oriTask := _rtTask; //29/10/2025	navkc1 JIRA 36186
	oriTwinTask := _rtTwinTask; //29/10/2025	navkc1 JIRA 36186
	
	_passport.useTIDictDeferUpdate 		  := true;
	_passport.useTITransactionDeferUpdate := true;
	_passport.useEventDeferUpdate		  := true;		//25.10.2024 navma1 #MTN-33231
	
	setDownLoc := _setDownLocation; //29/10/2025	navkc1 JIRA 36186
	twinSetDownLoc := _rtTwinSetdownLocation; //29/10/2025	navkc1 JIRA 36186
	
	//jlier1 TFS 54410 - do the weighing in the trx
	if _rtTwinTask = null and oriTask.ti &lt;&gt; null and _weight &lt;&gt; 0 then
		app.myUtilityUA.utlUpdateMachineWeighContainer(_machine,oriTask.ti,_weight,_isCertified,_passport);
		if _passport.hasErrors then		
			return;
		endif;
	endif;
	
	if _isSwap then
		twinTask:=oriTwinTask;
		if twinTask = null and _machine.allCurrentWorkingQueueTasks.size = 2 then
				foreach task in _machine.allCurrentWorkingQueueTasks discreteLock do
					if task = oriTask then
						continue;
					endif;
					twinTask:=task;
				endforeach;
		endif;
		if twinTask &lt;&gt; null then
			rtqEntry		:= oriTask.myEntry; //29/10/2025	navkc1 JIRA 36186
			twinRtqEntry 	:= twinTask.myEntry; //29/10/2025	navkc1 JIRA 36186
			
			if rtqEntry &lt;&gt; null then 
				job := rtqEntry.myJob;
			endif;
			
			if twinRtqEntry &lt;&gt; null then
				twinJob := twinRtqEntry.myJob;
			endif;
			
			/*if _rtTask.myEntry.myJob.isRelease
				and _rtTask.myEntry.myJob.isRoadJob		
				and twinTask.myEntry.myJob.isRelease
				and twinTask.myEntry.myJob.isRoadJob  then */       
			
			//29/10/2025	navkc1 JIRA 36186 - Set to local var
			if job.isRelease()
				and job.isRoadJob()
				and twinJob.isRelease()
				and twinJob.isRoadJob() then
				
				rtConfig := _machine.myRTVehicleConfig; //29/10/2025	navkc1 JIRA 36186
				
				//29/10/2025	navkc1 JIRA 36186 - If the config says swap cargo not job, then call the new TRX
				if rtConfig &lt;&gt; null and rtConfig.doSwapChangeCargo then
					app.myUtilityUA.utlSwapWLEJobCargo(rtqEntry.myWorkListEntry, twinRtqEntry.myWorkListEntry, setDownLoc, twinSetDownLoc, _passport);
					
					//29/10/2025	navkc1 JIRA 36186 User chose to set down 1 by 1, we need to swap the task we are doing so it reflect correctly on the UI
					// E.g. User selected to setdown Cargo 1(Task1), 
					// We did a swap, so Task1 now has Cargo 2.
					// Do a swap to the original task so we are still setting down Cargo 1
					// This makes sure things are reflected correctly on the UI/Vehicle App
					if oriTwinTask = null then
						oriTask := twinTask;
						setDownLoc := twinSetDownLoc;
					endif;
					
				else
					app.myUtilityUA.utlSwapTruckTasks(rtqEntry.myWorkListEntry,twinRtqEntry.myWorkListEntry,_passport);
				endif;
				
			else               
				
				app.myUtilityUA.utlSwapTandemTasksTargetLoc(oriTask, twinTask);
			endif;
		endif;
		if _passport.hasErrors() then
			return;
		endif;
	endif;
	
	//app.myUtilityUA.utlMachineSetdownTask(_machine,_rtTask,_rtTwinTask,_setDownLocation,_rtTwinSetdownLocation,_overrideToInterchange,_passport);
	app.myUtilityUA.utlMachineSetdownTask(_machine,oriTask,oriTwinTask,setDownLoc,twinSetDownLoc,_overrideToInterchange,_passport); //29/10/2025	navkc1 JIRA 36186
	
epilog
	self.finaliseActivityWithPassport(_passport);
end;</source>
        <Parameter name="_machine" type="CM_Machine" usage="input"/>
        <Parameter name="_rtTask" type="CM_RTQueueTask" usage="input"/>
        <Parameter name="_rtTwinTask" type="CM_RTQueueTask" usage="input"/>
        <Parameter name="_setDownLocation" type="String"/>
        <Parameter name="_rtTwinSetdownLocation" type="String"/>
        <Parameter name="_overrideToInterchange" type="Boolean"/>
        <Parameter name="_isSwap" type="Boolean"/>
        <Parameter name="_weight" type="Integer"/>
        <Parameter name="_isCertified" type="Boolean"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxMachineUpdateFaultResponse" id="f7f6d2cf-4ea6-4e3d-8a06-81cc2a4f8174">
        <updating/>
        <source>trxMachineUpdateFaultResponse(_machine : CM_Machine input;
							   _index : Integer;
							   _response : String;
							   _passport : CM_Passport input) updating;
/*

Date		Who		Reason
22 May 2017	cnwer1	Initial creation TFS 995 

*/

vars

begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportSilentLockExHandler(exception, 3, app.myPassport); //epr par 14718

	app.setContinueCMExceptions(false);

	if _machine = null then
		app.raiseCMException3(UNEXPECTED_PROGRAM_ERROR, class.name, method.name, 'Machine is null.', null, null);
	endif;
	
	beginTransaction;

	app.myUtilityUA.utlMachineUpdateFaultResponse(_machine,
												   _index,
												   _response,
												   _passport);
epilog
	self.finaliseActivityWithPassport(_passport);
end;</source>
        <Parameter name="_machine" type="CM_Machine" usage="input"/>
        <Parameter name="_index" type="Integer"/>
        <Parameter name="_response" type="String"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxMergeBreakBulk" id="53b92b27-70f4-4e21-a4ac-0403749cf695">
        <updating/>
        <source>trxMergeBreakBulk( _targetTi : CM_Cargo io; _allItemsToBeMerged : CM_TISet; _passport : CM_Passport input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 May 2013	cnwndl1	Initial creation	CCMS 2274 Break Bulk

*/

vars

	ti : CM_TrackedItem;

begin

	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);


	app.setContinueCMExceptions(false);
	
	app.myValUA.valBreakBulkMergeManual(	_targetTi,	//_targetTi : CM_Cargo io;
											_allItemsToBeMerged,	//_allItemsToBeMerged : CM_TISet;
											_passport	//_passport : CM_Passport input
											);
											
	if _passport.hasErrors then
		return;
	endif;

	beginTransaction;
	
	foreach ti in _allItemsToBeMerged do

		if _passport.hasErrors then
			break;
		endif;
		app.writeLog("Merging " &amp; ti.id &amp; " into " &amp; _targetTi.id, LogDEBUG);
		app.myUtilityUA.utlMergeBreakBulk( _targetTi, ti.CM_Cargo, _passport );
	
	endforeach;

epilog

	self.finaliseActivityWithPassport(_passport);
	
end;</source>
        <Parameter name="_targetTi" type="CM_Cargo" usage="io"/>
        <Parameter name="_allItemsToBeMerged" type="CM_TISet"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxMoveBOLOutLogWithSplit" id="58918e3d-5228-4562-9b3f-620dbd048814">
        <updating/>
        <source>trxMoveBOLOutLogWithSplit(_bol : CM_BOLOut; _passport : CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:     16 July 2001 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	moveController 		: CMIF_MoveController;
	errSet,
	tiSet	: CM_TISet;
	setNo,
	totStart,
	startTime,
	endTime	: Integer;
	ext		: CM_BOLExtLogOut;
	logLoadError	: CM_LogLoadError;
	logLoadErrorSet	: CM_LogLoadErrorSet;
	
begin

	self.initialiseActivityWithPassport(_passport, method);
	
	// Multi Transaction trx.  This is the type of transaction where we
	// commitTransaction/beginTransaction multiple times for efficiency
	// and concurrency reasons.  We want to dispatch event notifications
	// after the final commit/abort, as we delay all notifications until
	// then.  They will be sent as immediate notifications.
	app.myEventManager.setMultiTransactionTrx;

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);
	
	app.setContinueCMExceptions(false);
	
	ext := _bol.myExtension.CM_BOLExtLogOut;

	create moveController transient;	
	create tiSet transient;
	create logLoadErrorSet transient;
	
	beginTransaction;
	
	// delete all existing log errors that are associated with an existing TI
	foreach logLoadError in ext.allLogLoadErrors do
		exclusiveLock(logLoadError);
		if logLoadError.myLog &lt;&gt; null then
			logLoadErrorSet.add(logLoadError);
		endif;
	endforeach;
	
	if (not logLoadErrorSet.isEmpty) then
		logLoadErrorSet.purge;
	endif;
	
	ext.setLogsToLoadOut(tiSet, _passport);

	if tiSet.isEmpty then
		//nothing to move so lets get out of here
		if (not ext.isInError) then
			ext.setIsFullyLoaded(true);
		endif;
		return;
	endif;
	// Initialise move controller parameters.
	moveController.isSystemMove 	:= true;
	moveController.isForcedMove 	:= true;
	moveController.setMoveMode(REAL_MODE);
	moveController.setJobForMove(_bol.myYardJob);		
	moveController.setMyToPrimaryLocation(_bol.myPlannedLocation);
	if ext.loadDateTime.isValid then
		moveController.setEffectiveTimeStampOverride(ext.loadDateTime);
	endif;	
	create errSet transient;


	
	commitTransaction;		// release locks


	
	self.doMoveTrackedItemsWithSplit(tiSet, errSet, moveController, _passport);

	if _passport.hasErrors or errSet.size &gt; 0 then
		return;
	endif;

	// if doMoveTrackedItemsWithSplit has returned with no errors
	// we will be in trans state at this point
	//beginTransaction;
	ext.setPartiallyLoaded();
	if (not ext.isInError) then
		ext.setIsFullyLoaded(true);
	endif;
	
epilog
	self.finaliseActivityWithPassport(_passport);

	if moveController &lt;&gt; null then
		// need to do this once out of transaction state
		moveController.doSessionUnlockForAll();	// belts and braces here
	endif;
	
	delete moveController;
	delete tiSet;
	delete errSet;
	delete logLoadErrorSet;
	
end;</source>
        <Parameter name="_bol" type="CM_BOLOut"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxMoveCargoCheckItem" id="85183572-1397-4be3-b3ae-71ad8f290b79">
        <updating/>
        <source>trxMoveCargoCheckItem(_cargoCheckItem : CM_CargoCheckItem; _up : Boolean; _passport : CM_Passport input) updating;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 January 2010	cnwdap1	Initial creation
*/
vars
	cargoCheck : CM_CargoCheck;
	
begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);
	
	app.setContinueCMExceptions(false);

	cargoCheck := _cargoCheckItem.myCargoCheck;
	if cargoCheck.allCargoCheckItems.size = 1 then
		return;
	endif;
	
	beginTransaction;
	
	cargoCheck.allCargoCheckItems.moveElement(_cargoCheckItem, _up);

	/*	cargoCheck := _cargoCheckItems.first.myCargoCheck;
	if cargoCheck.allCargoCheckItems.size = 1 then
		return;
	endif;
	
	beginTransaction;
	
	cargoCheck.replaceCargoCheckItemSet(_cargoCheckItems);	*/

epilog
	self.finaliseActivityWithPassport(_passport);
end;</source>
        <Parameter name="_cargoCheckItem" type="CM_CargoCheckItem"/>
        <Parameter name="_up" type="Boolean"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
