    <JadeMethod name="displayAlert" id="e497ed30-439d-4bb3-b158-d54d8fb8c1ec">
        <updating/>
        <source>displayAlert(_alert : CM_SystemAlert; _row : Integer):Boolean protected, updating;
//09 JAN 2015 cnwma1 PAR #33173 14049 in CMUI_SystemAlerts::displayAlert
vars
	tmpSeverity,
	idx,
	colour 			: Integer;
	isSystem		: Boolean;
	entRow			: EntTableRow;
	str,
	terminalCol: String;
	exOccurred : Boolean;
begin
	
	on Exception do self.tableRowLimitException(exception, self.tblAlerts, exOccurred); // 09/01/2014 cnwma1 PAR #33173
	
	foreach entRow in self.tblAlerts.allTblDataEntRows do
		str := str &amp; _alert.getDisplayStringForAttribute(entRow.name, false) &amp; Tab; 
	endforeach;
	
	if _row = 0 then
		idx := self.tblAlerts.addItemObject(_alert, str);
		
		if exOccurred then	// 09/01/2014 cnwma1 PAR #33173
			return false;
		endif;
	else
		idx := _row;
		self.tblAlerts.addItemAt(str, idx);
		
		
		if exOccurred then	// 09/01/2014 cnwma1 PAR #33173
			return false;
		endif;
		self.tblAlerts.accessRow(idx).itemObject := _alert;
	endif;

		terminalCol:=ETRow_Terminal;
		terminalCol.firstCharToUpper;
		if self.tblAlerts.getCellValueByName(terminalCol,idx) = "System"  then
			colour := self.clrOne.backColor;
		else
			colour := self.clrTwo.backColor;
		endif;
		self.tblAlerts.accessRow(idx).backColor := colour;
		
		tmpSeverity := _alert.severity;
		
		if tmpSeverity = SEVERE_WARNING then
			self.tblAlerts.accessCell(idx,1).picture := self.btnWarnings.picture;//self.picWarning.picture;
		elseif tmpSeverity = SEVERE_DISASTER then
			self.tblAlerts.accessCell(idx,1).picture := self.btnDisasters.picture;//self.picDisaster.picture;
		elseif tmpSeverity = SEVERE_INFO then
			self.tblAlerts.accessCell(idx,1).picture := self.btnInfo.picture;//self.picInfo.picture;
		elseif tmpSeverity = SEVERE_ERROR then
			self.tblAlerts.accessCell(idx,1).picture :=  self.btnErrors.picture;//self.picError.picture;
		elseif tmpSeverity = SEVERE_REEFER or   
			   tmpSeverity = SEVERE_REEFER_ALERT or  
			   tmpSeverity = SEVERE_REEFER_MAX then
			self.tblAlerts.accessCell(idx,1).picture := self.picReefer.picture;
		endif;
		return true; 		// 09/01/2014 cnwma1 PAR #33173
end;</source>
        <access>protected</access>
        <Parameter name="_alert" type="CM_SystemAlert"/>
        <Parameter name="_row" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="displayAlerts" id="963edadc-8fcf-496e-bd53-448d61c69867">
        <updating/>
        <source>displayAlerts() updating;
// ---------------------------------------------------------------------------
// Created:		February  2002 By Andrew Bishop cnwab1
//
// Purpose:		
// ---------------------------------------------------------------------------
vars
	num	: Integer;
	dateStr,
	str	: String;

begin

	//14 May 2012	NDL	Par 29556
	self.btnShowSearcher.enabled := self.displayType &lt;&gt; DISPLAY_SPECIFIC;

	if self.queryDateFrom.isValid and
	   self.queryDateTo.isValid then
		//dateStr := self.queryDateFrom.shortFormatJMT &amp; '-' &amp; self.queryDateTo.shortFormatJMT;
		dateStr := self.queryDateFrom.shortFormatJMT &amp; ' ' &amp; self.queryTimeFrom.shortFormatJMT &amp; ' - ' &amp; self.queryDateTo.shortFormatJMT &amp; ' ' &amp; self.queryTimeTo.shortFormatJMT;	// 26/09/2014 cnwar2 #33950
	endif;

	self.tblAlerts.clearAllData;
	if self.displayType = DISPLAY_SPECIFIC then
		num := self.displayCollection(self.allCombinedAlerts);
		self.setCaption(app.getErrorString2(Specific_Alerts, num.String, dateStr));

	elseif self.displayType = DISPLAY_SYSTEM then
		num := self.displayCollection(app.myRoot.allSystemAlerts);	
		self.setCaption(app.getErrorString2(Global_Alerts, num.String, dateStr));

	elseif self.displayType = DISPLAY_TERMINAL then
		// Using self.myTerminal because this method can be note driven and
		// therefore app.getMyTerminal could return wrong terminal;
		num := self.displayCollection(self.myTerminal.allSystemAlertsByDateTime);		
		self.setCaption(app.getErrorString2(Terminal_Alerts, num.String, dateStr));

	elseif self.displayType = DISPLAY_BOTH then
		/*
		Date		      Who		Reason
		31 July 2008	cnwdz2	    Par16737 - Copy the whole dict to allCombinedAlerts reduces performance significantly.
		*/
		//self.allCombinedAlerts.clear();
		//self.myTerminal.allSystemAlertsByDateTime.copy(self.allCombinedAlerts);
		//app.myRoot.allSystemAlerts.copy(self.allCombinedAlerts);
		self.buildCombinedAlerts();
		num := self.displayCollection(self.allCombinedAlerts);
		self.setCaption(app.getErrorString2(Terminal_And_Global_Alerts, num.String, dateStr));
	else
		self.tblAlerts.rows := self.tblAlerts.fixedRows;
		str := app.getErrorString(Please_Select_Alert_Type);
		self.setCaption(str);
		self.tblAlerts.addItem(str);
		self.tblAlerts.accessCell(self.tblAlerts.fixedRows + 1,1).mergeCells := Table.MergeCells_Merge;
		self.tblAlerts.accessCell(self.tblAlerts.fixedRows + 1,1).alignment := Table.Alignment_Center_Middle;
		
		self.buttonsOffOn(false);
		return;
	endif;
	self.buttonsOffOn(true);
	
	self.setNavigatorHeading(self.caption);
end;</source>
    </JadeMethod>
    <JadeMethod name="displayCollection" id="2e7feed9-f6ca-4074-aa91-1c205a3bd516">
        <updating/>
        <source>displayCollection(_coll : CM_SystemAlertByDateTime) : Integer updating;

// 08/12/2010	cnwcs5	CCMS MES 1112/Par 24464 - filter by alert type
// 09 JAN 2015 cnwma1 PAR #33173 14049 in CMUI_SystemAlerts::displayAlert
// 11 Mar 2015	cnwkpd1	PAR #35843 - Make progress bar updates time-based, not object counts


vars
	tmpCurrentButton	: Integer;
	alert 				: CM_SystemAlert;
	iter				: Iterator;
	cmifMonitor			: CMIF_Monitor;
	passport			: CM_Passport;
	partsInJob,
	partsDone,
	num					: Integer;
	includeNullAlert,							// 08/12/2010	cnwcs5	CCMS MES 1112/Par 24464
	invalidAlert		: Boolean;
	alertType			: CM_SystemAlertType;	// 08/12/2010	cnwcs5	CCMS MES 1112/Par 24464
	selectedTypes		: ObjectArray;			// 08/12/2010	cnwcs5	CCMS MES 1112/Par 24464
	endTS, startTS		: TimeStamp;
	endTime				: Time;
	lastUpdate			: Decimal[20];
	
begin
	app.mousePointer 	:= MP_HOURGLASS;
	passport 			:= app.myPassport;
	
	self.setQueryValues();
	
	cmifMonitor := passport.myCMIFMonitor;
	if cmifMonitor &lt;&gt; null then
		delete cmifMonitor;
	endif;
	create cmifMonitor transient;
	cmifMonitor.myParent := self;
	passport.setMyCMIFMonitor(cmifMonitor);
	
	self.modalDialogReturnValue := self.ModalDialogReturn_Null;	
	
	self.modalDialogShow(null, app.getErrorString (Cancel) , null, null, 'Loading Alerts',  'Please Wait....');
	
	self.pbProgressBar.visible 	:= true;
	partsInJob 					:= _coll.size;

	selectedTypes 		:= self.lstAlertTypes.allSelectedObjects; // 	08/12/2010	cnwcs5	CCMS MES 1112/Par 24464 
	tmpCurrentButton 	:= self.currentButton;
	iter 				:= _coll.createIterator();	
	
	/*if self.queryDateTo.isValid then
		_coll.startKeyLss((self.queryDateTo + 1).asTimeStamp(), iter);
	endif;*/
	// 26/09/2014 cnwar2 #33950
	if self.queryDateTo.isValid then
		endTS.setDate( self.queryDateTo );
		endTime.setTime( self.queryTimeTo.hour, self.queryTimeTo.minute, 59, 999 );
		endTS.setTime( endTime );
		_coll.startKeyLss(endTS, iter);
	endif;
	
	/*
	Date		      Who		Reason
	31 July 2008	cnwdz2	    Par16737 - Use app.handleDeletedObject() to handle invalid object reference instead of isValidObject().
	*/
	on Exception do app.handleDeletedObject(exception, alert, invalidAlert);
	
	// 26/09/2014 cnwar2 #33950
	if self.queryDateFrom.isValid then
		startTS := self.queryDateFrom.asTimeStamp();
		startTS.setTime( self.queryTimeFrom );
	else
		startTS := null;
	endif;
	
	while iter.back(alert) do
		if (app.relativeMachineTime() - lastUpdate) &gt; CMIF_Monitor.Monitor_TimeBetweenUpdates then
			if (not cmifMonitor.updateProgress(cmifMonitor.message, partsInJob, partsDone)) then
				break;
			endif;
			lastUpdate := app.relativeMachineTime();
		endif;
		
		/*if self.queryDateFrom.isValid and alert.dateTime.date &lt; self.queryDateFrom then
			break;
		endif;*/
		// 26/09/2014 cnwar2 #33950
		if alert.dateTime &lt; startTS then
			break;
		endif;
		
		if self.displayType &lt;&gt; DISPLAY_SPECIFIC then	// 14 May 2012	NDL	Par 29556 - don't skip them when we have pre-selected a specififc set...
			// 08/12/2010	cnwcs5	CCMS MES 1112/Par 24464 - start
			alertType := alert.mySystemAlertType;
			
			if alertType = null then
				if not self.queryIncludeNullType then
					continue;
				endif;
			elseif not selectedTypes.includes (alertType) then
				continue;
			endif;
			// 08/12/2010	cnwcs5	CCMS MES 1112/Par 24464 - end
		endif;
		partsDone 	:= partsDone + 1;
		
		if (not self.includeAlert(alert, tmpCurrentButton)) then
			continue;
		endif;
		
		num 		:= num + 1;
		
		if not self.displayAlert(alert, 0) then
			break;	//09/01/2015  cnwma1 PAR #33173
		endif;
	endwhile;
	
	return num;

epilog
	delete iter;
	delete cmifMonitor;

	passport.setMyCMIFMonitor(null);
	
	self.frmModalDialog.visible := false;	
	app.mousePointer 			:= MP_DEFAULT;
end;</source>
        <Parameter name="_coll" type="CM_SystemAlertByDateTime"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="doBaseFormCancel" id="ee772048-dc52-4214-ba75-f4d89d9f95ad">
