<CollClass name="CM_OperatorByCodeDict" id="4e6ee340-5556-49f9-a9e4-10de88aef231">
    <memberType name="CM_Operator"/>
    <superclass name="CM_MemberKeyDictionary"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="terminal"/>
    <MemberKey>
        <property name="CM_Operator::code"/>
    </MemberKey>
    <JadeMethod name="getDisplayCodes" id="f452f8a9-e193-4923-8df9-a817843da1cd">
        <source>getDisplayCodes(_short : Boolean) : String;
// ---------------------------------------------------------------------------
// Created:		13 November 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
/*

Date				Who				Reason
19 May 2010			cnwkpd1			PAR #20728 - remove isValidObject calls for performance
29 July 2022 		navvt20 		Bug 54199: EUP - Tables with Operator/Stevedore not adhering to the configuration
*/

vars
	aCT : CM_Operator;
	line,oprStr : String; // 29.07.2022 navvt20 TFS 54199
	invalid 		: Boolean;
	
begin
	on Exception do app.handleDeletedObject(exception, aCT, invalid);	
	foreach aCT in self discreteLock do
//		if not global.isValidObject(aCT) then		
//			continue;							
//		endif;										
		
		// START 29.07.2022 navvt20 TFS 54199
		if app.myRoot.getConfig(ComboByNameOperator).Boolean then	
			oprStr :=  aCT.description;								
		else
			oprStr := aCT.code;
		endif;
		// END 29.07.2022 navvt20 TFS 54199
		
		if line = null then
			//line := aCT.code; // 29.07.2022 navvt20 TFS 54199
			line := oprStr;  	// 29.07.2022 navvt20 TFS 54199
		else
			//line := aCT.code;				// 29.07.2022 navvt20 TFS 54199	
			line := line &amp; ", " &amp; oprStr;   // 29.07.2022 navvt20 TFS 54199
		endif;
	endforeach;
	
	return line;
end;</source>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
</CollClass>
