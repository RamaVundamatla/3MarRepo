    <JadeMethod name="dataDumpDBFixup" id="37c4ebce-78d6-4d98-b07c-33b1366c61e9">
        <source>dataDumpDBFixup();

vars
	trans:CM_TITransaction;
	ti:CM_TrackedItem;
	objectArray:ObjectArray;
	object:Object;
	count1,count2:Integer;
begin
	app.initialize;
	app.isConverting := true;
	create objectArray transient;
	
	CM_TrackedItem.allInstances(objectArray,0,true);
	app.writeStatement( "Have "&amp;objectArray.size.String&amp;" trackedItems to process.");
	beginTransaction;
	foreach object in objectArray do
		ti := object.CM_TrackedItem;
		ti.updateObjectEdition(ti);
//		ti.fixupTITransactions;
		count1 := count1 + 1;
		if count1 &gt; 10000 then
			count2 := count2 + count1;
			count1 := 0;
			commitTransaction;
			app.writeStatement( "Done "&amp;count2.String&amp;" trackedItems."); 
			beginTransaction;
		endif;
	endforeach;
	commitTransaction;
	app.writeStatement( "Finished.");
end;</source>
    </JadeMethod>
