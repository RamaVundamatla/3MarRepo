    <JadeMethod name="delete" id="aae110fe-852a-4341-b710-bc4e4938b921">
        <updating/>
        <source>delete() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 December 2014	cnwmc5	Initial creation

*/

vars

begin
	if self.allLocationRestrictions &lt;&gt; null and not self.allLocationRestrictions.isEmpty() then
		self.allLocationRestrictions.purge();
	endif;
	
	if self.allLogLengths &lt;&gt; null and not self.allLogLengths.isEmpty() then
		self.allLogLengths.purge();
	endif;
	
	if self.allLogTreatments &lt;&gt; null and not self.allLogTreatments.isEmpty() then
		self.allLogTreatments.purge();
	endif;
	
	if self.allLogTypes &lt;&gt; null and not self.allLogTypes.isEmpty() then
		self.allLogTypes.purge();
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setProxyFromObject" id="8cf476d2-b7b4-45c0-bd4c-76b79ff29aaa">
        <updating/>
        <source>setProxyFromObject(_object: CM_LogGrade) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 December 2014	cnwmc5	Initial creation

*/

vars
	wsLength			: WS_LogLength;
	wsTreatment			: WS_LogTreatment;
	wsType				: WS_LogType;
	
	locationRestriction : CM_Restriction;
	length				: CM_LogLength;
	treatment			: CM_LogTreatment;
	type				: CM_LogType;
	code				: CM_Code;
	
begin
	inheritMethod(_object);
	
	foreach locationRestriction in _object.allLocationRestrictions do
		self.allLocationRestrictions.add(locationRestriction.getOidString());
	endforeach;
	
	foreach code in _object.allLogLengths do
		if not code.isKindOf(CM_LogLength) then
			continue;
		endif;
		
		length := code.CM_LogLength;
		
		create wsLength transient;
		wsLength.setProxyFromObject(length);
		self.allLogLengths.add(wsLength);
	endforeach;
	
	foreach code in _object.allLogTreatments do
		if not code.isKindOf(CM_LogTreatment) then
			continue;
		endif;
		
		treatment := code.CM_LogTreatment;
		
		create wsTreatment transient;
		wsTreatment.setProxyFromObject(treatment);
		self.allLogTreatments.add(wsTreatment);
	endforeach;
	
	foreach code in _object.allLogTypes do
		if not code.isKindOf(CM_LogType) then
			continue;
		endif;
		
		type := code.CM_LogType;
		
		create wsType transient;
		wsType.setProxyFromObject(type);
		self.allLogTypes.add(wsType);
	endforeach;
	
	self.maxMeanSED := _object.maxMeanSED;
	self.maxSED		:= _object.maxSED;
	self.minMeanSED	:= _object.minMeanSED;
	self.minSED		:= _object.minSED;
	
epilog

end;</source>
        <Parameter name="_object" type="CM_LogGrade"/>
    </JadeMethod>
</Class>
