    <JadeMethod name="refactorRateEntries" id="bfbe5060-6e97-44ba-a0f7-9930708ed34b">
        <source>refactorRateEntries();
// ---------------------------------------------------------------------------
// Created:		28 November 2005  By Andrew Bishop cnwab1
//
// Purpose:		if the user creates a service with a calc type that has only 1 rate entry, 
//				but then updates it so the calc type expects more than 1 then add in 
//				some extra zero rate etries.
//
// ---------------------------------------------------------------------------

vars
	aCT : CM_CalculationType;
	aRate : CM_Rate;
	aRateEntry : CM_RateEntry;
	arraySize, st, en, idx : Integer;
begin
	aCT := self.myCalculationType;
	
	if aCT = null then
		return;
	endif;
	
	if aCT.calculationType = INV_CALC_TYPE_BUSINESS_HRS_QTY then
		foreach aRate in self.debtorNodeRates do
			foreach aRateEntry in aRate.rateEntries do
				arraySize := aRateEntry.allCostPerUnits.size;
				en := 2;
				st := arraySize + 1;
				foreach idx in st to en do
					aRateEntry.allCostPerUnits.add(0);
				endforeach;
			endforeach;
		endforeach;
	elseif aCT.calculationType = INV_CALC_TYPE_BUSHRSVESELVALUE // PAR 30681
	or aCT.calculationType = INV_CALC_TYPE_BUSHRSCARGOVALUE then
		foreach aRate in self.debtorNodeRates do
			foreach aRateEntry in aRate.rateEntries do
				arraySize := aRateEntry.allCostPerUnits.size;
				en := 3;
				st := arraySize + 1;
				foreach idx in st to en do
					aRateEntry.allCostPerUnits.add(0);
				endforeach;
			endforeach;
		endforeach;
	elseif aCT.calculationType = INV_CALC_TYPE_VESSEL_TON_RANGE then
		arraySize := aCT.integerRange1.size;
		foreach aRate in self.debtorNodeRates do
			foreach aRateEntry in aRate.rateEntries do
				arraySize := aCT.integerRange1.size;
				en := arraySize;
				st := aRateEntry.allCostPerUnits.size + 1;
				foreach idx in st to en do
					aRateEntry.allCostPerUnits.add(0);
				endforeach;
			endforeach;
		endforeach;
	endif;

end;</source>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="5be16668-ee5a-420e-a1c7-aede6ea96ef1">
        <updating/>
        <source>setForCreate(_pxyService: SelfType) updating;
// ---------------------------------------------------------------------------
// Created:		August 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
// 29/3/22  jlier1	TFS 53286
// 23/8/22	navkc1 	ChangeRequest #54569 - Add Service Types
vars
	aCT : CM_CalculationType;	
	rdg : CM_RootDebtorGroup;
	theBank : CM_Bank;
begin
	theBank := self.bank;
	if theBank = null then
		theBank := _pxyService.bank;
	endif;
	rdg := theBank.getRootDebtorGroup();

	inheritMethod(_pxyService);
	self.defaultRateTable := _pxyService.defaultRateTable;
	rdg.addDefaultRateForService(self, app.myRoot.myRootCompany);

	aCT := _pxyService.myCalculationType;
	self.setMyCalculationType(aCT);
	
	self.externalReference1:=_pxyService.externalReference1;
	self.externalReference2:=_pxyService.externalReference2;
	
	// 23/08/22	navkc1	#54569 --&gt;
	self.allServiceTypes.clear();
	if _pxyService.allServiceTypes.isNotEmpty() then
		_pxyService.allServiceTypes.copy(self.allServiceTypes);
	endif;
	// 23/08/22	navkc1	#54569 &lt;--
end;</source>
        <Parameter name="_pxyService" type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="14eeed7f-d001-4b08-a899-4725020e09df">
        <updating/>
        <source>setForUpdate(_pxyService: SelfType) updating;
// ---------------------------------------------------------------------------
// Created:		August 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
// 29/3/22  jlier1	TFS 53286
// 23/8/22	navkc1 	ChangeRequest #54569 - Add Service Types
vars
	aCT : CM_CalculationType;
	aRate : CM_Rate;
	aRateEntry : CM_RateEntry;
begin
	inheritMethod(_pxyService);
	self.defaultRateTable := _pxyService.defaultRateTable;
//	self.myCalculationType := _pxyService.myCalculationType;
	aCT := _pxyService.myCalculationType;
	self.setMyCalculationType(aCT);
	
	self.refactorRateEntries();
	self.externalReference1:=_pxyService.externalReference1;
	self.externalReference2:=_pxyService.externalReference2;
	
	// 23/08/22	navkc1	#54569 --&gt;
	self.allServiceTypes.clear();
	
	if _pxyService.allServiceTypes.isNotEmpty() then
		_pxyService.allServiceTypes.copy(self.allServiceTypes);
	endif;
	// 23/08/22	navkc1	#54569 &lt;--
end;</source>
        <Parameter name="_pxyService" type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setMyCalculationType" id="3888b5eb-6b62-4797-bacb-1d19c6a5c737">
        <updating/>
        <source>setMyCalculationType(_ct : CM_CalculationType input) updating;
// ---------------------------------------------------------------------------
