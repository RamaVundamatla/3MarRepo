    <JadeMethod name="rebuildJobStatus" id="e894843c-9b43-4989-b368-689225666323">
        <updating/>
        <source>rebuildJobStatus(_job : CM_Job input)updating;
//--------------------------------------------------------------
//Created: 28 February 2002 By: cnwgd1
//--------------------------------------------------------------
vars

	theResult : Integer;	//13 Jan 2020 NDL	TFS 46815
	
begin	

	if _job = null then
		return;
	endif;
	
	app.mousePointer := MousePointer_HourGlass;
	
	//13 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
	while true do
	
		app.myTrxUA.trxUpdateJobStatus(_job, app.myPassport);
	
		if app.myPassport.trxCompletedOK then
			break;
		else
			theResult := app.showErrorWarningDialog('Rebuild Job Status', app.myPassport, ErrWarnMode_Update);
			if app.myPassport.noErrors and theResult = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		
		break;
		
	endwhile;
	
epilog
	app.mousePointer := MousePointer_Default;
end;</source>
        <Parameter name="_job" type="CM_Job" usage="input"/>
    </JadeMethod>
    <JadeMethod name="rebuildWLEStatus" id="0e9974ce-cc89-46c8-ac81-255c6aaa8327">
        <updating/>
        <source>rebuildWLEStatus(_wle : CM_WorkListEntry input)updating;
//--------------------------------------------------------------
//Created: 28 February 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	obj : Object;
	rtnValue : Boolean;
	theResult : Integer;	//13 Jan 2020 NDL	TFS 46815
begin	

	if _wle = null then
		return;
	endif;
	
	app.mousePointer := MousePointer_HourGlass;
	
	//13 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
	while true do
	
		app.myTrxUA.trxUpdateWLEStatus(_wle, app.myPassport);
	
		if app.myPassport.trxCompletedOK then
			break;
		else
			theResult := app.showErrorWarningDialog('Rebuild Entry Status', app.myPassport, ErrWarnMode_Update);
			if app.myPassport.noErrors and theResult = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		
		break;
		
	endwhile;
	
epilog
	app.mousePointer := MousePointer_Default;
end;</source>
        <Parameter name="_wle" type="CM_WorkListEntry" usage="input"/>
    </JadeMethod>
    <JadeMethod name="remarksUpdate" id="664ddb11-def5-4bd0-aa30-c2d8d417f8be">
        <source>remarksUpdate(_obj : CM_Object input);
// ---------------------------------------------------------------------------
// Created:		February  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 29/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
// ---------------------------------------------------------------------------

vars
	remarksFrm	: CMUI_Remarks;	
begin
	
	if _obj = null then
		return;
	endif;

	// Update the navigator
	// Mar 2011 cnwjre1 27097 call consolidated request edit form for delivery request; call the existing one for others
	//epr par 34254 6/6/14
	if _obj.isKindOf(CM_DeliveryRequest) then
		self.myAssistant.showRequestEditForm(_obj.CM_DeliveryRequest,null,self.myCurrentWLE);
	else
		self.myAssistant.showRemarksForm(_obj);
	endif;

end;</source>
        <Parameter name="_obj" type="CM_Object" usage="input"/>
    </JadeMethod>
    <JadeMethod name="reselectListObject" id="0f672871-63da-4702-ab2d-1e1094c73682">
        <updating/>
        <source>reselectListObject()updating;
//--------------------------------------------------------------
//Created: 17 June 2004 By: cnwgd1
//--------------------------------------------------------------
vars
	idx : Integer;
begin
	
	if self.selectedListObject = null 
	or (not global.isValidObject(self.selectedListObject)) then
		self.lstJobsSetSelectedObject();
		return;
	endif;

	//Only highlights the row
	self.lstJobs.clearAllSelected();
		
	idx := self.lstJobs.findObject(self.selectedListObject);
	self.lstJobs.listObject := self.selectedListObject;
	self.lstJobs.itemSelected[idx] := true;	

	if self.topObject &lt;&gt; null then
		idx := self.lstJobs.findObject(self.topObject);
		if idx &gt; 0 then
			self.lstJobs.topIndex := idx;
		endif;
	elseif self.topIndex &gt; 0 then
		self.lstJobs.topIndex := self.topIndex;
	else
		self.lstJobs.topIndex := self.lstJobs.findObject(self.selectedListObject);
	endif;

end;</source>
    </JadeMethod>
