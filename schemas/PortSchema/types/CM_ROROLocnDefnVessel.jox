    <JadeMethod name="setProxy" id="e5669b81-f159-4e4d-aa99-8dffb31fdddc">
        <updating/>
        <source>setProxy(	_structure : CM_ROROVesselStructure;
			_code, _desc, _remarks : String; 
			_deckItemLayout :  CM_DeckItemLayout;
			_deck : CM_Deck; 
			_hasPower : Boolean;
			_isRotatable : Boolean;
			_isWaterCooled : Boolean;
			_maxLoadPer20 : Decimal;
			_maxLoadPer40 : Decimal;
			_maxLoadTotal : Decimal;
			_maxStackHeight : Decimal;
			_numTiers : Integer;
			_ordinal : Integer;
			_orientation: Integer;
			_voltageType: Integer;
			_adjacentSlot : CM_ROROLocnDefn;
			_deckLayerLayout : CM_DeckLayerLayout;
			_labelManChanged, _isOOTL : Boolean) updating;
/*
Purpose:			
Date		Who		Reason
18 April 2011	cnwab1	Initial creation
*/

vars

begin
	inheritMethod(	_structure,
					_code, _desc, _remarks,
					_deckItemLayout,
					_deck ,
					_hasPower ,
					_isRotatable,
					_isWaterCooled ,
					_maxLoadPer20,
					_maxLoadPer40,
					_maxLoadTotal,
					_maxStackHeight,
					_numTiers,
					_ordinal,
					_orientation,
					_voltageType,
					_adjacentSlot,
					_deckLayerLayout,_labelManChanged, _isOOTL );
					
	self.myROROStructure := _structure;
	
epilog

end;</source>
        <Parameter name="_structure" type="CM_ROROVesselStructure"/>
        <Parameter name="_code" type="String"/>
        <Parameter name="_desc" type="String"/>
        <Parameter name="_remarks" type="String"/>
        <Parameter name="_deckItemLayout" type="CM_DeckItemLayout"/>
        <Parameter name="_deck" type="CM_Deck"/>
        <Parameter name="_hasPower" type="Boolean"/>
        <Parameter name="_isRotatable" type="Boolean"/>
        <Parameter name="_isWaterCooled" type="Boolean"/>
        <Parameter name="_maxLoadPer20" type="Decimal"/>
        <Parameter name="_maxLoadPer40" type="Decimal"/>
        <Parameter name="_maxLoadTotal" type="Decimal"/>
        <Parameter name="_maxStackHeight" type="Decimal"/>
        <Parameter name="_numTiers" type="Integer"/>
        <Parameter name="_ordinal" type="Integer"/>
        <Parameter name="_orientation" type="Integer"/>
        <Parameter name="_voltageType" type="Integer"/>
        <Parameter name="_adjacentSlot" type="CM_ROROLocnDefn"/>
        <Parameter name="_deckLayerLayout" type="CM_DeckLayerLayout"/>
        <Parameter name="_labelManChanged" type="Boolean"/>
        <Parameter name="_isOOTL" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setProxyCode" id="ccec61f5-24e7-492c-be50-461286940f08">
        <updating/>
        <source>setProxyCode(_code: String)  : Boolean  updating;
/*
Purpose:			
Date		Who		Reason
09 February 2012	cnwab1	Initial creation
*/

vars	
	realMe : CM_ROROLocnDefnVessel;
	otherMe : CM_ROROLocnDefn;
begin

	// PAR 29088
	if self.pxyIsProxy then // update proxy
		realMe := self.pxyGetRealObject();
	elseif self.isTransient then // create proxy
		realMe := self;
	else
		realMe := self;
	endif;
	
	if realMe.myDeck &lt;&gt; null then
		otherMe := realMe.myDeck.allROROLocnDefnByCode[_code];
		if otherMe &lt;&gt; null and otherMe &lt;&gt; realMe then
			return false;
		endif;	
	elseif realMe.myROROStructure &lt;&gt; null then
		otherMe := realMe.myROROStructure.allROROLocnDefnByCode[realMe.myDeck, _code];
		if otherMe &lt;&gt; null and otherMe &lt;&gt; realMe then
			return false;
		endif;

	endif;

	return inheritMethod(_code);

epilog

end;</source>
        <Parameter name="_code" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setProxyForCreateDefaults" id="34396656-5e60-424e-9f41-c14c57c4202d">
        <updating/>
        <source>setProxyForCreateDefaults( _deckItemLayout :  CM_DeckItemLayout; _adjacent : CM_ROROLocnDefn; _orientation : Integer) updating;
/*
Purpose:			
Date		Who		Reason
18 April 2011	cnwab1	Initial creation
*/

vars

begin

	inheritMethod(_deckItemLayout , _adjacent, _orientation);
	self.myROROStructure := self.myDeck.CM_DeckVessel.getROROStructure;
	
epilog

end;</source>
        <Parameter name="_deckItemLayout" type="CM_DeckItemLayout"/>
        <Parameter name="_adjacent" type="CM_ROROLocnDefn"/>
        <Parameter name="_orientation" type="Integer"/>
    </JadeMethod>
</Class>
