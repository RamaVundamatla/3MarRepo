    <JadeMethod name="addRequestToSortDict" id="1dc13fc6-ff29-4dcc-9650-f2af304a43ca">
        <source>addRequestToSortDict(_roroReq : CM_RORORequest);
/*
Purpose:			
Date		Who		Reason
08 August 2011	cnwab1	Initial creation
*/

vars
	deckOrd, x1,y1,z1, portIndex : Integer;
	iter : Iterator;
begin



	return; // we are not doing port rotation checks across a deck








	if _roroReq.isTransient then
		return;
	endif;
	
	if self.allLoadCCByPortRotationXYZ.includes(_roroReq) then
		iter := self.allLoadCCByPortRotationXYZ.createIterator();
		iter.startAtObject(_roroReq);
		self.allLoadCCByPortRotationXYZ.getIteratorKeys(portIndex, x1,y1,z1,deckOrd,iter);
		self.allLoadCCByPortRotationXYZ.removeKeyEntry(portIndex, x1,y1,z1,deckOrd, _roroReq);
	endif;

	if _roroReq.getOrdinalsForPortRotationSort(self.ordinal, deckOrd, x1,y1,z1, portIndex) then
		self.allLoadCCByPortRotationXYZ.putAtKey(portIndex, x1,y1,z1,deckOrd, _roroReq);
	endif;

epilog
	delete iter;
end;</source>
        <Parameter name="_roroReq" type="CM_RORORequest"/>
    </JadeMethod>
    <JadeMethod name="archive" id="b6586bdf-3532-480d-8aee-fedf22220c36">
        <updating/>
        <source>archive(_controller : CMIF_ArchiveVoyage; _moveControl : CMIF_MoveController input; _passport : CM_Passport input) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
13 Mar 2020 cnwma1 Bug 48863: JMT - Voyage Archive, Non Worked Cargo Issue

*/
vars
	slotControllerIter : Iterator;
	slotController     : CM_VoyageROROController;	
	obj				   : Object;
	tiArray			   : CM_TIArray;
begin

	exclusiveLock(self);
	if _controller = null then
		app.raiseCMException2(MethodWithNullParam, method.name, 'CMIF_ArchiveVoyage controller', null, null);
		return;
	endif;
	if _passport = null then
		app.raiseCMException2(MethodWithNullParam, method.name, 'passport', null, null);
		return;
	endif;
	if _moveControl = null then
		app.raiseCMException2(MethodWithNullParam, method.name, '_moveControl', null, null);
		return;
	endif;	

	create tiArray transient;

	slotControllerIter := self.allROROSlotControllers.createIterator;
	while slotControllerIter.next(slotController) do
		slotController.archive(_controller, _moveControl, tiArray, _passport);
	endwhile;

epilog
	delete tiArray;
	delete slotControllerIter;
end;</source>
        <Parameter name="_controller" type="CMIF_ArchiveVoyage"/>
        <Parameter name="_moveControl" type="CMIF_MoveController" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="areCoordinatesWild" id="bf5cfc8f-010d-43e0-9e60-c2ae4910f087">
        <source>areCoordinatesWild( _theX, _theY : Decimal; _msg : String io):Boolean;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
26 June 2012	cnwndl1	Initial creation	Par 29775

*/

vars

	x1 : Integer;
	x2 : Integer;
	y1 : Integer;
	y2 : Integer;
	
	x1m : Decimal[12,1];
	x2m : Decimal[12,1];
	y1m : Decimal[12,1];
	y2m : Decimal[12,1];

begin

	if _theX = 0 and _theY = 0 then
		return false;
	 endif;

	self.myDeckLayout.getExtremePoints(x1, y1, x2, y2 );
	
	x1m := x1 / ROROStructurePixelsPerMetre;
	x2m := x2 / ROROStructurePixelsPerMetre;
	
	y2m := ( y2 / 2 ) / ROROStructurePixelsPerMetre;		// i.e. half the total width and positive = starboard.
	y1m := y2m * -1;										// negative meaning port
	
	if _theX &lt; ( x1m - 2 ) then	// 2 metre buffer
		_msg := app.getErrorString1( X_coordinate_wild, app.getErrorString(CM_Aft)) &amp; CrLf;
	endif;
	if _theX &gt; ( x2m + 2 ) then // 2 metre buffer
		_msg := app.getErrorString1( X_coordinate_wild, app.getErrorString(CM_Forward)) &amp; CrLf;
	endif;
	if _theY &lt; ( y1m + 1 ) then	// 1 metre buffer
		_msg := _msg &amp; app.getErrorString1( Y_coordinate_wild, app.getErrorString(LL_Port)) &amp; CrLf;
	endif;
	if _theY &gt; ( y2m + 1 ) then	// 1 metre buffer
		_msg := _msg &amp; app.getErrorString1( Y_coordinate_wild, app.getErrorString(CM_Starboard)) &amp; CrLf;
	endif;
	
	if _msg &lt;&gt; null then
		_msg := _msg &amp; app.getErrorString(Continue) &amp; "?";
	endif;
	
	return _msg &lt;&gt; null;

epilog

end;
</source>
        <Parameter name="_theX" type="Decimal"/>
        <Parameter name="_theY" type="Decimal"/>
        <Parameter name="_msg" type="String" usage="io"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="cloneMySelf" id="d2b02ede-009b-4843-b503-60e8d708f0d8">
        <source>cloneMySelf(_newStructure: CM_ROROVoyageStructure; _clearCode: Boolean; _copy: Boolean): CM_DeckVoyage;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
02 June 2011	cnwer1	Initial creation CCMS MES 1116

*/

vars
	aDeck, newDeck : CM_DeckVoyage;
	newSubDeck,
	subDeck : CM_DeckVoyageSub;
begin
	newDeck := self.cloneSelf(_copy);
	
	if _clearCode then
		newDeck.code:=null;
	endif;
	newDeck.setMyVoyageStructure(_newStructure);

	self.cloneMySelfSuper(newDeck, _copy);

	foreach aDeck in self.allSubDecks discreteLock do
		subDeck := aDeck.CM_DeckVoyageSub;
	
		newSubDeck := subDeck.cloneMySelfSub(newDeck, false,  _copy);
	
	endforeach;
	
	return newDeck;

epilog

end;</source>
        <Parameter name="_newStructure" type="CM_ROROVoyageStructure"/>
        <Parameter name="_clearCode" type="Boolean"/>
        <Parameter name="_copy" type="Boolean"/>
        <ReturnType type="CM_DeckVoyage"/>
    </JadeMethod>
    <JadeMethod name="createDefaultDischargeCC" id="9ba1d82f-6194-4dc5-8300-84c46da5b966">
        <updating/>
        <source>createDefaultDischargeCC(_passport : CM_Passport input) updating;
/*
------------------------------------------------------------------------
Created:			26 February 2003 by cnwdwq1
Purpose:			Called from the voyage for each bay, sets the slotRequest to Discharge
Parameters:		
Returns:			
Changed On		Changed By		Reason
------------	------------	-----------------------------------------
														
------------------------------------------------------------------------
*/
vars
	roroControllerIter : Iterator;
	roroController : CM_VoyageROROController;
	layer : CM_DeckLayerLayout;
	defn : CM_DeckItem;
	theVoyage : CM_Voyage;
	theTerminal : CM_Terminal;
	theMaster, theCloneMaster : CM_ROROLocnDefn;
	allMasters : ObjectSet;
begin

	create allMasters transient;



	theVoyage := self.myVoyageStructure.myVoyage;
	theTerminal := theVoyage.myTerminal;

	roroControllerIter := self.allROROControllers.createIterator;
	while roroControllerIter.next(roroController) do
	
		if roroController.allTrackedItems.isEmpty() then
			continue;
		endif;
		
		defn := roroController.getDefn();
		if defn.myLayout &lt;&gt; null then
			// ### If layout or layer is not visible then ignore
			if not defn.myLayout.isVisible then
				continue;
			endif;
			if not defn.myLayout.myDeckLayer.isVisible then
				continue;
			endif;
		else
			continue;
		endif;
		
		roroController.createDefaultDischargeCC(_passport, false); // PAR 28883
		
		// PAR 31569 missed when doing PAR 31110 - CCMS 1320
		if _passport.hasErrorsOrNonIgnoredWarnings() then
			return;
		endif;
		
		theMaster := roroController.getRotationMaster();
		if theMaster &lt;&gt; null and not theMaster.isOOTL() then
			allMasters.addNoDuplicates(theMaster, false);
		endif;
		
	endwhile;

	
	// PAR 31569 missed when doing PAR 31110 - CCMS 1320 if everything in the rotated actual is colour coded for discharge then clone and unrotated the load view.
	app.myUtilityCA.utlCreateRORORotateSwitchLoad(allMasters, _passport);

epilog
	delete allMasters;

	delete roroControllerIter;
end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="delete" id="30d7b7fa-bcf9-4340-bcec-0d5cd1274ff8">
        <updating/>
        <source>delete() updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
02 June 2011	cnwer1	Initial creation CCMS MES 1116

*/

vars

begin
	if not self.isTransient then
		if self.myVoyageStructure &lt;&gt; null then
			self.myVoyageStructure.causeEvent(EVENT_VESSEL_DECK_DELETE,false,self);
		endif;

	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="getActiveROROReqsForColourCode" id="96c27433-43c6-4192-a54b-484780b4de8a">
        <source>getActiveROROReqsForColourCode(ccType : Integer; scs : CM_RORORequestSet input);
/*
Purpose:			
Date				Who			Reason
SEPTEMBER 2011		CNWAB1		Initial creation
*/

vars
	slot : CM_VoyageROROController;
begin
	if scs = null then
		app.raiseCMException2(MethodWithNullParam, method.name, 'SlotRequest Set', null, null);
		return;
	endif;
	scs.clear;
	if ccType &lt;&gt; LOAD_COLOURCODE and ccType &lt;&gt; DISCHARGE_COLOURCODE then
		app.raiseCMException1(ERR_INVALID_COLOURCODE, ccType.String, null, null);
		return;
	endif;
	//------------------
	//Find all slots in the colour code for the passed in type
	//------------------
	foreach slot in self.allROROControllers discreteLock do

		//----------------------
		//Test to see if its set
		//----------------------
		if ccType = LOAD_COLOURCODE then
			if slot.myRORORequestLoad = null then
				continue;
			endif;
			if slot.myRORORequestLoad.moveType = NULL_MOVETYPE then
				continue;
			endif;
			scs.add(slot.myRORORequestLoad);
		elseif ccType = DISCHARGE_COLOURCODE then
			if slot.myRORORequestDischarge = null then
				continue;
			endif;
			if slot.myRORORequestDischarge.moveType = NULL_MOVETYPE then
				continue;
			endif;
			scs.add(slot.myRORORequestDischarge);
		endif;
	endforeach;
end;</source>
        <Parameter name="ccType" type="Integer"/>
        <Parameter name="scs" type="CM_RORORequestSet" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getAllDeckJobs" id="d91513f7-3fcc-4cfb-bb13-36deb6b5c212">
        <source>getAllDeckJobs(_allJobs : CM_VoyageJobSet input);
/*
Purpose:			
Date		Who		Reason
14 September 2011	cnwab1	Initial creation
*/

vars
	aDeck : CM_DeckVoyage;
	deckJob : CM_VoyageDeckJob;
	aSlot : CM_VoyageROROController;
	aRequest : CM_RORORequest;
	invalidObject : Boolean;
begin
	if _allJobs = null then
		return;
	endif;
	
	on Exception do app.handleDeletedObject(exception,aRequest, invalidObject);
	
	foreach aSlot in self.allROROControllers  discreteLock do
		aRequest := aSlot.myRORORequestDischarge;
		if aRequest &lt;&gt; null then
			deckJob := aRequest.myJob.CM_VoyageDeckJob;
			
			if invalidObject then
				invalidObject:=false;
				continue;
			endif;
			
			if deckJob &lt;&gt; null then
				_allJobs.addNoDuplicates(deckJob, false);
			endif;
		endif;
		aRequest := aSlot.myRORORequestLoad;
		if aRequest &lt;&gt; null then
		//or aRequest.isRehandle
			if (aRequest.isSoB ) 
			and aRequest.myRequestLinkedDischarge &lt;&gt; null 
			and aRequest.myRequestLinkedDischarge.myJob.isKindOf(CM_VoyageDeckJob) then // PAR 28968
				deckJob:=aRequest.myRequestLinkedDischarge.myJob.CM_VoyageDeckJob;
			else
				deckJob := aRequest.myJob.CM_VoyageDeckJob;
			endif;
			
			if deckJob &lt;&gt; null then
				_allJobs.addNoDuplicates(deckJob, false);
			endif;
		endif;
	endforeach;
epilog

end;</source>
        <Parameter name="_allJobs" type="CM_VoyageJobSet" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getAllProposedTIs" id="7c8b7bd4-7e50-4e4e-b61c-b634ad8a1e0c">
        <source>getAllProposedTIs(_theTIs : CM_TIArray input);
/*
Purpose:			
Date				Who			Reason
AUGUST 2011		CNWAB1		Initial creation
*/

vars

	theROROController : CM_VoyageROROController;
	theTIs : CM_TIArray;
	theTI : CM_TrackedItem;
	numTI, labelID : String;
begin
	if _theTIs = null then
		return;
	endif;
	create theTIs transient;
	foreach theROROController in self.allROROControllers do
		theROROController.getProposedTIs(theTIs);
		if not theTIs.isEmpty then
			theTIs.copy(_theTIs);
		endif;
	endforeach;
epilog
	delete theTIs;
end;</source>
        <Parameter name="_theTIs" type="CM_TIArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getAllTrackedItems" id="f747ac9a-7c4e-4827-87ba-ab612b9dc287">
        <source>getAllTrackedItems(_theMoveMode : Integer; _theTIs : CM_TIArray input);
// ---------------------------------------------------------------------------
// Created:		October 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	theROROController : CM_VoyageROROController;
	theTIs : CM_TIArray;
begin
	if _theTIs = null then
		return;
	endif;
	create theTIs transient;
	foreach theROROController in self.allROROControllers do
		theTIs.clear;
		if _theMoveMode = QUEUE_MODE then
			theROROController.getAllQueuedTrackedItems(theTIs, true);
		elseif _theMoveMode = PLANNING_MODE then
			theROROController.getAllPlannedTrackedItems(theTIs, true, false);
		elseif _theMoveMode = REAL_MODE then
			theROROController.allTrackedItems.copy(theTIs);
		endif;
		
		theTIs.copy(_theTIs);
	endforeach;
epilog
	delete theTIs;
end;</source>
        <Parameter name="_theMoveMode" type="Integer"/>
        <Parameter name="_theTIs" type="CM_TIArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getDeckVessel" id="09f5c1cc-894f-4a33-9b4b-30574b6c4324">
        <source>getDeckVessel():CM_DeckVessel;
/*

Date		Who		Reason
10 August 2011	cnwcs5	Initial creation - CCMS MES 1033 / par 27951 RORO KPI
*/
vars
	voyage	:CM_Voyage;
	vessel	:CM_Vessel;
begin	
	voyage	:= self.getVoyage;
	vessel	:= self.getVessel;
	
	return vessel.myROROVesselStructure.allDecksByCode [self.code];
epilog

end;</source>
        <ReturnType type="CM_DeckVessel"/>
    </JadeMethod>
    <JadeMethod name="getKPIUsed" id="ff81427b-617e-4fdb-b150-a3bdb2f7097d">
        <source>getKPIUsed(_mode : Integer; _volume,_area, _lm : Decimal output);
/*
Purpose:			
Date		Who		Reason
01 September 2011	cnwab1	Initial creation
*/

vars
	item : CM_DeckItem;
	areaUsed : Decimal[12,2];
	tmpTIs : CM_TIArray;
	tmpArea, tmpVol : Decimal[12,2];
begin

	create tmpTIs transient;
	
	foreach item in self.allDeckItems discreteLock do
		if item.myLayout = null then
			continue;
		endif;
		if not item.includeInKPI() then
			continue;
		endif;
		
		 item.getKPIArea(_mode, tmpTIs, tmpArea, tmpVol);
		 
		 _area := _area + tmpArea;
		 _volume := _volume + tmpVol;
		 
	endforeach;
	
	_lm := _area / self.myVoyageStructure.myVoyage.myTerminal.getConfigLMWidth();
	

epilog
	delete tmpTIs;
end;</source>
        <Parameter name="_mode" type="Integer"/>
        <Parameter name="_volume" type="Decimal" usage="output"/>
        <Parameter name="_area" type="Decimal" usage="output"/>
        <Parameter name="_lm" type="Decimal" usage="output"/>
    </JadeMethod>
    <JadeMethod name="getKPIVoyageDeckWorkPointForJS" id="085135a9-7b56-49a9-b8da-9ea8b9d8760b">
        <source>getKPIVoyageDeckWorkPointForJS(_js : CM_VoyageJobSheet) : CM_KPIVoyageDeckWorkPoint;
/*		
Date		Who		Reason
10 August 2011	cnwcs5	Initial creation - CCMS MES 1033 / par 27951 RORO KPI
*/
vars
	kpi  : CM_KPI;
begin
	foreach kpi in self.allKPIVoyageDeckWorkPoints discreteLock do
		if kpi.CM_KPIVoyageDeckWorkPoint.myWorkPoint = _js.getMyWorkPoint then
			return kpi.CM_KPIVoyageDeckWorkPoint;
		endif;
	endforeach;
	
	return null;
end;</source>
        <Parameter name="_js" type="CM_VoyageJobSheet"/>
        <ReturnType type="CM_KPIVoyageDeckWorkPoint"/>
    </JadeMethod>
    <JadeMethod name="getLoadCCPercentageBreakdown" id="63ad1172-5b23-4afc-b0e8-f34bc45fd3ef">
        <source>getLoadCCPercentageBreakdown(	_portsByPercentage : DynaDictionary input);
/*

Purpose:		Gets all the load colour coding as a percentage of discarge port colour coding
				

Parameters:		_portsByPercentage is a Dyna Dict - its member ship is CM_Port has 2 external keys - number of cc items &amp; the % of total load cc	

Return Value:		


Date		Who		Reason
31 August 2011	cnwer1	Initial creation CCMS MES 1033
17/03/2015		cnwmh5	Tranisent Leaks
*/

vars
	dynaIter,
	iter : Iterator;
	slotController : CM_ROROSlotController;
	gcController   : CM_ROROGCController;
	loadRequest : CM_RORORequest;
	totalLoadCC ,numPort, numWLEs: Integer;
	percent : Integer;
	loadPort : CM_Port;
	allPorts : CM_PortSet;
begin
	
	
	_portsByPercentage.setMembership(CM_Port);
	_portsByPercentage.addExternalKey(Integer,4,false,false); //total number loaded 
	_portsByPercentage.addExternalKey(Integer,4,false,false); //percentage
	_portsByPercentage.endKeys(true);
	
	create allPorts transient;
	
	dynaIter:=_portsByPercentage.createIterator;
	iter:=self.allROROSlotControllers.createIterator;
	while iter.next(slotController) do
		loadRequest:=slotController.myRORORequestLoad;
		if loadRequest = null then	
			continue;
		endif;
		loadPort:=loadRequest.getAttrDischargePort;
		if loadPort = null then
			continue;
		endif;
		
		numWLEs:=loadRequest.allWorkListEntries.size;
		if numWLEs = 0 then	
			continue;
		endif;
		if not _portsByPercentage.includes(loadPort) then
			_portsByPercentage.putAtKey(numWLEs,null,loadPort);
			allPorts.addNoDuplicates(loadPort,false);
		else
			dynaIter.startAtObject(loadPort);
			numPort:=dynaIter.getCurrentKey(1).Integer;
			_portsByPercentage.removeKeyEntry(numPort,null,loadPort);
			_portsByPercentage.putAtKey(numPort+numWLEs,null,loadPort);
		endif;
		totalLoadCC:=totalLoadCC + numWLEs;
	endwhile;
	
	delete iter;
	iter:=self.allROROGCControllers.createIterator;
	while iter.next(gcController) do
		loadRequest:=gcController.myRORORequestLoad;
		if loadRequest = null then	
			continue;
		endif;
		loadPort:=loadRequest.getAttrDischargePort;
		if loadPort = null then
			continue;
		endif;
		
		numWLEs:=loadRequest.allWorkListEntries.size;
		if numWLEs = 0 then	
			continue;
		endif;
		if not _portsByPercentage.includes(loadPort) then
			_portsByPercentage.putAtKey(numWLEs,null,loadPort);
			allPorts.addNoDuplicates(loadPort,false);
		else
			dynaIter.startAtObject(loadPort);
			numPort:=dynaIter.getCurrentKey(1).Integer;
			_portsByPercentage.removeKeyEntry(numPort,null,loadPort);
			_portsByPercentage.putAtKey(numPort+numWLEs,null,loadPort);
		endif;
		totalLoadCC:=totalLoadCC + numWLEs;
	endwhile;
	
	delete iter;
	iter:=allPorts.createIterator;
	while iter.next(loadPort) do
		dynaIter.startAtObject(loadPort);
		numPort:=dynaIter.getCurrentKey(1).Integer;
		percent:=((numPort/totalLoadCC) * 100).rounded;
		_portsByPercentage.removeKeyEntry(numPort,null,loadPort);
		_portsByPercentage.putAtKey(numPort,percent,loadPort);
	endwhile;
	
epilog
	delete iter;
	delete dynaIter;
	delete allPorts;
end;</source>
        <Parameter name="_portsByPercentage" type="DynaDictionary" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getName" id="a74cd043-4a48-4caa-b3ac-b3bd0da1f0d5">
