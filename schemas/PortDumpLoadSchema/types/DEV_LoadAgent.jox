    <JadeMethod name="loadYardTransferArea" id="b31d2a13-e8c3-4690-9c31-d59db9b58475">
        <source>loadYardTransferArea(_proxyObject:CM_Object io):Boolean protected;

vars
	 proxyObject: CM_TerminalArea;
	error: CM_Error;
	theUser: CM_User;
	result: Boolean;
	yaDeckingOptions: CM_YADeckingOptionsTA;
	realObject : CM_TerminalAreaMaster;

begin
	


	result := false;
	proxyObject := _proxyObject.CM_TerminalArea;
	create yaDeckingOptions transient;
	yaDeckingOptions.setProxy(false, true, proxyObject);
	yaDeckingOptions.setProxyRules(DeckingRule_Default, DeckingRule_Default);

	app.myTrxCA.trxCreateTerminalArea(proxyObject, realObject,  app.myPassport);

	if app.myPassport.trxCompletedOK and
	   app.myPassport.allErrorWarnings.size = 0 then
//		write class.name&amp;'::'&amp;method.name&amp;' '&amp;proxyObject.id&amp;" OK";
		result := true;
	else
		foreach error in app.myPassport.allWarnings do
			write class.name&amp;'::'&amp;method.name&amp;' '&amp;proxyObject.id&amp;" WARNING: "&amp;error.text;
		endforeach;
		foreach error in app.myPassport.allErrors do
			write class.name&amp;'::'&amp;method.name&amp;' '&amp;proxyObject.id&amp;" ERROR: "&amp;error.text;
		endforeach;
	endif;
epilog

	return result;
end;</source>
