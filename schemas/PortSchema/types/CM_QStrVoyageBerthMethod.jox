    <JadeMethod name="setComboValues" id="2900afe0-cf27-4989-ac7f-eb5ced44e7cf">
        <source>setComboValues(comboBox 				: ComboBox input; 
			   queryCriteriaLineHolder	: CM_QueryCriteriaLineHolder; 
			   queryOperator			: CM_QueryOperator; 
			   passport					: CM_Passport);
/*****************************************************
Author		: jlgka1 (Karen Alexander)
Date		: 11 September 2018
TFS#		: 40200
Function	: Populate comboBox List.

*** Changes ***
Date			Name		TFS#		Description

****************************************************/
vars
	berth		: HMS_Berth;
	storeIdx	: Integer;
	idx			: Integer;
	selectStr	: String;
	str			: String;
	selectBerth : HMS_Berth;
begin
	comboBox.clear();	
	comboBox.sorted := true;
	
	if CM_QStringLookup.hasInstance(queryOperator) then
		selectStr := queryOperator.CM_QStringLookup.selectionValue;
	elseif CM_QStringLookupNotEqual.hasInstance(queryOperator) then
		selectStr := queryOperator.CM_QStringLookupNotEqual.selectionValue;
	endif;
	
	foreach berth in HMS_Berth.instances do		
		
		str := berth.code &amp; Tab &amp; ' (' &amp; berth.description &amp; ')';		
		idx := comboBox.addItem(str);
		comboBox.itemObject[idx] := berth;
		
		if berth.code = selectStr then
			selectBerth := berth;
		endif;
	endforeach;
	
	storeIdx := comboBox.findObject(selectBerth);
	if storeIdx &gt; 0 and storeIdx &lt; comboBox.listCount then
		comboBox.listIndex := storeIdx;
	endif;
end;</source>
        <Parameter name="comboBox" type="ComboBox" usage="input"/>
        <Parameter name="queryCriteriaLineHolder" type="CM_QueryCriteriaLineHolder"/>
        <Parameter name="queryOperator" type="CM_QueryOperator"/>
        <Parameter name="passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="setListValues" id="c6496101-a22c-4034-abf0-0fc8c7a2730c">
        <source>setListValues(table						: Table input; 
			  queryCriteriaLineHolder	: CM_QueryCriteriaLineHolder;
			  queryOperator				: CM_QueryOperator; 
			  passport					: CM_Passport);
/*****************************************************
Author		: jlgka1 (Karen Alexander)
Date		: 11 September 2018
TFS#		: 40200
Function	: Populate Selection List.

*** Changes ***
Date			Name		TFS#		Description

****************************************************/

vars
	berth					: HMS_Berth;
	selectionValue			: Integer;
	idx						: Integer;
	array					: ObjectArray;
begin
	
	table.rows := table.fixedRows;
	table.sortColumn[1] := 2;
	table.sortAsc[1] := true;
	
	array := table.getPropertyValue('allSelectedObjects').ObjectArray;
	array.clear;
	
	foreach berth in HMS_Berth.instances do
	
		selectionValue := 0;
		if queryOperator &lt;&gt; null and  queryOperator.CM_QStringIsOneOf.allSelectionValues.includes(berth.code) then
			selectionValue := 1;
			array.add(berth);
		endif;		
		
		idx := table.addItem(selectionValue.String &amp; Tab  &amp; berth.code  &amp; Tab &amp; ' (' &amp; berth.description &amp; ')');
		
		table.accessRow(idx).itemObject := berth;
	endforeach;
	
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="queryCriteriaLineHolder" type="CM_QueryCriteriaLineHolder"/>
        <Parameter name="queryOperator" type="CM_QueryOperator"/>
        <Parameter name="passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="setValuesFromList" id="b032e861-a4f6-4449-a8b9-f0ef35a37281">
        <source>setValuesFromList(table: Table input; queryOperator: CM_QueryOperator input);

/*****************************************************
Author		: jlgka1 (Karen Alexander)
Date		: 11 September 2018
TFS#		: 40200

*** Changes ***
Date			Name		TFS#		Description

****************************************************/

vars
	berth		: HMS_Berth;
	str			: String;
	numRows		: Integer;
	idx			: Integer;
	strArray	: StringArray;

begin

	create strArray transient;
	
	numRows := table.rows;
	foreach idx in (table.fixedRows + 1) to numRows do
		str := table.accessCell(idx, 1).text;
		if str = TableCheckBox_Selected then
			berth := table.accessRow(idx).itemObject.HMS_Berth;
			strArray.add(berth.code);
		endif;
	endforeach;
	
	queryOperator.setSearchValue(strArray);

epilog
	delete strArray;
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="queryOperator" type="CM_QueryOperator" usage="input"/>
    </JadeMethod>
    <JadeMethod name="translateToDisplayValue" id="e8c77763-2947-433f-b644-de3f2923bc73">
        <source>translateToDisplayValue(_value: Any): String;
/*****************************************************
Author		: jlgka1 (Karen Alexander)
Date		: 11 September 2018
TFS#		: 40200

*** Changes ***
Date			Name		TFS#		Description

****************************************************/

begin
	if _value.isKindOf(HMS_Berth) then
		if _value &lt;&gt; null then
			return _value.HMS_Berth.code;
		else 
			return null;
		endif;
	else
		return _value.String;
	endif;
	return null;

end;</source>
        <Parameter name="_value" type="Any"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="translateToSearchValue" id="6a063b16-bdc5-4418-99dd-bc52a0986e83">
        <source>translateToSearchValue(_value: Any): Any;
/*****************************************************
Author		: jlgka1 (Karen Alexander)
Date		: 11 September 2018
TFS#		: 40200

*** Changes ***
Date			Name		TFS#		Description

****************************************************/

vars
	invalidObj 		: Boolean;
	object			: HMS_Berth;
	returnVal		: String;
	
begin
	if _value &lt;&gt; null then
		if _value.isKindOf(Collection) then			// PAR #18348
			return _value;
		endif;

		if _value.isKindOf(HMS_Berth) then
			object := _value.HMS_Berth;
		endif;
	endif;
	
	if object &lt;&gt; null then
		on Exception do app.handleDeletedObject(exception, object, invalidObj);
		
		returnVal := object.code;
	endif;
	
	return returnVal;
	
end;</source>
        <Parameter name="_value" type="Any"/>
        <ReturnType type="Any"/>
    </JadeMethod>
    <JadeMethod name="translateToSearchValueForWeb" id="dd38efc5-2b3e-4f3a-bdca-c79f70e33fe9">
        <source>translateToSearchValueForWeb(_value: Any; _sending : Boolean): Any;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 09/09/2019	jlgdap1		Initial creation TFS 45769 JMT Web portal selector query parameters
//
vars
	str, rtnValue : String;
	harbour : HMS_Harbour;
	strArray : StringArray;

begin
	if _value.isKindOf(HMS_Berth) then
		return _value.HMS_Berth.code;
		
	elseif _value.isKindOf(String) then
		if _value.String.cnContains("|") then
			harbour := app.myPassport.myTerminal.myHarbour;
			if harbour &lt;&gt; null then
				str := _value.String;
				create strArray transient;
				str.getTokensForDelimiter("|", strArray);
				return strArray;
			endif;
		endif;
		
		return _value.String;
		
	elseif _value.isKindOf(StringArray) then
		foreach str in _value.StringArray do
			rtnValue := rtnValue &amp; str &amp; CNEC_COMMA &amp; Space;
		endforeach;
		rtnValue := rtnValue[1:rtnValue.length-2];
		return rtnValue;
		
	endif;
	
	return inheritMethod(_value, _sending);

epilog

end;</source>
        <Parameter name="_value" type="Any"/>
        <Parameter name="_sending" type="Boolean"/>
        <ReturnType type="Any"/>
    </JadeMethod>
</Class>
