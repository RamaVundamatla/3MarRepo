    <JadeMethod name="setUserDefinedTI" id="9c27025b-7989-4770-a5da-08e89d6187b6">
        <updating/>
        <source>setUserDefinedTI(_ediTi: CM_EDICargoTI; _site : Integer; _terminal: CM_Terminal; _updateController: CMIF_TIUpdateController input; _passport: CM_Passport input) updating;
/*
----------  ----------  --------------------------------------------------
Created:	04 August 2006 By cnwth2

Purpose:	

Changed On  Changed By  Reason
----------  ----------  --------------------------------------------------
01/12/2009	cnwdap1	 	CCMS MES 1007 Move reefer properties up to CM_TrackedItem level
22/01/2010	cnwdad1		PAR #22179 - Added over dimension properties.
// 07 Jun 2017	cnwrs1	TFS 4462 SNO add Terminal Operator, Unknown Seal and support multiple seals
28/06/2017	cnwdap1		TFS 4492 SNO VERMAS Changes
*/
vars

	now : TimeStamp;

begin
	inheritMethod(_ediTi, _site, _terminal, _updateController, _passport);
	
	now := app.actualTimeServer();	// 16 Sept 2016	cnwns1	TFS 488 - Multi Timezone Support
		
	self.isoType := _ediTi.isoType;
//	self.availabilityGrade := self.myTerminal.getConfig(DefAvailabilityGrade).Integer;	// cnwrl1 03/02/2010 PAR 21758 - what it was
	// cnwrl1 03/02/2010 PAR 21758 - start of coding
	if _ediTi.availabilityGrade = null then
		self.availabilityGrade	:= self.myTerminal.getConfig( DefAvailabilityGrade ).Integer;
	else
		self.availabilityGrade	:= _ediTi.availabilityGrade;
	endif;
	// cnwrl1 03/02/2010 PAR 21758 - end of coding
	
	//cnwmc5 - 23 Jan 2014 - PAR 33001
	if _ediTi.overHeight &lt;&gt; NULL_INTEGER then
		self.overHeight			:=	_ediTi.overHeight;
	endif;
	if _ediTi.overLengthFront &lt;&gt; NULL_INTEGER then
		self.overLengthFront	:=	_ediTi.overLengthFront;
	endif;
	if _ediTi.overLengthBack &lt;&gt; NULL_INTEGER then
		self.overLengthRear		:=	_ediTi.overLengthBack;
	endif;
	if _ediTi.overWidthLeft &lt;&gt; NULL_INTEGER then
		self.overWidthLeft		:=	_ediTi.overWidthLeft;
	endif;
	if _ediTi.overWidthRight &lt;&gt; NULL_INTEGER then
		self.overWidthRight		:=	_ediTi.overWidthRight;
	endif;
	
//	self.sealNum		:= _ediTi.sealNum;
//	self.sealNumCustoms := _ediTi.sealCustoms;
//	self.sealNumShippers:= _ediTi.sealShipper;
//	self.sealNumVent	:= _ediTi.sealNumberVent;	// CCMS1909 - PAR22160 cnwsh3	
	
	//16 Sep 2010	NDL	Par 25608	- Use new CM_SealTI structure.
	self.createProxySealTIsFromRawData(	_ediTi.sealNum,	//_sealNum : String;
										null,	//_prevSealNum : String;
										_ediTi.sealShipper,	//_sealNumShippers : String;
										_ediTi.sealNumberVent,	//_sealNumVent : String;
										_ediTi.sealCustoms,	//_sealNumCustoms : String;
										_ediTi.sealTerminalOperator,
										_ediTi.sealUnknown,
										now	//_now : TimeStamp
										);
										
	self.setMyVGMDetails(	_ediTi.weightCertifiedReference,	// TFS 4492
							_ediTi.weightCertifiedName,			// TFS 4492
							_ediTi.vgmAuthSignature,			// TFS 4492
							_ediTi.vgmCommsType,				// TFS 4492
							_ediTi.vgmDocumentDetails,			// TFS 4492
							_ediTi.vgmEDITransmission,			// TFS 4492
							_ediTi.vgmElectronicMail,			// TFS 4492
							_ediTi.vgmMail,						// TFS 4492
							_ediTi.vgmPhone,					// TFS 4492
							_ediTi.vgmTelefax,					// TFS 4492
							_ediTi.vgmTelephone,				// TFS 4492
							_ediTi.vgmDocsIssuedDT,				// TFS 4492
							_ediTi.vgmDeterminationDT,			// TFS 4492
							null	);							// TFS 4492
end;</source>
        <Parameter name="_ediTi" type="CM_EDICargoTI"/>
        <Parameter name="_site" type="Integer"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_updateController" type="CMIF_TIUpdateController" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setUserDefinedTIForModify" id="17d03766-b93d-4111-83c1-fb0987f5fbcd">
        <updating/>
        <source>setUserDefinedTIForModify(_ediTi: CM_EDICargoTI; _terminal: CM_Terminal; _updateController: CMIF_TIUpdateController input; _passport: CM_Passport input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 April 2014	cnwmc5	Initial creation	CCMS 2352
// 07 Jun 2017	cnwrs1	TFS 4462 SNO add Terminal Operator, Unknown Seal and support multiple seals
*/

vars
	now : TimeStamp;
begin
	inheritMethod(_ediTi, _terminal, _updateController, _passport);
	
		now := app.actualTimeServer();	// 16 Sept 2016	cnwns1	TFS 488 - Multi Timezone Support
	
	if _ediTi.isoType &lt;&gt; null then
		self.isoType := _ediTi.isoType;
	endif;

	if _ediTi.availabilityGrade &lt;&gt; null then
		self.availabilityGrade	:= _ediTi.availabilityGrade;
	endif;

	if _ediTi.overHeight &lt;&gt; NULL_INTEGER then
		self.overHeight			:=	_ediTi.overHeight;
	endif;
	if _ediTi.overLengthFront &lt;&gt; NULL_INTEGER then
		self.overLengthFront	:=	_ediTi.overLengthFront;
	endif;
	if _ediTi.overLengthBack &lt;&gt; NULL_INTEGER then
		self.overLengthRear		:=	_ediTi.overLengthBack;
	endif;
	if _ediTi.overWidthLeft &lt;&gt; NULL_INTEGER then
		self.overWidthLeft		:=	_ediTi.overWidthLeft;
	endif;
	if _ediTi.overWidthRight &lt;&gt; NULL_INTEGER then
		self.overWidthRight		:=	_ediTi.overWidthRight;
	endif;

	self.createProxySealTIsFromRawData(	_ediTi.sealNum,
										null,
										_ediTi.sealShipper,
										_ediTi.sealNumberVent,
										_ediTi.sealCustoms,
										_ediTi.sealTerminalOperator,
										_ediTi.sealUnknown,
										now);
epilog

end;</source>
        <Parameter name="_ediTi" type="CM_EDICargoTI"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_updateController" type="CMIF_TIUpdateController" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setWagon" id="9ee6f8b2-a4bc-458d-b507-f57c06dfaa28">
        <updating/>
        <source>setWagon(_wagonId: String; _wagonObject: CM_Wagon; _wagonClass : CM_WagonClass; _moveWagon : Boolean ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 March 2013	cnwndl1	Initial creation	Par 31278

*/

vars

	existingPreNoteWagon : CM_Wagon;

begin

	existingPreNoteWagon := self.myNotifiedWagon;

	//inheritMethod(_wagonId, _wagonObject, _wagonClass);
	inheritMethod(_wagonId, _wagonObject, _wagonClass, _moveWagon); //12 Jan 2018 MPD TFS 36406
	
	//warn if we are trying to pre-note a container on a boxcar.
	
	if self.myNotifiedWagon = null then
		//its been cleared, no issue
		return;
	endif;
	if self.myNotifiedWagon = existingPreNoteWagon then
		// it hasn't changed, no issue
		return;
	endif;
	if not self.myNotifiedWagon.isBoxcar then
		// its not a box car, no issue
		return;
	else	
		app.raiseCMWarning(Boxcar_wagons_not_design_conta, null, null, self);
	endif;

epilog

end;</source>
        <Parameter name="_wagonId" type="String"/>
        <Parameter name="_wagonObject" type="CM_Wagon"/>
        <Parameter name="_wagonClass" type="CM_WagonClass"/>
        <Parameter name="_moveWagon" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setWashDetails" id="7a5cc38a-3701-497d-8f81-18e083928005">
        <updating/>
        <source>setWashDetails(_clean:Boolean) updating;
// ---------------------------------------------------------------------------
// Created:     21 September 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	trans	: CM_TITransaction;

begin
	if self.offsiteCleaned then // PAR 7279 AKB2004JAN - if cleaned offsite the washDT is set, this was nulling it out
		return;
	endif;
	
	if _clean then
		//trans := self.getLastTransOfType(TRANS_TYPE_WASH);
		trans := self.getLastTransOfClass(CM_Wash);	//22 Mar 2016	NDL	TFS 1694
		
		if trans = null then // hasnt been washed
			self.washDT := null;
		else
			self.washDT := trans.dateTime;
		endif;
	else // is dirty
		self.washDT := null;
	endif;
end;</source>
        <Parameter name="_clean" type="Boolean"/>
    </JadeMethod>
