    <JadeMethod name="addToolbarControls" id="a9987dff-ee70-41d2-add3-fbea96ae56dc">
        <updating/>
        <source>addToolbarControls() updating, protected;
//--------------------------------------------------
// Created:	22 January 2004 By: cnwgd1
//--------------------------------------------------
vars
	toolbar		: CMUI_Toolbar;
begin
	inheritMethod();
	
	toolbar := self.frmToolbar;
	//toolbar.addButton(self.btnSaveBase, CMUI_Toolbar.Control_Alignment_Left);	
	toolbar.addButton(self.btnNew, CMUI_Toolbar.Control_Alignment_Left);		
	toolbar.addButton(self.btnEdit, CMUI_Toolbar.Control_Alignment_Left);			
	toolbar.addButton(self.btnDelete, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnCancelBase, CMUI_Toolbar.Control_Alignment_Right);

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="applyMovementChange" id="e747fd06-85c3-432e-8894-de4e164b40b4">
        <updating/>
        <source>applyMovementChange(oldMovement : CMIF_HMS_WorkingMovement; newMovement : CMIF_HMS_WorkingMovement) updating;

vars

begin
 	// Determine whether movement is ADD, DELETE or EDIT
 	if oldMovement=null then
 		// Add
 		buildEntireForeground;
 	elseif newMovement=null then
 		// Delete
 		buildEntireForeground;
 	else
 		// Edit
 		buildEntireForeground;
 	endif;
end;</source>
        <Parameter name="oldMovement" type="CMIF_HMS_WorkingMovement"/>
        <Parameter name="newMovement" type="CMIF_HMS_WorkingMovement"/>
    </JadeMethod>
