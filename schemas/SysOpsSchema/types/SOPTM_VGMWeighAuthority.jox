    <JadeMethod name="doDelete" id="e59a528d-de51-427f-9ae9-39c11d8cee13">
        <updating/>
        <source>doDelete(pObj: Object io) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 14/06/2017	cnwdap1		Initial creation TFS 4492 / 2523 SNO / CPL VERMAS Changes
//
vars
	result : Integer;

begin
	while true do
		app.myTrxDA.trxDeleteWeighAuthority(pObj.CM_WeighAuthority, app.myPassport);
		
		if app.myPassport.trxCompletedOK then
			self.myForm.clearErrorWarnings();
			break;
		else
			if app.myPassport.noErrors
			and app.myPassport.hasWarnings then
				//only do this if no error and has warnings - other combinations handled by the form - only way to handle warning at the moment
				result := app.showErrorWarningDialog('Delete', app.myPassport, ErrWarnMode_Delete + ErrWarnMode_CanAckWarnings);
				if app.myPassport.noErrors and
					result = IDOK then
					// there must have just been warnings that the user has acknoledged so ..
					app.myPassport.warningsAcknowledged	:= true;
					continue;
				endif;
			else
				//the form doDelete will handle it
			endif;
		endif;
		break;
	endwhile;

epilog

end;</source>
        <Parameter name="pObj" type="Object" usage="io"/>
    </JadeMethod>
    <JadeMethod name="doResize" id="4582fa93-397d-4c5f-b602-009182b08718">
        <source>doResize();
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 23/06/2017	cnwdap1		Initial creation TFS 4492 SNO VERMAS Changes
//
vars
	form : SOP_TableMaintForm;
	
begin
	inheritMethod();
	form := self.myForm;
		
	form.tblData1.columnWidth[2] := form.tblData1.clientWidth - form.tblData1.columnWidth[1];
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doSave" id="25608127-9418-4214-8d73-7e7123999a5f">
        <updating/>
        <source>doSave(): Boolean updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 14/06/2017	cnwdap1		Initial creation TFS 4492 / 2523 SNO / CPL VERMAS Changes
//
vars
	form : SOP_TableMaintForm;
	pxyWeighAuth : CM_WeighAuthority;
	table : CM_EntryTable;
	dataTable : CM_DataTable;
	authName, certName, addr1, addr2, addr3, 
	email1, email2, phone1, phone2, solas : String;
	isDefault, notAvail : Boolean;
	authTerm : CM_WeighAuthTerminal;
	terminal : CM_Terminal;
	row : Integer;
	allAuthTerminals : ObjectArray;

begin
	form := self.myForm; 
	table := form.tblInput1;
	dataTable := form.tblData1;
	
	authName := table.getValueByName(ETRow_WeightAuthorisedBy).String;
	certName := table.getValueByName(ETRow_WeightCertifiedBy).String;
	addr1 := table.getValueByName(ETRow_AddressLine1).String;
	addr2 := table.getValueByName(ETRow_AddressLine2).String;
	addr3 := table.getValueByName(ETRow_AddressLine3).String;
	email1 := table.getValueByName(ETRow_EmailAddress).String;
	email2 := table.getValueByName(ETRow_EmailAddress2).String;
	phone1 := table.getValueByName(ETRow_Phone).String;
	phone2 := table.getValueByName(ETRow_Phone2).String;
	solas := table.getValueByName(ETRow_SolasMethod).String;
	isDefault := table.getValueByName(ETRow_IsDefault).Boolean;
	notAvail := table.getValueByName(ETRow_NotAvailableForEntry).Boolean;
	
	if form.myProxyObject = null then
		if form.mode = form.Mode_Add then
			create form.myProxyObject as CM_WeighAuthority transient;
		else
			app.raiseUnexpectedProgramError(class.name, method.name, 'Proxy object is null for update');
			return false;
		endif;
	endif;
	
	pxyWeighAuth := form.myProxyObject.CM_WeighAuthority;
	pxyWeighAuth.setProxy(authName, certName, addr1, addr2, addr3, email1, email2, phone1, phone2, solas, notAvail);
	
	create allAuthTerminals transient;
	foreach row in dataTable.fixedRows + 1 to dataTable.rows do
		if dataTable.accessCell(row, 1).inputType = Table.InputType_CheckBox then
			if dataTable.accessedCell.text = "1" then
				terminal := dataTable.accessRow(row).itemObject. CM_Terminal;
				authTerm := pxyWeighAuth.allWeighAuthTerminals[terminal];
				if authTerm = null then
					create authTerm transient;
				endif;
				authTerm.setForCreate(dataTable.accessCell(row, 2).text = "1", pxyWeighAuth, terminal);
				allAuthTerminals.add(authTerm);
			endif;
		endif;
	endforeach;
	
	if form.mode = form.Mode_Add then
		app.myTrxCA.trxCreateWeighAuthority(pxyWeighAuth, form.myCurrentObject, allAuthTerminals, app.myPassport);
	elseif form.mode = form.Mode_Update then
		app.myTrxUA.trxUpdateWeighAuthority(pxyWeighAuth, allAuthTerminals, app.myPassport);
	else
		app.raiseUnexpectedProgramError(class.name, method.name, '  Invalid mode (' &amp; form.mode.String &amp; ')');
		return false;
	endif;
	
	return app.myPassport.trxCompletedOK;

epilog
	if allAuthTerminals &lt;&gt; null then
		allAuthTerminals.purge;
	endif;
	delete allAuthTerminals;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doTblData1Click" id="c8be83ef-443b-454c-afdc-6a7f26d41282">
        <source>doTblData1Click();
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 01/08/2017	jlgdap1		Initial creation TFS 4492 SNO VERMAS Changes
//
vars
	table : CM_DataTable;
	row, col : Integer;

begin
	inheritMethod();
	
	table := self.myForm.tblData1;
	row := table.row;
	col := table.column;
	if col = 1 and table.accessCell(row, col).text = "0" then
		table.accessCell(row, 2).text := "0";
	elseif col = 2 and table.accessCell(row, 1).text = "0" then
		table.accessCell(row, 1).text := "1";
	endif;

epilog

end;</source>
    </JadeMethod>
