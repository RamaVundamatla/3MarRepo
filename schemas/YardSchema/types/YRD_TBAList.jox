    <JadeMethod name="doMnuUnassignTBAClick" id="9351de85-c31d-4cb2-b294-980abfc69f7a">
        <updating/>
        <source>doMnuUnassignTBAClick() updating;
/*
Purpose:			
Date		Who		Reason
25 March 2014	cnwab1	Initial creation
*/

vars
	theTI : CM_TrackedItem;
	theRow : Integer;
	table : CM_DataTable;
	theReturn: Integer;
begin
	table := self.tblData;
	if table.row &lt;= table.fixedRows then
		return;
	endif;
	
	theTI := table.accessRow(table.row).itemObject.CM_TrackedItem;
	if theTI = null then
		return;
	endif;

// TFS 45590	if theTI.myMatchedTBA = null then // PAR 35574
	if theTI.myMatchedActual = null then // PAR 35574
		return;
	endif;
	
// TFS 45590	if app.msgBox("Unassign '" &amp; theTI.id &amp; "' from matched item '" &amp; theTI.myMatchedTBA.id &amp;"' ?", "Confirm TBA Unassign", MsgBox_OK_Cancel) = MsgBox_Retry_Cancel then // PAR 35574
	if app.msgBox("Unassign '" &amp; theTI.id &amp; "' from matched item '" &amp; theTI.myMatchedActual.id &amp;"' ?", "Confirm TBA Unassign", MsgBox_OK_Cancel) = MsgBox_Retry_Cancel then // PAR 35574
		return;
	endif;
		
	while true do
		app.myTrxUA.trxUpdateUnassignTBA(theTI, app.myPassport);
		if app.myPassport.trxCompletedOK then
			// Clear errors/warnings from form and err/warnings window
			self.clearErrorWarnings();
			global.beep;
			break;
		else
			theReturn := app.showErrorWarningDialog("Unassign TBA", app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   theReturn = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
			return;
		endif;
		break;
	endwhile;


	
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doNotableClear" id="8e0303e7-7594-4506-b6fa-08f08bfbdb52">
        <source>doNotableClear();
// ---------------------------------------------------------------------------
// Created:		23 February 2010 cnwjo3
//
// Purpose:		par 21915.  Each form should implement doNotableClear without an inheritMethod();
//
vars
	removedNotification : Integer;
	anObject : Object;
begin

	foreach anObject in self.allNotableObjects do
		if anObject.isKindOf(CM_TrackedItem) then
			endNotification(anObject, Object_Update_Event);
			endNotification(anObject, Object_Delete_Event);
			removedNotification := removedNotification + 1;
		endif;
	endforeach;

	validateNotificationRemoval(removedNotification,self.allNotableObjects.size);
	
	self.allNotableObjects.clear;
end;</source>
    </JadeMethod>
    <JadeMethod name="doPrint" id="0fa1bbc7-93ef-47bf-8847-29d5cfdc35cb">
        <source>doPrint();

vars

	gtpRateTable:        CM_GenericTablePrint;
	now:                 TimeStamp;
	hdrStr				: String;
	rateTable : Table;
	tmpJadeReport  : JadeReport;
begin
	now := self.systemToLocalTime(app.actualTimeServer());	// 6/5/16 cnwmp6 TFS 488 - Multi timezone support
	rateTable := self.tblData;
	
	app.mousePointer := MP_HOURGLASS;
	app.printer.suppressDialog := true;

	create gtpRateTable;
	app.printer.setMargins(Print_Landscape,0,0,10,10);


	// setup header information

	// set header
	gtpRateTable.frHeader.width := app.printer.pageWidth;
	hdrStr := self.caption;

	gtpRateTable.setHeaders(hdrStr, null);
	create tmpJadeReport transient;
	tmpJadeReport.description := self.caption;
	app.printer.setReport(tmpJadeReport);

	app.printer.setHeader(gtpRateTable.frHeader);

	// set footer
	gtpRateTable.frFooter.width := app.printer.pageWidth;
	gtpRateTable.lblTheUser.caption := app.getMyUserCode;
	gtpRateTable.lblTheDatePrinted.caption := now.String;
	app.printer.setFooter(gtpRateTable.frFooter);

	gtpRateTable.printTable(tblData, true, null);


epilog
	app.printer.close;
	app.printPreview(tmpJadeReport, true);
	delete gtpRateTable;
	app.mousePointer := MP_DEFAULT;



end;</source>
    </JadeMethod>
    <JadeMethod name="doQuery" id="edcb9ed2-9d02-45f5-8b55-b4de89baf016">
        <updating/>
        <source>doQuery() updating;
// ---------------------------------------------------------------------------
// Created:		July 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	tbl						: CM_DataTable;
	ls						: Boolean;	
begin
	
	self.mousePointer := Window.MousePointer_HourGlass;
	app.cmsBeginLoad(ls);

	self.tblInfo.rows := self.tblInfo.fixedRows;
	self.tblData.rows := self.tblData.fixedRows;

	tbl := self.tblData;
	self.doNotableClear();
	
	self.displayTable();
	
	self.frmQuery.visible := (self.tblData.rows = self.tblData.fixedRows); // TFS 45590
	
epilog
	app.cmsEndLoad(ls);	
	self.mousePointer := Window.MousePointer_Default;
end;</source>
    </JadeMethod>
    <JadeMethod name="doRefresh" id="adea80a7-906f-4ecf-ac4f-7247761824ba">
