    <JadeMethod name="doTblDataClick" id="b258011b-e1c4-44d9-94b5-e1ca92d14f7a">
        <source>doTblDataClick();
/*
Purpose:			

Date		Who		Reason
29 November 2023	navab1	CR 61268
*/
vars
	dataContainer : CM_DataContainer;
	rateEntriesMaintForm : INV_ContractRateEntriesMaint;
	rateEntryDates : CMIF_ContractRateEntryDates; //25/10/2023 navmv20 CR 60503 Task 60505
begin
	rateEntryDates := self.tblData.accessRow(self.tblData.row).itemObject.CMIF_ContractRateEntryDates;
	if rateEntryDates = null then
		app.msgBox(app.getErrorString(Record_selected), app.getErrorString(Warning),MsgBox_OK_Only);
		return;
	endif;

	if self.myRateEntryForm &lt;&gt; null then
		rateEntriesMaintForm := self.myRateEntryForm; 
		rateEntriesMaintForm.updateMode := true;
		rateEntriesMaintForm.setCMIFRateEntryDates(rateEntryDates);
		rateEntriesMaintForm.setInvoiceContractRate(self.myInvoiceContractRate);
		rateEntriesMaintForm.setMyCurrentBank(self.myCurrentBank);
		rateEntriesMaintForm.myContractDetail := self.myContractDetails;
		rateEntriesMaintForm.myService := self.myInvoiceContractRate.myService;
		rateEntriesMaintForm.myCalculationType := self.myInvoiceContractRate.myCalculationType; // ### TFS CR 61579 TASK 62453 12FEB2024 NAVAB1
		rateEntriesMaintForm.setFromTS(rateEntryDates.fromTS);
		rateEntriesMaintForm.setToTS(rateEntryDates.toTS);
		rateEntriesMaintForm.populateRateEntryDT();
		rateEntriesMaintForm.tblDisplayRow();
	endif;
	
	// ### TFS CR 61268 29NOV2023 NAVAB1
	create dataContainer transient;
	dataContainer.headerColour := self.colorHeadingColumn;
	dataContainer.valueColour := self.colorValueColumn;
	
	rateEntryDates.getExtraInfo(dataContainer);
	
	if dataContainer &lt;&gt; null then
		self.showExtraInformation(dataContainer, self.tblInfo, true, false, 4, 0, 0, 0, 1);
		self.doResizeColumnWidths(self.tblInfo, true);
	endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doTblInvRateContMenu" id="3c9acf2c-f87c-44da-b00b-1cd37b9383d0">
        <updating/>
        <source>doTblInvRateContMenu(cntrl: Table input; conwin: Window input; mouse: Boolean; x: Integer; y: Integer):Boolean updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 Feb 2023 navtnr20	TFS CR 55646 Task 55665: UI - Contract Details
25 October 2023 navmv20 CR 60503 Task 60505: UI - Contract Rate Entry UI Changes
*/

vars
	canEdit		: Boolean;
	x1,
	y1			: Real;
begin
	x1 := x;
	y1 := y;
	if (not mouse) then
	    x1 := 1;
	    y1 := 1;
	endif;
	conwin.windowToScreen(x1, y1);
	self.screenToWindow(x1, y1);
	//self.mnuColumnOrganiser.visible := true; //25/10/2023 navmv20 CR 60503 Task 60505
	//self.mnuColumnOrganiser.userObject := self.tblData; //25/10/2023 navmv20 CR 60503 Task 60505
	if app.isAllowedToInspect then
		self.mnuInspectObject.visible := true;
	else
		self.mnuInspectObject.visible := false;	
	endif;	
	self.popupMenu(self.mnuContextMenu, x1.Integer, y1.Integer);
	return false;

end;</source>
        <access>protected</access>
        <Parameter name="cntrl" type="Table" usage="input"/>
        <Parameter name="conwin" type="Window" usage="input"/>
        <Parameter name="mouse" type="Boolean"/>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getXMLSettingsForSave" id="e5862f3c-b071-4d20-ad81-8868c30f7be8">
