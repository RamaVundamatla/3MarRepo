    <JadeMethod name="hasItems" id="8bc70af3-302f-4672-a80e-d79211b44e8c">
        <source>hasItems(): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
01 November 2024	navcs2	MTN-33047 EUP - NTO-1000 - EUP - Additional Data Fields in EDI Operations	


*/

vars
	ti	: Object;
	objSet	: CM_ObjectArray;
begin
	create objSet transient;
	
	self.getAllEDITrackedItems(objSet);
	
	foreach ti in objSet do
		if (ti.CM_EDITrackedItem.isRequestDetail and ti.CM_EDIRequestDetailTI.ids &lt;&gt; null) then
			return true;
		endif;
	endforeach;
	
	return false;
epilog
	delete objSet;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
