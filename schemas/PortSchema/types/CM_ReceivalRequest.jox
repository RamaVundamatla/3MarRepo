    <JadeMethod name="getDisplayStringForAttribute" id="d0435d72-ccc7-4e47-9e8d-a74dbc752464">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
//18 February 2010	cnwdw1	
//
vars
	//ct  : CM_CargoType;
	receiveInfo : CM_ReceivalInfo;
	str : String;
	allStrs : String;
	totQtyLeft : Integer; 
begin
	if _attrName = ETRow_Id then
		
		//epr par 32675
	//	ct:= self.getCargoType;
	//	if ct &lt;&gt; null then
	//		return ct.abbreviation;
	//	endif;
	
		//04 Mar 2104	NDL	Par 33596
		if self.allReceivalInfo.isNotEmpty then
			foreach receiveInfo in self.allReceivalInfo do
				str := receiveInfo.getDisplayStringForRoadOps();
				if str = null then
					continue;
				endif;
				if allStrs &lt;&gt; null then
					allStrs := allStrs &amp; ",";
				endif;
				allStrs := allStrs &amp; str;
			endforeach;
			return allStrs;
		endif;
		
		return app.getErrorString(GeneralCargo);
		
	elseif _attrName = ETRow_TotalQuantity then	//05 Mar 2104	NDL	Par 33596
		if self.allReceivalInfo.isNotEmpty then
			foreach receiveInfo in self.allReceivalInfo do
				if receiveInfo.quantity = 0 then
					return app.getErrorString(Unknown);
				else
					totQtyLeft := totQtyLeft + receiveInfo.getTotQtyLeft();
				endif;
			endforeach;
			return totQtyLeft.asStringJMT;
		endif;
		
		return "1".asStringJMT;
	
	endif;
	
	return inheritMethod(_attrName, _short);

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getExtraInfo" id="b2a29630-c246-4c12-b37f-d95a4fd091ae">
        <source>getExtraInfo(_dataContainer: CM_DataContainer);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
25 February 2010	cnwjk3	ccms 1071

*/

vars
	block 				: CM_DataContainerBlock;
	receivalInfo		: CM_ReceivalRequestInfo;
	count,
	numReceivalInfos 	: Integer;
begin
	inheritMethod(_dataContainer);
	numReceivalInfos := self.allReceivalInfo.size();
	foreach receivalInfo in self.allReceivalInfo do
		count := count + 1;
		block := _dataContainer.addNewBlock;
		block.addNewItem(app.getErrorString(Receival_Information) &amp; "(" &amp; count.String &amp; " of " &amp; numReceivalInfos.String &amp; ")", DC_MoreInfo, 2, null);		
		receivalInfo.getExtraInfo(_dataContainer);
	endforeach;
	

epilog

end;</source>
        <Parameter name="_dataContainer" type="CM_DataContainer"/>
    </JadeMethod>
    <JadeMethod name="getOperatorCode" id="734e1f16-36d2-41bc-92eb-7241a7eafd4f">
        <source>getOperatorCode(): String;
//----------------------------------------------------------------------
// Created by 	cnwsh3
// Date 		16 March 2010
//
// Implemented version: JMT 7.8.1
// Date  		User  		Change
//----------------------------------------------------------------------
vars
	recInfo : CM_ReceivalInfo;
begin
	if self.allReceivalInfo.isNotEmpty() then
		recInfo := self.allReceivalInfo.first;
		
		if recInfo.myBooking &lt;&gt; null then
			return recInfo.myBooking.getOperatorCode();
		endif;
	endif;
	
	return inheritMethod();

epilog
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getQuantityForRequest" id="33ab3b33-c60c-4e11-9ac4-a48261282de7">
        <source>getQuantityForRequest(): Integer;
//----------------------------------------------------------------------
// Created by 	cnwsh3
// Date 		16 March 2010
//
// Implemented version: JMT 7.8.1
// Date  		User  		Change
// USED IN REPORT DESIGN.  DO NOT DELETE.
// 16/03/2010 	cnwsh3		MES 1019 PAR22675
// Need a way to return the quantity using the request.
//----------------------------------------------------------------------
vars
	recInfo : CM_ReceivalInfo;
	cnt 	: Integer;
begin
	if self.allReceivalInfo.isNotEmpty then
		foreach recInfo in self.allReceivalInfo do
			cnt := cnt + recInfo.getQuantity();
		endforeach;
		
		return cnt;
	endif;
	
	return inheritMethod();
	
epilog
end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getReceivedTIs" id="73fc938b-12b9-4ee0-b4b3-c93d32ff512e">
        <source>getReceivedTIs(_objs : CM_ObjectArray io);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
19 February 2010	cnwjk3	ccms 1071

*/

vars
	info : CM_ReceivalInfo;
begin
	if _objs = null then
		return;
	endif;
	
	foreach info in self.allReceivalInfo do
		info.allTrackedItems.copy(_objs);
	endforeach;
	
epilog

end;</source>
        <Parameter name="_objs" type="CM_ObjectArray" usage="io"/>
    </JadeMethod>
    <JadeMethod name="hasReceivedTIs" id="07a1a9cb-c3d9-40a5-816b-3c576763f3ca">
        <source>hasReceivedTIs() : Boolean;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
19 February 2010	cnwjk3	ccms 1071

*/

vars
	info : CM_ReceivalInfo;
begin
	foreach info in self.allReceivalInfo do
		if info.hasReceivedTIs() then
			return true;
		endif;
	endforeach;
	
	return false;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
