    <JadeMethod name="loadCombos" id="1d3ca853-ec52-4395-8e64-7aecbc10ada1">
        <source>loadCombos() protected;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05/08/2009	cnwjk3	Initial creation
23/08/2013	cnwdap1	PAR #32331 Added Colour
07/03/2016	cnwdap1	PAR #37606 Consignees not available for entry
02/10/2020  cnwma1  ChangeRequest 50112: ASPA - GCI Stevedores
02/05/2022	jlizm1	TFS 53084 GPHA revceival/release of tranship cargo
*/
vars
	imex		: CM_IMEXStatus;
	operator	: CM_Operator;
	allROBContainers : ObjectSet;
	obj			: Object;
	isoType		: CM_ISOType;								// PAR #37606
begin
	self.doBuildCargoTypes(self.cmbTiType);	
	// CargoTypes
	if self.isGeneralCargo() then
		self.doBuildCargoTypes(self.cmbType);
		
		if self.cmbPackTo.isHidden = false then
			create allROBContainers transient;
			self.myCurrentVehicleVisit.getAllReleaseContainerEntities(allROBContainers);
			foreach obj in allROBContainers do
				self.cmbPackTo.addItemObject(obj.CMGTE_Entity.getID, obj);
				
			endforeach;
		endif;
	endif;
	
	// Commodities
	self.cmbCommodity.listCollection(app.myRoot.allCommodities, true, 0);

	// ISO Types
	//self.cmbISOType.listCollection(app.myRoot.allISOTypes, true, 0);						// PAR #37606
	foreach isoType in app.myRoot.allISOTypes discreteLock do								// PAR #37606
		if isoType.isNotAvailableForEntry then												// PAR #37606
			continue;																		// PAR #37606
		endif;																				// PAR #37606
		self.cmbISOType.addItemObject(isoType.code &amp; Tab &amp; isoType.description, isoType);	// PAR #37606
	endforeach;																				// PAR #37606
	
	// ISO Groups
	self.cmbISOGroup.listCollection(app.myRoot.allISOTypeGroups, true, 0 );
	
	// IMEX Statuses
	//+++self.cmbImexStatus.listCollection(app.myRoot.allImexStatuses, true, 0);
	// 28029 Nov 2011 don't show tranship or remain on board
	foreach imex in app.myRoot.allImexStatuses where imex.code &lt;&gt; TI_IMEX_STATUS_TRANSHIP and
													 imex.code &lt;&gt; TI_IMEX_STATUS_REMAINONBOARD do
		cmbImexStatus.addItemObject(imex.description, imex);
	endforeach;
	
	if app.myRoot.allowTranshipInterModal then							// TFS 53084
		imex := app.myRoot.allImexStatuses[TI_IMEX_STATUS_TRANSHIP];	// TFS 53084
		if imex &lt;&gt; null then											// TFS 53084
			cmbImexStatus.addItemObject(imex.description, imex);		// TFS 53084
		endif;
	endif;

	// Sub-terminal
	self.myAssistant.comboBoxSubTerminal(cmbSubTerminal.getEmbeddedControl.ComboBox, null, self.myTerminal);
	
	// Availability Gradessss	
	operator := self.cmbOperatorCode.listObject.CM_Operator;
	self.loadMTGradesForOperator(operator);
	
	// Consignee &amp; Update Consignee
	//epr TFS 6535 29/8/17 
	self.myAssistant.comboBoxConsignor(cmbConsignee.getEmbeddedControl.ComboBox,null,CONSIGNEE);
	self.myAssistant.comboBoxConsignor(cmbUpdateConsign.getEmbeddedControl.ComboBox,null,CONSIGNEE);
	
	// Destination Terminal
	self.myAssistant.comboBoxDestTerminal(self.cmbDestTerminal.getEmbeddedControl().CMUI_FieldComboBoxControl, self.myTerminal, null);

	// Delivery Reasons
	self.doBuildDeliveryReasons(self.cmbDelReason.getEmbeddedControl().CMUI_FieldComboBoxControl);

	// Voyage
	self.myAssistant.comboBoxVoyageCurrent(	cmbVoyageCode,
											null,
											true,
											false,
											false,
											true,
											true,
											false,
											true,
											false,
											true);
	
	// Source Terminal Area  par 22634 change from text box
	self.myAssistant.comboBoxSourceArea2(self.cmbTermArea.getEmbeddedControl.ComboBox, null, true, false);

	//Release Jobs
	self.myAssistant.comboBoxReleaseJobs(self.cmbReleaseJobs.getEmbeddedControl.ComboBox, self.myCarrier);

	// Colour												// PAR #32331
	self.myAssistant.listTableColour(self.lstColourList);	// PAR #32331
	self.myAssistant.comboBoxStevedore(self.cmbStevedore.getEmbeddedControl.ComboBox,null); //02.10.2020 cnwma1 TFS #50112
epilog
	delete allROBContainers;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="loadMTGradesForOperator" id="b267835f-13ff-451f-98df-7fe30845d635">
        <source>loadMTGradesForOperator(_operator : CM_Operator) protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
07 August 2009	cnwjk3	Initial creation

*/

vars

begin
	self.myAssistant.listTableMTGrade(self.lstMTGrade, _operator, null); 
epilog

end;</source>
