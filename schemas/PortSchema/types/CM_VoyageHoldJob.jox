    <JadeMethod name="processExtraWles" id="9dbf59a0-b524-4e34-834c-609c96cedeb8">
        <updating/>
        <source>processExtraWles( allWLEs : CM_WLEArray ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 June 2017	cnwndl1	Initial creation	TFS 4948

*/

vars

	pxyWle : CM_WorkListEntry;
	ti : CM_TrackedItem;
	request : CM_HoldRequest;
	newWle : CM_WorkListEntry;

begin

	foreach pxyWle in allWLEs do
	
		ti := pxyWle.myTrackedItem;
									
		// create a request
		create request;
		request.setForUpdateVoyageHoldJob(self);
		// attach the request to this job
		request.setJob(self);
		// set move type (needed here so WLE gets things correct	
		if ti.getTransitStatus = TI_TransitStatusSOB then			
			request.setMoveType(SOB_MOVETYPE);						
		elseif ti.getTransitStatus = TI_TransitStatusDLR then		
			request.setMoveType(DLR_MOVETYPE);						
		endif;														
		// create a WLE
		newWle := request.createWLEForTI(ti);
		newWle.setQuantity( pxyWle.quantity );		
		newWle.setWeight( pxyWle.weight );				
														
		// and attach the TI to me
		self.updateTICollections(ti, null);
		
	endforeach;

epilog

end;</source>
        <Parameter name="allWLEs" type="CM_WLEArray"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="ba52bf73-0e68-4b0c-81c7-265b1f6e544a">
        <source>pxyCreateUpdateProxy(): SelfType;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 31/01/2017	cnwdap1		Initial creation TFS 3219 LNX Voyage Operations Enhancements
// 07/03/2017	cnwdap1		TFS 3516 LNX Hold Planning Quantity
//
vars
	pxyHoldJob : CM_VoyageHoldJob;
	completedOK : Boolean;

begin
	pxyHoldJob := inheritMethod();
	
	pxyHoldJob.myShift := self.myShift;
	self.allReceiveTrackedItems.copy(pxyHoldJob.allReceiveTrackedItems);		// TFS 3516
	self.allReleaseTrackeditems.copy(pxyHoldJob.allReleaseTrackeditems);		// TFS 3516
	
	completedOK := true;
	return pxyHoldJob;
	
epilog
	if not completedOK then
		delete pxyHoldJob;
	endif;
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="removeTIsFromJob" id="c46050ca-b5cb-41dd-999f-ab861295eb9b">
        <updating/>
        <source>removeTIsFromJob(_tisToRemove : CM_TISet) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 23/01/2017	cnwdap1		Initial creation TFS 3219 LNX Voyage Operations Enhancements
// 21/02/2017	cnwdap1		TFS 3489 LNX DLR/SOB
//
vars
	ti : CM_TrackedItem;

begin
	foreach ti in _tisToRemove do
		if self.isDischarge and self.allReleaseTrackeditems.includes(ti) then
			self.allReleaseTrackeditems.remove(ti);
		elseif not self.isDischarge and self.allReceiveTrackedItems.includes(ti) then
			self.allReceiveTrackedItems.remove(ti);
		endif;
		
		if ti.getTransitStatus = TI_TransitStatusDLR or ti.getTransitStatus = TI_TransitStatusSOB then	// TFS 3489
			ti.setTransitStatus(TI_TransitStatusNull, true, app.myPassport);							// TFS 3489
		endif;																							// TFS 3489
	endforeach;
			
epilog

end;</source>
        <Parameter name="_tisToRemove" type="CM_TISet"/>
    </JadeMethod>
    <JadeMethod name="setDefaultLoadLanes" id="cc3b3ffa-566c-45ae-80f4-6587cbef51c4">
        <updating/>
        <source>setDefaultLoadLanes(_startFromLC: CM_BlockController; _startFromWLE: CM_VoyageWLE) updating;
//
// Purpose:			
//
// Parameters:			
