    <JadeMethod name="addObjectsToTable" id="e5ffaa9e-a2cc-4dac-91ab-61bd25c91747">
        <updating/>
        <source>addObjectsToTable(_numItems: Integer io) updating;
/*

Purpose:   		Think this is where we do the search 	
					once we find an object call self.addObjectToTable
					that calls tblDataDisplayRow


Return Value:		


Date		Who		Reason
13 September 2007	cnwer1	Initial creation - PAR#xxxx

*/
vars
	allFaults 	: CM_FaultsByReportedTS;
	fault : CM_Fault;
	iter : Iterator;
	breakOut : Boolean;
begin

	allFaults:=self.getCollectionForSearch;
	if allFaults = null or allFaults.size = 0 then
		return;
	endif;
	
	iter := allFaults.createIterator;
	if self.filterFromTS &lt;&gt; null then
		allFaults.startKeyGeq(self.filterFromTS,iter);	
	endif;
	

	while iter.next(fault) do
		
		if self.filterToTS &lt;&gt; null  and self.filterToTS &lt; fault.reportedTS then
			break;
		endif;
		
		
		if self.includeObject(fault, app.myPassport) then
			self.addObjectToTable(fault, _numItems, breakOut);
			
			if breakOut then
				break;
			endif;
		endif;
		
	endwhile;
	
epilog
	delete iter;
end;</source>
        <Parameter name="_numItems" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="addToolbarControls" id="4afdea61-992b-40f4-883d-9ddafe382617">
        <source>addToolbarControls()  protected;
/*

Purpose:			


Return Value:		


Date		Who		Reason
14 September 2007	cnwer1	Initial creation - PAR#xxxx

*/
vars
toolbar			: CMUI_Toolbar;
	showCaptions	: Boolean;

begin
	inheritMethod();
	toolbar := self.frmToolbar;	
	/* PAR 15966
	toolbar.addButton(self.btnPrintTV, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnShowSearchTV, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnNewTV, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnEditTV, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnDeleteTV, CMUI_Toolbar.Control_Alignment_Left);
	*/
	self.btnSaveBase.visible := false;
	showCaptions := toolbar.showCaptions;
	
	//=======================================
	// now setup searchToolbar
	//=======================================
	toolbar := self.frmSearchToolbar;

	toolbar.showCaptions := showCaptions;
// PAR 15966
//	toolbar.addButton(self.btnSearchTV, CMUI_Toolbar.Control_Alignment_Left);
//	toolbar.addButton(self.btnResetSearchTV, CMUI_Toolbar.Control_Alignment_Left);
//	toolbar.addButton(self.btnCloseSearchTV, CMUI_Toolbar.Control_Alignment_Left);
	
	toolbar.positionToolbarControls();
	toolbar.visible := true;


epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="btnEditTV_click" id="2594192f-ee91-4964-9e22-835502fab83b">
        <updating/>
        <source>btnEditTV_click(btn: Button input) updating;
/*

Purpose:	since i am going to open a new form rather than using the thumbnail ent table
			i have reimplemented this method 


Return Value:		


Date		Who		Reason
14 September 2007	cnwer1	Initial creation - PAR#xxxx

*/
vars
	faultForm : SOP_FaultMaintForm;
	fault : CM_Fault;
begin
//	inheritMethod(btn); // do not do this as the updating is on a seperate form

	if self.myCurrentObject = null then
		return;
	endif;
	
	// PAR 15966
	if self.multiSelect &lt;&gt; CM_BaseTable.MultiSelect_None 
	and self.tblData.allSelectedObjects.size &gt; 1 then
	   	if (not self.allowMultiSelectEdit) then
	   		app.msgBox('You must select only ONE item to edit', 'Error', MsgBox_OK_Only + MsgBox_Information_Icon);
	   		return;
	   	endif;
	endif;
	
	fault:= self.myCurrentObject.CM_Fault;

	
	faultForm	:= app.loadForm(SOP_FaultMaintForm, self.myAssistant.class, false, false ,true ,self.myTerminal, null).SOP_FaultMaintForm;
	if faultForm = null then
		return;
	endif;
	
	faultForm.init(self.myTerminal,fault);
	faultForm.show;
epilog

end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="btnNewTV_click" id="1c14cda4-1d44-4318-b96e-d10322219b6e">
