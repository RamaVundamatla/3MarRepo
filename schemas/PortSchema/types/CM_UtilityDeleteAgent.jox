    <JadeMethod name="utlDeleteWagons" id="cb1bd010-70d7-42d1-9601-145548979a13">
        <source>utlDeleteWagons(_allWagons:CM_WagonSet input;
				_isValidate : Boolean;
				_isTrainConsist : Boolean;
				_isInitialise : Boolean;
				_passport : CM_Passport input);
// --------------------------------------------------------------------------------
// Created:		28 July 2010 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	wagonObj	: CM_Wagon;
	
begin
	if _isInitialise then
		self.initialiseActivity();
	endif;
	
	app.setContinueCMExceptions(true);
	
	foreach wagonObj in _allWagons do
		app.myValDA.valWagon(wagonObj, (_isValidate and _isTrainConsist));
	endforeach;
	
	if (not self.checkValidationWithPassport(_passport)) or _isValidate then // Show any Errors and Warnings in a list
		return;
	endif;

	app.setContinueCMExceptions(false);
	
	foreach wagonObj in _allWagons do
		self.myDeleteAuditAgent.audDeleteGeneric(wagonObj);
		wagonObj.erase(NORMAL_ERASE);
	endforeach;
end;</source>
        <Parameter name="_allWagons" type="CM_WagonSet" usage="input"/>
        <Parameter name="_isValidate" type="Boolean"/>
        <Parameter name="_isTrainConsist" type="Boolean"/>
        <Parameter name="_isInitialise" type="Boolean"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
