    <JadeMethod name="setForCreate" id="189f3bcd-a7f5-4521-8768-4716a04d7612">
        <updating/>
        <source>setForCreate(_ftpEntity : CM_FTPEntity) updating;
//
// CCMS 1143 cnwrs1 10 Aug 2010
//
vars

begin
	_ftpEntity.raiseExceptionIfNotTransient(method);
	
	self.setForUpdate(_ftpEntity);
	self.myRoot := app.myRoot;
end;
</source>
        <Parameter name="_ftpEntity" type="CM_FTPEntity"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="6cbdab52-9d3d-4b12-8365-4572fcd245a0">
        <updating/>
        <source>setForUpdate(_ftpEntity : CM_FTPEntity) updating;
//
// CCMS 1143 cnwrs1 10 Aug 2010
//
//11 Jun 2014	cnwrs1	Par 34062 add useProxy to FTP Get/Put
//20 Aug 2015	cnwrs1	Par 36795 enable a file to be read and deleted in one session
//24 Aug 2015	cnwrs1	Par 36815 enable FTP get to continue after a failed file delete by saving off the fileNames
//
vars

begin
	self.destinationDirectory := _ftpEntity.destinationDirectory;
	self.id := _ftpEntity.id;
	self.isPassive := _ftpEntity.isPassive;
	self.useProxy := _ftpEntity.useProxy;
	self.mode := _ftpEntity.mode;
	self.password := _ftpEntity.password;
	self.serverGMTBias := _ftpEntity.serverGMTBias;
	self.serverName := _ftpEntity.serverName;
	self.serverType := _ftpEntity.serverType;
	self.sourceDirectory := _ftpEntity.sourceDirectory;
	self.userId := _ftpEntity.userId;
	self.setSingleFileCopy(_ftpEntity.getSingleFileCopy);
	self.setSaveUndeletedFilesList(_ftpEntity.getSaveUndeletedFilesList);
end;
</source>
        <Parameter name="_ftpEntity" type="CM_FTPEntity"/>
    </JadeMethod>
    <JadeMethod name="setPassword" id="e0fbe3ea-3780-4f9d-8072-d968ea04de5c">
        <updating/>
        <source>setPassword(_password : String) updating;
//
//22 May 2013	cnwrs1	Par 31483 Ftp connect not always connecting
// 09 Dec 2019	jlgrs1	TFS 46528 remove password if it is only blank characters
//
vars

begin
	if _password.trimBlanks = null then
		self.password := null;
	else
		self.password := _password;
	endif;
end;
</source>
        <Parameter name="_password" type="String"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="474af8d8-9bf1-4e7f-8875-c44184785c6f">
        <updating/>
        <source>setProxy(_destinationDirectory, _id, _password, _serverName, _sourceDirectory, _userId : String;
			_isPassive, _useProxy : Boolean;
			_mode, _serverGMTBias, _serverType, _port, _timeOut : Integer; 
			_singleFileCopy, _saveUndeletedFilesList : Boolean; _passPhrase, _privateKey, _publicKey : String) updating;
//
// CCMS 1143 cnwrs1 10 Aug 2010
//
//11 Jun 2014	cnwrs1	Par 34062 add useProxy to FTP Get/Put
//20 Aug 2015	cnwrs1	Par 36795 enable a file to be read and deleted in one session
//24 Aug 2015	cnwrs1	Par 36815 enable FTP get to continue after a failed file delete by saving off the fileNames
// 17 Sep 2019	jlgrs1	TFS 46087 JMT implement SFTP.
//
vars

begin
	self.destinationDirectory := _destinationDirectory;
	self.id := _id;
	self.isPassive := _isPassive;
	self.useProxy := _useProxy;
	self.mode := _mode;
	self.password := _password;
	self.serverGMTBias := _serverGMTBias;
	self.serverName := _serverName;
	self.serverType := _serverType;
	self.sourceDirectory := _sourceDirectory;
	self.userId := _userId;
	self.setSingleFileCopy(_singleFileCopy);
	self.setSaveUndeletedFilesList(_saveUndeletedFilesList);
end;
</source>
        <Parameter name="_destinationDirectory" type="String"/>
        <Parameter name="_id" type="String"/>
        <Parameter name="_password" type="String"/>
