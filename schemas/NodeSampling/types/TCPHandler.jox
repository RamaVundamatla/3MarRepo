    <JadeMethod name="delClassAndMethodDescriptions" id="ca02a0de-3c98-435e-839d-e50dc1b21592">
        <updating/>
        <source>delClassAndMethodDescriptions(_environment : Environments io) updating;

vars
	count      : Integer;
	result     : Integer;
	className  : ClassNames;
	methodName : MethodNames;
begin

	result := app.msgBox("Deleting '" &amp; _environment.name &amp; "'     " &amp; CrLf &amp;
	                     '  ' &amp; _environment.allClassnames.size.String  &amp; ' Class names' &amp; CrLf &amp;
	                     '  ' &amp; _environment.allMethodnames.size.String &amp; ' Method names', 'Warning', MsgBox_OK_Cancel + MsgBox_Exclamation_Mark_Icon);
	app.mousePointer := Window.MousePointer_HourGlass;
	if result = MsgBox_Return_OK then
		
		beginTransaction;
		_environment.state := Environments.State_Deleting;
		foreach className in _environment.allClassnames do
			delete className;
			count := count + 1;
			if count mod 5000 = 0 then
				commitTransaction;
				beginTransaction;
			endif;
		endforeach;
		commitTransaction;
		count := 0;
		beginTransaction;
		foreach methodName in _environment.allMethodnames do
			delete methodName;
			count := count + 1;
			if count mod 5000 = 0 then
				commitTransaction;
				beginTransaction;
			endif;
		endforeach;
		delete _environment;
		commitTransaction;
	endif;

epilog
	app.mousePointer := Window.MousePointer_Default;
end;</source>
        <Parameter name="_environment" type="Environments" usage="io"/>
    </JadeMethod>
    <JadeMethod name="getClassDescription" id="190cbcb1-5c82-42c2-9e0d-953ae2c82aea">
        <updating/>
        <source>getClassDescription(v_environment : Environments; sampleObject : SampleObjects) : String updating;
constants

vars
	number    : Integer;
	pnumber   : Integer;
	aClass    : ClassNames;
	classname : String;
	oid       : String;
begin
	number  := sampleObject.classnumber;
	aClass  := v_environment.allClassnames [ number ];

	if aClass = null then 
		if number &gt; 1279 and number &lt; 2048 then
			number := number - 1279;
			aClass := v_environment.allClassnames [ number ];
		endif;
	endif;
	if aClass &lt;&gt; null then
		classname := aClass.name;
	else
		pnumber := sampleObject.parClassnumber;
		aClass  := v_environment.allClassnames [ pnumber ];
		if aClass = null then 
			if pnumber &gt; 1279 and pnumber &lt; 2048 then
				pnumber := pnumber - 1279;
				aClass := v_environment.allClassnames [ pnumber ];
			endif;
		endif;
		if aClass &lt;&gt; null then
			classname := 'Blob/Slob (' &amp;  aClass.name &amp; ')';
		else
			classname := 'Blob/Slob';
		endif;
	endif;
	oid := ' ('  &amp; number.String;
	if sampleObject.instanceId &lt;&gt; 0 then
		oid := oid &amp; '.' &amp; sampleObject.instanceId.String;
		if sampleObject.parClassnumber &lt;&gt; 0 then //and sampleObject.classnumber = 0 then
			oid := oid &amp; '.' &amp; sampleObject.parClassnumber.String &amp; '.' &amp; sampleObject.subLevel.String &amp; '.' &amp; sampleObject.subId.String;
		endif;
	else
		if sampleObject.parClassnumber &lt;&gt; 0 then //and sampleObject.classnumber = 0 then
			oid := oid &amp; '.' &amp; sampleObject.parClassnumber.String &amp; '.' &amp; sampleObject.subLevel.String &amp; '.' &amp; sampleObject.subId.String;
		endif;	
	endif;
	oid := oid &amp; ')';
	classname := classname &amp; oid;
	if classname = 'Blob/Slob (0)' then
		return '*';
	endif;
	return classname;
epilog

end;</source>
        <Parameter name="v_environment" type="Environments"/>
        <Parameter name="sampleObject" type="SampleObjects"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getSystemInformationOnMachines" id="a678bc8b-96d7-4d95-beb1-b5b1c0843064">
        <source>getSystemInformationOnMachines() : String;
vars

	l_ProcessorsA   : String;
	l_ProcessorsC   : String;
	l_ProcessorsS   : String;
	l_SpeedA        : String;
	l_SpeedC        : String;
	l_SpeedS        : String;
	l_MemoryA       : String;
	l_MemoryC       : String;
	l_MemoryS       : String;
begin

	l_ProcessorsC := app.getNumberOfProcessorsOnClient.String;
	l_ProcessorsS := app.getNumberOfProcessorsOnServer.String;
	l_SpeedC      := app.getProcessorSpeedOnClient;
	l_SpeedS      := app.getProcessorSpeedOnServer;
	l_MemoryC     := app.getMachineMemorySizeOnClient.String &amp; ' MB';
	l_MemoryS     := app.getMachineMemorySizeOnServer.String &amp; ' MB';
	if process.isUsingThinClient then
		l_ProcessorsA := app.getNumberOfProcessorsOnAppSer.String;
		l_SpeedA      := app.getProcessorSpeedOnAppSer;
		l_MemoryA     := app.getMachineMemorySizeOnAppSer.String &amp; ' MB' ;
	else
		l_ProcessorsA := 'N/A';
		l_SpeedA      := 'N/A';
		l_MemoryA     := 'N/A';
	endif;
	return              'Client '     &amp; CrLf &amp;
	                    'Processors ' &amp; l_ProcessorsC &amp; CrLf &amp;
						'Speed '      &amp; l_SpeedC      &amp; CrLf &amp;
						'Memory '     &amp; l_MemoryC     &amp; CrLf &amp; CrLf &amp;
						'Application Server'  &amp; CrLf &amp;
	                    'Processors ' &amp; l_ProcessorsA &amp; CrLf &amp;
	                    'Speed '      &amp; l_SpeedA      &amp; CrLf &amp;
						'Memory '     &amp; l_MemoryA     &amp; CrLf &amp; CrLf &amp;
						'Server '     &amp; CrLf &amp;
	                    'Processors ' &amp; l_ProcessorsS &amp; CrLf &amp;
						'Speed '      &amp; l_SpeedS      &amp; CrLf &amp;
						'Memory '     &amp; l_MemoryS;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="listenContinuousCallback" id="f19becfd-ea93-48a6-9e02-bb45140af583">
        <updating/>
        <source>listenContinuousCallback(listener :	TcpIpConnection; newTcp : TcpIpConnection io) updating;

vars
	time : Time;
begin
	message := 'Connected ' &amp; listener.String &amp; ' ' &amp; listener.localIpAddress &amp; ' ' &amp; 
	           listener.localPort.String &amp; ', local' &amp; 
	           newTcp.String &amp; ' ' &amp; newTcp.localIpAddress &amp; ' ' &amp; newTcp.localPort.String &amp; ', remote ' &amp;
   	           newTcp.remoteIpAddress &amp; ' ' &amp; newTcp.remotePort.String;

	app.causeEvent(Statusline_Message, true, time.String &amp; ' ' &amp; message);
	if firstOpen = 0 then
		firstOpen := app.clock;
	else
		latestOpen := app.clock;
	endif;
	numberOfOpens := numberOfOpens + 1;
	v_tcpArray.add(newTcp);
	beginTransientTransaction;
	newTcp.fillReadBuffer := true;
	commitTransientTransaction;

	readUntilAsynchOneAddress(newTcp);
	
end;</source>
        <Parameter name="listener" type="TcpIpConnection"/>
        <Parameter name="newTcp" type="TcpIpConnection" usage="io"/>
    </JadeMethod>
    <JadeMethod name="loadClassAndMethodDescriptions" id="6a3f4a74-e8c1-4d96-8257-e7a3d60141e6">
        <updating/>
        <source>loadClassAndMethodDescriptions() updating;

vars
	v_file      : File;
	cmd         : CMDFileOpen;
	root        : Root;
	data        : String;
	count       : Integer;	
	environment : Environments;
	environ     : String;
	methods     : Boolean;

begin

	create cmd transient;
	create v_file transient;
	cmd.filter := ' | *.txt';

	if cmd.open = 0 then
	    v_file.fileName := cmd.fileName;
	else
		return;
	endif;
	v_file.kind 	:= File.Kind_Unknown_Text; // 3/3/16  cnwns1 PAR 36286 unicode version
	v_file.mode     := File.Mode_Input;

	if v_file.isAvailable = false then
		return;
	endif;

	root     := Root.firstInstance;
	if root = null then
		beginTransaction;
		create root;
		commitTransaction;
		app.myListener.v_root := root;
		app.myListener.loadingForm;
		app.myListener.enableControls;
	endif;

	environ := '&lt;enter system name - up to 30 characters&gt;';
	read environ;
	if environ.trimBlanks = null then
		return;
	endif;
	if environ.trimBlanks.length &gt; 30 then
		write 'Supplied name must be less than 31 characters';
		return;
	endif;
	environment := root.allEnvironments[environ];
	if environment = null then
		beginTransaction;

		create environment;
		environment.name   := environ;
		environment.myRoot := root;
		environment.state  := Environments.State_Loading;

		commitTransaction;
	endif;
	v_file.open;

	app.mousePointer := Window.MousePointer_HourGlass;
	beginTransaction;
	while not v_file.endOfFile do : outter 
		count.bump;
		if count mod 2000 = 0 then
			commitTransaction;
			beginTransaction;
		endif; 
		data  := v_file.readLine();
		if data.length &gt; 4 then
			if data[ 1 : 5 ] = '-----' then
				methods := true;
			endif;
		endif;
		if methods then
			setupMethodname(data, environment);
		else
			setupClassname(data, environment);
		endif;

	endwhile;

	environment.state := Environments.State_Loaded;
	commitTransaction;

	app.mousePointer := Window.MousePointer_Default;
epilog
	delete v_file;
	delete cmd;
end;</source>
    </JadeMethod>
    <JadeMethod name="loadInputFromFile" id="8ce0b020-92a1-4ff3-ab07-76a14534cb30">
        <updating/>
        <source>loadInputFromFile() updating;
//
//  Takes a file created by Node Sampling and loads it in as if we received it via TCPIP
//
vars
	v_file      : File;
	cmd         : CMDFileOpen;
	data        : String;

begin

	create cmd transient;
	create v_file transient;
	cmd.filter := ' | *.smp';

	if cmd.open = 0 then
	    v_file.fileName := cmd.fileName;
	else
		return;
	endif;
	
	v_file.mode     := File.Mode_Input;
	//v_file.kind     := File.Kind_ANSI;
	v_file.kind     := File.Kind_Unknown_Text;	// 29/2/16 cnwmp6 PAR 36286 unicode version
	
	if v_file.isAvailable = false then
		return;
	endif;

	v_file.open;

	app.mousePointer := Window.MousePointer_HourGlass;
	while not v_file.endOfFile do : outter 

		data  := v_file.readLine();
		processNodeSamplingInput(data);

	endwhile;
	app.mousePointer := Window.MousePointer_Default;
epilog
	delete v_file;
	delete cmd;
end;</source>
    </JadeMethod>
    <JadeMethod name="openConnection" id="622652cd-08ba-4af3-b91e-362d5b60fecd">
        <updating/>
        <source>openConnection() updating;
vars

begin

	listener := false;
	create connection transient;
	v_tcpArray.add(connection);
	message := 'Opening connection';

	connection.name := app.computerName;
	connection.port := 44444;
	connection.timeout := 10000;

	connection.open();
	write connection.timeout;
	message := 'Open - ' &amp; connection.String;

end;</source>
    </JadeMethod>
    <JadeMethod name="printOutput" id="730baccb-8afa-4c31-93ae-6ea8ec9ba65c">
        <updating/>
        <source>printOutput(_environment : Environments; _col : SampleObjectByCountDict; type : String; _limit : Integer) : Integer updating;
constants

vars

	sampleObject : SampleObjects;
	timestamp    : TimeStamp;
	tableData    : String;
	total        : Integer;
	cell         : JadeTableCell;
	row          : JadeTableRow;
	result       : Integer;
begin

	printForm.l_timestamp.caption := timestamp.String;

	cell := printForm.tbl_1_1.accessCell(1, 3);
	cell.alignment  := Table.Alignment_Center_Middle;
	cell.mergeCells := Table.MergeCells_Merge;
	cell.text       := '           Queued'; 
 	cell := printForm.tbl_1_1.accessCell(1, 4);

	printForm.tbl_1_1.row := 2;
	printForm.tbl_1_1.text := 'Class' &amp; Tab &amp; 'Count' &amp; Tab &amp; 'Count' &amp; Tab &amp; 'Time';
	app.printer.setHeader(printForm.fr_header);
	app.printer.setFooter(printForm.fr_footer);
	printForm.l_title.caption := type;

	row := printForm.tbl_Details.accessRow(1);
	row.fontBold := false;
	foreach  sampleObject in _col do
		total := total + sampleObject.count;
		//
		// Check to see if we have restricted the output 
		//
		if sampleObject.count &lt; _limit then
			break;
		endif;
		if sampleObject.type = Lock_Request then
			tableData := getClassDescription(_environment, sampleObject) &amp; Tab &amp; sampleObject.count.String &amp; Tab &amp; sampleObject.queuedCount.String &amp; Tab &amp; sampleObject.queuedTime.String;
		else
			tableData := getClassDescription(_environment, sampleObject) &amp; Tab &amp; sampleObject.count.String &amp; Tab &amp; '' &amp; Tab &amp; '';
		endif;
		printForm.tbl_Details.text := tableData;
		result := app.printer.print(printForm.fr_detail01);
		if result &lt;&gt; 0 then
			return result;
		endif;

	endforeach;

	row := printForm.tbl_Details.accessRow(1);
	row.fontBold := true;
	printForm.tbl_Details.text :=  ' Total ' &amp; type &amp; Tab &amp; total.String &amp; Tab &amp; ' ' &amp; Tab &amp; '';	
	result := app.printer.print(printForm.fr_detail01);
	if result &lt;&gt; 0 then
		return result;
	endif;
	return 0;
epilog

end;</source>
        <Parameter name="_environment" type="Environments"/>
        <Parameter name="_col" type="SampleObjectByCountDict"/>
        <Parameter name="type" type="String"/>
        <Parameter name="_limit" type="Integer"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="processBeginProcess" id="f672657c-d16c-4f98-a8e6-a4459204909e">
        <updating/>
        <source>processBeginProcess(_data : String) updating;

vars

begin

end;</source>
        <Parameter name="_data" type="String"/>
    </JadeMethod>
    <JadeMethod name="processCacheSnapshot" id="1b41f027-7156-4c66-b273-82cb0394e7d3">
        <updating/>
        <source>processCacheSnapshot(_data : String; _pos : Integer) updating;
//
//2 2 3 10889 680979 85954 350503 57963 0 0 2 6 1 85824 2 54482 7 0 0 0 1 73 1 0 4 1 167 0 1 0 0 0 0 8
//
vars

	sampleMessage : SampleMessages;
	nodeNumber    : Integer;
	ticks         : Integer64;
	processNumber : String;
	classname     : String;
	class         : Integer;
	instance      : Integer64;
	subLevel      : Integer;
	subId         : Integer;
	edition       : Integer;
	objectSize    : Integer;
	flag          : Integer;
	actualInstance: Integer64;
	methClass     : Integer;
	methInstId    : Integer;
	parClass      : Integer;
	cacheType     : Integer;
	bufferActivity: Integer;
	order         : Integer;
	hits          : Integer64;
	pos           : Integer;
	data          : String;
	output        : String;

begin 
	pos           := _pos;
	data          := _data;
	nodeNumber    := data.getToken(pos).Integer;
	processNumber := data.getToken(pos);
	ticks         := data.getToken(pos).Integer64; // clock ticks
	lastCPUTime   := data.getToken(pos).Integer64; // node cpu
	bypassTokens( 5, data, pos); // node ticks, process cpu, process ticks, process logical clocks, user number
	cacheType     := data.getToken(pos).Integer; // cache type 1 - persistent, 2 transient, 3 remote transient
	bufferActivity:= data.getToken(pos).Integer; // buffer activity
	order         := data.getToken(pos).Integer; // Order in LRU
	bypassTokens( 1, data, pos); // birth time,
	hits     	  := data.getToken(pos).Integer64; // Hits
	class         := data.getToken(pos).Integer; // Class ID
	class         := class.bitAnd(16383); // get rid of transient and shared transient bits
	instance      := data.getToken(pos).Integer64; // Instance ID
	parClass      := data.getToken(pos).Integer; // Parent Class ID
	parClass      := parClass.bitAnd(16383);     // get rid of transient and shared transient bits
	subLevel      := data.getToken(pos).Integer; // subLevel
	subId         := data.getToken(pos).Integer; // subId
	edition       := data.getToken(pos).Integer; // subLevel
	objectSize    := data.getToken(pos).Integer; // subId
	flag          := data.getToken(pos).Integer; // Flag
	//
	// 0 - empty, 6 - deleted
	//
	if flag = 0 or flag = 6 then
		return;
	endif;
	//
	// Temp fix for large instances
	//
	if instance &gt; Max_Integer then
		return;
	endif;
	
	v_sample.classnumber    := class;
	v_sample.instanceId     := instance.Integer;
	v_sample.parClassnumber := parClass;
	v_sample.subId          := subId;
	v_sample.subLevel       := subLevel;
	classname := getClassDescription(v_environment, v_sample);

//	app.myListener.tbl_cache.rows := app.myListener.tbl_cache.rows + 1;
//	app.myListener.tbl_cache.row := app.myListener.tbl_cache.rows;

	output := classname &amp; Tab &amp;  hits.String &amp; Tab &amp; edition.String &amp; Tab &amp; 
	          objectSize.String &amp; Tab &amp; flag.String &amp; Tab &amp; processNumber.String;

	create sampleMessage transient;
	sampleMessage.message := output;
	v_snapshotMessageSet.add(sampleMessage);
//	app.myListener.tbl_cache.text := output;
//	write classname &amp; ' hits - ' &amp; hits.String &amp; ', edition -  ' &amp; edition.String &amp; ', size - ' &amp; objectSize.String;
epilog

end;</source>
        <Parameter name="_data" type="String"/>
        <Parameter name="_pos" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="processCacheStatistics" id="a33956a3-8059-489f-a260-c7f9897fb756">
        <updating/>
        <source>processCacheStatistics(_data : String; _pos : Integer) updating;
//
// 1 1 1 1548664 8461 862404 410 68080 243 44 "Cache" 2 217 0 53 0 0 0 0 10000000 4415 7535415 5000000 0 19 19 0 0 18 2 481 2 16
//
vars
	nodeNumber    : Integer;
	misses        : Integer64;
	topLRUHits    : Integer64;
	createdBuffers: Integer64;
	cleanSwaps    : Integer64;
	dirtySwaps    : Integer64;
	resizes       : Integer64;
	cacheSize     : Integer64;
	totalBuffers  : Integer64;
	availableCache: Integer64;
	cacheType     : Integer;
	hits          : Integer64;
	pos           : Integer;
	data          : String;
	output        : String;
	type          : String;

begin 
	pos           := _pos;
	data          := _data;
	nodeNumber    := data.getToken(pos).Integer;
	bypassTokens( 9, data, pos); // node ticks, process cpu, process ticks, process logical clocks, user number
	cacheType     := data.getToken(pos).Integer; // cache type 1 - persistent, 2 transient, 3 remote transient
	hits     	  := data.getToken(pos).Integer64; // Hits
	misses        := data.getToken(pos).Integer64; // misses
	topLRUHits    := data.getToken(pos).Integer64; // 
	createdBuffers:= data.getToken(pos).Integer64; // creates
	cleanSwaps    := data.getToken(pos).Integer64; // clean swaps
	dirtySwaps    := data.getToken(pos).Integer64; // dirty swaps
	resizes       := data.getToken(pos).Integer64; // resizes
	cacheSize     := data.getToken(pos).Integer64; // total cache 
	totalBuffers  := data.getToken(pos).Integer64; // number of buffers
	availableCache:= data.getToken(pos).Integer64; // current available cache
	if cacheType = 1 then 
		type := 'Persistent';
	elseif cacheType = 2 then
		type := 'Transient';
	elseif cacheType = 3 then
		type := 'Remote Transient';
	endif;

	output        := type &amp; ' Cache - Statistics' &amp; CrLf &amp; CrLf &amp;
	                 'Node -            ' &amp; nodeNumber.String &amp; CrLf &amp;
                     'Hits -            ' &amp; hits.userNumberFormat($IntegerFormat) &amp; CrLf &amp;
	                 'Misses -          ' &amp; misses.userNumberFormat($IntegerFormat) &amp; CrLf &amp;
	                 'Top of LRU hits - ' &amp; topLRUHits.userNumberFormat($IntegerFormat) &amp; CrLf &amp;
	                 'Buffer creates  - ' &amp; createdBuffers.userNumberFormat($IntegerFormat) &amp; CrLf &amp;
	                 'Clean Swaps     - ' &amp; cleanSwaps.userNumberFormat($IntegerFormat) &amp; CrLf &amp;
	                 'Dirty Swaps     - ' &amp; dirtySwaps.userNumberFormat($IntegerFormat) &amp; CrLf &amp;
	                 'Resizes         - ' &amp; resizes.userNumberFormat($IntegerFormat) &amp; CrLf &amp;
	                 'Cache size      - ' &amp; cacheSize.userNumberFormat($IntegerFormat) &amp; CrLf &amp;
	                 'Total buffers   - ' &amp; totalBuffers.userNumberFormat($IntegerFormat) &amp; CrLf &amp;
	                 'Available cache - ' &amp; availableCache.userNumberFormat($IntegerFormat);
	app.myListener.tbx_cacheStats.text := output;
end;</source>
        <Parameter name="_data" type="String"/>
        <Parameter name="_pos" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="processCheckIfRequired" id="90728fa0-2570-48de-85c6-e9e0016fc5ae">
        <updating/>
        <source>processCheckIfRequired(_requestType : Integer; _mode : Integer64) : Boolean updating;
constants

vars

begin
	if not (_requestType = Get_Request            or _requestType = Lock_Request or 
	        _requestType = Unlock_Request         or _requestType = Put_Request or
	        _requestType = Note_Request           or _requestType = BeginTransaction_Request or
	        _requestType = EndTransaction_Request or _requestType = CauseEvent_Request or
	        _requestType = GetOid_Request         or _requestType = GetEdition_Request or
	        _requestType = RemoteMethod_Request   or _requestType = ReturnNotes_Request or
	        _requestType = BeginNotification_Request) then
		return false;
	endif;
	if _requestType = BeginTransaction_Request then
		return true;
	endif;
	if _requestType = CauseEvent_Request then
		return true;
	endif;
	if _requestType = ReturnNotes_Request then
		return true;
	endif;

	if _requestType = Get_Request and v_Get = false then
		return false;
	endif;
	if _requestType = Lock_Request and v_Lock = false then
		return false;
	endif;
	if _requestType = Unlock_Request and v_Unlock = false then
		return false;
	endif;
	if _requestType = Note_Request and v_Note = false then
		return false;
	endif;
	if _requestType = Put_Request then
		if _mode = Create_Put and v_Create = false then
			return false;
		endif;
		if _mode = Update_Put and v_Update = false then
			return false;
		endif;
		if _mode = Delete_Put and v_Delete = false then
			return false;
		endif;
	endif;
	if _requestType = GetEdition_Request and v_GetEdn = false then
		return false;
	endif;
	return true;
epilog

end;</source>
        <Parameter name="_requestType" type="Integer"/>
        <Parameter name="_mode" type="Integer64"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="processFileHeader" id="a46716f0-fbbc-42b6-be35-03c59d6ca8e1">
        <updating/>
        <source>processFileHeader(_data : String; _pos : Integer) updating;
//
// 0 0 1 CNWKC1A 6.1.02.15 2453565 77496612 -720 "Thu Jul 14 09:31:36 2005"
//
vars
	pos          : Integer;
	data         : String;
	token        : String;
	nodeType     : Integer;
	computerName : String;
	jadeVersion  : String;
begin
	pos          := _pos;
	data         := _data;
	token        := data.getToken(pos);         // node number
	nodeType     := data.getToken(pos).Integer; // node type 1 - daatbase server, 2 - app server etc
	computerName := data.getToken(pos); //
	jadeVersion  := data.getToken(pos); //
end;</source>
        <Parameter name="_data" type="String"/>
        <Parameter name="_pos" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="processGet" id="501758dc-ea63-455a-9b9a-2b84569131c9">
        <updating/>
        <source>processGet(class : Integer; instanceId : Integer; parClass : Integer; subLevel : Integer; subId : Integer; 
           waitTime : Integer64; volatility : Integer; lockKind : Integer) updating;

vars
	sampleObject : SampleObjects;
begin
	sampleObject  := app.myListener.v_sampleGets [ class , instanceId, parClass, subLevel, subId];

	if sampleObject = null then
		create sampleObject;
		sampleObject.classnumber    := class;
		sampleObject.instanceId     := instanceId;
		sampleObject.parClassnumber := parClass;
		sampleObject.subLevel       := subLevel;
		sampleObject.subId          := subId;
		sampleObject.type           := Get_Request;
		sampleObject.count          := 0;
		sampleObject.lockKind       := lockKind;
		sampleObject.volatility     := volatility;
		app.myListener.v_sampleGets.add(sampleObject);
	endif;
	if waitTime &lt;&gt; 0 then
		sampleObject.queuedCount.bump;
		sampleObject.queuedTime := sampleObject.queuedTime + waitTime.Integer;
	endif;
	sampleObject.count.bump;

end;</source>
        <Parameter name="class" type="Integer"/>
        <Parameter name="instanceId" type="Integer"/>
        <Parameter name="parClass" type="Integer"/>
        <Parameter name="subLevel" type="Integer"/>
        <Parameter name="subId" type="Integer"/>
        <Parameter name="waitTime" type="Integer64"/>
        <Parameter name="volatility" type="Integer"/>
        <Parameter name="lockKind" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="processGetEdition" id="aab06422-f97b-49cc-b491-d59e6296c662">
        <updating/>
        <source>processGetEdition(class : Integer; instanceId : Integer; parClass : Integer; subLevel : Integer; subId : Integer; waitTime : Integer64) updating;

vars
	sampleObject : SampleObjects;
begin
	sampleObject  := app.myListener.v_sampleGetEditions [ class , instanceId, parClass, subLevel, subId];

	if sampleObject = null then
		create sampleObject;
		sampleObject.classnumber    := class;
		sampleObject.instanceId     := instanceId;
		sampleObject.parClassnumber := parClass;
		sampleObject.subLevel       := subLevel;
		sampleObject.subId          := subId;
		sampleObject.type           := GetEdition_Request;
		sampleObject.count          := 0;
		app.myListener.v_sampleGetEditions.add(sampleObject);
	endif;

	sampleObject.count.bump;

end;</source>
        <Parameter name="class" type="Integer"/>
        <Parameter name="instanceId" type="Integer"/>
        <Parameter name="parClass" type="Integer"/>
        <Parameter name="subLevel" type="Integer"/>
