    <JadeMethod name="asJSONFormat" id="d000ccb9-ad66-4456-83da-794c9ed0d798">
        <source>asJSONFormat() : String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 Mar 2017	cnwkpd1	TFS 3369 - Push Events application

*/

vars

begin
	if not self.isValid then
		return null;
	endif;
	
	return self.formatAsHHMMSSmmm();

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="asMilliseconds" id="14bc5ff3-4377-4fcb-b8ac-360ab524c7fd">
        <source>asMilliseconds() : Integer;
// ---------------------------------------------------------------------------
// Created:     05 May 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin
	
	return (((self.hour * 3600) +
		   (self.minute * 60) +
		   (self.second)) * 1000) + self.milliSecond;

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="asStringForWebInterface" id="af4fb44c-e665-4be6-97b9-8f555d6b6acf">
        <source>asStringForWebInterface():String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26 October 2012	cnwndl1	Initial creation	Par 30622

				The RIA may be running on a server that uses a different LOCALE than
				the client.  Convert to known format at both ends.

*/

vars

begin

	return self.format("HH:mm:ss");

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
