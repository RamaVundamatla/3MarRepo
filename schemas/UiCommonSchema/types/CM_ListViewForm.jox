    <JadeMethod name="allowPrint" id="faa7e311-7f02-4974-8834-72a4a319f503">
        <methodInvocation>mapping</methodInvocation>
        <updating/>
        <source>allowPrint(set: Boolean; _value: Boolean io) mapping, updating;
// ---------------------------------------------------------------------------
// Created:     19 April 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	if set then
		if self.allowPrint &lt;&gt; _value then
			self.allowPrint := _value;
			if _value then
				btnPrintTV.visible := true;
			else
				btnPrintTV.visible := false;
			endif;
		endif;
	else
		_value := self.allowPrint;
	endif;
	
end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="Boolean" usage="io"/>
    </JadeMethod>
