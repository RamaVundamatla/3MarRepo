    <JadeMethod name="addDisplayTimeSlot" id="c5e2cb29-680b-45db-87b7-6399d66d2818">
        <updating/>
        <source>addDisplayTimeSlot(_timeSlot : CM_TimeSlotEntity; _row : Integer; _col : Integer) updating;

vars
	col : Integer;
begin
	if self.formType = FORM_TYPE_STD then
		if _col = MONDAY then
			self.tblTimeSlot.accessCell(_row, 1).text := _timeSlot.startTime.format("hh:mm").String;
		endif;
		col := _col + 1;
		self.tblTimeSlot.accessCell(_row, col).text := _timeSlot.numOfSlot.String;
		self.tblTimeSlot.accessCell(_row, col).itemObject := _timeSlot;
	else
		self.tblTimeSlot.accessCell(_row, 1).text := _timeSlot.startTime.format("hh:mm").String;
		self.tblTimeSlot.accessCell(_row, _col).text := _timeSlot.numOfSlot.String;
		self.tblTimeSlot.accessCell(_row, _col).itemObject := _timeSlot;
	endif;
end;
</source>
        <Parameter name="_timeSlot" type="CM_TimeSlotEntity"/>
        <Parameter name="_row" type="Integer"/>
        <Parameter name="_col" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="addToolbarControls" id="db1a1619-7bbc-4553-a28b-66d5f25b83cb">
