    <JadeMethod name="doCmbOperatorClick" id="43a474d2-c908-4793-b215-c3ece6b87568">
        <updating/>
        <source>doCmbOperatorClick()updating;
// ---------------------------------------------------------------------------
// Created:     24 November 2009 by cnwcs5
// Purpose:     CCMS 1028 - summary mappings
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	line : CM_XTABMappingLine;
	index : Integer;
begin

	line := getFirstSelectedLine(index);
	if line = null 
	or line.myQueryOperator &lt;&gt; self.cmbOperator.listObject then // TFS 7528 changing from one operator to another did not change the value control
		self.setControlsForOperator (txtValue1, txtValue2, txtDate1, txtDate2, txtTime1, txtTime2, lblValue, lblAnd, cmbValue, tblValue, true, 
				self.myQueryProperty, cmbOperator.listObject.CM_QueryOperator);
	else
		// We will have already displayed this mappping line, don't change anything else...
	endif;

epilog
	
end;</source>
    </JadeMethod>
    <JadeMethod name="doMappingLineAdd" id="fc38a744-2944-4e01-ac49-5526d9ae9a32">
        <updating/>
        <source>doMappingLineAdd() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
26 November 2009	cnwndl1	Initial creation

*/

vars

	newLine : CM_XTABMappingLine;
	proxyMap : CM_XTABMapping;
	proxyOperator : CM_QueryOperator;
	searchValue : Any;
	
begin

	proxyMap := self.myProxyObject.CM_XTABMapping;
	if proxyMap = null then
		app.msgBox(app.getErrorString(Proxy_Object_Null_For_Update),app.getErrorString(Contact_developer), MsgBox_OK_Only + MsgBox_Stop_Icon);
		return;
	endif;
	
	if cmbOperator.listObject = null then
		app.msgBox(app.getErrorString(XTAB_OperatorRequired),app.getErrorString(Error), MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
		cmbOperator.setFocus();
		return;
	endif;
	
	if txtMapValue.text.trimBlanks = null then
		app.msgBox(app.getErrorString(XTAB_Mapped_Value_Reqd),app.getErrorString(Error), MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
		txtMapValue.setFocus();
		return;
	endif;
	
	create newLine transient;
	newLine.setMappedValue( txtMapValue.text );
	
	create proxyOperator as cmbOperator.listObject.CM_QueryOperator.class transient;
	self.setSearchValueOnOperator( txtValue1, txtValue2, txtDate1, txtDate2, txtTime1, txtTime2, cmbValue, tblValue, self.myQueryProperty, proxyOperator);
	newLine.setMyQueryOperator( proxyOperator );
	
	proxyMap.allMappingLines.add(newLine);

	self.setControlsForMapping();
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doMappingLineDelete" id="cc04d0e0-ceb4-42e1-9c6a-591a7f88b4c3">
        <updating/>
        <source>doMappingLineDelete() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
26 November 2009	cnwndl1	Initial creation

*/

vars

	index : Integer;
	line : CM_XTABMappingLine;
	
begin

	line := self.getFirstSelectedLine( index );
	if line = null then
		app.msgBox(app.getErrorString(Please_select_mapping_line),app.getErrorString(Error), MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
		return;
	endif;
	
	delete line;
	
	self.setControlsForMapping();
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doMappingLineMove" id="ffd4b5a4-cd95-4660-88c4-8d5b4fc428ee">
        <updating/>
        <source>doMappingLineMove( _down : Boolean ) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
26 November 2009	cnwndl1	Initial creation

*/

vars

	proxyMap : CM_XTABMapping;
	newIndex : Integer;
	lineToShift : CM_XTABMappingLine;
	index : Integer;
	line : CM_XTABMappingLine;
	newOrderArray : CM_XTABMappingLineArray;
	
begin

	proxyMap := self.myProxyObject.CM_XTABMapping;
	if proxyMap = null then
		app.msgBox(app.getErrorString(Proxy_Object_Null_For_Update),app.getErrorString(Contact_developer), MsgBox_OK_Only + MsgBox_Stop_Icon);
		return;
	endif;

	lineToShift := self.getFirstSelectedLine( index );
	if lineToShift = null then
		app.msgBox(app.getErrorString(Please_select_mapping_line),app.getErrorString(Error), MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
		return;
	endif;
	
	create newOrderArray transient;
	
	if _down then
		newIndex := index + 1;
	else
		newIndex := index - 1;
	endif;
	
	foreach index in 1 to tblMappings.rows do
		if not _down and index = newIndex then
			newOrderArray.add(lineToShift);
		endif;
		line := tblMappings.accessRow(index).itemObject.CM_XTABMappingLine;
		if line = null or line = lineToShift then
			continue;
		endif;
		newOrderArray.add(line);
		if _down and index = newIndex then
			newOrderArray.add(lineToShift);
		endif;
	endforeach;
	
	proxyMap.allMappingLines.clear();
	newOrderArray.copy(proxyMap.allMappingLines);
	
	self.loadMapping(newIndex);
	
epilog

	delete newOrderArray;
	
end;</source>
        <Parameter name="_down" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doMappingLineUpdate" id="6a1c635d-8171-4f8c-b1a5-c898d36527f1">
        <updating/>
        <source>doMappingLineUpdate() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
25 November 2009	cnwndl1	Initial creation

*/

vars

	index : Integer;
	line : CM_XTABMappingLine;
	proxyOperator : CM_QueryOperator;
	
	
begin

	line := self.getFirstSelectedLine( index );
	if line = null then
		app.msgBox(app.getErrorString(Please_select_mapping_line),app.getErrorString(Cannot_Perform_Edit), MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
		return;
	endif;

	if txtMapValue.text = null then
		app.msgBox(app.getErrorString(XTAB_Mapped_Value_Reqd),app.getErrorString(Error), MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
		txtMapValue.setFocus();
		return;
	endif;
	
	if cmbOperator.listObject = null then
		app.msgBox(app.getErrorString(XTAB_OperatorRequired),app.getErrorString(Error), MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
		cmbOperator.setFocus();
		return;
	endif;

	line.setMappedValue( txtMapValue.text );
	delete line.myQueryOperator;	// in case its is going to be a different type.
	
	create proxyOperator as cmbOperator.listObject.CM_QueryOperator.class transient;
	self.setSearchValueOnOperator( txtValue1, txtValue2, txtDate1, txtDate2, txtTime1, txtTime2, cmbValue, tblValue, self.myQueryProperty, proxyOperator);
	line.setMyQueryOperator( proxyOperator );
	
	self.setControlsForMapping();
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doOK" id="ab71cbe1-a597-4a54-b525-fabd680b9d87">
        <updating/>
        <source>doOK() updating;
// ---------------------------------------------------------------------------
// Created:     24 November 2009 by cnwcs5
// Purpose:     CCMS 1028 - summary mappings
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	proxy : CM_XTABMapping;
	realMapping : CM_XTABMapping;
	result : Integer;
begin

	proxy := self.myProxyObject.CM_XTABMapping;
	if proxy = null then
		app.msgBox(app.getErrorString(Proxy_Object_Null_For_Update),app.getErrorString(Contact_developer), MsgBox_OK_Only + MsgBox_Stop_Icon);
		return;
	endif;

	proxy.setName(self.txtName.text.trimBlanks);
	proxy.setDescription(self.txtDescription.text.trimBlanks);
	if optGrpHeading.value then
		proxy.setOtherValues(CM_XTABMapping.OTHER_GROUPED);
	elseif optGrpProperty.value then
		proxy.setOtherValues(CM_XTABMapping.OTHER_SEPERATE);
	endif;
	
	if optOrderMapping.value then
		proxy.setOrder(CM_XTABMapping.ORDER_MAPPING);
	elseif optOrderValue.value then
		proxy.setOrder(CM_XTABMapping.ORDER_MAPPING_VALUE);
	endif;
	
	proxy.setOtherHeading(txtOtherHeading.text);
	proxy.setIncludeAllMappingValues (self.chkIncludeAll.value);	// cnwcs5 07/12/2009
	
	while true do
		if self.myXTABMapping &lt;&gt; null then	// updating
			app.myTrxUA.trxUpdateXTABMapping(proxy, app.myPassport);
		else	// creating a new one
			app.myTrxCA.trxCreateXTABMapping(proxy, realMapping, app.myPassport);
		endif;
		if app.myPassport.trxCompletedOK then
			self.clearErrorWarnings();
			self.myXTABMapping := realMapping;
			break;
		else
			result := app.showErrorWarningDialog(app.getErrorString(Train_update), app.myPassport, ErrWarnMode_Add + ErrWarnMode_CanAckWarnings); //+ cnwmd1, CCMS 1067, Par 19710
			if app.myPassport.noErrors and
			   result = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			return;
		endif;
		break;
	endwhile;
			
	inheritMethod();

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="getFirstSelectedLine" id="f7b162e1-a6b6-4def-8f07-e8179185120e">
        <source>getFirstSelectedLine( _index : Integer output) : CM_XTABMappingLine;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
25 November 2009	cnwndl1	Initial creation

*/

vars

	index : Integer;
	obj : Object;
	
begin

	foreach index in 1 to tblMappings.rows do
		if tblMappings.accessRow(index).selected then
			obj := tblMappings.accessRow(index).itemObject;
			_index := index;
			break;
		endif;
	endforeach;
	
	if obj &lt;&gt; null then
		return obj.CM_XTABMappingLine;
	endif;
	
	return null;
	
epilog

end;</source>
        <Parameter name="_index" type="Integer" usage="output"/>
        <ReturnType type="CM_XTABMappingLine"/>
    </JadeMethod>
    <JadeMethod name="initMappingTable" id="6433646a-11cf-4c1f-a478-95ec8eaf28ee">
        <source>initMappingTable()protected;
// ---------------------------------------------------------------------------
// Created:     23 November 2009 by cnwcs5
// Purpose:     CCMS 1061 - gate config
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	tbl		:Table;
begin
	tbl	:= self.tblMappings;
	
	tbl.fixedRows	:= 1;
	tbl.rows		:= tbl.fixedRows;
	tbl.columns		:= 3;
	
	tbl.setCellText (1,1, lblOperator.caption.stripTrailingColon &amp; Tab &amp; 
							lblValue.caption.stripTrailingColon &amp; Tab &amp; 
							lblMapValue.caption.stripTrailingColon);
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="loadMapping" id="f8e59567-5ff0-493b-ba4c-353c834e982e">
        <updating/>
        <source>loadMapping( _setToIndex : Integer ) protected, updating;
// ---------------------------------------------------------------------------
// Created:     24 November 2009 by cnwcs5
// Purpose:     CCMS 1028 - summary mappings
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 07/12/2009	cnwcs5		ccms 1028
// ---------------------------------------------------------------------------
vars

	mapping	: CM_XTABMapping;
	table	: Table;
	obj		: Object;
	line	: CM_XTABMappingLine;
	op		: CM_QueryOperator;
	prop	: CM_QueryProperty;
	index	: Integer;
	
begin

	mapping  := self.myProxyObject.CM_XTABMapping;
	table := self.tblMappings;
	prop := self.myQueryProperty;
	
	self.txtName.text := mapping.name;
	self.txtDescription.text := mapping.description;
	self.txtOtherHeading.text := mapping.otherHeading;
	
	if mapping.otherValues = CM_XTABMapping.OTHER_SEPERATE then
		self.optGrpProperty.value := true;
		self.optGrpHeading.value := false;
	else
		self.optGrpProperty.value := false;
		self.optGrpHeading.value := true;
	endif;
	
	if mapping.order = CM_XTABMapping.ORDER_MAPPING_VALUE then
		self.optOrderValue.value := true;
		self.optOrderMapping.value := false;
	else
		self.optOrderValue.value := false;
		self.optOrderMapping.value := true;
	endif;
	
	self.chkIncludeAll.value	:= mapping.includeAllMappingValues;	// cnwcs5 07/2/2009
	
	table.rows := table.fixedRows;
	
	foreach obj in mapping.allMappingLines do
		line	:= obj.CM_XTABMappingLine;
		op 		:= line.myQueryOperator;
		
		index := table.addItem (op.description &amp; Tab &amp; op.getSearchValueStr (prop) &amp; Tab &amp; line.mappedValue);
		table.accessRow(index).itemObject := line;
		if index = _setToIndex then
			table.accessRow(index).selected := true;
		endif;
	endforeach;
	
	self.setMappingLineTableButtons();
	
	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_setToIndex" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="loadOperatorsCombo" id="8d67da6f-4754-4744-a28e-c6fc337e1add">
