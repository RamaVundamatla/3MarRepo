    <JadeMethod name="machineDirectorTwin" id="879af629-8d6d-4fbe-8e56-d95f35ae4133">
        <source>machineDirectorTwin(_machine: CM_Machine; _tiID: String; _twinTiID : String) protected;

/*

Purpose:	twin/tandem lift directiors

Parameters:			

Return Value:		


Date		Who		Reason
12 July 2011	cnwrd1	Initial creation

*/

vars
	mediator : CM_RadioTelemetryMediator;
begin
	create mediator transient;
	mediator.machine := _machine;
	mediator.task := _machine.currentQueueTask;
	mediator.setActiveTerminal(self.getTerminal);
	app.myTrxRT.trxActionDirectorTask(_tiID , _twinTiID, mediator, false, true, null,null,null, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();

epilog
	delete mediator;
end;</source>
        <access>protected</access>
