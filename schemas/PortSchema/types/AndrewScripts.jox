    <JadeMethod name="listEntDefForCargoTypes" id="0633d6b3-4be2-475f-ab3f-71ea0bf86ecd">
        <source>listEntDefForCargoTypes();
/*
Purpose:			

Date		Who		Reason
25 March 2022	navab1	TFS 51855
*/

vars
	ct : CM_CargoBOLType;
	root : CM_Root;
	strArray : StringArray;
begin

	root := CM_Root.firstInstance;
	
	create strArray transient;
	
	foreach ct in root.allCargoTypesById do
		if strArray.indexOf(ct.maintFormTblDataDef) &lt;= 0 then
			strArray.add(ct.maintFormTblDataDef);
		
		endif;
	endforeach;
	
	
	strArray.inspectModal;
epilog
	delete strArray;
end;</source>
    </JadeMethod>
