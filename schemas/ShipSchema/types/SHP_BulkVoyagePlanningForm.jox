    <JadeMethod name="doFlipPortStarboard" id="5d26b352-7225-43e7-b3a0-646623b12123">
        <updating/>
        <source>doFlipPortStarboard() updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 03/02/2016	cnwdap1		Initial creation PAR #36766 Bulk Graphical Representation
//
vars

begin
	if self.myBulkDrawingController = null then
		return;
	endif;
	self.myBulkDrawingController.setIsStarboardBerthed(not self.myBulkDrawingController.isStarboardBerthed);
	self.redraw();
epilog

