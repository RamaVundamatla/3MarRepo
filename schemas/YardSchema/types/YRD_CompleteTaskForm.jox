// ----------	--------	-----------------------------------------------------
// 19/01/2015	cnwdap1		Initial creation PAR #35397 CCMS SFW 1394 Voyage Rationalisation
//
vars

begin
	_weight := self.getWeightMovedKgs();
epilog

end;</source>
        <Parameter name="_weight" type="Decimal" usage="output"/>
    </JadeMethod>
    <JadeMethod name="initDetails" id="346a79c6-1a49-4cef-b6eb-4a85ca992b1a">
        <updating/>
        <source>initDetails(_terminal : CM_Terminal;_rtQueueTask : CM_RTQueueTask)  : Boolean updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
11 February 2011	cnwer1	Initial creation
14 Dec		2015	cnwma1	PAR #3265	Set Task Status to Set Complete for a Release by Type gives a 1090 error
*/

vars
	isMoveNoNextEntry	: Boolean;
	wle : CM_WorkListEntry;
	currentDescription,
	orginLocID,finalLocID : String;
	rtQueueEntry : CM_RTQueueEntry;
	prevEntry,
	nextEntry	: CM_RTQueueEntry;
	machineTypeGroup : CM_MachineTypeGroup ;
	pickupTask : CM_RTQueueTask;
	ti 			: CM_TrackedItem;
	ct : CM_CargoType;
begin
	self.optMove.value:=false;
	self.myTerminal:=_terminal;
	rtQueueEntry:=_rtQueueTask.myEntry;
	
	if rtQueueEntry.status = ENTRY_COMPLETE then
	
		app.msgBox(app.getErrorString(Not_complete_completed_entry), app.getErrorString(Error),MsgBox_OK_Only);
		return false;
	endif;
	
	if _rtQueueTask.isSetDown then
		pickupTask:=rtQueueEntry.getDirectorOrPickupTask();
	
		if pickupTask.status = TASK_COMPLETE then
			self.myInitQueueTask:=_rtQueueTask;
		else
			self.myInitQueueTask:=pickupTask;
		endif;
	elseif _rtQueueTask.isMove then
		nextEntry := rtQueueEntry.getNextRelatedEntry(); //epr par 35702 CCMS 2457 17/2/15
		// 28726 cnwjre1 Nov 2011 voyage load via machine rules ending in IMV
		if nextEntry = null then
			pickupTask := rtQueueEntry.getDirectorOrPickupTask();
			isMoveNoNextEntry := true;
		else
			pickupTask:=nextEntry.getDirectorOrPickupTask();
		endif;
		self.myInitQueueTask:=pickupTask;
	elseif _rtQueueTask.taskType = TASK_BREAKBULK then
		self.myInitQueueTask:=_rtQueueTask;
	else
			
		self.myInitQueueTask:=_rtQueueTask;
	endif;
	
	if self.myInitQueueTask.status = TASK_COMPLETE then
		self.myInitQueueTask:=rtQueueEntry.getDirectorOrSetDownTask();
	endif;
	

	wle:=rtQueueEntry.myWorkListEntry;
	prevEntry:=rtQueueEntry.getPreviousRelatedEntry();//epr par 35702 CCMS 2457 17/2/15
	if isMoveNoNextEntry then	// 28726 cnwjre1 Nov 2011 voyage load via machine rules ending in IMV
		self.optPickSetTask.visible := false;
		self.optPickupTask.visible := false;
		self.lblPickSetTask.visible := false;
		self.lblPickupTask.visible := false;
		self.optMove.value := true;
	else
	
		if self.myInitQueueTask.taskType = TASK_PICKUP  or  self.myInitQueueTask.taskType = TASK_BREAKBULK then
	
			machineTypeGroup:=app.myRoot.allMachineTypeGroups[rtQueueEntry.machineTypeGroup];
			self.lblPickupTask.caption:=app.getErrorString1(Complet_pickup_task_from,self.myInitQueueTask.sourceLocationId);
			self.loadTaskMachines();
			
			self.lblPickSetTask.visible:=true;
			
			if self.myInitQueueTask.isPlanOnPickupNoTarget then //cwnrd1 ccms 2014
				self.optPickSetTask.visible:=false;
				self.optPickSetTask.value:=false;
			else
				self.optPickSetTask.visible:=true;
				self.optPickSetTask.value:=true;
				self.lblPickSetTask.caption:=app.getErrorString2(Complete_pickup_setdown_task,self.myInitQueueTask.sourceLocationId,self.myInitQueueTask.getTargetLocationForDisplay);	
			endif;
			 //epr par 35702 CCMS 2457 17/2/15
			if wle.allRTQueueEntries.size = 1  or ( prevEntry &lt;&gt; null and prevEntry.status = ENTRY_COMPLETE ) then
				self.optMove.visible:=false;
				self.lblMove.visible:=false;
			endif;
			
			if self.myInitQueueTask.taskType = TASK_BREAKBULK then		
				self.lblWeight.visible:=self.myInitQueueTask.myEntry.isBulkMove;
				self.tblWeight.visible:=self.myInitQueueTask.myEntry.isBulkMove;
				self.lblQuantity.visible:=not self.myInitQueueTask.myEntry.isBulkMove;
				self.txtQuantity.visible:=not self.myInitQueueTask.myEntry.isBulkMove;
				if self.tblWeight.visible then
					if self.myInitQueueTask.ti &lt;&gt; null then										// 14/12/2015 cnwma1 PAR #37265
						ct:=self.myInitQueueTask.ti.myCargoType;
						if ct.isTrackByWeight then
							self.lblWeight.caption:= app.getErrorString(CM_Weight);
							self.tblWeight.setup(Type_Weight, self.backColor);
							self.tblWeight.setValues(" " &amp; ct.myWeightMeasurementType.shortName);
						else
							self.lblWeight.caption:= app.getErrorString(CM_Volume);
							
							self.tblWeight.setup(Type_Volume, self.backColor);		
							self.tblWeight.setValues(" " &amp; ct.myVolumeMeasurementType.shortName);
						endif;
						self.tblWeight.tabKey:=J_key_Tab;
					else 
						self.lblWeight.caption:= app.getErrorString(CM_Weight);
						self.tblWeight.setup(Type_Weight, self.backColor);
						self.tblWeight.setValues(" " &amp; app.getDefaultMeasurementForType(Type_Weight).shortName);
						self.tblWeight.tabKey:=J_key_Tab;
					endif;																          // 14/12/2015 cnwma1 PAR #37265
				endif;
			else
				self.lblQuantity.visible:=false;
				self.txtQuantity.visible:=false;
			endif;
			
		elseif self.myInitQueueTask.taskType = TASK_SETDOWN then
			
			self.lblMach.visible:=false;
			self.cmbMach.visible:=false;
			
			
			self.optPickSetTask.visible:=false;
			self.lblPickSetTask.visible:=false;
			
			self.optPickupTask.value:=true;
			self.lblPickupTask.caption:=app.getErrorString1(Complete_setdown_task,self.myInitQueueTask.targetLocationId);
		elseif self.myInitQueueTask.taskType = TASK_DIRECTOR then
			app.msgBox(app.getErrorString(Complete_director_no_cargo) ,app.getErrorString(Error),MsgBox_OK_Only);
			
			return false;
			
		endif;	
	endif;
	
		
	if wle.allRTQueueEntries.size = 1  then
		self.optMove.visible:=false;
		self.lblMove.visible:=false;
		
	elseif prevEntry &lt;&gt; null then
		if prevEntry.status = ENTRY_COMPLETE or 
			prevEntry.machineTypeGroup = MACHINETYPEGRP_IMV and prevEntry.status = ENTRY_WORKING  then
			self.optMove.visible:=false;
			self.lblMove.visible:=false;
		endif;
	endif;
	
	self.loadSetdownIMVs();
	
	ti:= wle.getMyTrackedITem;
	if ti &lt;&gt; null then
		orginLocID:=ti.myPrimaryActualLocation.getFullId();
	else
		orginLocID:=wle.getOriginalTaskSourceLocId;
	endif;
	finalLocID :=wle.getFinalTaskTargetLocId;
	self.lblMove.caption:=app.getErrorString2(Complet_entire_move_from,orginLocID,finalLocID);
	
		
	self.resizeControls();
	
	return true;
epilog
	
end;</source>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_rtQueueTask" type="CM_RTQueueTask"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isIMVneeded" id="5ea8fd4a-d1d4-46d7-bccc-c4e8460574d7">
        <source>isIMVneeded() : Boolean;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
16 March 2011	cnwer1	Initial creation

*/

vars
	setdownTask : CM_RTQueueTask;
begin

	if self.optMove.value then
		return false;
	endif;

	if self.optPickupTask.value then
		if self.myInitQueueTask.taskType = TASK_SETDOWN then
			return  self.myInitQueueTask.machineTypeGroup =MACHINETYPEGRP_IMV;
		endif;
	elseif self.optPickSetTask.value then
		if self.myInitQueueTask.taskType = TASK_SETDOWN then
			setdownTask:= self.myInitQueueTask;
		else
			setdownTask:=self.myInitQueueTask.myEntry.getDirectorOrSetDownTask();
		endif;
		
		if setdownTask = null then
			if self.myInitQueueTask.taskType = TASK_BREAKBULK then
				setdownTask:=self.myInitQueueTask;
			endif;
		endif;
		
		if setdownTask &lt;&gt; null then //cnwrd1 ccms 2014
			return setdownTask.machineTypeGroup =MACHINETYPEGRP_IMV;
		else
			return false;
		endif;
	endif;
	
	return false;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="loadSetdownIMVs" id="e8dda062-4200-46ff-b34a-39fa483fecf3">
        <source>loadSetdownIMVs() protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
11 March 2011	cnwer1	Initial creation

*/

vars
	iter : Iterator;
	moveTask : CM_RTQueueTask;
	rtQueueEntry : CM_RTQueueEntry;
	machine,intendedMachine 	: CM_Machine;
	idx 		: Integer;
begin
	if  not self.isIMVneeded then
		self.lblIMV.visible:=false;
		self.cmbIMV.visible:=false;
		return;
	endif;
	
	self.lblIMV.visible:=true;
	self.cmbIMV.visible:=true;
	
	rtQueueEntry:=self.myInitQueueTask.myEntry;
	//epr par 35702 3/3/15
	moveTask:=rtQueueEntry.getNextEntryFirstMoveTask();
	if moveTask  = null then
		return;
	endif;
	
	iter:= self.myTerminal.machines.createIterator;
	while iter.next(machine) do
		if machine.machineType &lt;&gt; MACHINETYPE_IMV then
			continue;
		endif;
	
		if not moveTask.queryMachineAssign(machine,false,true,true,true,true,null) then
			continue;
		endif;
		idx:=self.cmbIMV.addItem(machine.code);
		self.cmbIMV.itemObject[idx]:=machine;
	endwhile;
	
	intendedMachine:=moveTask.machine;
	if intendedMachine = null then
		intendedMachine:=moveTask.intendedMachine;
	endif;
	
	if intendedMachine &lt;&gt; null then
		self.cmbIMV.listObject:=intendedMachine;
	endif;
epilog
	delete iter;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="loadTaskMachines" id="487aebc0-283c-4a15-9e16-d84cf5c45de5">
        <source>loadTaskMachines() protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
11 March 2011	cnwer1	Initial creation

*/

vars
	iter : Iterator;
	machine ,intendedMachine: CM_Machine;
	idx 	: Integer;
	
begin
		
	iter:= self.myTerminal.machines.createIterator;
	while iter.next(machine) do
		if not self.myInitQueueTask.queryMachineAssign(machine,false,true,false,false,false,null) then
			continue;
		endif;
		idx:=self.cmbMach.addItem(machine.code);
		self.cmbMach.itemObject[idx]:=machine;
	endwhile;	
	
	
	intendedMachine:=self.myInitQueueTask.machine;
	if intendedMachine =  null then
		intendedMachine:=self.myInitQueueTask.intendedMachine;
	endif;
	
	if intendedMachine &lt;&gt; null then
		self.cmbMach.listObject:=intendedMachine;
	endif;
epilog
	delete iter;

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="optMove_click" id="d11cb39e-0973-4a0f-8e5f-2a2f0133a05d">
        <controlMethod name="OptionButton::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>optMove_click(optionbutton: OptionButton input) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
11 March 2011	cnwer1	Initial creation

*/

vars

begin
	self.lblMach.enabled:=false;
	self.cmbMach.enabled:=false;
	self.lblIMV.visible:=self.isIMVneeded;
	self.cmbIMV.visible:=self.isIMVneeded;
	
epilog

end;</source>
        <Parameter name="optionbutton" type="OptionButton" usage="input"/>
    </JadeMethod>
    <JadeMethod name="optPickSetTask_click" id="92ff242a-a35c-48f1-91c5-c29228e8721e">
        <controlMethod name="OptionButton::click"/>
