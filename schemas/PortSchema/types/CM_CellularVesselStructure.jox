    <JadeMethod name="cloneMySelf" id="f2c8ae98-4c58-400b-8f02-a83adc6bd3fb">
        <source>cloneMySelf(_transient : Boolean): SelfType;
// ---------------------------------------------------------------------------
// Created:     16 July 2001 by cnwrs1
//
// Purpose:     used by ship definition to create a new copy of it self 
//              may be redundant in version 7 ship defn
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	newVessel:CM_CellularVesselStructure;	
	bayDefn,newBayDefn, previousBayDefn :CM_BayDefn;
	hatchLid : CM_HatchLid;
	newHatchLid : CM_HatchLidVessel;
	aHold,newHold : CM_Hold; 
	//aTank, newTank : CM_VesselTank;
	//aSection, newSection : CM_VesselSection;
begin
	
	newVessel := inheritMethod(_transient);
	
	foreach aHold in self.allHolds do
		newHold := aHold.CM_VesselHold.cloneMySelf(newVessel);
	endforeach;
	
	foreach bayDefn in self.allBaysByOrdinal do
		newBayDefn := bayDefn.cloneMySelf(newVessel);
	endforeach;	

	// link up our NEW bays to each other
	previousBayDefn := null;
	foreach bayDefn in newVessel.allBaysByOrdinal do
		if previousBayDefn &lt;&gt; null then
			previousBayDefn.setMyAftBay(bayDefn);
		endif;
		previousBayDefn := bayDefn;
	endforeach;

	// hatch lids need bays so do after bays are created
	foreach hatchLid in self.allHatchlids do
		newHatchLid := hatchLid.CM_HatchLidVessel.cloneMySelf(newVessel);
	endforeach;	
	
	/*foreach aTank in self.allTanks do
		newTank := aTank.CM_VesselTankVessel.cloneMySelf(newVessel);
	endforeach;
	
	foreach aSection in self.allSections do
		newSection := aSection.CM_VesselSectionVessel.cloneMySelf(newVessel);
	endforeach;*/
		
	return newVessel;
end;</source>
        <Parameter name="_transient" type="Boolean"/>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="convertVessel" id="54acf966-71a5-4457-b334-a8d9ee884d72">
        <updating/>
        <source>convertVessel(_oldVessel: CM_Vessel) updating;
//--------------------------------------------------
// Created:	31 January 2006 By: cnwgd1
//--------------------------------------------------
vars
	tmpBay : CM_BayDefn;
	tmpLids : CM_HatchLid;
	tmpHold : CM_Hold;
begin
/*	inheritMethod(_oldVessel);
	
	self.bridgeAfterBay 			:= _oldVessel.bridgeAfterBay;
	self.isImported		 			:= _oldVessel.isImported;	
	self.isoHalfHeights		 		:= _oldVessel.iSOVessel;		
	self.use40Id 					:= _oldVessel.use40Id;
	self.useBayCellTierNumbering 	:= _oldVessel.useBayCellTierNumbering;
	
	// 40ft Bays
	foreach tmpBay in _oldVessel.allBays40ByLabel do
		tmpBay.setPropertyValue(CM_BayDefn::my40Vessel.name, null);
		tmpBay.setPropertyValue(CM_BayDefn::my40VesselCellular.name, self);		
	endforeach;	

	// Bays/Ordinal
	foreach tmpBay in _oldVessel.allBaysByLabel do
		tmpBay.setPropertyValue(CM_BayDefn::myVessel.name, null);
		tmpBay.setPropertyValue(CM_BayDefn::myVesselCellular.name, self);		
	endforeach;		

	// Hatch Lids
	foreach tmpLids in _oldVessel.allHatchlids do
		tmpLids.setPropertyValue(CM_HatchLidVessel::myCellularVessel.name, null);
		tmpLids.setPropertyValue(CM_HatchLidVessel::myCellularVesselStructure.name, self);		
	endforeach;			

	// Vessel Holds
	foreach tmpHold in _oldVessel.allHolds do
		tmpHold.setPropertyValue(CM_VesselHold::myVessel.name, null);
		tmpHold.setPropertyValue(CM_VesselHold::myCellularVesselStructure.name, self);		
	endforeach;		
*/	
end;</source>
        <Parameter name="_oldVessel" type="CM_Vessel"/>
    </JadeMethod>
