    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="location"/>
    <ExplicitInverseRef name="myOtherTerminalTransferArea" id="ee7b5f72-c4bc-49ca-ae30-3f01577ad4a8">
