    <JadeMethod name="doAuditRateHistoryCreate" id="084359e3-5daf-401c-90ee-5e0af9efa864">
        <updating/>
        <source>doAuditRateHistoryCreate(_newCost : Decimal;_oldCost : Decimal;  pDeleted : Boolean;  _status : Integer) protected, updating;
// ---------------------------------------------------------------------------
// Created:		January 2005 By Andrew Bishop cnwab1
//
// Purpose:		JMH Invoice changes 
//
// ---------------------------------------------------------------------------
/*

Date		Who		Reason
12 Oct 2016	cnwkpd1	TFS 2815 - JADE 7.1.08 causeEvent changes
	
*/

vars
	auditRateChg	: CM_AuditLineRateOverride;

begin
	create auditRateChg persistent;
	auditRateChg.auditedFOs.clear;
	auditRateChg.unauditedFOs.clear;
// ### TFS BUG 62926 13MAR2024 NAVAB1	app.myUtilityUA.myUpdateAuditAgent.audUpdateGeneric(auditRateChg, true);			// 11/5/18 MAP TFS37718
	auditRateChg.sequenceNum := app.getNextInvoiceSeqNumOnRootBank(SN_AUDIT); // PAR 15036
	auditRateChg.userId := app.getMyUserCode;
	auditRateChg.dateTime := app.actualTimeServer;
	auditRateChg.isDeleted := false;	
	auditRateChg.status := _status;
	
	if (not pDeleted) then
		auditRateChg.previousCost := _oldCost;
		auditRateChg.newCost := _newCost;
		auditRateChg.myCharge := self;
	else 
		auditRateChg.isDeleted := true;
		auditRateChg.previousCost := _oldCost;
	endif;
// ### TFS BUG 62926 13MAR2024 NAVAB1	app.myUtilityUA.myUpdateAuditAgent.audUpdateGeneric(auditRateChg, false);			// 11/5/18 MAP TFS37718
	auditRateChg.auditedFOs.add(self.invoiceLine);

//	self.causeEvent(Object_Update_Event, false, null);	
	self.updateObjectEdition(self);
			
end;</source>
        <access>protected</access>
        <Parameter name="_newCost" type="Decimal"/>
        <Parameter name="_oldCost" type="Decimal"/>
        <Parameter name="pDeleted" type="Boolean"/>
        <Parameter name="_status" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="evaluateMinMaxRate" id="ab00bebb-3538-41fd-af45-ea90730be565">
        <source>evaluateMinMaxRate(_actualTotal : Real; _minMaxUsed : Boolean output; _minMaxDisplayed : Boolean output) : Real protected;
// ---------------------------------------------------------------------------
// Created:		March 2006 By Andrew Bishop cnwab1
//
// Purpose:     	// ### CCMS 1424 _actualTotal is the true total (without min/max applied
//				returns the new total with min/max applied if any
// ---------------------------------------------------------------------------
// Date			Who		Reason
// 18 Oct 2024	navlw1	JIRA-33107: Invoice Logging Use Levels
// 25 Feb 2025	navah1	Story 34141: MTN - Performance Improvements - Review for invLog() Methods
vars
	tmpActualTotal, 
	tmpQty			: Real;
	aCT				: CM_CalculationType;
	unitsUsed		: Real;
	diffMin			: Integer;
	resourceUsed	: HMS_ResourceUsed;
	minAmt			: Decimal[14,2];	//11 May 2018	NDL	TFS 38528
	maxAmt			: Decimal[14,2];	//11 May 2018	NDL	TFS 38528
	canLogExtra		: Boolean;			//26.02.2025 navah1	#34141
begin
	canLogExtra		:= app.canLogExtraDetail(); //26.02.2025 navah1	#34141
	
	_minMaxUsed 	 := false;
	_minMaxDisplayed := false;
	tmpActualTotal   := _actualTotal;
	
	if canLogExtra then	//26.02.2025 navah1	#34141
		app.invLog("EVALUATING MIN MAX - STARTING", LogINFO.String);
	endif;
	// ### VOYAGE INVOICING, adjust total with min and max values
	
	if not self.overridden // ### PAR 11216
	and self.service &lt;&gt; null then
		aCT := self.service.myCalculationType;
		if aCT &lt;&gt; null and aCT.isVoyageCalcType then // PAR 10114
		
			// ### PAR 10368
			minAmt := aCT.amountMin;
			maxAmt := aCT.amountMax;
			
			tmpQty := 1;
			if invoiceLine.myTransactionHMS &lt;&gt; null and invoiceLine.myTransactionHMS.myResourceUsed &lt;&gt; null then
				resourceUsed := invoiceLine.myTransactionHMS.myResourceUsed;
				unitsUsed 	 := resourceUsed.unitsUsed;
				if unitsUsed = 0 then		// 35339 date range processing
					if aCT.requiresDateRange and
					   resourceUsed.fromDateTime.isValid and
				       resourceUsed.toDateTime.isValid then				   
						diffMin 	:= (resourceUsed.toDateTime.cnEcDiff(resourceUsed.fromDateTime) / MillisecondsPerMinute).Integer;
						unitsUsed 	:= aCT.getNumHourBlocks(diffMin, true, null);
					endif;
				endif;
				tmpQty := tmpQty.max(unitsUsed);
				
				if aCT.isUsingGRTInQty() then // PAR 34764
					minAmt := minAmt * tmpQty;// ### PAR 10368
					maxAmt := maxAmt * tmpQty;// ### PAR 10368
				endif;
			endif;
			
			if canLogExtra then	//26.02.2025 navah1	#34141
				app.invLog("EVALUATING MIN MAX - min amt = " &amp; minAmt.asStringJMT &amp; " max amt " &amp; maxAmt.asStringJMT &amp; "amount is " &amp; tmpActualTotal.asStringJMT, LogINFO.String);
			endif;
			
			if tmpActualTotal &lt; minAmt and minAmt &gt; -999999  and minAmt &lt;&gt; 0 then
				tmpActualTotal 		:= aCT.amountMin;
				_minMaxUsed 		:= true;
				_minMaxDisplayed 	:= true;
			elseif tmpActualTotal &gt; maxAmt and maxAmt &lt;&gt; 0 then
				tmpActualTotal 		:= aCT.amountMax;
				_minMaxUsed 		:= true;
				_minMaxDisplayed 	:= true;
			endif;
		endif;
	endif;

	return tmpActualTotal;
	
end;</source>
        <access>protected</access>
        <Parameter name="_actualTotal" type="Real"/>
        <Parameter name="_minMaxUsed" type="Boolean" usage="output"/>
        <Parameter name="_minMaxDisplayed" type="Boolean" usage="output"/>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="evaluateRate" id="89c0a4fe-6992-401c-85c1-ffe948e5963a">
        <updating/>
        <source>evaluateRate() updating;
// CCMS SFW 1264 Apr 2012 invoice non-virtual fields - this code is now done at charge create, pre-post print, post or on demand (invoice re-evaluate), 
//	and automatically from a rate change, NOT each time anyone looks at an invoice.
// This method is now only ever called from a utl method in transaction state.
// 
// Changed On	By			Reason
// ----------	--------	-------------------------------------------------------
// 23/11/2015	cnwdap1		PAR #36909 minimum Charges - don't recalculate rate on minimum charge line
// 07/01/2015	cnwdap1		PAR #37337 minimum Charges - don't recalculate rate on Cash minimum charge line
// 21/11/2018   cnwma1		ChangeRequest 41945: PEL1 - SAP - Invoice changes restriction
// 22/03/2021   cnwma1 		ChangeRequest 50925: ASPA - New Total Column in Invoice Form
// 18 Oct 2024	navlw1		JIRA-33107: Invoice Logging Use Levels
// 25 Feb 2025	navah1		Story 34141: MTN - Performance Improvements - Review for invLog() Methods
vars
	minMaxRate, actualLineTotal, newRate	:   Real;
	rateTotal	: Real;
	minMaxUsed, minMaxDisplayed	: Boolean;
	aCT : CM_CalculationType;
	terminal: CM_Terminal;
	roundDecimalOpt	: Integer;
	canLogExtra	: Boolean;	//26.02.2025 navah1	#34141
begin
	canLogExtra	:= app.canLogExtraDetail();		//26.02.2025 navah1	#34141
	// ### TFS BUG 61096 21NOV2023 NAVAB1
	if self.invoiceLine&lt;&gt; null
	and self.service &lt;&gt; null then
		if canLogExtra then	//26.02.2025 navah1	#34141
			app.invLog("-", LogINFO.String);
			app.invLog("-", LogINFO.String);
			app.invLog(method.qualifiedName &amp; " ########", LogDEBUG.String);
			app.invLog(method.qualifiedName &amp; " ########", LogDEBUG.String);
			app.invLog(method.qualifiedName &amp; " STARTING - " &amp; self.invoiceLine.sequenceNum.String &amp; "/" &amp; self.service.name, LogTRACE.String);
			app.invLog(method.qualifiedName &amp; " ########", LogDEBUG.String);
			app.invLog(method.qualifiedName &amp; " ########", LogDEBUG.String);
			app.invLog("-", LogINFO.String);
			app.invLog("-", LogINFO.String);
		endif;
	endif;
	
	if self.overridden or
	   self.invoiceLine = null or
	   self.invoiceLine.hasMinMaxTotal or														// Min/Max so rate has been overridden CCMS 1424
	   self.invoiceLine.invoice = null or
	   not self.invoiceLine.invoice.canUpdate or 												//21.11.2018 cnwma1 TFS #41945
	   self.invoiceLine.invoice.isPostedOrReversal or 											//04 Sep 2017	NDL	TFS 6759
	   (self.invoiceLine &lt;&gt; null and self.invoiceLine.myInvoiceLineOriginal &lt;&gt; null) or			// PAR #36909
	   (self.invoiceLine &lt;&gt; null and self.invoiceLine.invoiceLineDesc.isUsedAsMinimumCharge) or	// PAR #37337
	    self.status = VOID then
		if canLogExtra then	//26.02.2025 navah1	#34141
			// ### TFS 2682
			app.invLog("RATE - Not re-evaluated", LogINFO.String);
		endif;
		return;
	endif;
	
	// ### TFS CR 55644 TASK 55684 13JAN2023 NAVAB1	newRate := self.getRateFromTable(rateTotal);
	if not self.getContractAndEvaluate(newRate, rateTotal) then // ### TFS CR 55644 TASK 55684 12JAN2023 NAVAB1
		if canLogExtra then	//26.02.2025 navah1	#34141
			// ### TFS CR 55644 TASK 55684 16JAN2023 NAVAB1
			app.invLog("RATE - Using standard Rate Table for rate", LogTRACE.String);
		endif;
		// ### JIRA 33347 19NOV2024 NAVAB1 - not using a contract so make sure contract details are all nulled.
		self.invoiceLine.resetContractData();
		
		newRate := self.getRateFromTable(rateTotal);
	else
		if canLogExtra then	//26.02.2025 navah1	#34141
			// ### TFS CR 55644 TASK 55684 16JAN2023 NAVAB1
			app.invLog("RATE - Using debtor contract for rate", LogINFO.String);
		endif;
	endif;

	if self.invoiceLine.isVTMISInvoiceLine()
	and not self.invoiceLine.manual then
		
		if rateTotal = 0 then
			actualLineTotal := newRate * self.invoiceLine.quantity;
		else
			actualLineTotal := rateTotal;
			self.total := actualLineTotal;
		endif;
		minMaxRate := self.evaluateMinMaxRate(actualLineTotal,minMaxUsed, minMaxDisplayed);	// ### CCMS 1424
		if minMaxUsed then		// ### CCMS 1424
			self.invoiceLine.hasMinMaxTotal := true;
			self.invoiceLine.displayMinMaxApplied := minMaxDisplayed;
			if self.service &lt;&gt; null then		// 36965 handle null service
				aCT := self.service.myCalculationType;
			endif;
			if aCT &lt;&gt; null 
			and not   aCT.isUsingGRTInQty()  then // PAR 34764
				self.invoiceLine.setForUpdateQuantity(1.0);
			else
				//epr TFS  44787 1/7/19 - for GRT has to set Qty to 1 because the rate will be the Total Amount - should never get here for pelindo they do not have any min/max set
				self.invoiceLine.setQuantityToHMSResoureQty(); 
		
			endif;

			newRate := minMaxRate;	// ### CCMS 1424
		
		else
			self.invoiceLine.hasMinMaxTotal := false;
			self.invoiceLine.displayMinMaxApplied := false;
		endif;
	endif;
	
	terminal := self.getMyTerminal();		// 22/8/18 TFS40270
	
	/* 19.03.2020 cnwma1 TFS #50925
	if terminal &lt;&gt; null and terminal.getConfig(InvoiceRoundLineTotal).Boolean then
		if rateTotal = 0 then
			rateTotal := newRate * self.invoiceLine.quantity;
		endif;
	endif;
	*/
	
	// ### JIRA 34909 16MAY2025 NAVAB1 - no rounding when splitting 
	if app.myPassport.context = Context_Pass_InvSplitMerge then	
		rateTotal := newRate * self.invoiceLine.quantity;
	else
		//19.03.2020 cnwma1 TFS #50925
		if terminal &lt;&gt; null then
			roundDecimalOpt := terminal.getConfig(InvoiceRoundLineTotal).Integer;
			if roundDecimalOpt &lt;&gt; CMIF_ConfigTerminal.InvLineRound_Value_NoRound then
				if rateTotal = 0 then
					rateTotal := newRate * self.invoiceLine.quantity;
				endif;
			endif;
		endif;
		//19.03.2020 cnwma1 TFS #50925
	endif;
	
	// 1279 escalating charges, consolidated invoice line, set total value directly to avoid rounding from using the derived rate
	if rateTotal &lt;&gt; 0 
	and self.total &lt;&gt; rateTotal then
		if canLogExtra then	//26.02.2025 navah1	#34141
			app.invLog(method.qualifiedName &amp; " Setting TOTAL Explicitly To " &amp; rateTotal.String, LogINFO.String);
		endif;
		self.total := rateTotal;
		self.isTotalSetExplicitly := true;
	endif;
	
	if newRate &lt;&gt; self.rate.roundedTo(6) then
		if canLogExtra then	//26.02.2025 navah1	#34141
			app.invLog(method.qualifiedName &amp; " Rate change from " &amp; self.rate.String &amp; " to " &amp; newRate.roundedTo(6).String, LogINFO.String);
		endif;
		self.rate := newRate.roundedTo(6);
	endif;

end;</source>
    </JadeMethod>
    <JadeMethod name="evaluateRateForContract" id="d46f6db3-3150-46a2-ab43-b11e2341a138">
        <source>evaluateRateForContract(_newRate : Decimal output; _newTotal : Decimal output; _contract : CM_InvoiceContract; _usingPrimary : Boolean) : Boolean;
/*
Purpose:			

Date			Who		Reason
13 January 2023	navab1	TFS CR 55644 TASK 55684
17/03/2023		navkc1	Bug 57002: EUP - Criteria Priority does not provide expected functionality
 // ### TFS BUG 57505 13APR2023 NAVAB1 added original invoice amount
03/11/2023		navkc1 Bug 61061: FR | 54089 - EUP - Contracts - Volume based Invoice line - UOM code is blank
18 Oct 2024		navlw1	JIRA MTN-33107: Invoice Logging Use Levels
25 Feb 2025	navah1	Story 34141: MTN - Performance Improvements - Review for invLog() Methods
*/

vars
	ti : CM_TrackedItem;
	contractId : String;
	debtor : CM_Debtor;
	dateTime : TimeStamp;
	bank : CM_Bank;
	invLine : CM_InvoiceLine;
	invLineType : CM_InvoiceLineDesc;
	service : CM_Service;
	contract : CM_InvoiceContract;
	iterContract, iterDetail, iterEntry : Iterator;
	calcType : CM_CalculationType;
	detail : CM_InvoiceContractDetails;
	detailVB : CM_InvoiceContractDtlsVolBased;
	rate : CM_InvoiceContractRate;
	accum : CM_InvoiceContractAccumulate;
	rangeAmount, invLineAmount, originalInvAmount : Real;
	updateAmount : Boolean;
	blockUnit, calcTypeType : Integer;
	uomType : Integer;
	uomObj : CM_InvoiceUnitOfMeasure;
	itemDesc : String;
	criteriaNoMatchReason : String;
	canLogExtra	: Boolean;	//26.02.2025 navah1	#34141
begin
	canLogExtra	:= app.canLogExtraDetail();	//26.02.2025 navah1	#34141
	ti := self.getTI();

	/*  // ### TFS CR 54345 TASK 54267 01JUN2023 NAVAB1
	// Only cargo billing
	
	if ti = null then
		return false;
	endif;
	*/
	
	itemDesc := self.getItemDescription(); // ### TFS CR 54345 TASK 54267 01JUN2023 NAVAB1
	
	bank := self.getBank();
	
	// 27FEB2023	NAVAB1	CR 54345 Task 54267  contractId := self.getContractId();
	
	contractId := _contract.contractId;
	debtor := _contract.myDebtor;
	dateTime := self.invoiceLine.chargeTime;
	invLine := self.invoiceLine;
	invLineType := invLine.invoiceLineDesc;
	service := self.service;
	
	if invLineType &lt;&gt; null then
		// default
		uomObj:= invLineType.myUOM;
		if uomObj &lt;&gt; null then
			uomType := uomObj.type;
		endif;
	endif;
	
	if debtor = null then
		if canLogExtra then	//26.02.2025 navah1	#34141
			app.invLog("CONT - NO DEBTOR for Contract " &amp; contractId, LogINFO.String);
		endif;
		return false;
	endif;
	
	
	contract := _contract;
	if contract = null then
		return false;
	endif;
	if canLogExtra then	//26.02.2025 navah1	#34141
		app.invLog("CONT - Attempt Contract Rates ITEM :" &amp; itemDesc &amp; " Invoice Line: " &amp; invLineType.narration &amp; " service: " &amp; service.name, LogINFO.String);
	endif;
	
	_newRate := 0;
	if canLogExtra then	//26.02.2025 navah1	#34141
		app.invLog("CONT - Found contract for debtor: " &amp; debtor.name &amp; " contract Id: " &amp; contract.contractId, LogINFO.String);
	endif;
	
	// ### TFS BUG 61892 29DEC2023 NAVAB1
	if canLogExtra then	//26.02.2025 navah1	#34141
		app.invLog("CONT - Searching contract details for date time : " &amp; dateTime.String &amp; " that matches TI by criteria for '" &amp; invLineType.narration &amp; "'", LogINFO.String);
	endif;
	
	//foreach detail in contract.allInvoiceContractDetailByFrom discreteLock 
	foreach detail in contract.allInvoiceContractDetails discreteLock, reversed // 17/03/2023	navkc1	#57002
		where detail.myInvoiceLineType = invLineType do

		if not _usingPrimary then
			if dateTime &lt; detail.fromTS  
			or dateTime&gt; detail.toTS then // detail not validate
				if canLogExtra then	//26.02.2025 navah1	#34141
					app.invLog("Detail not valid. charge date is " &amp; dateTime.String &amp; " Detail is " &amp; detail.fromTS.String &amp; " to " &amp; detail.toTS.String &amp; ".", LogINFO.String);
				endif;
				continue;
			endif;
		endif;
		
		if detail.myInvoiceContractCriteria &lt;&gt; null // ### TFS CR 56806 TASK 56807 15MAR2023 NAVAB1
		and ti &lt;&gt; null then  // ### TFS CR 54345 TASK 54267 01JUN2023 NAVAB1
 // ### TFS BUG 61892 29DEC2023 NAVAB1		if not detail.myInvoiceContractCriteria.matches(ti) then
			if not detail.myInvoiceContractCriteria.matchesReason(ti, criteriaNoMatchReason, null) then // ### TFS BUG 61892 29DEC2023 NAVAB1 get the reason
				// ### TFS BUG 61892 29DEC2023 NAVAB1
				if canLogExtra then	//26.02.2025 navah1	#34141
					app.invLog("CONT - CRITERIA NO MATCH, Ignored, '" &amp; detail.myInvoiceContractCriteria.description &amp; "' does not match criteria " &amp; criteriaNoMatchReason.toUpper(), LogINFO.String);
				endif;
				continue;
			endif;
			if canLogExtra then	//26.02.2025 navah1	#34141
				app.invLog("CONT - Detail " &amp; detail.fromTS.String &amp; "/" &amp; detail.toTS.String &amp; " MATCH, does match criteria :'" &amp; detail.myInvoiceContractCriteria.description &amp; "'", LogINFO.String);
			endif;
		else
			if canLogExtra then	//26.02.2025 navah1	#34141
				app.invLog("CONT - Detail " &amp; detail.fromTS.String &amp; "/" &amp; detail.toTS.String &amp; " Using NO criteria'", LogINFO.String);
			endif;
		endif;
		
		rate := detail.allInvContractRatesByService[service];
		if rate = null then
			if canLogExtra then	//26.02.2025 navah1	#34141
				app.invLog("CONT - Service " &amp; service.name &amp; " Ignored, is not mapped with rates", LogINFO.String);
			endif;
			continue;

		endif;
		
		if canLogExtra then	//26.02.2025 navah1	#34141
			app.invLog("CONT - Need amount to use for rate entry amount range", LogINFO.String);
		endif;
		if detail.contractType = INV_CONTRACT_TYPE_VOLUME_BASED then // ### TFS CR 55624 TASK 55700 24JAN2023 NAVAB1
			if canLogExtra then	//26.02.2025 navah1	#34141
				app.invLog("CONT - VOLUME BASED contract detail found", LogINFO.String); 
			endif;
			detailVB := detail.CM_InvoiceContractDtlsVolBased;
			calcType := detailVB.myCalculationType;
			if detail.myUnitOfMeasure &lt;&gt; null then
				uomType := detail.myUnitOfMeasure.type;
			endif;
			
			updateAmount := false;
			
			accum := detailVB.getContractAccumulation(invLine); // Gets and creates if necessary, it performs the accumulation as well
			
			if calcType = null  // ### TFS BUG 57395 30MAR2023 NAVAB1
			or accum = null then // ### TFS BUG 57395 30MAR2023 NAVAB1
				// ### TFS BUG 57395 30MAR2023 NAVAB1
				if canLogExtra then	//26.02.2025 navah1	#34141
					app.invLog("CONT - Matched to volume based but wrong transaction type or does not match 'receival' type, Ignoring detail " &amp; detail.auditId(), LogTRACE.String);		
				endif;
				continue; // ### TFS BUG 57395 30MAR2023 NAVAB1
			else
				if canLogExtra then	//26.02.2025 navah1	#34141
					app.invLog("CONT - Deriving volume based amount from calc type: " &amp; calcType.description &amp; " UOM type: " &amp; app.getUOMInttoStr(uomType), LogTRACE.String);
				endif;
				// ### GET RANGE AMOUNT TO GET RATE
				if uomType = Invoice_UOM_Type_Weight then
					rangeAmount := accum.accumulatedWeight;
					originalInvAmount :=  invLine.getTrackedItemWeight(); // ### TFS BUG 57505 13APR2023 NAVAB1
				elseif uomType = Invoice_UOM_Type_Volume then
					originalInvAmount :=  invLine.getTrackedItemVolume(); // ### TFS BUG 57505 13APR2023 NAVAB1
					rangeAmount := accum.accumulatedVolume;
				elseif uomType = Invoice_UOM_Type_TEU then
					rangeAmount := accum.accumulatedTEU;
					if ti &lt;&gt; null then // ### TFS BUG 57505 13APR2023 NAVAB1
						originalInvAmount:= ti.getNumTEUDeci(); // ### TFS BUG 57505 13APR2023 NAVAB1
					endif;
					
				elseif uomType = Invoice_UOM_Type_Quantity then // quantity
					rangeAmount := accum.accumulatedQuantity;
					originalInvAmount :=  invLine.getTrackedItemQuantity(); // ### TFS BUG 57505 13APR2023 NAVAB1
				endif;
				
				if rangeAmount = 0 then
					if canLogExtra then	//26.02.2025 navah1	#34141
						app.invLog("CONT - Volume amount is ZERO (calc type is not weight, volume or quantity based) using amount on invoice line " &amp; invLine.quantity.String, LogINFO.String);
					endif;
					rangeAmount := invLine.quantity;
				else
					if canLogExtra then	//26.02.2025 navah1	#34141
						app.invLog("CONT - Derived accumulated amount " &amp; rangeAmount.String, LogINFO.String);
					endif;
				endif;
				
				// ### LINE AMOUNT TO UPDATE INVOICE LINE WITH
				// ### TFS CR 61579 TASK 62473 13FEB2024 NAVAB1				calcType := detail.myCalculationType;
				if calcType &lt;&gt; null then
					if canLogExtra then	//26.02.2025 navah1	#34141
						app.invLog("CONT - Deriving invoice line quantity from calc type: " &amp; calcType.description, LogINFO.String);
					endif;
					calcTypeType := calcType.calculationType;
					if invLine.myTransactionTI &lt;&gt; null then // ### TFS BUG 61892 29DEC2023 NAVAB1
						if calcTypeType = INV_CALC_TYPE_BUSHRSCARGOVALUE then // PAR 30681
							if calcType &lt;&gt; null then
								blockUnit := calcType.theCalcTypeUnit;
							else
								blockUnit := INV_CALC_TYPE_UNITY; // value of 1
							endif;
							invLineAmount := invLine.quantityCARGObyType(blockUnit, true);
						elseif (calcTypeType = INV_CALC_TYPE_CARGOWEIGHTCONVT
							or calcTypeType = INV_CALC_TYPE_CARGOLENGTHCONVT
							or calcTypeType = INV_CALC_TYPE_CARGOVOLUMECONVT) then
								invLineAmount := invLine.quantityCARGObyMeasurement(calcTypeType);
						else
							invLineAmount := invLine.quantityCARGObyType(calcTypeType, false);
						endif;
					elseif invLine.myTransactionEvent &lt;&gt; null then // ### TFS BUG 61892 29DEC2023 NAVAB1
						if invLine.myTransactionEvent.isLocationActivityEvent() then
							invLineAmount := invLine.quantityInventoryCalcType(calcType);
						else
							invLineAmount := invLine.quantityEventCalcType(calcType);
						endif;
					elseif invLine.myTransactionWO &lt;&gt; null then // ### TFS BUG 61892 29DEC2023 NAVAB1
							invLineAmount := invLine.quantityWorkOrderCalcType(calcType);
					elseif invLine.myTransactionHMS &lt;&gt; null then // ### TFS BUG 61892 29DEC2023 NAVAB1
							invLineAmount := invLine.quantityVOYAGECalcType(calcType);
					endif;
					
					if invLineAmount = 0 then
						if canLogExtra then	//26.02.2025 navah1	#34141
							app.invLog("CONT - invoice line quantity is ZERO using amount on invoice line " &amp; invLine.quantity.String, LogINFO.String);
						endif;
						invLineAmount := invLine.quantity;
					else
						if canLogExtra then	//26.02.2025 navah1	#34141
							app.invLog("CONT - Derived invoice line quantity is " &amp; invLineAmount.String, LogINFO.String);
						endif;
					endif;
					
					updateAmount := invLineAmount &lt;&gt; invLine.quantity; // Amount is changing?
					
					
				else
					if canLogExtra then	//26.02.2025 navah1	#34141
						app.invLog("CONT - Using amount on invoice line " &amp; invLine.quantity.String, LogINFO.String);
					endif;
					rangeAmount := invLine.quantity;
				endif;			
			endif;
		else
			if canLogExtra then	//26.02.2025 navah1	#34141
				app.invLog("CONT - STANDARD contract detail found", LogINFO.String);
			endif;
			calcType := detail.myCalculationType;
			if calcType &lt;&gt; null then
				if canLogExtra then	//26.02.2025 navah1	#34141
					app.invLog("CONT - Deriving invoice line quantity from calc type: " &amp; calcType.description, LogINFO.String);
				endif;
				calcTypeType := calcType.calculationType;
				if invLine.myTransactionTI &lt;&gt; null then // ### TFS BUG 61892 29DEC2023 NAVAB1
					if calcTypeType = INV_CALC_TYPE_BUSHRSCARGOVALUE then // PAR 30681
						if calcType &lt;&gt; null then
							blockUnit := calcType.theCalcTypeUnit;
						else
							blockUnit := INV_CALC_TYPE_UNITY; // value of 1
						endif;
						invLineAmount := invLine.quantityCARGObyType(blockUnit, true);
					elseif (calcTypeType = INV_CALC_TYPE_CARGOWEIGHTCONVT
						or calcTypeType = INV_CALC_TYPE_CARGOLENGTHCONVT
						or calcTypeType = INV_CALC_TYPE_CARGOVOLUMECONVT) then
							invLineAmount := invLine.quantityCARGObyMeasurement(calcTypeType);
					else
						invLineAmount := invLine.quantityCARGObyType(calcTypeType, false);
					endif;
				elseif invLine.myTransactionEvent &lt;&gt; null then // ### TFS BUG 61892 29DEC2023 NAVAB1
					if invLine.myTransactionEvent.isLocationActivityEvent() then
						invLineAmount := invLine.quantityInventoryCalcType(calcType);
					else
						invLineAmount := invLine.quantityEventCalcType(calcType);
					endif;
				elseif invLine.myTransactionWO &lt;&gt; null then // ### TFS BUG 61892 29DEC2023 NAVAB1
						invLineAmount := invLine.quantityWorkOrderCalcType(calcType);
				elseif invLine.myTransactionHMS &lt;&gt; null then // ### TFS BUG 61892 29DEC2023 NAVAB1
						invLineAmount := invLine.quantityVOYAGECalcType(calcType);
				endif;
				
				if invLineAmount = 0 then
					if canLogExtra then	//26.02.2025 navah1	#34141
						app.invLog("CONT - invoice line quantity is ZERO using amount on invoice line " &amp; invLine.quantity.String, LogINFO.String);
					endif;
					invLineAmount := invLine.quantity;
				else
					if canLogExtra then	//26.02.2025 navah1	#34141
						app.invLog("CONT - Derived invoice line quantity is " &amp; invLineAmount.String, LogINFO.String);
					endif;
				endif;
				if invLineAmount = 0 then // ### TFS CR 54345 TASK 54267 01JUN2023 NAVAB1
					// ### TFS CR 54345 TASK 54267 01JUN2023 NAVAB1
					if canLogExtra then	//26.02.2025 navah1	#34141
						app.invLog("CONT - invoice line quantity is still ZERO using value of one ", LogINFO.String);
					endif;
					invLineAmount := 1; // ### TFS CR 54345 TASK 54267 01JUN2023 NAVAB1
				endif;

// ### TFS CR 61579 TASK 62473 13FEB2024 NAVAB1				invLineAmount := rangeAmount;
				
				updateAmount := invLineAmount &lt;&gt; invLine.quantity; // Amount is changing?
				
			else
				if canLogExtra then	//26.02.2025 navah1	#34141
					app.invLog("CONT - Using default quantity on invoice line " &amp; invLine.quantity.String, LogINFO.String);
				endif;
				rangeAmount := invLine.quantity;
			endif;
			
		
		endif;
		
// ### TFS CR 61579 TASK 62473 13FEB2024 NAVAB1		rate := detail.allInvContractRatesByService[service];
		if rate &lt;&gt;  null then
			//03/11/2023	navkc1 Bug 61061 - Use the UOM from Invoice Contract Details if there is one.
			if detail.myUnitOfMeasure &lt;&gt; null then
				uomObj:= detail.myUnitOfMeasure;
			endif;
			
			if detail.contractType = INV_CONTRACT_TYPE_VOLUME_BASED then // ### TFS CR 55624 TASK 55700 07FEB2023 NAVAB1
				/* //03/11/2023	navkc1 Bug 61061
				// ### TFS CR 55653 TASK 55669 20JUN2023 NAVAB1
				if uomObj = null then
					uomObj:= detail.myUnitOfMeasure;
				endif;
				*/
				if rate.evaluateRateVolumeBased(_usingPrimary,_newRate,_newTotal, uomObj, updateAmount, rangeAmount, invLineAmount, originalInvAmount, dateTime, invLine, service, calcType) then // ### TFS BUG 57505 19APR2023 NAVAB1 added calcType
					 // ### TFS BUG 57729 28APR2023 NAVAB1 - stamp the volume based accumulated values on each of the charges.
					 /* // ### TFS CR 55653 TASK 55669 20JUN2023 NAVAB1
					if accum &lt;&gt; null then
						foreach charge in invLine.charges discreteLock do
							charge.contractVBAccumulatedQuantity := accum.accumulatedQuantity;
							charge.contractVBAccumulatedTEU := accum.accumulatedTEU;
							charge.contractVBAccumulatedVolume := accum.accumulatedVolume;
							charge.contractVBAccumulatedWeight := accum.accumulatedWeight;
						endforeach;
					endif;
					*/
					
					detail.logDetailUsed(rate); // ### TFS BUG 61096 21NOV2023 NAVAB1 // ### TFS CR 61579 TASK 62473 13FEB2024 NAVAB1
					return true;
				endif;
			
	
			else
				// ### TFS CR 61579 TASK 62473 13FEB2024 NAVAB1
				calcType := rate.myCalculationType;
				if calcType &lt;&gt; null then
					if canLogExtra then	//26.02.2025 navah1	#34141
						app.invLog("CONT - Deriving invoice line quantity from calc type: " &amp; calcType.description, LogINFO.String);
					endif;
					calcTypeType := calcType.calculationType;
					if invLine.myTransactionTI &lt;&gt; null then // ### TFS BUG 61892 29DEC2023 NAVAB1
						if calcTypeType = INV_CALC_TYPE_BUSHRSCARGOVALUE then // PAR 30681
							if calcType &lt;&gt; null then
								blockUnit := calcType.theCalcTypeUnit;
							else
								blockUnit := INV_CALC_TYPE_UNITY; // value of 1
							endif;
							rangeAmount := invLine.quantityCARGObyType(blockUnit, true);
						elseif (calcTypeType = INV_CALC_TYPE_CARGOWEIGHTCONVT
							or calcTypeType = INV_CALC_TYPE_CARGOLENGTHCONVT
							or calcTypeType = INV_CALC_TYPE_CARGOVOLUMECONVT) then
								rangeAmount := invLine.quantityCARGObyMeasurement(calcTypeType);
						else
							rangeAmount := invLine.quantityCARGObyType(calcTypeType, false);
						endif;
					elseif invLine.myTransactionEvent &lt;&gt; null then // ### TFS BUG 61892 29DEC2023 NAVAB1
						if invLine.myTransactionEvent.isLocationActivityEvent() then
							rangeAmount := invLine.quantityInventoryCalcType(calcType);
						else
							rangeAmount := invLine.quantityEventCalcType(calcType);
						endif;
					elseif invLine.myTransactionWO &lt;&gt; null then // ### TFS BUG 61892 29DEC2023 NAVAB1
							rangeAmount := invLine.quantityWorkOrderCalcType(calcType);
					elseif invLine.myTransactionHMS &lt;&gt; null then // ### TFS BUG 61892 29DEC2023 NAVAB1
							rangeAmount := invLine.quantityVOYAGECalcType(calcType);
					endif;
					
					if rangeAmount = 0 then
						if canLogExtra then	//26.02.2025 navah1	#34141
							app.invLog("CONT - invoice line quantity is ZERO using amount on invoice line " &amp; invLine.quantity.String &amp; calcType.description, LogINFO.String);
						endif;
						rangeAmount := invLine.quantity;
					else
						if canLogExtra then	//26.02.2025 navah1	#34141
							app.invLog("CONT - Derived invoice line quantity is " &amp; rangeAmount.String, LogINFO.String);
						endif;
					endif;
					if rangeAmount = 0 then // ### TFS CR 54345 TASK 54267 01JUN2023 NAVAB1
						// ### TFS CR 54345 TASK 54267 01JUN2023 NAVAB1
						if canLogExtra then	//26.02.2025 navah1	#34141
							app.invLog("CONT - invoice line quantity is still ZERO using value of one ", LogINFO.String);
						endif;
						rangeAmount := 1; // ### TFS CR 54345 TASK 54267 01JUN2023 NAVAB1
					endif;

					updateAmount := invLineAmount &lt;&gt; invLine.quantity; // Amount is changing?
					
				else
					if canLogExtra then	//26.02.2025 navah1	#34141
						app.invLog("CONT - Using default quantity on invoice line " &amp; invLine.quantity.String, LogINFO.String);
					endif;
					rangeAmount := invLine.quantity;
				endif;
// ### TFS CR 61579 TASK 62473 13FEB2024 NAVAB1
			
			
			
			
				if rate.evaluateRate(_usingPrimary, _newRate, uomObj,updateAmount,rangeAmount,invLineAmount, dateTime, invLine) then
					
					detail.logDetailUsed(rate); // ### TFS BUG 61096 21NOV2023 NAVAB1 // ### TFS CR 61579 TASK 62473 13FEB2024 NAVAB1
					return true;
				endif;

			endif;
		endif;
	endforeach;
	// ### TFS CR 54345 TASK 54267 01JUN2023 NAVAB1 itemDesc
	if canLogExtra then	//26.02.2025 navah1	#34141
		app.invLog("CONT - No valid rate can be found for ITEM: " &amp; itemDesc &amp; " Invoice Line: " &amp; invLineType.narration &amp; " service: " &amp; service.name, LogINFO.String);
	endif;
	return false;
epilog
	delete iterContract;
	delete iterDetail;
	delete iterEntry;
end;</source>
        <Parameter name="_newRate" type="Decimal" usage="output"/>
        <Parameter name="_newTotal" type="Decimal" usage="output"/>
        <Parameter name="_contract" type="CM_InvoiceContract"/>
        <Parameter name="_usingPrimary" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="exportAsXMLDoc" id="da133b1f-5011-4574-9ff4-295374514ff6">
        <source>exportAsXMLDoc(_file: File);

vars

	allProperties : PropertyColl;
	property : Property;
	ti : CM_TrackedItem;
	imexStatus,
	operatorCode,
	billOfLading,
	bookingReference,
	operatorDescription,	
	directDelivery,		
	consignee,
	consigneeDesc,
	shippingReference,
	cargoType,
	cargoTypeDescr ,
	subCargoTypeCode,
	subCargoTypeDesc,
	commodityCode,	
	commodityDesc,
	cargoId,
	totalQuantity,
	totalWeight,
	totalVolume,
	hazList,
 	hazListDisc,
	dwellDays,
	isOverDimensions,
	isHazardous	,
	weightUom,
	volumeUom,
	qtyUom,
	hmsResCode,
	hmsResDesc,
	hmsResFrom,
	hmsResTo,
	hmsResUnits,
	hmsResUOM,
	todoCode,
	todoDesc		: String;
	isImport		: Boolean;
begin
			
	
	allProperties:=self.class.allProperties();
	foreach property in allProperties do
		if property.isKindOf(Reference) then		
			self.exportAsXMLDocReference(property.Reference,_file);							
		elseif  property.isKindOf(Attribute) then
			self.exportAsXMLDocAttribute(property.Attribute,_file);
		endif;
	endforeach;
	
	_file.writeString(self.formatAsXML("taxRate", self.getTaxRateForCharge().String.xmlReplaceReservedChars(true)));
	_file.writeString(self.formatAsXML("taxCode", self.getTaxCode(false).String.xmlReplaceReservedChars(true)));
	_file.writeString(self.formatAsXML("sequenceNum", self.invoiceLine.sequenceNum.String.xmlReplaceReservedChars(true)));
	_file.writeString(self.formatAsXML("narration", self.invoiceLine.invoiceLineDesc.narration.String.xmlReplaceReservedChars(true)));
	_file.writeString(self.formatAsXML("quantity", self.invoiceLine.quantity.String.xmlReplaceReservedChars(true)));
	_file.writeString(self.formatAsXML("salesUom", self.invoiceLine.invoiceLineDesc.unitNarration.xmlReplaceReservedChars(true)));
	_file.writeString(self.formatAsXML("rate", self.rate.String.xmlReplaceReservedChars(true)));
	_file.writeString(self.formatAsXML("name", self.service.name.String.xmlReplaceReservedChars(true)));
	
	ti := self.getTI();
	if ti&lt;&gt; null then
		imexStatus 			:= ti.getImExStatusString;
		billOfLading 		:= ti.billOfLading;
		bookingReference 	:= ti.bookingReference;
		isImport			:= ti.isImport;
		directDelivery 		:= ti.directDelivery.String;
		consignee 			:= ti.consignee;
		shippingReference 	:= ti.shippingReference;
		consigneeDesc 		:= ti.getConsigneeDesc;
		operatorCode 		:= ti.operatorCode;
		operatorDescription := ti.operatorDescription;
		cargoType 			:= ti.cargoType.String;
		cargoTypeDescr 		:= ti.cargoTypeDescr;
		subCargoTypeCode 	:= ti.getCargoSubTypeCode;
		if ti.myProduct &lt;&gt; null then
			subCargoTypeDesc 	:= ti.myProduct.description;
		endif;
		commodityCode 		:= ti.commodity;
		commodityDesc 		:= ti.getCommodityDesc;
		cargoId       		:= ti.id;
		totalQuantity  		:= ti.totalQuantity.String;
		totalWeight    		:= ti.totalWeight.String;
		totalVolume    		:= ti.totalVolume.String;
		isHazardous			:= ti.isHazardous.String;
		hazList				:= ti.getHazardsAsString;
		hazListDisc			:= ti.getHazardsDescAsString;
		isOverDimensions    := ti.isOverDimensions.String;
		dwellDays			:= ti.getDwellDays.String;
		qtyUom				:= "qty";
		if ti.myTerminal &lt;&gt; null then
			weightUom:= ti.myTerminal.getDefaultMeasurementForType(Type_Weight).shortName;
			volumeUom := ti.myTerminal.getDefaultMeasurementForType(Type_Volume).shortName;
		else
			weightUom :="kg";
			volumeUom :="m3";
		endif;
	endif;
	
	
	_file.writeString(self.formatAsXML("imexStatus",      imexStatus.xmlReplaceReservedChars(true)));
	_file.writeString(self.formatAsXML("operator",        operatorCode.xmlReplaceReservedChars(true)));
	_file.writeString(self.formatAsXML("operatorName",    operatorDescription.xmlReplaceReservedChars(true)));
	
	if isImport then
		_file.writeString(self.formatAsXML("bolBook",      billOfLading.xmlReplaceReservedChars(true)));
	else
		_file.writeString(self.formatAsXML("bolBook", 	   bookingReference.xmlReplaceReservedChars(true)));
	endif;
	
	_file.writeString(self.formatAsXML("directDelivery",   directDelivery.String.xmlReplaceReservedChars(true)));
	
	if consignee  &lt;&gt; null then 
		_file.writeString(self.formatAsXML("conShipCode",  consignee.xmlReplaceReservedChars(true)));
	else
		_file.writeString(self.formatAsXML("conShipCode",  shippingReference.xmlReplaceReservedChars(true)));
	endif;
	
	if consignee &lt;&gt; null then
		_file.writeString(self.formatAsXML("conShipDesc",  consigneeDesc.xmlReplaceReservedChars(true)));
	else
		_file.writeString(self.formatAsXML("conShipDesc",  shippingReference.xmlReplaceReservedChars(true)));
	endif;
	
	_file.writeString(self.formatAsXML("cargoTypeCode",    cargoType.xmlReplaceReservedChars(true)));
	_file.writeString(self.formatAsXML("cargoTypeDesc",    cargoTypeDescr .xmlReplaceReservedChars(true)));
	_file.writeString(self.formatAsXML("subCargoTypeCode", subCargoTypeCode.xmlReplaceReservedChars(true)));
	_file.writeString(self.formatAsXML("subCargoTypeDesc", subCargoTypeDesc.xmlReplaceReservedChars(true)));
	_file.writeString(self.formatAsXML("commodityCode",    commodityCode.xmlReplaceReservedChars(true)));
	_file.writeString(self.formatAsXML("commodityDesc",    commodityDesc.xmlReplaceReservedChars(true)));
	_file.writeString(self.formatAsXML("cargoId", 		   cargoId.xmlReplaceReservedChars(true)));
	
	_file.writeString(self.formatAsXML("totalQuantity",	   totalQuantity.xmlReplaceReservedChars(true)));
	_file.writeString(self.formatAsXML("totalQuantityUOM", qtyUom.xmlReplaceReservedChars(true)));
	
	_file.writeString(self.formatAsXML("totalWeight", 	   totalWeight.xmlReplaceReservedChars(true)));
	_file.writeString(self.formatAsXML("totalWeightUOM",   weightUom.xmlReplaceReservedChars(true)));

	_file.writeString(self.formatAsXML("totalVolume", 	   totalVolume.xmlReplaceReservedChars(true)));
	_file.writeString(self.formatAsXML("totalVolumeUOM",   volumeUom.xmlReplaceReservedChars(true)));

	
	_file.writeString(self.formatAsXML("isHazardous", 	   isHazardous.xmlReplaceReservedChars(true)));
	_file.writeString(self.formatAsXML("hazList", 		   hazList.xmlReplaceReservedChars(true)));
	_file.writeString(self.formatAsXML("hazListDesc",	   hazListDisc.xmlReplaceReservedChars(true)));
	_file.writeString(self.formatAsXML("isOverDimensions", isOverDimensions.xmlReplaceReservedChars(true)));
	_file.writeString(self.formatAsXML("dwellDays", 	   dwellDays.xmlReplaceReservedChars(true)));
	
	///ToDo Task
	if self.invoiceLine &lt;&gt; null 
	and self.invoiceLine.myTransactionTI &lt;&gt; null 
	and self.invoiceLine.myTransactionTI.getMyToDoTaskCode &lt;&gt; null then
		todoCode := self.invoiceLine.myTransactionTI.getMyToDoTaskCode.String;
		todoDesc := self.invoiceLine.myTransactionTI.getMyToDoTaskDescription;
	endif;
	_file.writeString(self.formatAsXML("todoCode",         todoCode.xmlReplaceReservedChars(true)));
	_file.writeString(self.formatAsXML("todoDesc",         todoDesc.xmlReplaceReservedChars(true)));
	
	///ToD Task Resources
	if self.invoiceLine &lt;&gt; null 
	and self.invoiceLine.myTransactionHMS &lt;&gt; null 
	and self.invoiceLine.myTransactionHMS.myResourceUsed &lt;&gt; null then
	
		hmsResCode := self.invoiceLine.myTransactionHMS.myResourceUsed.code;
		hmsResDesc := self.invoiceLine.myTransactionHMS.myResourceUsed.description;
		hmsResFrom := self.invoiceLine.myTransactionHMS.myResourceUsed.getFromDateTimeLocalTZ.Date.format("dd/MM/yyyy").String;
		hmsResTo   := self.invoiceLine.myTransactionHMS.myResourceUsed.getToDateTimeLocalTZ.Date.format("dd/MM/yyyy").String;
		hmsResUnits:= self.invoiceLine.myTransactionHMS.myResourceUsed.unitsUsed.String;
		hmsResUOM  := self.invoiceLine.myTransactionHMS.myResourceUsed.myResourceType.quantityUnits;
	endif;
	_file.writeString(self.formatAsXML("hmsResCode", 	   hmsResCode.xmlReplaceReservedChars(true)));
	_file.writeString(self.formatAsXML("hmsResDesc",       hmsResDesc.xmlReplaceReservedChars(true)));

	_file.writeString(self.formatAsXML("hmsResFrom",       hmsResFrom.xmlReplaceReservedChars(true)));
	_file.writeString(self.formatAsXML("hmsResTo",         hmsResTo.xmlReplaceReservedChars(true)));
	_file.writeString(self.formatAsXML("hmsResUnits",      hmsResUnits.xmlReplaceReservedChars(true)));
	_file.writeString(self.formatAsXML("hmsResUOM",        hmsResUOM.xmlReplaceReservedChars(true)));
	
	
epilog
	delete allProperties;

end;
</source>
        <Parameter name="_file" type="File"/>
    </JadeMethod>
    <JadeMethod name="exportAsXMLDocIgnoreAttr" id="be072d7b-fa7f-47f7-8fca-9ae9d28b61ec">
        <source>exportAsXMLDocIgnoreAttr(_property: Property input): Boolean;

vars

begin
	if _property = CM_Charge::invoiceLine then
		return true;
	elseif _property = CM_Charge::voidedFrominvoiceLine then
		return true;
	elseif _property = CM_Charge::status then
		return true;
	elseif _property = CM_Charge::isTotalSetExplicitly then
		return true;
	endif;
	
	return inheritMethod(_property);
end;
</source>
        <Parameter name="_property" type="Property" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="exportAsXMLInverseRef" id="b3ae8998-83c7-47b9-b100-0789fca97feb">
        <source>exportAsXMLInverseRef(_property: Reference): Integer protected;

vars

begin
	if _property = CM_Charge::service then
		return ExportAsParent;
	endif;
	return inheritMethod(_property);
end;
</source>
        <access>protected</access>
        <Parameter name="_property" type="Reference"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getAmountForCurrencyCode" id="74e32971-a3ac-4549-8239-81742dbdcd01">
        <source>getAmountForCurrencyCode( _typeCode : String ):Decimal;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 March 2018	jlgndl1	Initial creation	TFS 37550

*/

vars

	currencyType : CM_CurrencyType;
	rate : CM_CurrencyRate;
	effectiveDT : TimeStamp;

begin
	if self.invoiceLine &lt;&gt; null 
	and not self.invoiceLine.isCurrencyConversionRequired() then // TFS 41484
		return self.total;
	endif;


	if _typeCode.trimBlanks = null then
		return 0.0;
	endif;
	
	currencyType := app.myRoot.allCurrencyTypes.getAtKey(_typeCode).CM_CurrencyType;
	
	if currencyType = null then
		return 0.0;
	endif;
	
	//13 Jun 2018	NDL	TFS 39197
	effectiveDT := null;
	if self.invoiceLine &lt;&gt; null
	and self.invoiceLine.invoice &lt;&gt; null
	then
		effectiveDT := self.invoiceLine.invoice.getRateDateFromStatus();
	endif;
	
	if not effectiveDT.isValid() then
		effectiveDT := self.invoiceLine.chargeTime;
	endif;
	
	rate := currencyType.getRate( effectiveDT );
	if rate = null then
		return 0.0;
	endif;
	
	return rate.rate * self.total;

epilog

end;</source>
        <Parameter name="_typeCode" type="String"/>
        <ReturnType type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="getAuditText" id="f14f6ace-dd2f-4e92-bca4-ce509a4ef328">
        <source>getAuditText(): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 May 2018	jlgmp6	Initial creation	TFS37718

*/

vars
	txt,
	tmpStr: String;
begin
	txt[10000] 	:= '*';
	txt 		:= null;
	txt 		:= inheritMethod();

	tmpStr := null;
	if self.status = VOID then
		tmpStr := app.getErrorString(Void);
	elseif self.status = NORMAL then
		tmpStr := app.getErrorString(Normal);
	else
		tmpStr := app.getErrorString(Other);
	endif;
	txt := txt &amp; app.getErrorString(Status) &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp; tmpStr &amp; AuditStringSeparator;

	return txt;
	
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getBank" id="2f6fa95a-bc9c-42e9-9ec7-ad5f1747fe97">
        <source>getBank(): CM_Bank;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 August 2018	jlgmp6	Initial creation	TFS40270

*/

vars
	lbank : CM_Bank;
begin
	lbank := self.bank;
	
	if lbank = null then
		if self.invoiceLine &lt;&gt; null then
			lbank := self.invoiceLine.bank;
		endif;
	endif;
	
	if lbank = null then
		if self.invoiceLine &lt;&gt; null then
			if self.invoiceLine.invoiceLineDesc &lt;&gt; null then
				lbank := self.invoiceLine.invoiceLineDesc.getBank();
			endif;
		endif;
	endif;
	
	return lbank;
	
epilog

end;</source>
        <ReturnType type="CM_Bank"/>
    </JadeMethod>
    <JadeMethod name="getChargeTotalTen" id="c12178b9-95f5-4bd5-a9da-7031ac8da5a7">
        <source>getChargeTotalTen() : Decimal;
/*

Purpose:			Return total in 10 decimal

Parameters:			

Return Value:		

Date		Who		Reason
15/05/2025	navkc1 JIRA EPIC-34131 STORY-34815 GPHA | XML Invoice Export 10DC - Ten Decimal Place Methods

*/

vars
	invoiceStatus	: Integer;
	invalid			: Boolean;
	chargeTotal		: Decimal[23,10];
	invLine			: CM_InvoiceLine;
	inv				: CM_Invoice;
begin
	
	chargeTotal := 0; // Set this so it display 10 decimal 
	
	invLine := self.invoiceLine;
	
	if invLine = null then
		return chargeTotal;
	endif;
	
	inv := invLine.invoice;
	
	if inv = null then
		if self.isTotalSetExplicitly then
			chargeTotal := self.total;
		else
			chargeTotal := self.rate * invLine.quantity;
		endif;
		
		return chargeTotal;
	endif;
	
	on Exception do app.handleDeletedObject(exception, inv, invalid);
	
	invoiceStatus := inv.status;
	
	if invalid then
		return chargeTotal;
	endif;
	
	if self.status = VOID then
		chargeTotal := 0;
	else
		if 	invoiceStatus = CM_Invoice.INVOICE_POSTED or 
			invoiceStatus = CM_Invoice.INVOICE_POSTED_CREDIT or 
			invoiceStatus = CM_Invoice.INVOICE_POSTED_REVERSE or 
			invoiceStatus = CM_Invoice.INVOICE_PENDING_REVERSE then
			
			chargeTotal := self.total;
		elseif invLine.status = CM_InvoiceLine.STATUS_VOIDED then
			chargeTotal := 0;
		elseif self.isTotalSetExplicitly then
			chargeTotal := self.total;
		else
			chargeTotal := self.rate * invLine.quantity;
		endif;
	endif;
	
	return chargeTotal;
	
epilog

end;</source>
        <ReturnType type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="getChargeTotalTenStr" id="5df83c2c-c45f-42fc-a159-97fdc51d7d09">
        <source>getChargeTotalTenStr() : String;
/*

Purpose:			created for JRW so it displays 10 decimals

Parameters:			

Return Value:		

Date		Who		Reason
//19/05/2025	navkc1 JIRA EPIC-34131 STORY-34816

*/

vars

begin
	return self.getChargeTotalTen().String;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getContractAndEvaluate" id="fb46c3cb-11ac-4cbd-89d4-987c7fce8724">
        <source>getContractAndEvaluate(_newRate : Decimal output; _newTotal : Decimal output) : Boolean; // this boolean is to say whether a contract rate was found
/*
Purpose:			

Date			Who		Reason
13 January 2023	navab1	TFS CR 55644 TASK 55684
18 Oct 2024		navlw1	JIRA-33107: Invoice Logging Use Levels
25 Feb 2025	navah1	Story 34141: MTN - Performance Improvements - Review for invLog() Methods
*/

vars
	ti : CM_TrackedItem;
	contractId : String;
	debtor : CM_Debtor;
	dateTime : TimeStamp;
	bank : CM_Bank;
	invLine : CM_InvoiceLine;
	invLineType : CM_InvoiceLineDesc;
	service : CM_Service;
	contract : CM_InvoiceContract;
	iterContract, iterDetail, iterEntry : Iterator;
	found : Boolean;
	calcType : CM_CalculationType;
	detail : CM_InvoiceContractDetails;
	rate : CM_InvoiceContractRate;
	entry : CM_InvoiceContractRateEntry;
	amount : Real;
	blockUnit, calcTypeType : Integer;
	usingPrimary, rateFound : Boolean;
	canLogExtra : Boolean;	//26.02.2025 navah1	#34141
begin
	canLogExtra	:= app.canLogExtraDetail();				//26.02.2025 navah1	#34141
	// Only cargo billing
	ti := self.getTI();
	
	/*  // ### TFS CR 54345 TASK 54267 01JUN2023 NAVAB1
	if ti = null then
		return false;
	endif;
	*/
	bank := self.getBank();
	
	// ## no contracts defined
	if bank.allInvoiceContractsById.isEmpty then
		return false;
	endif;
	
 // ### TFS 57512 12APR2023 NAVAB1	contractId := ti.contractId;
	debtor := self.getMyDebtor();
	dateTime := self.invoiceLine.chargeTime;
	invLine := self.invoiceLine;
	invLineType := invLine.invoiceLineDesc;
	service := self.service;
	
	if debtor = null then
		if canLogExtra then	//26.02.2025 navah1	#34141
			app.invLog("CONT - NO DEBTOR for Contract " &amp; contractId, LogINFO.String);
		endif;
		return false;
	endif;
	
	
	usingPrimary := self.getContractForDebtor(contract);
	if contract = null then
		return false;
	endif;
	contractId := contract.contractId; // ### TFS 57512 12APR2023 NAVAB1
	
	_newRate := 0;
	
	// if 'usingPrimary' is true, we are using the primary because there were no valid contracts, so we use the primary contract and we do not check dates
	rateFound := self.evaluateRateForContract(_newRate,_newTotal,contract, usingPrimary);
	
	// ### 16MAR2023	NAVAB1	BUG 57016
	if contract.myDebtor &lt;&gt; self.invoiceLine.debtor then
		self.invoiceLine.debtorChange(contract.myDebtor);
	endif;
	
	if rateFound then
		if canLogExtra then	//26.02.2025 navah1	#34141
			app.invLog("CONT - Using contract " &amp; contract.contractId &amp; " for debtor " &amp; contract.myDebtor.name &amp; " for rate", LogINFO.String);
		endif;
	endif;
	
	return rateFound;


epilog
	delete iterContract;
	delete iterDetail;
	delete iterEntry;
end;</source>
        <Parameter name="_newRate" type="Decimal" usage="output"/>
        <Parameter name="_newTotal" type="Decimal" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getContractForDebtor" id="c53b657b-d30a-4caa-b195-75ee0eb206e5">
        <source>getContractForDebtor(_contractToUse : CM_InvoiceContract output) : Boolean; // this boolean is for whether we are using the primary because could find not valid contract
/*
Purpose:			

Date			Who		Reason
13 January 2023	navab1	TFS CR 55644 TASK 55684
17/03/2023		navkc1	Bug 57002: EUP - Criteria Priority does not provide expected functionality
18 Oct 2024		navlw1	JIRA MTN-33107: Invoice Logging Use Levels
25 Feb 2025	navah1	Story 34141: MTN - Performance Improvements - Review for invLog() Methods
*/

vars
	ti : CM_TrackedItem;
	contractId, contractMessage, itemDesc : String;
	debtor, shipTermDebtor, incoDebtor : CM_Debtor;
	dateTime : TimeStamp;
	bank : CM_Bank;
	invLine : CM_InvoiceLine;
	invLineType : CM_InvoiceLineDesc;
	service : CM_Service;
	contract, shipTermContract : CM_InvoiceContract;
	iterContract, iterDetail, iterEntry : Iterator;
	detail : CM_InvoiceContractDetails;
	shipTermMapping : CM_InvoiceShipTermMapping;
	debtorType : CM_DebtorType;
	usingPrimary : Boolean;
	criteriaNoMatchReason : String;
	foundLineType : Boolean;
	trans : CM_TITransaction;
	incoUsed : Boolean;
	canLogExtra	: Boolean;	//26.02.2025 navah1	#34141
begin
	canLogExtra	:= app.canLogExtraDetail(); //26.02.2025 navah1	#34141
	ti := self.getTI();
	
	/* // ### TFS CR 54345 TASK 54267 01JUN2023 NAVAB1
	// Only cargo billing
	if ti = null then
		_contractToUse := null;
		return false;
	endif;
	*/

	bank := self.getBank();
	
	// ## no contracts defined
	if bank.allInvoiceContractsById.isEmpty then
		_contractToUse := null;
		return false;
	endif;
	
	invLine := self.invoiceLine;
	
	trans := invLine.myTransactionTI;// ### TFS CR 58263 TASK 58264 07FEB2024 NAVAB1
	
	/* // ### TFS 57512 12APR2023 NAVAB1
	contractId := invLine.contractId;
	if contractId = null then
		contractId := ti.contractId;
	endif;
	*/
	
	 // ### TFS CR 54345 TASK 54267 01JUN2023 NAVAB1
	itemDesc := self.getItemDescription();

	contractId := self.getContractId(); // ### TFS 57512 12APR2023 NAVAB1
		
	debtor := self.getMyDebtor();
	dateTime := self.invoiceLine.chargeTime;
	invLineType := invLine.invoiceLineDesc;
	service := self.service;
	
	if debtor = null then
		if canLogExtra then	//26.02.2025 navah1	#34141
			app.invLog("CONT - NO DEBTOR for Contract " &amp; contractId, LogINFO.String);
		endif;
		_contractToUse := null;
		return false;
	endif;
	
	contractMessage := "BLANK";
	if contractId &lt;&gt; null then
		contractMessage := contractId ;
	endif;
	if canLogExtra then	//26.02.2025 navah1	#34141
		app.invLog("CONT - Attempt Contract Debtor: " &amp; debtor.name &amp; " ContractId: " &amp; contractMessage &amp; " ITEM: " &amp; itemDesc &amp; " Invoice Line: " &amp; invLineType.narration &amp; " service: " &amp; service.name, LogTRACE.String);
	endif;
	if contractId = null then // ### BUG 57145 20MAR2023 NAVAB1
		if canLogExtra then	//26.02.2025 navah1	#34141
			app.invLog("CONT - No contract Id on ITEM: " &amp; itemDesc &amp; ", using PRIMARY contract for  " &amp; debtor.name, LogDEBUG.String);
		endif;
/*
			_contractToUse := null; // ### BUG 57145 20MAR2023 NAVAB1
			return false; // ### BUG 57145 20MAR2023 NAVAB1
			*/
		// use the primary
		contract := debtor.getContractPrimary(bank, dateTime); // ### TFS CR 54345 TASK 54267 01JUN2023 NAVAB1 // ### TFS BUG 60627 15NOV2023 NAVAB1 use BU and date
		usingPrimary := true; // ### TFS BUG 59807 14AUG2023 NAVAB1
	else // ### TFS CR 54345 TASK 54267 01JUN2023 NAVAB1
		contract := debtor.allInvoiceContracts[bank, contractId]; // contracts are unique by ID within the BU
	endif; // ### BUG 57145 20MAR2023 NAVAB1
	

	// Is the contract VALID.
	if contract &lt;&gt; null then
		if dateTime &lt; contract.fromTS  
		or dateTime&gt; contract.toTS then
			contract := null; // contract not validate
		elseif not contract.active then
			contract := null; // contract not validate
		endif;
	endif;
	
	// No matching valid contract just use the primary contract.
	if contract = null then
		if canLogExtra then	//26.02.2025 navah1	#34141
			app.invLog("CONT - Active contract NOT found for correct date time, debtor and contract Id. Attempt PRIMARY", LogDEBUG.String);
		endif;
		contract := debtor.getContractPrimary(bank, dateTime); // ### TFS BUG 60627 15NOV2023 NAVAB1 use BU and date
		if contract = null then
			if canLogExtra then	//26.02.2025 navah1	#34141
				app.invLog("CONT - PRIMARY contract NOT found for debtor " &amp; debtor.name, LogTRACE.String);
			endif;
			_contractToUse := null;
			return false;
		else
			if canLogExtra then	//26.02.2025 navah1	#34141
				app.invLog("CONT - PRIMARY contract found for debtor " &amp; debtor.name, LogINFO.String);
			endif;
			usingPrimary := true;
		endif;
	endif;
	

	if contract &lt;&gt; null 
	and debtor = contract.myDebtor then
		if canLogExtra then	//26.02.2025 navah1	#34141
			app.invLog("CONT - Found contract for debtor: " &amp; debtor.name &amp; " contract Id: " &amp; contract.contractId, LogINFO.String);
			// ### TFS BUG 61892 29DEC2023 NAVAB1
			app.invLog("CONT - Searching contract details for date time : " &amp; dateTime.String &amp; " that matches TI by criteria for '" &amp; invLineType.narration &amp; "'", LogINFO.String);
		endif;
		//foreach detail in contract.allInvoiceContractDetailByFrom discreteLock 
		foreach detail in contract.allInvoiceContractDetails discreteLock, reversed // 17/03/2023	navkc1	#57002
			where detail.myInvoiceLineType = invLineType do
			foundLineType := true;
			if not usingPrimary then // if falsed to use the primary because the contracts are not valid, then we must ignore the dates.
				if dateTime &lt; detail.fromTS  
				or dateTime&gt; detail.toTS then // detail not validate
					if canLogExtra then	//26.02.2025 navah1	#34141
						app.invLog("CONT - Detail not valid. charge date is " &amp; dateTime.String &amp; " Detail is " &amp; detail.fromTS.String &amp; " to " &amp; detail.toTS.String &amp; ".", LogINFO.String);
					endif;
					continue;
				endif;
			endif;
			
			if detail.myInvoiceContractCriteria &lt;&gt; null  // ### TFS CR 56806 TASK 56807 15MAR2023 NAVAB1
			and ti &lt;&gt; null then // ### TFS CR 54345 TASK 54267 01JUN2023 NAVAB1
				 // ### TFS BUG 61892 29DEC2023 NAVAB1if not detail.myInvoiceContractCriteria.matches(ti) then
				if not detail.myInvoiceContractCriteria.matchesReason(ti, criteriaNoMatchReason, null) then // ### TFS BUG 61892 29DEC2023 NAVAB1 - get the reason
					// ### TFS BUG 61892 29DEC2023 NAVAB1
					if canLogExtra then	//26.02.2025 navah1	#34141
						app.invLog("CONT - CRITERIA NO MATCH, Ignored, '" &amp; detail.myInvoiceContractCriteria.description &amp; "' does not match criteria " &amp; criteriaNoMatchReason.toUpper(), LogINFO.String);
					endif;
					continue;
				endif;
				if canLogExtra then	//26.02.2025 navah1	#34141
					app.invLog("CONT - Detail " &amp; detail.fromTS.String &amp; "/" &amp; detail.toTS.String &amp; " MATCH, does match criteria :'" &amp; detail.myInvoiceContractCriteria.description, LogINFO.String);
				endif;
			else
				if detail.myInvoiceContractCriteria = null then // ### TFS CR 54345 TASK 54267 01JUN2023 NAVAB1
					// ### TFS CR 56806 TASK 56807 15MAR2023 NAVAB1
					if canLogExtra then	//26.02.2025 navah1	#34141
						app.invLog("CONT - Detail " &amp; detail.fromTS.String &amp; "/" &amp; detail.toTS.String &amp; " USING, has no criteria'", LogINFO.String);
					endif;
				else
					 // ### TFS CR 54345 TASK 54267 01JUN2023 NAVAB1
					if canLogExtra then	//26.02.2025 navah1	#34141
						app.invLog("CONT - Detail " &amp; detail.fromTS.String &amp; "/" &amp; detail.toTS.String &amp; " USING, has no TI so criteria ignored'", LogINFO.String);
					endif;
			endif;
			endif;
			
			
			// ### TFS CR 58263 TASK 58264 07FEB2024 NAVAB1
			// See CM_Storage/CM_TITransaction::getDebtorForInvoiceLine(). if there was a change of ownership, the COO might specify a debtor or an INCO term to get a debtor. The current debtor on the invoice line will be that debtor.
			//																	if the INCO term was used in getDebtorForInvoiceLine() then we do not use the shipping terms on the contract (see below).
			if ti &lt;&gt; null  // ### TFS BUG  62551 21FEB2024 NAVAB1
			and ti.allOwnershipChange.isNotEmpty() then
				if trans &lt;&gt; null then
				
					// ### TFS CR 64873 TASK 65509 02AUG2024 NAVAB1 - incoDebtor work for all transaction types
					incoDebtor := trans.getDebtorForInvLineUsedCOO(invLineType, incoUsed);
					if incoUsed 
					and incoDebtor = debtor then
						if canLogExtra then	//26.02.2025 navah1	#34141
							app.invLog("CONT - COO INCO TERMS used to derive debtor for '" &amp; invLineType.narration &amp; "' Not using shipping terms on contract", LogINFO.String);
						endif;
						_contractToUse := contract; 
						return usingPrimary;
						
					endif;
				endif;
			endif;
			// ###### We have found a matching detail. Now we check if there is a shipping term.
			//			Ship Terms are configuration that allow the debtor to be changed by invoice line type
			//			If we can derive a different debtor from the one on the invoice line then we try to get a valid contract for that debtor.
			//			If we cannot get a valid contract for the ship term debtor then we just use the contract we already have found.
			if detail.myShippingTerm = null then
				if canLogExtra then	//26.02.2025 navah1	#34141
					app.invLog("CONT - No ship term on contract detail for '" &amp; invLineType.narration &amp; "'", LogINFO.String);
				endif;
				_contractToUse := contract; // no ship term so use contract for invoice line debtor
				return usingPrimary;
			else
				
				shipTermMapping := detail.myShippingTerm.allShipTermMappingsByInvLnType[invLineType];
				if shipTermMapping = null then
					if canLogExtra then	//26.02.2025 navah1	#34141
						app.invLog("CONT - No ship term mapping found for '" &amp; invLineType.narration &amp; "' using contract for debtor on invoice line " &amp; debtor.name, LogINFO.String);
					endif;
					_contractToUse := contract; // no ship term so use contract for invoice line debtor
					return usingPrimary;
				else
					// ### 16MAR2023	NAVAB1	BUG 57016
					if canLogExtra then	//26.02.2025 navah1	#34141
						app.invLog("CONT - Shipping terms " &amp; detail.myShippingTerm.code &amp; " found on contract detail for '" &amp; invLineType.narration &amp; "'", LogINFO.String);
					endif;
					debtorType := shipTermMapping.myDebtorType;
					if debtorType = null then
						if canLogExtra then	//26.02.2025 navah1	#34141
							app.invLog("CONT - No debtor type specified on mapping for '" &amp; invLineType.narration &amp; "' using contract for debtor on invoice line " &amp; debtor.name, LogINFO.String);
						endif;
						_contractToUse := contract; // no ship term so use contract for invoice line debtor
						return usingPrimary;
					else
						shipTermDebtor := invLineType.getDebtorFromTI(ti,debtorType);
						if shipTermDebtor = null then
							// ### TFS BUG  62551 21FEB2024  removed ti reference as it might be null
							if canLogExtra then	//26.02.2025 navah1	#34141
								app.invLog("CONT - Debtor cannot be derived for " &amp; debtorType.description &amp; " using contract for debtor on invoice line " &amp; debtor.name, LogINFO.String);
							endif;
							_contractToUse := contract; // no ship term so use contract for invoice line debtor
							return usingPrimary;
						else
							// ### 16MAR2023	NAVAB1	BUG 57016
							if canLogExtra then	//26.02.2025 navah1	#34141
								app.invLog("CONT - Attempting to find contract for the shipping terms debtor " &amp; shipTermDebtor.name, LogINFO.String);
							endif;
							// we have a ship term debtor, lets get a valid contract for this debtor
							shipTermContract := shipTermDebtor.allInvoiceContracts[bank, contractId]; // contracts are unique by ID within the BU

							// Is the contract VALID.
							if shipTermContract &lt;&gt; null then
								if dateTime &lt; shipTermContract.fromTS  
								or dateTime&gt; shipTermContract.toTS then // contract not validate
									shipTermContract := null;
								elseif not shipTermContract.active then
									shipTermContract := null;
								endif;
							endif;
							
							// No matching valid contract just use the primary contract.
							if shipTermContract = null then
								if canLogExtra then	//26.02.2025 navah1	#34141
									app.invLog("CONT - Active contract NOT found for debtor " &amp; shipTermDebtor.name &amp; " with correct date time, debtor and contract Id. Attempt PRIMARY", LogINFO.String);
								endif;
								shipTermContract := shipTermDebtor.getContractPrimary(bank,dateTime); // ### TFS BUG 60627 15NOV2023 NAVAB1
								if shipTermContract = null then
									if canLogExtra then	//26.02.2025 navah1	#34141
										app.invLog("CONT - PRIMARY contract not found for debtor '" &amp; shipTermDebtor.name &amp; "' using contract for debtor on invoice line " &amp; debtor.name, LogINFO.String);
									endif;
									_contractToUse := contract; // no ship term so use contract for invoice line debtor
									return usingPrimary;
								else
									usingPrimary := true;
								endif;	
							else
								usingPrimary := false;
							endif;
							if canLogExtra then	//26.02.2025 navah1	#34141
								app.invLog("CONT - PRIMARY contract found for debtor '" &amp; shipTermDebtor.name &amp; "' ContractId: " &amp; shipTermContract.contractId, LogINFO.String);	
							endif;
							_contractToUse := shipTermContract; // no ship term so use contract for invoice line debtor
							return usingPrimary;
						endif;
						
					endif;
				endif;

			endif;
		endforeach;
		if canLogExtra then	//26.02.2025 navah1	#34141
			if foundLineType then
				// ### TFS CR 54345 TASK 54267 01JUN2023 NAVAB1
				app.invLog("CONT - No valid rate can be found for ITEM:" &amp; itemDesc &amp; " Invoice Line: " &amp; invLineType.narration &amp; " service: " &amp; service.name, LogINFO.String);	
			else
				app.invLog("CONT - Contract Detail  can be found for Line Type :"  &amp; invLineType.narration &amp; " service: " &amp; service.name, LogINFO.String);
			endif;
		endif;
	else
		if canLogExtra then	//26.02.2025 navah1	#34141
			app.invLog("CONT - Not Found Contract for Debtor: " &amp; debtor.name &amp; " ContractId: " &amp; contractId, LogINFO.String);
		endif;

	endif;

	return false;
epilog
	delete iterContract;
	delete iterDetail;
	delete iterEntry;
end;</source>
        <Parameter name="_contractToUse" type="CM_InvoiceContract" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getContractId" id="ddfffb4a-16a3-4523-ae05-1c90aec14040">
        <source>getContractId() : String;
/*
Purpose:			

Date		Who		Reason
 // ### TFS 57512 12APR2023 NAVAB1
*/

vars
	ti : CM_TrackedItem;
	wod : CM_WorkOrderDtl;
	invLine : CM_InvoiceLine;
	contractId : String;
begin
	ti := self.getTI();
	invLine := self.invoiceLine;
	wod := self.getWorkOrder();
	
	contractId := invLine.contractId;
	if contractId = null then
		if ti &lt;&gt; null then
			contractId := ti.contractId;
		endif;
	endif;

	if contractId = null then
		if wod &lt;&gt; null then
			contractId := wod.contractId;
		endif;
	endif;
	
	return contractId;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getConvertedRate" id="4f36a897-8ba0-4811-8bc6-71a0aee32bae">
        <source>getConvertedRate( _exchangeRate : Decimal ) : Real;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
28/11/2018	jlgndl1	Initial creation	TFS 42218
01/12/2018	jlgdap1	TFS 42323 Errors with currency conversions in Indonesian Rupiah
08/12/2018  cnwma1  Bug 42400: PEL1 - Cash Receipt - Invoice Total and Autocollection Surcharge Line

*/

vars
	
	rupiahRate : Real;
	remainder : Real;
	truncatedRate : Real;	//Integer;  		// TFS 42323
	invalid : Boolean;
	invoiceStatus : Integer;
	
begin

	if self.invoiceLine = null then
		rupiahRate := 0;
	
	// 32498 pro forma invoice lines and cash extra values
	elseif self.invoiceLine.invoice = null then
		// TFS 42084 should not have used isTotalSetExplicitly should have used overridden
		 // TFS 42084 if self.isTotalSetExplicitly then // TFS 42084
		//if self.overridden then // TFS 42084
		if self.overridden or self.isTotalSetExplicitly then	//06 Dec 2018	NDL	TFS 42400 - And back again, this actually just means
											// the total has been set explicitly, not via the rate and quantity field.
			rupiahRate := ( self.total * _exchangeRate );
			if self.invoiceLine.quantity &gt; 1 and rupiahRate &lt;&gt; 0 then
				rupiahRate := rupiahRate / self.invoiceLine.quantity;
			endif;
		else
		
			rupiahRate := ( _exchangeRate * self.rate );
		endif;
		
	elseif self.status = VOID then
		rupiahRate := 0;
		
	else
		// CCMS 1280 pro forma transient invoice line will have an invalid .invoice
		on Exception do app.handleDeletedObject(exception, self.invoiceLine.invoice, invalid);
		invoiceStatus := self.invoiceLine.invoice.status;
	
		if invoiceStatus = CM_Invoice.INVOICE_POSTED
		or invoiceStatus = CM_Invoice.INVOICE_POSTED_CREDIT		
		or invoiceStatus = CM_Invoice.INVOICE_POSTED_REVERSE	
		or invoiceStatus = CM_Invoice.INVOICE_PENDING_REVERSE  
// TFS 42084 		or self.isTotalSetExplicitly
		or self.overridden // TFS 42084
		or self.isTotalSetExplicitly	//06 Dec 2018	NDL	TFS 42400 - And back again
		then
			
			/*08.12.2018 cnwma1 Bug #42400
			rupiahRate := ( self.total * _exchangeRate );
			if self.invoiceLine.quantity &gt; 1 and rupiahRate &lt;&gt; 0 then
				rupiahRate := rupiahRate / self.invoiceLine.quantity;
			endif;
			*/
			rupiahRate := self.rate * _exchangeRate;  //08.12.2018 cnwma1 Bug #42400
		elseif self.invoiceLine.status = CM_InvoiceLine.STATUS_VOIDED then
			rupiahRate := 0;
		
		else
			rupiahRate := ( _exchangeRate * self.rate );
			
		endif;
		
	endif;
	
	
	// 08.12.2018 cnwma1 Bug #42400
	/*
	if rupiahRate &lt;&gt; 0 then
		//truncatedRate := rupiahRate.Integer;				// TFS 42323
		truncatedRate := rupiahRate.truncatedTo(0);			// TFS 42323
		remainder := rupiahRate - truncatedRate;
		//apply rounding
		if remainder &gt;= 0.5 then
			truncatedRate := truncatedRate + 1;
		endif;
	endif;
	*/
	
	//08.12.2018 cnwma1 Bug #42400 Added to Fix Negative Rates
	if rupiahRate &lt;&gt; 0 then
		if rupiahRate &gt; 0 then
			truncatedRate := rupiahRate.truncatedTo(0);			
			remainder := rupiahRate - truncatedRate;
			//apply rounding
			if remainder &gt;= 0.5 then
				truncatedRate := truncatedRate + 1;
			endif;
		else
			truncatedRate := rupiahRate.truncatedTo(0)*-1;	
			remainder := (rupiahRate*-1) - truncatedRate;
			//apply rounding
			if remainder &gt;= 0.5 then
				truncatedRate := (truncatedRate + 1);
				
			endif;
			truncatedRate := (truncatedRate *-1);
		endif;
	endif;
	
	return truncatedRate;
	
epilog
	
end;</source>
        <Parameter name="_exchangeRate" type="Decimal"/>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="getDisplayDetails" id="cd857bca-9642-40bd-b15c-22382246fa42">
        <source>getDisplayDetails(_short: Boolean): String;
// ---------------------------------------------------------------------------
// Created:     Aug 2004	cnwrs1
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------

vars

begin
	return self.sequenceNum.String&amp;'  '&amp;self.rate.String;
end;</source>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getGLRateSummaryStats" id="971e8e3e-edb6-443f-8a77-3daf85830681">
        <updating/>
        <source>getGLRateSummaryStats(glSumm : CM_GLSummaryByGLCodeRateDict input) updating;
/*
Purpose:			
		
Parameters:			

Return Value:		

Date		Who		Reason
31 Oct 2017 cnwma1 TFS #7487 CPL - Invoice Export
04 Mar 2020 cnwma1 ChangeRequest 48497: CPL - Credit invoice details for GreenTree Financial export files
*/

vars
	gl 			  : CM_GLSummary;
	tmpStrCargoId : String;
	tmpStrRemarks : String;
begin

	/* 04/03/2020 cnwma1 TFS #48497
	if self.invoiceLine.status = CM_InvoiceLine.STATUS_VOIDED or
	   self.service = null or	// 36965 handle null service
		status = VOID then
		return;
	endif;
	*/
	
	//04/03/2020 cnwma1 TFS #48497
	if not self.invoiceLine.invoice.isReverseCredit then
		if self.invoiceLine.status = CM_InvoiceLine.STATUS_VOIDED or self.status = VOID then
			return;
		endif;
	endif;
	
	//04/03/2020 cnwma1 TFS #48497
	if self.service = null then
		return;
	endif;

	// rate is current because the invoice must be posted before exporting
	gl := glSumm[self.glCode, self.rate, self.service.name];
	if gl = null then
		create gl;
		gl.glCode 	   := self.glCode;
		gl.rate 	   := self.rate;
		gl.serviceName := service.name;
		glSumm.add(gl);
	endif;

	gl.quantity      := gl.quantity + self.invoiceLine.quantity;
	gl.amount        := gl.amount + total;
	gl.myInvoiceLine := self.invoiceLine;
	
	if self.invoiceLine &lt;&gt; null then                       // 31.10.2017 cnwma1 TFS #7487
		if self.invoiceLine.trackedItemId &lt;&gt; null then     // 31.10.2017 cnwma1 TFS #7487
			tmpStrCargoId    := self.invoiceLine.trackedItemId ;
			gl.trackedItemId := tmpStrCargoId  &amp; Comma &amp; gl.trackedItemId ;
		endif;
		
		if self.invoiceLine.remarks &lt;&gt; null then          // 31.10.2017 cnwma1 TFS #7487
			tmpStrRemarks := self.invoiceLine.remarks ;
			gl.remarks 	  := tmpStrRemarks  &amp; Comma &amp; gl.remarks ;
		endif;
	endif;
	
end;</source>
        <Parameter name="glSumm" type="CM_GLSummaryByGLCodeRateDict" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getGLRateSummaryStatsNarr" id="86e2ba96-6dce-41a3-9aeb-40bd2e032123">
        <updating/>
        <source>getGLRateSummaryStatsNarr(glSumm : CM_GLSummaryByGLCodeRateDict io) updating;

vars
	gl : CM_GLSummary;

begin
	// if the corresponding invoice line is voided
	if self.invoiceLine.status = CM_InvoiceLine.STATUS_VOIDED or
	   self.service = null or		// 36965 handle null service
		status = VOID then
		return;
	endif;

	// rate is current because the invoice must be posted before exporting
	gl := glSumm[self.glCode, self.rate, self.service.name];
	if gl = null then
		create gl;
		gl.glCode := glCode;
		gl.rate := rate;
		gl.serviceName := service.name;
		glSumm.add(gl);
	endif;

	gl.quantity := gl.quantity + self.invoiceLine.quantity;
	gl.amount := gl.amount + total;
end;</source>
        <Parameter name="glSumm" type="CM_GLSummaryByGLCodeRateDict" usage="io"/>
    </JadeMethod>
    <JadeMethod name="getGLRateSummaryStatsTI" id="890b2d8d-ff1b-4d6f-aa52-8b35b5af166b">
        <updating/>
        <source>getGLRateSummaryStatsTI(glSumm : CM_GLSummaryByGLCodeRateDict input) updating;

vars
	gl : CM_GLSummary;
	theTIid, theServiceName : String;
begin
	// if the corresponding invoice line is voided
	if self.invoiceLine.status = CM_InvoiceLine.STATUS_VOIDED or
	   self.service = null or			// 36965 handle null service
		status = VOID then
		return;
	endif;

	theTIid := self.invoiceLine.getTIID();

	theServiceName := self.service.name;
	// rate is current because the invoice must be posted before exporting
	gl := glSumm[theTIid, self.rate, theServiceName];
	if gl = null then
		create gl;
		gl.glCode := theTIid;
		gl.otherCode := self.glCode;
		gl.rate := self.rate;
		gl.serviceName := theServiceName;
		glSumm.add(gl);
	endif;

	gl.quantity := gl.quantity + self.invoiceLine.quantity;
	gl.amount := gl.amount + self.total;
	gl.myInvoiceLine := self.invoiceLine;
end;</source>
        <Parameter name="glSumm" type="CM_GLSummaryByGLCodeRateDict" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getGLSummStatSumByGLCodeInvDes" id="bba64e6f-a3fc-4ff9-a0f1-52c4a099482a">
        <source>getGLSummStatSumByGLCodeInvDes(glSumm : CM_GLSummaryByGLCodeDict input);
//----------------------------------------------------------------------
//  Created by cnwsh3
//	Date 06 June 2008
//
// Implemented version: 7.6.2
// To accommodate reporting on a gl code with multiple invoice line descriptions.
//----------------------------------------------------------------------
constants
	TheA :String = #"C5";
vars
	gl : CM_GLSummary;
	glInvoiceDesCode : String;
	invoiceLineDescription : String;
begin
	// if the corresponding invoice line is voided
	if invoiceLine.status = CM_InvoiceLine.STATUS_VOIDED or
		self.service = null or		// 36965 handle null service
		self.status = VOID then
		return;
	endif;
	//Note: TheA is the delimiter between the GLCode and the narration so we can get the GLCode when creating an analysis record.
	invoiceLineDescription := self.glCode &amp; TheA &amp; self.invoiceLine.invoiceLineDesc.narration;
	invoiceLineDescription := invoiceLineDescription;
	
	gl := glSumm[invoiceLineDescription];
	if gl = null then
		create gl;
		gl.glCode := invoiceLineDescription;//glCode;
		gl.serviceName := self.service.name; // PAR 31601 CCMS DPH 2276
		gl.rate := self.rate; // PAR 31891
		glSumm.add(gl);
	endif;
	
	gl.myInvoiceLine := self.invoiceLine; // CCMS 1269
	//PAR17564 Change to the way we we tally the quantity
	//gl.quantity := gl.quantity + 1;
	gl.quantity := gl.quantity + self.invoiceLine.quantity;
	gl.amount := gl.amount + total;

epilog
end;</source>
        <Parameter name="glSumm" type="CM_GLSummaryByGLCodeDict" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getGLSummaryStats" id="71218508-fca5-4706-aaff-0b50ff544b7d">
        <source>getGLSummaryStats(glSumm : CM_GLSummaryByGLCodeDict input);

vars
	gl : CM_GLSummary;

begin
	// if the corresponding invoice line is voided
	if invoiceLine.status = CM_InvoiceLine.STATUS_VOIDED or
		status = VOID then
		return;
	endif;

	gl := glSumm[glCode];
	if gl = null then
		create gl;
		gl.glCode := glCode;
		glSumm.add(gl);
	endif;
	gl.myInvoiceLine := self.invoiceLine; // CCMS 1269

	gl.amount := gl.amount + total;

end;</source>
        <Parameter name="glSumm" type="CM_GLSummaryByGLCodeDict" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getInvoice" id="36865567-f971-4629-b615-f314d4676720">
        <source>getInvoice() : CM_Invoice;
/*
Purpose:			

Date		Who		Reason
23 April 2024	navab1	BUG 63725
*/

vars
	inv : CM_Invoice;
	invLine : CM_InvoiceLine;

begin
	invLine := self.invoiceLine;
	
	if invLine = null then
		return null;
	endif;
	
	return invLine.invoice;
epilog

end;</source>
        <ReturnType type="CM_Invoice"/>
    </JadeMethod>
    <JadeMethod name="getItemDescription" id="ba4ad156-aa41-4c98-9078-97009af1c0bb">
        <source>getItemDescription() : String;
/*
Purpose:			

Date		Who		Reason
01JUN2023	NAVAB1	 CR 54345 TASK 54267 
*/

vars
	ti : CM_TrackedItem;
	wod : CM_WorkOrderDtl;
	invLine : CM_InvoiceLine;
	contractId : String;
begin
	ti := self.getTI();
	if ti &lt;&gt; null then
		return ti.id;
	endif;
	
	invLine := self.invoiceLine;

	if invLine.myTransactionEvent &lt;&gt; null then
		return invLine.myTransactionEvent.getTypeName();
	elseif invLine.myTransactionWO &lt;&gt; null then
		return invLine.myTransactionWO.getTypeString();
	endif;

	return null;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getMinMaxDetails" id="2dedda7a-a48a-4ab4-9f58-22acd098d478">
        <source>getMinMaxDetails(_isMinMaxSet : Boolean output; _minMaxUsed : Boolean output; _minMaxDisplayed : Boolean output);
/* cnwjre1 Nov 2011 28304 the GRT quantity is showing instead of the original quantity value for some marine invoices - in particular
    when voiding an invoice line (which doesn't particularly matter but doesn't look good), plus at least one Port Nelson active invoice.
	Called from the end of CM_InvoiceLine lineTotal this processing is the min/max code from evaluateRate but also handling a VOID line
*/
vars
	minMaxRate,actualLineTotal,newRate	: Real;
	rateTotal	: Real;
	minMaxUsed,minMaxDisplayed : Boolean;
begin
	_isMinMaxSet := false;
	_minMaxUsed := false;
	_minMaxDisplayed := false;

	if self.invoiceLine = null then
		return;
	endif;
	if self.invoiceLine.invoice = null then
		return;
	endif;
	//if self.invoiceLine.invoice.status = CM_Invoice.INVOICE_POSTED
	if self.invoiceLine.invoice.isPostedOrReversal	//04 Sep 2017	NDL	TFS 6759
	then
		return;
	else
		if self.overridden or
		   self.invoiceLine = null or
		   self.invoiceLine.hasMinMaxTotal or
		   self.invoiceLine.invoice = null or
		 //  self.invoiceLine.invoice.status = CM_Invoice.INVOICE_POSTED or
		   self.invoiceLine.invoice.isPostedOrReversal	//04 Sep 2017	NDL	TFS 6759	
		   then
			return;
		endif;
		newRate := self.getRateFromTable(rateTotal);

		if self.invoiceLine.isVTMISInvoiceLine()
		and not self.invoiceLine.manual then
			if rateTotal = 0 then
				actualLineTotal := newRate * self.invoiceLine.quantity;
			else
				actualLineTotal := rateTotal;
			endif;
			minMaxRate := self.evaluateMinMaxRate(actualLineTotal, minMaxUsed, minMaxDisplayed);
			if minMaxUsed then
				_isMinMaxSet := true;
				_minMaxUsed := true;
				_minMaxDisplayed := minMaxDisplayed;
			endif;
		endif;
	endif;
end;</source>
        <Parameter name="_isMinMaxSet" type="Boolean" usage="output"/>
        <Parameter name="_minMaxUsed" type="Boolean" usage="output"/>
        <Parameter name="_minMaxDisplayed" type="Boolean" usage="output"/>
    </JadeMethod>
    <JadeMethod name="getMyDebtor" id="7c7672c6-0139-4c99-a479-8576da43904d">
