    <JadeMethod name="getHeader" id="a67c6e13-6659-44f8-91de-82aa87bb37cc">
        <source>getHeader(_opCode : String; _terminal : CM_Terminal; _runDate : Date):String protected;

//22 Jan 2016	cnwrs1	37444 Use Cams controller rundate time rathyer than current date time

vars
	port	: String;
	fCode	: String;
	header	: String;
begin
	port :=  _terminal.getConfig(PortDestCode).String.trimBlanks;
	fCode := getXlatedForeignCode(_opCode.trimBlanks, port, XLATION_TYPE_PORT_BYOP, _terminal).padBlanks(5);
	header := fCode &amp; _runDate.shortYearEDI(); 
	return header.padBlanks(99);
end;</source>
        <access>protected</access>
        <Parameter name="_opCode" type="String"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_runDate" type="Date"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getMTContainersReleased" id="e01cc4fd-073f-4a42-b7ca-ff0eed596e14">
        <updating/>
        <source>getMTContainersReleased(_camFile: CM_CamFile io; _camProtocol: CM_CamProtocol; _camAgent : CM_CamControllerAgent)updating, protected;
//18 Jul 2012	cnwrs1	CCMS 1269 CAMS remove CM_CamTask
//06 Mar 2015	cnwrs1	Par35784 - increased exclusion reason logging to include non excluded

vars
	ti					: CM_TrackedItem;
	transaction			: CM_TITransaction;
	transactionArray	: CM_TransactionArray;
	className			: String;
	type				: Integer;
	iter				: Iterator;
	transDict			: CM_TITransactionByDateTypeDict;
	
begin
	create transactionArray transient;
    
    transDict := _camProtocol.terminal.allTITransactions;
    
   	iter := transDict.createIterator;
	transDict.startKeyGeq(_camAgent.startDateTime, 0, iter);
		
	while iter.next(transaction) do
		if transaction.dateTime &gt; _camAgent.endDateTime then
			break;
		endif;

		if transaction.dateTime &gt; _camAgent.startDateTime and
    	   transaction.dateTime &lt; _camAgent.endDateTime and
		   self.isTransactionToBeProcessed(_camProtocol, transaction, _camAgent) and //par 21254 cnwrs1 oct 2009
       	   transaction.myTrackedItem &lt;&gt; null then
			if _camAgent.logIncludedTransactions then
				_camAgent.logReasonForInclusion(transaction, "Transaction is correct time period and in Transaction Type list");
			endif;
			transactionArray.add(transaction);    		
		endif;
    endwhile;

	//-----------------------------
	// get messages for ti's
	//-----------------------------
	foreach transaction in transactionArray do
		ti := transaction.myTrackedItem;
   		if ti.operatorCode.trimBlanks =	_camProtocol.operatorXlationCode.trimBlanks and not ti.isFull then
			self.processTI(ti, _camProtocol, _camFile);	
    	endif;
	endforeach;
        
epilog
	delete transactionArray;
	delete iter;	
end;</source>
        <access>protected</access>
        <Parameter name="_camFile" type="CM_CamFile" usage="io"/>
        <Parameter name="_camProtocol" type="CM_CamProtocol"/>
        <Parameter name="_camAgent" type="CM_CamControllerAgent"/>
    </JadeMethod>
    <JadeMethod name="getMessage" id="d767d682-8378-4a0c-99c8-d003c4059439">
        <source>getMessage(_ti : CM_TrackedItem): String protected;

vars
	ti 			: CM_TrackedItem;
	message 	: String;
begin
	if _ti = null then
		return null;
	endif;
	
	ti := _ti;
	
	message := 	ti.id[1:11].padBlanks(11) &amp; 
				ti.getISOType[1:4].padBlanks(4) &amp;
				self.getTIStatus(ti)[1:1] &amp;
				self.getReleaseNum(ti)[1:9] &amp;
				self.isFoodGrade(ti)[1:1] &amp;
				self.isEmpty(ti)[1:1] &amp;
				self.getSealNum(ti)[1:15] &amp;
				self.temperatureDetails(ti)[1:4] &amp;
				self.getWeight(ti)[1:5] &amp;
				self.importExport(ti)[1:1] &amp;
				self.getExportVessel(ti)[1:3] &amp;
				self.getExportVoyage(ti)[1:4] &amp;
				self.getDischargePort(ti)[1:5] &amp;
				ti.remarks[1:35].padBlanks(35);
	
	return message[1:99]; 	
end;</source>
        <access>protected</access>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getReleaseNum" id="fa2a465a-116b-41aa-b45d-e9a484006c2e">
        <source>getReleaseNum(_ti : CM_TrackedItem):String protected;
//9 chars
vars
	strReleaseNum	: String;
	bulkRel			: CM_BulkRelease;
begin

	bulkRel :=  _ti.getLatestBulkReleaseReleased(BR_TYPE_ROAD); //_ti.allBulkReleasesReleased.first;// cnwrd1 26.5.09 ccms 1804  // we are after the delivery release/road release..
	//if _ti.myBulkReleaseReleased &lt;&gt; null then 
	if  bulkRel &lt;&gt; null then // cnwrd1 26.5.09 ccms 1804
		if _ti.deliveryRelease &lt;&gt; null then
			strReleaseNum := _ti.deliveryRelease.padBlanks(9);		
		elseif _ti.releaseRequest &lt;&gt; null then
			strReleaseNum := _ti.releaseRequest.deliveryNumber.padBlanks(9);		
		endif;   		
	elseif _ti.bookingReference &lt;&gt; null then
		strReleaseNum := _ti.bookingReference.padBlanks(9);
	endif;

	if strReleaseNum = null then
		strReleaseNum := "         ";		
	endif;

	return strReleaseNum[1:9];
end;</source>
        <access>protected</access>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getSealNum" id="27de0e23-bea3-4058-bf11-e7a48297fa07">
        <source>getSealNum(_ti: CM_TrackedItem):String protected;
//15 chars
vars
	strSealNum	: String;
	cont		: CM_Container;
begin
	if _ti.isKindOf(CM_Container) then	
		cont := _ti.CM_Container;
		//if cont.sealNum.trimBlanks &lt;&gt; null then	
		//	strSealNum	:= cont.sealNum;
		if cont.getSealNum.trimBlanks &lt;&gt; null then	//15 Sep 2010	NDL	Par 25608
			strSealNum	:= cont.getSealNum;	//15 Sep 2010	NDL	Par 25608
		elseif cont.getSealNumShipper &lt;&gt; null then	//15 Sep 2010	NDL	Par 25608 - change from direct ref to using method 'getSealNumShipper'
			strSealNum	:= cont.getSealNumShipper;//15 Sep 2010	NDL	Par 25608 - change from direct ref to using method 'getSealNumShipper'
		elseif cont.getSealNumCustomsFirst &lt;&gt; null then	//15 Sep 2010	NDL	Par 25608 - change to using method 'getSealNumCustoms' or 'getSealNumCustomsFirst'
			strSealNum	:= cont.getSealNumCustomsFirst;//15 Sep 2010	NDL	Par 25608 - change to using method 'getSealNumCustoms' or 'getSealNumCustomsFirst'
		endif;
	endif;        
	return strSealNum.padBlanks(15);
end;</source>
        <access>protected</access>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getTIStatus" id="8195b620-b56c-4d74-9ef4-c5d2eea31e4d">
        <source>getTIStatus(_ti: CM_TrackedItem):String protected;

vars
termArea	: CM_TerminalArea;
begin
	if _ti.site = TI_SITE_ONSITE then
   		if _ti.isAvailable then 
      		return AVAILABLE;				//Valid availability grade
		elseif _ti.hasToDoTasksWithTransClass(TRANS_TYPE_SURVEY, false) then	// 04/11/2010 cnwar2 #26198
      	//elseif _ti.hasToDoTasksWithTransClass(CM_Survey, false) then
      		return AWAITING_SURVEY;				// ToDoTask is ("Awaiting Survey" or "Survey") then
      	elseif _ti.hasToDoTasksWithTransClass(TRANS_TYPE_PRETRIP, false) then	// 04/11/2010 cnwar2 #26198
      	//elseif _ti.hasToDoTasksWithTransClass(CM_PreTrip, false) then
      		return AWAITING_PTIWASH;				//Awaiting PTI/Wash
      	elseif _ti.hasToDoTasksWithTransClass(TRANS_TYPE_WASH, false) then		// 04/11/2010 cnwar2 #26198
      	//elseif _ti.hasToDoTasksWithTransClass(CM_Wash, false) then
      		return AWAITING_PTIWASH;				//Awaiting Wash
      	elseif  _ti.damaged then 
      		return AWAITING_APPROVAL;				//Awaiting repair approval
   		elseif _ti.hasStops then 
      		return HELD;				//On hold
		elseif _ti.isKindOf(CM_Container) and not _ti.CM_Container.isClean then 
   			return AWAITING_PTIWASH;				//Awaiting Wash
   		elseif _ti.myPrimaryActualLocation &lt;&gt; null and _ti.myPrimaryActualLocation.isKindOf(CM_YardController) then
   			termArea := _ti.myPrimaryActualLocation.CM_YardController.myTerminalArea;
   			if termArea &lt;&gt; null then
	      		if termArea.type = TA_TYPE_REPAIR then 
	      			return APPROVED_REPAIR;				//Approved for repair
	      		elseif termArea.type = TA_TYPE_PTI then
	      			return AWAITING_PTIWASH;				//Awaiting PTI
	      		elseif termArea.type = TA_TYPE_WASH_AREA then
	      			return AWAITING_PTIWASH;				//Awaiting Wash
	      		endif;
	      	endif;
   		endif;
	else
   		return RELEASED; 					//Released
	endif;
	
	//unknown
	return UNKNOWN;
	
end;</source>
        <access>protected</access>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getWeight" id="4f0ac672-bbd8-4b1a-affb-e00c3d6426d6">
        <source>getWeight(_ti: CM_TrackedItem):String protected;
//
//06 Aug 2012	cnwrs1	- Par 30155 CCMS 1017 weight change for maersk Stock report has not worked correctly
//
vars
	strWeight:	String;
begin
	if _ti.totalWeight = NULL_WEIGHT then				//+cnwml2 MSL CCMS 1017
		return "     ";
	else
		// pad the weight out to be 5 characters with leading spaces no decimals
		strWeight := _ti.totalWeight.asStringWeightJMTLeadingSpaces(5);	//06 Aug 2012	cnwrs1	- Par 30155 CCMS 1017 weight change for maersk Stock report has not worked correctly	//+cnwml2 MSL CCMS 1017
	endif;
	
	return strWeight[strWeight.length-4:5];
end;</source>
        <access>protected</access>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="importExport" id="fa55ab36-840c-4d0e-b282-2d4f57b86e4c">
        <source>importExport(_ti: CM_TrackedItem):String protected;
//
// 14/07/2010	cnwdap1		PAR #25021 review use of isImport/isExport for tranships
//
vars

begin
	if _ti.isFull then
		//if _ti.isImport then								// PAR #25021
		if _ti.isImport or _ti.isTranshipInbound then		// PAR #25021
			return "I";
		//elseif _ti.isExport then							// PAR #25021
		elseif _ti.isExport or _ti.isTranshipOutbound then	// PAR #25021
			return "E";
		endif; 
	endif;
	
	return " ";
end;</source>
        <access>protected</access>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="isEmpty" id="eff12ed9-bf8a-4d38-be6a-adf3e7841819">
        <source>isEmpty(_ti: CM_TrackedItem):String protected;

vars

begin
	if _ti.isFull then
		return "N";
	else
		return "Y";
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="isFoodGrade" id="cf61cc6e-cabe-4403-8bd6-1144662109e8">
        <source>isFoodGrade(_ti: CM_TrackedItem):String protected;

vars

begin
	if _ti.isKindOf(CM_Container) then
		if _ti.CM_Container.availabilityGrade = 2 then
			return "Y";
		endif;
	endif;
	
	return "N";
end;</source>
        <access>protected</access>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="outputFile" id="f8cae520-fae9-4b77-9719-8cec10a3b7ea">
        <updating/>
        <source>outputFile(_protocol : CM_CamProtocol input; _camAgent : CM_CamControllerAgent; _camFile : CM_CamFile input; _runDateTime : TimeStamp; _camTaskHistory : CM_CamTaskHistory input;
		   _unhSeqNumber : Integer io; _seqNumber : Integer; _terminal : CM_Terminal; _contextObj : CM_Object; _transactions : CM_TITransactionSet) updating;

// 10/02/2011	cnwcs5	CCMS JMT 1977/PAR 26531 - changed _camFile/_camTaskHistory parameter usage from io to input
// 18 Jul 2012	cnwrs1	CCMS 1269 CAMS remove CM_CamTask
// 30 Jul 2012	cnwrs1	CCMS 1269 CAMS remove CM_CamTask
// 20/12/2012	cnwcs5	CCMS SFW 1294 /par 30855
// 29 Jan 2015	cnwrs1	Par 35544 - Change CamMessage to use HugeStringArray
// 29 Feb 2015	cnwrs1	Par 35544/35738 - Change CamMessage to use HugeStringArray
// 25 Feb 2015	cnwrs1	Par 35544 - Refactor Cams file storage to string
// 22 Jan 2016	cnwrs1	37444 Use Cams controller rundate time rathyer than current date time
// 09 Jan 2020 	jlgdap1	TFS 48016 SNO Deletion CODECO - new _transactions parameter
vars
    camVoyage	: CM_CamVoyage;
    camMessage	: CM_CamMessage;
	str			: String;
    i			: Integer;
	headerColl, trailerColl	: HugeStringArray;	
	strLine : String;
begin
    app.writeLog( "===================================", LogWARN);

    if _camFile.camVoyages.size &gt; 0 then
        foreach camVoyage in _camFile.camVoyages do
            foreach camMessage in camVoyage.camMessages do
				headerColl 	:= camMessage.header;
				trailerColl	:= camMessage.trailer;
				
				//header
                strLine := strLine &amp; self.outputFileMessage(_camTaskHistory, self.getHeader('MSK ', _terminal, _runDateTime.date), headerColl); 
                strLine := strLine &amp; self.outputFileMessage(_camTaskHistory, "".padBlanks(38), headerColl);
				
                _camFile.clearMessageCount();
                _camFile.incrementMessageCount();
                
                i := 1;
				
                while i &lt;= camMessage.group3.size do
                	//need to output one bit at a time - don't concat
                    str := camMessage.group3[i].String;
                    strLine := strLine &amp; self.outputFileMessage(_camTaskHistory, str, null);
//					
 //                   str := camMessage.group4[i].String;
//					outputFileMessage(_camTaskHistory, str, null);
//					
                    _camFile.incrementMessageCount();
                    i := i + 1;
                endwhile;
            endforeach;
        endforeach;
    endif;

	app.writeLog(_protocol.code &amp; " File contains " &amp; _camFile.messageCount.String &amp; " messages.", LogWARN);
    app.writeLog( "===================================", LogWARN);
	_camTaskHistory.setRawDataString(strLine);
end;</source>
        <Parameter name="_protocol" type="CM_CamProtocol" usage="input"/>
        <Parameter name="_camAgent" type="CM_CamControllerAgent"/>
        <Parameter name="_camFile" type="CM_CamFile" usage="input"/>
        <Parameter name="_runDateTime" type="TimeStamp"/>
        <Parameter name="_camTaskHistory" type="CM_CamTaskHistory" usage="input"/>
        <Parameter name="_unhSeqNumber" type="Integer" usage="io"/>
        <Parameter name="_seqNumber" type="Integer"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_contextObj" type="CM_Object"/>
        <Parameter name="_transactions" type="CM_TITransactionSet"/>
    </JadeMethod>
    <JadeMethod name="processTI" id="bbaf6342-609f-4caf-96aa-5e1085794ca1">
        <updating/>
        <source>processTI(_ti: CM_TrackedItem; _camProtocol: CM_CamProtocol; _camFile: CM_CamFile io) updating, protected;
// 24/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
//29 Jan 2015	cnwrs1	Par 35544 - Change CamMessage to use HugeStringArray
vars
	camMessage	: CM_CamMessage;
	message		: String;
	vesselCode : String; //par18987 cnwrs1 Mar 2009
begin
	
    camMessage := getCamMessage(_camFile, STOCK_REPORT_VOYAGE, vesselCode, STOCK_REPORT_TYPE, _camProtocol.singleContainerPerBGM); //ccms1747 cnwrs1 aug 2008 

	if camMessage &lt;&gt; null then
	    camMessage.camVoyage.voyageOid := _ti.myVoyage; //maybe don't need this - don't know  JC
	    //------------------------------
	    // now create the message 
	    //------------------------------
	    
		message := self.getMessage(_ti);

	//	app.mainForm.CMS_CamsMainForm.traceConsoleMessage(3, "Message Length " &amp; message.length.String &amp; ".");
	    // this is a bit grubby by splitting the message up into segments to store
	    // in the string array which can only be 62 chars long.
	    // If works fine as long as the decoding is the same. 
	    camMessage.group3.add(message);
//	    camMessage.group4.add(message[62:38]);
	    camMessage.eqdCount := camMessage.eqdCount + 1;
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_camProtocol" type="CM_CamProtocol"/>
        <Parameter name="_camFile" type="CM_CamFile" usage="io"/>
    </JadeMethod>
    <JadeMethod name="specialFileName" id="c2d9884e-c34b-4f84-95c7-6971203fc576">
        <source>specialFileName(_camGroup: CM_CamGroup; _startDateTime: TimeStamp; _runDateTime : TimeStamp): String;

vars
begin
	return _camGroup.recipient.trimBlanks&amp;_camGroup.senderCodeDepot.trimBlanks&amp;_startDateTime.date.shortYearEDI()&amp;_startDateTime.time.format("hh")&amp;".txt";

end;</source>
        <Parameter name="_camGroup" type="CM_CamGroup"/>
        <Parameter name="_startDateTime" type="TimeStamp"/>
        <Parameter name="_runDateTime" type="TimeStamp"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="temperatureDetails" id="d051f40f-1ba5-4444-bc3b-5094d92a36db">
        <source>temperatureDetails(_ti: CM_TrackedItem): String protected;

vars
	cont	: CM_Container;
	strTemp	: String;
	temp	: Integer;
begin

	if _ti.isKindOf(CM_Container) then
		cont := _ti.CM_Container;
		if cont.myOperator &lt;&gt; null and cont.getTemperature &lt;&gt; NULL_TEMPERATURE then
			if cont.myOperator.displayTempFahrenheit then
				temp := cont.temperatureInFahrenheit.Integer;
				strTemp := "   " &amp; temp.String &amp; "F";
			else
				temp := cont.getTemperature.Integer;
				strTemp := "   " &amp; temp.String &amp; "C";
			endif;
			//return the last 4 characters - string is always =&gt; 4 long	
			return 	strTemp[strTemp.length-3:4];
		endif;
	endif;	

	return "    ";

end;</source>
        <access>protected</access>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="testMessage" id="79fe68d7-61aa-4385-9029-922096f919ab">
        <source>testMessage(_ti: CM_TrackedItem; _terminal: CM_Terminal):String;
//for testing - called from script
//22 Jan 2016	cnwrs1	37444 Use Cams controller rundate time rathyer than current date time
vars
	now : Date;
begin
	now := app.actualTimeServer().date();	// 16 Sept 2016	cnwns1	TFS 488 - Multi Timezone Support
	return self.getHeader('MSK ', _terminal, now) &amp; CrLf &amp; self.getMessage(_ti);
end;

