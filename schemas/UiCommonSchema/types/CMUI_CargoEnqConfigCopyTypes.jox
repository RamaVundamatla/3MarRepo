    <JadeMethod name="populateTypes" id="37dd9ada-dcbd-4d61-9f24-b6cdf853840a">
        <updating/>
        <source>populateTypes() updating, protected;
// populate cargo types with types that the user has access to
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------
// 05/05/2020	jlgdap1		TFS 49252 CPL Cargo Types not showing in System Admin
vars
	cargo			: CM_CargoType;
	tmpId,
	idx				: Integer;
	canDoLogs,
	canDoGeneralCargo	: Boolean;
//	canDoDeveloper	: Boolean;
	tmpUser			: CM_User;

begin
	tmpUser := app.getMyUser;
	
	canDoLogs			:= tmpUser.canDo(self.myTerminal, Mod_Logs);
	canDoGeneralCargo	:= tmpUser.canDo(self.myTerminal, Mod_GeneralCargo) ;
//	canDoDeveloper		:= tmpUser.canDo(self.myTerminal, PmDeveloper);
	self.lstTypesFrom.clear();	
	// just cargo types, not BOL types as well as their tabs are not user-configurable
	foreach cargo in app.myRoot.allCargoTypesById do
		// from 31981 skip not-available-for-entry cargo types
		if cargo.isNotAvailableForEntry then
			continue;
		endif;
		// populate only those cargo types that are in selected column of terminal config
		if not self.myTerminal.allCargoBOLTypes.includes(cargo) then
			continue;
		endif;
		tmpId := cargo.id;
		if (tmpId = TI_CargoType_Log and (not canDoLogs)) or 
		   //(tmpId &gt; TI_CargoBOLType_JMTMax /*and (not canDoDeveloper)*/) or			// TFS 49252
		   (tmpId &gt; TI_CargoBOLType_JMTMax and (not app.myRoot.isClientCentrePort)) or	// TFS 49252
		   (tmpId &gt; TI_CargoBOLType_Max and tmpId &lt; TI_CargoBOLType_JMTMax and 
		   		((not canDoGeneralCargo) )) then
			continue;
		endif;
		// if the cargo type requires cargo subtypes but none have been set up, don't display it
		if cargo.isSubCargoTypeRequired and not cargo.hasProductTypes then
			continue;
		endif;
	
		idx := self.lstTypesFrom.addItem(cargo.description);
		self.lstTypesFrom.itemObject[idx] := cargo;
	endforeach;
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setupForm" id="ad1a81b4-b5c0-4b1b-9641-f4687691e158">
        <updating/>
        <source>setupForm() updating;

vars
	userName	: String;
	user	: CM_User;
begin
	inheritMethod();
	user := self.allUsers.first.CM_User;
	if user &lt;&gt; null then
		userName := user.userName;
	endif;
	if self.isExtract then
		self.lblUser.caption := app.getErrorString1(Enq_Config_Extract_User, userName);
	elseif self.copyFrom then
		self.lblUser.caption := app.getErrorString1(Enq_Config_Copy_From_User, userName);
	else
		if self.allUsers.size = 1 then
			self.lblUser.caption := app.getErrorString1(Enq_Config_Copy_User, userName);
		else
			self.lblUser.caption := app.getErrorString1(Enq_Config_Copy_Number, self.allUsers.size.String);
		endif;
	endif;

	self.populateTypes();
	self.btnOK.enabled := false;
end;
</source>
    </JadeMethod>
    <JadeMethod name="translateForm" id="d12e71cb-cf9c-4d13-80f6-ee3e86b42e92">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0016856, locale);
	btnAdd.translateCaption(Xlat_0016857, locale);
	btnAddAll.translateCaption(Xlat_0016858, locale);
	btnCancel.translateCaption(Xlat_0016859, locale);
	btnOK.translateCaption(Xlat_0016860, locale);
	btnRemAll.translateCaption(Xlat_0016861, locale);
	btnRemove.translateCaption(Xlat_0016862, locale);
	lblUser.translateCaption(Xlat_0016863, locale);
end;</source>
    </JadeMethod>
</GUIClass>
