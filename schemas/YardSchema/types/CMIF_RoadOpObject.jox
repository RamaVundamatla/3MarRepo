    <JadeMethod name="addDataTableObject" id="04346a76-d484-4552-bd33-aaa7a90c52a5">
        <source>addDataTableObject(	_obj : CM_Object input) : Boolean;
/*
Purpose:				
Return Value:		
				
Date		Who		Reason
16 August 2006	cnwer1	Initial creation - PAR#xxxx
19/03/2010		cnwcs5	par 23193 - tracked item notifications
*/
vars
	str				: String;
	rowIdx, i 		: Integer;
	displayStrings 	: HugeStringArray;
	tableObjects 	: ObjectArray;
	vehicle			: CM_Vehicle;
	invalidObject	: Boolean;
	obj				: CM_Object;	// par 23193
begin
	on Exception do app.handleDeletedObject (exception, _obj, invalidObject);
	
	create displayStrings transient;
	create tableObjects transient;

	self.getTableDisplayStrings(_obj, displayStrings, tableObjects);
	
	// if obj is invalid we will rturn here
	if invalidObject then
		return false;
	endif;
	
	if displayStrings.size = 0 then
		return false;
	endif;
	
	// 15/05/2008 cnwar2 #15934 - check if added object is already in table
	if _obj.isKindOf(CM_Vehicle) then
		vehicle := _obj.CM_Vehicle;
	elseif _obj.isKindOf(CM_WorkListEntry) then
		vehicle := _obj.CM_WorkListEntry.getJobVehicle;
	endif;
	//only if this is a vehicle table i.e. _obj = vehicle 
	//epr TFS 7828 24/11/17
	if vehicle &lt;&gt; null and _obj = vehicle and  self.myDataTable.findObjectInRow(vehicle, rowIdx) then
		// vehicle already in the table
		return false;
	endif;
	
	//cnwmc5 - 27 Jan 2015 - PAR 35528
	//epr TFS 7828 24/11/17
	if self.myRoadOpController.checkLogDocket then
		if vehicle &lt;&gt; null and vehicle.containsLogDocket() then
			return false;
		endif;
	endif;
	
	i := 1;

	foreach str in displayStrings do 
		obj 	:= tableObjects[i].CM_Object;					// par 23193
		rowIdx 	:= self.myDataTable.addItemObject (obj, str);	// par 23193
		
		if obj.isKindOf (CM_YardWLE) then						// par 23193
			self.doNotableAdd (obj.CM_YardWLE.myTrackedItem);	// par 23193
		endif;													// par 23193
		
		// par 23193 self.setTableRowColour(_obj, rowIdx);
		self.setTableRowColour(obj, rowIdx);					// par 23193
		
		i := i + 1;
	endforeach;
	
	return true;
epilog	
	delete displayStrings;
	delete tableObjects;
end;</source>
        <Parameter name="_obj" type="CM_Object" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="addVehicleToDataTable" id="ed73f108-5400-4563-8217-65f8bf7219e9">
        <source>addVehicleToDataTable(_vehicle : CM_Vehicle input);
/*
Date		Who		Reason
22 August 2006	cnwer1	Initial creation - PAR#xxxx
*/
vars
	coll	:CM_VehicleMachineByCodeDict;
begin
	coll := self.allVehicles;
	
	if coll[_vehicle.code] = null then
		coll.add(_vehicle);
	endif;
epilog

end;</source>
