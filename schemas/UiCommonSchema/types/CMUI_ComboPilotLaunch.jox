        <text>TFS 44438</text>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="myHarbour" id="a9cb4252-b9b5-45d2-8149-6115cbbf63b6">
        <embedded/>
        <type name="HMS_Harbour"/>
        <access>readonly</access>
    </ImplicitInverseRef>
    <JadeMethod name="displayEntry" id="a1eb877a-cd5f-4a01-996b-ce1baea3bbcc">
        <controlMethod name="CMUI_ComboBox::displayEntry"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <executionLocation>client</executionLocation>
        <source>displayEntry(combobox: ComboBox input; _pilotLaunch : HMS_PilotLaunch; lstIndex: Integer): String updating, clientExecution;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 May 2019	jlgsl4	TFS 44438 - PEL1 - Multiple Pilot Launches for one movement

*/

vars

begin
	if _pilotLaunch = null then
		return null;
	endif;
	
	if _pilotLaunch.isNotAvailableForEntry then
		if self.myObject &lt;&gt; _pilotLaunch then
			return null;
		else
			self.hasDirtyObject := true;
		endif;
	endif;

	return _pilotLaunch.description &amp; ' (' &amp; _pilotLaunch.code &amp; ')';				
end;
</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
        <Parameter name="_pilotLaunch" type="HMS_PilotLaunch"/>
        <Parameter name="lstIndex" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getCollectionJMT" id="8cf45f0c-df2e-49a0-841e-0cade7d9fac0">
        <source>getCollectionJMT(): Collection protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 May 2019	jlgsl4	TFS 44438 - PEL1 - Multiple Pilot Launches for one movement

*/

vars
	pilotLaunch : HMS_PilotLaunch;
begin
	self.allTempPilotLaunches.clear();
	if self.myHarbour &lt;&gt; null then
		foreach pilotLaunch in app.myRoot.allPilotLaunches discreteLock where not pilotLaunch.isNotAvailableForEntry
			and pilotLaunch.myCurrentHarbour = self.myHarbour do
			self.allTempPilotLaunches.add(pilotLaunch);
		endforeach;
	endif;
	return self.allTempPilotLaunches;
epilog

end;</source>
        <access>protected</access>
        <ReturnType type="Collection"/>
    </JadeMethod>
    <JadeMethod name="getListUpdateStatus" id="ed1a5b41-a225-436d-86d3-57782a557af8">
