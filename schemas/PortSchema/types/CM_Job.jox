    <JadeMethod name="getJobStats" id="bb94697d-6030-47c8-b90f-d209c81bbb87">
        <source>getJobStats(_jobStats :CMIF_JobStats io;
			_voyageStats : CMIF_VoyageStats input);
/*

Purpose:			


Return Value:		


Date		Who		Reason
25 July 2007	cnwer1	Initial creation - PAR#xxxx

*/
vars
	aReq : CM_Request;
	theWLE : CM_WorkListEntry;
begin
	foreach theWLE in self.workListEntries discreteLock do
		aReq := theWLE.myRequest;
		
		if not aReq.isValidForJobStats() then
			continue;
		endif;

		if theWLE.status = WLE_COMPLETED then
			_jobStats.completeMoves := _jobStats.completeMoves + 1;
		else
			_jobStats.incompleteMoves := _jobStats.incompleteMoves + 1;
		endif;
	endforeach;



epilog

end;</source>
        <Parameter name="_jobStats" type="CMIF_JobStats" usage="io"/>
        <Parameter name="_voyageStats" type="CMIF_VoyageStats" usage="input"/>
    </JadeMethod>
