    <JadeMethod name="doCmbStorConfigTypeBuild" id="62924ce8-7bd0-4b14-ae0d-168d20e42d56">
        <source>doCmbStorConfigTypeBuild();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 November 2017	jlgndl1	Initial creation	TFS 7032

*/

vars

	aTerm : CM_Terminal;
	combobox : ComboBox;
	storConType : CM_StorageConfigType;
	tmpStorConType : CM_StorageConfigType;
	index : Integer;
	
begin

	combobox := self.myForm.cmbStorConType;
	combobox.clear;

	if self.myForm.myCurrentObject &lt;&gt; null then
		aTerm := self.myForm.myCurrentObject.CM_Terminal;
	elseif self.myForm.myProxyObject &lt;&gt; null then
		aTerm := self.myForm.myProxyObject.CM_Terminal;
	endif; 
	
	if aTerm =  null then
		return;
	endif;
	
	storConType := aTerm.getMyStorageConfigType();
	
	foreach tmpStorConType in app.myRoot.allStorageConfigTypes discreteLock do
		index := combobox.addItem( tmpStorConType.getNiceName );
		combobox.itemObject[index] := tmpStorConType;
	endforeach;
	
	combobox.listIndex := combobox.findObject( storConType );

epilog
	
end;</source>
    </JadeMethod>
