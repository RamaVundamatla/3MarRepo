    <JadeMethod name="pxyCreateUpdateProxy" id="da64723b-b6ab-41d3-ad05-748921c7b84b">
        <source>pxyCreateUpdateProxy(): SelfType;
// ---------------------------------------------------------------------------
// Created:     28 January 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 20/04/2011	cnwmh5		PAR #27401 - Add code to handle prossible exceptions occurring when
//							trying to create the proxy
// ---------------------------------------------------------------------------
vars
	pxyGridObject	: CM_GridObject;
	completedOK		: Boolean;
	
begin
	pxyGridObject := inheritMethod();

	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return pxyGridObject;

epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete pxyGridObject;
	endif;
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
