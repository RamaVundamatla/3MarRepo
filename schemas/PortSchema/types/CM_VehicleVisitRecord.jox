    <JadeMethod name="getBulkGateAreaLaneContrIn" id="cfd5ea2a-a63f-44de-8fa1-8e57f6427e77">
        <source>getBulkGateAreaLaneContrIn():CM_GateAreaLaneController;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 July 2017	jlgns1	Initial creation

*/

vars
	detail	: CM_VehicleVisitRecordDetail;
	gateAreaControler : CM_GateAreaLaneController;	
	
begin
	foreach detail in self.allVehicleVisitRecordDetails reversed do
		if detail.recordType = VisitRecord_Arrive_PGate_In then
		gateAreaControler := detail.getExtraInfo_BulkGateAreaCont;
			if gateAreaControler &lt;&gt; null then
				return gateAreaControler;
