    <JadeMethod name="lockForAutoUpdates" id="d55a0436-5bd2-496f-b34a-5f69ae1bd29a">
        <source>lockForAutoUpdates();
// --------------------------------------------------------------------------------
// Created:		23 August 2010 by cnwjo3
//
// Purpose:		Lock CM_ITSInterfaceDefinition.  par 25401.
//
vars

begin
	if self.myITSInterfaceDefinition &lt;&gt; null then
		self.exclusiveLock(self.myITSInterfaceDefinition);
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="populateCmifMessage" id="b636d671-e928-4e38-9a18-fbad0cee0685">
        <source>populateCmifMessage(_cmifMsg : CMIF_ITSInterfaceMsg input; _validateFormat : Boolean);

/*

Purpose:			Get property values that may be stored in xml data.

Parameters:			_validateFormat - if true, an exception will be raised when invalid xml data is encountered.

Return Value:		_cmifMsg will be populated with values from message.


Date		Who		Reason
19 Nov 2009	consw1	PAR #21593 - Development of CCMS MES 1014 - RDT ITS Interface

*/

vars

begin
	if self.myMachine &lt;&gt; null then
		_cmifMsg.machineId := self.myMachine.id;
	endif;

epilog

end;</source>
        <Parameter name="_cmifMsg" type="CMIF_ITSInterfaceMsg" usage="input"/>
        <Parameter name="_validateFormat" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="reset" id="adec6022-1ed1-4060-b387-06be1a64654a">
        <updating/>
        <source>reset() updating;

/*

Purpose:			Remove message from interface queues

Parameters:			None

Return Value:		None


Date		Who		Reason
01 Dec 2009	consw1	PAR #21593 - Development of CCMS MES 1014 - RDT ITS Interface

*/

vars

begin
	self.lockForAutoUpdates();  //cnwjo3 par 25401
	self.isReset := true;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setProcessed" id="edd28a34-8c30-4182-82ff-9b6e8928f1d2">
        <updating/>
        <source>setProcessed(_processedTS : TimeStamp) updating;

/*

Purpose:			Remove Responses from To Send Queue.
					Remove Requests from To Action Queue.
					
Parameters:			Time completed

Return Value:		None


Date		Who		Reason
30 Nov 2009	consw1	PAR #21593 - Development of CCMS MES 1014 - RDT ITS Interface

*/

vars

begin
	self.lockForAutoUpdates();  //cnwjo3 par 25401
	self.processedTS := _processedTS;
epilog

end;</source>
        <Parameter name="_processedTS" type="TimeStamp"/>
    </JadeMethod>
</Class>
