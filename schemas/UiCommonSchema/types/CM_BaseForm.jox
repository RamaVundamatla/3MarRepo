    <JadeMethod name="keyDown" id="fd315d2e-254f-4718-9282-ea07bceeb86f">
        <controlMethod name="Form::keyDown"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>keyDown(keyCode: Integer io; shift: Integer) updating;
// ---------------------------------------------------------------------------
// Created:     11 August 2003 by cnwrs2
// 25/01/2018   cnwma1 Bug 36729: SNO - Viewing the permissions for a screen
// Purpose:     
// ---------------------------------------------------------------------------
// Changed On	By			Reason
// ----------	--------	--------------------------------------------------
// 26/03/2020	jlgdap1		TFS 48992 MTN Automated Testing - Table Navigation
// 04/11/2020	jlgmd1		Move environment checking code to centralised place
// 22/11/2023	navhn30		ChangeRequest 53372: MTN - Improvements to JMTSUPPORT User Abilities
vars
	
begin
	if keyCode = CMUI_Key_F1 then
		if app.isControlKeyDown()
		and not app.isAltKeyDown()
		and not app.isShiftKeyDown()
		then
			app.showHelp(self.hwnd, HelpFile_Index);		
		else
			app.showHelp(self.hwnd, self.helpFileName);
		endif;
		
		keyCode := null;//stop further processing by Jade/Windows	
		
	elseif keyCode = CMUI_Key_F5 then
		app.myPassport.myActivityCapture.startCaptureFormRefresh(self.String);
		self.doRefresh();
		return;
		
	elseif keyCode = J_key_P then 
	    if app.isControlKeyDown()
		and not app.isAltKeyDown()
		and not app.isShiftKeyDown()
	    then
	        self.doPrint();
	    endif;
	    
	elseif keyCode = CMUI_Key_F3
		and app.isControlKeyDown()
		and not app.isAltKeyDown()
		and not app.isShiftKeyDown()
		then
			self.doShowAlertAlarm();
			
	elseif keyCode = CMUI_Key_F10	// Generic Find Form - 22 Jan 2014	NDL	Par 33350
		then
			if app.isControlKeyDown then										// TFS 48992
				if app.isInternalEnvironment(false) then								// TFS 48992
					self.showAutomationQuickForm();								// TFS 48992
				endif;															// TFS 48992
			else																// TFS 48992
				self.showGenericSearchForm();
			endif;																// TFS 48992
			
	elseif keyCode = CMUI_Key_F11
		and app.isControlKeyDown()
		and not app.isAltKeyDown()
		and not app.isShiftKeyDown()
		and (app.isAllowedToInspect() or app.isDevelopmentSystem())
		then
			self.inspect();
			//app.inspect;
	elseif keyCode = CMUI_Key_F12 then
		if (app.isAllowedToInspect() or app.isDevelopmentSystem()) and shift.cnEcIsCtrlKey() then		// 22.11.23		 navhn30	#TFS 53372
			if shift.cnEcIsShiftKey() then
				self.cnEcShowContents();
			else
				self.showActiveDetails();
			endif;
		//elseif (app.isSpecial() or app.isDevelopmentSystem()) and shift.cnEcIsAltKey() then     // 25/01/2018   cnwma1 Bug 36729
		elseif  shift.cnEcIsAltKey() then                                                         // 25/01/2018   cnwma1 Bug 36729
			if shift.cnEcIsShiftKey() then
				self.showPermissionValues();
			else
				self.cnEcListInUseBy();
			endif;
		endif;
	endif;
epilog
	if app.myPassport &lt;&gt; null then
		if app.myPassport.myActivityCapture &lt;&gt; null then
			app.myPassport.myActivityCapture.stopCaptureFormRefresh();
		endif;
	endif;
end;</source>
        <Parameter name="keyCode" type="Integer" usage="io"/>
        <Parameter name="shift" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="load" id="5683bba4-bb61-4dba-87b4-9cf82e0fbfa6">
        <controlMethod name="Form::load"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>load() updating;
// ---------------------------------------------------------------------------
// Created:     10 May 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
//	1/9/2006	RBarr		Localisation - Call zTranslateDONOTEDIT() to translate form text
// ----------   ----------  --------------------------------------------------
// 11/04/2011	cnwmh5		PAR #27347 - Change to use app.cmsBeginLoad / app.cmsEndLoad and put app.cmsEndLoad in epilog
// 27 May 2014	cnwkpd1	PAR #34210 - CCMS SFW 1350 - Online Documentation
// ---------------------------------------------------------------------------
vars
	tmpUser	: CM_User;
	isActivityCaptureInit,
	inLoadState : Boolean;
	showConfigFinder : Boolean;
begin


	// PAR 18811 - need to leave this as visible so that alt-keys on buttons still work
	self.frmToolbarBtns.visible := true;
	self.frmToolbarBtns.top := -1000;	// move out of visible area

	tmpUser := app.getMyUser;
	if tmpUser = null and app.name = 'JMScenarioTest' then
		// picker window used to select scenario before app is properly
		// initialized - refer to UiCommonSchema::pickerWindowForScenarios
		return;
	endif;
	
	if tmpUser = null then
		app.writeLog('Terminating as user is null', LogFATAL);	//26 Nov 2019	NDL	TFS 47053
		if app.isDevelopmentSystem then
			app.msgBox('User is null - terminating app', 'Error', 0);
		endif;
		app.raiseUnexpectedProgramError(class.name, method.name, 'User is null');
		terminate;
	endif;
// TFS 2198	if tmpUser.canDo(null, PmSecurityRoleUpdate) then
		self.mnuViewPermissions.visible := true;
// TFS 2198	else
// TFS 2198		self.mnuViewPermissions.visible := false;
// TFS 2198	endif;
	
	//29 Nov 2018	NDL	TFS 42103 - make generally available
	//if app.isSpecial() or app.isDevelopmentSystem then
		self.mnuViewLogging.visible := true;
	//endif;
	
	showConfigFinder := tmpUser.canDo(null, PmAdmConfigView) or tmpUser.canDo(null, PmAdmConfigMaint);
	self.mnuViewConfig.visible := showConfigFinder;
	
	isActivityCaptureInit := true;
	app.myPassport.myActivityCapture.startCaptureFormLoad(self.String);
	
	self.mnuViewToolbar.checked := (not app.toolbarHidden);

	self.setColorsFromController(null);

	self.frmToolbar.priorityRight := true;
	self.pbProgressBar.height := 20;		// set in painter when able

	// Perform form and control caption translation (this method is reimplemented)
	app.cmsBeginLoad(inLoadState);					// 11/04/2011 cnwmh5 #27347
	self.translateForm();
	self.setupDefaultHelpKeyword();					// PAR #34210
	app.cmsEndLoad(inLoadState);					// 11/04/2011 cnwmh5 #27347
	
	self.initPosition();
	self.setupForm();
	self.setMenus();
	self.handleHelpMenuSetup();						// PAR #34210
	
	app.writeLog(self.class.name &amp; " open", LogINFO);	

	if self.toolbarStyle &lt;&gt; ToolbarStyle_None then
		self.zSetupToolbar();
	endif;

	// PAR 18811 - move to top of method so happens first
	//self.frmToolbarBtns.top := -1000;	// move out of visible area

	if self.windowState &lt;&gt; self.WindowState_Minimized then
		// at startup we open windows minimised so don't 
		// bother resizing.  Resize will get done when
		// user first access them
		self.doResize();
	endif;

epilog
	app.cmsEndLoad(inLoadState);				// 11/04/2011 cnwmh5 #27347
	if isActivityCaptureInit then
		app.myPassport.myActivityCapture.stopCaptureFormLoad();
	endif;

end;</source>
    </JadeMethod>
