    <JadeMethod name="canEditOrDeleteInEnquiry" id="5ee4af8d-c743-4349-813f-25f30a706548">
        <source>canEditOrDeleteInEnquiry() : Boolean;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 20/06/2018	jlgdap1		Initial creation TFS 39286 PEL1 Work Order Enquiry Voyage Requests
// 11 Oct 2021	jlier1		TFS 51963
vars
	woDtl : CM_WorkOrderDtl;

begin
	woDtl := self.allWoDtls.first;
	if woDtl = null then
		return true;
	endif;
		
	if woDtl.isKindOf(CM_WodMarineServiceDetail) or woDtl.isKindOf(CM_WodVoyageCargoRequest) or woDtl.isKindOf(CM_WodVoyageRequest) 
	or woDtl.isKindOf(CM_WodMarineServicesDepart) or woDtl.isKindOf(CM_WodMarineServicesInitial)
	then
		return false;
	endif;
	return true;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="canEstimate" id="1b3c17ff-5eee-48fd-98f5-8f6fc14ec96d">
        <source>canEstimate():Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 Jan 2023	navma1  	ChangeRequest 56141: EUP - Refactor and Remove CM_WorkOrderTISource from CM_WorkOrderTI
*/

vars
	cashReceipt : CM_CashReceipt;
	debtor	    : CM_Debtor;
	user		: CM_User;
	failedDAC	: CM_DataAccessController;
begin
	user				:= app.getMyUser();					//12.01.2023 navma1 #56141 Task#56147 
	
	foreach cashReceipt in self.allCashReceipts do
		debtor := cashReceipt.getDebtor();					//12.01.2023 navma1 #56141 Task#56147
		if debtor = null then
			continue;
		endif;
		if not debtor.canUserAccessSelf(user, failedDAC, app.myPassport) then
			app.writeLog("Debtor " &amp; debtor.name &amp; " not accessible to user " &amp; user.code, LogDEBUG);	//25 Nov 2019	NDL	TFS 47053
			continue;
		endif;
		return true;
		break;
	endforeach;
	return false;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
