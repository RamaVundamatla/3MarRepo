    <JadeMethod name="loadOperationCmb" id="ea829dad-b5c8-4bfc-b27b-eec52e84ef1d">
        <source>loadOperationCmb();
//26 August 2010	cnwml2

//+cnwml2 				PAR23715 SFW CCMS1131
// cnwdap1	11/08/2011	PAR#27972 Bulk release type no longer translatable, replaced by string constants
vars

begin
	self.cmbOperation.clear();
	//self.cmbOperation.addItem(app.getString(Road));				// PAR #27972
	//self.cmbOperation.addItem(app.getString(BR_TYPE_DESCR_RAIL));	// PAR #27972
	//self.cmbOperation.addItem(app.getString(BR_TYPE_DESCR_SHIP));	// PAR #27972
	self.cmbOperation.addItem(BR_TYPE_ROAD_STR);					// PAR #27972
	self.cmbOperation.addItem(BR_TYPE_RAIL_STR);					// PAR #27972
	self.cmbOperation.addItem(BR_TYPE_SHIP_STR);					// PAR #27972
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="loadRecRelCombo" id="59937758-ec10-4457-bbc5-fc4120445a1d">
        <source>loadRecRelCombo();
//26 August 2010	cnwml2
//+cnwml2 PAR23715 SFW CCMS1131

vars

begin
	self.cmbReceival.clear();
	self.cmbReceival.addItem(app.getString(Default));
	self.cmbReceival.addItem(app.getString(Strict));
	self.cmbReceival.addItem(app.getString(Full));
	self.cmbReceival.addItem(app.getString(View));
	self.cmbReceival.addItem(app.getString(None));
	
	self.cmbRelease.clear();
	self.cmbRelease.addItem(app.getString(Default));
	self.cmbRelease.addItem(app.getString(Strict));
	self.cmbRelease.addItem(app.getString(Full));
	self.cmbRelease.addItem(app.getString(View));
	self.cmbRelease.addItem(app.getString(None));
	
epilog

end;</source>
    </JadeMethod>
