    <JadeMethod name="addNotableTi" id="2182abe7-c57b-46be-b72a-915056cc9e8c">
        <source>addNotableTi( ti : CM_TrackedItem );

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
02 March 2012	cnwndl1	Initial creation	Par 29195

*/

vars

begin

	

	if not self.allNotableTis.includes( ti ) then
		self.allNotableTis.add( ti );
		self.beginNotification( ti, Any_System_Event, Response_Continuous, null );
	endif;

epilog

end;</source>
        <Parameter name="ti" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="addSelectedCargo" id="ff2e9f38-0690-44af-b9b7-4d1db98e6bcf">
        <source>addSelectedCargo( _tiArray : ObjectArray );

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
28 February 2012	cnwndl1	Initial creation	Par 29195

*/

vars

	iter : Iterator;
	ti : CM_TrackedItem;
	rowIndex : Integer;
	updated : Boolean;
	size : Integer;
	subTi : CM_TrackedItem;

begin

	if _tiArray = null or _tiArray.isEmpty then
		return;
	endif;
	
	ti := _tiArray.first.CM_TrackedItem;
	// 30069 null test already just added by DW
	if ti.myPrimaryActualLocation &lt;&gt; null and  ti.myPrimaryActualLocation.myTerminal &lt;&gt; self.myTerminal then
		app.msgBox( app.getErrorString2(Testplan_Term_Mismatch, ti.myPrimaryActualLocation.myTerminal.code, self.myTerminal.code ), app.getErrorString(Error), MsgBox_OK_Only );
		return;
	endif;
	
	self.shtSelected.setFocus();

	iter := _tiArray.createIterator;
		
	while iter.next( ti ) do
		rowIndex := 0;
		self.tblSelectedCargo.findObjectInRow(ti, rowIndex);
		if rowIndex &gt; 1 then
			// it already exists, don't add it.
			continue;
		endif;
		//15 July 2014	NDL	Par 
	//	if ti.isChild then	//18 Jul 2013	NDL	Par 31899
	//		continue;
	//	endif;
		if ti.isCargoGroupItem then	//08 Jun 2015	NDL	Par 36338 - just add the cargo in the cargo gropup
			//foreach subTi in ti.CM_CargoGroup.allAssignedTrackedItems do
			foreach subTi in ti.CM_CargoGroup.allAssignedTrackedItems where ( subTi.isOnSite or subTi.isNotified )do	//15 Feb 2016	NDL	Par 37544
				if not _tiArray.includes( subTi ) then
					rowIndex := 0;
					self.tblSelectedCargo.findObjectInRow(subTi, rowIndex);	//15 Feb 2016	NDL	Par 37544
					if rowIndex &gt; 1 then
						continue;
					endif;
					rowIndex := self.tblSelectedCargo.addItemObject( subTi, subTi.getAttributeStringForDefArray(self.tblSelectedCargo.allTblDataEntRows) );
					if subTi.myPrimaryPlannedLocation &lt;&gt; null then
						self.tblSelectedCargo.accessRow( rowIndex ).backColor := Grey;
					endif;
					updated := true;
					addNotableTi( subTi );	
				endif;
			endforeach;
			continue;
		endif;
		rowIndex := self.tblSelectedCargo.addItemObject( ti, ti.getAttributeStringForDefArray(self.tblSelectedCargo.allTblDataEntRows) );
		if ti.myPrimaryPlannedLocation &lt;&gt; null then
			self.tblSelectedCargo.accessRow( rowIndex ).backColor := Grey;
		endif;
		updated := true;
		addNotableTi( ti );
	endwhile;
	
	//The selection has changed, clear the other sheets.
	if updated then
		self.clearWouldPlanAndFailed();
		size := self.tblSelectedCargo.rows - self.tblSelectedCargo.fixedRows;
		self.shtSelected.caption := "(x" &amp; size.String &amp; ") " &amp; app.getErrorString(Selected_Cargo);
	endif;

epilog

	delete iter;

end;</source>
        <Parameter name="_tiArray" type="ObjectArray"/>
    </JadeMethod>
    <JadeMethod name="allowsTableFilters" id="cb427caa-729f-4c68-b323-e695918c9186">
        <source>allowsTableFilters(_table: Table): Boolean;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
29 February 2012	cnwndl1	Initial creation	Par 29195

*/

vars

begin

	if _table = self.tblSelectedCargo
	or _table = self.tblFailed
	or _table = self.tblWouldPlan
	then
		return true;
	endif;
	
	return false;

epilog

end;</source>
        <Parameter name="_table" type="Table"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="applyColumnFilter" id="2e4ff232-7b8b-4682-80ae-1a500d22e165">
        <updating/>
        <source>applyColumnFilter(_table: CM_DataTable io): Integer updating;
/*
Date		Who		Reason
29 February 2012	cnwndl1	Initial creation	Par 29195

*/
vars
	visibleCount : Integer;
begin
	if _table &lt;&gt; null then
		if _table.allowsColumnFilters then
			visibleCount := _table.applyColumnFilter( self.allColumnFilters );
		endif;
	endif;
	
	return visibleCount;

epilog

end;</source>
        <Parameter name="_table" type="CM_DataTable" usage="io"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
