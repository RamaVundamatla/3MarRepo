    <JadeMethod name="setupForm" id="f21cebd4-15e0-4220-93a1-60edcaaf62d3">
        <updating/>
        <source>setupForm() updating;
/*
Purpose:			

Date		Who		Reason
08 July 2024	navab1	CR 64615 TASK 64649
04 Jul 2024	navnk30	ChangeRequest 64613: NSW - Auto Voyage Configuration. Task 64639.
*/

vars

begin
	inheritMethod();

	self.doBuildCmbDateType();
	self.doBuildCMbDischTermArea(null, null);
	self.doBuildCmbVoyageStatus(); // ### TFS CR 64616 TASK 64652 16JUL2024 NAVAB1
	self.setupCompFields(); // ### TFS CR 64614 TASK 64642 16JUL2024 NAVAB1
	self.doBuildMSGComparisonFields(); // ### TFS CR 64614 TASK 64642 16JUL2024 NAVAB1
	
	self.doDisplayAutoData();
	self.doDisplayAutoCompData();
	
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		self.btnSave.enabled:= false;
		self.grpRetro.enabled:= false;
		self.cmbDischargeLC.enabled := false;
		self.cmbDischargeTA.enabled := false;
		self.cmbDischargeTAType.enabled := false;
		self.btnDelete.visible := false;
	else
		self.btnDelete.visible := app.isSpecial;
	endif;
	
epilog

end;</source>
    </JadeMethod>
