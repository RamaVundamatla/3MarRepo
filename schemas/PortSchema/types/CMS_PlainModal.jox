<GUIClass name="CMS_PlainModal" id="0bc62e73-9bb4-4f63-a822-b1e334fadf77">
    <superclass name="Form"/>
    <transient/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <ImplicitInverseRef name="myTerminal" id="ad6f067b-55ae-4477-a1ed-0a49a887da7c">
        <embedded/>
        <type name="CM_Terminal"/>
    </ImplicitInverseRef>
    <JadeMethod name="activate" id="b8b62089-fa89-4e1e-971c-d48ba72895f7">
        <controlMethod name="Form::activate"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>activate() updating;
// ---------------------------------------------------------------------------
// Created:     06 December 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	app.setMyTerminal(self.myTerminal);
	if self.myTerminal = null then
		app.writeStatement( class.name &amp; '::' &amp; method.name &amp; ' *** myTerminal is null for ' &amp; self.String);
	endif;

end;</source>
    </JadeMethod>
    <JadeMethod name="btnHelp_clickX" id="278f3ba0-af7f-4391-94fa-fe76ba77313b">
        <updating/>
        <source>btnHelp_clickX(btn: Button input) updating;

//	RD 2 v 00: copies in CMS_Modal, CMS_MainForm, CMS_PlainModal
//	RD 18 vii 00: replaced with app method
//	RD 18 xii 00: replaced with btnHelp_mouseUp

begin
	if self.helpKeyword.length = 0 then
		self.helpKeyword := self.name;
	endif;
	app.helpShowHelp( self );
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="btnHelp_mouseUp" id="083ab4ba-5ba6-46b5-8a0f-26cdfee08438">
        <updating/>
        <source>btnHelp_mouseUp( btn : Button input; button, shift : Integer; x, y : Real ) updating;

vars

begin
	if button = 2 then	// right-click
		
	else				// left click (or middle-click)
		if self.helpKeyword.length = 0 then
			self.helpKeyword := self.name;
		endif;
		app.helpShowHelp( self );
	endif;
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
</GUIClass>
