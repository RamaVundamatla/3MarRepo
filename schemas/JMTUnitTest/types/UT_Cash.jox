begin
	cargo := _cargo;

	foreach payment in cargo.allCashPayments do
		if payment.myCashPaymentForInvoice &lt;&gt; null then // TFS 7357 tax payment ignore
			continue;
		endif;
		count := count + 1;
		if count = 1 then
			self.assertEqualMsg(payment.cashValue, 1000.Decimal, "Cargo payment " &amp; count.String &amp; " after last release");
		elseif count = 2 then
			self.assertEqualMsg(payment.cashValue, 5000.Decimal, "Cargo payment " &amp; count.String &amp; " after last  release");
		elseif count = 3 then
			self.assertEqualMsg(payment.cashValue, 1000.Decimal, "Cargo payment " &amp; count.String &amp; " after last release");
