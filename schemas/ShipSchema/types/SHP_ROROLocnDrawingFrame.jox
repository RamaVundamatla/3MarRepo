        <source>getObjectForPosition(x, y : Integer) : Object;
/*
Date		    Who			Reason
15 July 2011	cnwas3	  Initial creation: CCMS 1035 CargoSideView form
*/

vars
	xy1, xy2	: Point;
begin

	return self.getObjectAndPointsForPosition(x, y, xy1, xy2);

end;</source>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
