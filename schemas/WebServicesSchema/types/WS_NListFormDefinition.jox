<Class name="WS_NListFormDefinition" id="ec9dad69-404d-47ea-9acd-e99fb35c7cb8">
    <superclass name="WS_NFormDefinition"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="restwebservice"/>
    <ImplicitInverseRef name="allFieldDefinitions" id="aabbdb96-f6e6-4413-b2c1-7c247543b02b">
        <memberTypeInverse/>
        <type name="WS_NFieldDefinitionArray"/>
    </ImplicitInverseRef>
    <JadeMethod name="buildFormDefinition" id="9a0ad5a9-47e0-4fe8-8d4d-040b40444bfd">
        <updating/>
        <source>buildFormDefinition() : Boolean updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 02/10/2020	jlgdap1		Initial creation TFS 49227 Navis API - nReefer API
//
vars
	entDef : EntTableDef;
	row : EntTableRow;

begin
	entDef := app.myRoot.myEntTableDataRoot.getEntTableDef(ETDef_ReeferAPI);
	if entDef = null then
		return false;
	endif;
	
	foreach row in entDef.allEntTableRows discreteLock do
		self.createField(row);
	endforeach;
	
	return true;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="createField" id="84ddf71a-bd73-47d0-95e6-65ed801830a8">
        <updating/>
        <source>createField(_entRow : EntTableRow) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 02/10/2020	jlgdap1		Initial creation TFS 49227 MTN Navis API - nReefer API
//
vars
	fieldDef : WS_NFieldDefinition;
	row, col : Integer;

begin
	create fieldDef transient;
	if fieldDef.setField(_entRow) then
		self.allFieldDefinitions.add(fieldDef);
	else
		delete fieldDef;
	endif;
epilog

end;</source>
        <Parameter name="_entRow" type="EntTableRow"/>
    </JadeMethod>
</Class>
