    <JadeMethod name="getReceivedTrackedItems" id="e4937e07-bfb2-4004-b763-d99d8030e633">
        <source>getReceivedTrackedItems(_coll :Collection input);
/*

Purpose:			Get all received items

Parameters:			_coll : the collection to be filled

Return Value:		null

Date		Who		Reason
12 Jun 2013	cnwcs5	Initial Creation - par 31670
01 Apr 2019	jlgzm1	tfs43864 Booking screen performance

*/
vars
	item	: CM_BookingRefItem;
	ti		: CM_TrackedItem;
	iter	: Iterator;
begin
	//make sure we're working with the real object
	if self.isTransient then
		item := app.myProxyManager.getRealObject(self).CM_BookingRefItem;
		if item &lt;&gt; null then
			item.getReceivedTrackedItems (_coll);
			return;
		endif;
	endif;

	//tfs43864 start
	iter := self.allTIsByState.createIterator();
	
	//get all items with state &lt; prenote
	self.allTIsByState.startKeyGeq(TI_STATE_UNDEFINED, "", 0, iter);
	while iter.next(ti) do
		//check state key
		if iter.getCurrentKey(1).Integer &gt;= TI_STATE_NOTIFIED then
			break;
		endif;
		_coll.add (ti);
	endwhile;

	//get all items with state &gt; prenote and state &lt; merged
	self.allTIsByState.startKeyGeq(TI_STATE_OFFSITE, "", 0, iter);
	while iter.next(ti) do
		//check state key
		if iter.getCurrentKey(1).Integer &gt;= TI_STATE_MERGED then
			break;
		endif;
		_coll.add (ti);
	endwhile;
	//tfs43864 end
	
epilog
	delete iter;
end;</source>
        <Parameter name="_coll" type="Collection" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getReceivedWeight" id="5c62de9d-d539-4367-b411-d460881dc6be">
        <source>getReceivedWeight() : Decimal;
/*

Date		Who		Reason
23 September 2014	cnwer1	Initial creation PAR 34935

*/

vars
	ti 			: CM_TrackedItem;
	receivedWeight	: Decimal[14,4];
	item 		: CM_BookingRefItem;
begin
	if not self.isBulkMulti then
		return null;
	endif;
	
	if self.isTransient then
		item := app.myProxyManager.getRealObject(self).CM_BookingRefItem;
		
		if item &lt;&gt; null then
			return item.getReceivedWeight;
		endif;
	endif;

	foreach ti in self.allTIs where (ti.state &lt;&gt; TI_STATE_NOTIFIED and ti.state &lt;&gt; TI_STATE_MERGED) do
		if ti.isBulkByVolume or ti.isBulkByWeight then
			receivedWeight :=receivedWeight +  ti.totalWeight;
		endif;
	endforeach;
	
	return receivedWeight;
epilog

end;</source>
        <ReturnType type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="getRecievedCount" id="63c04423-2941-4a23-9d18-f7ef1b8dda7a">
        <source>getRecievedCount():Integer;
/*

Purpose:			Get number of received items

Parameters:			null

Return Value:		total number of received items

Date		Who		Reason
27 Nov 2009	cnwndl1	Initial creation	CCMS 1028
12 Jun 2013	cnwcs5	par 31670 -
03 apr 2019 jlgzm1	TFS43864 Booking screen performance

*/
vars
	ti			: CM_TrackedItem;
	total		: Integer;
	item 		: CM_BookingRefItem;
	iter		: Iterator;
begin
	if self.isBulkMulti then
		return 0;
	endif;
	
	//make sure we're working with the real object
	if self.isTransient then
		item := app.myProxyManager.getRealObject(self).CM_BookingRefItem;
		if item &lt;&gt; null then
			return item.getRecievedCount;
		endif;
	endif;
	
	//tfs43864 start
	iter := self.allTIsByState.createIterator();
	
	//get all items with state &lt; prenote
	self.allTIsByState.startKeyGeq(TI_STATE_UNDEFINED, "",  0, iter);
	while iter.next(ti) do
		if iter.getCurrentKey(1).Integer &gt;= TI_STATE_NOTIFIED then
			break;
		endif;
		if ti.myCargoType.isBulkMulti then
			continue;
		endif;
		//add total quantity
		total := total + iter.getCurrentKey(3).Integer;
	endwhile;

	//get all items with state &gt; prenote and state &lt; merged
	self.allTIsByState.startKeyGeq(TI_STATE_OFFSITE, "",  0, iter);
	while iter.next(ti) do
		if iter.getCurrentKey(1).Integer &gt;= TI_STATE_MERGED then
			break;
		endif;
		if ti.myCargoType.isBulkMulti then
			continue;
		endif;
		//add total quantity
		total := total + iter.getCurrentKey(3).Integer;
	endwhile;
	//tfs43864 end
	
	return total;
epilog
	delete iter;

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
