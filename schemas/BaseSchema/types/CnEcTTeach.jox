    <JadeMethod name="addError" id="3a2f2e51-4645-4860-a4c3-a7cd6ea3aae1">
        <source>addError(pError : String io; pNewError : String);

begin
	if pNewError.length &gt; 0 then
		pError := pError &amp; CrLf &amp; pNewError;
	endif;
end;</source>
        <Parameter name="pError" type="String" usage="io"/>
        <Parameter name="pNewError" type="String"/>
    </JadeMethod>
    <JadeMethod name="doReplaceCrLf" id="8dc50047-00bf-4ad1-afa3-a6d1bb24ac18">
        <source>doReplaceCrLf(pSourceStr : String) : String;

vars
	outStr		: String;
	posLf		: Integer;

begin
	if pSourceStr.length &gt; 8000 then
		outStr := pSourceStr[1:8000];
	else
		outStr := pSourceStr;
	endif;

	posLf := outStr.pos(self.CRLF_PLACEHOLDER, 1);

	if posLf = 0 then
		return outStr;
	endif;

	while posLf &gt; 0 do
		if outStr.length = self.CRLF_PLACEHOLDER.length then					// replace entire string 
			outStr := " ";
		elseif posLf = 1 then
			outStr := outStr[1 + self.CRLF_PLACEHOLDER.length:end];			// if at start of string, drop
		elseif ( posLf + self.CRLF_PLACEHOLDER.length ) &gt;= outStr.length then
			outStr := outStr[1:posLf - 1];						// if at end of string, drop - can still get at end tho' e.g. with multiple LFs... see loop below
		else
			outStr := outStr[1:posLf - 1] &amp; CrLf &amp; outStr[posLf + self.CRLF_PLACEHOLDER.length:end];
		endif;
		
		posLf := outStr.pos(self.CRLF_PLACEHOLDER, 1);	
	endwhile;

	if CrLf.length &gt; outStr.length then
		return outStr;
	endif;

	posLf := outStr.pos(CrLf, outStr.length - CrLf.length + 1);

	while posLf &gt; 0 do	// remove markers at end of string
		if outStr.length = CrLf.length then
			outStr := " ";
			posLf := 0;
		else
			outStr := outStr[1:outStr.length - CrLf.length];		// if at end, drop
			posLf := outStr.pos(CrLf, outStr.length - CrLf.length + 1);
		endif;
	endwhile;

	return outStr;
end;</source>
        <Parameter name="pSourceStr" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getNextChunk" id="7401e69f-9c7f-4462-a795-10f47ac5358a">
        <source>getNextChunk(pString : String io) : String;

//	input: Tab delimited string
//	returns characters up to Tab, removes these from string (including tab) 

vars
	tabPos	: Integer;
	str		: String;

begin
	tabPos := pString.pos( Tab, 1);	// replaced Tab

	if tabPos = 0 then
		str := pString;
		pString := "";
	else
		str := pString[1:tabPos-1];

		if tabPos = pString.length then
			pString := null;
		else
			pString := pString[ tabPos + 1 : pString.length - tabPos ];
		endif;
	endif;
	
	return str.trimBlanks;
end;</source>
        <Parameter name="pString" type="String" usage="io"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="isNextChunk" id="b5f8efca-89c0-4495-a052-b07beeb20eab">
        <source>isNextChunk(pInString : String io; pText : String) : Boolean;

begin
	return (self.getNextChunk(pInString) = pText);
end;</source>
        <Parameter name="pInString" type="String" usage="io"/>
        <Parameter name="pText" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
