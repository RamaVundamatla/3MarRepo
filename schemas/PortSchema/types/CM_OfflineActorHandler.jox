    <transient/>
    <sharedTransientAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>JASSchema OfflineActorAppHandler copy.</text>
    <Constant name="Event_Offline_Actor_Update" id="a97fbc6d-f3bb-419c-ae16-b09777f316af">
