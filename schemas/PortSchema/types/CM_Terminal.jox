    <JadeMethod name="getDefaultCargoGroupCargoType" id="32c0bc41-88dd-4adf-a4b0-c311181596aa">
        <source>getDefaultCargoGroupCargoType():CM_CargoType;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 Jun 2015	cnwndl1	Initial creation	Par 36338
27 Jun 2023	navdap1	TFS 58813 EUP 58813 EUP Instructions and default cargo group type
*/

vars

	iter : Iterator;
	cargoType : CM_CargoBOLType;

begin
	// TFS 58813 start
	if self.defaultCargoGroupType &lt;&gt; null then
		cargoType := app.myRoot.allCargoTypesById[self.defaultCargoGroupType];
		if cargoType &lt;&gt; null then
			return cargoType.CM_CargoType;
		endif;
	endif;
	// TFS 58813 end
	
	//21 Jun 2019	NDL	TFS 44895
	if app.myAlternateDict &lt;&gt; null then
		return app.myAlternateDict.getDefaultCargoGroupCargoType( self );
	endif;
	
	iter := self.allCargoBOLTypes.createIterator;
	while iter.next( cargoType ) do
		if cargoType.isCargoGroup() then
			return cargoType.CM_CargoType;
		endif;
	endwhile;
	
	return null;

epilog

	delete iter;

end;</source>
        <ReturnType type="CM_CargoType"/>
    </JadeMethod>
    <JadeMethod name="getDefaultCompanyBank" id="f10f31d7-c1ac-4af4-b96f-e2d0bd76abb0">
        <source>getDefaultCompanyBank():CM_Bank;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
17 April 2012	cnwndl1	Initial creation	Par 29393

