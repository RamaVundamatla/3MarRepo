    <JadeMethod name="cmbCargoTypes_lostFocus" id="05cb2ea3-b7cc-4255-97ef-a66bc75d72da">
        <controlMethod name="CMUI_ComboBoxObject::lostFocus"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbCargoTypes_lostFocus(combobox: ComboBox input) updating;
//14 October 2009	cnwml2
//12 January 2023	navcs2	ChangeRequest 56149: EUP - VAS Cargo Search Screen (Task 56150)


vars
	cargoType : CM_CargoType;
begin
	if combobox.listObject &lt;&gt; self.myCargoType then	// TFS 46054 jlgzm1 25/09/2019
		self.initFieldsForEntDefName(ETDef_CargoSearch, true);
		cargoType := combobox.listObject.CM_CargoType;	// TFS 46054
		self.myCargoType := cargoType;
	endif;
	
	// 12 Jan 2023 navcs2 #56149 (Task 56150)
	if cargoType &lt;&gt; null then
		self.cmbCommodities.listCollection(cargoType.allCommodities, true, ComboBox.DisplayCollection_Forward);
	endif;
epilog

end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="cmbCommodities_displayEntry" id="2a486884-4777-412a-bca9-d237cecf006f">
