    </JadeMethod>
    <JadeMethod name="checkErrorWarnAllHaveOccurred" id="e475e530-091e-4ecd-8aee-67bf760945a0">
        <source>checkErrorWarnAllHaveOccurred() : Boolean protected;
/*
Purpose:	Check that the multiple expected errors where the only errors		

Date		Who		Reason
07DEC2022	NAVAB1	TFS CR 55623 TASK 55673
*/

vars
	error					: CM_Error;
	errir : Integer;
	matched : Boolean;
begin

	foreach error in app.myPassport.allErrorWarnings do
		if not self.expectedTrxErrors.includes(error.errorCode) then
			executeWhen JMTDevelopmentEnvironment;
			write method.qualifiedName &amp; " Errors in passport not expected - " &amp; error.text;
			endExecuteWhen;
			
			return false;
		endif;
	endforeach;

	foreach errir in self.expectedTrxErrors do
		matched := false;
		foreach error in app.myPassport.allErrorWarnings do
			if error.errorCode = errir then
				matched  := true;
			endif;
		endforeach;
		
		if not matched then
			executeWhen JMTDevelopmentEnvironment;
			write method.qualifiedName &amp; " Expected error not in passort " &amp; errir.String;
			endExecuteWhen;

			return false;
		endif;
	endforeach;

	return true;
	
epilog

end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="checkErrorWarningHasOccurred" id="6cce1e4e-6f73-4d21-b258-caa8b9df68ef">
        <source>checkErrorWarningHasOccurred() : Boolean protected;

/*

Purpose:		Check to see if the passed in error code exists in
				either the errors or warnings collection

Date			Who		Reason
29/10/2014		cnwmh5	Initial creation

*/

vars
	
	error					: CM_Error;
	
	hasOccurred				: Boolean;
	
begin

	hasOccurred := false;

	foreach error in app.myPassport.allErrorWarnings do
		if self.expectedTrxErrors.includes(error.errorCode) then
			hasOccurred := true;
			break;
		endif;
	endforeach;

	return hasOccurred;
	
epilog

end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="checkMethodShouldBeRun" id="6983e248-b575-4bb8-88ca-65240814c4e3">
        <source>checkMethodShouldBeRun(_logResult : Boolean);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 February 2013	cnwmc5	Initial creation
16/03/2015			cnwmh5	Transient Leaks
*/

constants
	XMLHeader				: String = "&lt;?xml version=";
	XMLAdditional			: String = "UT_Additional";
	XMLCategories			: String = "Categories";
	XMLCategory				: String = "Category";
	XMLAttributeCanDelete	: String = "CanDelete";
	XMLEndString			: String = XMLAdditional &amp; "&gt;";
	ScheduleText			: String = "SCHEDULE_";
vars
	xmlDocument 			: JadeXMLDocument;
	xmlElementAdditional,
	xmlElementCategories,
	xmlElementCategory		: JadeXMLElement;
	xmlAttributeCategories	: JadeXMLAttribute;
	category				: UM_Category;
	
	categoryElements		: JadeXMLElementArray;
	
	categoryText			: String;
	classMethodText			: String;
	xmlText					: String;
	xmlHeaderPos			: Integer;
	xmlEndPos				: Integer;
	canBeDeleted			: Boolean;
begin
	
	create xmlDocument transient;
	xmlDocument.parseString(xmlText);
	
	// check if there is a XMLAdditional element
	xmlElementAdditional := xmlDocument.getElementByTagName(XMLAdditional);
	if xmlElementAdditional = null then
		return;
	endif;

	// check to see if there is a XMLCategories element
	xmlElementCategories := xmlElementAdditional.getElementByTagName(XMLCategories);
	if xmlElementCategories = null then
		return;
	endif;
	
	// get all categories for the element
	create categoryElements transient;
	xmlElementCategories.getAllElementsByTagName(XMLCategory, categoryElements);

	foreach xmlElementCategory in categoryElements do
		categoryText := xmlElementCategory.text;
		
		if not self.logResult and categoryText[1:9] = "SCHEDULE_" then
			break;		//cnwmc5 - 4/2/2013
		endif;
	endforeach;
epilog
	if xmlDocument &lt;&gt; null then
		delete xmlDocument;
	endif;
end;</source>
        <Parameter name="_logResult" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="checkNeedToRunMethod" id="ad0ca591-8721-4dad-8856-e0b066b2afa8">
        <source>checkNeedToRunMethod(_method : Method) : Boolean;

/*

Purpose:		Check whether method needs to be run	

Date			Who		Reason
28 April 2011	cnwmh5	Initial creation

*/

vars

	scheduleArray	: StringArray;
	
	returnVal		: Boolean;
	text			: String;
	
begin

	returnVal := true;
	
	create scheduleArray transient;
	text := _method.text.replaceString(", ", ",");
	text.replaceString("," &amp; Tab, ",");
	text.replaceString(CrLf, ",");
	scheduleArray.cnGetTokens(text, ",", false);
	
	if self.myScheduleConstant = null then
		if scheduleArray.includes(DO_NOT_RUN) then
			returnVal := false;
		endif;
	else
		if not scheduleArray.includes(self.myScheduleConstant.name) then
			returnVal := false;
		endif;
	endif;
	
	return returnVal;
	
epilog

	delete scheduleArray;

end;</source>
        <Parameter name="_method" type="Method"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
