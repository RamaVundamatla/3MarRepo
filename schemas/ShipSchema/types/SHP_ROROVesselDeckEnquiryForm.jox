    <JadeMethod name="doNewSubDeck" id="ba14cfee-df59-4091-92de-9746590c8d53">
        <source>doNewSubDeck() protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
27 April 2011	cnwer1	Initial creation CCMS 1031

*/

vars

	deck : CM_DeckVessel;
begin

	if self.tbRoRolDecks.accessRow(self.tbRoRolDecks.row) = null then
		return;
	endif;
	deck:=self.tbRoRolDecks.accessRow(self.tbRoRolDecks.row).itemObject.CM_DeckVessel;
	
	if deck &lt;&gt; null then
		if deck.isKindOf(CM_DeckVesselSub) then
			deck:=deck.CM_DeckVesselSub.myParentDeck;
		endif;
		self.myAssistant.SHP_Assistant.showROROVesselDeckDefn(deck,null,SHP_RORODeckDefinitionForm.Mode_New);
	endif;
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
