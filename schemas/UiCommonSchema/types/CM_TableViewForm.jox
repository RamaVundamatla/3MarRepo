    <JadeMethod name="handlePrintTableRowException" id="e2cb27da-1946-4698-aeb1-598a8fb7a84e">
        <source>handlePrintTableRowException(_exc : Exception) : Integer protected;

/*

Purpose:			Handle a table row exception during an attempt to print the contents of the view table


Return Value:		Standard exception return code


Date		Who		Reason
17 Mar 2008	cnwkpd1	PAR #16145 - 14049 exception when printing from Audit Details

*/

constants
	InvalidNumberOfRows		= 14049;
	InvalidTableRow			= 14051;
	
vars

begin
	if _exc.errorCode = InvalidNumberOfRows or
	   _exc.errorCode = InvalidTableRow then
		app.msgBox(app.getErrorString(ERR_MAX_TABLE_ROW_EXCEEDED), 'Error', MsgBox_OK_Only + MsgBox_Stop_Icon);
		return Ex_Abort_Action;
	endif;
	
	// Not our exception
	return Ex_Pass_Back;
	
	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_exc" type="Exception"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="handleTblDataDblClick" id="c8b6c1e6-644a-4406-a581-e872a3ba19a4">
        <updating/>
        <source>handleTblDataDblClick(_row : Integer) updating;
// ---------------------------------------------------------------------------
// Created:     13 September 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	obj	: Object;
begin
	obj := tblData.accessRow(_row).itemObject;

	if CM_TrackedItem.hasInstance(obj) then
		// want to open cargo edit with this object
		self.myAssistant.showCargoEnquiryForm(obj.CM_TrackedItem, self.myMasterMenuAction, true, false);
	elseif CM_CalculationType.hasInstance(obj) then  //cnwjo3 par 21001
		if self.btnEditTV.enabled = true then
			self.btnEditTV_click(self.btnEditTV);
		endif;
	endif;
end;</source>
        <Parameter name="_row" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="hideShowDataTable" id="25ab42b0-1758-4a85-9b29-83b3e6e627b8">
        <updating/>
        <source>hideShowDataTable() updating;
// ---------------------------------------------------------------------------
// Created:     21 July 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
// Ticket 44332 workaround for Steinweg Rotterdam
vars

begin

	self.isDataTableVisible := (not self.isDataTableVisible);
	
	// Ticket 44332 start
	if not self.isDataTableVisible then
		if self.sptMain.getMyLeftControl.width &lt; 10 then
			self.isDataTableVisible := (not self.isDataTableVisible);
		endif;
	endif;
	// Ticket 44332 end
	
	if self.isDataTableVisible then
		sptMain.showLeftControl(self.sptMainRatioSaved, true);
		self.btnExportCSVTV.enabled := true;
		self.btnPrintTV.enabled := true;
		self.btnShowSearchTV.enabled := true;
		//self.isDataFiltered := true;
		//self.allowSearch := true;
		//self.zShowSearcher();
	else
		self.sptMainRatioSaved := sptMain.leftToRightRatio;
		sptMain.hideLeftControl(true);
		self.btnExportCSVTV.enabled := false;
		self.btnPrintTV.enabled := false;
		self.btnShowSearchTV.enabled := false;	
		//self.isDataFiltered := false;
		//self.allowSearch := false;
		//self.zHideSearcher();
	endif;

end;</source>
    </JadeMethod>
    <JadeMethod name="hideShowThumbnail" id="b313df91-de26-4eeb-bdb1-5ff47b1b09fa">
        <updating/>
        <source>hideShowThumbnail() updating;
// ---------------------------------------------------------------------------
// Created:     21 July 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin

	self.isThumbnailVisible := (not self.isThumbnailVisible);

	if self.isThumbnailVisible then
		sptMain.showRightControl(100 - self.sptMainRatioSaved, true);
	else
		self.sptMainRatioSaved := sptMain.leftToRightRatio;
		sptMain.hideRightControl(true);
	endif;

end;</source>
    </JadeMethod>
    <JadeMethod name="includeObject" id="e30d9283-f393-4fb5-aa84-4d53c42483e0">
        <updating/>
        <source>includeObject(_obj : Object; _passport : CM_Passport) : Boolean updating;
// ---------------------------------------------------------------------------
// Created:     30 April 2002 by cnwrs2
//
// Purpose:     This should be overridden in the calling form to return
//				true/false if the object should be shown based on the
//				current filter criteria or state of the form
//
// Parameters:  The object to check (usually of the data class being displayed
//
// Returns:     True if the object is to be displayed / included in the dyna dict
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	return true;

end;</source>
        <Parameter name="_obj" type="Object"/>
        <Parameter name="_passport" type="CM_Passport"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="includeThumbnailEmptyRow" id="a0275947-ccb3-42c0-afb2-1e2f6ddcef81">
        <source>includeThumbnailEmptyRow(_dataStr : String input; 
							_entTableDef : EntTableDef;
							_heading : String) : Boolean protected;
/*

Date		Who		Reason
09 April 2014	cnwer1	Initial creation PAR

*/

vars
	entRow 		: EntTableRow;
begin
	if  not self.isHideThumbnailEmtpy then
		return true;
	endif;
	
	
	if _dataStr = null then
		return  false;
	endif;
	if _dataStr.isDecimal and _dataStr.Decimal = 0 then
		return  false;
	endif;
			
	if _dataStr = "false" or _dataStr = "No" then
		return  false;
	endif;
			
	if _entTableDef &lt;&gt; null then
		entRow:=_entTableDef.getEntTableRowByHeading(_heading);
		if entRow &lt;&gt;  null and entRow.measurementType &lt;&gt; null and _dataStr[1] = " "  then	
			return  false;
		endif;
	endif;
	
	return true;

epilog

end;</source>
