    <JadeMethod name="validateMe" id="61d96cab-5582-4191-867f-fe99d7c198fd">
        <source>validateMe() protected;

/*

Purpose:		
Parameters:		
Return Value:	

Date				Who		Reason
15 May 2009			cnwrl1	Initial creation as part of PAR 19668 - CCMS 1814

*/
	
vars
	
begin
	self.raiseExceptionIfNotTransient( method );
	
	if self.myMachine = null then
	//	app.raiseCMException1( REQUIRED_FIELD, app.getErrorString( Machine ), null, null );
		app.raiseCMException1( Input_required_field_Required, app.getErrorString( Machine ), null, null ); // cnwdb2	PAR 35364


	endif;
	
	if self.myTCPInterfaceDefinition = null then		// of course this should never happen!
//		app.raiseCMException1( REQUIRED_FIELD, app.getErrorString( Test_again ) &amp; 'TCPInterfaceDefinition', null, null );	// cnwrl1 30/06/2009 PAR 20090 - what it was
		app.raiseCMException( Interface_Defn_Null_4_History, null, null );
	endif;
	
epilog
	
end;
</source>
        <access>protected</access>
