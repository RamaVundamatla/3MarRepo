    <DbClassMap file="jsscore_transient"/>
    <JadeMethod name="addBinary" id="382b78a9-3678-4eb2-9e42-24ca48bd6eeb">
        <lockReceiver/>
        <updating/>
        <source>addBinary(pBinaryValue:Binary):Integer updating;
// --------------------------------------------------------------------------------
// Created:		29 August 1999 -  addBinary
// By:			cnwdad1
//
// Purpose:		Adds a new element to the array with the specified binary value.
//
// Parameters:	pBinaryValue (Binary) - The binary value for the new array element.
// Returns:		Integer - The index of the new array element.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	theElement	: JSSElement;
	index		: Integer;

begin
	theElement	:=	self.createEntry();
	theElement.setBinaryValue(pBinaryValue);
	index	:=	self.size() + 1;
	self.atPut(index, theElement);
epilog
	return index;
end;</source>
        <Parameter name="pBinaryValue" type="Binary"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="addBinaryAt" id="476f2af9-4010-4de5-8fe0-0c3c6122c3b9">
        <lockReceiver/>
        <updating/>
        <source>addBinaryAt(pIndex:Integer; pBinaryValue:Binary) updating;
// --------------------------------------------------------------------------------
// Created:		29 August 1999 -  addBinaryAt
// By:			cnwdad1
//
// Purpose:		Inserts a new element into the array at the specified index position
//				and with the specified binary value.
//
// Parameters:	pBinaryValue (Binary) - The binary value for the new array element.
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	theElement	: JSSElement;

begin
	theElement	:=	self.createEntry();
	theElement.setBinaryValue(pBinaryValue);
	self.atPut(pIndex, theElement);
end;</source>
        <Parameter name="pIndex" type="Integer"/>
        <Parameter name="pBinaryValue" type="Binary"/>
    </JadeMethod>
