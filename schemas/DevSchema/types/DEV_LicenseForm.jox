    <JadeMethod name="doListModuleUsageSYSSUBS" id="058f468c-d6e6-4d93-bdf1-2677509e9417">
        <updating/>
        <source>doListModuleUsageSYSSUBS() updating;
/*
Purpose - 	
Who - NAVAB1
Date - 09JAN2025
ADO - JIRA 33502
*/

vars
	permObj : CM_PermissionObject;
	idx, currentRow : Integer;
	 
	client : DEV_LicenseClient;
	license : DEV_LicenseDtl;
begin

	currentRow := self.tblLicense.row;
	
	if currentRow &lt;= self.tblLicense.fixedRows then
		return;
	endif;
	
	self.tblLicense.accessRow(currentRow);
	permObj := self.tblLicense.accessedRow.itemObject.CM_PermissionObject;
	
	if permObj = null then
		return;
	endif;
	
	write permObj.description;
	write "";
	
	idx := permObj.constValue;
	idx := permObj.constValue - Mod_BaseView;
	
	foreach client in self.allClients do
		foreach license in client.allLicenseDtls do : innerloop
			if license.type = self.currentLicenseType then
			
				if idx &lt;= license.allDetails.size then
					if license.allDetails[idx] = true then
						write client.name;
						break innerloop;
					endif;
				endif;
			endif;
		endforeach;
	endforeach;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doPrintAll" id="9c520f65-0926-411b-b996-9db1e80a991a">
        <source>doPrintAll() protected;
// ---------------------------------------------------------------------------
// Created:     14 September 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	tmpPrintTable	: CM_GenericTablePrint;
	tmpClient		: DEV_LicenseClient;
	tmpDtl			: DEV_LicenseDtl;
	onlyReal		: Boolean;

begin

	tmpClient := self.myCurrentClient;
	if tmpClient = null then
		app.msgBox('Please select a client to print', 'Error', 0);
		return;
	endif;

	app.mousePointer := MousePointer_HourGlass;

	onlyReal	:= self.chkOnlyReal.value;

	app.printer.printPreview := true;
	app.printer.suppressDialog := true;
	app.printer.setMargins(Print_Portrait,10,10,10,10);
	
	create tmpPrintTable transient;
	
	foreach tmpClient in self.allClients do
		if onlyReal and (not tmpClient.isRealClient) then
			continue;
		endif;
		self.printClient(tmpClient, tmpPrintTable);
		app.printer.newPage();
	endforeach;

epilog
	app.printer.close;
	delete tmpPrintTable;
	app.mousePointer := MousePointer_Default;

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doPrintCurrent" id="760ef67c-32d9-42be-a76c-3f156b71cd1a">
        <source>doPrintCurrent() protected;
// ---------------------------------------------------------------------------
// Created:     14 September 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	tmpPrintTable	: CM_GenericTablePrint;
	tmpClient		: DEV_LicenseClient;
	tmpDtl			: DEV_LicenseDtl;

begin

	tmpClient := self.myCurrentClient;
	if tmpClient = null then
		app.msgBox('Please select a client to print', 'Error', 0);
		return;
	endif;

	app.mousePointer := MousePointer_HourGlass;

	app.printer.printPreview := true;
	app.printer.suppressDialog := true;
	app.printer.setMargins(Print_Portrait,10,10,10,10);
	
	create tmpPrintTable transient;
	self.printClient(tmpClient, tmpPrintTable);

epilog
	app.printer.close;
	delete tmpPrintTable;
	app.mousePointer := MousePointer_Default;

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doSave" id="521b2c10-0a88-46e1-8a47-5266d2b35468">
        <updating/>
        <source>doSave() : Boolean updating, protected;
// ---------------------------------------------------------------------------
// Created:     05 November 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
begin
	if self.clientSave() then
		return self.doSaveDtl();
	endif;
	return false;
end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doSaveDtl" id="8f763313-e10a-44c2-8826-52863a11e180">
        <updating/>
        <source>doSaveDtl() : Boolean updating, protected;
// ---------------------------------------------------------------------------
// Created:     13 September 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	idx,
	ediIdx,
	numRows,
	rowIdx,
	permIdx			: Integer;
	tmpEdiLicenseDtl,
	tmpLicenseDtl	: DEV_LicenseDtl;
	tmpObj			: Object;
	ediFileType		: CM_EDIFileType;
	permObj			: CM_PermissionObject;
	haveAddedEDI,
	haveAdded,
	tmpValue, hasMTNCore		: Boolean;
	tmpDate			: Date;
	camDescType		: CM_CamProtocolDesc;
	subsExpDate, ewsExpiryDate: Date;
	ediAgent	: CM_EDIFileTypeAgent;
begin

	tmpLicenseDtl := self.myCurrentLicenseDtl;
	if tmpLicenseDtl = null then
		tmpLicenseDtl := self.myCurrentClient.addLicenseDtl(self.cmbLicenseType.text, self.currentLicenseType);
		if tmpLicenseDtl = null then
			// must have been an error in above, which will have already been shown
			return false;
		endif;
		haveAdded := true;
	endif;
	
	tmpDate := self.txtExpiryDate.getDate();
	if (not tmpLicenseDtl.validateExpiryDate(tmpDate)) then
		self.txtExpiryDate.setFocus();
		if haveAdded then
			delete tmpLicenseDtl;
		endif;
		return false;
	endif;
	
	tmpLicenseDtl.setForUpdate(tmpLicenseDtl.name, self.txtExpiryDate.getDate());
	tmpLicenseDtl.clearArrays(); // ### JIRA 33541 12DEC2024 NAVAB1
	
	numRows := self.tblLicense.rows;

	foreach rowIdx in self.tblLicense.fixedRows + 1 to numRows do
		tmpObj := self.tblLicense.accessRow(rowIdx).itemObject;
		if tmpObj = null then
			//23/12/2024	navkc1 JIRA Story MTN-33491 - System License type has a special row with empty object for EDI Base Bundle
			if not self.currentLicenseType = DEV_LicenseEntity.LicenseType_System then
				continue;
			endif;
		endif;
		
		tmpValue := (self.tblLicense.accessCell(rowIdx, ValueColumn).text = '1');
		subsExpDate := null;
		
		if self.currentLicenseType = DEV_LicenseEntity.LicenseType_Subscription then	//17 Jun 2020	NDL	TFS 49569
			tmpValue := (self.tblLicense.accessCell(rowIdx, 3).text = '1');
			if tmpValue then
				subsExpDate := self.tblLicense.accessCell(rowIdx, 2).text.Date;
			endif;
			permObj := tmpObj.CM_PermissionObject;
			permIdx := permObj.constValue;
		// ### JIRA 33543 12DEC2024 NAVAB1
		elseif self.currentLicenseType = DEV_LicenseEntity.LicenseType_EWS then
			tmpValue := (self.tblLicense.accessCell(rowIdx, 3).text = '1');
			if tmpValue then
				subsExpDate := self.tblLicense.accessCell(rowIdx, 2).text.Date;
			endif;
			if tmpObj.isKindOf(CM_EWSEndpointType) then
				permIdx := tmpObj.CM_EWSEndpointType.type;
			elseif tmpObj.isKindOf(CM_ExternalWebServiceType) then
				permIdx := tmpObj.CM_ExternalWebServiceType.type;
			endif;
		elseif self.currentLicenseType = DEV_LicenseEntity.LicenseType_EDI then
			if CM_EDIFileType.hasInstance(tmpObj) then
				ediFileType := tmpObj.CM_EDIFileType;
				permIdx := ediFileType.type;
			elseif CM_CamProtocolDesc.hasInstance(tmpObj) then
				camDescType := tmpObj.CM_CamProtocolDesc;
				permIdx := camDescType.type;
			endif;
			
		else
			//23/12/2024	navkc1 JIRA Story MTN-33491 - Special row for EDI Base Bundle
			if tmpObj = null then
				
				// If it's EDI Base bundle
				if self.tblLicense.accessCell(rowIdx, 1).text = "EDI " &amp; CM_EDIFileType.EDI_Bundle_BASE_Str then
					ediAgent := self.myEDIFileTypeAgent;
					
					tmpEdiLicenseDtl := self.myCurrentClient.myEDILicense;
					
					// We don't have a EDI License and is not checked to enable it, then don't do anything
					if tmpEdiLicenseDtl = null and not tmpValue then
						continue;
					endif;
					
					// Create new EDI License type detail if it's null
					if tmpEdiLicenseDtl = null and tmpValue then
						tmpEdiLicenseDtl := self.myCurrentClient.addLicenseDtl(ProductStr_JMT_EDI, DEV_LicenseEntity.LicenseType_EDI);
						
						haveAddedEDI := true;
						
						// If still null, skip the EDI Base bundle and continue with other rows
						if tmpEdiLicenseDtl = null then
							app.msgBox("Error creating EDI License type detail. Skipped EDI Base Bundle and proceed with others. Please do the EDI Base Bundle manually", "Error", MsgBox_OK_Only);
							continue;
						endif;
					endif;
					
					// Update the License Type combo index with the EDI License type detail object
					if haveAddedEDI then
						// Delete the existing index with null object
						ediIdx := self.cmbLicenseType.findStringExact(1, ProductStr_JMT_EDI);
						self.cmbLicenseType.removeItem(ediIdx);
						
						// Add a new index with actual EDI License type detail object
						self.cmbLicenseType.addItemObject(ProductStr_JMT_EDI, tmpEdiLicenseDtl);
						
						// Set the list index back to System License.
						idx := self.cmbLicenseType.findObject(tmpLicenseDtl);
						self.cmbLicenseType.listIndex := idx;
						
						// Set the expiry date of the EDI License type detail
						tmpEdiLicenseDtl.setForUpdate(tmpEdiLicenseDtl.name, self.txtExpiryDate.getDate());
					endif;
					
					// Get permission for base bundle and set to true
					foreach ediFileType in ediAgent.allEDIFileTypes do
						if ediFileType.getEDIBundle() &lt;&gt; CM_EDIFileType.EDI_Bundle_BASE then
							continue;
						endif;
						permIdx := ediFileType.type;
						tmpEdiLicenseDtl.setPermission(permIdx, tmpValue, subsExpDate);
					endforeach;
					
					// Get permission for base bundle and set to true
					foreach camDescType in ediAgent.allCAMProtocolDescs do
						if camDescType.getEDIBundle() &lt;&gt; CM_EDIFileType.EDI_Bundle_BASE then
							continue;
						endif;
						permIdx := camDescType.type;
						tmpEdiLicenseDtl.setPermission(permIdx, tmpValue, subsExpDate);
					endforeach;
					
					// Done with EDI Base bundle row, continue to the next row
					continue;
				endif;
			endif;
			
			permObj := tmpObj.CM_PermissionObject;
			permIdx := permObj.constValue;
		//	write permIdx;
			// ### JIRA 33502 20DEC2024 NAVAB1
			if permIdx = Mod_BaseSystem then
				hasMTNCore := true;
			endif;
		endif;
		
		tmpLicenseDtl.setPermission(permIdx, tmpValue, subsExpDate);
	endforeach;

	// ### JIRA 33502 20DEC2024 NAVAB1
	if self.currentLicenseType = DEV_LicenseEntity.LicenseType_System then
		if hasMTNCore then
			tmpLicenseDtl.setPermission(Mod_YardPlanning, true, null);
			tmpLicenseDtl.setPermission(Mod_CargoGroup, true, null);
			tmpLicenseDtl.setPermission(Mod_CargoShip, true, null);
			tmpLicenseDtl.setPermission(Mod_CargoHandling, true, null);
			tmpLicenseDtl.setPermission(Mod_Weighing, true, null);
			tmpLicenseDtl.setPermission(Mod_Webservice, true, null);
			
			if self.chkRealClient.value then // ### JIRA 33843 23JAN2025 NAVAB1 only for real clients not internal 
				if not self.isClientAJMAN() then
					tmpLicenseDtl.setPermission(Mod_DutyDoc, false, null); // ALWAYS FALSE
				endif;
				if not self.isClientC3() then
					tmpLicenseDtl.setPermission(Mod_Logs, false, null); // ALWAYS FALSE
				endif;
			endif;
		endif;	
	endif;
	
	//17 Jun 2020	NDL	TFS 49569
	if  tmpLicenseDtl.type = DEV_LicenseEntity.LicenseType_Subscription then
		if (not tmpLicenseDtl.validateSubsExpDates( self.mySubscriptionPermAgent )) then
			self.txtExpiryDate.setFocus();
			if haveAdded then
				delete tmpLicenseDtl;
			endif;
			return false;
		endif;
	endif;
	if tmpLicenseDtl.type = DEV_LicenseEntity.LicenseType_EWS then // ### JIRA 33543 12DEC2024 NAVAB1
		if not  tmpLicenseDtl.validateEWSExpiryDates( self.myEWSTypeAgent) then
			return false;
		endif;
	endif;

	// save the data in the "dataBase"
	self.saveAsXML();
	self.compareChanges();	// ###  JIRA 36920 05JAN2026 NAVAB1
	self.setHasLicenseDtlsChanged(false);
	
	if haveAdded then
		self.initComboLicenseType(self.myCurrentClient);
		self.setCurrentLicenseDtl(tmpLicenseDtl, tmpLicenseDtl.type);
	endif;
	
	self.mode := 0;	//08 Oct 2019	NDL	TFS 46169

	return true;

end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doSaveDtlSimple" id="7877ecca-03bb-48d9-b9a3-1784c0f58ab1">
        <updating/>
        <source>doSaveDtlSimple() : Boolean updating, protected;
/*
Purpose:			
Date				Who			Reason
April 2017		CNWAB1		Initial creation
08 Oct 2019	NDL	TFS 46169
*/
vars
	numRows,
	rowIdx,
	permIdx			: Integer;
	tmpLicenseDtl	: DEV_LicenseDtl;
	tmpObj			: Object;
	ediFileType		: CM_EDIFileType;
	permObj			: CM_PermissionObject;
	haveAdded,
	tmpValue		: Boolean;
	tmpDate			: Date;
	camDescType		: CM_CamProtocolDesc;
	pmBaseSystem, pmVTMISMod, pmCashDebtorModule, pmInvoiceMod : Boolean;
begin
/*  // ### JIRA 33843 23JAN2025 NAVAB1 not used



	tmpLicenseDtl := self.myCurrentLicenseDtl;
	if tmpLicenseDtl = null then
		tmpLicenseDtl := self.myCurrentClient.addLicenseDtl(self.cmbLicenseType.text, self.currentLicenseType);
		if tmpLicenseDtl = null then
			// must have been an error in above, which will have already been shown
			return false;
		endif;
		haveAdded := true;
	endif;
	
	tmpDate := self.txtExpiryDate.getDate();
	if (not tmpLicenseDtl.validateExpiryDate(tmpDate)) then
		self.txtExpiryDate.setFocus();
		if haveAdded then
			delete tmpLicenseDtl;
		endif;
		return false;
	endif;
	
	tmpLicenseDtl.setForUpdate(tmpLicenseDtl.name, self.txtExpiryDate.getDate());
	
	numRows := self.tblLicense.rows;

	foreach rowIdx in self.tblLicense.fixedRows + 1 to numRows do
		tmpObj := self.tblLicense.accessRow(rowIdx).itemObject;
		if tmpObj = null then
			continue;
		endif;
			permObj := tmpObj.CM_PermissionObject;
		
		tmpValue := (self.tblLicense.accessCell(rowIdx, ValueColumn).text = '1');
		if tmpValue and permObj.constValue = Mod_BaseSystem then
			pmBaseSystem := true;
		endif;
		if tmpValue and permObj.constValue = Mod_Cash then
			pmCashDebtorModule := true;
		endif;
		if tmpValue and permObj.constValue = Mod_Invoicing then
			pmInvoiceMod := true;
		endif;
		if tmpValue and permObj.constValue = Mod_Harbour then
			pmVTMISMod := true;
		endif;
		
	endforeach;

	if pmBaseSystem then
		tmpLicenseDtl.setPermission(Mod_BaseSystem, true, null);
		tmpLicenseDtl.setPermission(Mod_YardPlanning, true, null);
		tmpLicenseDtl.setPermission(Mod_BulkCargo, true, null);
		tmpLicenseDtl.setPermission(Mod_CargoShip, true, null);
		tmpLicenseDtl.setPermission(Mod_CargoHandling, true, null);
		tmpLicenseDtl.setPermission(Mod_DataExtract, true, null);
		tmpLicenseDtl.setPermission(Mod_EDIVGM, true, null);
		tmpLicenseDtl.setPermission(Mod_GeneralCargo, true, null);
		tmpLicenseDtl.setPermission(Mod_Weighing, true, null);
		tmpLicenseDtl.setPermission(Mod_VesselRORO, true, null);
		tmpLicenseDtl.setPermission(Mod_WebApps, true, null);
		tmpLicenseDtl.setPermission(Mod_Queuing, true, null);
		tmpLicenseDtl.setPermission(Mod_Rail, true, null);
		tmpLicenseDtl.setPermission(Mod_VehicleBooking, true, null);
		tmpLicenseDtl.setPermission(Mod_Webservice, true, null);
		
		tmpLicenseDtl.setPermission(Mod_DutyDoc, false, null); // ALWAYS FALSE
		tmpLicenseDtl.setPermission(Mod_Logs, false, null); // ALWAYS FALSE
		
	endif;
	
	if pmCashDebtorModule then
		tmpLicenseDtl.setPermission(Mod_Cash, true, null);
	endif;
	
	if pmInvoiceMod then
		tmpLicenseDtl.setPermission(Mod_Invoicing, true, null);
	endif;
	
	if pmVTMISMod then
		tmpLicenseDtl.setPermission(Mod_Harbour, true, null);
	endif;

	// save the data in the "dataBase"
	self.saveAsXML();
	
	self.setHasLicenseDtlsChanged(false);
	
	self.mode := 0;	//08 Oct 2019	NDL	TFS 46169
	if haveAdded then
		self.initComboLicenseType(self.myCurrentClient);
		self.setCurrentLicenseDtl(tmpLicenseDtl, tmpLicenseDtl.type);
	endif;
	
	self.initTblLicenseForSysOrTerminal(self.myCurrentLicenseDtl); //08 Oct 2019	NDL	TFS 46169
*/
	return true;

end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doSelectEDILicense" id="4d92603e-8bd8-4299-95ba-bd0e08fdb1ab">
        <source>doSelectEDILicense();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23/12/2024	navkc1 JIRA Story MTN-33491: MTN | License - EDI Bundles Methods

*/
vars
	selectedBundleType,
	bundleType,
	row,
	maxRow,
	firstRow,
	selectedRow		: Integer;
	rowObj,
	selectedLicense : Object;
	table 			: CM_BaseTable;
	canDoRemain,
	isGroupSelected : Boolean;
	canDo,
	setCanDo		: String;
begin
	
	table := self.tblLicense;
	maxRow := table.rows;
	selectedRow := table.row;
	firstRow := table.fixedRows + 1;
	
	selectedLicense := table.accessRow(selectedRow).itemObject;
	setCanDo := table.accessCell(selectedRow, self.ValueColumn).text;
	
	selectedBundleType := table.accessCell(selectedRow, self.EDIBundleColumn).text.Integer;

	// Grouping header is selected
	if selectedLicense = null then
		isGroupSelected := true;
	endif;
	
	if isGroupSelected then
		// Grouping header is selected, proceed to tick/untick all licenses within that grouping
		foreach row in selectedRow + 1 to maxRow do
			rowObj := table.accessRow(row).itemObject;
			bundleType := table.accessCell(row, self.EDIBundleColumn).text.Integer;
			
			// We reach a different grouping header/different bundle type
			if rowObj = null or bundleType &lt;&gt; selectedBundleType then
				break;
			endif;
			
			// Set value
			table.accessCell(row, self.ValueColumn).text := setCanDo;
		endforeach;
	else
		// Individual license is selected, find the grouping header and tick/untick it
		
		// This loop go DOWNWARDS from the selected license to the next grouping
		foreach row in selectedRow + 1 to maxRow do
			rowObj := table.accessRow(row).itemObject;
			bundleType := table.accessCell(row, self.EDIBundleColumn).text.Integer;
			
			// We reach a different grouping header/different bundle type
			if rowObj = null or bundleType &lt;&gt; selectedBundleType then
				break;
			endif;
			
			canDo := table.accessCell(row, self.ValueColumn).text;
			
			// If we are unticking a license, we want to make sure other licenses within the group is all untick before unticking the grouping header
			if setCanDo = '0' and canDo &lt;&gt; setCanDo then
				// There are still licenses ticked within the group, don't need to change the groping header
				canDoRemain := true;
				break;
			endif;
		endforeach;
		
		// If we still want to change the value of the grouping
		if not canDoRemain then
			// This loop go UPWARDS from the selected license to it's own grouping
			foreach row in selectedRow - 1 to firstRow step -1 do
				rowObj := table.accessRow(row).itemObject;
				bundleType := table.accessCell(row, self.EDIBundleColumn).text.Integer;
				
				// We reach a different grouping header/different bundle type
				if bundleType &lt;&gt; selectedBundleType then
					break;
				endif;
				
				// License
				if rowObj &lt;&gt; null then
					canDo := table.accessCell(row, self.ValueColumn).text;
					// If we are unticking a license, we want to make sure other licenses within the group is all untick before unticking the grouping header
					if setCanDo = '0' and canDo &lt;&gt; setCanDo then
						// There are still licenses ticked within the group, don't need to change the groping header
						canDoRemain := true;
						break;
					endif;
				endif;
				
				// This is the grouping header row of the selected license
				if rowObj = null then
					table.accessCell(row, self.ValueColumn).text := setCanDo;
				endif;
				
			endforeach;
		endif;
		
	endif;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doSetAllForSubs" id="6082c3d6-39f4-4130-a839-03b07f4caef0">
        <updating/>
        <source>doSetAllForSubs() updating;
/*
Purpose:	

Date		Who		Reason
09 January 2025	navab1	JIRA 33502
*/

vars
	tmpValue : Boolean;
	rowIdx, colIdx : Integer;
	expDate : Date;
	tmpLicenseDtl : DEV_LicenseDtl;
begin

	tmpLicenseDtl := self.myCurrentLicenseDtl;
	expDate := self.txtExpiryDate.getDate();
	if (not tmpLicenseDtl.validateExpiryDate(expDate)) then
		self.txtExpiryDate.setFocus();
	endif;
	
	rowIdx := self.tblLicense.row;
	
	if not expDate.isValid then
		return;
	endif;
	
	self.setHasLicenseDtlsChanged(true);

	foreach rowIdx in self.tblLicense.fixedRows + 1 to self.tblLicense.rows do
		if self.currentLicenseType = DEV_LicenseEntity.LicenseType_Subscription 
		or self.currentLicenseType = DEV_LicenseEntity.LicenseType_EWS then
			if self.btnSetAll.helpContextId = 1 then
				self.tblLicense.accessCell(rowIdx, 3).text := '0';
				self.tblLicense.accessCell(rowIdx, 2).text := "";
			else
				self.tblLicense.accessCell(rowIdx, 3).text := '1';
				self.tblLicense.accessCell(rowIdx, 2).text := expDate.shortFormat();
			endif;
		else
			if self.btnSetAll.helpContextId = 1 then
				self.tblLicense.accessCell(rowIdx, 2).text := '0';
			else
				self.tblLicense.accessCell(rowIdx, 2).text := '1';
			endif;
		endif;			
	endforeach;
	
	if self.btnSetAll.helpContextId = 1 then
		self.btnSetAll.helpContextId := 0;
		self.btnSetAll.caption := 'Set All';
	else
		self.btnSetAll.helpContextId := 1;
		self.btnSetAll.caption := 'Unset All';
	endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doShowAllClickEDI" id="835c7b96-804b-494a-bcd7-b06b17141f80">
        <source>doShowAllClickEDI(_isShowAll : Boolean);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23/12/2024	navkc1 JIRA Story MTN-33491: MTN | License - EDI Bundles Methods

*/

vars
	fixedRow,
	maxRow,
	row			: Integer;
	
	table 		: CM_BaseTable;
	tableRow	: JadeTableRow;
begin
	
	table := self.tblLicense;
	fixedRow := table.fixedRows;
	maxRow := table.rows;
	
	foreach row in fixedRow + 1 to maxRow do
		tableRow := table.accessRow(row);
		
		if _isShowAll then
			// In show all, hide bundle, show module
			if tableRow.itemObject = null then
				tableRow.visible := false;
			else
				tableRow.visible := true;
			endif;
			
		else
			// In show all, show bundle, hide module
			if tableRow.itemObject = null then
				tableRow.visible := true;
			else
				tableRow.visible := false;
			endif;
			
		endif;
	endforeach;
	
epilog

end;</source>
        <Parameter name="_isShowAll" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doTerminalNameUpdate" id="77032609-df81-4d75-82f7-bfe81d3b1e0f">
        <updating/>
        <source>doTerminalNameUpdate() updating, protected;
// ---------------------------------------------------------------------------
// Created:     06 November 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	tmpStr	: String;
	licDtl	: DEV_LicenseDtl;
	
begin

	if self.myCurrentClient = null then
		app.msgBox('You must select a client', 'Error', 0);
		return;
	endif;

	
	licDtl := self.myCurrentLicenseDtl;
	if licDtl = null then
		app.msgBox('You must select a terminal line to update', 'Error', 0);
		return;
	endif;
	
	tmpStr := licDtl.name;
	
	read tmpStr;
	if tmpStr = null then
		// user pressed cancel
		return;
	endif;
	
	licDtl.setForUpdate(tmpStr, licDtl.expiryDate);
	
	// update the name in the textbox
	self.cmbLicenseType.itemText[self.cmbLicenseType.listIndex] := tmpStr;
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="getConstant" id="a8695e24-61b1-4553-a1be-7e8835343d64">
        <source>getConstant() : Constant protected;
// ---------------------------------------------------------------------------
// Created:     06 November 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin

	return DEV_LicenseEntity.getConstant(DEV_LicenseEntity.DETAILS);
	
end;</source>
        <access>protected</access>
        <ReturnType type="Constant"/>
    </JadeMethod>
    <JadeMethod name="getDateChangeNote" id="d9f60219-7001-4f09-b2e3-f046b3a3ca01">
        <source>getDateChangeNote(name : String;permExp, permExpBefore : Date) : String;
/*
Purpose:	

Date		Who		Reason
07 January 2026	navab1	JIRA 36920
*/

vars
	dateStrBefore, dateStr, dateChange : String;
begin
	if permExp &lt;&gt; permExpBefore then
		if permExpBefore = null then
			dateStrBefore := "NULL";
		else
			dateStrBefore := permExpBefore.String;
		endif;
		if permExp = null then
			dateStr := "NULL";
		else
			dateStr := permExp.String;
		endif;
		
		dateChange := name &amp; " expiry has changed from " &amp; dateStrBefore &amp; " to " &amp; dateStr;
		
		return dateChange;
	endif;
	
	return null;
epilog

end;</source>
        <Parameter name="name" type="String"/>
        <Parameter name="permExp" type="Date"/>
        <Parameter name="permExpBefore" type="Date"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getLicenseTypeFromText" id="2dfeeb8e-ba0b-47a0-a4da-903f46c0d414">
        <source>getLicenseTypeFromText(_text : String) : Integer protected;
// ---------------------------------------------------------------------------
// Created:     13 September 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
// ### JIRA 33543 12DEC2024 NAVAB1 change to use constants
vars

begin

	if _text = ProductStr_JMT_EDI then
		return DEV_LicenseEntity.LicenseType_EDI;
	elseif _text = ProductStr_JMT  then
		return DEV_LicenseEntity.LicenseType_System;
	elseif _text = ProductStr_SUBS  then	//17 Jun 2020	NDL	TFS 49569
		return DEV_LicenseEntity.LicenseType_Subscription;
	elseif _text = ProductStr_EWS  then	// ### JIRA 33543 12DEC2024 NAVAB1
		return DEV_LicenseEntity.LicenseType_EWS;
	endif;
	
	// assume that must be a terminal one
	return DEV_LicenseEntity.LicenseType_Terminal;

end;</source>
        <access>protected</access>
        <Parameter name="_text" type="String"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getRemoteObject" id="d3653a4b-7807-4d22-8c26-620b4fa2a26b">
        <source>getRemoteObject() : Object protected;
// ---------------------------------------------------------------------------
// Created:     06 November 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
constants
	SCHEMA_NAME		: String = "JSSLicenseKeyMaintSchema";
	CLASS_NAME		: String = "JSSLKey";

vars
	theRemoteSchema	: Schema;
	theRemoteClass	: Class;
	theRemoteObject	: Object;

begin

	theRemoteSchema	:=	rootSchema.getSchema(SCHEMA_NAME);
	
	if theRemoteSchema = null then
		app.msgBox("Could not locate the remote schema (" &amp; SCHEMA_NAME &amp; ").", 'Error', 0);
		return theRemoteObject;
	endif;

	theRemoteClass	:=	theRemoteSchema.getClass(CLASS_NAME);
		
	if theRemoteClass = null then
		app.msgBox("Could not locate the service interface class (" &amp; CLASS_NAME &amp; ").", 'Error', 0);
		return theRemoteObject;
	endif;

	create theRemoteObject as theRemoteClass transient;

	return theRemoteObject;

end;</source>
        <access>protected</access>
        <ReturnType type="Object"/>
    </JadeMethod>
    <JadeMethod name="getValueForSysTermPermission" id="48be6a7b-7266-4a65-b371-7a95e55fc989">
        <source>getValueForSysTermPermission(_licenseDtl : DEV_LicenseDtl; _permValue : Integer; _ignore : Boolean output; _subExpDate : Date output) : Boolean protected;
// ---------------------------------------------------------------------------
// Created:     14 September 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin

	_subExpDate:= null; //17 Jun 2020	NDL	TFS 49569
	
	if _permValue = Mod_BaseView then
		_ignore := true;
		return false;
	endif;
	if _permValue = PmNum01 or
	   _permValue = PmNum02 or
	   _permValue = PmNum03 or
	   _permValue = PmNum04 or
	   _permValue = PmNum05 or
	   _permValue = PmNum06 or
	   _permValue = PmNum07 or
	   _permValue = PmNum08 or
	   _permValue = PmNum09 or
	   _permValue = PmNum10 or
	   _permValue = PmAdmInternal or
	   _permValue = PmSite then
		_ignore := true;
		return false;
	endif;

	_ignore := false;
	
	
	if _licenseDtl &lt;&gt; null then
		if _licenseDtl.canDo(_permValue) then	//17 Jun 2020	NDL	TFS 49569
			if _licenseDtl.type = _licenseDtl.LicenseType_Subscription 
			or _licenseDtl.type = _licenseDtl.LicenseType_EWS then // ### JIRA 33541 16DEC2024 NAVAB1
				_subExpDate := _licenseDtl.getSubscriptionExpDate( _permValue );
			endif;
			return true;
		endif;
	endif;
	
	return false;

end;</source>
        <access>protected</access>
        <Parameter name="_licenseDtl" type="DEV_LicenseDtl"/>
        <Parameter name="_permValue" type="Integer"/>
        <Parameter name="_ignore" type="Boolean" usage="output"/>
        <Parameter name="_subExpDate" type="Date" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="init" id="5dec1fd5-9452-4855-94ac-5845849a322b">
        <updating/>
        <source>init() updating, protected;
// ---------------------------------------------------------------------------
// Created:     05 November 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	tmpConst	: Constant;

begin

	self.colorChange	:= LightRed;

	create self.myPermissionAgent transient;
	create self.myEDIFileTypeAgent transient;
	create self.mySubscriptionPermAgent transient;
	create self.myEWSTypeAgent transient; // ### JIRA 33541 12DEC2024 NAVAB1
	
	tmpConst := self.getConstant();
	
	if tmpConst = null then
		app.msgBox('Constant not found!', 'Error', MsgBox_OK_Only);
		terminate;
	endif;
	
	self.myConstant := tmpConst;
	
	self.createClientBeforeData(tmpConst.text);  // ###  JIRA 36920 05JAN2026 NAVAB1
	self.createClientData(tmpConst.text);
	

	self.myPermissionAgent.populatePermissionDict(false, true, 0);
	self.mySubscriptionPermAgent.populatePermissionDict(false, true, PermType_Subscriptions);	//17 Jun 2020	NDL	TFS 49569
	self.myEDIFileTypeAgent.init();
	self.myEWSTypeAgent.init(); // ### JIRA 33541 12DEC2024 NAVAB1
	
	self.initComboClient();
	mode := 0;	//09 Oct 2019	NDL	TFS 46169
	self.setCurrentClient(self.allClients.first);	
	
	self.caption := self.caption &amp; " " &amp; app.dbPath;  // ### JIRA 36920 07JAN2026 NAVAB1

	self.minimumWidth := 800;	//09 Oct 2019	NDL	TFS 46169
	self.minimumHeight := 800;	//09 Oct 2019	NDL	TFS 46169
	
	self.resize();
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="initComboClient" id="bf51f35a-daba-4b9f-b9b8-682e6e47e166">
        <source>initComboClient() protected;
// ---------------------------------------------------------------------------
// Created:     05 November 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	tmpClient	: DEV_LicenseEntity;

begin

	cmbClient.clear;

	foreach tmpClient in self.allClients do
		cmbClient.addItemObject(tmpClient.name, tmpClient);
		
		if tmpClient.getIsRealClient() then
			//write tmpClient.name &amp; ", " &amp; tmpClient.name[1:20] &amp; ", " &amp; tmpClient.name[1:30] &amp; ", " &amp; tmpClient.getNumTerminals().String;
		endif;
	endforeach;

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="initComboLicenseType" id="9341f216-762b-4bb9-97d7-d4549105a3b1">
        <source>initComboLicenseType(_client : DEV_LicenseClient) protected;
// ---------------------------------------------------------------------------
// Created:     13 September 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
// ### JIRA 33543 12DEC2024 NAVAB1 change to use constants
vars
	tmpTerm	: DEV_LicenseDtl;
	
begin

	self.cmbLicenseType.clear;
	if _client = null then
		return;
	endif;

	self.cmbLicenseType.addItemObject(ProductStr_JMT, _client.mySystemLicense);
	self.cmbLicenseType.addItemObject(ProductStr_JMT_EDI , _client.myEDILicense);
	self.cmbLicenseType.addItemObject(ProductStr_SUBS , _client.mySubscriptionLicense);	//17 Jun 2020	NDL TFS 49569
	self.cmbLicenseType.addItemObject(ProductStr_EWS , _client.myEWSLicense); // ### JIRA 33543 12DEC2024 NAVAB1

	foreach tmpTerm in _client.allTerminalLicenses do
		self.cmbLicenseType.addItemObject(tmpTerm.name, tmpTerm);
	endforeach;

	// default will be set later
	self.cmbLicenseType.text := null;

end;</source>
        <access>protected</access>
        <Parameter name="_client" type="DEV_LicenseClient"/>
    </JadeMethod>
    <JadeMethod name="initTblLicenseForEDI" id="ccf82591-b7e1-428a-9d3d-4763edb581e2">
        <updating/>
        <source>initTblLicenseForEDI(_licenseDtl : DEV_LicenseDtl) updating, protected;
// ---------------------------------------------------------------------------
// Created:     05 November 2003 by cnwrs2
//
// Purpose:     Should only be called from setCurrentLicenseDtls(..)
// ---------------------------------------------------------------------------
vars
	ediAgent	: CM_EDIFileTypeAgent;
	ediFileType	: CM_EDIFileType;
	canDoStr	: String;
	prevBundle,
	bundle,
	row,
	idx,
	color1,
	color2,
	theColor,
	tmpValue	: Integer;
	camDescType	: CM_CamProtocolDesc;
	hasUnknown,
	hasCustom,
	hasBase,
	hasEdifact,
	hasX12,
	hasSuzano	: Boolean; //23/12/2024	navkc1 JIRA Story MTN-33491
begin

	if _licenseDtl &lt;&gt; null and
	   _licenseDtl.type &lt;&gt; DEV_LicenseEntity.LicenseType_EDI then
		app.msgBox('Incorrect license type (' &amp; _licenseDtl.type.String &amp; ') for ' &amp; method.name, 'Error', 0);
		return;
	endif;
	
	ediAgent := self.myEDIFileTypeAgent;

	// ### JIRA 33502 20DEC2024 NAVAB1
	//self.chkShowAll.visible := false;
	self.chkShowAll.visible := true; //23/12/2024	navkc1 JIRA Story MTN-33491
	self.chkShowAll.value := false; //23/12/2024	navkc1 JIRA Story MTN-33491
	self.tblLicense.selectMode := Table.SelectMode_WholeRows;
	
	tblLicense.rows := tblLicense.fixedRows;
	//tblLicense.columns := 2;	//17 Jun 2020	NDL	TFS 49569
	self.tblLicense.columns := 3; //23/12/2024	navkc1 JIRA Story MTN-33491
	self.tblLicense.accessColumn(self.EDIBundleColumn).visible := false; //23/12/2024	navkc1 JIRA Story MTN-33491

	tblLicense.accessCell(1, 1).text := 'Module' &amp; Tab &amp; 'Value' &amp; Tab &amp; 'Bundle Type'; // ### JIRA 33543 12DEC2024 NAVAB1
	tblLicense.accessColumn(2).inputType := Table.InputType_CheckBox;
	tblLicense.accessColumn(self.EDIBundleColumn).inputType := Table.InputType_Default; //23/12/2024	navkc1 JIRA Story MTN-33491
	
	self.tblLicense.sortColumn[1] := self.EDIBundleColumn; //23/12/2024	navkc1 JIRA Story MTN-33491 - Do sorting for easier grouping
	self.tblLicense.sortColumn[2] := 1; //23/12/2024	navkc1 JIRA Story MTN-33491 - Do sorting for easier grouping
	
	foreach ediFileType in ediAgent.allEDIFileTypes do
		tmpValue := ediFileType.type;
		
		bundle := ediFileType.getEDIBundle(); //23/12/2024	navkc1 JIRA Story MTN-33491
		
		theColor := ediFileType@getColourForRow(bundle); 	//23/12/2024	navkc1 JIRA Story MTN-33491
		
		canDoStr := '0';	// so as unchecked
		if _licenseDtl &lt;&gt; null then
			if _licenseDtl.canDo(tmpValue) then
				canDoStr := '1';	// so as checked
				
				//23/12/2024	navkc1 JIRA Story MTN-33491
				if bundle = CM_EDIFileType.EDI_Bundle_BASE then
					hasBase := true;
				elseif bundle = CM_EDIFileType.EDI_Bundle_CUSTOM then
					hasCustom := true;
				elseif bundle = CM_EDIFileType.EDI_Bundle_EDIFACT then
					hasEdifact := true;
				elseif bundle = CM_EDIFileType.EDI_Bundle_SUZANO then
					hasSuzano := true;
				elseif bundle = CM_EDIFileType.EDI_Bundle_UNKNOWN then
					hasUnknown := true;
				elseif bundle = CM_EDIFileType.EDI_Bundle_X12 then
					hasX12 := true;
				endif;
			endif;
		endif;
		
		row := tblLicense.addItemObject(ediFileType, ediFileType.name &amp; Tab &amp; canDoStr &amp; Tab &amp; bundle.String);
		self.tblLicense.accessedRow.backColor := theColor;						//23/12/2024	navkc1 JIRA Story MTN-33491
		self.tblLicense.accessedRow.foreColor:= theColor.getInverseColour();	//23/12/2024	navkc1 JIRA Story MTN-33491
		self.tblLicense.accessedRow.visible := false;							//23/12/2024	navkc1 JIRA Story MTN-33491
	endforeach;

	prevBundle := null; //23/12/2024	navkc1 JIRA Story MTN-33491
	
	foreach camDescType in ediAgent.allCAMProtocolDescs do
		tmpValue := camDescType.type;
		
		bundle := camDescType.getEDIBundle(); //23/12/2024	navkc1 JIRA Story MTN-33491
		
		canDoStr := '0';	// so as unchecked
		if _licenseDtl &lt;&gt; null then
			if _licenseDtl.canDo(tmpValue) then
				canDoStr := '1';	// so as checked
				//23/12/2024	navkc1 JIRA Story MTN-33491
				if bundle = CM_EDIFileType.EDI_Bundle_BASE then
					hasBase := true;
				elseif bundle = CM_EDIFileType.EDI_Bundle_CUSTOM then
					hasCustom := true;
				elseif bundle = CM_EDIFileType.EDI_Bundle_EDIFACT then
					hasEdifact := true;
				elseif bundle = CM_EDIFileType.EDI_Bundle_SUZANO then
					hasSuzano := true;
				elseif bundle = CM_EDIFileType.EDI_Bundle_UNKNOWN then
					hasUnknown := true;
				elseif bundle = CM_EDIFileType.EDI_Bundle_X12 then
					hasX12 := true;
				endif;
			endif;
		endif;

		row := tblLicense.addItemObject(camDescType, camDescType.name &amp; Tab &amp; canDoStr &amp; Tab &amp; bundle.String);
		theColor := camDescType.getColourForRow(bundle); 	//23/12/2024	navkc1 JIRA Story MTN-33491
		self.tblLicense.accessedRow.backColor := theColor;						//23/12/2024	navkc1 JIRA Story MTN-33491
		self.tblLicense.accessedRow.foreColor := theColor.getInverseColour(); 	//23/12/2024	navkc1 JIRA Story MTN-33491
		self.tblLicense.accessedRow.visible := false;							//23/12/2024	navkc1 JIRA Story MTN-33491
	endforeach;
	
	
	/*===================================================================
	//23/12/2024	navkc1 JIRA Story MTN-33491 - Add the grouping header
	===================================================================*/
	
	prevBundle := -999;
	row := self.tblLicense.rows;
	foreach idx in self.tblLicense.fixedRows + 1 to row do
		canDoStr := '0';
		bundle := self.tblLicense.accessCell(idx, self.EDIBundleColumn).text.Integer;

		if bundle &lt;&gt; prevBundle then
			
			if bundle = CM_EDIFileType.EDI_Bundle_BASE and hasBase then
				canDoStr := '1';
			elseif bundle = CM_EDIFileType.EDI_Bundle_CUSTOM and hasCustom then
				canDoStr := '1';
			elseif bundle = CM_EDIFileType.EDI_Bundle_EDIFACT and hasEdifact then
				canDoStr := '1';
			elseif bundle = CM_EDIFileType.EDI_Bundle_SUZANO and hasSuzano then
				canDoStr := '1';
			elseif bundle = CM_EDIFileType.EDI_Bundle_UNKNOWN and hasUnknown then
				canDoStr := '1';
			elseif bundle = CM_EDIFileType.EDI_Bundle_X12 and hasX12 then
				canDoStr := '1';
			endif;
			
			self.tblLicense.addItemAt("- " &amp; CM_EDIFileType@getEDIBundleStr(bundle) &amp; Tab &amp; canDoStr &amp; Tab &amp; bundle.String, idx);
			theColor := CM_EDIFileType@getColourForRow(bundle);
			self.tblLicense.accessRow(idx);
			self.tblLicense.accessedRow.backColor := theColor;
			self.tblLicense.accessedRow.foreColor := theColor.getInverseColour();
			row += 1;
		endif;
		
		prevBundle := bundle;
		
	endforeach;
	
epilog
	
end;</source>
        <access>protected</access>
        <Parameter name="_licenseDtl" type="DEV_LicenseDtl"/>
    </JadeMethod>
    <JadeMethod name="initTblLicenseForEWS" id="1752404f-6731-4c32-90bd-42fd0c1fadbf">
        <updating/>
        <source>initTblLicenseForEWS(_licenseDtl : DEV_LicenseDtl) updating, protected;
/*
Purpose - 	
Who - NAVAB1
Date - 12DEC2024
ADO - JIRA 33543
*/


vars
	ewsAgent	: CM_EWSTypeAgent;
	ewsType	: CM_ExternalWebServiceType;
	canDoStr	: String;
	idx,
	color1,
	color2,
	theColor,
	tmpValue, tmpcolor	: Integer;
	epType	: CM_EWSEndpointType;
	date : Date;
	dateStr : String;
	tmpIgnore : Boolean;
begin

	if _licenseDtl &lt;&gt; null and
	   _licenseDtl.type &lt;&gt; DEV_LicenseEntity.LicenseType_EWS then
		app.msgBox('Incorrect license type (' &amp; _licenseDtl.type.String &amp; ') for ' &amp; method.name, 'Error', 0);
		return;
	endif;
	date := null;
	ewsAgent := self.myEWSTypeAgent;

	// ### JIRA 33502 20DEC2024 NAVAB1
	self.chkShowAll.visible := false; 
	self.tblLicense.selectMode := Table.SelectMode_WholeRows;
	
	tblLicense.rows := tblLicense.fixedRows;
	tblLicense.columns := 4;
	
	tblLicense.sortColumn[1] := 4;	// SortKey
	tblLicense.sortColumn[2] := 1;	// Module/Endpoint
	
	tblLicense.accessCell(1, 1).text := 'Module' &amp; Tab &amp; 'Expiry Date' &amp; Tab &amp; 'Value' &amp; Tab &amp; 'SortKey';
	tblLicense.accessColumn(4).visible := false;
	tblLicense.accessColumn(4).inputType := Table.InputType_TextNumeric;
	tblLicense.accessColumn(3).inputType := Table.InputType_CheckBox;
	tblLicense.accessColumn(3).visible := true; //23/12/2024	navkc1 JIRA Story MTN-33491
	tblLicense.accessColumn(2).inputType := Table.InputType_EditMask;
	tblLicense.accessColumn(2).editMask  := app.getDateEditMaskForShortFormat();
	tblLicense.accessColumn(2).enabled := true; //23/12/2024	navkc1 JIRA Story MTN-33491
	
	foreach ewsType in ewsAgent.allEWSTypesByType do
		tmpValue := ewsType.type;
		
		canDoStr := '0';	// so as unchecked
		date := null;
		
		if _licenseDtl &lt;&gt; null then
			if _licenseDtl.canDo(tmpValue) then
				canDoStr := '1';	// so as checked
			endif;
		endif;
		if canDoStr = '1' then
			self.getValueForSysTermPermission(_licenseDtl, tmpValue, tmpIgnore, date );
		endif;
		
		if tmpIgnore then
			continue;
		endif;
	
		dateStr := date.format("dd/MM/yyy");
		
		idx := tblLicense.addItemObject(ewsType, ewsType.name &amp; Tab &amp; dateStr &amp; Tab &amp; canDoStr &amp; Tab &amp; "1");
		
		// ### JIRA 33502 20DEC2024 NAVAB1
		tmpcolor := ewsType.getColourForRow();
		tblLicense.accessRow(idx).backColor := tmpcolor;
		tblLicense.accessRow(idx).foreColor := tmpcolor.getInverseColour();
	endforeach;

	self.tblLicense.addItem("--- API/EDBIC Endpoints ---" &amp; Tab /*name*/ &amp; Tab /*date*/ &amp; Tab /*enabled*/ &amp; "2");
	foreach epType in ewsAgent.allEWSEndpointTypeByType do
		tmpValue := epType.type;
		
		canDoStr := '0';	// so as unchecked
		date := null;

		if _licenseDtl &lt;&gt; null then
			if _licenseDtl.canDo(tmpValue) then
				canDoStr := '1';	// so as checked
			endif;
		endif;
		if canDoStr = '1' then
			self.getValueForSysTermPermission(_licenseDtl, tmpValue, tmpIgnore, date );
		endif;
		
		if tmpIgnore then
			continue;
		endif;

		dateStr := date.format("dd/MM/yyy");
		
		idx := tblLicense.addItemObject(epType, epType.name &amp; Tab &amp; dateStr &amp; Tab &amp; canDoStr &amp; Tab &amp; "2");
		
		// ### JIRA 33502 20DEC2024 NAVAB1
		tmpcolor := epType.getColourForRow();
		tblLicense.accessRow(idx).backColor := tmpcolor;
		tblLicense.accessRow(idx).foreColor := tmpcolor.getInverseColour();
	endforeach;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_licenseDtl" type="DEV_LicenseDtl"/>
    </JadeMethod>
    <JadeMethod name="initTblLicenseForSub" id="a1b688a6-7661-426a-8664-4fbe8b94dabd">
        <updating/>
        <source>initTblLicenseForSub(_licenseDtl : DEV_LicenseDtl) updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 June 2020	jlgndl1	Initial creation	TFS 49569

*/

vars

	permAgent	: CM_PermissionAgent;
	permObj		: CM_PermissionObject;
	canDoStr	: String;
	tmpIgnore	: Boolean;
	tmpValue, idx, tmpcolor	: Integer;
	dateStr		: String;
	date : Date;
	
begin

	if _licenseDtl &lt;&gt; null and
	   _licenseDtl.type &lt;&gt; DEV_LicenseEntity.LicenseType_Subscription then
		app.msgBox('Incorrect license type (' &amp; _licenseDtl.type.String &amp; ') for ' &amp; method.name, 'Error', 0);
		return;
	endif;
	
	permAgent := self.mySubscriptionPermAgent;

	// ### JIRA 33502 20DEC2024 NAVAB1
	self.chkShowAll.visible := false; 
	self.tblLicense.selectMode := Table.SelectMode_WholeRows;
	
	tblLicense.rows := tblLicense.fixedRows;
	tblLicense.columns := 3;	//17 Jun 2020	NDL	TFS 49569
	
	tblLicense.accessCell(1, 1).text := 'Module' &amp; Tab &amp; 'Expiry Date' &amp; Tab &amp; 'Value'; // ### JIRA 33543 12DEC2024 NAVAB1
	tblLicense.accessColumn(2).inputType := Table.InputType_EditMask;
	tblLicense.accessColumn(2).editMask  := app.getDateEditMaskForShortFormat();
	tblLicense.accessColumn(3).inputType := Table.InputType_CheckBox;
	tblLicense.accessColumn(3).visible := true; //23/12/2024	navkc1 JIRA Story MTN-33491
	tblLicense.accessColumn(2).enabled := true; //23/12/2024	navkc1 JIRA Story MTN-33491
	
	foreach permObj in permAgent.allPermissionsByName do
		tmpValue := permObj.constValue;
		canDoStr := '0';	// so as unchecked
		if self.getValueForSysTermPermission(_licenseDtl, tmpValue, tmpIgnore, date ) then
			canDoStr := '1';	// so as checked
		endif;
		
		if tmpIgnore then
			continue;
		endif;
		
		dateStr := date.format("dd/MM/yyy");
		//write method.qualifiedName &amp; " more code needed to show date for "&amp;permObj.description&amp;"!";

		idx:= tblLicense.addItemObject(permObj, permObj.description &amp; Tab &amp; dateStr &amp; Tab &amp; canDoStr);
		
		// ### JIRA 33502 20DEC2024 NAVAB1
		tmpcolor := permObj.getColourForRow();
		tblLicense.accessRow(idx).backColor := tmpcolor;
		tblLicense.accessRow(idx).foreColor := tmpcolor.getInverseColour();
		
	endforeach;
	
	

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_licenseDtl" type="DEV_LicenseDtl"/>
    </JadeMethod>
    <JadeMethod name="initTblLicenseForSysOrTermSimp" id="9bcafb82-984d-4ed6-abd0-85a8c17d5094">
        <updating/>
        <source>initTblLicenseForSysOrTermSimp(_licenseDtl : DEV_LicenseDtl) updating, protected;
/*
Purpose:			
Date				Who			Reason
APRIL 2017		CNWAB1		Initial creation
*/
vars
	permAgent	: CM_PermissionAgent;
	permObj		: CM_PermissionObject;
	canDoStr	: String;
	tmpIgnore	: Boolean;
	idx,
	color1,
	color2,
	theColor,
	tmpValue	: Integer;

begin
/* NOT USED // ### JIRA 33502 20DEC2024 NAVAB1
	if _licenseDtl &lt;&gt; null and
	   _licenseDtl.type &lt;&gt; DEV_LicenseEntity.LicenseType_System and
	   _licenseDtl.type &lt;&gt; DEV_LicenseEntity.LicenseType_Terminal then
		app.msgBox('Incorrect license type (' &amp; _licenseDtl.type.String &amp; ') for ' &amp; method.name, 'Error', 0);
		return;
	endif;

	permAgent := self.myPermissionAgent;

	tblLicense.rows := tblLicense.fixedRows;
	tblLicense.columns := 2;	//17 Jun 2020	NDL	TFS 49569

	tblLicense.accessCell(1, 1).text := 'License' &amp; Tab &amp; 'Value';
	tblLicense.accessColumn(2).inputType := Table.InputType_CheckBox;
	
	self.addLicenseToTable(Mod_BaseSystem,_licenseDtl, "1");
	self.addLicenseToTable(Mod_Cash,_licenseDtl,"0");
	self.addLicenseToTable(Mod_Invoicing,_licenseDtl,"0");
	self.addLicenseToTable(Mod_Harbour,_licenseDtl,"0");
	
	self.txtExpiryDate.setDate( "31 Dec 3000".Date );
*/
end;</source>
        <access>protected</access>
        <Parameter name="_licenseDtl" type="DEV_LicenseDtl"/>
    </JadeMethod>
    <JadeMethod name="initTblLicenseForSysOrTerminal" id="37728406-6e7d-436b-8490-66a4c4e06047">
        <updating/>
        <source>initTblLicenseForSysOrTerminal(_licenseDtl : DEV_LicenseDtl) updating, protected;
// ---------------------------------------------------------------------------
// Created:     05 November 2003 by cnwrs2
//
// Purpose:     Should only be called from setCurrentLicenseDtls(..)
// ---------------------------------------------------------------------------
vars
	permAgent	: CM_PermissionAgent;
	permObj		: CM_PermissionObject;
	currentClient : DEV_LicenseClient;
	ediLicenseDtl : DEV_LicenseDtl;
	canDoStr	: String;
	tmpIgnore	: Boolean;
	bundle,
	idx,
	color1,
	color2,
	theColor,
	tmpValue, tmpcolor	: Integer;
	dummyDate : Date;
	ediAgent	: CM_EDIFileTypeAgent;
	ediFileType	: CM_EDIFileType;
	camDescType		: CM_CamProtocolDesc;

begin

	if _licenseDtl &lt;&gt; null and
	   _licenseDtl.type &lt;&gt; DEV_LicenseEntity.LicenseType_System and
	   _licenseDtl.type &lt;&gt; DEV_LicenseEntity.LicenseType_Terminal then
		app.msgBox('Incorrect license type (' &amp; _licenseDtl.type.String &amp; ') for ' &amp; method.name, 'Error', 0);
		return;
	endif;

	permAgent := self.myPermissionAgent;

	// ### JIRA 33502 20DEC2024 NAVAB1
	self.chkShowAll.visible := true; 
	self.tblLicense.selectMode := Table.SelectMode_WholeRows;
	
	tblLicense.rows := tblLicense.fixedRows;
	tblLicense.columns := 2;	//17 Jun 2020	NDL	TFS 49569

	tblLicense.accessCell(1, 1).text := 'Module' &amp; Tab &amp; 'Value';// ### JIRA 33543 12DEC2024 NAVAB1
	tblLicense.accessColumn(2).inputType := Table.InputType_CheckBox;
	tblLicense.accessColumn(2).enabled := true; //23/12/2024	navkc1 JIRA Story MTN-33491
	foreach permObj in permAgent.allPermissionsByName do
	
		// ### JIRA 33502 20DEC2024 NAVAB1
		if not self.chkShowAll.value
		and not permObj.showInLicenseApp(self.myCurrentClient.name) then
			continue;
		elseif permObj.showNever(self.chkRealClient.value) then // 20JAN2025	navab1	JIRA 33502 // ### JIRA 33843 23JAN2025 NAVAB1 changed to check real client
			continue;
		endif;

		
		tmpValue := permObj.constValue;
		canDoStr := '0';	// so as unchecked
		if self.getValueForSysTermPermission(_licenseDtl, tmpValue, tmpIgnore, dummyDate) then
			canDoStr := '1';	// so as checked
		endif;
		
		if tmpIgnore then
			continue;
		endif;
		
//		write  tmpValue.String &amp; " - " &amp;   permObj.description &amp; " " &amp; permObj.constName;
		tmpcolor := permObj.getColourForRow();
		
		if self.chkRealClient.value then  // ### JIRA 33843 23JAN2025 NAVAB1 
			// ### JIRA 33502 20DEC2024 NAVAB1
			if tmpValue = Mod_Logs then
				if canDoStr= '0' then
					if not self.chkShowAll.value then // ### JIRA 33843 23JAN2025 NAVAB1 
						continue;
					endif;
				endif;
			endif;
			// ### JIRA 33843 23JAN2025 NAVAB1 
			if tmpValue = Mod_DutyDoc then
				if canDoStr= '0' then
					if not self.chkShowAll.value then 
						continue;
					endif;
				endif;
			endif;
		endif;
		
		idx := tblLicense.addItemObject(permObj, permObj.description &amp; Tab &amp; canDoStr);
		tblLicense.accessRow(idx).backColor := tmpcolor;
		tblLicense.accessRow(idx).foreColor := tmpcolor.getInverseColour();
	endforeach;
	
	/* ==============================================================
	//23/12/2024	navkc1 JIRA Story MTN-33491 - For Base EDI Bundle	
	==============================================================*/
	ediAgent := self.myEDIFileTypeAgent;
	currentClient := self.myCurrentClient;
	ediLicenseDtl := currentClient.myEDILicense;
	canDoStr := '0';
	
	// Check whether any permissions in the Base EDI Bundle is enabled
	foreach ediFileType in ediAgent.allEDIFileTypes do
		bundle := ediFileType.getEDIBundle();
		
		// Only check for Base Bundle
		if bundle &lt;&gt; CM_EDIFileType.EDI_Bundle_BASE then
			continue;
		endif;
		
		tmpValue := ediFileType.type;
		
		if ediLicenseDtl &lt;&gt; null then
			if ediLicenseDtl.canDo(tmpValue) then
				canDoStr := '1';
				break;
			endif;
		endif;
	endforeach;
	
	// Check CAMs if none found
	if canDoStr = '0' then
		foreach camDescType in ediAgent.allCAMProtocolDescs do
			bundle := camDescType.getEDIBundle();
			
			// Only check for Base Bundle
			if bundle &lt;&gt; CM_EDIFileType.EDI_Bundle_BASE then
				continue;
			endif;
			
			tmpValue := camDescType.type;
			
			if ediLicenseDtl &lt;&gt; null then
				if ediLicenseDtl.canDo(tmpValue) then
					canDoStr := '1';
					break;
				endif;
			endif;
		endforeach;
	endif;
	
	//23/12/2024	navkc1 JIRA Story MTN-33491 - Add empty row for Base EDI Bundle	
	idx := self.tblLicense.addItemObject(null, "EDI " &amp; CM_EDIFileType@getEDIBundleStr(CM_EDIFileType.EDI_Bundle_BASE) &amp; Tab &amp; canDoStr);
	self.tblLicense.accessRow(idx);
	self.tblLicense.accessedRow.backColor := PaleGreen;
	self.tblLicense.accessedRow.foreColor := PaleGreen.getInverseColour();
end;</source>
        <access>protected</access>
        <Parameter name="_licenseDtl" type="DEV_LicenseDtl"/>
    </JadeMethod>
    <JadeMethod name="isAutoAdded" id="efae3252-bf46-46e8-8f16-4f55717f0691">
        <source>isAutoAdded(_module : Integer) : String;
/*
Purpose: in the Licensed UI there is a list of modules, however in MTN there are more modules, some are auto turned on becasue the client has the BASE module	in the system license
Logs is only turned on for C3
Duty Docs is only turned on for Ajman

Date		Who		Reason
15 January 2026	navab1	JIRA 36920
*/

vars

begin

		if _module = Mod_YardPlanning
		or _module = Mod_CargoGroup
		or _module = Mod_CargoShip
		or _module = Mod_CargoHandling
		or _module = Mod_Weighing
		or _module = Mod_Webservice then
			return "(Auto Added) ";
		endif;

		return "";
epilog

end;</source>
        <Parameter name="_module" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
