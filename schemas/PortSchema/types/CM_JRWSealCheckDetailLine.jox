    <JadeMethod name="getDateLocalTZ" id="327f6f53-3613-43bd-8ce8-55945d41bcbb">
        <source>getDateLocalTZ(): TimeStamp;
/*

Purpose:			Return the local timezone version of the receiver's dateTime (for JRW)

Parameters:			None

Return Value:		

Date		Who		Reason
03 Jun 2016	cnwmp6	TFS 488 - Multi Timezone Support

*/
vars

begin
	return self.systemToLocalTime(self.date);
epilog

end;</source>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="getDateString" id="79cd64da-6745-49b9-8610-7bee61103356">
        <source>getDateString():String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
01 October 2010	cnwndl1	Initial creation	Par 25608

*/

vars

	str : String;
	
begin

	if not date.Date.isValid then
		str :=  null;
	else
		str := date.asStringJMT();
	endif;
	
	return str;
	
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDateStringLocalTZ" id="da8fa2be-d0c8-4771-9afa-406d2298d47f">
        <source>getDateStringLocalTZ(): String;
/*

Purpose:			Return the local timezone version of the receiver's dateTime (for JRW)

Parameters:			None

Return Value:		

Date		Who		Reason
03 Jun 2016	cnwmp6	TFS 488 - Multi Timezone Support

*/
vars

	str : String;
	
begin

	if not date.Date.isValid then
		str :=  null;
	else
		str := self.systemToLocalTime(date).asStringJMT();
	endif;
	
	return str;
	
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="setDetails" id="8f1d542a-1b02-4f7e-8667-4acb49cbcd81">
        <updating/>
        <source>setDetails( _index : Integer; _sealCheckDetail : CM_SealCheckDetail ) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
29 September 2010	cnwndl1	Initial creation	Par 25608

*/

vars
	sealCheck : CM_SealCheck;
begin

	self.mySealCheckDetail := _sealCheckDetail;
	self.index := _index;
	
	sealCheck := _sealCheckDetail.mySealCheck;
	
	primarySortKey := sealCheck.id;
	
	if _index = 1 then	//print these values on first line only.
		self.cargoId := sealCheck.id;
		self.isoType := sealCheck.getIsoTypeString;
		self.imex := sealCheck.getImexString;
		self.operator := sealCheck.getOperatorString;
		self.booking := sealCheck.getBookingString;
	else	 // print these values empty on subsequent lines 
		self.cargoId := null;
		self.isoType := null;
		self.imex := null;
		self.operator := null;
		self.booking := null;
	endif;
	
	self.sealType := _sealCheckDetail.sealType;
	self.notified := _sealCheckDetail.sealBefore;
	
	self.match := ( not _sealCheckDetail.isUnMatched() ).getYesNo();
	
	self.checkType := _sealCheckDetail.getSealCheckTypeString();
	
	if _sealCheckDetail.sealCheckType = SEAL_CHECK_VIEW then
		if _sealCheckDetail.viewed = _sealCheckDetail.Seal_Not_Viewed then
			self.actual := app.getErrorString(Missing);
		elseif _sealCheckDetail.viewed = _sealCheckDetail.Seal_Viewed then
			self.actual := app.getErrorString(Present);
		else
			self.actual := null;
		endif;
	elseif _sealCheckDetail.sealCheckType = SEAL_CHECK_FULL or _sealCheckDetail.sealCheckType = SEAL_CHECK_STRICT then
		self.actual := _sealCheckDetail.sealAfter;
	else
		self.actual := null;
	endif;
	
	
	self.date := _sealCheckDetail.createdTime;
	self.user := sealCheck.userId;

epilog

end;</source>
        <Parameter name="_index" type="Integer"/>
        <Parameter name="_sealCheckDetail" type="CM_SealCheckDetail"/>
    </JadeMethod>
    <JadeMethod name="setDetailsFromSealTi" id="4939407f-901f-470b-a848-d900f5bdb50f">
        <updating/>
        <source>setDetailsFromSealTi( _ti : CM_TrackedItem; _index : Integer; sealTi : CM_SealTI ) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
01 October 2010	cnwndl1	Initial creation	Par 25608

*/

vars
	
begin

	self.mySealCheckDetail := null;
	self.index := _index;
	
	primarySortKey := _ti.id;
	
	if _index = 1 then	//print these values on first line only.
		self.cargoId := _ti.id;
		self.isoType := _ti.getISOType;
		self.imex := _ti.getImExStatusString;
		self.operator := _ti.operatorCode;
		self.booking := _ti.bookingReference;
	else	 // print these values empty on subsequent lines 
		self.cargoId := null;
		self.isoType := null;
		self.imex := null;
		self.operator := null;
		self.booking := null;
	endif;
	
	if sealTi &lt;&gt; null then
		self.sealType := sealTi.sealType;
		self.notified := sealTi.getSealValueAsString;
	endif;
	
	self.match := ( self.notified = null ).getYesNo();
	
	self.checkType := app.getErrorString(Not_checked);
	self.actual := null;

	self.date := null;
	self.date.setTime(null);
	self.user := null;

epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_index" type="Integer"/>
        <Parameter name="sealTi" type="CM_SealTI"/>
    </JadeMethod>
</Class>
