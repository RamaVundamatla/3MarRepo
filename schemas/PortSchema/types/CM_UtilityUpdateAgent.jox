    <JadeMethod name="utlUpdateAuditTALocComments" id="e93caeb4-8047-4f56-913a-0323423471dd">
        <source>utlUpdateAuditTALocComments(_coll :Collection; _value :String; _passport :CM_Passport);
// ---------------------------------------------------------------------------
// Created:     07 March 2011 by cnwcs5
// Purpose:     
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	any 	:Any;
	audit	:CM_AuditTALocations;
begin
	self.initialiseActivity();

	app.setContinueCMExceptions(true);
		
	foreach any in _coll do 
		if not any.isKindOf (CM_AuditTALocations) then
			app.raiseUnexpectedProgramError (self.class.name, method.name, 
								"Invalid Type - Expecting CM_AuditTALocations");
		endif;
		
		audit := any.CM_AuditTALocations;
		
		audit.setRemarks (_value);
	endforeach;
epilog

end;</source>
        <Parameter name="_coll" type="Collection"/>
        <Parameter name="_value" type="String"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
