    <DbClassMap file="basehtml"/>
    <PrimAttribute name="isCompact" id="fcc1c08e-cd02-4740-a342-c118a56600b7">
        <embedded/>
        <type name="Boolean"/>
    </PrimAttribute>
    <JadeMethod name="buildTagBody" id="ff3afb37-2ad4-473a-b1c4-528937a60855">
        <source>buildTagBody(): String protected;
// --------------------------------------------------------------------------------
// Created:		06 December 2001 by cnwdad1
//
// Purpose:		Refer to the CnEcHtmlTagObject implementation.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	htmlString	: String;
	
begin
	if self.listType &lt;&gt; null then
		htmlString	:=	' TYPE="' &amp; self.listType.String &amp; '"';
	endif;
	
	if self.isCompact then
		htmlString	:=	htmlString &amp; ' COMPACT';
	endif;
	
	htmlString	:=	htmlString &amp; '&gt;' &amp; CrLf &amp; self.buildListEntries() &amp; inheritMethod();
	
	return htmlString;
end;</source>
        <access>protected</access>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getHtml" id="eaeaf237-3c8f-4e1d-8954-3fb870a33848">
        <source>getHtml(): String;
// --------------------------------------------------------------------------------
// Created:		06 December 2001 by cnwdad1
//
// Purpose:		Refer to the CnEcHtmlTagObject implementation.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return '&lt;UL' &amp; self.buildTagBody() &amp; '&lt;/UL&gt;';
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="isValidType" id="6d71f473-5af9-40f8-8780-8c42390a83f4">
        <source>isValidType(pType:String):Boolean protected;
// --------------------------------------------------------------------------------
// Created:		06 December 2001 by cnwdad1
//
// Purpose:		Validates the receiver's list type setting.
//
// Parameters:	pType - The receiver's list type setting.
//
// Returns:		True if the list type setting is valid, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if pType = self.TYPE_DEFAULT
	or pType = self.TYPE_CIRCLE
	or pType = self.TYPE_DISC
	or pType = self.TYPE_SQUARE
	then
		return true;
	else
		CnEcBaseHtmlException.raise_(CNEC_X_22003, '"' &amp; pType &amp; '" is not a valid Unordered List tag type');
	endif;
	
	return false;
end;</source>
        <access>protected</access>
        <Parameter name="pType" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
