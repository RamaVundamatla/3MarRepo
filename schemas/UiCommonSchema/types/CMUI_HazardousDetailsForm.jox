    <JadeMethod name="setMyMasterItems" id="6bb0cbea-dc1a-463e-9a0a-5041c43f2af6">
        <updating/>
        <source>setMyMasterItems(	_pxyTrackedItem : CM_TrackedItem; 
					_pxyBookingItem : CM_BookingRefItem; 
					_pxyBooking : CM_BookingRef;
					_hazards : ObjectArray	) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 14/11/2016	cnwdap1		Initial creation TFS 2842 STWR Hazardous Details Enhancements
//
vars
	obj : Object;

begin
	self.myPxyTrackedItem 	:= _pxyTrackedItem;
	self.myPxyBookingItem 	:= _pxyBookingItem;
	self.myPxyBooking 		:= _pxyBooking;
	if _hazards &lt;&gt; null then
		foreach obj in _hazards do
			self.allHazardsToShow.add(obj);
		endforeach;
	endif;
epilog

