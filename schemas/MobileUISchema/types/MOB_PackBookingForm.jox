    <JadeMethod name="clearContainerDetails" id="6972efd2-54ed-47f3-b543-66db6e7d515d">
        <updating/>
        <source>clearContainerDetails() updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 01/04/2015	cnwdap1		Initial creation PAR #35895 CCMS PNL 2461
//
vars

begin
	self.txt_ContainerNbr.text 		:= null;
	self.cmb_Consignor.listIndex	:= -1;
	
	if self.myBooking &lt;&gt; null then
		self.lbl_PackDetail.caption := self.myBooking.numTIs.String &amp; " of " &amp; self.myBooking.getTotalQuantity.String;
	endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="clearDetails" id="6aaa7a0f-ea87-4b13-a348-43eed79e50b9">
        <source>clearDetails();
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 24/03/2015	cnwdap1		Initial creation PAR #35895 CMS PNL 2461
//
vars

begin
	self.lbl_OpDetail.caption 		:= null;
	self.lbl_ISODetail.caption 		:= null;
	self.lbl_GradeDetail.caption 	:= null;
	self.lbl_PackDetail.caption 	:= null;
	self.lbl_VoyageDetail.caption 	:= null;
	self.lbl_ArriveDetail.caption 	:= null;
	self.lbl_DestDetail.caption 	:= null;
	
	self.txt_ContainerNbr.text 		:= null;
	self.cmb_Consignor.listIndex	:= -1;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doBookingCheck" id="b8eaabd7-764a-4822-a7f3-d911d34ff44f">
        <updating/>
        <source>doBookingCheck() updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 23/03/2015	cnwdap1		Initial creation PAR #35985 CCMS PNL 2461
// 09/07/2015	cnwdap1		PAR #36484 Release should be a Road Release, not a Packing Release
// 30/09/2015	cnwdap1		PAR #36988 Release just needs to have the same number as the booking,
//							doesn't need to be associated with the booking in amy way
//
vars
	bookingRef		: String;
	booking 		: CM_BookingRef;
	release 		: CM_BulkRelease;
	//packingRelease: CM_BulkRelease;			// PAR #36484
	roadRelease		: CM_BulkRelease;			// PAR #36484
	today			: TimeStamp;				// PAR #36988

begin
	// find  a booking to match the entered booking number
	self.clearDetails;
	bookingRef := self.txt_Booking.text.trimBlanks;
	booking := self.myTerminal.allBookingRefsByRef[bookingRef];
	if booking = null then
		app.msgBox(app.getErrorString1(Active_booking_not_found, bookingRef), app.getErrorString(Error), MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
		return;
	endif;
	// PAR #36988 No longer required
	//if booking.allReleaseRequests.isEmpty then
	//	app.msgBox(app.getErrorString1(Booking_no_release_requests, bookingRef), app.getErrorString(Error), MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
	//	return;
	//endif;
	//foreach release in booking.allReleaseRequests do
	//	//if release.isPackingType then			// PAR #36484
	//	//	packingRelease := release;			// PAR #36484
	//	if release.isRoadType then				// PAR #36484
	//		roadRelease := release;				// PAR #36484
	//		break;
	//	endif;
	//endforeach;
	today := app.actualTimeServer;																			// PAR #36988
	roadRelease := self.myTerminal.allBulkReleasesByCodeDate.getAtKeyGeq(booking.bookingReference, today);	// PAR #36988
	//if roadRelease = null then					// PAR #36484											// PAR #36988
	if roadRelease = null 																					// PAR #36988
	or roadRelease.code &lt;&gt; booking.bookingReference 														// PAR #36988
	or roadRelease.status &lt;&gt; BR_ACTIVE 																		// PAR #36988
	or not roadRelease.isRoadType then																		// PAR #36988
		app.msgBox(app.getErrorString1(Booking_no_release_requests, self.txt_Booking.text), app.getErrorString(Error), MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
		return;
	endif;
	
	// we have a release - display the details
	self.lbl_OpDetail.caption := booking.operatorCode;
	//self.lbl_ISODetail.caption := packingRelease.getISOCode;					// PAR #36484
	//self.lbl_GradeDetail.caption := packingRelease.getAvailGradesForReport;	// PAR #36484
	self.lbl_ISODetail.caption := roadRelease.getISOCode;						// PAR #36484
	self.lbl_GradeDetail.caption := roadRelease.getAvailGradesForReport;		// PAR #36484
	self.lbl_VoyageDetail.caption := booking.voyageCode;
	self.lbl_ArriveDetail.caption := booking.myVoyage.arrivedDT.asStringJMT();
	self.lbl_DestDetail.caption := booking.destinationPort;
	
	self.lbl_PackDetail.caption := booking.numTIs.String &amp; " of " &amp; booking.getTotalQuantity.String;
		
	self.myBooking := booking;
	//self.myBulkRelease := release;			// PAR #36484
	self.myBulkRelease := roadRelease;			// PAR #36484
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doPackCargoClick" id="5626353b-7ac1-4b85-a57f-54a727fcc5ce">
        <updating/>
        <source>doPackCargoClick() updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 24/03/2015	cnwdap1		Initial creation PAR #35895 CCMS PNL 2461
// 25/05/2015	cnwdap1		PAR #36231 Ensure we have selected a consignor bevore accessing it
// 01/10/2015	cnwdap1		PAR #36988 New booking item parameter for trx method
//
vars
	containerId		: String;
	container 		: CM_TrackedItem;
	bookingItem		: CM_BookingRefItem;
	extraMessage	: String;
	subTerminal		: CM_SubTerminal;
	isoType			: String;
	isoGroup		: String;
	pxyTI			: CM_TrackedItem;
	warehouse		: CM_SubTerminal;
	result 			: Integer;
	pxyRelease		: CM_BulkRelease;
	form			: MOB_PackBookingDetailForm;
	consignor		: CM_ConsigneeConsignor;
	reason			: String; //05/04/2024	navkc1 Bug 63509

begin
	containerId := self.txt_ContainerNbr.text.trimBlanks;
	if containerId = null then 
		app.msgBox(app.getErrorString(NO_Container_selected), app.getErrorString(Error), MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
		return;
	endif;
	container := self.myTerminal.allOnsiteTIsByCargoTypeId[TI_CargoType_Container, containerId];
	if container = null then
		app.msgBox(app.getErrorString1(ERR_TI_NOT_ONSITE, containerId), app.getErrorString(Error), MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
		return;
	endif;
	if self.myBooking = null then						// PAR #36231
		self.doBookingCheck();							// PAR #36231
	endif;												// PAR #36231
	bookingItem := self.findBookingItemForTI(container.getISOTypeObject, container.myOperator, reason);
	if bookingItem = null then
		//app.msgBox(app.getErrorString2(Error_No_Booking_Ref_Item, self.myBooking.bookingReference, container.id), app.getErrorString(Error), MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
		app.msgBox(app.getErrorString3(Error_No_Booking_Ref_Item, self.myBooking.bookingReference, container.id, reason), app.getErrorString(Error), MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
		return;
	endif;
	
	// update container to attach it to release and booking, and change subterminal to warehouse subterminal
	pxyTI := app.createUpdateProxy(container).CM_TrackedItem;
	if self.cmb_Consignor.listIndex &gt; 0 then						// PAR #36231
		consignor := self.cmb_Consignor.itemObject[self.cmb_Consignor.listIndex].CM_ConsigneeConsignor;
	endif;															// PAR #36231
	if consignor &lt;&gt; null then
		pxyTI.setConsignorByString(consignor.code);
	endif;
	if self.myTerminal.isSubTerminalsOn then
		warehouse := self.myTerminal.getConfig(MySubTerminalForTargetBulk).CM_SubTerminal;
		pxyTI.setSubTerminal(warehouse,null);
	endif;
	pxyTI.setBookingRefAndItem(self.myBooking, bookingItem, true, app.myPassport);
	pxyRelease := app.createUpdateProxy(self.myBulkRelease).CM_BulkRelease;
	
	while true do
		//app.myTrxUA.trxUpdateTIPriorWhousePacking(pxyTI, pxyRelease, app.myPassport);				// PAR #36988
		app.myTrxUA.trxUpdateTIPriorWhousePacking(pxyTI, pxyRelease, bookingItem, app.myPassport);	// PAR #36988
		
		if app.myPassport.trxCompletedOK then
			break;
		else
			//If there were warnings, give the user a chance to see them. If there are no errors they may decide to acknowledge
			//them and update anyway.
			result := app.showErrorWarningDialog('Tracked Item Update', app.myPassport, ErrWarnMode_Add + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   result = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		break;
	endwhile;
	
	// show pack detail screen
	if app.myPassport.trxCompletedOK then
		form := app.myMobileGUIAgent.findOrShowForm(MOB_PackBookingDetailForm, container, false).MOB_PackBookingDetailForm;
		form.myBooking := self.myBooking;
		form.lbl_Booking.caption := self.myBooking.bookingReference;
		form.myCallingForm := self;
	endif;
epilog
	delete pxyTI;
	delete pxyRelease;
end;</source>
    </JadeMethod>
    <JadeMethod name="findBookingItemForTI" id="fedb76a9-cd07-4ae2-a733-4166cc55ae0a">
        <source>findBookingItemForTI(_isoType : CM_ISOType; _operator : CM_Operator; _reason : String io) : CM_BookingRefItem;
//
// Purpose:			Code modelled on CM_BookingRef::getmatchingItemForTI, but ignoring commodity check
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 01/04/2015	cnwdap1		Initial creation PAR #35895 CCMS PNL 2461
// 02/06/2015	cnwdap1		PAR #36231 Make sure we have a booking here
//
vars
	brItem		: CM_BookingRefItem;
	isoGroup	: CM_ISOTypeGroup;
	checkedAll	: Boolean;
	
begin
	if self.myBooking = null then
		return null;
	endif;
	if self.myBooking.myOperator &lt;&gt; _operator then
		return null;
	endif;
	
	while true do
		foreach brItem in self.myBooking.allBookingRefItems do
			if _isoType &lt;&gt; null then
				if  brItem.myISOType &lt;&gt; null and not checkedAll then
					if brItem.myISOType &lt;&gt; _isoType then
						//05/04/2024	navkc1 Bug 63509
						if _reason.pos(app.getErrorString(ISOTypes), 1) = null then
							if _reason &lt;&gt; null then
								_reason &amp;= ", " &amp; app.getErrorString(ISOTypes);
							else
								_reason &amp;= app.getErrorString(ISOTypes);
							endif;
						endif;
						continue; // Supplied ISO type doesn't match with the ISO type of the booking item
					endif;
				endif;
				if brItem.isoTypeGroup &lt;&gt; null then
					isoGroup := _isoType.myISOTypeGroup;
					if isoGroup = null or isoGroup.code &lt;&gt; brItem.isoTypeGroup then
						//05/04/2024	navkc1 Bug 63509
						if _reason.pos(app.getErrorString(ISOGroups), 1) = null then
							if _reason &lt;&gt; null then
								_reason &amp;= ", " &amp; app.getErrorString(ISOGroups);
							else
								_reason &amp;= app.getErrorString(ISOGroups);
							endif;
						endif;
						continue; // Supplied ISO type doesn't match with the ISO group of the booking item
					endif;
				endif;
			endif;
			
			// Falls through if there wasn't an ISO type supplied
			// Falls through if there isn't an ISO type or ISO Group on the booking item			
			if  brItem.myCargoType = app.myRoot.allCargoTypesById[TI_CargoType_Container] then 
				if checkedAll then
					return brItem;
				endif;
				if not brItem.isCompleteWithPrenotes then
					return brItem;
				endif;
			endif;
		endforeach;

		if not checkedAll then
			checkedAll := true;
		else
			break;
		endif;
	endwhile;
	
	return null;
epilog

end;</source>
        <Parameter name="_isoType" type="CM_ISOType"/>
        <Parameter name="_operator" type="CM_Operator"/>
        <Parameter name="_reason" type="String" usage="io"/>
        <ReturnType type="CM_BookingRefItem"/>
    </JadeMethod>
    <JadeMethod name="setupForm" id="406eeae0-a350-4077-b853-014be32894d4">
        <updating/>
        <source>setupForm() updating, protected;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 23/03/2015	cnwdap1		Initial creation PAR #35895 CCMS PNL 3461
//
vars
	consignor	: CM_ConsigneeConsignor;
	idx			: Integer;

begin
	inheritMethod();
	
	// load consignors
	foreach consignor in app.myRoot.allConsigneeConsignors do
		if consignor.isNotAvailableForEntry or not consignor.isConsignor then
			continue;
		endif;
		if not consignor.isUsedForPacking then
			continue;
		endif;
		idx := self.cmb_Consignor.addItem(consignor.code &amp; Tab &amp; consignor.description);
		self.cmb_Consignor.itemObject[idx] := consignor;
	endforeach;
	self.txt_Booking.setFocus();

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="translateForm" id="1f164712-25d0-43aa-b8ca-16b901369195">
        <updating/>
        <source>translateForm(locale : CM_Locale) updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 24 March 2015.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	
begin
	// Determine the locale for translations.
	inheritMethod(locale);
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0020349, locale);
	btn_Cancel.translateCaption(Xlat_0020350, locale);
	btn_Check.translateCaption(Xlat_0020351, locale);
	btn_PackOK.translateCaption(Xlat_0020352, locale);
	lbl_Booking.translateCaption(Xlat_0020353, locale);
	lbl_Consignor.translateCaption(Xlat_0020354, locale);
	lbl_ContainerNbr.translateCaption(Xlat_0020355, locale);
	lbl_Destination.translateCaption(Xlat_0020356, locale);
	lbl_Grade.translateCaption(Xlat_0020357, locale);
	lbl_ISOType.translateCaption(Xlat_0020358, locale);
	lbl_Operator.translateCaption(Xlat_0020359, locale);
	lbl_PackStatus.translateCaption(Xlat_0020360, locale);
	lbl_Voyage.translateCaption(Xlat_0020361, locale);
	lbl_VoyageArrive.translateCaption(Xlat_0020362, locale);
end;</source>
        <Parameter name="locale" type="CM_Locale"/>
    </JadeMethod>
</GUIClass>
