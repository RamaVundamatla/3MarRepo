    <JadeMethod name="trxUpdateLicense" id="4285e1e9-24c2-469b-b4fd-0be153cfc1eb">
        <updating/>
        <source>trxUpdateLicense(_cmObj : CM_Object input; 
		_licenseName,
		_licenseKey,
		_productCode : String;
		_expectedEdition : Integer; 
		_passport : CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:     11 November 2002 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	licObj		: Object;
	prodCode	: String;
	cmifMonitor	: CMIF_Monitor;
	tmpRoot		: CM_Root;
	tmpTerm		: CM_Terminal;
	
begin
	self.initialiseActivityWithPassport(_passport, method);
	
	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);
	
	app.setContinueCMExceptions(false);
	self.raiseExceptionIfNull(_cmObj, 'License Object');
	
	if CM_Root.hasInstance(_cmObj) then
		tmpRoot := _cmObj.CM_Root;
	elseif CM_Terminal.hasInstance(_cmObj) then
		tmpTerm := _cmObj.CM_Terminal;
	else
		// license obj only valid for cm_root or cm_terminal class
		app.raiseCMException(ErrInvalidLicenseClass, null, null);
		return;
	endif;
	
	if _passport.hasErrors() then
		return;
	endif;
	
	if _licenseName = null then
	//	app.raiseCMException1(REQUIRED_FIELD, app.getErrorString(License_Name), 'licenseName', null);
		app.raiseCMException1(Input_required_field_Required, app.getErrorString(License_Name), 'licenseName', null); // cnwdb2	PAR 35364


		return;
	endif;
	
	if _licenseKey = null then
	//	app.raiseCMException1(REQUIRED_FIELD, app.getErrorString(License_Key), '_licenseKey', null);
		app.raiseCMException1(Input_required_field_Required, app.getErrorString(License_Key), '_licenseKey', null); // cnwdb2	PAR 35364
		return;
	endif;
	
	if _productCode = null
	or ( _productCode &lt;&gt; ProductCode_JMT
	and _productCode &lt;&gt; ProductCode_Subs	//18 Jun 2020	NDL	TFS 49569
	and _productCode &lt;&gt; ProductCode_JMT_EDI 
	and _productCode &lt;&gt; ProductCode_EWS) // ### JIRA 33541 16DEC2024 NAVAB1
	then
		app.raiseCMException1(ErrInvalidLicenseProductCode, _productCode, '_productCode', null);
		return;
	endif;	
	
	if _productCode = ProductCode_JMT_EDI then
		self.raiseExceptionIfNull(tmpRoot, 'CM_Root');
	endif;		
	
	if (not self.checkValidationWithPassport(_passport)) then
		return;
	endif;
	
	cmifMonitor := _passport.myCMIFMonitor;
	
	beginTransaction;
	
	exclusiveLock(_cmObj);
	if _cmObj.edition &lt;&gt; _expectedEdition then
		app.raiseCMException1(ObjectUpdatedByAnotherUserSave, 'License Object', null, null);
		return;
	endif;
	
	if _passport.hasErrors() then
		return;
	endif;
	
	if _cmObj &lt;&gt; app.myRoot then
		// lock root to ensure single thread of validation
		exclusiveLock(app.myRoot);
	endif;
	
	app.myRoot.validateLicenseName(_licenseName, _productCode, _cmObj);
	
	if _passport.hasErrors() then
		return;
	endif;
	
	app.myUtilityUA.myUpdateAuditAgent.audUpdateGeneric(_cmObj, true);
	if _passport.hasErrors then
		return;
	endif;
	
	// Deliberately done this way so as to avoid any references to
	// the security module
	licObj := app.myCheckerObject;
	if licObj = null then
		app.raiseCMException(ErrLicenseObjectNotFound, null, null);
		return;
	endif;
	
	// We will handle the transactions
	licObj.sendMsgWithParams('setTransactionStateFlag', false);
	if  _productCode = ProductCode_Subs	//19 Jun 2020	NDL	TFS 49569
	or  _productCode = ProductCode_EWS	then	// ### JIRA 33545 16DEC2024 NAVAB1
		prodCode := licObj.sendMsgWithParams('enterSubsLicenseKey', _licenseName, _licenseKey).String;
	else
		prodCode := licObj.sendMsgWithParams('enterLicenseKey', _licenseName, _licenseKey).String;
	endif;
	
	if prodCode &lt;&gt; _productCode then
		// invalid license key
		app.raiseCMException(ErrInvalidLicenseKey, null, null);
		return;
	endif;
	
	if tmpRoot &lt;&gt; null then
		tmpRoot.setLicenseName(_licenseName, _productCode);
	elseif tmpTerm &lt;&gt; null then
		tmpTerm.setLicenseName(_licenseName);
	else
		app.raiseCMException(ErrInvalidLicenseClass, null, null);
		return;
	endif;
	
	if _passport.noErrors()
	and ( _productCode = ProductCode_JMT or _productCode = ProductCode_Subs )	//19 Jun 2020	NDL	TFS 49569
	then
		app.myRoot.setSystemPermissionDetails();
	endif;

	if _passport.noErrors()
	and (_productCode = ProductCode_JMT or _productCode = ProductCode_Subs )  //jlier1 TFS 57095 14/3/22
	then
		app.myRoot.resetRootSecurityRoles(cmifMonitor);
	endif;
	
	if _passport.noErrors() then
		// This is only required if the class is being auditted
		app.myUtilityUA.myUpdateAuditAgent.audUpdateGeneric(_cmObj, false);
	endif;
epilog
	self.finaliseActivityWithPassport(_passport);
end;</source>
        <Parameter name="_cmObj" type="CM_Object" usage="input"/>
        <Parameter name="_licenseName" type="String"/>
        <Parameter name="_licenseKey" type="String"/>
        <Parameter name="_productCode" type="String"/>
        <Parameter name="_expectedEdition" type="Integer"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
