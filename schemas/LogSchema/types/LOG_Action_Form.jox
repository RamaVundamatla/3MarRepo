        <updating/>
        <source>resetTopPositions() protected, updating;

vars

	theHeight	: Real;

begin

	theHeight		:= self.topMargin + 10;
	self.optDocket.top		:= theHeight;
	self.optLocation.top	:= theHeight;
	self.optLogId.top		:= theHeight;
	self.optSpecs.top		:= theHeight;
	self.tblSelection.top	:= self.optDocket.top + self.optDocket.height + 10;
	self.splitterFrame.top	:= self.tblSelection.top + self.tblSelection.height + 10;
	self.tblActionData.top	:= self.height - self.tblActionData.height - 40;
	self.splitterFrame.height := self.tblActionData.top - self.splitterFrame.top - 10;
	self.splitContainer.cnEcResizeContents();
	//	self.splitContainer.cnEcResizeContents();
//		self.txtDetails.top		:= self.tblSelection.top + self.tblSelection.height + 10;
//	self.tblActionData.top	:= self.splitterFrame.top + self.splitterFrame.height + 10;
	
end;</source>
