    <JadeMethod name="initTableData" id="b9244e8d-789b-4d60-a61a-01d8857f505a">
        <subschemaFinal/>
        <updating/>
        <source>initTableData(_theEntDef: String) updating, subschemaFinal;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
21 March 2018	jlgsl4	TFS 37410 Import MTs IMEX transition status

*/

vars

begin
	self.tblData.allSelectedObjects.clear;
	if _theEntDef &lt;&gt; null then
		inheritMethod(_theEntDef);
	else
		//reset stuff
		self.tblData.rows := 1;	
	endif;

epilog

end;</source>
        <Parameter name="_theEntDef" type="String"/>
    </JadeMethod>
    <JadeMethod name="populateDataTable" id="0729da78-2c3e-4979-8da4-8ba241b9b0cf">
        <updating/>
        <source>populateDataTable() updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
20 March 2018	jlgsl4	TFS 37410 Import MTs IMEX transition status

*/

vars
	str		: String;
	savedRow,
	row		: Integer;
	transitionCriteria : CM_IMEXTransitionCriteria;
begin

	if self.tblData.rows &gt; 1 then
		savedRow := self.tblData.row;
	endif;
	self.tblData.rows:= self.tblData.fixedRows;

	foreach transitionCriteria in self.myTerminal.allIMEXTransitionCriteria do	//18 May 2016	NDL	TFS 1981 use the byPriority collection
		self.doQueryAddItem(transitionCriteria);
	endforeach;
	
	// restore the current row
	if savedRow &gt; 0 and savedRow &lt;= self.tblData.rows then
		self.tblData.row := savedRow;
	else
		if self.tblData.rows &gt; 1 then
			self.tblData.row := 2;	// first data row
		endif;
	endif;

end;</source>
        <access>protected</access>
    </JadeMethod>
