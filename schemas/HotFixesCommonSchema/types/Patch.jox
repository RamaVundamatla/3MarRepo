    <JadeMethod name="getParDirectory" id="111563d0-8f21-4e13-8a73-487afb040ee3">
        <source>getParDirectory() : String protected;
// created by cnwvu1 on 11/03/2007
vars
	dirPart	: String;
	parNo	: String;
	tag		: String;
	base	: String;
begin
	// TFS 38497 jlgmd1 12/10/2018 START
	dirPart := app.myRootHotFix.DIR_PART_PAR;
	parNo := self.parNo;
	
	if self.isTFSPatch then
		dirPart := app.myRootHotFix.DIR_PART_TFS;
		if parNo[1:1] = app.myRootHotFix.TFS_NUMBER_MASK then
			parNo := self.parNo[2:end];
		endif;
	endif;
	
	if self.tag &lt;&gt; null then
		tag := "_" &amp; self.tag;
	endif;
	// TFS 38497 jlgmd1 12/10/2018 END

	if self.readme_parTopic.cnContains("Priority A") then
		base := app.myRootHotFix.getDirHotFixes();
	else
		base := app.myRootHotFix.getDirOfPatches();
	endif;
	
	//return app.myRootHotFix.getDirOfPatches() &amp; self.patchNo &amp; app.myRootHotFix.DIR_PART_PAR &amp; self.parNo &amp; '\';
	return base &amp; self.patchNo &amp; dirPart &amp; parNo &amp; tag &amp; '\';		// TFS 38497 jlgmd1 12/10/2018

end;
</source>
        <access>protected</access>
        <ReturnType type="String"/>
    </JadeMethod>
