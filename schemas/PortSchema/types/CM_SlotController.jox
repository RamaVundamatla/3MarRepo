    <JadeMethod name="addSlotRequest" id="26aa8002-d6c6-4f13-889e-49f4817e2ba6">
        <updating/>
        <source>addSlotRequest(_isLoad : Boolean; _slotRequest : CM_SlotRequest) updating;
/*
------------------------------------------------------------------------
Created:			27 March 2003 by cnwdwq1
Purpose:			Updates the slotRequest collection AND THE STATIC property.
							We use the static property to quickly get the current state of the the controller.
Parameters:		
Returns:			
Changed On		Changed By		Reason
------------	------------	-----------------------------------------
														
------------------------------------------------------------------------
*/
vars

begin

	if _slotRequest.mySlotController &lt;&gt; self then
		app.raiseUnexpectedProgramError(class.name, method.name, 'attempt to add slotRequest to (' &amp; self.String &amp;
					') when slotRequest.mySlotController = ' &amp; _slotRequest.mySlotController.String);
		return;
	endif;

	if _isLoad then
		if self.allSlotRequestsLoad.includes(_slotRequest) then
			return;
		endif;
		self.allSlotRequestsLoad.add(_slotRequest);
		self.mySlotRequestLoad := _slotRequest;
	else
		if self.allSlotRequestsDischarge.includes(_slotRequest) then
			return;
		endif;
		self.allSlotRequestsDischarge.add(_slotRequest);
		self.mySlotRequestDischarge := _slotRequest;
	endif;


end;</source>
        <Parameter name="_isLoad" type="Boolean"/>
        <Parameter name="_slotRequest" type="CM_SlotRequest"/>
    </JadeMethod>
    <JadeMethod name="archive" id="f957fe05-6c26-43ba-8a6d-3c1d1542aeb3">
        <updating/>
        <source>archive(_controller : CMIF_ArchiveVoyage; _moveControl : CMIF_MoveController input; _tiArray : CM_TIArray input; _passport : CM_Passport input)updating;
/*
------------------------------------------------------------------------
Created:			20 February 2003 by cnwdwq1
Purpose:			Archives the stuff on this slot controller.
Parameters:		See Method signature above. Special comment:
Returns:			See Method signature above. Special comment:
Changed On		Changed By		Reason
------------	------------	-----------------------------------------
13 Mar 2020 	cnwma1 			Bug 48863: JMT - Voyage Archive, Non Worked Cargo Issue														
------------------------------------------------------------------------
*/
vars
	ti             : CM_TrackedItem;
	tmpSlotRequest : CM_SlotRequest;
	theMonitor     : CMIF_Monitor;

begin

	exclusiveLock(self);
	
	if _controller = null then
		app.raiseCMException2(MethodWithNullParam, method.name, 'controller', null, null);
		return;
	endif;
	if _passport = null then
		app.raiseCMException2(MethodWithNullParam, method.name, 'passport', null, null);
		return;
	endif;
	if _moveControl = null then
		app.raiseCMException2(MethodWithNullParam, method.name, '_moveControl', null, null);
		return;
	endif;	
	
	inheritMethod(_controller, _moveControl, _tiArray, _passport); //13/03/2020 cnwma1 Bug #48863
	
	
	/*//13/03/2020 cnwma1 Bug #48863
	//-------------------------
	//unplan all planned TIs (do this no matter what)
	//-------------------------
	_tiArray.clear;
	self.getAllPlannedTrackedItems(_tiArray, true, false);
	foreach ti in _tiArray do
		exclusiveLock(ti);
		_moveControl.setMoveMode(PLANNING_MODE);
		_moveControl.setMyTrackedItem(ti);
		_moveControl.isFullyUnplan := true;	//For DLR's
		_moveControl.executeUndoMove(_passport);
	endforeach;			
	//-------------------------
	//Unqueue all _tiArray (do this no matter what)
	//-------------------------
	_tiArray.clear;
	self.getAllQueuedTrackedItems(_tiArray, true);
	foreach ti in _tiArray do
		exclusiveLock(ti);
		_moveControl.setMoveMode(QUEUE_MODE);
		_moveControl.setMyTrackedItem(ti);
		_moveControl.executeUndoMove(_passport);
	endforeach;			

	//----------------------
	//Unworked Trackeditems on the ship
	//------------------------
	if _controller.myMonitor &lt;&gt; null then
		theMonitor := _controller.myMonitor;
	endif;
	*/
	
	/*//13/03/2020 cnwma1 Bug #48863
	if _controller.removeNonWorkedTrackedItems then
		//th2 - performance!! Reduce update frequency as this was taking %26 of total time (doh!)
		//if theMonitor &lt;&gt; null then
		//	theMonitor.updateProgress(app.getErrorString(RemovingNonWorkedTrackedItems)&amp; '...', null, null);
		//endif;
		_tiSet.clear;
		self.allTrackedItems.copy(_tiSet);		

		while true do
			ti := _tiSet.first;
			if ti = null then
				break;
			endif;
			exclusiveLock(ti);
			_tiSet.remove(ti);
			if ti.wasWorkedInSystem() then
				continue;
			endif;
			if ti.isChild then
				continue;
			endif;
			ti.erase(NORMAL_ERASE);
		endwhile;
	endif;
	
	*/
	//----------------------
	//Nuke the slot Requests (load/discharge)
	//------------------------
	
	// the following will remove the slotRequest from
	// the allSlotRequestsDischarge array as inversed
	if self.mySlotRequestDischarge &lt;&gt; null then // ### PAR 10450
		self.mySlotRequestDischarge.erase(NORMAL_ERASE);
		self.mySlotRequestDischarge := null;
	endif;
	
	while true do
		tmpSlotRequest := self.allSlotRequestsDischarge.last;
		if tmpSlotRequest = null then
			break;
		endif;
		tmpSlotRequest.erase(NORMAL_ERASE);			
	endwhile;

	if self.mySlotRequestLoad &lt;&gt; null then // ### PAR 10450
		self.mySlotRequestLoad.erase(NORMAL_ERASE);
		self.mySlotRequestLoad := null;
	endif;
	
	while true do
		tmpSlotRequest := self.allSlotRequestsLoad.last;
		if tmpSlotRequest = null then
			break;
		endif;
		tmpSlotRequest.erase(NORMAL_ERASE);			
	endwhile;
	
end;</source>
        <Parameter name="_controller" type="CMIF_ArchiveVoyage"/>
        <Parameter name="_moveControl" type="CMIF_MoveController" usage="input"/>
        <Parameter name="_tiArray" type="CM_TIArray" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="calculateMoveLCs" id="a2cb87ee-1c13-4d91-a27e-04e191bf7039">
        <source>calculateMoveLCs(_ti : CM_TrackedItem): Real;
// ---------------------------------------------------------------------------
// Created:     13 September 2001 by cnwdwq1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	len : Real;
begin
	len := _ti.getLengthInUnits();
	if len &gt; 1 then
		return len div 2;
	else
		return 1;
	endif;
end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <ReturnType type="Real"/>
    </JadeMethod>
