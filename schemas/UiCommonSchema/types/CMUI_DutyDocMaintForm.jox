    <JadeMethod name="doDelete" id="b7c7c721-15a5-4929-98d1-7787137a58ad">
        <updating/>
        <source>doDelete(): Boolean updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 December 2012	cnwer1	Initial creation HAT 2189
31 July     2014    cnwma1 PAR 34408 Credit Customer current charges
*/

vars

	dutyDoc : CM_Object;
	theReturn : Integer;
	bulkRelease : CM_BulkRelease;
	tis: CM_TISet;
	ti: CM_TrackedItem;
	invoice: CM_Invoice;						
	invoiceLine, pxyInvoiceLine: CM_InvoiceLine;
	invoiceStatus	: CMIF_InvoiceStatus;		 
	txn : CM_TITransaction;
	txnSet : CM_TITransactionSet;
	invoiceLineSet : CM_InvoiceLineSet;
	oldDuty		: Decimal[5,2];
	dutyDocItem,pxyDocItem: CM_DutyDocItem;
	ls: Boolean;

begin
	
	dutyDoc := self.myDutyDoc;
	if dutyDoc = null then
		return false;
	endif;	
		
	create tis transient;
	// void All Invoice Lines for the dutydoc Items
	self.myDutyDoc.getTIsFor(self.myDutyDoc.allDutyDocItems, tis);
	while true do
		if self.myDutyDoc.dutyDeposit = 0 then								// cnwma1 31/07/2014 PAR 34408
			foreach ti in tis   do
				create txnSet transient;
				create invoiceLineSet transient;
				txnSet := ti.getTransOfType(TRANS_TYPE_DUTY_CHARGE);
				foreach txn in txnSet do
				 if txn.myInvoiceLine &lt;&gt; null then
						if  txn.myInvoiceLine.trackedItem = ti and txn.myInvoiceLine.voided=false then
							invoiceLineSet.addNoDuplicates(txn.myInvoiceLine,false);
						endif;
				 endif;
				endforeach;
				foreach invoiceLine in invoiceLineSet do
					if invoiceLine &lt;&gt; null and invoiceLine.status &lt;&gt; 1 then
						create invoiceStatus transient;
						pxyInvoiceLine := invoiceLine.pxyGetProxyObject();
						if pxyInvoiceLine = null then
						
							app.cmsBeginLoad(ls);
							pxyInvoiceLine := app.createUpdateProxy(invoiceLine).CM_InvoiceLine;
							app.cmsEndLoad(ls);
							
						endif;
						invoiceStatus.allInvoiceLines.add(pxyInvoiceLine);
						invoiceStatus.newStatus := CM_InvoiceLine.STATUS_VOIDED;
						app.myTrxUA.trxUpdateInvoiceStatus(invoiceStatus, app.myPassport);
						 delete invoiceStatus;
						 delete pxyInvoiceLine;
						if not app.myPassport.trxCompletedOK then
							theReturn := app.showErrorWarningDialog("Duty Documentation", app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
							if app.myPassport.noErrors and
								theReturn = IDOK then
									// there must have just been warnings that the user has acknoledged so ..
								app.myPassport.warningsAcknowledged	:= true;
								continue;
							endif;
							return false;
						endif;
					endif;
				endforeach;
			endforeach;
		endif;
		
	  // Void All invoice lines for the Extra Charges
	    if self.myDutyDoc.dutyDeposit = 0 then				// cnwma1 31/07/2014 PAR 34408
			foreach invoice in self.myDutyDoc.getMyDebtor.allInvoices where invoice.isVoided = false and invoice.invoiceType.description="Non Cargo Charges" do
					foreach invoiceLine in invoice.invoiceLines where invoiceLine.voided = false and invoiceLine.remarks =self.myDutyDoc.id do
							create invoiceStatus transient;
								app.cmsBeginLoad(ls);
								pxyInvoiceLine := app.createUpdateProxy(invoiceLine).CM_InvoiceLine;
								app.cmsEndLoad(ls);
								invoiceStatus.allInvoiceLines.add(pxyInvoiceLine);
								invoiceStatus.newStatus := CM_InvoiceLine.STATUS_VOIDED;
								app.myTrxUA.trxUpdateInvoiceStatus(invoiceStatus, app.myPassport);
								delete invoiceStatus;
								delete pxyInvoiceLine;
								if not app.myPassport.trxCompletedOK then
									theReturn := app.showErrorWarningDialog("Duty Documentation", app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
									if app.myPassport.noErrors and
									theReturn = IDOK then
									// there must have just been warnings that the user has acknoledged so ..
									app.myPassport.warningsAcknowledged	:= true;
									continue;
									endif;
									return false;
								endif;
					endforeach;
			endforeach;
		endif;	
		foreach dutyDocItem in self.myDutyDoc.allDutyDocItems do
			pxyDocItem := dutyDocItem.pxyGetProxyObject();
				if pxyDocItem = null then
					app.cmsBeginLoad(ls);
						pxyDocItem := app.createUpdateProxy(dutyDocItem).CM_DutyDocItem;
					app.cmsEndLoad(ls);
				endif;
				pxyDocItem.setProxyDutyDoc(null);
				pxyDocItem.setDutyItemValue();
				
				app.myTrxUA.trxUpdateDutyDocItem( pxyDocItem, app.myPassport );      
				if not app.myPassport.trxCompletedOK then
					theReturn := app.showErrorWarningDialog("Duty Documentation", app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
					if app.myPassport.noErrors and
						theReturn = IDOK then
						app.myPassport.warningsAcknowledged	:= true;
						continue;
					endif;
					return false;
				endif;
				delete pxyDocItem;
		endforeach;
			
		// Delete Release Request  // cnwma1 31/07/2014 PAR 34408
		bulkRelease := self.myTerminal.getBulkReleaseFromCode(self.myDutyDoc.id);
		if bulkRelease &lt;&gt; null then
			app.myTrxDA.trxDeleteBulkRelease(bulkRelease, app.myPassport);
		endif;
		if not app.myPassport.trxCompletedOK then
			theReturn := app.showErrorWarningDialog("Duty Documentation", app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
				if app.myPassport.noErrors and
				theReturn = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
				endif;
			return false;
		endif;		
		// Delete all the DutyDocItems
		app.myTrxDA.trxDeleteCMObject(dutyDoc,app.myPassport);
		if not app.myPassport.trxCompletedOK then
			theReturn := app.showErrorWarningDialog("Duty Documentation", app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
				theReturn = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			return false;
		endif;
		break;
	endwhile;
	return true;
epilog
	app.cmsEndLoad(ls);
	if invoiceStatus &lt;&gt; null then
	invoiceStatus.allInvoiceLines.purge;
	endif;
	delete pxyInvoiceLine;
	delete invoiceStatus;
	app.mousePointer := MP_DEFAULT;
	delete tis;
	delete invoiceLineSet;
	delete txnSet;

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doSave" id="7b7169e3-1fd1-48c9-ae58-12106011ef2a">
        <updating/>
        <source>doSave(_updateDataEntry: Boolean) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 December 2012	cnwer1	Initial creation HAT 2189
*/

vars
	pxyDutyDoc, realDutyDoc : CM_DutyDoc;
	agent: CM_DutyDocAgent;
	theReturn : Integer;
	approvalProcessingRequired: Boolean;
	dutyDocItem: CM_DutyDocItem;
	freeStorageDays: Integer;
	loadState: Boolean;
begin

	
	pxyDutyDoc:=self.setProxyDetails(_updateDataEntry);
	
	if pxyDutyDoc = null then
		return;
	endif;
	

	while true do
		approvalProcessingRequired := false;
		if self.myDutyDoc = null then
			app.myTrxCA.trxCreateDutyDoc(pxyDutyDoc,realDutyDoc, app.myPassport);
			approvalProcessingRequired :=  pxyDutyDoc.dutyDocUserId &lt;&gt; null;		// PAR 31517
		else
			approvalProcessingRequired := pxyDutyDoc.dutyDocUserId &lt;&gt; null and myDutyDoc.dutyDocUserId = null;  // PAR 31517
			app.myTrxUA.trxUpdateDutyDoc(pxyDutyDoc, app.myPassport);
		endif;
		
		if not app.myPassport.trxCompletedOK then

			theReturn := app.showErrorWarningDialog("Duty Documentation", app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
				theReturn = IDOK then
					// there must have just been warnings that the user has acknoledged so ..
					app.myPassport.warningsAcknowledged	:= true;
					continue;
				endif;
			return;
		else
			if self.myDutyDoc = null then
				self.setMyDutyDoc(realDutyDoc);	
				self.loadDutyDoc(_updateDataEntry);
			endif;
			
			if approvalProcessingRequired then
				app.myTrxUA.trxDutyDocApprovalProcessing(self.myDutyDoc, app.myPassport);
				if not app.myPassport.trxCompletedOK then
					app.showErrorWarningDialog("Duty Documentation", app.myPassport, ErrWarnMode_AddUpdate);
					return;
				endif;
			endif;
	
		/*create tis transient;
		self.myDutyDoc.getTIsFor(self.myDutyDoc.allDutyDocItems, tis);
		if self.myDutyDoc.isImport then
		app.myUtilityCA.utlCreateDutyDocRoadRelease(self.myDutyDoc, tis, release, app.myPassport);
		endif;*/
	
/*			PAR 34049 Free days is actually display only and cannot be changed
			if self.txtFreeDays.text.trimBlankCharacters &lt;&gt; null then
				write "update free days";
				freeStorageDays := self.txtFreeDays.text.Integer;
				// Update free storage days
				foreach dutyDocItem in self.myDutyDoc.allDutyDocItems do
					if dutyDocItem.getMyTrackedItem.freeStorageDays &lt;&gt; freeStorageDays then
						app.cmsBeginLoad(loadState);
						pxyTi := dutyDocItem.getMyTrackedItem.pxyCreateUpdateProxy();
						app.cmsEndLoad(loadState);
						app.myTrxUA.trxUpdateTIFreeStorageDays(pxyTi, freeStorageDays, app.myPassport);
						if not app.myPassport.trxCompletedOK then
							app.showErrorWarningDialog("Duty Documentation", app.myPassport, ErrWarnMode_AddUpdate);
						return;
						delete pxyTi;
				endif;
					endif;
				endforeach;
			endif;
*/			
		endif;
		break;
	endwhile;
	
epilog	
	delete pxyDutyDoc;
	delete agent;

end;</source>
        <Parameter name="_updateDataEntry" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doSelectContainerClick" id="00a0a926-c8d6-4bb1-bc89-1d1ae5ffd689">
        <updating/>
        <source>doSelectContainerClick() updating;
/*
  Select a container that has already been assigned to a Duty Doc Item (32036)
  02/09/2014 CNWMA1 PAR#34845 Container Filter by voyage
*/
vars
	voyageTis: CM_TISet;
	tis: CM_TIArray;
	selectedObject, obj: Object;
	oa: ObjectArray;
	consignee: CM_ConsigneeConsignor;
	voyage, voyage1: CM_Voyage;
	ti, voyageTi: CM_TrackedItem;
	dutyDocItems: CM_DutyDocItemSet;
	pxyDutyDocItem, dutyDocItem: CM_DutyDocItem;
	agent: CM_DutyDocAgent;
	dutyDocType : CM_DutyDocType;
	imex 	: Integer;
	theResult : Integer;	//13 Jan 2020 NDL	TFS 46815
begin
	create agent transient;
	
	if app.myPassport.myTerminal = null then
		app.myPassport.setMyTerminal(self.myTerminal);
	endif;
	
	self.doSave(false);

	if self.myDutyDoc = null then
		return;
	endif;

	consignee := self.myDutyDoc.getMyConsignee();
	voyage := self.myDutyDoc.getMyVoyage();
	//epr par 31299
	dutyDocType:= self.myDutyDoc.getDutyDocTypeObject();
	if dutyDocType &lt;&gt; null then
		imex:=dutyDocType.imex;
	endif;
	
	create tis transient;
	create dutyDocItems transient;
	if consignee &lt;&gt; null then
		create voyageTis transient;
		agent.getAllUnassignedTis(self.myTerminal, voyageTis);
		
		// Get all the onsite containers for a consignee
		foreach ti in voyageTis do
			//epr par 31299
			if ti.myConsignee &lt;&gt; consignee then
				continue;
			endif;
			if imex &lt;&gt; 0 and ti.getImExStatus &lt;&gt; imex then
				continue;
			endif;
			if ti.myVoyage &lt;&gt; null and ti.myVoyage &lt;&gt; voyage then  // 02/09/2014 CNWMA1 PAR# 34845 
				continue;
			endif;
			tis.add(ti);
		
		endforeach;
	endif;
	
	self.myAssistant.pickerWindowForTrackedItem(tis, self.myTerminal, consignee, voyage,imex, true, selectedObject);

	if selectedObject &lt;&gt; null then
		if selectedObject.isKindOf(CM_TrackedItem) then
			create oa transient;
			oa.add(selectedObject);
			selectedObject := oa;
		endif;
		foreach obj in selectedObject.ObjectArray do
			ti := obj.CM_TrackedItem;
			dutyDocItems.clear();
			agent.getDutyDocItemsUnassigned(ti, dutyDocItems);
			foreach dutyDocItem in dutyDocItems do
				beginLoad;
				pxyDutyDocItem := dutyDocItem.pxyCreateUpdateProxy().CM_DutyDocItem;
				endLoad;
				pxyDutyDocItem.setProxyDutyDoc(self.myDutyDoc);
				
				//13 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
				while true do
				
					app.myTrxUA.trxUpdateDutyDocItem( pxyDutyDocItem, app.myPassport );
				
					if app.myPassport.trxCompletedOK then
						break;
					else
						theResult := app.showErrorWarningDialog("Duty Documentation", app.myPassport, ErrWarnMode_AddUpdate);
						if app.myPassport.noErrors and theResult = IDOK then
							app.myPassport.warningsAcknowledged	:= true;
							continue;
						endif;
					endif;
					
					return;
					
				endwhile;
				
				delete pxyDutyDocItem;
				
			endforeach;			
		endforeach;
		self.loadDutyDocItems();
	endif;
epilog
	delete tis;
	delete voyageTis;
	delete oa;
	delete dutyDocItems;
	delete pxyDutyDocItem;
	delete agent;
	app.mousePointer := Window.MousePointer_Default;
end;</source>
    </JadeMethod>
