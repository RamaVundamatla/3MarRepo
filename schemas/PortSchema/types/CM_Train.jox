    <JadeMethod name="getSiteDescription" id="b329b72f-a908-4daa-9027-ecf0c2f31f0a">
        <source>getSiteDescription() : String;
// ---------------------------------------------------------------------------
// Created:     09 June 2009 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin
	if self.myTerminal &lt;&gt; null then
		if self.isCompletelyConfirmed(false) then
			return app.getErrorString(OnTerminal);
		else
			return app.getErrorString(Unconfirmed) &amp; " " &amp; app.getErrorString(SHP_PLANNING); // PAR 20834
		endif;
//	elseif self.myTerminalNotArrived &lt;&gt; null then // 773???
//		return app.getErrorString(Notified);
	elseif self.myTerminalDeparted &lt;&gt; null then
		return app.getErrorString(Departed);
	endif;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getStatusLineStats" id="4455c114-781e-4558-82d6-64f548be5066">
        <source>getStatusLineStats() : String;
// ---------------------------------------------------------------------------
// Created:     06 August 2009 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
// 11 Nov 2015		cnwma1			PAR #36748 Error 4013  in Train Enquiry when opening the train
// ---------------------------------------------------------------------------

vars
	totLoad, 
	totDisch, 
	totIntransit, 
	totIn, 
	totWagonIn, 
	totWagonOut 	: Integer;
	totTrainWeight,
	totCargoWeight,
	totWagonWeight  : Real;  //36748
begin
	totLoad 		:= self.getCargoTotals(ETRow_TotalCargoLoaded);
	totDisch 		:= self.getCargoTotals(ETRow_TotalCargoDischarged);
	totIntransit	:= self.getCargoTotals(ETRow_TotalCargoIntransit);
	totIn 			:= self.getCargoTotals(ETRow_TotalCargoIn);
	totWagonIn 		:= self.allWagonsByOrderInward.size;
	totWagonOut 	:= self.allWagonsByOrderOutward.size;
	totCargoWeight  := self.getCargoWeightProposed(); // PAR 21977
	totWagonWeight  := self.getWagonTareWeight(false).Real.roundedTo(0);
	totTrainWeight  := totWagonWeight + totCargoWeight;// PAR 21977

	//27 Aug 2009	NDL	CCMS 1094
	return
	app.getErrorString(Total_wagons) 		  &amp; " - " &amp; 
	app.getErrorString(IN_YO) 				  &amp; ": " &amp; totWagonIn.String &amp; " | " &amp; 
	app.getErrorString(OUT_YO) 				  &amp; ": " &amp; totWagonOut.String &amp; "         " &amp;
	app.getErrorString(CM_TotalItems) 		  &amp; " - " &amp;
	app.getErrorString(IN_YO) 				  &amp; ": " &amp; totIn.String &amp; " | " &amp; 
	app.getErrorString(In_Transit) 			  &amp; ": " &amp; totIntransit.String &amp; " | " &amp; 
	app.getErrorString(Discharged) 			  &amp; ": " &amp; totDisch.String &amp; " | " &amp; 
	app.getErrorString(Loaded) 				  &amp; ": " &amp; totLoad.String &amp; " | " &amp; 
	app.getErrorString(Proposed_total_weight) &amp; ": " &amp; totTrainWeight.String;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
