<Class name="CM_QStringProperty" id="88fff671-406c-4152-8038-fd9f4f84b251">
    <superclass name="CM_QueryProperty"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="query"/>
    <JadeMethod name="create" id="89045c40-59de-433c-aa77-8ea1115fbece">
        <updating/>
        <source>create() updating;
// -----------------------------------------------------------------------------
// Created:		08 May 2002 by cnwka1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	---------------------------------------------
//
// -----------------------------------------------------------------------------
vars
	oper : CM_QueryOperator;

begin
	if self.isTransient then 
		return;
	endif;
		
	create oper as CM_QStringStartsWith persistent;
	self.allAllowedOperators.add(oper);
	
	create oper as CM_QStringEndsWith persistent;
	self.allAllowedOperators.add(oper);
	
	//15 May 2013	NDL	Par 31506
	create oper as CM_QStringStartsOrEndsWith persistent;
	self.allAllowedOperators.add(oper);
	
	create oper as CM_QStringContains persistent;
	self.allAllowedOperators.add(oper);

	create oper as CM_QStringNotEqual persistent;
	self.allAllowedOperators.add(oper);

	create oper as CM_QStringEquals persistent;
	self.allAllowedOperators.add(oper);
	
	//+cnwml2 PAR23586  POL CCMS 1878
	create oper as CM_QStringRange persistent;
	self.allAllowedOperators.add(oper);

end;</source>
    </JadeMethod>
    <JadeMethod name="getDefaultOperator" id="34c231cb-a0f2-45eb-8567-62472d28483a">
        <source>getDefaultOperator(): CM_QueryOperator;
// ---------------------------------------------------------------------------
// Created:     23 September 2003	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars

begin
	return self.allAllowedOperators[CM_QueryOperator.Operator_StartsWith];

end;</source>
        <ReturnType type="CM_QueryOperator"/>
    </JadeMethod>
    <JadeMethod name="getKeyLengthForXTABDictionary" id="df436e9f-79cc-4f13-843d-cb3ff8a64337">
        <source>getKeyLengthForXTABDictionary(): Integer;
// ---------------------------------------------------------------------------
// Created:     04 December 2008 by concms1
// Purpose:     CCMS SFW 1047 - Totals Only Lists
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	schema	:Schema;
	cls		:Class;
	prop	:Property;
	length	:Integer;
begin
	schema 	:= rootSchema.getSchema ('PortSchema');
	cls		:= schema.getClass (self.propertyClassName);
	
	if cls &lt;&gt; null then
		prop := cls.findProperty (self.propertyName);
		
		if prop &lt;&gt; null and prop.isKindOf (Attribute) then
			length := prop.Attribute.length;
			return length;
		endif;
	endif;
	
	return inheritMethod();	// all we can do
epilog

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getQueryOperatorForYADataConv" id="4eee60e6-b431-4d64-b1cc-8056c1a66e74">
        <source>getQueryOperatorForYADataConv(): Class;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 June 2015	cnwndl1	Initial creation	Par 36338

*/

vars

begin
	return CM_QStringEquals;

epilog

end;</source>
        <ReturnType type="Class"/>
    </JadeMethod>
    <JadeMethod name="getValueForObject" id="a2de9e18-99df-4b06-9133-1e7c00bc5727">
        <source>getValueForObject(_obj: Object; _op: CM_QueryOperator input): Any;
// ---------------------------------------------------------------------------
// Created:     30 June 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	propValue : Any; 

begin
	propValue := inheritMethod(_obj,_op);

	if self.needToUpperCase then
		propValue := propValue.String.toUpper;
	endif;

	return propValue;

end;</source>
        <Parameter name="_obj" type="Object"/>
        <Parameter name="_op" type="CM_QueryOperator" usage="input"/>
        <ReturnType type="Any"/>
    </JadeMethod>
    <JadeMethod name="setTextValues" id="5ae60aaf-719c-4dd5-a5aa-2e895b256327">
        <source>setTextValues(_txt: TextBox input; _params: CM_QueryCriteriaLineHolder; _operator: CM_QueryOperator; _passport: CM_Passport);
// ---------------------------------------------------------------------------
// Created:     12 August 2003	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars

begin
	if _txt = null or (not CM_QueryStringOperators.hasInstance(_operator)) then
		return;
	endif;
	
	_txt.text := _operator.CM_QueryStringOperators.searchValue.String;

end;</source>
        <Parameter name="_txt" type="TextBox" usage="input"/>
        <Parameter name="_params" type="CM_QueryCriteriaLineHolder"/>
        <Parameter name="_operator" type="CM_QueryOperator"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
</Class>
