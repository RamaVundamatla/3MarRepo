    <JadeMethod name="removeSystemTypeFromCombo" id="fbce45f3-4d54-4c2e-b848-dbcef936fc29">
        <source>removeSystemTypeFromCombo() protected;
// ---------------------------------------------------------------------------
// Created:     14 January 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	idx			: Integer;
begin

	idx := self.cmbReportType.findString(1, CM_QryReport.ReportTypeDescr_SystemDefined);
	if idx &gt; 0 then
		self.cmbReportType.removeItem(idx);
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="removeTrackedItemFromCombo" id="848c1fb3-933c-42dd-abd9-bc1ee19b550b">
        <source>removeTrackedItemFromCombo() protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
8 Dec 2015	cnwma1	PAR #37254 JH - Report Error (14011). Invalid property array index
9 Feb 2016  cnwma1  PAR #36654 Reports run through the web interface missing port logo
*/

vars
	idx : Integer;
begin
	
	if self.myProxyObject.isKindOf(CM_QryReportSystem) then     //09/02/2016 cnwma1 PAR #36654
		return;
	endif;
	if self.myProxyObject.CM_QryReportUser &lt;&gt; null then   //8/12/2015  cnwma1 PAR #37254
		if self.myProxyObject.CM_QryReportUser.reportType &lt;&gt; CM_QryReportUser.ReportType_TrackedItem then
			idx := self.cmbReportType.findItemData(CM_QryReportUser.ReportType_TrackedItem);
			if not  app.getMyUser.canDo(self.myProxyObject.CM_QryReportUser.getMyTerminal, Mod_Logs) then
				if idx &gt; 0 then
					self.cmbReportType.removeItem(idx);
				endif;
			endif;
		endif;
		
	endif;
	
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="selectFirstRow" id="0c969b67-15a1-44af-8118-18efd7f16e2d">
        <updating/>
        <source>selectFirstRow(_showData : Boolean) protected, updating;
// -------------------------------------------
// Created 28 February 2005 by cnwdvb1
// -------------------------------------------
vars

begin

	if self.tblData.rows &gt; self.tblData.fixedRows then
		self.tblData.clearAllSelected();
		self.myCurrentObject := self.tblData.accessRow(self.tblData.fixedRows + 1).itemObject.CM_Object;
		self.tblData.accessedRow.selected := true;
		if _showData then
			self.showThumbnailData(self.myCurrentObject.CM_QryReport);
		endif;
	endif;

end;</source>
        <access>protected</access>
        <Parameter name="_showData" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setAvailableFormats" id="a980977d-5161-42fc-aeb2-68adca528598">
        <source>setAvailableFormats(_qryReport : CM_QryReport) protected;
// ---------------------------------------------------------------------------
// Created:     02 December 2004	cnwhjg1
//
// Purpose:     
// ----------   ----------  --------------------------------------------------
vars

	format	: CMIF_Object;

begin

	self.allAvailableFormats.clear();
	if _qryReport &lt;&gt; null and _qryReport.isFormBasedReport then
		foreach format in self.allFormats where format.CMIF_ReportFormats.formatType = JadeReportWriterReport.PRINTER or
		format.CMIF_ReportFormats.formatType = CM_QryReport.PDF_Format do
		self.allAvailableFormats.add(format);
		endforeach; 		
	else
		self.allFormats.copy(self.allAvailableFormats);
	endif;
	
	self.lstFormats.displayCollection(self.allAvailableFormats, false, 0, null);
	

end;</source>
        <access>protected</access>
        <Parameter name="_qryReport" type="CM_QryReport"/>
    </JadeMethod>
    <JadeMethod name="setButtonsForReportType" id="ceb019dd-eaa5-4f82-9ae1-2030dee71074">
        <source>setButtonsForReportType();
//----------------------------------------------------------------------
//  Created by cnwsh3
//	Date 13 March 2009
//
// Implemented version:
// 
//----------------------------------------------------------------------
vars

begin
	if self.cmbReportFilter.itemData[self.cmbReportFilter.listIndex] = CM_QryReport.ReportType_SystemDefined then
		self.btnNewTV.enabled := false;
		self.btnDeleteTV.enabled := false;
	else
		self.btnNewTV.enabled := true;
		self.btnDeleteTV.enabled := true;
	endif;
epilog
end;</source>
    </JadeMethod>
    <JadeMethod name="setColorsFromController" id="87b17f5e-7b92-4779-8d2f-eae2066ec72f">
        <updating/>
        <source>setColorsFromController(_colorControl: CM_ColorController) updating;
// -------------------------------------------
// Created 21 September 2004 by cnwdvb1
// -------------------------------------------
vars

	theBackColour	: Integer;

begin
	inheritMethod(_colorControl);

	self.setColorsForTable(self.tblParamData);
	self.setColorsForEntryTable(self.tblParamEnt);
	self.setColorsForEntryTable(self.tblReportDtl);
	self.setColorsForTable(self.tblCriteria);
	self.setColorsForTable(self.tblDesigns);
	
	theBackColour := self.backColor;
	
	self.shtParameters.backColor	:= theBackColour;
	self.shtReportDetails.backColor	:= theBackColour;
	self.fldInput.backColor			:= theBackColour;
	
	self.frmParamData.backColor		:= theBackColour;
	self.frmParamEnt.backColor		:= theBackColour;

end;</source>
        <Parameter name="_colorControl" type="CM_ColorController"/>
    </JadeMethod>
    <JadeMethod name="setControlsForAddEdit" id="aef42f72-537d-4a5e-8d64-cfbcc25654a8">
        <updating/>
        <source>setControlsForAddEdit() updating;
// -----------------------------------------------------------------------------
// Created:		17 June 2002 by cnwka1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	---------------------------------------------
// 8/12/2015	cnwma1	PAR #37254 JH - Report Error (14011). Invalid property array index
// -----------------------------------------------------------------------------
vars
	qryReport				: CM_QryReport;
	pxyQryParam,
	qryParam				: CM_QueryReportParam;
	tbl						: CM_DataTable;
	entDef					: EntTableDef;

begin
	
	inheritMethod();
	qryReport := self.myCurrentObject.CM_QryReport;
	self.tblCriteria.userInputEnabled := true;
	self.isEditingSystemReport := CM_QryReportSystem.hasInstance(self.myCurrentObject);
	self.removeSystemTypeFromCombo();
	self.removeTrackedItemFromCombo();  //8/12/2015 cnwma1 PAR #37254
	self.cmbReportFilter.enabled := false;
	self.tblParamData.rows := self.tblParamData.fixedRows;
	
	self.setAvailableFormats(self.myCurrentObject.CM_QryReport);
	
	if self.mode = self.Mode_Add then
		self.tblDesigns.allSelectedObjects.clear();
		self.tblParamEnt.showHideRowsByViewName('default', CM_EntryTable.ShowHideRows, true);
		self.tblParamEnt.clearValues();
		self.tblReportDtl.clearValues();
		self.tblParamEnt.setValueByName(ETRow_IsVisible, true.cnEcGetTableCheckBoxValue);
		self.tblParamEnt.adjustHeight(200);
		self.tblReportDtl.setFocus();
		self.tblReportDtl.goToRowByName(ETRow_ReportName);
		self.tblCriteria.rows := self.tblCriteria.fixedRows;
		
		
	elseif (self.mode = self.Mode_Update) and 
	   (self.fldInput.topSheet = self.shtParameters) then
		self.tblParamEnt.setFocus();
		self.tblParamEnt.moveFirst();
	endif;
	
	self.tblReportDtl.userInputEnabled := true;
	//th2 PAR 12741 - redid this section - somebody buggered over the enabling and disabling of rows to
	//allow users to update the type and view for system reports, thus breaking them
	if self.isEditingSystemReport then
		self.shtParameters.enabled := false;
		self.tblReportDtl.disableRowByName(ETRow_ReportName);
		// 35875 allow us to edit them
		if app.isDevelopmentSystemMain() then
			self.tblReportDtl.enableRowByName(ETRow_ReportDescription);
		else
			self.tblReportDtl.disableRowByName(ETRow_ReportDescription);
		endif;
		self.tblReportDtl.disableRowByName(ETRow_ReportType);
		self.tblReportDtl.disableRowByName(ETRow_ReportView);
		//users can associate different designs to run against system reports, but that's it
		self.tblReportDtl.enableRowByName(ETRow_JRWReport);
		self.tblReportDtl.enableRowByName(ETRow_JrwReport);
	else//they can update everything
		self.shtParameters.enabled := true;
		self.tblReportDtl.enableRowByName(ETRow_ReportName);
		self.tblReportDtl.enableRowByName(ETRow_ReportDescription);
		self.tblReportDtl.enableRowByName(ETRow_ReportType);
		// Shouldn't be able to update view. This is based on type.
		//self.tblReportDtl.enableRowByName(ETRow_ReportView);
		self.tblReportDtl.enableRowByName(ETRow_JRWReport);
		self.tblReportDtl.enableRowByName(ETRow_JrwReport);
	endif;
	
	if qryReport &lt;&gt; null and qryReport.isFormBasedReport then
		self.tblReportDtl.disableRowByName(ETRow_ReportName);
		self.tblReportDtl.disableRowByName(ETRow_ReportDescription);
		self.tblReportDtl.disableRowByName(ETRow_ReportType);
		self.tblReportDtl.disableRowByName(ETRow_ReportView);
		self.tblReportDtl.disableRowByName(ETRow_JRWReport);
		self.tblReportDtl.disableRowByName(ETRow_JrwReport);
		self.shtParameters.enabled := false;
	endif;		
	
	self.tblCriteria.accessColumn(self.Column_CriteriaName).inputType := Table.InputType_None;
	self.tblParamEnt.userInputEnabled := true;
	
	self.btnAdd.enabled := true;
	self.btnUpdate.enabled := true;
	self.btnRemove.enabled := true;

	//to set the fix default report type to External and Seletor
	//added by cnwyl1 120506
	if self.mode &lt;&gt; self.Mode_Update then		// 34442 for an update, keep the existing view name etc	- this code is for new reports only
		if self.cmbReportFilter.itemData[cmbReportFilter.listIndex] = CM_QryReport.ReportType_External or 
		self.cmbReportFilter.itemData[cmbReportFilter.listIndex] = CM_QryReport.ReportType_Selector then
			self.cmbReportType.text := self.cmbReportFilter.text;
			self.tblReportDtl.setValueByName(ETRow_ReportType, self.cmbReportType.text);
			self.doCmbReportTypeClick(); //25/02/2010 cnwdz2 par22465
		endif;
	endif;
	//add end
	if self.mode &lt;&gt; self.Mode_Update then
		return;
	endif;
	
	if qryReport = null then
		return;
	endif;
	
	tbl := self.tblParamData;
	tbl.rows := tbl.fixedRows;
	entDef := app.myController.getEntTableDef(ETDef_ParamData);
	
	foreach qryParam in qryReport.allQueryReportParams do
		pxyQryParam := qryParam.cloneSelf(true); //Kevin didn't inherit from CM_Object so can't use proxy manager.	
		self.addTblParamDataRow(pxyQryParam, entDef, null);
	endforeach;
end;</source>
    </JadeMethod>
    <JadeMethod name="setControlsForView" id="1d14b70b-365e-43db-8437-453522d52b07">
        <updating/>
        <source>setControlsForView() updating;
// ---------------------------------------------------------------------------
// Created:     21 November 2002		cnwth2	
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	idx			: Integer;
begin
	inheritMethod();
	self.btnAdd.enabled := false;
	self.btnUpdate.enabled := false;
	self.btnRemove.enabled := false;
	
	self.tblReportDtl.userInputEnabled := false;
	self.tblCriteria.userInputEnabled := false;
	self.tblParamEnt.userInputEnabled := false;
	self.tblParamData.userInputEnabled  := false;
	self.cmbReportFilter.enabled := true;
	self.shtParameters.enabled := true;
	
	//PAR19139 cnwsh3 - Check what the report type filter is so we don't enable buttons that shouldn't be for system reports.
	self.setButtonsForReportType();
	
	// TFS 2101 CNWAB1
	if not app.myCurrentUserCan(null, self.permissionMaint) then
		self.btnJRWConfigT.enabled := false;
		self.btnJRWDesignT.enabled := false;
	endif;
end;</source>
