        <ReturnType type="WS_CargoFilterSitesResponse"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="getCargoItemNextPrevious" id="f61d8da0-8dd8-4ec2-a052-d51ad509e03b">
        <source>getCargoItemNextPrevious(request : WS_NextCargoItemQueryRequest) : WS_NextCargoItemResponse webService;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 August 2016	cnwmc5	Initial creation

*/

vars
	
	response		: WS_NextCargoItemResponse;
	completedOK		: Boolean;
	obj				: Object;
	nextPreviousTI,
	ti				: CM_TrackedItem;
	wsTI			: WS_TrackedItem;
	failedDAC		: CM_DataAccessController;
	agent 			: CMIF_MobileGenericAgent;
	
begin
	// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);
	
	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	
	// Initialise the passport for the new transaction
	// In particular this sets passport myUser and myTerminal
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	
	// Create the response
	create response transient;
	
	// Check security access to this message, if required
	//app.checkCurrentUserHasAccess(99999);		// Replace with appropriate permission
	if app.myPassport.hasErrors then
		completedOK := true;
		return response;
	endif;
	
	if request.cargoOid &lt;&gt; null then
		//epr TFS 5535 4/8/17 
		ti := app.myPassport.getObjectOfTypeFromOid(request.cargoOid,CM_TrackedItem).CM_TrackedItem;
		if app.myPassport.hasErrors then
			completedOK:=true;
			return response;
		endif;	
	endif;
	
	create agent transient;
	if request.isPrevious then
		nextPreviousTI := agent.getPreviousTI(ti, request.reefersOnly, request.columnOrder);
	else
		nextPreviousTI := agent.getNextTI(ti, request.reefersOnly, request.columnOrder);
	endif;
	
	if nextPreviousTI = null then
		completedOK := true;
		return response;
	endif;
	
	response.hasPrevious := agent.getPreviousTI(nextPreviousTI, request.reefersOnly, request.columnOrder) &lt;&gt; null;
	response.hasNext := agent.getNextTI(nextPreviousTI, request.reefersOnly, request.columnOrder) &lt;&gt; null;
	
	if not nextPreviousTI.canUserAccessSelf(app.getMyUser(), failedDAC, app.myPassport) then
		app.raiseCMException(ERR_dontHaveAccessToThisItem,null,null);
		completedOK := true;
		return response;
	endif;
	
	create wsTI transient;
	wsTI.setProxyFromObject(nextPreviousTI);
	response.myTrackedItem := wsTI;
	
	// Got to here, everything is ok
	completedOK := true;
	return response;
	
epilog
	// Tidy up any local transients
	delete agent;
	
	if not completedOK then
		cnSetTransactionError(true);
		delete response;				// prevent transient leaks
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;
	
end;</source>
        <Parameter name="request" type="WS_NextCargoItemQueryRequest"/>
        <ReturnType type="WS_NextCargoItemResponse"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="getCargoStops" id="5de25b2a-a627-4e24-b2cd-55d9ff1643d5">
        <source>getCargoStops(_cargoOid : String)  : WS_CargoStopsResponse webService;
/*

Date		Who		Reason
15 June 2016	cnwer1	Initial creation PAR

*/

vars
	completedOK : Boolean;
	response : WS_CargoStopsResponse;
	cargo : CM_TrackedItem;
	failedDAC : CM_DataAccessController;
	cmifStop 			: CMIF_CargoStop;
	cmif 				: CMIF_Object;
	allCMIFCargoStops 	: CMIF_Array;
	wsStop : WS_CargoStop;
begin
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);

	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		//return null;
	endif;
	
	// Initialise the passport for the new transaction
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	
	// Create the response
	create response transient;
	if _cargoOid = "" then
		completedOK := true;
		return response;
	endif;
	
	//epr TFS 5535 4/8/17 
	cargo :=app.myPassport.getObjectOfTypeFromOid( _cargoOid,CM_TrackedItem).CM_TrackedItem;	
	if cargo = null then
		completedOK := true;
		return response;
	endif;
	
	
	create allCMIFCargoStops transient;
	cargo.getAllStopsToSetAndClear(allCMIFCargoStops);
	foreach cmif in allCMIFCargoStops discreteLock do
		cmifStop:=cmif.CMIF_CargoStop;
		create wsStop transient;
		wsStop.setProxyFromObject(cmifStop);
		response.allCargoStops.add(wsStop);
	endforeach;
	// Got to here, everything is OK
	completedOK := true;
	return response ;
	

epilog
	if not completedOK then
		cnSetTransactionError(true);
		delete response;				// prevent transient leaks
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	
	if allCMIFCargoStops &lt;&gt; null then
		allCMIFCargoStops.purge;
	endif;
	delete allCMIFCargoStops;
	
	cnEndTransaction;


end;</source>
        <Parameter name="_cargoOid" type="String"/>
        <ReturnType type="WS_CargoStopsResponse"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="getCargoSubtypesForCargoType" id="c37ccdd0-9715-4d0e-99fc-54fd0e919085">
        <source>getCargoSubtypesForCargoType(cargoType : Integer) : WS_ProductResponse webService;

/*

Purpose:			Get the Cargo Subtypes for the passed in Cargo Type.

Parameters:			Selected CargoType oid

Return Value:		Response populated with matching Cargo Subtypes


Date		Who		Reason
18 Mar 2010	cnwdz2	PAR #23232 - Development of new RIA Web Service application

*/

vars
	obj				: Object;
	cargoTypeObj	: CM_CargoType;
	product			: CM_Product;
