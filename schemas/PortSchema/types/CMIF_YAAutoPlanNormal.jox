    <JadeMethod name="isImexStatus_ExportVoyAlloc" id="5094d451-3b13-4e87-bb93-35efe7d1cad7">
        <source>isImexStatus_ExportVoyAlloc(_yaData : CM_YADataObjects) : Boolean;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
22 February 2011	cnwer1	Initial creation

*/

vars
	yaParent : CM_YACriteria;
	obj 	 : Object;
	imexStatus 	 : CM_IMEXStatus;
	tiImexStatus 		: Integer;
begin
	if _yaData.myYAParent.isKindOf(CM_YACriteria) then
		yaParent := _yaData.myYAParent.CM_YACriteria;	
		
		if yaParent.myYACriteriaType.type &lt;&gt; YACriteriaType_ImexStatus then
			return false;
		endif;
		
		if yaParent.myYardAllocation &lt;&gt; null and 
			yaParent.myYardAllocation.isKindOf(CM_VoyageAllocation)then
			
			
			
			obj := _yaData.allObjects.first;
			if obj = null then
				return false;
			endif;
			
			imexStatus:=obj.CM_IMEXStatus ;
			tiImexStatus:=self.myTrackedItem.getReceivalIMEXStatus;
			if  imexStatus.code = TI_IMEX_STATUS_EXPORT then
				if tiImexStatus = imexStatus.code then
					return true;
				endif;
				
				
				
				if tiImexStatus = TI_IMEX_STATUS_TRANSHIP and not yaParent.myYardAllocation.CM_VoyageAllocation.myVoyage.haveVoyAllocTranship() then
					
					return true;
				endif;
			endif;
			
		endif;
	endif;
	
	return false;
epilog

end;</source>
        <Parameter name="_yaData" type="CM_YADataObjects"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isImexStatus_Match" id="2da9222b-5ff7-4c1b-9c4f-4355f4802c41">
        <source>isImexStatus_Match(_yaData: CM_YADataObjects): Boolean;
// -------------------------------------------
// Created 27 May 2005 by cnwdvb1
// -------------------------------------------
vars
	status		: Integer;
begin
	
	status := self.myTrackedItem.getReceivalIMEXStatus();
	// Only priorities will be empty.
	if (status &lt;&gt; null and _yaData.isEmpty()) then
		return true;
	endif;
	
	if self.includeDLRsSOBsImexCheckCase(_yaData) then //cnwas3 par 26773
		return true;
	endif;
	
	//if self.isImexStatus_ExportVoyAlloc(_yaData) then
	//	return true;
	//endif;
	
	return _yaData.visitObjectsUntilTrue(self, CMIF_YAAutoPlanNormal::isImexStatus_Compare, status);
end;</source>
        <Parameter name="_yaData" type="CM_YADataObjects"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isInstructionType_Compare" id="561affc8-a00a-4491-a70c-372bf217c9bd">
        <source>isInstructionType_Compare(instructionType: Object; code: String): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 Feb 2023 navhl20 ChangeRequest 61960: FR | 57937 - [TKT: 61898] - Kiosk - US.080 'c' - Coded Instructions Missing from Additional question Criteria 

*/

vars

begin
	return instructionType.CM_InstructionType.code = code;
epilog

end;</source>
