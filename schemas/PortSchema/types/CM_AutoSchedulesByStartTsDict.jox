<CollClass name="CM_AutoSchedulesByStartTsDict" id="15c10dd8-e8e1-4580-8faa-6b0100f52309">
    <duplicatesAllowed/>
    <memberType name="CM_AutoSchedule"/>
    <superclass name="MemberKeyDictionary"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="backgroundprocess"/>
    <MemberKey>
        <property name="CM_AutoSchedule::isActive"/>
    </MemberKey>
    <MemberKey>
        <property name="CM_AutoSchedule::runTs"/>
    </MemberKey>
    <JadeMethod name="getEventSchedulesOfType" id="aee983cf-caa4-4a48-8bdf-b06c2ac71680">
        <source>getEventSchedulesOfType(_type : Integer; _allEventSchedules : CM_AutoScheduleSet input);
// -------------------------------------------
// Created 30 June 2004 by cnwdvb1
// 05 Oct 2018	jlgrh7 TFS #41253 SNO - Voyage Schedule error changed _allEventSchedules reference type from dynDict to ObjectSet
// -------------------------------------------
vars

	schedule : CM_AutoSchedule;

begin

	_allEventSchedules.clear();
	foreach schedule in self where schedule.selectionState = State_Event and 
								   schedule.eventDataType = _type  and 
								   schedule.isActive =  CM_AutoSchedule.Schedule_Is_Active do
		_allEventSchedules.add(schedule);
	endforeach;


end;</source>
        <Parameter name="_type" type="Integer"/>
        <Parameter name="_allEventSchedules" type="CM_AutoScheduleSet" usage="input"/>
    </JadeMethod>
</CollClass>
