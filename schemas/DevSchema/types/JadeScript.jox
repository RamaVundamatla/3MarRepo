    <JadeMethod name="sdlCreateWSEventMapping" id="d5573e7e-2b86-4174-9fe5-57a29b22f729">
        <updating/>
        <source>sdlCreateWSEventMapping() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25 Feb 2019	jlgsl4	TFS 40360 - NXL - KiwiRail EDI message
*/

vars
	wsDef : CM_KiwiRailCheckInWSDef;
	eventType : CM_EventType;
	wsEventMapping : CM_ExtWebServiceEventMapping;
begin
	app.initialize();
	wsDef := CM_KiwiRailCheckInWSDef.firstInstance();
	foreach eventType in app.myRoot.allEventTypesByCategory do
		if eventType.name = "Train Departed" then
			break;
		endif;
	endforeach;
	beginTransaction;
	create wsEventMapping persistent;
	wsEventMapping.setEventType(eventType);
	wsDef.setMyEventMapping(wsEventMapping);
	commitTransaction;
	eventType := eventType;
epilog
	//delete wsEventMapping;
end;</source>
