    <JadeMethod name="getConfiguredApprovalExpiryTS" id="ed185a2e-1509-449c-befc-366993f0d5a5">
        <source>getConfiguredApprovalExpiryTS(_reqByDate : TimeStamp): TimeStamp;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04/04/2019	jlgndl1	Initial creation
23/04/2019	jlgdap1	TFS 43405 Correct Approval Expiry Date calculation and allow for Cargo Allocation tran maps
02/10/2019	jlgdap1	TFS 46823 Wrong Expiry Date Calculation - debtor-specific tran map not taken in to account
23 Oct 2024	navlw1	JIRA-33107: Invoice Logging Use Levels
*/

vars

	firstTi : CM_TrackedItem;
	dateToReturn : TimeStamp;
	storage : CM_Storage;
	tiTrx : CM_TITransaction;
	bank : CM_Bank;
	now : TimeStamp;
	later : TimeStamp;
	qrm : CM_QuantityRangeMap;
	increment : Integer;
	aSBController : CMIF_ServiceBroker;
	qm : CM_QuantityMap;
	broker : CM_ServiceBroker;			// TFS 46823
	debtor : CM_Debtor;					// TFS 46823
	debtorMap : CM_DebtorMap;			// TFS 46823

begin
	
	if not self.allAvailableTIs.isEmpty then
		firstTi := self.allAvailableTIs.first;
	endif;
	if firstTi = null then
		if not self.allActionedTIs.isEmpty then
			firstTi := self.allActionedTIs.first;
		endif;
	endif;
	if firstTi = null then
		if not self.allCompleteTIs.isEmpty then
			firstTi := self.allCompleteTIs.first;
		endif;
	endif;
	
	if firstTi = null then
		return null;
	endif;
	
	tiTrx := firstTi.findLastStorageRelevantTrans();
	if tiTrx = null then
		return null;
	endif;
	
	bank := firstTi.companyOid;
	now := app.actualTimeAppServer();
	later.setDate( now.date + 1 );
	later.setTime( now.time );
	
	create storage transient;
	//08 Apr 2019	NDL	TFS 43405
	storage.setForQrmEnquiry( 	firstTi,	//_ti : CM_TrackedItem;
								tiTrx,	//_startTrx : CM_TITransaction;
								later	//_dateTime : TimeStamp
								);
	
	//qrm := bank.getQuantityRangeForTransaction( storage );
	create aSBController transient;
	aSBController.myTransaction := storage;
	if bank.terminal.getConfig(InvUseInvoiceCargoAlloc).Boolean then
		aSBController.isInvoiceCargoAllocation := true;
		bank.getInvoiceLineDescForTIAlloc(aSBController);
		if aSBController.allInvoiceLineTypes.isEmpty() then // nothing for allocations so try transaction map
			app.invLog(method.qualifiedName &amp; " No cargo allocation map found, checking normal cargo map", LogINFO.String);
			aSBController.isInvoiceCargoAllocation := false;
			bank.getInvoiceLineDescForXaction(aSBController);
		endif;
	else
		bank.getInvoiceLineDescForXaction(aSBController);
	endif;
	
	if aSBController.myServiceBroker &lt;&gt; null then
		qm := aSBController.myServiceBroker.myChildQuantityMap;
		if qm &lt;&gt; null and not qm.allQuantityRanges.isEmpty then
			qrm := qm.allQuantityRanges.first;
		endif;
		
		// TFS 46823 check for debtor-specific range map
		broker := aSBController.myServiceBroker;
		debtor := broker.getDebtorForTransaction(aSBController).CM_Debtor;
		if debtor &lt;&gt; null then
			debtorMap := broker.allDebtorMapsByDebtor[debtor.name];
			if debtorMap &lt;&gt; null then
				qm := debtorMap.myChildQuantityMap;
				if qm &lt;&gt; null and not qm.allQuantityRanges.isEmpty then
					qrm := qm.allQuantityRanges.first;
				endif;
			endif;
		endif;
		// TFS 46823 end
	endif;
	
	if qrm = null then
		return null;
	endif;
	
	if qrm.rangeEnd &gt; 100 then	// arbitary limit for max value.
		increment := 100;
	else
		increment := qrm.rangeEnd.Integer;
	endif;
	
	// TFS 43405 Approval Expiry Time should always be 23:59			// TFS 43405
	// And Approval Expiry Date should include tiTrx date				// TFS 43405
	// And Approval Expiry Date should be Required By Date if Approval	// TFS 43405
	// Expiry Date goes past the first tier of the Storage map			// TFS 43405
	// (so in effect if there's a storage transaction, dateToReturn 	// TFS 43405
	// will be the required by date)									// TFS 43405
	//dateToReturn.setTime( tiTrx.dateTime.time );						// TFS 43405
	//dateToReturn.setDate( tiTrx.dateTime.date + increment );			// TFS 43405
	dateToReturn.setTime( "23:59:00".Time );							// TFS 43405
	dateToReturn.setDate( tiTrx.dateTime.date - 1 + increment );		// TFS 43405
	if tiTrx.type = TRANS_TYPE_STORAGE and _reqByDate.isValid then		// TFS 43405
		dateToReturn.setDate(_reqByDate.date);							// TFS 43405
	endif;																// TFS 43405
	
	return dateToReturn;

epilog

	delete storage;
	delete aSBController;	//22 May 2019	TFS 44774

end;</source>
        <Parameter name="_reqByDate" type="TimeStamp"/>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="getDisplayString" id="ab39eb12-38b3-43a8-8500-fedbaf081813">
        <source>getDisplayString(_useShortDesc: Boolean): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 October 2021		navma1	Initial creation

*/

vars
	displayString 	: String;
	desc			: String;
	woTaskType	 	: CM_WorkOrderDetailType;
begin
	
	desc := app.myRoot.getWorkOrderTaskDescByType(WorkOrderMode_Cargo,self.detailType);
	
	if desc = null then
		return null;
		
	endif;
	if _useShortDesc then
		displayString :=  desc;
	else
		displayString := "(" &amp; self.taskID.String &amp; ") " &amp; desc;
		
	endif;
	
	return displayString;
epilog

end;</source>
        <Parameter name="_useShortDesc" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="0af8416f-53af-4a28-9c59-e1ab0ca781fe">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 Feb 2023 navma1 ChangeRequest 56457:[56458] EUP - Allowing different sets of cargo items per work order task [Refactor]
29 Mar 2023 navhl20 ChangeRequest 55443:[54991] EUP - Receive Cargo Work Order - Enhancements
*/

vars

begin
	
	if _attrName = ETRow_Required then
		return self.myParent.CM_WorkOrderTI.allTIs.size.String;
	elseif _attrName = ETRow_Complete then
		return self.getTotalComplete.asStringJMT();
	elseif _attrName = ETRow_Actioned then
		return self.getTotalActioned().asStringJMT();
	elseif _attrName = ETRow_RemToAction then
		return self.getNumberRemainingToAction().asStringJMT();							//08.02.2023 navma1 #56457:[56458]
	elseif _attrName = ETRow_RemToComplete then
		//return self.getNumberRemainingToComplete().asStringJMT();						//08.02.2023 navma1 #56457:[56458]
		return (self.allSelectedTIs.size - self.allCompleteTIs.size).asStringJMT();		//08.02.2023 navma1 #56457:[56458]
	elseif _attrName = ETRow_Priority then												//29.3.2023 navhl20	#55443[54991]
		return self.getPriority();														//29.3.2023 navhl20	#55443[54991]
	endif;
	
	return inheritMethod(_attrName, _short);

epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getExtraInfo" id="71f80bcb-eb6d-4f7d-a72e-937497f5ae95">
        <source>getExtraInfo(_dataContainer: CM_DataContainer);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 Sep 2021 navma1  ChangeRequest 51925: SAL - Web Portal Cargo Work Orders
08 Feb 2023 navma1  ChangeRequest 56457: EUP - Allowing different sets of cargo items per work order task [Refactor]
15 Mar 2023 navhl20 ChangeRequest 56614:[56615] EUP - Allow Multi ToDo Tasks Description on Cargo ToDo Work Order
06 Jun 2023 navma1  ChangeRequest 58339: EUP | Delivery Dispatch Screen - Road Operation
03 Jul 2023 navma1  ChangeRequest 58849: EUP | Delivery Dispatch Screen - Unpack Operation
29 Sep 2023 navhl20 ChangeRequest 59638: EUP | Ship Operations in DD - [54176.010] - [Receive] Work Order Detail Grouping
21 May 2024 navhl20 ChangeRequest 64150: EUP - Work Order - Remedial
30 May 2024 navhl20 Bug 64101: EUP - For the Pack Job the parent and child details are empty on the Complete Job form 
*/

vars
	block    	  : CM_DataContainerBlock;
	wodToDo  	  : CM_WodToDo;
	addStr   	  : String;	
	trans 	 	  : CM_WOTransaction;
	job		 	  : CM_Job;
	transportMode : Integer;
begin
	inheritMethod(_dataContainer);
	
	block 	:= _dataContainer.addNewBlock;
	
	if app.isSpecial then														//08.02.2023 navma1 #56457:[56458]

		block.addNewItem('Required By DT', DC_Label, 1, self);					//06.06.2023 navma1 #58339
		block.addNewItem(self.requiredByDT.asStringJMT, DC_Data, 1, self);
		
		block.addNewItem('All Selected', DC_Label, 1, self);
		block.addNewItem(self.allSelectedTIs.size.String, DC_Data, 1, self);

		block.addNewItem('All Available', DC_Label, 1, self);
		block.addNewItem(self.allAvailableTIs.size.String, DC_Data, 1, self);

		block.addNewItem('All Actioned', DC_Label, 1, self);
		block.addNewItem(self.allActionedTIs.size.String, DC_Data, 1, self);
	
		block.addNewItem('All Completed', DC_Label, 1, self);
		block.addNewItem(self.allCompleteTIs.size.String, DC_Data, 1, self);

		block.addNewItem('All Jobs', DC_Label, 1, self);
		block.addNewItem(self.allJobs.size.String, DC_Data, 1, self);
		
		job := self.allJobs.first;													//03.07.2023 navma1 #58849
		if job &lt;&gt; null then
			block.addNewItem('Job Details', DC_Label, 1, self);
			block.addNewItem(job.id &amp; Space &amp; job.statusString, DC_Data, 1, job);
		endif;
		
		if self.allToDoRequests.isNotEmpty then
			wodToDo := self.allToDoRequests.first;
			wodToDo.getExtraInfo(_dataContainer);
		endif;
		
	endif;
	
	// temp solution navma1 01.05.2024 #64150
	/*
	//30.05.2024 navhl20 #64101
	transportMode := self.getTransport();
	if transportMode &lt;&gt; TI_TRANSMODE_SHIP then
		addStr := self.allSelectedTIs.listString(Comma,CM_TrackedItem::id.name);								//08.02.2023 navma1 #56457 Task#56458
		if addStr &lt;&gt; null then
			block := _dataContainer.addNewBlock;
			block.addNewItem(app.getErrorString(Cargo), DC_Label, 1,  self.allSelectedTIs.first);
			block.addNewItem(addStr.formatWithEllipsis(1,50,true), DC_Data, 1, self.allSelectedTIs.first);		//29.9.2023 navhl20 #59638
		endif;	
	endif;*/
	
	addStr := null;
	wodToDo := self.allToDoRequests.first;
	if wodToDo &lt;&gt; null then
		addStr := wodToDo.allToDoTasksDescs.listString(Comma,CM_ToDoTaskDesc::description.name);				//05.04.2023 navma1 #56614:[56615]
	endif;
	
	if addStr &lt;&gt; null then
		block := _dataContainer.addNewBlock;
		block.addNewItem(app.getErrorString(Todo_task), DC_Label, 1, null);
		block.addNewItem(addStr, DC_Data, 1, null);
	endif;	
epilog

end;</source>
        <Parameter name="_dataContainer" type="CM_DataContainer"/>
    </JadeMethod>
    <JadeMethod name="getFirstSelectedTi" id="f6518424-4f9b-4bff-8b55-b540ea8185ba">
        <source>getFirstSelectedTi(): CM_TrackedItem;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 Apr 2025	navhl20 Bug MTN-34502: EUP FR | 54014 - Error 4 (Object Not Found) when searching for work orders in WO Enquiry

*/

vars
	ti 		: CM_TrackedItem;
	invalid	: Boolean;
begin
	on Exception do app.handleDeletedObject(exception, ti, invalid);
	foreach ti in self.allSelectedTIs do
		invalid := false;
		ti.edition;
		
		if invalid then
			continue;
		endif;	
		
		return ti;
	endforeach;
	
	return null;
epilog

end;</source>
        <ReturnType type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="getFirstTI" id="3957f3d4-cff8-4deb-9905-141719bba7ad">
        <source>getFirstTI() : CM_TrackedItem;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26/11/2024	navkc1 JIRA Story MTN-19092: EUP | 54014 - Work Orders Enhancements - Improved Search and usability

*/

vars
	ti 		: CM_TrackedItem;
	invalid	: Boolean;
	edition	: Integer;
begin
	
	on Exception do app.handleDeletedObject(exception, ti, invalid);
	
	ti := self.allSelectedTIs.first();
	
	if ti &lt;&gt; null then
		ti.edition();
		
		if invalid then
			return null;
		endif;
	endif;
	return ti;
epilog

end;</source>
        <ReturnType type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="getInstructionsForContext" id="2b74038b-8133-49d8-9882-39812c7b29df">
        <source>getInstructionsForContext(_instructions: CM_InstructionsIssuedSet io; _passingObject: Object; _context: String);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 Oct 2023	navnk30	ChangeRequest 59946: EUP - Additional Operational Instructions on the Order - Enhancement 2
19 Oct 2023	navma1  Defect 60923: MTN - Exception when selecting the Job Type as Truck Load on the Work Order Operations app
08 Nov 2023	navnk30	ChangeRequest 60646: EUP | Mobile DD - [53891.060] - Special Instructions in the Mobile App

*/

vars
	dynaDict	: DynaDictionary;
	ti			: CM_TrackedItem;
	object		: Object;
	inst		: CM_InstructionsIssued;
begin
	inheritMethod(_instructions, _passingObject, _context);
	create dynaDict transient;
	dynaDict.setMembership(CM_TrackedItem);
	dynaDict.addMemberKey(CM_TrackedItem::myInstructions.name, true, true);
	dynaDict.endKeys(true);
	
	self.allSelectedTIs.copy(dynaDict);
	
	if _context = Unpack_Cargo then						//08.11.2023 navnk30 #60646
		//add child cargo item level instructions
		foreach ti in self.allSelectedTIs do
			ti.allChildren.copy(dynaDict);
		endforeach;
	endif;
	
	foreach object in dynaDict do
		ti := object.CM_TrackedItem;
		inst := ti.getInstructions;
		
		_instructions.tryAddIfNotNull(inst);
		
		if inst = null then
			break;
		endif;
		
		
	endforeach;
epilog
	delete dynaDict;
end;</source>
        <Parameter name="_instructions" type="CM_InstructionsIssuedSet" usage="io"/>
        <Parameter name="_passingObject" type="Object"/>
        <Parameter name="_context" type="String"/>
    </JadeMethod>
    <JadeMethod name="getMatchingWodWle" id="0475831b-c5ec-4109-a783-51f3ebccb428">
        <source>getMatchingWodWle(_job : CM_Job;_ti : CM_TrackedItem;_class : Class): CM_WorkListEntry;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 Apr 2023 navma1  ChangeRequest 55440:[54990] EUP - Release Cargo Work Order - Enhancement
28 May 2024 navma1	Bug 64224: MTN - DeadLocks Caused by Future Actors
*/

vars
	wle : CM_WorkListEntry;
begin
	foreach wle in _job.workListEntries discreteLock do //28.05.2024 navma1 #64224
		
		if not wle.isKindOf(_class) then
			continue;
		endif;
		if wle.myTrackedItem = _ti then	
			return wle;
		endif;
	
	endforeach;
	return null;
epilog

end;</source>
        <Parameter name="_job" type="CM_Job"/>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_class" type="Class"/>
        <ReturnType type="CM_WorkListEntry"/>
    </JadeMethod>
