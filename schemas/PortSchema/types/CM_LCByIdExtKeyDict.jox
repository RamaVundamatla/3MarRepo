<CollClass name="CM_LCByIdExtKeyDict" id="9a8bc737-ccd1-4e28-a843-2d2d1edd24ef">
    <duplicatesAllowed/>
    <memberType name="CM_LocationsController"/>
    <superclass name="CM_ExtKeyDictionary"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="terminal"/>
    <ExternalKey name="ident">
        <length>31</length>
        <type name="String"/>
    </ExternalKey>
    <JadeMethod name="add" id="2f9749a1-6c33-4ee6-9991-69172452d7ec">
        <lockReceiver/>
        <updating/>
        <source>add(value: MemberType) updating, lockReceiver;
// ---------------------------------------------------------------------------
// Created:     08 October 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	keyStr	: String;
begin

	keyStr := self.getKey(value);
	self.putAtKey(keyStr, value);

end;</source>
        <Parameter name="value" type="MemberType"/>
    </JadeMethod>
    <JadeMethod name="getKey" id="8eac8f59-74fd-428d-af11-b0b87d77b979">
        <source>getKey(value : MemberType) : String protected;

vars
	keyStr	: String;
begin

	keyStr := value.ident;
	if keyStr = null then
		keyStr := value.getID();
	endif;
	
	return keyStr;
end;</source>
        <access>protected</access>
        <Parameter name="value" type="MemberType"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="includes" id="854b67d9-df83-4243-8c13-6ae3155f0c5f">
        <source>includes(value: MemberType): Boolean;
// ---------------------------------------------------------------------------
// Created:     16 October 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	keyStr,
	tmpStr	: String;
	obj		: Object;
	iter	: Iterator;
begin

	if value = null then
		return false;
	endif;

	keyStr := self.getKey(value);
	
	if keyStr = null then
		return false;
	endif;
	
	iter := self.createIterator;
	self.startKeyGeq(keyStr, iter);

	// as this dict allows dups need to do the following
	
	while iter.next(obj) do
		self.getIteratorKeys(tmpStr, iter);
		if tmpStr &lt;&gt; keyStr then
			return false;
		endif;
		if obj = value then
			return true;
		endif;
	endwhile;
	
	return false;

//	return self.includesKey(keyStr);

epilog
	delete iter;	
end;</source>
        <Parameter name="value" type="MemberType"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="includesObject" id="545d0649-e196-465e-89c8-054c5d909f13">
        <source>includesObject(value: MemberType): Boolean;
// ---------------------------------------------------------------------------
// Created:     16 October 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	keyStr,
	tmpStr	: String;
	obj		: Object;
	iter	: Iterator;
begin

	if value = null then
		return false;
	endif;

	iter := self.createIterator;
	
	while iter.next(obj) do
		if obj = value then
			return true;
		endif;
	endwhile;
	
	return false;

epilog
	delete iter;	
end;</source>
        <Parameter name="value" type="MemberType"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="remove" id="a63524a2-ce72-49ac-8c65-b05eb5b0a9b8">
        <lockReceiver/>
        <updating/>
        <source>remove(value: MemberType) updating, lockReceiver;

vars
	keyStr	: String;
begin

	keyStr := self.getKey(value);
	self.removeKeyEntry(keyStr, value);
end;</source>
        <Parameter name="value" type="MemberType"/>
    </JadeMethod>
</CollClass>
