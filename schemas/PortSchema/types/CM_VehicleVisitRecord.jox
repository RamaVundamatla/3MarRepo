    <JadeMethod name="getGateInToGateOutTime" id="bc9e983f-6ea3-47ae-a576-83097aae5ce0">
        <source>getGateInToGateOutTime() : Integer;
// ---------------------------------------------------------------------------
// Created:     15 April 2008 by cnwrs2
//
// Purpose:     Returns the number of mins between the in gate and
//				the truck leaving the terminal.
// ---------------------------------------------------------------------------
vars
	inGateTS,
	outGateTS	: TimeStamp;
begin

	inGateTS := self.getArrivalAtGateInTime();
	outGateTS := self.getArrivalAtGateOutTime();
	
	if inGateTS.isValid and outGateTS.isValid then
		return inGateTS.truncateToMinute.getDifferenceInMinutes(outGateTS.truncateToMinute);
	endif;
	
	return 0;
end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getGateOut" id="fb8e6dbe-69ea-40d1-8ea1-770e680cf86d">
        <source>getGateOut() : CM_Gate;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 May 2023	jlier1	Initial creation 57936

*/

vars
	vvrd : 		CM_VehicleVisitRecordDetail;
	gateObj : CM_Gate;
	extraInfo : CM_Object;
begin
	vvrd:=self.getLastGateOutVVRD;
	if vvrd = null then
		return self.getGateIn;
	endif;
	
	extraInfo:=vvrd.getExtraInfoObject;
	if extraInfo = null then
		return self.getGateIn;
	endif;
	if extraInfo.isKindOf(CM_LaneController) then
		gateObj:=extraInfo.CM_LaneController.getGate;
		if gateObj &lt;&gt; null then
			return gateObj;
		endif;	
	endif;
	
	return self.getGateIn;

epilog

end;</source>
        <ReturnType type="CM_Gate"/>
    </JadeMethod>
    <JadeMethod name="getGateOutName" id="fbff91a5-2318-4b33-963a-931c4d37da36">
        <source>getGateOutName() : String;
/*

Purpose:		If exits a different gate then get that one. 	

Parameters:			

Return Value:		

Date		Who		Reason
17 May 2023	jlier1	Initial creation 57936

*/

vars

	gateObj : CM_Gate;
begin
	gateObj:=self.getGateOut;
	if gateObj &lt;&gt; null then
		return gateObj.name;
	endif;	
	return self.getGateInName;
	
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getGateOutVVRDetail" id="a3449c8f-38c6-4518-b916-1a7f28879e24">
        <source>getGateOutVVRDetail():CM_VehicleVisitRecordDetail;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 November 2015	cnwndl1	Initial creation	Par 36886

*/

vars

	detail	: CM_VehicleVisitRecordDetail;
	
begin

	foreach detail in self.allVehicleVisitRecordDetails do
		if detail.recordType = VisitRecord_Complete_OutGate then
			return detail;
