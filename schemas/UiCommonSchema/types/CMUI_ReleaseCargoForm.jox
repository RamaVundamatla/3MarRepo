        <source>btnCargoAvailCheck_click(btn: Button input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 Mar 2019	jlgdi1	TFS# 41721 Initial creation

*/

vars
	dynaDict : DynaDictionary;
	originalColl : Collection;	
	trackedItems : CM_TISet;
	roadGateCargoCheckForm : CMUI_RoadGateCargoCheck;
	
begin
	create dynaDict transient;
	create trackedItems transient;
	
	createCargoCollection(dynaDict);
	originalColl := checkCargoAvailability(trackedItems);	
	consolidateCargo(originalColl, dynaDict);
	
	create roadGateCargoCheckForm transient;
	roadGateCargoCheckForm.myCollection := dynaDict;
	roadGateCargoCheckForm.myParentForm := self;	//21 Oct 2019	NDL	TFS 46911
	roadGateCargoCheckForm.myTerminal := self.myTerminal;	//21 Oct 2019	NDL	TFS 46911
	roadGateCargoCheckForm.showModal();
	
epilog
	delete trackedItems;
	delete dynaDict;
	delete roadGateCargoCheckForm;
end;</source>
