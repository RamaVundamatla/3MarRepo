<Class name="CM_RemoteJobQueryHdr" id="62ad8799-7299-4a12-9c17-a2638ebb4e68">
    <superclass name="CM_RemoteDataHdr"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>&lt;display&gt;Job Query&lt;/display&gt;</text>
    <DbClassMap file="remoteDataProcessing"/>
    <CompAttribute name="allJobs" id="802c5b55-daf7-430b-89ea-4cc14e49f4bd">
        <type name="StringArray"/>
        <access>readonly</access>
    </CompAttribute>
    <JadeMethod name="buildQueueResponse" id="539de9fe-9003-4404-a21c-aa54fc162422">
        <source>buildQueueResponse(_set : ObjectSet) : String protected;
// 29/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
vars

	cmif		: CMIF_RTQueueGrouping;
	queueEntry	: CM_RTQueueEntry;
	iter		: Iterator;
	response	: String;

begin

	iter := _set.createIterator;
	while iter.next(cmif) do
		response := response &amp; '&lt;' &amp; XML_JOBDTL &amp; ' class="' &amp; cmif.queueType.toUpper &amp; '" type=' &amp; 
		CM_RemoteDataObject.Type_Full &amp; '&gt;' &amp; CrLf;
		foreach queueEntry in cmif.allRTQueueEntries do

			response := response &amp; self.formatAsXML(XML_JOB, queueEntry.getDetailForRemoteQuery(Type_Full));
		endforeach;
		response := response &amp; self.formatAsXMLSuffix(XML_JOBDTL);
	endwhile;
	return response;	
epilog
	delete iter;
end;</source>
        <access>protected</access>
        <Parameter name="_set" type="ObjectSet"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getJobQueryResponse" id="26109276-fa7d-422a-84bb-833ad5974d66">
        <source>getJobQueryResponse(_error : Integer output; _errorTxt : String output) : String protected;

vars

	queueEntry	: CM_RTQueueEntry;
	oid,
	errStr		: String;
	set			: ObjectSet;
	response	: String;

begin

	create set transient;
	foreach oid in self.allJobs do
		queueEntry := oid.asOid.CM_RTQueueEntry;
		if queueEntry = null then
			errStr := errStr &amp; ', ' &amp; oid;
		else
			sortQueueEntriesByType(queueEntry, set);	
		endif;
	endforeach;	

	response := self.formatAsXMLPrefix(XML_BDY) &amp; self.formatAsXMLPrefix(XML_JOBLST) &amp; buildQueueResponse(set) &amp;
				self.formatAsXMLSuffix(XML_JOBLST) &amp; self.formatAsXMLSuffix(XML_BDY);		
				
	if errStr.length &gt; 2 then
		_error := Err_QueueEntryNotFound;
		_errorTxt := app.getErrorString1(Err_QueueEntryNotFound, null) &amp; ' ' &amp; errStr[3 : end];
	endif;

	return response;

epilog

	set.purge;
	delete set;
end;</source>
        <access>protected</access>
        <Parameter name="_error" type="Integer" usage="output"/>
        <Parameter name="_errorTxt" type="String" usage="output"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getMessageResponseType" id="35abbf59-6121-4154-9fd9-848f68111916">
        <source>getMessageResponseType(): String;

vars

begin
	return CM_RemoteDataManager.JOBQRYRSP;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="processExternal" id="ad8b3154-71c0-4304-af6d-2cbe21a26fb0">
        <updating/>
        <source>processExternal(_parseAgent: CM_RemoteParseAgent io): String updating;

vars

	err			: Integer;
	errTxt		: String;
	response	: String;
	headerCast	: CM_RemoteDataHdr;

begin

	response := inheritMethod(_parseAgent);
	if response = null then
		if _parseAgent.createJobQueryDetail(self) then
			response := self.getJobQueryResponse(err, errTxt);
			return self.doBuildMessage(self.xmlResponse(err, errTxt) &amp; response);
		endif;
		response := app.getErrorString1(Err_XML, 'Job query');
		return self.doBuildMessage(self.xmlResponse(Err_XML , response));
	endif;
	headerCast := self;
	return self.doBuildMessage(self.xmlDefaultResponse(headerCast, Err_XML , response));
			
end;</source>
        <Parameter name="_parseAgent" type="CM_RemoteParseAgent" usage="io"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="setProxyForJobQueryHdr" id="8b6f26e9-5186-4c2a-8e0b-88c711f048af">
        <updating/>
        <source>setProxyForJobQueryHdr(_allJobs	: HugeStringArray) updating;

vars

begin

	self.raiseExceptionIfNotTransient(method);
	_allJobs.copy(self.allJobs);

end;</source>
        <Parameter name="_allJobs" type="HugeStringArray"/>
    </JadeMethod>
    <JadeMethod name="sortQueueEntriesByType" id="7432ebd7-1820-4ff9-913c-43e97b0609fa">
        <source>sortQueueEntriesByType(_queueEntry : CM_RTQueueEntry; _set : ObjectSet input) protected;

vars

	cmif	: CMIF_RTQueueGrouping;
	iter	: Iterator;
	type	: String;

begin

	type := _queueEntry.myJob.getXMLType;
	iter := _set.createIterator;
	while iter.next(cmif) do
		if cmif.queueType = type then
			break;
		endif;
		cmif := null;
	endwhile;
	if cmif= null then
		create cmif transient;
		cmif.queueType := type;
		_set.add(cmif);
	endif;
	cmif.allRTQueueEntries.add(_queueEntry);
	
epilog
	delete iter;
end;</source>
        <access>protected</access>
        <Parameter name="_queueEntry" type="CM_RTQueueEntry"/>
        <Parameter name="_set" type="ObjectSet" usage="input"/>
    </JadeMethod>
</Class>
