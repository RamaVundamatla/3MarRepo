    <JadeMethod name="addRowToTable" id="92e3299f-9d37-44e4-9805-949d1b83ebc2">
        <updating/>
        <source>addRowToTable(_str : String; _addToTop : Boolean) : Integer updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
20 September 2019	jlgmd1	Initial creation
13 January 2020		jlgmd1	TFS 48201 JMT - Make it obvious what the web service call made was

*/

constants
	WS_CALL_MAGIC	: String = 'xmlns="urn:JadeWebServices/JMTWebService/"&gt;';
vars
	assoc			: CM_Association;
	sanitisedStr	: String;
	idx				: Integer;
	pos				: Integer;
begin
	if self.myForm = null then
		return null;
	endif;
	
	create assoc transient;
	assoc.setValue(_str);
	
	if self.searchType = self.SearchType_Ping and self.processType = self.SupProc_Web then
		pos := _str.pos(WS_CALL_MAGIC, 1);
		if pos &gt; 0 then
			pos := _str.reversePosIndex("&lt;", pos) + 1;	// This will hide an issue when pos = 0
			self.webServiceCall := _str.scanUntil(" ", pos);
		endif;
	endif;
	
	sanitisedStr := _str.replace(CrLf, " ");
	if _addToTop then
		idx := 1;
		self.myForm.tblResults.addItemAt(sanitisedStr, idx);
	else
		idx := self.myForm.tblResults.addItem(sanitisedStr);
	endif;
	self.myForm.tblResults.accessRow(idx).itemObject := assoc;
	
	return idx;
epilog

end;</source>
        <Parameter name="_str" type="String"/>
        <Parameter name="_addToTop" type="Boolean"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="addRowToTableColour" id="e079a740-adcc-46f0-99bc-8cea3781edd5">
        <updating/>
        <source>addRowToTableColour(_str : String; _addToTop : Boolean; _colour : Integer) updating;
/*

Purpose:			Adds a new row with the specified colour

Parameters:			

Return Value:		

Date				Who		Reason
10 January 2020		jlgmd1	Initial creation TFS 48181

*/

vars
	idx				: Integer;
	row				: JadeTableRow;
begin
	idx := self.addRowToTable(_str, _addToTop);
	
	if idx = null then
		return;
	endif;
	
	row := self.myForm.tblResults.accessRow(idx);
	
	if _colour &lt;&gt; null then
		row.backColor := _colour;
	else
		row.backColor := White;
	endif;
	
epilog

end;</source>
        <Parameter name="_str" type="String"/>
        <Parameter name="_addToTop" type="Boolean"/>
        <Parameter name="_colour" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="clearTableRows" id="1713aff9-4300-4f70-a1d5-b7017d9c931a">
        <source>clearTableRows();
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
20 September 2019	jlgmd1	Initial creation
10 January 2020		jlgmd1	Used the same clear method as the form

*/

vars

begin
	if self.myForm = null then
		return;
	endif;
	
	self.myForm.clearTblResults();
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="create" id="019f0853-30a1-4b2e-97cb-7f6266db43e8">
        <updating/>
        <source>create() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
09 January 2020		jlgmd1	Initial creation TFS 48181

*/

vars

begin
	// A list of known strings to delimit groups of log messages
	// These should be ordered by the chances of each string being encountered first
	create self.magicStartStrings transient;
	create self.magicEndStrings transient;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="delete" id="aa9dac03-816d-4a4a-8bc7-89b053642d30">
        <updating/>
        <source>delete() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
09 January 2020		jlgmd1	Initial creation TFS 48181

*/

vars

begin

	delete self.magicStartStrings;
	delete self.magicEndStrings;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doSearch" id="408e7f21-45d6-42e0-8003-665c5c022ed1">
        <updating/>
        <source>doSearch() : Boolean updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
07 January 2020		jlgmd1	Initial creation TFS 48181 - refactored from doSearchPing to allow multiple search types
13 January 2020		jlgmd1	TFS 48201 JMT - Make it obvious what the web service call made was

*/

vars
	prof				: JadeProfiler;
begin
	if self.logsLocation = null or self.envName = null then
		self.updateStatusText("Error - logs location or environment name is null", true);
		return false;
	endif;
	
	if self.processName = null then
		self.updateStatusText("Error - process name is null or invalid", true);
		return false;
	endif;
	
	if not self.isSupportedProc() then
		self.updateStatusText("Error - Process [" &amp; self.processName &amp; "] is not supported for this search", true);
		return false;
	endif;
	
	// Populate our 'magic' start strings
	self.populateMagicStings();
	
	// Set up the profiler
	/*prof := process.profiler;
	prof.methodCount := 200;
	prof.fileName := class.name &amp; "_" &amp; method.name &amp; "_" &amp; app.actualTime.fileNameFormat;
	prof.start;*/
	
	// Clear any previous values
	self.webServiceCall := null;
	
	// JSM Pings
	if self.searchType = self.SearchType_Ping then
		return self.doSearchPing();
	endif;
	
	// Process Activity for a given timestamp
	if self.searchType = self.SearchType_Activity then
		return self.doSearchActivity();
	endif;
	
	return false;
epilog
	if prof &lt;&gt; null then
		//prof.report;
	endif;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doSearchActivity" id="ee7de693-cf38-48bd-8480-60d9db2b5626">
        <updating/>
        <source>doSearchActivity() : Boolean updating, protected;
/*

Purpose:			Find what a given processType was doing at the specified time.
					This is so we can work out what the web services were doing at the time they cause 100% CPU usage,
					But we don't know which process(s) were causing it.

Parameters:			

Return Value:		

Date				Who		Reason
07 January 2020		jlgmd1	Initial creation TFS 48181

*/
constants
	TimeDiffHrs			: Integer = 1;
	DTLogLen			: Integer = 19;	// Its actually 23, but for this prupose we're ignoring the milliseconds
	RET_IGNORE			: Integer = 2;
vars
	completedOk		: Boolean;
	point,
	sTime,
	eTime			: TimeStamp;
	folder			: FileFolder;
	iter			: Iterator;
	file			: FileNode;
	str				: String;
	searchProc		: String;
	procId			: Integer;
	idx				: Integer;
	proc,
	procCopy		: JadeDynamicObject;
	foundProcs		: JadeDynamicObjectArray;
	linesToFind		: Integer;
	fwResults,
	rvResults		: CM_AssociationDict;
	assoc			: CM_Association;
	tmpStr			: String;
	fwSearchRes		: Integer;
	black			: Boolean;
	bgColour		: Integer;
begin
	// This might be a little difficult to actually work out, but what we want to be doing is...
	// 1. Work out how many processes of our type were running at the time
	// 2. Start with getting the first line before and after the specified time for each process
	// 3. Then use that to determine if the process was busy or not
	
	// We can actually time box this a little bit so we're not seaching through ALL the logs
	// How about we start with an hour each side of the given time... that *should* be more than enough
	// To see all the running processes during that time period
	// (although some of the longer web services calls might exceed this)
	
	if self.startTime = null or not self.startTime.isValid or self.startDate = null or not self.startDate.isValid then
		self.updateStatusText("Error - start date/time not set", true);
		return false;
	endif;
	
	// Work out our timebox
	point.setTime(self.startTime);
	point.setDate(self.startDate);
	eTime := point.addHours(TimeDiffHrs);
	sTime := point.addHours(-TimeDiffHrs);
	
	app.writeStatement("Logs Location: 	" &amp; self.logsLocation);
	app.writeStatement("Environment: 	" &amp; self.envName);
	app.writeStatement("Process Name:	" &amp; self.processName);
	app.writeStatement("Start Time:		" &amp; sTime.formatAsYYYYMMDDHHMMSSMMM);
	app.writeStatement("End Time:		" &amp; eTime.formatAsYYYYMMDDHHMMSSMMM);
	
	create folder transient;
	folder.mask := "cn_" &amp; envName &amp; "*.log";
	folder.fileName := self.logsLocation;
	folder.usePresentationFileSystem := true;
	iter := folder.files.createIterator();
	
	create foundProcs transient;
	create proc transient;
	proc.addProperty("processId", Integer);
	proc.addProperty("firstLine", String);
	proc.addProperty("lastLine", String);
	
	searchProc := ":" &amp; self.processName;
	
	// Start by doing a quick read of each line and keeping track of all the processes we're interested in
	while iter.next(file) do : outerLoop
		if file.cnEcIsFolder then continue; endif;
		if file.lastModifiedTime &lt; sTime then continue; endif;
		if file.lastModifiedTime &gt; eTime then break; endif;
		
		self.updateStatusText("Searching for running " &amp; self.processName &amp; "... found [" &amp; linesToFind.String &amp; "]" , false);
		file.File.seek(0);	// make sure we start at the beginning
		str := file.File.readString(file.File.fileLength);
		
		idx := str.pos(searchProc, 1);
		while idx &gt; 0 do
			tmpStr := str.scanUntil("/", idx);
			
			// Make sure our process matches as closely as possible
			// So we don't get JMTWebServiceSupport/42 when we're only interested in JMTWebService/41
			// While, still supported named processes (eg, BGP_GenericController#CAMS/29)
			if tmpStr.length &gt; searchProc.length and tmpStr[searchProc.length:1] &lt;&gt; "#" then
				idx := str.pos(searchProc, idx);
				continue;	// not our process, skip
			endif;
			
			idx := idx + 1;
			procId := str.scanUntil(":", idx).Integer;
			
			if foundProcs.size &lt; procId or foundProcs[procId] = null then
				procCopy := proc.copySelf(true);
				procCopy.setPropertyValue("processId", procId);
				foundProcs.atPut(procId, procCopy);
				linesToFind := linesToFind + 1;
			endif;
			
			idx := str.pos(searchProc, idx);
			// continue until we reach the end of the current log
		endwhile;
	endwhile;
	
	// Now we know what we're looking for, do a forward search to find the 'first' entry after our given time
	// (Which is actually the 'last' line we're interested in)	
	create fwResults transient;
	create rvResults transient;
	
	foreach proc in foundProcs where proc &lt;&gt; null do
		// Start fresh
		fwResults.purge();
		rvResults.purge();
		delete iter;
		
		iter := folder.files.createIterator();
		searchProc := self.processName &amp; "/" &amp; proc.getPropertyValue("processId").String;
		
		fwSearchRes := self.forwardSearch(iter, point, searchProc, self.magicStartStrings, self.magicEndStrings, fwResults);
		if fwSearchRes &lt;&gt; RET_IGNORE then
			self.reverseSearch(iter, point, searchProc, self.magicStartStrings, self.magicEndStrings, rvResults);
		
			if black then
				bgColour := LightGray;
			else
				bgColour := White;
			endif;
			black := not black;
			
			self.addRowToTableColour(searchProc, false, bgColour);
			
			// Remember, the reverse search results will be 'backwards'
			foreach assoc in rvResults reversed do
				self.addRowToTableColour(assoc.asString, false, bgColour);
			endforeach;
			
			foreach assoc in fwResults do
				self.addRowToTableColour(assoc.asString, false, bgColour);
			endforeach;
		endif;
	endforeach;
	
	self.updateStatusText("Done", false);
	
	completedOk := true;
epilog
	delete proc;
	delete procCopy;
	if foundProcs &lt;&gt; null then
		foundProcs.purge();
		delete foundProcs;
	endif;
	delete fwResults;	// calls purge
	delete rvResults;	// calls purge
	
	return completedOk;
end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doSearchPing" id="ab1d0fdd-6ae0-4983-99d5-ed3b24c8fcf1">
        <updating/>
        <source>doSearchPing() : Boolean updating, protected;
/*

Purpose:			Work out what a specific process was doing for a given timestamp

Parameters:			

Return Value:		

Date				Who		Reason
19 September 2019	jlgmd1	Initial creation
13 December 2019	jlgzm1	TFS 47162 JSM Ping Alerts - report controller
09 January 2019		jlgmd1	TFS 48181 Refactor to allow searching for generic process type 'activity'
13 January 2020		jlgmd1	TFS 48201 JMT - Make it obvious what the web service call made was

*/

constants
	RET_FOUND		: Integer = 1;
vars
	pingTime		: TimeStamp;
	folder			: FileFolder;
	file			: FileNode;
	iter			: Iterator;
	magicStr		: String;
	fwdRes,
	revRes			: CM_AssociationDict;
	assoc			: CM_Association;
	fwSearchRes 	: Integer;
	doneStr			: String;
begin
	
	if self.startTime = null or not self.startTime.isValid or self.startDate = null or not self.startDate.isValid then
		self.updateStatusText("Error - start date/time not set", true);
		return false;
	endif;
	
	pingTime.setTime(self.startTime);
	pingTime.setDate(self.startDate);
	
	app.writeStatement("Logs Location: 	" &amp; self.logsLocation);
	app.writeStatement("Environment: 	" &amp; self.envName);
	app.writeStatement("Process Name:	" &amp; self.processName);
	app.writeStatement("Ping Time:	" &amp; pingTime.formatAsYYYYMMDDHHMMSSMMM);
	
	
	self.addRowToTable("******** PING REQUEST HERE (ish) ********", false);
	
	create folder transient;
	folder.mask := self.getLogMask();
	folder.fileName := self.logsLocation;
	folder.usePresentationFileSystem := true;
	iter := folder.files.createIterator();
	
	self.updateStatusText("Starting forward search...", false);
	create fwdRes transient;
	fwSearchRes := self.forwardSearch(iter, pingTime, self.processName, self.magicStartStrings, self.magicEndStrings, fwdRes);
	
	// TFS 48201 jlgmd1 13/01/2020
	// This error really only indicates that we can't find the 'end' of the web message we're looking for.
	// Meaning when the end is after midnight, this incorrectly returns.
	// Disabling for now, until I think of a better way (if any) to indicate to the user their search is wrong
	/*if fwSearchRes &lt;&gt; RET_FOUND then
		self.clearTableRows();
		self.updateStatusText("Error, unable to find web message for " &amp; self.processName &amp; "@" &amp; pingTime.String, true);
		return false;
	endif;*/
	
	// Then find the first mention of it before the current log
	self.updateStatusText("Starting reverse search...", false);
	create revRes transient;
	self.reverseSearch(iter, pingTime, self.processName, self.magicStartStrings, self.magicEndStrings, revRes);
	
	foreach assoc in fwdRes do
		self.addRowToTable(assoc.asString, assoc.asBoolean);
	endforeach;
	foreach assoc in revRes do
		self.addRowToTable(assoc.asString, assoc.asBoolean);
	endforeach;
	
	if fwdRes.size = 0 and revRes.size = 0 then
		doneStr := "Error: [" &amp; self.processName &amp; "] not found in logs";
	else
		doneStr := "Done";
	endif;
	
	if self.webServiceCall &lt;&gt; null then
		doneStr := doneStr &amp; " [" &amp; self.webServiceCall &amp; "]";
	endif;
	self.updateStatusText(doneStr, false);
	
	return true;
epilog
	delete folder;
	delete iter;
	delete fwdRes;	// calls purge
	delete revRes;	// calls purge
end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="forwardSearch" id="6c96552e-30c2-4606-b11e-c31ac7352374">
        <source>forwardSearch(_fileIter : Iterator io; _pointInTime : TimeStamp; _needle : String; _startIdents, _endIdents : HugeStringArray; _results : CM_AssociationDict ) : Integer protected;
/*

Purpose:			

Parameters:			_fileIter		An iterator pointing to a collection of log files to go through
					_pointInTime	The point in time to start caring about matching log lines
					_needle			The Process name to search for
					_startIdents	A list of 'magic' strings that identifies the start of a new gorup of log lines for a given process
					_results		The Association dictionary to add our table lines to. String is used for the log line, 
									Boolean is used to identify whether it should be added to the top of the table or not

Return Value:		

Date				Who		Reason
08 January 2020		jlgmd1	Initial creation TFS 48181 Refactor from doSearchPing

*/

constants
	//APP_START_MAGIC		: String = "-----------------  Application Start Up ---------------------------";
	RET_NOT_FOUND		: Integer = 0;
	RET_FOUND			: Integer = 1;
	RET_IGNORE			: Integer = 2;
vars
	file		: FileNode;
	str,
	dateStr,
	curLine,
	tmpStr		: String;
	idx			: Integer;
	badDate		: Boolean;
	tblLine		: CM_Association;
	key			: String;
	keyChar		: Character;
	magicStr	: String;
	retVal		: Integer;
	lineDT		: TimeStamp;
begin
	keyChar := "a".Character;	// I'm sure there is a better way to do this ;)
	retVal := RET_NOT_FOUND;

	// Start by finding the first log file modified after the timestamp
	while _fileIter.next(file) do :forwardFind
		if file.cnEcIsFolder then continue; endif;
		if file.lastModifiedTime &lt; _pointInTime then continue; endif;
		
		self.updateStatusText("Performing forward search [" &amp; _needle &amp; "] ... " &amp; file.name, false);
		file.File.seek(0);	// make sure we start at the beginning
		str := file.File.readString(file.File.fileLength);
		
		idx := str.pos(_needle, 1);
		while idx &gt; 0 do
			// Found!
			idx := str.reversePosIndex(CrLf, idx);								// go to the beginning of the line
			if idx = 0 then idx := 1; endif;									// reversPosIndex returns 0 when it hits the beginning of the file
			str.scanWhile(CrLf, idx);
			
			// The 'end of the line' might actually be split across multiple lines
			// So keep reading until the next date segment
			badDate := false;
			dateStr := str.scanUntil(" ", idx);
			if dateStr.length &lt; 10 then
				badDate := true;
			endif;
			
			curLine := null;
			tmpStr := str.scanUntil(CrLf, idx);									// and grab all text until the end
			
			if badDate then
				curLine := dateStr &amp; tmpStr;
			else
				while tmpStr.pos(dateStr, 1) &lt;&gt; 1 and idx &gt; 0 do
					if curLine = null then
						curLine := dateStr &amp; tmpStr;
					else
						curLine := curLine &amp; CrLf &amp; tmpStr;
					endif;
					
					str.scanWhile(CrLf, idx);
					if idx &gt; 0 then
						tmpStr := str.scanUntil(CrLf, idx);
					endif;
				endwhile;
				if idx &gt; 0 then
					idx := str.reversePosIndex(CrLf, idx);
				endif;
			endif;
			
			// Need to handle, so look for 2nd ' ' character
			// 03/09/2020 12:25:34.150
			// 03-09-20 12:25:34.150
			// 2021/01/28 23:55:56.463: 
			dateStr := curLine[1:curLine.pos(" ", 12)].trimRight();
			if dateStr[dateStr.length:1] = ":" then
				dateStr := dateStr[1:dateStr.length-1];
			endif;
			
			lineDT := dateStr.TimeStamp;
			if not lineDT.isValid or lineDT &lt; _pointInTime then
				curLine := null;
			endif;
			
			if curLine &lt;&gt; null then
				foreach magicStr in _startIdents do
					if curLine.pos(magicStr, 1) &gt; 0 then
						/*if magicStr = APP_START_MAGIC then
							retVal := RET_IGNORE;
						endif;*/
						break forwardFind;												// We've found the next start message, so we can stop looping now
					endif;
				endforeach;				
			
				retVal := RET_FOUND;
				//self.addRowToTable(curLine, false);
				create tblLine transient;
				tblLine.set2Values(curLine, false);
				key := key &amp; keyChar;
				if key.length &gt;= 255 then
					keyChar := (keyChar.Integer + 1).Character;
					key := keyChar;
				endif;
				_results[key] := tblLine;
				tblLine := null;
				
				foreach magicStr in _endIdents do
					if curLine.pos(magicStr, 1) &gt; 0 then
						break forwardFind;												// We've found our last message, so we can stop looping now
					endif;
				endforeach;
			endif;
			
			if idx &gt; 0 then
				idx := str.pos(_needle, idx);									// Find-next
			endif;
			
			// ... and repeat
		endwhile;
	endwhile;

epilog
	if tblLine &lt;&gt; null then
		delete tblLine;
	endif;

	return retVal;
end;</source>
        <access>protected</access>
        <Parameter name="_fileIter" type="Iterator" usage="io"/>
        <Parameter name="_pointInTime" type="TimeStamp"/>
        <Parameter name="_needle" type="String"/>
        <Parameter name="_startIdents" type="HugeStringArray"/>
        <Parameter name="_endIdents" type="HugeStringArray"/>
        <Parameter name="_results" type="CM_AssociationDict"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getLogMask" id="af3584b2-66da-4e12-9bd9-3a3205bfed54">
        <source>getLogMask() : String protected;
/*

Purpose:			Return the file mask of the log names we should search for, depending on our process type

Parameters:			

Return Value:		

Date				Who		Reason
04 September 2020	jlgmd1	TFS 50003 Initial creation

*/

vars
	mask		: String;
begin
	// Default to Card Schema logs
	mask := "cn_" &amp; self.envName &amp; "*.log";

	if self.processType = CM_LogParserAgent.SupProc_Web then
		// multiple log types aren't supported yet... but thats the plan!
		//mask := mask &amp; "|jmtwebservice*.log";
		mask := "jmtwebservice*.log";
	endif;

	return mask;
epilog

end;</source>
        <access>protected</access>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="guessEnvName" id="4d2598a0-409a-4f1d-9a29-f162c9b5cd8a">
        <updating/>
        <source>guessEnvName() protected, updating;
/*

Purpose:			Try and guess what the Environment name is, based on the logs in the log folder

Parameters:			

Return Value:		

Date				Who		Reason
19 September 2019	jlgmd1	Initial creation

*/

vars
	kvDict		: CM_AssociationDict;
	kvVal		: CM_Association;
	
	folder		: FileFolder;
	file		: FileNode;
	
	idx			: Integer;
	name		: String;
	
	iter		: Iterator;
	sa			: StringArray;
begin
	// Nothing to do
	if logsLocation = null then
		return;
	endif;
	
	create folder transient;
	folder.mask := "cn_*.log";
	folder.usePresentationFileSystem := true;
	folder.fileName := self.logsLocation;
	folder.readOnly := true;

	// Unhelpfully this call keeps a handle on the folder until the processes is closed :(
	if not folder.isAvailable then
		//app.raiseUnexpectedProgramError(class.name, method.name, "Error - Unable to access logs directory.");
		self.updateStatusText("Error - Unable to access logs directory", true);
		return;
	endif;
	
	// Go through all the cn_ logs in the folder and record the part between the _ and the numbers at the end
	// The one that occurs most often should be our environment name
	create kvDict transient;
	foreach file in folder.files do
		idx := 4;
		name := file.name.scanUntil("0123456789", idx).toUpper;
		kvVal := kvDict[name];
		if kvVal = null then
			kvDict.addAssoc(name, 1);
		else
			kvVal.setValue(kvVal.asInteger+1);
		endif;
	endforeach;
	
	// What name had the most occurrences ?
	idx := 0;
	iter := kvDict.createIterator();
	while iter.next(kvVal) do
		if kvVal.asInteger &gt; idx then
			name := iter.getCurrentKey(1).String.toLower;
			idx := kvVal.asInteger;
		endif;
	endwhile;
	
	// Some environments have the name of the cn logs as cn_&lt;envname&gt;_log[number].log
	create sa transient;
	name.getTokensForDelimiter("_", sa);
	name := sa[1];
	
	self.envName := name;
	self.updateStatusText("Environment detected: " &amp; self.envName, false);
	
	// Attempt to reduce the read(write?) lock on the folder
	folder.fileName := null;
epilog
	delete folder;
	delete kvDict;
	delete iter;
	delete sa;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="isSupportedProc" id="37b61cec-ec92-4791-9ffe-77d829836354">
        <updating/>
        <source>isSupportedProc() : Boolean protected, updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
20 September 2019	jlgmd1	Initial creation
13 December 2019	jlgzm1	TFS 47162 JSM Ping Alerts - report controller
09 January 2019		jlgmd1	TFS 48181 Allow searching for process 'Activity'

*/

constants
	JMTWebServiceName	: String = "JMTWebService";
	ReportCtrlName		: String = "BGP_ReportControllerApp";
	BGPCtrlName			: String = "BGP_ControllerApp";

vars
	proc : String;
begin
	proc := self.processName;
	
	//
	// Ping Searches
	//
	if self.searchType = self.SearchType_Ping then
		
		if proc.pos(JMTWebServiceName, 1) &gt; 0 then
			self.processType := self.SupProc_Web;
			return true;
		elseif proc.pos(ReportCtrlName, 1) &gt; 0 then
			self.processType := self.SupProc_BGP;
			return true;
		elseif proc.pos(BGPCtrlName, 1) &gt; 0 then
			self.processType := self.SupProc_BGP;
			return true;
		endif;
	
	//
	// Activity Searches
	//
	elseif self.searchType = self.SearchType_Activity then
	
		if proc.pos(JMTWebServiceName, 1) &gt; 0 then
			self.processType := self.SupProc_Web;
			return true;
		endif;
	
	endif;
	
	return false;
		
epilog

end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="logsLocation" id="c4aca384-ea46-4eb4-811c-655b03fa75f6">
        <methodInvocation>mapping</methodInvocation>
        <updating/>
        <source>logsLocation(set : Boolean; _value : String io) mapping, updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
19 September 2019	jlgmd1	Initial creation

*/

vars

begin
	if set then
		self.logsLocation := _value;
		self.guessEnvName();
	endif;
epilog

end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="populateMagicStings" id="f1723a83-13d4-4a2c-bc82-c00b07f6cd99">
        <updating/>
        <source>populateMagicStings() updating, protected;
/*

Purpose:			A list of known strings to delimit groups of log messages
					These should be ordered by the chances of each string being encountered first

Parameters:			

Return Value:		

Date				Who		Reason
09 January 2020		jlgmd1	Initial creation TFS 48181

*/

constants
	APP_START_MAGIC		: String = "-----------------  Application Start Up ---------------------------";
	WEB_START_MAGIC  	: String = "input=";
	WEB_END_EX_MAGIC	: String = "Aborting transaction and returning Ex_Abort_Action";	// With the new logging suppressing debug statements, we don't really have much to go off by default
	WEB_END_TCOM		: String = "Process::doCompactTransientFile compact of transient file complete";
	BGP_START_MAGIC  	: String = "Started processing BGP Request";
	NOTE_START_MAGIC	: String = "::userNotification parameters=";
	APP_END_MAGIC		: String = "now sending session close msg to Karma";	// this kinda makes the APP_START_MAGIC a bit redundent, but can't hurt to leave it in
	PING_START_MAGIC	: String = "Now replying to ping timed";
	PING_END_MAGIC		: String = "receipt and processing of CnPingCmd";	// ... completed - will delete.	The end of the previous successful ping
vars

begin
	// Make sure we clear out anything that might already be there
	self.magicStartStrings.clear();
	self.magicEndStrings.clear();
	
	if self.processType = self.SupProc_Web then
		magicStartStrings.add(WEB_START_MAGIC);
		magicEndStrings.add(WEB_END_EX_MAGIC);
		magicEndStrings.add(WEB_END_TCOM);
	elseif self.processType = self.SupProc_BGP then
		magicStartStrings.add(BGP_START_MAGIC);
	endif;
	
	magicStartStrings.add(NOTE_START_MAGIC);
	magicStartStrings.add(APP_START_MAGIC);
	
	magicEndStrings.add(APP_END_MAGIC);
	//magicEndStrings.add(PING_END_MAGIC);
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="processName" id="004c5de1-caf4-4cc4-9392-586e87177236">
        <methodInvocation>mapping</methodInvocation>
        <source>processName(set : Boolean; _value : String io) mapping;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
13 December 2019	jlgzm1	Initial creation TFS 47162 JSM Ping Alerts - report controller
09 January 2020		jlgmd1	TFS 48181 Only mangle the processName if we're doing a Ping type search
13 January 2020		jlgmd1	TFS 48181 Handle BGP_ExternalWSController searches

*/

vars
	pos 	: Integer;
	id		: String;
begin
	if set and self.searchType = self.SearchType_Ping then
		pos := _value.pos("/", 1);
		if pos &gt; 0 and pos+1 &lt; _value.length then
			id := _value[pos+1:end];
		endif;
		
		if id = null or not id.isInteger then
			// process name is invalid, set as null
			_value := null;
			return;
		endif;
		
		// Handle app overrides - sometimes the reported name doesn't match the app name in the logs
		if _value.pos("BGP_ReportController", 1) &gt; 0 then
			_value := "BGP_ReportControllerApp/" &amp; id;
		
		// The BGP_ControllerApp and its sub classes are logged under the parent BGP_ControllerApp class
		elseif (_value.pos("BGP_GenericController", 1) &gt; 0 or
				_value.pos("BGP_ExternalWSController", 1) &gt; 0)
			then
			_value := "BGP_ControllerApp/" &amp; id;
		endif;
	endif;
	
epilog

end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="reverseSearch" id="cb35c523-9d09-4daf-aeca-fde206fc7c83">
        <source>reverseSearch(_fileIter : Iterator io; _pointInTime : TimeStamp; _needle : String; _startIdents, _endIdents : HugeStringArray; _results : CM_AssociationDict input) protected;
/*

Purpose:			

Parameters:			_fileIter		An iterator pointing to a collection of log files to go through
					_pointInTime	The point in time to start caring about matching log lines
					_needle			The Process name to search for
					_startIdents	A list of 'magic' strings that identifies the start of a new gorup of log lines for a given process
					_results		The Association dictionary to add our table lines to. String is used for the log line, 
									Boolean is used to identify whether it should be added to the top of the table or not

Return Value:		

Date				Who		Reason
08 January 2020		jlgmd1	Initial creation TFS 48181 Refactor from doSearchPing

*/

constants
	PING_REPLY_MSG : String = "Now replying to ping timed at";
vars
	file		: FileNode;
	str,
	dateStr,
	curLine,
	tmpStr		: String;
	idx,
	startIdx,
	tIdx		: Integer;
	badDate		: Boolean;
	tblLine		: CM_Association;
	key			: String;
	keyChar		: Character;
	magicStr	: String;
	lineDT		: TimeStamp;
	pingTime	: Time;
begin
	keyChar := "a".Character;	// I'm sure there is a better way to do this ;)
	_fileIter.next(file);		// Go forward one log, so the reverseFind starts at the 'current' log
	
	while _fileIter.back(file) do :reverseFind
		if file.cnEcIsFolder then continue; endif;
		
		self.updateStatusText("Performing reverse search [" &amp; _needle &amp; "] ... " &amp; file.name, false);
		file.File.seek(0);	// make sure we start at the beginning
		str := file.File.readString(file.File.fileLength);
		
		idx := str.reversePos(_needle);
		while idx &gt; 0 do
			// Found!
			startIdx := idx;
			idx := str.reversePosIndex(CrLf, idx);								// go to the beginning of the line
			if idx = 0 then idx := 1; endif;									// reversPosIndex returns 0 when it hits the beginning of the file
			str.scanWhile(CrLf, idx);
			
			// The 'end of the line' might actually be split across multiple lines
			// So keep reading until the next date segment
			badDate := false;
			dateStr := str.scanUntil(" ", idx);
			if dateStr.length &lt; 10 then
				badDate := true;
			endif;
			
			curLine := null;
			tmpStr := str.scanUntil(CrLf, idx);									// and grab all text until the end
			
			if badDate then
				curLine := dateStr &amp; tmpStr;
			else
				while tmpStr.pos(dateStr, 1) &lt;&gt; 1 and idx &gt; 0 do
					if curLine = null then
						curLine := dateStr &amp; tmpStr;
					else
						curLine := curLine &amp; CrLf &amp; tmpStr;
					endif;
					
					str.scanWhile(CrLf, idx);
					if idx &gt; 0 then
						tmpStr := str.scanUntil(CrLf, idx);
					endif;
				endwhile;
			endif;
			
			// Need to handle, so look for 2nd ' ' character
			// 03/09/2020 12:25:34.150
			// 03-09-20 12:25:34.150
			// 2021/01/28 23:55:56.463: 
			dateStr := curLine[1:curLine.pos(" ", 12)].trimRight();
			if dateStr[dateStr.length:1] = ":" then
				dateStr := dateStr[1:dateStr.length-1];
			endif;
			
			lineDT := dateStr.TimeStamp;
			if not lineDT.isValid or lineDT &gt; _pointInTime then
				curLine := null;
			else
				//self.addRowToTable(curLine, true);
				create tblLine transient;
				tblLine.set2Values(curLine, true);
				key := key &amp; keyChar;
				if key.length &gt;= 255 then
					keyChar := (keyChar.Integer + 1).Character;
					key := keyChar;
				endif;
				_results[key] := tblLine;
				tblLine := null;
			endif;
			
			// Work out whether we should stop searching or not...
			if curLine &lt;&gt; null then
				
				foreach magicStr in _startIdents do
					if curLine.pos(magicStr, 1) &gt; 0 then
						break reverseFind;												// We've found our start message, so we can stop looping now
					endif;
				endforeach;
				
				foreach magicStr in _endIdents do
					if curLine.pos(magicStr, 1) &gt; 0 then
						break reverseFind;												// We've found the end of a previous message, so we can stop looping now
					endif;
				endforeach;
				
				// Otherwise, check if its a ping reply
				if curLine.pos(PING_REPLY_MSG, 1) &gt; 0 then
					// Get the current line timestamp, and the ping timestamp
					
					// Find the second to last ,
					tIdx := curLine.reversePos(",")-1;
					tIdx := curLine.reversePosIndex(",", tIdx);
					tIdx := tIdx + 1;
					pingTime := curLine.scanUntil(",", tIdx)[2:8].Time;		// " 10:56:02" -&gt; "10:56:02"
					
					// Now allow up to 5 seconds for the delay in logging
					if pingTime &lt;= lineDT.time.addSeconds(5) then
						// The ping being replied to is 'now'
						// If the WebService is idle and just replying to pings all the time, then really, we don't care
						break reverseFind;
					endif;
				endif;
			endif;
				
			if idx = 0 then
				idx := file.File.fileLength-1;										// idx will be 0 here if we're the very last line in the log
				idx := str.reversePosIndex(CrLf, idx);								// Back to the beginning of the curLine
				idx := str.reversePosIndex(_needle, idx);							// Find-previous (but perhaps - just where we started)
				if idx = startIdx then
					idx := str.reversePosIndex(_needle, idx);						// This will only apply if our last line isn't complete by EOF
				endif;
			else
				idx := idx - 1;		// Cr/Lf
				idx := str.reversePosIndex(CrLf, idx);								// Back to the beginning of the curLine
				if idx &gt; 0 then
					idx := str.reversePosIndex(_needle, idx);						// back to where we started
				endif;
				if idx &gt; 0 then
					idx := str.reversePosIndex(_needle, idx);						// Find-previous
				endif;
			endif;
			
			// ... and repeat
		endwhile;
	endwhile;
epilog
	if tblLine &lt;&gt; null then
		delete tblLine;
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="_fileIter" type="Iterator" usage="io"/>
        <Parameter name="_pointInTime" type="TimeStamp"/>
        <Parameter name="_needle" type="String"/>
        <Parameter name="_startIdents" type="HugeStringArray"/>
        <Parameter name="_endIdents" type="HugeStringArray"/>
        <Parameter name="_results" type="CM_AssociationDict" usage="input"/>
    </JadeMethod>
    <JadeMethod name="updateStatusText" id="91bad4b2-9ec5-4241-9c9a-848f78298fc8">
        <source>updateStatusText(_msg : String; _inError : Boolean) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
19 September 2019	jlgmd1	Initial creation

*/

vars

begin
	if self.myForm = null then
		return;
	endif;
	
	self.myForm.setStatusCaption(_msg, _inError);
	app.writeStatement(_msg);
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_msg" type="String"/>
        <Parameter name="_inError" type="Boolean"/>
    </JadeMethod>
</Class>
