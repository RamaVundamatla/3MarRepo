    <JadeMethod name="modalDialogShow2" id="6bf08908-b797-4b8c-9193-e11e50883956">
        <updating/>
        <source>modalDialogShow2(_frameCaption, _btnDefaultCaption, _btnOpt1Caption, _btnOpt2Caption,
				  _lblMessage, _lblInfo : String;
				  _showFullScreen : Boolean) updating;
// ---------------------------------------------------------------------------
// Created:		September  2002 By Andrew Bishop cnwab1
//
// Purpose:		
// ---------------------------------------------------------------------------
constants
	DefaultHeight = 120;
	DefaultWidth = 320;
begin
	
	self.cmbOpt1.visible := false;
	self.cmbOpt2.visible := false;
		
	self.pbProgressBar.visible := false;
	self.pbProgressBar.foreColor := Blue;
	self.pbProgressBar.backColor := White;

	self.lblModalInfo.visible := true;

	self.frmModalDialog.caption := _frameCaption;
	self.btnModalDefault.caption := _btnDefaultCaption;
	self.btnModalOpt1.caption := _btnOpt1Caption;
	self.btnModalOpt2.caption := _btnOpt2Caption;
	
	self.lblModalMessage.caption := _lblMessage;
	self.lblModalMessage.alignment := Frame.Alignment_Center_Middle;
	self.lblModalMessage.fontBold := true;
	self.lblModalMessage.visible := true;	
	
	self.lblModalInfo.caption := _lblInfo;
	self.lblModalInfo.alignment := Frame.Alignment_Center_Middle;
	self.lblModalInfo.fontBold := false;
	self.lblModalInfo.move(lblModalMessage.left, pbProgressBar.top + pbProgressBar.height + 2, lblModalInfo.width, lblModalInfo.height);
	self.lblModalInfo.visible := true;
	
	if _btnDefaultCaption = null then
		self.btnModalDefault.visible := false;
	else
		self.btnModalDefault.visible := true;
	endif;
	if _btnOpt1Caption = null then
		self.btnModalOpt1.visible := false;
	else
		self.btnModalOpt1.visible := true;
	endif;
	if _btnOpt2Caption = null then
		self.btnModalOpt2.visible := false;
	else
		self.btnModalOpt2.visible := true;
	endif;
	
	// change here so can pass in as a parameter
	//if self.isFirstActivateComplete then
	if _showFullScreen then
		self.frmModalDialog.height := DefaultHeight;
		self.frmModalDialog.width := DefaultWidth;
	else
		self.frmModalDialog.height := self.clientHeight;
		self.frmModalDialog.width := self.clientWidth;
		self.btnModalOpt1.visible := false;
		self.btnModalOpt2.visible := false;
		self.btnModalDefault.visible := false;
	endif;

	self.modalDialogReturnValue := null;
	self.frmProgressCtr.centreWindow;

	self.frmModalDialog.zOrder(1);	// make sure its on top
	self.frmModalDialog.centreWindow();
	self.frmModalDialog.visible := true;
	self.frmModalDialog.refreshNow;
	
end;</source>
        <Parameter name="_frameCaption" type="String"/>
        <Parameter name="_btnDefaultCaption" type="String"/>
        <Parameter name="_btnOpt1Caption" type="String"/>
        <Parameter name="_btnOpt2Caption" type="String"/>
        <Parameter name="_lblMessage" type="String"/>
        <Parameter name="_lblInfo" type="String"/>
        <Parameter name="_showFullScreen" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="modalDialogShowCombos" id="7ed2f8c0-0aab-44e4-9ff8-3eac26b40372">
        <source>modalDialogShowCombos(_btnDefaultCaption, _btnOpt1Caption, _btnOpt2Caption,
				  	  _lblCmbOpt1, _lblCmbOpt2 : String);
//-----------------------------------------
//Created: June 2003 By: cnwgd1
//-----------------------------------------
constants
	DefaultHeight = 115; // 100;
	DefaultWidth = 310; //300;

vars
	tmpLeft : Real;
begin
	
	// Hide Progress Bar
	self.pbProgressBar.visible := false;

	// Comboboxes
	if _lblCmbOpt1 &lt;&gt; null then	
		self.lblModalMessage.caption := _lblCmbOpt1;
		//self.lblModalMessage.left := lblModalMessage.parent.left;
		self.lblModalMessage.autoSize := true;				
		self.lblModalMessage.alignment := Frame.Alignment_Left_Middle;
		self.lblModalMessage.fontBold := false;
		self.lblModalMessage.visible := true;
		self.cmbOpt1.visible := true;
		//self.cmbOpt1.width := self.cmbOpt1.parent.width - lblModalMessage.left - lblModalMessage.width - HorizontalSpacing - WinRightMargin;
		//self.cmbOpt1.move(lblModalMessage.left + lblModalMessage.width + 5, lblModalMessage.top, self.cmbOpt1.width, self.cmbOpt1.height);
	else
		self.lblModalMessage.visible := false;		
	endif;

	if _lblCmbOpt2 &lt;&gt; null then
		self.lblModalInfo.caption := _lblCmbOpt2;
		//self.lblModalInfo.left := lblModalInfo.parent.left;
		//self.lblModalInfo.top := cmbOpt1.top + cmbOpt1.height + 2;
		self.lblModalInfo.autoSize := true;				
		self.lblModalInfo.alignment := Frame.Alignment_Left_Middle;
		self.lblModalInfo.fontBold := false;
		self.lblModalInfo.visible := true;
		self.cmbOpt2.visible := true;
		//self.cmbOpt2.width := self.cmbOpt1.parent.width - lblModalInfo.left - lblModalInfo.width - HorizontalSpacing - WinRightMargin;
		//self.cmbOpt2.move(lblModalInfo.left + lblModalInfo.width + 5, lblModalInfo.top, self.cmbOpt2.width, self.cmbOpt2.height);				
	else
		self.lblModalInfo.visible := false;		
	endif;

	// Buttons
	self.btnModalDefault.caption := _btnDefaultCaption;
	self.btnModalOpt1.caption := _btnOpt1Caption;
	self.btnModalOpt2.caption := _btnOpt2Caption;
		
	if _btnDefaultCaption = null then
		self.btnModalDefault.visible := false;
	else
		self.btnModalDefault.visible := true;
	endif;
	if _btnOpt1Caption = null then
		self.btnModalOpt1.visible := false;
	else
		self.btnModalOpt1.visible := true;
	endif;
	if _btnOpt2Caption = null then
		self.btnModalOpt2.visible := false;
	else
		self.btnModalOpt2.visible := true;
	endif;

	// Frame	
	self.frmModalDialog.height := DefaultHeight;
	self.frmModalDialog.width := DefaultWidth;

	self.frmProgressCtr.centreWindow;
	self.frmModalDialog.centreWindow();
	self.frmModalDialog.visible := true;	
	self.frmModalDialog.refreshNow;

	tmpLeft := lblModalMessage.parent.left;	
	if self.cmbOpt1.visible then
		self.lblModalMessage.left := tmpLeft;
		self.cmbOpt1.width := self.cmbOpt1.parent.width - tmpLeft - lblModalMessage.width - HorizontalSpacing - WinRightMargin;
		self.cmbOpt1.move(tmpLeft + lblModalMessage.width + 15, lblModalMessage.top, self.cmbOpt1.width, self.cmbOpt1.height);	
	endif;

	if self.cmbOpt2.visible then
		self.lblModalInfo.left := tmpLeft;
		self.lblModalInfo.top := cmbOpt1.top + cmbOpt1.height + 5;		
		self.cmbOpt2.width := self.cmbOpt1.parent.width - tmpLeft - lblModalInfo.width - HorizontalSpacing - WinRightMargin;
		self.cmbOpt2.move(tmpLeft + lblModalInfo.width + 15, lblModalInfo.top, self.cmbOpt2.width, self.cmbOpt2.height);	
	endif;	
end;</source>
        <Parameter name="_btnDefaultCaption" type="String"/>
        <Parameter name="_btnOpt1Caption" type="String"/>
        <Parameter name="_btnOpt2Caption" type="String"/>
        <Parameter name="_lblCmbOpt1" type="String"/>
        <Parameter name="_lblCmbOpt2" type="String"/>
    </JadeMethod>
    <JadeMethod name="modalDialogUpdateInfo" id="fb9df847-6316-4836-bfe7-755407c1ae41">
