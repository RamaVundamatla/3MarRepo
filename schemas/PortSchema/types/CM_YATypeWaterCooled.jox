<Class name="CM_YATypeWaterCooled" id="3db33d27-f577-496b-8094-fbd6f5506d19">
    <superclass name="CM_YACriteriaType"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <access>protected</access>
    <DbClassMap file="yardAllocations"/>
    <JadeMethod name="getCriteriaObjectForTi" id="73111786-f268-49b3-8b24-173989c59664">
        <source>getCriteriaObjectForTi(_ti: CM_TrackedItem; _criteriaObject: CM_Object output; _process: Boolean output);

vars

begin
	if _ti.isKindOf(CM_Container) then
		if _ti.CM_Container.getCoolingType = ContainerWaterCooled then
			_process := true;
		endif;
	endif;
end;
</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_criteriaObject" type="CM_Object" usage="output"/>
        <Parameter name="_process" type="Boolean" usage="output"/>
    </JadeMethod>
    <JadeMethod name="getCriteriaValueForTi" id="335d8772-021f-4a5a-9090-2d7deb2f71f8">
        <source>getCriteriaValueForTi(_ti: CM_TrackedItem; _criteriaValue: Any output);
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02/11/2010	cnwdap1	Initial creation PAR #26184
*/
vars

begin
	if _ti.getCoolingType = ContainerWaterCooled then
		_criteriaValue := CM_YADataBoolean.VALUE_TRUE;
	else
		_criteriaValue := CM_YADataBoolean.VALUE_FALSE;
	endif;

epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_criteriaValue" type="Any" usage="output"/>
    </JadeMethod>
