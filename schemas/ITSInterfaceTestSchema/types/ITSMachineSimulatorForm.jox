        <Parameter name="_message" type="JadeXMLDocument"/>
    </JadeMethod>
    <JadeMethod name="doReceiveError" id="dbbdce56-0c25-4b74-bc71-6901b6633a0e">
        <updating/>
        <source>doReceiveError(_message : JadeXMLDocument) updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
17 December 2009	cnwkpd1	PAR #21593 - CCMS MES 1014 - ITS RDT Interface

*/

vars
	header,
	element			: JadeXMLElement;
	msg				: String;
	
begin
	header := _message.rootElement.getElementByTagName(XML_Tag_Header);
	element := header.getElementByTagName(XML_Tag_ErrorCode);
	
	if element &lt;&gt; null then
		msg := element.text();
	endif;
	
	element := header.getElementByTagName(XML_Tag_ErrorText);
	
	if element &lt;&gt; null then
		msg := msg &amp; " - " &amp; element.text();
	endif;
	
	app.msgBox(msg, "Error", MsgBox_OK_Only);
	
	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_message" type="JadeXMLDocument"/>
    </JadeMethod>
