    <JadeMethod name="addDays" id="cc235e76-a39d-4c9b-b02f-72a0941b1bf2">
        <source>addDays(_amountToAdd: Integer):TimeStamp;
//----------------------------------------------------------------
//	Created:	25 November 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin

	return self.cnEcAddDays(_amountToAdd);

end;</source>
