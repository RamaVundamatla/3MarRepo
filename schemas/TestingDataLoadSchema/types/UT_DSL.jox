    <JadeMethod name="addEventType" id="ba2d691e-7525-473a-afd0-c0fefeb7e66f">
        <source>addEventType(_eCategory : Integer; _eName : String; _eDescription : String; _eColour : Integer; _eErrorsWarnings : ObjectArray) : CM_EventType;
// --------------------------------------------------------------------------------
// Created:		03 Novemeber 2009 by cnwjo3
//
// Purpose:		Add a new Event type.  Basically emulate System Admin::Event Types

vars
	newEvent		: CM_EventType;
	pxyET			: CM_EventType;
	validEventType	: Boolean;
	etNo			: Integer;
	errorWarning	: Object;
	pxyErrorWarning : CM_InterestedWarning;
begin
	//yeah, i know.  Its a weird way of doing it.. but at least you can understand it.
	if _eCategory = CM_EventType.SYSTEM_EVENT then
		//actually i don't think we should really allow system events.... bah again!
		validEventType  := true;
	elseif _eCategory = CM_EventType.WARNING_EVENT then
		//actually at this point we could check if errorsWarnings array has been set.  bah!
		validEventType := true;
	elseif _eCategory =  CM_EventType.TRAIN_EVENT then 
		validEventType := true;
	elseif _eCategory =  CM_EventType.VOYAGE_EVENT then 
		validEventType := true;
	endif;

	if not validEventType then
		return null;
	endif;

	create pxyET transient;
	etNo := pxyET.getNextTypeInteger();
	pxyET.setProxy(etNo, _eName, _eDescription, pxyET.classNameToCreate, _eColour, _eCategory, app.myRoot,0,false,null);
	
	if not app.myPassport.trxCompletedOK() then
		return null;  //looks like proxy event type couldn't be created for some reason
	endif;

	if _eErrorsWarnings &lt;&gt; null then
		foreach errorWarning in _eErrorsWarnings do
			create pxyErrorWarning transient;
			pxyErrorWarning.setProxy(errorWarning.XLAT_Translation.myTranslatableText.number);
			pxyErrorWarning.addEventType(pxyET);
		endforeach;
	endif;
	
	//we only add.
	app.myTrxCA.trxCreateEventType(pxyET, newEvent, app.myPassport);
	
	if not app.myPassport.trxCompletedOK() then
		return null;  //looks like proxy event type couldn't be created for some reason
	endif;
	
	return newEvent;
epilog
	delete pxyErrorWarning;
	delete pxyET;
end;</source>
        <Parameter name="_eCategory" type="Integer"/>
        <Parameter name="_eName" type="String"/>
        <Parameter name="_eDescription" type="String"/>
        <Parameter name="_eColour" type="Integer"/>
        <Parameter name="_eErrorsWarnings" type="ObjectArray"/>
        <ReturnType type="CM_EventType"/>
    </JadeMethod>
