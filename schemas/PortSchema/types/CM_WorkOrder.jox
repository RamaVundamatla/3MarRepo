    <JadeMethod name="hasBeenApproved" id="da3be6ba-31f4-4dd0-9420-1c1ae1318c21">
        <source>hasBeenApproved(): Boolean;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
18 June 2010	cnwrd1	Initial creation

*/

vars

begin

	if self.taskStatus = WO_STATUS_APPROVED or
		self.taskStatus = WO_STATUS_COMPLETE or
		self.taskStatus = WO_STATUS_CANCELLED or
		self.taskStatus = WO_STATUS_HELD or
		self.taskStatus = WO_STATUS_PARTCOMPLETE or
		self.taskStatus = WO_STATUS_PENDING_CANCEL or
		self.taskStatus = WO_STATUS_PENDING_HOLD 
		then 
		return true;
	else
		return false;
	endif;

epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
