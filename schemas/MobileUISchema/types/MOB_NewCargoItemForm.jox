    <JadeMethod name="btn_Cancel_click" id="9e276af5-cffa-4849-9abb-b9f5f334a502">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btn_Cancel_click(btn: Button input) updating;
// ---------------------------------------------------------------------------
// Created:     09 April 2008 by cnwaer1
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin
	app.mousePointer	:=	Busy;
	self.modalResult := ModalResultCancel;
	self.doCloseForm();
epilog
	app.mousePointer	:=	Idle;
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="btn_OK_click" id="cb29e431-0e3b-47e6-9c17-f78e6961955a">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btn_OK_click(btn: Button input) updating;
// ---------------------------------------------------------------------------
// Created:     15 April 2008 by cnwaer1
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin
	if self.doSave() then
		modalResult := ModalResultOK;
		unloadForm;
		return;
	endif;
	modalResult := ModalResultError;
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
