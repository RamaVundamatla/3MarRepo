    <JadeMethod name="validateForCreate" id="e9afa076-b1f1-4460-8c55-abec981d9a90">
        <source>validateForCreate();
// ---------------------------------------------------------------------------
// Created:	30 September 2008 By Graeme Black cnwgb1
/// ---------------------------------------------------------------------------
vars
	cusMess : CM_CustomsStatusMessage;
begin
	if self.dispositionCode = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Disposition Code', null, null);
		app.raiseCMException(Input_required_field_dispCode, null, null); // cnwdb2	PAR 35364


	endif;
	if self.myBOL = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'BOL', null, null);
		app.raiseCMException(Input_required_field_bol, null, null); // cnwdb2	PAR 35364
	endif;
	
	if self.myBOL &lt;&gt; null then
		cusMess := self.myBOL.allCustomsStatMessageByCodeDT[self.dispositionCode, self.timeReceived];
		if cusMess &lt;&gt; null then
			app.raiseCMException(File_DB_Loaded, null, null);
		endif;
	endif;
	
epilog
end;</source>
    </JadeMethod>
</Class>
