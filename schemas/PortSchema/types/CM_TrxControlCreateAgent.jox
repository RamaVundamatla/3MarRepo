Return Value:		


Date		Who		Reason
19 May 2010	cnwer1	Initial creation
20/04/2023	navkc1	Bug 57628: CUX-Adding Criteria to Transaction Mapping allocation configuration results in error
*/

vars
	cmifObject		: CMIF_Object;
	transientObj	: CMIF_YACriteriaPriority;
	proxyObj		: CM_YACriteriaPriority;
	priorityValue	: Real;
	sortValue		: Real;	//20/04/2023	navkc1	Bug 57628 Needs to be the same type as receive

begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	app.setContinueCMExceptions(false);
	
	if _machineType &lt;&gt; null and _terminal = null then
	//	app.raiseCMException1(REQUIRED_FIELD,"Terminal",null,null);
		app.raiseCMException(Input_required_field_terminal,null,null); // cnwdb2	PAR 35364
		
		return;
	endif;
	
	if _machine = null and _terminal = null and _machineType = null then
	//	app.raiseCMException1(REQUIRED_FIELD,"Terminal",null,null);
		app.raiseCMException(Input_required_field_terminal,null,null); // cnwdb2	PAR 35364
		return;
	endif;
	
	app.myValCA.valCM_Object(_pxyRTVehicleConfig, _passport);
	
	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	
	// CCMS MES 1080 PAR 24294	15/09/2010
	if _allCriteria &lt;&gt; null then // YA criteria is set only for terminals
		// Now calculate the cargo check item priority values on the proxy objects, working
		// backwards from the least important
		foreach cmifObject in _allCriteria reversed do
			transientObj	:= cmifObject.CMIF_YACriteriaPriority;
			if transientObj.isDeleted then
				continue;
			endif;
			
			proxyObj		:= transientObj.myProxy;
			priorityValue	:= 2 ^ sortValue;
			proxyObj.setPriorityValue(priorityValue);
			sortValue		:= sortValue + 1;
		endforeach;
		
	endif;
	

	// Start the transaction
	beginTransaction;
	
	app.myUtilityCA.utlCreateRTVehicleConfig(_pxyRTVehicleConfig, _newRTVehicleConfig, _allCriteria, _terminal, _machineType, _machine, _passport);

epilog
	self.finaliseActivityWithPassport(_passport);
end;</source>
        <Parameter name="_pxyRTVehicleConfig" type="CM_RTVehicleConfig" usage="input"/>
        <Parameter name="_newRTVehicleConfig" type="CM_RTVehicleConfig" usage="output"/>
        <Parameter name="_allCriteria" type="CMIF_Array" usage="input"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_machineType" type="CM_MachineType"/>
        <Parameter name="_machine" type="CM_Machine"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
