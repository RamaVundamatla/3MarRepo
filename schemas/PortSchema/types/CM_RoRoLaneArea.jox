    <JadeMethod name="validateLanesForUpdate" id="2df8bed3-3996-4698-970c-1953a6cd5e86">
        <source>validateLanesForUpdate() protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
24 November 2009	cnwjk3	Initial creation

*/

vars
	lane	: CM_RoRoController;
	realTA	: CM_RoRoLaneArea;
	laneNum	: Integer;
begin
	realTA := self.pxyGetRealObject();
	if realTA = null then
		app.raiseUnexpectedProgramError(class.name, method.name, "No real object found for proxy RoRo Lane Area");
	endif;
	
	if self.laneCount &lt; realTA.laneCount then
		// Ensure that the lanes being discarded don't have cargo in them
		foreach laneNum in self.laneCount + 1 to realTA.laneCount do
			lane := realTA.allLanesByLaneNumber[laneNum];
			lane.validateForDelete();
		endforeach;
	endif;
	
	foreach lane in self.allLanesByLaneNumber do
		lane.validateForUpdate(lane.pxyGetRealObject, app.myPassport);
	endforeach;
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="validateStandardGap" id="2658ac33-1e2e-421e-b281-6793159cee1d">
        <source>validateStandardGap() protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
24 November 2009	cnwjk3	Initial creation

*/

vars

begin
	if self.standardGap &gt; self.maxLaneLen then
		app.raiseCMException2(RoRo_StdGapOutOfRange, self.standardGap.String, self.maxLaneLen.String, null, null);
	endif;
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="yaBuildBlocks" id="cbbd6d94-bb5a-45f5-9a46-c814f5a78063">
        <source>yaBuildBlocks(pYardAllocationObj: CM_YardAllocation; pAllControllersObj: CM_LCArray input; pAllBlocksInObj: CM_YABlockArray input; pAllBlocksOutObj: CM_YABlockArray input): Boolean;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
26 January 2010	cnwjk3	Initial creation

*/

	//return inheritMethod(pYardAllocationObj, pAllControllersObj, pAllBlocksInObj, pAllBlocksOutObj);
vars
	blockObj			: CM_YABlock;
	controllerObj		: CM_LocationsController;
	roroControllerObj	: CM_RoRoController;
	controllerSetObj	: CM_LCArray;
	deleteBlockSet		: CM_YABlockSet;
	doDelete			: Boolean;
	
begin		
	create controllerSetObj transient;
	create deleteBlockSet transient;
	
	foreach blockObj in pAllBlocksInObj where blockObj.myTerminalArea = self do
		deleteBlockSet.add(blockObj);
	endforeach;
	
	blockObj := null;
	foreach controllerObj in pAllControllersObj do
	
		if pYardAllocationObj = null then
			doDelete := true;
		endif;
		
		if (not CM_RoRoController.hasInstance(controllerObj)) then
			// This should not ever happen!!
			continue;
		endif;
		
		roroControllerObj	:=	controllerObj.CM_RoRoController;
		
		// Note that whilst we only look up a YA Block from the "In" collection, we will
		// add any new blocks to both the "In" and "Out" collections. This is because
		// both the "In" and the "Out" collections contain the same objects, the only
		// difference is that they may be in a different order.
		
		
		if blockObj &lt;&gt; null and deleteBlockSet.includes(blockObj) then
			// Need to clear out controllers for first time.
			blockObj.allYardControllers.clear();
			deleteBlockSet.remove(blockObj);
		endif;
		
		controllerSetObj.add(controllerObj);
		
		// If a YA Block wasn't found for the Grid Row, one will be created here.
		
		self.yaAddControllersToBlock(pYardAllocationObj, controllerSetObj, blockObj, pAllBlocksInObj, pAllBlocksOutObj);
		controllerSetObj.clear();
	endforeach;
	
	if doDelete then

		foreach blockObj in deleteBlockSet do
			if pAllBlocksInObj.includes(blockObj) then
				pAllBlocksInObj.remove(blockObj);
				pAllBlocksOutObj.remove(blockObj);
			endif;
		endforeach;
		deleteBlockSet.purge();
	endif;
	
	return true;
epilog
	delete controllerSetObj;
	delete deleteBlockSet;
end;
</source>
        <Parameter name="pYardAllocationObj" type="CM_YardAllocation"/>
        <Parameter name="pAllControllersObj" type="CM_LCArray" usage="input"/>
        <Parameter name="pAllBlocksInObj" type="CM_YABlockArray" usage="input"/>
        <Parameter name="pAllBlocksOutObj" type="CM_YABlockArray" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="yaGetBlockType" id="95ad1a96-5ffe-41be-8af2-9125c67eaf54">
        <source>yaGetBlockType(): Class;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
27 November 2009	cnwjk3	Initial creation

*/

vars

begin
	return CM_YARoRoLaneBlock;
epilog

end;</source>
        <ReturnType type="Class"/>
    </JadeMethod>
</Class>
