    <JadeMethod name="zSetPxySealNumShippers" id="792827f4-aab4-48a9-9d4f-a1c5b556e366">
        <updating/>
        <source>zSetPxySealNumShippers(_sealNumShippers : String) updating;
// -------------------------------------------
// Created 08 February 2005 by cnwdvb1
// -------------------------------------------
// 07 Jun 2017	cnwrs1	TFS 4462 SNO add Terminal Operator, Unknown Seal and support multiple seals
vars
