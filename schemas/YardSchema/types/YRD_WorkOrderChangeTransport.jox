    <JadeMethod name="doBtnClickChangeTrans" id="53a32b41-e3a9-498f-8cc1-04d369adc5f1">
        <updating/>
        <source>doBtnClickChangeTrans()updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 April 2023	navhl20	ChangeRequest 56631:[56185] EUP - Transport Mode change - UI Changes
04 Jan 2024 navlc30 ChangeRequest 59997: EUP | Work Order Transport Mode change - Rail Receive
30 Jan 2024 navlc30 Bug 62217 MTN - 1090 exception when changing the transport mode from Rail to Ship

*/

vars

begin
	//if app.msgBox(app.getErrorString2(Conform_Change_Transport,self.txtCurrentTrans.text,self.txtNewTrans.text), app.getErrorString(Change_transport_mode), MsgBox_Question_Mark_Icon + MsgBox_Yes_No) = MsgBox_Return_No then	//04.01.2024 navlc30 #59997
	if app.msgBox(app.getErrorString2(Conform_Change_Transport,self.txtCurrentTrans.text,self.cmbNewTrans.text), app.getErrorString(Change_transport_mode), MsgBox_Question_Mark_Icon + MsgBox_Yes_No) = MsgBox_Return_No then		//04.01.2024 navlc30 #59997
		return;
	endif;

	if self.cmbNewTrans.text = TI_TRANSMODE_SHIP_STR and self.cmbVoyage.text.isBlank then																																			//30.01.2024 navlc30 #62217
		app.msgBox(app.getErrorString1(Input_required_field_Required, self.lblVoyage.caption), app.getErrorString(Change_transport_mode),MsgBox_OK_Only);
		return;
	endif;	
	
	self.doSave();
	if app.myPassport.trxCompletedOK then
		self.unloadForm();
		self.myParentForm.YRD_WorkOrder.unloadForm();
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doCmbClickNewTransMode" id="55baa3fb-a967-4542-9d70-ddcfb1f26777">
        <source>doCmbClickNewTransMode();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 Jan 2024 navlc30 ChangeRequest 59997: EUP | Work Order Transport Mode change - Rail Receive
22 Feb 2024	navpw1	TFS: 59411 (61865) - Added support for Changing from Rail to Ship for Release

*/

vars
	cmb    : CMUI_ComboBox;
	term   : CM_Terminal;
	voyage : CM_Voyage;	
	train  : CM_Train;
	str    : String;
begin

	term := self.myTerminal;
	cmb  := self.cmbVoyage;
	cmb.clear;
	self.lblNewBol.visible 		:= false;
	self.lblNewBook.visible 	:= true;
	
	str  := self.cmbNewTrans.text;
	
	if self.myWorkOrderDtl.isWodReceive then
		if str = TI_TRANSMODE_RAIL_STR then
			foreach train in term.allTrainsOnTerminal do 
				cmb.addItemObject(train.code, train);
			endforeach;
		else
			foreach voyage in term.allVoyagesByCode do 
				cmb.addItemObject(voyage.code, voyage);
			endforeach;
			//For Ship we will display new BOL
			if str = TI_TRANSMODE_SHIP_STR then
				self.lblNewBol.visible 		:= true;
				self.lblNewBook.visible 	:= false;		
			endif;	
		endif;
		
	// ### TFS 59411 (61865) 22Feb2024 NAVPW1
	elseif self.myWorkOrderDtl.isWodRelease then
		if str = TI_TRANSMODE_RAIL_STR then
			foreach train in term.allTrainsOnTerminal do 
				cmb.addItemObject(train.code, train);
			endforeach;
			
		else
			foreach voyage in term.allVoyagesByCode do 
				cmb.addItemObject(voyage.code, voyage);
			endforeach;
			
		endif;
		
		if str = TI_TRANSMODE_SHIP_STR then
			self.lblNewBol.visible				:= false;
			self.lblNewBook.visible				:= true;
			self.lblNewReleaseRequest.visible	:= false;
			
		elseif str = TI_TRANSMODE_RAIL_STR or str = TI_TRANSMODE_ROAD_STR then
			self.lblNewBol.visible				:= false;
			self.lblNewBook.visible				:= false;
			self.lblNewReleaseRequest.visible	:= true;
			
		endif;	
		
	endif;
	// ### TFS 59411 (61865) 22Feb2024 NAVPW1
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doFilterTable" id="a166f79d-7f82-442e-b44c-e9b090b2093f">
        <updating/>
        <source>doFilterTable() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 May 2023 navhl20	ChangeRequest 56631:[56185] EUP - Transport Mode change - UI Changes
*/

vars
	filterText 	: String;
	rowIdx,
	colIdx,
	start,
	totalRows,
	rows		: Integer;
	cell 		: JadeTableCell;
	cellText 	: String;
	tbl			: CM_DataTable;
	selectAll	: Boolean;
	
begin
	/* //23/04/2024	navkc1 CR63736 Task 63770 - Use new filter control to do filtering.
	rows		:= 0;
	filterText  := self.txtFilter.text.toUpper();	
	tbl  		:= self.tblPendingCargo;
	
	if filterText = "" then
		self.clearFilter();
		return;
	else
		self.btnClearFilter.enabled := true;
	endif;
	
	start := tbl.fixedRows + 1;

	foreach rowIdx in start to tbl.rows do : rowLoop
		tbl.accessRow(rowIdx);
		
		foreach colIdx in 1 to tbl.columns do
			cell 	 := tbl.accessCell(rowIdx, colIdx);
			cellText := cell.text.toUpper;
			
			if cellText.length &gt; 0 and cellText.pos(filterText, 1) &gt; 0 then
				tbl.accessedRow.visible := true;
				if self.chkSelectAll.value then
					tbl.selectRow(rowIdx,false);
				else
					tbl.deselectRow(rowIdx);
				endif;
				rows := rows+1;
				continue rowLoop;
			endif;
		endforeach;
		
		tbl.accessedRow.visible := false;
		if self.chkSelectAll.value then
			tbl.deselectRow(rowIdx);
		endif;
	endforeach;
	*/ //23/04/2024	navkc1 CR63736 Task 63770
	
	tbl := self.tblPendingCargo;
	start := tbl.fixedRows + 1;
	totalRows := tbl.rows;
	selectAll := self.chkSelectAll.value;
	
	foreach rowIdx in start to totalRows do
		tbl.accessRow(rowIdx);
		
		if selectAll and tbl.accessedRow.visible then
			tbl.selectRow(rowIdx, false);
		else
			tbl.deselectRow(rowIdx);
		endif;
	endforeach;
	
	self.doTblDataSelect();
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doMnuFormContextMenu" id="bde4533a-257b-46cc-bc6e-30f67b2b8a41">
        <updating/>
        <source>doMnuFormContextMenu(table : CM_DataTable input; mouse: Boolean; x: Integer; y: Integer): Boolean updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 Feb 2023	navhl20	ChangeRequest 56631:[56185] EUP - Transport Mode change - UI Changes

*/

vars
	isShowDataMenusP,
	isShowDataMenusC		: Boolean;
	isDataValidRow		: Boolean;
	x1, y1				: Real;
begin
	if table = self.tblPendingCargo then
		isShowDataMenusP	:=	(table = self.tblPendingCargo);
	elseif table = self.tblCompletedCargo then
		isShowDataMenusC	:=	(table = self.tblCompletedCargo);
	endif;
	
	self.mnuColumnOrganiser.visible := true;
	self.mnuColumnOrganiser.userObject := table;
	
	if isShowDataMenusP then
		isDataValidRow	:=	(self.tblPendingCargo.row &gt; self.tblPendingCargo.fixedRows);
	elseif isShowDataMenusC then
		isDataValidRow	:=	(self.tblCompletedCargo.row &gt; self.tblCompletedCargo.fixedRows);
	endif;

	x1	:=	x;
	y1	:=	y;
	
	if (not mouse) then  // if keyboard, use current listIndex value
	    x1	:=	1;
	    y1	:=	1;
	endif;

	table.windowToScreen(x1, y1);
	self.screenToWindow(x1, y1);   // convert x, y relative to form
	self.popupMenu(self.mnuWorkOrderChangeTrans, x1.Integer, y1.Integer);
	return false;
epilog

end;</source>
        <Parameter name="table" type="CM_DataTable" usage="input"/>
        <Parameter name="mouse" type="Boolean"/>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doPermissionCheck" id="7a0e2035-738b-4758-ac28-8f2dafcec7e4">
        <source>doPermissionCheck();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 Feb 2023	navhl20	ChangeRequest 56631:[56185] EUP - Transport Mode change - UI Changes

*/

vars
	
begin
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		self.btnChangeTransport.enabled := false;
		self.txtNewBookorBol.enabled	:= false;
		self.cmbVoyage.enabled			:= false;
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doSave" id="2b60281b-0099-414b-9d2f-e6e26572ccca">
        <updating/>
        <source>doSave()updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 May 2023	navhl20	ChangeRequest 56631:[56185] EUP - Transport Mode change - UI Changes
04 Jan 2024 navlc30 ChangeRequest 59997: EUP | Work Order Transport Mode change - Rail Receive
13 Feb 2024	navpw1	TFS: 59411 (62272) - Added support to split WLE's for work orders
27 Feb 2024	navpw1	TFS: 59411 (61864) - Refactored code and fixed 1090

*/

vars
	result			: Integer;
	newId,
	newTrans		: String;
	transport		: CM_Object;
	quantityIfWLE	: Integer;
	releaseRequest	: CM_BulkRelease;
	
begin
	newId 		:= self.txtNewBookorBol.text;
	//newTrans	:= self.txtNewTrans.text;						//04.01.2024 navlc30 #59997
	newTrans	:= self.cmbNewTrans.text;						//04.01.2024 navlc30 #59997
	transport 	:= self.cmbVoyage.listObject.CM_Object;
	
	if self.myWorkOrderDtl.isWodRelease then
		releaseRequest := self.myWorkOrderDtl.CM_WodRelease.myReleaseRequest;
	endif;
	
	if releaseRequest &lt;&gt; null and releaseRequest.releaseByType then
		quantityIfWLE := self.txtQuantity.text.Integer;
	endif;
	
	while true do
		app.myTrxUA.trxUpdateWorkOrderTransport(self.myWorkOrder,self.myWorkOrderDtl,transport,newTrans,newId,self.tblPendingCargo.allSelectedObjects,self.myTerminal, app.myPassport, quantityIfWLE);
		
		if app.myPassport.trxCompletedOK then
			break;
		else
			result := app.showErrorWarningDialog(self.caption, app.myPassport, ErrWarnMode_Add + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   result = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		return;
	endwhile;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doSelectAll" id="45688d21-ba9b-4b6a-9000-089b5e3c449f">
        <updating/>
        <source>doSelectAll()updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 May 2023	navhl20	05 May 2023 navhl20	ChangeRequest 56631:[56185] EUP - Transport Mode change - UI Changes

*/

vars

begin
	if self.chkSelectAll.value then
		self.tblPendingCargo.selectAll();
		self.doTblDataSelect();
	else
		
		//if self.txtFilter.text = null then
		if self.frmTableFilter.txtFilterBox.text = null then //05/06/2024	navkc1 CR 63736 Task 63770
			self.populatePendingTis(false);
		else
			self.doFilterTable();
		endif;
		self.lblTotalSelected.visible := false;
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doTblDataSelect" id="d75de739-bfbc-4d15-acb5-835e0499b57a">
        <source>doTblDataSelect();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 May 2023	navhl20	ChangeRequest 56631:[56185] EUP - Transport Mode change - UI Changes

*/

vars
	count : Integer;
begin
	count := self.tblPendingCargo.allSelectedObjects.size();
	if count &gt; 0 then
		self.lblTotalSelected.visible := true;
	else
		self.lblTotalSelected.visible := false;
	endif;
	self.lblTotalSelected.caption := "";
	self.lblTotalSelected.caption := app.getErrorString(Total_selected) &amp; Space &amp; count.String;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="getXMLSettingsForSave" id="3793abdc-c2fa-46e9-a9e0-b06eea336c29">
        <updating/>
        <source>getXMLSettingsForSave(): String updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 Feb 2023	navhl20	ChangeRequest 56631:[56185] EUP - Transport Mode change - UI Changes

*/

vars
	rtnString	:	String;
begin
	rtnString := inheritMethod();
	if self.defPendingCargo &lt;&gt; null then
		rtnString := rtnString &amp; self.defPendingCargo;
	else 
		rtnString := rtnString &amp; self.defCompletedCargo;
	endif;
	
	return rtnString;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="mnuColumnOrganiser_click" id="24b9a43f-918b-44a4-9581-8526a80b1b43">
        <controlMethod name="MenuItem::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>mnuColumnOrganiser_click(menuItem: MenuItem input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 February 2023	navds21	Initial creation

*/

vars

begin
	self.showColumnOrganiser();
epilog

end;</source>
        <Parameter name="menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="populateCompletedTis" id="07124ddc-604f-42ea-8de1-4f8aa23a3cda">
        <source>populateCompletedTis(_isCaption:Boolean);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 May 2023 navhl20	ChangeRequest 56631:[56185] EUP - Transport Mode change - UI Changes
15 Feb 2024	navpw1	TFS: 59411 (62272) - Added support to split WLE's for work orders

*/

vars
	trackedItem		: CM_TrackedItem;
	idx				: Integer;
	theDataLine		: String;
	tiSet       	: CM_TISet;
	entTableDef 	: EntTableDef;
	theTable 		: CM_DataTable;
	xmlStr 			: String;
	wodTIDtl		: CM_WorkOrderTIDtl;	// ### TFS 59411 (61855) 22Dec2023 NAVPW1 - Can be either Receive/Release and we want to access allCompleteTIs
	wleArr			: CM_WLEArray;
	wle				: CM_WorkListEntry;
	job				: CM_Job;
	releaseRequest	: CM_BulkRelease;
	
begin
	theTable := self.tblCompletedCargo;
	
	//wodReceive := self.myWorkOrderDtl.CM_WodReceive;
	wodTIDtl := self.myWorkOrderDtl.CM_WorkOrderTIDtl;
	
	if wodTIDtl.isWodRelease then
		releaseRequest := wodTIDtl.CM_WodRelease.myReleaseRequest;
		
		if releaseRequest &lt;&gt; null and releaseRequest.releaseByType then
			entTableDef	:= app.myController.getEntTableDef(ETDef_WoJobWle);
		else
			entTableDef	:= app.myController.getEntTableDef(ETDef_LlHeadings);
		endif;
	else
		entTableDef	:= app.myController.getEntTableDef(ETDef_LlHeadings);
		
	endif;
	
	xmlStr := self.defCompletedCargo;
	if xmlStr &lt;&gt; null then
		theTable.setTblDataEntRowsFromXML(entTableDef, xmlStr);	
	else	
		theTable.setTblDataEntRowsFromDef(entTableDef);
	endif;
	
	theTable.userInputEnabled 	:= enabled;
	theTable.selectMode 		:= CM_EntryTable.SelectMode_None;
	theTable.selectionType 		:= CM_EntryTable.SelectMode_None;
	theTable.readOnly 			:= false;
	theTable.fixedColumns    	:= 0;
	theTable.fixedRows 	   	 	:= 1;
	theTable.show3D 			:= Table.Show3D_Not3D;
	theTable.multiSelect 		:= CM_BaseTable.MultiSelect_None;
	
	if wodTIDtl.isWodRelease and wodTIDtl.CM_WodRelease.myReleaseRequest &lt;&gt; null and wodTIDtl.CM_WodRelease.myReleaseRequest.releaseByType then
		create wleArr transient;
		foreach job in wodTIDtl.allJobs do
			foreach wle in job.workListEntries do
				if wle.isCompleted then
					wleArr.add(wle);
				endif;
				
			endforeach;
		endforeach;
		
	elseif wodTIDtl &lt;&gt; null  then
		create tiSet transient;
		foreach trackedItem in wodTIDtl.allCompleteTIs do
			tiSet.addNoDuplicates(trackedItem,false);
		endforeach;
	endif;
	
	if tiSet &lt;&gt; null then
		if _isCaption then
			self.grpCompletedCargo.caption := self.grpCompletedCargo.caption &amp; Space &amp; "[" &amp; wodTIDtl.allCompleteTIs.size.String &amp; "]";
		endif;
		
		foreach trackedItem in tiSet do
			if idx &gt;= JadeTableRowLimit then
				app.msgBox('Maximum number of entries in table exceeded. Only the first ' &amp; JadeTableRowLimit.String &amp; ' will be shown', 'Error', MsgBox_OK_Only);
				break;
			endif;
			theDataLine := trackedItem.getAttributeStringForDefArray(theTable.allTblDataEntRows);
			theTable.accessRow(theTable.addItem(theDataLine)).itemObject := trackedItem;
			theTable.accessedRow.backColor := Grey;
			theTable.accessedRow.foreColor := White;
			idx := idx + 1;
		endforeach;
		
	elseif wleArr &lt;&gt; null and wleArr.isNotEmpty then
		if _isCaption then
			self.grpCargo.caption := self.grpCargo.caption &amp; Space &amp; "[" &amp; wleArr.size.String &amp; "]";
		endif;
		
		foreach wle in wleArr do
			if idx &gt;= JadeTableRowLimit then
				app.msgBox('Maximum number of entries in table exceeded. Only the first ' &amp; JadeTableRowLimit.String &amp; ' will be shown', 'Error', MsgBox_OK_Only);
				break;
			endif;
			theDataLine := wle.getAttributeStringForDefArray(theTable.allTblDataEntRows);
			theTable.accessRow(theTable.addItem(theDataLine)).itemObject := wle;
			idx := idx + 1;
		endforeach;
	endif;
	
epilog
	delete tiSet;
	delete wleArr;
	
end;</source>
        <Parameter name="_isCaption" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="populateOldDetails" id="14b751f1-8014-49fb-afe8-8d288c404f06">
        <updating/>
        <source>populateOldDetails() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 Feb 2023	navhl20	ChangeRequest 56631:[56185] EUP - Transport Mode change - UI Changes
04 Jan 2024 navlc30 ChangeRequest 59997: EUP | Work Order Transport Mode change - Rail Receive
15 Feb 2024	navpw1	TFS: 59411 (62272) - Added support to split WLE's for work orders
19 Feb 2024	navpw1	TFS: 59411 (61868) - Added support for Changing from Rail to Road for Release
22 Feb 2024	navpw1	TFS: 59411 (61865) - Added support for Changing from Rail to Ship for Release
26 Feb 2024	navpw1	TFS: 59411 (61864) - Added support for changing transport mode from ship to road for Cargo Releases
21 Mar 2024	navpw1	TFS: 63073 (63085) - Fixed label displaying issue, should of shown the new booking label and turned off the new release request label by default
17 Apr 2024 navpw1	TFS: 63663 (63721) - Added an else if statement for handling the display of a ship release request

*/

vars
	transport		: Integer;
	transStr		: String;
	booking			: CM_BookingRef;
	voyage			: CM_Voyage;
	releaseRequest	: CM_BulkRelease;		// ### TFS 59411 (61855) 22Dec2023 NAVPW1
	wodReceive		: CM_WodReceive;
	wodRelease		: CM_WodRelease;		// ### TFS 59411 (61855) 22Dec2023 NAVPW1
	wodTIDtl		: CM_WorkOrderTIDtl;	// ### TFS 59411 (61855) 25Jan2024 NAVPW1
	
begin
	// ### TFS 59411 (61855) 22Dec2023 NAVPW1
	if self.myWorkOrderDtl = null then
		return;
	endif;
	// ### TFS 59411 (61855) 22Dec2023 NAVPW1
	
	//Receive
	if self.myWorkOrderDtl.isWodReceive then
		wodReceive := self.myWorkOrderDtl.CM_WodReceive;
		transport 					:= wodReceive.transport;
		transStr					:= app.transportModeENumToString(transport);
		voyage						:= wodReceive.myVoyage;
		self.txtCurrentTrans.text 	:= transStr;
		self.cmbVoyage.setIndexFromObject(voyage);
		self.txtNewTrans.visible	:= false;												//04.01.2024 navlc30 #59997
		self.grpTransport.caption 	:= self.grpTransport.caption;								//08.01.20243 navlc30 #59997
		
		self.setupOldDetails(transStr, wodReceive);												//08.01.20243 navlc30 #59997	
	endif;
	
	// ### TFS 59411 (61855) 22Dec2023 NAVPW1
	wodTIDtl := self.myWorkOrderDtl.CM_WorkOrderTIDtl;
	transport 					:= wodTIDtl.getTransport();
	transStr					:= app.transportModeENumToString(transport);
	voyage						:= wodTIDtl.getVoyage();
	
	if self.myWorkOrderDtl.isWodRelease then
		wodRelease := self.myWorkOrderDtl.CM_WodRelease;
		self.txtCurrentTrans.text 	:= transStr;
		self.cmbVoyage.setIndexFromObject(voyage);
		
		self.setupOldDetails(transStr, wodRelease);
		
		if transStr = TI_TRANSMODE_ROAD_STR or transStr = TI_TRANSMODE_RAIL_STR then
			self.lblBooking.visible 			:= false;
			self.lblBol.visible 				:= false;
			self.lblReleaseRequest.visible 		:= true;
			self.grpTransport.caption 			:= self.grpTransport.caption; //&amp; Space &amp; "[" &amp; TI_TRANSMODE_SHIP_STR &amp; Hyphen &amp; TI_TRANSMODE_ROAD_STR &amp; "]";
			
			self.lblNewBol.visible 				:= false;
			self.lblNewBook.visible 			:= false;
			self.lblNewReleaseRequest.visible	:= false;
			
			releaseRequest := wodRelease.myReleaseRequest;
			if releaseRequest &lt;&gt; null then
				self.txtOldBookorBol.text := releaseRequest.code;
				self.txtNewBookorBol.text := releaseRequest.code;
			endif;
			
			if not self.cmbNewTrans.text = TI_TRANSMODE_SHIP_STR or releaseRequest.releaseByType then // ### TFS 63666 (63761) 22Apr2024 NAVPW1
				self.lblNewReleaseRequest.visible := true;
			else
				self.lblNewBook.visible := true;
			endif;
			
		else //For Ship Releases
			booking									:= wodRelease.myBookingRef;
			releaseRequest							:= wodRelease.myReleaseRequest;
			
			if booking &lt;&gt; null then
				self.lblBooking.visible 			:= true;
				self.lblBol.visible 				:= false;
				self.lblNewBol.visible 				:= false;
				self.lblNewBook.visible 			:= false;
				self.lblNewReleaseRequest.visible	:= true;
				self.txtOldBookorBol.text 			:= booking.bookingReference;
				self.txtNewBookorBol.text 			:= booking.bookingReference;
				self.txtNewTrans.text 				:= TI_TRANSMODE_ROAD_STR;
				self.grpTransport.caption 			:= self.grpTransport.caption; //&amp; Space &amp; "[" &amp; TI_TRANSMODE_ROAD_STR &amp; Hyphen &amp; TI_TRANSMODE_SHIP_STR &amp; "]";
				
			elseif releaseRequest &lt;&gt; null then
				self.lblBooking.visible 			:= false;
				self.lblBol.visible 				:= false;
				self.lblReleaseRequest.visible		:= true;
				self.lblNewBol.visible 				:= false;
				self.lblNewBook.visible 			:= false;
				self.lblNewReleaseRequest.visible	:= true;				// ### TFS 64387 31May2024 NAVPW1
				self.txtOldBookorBol.text 			:= releaseRequest.code;
				self.txtNewBookorBol.text 			:= null; //Keep empty cannot have 2 release requests active with the same code. Helps to avoid that issue
				self.txtNewTrans.text 				:= TI_TRANSMODE_ROAD_STR;
				self.grpTransport.caption 			:= self.grpTransport.caption; //&amp; Space &amp; "[" &amp; TI_TRANSMODE_ROAD_STR &amp; Hyphen &amp; TI_TRANSMODE_SHIP_STR &amp; "]";
				
			endif;
		endif;
	endif;
	// ### TFS 59411 (61855) 22Dec2023 NAVPW1
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="populatePendingTis" id="e7cbdaff-61d7-4886-9bb4-7b864d0d43b3">
        <source>populatePendingTis(_isCaption:Boolean);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 Feb 2023	navhl20	ChangeRequest 56631:[56185] EUP - Transport Mode change - UI Changes
13 Feb 2024	navpw1	TFS: 59411 (61867) - Made changes to load wles when dealing with release by type
13 Feb 2024	navpw1	TFS: 59411 (62272) - Added support to split WLE's for work orders

*/

vars
	ti				: CM_TrackedItem;
	idx				: Integer;
	theDataLine		: String;
	tiSet       	: CM_TISet;
	entTableDef 	: EntTableDef;
	theTable 		: CM_DataTable;
	xmlStr 			: String;
	woDtl			: CM_WorkOrderTIDtl;
	wleArr			: CM_WLEArray;
	wle				: CM_WorkListEntry;
	job				: CM_Job;
	releaseRequest	: CM_BulkRelease;
	
begin
	
	theTable	:= self.tblPendingCargo;
	woDtl		:= self.myWorkOrderDtl.CM_WorkOrderTIDtl;
	
	if woDtl.isWodRelease then
		releaseRequest := woDtl.CM_WodRelease.myReleaseRequest;
		
		if releaseRequest &lt;&gt; null and releaseRequest.releaseByType then
			entTableDef	:= app.myController.getEntTableDef(ETDef_WoJobWle);
		else
			entTableDef	:= app.myController.getEntTableDef(ETDef_LlHeadings);
		endif;
	else
		entTableDef	:= app.myController.getEntTableDef(ETDef_LlHeadings);
		
	endif;
	
	
	xmlStr := self.defPendingCargo;
	if xmlStr &lt;&gt; null then
		theTable.setTblDataEntRowsFromXML(entTableDef, xmlStr);	
	else	
		theTable.setTblDataEntRowsFromDef(entTableDef);
	endif;
	
	theTable.userInputEnabled 	:= false;
	theTable.selectMode 		:= CM_EntryTable.SelectMode_FixedRow;
	theTable.selectionType 		:= CM_EntryTable.SelectionType_Row;
	theTable.readOnly 			:= false;
	theTable.fixedColumns   	:= 0;
	theTable.fixedRows 	   	 	:= 1;
	theTable.show3D 			:= Table.Show3D_Not3D;
	theTable.multiSelect 		:= CM_BaseTable.MultiSelect_Simple;
	
	if woDtl.isWodRelease and woDtl.CM_WodRelease.myReleaseRequest &lt;&gt; null and woDtl.CM_WodRelease.myReleaseRequest.releaseByType then
		theTable.multiSelect 		:= CM_BaseTable.MultiSelect_None;	//Disabling Multiselect as it will be too complicated to switch multiple without large code changes.
		self.chkSelectAll.enabled	:= false;							//Disabling Select all as it will be too complicated to switch multiple without large code changes.
		create wleArr transient;
		foreach job in woDtl.allJobs do
			foreach wle in job.workListEntries do
				if wle.isCompleted then
					continue;
				endif;
				
				wleArr.add(wle);
			endforeach;
		endforeach;
		
	elseif woDtl &lt;&gt; null  then
		create tiSet transient;
		foreach ti in woDtl.allSelectedTIs do
			if woDtl.allCompleteTIs.includes(ti) then
				continue;
			endif;
			tiSet.addNoDuplicates(ti,false);
		endforeach;
	endif;
	
	if tiSet &lt;&gt; null then
		if _isCaption then
			self.grpCargo.caption := self.grpCargo.caption &amp; Space &amp; "[" &amp; tiSet.size.String &amp; "]";
		endif;
		
		foreach ti in tiSet do
			if idx &gt;= JadeTableRowLimit then
				app.msgBox('Maximum number of entries in table exceeded. Only the first ' &amp; JadeTableRowLimit.String &amp; ' will be shown', 'Error', MsgBox_OK_Only);
				break;
			endif;
			theDataLine := ti.getAttributeStringForDefArray(self.tblPendingCargo.allTblDataEntRows);
			self.tblPendingCargo.accessRow(self.tblPendingCargo.addItem(theDataLine)).itemObject := ti;
			idx := idx + 1;
		endforeach;
		
	elseif wleArr &lt;&gt; null and wleArr.isNotEmpty then
		if _isCaption then
			self.grpCargo.caption := self.grpCargo.caption &amp; Space &amp; "[" &amp; wleArr.size.String &amp; "]";
		endif;
		
		foreach wle in wleArr do
			if idx &gt;= JadeTableRowLimit then
				app.msgBox('Maximum number of entries in table exceeded. Only the first ' &amp; JadeTableRowLimit.String &amp; ' will be shown', 'Error', MsgBox_OK_Only);
				break;
			endif;
			theDataLine := wle.getAttributeStringForDefArray(self.tblPendingCargo.allTblDataEntRows);
			self.tblPendingCargo.accessRow(self.tblPendingCargo.addItem(theDataLine)).itemObject := wle;
			idx := idx + 1;
		endforeach;
	endif;
	
epilog
	delete tiSet;
	delete wleArr;
	
end;</source>
        <Parameter name="_isCaption" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="saveXMLStrForTblColumns" id="688100a8-1ef0-428f-bbd2-5dbde9b39818">
        <updating/>
        <source>saveXMLStrForTblColumns(table: CM_DataTable input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 Feb 2023	navhl20	ChangeRequest 56631:[56185] EUP - Transport Mode change - UI Changes

*/

vars
	xmlStr : String;
begin
	if table = self.tblPendingCargo then
		xmlStr := self.tblPendingCargo.getXmlStrForColumns(true);
		self.defPendingCargo := xmlStr;
	endif;
	if table = self.tblCompletedCargo then
		xmlStr := self.tblCompletedCargo.getXmlStrForColumns(true);
		self.defCompletedCargo := xmlStr;
	endif;	
epilog

end;</source>
        <Parameter name="table" type="CM_DataTable" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setFormCaption" id="249c62f7-fc2a-4d74-bbef-626ae21542d4">
        <updating/>
        <source>setFormCaption()updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 Feb 2023	navhl20	ChangeRequest 56631:[56185] EUP - Transport Mode change - UI Changes
22 Dec 2023	navpw1	TFS: 59411 (61855): Removed transport mode from caption and refactored code and removed isKindOf
*/

vars
	//transport : Integer;
	receiveRelease : String;

begin
	/*
	//if self.myWorkOrderDtl.isKindOf(CM_WodReceive) then
	if self.myWorkOrderDtl.isWodReceive then
		transport := self.myWorkOrderDtl.CM_WodReceive.getTransport();
		self.caption := self.caption &amp; Space &amp; Hyphen &amp; Space &amp; app.getErrorString(Receive_Cargo) &amp; Space &amp; "[" &amp; app.transportModeENumToString(transport) &amp; "]" &amp; Space &amp; Hyphen &amp; Space &amp; app.getErrorString(WorkOrder) &amp; self.myWorkOrder.id;
	else
		transport := self.myWorkOrderDtl.CM_WodRelease.getTransport();
		self.caption := self.caption &amp; Space &amp; Hyphen &amp; Space &amp; app.getErrorString(Release_cargo) &amp; Space &amp; "[" &amp; app.transportModeENumToString(transport) &amp; "]" &amp; Space &amp; Hyphen &amp; Space &amp; app.getErrorString(WorkOrder) &amp; self.myWorkOrder.id;
		
	endif;
	*/
	if self.myWorkOrderDtl &lt;&gt; null and self.myWorkOrderDtl.isWodReceive then
		receiveRelease := app.getErrorString(Receive_Cargo);
	else
		receiveRelease := app.getErrorString(Release_cargo);
	endif;
	
	self.caption := self.caption &amp; Space &amp; Hyphen &amp; Space &amp; receiveRelease &amp; Space &amp; Hyphen &amp; Space &amp; app.getErrorString(WorkOrder) &amp; self.myWorkOrder.id;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setTableDataFromOrganiser" id="6db14da4-64fc-4b7e-81bd-f0df213723bb">
        <updating/>
        <source>setTableDataFromOrganiser(_theTable: CM_DataTable input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 Feb 2023	navhl20	ChangeRequest 56631:[56185] EUP - Transport Mode change - UI Changes

*/

vars

begin
	self.doRefresh();
	self.saveXMLStrForTblColumns(_theTable);
	_theTable.rows := 1;
	if _theTable = self.tblPendingCargo then
		self.populatePendingTis(false);
	else
		self.populateCompletedTis(false);
	endif;
epilog

end;</source>
        <Parameter name="_theTable" type="CM_DataTable" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setWorkOrderDetail" id="f31e355c-72a8-4f11-9335-d7d2bf9cd536">
        <updating/>
        <source>setWorkOrderDetail( _workOrderDtl : CM_WorkOrderDtl;_workOrder:CM_WorkOrder) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who			Reason
02 Feb 2023	navhl20	ChangeRequest 56631:[56185] EUP - Transport Mode change - UI Changes

*/

vars

begin
	self.myWorkOrderDtl := _workOrderDtl;
	self.myWorkOrder 	:= _workOrder;
epilog

end;</source>
        <Parameter name="_workOrderDtl" type="CM_WorkOrderDtl"/>
        <Parameter name="_workOrder" type="CM_WorkOrder"/>
    </JadeMethod>
    <JadeMethod name="setupForm" id="9fa0f75f-714f-42b4-8c29-9873f06ff1c1">
        <updating/>
        <source>setupForm() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		         Who		Reason
02 February 2023	navds21	   	ChangeRequest 56631:[56185] EUP - Transport Mode change - UI Changes

*/

vars

begin
	self.setFormCaption();
	self.handleMenusForModalDisplay();
	
	self.doPermissionCheck();
	
	self.buildcmbVoyage();
	self.populateOldDetails();
	self.populatePendingTis(true);
	self.populateCompletedTis(true);
	
	self.frmTableFilter.setupControl(self.tblPendingCargo, null);								//05/06/2024	navkc1 CR 63736 Task 63770
	self.frmTableFilter.setCallbackMethod(YRD_WorkOrderChangeTransport::doFilterTable.name);	//05/06/2024	navkc1 CR 63736 Task 63770
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setupOldDetails" id="92bded49-dd1f-47ae-911a-000b27a0f744">
        <updating/>
        <source>setupOldDetails(_transStr	: String; _wodTI  : CM_WorkOrderTIDtl) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 Jan 2024 navlc30 ChangeRequest 59997: EUP | Work Order Transport Mode change - Rail Receive
30 Jan 2024	navpw1	TFS: 59411 (61855) - Added changes for Work Order Detail Release
07 Feb 2024 navlc30 Bug 62378: EUP - 1090 exception when clicking on Change Transport Mode button for Rail Receive jobs
15 Feb 2024	navpw1	TFS: 59411 (62272) - Added support to split WLE's for work orders
19 Feb 2024	navpw1	TFS: 59411 (61867) - Added support for Changing from Road to Rail for Release
19 Feb 2024	navpw1	TFS: 59411 (61868) - Added support for Changing from Rail to Road for Release
22 Feb 2024	navpw1	TFS: 59411 (61865) - Added support for Changing from Rail to Ship for Release
26 Feb 2024	navpw1	TFS: 59411 (61864) - Added support for changing transport mode from ship to road for Cargo Releases

*/
constants	
	INDEX		: Integer = 2;
	
vars
	booking 		: CM_BookingRef;
	bol				: CM_BOL;
	releaseRequest	: CM_BulkRelease;
	wodReceive		: CM_WodReceive;
	wodRelease		: CM_WodRelease;
	
begin
	if _wodTI.isWodReceive then
		wodReceive := _wodTI.CM_WodReceive;									//07.02.2024 navlc30 #62378
		if _transStr = TI_TRANSMODE_SHIP_STR then
			bol := wodReceive.myBillOfLading;
			if bol &lt;&gt; null then
				self.lblBooking.visible 	:= false;
				self.lblBol.visible 		:= true;
				self.lblNewBol.visible 		:= false;
				self.lblNewBook.visible 	:= true;
				self.txtOldBookorBol.text 	:= bol.number;
				self.txtNewBookorBol.text 	:= bol.number;
			endif;
			self.cmbNewTrans.addItem(TI_TRANSMODE_ROAD_STR);	
			self.cmbNewTrans.addItem(TI_TRANSMODE_RAIL_STR);
			self.cmbNewTrans.setIndex(INDEX);
		else
			booking := wodReceive.myBookingRef;
			if booking &lt;&gt; null then
				self.lblBooking.visible 	:= true;
				self.lblBol.visible 		:= false;
				self.lblNewBol.visible 		:= true;
				self.lblNewBook.visible 	:= false;
				self.txtOldBookorBol.text 	:= booking.bookingReference;
				self.txtNewBookorBol.text 	:= booking.bookingReference;
			endif;
			if _transStr = TI_TRANSMODE_ROAD_STR then
				self.cmbNewTrans.addItem(TI_TRANSMODE_RAIL_STR);
				self.cmbNewTrans.addItem(TI_TRANSMODE_SHIP_STR);
				self.cmbNewTrans.setIndex(INDEX);
			elseif _transStr = TI_TRANSMODE_RAIL_STR then
				self.cmbNewTrans.addItem(TI_TRANSMODE_ROAD_STR);
				self.cmbNewTrans.addItem(TI_TRANSMODE_SHIP_STR);
				self.cmbNewTrans.setIndex(INDEX);				
			endif;
		endif;
		self.height := self.minimumHeight;
		
	elseif _wodTI.isWodRelease then
		wodRelease := _wodTI.CM_WodRelease;
		if _transStr = TI_TRANSMODE_ROAD_STR then
			self.cmbNewTrans.addItem(TI_TRANSMODE_RAIL_STR);
			self.cmbNewTrans.addItem(TI_TRANSMODE_SHIP_STR);
			self.cmbNewTrans.setIndex(INDEX);
			
		elseif _transStr = TI_TRANSMODE_RAIL_STR then
			self.cmbNewTrans.addItem(TI_TRANSMODE_ROAD_STR);
			self.cmbNewTrans.addItem(TI_TRANSMODE_SHIP_STR);
			self.cmbNewTrans.setIndex(INDEX);
			
		elseif _transStr = TI_TRANSMODE_SHIP_STR then
			self.cmbNewTrans.addItem(TI_TRANSMODE_ROAD_STR);
			self.cmbNewTrans.addItem(TI_TRANSMODE_RAIL_STR);
			self.cmbNewTrans.setIndex(INDEX);
			
		endif;
		
		releaseRequest := wodRelease.myReleaseRequest;
		if releaseRequest &lt;&gt; null and
			releaseRequest.releaseByType
		then //If we are a release by type then show the quantity text box and reorganise the ui
			self.lblNewBol.visible				:= false;	//Can be removed
			self.lblNewBook.visible				:= false;	//Can be removed
			self.lblNewReleaseRequest.visible	:= true;	//Can be removed
			self.lblQuantity.visible := true;
			self.txtQuantity.visible := true;
			self.grpCompletedCargo.parentAspect := 0;
			self.grpCompletedCargo.relativeHeight := false;
			self.grpTransport.height += 25;
			self.grpCargo.top += 25;
			self.grpCompletedCargo.top += 15;					// ### TFS 63647 (63694) 17Apr2024 NAVPW1
			
			//Increment the minimum height to 25 in case form is smaller. Form will automatically resize to be bigger
			self.minimumHeight += 25; 							// ### TFS 63647 (63694) 17Apr2024 NAVPW1
			
			//Need to reset parent bottom offset as it is changed when height of form is changed.
			self.grpCompletedCargo.parentBottomOffset := 31;	// ### TFS 63647 (63694) 17Apr2024 NAVPW1
			
			self.grpCompletedCargo.parentAspect := 3;
			self.grpCompletedCargo.relativeHeight := true;
			
		endif;
		
	endif;
epilog

end;</source>
        <Parameter name="_transStr" type="String"/>
        <Parameter name="_wodTI" type="CM_WorkOrderTIDtl"/>
    </JadeMethod>
    <JadeMethod name="showColumnOrganiser" id="8814e3c7-f43b-4cb1-bcfe-58535aa64b43">
        <source>showColumnOrganiser();
/*

Purpose:			

Parameters:			

Return Value:		

Date		           Who		Reason
02 Feb 2023	navhl20	ChangeRequest 56631:[56185] EUP - Transport Mode change - UI Changes

*/

vars

begin
	if self.mnuColumnOrganiser.userObject = self.tblPendingCargo then
		self.tblPendingCargo.showColumnOrganiserFrm(self.myTerminal,null);
	elseif self.mnuColumnOrganiser.userObject = self.tblCompletedCargo then
		self.tblCompletedCargo.showColumnOrganiserFrm(self.myTerminal, null);
	endif;
epilog

end;</source>
    </JadeMethod>
