    <JadeMethod name="freightForwarderVerify" id="6517f79b-5135-4f33-8cf4-08309f8971e1">
        <source>freightForwarderVerify(_terminal: CM_Terminal) :String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
31 May 2017	cnwndl1	Initial creation	TFS 4456

*/

vars

	returnValue : Integer;
	message: String;
	consignee : CM_ConsigneeConsignor;

begin

	returnValue := VALID;

	if self.freightForwarder.trimBlanks &lt;&gt; null then
		
		consignee := app.myRoot.allConsigneeConsignors[ self.freightForwarder.trimBlanks ];
		
		if consignee = null then
			message := " " &amp; app.getErrorString1( ERR_INVALID_FreightForwarder, self.freightForwarder.trimBlanks );
			returnValue := WARNING;
		elseif not consignee.isFreightFwdr then
			message := " " &amp; app.getErrorString1( FreightForwarderNotFlagged, self.freightForwarder.trimBlanks );
			returnValue := WARNING;
		endif;
	
	endif;

	return returnValue.String &amp; message;

epilog

end;</source>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="fullOrMTVerify" id="3e81eb36-6eeb-4b89-919f-4d11348f9e7b">
        <source>fullOrMTVerify(c: CM_Terminal) :String;
vars
	value: Integer;
	message: String;
begin
	value := WARNING;
	if fullOrMT = "F" or
	   fullOrMT = "E" or
	   fullOrMT = "L" or
	   fullOrMT = "B" then
		value := VALID;
	else
		message := "Must be F,E,L or B.";
	endif;
	return value.String &amp; message;
end;</source>
        <Parameter name="c" type="CM_Terminal"/>
        <ReturnType type="String"/>
    </JadeMethod>
