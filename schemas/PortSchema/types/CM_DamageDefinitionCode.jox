    <JadeMethod name="cnEcGetDuplicate" id="4ef59e0f-1cef-42ee-bd6a-a112b68304d3">
        <source>cnEcGetDuplicate(pFormat: CnEcXmlFormat; pInput: CnEcXmlStructureInstance): Object;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 September 2014	cnwndl1	Initial creation	Par 34893	

*/

vars

	code : String;
	damage : CM_DamageDefinitionCode;

begin

	code := self.cnEcXMLGetTheAttributeValue( pFormat, pInput, self.class.name, "code" ).String; 
	
	if code &lt;&gt; null then
		damage := app.myRoot.allDamageDefinitionCodes.getAtKey( code );
	endif;

epilog

	return damage;

end;</source>
        <Parameter name="pFormat" type="CnEcXmlFormat"/>
        <Parameter name="pInput" type="CnEcXmlStructureInstance"/>
        <ReturnType type="Object"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="b8c72e06-ea6d-4025-a5b4-2fc8a4904607">
        <updating/>
        <source>setForCreate(_pxyDamageCode : CM_DamageDefinitionCode) updating;
/*
----------   ----------  --------------------------------------------------
Created:	19 September 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars

begin
	self.setForUpdate(_pxyDamageCode);

end;


</source>
        <Parameter name="_pxyDamageCode" type="CM_DamageDefinitionCode"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="59d40c49-822e-4854-b0c4-26531fe2ace9">
        <updating/>
        <source>setForUpdate(_pxyDamageCode : CM_DamageDefinitionCode) updating;
/*
----------   ----------  --------------------------------------------------
Created:	19 September 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars

begin
	self.code 		:= _pxyDamageCode.code;
	self.description:= _pxyDamageCode.description;
	
	self.allCargoTypes.clear();
	_pxyDamageCode.allCargoTypes.copy(self.allCargoTypes);
	
	//epr par 35332 15/12/14
	self.allMachineTypesByType.clear();
	_pxyDamageCode.allMachineTypesByType.copy(self.allMachineTypesByType);
	
	self.myRoot 	:= app.myRoot;
	

end;


</source>
        <Parameter name="_pxyDamageCode" type="CM_DamageDefinitionCode"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="1df09098-b6ff-494c-8bc5-c1ad0aada0dc">
        <updating/>
        <source>setProxy(_code,
		_description : String;
		_allCargoTypes : CM_ObjectSet;
		_machineTypes : CM_MachineTypeByTypeDict) updating;
/*
----------   ----------  --------------------------------------------------
Created:	19 September 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars

begin
	self.raiseExceptionIfNotTransient(method);
	
	self.code := _code;
	self.description := _description;
	
	// CCMS SFW1066 PAR20321 - Recording Damage Details Changes.
	self.allCargoTypes.clear();
	if _allCargoTypes &lt;&gt; null then
		_allCargoTypes.copy(self.allCargoTypes);
	endif;
		//epr par 35332 15/12/14
	self.allMachineTypesByType.clear();
	if _machineTypes &lt;&gt; null then
		_machineTypes.copy(self.allMachineTypesByType);
	endif;
end;


</source>
        <Parameter name="_code" type="String"/>
        <Parameter name="_description" type="String"/>
        <Parameter name="_allCargoTypes" type="CM_ObjectSet"/>
        <Parameter name="_machineTypes" type="CM_MachineTypeByTypeDict"/>
    </JadeMethod>
    <JadeMethod name="validateForCreate" id="80801bd2-8888-45c1-9de3-e0c15e6ac47c">
        <source>validateForCreate();
/*
----------   ----------  --------------------------------------------------
Created:	19 September 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars

begin
	self.validateForUpdate();

end;


</source>
    </JadeMethod>
    <JadeMethod name="validateForDelete" id="1b4f0821-a4b1-4260-a3aa-16b929236484">
        <source>validateForDelete();
/*
----------   ----------  --------------------------------------------------
Created:	19 September 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars

begin
	// 26/08/2009 	cnwsh3 		CCMS SFW1066 PAR20321 - Recording Damage Details Changes.
	/*if (not self.allDamageInstances.isEmpty) then
		app.raiseCMException1(Full_Replacement_Message, 'There are still cargo items with instances of this damage definition code.',null, null);
	endif;
	*/	
	//Replaced collection for to use new CM_DamagePositions
	if (not self.allDamageInstancesByDamagePos.isEmpty) then
		app.raiseCMException(There_still_cargo_items_with_i,null, null);
	endif;
	
	if (not self.allCargoTypes.isEmpty) then
		app.raiseCMException2(DamageCodeAllocatedCargoType, self.code, self.allCargoTypes.first.description ,null, null);
	endif;

end;


</source>
    </JadeMethod>
    <JadeMethod name="validateForUpdate" id="622e2e61-1dcf-46ac-88cf-76255f07161c">
        <source>validateForUpdate();
/*
----------   ----------  --------------------------------------------------
Created:	19 September 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
//13/06/2022 navds20 TFS 53760 DuplicateItem not Translatable
	
----------   ----------  --------------------------------------------------
*/
vars
	realDamageCode,
	existingDamageCode			: CM_DamageDefinitionCode;
begin
	if self.code = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Code', ETRow_Code, self);
		app.raiseCMException(Input_required_field_code, ETRow_Code, self); // cnwdb2	PAR 35364

	endif;
	
	if self.description = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Description', ETRow_Description, self);
		app.raiseCMException(Input_required_field_desc, ETRow_Description, self); // cnwdb2	PAR 35364


	endif;
	
	existingDamageCode	:= app.myRoot.allDamageDefinitionCodes[self.code];
	realDamageCode		:= self.pxyGetRealObject();
	
	if existingDamageCode &lt;&gt; null and
	   (realDamageCode = null or //in which case we are trying add a new one that is duplicate
	   existingDamageCode &lt;&gt; realDamageCode) //in which case we are trying update one to be same as another
	   then
		//app.raiseCMException2(DuplicateItem, "Damage definition code", self.code, null, null); //13.06.2022 navds20 53760
		// Damage definition code already exists for %1 : Damage_defini_code_alread_exis
		app.raiseCMException1(Damage_defini_code_alread_exis, self.code, null, null); //13.06.2022 navds20 53760
	endif;	

end;


</source>
    </JadeMethod>
</Class>
