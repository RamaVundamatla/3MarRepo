    </JadeMethod>
    <JadeMethod name="sendToEDBIC" id="4eb88127-c68a-4300-a4e9-dfa8a0e28945">
        <updating/>
        <source>sendToEDBIC(_heading, _url, _verb, _jsonPostData : String; _terminal : CM_Terminal; _activeCuxPortInterface : CM_CuxportServiceDef) : String protected, updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 Nov 2022	navpw1	Initial creation TFS: 55215
05 Apr 2023	navdap1	TFS 57362 CUX - Changes to Outgoing Message Formats
*/

vars
	resultCode		: Integer;
	jsonResponse	: String;
	pxyActivity, 
	requestActivity	: CM_EWSActivityEdBic;
	
begin
	if _jsonPostData = "null" then
		return null;
	endif;
	
	app.writeLog(method.qualifiedName &amp; Tab &amp; "Sending request to EDBIC: '" &amp; _jsonPostData &amp; "'", LogDEBUG);
	
	create pxyActivity transient;
	pxyActivity.initialiseActivity(	_heading, 
									_activeCuxPortInterface.name, 
									_terminal, 
									null,
									"A".Character,
									"Default",
									false,
									null	);
	pxyActivity.setRequest(_jsonPostData);	// ### TFS 57382 29Mar2023 NAVPW1
	requestActivity := app.myTrxCA.trxCreateEWSActivityHistory(pxyActivity, app.myPassport).CM_EWSActivityEdBic;
	delete pxyActivity;
	
	jsonResponse := self.doSendHTTPRequest(	_url,
											_verb,
											self.getAdditionalHeadersForHTTP(),
											_jsonPostData,
											resultCode);
	
	if resultCode &lt;&gt; HttpResponseOK and resultCode &lt;&gt; HttpResponseCreated then
		app.writeLog(method.qualifiedName &amp; Tab &amp; "Response from " &amp; _url &amp; " was " &amp; resultCode.String &amp; ":" &amp; jsonResponse, LogDEBUG);
		if resultCode = null then
			jsonResponse := "Connection Failure or Timeout";
		endif;
	endif;
	
	pxyActivity := app.createUpdateProxy(requestActivity).CM_EWSActivityEdBic;
	pxyActivity.setResponse(jsonResponse);
	pxyActivity.setResponseCode(resultCode);
	app.myTrxUA.trxUpdateEWSActivity(pxyActivity, app.myPassport);
	delete pxyActivity;
	
	return jsonResponse;
epilog
	delete pxyActivity;
end;</source>
        <access>protected</access>
        <Parameter name="_heading" type="String"/>
        <Parameter name="_url" type="String"/>
        <Parameter name="_verb" type="String"/>
        <Parameter name="_jsonPostData" type="String"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_activeCuxPortInterface" type="CM_CuxportServiceDef"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="sendTrainDepartureToEDBIC" id="de03d8ea-c2f0-4fd5-b26a-f7cbbf9160cf">
        <updating/>
        <source>sendTrainDepartureToEDBIC(_activeCuxPortInterface : CM_CuxportServiceDef; _train : CM_Train; _terminal : CM_Terminal) : Boolean updating;
//
// Purpose:			User Story 57370.140 Send Import Cargo Details to EDBIC for Cargo Released vi Rail
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 06/04/2023	navdap1		Initial creation TFS 57362 CUX - Changes to Outgoing Message Formats
// 17/04/2023	navdap1		TFS 57207 EUP - Refactor Inspection App API Message
// 20/06/2023	navdap1		TFS 58722 EUP "Class of object is invalid in this context" error when gating in cargo
//
vars
	extWebService			: CM_ExternalWebServiceDef;		// TFS 58722
	activeCuxPortInterface	: CM_CuxportServiceDef;
	wagon					: CM_Wagon;
	lc 						: CM_LocationsController;
	ti						: CM_TrackedItem;
	cargoOnly				: CMIF_JsonCargoOnlyCUX;
	cargo					: CMIF_JsonCargoCUX;
	jsonPostData			: String;
	methodType,
	endpointPath			: String;
	
begin
	extWebService := app.myRoot.getFirstActiveEWSForEndpoint( ETRow_TrainDepartureEDBIC );	// TFS 58722
	if extWebService &lt;&gt; null and extWebService.isEDBIC then									// TFS 58722
		activeCuxPortInterface := extWebService.CM_CuxportServiceDef;						// TFS 58722
	endif;																					// TFS 58722
	
	if activeCuxPortInterface = null then
		app.writeLog(method.qualifiedName &amp; Tab &amp; "No Train Departure Cuxport Interface defined", LogERROR);
		app.doRaiseAlert(method.qualifiedName &amp; Tab &amp; "No Train Departure Cuxport Interface defined");
		return false;
	endif;
	
	create cargoOnly transient;
	foreach wagon in _train.allWagonsByIdOutward do
		foreach lc in wagon.allLocationsControllers do
			foreach ti in lc.allTrackedItems where ti.isImport do
				create cargo transient;
				cargo.setFromTI(ti, false);
				cargoOnly.cargo.add(cargo);
			endforeach;
		endforeach;
	endforeach;
	// any data to send?
	if cargoOnly.cargo.isEmpty then
		app.writeLog(method.qualifiedName &amp; Tab &amp; "No Import cargo for train " &amp; _train.code &amp; " - no message sent", LogDEBUG); 
		return true;
	endif;
	
	cargoOnly.deserializeJSON(jsonPostData);
	app.writeLog(method.qualifiedName &amp; Tab &amp; "jsonPostData is " &amp; jsonPostData, LogDEBUG);
	
	// TFS 57207 start
	activeCuxPortInterface.getEndpointMethodAndValue(ETRow_TrainDepartureEDBIC, methodType, endpointPath);
	if methodType = null or endpointPath = null then
		app.writeLog(method.qualifiedName &amp; Tab &amp; activeCuxPortInterface.name &amp; " is not set up correctly for " &amp; activeCuxPortInterface.name &amp; Space &amp; ETRow_TrainDepartureEDBIC &amp; " messages", LogERROR);
		app.doRaiseAlert(activeCuxPortInterface.name &amp; " is not set up correctly for " &amp; activeCuxPortInterface.name &amp; Space &amp; ETRow_TrainDepartureEDBIC &amp; " messages");
		return true;
	endif;
	// TFS 57207 end
	self.sendToEDBIC(method.qualifiedName, activeCuxPortInterface.baseEndpoint &amp; "/" &amp; endpointPath, methodType, jsonPostData, _terminal, activeCuxPortInterface);
	return true;
	
epilog
	delete cargoOnly;
end;</source>
        <Parameter name="_activeCuxPortInterface" type="CM_CuxportServiceDef"/>
        <Parameter name="_train" type="CM_Train"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="sendTruckArrivalToEDBIC" id="53c2959f-2bc3-4059-a6e6-a191d12cbae0">
        <updating/>
        <source>sendTruckArrivalToEDBIC(_activeCuxPortInterface : CM_CuxportServiceDef; _vehicleVisit : CM_VehicleVisitRecord; _terminal : CM_Terminal) : Boolean updating;
//
// Purpose:			User Story 57370.170 Send Road Jobs for Visy-Integration to EDBIC
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 06/04/2023	navdap1		Initial creation TFS 57362 CUX - Changes to Outgoing Message Formats
// 17/04/2023	navdap1		TFS 57207 EUP - Refactor Inspection App API Message
// 20/06/2023	navdap1		TFS 58722 EUP "Class of object is invalid in this context" error when gating in cargo
//
vars
	extWebService			: CM_ExternalWebServiceDef;		// TFS 58722
	activeCuxPortInterface	: CM_CuxportServiceDef;
	gteEntity				: CMGTE_Entity;
	roadJob					: CMIF_JsonRoadJobCUX;
	cargo					: CMIF_JsonCargoCUX;
	jsonPostData			: String;
	methodType,
	endpointPath			: String;
	
begin
	extWebService := app.myRoot.getFirstActiveEWSForEndpoint( ETRow_TruckArrivalEDBIC );	// TFS 58722
	if extWebService &lt;&gt; null and extWebService.isEDBIC then									// TFS 58722
		activeCuxPortInterface := extWebService.CM_CuxportServiceDef;						// TFS 58722
	endif;																					// TFS 58722
	
	if activeCuxPortInterface = null then
		app.writeLog(method.qualifiedName &amp; Tab &amp; "No Truck Arrival Cuxport Interface defined", LogERROR);
		app.doRaiseAlert(method.qualifiedName &amp; Tab &amp; "No Truck Arrival Cuxport Interface defined");
		return false;
	endif;
	
	create roadJob transient;
	roadJob.driverCode := _vehicleVisit.driverCode;
	roadJob.driverName := _vehicleVisit.driversName;
	roadJob.interchangeArea := _vehicleVisit.transferAreaId;
	roadJob.truckRegNbr := _vehicleVisit.regNumber;
	roadJob.vehicleVisitNumber := _vehicleVisit.visitNumber;
	foreach gteEntity in _vehicleVisit.allGateEntities do
		create cargo transient;
		if not gteEntity.isRecievalByType and gteEntity.isReceipt then	//15.Mar.24 navsp1 TFS 62947
			cargo.setFromGTEReceival(gteEntity.CMGTE_Receival);
			roadJob.cargoReceived.add(cargo);
		elseif gteEntity.isRelease then
			cargo.setFromGTERelease(gteEntity.CMGTE_Release);
			roadJob.cargoReleased.add(cargo);
		endif;
	endforeach;
	
	roadJob.deserializeJSON(jsonPostData);
	app.writeLog(method.qualifiedName &amp; Tab &amp; "jsonPostData is " &amp; jsonPostData, LogDEBUG);
	
	// TFS 57207 start
	activeCuxPortInterface.getEndpointMethodAndValue(ETRow_TruckArrivalEDBIC, methodType, endpointPath);
	if methodType = null or endpointPath = null then
		app.writeLog(method.qualifiedName &amp; Tab &amp; activeCuxPortInterface.name &amp; " is not set up correctly for " &amp; activeCuxPortInterface.name &amp; Space &amp; ETRow_TruckArrivalEDBIC &amp; " messages", LogERROR);
		app.doRaiseAlert(activeCuxPortInterface.name &amp; " is not set up correctly for " &amp; activeCuxPortInterface.name &amp; Space &amp; ETRow_TruckArrivalEDBIC &amp; " messages");
		return true;
	endif;
	// TFS 57207 start
	self.sendToEDBIC(method.qualifiedName, activeCuxPortInterface.baseEndpoint &amp; "/" &amp; endpointPath, methodType, jsonPostData, _terminal, activeCuxPortInterface);
	return true;
	
epilog
	delete roadJob;
end;</source>
