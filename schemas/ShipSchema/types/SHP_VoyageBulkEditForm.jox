    <JadeMethod name="displayDetail" id="0084b496-f73d-4f21-957a-dc99e64cfa1f">
        <source>displayDetail(_obj : Any) : String;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 11/06/2021	navdap1		Initial creation TFS 51326 ASPA Bulk Edit Voyages
//
vars
	voyage : CM_Voyage;

begin
	if _obj = null then
		return null;
	endif;
	
	voyage := _obj.CM_Voyage;
	return voyage.code &amp; Space &amp; voyage.vesselName;
epilog

end;</source>
        <Parameter name="_obj" type="Any"/>
        <ReturnType type="String"/>
    </JadeMethod>
