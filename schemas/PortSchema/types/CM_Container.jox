//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
vars
	theContentsStatus		: CM_ContentsStatus;
begin
	theContentsStatus := app.myRoot.allContentsStatuses[self.contentsStatus];
	
	if theContentsStatus = null then
		app.raiseCMException1(ERR_INVALID_CONTENTS_STATUS, self.contentsStatus.String, 'contents status', null);
	endif;

end;</source>
