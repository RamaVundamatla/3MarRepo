        <source>toolbarShowCaptions(_showCaptions: Boolean) updating;
// ---------------------------------------------------------------------------
// Created:     07 December 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin

	// need to reset the width of the searcher to
	// allow all the buttons to show in full
	if _showCaptions then
		//cnwsh3 04/03/2006 Change from 380 to 390 to allow for new font for 7.4.2.  Close Search Icon was being cut off.
		self.frmSearch.width := CargoEnqSearchWidthWithCaption;//380;  
	else
		frmSearch.width := FrmSearchStdWidth;
	endif;
	
	inheritMethod(_showCaptions);
	

end;</source>
