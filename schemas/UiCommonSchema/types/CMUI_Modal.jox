    <JadeMethod name="setAssistantAndTerminalRefs" id="fee17f67-525b-4bef-b17c-80be5e8f3886">
        <updating/>
        <source>setAssistantAndTerminalRefs(_assistant : CMUI_Assistant; _terminal : CM_Terminal) updating;
// ---------------------------------------------------------------------------
// Created:     19 July 2002 by cnwrs2
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	if _assistant &lt;&gt; null then
		self.createMyAssistant(_assistant.class);
	endif;
	
	self.setMyTerminal(_terminal);

end;</source>
        <Parameter name="_assistant" type="CMUI_Assistant"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="translateForm" id="c5cf4312-d661-4a2e-b1a3-b5803a91e220">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
//	self.translateCaption(Xlat_0017433, locale);
	btnCancel.translateCaption(Xlat_0014573, locale);
	btnOk.translateCaption(Xlat_0014574, locale);
end;</source>
    </JadeMethod>
    <JadeMethod name="unload" id="4380ccb1-154a-499d-bff1-0cab2b1a70b8">
        <controlMethod name="Form::unload"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>unload() updating;

vars

begin
	self.modalResult := self.modalResult;
	
	inheritMethod(); // par14139 Mohammad 6/6/2007
	
end;</source>
    </JadeMethod>
</GUIClass>
