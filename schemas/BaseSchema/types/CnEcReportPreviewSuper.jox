<GUIClass name="CnEcReportPreviewSuper" id="0e71485a-e9a1-4dec-a24a-2e7494fb4ebf">
    <superclass name="CnEcReportBaseForm"/>
    <transient/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>___________________________________________________________________________

