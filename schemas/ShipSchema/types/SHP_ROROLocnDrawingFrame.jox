    <JadeMethod name="getPointsForObject" id="6c944187-087b-40df-b2fe-1d3286326d64">
        <source>getPointsForObject(_obj: Object; _x1: Integer output; _y1: Integer output; _x2: Integer output; _y2: Integer output): Boolean;
/*
Purpose:			
Date		Who		Reason
01 August 2011	cnwab1	Initial creation
*/

vars
	key1, key2 : Point;
begin


	if 	self.allDrawnObjects.findObjectInDictGetXY(_obj,key1, key2) then
		_x1 := key1.x;
		_y1 := key1.y;
		_x2 := key2.x;
		_y2 := key2.y;
 		
		return true;
	else
		return false;
	endif;
	
		


epilog

end;</source>
        <Parameter name="_obj" type="Object"/>
        <Parameter name="_x1" type="Integer" usage="output"/>
        <Parameter name="_y1" type="Integer" usage="output"/>
        <Parameter name="_x2" type="Integer" usage="output"/>
        <Parameter name="_y2" type="Integer" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="handleMouseMove" id="9c4a18f2-f9d5-4c4f-b2c1-f65d39540d0e">
        <updating/>
        <executionLocation>client</executionLocation>
        <source>handleMouseMove(frame: Frame input; button: Integer; shift: Integer; x: Real; y: Real) updating, clientExecution;
/*
Purpose:			
Date		Who		Reason
21 September 2011	cnwab1	Initial creation
*/

vars


	dragCursorObj	: Picture;
	tmpDrawController : SHP_ROROLocnDrawingController;
	tmpObj : Object;
	theLC : CM_LocationsController;
	theFrame : Frame;
	theTI : CM_TrackedItem;
	origX, origY : Real;
	planForm : SHP_ROROPlanningForm;
begin

	// TFS 2198 CNWAB1
	if self.myCargoSideViewForm &lt;&gt; null then
		if not app.myCurrentUserCan(self.myCargoSideViewForm.myTerminal, self.myCargoSideViewForm.permissionMaint) then
			return;
		endif;
	endif;


	tmpDrawController := self.myROROLocnDrawingController;
	theFrame := self;

	origX := self.myScrollingFrame.origXpos;
	origY := self.myScrollingFrame.origYpos;

	
	if button = Window.MouseButton_Left 
	and shift.hasNoKeyboardPressed() 
	and app.dragDetected(x, y, origX, origY) then	
	
		planForm := self.myROROLocnDrawingController.myCargoSideViewForm.myROROPlanningForm;
		// initiate a drag/drop
		// PAR 32149 tmpObj := self.getObjectForPosition(x.Integer, y.Integer);
		tmpObj := self.getObjectForPosition(origX.Integer, origY.Integer); // PAR 32149
		
		if not tmpObj.isKindOf(CM_LocationsController)  then
			return;
		endif;
		theLC := tmpObj.CM_LocationsController;
		
		theTI := theLC.getNextTIToBeOfMode(REAL_MODE); //planForm.moveModeForm);
		if theTI = null then
			return;
		endif;
		

		app.myDraggedTrackedItem := theTI;
		app.isDragging := true;
		
		planForm.setMoveControllerSource(theTI); // &lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;

		theFrame.dragMode	:=	self.DragMode_Drag;
		create dragCursorObj transient;

		planForm.setPictureDragCursor(dragCursorObj);
		if dragCursorObj &lt;&gt; null then
			theFrame.dragCursor	:=	dragCursorObj.picture;
		endif;
	endif;
epilog
	delete dragCursorObj;

end;</source>
        <Parameter name="frame" type="Frame" usage="input"/>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
