    <JadeMethod name="addJobToJobDtl" id="12daaa6c-5b0e-4b14-a356-77dbfca5155c">
        <source>addJobToJobDtl();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
31 July 2024	navnk30	Initial creation

*/

vars
	job : CM_Job;
	trx	: CM_Transaction;
	stO	: CM_StateReference;
begin
	beginTransaction;
		job := "2273.267354".asOid().CM_Job;
		trx := "15592.2779".asOid().CM_Transaction;
		create stO persistent;
		stO.set(job.getOidAsString(), job, trx);
epilog
	commitTransaction;
end;</source>
    </JadeMethod>
    <JadeMethod name="cmqfFilterObjs" id="e58b6b4a-cc95-4ab6-8d35-5477cb779a9a">
        <source>cmqfFilterObjs();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 September 2024	navnk30	Initial creation

*/

vars
	cmqfReal,
	qfCam		: CMQF_CamTransactionTemplate;
	jrwTrans	: CM_JRWTransaction;
	_camProtocol : CM_CamProtocol;
	_camAgent	: CM_CamControllerAgent;
	coll		: CM_TransactionSet;
begin
	app.initialize();
	cmqfReal	:= "10454.7".asOid().CMQF_CamTransactionTemplate;
	_camProtocol := "2173.864117".asOid().CM_CamProtocol;
	create _camAgent transient;
	
	qfCam := _camProtocol.myQFCamTransactionTemplate.cloneSelfAs(CMQF_CamTransactionTemplate, true).CMQF_CamTransactionTemplate;
	qfCam.cloneReferences(_camProtocol.myQFCamTransactionTemplate, true);
	create coll transient;
	qfCam.filterObjects(coll, app.myPassport);
	app.myQAFilter.qryTransactionsCam(qfCam, app.myPassport);
	jrwTrans := app.myQAFilter.allJRWTransients.first.CM_JRWCamTransaction;
epilog
	delete coll;
	delete jrwTrans;
end;</source>
    </JadeMethod>
