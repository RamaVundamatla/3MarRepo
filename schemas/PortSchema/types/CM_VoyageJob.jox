    <JadeMethod name="getJobNumSuffix" id="7b1cd6a8-b39a-4a3b-8df4-dae7b8f12750">
        <source>getJobNumSuffix(_jobNum : String) : String;
// ---------------------------------------------------------------------------
// Created:     cnwyl1  Yi Liu
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	tmpStr,
	rtn 	: String;
	length,
	pos		: Integer;	
	
begin
	tmpStr := _jobNum;
	length := jobNum.length();
	
	tmpStr := tmpStr.reverse();
	
	pos := 1;
	rtn := tmpStr.scanUntil("1234567890", pos).reverse;
	return rtn;
epilog

end;</source>
