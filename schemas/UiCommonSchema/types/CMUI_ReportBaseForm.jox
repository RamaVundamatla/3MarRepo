    <JadeMethod name="addRowToTable" id="33c48b44-0a9a-492c-9da9-77af3d5aaa84">
        <source>addRowToTable(pStr : String; _autoColumn : Boolean);
// ---------------------------------------------------------------------------
// Created:     30 October 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	row:             Integer;
	column:          Integer;
	accessMode:      Integer;
	tmpStr		: String;
	
begin

	row := self.tblReport.addItem(pStr);
	self.tblReport.accessMode := self.tblReport.AccessMode_Cell;
	
	foreach column in 1 to self.tblReport.columns do
		if (not self.tblReport.columnVisible[column]) then
			self.tblReport.columnWidth[column] := 0;
			continue;
		endif;
	
		if _autoColumn then	
			tmpStr := self.tblReport.accessCell(row, column).text;
			if row = 1 then
				self.tblReport.columnWidth[column] := self.tblReport.getTextExtent(tmpStr) + 4;
			else
				self.tblReport.columnWidth[column] := self.tblReport.columnWidth[column].max(tblReport.getTextExtent(tmpStr) + 4);
			endif;
		endif;
	endforeach;

end;</source>
        <Parameter name="pStr" type="String"/>
        <Parameter name="_autoColumn" type="Boolean"/>
    </JadeMethod>
