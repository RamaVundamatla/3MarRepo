    <JadeMethod name="addItem" id="23622451-883b-44af-b27c-2d5a6ebc58e7">
        <source>addItem(_text:String):Integer;
// --------------------------------------------------------------------------------
// Created:		20 February 2006 by cnwdad1
//
// Purpose:		Adds an object to the combobox control, with text.
//
// Parameters:	_text - The text to display for the entry.
//				_obj - A reference to the object for the entry.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return self.myComboBox.addItem(_text);
end;</source>
        <Parameter name="_text" type="String"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
