<Class name="CM_InvoiceAllocationConfig" id="3794ca59-ce00-42fc-aa41-67486a36616c">
    <superclass name="CM_YAIMEXConfig"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="yardAllocations"/>
    <ExplicitInverseRef name="myDebtorTypeForDerivation" id="08234c38-65b6-4757-9a6f-19f6999e1374">
        <transientToPersistentAllowed/>
        <updateMode>manual</updateMode>
        <embedded/>
        <type name="CM_DebtorType"/>
        <Inverse name="CM_DebtorType::allInvoiceAllocationConfigs"/>
    </ExplicitInverseRef>
    <ExplicitInverseRef name="myTranMapInventory" id="3c0e6ab5-0cb2-4a3e-ac55-a584a776b603">
        <transientToPersistentAllowed/>
        <embedded/>
        <type name="CM_TranMapInventoryAllocation"/>
        <Inverse name="CM_TranMapInventoryAllocation::myInvoiceAllocationConfig"/>
    </ExplicitInverseRef>
    <ExplicitInverseRef name="myTransactionMap" id="525bcde8-595b-42a9-85b8-bb65ae4cc504">
        <kind>child</kind>
        <transientToPersistentAllowed/>
        <updateMode>manual</updateMode>
        <embedded/>
        <type name="CM_TranMapCargoAllocation"/>
        <Inverse name="CM_TranMapCargoAllocation::myInvoiceAllocationConfig"/>
    </ExplicitInverseRef>
    <JadeMethod name="auditId" id="fde5f42b-56ed-42ba-b758-cb488b93bb55">
        <source>auditId(): String;
// --------------------------------------------------------------------------------
// Created:		7 December 2009 by cnwjo3
//
vars

begin
	if self.myTransactionMap &lt;&gt; null then
		return self.myTransactionMap.auditId &amp; " - Cargo Invoice Allocation Config";
	endif;
	if self.myTranMapInventory &lt;&gt; null then // ### TFS 51219 25MAY2021 NAVAB1
		return self.myTranMapInventory.auditId &amp; " - Inventory Allocation Config"; // ### TFS 51219 25MAY2021 NAVAB1
	endif;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="1b5a6e14-f9c3-4e05-8fb6-3ea91a913208">
        <source>pxyCreateUpdateProxy(): SelfType;
/*
Purpose:			
Date				Who			Reason
MARCH 2015		CNWAB1		Initial creation
*/

vars
	pxy	: CM_InvoiceAllocationConfig;
	completedOK		: Boolean;
begin
	pxy := inheritMethod();

	pxy.myTransactionMap := self.myTransactionMap;
	pxy.myTranMapInventory := self.myTranMapInventory; // ### TFS 51219 25MAY2021 NAVAB1
	pxy.myDebtorTypeForDerivation := self.myDebtorTypeForDerivation;
	
	completedOK := true;		
	return pxy;
	
epilog
	if not completedOK then			
		delete pxy;
	endif;	
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="removeDeletedCriteriaTypes" id="9caf6a69-4b9a-4a07-97d5-cbbfcc4b2c4a">
        <updating/>
        <source>removeDeletedCriteriaTypes(_typeArray : IntegerArray) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 03/12/2019	jlgdap1		Initial creation TFS 47755 STWO
//
vars
	typeToDelete : Integer;
	criteriaToDelete : ObjectArray;
	tranMapAllocation : CM_TranMapCargoAllocation;
	yardAlloc : CM_YardAllocation;
	allocation : CM_InvoiceCargoAllocation;
	criteria : CM_YACriteria;

begin

	 // ### TFS 51219 25MAY2021 NAVAB1
	if self.myTransactionMap &lt;&gt; null then
		self.myTransactionMap.removeDeletedCriteriaTypes(_typeArray);
	elseif self.myTranMapInventory &lt;&gt; null then
		self.myTranMapInventory.removeDeletedCriteriaTypes(_typeArray);
	else
		return;
	endif;

/*  // ### TFS 51219 25MAY2021 NAVAB1 - Refactor
	tranMapAllocation := self.myTransactionMap;
	if tranMapAllocation = null then
		return;
	endif;
	
	create criteriaToDelete transient;
	
	foreach yardAlloc in tranMapAllocation.allInvoiceCargoAllocations discreteLock do
		allocation := yardAlloc.CM_InvoiceCargoAllocation;
		foreach criteria in allocation.allCriteriaByType discreteLock do
			if _typeArray.includes(criteria.myYACriteriaType.type)
			and criteria.myYACriteriaType.isBooleanType then
				criteriaToDelete.add(criteria);
			endif;
		endforeach;
	endforeach;
	
	criteriaToDelete.purge;
	*/
epilog
	delete criteriaToDelete;
end;</source>
        <Parameter name="_typeArray" type="IntegerArray"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="a688b9f1-8261-4cc2-b5c7-04d93c6c52ea">
        <updating/>
        <source>setForUpdate(_pxy : CM_InvoiceAllocationConfig) updating;
/*
Purpose:			
Date		Who			Reason
MARCH 2015	CNWAB1		Initial creation
30 May 2017	cnwkpd1		TFS #4542 - Invoicing performance changes
21 Jun 2017	cnwma1 TFS #4498 JMT - Cargo Allocation Fix Up Export Script
02 Dec 2019	jlgdap1		TFS 47755 STWO JMT ignores full/empty on transaction when resynchronising
*/
vars
	criteriaType,
	dependentTxtType: CM_YACriteriaType;
	typesToDelete : IntegerArray;				// TFS 47755
	
begin
	// TFS 47755 See of any of the criteria that have been removed are of Boolean type
	// We have to go through all cargo allocations on the tran map and remove the deleted
	// boolean criteria
	create typesToDelete transient;
	foreach criteriaType in self.allOpCriteria do
		if criteriaType.isBooleanType and not _pxy.allOpCriteria.includes(criteriaType) then
			typesToDelete.add(criteriaType.type);
		endif;
	endforeach;
	self.removeDeletedCriteriaTypes(typesToDelete);
	// TFS 47755 end
	
	self.allOpCriteria.clear;
	_pxy.allOpCriteria.copy(self.allOpCriteria);

	if self.myTranMapInventory &lt;&gt; null then // ### TFS 51219 25MAY2021 NAVAB1
		// ### HARD CODE INVENTORY TYPE
		criteriaType := app.myRoot.allYACriteriaTypes[YACriteriaType_InventoryType]; // ### TFS 51219 25MAY2021 NAVAB1
	
	elseif self.myTransactionMap &lt;&gt; null then
		// ### HARD CODE TRANSACTION TYPE
		criteriaType := app.myRoot.allYACriteriaTypes[YACriteriaType_TransactionType];
		dependentTxtType:=app.myRoot.allYACriteriaTypes[YACriteriaType_TrxToDoResource];
		
	endif;
	
	if not self.allOpCriteria.includes(criteriaType) then    //21/2017 cnwma1 TFS #4498
		self.allOpCriteria.add(criteriaType);
	endif;
	
	//jlier1 TFS  63834 13/5/24
	if dependentTxtType &lt;&gt; null and self.allOpCriteria.includes(dependentTxtType) then
		//removed and add to the end so it is always after Transaction type, because it is dependent on transaction type
		self.allOpCriteria.remove(dependentTxtType);
		self.allOpCriteria.add(dependentTxtType);
	endif;
	self.myDebtorTypeForDerivation := _pxy.myDebtorTypeForDerivation;
	
	self.myTransactionMap := _pxy.myTransactionMap;
	self.myTranMapInventory := _pxy.myTranMapInventory; // ### TFS 51219 25MAY2021 NAVAB1
	
	// TFS #4542
	// After a possible change to the configured criteria, need to recalculate all priorities for the owning
	// transaction map
	if self.myTransactionMap &lt;&gt; null then
		self.myTransactionMap.recalcAllocationPriorities();
	endif;
	if self.myTranMapInventory &lt;&gt; null then // ### TFS 51219 25MAY2021 NAVAB1
		self.myTranMapInventory.recalcAllocationPriorities(); // ### TFS 51219 25MAY2021 NAVAB1
	endif;

epilog
	delete typesToDelete;			// TFS 47755
end;</source>
        <Parameter name="_pxy" type="CM_InvoiceAllocationConfig"/>
    </JadeMethod>
    <JadeMethod name="setProxyInvoiceAllocation" id="15bcd3c5-9fe6-4990-a552-8ca7ee6db2c6">
        <updating/>
        <source>setProxyInvoiceAllocation(_opCriteriaColl: CM_YACriteriaTypeArray; _debtor : CM_DebtorType; _tranMap : CM_TranMapCargoAllocation input; _tranmapInvent : CM_TranMapInventoryAllocation) updating;
/*
Purpose:			
Date		Who		Reason
12 March 2015	cnwab1	Initial creation
*/

vars

begin

	self.allOpCriteria.clear;
	_opCriteriaColl.copy(self.allOpCriteria);

	self.myTransactionMap := _tranMap;
	self.myTranMapInventory := _tranmapInvent;  // ### TFS 51219 25MAY2021 NAVAB1
	
	self.myDebtorTypeForDerivation := _debtor;
epilog

end;</source>
        <Parameter name="_opCriteriaColl" type="CM_YACriteriaTypeArray"/>
        <Parameter name="_debtor" type="CM_DebtorType"/>
        <Parameter name="_tranMap" type="CM_TranMapCargoAllocation" usage="input"/>
        <Parameter name="_tranmapInvent" type="CM_TranMapInventoryAllocation"/>
    </JadeMethod>
    <JadeMethod name="validateForUpdate" id="0baf95db-b92e-4c5c-9f91-70a7619116fb">
        <source>validateForUpdate();
/*
Purpose:			
Date				Who			Reason
MARCH 2015		CNWAB1		Initial creation
*/
vars

	iter : Iterator;
	ya : CM_YardAllocation;
	yaCritType : CM_YACriteriaType;
	excludesArray : IntegerArray;

begin
//	if self.myDebtorTypeForDerivation = null then
//		app.raiseCMException(Please_select_debtor_type_deri,null,self);
//	endif;
	
	if self.allOpCriteria.isEmpty then
		app.raiseCMException(Please_select_some_alloca_crit,null,self);
	
	endif;
	
	if self.myTransactionMap = null
	and self.myTranMapInventory = null then  // ### TFS 51219 25MAY2021 NAVAB1
		app.raiseCMException(Please_transaction,null,self);
	
	else
	
		create excludesArray transient;
		excludesArray.add(YACriteriaType_TransactionType);  // can not be manually selected as part of the config so ignore it
		excludesArray.add(YACriteriaType_InventoryType);   // ### TFS 51219 25MAY2021 NAVAB1 -  can not be manually selected as part of the config so ignore it
	
		if self.myTransactionMap &lt;&gt; null then // ### TFS 51219 25MAY2021 NAVAB1
			iter := self.myTransactionMap.allInvoiceCargoAllocations.createIterator;
		else
			iter := self.myTranMapInventory.allInvoiceInventoryAllocations.createIterator; // ### TFS 51219 25MAY2021 NAVAB1
		
		endif;
			
			
		while iter.next( ya ) do
			yaCritType := ya.getCriteriaNotIncluded( self.allOpCriteria, excludesArray );
			if yaCritType &lt;&gt; null then
				app.raiseCMException2( Not_remove_criteria, yaCritType.description, ya.code, null, self );
				break;
			endif;
		endwhile;
	
	endif;
	
epilog

	delete iter;
	delete excludesArray;
	
end;</source>
    </JadeMethod>
</Class>
