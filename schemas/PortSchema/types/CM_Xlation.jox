    <JadeMethod name="validateMe" id="1f1990f0-642c-4dc4-8638-1a38a07d4813">
        <source>validateMe();
// ---------------------------------------------------------------------------
// Created:     02 July 2003 by cnwrs1
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 13/03/2013	cnwcs5		CCMS POL 2097 / par 31259 - transaltion criteria
// 15/02/2023	jlizm1		TFS 56604 CSV Import of translation terms - improve error messages
// ---------------------------------------------------------------------------
vars
	pxyXlationTable, xlationTable	:CM_XlationTable;
	xlation_In		:CM_Xlation;
	sysObject		: CM_Object;
	
begin
	if self.foreignCode = null then
//		app.raiseCMException1(REQUIRED_FIELD, 'Xlation Foreign code', null, null);
		app.raiseCMException(Input_required_field_xlatForei, null, null); // cnwdb2	PAR 35364
	endif;
	
	if self.systemCode = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Xlation System code', null, null);
		app.raiseCMException(Input_required_field_xlatSys, null, null); // cnwdb2	PAR 35364
	endif;
	
	pxyXlationTable := self.myXlationTable;

	if pxyXlationTable = null then
		// we expect GUI to take care of this
		app.raiseUnexpectedProgramError (self.class.name, method.name, "Xlation table missing");
		return;
	endif;
	
	xlationTable := pxyXlationTable.pxyGetRealObject;
	
	if xlationTable = null then
		// make sure the translation table is set up correctly - we expect the form to do this for us
		pxyXlationTable.validateForCreate;
		
	endif;
	
	if pxyXlationTable.requiresSystemObj then
		sysObject := self.getObjectForSystemCode(pxyXlationTable.type, pxyXlationTable.getMyTerminal);
		if sysObject = null then
			app.raiseCMException1(Object_not_found_sys_code, self.systemCode, null, null);
		endif;
	endif;
	
end;</source>
    </JadeMethod>
</Class>
