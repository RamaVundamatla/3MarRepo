    <JadeMethod name="createVessel" id="39ab9f2d-27c2-4772-bf8d-c5e1fc666810">
        <source>createVessel(): CM_Vessel protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 August 2018	jlger1	Initial creation 40523

*/

vars
	pxyVessel,			
	realVessel 			: CM_Vessel;
	conflictManager 	: CMIF_HMS_ConflictsManager;	
	proxyXlation 	 	: CM_XlationTable;
	pxyXlationIn			:CM_Xlation_In;
begin
	create pxyVessel transient;
	pxyVessel.setProxyForInaPortnetPKK(self,app.myPassport.myTerminal);
	app.myPassport.setWarningsIgnored(true);
	app.myTrxCA.trxCreateVessel(pxyVessel,realVessel,conflictManager,app.myPassport);
	
	if app.myPassport.hasErrors then
		return null;
	endif;
	
	if self.kapalNama.length &gt; 25 then
		//should probably create a translation because I have just defaulted to the first 25 characters 
		create proxyXlation transient;
		proxyXlation.setProxy (XLATION_TYPE_VESSEL, app.myRoot, null, null, null,null);
		create pxyXlationIn as CM_Xlation_In transient;
		pxyXlationIn.setProxy (realVessel.code, self.kapalNama, proxyXlation);
		app.myPassport.setWarningsIgnored(true);
		app.myTrxUA.trxUpdateXlation(proxyXlation, app.myPassport);
	endif;
	
	return realVessel;
	
epilog
	delete pxyVessel;
	delete conflictManager;

end;</source>
        <access>protected</access>
        <ReturnType type="CM_Vessel"/>
    </JadeMethod>
    <JadeMethod name="createVoyage" id="024f0830-018d-4a2e-9ae9-2293ffa25aa5">
        <source>createVoyage() : CM_Voyage;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 September 2018	jlger1	Initial creation
 11/10/2021	jlier1		TFS 51963
*/

vars
	voyage : CM_Voyage ; 
	vessel : CM_Vessel ;
	term : CM_Terminal;
	newVoyageCode : String;
	voyageNum : Integer;
	pxyVoyage : CM_Voyage;
	load : Boolean;
	createStructure : Boolean;
	conflictManager : CMIF_HMS_ConflictsManager;							
	cmifPKK : CMIF_IPNPKKItem;
	validStatuses : IntegerArray;
	voyageStatus : CM_VoyageStatus;
	currentStatus : CM_VoyageStatus;
	voyageStatusStr : String;
	operator : CM_Operator;	//06 Nov 2018	NDL	TFS 41829
begin

	
	term := app.myPassport.myTerminal;
	
	app.setContinueCMExceptions(true);
	self.validateDetails();
	if app.myPassport.hasErrors then
		return null;
	endif;
	app.setContinueCMExceptions(false);
	
	voyage:=self.getVoyage;
	if voyage &lt;&gt; null then
		vessel:=voyage.myVessel;
	else
		vessel:= self.getVessel();
	endif;
	
	if vessel = null then
		//create the vessel
		vessel :=self.createVessel();  // epr tfs 40523 27/8/18
	else	//06 Nov 2018	NDL	TFS 41829
		operator := self.getOperator;
		if operator &lt;&gt; null then
			if vessel.myOperator &lt;&gt; operator then
				self.updateVesselOperator( vessel, operator );
				if app.myPassport.hasErrors then
					return null;
				endif;
			endif;
		endif;
	endif;
	
	if vessel = null then	
		return null;
	endif;
	voyageStatus :=app.myRoot.allVoyageStatuses.getAtKey( Voyage_Status_IVoyRequested );
	if voyage &lt;&gt; null then
		app.setContinueCMExceptions(true);
		// voyage must be Inaportnet process
		//if not voyage.isInaportnetVoyageProcess then
			app.raiseCMException2(Voyage_Not_Inaportnet, voyage.code, voyage.voyageCodeExternal, null, null);
		//endif;
		// and must be at the defined status
		//self.validateVoyageStatusForMsg( voyage );
		if voyageStatus &lt;&gt; null then
			currentStatus := voyage.getVoyageStatusObject;
			if currentStatus &lt;&gt; null then
				voyageStatusStr := currentStatus.description;
			endif;
			//
			create validStatuses transient;
			self.getValidCurrentStatuses( validStatuses );
			if not validStatuses.includes( voyage.status) then
				app.raiseCMException2( Voyage_incorr_status_this_acti, voyage.code, voyageStatusStr, null, null );
			endif;
		endif;
		
		app.setContinueCMExceptions(false);
		if app.myPassport.hasErrors then
			return null;
		endif;
	endif;
	
	 
// If voyage = null we are creating a new one, otherwise we are updating the existing one.
	if voyage = null then
	
		newVoyageCode := term.getNextVoyageCode( vessel, voyageNum, app.myPassport );
		
		pxyVoyage := vessel.createProxyVoyageRequest(	term,	//_terminal : CM_Terminal;
														newVoyageCode,	//_voyageCode : String;
														self.getOperator,	//_operator : CM_Operator;
														self.tanggalEta.asTimeStampFromInaportnet,	//_arrivalTS  : TimeStamp;
														self.tanggalEtd.asTimeStampFromInaportnet,	//_daysAtPort : Decimal;
														self.hasCargo,	//_hasCargo : Boolean;
														self.nomorPKK,	//_externalCode : String;
														null, //external ref
														self.getOriginPort,
														self.getLastPortOfCall,
														self.getNextPortOfCall,
														self.getLastPort,
														null,null,null,null,
														app.myRoot.allVoyageProcesses[VoyageProcessInaportnet],
														app.myPassport	//_passport : CM_Passport input
														);
					
	else
	
		app.cmsBeginLoad( load );
		pxyVoyage := voyage.pxyCreateUpdateProxy();
		app.cmsEndLoad( load );
		
	endif;

	
	
	// Update from some of what they have passed in, note some of these	are not actually used by us  YET!!!
	pxyVoyage.setProxyForInaPortnetPKK( self);
	
	
	createStructure := pxyVoyage.myCellularVoyageStructure &lt;&gt; null;
	if voyageStatus &lt;&gt; null then
		pxyVoyage.setStatusFromObject( voyageStatus );
	endif;
	
	app.myPassport.setWarningsIgnored(true);
	
	if voyage = null then	
		//epr TFS 42255 3/12/18
		app.myTrxCA.trxCreateVoyageRequest(pxyVoyage, vessel,self.getOperator, null, null,
											self.kodeAsalPelabuhan.trimBlanks,
											self.kodeTujuanPelabuhan.trimBlanks,
											self.kodeMuatPelabuhan.trimBlanks,
											self.kodeTujuanAkhirPelabuhan.trimBlanks,false,null,null,app.myPassport);
											
		voyage:=self.getVoyage;
	else
		app.myTrxUA.trxUpdateVoyage(createStructure, false, pxyVoyage, conflictManager, null, false, app.myPassport);
		
	endif;
	
	return voyage;
epilog
	delete cmifPKK;
	delete pxyVoyage;
	if conflictManager &lt;&gt; null then
		delete conflictManager;
	endif;
	app.cmsEndLoad( load );
end;</source>
        <ReturnType type="CM_Voyage"/>
    </JadeMethod>
    <JadeMethod name="getBerth" id="89794f6b-6e30-4428-8560-deaca70d0d17">
        <source>getBerth() : HMS_Berth;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 August 2018	jlger1	Initial creation

*/

vars
	harbour : HMS_Harbour;
	term 	: CM_Terminal;
	berth : HMS_Berth;

begin
	if self.dermagaNama = null then
		return null;
	endif;
	
	term := app.myPassport.myTerminal;
	
	harbour := term.myHarbour;
	if harbour &lt;&gt; null then
		foreach berth in harbour.allBerths discreteLock do
			if berth.externalReference2 = self.dermagaNama or
				berth.code=self.dermagaNama then
				return berth;
			endif;
		endforeach;
	endif;
	
	return null;
epilog

end;</source>
        <ReturnType type="HMS_Berth"/>
    </JadeMethod>
    <JadeMethod name="getLastPort" id="0c65f224-75ab-4d4a-a822-a02e4a748cdb">
