							_allVoyageJobs : CM_JobArray	);
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 16/12/2019	jlgdap1		Initial creation TFS 47144 JMT Refactor OOW Job Split Transfer
//
vars
	transForm : CMUI_SplitOrTransWorkCraneForm;
	job : CM_Job;
begin

	if _voyageJob = null then
		return;
	endif;
	
	transForm := app.loadForm(CMUI_SplitOrTransWorkCraneForm, CMUI_Assistant, false, false, true, self.myTerminal, null).CMUI_SplitOrTransWorkCraneForm;
	transForm.setDetails(_voyageJob,_selectedWLEs,_allVoyageJobs);
	transForm.setFormParent(app.mainForm);
	transForm.mode := transForm.Mode_Transfer;

	transForm.show();	
epilog

