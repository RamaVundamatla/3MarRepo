<Class name="CMIF_OutputField_Sum" id="bc69d5c0-b686-46e3-b8f3-cf6256c15315">
    <superclass name="CMIF_OutputField"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="query"/>
    <PrimAttribute name="sum" id="04fd906a-a1e9-48d9-98c7-53cf029a24df">
        <precision>23</precision>
        <scaleFactor>8</scaleFactor>
        <embedded/>
        <type name="Decimal"/>
        <access>readonly</access>
    </PrimAttribute>
    <JadeMethod name="getValue" id="d7798833-298c-4a41-8113-dc028091b70e">
        <source>getValue(): String;
// ---------------------------------------------------------------------------
// Created:     04 December 2008 by concms1
// Purpose:     CCMS SFW 1047 - Totals Only Lists
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 07/12/2009	cnwcs5		ccms 1028 - supress 0 values
// ---------------------------------------------------------------------------
vars
	value	:Decimal[23,8];
begin
	value := self.sum;		// cnwcs5 07/12/2009
	
	if value = 0 then		// cnwcs5 07/12/2009
		return null;		// cnwcs5 07/12/2009
	endif;					// cnwcs5 07/12/2009
	
	return value.roundedTo (self.decimals).asStringJMTWithPrecision (self.decimals, self.useSeperator);	// cnwcs5 07/12/2009
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="isSum" id="6bc38710-6f4e-478a-9c33-eba190031353">
        <source>isSum(): Boolean;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
08 December 2009	cnwndl1	Initial creation	CCMS 1023

*/

vars

begin
	return true;

epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="updateSelf" id="c3a905a6-8537-41b6-881a-2c4a4b562c84">
        <updating/>
        <source>updateSelf(_value: Any; _obj :Object) updating;
// ---------------------------------------------------------------------------
// Created:     04 December 2008 by concms1
// Purpose:     CCMS SFW 1047 - Totals Only Lists
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin 
	if _value.isKindOf (CM_SnapshotField_Sum) then
		self.sum := self.sum + _value.CM_SnapshotField_Sum.sum;
	else
		// assume decminal
		self.sum	:= self.sum + _value.Decimal;
	endif;
epilog

end;</source>
        <Parameter name="_value" type="Any"/>
        <Parameter name="_obj" type="Object"/>
    </JadeMethod>
</Class>
