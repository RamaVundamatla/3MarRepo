    <JadeMethod name="flipHorizontal" id="d3eb1c64-46ed-40f6-8895-22f8d7ab249a">
        <updating/>
        <source>flipHorizontal(_recenterLocation : Boolean) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
12 April 2010	cnwjk3	Initial creation

*/

vars

begin
	if self.myDisplayBuilder &lt;&gt; null and not self.myDisplayBuilder.canFlipH(self.drawMode) then
		return;
	endif;

	self.flipH := not self.flipH;
	
	if self.flipH then
		self.leftOffset := 0;
	else
		self.rightOffset := 0;
	endif;

	if _recenterLocation then
		self.resetScrollOffsets();
		self.resizeDrawingFrames();
		self.reDrawAreaFromLocation(self.myTargetLocation, self.drawMode);	
	else			
		// Code for flipping without re-centering on location
		self.resetScrollOffsets();
		self.resizeDrawingFrames();
		self.calcViewSizes();	
		self.reCalcColsForFlip();
		self.calcDrawRows();
		self.calcDrawCols();
		self.drawEverything();
	endif;

epilog

end;</source>
        <Parameter name="_recenterLocation" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="flipLandscapePortrait" id="930cfd3c-2d93-4bfb-9468-9e6e90aa71c2">
