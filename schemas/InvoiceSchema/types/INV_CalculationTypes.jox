    <JadeMethod name="setProxyFromTable" id="832db89f-910a-4658-8f23-76abe9c9dff7">
        <updating/>
        <source>setProxyFromTable(_pxyCalculationType : CM_CalculationType input) updating;
// ---------------------------------------------------------------------------
// Created:		January 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 20/05/2009	cnwdad1		PAR #17633.  Changed the Decimal and Real type casts to
//							instead use String::asDecimalJMT or asRealJMT methods.
//	Aug 2010	cnwjre1		Par 24024 quantity and rate hook code
// 23/08/2022	jlika1		TFS 54897 MTN - Days being charged is incorrect
// --------------------------------------------------------------------------------
vars
	booleans	: BooleanArray;
	integers	: IntegerArray;
	idx			: Integer;
	tmpCalcType	: Integer;
	ctUnit		: Integer;
	isCargo,
	isEvent,
	isVoyage, isWO, isInvent	: Boolean;
	pxyQtyRange	: CM_QuantityRange;
	rangeType  	: Integer;
	minAmt, maxAmt : Real;
	mesType : CM_MeasurementType;
	weightToUse, //02/10/2025	navkc1 JIRA 36149
	rateType : Integer;
	isBol : Boolean;	//31 Oct 2019	NDL	TFS 47100
begin
	create booleans transient;
	create integers transient;
	
	idx := self.cmbBlockUnit.listIndex;
	if idx &gt; 0 then
		ctUnit := self.cmbBlockUnit.itemData[idx];
	endif;
	
	mesType := self.cmbMesType.listObject.CM_MeasurementType;
	
	booleans.add(self.tblEntDetail.getValueByName(ETRow_Day1Chk).Boolean);
	booleans.add(self.tblEntDetail.getValueByName(ETRow_Day2Chk).Boolean);
	booleans.add(self.tblEntDetail.getValueByName(ETRow_Day3Chk).Boolean);
	booleans.add(self.tblEntDetail.getValueByName(ETRow_Day4Chk).Boolean);
	booleans.add(self.tblEntDetail.getValueByName(ETRow_Day5Chk).Boolean);
	booleans.add(self.tblEntDetail.getValueByName(ETRow_Day6Chk).Boolean);
	booleans.add(self.tblEntDetail.getValueByName(ETRow_Day7Chk).Boolean);
	
	idx := self.cmbCalcTypes.listIndex;
	if idx &gt; 0 then
		tmpCalcType := self.cmbCalcTypes.itemData[idx];
	endif;
	
	// PAR 31615
	if tmpCalcType = INV_CALC_TYPE_CARGOLENGTHCONVT
	or tmpCalcType = INV_CALC_TYPE_CARGOWEIGHTCONVT
	or tmpCalcType = INV_CALC_TYPE_CARGOVOLUMECONVT then
		mesType := self.cmbMesType.listObject.CM_MeasurementType;
		
		//02/10/2025	navkc1 JIRA 36144 
		if tmpCalcType = INV_CALC_TYPE_CARGOWEIGHTCONVT then
			weightToUse := self.cmbWeightToUse.listData(); 
		endif;
	endif;
	
	 // ### TFS 51219 28MAY2021 NAVAB1
	if tmpCalcType = INV_CALC_TYPE_INVENT_WEIGHT
	or tmpCalcType = INV_CALC_TYPE_INVENT_VOLUME
	or tmpCalcType = INV_CALC_TYPE_INVENT_QUANTITY then
		mesType := self.cmbMesType.listObject.CM_MeasurementType;
	endif;
	

	
	if tmpCalcType = INV_CALC_TYPE_WO_CARGOQUANTITY
	or tmpCalcType = INV_CALC_TYPE_WO_CARGOREVTONS
	or tmpCalcType = INV_CALC_TYPE_WO_CARGOVOLUME
	or tmpCalcType = INV_CALC_TYPE_WO_CARGOWEIGHT
	or tmpCalcType = INV_CALC_TYPE_WO_ETMAL_DAYS
	or tmpCalcType = INV_CALC_TYPE_WO_ETMAL_HOURS
	or tmpCalcType = INV_CALC_TYPE_WO_ETMAL_MINUTES
	or tmpCalcType = INV_CALC_TYPE_WO_PERMIT
	or tmpCalcType = INV_CALC_TYPE_WO_UNITS
	or tmpCalcType = INV_CALC_TYPE_WO_VALUEOF1
	//Start navtnr20 29-05-2023 54266
	or tmpCalcType = INV_CALC_TYPE_WO_RES_UNIT
	or tmpCalcType = INV_CALC_TYPE_WO_TIME_DAYS
	or tmpCalcType = INV_CALC_TYPE_WO_DAYS_FULL
	or tmpCalcType = INV_CALC_TYPE_WO_TIME_HOURS
	or tmpCalcType = INV_CALC_TYPE_WO_TIME_MINUT
	or tmpCalcType = INV_CALC_TYPE_WO_RES_WEIGHT
	or tmpCalcType = INV_CALC_TYPE_WO_RES_VOLUME
	or tmpCalcType = INV_CALC_TYPE_WO_RES_QUANTITY
	or tmpCalcType = INV_CALC_TYPE_WO_RES_QTYWGT
	or tmpCalcType = INV_CALC_TYPE_WO_RES_QTYVOL
	or tmpCalcType = INV_CALC_TYPE_WO_RES_QTYQTY then
	//End navtnr20 29-05-2023 54266
		isWO := true;
	elseif tmpCalcType = INV_CALC_TYPE_INVENT_WEIGHT // ### TFS 51219 28MAY2021 NAVAB1
	or tmpCalcType = INV_CALC_TYPE_INVENT_VOLUME // ### TFS 51219 28MAY2021 NAVAB1
	or tmpCalcType = INV_CALC_TYPE_INVENT_QUANTITY // ### TFS 51219 28MAY2021 NAVAB1
	or tmpCalcType = INV_CALC_TYPE_INVENT_VALUE1 then // ### TFS 51219 28MAY2021 NAVAB1
		isInvent := true; // ### TFS 51219 28MAY2021 NAVAB1

	elseif tmpCalcType = INV_CALC_TYPE_EVENT_GRT
	or tmpCalcType = INV_CALC_TYPE_EVENT_LENGTH
	or tmpCalcType = INV_CALC_TYPE_EVENT_TIME_DAYS
	or tmpCalcType = INV_CALC_TYPE_EVENT_TIME_HOURS
	or tmpCalcType = INV_CALC_TYPE_EVENT_TIME_MINUT
	or tmpCalcType = INV_CALC_TYPE_EVENT_UNIT
	or tmpCalcType = INV_CALC_TYPE_EVENT_DAYS_FULL then
		isEvent := true;
	
	//31 Oct 2019	NDL	TFS 47100
	elseif tmpCalcType = INV_CALC_TYPE_BOL_NUMITEMS
	or tmpCalcType = INV_CALC_TYPE_BOL_VALUEOF1
	or tmpCalcType = INV_CALC_TYPE_BOL_VOLUME
	or tmpCalcType = INV_CALC_TYPE_BOL_WEIGHT then
		isBol := true;
	
	// 24024 CCMS 1151 Aug 2010 cnwjre1 user hook code for invoice quantity and rate
	elseif self.cargoCalcTypes.includes(tmpCalcType) then
		isCargo := true;
	else
		isVoyage := true;
	endif;
	
	rangeType:=RANGETYPE_DEFAULT;
	if self.isEscalatingCharge then
		if self.isEscChargeRelToFSD then
			rangeType:=RANGETYPE_FSD_RELATIVE;
		endif;
	endif;

	//	CCMS SFW 1279 May 2012 Storage Escalating Charges
	// TFS 2105 if these were set up in a prior save which got errors, clear them before creating new ones which got duplicate keys on adding to this dictionary
	_pxyCalculationType.allQuantityRanges.purge();
	foreach idx in 1 to self.rangeStart.size do
		create pxyQtyRange transient;
		pxyQtyRange.setup("", _pxyCalculationType, self.days[idx], 0, self.rangeStart[idx], self.rangeEnd[idx],rangeType);
	endforeach;

	// PAR 34764
	if tmpCalcType = INV_CALC_TYPE_TIMEBLCK_HRS_UNT 
	or tmpCalcType = INV_CALC_TYPE_TIMEBLCK_HRS_ONE 
	or tmpCalcType = INV_CALC_TYPE_VESSEL_TON then
		minAmt := self.tblEntDetail.getValueByName(ETRow_BlockRateMin).String.asDecimalJMT();
		maxAmt := self.tblEntDetail.getValueByName(ETRow_BlockRateMax).String.asDecimalJMT();
	else
		minAmt := self.tblEntDetail.getValueByName(ETRow_AmountMin).String.asDecimalJMT();
		maxAmt := self.tblEntDetail.getValueByName(ETRow_AmountMax).String.asDecimalJMT();
	endif;
	
	//22 Mar 2019	NDL	TFS 43687
	if self.cmbRateType.listIndex &lt; 1 then
		rateType := 0;
	else
		rateType := self.cmbRateType.itemData[ self.cmbRateType.listIndex ];
	endif;
	
	_pxyCalculationType.setProxy(booleans, 
								tmpCalcType,
								self.tblEntDetail.getValueByName(ETRow_Code).String,
								self.tblEntDetail.getValueByName(ETRow_Description).String,
								self.tblEntDetail.getValueByName(ETRow_HoursFree).String.asRealJMT(),
								self.tblEntDetail.getValueByName(ETRow_HoursMax).String.asRealJMT(),
								self.tblEntDetail.getValueByName(ETRow_HoursMin).String.asRealJMT(),
								self.tblEntDetail.getValueByName(ETRow_HoursBlock).String.asRealJMT(),
								self.range,
								
								self.tblEntDetail.getValueByName(ETRow_IsNotAvailableForEntryCk).Boolean,
								self.tblEntDetail.getValueByName(ETRow_TimeFrom).Time,
								self.tblEntDetail.getValueByName(ETRow_TimeTo).Time,
								minAmt, // PAR 34764
								maxAmt, // PAR 34764
								// PAR 34764 self.tblEntDetail.getValueByName(ETRow_AmountMin).String.asDecimalJMT(),
								// PAR 34764 self.tblEntDetail.getValueByName(ETRow_AmountMax).String.asDecimalJMT(),
								ctUnit,
								self.quantityHookSource,
								self.rateHookSource,
								self.remarkHookSource,		// 22/2/18 MAP TFS37124
								app.myPassport.userCode,
								isCargo,
								isVoyage, 
								isEvent,
								isWO, // TFS 39198
								self.cmbCalNormal.listObject.CM_Calendar,
								self.cmbCalExclusion.listObject.CM_Calendar,
								mesType,
								rateType,	//22 Mar 2019	NDL	TFS 43687
								isBol,	//30 Oct 2019	NDL	TFS 47100
								isInvent, // ### TFS 51219 25MAY2021 NAVAB1
								weightToUse //02/10/2025	navkc1 JIRA 36149
								);
epilog
	delete booleans;
	delete integers;
end;</source>
        <Parameter name="_pxyCalculationType" type="CM_CalculationType" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setupForm" id="7f3bcbaa-9375-4872-a1c4-6ae1e1441d1c">
        <updating/>
        <source>setupForm() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26 June 2024	navkc1	Initial creation

*/

vars

begin
	inheritMethod();
	//25/06/2024	navkc1 CR 64823 Task 64824
	self.frmTableFilter.setCallbackMethod(INV_CalculationTypes::doFilterTable.name); //25/06/2024	navkc1 CR 64823 Task 64824
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setupPermissions" id="c1fed4d2-cfc0-408a-8242-ef39d74bfa87">
        <updating/>
        <source>setupPermissions() updating;
// ---------------------------------------------------------------------------
// Created:     16 March 2005 by cnwrs2
//
// Purpose:  
//	July 2012 29755    user-defined calc types are valid for cargo and HMS - enable edit by permission only
// ---------------------------------------------------------------------------
vars
	canEdit		: Boolean;
begin
	
	canEdit := app.myPassport.myUser.canDo(null, self.permissionMaint);

	// does the user have maintenance premission for this form
	self.allowAdd		:= canEdit;
	self.allowDelete	:= canEdit;
	self.allowUpdate 	:= canEdit;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="showHookCodeMaintForm" id="638148d1-15eb-447b-aa9d-6c3918d0c345">
        <updating/>
        <source>showHookCodeMaintForm(_hookType : Integer) updating;
// 24024 CCMS 1151 Aug 2010 cnwjre1 user hook code for invoice quantity and rate
// 34489 CCMS SFW 1327 add hook code for HMS types
vars
	hookType	: CM_HookType;
	calcType 	: CM_CalculationType;
	isOK : Boolean;
	source		: String;
	constantText	: String;
	methodName	: String;
	parentClass	: Class;
	formCaption	: String;
begin

	hookType := app.myRoot.allHookTypes[_hookType];
	if hookType = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Hook Type is null for ' &amp; _hookType.String);
		return;
	endif;

	if self.myCurrentObject &lt;&gt; null then	// is for new item
		formCaption := "Calculation Type '" &amp; self.myCurrentObject.CM_CalculationType.description &amp; "'";
	else
		formCaption := "New Calculation Type";
	endif;
	if _hookType = HookType_InvoiceQuantity then
		source := self.quantityHookSource;
		constantText := app.getGlobalConstantText(HookTypes, "HookType_InvoiceQuantity");
		methodName := constantText.cnEcGetTagValueOfName('hookMethodName');
		parentClass := rootSchema.getSchema(PortSchemaName).getClass(constantText.cnEcGetTagValueOfName('hookClassType'));
	elseif _hookType = HookType_InvoiceRate then
		source := self.rateHookSource;
		constantText := app.getGlobalConstantText(HookTypes, "HookType_InvoiceRate");
		methodName := constantText.cnEcGetTagValueOfName('hookMethodName');
		parentClass := rootSchema.getSchema(PortSchemaName).getClass(constantText.cnEcGetTagValueOfName('hookClassType'));
	elseif _hookType = HookType_InvoiceRemarks then		// 22/2/18 MAP TFS37124
		source := self.remarkHookSource;
		constantText := app.getGlobalConstantText(HookTypes, "HookType_InvoiceRemarks");
		methodName := constantText.cnEcGetTagValueOfName('hookMethodName');
		parentClass := rootSchema.getSchema(PortSchemaName).getClass(constantText.cnEcGetTagValueOfName('hookClassType'));
	elseif _hookType = HookType_HMSInvoiceQuantity then
		source := self.quantityHookSource;
		constantText := app.getGlobalConstantText(HookTypes, "HookType_HMSInvoiceQuantity");
		methodName := constantText.cnEcGetTagValueOfName('hookMethodName');
		parentClass := rootSchema.getSchema(PortSchemaName).getClass(constantText.cnEcGetTagValueOfName('hookClassType'));
	elseif _hookType = HookType_HMSInvoiceRate then
		source := self.rateHookSource;
		constantText := app.getGlobalConstantText(HookTypes, "HookType_HMSInvoiceRate");
		methodName := constantText.cnEcGetTagValueOfName('hookMethodName');
		parentClass := rootSchema.getSchema(PortSchemaName).getClass(constantText.cnEcGetTagValueOfName('hookClassType'));
	endif;
	
	isOK := app.showHookCodeMaintForm2(hookType, source, (self.mode = self.Mode_View), methodName, parentClass, formCaption, true);
	if isOK and
	   not self.mode = self.Mode_View then
		if _hookType = HookType_InvoiceQuantity or
		   _hookType = HookType_HMSInvoiceQuantity then
			self.quantityHookSource := source;
		elseif _hookType = HookType_InvoiceRate or
		   _hookType = HookType_HMSInvoiceRate then
			self.rateHookSource := source;
		elseif _hookType = HookType_InvoiceRemarks then		// 22/2/18 MAP TFS37124
			self.remarkHookSource := source;
		endif;
	endif;

end;</source>
        <Parameter name="_hookType" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="showRangeEscalatingFrame" id="f0095e57-d7d4-4c70-8f69-863a09ec4a97">
        <source>showRangeEscalatingFrame();
// ---------------------------------------------------------------------------
// Created:		May 2012 CCMS 1279 Escalating Charges
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	tot,row,idx : Integer;
	firstRange : CM_QuantityRange;
begin
	
	self.frmRange.left := self.tblData.width + 50;
	self.frmRange.top := 150;
	self.frmRange.width := 250;
	self.frmRangeTB.width := self.frmRange.width - 12;
	self.frmRangeTB.positionToolbarControls();
	self.chkRelFSD.visible:=false;
	self.initTableEscalatingRange();

	if self.myCurrentObject &lt;&gt; null then
		firstRange:=self.myCurrentObject.CM_CalculationType.allQuantityRanges.first;
	endif;
	if firstRange &lt;&gt; null then
		self.chkRelFSD.value:=firstRange.rangeType=RANGETYPE_FSD_RELATIVE;
	endif;
	
	self.frmRange.zOrder(1);
	
	self.tblRange.rows := 1;
	self.frmRange.visible := true;

	if (self.mode = self.Mode_Add or self.myCurrentObject.CM_CalculationType.allQuantityRanges.isEmpty()) 
	and self.rangeStart.isEmpty() then
		row := self.tblRange.addItem(1.String &amp; Tab &amp; Tab);
		self.tblRange.accessCell(row,self.COLUMN_FROM).cellControl.TextBox.selectionStyle := TextBox.SelectionStyle_SelectAll;
		self.tblRange.accessCell(row,self.COLUMN_TO).cellControl.TextBox.selectionStyle := TextBox.SelectionStyle_SelectAll;
		self.tblRange.accessCell(row,self.COLUMN_PER_DAYS).cellControl.TextBox.selectionStyle := TextBox.SelectionStyle_SelectAll;
	else
		tot := self.rangeStart.size;
		foreach idx in 1 to tot do
			row := self.tblRange.addItem((self.rangeStart[idx]).String &amp; Tab &amp; self.rangeEnd[idx].String &amp; Tab &amp; self.days[idx].String);
			self.tblRange.accessCell(row,self.COLUMN_FROM).cellControl.TextBox.selectionStyle := TextBox.SelectionStyle_SelectAll;
			self.tblRange.accessCell(row,self.COLUMN_TO).cellControl.TextBox.selectionStyle := TextBox.SelectionStyle_SelectAll;
			self.tblRange.accessCell(row,self.COLUMN_PER_DAYS).cellControl.TextBox.selectionStyle := TextBox.SelectionStyle_SelectAll;
		endforeach;
		
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="showRangeFrame" id="da81782c-2343-4943-8cb4-226330dfb77f">
        <source>showRangeFrame();
// ---------------------------------------------------------------------------
// Created:		January 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	tot,row,idx : Integer;
	idealHeight : Real;
	
begin
	if self.isEscalatingCharge then
		self.showRangeEscalatingFrame();
		return;
	endif;
	self.initTableRange();
	
	self.chkRelFSD.visible:=false;
	self.frmRange.left := self.tblData.width + 50;
	self.frmRange.top := 150;
	self.frmRange.height := 235;
	self.tblRange.move(0,self.frmRangeTB.height,self.frmRange.clientWidth,self.frmRange.clientHeight - self.frmRangeTB.height);
	self.frmRange.zOrder(1);
	
	self.tblRange.rows := 1;
	self.frmRange.visible := true;

	if (self.mode = self.Mode_Add or self.myCurrentObject.CM_CalculationType.integerRange1.isEmpty) 
	and self.range.isEmpty then
		row := self.tblRange.addItem(1.String &amp; Tab);
		self.tblRange.accessCell(row,self.COLUMN_TO).cellControl.TextBox.selectionStyle := TextBox.SelectionStyle_SelectAll;
		
		foreach idx in 1 to 10 do
			row := self.tblRange.addItem(Tab);
			self.tblRange.accessCell(row,self.COLUMN_TO).cellControl.TextBox.selectionStyle := TextBox.SelectionStyle_SelectAll;
		endforeach;
		tot := 11;	//27 Jan 2015	NDL	Par 31381
	else
		row := self.tblRange.addItem(1.String &amp; Tab &amp; self.range[1].String);
		self.tblRange.accessCell(row,self.COLUMN_TO).cellControl.TextBox.selectionStyle := TextBox.SelectionStyle_SelectAll;
		
		tot := self.range.size;
		foreach idx in 2 to tot do
			row := self.tblRange.addItem((self.range[idx - 1] + 1).String &amp; Tab &amp; self.range[idx].String);
			self.tblRange.accessCell(row,self.COLUMN_TO).cellControl.TextBox.selectionStyle := TextBox.SelectionStyle_SelectAll;
		endforeach;
		
	endif;

	//27 Jan 2015	NDL	Par 31381 - resize based on data.
	if tot &gt; 4 then
		idealHeight := tblRange.top + ( tot * ( self.tblRange.accessRow(1).height + 2 ) ) + 10;
		if self.frmRange.height &gt;= idealHeight then
			// nothing to do
		elseif idealHeight &lt; self.sptMain.height then
			//bigger than minimum height, draw ideal size, and centre.
			self.frmRange.top :=  ((self.sptMain.height - idealHeight ) / 2 ) + 27;
			self.frmRange.height := idealHeight;
			self.tblRange.height := self.frmRange.clientHeight - self.tblRange.accessRow(1).height;
		else
			//too much data for form height, set to max available height
			self.frmRange.top := 27;
			self.frmRange.height := self.sptMain.height;
			self.tblRange.height := self.frmRange.clientHeight - self.tblRange.accessRow(1).height;
		endif;
	endif;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="showThumbnailData" id="577b924e-eecd-408a-8da3-9664cddd30ab">
        <updating/>
        <source>showThumbnailData(obj: Object) updating;
// 24024
// Changed On	By			Reason
// ----------	--------	------------------------------------------------------------
// 08/04/2019	jlgdap1		TFS 43694 PEL1 Charging for Vessels that use a Ramp
// 29/08/2022	jlika1		TFS 54420 - PRP - Enstructure - Financial Requirements
vars
	theCalculationType : CM_CalculationType;

begin
	theCalculationType := obj.CM_CalculationType;

	if theCalculationType = null then
		self.btnDeleteTV.enabled := false;
		self.btnEditTV.enabled := false;
	elseif theCalculationType.isCargoCalcType then
		// 24024 can edit and delete user cargo types but not the standard ones
		if theCalculationType.isStandardCargo() then
			self.btnDeleteTV.enabled := false;
			self.btnEditTV.enabled := false;
		else
			self.btnDeleteTV.enabled := true;
			self.btnEditTV.enabled := true;
		endif;
	elseif theCalculationType.isInventoryType then
		 // ### TFS 51219 28MAY2021 NAVAB1 can edit and delete user inventory types but not the standard ones
		if theCalculationType.isStandardInventory() then
			self.btnDeleteTV.enabled := false;
			self.btnEditTV.enabled := false;
		else
			self.btnDeleteTV.enabled := true;
			self.btnEditTV.enabled := true;
		endif;
	elseif theCalculationType.isEventCalcType then
		if theCalculationType.isStandardEvent() then
			self.btnDeleteTV.enabled := false;
			self.btnEditTV.enabled := false;
		else
			self.btnDeleteTV.enabled := true;
			self.btnEditTV.enabled := true;
		endif;
	// TFS 39198
	elseif theCalculationType.isWorkOrderType then
		if theCalculationType.isStandardWorkOrder() then
			self.btnDeleteTV.enabled := false;
			self.btnEditTV.enabled := false;
		else
			self.btnDeleteTV.enabled := true;
			self.btnEditTV.enabled := true;
		endif;
	//31 Oct 2019	NDL	TFS 47100
	elseif theCalculationType.isBolCalcType then
		if theCalculationType.isStandardBOL() then
			self.btnDeleteTV.enabled := false;
			self.btnEditTV.enabled := false;
		else
			self.btnDeleteTV.enabled := true;
			self.btnEditTV.enabled := true;
		endif;
	else
		self.btnDeleteTV.enabled := true;
		self.btnEditTV.enabled := true;
	endif;
	// 24024 CCMS 1151 Aug 2010 cnwjre1 user hook code for invoice quantity and rate
	self.quantityHookSource := null;
	self.rateHookSource := null;
	self.remarkHookSource := null;		// 22/2/18 MAP TFS37124
	if theCalculationType &lt;&gt; null then
		if theCalculationType.myHookCodeQuantity &lt;&gt; null then
			self.quantityHookSource := theCalculationType.myHookCodeQuantity.getCurrentJadeCode();
		endif;
		if theCalculationType.myHookCodeRate &lt;&gt; null then
			self.rateHookSource := theCalculationType.myHookCodeRate.getCurrentJadeCode();
		endif;
		if theCalculationType.myHookCodeRemarks &lt;&gt; null then
			self.remarkHookSource := theCalculationType.myHookCodeRemarks.getCurrentJadeCode();	// 22/2/18 MAP TFS37124
		endif;
	endif;

	self.tblThumb.rows := 0;
	self.tblThumb.columns := 2;
	self.showThumbnailForDef(ETDef_InvThumbNail, theCalculationType);

	if theCalculationType.isCargoCalcType 
	or theCalculationType.isEventCalcType 
	or theCalculationType.isBolCalcType //31 Oct 2019	NDL	TFS 47100
	or theCalculationType.isWorkOrderType then // TFS 39198
		self.tblThumb.hideRowFromHeading(self.tblEntDetail.getHeadingByName(ETRow_TimeFrom));
		self.tblThumb.hideRowFromHeading(self.tblEntDetail.getHeadingByName(ETRow_TimeTo));
		self.tblThumb.hideRowFromHeading(self.tblEntDetail.getHeadingByName(ETRow_Day1Chk));
		self.tblThumb.hideRowFromHeading(self.tblEntDetail.getHeadingByName(ETRow_Day2Chk));
		self.tblThumb.hideRowFromHeading(self.tblEntDetail.getHeadingByName(ETRow_Day3Chk));
		self.tblThumb.hideRowFromHeading(self.tblEntDetail.getHeadingByName(ETRow_Day4Chk));
		self.tblThumb.hideRowFromHeading(self.tblEntDetail.getHeadingByName(ETRow_Day5Chk));
		self.tblThumb.hideRowFromHeading(self.tblEntDetail.getHeadingByName(ETRow_Day6Chk));
		self.tblThumb.hideRowFromHeading(self.tblEntDetail.getHeadingByName(ETRow_Day7Chk));
		self.tblThumb.hideRowFromHeading(self.tblEntDetail.getHeadingByName(ETRow_Range));
		self.tblThumb.hideRowFromHeading(self.tblEntDetail.getHeadingByName(ETRow_BlockRateMin)); // PAR 34764
		self.tblThumb.hideRowFromHeading(self.tblEntDetail.getHeadingByName(ETRow_BlockRateMax)); // PAR 34764
		self.tblThumb.hideRowFromHeading(self.tblEntDetail.getHeadingByName(ETRow_AmountMin));
		self.tblThumb.hideRowFromHeading(self.tblEntDetail.getHeadingByName(ETRow_AmountMax));
		self.tblThumb.hideRowFromHeading(self.tblEntDetail.getHeadingByName(ETRow_HoursMin));
		self.tblThumb.hideRowFromHeading(self.tblEntDetail.getHeadingByName(ETRow_HoursMax));
		self.tblThumb.hideRowFromHeading(self.tblEntDetail.getHeadingByName(ETRow_HoursBlock));
		self.tblThumb.hideRowFromHeading(self.tblEntDetail.getHeadingByName(ETRow_HoursFree));
		self.tblThumb.hideRowFromHeading(self.tblEntDetail.getHeadingByName(ETRow_BlockUnit));
		self.tblThumb.hideRowFromHeading(self.tblEntDetail.getHeadingByName(ETRow_IsNotAvailableForEntryCk));
		self.tblThumb.hideRowFromHeading(self.tblEntDetail.getHeadingByName(ETRow_WeightToUse)); //02/10/2025	navkc1 JIRA 36144 
		
		if theCalculationType.isCargoCalcType and
		   theCalculationType.isStandardCargo() then
			self.tblThumb.hideRowFromHeading(self.tblEntDetail.getHeadingByName(ETRow_CalcTypeDesc));
		endif;			
		// 24024
		/* TFS 39198
		if not theCalculationType.isCargoCalcType then
			self.tblThumb.hideRowFromHeading(self.tblEntDetail.getHeadingByName(ETRow_QuantityHookCode));
			self.tblThumb.hideRowFromHeading(self.tblEntDetail.getHeadingByName(ETRow_RateHookCode));
			self.tblThumb.hideRowFromHeading(self.tblEntDetail.getHeadingByName(ETRow_RemarksHookCode));	// 22/2/18 MAP TFS37124
			self.tblThumb.hideRowFromHeading(self.tblEntDetail.getHeadingByName(ETRow_EscalatingCharges));
		else
		*/
		if theCalculationType.isStandardCargo() or
		   not theCalculationType.isStorageCalculation() then
			self.tblThumb.hideRowFromHeading(self.tblEntDetail.getHeadingByName(ETRow_EscalatingCharges));
		endif;
		 // PAR 30681
		if theCalculationType.calculationType &lt;&gt; INV_CALC_TYPE_BUSHRSVESELVALUE
		and theCalculationType.calculationType &lt;&gt; INV_CALC_TYPE_BUSHRSCARGOVALUE then 
			self.tblThumb.hideRowFromHeading(self.tblEntDetail.getHeadingByName(ETRow_CalendarNormalDates));
			self.tblThumb.hideRowFromHeading(self.tblEntDetail.getHeadingByName(ETRow_CalendarExclusionDates));
		else
			self.tblThumb.showRowFromHeading(self.tblEntDetail.getHeadingByName(ETRow_BlockUnit));
		endif;
		
		if theCalculationType.isWorkOrderType
		or theCalculationType.calculationType = INV_CALC_TYPE_WO_EXTRA	//28 Jun 2018	NDl	TFS 39246
		then // TFS 39198
			self.tblThumb.showRowFromHeading(self.tblEntDetail.getHeadingByName(ETRow_BlockUnit));
		endif;
		
		if theCalculationType.calculationType = INV_CALC_TYPE_CARGOWEIGHTCONVT		// PAR 31615
		or theCalculationType.calculationType = INV_CALC_TYPE_CARGOLENGTHCONVT		// PAR 31615
		or theCalculationType.calculationType = INV_CALC_TYPE_CARGOVOLUMECONVT then		// PAR 31615
			self.tblThumb.showRowFromHeading(self.tblEntDetail.getHeadingByName(ETRow_BlockUnit));
			
			//02/10/2025	navkc1 JIRA 36144 
			if theCalculationType.calculationType = INV_CALC_TYPE_CARGOWEIGHTCONVT then
				self.tblThumb.showRowFromHeading(self.tblEntDetail.getHeadingByName(ETRow_WeightToUse));
			endif;
			
		endif;
		if theCalculationType.calculationType &lt;&gt; INV_CALC_TYPE_CARGOWEIGHTCONVT		// PAR 31615
		and theCalculationType.calculationType &lt;&gt; INV_CALC_TYPE_CARGOLENGTHCONVT		// PAR 31615
		and theCalculationType.calculationType &lt;&gt; INV_CALC_TYPE_CARGOVOLUMECONVT then		// PAR 31615
			self.tblThumb.hideRowFromHeading(self.tblEntDetail.getHeadingByName(ETRow_MeasurementType));
		endif;
		
		if self.isEventBlockUnit(theCalculationType) then
			self.tblThumb.showRowFromHeading(self.tblEntDetail.getHeadingByName(ETRow_AmountMin));
			self.tblThumb.showRowFromHeading(self.tblEntDetail.getHeadingByName(ETRow_AmountMax));		
			self.tblThumb.showRowFromHeading(self.tblEntDetail.getHeadingByName(ETRow_BlockUnit));
		endif;
	else
		// ### Thumbnail tables do not have VIEWS so this emulates views
		// 24024
		//self.tblThumb.hideRowFromHeading(self.tblEntDetail.getHeadingByName(ETRow_QuantityHookCode));
		//self.tblThumb.hideRowFromHeading(self.tblEntDetail.getHeadingByName(ETRow_RateHookCode));
		//	34489 SFW 1327 Tidal Class show hook code for cargo and voyage
		self.tblThumb.showRowFromHeading(self.tblEntDetail.getHeadingByName(ETRow_RateHookCode));
		self.tblThumb.showRowFromHeading(self.tblEntDetail.getHeadingByName(ETRow_QuantityHookCode));
		self.tblThumb.showRowFromHeading(self.tblEntDetail.getHeadingByName(ETRow_RemarksHookCode));	// 22/2/18 MAP TFS37124
		self.tblThumb.hideRowFromHeading(self.tblEntDetail.getHeadingByName(ETRow_EscalatingCharges));
		self.tblThumb.hideRowFromHeading(self.tblEntDetail.getHeadingByName(ETRow_WeightToUse)); //02/10/2025	navkc1 JIRA 36144 
		if (theCalculationType.calculationType &lt;&gt; INV_CALC_TYPE_VESSEL_TON_RANGE and theCalculationType.calculationType &lt;&gt; INV_CALC_TYPE_VESSEL_TON_QTY1 ) then 
			self.tblThumb.hideRowFromHeading(self.tblEntDetail.getHeadingByName(ETRow_Range));
		endif;
		if theCalculationType.calculationType &lt;&gt; INV_CALC_TYPE_BUSINESS_HRS_QTY then
			self.tblThumb.hideRowFromHeading(self.tblEntDetail.getHeadingByName(ETRow_TimeFrom));
			self.tblThumb.hideRowFromHeading(self.tblEntDetail.getHeadingByName(ETRow_TimeTo));
			self.tblThumb.hideRowFromHeading(self.tblEntDetail.getHeadingByName(ETRow_Day1Chk));
			self.tblThumb.hideRowFromHeading(self.tblEntDetail.getHeadingByName(ETRow_Day2Chk));
			self.tblThumb.hideRowFromHeading(self.tblEntDetail.getHeadingByName(ETRow_Day3Chk));
			self.tblThumb.hideRowFromHeading(self.tblEntDetail.getHeadingByName(ETRow_Day4Chk));
			self.tblThumb.hideRowFromHeading(self.tblEntDetail.getHeadingByName(ETRow_Day5Chk));
			self.tblThumb.hideRowFromHeading(self.tblEntDetail.getHeadingByName(ETRow_Day6Chk));
			self.tblThumb.hideRowFromHeading(self.tblEntDetail.getHeadingByName(ETRow_Day7Chk));
		endif;
		 // PAR 30681
		if theCalculationType.calculationType &lt;&gt; INV_CALC_TYPE_BUSHRSVESELVALUE
		and theCalculationType.calculationType &lt;&gt; INV_CALC_TYPE_BUSHRSCARGOVALUE then 
			self.tblThumb.hideRowFromHeading(self.tblEntDetail.getHeadingByName(ETRow_CalendarNormalDates));
			self.tblThumb.hideRowFromHeading(self.tblEntDetail.getHeadingByName(ETRow_CalendarExclusionDates));
			
			if theCalculationType.isUsingGRTInQty() then // PAR 34764
				self.tblThumb.hideRowFromHeading(self.tblEntDetail.getHeadingByName(ETRow_AmountMin)); // PAR 34764
				self.tblThumb.hideRowFromHeading(self.tblEntDetail.getHeadingByName(ETRow_AmountMax)); // PAR 34764
			else
				self.tblThumb.hideRowFromHeading(self.tblEntDetail.getHeadingByName(ETRow_BlockRateMin)); // PAR 34764
				self.tblThumb.hideRowFromHeading(self.tblEntDetail.getHeadingByName(ETRow_BlockRateMax)); // PAR 34764
			endif;
			
		else
			// PAR 34764 self.tblThumb.hideRowFromHeading(self.tblEntDetail.getHeadingByName(ETRow_AmountMin));
			// PAR 34764 self.tblThumb.hideRowFromHeading(self.tblEntDetail.getHeadingByName(ETRow_AmountMax));
			self.tblThumb.hideRowFromHeading(self.tblEntDetail.getHeadingByName(ETRow_BlockRateMin)); // PAR 34764
			self.tblThumb.hideRowFromHeading(self.tblEntDetail.getHeadingByName(ETRow_BlockRateMax)); // PAR 34764

		endif;
		
		
		if theCalculationType.calculationType &lt;&gt; INV_CALC_TYPE_TIMEBLCK_HRS
		and theCalculationType.calculationType &lt;&gt; INV_CALC_TYPE_TIMEBLCK_HRS_UNT
		and theCalculationType.calculationType &lt;&gt; INV_CALC_TYPE_TIMEBLCK_HRS_ONE then 
			self.tblThumb.hideRowFromHeading(self.tblEntDetail.getHeadingByName(ETRow_HoursMin));
			self.tblThumb.hideRowFromHeading(self.tblEntDetail.getHeadingByName(ETRow_HoursMax));
			self.tblThumb.hideRowFromHeading(self.tblEntDetail.getHeadingByName(ETRow_HoursBlock));
			self.tblThumb.hideRowFromHeading(self.tblEntDetail.getHeadingByName(ETRow_HoursFree));
		endif;
		if theCalculationType.calculationType &lt;&gt; INV_CALC_TYPE_TIMEBLCK_HRS_UNT
		and theCalculationType.calculationType &lt;&gt; INV_CALC_TYPE_TIMEBLCK_HRS_ONE
		// 30680 CCMS QNS 2178 add the vessel tonnage types
		and theCalculationType.calculationType &lt;&gt; INV_CALC_TYPE_BUSHRSVESELVALUE // PAR 30681
		and theCalculationType.calculationType &lt;&gt; INV_CALC_TYPE_BUSHRSCARGOVALUE   // PAR 30681
		and theCalculationType.calculationType &lt;&gt; INV_CALC_TYPE_CARGOWEIGHTCONVT		// PAR 31615
		and theCalculationType.calculationType &lt;&gt; INV_CALC_TYPE_CARGOLENGTHCONVT		// PAR 31615
		and theCalculationType.calculationType &lt;&gt; INV_CALC_TYPE_CARGOVOLUMECONVT		// PAR 31615
		and theCalculationType.calculationType &lt;&gt; INV_CALC_TYPE_VESSEL_TON		
		and theCalculationType.calculationType &lt;&gt; INV_CALC_TYPE_VESSEL_TON_RANGE
		and theCalculationType.calculationType &lt;&gt; INV_CALC_TYPE_VESSEL_TON_QTY1 
		and theCalculationType.calculationType &lt;&gt; INV_CALC_TYPE_TIDAL_CLASS then 	// 34489 CCMS 1327
			self.tblThumb.hideRowFromHeading(self.tblEntDetail.getHeadingByName(ETRow_BlockUnit));
		endif;
		if theCalculationType.calculationType &lt;&gt; INV_CALC_TYPE_CARGOWEIGHTCONVT		// PAR 31615
		and theCalculationType.calculationType &lt;&gt; INV_CALC_TYPE_CARGOLENGTHCONVT		// PAR 31615
		and theCalculationType.calculationType &lt;&gt; INV_CALC_TYPE_CARGOVOLUMECONVT then		// PAR 31615
			self.tblThumb.hideRowFromHeading(self.tblEntDetail.getHeadingByName(ETRow_MeasurementType));
		endif;
		
		if theCalculationType.calculationType = INV_CALC_TYPE_CARGOWEIGHTCONVT then
			self.tblThumb.showRowFromHeading(self.tblEntDetail.getHeadingByName(ETRow_WeightToUse)); //02/10/2025	navkc1 JIRA 36144 
		endif;
	endif;
	
	//22 Mar 2019	NDL	TFS 43687
	if theCalculationType.calculationType = INV_CALC_TYPE_VESSEL_TON
	or theCalculationType.calculationType = INV_CALC_TYPE_TIMEBLCK_HRS
	or theCalculationType.calculationType = INV_CALC_TYPE_TIMEBLCK_HRS_ONE
	or theCalculationType.calculationType = INV_CALC_TYPE_TIMEBLCK_HRS_UNT
	or theCalculationType.calculationType = INV_CALC_TYPE_TIME_PERIOD_HRS
	or theCalculationType.calculationType = INV_CALC_TYPE_TIME_PERIOD_HRMN  // ### TFS CR 65326 TASK 65327 06AUG2024 NAVAB1
	or theCalculationType.calculationType = INV_CALC_TYPE_RESOURCE_QTY 
	or theCalculationType.calculationType = INV_CALC_TYPE_QUOTED_RATE
	or theCalculationType.calculationType = INV_CALC_TYPE_RESOURCE_DAYS
	or theCalculationType.calculationType = INV_CALC_TYPE_WO_CARGOQUANTITY		// TFS 43694
	or theCalculationType.calculationType = INV_CALC_TYPE_WO_CARGOREVTONS		// TFS 43694
	or theCalculationType.calculationType = INV_CALC_TYPE_WO_CARGOVOLUME		// TFS 43694
	or theCalculationType.calculationType = INV_CALC_TYPE_WO_CARGOWEIGHT		// TFS 43694
	or theCalculationType.calculationType = INV_CALC_TYPE_WO_ETMAL_DAYS			// TFS 43694
	or theCalculationType.calculationType = INV_CALC_TYPE_WO_ETMAL_HOURS		// TFS 43694
	or theCalculationType.calculationType = INV_CALC_TYPE_WO_ETMAL_MINUTES		// TFS 43694
	or theCalculationType.calculationType = INV_CALC_TYPE_WO_UNITS				// TFS 43694
	or theCalculationType.calculationType = INV_CALC_TYPE_WO_VALUEOF1			// TFS 43694
	or theCalculationType.calculationType = INV_CALC_TYPE_BOL_VALUEOF1		//31 Oct 2019	NDL	TFS 47100
	then
		self.tblThumb.showRowFromHeading( self.tblEntDetail.getHeadingByName(ETRow_RateType) );
	else
		self.tblThumb.hideRowFromHeading( self.tblEntDetail.getHeadingByName(ETRow_RateType) );
	endif;
		
		
		
	if theCalculationType.isCargoCalcType then
		if theCalculationType.isStandardCargo() then
			self.tblThumb.hideRowFromHeading(self.tblEntDetail.getHeadingByName(ETRow_IsNotAvailableForEntryCk));
		else
			self.tblThumb.showRowFromHeading(self.tblEntDetail.getHeadingByName(ETRow_IsNotAvailableForEntryCk));
		endif;
	endif;

	
	// TFS 2198 CNWAB1
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		self.btnDeleteTV.enabled := false;
		self.btnEditTV.enabled := false;
		self.btnSaveBase.enabled := false;

	endif;
end;</source>
        <Parameter name="obj" type="Object"/>
    </JadeMethod>
    <JadeMethod name="tblEntDetail_click" id="fe4cacdd-6dde-4f93-8104-eb9d4ee4d491">
        <controlMethod name="CM_EntryTable::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblEntDetail_click(table: Table input) updating;

vars
	rowInTable	: Integer;
begin
	self.isEscalatingCharge := false;
	rowInTable := table.CM_EntryTable.getRow(ETRow_EscalatingCharges);
	// row = rowInTable when clicking on ETRow_EscalatingCharges
	if table.row = rowInTable and rowInTable &gt; 0 then
		if self.tblEntDetail.getValueByName(ETRow_EscalatingCharges).Boolean then
			self.isEscalatingCharge := true;
			self.showRangeFrame();
		endif;
	endif;
end;
</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="tblEntDetail_dblClick" id="c0b5272a-979f-4f00-a8cf-64bf7ef624fd">
        <controlMethod name="CM_EntryTable::dblClick"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblEntDetail_dblClick(table: CM_EntryTable input) updating;
// ---------------------------------------------------------------------------
// Created:		January 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

	rowInTable	: Integer;
	entTable	: CM_EntryTable;
	calculationType	: CM_CalculationType;
begin

	entTable := table.CM_EntryTable;
	rowInTable := table.CM_EntryTable.getRow(ETRow_Range);
	if table.row = rowInTable and rowInTable &gt; 0 then
		self.showRangeFrame();
	endif;
	// 
	self.isEscalatingCharge := false;
	rowInTable := table.CM_EntryTable.getRow(ETRow_EscalatingCharges);
	if table.row = rowInTable and rowInTable &gt; 0 then
		self.isEscalatingCharge := true;
		self.showRangeFrame();
	endif;
	
// 24024 CCMS 1151 Aug 2010 cnwjre1 user hook code for invoice quantity and rate
	// 34489 CCMS 1327 extend to HMS types
	calculationType := self.myCurrentObject.CM_CalculationType;
	rowInTable := entTable.getRow(ETRow_QuantityHookCode);
	if table.row = rowInTable and rowInTable &gt; 0 then
		if calculationType &lt;&gt; null and
		   calculationType.isVoyageCalcType then
			self.showHookCodeMaintForm(HookType_HMSInvoiceQuantity);
		else
			self.showHookCodeMaintForm(HookType_InvoiceQuantity);
		endif;
		return;
	endif;
	rowInTable := entTable.getRow(ETRow_RateHookCode);
	if table.row = rowInTable and rowInTable &gt; 0 then
		if calculationType &lt;&gt; null and
		   calculationType.isVoyageCalcType then
			self.showHookCodeMaintForm(HookType_HMSInvoiceRate);
		else
			self.showHookCodeMaintForm(HookType_InvoiceRate);
		endif;
		return;
	endif;
	rowInTable := entTable.getRow(ETRow_RemarksHookCode);		// 22/2/18 MAP TFS37124
	if table.row = rowInTable and rowInTable &gt; 0 then
		self.showHookCodeMaintForm(HookType_InvoiceRemarks);
		return;
	endif;

end;</source>
        <Parameter name="table" type="CM_EntryTable" usage="input"/>
    </JadeMethod>
    <JadeMethod name="tblRange_rowColumnChg" id="aa2a45f4-8954-4396-92a9-aad520bf1fce">
        <controlMethod name="CM_EntryTable::rowColumnChg"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblRange_rowColumnChg(table: Table input) updating;
// ---------------------------------------------------------------------------
// Created:		January 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

begin
	if self.isEscalatingCharge then
		self.checkRangeTableEscalating();
	else
		self.checkRangeTable();
	endif;

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="timerEvent" id="3ac8ee0a-04d5-40c1-ada6-69c2347e8a55">
        <updating/>
        <source>timerEvent(eventTag: Integer) updating;
/*

Purpose:			Filters the table once the user finishes typing

Parameters:			eventTag	Integer	The event tag triggered

Return Value:		NONE

Date				Who		Reason
22 September 2021	navpw1	Initial creation TFS: 51912

*/

begin
	if eventTag = self.Timer_TableData_Filter then
		self.doFilterTable();
	endif;

	inheritMethod(eventTag);
	
end;</source>
        <Parameter name="eventTag" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="translateForm" id="4f338f68-6ac8-40db-b24e-b5193d45dfdf">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0006135, locale);
	btnAddRange.translateBubbleHelp(Xlat_0002058, locale);
	btnAddRange.translateCaption(Xlat_0002059, locale);
	btnCancelRange.translateBubbleHelp(Xlat_0002052, locale);
	btnCancelRange.translateCaption(Xlat_0002054, locale);
	btnDeleteRange.translateBubbleHelp(Xlat_0002053, locale);
	btnDeleteRange.translateCaption(Xlat_0002055, locale);
	btnSaveRange.translateBubbleHelp(Xlat_0002056, locale);
	btnSaveRange.translateCaption(Xlat_0002057, locale);
	chkRelFSD.translateCaption(Xlat_0018141, locale);
end;</source>
    </JadeMethod>
</GUIClass>
