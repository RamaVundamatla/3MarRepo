    <JadeMethod name="isTIUniqueIdCargoType" id="c8bb8089-0eaa-4e2d-8b05-409149adf4ac">
        <updating/>
        <source>isTIUniqueIdCargoType(_ti : CM_TrackedItem; _passport : CM_Passport input) : Boolean updating;
// validates that the id/cargoType of the passed in ti is unique if it
// has to be based on its current state, etc
// code moved from createTrackedItem to avoid locking the CM_Terminal.allOnSite tis dict
// when doing deferred transactions
// ---------------------------------------------------------------------------
// Changed On 	By			Reason
// ----------	--------	--------------------------------------------------
// 12/05/2010	cnwdap1		CCMS 1116 Tranship changes
// 01/03/2024	navcs2		ChangeRequest 62686: CUX | FR 61749 | Investigate Ticket 62683 - Cannot create multiple prenotes
vars
	existingTI 	: CM_TrackedItem;
	tmpCargoType	: CM_CargoType;
	tiDesc, str : String;
begin
	//----------------
	//If passed in oid is NOT a transient object, then complain.
	//----------------
	if _ti = null then
		app.setContinueCMExceptions(false);
		app.raiseCMException2(MethodWithNullParam, method.name , '_ti', null, null);
		return false;
	endif;

	// PAR 29457 - came across this whilst testing EDI. My GC cargo allowed duplicate IDs but this test was saying NO!
	if _ti.state = TI_STATE_NOTIFIED and self.getConfig( PrenoteUniqBooking ).Boolean then										// 01/03/2024 navcs2 ChangeRequest 62686
			if not self.noOnsiteDuplicate(_ti, _ti.cargoType, _ti.operatorCode, _ti.bookingReference, false, false) then		// 01/03/2024 navcs2 ChangeRequest 62686
				app.raiseCMException1(Preno_with_same_booki_ref, _ti.id, null, null);											// 01/03/2024 navcs2 ChangeRequest 62686
			endif;																												// 01/03/2024 navcs2 ChangeRequest 62686
	elseif _ti.myCargoType.allowDuplicates then																					// 01/03/2024 navcs2 ChangeRequest 62686
		return true;
	endif;
	
	//----------------
	//Does TI already exist?
	//----------------
	existingTI := self.lookupTrackedItem(_ti.id, _ti.cargoType, _ti.state, _ti.voyageCode, false);
	if existingTI &lt;&gt; null and existingTI &lt;&gt; _ti then
		//Exists!
		app.setContinueCMExceptions(false);
		if _ti.state = TI_STATE_NORMAL then
			//if _ti.myVoyageTranshipExport &lt;&gt; null  or _ti.myTranshipImport &lt;&gt; null then // CCMS 1011	// PAR #23645 CCMS 1116
				//return true;																			// PAR #23645 CCMS 1116
			//else																						// PAR #23645 CCMS 1116
				app.raiseCMException1(ERR_DUP_ONSITE_TI, _ti.id, null, null);
			//endif;																					// PAR #23645 CCMS 1116

		elseif _ti.state = TI_STATE_NOTIFIED then
			//we want all errors at once when building edi prenotes, so continue
			tmpCargoType := _ti.myCargoType;
			if tmpCargoType = null or not tmpCargoType.allowDuplicates then
				app.setContinueCMExceptions(true);	
				app.raiseCMException1(ERR_DUP_NOTIFIED_TI, _ti.id, null, null);
			endif;
			// We have a duplicate but it is allowed.
			return true;
		elseif _ti.state = TI_STATE_EDI then
			//simply continue, we are creating a NEW TI each time here.
			return true; //not raising an error so have to return true
		else
			//if _ti.myVoyageTranshipExport &lt;&gt; null  or _ti.myTranshipImport &lt;&gt; null then // CCMS 1011	// PAR #23645 CCMS 1116
				//return true;																			// PAR #23645 CCMS 1116
			//else																						// PAR #23645 CCMS 1116
				tmpCargoType := app.myRoot.allCargoTypesById[_ti.cargoType];
				if tmpCargoType &lt;&gt; null then
					tiDesc := tmpCargoType.description.trimBlanks;
				else
					tiDesc := "Unknown";
				endif;
				if existingTI.myReceivalBOL &lt;&gt; null then
					str := 'associated with Docket' &amp; existingTI.myReceivalBOL.number;
				else
					str := 'in the system with status ' &amp; existingTI.contentsStatusDescription;
				endif;
				app.raiseCMException3(ItemAlreadyExists, 'Create Tracked Item', tiDesc &amp; ' ' &amp; _ti.id, str, null, null);
			//endif;																					// PAR #23645 CCMS 1116
		endif;
		return false;
	endif;
	
	return true;

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
