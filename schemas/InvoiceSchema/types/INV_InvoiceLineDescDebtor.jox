        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="doCmbBankBuild" id="4d300682-3d27-47e2-b216-63291c9f7435">
        <source>doCmbBankBuild();
//	35874 build combo for business unit query
vars
	company			: CM_Bank;
	businessUnits	: CM_CompanyByCodeDict;
	currentBU		: CM_Bank;
	combo			: CMUI_ComboBox;
begin

	combo := self.cmbBank;
	create businessUnits transient;
	currentBU := self.myTerminal.getAvailableCompanies(businessUnits);
	foreach company in businessUnits do
		combo.addItem(company.code);
		combo.itemObject[combo.newIndex] := company;
	endforeach;
	if currentBU &lt;&gt; null then
		combo.listObject := currentBU;
	endif;
epilog
	delete businessUnits;
end;
</source>
    </JadeMethod>
    <JadeMethod name="doDelete" id="19cf5c5f-2a0c-439e-958c-badebb13927e">
        <updating/>
        <source>doDelete(): Boolean updating;
// ---------------------------------------------------------------------------
// Created:		May 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

	theReturn : Integer;
begin
 
	while true do
 
 	 	app.myTrxDA.trxDeleteInvoiceLineDescDebtor(self.myCurrentObject.CM_DebtorInvoiceLineDesc, app.myPassport);
		if app.myPassport.trxCompletedOK then
			// Clear errors/warnings from form and err/warnings window
			self.clearErrorWarnings();
			global.beep;
			return true;
		else
			theReturn := app.showErrorWarningDialog("Invoice Line Description Debtor Consolidation", app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors 
			and theReturn = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
			return false;
		endif;
		break;
	endwhile;

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
