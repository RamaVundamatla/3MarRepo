    <JadeMethod name="translateForm" id="b0b96922-0e78-4168-b40d-005c461f87e0">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 04 April 2022 20:23:43.
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0006698, locale);
	btnBayDefinition.translateBubbleHelp(Xlat_0003227, locale);
	btnBayDefinition.translateCaption(Xlat_0003230, locale);
	//btnClearFilter.translateCaption(Xlat_0024627, locale);
	btnCloseSearch.translateBubbleHelp(Xlat_0014481, locale);
	btnCloseSearch.translateCaption(Xlat_0003237, locale);
	btnDelete.translateBubbleHelp(Xlat_0003243, locale);
