		app.msgBox(app.getErrorString(SelectStatusForCrdNote), app.getErrorString(Information), MsgBox_Information_Icon + MsgBox_OK_Only);
		return;
	endif;
	
	self.doSaveDLRT();
	
	// ### JIRA 19932 21OCT2024 NAVAB1
	/*if app.myRoot.isAsynchronousMethodEnabled() then // EUP ONLY for FOLLOWING CODE
