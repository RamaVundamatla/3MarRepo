    <JadeMethod name="btnReadTag_click" id="4053464d-1c1d-4709-a910-6ea9efa5a7a0">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnReadTag_click(btn: Button input) updating;

vars
obj: Object;
	rtQueueEntry : CM_RTQueueEntry;
begin
	self.clearErrors;
	if app.myVehicleMountedRTGGuiAgent.myVehicleMountedRTGAgent.hasRFIDReader then
		app.myVehicleMountedRTGGuiAgent.doRFIDTagRead();
	else

		obj := self.tblJobs.accessRow(self.tblJobs.row).itemObject;
		self.clearErrors;
		rtQueueEntry:=obj.DTO_RTQueueEntry.myRealQueueEntry.CM_RTQueueEntry;
		app.myVehicleMountedRTGGuiAgent.myVehicleMountedRTGAgent.doOfferTasks(rtQueueEntry);
	endif;

end;
</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doAcceptTask" id="589f9841-376e-45a5-80b1-278a08b0febc">
        <updating/>
        <source>doAcceptTask()  protected, updating;
/*

Purpose:			


Return Value:		


Date		Who		Reason
15 September 2006	cnwer1	Initial creation - PAR#xxxx

*/
vars

	obj 		: Object;
	_type	: String;
	_containerId,
	_fromLoc,
	_toLoc: String;
	_ostow,
	_canEdit,
	_toIsVehicle,
	invalidObject : Boolean;
	theTable 	: Table;
	theAcceptedRow : Integer;
	rtQueueEntry : CM_RTQueueEntry;
begin

	app.mousePointer	:=	Busy;
	theTable:=tblJobs;
	theAcceptedRow:=0;
	//epr par 17955 26/9/08
	//nothing to check
	if theTable.rows =  theTable.fixedRows then 
		return;
	endif;
	
	
	
	if self.acceptedRow &lt;&gt; null then
		theAcceptedRow:=self.acceptedRow;
		obj := theTable.accessRow(theAcceptedRow).itemObject;
		
	else
		theAcceptedRow:=theTable.row;
		//if it is the fixed row make it the first item
		if theAcceptedRow = theTable.fixedRows then
			theAcceptedRow:=theTable.fixedRows+1;
		endif;
		obj := theTable.accessRow(theAcceptedRow).itemObject;
	
		if obj = null then
			app.msgBox("You must select an item in the list","Job",MsgBox_Exclamation_Mark_Icon);
			return;
		endif;
	endif;
	self.clearErrors;
	
	on Exception do app.handleDeletedObject(exception,obj,invalidObject);	
	rtQueueEntry:=obj.DTO_RTQueueEntry.myRealQueueEntry.CM_RTQueueEntry;
	
	if invalidObject  then
		app.msgBox("You must select an item in the list","Job",MsgBox_Exclamation_Mark_Icon);
		//have an invalid dto object have no option but to reload the table
		self.loadTaskTable();
		return;
	endif;
	
	app.myVehicleMountedRTGGuiAgent.doAcceptTask( rtQueueEntry,null,allErrorMsgs);
	
	if self.checkErrors then
		return;
	endif;

	self.acceptedRow:=theAcceptedRow;
	
	app.myVehicleMountedRTGGuiAgent.getMoveDetails(_type,_containerId,_fromLoc,_toLoc,_ostow,_canEdit,_toIsVehicle,allErrorMsgs);
	if self.checkErrors then
		app.myVehicleMountedRTGGuiAgent.doCancelTask( rtQueueEntry,allErrorMsgs);
		return;
	endif;
	self.setupMsgFrameNew(_type,_containerId,_fromLoc,_toLoc,_ostow,_canEdit,_toIsVehicle);


epilog
	app.mousePointer	:=	Idle;
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doCancelTask" id="f0a000cf-e594-4aed-8fb7-29a81b7136df">
        <updating/>
        <source>doCancelTask() updating, protected;
/*

Purpose:			


Return Value:		


Date		Who		Reason
18 September 2006	cnwer1	Initial creation - PAR#xxxx

*/
vars
	obj : Object;
	theTable 	: Table;
	rtQueueEntry : CM_RTQueueEntry;
begin

	app.mousePointer	:=	Busy;
	theTable:=tblJobs;
	if self.tblJobs.rows &lt; self.acceptedRow then
		self.acceptedRow:=self.tblJobs.rows;
	elseif self.tblJobs.rows = 1 then
		self.frmAccept.visible := false;
		self.changeDefaultButtons(btnMsgOK,btnAccept);
		self.changeCancelButtons(btnMsgCancel,btnLogoff);
		self.acceptedRow:=null;
		return;
	endif;
	
	obj := theTable.accessRow(self.acceptedRow).itemObject;//self.acceptedRow).itemObject;
	if obj = null then
		app.msgBox("You must select an item in the list","Job",MsgBox_Exclamation_Mark_Icon);
		return;
	endif;
	self.clearErrors;
	rtQueueEntry:=obj.DTO_RTQueueEntry.myRealQueueEntry.CM_RTQueueEntry;
	app.myVehicleMountedRTGGuiAgent.doCancelTask( rtQueueEntry,allErrorMsgs);

	if self.checkErrors then
		return;
	endif;
	
	self.frmAccept.visible := false;
	self.changeDefaultButtons(btnMsgOK,btnAccept);
	self.changeCancelButtons(btnMsgCancel,btnLogoff);
	
	self.acceptedRow:=null;
epilog
	app.mousePointer	:=	Idle;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doDoorJob" id="790693c5-4140-4438-b6c2-fbfac5c2db56">
        <source>doDoorJob();
/*

Purpose:			


Return Value:		


Date		Who		Reason
15 November 2006	cnwer1	Initial creation - PAR#xxxx
10 Mar 2010	consw1	PAR #22898 - UE 1086

*/
vars
	obj : Object;
	rtQueueEntry : CM_RTQueueEntry;
begin
	obj := self.tblJobs.accessRow(self.tblJobs.row).itemObject;
	if obj = null then
		app.msgBox("You must select an item in the list","Job",MsgBox_Exclamation_Mark_Icon);
		return;
	endif;
	self.clearErrors;
	rtQueueEntry:=obj.DTO_RTQueueEntry.myRealQueueEntry.CM_RTQueueEntry;
	app.myVehicleMountedRTGGuiAgent.doDoorJob( rtQueueEntry,allErrorMsgs);
	
	if self.checkErrors then
		return;
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doKeyDown" id="c204d15e-b151-4b7a-adad-a6d81ce73d10">
        <updating/>
        <source>doKeyDown(keyCode: Integer io; shift: Integer) updating;
/*

Purpose:			


Return Value:		


Date		Who		Reason
14 September 2006	cnwer1	Initial creation - PAR#xxxx

*/
vars

begin
	inheritMethod(keyCode, shift);
	
	if keyCode = J_key_F2 then
		self.btnAccept.click(self.btnAccept);
	elseif keyCode = J_key_F6 then
		self.isPrimaryQueue:=false;
		self.setupChangeQueue();
	elseif keyCode = J_key_F7 then
		self.btnJobOrder.click(self.btnJobOrder);
	endif;
	
epilog

end;</source>
        <Parameter name="keyCode" type="Integer" usage="io"/>
        <Parameter name="shift" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="doMove" id="29d52760-8748-4473-9225-c59fe6ca91c0">
        <updating/>
        <source>doMove() protected, updating;
/*

Purpose:			


Return Value:		


Date		Who		Reason
15 September 2006	cnwer1	Initial creation - PAR#xxxx

*/
vars
	_type,
	_containerId,
	_fromLoc,
	_toLoc: String;
	_ostow,
	_canEdit,
	_toIsVehicle: Boolean;
	errorMsg : MobileHandHeldThin::DTO_HandHeldGateError;
	theTable 	: Table;
begin
	app.mousePointer	:=	Busy;
	theTable 	:=tblJobs;
	self.clearErrors;
	if app.myVehicleMountedRTGGuiAgent.hasCurrentOverstowTI then
		//move that overstow object ;
		app.myVehicleMountedRTGGuiAgent.doMoveCurrentOversowTI(currentContainerId,txtRow.text,allErrorMsgs);
		
		if self.checkErrors() then
			return;
		endif;
		
		app.myVehicleMountedRTGGuiAgent.getMoveDetails(_type,_containerId,_fromLoc,_toLoc,_ostow,_canEdit,_toIsVehicle,allErrorMsgs);
		if self.checkErrors then
			app.myVehicleMountedRTGGuiAgent.doCancelTask( null,allErrorMsgs);
			return;
		endif;
		self.setupMsgFrameNew(_type,_containerId,_fromLoc,_toLoc,_ostow,_canEdit,_toIsVehicle);
		return;
	else
		//easy move the current rt task ti to value in the txt field
		if txtRow.visible then
			app.myVehicleMountedRTGGuiAgent.doMoveCurrentTaskTI(currentContainerId,txtRow.text,allErrorMsgs);
		else
			app.myVehicleMountedRTGGuiAgent.doMoveCurrentTaskTI(currentContainerId,toLocationId,allErrorMsgs);
		endif;	
		
		if self.checkErrors() then
			return;
		endif;
	endif;
	self.frmAccept.visible := false;
	self.acceptedRow:=null;
	self.changeDefaultButtons(btnMsgOK,btnAccept);
	self.changeCancelButtons(btnMsgCancel,btnLogoff);
	
	theTable.selectMode:=Table.SelectMode_WholeRows;
epilog
	app.mousePointer	:=	Idle;	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doTableItemSelect" id="beb6f0ee-8cd4-425b-a8fd-8ffe08174df0">
        <source>doTableItemSelect(_obj: Object input);
/*

Purpose:			


Return Value:		


Date		Who		Reason
07 November 2006	cnwer1	Initial creation - PAR#xxxx

*/
vars
	containerId,
	hazText,
	str : String;
	isHazardous : Boolean;
begin
	inheritMethod(_obj);

	containerId:=tblJobs.accessCell(tblJobs.row,ColNoContainer).text;
	hazText:=tblJobs.accessCell(tblJobs.row,ColNoHazard).text;
	isHazardous:=hazText.isTrue("Yes");
	if isHazardous then
		str:="Container " &amp; containerId &amp; " is Hazardous";
	endif;
	txtTIDetails.text:=str;
epilog

end;</source>
        <Parameter name="_obj" type="Object" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doToggleOrder" id="2a92471f-c1e6-4bb9-ac3e-d01be135742d">
        <source>doToggleOrder();
/*

Purpose:			


Return Value:		


Date		Who		Reason
23 April 2008	cnwer1	Initial creation - PAR#xxxx

*/
vars

	currentSortColumn : Integer;
begin
	
	currentSortColumn:=tblJobs.sortColumn[1];
	tblJobs.sortAsc[1]:=true;
	tblJobs.sortCased[1]:=false;
	if currentSortColumn = ColRTOrder then
		tblJobs.sortColumn[1]:=ColLocation;
		tblJobs.sortType[1]:=Table.SortType_Alpha;
		tblJobs.sortAsc[1]:=true;
	else
		app.myVehicleMountedRTGGuiAgent.myVehicleMountedAgent.updateTableWithRTOrder(1,true,self.tblJobs);
		tblJobs.sortColumn[1]:=ColRTOrder;
		tblJobs.sortType[1]:=Table.SortType_Numeric;
		tblJobs.sortAsc[1]:=true;
	endif;

	tblJobs.resort();


epilog

end;</source>
    </JadeMethod>
