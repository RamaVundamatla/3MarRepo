    <JadeMethod name="translateForm" id="22499a23-38bf-4527-ba0e-c7e4e5134453">
        <updating/>
        <source>translateForm(locale : CM_Locale) updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	
begin
	// Determine the locale for translations.
	inheritMethod(locale);
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0016600, locale);
	lblVoyageMachine.translateCaption(Xlat_0016601, locale);
end;</source>
        <Parameter name="locale" type="CM_Locale"/>
    </JadeMethod>
    <JadeMethod name="updateObjectInTable" id="baefbfad-fad1-4f6e-aed2-5709b1585378">
        <updating/>
        <source>updateObjectInTable(_eventType : Integer; _delay :CM_Delay; _table : CM_MobTable input) : Boolean updating, protected;
// update table of delays from notifications
vars
	row	: Integer;
begin
	if _eventType = Object_Delete_Event or _eventType = Object_Update_Event then
		_table.findObjectInRow(_delay, row);
	
		if row &lt;= _table.fixedRows then
			return false;
		endif;

		_table.removeItem(row); 
		_table.removeItem(row); 
		
		self.doNotableRemove (_delay);
		
		if _eventType = Object_Update_Event then 
			row := _table.rows;
			_table.rows := _table.rows + 2;
			self.doAddToTable(row, _delay);
		endif;
		
	elseif _eventType = Object_Create_Event then
		row := _table.rows;
		_table.rows := _table.rows + 2;
		self.doAddToTable(row, _delay);
	endif;
	
	self.colourRows();
	 
	return true;
end;
</source>
        <access>protected</access>
        <Parameter name="_eventType" type="Integer"/>
        <Parameter name="_delay" type="CM_Delay"/>
        <Parameter name="_table" type="CM_MobTable" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</GUIClass>
