	addDamageWithDate(container9Obj, "BENT", "All", null, 1, "container3 damage1", now);			
	addDamageWithRepair(container10Obj, "RUST", "All", null, 1, "container4 damage1", now, repairReason, "repair of damage1 container4Obj", now.addHours(+1));	
	addDamageWithRepair(container11Obj, "RUST", "All", null, 1, "container5 damage1", now, repairReason, "repair of damage1 container5Obj", now.addHours(+1));	
	
	
	
