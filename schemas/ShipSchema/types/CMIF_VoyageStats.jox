<Class name="CMIF_VoyageStats">
    <JadeMethod name="getWorkETCActualNew" id="9dc4c045-f399-4fbf-8a35-c79f07a17895">
        <source>getWorkETCActualNew() : TimeStamp;
/*

Purpose:			


Return Value:		


Date		Who		Reason
26 March 2007	cnwer1	Initial creation - PAR#13669

*/
vars
	shpJobDrawController: 	SHP_JobControllerController;
	allJobsStartEndTime : ObjectArray ;
begin

	create shpJobDrawController transient;
	shpJobDrawController.setMyVoyage(self.myVoyage);
	create allJobsStartEndTime transient;
	shpJobDrawController.getAllJobs(allJobsStartEndTime);
	return shpJobDrawController.voyageEndTime;

epilog

	delete shpJobDrawController;
	allJobsStartEndTime.purge;
	delete allJobsStartEndTime;

end;</source>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
</Class>
