    <JadeMethod name="compareUsersDataAccess" id="5e325934-2d8d-4cc6-8fdc-04d2a1ddc5b9">
        <source>compareUsersDataAccess(_user : CM_User; _class : Class) : Boolean;
// -------------------------------------------
// Created 15 December 2004 by cnwdvb1
// -------------------------------------------
vars

	comparedDataAccess,
	orginalDataAccess	: CM_DataAccessController;

begin

	if _class = CM_Carrier then
	
		comparedDataAccess := _user.getDataAccessController(CM_Carrier.name);
		orginalDataAccess := self.getDataAccessController(CM_Carrier.name);
		
		// If we don't have a data access controller then we are allowed to view object.
		if comparedDataAccess &lt;&gt; null then
			if orginalDataAccess = null or not orginalDataAccess.compareDataControllerObjs(comparedDataAccess) then
				return false;
			endif;
		endif;
		return true;
	endif;
	
	
	if _class = CM_ConsigneeConsignor then
		comparedDataAccess := _user.getDataAccessController(CM_ConsigneeConsignor.name);
		orginalDataAccess := self.getDataAccessController(CM_ConsigneeConsignor.name);
		
		// If we don't have a data access controller then we are allowed to view object.
		if comparedDataAccess &lt;&gt; null then
			if orginalDataAccess = null or not orginalDataAccess.compareDataControllerObjs(comparedDataAccess) then
				return false;
			endif;
		endif;
		return true;
	endif;
	
	
	if _class = CM_Operator then
		comparedDataAccess := _user.getDataAccessController(CM_Operator.name);
		orginalDataAccess := self.getDataAccessController(CM_Operator.name);
		
		// If we don't have a data access controller then we are allowed to view object.
		if comparedDataAccess &lt;&gt; null then
			if orginalDataAccess = null or not orginalDataAccess.compareDataControllerObjs(comparedDataAccess) then
				return false;
			endif;
		endif;
		return true;
	endif;

	
/*	comparedDataAccess := _user.getDataAccessController(CM_Organisation.name);
	orginalDataAccess := self.getDataAccessController(CM_Organisation.name);
	
	if comparedDataAccess &lt;&gt; null then
		if orginalDataAccess = null or not orginalDataAccess.compareDataControllerObjs(comparedDataAccess) then
			_errorStr := 'Organisation Data Access';
			return false;
		endif;
	endif;*/
	
	return true;


end;</source>
        <Parameter name="_user" type="CM_User"/>
        <Parameter name="_class" type="Class"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="convertUserWindowsFor724" id="fc8681db-fc2b-407b-80e1-2b638af5d3cc">
        <updating/>
        <source>convertUserWindowsFor724() updating;
// ---------------------------------------------------------------------------
// Created:     01 September 2004 by cnwrs2
//
// Purpose:     The 724 upgrade moved the CM_UserWindows down to new sub-class
// ---------------------------------------------------------------------------
vars
	oldUserWin	: CM_UserWindow;
	newUserWin	: CM_UserWindowForOpen;

begin

	foreach oldUserWin in self.allUserWindows do
		newUserWin := oldUserWin.cloneSelfAs(CM_UserWindowForOpen, false).CM_UserWindowForOpen;
		newUserWin.setUserFor724(self);
	endforeach;
	
	self.allUserWindows.purge;

end;</source>
    </JadeMethod>
    <JadeMethod name="create" id="719d1a61-06c1-4757-8645-58b798e0813f">
