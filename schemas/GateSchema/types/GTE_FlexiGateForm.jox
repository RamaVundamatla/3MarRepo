    <JadeMethod name="lstAVGrade_lostFocus" id="4c07a429-b698-4877-b8bf-d64ac917c0fe">
        <controlMethod name="Table::lostFocus"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>lstAVGrade_lostFocus(table: Table input) updating;
/*

Date		Who		Reason
21 August 2013	cnwer1	Initial creation PAR

*/

vars
	str : String;
begin
	// get codes from list box, display in text box and disappear the list box
	str := self.lstAVGrade.getSelectedString(CM_MTGrade::description.name);
	if str.length &gt; 30 then
		self.txtAVGrade.text := str[1:29]&amp; '...';
	else
		self.txtAVGrade.text := str;
	endif;
	self.txtAVGrade.visible := true;
	self.lstAVGrade.visible:=false;
	self.lstAVGrade.parent := self.grpTrailerOut;
epilog

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
