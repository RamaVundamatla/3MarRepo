    <JadeMethod name="utlUpdateCodeGroupLogSpecsTree" id="257a3ae6-aef4-4476-bdfe-846b5585ed00">
        <source>utlUpdateCodeGroupLogSpecsTree(_proxyCodeGroup, _realCodeGroup : CM_CodeGroup; _passport : CM_Passport input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 December 2014	cnwmc5	Initial creation

*/

vars
	deleteLogSpecies		: CM_CodesByCodeDict;
	deleteLogGrades			: CM_CodesByCodeDict;
	deleteLogTreatments		: CM_CodesByCodeDict;
	deleteLogTypes			: CM_CodesByCodeDict;
	deleteLogLengths		: CM_CodesByCodeDict;
	
	pxyCodeGroupLogSpecs,
	realCodeGroupLogSpecs	: CM_CodeGroupLogSpecs;
	
	pxyGrade,
	grade					: CM_LogGrade;
	pxyLength,
	length					: CM_LogLength;
	pxySpecies,
	species					: CM_LogSpecies;
	pxyTreatment,
	treatment				: CM_LogTreatment;
	pxyType,
	type					: CM_LogType;
	pxyCode,
	pxyCodeGrade			: CM_Code;
	
begin
	self.initialiseActivity();
	
	if not _realCodeGroup.isKindOf(CM_CodeGroupLogSpecs) then
		app.raiseCMException1(Err_InvalidClass, _proxyCodeGroup.class.String, null, null);
		return;
	endif;
	
	app.myUtilityUA.utlUpdateCodeGroup(_proxyCodeGroup, _passport);
	
	pxyCodeGroupLogSpecs := _proxyCodeGroup.CM_CodeGroupLogSpecs;
	realCodeGroupLogSpecs := _realCodeGroup.CM_CodeGroupLogSpecs;
	
	create deleteLogSpecies transient;
	create deleteLogGrades transient;
	create deleteLogTreatments transient;
	create deleteLogTypes transient;
	create deleteLogLengths transient;
	
	realCodeGroupLogSpecs.allLogLengths.copy(deleteLogLengths);
	foreach pxyLength in pxyCodeGroupLogSpecs.allLogLengths do
		length := realCodeGroupLogSpecs.allLogLengths[pxyLength.code];
		
		if length = null then
			pxyLength.setCodeGroupLogSpecs(realCodeGroupLogSpecs);
			app.myUtilityCA.utlCreateLogLength(pxyLength, length, _passport);
		else
			self.utlUpdateLogLength(pxyLength, _passport);
			deleteLogLengths.remove(length);
		endif;
		pxyLength.setCodeGroupLogSpecs(pxyCodeGroupLogSpecs);		//cnwmc5 - 19 Dec 2014 - PAR 35446
	endforeach;
	
	realCodeGroupLogSpecs.allLogTreatments.copy(deleteLogTreatments);
	foreach pxyTreatment in pxyCodeGroupLogSpecs.allLogTreatments do
		treatment := realCodeGroupLogSpecs.allLogTreatments[pxyTreatment.code];
		
		if treatment = null then
			pxyTreatment.setCodeGroupLogSpecs(realCodeGroupLogSpecs);
			app.myUtilityCA.utlCreateLogTreatment(pxyTreatment, treatment, _passport);
		else
			self.utlUpdateLogTreatment(pxyTreatment, _passport);
			deleteLogTreatments.remove(treatment);
		endif;
		pxyTreatment.setCodeGroupLogSpecs(pxyCodeGroupLogSpecs);	//cnwmc5 - 19 Dec 2014 - PAR 35446
	endforeach;
	
	realCodeGroupLogSpecs.allLogTypes.copy(deleteLogTypes);
	foreach pxyType in pxyCodeGroupLogSpecs.allLogTypes do
		type := realCodeGroupLogSpecs.allLogTypes[pxyType.code];
		
		if type = null then
			pxyType.setCodeGroupLogSpecs(realCodeGroupLogSpecs);
			app.myUtilityCA.utlCreateLogType(pxyType, type, _passport);
		else
			self.utlUpdateLogType(pxyType, _passport);
			deleteLogTypes.remove(type);
		endif;
		pxyType.setCodeGroupLogSpecs(pxyCodeGroupLogSpecs);			//cnwmc5 - 19 Dec 2014 - PAR 35446
	endforeach;
	
	realCodeGroupLogSpecs.allCodes.copy(deleteLogSpecies);
	foreach pxyCode in pxyCodeGroupLogSpecs.allCodes do
		if not pxyCode.isKindOf(CM_LogSpecies) then
			continue;
		endif;
		
		pxySpecies := pxyCode.CM_LogSpecies;
		species := realCodeGroupLogSpecs.allCodes[pxyCode.code].CM_LogSpecies;
		
		if species = null then
			pxySpecies.setCodeGroup(realCodeGroupLogSpecs);
			app.myUtilityCA.utlCreateLogSpecies(pxySpecies, species, _passport);
		else
			self.utlUpdateLogSpecies(pxySpecies, _passport);
			deleteLogSpecies.remove(species);
		endif;
		pxySpecies.setCodeGroup(pxyCodeGroupLogSpecs);				//cnwmc5 - 19 Dec 2014 - PAR 35446
		
		//cnwmc5 - 19 Dec 2014 - PAR 35446
		if app.myPassport.hasErrors then
			return;
		endif;
		
		species.allLogGrades.copy(deleteLogGrades);
		foreach pxyCodeGrade in pxySpecies.allLogGrades do
			if not pxyCodeGrade.isKindOf(CM_LogGrade) then
				continue;
			endif;
			
			pxyGrade := pxyCodeGrade.CM_LogGrade;
			grade := species.allLogGrades[pxyGrade.code].CM_LogGrade;
			
			pxyGrade.setLogSpecies(species);
			pxyGrade.setRealLogSpecs(realCodeGroupLogSpecs);
			
			if grade = null then
				app.myUtilityCA.utlCreateLogGrade(pxyGrade, grade, _passport);
			else
				self.utlUpdateLogGrade(pxyGrade, _passport);
				deleteLogGrades.remove(grade);
			endif;
			pxyGrade.setLogSpecies(pxySpecies);						//cnwmc5 - 19 Dec 2014 - PAR 35446
			pxyGrade.setRealLogSpecs(pxyCodeGroupLogSpecs);			//cnwmc5 - 19 Dec 2014 - PAR 35446
		endforeach;
	endforeach;
	
	foreach pxyCode in deleteLogGrades do
		if not pxyCode.isKindOf(CM_LogGrade) then
			continue;
		endif;
		
		app.myUtilityDA.utlDeleteLogGrade(pxyCode.CM_LogGrade, _passport);
	endforeach;
	
	foreach pxyCode in deleteLogLengths do
		if not pxyCode.isKindOf(CM_LogLength) then
			continue;
		endif;
		
		app.myUtilityDA.utlDeleteLogLength(pxyCode.CM_LogLength, _passport);
	endforeach;
	
	foreach pxyCode in deleteLogTreatments do
		if not pxyCode.isKindOf(CM_LogTreatment) then
			continue;
		endif;
		
		app.myUtilityDA.utlDeleteLogTreatment(pxyCode.CM_LogTreatment, _passport);
	endforeach;
	
	foreach pxyCode in deleteLogTypes do
		if not pxyCode.isKindOf(CM_LogType) then
			continue;
		endif;
		
		app.myUtilityDA.utlDeleteLogType(pxyCode.CM_LogType, _passport);
	endforeach;
	
	foreach pxyCode in deleteLogSpecies do
		if not pxyCode.isKindOf(CM_LogSpecies) then
			continue;
		endif;
		
		app.myUtilityDA.utlDeleteLogSpecies(pxyCode.CM_LogSpecies, _passport);
	endforeach;

epilog
	delete deleteLogSpecies;
	delete deleteLogGrades;
	delete deleteLogTreatments;
	delete deleteLogTypes;
	delete deleteLogLengths;
	
end;</source>
        <Parameter name="_proxyCodeGroup" type="CM_CodeGroup"/>
        <Parameter name="_realCodeGroup" type="CM_CodeGroup"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateCodeGroupSrcLocTree" id="b9dd47b9-9b1b-4e8b-b102-949b763a5575">
        <source>utlUpdateCodeGroupSrcLocTree(_proxyCodeGroup, _realCodeGroup : CM_CodeGroup; _passport : CM_Passport input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 December 2014	cnwmc5	Initial creation

*/

vars
	deleteSrcLocs		: CM_CodesByCodeDict;
	deleteSrcSubLocs	: CM_CodesByCodeDict;
	deleteSrcSubSubLocs	: CM_CodesByCodeDict;
	
	pxyCodeSrcLoc		: CM_Code;
	pxyCodeSrcSubLoc	: CM_Code;
	pxyCodeSrcSubSubLoc	: CM_Code;
	srcLoc,
	pxySrcLoc			: CM_SourceLocation;
	srcSubLoc,
	pxySrcSubLoc		: CM_SourceSubLocation;
	srcSubSubLoc,
	pxySrcSubSubLoc		: CM_SourceSubSubLocation;
	
	load				: Boolean;
	
begin
	self.initialiseActivity();
	
	create deleteSrcLocs transient;
	create deleteSrcSubLocs transient;
	create deleteSrcSubSubLocs transient;
	
	_realCodeGroup.allCodes.copy(deleteSrcLocs);
	
	foreach pxyCodeSrcLoc in _proxyCodeGroup.allCodes do
		if not pxyCodeSrcLoc.isKindOf(CM_SourceLocation) then
			continue;
		endif;
		
		pxySrcLoc := pxyCodeSrcLoc.CM_SourceLocation;
		srcLoc := _realCodeGroup.allCodes[pxyCodeSrcLoc.code].CM_SourceLocation;
		
		if srcLoc = null then
			pxySrcLoc.setCodeGroup(_realCodeGroup);
			app.myUtilityCA.utlCreateSourceLocation(pxySrcLoc, srcLoc, _passport);
			pxySrcLoc.setCodeGroup(_proxyCodeGroup);			//cnwmc5 - 19 Dec 2014 - PAR 35446
		else
			self.utlUpdateSourceLocation(pxySrcLoc, srcLoc, _passport);
			deleteSrcLocs.remove(srcLoc);
		endif;
		
		//cnwmc5 - 19 Dec 2014 - PAR 35446
		if app.myPassport.hasErrors then
			return;
		endif;
		
		srcLoc.allSubLocations.copy(deleteSrcSubLocs);
		foreach pxyCodeSrcSubLoc in pxySrcLoc.allSubLocations do
			if not pxyCodeSrcSubLoc.isKindOf(CM_SourceSubLocation) then
				continue;
			endif;
			
			pxySrcSubLoc := pxyCodeSrcSubLoc.CM_SourceSubLocation;
			srcSubLoc := srcLoc.allSubLocations[pxySrcSubLoc.code].CM_SourceSubLocation;
			
			if srcSubLoc = null then
				pxySrcSubLoc.setSourceLocation(srcLoc);
				app.myUtilityCA.utlCreateSourceSubLocation(pxySrcSubLoc, srcSubLoc, _passport);
				pxySrcSubLoc.setSourceLocation(pxySrcLoc);		//cnwmc5 - 19 Dec 2014 - PAR 35446
			else
				self.utlUpdateSourceSubLocation(pxySrcSubLoc, srcSubLoc, _passport);
				deleteSrcSubLocs.remove(srcSubLoc);
			endif;
			
			//cnwmc5 - 19 Dec 2014 - PAR 35446
			if app.myPassport.hasErrors then
				return;
			endif;
			
			srcSubLoc.allSubSubLocations.copy(deleteSrcSubSubLocs);
			foreach pxyCodeSrcSubSubLoc in pxySrcSubLoc.allSubSubLocations do
				if not pxyCodeSrcSubSubLoc.isKindOf(CM_SourceSubSubLocation) then
					continue;
				endif;
				
				pxySrcSubSubLoc := pxyCodeSrcSubSubLoc.CM_SourceSubSubLocation;
				srcSubSubLoc := srcSubLoc.allSubSubLocations[pxySrcSubSubLoc.code].CM_SourceSubSubLocation;
				
				if srcSubSubLoc = null then
					pxySrcSubSubLoc.setSourceSubLocation(srcSubLoc);
					app.myUtilityCA.utlCreateSourceSubSubLocation(pxySrcSubSubLoc, srcSubSubLoc, _passport);
					pxySrcSubSubLoc.setSourceSubLocation(pxySrcSubLoc);		//cnwmc5 - 19 Dec 2014 - PAR 35446
				else
					self.utlUpdateSourceSubSubLocation(pxySrcSubSubLoc, _passport);
					deleteSrcSubSubLocs.remove(srcSubSubLoc);
				endif;
			endforeach;
		endforeach;
	endforeach;
	
	foreach pxyCodeSrcSubSubLoc in deleteSrcSubSubLocs do
		if not pxyCodeSrcSubSubLoc.isKindOf(CM_SourceSubSubLocation) then
			continue;
		endif;
		
		app.myUtilityDA.utlDeleteSourceSubSubLocation(pxyCodeSrcSubSubLoc.CM_SourceSubSubLocation, _passport);
	endforeach;
	
	foreach pxyCodeSrcSubLoc in deleteSrcSubLocs do
		if not pxyCodeSrcSubLoc.isKindOf(CM_SourceSubLocation) then
			continue;
		endif;
		
		app.myUtilityDA.utlDeleteSourceSubLocation(pxyCodeSrcSubLoc.CM_SourceSubLocation, _passport);
	endforeach;
	
	foreach pxyCodeSrcLoc in deleteSrcLocs do
		if not pxyCodeSrcLoc.isKindOf(CM_SourceLocation) then
			continue;
		endif;
		
		app.myUtilityDA.utlDeleteSourceLocation(pxyCodeSrcLoc.CM_SourceLocation, _passport);
	endforeach;
	
epilog
	delete deleteSrcLocs;
	delete deleteSrcSubLocs;
	delete deleteSrcSubSubLocs;
	
end;</source>
        <Parameter name="_proxyCodeGroup" type="CM_CodeGroup"/>
        <Parameter name="_realCodeGroup" type="CM_CodeGroup"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateCodeGroupType" id="113f6826-c9a4-4f57-8042-e91b34eac9e6">
        <source>utlUpdateCodeGroupType(pProxyCodeGroupType : CM_CodeGroupType; _passport : CM_Passport input);
// ---------------------------------------------------------------------------
// Created:     06 June 2002 by cnwsb1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	realCodeGroupType	: CM_CodeGroupType;
	expectedEdition		: Integer;
	
begin

	self.initialiseActivity();

	pProxyCodeGroupType.raiseExceptionIfNotProxy(method);

	app.setContinueCMExceptions(true);

	pProxyCodeGroupType.pxyGetRealObjectAndEdition(realCodeGroupType, expectedEdition);
	
	if realCodeGroupType = null then	
		app.raiseCMException1(ProxyMgrCannotLocateReal, CM_CodeGroupType.name, null, null);
		return;
	endif;

	app.myValUA.valCodeGroupType(realCodeGroupType, pProxyCodeGroupType);
	
	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	
	app.setContinueCMExceptions(false);

	exclusiveLock(realCodeGroupType);

	if _passport.noErrors and realCodeGroupType.edition &lt;&gt; expectedEdition then
		app.raiseCMException1(ObjectUpdatedByAnotherUserSave, 'CodeGroup Type', null, null);
		return;
	endif;
	
	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realCodeGroupType, true);
	endif;
	
	if _passport.noErrors then
		realCodeGroupType.setForUpdate(pProxyCodeGroupType);
	endif;

	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realCodeGroupType, false);
	endif;

end;</source>
        <Parameter name="pProxyCodeGroupType" type="CM_CodeGroupType"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateCommodity" id="d0b2a3f8-28b9-4acf-a980-256ffbb41996">
        <source>utlUpdateCommodity(pProxyCommodity:CM_Commodity; _passport : CM_Passport input);
// ---------------------------------------------------------------------------
// Created:     16 July 2001 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 06/12/2018	jlgdap1		TFS 42083 PEL1 Cargo Transaction map - Commodity update
// ---------------------------------------------------------------------------
vars
	realCommodity:CM_Commodity;
	expectedEdition:Integer;
	oldCode, newCode : String;				// TFS 42083
	
begin

	self.initialiseActivity();

	pProxyCommodity.raiseExceptionIfNotProxy(method);

	app.setContinueCMExceptions(true);

	pProxyCommodity.pxyGetRealObjectAndEdition(realCommodity, expectedEdition);
	newCode := pProxyCommodity.code;							// TFS 42083
	oldCode := realCommodity.code;								// TFS 42083
	
	if realCommodity = null then	
		app.raiseCMException1(ProxyMgrCannotLocateReal, CM_Commodity.name, null, null);
		return;
	endif;

	app.myValUA.valCommodity(realCommodity, pProxyCommodity);
	
	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	
	app.setContinueCMExceptions(false);

	exclusiveLock(realCommodity);

	if _passport.noErrors and realCommodity.edition &lt;&gt; expectedEdition then
		app.raiseCMException1(ObjectUpdatedByAnotherUserSave, 'Commodity', null, null);
		return;
	endif;
	
	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realCommodity, true);
	endif;
	
	if _passport.noErrors then
		realCommodity.setForUpdate(pProxyCommodity);
	endif;

	if _passport.noErrors then									// TFS 42083
		if oldCode &lt;&gt; newCode then								// TFS 42083
			self.updateCommodityMapCode(oldCode, newCode);		// TFS 42083
		endif;													// TFS 42083
	endif;														// TFS 42083

	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realCommodity, false);
	endif;

end;</source>
        <Parameter name="pProxyCommodity" type="CM_Commodity"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateCommodityGroup" id="34fd46c7-24cb-4614-82ef-89320709813d">
        <source>utlUpdateCommodityGroup(pProxyCommodityGroup:CM_CommodityGroup; _passport : CM_Passport input);
// ---------------------------------------------------------------------------
// Created:     16 July 2001 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	realCommodityGroup:CM_CommodityGroup;
	expectedEdition:Integer;
	codeChanged:Boolean;
	eventStr : String;
	theTerminal : CM_Terminal;
begin

	self.initialiseActivity();

	pProxyCommodityGroup.raiseExceptionIfNotProxy(method);

	app.setContinueCMExceptions(true);

	pProxyCommodityGroup.pxyGetRealObjectAndEdition(realCommodityGroup, expectedEdition);
	
	if realCommodityGroup = null then	
		app.raiseCMException1(ProxyMgrCannotLocateReal, CM_CommodityGroup.name, null, null);
		return;
	endif;

	app.myValUA.valCommodityGroup(realCommodityGroup, pProxyCommodityGroup);
	
	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	
	app.setContinueCMExceptions(false);

	exclusiveLock(realCommodityGroup);

	if _passport.noErrors and realCommodityGroup.edition &lt;&gt; expectedEdition then
		app.raiseCMException1(ObjectUpdatedByAnotherUserSave, 'CommodityGroup', null, null);
		return;
	endif;
	
	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realCommodityGroup, true);
	endif;
	
	if _passport.noErrors then
		if realCommodityGroup.colour &lt;&gt; pProxyCommodityGroup.colour then
			codeChanged := true;
		endif;
		realCommodityGroup.setForUpdate(pProxyCommodityGroup);
	endif;

	if _passport.noErrors then
		if codeChanged then
			eventStr := eventStr &amp;  "&lt;" &amp; GridXML_ColourCode &amp; "&gt;" &amp; realCommodityGroup.code  &amp; "&lt;/" &amp; GridXML_ColourCode &amp; "&gt;";
			eventStr := eventStr &amp;  "&lt;" &amp; GridXML_Colour &amp; "&gt;" &amp; realCommodityGroup.colour.String  &amp; "&lt;/" &amp; GridXML_Colour &amp; "&gt;";
			realCommodityGroup.causeEvent(EVENT_CODE_COLOUR_CHANGE, false, eventStr);
		endif;
		self.myUpdateAuditAgent.audUpdateGeneric(realCommodityGroup, false);
	endif;

end;</source>
        <Parameter name="pProxyCommodityGroup" type="CM_CommodityGroup"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateCompletedWOTask" id="be7eabdf-65f9-4335-be3f-d0656d55fe63">
        <updating/>
        <source>utlUpdateCompletedWOTask(_pxyWorkOrderDtl : CM_WorkOrderDtl input; _passport : CM_Passport input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13/11/2024	navkc1 JIRA Story MTN-33012: EUP | WO Transaction Billing Change of Debtor

*/

vars
	realWorkOrderDtl : CM_WorkOrderDtl;
	expectedEdition : Integer;
begin
	
	self.initialiseActivity();

	_pxyWorkOrderDtl.raiseExceptionIfNotProxy(method);

	app.setContinueCMExceptions(true);

	_pxyWorkOrderDtl.pxyGetRealObjectAndEdition(realWorkOrderDtl, expectedEdition);
	
	if realWorkOrderDtl = null then	
		app.raiseCMException1(ProxyMgrCannotLocateReal, CM_WorkOrderDtl.name, null, null);
		return;
	endif;

	app.myValUA.valWorkOrderTask(_pxyWorkOrderDtl);
	
	if (not self.checkValidationWithPassport(_passport)) then
		return;
	endif;
	
	app.setContinueCMExceptions(false);

	exclusiveLock(realWorkOrderDtl);

	if _passport.noErrors and realWorkOrderDtl.edition &lt;&gt; expectedEdition then
		app.raiseCMException1(ObjectUpdatedByAnotherUserSave, 'Work Order Task', null, null);
		return;
	endif;

	realWorkOrderDtl.setForUpdateCompleted(_pxyWorkOrderDtl);
	realWorkOrderDtl.doUpdateCompletedTansaction();
	realWorkOrderDtl.doVoidInvoiceLines();
	
	//jlier1 29/5/25 MTN-34591 
	realWorkOrderDtl.causeTerminalEvent(Event_WODtl_Update);
epilog

end;</source>
        <Parameter name="_pxyWorkOrderDtl" type="CM_WorkOrderDtl" usage="input"/>
