    <JadeMethod name="doSetdownTask" id="2fbd49bc-85d7-44eb-8ad3-7638dbc55e36">
        <updating/>
        <source>doSetdownTask(_rtTask: CM_RTQueueTask input; _twinTask: CM_RTQueueTask input; _setdownLoc: String; _twinSetdownLoc: String; _overrideToInterchange: Boolean; _errorMsgs: DTO_HandHeldGateErrorDict input) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
24 May 2010	cnwer1	Initial creation
01 Jul 2010	cnwkpd1	PAR #24858 - Change to use new trx for weight update
01 Jul 2010 cnwer1	PAR #24564 - after the initial setdown trx is completed successfully make sure after subsequent trx calls the passport trxCompletedOK returns true
03/08/2016  cnwma1  TFS 2475:PNL- Missing error relating to Loadrite interface
*/

vars

	taskTI : CM_TrackedItem;
	isCertified : Boolean;
	isTwin : Boolean;
	weight : Integer;
	taskQueue : CM_RadioTelemetryQueue;
begin
	self.initialiseForNewRequest(_errorMsgs);  //cnwjo3 par 24636

	taskTI:=_rtTask.ti;
	isTwin:= _twinTask &lt;&gt; null;
	
	taskQueue:=_rtTask.queue;
	
	inheritMethod(_rtTask, _twinTask, _setdownLoc, _twinSetdownLoc, _overrideToInterchange, _errorMsgs);
	// if  no errors and not showing task list
	
	if not app.myPassport.trxCompletedOK then
		return;
	endif;
	
/*	if taskQueue &lt;&gt; self.myRTQueue then
		self.myVMInterface.doRTQueueEntryChanged(null);
	endif;*/
	
	//get loadrite weight from interface
	// don't if its a twin
	if not isTwin and taskTI &lt;&gt; null then
		weight:=self.myVMInterface.getLoadriteWeight();
		isCertified := self.myVMInterface.isWeightCertified();
		if weight &lt;&gt; 0 then
			//self.myMachine.weighBox(weight,taskTI);
			app.myTrxUA.trxUpdateMachineWeighContainer(self.myMachine, taskTI, weight, isCertified, app.myPassport);
			// Ignore errors returned from weighing a container
			app.myPassport.initialiseTransaction;
			app.myPassport.finaliseTransaction(TRXStatus_Committed);
		endif;
	endif;

	if self.showingTaskList then
		return;
	endif;
	
	if not self.doAutomaticGetNextTask then
		return;
	endif;
	
	//epr par 33382 28/1/14 if it was a overstow task setdown will already have a task so don't try to get another because will just get an
	// error
	if self.myMachine.allCurrentWorkingQueueTasks.size &gt; 0 then
		return;
	endif;
	
	self.doGetNextTask(_errorMsgs,false);
	
	
	//epr par 24564 25/6/10 
	//we know the setdown trx completed succussfully regardless of the get next trx  make sure the passport  is trx completed ok
	app.myPassport.initialiseTransaction;
	app.myPassport.finaliseTransaction(TRXStatus_Committed); //epr par 24564
	
epilog

end;</source>
        <Parameter name="_rtTask" type="CM_RTQueueTask" usage="input"/>
        <Parameter name="_twinTask" type="CM_RTQueueTask" usage="input"/>
        <Parameter name="_setdownLoc" type="String"/>
        <Parameter name="_twinSetdownLoc" type="String"/>
        <Parameter name="_overrideToInterchange" type="Boolean"/>
        <Parameter name="_errorMsgs" type="DTO_HandHeldGateErrorDict" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doSwapTandemTasks" id="282c0390-3076-4f2e-8064-9fc4e960bfbe">
        <source>doSwapTandemTasks(_firstTask, _secondTask : DTO_RTQueueEntry input);
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
17 June 2010	cnwer1	Initial creation

*/

vars
	result : Boolean;
	firstTask, secondTask  : CM_RTQueueTask;
begin
	firstTask:=_firstTask.myRealQueueEntry.CM_RTQueueEntry.getFirstUncompletedTask;
	secondTask:=_secondTask.myRealQueueEntry.CM_RTQueueEntry.getFirstUncompletedTask;
	
	while true do
		self.initialiseForNewRequest(null);

		app.myTrxUA.trxSwapMachineTandemTasks(self.myMachine,firstTask, secondTask,app.myPassport);
		
		if app.myPassport.trxCompletedOK then
			break;
		endif;
		result:= self.createErrorsFromPassport(null);
		if result then
			break;
		else
			continue;
		endif;
	endwhile;
epilog

end;</source>
        <Parameter name="_firstTask" type="DTO_RTQueueEntry" usage="input"/>
        <Parameter name="_secondTask" type="DTO_RTQueueEntry" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doToggleSortOrder" id="2e7adbe6-8221-44e0-b46e-c1ed8488b3bf">
        <updating/>
        <source>doToggleSortOrder(_table : Table input) protected , updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
13 April 2010	cnwer1	Initial creation

//only sorted by rt queue order
*/

vars
	sortColumn : Integer;
begin
	if self.myVMInterface = null then
		return;
	endif;
	
	if  not self.myVMInterface.sortTableInRTQueueOrder(_table) then
		return;
	endif;
	

	self.updateTableWithRTOrder(1,true,_table);
	sortColumn:=self.getSortColumn(_table);
	_table.accessColumn(sortColumn).visible:=false;
	_table.accessColumn(sortColumn).itemObject:=null;  //epr par 33552
		
	_table.sortColumn[1]:=sortColumn;
	_table.sortType[1]:=Table.SortType_Numeric;
	_table.sortAsc[1]:=true;
	

	_table.resort();


epilog

end;</source>
        <access>protected</access>
        <Parameter name="_table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doesSeperatePickupSetdown" id="4f99e94a-a226-4694-9651-1c158ead3115">
        <updating/>
        <source>doesSeperatePickupSetdown() :Boolean updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
14 April 2010	cnwer1	Initial creation

*/

vars

begin
	return self.getMyRTVehicleConfig.useSeperatePickupSetdown;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="filterSearchedResults" id="dfb96491-a076-4327-9b4f-e2c6f4d91bbd">
        <updating/>
        <source>filterSearchedResults(	_foundTIs : CM_TISet input;
						_allAvailRTEntries,
						_allFoundRTEntries : CM_RTQueueEntryArray input;
						_allNonRTTis : CM_TIArray input;
						_isEnquiry : Boolean) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
23 April 2010	cnwer1	Initial creation

*/

vars
	maxNumberSearchResult 		: Integer;
	invalidObject		: Boolean;
	iter 				: Iterator;
	ti					: CM_TrackedItem;
	fm					: CM_FutureMove;
	qfm					: CM_FutureMoveQueued;
	rtQueueEntry		: CM_RTQueueEntry;
	rtConfig			: CM_RTVehicleConfig;
begin
	if _foundTIs = null then
	
		return;
	endif;
	
	maxNumberSearchResult:=self.getMaxDisplaySearchResults();
	
	on Exception do app.handleDeletedObject(exception,rtQueueEntry,invalidObject);
	rtConfig:=self.getMyRTVehicleConfig;		
	// get RT results first;
	iter:=_foundTIs.createIterator;
	while iter.next(ti) do
		if not _isEnquiry then
			foreach fm in ti.allQueuedFutureMoves do
				qfm:=fm.CM_FutureMoveQueued;
				if qfm.allRTQueueEntries.size = 0 then
					continue;
				endif;
				
				foreach rtQueueEntry in qfm.allRTQueueEntries do
				
				//	if self.canDisplaySecondaryQueues then
					if rtConfig.limitEnquiryToCurrentQ then
						if self.canDisplaySecondaryQueues then
							if not self.myMachine.allQueues.includes(rtQueueEntry.myQueue) 
							and rtQueueEntry.myQueue &lt;&gt; self.myRTQueue then		// 22/09/2011 cnwar2 #28214
								continue;										// Also check primary q in case it is not in the secondary q list (allQueues)
							endif;
						else
							if rtQueueEntry.myQueue &lt;&gt; self.myRTQueue then
								continue;
							endif;
						endif;
					endif;
					
					_allFoundRTEntries.add(rtQueueEntry);
					
					if not self.queryDisplayRTEntry(rtQueueEntry) then
						continue;
					endif;
					
					
					_allAvailRTEntries.add(rtQueueEntry);
					
				endforeach;
			endforeach;		
		else
			_allNonRTTis.add(ti);
			if _allNonRTTis.size = maxNumberSearchResult then
				break;
			endif;
		endif;
	endwhile;
	
	
epilog
	delete iter;

end;</source>
        <Parameter name="_foundTIs" type="CM_TISet" usage="input"/>
        <Parameter name="_allAvailRTEntries" type="CM_RTQueueEntryArray" usage="input"/>
        <Parameter name="_allFoundRTEntries" type="CM_RTQueueEntryArray" usage="input"/>
        <Parameter name="_allNonRTTis" type="CM_TIArray" usage="input"/>
        <Parameter name="_isEnquiry" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="findTwinTask" id="2b381f32-fcc6-47fb-9f5f-3c1ad1486240">
        <source>findTwinTask(	_dtoQueueEntry : DTO_RTQueueEntry input;
				_selectedTasks : CM_RTQueueTaskArray input;
				_isTwin: Boolean);
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
13 Apr 2010	cnwer1	Initial creation
07 Dec 2010 cnwer1	par  25876 for closest overstows can't just get first task
19 Jan 2016	cnwkpd1	PAR #37398 - 1090 from VMT applicationb

*/

vars
	rtQueueEntry ,
	twinRTQueueEntry : CM_RTQueueEntry;
	rtQueueTask,
	twinTask : CM_RTQueueTask;
	errorString : String;
begin
	rtQueueTask := self.getQueueTask(_dtoQueueEntry);  // CCMS 1210
	
	// PAR #37398 - Due to timing of notification processing, the real task behind the selected queue entry can have
	// already been deleted, so a null queue entry is returned.  In this case, just return.
	if rtQueueTask = null then
		return;
	endif;
	
	_selectedTasks.add(rtQueueTask);

	if not _isTwin then   // SFW 1210 
		return;
	endif;
	
	if (not self.myMachine.machineType = MACHINETYPE_IMV and not self.myMachine.isTwinLift()) then
		return;
	endif;
	
	
 
	if  self.showingTaskList then
		twinRTQueueEntry:=rtQueueTask.myEntry.getTwinnableEntry();
		if twinRTQueueEntry &lt;&gt; null then
			//7/12/10 epr par 25876 
			twinTask:=twinRTQueueEntry.getDirectorOrPickupTask();
			if not self.myMachine.checkTwinCarryTwoTasks(rtQueueTask,twinTask,false,errorString) then
				 twinTask:=null;
			endif;
		endif;
	else
		twinTask:=self.myMachine.findOtherTwinTask(rtQueueTask);
		
	endif;
	
	if twinTask &lt;&gt; null then
		_selectedTasks.add(twinTask);
	endif;
epilog

end;</source>
        <Parameter name="_dtoQueueEntry" type="DTO_RTQueueEntry" usage="input"/>
        <Parameter name="_selectedTasks" type="CM_RTQueueTaskArray" usage="input"/>
        <Parameter name="_isTwin" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getCurrentAccessDirectionDesc" id="e9ef5ecc-2f15-4b00-b87d-0cbbbbfaa2dd">
        <source>getCurrentAccessDirectionDesc() : String;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
12 May 2010	cnwer1	Initial creation

*/

vars

begin
	if self.currentAccessDirection = CM_YABlock.SideAccess_Front then
		return app.getErrorString(Front);
	elseif self.currentAccessDirection = CM_YABlock.SideAccess_Back then
		return app.getErrorString(Back);
	endif;
	
	return null;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getEntTableView" id="d7c5a749-e7e3-462f-8136-cb6a6ab3532d">
        <updating/>
        <source>getEntTableView(_table : Table input)  : EntTableView protected, updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
20 April 2010	cnwer1	Initial creation

*/

vars
	entTableDef  : EntTableDef;
	entTableView	: EntTableView;
	tableType		: Integer;
begin
	if self.myVMInterface = null then
		return null;
	endif;
	
	tableType:=self.myVMInterface.getTableType(_table);
	
	if tableType = CM_RTVehicleConfig.QENTRY_FIELDS then
		return self.getMyRTVehicleConfig.myVisibleTaskFields;
	endif;
	
	if tableType = CM_RTVehicleConfig.DIRECTOR_FEILDS then
		return self.getMyRTVehicleConfig.myVisibleDirectorFields;
	endif;
	
	if tableType = CM_RTVehicleConfig.CARGO_FEILDS then
		return self.getMyRTVehicleConfig.myVisibleCargoFields;
	endif;

	return null;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_table" type="Table" usage="input"/>
        <ReturnType type="EntTableView"/>
    </JadeMethod>
    <JadeMethod name="getEntTableViewFromTable" id="7e9cea9b-69bb-4d62-9c62-1b33cad6b92f">
        <source>getEntTableViewFromTable(_table : Table input; _headerIsTopRow : Boolean; _entView : EntTableView input);
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
03 Dec 2012	NDL	Par 30261

*/

vars

	column : Integer;
	row : Integer;
	obj : Object;

begin

	_entView.allEntTableRows.clear();
	if _headerIsTopRow then
		foreach column in 1 to _table.columns do
			obj := _table.accessColumn(column).itemObject;
			if obj.isKindOf(EntTableRow) then
				_entView.allEntTableRows.add( obj.EntTableRow );
			endif;
		endforeach;
	else
		foreach row in 1 to _table.rows do
			obj := _table.accessRow(row).itemObject; //epr 30859 6/12/12
			if obj.isKindOf(EntTableRow) then
				_entView.allEntTableRows.add( obj.EntTableRow );
			endif;
		endforeach;
	endif;
	
epilog

end;
</source>
        <Parameter name="_table" type="Table" usage="input"/>
        <Parameter name="_headerIsTopRow" type="Boolean"/>
        <Parameter name="_entView" type="EntTableView" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getIMVComboListStringForPenn" id="9eea4591-0239-4db8-b507-9d0180bc2334">
        <source>getIMVComboListStringForPenn(_entry : DTO_RTQueueEntry):String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 April 2014	cnwndl1	Initial creation	Par	33664 
10 March 2015   cnwma1  PAR # 35797 Mulitple Containers on IMV does not work for VMT configured for PENN
*/

vars

	iter : Iterator;
	machine : CM_Machine;
	str : String;
	index : Integer;
	maxTEUCount,
	imvTEUCount,
	remainingTEU	: Integer;
	ti              : CM_TrackedItem;

begin

	if _entry &lt;&gt; null then
		ti := _entry.getTI;
		if ti .isKindOf(CM_Container) then
			maxTEUCount:=self.myTerminal.getConfig(NoIMVmoveTEUs).Integer;
		endif;
	endif;
	
	iter := self.myTerminal.machines.createIterator;
	/*while iter.next( machine ) do								 // 10/03/2015  cnwma1 PAR #35797
		if not machine.isIMV then
			continue;
		endif;
		if machine.myMachineController.allTrackedItems.isEmpty then
			if str &lt;&gt; null then
				str := str &amp; Tab;
			endif;
			str := str &amp; machine.id;
		endif;
	endwhile;*/	
	while iter.next( machine ) do									 // 10/03/2015  cnwma1 PAR #35797
		if not machine.isIMV then
			continue;
		endif;
		if maxTEUCount &gt; 0 then
			foreach ti in machine.myMachineController.allTrackedItems discreteLock do
				if not ti.isContainer then
					continue;
				endif;
				imvTEUCount:=imvTEUCount + ti.getNumTEU.Integer;	
			endforeach;
			
			remainingTEU:=maxTEUCount - imvTEUCount;
			imvTEUCount :=0;
			if remainingTEU &gt; 0 then
				if str &lt;&gt; null then
					str := str &amp; Tab;
				endif;
				str := str &amp; machine.id;
				
			endif;
		else
			if machine.myMachineController.allTrackedItems.isEmpty then
				if str &lt;&gt; null then
					str := str &amp; Tab;
				endif;
				str := str &amp; machine.id;
			endif;
		endif;
	endwhile;															 // 10/03/2015  cnwma1 PAR #35797
	
	return str;

epilog

	delete iter;

end;</source>
        <Parameter name="_entry" type="DTO_RTQueueEntry"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getManualOverstowMoveCargo" id="8e80262f-20a3-4477-8549-29fd098574cb">
        <updating/>
        <source>getManualOverstowMoveCargo(_rtQueueTasks: CM_RTQueueTaskArray input) : Boolean updating,protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
12 May 2010	cnwer1	Initial creation
23 Feb 2010 cnwer1	PAR 28126
*/

vars
	otherTask,
	rtQueueTask ,
	overstowedRTQueueTask  : CM_RTQueueTask;
	allOverstowedTIs    	: CM_TIArray;
	maxOstowMoves, idx			: Integer;
begin
	if self.myVMInterface = null then
		return false;
	endif;

	if self.getMyRTVehicleConfig = null then
		return false;
	endif;
	
	if self.getMyRTVehicleConfig.overstowMoveMode &lt;&gt; CM_RTVehicleConfig.OSTOW_MANUAL then
		return false;
	endif;
	create allOverstowedTIs transient;
	//no errors and not currentQueueTasks check if it is overstowed and option to not auto plan shift overstows is set
	
	
	foreach rtQueueTask in self.allOverstowedTasks do
		if rtQueueTask = null then
			continue;
		endif;
		idx:=idx + 1;
		if self.currentOverstowedTask &lt;&gt; null and rtQueueTask = self.currentOverstowedTask then
			continue;
		endif;
		rtQueueTask.getAllOverstowedTIs ( allOverstowedTIs,self.currentAccessDirection,self.myMachine) ;
		if self.allOverstowedTasks.size &gt; 1 then
			if idx = 1 then
				otherTask := self.allOverstowedTasks[2];
			else
				otherTask := self.allOverstowedTasks[1];
			endif;
		endif;
		
		if otherTask &lt;&gt; null then
			if allOverstowedTIs.includes(otherTask.ti) then
				allOverstowedTIs.remove(otherTask.ti);
			endif;
		endif;
		
		if allOverstowedTIs.size &gt; 0  then
			overstowedRTQueueTask	:=rtQueueTask;
			self.currentOverstowedTask := rtQueueTask;
			break;
		endif;
	endforeach;
	
	if allOverstowedTIs.size = 0 then
		return false;
	endif;
	
	maxOstowMoves:=self.getMyRTVehicleConfig.maxNumberOverstowForDriver;
	if maxOstowMoves &gt; 0 then
		if allOverstowedTIs.size &gt; maxOstowMoves then
			return false;
		endif;
	endif;
	
	self.myVMInterface.doManualOverstowMove(allOverstowedTIs);
	
	return true;
epilog
	delete allOverstowedTIs;
end;</source>
        <access>protected</access>
        <Parameter name="_rtQueueTasks" type="CM_RTQueueTaskArray" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getMaxDisplayQueueEntries" id="097f97f2-d877-42c1-899e-7f86933a0852">
        <updating/>
        <source>getMaxDisplayQueueEntries(): Integer protected, updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
19 April 2010	cnwer1	Initial creation

*/

vars

begin
	//epr par 27554 20/5/2011 if it is using get return null for max number because with this
	// set it causes the table synch agent to check for more entries when the table refreshes
	// and we don't want that  because we are only interested in one or two entries at the most
	if self.showingTaskList then
		return self.getMyRTVehicleConfig.maxNumberQueueEntries;
	else
		return null;
	endif;
epilog

end;</source>
        <access>protected</access>
        <ReturnType type="Integer"/>
    </JadeMethod>
