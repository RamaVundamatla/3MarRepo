<Class name="CM_SnapshotField_Sum" id="b2a1bf6a-8cb1-4d3f-8ec6-06e5137c686e">
    <superclass name="CM_SnapshotField"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="snapshots"/>
    <PrimAttribute name="sum" id="64100284-752c-4b3f-819b-a664036ae91a">
        <precision>23</precision>
        <scaleFactor>8</scaleFactor>
        <embedded/>
        <type name="Decimal"/>
        <access>readonly</access>
    </PrimAttribute>
    <JadeMethod name="getValue" id="8216f83f-e478-48d6-817d-16c00c59c20d">
        <source>getValue(): String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
09 December 2009	cnwndl1	Initial creation	CCMS 1023

*/

vars
	value	:Decimal[23,8];
begin
	value := self.sum;		
	
	if value = 0 then		
		return null;		
	endif;					
	
	return value.roundedTo (self.decimals).asStringJMTWithPrecision (self.decimals, self.useSeperator);	// cnwcs5 07/12/2009
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getXTABFieldFunction" id="73f82b5a-0b65-4f2c-ab93-f2d456219ffb">
        <source>getXTABFieldFunction(): Integer;
// ---------------------------------------------------------------------------
// Created:     10 December 2009 by cnwcs5:1
// Purpose:     ccms 1023 - snapshot summaries   
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	return CM_XTABField.Function_Sum;

epilog

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setFromCmifAndXtabFields" id="417a9db8-a4c0-45c8-85d3-3e89e07782a6">
        <updating/>
        <source>setFromCmifAndXtabFields(_cmifField: CMIF_OutputField; _xtabField: CM_XTABField) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
09 December 2009	cnwndl1	Initial creation	CCMS 1023

*/

vars

begin

	inheritMethod(_cmifField, _xtabField);
	
	self.sum := _cmifField.CMIF_OutputField_Sum.sum;

epilog

end;</source>
        <Parameter name="_cmifField" type="CMIF_OutputField"/>
        <Parameter name="_xtabField" type="CM_XTABField"/>
    </JadeMethod>
</Class>
