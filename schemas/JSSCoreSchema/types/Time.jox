  COPYRIGHT © JADE SOFTWARE CORPORATION LIMITED 2002 - ALL RIGHTS RESERVED
____________________________________________________________________________</text>
        <Parameter name="pSeconds" type="Integer"/>
        <ReturnType type="Time"/>
    </JadeMethod>
    <JadeMethod name="jssDisplayMS" id="af2c2e07-32ae-4e15-98f1-e7c5cc908fa3">
        <source>jssDisplayMS():String;
// --------------------------------------------------------------------------------
// Created:		19 June 2000 -  cnEcDisplayMS
// By:			cnwdad2
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return(self.display &amp; '.' &amp; (self.milliSecond + 1000).String[2:3]);
end;</source>
        <text>___________________________________________________________________________

