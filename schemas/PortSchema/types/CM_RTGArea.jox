    <JadeMethod name="isValidAreaForRTMoveMethod" id="aa05c18a-f01e-4d89-bf5c-5ac99da55c92">
        <source>isValidAreaForRTMoveMethod(_rtMoveMethod: CM_RTMoveMethod; _isSource: Boolean): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
10 February 2010	cnwer1	Initial creation

*/

vars

begin
	if _isSource then
		if _rtMoveMethod.allMachineTypeGroups.first.type &lt;&gt; MACHINETYPEGRP_RTG then
			return false;
		endif;
	else
		if _rtMoveMethod.allMachineTypeGroups.last.type &lt;&gt; MACHINETYPEGRP_RTG then
			return false;
		endif;
	endif;
	
	return true;

epilog

end;</source>
        <Parameter name="_rtMoveMethod" type="CM_RTMoveMethod"/>
        <Parameter name="_isSource" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="89d7167a-50ae-45de-a8b9-88bc17be902b">
        <source>pxyCreateUpdateProxy(): SelfType;
/*

Purpose:			

Parameters:			

Return Value:		


Date			Who		Reason
21 August 2009	cnwer1	Initial creation
20/04/2011		cnwmh5	PAR #27401 - Add code to handle prossible exceptions occurring when
						trying to create the proxy
*/

vars
	pxyRTGArea : CM_RTGArea;
	completedOK		: Boolean;
begin
	pxyRTGArea:= inheritMethod();
	
	//epr ccms 1076 we maintain/create these objects as we update RTG area
	pxyRTGArea.allAssociatedInterchangeAreas.clear;

	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return pxyRTGArea;
epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete pxyRTGArea;
	endif;

end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
