    <JadeMethod name="doDelete" id="6846f297-0c60-4d04-ba17-d6ffdf4865b6">
        <updating/>
        <source>doDelete(pObj: Object io) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 Oct 2022 navtnr20 ChangeRequest 54967: EUP - INB/OUT - Operational Instructions
*/
