    <JadeMethod name="loadReference" id="8ca0536e-b3c4-41a5-a4dd-48e6012032a9">
        <updating/>
        <source>loadReference(_devReference : DEV_Reference) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 December 2021	navpw1	Initial creation TFS: 52202

*/

vars
	schema 				: Schema;
	currentClass 		: Class;
	currentReference 	: Reference;
	outputFile 			: File;
	
begin
	schema := rootSchema.getSchema(_devReference.myClass.mySchema.name);
	currentClass := schema.getClass(_devReference.myClass.name);
	currentReference := currentClass.getProperty(_devReference.name).Reference;
	
	self.caption := "Source Comparison Reference" &amp; " - " &amp; _devReference.name;
	
	if currentReference = null then
		self.slStatus.caption := "Reference Missing";
	elseif _devReference.type &lt;&gt; currentReference.type.name then
		self.slStatus.caption := "Difference: Type";
	elseif _devReference.documentationTextData &lt;&gt; currentReference.text then
		self.slStatus.caption := "Difference: Text";
	endif;
	
	self.tblLoaded.rows := 0;
	self.tblLoaded.clearAllSelected();
	self.tblLoaded.addItemAt("Loaded", 1);
	self.tblLoaded.accessRow(1).fontBold := true;
	self.tblLoaded.fixedRows := 1;
	
	self.tblLoaded.addItemObject(_devReference, "Name");
	self.tblLoaded.addItemObject(_devReference, "Modified TimeStamp");
	self.tblLoaded.addItemObject(_devReference, "Modified by");
	self.tblLoaded.addItemObject(_devReference, "Modified version");
	self.tblLoaded.addItemObject(_devReference, "Documentation Text");
	self.tblLoaded.addItemObject(_devReference, "Type");
	
	self.tblLoaded.setCellText(2, 2, _devReference.name);
	self.tblLoaded.setCellText(3, 2, _devReference.modifiedTimeStamp.String);
	self.tblLoaded.setCellText(4, 2, _devReference.modifiedBy);
	self.tblLoaded.setCellText(5, 2, _devReference.modifiedVersion);
	self.tblLoaded.setCellText(6, 2, self.cleanText(_devReference.documentationTextData));
	self.tblLoaded.setCellText(7, 2, _devReference.type);
	
	self.tblCurrent.rows := 0;
	self.tblCurrent.clearAllSelected();
	self.tblCurrent.addItemAt("Current", 1);
	self.tblCurrent.accessRow(1).fontBold := true;
	self.tblCurrent.fixedRows := 1;
	
	self.tblCurrent.addItemObject(currentReference, "Name");
	self.tblCurrent.addItemObject(currentReference, "Modified TimeStamp");
	self.tblCurrent.addItemObject(currentReference, "Modified by");
	self.tblCurrent.addItemObject(currentReference, "Modified version");
	self.tblCurrent.addItemObject(currentReference, "Documentation Text");
	self.tblCurrent.addItemObject(currentReference, "Type");
	
	if currentReference = null then
		return;
	endif;
	
	self.tblCurrent.setCellText(2, 2, currentReference.name);
	self.tblCurrent.setCellText(3, 2, currentReference.getModifiedTimestamp().String);
	self.tblCurrent.setCellText(4, 2, currentReference.getModifiedBy());
	self.tblCurrent.setCellText(5, 2, currentReference.version.asStringJMT());
	self.tblCurrent.setCellText(6, 2, self.cleanText(currentReference.text));
	self.tblCurrent.setCellText(7, 2, currentReference.type.name);

end;</source>
        <Parameter name="_devReference" type="DEV_Reference"/>
    </JadeMethod>
