<Class name="WS_CargoDamage" id="0cf41dbb-7a15-4a18-9d38-aceeadbc7472">
    <superclass name="WS_ProxyObject"/>
    <transient/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="webservice"/>
    <ImplicitInverseRef name="allDamageItems" id="bec3eea4-6f21-4637-9968-4e3f65ac031b">
        <memberTypeInverse/>
        <type name="WS_DamageArray"/>
        <access>readonly</access>
    </ImplicitInverseRef>
    <PrimAttribute name="cargoId" id="4ae22788-db34-49a1-9b51-6317d0351f00">
        <length>31</length>
        <embedded/>
        <type name="String"/>
        <access>readonly</access>
    </PrimAttribute>
    <ImplicitInverseRef name="cargoType" id="ddeac85c-8c87-4f7e-a380-b8416df7922c">
        <embedded/>
        <type name="WS_CargoType"/>
        <access>readonly</access>
    </ImplicitInverseRef>
    <JadeMethod name="delete" id="5f7a3634-5d3c-495e-bc68-be23d2ce17da">
        <updating/>
        <source>delete() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 August 2015	cnwmc5	Initial creation

*/

vars

begin
	delete self.cargoType;
	self.allDamageItems.purge();
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setProxyFromObject" id="f5853a32-233a-4475-8af1-5e7e4c030519">
        <updating/>
        <source>setProxyFromObject(_ti: CM_TrackedItem) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 August 2015	cnwmc5	Initial creation

*/

vars
	damageItem		: CM_DamageInstance;
	wsDamageItem	: WS_Damage;
begin
	inheritMethod(_ti);
	
	self.cargoId := _ti.id;
	
	if _ti.myCargoType &lt;&gt; null then
		create self.cargoType transient;
		self.cargoType.setProxyFromObject(_ti.myCargoType);
	endif;
	
	foreach damageItem in _ti.allDamageInstances do
		create wsDamageItem transient;
		wsDamageItem.setProxyFromObject(damageItem);
		self.allDamageItems.add(wsDamageItem);
	endforeach;
epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
    </JadeMethod>
</Class>
