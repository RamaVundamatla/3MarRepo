<Class name="Car" id="94c4b63e-a6cc-459c-ac07-24cc0b48824c">
    <superclass name="Object"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="dev"/>
    <ImplicitInverseRef name="elements" id="bff5c131-88d5-4728-b77c-3f5d4dae397f">
        <memberTypeInverse/>
        <type name="ObjectSet"/>
        <access>readonly</access>
    </ImplicitInverseRef>
    <JadeMethod name="create" id="37867f96-95a8-4d22-88a7-87e01547e961">
        <updating/>
        <source>create() updating;
//18 August 2009	cnwdw1	
//
vars
	wheel: Wheel;
	body: Body;
	engine: Engine;
begin
	create wheel transient;
	wheel.name := "front left";
	elements.add(wheel);
	
	create wheel transient;
	wheel.name := "front right";
	elements.add(wheel);

	create wheel transient;
	wheel.name := "back left";
	elements.add(wheel);

	create wheel transient;
	wheel.name := "back right";
	elements.add(wheel);
	
	create body transient;
	elements.add(body);
	
	create engine transient;
	elements.add(engine);
end;</source>
    </JadeMethod>
    <JadeMethod name="delete" id="cdc07d37-3c4c-4f5e-b797-9c8a4bfb64a8">
        <updating/>
        <source>delete() updating;
//18 August 2009	cnwdw1	
//
vars

begin
	elements.purge;
end;</source>
    </JadeMethod>
    <JadeMethod name="print" id="13ad5b32-e138-416f-9b24-c5cb620cf736">
        <source>print();
//19 August 2009	cnwdw1	
//
vars
	obj: Object;
begin
	write "============";
	write "Print Car";
	foreach obj in self.elements do
		obj.CarElement.print;
	endforeach;
	write "Printed Car";

end;</source>
    </JadeMethod>
</Class>
