    <JadeMethod name="buildSelf" id="f0f34624-371d-4d88-84e9-bec5309d8d8d">
        <updating/>
        <source>buildSelf() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24/03/2023	navcs2	ChangeRequest 57299:[57300]: EUP - Create new filter multi-select group box control
09 Jul 2024	navnk30	ChangeRequest 64536: MTN - Adding Filter to column organizer screen - Selected Columns. Task 64537.
18 Sep 2024	navnk30	Bug 66009: MTN - Column Organiser Column Sorting Upon reordering sorted columns all columns appear in list
*/

vars
	
begin
	inheritMethod();
	
	if self.txtFilterBoxLeft = null then
		create self.txtFilterBoxLeft transient;
		self.txtFilterBoxLeft.parent := self;
		self.form.addControl(self.txtFilterBoxLeft);
		self.txtFilterBoxLeft.left := self.myAvailableLbl.top;
		self.txtFilterBoxLeft.visible := true;
		self.txtFilterBoxLeft.setGroupBoxParent(self);
	endif;
		
	if self.myMultiSelectClearBtnLeft = null then
		create self.myMultiSelectClearBtnLeft transient;
		self.myMultiSelectClearBtnLeft.parent := self;
		form.addControl(self.myMultiSelectClearBtnLeft);
		self.myMultiSelectClearBtnLeft.width := self.BtnWidth;
		self.myMultiSelectClearBtnLeft.caption := self.BtnText; 
		self.myMultiSelectClearBtnLeft.fontSize := self.BtnFontSize;
		self.myMultiSelectClearBtnLeft.visible := true;
	endif;
	
	//09.07.2024 navnk30 #64536 Task 64537	START
	if self.txtFilterBoxRight = null then
		create self.txtFilterBoxRight transient;
		self.txtFilterBoxRight.parent := self;
		self.form.addControl(self.txtFilterBoxRight);
		self.txtFilterBoxRight.left := self.mySelectedLbl.left;
		self.txtFilterBoxRight.visible := true;
		self.txtFilterBoxRight.top := self.txtFilterBoxLeft.top;
		self.txtFilterBoxRight.parentBottomOffset := self.txtFilterBoxLeft.parentBottomOffset;
		self.txtFilterBoxRight.setGroupBoxParent(self);
	endif;
	
	if self.myMultiSelectClearBtnRight = null then
		create self.myMultiSelectClearBtnRight transient;
		self.myMultiSelectClearBtnRight.parent := self;
		form.addControl(self.myMultiSelectClearBtnRight);
		self.myMultiSelectClearBtnRight.width := self.BtnWidth;
		self.myMultiSelectClearBtnRight.caption := self.BtnText; 
		self.myMultiSelectClearBtnRight.fontSize := self.BtnFontSize;
		self.myMultiSelectClearBtnRight.visible := true;
	endif;
	//09.07.2024 navnk30 #64536 Task 64537	END
	
	if self.name = CMUI_ColumnOrganiserForm::mulColumnSorter.name then	//18.09.2024 navnk30 #66009
		self.myMultiSelectClearBtnRight.visible := false;
		self.txtFilterBoxRight.visible := false;
	endif;
epilog

end;</source>
    </JadeMethod>
