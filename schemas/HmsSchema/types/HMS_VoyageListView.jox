    <JadeMethod name="buildEntireForeground" id="6ad24692-02ca-4843-97f3-9a8f5729749c">
        <updating/>
        <source>buildEntireForeground() updating;

vars
	workingMovement:	CMIF_HMS_WorkingMovement;
  	workingVoyage:		CMIF_HMS_WorkingVoyage;
	str:				String;
begin

	lbxVoyageTree.clear;
	if self.myViewController = null then
		return;
	endif;

	if optByArrival.value=true then
		foreach workingVoyage in myViewController.allVoyagesViewedByArrvDT do
			lbxVoyageTree.addItem(workingVoyage.arrivedDT.date.format('dd MMM yy ') &amp; ": " &amp; workingVoyage.myHMSVoyageData.vesselName.trimBlanks &amp; " arrives");
			lbxVoyageTree.itemObject[lbxVoyageTree.newIndex]:=workingVoyage;
			lbxVoyageTree.itemLevel[lbxVoyageTree.newIndex]:=1;
			lbxVoyageTree.itemExpanded[lbxVoyageTree.newIndex]:=true;
			lbxVoyageTree.itemPicture[lbxVoyageTree.newIndex]:=picVoyage.picture;			
			if workingVoyage.notYetSaved=true then
				lbxVoyageTree.itemForeColor[lbxVoyageTree.newIndex]:=VoyageNotYetSaved;
			else
				lbxVoyageTree.itemForeColor[lbxVoyageTree.newIndex]:=Black;//VoyageNotSelectedNotSaved;
			endif;
			foreach workingMovement in workingVoyage.allWorkingMovements do
				if drawTextWidth(workingMovement.moveType &amp; ":" &amp; Tab) = drawTextWidth(Tab &amp; Tab) then
// cnwdad1 18/06/2009 - PAR #19942.
					//lbxVoyageTree.addItem(workingMovement.moveType &amp; ":" &amp; Tab &amp; workingMovement.occursOnDT.date.format('dd MMM yy ') &amp; workingMovement.occursOnDT.Time.format('HH:mm'));
					lbxVoyageTree.addItem(workingMovement.moveType &amp; ":" &amp; Tab &amp; workingMovement.occursOnDT.date.format('dd MMM yy ') &amp; workingMovement.occursOnDT.Time.format(app.getTimeShortFormat(false)));
				else 
// cnwdad1 18/06/2009 - PAR #19942.
					//lbxVoyageTree.addItem(workingMovement.moveType &amp; ":" &amp; Tab  &amp; Tab &amp; workingMovement.occursOnDT.date.format('dd MMM yy ') &amp; workingMovement.occursOnDT.Time.format('HH:mm'));
					lbxVoyageTree.addItem(workingMovement.moveType &amp; ":" &amp; Tab  &amp; Tab &amp; workingMovement.occursOnDT.date.format('dd MMM yy ') &amp; workingMovement.occursOnDT.Time.format(app.getTimeShortFormat(false)));
				endif;
				lbxVoyageTree.itemObject[lbxVoyageTree.newIndex]:=workingMovement;
				lbxVoyageTree.itemLevel[lbxVoyageTree.newIndex]:=2;
				lbxVoyageTree.itemExpanded[lbxVoyageTree.newIndex]:=false;
				if workingMovement.moveType = HMSMovementTypeArrival then
					lbxVoyageTree.itemPicture[lbxVoyageTree.newIndex]:=picArrive.picture;
				elseif workingMovement.moveType = HMSMovementTypeDeparture then
					lbxVoyageTree.itemPicture[lbxVoyageTree.newIndex]:=picDepart.picture;
				else
					lbxVoyageTree.itemPicture[lbxVoyageTree.newIndex]:=picShift.picture;				
				endif;												
				
				if workingMovement.notYetSaved=true then
					lbxVoyageTree.itemForeColor[lbxVoyageTree.newIndex]:=MovementNotYetSaved;
				else
					lbxVoyageTree.itemForeColor[lbxVoyageTree.newIndex]:=Black;//MovementIsSaved;
				endif;

			endforeach;		
		endforeach; 
	elseif optByDeparture.value=true then
      	foreach workingVoyage in myViewController.allVoyagesViewedByDeptDT do
			lbxVoyageTree.addItem(workingVoyage.departedDT.date.format('dd MMM yy ') &amp; ": " &amp; workingVoyage.myHMSVoyageData.vesselName.trimBlanks &amp; " departs");
			lbxVoyageTree.itemObject[lbxVoyageTree.newIndex]:=workingVoyage;
			lbxVoyageTree.itemLevel[lbxVoyageTree.newIndex]:=1;
			lbxVoyageTree.itemExpanded[lbxVoyageTree.newIndex]:=true;
			lbxVoyageTree.itemPicture[lbxVoyageTree.newIndex]:=picVoyage.picture;						
			if workingVoyage.notYetSaved=true then
				lbxVoyageTree.itemForeColor[lbxVoyageTree.newIndex]:=VoyageNotYetSaved;
			else
				lbxVoyageTree.itemForeColor[lbxVoyageTree.newIndex]:=Black;//VoyageNotSelectedNotSaved;
			endif;
			foreach workingMovement in workingVoyage.allWorkingMovements do
				if drawTextWidth(workingMovement.moveType &amp; ":" &amp; Tab) = drawTextWidth(Tab &amp; Tab) then
// cnwdad1 18/06/2009 - PAR #19942.
					//lbxVoyageTree.addItem(workingMovement.moveType &amp; ":" &amp; Tab &amp; workingMovement.occursOnDT.date.format('dd MMM yy ') &amp; workingMovement.occursOnDT.Time.format('HH:mm'));
					lbxVoyageTree.addItem(workingMovement.moveType &amp; ":" &amp; Tab &amp; workingMovement.occursOnDT.date.format('dd MMM yy ') &amp; workingMovement.occursOnDT.Time.format(app.getTimeShortFormat(false)));
				else 
// cnwdad1 18/06/2009 - PAR #19942.
					//lbxVoyageTree.addItem(workingMovement.moveType &amp; ":" &amp; Tab  &amp; Tab &amp; workingMovement.occursOnDT.date.format('dd MMM yy ') &amp; workingMovement.occursOnDT.Time.format('HH:mm'));
					lbxVoyageTree.addItem(workingMovement.moveType &amp; ":" &amp; Tab  &amp; Tab &amp; workingMovement.occursOnDT.date.format('dd MMM yy ') &amp; workingMovement.occursOnDT.Time.format(app.getTimeShortFormat(false)));
				endif;
				lbxVoyageTree.itemObject[lbxVoyageTree.newIndex]:=workingMovement;
				lbxVoyageTree.itemLevel[lbxVoyageTree.newIndex]:=2;
				lbxVoyageTree.itemExpanded[lbxVoyageTree.newIndex]:=false;
				if workingMovement.moveType = HMSMovementTypeArrival then
					lbxVoyageTree.itemPicture[lbxVoyageTree.newIndex]:=picArrive.picture;
				elseif workingMovement.moveType = HMSMovementTypeDeparture then
					lbxVoyageTree.itemPicture[lbxVoyageTree.newIndex]:=picDepart.picture;
				else
					lbxVoyageTree.itemPicture[lbxVoyageTree.newIndex]:=picShift.picture;				
				endif;																
				if workingMovement.notYetSaved=true then
					lbxVoyageTree.itemForeColor[lbxVoyageTree.newIndex]:=MovementNotYetSaved;
				else
					lbxVoyageTree.itemForeColor[lbxVoyageTree.newIndex]:=Black;//MovementIsSaved;
				endif;
			endforeach;	
		endforeach;
	elseif optByVoyageCode.value=true then
		foreach workingVoyage in myViewController.allVoyagesViewedByCode do
			lbxVoyageTree.addItem(workingVoyage.myHMSVoyageData.vesselName.trimBlanks &amp; " (Arrives: " &amp; workingVoyage.arrivedDT.date.format('dd MMM yy ') &amp; ")");
			lbxVoyageTree.itemObject[lbxVoyageTree.newIndex]:=workingVoyage;
			lbxVoyageTree.itemLevel[lbxVoyageTree.newIndex]:=1;
			lbxVoyageTree.itemExpanded[lbxVoyageTree.newIndex]:=true;
			lbxVoyageTree.itemPicture[lbxVoyageTree.newIndex]:=picVoyage.picture;						
			if workingVoyage.notYetSaved=true then
				lbxVoyageTree.itemForeColor[lbxVoyageTree.newIndex]:=VoyageNotYetSaved;
			else
				lbxVoyageTree.itemForeColor[lbxVoyageTree.newIndex]:=Black;//VoyageNotSelectedNotSaved;
			endif;
			foreach workingMovement in workingVoyage.allWorkingMovements do
				if drawTextWidth(workingMovement.moveType &amp; ":" &amp; Tab) = drawTextWidth(Tab &amp; Tab) then
// cnwdad1 18/06/2009 - PAR #19942.
					//lbxVoyageTree.addItem(workingMovement.moveType &amp; ":" &amp; Tab &amp; workingMovement.occursOnDT.date.format('dd MMM yy ') &amp; workingMovement.occursOnDT.Time.format('HH:mm'));
					lbxVoyageTree.addItem(workingMovement.moveType &amp; ":" &amp; Tab &amp; workingMovement.occursOnDT.date.format('dd MMM yy ') &amp; workingMovement.occursOnDT.Time.format(app.getTimeShortFormat(false)));
				else 
// cnwdad1 18/06/2009 - PAR #19942.
					//lbxVoyageTree.addItem(workingMovement.moveType &amp; ":" &amp; Tab  &amp; Tab &amp; workingMovement.occursOnDT.date.format('dd MMM yy ') &amp; workingMovement.occursOnDT.Time.format('HH:mm'));
					lbxVoyageTree.addItem(workingMovement.moveType &amp; ":" &amp; Tab  &amp; Tab &amp; workingMovement.occursOnDT.date.format('dd MMM yy ') &amp; workingMovement.occursOnDT.Time.format(app.getTimeShortFormat(false)));
				endif;
				lbxVoyageTree.itemObject[lbxVoyageTree.newIndex]:=workingMovement;
				lbxVoyageTree.itemLevel[lbxVoyageTree.newIndex]:=2;
				lbxVoyageTree.itemExpanded[lbxVoyageTree.newIndex]:=false;
				if workingMovement.moveType = HMSMovementTypeArrival then
					lbxVoyageTree.itemPicture[lbxVoyageTree.newIndex]:=picArrive.picture;
				elseif workingMovement.moveType = HMSMovementTypeDeparture then
					lbxVoyageTree.itemPicture[lbxVoyageTree.newIndex]:=picDepart.picture;
				else
					lbxVoyageTree.itemPicture[lbxVoyageTree.newIndex]:=picShift.picture;				
				endif;																
				if workingMovement.notYetSaved=true then
					lbxVoyageTree.itemForeColor[lbxVoyageTree.newIndex]:=MovementNotYetSaved;
				else
					lbxVoyageTree.itemForeColor[lbxVoyageTree.newIndex]:=Black;//MovementIsSaved;
				endif;
			endforeach;	
		endforeach;
	endif;

	// Set selected movement
	setCurrentVoyage(myViewController.myCurrentWorkingVoyage);
	setSelectedMovement(myViewController.myCurrentWorkingMovement);
	lbxVoyageTree.refreshNow;
end;</source>
    </JadeMethod>
