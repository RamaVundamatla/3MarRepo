<Class name="CMIF_WorkOrderTransController" id="a680f3f6-e9ce-4e60-9e89-4ff20dbcf175">
    <superclass name="CMIF_TITransactionController"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="workorder"/>
    <ImplicitInverseRef name="myWorkOrder" id="29637894-1558-4847-9fc9-30db34d5fa51">
        <embedded/>
        <type name="CM_WorkOrderTI"/>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="myWorkOrderDetail" id="54a90e60-e075-4963-a8e2-103633b4b70b">
        <embedded/>
        <type name="CM_WorkOrderDtl"/>
    </ImplicitInverseRef>
    <JadeMethod name="setFromTransaction" id="81655abf-6562-4a6d-9728-b4902a562a9b">
        <updating/>
        <source>setFromTransaction(_txn: CM_TITransaction) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
09 December 2009	cnwrd1	Initial creation

*/

vars

begin
	inheritMethod(_txn);
	
	if _txn.isKindOf(CM_WorkOrderAssign) then
		self.myWorkOrder := _txn.CM_WorkOrderAssign.myWorkOrder;
	elseif  _txn.isKindOf(CM_WorkOrderUnassign) then 
		self.myWorkOrder := _txn.CM_WorkOrderUnassign.myWorkOrder;
	else
	// wrong transation type
	endif;
	
epilog

end;</source>
        <Parameter name="_txn" type="CM_TITransaction"/>
    </JadeMethod>
    <JadeMethod name="setTransactionDetails" id="f885611c-7538-4443-a9a2-c64f673f0124">
        <updating/>
        <source>setTransactionDetails(pTrx: CM_TITransaction input) updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
09 December 2009	cnwrd1	Initial creation

*/

vars

begin
	inheritMethod(pTrx);

epilog

end;</source>
        <access>protected</access>
        <Parameter name="pTrx" type="CM_TITransaction" usage="input"/>
    </JadeMethod>
</Class>
