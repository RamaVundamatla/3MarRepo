    <JadeMethod name="populateCmbNewTask" id="6c3b2136-c4b4-4ea9-9e6d-2e3513380dd3">
        <source>populateCmbNewTask() protected;

vars
	classObj	: Class;
	itemIndex	: Integer;
	comboboxObj	: ComboBox;
	allClasses	: ClassColl;
	
begin
	comboboxObj	:=	cmbNewTask;
	comboboxObj.clear();
	allClasses	:=	currentSchema.allClasses();
	
	foreach classObj in allClasses do
		if classObj.inheritsFrom(CnEcBackShedTask) and classObj.name &lt;&gt; CnEcBackShedTask.name then
			itemIndex := comboboxObj.addItem(classObj.name);
			comboboxObj.itemObject[itemIndex] := classObj;
		endif;
	endforeach;
epilog
	delete allClasses;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setTask" id="ef87c4e1-4cad-42c5-9902-d1a266123019">
