    <JadeMethod name="addDummyProperty" id="c507964c-537d-45b7-9b24-ece173e9df11">
        <source>addDummyProperty(pListboxObj:CnEcListBox input; pListIndex:Integer io) protected;
// --------------------------------------------------------------------------------
// Created:		04 November 2001 by cnwdad1
//
// Purpose:		Adds a dummy property child node to the listbox tree.
//
// Parameters:	pListboxObj - The listbox to add the child node to.
//				pListIndex - The item index of the parent to add the child node to.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	childIndex	: Integer;
	childLevel	: Integer;
	
begin
	childIndex	:=	pListIndex + 1;
	childLevel	:=	pListboxObj.itemLevel[pListIndex] + 1;
	
	pListboxObj.addItemAt(self.DUMMY_OBJECT, childIndex);
	pListboxObj.itemLevel[childIndex]		:=	childLevel;
	pListboxObj.itemForeColor[childIndex]	:=	Gray;
	
	pListIndex	:=	childIndex;
end;</source>
        <access>protected</access>
        <Parameter name="pListboxObj" type="CnEcListBox" usage="input"/>
        <Parameter name="pListIndex" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="clearOutput" id="ca916b9c-ba53-459e-97ff-ef97ab5d2e21">
        <source>clearOutput() protected;
// --------------------------------------------------------------------------------
// Created:		02 November 2001 by cnwdad1
//
// Purpose:		Clears the method execution output window pane.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	txtOutput.text	:=	null;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="createAndExecuteMethod" id="0441a7c9-2936-4f64-b0ea-0c546572a06f">
        <source>createAndExecuteMethod(	pSource:String;
						pErrorCode:Integer io;
						pErrorPosition:Integer io;
						pErrorLength:Integer io;
						pErrorMessage:String io):String protected;
// --------------------------------------------------------------------------------
// Created:		03 November 2001 by cnwdad1
//
// Purpose:		Creates a transient method with the supplied source, executes the
//				method, then returns the response, including any error information.
//
// Parameters:	pSource - The method source code.
//				pErrorCode - The error code of an invalid method source message.
//				pErrorPosition - The position in the method code of an error.
//				pErrorLength - The length of the method code that is in error.
//				pErrorMessage - The error message corresponding to the error code.
//
// Returns:		The executed method's return value.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	receiverObj		: Object;
	methodObj		: JadeMethod;
	sourceCode		: String;
	returnAny		: Any;

begin
	receiverObj	:=	self.aMyObject;
	sourceCode	:=	pSource;
	methodObj	:=	process.createTransientMethod(	self.METHOD_NAME,
													receiverObj.class(),
													currentSchema,
													sourceCode,
													true,
													Any,
													pErrorCode,
													pErrorPosition,
													pErrorLength);
	
	if methodObj = null then
		pErrorMessage	:=	process.getErrorText(pErrorCode);
	else
		returnAny		:=	process.executeTransientMethod(methodObj, receiverObj);
		
		return returnAny.String;
	endif;
epilog
	process.deleteTransientMethod(methodObj);
end;</source>
        <access>protected</access>
        <Parameter name="pSource" type="String"/>
        <Parameter name="pErrorCode" type="Integer" usage="io"/>
        <Parameter name="pErrorPosition" type="Integer" usage="io"/>
        <Parameter name="pErrorLength" type="Integer" usage="io"/>
        <Parameter name="pErrorMessage" type="String" usage="io"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="doFormLoad" id="8cd1b954-4b4f-499d-9e31-4dc1fb7e26d5">
        <updating/>
        <source>doFormLoad() updating, protected;
// -----------------------------------------------------------------------------
// Created:		31 October 2001 by cnwdad1
//
// Purpose:		Default form load functions.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//
// -----------------------------------------------------------------------------
vars
	targetObj		: Object;
	allKeyCodesObj	: CnEcKeyCodeArray;
	
begin
	targetObj		:=	self.aMyObject;
	
	if targetObj = null then
		app.msgBox("There is no object to inspect.", self.INSPECTOR_NAME, -30);
		return;
	else
		endNotificationForSubscriber(self);
		beginNotification(targetObj, Object_Update_Event, Response_Continuous, 0);
		beginNotification(targetObj, Object_Delete_Event, Response_Cancel, 0);
	endif;

	self.caption	:=	self.INSPECTOR_NAME &amp; ": " &amp; targetObj.class().name;
	
	if process.isInTransactionState then
		if app.isMultiUser() then
			self.startTimer();		// Only blink if we're in multi-user mode.
		else
			lblState.visible	:=	true;
		endif;
	else
		lblState.visible		:=	false;
	endif;
	
	self.loadCallStack();
	
	create allKeyCodesObj transient;
	allKeyCodesObj.add(CNEC_KEY_F8);
	allKeyCodesObj.add(CNEC_KEY_F9);
	allKeyCodesObj.add(CNEC_KEY_F12);
	self.registerFormKeys(allKeyCodesObj);
epilog
	delete allKeyCodesObj;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="enableCallStackMenus" id="0c35f05d-39d2-4fa9-9eaf-48f158827905">
        <source>enableCallStackMenus(pTableObj:CnEcTable) protected;
// --------------------------------------------------------------------------------
// Created:		16 November 2001 by cnwdad1
//
// Purpose:		Set the currently enabled call-stack menus.
//
// Parameters:	pTableObj - The table for which the relevant menus should be set.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	columnIndex	: Integer;
	
begin
	columnIndex	:=	pTableObj.column;
	
	if columnIndex = 2 then
		mnuCallsInspectMethod.enabled	:=	false;
		mnuCallsInspectRec.enabled		:=	true;
	elseif columnIndex = 3 then
		mnuCallsInspectMethod.enabled	:=	true;
		mnuCallsInspectRec.enabled		:=	false;
	else
		mnuCallsInspectMethod.enabled	:=	false;
		mnuCallsInspectRec.enabled		:=	false;
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="pTableObj" type="CnEcTable"/>
    </JadeMethod>
    <JadeMethod name="executeSource" id="27358cf6-be69-45ee-a2f3-9c45e2b51e9b">
        <source>executeSource() protected;
// --------------------------------------------------------------------------------
// Created:		02 November 2001 by cnwdad1
//
// Purpose:		Takes the user's method source code, runs it, and shows the
//				response in the method execution window pane.
//
//				Any syntax errors etc. will be reported in the method execution
//				window pane.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	sourceCode			: String;
	returnAny			: Any;
	errorCode			: Integer;
	errorMessage		: String;
	errorPosition		: Integer;
	errorLength			: Integer;
	
begin
	sourceCode		:=	txtSource.cnEcString();
	returnAny		:=	self.createAndExecuteMethod(sourceCode,
													errorCode,
													errorPosition,
													errorLength,
													errorMessage);
	
	if errorMessage = null then
		if txtOutput.cnEcString() = null then
			txtOutput.text	:=	returnAny.String;
		else
			txtOutput.text	:=	txtOutput.text &amp; CrLf &amp; returnAny.String;
		endif;
		
		txtOutput.scrollVertPos	:=	txtOutput.lineCount;
	else
		txtOutput.text			:=	txtOutput.text &amp; CrLf &amp; "Error " &amp; errorCode.String &amp; " - " &amp; errorMessage;
		txtOutput.scrollVertPos	:=	txtOutput.lineCount;
		txtSource.selStart		:=	errorPosition;
		txtSource.selLength		:=	errorLength;
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="getCallStackMethod" id="2bd991d5-48f3-40f6-9cca-e7a26515cf33">
        <source>getCallStackMethod(pTableObj:CnEcTable input):MethodCallDesc protected;
// --------------------------------------------------------------------------------
// Created:		16 November 2001 by cnwdad1
//
// Purpose:		Get the Method Call Description object for the currently selected
//				row in the spcified table.
//
// Parameters:	pTableObj - The table control with the selected row.
//
// Returns:		The Method Call Desctipion object.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	tableRowObj		: JadeTableRow;
	
begin
	tableRowObj		:=	pTableObj.accessRow(pTableObj.row);
	
	return tableRowObj.itemObject.MethodCallDesc;
end;</source>
        <access>protected</access>
        <Parameter name="pTableObj" type="CnEcTable" usage="input"/>
        <ReturnType type="MethodCallDesc"/>
    </JadeMethod>
    <JadeMethod name="getPropertyOwner" id="12d2e80a-da45-4cc2-98cc-3040146e5298">
        <source>getPropertyOwner(pListboxObj:CnEcListBox; pListIndex:Integer):Object protected;
// --------------------------------------------------------------------------------
// Created:		01 November 2001 by cnwdad1
//
// Purpose:		Returns the owner object of the property at the specified listbox
//				item index.
//
// Parameters:	pListboxObj - The listbox containing the property information.
//				pListIndex - The index from which to start looking for the parent.
//
// Returns:		The object on which the property is defined.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	sourceObj	: Object;
	parentIndex	: Integer;
	
begin
	parentIndex	:=	pListboxObj.cnEcFindParent(pListIndex);
	
	if parentIndex = 0 then
		return self.aMyObject;
		
	else
		sourceObj	:=	self.getSourceObject(pListboxObj, parentIndex);
		
	endif;
epilog
	return sourceObj;
end;</source>
        <access>protected</access>
        <Parameter name="pListboxObj" type="CnEcListBox"/>
        <Parameter name="pListIndex" type="Integer"/>
        <ReturnType type="Object"/>
    </JadeMethod>
    <JadeMethod name="getSourceObject" id="a262e5c1-6e02-4efa-a4b1-0b8771a1fe38">
        <source>getSourceObject(pListboxObj:CnEcListBox; pListIndex:Integer):Object protected;
// --------------------------------------------------------------------------------
// Created:		02 November 2001 by cnwdad1
//
// Purpose:		Each node in the tree, down to the selected list item, represents
//				the data source path of references from the object being inspected,
//				down to the property in the selected list item.
//
//				This method will navigate that source path to arrive at the object
//				corresponding to the selected list item.  If any of the references
//				in the source path "tree" are null, then the scan will be abandoned.
//
//			eg.	+ CnEcBaseRoot							&lt;&lt;-- object being inspected
//					|--allReleaseHistoryMasters
//					+--mySpellRoot
//						|--allSpellWords
//						|--allSpellWordsByMetaphone
//						|--allSpellWordsByMetaphone
//						|--allSpellWordsBySoundex		&lt;&lt;-- selected list item
//						+--myBaseRoot
//
//				In this example, this method will navigate from the CnEcBaseRoot
//				object down to the allSpellWordsBySoundex collection, and return
//				that object (CnEcSpellWordBySoundex dictionary).
//
// Parameters:	pListboxObj - The listbox control to scan.
//				pListIndex - The index of the selected list item.
//
// Returns:		The object corresponding to the selected list item's property.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	sourceParentObj	: Object;
	sourceObj		: Object;
	sourcePath		: String;
	propertyName	: String;
	propertyObj		: Property;
	nodePosition	: Integer;
	nameSeparator	: String;
	
begin
	sourceParentObj	:=	self.aMyObject;
	sourceObj		:=	sourceParentObj;
	nameSeparator	:=	pListboxObj.nameSeparator;
	sourcePath		:=	pListboxObj.itemFullName(pListIndex);
	nodePosition	:=	1;
	
	// The first  node in the source path will the the object being inspected,
	// so get that one out of the way first.
	propertyName	:=	sourcePath.cnEcNextDelimitedField(nameSeparator, nodePosition);
	
	while nodePosition &gt; 1 do
		propertyName	:=	sourcePath.cnEcNextDelimitedField(nameSeparator, nodePosition);
		propertyObj		:=	sourceParentObj.class().findProperty(propertyName);
		
		if propertyObj = null then
			sourceObj	:=	null;
			break;
		endif;
		
		if propertyObj.cnEcIsReference() then
			sourceObj	:=	sourceParentObj.getPropertyValue(propertyName).Object;
			
			if sourceObj = null then
				break;
			endif;
		else
			sourceObj	:=	null;
			break;
		endif;
		
		sourceParentObj	:=	sourceObj;
	endwhile;
epilog
	return sourceObj;
end;</source>
        <access>protected</access>
        <Parameter name="pListboxObj" type="CnEcListBox"/>
        <Parameter name="pListIndex" type="Integer"/>
        <ReturnType type="Object"/>
    </JadeMethod>
    <JadeMethod name="initializeCallStackTable" id="621731b3-eba7-41a2-9b99-dcd1f06ed3ea">
        <source>initializeCallStackTable(pTableObj:CnEcTable input) protected;
// --------------------------------------------------------------------------------
// Created:		16 November 2001 by cnwdad1
//
// Purpose:		Initialize the call-stack datatable.
//
// Parameters:	pTheTable - The table to initialize.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	tableColumnObj	: JadeTableColumn;
	
begin
	pTableObj.rows	:=	1;
	pTableObj.setCellText(1, 1, "Call #" &amp; Tab &amp; "Receiver" &amp; Tab &amp; "Method" &amp; Tab &amp; "Position" &amp; Tab &amp; "Mode");
	pTableObj.partialTextIndication	:=	true;

	tableColumnObj				:=	pTableObj.accessColumn(1);
	tableColumnObj.alignment	:=	Table.Alignment_Center;
	
	tableColumnObj				:=	pTableObj.accessColumn(2);
	tableColumnObj.alignment	:=	Table.Alignment_Left;
	
	tableColumnObj				:=	pTableObj.accessColumn(3);
	tableColumnObj.alignment	:=	Table.Alignment_Left;
	
	tableColumnObj				:=	pTableObj.accessColumn(4);
	tableColumnObj.alignment	:=	Table.Alignment_Center;
	
	tableColumnObj				:=	pTableObj.accessColumn(5);
	tableColumnObj.alignment	:=	Table.Alignment_Center;
	
	txtStackSource.text			:=	null;
end;</source>
        <access>protected</access>
        <Parameter name="pTableObj" type="CnEcTable" usage="input"/>
    </JadeMethod>
    <JadeMethod name="initializeValuesTable" id="3e08aa2d-bee8-4b66-9a47-6c57ea6080fc">
        <source>initializeValuesTable() protected;
// -----------------------------------------------------------------------------
// Created:		31 October 2001 by cnwdad1
//
// Purpose:		Initializes the table containing property details and values.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//
// -----------------------------------------------------------------------------
vars
	tableObj	: CnEcTable;
	
begin
	tableObj		:=	tblValues;
	tableObj.clear();
	tableObj.rows	:=	0;
	
	if self.aMyObject = null then
		return;
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="insertSource" id="f4c46e91-7e3c-4c29-903d-9a6f03e15ba5">
        <source>insertSource(pText:String) protected;
// --------------------------------------------------------------------------------
// Created:		03 November 2001 by cnwdad1
//
// Purpose:		Inserts the specified string value into the source code textbox.
//
// Parameters:	pText - The string value to insert into the source.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	textboxObj		: CnEcTextBox;
	sourceCode		: String;
	insertPosition	: Integer;
	
begin
	textboxObj		:=	txtSource;
	insertPosition	:=	textboxObj.selStart;
	sourceCode		:=	textboxObj.cnEcString();
	
	if insertPosition = 1 then
		sourceCode	:=	pText &amp; sourceCode;
	elseif insertPosition = sourceCode.length() then
		sourceCode	:=	sourceCode &amp; pText;
	else
		sourceCode	:=	sourceCode[1:(insertPosition)] &amp;
						pText &amp;
						sourceCode[(insertPosition + 1):end];
	endif;
	
	textboxObj.text		:=	sourceCode;
	textboxObj.selStart	:=	insertPosition + pText.length();
	textboxObj.setFocus();
end;</source>
        <access>protected</access>
        <Parameter name="pText" type="String"/>
    </JadeMethod>
    <JadeMethod name="inspectObject" id="3ce9e049-62b0-4425-9a08-4bf7d708491c">
        <source>inspectObject(pTargetObj:Object) protected;
// --------------------------------------------------------------------------------
// Created:		04 November 2001 by cnwdad1
//
// Purpose:		Invokes the native JADE inspector for the specified object.
//
// Parameters:	pTargetObj - The object to inspect.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	pTargetObj.inspectModal();
end;</source>
        <access>protected</access>
        <Parameter name="pTargetObj" type="Object"/>
    </JadeMethod>
    <JadeMethod name="keyDown" id="f251e2fe-de1d-4122-ad3d-87987129163c">
        <controlMethod name="Form::keyDown"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>keyDown(keyCode: Integer io; shift: Integer) updating;
// --------------------------------------------------------------------------------
// Created:		02 November 2001 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	app.mousePointer	:=	Busy;
	
	if keyCode = CNEC_KEY_F8 then
		self.executeSource();
		
	elseif keyCode = CNEC_KEY_F9 then
		self.clearOutput();
	
	elseif keyCode = CNEC_KEY_F12 then
		unloadForm();
	endif;
epilog
	app.mousePointer	:=	Idle;
end;</source>
        <Parameter name="keyCode" type="Integer" usage="io"/>
        <Parameter name="shift" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="listNodeOpenClose" id="a1fcd940-02db-4b5a-925f-b3a9ad109e5d">
        <source>listNodeOpenClose(pListboxObj:CnEcListBox input; pListIndex:Integer) protected;
// --------------------------------------------------------------------------------
// Created:		03 November 2001 by cnwdad1
//
// Purpose:		Handles the opening and closing of the Property tree nodes.
//
// Parameters:	pListboxObj - The listbox who's node to open or close.
//				pListIndex - The item index of the node to open or close.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	classObj	: Class;
	propertyObj	: Property;
	listIndex	: Integer;
	itemLevel	: Integer;
	
begin
	if pListIndex = 1 then
		classObj	:=	self.aMyObject.class();
	else
		propertyObj	:=	pListboxObj.itemObject[pListIndex].Property;
		
		if propertyObj = null or propertyObj.cnEcIsPrimitive() then
			return;
		endif;
		
		classObj	:=	propertyObj.type.Class;
	endif;

	if pListboxObj.itemExpanded[pListIndex] then
		self.listNodeRemoveChildren(pListboxObj, pListIndex);
	else
		listIndex	:=	pListIndex;
		itemLevel	:=	pListboxObj.itemLevel[listIndex];
		
		self.loadPropertiesForObject(classObj, listIndex, itemLevel);
	endif;
	
	pListboxObj.itemExpanded[pListIndex]	:=	(not pListboxObj.itemExpanded[pListIndex]);
end;</source>
        <access>protected</access>
        <Parameter name="pListboxObj" type="CnEcListBox" usage="input"/>
        <Parameter name="pListIndex" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="listNodeRemoveChildren" id="6c5b1715-fb99-4340-acfb-d76de59b7889">
        <source>listNodeRemoveChildren(pListboxObj:CnEcListBox input; pListIndex:Integer) protected;
// --------------------------------------------------------------------------------
// Created:		03 November 2001 by cnwdad1
//
// Purpose:		Removes all child list items of the specified item index from the
//				listbox tree.
//
// Parameters:	pListboxObj - The listbox from which to remove the node's children.
//				pListIndex - The item index of the node whose children to remove.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	childLevel	: Integer;
	childIndex	: Integer;
	
begin
	childIndex	:=	pListIndex + 1;
	childLevel	:=	pListboxObj.itemLevel[pListIndex] + 1;
	
	// First, add back a dummy so that the node picture is a Folder instead of a leaf.
	
	pListboxObj.addItemAt(self.DUMMY_OBJECT, childIndex);
	pListboxObj.itemLevel[pListboxObj.newIndex]	:=	pListboxObj.itemLevel[pListIndex] + 1;
	childIndex	:=	childIndex + 1;
	
	// Now remove the other remaining child nodes.
	
	while childIndex &lt;= pListboxObj.listCount do
		if pListboxObj.itemLevel[childIndex] = childLevel then
			pListboxObj.removeItem(childIndex);
		else
			break;
		endif;
	endwhile;
end;</source>
        <access>protected</access>
        <Parameter name="pListboxObj" type="CnEcListBox" usage="input"/>
        <Parameter name="pListIndex" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="load" id="7f82f492-310f-4f6a-832c-0c12d8908824">
        <controlMethod name="Form::load"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>load() updating;
// -----------------------------------------------------------------------------
// Created:		31 October 2001 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//
// -----------------------------------------------------------------------------
begin
	app.mousePointer	:=	Busy;
	inheritMethod();
	centreWindow();
	
	self.doFormLoad();
	self.resize();
epilog
	app.mousePointer	:=	Idle;
end;</source>
    </JadeMethod>
    <JadeMethod name="loadCallStack" id="e53dc52f-bc41-4006-876c-6169be2d9c1e">
        <source>loadCallStack() protected;
// --------------------------------------------------------------------------------
// Created:		16 November 2001 by cnwdad1
//
// Purpose:		Populate the call-stack table control.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	methodCallObj	: MethodCallDesc;
	receiverObj		: Object;
	tableObj		: CnEcTable;
	tableRowObj		: JadeTableRow;
	rowString		: String;
	rowIndex		: Integer;
	stackCount		: Integer;
	
begin
	tableObj	:=	tblCallStack;
	self.initializeCallStackTable(tableObj);
	
	if (not self.aIsShowCallStack) then
		shtCallStack.visible	:=	false;
		return;
	endif;
	
	self.aAllProcessCalls.purge();
	process.currentStack(self.aAllProcessCalls);
	self.aAllProcessCalls.removeAt(1);
	stackCount	:=	self.aAllProcessCalls.size();
	
	foreach methodCallObj in self.aAllProcessCalls do
		receiverObj	:=	methodCallObj.getReceiver();
		
		if receiverObj &lt;&gt; self then
			rowString	:=	stackCount.String &amp; Tab &amp;
							receiverObj.String &amp; Tab &amp;
							methodCallObj.method.name &amp; Tab &amp;
							methodCallObj.position.String &amp; Tab &amp;
							methodCallObj.invocationMode.Integer.String;
							
			rowIndex				:=	tableObj.addItem(rowString);
			tableRowObj				:=	tableObj.accessRow(rowIndex);
			tableRowObj.itemObject	:=	methodCallObj;
		endif;

		stackCount	:=	stackCount - 1;
	endforeach;
	
	self.enableCallStackMenus(tableObj);
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="loadCallStackSource" id="497fbb5b-60b7-430c-b280-1fc654753c5a">
        <source>loadCallStackSource() protected;
// -----------------------------------------------------------------------------
// Created:		11 December 2001 by cnwdad1
//
// Purpose:		Populate the call-stack source textbox with the method source of
//				the currently selected Call Stack Description object.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//
// -----------------------------------------------------------------------------
vars
	methodCallObj	: MethodCallDesc;
	tableObj		: CnEcTable;
	rowIndex		: Integer;
	
begin
	tableObj		:=	tblCallStack;
	rowIndex		:=	tableObj.row;
	methodCallObj	:=	tableObj.accessRow(rowIndex).itemObject.MethodCallDesc;
	
	if methodCallObj = null then
		txtStackSource.text	:=	null;
	else
		txtStackSource.text	:=	methodCallObj.method.getSource;
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="loadDescriptionCollection" id="b745cbbc-0f63-4774-b0c1-0e60c46beba5">
        <source>loadDescriptionCollection(pTableObj:CnEcTable; pOwnerObj:Object; pPropertyObj:Property) protected;
// --------------------------------------------------------------------------------
// Created:		01 November 2001 by cnwdad1
//
// Purpose:		Adds details of the collection property to the display table.
//
// Parameters:	pTableObj - The table containing the property details.
//				pOwnerObj - The object on which the property is defined.
//				pPropertyObj - The property object whose details to display.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	collectionObj	: Collection;
	
begin
	if pOwnerObj &lt;&gt; null then
		collectionObj	:=	pOwnerObj.getPropertyValue(pPropertyObj.name).Collection;
	endif;
	
	pTableObj.addItem("Kind" &amp; Tab &amp; pPropertyObj.type.CollClass.cnEcGetCollectionTypeName());
	
	if collectionObj = null then
		pTableObj.addItem("Size" &amp; Tab &amp; "0");
	else
		pTableObj.addItem("Size" &amp; Tab &amp; collectionObj.size().String);
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="pTableObj" type="CnEcTable"/>
        <Parameter name="pOwnerObj" type="Object"/>
        <Parameter name="pPropertyObj" type="Property"/>
    </JadeMethod>
    <JadeMethod name="loadDescriptionGeneric" id="d6744495-ab3d-4f39-99d1-4978d1ba8f1e">
        <source>loadDescriptionGeneric(pTableObj:CnEcTable; pOwnerObj:Object; pPropertyObj:Property) protected;
// --------------------------------------------------------------------------------
// Created:		01 November 2001 by cnwdad1
//
// Purpose:		Adds generic details of the property to the display table.
//
// Parameters:	pTableObj - The table containing the property details.
//				pOwnerObj - The object on which the ptoperty is defined.
//				pPropertyObj - The property object whose details to display.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	propertyName	: String;
	
begin
	propertyName	:=	pPropertyObj.name;
	pTableObj.addItem("Name" &amp; Tab &amp; propertyName);
	pTableObj.addItem("Type" &amp; Tab &amp; pPropertyObj.type.name);
	
	if pPropertyObj.cnEcIsAttribute() then
		if pPropertyObj.cnEcIsPrimitiveArray() then
			self.loadDescriptionPrimitiveArray(pTableObj, pOwnerObj, propertyName);
		
		elseif pPropertyObj.cnEcIsPrimitive() then
			self.loadDescriptionPrimitive(pTableObj, pPropertyObj);
		
		else
			return;
		endif;
		
	elseif pPropertyObj.cnEcIsReference() then
		if pPropertyObj.cnEcIsCollection() then
			self.loadDescriptionCollection(pTableObj, pOwnerObj, pPropertyObj);
			
		else
			self.loadDescriptionReference(pTableObj, pOwnerObj, pPropertyObj);
		
		endif;
	endif;

	if pOwnerObj = null then
		pTableObj.addItem("Value" &amp; Tab &amp; "null");
	else
		pTableObj.addItem("Value" &amp; Tab &amp; pOwnerObj.getPropertyValue(propertyName).String);
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="pTableObj" type="CnEcTable"/>
        <Parameter name="pOwnerObj" type="Object"/>
        <Parameter name="pPropertyObj" type="Property"/>
    </JadeMethod>
    <JadeMethod name="loadDescriptionPrimitive" id="2ba697fd-b49b-4363-9aef-780c900bf13b">
        <source>loadDescriptionPrimitive(pTableObj:CnEcTable; pPropertyObj:Property) protected;
// --------------------------------------------------------------------------------
// Created:		01 November 2001 by cnwdad1
//
// Purpose:		Adds details of the primitive property to the display table.
//
// Parameters:	pTableObj - The table containing the property details.
//				pPropertyObj - The property object whose details to display.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	pTableObj.addItem("Kind" &amp; Tab &amp; "Primitive");
	pTableObj.addItem("Length" &amp; Tab &amp; pPropertyObj.PrimAttribute.getLength.String);
			
	if pPropertyObj.type = Decimal then
		pTableObj.addItem("Scale Factor" &amp; Tab &amp; pPropertyObj.PrimAttribute.scaleFactor.String);
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="pTableObj" type="CnEcTable"/>
        <Parameter name="pPropertyObj" type="Property"/>
    </JadeMethod>
    <JadeMethod name="loadDescriptionPrimitiveArray" id="e193514d-1874-4d9a-bd3d-20b18aa78104">
        <source>loadDescriptionPrimitiveArray(pTableObj:CnEcTable; pOwnerObj:Object; pPropertyName:String) protected;
// --------------------------------------------------------------------------------
// Created:		01 November 2001 by cnwdad1
//
// Purpose:		Adds details of the primitive array property to the display table.
//
// Parameters:	pTableObj - The table containing the property details.
//				pOwnerObj - The object on which the property is defined.
//				pPropertyName - The name of the property whose details to display.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	propertyArrayObj	: Array;
	
begin
	pTableObj.addItem("Kind" &amp; Tab &amp; "Primitive Array");
	
	if pOwnerObj = null then
		pTableObj.addItem("Size" &amp; Tab &amp; "0");
	else
		propertyArrayObj	:=	pOwnerObj.getPropertyValue(pPropertyName).Array;
		pTableObj.addItem("Size" &amp; Tab &amp; propertyArrayObj.size().String);
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="pTableObj" type="CnEcTable"/>
        <Parameter name="pOwnerObj" type="Object"/>
        <Parameter name="pPropertyName" type="String"/>
    </JadeMethod>
    <JadeMethod name="loadDescriptionReference" id="d575835e-f976-43b3-9442-02fe55033ab4">
        <source>loadDescriptionReference(pTableObj:CnEcTable; pOwnerObj:Object; pPropertyObj:Property) protected;
// --------------------------------------------------------------------------------
// Created:		01 November 2001 by cnwdad1
//
// Purpose:		Adds details of the reference property to the display table.
//
// Parameters:	pTableObj - The table containing the property details.
//				pOwnerObj - The object on which the property is defined.
//				pPropertyObj - The property object whose details to display.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	referenceObj	: Object;
	
begin
	pTableObj.addItem("Kind" &amp; Tab &amp; "Object");
	
	if pOwnerObj &lt;&gt; null then
		referenceObj	:=	pOwnerObj.getPropertyValue(pPropertyObj.name).Object;
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="pTableObj" type="CnEcTable"/>
        <Parameter name="pOwnerObj" type="Object"/>
        <Parameter name="pPropertyObj" type="Property"/>
    </JadeMethod>
    <JadeMethod name="loadDescriptionSelf" id="c84a6573-f34f-4a35-a658-857aa069a40e">
        <source>loadDescriptionSelf(pTableObj:CnEcTable; pTargetObj:Object) protected;
// --------------------------------------------------------------------------------
// Created:		02 November 2001 by cnwdad1
//
// Purpose:		Adds details of the object being inspected to the display table.
//
// Parameters:	pTableObj - The table containing the property details.
//				pTargetObj - The object whose details to display.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	pTableObj.addItem("Type" &amp; Tab &amp; pTargetObj.class().name);
	pTableObj.addItem("Kind" &amp; Tab &amp; "Object");
	pTableObj.addItem("Value" &amp; Tab &amp; pTargetObj.String);
end;</source>
        <access>protected</access>
        <Parameter name="pTableObj" type="CnEcTable"/>
        <Parameter name="pTargetObj" type="Object"/>
    </JadeMethod>
    <JadeMethod name="loadProperties" id="5ed99dc0-8bd9-4318-8867-52bc795abebd">
        <source>loadProperties() protected;
// -----------------------------------------------------------------------------
// Created:		31 October 2001 by cnwdad1
//
// Purpose:		Load the properties of the object being inspected into the
//				properties listbox.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//
// -----------------------------------------------------------------------------
vars
	listboxObj	: CnEcListBox;
	targetObj	: Object;
	listPointer	: Integer;
	
begin
	listboxObj	:=	lstProperties;
	listboxObj.clear();
	
	if self.aMyObject = null then
		return;
	endif;
	
	targetObj	:=	self.aMyObject;
	
	listPointer	:=	listboxObj.addItem(targetObj.class().name);
	listboxObj.itemForeColor[listPointer]	:=	Black;
	listboxObj.itemLevel[listPointer]		:=	1;
	
	// Now add the dummy child node so that the parent node show a folder, not a leaf.
	
	listboxObj.addItemAt(self.DUMMY_OBJECT, (listPointer + 1));
	listboxObj.itemLevel[(listPointer + 1)]	:=	2;
	
	// Fimnally, load up the objects properties.
	
	self.loadPropertiesForObject(targetObj.class(), listPointer, 1);
	
	listboxObj.itemExpanded[listPointer]	:=	true;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="loadPropertiesForObject" id="8f543b25-500b-4553-8799-36fa6748b149">
        <source>loadPropertiesForObject(pClassObj:Class; pListIndex:Integer io; pClassLevel:Integer) protected;
// -----------------------------------------------------------------------------
// Created:		31 October 2001 by cnwdad1
//
// Purpose:		Loads all of the properties of the specified class into the
//				properties listbox.
//
// Parameters:	pClassObj - The clas whose properties to add to the listbox.
//				pClasSIndex - The listbox item index at which to start adding
//					the properties.
//				pStartLevel - The item level at which to start adding the
//					properties.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//
// -----------------------------------------------------------------------------
vars
	listboxObj		: CnEcListBox;
	propertyCollObj	: PropertyColl;
	targetObj		: Object;
	propertyObj		: Property;
	listPointer		: Integer;
	propertyLevel	: Integer;
	childLevel		: Integer;
	isCollection	: Boolean;
	isFound			: Boolean;
	itemColor		: Integer;
	
begin
	listboxObj		:=	lstProperties;
	listPointer		:=	pListIndex + 1;
	propertyLevel	:=	pClassLevel + 1;
	childLevel		:=	propertyLevel + 1;
	isCollection	:=	pClassObj.cnEcIsCollection();
	targetObj		:=	self.getSourceObject(listboxObj, pListIndex);
	
	self.removeDummyProperty(listboxObj, listPointer);
	
	isFound			:=	false;
	propertyCollObj	:=	pClassObj.allProperties();
	
	foreach propertyObj in propertyCollObj do
		if isCollection then
			if propertyObj.isSystemObject() then
				continue;
			endif;
		endif;
		
		listboxObj.addItemAt(propertyObj.name, listPointer);
		listboxObj.itemLevel[listPointer]		:=	propertyLevel;
		listboxObj.itemObject[listPointer]		:=	propertyObj;
		
		if targetObj = null then
			itemColor	:=	Gray;
		else
			// We know that the parent object is not null, but if the current
			// property's object is null, then we still need to gray it out.
			
			if propertyObj.cnEcIsReference()
			or propertyObj.cnEcIsPrimitiveArray()
			then
				if self.getSourceObject(listboxObj, listPointer) = null then
					itemColor	:=	Gray;
				else
					itemColor	:=	Black;
				endif;
			else
				itemColor	:=	Black;
			endif;
		endif;

		listboxObj.itemForeColor[listPointer]	:=	itemColor;
		
		if propertyObj.cnEcIsReference()
		or propertyObj.cnEcIsPrimitiveArray()
		then
			self.addDummyProperty(listboxObj, listPointer);
		endif;

		listPointer	:=	listPointer + 1;
		isFound		:=	true;
	endforeach;
	
	if (not isFound) then
		// No properties were found to load, so we'll add back the dummy child node.
		self.addDummyProperty(listboxObj, pListIndex);
	endif;
epilog
	delete propertyCollObj;
end;</source>
        <access>protected</access>
        <Parameter name="pClassObj" type="Class"/>
        <Parameter name="pListIndex" type="Integer" usage="io"/>
        <Parameter name="pClassLevel" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="loadPropertyValues" id="cf51f2b6-6124-410b-8543-8e07ec1ea964">
        <source>loadPropertyValues(pListIndex:Integer) protected;
// --------------------------------------------------------------------------------
// Created:		01 November 2001 by cnwdad1
//
// Purpose:		Load the details and values of the property at the specified listbox
//				index into the display table.
//
// Parameters:	pListIndex - The item index of the property whose details to display.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	listboxObj				: CnEcListBox;
	tableObj				: CnEcTable;
	propertyName			: String;
	propertyObj				: Property;
	propertyOwnerObj		: Object;
	
begin
	self.initializeValuesTable();
	
	tableObj	:=	tblValues;
	
	if pListIndex = 1 then
		self.loadDescriptionSelf(tableObj, self.aMyObject);
		return;
	endif;
	
	listboxObj			:=	lstProperties;
	propertyOwnerObj	:=	self.getPropertyOwner(listboxObj, pListIndex);
	
	propertyObj	:=	listboxObj.itemObject[pListIndex].Property;
	
	if propertyObj = null then
		return;
	endif;
	
	self.loadDescriptionGeneric(tableObj, propertyOwnerObj, propertyObj);
end;</source>
        <access>protected</access>
        <Parameter name="pListIndex" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="lstProperties_click" id="0667ea12-e77f-4dab-af69-bca9ddf890c0">
        <controlMethod name="ListBox::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>lstProperties_click(listbox: ListBox input) updating;
// --------------------------------------------------------------------------------
// Created:		01 November 2001 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	
begin
	app.mousePointer	:=	Busy;
	
	self.loadPropertyValues(listbox.listIndex);
	self.selectedPropertyOptions();
epilog
	app.mousePointer	:=	Idle;
end;</source>
        <Parameter name="listbox" type="ListBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="lstProperties_mouseDown" id="e5481223-f308-4e49-bc72-539288f62b8b">
        <controlMethod name="ListBox::mouseDown"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>lstProperties_mouseDown(listbox: ListBox input; button: Integer; shift: Integer; x: Real; y: Real) updating;
// --------------------------------------------------------------------------------
// Created:		03 November 2001 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	actualXPos	: Real;
	actualYPos	: Real;
	
begin
	if button = Window.MouseButton_Right then
		actualXPos	:=	x;
		actualYPos	:=	y;
		
		self.cnEcGetRelativePosition(listbox, actualXPos, actualYPos);
		popupMenu(mnuListbox, actualXPos.Integer, actualYPos.Integer);
	endif;
end;</source>
