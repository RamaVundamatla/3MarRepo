    <JadeMethod name="keyDown" id="70eb8aac-5691-4d96-89b3-a836a250b25c">
        <controlMethod name="Form::keyDown"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>keyDown(keyCode: Integer io; shift: Integer) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
17 June 2011	cnwndl1	Initial creation	Par 27731

*/

vars

begin

	if keyCode = CMUI_Key_F3 then
		self.doShowSearcherClick();
	elseif keyCode = CMUI_Key_F5 then
		self.doMTPoolingQuery();
	else
		inheritMethod(keyCode, shift);
	endif;

epilog

end;</source>
