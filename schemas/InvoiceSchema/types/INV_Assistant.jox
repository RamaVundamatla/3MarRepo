    <JadeMethod name="showInvoiceLineList" id="035d6870-e870-43d9-b36a-5dc33fff0b92">
        <source>showInvoiceLineList(_object : CM_Object; _multiTerminal : Boolean; _masterMenuAction : CMUI_MenuAction);
// ---------------------------------------------------------------------------
// Created:		August 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	invoiceForm : INV_ListLines;
	menuAction : CMUI_MenuAction;
begin
	
	if _object = null or not _object.isKindOf(CM_Debtor) then
		return;
	endif;
	menuAction := app.myController.createMenuAction(PmAdmInvoicelinesView, null, _masterMenuAction, self.myTerminal);
	if menuAction = null then
		return;
	endif;
	
	invoiceForm := menuAction.goToObject(null, null, false, null).INV_ListLines;
	if invoiceForm = null then
		return;
	endif;

	if _multiTerminal then	
		invoiceForm.setPropertyValue(INV_ListInvoices::mode.name,INV_ListInvoices.Mode_MultiTerminal);
	endif;
	
	invoiceForm.myCurrentDebtor := _object.CM_Debtor;
	invoiceForm.show(); //WithObject(_object, _thumbnailOnly, _doEdit);

end;</source>
        <Parameter name="_object" type="CM_Object"/>
        <Parameter name="_multiTerminal" type="Boolean"/>
        <Parameter name="_masterMenuAction" type="CMUI_MenuAction"/>
    </JadeMethod>
    <JadeMethod name="showInvoiceLineTypeForm" id="2b7e4f6f-ec49-40d6-914e-12aab5ea9dc9">
        <source>showInvoiceLineTypeForm(_object : CM_Object; _masterMenuAction : CMUI_MenuAction;_thumbnailOnly, _doEdit : Boolean);
// ---------------------------------------------------------------------------
// Created:		August 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	invoiceForm : CM_TableViewForm;
	menuAction : CMUI_MenuAction;
begin
	
	if _object = null then
		return;
	endif;
	menuAction := app.myController.createMenuAction(PmAdmInvLineDescriView, null, _masterMenuAction, self.myTerminal);
	if menuAction = null then
		return;
	endif;
	
	invoiceForm := menuAction.goToObject(null, null, false, null).CM_TableViewForm;
	if invoiceForm = null then
		return;
	endif;
	
	invoiceForm.showWithObject(_object, _thumbnailOnly, _doEdit);

end;</source>
        <Parameter name="_object" type="CM_Object"/>
        <Parameter name="_masterMenuAction" type="CMUI_MenuAction"/>
        <Parameter name="_thumbnailOnly" type="Boolean"/>
        <Parameter name="_doEdit" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="showInvoiceLineUpdateForm" id="be2f813b-a710-4fa9-a1e1-6875363389f0">
        <source>showInvoiceLineUpdateForm(_invoiceLine : CM_InvoiceLine input; _view : String; _parentForm : CM_BaseForm);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 January 2026	jlier1	Initial creation 36572

*/

vars
	form :INV_InvoiceLineUpdate;
begin

	if not app.myCurrentUserCan(self.myTerminal, _parentForm.permissionMaint) then
		if app.myCurrentUserCan(self.myTerminal, PmAdmInvoiceLineStatusVoid) and _view = ETView_InvListInvLinePropVoid then
		elseif app.myCurrentUserCan(self.myTerminal, PmAdmInvoiceLineStatusNormal) and _view = ETView_InvListInvLinePropVoid then
		else
			app.msgBox(app.getErrorString(NoPermission),app.getErrorString(Error),MsgBox_OK_Only);
			return;
		endif;
	endif;

	if _invoiceLine = null then
		app.msgBox(app.getErrorString(Invoice_line_selected),app.getErrorString(Invoice_line),MsgBox_OK_Only);
		return;
	endif;
	
	create form transient;
	form := app.loadForm(INV_InvoiceLineUpdate, 
			INV_Assistant, 
			false, 
			false,
			false, 
			self.myTerminal,
			null).INV_InvoiceLineUpdate;	

	if form = null then
		return;
	endif;
	form.myCurrentInvoiceLine:=_invoiceLine;
	form.currentView:=_view;
	form.createMyAssistant(INV_Assistant);
	form.setParentForm (_parentForm);
	form.showModal();
epilog

end;</source>
        <Parameter name="_invoiceLine" type="CM_InvoiceLine" usage="input"/>
        <Parameter name="_view" type="String"/>
        <Parameter name="_parentForm" type="CM_BaseForm"/>
    </JadeMethod>
    <JadeMethod name="showInvoiceLinesForInvoice" id="c5347518-ec7b-40c5-9540-b5eb456bd990">
        <source>showInvoiceLinesForInvoice(_invoice : CM_Invoice; _masterMenuAction : CMUI_MenuAction);
// ---------------------------------------------------------------------------
// Created:		February 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

	invoiceForm 	: Form; 
	menuAction 		: CMUI_MenuAction;
begin
	if _invoice = null then
		return;
	endif;
	
	menuAction := app.myController.createMenuAction(PmAdmInvoicelinesView, null, _masterMenuAction, self.myTerminal);
	if menuAction = null then
		return;
	endif;
	
	invoiceForm := menuAction.goToObject(null, null, false, null); 
	if invoiceForm = null then
		return;
	endif;
	invoiceForm.INV_ListLines.myCurrentInvoice := _invoice;
	invoiceForm.show();


end;</source>
        <Parameter name="_invoice" type="CM_Invoice"/>
        <Parameter name="_masterMenuAction" type="CMUI_MenuAction"/>
    </JadeMethod>
    <JadeMethod name="showInvoiceListForm" id="08463a0f-ec38-4db8-bab4-28f89ad859d1">
        <source>showInvoiceListForm(_object : CM_Object; _masterMenuAction : CMUI_MenuAction; _multiTerm : Boolean);
// ---------------------------------------------------------------------------
// Created:		August 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	invoiceForm : INV_ListInvoices;
	menuAction : CMUI_MenuAction;
begin
	if _object = null or not (_object.isKindOf(CM_Debtor) or _object.isKindOf(CM_Invoice)) then
		return;
	endif;
	menuAction := app.myController.createMenuAction(PmAdmInvoicelistView, null, _masterMenuAction, self.myTerminal);
	if menuAction = null then
		return;
	endif;
	
	invoiceForm := menuAction.goToObject(null, null, false, null).INV_ListInvoices;
	if invoiceForm = null then
		return;
	endif;
	
	if _object.isKindOf(CM_Debtor) then
		invoiceForm.myCurrentDebtor := _object.CM_Debtor;
	elseif _object.isKindOf(CM_Invoice) then
		invoiceForm.myCurrentInvoice := _object.CM_Invoice;
	endif;
	
	if _multiTerm then
		invoiceForm.setPropertyValue(INV_ListInvoices::mode.name,INV_ListInvoices.Mode_MultiTerminal);
	endif;
	invoiceForm.show(); //WithObject(_object, _thumbnailOnly, _doEdit);

end;</source>
        <Parameter name="_object" type="CM_Object"/>
        <Parameter name="_masterMenuAction" type="CMUI_MenuAction"/>
        <Parameter name="_multiTerm" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="showInvoiceSSAllocationMaint" id="de858de8-8802-4c28-baf0-ad0649f206e2">
        <source>showInvoiceSSAllocationMaint(	_alloc : CM_InvoiceAllocation;
								_ssBroker : CM_SnapShotServiceBroker;
								_masterMenuAction : CMUI_MenuAction
								);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 February 2019	jlgndl1	Initial creation

*/

vars
	invoiceForm : CMUI_YAMaintInvoiceSSAlloc;
	yas: ObjectArray;
begin
	invoiceForm := app.loadForm(CMUI_YAMaintInvoiceSSAlloc, 
							INV_Assistant, 
							false, 
							false,
							false, 
							self.myTerminal,
							null).CMUI_YAMaintInvoiceSSAlloc;	
	
	// from 36280 check for no form because of security issue
	if invoiceForm = null then
		return;
	endif;
	invoiceForm.createMyAssistant(INV_Assistant);
	invoiceForm.mySSBroker := _ssBroker;
	
	if _alloc &lt;&gt; null then // UPDATE
		create yas transient;		
		yas.add(_alloc);
	endif;
	
	invoiceForm.setYardAllocation(yas);
	

	invoiceForm.showModal();	
	
epilog
	delete yas;
end;</source>
        <Parameter name="_alloc" type="CM_InvoiceAllocation"/>
        <Parameter name="_ssBroker" type="CM_SnapShotServiceBroker"/>
        <Parameter name="_masterMenuAction" type="CMUI_MenuAction"/>
    </JadeMethod>
