<Class name="CnEcHtmlOrderedListTag" id="dac3f602-211f-4850-89b8-361f326ad986">
    <superclass name="CnEcHtmlListTag"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
