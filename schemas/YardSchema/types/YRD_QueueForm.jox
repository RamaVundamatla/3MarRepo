    <JadeMethod name="timerEvent" id="f1f3487b-1a6e-4432-9510-2b487441a701">
        <updating/>
        <source>timerEvent(eventTag: Integer) updating;
//
// 14 Sep 2016	cnwrs1			FTS 2629 PAR #38163 JMT going slow
//
vars

begin
	if eventTag = self.Timer_Refresh then
		self.refreshTimerStarted := false;
		self.loadQueues(true);
	elseif eventTag = self.Timer_EntryRefresh then
		self.refreshEntityTimerStarted := false;
		self.loadQueueEntries();
	endif;		
epilog

end;</source>
