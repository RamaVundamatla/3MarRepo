    <JadeMethod name="checkForMinimumCharge" id="558fc0f4-67da-4a9e-9cd1-c7d7afdcda0c">
        <source>checkForMinimumCharge(_debtor : CM_Debtor; _origInvLine : CM_InvoiceLine input; _tran : CM_Transaction);
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 18/09/2015	cnwdap1		Initial creation PAR #36909 CCMS ADP 2537 Minimum Charge changes
// 20 Jan 2020  cnwma1		Bug 48298: ADP - FW: Ticket 48149 - Minimum Charge Line remove in UAT - ##336278##
//
vars
	diff 	: Real;
	newLine : CM_InvoiceLine;
	seqNum  : Integer;
	now 	: TimeStamp;
	charge  : CM_Charge;
	theController : CMIF_InvoiceLineManual; //29/09/2025	navkc1 JIRA 35917
	ti : CM_TrackedItem; //29/09/2025	navkc1 JIRA 35917
begin
	now := app.actualTimeServer();	// 16 Sept 2016	cnwns1	TFS 488 - Multi Timezone Support
	if self.minimumChargeAmount &lt;&gt; null then
		// does this minimum quantity kick in at the invoice line level?
		if self.minimumChargeGroupBy = self.GROUP_BY_INVOICELINE and self.minimumChargeAmount &gt; _origInvLine.lineTotal then
			if _origInvLine &lt;&gt; null then
				
				if not  self.hasMinChargeCollected(_origInvLine) then
					// create an invoice line for the difference in amount between invoice line and my minimum amount
					diff := self.minimumChargeAmount - _origInvLine.lineTotal;
					/*//29/09/2025	navkc1 JIRA 35917 Change to use standard CMIF_InvoiceLineManual
					create newLine persistent;
					seqNum := app.getNextInvoiceSeqNumOnRootBank(SN_INVOICELINE);
					newLine.setForCreate(seqNum, false, null, self.minimumChargeInvoiceLineType, _origInvLine.invoice, _debtor, _origInvLine.bank, 1, now);
					if _tran &lt;&gt; null and _tran.isKindOf(CM_TITransaction) then	//14 Jun 2017	NDL	TFS 4816
						newLine.setMyTransaction(_tran.CM_TITransaction);
						newLine.setTrackedItem(_tran.CM_TITransaction.myTrackedItem);
					elseif _tran &lt;&gt; null and _tran.isKindOf(CM_EventTransaction) then	//14 Jun 2017	NDL	TFS 4816
						newLine.setMyTransactionEvent( _tran.CM_EventTransaction );
					endif;
					newLine.setMyInvoiceLineOriginal(_origInvLine);
					newLine.createCharges();
					foreach charge in newLine.charges do
						/* TFS 45319
						charge.total := self.minimumChargeAmount - _origInvLine.lineTotal;
						// TFS 42084 charge.isTotalSetExplicitly := true; // should not have used isTotalSetExplicitly should have used overridden
						charge.setOverriden(); // TFS 42084
						charge.setRateForMinMax(charge.total);
						*/
					/*	charge.total := diff; // TFS 45319
						charge.setOverriden(); // TFS 45319
						charge.setRateForMinMax(diff); // TFS 45319
					endforeach;
					newLine.setTotalAmount();  // ### JIRA 35502 21JUL2025 NAVAB1 if setting the total then set static value as well					
					*/
					//29/09/2025	navkc1 JIRA 35917
					create theController transient;
					theController.myInvoice := _origInvLine.invoice;
					theController.quantity := 1;
					theController.isManual := false;
					theController.chargeTime := now;
					theController.isOverridden := true;
					theController.totalAmount := diff;
					theController.rate := diff;
					if _tran &lt;&gt; null then
						theController.myTransaction := _tran;
						
						if _tran.isCargoTrx() then
							ti := _tran.CM_TITransaction.myTrackedItem;
							theController.myTrackedItem := ti;
						endif;
					endif;
					
					newLine := self.minimumChargeInvoiceLineType.createManualInvoiceLine(theController, ti, false);
					newLine.setMyInvoiceLineOriginal(_origInvLine);
					
				endif;
			endif;
		endif;
	endif;
	
epilog
	delete theController; //29/09/2025	navkc1 JIRA 35917
end;</source>
        <Parameter name="_debtor" type="CM_Debtor"/>
        <Parameter name="_origInvLine" type="CM_InvoiceLine" usage="input"/>
        <Parameter name="_tran" type="CM_Transaction"/>
    </JadeMethod>
    <JadeMethod name="createInvoiceLine" id="bdc91719-bac6-4ced-a99b-8b91e07abc90">
        <updating/>
        <source>createInvoiceLine(debtor : CM_Debtor; tran : CM_TITransaction) : CM_InvoiceLine updating;

vars
	invLine:   CM_InvoiceLine;
	invoice:   CM_Invoice;
	now:       TimeStamp;
	seqNum : Integer;
	invType : CM_InvoiceDesc;
	cmifHook: CMIF_CalcTypeRemarksHook;
begin

	invType := self.getInvoiceType(debtor); // PAR 8924

	invoice := self.bank.getAutoInvoice(invType, self, tran, debtor, false); // PAR 8924
	create invLine persistent;
	// PAR 30751 seqNum := self.bank.getSeqNumInvoiceLine(); // PAR 18104
	seqNum := app.getNextInvoiceSeqNumOnRootBank(SN_INVOICELINE); // PAR 30751

	if tran.dateTime.isValid then
		now := tran.dateTime;	//else use timestamp set in now.
	else
		now := app.serverTimestampAtTrxStart;	// should always use this
	endif;
	invLine.setForCreate(seqNum, false, null,self, invoice, debtor, bank, 0, now);
	invLine.setMyTransaction(tran);
	invLine.setTrackedItem(tran.myTrackedItem);
	invLine.createCharges();
	
	invLine.doHookCodeForRemarks();	//27 Dec 2018	NDL	TFS 42119
		
/*	calcType := invLine.getCalcType();			// 28/2/18 MAP TFS37124
	if calcType &lt;&gt; null and calcType.myHookCodeRemarks &lt;&gt; null then
		create cmifHook transient;
		cmifHook.myTransaction := tran;
		cmifHook.origRemarks := invLine.remarks;
		cmifHook.myInvoiceLine := invLine;

		valueOut := app.myHookAgent.runHookLinkReturn(HookType_InvoiceRemarks, calcType, calcType, cmifHook).String;
		if invLine.remarks &lt;&gt; valueOut then
			app.invLog("Remarks change from " &amp; invLine.remarks &amp; " to " &amp; valueOut);
			invLine.setRemarks(valueOut);
		endif;
	endif; */
	
	app.myUtilityCA.myCreateAuditAgent.audCreateGeneric(invLine);		// 9/5/18 MAP TFS37718

	return invLine;

epilog
	delete cmifHook;
end;</source>
        <Parameter name="debtor" type="CM_Debtor"/>
        <Parameter name="tran" type="CM_TITransaction"/>
        <ReturnType type="CM_InvoiceLine"/>
    </JadeMethod>
    <JadeMethod name="createInvoiceLineBOL" id="57bc7a5a-bfc2-4b6e-94b7-712d497099bd">
        <updating/>
        <source>createInvoiceLineBOL(_debtor : CM_Debtor; _tran : CM_BOLTransaction) : CM_InvoiceLine updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
01 November 2019	jlgndl1	Initial creation	TFS 47100
23 Oct 2024			navlw1	JIRA-33107: Invoice Logging Use Levels

*/

vars
	invLine:   CM_InvoiceLine;
