    <JadeMethod name="btnNo_click" id="db2a967a-9d47-425f-96c0-bf7f5d08052c">
        <controlMethod name="JadeMask::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnNo_click(jadeMask: JadeMask input) updating;
// --------------------------------------------------------------------------------
// Created:		23 July 2007 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	app.mousePointer	:=	Busy;
	app.beep();
	self.modalResult	:=	self.CNEC_MODAL_CANCEL;		// The driver is rejecting the weight.
	self.unloadForm();
epilog
	app.mousePointer	:=	Idle;
end;</source>
        <Parameter name="jadeMask" type="JadeMask" usage="input"/>
    </JadeMethod>
    <JadeMethod name="btnYes_click" id="5c3eff90-a0f9-4727-bde2-257eb64f5095">
        <controlMethod name="JadeMask::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnYes_click(jadeMask: JadeMask input) updating;
// --------------------------------------------------------------------------------
// Created:		23 July 2007 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	weight	: Integer;
	
begin
	app.mousePointer	:=	Busy;
	app.beep();
	weight	:=	txtWeight.cnEcInteger();
	
	if weight &lt;= 0 then
		app.msgBox("The weight must be greater than zero.", "Invalid Weight", MsgBox_Stop_Icon + MsgBox_OK_Only);
		return;
		
	elseif weight &lt;&gt; self.aWeight then
		self.aWeight		:=	txtWeight.cnEcInteger();
		self.modalResult	:=	self.CNEC_MODAL_UPDATE;		// The weight was changed by the driver.
		
	else
		self.modalResult	:=	self.CNEC_MODAL_CLOSE;		// No update, but not cancelled either.
		
	endif;
	
	self.unloadForm();
epilog
	app.mousePointer	:=	Idle;
end;</source>
        <Parameter name="jadeMask" type="JadeMask" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doBackspace" id="17774f47-f2ad-4453-a657-b16e2f97a2a4">
        <source>doBackspace() protected;
// --------------------------------------------------------------------------------
// Created:		13 November 2006 by cnwdad1
//
// Purpose:		Performs the "Backspace" action when the user hits the backspace button.
//
//				Reimplement this abstraction method on subclassed forms, with the
//				appropriate behaviour.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	textboxObj	: TextBox;
	textValue	: String;
	textLength	: Integer;
	
begin
	textboxObj	:=	txtWeight;
	textValue	:=	textboxObj.cnEcString();
	textLength	:=	textValue.length();
	
	if textLength = 1 then
		textValue	:=	null;
	elseif textLength &gt; 1 then
		textValue	:=	textValue.cnEcUpto(textLength - 1);
	endif;
	
	textboxObj.text	:=	textValue;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doClear" id="51c21693-080c-45da-96f3-c6dfdda1c21c">
        <updating/>
        <source>doClear() updating, protected;
// --------------------------------------------------------------------------------
// Created:		30 June 2006 by cnwdad1
//
// Purpose:		Refer to superclass implementation.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	txtWeight.cnEcSet(null);
	self.doEnableControls();
	txtWeight.setFocus();
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doKeyboardInput" id="33b099a0-45df-4c81-a201-e838066d8dc6">
        <updating/>
        <source>doKeyboardInput(_input: String):Boolean updating, protected;
// --------------------------------------------------------------------------------
// Created:		29 June 2006 by cnwdad1
//
// Purpose:		Refer to superclass implementation.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	weight	: String;
	
begin
	if _input = self.KEY_BACKSP then
		self.doBackspace();
		return true;
	elseif _input = self.KEY_CLEAR then
		self.doClear();
		return true;
	endif;
	
	if txtWeight.selLength &gt; 0 then
		weight	:=	_input;
	else
		weight	:=	txtWeight.cnEcString() &amp; _input;
	endif;

	if self.validateText(txtWeight, weight) then
		txtWeight.cnEcSet(weight);
	endif;
	
	self.doEnableControls();
	return true;
end;</source>
        <access>protected</access>
        <Parameter name="_input" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setWeight" id="97661585-e4fa-4c96-a707-f6705e4dab7a">
        <updating/>
        <source>setWeight(pWeight:Decimal) updating;
// --------------------------------------------------------------------------------
// Created:		23 July 2007 by cnwdad1
//
// Purpose:		Sets the current weight value on the receiver.
//
// Parameters:	pWeight - The current weight of the container.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.aWeight	:=	pWeight;
end;</source>
        <Parameter name="pWeight" type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="setupForm" id="41966b3a-d643-4635-8576-704f1aa3c484">
        <updating/>
        <source>setupForm() updating, protected;
// --------------------------------------------------------------------------------
// Created:		23 July 2007 by cnwdad1
//
// Purpose:		Standard form setup method.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	inheritMethod();
	
	txtWeight.cnEcSet(self.aWeight.asStringWeightJMT());
	txtWeight.setFocus();
	
	self.caption := "KIOSK - Weight Confirm";	//10 Sep 2021	NDL	TFS 51934
	
epilog
	app.mousePointer	:=	Idle;
end;</source>
        <access>protected</access>
    </JadeMethod>
</GUIClass>
