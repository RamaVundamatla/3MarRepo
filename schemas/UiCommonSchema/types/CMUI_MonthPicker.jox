        <Parameter name="_date" type="Date"/>
    </JadeMethod>
    <JadeMethod name="setYear" id="cf4a0d08-9ba1-40ed-bfe8-353d01e80ad4">
        <updating/>
        <source>setYear(_year : Integer) updating;
/*

Date		    Who			Reason
28 October 2010	cnwas3	  Initial creation

*/

vars

begin
	self.myYearTextBox.text := _year.asStringJMT();
	self.selectedDate := self.selectedDate.addYears(_year - self.selectedDate.year);
epilog

end;</source>
        <Parameter name="_year" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="windowCreated" id="52091fe5-3a03-4b9d-b7a8-e603d250ffa2">
        <controlMethod name="Control::windowCreated"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <executionLocation>client</executionLocation>
        <source>windowCreated(cntrl: Control input; persistCntrl: Control) updating, clientExecution;
/*

Date		    Who			Reason
27 October 2010	cnwas3	  Initial creation
// 17 May 2016	cnwns1	TFS 488 - Multi Timezone Support
*/

vars

begin
	inheritMethod(cntrl, persistCntrl);
	if app.name = "JadePainter" then
		self.systemDate := app.actualTimeServer().date();// 17 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	else
		self.systemDate := self.systemToLocalTime(app.actualTimeServer()).date();// 17 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	endif;
	self.buildSelf();	
	//self.cnEcResizeContents();
	self.resetValuesToDate(self.systemDate);
epilog

end;</source>
        <Parameter name="cntrl" type="Control" usage="input"/>
        <Parameter name="persistCntrl" type="Control"/>
    </JadeMethod>
