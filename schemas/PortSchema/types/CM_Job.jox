    <JadeMethod name="getMeasurementStringForAttrib" id="a2463e3b-881f-45f7-8696-96d4092f6c31">
        <source>getMeasurementStringForAttrib(_attrName: String; _measureType: String; _short: Boolean): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 Oct 2023	navhl20	ChangeRequest 60033: EUP | Ship Operations in DD - [54176.010] - [Receive] Ship Job List 

*/

vars

begin
	if _attrName = ETRow_Tonnage then
		return app.convertMeasurementForDisplay(_measureType, self.getTonnage());
	endif;
	return inheritMethod(_attrName, _measureType, _short);

epilog

end;</source>
