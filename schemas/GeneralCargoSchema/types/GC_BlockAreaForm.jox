    <JadeMethod name="setNotifications" id="0d51c09f-6aba-4e63-bf43-e6da3c2a97d4">
        <source>setNotifications(_startNote : Boolean) protected;
// Regsiter for all interresting notes 
vars
	anObject	: Object;
	idx			: Integer;
	numRows		: Integer;
	theTable	: Table;
	invalidObj	: Boolean;
	
begin
	theTable	:=	self.frmColLegendTIs.myLegendTable;
	numRows		:=	theTable.rows;

	on Exception do app.handleDeletedObject(exception, anObject, invalidObj);
	self.endNotificationForSubscriber(self);
	if _startNote then
		foreach idx in 2 to numRows do
			anObject := theTable.accessRow(idx).itemObject;
			if anObject &lt;&gt; null then
				self.beginNotification(anObject, EVENT_CODE_COLOUR_CHANGE, Response_Continuous, null);
			endif;
		endforeach;

		self.beginNotification(self.myTerminal, self.myTerminal.getTerminalEvent(Event_YardAllocationCreate), Response_Continuous, null);
		self.beginNotification(self.myTerminal, self.myTerminal.getTerminalEvent(Event_YardAllocationUpdate), Response_Continuous, null);
		self.beginNotification(self.myTerminal, self.myTerminal.getTerminalEvent(Event_YardAllocationDelete), Response_Continuous, null);
		self.beginNotification(self.frmBlockArea.getTerminalArea(), self.myTerminal.getTerminalEvent(EVENT_TI_MOVE), Response_Continuous, null);	
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="_startNote" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setSelector" id="27c3c5b0-6fb2-432e-8e82-001165c10cca">
        <updating/>
        <source>setSelector(_theSelector : CMUI_Selector input) updating, protected;

/*

Purpose:			


Return Value:		


Date		Who		Reason
16 May 2008	cnwkpd1	PAR #16753 - CCMS SFW 1003 - General Cargo Graphical Screens

*/

vars


begin
// -----&gt;&gt; the following was copied in from the YardSchema form.
	_theSelector.myQDef := app.myRoot.allQueryDefinitionObjects[CM_QueryDefinition.TrackedItem_Query_Type,0];//TI_CargoType_Container];
	_theSelector.disableMnuEnquiry := false;
	
	_theSelector.myDefaultTerminalArea := self.myCurrentTerminalArea;
	
	if self.myCurrentTerminalArea &lt;&gt; null and not _theSelector.allDefaultTerminalAreas.includes(self.myCurrentTerminalArea) then
		_theSelector.allDefaultTerminalAreas.add(self.myCurrentTerminalArea);
	endif;
	
// -----&gt;&gt; the following was the original code in this method.
	_theSelector.myTerminal := self.myTerminal;
	_theSelector.myEnquiryCollectionClass := CM_TIArray;
	_theSelector.defaultSiteStr := TI_SITE_ONSITE_str;
end;</source>
        <access>protected</access>
        <Parameter name="_theSelector" type="CMUI_Selector" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setupForm" id="c31aee19-45c7-468d-8b7e-72954e3aa670">
        <updating/>
        <source>setupForm() updating;

/*

Purpose:			


Return Value:		


Date		Who		Reason
16 May 2008	cnwkpd1	PAR #16753 - CCMS SFW 1003 - General Cargo Graphical Screens

*/

//constants
//	M_REAL = 0;
//	M_PLANNING = 1;
//	M_REHANDLE = 2;
//	M_Queue = 3;
// adm 250509 Par 19575	
vars
	operatorTerminology : String;

begin
	inheritMethod();
	
	if not self.myTerminal.getConfig(ShowCargoPicture).Boolean then
		self.sptBottom.hideRightControl(true);
	endif;
 	
	self.mnuGridAreaContext.visible	:=	false;
	self.doInitInfoTable();
	// this sets the captions for some menus
	self.getXMLSettingsForSetup();
	
	if self.xmlLegend then
		self.mnuGridHideLegend.caption		:=	self.MNU_LEGEND_HIDE;
	else
		self.mnuGridHideLegend.caption		:=	self.MNU_LEGEND_SHOW;
	endif;
	
	if self.xmlSplitMain &lt;&gt; 0 then
		self.splMain.setLeftToRightRatioAndResize(self.xmlSplitMain);
	else
		self.xmlSplitMain	:= 50;  //cnwjo3 par 22920
	endif;
	if xmlSplitGridArea01 &lt;&gt; null then
		self.sptGridArea01.setLeftToRightRatioAndResize(xmlSplitGridArea01.Integer);
	else
		self.xmlSplitGridArea01	:= 50;   //cnwjo3 par 22920
	endif;

	self.mnuGridHideLegend_click(self.mnuGridHideLegend);

	if not self.xmlMacro then
		self.mnuGridHideMacro.caption := self.MNU_MACRO_SHOW;
	else
		self.mnuGridHideMacro.caption := self.MNU_MACRO_HIDE;
	endif;
	
	self.mnuGridHideMacro_click(self.mnuGridHideMacro); // this reverses the lines above and sets things correctly
	
	self.toolbarStyle := self.ToolbarStyle_ShowNoHide;
	self.showToolbar := true;

	// ####################
	
	if self.myTerminal.getConfig(ShowCargoPicture).Boolean then		
		self.sptBottom.setLeftToRightRatioAndResize(85);		
 	endif;

	self.frmColLegendTIs.visible		:=	true;
	self.btnViewYardAllEd.enabled := false;

	self.setCaption(app.getErrorString(TerminalAreas));
	
	self.doResize();	
	
		
	self.doSwitchSplitterChild();
	self.sptBottom.cnEcResizeContents();
	self.setNavigatorHeading(self.caption);
	self.sptBottom.hideRightControl(true);
	
	// Instand Move mode and Actual Display moed only, so hide menus
	self.frmStatusLine.myFrameMoveMode.visible := false;
	self.frmStatusLine.myFrameDisplayMode.visible := false;


epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setupFormFromAreaSelector" id="0933b005-638a-4fa7-bd72-df26118fd6da">
        <updating/>
        <source>setupFormFromAreaSelector() : Boolean updating, protected;

/*

Purpose:			


Return Value:		


Date		Who		Reason
16 May 2008	cnwkpd1	PAR #16753 - CCMS SFW 1003 - General Cargo Graphical Screens

*/

vars
	anObject	: Object;
	idx			: Integer;
	theCaption	: String;
	
begin
	if self.myCurrentTerminalArea = null then
		app.msgBox(app.getErrorString(Please_Select_Areas), app.getErrorString(Select_Area_Error), MsgBox_OK_Only);
		return false;
	endif;

	self.frmColLegendTIs.myLegendTable.rows := 0;
	idx := 1;

	self.frmModalDialog.visible	:=	false;
	self.frmModalDialog.height	:=	100;
	
	theCaption := self.caption;
	
	self.frmBlockArea.init(self.myCurrentTerminalArea.CM_IrregularBlockArea, false, null, self); 
	self.myDrawingController := self.frmBlockArea.myDrawingController;
	
	self.myDrawingController.setScale(self.xmlZoomFactor, true, true); // PAR 32308

	
	self.drawGridArea();
	
	
	if self.myDrawingController = null 
	or (self.myDrawingController &lt;&gt; null and self.myDrawingController.viewMode = 0) then
		self.btnViewOperator.value := true;
		self.btnViewOperator.click(btnViewOperator);
	endif;
	self.doResize();
	return true;
end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="showAreaSelector" id="36bc0253-ac41-48e6-aa01-220225fee4a5">
        <source>showAreaSelector() protected;

/*

Purpose:			


Return Value:		


Date		Who		Reason
16 May 2008	cnwkpd1	PAR #16753 - CCMS SFW 1003 - General Cargo Graphical Screens

*/

vars
	theFrame : CMUI_MoveableFrame;
	
begin
	theFrame := self.frmSelectAreas;
	
	theFrame.centreHorizontallyInParent();
	theFrame.top := 100;
	
	theFrame.zOrder(1);
	
	if self.myCurrentTerminalArea = null then
		self.cmbSelectedArea.listIndex := -1;
	else
		self.cmbSelectedArea.listIndex := self.cmbSelectedArea.findObject(self.myCurrentTerminalArea);
	endif;
	
	self.showAreaSelectorEnable(true);
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="showAreaSelectorEnable" id="5511c9c6-aa16-4a53-988a-f088491ddd27">
        <source>showAreaSelectorEnable(_enable : Boolean) protected;

/*

Purpose:			


Return Value:		


Date		Who		Reason
16 May 2008	cnwkpd1	PAR #16753 - CCMS SFW 1003 - General Cargo Graphical Screens

*/

begin
	self.frmBlockArea.enabled := not _enable;
	self.frmColLegendTIs.enabled := not _enable;
	self.frmToolbar.enabled := not _enable;
	self.tblGridAreaInfo.enabled := not _enable;
	self.frmSelectAreas.visible := _enable;
end;</source>
        <access>protected</access>
        <Parameter name="_enable" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="showExtraInforForLocation" id="6e2b47bc-3f83-4f24-ab86-3de244f1e89b">
        <updating/>
        <source>showExtraInforForLocation(_location : CM_LocationsController) protected, updating;

/*

Purpose:			


Return Value:		


Date		Who		Reason
22 May 2008	cnwkpd1	PAR #16753 - CCMS SFW 1003 - General Cargo Graphical Screens

*/

vars
	dataContainer		: CM_DataContainer;
	numberOfColumns		: Integer;
	theObject			: Object;
	
begin
	self.tblGridAreaInfo.rows	:=	0;
	numberOfColumns := self.getNumberOfColumns();
	
	if _location &lt;&gt; null then
		self.tblGridAreaInfo.alignment	:=	Table.Alignment_Left_Top;

		// Display Info
		create dataContainer transient;
		dataContainer.headerColour := self.colorHeadingColumn;
		dataContainer.valueColour := self.colorValueColumn;
		_location.getExtraInfo(dataContainer);
		
		self.tblGridAreaInfo.userObject	:= _location;

		self.showExtraInformation(	dataContainer,
									self.tblGridAreaInfo,
									false,
									self.mnuGridBigFont.checked,
									numberOfColumns,
									self.getNumberOfColsForData(),
									self.getNumberOfColsForHeader(),
									self.getNumberOfColsForIcon(),
									self.getNumberOfColsForLabel());
			
		self.doResizeColumnWidths(self.tblGridAreaInfo, true);
	endif;


epilog
	delete dataContainer;
	
end;</source>
        <access>protected</access>
        <Parameter name="_location" type="CM_LocationsController"/>
    </JadeMethod>
    <JadeMethod name="showLocationEnquiryFormBlock" id="7c714974-0aec-48a5-9636-d317c377e6d9">
        <source>showLocationEnquiryFormBlock(_location : CM_LocationsController) protected;

/*

Purpose:			


Return Value:		


Date		Who		Reason
16 May 2008	cnwkpd1	PAR #16753 - CCMS SFW 1003 - General Cargo Graphical Screens

*/

vars
	theLC			: CM_LocationsController;
	menuAction		: CMUI_MenuAction;
	
begin
	if _location = null then
		return;
	endif;
	
	/*05/05/2009 cnwdz2 par18236
	menuAction := app.myController.createMenuAction(PmYardLocationEnqView, null, self.myMasterMenuAction, self.myTerminal);
	
	if menuAction = null then
		return;
	endif;
	*/
	
	self.myAssistant.showLocationEnquiryForm(_location, self.myMasterMenuAction, false, false);

end;</source>
        <access>protected</access>
        <Parameter name="_location" type="CM_LocationsController"/>
    </JadeMethod>
    <JadeMethod name="showSelectedInfo" id="d1a69559-f308-469a-a782-8376f03afc3f">
