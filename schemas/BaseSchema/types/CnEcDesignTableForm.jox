    <JadeMethod name="attributeTable_change" id="3d2b5ef9-1126-4be0-a682-6af472d5068b">
        <controlMethod name="Table::change"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>attributeTable_change(table: Table input) updating;

vars
	heading					: String;
	col						: Integer;
begin
	col := columnTable.column;
	heading := attributeTable.getCellText(attributeTable.row, 1);

	if heading = 'Visible' then
		transientTable.columnVisibleArray[col] := attributeTable.getCellText(attributeTable.row, 2);
		columnTable.accessMode := Table.AccessMode_Column;
		if transientTable.columnVisibleArray[col][1:1] = '0' then
			columnTable.foreColor := Blue;
		else
			columnTable.foreColor := Black;
		endif;
		columnTable.accessMode := Table.AccessMode_Sheet;
	elseif heading = 'Picture' then
		transientTable.columnPictureArray[col] := attributeTable.getCellText(attributeTable.row, 2)[1:1] = '1';
	elseif heading = 'Width' then
		transientTable.columnWidthArray[col] := attributeTable.getCellText(attributeTable.row, 2).Integer;
		columnTable.columnWidth[col] := transientTable.columnWidthArray[col];
	elseif heading = 'Row 1 Height' then
		transientTable.columnHeight := attributeTable.getCellText(attributeTable.row, 2).Integer;
		columnTable.rowHeight[1] := transientTable.columnHeight;
		self.columnTableResize();
	elseif heading = 'Input Type' then
		transientTable.columnInputTypeArray[col] := attributeTable.getCellText(attributeTable.row, 2);
		columnTable.accessMode := Table.AccessMode_Column;
		columnTable.inputType := transientTable.columnInputTypeArray[col][1:1].Integer;
		columnTable.accessMode := Table.AccessMode_Sheet;

		inputControlArray[transientTable.columnInputTypeArray[col].Integer + 1].Button.value := true;

	elseif heading = 'Alignment' then
		transientTable.columnAlignmentArray[col] := attributeTable.getCellText(attributeTable.row, 2);
		columnTable.accessMode := Table.AccessMode_Column;
		columnTable.alignment := transientTable.columnAlignmentArray[col][1:1].Integer;
		columnTable.accessMode := Table.AccessMode_Sheet;

		alignControlArray[transientTable.columnAlignmentArray[col].Integer + 1].Button.value := true;

	elseif heading = 'Length' then
		transientTable.columnLengthArray[col] := attributeTable.getCellText(attributeTable.row, 2).Integer;
		columnTable.accessMode := Table.AccessMode_Column;
		columnTable.maxLength := transientTable.columnLengthArray[col].Integer;
		columnTable.accessMode := Table.AccessMode_Sheet;
	endif;

	columnTable.refresh();
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="bAlignCentreH_click" id="c5aa7d92-d6a4-4729-8000-27172442de6a">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>bAlignCentreH_click(btn: Button input) updating;

begin
	headerAlignmentArray[columnTable.column] := Table.Alignment_Center.String &amp; " - Centre";
	columnTable.row := 1;
	columnTable.accessMode := Table.AccessMode_Cell;
	columnTable.alignment := Table.Alignment_Center;
	columnTable.accessMode := Table.AccessMode_Sheet;

	self.setAlignmentCheckedHeader();
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
