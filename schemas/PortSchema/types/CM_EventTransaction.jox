    <JadeMethod name="getDays" id="8aa62b10-9780-48ec-be50-078a0eff4b10">
        <source>getDays() : Real;
/*****************************************************
Author		: jlika1 (Karen Alexander)
Date		: 20 September 2022
TFS#		: 54850
Function	:

*** Changes ***
Date			Name		TFS#		Description

****************************************************/
vars
	diffTimeStamp 	: Real;
	startTimeStamp	: TimeStamp;
	endTimeStamp	: TimeStamp;
begin
	startTimeStamp 	:= self.getStartTS();
	endTimeStamp	:= self.getEndTS();
	diffTimeStamp	:= startTimeStamp.differenceInHoursReal(endTimeStamp);
	
	return (diffTimeStamp/24).Real;
end;</source>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="getDaysFull" id="62800acf-62cf-48a4-8176-e3f0832a0ea5">
        <source>getDaysFull() : Integer;
/*****************************************************
Author		: jlika1 (Karen Alexander)
Date		: 27 September 2022
TFS#		: 54897
Function	:

*** Changes ***
Date			Name		TFS#		Description

****************************************************/
vars
	diffDays 		: Integer;
	startTimeStamp	: TimeStamp;
	endTimeStamp	: TimeStamp;
begin
	startTimeStamp 	:= self.getStartTS();
	endTimeStamp	:= self.getEndTS();
	diffDays	:= startTimeStamp.differenceInHoursFullDay(endTimeStamp);
	
	return diffDays.Integer;
end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
