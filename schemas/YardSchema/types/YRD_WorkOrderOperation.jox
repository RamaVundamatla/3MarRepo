    <JadeMethod name="buildCmbJobStatus" id="70e77a34-4ad7-428c-8ef1-e3e61354f379">
        <source>buildCmbJobStatus();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 May 2023 navma1  ChangeRequest 57878: EUP - Delivery Dispatch – Screen Design

*/

vars

begin
	self.cmbJobStatus.clear();
	self.cmbJobStatus.addItemObject("", null);
	self.cmbJobStatus.sorted := false;
	
	self.cmbJobStatus.addItemWithData("Job Unactioned",   JOB_UNACTIONED);					//00
	self.cmbJobStatus.addItemWithData("Job Part Complete",JOB_PART_COMPLETE );				//1
	self.cmbJobStatus.addItemWithData("Job Complete",JOB_COMPLETE );						//04
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="buildCmbJobType" id="446ff956-9645-4e7a-b23a-8566067a7233">
        <source>buildCmbJobType();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 May 2023 navma1  ChangeRequest 57878: EUP - Delivery Dispatch – Screen Design
07 Jun 2023 navhl20 ChangeRequest 58543: EUP - Delivery Dispatch – Allocation List - VAS
08 Jun 2023 navhl20 ChangeRequest 57745: EUP - Delivery Dispatch – Allocation List - Road
15 Jun 2023 navhl20 ChangeRequest 57762: EUP - Delivery Dispatch – Un Allocated Pack/UnPack
22 Jun 2023 navhl20 ChangeRequest 57758: EUP - Delivery Dispatch – Un Allocated Rail
03 Oct 2023 navhl20 ChangeRequest 60033: EUP | Ship Operations in DD - [54176.010] - [Receive] Ship Job List 
18 Oct 2023 navhl20 Bug 60931: EUP - Delivery Dispatch Remedial [2]
25 Mar 2025	navhl20 CR MTN-34425: MTN - Removing unnecessary codes from Work Order Operation screen methods.
*/

vars
	mode	: Integer;
	cmb		: CMUI_ComboBox;
begin
	
	cmb := self.cmbJobType;
	
	mode := self.operationModeInt;													//25.03.2025 navhl20 #34425
	
	cmb.clear();
	cmb.addItemObject("", null);
	cmb.sorted := false;
	
	cmb.addItemWithData("Receive",WO_TASK_RECEIVE );				//06
	cmb.addItemWithData("Release",WO_TASK_RELEASE );				//07
	cmb.addItemWithData("Unpack",WO_TASK_UNPACK );					//03
	cmb.addItemWithData("Pack",WO_TASK_PACK );						//02
	cmb.addItemWithData("ToDo Cargo",WO_TASK_TODO );				//08
	cmb.addItemWithData("ToDo Voyage",WO_TASK_ToDo_VOYAGE );		//31
	cmb.addItemWithData("ToDo Truck",WO_TASK_ToDo_TRUCK );			//32
	cmb.addItemWithData("ToDo Train",WO_TASK_ToDo_TRAIN );			//33
	cmb.addItemWithData("ToDo Wagon",WO_TASK_ToDo_WAGON );			//34
	cmb.addItemWithData("ToDo Vehicle Booking",WO_TASK_ToDo_VBS );	//35
	cmb.addItemWithData("ToDo Non Operational",WO_TASK_ToDo_NONOPS);//36
	
	if mode = YRD_WorkOrderOperation.Mode_TODO then									//07.6.2023 navhl20 #58543
		cmb.clear();
		cmb.addItemObject("", null);
		cmb.addItemWithData("ToDo Cargo",WO_TASK_TODO );				//08
		cmb.addItemWithData("ToDo Voyage",WO_TASK_ToDo_VOYAGE );		//31
		cmb.addItemWithData("ToDo Truck",WO_TASK_ToDo_TRUCK );			//32
		cmb.addItemWithData("ToDo Train",WO_TASK_ToDo_TRAIN );			//33
		cmb.addItemWithData("ToDo Wagon",WO_TASK_ToDo_WAGON );			//34
		cmb.addItemWithData("ToDo Vehicle Booking",WO_TASK_ToDo_VBS );	//35
		cmb.addItemWithData("ToDo Non Operational",WO_TASK_ToDo_NONOPS);//36
	endif;
	
	if mode = YRD_WorkOrderOperation.Mode_ROAD or									//08.6.2023 navhl20 #57745 
	mode = YRD_WorkOrderOperation.Mode_RAIL or										//15.6.2023 navhl20 #57758										 
	mode = YRD_WorkOrderOperation.Mode_SHIP then									//03.10.2023 navhl20 #60033									
		cmb.clear();
		cmb.addItemObject("", null);
		cmb.addItemWithData("Receive",WO_TASK_RECEIVE );				//06
		cmb.addItemWithData("Release",WO_TASK_RELEASE );				//07
	endif;
	
	if mode = YRD_WorkOrderOperation.Mode_PACKUNPACK then							//15.6.2023 navhl20 #57762
		cmb.clear();
		cmb.addItemObject("", null);
		cmb.addItemWithData("Unpack",WO_TASK_UNPACK );					//03
		cmb.addItemWithData("Pack",WO_TASK_PACK );						//02
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="buildCmbMode" id="88b3deea-5ce4-49e7-b7c7-854ced69f94f">
        <updating/>
        <source>buildCmbMode()updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 Jun 2023 navma1  ChangeRequest 58339: EUP | Delivery Dispatch Screen - Road Operation
07 Jun 2023 navhl20 ChangeRequest 58543: EUP - Delivery Dispatch – Allocation List - VAS
22 Jun 2023 navhl20 ChangeRequest 57758: EUP - Delivery Dispatch – Un Allocated Rail
03 Oct 2023 navhl20 ChangeRequest 60033: EUP | Ship Operations in DD - [54176.010] - [Receive] Ship Job List
28 Jun 2024 navbs1  CR 64897 Task 64898: UI - Operation Combo add ALL
05 Mar 2025 navbs1	Story MTN-34213: MTN - Work Order Operations screen loading data twice on start-up
20 Mar 2025	navhl20 CR MTN-34425: MTN - Removing unnecessary codes from Work Order Operation screen methods.
*/

vars

begin
	self.cmbMode.clear();
	self.cmbMode.sorted := false;
	
	self.cmbMode.addItemWithData(app.getErrorString(All), YRD_WorkOrderOperation.Mode_ALL );			//03.10.2023 navhl20 #60033  	//28.06.2024 navbs1 CR 64897 Task 64898
	self.cmbMode.addItemWithData(app.getErrorString(WO_Road), YRD_WorkOrderOperation.Mode_ROAD );
	self.cmbMode.addItemWithData(app.getErrorString(WO_Rail), YRD_WorkOrderOperation.Mode_RAIL );		//22.6.2023 navhl20 #57758
	self.cmbMode.addItemWithData(app.getErrorString(WO_Ship), YRD_WorkOrderOperation.Mode_SHIP );		//03.10.2023 navhl20 #60033
	self.cmbMode.addItemWithData(app.getErrorString(WO_PackUnpack), YRD_WorkOrderOperation.Mode_PACKUNPACK );
	self.cmbMode.addItemWithData(app.getErrorString(WO_Todo_task), YRD_WorkOrderOperation.Mode_TODO );
	
	if self.operationMode &lt;&gt; null then												//07.6.2023 navhl20 #58543
		self.cmbMode.listIndex := self.cmbMode.findString(1,self.operationMode);
	else
		self.cmbMode.listIndex := self.cmbMode.findString(1,app.getErrorString(WO_Road));
	endif;
	self.doModeChange(self.cmbMode);												//05.03.2025 navbs1 #34213
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="buildCmbTransport" id="a1cad57a-8e78-4aae-a658-31302408e84e">
        <source>buildCmbTransport(_show : Boolean);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 Oct 2023 navhl20 ChangeRequest 60033: EUP | Ship Operations in DD - [54176.010] - [Receive] Ship Job List 
17 Jun 2024 navhl20 ChangeRequest 64684: EUP - Add new filter criteria in Work Order Operations.
*/

vars
	iter	: Iterator;
	voyage	: CM_Voyage;
	train	: CM_Train;
begin
	if self.lblTransport.caption = "Voyage" then						//17.06.2024 navhl20 #64684
		iter := self.myTerminal.allVoyagesByCode.createIterator;
		
		self.cmbTransport.clear;
		
		self.cmbTransport.addItemObject("", null);

		while iter.next(voyage) do
			if _show then
				if not voyage.isCurrentOnPort() then
					continue;
				endif;
			endif;
			self.cmbTransport.addItemObject(voyage.code &amp; Tab &amp; voyage.description, voyage);
		endwhile; 
	elseif self.lblTransport.caption = "Train" then						//17.06.2024 navhl20 #64684
		iter := self.myTerminal.allTrainsOnTerminal.createIterator;
		
		self.cmbTransport.clear;
		
		self.cmbTransport.addItemObject("", null);

		while iter.next(train) do
			self.cmbTransport.addItemObject(train.code &amp; Tab &amp; train.description, train);
		endwhile; 
	endif;
epilog
	delete iter;
end;</source>
        <Parameter name="_show" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="buildCmbTruckStatus" id="9de8d755-e6a2-44d1-a5e9-9dcd128953ab">
