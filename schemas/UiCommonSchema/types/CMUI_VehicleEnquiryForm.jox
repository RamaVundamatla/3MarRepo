    <JadeMethod name="doDelete" id="9235879b-6c3a-4375-9021-7a7b2f43aca6">
        <updating/>
        <source>doDelete(): Boolean updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 November 2017	jlgndl1	Initial creation	TFS 7216

*/

vars

	vehicle : CM_Vehicle;
	obj : Object;
	theResult : Integer;	//14 Jan 2020 NDL	TFS 46815

begin
	
	vehicle := self.myCurrentObject.CM_Vehicle;
	if vehicle = null then
		return false;
	endif;
	
	//14 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
	while true do
	
		if self.tblData.allSelectedObjects.size &gt; 1 then	
			app.myTrxDA.trxDeleteVehicles( self.tblData.allSelectedObjects, app.myPassport );
		else
			app.myTrxDA.trxDeleteVehicle( vehicle, app.myPassport );	
		endif;
	
		if app.myPassport.trxCompletedOK then
			break;
		else
			theResult := app.showErrorWarningDialog('Booking', app.myPassport, ErrWarnMode_Delete);
			if app.myPassport.noErrors and theResult = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		
		return false;
		
	endwhile;
	
	return true;

epilog
	
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doMnuFormContextMenu" id="309e60a6-ca6e-4ba9-9087-cc2c5701283c">
        <updating/>
        <source>doMnuFormContextMenu(conwin: Window input; mouse: Boolean; x: Integer; y: Integer): Boolean updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 November 2017	jlgndl1	Initial creation	TFS 7216

*/

vars
	tmpMenu : MenuItem;
	truck : CM_Vehicle;
	weighable : Boolean;
	errMsg : String;	//08 Jan 2018	NDL	TFS 36437
	
begin

	truck := self.myCurrentObject.CM_Vehicle;
	weighable := truck &lt;&gt; null and truck.isWeighBridgeWeighable( null, errMsg );
	
	self.mnuWeighVehicle.visible := weighable;
	self.mnuWeighVehicle.caption := app.getErrorString(Weigh_vehicle);
	
	self.zCloneMenu( self.mnuTblVCloneDataTbl, self.mnuWeighVehicle, false );
	self.zCloneMenu( tmpMenu, self.mnuWeighVehicle, true );
	
	return inheritMethod( conwin, mouse, x, y );
	
epilog
	
end;</source>
        <Parameter name="conwin" type="Window" usage="input"/>
        <Parameter name="mouse" type="Boolean"/>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doSave" id="d4db6ae1-a207-4c08-bf0b-c8162d0e6ff7">
        <updating/>
        <source>doSave(): Boolean updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
31 October 2017	jlgndl1	Initial creation	TFS 7216

*/

vars

	tareKilos : Decimal [16,4];
	rtnValue : Boolean;
	isNotAvailableForEntry : Boolean;
	proxyVehicle : CM_Vehicle;
	lRegNumber : String;
	lCarrier : CM_Carrier;	
	state : String;
	maxGrossLadenWeight : Decimal [16,4];
	numItems: Integer;
	breakOut: Boolean;
	result : Integer;
	
begin
  	
	lRegNumber := self.tblInput1.getValueByName(ETRow_RegNumber).String;
	lCarrier := self.cmbCarrier.listObject.CM_Carrier;
	tareKilos := self.getConvertedDisplayValue( ETRow_TareKilos, self.weightType ).Integer;
	maxGrossLadenWeight := self.getConvertedDisplayValue( ETRow_MaxGrossLadenWeight, self.weightType ).Integer;
	isNotAvailableForEntry := self.tblInput1.getValueByName(ETRow_IsNotAvailableForEntry).Boolean;
	state := self.tblInput1.getValueByName(ETRow_State).String;
	
	if self.myProxyObject = null then
		if self.mode = self.Mode_Add then
			create self.myProxyObject as CM_Vehicle transient;
		else
			app.raiseUnexpectedProgramError(class.name, method.name, 'Proxy object is null for update');
			return false;
		endif;
	endif;

	proxyVehicle := self.myProxyObject.CM_Vehicle;
	proxyVehicle.setProxy( lRegNumber, null, tareKilos, maxGrossLadenWeight, lCarrier, state, isNotAvailableForEntry, self.myTerminal);

	while true do
	
		if self.mode = self.Mode_Add then
			app.myTrxCA.trxCreateVehicle(proxyVehicle, self.myCurrentObject, app.myPassport);	
		elseif self.mode = self.Mode_Update then
			app.myTrxUA.trxUpdateVehicle(proxyVehicle, app.myPassport);
		else
			app.raiseUnexpectedProgramError(class.name, method.name, '  Invalid mode (' &amp; self.mode.String &amp; ')');
			return false;	
		endif;
			
		if app.myPassport.trxCompletedOK then

			return true;
		else
			result := app.showErrorWarningDialog('Booking', app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors 
			and   result = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		return false;
	endwhile;
	
	return false;

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getWeighFormObjects" id="cc0a49f8-5c3d-41be-90de-7708852e9752">
        <source>getWeighFormObjects(_obj: CM_Object; _objArray: ObjectArray input): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 November 2017	jlgndl1	Initial creation	TFS 7216

*/

vars

begin

	if _obj &lt;&gt; null then
		_objArray.addExclusive( _obj ); //wil be just a vehicle
	endif;
	
	return true;

epilog

end;</source>
        <Parameter name="_obj" type="CM_Object"/>
        <Parameter name="_objArray" type="ObjectArray" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="includeObject" id="ff028b37-a433-42e6-ae4a-64ba94b495b8">
        <updating/>
        <source>includeObject(_vehicle: CM_Vehicle; _passport: CM_Passport): Boolean updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
31 October 2017	jlgndl1	Initial creation	TFS 7216

*/

vars

begin

	
	
	if self.filterState &lt;&gt; null then
		if _vehicle.state &lt;&gt; self.filterState then
			return false;
		endif;
	endif;
	
	if self.myFilterCarrier &lt;&gt; null then
		if _vehicle.carrier &lt;&gt; self.myFilterCarrier then
			return false;
		endif;
	endif;
	
	if self.filterNA = 0 then
		//Inlcude Not available ONLY
		if not _vehicle.isNotAvailableForEntry then
			return false;
		endif;
	elseif self.filterNA = 1 then
		//Include Available ONLY
		if _vehicle.isNotAvailableForEntry then
			return false;
		endif;
	endif;
	
	if self.filterRegNo &lt;&gt; null then
		if _vehicle.regNumber[1 : self.filterRegNo.length] &lt;&gt; self.filterRegNo then
			return false;
		endif;
	endif;
	
	return true;

epilog

end;</source>
        <Parameter name="_vehicle" type="CM_Vehicle"/>
        <Parameter name="_passport" type="CM_Passport"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
