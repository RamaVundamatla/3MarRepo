    <JadeMethod name="validateForCreate" id="30097471-9ba1-4fe7-a1c9-948baf3d72d4">
        <source>validateForCreate();
// ---------------------------------------------------------------------------
// Created:		August 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// 08/12/2014 cnwdb2	PAR 35364 
// ---------------------------------------------------------------------------

vars
	theBank : CM_Bank;
begin
	theBank := app.myRoot.myRootCompany;
	
	// cnwrl1 06/11/2009 PAR 19278 - start of coding
	if self.description = null then
	//	app.raiseCMException1( REQUIRED_FIELD, app.getString( Description ), self.description, null );
		app.raiseCMException1( Input_required_field_Required, app.getString( Description ), self.description, null ); // cnwdb2	PAR 35364
	endif;
	
	// cnwrl1 06/11/2009 PAR 19278 - end of coding
	if theBank.allFinancialPeriods[self.description] &lt;&gt; null then
	//	app.raiseCMException3(ERR_DUPLICATE_KEY,"Financial Period Type", self.description,"It must be unique.", null,null);
		app.raiseCMException1(Already_exists_fincPeriod, self.description, null,null); //cnwdb2	PAR 35364

	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="validateForDelete" id="d76b6b8c-6e0f-4a15-bb7f-3199f815820c">
        <source>validateForDelete();
// ---------------------------------------------------------------------------
// Created:		August 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	inv : CM_InvoiceDesc;
	list : String;
	debtor : CM_DebtorNode;
begin
	if self.isDefault then
		app.raiseCMException1(ERR_FP_IsDefault, self.description,null,null);
	endif;
	
	// ### INVOICE TYPES
	if not self.allInvoiceDesc.isEmpty then
		foreach inv in self.allInvoiceDesc discreteLock do
			if list = "" then
				list := inv.description;
			else
				list := list &amp; ", " &amp; inv.description;
			endif;
		endforeach;
		
		if list &lt;&gt; "" then
			app.raiseCMException2(Finan_perio_canno_delet_invoi_, self.description, list,null,null);
		endif;
	
	endif;
	
	// ### DEBTORS
	list := "";
	if not self.allDebtors.isEmpty then
		foreach debtor in self.allDebtors discreteLock do
			if list = "" then
				list := debtor.name;
			else
				list := debtor.name &amp; ", " &amp; debtor.name;
			endif;
		endforeach;
		
		if list &lt;&gt; "" then
			app.raiseCMException2(Financ_period_cannot_delete_de, self.description, list,null,null);
		endif;
	
	endif;
	
	
	
end;</source>
    </JadeMethod>
