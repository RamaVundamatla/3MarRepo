    <JadeMethod name="setForUpdate" id="5ec22249-abf5-414e-81f0-cc76118e8c5d">
        <updating/>
        <source>setForUpdate(_pxyExemptCert : HMS_PilotExemptionCertificate; _passport : CM_Passport input) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
26 April 2012	cnwndl1	Initial creation	Par 29496

*/

vars

begin

	inheritMethod(_pxyExemptCert, _passport);
	
	self.certifiedDate := _pxyExemptCert.certifiedDate;
	self.expiryDate := _pxyExemptCert.expiryDate;
	self.revalidationDate := _pxyExemptCert.revalidationDate;
	self.myVessel := _pxyExemptCert.myVessel;
	self.myHarbour := _pxyExemptCert.myHarbour;
	self.myValidatedBy := _pxyExemptCert.myValidatedBy;
	self.myMaster := _pxyExemptCert.myMaster;

epilog

end;</source>
        <Parameter name="_pxyExemptCert" type="HMS_PilotExemptionCertificate"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="2111b4ab-666a-422b-a827-67b52866ddb1">
        <updating/>
        <source>setProxy(	_certifiedDate : Date;
			_expiryDate : Date;
			_revalidationDate : Date;
			_myVessel : CM_Vessel;
			_myValidatedBy : HMS_Pilot;
			_myHarbour : HMS_Harbour;
			_myMaster : HMS_Master
			) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
26 April 2012	cnwndl1	Initial creation	Par 29496

*/

vars

begin

	self.certifiedDate := _certifiedDate;
	self.expiryDate := _expiryDate;
	self.revalidationDate := _revalidationDate;
	self.myVessel := _myVessel;
	self.myValidatedBy := _myValidatedBy;
	self.myHarbour := _myHarbour;
	self.myMaster := _myMaster;

epilog

end;</source>
        <Parameter name="_certifiedDate" type="Date"/>
        <Parameter name="_expiryDate" type="Date"/>
        <Parameter name="_revalidationDate" type="Date"/>
        <Parameter name="_myVessel" type="CM_Vessel"/>
        <Parameter name="_myValidatedBy" type="HMS_Pilot"/>
        <Parameter name="_myHarbour" type="HMS_Harbour"/>
        <Parameter name="_myMaster" type="HMS_Master"/>
    </JadeMethod>
