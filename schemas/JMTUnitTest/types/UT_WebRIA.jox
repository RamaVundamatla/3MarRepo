<Class name="UT_WebRIA" id="c6d95f74-6fd3-4a5e-844f-740a5089e1d8">
    <superclass name="UT_DSL"/>
    <transient/>
    <sharedTransientAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="unitTest"/>
    <JadeMethod name="assignedTeam" id="3658e6f9-65ce-47a0-a73a-c5228dfbbfa5">
        <options>4</options>
        <source>assignedTeam(): String typeMethod;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 March 2025	navsp1	Initial creation JIRA-34202

*/

