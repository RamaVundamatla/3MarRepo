    <JadeMethod name="setupThumbnailDetails" id="bb5cf579-4b69-4e53-964b-d9acd7eec5ae">
        <updating/>
        <source>setupThumbnailDetails() updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 08/03/2018	jlgdap1		Initial creation TFS 37427 PEL1 Voyage Status Enhancements
//
vars
	form : SOP_TableMaintForm;

begin
	form := self.myForm;
	form.useProxyObject := true;
	form.setTblDataEntRows(ETDef_VoyageStatusDetail);
	form.shtTblInput1.caption := app.getErrorString(Details);
	form.initTblInput(form.tblInput1, ETDef_VoyageStatusThumb);
	form.shtTblInput1.visible := true;
epilog

end;</source>
