    <JadeMethod name="hasRateHookCode" id="33c44c93-54f6-45b4-97f7-8c9cce0243b1">
        <source>hasRateHookCode() : Boolean;
// 24024 added for reporting
vars
	result	: Boolean;
begin
	if self.service &lt;&gt; null and
	   self.service.myCalculationType &lt;&gt; null and
	   self.service.myCalculationType.myHookCodeRate &lt;&gt; null then
		result := true;
	endif;
	return result;
end;
</source>
