    <JadeMethod name="getCurrentLengthOfTime" id="ef578bd4-3b2c-4173-a7d1-90b65fd6e660">
        <source>getCurrentLengthOfTime(): Decimal;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
13 December 2018	jlgndl1	Initial creation	TFS 42501
// 19 Dec 2018	NDL	TFS Protect against deleted Workpoint object

*/

vars

	lengthOfTime : Decimal[12,2];
	wodCargoRequest : CM_WodCargoRequest;
	workPoint : CM_WorkPoint;
	daysToComplete : Decimal[6,2];
	wpRate : CM_WorkPointCargoRates;
	dummyTi : CM_TrackedItem;
	gangs : Integer;
	holdId : String;
	
	holdValueArray : DecimalArray;
	holdIdArray : StringArray;
	index : Integer;
	roundedTotal : Decimal[6,2];
	longestDays : Decimal[6,2];
	incrementForCargo : Decimal[5,2];


begin
	
	lengthOfTime := inheritMethod();
	if lengthOfTime &gt; 0 then
		return lengthOfTime;
	endif;
	
	if not self.isAdditionalCargo then
		return 0.0;
	endif;
	
	//dummy it up based on the set rules from the ETMAL form.
	create holdValueArray transient;
	create holdIdArray transient;
	
	//iterate thru getting into total elapsed value by hold.
	foreach wodCargoRequest in self.allCargoDetails do
		daysToComplete := 0.00;
		holdId := wodCargoRequest.getHoldId();
		workPoint := wodCargoRequest.getMyWorkPoint;
		gangs := wodCargoRequest.numGangs;
		if workPoint &lt;&gt; null then
			wpRate := workPoint.getDefinedTargetRate( wodCargoRequest, null, dummyTi );
			if wpRate &lt;&gt; null then
				daysToComplete := wpRate.getDaysToComplete( wodCargoRequest, gangs, false );
			endif;
		endif;
		
		if holdIdArray.includes( holdId ) then
			index := holdIdArray.indexOf( holdId );
		else
			holdValueArray.add(0.00);
			holdIdArray.add(holdId);
			index := holdIdArray.size;
		endif;
		
		holdValueArray[ index ] := holdValueArray[ index ] + daysToComplete;
		
	endforeach;
	
	//now round up each hold value based on the terminals config 'TotDaysReqRoundedToHours'
	if not holdValueArray.isEmpty then
		foreach index in 1 to holdValueArray.size do
			roundedTotal := self.getMyTerminal.applyRoundingToValue( holdValueArray[ index ] );
			holdValueArray[ index ] := roundedTotal;
		endforeach;
	endif;

	//get the longest one and add the increment
	if not holdValueArray.isEmpty then
		foreach index in 1 to holdValueArray.size do
			daysToComplete := holdValueArray[ index ];
			if daysToComplete &gt; 0 then
				if longestDays &lt; daysToComplete then
					longestDays := daysToComplete; 
				endif;
			endif;
		endforeach;
	
		incrementForCargo := self.getMyTerminal.getConfig( TotDaysReqAddForCargo ).Decimal;
		longestDays := longestDays + incrementForCargo; 
	
	endif;

	return longestDays;

epilog

	delete holdValueArray;
	delete holdIdArray;
	
end;</source>
        <ReturnType type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="getDisplayString" id="a909d6ec-8718-45fe-8147-a68008693a6c">
        <source>getDisplayString(_useShortDesc: Boolean): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 Oct 2018	jlger1	Initial creation 41310
29 Sep 2021 navma1  ChangeRequest 51925: SAL - Web Portal Cargo Work Orders
*/

vars
	description : String;
	typeDesc    : String;
begin
	typeDesc := self.getTypeDescription();							   //29.09.2021 navma1 #51925
	
	if _useShortDesc then
		return typeDesc;
	endif;
	
	description:= typeDesc &amp; " - " &amp; app.workOrderPermitsString(self.permitType); 												 //29.09.2021 navma1 #51925

	if permitDetailType = WO_TASK_EXTENSION then
		description := description &amp; " " &amp; app.myRoot.getWorkOrderTaskDescByType(WorkOrderMode_Voyage,WO_TASK_EXTENSION);		 //29.09.2021 navma1 #51925
	elseif permitDetailType = WO_TASK_SHIFTMOVEMENT then
		description := description &amp; " " &amp; app.myRoot.getWorkOrderTaskDescByType(WorkOrderMode_Voyage,WO_TASK_SHIFTMOVEMENT);    //29.09.2021 navma1 #51925   
	elseif permitDetailType = WO_TASK_MARINEINITIAL then
		description := description &amp; " " &amp;  app.myRoot.getWorkOrderTaskDescByType(WorkOrderMode_Voyage,WO_TASK_MARINEINITIAL);   //29.09.2021 navma1 #51925
	endif;
		
	
	
	return description;
epilog

end;</source>
        <Parameter name="_useShortDesc" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
