    <JadeMethod name="validateId" id="a0defd6a-7c47-427f-b67a-c9059bf2997b">
        <source>validateId(_realTerminalAreaMaster : CM_TerminalAreaMaster) protected;
//	Feb 2014 from 33418, with terminal area-specific code.
//	'self' is the proxy to create or update from.
vars
	oldId,
	newId	: String;
	lcArray	: ObjectArray;
	term	: CM_Terminal;

begin
	inheritMethod(_realTerminalAreaMaster);

	term := self.myTerminal;
	newId := self.id.trimBlanks().toUpper();
	if _realTerminalAreaMaster &lt;&gt; null then
		oldId := _realTerminalAreaMaster.id;
	endif;

	// do these checks for add or create, if id has changed or not.
	// 5 Sep 2008	cnwdz2	Par17858 a terminal area is not allowed to have the same id as a vehicle.
	if term.vehicles[newId, ""] &lt;&gt; null then
		app.raiseCMException3(ERR_DUPLICATE_TA_VEHICLE_ID, term.code, newId, self.typeString, null, null);
	endif;
	// or a machine
	if term.machines[newId] &lt;&gt; null then
		app.raiseCMException2(ERR_INVALID_VALUE, "Terminal Area ID ", "It is in use as a Machine ID", null, null);
	endif;
	
	// if id has changed, don't allow if there is cargo (which needs the CM_TrackedItem.locationId updated and possibly more ...)
	if _realTerminalAreaMaster &lt;&gt; null and
	   _realTerminalAreaMaster.isKindOf(CM_TerminalArea) and
	   newId &lt;&gt; oldId then
		create lcArray transient;
		_realTerminalAreaMaster.CM_TerminalArea.getAllLCsWithCargo(lcArray);
		if lcArray.size &gt; 0 then
			app.raiseCMException(Cannot_change_term_area_id, null, null);
		endif;
	endif;
	
epilog
	delete lcArray;
end;</source>
        <access>protected</access>
        <Parameter name="_realTerminalAreaMaster" type="CM_TerminalAreaMaster"/>
    </JadeMethod>
