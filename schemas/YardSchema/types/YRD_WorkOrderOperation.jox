    <JadeMethod name="doPermissionsCheck" id="03039c0f-11b6-4234-8aa2-78de9961e778">
        <source>doPermissionsCheck();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 Sep 2024	navnk30	Bug 66107: MTN | Work Order Operations Permissions

*/

vars

begin
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		self.mnuAddJobSheet.enabled := false;
		self.mnuAllocateJobSheet.enabled := false;
		self.mnuRetroDT.enabled := false;
