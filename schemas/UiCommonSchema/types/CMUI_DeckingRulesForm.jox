    <JadeMethod name="addItemToListAt" id="9e551859-c252-479a-972b-ffe64fe34a96">
        <source>addItemToListAt(_idx: Integer; _yaLocnCellItem: CM_YALocationCell);
//----------------------------------------------------------------
//	Created:	24 April 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin

	if self.chkShowHeights.value then
		self.lstDeckingLocns.addItemAt(_yaLocnCellItem.getListDisplayWithHeight,_idx);
	else
		self.lstDeckingLocns.addItemAt(_yaLocnCellItem.getListDisplay,_idx);
	endif;
	self.lstDeckingLocns.itemObject[_idx] := _yaLocnCellItem;
	if self.myMarkerLocnCell = _yaLocnCellItem then
		self.lstDeckingLocns.itemBackColor[_idx] := Red;	
	endif;


end;</source>
        <Parameter name="_idx" type="Integer"/>
        <Parameter name="_yaLocnCellItem" type="CM_YALocationCell"/>
    </JadeMethod>
    <JadeMethod name="addToTableExHandler" id="ecf4c582-aa7c-4089-b9dd-479847a54201">
        <source>addToTableExHandler(_exObj: Exception):Integer;
//----------------------------------------------------------------
//	Created:	27 April 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin
	if _exObj.errorCode = 1310 then
		//dup key for the rule
		app.msgBox(app.getErrorString(DeckignRuleExists), app.getErrorString(Warning), MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
		return Ex_Abort_Action;
	else
		return Ex_Pass_Back;
	endif;

end;</source>
        <Parameter name="_exObj" type="Exception"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="addToolbarControls" id="8c66cfb5-ec0c-41b5-a315-72f73f2bf896">
        <updating/>
        <source>addToolbarControls() updating, protected;
//----------------------------------------------------------------
//	Created:	21 April 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	toolbar			: CMUI_Toolbar;
begin
	inheritMethod();
	
	toolbar := self.frmToolbar;
	toolbar.addButton(self.btnSaveBase, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnCancelBase, CMUI_Toolbar.Control_Alignment_Right);
	toolbar.showCaptions := false;
	toolbar.visible := true;

	//custom frame	
	toolbar := self.frmCustomToolbar;
	toolbar.addButton(self.btnCustomSave, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnRevSelection, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnMark, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnMoveToMarker, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addFrame(self.frmToolbarCtrl, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnCustomCancel, CMUI_Toolbar.Control_Alignment_Right);

	toolbar.positionToolbarControls();
	toolbar.showCaptions := false;
	toolbar.visible := true;
	

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="btnCustomCancelClick" id="389d5e29-0d76-43fb-b8be-fdbe053ebdab">
        <source>btnCustomCancelClick();
//----------------------------------------------------------------
//	Created:	21 April 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin

	if self.customOrderHasChanged 
	and app.msgBox(app.getErrorString(UnsavedChangesWillBeLost) &amp; CrLf &amp; app.getErrorString(AreYouSure), app.getErrorString(Warning), MsgBox_Yes_No + MsgBox_Exclamation_Mark_Icon) = MsgBox_Return_No then
		return;
	endif;

	self.enableFormCustomClose();
	self.frmCustomSetting.visible := false;

end;</source>
    </JadeMethod>
    <JadeMethod name="btnCustomCancel_click" id="56f75b10-c0e7-4129-b11a-e8119f239477">
