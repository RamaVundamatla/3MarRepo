    <JadeMethod name="copyDirectory" id="87e645ca-bb28-43eb-935b-3fea88b2fbc6">
        <updating/>
        <source>copyDirectory(pSourcePath:String; pTargetPath:String; pNodeOptions:Integer):Boolean updating;
// --------------------------------------------------------------------------------
// Created:		09 July 2002 by cnwdad2
//
// Purpose:		Copies the specified directory into the requested destination path.
//
// Parameters:	pSourcePath - The original directory to copy.
//				pTargetPath - The destination path to copy the directory into.
//				pNodeOptions - Specifies the source and target JADE nodes.
//
// Returns:		True if the operation succeeded, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	sourceNode	: Integer;
	targetNode	: Integer;
	
begin
	on Exception do self.xHandler(exception);
	
	self.doFileErrorSet(0, null);
	
	if self.interpretNodeOptions(pNodeOptions, sourceNode, targetNode) then
		if sourceNode = JSSFMFileManagerService.NODE_SOURCE_CLIENT then
			return self.copyDiskDirectoryClient(pSourcePath, pTargetPath, sourceNode, targetNode);
		elseif sourceNode = JSSFMFileManagerService.NODE_SOURCE_APPSERVER then
			return self.copyDiskDirectoryAppServer(pSourcePath, pTargetPath, sourceNode, targetNode);
		elseif sourceNode = JSSFMFileManagerService.NODE_SOURCE_DBSERVER then
			return self.copyDiskDirectoryDbServer(pSourcePath, pTargetPath, sourceNode, targetNode);
		endif;
	endif;
epilog
	on Exception do null;
	
	self.doFileErrorCheck();
end;</source>
        <Parameter name="pSourcePath" type="String"/>
        <Parameter name="pTargetPath" type="String"/>
        <Parameter name="pNodeOptions" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="copyDiskDirectory" id="d52ebd44-8d99-4fc1-8115-7ecbbd0cda46">
        <updating/>
        <source>copyDiskDirectory(	pSourcePath:String;
					pTargetPath:String;
					pSourceNode:Integer;
					pTargetNode:Integer;
					pIsPresentationFileSystem:Boolean):Boolean updating, protected;
// --------------------------------------------------------------------------------
// Created:		03 July 2002 by cnwdad1
//
// Purpose:		Copies a disk directory to a new location.
//
// Parameters:	pSourcePath - The original directory to copy.
//				pTargetPath - The target path to copy the directory to.
//				pSourceNode - Specifies the source JADE node.
//				pTargetNode - Specifies the target JADE node.
//				pIsPresentationFileSystem - For thin client nodes, this flag indicates
//					whether to use the thin client's own file system rather than the
//					Application Server node's file system.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	diskFolderObj	: FileFolder;
	theDiskNode		: FileNode;
	destinationPath	: String;
	destinationNode	: String;
	nodeName		: String;
	returnValue		: Boolean;
	
begin
	returnValue				:=	false;
	create diskFolderObj transient;
	diskFolderObj.usePresentationFileSystem	:=	pIsPresentationFileSystem;
	diskFolderObj.fileName	:=	pSourcePath;
	
	nodeName		:=	pSourcePath[pSourcePath.reversePos(JSS_SEPARATOR_WIN):end];
	destinationPath	:=	pTargetPath;
	
	if pTargetNode = JSSFMFileManagerService.NODE_TARGET_CLIENT then
		returnValue	:=	self.createDiskDirectoryClient(destinationPath);
	elseif pTargetNode = JSSFMFileManagerService.NODE_TARGET_APPSERVER then
		returnValue	:=	self.createDiskDirectoryAppServer(destinationPath);
	elseif pTargetNode = JSSFMFileManagerService.NODE_TARGET_DBSERVER then
		returnValue	:=	self.createDiskDirectoryDbServer(destinationPath);
	endif;
	
	if returnValue and self.errorCode = 0 then
		foreach theDiskNode in diskFolderObj.files() do
			theDiskNode.usePresentationFileSystem	:=	theDiskNode.usePresentationFileSystem;
			
			if theDiskNode.isKindOf(FileFolder) then
				destinationNode	:=	destinationPath &amp; JSS_SEPARATOR_WIN &amp; theDiskNode.name;
				
				if self.copyDiskDirectory(theDiskNode.fileName, destinationNode, pSourceNode, pTargetNode, pIsPresentationFileSystem) then
					returnValue	:=	true;
				endif;
			else
				destinationNode	:=	destinationPath &amp; JSS_SEPARATOR_WIN &amp; theDiskNode.name;
				
				if self.copyDiskFile(theDiskNode.fileName, destinationNode, pSourceNode, pTargetNode) then
					returnValue	:=	true;
				endif;
			endif;
			
			if self.isCancelled then
				break;
			elseif self.errorCode &lt;&gt; 0 then
				returnValue	:=	false;
				return returnValue;
			endif;
		endforeach;
	else
		returnValue	:=	false;
	endif;
epilog
	delete diskFolderObj;
	
	return returnValue;
end;</source>
        <access>protected</access>
        <Parameter name="pSourcePath" type="String"/>
        <Parameter name="pTargetPath" type="String"/>
        <Parameter name="pSourceNode" type="Integer"/>
        <Parameter name="pTargetNode" type="Integer"/>
        <Parameter name="pIsPresentationFileSystem" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="copyDiskDirectoryAppServer" id="690ba039-e431-48fb-80ed-c4d759045a59">
        <updating/>
        <executionLocation>client</executionLocation>
        <source>copyDiskDirectoryAppServer(pSourcePath:String; pTargetPath:String; pSourceNode:Integer; pTargetNode:Integer):Boolean updating, protected, clientExecution;
// --------------------------------------------------------------------------------
// Created:		09 July 2002 by cnwdad2
//
// Purpose:		AppServer node wrapper for the copyDiskDirectory method.
// --------------------------------------------------------------------------------
constants
	IS_PRESENTATION_FILE_SYSTEM	: Boolean = false;
	
begin
	return self.copyDiskDirectory(	pSourcePath,
									pTargetPath,
									pSourceNode,
									pTargetNode,
									IS_PRESENTATION_FILE_SYSTEM);
end;</source>
        <access>protected</access>
        <Parameter name="pSourcePath" type="String"/>
        <Parameter name="pTargetPath" type="String"/>
        <Parameter name="pSourceNode" type="Integer"/>
        <Parameter name="pTargetNode" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="copyDiskDirectoryClient" id="c8e18a6c-c21b-43a1-912e-a794fe6e3596">
        <updating/>
        <executionLocation>client</executionLocation>
        <source>copyDiskDirectoryClient(pSourcePath:String; pTargetPath:String; pSourceNode:Integer; pTargetNode:Integer):Boolean updating, protected, clientExecution;
// --------------------------------------------------------------------------------
// Created:		09 July 2002 by cnwdad2
//
// Purpose:		Client node wrapper for the copyDiskDirectory method.
// --------------------------------------------------------------------------------
begin
	return self.copyDiskDirectory(	pSourcePath,
									pTargetPath,
									pSourceNode,
									pTargetNode,
									process.isUsingThinClient());
end;</source>
        <access>protected</access>
        <Parameter name="pSourcePath" type="String"/>
        <Parameter name="pTargetPath" type="String"/>
        <Parameter name="pSourceNode" type="Integer"/>
        <Parameter name="pTargetNode" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="copyDiskDirectoryDbServer" id="ef5b6df2-30a0-4502-ae66-e501290734fe">
        <updating/>
        <executionLocation>server</executionLocation>
        <source>copyDiskDirectoryDbServer(pSourcePath:String; pTargetPath:String; pSourceNode:Integer; pTargetNode:Integer):Boolean updating, protected, serverExecution;
// --------------------------------------------------------------------------------
// Created:		09 July 2002 by cnwdad2
//
// Purpose:		Database Server node wrapper for the copyDiskDirectory method.
// --------------------------------------------------------------------------------
constants
	IS_PRESENTATION_FILE_SYSTEM	: Boolean = false;
	
begin
	on Exception do self.xHandlerServer(exception);
	
	return self.copyDiskDirectory(	pSourcePath,
									pTargetPath,
									pSourceNode,
									pTargetNode,
									IS_PRESENTATION_FILE_SYSTEM);
end;</source>
        <access>protected</access>
        <Parameter name="pSourcePath" type="String"/>
        <Parameter name="pTargetPath" type="String"/>
        <Parameter name="pSourceNode" type="Integer"/>
        <Parameter name="pTargetNode" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="copyDiskFile" id="f5cdb454-7027-477e-a200-2447c9cefa84">
        <updating/>
        <source>copyDiskFile(pPathName:String; pTargetPath:String; pSourceNode:Integer; pTargetNode:Integer):Boolean updating, protected;
// --------------------------------------------------------------------------------
// Created:		08 July 2002 by cnwdad2
//
// Purpose:		Copies a disk file to a new location.
//
// Parameters:	pPathName - The original source file.
//				pTargetPath - The location path of the copied file.
//				pSourceNode - Specifies the source JADE node.
//				pTargetNode - Specifies the target JADE node.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 08/08/2002	cnwdad1		Added a check for the size of the file being copied. If
//							the file has a length of zero, then the target file will
//							be opened, but we won't bother reading the source file
//							and writing to the target file.
//
// 17/10/2002	cnwdad1		Added a temporary patch to circumvent a problem where the
//							File:fileLength() method returns -ve values for files &gt;
//							2,147,483,647 bytes.  This patch will be removed when the
//							issue has been resolved in JADE.
//
// 13/12/2004	cnwdad1		Changed so that allo of the cleanup stuff is done in the
//							epilog so that it'll still get done even if there's an
//							exception.
// --------------------------------------------------------------------------------
vars
	theSourceDiskFile	: File;
	theTargetDiskFile	: File;
	fileOffset			: Decimal[23];
	fileLength			: Decimal[23];
	fileData			: Binary;
	isCompressionUsed	: Boolean;
	deleteNode			: Integer;
	theProgressForm		: JSSFMProgressForm;
	isForUpdate			: Boolean;
	nameOfSource		: String;
	nameOfTarget		: String;
	nameOfFile			: String;
	returnValue			: Boolean;
	
begin
	// Check whether we can use compression.  Note that if the file is being copied
	// to or from a Thin Client, then we can't use compression because the compress/
	// uncompress routines cannot execute on the Thin Client, however the JADE RPC
	// calls will be compressed by JADE anyway if the appropriate INI File settings
	// are configured.
	
	if pSourceNode = JSSFMFileManagerService.NODE_SOURCE_CLIENT
	or pTargetNode = JSSFMFileManagerService.NODE_TARGET_CLIENT
	then
		isCompressionUsed	:=	(not process.isUsingThinClient());
	else
		isCompressionUsed	:=	true;
	endif;
	
	// Open the disk file objects, on the relevent nodes.
	
	isForUpdate	:=	false;
	
	if pSourceNode = JSSFMFileManagerService.NODE_SOURCE_CLIENT then
		fileLength	:=	self.openDiskFileClient(pPathName, isForUpdate, theSourceDiskFile);
	elseif pSourceNode = JSSFMFileManagerService.NODE_SOURCE_APPSERVER then
		fileLength	:=	self.openDiskFileAppServer(pPathName, isForUpdate, theSourceDiskFile);
	elseif pSourceNode = JSSFMFileManagerService.NODE_SOURCE_DBSERVER then
		fileLength	:=	self.openDiskFileDbServer(pPathName, isForUpdate, theSourceDiskFile);
	endif;
	
//// cnwdad1 - Temporary patch to circumvent a problem where the File:fileLength() method returns
//// -ve values for files &gt; 2,147,483,647 bytes.
//if fileLength &lt; 0 then
//	returnValue	:=	false;
//	return returnValue;
//endif;
	
	if self.errorCode &lt;&gt; 0 then
		returnValue	:=	false;
		return returnValue;
	endif;
	
	isForUpdate	:=	true;
	
	if pTargetNode = JSSFMFileManagerService.NODE_TARGET_CLIENT then
		self.openDiskFileClient(pTargetPath, isForUpdate, theTargetDiskFile);
	elseif pTargetNode = JSSFMFileManagerService.NODE_TARGET_APPSERVER then
		self.openDiskFileAppServer(pTargetPath, isForUpdate, theTargetDiskFile);
	elseif pTargetNode = JSSFMFileManagerService.NODE_TARGET_DBSERVER then
		self.openDiskFileDbServer(pTargetPath, isForUpdate, theTargetDiskFile);
	endif;
	
	if self.errorCode &lt;&gt; 0 then
		returnValue	:=	false;
		return returnValue;
	endif;
	
	// Now read the source file, chunk-by-chunk, and write each chunk to the target file.
	
	fileOffset			:=	0;
	self.isCancelled	:=	false;
	theProgressForm		:=	self.myProgressForm;
	
	if theProgressForm &lt;&gt; null then
		self.getPathAndFileNames(pPathName, self.isSourceUnix, nameOfSource, nameOfFile);
		self.getPathAndFileNames(pTargetPath, self.isTargetUnix, nameOfTarget, nameOfFile);
		theProgressForm.startProgress(nameOfSource, nameOfTarget, nameOfFile, fileLength);
	endif;
	
	if fileLength &gt; 0 then
		while fileOffset &lt;= fileLength do
			if pSourceNode = JSSFMFileManagerService.NODE_SOURCE_CLIENT then
				fileData	:=	self.readDiskFileClient(theSourceDiskFile, isCompressionUsed, fileOffset);
			elseif pSourceNode = JSSFMFileManagerService.NODE_SOURCE_APPSERVER then
				fileData	:=	self.readDiskFileAppServer(theSourceDiskFile, isCompressionUsed, fileOffset);
			elseif pSourceNode = JSSFMFileManagerService.NODE_SOURCE_DBSERVER then
				fileData	:=	self.readDiskFileDbServer(theSourceDiskFile, isCompressionUsed, fileOffset);
			endif;
			
			if self.errorCode &lt;&gt; 0 then
				returnValue	:=	false;
				return returnValue;
			endif;
			
			if pTargetNode = JSSFMFileManagerService.NODE_TARGET_CLIENT then
				self.writeToDiskFileClient(theTargetDiskFile, fileData, isCompressionUsed);
			elseif pTargetNode = JSSFMFileManagerService.NODE_TARGET_APPSERVER then
				self.writeToDiskFileAppServer(theTargetDiskFile, fileData, isCompressionUsed);
			elseif pTargetNode = JSSFMFileManagerService.NODE_TARGET_DBSERVER then
				self.writeToDiskFileDbServer(theTargetDiskFile, fileData, isCompressionUsed);
			endif;
			
			if self.errorCode &lt;&gt; 0 then
				returnValue	:=	false;
				return returnValue;
			endif;
			
			if theProgressForm &lt;&gt; null then
				theProgressForm.updateProgress(fileOffset);
				
				if theProgressForm.isCancelled then
					theProgressForm.visible	:=	false;
					
					if theProgressForm.isConfirmCancel() then
						self.isCancelled	:=	true;
						break;
					endif;
				endif;
			endif;
			
			if fileOffset &gt;= fileLength then
				break;
			endif;
		endwhile;
	endif;
	
	returnValue	:=	true;
// cnwdad1 13/12/2004 - Whilst it's not desirable to have such a big epilog,
// we need to be sure that this cleanup stuff is done if there's an exception.
epilog
	// Now close the disk files (this method will also delete the disk file objects).
	
	if pSourceNode = JSSFMFileManagerService.NODE_SOURCE_CLIENT then
		self.closeDiskFileClient(theSourceDiskFile);
	elseif pSourceNode = JSSFMFileManagerService.NODE_SOURCE_APPSERVER then
		self.closeDiskFileAppServer(theSourceDiskFile);
	elseif pSourceNode = JSSFMFileManagerService.NODE_SOURCE_DBSERVER then
		self.closeDiskFileDbServer(theSourceDiskFile);
	endif;
	
	if pTargetNode = JSSFMFileManagerService.NODE_TARGET_CLIENT then
		self.closeDiskFileClient(theTargetDiskFile);
	elseif pTargetNode = JSSFMFileManagerService.NODE_TARGET_APPSERVER then
		self.closeDiskFileAppServer(theTargetDiskFile);
	elseif pTargetNode = JSSFMFileManagerService.NODE_TARGET_DBSERVER then
		self.closeDiskFileDbServer(theTargetDiskFile);
	endif;
	
	if self.errorCode &lt;&gt; 0 then
		returnValue	:=	false;
// cnwdad1 13/12/2004 - We still need to delete the file if there's been an error.
//		return returnValue;
	endif;
	
// cnwdad1 13/12/2004 - Added a check for the current exception state.
//	if self.isCancelled then
	if self.isCancelled
	or process.isInExceptionState()
	then
		if pTargetNode = JSSFMFileManagerService.NODE_TARGET_CLIENT then
			deleteNode	:=	JSSFMFileManagerService.NODE_SOURCE_CLIENT;
		elseif pTargetNode = JSSFMFileManagerService.NODE_TARGET_APPSERVER then
			deleteNode	:=	JSSFMFileManagerService.NODE_SOURCE_APPSERVER;
		elseif pTargetNode = JSSFMFileManagerService.NODE_TARGET_DBSERVER then
			deleteNode	:=	JSSFMFileManagerService.NODE_SOURCE_DBSERVER;
		endif;
		
		self.deleteFile(pTargetPath, deleteNode);
	endif;
	
	return returnValue;
end;</source>
        <access>protected</access>
        <Parameter name="pPathName" type="String"/>
        <Parameter name="pTargetPath" type="String"/>
        <Parameter name="pSourceNode" type="Integer"/>
        <Parameter name="pTargetNode" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="copyFile" id="c41ecf79-0771-493a-9665-39b0a4149652">
        <updating/>
        <source>copyFile(pSourcePath:String; pTargetPath:String; pNodeOptions:Integer):Boolean updating;
// --------------------------------------------------------------------------------
// Created:		08 July 2002 by cnwdad2
//
// Purpose:		Copies a disk file to a new location.
//
// Parameters:	pSourceName - The path name of original source file.
//				pTargetPath - The target location path for the copied file.
//				pNodeOptions - Specifies the source and target JADE nodes.
//
// Returns:		True if the operation succeeded, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	sourceNode	: Integer;
	targetNode	: Integer;
	
begin
	on Exception do self.xHandler(exception);
	
	self.doFileErrorSet(0, null);
	
	if self.interpretNodeOptions(pNodeOptions, sourceNode, targetNode) then
		return self.copyDiskFile(pSourcePath, pTargetPath, sourceNode, targetNode);
	endif;
epilog
	on Exception do null;
	
	self.doFileErrorCheck();
end;</source>
        <Parameter name="pSourcePath" type="String"/>
        <Parameter name="pTargetPath" type="String"/>
        <Parameter name="pNodeOptions" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="create" id="397fa902-2013-4884-8986-c856e4f4002b">
        <updating/>
        <source>create() updating;
// --------------------------------------------------------------------------------
// Created:		12 July 2002 by cnwdad2
//
// Purpose:		Constructor to set default values etc..
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.setFileChunkSize(self.COPY_CHUNK_SIZE);
end;</source>
    </JadeMethod>
    <JadeMethod name="createDirectory" id="1efab56f-3a20-485d-8459-ab707308c79f">
        <updating/>
        <source>createDirectory(pDirectoryName:String; pNodeOptions:Integer):Boolean updating;
// --------------------------------------------------------------------------------
// Created:		09 July 2002 by cnwdad2
//
// Purpose:		Creates a new directory on the specified target node.
//
// Parameters:	pDirectoryName - The path name of the new directory.
//				pNodeOptions - Specifies the target JADE node.
//
// Returns:		True if the operation succeeded, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	sourceNode	: Integer;
	
begin
	on Exception do self.xHandler(exception);
	
	self.doFileErrorSet(0, null);
	
	if self.interpretTargetNodeOptions(pNodeOptions, sourceNode) then
	
		if sourceNode = JSSFMFileManagerService.NODE_TARGET_CLIENT then
			return self.createDiskDirectoryClient(pDirectoryName);
		elseif sourceNode = JSSFMFileManagerService.NODE_TARGET_APPSERVER then
			return self.createDiskDirectoryAppServer(pDirectoryName);
		elseif sourceNode = JSSFMFileManagerService.NODE_TARGET_DBSERVER then
			return self.createDiskDirectoryDbServer(pDirectoryName);
		endif;
	
	endif;
epilog
	on Exception do null;
	
	self.doFileErrorCheck();
end;</source>
        <Parameter name="pDirectoryName" type="String"/>
        <Parameter name="pNodeOptions" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="createDiskDirectory" id="33df195c-aaec-4d78-b5f0-ed7111c4707e">
        <source>createDiskDirectory(pDirectoryName:String; pIsPresentationFileSystem:Boolean):Boolean protected;
// --------------------------------------------------------------------------------
// Created:		02 July 2002 by cnwdad1
//
// Purpose:		Creates a new disk directory.
//
// Parameters:	pDirectoryName - The path name of the new directory.
//				pIsPresentationFileSystem - For thin client nodes, this flag indicates
//					whether to use the thin client's own file system rather than the
//					Application Server node's file system.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	diskFolderObj	: FileFolder;
	returnValue		: Boolean;
	
begin
	returnValue	:=	false;
	create diskFolderObj transient;
	
	diskFolderObj.usePresentationFileSystem	:=	pIsPresentationFileSystem;
	diskFolderObj.fileName					:=	pDirectoryName;
	diskFolderObj.make();
	
	returnValue	:=	true;
epilog
	delete diskFolderObj;
	
	return returnValue;
end;</source>
        <access>protected</access>
        <Parameter name="pDirectoryName" type="String"/>
        <Parameter name="pIsPresentationFileSystem" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
