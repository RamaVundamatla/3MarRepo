    <JadeMethod name="addToDrawnObjects" id="58fcbe9e-80dd-4179-8ec8-c57bf3a23e66">
        <updating/>
        <source>addToDrawnObjects(_x1,_y1,_x2,_y2 : Integer ; _obj : Object) updating;
// ---------------------------------------------------------------------------
// Created:		05 December 2005  By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	aPointArray : PointArray;
begin
	
	if  self.allDrawnObjects.includes(_obj)  then
		self.allDrawnObjects.removeObjectFromDict(_obj);
	endif;
	
	self.setTmpPointArrayXYs(_x1,_y1,_x2,_y2);
	create aPointArray transient;
	self.tmpPointArray.copy(aPointArray);
	self.allDrawnObjects.putAtKey(_x1,_y1,_x2,_y2,aPointArray, _obj);
	self.allPolygons.add(aPointArray); // for cleanup
end;</source>
        <Parameter name="_x1" type="Integer"/>
        <Parameter name="_y1" type="Integer"/>
        <Parameter name="_x2" type="Integer"/>
        <Parameter name="_y2" type="Integer"/>
        <Parameter name="_obj" type="Object"/>
    </JadeMethod>
    <JadeMethod name="addToTransientDrawnObjects" id="f0882c4c-bb09-4d35-ad63-324a73816651">
        <updating/>
        <source>addToTransientDrawnObjects(_x1,_y1,_x2,_y2 : Integer ; _obj : Object; _autoRemove : Boolean) updating;
// ---------------------------------------------------------------------------
// Created:		05 December 2005  By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	aPointArray : PointArray;
	obj			: Object;
begin
	if _autoRemove then
		if  self.allTransientDrawnObjects.includes(_obj)  then
			self.allTransientDrawnObjects.removeObjectFromDict(_obj);
		endif;
	endif;
	self.setTmpPointArrayXYs(_x1,_y1,_x2,_y2);
	create aPointArray transient;
	self.tmpPointArray.copy(aPointArray);
	self.allTransientDrawnObjects.putAtKey(_x1,_y1,_x2,_y2,aPointArray, _obj);
	self.allPolygons.add(aPointArray); // for cleanup
end;</source>
        <Parameter name="_x1" type="Integer"/>
        <Parameter name="_y1" type="Integer"/>
        <Parameter name="_x2" type="Integer"/>
        <Parameter name="_y2" type="Integer"/>
        <Parameter name="_obj" type="Object"/>
        <Parameter name="_autoRemove" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="changeBackColor" id="ab4b4ed1-3ec5-4358-abe2-c3c6dfc5aaf0">
        <source>changeBackColor(_defYardBackColSelected : Integer);
// ---------------------------------------------------------------------------
// Created:		May 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

begin
	self.myDrawingFrame.changeRoRoBackColor(_defYardBackColSelected);
epilog
end;</source>
        <Parameter name="_defYardBackColSelected" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="clearAllSelectedObjects" id="a2ca847c-2c7e-4976-91dc-f33735867690">
        <updating/>
        <source>clearAllSelectedObjects() updating;
// ---------------------------------------------------------------------------
// Created:     cnwjk3 PAR 22733 09/03/2010
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	tmpSet	: ObjectSet;
	obj		: Object;
begin
	tmpSet := self.allTempObjects;
	tmpSet.clear;

	self.allSelectedObjects.copy(tmpSet);
	self.allSelectedObjects.clear;
	self.allObjectEditions.clear;
	self.stopHighlighter();
	
	foreach obj in tmpSet do
		self.myDrawingFrame.drawObject(obj, self);
	endforeach;

	tmpSet.clear;

	self.allSelectedObjectsAlt.copy(tmpSet);
	self.allSelectedObjectsAlt.clear;

	foreach obj in tmpSet do
		self.drawObject(null, obj);
	endforeach;

end;</source>
    </JadeMethod>
    <JadeMethod name="clearCollectionsForReDraw" id="3dedcf9a-8571-478d-9472-f2d41e42a7a6">
        <source>clearCollectionsForReDraw() protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
01 February 2010	cnwjk3	Initial creation

*/

vars

begin
	self.allYARowHeights.clear();
	self.allYARows.clear();
	self.allYAObjects.clear();	
	self.allOIDSbyOIDString.purge;
	self.allTransientDrawnObjects.purge;
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="clearMetricLabels" id="d0b9c33d-ec60-427d-850a-f2f522716eb5">
        <source>clearMetricLabels(_x1, _y1 : Real;  _taDrawWidth: Real ) protected;

/*

Purpose:			
	Clear a space to re-draw metric labels. This is necessary for redrawing from
	notifications
Parameters:			
	_x1, _y1 		: position where the metric arrows start drawing from (unflipped) 
	_taDrawWidth	: width of terminal area (scaled)
Return Value:		


Date		Who		Reason
08 December 2009	cnwjk3	Initial creation

*/
vars
	lx1, ly1,
	lx2, ly2	: Real;
begin
	self.myDrawingFrame.drawFontSize := self.getMetricFontSize();
	
	lx1 := _x1;
	lx1 := _x1 -4;
	//lx2 := lx1 + _taDrawWidth -1;
	lx2 := lx1 + _taDrawWidth +10;
	ly1 := _y1 + 4;
	ly2 := ly1 + self.getMetricFontSize()+2;
	//ly1 := ly1 -1;
	ly1 := ly1 -8;

	// Clear the rectangle
	self.clearRectangle(lx1, ly1, lx2, ly2, self.myDrawingFrame); 
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_x1" type="Real"/>
        <Parameter name="_y1" type="Real"/>
        <Parameter name="_taDrawWidth" type="Real"/>
    </JadeMethod>
    <JadeMethod name="clearPositionLabels" id="c97cbc77-0545-4df3-99cc-5fa2d1bc1005">
        <source>clearPositionLabels(_x1, _y1 : Real;  _taDrawWidth : Real ) protected;

/*

Purpose:			
	Clear a space to re-draw metric labels. This is necessary for redrawing from
	notifications
Parameters:			
	_x1, _y1 		: Top-left of lane (unflipped) 
	_taDrawWidth	: width of terminal area (scaled)
Return Value:		


Date		Who		Reason
08 December 2009	cnwjk3	Initial creation

*/
vars
	lx1, ly1,
	lx2, ly2	: Real;
begin
	self.myDrawingFrame.drawFontSize := self.getMetricFontSize();
	
	lx1 := _x1;
	lx2 := lx1 + _taDrawWidth -1;
	ly1 := _y1 -  self.getMetricFontSize()-2;
	ly2 := _y1 - 1;
	
	// Clear the rectangle
	self.clearRectangle(lx1, ly1, lx2, ly2, self.myDrawingFrame); 
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_x1" type="Real"/>
        <Parameter name="_y1" type="Real"/>
        <Parameter name="_taDrawWidth" type="Real"/>
    </JadeMethod>
    <JadeMethod name="clearRectangle" id="9bb4ffec-ff5c-45ca-83ce-5b952f41820f">
        <source>clearRectangle(x1, y1, x2, y2 : Real; _frame : CMUI_Frame) protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
15 December 2009	cnwjk3	Initial creation

*/

vars

begin

	self.myDrawingFrame.drawFillColor := self.myDrawingFrame.backColor; 

	_frame.drawFilledRectangle(x1, y1, x2, y2, self.myDrawingFrame.backColor);
epilog

end;</source>
        <access>protected</access>
        <Parameter name="x1" type="Real"/>
        <Parameter name="y1" type="Real"/>
        <Parameter name="x2" type="Real"/>
        <Parameter name="y2" type="Real"/>
        <Parameter name="_frame" type="CMUI_Frame"/>
    </JadeMethod>
    <JadeMethod name="clearStartOffsetLabels" id="f75cbd3a-0597-4312-8f4f-33daf110f441">
        <source>clearStartOffsetLabels(_x1, _y1, _laneWidth, _startOffset : Real; _flipHorizontal : Boolean; _tx, _ty, _taDrawWidth : Real ) protected;

/*

Purpose:			
	Clear a space to re-draw metric labels. This is necessary for redrawing from
	notifications
Parameters:			
	_x1, _y1 		: top LHS pos of lane before start offset and unflipped
	_laneWidth		: width of lane
	_startOffset	: start offset in pixels
	_tx				: X pos of terminal area
	_ty				: Y pos of terminal area
	_taDrawWidth	: width of terminal area (scaled)
	_taDrawHeight	: height of terminal area (scaled)
Return Value:		


Date		Who		Reason
08 December 2009	cnwjk3	Initial creation

*/
vars
	lx1, ly1,
	lx2, ly2	: Real;
begin
	// form a rectangle which represents the start offset space
	lx1 := _x1;
	ly1 := _y1;
	lx2 := lx1 + _startOffset;
	ly2 := ly1 + _laneWidth;
	
	if _flipHorizontal then
		lx1 := self.flipPointX(_tx, _taDrawWidth, lx1);  
		lx2 := self.flipPointX(_tx, _taDrawWidth, lx2);  
	endif;
	
	self.normaliseRealRectanglePoints(lx1, ly1, lx2, ly2);
	
	// Clear the rectangle
	self.clearRectangle(lx1, ly1, lx2, ly2, self.myDrawingFrame); 
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_x1" type="Real"/>
        <Parameter name="_y1" type="Real"/>
        <Parameter name="_laneWidth" type="Real"/>
        <Parameter name="_startOffset" type="Real"/>
        <Parameter name="_flipHorizontal" type="Boolean"/>
        <Parameter name="_tx" type="Real"/>
        <Parameter name="_ty" type="Real"/>
        <Parameter name="_taDrawWidth" type="Real"/>
    </JadeMethod>
    <JadeMethod name="clearTIBehaviourSelectionRect" id="b60c1d2a-94b1-4d50-b715-fcff665bc4ee">
        <source>clearTIBehaviourSelectionRect(_x1, _y1, _x2, _y2 : Integer) protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
09 March 2010	cnwjk3	PAR 22733
*/

vars
	oldDrawWidth : Integer;
begin
	oldDrawWidth := self.myDrawingFrame.drawWidth;
	self.myDrawingFrame.drawWidth := TI_SELECT_DRAW_WIDTH;
	self.myDrawingFrame.drawRectangle(_x1 + TI_SELECT_DRAW_WIDTH/2, _y1 + TI_SELECT_DRAW_WIDTH/2, _x2 - TI_SELECT_DRAW_WIDTH/2, _y2 - TI_SELECT_DRAW_WIDTH/2, Gray);
	self.myDrawingFrame.drawWidth := oldDrawWidth;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_x1" type="Integer"/>
        <Parameter name="_y1" type="Integer"/>
        <Parameter name="_x2" type="Integer"/>
        <Parameter name="_y2" type="Integer"/>
    </JadeMethod>
