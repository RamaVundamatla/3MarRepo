    <JadeMethod name="displayTaxCode" id="f79276e1-c56d-47e7-8be7-0e263bbba857">
        <source>displayTaxCode();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 October 2022	navmv20	ChangeRequest 55005: EUP - Invoicing - Invoice Line TAX Maintenance

*/

vars
	progress            :   CMS_Progress;
	service             :   CM_Service;
	invoiceLine         :   CM_InvoiceLine;
	charge              :   CM_Charge;
	keyService          :   CM_Service;
	keyOverridden       :   Boolean;
	prevKeyService      :   CM_Service;
	prevKeyOverridden   :   Boolean;
	chargeCount         :   Integer;
	i                   :   Integer;
	chargeIterator 		:   Iterator;
	theTable 			:   Table;
	taxCode,
	prevTaxCode 		:   String;
begin
	theTable := self.tblInvTable;
		
	create progress;
	progress.show;
	progress.raiseExceptionOnAbort := false;
	progress.setAction("Extracting charges from invoice lines...");
	progress.progress.partsInJob := self.allInvoiceLines.size;

	self.allCharges.clear;
	i := 0;
	foreach invoiceLine in self.allInvoiceLines do
		if invoiceLine.status &lt;&gt; CM_InvoiceLine.STATUS_VOIDED and
			not invoiceLine.invoice.isPostedOrReversal then	
			invoiceLine.charges.copy(self.allCharges);
		endif;
		i := i + 1;
		progress.progress.partsDone := i;
// ### TFS BUG 62926 13MAR2024 NAVAB1		progress.doWindowEvents(0);
		if progress.aborted then
			return;
		endif;
	endforeach;

	progress.setAction("Grouping service taxes...");
	progress.progress.partsInJob := self.allCharges.size;

	chargeIterator :=  self.allCharges.createIterator;

	i := 0;
	while chargeIterator.next(charge) do
		keyService:=charge.service;
		taxCode:= charge.taxCode; // ### TFS BUG 64505 11JUNE024 NAVAB1     invoiceLine.taxCode; // ### TFS CR 62992 TASK 62994 21MAR2024 NAVAB1 charge.getTaxCode(false);
		keyOverridden:=charge.overriddenTax;
		
		if keyService = prevKeyService and taxCode = prevTaxCode and keyOverridden = prevKeyOverridden then
			chargeCount := chargeCount + 1;
		else
			if chargeCount &gt; 0 then
				self.addServiceTaxToTable(prevKeyService,chargeCount, prevTaxCode,prevKeyOverridden);
			endif;
			prevKeyService := keyService;
			prevTaxCode:=taxCode;
			prevKeyOverridden := keyOverridden;
			chargeCount := 1;
		endif;
		i := i + 1;
		progress.progress.partsDone := i;
// ### TFS BUG 62926 13MAR2024 NAVAB1		progress.doWindowEvents(0);
		if progress.aborted then
			return;
		endif;
	endwhile;

	if chargeCount &gt; 0 then
		self.addServiceTaxToTable(prevKeyService,chargeCount, prevTaxCode,prevKeyOverridden);
	endif;

	if theTable.rows &gt; theTable.fixedRows then
		theTable.row := 2;
		theTable.accessRow(2).selected := true;
	endif;

epilog
	delete progress;
	delete chargeIterator;
	app.mousePointer := MP_DEFAULT;
end;</source>
    </JadeMethod>
    <JadeMethod name="doBtnSaveChangesClick" id="31412cde-3dd0-4302-adbb-4e9e95919f40">
        <updating/>
        <source>doBtnSaveChangesClick() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 October 2022	navmv20	ChangeRequest 55005: EUP - Invoicing - Invoice Line TAX Maintenance

*/

vars
	theController 		: CMIF_ChargesController;
	pxyCharges 			: CM_ChargeByServiceTaxOvrdDict;
	index,
	theReturn,
	rowSt,
	rowEnd,
	items 				: Integer;
	theService          : CM_Service;
	isReinstateTax ,
	currentlyOverridden : Boolean;
	theTable 			: CM_DataTable;
	aCharge,
	pxyCharge 			: CM_Charge;
	currentTaxCodeStr,
	newTaxCodeStr,
	taxCodeNew			: String;
	currentTaxCode,
	newTaxCode			: CM_TaxCode; 
begin

	create theController transient;
	create pxyCharges transient;
	foreach aCharge in self.allCharges do 
		pxyCharge := app.createUpdateProxy(aCharge).CM_Charge;
		theController.allChargesByTax.add(pxyCharge);
	endforeach;

	theController.allChargesByTax.copy(pxyCharges);
	
	theTable := self.tblInvTable;

	theTable.column := 1;
	rowSt := theTable.fixedRows + 1;
	rowEnd := theTable.rows;
	
	foreach index in rowSt to rowEnd do
		theService := theTable.accessRow(index).itemObject.CM_Service;
		items:=theTable.getCellValueByName(ETRow_Items,index).Integer;
		currentlyOverridden := theTable.getCellValueByName(ETRow_TaxOverridden,index).convertToBoolean(); 
		newTaxCodeStr:=theTable.getCellValueByName(ETRow_NewTaxCode,index);
		currentTaxCodeStr:=theTable.getCellValueByName(ETRow_CurrentTaxCode,index);
		
		if newTaxCodeStr = "" then										
			isReinstateTax := true;							
		else
			isReinstateTax := false;
			taxCodeNew:=newTaxCodeStr;
		endif;
		
		currentTaxCode:= self.myCurrentBank.allTaxCodes[currentTaxCodeStr];
		newTaxCode:=self.myCurrentBank.allTaxCodes[taxCodeNew];
		
		self.setProxyChargeTax(theController.allChargesByTax,theService, currentTaxCode, currentlyOverridden, items, newTaxCode, isReinstateTax);
	endforeach;	
	theController.allChargesByTax.clear;
	pxyCharges.copy(theController.allChargesByTax);

	if not theController.allChargesByTax.isEmpty then
		while true do
			app.myTrxUA.trxUpdateChargesTaxManual(theController,app.myPassport);
			if app.myPassport.trxCompletedOK then
				// Clear errors/warnings from form and err/warnings window
				self.clearErrorWarnings();
				global.beep;
				self.unloadForm();
				break;
			else
				theReturn := app.showErrorWarningDialog(app.getErrorString(INV_Charges_Update), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
				if app.myPassport.noErrors and
				   theReturn = IDOK then
					// there must have just been warnings that the user has acknoledged so ..
					app.myPassport.warningsAcknowledged	:= true;
					continue;
				endif;
				self.setAllErrorWarnings(app.myPassport);
				return;
			endif;
			break;
		endwhile;
	endif;
epilog
	foreach pxyCharge in theController.allChargesByTax do 
		delete pxyCharge;
	endforeach;
	delete theController;

end;</source>
    </JadeMethod>
    <JadeMethod name="doBuildTaxCodeCombo" id="fe065550-dd3e-40ec-ab9d-663b551fca12">
        <source>doBuildTaxCodeCombo();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 October 2022	navmv20	ChangeRequest 55005: EUP - Invoicing - Invoice Line TAX Maintenance

*/

vars
	tax : CM_TaxCode;
begin
	self.cmbNewTaxCode.clear;
	self.cmbNewTaxCode.addItem("(none)");
	self.cmbNewTaxCode.itemObject[self.cmbNewTaxCode.newIndex] := null;
	foreach tax in self.myCurrentBank.allTaxCodes where tax.notAvailableForEntry = false do
		self.cmbNewTaxCode.addItem(tax.getDisplayDetails(false));
		self.cmbNewTaxCode.itemObject[self.cmbNewTaxCode.newIndex] := tax;
	endforeach;
	
epilog

end;</source>
    </JadeMethod>
