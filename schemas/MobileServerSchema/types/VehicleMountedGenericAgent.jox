        <updating/>
        <source>getMaxDisplaySearchResults() : Integer protected, updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
24 May 2010	cnwer1	Initial creation

*/

vars

begin

	return self.getMyRTVehicleConfig.maxNumberSearchResults;
epilog

end;</source>
        <access>protected</access>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getMoveTaskStr" id="6d06610d-e388-4256-bf7e-d8a8dff8bb5c">
        <updating/>
        <source>getMoveTaskStr() : String updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
16 April 2010	cnwer1	Initial creation

*/

vars
	moveState : Integer;
begin
	moveState:=self.getNextMoveState();
	if moveState = ACCEPT_TASK then
		return app.getErrorString(Accept);
	elseif moveState = GETNEXT_TASK then
		return  app.getErrorString(GetNext);
	elseif moveState = PICKUP_TASK then
		return app.getErrorString(Pickup);
	elseif  moveState = SETDOWN_TASK then
		return app.getErrorString(Setdown);
	elseif  moveState = COMPLETE_TASK then
		return app.getErrorString(Complete);
	endif;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getMyRTVehicleConfig" id="45e78002-ab8b-4232-9c09-6bfa57fb7c00">
        <updating/>
        <source>getMyRTVehicleConfig() : CM_RTVehicleConfig updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
08 June 2010	cnwer1	Initial creation

*/

vars
	invalidObject : Boolean;
	edition  : Integer;
begin
	
	on Exception do app.handleDeletedObject(exception,self.myRTVehicleConfig,invalidObject);
	
	if self.myRTVehicleConfig = null then
		self.myRTVehicleConfig:=self.myTerminal.getRTVehicleConfigForObject(self.myMachine);
	endif;
	
	edition:=self.myRTVehicleConfig.edition;
	if invalidObject then
		self.myRTVehicleConfig:=self.myTerminal.getRTVehicleConfigForObject(self.myMachine);
	endif;
	
	return self.myRTVehicleConfig;
epilog

end;</source>
        <ReturnType type="CM_RTVehicleConfig"/>
    </JadeMethod>
    <JadeMethod name="getMyScreenMode" id="6623bb6f-96da-4c88-946c-788c44a2261e">
        <updating/>
        <source>getMyScreenMode()  : CM_RTScreenConfig updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
08 June 2010	cnwer1	Initial creation
08/03/2011	cnwmh5	PAR #27142 - Change to local variable rather than self for handleDeleteObject exception
*/

vars
	invalidObject : Boolean;
	edition  : Integer;
	screenMode	: CM_RTScreenConfig;
begin
	
	screenMode := self.myScreenMode;
	on Exception do app.handleDeletedObject(exception,screenMode,invalidObject);
	edition:=screenMode.edition;
	if invalidObject then
		self.getMyRTVehicleConfig;
		return screenMode;
	endif;
	
	return screenMode;
	
epilog

end;</source>
        <ReturnType type="CM_RTScreenConfig"/>
    </JadeMethod>
    <JadeMethod name="getNextMoveState" id="dc124a0c-a10e-4768-babc-5f586f8f0454">
        <updating/>
        <source>getNextMoveState() : Integer updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
16 April 2010	cnwer1	Initial creation

*/

vars

begin
	if self.myMachine.currentQueueTask = null then
		if self.showingTaskList then
			return self.ACCEPT_TASK;
		else
			return self.GETNEXT_TASK;
		endif;
	else
		if not self.showingTaskList then
			if self.myMachine.currentQueueTask.status = TASK_OFFERED then
				return self.ACCEPT_TASK;
			else
				if self.isIMV then
					return self.ACCEPT_TASK; 
				endif;
			endif;	
		endif;
		
		if self.doesSeperatePickupSetdown then
			if self.myMachine.currentQueueTask.taskType = TASK_PICKUP or
				self.myMachine.currentQueueTask.taskType = TASK_DIRECTOR then
				return self.PICKUP_TASK;
		
				
			elseif self.myMachine.currentQueueTask.taskType = TASK_SETDOWN then
				return self.SETDOWN_TASK;
			endif;
		else
			return self.COMPLETE_TASK;
		endif;
		
	endif;
epilog

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getQueueTask" id="94aae704-f311-4989-a7ce-312b15103e53">
        <source>getQueueTask(_dtoQueueEntry : DTO_RTQueueEntry input) : CM_RTQueueTask;
//23 March 2011	cnwdw1	
// CCMS 1210
vars
	invalidObject	: Boolean;
	rtQueueEntry	: CM_RTQueueEntry;
	rtQueueTask		: CM_RTQueueTask;
begin
	on Exception do app.handleDeletedObject(exception, _dtoQueueEntry, invalidObject);		//cnwmc5 - 27 Feb 2014 - PAR 30311
	on Exception do app.handleDeletedObject(exception, rtQueueEntry, invalidObject);

	rtQueueEntry := _dtoQueueEntry.myRealQueueEntry.CM_RTQueueEntry;
	
	if invalidObject or rtQueueEntry = null then	//cnwmc5 - 27 Feb 2014 - PAR 30311
		return null;								//cnwmc5 - 27 Feb 2014 - PAR 30311
	endif;											//cnwmc5 - 27 Feb 2014 - PAR 30311
	if rtQueueEntry.allTasks.size &gt; 0 and not invalidObject then
		rtQueueTask	:= rtQueueEntry.allTasks.first;
	endif;
	if invalidObject or rtQueueTask = null then
		return null;
	endif;	
	return rtQueueTask;
end;</source>
        <Parameter name="_dtoQueueEntry" type="DTO_RTQueueEntry" usage="input"/>
        <ReturnType type="CM_RTQueueTask"/>
    </JadeMethod>
    <JadeMethod name="getRelatedTask" id="81925ee5-b80b-407e-8e3d-ad84c31ba685">
        <updating/>
        <source>getRelatedTask() updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date			Who		Reason
16 April 2010	cnwer1	Initial creation
06/12/2010		cnwcs5	par 23714/ccms 1132 - get move NOT director task
*/

vars

	task : CM_RTQueueTask;
	entry : CM_RTQueueEntry;
begin
	task := self.getCurrentTask;
	entry := task.myEntry;
	if entry &lt;&gt; null then
		self.myRelatedTask:=entry.getNextEntryFirstTask;
		if self.myRelatedTask = null then
			self.myRelatedTask:=entry.getPreviousEntryFirstMoveTask;	// 06/12/2010 cnwcs5 par 23714/ccms 1132
		endif;
	endif;
	
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="getSortColumn" id="5413beeb-028b-454f-9eaa-4b922587c06c">
        <updating/>
        <source>getSortColumn(_table : Table input): Integer protected, updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
19 April 2010	cnwer1	Initial creation

*/

vars
	entTableView : EntTableView;
begin

	entTableView:=self.getEntTableView(_table);

	return entTableView.allEntTableRows.size  + 1;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_table" type="Table" usage="input"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="initTable" id="aca47518-a108-406c-880b-b26fa0e3b871">
        <updating/>
        <source>initTable(_table : Table input) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
28 May 2010	cnwer1	Initial creation
02 Sep 2010 cnwer1 	PAR 25206
*/

vars

begin	
	self.myMachQEntryTableSynchAgent.setTableDetails(_table,self.getEntTableView(_table),self.getHeaderTopRow(_table));
	if self.myMachQEntryTableSynchAgent.getNumberOfEntries = 0 then
		self.loadRTTaskTable(_table,null);
	else
		self.myMachQEntryTableSynchAgent.doReloadAllQueueEntries(_table);
	endif;
epilog

end;</source>
        <Parameter name="_table" type="Table" usage="input"/>
    </JadeMethod>
