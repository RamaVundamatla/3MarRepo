    <JadeMethod name="cmbWebServiceType_change" id="4619bea2-1585-417b-bc40-2cea210d592d">
        <controlMethod name="ComboBox::change"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbWebServiceType_change(combobox: ComboBox input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 Nov 2018	jlgmp6	Initial creation	TFS41999
13 Mar 2019	jlgsl4	TFS 40360 - NXL - KiwiRail EDI message
09 Apr 2020	jlgdap1	TFS 49003 MTN API Inline Agent
21 Sep 2020 cnwma1 ChangeRequest 49906: MTN - Ops View External Webservice
10 Oct 2022	jlika1	TFS 54892 - POB - Vessel, Voyage and Movement EDI Messages
02 Nov 2022	navpw1	TFS: 55215 - Added support for ExternalWebServiceEDBIC to load its view
06 Dec 2022	navdap1	TFS 55159 MTN - Export CAMS to JSON API Endpoint
*/

vars
	tbl : CM_EntryTable;
	webServicetype: CM_ExternalWebServiceDef;
begin

	if combobox.parent.isKindOf(CM_EntryTable) then
		combobox.parent.CM_EntryTable.setValueByControlName(combobox.name, combobox.text);
		if combobox.listObject = null then
			return;
		endif;
		//jlier1 TFS 56856 28/3/23
		if combobox.text &lt;&gt; null and self.myCurrentTableItem.isKindOf(SOPTM_ExtWebService) then
			self.myCurrentTableItem.SOPTM_ExtWebService.changeViews(combobox.text);
		endif;
		self.resize;
	endif;

end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
    </JadeMethod>
