    <JadeMethod name="setAssignedCargoIdsFromString" id="f123032e-5502-4e19-a6b1-26b1dc0802b2">
        <updating/>
        <source>setAssignedCargoIdsFromString( _str : String )updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 August 2015	cnwndl1	Initial creation	Par 36608

*/

vars

	strArray : StringArray;

begin

	self.allPreAssignedCargoIds.clear();

	strArray := _str.getTokens();
	if strArray &lt;&gt; null and not strArray.isEmpty then
		strArray.copy( self.allPreAssignedCargoIds );
	endif;

epilog

	delete strArray;

end;</source>
        <Parameter name="_str" type="String"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="9e40ef5a-e857-4867-921a-ac20ef31224d">
        <updating/>
        <source>setForUpdate(_proxyEDITI: SelfType) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 August 2015	cnwndl1	Initial creation

*/

vars

begin
	
	inheritMethod(_proxyEDITI);

	self.defaultLocation := _proxyEDITI.defaultLocation;
	self.remarks := _proxyEDITI.remarks;	//21 Sep 2015	NDL	Par 36338
	self.maxWeight := _proxyEDITI.maxWeight;
	self.minWeight := _proxyEDITI.minWeight;
	self.operatorCode := _proxyEDITI.operatorCode;
	self.allPreAssignedCargoIds.clear();
	if not _proxyEDITI.allPreAssignedCargoIds.isEmpty then
		_proxyEDITI.allPreAssignedCargoIds.copy( self.allPreAssignedCargoIds );
	endif;

epilog

end;</source>
        <Parameter name="_proxyEDITI" type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="verifySelf" id="9133297c-4eb2-419e-97f1-e3c819b3b995">
        <source>verifySelf();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 August 2015	cnwndl1	Initial creation

*/

vars

	cType : CM_CargoType;
	
begin

	
	cType := app.myRoot.allCargoTypesById[self.cargoType];
	if cType = null then
		if self.cargoTypeDescr &lt;&gt; null then
			if self.cargoTypeDescr.isInteger then
				cType := app.myRoot.allCargoTypesById[self.cargoTypeDescr.Integer];
			else
				cType := app.myRoot.getCargoTypeFromAbbrevOrDescr( self.cargoTypeDescr );
			endif;
		endif;
	endif;

	if cType = null then
		app.raiseCMException1( Requires_cargo_type, self.id, null, null );
		return;
	elseif not cType.isCargoGroup then
		app.raiseCMException2( Cargo_type_selec_not_defin_car, cType.description, self.id, null, null );
		return;
	endif;
	
	if id = null then
		app.raiseCMException( ERR_INVALID_TI_ID, null, null );
		return;
	endif;
		
epilog

end;</source>
    </JadeMethod>
</Class>
