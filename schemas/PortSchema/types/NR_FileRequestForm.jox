        <updating/>
        <source>btnAddClass_click(btn: Button input) updating;
// ---------------------------------------------------------------------------
// Created:     12 March 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	className	: String;
begin
	className := self.txtClassToAdd.text;
	if className = null then
		app.msgBox('You must enter a class name to add', 'Error', MsgBox_OK_Only);
		return;
	endif;
	
	self.lstCheck.addItem(className);
	
end;</source>
