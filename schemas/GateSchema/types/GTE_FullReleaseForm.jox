    <JadeMethod name="cmbCarrier_lostFocus" id="19f62d8a-7ab1-4261-a0e8-5db03a9fe2cc">
        <controlMethod name="CMUI_ComboBoxObject::lostFocus"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbCarrier_lostFocus(combobox: ComboBox input) updating;
// -------------------------------------------
// Created 10 September 2004 by cnwdvb1
//15/01/2015   cnwma1		 PAR #35462 Carrier Drop-down Fields	
// -------------------------------------------
vars
		tbl			: CM_EntryTable;
begin

	//self.tblMain.setValueByControlName(combobox.name, combobox.text); //12/01/2015 cnwma1 PAR #35462 
	if not CM_EntryTable.hasInstance(combobox.parent) then
		return;
	endif;
	
	tbl := combobox.parent.CM_EntryTable;

	if cmbCarrier.listObject &lt;&gt; null then
		tbl.setValueByControlName(combobox.name, cmbCarrier.listObject.CM_Carrier.code);
	else
		tbl.setValueByControlName(combobox.name, null);
	endif;
	
	combobox.doChangedCompareForEntryTable();

end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="cmbConsignee_displayEntry" id="b2f854ef-1082-410b-97f9-c395c9a4a30f">
