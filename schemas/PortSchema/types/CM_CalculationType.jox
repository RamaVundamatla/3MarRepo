        <source>isVolumeBased() : Boolean;
/*
Purpose:			

Date		Who		Reason
24JAN2023	NAVAB1	CR 55624 TASK 55700 
*/
vars
	result	: Boolean;
begin
	if self.calculationType = INV_CALC_TYPE_BOL_VOLUME or
	   self.calculationType = INV_CALC_TYPE_WO_CARGOVOLUME or
	   self.calculationType = INV_CALC_TYPE_CARGOVOLUMECONVT or
