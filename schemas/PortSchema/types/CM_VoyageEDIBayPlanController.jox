    <JadeMethod name="getNumTIsString" id="5e346d77-f4ce-4c0b-a8fa-9b1dbd1fc783">
        <source>getNumTIsString():String;
//----------------------------------------------------------------
//	Created:	30 January 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------

vars

begin
	if self.myEdiData &lt;&gt; null then
		return self.myEdiData.allEDITrackedItems.size.String &amp; " items";
	endif;
	
end;</source>
        <ReturnType type="String"/>
