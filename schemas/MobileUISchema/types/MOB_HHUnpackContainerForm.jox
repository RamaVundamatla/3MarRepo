    <JadeMethod name="setupControls" id="1354a293-2a43-4856-8739-8e3ab8bbfe48">
        <updating/>
        <source>setupControls() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
05 July 2011	cnwndl1	Initial creation	Par 26476

*/

vars

	folderHeight : Real;
	stdHeight : Real;
	vTop : Real;
	vLeft : Real;
	vHeight : Real;

begin

	self.setResizeableMarginAndFontSize();
	stdHeight := self.getStdControlHeight;

//	folderHeight := self.height - self.getCMDHeight() - stdHeight +  self.getSessionAgent().deviceHeightOffset;
	folderHeight := self.clientHeight - self.getCMDHeight() - stdHeight;	 //26 Jun 2017	NDL	TFS 4647
	
	self.fldCargo.move(	self.resizedMargin,
						self.resizedMargin,
						self.clientWidth - 4,
						folderHeight
						);
						
	self.frmUnpacked.move(	0,
							0,
							self.shtUnpacked.width - self.resizedMargin,
							self.shtUnpacked.height - self.resizedMargin
							);
								
	self.txtCargoId.move(	0,
							1,
							self.shtToUnPack.width - self.resizedMargin,
							stdHeight
							);
	self.txtCargoId.text := lblCargoId.caption.toUpper;
							
	vTop := self.txtCargoId.height + self.resizedMargin;
	self.frmToUnPack.move(	0,
							vTop,
							self.shtToUnPack.width - self.resizedMargin,
							self.shtToUnPack.height - vTop - self.resizedMargin
							);
							
//	top := self.fldCargo.top + self.fldCargo.height + margin;
	
	self.doResizeControls(true);
	
	//09 Mar 2017	NDL	TFS 3635
	if self.myTerminal.hasNoCargoCheckItemsFor(CONT_CHECK_CONTEXT_UNPACK) then
		self.btnTwo.enabled := false;
	else
		self.btnTwo.enabled := true;
	endif;
	
	self.docActsToDisplay.clear();	//29 Sep 2016	NDL	TFS 2654 / 2001
	self.setupToUnPackBtns();
	self.setupUnPackedBtns();
	
	self.txtCargoId.setFocus();
	

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setupForm" id="b2eaa234-cd53-473a-8b1e-b0e0c2ba3664">
        <updating/>
        <source>setupForm() updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
05 July 2011	cnwndl1	Initial creation	Par 26476

*/

vars

	isFromDocAction : Boolean;	//12 Dec 2016	NDL	TFS 3113 / 2001

begin

	inheritMethod();

	self.myHandHeldCheckerAgent := app.myHandHeldCheckerAgent;
	self.myUnpackContainer := self.myMobileGenericAgent.myUnpackTi;
	self.myDefaultLocation := self.myMobileGenericAgent.myUnpackDefaultLocation;
	self.caption := app.getErrorString(Unpack) &amp; " " &amp; self.myUnpackContainer.id;	
	
	self.allowChangeID := self.myMobileGenericAgent.unpackChangeID;	//08 Apr 2014	NDL	Par 33859

	if self.myMobileGenericAgent.myPackTi &lt;&gt; null then
		//we have just returned from creating a new item in the container for unpacking.
		//set the next to to action
		self.myMobileGenericAgent.setMyNextTiToAction( self.myMobileGenericAgent.myPackTi );
		//c;ear the .myPackTi
		self.myMobileGenericAgent.setPackContainerDetails(	self.myMobileGenericAgent.myPackStockBookingRef,	//_stockBookingRef : CM_BookingRef;
																self.myMobileGenericAgent.myPackStockBookingItem,	//_stockBookingRefItem : CM_BookingRefItem;
																self.myMobileGenericAgent.myPackExportBookingRef,	//_exportBookingRef : CM_BookingRef;
																self.myMobileGenericAgent.myPackExportBookingItem,	//_exportBookingRefItem : CM_BookingRefItem;
																null	//_trackedItem : CM_TrackedItem
																);
		// either rcall the checks form or prepare to unpack.
		//if self.myHandHeldCheckerAgent.myTerminal.allCargoChecks[CARGO_CHECK_CONTEXT_UNPACK].allCargoCheckItems.size = 0 then
		if self.myTerminal.hasNoCargoCheckItemsFor(CARGO_CHECK_CONTEXT_UNPACK) then	//31 May 2012	NDL Par 29038
			self.gotoForm( MOB_HHUnpackCargoToForm, false );
			return;
			
		else
			//requires checks first
			self.myMobileGenericAgent.setMyDeliveryRequest(null);
			self.myMobileGenericAgent.setChecksState(self.myMobileGenericAgent.UnpackCargo);
			self.gotoForm(MOB_HHGateCheckCargo, false);
			return;
			
		endif;
	endif;
	
	//12 Dec 2016	NDL	TFS 3113 / 2001
	if self.myMobileGenericAgent.allReserveDetails &lt;&gt; null and  self.myMobileGenericAgent.allBookingRefItems &lt;&gt; null then
		isFromDocAction := ( self.myMobileGenericAgent.allReserveDetails.size + self.myMobileGenericAgent.allBookingRefItems.size ) &gt; 0 and ( self.myMobileGenericAgent.stringField1 &lt;&gt; null );
	endif;
			
	//returning from 'MOB_HHGateCheckCargo' when we have done a 'Next' (initiated from the 'clickUnPackButton' )
	//if self.myMobileGenericAgent.myNextTiToAction &lt;&gt; null then
	if not isFromDocAction and self.myMobileGenericAgent.myNextTiToAction &lt;&gt; null then	//12 Dec 2016	NDL	TFS 3113 / 2001
		self.gotoForm( MOB_HHUnpackCargoToForm, false );
		return;
	endif;
	
	
	
	self.setupCmdButtons( 3, app.getErrorString(Complete), app.getErrorString(Checks), app.getErrorString(Back), null, null );
	
	self.setupControls();
	
	self.returnFromDocAction();	//29 Sep 2016	NDL	TFS 2654 / 2001

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setupToUnPackBtns" id="ee7871ba-9ded-41cb-bfcb-f5228d1bc072">
        <updating/>
        <source>setupToUnPackBtns() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
05 July 2011	cnwndl1	Initial creation	Par 26476

*/

constants

	TAB_INDEX_START = 1000;
	
vars

	errMess : String;
	buttonWidth : Real;
	buttonNumber : Integer;
	menuButton : MOB_Button;
	buttonOffset : Integer;
	ti  : CM_TrackedItem;
	size : Integer;
	buttonHeight : Integer;
	allowMoreCargoButton : Boolean;	//04 Dec 2015	NDl	Par 36866
	bookingRefItem : CM_BookingRefItem;
	docActions : CM_DocumentActions;
	taskAndStopStr : String;
	
begin
	
	// get the container
	if self.myUnpackContainer = null then
		errMess := "developer error,  no Container";
		self.msgBox( errMess, app.getErrorString(Error), MsgBox_OK_Only, true);
		return;
	endif;
	
		
	// create the buttons on the form
	size := self.myUnpackContainer.allChildren.size + 1;
	
	buttonHeight := self.getScrollingButtonHeight();
	self.btnToUnpackTemp.height := buttonHeight;
	buttonWidth := self.getButtonWidthSetScrollBar( size, self.frmToUnPack, self.btnToUnpackTemp.height, self.scrToUnPack );
	
	foreach ti in self.myUnpackContainer.allChildren do
		
		//29 Sep 2016	NDL	TFS 2654 / 2001
		bookingRefItem := ti.myBookingRefItem;
		if bookingRefItem &lt;&gt; null then
			docActions := bookingRefItem.myBookingRefItemActions;
		else
			docActions := null;
		endif;
		
		buttonNumber := buttonNumber + 1;
		menuButton := self.btnToUnpackTemp.loadControl( buttonNumber ).MOB_Button;
		menuButton.move(0, buttonOffset, buttonWidth, buttonHeight-4 );
		
		menuButton.userObject := ti;
		//08 Apr 2014	NDL	Par 33859
		if not allowChangeID then
			menuButton.caption := ti.cargoTypeDescr &amp; " - " &amp; ti.id;
		else
			menuButton.caption := self.getPennButtonCaption(ti);
		endif;
		
		//29 Sep 2016	NDL	TFS 2654 / 2001
		if docActions &lt;&gt; null then
			taskAndStopStr := docActions.getTaskAndStopStrForTi(ti,true);
			if taskAndStopStr &lt;&gt; null then
				menuButton.caption := menuButton.caption &amp; " " &amp; taskAndStopStr;
				self.docActsToDisplay.addExclusive( docActions );
			endif;
		endif;
		
		self.addHazDetailsToButton( menuButton, ti, null ); //30 May 2017	NDL	TFS 4587
		
		menuButton.enabled := true;
		
		buttonOffset := buttonOffset + buttonHeight-2;
		menuButton.tabIndex := TAB_INDEX_START + buttonNumber;
	
	endforeach;
	
	allowMoreCargoButton := self.myTerminal.getConfig(AllowUnpackMoreCargo).Boolean;	//04 Dec 2014	NDL	Par 36866
	
	if allowMoreCargoButton then
		buttonNumber := buttonNumber + 1;
		menuButton := self.btnToUnpackTemp.loadControl( buttonNumber ).MOB_Button;
		menuButton.move(0, buttonOffset, buttonWidth, buttonHeight-4 );
		
		menuButton.userObject := null;
		menuButton.caption := app.getErrorString(More_cargo);
		menuButton.enabled := true;	
		
		buttonOffset := buttonOffset + buttonHeight-2;
		menuButton.tabIndex := TAB_INDEX_START + buttonNumber;
	endif;
	
	self.btnToUnpackTemp.visible := false;

epilog


end;</source>
    </JadeMethod>
    <JadeMethod name="setupUnPackedBtns" id="af7c0671-cc7a-405e-9c34-8840a1e6e9ff">
        <updating/>
        <source>setupUnPackedBtns() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
05 July 2011	cnwndl1	Initial creation	Par 26476

*/

constants

	TAB_INDEX_START = 1000;
	
vars

	errMess : String;
	buttonWidth : Real;
	size : Integer;
	buttonNumber : Integer;
	menuButton : MOB_Button;
	buttonOffset : Integer;
	ti  : CM_TrackedItem;
	buttonHeight : Integer;
	bookingRefItem : CM_BookingRefItem;
	docActions : CM_DocumentActions;
	taskAndStopStr : String;
	
begin
	
	// get the container
	if self.myUnpackContainer = null then
		errMess := "developer error,  no Conatiner";
		self.msgBox( errMess, app.getErrorString(Error), MsgBox_OK_Only, true);
		return;
	endif;
	
		
	// create the buttons on the form
	size := self.myMobileGenericAgent.allUnpackedTis.size;

	buttonHeight := self.getScrollingButtonHeight();
	self.btnInYardTemp.height := buttonHeight;
	buttonWidth := self.getButtonWidthSetScrollBar( size, self.frmUnpacked, self.btnInYardTemp.height, self.scrUnPacked );


	foreach ti in self.myMobileGenericAgent.allUnpackedTis do
	
		//29 Sep 2016	NDL	TFS 2654 / 2001
		bookingRefItem := ti.myBookingRefItem;
		if bookingRefItem &lt;&gt; null then
			docActions := bookingRefItem.myBookingRefItemActions;
		else
			docActions := null;
		endif;
		
		buttonNumber := buttonNumber + 1;
		menuButton := self.btnInYardTemp.loadControl( buttonNumber ).MOB_Button;
		menuButton.move(0, buttonOffset, buttonWidth, buttonHeight-4 );
		
		menuButton.userObject := ti;
		menuButton.caption := ti.cargoTypeDescr &amp; " - " &amp; ti.id;
		menuButton.enabled := true;
		
		//29 Sep 2016	NDL	TFS 2654 / 2001
		if docActions &lt;&gt; null then
			taskAndStopStr := docActions.getTaskAndStopStrForTi(ti,true);
			if taskAndStopStr &lt;&gt; null then
				menuButton.caption := menuButton.caption &amp; " " &amp; taskAndStopStr;
				self.docActsToDisplay.addExclusive( docActions );
			endif;
		endif;
		
		self.addHazDetailsToButton( menuButton, ti, CrLf ); //30 May 2017	NDL	TFS 4587
		
		buttonOffset := buttonOffset + buttonHeight-2;
		menuButton.tabIndex := TAB_INDEX_START + buttonNumber;
		
	endforeach;
	
	self.btnInYardTemp.visible := false;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="translateForm" id="d28cd3fe-cd9f-422a-9ae1-220609725725">
        <updating/>
        <source>translateForm(locale : CM_Locale) updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 27 October 2016 09:10:29.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	
begin
	// Determine the locale for translations.
	inheritMethod(locale);
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0016632, locale);
	btnDocActions.translateCaption(Xlat_0021439, locale);
	btnInYardTemp.translateCaption(Xlat_0016633, locale);
	btnToUnpackTemp.translateCaption(Xlat_0016634, locale);
	lblCargoId.translateCaption(Xlat_0016635, locale);
	shtToUnPack.translateCaption(Xlat_0016636, locale);
	shtUnpacked.translateCaption(Xlat_0016637, locale);
end;</source>
        <Parameter name="locale" type="CM_Locale"/>
    </JadeMethod>
