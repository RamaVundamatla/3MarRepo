    <JadeMethod name="doSave" id="5df59780-72a4-4431-86e6-6eea7bf281a1">
        <updating/>
        <source>doSave(): Boolean updating;
// ---------------------------------------------------------------------------
// Created:     12 May 2003 by cnwsgp1
// 23 September 2025	navhn30	MTN-36045: LNX | Trades table update only with active voyages.
// ---------------------------------------------------------------------------
vars
	isNotAvailableForEntry	: Boolean;
	proxyTrade				: CM_Trade;
	lCode,lDescription		: String;
	lOrder					: Integer;
	theForm 				: SOP_TableMaintForm;
	pOperators 				: ObjectArray;
	pShippingLines 			: CM_ShippingLineByCodeDict;
	i : Integer;
	lstBox : CMUI_ListBox;
	port : CM_Port;
	pxyPortRotation 		: CM_PortRotation;
	updatePortsOfCall		: Boolean;
	allowActiveTrades		:  Boolean;

begin
  	theForm := self.myForm; 

	lDescription := theForm.tblInput1.getValueByName(ETRow_Description).String;
	lOrder := theForm.tblInput1.getValueByName(ETRow_OrderNo).Integer;
	isNotAvailableForEntry := theForm.tblInput1.getValueByName(ETRow_NotAvailableForEntry).Boolean;
	allowActiveTrades := app.myRoot.getConfig(AllowActiveDefaultTrade).Boolean;			//23.09.2025	navhn30 	MTN-36045
	
	if theForm.myProxyObject = null then
		if theForm.mode = theForm.Mode_Add then
			create theForm.myProxyObject as CM_Trade transient;
		else
			app.raiseUnexpectedProgramError(class.name, method.name, 'Proxy object is null for update');
			return false;
		endif;
	endif;
	proxyTrade := theForm.myProxyObject.CM_Trade;
	
	create pOperators transient;
    theForm.mulSelect1.getSelected(pOperators);    

	create pShippingLines transient;
	theForm.mulSelect2.getSelected(pShippingLines);
	
	lstBox :=self.myForm.lstSingleSelect1;

	proxyTrade.allPortRotations.purge;
	
	i :=1;
	while i &lt;= lstBox.listCount do
		if lstBox.itemLevel[i] &gt; 1 then
			if pxyPortRotation &lt;&gt; null then
				pxyPortRotation.allTranshipPorts.add(lstBox.itemObject[i].CM_Port);
			endif;
			i:=i+1;
			continue;
		endif;
		port:=lstBox.itemObject[i].CM_Port;
		create pxyPortRotation transient;
		pxyPortRotation.setProxy(port,proxyTrade);
		i:=i+1;
	endwhile;
	
	proxyTrade.setProxy(lCode, lDescription, lOrder, pOperators, isNotAvailableForEntry, pShippingLines);

	if theForm.mode = theForm.Mode_Add then
		app.myTrxCA.trxCreateTrade(proxyTrade, theForm.myCurrentObject,app.myPassport);
	elseif theForm.mode = theForm.Mode_Update then
		if self.portsOfCallChanged then
			if allowActiveTrades then				//23.09.2025	navhn30 	MTN-36045
				updatePortsOfCall:= app.msgBox(app.getErrorString(Trade_Update_Active_Voy_Ports),app.getErrorString(Ports_of_call),MsgBox_Yes_No) = MsgBox_Return_Yes;		
			else
				updatePortsOfCall:= app.msgBox(app.getErrorString(Trade_Update_Voyage_Ports),app.getErrorString(Ports_of_call),MsgBox_Yes_No) = MsgBox_Return_Yes;
			endif;
		endif;
	
		app.myTrxUA.trxUpdateTrade(proxyTrade, updatePortsOfCall,app.myPassport);
	else
		app.raiseUnexpectedProgramError(class.name, method.name, '  Invalid mode (' &amp; theForm.mode.String &amp; ')');
		return false;
	endif;
	

	
	return app.myPassport.trxCompletedOK();
	
epilog

	delete pOperators;
	delete pShippingLines;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
