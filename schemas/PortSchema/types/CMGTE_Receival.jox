    <JadeMethod name="getStringDictKey" id="ec2c6a85-217e-4fe9-a4ad-91ec5c754430">
        <source>getStringDictKey(): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
01 May 2023			jlizm1	Initial creation TFS 55453 Cargo uniqueness by subtype

*/

vars
	ct 		: CM_CargoType;
	retStr 	: String;
	
begin

	if self.myParent &lt;&gt; null then
		return self.id &amp; "/" &amp; self.myParent.getStringDictKey();
	endif;
	
	ct := self.getMyCargoType();
	
	retStr := self.id;
	
	if ct &lt;&gt; null and ct.allowDuplicates then
		if ct.useCargoGroupForUniqueness then
			retStr := retStr &amp; "/" &amp; self.getCargoGroupCode;
		endif;
		if ct.useCargoSubtypeForUniqueness then
			retStr := retStr &amp; "/" &amp; self.getCargoSubTypeCode;
		endif;
	endif;
	
	return retStr[1:60];
	

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getTI" id="b7dc6854-3973-400c-bc58-2d1b0eef57ea">
        <source>getTI() : CM_TrackedItem;
// ---------------------------------------------------------------------------
// Created:     14 October 2008 by cnwab1
//
