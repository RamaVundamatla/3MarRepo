    <JadeMethod name="doDictioanryMaint" id="1be2e0c9-a75b-489b-bfac-a09ece044442">
        <source>doDictioanryMaint() protected;
// --------------------------------------------------------------------------------
// Created:		06 September 2002 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	theDictionaryForm	: JSSWordDictionaryMaintForm;
	
begin
	create theDictionaryForm;
	theDictionaryForm.setSpellCheckForm(self);
	theDictionaryForm.showModal();
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doDisplayText" id="3549c332-f025-47df-ae0a-a5fa9c848fa8">
        <source>doDisplayText() protected;
// --------------------------------------------------------------------------------
// Created:		06 September 2002 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	coordX1			: Integer;
	coordY1			: Integer;
	textColor		: Integer;
	preTextWork		: String;
	errorTextWork	: String;
	postTextWork	: String;
	preTextSize		: Integer;
	errorTextSize	: Integer;
	postTextSize	: Integer;
	
begin
	// Clear the text already there.
	
	picText.clearGraphics();
	picText.autoRedraw		:=	true;
	picText.drawTextAlign	:=	Window.DrawTextAlign_Left;
			
	// Determine what portions of the text to display given
	// the position of the scroll bar and the size of the 
	// pieces of text.
	
	preTextSize		:=	self.aPreText.length();
	errorTextSize	:=	self.aErrorText.length();
	postTextSize	:=	self.aPostText.length();
	  
	if hscTextScroll.value = 0 then
		preTextWork	:=	self.aPreText;
	elseif hscTextScroll.value &gt; preTextSize then
		preTextWork	:=	null;
	else
		preTextWork	:=	self.aPreText[hscTextScroll.value:end];
	endif;
	
	if hscTextScroll.value &lt;= preTextSize then
		errorTextWork	:=	self.aErrorText;
	elseif hscTextScroll.value &gt; preTextSize + errorTextSize then
		errorTextWork	:=	null;
	else
		errorTextWork	:=	self.aErrorText[(hscTextScroll.value - preTextSize):end];
	endif;
	
	if hscTextScroll.value &lt;= (preTextSize + errorTextSize) then
		postTextWork	:=	self.aPostText;
	else
		postTextWork	:=	self.aPostText[(hscTextScroll.value - ( preTextSize + errorTextSize)):end];
	endif;
	
	// draw the 3 pieces of text on the control. 	  			  			  			  			  			  			  			  		
	 
	textColor	:=	Black;
	coordX1		:=	5;
	coordY1		:=	2;
	picText.drawTextAt(preTextWork, coordX1, coordY1, textColor);
	
	coordX1		:=	coordX1 + picText.drawTextWidth(preTextWork).Integer;
	textColor	:=	Red;
	picText.drawTextAt(errorTextWork, coordX1, coordY1, textColor);
	
	coordX1		:=	coordX1 + picText.drawTextWidth(errorTextWork).Integer;
	textColor	:=	Black;
	picText.drawTextAt(postTextWork, coordX1, coordY1, textColor);
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doFormLoad" id="f20f39fb-43f4-4965-9ee3-1146aff149f1">
        <updating/>
        <source>doFormLoad() updating, protected;
// --------------------------------------------------------------------------------
// Created:		06 September 2002 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	inheritMethod();
	
	self.caption			:=	"Spell Check: " &amp; self.aMySpellCheck.myDictionary.dictionaryName;
	btnReplace.enabled		:=	false;
	btnReplaceAll.enabled	:=	false;
	
	self.populateSuggestedWords();
	
	self.setupScroll();
end;</source>
        <access>protected</access>
    </JadeMethod>
