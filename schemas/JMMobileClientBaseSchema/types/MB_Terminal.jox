    <JadeMethod name="setForCreate" id="9bb8a2e5-65da-4e5e-a527-0047efdf1982">
        <updating/>
        <source>setForCreate(_code, _name, _oid : String; _edition : Integer) updating;
// ---------------------------------------------------------------------------
// Created:     23 August 2005 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin

	self.setForUpdate(_code, _name, _edition);
	self.setMasterForCreate(_oid, _edition);

end;</source>
        <Parameter name="_code" type="String"/>
        <Parameter name="_name" type="String"/>
        <Parameter name="_oid" type="String"/>
        <Parameter name="_edition" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="983db5d5-71b7-410d-b673-bc862b0b9197">
        <updating/>
        <source>setForUpdate(_code, _name : String; _edition : Integer) updating;
// ---------------------------------------------------------------------------
// Created:     23 August 2005 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin

	self.code	:= _code;
	self.name	:= _name;
	self.setMasterForUpdate(_edition);

end;</source>
        <Parameter name="_code" type="String"/>
        <Parameter name="_name" type="String"/>
        <Parameter name="_edition" type="Integer"/>
    </JadeMethod>
