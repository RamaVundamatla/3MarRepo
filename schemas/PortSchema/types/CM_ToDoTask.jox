    <JadeMethod name="getMTReportColumnFromDesc" id="718869e0-e7cf-4bc3-b4a5-f45497c69145">
        <source>getMTReportColumnFromDesc(): Integer;
//----------------------------------------------------------------
//	Created:	02 November 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	desc	: CM_ToDoTaskDesc;
	col		: Integer;
begin
	col := null;
	desc := self.getMyToDoTaskDesc();
	
	if desc &lt;&gt; null then
		col := desc.emptyReportColumn;
	endif;
	
	return col;
	
end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getMyToDoTaskDesc" id="5b7efe42-fe24-4f42-a300-2232f167c270">
        <source>getMyToDoTaskDesc() : CM_ToDoTaskDesc;
// ---------------------------------------------------------------------------
// Created:		October 2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
/*

Date		Who		Reason
19 May 2010	cnwkpd1	PAR #20728 - remove isValidObject calls for performance

*/

vars

begin
	if self.toDoTaskDesc &lt;&gt; null then
//		if global.isValidObject(self.toDoTaskDesc) then	- inversed, so can't be invalid
			return self.toDoTaskDesc;
//		endif;
	endif;
	
	return app.myRoot.allToDoTaskDescriptions[self.toDoTaskDescCode];
end;</source>
        <ReturnType type="CM_ToDoTaskDesc"/>
    </JadeMethod>
