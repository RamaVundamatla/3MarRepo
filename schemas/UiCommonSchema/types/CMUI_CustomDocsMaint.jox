    <JadeMethod name="doTblDatalContextMenu" id="95da1ece-23d4-4908-a468-8a542b92b50a">
        <updating/>
        <source>doTblDatalContextMenu(cntrl: Table input; conwin: Window input; mouse: Boolean; x: Integer; y: Integer):Boolean updating, protected;
/*
Purpose:			

Date		Who		Reason
11AUG2023	NAVAB1	 CR 59614 TASK 59619
*/

vars
	canEdit		: Boolean;
	x1,
	y1			: Real;
begin
	x1 := x;
	y1 := y;
	if (not mouse) then
	    x1 := 1;
	    y1 := 1;
	endif;
	conwin.windowToScreen(x1, y1);
	self.screenToWindow(x1, y1);
	self.mnuColumnOrganiser.visible := true;
	self.mnuColumnOrganiser.userObject := self.tblData;
	self.mnuInspectObject.visible := app.isAllowedToInspect();  // ### TFS 60004 24AUG2023 NAVAB1
	self.popupMenu(self.mnuContextMenu, x1.Integer, y1.Integer);
	return false;

end;</source>
        <access>protected</access>
        <Parameter name="cntrl" type="Table" usage="input"/>
        <Parameter name="conwin" type="Window" usage="input"/>
        <Parameter name="mouse" type="Boolean"/>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="enableForCargoReview" id="15429c99-93f0-46ef-b4ca-d9355a16568b">
        <source>enableForCargoReview();
/*
Purpose:			

Date		Who		Reason
25 August 2023	navab1	CR 59942 TASK 59943 
*/

vars
	docType : CM_CustomDocumentType;
	mandatoryAttr: String;
	enableBtn : Boolean;
begin
	 docType := self.cmbDocType.listObject.CM_CustomDocumentType;
	if docType = null then
		enableBtn := false;
	 // The Doc Type 126 is for the whole amount, you cannot use 'update' to change any amount or exclude any cargo items.
// ### TFS CR 60424 TASK 60549 17OCT2023 NAVAB1	elseif docType.allPrevDocumentTypes.isEmpty then
	elseif docType.isInward() then // ### TFS CR 60424 TASK 60549 17OCT2023 NAVAB1
		enableBtn := false;
	else
		enableBtn := true;
		foreach mandatoryAttr in docType.allMandatoryFields do
			if mandatoryAttr = ETRow_CustAgent and  self.cmbCustomsAgent.listObject = null then
				enableBtn := false;
				break;
			elseif mandatoryAttr = ETRow_HsCodes and  self.cmbHSCodes.listObject = null then
				enableBtn := false;
				break;
			elseif mandatoryAttr = ETRow_CustLicense and self.cmbLicense.listObject = null then
				enableBtn := false;
				break;
			elseif mandatoryAttr = ETRow_Direction and self.cmbDirection.listIndex &lt;=0 then
				enableBtn := false;
				break;
			elseif mandatoryAttr = ETRow_Remarks and self.txtRemarks.text = null then
				enableBtn := false;
				break;
			elseif mandatoryAttr = ETRow_ItemNumber and self.txtRefNumber.text = null then
				enableBtn := false;
				break;
			elseif mandatoryAttr = ETRow_Description and self.txtDesc.text = null then
				enableBtn := false;
				break;
			elseif mandatoryAttr = ETRow_ExternalRef1 and self.txtExtRef.text = null then
				enableBtn := false;
				break;
			endif;
		endforeach;
	endif;

	if not enableBtn then
// ### TFS CR 60424 TASK 60549 17OCT2023 NAVAB1		if docType &lt;&gt; null and docType.allPrevDocumentTypes.isEmpty then
		if docType &lt;&gt; null and docType.isInward() then // ### TFS CR 60424 TASK 60549 17OCT2023 NAVAB1
			self.btnUpdate.bubbleHelp := "Cannot update partial details for this document type";
		else
			self.btnUpdate.bubbleHelp := "Please enter all mandatory data before being allowed to edit the details";
		endif;
	else
		self.btnUpdate.bubbleHelp := "";
	endif;
	self.btnUpdate.enabled := enableBtn;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="getCargoReviewProxyDocType" id="97698602-b692-4a10-9e3c-0b3c7f77e438">
        <source>getCargoReviewProxyDocType(_custDocDetail : CM_CustomDocumentDetail);
/*// ### TFS CR 60424 TASK 60549 26SEP2023 NAVAB1 - explanation
Purpose - 	You have been to the detail screen where Tis may have been included or excluded.
				This method is re looking at what is now included, because it may mean that the cust doc type must change
				This method is trying to stop a TI skipping a doc type.
Who - NAVAB1
Date - 05SEP2023
ADO - CR 59942 TASK 59943 
*/

vars
	subDetail : CM_CustomDocumentDetail;
	ti : CM_TrackedItem;
	custDoc : CM_CustomDocument;
	custDocType : CM_CustomDocumentType;
begin

	foreach subDetail in _custDocDetail.allSubDetails discreteLock do
		if subDetail.isIncluded() then
			ti := subDetail.myTrackedItem;
			if ti &lt;&gt; null then
				custDoc:= ti.getPreviousCustomDocument(null); 
				if custDoc &lt;&gt; null then
					custDocType := custDoc.myCustomDocumentType;
					if custDocType &lt;&gt; null then
						break;
					endif;
				endif;
			endif;
		endif;
	
	endforeach;
	
	/* // ### TFS BUG 62187 14FEB2024 NAVAB1
	if custDocType &lt;&gt; null then
		self.buildCmbDocType(custDocType);
	endif;
	*/
	
epilog

end;</source>
        <Parameter name="_custDocDetail" type="CM_CustomDocumentDetail"/>
    </JadeMethod>
    <JadeMethod name="getFirstTi" id="fcdc72bf-b2e3-4ec8-bcde-12198587effe">
        <source>getFirstTi() : CM_TrackedItem;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01/09/2023	navkc1	CR 59937 Task 59941: UI - Default Custom License Based on Cargo Location

*/

vars
	ti		: CM_TrackedItem;
	
begin
	
	if self.myCustomDocument &lt;&gt; null then
		ti := self.myCustomDocument.getFirstTi();
	elseif self.allTiSet.isNotEmpty() then
		ti := self.allTiSet.first();
		
		if ti.isCargoGroupItem() then
			ti := ti.CM_CargoGroup.allAssignedTrackedItems.first();
		endif;
	endif;
	
	return ti;
	
epilog

end;</source>
        <ReturnType type="CM_TrackedItem"/>
    </JadeMethod>
