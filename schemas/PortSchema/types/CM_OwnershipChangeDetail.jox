    <JadeMethod name="validateCOOEffectiveDate" id="9e8989af-918f-442d-9469-42403fdcb17b">
        <source>validateCOOEffectiveDate();
/*

Purpose:			This checks wheter a TI previously has a COO approved.
					If so, this new COO effective should not be earlier than the one done previously.

Parameters:			

Return Value:		

Date		Who		Reason
08/12/2023	navkc1 ChangeRequest 58261 Task 58260: Jade - COO Invoice Issues Send Email

*/

vars
	ti					: CM_TrackedItem;
	storageExpDetail	: CM_StorageExpiryDetail;
	currentCooHeader,
	prevCooHeader		: CM_OwnershipChange;
	
begin
	
	currentCooHeader := self.getOwnershipChangeHeader();
	ti := self.myTrackedItem;
	
	storageExpDetail := ti.getLastStorageExpDetailWithCOO();
	
	if storageExpDetail = null then
		return;
	endif;
	
	prevCooHeader := storageExpDetail.myOwnershipChange;
	
	if prevCooHeader = null then
		return;
	endif;
	
	if currentCooHeader.dateTimeCOO &lt; prevCooHeader.dateTimeCOO then
		app.raiseCMException2(Ownership_Changed_On, ti.id, prevCooHeader.dateTimeCOO.asStringJMT(), null, null);
	endif;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="validateForApproval" id="1843b93d-a4cf-4c09-acc4-9625d2b4507a">
        <source>validateForApproval();
/*
Purpose:	

Date		Who		Reason
14 January 2025	navab1	JIRA 33801
*/

vars
	ti : CM_TrackedItem;
	voy : CM_Voyage;
	op : CM_Operator;
	coo : CM_OwnershipChange;
begin
	ti := self.myTrackedItem;
	voy := ti.myVoyage;
	
	coo := self.getOwnershipChangeHeader();
	
	if coo = null then
		return;
	endif;
	
	op := coo.myOperatorNew;
	if voy &lt;&gt; null 
	and not voy.isNullVoyage
	and op &lt;&gt; null then
		if not voy.allOperators.includes(op) then
			app.raiseCMException2(VB_VALID_VOY,op.code, voy.code, ETRow_Operator, null);
		endif;
	endif;
			
	
epilog

end;</source>
    </JadeMethod>
