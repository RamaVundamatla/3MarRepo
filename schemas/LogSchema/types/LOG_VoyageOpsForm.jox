    <JadeMethod name="activate" id="793f28ad-2253-46ab-942f-15855b88a5a3">
        <controlMethod name="Form::activate"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>activate() updating;
//--------------------------------------------------------------
//Created: 14 May 2003 By: cnwgd1
//--------------------------------------------------------------
vars

begin
	inheritMethod();
//	if self.myCurrentVoyage &lt;&gt; null then
	//	app.myPassport.setMyTerminal(self.myCurrentVoyage.myTerminal);
//	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="allocateRowClearNotes" id="f18d2097-e3ee-4b1d-a73d-a8ff1799d2e7">
        <updating/>
        <source>allocateRowClearNotes() updating;
//-----------------------------------------
// Created: January 2004 By: cnwgd1
//-----------------------------------------
vars
	sohLocn : CM_SOHLocation;
begin
	foreach sohLocn in self.allSOHSearchResults do
		endNotification(sohLocn, Object_Update_Event);
	endforeach;

end;</source>
    </JadeMethod>
    <JadeMethod name="allocateRowSearch" id="4b870cde-3715-4731-855e-1fe4fb31abd0">
        <updating/>
        <source>allocateRowSearch() updating;
//--------------------------------------------------------------
//Created: 25 July 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	operator	: CM_Operator;
	terminal	: CM_Terminal;
	species,
	grade,
	type,
	treatment,
	tmpStr, 
	length		 : String;
begin
	
	if self.myCurrentStockOrderLine = null and 
	   self.myCurrentStockOrderSummary = null then
		self.showCannotAccessSheetMsg(shtAllocateRows, 'Please select a Stock Order form the above table.');
		return;
	else
		self.hideCannotAccessSheetMsg(shtAllocateRows);
	endif;
	app.mousePointer := MousePointer_HourGlass;
	
	if cmbFilterOper.myObject &lt;&gt; null then
		operator := cmbFilterOper.myObject.CM_Operator;
	else
		tmpStr := app.getTerminologyAlternate(null, self.myTerminal, CM_TerminologyOperator, CM_TermExpressionSingular, 'Supplier');
	//	app.msgBox(app.getErrorString1(REQUIRED_FIELD, tmpStr), 'Select ' &amp; tmpStr, MsgBox_Information_Icon + MsgBox_OK_Only);
		app.msgBox(app.getErrorString1(Input_required_field_Required, tmpStr), 'Select ' &amp; tmpStr, MsgBox_Information_Icon + MsgBox_OK_Only); // cnwdb2	PAR 35364
		return;
	endif;
	
	species 	:= tblAlloSearch.getValueByName(ETRow_FilterSpecies).String;	
	grade		:= tblAlloSearch.getValueByName(ETRow_FilterGrade).String;	
	type 		:= tblAlloSearch.getValueByName(ETRow_FilterType).String;	
	treatment 	:= tblAlloSearch.getValueByName(ETRow_FilterTreatment).String;	
	length 		:= tblAlloSearch.getValueByName(ETRow_FilterLength).String;
		
	if species = null then
	//	app.msgBox(app.getErrorString1(REQUIRED_FIELD, 'Species'), 'Select Species', MsgBox_Information_Icon + MsgBox_OK_Only);
		app.msgBox(app.getErrorString(Input_required_field_species), 'Select_species', MsgBox_Information_Icon + MsgBox_OK_Only); // cnwdb2	PAR 35364
		return;
	endif;

	self.allocateRowClearNotes();
	self.allSOHSearchResults.clear;

	if self.myCurrentStockOrderObject &lt;&gt; null then	
		terminal := self.myCurrentStockOrderObject.getMyTerminal();
	elseif self.myCurrentStockOrderLine &lt;&gt; null then
		terminal := self.myCurrentStockOrderLine.getMyTerminal();	
	elseif self.myCurrentStockOrderSummary &lt;&gt; null then
		terminal := self.myCurrentStockOrderSummary.getMyTerminal();	
	endif;
	
	if terminal &lt;&gt; null then
		terminal.getSOHLocationsForLogSpec(operator, species, grade, type, treatment, length, self.allSOHSearchResults);
	endif;

	self.showSOHSearchResults();
	self.txtAllocRowDtls.text := null;
	
epilog
	app.mousePointer := MousePointer_Default;	
end;</source>
    </JadeMethod>
    <JadeMethod name="allocatedRowsSave" id="cd778218-dc11-467b-8d7d-26d8dd2f891e">
        <updating/>
        <source>allocatedRowsSave()updating;
//--------------------------------------------------------------
//Created: 26 July 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	iFaceAlloc 	: CMIF_StockOrderAllocation;
	iFaceSet 	: CMIF_LogStockOrderAllocSet;
	stockObject : CM_StockOrderObject;
	sohLocn 	: CM_SOHLocation;
	row,
	saveRow,
	result,
	colAllocQty : Integer;	
	ls			: Boolean;
begin

	stockObject := self.myCurrentStockOrderObject;
	if stockObject = null then
		return;
	elseif self.tblOrderData.row &lt;= self.tblOrderData.fixedRows then 
		//if get here then must have no order line highlighted even though self.myCurrentStockOrderObject is not null
		// this must mean self.myCurrentStockOrderObject is incorrect and probably for another voyage. this can lead to rows allocated
		// to incorrect lots/summarys. 
		self.showCannotAccessSheetMsg(shtAllocateRows, 'You must select a stock order line in the table above before you can allocate rows.');
		return;		

	endif;
	app.mousePointer := MousePointer_HourGlass;	
	app.cmsBeginLoad(ls);		
	
	exclusiveLock(stockObject);
	colAllocQty := tblSrchResults.getColumnByRowName(ETRow_AllocVolume);
	row := self.tblSrchResults.rows;
	saveRow := self.tblSrchResults.row;
	create iFaceSet transient;

	while row &gt; tblSrchResults.fixedRows do
		create iFaceAlloc transient;
		sohLocn := tblSrchResults.accessRow(row).itemObject.CM_SOHLocation;
		sharedLock(sohLocn);
		iFaceAlloc.mySOHLocation := sohLocn;
		iFaceAlloc.expectedEditionSOHLocn := sohLocn.edition;

		iFaceAlloc.volume := tblSrchResults.accessCell(row, colAllocQty).text;
		
		if stockObject.isKindOf(CM_StockOrderProductLine) then
			iFaceAlloc.myLogStockOrderLine := stockObject.CM_LogStockOrderLine;
			iFaceAlloc.mode 			   := iFaceAlloc.Mode_LineAllocation;
		elseif stockObject.isKindOf(CM_StockOrderSummary) then
			iFaceAlloc.myStockOrderSummary := stockObject.CM_StockOrderSummary;
			iFaceAlloc.mode := iFaceAlloc.Mode_SummaryAllocation;			
		endif;
		
		iFaceAlloc.expectedEditionStockOrder := stockObject.edition;
		iFaceSet.add(iFaceAlloc);		
		row := (row - 1);
		sohLocn := null;		
	endwhile;

	while true do
		app.myTrxUA.trxUpdateCMIF_LogStockAlloc(iFaceSet, app.myPassport);
		if app.myPassport.trxCompletedOK then
			// Clear errors/warnings from form and err/warnings window
			self.clearErrorWarnings();
			break;
		else
			result := app.showErrorWarningDialog('Allocate Rows', app.myPassport, ErrWarnMode_Update + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   result = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;

			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
		endif;
		
		return;
	endwhile;
epilog
	endLoad;
	if iFaceSet &lt;&gt; null then 
		iFaceSet.purge();
		delete iFaceSet;
	endif;
	app.mousePointer := MousePointer_Default;		
end;</source>
    </JadeMethod>
    <JadeMethod name="archiveSearch" id="f427dd78-df5a-4bff-9558-14b7f13d7d35">
        <updating/>
        <source>archiveSearch()updating;
//--------------------------------------------------------------
//Created: 26 November 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	terminal 	: CM_Terminal;
	voyCode		: String;
	imo			: String;
	startDate,
	endDate		: Date;
begin
	
	if self.modeView &lt;&gt; Mode_ArchiveView then
		return;
	endif;
	
	app.mousePointer := MousePointer_HourGlass;
	self.allArchivedVoySearchResults.clear();
	
	if cmbTerminal.listObject &lt;&gt; null then
		terminal := cmbTerminal.listObject.CM_Terminal;
	endif;
	
	voyCode 	:= self.tblArchiveSearch.getValueByName(ETRow_VoyageCode).String;
	imo		 	:= self.tblArchiveSearch.getValueByName(ETRow_IMO).String;
	startDate 	:= self.tblArchiveSearch.getValueAsDate(ETRow_FilterStartDate);
	endDate		:= self.tblArchiveSearch.getValueAsDate(ETRow_FilterEndDate);

	if terminal &lt;&gt; null then
		terminal.lookupArchivedVoyages(self.allArchivedVoySearchResults, voyCode, imo, startDate, endDate);
	else
		app.myRoot.lookupArchivedVoyages(self.allArchivedVoySearchResults, voyCode, imo, startDate, endDate);
	endif;

	self.listsTreeViewLoadAll();
	if self.fldTreeView.topSheet = self.shtListSuppliers then		
		self.listTreeViewChange(lstSuppliers);
	else
		self.listTreeViewChange(lstPorts);
	endif;

epilog
	app.mousePointer := MousePointer_Default;				
end;</source>
    </JadeMethod>
    <JadeMethod name="archiveView" id="71c08737-3168-4aab-8475-11293e248e33">
        <updating/>
        <source>archiveView()updating;
//--------------------------------------------------------------
//Created: 29 November 2002 By: cnwgd1
//--------------------------------------------------------------
vars

begin

	self.modeView := Mode_ArchiveView;
	self.clearForm();
	
	// CCMS 1124
	self.tblArchiveSearch.visible := true; 
	self.btnArchiveSearch.visible := true;
	
	self.setEnableObjects();	
	
end;</source>
    </JadeMethod>
