02 June 2015	cnwer1	Initial creation PAR

*/

vars

begin
	return ETDef_EDITIDebtor;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="loadDB" id="d288d7c6-1e66-4b06-ab00-4f1584b4690d">
        <source>loadDB(_validateOnly: Boolean; _passport: CM_Passport input);
/*

Date		Who		Reason
02 June 2015	cnwer1	Initial creation PAR
12 Nov 2025 navlc30 JIRA 36357 - LINX - Enable importing debtor addresses via EDI
01 Dec 2025 navlc30 JIRA 36749 - LINX - Audits not getting created for the Debtor with Addressed created through EDI

*/

vars
	real : CM_DebtorNode;
	cmifDebtorNode : CMIF_DebtorNode;
begin
	self.verifySelf();
	
	if _validateOnly then
		return;
	endif;
	
	if self.action = self.EDI_ACTION_ADD then
		cmifDebtorNode:=self.createCMIF_Debtor();
		app.myUtilityCA.utlCreateDebtorNode(cmifDebtorNode, real, _passport);
	elseif self.action = self.EDI_ACTION_UPDATE or self.action =self.EDI_ACTION_MODIFY then
		cmifDebtorNode:=self.createCMIF_Debtor();
		app.myUtilityUA.utlUpdateDebtorNode(cmifDebtorNode,_passport);
	endif;
	
epilog
	if cmifDebtorNode &lt;&gt; null then
		delete cmifDebtorNode.myPxyDebtorNode;
		cmifDebtorNode.allDebtorTerminalDetails.purge(); // ### TFS 52237 27OCT2021 NAVAB1

		delete cmifDebtorNode;
	endif;
end;</source>
        <Parameter name="_validateOnly" type="Boolean"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="name" id="a921ba6b-1cc7-4ed7-ac52-503ebc1ef6eb">
        <methodInvocation>mapping</methodInvocation>
        <updating/>
        <source>name(set : Boolean; _value : String io) mapping, updating;
/*

Date		Who		Reason
03 June 2015	cnwer1	Initial creation PAR
// 08 May 2018	jlgrs1	TFS 36425 SingleLine Booking partial processing not working


*/

vars

begin
	if set then
		self.setId(_value[1:30]);
		_value := _value[1:100];	//14 Mar 2019	NDL	TFS 43671
	endif;
epilog

end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="4ec8f405-8de8-4623-827f-5671f1fa92c9">
        <updating/>
        <source>setForUpdate(_proxyEDITI: SelfType) updating;
/*

Date		Who		Reason
11 Jun 2015	cnwer1	Initial creation PAR 36435
28 Mar 2020 cnwma1	Bug 48994: ASPA - Debtor Uploads missing Attributes
*/

vars

begin
	inheritMethod(_proxyEDITI);
	self.action                   := _proxyEDITI.action;
	self.badDebtor                := _proxyEDITI.badDebtor;
	self.billingAddress			  := _proxyEDITI.billingAddress;
	self.decfinName				  := _proxyEDITI.decfinName;
	self.externalReference		  := _proxyEDITI.externalReference;
	self.isPurchaseOrderMandatory := _proxyEDITI.isPurchaseOrderMandatory;
	self.isSuspended			  := _proxyEDITI.isSuspended;
	self.isZeroRatedTax			  := _proxyEDITI.isZeroRatedTax;
	self.longName				  := _proxyEDITI.longName;
	self.myParentDebtorNode		  := _proxyEDITI.myParentDebtorNode;
	self.name					  := _proxyEDITI.name;
	self.purchaseOrderCode  	  := _proxyEDITI.purchaseOrderCode;
	self.remarks				  := _proxyEDITI.remarks;
	self.code  			    	  := _proxyEDITI.code;                    //30.03.2020 cnwma1 #48994
	self.termsOfTrade       	  := _proxyEDITI.termsOfTrade;            //30.03.2020 cnwma1 #48994
	self.additionalInformation1   := _proxyEDITI.additionalInformation1;  //30.03.2020 cnwma1 #48994
	self.additionalInformation2   := _proxyEDITI.additionalInformation2;  //30.03.2020 cnwma1 #48994
		
epilog

end;</source>
        <Parameter name="_proxyEDITI" type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="verifySelf" id="5391dc6b-b99b-404f-8afa-7f99b57bc87b">
        <source>verifySelf();
/*

Date		Who		Reason
02 Jun 2015	cnwer1	Initial creation PAR
04 Mar 2019	jlgrs1	TFS 41913 STWR - Reconfiguration of the EDI Operation form to better handle EDI collection locks while loading 
28 Mar 2020 cnwma1	Bug 48994: ASPA - Debtor Uploads missing Attributes
*/

vars
	root 			  : CM_Root;
	parentDebtor      : CM_DebtorNode;
	duplicateDebtor   : CM_Debtor;
	parentEDIDebtorTI : CM_EDIDebtorTI;
begin
	if self.action &lt;&gt; CM_EDITrackedItem.EDI_ACTION_ADD 
			and self.action &lt;&gt; CM_EDITrackedItem.EDI_ACTION_MODIFY
			and self.action &lt;&gt; CM_EDITrackedItem.EDI_ACTION_UPDATE then
			app.raiseCMException1(EDI_Action_Is_Invalid, action, ETRow_Action, self);
			return;
	endif;
	
	
	if self.name = null then
		app.raiseCMException(Input_required_field_name, null, null); // cnwdb2	PAR 35364
		return;
	endif;
	
	duplicateDebtor:=self.getDebtor();
	if self.action = CM_EDITrackedItem.EDI_ACTION_ADD then	
		if duplicateDebtor &lt;&gt; null then
			//raise exception can not add debtor as already exists
			app.raiseCMException1(Already_exists_debtor,self.name,null,null);
		endif;
	endif;
	
	if self.myParentDebtorNode &lt;&gt; null then
		//check if parent debtor exist either in db already or in file
		parentDebtor := app.myRoot.myRootCompany.debtorNodes[self.myParentDebtorNode];    //28.03.2020 cnwma1 #48994
		if parentDebtor = null then
			//check not to be added in file
			if self.myEDIData &lt;&gt; null then
				parentEDIDebtorTI := self.myEDIData.allEDITrackedItems[self.myParentDebtorNode[1:30]].CM_EDIDebtorTI;
				if parentEDIDebtorTI = null or not parentEDIDebtorTI.action = self.EDI_ACTION_ADD then
					app.raiseCMException2(Parent_debtor_does_not_exist,self.name, self.myParentDebtorNode, null, null);
				endif;
			endif;
		endif;			
	endif;	
	
	if self.action = CM_EDITrackedItem.EDI_ACTION_MODIFY or self.action = CM_EDITrackedItem.EDI_ACTION_UPDATE then
		if duplicateDebtor = null then 
			app.raiseCMException2(Does_not_exist_cannot_update,app.getErrorString(INV_Debtor), self.name, null, null);
		endif;
	endif;
epilog

end;</source>
    </JadeMethod>
</Class>
