    <JadeMethod name="translateForm" id="c7fce88f-016d-40c6-8605-d40623b6fd47">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 18 February 2021 08:52:40.
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0022207, locale);
	frmSearchText.translateCaption(Xlat_0024118, locale);
	frmTermOpts.translateCaption(Xlat_0024119, locale);
	lblHHApp.translateCaption(Xlat_0022208, locale);
	lblMobileApp.translateCaption(Xlat_0022209, locale);
	lblWebservices.translateCaption(Xlat_0022210, locale);
end;</source>
    </JadeMethod>
</GUIClass>
