/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 May 2018	jlgmp6	Initial creation	TFS 37718
31 Mar 2025 navma1  MTN-34387 MTN - Removing Unnecessary Audits
*/


vars
	auditIdStr : String;
begin
	auditIdStr := self.auditId();								//31.03.2025 navma1 #MTN-34387
	
