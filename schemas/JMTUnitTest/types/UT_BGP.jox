    <JadeMethod name="addMachineAndQCargo" id="c59e9a20-7ebb-4a59-9d04-0c92b475aef1">
        <source>addMachineAndQCargo(voyageJob : CM_VoyageJob);
/*
Purpose:			
Date		Who		Reason
14 February 2012	NAVAB1	Initial creation
*/

vars
	tas: StringArray;
	straddle : CM_Machine;
	voy : CM_Voyage;
	ti : CM_TrackedItem;
	wle : CM_WorkListEntry;
	queueEntry : CM_RTQueueEntry;
	theQ : CM_RadioTelemetryQueue;
begin
	voy := self.getVoyage("UTBISH9");



	// workJob to CTA
	self.deleteMachine("UTS1");
	self.deleteRTDevice("91");
	create tas transient;
	tas.add("UTRJD1"); 
	//tas.add("UTRJD2"); 
	tas.add("CTA1");
	self.addStraddle("UTS1", 91, tas, "UTGARBAGE1");
	
	straddle := self.getMachine("UTS1");
	
	theQ := self.getQueue("UTGARBAGE1");
	self.machineAssignToQueue(straddle, theQ);
	
	assertNotNull(straddle);
	app.isRTApp:=true;  
	
	self.machineLogon(straddle);
	
	foreach wle in voyageJob.workListEntries discreteLock do
		
		queueEntry := wle.allRTQueueEntries[1];
		self.machineAcceptSpecifiedTask(straddle, queueEntry);
		
		app.myPassport.setWarningsIgnored(true);
		app.myPassport.setWarningsAcknowledged(true);
		app.myTrxUA.trxMachinePickupTask(straddle,null,null,app.myPassport);

		
		app.myPassport.setWarningsIgnored(true);
		app.myPassport.setWarningsAcknowledged(true);
		self.machineSetdown(straddle, wle.myTrackedItem, straddle.currentQueueTask.targetLocationId);//machineSetdownTask(straddle, queuetask, queuetask.targetLocationId);
	//break;
	endforeach;
	self.machineLogOff(straddle);

epilog
	app.isRTApp:=false;  
	delete tas;
end;</source>
        <Parameter name="voyageJob" type="CM_VoyageJob"/>
    </JadeMethod>
