    <JadeMethod name="getAllSelectedInvLineTypes" id="4064778f-d116-426e-97b9-b94eaf1a188c">
        <source>getAllSelectedInvLineTypes( _selected : CM_InvoiceLineDescSet input );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 June 2018	jlgndl1	Initial creation

*/

vars

	lineType : CM_InvoiceLineDesc;
	edition : Integer;
	invalid : Boolean;
	
begin

	_selected.clear();
	
	on Exception do app.handleDeletedObject( exception, lineType, invalid );
	
	
	foreach lineType in self.allSelectedInvLineTypes do
		invalid := false;
		edition := lineType.edition;
		if invalid then
			continue;
		endif;
		_selected.add( lineType );
	endforeach;

epilog

end;</source>
        <Parameter name="_selected" type="CM_InvoiceLineDescSet" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getCargoSurchargeInvLineType" id="0586646d-192d-4a1d-9e03-013907e82248">
        <source>getCargoSurchargeInvLineType():CM_InvoiceLineDesc;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 April 2018	jlgndl1	Initial creation	TFS 37818

*/

vars

	lineType : CM_InvoiceLineDesc;
	edition : Integer;
	invalid : Boolean;

begin

	lineType := self.myCargoSurchargeInvLineType;
	if lineType = null then
		return null;
	endif;
	
	on Exception do app.handleDeletedObject( exception, lineType, invalid );
	edition := lineType.edition;
	if invalid then
		return null;
	endif;
	
	return lineType;

epilog

end;</source>
        <ReturnType type="CM_InvoiceLineDesc"/>
    </JadeMethod>
