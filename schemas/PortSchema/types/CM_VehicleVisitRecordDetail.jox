    <JadeMethod name="isVisitStage" id="546c4461-de63-4abe-baea-d696ca0137f0">
        <source>isVisitStage():Boolean;
// ---------------------------------------------------------------------------
// Created:     21 May 2009 by concms1
// Purpose:     Par 19715 - Vehicle Visit Record Detail Changes
// Parameters:  None
// Returns:     True if the record type relates to the progress of the vehicle
//				through the terminal, i.e. not a cargo move etc.
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 01/09/2009	cnwcs5		ccms 1061 - new VVRD types
// ---------------------------------------------------------------------------
vars

begin
	/* Note: This method whould be updated as new stages are introduced */
	return self.recordType = VisitRecord_Create or
			self.recordType = VisitRecord_Arrive_AGate or
			self.recordType = VisitRecord_Complete_AGate_In or
			self.recordType = VisitRecord_Arrive_PGate_In or
			self.recordType = VisitRecord_Complete_PGate_In or
			self.recordType = VisitRecord_Yard or
			self.recordType = VisitRecord_Arrive_PGate_Out or
			self.recordType = VisitRecord_Complete_PGate_Out or
			self.recordType = VisitRecord_Trouble or
			self.recordType = VisitRecord_Complete_OutGate;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="c17a3c2d-1d22-4419-91c8-22237251f3e1">
        <source>pxyCreateUpdateProxy(): SelfType;

/*

Purpose:			

Parameters:			

Return Value:		


Date				Who		Reason
11 September 2009	cnwjk3	SFW1035
20/04/2011			cnwmh5	PAR #27401 - Add code to handle prossible exceptions occurring when
							trying to create the proxy
*/

vars
	pxyVVRD : CM_VehicleVisitRecordDetail;
	completedOK		: Boolean;
begin
	pxyVVRD :=  inheritMethod();
	pxyVVRD.myExtraInfoObject := self.myExtraInfoObject;
	pxyVVRD.myVehicleVisitRecord := self.myVehicleVisitRecord;
	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return pxyVVRD;
epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete pxyVVRD;
	endif;

end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="recordTypeString" id="dba7510e-a61b-4633-8872-ca6ffc804339">
        <source>recordTypeString() : String;
// ---------------------------------------------------------------------------
// Created:     26 August 2008 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
// 20/05/2009		concms1			Par 19715 - new record types/translations
// 18/12/2013		cnwdap1			PAR #32849 CCMS PEN 2321 Security Gate
// 06/04/2023		jlizm1			TFS 57098 EUP Seal numbers on trucks
// ---------------------------------------------------------------------------

vars
	type	:Integer;
begin 
	type := self.recordType;
	
	if type = VisitRecord_Arrive_AGate then
		return app.getErrorString (Arrival_a_gate);
	elseif type = VisitRecord_Complete_AGate_In then
		return (app.getErrorString(Complete_a_gate_in));
	elseif type = VisitRecord_Arrive_PGate_In then
		return app.getErrorString(Arrival_inward_gate_lane);
	elseif type = VisitRecord_Arrive_PGate_Out then
		return app.getErrorString(Arrival_outward_gate_lane);
	elseif type = VisitRecord_Yard then
		return app.getErrorString(Arrive_Yard);
	elseif type = VisitRecord_Complete_PGate_Out then
		return app.getErrorString(Complete_outward_gate_lane);
	elseif type = VisitRecord_Create then
		return app.getErrorString (Pre_Check); 
	elseif type = VisitRecord_Trouble then
		return "Trouble";
	elseif type = VisitRecord_CargoRemoved then
		return app.getErrorString(Cargo_removed);
	elseif type = VisitRecord_CargoPlaced then
		return app.getErrorString(Cargo_placed);
	elseif type = VisitRecord_ReadyToLeave then
		return app.getErrorString(Ready_To_Leave);
	elseif type = VisitRecord_Complete_OutGate then
		return app.getErrorString (Road_exit);
	elseif type = VisitRecord_Turnaround then
		return app.getErrorString (XLAT_Turnaround);
	elseif type = VisitRecord_Cancel then
		return app.getErrorString (Cancelled_At_Gate);
	elseif type = VisitRecord_Deleted_Entry then	//18 Feb 2011	NDL par 27046
		return app.getErrorString (Item_deleted);
	elseif type = VisitRecord_AssignRFIDTag then
		return app.getErrorString(Assign_rfid);
	elseif type = VisitRecord_DeassignRFIDTag then
		return app.getErrorString(Unassign_rfid);
		
	elseif type = VisitRecord_ArriveSecurityGate then				// PAR #32849
		return app.getErrorString(Arrival_security_gate);			// PAR #32849
	elseif type = VisitRecord_DepartSecurityGate then				// PAR #32849
		return app.getErrorString(Departure_security_gate);			// PAR #32849
	elseif type = VisitRecord_WeighBridge then	//19 Mar 2014	NDL	Par 33268			
		return app.getErrorString(Weighing);
	elseif type = VisitRecord_WeighBridgeIn then//epr TFS  44965 3/7/19	
		return app.getErrorString(Weighing_In);
	elseif type = VisitRecord_WeighBridgeOut then			
		return app.getErrorString(Weighing_Out);	
	elseif type = VisitRecord_SwapReleaseCargo then
		//epr par 34174 23/5/14
		return app.getErrorString(Swap_release_cargo);
	elseif type = VisitRecord_WayBillPrint then	//26 Aug 2015	NDL	Par 36677
		return app.getErrorString(Waybill_report);
	elseif type = VisitRecord_Bulk_In then	//10 Nov 2016	NDL	TFS 2867 / 2779
		return  app.getErrorString(Bulk_gate_in);
	elseif type = VisitRecord_Bulk_Out then	//10 Nov 2016	NDL	TFS 2867 / 2779
		return  app.getErrorString(Bulk_gate_out);
	elseif type = VisitRecord_TruckGrsWeightIn then		// 20/6/17 MAP TFS4273
		return app.getErrorString(Vehicle_gross_inward);
	elseif type = VisitRecord_TruckGrsWeightOut then	// 20/6/17 MAP TFS4273
		return app.getErrorString(Vehicle_gross_outward);
	elseif type = VisitRecord_SealAdd then			// TFS 57098
		return app.getErrorString(Seal_applied);
	elseif type = VisitRecord_SealCheck then		// TFS 57098
		return app.getErrorString(Seal_checked);
	elseif type = VisitRecord_SealDelete then		// TFS 57098
		return app.getErrorString(Seal_removed);
	elseif type = VisitRecord_JobStart then //13/03/2024	navkc1 CR 62890 Task 62893
		return app.getErrorString(Visit_record_start);
	elseif type = VisitRecord_JobStop then //13/03/2024	navkc1 CR 62890 Task 62893
		return app.getErrorString(Visit_record_stop);
	elseif type = VisitRecord_JobResume then //13/03/2024	navkc1 CR 62890 Task 62893
		return app.getErrorString(Visit_record_resume);
	elseif type = VisitRecord_JobComplete then //13/03/2024	navkc1 CR 62890 Task 62893
		return app.getErrorString(Visit_record_complete);
	else
		return "";
	endif;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
