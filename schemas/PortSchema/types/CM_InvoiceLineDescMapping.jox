    <JadeMethod name="shouldAuditProperty" id="0aa4b314-30d3-4c4f-8ed9-6d3b1dd6a507">
        <source>shouldAuditProperty(_rootClass: Class; _property: Property): Boolean protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 December 2016	cnwma1	Initial creation

*/

	vars
		propName	: String;
begin
	if _property = null then
		return false;
	endif;
	
	propName := _property.name;
	
	if	propName = CM_InvoiceLineDescMapping::myChildQuantityMap.name   or 
		propName = CM_InvoiceLineDescMapping::myInvoiceLineDesc.name or 
		propName = CM_InvoiceLineDescMapping::myInvoiceType.name
		then
		return false;
	else
		return inheritMethod(_rootClass, _property);
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="_rootClass" type="Class"/>
        <Parameter name="_property" type="Property"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validateForCreate" id="8a1e0982-c663-4f58-a72c-cb25007948bc">
        <source>validateForCreate();
// ---------------------------------------------------------------------------
// Created:		October 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	aDebtor : CM_Debtor; 
	aLine : CM_InvoiceLineDesc; 
	aType : CM_InvoiceDesc;
	aMap : CM_InvoiceLineDescMapping;
	blnReturn : Boolean;
begin
	aDebtor := self.myDebtor;
	aLine := self.myInvoiceLineDesc;
	aType := self.myInvoiceType;
	// dh 14/11/2007 par 14451 added the following three checks:
	if aDebtor = null then
//		app.raiseCMException1(REQUIRED_FIELD, 'debtor', ETRow_Hatch, null);
		app.raiseCMException(Input_required_field_debtor, ETRow_Hatch, null); // cnwdb2	PAR 35364
		blnReturn := true;
	endif;
	if aLine = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'invoice line', ETRow_Hatch, null);
		app.raiseCMException(Input_required_field_invLine, ETRow_Hatch, null); 
		blnReturn := true;
	endif;	
	if aType = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'invoice type', ETRow_Hatch, null);
		app.raiseCMException(Input_required_field_invType, ETRow_Hatch, null); // cnwdb2	PAR 35364
		blnReturn := true;
	endif;
	// dh end of changes
	if blnReturn then
		return;
	endif;
	aMap := self.myBank.allInvoiceLineDescMappings[aDebtor,aLine,aType];
	if aMap &lt;&gt; null then
		app.raiseCMException2(ERR_INVALID_VALUE, "Mapping", 
				"A mapping for " &amp; aDebtor.name &amp; "/" &amp; aLine.narration &amp; "/" &amp; aType.description &amp; " already exists.", null, null);
	endif;

	if aLine.amIMappedForDebtor(aDebtor) then
		aType := aLine.getInvoiceType(aDebtor);
		app.raiseCMException2(ERR_INVALID_VALUE, "Mapping", 
				"A mapping for Invoice Line Desc '" &amp; aLine.narration &amp; "' for debtor '" &amp; aDebtor.name  &amp; "' already exists. " 
							&amp; "It is mapped to " &amp; aType.description &amp; ". Delete this mapping first then add.", null, null);
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="validateForDelete" id="910c05d2-2f75-4eba-b3d8-4377c111d9c1">
        <source>validateForDelete();
// ---------------------------------------------------------------------------
// Created:		October 2004 By Andrew Bishop cnwab1
