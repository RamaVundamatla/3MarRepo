<Class name="CM_ITSInterfaceReqDelQEntry" id="3f711965-b44f-45f5-838b-c3af8617dbc8">
    <superclass name="CM_ITSInterfaceRequestInternal"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>Created when an RT Queue Entry is deleted.

This will trigger JMT to clean up the ITS interface for the deleted RT Queue Entry.</text>
    <DbClassMap file="jmtinterface"/>
    <PrimAttribute name="queueEntryID" id="e7e7f924-9d65-40a2-bb0d-2d4b055682ee">
        <embedded/>
        <type name="Integer"/>
        <access>readonly</access>
    </PrimAttribute>
    <JadeMethod name="populateCmifMessage" id="8291aee4-d916-40b3-b95d-940c2f801063">
        <source>populateCmifMessage(_cmifMsg: CMIF_ITSInterfaceMsg input; _validateFormat: Boolean);

/*

Purpose:			Get property values that may be stored in xml data.

Parameters:			_validateFormat - if true, an exception will be raised when invalid xml data is encountered.

Return Value:		_cmifMsg will be populated with values from message.


Date		Who		Reason
08 Dec 2009	consw1	PAR #21593 - Development of CCMS MES 1014 - RDT ITS Interface

*/

vars

begin
	inheritMethod(_cmifMsg, _validateFormat);
	
	_cmifMsg.messageType	:= ITS_MESSAGETYPE_INTERNALDELQE;
	_cmifMsg.queueEntryId 	:= self.queueEntryID;

epilog

end;</source>
        <Parameter name="_cmifMsg" type="CMIF_ITSInterfaceMsg" usage="input"/>
        <Parameter name="_validateFormat" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="30e527f1-1f04-4065-8cf9-96ec297a9c0d">
        <updating/>
        <source>setForCreate(_pxyObject: CM_ITSInterfaceReqDelQEntry; _passport : CM_Passport input) updating;

/*

Purpose:			

Parameters:			None

Return Value:		None


Date		Who		Reason
26 Nov 2009	consw1	PAR #21593 - Development of CCMS MES 1014 - RDT ITS Interface

*/

vars

begin
	self.queueEntryID	:= _pxyObject.queueEntryID;

	inheritMethod(_pxyObject, _passport);

epilog

end;</source>
        <Parameter name="_pxyObject" type="CM_ITSInterfaceReqDelQEntry"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="63fc484f-6c17-426f-a235-c02e0a556cc5">
        <updating/>
        <source>setProxy(	_queueEntryID	: Integer;
			_interfaceDefn	: CM_ITSInterfaceDefinition	) updating;

/*

Purpose:			Standard method for setting the proxy object's properties.

Parameters:			The instance id for the queue entry that has been deleted.

Return Value:		None


Date		Who		Reason
26 Nov 2009	consw1	PAR #21593 - Development of CCMS MES 1014 - RDT ITS Interface

*/

vars

begin
	self.createdTS		:= app.actualTimeServer();
	self.priority		:= self.Priority_Low;
	self.queueEntryID	:= _queueEntryID;

	self.myUser			:= null;
	self.myMachine		:= null;
	
	self.myITSInterfaceDefinition := _interfaceDefn;
	
epilog

end;</source>
        <Parameter name="_queueEntryID" type="Integer"/>
        <Parameter name="_interfaceDefn" type="CM_ITSInterfaceDefinition"/>
    </JadeMethod>
</Class>
