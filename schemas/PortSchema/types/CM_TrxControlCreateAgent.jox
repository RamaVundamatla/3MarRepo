    <JadeMethod name="trxCreateDestToDischargePort" id="a4ff5d5a-06bd-4311-92c8-9049fc5e64fb">
        <updating/>
        <source>trxCreateDestToDischargePort(_operator : CM_Operator; _shippingLine : CM_ShippingLine; _destPort, _dischPort : CM_Port; _passport : CM_Passport input) updating;

vars
	operShippingLine : CM_OperatorShippingLine;
	_proxyOperShippingLine : CM_OperatorShippingLine;
	_proxyDestToDischargePort : CM_DestinationToDischargePort;
	newDestToDischargePort : CM_DestinationToDischargePort;
begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	app.setContinueCMExceptions(true);

	operShippingLine := app.myRoot.allOperatorShippingLines[_operator, _shippingLine];
	if operShippingLine = null then
		create _proxyOperShippingLine as CM_OperatorShippingLine transient;
		_proxyOperShippingLine.setProxy(_operator, _shippingLine);
		app.myValCA.valOperatorShippingLine(_proxyOperShippingLine);
		if not self.checkValidationWithPassport(_passport) then
			return;
		endif;
	endif;

	create _proxyDestToDischargePort as CM_DestinationToDischargePort transient;
	_proxyDestToDischargePort.setProxy(_destPort, _dischPort);
	app.myValCA.valDestinationToDischargePort(_proxyDestToDischargePort, operShippingLine);
	
	endLoad;		// explicitly release any locks
	
	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;

	_passport.useTIDictDeferUpdate := true;
	_passport.useTITransactionDeferUpdate := true;

	beginTransaction;
	if operShippingLine = null then
		app.myUtilityCA.utlCreateOperShippingLine(_proxyOperShippingLine, operShippingLine, _passport);	
	endif;
	app.myUtilityCA.utlCreateDestToDischargePort(_proxyDestToDischargePort, newDestToDischargePort, operShippingLine, _passport);	

	_passport.doDeferredUpdates();
	
epilog
	self.finaliseActivityWithPassport(_passport);		
end;</source>
        <Parameter name="_operator" type="CM_Operator"/>
        <Parameter name="_shippingLine" type="CM_ShippingLine"/>
        <Parameter name="_destPort" type="CM_Port"/>
        <Parameter name="_dischPort" type="CM_Port"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxCreateDocketError" id="03e33cd9-eefc-4c70-b34b-ff136e2407c2">
        <updating/>
        <source>trxCreateDocketError(_proxyDocketError : CM_DocketError input; 
				_newDocketError : CM_DocketError output;
				_passport : CM_Passport input) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
01 February 2010	cnwas3	Initial creation

*/


vars

begin
// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	app.setContinueCMExceptions(false);
	// Start the transaction
	beginTransaction;

	// Perform the operation
	app.myUtilityCA.utlCreateDocketError(_proxyDocketError,_newDocketError,_passport);
	
	if _passport.noErrors then
		app.myUtilityCA.myCreateAuditAgent.audCreateGeneric(_newDocketError);
	endif;
	
epilog
	self.finaliseActivityWithPassport(_passport);
end;</source>
        <Parameter name="_proxyDocketError" type="CM_DocketError" usage="input"/>
        <Parameter name="_newDocketError" type="CM_DocketError" usage="output"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxCreateDocketErrorType" id="c0d70fd5-6077-4b2a-bbe1-6ee5d093a51f">
        <updating/>
        <source>trxCreateDocketErrorType(_proxyLogDocketError : CM_DocketErrorType input; 
				_newLogDocketError : CM_DocketErrorType output;
				_passport : CM_Passport input) updating;
/*Purpose:			

Parameters:			

Return Value:		
Date		Who		Reason
27 January 2010	cnwas3	Initial creation ccms 1110
*/
vars

begin
// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	app.setContinueCMExceptions(false);
	// Start the transaction
	beginTransaction;

	// Perform the operation
	self.raiseExceptionIfNull(_proxyLogDocketError, app.getErrorString(Docket_error_proxy));
	_proxyLogDocketError.raiseExceptionIfNotTransient(method);

	_proxyLogDocketError.validateForCreate();

	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	
	app.setContinueCMExceptions(false);

	create _newLogDocketError persistent;
	_newLogDocketError.setForCreate(_proxyLogDocketError);
	
	if _passport.noErrors then
		app.myUtilityCA.myCreateAuditAgent.audCreateGeneric(_newLogDocketError);
	endif;
	
epilog
	self.finaliseActivityWithPassport(_passport);
end;</source>
        <Parameter name="_proxyLogDocketError" type="CM_DocketErrorType" usage="input"/>
        <Parameter name="_newLogDocketError" type="CM_DocketErrorType" usage="output"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxCreateDoorDirectionRule" id="ad6ca59d-a3a2-4032-ad86-9875c420d4a7">
        <updating/>
        <source>trxCreateDoorDirectionRule(_pxyDDRule : CM_DoorDirectionRule; _realDDRule : CM_DoorDirectionRule output; _lcSet : CM_LCSet input; _passport : CM_Passport input) updating;

// cnwdvb1 15 January 2003 

vars
	aTA : CM_TerminalArea;

begin

	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do self.agtPassportExHandler(exception, _passport);
	on LockException do self.agtPassportLockExHandler(exception, _passport);


	app.setContinueCMExceptions(true);
	
	app.myValUA.valDoorDirectionRule(_pxyDDRule, _lcSet);
	
	if not _passport.noErrors() then
		return;
	endif;
		
	// Start the transaction
	beginTransaction;
	app.myUtilityCA.utlCreateDoorDirectionRule(_pxyDDRule, _realDDRule, _lcSet, _passport);

	if _passport.noErrors() then
		aTA := _realDDRule.myTerminalArea;
		aTA.causeEvent( aTA.myTerminal.getTerminalEvent(Event_TALocation_Create), false, _realDDRule );
	endif;

epilog
	self.finaliseActivityWithPassport(_passport);
end;</source>
        <Parameter name="_pxyDDRule" type="CM_DoorDirectionRule"/>
        <Parameter name="_realDDRule" type="CM_DoorDirectionRule" usage="output"/>
        <Parameter name="_lcSet" type="CM_LCSet" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
