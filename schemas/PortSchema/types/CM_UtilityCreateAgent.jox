    <JadeMethod name="utlCreateGateScanRecord" id="486c8256-7d61-45a5-b589-3bf075479207">
        <source>utlCreateGateScanRecord(_pxyGateScanRecord : CM_GenericGateScanRecord; _newGateScanRecord: CM_GenericGateScanRecord output; _passport : CM_Passport input);
/*

Purpose:			Utility to create a new GateScan Record from Proxy object passed in and gives a new gate scan record out

Parameters:			_pxyGateScanRecord	CM_GenericGateScanRecord	Proxy gate scan record to create real object from (Input meaning it gets passed in as a constant)
					_newGateScanRecord	CM_GenericGateScanRecord	Real gate scan record created (Output meaning it is passed outwards)
					_passport			CM_Passport					Passport to use for our Trx that holds errors and other useful data

Return Value:		NONE

Date		Who		Reason
14 February 2022	navpw1	Initial creation TFS: 52773

*/

vars
	expectedEdition : Integer;

begin
	self.initialiseActivity();
	
	_pxyGateScanRecord.raiseExceptionIfNotTransient(method);
	
	app.setContinueCMExceptions(true);

	app.myValCA.valGateScanRecord(_pxyGateScanRecord);
	
	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;

	app.setContinueCMExceptions(false);

	create _newGateScanRecord persistent;
	_newGateScanRecord.setForCreate(_pxyGateScanRecord);
	
	if _passport.noErrors then
		self.myCreateAuditAgent.audCreateGeneric(_newGateScanRecord);
	endif;
	
	// ### TFS 54311 18Oct2022 NAVPW1
	if _passport.noErrors then
		_passport.myTerminal.causeEvent(_passport.myTerminal.getTerminalEvent(EVENT_GATESCAN_CREATE),false, _newGateScanRecord);
	endif;
	// ### TFS 54311 18Oct2022 NAVPW1
	
end;</source>
        <Parameter name="_pxyGateScanRecord" type="CM_GenericGateScanRecord"/>
        <Parameter name="_newGateScanRecord" type="CM_GenericGateScanRecord" usage="output"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
