    <JadeMethod name="trxUpdateTITransaction" id="d6a32764-6178-4731-a415-ab0ff90a452d">
        <updating/>
        <source>trxUpdateTITransaction(_tiTransactionController:CMIF_TITransactionController input; 
				_origTrans :CM_TITransaction input;
				_passport : CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:		October  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	previousTrans : CM_TITransaction;
begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);
	
	app.setContinueCMExceptions(false);
	// Start the transaction
	beginTransaction;

	// Perform the operation
	app.myUtilityUA.utlUpdateTITransaction(_tiTransactionController, _origTrans, _passport);
	
	//epr TFS 2996 8/12/16
	if not _passport.hasErrors then
		if _origTrans.previousVersions &lt;&gt; null and _origTrans.previousVersions.size  &gt; 0 then
			previousTrans:= _origTrans.previousVersions[1];
			if previousTrans &lt;&gt; null then
				previousTrans.setExtraData(TrnsExtraDataAuditInfo,"User Edited transaction" );
			endif;
		endif;
	endif;
	
	
epilog
	self.finaliseActivityWithPassport(_passport);
end;</source>
