begin

	return false;

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="lookupAllTIsUsingIdCargoType" id="cf0b5779-e028-4c62-a67d-8937f416435e">
        <source>lookupAllTIsUsingIdCargoType(pId: String; pCargoType: Integer; _set: CM_TISet input; _cmifMonitor : CMIF_Monitor input) : Boolean;
/*
 ------------------------------------------------------------------------
Created:			18 October 2002 by cnwdwq1
Purpose:			This can be used on the dicts that have ID and cargoType only
							as the keys.  If cargoType = TI_CargoType_Null then 
							return ALL LIKE TI with this id
Parameters:		None
Returns:			Nothing
Changed On		Changed By		Reason
--------------		--------------		-----------------------------------------
---------------------------------------------------------------------------
*/
vars
	tmpTI	: CM_TrackedItem;
	iter	: Iterator;
	keyId	: String;
	keyType	: Integer;
begin
	if _set = null then
		app.raiseCMException2(MethodWithNullParam, method.name, 'TISet', null, null);
		return false;
	endif;

	iter := self.createIterator;
	self.startKeyGeq(pId, pCargoType, iter);
	
	while iter.next(tmpTI) do
		if _cmifMonitor &lt;&gt; null then
			if (not self.checkProgress(_cmifMonitor)) then
				return false;
			endif;
		endif;
		iter.getCurrentKeys(keyId, keyType);
		if pId &lt;&gt; null and (not keyId.startsWith(pId))  then
			break;
		endif;
		if pCargoType &lt;&gt; TI_CargoType_Null and keyType &lt;&gt; pCargoType then
			// Changed so ti is ignored but search doesn't stop until the id doesn't match.
			// Was missing out items where the supplied key was short. ie 4 characters.
			continue;
		endif;

		/*
		if not keyId.startsWith(pId)  then
			continue;
		endif;
		if keyType &lt;&gt; pCargoType then
			continue;
		endif;
		*/
		_set.addNoDuplicates(tmpTI, false);
		if _cmifMonitor &lt;&gt; null then
			_cmifMonitor.numFound := _cmifMonitor.numFound + 1;
		endif;
	endwhile;
	
	return true;
epilog
	delete iter;
end;</source>
        <Parameter name="pId" type="String"/>
        <Parameter name="pCargoType" type="Integer"/>
        <Parameter name="_set" type="CM_TISet" usage="input"/>
        <Parameter name="_cmifMonitor" type="CMIF_Monitor" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="lookupTIUsingIDExact" id="679327e7-f07c-422e-b05b-2967e40563f2">
        <source>lookupTIUsingIDExact(pId: String): CM_TrackedItem;
/*
	Created on 11 April 2008
	
	by Debby Hutchison
	
	Purpose:

Date		Who		Reason
23 Dec 2010	cnwkpd1	PAR #26678 - Tidy up transient leaks

*/

vars
	tmpTI	: CM_TrackedItem;
	id		: String;
	iter 	: Iterator;
begin
	iter := createIterator;
	startKeyGeq(pId, null, iter);
	while iter.next(tmpTI) do
		if tmpTI.id = pId then
			return tmpTI;
		endif;
		if tmpTI.id &gt; pId then
			break;
		endif;
	endwhile;
	return null;
	
epilog
	delete iter;		// PAR #26678
end;</source>
        <Parameter name="pId" type="String"/>
        <ReturnType type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="lookupTIUsingIdCargoType" id="862b53ca-67a0-4476-b868-ec667669a123">
        <source>lookupTIUsingIdCargoType(pId: String; pCargoType: Integer): CM_TrackedItem;
/*
 ------------------------------------------------------------------------
Created:			18 October 2002 by cnwdwq1
Purpose:			
Parameters:		None
Returns:			Nothing
Changed On		Changed By		Reason
--------------		--------------		-----------------------------------------
---------------------------------------------------------------------------
*/
vars

	tmpTI	: CM_TrackedItem;
	id		: String;

begin

	if pCargoType &lt;&gt; TI_CargoType_Null then
		tmpTI := self[pId, pCargoType];
		return tmpTI;
	endif;
	
	tmpTI := self.getAtKeyGeq(pId, pCargoType);
//not checking key
	if tmpTI = null then
		return null;	//Make it a bit obvious
	endif;

	// DVB Changed to get correct match. Use reverse key if necessary to work out if
	// we have the correct ti 30/10/03
	if self.isReversed then
		id := tmpTI.idReversed;
	else
		id := tmpTI.id;
	endif;

	if pId &lt;&gt; null and pId.length() &gt; 0 and id[1:pId.length] = pId then
		return tmpTI;
	endif;
	return null;
end;</source>
        <Parameter name="pId" type="String"/>
        <Parameter name="pCargoType" type="Integer"/>
        <ReturnType type="CM_TrackedItem"/>
    </JadeMethod>
</CollClass>
