    <JadeMethod name="processSystemShippingLines" id="5a744964-0265-4839-b35f-d4450575972c">
        <source>processSystemShippingLines(_userXMLElement : JadeXMLElement; _methodStr : String io);

/*

Purpose:		Create / Add required shipping lines	

Date			Who		Reason
23/02/2012		cnwmh5	Initial creation

*/

vars

	xmlElement				: JadeXMLElement;
	obj						: Object;
	
	varsStr					: String;
	codeStr					: String;
	epilogStr				: String;
	
	description				: String;
	code					: String;
	
begin
			
	foreach obj in _userXMLElement.childNodes do
		xmlElement := obj.JadeXMLElement;
		code := self.returnElementText(xmlElement.getElementByTagName('code')).String;
		description := self.returnElementText(xmlElement.getElementByTagName('description')).String;
		codeStr := codeStr &amp; Tab &amp; 'self.addShippingLine(' &amp; code &amp; ', ' &amp; description &amp; ', false);' &amp; CrLf;
	endforeach;
	
	_methodStr.cnReplaceString('&lt;^%vars^%&gt;', varsStr);
	_methodStr.cnReplaceString('&lt;^%code^%&gt;', codeStr);
	_methodStr.cnReplaceString('&lt;^%epilog^%&gt;', epilogStr);
	
epilog

end;
</source>
