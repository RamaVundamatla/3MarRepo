    <JadeMethod name="doSave" id="a6dec789-5d02-43db-93cf-db3e708b2ba1">
        <updating/>
        <source>doSave(): Boolean updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 June 2022	navds20	ChangeRequest 53862: EUP - WMS - Damage Recording Extra Details

*/


vars
	theForm 				: SOP_TableMaintForm;
	tbl						: CM_EntryTable;
	code,
	description				: String;
	isNotAvailableForEntry 	: Boolean;
	pxyDamageParty,
	newDamageParty		: CM_DamageParty;
	terminal				:CM_Terminal;
begin
	theForm := self.myForm;
	tbl := theForm.tblInput1;
	
	code := tbl.getValueByName(ETRow_Code).String;
	description := tbl.getValueByName(ETRow_Description).String;
	isNotAvailableForEntry := tbl.getValueByName(ETRow_IsNotAvailableForEntry).Boolean;
	terminal			   := self.myForm.myTerminal;
	
	if theForm.myProxyObject = null then
		if theForm.mode = theForm.Mode_Add then
			create theForm.myProxyObject as CM_DamageParty transient;
		else
			app.raiseUnexpectedProgramError(class.name, method.name, 'Proxy object null for update');
			return false;
		endif;
	endif;
	
	pxyDamageParty := theForm.myProxyObject.CM_DamageParty;
	pxyDamageParty.setProxy(code, description, isNotAvailableForEntry,terminal);
	
	if theForm.mode = theForm.Mode_Add then
		app.myTrxCA.trxCreateDamageParty(pxyDamageParty, newDamageParty, app.myPassport);
	elseif theForm.mode = theForm.Mode_Update then
		app.myTrxUA.trxUpdateDamageParty(pxyDamageParty, app.myPassport);
	endif;
	
	return app.myPassport.trxCompletedOK();
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getCollection" id="fdae9727-7bea-42ee-abe5-34879f4aef53">
