    <JadeMethod name="addObjectsToTable" id="70a9db04-a70c-40fe-a8df-e11fc272e566">
        <updating/>
        <source>addObjectsToTable(_numItems: Integer io) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date				Who			Reason
02 September 2008	concms1:1	User definable forms

*/

vars
	config		: CM_FormConfigForm;
	breakOut 	: Boolean;
begin
	foreach config in CM_FormConfigForm.instances do
		self.addObjectToTable(config, _numItems, breakOut);
		
		if breakOut then
			break;
		endif;
	endforeach;

epilog

end;</source>
        <Parameter name="_numItems" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="btnEditTV_click" id="cdbe55d5-a60b-4d5c-b4f2-f82f1d22b977">
        <updating/>
        <source>btnEditTV_click(btn: Button input) updating;
// ---------------------------------------------------------------------------
// Created:     02 September 2008 by concms1:1
//
// Purpose:     User definable forms - CCMS 1011
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	form	: Form;
	config	: CM_FormConfigForm;
begin
	if self.myCurrentObject = null then
		return;
	endif;
	

	if self.tblData.allSelectedObjects.size &gt; 1 then
   		app.msgBox('You must select only ONE item to edit', 'Error', MsgBox_OK_Only + MsgBox_Information_Icon);
   		return;
	endif;
	
	config	:= self.myCurrentObject.CM_FormConfigForm;
	form	:= app.loadForm(SOP_FormConfigCustomiseForm, self.myAssistant.class, false, false ,true ,self.myTerminal, null);

	if form = null or config = null then
		return;
	endif;
	
	form.SOP_FormConfigCustomiseForm.setMyFormConfiguration (config);
	
	form.show;
epilog

end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
