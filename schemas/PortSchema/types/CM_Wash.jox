    <JadeMethod name="setForDelete" id="4272a6f5-c507-475c-beb9-88bb642a5e7c">
        <updating/>
        <source>setForDelete(_reason: String) updating;

vars
	clean:Boolean;
begin
	inheritMethod(_reason);
	if self.myTrackedItem.cargoType = TI_CargoType_Container then
		self.myTrackedItem.setWashDetails(clean); //set the container dirty
	endif;
end;</source>
        <Parameter name="_reason" type="String"/>
    </JadeMethod>
    <JadeMethod name="updateTI" id="34c64629-5069-4163-9ba7-62633bdb8970">
        <updating/>
        <source>updateTI(_passport : CM_Passport input) updating;

vars
	isClean:Boolean;
begin
	inheritMethod(_passport);
	if self.myTrackedItem = null then
		return;
	endif;
	isClean := true;
	self.myTrackedItem.setWashDetails(isClean);

end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
</Class>
