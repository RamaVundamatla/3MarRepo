<Class name="DEV_ExternalMethod" id="9474e02b-9d00-45b5-8a95-2b83c8ee9479">
    <superclass name="DEV_SchemaObjectEntity"/>
    <transient/>
    <sharedTransientAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="dev"/>
    <PrimAttribute name="description" id="694d78f1-fb53-4489-b3ca-d95ca0233f41">
        <type name="String"/>
        <access>readonly</access>
    </PrimAttribute>
    <ExplicitInverseRef name="myClass" id="e75e16f9-1c88-4ca8-9e9e-cf5190bde705">
        <kind>child</kind>
        <updateMode>manual</updateMode>
        <embedded/>
        <type name="DEV_Class"/>
        <access>readonly</access>
        <Inverse name="DEV_Class::allExternalMethods"/>
        <Inverse name="DEV_Class::allExternalMethodsOrd"/>
    </ExplicitInverseRef>
    <JadeMethod name="create" id="b071e863-7065-4afe-817e-83055b78e37f">
        <updating/>
        <source>create(_name, 
		_description	: String;
		_class 			: DEV_Class) ::super(_name) updating;
/*

Purpose:			Constructor for DEV_ExternalMethod class

Parameters:			_name:					The name of the external method
					_description:			The description of the external method
					_class:					The class object the external method belongs to

Return Value:		

Date		Who		Reason
10 November 2021	navpw1	Initial creation TFS: 52202

*/

begin
	//Set Attributes
	self.name				:= _name;
	self.description		:= _description;
	
	//Set References
	self.myClass 			:= _class;
	
end;</source>
        <Parameter name="_name" type="String"/>
        <Parameter name="_description" type="String"/>
        <Parameter name="_class" type="DEV_Class"/>
    </JadeMethod>
    <JadeMethod name="update" id="517bf48b-596a-46f7-980a-47d13de45330">
        <updating/>
        <source>update(_description : String) updating;
/*

Purpose:			Update method for DEV_ExternalMethod class (Sets optional attributes)

Parameters:			_description:		The description of the external method

Return Value:		

Date		Who		Reason
10 November 2021	navpw1	Initial creation TFS: 52202

*/

begin
	self.description		:= _description;

end;</source>
        <Parameter name="_description" type="String"/>
    </JadeMethod>
</Class>
