<Class name="CM_EDIPartyQatarRules" id="2362a6e1-35fe-40c6-9556-fdb9b16ff5c9">
    <superclass name="CM_EDIPartyRules"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="edi"/>
    <JadeMethod name="create" id="f07384d1-61c4-4671-a864-c562c3a7e986">
        <updating/>
        <source>create() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 June 2015	cnwndl1	Initial creation	Par 36543

*/

vars
	type	:CM_EDIFileType;
begin
	// set file type
	type := app.myRoot.allEDIFileTypes.getAtKeyGeq(EDIFileType_XML_Milaha_Customs, null);
	
	if type = null or type.type &lt;&gt; EDIFileType_XML_Milaha_Customs then
		app.raiseUnexpectedProgramError (self.class.name, method.name, 'Milaha Custom file type missing');
	endif;
	
	self.myEDIFileType	:= type;
epilog

end;</source>
    </JadeMethod>
</Class>
