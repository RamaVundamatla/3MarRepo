    <JadeMethod name="validateForUpdate" id="8681b70b-90fb-4c09-a6ea-bae4cf446a43">
        <source>validateForUpdate(pProxyTransaction : CM_TITransaction);
// ---------------------------------------------------------------------------
// Created:     24 September 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//// 16 May 2016	cnwns1	TFS 488 - Multi Timezone Support
// ---------------------------------------------------------------------------
vars
	now				:Date;
	tmpTS			: TimeStamp;
begin
	now := app.actualTimeServer().date;// 16 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	
	if (not self.canUpdateTransaction()) then
		// must overide in sub-classes to allow updating
		app.raiseCMException(ERR_INVALID_TRANS_EDIT, null, null);
		return;
	endif;

	// Check the user has not changed any fields that cannot be changed
	if self.type &lt;&gt; pProxyTransaction.type then
		app.raiseCMException(ERR_INVALID_TRANS_EDIT, 'type', null);
	endif;
	
	if self.userId = null then
		app.raiseCMException(ERR_INVALID_TRANS_EDIT, 'userId', null);
	endif;
	
	if self.myTrackedItem &lt;&gt; pProxyTransaction.myTrackedItem then
		app.raiseCMException(ERR_INVALID_TRANS_EDIT, 'myTrackedItem', null);
	endif;

	if (not pProxyTransaction.dateTime.isValid()) or
	   pProxyTransaction.dateTime.date &gt; (now-(10*365.25).Integer)  or	//about 10yrs ago
	   pProxyTransaction.dateTime.date &lt; (now+92) then					// next 3 month
	//	app.raiseCMException1(REQUIRED_FIELD, 'dateTime', null, null);
		app.raiseCMException(Input_required_field_dateTime, null, null); // cnwdb2	PAR 35364
	endif;
	
	

end;</source>
        <Parameter name="pProxyTransaction" type="CM_TITransaction"/>
    </JadeMethod>
</Class>
