    <JadeMethod name="eprUpdateVPTerminal" id="04323401-58d7-4857-8144-36ba3abe5440">
        <source>eprUpdateVPTerminal();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 October 2021	jlier1	Initial creation

*/

vars

	terminal : CM_Terminal;

begin	

app.initialize();

	app.myPassport.setMyUser(CM_Root.firstInstance.allUsers[SUPERUSER_Str]);
	beginTransaction;
	// If the pelindo process was set as the default process, update to use mtnwo process
	foreach terminal in CM_Root.firstInstance.allTerminals do
		if terminal.getConfig(DefaultVoyageProcess).String = VoyageProcessPelindo1 then
			terminal.setConfig(DefaultVoyageProcess, VoyageProcessWO);
		elseif terminal.getConfig(DefaultVoyageProcess).String = "JMT" then
			terminal.setConfig(DefaultVoyageProcess, VoyageProcessDefault);
		endif;
	endforeach;
	
	commitTransaction;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="eptTestGateChecker" id="aef59920-f120-4e37-8d00-66ffd45982f0">
        <source>eptTestGateChecker();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 October 2017	jlger1	Initial creation

*/

vars


	idx : Integer;
	gate 			: CM_Gate;
	errmsg 			:String;
	gateArea 		: CM_TerminalArea;
	gateLane		: CM_LocationsController;
	terminal 		: CM_Terminal;
	gateCheckerController : CMIF_MobileGateChecker;
	truck 			: CM_Vehicle;
begin
		app.initialize();
	app.myPassport.setMyUserFromCode("CNWER1");
	
	terminal:=CM_Root.firstInstance.allTerminals["JBL"];
	gate := terminal.allGates["GATE_VTA"];
	create gateCheckerController transient;
	gateCheckerController.setMyTerminal(terminal);
	
	
	app.myPassport.setMyTerminal(terminal);
		truck := terminal.vehicles["HL001", null];
		gateCheckerController.setTruck(truck);
 gateArea:=terminal.getTAFromClassString("VTA_P Lane 7",idx,CM_GateArea);
	foreach  gateLane in gateArea.allLocationsControllers do
		if gateLane.isKindOf(CM_GateAreaLaneController) then
			if gateLane.getNiceName = "VTA_P Lane 7" then
				 	gateCheckerController.setGateAreaLaneController(gateLane.CM_GateAreaLaneController,false);
				break;
			endif;
	 endif;
	endforeach;
	
	write gateCheckerController.inward;
	gateCheckerController.doGateCheckerCompleteOutward();
	
	delete gateCheckerController;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="extractClientEDILicensesAsCSV" id="eaabc1e2-7671-4d74-b116-b43ac236ab6c">
        <source>extractClientEDILicensesAsCSV();
//24 October 2008	cnwdw1	
// Extract the licenses set for each client
vars
	ediAgent	: CM_EDIFileTypeAgent;
//	clientLicenseDetails, clientXML: String;
//	pos: Integer;
//	client: DEV_LicenseClient;
//	clients: DEV_LicenseClientByName;
//	clientNames: String;
