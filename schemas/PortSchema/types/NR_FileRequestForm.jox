    <JadeMethod name="clearAllClassesToCheck" id="47881446-2fad-4fd9-a405-75af1c1f7401">
        <source>clearAllClassesToCheck() protected;
// ---------------------------------------------------------------------------
// Created:     15 March 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	idx,
	numClasses	: Integer;
begin

	numClasses := self.lstCheck.listCount;
	
