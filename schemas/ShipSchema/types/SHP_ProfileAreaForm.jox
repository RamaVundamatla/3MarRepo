    <JadeMethod name="showTableStats" id="f51d644e-5164-44f1-bd6b-5196f95f9758">
        <source>showTableStats();
// ---------------------------------------------------------------------------
// Created:		December 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
constants
	WIDTHDATA = 150;
vars
	theTable					: Table;
	numColumns,idx,
	numCranes				: Integer;
	aJS 						: CM_VoyageJobSheet;
	tmpJobSheetStats			: CMIF_JobSheetStats;
begin

	foreach aJS in self.myCurrentVoyage.allJobSheets discreteLock do
		if aJS.allJobsByOrder.isEmpty then
			continue;
		endif;
		numCranes := numCranes + 1;
	endforeach;

	//epr 26/3/07 par 13730
	if numCranes &gt; 1 or numCranes = 0 then
		numColumns	:= numCranes  + 2; // PAR 8436
	else
		numColumns := numCranes + 1;
	endif;
	theTable := self.tblGridAreaInfo;
	theTable.columns := numColumns;
	
	foreach idx in 2 to numColumns do
		theTable.accessColumn(idx).width := WIDTHDATA;
		theTable.accessColumn(idx).backColor := self.colorValueColumn;
	endforeach;

	idx := 1; // PAR 8436
	if numCranes &gt; 1 or numCranes = 0 then // PAR 8436
		idx := 2;
		self.showTableStatsColumn(self.myVoyageStats,idx);
		 
	endif;
	// ##### EACH CRANE
	foreach aJS in self.myCurrentVoyage.allJobSheets discreteLock do
		if aJS.allJobsByOrder.isEmpty then // PAR 8436
			continue;
		endif;
		idx := idx + 1;
		
		tmpJobSheetStats := self.myVoyageStats.getJobSheetStatsForJobSheet(aJS);
		self.showTableStatsColumn(tmpJobSheetStats,idx);
		
	endforeach;
end;</source>
    </JadeMethod>
    <JadeMethod name="showTableStatsAB" id="61b63855-26e5-43a2-9ed5-1ad7f40cb070">
        <source>showTableStatsAB();
// ---------------------------------------------------------------------------
// Created:		December 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
constants
	WIDTHDATA = 160;
vars
	theTable					: Table;
	numColumns,idx,
	numCranes				: Integer;
	aJS 						: CM_VoyageJobSheet;
	tmpJobSheetStats			: CMIF_JobSheetStats;
begin
	foreach tmpJobSheetStats in self.myVoyageStats.allJobSheetStats discreteLock do
		numCranes := numCranes + 1;
	endforeach;

	//epr 26/3/07 par 13730
	if numCranes &gt; 1 or numCranes = 0 then
		numColumns	:= numCranes  + 2; // PAR 8436
	else
		numColumns := numCranes + 1;
	endif;
	theTable := self.tblGridAreaInfo;
	theTable.columns := numColumns;
	
	foreach idx in 2 to numColumns do
		theTable.accessColumn(idx).width := WIDTHDATA;
		theTable.accessColumn(idx).backColor := self.colorValueColumn;
	endforeach;

	idx := 1; // PAR 8436
	if numCranes &gt; 1 or numCranes = 0 then // PAR 8436
		idx := 2;
		self.showTableStatsColumn(self.myVoyageStats,idx);
		 
	endif;
	// ##### EACH CRANE
	foreach tmpJobSheetStats in self.myVoyageStats.allJobSheetStats discreteLock do
		idx := idx + 1;
		
		self.showTableStatsColumn(tmpJobSheetStats,idx);
		
	endforeach;
end;</source>
    </JadeMethod>
    <JadeMethod name="showTableStatsColumn" id="e89aafea-37f4-4b30-b27a-e5dc0aa426db">
        <source>showTableStatsColumn(_obj :  CMIF_Object input; _column : Integer) protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
12 September 2011	cnwer1	Initial creation CCMS MES 1033

*/

vars
	entRow : EntTableRow;
	row 	: Integer;
	str 	: String;
	theTable : CM_DataTable;
begin
	theTable:= self.tblGridAreaInfo;
	row:=1;
	while row &lt;= theTable.rows do
		entRow:=theTable.accessRow(row).itemObject.EntTableRow;
		str:= _obj.getDisplayStringForAttribute(entRow.name,false);	
		theTable.accessCell(row,_column).text:=str;
		
		if  _obj.isKindOf(CMIF_VoyageStats) then
			//epr par 31764 6/8/13
			if self.myCurrentVoyage &lt;&gt; null and self.myCurrentVoyage.myROROStructure = null and (entRow.name = ETRow_VolumeMoved 
				or  entRow.name = ETRow_VolumeToMove
				or entRow.name = ETRow_QuantityMoved
				or entRow.name = ETRow_QuantityToMove) then
				theTable.accessRow(row).visible:=false;		
			endif;
		endif;	
		row:=row + 1;
	endwhile;
	
	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_obj" type="CMIF_Object" usage="input"/>
        <Parameter name="_column" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="showTableStatsColumnLabels" id="f47c76ac-dd16-4120-9654-115dc93fd6ee">
        <source>showTableStatsColumnLabels() protected;
/* ---------------------------------------------------------------------------
// Created:		January 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
12 Sep 2011	cnwer1	CCMS 1239
*/

vars
	theTable : CM_DataTable;
	finIO : CM_ExtFinanceIO;
	entTableDef : EntTableDef;
	entTableRow : EntTableRow;
	tmpStr      : String;
	idx		: Integer;
	hideActualRate:	Boolean;
begin
	// PAR 11106
	finIO := self.myTerminal.getConfig(FinancialIOClass).CM_ExtFinanceIO;
	if finIO &lt;&gt; null then
		if finIO.class = CM_Greentree then
			hideActualRate:=true;
		endif;
	endif;
	
	theTable := self.tblGridAreaInfo;
	entTableDef:=app.myRoot.myEntTableDataRoot.allEntTableDefs[ETDef_SideProfileStats];
	foreach entTableRow in entTableDef.allEntTableRows do
		if hideActualRate and 	entTableRow.name =  ETRow_ActualRate then
			continue;
		endif;
		
		if not hasKPILicense and entTableRow.name = ETRow_NetRate then
			continue;
		endif;
		tmpStr := entTableRow.getShortHeading(null, self.myTerminal, app.myCurrentLocale);
		idx:=theTable.addItemObject(entTableRow,tmpStr);
		
	endforeach;
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="showTimings" id="6ca883a2-aeb6-4403-b4fc-d28f07ef9fad">
        <source>showTimings();
// ---------------------------------------------------------------------------
// Created:		03 April 2007 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	rlOverallProdRate : Real; //Overall Productivity Time
	rlOverallProdTime : Real ; // Overall Productivity Rate
	rlBerthage : Real ; //Berthage Time
	rlProdTime : Real;//Productivity Time
	rlProdRate : Real;// Productivity Rate
	rlGrsProdTime,
	rlGrsProdrate : Real;//Gross Productivity Time
	tsPilotOB,
	tsAtBerth,
	tsLabourOn,
	tsWorkStarted,
	tsWorkEnded,
	tsLabourOff,
	tsSailed,
	tsPilotReturn,
	tsAnchorDown: TimeStamp;
	rlBerthageTime : Real;
	voy : CM_Voyage;
	ave, stCol, endCol, posNeg, numOfDays, idx, totalTIs : Integer;
	aJS : CM_JobSheet;
	rlTotWorkingHrs : Real;
	rlTotDownHrs : Real;
	rlGrossOpHrs : Real;
	rlNetCraneHrs : Real;
begin
	if self.myCurrentVoyage = null then
		return;
	endif;
	//if  not app.myPassport.myUser.canDo(self.myTerminal, PmKPIModule) then
	if  not app.myPassport.myUser.canDo(self.myTerminal, Mod_BaseSystem) then//07 Oct 2019	NDL	TFS 46169
		return;
	endif;
	
	app.mousePointer := Window.MousePointer_HourGlass;
	self.tblTimings.rows := self.tblTimings.fixedRows;
	self.tblTimings.columns := 5;
	voy := self.myCurrentVoyage;
	foreach aJS in voy.allJobSheets discreteLock do
		totalTIs := totalTIs + aJS.CM_VoyageJobSheet.allShipReceivals.size;
		totalTIs := totalTIs + aJS.CM_VoyageJobSheet.allShipReleases.size;
	endforeach;
	tsPilotOB := self.systemToLocalTime(voy.pilotOnBoardDT);		// 20/5/16 cnwmp6 TFS 488 - Multi timezone support
	tsAtBerth := self.systemToLocalTime(voy.arrivedDT);
	tsLabourOn := self.systemToLocalTime(voy.labourOnBoard);
	tsWorkStarted := self.systemToLocalTime(voy.shipExchangeDate);
	tsWorkEnded := self.systemToLocalTime(voy.shipExchangeCompleteDT);
	tsLabourOff := self.systemToLocalTime(voy.labourOnShore);
	tsSailed := self.systemToLocalTime(voy.departedDT);
	tsPilotReturn := self.systemToLocalTime(voy.shipPilotReturnDT);
	tsAnchorDown := self.systemToLocalTime(voy.shipAnchorDownDT);

	self.showTimingsADD(null);
	self.showTimingsADD(app.getErrorString(PilotOnBoard) &amp; Tab &amp;
						tsPilotOB.shortCurrentLocaleFormat() &amp; Tab &amp;
						app.getErrorString(Overall_productivi_time) &amp; Tab &amp;
						"(" &amp; app.getErrorString(PilotOnBoard) &amp; " " &amp; app.getErrorString(To)&amp; " " &amp; app.getErrorString(Labour_ashore) &amp; ")" );
	self.showTimingsADD(app.getErrorString(Arrival) &amp; Tab &amp;
						tsAtBerth.shortCurrentLocaleFormat() &amp; Tab &amp; 
						app.getErrorString(Overall_productivi_rate)  &amp; Tab &amp;
						"(" &amp; totalTIs.String &amp; " " &amp; app.getErrorString(Containers) &amp; "/" &amp; app.getErrorString(Overall_productivi_time) &amp; ")") ; 											
	self.showTimingsADD(app.getErrorString(Labour_aboard) &amp; Tab &amp;
						tsLabourOn.shortCurrentLocaleFormat() &amp; Tab &amp;
						app.getErrorString(Berthage_time)  &amp; Tab &amp;
						"(" &amp; app.getErrorString(Anchor_down) &amp; " " &amp; app.getErrorString(To)&amp; " " &amp; app.getErrorString(Pilot_return) &amp; ")");
	self.showTimingsADD(app.getErrorString(Ship_exchange_start) &amp; Tab &amp;
						tsWorkStarted.shortCurrentLocaleFormat() &amp; Tab &amp; 
						app.getErrorString(Productivity_time)  &amp; Tab &amp;
						"(" &amp; app.getErrorString(Arrival) &amp; " " &amp; app.getErrorString(To)&amp; " " &amp; app.getErrorString(Labour_ashore) &amp; ")");
	self.showTimingsADD(app.getErrorString(Ship_exchange_finished) &amp; Tab &amp;
						tsWorkEnded.shortCurrentLocaleFormat() &amp; Tab &amp; 
						app.getErrorString(Productivity_rate)  &amp; Tab &amp;
						"(" &amp; totalTIs.String &amp; " " &amp; app.getErrorString(Containers) &amp; "/" &amp; app.getErrorString(Productivity_time) &amp; ")");
	self.showTimingsADD(app.getErrorString(Labour_ashore) &amp; Tab &amp;
						tsLabourOff.shortCurrentLocaleFormat() &amp; Tab &amp; 
						app.getErrorString(Gross_productivi_time)  &amp; Tab &amp;
						"(" &amp; app.getErrorString(Labour_aboard) &amp; " " &amp; app.getErrorString(To)&amp; " " &amp; app.getErrorString(Labour_ashore) &amp; ")");
	self.showTimingsADD(app.getErrorString(Departed) &amp; Tab &amp;
						tsSailed.shortCurrentLocaleFormat() &amp; Tab &amp; 
						app.getErrorString(Gross_productivi_rate)  &amp; Tab &amp;
						"(" &amp; totalTIs.String &amp; " " &amp; app.getErrorString(Containers) &amp; "/" &amp; app.getErrorString(Gross_productivi_time) &amp; ")");
	self.showTimingsADD(app.getErrorString(Anchor_down) &amp; Tab &amp;
						tsAnchorDown.shortCurrentLocaleFormat());
	self.showTimingsADD( app.getErrorString(Pilot_return) &amp; Tab &amp;
						tsPilotReturn.shortCurrentLocaleFormat());
	

	//04 Apr 2012	NDL	Par 29369
	self.showTimingsADD(null);
	self.showTimingsADD( app.getErrorString(Gross_operating_hrs) &amp; Tab &amp;
						Tab &amp;
						app.getErrorString(Potential_work_point) &amp; Tab &amp;
						"(" &amp; app.getErrorString(Total_working_hrs) &amp; " + " &amp; app.getErrorString(Total_down_time) &amp; ")");
	self.showTimingsADD( app.getErrorString(Total_working_hrs) &amp; Tab&amp; 
						Tab &amp;
						app.getErrorString(Work_point_operati_elapsed) &amp; Tab &amp;
						"(" &amp; app.getErrorString(Labour_aboard) &amp; " " &amp; " " &amp; app.getErrorString(To)&amp; " " &amp; " " &amp; app.getErrorString(Labour_ashore) &amp; " " &amp; app.getErrorString(Per_Work_point) &amp; ")");
	self.showTimingsADD( app.getErrorString(Total_down_time) &amp; Tab &amp;
						Tab &amp;
						app.getErrorString(Work_point_non_operating) &amp; Tab &amp;
						"(" &amp; app.getErrorString(Work_point_exchan_gaps_betwee) &amp; " '" &amp; app.getErrorString(Ship_exchange_start) &amp; "' &amp; '" &amp; app.getErrorString(Finished) &amp; "')");	
	self.showTimingsADD( app.getErrorString(Net_crane_operating_hrs) &amp; Tab &amp;
						Tab &amp;
						app.getErrorString(Net_Work_point_operating) &amp; Tab &amp;
						"(" &amp; app.getErrorString(Total_working_hrs) &amp; " - " &amp; app.getErrorString(Total_operationa_delays) &amp; ")");
	self.showTimingsADD(null);

	 // PAR 25719 NEW KPI 2010 CCMS SFW 1134
	self.showTimingsADD(app.getErrorString(Number_lashings) &amp; Tab &amp; voy.getNumLashings().String);
	self.showTimingsADD(app.getErrorString(Number_unlashings) &amp; Tab &amp; voy.getNumUnlashings().String);
	self.showTimingsADD(app.getErrorString(Number_cage_moves) &amp; Tab &amp; voy.getNumCageMoves().String);
	self.showTimingsADD(app.getErrorString(Number_extra_moves) &amp; Tab &amp; voy.getNumExtraMoves().String);
	self.showTimingsADD(app.getErrorString(Number_lashing_bin_moves) &amp; Tab &amp; voy.getNumLashingBinMoves().String);
	
	self.showTimingsVoyage(self.myCurrentVoyage);
	
	
	if self.myVesselVoyageController &lt;&gt; null then
		foreach voy in self.myVesselVoyageController.allVoyages do
			self.showTimingsVoyage(voy);
		endforeach;
	endif;
	
	
	stCol := 5;
	endCol := self.tblTimings.columns;
	ave := endCol - stCol;
	foreach idx in stCol to endCol do
		rlOverallProdRate := rlOverallProdRate + self.tblTimings.accessCell(3,idx).text.getRealFromText; //Overall Productivity Time
		rlOverallProdTime := rlOverallProdTime + self.tblTimings.accessCell(2,idx).text.getRealFromText; // Overall Productivity Rate
		rlBerthage := rlBerthage +  self.tblTimings.accessCell(4,idx).text.getRealFromText; //Berthage Time
		rlProdTime := rlProdTime +  self.tblTimings.accessCell(5,idx).text.getRealFromText;//Productivity Time
		rlProdRate := rlProdRate +  self.tblTimings.accessCell(6,idx).text.getRealFromText;// Productivity Rate
		rlGrsProdTime := rlGrsProdTime + self.tblTimings.accessCell(7,idx).text.getRealFromText; //Gross Productivity Time
		rlGrsProdrate := rlGrsProdrate +  self.tblTimings.accessCell(8,idx).text.getRealFromText;//Gross Productivity Rate
		//05 Apr 2012	NDL	Par 29369
		rlGrossOpHrs := rlGrossOpHrs +  self.tblTimings.accessCell(12,idx).text.getRealFromText;//Gross Op Hrs
		rlTotWorkingHrs := rlTotWorkingHrs +  self.tblTimings.accessCell(13,idx).text.getRealFromText;//Tot Working hrs
		rlTotDownHrs := rlTotDownHrs +  self.tblTimings.accessCell(14,idx).text.getRealFromText;// Tot Down Hrs
		rlNetCraneHrs := rlNetCraneHrs +  self.tblTimings.accessCell(15,idx).text.getRealFromText;//Net Crane Hrs
	endforeach;
	
	idx := self.tblTimings.columns + 1;
	self.tblTimings.columns := idx;
	self.tblTimings.accessCell(1,idx).text := app.getErrorString(AVERAGE);
	// PAR 22125 changed CM_Decimal1LeadingZero to CM_Decimal2LeadingZero
	self.tblTimings.accessCell(2,idx).text :=(rlOverallProdTime / ave).asStringJMTWithPrecision($CM_Decimal2LeadingZero.decimalPlaces, true).asStringJMT; //Overall Productivity Time
	self.tblTimings.accessCell(3,idx).text :=(rlOverallProdRate / ave).asStringJMTWithPrecision($CM_Decimal2LeadingZero.decimalPlaces, true).asStringJMT; // Overall Productivity Rate
	self.tblTimings.accessCell(4,idx).text :=(rlBerthageTime / ave).asStringJMTWithPrecision($CM_Decimal2LeadingZero.decimalPlaces, true).asStringJMT; //Berthage Time
	self.tblTimings.accessCell(5,idx).text :=(rlProdTime / ave).asStringJMTWithPrecision($CM_Decimal2LeadingZero.decimalPlaces, true).asStringJMT; //Productivity Time
	self.tblTimings.accessCell(6,idx).text :=(rlProdRate / ave).asStringJMTWithPrecision($CM_Decimal2LeadingZero.decimalPlaces, true).asStringJMT; // Productivity Rate
	self.tblTimings.accessCell(7,idx).text :=(rlGrsProdTime / ave).asStringJMTWithPrecision($CM_Decimal2LeadingZero.decimalPlaces, true).asStringJMT; //Gross Productivity Time
	self.tblTimings.accessCell(8,idx).text :=(rlGrsProdrate / ave).asStringJMTWithPrecision($CM_Decimal2LeadingZero.decimalPlaces, true).asStringJMT; //Gross Productivity Rate
	//05 Apr 2012	NDL	Par 29369
	self.tblTimings.accessCell(12,idx).text :=(rlGrossOpHrs / ave).asStringJMTWithPrecision($CM_Decimal2LeadingZero.decimalPlaces, true).asStringJMT;//Gross Op Hrs
	self.tblTimings.accessCell(13,idx).text :=(rlTotWorkingHrs / ave).asStringJMTWithPrecision($CM_Decimal2LeadingZero.decimalPlaces, true).asStringJMT;//Tot Working hrs
	self.tblTimings.accessCell(14,idx).text :=(rlTotDownHrs / ave).asStringJMTWithPrecision($CM_Decimal2LeadingZero.decimalPlaces, true).asStringJMT;// Tot Down Hrs
	self.tblTimings.accessCell(15,idx).text :=(rlNetCraneHrs / ave).asStringJMTWithPrecision($CM_Decimal2LeadingZero.decimalPlaces, true).asStringJMT;//Net Crane Hrs
	
	self.loadTblWPOpHrs();
	
epilog

	app.mousePointer := Window.MousePointer_Default;
end;</source>
    </JadeMethod>
    <JadeMethod name="showTimingsADD" id="ef066283-8c59-464d-9155-0892de198d53">
        <source>showTimingsADD(_text : String);
// ---------------------------------------------------------------------------
// Created:		13 September 2007 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	idx, back1, back2, tmp : Integer;
begin
	idx := self.tblTimings.addItem(_text);
	
	foreach tmp in 1 to 4 do
		self.tblTimings.accessCell(idx,tmp).itemObject := self.myCurrentVoyage;
	endforeach;
	
	if idx mod 2 = 0 then
		back1 := ColourLightGrey01;
		back2 := White;
	else
		back2 := ColourLightGrey01;
		back1 := White;
	
	endif;
	self.tblTimings.accessRow(idx).backColor := back1;
	self.tblTimings.accessedRow.foreColor := Black;
	self.tblTimings.accessCell(idx,3).backColor := back2;
	self.tblTimings.accessedCell.foreColor := Black;
	self.tblTimings.accessCell(idx,4).backColor := back2;
	self.tblTimings.accessedCell.foreColor := Black;

end;</source>
        <Parameter name="_text" type="String"/>
    </JadeMethod>
    <JadeMethod name="showTimingsVoyage" id="3f7b6c8d-ccf1-46d1-9aa5-969ea5cf122c">
        <source>showTimingsVoyage(_voy : CM_Voyage);
// ---------------------------------------------------------------------------
// Created:		13 September 2007 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars

	rlBerthageTime,
	rlOverallProdTime,
	rlOverallProdRate,
	rlProdTime,
	rlProdRate,
	rlGrsProdTime,
	rlGrsProdrate : Real;
	aJS : CM_JobSheet;
	tmp, idx, totalTIs : Integer;
	
	rlTotWorkingHrs : Real;
	rlTotDownHrs : Real;
	rlGrossOpHrs : Real;
	rlNetCraneHrs : Real;
	
begin
	
	rlOverallProdTime := _voy.getKPIOverallProductivityTime();
	rlOverallProdRate := _voy.getKPIOverallProductivityRate();
	rlBerthageTime := _voy.getKPIBerthageTime();
	rlProdTime := _voy.getKPIProductivityTime();
	rlProdRate := _voy.getKPIProductivityRate();
	rlGrsProdTime := _voy.getKPIGrossProductivityTime();
	rlGrsProdrate:= _voy.getKPIGrossProductivityRate();
	
	
	idx := self.tblTimings.columns + 1;
	self.tblTimings.columns := idx;
	self.tblTimings.accessCell(1,idx).text := _voy.code;
	self.tblTimings.accessCell(2,idx).text :=rlOverallProdTime.asStringJMTWithPrecision($CM_Decimal2LeadingZero.decimalPlaces, true).asStringJMT; //Overall Productivity Time
	self.tblTimings.accessCell(3,idx).text :=rlOverallProdRate.asStringJMTWithPrecision($CM_Decimal2LeadingZero.decimalPlaces, true).asStringJMT; // Overall Productivity Rate
	self.tblTimings.accessCell(4,idx).text :=rlBerthageTime.asStringJMTWithPrecision($CM_Decimal2LeadingZero.decimalPlaces, true).asStringJMT; //Berthage Time
	self.tblTimings.accessCell(5,idx).text :=rlProdTime.asStringJMTWithPrecision($CM_Decimal2LeadingZero.decimalPlaces, true).asStringJMT; //Productivity Time
	self.tblTimings.accessCell(6,idx).text :=rlProdRate.asStringJMTWithPrecision($CM_Decimal2LeadingZero.decimalPlaces, true).asStringJMT; // Productivity Rate
	self.tblTimings.accessCell(7,idx).text :=rlGrsProdTime.asStringJMTWithPrecision($CM_Decimal2LeadingZero.decimalPlaces, true).asStringJMT; //Gross Productivity Time
	self.tblTimings.accessCell(8,idx).text :=rlGrsProdrate.asStringJMTWithPrecision($CM_Decimal2LeadingZero.decimalPlaces, true).asStringJMT; //Gross Productivity Rate
	
	foreach tmp in 1 to 8 do
		self.tblTimings.accessCell(tmp,idx).itemObject := _voy;
	endforeach;
	
	//05 Apr 2012	NDL	Par 29369
	rlTotWorkingHrs := _voy.getWPOpHrsTotalWorkHrs();
	rlTotDownHrs := _voy.getWPOpHrsTotalDownHrs();
	rlGrossOpHrs := rlTotWorkingHrs + rlTotDownHrs;
	rlNetCraneHrs := _voy.getWPOpHrsTotalNetOpHrs();
	self.tblTimings.accessCell(12,idx).text :=rlGrossOpHrs.asStringJMTWithPrecision($CM_Decimal2LeadingZero.decimalPlaces, true).asStringJMT; //Gross Op Hrs
	self.tblTimings.accessCell(13,idx).text :=rlTotWorkingHrs.asStringJMTWithPrecision($CM_Decimal2LeadingZero.decimalPlaces, true).asStringJMT; //Tot Working hrs
	self.tblTimings.accessCell(14,idx).text :=rlTotDownHrs.asStringJMTWithPrecision($CM_Decimal2LeadingZero.decimalPlaces, true).asStringJMT; // Tot Down Hrs	
	self.tblTimings.accessCell(15,idx).text :=rlNetCraneHrs.asStringJMTWithPrecision($CM_Decimal2LeadingZero.decimalPlaces, true).asStringJMT; //Net Crane Hrs
	
	foreach tmp in 12 to 15 do
		self.tblTimings.accessCell(tmp,idx).itemObject := _voy;
	endforeach;

end;</source>
        <Parameter name="_voy" type="CM_Voyage"/>
    </JadeMethod>
    <JadeMethod name="showWebCamFrame" id="e32b7391-8f84-465d-a2dc-5a01e59d5dbb">
        <source>showWebCamFrame();
// ---------------------------------------------------------------------------
// Created:		January 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	aPicture : Binary;
	theW, theH : Integer;
begin
	if self.frmWebCam.visible then
		self.frmWebCam.visible := false;
		return;
	endif;
	
	self.showWebCamPicture();
/*	
	aPicture :=  app.getMyTerminal.getConfig(PicWebCamPicture01).Binary;
	if aPicture = null then
		self.frmWebCam.visible := false;
		return;
	
	endif;
	
	self.picWebCam.stretch := Picture.Stretch_ToControl;
	self.picWebCam.picture := aPicture;
	
	theW := self.picWebCam.pictureWidth;
	theH := self.picWebCam.pictureHeight;
	self.picWebCam.move(0,30,(theW / 2).Integer,(theH / 2).Integer);
	self.picWebCam.picture := aPicture;
	self.frmWebCam.move(20,20,self.picWebCam.clientWidth + 25,self.picWebCam.clientHeight + 45);
	self.btnWebCamClose.zOrder(1);
	self.frmWebCam.visible := true;
	self.frmWebCam.zOrder(1);
	*/
end;</source>
    </JadeMethod>
    <JadeMethod name="showWebCamPicture" id="4faeb428-7e85-45bb-b892-aa2e9b6576ec">
        <source>showWebCamPicture();
// ---------------------------------------------------------------------------
// Created:		January 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	aPicture : Binary;
	theW, theH : Integer;
	aTerm : CM_Terminal;
begin
	app.mousePointer := Window.MousePointer_HourGlass;

//	aPicture :=  app.getMyTerminal.getConfig(PicWebCamPicture01).Binary;
	/*
	aTerm := app.getMyTerminal;
	if aTerm = null then
		aTerm := self.myTerminal;
	endif;
	*/
	// Prioritise self.myTerminal as notes could change the terminal that the app method call returns
	// but the form could relate to a different terminal - cnwcp2 20/2/2009 PAR#18073
	
	//- cnwmd1, Par 20643
	/*aTerm := self.myTerminal;
	if aTerm = null then
		aTerm := app.getMyTerminal;
	endif;*/
	aTerm :=  self.myTerminal; //+ cnwmd1, Par 20643
	
	if aTerm = null then
		return;
	endif;

	aPicture :=  aTerm.getConfig(PicWebCamPicture01).Binary;
	if aPicture = null then
		aPicture :=  app.myRoot.getConfig(PicWebCamPicture01).Binary;
		if aPicture = null then
			self.frmWebCam.visible := false;
			return;
		endif;
	endif;
	
	self.picWebCam.stretch := Picture.Stretch_ToControl;
	self.picWebCam.picture := aPicture;
	
	theW := self.picWebCam.pictureWidth;
	theH := self.picWebCam.pictureHeight;
	theW := (theW * self.webPicScaleFactor).Integer;
	theH := (theH * self.webPicScaleFactor).Integer;
	
	self.picWebCam.move(3,self.frmToolbarWebCam.clientHeight + 5,theW,theH);
	self.picWebCam.picture := aPicture;
//	self.frmWebCam.move(self.frmWebCam.left,self.frmWebCam.top,self.picWebCam.clientWidth + 20,self.picWebCam.clientHeight + 45);
	self.frmWebCam.move(self.xmlWebLeft,self.xmlWebTop,self.picWebCam.clientWidth + 20,self.picWebCam.clientHeight + 45);
	self.btnWebCamX.zOrder(1);
	self.frmWebCam.cnEcResizeContents;
	self.frmWebCam.visible := true;
	self.frmWebCam.zOrder(1);

	self.frmToolbarWebCam.autoRedraw := true;
	self.frmToolbarWebCam.clearGraphics();
	self.frmToolbarWebCam.drawTextAt("Zoom Factor " &amp; self.webPicScaleFactor.String,45, 3,Black);
epilog
	app.mousePointer := Window.MousePointer_Default;
end;</source>
    </JadeMethod>
