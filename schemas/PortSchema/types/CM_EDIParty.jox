    <JadeMethod name="setProxy" id="04eb65dd-ac69-402e-b347-60cbd4a73237">
        <updating/>
        <source>setProxy(	_name, _description, _senders :String; 
			_operator :CM_Operator; 
			_terminal :CM_Terminal;
			_onlyUseXlationOpForXlation : Boolean)updating;
/*
Date		Who		Reason
23 November 2011	cnwcs5	Initial creation - CCMS POL 2122 / par 28696 - Empty Releases via COPARN
*/
vars

begin
	self.name					:= _name;
	self.description			:= _description;
	self.myTranslationOperator	:= _operator;
	
	self.setUNEdifactSenderCodes (_senders);
	self.onlyUseXlationOpForXlation:=_onlyUseXlationOpForXlation; //jlier1	TFS 57187 22/3/23
	self.myTerminal		:= _terminal;
epilog

end;</source>
        <Parameter name="_name" type="String"/>
        <Parameter name="_description" type="String"/>
        <Parameter name="_senders" type="String"/>
        <Parameter name="_operator" type="CM_Operator"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_onlyUseXlationOpForXlation" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setUNEdifactSenderCodes" id="1350880a-5a35-4c34-9b63-751a75042c84">
        <updating/>
        <source>setUNEdifactSenderCodes(_text :String)updating;
/*
Purpose		Set snder code from string value

Date		Who		Reason
16/11/2011	cnwcs5	Initial creation - CCMS POL 2122 / par 28696 - Empty Releases via COPARN
*/
vars
	str		:String;
	array	:StringArray;
begin
	self.raiseExceptionIfNotTransient (method);
	
	// always store in upper case
	str := _text.toUpper;
	
	self.allUNEdifactSenderCodes.clear;
		
	array := str.getTokens ();
	
	array.copy (self.allUNEdifactSenderCodes);
	
	if _text &lt;&gt; null and _text &lt;&gt; array.first then
		self.allUNEdifactSenderCodes.add(_text); //jlier1 TFS 56705 23/2/22
	endif;
epilog
	delete array;
end;</source>
        <Parameter name="_text" type="String"/>
    </JadeMethod>
    <JadeMethod name="updateUNEdifactSenderCodes" id="2a2f6818-ecc8-41b1-9a98-df9bd6d5c76d">
        <source>updateUNEdifactSenderCodes(_proxy :CM_EDIParty) protected;
/*
Purpose:	Maintain external key dictionary CM_Terminal::allEDIPartiesBySenderCode and
			copy new values to the receiver

Date		Who		Reason
16/11/2011	cnwcs5	Initial creation - CCMS POL 2122 / par 28696 - Empty Releases via COPARN
*/
vars
	str		:String;
	coll	:CM_EDIPartyBySenderCode;
	party	:CM_EDIParty;
	gotException	:Boolean;
	test	:Integer;
begin
	// _proxy has new values
	// self has old values

	self.raiseExceptionIfTransient (method);
	_proxy.raiseExceptionIfNotTransient (method);
	
	on Exception do app.handleDeletedObject (exception, party, gotException);
	
	// use terminal reference on proxy as it will not be set on the real object when creating
	coll := _proxy.myTerminal.allEDIPartiesBySenderCode;
	
	// remove entries from coll for codes no longer used
	foreach str in self.allUNEdifactSenderCodes do
		if not _proxy.allUNEdifactSenderCodes.includes (str) then	// array should be small
			party := coll [str];
			
			if party = self then
				coll.removeKeyEntry (str, party);
			else
				// Hmmm - just ignore.  There is a problem with our validation somewhere
			endif;
		endif;
	endforeach;
	
	// add entries to coll for new codes
	foreach str in _proxy.allUNEdifactSenderCodes do
		if not self.allUNEdifactSenderCodes.includes (str) then	// array should be small
			party := coll [str];
			
			if party = null then
				coll [str] := self;
			elseif party = self then
				// already there - just ignore but something wrong somewhere
			else
				// if the entry is an invalid object reference then we can just overwrite the entry
				test := party.edition;
				
				if gotException then
					coll [str] := self;
					
					gotException := false;
				else
					// Uh oh - there is a problem with our validaton.  This should not be happening
					app.raiseUnexpectedProgramError (self.class.name, method.name, 'Sender code (' &amp; str &amp; ') is already used by EDI Party (' &amp; party.String &amp; '). It cannot be used for EDI Party (' &amp; self.String &amp; ').');
				endif;
			endif;
		endif;
	endforeach;

	// now update string array on the receiver with new values
	self.allUNEdifactSenderCodes.clear;
	
	_proxy.allUNEdifactSenderCodes.copy (self.allUNEdifactSenderCodes);
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_proxy" type="CM_EDIParty"/>
    </JadeMethod>
    <JadeMethod name="validate" id="d0c54fdf-bc9e-49f4-96cc-faa25f948b42">
        <source>validate(_passport: CM_Passport input) protected;
/*
Date		Who		Reason
16/11/2011	cnwcs5	Initial creation - CCMS POL 2122 / par 28696 - Empty Releases via COPARN
*/
vars
	
begin
	if self.name = null then
		// error - must have name
		app.raiseCMException (EDI_Party_Error1, null, null);
	endif;
	
	if self.myTerminal = null then
		// error - must have terminal
		app.raiseUnexpectedProgramError (self.class.name, method.name, 'Terminal has not been set');
	endif;
	
	if self.allUNEdifactSenderCodes.isEmpty then
		// warning - should have sender codes
		app.raiseCMException (EDI_Party_Error2, null, null);
	endif;
	
	self.validateUNEdifactSenderCodes ();
	self.validateRules (_passport);
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="validateCreate" id="d8e1a57a-dcaf-4b44-9a9f-123f2b742256">
