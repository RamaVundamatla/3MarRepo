*/

vars

begin
	return self.systemToLocalTime(self.createdTime);
epilog

end;</source>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="getDataForAttribute" id="32cd6fbc-4e79-4d84-8707-2ab926c61a4f">
        <source>getDataForAttribute(_rowName, _heading : String; _headings : StringArray input; _data : HugeStringArray input);
// ---------------------------------------------------------------------------
// Created:     20 March 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	tmpStr		: String;
begin

	if self.getDataForDefSpecial(_rowName, _heading, _headings, _data) then
		return;
	else
		// If we need to change the display of any of these defaults that are
		// in getDisplayStringForAttribute for
		// certain attributes then consider enhancing EntTableCellControl to hold
		// display properties and use that here.

		tmpStr := getDisplayStringForAttribute(_rowName, false);
		_headings.add(_heading);
		if tmpStr.length &gt; 2047 then
			_data.add(tmpStr[1:2044]&amp;'...');
		else
			_data.add(tmpStr);
		endif;
	endif;

end;</source>
        <Parameter name="_rowName" type="String"/>
        <Parameter name="_heading" type="String"/>
        <Parameter name="_headings" type="StringArray" usage="input"/>
        <Parameter name="_data" type="HugeStringArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getDataForDef" id="03534b5c-58a0-4e9a-a355-9558ef0286a3">
        <source>getDataForDef(_entTableDef : EntTableDef; _headings : StringArray input; _data : HugeStringArray input; _terminal : CM_Terminal);
// ---------------------------------------------------------------------------
// Created:     20 March 2002 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
// Changed On	By			Reason
// ----------	--------	--------------------------------------------------
// 27/03/2013	cnwdap1		PAR #31155 CCMS SFW 1321 Imperial Measurements
vars
	entTableRow	: EntTableRow;
	measure		: CM_MeasurementType;				// PAR #31155
	rowName		: String;							// PAR #31155

begin

	foreach entTableRow in _entTableDef.allEntTableRows do
		if entTableRow.isGroupRow() then		// PAR 19910
			//_headings.add("$"&amp;entTableRow.getHeading(null, null, app.myCurrentLocale));
			//_data.add("");
			continue;
			
		elseif entTableRow.measurementType &lt;&gt; null then																					// PAR #31155
			foreach measure in app.myRoot.allMeasurementTypesByShortName where measure.measurementType = entTableRow.measurementType do	// PAR #31155
				if not measure.isAvailableForEntry or not measure.isDisplay then														// PAR #31155
					continue;																											// PAR #31155
				endif;																													// PAR #31155
				rowName := app.getMeasurementPrefixFromType(measure.measurementType) &amp; entTableRow.name &amp; "_" &amp; measure.shortName;		// PAR #31155
				self.getDataForAttribute(rowName, entTableRow.getHeading(null, null, app.myCurrentLocale), _headings, _data);			// PAR #31155
			endforeach;																													// PAR #31155
			
		else
			self.getDataForAttribute(entTableRow.name, entTableRow.getHeading(null, null, app.myCurrentLocale), _headings, _data);
		endif;
	endforeach;
end;</source>
        <Parameter name="_entTableDef" type="EntTableDef"/>
        <Parameter name="_headings" type="StringArray" usage="input"/>
        <Parameter name="_data" type="HugeStringArray" usage="input"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="getDataForDefSpecial" id="b9cf5380-a4f3-4b2a-895f-304b232c90b1">
        <source>getDataForDefSpecial(_attrName : String; _heading : String; _headings : StringArray input; _data : HugeStringArray input) : Boolean protected;
// ---------------------------------------------------------------------------
// Created:     01 May 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	if _attrName = ETRow_Seperator then
		_headings.add('');
		_data.add('');
		return true;
	endif;
	
	return false;

end;</source>
        <access>protected</access>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_heading" type="String"/>
        <Parameter name="_headings" type="StringArray" usage="input"/>
        <Parameter name="_data" type="HugeStringArray" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getDataForETView" id="502438db-8bd5-4522-b93c-5f02d3c77d55">
        <source>getDataForETView(_entTableDef : EntTableDef; _entTableView : EntTableView; _headings : StringArray input; _data : HugeStringArray input; _terminal : CM_Terminal);
/*
	Created on 31 January 2008 by Debby Hutchison
*/
vars
	entTableRow	: EntTableRow;
begin
	foreach entTableRow in _entTableDef.allEntTableRows do
		if _entTableView = null or 
			_entTableView.allEntTableRows.includes(entTableRow) then
			self.getDataForAttribute(entTableRow.name, entTableRow.getHeading(null, null, app.myCurrentLocale), _headings, _data);
		endif;
	endforeach;
end;</source>
        <Parameter name="_entTableDef" type="EntTableDef"/>
        <Parameter name="_entTableView" type="EntTableView"/>
        <Parameter name="_headings" type="StringArray" usage="input"/>
        <Parameter name="_data" type="HugeStringArray" usage="input"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
    </JadeMethod>
