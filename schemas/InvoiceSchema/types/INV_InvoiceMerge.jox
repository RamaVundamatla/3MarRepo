    <JadeMethod name="doBuildTargetCombo" id="58f00b50-7982-4e93-92c7-a3ee8ae93078">
        <source>doBuildTargetCombo();
/*
Purpose:			

Date		Who		Reason
11 January 2024	navab1	CR 58085 TASK 61346
*/

vars
	combo : CMUI_ComboBox;
	invoice : CM_Invoice;
	debtor : CM_Debtor;
	category : Integer;
	proc : CM_InvoiceProcess;
	bu : CM_Bank;
	
	idx, numover : Integer;
begin
	combo := self.cmbTargetInvoice;
	combo.clear();
	combo.sorted := true;
	
	invoice := self.allInvoicesToLink.first;
	
	if invoice = null then
		return;
	endif;
	
	debtor := invoice.debtor;
	category := invoice.category;
	proc := invoice.getMyInvoiceProcess();
	bu := invoice.bank;
	
	foreach invoice in debtor.invoicesByStatus discreteLock do
		if self.allInvoicesToLink.includes(invoice) then
			continue;
		endif;
		
		if not invoice.canMerge() then
			continue;
		endif;
		
		if category &lt;&gt; invoice.category then
			continue;
		endif;
		
		if invoice.bank &lt;&gt; bu then
			continue;
		endif;
		
		if invoice.getMyInvoiceProcess() &lt;&gt; proc then
			continue;
		endif;
		
		// ### JIRA 19232 29OCT2024 NAVAB1
		idx +=1;
		if idx &lt;= JadeTableRowLimit then
			self.cmbTargetInvoice.addItemObject(invoice.sequenceNum.String,invoice);
		endif;
	
	endforeach;

		// ### JIRA 19232 29OCT2024 NAVAB1
	if idx &gt; JadeTableRowLimit then
		numover := ((JadeTableRowLimit - idx) * -1);

		app.msgBox(app.getErrorString5(More_than_invoi_were_found_deb,JadeTableRowLimit.String,
																			debtor.name,
																			JadeTableRowLimit.String,
																			idx.String,
																			numover.String), "INFO", MsgBox_OK_Only);
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doMerge" id="ec94010f-f757-412a-bd76-d2c0ddf27d4f">
        <updating/>
        <source>doMerge() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 January 2023	navkc1	Initial creation TFS CR 55305 Task 55536: UI - Invoice Credit Note UI
03/11/2025 jlier1 	MTN-34531 - Deadlock retry for everyone	
*/

vars
	
begin
	self.doMergeDLRT();
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doMergeDLRT" id="ddbe2769-edaf-4f1f-90e1-cf0c68bf0026">
        <updating/>
        <source>doMergeDLRT() updating;
/*
Purpose - 	
Who - NAVAB1
Date - 21OCT2024
ADO - JIRA 19932
7/3/25 navsaa30 14818 MTN | Silent Deadlock Retry Technical Debt
03/11/2025 jlier1 	MTN-34531 - Deadlock retry for everyone	
*/

vars
	invoice 		: CM_Invoice;	
	theReturn 		: Integer;
	controller : CMIF_InvoiceLineMerge;
	localCaption : String;
begin
	invoice := self.cmbTargetInvoice.listObject.CM_Invoice;
	
	if invoice = null then
		app.msgBox(app.getErrorString(INV_Please_Select_An_Invoice), app.getErrorString(Information), MsgBox_OK_Only);
		return;
	endif;
	
	if app.msgBox(app.getErrorString1(Pleas_confi_that_want_merge_li, invoice.sequenceNum.String), app.getErrorString(Information), MsgBox_OK_Cancel) = MsgBox_Return_Cancel then
		return;
	endif;

	localCaption := self.caption;
	
	//set up the silent deadlock handler to attempt to retry
	app.myPassport.setupForDeadlockReplay(220, 3000);
	app.myPassport.silentDeadlockLimit := 10;	
	
	self.mousePointer := Window.MousePointer_HourGlass;
	
	
	create controller transient;
	controller.myTargetInvoice := invoice;
	self.allInvoicesToLink.copy(controller.allInvoices);
	
	
	while true do
		while true do
			app.myTrxUA.trxUpdateInvoiceMerge(controller, app.myPassport);
			
			if app.myPassport.hadDeadlock then //jlier1 4/11/25 break to deadlock loop
				break;
			endif;
			
			if app.myPassport.trxCompletedOK then
				self.clearErrorWarnings();
				app.msgBox( app.getErrorString(SAVE_COMPLETE),app.getErrorString(Information) , MsgBox_OK_Only + MsgBox_Information_Icon);
				self.unloadForm();
				break;
			else
				theReturn := app.showErrorWarningDialog(app.getErrorString(CM_Update_Invoice), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
				if app.myPassport.noErrors 
				and theReturn = IDOK then
					app.myPassport.warningsAcknowledged	:= true;
					continue;
				endif;
				self.setAllErrorWarnings(app.myPassport);
				return;
			endif;
			break;
		endwhile;
		
		//if we did NOT have a dead lock, just bail out.
		if app.myPassport.noTrxReplayAllowed() then
			if app.myPassport.hadDeadlock then //had a deadlock and reached the limit show the deadlock error
				app.showErrorWarningDialog(app.getErrorString(CM_Update_Invoice), app.myPassport, ErrWarnMode_Update + ErrWarnMode_CanAckWarnings);
			endif;
			break;
		endif;
		
		self.updateCaptionDeadlockRetry(localCaption);
				
	endwhile;

	
epilog

	//set the silent deadlock handler back to the default values i.e. OFF
	app.myPassport.resetSilentDeadlockHandler; //7/3/25 navsaa30 #14818
	self.caption := localCaption;
	self.mousePointer := Window.MousePointer_Default;
	delete controller;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="doQuery" id="15cd6e69-5ea7-4333-a5a2-5f899c5b0d6e">
        <updating/>
        <source>doQuery() updating;
/*
Purpose:			

Date		Who		Reason
11 January 2024	navab1	CR 58085 TASK 61346
*/

vars
	invName			: String;
	theTable 		: CM_DataTable;
	collInvoices	: CM_InvoiceSet;
	idx				: Integer;
	anInvoice		: CM_Invoice;
	bank			: CM_Bank;
	pd				: CMS_Progress;
	lastUpdate		: Decimal [20];
begin
	on CM_ProgressException do haltProgress(exception);
	
	self.mousePointer := Window.MousePointer_HourGlass;

	create pd;
	pd.setBackground(self.backColor);
	pd.show;
	pd.setAction(app.getErrorString1(Loading_invoices,null));
	
	theTable := self.tblInvoices;
	theTable.rows := theTable.fixedRows;
	theTable.clearAllSelected ();

	collInvoices :=  self.allInvoicesToLink;
	pd.progress.partsInJob := collInvoices.size;
	
	foreach anInvoice in collInvoices reversed do
		idx := idx + 1;
		if (app.relativeMachineTime - lastUpdate) &gt; CMIF_Monitor.Monitor_TimeBetweenUpdates then	
			pd.setAction(app.getErrorString1(Loading_invoices,invName));
			pd.progress.partsDone := idx;
			lastUpdate := app.relativeMachineTime;													
		endif;																						
		
		self.doQueryAddItemToTable(anInvoice);
		
		if theTable.rows = JadeTableRowLimit then
			break;
		endif;
	endforeach;
	
epilog
	
	delete pd;
	self.mousePointer := Window.MousePointer_Default;
end;</source>
    </JadeMethod>
    <JadeMethod name="doQueryAddItemToTable" id="018b3ba0-89ea-4482-b711-ead8a5a17345">
        <updating/>
        <source>doQueryAddItemToTable(_theInvoice : CM_Invoice) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25 January 2023	navkc1	Initial creation TFS CR 55305 Task 55536: UI - Invoice Credit Note UI

*/

vars
	theDataLine : String;
	theTable	: CM_DataTable;
	
begin
	if not global.isValidObject(_theInvoice) then
		return;
	endif;

	theTable := self.tblInvoices;
	
	theDataLine := _theInvoice.getAttributeStringForDefArray(theTable.allTblDataEntRows);

	theTable.addItemObject(_theInvoice, theDataLine);

epilog

end;</source>
        <Parameter name="_theInvoice" type="CM_Invoice"/>
    </JadeMethod>
    <JadeMethod name="doTableContext" id="ffcf4e71-2c72-418a-8bef-2f271275e7e7">
        <updating/>
        <source>doTableContext(cntrl: Table input; conwin: Window input; mouse: Boolean; x: Integer; y: Integer) : Boolean updating;
/*
Purpose:			

Date		Who		Reason
11 January 2024	navab1	CR 58085 TASK 61346
*/

vars
	xLeft	: Real;
	yTop	: Real;
	
begin
	
	xLeft := x;
	yTop := y;
	
	conwin.windowToScreen(xLeft, yTop);	
	self.screenToWindow(xLeft, yTop);
	
	self.mnuMenuContext.userObject := cntrl;
	
	self.popupMenu(self.mnuMenuContext, xLeft.Integer, yTop.Integer);
	
	return false;
epilog

end;</source>
        <Parameter name="cntrl" type="Table" usage="input"/>
        <Parameter name="conwin" type="Window" usage="input"/>
        <Parameter name="mouse" type="Boolean"/>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
