    <JadeMethod name="clone" id="96649922-c65a-41c2-b75e-18a03e885b5d">
        <source>clone(toNewId : String) : CM_MoveMap;
//This method clones the existing moveMap, its moveplans, and all subsidiary stuff
//to make a new one.
vars
	moveMap : CM_MoveMap;
	movePlan	: CM_MovePlan;
	ap	:	CM_AttributePlan;
	dummy : CM_MovePlan;	//Intentionally left NULL
begin
	create moveMap;
	moveMap.id := toNewId;
	moveMap.clonedFromId := self.id;
	moveMap.terminal := self.terminal;
	//----------------
	//copy the Attributeplans objects (ALL of them, this gets the "global" level
	//----------------
	foreach ap in self.allAttributePlans do
		ap.clone(dummy, moveMap);
	endforeach;
	//--------------------
	//Copy the movePlans
	//--------------------
	foreach movePlan in self.movePlans do
		movePlan.clone(moveMap);
	endforeach;
	return moveMap;
end;</source>
        <Parameter name="toNewId" type="String"/>
        <ReturnType type="CM_MoveMap"/>
    </JadeMethod>
    <JadeMethod name="createMovePlan" id="96addf0d-0e12-4c03-95c3-af305faf9d12">
        <updating/>
        <source>createMovePlan(source : String; target : String; _movePlan : CM_MovePlan output) updating;
//PAR 3690 AJA 11/9/00: Just creates an empty move plan to enable the
//user to start defining attribute plans.
//13/06/2022 navds20 TFS 53760 DuplicateItem not Translatable
begin
	if self.movePlans[source, target] &lt;&gt; null then
		app.setContinueCMExceptions(false);
		//app.raiseCMException2(DuplicateItem, "MovePlan", source &amp; " to " &amp; target, null, null); //13.06.2022 navds20 53760
		//MovePlan already exists for %1 to %2 : Moveplan_already_exists
		app.raiseCMException2(Moveplan_already_exists, source, target, null, null); //13.06.2022 navds20 53760
		return;	
	endif;
	//---------------
	//Create new one
	//---------------
	create _movePlan;
	_movePlan.setForUpdate(source, target, self);
end;</source>
        <Parameter name="source" type="String"/>
        <Parameter name="target" type="String"/>
        <Parameter name="_movePlan" type="CM_MovePlan" usage="output"/>
    </JadeMethod>
    <JadeMethod name="erase" id="a64ef929-f924-4c17-b707-6c140b8efd19">
        <updating/>
        <source>erase(_eraseLevel: Integer) updating;
//Destroy ourselves.
vars
	ap		: CM_AttributePlan;
	mp		: CM_MovePlan;
	/*term	: CM_Terminal;
	voy		: CM_Voyage;
	cv		: CM_CellularVoyageStructure;*/
begin
	//------------------
	//Clear out our attribute plans
	//------------------
	exclusiveLock(self);
	while self.allAttributePlans.size &gt; 0 do
		ap := self.allAttributePlans.last;
		ap.erase(_eraseLevel);
	endwhile;
	//------------------
	//Clear out our moveplans - probably wont be any left at this stage but wont hurt to check
	//------------------
	while self.movePlans.size &gt; 0 do
		mp := self.movePlans.last;
		mp.erase(_eraseLevel);
	endwhile;
	
	/*term := self.terminal;

	foreach voy in term.allVoyagesByCode discreteLock do
		cv := voy.myCellularVoyageStructure;
		if cv &lt;&gt; null then		
			if not global.isValidObject(cv.myMoveMapReceival) then
				cv.setRecMoveMap(null);
			endif;
			
			if not global.isValidObject(cv.myMoveMapRelease) then
				cv.setRelMoveMap(null);
			endif;
		endif;
	endforeach;	

	foreach voy in term.allVoyagesArchived discreteLock do
		cv := voy.myCellularVoyageStructure;
		if cv &lt;&gt; null then
			if not global.isValidObject(cv.myMoveMapReceival) then
				cv.setRecMoveMap(null);
			endif;
			
			if not global.isValidObject(cv.myMoveMapRelease) then
				cv.setRelMoveMap(null);
			endif;
		endif;
	endforeach;	*/
		
	//------------------
	//Night night nurse...
	//------------------
	inheritMethod(_eraseLevel);
end;</source>
        <Parameter name="_eraseLevel" type="Integer"/>
    </JadeMethod>
