<Class name="HMS_TidalClass">
    <JadeMethod name="importPLXMLReference" id="7795b2df-5003-47fc-a7ef-aa83ad57b892">
        <source>importPLXMLReference(_name, _theCode, _referencesBlock: String): Object;

vars

begin
	if _name = HMS_TidalClass::myRoot.name then
		return app.myRoot;
	else
		return null;
	endif;
end;</source>
