    <JadeMethod name="delete" id="8b3d16d9-2996-4b1f-b37b-fa994559a2fd">
        <updating/>
        <source>delete() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26 Oct 2022 navtnr20 ChangeRequest 54967: EUP - INB/OUT - Operational Instructions

*/

vars
	terminal : CM_Terminal;
begin
	self.resetAuditsDuringDelete();
	
	if not self.isTransient then
		if self.myParent.isKindOf(CM_WorkOrder) then
			terminal:=self.myParent.getMyTerminal;
			if terminal &lt;&gt; null then
				app.myEventManager.createSingleObjInfoNoteEvt(self.myParent, terminal.getTerminalEvent(Event_WorkOrder_Update),  self.myParent);
			endif;	
		endif;
	endif;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="00e03815-3ac2-4977-8a3e-c81c643e8d23">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 Oct 2023	navnk30	ChangeRequest 59946: EUP - Additional Operational Instructions on the Order - Enhancement 2

*/

vars

begin
	if _attrName = ETRow_InstructionType then
		return self.getInstructionCode &amp; " - " &amp; self.getInstructionDesc;
	elseif _attrName = ETRow_InstructionParentType then
		return self.getParentType();
	elseif _attrName = ETRow_InstructionReference then
		return self.getReferenceId();
	elseif _attrName = ETRow_InstructionInternal then
		return self.internalInstructions;
	elseif _attrName = ETRow_InstructionExternal then
		return self.externalInstruction;
	else
		return inheritMethod(_attrName, _short);
	endif;

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
