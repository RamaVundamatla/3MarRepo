    <JadeMethod name="doTblDataContextMenu" id="c62fb003-81c8-4b02-b02a-f4e927f05af3">
        <updating/>
        <source>doTblDataContextMenu(cntrl: Table input; conwin: Window input; mouse: Boolean; x: Integer; y: Integer): Boolean updating;
//----------------------------------------------------------------
//	Created:	20 January 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

	anObject	: Object;
	aLLTI		: CM_EDILoadListComparisonTI;
//	newMenuItem : MenuItem;
	
begin
	//self.mnuColumnOrganiser.visible := false;
	self.mnuContextTIEnquire.enabled := false;
	self.mnuContextTIEdit.enabled := false;
	self.mnuContextTIEnquire.caption := "Cargo Enquiry...";
	self.mnuContextTIEdit.caption := "Cargo Edit...";

	//cnwjo3 CCMS 1084
	if self.cmbView.text = self.VIEW_NOT_IN_DB and self.frmLoadListView.visible then
		self.mnuCreatePrenotes.visible := true;
	else
		self.mnuCreatePrenotes.visible := false;
	endif;
	if self.tblData.allSelectedObjects.size = 0 then
		self.mnuCreatePrenotes.enabled := false;
	else
		self.mnuCreatePrenotes.enabled := true;
	endif;

	// 2/10/19 MAP TFS 45590
	self.mnuCreateTBA.visible := self.cmbView.text = self.VIEW_NOT_IN_DB and self.comparisonMode = self.LOAD_COMPARISON;
	self.mnuCreateTBA.enabled := false;
	foreach anObject in self.tblData.allSelectedObjects do
		if anObject.CM_EDILoadListTI.cargoTypeDescr &lt;&gt; app.getErrorString(ISO_Container) then
			break;
		endif;
		self.mnuCreateTBA.enabled := true;
	endforeach;

	anObject :=  cntrl.accessRow(cntrl.row).itemObject;
	if CM_EDILoadListComparisonTI.hasInstance(anObject) then
		aLLTI := anObject.CM_EDILoadListComparisonTI;
		if aLLTI.myTrackedItem &lt;&gt; null then
			self.mnuContextTIEnquire.enabled := true;
			self.mnuContextTIEdit.enabled := true;
		endif;
	elseif CM_TrackedItem.hasInstance(anObject) then
		self.mnuContextTIEnquire.enabled := true;
		self.mnuContextTIEdit.enabled := true;
	else
	//	return false;
	endif;
	
	// cnwrl1 17/02/2009 - (CCMS SFW 1047 - Totals Only Lists) - start of coding
	self.mnuSummarise.visible	:= false;	// default this menu level to invisible, makes sub-menu invisible.
	if self.bAllowSummaryDefn then
		self.mnuSummarise.visible			:= true;
		// the summarise selected is only enabled if something is actually selected.
		self.mnuSummariseSelected.visible	:= not self.tblData.allSelectedObjects.isEmpty;
	endif;
	// cnwrl1 17/02/2009 - (CCMS SFW 1047 - Totals Only Lists) - end of coding
	
	self.mnuContextSep01.visible := true;
	self.mnuContextTIEnquire.visible := true;
	self.mnuContextTIEdit.visible := true;
	
	
		// TFS 2198 CNWAB1
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
	self.mnuContextTIEdit.enabled := false;

	endif;

	
	return self.showContextMenu(self.mnuContextTable,cntrl,conwin,mouse,x, y);

end;</source>
        <Parameter name="cntrl" type="Table" usage="input"/>
        <Parameter name="conwin" type="Window" usage="input"/>
        <Parameter name="mouse" type="Boolean"/>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doTblDataDBClick" id="b84fcfc4-472e-440b-b7ac-69b7a7bc9b17">
        <updating/>
        <source>doTblDataDBClick(_table: CM_DataTable input) updating;
//----------------------------------------------------------------
//	Created:	04 November 2003	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

	obj	: CM_Object;
	row : Integer;
	ti	: CM_TrackedItem;
begin
	inheritMethod(_table);

	row := _table.row;
	
	if row &gt; tblData.fixedRows then
		obj := self.tblData.accessRow(row).itemObject.CM_Object;
		
		if obj = null then
			return;
		endif;
		
		if obj.isKindOf(CM_EDILoadListComparisonTI) then
			ti := obj.CM_EDILoadListComparisonTI.myTrackedItem;
		elseif obj.isKindOf(CM_TrackedItem) then
			ti := obj.CM_TrackedItem;
		endif;
	
		if ti &lt;&gt; null then
			self.myAssistant.showCargoEnquiryForm(ti, self.myMasterMenuAction, true, false);
		endif;
		
	endif;

end;</source>
        <Parameter name="_table" type="CM_DataTable" usage="input"/>
    </JadeMethod>
