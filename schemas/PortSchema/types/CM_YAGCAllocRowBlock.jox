<Class name="CM_YAGCAllocRowBlock" id="262ed0fd-16b0-4e4e-bc6d-d11c3f86b1c7">
    <superclass name="CM_YARowBlock"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="yardAllocations"/>
    <JadeMethod name="buildLocationStatistics" id="19a55b67-34be-4763-b9d7-3335b0ae4d6c">
        <updating/>
        <source>buildLocationStatistics() updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 11/06/2020	jlgdap1		Initial creation TFS 49453 ASPA Satellite View Screen for Flexible Terminal Areas
//
vars
	locationStatistics	: CM_LocationStatistics;
	plocationStatistics	: CM_LocationStatistics;
	allocRowArea		: CM_GeneralCargoAllocRowArea;
	allTIs				: CM_TIArray;
	terminal			: CM_Terminal;
	theTI				: CM_TrackedItem;
	container			: CM_Container;
	invalidContainer	: Boolean;
	lc, colLC			: CM_LocationsController;
	
begin
	if self.myLocationStatistics = null then
		create plocationStatistics transient;
		plocationStatistics.setParent(self);
		create locationStatistics  persistent;
		locationStatistics.setupForCreate(plocationStatistics);
	endif;

	exclusiveLock(self.myLocationStatistics);
	self.myLocationStatistics.clearSystemCounts;

	if self.myTerminalArea.isGeneralCargoAllocArea() then

		allocRowArea := self.myTerminalArea.CM_GeneralCargoAllocRowArea;
		
		// Total		
		//self.myLocationStatistics.c20Total := allocRowArea.maxCapacity;
		//self.myLocationStatistics.c30Total := allocRowArea.maxCapacity;
		//self.myLocationStatistics.c40Total := allocRowArea.maxCapacity;
		//self.myLocationStatistics.c45Total := allocRowArea.maxCapacity;
		//self.myLocationStatistics.c53Total := allocRowArea.maxCapacity;
		
		// Init free
		//self.myLocationStatistics.c20Free := allocRowArea.maxCapacity;
		//self.myLocationStatistics.c30Free := allocRowArea.maxCapacity;
		//self.myLocationStatistics.c40Free := allocRowArea.maxCapacity;
		//self.myLocationStatistics.c45Free := allocRowArea.maxCapacity;
		//self.myLocationStatistics.c53Free := allocRowArea.maxCapacity;
		
		create allTIs transient;
		allocRowArea.getAllTrackedItems(allTIs);
		
		on Exception do app.handleDeletedObject(exception, container, invalidContainer);
		
		// Used &amp; Free
		foreach theTI in allTIs do
			if theTI.isKindOf(CM_Container) then
				container := theTI.CM_Container;
				if container.is20 then
					self.myLocationStatistics.c20Used := self.myLocationStatistics.c20Used + 1;
				elseif container.is30 then
					self.myLocationStatistics.c30Used := self.myLocationStatistics.c30Used + 1;
				elseif container.is40 then
					self.myLocationStatistics.c40Used := self.myLocationStatistics.c40Used + 1;
				elseif container.is45 then
					self.myLocationStatistics.c45Used := self.myLocationStatistics.c45Used + 1;
				elseif container.is53 then
					self.myLocationStatistics.c53Used := self.myLocationStatistics.c53Used + 1;				
				endif;
				self.myLocationStatistics.c20Free := (self.myLocationStatistics.c20Free-1);
				if self.myLocationStatistics.c20Free &lt; 0 then
					self.myLocationStatistics.c20Free := 0;	
				endif;
				self.myLocationStatistics.c30Free := self.myLocationStatistics.c20Free;
				self.myLocationStatistics.c45Free := self.myLocationStatistics.c20Free;
				self.myLocationStatistics.c53Free := self.myLocationStatistics.c20Free;
				self.myLocationStatistics.c40Free := self.myLocationStatistics.c20Free;
			endif;
		endforeach;
		
		// Calculate future queued/planned (unchanged from original code)
		foreach lc in self.myTerminalArea.CM_GeneralCargoAllocRowArea.allRowControllersById discreteLock do
			foreach colLC in lc.CM_GeneralCargoAllocGroup.allLocations discreteLock do
				self.myLocationStatistics.processALocationController(colLC, 1, 1);
			endforeach;
		endforeach;
		
		//cnwjo3 par 21189
		self.myLocationStatistics.free := self.myLocationStatistics.c20Free;
	//	self.myLocationStatistics.used := self.allYardControllers.first.getTrackedItemCount;	//cnwrd1 31736 break bulk counting	
		//	15 Apr 2015	NDL	Par 35969 - Don't include Break-Bulk
		self.myLocationStatistics.used := self.myLocationStatistics.c20Used + self.myLocationStatistics.c30Used
										+ self.myLocationStatistics.c40Used + self.myLocationStatistics.c45Used
										+ self.myLocationStatistics.c53Used;
		self.myLocationStatistics.total := self.myLocationStatistics.c20Total;
		
		
		self.myLocationStatistics.setUpdateTimestamp;
		terminal := self.myTerminalArea.myTerminal;
		terminal.causeEvent(terminal.getTerminalEvent(EVENT_LOCATION_STATS_CHANGE), false, self.myLocationStatistics);
	endif;
epilog
	delete plocationStatistics;
	delete allTIs;	//07 Apr 2021	NDL	TFS 49912 - Transient leak;
end;</source>
    </JadeMethod>
    <JadeMethod name="getLocationsString" id="e0f66e4f-62c5-48fd-95d1-5c2022b7acb9">
        <source>getLocationsString(): String;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 16/06/2020	jlgdap1		Initial creation TFS 49453 ASPA Satellite View Screen for Flexible Terminal Areas
//
vars
	yc : CM_YardController;
	ac : CM_GeneralCargoAllocController;
	minCol, maxCol : String;
	minLoc, maxLoc : CM_GeneralCargoAllocController;
	locString : String;

begin
	foreach yc in self.allYardControllers do
		ac := yc.CM_GeneralCargoAllocController;
		if minCol = null or ac.id &lt; minCol then
			minCol := ac.id;
			minLoc := ac;
		endif;
		if ac.id &gt; maxCol then
			maxCol := ac.id;
			maxLoc := ac;
		endif;	
	endforeach;
	if minCol &lt;&gt; null and minLoc = maxLoc then
		locString := minLoc.id;
	else
		if minCol &lt;&gt; null and maxCol &lt;&gt; null then
			locString := minLoc.id &amp; "-" &amp; maxLoc.id;
		endif;
	endif;
	return locString;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getYAMDisplay" id="85324140-04e8-4fbd-b88b-683eb7a701a9">
        <source>getYAMDisplay(pIsSortIn: Boolean): String;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 16/06/2020	jlgdap1		Initial creation TFS 49453 ASPA Satellite View Screen for Flexible Terminal Areas
//
vars

begin
	return inheritMethod(pIsSortIn) &amp; Space &amp; self.getLocationsString;

epilog

end;</source>
        <Parameter name="pIsSortIn" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="initialiseForDecking" id="35398f19-76f3-48af-85f7-b2ae66117c5c">
        <source>initialiseForDecking(_pxyDeckingOptions: CM_YADeckingOptionsBlock input);
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 12/06/2020	jlgdap1		Initial creation TFS 49453 ASPA Satellite View Screen for Flexible Terminal Areas
//
vars
	locn : CM_YardController;
	
begin
	foreach locn in self.allYardControllers do
		locn.setupForDeckingInBlock(1, 1, _pxyDeckingOptions);
	endforeach;

	//do default out - reverse of in?
	_pxyDeckingOptions.setOutDeckingReverseOfIn();

epilog

end;</source>
        <Parameter name="_pxyDeckingOptions" type="CM_YADeckingOptionsBlock" usage="input"/>
    </JadeMethod>
    <JadeMethod name="searchForLocationIn" id="bad47646-3758-400e-9bb6-8cfd5961400f">
        <source>searchForLocationIn(_yaAgent: CM_YAAutoplanAgent input): Boolean;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 14/05/2021	navdap1		Initial creation TFS 49858 PRP 
//
vars
	ti : CM_TrackedItem;
	group : CM_GeneralCargoAllocGroup;
	prodMinMax : CM_TerminalAreaProductMinMax;
	locationCell : CM_YALocationCell;

begin
	if not self.initSearchForLC(_yaAgent) then
		return false;
	endif;
	
	// If product min/max is set at group level, just check the first column of each group
	// If product min/max is set at column level, or there is no product min/max, check every column
	ti := _yaAgent.myCMIFYAAutoPlan.getMyTrackedItem;
	if ti = null then
		return inheritMethod(_yaAgent);
	endif;
	
	group := self.allYardControllers.first.CM_GeneralCargoAllocController.myGroup;
	prodMinMax := self.myTerminalArea.allProductMinMax[group, ti.myCargoType, ti.myProduct];
	if prodMinMax &lt;&gt; null then
		// just check the first column - this min/max is by group
		if self.searchLCIn(self.myDeckingOptions.allYALocationCellsIn.first, _yaAgent) and _yaAgent.hasFoundAvailableLoc() then
			return true;
		endif;
	else
		// check all locations in the group - this min/max is by column
		foreach locationCell in self.myDeckingOptions.allYALocationCellsIn discreteLock do
			if self.searchLCIn(locationCell, _yaAgent) and _yaAgent.hasFoundAvailableLoc() then
				return true;
			endif;
		endforeach;
	endif;
	
	return false;

epilog

end;</source>
        <Parameter name="_yaAgent" type="CM_YAAutoplanAgent" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
