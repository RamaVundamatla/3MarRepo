<Class name="CM_EDILoadListTIPON" id="3e1fe85c-8528-46f1-8fb4-2014698f9037">
    <superclass name="CM_EDILoadListTI"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="edi"/>
    <JadeMethod name="setDefault" id="74ac0f13-35be-4976-90b2-3a7d8ea6fa16">
        <updating/>
        <source>setDefault(_infoTI: StringArray) updating;
//----------------------------------------------------------------
//	Created:	03 October 2003	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
//02 Feb 2012	cnwrs1	Par 29076 Fix up Hazard Processing in EDI
//08 Apr 2013	cnwcs5	CCMS POL 2097/par 31259 - commodity xlations

vars
	infoTI : StringArray;
	mtCmdty, defCmdty, refCmdty, hazCmdty	: String;
begin
	app.getTerminalDefCmdty(mtCmdty, defCmdty, refCmdty, hazCmdty);
	
	infoTI := _infoTI;
	
	self.operatorCode		:= "PON";					
	self.locationId			:= "null";
	//self.voyageCode		:= infoTI[1];				//voyage
	self.setLoadPort(infoTI[2]);						//loadport	
	self.setDischargePort(infoTI[3][1:5]);				//discharge
	self.setID(infoTI[4]);								//cargo ID
	self.setISOTypeFromSizeType(infoTI[5], infoTI[6]);	//size &amp; type
	//self.igf				:= infoTI[7];				//igf
	self.setDestinationPort(infoTI[8][1:5]);			//Dest				
	self.weight				:= infoTI[9].Integer;		//weight
	self.bookingRef			:= infoTI[10].toUpper;		//bookingRef
	self.shipperDesc		:= infoTI[12];				//shipper
	self.setHazardous(infoTI[13]);						//dangerous?
	self.setOutOfGauge(infoTI[14]);						//OD?
	// par 31259 set temp b4 commodity as it is needed for xlation
	self.setTemp(infoTI[17]);							//temp
	self.setCommodity(infoTI[11], app.myRoot.allOperators[self.operatorCode]);						//commodity - translate
	self.setVents(infoTI[18]);							//vents
				
	if self.commodity = null then
		if self.temperature = NULL_TEMPERATURE then
			if self.hazardous then
				self.commodity := hazCmdty;
			else
				self.commodity := defCmdty;
			endif;
		else
			self.commodity := refCmdty;
		endif;
		self.fullOrMT := "F";
	elseif self.commodity = mtCmdty then
		self.fullOrMT := "E";
	else
		self.fullOrMT := "F";
	endif;

end;</source>
        <Parameter name="_infoTI" type="StringArray"/>
    </JadeMethod>
    <JadeMethod name="setISOTypeFromSizeType" id="6c67ddc2-805d-4804-a90e-b60b3ca74091">
        <updating/>
        <source>setISOTypeFromSizeType(_size: String; _type: String) updating;
//----------------------------------------------------------------
//	Created:	22 October 2003	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	isoTypeCode		: String;
	
begin
	if _size.length &gt; 1 then
		isoTypeCode := _size[1:2];
	else
		isoTypeCode := "20";	//default 
	endif;
	if _type.length &gt; 1 then
		isoTypeCode := isoTypeCode &amp; _type[1:2];
	else
		isoTypeCode := isoTypeCode &amp; "GP";	//default
	endif;
	
	self.isoType := isoTypeCode;
	
end;
</source>
        <Parameter name="_size" type="String"/>
        <Parameter name="_type" type="String"/>
    </JadeMethod>
</Class>
