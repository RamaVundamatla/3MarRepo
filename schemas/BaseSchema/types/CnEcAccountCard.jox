    <PrimAttribute name="cardNumber" id="cd89c8ec-a4ee-4808-a4ab-332b6082eefe">
        <length>51</length>
        <embedded/>
        <type name="String"/>
        <access>readonly</access>
    </PrimAttribute>
    <JadeMethod name="doValidateCardNumber" id="162eb0d4-c76d-43ca-b5e0-774cc062530c">
        <source>doValidateCardNumber():Boolean protected, abstract;</source>
        <abstract/>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isValidNumber" id="30a6decb-54c5-449b-986d-34ccb913c846">
        <source>isValidNumber():Boolean;
// --------------------------------------------------------------------------------
// Created:		06 August 2002 by cnwdad2
//
// Purpose:		eturns a boolean flag to indicate whether the card number is valid.
//
// Parameters:	None
//
// Returns:		True if the card number is valid, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return self.doValidateCardNumber();
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="updateMe" id="3914b0ca-91eb-41c4-aeaa-7e7caaa9d092">
        <updating/>
        <source>updateMe(pCardNumber:String) updating;
// --------------------------------------------------------------------------------
// Created:		06 August 2002 by cnwdad1
//
// Purpose:		Updates the receiver's card number.
//
// Parameters:	pcardNumber - The card number.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if self.cardNumber &lt;&gt; pCardNumber then
		self.cardNumber	:=	pCardNumber;
	endif;
end;</source>
        <Parameter name="pCardNumber" type="String"/>
    </JadeMethod>
</Class>
