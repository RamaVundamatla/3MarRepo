    <JadeMethod name="btnSelectAll_click" id="91282ee0-8afc-4f23-9eb9-a8400bb6f371">
        <controlMethod name="CMUI_Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnSelectAll_click(btn: Button input) updating;
//--------------------------------------------------------------
//Created: 12 June 2002 By: cnwgd1
//--------------------------------------------------------------
vars

begin
	if btn.caption = 'Select All' then
		self.selectUnselectAll(true);
		btn.caption := 'Deselect All';
	else
		self.selectUnselectAll(false);
		btn.caption := 'Select All';
	endif;
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="calculateItems" id="6a433502-50fb-49ca-acdf-38d4d71b9884">
        <source>calculateItems();
//--------------------------------------------------------------
//Created: 12 June 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	numRows,
	row,
	count,
	totEntered 	: Integer;
	str		 	: String;
	theSheet 	: JadeTableSheet;
begin

	numRows := 12;

	count := self.tblItems01.sheets;
	while count &gt; 0 do
		theSheet := self.tblItems01.accessSheet(count);
		foreach row in 1 to numRows do
			str := theSheet.accessCell(row, 1).text;
			if str &lt;&gt; null then
				totEntered := totEntered + 1;
			endif;
		endforeach;
		count := count - 1;
	endwhile;
		
	count := self.tblItems02.sheets;
	while count &gt; 0 do
		theSheet := self.tblItems02.accessSheet(count);
		foreach row in 1 to numRows do
			str := theSheet.accessCell(row, 1).text;
			if str &lt;&gt; null then
				totEntered := totEntered + 1;
			endif;
		endforeach;
		count := count - 1;
	endwhile;
	
	count := self.tblItems03.sheets;
	while count &gt; 0 do
		theSheet := self.tblItems03.accessSheet(count);
		foreach row in 1 to numRows do
			str := theSheet.accessCell(row, 1).text;
			if str &lt;&gt; null then
				totEntered := totEntered + 1;
			endif;
		endforeach;
		count := count - 1;
	endwhile;
	
	count := self.tblItems04.sheets;
	while count &gt; 0 do
		theSheet := self.tblItems04.accessSheet(count);
		foreach row in 1 to numRows do
			str := theSheet.accessCell(row, 1).text;
			if str &lt;&gt; null then
				totEntered := totEntered + 1;
			endif;
		endforeach;
		count := count - 1;
	endwhile;
	
	count := self.tblItems05.sheets;
	while count &gt; 0 do
		theSheet := self.tblItems05.accessSheet(count);
		foreach row in 1 to numRows do
			str := theSheet.accessCell(row, 1).text;
			if str &lt;&gt; null then
				totEntered := totEntered + 1;
			endif;
		endforeach;
		count := count - 1;
	endwhile;
	
	count := self.tblItems06.sheets;
	while count &gt; 0 do
		theSheet := self.tblItems06.accessSheet(count);
		foreach row in 1 to numRows do
			str := theSheet.accessCell(row, 1).text;
			if str &lt;&gt; null then
				totEntered := totEntered + 1;
			endif;
		endforeach;
		count := count - 1;
	endwhile;
	
	self.tbEntered.text := totEntered.String;
	self.tbRemaining.text := self.calculateRemaining().String;
end;</source>
    </JadeMethod>
    <JadeMethod name="calculateRemaining" id="bf997781-b6fa-4646-8459-b0a6bec14168">
        <source>calculateRemaining() : Integer;
//--------------------------------------------------------------
//Created: 11 June 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	required, remaining, entered : Integer;
begin
	required := self.tbRequired.text.Integer;
	entered := tbEntered.text.Integer;
	remaining := (required - entered);
	return remaining;
end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="clearTblItems" id="a9f4ed69-fdd4-44a3-af1d-ad87a7742d39">
        <source>clearTblItems();
//--------------------------------------------------------------
//Created: 11 June 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	sheets, count : Integer;
	theSheet : JadeTableSheet;
begin

	sheets := self.tblItems01.sheets;
	
	self.tblItems01.clear();
	count := 1;			
	while count &lt;= sheets do
		theSheet := self.tblItems01.accessSheet(count);
		if count = 1 then
			theSheet.visible := true;
		else
			theSheet.visible := false;
		endif;		
		theSheet.inputType := Table.InputType_TextBox;
		theSheet.clear();		
		count := count + 1;
	endwhile;

	self.tblItems02.clear();
	count := 1;			
	while count &lt;= sheets do
		theSheet := self.tblItems02.accessSheet(count);	
		if count = 1 then
			theSheet.visible := true;		
		else
			theSheet.visible := false;
		endif;
		theSheet.inputType := Table.InputType_TextBox;
		theSheet.clear();				
		count := count + 1;
	endwhile;

	self.tblItems03.clear();
	count := 1;			
	while count &lt;= sheets do
		theSheet := self.tblItems03.accessSheet(count);	
		if count = 1 then
			theSheet.visible := true;		
		else
			theSheet.visible := false;
		endif;
		theSheet.inputType := Table.InputType_TextBox;		
		theSheet.clear();
		count := count + 1;
	endwhile;

	self.tblItems04.clear();
	count := 1;			
	while count &lt;= sheets do
		theSheet := self.tblItems04.accessSheet(count);	
		if count = 1 then
			theSheet.visible := true;		
		else		
			theSheet.visible := false;
		endif;
		theSheet.inputType := Table.InputType_TextBox;
		theSheet.clear();				
		count := count + 1;
	endwhile;

	self.tblItems05.clear();
	count := 1;			
	while count &lt;= sheets do
		theSheet := self.tblItems05.accessSheet(count);	
		if count = 1 then
			theSheet.visible := true;		
		else
			theSheet.visible := false;
		endif;
		theSheet.inputType := Table.InputType_TextBox;
		theSheet.clear();				
		count := count + 1;
	endwhile;

	self.tblItems06.clear();
	count := 1;			
	while count &lt;= sheets do
		theSheet := self.tblItems06.accessSheet(count);	
		if count = 1 then
			theSheet.visible := true;
		else
			theSheet.visible := false;		
		endif;
		theSheet.inputType := Table.InputType_TextBox;
		theSheet.clear();				
		count := count + 1;
	endwhile;					
	
															
end;</source>
