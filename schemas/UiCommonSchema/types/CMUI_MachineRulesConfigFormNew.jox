    <JadeMethod name="doSelectRTMoveMethodRule" id="2ba962e7-91a7-49aa-bb4f-7e249002eecb">
        <source>doSelectRTMoveMethodRule();
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
03 February 2010	cnwer1	Initial creation
02 September 2011	cnwdap1	PAR #25693 CCMS POL 2008 Added Queuing Rule
*/

vars
	rtMoveMethodRule : CM_RTMoveMethodRule;
	idx				: Integer;

begin
	if self.tblMoveRules.row &lt;= 1 then
		return;
	endif;
	rtMoveMethodRule:=self.tblMoveRules.accessRow(self.tblMoveRules.row).itemObject.CM_RTMoveMethodRule;
	
	if rtMoveMethodRule = null then
		return;
	endif;
	
	idx:=self.cmbMoveMethod.findObject(rtMoveMethodRule.myRTMoveMethod);
	if idx &gt; 0 then
		self.cmbMoveMethod.listIndex:=idx;
		self.cmbMoveMethod.click(self.cmbMoveMethod);
	endif;
	self.txtShortDesc.text:=rtMoveMethodRule.shortDescription;
	self.chkDefault.value:=rtMoveMethodRule.isDefault;
	
	// PAR #25693 
	self.cmbQueuingRule.text := rtMoveMethodRule.queuingRule;
	//self.cmbQueuingRule.enabled := rtMoveMethodRule.myRTMoveMethod.description.cnContains("IC"); //cnwrd1 par 31524 6.6.13
	// PAR #25693 end

	if rtMoveMethodRule.mySourceICArea = null then
		self.cmbSourceIC.listIndex:=-1;
	else
		idx:=self.cmbSourceIC.findObject(rtMoveMethodRule.mySourceICArea);
		if idx &gt; 0 then
			self.cmbSourceIC.listIndex:=idx;
		endif;
	endif;
	
	if rtMoveMethodRule.myTargetICArea = null then
		self.cmbTargetIC.listIndex:=-1;
	else
		idx:=self.cmbTargetIC.findObject(rtMoveMethodRule.myTargetICArea);
		if idx &gt; 0 then
			self.cmbTargetIC.listIndex:=idx;
		endif;
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doSelectRuleType" id="d853e26f-7a20-4f1e-accc-c1a9f8bffd41">
        <source>doSelectRuleType();
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
02 February 2010	cnwer1	Initial creation

*/

vars
	ruleType : Integer;
begin
	ruleType:=self.cmbRuleType.listIndex;
	
	if ruleType = RuleTypeTAMaster then
		self.lblToTAMaster.caption:="To TA Master:";
		self.lblFromTAMaster.caption:="From TA Master:";
		self.myAssistant.comboBoxTerminalArea(self.cmbFromTA,TA_TYPE_NULL, null);
		self.myAssistant.comboBoxTerminalArea(self.cmbToTA,TA_TYPE_NULL, null);
	elseif ruleType = RuleTypeTAType then
		self.lblToTAMaster.caption:="To TA Type:";
		self.lblFromTAMaster.caption:="From TA Type:";
		self.myAssistant.comboBoxTAType(self.cmbFromTA,null, true);
		self.myAssistant.comboBoxTAType(self.cmbToTA,null, true);
	endif;
	self.cmbSourceIC.enabled:=false;
	self.cmbSourceIC.clear;
	self.cmbTargetIC.enabled:=false;
	self.cmbTargetIC.clear;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="excludeRTMoveMethod" id="6873eb8a-b680-4263-9810-da98881d973e">
        <source>excludeRTMoveMethod(_rtMoveMethod : CM_RTMoveMethod) : Boolean protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
02 February 2010	cnwer1	Initial creation

*/

vars
	ruleType : Integer;
	taToType,
	taFromType : CM_TerminalAreaType;
	taToMaster ,
	taFromMaster :  CM_TerminalArea;
	
begin
	
	ruleType:=self.cmbRuleType.listIndex;
	
	if ruleType = self.RuleTypeTAMaster then
	
		if not self.cmbToTA.listObject.isKindOf(CM_TerminalArea) then
			self.cmbToTA.listObject:=null;
		endif;
		if not self.cmbFromTA.listObject.isKindOf(CM_TerminalArea) then
			self.cmbFromTA.listObject:=null;
		endif;

		taToMaster:=self.cmbToTA.listObject.CM_TerminalArea;
		taFromMaster:=self.cmbFromTA.listObject.CM_TerminalArea;
		
		return not _rtMoveMethod.isValidForMachineRule( ruleType=self.RuleTypeTAMaster, taToMaster, taFromMaster);	//moved from UI. #21288 21/10/2010
	
	elseif ruleType = self.RuleTypeTAType then
	
		if not self.cmbToTA.listObject.isKindOf(CM_TerminalAreaType) then
			self.cmbToTA.listObject:=null;
		endif;
		if not self.cmbFromTA.listObject.isKindOf(CM_TerminalAreaType) then
			self.cmbFromTA.listObject:=null;
		endif;
	
		taToType:=self.cmbToTA.listObject.CM_TerminalAreaType;
		taFromType:=self.cmbFromTA.listObject.CM_TerminalAreaType;
		
		return not _rtMoveMethod.isValidForMachineRule( ruleType=self.RuleTypeTAMaster, taToType, taFromType);	//moved from UI. #21288 21/10/2010
		
	endif;
	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_rtMoveMethod" type="CM_RTMoveMethod"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="loadFromProxy" id="c2ef6c02-6f19-40a6-9ed0-8f3642c1919b">
        <source>loadFromProxy() protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
02 February 2010	cnwer1	Initial creation

*/

vars
	cmbIndex : Integer;
begin
	self.cmbRuleType.enabled:= self.myProxyMultiRule = null;
	if self.myProxyMultiRule = null then
		return;
	endif;
	
	if self.myProxyMultiRule.isTATypeRule() then
		self.cmbRuleType.listIndex := RuleTypeTAType;
		self.doSelectRuleType();
		cmbIndex:= self.cmbFromTA.findObject(self.myRule.CM_RTQueueMultiRuleTAType.myFromTAType);
		if cmbIndex &gt; 0 then
			self.cmbFromTA.listIndex:=cmbIndex;
		endif;
		
		cmbIndex:= self.cmbToTA.findObject(self.myRule.CM_RTQueueMultiRuleTAType.myToTAType);
		if cmbIndex &gt; 0 then
			self.cmbToTA.listIndex:=cmbIndex;
		endif;
	else
		self.cmbRuleType.listIndex := RuleTypeTAMaster;
		self.doSelectRuleType();
		cmbIndex:= self.cmbFromTA.findObject(self.myRule.CM_RTQueueMultiRuleTAMaster.myFromTAMaster);
		if cmbIndex &gt; 0 then
			self.cmbFromTA.listIndex:=cmbIndex;
			self.loadSourceICCombo();
		endif;
		
		cmbIndex:= self.cmbToTA.findObject(self.myRule.CM_RTQueueMultiRuleTAMaster.myToTAMaster);
		if cmbIndex &gt; 0 then
			self.cmbToTA.listIndex:=cmbIndex;
			self.loadTargetICCombo();
		endif;
	endif;
	
	self.cmbMoveMethod.initialise(true);
	
	self.loadTableFromProxy();

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="loadSourceICCombo" id="cffacf19-fd7a-43ed-bcaa-52a7c711561c">
        <source>loadSourceICCombo() protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
03 February 2010	cnwer1	Initial creation

*/

vars
	ta : CM_TerminalArea;
begin
	if self.cmbFromTA.listIndex &lt; 0 then
		return;
	endif;
	
	ta:=self.cmbFromTA.listObject.CM_TerminalArea;
	
	self.cmbSourceIC.clear;
	self.cmbSourceIC.listCollection(ta.allAssociatedInterchangeAreas,false,0);
	
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="loadTableFromProxy" id="9182f8f6-8a6d-4da3-8f38-ea86e70148dc">
        <source>loadTableFromProxy() protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
03 February 2010	cnwer1	Initial creation

*/

vars

begin
	//load table 
	self.tblMoveRules.rows:=1;
	self.tblMoveRules.displayRowsForCollection(self.myProxyMultiRule.allDefaultRTMoveMethodRules,self.tblMoveRules.backColor,self.tblMoveRules.backColor,app.myPassport);
	self.tblMoveRules.displayRowsForCollection(self.myProxyMultiRule.allOtherRTMoveMethodRules,self.tblMoveRules.backColor,self.tblMoveRules.backColor,app.myPassport);

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="loadTargetICCombo" id="c66bce4f-93bb-4e8b-9c59-61e4b00a4f2f">
        <source>loadTargetICCombo() protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
05 February 2010	cnwer1	Initial creation

*/

vars
	ta : CM_TerminalArea;
begin
	if self.cmbToTA.listIndex &lt; 0 then
		return;
	endif;
	
	ta:=self.cmbToTA.listObject.CM_TerminalArea;
	
	self.cmbTargetIC.clear;
	self.cmbTargetIC.listCollection(ta.allAssociatedInterchangeAreas,false,0);
	

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setFormFromRule" id="d878dae2-3bd7-43a4-aa53-9a134b21d1a7">
        <updating/>
        <source>setFormFromRule() updating, protected;

// Created by cnwdvb1 on 05 September 2006
/*

Date		Who		Reason
01 Apr 2008	conks1	PAR #16296 - Handle deleted rule

*/

vars
	invalidRule		: Boolean;
	edition : Integer;
begin
	
	
	if self.myRule &lt;&gt; null then
	
		on Exception do app.handleDeletedObject(exception, self.myRule, invalidRule);
		
		edition:=self.myRule.edition;
		if invalidRule then
			self.myRule := null;
		endif;
		if self.myRule &lt;&gt; null then
			self.myProxyMultiRule:=app.createUpdateProxy(self.myRule).CM_RTQueueMultiRule;
		endif;	
	endif;
		
	self.loadFromProxy();
	
end;
</source>
        <access>protected</access>
    </JadeMethod>
