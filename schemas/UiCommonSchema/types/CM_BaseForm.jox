    <JadeMethod name="askUserToAbandonChanges" id="9affa689-cc23-4fd6-9fa0-7ac826f1127b">
        <source>askUserToAbandonChanges( _defaultToFirstButton : Boolean ) : Boolean;
// --------------------------------------------------------------------------------
// Created:		19 September 2008 by cnwdad1
//
// Purpose:		Ask the user whether they wish to abandon any changes.
//
// Parameters:	None
//
// Returns:		True if the user chose yes, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 12/01/2009	cnwrl1		Add a boolean for which button is to be the default (CCMS SFW 1047 - Totals Only Lists)
// --------------------------------------------------------------------------------
vars
	userResponse	: Integer;
	defaultButton	: Integer;
	
begin
	if _defaultToFirstButton then
		defaultButton	:= MsgBox_Default_First;
	else
		defaultButton	:= MsgBox_Default_Second;	// setting this one will force the users to actually choose to exit.
	endif;
	
	userResponse	:=	app.msgBox(	app.getErrorString( EditChangedAndClosing ),
									self.caption &amp; " Losing Changes !",
									MsgBox_Yes_No + MsgBox_Question_Mark_Icon + defaultButton );
	
	return (userResponse = MsgBox_Return_Yes);
end;</source>
        <Parameter name="_defaultToFirstButton" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="beginTimerForNotifications" id="914e8045-ade7-4f82-b18b-fbf680b4423e">
        <updating/>
        <source>beginTimerForNotifications(_object : Object; _eventType : Integer; _eventTag : Integer; _userInfo : Any) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13/03/2025	navkc1 JIRA Story MTN-34219: MTN | Notification Framework

*/

vars
	random			: Integer;
	noteRecord		: CMIF_NotificationRecord;
	userStrInfo		: String;
	isUserInfoObj	: Boolean; //27/03/2025	navkc1 JIRA Story MTN-34156
begin
	
	on Exception do self.handleNotificationException(exception); //27/05/2025	navkc1 JIRA MTN 34904
	
	self.endTimer(self.BaseForm_TimerNotes);
	
	if _userInfo.isKindOf(Object) then
		userStrInfo := self.getOidStringForObject(_userInfo.Object);
		isUserInfoObj := true; //27/03/2025	navkc1 JIRA Story MTN-34156
	else
		userStrInfo := _userInfo.String;
	endif;
	
	// Get Notification record
	noteRecord := self.allNoteRecords[_eventType, _object, _eventTag, userStrInfo];
	
	// Create one if not found
	if noteRecord = null then
		create noteRecord transient;
		noteRecord.eventTag := _eventTag;
		noteRecord.eventType := _eventType;
		noteRecord.myObject := _object;
		noteRecord.userInfoString := userStrInfo;
		
		//27/03/2025	navkc1 JIRA Story MTN-34156
		if isUserInfoObj then
			noteRecord.myUserInfo := _userInfo.Object;
		endif;
		
		self.allNoteRecords.addNoDuplicates(noteRecord, false);
		
	endif;
	
	// If we have Notification record, start timer
	if self.allNoteRecords.isNotEmpty() then
		self.beginTimer(500 + app.random(100), Timer_OneShot, self.BaseForm_TimerNotes);
	endif;
	
epilog

end;</source>
        <Parameter name="_object" type="Object"/>
        <Parameter name="_eventType" type="Integer"/>
        <Parameter name="_eventTag" type="Integer"/>
        <Parameter name="_userInfo" type="Any"/>
    </JadeMethod>
