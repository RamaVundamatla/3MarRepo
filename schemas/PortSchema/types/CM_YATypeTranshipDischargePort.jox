    <DbClassMap file="yardAllocations"/>
    <JadeMethod name="getCriteriaObjectForTi" id="1f4d612b-1a20-4b58-b374-9c20496de5f9">
        <source>getCriteriaObjectForTi(_ti: CM_TrackedItem; _criteriaObject: CM_Object output; _process: Boolean output);
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02/11/2010	cnwdap1	Initial creation PAR #26184
*/
vars

begin
	if _ti.myTranshipDetail &lt;&gt; null then 
		_criteriaObject := _ti.myTranshipDetail.myDischargePort;
		_process := true;
	endif;

epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_criteriaObject" type="CM_Object" usage="output"/>
        <Parameter name="_process" type="Boolean" usage="output"/>
    </JadeMethod>
    <JadeMethod name="getTypeName" id="95fbb078-0893-4f5e-8346-f4d96ffd40fc">
        <source>getTypeName(): String;
// PAR 25934
begin
	return "Tranship Discharge Port";
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="isCMIFDataMatch" id="3a774f80-1c12-4345-b488-d24246a1c197">
        <source>isCMIFDataMatch(_cmifAutoPlan: CMIF_YAAutoPlan; _yaData: CM_YADataObjects): Boolean;
// PAR 25934
begin
	return _cmifAutoPlan.isTranshipDischargePort_Match(_yaData);
end;</source>
        <Parameter name="_cmifAutoPlan" type="CMIF_YAAutoPlan"/>
        <Parameter name="_yaData" type="CM_YADataObjects"/>
