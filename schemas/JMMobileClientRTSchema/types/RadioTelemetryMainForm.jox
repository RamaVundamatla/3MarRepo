    <JadeMethod name="btnChangePass_click" id="53711af6-51b7-4307-b9f9-bb5a16c2d4e6">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnChangePass_click(btn: Button input) updating;
// -------------------------------------------
// Created 24 November 2005 by cnwdvb1
// -------------------------------------------
vars
	formObj	: RadioTelemetry_ChangePSWForm;
	
begin
	app.mousePointer	:=	Busy;
	
	create formObj transient;
	fldMainReal.enabled	:=	false;
	formObj.setUserName(self.txtUserName.text);
	formObj.showModal();
epilog
	fldMainReal.enabled	:=	true;
	app.mousePointer	:=	Idle;
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
