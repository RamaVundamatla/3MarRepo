<Class name="CMIF_HumidReading" id="e7bec1dc-3e45-472a-b8dd-6dce4adf4b56">
    <superclass name="CMIF_Object"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="cmtrans"/>
    <PrimAttribute name="dateTime" id="e84de6f4-daad-4a28-b31e-fec03f19ea7f">
        <embedded/>
        <type name="TimeStamp"/>
    </PrimAttribute>
    <PrimAttribute name="humidity" id="eb74148c-ac9c-44de-ae2d-d6c60679a5d0">
        <precision>23</precision>
        <scaleFactor>2</scaleFactor>
        <embedded/>
        <type name="Decimal"/>
    </PrimAttribute>
    <ImplicitInverseRef name="myTerminal" id="4a451fda-cb24-47c2-aa2f-256703cea51c">
        <embedded/>
        <type name="CM_Terminal"/>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="myTrackedItem" id="73822e79-4db6-48cf-b2c2-d2a82097030d">
        <embedded/>
        <type name="CM_TrackedItem"/>
    </ImplicitInverseRef>
    <PrimAttribute name="noCharge" id="0de62d92-a8a5-4e0e-a03e-fd371918bbaa">
        <embedded/>
        <type name="Boolean"/>
    </PrimAttribute>
    <PrimAttribute name="userId" id="12e0500b-097c-412d-8783-59356afaee38">
        <length>11</length>
        <embedded/>
        <type name="String"/>
    </PrimAttribute>
    <JadeMethod name="getHumidity" id="3878b5e4-ab25-4a3c-87fd-faf1ae0cdf23">
        <source>getHumidity():Decimal;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 April 2020	jlgndl1	Initial creation	TFS 47958

*/

vars

begin

	//All Humidity display fields are limited to Decimal 6,2  so don't returm bigger than that
	if self.humidity &gt; 999.99 then
		return 999.99;
	endif;

	return self.humidity;

epilog

end;</source>
        <ReturnType type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="setHumidity" id="eea22d50-c5ef-4f8d-b917-d08d314a30dd">
        <updating/>
        <source>setHumidity( _humidity : Decimal )updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 April 2020	jlgndl1	Initial creation

*/

vars

begin

	self.humidity := _humidity;

epilog

end;</source>
        <Parameter name="_humidity" type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="setTITransController" id="33f83a15-d342-4e2b-9d70-f4a3b1eded30">
        <source>setTITransController(_tiTransController: CMIF_TITransactionController input);
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 17/03/2015	cnwdap1		Initial creation PAR #35874 TFS 265
//
vars

begin
	_tiTransController.userGenerated := false;
	_tiTransController.userId := self.userId;
	_tiTransController.noCharge := self.noCharge;
	_tiTransController.myTrackedItem := self.myTrackedItem;
	_tiTransController.type := TRANS_TYPE_HUMIDITYREADING;
	_tiTransController.dateTime := self.dateTime;
epilog

end;</source>
        <Parameter name="_tiTransController" type="CMIF_TITransactionController" usage="input"/>
    </JadeMethod>
</Class>
