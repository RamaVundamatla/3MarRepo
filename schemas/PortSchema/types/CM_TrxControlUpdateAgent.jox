    <JadeMethod name="trxUpdateRTTaskICLocation" id="5c7e8682-4384-4fb5-afad-eee7ee3199c8">
        <updating/>
        <source>trxUpdateRTTaskICLocation(_locationsController : CM_LocationsController;
							_rtTask : CM_RTQueueTask input;
							_twinLocationController : CM_LocationsController;
							_twinTask : CM_RTQueueTask input;
							_passport : CM_Passport input) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
02 February 2011	cnwer1	Initial creation

*/

vars

begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	app.setContinueCMExceptions(false);

	beginTransaction;

	app.myUtilityUA.utlUpdateRTTaskICLocation(_locationsController, _rtTask,_passport);

	if _passport.hasErrors then
		return;
	endif;
	
	if _twinTask &lt;&gt; null and _twinLocationController &lt;&gt; null then
		app.myUtilityUA.utlUpdateRTTaskICLocation(_twinLocationController, _twinTask,_passport);
	endif;
epilog
	self.finaliseActivityWithPassport(_passport);

end;</source>
        <Parameter name="_locationsController" type="CM_LocationsController"/>
        <Parameter name="_rtTask" type="CM_RTQueueTask" usage="input"/>
        <Parameter name="_twinLocationController" type="CM_LocationsController"/>
        <Parameter name="_twinTask" type="CM_RTQueueTask" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxUpdateRTTaskTargetLocation" id="3c72e8a3-03df-41a7-9604-c4053f49e511">
        <updating/>
        <source>trxUpdateRTTaskTargetLocation(	_locationsController : CM_LocationsController;
								_rtTask : CM_RTQueueTask input;
								_twinLocationController : CM_LocationsController;
								_twinTask : CM_RTQueueTask input;
								_newMoveMethodRule 	: CM_RTMoveMethodRule;
								_passport : CM_Passport input) updating;
// -------------------------------------------
// Created 13 October 2003 by cnwdvb1
// 30 May 2025 naviv1	Bug MTN-34993 - HAT - Error 1081 when Updating RTQ Task Target Location
// -------------------------------------------
vars
	evt 	: CM_SingleObjectUserInfoNoteEvt;
	rtTask 	: CM_RTQueueTask;
	hadLock : Boolean;
begin

	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);
	
	//MTN-34993  -- Added deferred updates and silent deadlock retry handling to prevent contention issues:
	// - Deferred updates help minimize the time spent holding exclusive locks on shared collections 
	// - Silent deadlock retry logic ensures the operation is retried automatically a limited number of times 
	//   in case a deadlock still occurs due to concurrent access by high-volume processes.
	// This combined approach improves overall robustness without impacting performance under normal load.

	on DeadlockException do agtPassportSilDLckExHandlerFlg(exception, hadLock, _passport);  

	// Set up the deadlock reply values
	_passport.setupForDeadlockReplay(-200, 300 + app.random(300));
	_passport.silentDeadlockLimit := 3;	 
	
	//app.setContinueCMExceptions(false);

	
	while true do 																						//30.05.2025 naviv1 #34993
		// Clear any Errors/Warnings we might have
		hadLock := false; 																				//30.05.2025 naviv1 #34993
		_passport.clearErrorsWarnings(); 																//30.05.2025 naviv1 #34993
		
		beginTransaction;
		
		_passport.useEventDeferUpdate := true;															//30.05.2025 naviv1 #34993		
		_passport.useTITransactionDeferUpdate := true;													//30.05.2025 naviv1 #34993									

		app.myUtilityUA.utlUpdateRTTaskTargetLocation(_locationsController, _rtTask, _newMoveMethodRule,_passport);


		if _passport.noErrors() and  _twinTask &lt;&gt; null and _twinLocationController &lt;&gt; null  then 		//30.05.2025 naviv1 #34993
			
			if _twinTask.isOverstowTaskAuto then
				rtTask:=_twinTask;
			else
				rtTask := _twinTask.myEntry.myWorkListEntry.allRTQueueEntries.last.allTasks.last;
			endif;
			
			if rtTask.targetLocation &lt;&gt; _twinLocationController then
				app.myUtilityUA.utlUpdateRTTaskTargetLocation(_twinLocationController, _twinTask, _newMoveMethodRule,_passport);
				
				evt := app.myEventManager.allSingleObjInfoNotes[_twinTask.myEntry.myQueue, _twinTask.getMyTerminal.getTerminalEvent(Event_Update_Queue_Entry), _twinTask.myEntry];
				if evt &lt;&gt; null then
					delete evt;
				endif;
			endif;
		endif;
		
		if _passport.noErrors() then 																	//30.05.2025 naviv1 #34993
			_passport.doDeferredUpdates();
		endif;
		
		if hadLock then 																				//30.05.2025 naviv1 #34993
			if _passport.silentDeadlockRetryCount &gt; _passport.silentDeadlockLimit then
				// Too many errors!
				break;
			else
				hadLock := false;				
				_passport.silentDeadlockRetryCount := _passport.silentDeadlockRetryCount + 1;
				process.sleep(_passport.silentDeadlockSleepTime);
				continue;
			endif;
		endif;

        break;
		
	endwhile;
epilog
	app.myPassport.resetSilentDeadlockHandler; 															//30.05.2025 naviv1 #34993
	self.finaliseActivityWithPassport(_passport);
end;</source>
        <Parameter name="_locationsController" type="CM_LocationsController"/>
        <Parameter name="_rtTask" type="CM_RTQueueTask" usage="input"/>
        <Parameter name="_twinLocationController" type="CM_LocationsController"/>
        <Parameter name="_twinTask" type="CM_RTQueueTask" usage="input"/>
        <Parameter name="_newMoveMethodRule" type="CM_RTMoveMethodRule"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxUpdateRTVehicleConfig" id="52754b04-ad14-4435-a402-acaaa6fc2f14">
        <updating/>
        <source>trxUpdateRTVehicleConfig(	_pxyRTVehicleConfig : CM_RTVehicleConfig input;
							_allCriteria		: CMIF_Array input;
							_passport			: CM_Passport input) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
19 May 2010	cnwer1	Initial creation
20/04/2023	navkc1	Bug 57628: CUX-Adding Criteria to Transaction Mapping allocation configuration results in error
*/

vars
	cmifObject		: CMIF_Object;
	transientObj	: CMIF_YACriteriaPriority;
	proxyObj		: CM_YACriteriaPriority;
	priorityValue	: Real;
	sortValue		: Real;	//20/04/2023	navkc1	Bug 57628 Needs to be the same type as receive

begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	app.setContinueCMExceptions(false);
	
	//epr par 35664 2/3/15
	app.myValUA.valCM_Object(_pxyRTVehicleConfig, _passport);
	
	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	
	// CCMS MES 1080 PAR 24294	15/09/2010
	if _allCriteria &lt;&gt; null then // YA criteria is set only for terminals
		// Now calculate the cargo check item priority values on the proxy objects, working
		// backwards from the least important
		foreach cmifObject in _allCriteria reversed do
			transientObj	:= cmifObject.CMIF_YACriteriaPriority;
			if transientObj.isDeleted then
				continue;
			endif;
			
			proxyObj		:= transientObj.myProxy;
			priorityValue	:= 2 ^ sortValue;
			proxyObj.setPriorityValue(priorityValue);
			sortValue		:= sortValue + 1;
		endforeach;
		
	endif;
	
	// Start the transaction
	beginTransaction;

	app.myUtilityUA.utlUpdateRTVehicleConfig(_pxyRTVehicleConfig, _allCriteria, _passport);
epilog
	self.finaliseActivityWithPassport(_passport);

end;</source>
        <Parameter name="_pxyRTVehicleConfig" type="CM_RTVehicleConfig" usage="input"/>
        <Parameter name="_allCriteria" type="CMIF_Array" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
