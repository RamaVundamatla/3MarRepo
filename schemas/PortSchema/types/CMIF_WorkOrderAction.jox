    </PrimAttribute>
    <PrimAttribute name="populateFromAvailable" id="79de8253-d3eb-4637-90d6-d9db9276f899">
        <embedded/>
        <type name="Boolean"/>
    </PrimAttribute>
    <PrimAttribute name="useYardJobs" id="0867dd31-5231-40db-abb3-f39d0cc33e21">
