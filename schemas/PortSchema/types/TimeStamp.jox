    <JadeMethod name="localToSystemTime" id="e34c2d5e-4ec8-4501-95b9-e31ec4a78d99">
        <source>localToSystemTime(_timeZoneID : String) : TimeStamp;
/*

Purpose:			Convert the receiver TimeStamp from the passed in TimeZone to the current System 
					TimeZone

Parameters:			Windows ID of the receiver TimeStamp's timezone

Return Value:		Receiver TimeStamp converted to the System TimeZone

Date		Who		Reason
11 Mar 2016	cnwkpd1	TFS 488 - Multi Timezone Support


*/

vars

begin
	if app.myTimeZoneHelper = null then
		return self;
	else
		return app.myTimeZoneHelper.convertTime(self, _timeZoneID, app.systemTimeZoneID);
	endif;

epilog

end;</source>
        <Parameter name="_timeZoneID" type="String"/>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="localToSystemTimeUsingObject" id="e3231a48-8c77-4f99-83d2-7b1c0dca9c85">
        <source>localToSystemTimeUsingObject(_ownerObject : Object) : TimeStamp;
/*

Purpose:			Convert the receiver TimeStamp from the passed in object's TimeZone to the current System 
					TimeZone

Parameters:			Object the receiver belongs to

Return Value:		Receiver TimeStamp converted to the System TimeZone

Date		Who		Reason
11 Mar 2016	cnwkpd1	TFS 488 - Multi Timezone Support

*/

vars
	terminal		: CM_Terminal;
	
begin
	terminal := _ownerObject.getMyTerminal();
	
	if terminal = null then
		return self;
	else
		return self.localToSystemTime(terminal.timeZoneID);
	endif;
	
epilog

end;</source>
        <Parameter name="_ownerObject" type="Object"/>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="milliSecondsDiff" id="d5189ded-bd99-46aa-90e1-a0b44447f09b">
        <source>milliSecondsDiff(ts : TimeStamp) : Integer;
//-----------------------------------------
//Created: July 2003 By: cnwgd1
//-----------------------------------------
vars
	i : Integer;

begin

	i := ((((((self.date - ts.date) * 24) + 
		  (self.time.hour -ts.time.hour)) * 60) + 
		   (self.time.minute - ts.time.minute)) * 60 + 
		    (self.time.second-ts.time.second)) * 1000 + (self.time.milliSecond-ts.time.milliSecond);
	return i;

end;</source>
        <Parameter name="ts" type="TimeStamp"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="minutesDiff" id="b9f036ff-3eea-4bad-bc9d-4fd3b0e839ad">
        <source>minutesDiff(endTS : TimeStamp) : Real;
// I am assuming that self = start TimeStamp, endTS = end TimeStamp
// for the moment!
constants
	MinutesInDay		 =	1440;	// 24 * 60
	MillisecondsInMinute =	60000;  // 60 * 1000
vars
	diff	: Real;
begin
	//	number of days difference * minutes in a day
	diff := (endTS.date - self.date) * MinutesInDay;
	if diff &gt; 0 then
		//	more than one day, but which time is greater
		if endTS.time &gt; self.time then
			diff := diff + (endTS.time - self.time) / MillisecondsInMinute;
		else
			//  the last day is not a whole day, so subtract 1 day, then:
			//	add the number of minutes remaining in the day from start time
			//	and the number of minutes of the end time
			diff := diff - MinutesInDay;
			diff := diff + (MinutesInDay - (self.time.Real / MillisecondsInMinute));
			diff := diff + (endTS.time.Real / MillisecondsInMinute);
		endif;
	else
		//	same day, so only difference is in the times
		diff := diff + (endTS.time - self.time) / MillisecondsInMinute;
	endif;
	return(diff);
end;</source>
        <Parameter name="endTS" type="TimeStamp"/>
        <ReturnType type="Real"/>
    </JadeMethod>
