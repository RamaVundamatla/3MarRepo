end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="btnDeleteKey_click" id="a1d1932d-0187-4f2e-8530-9ac756d7ba25">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnDeleteKey_click(btn: Button input) updating;
// --------------------------------------------------------------------------------
// Created:		23 January 2000 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	iniSectionObj	: CnEcIniSection;
	iniKeyObj		: CnEcIniKey;

begin
	app.mousePointer	:=	Busy;

	if lstKey.listIndex = CNEC_NULL_INDEX then
		return;
	endif;

	iniSectionObj	:=	lstSection.listObject.CnEcIniSection;
	iniKeyObj		:=	lstKey.listObject.CnEcIniKey;
	iniSectionObj.deleteIniKey(iniKeyObj.keyName);
	lstKey.listCollection(iniSectionObj.allIniKeys, false, 0);
	self.enableSetting(false, null);
	self.enableButtons();
epilog
	app.mousePointer	:=	Idle;
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="btnDeleteSection_click" id="49940432-3a1d-48fd-b370-d1433cd72c1a">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnDeleteSection_click(btn: Button input) updating;
// --------------------------------------------------------------------------------
// Created:		23 January 2000 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	iniSectionObj	: CnEcIniSection;

begin
	app.mousePointer	:=	Busy;

	if lstSection.listIndex = CNEC_NULL_INDEX then
		return;
	endif;

	iniSectionObj	:=	lstSection.listObject.CnEcIniSection;
	self.aMyIniFile.deleteIniSection(iniSectionObj.sectionName);
	lstSection.listCollection(self.aMyIniFile.allIniSections, false, 0);
	lstKey.clear;
	self.enableSetting(false, null);
	self.enableButtons();
epilog
	app.mousePointer	:=	Idle;
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="btnSet_click" id="b4311150-77f2-40b5-8c4e-c29045ec433e">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnSet_click(btn: Button input) updating;
// --------------------------------------------------------------------------------
// Created:		22 January 2000 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	iniKeyObj	: CnEcIniKey;
	keyValue	: String;
	rowIndex	: Integer;
	listboxObj	: ListBox;

begin
	app.mousePointer	:=	Busy;

	listboxObj	:=	lstKey;

	if listboxObj.listIndex = CNEC_NULL_INDEX then
		return;
	else
		iniKeyObj	:=	listboxObj.listObject.CnEcIniKey;
	endif;

	keyValue	:=	txtSetting.text.trimBlanks();
	iniKeyObj.setKeyValue(keyValue);
	rowIndex	:=	listboxObj.findObject(iniKeyObj);

	if rowIndex &lt;&gt; CNEC_NULL_INDEX then
		listboxObj.itemText[rowIndex]	:=	iniKeyObj.getListDisplay();
	endif;
epilog
	app.mousePointer	:=	Idle;
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="deleteIniFileReference" id="376ca52a-f7f2-4852-8ab2-4be79752c28b">
        <updating/>
        <source>deleteIniFileReference() updating;
// --------------------------------------------------------------------------------
// Created:		22 January 2000 by cnwdad1
//
// Purpose:		Delete the reference to the initialization file.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	delete self.aMyIniFile;
end;</source>
    </JadeMethod>
    <JadeMethod name="enableButtons" id="e59ad3ef-cd62-476f-94af-813367b282df">
        <source>enableButtons();
// --------------------------------------------------------------------------------
// Created:		22 January 2000 by cnwdad1
//
// Purpose:		Set the currently enabled buttons.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if self.aMyIniFile = null then
		btnDeleteSection.enabled	:=	false;
		btnAddKey.enabled			:=	false;
		btnDeleteKey.enabled		:=	false;
	else
		if lstSection.listIndex = CNEC_NULL_INDEX then
			btnDeleteSection.enabled	:=	false;
			btnAddKey.enabled			:=	false;
			btnDeleteKey.enabled		:=	false;
		else
			btnDeleteSection.enabled	:=	true;

			if lstKey.listIndex = CNEC_NULL_INDEX then
				btnAddKey.enabled		:=	true;
				btnDeleteKey.enabled	:=	false;
			else
				btnAddKey.enabled		:=	true;
				btnDeleteKey.enabled	:=	true;
			endif;
		endif;
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="enableSetting" id="12e0378a-c633-4b34-bee2-ea4bbbd96c08">
        <source>enableSetting(pEnabled:Boolean; pSettingValue:String);
// --------------------------------------------------------------------------------
// Created:		22 January 2000 by cnwdad1
//
// Purpose:		Enable (and set if true) the INI setting textbox.
//
// Parameters:	pEnabled - If true, enable the text box.
//				pSettingValue - The INI setting's value.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if pEnabled then
		txtSetting.text		:=	pSettingValue;
	else
		txtSetting.text		:=	null;
	endif;

	txtSetting.readOnly	:=	(not pEnabled);
	btnSet.enabled		:=	pEnabled;
end;</source>
        <Parameter name="pEnabled" type="Boolean"/>
        <Parameter name="pSettingValue" type="String"/>
    </JadeMethod>
    <JadeMethod name="load" id="d2772db6-b476-4a75-9229-8b7b52d69ae1">
        <controlMethod name="Form::load"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>load() updating;
// --------------------------------------------------------------------------------
// Created:		01 February 2000 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	app.mousePointer	:=	Busy;
	inheritMethod();
	centreWindow();
	self.enableSetting(false, null);
	self.enableButtons();
	cnEcMonitor(method.name &amp; " is loading " &amp; self.name &amp; ".");
epilog
	app.mousePointer	:=	Idle;
end;</source>
    </JadeMethod>
    <JadeMethod name="lstKey_click" id="0331a41e-9022-4046-a508-dfff246d8b1c">
        <controlMethod name="ListBox::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>lstKey_click(listbox: ListBox input) updating;
// --------------------------------------------------------------------------------
// Created:		22 January 2000 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if listbox.listIndex = CNEC_NULL_INDEX then
		self.enableSetting(false, null);
	else
		self.enableSetting(true, listbox.listObject.CnEcIniKey.keyValue);
	endif;

	self.enableButtons();
end;</source>
        <Parameter name="listbox" type="ListBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="lstKey_displayEntry" id="e20ebcb2-292b-4a11-934b-1dba04b79d89">
        <controlMethod name="ListBox::displayEntry"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>lstKey_displayEntry(listbox: ListBox input; obj: Any; lstIndex: Integer):String updating;
// --------------------------------------------------------------------------------
// Created:		22 January 2000 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return obj.CnEcIniKey.getListDisplay();
end;</source>
        <Parameter name="listbox" type="ListBox" usage="input"/>
        <Parameter name="obj" type="Any"/>
        <Parameter name="lstIndex" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="lstSection_click" id="42a072a2-7ce3-4bb7-81b0-405866cfd083">
        <controlMethod name="ListBox::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>lstSection_click(listbox: ListBox input) updating;
// --------------------------------------------------------------------------------
// Created:		22 January 2000 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	app.mousePointer	:=	Busy;

	if listbox.listIndex = CNEC_NULL_INDEX then
		lstKey.clear();
	else
		lstKey.listCollection(listbox.listObject.CnEcIniSection.allIniKeys, false, 0);
	endif;

	self.enableSetting(false, null);
	self.enableButtons();
epilog
	app.mousePointer	:=	Idle;
end;</source>
        <Parameter name="listbox" type="ListBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="lstSection_displayEntry" id="48832c3b-7e99-400e-803c-c2f360550bf7">
        <controlMethod name="ListBox::displayEntry"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>lstSection_displayEntry(listbox: ListBox input; obj: Any; lstIndex: Integer):String updating;
// --------------------------------------------------------------------------------
// Created:		22 January 2000 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return obj.CnEcIniSection.getListDisplay();
end;</source>
        <Parameter name="listbox" type="ListBox" usage="input"/>
        <Parameter name="obj" type="Any"/>
        <Parameter name="lstIndex" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="unload" id="395bf7eb-f73b-4807-9778-539d62683153">
        <controlMethod name="Form::unload"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>unload() updating;
// --------------------------------------------------------------------------------
// Created:		22 January 2000 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.deleteIniFileReference();
end;</source>
