    <JadeMethod name="deleteWONoVal" id="57612188-7596-48fc-af1c-e8dee993fa6c">
        <source>deleteWONoVal(_workOrder : String; _term : CM_Terminal);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 Sep 2023 navhl20 ChangeRequest 59638: EUP | Ship Operations in DD - [54176.010] - [Receive] Work Order Detail Grouping

*/
vars
	workOrder : CM_WorkOrder;
	wod       : CM_WorkOrderDtl;
	job		  : CM_Job;
	jobArr    : CM_JobArray;
	wodTodo	  : CM_WodToDo;
begin
	create jobArr transient;
	
	workOrder := _term.allWorkOrders[_workOrder];
	if workOrder &lt;&gt; null then
		
		foreach wod in workOrder.allWoDtls do
			
			if wod.isKindOf(CM_WorkOrderTIDtl) then
				foreach job in wod.CM_WorkOrderTIDtl.allJobs do
					jobArr.add(job);
				endforeach;
				foreach wodTodo in  wod.CM_WorkOrderTIDtl.allToDoRequests do 
					
					foreach job in wodTodo.allJobs do
						jobArr.add(job);
					endforeach;
				endforeach;
			elseif wod.isKindOf(CM_WorkOrderToDoDtl) then
				foreach job in wod.CM_WorkOrderToDoDtl.allJobs do
					jobArr.add(job);
				endforeach;
			endif;
		endforeach;
		
		beginTransaction;
		
		jobArr.purge();
		
		workOrder.erase(NORMAL_ERASE);
		
		commitTransaction;
	endif;
epilog
	delete jobArr;
end;</source>
        <Parameter name="_workOrder" type="String"/>
        <Parameter name="_term" type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="dqmFixToDoResource" id="e17ffe59-fae0-451a-8340-1d0cad99707d">
        <source>dqmFixToDoResource();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 September 2024		navma1	Initial creation

*/

vars
	resourceType : CM_ResourceType;
begin
	resourceType := "10777.285".asOid.CM_ResourceType;
	
	if resourceType &lt;&gt; null then
