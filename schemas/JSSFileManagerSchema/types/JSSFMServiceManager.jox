        <embedded/>
        <type name="Boolean"/>
        <access>readonly</access>
    </PrimAttribute>
    <ImplicitInverseRef name="myFileBrowserForm" id="ee6889f8-f256-441a-8377-19072b1795b7">
        <embedded/>
        <type name="JSSFMFileBrowserForm"/>
        <access>readonly</access>
