    </JadeMethod>
    <JadeMethod name="getAuditText" id="0ebc9dca-7514-4ddc-b56d-ff8317d4d025">
        <source>getAuditText(): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 December 2022	navkc1	Initial creation TFS CR 55300 TASK 55524

*/

vars
	audTxt, 
	tmpStr			: String;
	size,
	year,
	seq				: Integer;
begin
	audTxt[10000] 	:= '*';
	
	audTxt := inheritMethod();
	
	size := self.nextSequenceNumArray.size();
	
	if size = 0 then
		return audTxt;
	endif;
	
	while year &lt; size do
		year += 1;
		
		seq := self.nextSequenceNumArray[year].Integer;
		
		if seq = 0 then
			continue;
		endif;
		
		tmpStr := (2000 + year).String &amp; "-" &amp; seq.String &amp; Cr &amp; tmpStr;
	endwhile;
	
	audTxt := audTxt &amp; AuditStringSeparator &amp; CM_AutoExternalNumberGen::nextSequenceNum.name &amp; AuditStringSeparator &amp; tmpStr.length().String &amp; AuditStringSeparator &amp; tmpStr;
	
	return audTxt;
	
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getNextSequenceNumArray" id="5e3e498b-0f09-4c10-a150-55ab06921466">
        <source>getNextSequenceNumArray( theYear : Integer ): Real;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 June 2018	jlgndl1	Initial creation	TFS 39197
18 July 2018	jlgma1	ChangeRequest 39698: PEL1 - SAP Enable SAP interfaces
*/

vars

begin
	if self.nextSequenceNumArray.size &lt; theYear then  //18.7.18 cnwma1 TFS #39698
		return 0;
	endif;
	return self.nextSequenceNumArray[ theYear ];

epilog

end;</source>
        <Parameter name="theYear" type="Integer"/>
        <ReturnType type="Real"/>
    </JadeMethod>
