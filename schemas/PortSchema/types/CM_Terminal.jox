    <JadeMethod name="logNextSeqNoNumber" id="d9a6df4d-3361-4d69-b5c4-ceab8b78d7fc">
        <methodInvocation>mapping</methodInvocation>
        <updating/>
        <source>logNextSeqNoNumber(set: Boolean; _value: String io)updating, mapping;
//--------------------------------------------------------------
//Created: 17 May 2002 By: cnwgd1
//--------------------------------------------------------------
constants
	KeyDesc = 'LogNoNumber Sequence Number';
vars
	theKeySeries 	: CM_KeySeries;
	seriesKey		: CM_SeriesKey;
	prefix,
	suffix 			: String;
	root 			: Integer;
	keyLocked		: Boolean;
begin
	if set then
		app.raiseSetVirtualError(class.name, method.name);	
		return;
	endif;
	
	//17 May 2012	NDL	Par 28193 - Being a mapping method this is
	// called from CardSchema when a system dump is being performed... 
	// If we are not in trans state, the crash caused by the 1048,
	// means we don't get the rest of the details for terminal in the dump
	if not self.isTransient then
		if not process.isInTransactionState then
			return;
		endif;
	endif;
	
	prefix := self.getConfig(LogNoNumberPrefix).String;
	if prefix = null then
		prefix := self.code;
	endif;
	theKeySeries := self.allKeySeriesByCode[SN_LogNoNumberSeqNo];
	
	if theKeySeries = null then
		create theKeySeries persistent;
		theKeySeries.set(SN_LogNoNumberSeqNo, KeyDesc, self);
		create seriesKey persistent;
		seriesKey.set(prefix, 1);
		theKeySeries.nextKey := seriesKey;
	else
		seriesKey := theKeySeries.nextKey;
		if seriesKey.prefix &lt;&gt; prefix then
			seriesKey.set(prefix, 1);
		endif;
	endif;

	lock(theKeySeries, Reserve_Lock, Transaction_Duration, 5000);
	keyLocked := true;	//17 May 2012	NDL	Par 28193

	theKeySeries.reserve(app.computerName, process.signOnUserCode, prefix, root, suffix);
	theKeySeries.issue(app.computerName, process.signOnUserCode);

	_value := prefix &amp; root.String;	// &amp; suffix; not used at present.

epilog
	if keyLocked then	//17 May 2012	NDL	Par 28193
		unlock(theKeySeries);
	endif;		
end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="logNextSeqNumber" id="760511c9-b570-44ac-95a0-a5ad800cf18c">
        <methodInvocation>mapping</methodInvocation>
        <updating/>
        <source>logNextSeqNumber(set: Boolean; _value: String io)updating, mapping;
//--------------------------------------------------------------
//Created: 17 May 2002 By: cnwgd1
//--------------------------------------------------------------
constants
	KeyDesc = 'Log Sequence Number';
vars
	theKeySeries 	: CM_KeySeries;
	seriesKey		: CM_SeriesKey;
	prefix,
	suffix 			: String;
	root 			: Integer;
	keyLocked		: Boolean;
begin

	if set then
		app.raiseSetVirtualError(class.name, method.name);	
		return;
	endif;
	
	//17 May 2012	NDL	Par 28193 - Being a mapping method this is
	// called from CardSchema when a system dump is being performed... 
	// If we are not in trans state, the crash caused by the 1048,
	// means we don't get the rest of the details for terminal in the dump
	if not self.isTransient then
		if not process.isInTransactionState then
			return;
		endif;
	endif;
	
	prefix := self.getConfig(LogSeqNumberPrefix).String;
	if prefix = null then
		prefix := self.code;
	endif;	
	theKeySeries := self.allKeySeriesByCode[SN_LogSeqNumber];
	
	if theKeySeries = null then
		create theKeySeries persistent;
		theKeySeries.set(SN_LogSeqNumber, KeyDesc, self);
		create seriesKey persistent;
		seriesKey.set(prefix, 1);
		theKeySeries.nextKey := seriesKey;
	else
		seriesKey := theKeySeries.nextKey;
		if seriesKey.prefix &lt;&gt; prefix then
			seriesKey.set(prefix, 1);
		endif;
	endif;

	lock(theKeySeries, Reserve_Lock, Transaction_Duration, 5000);
	keyLocked := true;	//17 May 2012	NDL	Par 28193

	theKeySeries.reserve(app.computerName, process.signOnUserCode, prefix, root, suffix);
	theKeySeries.issue(app.computerName, process.signOnUserCode);

	_value := prefix &amp; root.String;	// &amp; suffix; not used at present.

epilog
	if keyLocked then	//17 May 2012	NDL	Par 28193
		unlock(theKeySeries);
	endif;		
end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="lookupAllNotifiedOnsiteTIs" id="82072eb7-43e9-4d8e-bb56-248cc4cb7dea">
        <source>lookupAllNotifiedOnsiteTIs(_cargoType : Integer;
							_id : String; 
							_tis : Btree input;
							_searchReversed : Boolean;
							_cmifMonitor : CMIF_Monitor input);

/*

Purpose:			Find all prenoted tracked items of the passed in cargo type with an id (can be partial)
					matching passed in id


Return Value:		_tis populated with unique tracked items


Date		Who		Reason
20 Nov 2009	cnwer1	Initial creation
// 06 Sep 2016	cnwrs1	TFS 2586 dont always include archived voyages and lookup reveresed even if we found data in non reverese lookup
*/

vars
	set				: CM_TISet;

begin
	if _tis = null then
		app.raiseCMException2(MethodWithNullParam, method.name, '_tis', null, null);
		return;
	endif;
	
	create set transient;
	
	//epr TFS 1602 1/3/17 removed redundant if statement
//	self.allNotifiedTIsByCargoTypeId.lookupAllTIsUsingIdCargoType(_id, _cargoType, set, _cmifMonitor);

	//05 Jul 2017	NDL	TFS 5238 - Use the other collection if null cargo type...
	if _cargoType = null then
		self.allNotifiedTIsByIdCargoType.lookupAllTIsUsingIdCargoType(_id, _cargoType, set, _cmifMonitor);
	else
		self.allNotifiedTIsByCargoTypeId.lookupAllTIsUsingIdCargoType(_id, _cargoType, set, _cmifMonitor);
	endif;
	
	
	if set.isEmpty or
	   _searchReversed then
		// Check for reversed
		self.allNotifiedTIsByCargoTypeIdRev.lookupAllTIsUsingIdCargoType(_id.reverse, _cargoType, set, _cmifMonitor);
		if set.isEmpty then
			// TI not found
			return;
		endif;
	endif;

	set.copyNoDuplicates(_tis, false);
	
	
epilog
	delete set;

end;</source>
        <Parameter name="_cargoType" type="Integer"/>
        <Parameter name="_id" type="String"/>
        <Parameter name="_tis" type="Btree" usage="input"/>
        <Parameter name="_searchReversed" type="Boolean"/>
        <Parameter name="_cmifMonitor" type="CMIF_Monitor" usage="input"/>
    </JadeMethod>
    <JadeMethod name="lookupAllOffSiteTrackedItems" id="8c2487de-f084-48c1-b238-46ab44ef6108">
        <source>lookupAllOffSiteTrackedItems(pCargoType : Integer; pId : String; _tis : CM_TISet input; _searchReversed : Boolean; _cmifMonitor : CMIF_Monitor input);
// ---------------------------------------------------------------------------
// Created:     13 February 2001 by cnwdwq1
//
// Purpose: 	Copies ALL TI's for this ID and cargoType into passed in array.
// 06 Sep 2016	cnwrs1	TFS 2586 dont always include archived voyages and lookup reveresed even if we found data in non reverese lookup
// ---------------------------------------------------------------------------
vars
	set		: CM_TISet;
	ls : Boolean;
begin

	create set transient;
	ls := process.isInLoadState;
	endLoad;
	beginLoad;
	if pCargoType = null then
		self.allOffsiteTIsByIdCargoType.lookupAllTIsUsingIdCargoType(pId, pCargoType, set, _cmifMonitor);
	else
		self.allOffsiteTIsByCargoTypeId.lookupAllTIsUsingIdCargoType(pId, pCargoType, set, _cmifMonitor);
	endif;
	endLoad;
	if set.isEmpty or
	   _searchReversed then
		// Check for reversed
		beginLoad;
// 06 Sep 2016	cnwrs1	TFS 2586 dont always include archived voyages and lookup reveresed even if we found data in non reverese lookup
		if pCargoType = null then
			self.allOffsiteTIsByIdCargoTypeRev.lookupAllTIsUsingIdCargoType(pId.reverse, pCargoType, set, _cmifMonitor);
		else
			self.allOffsiteTIsByCargoTypeIdRev.lookupAllTIsUsingIdCargoType(pId.reverse, pCargoType, set, _cmifMonitor);
		endif;
		endLoad;
		if set.isEmpty then
			// TI not found
			return;
		endif;
	endif;
	set.copyNoDuplicates(_tis, false);
epilog
	delete set;
	if ls and not 	process.isInLoadState then
		beginLoad;
	else
		endLoad;
	endif;
end;</source>
        <Parameter name="pCargoType" type="Integer"/>
        <Parameter name="pId" type="String"/>
        <Parameter name="_tis" type="CM_TISet" usage="input"/>
        <Parameter name="_searchReversed" type="Boolean"/>
        <Parameter name="_cmifMonitor" type="CMIF_Monitor" usage="input"/>
    </JadeMethod>
    <JadeMethod name="lookupAllOnShipTIsInPortFrom" id="f5608d4c-4a95-4aee-85a7-e8caf89c06b9">
        <source>lookupAllOnShipTIsInPortFrom(_id : String; 
							_cargoType : Integer;
							_fromTS: TimeStamp;
							_tis : Btree input;
							_tryReversed : Boolean;
							_cmifMonitor : CMIF_Monitor input);
/*

Date		Who		Reason
22 January 2014	cnwer1	Initial creation PAR
04/03/2015		cnwmh5	Tranisent Leak
11 Nov 2017	EPR TFS 7725 adde try reversed as a parameter
*/

vars
	upperId	: String;
	voy 	: CM_Voyage;
	ls		: Boolean;
	tSet	: CM_TISet;
	iter	: Iterator;

begin

	create tSet transient;
	upperId := _id.toUpper;
	
	iter := self.allVoyagesByArrivalDTCode.createIterator;
	if _fromTS &lt;&gt; null then
		self.allVoyagesByArrivalDTCode.startKeyGeq(_fromTS, null, iter);
	endif;
	while iter.next(voy) do
		if voy.isCancelled then  //jlier1 TFS51963 5/10/21
			continue;
		endif;
		beginLoad;
		if (not voy.lookupAllTrackedItems(upperId, _cargoType, false, _tryReversed, tSet, _cmifMonitor)) then
			break;
		endif;
		endLoad;
		if tSet.isEmpty = false then
			tSet.copyNoDuplicates(_tis, false);
			tSet.clear;
		endif;
	endwhile;
	endLoad;
epilog
	delete iter;
	delete tSet;
end;</source>
        <Parameter name="_id" type="String"/>
        <Parameter name="_cargoType" type="Integer"/>
        <Parameter name="_fromTS" type="TimeStamp"/>
        <Parameter name="_tis" type="Btree" usage="input"/>
        <Parameter name="_tryReversed" type="Boolean"/>
        <Parameter name="_cmifMonitor" type="CMIF_Monitor" usage="input"/>
    </JadeMethod>
    <JadeMethod name="lookupAllOnShipTrackedItems" id="9282f1e0-7685-4222-9395-d9b506b43950">
        <source>lookupAllOnShipTrackedItems(_id : String; _cargoType : Integer; _includeOffLoaded, _includeArchivedVoyages, _searchReversed : Boolean; _tis : Btree input; _cmifMonitor : CMIF_Monitor input);
// ---------------------------------------------------------------------------
// Created:     18 November 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// July 07      cnwrs1      add archived option for Container enq
// 06 Sep 2016	cnwrs1	TFS 2586 dont always include archived voyages and lookup reveresed even if we found data in non reverese lookup
// ---------------------------------------------------------------------------
vars
	upperId	: String;
	voy 	: CM_Voyage;
	ls		: Boolean;
	tSet	: CM_TISet;
	iter	: Iterator;
begin

	create tSet transient;
	upperId := _id.toUpper;

//	app.cmsBeginLoad(ls); Removed due to duration of lock DQ 31 may 04
	ls := process.isInLoadState;
	endLoad;
	if _includeArchivedVoyages then
		iter := self.allVoyagesSet.createIterator;
	else
		iter := self.allVoyagesByCode.createIterator;
	endif;
	while iter.next(voy) do
		//	foreach voy in self.allVoyagesByCode do
	 	//Search in each voyage
		beginLoad;
		if (not voy.lookupAllTrackedItems(upperId, _cargoType, _includeOffLoaded, _searchReversed, tSet, _cmifMonitor)) then
			break;
		endif;
		endLoad;
		if tSet.isEmpty = false then
			tSet.copyNoDuplicates(_tis, false);
			tSet.clear;
		endif;
	endwhile;
	endLoad;

epilog
//	app.cmsEndLoad(ls);	Removed due to duration of lock
	delete iter;
	if ls and not 	process.isInLoadState then
		beginLoad;
	else
		endLoad;
	endif;
	delete tSet;
end;</source>
        <Parameter name="_id" type="String"/>
        <Parameter name="_cargoType" type="Integer"/>
        <Parameter name="_includeOffLoaded" type="Boolean"/>
        <Parameter name="_includeArchivedVoyages" type="Boolean"/>
        <Parameter name="_searchReversed" type="Boolean"/>
        <Parameter name="_tis" type="Btree" usage="input"/>
        <Parameter name="_cmifMonitor" type="CMIF_Monitor" usage="input"/>
    </JadeMethod>
    <JadeMethod name="lookupAllOnsiteTrackedItems" id="a10d5252-3c98-40f2-8428-aa81244459b8">
        <source>lookupAllOnsiteTrackedItems(_cargoType : Integer;
							_id : String; 
							_tis : Btree input;
							 _searchReversed : Boolean;
							_cmifMonitor : CMIF_Monitor input);

/*

Purpose:			Find all onsite tracked items of the passed in cargo type with an id (can be partial)
					matching passed in id


Return Value:		_tis populated with unique tracked items


Date		Who		Reason
29 Feb 2008	cnwkpd1	PAR #16010 - CCMS Otago 1502 - Thin Client RT Enhancements
// 06 Sep 2016	cnwrs1	TFS 2586 dont always include archived voyages and lookup reveresed even if we found data in non reverese lookup
*/

vars
	set				: CM_TISet;

begin
	if _tis = null then
		app.raiseCMException2(MethodWithNullParam, method.name, '_tis', null, null);
		return;
	endif;
	
	create set transient;
	
	if _cargoType = null then
		self.allOnsiteTIsByIdCargoType.lookupAllTIsUsingIdCargoType(_id, _cargoType, set, _cmifMonitor);
	else
		self.allOnsiteTIsByCargoTypeId.lookupAllTIsUsingIdCargoType(_id, _cargoType, set, _cmifMonitor);
	endif;
	
	if set.isEmpty or
	   _searchReversed then
		// Check for reversed
// 06 Sep 2016	cnwrs1	TFS 2586 dont always include archived voyages and lookup reveresed even if we found data in non reverese lookup
		if _cargoType = null then
			self.allOnsiteTIsByIdCargoTypeRev.lookupAllTIsUsingIdCargoType(_id.reverse, _cargoType, set, _cmifMonitor);
		else
			self.allOnsiteTIsByCargoTypeIdRev.lookupAllTIsUsingIdCargoType(_id.reverse, _cargoType, set, _cmifMonitor);
		endif;
		if set.isEmpty then
			// TI not found
			return;
		endif;
	endif;

	set.copyNoDuplicates(_tis, false);
	
	
epilog
	delete set;

end;</source>
        <Parameter name="_cargoType" type="Integer"/>
        <Parameter name="_id" type="String"/>
        <Parameter name="_tis" type="Btree" usage="input"/>
        <Parameter name="_searchReversed" type="Boolean"/>
        <Parameter name="_cmifMonitor" type="CMIF_Monitor" usage="input"/>
    </JadeMethod>
    <JadeMethod name="lookupAllOnsiteTrailers" id="097ecbea-c749-4f2b-969a-61e2abd3d4c4">
        <source>lookupAllOnsiteTrailers(_cargoType : Integer;
						_id : String; 
						_tis : Btree input; 
						 _searchReversed : Boolean;
						_cmifMonitor : CMIF_Monitor input);
/*

Date		Who		Reason
24 September 2013	cnwer1	Initial creation PAR
// 06 Sep 2016	cnwrs1	TFS 2586 dont always include archived voyages and lookup reveresed even if we found data in non reverese lookup
*/

vars
set				: CM_TISet;
	cargoType  : CM_CargoBOLType;
begin
	if _tis = null then
		app.raiseCMException2(MethodWithNullParam, method.name, '_tis', null, null);
		return;
	endif;
	
	create set transient;
	
	if _cargoType = null then
		foreach cargoType in self.allCargoBOLTypes where  cargoType.isTrailer do
			self.allOnsiteTIsByCargoTypeId.lookupAllTIsUsingIdCargoType(_id, cargoType.id, set, _cmifMonitor);
		endforeach;
	else
		self.allOnsiteTIsByCargoTypeId.lookupAllTIsUsingIdCargoType(_id, _cargoType, set, _cmifMonitor);
	endif;
	
	if set.isEmpty or
	   _searchReversed then
		// Check for reversed
		if _cargoType = null then
			foreach cargoType in self.allCargoBOLTypes where  cargoType.isTrailer do
				self.allOnsiteTIsByIdCargoTypeRev.lookupAllTIsUsingIdCargoType(_id.reverse, cargoType.id, set, _cmifMonitor);
			endforeach;
		else
			self.allOnsiteTIsByIdCargoTypeRev.lookupAllTIsUsingIdCargoType(_id.reverse, _cargoType, set, _cmifMonitor);
		endif;
	endif;
	

	set.copyNoDuplicates(_tis, false);
	
	
epilog
	delete set;
end;</source>
        <Parameter name="_cargoType" type="Integer"/>
        <Parameter name="_id" type="String"/>
        <Parameter name="_tis" type="Btree" usage="input"/>
        <Parameter name="_searchReversed" type="Boolean"/>
        <Parameter name="_cmifMonitor" type="CMIF_Monitor" usage="input"/>
    </JadeMethod>
