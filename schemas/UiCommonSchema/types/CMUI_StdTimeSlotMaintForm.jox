    <JadeMethod name="setupForm" id="dda7efaa-f609-4b45-af3f-0c5bd9aba6ac">
        <updating/>
        <source>setupForm() updating;
// ---------------------------------------------------------------------------
// Created:		April  2007 By Andrew Yi Liu (cnwyl1)
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin
	inheritMethod();
	self.beginClassNotification(CM_TimeSlotStd, false, self.myTerminal.getTerminalEvent(Event_TimeSlotStd_Add), Response_Continuous, null);
	self.beginClassNotification(CM_TimeSlotStd, false, self.myTerminal.getTerminalEvent(Event_TimeSlotStd_Update), Response_Continuous, null);
	self.beginClassNotification(CM_TimeSlotStd, false, self.myTerminal.getTerminalEvent(Event_TimeSlotStd_Delete), Response_Continuous, null);

	self.beginClassNotification(CM_TimeSlot, false, self.myTerminal.getTerminalEvent(Event_TimeSlot_Add), Response_Continuous, null);
	self.beginClassNotification(CM_TimeSlot, false, self.myTerminal.getTerminalEvent(Event_TimeSlot_Update), Response_Continuous, null);
	self.beginClassNotification(CM_TimeSlot, false, self.myTerminal.getTerminalEvent(Event_TimeSlot_Delete), Response_Continuous, null);
	
	self.toolbarStyle := self.ToolbarStyle_ShowNoHide;
	self.showToolbar := true;
	self.frmToolbar.priorityRight := true;
	self.frmCreateDlg.visible := false;
	self.myTerminal := app.myPassport.myTerminal;
	self.initForm();
	self.width := self.tblTimeSlot.width;
	self.height := self.tblTimeSlot.height + 200;
	
	if self.formType = FORM_TYPE_STD then
		self.caption := "Standard Time Slot";
	else
		self.caption := "Time Slot";
	endif;
	
	self.getXMLSettingsForSetup();
end;</source>
    </JadeMethod>
    <JadeMethod name="showContextMenu" id="e00bf807-41a5-4035-a4ef-d1c1b8c485b9">
        <updating/>
        <source>showContextMenu(pMenuItem: MenuItem; cntrl: Control input; conwin: Window input; mouse: Boolean; x: Integer; y: Integer): Boolean updating;

vars

begin
	if self.formType = FORM_TYPE_STD then
		self.mnuCopyTimeSlot.visible := false;
	else
		self.mnuCopyTimeSlot.visible := true;
	endif;
	
	return inheritMethod(pMenuItem, cntrl, conwin, mouse, x, y);
end;
</source>
        <Parameter name="pMenuItem" type="MenuItem"/>
        <Parameter name="cntrl" type="Control" usage="input"/>
        <Parameter name="conwin" type="Window" usage="input"/>
        <Parameter name="mouse" type="Boolean"/>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="tblTimeSlot_contextMenu" id="8c769a82-e4ab-4fff-a6ea-cd06df0231b6">
        <controlMethod name="Table::contextMenu"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblTimeSlot_contextMenu(table: Table input; conwin: Window input; mouse: Boolean; x: Integer; y: Integer):Boolean updating;

vars

begin
	self.mnuInspect.visible := app.isAllowedToInspect();
	if self.myCurrentTimeSlot &lt;&gt; null and app.isValidObject(self.myCurrentTimeSlot) then
		self.mnuInspect.userObject := self.myCurrentTimeSlot;
		if self.mnuInspect.userObject.isTransient() then
			self.mnuInspect.caption := "Inspect Transient Object...";
		else
			self.mnuInspect.caption := "Inspect Persistent Object...";
		endif;
		return self.showContextMenu(mnuTS, table, conwin, mouse, x, y);
	endif;
	
	
end;
</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="conwin" type="Window" usage="input"/>
        <Parameter name="mouse" type="Boolean"/>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="tblTimeSlot_queryRowColChg" id="d1335e6f-22b5-4813-ab16-d74812057da7">
        <controlMethod name="CM_DataTable::queryRowColChg"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblTimeSlot_queryRowColChg(table: Table input; newSheet: Integer; newRow: Integer; newCol: Integer):Boolean updating;
// ---------------------------------------------------------------------------
// Created:     cnwyl1  Yi Liu
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	result	: Integer;
begin

	if table.row = newRow then
		// must be a column change so don't care
		return true;
	endif;

	if self.mode = self.MODE_VIEW then
		// viewing so no check needed.
		return true;
	elseif self.mode = self.MODE_ADD then
		result := app.msgBox(app.getErrorString(QueryRowChange),  app.getErrorString(Warning), MsgBox_Yes_No_Cancel + MsgBox_Question_Mark_Icon);
		
		if result = MsgBox_Return_Cancel then
			// do NOT move to new row.
			return false;
		elseif result = MsgBox_Return_No then
			// cancel changes to existing item and move to the next row
			self.doBaseFormCancel();
			return true;
		elseif result = MsgBox_Return_Yes then
			// save the existing item, if successful then move to the new row;
			self.doBaseFormSave();
			return true;
		endif;
	else
		return true;
	endif;
	return false;
epilog

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="newSheet" type="Integer"/>
        <Parameter name="newRow" type="Integer"/>
        <Parameter name="newCol" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
