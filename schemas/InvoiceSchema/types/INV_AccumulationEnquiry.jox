    <JadeMethod name="addRowToTable" id="aad9486c-b078-47aa-ac77-a2ff581d2252">
        <source>addRowToTable(_contractAcc : CM_InvoiceContractAccumulate);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 Mar 2023 navtnr20	TFS CR 55647 Task 55697: UI - Volume Based Enquiry of Accumulations

*/

vars
	theDataLine : String;

begin
	theDataLine := _contractAcc.getAttributeStringForDefArray(self.tblData.allTblDataEntRows);
	self.tblData.accessRow(self.tblData.addItem(theDataLine)).itemObject := _contractAcc;
epilog

end;</source>
