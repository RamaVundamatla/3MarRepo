    <JadeMethod name="activate" id="c1ff715b-7b08-4d6e-9dcf-43cf7d1b5424">
        <controlMethod name="Form::activate"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>activate() updating;
// ---------------------------------------------------------------------------
// Created:     06 December 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	app.setMyTerminal(self.myTerminal);
	if self.myTerminal = null then
		app.writeStatement( class.name &amp; '::' &amp; method.name &amp; ' *** myTerminal is null for ' &amp; self.String);
	endif;

end;</source>
    </JadeMethod>
    <JadeMethod name="btnCancel_click" id="6505e519-ef10-4199-beab-294d45af461a">
        <controlMethod name="Button::click"/>
