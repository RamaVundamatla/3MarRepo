    <JadeMethod name="btnHazDetails_click" id="ab8ee272-e875-4090-aeeb-fd8beacfc01a">
        <controlMethod name="CMUI_Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnHazDetails_click(btn: Button input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 September 2018	jlgab1	Initial creation

*/

vars

begin
		self.myAssistant.showHazardousDetailsSnapShot(self.myTerminal, self.myProxyObject, self, self.myMasterMenuAction);
epilog

end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
