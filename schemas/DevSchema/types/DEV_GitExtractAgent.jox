    <JadeMethod name="create" id="18433eb6-2036-4102-b539-7305466e405b">
        <updating/>
        <source>create() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
11 July 2025		navmd1	Initial creation

*/

vars
	
begin
	self.allMethodsToExtract.setMembership(Method);
	self.allMethodsToExtract.addExternalKey(Schema, 0, false, false);
	self.allMethodsToExtract.addExternalKey(Class, 0, false, false);
	self.allMethodsToExtract.addExternalKey(String, 100, false, false);
	self.allMethodsToExtract.endKeys(false);
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="parseMethodNames" id="4fdd8995-f443-46a7-8c8a-d181e62cf335">
        <source>parseMethodNames(_text : String);
/*

Purpose:			

Parameters:			_text	String	A list of method names/classes seperated by CrLf

Return Value:		

Date				Who		Reason
11 July 2025		navmd1	Initial creation

*/

vars
	inputStr,
	line,
	part1,
	part2,
	part3		: String;
	portSchema,
	scm			: Schema;
	lineIdx,
	idx			: Integer;
begin
	portSchema := rootSchema.getSchema(PortSchemaName);
	
	inputStr := _text.trimBlanks().replace__(CrLf, Space, false);
	lineIdx := 1;
	
	while lineIdx &gt; 0 do
		idx := 1;
		part1 := null;
		part2 := null;
		part3 := null;
		
		line := inputStr.scanUntil(" ", lineIdx);
		
		part1 := line.scanUntil(":", idx);
		line.scanWhile(":", idx);
		part2 := line.scanUntil(":", idx);
		if idx &gt; 0 then
			line.scanWhile(":", idx);
			if idx = 0 then
				write "Bad method/class entry. Unable to parse [" &amp; line &amp; "]";
				return;
			endif;
			part3 := line[idx:end];
		endif;
		write "Found: " &amp; part1 &amp; Space &amp; part2 &amp; Space &amp; part3;
		
		if part3 &lt;&gt; null then
			// Must be a method/attribute
//			scm := portSchema.
		endif;
		
		inputStr.scanWhile(" ", lineIdx);
	endwhile;
epilog
	
end;</source>
        <Parameter name="_text" type="String"/>
    </JadeMethod>
</Class>
