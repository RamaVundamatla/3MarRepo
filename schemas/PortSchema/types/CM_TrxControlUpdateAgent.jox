    <JadeMethod name="trxUpdateCargoCheckItem" id="787ce55e-fb89-4574-9fbf-3b9eaefb1dd9">
        <updating/>
        <source>trxUpdateCargoCheckItem(_pxyCargoCheckItem : CM_CargoCheckItem; _allCriteria : CMIF_Array input; _passport : CM_Passport input) updating;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 January 2010	cnwdap1	Initial creation
20/04/2023	navkc1	Bug 57628: CUX-Adding Criteria to Transaction Mapping allocation configuration results in error
*/
vars
	cmifObject		: CMIF_Object;
	transientObj	: CMIF_YACriteriaPriority;
	proxyObj		: CM_YACriteriaPriority;
	priorityValue	: Real;
	sortValue		: Real; //20/04/2023	navkc1	Bug 57628 Needs to be the same type as receive

begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);
	
	_pxyCargoCheckItem.raiseExceptionIfNotProxy(method);
	app.setContinueCMExceptions(true);
	
	// Now calculate the cargo check item priority values on the proxy objects, working
	// backwards from the least important
	foreach cmifObject in _allCriteria reversed do
		transientObj	:= cmifObject.CMIF_YACriteriaPriority;
		if transientObj.isDeleted then
			continue;
		endif;
		
		proxyObj		:= transientObj.myProxy;
		priorityValue	:= 2 ^ sortValue;
		proxyObj.setPriorityValue(priorityValue);
		sortValue		:= sortValue + 1;
	endforeach;

	beginTransaction;
	
	app.myUtilityUA.utlUpdateCargoCheckItem(_pxyCargoCheckItem, _allCriteria, _passport);
epilog
	self.finaliseActivityWithPassport(_passport);
end;</source>
        <Parameter name="_pxyCargoCheckItem" type="CM_CargoCheckItem"/>
        <Parameter name="_allCriteria" type="CMIF_Array" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxUpdateCargoForecast" id="719c7b45-20fa-44a7-b1e0-d560c83a9ec4">
        <updating/>
        <source>trxUpdateCargoForecast(_pxyCargoForecast: CM_CargoForecast; _passport : CM_Passport input) updating;
/*

Purpose:			Updates an existing Cargo Forecast from the Proxy object passed in

Parameters:			_pxyCargoForecast	CM_CargoForecast	The proxy object to update the real object from
					_passport			CM_Passport			Passport to use for our Trx that holds errors and other useful data

Return Value:		NONE

Date		Who		Reason
04 April 2022	navpw1	Initial creation TFS: 53132

*/

begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

