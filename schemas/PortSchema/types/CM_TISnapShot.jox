    <JadeMethod name="getHSDescription" id="faeda672-cd8d-4939-8d1a-11593865349b">
        <source>getHSDescription() : String;
/*****************************************************
Author		: jlika1 (Karen Alexander)
Date		: 13 December 2022
TFS#		: 55589
Function	:

*** Changes ***
Date			Name		TFS#		Description

****************************************************/

vars
	code 		: CM_HarmonizedSystem;
	returnVal 	: String;	
begin
	returnVal := app.getErrorString(HS_Unknown);
	
	code := self.myHSCode;
