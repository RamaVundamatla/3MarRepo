    </JadeMethod>
    <JadeMethod name="getDescription" id="049fc94b-67ea-4e23-8c10-7f6d4bc7696b">
        <source>getDescription(): String;
// -------------------------------------------
// Created 05 May 2005 by cnwdvb1
// -------------------------------------------
begin
	if self.value = self.VALUE_TRUE then
		return true.getYesNo();
	elseif self.value = self.VALUE_FALSE then
		return false.getYesNo();
	elseif self.value = self.VALUE_EITHER then
		return app.getErrorString(NotApplicable);	//23 Mar 2015	NDL	Par 35886
	else
		return app.getErrorString(CM_Invalid);
	endif;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getValueAsBoolean" id="82539b68-5814-4e95-be54-b1c5cd88941a">
        <source>getValueAsBoolean() : Boolean;
// CCMS 1043 Snapshot Summary Invoicing 	Oct 2010 	cnwjre1
vars
	result	: Boolean;
begin
	if self.value =  CM_YADataBoolean.VALUE_EITHER then
		result := true;
	elseif self.value = CM_YADataBoolean.VALUE_FALSE then
		result := false;
	elseif self.value = CM_YADataBoolean.VALUE_TRUE then
		result := true;
	endif;
	
	return result;
end;
</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
