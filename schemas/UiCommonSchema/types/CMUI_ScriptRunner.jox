        <updating/>
        <source>txtInspect_lostFocus(textbox: CMUI_TextBox input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
23 May 2024		navmd1	Initial creation

*/

vars

begin
	self.doInspectOid(textbox);
epilog

end;</source>
        <Parameter name="textbox" type="CMUI_TextBox" usage="input"/>
    </JadeMethod>
