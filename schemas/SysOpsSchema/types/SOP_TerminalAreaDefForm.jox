    <JadeMethod name="createAllCMIFGridLCsAssocIC" id="ae937c73-6043-4298-9f28-a8aac18e498c">
        <source>createAllCMIFGridLCsAssocIC() protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
24 February 2010	cnwer1	Initial creation

*/

vars
	interchangeArea : CM_InterchangeArea;
begin
	self.allCMIFGridLCsAssocICArea.purge;
	
	foreach interchangeArea in self.myProxyObject.CM_GridArea.allAssociatedInterchangeAreas do 
		self.createCMIFGridLCsAssocIC(interchangeArea);
	endforeach;
epilog
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="createCMIFGridLCsAssocIC" id="b9f96a62-130c-4a3d-aadf-5f228390952b">
        <source>createCMIFGridLCsAssocIC(_interchangeArea : CM_InterchangeArea ) protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
24 February 2010	cnwer1	Initial creation

*/

vars
	cmifGridLCsAssocICArea	: CMIF_GridLCsAssocICArea;
	iter	: Iterator;
	gridController,
	pxyGridController : CM_GridController;
begin	

	if not self.myCurrentObject.isKindOf(CM_GridArea) then
		return;
	endif;

	create cmifGridLCsAssocICArea transient;
	cmifGridLCsAssocICArea.setMyInterchangeArea(_interchangeArea);
	
	iter:=_interchangeArea.allAssociatedGridControllers.createIterator;
	_interchangeArea.allAssociatedGridControllers.startKeyGeq(self.myCurrentObject.CM_GridArea,null,null,iter);
	while iter.next(gridController) do
		if gridController.myTerminalArea &lt;&gt; self.myCurrentObject then
			break;
		endif;
		pxyGridController:=gridController.pxyGetProxyObject;
		cmifGridLCsAssocICArea.addGridController(pxyGridController);
	endwhile;
	self.allCMIFGridLCsAssocICArea.add(cmifGridLCsAssocICArea);
epilog
	delete iter;
end;</source>
        <access>protected</access>
        <Parameter name="_interchangeArea" type="CM_InterchangeArea"/>
    </JadeMethod>
    <JadeMethod name="createCMIFTerminalArea" id="069c9bb7-5404-4074-a261-39b7c802a50c">
        <updating/>
        <source>createCMIFTerminalArea(_type : CM_TerminalAreaType) updating, protected;
/*
----------   ----------  --------------------------------------------------
Created:	27 July 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars

begin
	delete self.myCMIFTerminalArea;
	
	create self.myCMIFTerminalArea as _type.getCMIFTAClassToCreate transient;
	self.myCMIFTerminalArea.myTerminal:=self.myTerminal;
	self.myCMIFTerminalArea.taType:=_type.type;
	self.myCMIFTerminalArea.myPxyTerminalAreaMaster:=self.myProxyObject.CM_TerminalAreaMaster;

end;</source>
        <access>protected</access>
        <Parameter name="_type" type="CM_TerminalAreaType"/>
    </JadeMethod>
    <JadeMethod name="createDeckingOptionsProxy" id="844818a6-ca7e-4bef-bf16-12b1aaf7b880">
        <updating/>
        <source>createDeckingOptionsProxy(_proxyTA: CM_TerminalArea) updating;
//----------------------------------------------------------------
//	Created:	02 June 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	theDO,
	pxyTADeckingOptions		: CM_YADeckingOptionsTA;
	inDeckingRule,
	outDeckingRule			: Integer;
	realObj					: CM_YADeckingOptionsTA;
begin
	if (not app.isValidObject(self.myPxyDeckingOptions)) then
		self.myPxyDeckingOptions := null;
	endif;
	
	delete self.myPxyDeckingOptions;
	pxyTADeckingOptions := self.myProxyObject.CM_TerminalArea.myYADeckingOptions;
	if pxyTADeckingOptions = null then
		if self.myCurrentObject = null then	
			create pxyTADeckingOptions transient;
		else
			theDO := self.myCurrentObject.CM_TerminalArea.myYADeckingOptions;
			if theDO &lt;&gt; null then
				pxyTADeckingOptions := app.createUpdateProxy(theDO).CM_YADeckingOptionsTA;
			else
				create pxyTADeckingOptions transient;
			endif;
		endif;
	endif;
	
	pxyTADeckingOptions.setProxy(false, true, _proxyTA);	
		
	self.origDeckingIn			:= pxyTADeckingOptions.inOptionType;
	self.origDeckingOut			:= pxyTADeckingOptions.outOptionType;
	self.origDeckDefDirection	:= _proxyTA.getGridRowColDeckingDirection();
	
	inDeckingRule	:= self.cmbDeckingOptIn.getCurrentItemData();
	outDeckingRule	:= self.cmbDeckingOptOut.getCurrentItemData();
	
	//cnwjo3 par 24157.  If its New then use Default Decking Rules.
	realObj := pxyTADeckingOptions.pxyGetRealObject;
	if realObj = null then
		//its new.  make sure defaults are used!
		inDeckingRule := DeckingRule_Default;
		outDeckingRule := DeckingRule_Default;
		pxyTADeckingOptions.setProxyRules(inDeckingRule, outDeckingRule);
	endif;	
	
	//cnwjo3 par 24157 code removed.  now we only setProxyRules on new TerminalAreas
	//pxyTADeckingOptions.setProxyRules(inDeckingRule, outDeckingRule);

	self.myPxyDeckingOptions := pxyTADeckingOptions;

end;</source>
        <Parameter name="_proxyTA" type="CM_TerminalArea"/>
    </JadeMethod>
    <JadeMethod name="createMyProxyObjForNew" id="b649e0f3-2eb7-49d0-842b-ef1e6262d8ac">
        <updating/>
        <source>createMyProxyObjForNew(_taType : CM_TerminalAreaType) updating, protected;
/*
----------   ----------  --------------------------------------------------
Created:	27 July 2006 By cnwth2

Purpose:	Necessary when this form is not showing tblData - we still need a place holder
			when adding a new terminal area.

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars

begin
	delete self.myProxyObject;
	create self.myProxyObject as _taType.getTAClassToCreate transient;

end;</source>
        <access>protected</access>
        <Parameter name="_taType" type="CM_TerminalAreaType"/>
    </JadeMethod>
    <JadeMethod name="createPlaceHolder" id="75fe4173-c884-45f2-bfda-5efef3eedd55">
        <updating/>
        <source>createPlaceHolder() updating;
// ---------------------------------------------------------------------------
// Created:     29 January 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	// because the data class is set to CM_TerminalArea here which is abstract
	// we just create a dummy straddle stack instead.
	create self.myPlaceHolderObject as CM_StraddleStack transient;
	self.frmMain.enabled := true;

end;</source>
