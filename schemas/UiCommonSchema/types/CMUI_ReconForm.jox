    <JadeMethod name="tblWorkEntryChange" id="63265486-e5c4-40d0-b7ee-f0870a8f12f1">
        <updating/>
        <source>tblWorkEntryChange(_tbl : CM_DataTable io) updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
10 August 2009	cnwml2	Initial creation

*/

vars

	obj : CM_Object;
	macroTbl : CM_DataTable;
begin
	
	//self.myCurrentWLE := null;		
	if _tbl.row &gt; 1 then
		obj := _tbl.accessRow(_tbl.row).itemObject.CM_Object;
	endif;
	//if self.myCurrentWLE = obj then
	//	return;
	//endif;
	
	if not global.isValidObject(obj) then
		return;
	endif;
	
	if obj.isKindOf(CM_BookingRefItem) then
		//self.myCurrentWLE := obj.CM_WorkListEntry;
		macroTbl := self.tblExpectedMacro;
		self.doTblExtraInfo(obj, macroTbl);
		//macroTbl.width := sptLeft.width - sptLeft.getMyRightControl.width + 10;
		macroTbl.width := self.sptLeft.getMyLeftControl.width;
	elseif obj.isKindOf(CM_TrackedItem) then
		if _tbl = self.tblActual then
			macroTbl := self.tblActualMacro;
			macroTbl.width := sptRight.width - sptRight.getMyRightControl.width + 10;
		elseif _tbl = self.tblUnreconciled then
			macroTbl := self.tblUnreconMacro;
			macroTbl.width := sptRight.getMyRightControl.width + 15;
		endif;
		self.doTblExtraInfo(obj, macroTbl);
	endif;
	
	self.setTblDataDetailCellText(_tbl);
end;</source>
        <access>protected</access>
        <Parameter name="_tbl" type="CM_DataTable" usage="io"/>
    </JadeMethod>
    <JadeMethod name="translateForm" id="347d98cd-1462-4274-9b00-975ed25af4f2">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0017452, locale);
	btnCancelComplet.translateCaption(Xlat_0012145, locale);
	btnCompleteRecon.translateCaption(Xlat_0012146, locale);
	btnEditActual.translateCaption(Xlat_0012147, locale);
	btnEditRecon.translateCaption(Xlat_0012148, locale);
	btnEditUnrecon.translateCaption(Xlat_0012149, locale);
	btnSaveClose.translateCaption(Xlat_0012150, locale);
	btnSaveComplete.translateCaption(Xlat_0012151, locale);
	chkReconciled.translateCaption(Xlat_0012152, locale);
	chkShowAllCargo.translateCaption(Xlat_0012153, locale);
	lblActual.translateCaption(Xlat_0012154, locale);
	lblExpected.translateCaption(Xlat_0012155, locale);
	lblReasonComplet.translateCaption(Xlat_0012156, locale);
	lblUnreconciled.translateCaption(Xlat_0018026, locale);
	mnuMacro.translateCaption(Xlat_0013478, locale);
	mnuMveSelReconItem.translateCaption(Xlat_0012158, locale);
	mnuMveUnrecCargo.translateCaption(Xlat_0012159, locale);
end;</source>
    </JadeMethod>
</GUIClass>
