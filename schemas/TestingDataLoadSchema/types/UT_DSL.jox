    <JadeMethod name="addVoyageWithContainerStructurOpsview" id="574810ce-590a-44d0-a810-551a7be714fa">
        <source>addVoyageWithContainerStructurOpsview(	_code : String; _vesselCode : String; _operatorName : String; _shippingLine : String ) : CM_Voyage;
/****Changes

Date		Name	TFS#			Description
============================================================================	
16/12/2008	cnwdw1	
05/03/2015 	cnwdap1	PAR #35826 
					CCMS SFW 1410 	Added expected arrival/departure date/time
11/04/2017	cnwdap1	TFS 4050 		LNX Job ID Enhancements
05/12/2018	jlgka1	TFS 37102		STWR - Add isBarges Flag.
// 10 Sep 2019	cnwrs1	TFS 46030
============================================================================*/
vars
	useHMSData				 : Boolean;
	vessel					 : CM_Vessel;
	pxyVoyage				 : CM_Voyage;
	voyage					 : CM_Voyage;
	inwardCode				 : String;
	cusresAltVoyageStr		 : String;							// cnwrl1 28/04/2010 PAR 23854
	cusresAltVoyage			 : CM_Voyage;						// cnwrl1 28/04/2010 PAR 23854
	pxyCellStructure		 : CM_CellularVoyageStructure;
	now						 : TimeStamp;
	arrivalDate				 : TimeStamp;
	departureDate 			 : TimeStamp;
	pxyGlobalVoyage			 : CM_VoyageGlobal;
	pxyHMSData				 : HMS_VoyageData;
	trade					 : CM_Trade;
	pxyVoyagePortRotation	 : CM_PortRotation;
	portRotation			 : CM_PortRotation;
	berth					 : HMS_Berth;
	term					 : CM_Terminal;
	useAllocations			 : Boolean;
	pxyPortRotationsToDelete : CM_PortRotationArray;				// 24/02/2014 cnwmh5 - transient leaks
	obj						 : Object;
	bank 					 : CM_Bank;
begin
	term := self.getTerminal();
	if self.opts.includesKey("dischargeCompany") then
		bank := self.opts.obj("dischargeCompany").CM_Bank;
	endif;
	//opts := self.getOpts(_opts);
	
//	vessel := getRoot.allVessels[_vesselCode];		// cnwrl1 14/05/2010 PAR 24216 - what it was
	vessel := self.getVessel( _vesselCode );
	self.assertNotNullMsg(vessel, "Vessel");                // 04/10/2013 cnwmh5
	 
	create pxyPortRotationsToDelete transient;
	
	if self.opts.includesKey("Trade") then
		trade := app.myRoot.allTradesByDescription[self.opts.str("Trade")];
	else
		trade := getTrade;
	endif;
	
	create pxyVoyage transient;							
	
	create pxyCellStructure transient;
	pxyVoyage.setProxyVoyageCellullStructure(pxyCellStructure);
	pxyCellStructure.setProxyCellularVoyage(vessel.myCellularVesselStructure.bridgeAfterBay, 
											vessel.myCellularVesselStructure.isoHalfHeights,
											vessel.myCellularVesselStructure.use40Id, 
											vessel.myCellularVesselStructure.useBayCellTierNumbering);
	
	create pxyGlobalVoyage transient;
	pxyGlobalVoyage.setProxy(_code, _vesselCode, null, null, null, null, null, 0, null, app.myRoot);
	pxyVoyage.setMyVoyageGlobalArrival(pxyGlobalVoyage);
	
	arrivalDate.setDate(now.date());
	arrivalDate.setTime(now.time());
	departureDate := arrivalDate.addDays(2);

	if self.opts.includesKey("tsArrival") then // whole time stamp
		arrivalDate := self.opts.timestamp("tsArrival");
	elseif self.opts.includesKey("dateArrival") then // just a date
		arrivalDate.setDate(self.opts.date("dateArrival"));
	endif;
	
	if self.opts.includesKey("tsDeparture") then // whole time stamp
		departureDate := self.opts.timestamp("tsDeparture");
	elseif self.opts.includesKey("dateDeparture") then // just a date
		departureDate.setDate(self.opts.date("dateDeparture"));
	endif;
	inwardCode := self.opts.str('inwardCode');
	
	// cnwrl1 28/04/2010 PAR 23854 - start of coding
	cusresAltVoyageStr	:= self.opts.str( 'myCusresAltVoyage' );
	if cusresAltVoyageStr &lt;&gt; null then
		cusresAltVoyage	:=  self.getVoyage( cusresAltVoyageStr );
	endif;
	// cnwrl1 28/04/2010 PAR 23854 - end of coding
	

	useAllocations	:= self.opts.bool( 'UseAllocations' );

	pxyVoyage.setProxyVoyage(	null,
								self.opts.str( ETRow_CallSign ),
								_code.toUpper(),								// 23/01/2014 cnwmh5
								inwardCode,
								self.createdByUnitTest(null),					// 18/08/2015 cnwmh5
								vessel.code,
								vessel.name,
								self.opts.str( ETRow_LloydsNumber ),
								false,
/* PAR 33644								false,
								false, */
								false,
								false,
								0,
								VoyageDisplayAlways,
								0,
								pxyVoyage.status,
								vessel.vesselType,
								null,
								arrivalDate,
								departureDate,
								pxyVoyage.loadStartDT,
								pxyVoyage.loadEndDT,
								null,
								null,
								null, 
								bank,// BANK
								getRoot.allOperators[_operatorName],
								trade,
								getRoot.allShippingLines[_shippingLine],
								self.getTerminal,
								pxyVoyage.myVoyageGlobalArrival,
								null,
								null,
								null,
								null,
//								null,							// cnwrl1 28/04/2010 PAR 23854 - what it was
								cusresAltVoyage,
								0,
								false,									// 27/05/2009 cnwar2 CCMS1040
								pxyVoyage.allOperators,
								pxyVoyage.allReceivalCutoffs,		// 27/05/2009 cnwar2 CCMS1040
								true, //use voyage allocations
								null,
								null,
								null,
								null,
								null,
								null,
								null,
								null,null,null,
								arrivalDate,departureDate,
								null,	//_generalLandingDate : Date	//14 Mar 2016	TFS 1407
								null,			// TFS 4050
								pxyVoyage.paymentType,
								pxyVoyage.isBarge, 	//jlgka1 TFS 37102
								pxyVoyage.voyageGroupCode,
								false	// 31.Aug.2023 navsp1 TFS 57809
								);					// PAR #35826
	
	
	self.createExchangeDates(pxyVoyage); // AKB 2010 AUG
	
	if self.opts.includesKey("useHMSData") then
		useHMSData := self.opts.bool("useHMSData");
	endif;
//	9/9/19 MAP always create HMS object
//	if useHMSData then
		berth := self.opts.obj("berth").HMS_Berth;
		create pxyHMSData transient;
		pxyHMSData.setPxyFromVessel(vessel, term);
		pxyHMSData.setMyBerth(berth);
		pxyHMSData.setTidalClasses(app.myRoot.allTidalClasses['A'], app.myRoot.allTidalClasses['B']);	//10 Sep 2019	cnwrs1	TFS 46030
		pxyVoyage.setHMSVoyageData(pxyHMSData);
		pxyHMSData.setProxyDefaultVoyageMovements(berth, null, app.myPassport);
//	endif;
	
	// Set the Port Rotations from the Trade
	foreach portRotation in trade.allPortRotations do
		create pxyVoyagePortRotation transient;
		portRotation.allTranshipPorts.copy(pxyVoyagePortRotation.allTranshipPorts);
		pxyVoyagePortRotation.setProxy(portRotation.myPort, pxyVoyage);
		pxyPortRotationsToDelete.add(pxyVoyagePortRotation);
	endforeach;
	
	pxyVoyage.setProxyForVoyageType(vessel.structureIncludesLOLO,vessel.structureIncludesRORO,vessel.structureIncludesHolds,vessel);
	if not self.opts.includesKey("CopyVoyageVAConfig") then					// 29/01/2014 cnwmh5
		self.opts.addAssoc("UseVesselAllocations", true);
		self.opts.addAssoc("Vessel", vessel);
		self.setProxyVoyageVAConfig(pxyVoyage); // AKB ADDED 18/8/11 RORO KPI
	endif;
	
	
	//cnwmc5 - 3/12/2012 - add all the trade operators to the voyage
	trade.operators.copyNoDuplicates(pxyVoyage.allOperators, false);

	self.ignoreTrxWarnings(true);
	//app.myPassport.setWarningsIgnored(true);
	app.myTrxCA.trxCreateVoyage(pxyVoyage, voyage, vessel, null, true, app.myPassport);
	
	self.assertNoTrxErrorsOrWarnings();

	return voyage;
epilog

	delete pxyCellStructure;											// 24/02/2014 ccnwmh5 - Transient Leaks
	
	foreach pxyVoyagePortRotation in pxyPortRotationsToDelete do		// 24/02/2014 ccnwmh5 - Transient Leaks
		delete pxyVoyagePortRotation;
	endforeach;
	delete pxyPortRotationsToDelete;
	
	delete pxyVoyage;													// 24/02/2014 ccnwmh5 - Transient Leaks

	if global.isValidObject(pxyGlobalVoyage) then
		delete pxyGlobalVoyage; //cnwrs1 par23228 10 Mar 2010 now done in CM_Voayge setForCreate
	endif;
end;
</source>
        <Parameter name="_code" type="String"/>
