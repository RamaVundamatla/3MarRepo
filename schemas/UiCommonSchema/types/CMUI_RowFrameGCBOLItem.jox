    <JadeMethod name="setTabOrder" id="7d382c65-bdee-4fb5-b369-d6f95aa03d43">
        <source>setTabOrder(_startNum : Integer; noOfEntries : Integer; bOn : Boolean);
// ---------------------------------------------------------------------------
// Created:     11 April 2006 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	index : Integer;
begin

	self.myLblNumberedEntry.caption := _startNum.String &amp; "/" &amp; noOfEntries.String;

	index := _startNum * 100;
	self.myTxtID.tabIndex := index;
	self.myTxtID.tabStop := bOn;
	index := index + 5;

	self.myTxtMarks.tabIndex := index;
	self.myTxtMarks.tabStop := bOn;
	index := index + 5;

	self.myTxtMarksNo.tabIndex := index;
	self.myTxtMarksNo.tabStop := bOn;
	index := index + 5;

	self.myTxtPurchaseOrder.tabIndex := index;
	self.myTxtPurchaseOrder.tabStop := bOn;
	index := index + 5;

	self.myCmbCargoType.tabIndex := index;
	self.myCmbCargoType.tabStop := bOn;
	index := index + 5;

	self.myCmbProduct.tabIndex := index;
	self.myCmbProduct.tabStop := bOn;
	index := index + 5;

	self.myTxtDescription.tabIndex := index;
	self.myTxtDescription.tabStop := bOn;
	index := index + 5;
	
	self.myTblProductDtls.tabIndex := index;
	self.myTblProductDtls.tabStop := bOn;
	index := index + 5;
	
	//self.myTxtWeight.tabIndex := index;
	//self.myTxtWeight.tabStop := bOn;
	//index := index + 5;
	
	//Replaced with table control and using product details to fill from and enttabledef
	//self.myTxtVolume.tabIndex := index;
	//self.myTxtVolume.tabStop := bOn;
	//index := index + 5;
	
	self.myCmbHatch.tabIndex := index;
	self.myCmbHatch.tabStop := bOn;
	index := index + 5;
	
	self.myTxtRemarks.tabIndex := index;
	self.myTxtRemarks.tabStop := bOn;
	index := index + 5;
	
end;</source>
        <Parameter name="_startNum" type="Integer"/>
        <Parameter name="noOfEntries" type="Integer"/>
        <Parameter name="bOn" type="Boolean"/>
    </JadeMethod>
