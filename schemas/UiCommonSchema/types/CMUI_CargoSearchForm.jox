    <JadeMethod name="translateForm" id="a43cbfb3-d064-4298-bf45-294038365f85">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 22 June 2023 12:59:25.
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0017262, locale);
	btnAdd.translateCaption(Xlat_0011839, locale);
	btnClear.translateCaption(Xlat_0011840, locale);
	btnRemove.translateCaption(Xlat_0011841, locale);
	btnSearchAll.translateCaption(Xlat_0011842, locale);
	btnSearchResults.translateCaption(Xlat_0011843, locale);
	chkEmptiesOnly.translateCaption(Xlat_0011844, locale);
	chkParentOnly.translateCaption(Xlat_0025216, locale);
	chkShowAllOperator.translateCaption(Xlat_0026136, locale);
	cmbBOL.translateCaption(Xlat_0011845, locale);
	cmbBookings.translateCaption(Xlat_0024923, locale);
	cmbCommodity.translateCaption(Xlat_0025338, locale);
	cmbConsignee.translateCaption(Xlat_0011846, locale);
	cmbFreightFwdr.translateCaption(Xlat_0011847, locale);
	cmbISOGroup.translateCaption(Xlat_0011848, locale);
	cmbISOType.translateCaption(Xlat_0011849, locale);
	cmbImexStatus.translateCaption(Xlat_0014272, locale);
	cmbMTGrade.translateCaption(Xlat_0014273, locale);
	cmbOperator.translateCaption(Xlat_0011850, locale);
	cmbReleases.translateCaption(Xlat_0024924, locale);
	cmbSite.translateCaption(Xlat_0011851, locale);
	cmbSubCargo.translateCaption(Xlat_0011852, locale);
	cmbType.translateCaption(Xlat_0011853, locale);
	cmbVoyage.translateCaption(Xlat_0011854, locale);
	lblResults.translateCaption(Xlat_0011855, locale);
	lblSelectedItems.translateCaption(Xlat_0011856, locale);
	lstColour.translateCaption(Xlat_0019186, locale);
	mnuColumnOrganiser.translateCaption(Xlat_0014274, locale);
	mnuEnquire.translateCaption(Xlat_0014541, locale);
	mnuMainContext.translateCaption(Xlat_0014275, locale);
	txtCargoGroupID.translateCaption(Xlat_0025340, locale);
	txtCargoID.translateCaption(Xlat_0011857, locale);
	txtLocation.translateCaption(Xlat_0014276, locale);
	txtMark.translateCaption(Xlat_0011858, locale);
	txtTextSearch.translateCaption(Xlat_0011859, locale);
	txtUnpackedFrom.translateCaption(Xlat_0019392, locale);
end;</source>
