    <JadeMethod name="doMnuRecClick" id="80e5ff3a-a58e-407a-810d-13b99c9b788e">
        <updating/>
        <source>doMnuRecClick(_sealCheck : Integer) : Boolean updating;
//07 September 2010	cnwml2
//+cnwml2 PAR23715 SFW CCMS1131
// 08/04/2011	cnwmh5		PAR #27347 - Add cmsEndLoad or endLoad to epilog so that if error occurs it will not leave it in beginLoad state
vars
	train : CM_Train;
	pxyTrain : CM_Train;
	wle : CM_YardWLE;
	result : Integer;
begin
	if self.myCurrentWLE &lt;&gt; null and self.myCurrentWLE.isKindOf(CM_YardWLE) then
		wle := self.myCurrentWLE.CM_YardWLE;
		if wle.job &lt;&gt; null and wle.job.isKindOf(CM_RailJob) then
			train := self.myCurrentWLE.CM_YardWLE.job.CM_RailJob.getMyTrain();
		endif;
	endif;
	
	if train &lt;&gt; null then
		beginLoad;
			pxyTrain := train.pxyCreateUpdateProxy();
		endLoad;
		
		pxyTrain.setSealCheckReceival(_sealCheck);
		
		while true do 
			app.myTrxUA.trxUpdateTrain(pxyTrain, false, app.myPassport);
			if app.myPassport.trxCompletedOK then
				// Clear errors/warnings from form and err/warnings window
				self.clearErrorWarnings();
				return true;
			else
				result := app.showErrorWarningDialog(self.caption, app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
				if app.myPassport.noErrors and
				   result = IDOK then
					// there must have just been warnings that the user has acknoledged so ..
					app.myPassport.warningsAcknowledged	:= true;
					continue;
				endif;
				
				self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
			endif;
		return false;
		endwhile;
	endif;
epilog
	endLoad;				// 08/04/2011 cnwmh5 #27347
	delete pxyTrain;
end;</source>
        <Parameter name="_sealCheck" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doMnuRelClick" id="3b1a8883-5ccf-4875-937f-907ce2cacefa">
        <updating/>
        <source>doMnuRelClick(_sealCheck : Integer) : Boolean updating;
//07 September 2010	cnwml2
//+cnwml2 PAR23715 SFW CCMS1131
// 08/04/2011	cnwmh5		PAR #27347 - Add cmsEndLoad or endLoad to epilog so that if error occurs it will not leave it in beginLoad state

vars
	train : CM_Train;
	pxyTrain : CM_Train;
	wle : CM_YardWLE;
	result : Integer;
begin
	if self.myCurrentWLE &lt;&gt; null and self.myCurrentWLE.isKindOf(CM_YardWLE) then
		wle := self.myCurrentWLE.CM_YardWLE;
		if wle.job &lt;&gt; null and wle.job.isKindOf(CM_RailJob) then
			train := self.myCurrentWLE.CM_YardWLE.job.CM_RailJob.getMyTrain();
		endif;
	endif;

	if train &lt;&gt; null then
		beginLoad;
			pxyTrain := train.pxyCreateUpdateProxy();
		endLoad;
		
		pxyTrain.setSealCheckRelease(_sealCheck);
		
		while true do
			app.myTrxUA.trxUpdateTrain(pxyTrain, false, app.myPassport);
			if app.myPassport.trxCompletedOK then
				// Clear errors/warnings from form and err/warnings window
				self.clearErrorWarnings();
				return true;
			else
				result := app.showErrorWarningDialog(self.caption, app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
				if app.myPassport.noErrors and
				   result = IDOK then
					// there must have just been warnings that the user has acknoledged so ..
					app.myPassport.warningsAcknowledged	:= true;
					continue;
				endif;
				
				self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
			endif;
		return false;
		endwhile;
	endif;
epilog
	endLoad;				// 08/04/2011 cnwmh5 #27347
	delete pxyTrain;
end;</source>
        <Parameter name="_sealCheck" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
