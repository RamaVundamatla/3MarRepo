    <JadeMethod name="translateToDisplayValue" id="64c375fd-d2f2-4425-9580-56c3b032e2c6">
        <source>translateToDisplayValue(_value: Any): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 April 2020	jlgndl1	Initial creation	TFS 47958

*/

vars

begin
	
	if _value.Decimal &lt;&gt; NULL_OXYGEN then
		return _value.String;
	endif;
	
	return null;

epilog

end;</source>
