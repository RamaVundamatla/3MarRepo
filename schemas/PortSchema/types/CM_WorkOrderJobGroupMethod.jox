    <JadeMethod name="doGroupCompare" id="302bbfe9-606b-41a1-9636-162fdd4ce4a1">
        <source>doGroupCompare(_currentTi : CM_TrackedItem;
			   _lastTi    : CM_TrackedItem;
			   _grpIdx    : Integer io);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 Sep 2023	navma1  ChangeRequest 59638: EUP | Ship Operations in DD - [54176.010] - [Receive] Work Order Detail Grouping
27 Sep 2023	navhl20 ChangeRequest 59638: EUP | Ship Operations in DD - [54176.010] - [Receive] Work Order Detail Grouping
03 May 2024 navhl20 ChangeRequest 63971: FR | 54176 - Ship operations in Delivery Dispatch screen
*/

vars
	lastTiLocation,
	currentTiLocation	: String;
	lcActual,
	lcPlanned,
	lcPlannedCurrent	: CM_LocationsController;
begin
	
	if _lastTi = null then
		return;
	endif;
	
	lcActual := _currentTi.myPrimaryActualLocation;						//03.05.2024 navhl20 #63971
	if lcActual &lt;&gt; null and 											//03.05.2024 navhl20 #63971
	lcActual.isKindOf(CM_ShipBlockController) or 
	lcActual.isKindOf(CM_GeneralCargoController) then
		lastTiLocation 		:= _lastTi.locationId;
		currentTiLocation 	:= _currentTi.locationId;
	else
		lcPlanned := _lastTi.myPrimaryPlannedLocation;
		if lcPlanned &lt;&gt; null and 
		lcPlanned.isKindOf(CM_ShipBlockController) or 
		lcPlanned.isKindOf(CM_GeneralCargoController) then
			lastTiLocation 	:= lcPlanned.getFullId();
		endif;
		lcPlannedCurrent := _currentTi.myPrimaryPlannedLocation;
		if lcPlannedCurrent &lt;&gt; null and 
		lcPlannedCurrent.isKindOf(CM_ShipBlockController) or 
		lcPlannedCurrent.isKindOf(CM_GeneralCargoController) then
			currentTiLocation 	:= lcPlannedCurrent.getFullId();
		endif;
	endif;
	
	if (self.allGroupingCriteria.includes(WOJG_CargoTypeInt)	   and _currentTi.cargoType   	 &lt;&gt; _lastTi.cargoType)   
	  or (self.allGroupingCriteria.includes(WOJG_CargoSubTypeInt)  and _currentTi.myProduct   	 &lt;&gt; _lastTi.myProduct) 
	  or (self.allGroupingCriteria.includes(WOJG_CommodityInt)     and _currentTi.commodity   	 &lt;&gt; _lastTi.commodity)
	  or (self.allGroupingCriteria.includes(WOJG_SpecialStowInt)   and _currentTi.specialStow 	 &lt;&gt; _lastTi.specialStow)
	  or (self.allGroupingCriteria.includes(WOJG_HoldNumberInt)    and currentTiLocation  	 	 &lt;&gt; lastTiLocation) 				//03.05.2024 navhl20 #63971
	  or (self.allGroupingCriteria.includes(WOJG_DischargePortInt) and _currentTi.dischargePort  &lt;&gt; _lastTi.dischargePort) 
	  then
		_grpIdx := _grpIdx +1 ;
	endif;
	  
epilog

end;</source>
        <Parameter name="_currentTi" type="CM_TrackedItem"/>
        <Parameter name="_lastTi" type="CM_TrackedItem"/>
        <Parameter name="_grpIdx" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="getAuditText" id="d7af5e8c-64c4-44c6-afc3-ec48f4820682">
        <source>getAuditText(): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 Sep 2023 navhl20 ChangeRequest 60063: EUP | Ship Operations in DD - Terminal Config for grouping attributes

*/

vars
	txt,
	tmpStr	: String;
	int 	: Integer;
begin
	txt[10000] 	:= '*';
	txt 		:= null;
	txt 		:= inheritMethod();

	tmpStr := null;
	if self.allWorkOrderDetailTypes.isNotEmpty() then
		tmpStr := self.allWorkOrderDetailTypes.listString(Comma,CM_WorkOrderDetailType::description.name);
		txt := txt &amp; 'Work Order Types' &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp; tmpStr &amp; AuditStringSeparator;
	endif;
	
	tmpStr := null;
	if self.allGroupingCriteria.isNotEmpty() then
		foreach int in self.allGroupingCriteria do
			if tmpStr = null then
				tmpStr := tmpStr &amp; app.groupCritEnumtoStr(int);
			else
				tmpStr := tmpStr &amp; Comma &amp; Space &amp; app.groupCritEnumtoStr(int);
			endif;
		endforeach;
		txt := txt &amp; 'Grouping Criteria' &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp; tmpStr &amp; AuditStringSeparator;
	endif;
	
	tmpStr := null;
	if self.allVessels.isNotEmpty() then
		tmpStr := self.allVessels.listString(Comma,CM_Vessel::code.name);
		txt := txt &amp; 'Vessels' &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp; tmpStr &amp; AuditStringSeparator;
	endif;
	
	return txt;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="dda1b04e-5b83-44c0-9fff-5a5b9b91fa9d">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 Sep 2023 navhl20 ChangeRequest 60063: EUP | Ship Operations in DD - Terminal Config for grouping attributes

*/

vars

begin
	if _attrName = ETRow_WorkOrderType then
		return self.getWOdtlType();
	elseif _attrName = ETRow_IsNotAvailForEntry then
		return self.isNotAvailableForEntry.String;
	elseif _attrName = ETRow_Vessel then
		return self.getVessels().formatWithEllipsis(1,100,true);
	elseif _attrName = ETRow_GrpCriteria then
		return self.getGroupingCrit();
	endif;
	
	return inheritMethod(_attrName, _short);
epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getGroupingCrit" id="182b86f8-da0f-4d9f-a8f3-c7d17a2b9218">
        <source>getGroupingCrit():String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 Sep 2023 navhl20 ChangeRequest 60063: EUP | Ship Operations in DD - Terminal Config for grouping attributes

*/

vars
	int	: Integer;
	str	: String;
begin
	foreach int in self.allGroupingCriteria do
		if str = null then
			str := str &amp; app.groupCritEnumtoStr(int);
		else
			str := str &amp; Comma &amp; app.groupCritEnumtoStr(int);
		endif;
	endforeach;
	return str;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getJobIdCrit" id="a603b97e-8313-4901-a2bd-6228ff0d27ca">
        <source>getJobIdCrit(_ti : CM_TrackedItem):String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 Oct 2023 navhl20 ChangeRequest 60090: EUP | Ship Operations in DD - [54176.020] -[Receive] Allocate Jobs to Gangs and Gangs to Holds

*/

vars
	int 	: Integer;
	crit	: String;
begin
	foreach int in self.allGroupingCriteria do
		if int = WOJG_CargoSubTypeInt then
			crit := _ti.getProductDescription();
			break;
		elseif int = WOJG_CommodityInt then
			crit := _ti.getCommodityDesc();
			break;
		endif;
	endforeach;
	return crit;
epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getPropertyNameForGrpCriteria" id="b0b93878-467e-4c58-aea5-f8d8c1c89a4d">
        <source>getPropertyNameForGrpCriteria(_grpCriteria : Integer; _wod : CM_WorkOrderDtl):String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 Sep 2023	navma1 ChangeRequest 59638: EUP | Ship Operations in DD - [54176.010] - [Receive] Work Order Detail Grouping
06 May 2024 navhl20 ChangeRequest 63971: FR | 54176 - Ship operations in Delivery Dispatch screen
*/

vars

begin
	if _grpCriteria = WOJG_CargoTypeInt then
		return CM_TrackedItem::myCargoType.name;
	
	elseif _grpCriteria = WOJG_CargoSubTypeInt then
		return CM_TrackedItem::myProduct.name;
	
	elseif _grpCriteria = WOJG_CommodityInt then
		return CM_TrackedItem::commodity.name;
	
	elseif _grpCriteria = WOJG_DischargePortInt then
		return CM_TrackedItem::dischargePort.name;
	
	elseif _grpCriteria = WOJG_HoldNumberInt then
		if _wod.isKindOf(CM_WodReceive) or _wod = null then							//06.05.2024 navhl20 #63971
			return CM_TrackedItem::myPrimaryActualLocation.name;
		else
			return CM_TrackedItem::myPrimaryPlannedLocation.name;
		endif;
	
	elseif _grpCriteria = WOJG_SpecialStowInt then
		return CM_TrackedItem::specialStow.name;
	endif;
epilog

end;</source>
        <Parameter name="_grpCriteria" type="Integer"/>
        <Parameter name="_wod" type="CM_WorkOrderDtl"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getVessels" id="3e13b6bc-19e8-4134-970d-f70c1b0a531b">
        <source>getVessels():String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 Sep 2023 navhl20 ChangeRequest 60063: EUP | Ship Operations in DD - Terminal Config for grouping attributes

*/

vars
	vessel 	: CM_Vessel;
	str		: String;
begin
	foreach vessel in self.allVessels do
		if str = null then
			str := str &amp; vessel.code &amp; Hyphen &amp; vessel.name;
		else
			str := str &amp; Comma &amp; vessel.code &amp; Hyphen &amp; vessel.name;
		endif;
	endforeach;
	return str;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getWOdtlType" id="920445bb-69e0-4325-b296-b07ce4832089">
        <source>getWOdtlType():String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 Sep 2023 navhl20 ChangeRequest 60063: EUP | Ship Operations in DD - Terminal Config for grouping attributes

*/

vars
	detailType 	: CM_WorkOrderDetailType;
	str			: String;
begin
	foreach detailType in self.allWorkOrderDetailTypes do
		if str = null then
			str := str &amp; detailType.description &amp; " - Ship";
		else
			str := str &amp; Comma &amp; Space &amp; detailType.description &amp; " - Ship";
		endif;
	endforeach;
	return str;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
