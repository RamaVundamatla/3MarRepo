    <JadeMethod name="utlDeleteFPDateTimeBulk" id="dcfa8ba0-f9c4-4750-99e0-0ab631419449">
        <source>utlDeleteFPDateTimeBulk(_financialPeriodEnd:CM_FinancialPeriodEnd input; _allProxyDates : CM_FinancialPeriodDateTimeDict);
/*
Purpose:			
Date				Who			Reason
FEBRUARY 2015		CNWAB1		Initial creation
*/
vars
	dt : CM_FinancialPeriodDateTime;
begin

	self.initialiseActivity();
	
	foreach dt in _allProxyDates discreteLock do
		self.myDeleteAuditAgent.audDeleteGeneric(dt);
	
		if app.myPassport.noErrors then
			if app.myPassport.noErrors then
				app.myRoot.causeEvent(EVENT_FINPERIOD_DELETE,false,dt);
				dt.erase(NORMAL_ERASE);
			endif;
		endif;
 
 
	endforeach;


epilog
	return;

end;</source>
        <Parameter name="_financialPeriodEnd" type="CM_FinancialPeriodEnd" usage="input"/>
        <Parameter name="_allProxyDates" type="CM_FinancialPeriodDateTimeDict"/>
    </JadeMethod>
