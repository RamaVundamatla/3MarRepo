    <JadeMethod name="wsRESTPutReleaseRequest" id="4dd0b699-6c53-4ad9-8b8b-1ec76f1fa00f">
        <source>wsRESTPutReleaseRequest(_json: String; _urlParams: String; _expectErrors: Boolean; _expectedErrorList : IntegerArray): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 Apr 2023	navak20	Task 57525: CUX - MTN-EDBIC - 100 - Process Release Request - PUT Unit Test
24 Oct 2024	navmd1	TFS 63327 ReleaseRequest Rewrite
01 Aug 2024 navsp1  TFS ChangeRequest 65383: MTN - /ReleaseRequest API further refinements
*/

vars
	request				: WS_RestReleaseRequestArray;
	requestLogin		: WS_RESTLoginAuthRequest;
	webService			: MasterTerminalAPIService;
	parser				: JadeJson;
	transientJSONObjs	: ObjectArray;
	response 			: WS_Response;
	ref 				: String;
	releaseRequestId	: String;
	epochTime			: Integer64;
	pos					: Integer;
	errorNum			: Integer;
	errorMessage		: WS_ErrorMessage;
	resMessage			: String;
	counter				: Integer;
begin
	create webService transient;
	create transientJSONObjs transient;
	create parser transient;
	
	self.loginREST(webService);	
	
	// set up the WS_Request object
	webService.setPropertyValue(WS_RestWebServiceProvider::requestPath.name, "/releaseRequest");
	request := parser.parse(_json, WS_RestReleaseRequestArray, transientJSONObjs).WS_RestReleaseRequestArray;
	
	if request.size &lt; 2 then										//TFS 65383
		if _urlParams &lt;&gt; null then
			pos := 1;
			releaseRequestId := _urlParams.scanUntil("/", pos);
			pos += 1;
			epochTime := _urlParams.scanUntil("/", pos).Integer64;			
		endif;
		// call the PUT /ReleaseRequest/{id}/{requestDT}
		response := webService.putReleaseRequest(request, releaseRequestId, epochTime);
	else
		// call the PUT /ReleaseRequest
		response := webService.putReleaseRequest(request);
	endif;
	
	
	
	// If we're expecting to fail, then return early
	if _expectErrors then
		if webService.httpStatusCode = HttpResponseOK then
			return "Failure expected, got 200 OK";
		endif;
		
		counter	:= 1;																				//TFS 65383
		if _expectedErrorList.size &gt; 0 then															//TFS 65383
			foreach errorNum in _expectedErrorList do												//TFS 65383
				if not response.allErrors.includesError(errorNum) then								//TFS 65383
					if counter &gt; 1 then																//TFS 65383
						resMessage := resMessage &amp; ", ";											//TFS 65383
					else
						resMessage	:= "Error code : ";
					endif;																			//TFS 65383
					resMessage := resMessage &amp; errorNum.String;										//TFS 65383
					counter +=1;																	//TFS 65383
				endif;																				//TFS 65383
			endforeach;																				//TFS 65383
			if resMessage &lt;&gt; null then																//TFS 65383
				return "Failures expected ("&amp;resMessage&amp;")";										//TFS 65383
			endif;																					//TFS 65383
			return null;																			//TFS 65383
		endif;																						//TFS 65383
		
		return response.allErrors.first.text;
	endif;
	
	if webService.httpStatusCode &lt;&gt; HttpResponseOK then
		if response.allErrors.size &gt; 0 then
			app.writeLog(response.allErrors.first.text, LogERROR);
		endif;
		return method.qualifiedName &amp; " Bad Response Code, expecting 200 OK, got " &amp; webService.httpStatusCode.String &amp; ". Check UnitTest runner logs for more details" &amp; CrLf &amp; app.myPassport.getErrorsAsString;
	endif;
	
	return null;
	
	// Not used,just here to provide a reference from the super schema super class method 
	ref := CM_UnitTestAgent::wsRESTPutReleaseRequest.name;
epilog
	webService.objectsToBeDeleted.purge();
	delete webService;
	delete parser;
	delete requestLogin;
	delete request;
	transientJSONObjs.purge();
	delete transientJSONObjs;

end;</source>
        <Parameter name="_json" type="String"/>
        <Parameter name="_urlParams" type="String"/>
        <Parameter name="_expectErrors" type="Boolean"/>
        <Parameter name="_expectedErrorList" type="IntegerArray"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="wsRESTPutVoyage" id="aa597938-3997-4327-a943-0c6ed2cc57b7">
        <source>wsRESTPutVoyage(_loginString: String; _json: String; _queryParamString : String; _expectErrors: Boolean): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
20 April 2023	navlw1	Initial creation CR 57560 CUX - MTN-EDBIC - Process Voyage - Unit Tests

*/

vars
	request				: WS_RestVoyageArray;
	requestLogin		: WS_RESTLoginAuthRequest;
	webService			: MasterTerminalAPIService;
	parser				: JadeJson;
	transientJSONObjs	: ObjectArray;
	response 			: WS_Response;
	login 				: WS_InterfaceObject;
	jsonLogin			: String;
	responseLogin  		: WS_NAuthTokenResponse;
	ref 				: String;
	jsonFormat			: String;
	newJson,
	id 					: String;
	pos 				: Integer;
	dict 				: WS_QueryStringParamDict;
begin

	create webService transient;
	create transientJSONObjs transient;
	create parser transient;
	
	// call PUT /login
	requestLogin := parser.parse(_loginString, WS_RESTLoginAuthRequest, transientJSONObjs).WS_RESTLoginAuthRequest;
	webService.setPropertyValue(WS_RestWebServiceProvider::requestPath.name, "/login");
	
	login := webService.postLogin(requestLogin);
	if not login.isKindOf(WS_NAuthTokenResponse) then
		delete login;
		if webService.httpStatusCode = HttpResponseUnauthorized then
			return HttpResponseUnauthorized.String &amp; " Unauthorized - Username / Password not OK";
		endif;
		return "Login failed";
	endif;
	
	responseLogin := login.WS_NAuthTokenResponse;
	webService.unitTestData.addAssoc("HTTP_AUTHORIZATION", "Bearer " &amp; responseLogin.accessToken);
	
	webService.qsData.parseNameValuePair(_queryParamString);
	
	// set up the WS_Request object
	webService.setPropertyValue(WS_RestWebServiceProvider::requestPath.name, "/voyage");
	request := parser.parse(_json, WS_RestVoyageArray, transientJSONObjs).WS_RestVoyageArray;
	
	if _queryParamString &lt;&gt; "" then
		pos := 2;
		id := _queryParamString.scanUntil('/', pos);
		// call the put/voyage
		response := webService.putVoyage(request, id);
	else
		// call the put/voyage
		response := webService.putVoyage(request);
	endif;

	// If we're expecting to fail, then return early
	if _expectErrors then
		if webService.httpStatusCode = HttpResponseOK then
			return "Failure expected, got 200 OK";
		endif;
		return response.WS_Response.allErrors.first.text;
	endif;
	
	if webService.httpStatusCode &lt;&gt; HttpResponseOK then
		if response.allErrors.size &gt; 0 then
			app.writeLog(response.allErrors.first.text, LogERROR);
		endif;
		return method.qualifiedName &amp; " Bad Response Code, expecting 200 OK, got " &amp; webService.httpStatusCode.String &amp; ". Check UnitTest runner logs for more details" &amp; CrLf &amp; app.myPassport.getErrorsAsString;
	endif;
	
	return null;
	
	// Not used,just here to provide a reference from the super schema super class method 
	ref := CM_UnitTestAgent::wsRESTPutVoyage.name;
	
epilog
	dict := webService.qsData;
	dict.purge();
	if webService.objectsToBeDeleted.isNotEmpty then
		webService.objectsToBeDeleted.purge;
	endif;
	delete webService;
	delete parser;
	delete requestLogin;
	delete request;
	transientJSONObjs.purge();
	delete transientJSONObjs;
end;</source>
        <Parameter name="_loginString" type="String"/>
        <Parameter name="_json" type="String"/>
        <Parameter name="_queryParamString" type="String"/>
        <Parameter name="_expectErrors" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="wsRESTPutWorkPointJobSheet" id="e11a55de-ed99-4cf2-b789-7d0b28723d32">
        <source>wsRESTPutWorkPointJobSheet(_json: String; _queryParamString: String; _expectFailure: Boolean): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 Jul 2023	navlw1	ChangeRequest 58336: [58935] EUP | LMS Gang API - Endpoint Unit Tests

*/

vars
	request 			: WS_RestWorkPointJSObject;
	requestLogin		: WS_RESTLoginAuthRequest;
	webService			: MasterTerminalAPIService;
	parser				: JadeJson;
	transientJSONObjs	: ObjectArray;
	response 			: WS_Response;
	login 				: WS_InterfaceObject;
	jsonLogin			: String;
	responseLogin  		: WS_NAuthTokenResponse;
	ref 				: String;
	jsonFormat			: String;
	newJson,
	id					: String;
	pos 				: Integer;
begin
	create webService transient;
	create transientJSONObjs transient;
	create parser transient;
	
	// Login Request
	self.loginREST(webService);	
	
	// set up the WS_Request object
	webService.setPropertyValue(WS_RestWebServiceProvider::requestPath.name, "/workPointJobSheet");
	request := parser.parse(_json, WS_RestWorkPointJSObject, transientJSONObjs).WS_RestWorkPointJSObject;
	
	// call the put/WorkPointJobSheet
	if _queryParamString &lt;&gt; "" then
		pos := 2;
		id := _queryParamString.scanUntil('/', pos);
	endif;
	
	response := webService.putWorkPointJobSheet(id, request);
	
	// If we're expecting to fail, then return early
	if _expectFailure then
		if webService.httpStatusCode = HttpResponseOK then
			return "Failure expected, got 200 OK";
		endif;
		return response.WS_Response.allErrors.first.text;
	endif;
	
	if webService.httpStatusCode &lt;&gt; HttpResponseOK then
		if response.allErrors.size &gt; 0 then
			app.writeLog(response.allErrors.first.text, LogERROR);
		endif;
		return method.qualifiedName &amp; " Bad Response Code, expecting 200 OK, got " &amp; webService.httpStatusCode.String &amp; ". Check UnitTest runner logs for more details" &amp; CrLf &amp; app.myPassport.getErrorsAsString;
	endif;
	
	return null;
	
	// Not used,just here to provide a reference from the super schema super class method 
	ref := CM_UnitTestAgent::wsRESTPutWorkPointJobSheet.name;

epilog
	if webService.objectsToBeDeleted.isNotEmpty then
		webService.objectsToBeDeleted.purge;
	endif;
	delete webService;
	delete parser;
	delete requestLogin;
	delete request;
	transientJSONObjs.purge();
	delete transientJSONObjs;
end;</source>
        <Parameter name="_json" type="String"/>
        <Parameter name="_queryParamString" type="String"/>
        <Parameter name="_expectFailure" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="wsRESTRejectQueryAndBody" id="bcf20244-2b80-415a-b181-4447370806a0">
        <source>wsRESTRejectQueryAndBody(_login, _json, _verb: String; _pathParamString: String; _expectFailure: Boolean): String;
/*

Purpose:			If a request body expects an array, then its invalid to provide both that and path attributes to uniquely identify 1 object

Parameters:			

Return Value:		

Date					Who		Reason
13 December 2023		navmd1	Initial creation TFS 60597

*/

vars
	webService			: MasterTerminalAPIService;
	parser				: JadeJson;
	transientJSONObjs	: ObjectArray;
	requestLogin		: WS_RESTLoginAuthRequest;
	login 				: WS_InterfaceObject;
	responseLogin  		: WS_NAuthTokenResponse;
	httpIn,
	queryStr,
	pathIn,
	methodType,
	contentType			: String;
	ref					: String;
	idx					: Integer;
	
begin
	create webService transient;
	create transientJSONObjs transient;
	create parser transient;
	
	// call POST /login
	requestLogin := parser.parse(_login, WS_RESTLoginAuthRequest, transientJSONObjs).WS_RESTLoginAuthRequest;
	webService.setPropertyValue(WS_RestWebServiceProvider::requestPath.name, "/login");
	
	login := webService.postLogin(requestLogin);
	if not login.isKindOf(WS_NAuthTokenResponse) then
		if webService.httpStatusCode = HttpResponseUnauthorized then
			return HttpResponseUnauthorized.String &amp; " Unauthorized - Username / Password not OK";
		endif;
		return "Login failed";
	endif;
	
	responseLogin := login.WS_NAuthTokenResponse;
	webService.unitTestData.addAssoc("HTTP_AUTHORIZATION", "Bearer " &amp; responseLogin.accessToken);
	
	// call ProcessRequest
	httpIn := _json;
	pathIn := _pathParamString;
	methodType := _verb;
	queryStr := "MasterTerminalAPI";	// Simulate sending something to the external API
	if httpIn = null then
		// If httpIn (requestBody) is null, then JADE /helpfully/ makes this the same as the queryStr :(
		// So lets make sure we do the same here
		httpIn := queryStr;
	endif;
	
	idx := 2;
	webService.setPropertyValue(WS_RestWebServiceProvider::requestPath.name, "/" &amp; pathIn.scanUntil("/", idx));
//	webService.processRequest(httpIn, queryStr,  pathIn, methodType);		// calling processRequest would be better here, but I can't work out some of the transients left behind (which makes me think its a JADE thing)
	
	// Arm the exception handler like processRequest would
	on CM_Exception do self.handleCMException(exception);
	
	// preProcessRequest(httpIn: String io; queryStr: String; pathIn: String; methodType: String; contentType: String)
	webService.sendMsgWithIOParams(WS_RestWebServiceProvider::preProcessRequest.name, httpIn, queryStr, pathIn, methodType, contentType);
	
	on CM_Exception do null;
	
	// If we're expecting to fail, then return early
	if _expectFailure then
		if webService.httpStatusCode = HttpResponseOK then
			return "Failure expected, got 200 OK";
		endif;
		if webService.httpStatusCode &lt;&gt; HttpResponseClientError then
			return "Got a failure, but was expecting " &amp; HttpResponseClientError.String &amp; " but got " &amp; webService.httpStatusCode.String;
		endif;
		return null;	// Got 400 Bad Request
	endif;
	
	if webService.httpStatusCode &lt;&gt; HttpResponseOK then
		if app.myPassport.allErrors.size &gt; 0 then
			app.writeLog(app.myPassport.getAllErrorsAndWarningsAsStr(), LogERROR);
		endif;
		return method.qualifiedName &amp; " Bad Response Code, expecting 200 OK, got " &amp; webService.httpStatusCode.String &amp; ". Check UnitTest runner logs for more details" &amp; CrLf &amp; app.myPassport.getErrorsAsString;
	endif;
	
	return null;
	
	// Not used,just here to provide a reference from the super schema super class method 
	ref := CM_UnitTestAgent::wsRESTRejectQueryAndBody.name;

epilog
	webService.objectsToBeDeleted.purge();
	delete webService;
	delete parser;
	delete requestLogin;
	transientJSONObjs.purge();
	delete transientJSONObjs;
end;</source>
        <Parameter name="_login" type="String"/>
        <Parameter name="_json" type="String"/>
        <Parameter name="_verb" type="String"/>
        <Parameter name="_pathParamString" type="String"/>
        <Parameter name="_expectFailure" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="wsRestLoadByReqRoad" id="a777ba76-d17c-4d36-ab21-6d687d5a709e">
        <source>wsRestLoadByReqRoad(_ti : CM_TrackedItem; _release : CM_BulkRelease; _detail : CM_ReserveDetail; _vehicle : CM_Vehicle; releaseAmount : Integer):String;	//09.09.2024 navbs1 #65777
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 Jan 2024	navhl20	Bug 62026: MTN - Unit test case missing for release road
09 Sep 2024	navbs1	Bug 65777: EUP | 53729 - Delivery Dispatch Screen - wrong WO info when multiple in one Job

*/

vars
	ref 				: String;
	webService 			: MTNInternalAPIService;
	request				: WS_CargoLoadToReleaseRequest;
	response			: WS_Response; 
	requestLogin		: WS_RESTLoginAuthRequest;
	parser				: JadeJson;
	transientJSONObjs	: ObjectArray;
	login 				: WS_InterfaceObject;
	jsonLogin			: String;
	responseLogin  		: WS_NAuthTokenResponse;
	jsonFormat			: String;
	newJson,
	id 					: String;
	pos 				: Integer;
	terminalCode  		: String;
	token 				: String;
	loginJson 			: String;
	
begin
	// Web service call
	create webService transient;
	
	terminalCode := self.UT_TERMINAL_CODE;
	
	if app.myRoot.allTerminals[terminalCode] = null then
		return "UT Terminal not found!";
	endif;	
	
	loginJson := '{
   "userId": "' &amp; self.USERCODE &amp; '",
   "password": "' &amp; self.PASSWORD &amp; '",
    "applicationId" : "internalAPI",
    "scope" : {
        "complexId" : "Master Terminal",
		"facilityId": "' &amp; terminalCode &amp; '",
        "operatorId" : "Navis",
        "yardId" : "MTN"
    }}';
	
	self.wsRESTLogin(loginJson, token);
	
	if token &lt;&gt; null then				
		webService.unitTestData.addAssoc("HTTP_AUTHORIZATION", token);
	endif;
	
	create request transient;
	request.setPropertyValue('releaseOid',_release.getOidAsString());
	request.setPropertyValue('reserveDetailOid',_detail.getOidAsString());
	request.setPropertyValue('targetLocationOid',_vehicle.getOidAsString());
	if releaseAmount = null then 		//09.09.2024 navbs1 #65777
		request.setPropertyValue('amount',_ti.totalQuantity.asStringJMT);
	else
		request.setPropertyValue('amount',releaseAmount.asStringJMT);
	endif;
	request.setPropertyValue('warningsAcknowledged',true);
	request.setPropertyValue('completedChecks',true);
	
	response := webService.putCargoLoadToRelease(request,_ti.getOidAsString());
	if response = null then
		return "test 1, trackeditem not Loaded successfully";
	endif;
	if response.hasErrors then
		return "test 2, " &amp; response.getErrorsAsStringForTesting;
	endif;
	
	return null;
	
	// Not used,just to provide a reference from the super schema super class method 
	ref := CM_UnitTestAgent::wsRestLoadByReqRoad.name;
epilog
	webService.unitTestData.removeAssoc("HTTP_AUTHORIZATION");	
	delete request;
	delete response;
	delete webService;
end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_release" type="CM_BulkRelease"/>
        <Parameter name="_detail" type="CM_ReserveDetail"/>
        <Parameter name="_vehicle" type="CM_Vehicle"/>
        <Parameter name="releaseAmount" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="wsSourceLocationMaint" id="5bf93d5a-cdf5-464a-94b8-9e0b461b8867">
        <source>wsSourceLocationMaint() : String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 December 2014	cnwdb2	Initial creation
13 Nov 	2017 	jlger1	TFS 7541 - unit test should not delete any transient ws object only requests and responses
									otherwise we are hiding the real transient leaks
*/
constants
//setup source location and code group details
	CODE_GROUP : String = "UT_Source";
	
	SOURCE_LOC_CODE : String = 'UTSL' ; 
	SOURCE_LOCDESC : String = "Unit Test Source Location" ; 
	
	SOURCESub_LOC_CODE : String = 'UTSSL' ; 
	SOURCESub_LOCDESC : String = "Unit Test Source Sub Location" ; 
	
	SOURCESubSub_LOC_CODE : String = 'UTSSSL' ; 
	SOURCESubSub_LOCDESC : String = "Unit Test Source Sub Sub Location" ; 
	
	
	//UPDATE
	UPDATE_SOURCE_LOCDESC : String = "UT Source Location UPDATED" ; 
	
	UPDATE_SOURCESub_LOCDESC : String = "UT Source Location isDiff" ; 
	
	UPDATE_SOURCESubSub_LOCDESC : String = "UT Source Location final Diff" ; 
	
	
vars
		ref : String;
	request	           			: WS_SourceLocationUpdateRequest;
	codeGroup 					: WS_CodeGroupSourceLocation;
	sourceLocation,	sourceLocation1			: WS_SourceLocation;
	sourceSubLocation			: WS_SourceSubLocation;
	sourceSubSubLocation		: WS_SourceSubSubLocation;	
	webService 					: JMTUserInterfaceService;
	response 					: WS_SourceLocationResponse;
	responseDelete 				: WS_Response;
	realCodeGroup 				: CM_CodeGroup;

	sourceLocationDesc  		: String ; 
	sourceLocationCode		    : String ; 
	
	sourceSubLocationDesc 	    : String ; 
	sourceSubLocationCode		: String ; 

	sourceSubSubLocationDesc    : String ; 
	sourceSubSubLocationCode    : String ; 

begin
	
	
	//set update checks to the specified globals
	sourceLocationDesc := SOURCE_LOCDESC  	;	
	sourceLocationCode := SOURCE_LOC_CODE ; 	
	
	sourceSubLocationDesc := SOURCESub_LOCDESC ; 
	sourceSubLocationCode := SOURCESub_LOC_CODE ; 	
	
	sourceSubSubLocationDesc := SOURCESubSub_LOCDESC ; 
	sourceSubSubLocationCode := SOURCESubSub_LOC_CODE ; 
	
	
	if app.name &lt;&gt; "JMTUnitTest" and app.name &lt;&gt; "JMTUnitTestRunner" then
		return "Pre-test check: App.name = '" &amp; app.name &amp; "' test will fail...";
	endif;
	
	create webService transient;
	
	create codeGroup transient;
	create sourceLocation transient;
	create sourceSubLocation transient;
	create sourceSubSubLocation transient;
	
	codeGroup.setPropertyValue('name', CODE_GROUP);
	codeGroup.allSourceLocations.add(sourceLocation);
	
	sourceLocation.setPropertyValue('code', SOURCE_LOC_CODE);
	sourceLocation.setPropertyValue('description', SOURCE_LOCDESC); 
	sourceLocation.allSourceSubLocations.add(sourceSubLocation);
	
	sourceSubLocation.setPropertyValue('code', SOURCESub_LOC_CODE);
	sourceSubLocation.setPropertyValue('description', SOURCESub_LOCDESC);
	sourceSubLocation.setPropertyValue('isFSC', true);
	sourceSubLocation.allSourceSubSubLocations.add(sourceSubSubLocation);
	
	sourceSubSubLocation.setPropertyValue('code', SOURCESubSub_LOC_CODE);
	sourceSubSubLocation.setPropertyValue('description', SOURCESubSub_LOCDESC);
	sourceSubSubLocation.setPropertyValue('notAvailableForEntry', true);

	create request transient;
	request.setPropertyValue('myCodeGroupSourceLocation', codeGroup);
	
	response := webService.createSourceLocation(request);
	if response = null then
		return "test 1, updateResponse not returned.";
	endif;
	if response.hasErrors then
		return "test 2, " &amp; response.getErrorsAsStringForTesting;
	endif;
	
	if response.myCodeGroupSourceLocation = null then
		return "test 3, source locations not in system" ; 
	endif ; 
//	response.inspectModal() ; 
	
	//check all source locations are in system and created
	foreach sourceLocation in response.myCodeGroupSourceLocation.allSourceLocations do
		if sourceLocation = null then
			return "test 3, source location not in system" ;  
		endif ; 
		foreach sourceSubLocation in sourceLocation.allSourceSubLocations do
			if sourceSubLocation = null then
				return "test 3, sourceSubLocation  not in system" ;  
			endif ; 
			foreach sourceSubSubLocation in sourceSubLocation.allSourceSubSubLocations do
				if sourceSubSubLocation = null then
					return "test 3, sourceSubSubLocation  not in system" ;  
				endif ; 			
			endforeach ; 
		endforeach ; 
	endforeach ; 
	
	//tidy up from create
	delete sourceSubSubLocation;
	delete sourceSubLocation;
	delete sourceLocation;
	delete request;
	delete response;
	
	// TEST 2 Update the source locations
	realCodeGroup := app.myRoot.allCodeGroups[CodeGroup_SourceLocation, CODE_GROUP];
	create codeGroup transient;

	codeGroup.setProxyFromObject(realCodeGroup);
	
//	codeGroup.allSourceLocations.first.setPropertyValue('description', 'UT Source Location UPDATED');

	// change all the source descriptions,values etc.
	foreach sourceLocation in codeGroup.allSourceLocations do
		sourceLocation.setPropertyValue('description', UPDATE_SOURCE_LOCDESC) ; 
		foreach sourceSubLocation in sourceLocation.allSourceSubLocations do 
			sourceSubLocation.setPropertyValue('description', UPDATE_SOURCESub_LOCDESC) ; 
			sourceSubLocation.setPropertyValue('notAvailableForEntry',true) ; 

			foreach sourceSubSubLocation in sourceSubLocation.allSourceSubSubLocations do 
				sourceSubSubLocation.setPropertyValue('description', UPDATE_SOURCESubSub_LOCDESC)  ; 
				sourceSubSubLocation.setPropertyValue('isFSC',true)  ; 
			endforeach  ;
		endforeach ; 
	endforeach ; 
	
//	sourceLocation.allSourceSubLocations.add(sourceSubLocation);
		
	//update the values
	create request transient;
	request.setPropertyValue('myCodeGroupSourceLocation', codeGroup);
	
	// make the update call
	response := webService.updateSourceLocation(request) ; 
	// check the response again
	if response = null then
		return "test 1, response not returned.";
	endif;
	if response.hasErrors then
		return "test 2, " &amp; response.getErrorsAsStringForTesting;
	endif;
	
	if response.myCodeGroupSourceLocation = null then
		return "test 3, source locations not in system to update" ; 
	endif ; 

	//check there actually has been a change
	foreach sourceLocation in codeGroup.allSourceLocations do
		if sourceLocation.description = sourceLocationDesc then
			write "The original source location description failed to change source location description " &amp; "(" &amp; sourceLocationDesc.String &amp; ")" ; 
		endif  ; 
	/*	if sourceLocation.code = sourceLocationCode then
			write "The original source location code failed to change source location code " &amp; "(" &amp; sourceLocationCode.String &amp; ")" ; 
		endif ; 
		*/
		foreach sourceSubLocation in sourceLocation.allSourceSubLocations do 
			if sourceSubLocation.description = sourceSubLocationDesc then
				return "The original sourceSub location description failed to change sourceSub location description " &amp; "(" &amp; sourceSubLocationDesc.String &amp; ")" ; 
			endif ; 
		/*	if sourceSubLocation.code = sourceSubLocationCode then
				return "The original sourceSub location code failed to change sourceSub location code " &amp; "(" &amp; sourceSubLocationCode.String &amp; ")" ; 
			endif ; 
			*/
			foreach sourceSubSubLocation in sourceSubLocation.allSourceSubSubLocations do 
			/*	if sourceSubSubLocation.code = sourceSubSubLocationCode then
					return "The original sourceSubSub location code failed to change sourceSubSub location code " &amp; "(" &amp; sourceSubSubLocationCode.String &amp; ")" ; 
				endif ;  */
				if sourceSubSubLocation.description = sourceSubSubLocationDesc then
					return "The original sourceSubSub location description failed to change sourceSubSub location description " &amp; "(" &amp; sourceSubSubLocationDesc.String &amp; ")" ; 
				endif ; 
			endforeach  ;
		endforeach ; 
	endforeach ; 
	
	//tidy up from update
	//;delete codeGroup;
	delete request;
	delete response;

	
	// TEST 3 delete the source locations	
	create codeGroup transient;
	codeGroup.setProxyFromObject(realCodeGroup);
	
	//update the values
	create request transient;
	request.setPropertyValue('myCodeGroupSourceLocation', codeGroup);
	
	// make the update call
	responseDelete := webService.deleteSourceLocation(request) ; 
	// check the response again
	if responseDelete = null then
		return "test 1, response not returned.";
	endif;
	if responseDelete.hasErrors then
		return "test 2, " &amp; responseDelete.getErrorsAsStringForTesting;
	endif;
	
	realCodeGroup := app.myRoot.allCodeGroups[CodeGroup_SourceLocation, CODE_GROUP];
	if realCodeGroup &lt;&gt; null then
		return "test 3, code group not deleted" ; 
	endif; 	
	
	return null;
	
	// Not used,just to provide a reference from the super schema super class method 
	ref := CM_UnitTestAgent::wsSourceLocationMaint.name; 

epilog
	
	delete webService;
	delete request;
	delete response;
	delete responseDelete;
	
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="wsTrainArrive" id="3b965539-4123-4c21-aa28-e82dac03e44f">
        <source>wsTrainArrive(_train: CM_Train; _trainCode, _trainDesc: String; arrival, schArrival: TimeStamp; _idArray, _railIdArray, _railLineIdArray: StringArray; _positionArray: IntegerArray): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 November 2016	cnwmp6	Initial creation
13 Nov 	2017 	jlger1	TFS 7541 - unit test should not delete any transient ws object only requests and responses
									otherwise we are hiding the real transient leaks
*/

vars
	ref : String;
	queryRequest : WS_TrainMovementUpdateRequest;
	queryReqService : JMTUserInterfaceService;
	queryResponse : WS_TrainMovementResponse;
	wsWagon: WS_Wagon;
	wsTrain: WS_Train;
	index: Integer;
begin
	if app.name &lt;&gt; "JMTUnitTest" and app.name &lt;&gt; "JMTUnitTestRunner" then
		return "Pre-test check: App.name = '" &amp; app.name &amp; "' test will fail...";
	endif;

	// use parameters to build wsTrain obj to populate request

	create wsTrain transient;
	if _train &lt;&gt; null then
		wsTrain.setPropertyValue("cmObjectId", _train.getOidString());
	else
		wsTrain.setPropertyValue("code", _trainCode);
		wsTrain.setPropertyValue("description", _trainDesc);
		wsTrain.setPropertyValue("arrivalDT", arrival.String);
		wsTrain.setPropertyValue("scheduledArrivalDT", schArrival.String);
	endif;
	// need to populate train
	foreach index in 1 to _idArray.size() do
		create wsWagon transient;
		wsWagon.setPropertyValue("id", _idArray[index]);
		wsWagon.setPropertyValue("railId", _railIdArray[index]);
		wsWagon.setPropertyValue("railLineId", _railLineIdArray[index]);
		wsWagon.setPropertyValue("railLinePosition", _positionArray[index]);
		wsTrain.addWagonIn(wsWagon);
	endforeach;
	create queryRequest transient;
	queryRequest.setPropertyValue("train", wsTrain);
	queryRequest.setPropertyValue("terminalCode", app.myPassport.myTerminal.code);

	
	// call web service

	create queryReqService transient;
	queryResponse := queryReqService.doArriveTrain(queryRequest);
	if queryResponse = null then
		return "test 1, queryResponse not returned.";
	endif;
	if queryResponse.hasErrors then
		return "test 2, " &amp; queryResponse.getErrorsAsStringForTesting;
	endif;
	//delete queryResponse;	
	
	return null;
	
	// Not used,just to provide a reference from the super schema super class method 
	ref := CM_UnitTestAgent::wsTrainArrive.name; 

epilog

	delete queryResponse;
	delete queryRequest;
	delete queryReqService;
	
end;</source>
        <Parameter name="_train" type="CM_Train"/>
        <Parameter name="_trainCode" type="String"/>
        <Parameter name="_trainDesc" type="String"/>
        <Parameter name="arrival" type="TimeStamp"/>
        <Parameter name="schArrival" type="TimeStamp"/>
        <Parameter name="_idArray" type="StringArray"/>
        <Parameter name="_railIdArray" type="StringArray"/>
        <Parameter name="_railLineIdArray" type="StringArray"/>
        <Parameter name="_positionArray" type="IntegerArray"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="wsTrainDepart" id="bea5774e-1486-4a19-93ba-eae018a27220">
        <source>wsTrainDepart(_train: CM_Train): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 November 2016	cnwmp6	Initial creation

*/

vars
	ref : String;
	queryRequest : WS_TrainMovementUpdateRequest;
	queryReqService : JMTUserInterfaceService;
	queryResponse : WS_TrainMovementResponse;
	
begin
	
	if app.name &lt;&gt; "JMTUnitTest" and app.name &lt;&gt; "JMTUnitTestRunner" then
		return "Pre-test check: App.name = '" &amp; app.name &amp; "' test will fail...";
	endif;

	create queryRequest transient;
	queryRequest.setPropertyValue("cmObjectId",_train.getOidString());
	
	create queryReqService transient;
	queryResponse := queryReqService.doDepartTrain(queryRequest);
	if queryResponse = null then
		return "test 1, queryResponse not returned.";
	endif;
	if queryResponse.hasErrors then
		return "test 2, " &amp; queryResponse.getErrorsAsStringForTesting;
	endif;
	delete queryResponse;	
	
	return null;
	
	// Not used,just to provide a reference from the super schema super class method 
	ref := CM_UnitTestAgent::wsTrainDepart.name; 

epilog

	delete queryResponse;
	delete queryRequest;
	delete queryReqService;
	
end;</source>
        <Parameter name="_train" type="CM_Train"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="wsVehicleVisitMaint" id="04e8372b-a6a7-4e4e-855c-8ae7c437ca49">
        <source>wsVehicleVisitMaint( _pins : StringArray; _carrierCode : String; _driver : CM_DriverDetails ) : String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 January 2015	cnwmc5	Initial creation
13 Nov 	2017 	jlger1	TFS 7541 - unit test should not delete any transient ws object only requests and responses
									otherwise we are hiding the real transient leaks
*/

vars
	ref : String;
	request		: WS_VehicleVisitUpdateRequest;
	vvr		 	: WS_VehicleVisit;
	wsRealVVR	: WS_VehicleVisit;
	vvrCancelRequest	: WS_CancelVehicleVisitRequest;
	
	webService 	: JMTUserInterfaceService;
	responseVVR	: WS_VehicleVisitResponse;
	response 	: WS_Response;
	
	carrier		: WS_Carrier;
	driver		: WS_Driver;
	
	realVVR		: CM_VehicleVisitRecord;
	
begin
	
	if app.name &lt;&gt; "JMTUnitTest" and app.name &lt;&gt; "JMTUnitTestRunner" then
		return "Pre-test check: App.name = '" &amp; app.name &amp; "' test will fail...";
	endif;
	
	// Create VVR
	create carrier transient;
	carrier.setPropertyValue("code", _carrierCode);
	
	if _driver &lt;&gt; null then
		create driver transient;
		driver.setPropertyValue("code", _driver.code);
		driver.setPropertyValue("name", _driver.name);
	endif;
	
	create vvr transient;
	vvr.setPropertyValue("carrier", carrier);
	vvr.setPropertyValue("gateName", "GATE_VTA");
	vvr.setPropertyValue("gateLane", "1");
	vvr.setPropertyValue("regNumber", "UTMC01");
	vvr.setPropertyValue("driver", driver);
	_pins.copy(vvr.allPINs);
	
	create request transient;
	request.setPropertyValue('myVehicleVisit', vvr);
	
	create webService transient;
	responseVVR := webService.createVehicleVisit(request);
	if responseVVR = null then
		return "test 1, updateResponse not returned.";
	endif;
	if responseVVR.hasErrors then
		return "test 2, " &amp; responseVVR.getErrorsAsStringForTesting;
	endif;
	wsRealVVR := responseVVR.allVehicleVisits.first;
	
	// Cancel VVR	
	create vvrCancelRequest transient;
	vvrCancelRequest.setPropertyValue("cancellationReason", "Because Unit Test");
	vvrCancelRequest.setPropertyValue("visitNumber", wsRealVVR.visitNumber);
	
	response := webService.cancelVehicleVisit(vvrCancelRequest);
	if response = null then
		return "test 1, updateResponse not returned.";
	endif;
	if response.hasErrors then
		return "test 2, " &amp; response.getErrorsAsStringForTesting;
	endif;
	delete response;
	
	return null;
	
	// Not used,just to provide a reference from the super schema super class method 
	ref := CM_UnitTestAgent::wsVehicleVisitMaint.name; 

epilog
	
	delete vvrCancelRequest;

	delete webService;
	delete request;
	delete response;
	delete responseVVR;
	
end;</source>
        <Parameter name="_pins" type="StringArray"/>
        <Parameter name="_carrierCode" type="String"/>
        <Parameter name="_driver" type="CM_DriverDetails"/>
        <ReturnType type="String"/>
    </JadeMethod>
</Class>
