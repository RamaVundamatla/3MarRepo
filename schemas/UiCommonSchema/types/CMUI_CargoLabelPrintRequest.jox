    <JadeMethod name="checkAutoCargoIdConfigure" id="1a7046ac-c840-4008-a785-837c36e16b5d">
        <updating/>
        <source>checkAutoCargoIdConfigure():Boolean updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
20 January 2010	cnwndl1	Initial creation	CCMS MES 1004

*/

vars

	autoIdGen : CM_AutoCargoIdGen;

begin

	if self.myTerminal = null then	//16 Mar 2011	NDL	Par 27204
		app.msgBox(app.getErrorString(Terminal_reference_set), app.getErrorString(Error), MsgBox_OK_Only);
		self.unloadForm();
		return false;
	endif;
	
	autoIdGen := self.myTerminal.getMyAutoIdGenerator( CM_AutoCargoIdGen ).CM_AutoCargoIdGen;
	
	if autoIdGen = null then
		app.msgBox(app.getErrorString(No_Auto_Cargo_Id_Config), app.getErrorString(Warning), MsgBox_OK_Only);
		return false;
	else
		if chkAuto.value then
			if autoIdGen.idStyle &lt; 1 then
				app.msgBox(app.getErrorString(Must_config_style), app.getErrorString(Warning), MsgBox_OK_Only);
				return false;
			endif;
		endif;
	endif;
	
	return true;
	
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
