    <JadeMethod name="isOnboadCargoType_Match" id="45efeafd-6578-4113-b6ae-cdfb93cc3e98">
        <source>isOnboadCargoType_Match(_yaData: CM_YADataObjects): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 May 2024	jlier1	Initial creation 63834

*/

vars
	cargoTypeDescs : StringArray;
	cargoTypeDesc	: String;
	cargoType 		: CM_CargoType;
begin
	if _yaData.isEmpty() then
		return true;
	endif;
	
	create cargoTypeDescs transient;
	self.myTransaction.onboardCargoTypes.getTokensForDelimiter(",",cargoTypeDescs);
	
	foreach cargoTypeDesc in cargoTypeDescs do
		cargoType:=app.myRoot.allCargoTypesByDescription[cargoTypeDesc.trimBlanks];
		if cargoType &lt;&gt; null then
			if _yaData.matches(cargoType) then
				return true;
			endif;
		endif;
	
	endforeach;
	
	return false;
epilog
	delete cargoTypeDescs;
end;</source>
        <Parameter name="_yaData" type="CM_YADataObjects"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isOnboardConsgineeNor_Match" id="f1c0b372-59b1-48e2-8dd3-f600047730e8">
        <source>isOnboardConsgineeNor_Match(_yaData: CM_YADataObjects): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 May 2024	jlier1	Initial creation 63834

*/

vars
	consigneeConsignor		: CM_ConsigneeConsignor;
	consingeesCode : String;
	consginees : StringArray;
begin
	if _yaData.isEmpty() then
		return true;
	endif;
	
	create consginees transient;
	self.myTransaction.onboardCosingeeCosingnors.getTokensForDelimiter(",",consginees);
	
	foreach consingeesCode in consginees do
		consigneeConsignor:= app.myRoot.allConsigneeConsignors[consingeesCode.trimBlanks];
		if consigneeConsignor &lt;&gt; null then
			if _yaData.matches(consigneeConsignor) then
				return true;
			endif;
		endif;
	endforeach;

	return false;
epilog
	delete consginees;
end;</source>
        <Parameter name="_yaData" type="CM_YADataObjects"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isOnboardSubType_Match" id="e48c055a-f10c-4661-8c76-e388622ce15f">
        <source>isOnboardSubType_Match(_yaData: CM_YADataObjects): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 May 2024	jlier1	Initial creation 63834

*/

vars
	subTypeDescs,cargoTypeDescs : StringArray;
	subTypeDesc,cargoTypeDesc	: String;
	cargoType 		: CM_CargoType;
	subType 		: CM_Product;
begin
	if _yaData.isEmpty() then
		return true;
	endif;
	
	create subTypeDescs transient;
	self.myTransaction.onboardSubTypes.getTokensForDelimiter(",",subTypeDescs);
	
	create cargoTypeDescs transient;
	self.myTransaction.onboardCargoTypes.getTokensForDelimiter(",",cargoTypeDescs);

	foreach cargoTypeDesc in cargoTypeDescs do
		cargoType:=app.myRoot.allCargoTypesByDescription[cargoTypeDesc.trimBlanks];
		if cargoType &lt;&gt; null then
			foreach subTypeDesc in subTypeDescs do
				subType:=cargoType.getProductFromCode(subTypeDesc.trimBlanks);
				if subType &lt;&gt; null then
					if _yaData.matches(subType) then
						return true;
					endif;
				endif;
			endforeach;
		endif;
	endforeach;
		
	return false;
epilog
	delete subTypeDescs;
	delete cargoTypeDescs;

end;</source>
        <Parameter name="_yaData" type="CM_YADataObjects"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isOperatorVoyage_Match" id="ad816247-d407-4d66-9f7d-ac71bd095c56">
        <source>isOperatorVoyage_Match(_yaData : CM_YADataObjects) : Boolean;
/*

Purpose:			Used to Verify that the Operator (Voyage)/CMVoyage::myOperator matches Cargo Allocation
					Other Method is_VoyageOperator_Match which is used for global voyage operators

Parameters:			NONE

Return Value:		NONE

Date		Who		Reason
22 April 2022	navpw1	Initial creation TFS: 53303

*/

vars
	ti 		 : CM_TrackedItem;
	voyage   : CM_Voyage;
	operator : CM_Operator;
begin
	ti	   := self.myTrackedItem;
	voyage := ti.myVoyage;
	
	if voyage = null then
		return false;
	endif;
	
	operator := voyage.myOperator;
	
	if operator = null then
		return false;
	endif;
	
	// Only priorities will be empty.
	if _yaData.isEmpty() then
		return true;
	endif;
	
	return _yaData.matches(operator);

end;</source>
