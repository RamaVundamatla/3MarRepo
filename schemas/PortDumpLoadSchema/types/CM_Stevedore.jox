<Class name="CM_Stevedore">
    <JadeMethod name="importPLXMLReference" id="e169ff8f-1372-4cd5-a61d-0cb0b63cbf37">
        <source>importPLXMLReference(_name, _theCode, _referencesBlock: String): Object;

vars

begin
	if _name = CM_Stevedore::myRoot.name then
		return app.myRoot;
	else
		return null;
	endif;
end;</source>
        <Parameter name="_name" type="String"/>
