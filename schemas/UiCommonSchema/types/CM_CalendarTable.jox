<GUIClass name="CM_CalendarTable" id="797701fd-4daf-440c-9616-40af2c85bc84">
    <superclass name="CM_BaseTable"/>
    <transient/>
    <sharedTransientAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="_usergui"/>
    <Constant name="DAYSOFWEEK" id="ae3ea970-897d-4c65-80af-bd4fd872ef9b">
        <source>7</source>
        <type name="Integer"/>
    </Constant>
    <Constant name="NUMOFROWS" id="9c127f12-2fa6-400d-b413-5417caf9a605">
        <source>7</source>
        <type name="Integer"/>
    </Constant>
    <PrimAttribute name="selectedDate" id="0832bed0-b103-4c68-ae88-005d34079c59">
        <embedded/>
        <type name="Date"/>
    </PrimAttribute>
    <JadeMethod name="init" id="e3d0923f-d87a-4723-9bd6-20a015956bae">
        <updating/>
        <source>init() updating;
// ---------------------------------------------------------------------------
// Created:     cnwyl1  Yi Liu
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	today : Date;
begin
	self.fixedRows := 1;
	self.fixedColumns := 0;
	self.columns := self.DAYSOFWEEK;
	self.rows := self.NUMOFROWS;
	self.fixed3D := false;
	self.selectMode := Table.SelectMode_Single;

	self.accessColumn(1).width := 50;
	self.accessColumn(2).width := 50;	
	self.accessColumn(3).width := 50;	
	self.accessColumn(4).width := 50;	
	self.accessColumn(5).width := 50;
	self.accessColumn(6).width := 50;
	self.accessColumn(7).width := 50;
	self.width := 355;
	self.height := 120;
	
	self.row := 1;
	self.column := 1;
	self.text := "Mon";
	self.column := 2;
	self.text := "Tue";
	self.column := 3;
	self.text := "Wed";
	self.column := 4;
	self.text := "Thu";		
	self.column := 5;
	self.text := "Fri";		
	self.column := 6;
	self.text := "Sat";		
	self.column := 7;
	self.text := "Sun";		
	self.showDays(today);
	self.selectDay(today);
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="selectDay" id="e418058a-7e6f-4cd7-8c91-ed93f3266253">
        <updating/>
        <source>selectDay(date : Date) updating;
// ---------------------------------------------------------------------------
// Created:     cnwyl1  Yi Liu
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	r, c : Integer;
begin
	accessMode := 1;
	r := 2;
	while r &lt;= rows do
		row := r;
		c := 1;
		while c &lt;= columns do
			column := c;	
			if text = date.day.String then
				self.accessCell(r, c).selected := true;
			else
				self.accessCell(r, c).selected := false;
			endif;
			c := c + 1;
		endwhile;
		r := r + 1;
	endwhile;
	row := 1;
	column := 1;
end;</source>
        <Parameter name="date" type="Date"/>
    </JadeMethod>
    <JadeMethod name="setDate" id="b0a6ef56-93a0-40c6-933b-72b956941093">
        <updating/>
        <source>setDate(pDate : Date) updating;
// ---------------------------------------------------------------------------
// Created:     cnwyl1  Yi Liu
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	self.showDays(pDate);
	self.selectDay(pDate);
epilog

end;</source>
        <Parameter name="pDate" type="Date"/>
    </JadeMethod>
    <JadeMethod name="showDays" id="6ba866cd-e3a8-471f-a883-a8e361da0a60">
        <updating/>
        <source>showDays(pDate : Date) updating;
// ---------------------------------------------------------------------------
// Created:     cnwyl1  Yi Liu
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	r, c : Integer;
	day : Date;
begin
	r := 1;
	while r &lt;= self.rows do
		self.row := r; 
		c := 1;
		while c &lt;= self.columns do
			self.column := c; 
			self.text := ""; 
			c := c + 1;
		endwhile;
			r := r + 1;
	endwhile;
	self.row := 1;
	day.setDate(1, pDate.month, pDate.year);
	while day.day &lt;= self.DAYSOFWEEK do
		self.column := day.dayOfWeek;
		self.text := day.dayName[1:3];
		day := day + 1;
	endwhile;
	self.row := 2;
	day.setDate(1, pDate.month, pDate.year);
	while day.month = pDate.month do
		self.column := day.dayOfWeek;
		self.text := day.day.String;
		if self.column &gt;= self.columns then
			if self.row &gt;= self.rows then
				self.row := 2;
			else			
				self.row := self.row + 1;
			endif;
		endif;
		day := day + 1;
	endwhile;
end;</source>
        <Parameter name="pDate" type="Date"/>
    </JadeMethod>
