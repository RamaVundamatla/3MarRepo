    <JadeMethod name="clearGateLane" id="45cb01ce-1ab6-4d69-b34a-3992399f51c4">
        <source>clearGateLane();
/*

Purpose:			Removes the Weighbridge reference from the GateLane and LaneDevice

Parameters:			NONE

Return Value:		NONE

Date		Who		Reason
27 May 2022	navpw1	Initial creation TFS: 52773

*/

vars
	gate			: CM_Gate;
	objectSet		: CM_ObjectSetActual;
	lObject			: CM_Object;
	gateLaneCont	: CM_GateAreaLaneController;
	allGates		: CM_GateNameDict;
	
begin
	create objectSet transient;
	
	if self.myTerminal = null then // ### TFS 52773 30May2022 NAVPW1 - In case a Logical Certify unit test gets in here with a null terminal
		return;
	endif;
	
	allGates := self.myTerminal.allGates;
	
	foreach gate in allGates do
		gate.getAllGALaneControllers(objectSet, Both);
		
		foreach gateLaneCont in objectSet as CM_GateAreaLaneController do		
			if gateLaneCont.getWeighBridge = self then
				gateLaneCont.setWeighbridgeSerial(null);
				
			endif;
			
		endforeach;
		
	endforeach;
	
epilog
	delete objectSet;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="delete" id="efc05d65-badc-4de7-9a91-caca8beb8a07">
        <updating/>
        <source>delete() updating;
/*

Purpose:			Cleans up References

Parameters:			NONE

Return Value:		NONE

Date		Who		Reason
09 May 2022	navpw1	Initial creation TFS: 52773

*/

begin
	if not isTransient then
		self.clearGateLane();
		
		if app.myAlternateDict &lt;&gt; null then
			app.myAlternateDict.setGnrcIfaceDvcDictNeedRefresh();
			
		endif;
		
	endif;
	
	self.resetAuditsDuringDelete();

end;</source>
    </JadeMethod>
    <JadeMethod name="doHandleTCPConnectionError" id="ac58128a-e072-4bb7-b0f6-e74165735ef8">
        <source>doHandleTCPConnectionError( _exception : Exception; _test : Boolean; _strArray : StringArray512 input ):Integer;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 March 2014	cnwndl1	Initial creation	Par 33268

*/

vars

	returnVal : Integer;
	logString : String;

begin

	returnVal := Ex_Pass_Back;
	
	if _exception.isKindOf( ConnectionException ) then
		logString := "Error " &amp; _exception.errorCode.String &amp; " - " &amp; _exception.extendedErrorText;
		logStatus( logString, _test, _strArray );
		if _exception.resumable then
			returnVal := Ex_Resume_Next;
		endif;
	endif;
	
	return returnVal;

epilog

end;</source>
        <Parameter name="_exception" type="Exception"/>
        <Parameter name="_test" type="Boolean"/>
        <Parameter name="_strArray" type="StringArray512" usage="input"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="doRTSContainerDirectWtUpdate" id="82b54a8f-2fcc-4340-bb96-f5b7c8af707f">
        <source>doRTSContainerDirectWtUpdate( 	_rtsContainer : CM_Container input;
								_totalWeightKgs : Decimal;
								_certifiedBy : String;
								_authPerson : String;
								_passport : CM_Passport input
								);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 May 2020	jlgndl1	Initial creation	TFS 49296

*/

vars

	tiUpdateCntrlr : CMIF_TIUpdateController;
	vgmDetails : CM_VGMDetails;
	updateCargoWeight : Boolean;

begin

	if _rtsContainer = null then
		return;
	endif;
	if _totalWeightKgs &lt;= 0 then
		return;
	endif;
	updateCargoWeight := _totalWeightKgs &lt;&gt; _rtsContainer.totalWeight and _rtsContainer.weightCargo &gt; 0 and _rtsContainer.weightTare &lt; _totalWeightKgs;
	
	tiUpdateCntrlr := app.createTIUpdateControl(TI_UPDMODE_RECEIPT, _passport.userCode, null);
	tiUpdateCntrlr.transactionType := TRANS_TYPE_WEIGH;
	tiUpdateCntrlr.newWeight := _totalWeightKgs;
	tiUpdateCntrlr.weighBridgeName := self.name;
	
	
	_rtsContainer.setTotalWeight( _totalWeightKgs, tiUpdateCntrlr, _passport);
	
	if updateCargoWeight then
		_rtsContainer.setWeightCargo(  _totalWeightKgs - _rtsContainer.weightTare );
	endif;
	
	if _certifiedBy &lt;&gt; null and _authPerson &lt;&gt; null then
		_rtsContainer.setMyVGMDetails( _certifiedBy, _authPerson,
									null, null, null, null, null, null, null, null, null,
									null, null, tiUpdateCntrlr );
	endif;

epilog

	delete tiUpdateCntrlr;

end;</source>
        <Parameter name="_rtsContainer" type="CM_Container" usage="input"/>
        <Parameter name="_totalWeightKgs" type="Decimal"/>
        <Parameter name="_certifiedBy" type="String"/>
        <Parameter name="_authPerson" type="String"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doWeighBridgeRequest" id="8f82e3db-a9e5-4382-866d-40fb5ba9b352">
        <source>doWeighBridgeRequest(	_weightType : CM_MeasurementType output;
						_rawWeight : Integer output;
						_test : Boolean;
						_strArray : StringArray512 input;
						_errArray : StringArray input
						);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 March 2014	cnwndl1	Initial creation	Par 33268

*/


vars

	connection : TcpIpConnection;
	logString : String;
	binResponse : Binary;
	errorString : String;
	fail : Boolean;
	requestStringStr : String;
	
begin

	logString := "About to request a weight reading from Weigh Bridge '" &amp; self.name &amp; "'.";
	self.logStatus( logString, _test, _strArray );
	
	if self.ipAddress = null then
		logString := "No TCP/IP address set up!";
		if _errArray &lt;&gt; null then
			_errArray.add(logString);
		endif;
		fail := true;
		_rawWeight := 0;
		return;
	else
		logString := "Using TCP/IP address '" &amp; self.ipAddress &amp; "'.";
		self.logStatus( logString, _test, _strArray );
	endif;
	if self.portNumber = null then
		logString := "No TCP/IP port number set up!";
		if _errArray &lt;&gt; null then
			_errArray.add(logString);
		endif;
		fail := true;
		_rawWeight := 0;
		return;
	else
		logString := "Using TCP/IP port number '" &amp; self.portNumber.String &amp; "'.";
		self.logStatus( logString, _test, _strArray );
	endif;
	if self.myWeighBridgeType = null then
		logString := "No weigh bridge type set up!";
		if _errArray &lt;&gt; null then
			_errArray.add(logString);
		endif;
		fail := true;
		_rawWeight := 0;
		return;
	else
		logString := "Weigh Bridge Type in use is '" &amp; self.myWeighBridgeType.code &amp; "'.";
		self.logStatus( logString, _test, _strArray );
	endif;
	
	if self.timeOutSeconds &gt; 0 then
		logString := "Time out is set to '" &amp;self.timeOutSeconds.String &amp; "' seconds.";
		self.logStatus( logString, _test, _strArray );
	endif;

	create connection transient;
	
	if connection = null then
		logString := "No TCP/IP connection";
		if _errArray &lt;&gt; null then
			_errArray.add(logString);
		endif;
		fail := true;
		_rawWeight := 0;
		return;
	endif;
	
	connection.name := self.ipAddress;
	connection.port := self.portNumber;
	connection.timeout := (self.timeOutSeconds * 1000);
	connection.usePresentationClient := false;
	
	logString := "Attempting to open TCP/IP connection to " &amp; self.name &amp; "'.";
	self.logStatus( logString, _test, _strArray );
	
	on ConnectionException do self.doHandleTCPConnectionError( exception, _test, _strArray );
		
	connection.open();
	
	if connection.state = TcpIpConnection.Connected then
		logString :=  "TCP/IP Connection status = Connected";
	elseif connection.state = TcpIpConnection.Connecting then
		logString :=  "TCP/IP Connection status = Connecting";
	elseif connection.state = TcpIpConnection.Disconnecting then
		logString :=  "TCP/IP Connection status = Disconnecting";
		_errArray.add(logString);
		fail := true;
		_rawWeight := 0;
		return;
	elseif connection.state = TcpIpConnection.Disconnected then
		
		
		executeWhen JMTDevelopmentEnvironment;
		if not _test then
			// In dev if we can't see their ip address, generate some data.
			self.generateDevTestData( _weightType, _rawWeight, _test, _strArray, _errArray);
			return;
		endif;
		endExecuteWhen;
		
		logString :=  "TCP/IP Connection status = Disconnected";
		if _errArray &lt;&gt; null then
			_errArray.add(logString);
		endif;
		fail := true;
		_rawWeight := 0;
		return;
	else
		logString :=  "TCP/IP Connection status unknown";
	endif;
	self.logStatus( logString, _test, _strArray );
	
	//send request to weigh bridge
	requestStringStr := self.myWeighBridgeType.getRequestString( self );
	logString := "Sending TCP/IP msg '" &amp; requestStringStr.Binary.String &amp; "'";
	self.logStatus( logString, _test, _strArray );
	connection.writeBinary( requestStringStr.asANSI(0) );// 16/3/16  cnwns1 PAR 36286 unicode version
	
	logString := "Waiting for TCP/IP response";
	self.logStatus( logString, _test, _strArray );
	binResponse := connection.readBinary(1000);
	
	logString := "TCP/IP Binary response = " &amp; binResponse.display;
	self.logStatus( logString, _test, _strArray );
	
	self.myWeighBridgeType.getWeightResponseString( binResponse, _weightType, _rawWeight, errorString );
	if _rawWeight = 0 and errorString &lt;&gt; null then
		logString := "Weigh Bridge error string = " &amp; errorString;
		self.logStatus( logString, _test, _strArray );
		if _errArray &lt;&gt; null then
			_errArray.add(logString);
		endif;
		logString := "TCP/IP Test Completed Unsuccessfully";
	else
		if _errArray &lt;&gt; null and errorString &lt;&gt; null then
			_errArray.add(errorString);
		endif;
		logString := "Weigh Bridge returned weight = " &amp; _rawWeight.asStringJMT();
		if _weightType &lt;&gt; null then
			logString := logString &amp; " " &amp; _weightType.shortName;
		endif;
		self.logStatus( logString, _test, _strArray );
		logString := "Weigh Bridge '" &amp; self.name &amp; "' Test Completed Successfully";
	endif;
	
epilog

	self.logStatus( logString, _test, _strArray );

	if connection &lt;&gt; null then
		logString := "Closing TCP/IP connection";
		self.logStatus( logString, _test, _strArray );
		connection.close;
	endif;
	
	if fail and _errArray &lt;&gt; null then
		logString := "Weight reading request FAILED!!";
		_errArray.add(logString);
		self.logStatus( logString, _test, _strArray );
	endif;

	delete connection;

end;</source>
        <Parameter name="_weightType" type="CM_MeasurementType" usage="output"/>
        <Parameter name="_rawWeight" type="Integer" usage="output"/>
        <Parameter name="_test" type="Boolean"/>
        <Parameter name="_strArray" type="StringArray512" usage="input"/>
        <Parameter name="_errArray" type="StringArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="generateDevTestData" id="cb4e2318-7356-4047-8d15-6168207fe63d">
        <source>generateDevTestData(	_weightType : CM_MeasurementType output;
						_rawWeight : Integer output;
						_test : Boolean;
						_strArray : StringArray512 input;
						_errArray : StringArray input
						) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26 March 2014	cnwndl1	Initial creation

*/

vars

	logString : String;
	randomNum : Integer;
	errorString : String;
	strResponse : String;
	binResponse : Binary;

begin

	executeWhen JMTDevelopmentEnvironment;
	
	logString := "In Development, generating TEST DATA for Weigh Bridge '" &amp; self.name &amp; "'.";
	errorString := "Connection not established.";
	_errArray.add(errorString);
	errorString := "Random Weight value generated for Testing purposes.";
	_errArray.add(errorString);
	self.logStatus( logString, _test, _strArray );

	randomNum := app.random(8);
	
	if self.myWeighBridgeType.code = CM_WeighBridgeObjType.SeriesW then
	
		if randomNum = 1 then
			strResponse := "&amp;01012192t75" &amp; Cr;
		elseif randomNum = 2 then
			strResponse := "&amp;01011376t75" &amp; Cr;
		elseif randomNum = 3 then
			strResponse := "&amp;01011000t75" &amp; Cr;
		elseif randomNum = 4 then
			strResponse := "&amp;01011500t75" &amp; Cr;
		elseif randomNum = 5 then
			strResponse := "&amp;01013208t75" &amp; Cr;
		elseif randomNum = 6 then
			strResponse := "&amp;01011939t75" &amp; Cr;
		elseif randomNum = 7 then
			strResponse := "&amp;01014000t75" &amp; Cr;
		elseif randomNum = 8 then
			strResponse := "&amp;01011753t75" &amp; Cr;
		endif;
		
		binResponse := strResponse.Binary;
		_weightType := app.myRoot.allMeasurementTypesByShortName["kg"];
		
		self.myWeighBridgeType.getWeightResponseString(	binResponse,	//_binResponse : Binary;
														_weightType,	//_weightType : CM_MeasurementType output;
														_rawWeight,	//_rawWeight : Integer output;
														errorString	//_errorString : String output
														);
		if errorString &lt;&gt; null then
			_errArray.add(errorString);
		endif;
		//self.logStatus( logString, _test, _strArray );
		
	else
		if randomNum = 1 then
			_weightType := app.myRoot.allMeasurementTypesByShortName["LT"];
			_rawWeight := 12;
		elseif randomNum = 2 then
			_weightType := app.myRoot.allMeasurementTypesByShortName["lbs"];
			_rawWeight := 25080;
		elseif randomNum = 3 then
			_weightType := app.myRoot.allMeasurementTypesByShortName["MT"];
			_rawWeight := 11;
		elseif randomNum = 4 then
			_weightType := app.myRoot.allMeasurementTypesByShortName["kg"];
			_rawWeight := 11500;
		elseif randomNum = 5 then
			_weightType := app.myRoot.allMeasurementTypesByShortName["LT"];
			_rawWeight := 13;
		elseif randomNum = 6 then
			_weightType := app.myRoot.allMeasurementTypesByShortName["lbs"];
			_rawWeight := 26320;
		elseif randomNum = 7 then
			_weightType := app.myRoot.allMeasurementTypesByShortName["MT"];
			_rawWeight := 14;
		elseif randomNum = 8 then
			_weightType := app.myRoot.allMeasurementTypesByShortName["kg"];
			_rawWeight := 11753;
		endif;
	
	endif;
		
	endExecuteWhen;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_weightType" type="CM_MeasurementType" usage="output"/>
        <Parameter name="_rawWeight" type="Integer" usage="output"/>
        <Parameter name="_test" type="Boolean"/>
        <Parameter name="_strArray" type="StringArray512" usage="input"/>
        <Parameter name="_errArray" type="StringArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getCargoUpdateModeStr" id="3bc68d5e-9792-4593-bf45-6e4b56572cb7">
        <source>getCargoUpdateModeStr():String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 July 2019	jlgndl1	Initial creation	TFS 44965

*/

vars

begin

	if self.updateCargoMode = SingleReading then
		return SingleReadingStr;
	elseif self.updateCargoMode = TwoReadings then
		return TwoReadingsStr;
	endif;
	
	return null;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="5ea67ec4-577d-4136-8804-5a8c0d023f3b">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 March 2014	cnwndl1	Initial creation	Par 33680
//24/01/17 cnwns1 TFS3153:PKT - Bulk Process - WeighBridge Integration

*/

vars

begin

	if  _attrName = ETRow_Name then
		return self.name;
		
	elseif  _attrName = ETRow_AutoRequest then
		return self.autoRequest.String;
		
	elseif  _attrName = ETRow_WeighBridgeType then
		if self.myWeighBridgeType &lt;&gt; null then
			return self.myWeighBridgeType.code;
		endif;
		return null;
	
	elseif  _attrName = ETRow_IpAddress then
		return self.ipAddress;
	
	elseif  _attrName = ETRow_PortNumber then
		return self.portNumber.String;
	
	elseif  _attrName = ETRow_TimeOutSeconds then
		return self.timeOutSeconds.asStringJMT;
		
	elseif _attrName =	ETRow_ComputerName	then
		return self.computerName;
	
	
	elseif _attrName = ETRow_MyGateLane then
		if self.myGateLane &lt;&gt; null then
			return self.myGateLane.getGateLaneNumber;
		else
			return null;
		endif;
	
	
	elseif _attrName = ETRow_WeightUnit then
		if self.myWeightType &lt;&gt; null then
			return self.myWeightType.name;
		else
			return null;
		endif;
		
	elseif _attrName = ETRow_DeviceAddress then	//25 May 2017	NDL	TFS 4383
		return deviceAddress.String.padLeadingZeros(2);
		
	elseif _attrName = ETRow_CargoUpdateMode then
		return getCargoUpdateModeStr;
		
	elseif _attrName = ETRow_CanUpdateRTS then	//11 May 2020	NDL	TFS 49296
		return self.canUpdateRTS.String;
		
	elseif _attrName = ETRow_DeviceID then	// ### TFS 52773 1APR2022 NAVPW1
		return self.deviceId;
		
	else
		return inheritMethod(_attrName, _short);
	endif;	
	

epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="isGenericScanAPI" id="4957fd50-a6a0-4962-9e0d-f13f28969c21">
        <methodInvocation>mapping</methodInvocation>
        <source>isGenericScanAPI(set: Boolean; _value: Boolean io) mapping;
/*

Purpose:			Tells us if our weigh bridge is a Generic Scan API Weigh Bridge

Parameters:			NONE

Return Value:		NONE

Date		Who		Reason
01 April 2022	navpw1	Initial creation TFS: 52773

*/

vars
	invalid	: Boolean;
	edition : Integer;
	
begin

	on Exception do app.handleDeletedObject(exception, self.myWeighBridgeType, invalid);
	
	if self.myWeighBridgeType = null then
		_value := false;
		return;
	endif;
	
	edition := self.myWeighBridgeType.edition;
	
	if invalid then
		_value := false;
		return;
	endif;
	
	if self.myWeighBridgeType.code = CM_WeighBridgeObjType.GenericScanAPI
	then
		_value := true;
		return;
	endif;
	
	_value := false;

end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="Boolean" usage="io"/>
    </JadeMethod>
    <JadeMethod name="isSerialPort" id="8190a8b7-c1c3-4863-84d6-67c95a7247b3">
        <methodInvocation>mapping</methodInvocation>
        <source>isSerialPort(set : Boolean; _value : Boolean io)  mapping;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 February 2017	cnwns1	Initial creation
//24/01/17 cnwns1 TFS3153:PKT - Bulk Process - WeighBridge Integration
05 Jul 2019	NDL	TFS 44965

*/

vars

	invalid	: Boolean;
	edition : Integer;
	
begin

	on Exception do app.handleDeletedObject(exception, self.myWeighBridgeType, invalid);
	
	if self.myWeighBridgeType = null then
		_value := false;
		return;
	endif;
	edition := self.myWeighBridgeType.edition;
	if invalid then
		_value := false;
		return;
	endif;
	
	if self.myWeighBridgeType.code = CM_WeighBridgeObjType.MT226
	or self.myWeighBridgeType.code = CM_WeighBridgeObjType.Kubota
	then
		_value := true;
		return;
	endif;
	
	_value := false;

epilog

end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="Boolean" usage="io"/>
    </JadeMethod>
