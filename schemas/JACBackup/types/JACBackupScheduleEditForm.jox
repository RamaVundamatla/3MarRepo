    <JadeMethod name="validPaths" id="163c5918-063e-4663-aa28-72829a837914">
        <source>validPaths():Boolean;
// ---------------------------------------------------------------------------
// Created:     
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	ff: FileFolder;
	i: Integer;
	tbx: TextBox;
	try: String;
begin
	create ff transient;

	foreach i in 1 to 9 do
		tbx := self.getControlWithName("tbxPath"&amp;i.String).TextBox;
		if tbx.enabled = false then
			break;
		endif;

		// Check for default usage
		if tbx.text.trimBlanks = null then
			tbx.text := self.tbxPathDef.text.trimBlanks;
		endif;

		// Make sure something was entered
		if tbx.text = null then
			app.msgBox("No foldername entered and no default faolder.", "Error", MsgBox_OK_Only);
			tbx.setFocus;
			return false;
		endif;

		// Remove any trailing \
		tbx.text := tbx.text.trimBlanks;
		if tbx.text[tbx.text.length:1] = "\" then
			tbx.text := tbx.text[1:tbx.text.length-1];
		endif;

		// Look for %d on the end and temporarily remove
		if tbx.text.length &gt; 2 and 
		   tbx.text[tbx.text.length-1:2] = "%d" then
			try := tbx.text[1:tbx.text.length-2];
		else
			try := tbx.text;
		endif;
/*
		if not ff.isValidPathName(try) then
			app.msgBox("Invalid Foldername", "Error", MsgBox_OK_Only);
			tbx.setFocus;
			return false;
		endif;

		ff.fileName:=try;
		if not ff.isAvailable then
			if app.msgBox("Create new folder " &amp; try, "Confirm", MsgBox_OK_Cancel) = MsgBox_Return_OK then
				ff.make;
			else
				tbx.setFocus;
				return false;
			endif;
		endif;
*/
	endforeach;

	return true;

epilog
	delete ff;	

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</GUIClass>
