    <JadeMethod name="includeObject" id="78ba331a-c689-456e-abf2-99227991b531">
        <updating/>
        <source>includeObject(_obj: Object; _passport: CM_Passport): Boolean updating;
//----------------------------------------------------------------------
//  Created by cnwsh3
//	Date 22 July 2009
//
// Implemented version: 7.7.3

//----------------------------------------------------------------------
vars

begin
	if self.includeNotAvailableEntries then
		return true;
	else
		return not _obj.CM_DamagePosition.isNotAvailableForEntry;
	endif;

epilog
end;</source>
        <Parameter name="_obj" type="Object"/>
        <Parameter name="_passport" type="CM_Passport"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="initShtMultiSelect" id="4341d921-5e97-4a83-a1b9-cbacbdcec77f">
        <source>initShtMultiSelect();
//----------------------------------------------------------------------
//  Created by cnwsh3
//	Date 20 July 2009
//
// Implemented version: 7.7.3
// CCMS SFW1066  - Recording Damage Details Changes.
//----------------------------------------------------------------------
vars
	theForm	: SOP_TableMaintForm;
	obj : Object;
	coll : CM_MachineTypeByTypeDict;
	machineType : CM_MachineType;
begin
	theForm := self.myForm;
	inheritMethod();
	
	self.setupMultiSelect1(app.getErrorString(CargoTypes), app.myRoot.allCargoTypesById, SOP_TableMaintForm::displayEntryCargoType.name);
	
	create coll transient;
	foreach machineType in app.myRoot.allMachineTypes where machineType.isKindOf(CM_WagonMachineType) do
		coll.add(machineType);
	endforeach;
	self.setupMultiSelect2(app.getErrorString(MachineTypes), coll, SOP_TableMaintForm::displayEntryMachineTypes.name);
	
epilog
	delete coll;
end;</source>
    </JadeMethod>
