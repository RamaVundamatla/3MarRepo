    <JadeMethod name="sendToReport" id="19506728-24ec-431e-980f-69f75a8fa11c">
        <source>sendToReport(_objSet : ObjectSet input);
// ---------------------------------------------------------------------------
// Created:     13 December 2007 by cnwaer1
//
// Purpose:    
// Date				Changed By		Reason
// 14 April 2010 	cnwsh3			Want to be able to report on more than just tracked items so added parameters 
//									to app methods for setting up the send to report form.
// ---------------------------------------------------------------------------
vars
	jrwReportName	: String;
	selectedOnly,
	printPreview 	: Boolean;
	tbl 			: CM_DataTable;
	tiArray 		: ObjectArray;
	obj 			: Object;
	ti 				: CM_TrackedItem;
	tiSet			: CM_TISet;
	outputType		: Integer;
	filePath		: String;
begin
	if app.getReportToSendItems(CM_TrackedItemView, null, selectedOnly, jrwReportName, printPreview, outputType, filePath) then // SFW CCMS 1115 PAR23680   cnwsh3 - Invoice JRW Interface
		create tiArray transient;
		foreach obj in _objSet do
			tiSet := obj.CMIF_CommercialQueryEntity.getTISet();
			if tiSet &lt;&gt; null and tiSet.size  &gt; 0 then 
				foreach ti in tiSet do
					if ti.isKindOf(CM_TrackedItem) and not tiArray.includes(ti) then
						tiArray.add (ti);
					endif;
				endforeach;
			endif;
		endforeach;
		//app.sendTIsToReport(tiArray, jrwReportName, printPreview);
		app.sendItemsToReport(CM_JRWTrackedItems, tiArray, jrwReportName, printPreview, outputType, filePath); // SFW CCMS 1115 PAR23680   cnwsh3 - Invoice JRW Interface. 
	endif;
epilog
	delete tiArray;
end;</source>
        <Parameter name="_objSet" type="ObjectSet" usage="input"/>
    </JadeMethod>
