    <JadeMethod name="setForUpdate" id="04c5af38-7f81-42cd-98f4-1159d72c4438">
        <updating/>
        <source>setForUpdate ( _proxyDebtorType : CM_DebtorType) updating;
// ---------------------------------------------------------------------------
// Created:	3 April 2008 By Graeme Black cnwgb1
// ---------------------------------------------------------------------------

begin
	_proxyDebtorType.raiseExceptionIfNotTransient(method);
	self.raiseExceptionIfTransient(method);
	
	self.code := _proxyDebtorType.code;
	self.description:= _proxyDebtorType.description;
	self.myDefaultDebtor:= _proxyDebtorType.myDefaultDebtor;
	self.isNotAvailableForEntry := _proxyDebtorType.isNotAvailableForEntry;
	self.allDebtors.clear;
	_proxyDebtorType.allDebtors.copy(self.allDebtors);
	self.myRoot := app.myRoot;
end;</source>
        <Parameter name="_proxyDebtorType" type="CM_DebtorType"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="33e8e7c6-5a9b-431d-99f7-40562e946703">
        <updating/>
        <source>setProxy( _code : String; _description : String; _defaultDebtor: CM_Debtor; _theDebtors: CM_DebtorSet; _notAvailableForEntry : Boolean) updating;
// ---------------------------------------------------------------------------
// Created:	3 April 2008 By Graeme Black cnwgb1
// ---------------------------------------------------------------------------
begin
	self.code := _code;
	self.description := _description;
	self.myDefaultDebtor := _defaultDebtor;
	if  _theDebtors &lt;&gt; null then
		_theDebtors.copy(self.allDebtors);
	endif;
	self.isNotAvailableForEntry := _notAvailableForEntry;
end;
</source>
        <Parameter name="_code" type="String"/>
        <Parameter name="_description" type="String"/>
        <Parameter name="_defaultDebtor" type="CM_Debtor"/>
        <Parameter name="_theDebtors" type="CM_DebtorSet"/>
        <Parameter name="_notAvailableForEntry" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validateForCreate" id="e867ce6c-a591-472a-b3d2-eba9c6f00517">
        <source>validateForCreate();
// ---------------------------------------------------------------------------
// Created:	3 April 2008 By Graeme Black cnwgb1
// ---------------------------------------------------------------------------
begin
	if app.myRoot.allDebtorTypes[self.code] &lt;&gt; null then
		app.raiseCMException1(Debto_type_alrea_exist_canno_c,self.code, null,null);
	endif;
	if self.code.trimBlanks = null then
		app.raiseCMException(Debto_type_must_have_code_cann,null,null);
	endif;
	if self.code[1:3] = "SDT" then
		app.raiseCMException(Usedd_debto_type_codes_must_be, null,null);
	endif;
	if self.description.trimBlanks = null then
		app.raiseCMException(Debto_type_must_have_descr_can, null,null);
	endif;
end;
</source>
    </JadeMethod>
    <JadeMethod name="validateForDelete" id="4f9ecd19-2da6-4a06-813b-6c25b9b7fc1c">
        <source>validateForDelete();

/*
Date			Who		Reason
07 March 2012	cnwar2	Initial creation

*/
vars

	whereUsed : String;

begin
	// 07/03/2012 cnwar2 #28974
	if not self.allDebtorMaps.isEmpty then
		app.raiseCMException1(CannotDeleteTransMap, self.description, null, null);
		return;
	endif;
	
	//10 Nov 2020	NDL	TFS 50279
	if self.isUsedinConfig( whereUsed ) then
		app.raiseCMException2(ERR_CANNOT_DELETE, self.code, whereUsed, null, self);
	endif;

end;</source>
    </JadeMethod>
    <JadeMethod name="validateForUpdate" id="c86adfb5-9c2f-4334-836e-75db5cd152bf">
        <source>validateForUpdate();
// ---------------------------------------------------------------------------
// Created:	3 April 2008 By Graeme Black cnwgb1
// ---------------------------------------------------------------------------
vars
	aDebtorType : CM_DebtorType;
	whereUsed : String;
begin
	if self.code.trimBlanks = null then
		app.raiseCMException(Debto_type_must_code_cann_upda,null,null);
	endif;
	if self.description.trimBlanks = null then
		app.raiseCMException(Debto_type_must_descr_can_upda,null,null);
	endif;
	if self.code[1:3] = "SDT" then
		app.raiseCMException(Usedd_debto_type_codes_must_up,null,null);
	endif;
	aDebtorType := app.myRoot.allDebtorTypes[self.code];
	if aDebtorType &lt;&gt; null and aDebtorType &lt;&gt; self.pxyGetRealObject() then
		app.raiseCMException1(Debto_type_code_alrea_exi_upda, self.code,null,null);
	endif;
	
	//10 Nov 2020	NDL	TFS 50279
	if self.isNotAvailableForEntry then
		if self.isUsedinConfig( whereUsed ) then
			app.raiseCMException1(Not_make_not_availa_while, whereUsed, null, self);
		endif;
	endif;
	
end;
</source>
    </JadeMethod>
</Class>
