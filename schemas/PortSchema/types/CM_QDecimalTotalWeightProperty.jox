<Class name="CM_QDecimalTotalWeightProperty" id="832a372a-32b3-4f5c-91cc-87f271bb9d22">
    <superclass name="CM_QDecimalProperty"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="query"/>
    <JadeMethod name="create" id="5a7361e0-2c8b-4fd8-a677-4fc9c76739ea">
        <updating/>
        <source>create() updating;
// --------------------------------------------------------------------------------
// Created:		24 Janurary 2009 by cnwjo3
//
// Purpose:		add the necessary 'Operators' for the property
//
vars
	oper	: CM_QueryOperator;
begin
	//cnwjo3 CCMS 1028
	create oper as CM_QDecimalInRange persistent;
	self.allAllowedOperators.add(oper);

	//cnwjo3 CCMS 1028
	create oper as CM_QDecimalNotInRange persistent;
	self.allAllowedOperators.add(oper);
end;</source>
    </JadeMethod>
    <JadeMethod name="getControlTypeForOperator" id="109a88c6-99ab-4dd0-b494-1f9b0bcf701c">
        <source>getControlTypeForOperator(_op: CM_QueryOperator): Integer;
// --------------------------------------------------------------------------------
// Created:		24 November 2009 by cnwjo3
//
// Purpose:		Get the type of control for the Selector screen	
//
vars

begin
	if _op.isKindOf(CM_QDecimalInRange) or _op.isKindOf(CM_QDecimalNotInRange) then
		return QueryControl_ComboBox;
	endif;

	return inheritMethod(_op);
end;</source>
        <Parameter name="_op" type="CM_QueryOperator"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getValueForObject" id="8e6429ed-5ea1-491a-bd11-8a4b933638cf">
        <source>getValueForObject(_obj: Object; _op: CM_QueryOperator input): Any;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 08/05/2013	cnwdap1		Initial creation PAR #
// 18/02/2014	cnwdap1		PAR #33329 Correct measurement handling for selector queries
//
vars
	value 	: Decimal [23,10];
	measure	: CM_MeasurementType;

begin
	if self.myMeasurementType = null then
		measure := app.getDefaultMeasurementForType(Type_Weight);
		value := _obj.getPropertyValue(self.propertyName).Decimal;
		return app.convertMeasurementForDisplay(measure.shortName, value) &amp; Space &amp; measure.shortName;
	else																																// PAR #33329
		return app.convertMeasurementForDisplay(self.myMeasurementType.shortName, _obj.getPropertyValue(self.propertyName).Decimal);	// PAR #33329
	endif;
	return inheritMethod(_obj, _op);

epilog

end;</source>
        <Parameter name="_obj" type="Object"/>
        <Parameter name="_op" type="CM_QueryOperator" usage="input"/>
        <ReturnType type="Any"/>
    </JadeMethod>
    <JadeMethod name="setComboValues" id="470fc071-b4e5-4b99-a78e-abe2c3c98ebc">
        <source>setComboValues(_combo: ComboBox input; _params: CM_QueryCriteriaLineHolder; _queryOperator: CM_QueryOperator; _passport: CM_Passport);
// --------------------------------------------------------------------------------
// Created:		24 November 2009 by cnwjo3
//
// Purpose:		Set up combo box and see the list object of the combo box
//
vars
	weight		: CM_WeightRange;
	weightDict	: CM_WeightRangeByValueDict;
	measure		: CM_MeasurementType;							// PAR #31155
begin
	_combo.clear();
	//weightDict := app.myRoot.allWeightRanges;						// PAR #31155
	if self.myMeasurementType &lt;&gt; null then							// PAR #31155
		measure := self.myMeasurementType;							// PAR #31155
	else															// PAR #31155
		measure := app.getDefaultMeasurementForType(Type_Weight);	// PAR #31155
	endif;															// PAR #31155
	weightDict := measure.allWeightRanges;							// PAR #31155
	
	_combo.sorted := false;
	foreach weight in weightDict do
		_combo.itemObject[_combo.addItem(weight.lower.String &amp; "-" &amp; weight.value.String)] := weight;
	endforeach;

	if CM_QDecimalInRange.hasInstance(_queryOperator) then
		//_combo.listObject := weightDict[_queryOperator.CM_QDecimalInRange.searchValue.Integer];			// PAR #31155
		_combo.listObject := weightDict[measure, _queryOperator.CM_QDecimalInRange.searchValue.Integer];	// PAR #31155
	elseif CM_QDecimalNotInRange.hasInstance(_queryOperator) then  //this should be CM_QDecimalNotInRange (class not created yet);
		//_combo.listObject := weightDict[_queryOperator.CM_QDecimalNotInRange.searchValue.Integer];		// PAR #31155
		_combo.listObject := weightDict[measure, _queryOperator.CM_QDecimalNotInRange.searchValue.Integer];	// PAR #31155
	endif;
	
	_combo.sorted := true;
end;</source>
        <Parameter name="_combo" type="ComboBox" usage="input"/>
        <Parameter name="_params" type="CM_QueryCriteriaLineHolder"/>
        <Parameter name="_queryOperator" type="CM_QueryOperator"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="translateToDisplayValue" id="e4412dfa-fe27-412a-b948-6596bff81c03">
        <source>translateToDisplayValue(_value: Any): String;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 08/05/2013	cnwdap1		Initial creation PAR #31155 CCMS SFW 1321 Imperial Measurements
//
vars
	measure : CM_MeasurementType;
	value 	: String;

begin
	return inheritMethod(_value);
	measure := self.myMeasurementType;
	if measure = null then
		measure := app.getDefaultMeasurementForType(Type_Weight);
		return app.convertMeasurementForDisplay(measure.shortName, _value.Decimal) &amp; Space &amp; measure.shortName;
	else
		return measure.removeDecimalZeros(_value.String) &amp; Space &amp; measure.shortName;
	endif;

epilog

end;</source>
        <Parameter name="_value" type="Any"/>
        <ReturnType type="String"/>
    </JadeMethod>
</Class>
