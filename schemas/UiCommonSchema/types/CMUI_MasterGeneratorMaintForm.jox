        <source>doNext() protected, updating;
/* ---------------------------------------------------------------------------
Created:	13 August 2008	by cnwvu1

Purpose:	
   
Change Date		Who		Reason

------------------------------------------------------------------------------*/
vars

begin

	if self.doSave() then
	
		self.txtID.text				:= null;
		self.txtID.setFocus();
		//to keep all previous values
		/*self.txtDescription.text	:= null;
		self.cmbOperator.text		:= null;
		self.cmbISOType.text		:= null;
		self.cmbGeneratorType.text	:= null;
		self.txtWeight.text			:= null;
		self.lstTblStops.clearSelected() ;
		self.lstTblToDoTasks.clearSelected();
		self.tblDamage.init();*/
		
	endif;


end;</source>
        <access>protected</access>
    </JadeMethod>
