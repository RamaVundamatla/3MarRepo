<Class name="CM_QBooleanDocActionToDo" id="d7bf9d0c-ce35-4889-9ac4-e4e3b57fc013">
    <superclass name="CM_QBooleanMethod"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="query"/>
    <Constant name="PREFIX_NICE_NAME" id="ea14471f-e0c6-4a5d-9aa2-b03372e3a717">
        <source>'ToDo DA- '</source>
        <type name="String"/>
    </Constant>
    <Constant name="PREFIX_PROPERTY_NAME" id="b9efdf12-b4cf-4af7-921b-39e504526b9b">
        <source>'toDoDA- '</source>
        <type name="String"/>
    </Constant>
    <PrimAttribute name="toDoTaskCode" id="73e43e03-cddb-4dbd-bd75-46b60a248f2a">
        <embedded/>
        <type name="Integer"/>
        <access>readonly</access>
    </PrimAttribute>
    <JadeMethod name="getValueForObject" id="e7f3b9c1-1c40-4b55-8614-3643c665742d">
        <source>getValueForObject(_obj: Object; _op: CM_QueryOperator input): Any;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 November 2016	cnwndl1	Initial creation	TFS 3021 / 2419

*/

vars
	
begin

	return _obj.CM_TrackedItem.hasIncompleteDocAction( null, self.toDoTaskCode );
	
end;</source>
        <Parameter name="_obj" type="Object"/>
        <Parameter name="_op" type="CM_QueryOperator" usage="input"/>
        <ReturnType type="Any"/>
    </JadeMethod>
    <JadeMethod name="setup" id="5033d8f4-83df-42cc-af9d-2757f09c549e">
        <updating/>
        <source>setup(_task :CM_ToDoTaskDesc; _className :String)updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 November 2016	cnwndl1	Initial creation	TFS 3021 / 2419

*/

vars
	strDesc	:String;
	intCode	:Integer;
begin
	strDesc := _task.shortDescription;
	intCode	:= _task.code;

	if strDesc.length &gt;= 24 then
		strDesc := _task.shortDescription[1:21] &amp; '...';
	endif;
	
	self.set(self.PREFIX_NICE_NAME &amp; strDesc, self.PREFIX_PROPERTY_NAME &amp; intCode.String, _className);
	
	if self.toDoTaskCode &lt;&gt; intCode then
		self.toDoTaskCode := intCode;
	endif;
	
	self.setPerformanceRating( CM_QueryProperty.Simple );	// Simple	= '1', CollKey	= '2', Complex	= '3'
			
epilog

end;</source>
        <Parameter name="_task" type="CM_ToDoTaskDesc"/>
        <Parameter name="_className" type="String"/>
    </JadeMethod>
</Class>
