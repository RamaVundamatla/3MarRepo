    <JadeMethod name="translateForm" id="669b44df-5179-4542-8c7c-dc2d8c2f2757">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0006293, locale);
	btnCalendarYear.translateBubbleHelp(Xlat_0003787, locale);
	btnCalendarYear.translateCaption(Xlat_0003793, locale);
	btnCopy.translateBubbleHelp(Xlat_0003788, locale);
	btnCopy.translateCaption(Xlat_0003794, locale);
	btnDelete.translateBubbleHelp(Xlat_0003789, locale);
	btnDelete.translateCaption(Xlat_0003795, locale);
	btnEdit.translateBubbleHelp(Xlat_0003790, locale);
	btnEdit.translateCaption(Xlat_0003796, locale);
	btnNewCalendar.translateBubbleHelp(Xlat_0003791, locale);
	btnNewCalendar.translateCaption(Xlat_0003797, locale);
	btnNewDate.translateBubbleHelp(Xlat_0003792, locale);
	btnNewDate.translateCaption(Xlat_0003798, locale);
	mnuCopy.translateCaption(Xlat_0006294, locale);
	mnuDelete.translateCaption(Xlat_0006295, locale);
	mnuEdit.translateCaption(Xlat_0006296, locale);
	mnuInspect.translateCaption(Xlat_0006297, locale);
	mnuMain.translateCaption(Xlat_0006298, locale);
	mnuNewCalendar.translateCaption(Xlat_0006299, locale);
	mnuNewDate.translateCaption(Xlat_0006300, locale);
	mnuNewYear.translateCaption(Xlat_0006301, locale);
end;</source>
    </JadeMethod>
