    <JadeMethod name="setDescending" id="c6486cd1-0293-4205-be12-aced5ad9f4c2">
        <updating/>
        <source>setDescending( _value : Boolean ) updating;
// ---------------------------------------------------------------------------
// Created:     11 November 2008 by concms1
// Purpose:     CCMS SFW 1047 - Totals Only Lists
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 09/01/2009	cnwrl1		Stop exception when not actually doing any updating (CCMS SFW 1047 - Totals Only Lists)
// ---------------------------------------------------------------------------
vars
	
begin
	if self.descending = _value then	// because this is being called on lost focus when not real updating is being done.
		return;
	endif;
	
	self.raiseExceptionIfNotTransient(method);
	
	self.descending := _value;
epilog
	
end;</source>
        <Parameter name="_value" type="Boolean"/>
    </JadeMethod>
