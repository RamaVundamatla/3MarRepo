    <JadeMethod name="btnViewInclOne_click" id="bc0050dc-8e12-4fd5-ba86-db810996da85">
        <controlMethod name="CMUI_Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnViewInclOne_click(btn: Button input) updating;
// ---------------------------------------------------------------------------
// Created:     19 December 2000 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	entTableRow	: EntTableRow;
	row,
	col			: Integer;

begin

	if tblDef.selectedCount &gt; 0 then
		row := 1;
		col := 1;
		while tblDef.selectedNext(row, col) do
			entTableRow := tblDef.accessRow(row).itemObject.EntTableRow;
			self.addViewRow(entTableRow);
			if col &gt; 1 then
				// if you are on column 2 and click the button this was looping around until
				// loaded 32,000 entries, since selectedNext was finding the same entry everytime.
				row	:= row + 1;
				col := 1;
			endif;
		endwhile;
	endif;
	
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="checkDefName" id="13198789-400f-4b5f-955e-e66eb53c2922">
        <source>checkDefName(pName : String) : Boolean;
// ---------------------------------------------------------------------------
// Created:     19 December 2000 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	i			: Integer;
begin

	if pName = null then
		app.msgBox('You must enter a definition name', 'Error', MsgBox_OK_Only);
		return false;
	endif;

	if myCurrentDef = null then 
		if self.myEntTableDataRoot.allEntTableDefs.includesKey(pName) then
			app.msgBox('This definition name has already been used', 'Error', MsgBox_OK_Only);
			return false;
		endif;
	else
		if self.myCurrentDef.name &lt;&gt; pName and
		   self.myEntTableDataRoot.allEntTableDefs.includesKey(pName) then
			app.msgBox('This definition name has already been used', 'Error', MsgBox_OK_Only);
			return false;
		endif;
	endif;
	
	//check for spaces
	foreach i in 1 to pName.length do
		if pName[i] = ' ' then
			app.msgBox('No spaces permitted in definition names', 'Error', MsgBox_OK_Only);
			return false;
		endif;
	endforeach;
	return true;
	
end;</source>
        <Parameter name="pName" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="checkGroupEdition" id="8ad323db-47f9-4b78-a82d-c7536dec88db">
        <source>checkGroupEdition() : Boolean protected;
// ---------------------------------------------------------------------------
// Created:     19 May 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 30 Aug 2012	cnwcs5	par 30292 - use updateObjectEdition instead of updateEdition 
// ---------------------------------------------------------------------------
vars
	rtnCode	: Boolean;
begin

	rtnCode := false;

	exclusiveLock(self.myCurrentGroup);
	
	if self.myCurrentGroup.edition &lt;&gt; self.expectedGroupEdition then
		abortTransaction;
		app.msgBox('Someone else has updated this group.  Your changes will be lost', 'Error', MsgBox_OK_Only);
	else
		self.updateObjectEdition (self.myCurrentGroup);	// par 30292
		
		rtnCode := true;
	endif;

epilog
	return rtnCode;
	
end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="checkGroupName" id="f8e814a8-55bf-425b-bb0d-9255661f880c">
        <source>checkGroupName(pName : String output) : Boolean;
// ---------------------------------------------------------------------------
// Created:     19 December 2000 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	i	: Integer;
begin

//	pName := cmbGroup.text;
	read pName;
	cmbGroup.text := pName;
	
	if pName = null then
		app.msgBox('You must enter a group name', 'Error', MsgBox_OK_Only);
		return false;
	endif;

	if myCurrentDef = null then 
		if self.myEntTableDataRoot.allEntTableGroups.includesKey(pName) then
			app.msgBox('This group name has already been used', 'Error', MsgBox_OK_Only);
			return false;
		endif;
	else
		if self.myCurrentDef.name &lt;&gt; pName and
		   self.myEntTableDataRoot.allEntTableGroups.includesKey(pName) then
			app.msgBox('This group name has already been used', 'Error', MsgBox_OK_Only);
			return false;
		endif;
	endif;
	
	//check for spaces
	foreach i in 1 to pName.length do
		if pName[i] = ' ' then
			app.msgBox('No spaces permitted in group names', 'Error', MsgBox_OK_Only);
			return false;
		endif;
	endforeach;
	
	return true;
	
end;</source>
        <Parameter name="pName" type="String" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="checkViewName" id="7a0d4296-b57c-402e-9236-84e8b40e7f2c">
        <source>checkViewName(pName : String output) : Boolean;
// ---------------------------------------------------------------------------
// Created:     19 December 2000 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	i		: Integer;
begin
	read pName;
	//pName := cmbView.text;
	cmbView.text := pName;
	
	if pName = null then
		app.msgBox('You must enter a view name', 'Error', MsgBox_OK_Only);
		return false;
	endif;
	
	if self.myCurrentDef = null then
		app.msgBox('You must select a definition first', 'Error', MsgBox_OK_Only);
		return false;
	endif;

	if myCurrentView = null then 
		if self.myCurrentDef.allEntTableViews.includesKey(pName) then
			app.msgBox('This view name has already been used', 'Error', MsgBox_OK_Only);
			return false;
		endif;
	else
		if myCurrentView.name &lt;&gt; pName and
		   self.myCurrentDef.allEntTableViews.includesKey(pName) then
			app.msgBox('This view name has already been used', 'Error', MsgBox_OK_Only);
			return false;
		endif;
	endif;
	
	//check for spaces
	foreach i in 1 to pName.length do
		if pName[i] = ' ' then
			app.msgBox('No spaces permitted in view names', 'Error', MsgBox_OK_Only);
			return false;
		endif;
	endforeach;
	
	return true;
	
end;</source>
        <Parameter name="pName" type="String" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
