    <JadeMethod name="doTblDataContextMenu" id="8b3d4be2-c2d7-40e3-bff0-acf013e50aa4">
        <updating/>
        <source>doTblDataContextMenu(cntrl: Table input; conwin: Window input; mouse: Boolean; x: Integer; y: Integer): Boolean updating;
//----------------------------------------------------------------
//	Created:	10 May 2006	by Jason Chapman  (cnwjc2)
//  RBarr 14/7/2006 Audit menu - chg invisible to disabled
//----------------------------------------------------------------
vars
	snapShot	: CM_TISnapShot;
	
begin
	// cnwrl1 16/02/2009 - (CCMS SFW 1047 - Totals Only Lists)
	self.mnuSummarise.visible	:= false;	// default this menu level to invisible, makes sub-menu invisible.
	
	if app.isAllowedToInspect then
		self.mnuInspectSnapShot.visible := true;
	else
		self.mnuInspectSnapShot.visible := false;
	endif;
	self.mnuColLegend.visible := not self.isFromItemSelector(); // TFS 40336
	
	if self.isFromItemSelector() then // TFS 40336
		self.mnuAddCargo.visible := false; //jlgzm1 13/12/2018 TFS 42462
		self.mnuResetSnapShot.visible := true;
		self.mnuUpdareFromCargo.visible := true;
	endif;
	
	snapShot := self.tblData.allSelectedObjects.first.CM_TISnapShot;
	if self.tblData.allSelectedObjects.size = 1
	and snapShot.hasAudits then
		self.mnuViewAudits.userObject := self.tblData.allSelectedObjects.first;
//		self.mnuViewAudits.visible := true;
		self.mnuViewAudits.enabled := true;
	else
		self.mnuViewAudits.userObject := null;
//		self.mnuViewAudits.visible := false;
		self.mnuViewAudits.enabled := false;
	endif;
	
	if snapShot &lt;&gt; null and snapShot.myUserTISnapShot &lt;&gt; null and snapShot.myUserTISnapShot.ignore = true then
		mnuHideCargo.caption := 'Show Selected Cargo';
	else
		mnuHideCargo.caption := 'Hide Selected Cargo';
	endif;
	return self.showContextMenu(self.mnuSnapShotContext,cntrl,conwin,mouse,x, y);

end;</source>
        <Parameter name="cntrl" type="Table" usage="input"/>
        <Parameter name="conwin" type="Window" usage="input"/>
        <Parameter name="mouse" type="Boolean"/>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doTblDataRowColChange" id="15b3bf43-335f-4f57-aaf2-190fcead1fd5">
        <updating/>
        <source>doTblDataRowColChange(table: Table input) updating;
//----------------------------------------------------------------
//	Created:	12 May 2006	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	lines,
	row,
	rowIdx	: Integer;
	obj		: CM_TISnapShot;
	msg		: CM_Message;
begin
	row := table.row;
	
	if row &lt;= table.fixedRows then
		return;
	endif;
	
	self.tblInfo.rows := 1;
	obj := table.accessRow(row).itemObject.CM_TISnapShot;
	
	if obj.myUserTISnapShot = null then
		return;
	endif;

	foreach msg in obj.myUserTISnapShot.allChangeNotes do
		rowIdx := self.tblInfo.addItem(msg.getInfoTableString);
		lines := msg.text.getDelimiterCount(CrLf) + 1;
		self.tblInfo.rowHeight[rowIdx] := self.tblInfo.rowHeight[1] * lines;
	endforeach;

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doTblInfoContextMenu" id="a74dd645-5e96-444f-9971-a241836c0ae5">
        <updating/>
        <source>doTblInfoContextMenu(_cntrl: Table input; _conwin: Window input; _mouse: Boolean; _x: Integer; _y: Integer) updating;

//  RBarr 14/7/2006 Hide Column Organiser menu for info table

begin
	mnuColumnOrganiser.visible := false;
	inheritMethod(_cntrl, _conwin, _mouse, _x, _y);
end;</source>
        <Parameter name="_cntrl" type="Table" usage="input"/>
        <Parameter name="_conwin" type="Window" usage="input"/>
        <Parameter name="_mouse" type="Boolean"/>
        <Parameter name="_x" type="Integer"/>
        <Parameter name="_y" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="handleNotification" id="89599633-359d-4254-a32f-024e29153547">
        <updating/>
        <source>handleNotification(eventType: Integer; theObject: Object; eventTag: Integer; userInfo: Any) updating;
//----------------------------------------------------------------
//	Created:	16 May 2006	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	tiSnapShot	: CM_TISnapShot;
	rowIdx		: Integer;
	bckColour	: Integer;
begin

	if CM_TISnapShot.hasInstance(theObject) then
		tiSnapShot := theObject.CM_TISnapShot;
	endif;
	
	if eventType = Object_Update_Event then
		if tiSnapShot &lt;&gt; null then
			if self.tblData.findObjectInRow(tiSnapShot, rowIdx) then
				if global.isValidObject(self.mySummaryItem)
				and (not self.mySummaryItem.allSnapShots.includes(tiSnapShot)) then
					self.tblData.removeItem(rowIdx);
					return;
				endif;
				self.tblData.accessCell(rowIdx, 1).text := tiSnapShot.getAttributeStringForDefArray(self.tblData.allTblDataEntRows);
			else
				rowIdx := self.tblData.addItemObject(tiSnapShot, tiSnapShot.getAttributeStringForDefArray(self.tblData.allTblDataEntRows));
			endif;			
			
			if not self.isFromItemSelector() then // TFS 40336
			
				bckColour := tiSnapShot.getDisplayRowColour();
				if bckColour &gt; 0 then
					self.tblData.accessRow(rowIdx).backColor := bckColour;
				endif;
			endif;
		endif;
	endif;
	
end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
        <Parameter name="userInfo" type="Any"/>
    </JadeMethod>
