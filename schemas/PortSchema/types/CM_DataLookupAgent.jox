    <JadeMethod name="resolveProduct" id="4a2cc648-4b2e-488f-ae6c-9e2343247555">
        <source>resolveProduct(_propertyName : String; _key : String) : Object;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 January 2026	naviv1	Initial creation

*/

vars
	cargoType : CM_CargoType;
begin
	if _propertyName = CM_Product::code.name then
		cargoType := self.proxyObject.getPropertyValue(CM_Product::myCargoType.name).CM_CargoType;
		return cargoType.allProducts[null,_key];
