    <JadeMethod name="trxUpdateYABlock" id="77839e91-2836-4ef5-979b-95c9bc094c33">
        <updating/>
        <source>trxUpdateYABlock(_proxyYABlock: CM_YABlock input; _yaBlock: CM_YABlock io; _passport : CM_Passport input) updating;
vars
	yardAllocation: CM_YardAllocation;
	expectedEdition	: Integer;
begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	_proxyYABlock.raiseExceptionIfNotProxy(method);
	app.setContinueCMExceptions(true);
	
	beginTransaction;

	_proxyYABlock.pxyGetRealObjectAndEdition(_yaBlock, expectedEdition);
	if _yaBlock = null then	
		app.raiseCMException1(ProxyMgrCannotLocateReal, CM_YABlock.name, null, null);
		return;
	endif;
	
	reserveLock(_yaBlock);
	
	if _passport.noErrors() and _yaBlock.edition &lt;&gt; expectedEdition then
		app.raiseCMException1(ObjectUpdatedByAnotherUserSave, "Yard Allocation Location", null, null);
		return;
	endif;
	
	app.myUtilityUA.utlUpdateYABlock(_proxyYABlock, _yaBlock, _passport);
	
epilog
	self.finaliseActivityWithPassport(_passport);
end;</source>
        <Parameter name="_proxyYABlock" type="CM_YABlock" usage="input"/>
        <Parameter name="_yaBlock" type="CM_YABlock" usage="io"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxUpdateYABlockGroup" id="04d9855c-5d6f-4d82-854e-2f81697ca4b5">
        <updating/>
        <source>trxUpdateYABlockGroup(_proxyYABlockGroup: CM_YABlockGroup input; _yaBlockGroup: CM_YABlockGroup io; _passport : CM_Passport input) updating;
vars
	yardAllocation: CM_YardAllocation;
	expectedEdition	: Integer;
begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	_proxyYABlockGroup.raiseExceptionIfNotProxy(method);
	app.setContinueCMExceptions(true);
	
	beginTransaction;

	_proxyYABlockGroup.pxyGetRealObjectAndEdition(_yaBlockGroup, expectedEdition);
	if _yaBlockGroup = null then	
		app.raiseCMException1(ProxyMgrCannotLocateReal, CM_YABlock.name, null, null);
		return;
	endif;
	
	reserveLock(_yaBlockGroup.myYardAllocationIn);
	
	if _passport.noErrors() and _yaBlockGroup.edition &lt;&gt; expectedEdition then
		app.raiseCMException1(ObjectUpdatedByAnotherUserSave, "Yard Allocation Group", null, null);
		return;
	endif;
	
	app.myUtilityUA.utlUpdateYABlockGroup(_proxyYABlockGroup, _yaBlockGroup, _passport);
	
epilog
	self.finaliseActivityWithPassport(_passport);
end;</source>
        <Parameter name="_proxyYABlockGroup" type="CM_YABlockGroup" usage="input"/>
        <Parameter name="_yaBlockGroup" type="CM_YABlockGroup" usage="io"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxUpdateYABlockOrder" id="f7f2ab2f-d97d-4b91-bcb1-329845dc9ac1">
        <updating/>
        <source>trxUpdateYABlockOrder(_proxyYA: CM_YardAllocation; _yaBlockOrder: CM_YABlockArray input; _yaGroupOrder: CM_YABlockGroupArray input; _isIn, _isOut: Boolean; _passport : CM_Passport input) updating;
// --------------------------------------------------------------------------------
// Created:		27 Ayg 2008 by cnwdw1
//
// Purpose:		Updates the IN/OUT order of the YABlocks.
//
// Parameters:	_proxyYA - A proxy reference to a YardAllocation.
//				_yaBlockOrder - The new block order. This must reference all the existing yaBlocks in the ya
//				_isIn - True for order IN otherwise false
//				_passport - A reference to the user's Passport object.
//
// Returns:		Nothing
vars
	yardAllocationObj	: CM_YardAllocation;
	expectedEdition		: Integer;
	aTA : CM_TerminalArea;
	tmpTerm : CM_Terminal;
	group, pGroup: CM_YABlockGroup;
	groups: CM_YABlockGroupArray;
begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	_proxyYA.raiseExceptionIfNotProxy(method);
	app.setContinueCMExceptions(true);
	
	beginTransaction;

	_proxyYA.pxyGetRealObjectAndEdition(yardAllocationObj, expectedEdition);
	if yardAllocationObj = null then	
		app.raiseCMException1(ProxyMgrCannotLocateReal, CM_YardAllocation.name, null, null);
		return;
	endif;
	
	exclusiveLock(yardAllocationObj);
	
	if _passport.noErrors() and yardAllocationObj.edition &lt;&gt; expectedEdition then
		app.raiseCMException1(ObjectUpdatedByAnotherUserSave, "Yard Allocation", null, null);
		return;
	endif;

	if _passport.noErrors() then
		app.myUtilityUA.myUpdateAuditAgent.audUpdateGeneric(yardAllocationObj, true);
	endif;

	// Collect the real groups
	create groups transient;
	yardAllocationObj.getGroups(groups);
	
	// Clear the order coolections
	if _isIn then
		yardAllocationObj.allYABlocksIn.clear();
		if _yaGroupOrder = null then
			yardAllocationObj.allYABlockGroupsIn.first.allYABlocksIn.clear();
		else
			yardAllocationObj.allYABlockGroupsIn.clear();
			foreach group in _yaGroupOrder do
				foreach pGroup in groups where pGroup.description = group.description do   // Out and IN have same list of groups
					pGroup.allYABlocksIn.clear();
				endforeach;
			endforeach;
		endif;
	endif;
	if _isOut then
		yardAllocationObj.allYABlocksOut.clear();
		if _yaGroupOrder = null then
			yardAllocationObj.allYABlockGroupsIn.first.allYABlocksOut.clear();
		else
			yardAllocationObj.allYABlockGroupsOut.clear();
			foreach group in _yaGroupOrder do
				foreach pGroup in groups where pGroup.description = group.description do   // Out and IN have same list of groups
					pGroup.allYABlocksOut.clear();
				endforeach;
			endforeach;
		endif;
	endif;
	
	// Update the Order collections
	if _isIn then
		_yaBlockOrder.copy(yardAllocationObj.allYABlocksIn);
		if _yaGroupOrder = null then
			_yaBlockOrder.copy(yardAllocationObj.allYABlockGroupsIn.first.allYABlocksIn);
		else
			foreach group in _yaGroupOrder do
				foreach pGroup in groups where pGroup.description = group.description do   // Out and IN have same list of groups
					group.allYABlocksIn.copy(pGroup.allYABlocksIn);
					yardAllocationObj.allYABlockGroupsIn.add(pGroup);
				endforeach;
			endforeach;
		endif;
	endif;
	if _isOut then
		_yaBlockOrder.copy(yardAllocationObj.allYABlocksOut);
		if _yaGroupOrder = null then
			_yaBlockOrder.copy(yardAllocationObj.allYABlockGroupsOut.first.allYABlocksOut);
		else
			foreach group in _yaGroupOrder do
				foreach pGroup in groups where pGroup.description = group.description do   // Out and IN have same list of groups
					group.allYABlocksOut.copy(pGroup.allYABlocksOut);
					yardAllocationObj.allYABlockGroupsOut.add(pGroup);
				endforeach;
			endforeach;
		endif;
	endif;
	
	updateObjectEdition(yardAllocationObj);
	
	if _passport.noErrors() then
		app.myUtilityUA.myUpdateAuditAgent.audUpdateGeneric(yardAllocationObj, false);

		// ### NOTES
		aTA	:=	yardAllocationObj.allTerminalAreas.first();
		
		if aTA &lt;&gt; null then
			tmpTerm	:=	aTA.myTerminal;
			tmpTerm.causeEvent(tmpTerm.getTerminalEvent(Event_YardAllocationUpdate), false, yardAllocationObj);
		endif;
	endif;


epilog
	delete groups;
	self.finaliseActivityWithPassport(_passport);
end;</source>
        <Parameter name="_proxyYA" type="CM_YardAllocation"/>
        <Parameter name="_yaBlockOrder" type="CM_YABlockArray" usage="input"/>
        <Parameter name="_yaGroupOrder" type="CM_YABlockGroupArray" usage="input"/>
        <Parameter name="_isIn" type="Boolean"/>
        <Parameter name="_isOut" type="Boolean"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
