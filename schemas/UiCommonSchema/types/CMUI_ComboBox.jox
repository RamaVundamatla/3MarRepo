        <source>displayEntry(combobox: ComboBox input; obj: Any; lstIndex: Integer): String updating, clientExecution;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 Aug 2015	cnwkpd1	Initial creation


*/

vars

begin
	return inheritMethod(combobox, obj, lstIndex);

epilog

end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
        <Parameter name="obj" type="Any"/>
