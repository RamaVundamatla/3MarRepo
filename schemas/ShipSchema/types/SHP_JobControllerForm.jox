    <JadeMethod name="tblCranes_contextMenu" id="8552d645-13c9-4146-9a1a-221e3113f56a">
        <controlMethod name="Table::contextMenu"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblCranes_contextMenu(table: Table input; conwin: Window input; mouse: Boolean; x: Integer; y: Integer):Boolean updating;
/*

Purpose:			


Return Value:		


Date		Who		Reason
07 August 2007	cnwer1	Initial creation - PAR#xxxx

*/
vars


	xLeft, 
	yTop : Real;
		crane :  CM_Crane;
	row,column : Integer;
begin	

	xLeft := x;
	yTop := y;
	table.getCellFromPosition(x,y,row,column);
	if row &gt; 1 and row &lt;= table.rows then
		crane:=table.accessRow(row).itemObject.CM_Crane;
	endif;

	conwin.windowToScreen(xLeft, yTop);
	self.screenToWindow(xLeft, yTop);   // convert x, y relative to form
	
	self.resetJobMenuItems;
	self.setupContextMenu(null,crane,null);	
//	self.mnuShowInJobOps.visible := true;
	self.popupMenu(mnuContextMenu, xLeft.Integer, yTop.Integer);	

	
	return true;

epilog

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="conwin" type="Window" usage="input"/>
