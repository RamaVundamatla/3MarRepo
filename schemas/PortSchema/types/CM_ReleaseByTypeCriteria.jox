Return Value:		

Date		Who		Reason
11 June 2015	cnwndl1	Initial creation

*/

vars

begin

	if self.myReserveSelection = null then
		app.raiseCMException(Reserve_selecti_referen_not, null, null);
	endif;
	
	inheritMethod();

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="validateTransient" id="f31af87a-08ce-46ae-a0dd-07407beb6cce">
        <source>validateTransient():String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 June 2015	cnwndl1	Initial creation

*/

vars

begin

	if self.allCriteria.isEmpty then
		return app.getErrorString(No_Criteria_values_selected);
	endif;
	
	if self.myReserveSelection = null then
		return app.getErrorString(Reserve_selecti_referen_not);
	endif;
	
	return null;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
