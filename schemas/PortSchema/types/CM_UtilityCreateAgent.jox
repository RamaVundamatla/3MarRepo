	pNewInvLineDescMapping.setForCreate(pProxyInvLineDescMapping);
	
	if _passport.noErrors then  // 09/01/2017 cnwma1 TFS #2712
		self.myCreateAuditAgent.audCreateGeneric(pNewInvLineDescMapping);
	endif;

	if _passport.noErrors then
		_passport.myTerminal.causeEvent(_passport.myTerminal.getTerminalEvent(EVENT_MAPPING_CREATE),false,pNewInvLineDescMapping);
	endif;

end;</source>
        <Parameter name="pProxyInvLineDescMapping" type="CM_InvoiceLineDescMapping"/>
