    <JadeMethod name="getQuantitiesInCargoTotal" id="894d2944-d4a0-4c20-9780-7c99e85688dd">
        <source>getQuantitiesInCargoTotal() : Integer;
// Created by 	cnwsh3
// Date 		17 September 2009
// Implemented version: JMT 7.7.3
// Date  		User  		Change
// 17/09/2009 	cnwsh3 		CCMS SFW1044 PARXXXX - AMS changes
// Give a cumulative total of the quantity values for cargo items for a BOL 
// That is, for each cargo item in the ti collection, sum the CM_TrackedItem.quantity field.
vars
	ti 		: CM_TrackedItem;
	total 	: Integer;
begin
	foreach ti in self.allTrackedItems do
		total := total + ti.quantity;
	endforeach;
	
	return total;
epilog
end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getRoot" id="053e7ce7-19d0-466d-8c99-3bdab45c9d59">
        <source>getRoot(): CM_Root;
//----------------------------------------------------------------
//	Created:	29 December 2003	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
//	Use this to get Root if your method might be used in the Report Writer
//----------------------------------------------------------------
vars

	tmpRoot	: CM_Root;

begin

	// try getting root from self first, only way if called from report writer (no app)
	if self.myTerminal &lt;&gt; null then
		tmpRoot := self.myTerminal.myRoot;
	endif;
	
	if tmpRoot = null then
		tmpRoot := app.myRoot;
	endif;
	
//	if tmpRoot = null then
//		return null;
//	endif;

	return tmpRoot;

end;</source>
        <ReturnType type="CM_Root"/>
    </JadeMethod>
    <JadeMethod name="getStopByID" id="11c3d978-73cd-4b01-8eb3-3a553948e0a7">
        <source>getStopByID(_aStop : Integer) : CM_Stops;
// ---------------------------------------------------------------------------
// Created:		May 2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
begin
	if app.myRoot.allStopsTable[_aStop] = null then
		return null;
	endif;
	return self.allStops[_aStop];
end;</source>
        <Parameter name="_aStop" type="Integer"/>
        <ReturnType type="CM_Stops"/>
    </JadeMethod>
    <JadeMethod name="getStopByIDAsAtDate" id="c6201930-2e1f-4fd4-a42b-7be78ea062e9">
        <source>getStopByIDAsAtDate( _stopID : Integer; _asAtDate : Date ) : CM_Stops;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 February 2015	cnwndl1	Initial creation	Par 35426

*/

vars
	allStops	: CM_StopsByIdDict;
	
begin
	if _stopID = null or app.myRoot.allStopsTable[_stopID] = null then
		return null;
	endif;
	
	// Establish if the required stop exists for this tracked item as at the date supplied.
	// A stop can exist which is not active as at today but will be in the future,
	// this is case when the stops clearanceExpiryDate is greater than today.
	create allStops transient;
	self.getAllActiveStopsAsAtDate(allStops, _asAtDate);		// _asAtDate of null means as at today
	
	return allStops[_stopID];
epilog
	delete allStops;
end;
</source>
        <Parameter name="_stopID" type="Integer"/>
        <Parameter name="_asAtDate" type="Date"/>
        <ReturnType type="CM_Stops"/>
    </JadeMethod>
    <JadeMethod name="getStopClearanceExpiry" id="b635a1ec-6d0d-492e-96db-eb954ce23292">
        <source>getStopClearanceExpiry( _stopId : Integer) : Date;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 January 2015	cnwndl1	Initial creation	Par 35426

*/

vars

	theStop : CM_Stops;
	
begin

	theStop := self.allStops[_stopId];

	if theStop &lt;&gt; null then
		return theStop.clearanceExpiryDate;
	endif;
	
	return null;
	
epilog

end;</source>
        <Parameter name="_stopId" type="Integer"/>
        <ReturnType type="Date"/>
    </JadeMethod>
    <JadeMethod name="getStopsCodes" id="105df76e-b8a3-4d21-872d-e2ea641c4144">
        <source>getStopsCodes(): String;
//----------------------------------------------------------------
//	Created:	7/10/2008 cnwsh3
//
//  Implemented: 7.6.3
//----------------------------------------------------------------
/*

Date		Who		Reason
16 Feb 2009	cnwkpd1	PAR #18914 - Rework to always use app.getMyUser

*/

vars
	tStr			: String;
	aStop			: CM_Stops;
	theStopTable	: CM_StopsTable;
	user			: CM_User;
	term			: CM_Terminal;
//	ut				: CM_UserTerminal;

begin
	term := self.myTerminal;
	user := app.getMyUser;

	// Don't return anything if User is not set up
	if user &lt;&gt; null then
		foreach aStop in self.allStops do
			theStopTable := self.getRoot.allStopsTable[aStop.id];
			
			if not user.canViewStop(term, theStopTable) then
				continue;
			endif;
			
			tStr := tStr &amp; " " &amp; theStopTable.code;
		endforeach;
	endif;
	
	return tStr;
	
	
epilog
	

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getTICollectionForTerminal" id="7d91b0ef-b430-4e4c-910c-b9cbb99bf16f">
        <source>getTICollectionForTerminal(_terminal : CM_Terminal) : Collection;
// ---------------------------------------------------------------------------
// Created:     07 May 2003 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	bolTerminal	: CM_BOLTerminal;
	coll		: Collection;

begin

	bolTerminal := self.allBOLTerminals[_terminal];
	if bolTerminal &lt;&gt; null then
		coll := bolTerminal.allTrackedItems;
	else
		coll := self.allTrackedItems;
	endif;
	
	return coll;

end;</source>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <ReturnType type="Collection"/>
    </JadeMethod>
