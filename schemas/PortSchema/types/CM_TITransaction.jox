    <JadeMethod name="setMyTIforTranshipDelete" id="ef9d5237-72c4-4cb8-9f71-702d14ce5662">
        <updating/>
        <source>setMyTIforTranshipDelete(_ti : CM_TrackedItem) updating;
// ---------------------------------------------------------------------------
// Created:     09 January 2007 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	tmpOrderNo	: Integer;
	invLine : CM_InvoiceLine;

begin

	// remove from current dict first
	self.myTrackedItem := null;
	
	tmpOrderNo	:= self.orderNo;
	while _ti.allTransactions.includesKey(self.dateTime, tmpOrderNo) do
		tmpOrderNo := tmpOrderNo + 1;
	endwhile;
	self.orderNo := tmpOrderNo;

	self.myTrackedItem := _ti;
	
	// always ensure that the Transaction and invoice line are in-sync
	foreach invLine in self.allInvoiceLines discreteLock do
		invLine.setTrackedItemOnly(_ti);
	endforeach;
end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
    </JadeMethod>
