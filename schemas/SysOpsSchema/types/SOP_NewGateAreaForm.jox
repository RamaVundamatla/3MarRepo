    <JadeMethod name="doCancel" id="315dec29-65f3-4cd1-b5e3-402e17215c87">
        <updating/>
        <source>doCancel() updating;
// ---------------------------------------------------------------------------
// Created:     24 June 2009 by concms1
// Purpose:     CCMS 1061 - Gate Config Changes  
// Parameters:  None
