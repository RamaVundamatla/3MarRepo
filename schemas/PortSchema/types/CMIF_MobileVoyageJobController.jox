    <JadeMethod name="moveUnPlanTi" id="238e6abe-0bb4-46d1-a2d6-94a3b29d0c45">
        <source>moveUnPlanTi( _trackedItem : CM_TrackedItem ): Boolean;
/*
Purpose:			
Date				Who			Reason
JULY 2015		CNWAB1		Initial creation
*/

vars
	wle : CM_WorkListEntry;
	wlesWithWarnings,	
	wleArray : CM_WLEArray;
	result	: Integer;
begin

	create wleArray transient;
	create wlesWithWarnings transient;
	
	if _trackedItem.myPrimaryQueuedLocation &lt;&gt; null then
		foreach wle in _trackedItem.allWorklistEntries where wle.myFutureMove &lt;&gt; null do	
			wleArray.add(wle);
		endforeach;
			app.myTrxUA.trxUpdateWLEsUnqueue(wleArray, wlesWithWarnings, app.myPassport);
			if app.myPassport.trxCompletedOK then
				return true;
			else
				return false;
			endif;
	endif;
	
	return true;
	
epilog

	delete wlesWithWarnings;
	delete wleArray;
end;</source>
        <Parameter name="_trackedItem" type="CM_TrackedItem"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="movedischargeToGroundTrx" id="0f9eea67-417c-41d5-a8a1-13e711f70d4c">
        <source>movedischargeToGroundTrx(	_groundOption : Integer;	
						_ti : CM_TrackedItem input;
						groundLocation : CM_LocationsController input;
						_job : CM_VoyageJob;
						_wle : CM_WorkListEntry input;
						_newId : String;
						_quantity : Integer;
						_weight : Decimal
						):Boolean;

/*
Purpose:			
Date				Who			Reason
JUNE 2015		CNWAB1		Initial creation
*/

vars
	
	newId : String;
	quantity : Integer;
	result : Integer;
	isSplit : Boolean;
	msg : String;
	weight : Decimal [16,4];
	doSplit : Boolean;

begin


	app.myTrxUA.trxLanderDischargeToGround(_groundOption, _ti, groundLocation, _job, _wle, app.myPassport);
	if app.myPassport.trxCompletedOK then
		app.myPassport.clearErrorsWarnings();
		return true;
	else
