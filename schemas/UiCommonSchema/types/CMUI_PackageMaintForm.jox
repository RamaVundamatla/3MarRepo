    <JadeMethod name="tblDataDisplayRow" id="6734977a-eac5-4570-a1c3-31724e50ef89">
        <source>tblDataDisplayRow(_package : CM_Package; _isAdd : Boolean);
//--------------------------------------------------
// Created:	06 May 2005 By: cnwgd1
//--------------------------------------------------
vars
	str : String;
	idx : Integer;
	theObject : CM_Package;
	theRow	: Integer;
begin
		
	str := _package.getAttributeStringForDefArray(self.tblData.allTblDataEntRows);
	
	if _isAdd then
		idx := self.tblData.addItemObject(_package, str);
		return;
	endif;
	
	theObject	:= _package;
	theRow		:= self.tblData.fixedRows + 1;
	if self.tblData.findObjectInRow(theObject, theRow) then
		if theRow &lt;= self.tblData.fixedRows then
			return;
		endif;
		self.tblData.removeItem(theRow);
		self.tblData.addItemAt(str, theRow);
		
		self.tblData.accessRow(theRow).itemObject := theObject;		// 10/05/2010 cnwar2 #22273
		self.tblData.accessedRow.selected := true;					// 10/05/2010 cnwar2 #22273
		self.displayExtraInfo();									// 10/05/2010 cnwar2 #22273
	else
		idx := self.tblData.addItemObject(_package, str);
	endif;

//	self.tblDataDisplayColourColumn(idx, _voyage.colour);
			
end;</source>
        <Parameter name="_package" type="CM_Package"/>
        <Parameter name="_isAdd" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="tblData_contextMenu" id="9762be38-de7a-46e3-956d-710281439e8d">
        <controlMethod name="Table::contextMenu"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblData_contextMenu(table: Table input; conwin: Window input; mouse: Boolean; x: Integer; y: Integer):Boolean updating;
// -------------------------------------------
// Created 30 November 2005 by cnwdvb1
// -------------------------------------------
vars

begin

	if app.isAllowedToInspect() then
		self.mnuInspectObj.visible := true;
	else
		self.mnuInspectObj.visible := false;
	endif;
	return self.showContextMenu(self.mnuContextTbl, table, conwin, mouse, x, y);


end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="conwin" type="Window" usage="input"/>
        <Parameter name="mouse" type="Boolean"/>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="tblData_dblClick" id="aad9e564-3420-4428-8bb0-fd3624cc695f">
        <controlMethod name="CM_DataTable::dblClick"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblData_dblClick(table: Table input) updating;
// -------------------------------------------
// Created 30 November 2005 by cnwdvb1
// -------------------------------------------
vars

begin


	if table.row &gt; table.fixedRows then // ### JIRA 35466
		if not app.myCurrentUserCan(null, self.permissionMaint) then // TFS 2101 CNWAB1
			return;
		endif;
		
		self.openPackageConfigForm(true);
		return;
	endif;

	 // ### JIRA 35466 29JUL2025 NAVAB1 column sorting
	if table.sortColumn[1] &gt; 0 then
		table.accessCell(1,table.sortColumn[1]).fontBold := false;
	endif;

	table.CM_DataTable.resortTableByColumn(table.column);

	table.accessCell(1,table.column).fontBold := true;
	
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="tblData_rowColumnChg" id="9f402308-e6e5-40f6-bea8-a54762a638cd">
