    <JadeMethod name="setProxyFromObject" id="545b7e2f-e659-4806-83d0-fa7b8352e3d6">
        <updating/>
        <source>setProxyFromObject(_realTrackedItem: CM_TrackedItem) updating;
/*

Purpose:			Include the cargo OID in the response to make migration easier for PNL

Parameters:			

Return Value:		

Date					Who		Reason
25 September 2024		navmd1	Initial creation TFS 64610

*/

vars

begin
	inheritMethod(_realTrackedItem);
	
	self.oid := _realTrackedItem.getOidAsString();

epilog

end;</source>
        <Parameter name="_realTrackedItem" type="CM_TrackedItem"/>
    </JadeMethod>
</Class>
