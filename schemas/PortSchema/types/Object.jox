        <ReturnType type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="theConfigKey" id="a021b4c0-6654-4be9-8531-ec0858d74eb7">
        <source>theConfigKey() : String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
08 April 2009	cnwjk3	Initial creation

*/

vars
	str: String;
	property: Property;
begin
	property := self.class.findProperty("code");
	if property = null then
		property := self.class.findProperty("id");
	endif;
	if property = null then
		property := self.class.findProperty("type");
	endif;
	if property = null then
		property := self.class.findProperty("name");
	endif;
	if property = null then
		property := self.class.findProperty("description");
	endif;
	if property = null then
		property := self.class.findProperty("label");
	endif;
	if property = null then
		property := self.class.findProperty("createdTime");
	endif;
	if property = null then
		str := self.getInstanceIdForObject(self).String;
		if class &lt;&gt; CM_Root then
			app.writeLog("no key for "&amp;self.class.name, 0);
		endif;
	else
		str := self.getPropertyValue(property.name).String.trimBlanks();
	endif;
	return str; 
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="theKeyForJMT" id="8204b089-54f9-4aa2-9ca1-1c14f0b366cc">
        <source>theKeyForJMT() : String;
// ----------   ----------  --------------------------------------------------
// Created		6 April 2006		cnwrs2
//
// Purpose:     reimplement for indivual classes as necassary
//				the default action is to find something to be the key
//			    this meyjod and its implementors MUST be the same in PortLoadSchema
// ----------   ----------  --------------------------------------------------

vars
	str: String;
	property: Property;
begin
	property := self.class.findProperty("code");
	if property = null then
		property := self.class.findProperty("id");
	endif;
	if property = null then
		property := self.class.findProperty("type");
	endif;
	if property = null then
		property := self.class.findProperty("name");
	endif;
	if property = null then
		property := self.class.findProperty("description");
	endif;
	if property = null then
		property := self.class.findProperty("label");
	endif;
	if property = null then
		property := self.class.findProperty("createdTime");
	endif;
	if property = null then
		str := self.getInstanceIdForObject(self).String;
		if class &lt;&gt; CM_Root then
			app.writeStatement( "no key for "&amp;self.class.name);
		endif;
	else
		str := self.getPropertyValue(property.name).String.trimBlanks();
	endif;
	return str; 
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
