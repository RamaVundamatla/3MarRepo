    <JadeMethod name="connect" id="a9abe127-d5ba-48b2-a6c3-aee49cbd37d9">
        <updating/>
        <source>connect(server : JadeDotNetType input) : Boolean updating;
/*

Purpose:			Connect to email receive server

Parameters:			NONE

Return Value:		Boolean	Represents whether connection was successful

Date				Who		Reason
02 February 2022	navpw1	Initial creation TFS: 51526
18 January 2024		navmd1	TFS 55021 EA Mail Tidyup and Refactor
22 March 2024		navmd1	TFS 63103 Add additional logging to Connect

*/

vars
	execptionOccurred : Boolean;
	
begin
	on Exception do self.handleExceptionsExt(exception, execptionOccurred);
	app.writeLog(method.qualifiedName, LogTRACE);
	
	self.getMailHelper.connectToMailServer(self.mailClient, server, self.logFileName, app.logLevel);
	
	return not execptionOccurred;
end;</source>
        <Parameter name="server" type="JadeDotNetType" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="convertAuthFromOCXtoDotNet" id="99ecf68c-1ac1-41e8-848a-e0cc5e166c23">
        <source>convertAuthFromOCXtoDotNet(_value : Integer) : Integer;
/*

Purpose:			Converts Auth OCX constants to Dot Net Constants

Parameters:			_value	Integer	Value to convert

Return Value:		Integer	The converted value

Date		Who		Reason
18 February 2022	navpw1	Initial creation TFS: 51526
18 October 2022		NAVSP1  ChangeRequest 55021: MTN - OAuth Enhancements - Refactor calls to EASMTPMail
22 January 2024		navmd1	TFS 55021 EA Mail Tidyup and Refactor
*/

begin
	if _value = BGP_EmailSendRequest.AUTH_NONE then
		return EAGetMailSupport.SmtpAuthType_AuthAuto;
		
	elseif _value = BGP_EmailSendRequest.AUTH_LOGIN then
		return EAGetMailSupport.SmtpAuthType_AuthLogin;
		
	elseif _value = BGP_EmailSendRequest.AUTH_NTLM then
		return EAGetMailSupport.SmtpAuthType_AuthNTLM;
	
	elseif _value = BGP_EmailSendRequest.AUTH_CRAM_MD5 then
		return EAGetMailSupport.SmtpAuthType_AuthCRAM5;
		
	elseif _value = BGP_EmailSendRequest.AUTH_PLAIN then
		return EAGetMailSupport.SmtpAuthType_AuthPlain;
		
	elseif _value = BGP_EmailSendRequest.AUTH_MSN then
		return EAGetMailSupport.SmtpAuthType_AuthMSN;
		
	else
		return -1; //We have invalid settings
		
	endif;

end;</source>
        <Parameter name="_value" type="Integer"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="convertRetSSLFromOCXtoDotNet" id="1d4ad999-948f-42fd-9d65-1ccbdffa03ca">
        <source>convertRetSSLFromOCXtoDotNet(_value : Integer) : Integer;
/*

Purpose:			Converts Return SSL OCX constants to Dot Net Constants

Parameters:			_value	Integer	Value to convert

Return Value:		Integer	The converted value

Date		Who		Reason
18 February 2022	navpw1	Initial creation TFS: 51526

*/
	
begin
	//Convert BGP_EmailSendRequest Constant to EASendSmtpServer ConnectType Constant as they have different numbers
	if _value = BGP_EmailSendRequest.SSL_NONE then
		return -1;
		
	elseif _value = BGP_EmailSendRequest.SSL_DIRECT then
		return EAGetMailSupport.SSLConnectType_ConnectSSL;
		
	elseif _value = BGP_EmailSendRequest.SSL_STARTTLS then
		return EAGetMailSupport.SSLConnectType_ConnectTLS;
		
	else
		return -1; //We have invalid settings
		
	endif;

end;</source>
        <Parameter name="_value" type="Integer"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="convertSndSSLFromOCXtoDotNet" id="33dcc3d0-f272-489f-ab8b-1bed25e12128">
        <source>convertSndSSLFromOCXtoDotNet(_value : Integer) : Integer;
/*

Purpose:			Converts Send SSL OCX constants to Dot Net Constants

Parameters:			_value	Integer	Value to convert

Return Value:		Integer	The converted value

Date		Who		Reason
18 February 2022	navpw1	Initial creation TFS: 51526
18 October 2022		NAVSP1  ChangeRequest 55021: MTN - OAuth Enhancements - Refactor calls to EASMTPMail
22 January 2024		navmd1	TFS 55021 EA Mail Tidyup and Refactor
*/
	
begin
	//Convert BGP_EmailSendRequest Constant to EASendSmtpServer ConnectType Constant as they have different numbers
	if _value = BGP_EmailSendRequest.SSL_DIRECT then
		return EAGetMailSupport.SmtpConnectType_ConnectDirectSSL;
		
	elseif _value = BGP_EmailSendRequest.SSL_NONE then
		return EAGetMailSupport.SmtpConnectType_ConnectNormal;
		
	elseif _value = BGP_EmailSendRequest.SSL_STARTTLS then
		return EAGetMailSupport.SmtpConnectType_ConnectSTARTTLS;
		
	else
		return -1; //We have invalid settings
		
	endif;

end;</source>
        <Parameter name="_value" type="Integer"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="create" id="71e66b7e-f03b-4d47-bd48-990288ca3033">
        <updating/>
        <source>create() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
18 January 2024		navmd1	Initial creation TFS 55021 EA Mail Tidyup and Refactor

*/

vars
	hadException	: Boolean;
begin
	on Exception do self.handleExceptionsExt(exception, hadException);
	create self.getMailHelper transient;
	create self.sendMailHelper transient;
	
	if self.getMailHelper &lt;&gt; null then
		self.getMailHelper.usePresentationClient := self.usePresentationClient;
	endif;
	
	if self.sendMailHelper &lt;&gt; null then
		self.sendMailHelper.usePresentationClient := self.usePresentationClient;
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="createMailClient" id="59463831-9dba-4ef0-b4c6-9e719093d7f0">
        <updating/>
        <source>createMailClient(_terminal : CM_Terminal; _timeout : Integer) : Boolean updating;
/*

Purpose:			Creates our Mail Client

Parameters:			_terminal	CM_Terminal	The terminal to use to get the license key for
					_timeout	Integer		The timeout for the connection to the mail server

Return Value:		Boolean	Representing whether the mail client was successfully created

Date		Who		Reason
02 February 2022	navpw1	Initial creation TFS: 51526
19 July 2022		navpw1	Bug: 54066 GPHA - BGP Stuck when sending email via OAUTH doesn't return
22 January 2024		navmd1	TFS 55021 EA Mail Tidyup and Refactor

*/

vars
	licenseStr 			: String;
	exceptionOccurred 	: Boolean;
begin
	on Exception do self.handleExceptionsExt(exception, exceptionOccurred);
	app.writeLog(method.qualifiedName, LogTRACE);
	
	licenseStr := app.emailArchitectSetLicenseOAuth(self.getMailHelper, _terminal);
	
	if licenseStr = null then
		app.writeLog("Failed to get a license key for Email Architect Email Read", LogERROR);
		app.createAlert("Failed to get a license key for Email Architect Email Read", true);
		app.raiseCMException1(ErrInvalidLicenseProductCode, "EAGETMail", null, null);
	endif;
	
	self.mailClient := self.getMailHelper.createClient(licenseStr.StringUtf8, EAGetMailSupport.GetMailInfosOptionType_All, _timeout, self.logFileName, app.logLevel);
	
	return not exceptionOccurred;
end;</source>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_timeout" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="createMailServer" id="b19b1453-9880-4116-99cf-6b331a1779b4">
        <updating/>
        <source>createMailServer(_server, _user, _password : String; _useSSL, _useImap4 : Boolean; _serverAuthType, _portNumber, _serverProtocol, _sslType : Integer) : JadeDotNetType /*MailServer*/ updating;
/*

Purpose:			Creates our Mail Server

Parameters:			_server			StringUtf8	Server to connect to
					_user			StringUtf8	User to login as
					_password		StringUtf8	Password to use for login
					_useSSL			Boolean		Whether we need to use SSL
					_useImap4		Boolean		Whether we need to use IMAP4
					_serverAuthType	Integer		The Auth type to use for the server
					_portNumber		Integer		The port number to use for the server
					_serverProtocol	Integer		The server protocol to use for the server

Return Value:		Boolean Representing whether we created a Mail Server successfully

Date				Who		Reason
02 February 2022	navpw1	Initial creation TFS: 51526
18 January 2024		navmd1	TFS 55021 EA Mail Tidyup and Refactor

*/

vars
	execptionOccurred	: Boolean;
	server				: JadeDotNetType;
begin
	on Exception do self.handleExceptionsExt(exception, execptionOccurred);
	app.writeLog(method.qualifiedName, LogTRACE);
	
	server := self.getMailHelper.createServer(_server.StringUtf8, _user.StringUtf8, _password.StringUtf8, _useSSL, _useImap4, _serverAuthType, _portNumber, _serverProtocol, _sslType, self.logFileName, app.logLevel);
	app.writeLog("Created a Mail Server", LogINFO);

	return server;
end;</source>
        <Parameter name="_server" type="String"/>
        <Parameter name="_user" type="String"/>
        <Parameter name="_password" type="String"/>
        <Parameter name="_useSSL" type="Boolean"/>
        <Parameter name="_useImap4" type="Boolean"/>
        <Parameter name="_serverAuthType" type="Integer"/>
        <Parameter name="_portNumber" type="Integer"/>
        <Parameter name="_serverProtocol" type="Integer"/>
        <Parameter name="_sslType" type="Integer"/>
        <ReturnType type="JadeDotNetType"/>
    </JadeMethod>
    <JadeMethod name="createSmtpMail" id="f3b0667e-7bc0-4415-92d8-ff3043f28722">
        <updating/>
        <source>createSmtpMail(_charset : String) : JadeDotNetType updating;
/*

Purpose:			Creates an SMTP mail object and returns it

Parameters:			_charset	String	Charset to use for the email

Return Value:		EASendSmtpMail	The Smtp mail object that was created

Date		Who		Reason
15 February 2022	navpw1	Initial creation TFS: 51526
18 OCT 2022			NAVSP1  ChangeRequest 55021: MTN - OAuth Enhancements - Refactor calls to EASMTPMail
17 January 2024		navmd1	TFS 55021 Refactor and Tidyup
*/

vars
	tmpStr				: String;
	execptionOccurred	: Boolean;
begin
	on Exception do self.handleExceptionsExt(exception, execptionOccurred);
	app.writeLog(method.qualifiedName, LogTRACE);
	
	tmpStr := app.emailArchitectSetLicenseOAuth(self.sendMailHelper, null);
	
	if tmpStr = null then
		app.writeLog("Failed to get a license key for Email Architect Email Read", LogERROR);
		app.createAlert("Failed to get a license key for Email Architect Email Read", true);
		return null;
		
	endif;
	
	return sendMailHelper.createSmtpMail(tmpStr.StringUtf8, _charset.StringUtf8, CMIF_EmailArchitect.DEFAULT_CHARSET.StringUtf8, self.logFileName, app.logLevel);
	
epilog
	
end;
</source>
        <Parameter name="_charset" type="String"/>
        <ReturnType type="JadeDotNetType"/>
    </JadeMethod>
    <JadeMethod name="createSmtpServer" id="acef117a-3a98-4076-8d2f-226fcae67cb8">
        <updating/>
        <source>createSmtpServer(_server, _user, _password : String; _portNumber, _authType, _sslUsage : Integer) : JadeDotNetType /*SmtpServer*/  updating;
/*

Purpose:			Creates an SMTP server object

Parameters:			_server		String	Server to connect to
					_user		String	User to log in as
					_password	String	Password to use for logging in
					_portNumber	Integer	Port number for server
					_authType	Integer	Auth type of the login request
					_sslUsage	Integer	The type of connection we're using SSL/TLS/None

Return Value:		Boolean Represents whether or not the mail server was created

Date		Who		Reason
15 February 2022	navpw1	Initial creation TFS: 51526
19 July 2022		navpw1	TFS: 52562 MTN - .Net Exceptions in OAUTH code
18 OCT 2022	        NAVSP1  ChangeRequest 55021: MTN - OAuth Enhancements - Refactor calls to EASMTPMail
16 January 2024		navmd1	TFS 55021 Tidyup and Rewrite
*/

vars
	exceptionOccurred 	: Boolean;
	smtpserver			: JadeDotNetType;
begin
	on Exception do self.handleExceptionsExt(exception, exceptionOccurred);
	app.writeLog(method.qualifiedName, LogTRACE);
	
	app.writeLog("User for sending email is " &amp; _user &amp; ", server is " &amp; _server, LogDEBUG);
	
	smtpserver := self.sendMailHelper.createSmtpServer(_server.StringUtf8, _portNumber, _user.StringUtf8, _password.StringUtf8, _authType, _sslUsage, self.logFileName, app.logLevel);
	
	if exceptionOccurred then
		return null;
	endif;
	
	app.writeLog("Created the SMTP Server", LogDEBUG);
	return smtpserver;
end;</source>
        <Parameter name="_server" type="String"/>
        <Parameter name="_user" type="String"/>
        <Parameter name="_password" type="String"/>
        <Parameter name="_portNumber" type="Integer"/>
        <Parameter name="_authType" type="Integer"/>
        <Parameter name="_sslUsage" type="Integer"/>
        <ReturnType type="JadeDotNetType"/>
    </JadeMethod>
    <JadeMethod name="delete" id="d7bfc2ce-8474-452c-b124-a235c7617908">
        <updating/>
        <source>delete() updating;
/*

Purpose:			Deletes all our created transients

Parameters:			NONE

Return Value:		NONE

Date				Who		Reason
02 February 2022	navpw1	Initial creation TFS: 51526
18 January 2024		navbmd1	TFS 55021 EA Mail Tidyup and Refactor
20 Februaru 2024	navmd1	TFS 62538 Fix error 4 on deletion of CMIF

*/

begin
	// Delete any 'sub objects' first to avoid error 4s
	delete self.mailClient;
	
	// Then delete the mail helpers
	delete self.getMailHelper;
	delete self.sendMailHelper;
end;</source>
    </JadeMethod>
    <JadeMethod name="deleteMailInfo" id="1f15bdf5-2dd0-414c-a11a-8b4237d1d7d5">
        <updating/>
        <source>deleteMailInfo(_mailInfo : JadeDotNetType input) : Boolean updating;
/*

Purpose:			Deletes the Mail Info on the server

Parameters:			_mailInfo	EAGetMailInfo	The mail info we want to delete

Return Value:		Boolean	Representing whether or not we successfully deleted the mail info

Date				Who		Reason
02 February 2022	navpw1	Initial creation TFS: 51526
18 January 2024		navmd1	TFS 55021 EA Mail Tidyup and Refactor

*/

vars
	execptionOccurred : Boolean;
	
begin
	on Exception do self.handleExceptionsExt(exception, execptionOccurred);
	app.writeLog(method.qualifiedName, LogTRACE);
	
	self.getMailHelper.deleteMail(self.mailClient, _mailInfo, self.logFileName, app.logLevel);
	
	return not execptionOccurred;
end;</source>
        <Parameter name="_mailInfo" type="JadeDotNetType" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getAttachment" id="2ce4baa6-7ded-4b4d-aca0-c19f915ad8ad">
        <updating/>
        <source>getAttachment(_mail : JadeDotNetType input; _idx : Integer; _contentType, _name, _id : String output) : JadeDotNetType updating;
/*

Purpose:			Gets an attachment from the email

Parameters:			_mail	EAGetMail	The mail to get the attachment from
					_idx	Integer		The index of the attachment

Return Value:		EAGetAttachment	The attachment from the email

Date				Who		Reason
02 February 2022	navpw1	Initial creation TFS: 51526
18 January 2024		navmd1	TFS 55021 EA Mail Tidyup and Refactor

*/

vars
	execptionOccurred 		: Boolean;
	attachment				: JadeDotNetType;
	contentType, name, id	: StringUtf8;
begin
	on Exception do self.handleExceptionsExt(exception, execptionOccurred);
	app.writeLog(method.qualifiedName, LogTRACE);
	
	attachment := self.getMailHelper.getAttachment(_mail, _idx, contentType, name, id, self.logFileName, app.logLevel);
	
	_contentType := contentType.String;
	_name := name.String;
	_id := id.String;
	
	return attachment;
end;</source>
        <Parameter name="_mail" type="JadeDotNetType" usage="input"/>
        <Parameter name="_idx" type="Integer"/>
        <Parameter name="_contentType" type="String" usage="output"/>
        <Parameter name="_name" type="String" usage="output"/>
        <Parameter name="_id" type="String" usage="output"/>
        <ReturnType type="JadeDotNetType"/>
    </JadeMethod>
    <JadeMethod name="getMail" id="9f132cdf-efc0-43ec-af45-c0a40484e8dd">
        <updating/>
        <source>getMail(_mailInfo : JadeDotNetType input; _numAttachments : Integer output; _from, _to, _subject, _body : String output; _isRead : Boolean output) : JadeDotNetType updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
02 February 2022	navpw1	Initial creation TFS: 51526
18 January 2024		navmd1	TFS 55021 EA Mail Tidyup and Refactor

*/

vars
	execptionOccurred 		: Boolean;
	mail					: JadeDotNetType;
	from, to_, subject, body	: StringUtf8;
begin
	on Exception do self.handleExceptionsExt(exception, execptionOccurred);
	app.writeLog(method.qualifiedName, LogTRACE);

	mail := self.getMailHelper.getMail(self.mailClient, _mailInfo, _numAttachments, from, to_, subject, body, _isRead, self.logFileName, app.logLevel);

	// navmd1 - Does this actually work for Unicode emails ?
	_from := from.asString(0);
	_to := to_.asString(0);
	_subject := subject.asString(0);
	_body := body.asString(0);
	
	return mail;
end;</source>
        <Parameter name="_mailInfo" type="JadeDotNetType" usage="input"/>
        <Parameter name="_numAttachments" type="Integer" usage="output"/>
        <Parameter name="_from" type="String" usage="output"/>
        <Parameter name="_to" type="String" usage="output"/>
        <Parameter name="_subject" type="String" usage="output"/>
        <Parameter name="_body" type="String" usage="output"/>
        <Parameter name="_isRead" type="Boolean" usage="output"/>
        <ReturnType type="JadeDotNetType"/>
    </JadeMethod>
    <JadeMethod name="getMailInfo" id="72eb8279-423d-434d-9228-a33188128eaf">
        <updating/>
        <source>getMailInfo(_idx : Integer; _mailHeaders : JadeDotNetType io; _flags : Integer output) : JadeDotNetType updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 February 2022	navpw1	Initial creation TFS: 51526
01 December 2023    navmj1 	57752: .NET object added to hold retrieved the mail headers
							       so they only have to be retrieved once with the first 
								   call to the helper, also create a log file name to log
								   .NET actions into
18 January 2024		navmd1	TFS 55021 EA Mail Tidyup and Refactor

*/

vars
	execptionOccurred 	: Boolean;
begin
	on Exception do self.handleExceptionsExt(exception, execptionOccurred);
	app.writeLog(method.qualifiedName, LogTRACE);
	
	return self.getMailHelper.getMailInfo(self.mailClient, _mailHeaders, _idx, EAGetMailSupport.GetMailInfosOptionType_All, _flags, self.logFileName, app.logLevel);	// 57752: 01/12/2023 - change in the .NET method 
																																										//        signature. Mail Headers object now past in
																																										//        and the name of the log file.
end;</source>
        <Parameter name="_idx" type="Integer"/>
        <Parameter name="_mailHeaders" type="JadeDotNetType" usage="io"/>
        <Parameter name="_flags" type="Integer" usage="output"/>
        <ReturnType type="JadeDotNetType"/>
    </JadeMethod>
    <JadeMethod name="getOAuthToken" id="65f3bec6-ebde-4b1d-86d1-cdfc37bdb036">
        <updating/>
        <source>getOAuthToken(_term : CM_Terminal) : String updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
03 Oct 2022		navmd1	Initial creation TFS 55020
30 Aug 2024		navmd1	TFS 65917 Show any OAuth Token errors to users
04 Sep 2024  	jlier1 	TFS 65949 - task 65950 - NSW | Dynamics Integration
04 Nov 2024		navdap1	MTN-33379 MTN - Emails unable to be sent via OAUTH
03 Jun 2025		navah1	Bug 34846: MSL-Email Receival from Inbound Mail ID - edifact@imterminal.it to the MTN Application has been stopped.
*/

constants
	MicrosoftURL = "https://login.microsoftonline.com/";
	Office365URI = "https://outlook.office365.com/.default";
vars
	tenantId	: String;
begin
	app.writeLog(method.qualifiedName, LogTRACE);
	
	tenantId := app.myRoot.getConfig(TenantId).String;
	if _term &lt;&gt; null and tenantId = null then					//03.06.2025 navah1 #34846
		tenantId :=_term.getConfig(TenantId).String;
	endif; 
	
	return app.getTokenFromEndpoint( _term, CMIF_OAuthToken.TYPE_EMAIL, MicrosoftURL, EmailOAuthClientId, EmailOAuthClientSecret, Office365URI, tenantId, null, null,2,null, self.lastError);	// MTN-33379
	 
end; </source>
        <Parameter name="_term" type="CM_Terminal"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="handleExceptionsExt" id="6248056f-0cb6-4ad9-9f50-c735a664705e">
        <updating/>
        <source>handleExceptionsExt(_exc: Exception; _excOccurred: Boolean io): Integer protected, updating;
/*

Purpose:			Try and give a little more help for people investigating Email issues

Parameters:			

Return Value:		

Date					Who		Reason
19 January 2024			navmd1	Initial creation 55021

*/

vars

begin
	self.lastError := _exc.extendedErrorText;

	return self.handleExceptions(_exc, _excOccurred);

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_exc" type="Exception"/>
        <Parameter name="_excOccurred" type="Boolean" usage="io"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="logFileName" id="621fefde-9171-441d-bd8e-5b829f6a174e">
        <source>logFileName(): StringUtf8 protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date					Who		Reason
18 January 2024			navmd1	Initial creation TFS 55021

*/

vars
	today		: Date;
	logFileName	: String;
begin
	today := app.actualTimeServer.Date;
	logFileName := self.class.name &amp; "_" &amp; today.formatAsYYYYMMDD &amp; "_" &amp; self.getInstanceIdForObject(process).String &amp; ".log";
		
	if self.usePresentationClient then
		logFileName := app.getTempDir &amp; logFileName;
	else
		if app.myCnCntrl &lt;&gt; null then
			logFileName := app.myCnCntrl.logPath &amp; "\" &amp; logFileName;
		else
			logFileName := app.getTempDirAppServer &amp; logFileName;
		endif;
	endif;
	
	return logFileName.StringUtf8;
epilog

end;</source>
        <access>protected</access>
        <ReturnType type="StringUtf8"/>
    </JadeMethod>
    <JadeMethod name="logout" id="97e98bdf-ecd0-458f-9f86-31ed1d6d8a52">
        <updating/>
        <source>logout(_deleteOldEmails : Boolean) : Boolean updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
10 February 2022	navpw1	Initial creation TFS: 51526
18 January 2024		navmd1	TFS 55021 EA Mail Tidyup and Refactor (renamed/merged from mailClientLogout and mailClientQuit)

*/

vars
	execptionOccurred : Boolean;
	
begin
	on Exception do self.handleExceptionsExt(exception, execptionOccurred);
	app.writeLog(method.qualifiedName, LogTRACE);
	
	self.getMailHelper.logout(self.mailClient, _deleteOldEmails, self.logFileName, app.logLevel);
	
	delete self.mailClient;
	
	return not execptionOccurred;
end;</source>
        <Parameter name="_deleteOldEmails" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="markAsRead" id="3a4cd4eb-fcf0-4947-996d-001f150909dc">
        <updating/>
        <source>markAsRead(_mailInfo : JadeDotNetType input; _read : Boolean) : Boolean updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date						Who		Reason
02 February 2022	navpw1	Initial creation TFS: 51526
18 January 2024		navmd1	TFS 55021 EA Mail Tidyup and Refactor

*/

vars
	execptionOccurred : Boolean;
	
begin
	on Exception do self.handleExceptionsExt(exception, execptionOccurred);
	app.writeLog(method.qualifiedName, LogTRACE);
	
	self.getMailHelper.markAsRead(self.mailClient, _mailInfo, _read, self.logFileName, app.logLevel);
	
	return execptionOccurred;
end;</source>
        <Parameter name="_mailInfo" type="JadeDotNetType" usage="input"/>
        <Parameter name="_read" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="saveToDisk" id="5cc2fc04-5bbe-4d66-8189-57df1f8cbfd4">
        <updating/>
        <source>saveToDisk(_mail, _attachment : JadeDotNetType input; _filePath : String) : Boolean updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
18 January 2024		navmd1	Initial creation TFS 55021 EA Mail Tidyup and Refactor

*/

vars
	exceptionOccurred	: Boolean;
begin
	on Exception do self.handleExceptionsExt(exception, exceptionOccurred);
	app.writeLog(method.qualifiedName, LogTRACE);
	
	self.getMailHelper.saveToDisk(_mail, _attachment, _filePath.StringUtf8, self.logFileName, app.logLevel);
	
	return not exceptionOccurred;
epilog

end;</source>
        <Parameter name="_mail" type="JadeDotNetType" usage="input"/>
        <Parameter name="_attachment" type="JadeDotNetType" usage="input"/>
        <Parameter name="_filePath" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="sendMail" id="eb7018e7-7461-47b3-a98b-8a98ecc16aea">
        <updating/>
        <source>sendMail(_server, _mail : JadeDotNetType input; _timeout : Integer; _smtpConversation : String output) : Boolean updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
15 February 2022	navpw1	Initial creation TFS: 51526
16 January 2024		navmd1	TFS 55021 Repurpose for EASendMail refactor

*/

vars
	exceptionOccurred	: Boolean;
begin
	on Exception do self.handleExceptionsExt(exception, exceptionOccurred);
	app.writeLog(method.qualifiedName, LogTRACE);
	
	_smtpConversation := self.sendMailHelper.sendMail(_server, _mail, _timeout, self.logFileName, app.logLevel).String;
	
	return not exceptionOccurred;
end;</source>
        <Parameter name="_server" type="JadeDotNetType" usage="input"/>
        <Parameter name="_mail" type="JadeDotNetType" usage="input"/>
        <Parameter name="_timeout" type="Integer"/>
        <Parameter name="_smtpConversation" type="String" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
