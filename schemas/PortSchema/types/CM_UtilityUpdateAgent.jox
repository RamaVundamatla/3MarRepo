begin

	self.initialiseActivity();

	pProxyLogRejectRCCode.raiseExceptionIfNotProxy(method);

	app.setContinueCMExceptions(true);

	pProxyLogRejectRCCode.pxyGetRealObjectAndEdition(realLogRejectRCCode, expectedEdition);
	
	if realLogRejectRCCode = null then	
		app.raiseCMException1(ProxyMgrCannotLocateReal, CM_LogRejectRecoveryCode.name, null, null);
		return;
	endif;

	app.myValUA.valLogRejectRCCode(realLogRejectRCCode, pProxyLogRejectRCCode);
	
	if (not self.checkValidationWithPassport(_passport)) then
		return;		// note that this gets "ignored" in the eplog
	endif;


	app.setContinueCMExceptions(false);

	exclusiveLock(realLogRejectRCCode);

	if _passport.noErrors and realLogRejectRCCode.edition &lt;&gt; expectedEdition then
		app.raiseCMException1(ObjectUpdatedByAnotherUserSave, 'LogRejectRCCode', null, null);
		return;
	endif;
	
	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realLogRejectRCCode, true);
	endif;
	
	if _passport.noErrors then
		realLogRejectRCCode.setForUpdate(pProxyLogRejectRCCode);
	endif;

	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realLogRejectRCCode, false);
	endif;

epilog
	
	
end;</source>
        <Parameter name="pProxyLogRejectRCCode" type="CM_LogRejectRecoveryCode"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateLogRow" id="92aaeb95-ec9b-4f5e-a7c2-af63b8908f9d">
        <source>utlUpdateLogRow(_cmifLogRow : CMIF_LogRowRestriction; _passport : CM_Passport input);

vars
	pxyRestriction, 
	realRestriction 	: CM_LocationRestrictLog;
	pxyController, 
	realController		: CM_LogController;
	rowAreaRow			: CM_RowAreaRow;
	origRealInspected,
	origRealFumigated	: Boolean;
	
begin
	
	self.initialiseActivity();

	pxyController := _cmifLogRow.myProxyLogController;
	realController := app.myProxyManager.getRealObject(pxyController).CM_LogController;
	sharedLock(realController);

	create pxyRestriction transient;

	pxyController.setFromCMIF(_cmifLogRow);
	pxyRestriction.setFromCMIF(_cmifLogRow);
	// 13/05/2010 cnwmh5 #23957 
	// set the pxyControllers restrictions
	pxyController.setLocationRestriction(pxyRestriction);
	app.myValUA.valLogRow(pxyController, realController, pxyRestriction, 
						_cmifLogRow, _passport);
	// 13/05/2010 cnwmh5 #23957
	// unset the proxyControllers restrictions
	pxyController.setLocationRestriction(null);
	
	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	
	app.setContinueCMExceptions(false);
	
	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realController, true);		// 09/09/2009 cnwar2 CCMS-1107/#20627
	endif;
		
	// Row &amp; restriction is correct now see if can fit in
	sharedLock(_cmifLogRow.myRowArea);

	rowAreaRow := _cmifLogRow.myRowAreaRow;
	// Now set width, work out position and update all other things.

	if _passport.noErrors then
		realRestriction := realController.myLocationRestriction.CM_LocationRestrictLog;
		realRestriction.setForUpdate(pxyRestriction);
	endif;
	
	// save original values, later update all logs in the log row, if orig values in area have been changed
	// CCMS 1071, PAR20627 Sep 2009 cnwvu1
	origRealInspected := realController.isInspected;
	origRealFumigated := realController.isFumigated;

	if _passport.noErrors then
		realController.setForUpdate(pxyController, realController.myTerminalArea);
	endif;
		
	// 14/09/2009 cnwvu1 CCMS-1107/#20627
	if _passport.noErrors then
		realController.setExtraFieldsFrom_cmifLogRow(_cmifLogRow, origRealInspected, origRealFumigated);
	endif;

	if _passport.noErrors then
		realRestriction.allLocationControllers.add(realController);
	endif;
	
	if _passport.noErrors then
		if rowAreaRow &lt;&gt; null then
			rowAreaRow.setForUpdateFromCMIFLogRow(_cmifLogRow, realController);
		elseif _cmifLogRow.status &lt;&gt; LC_Status_PhysicallyEmpty then
			// Must by changing from Empty back to something else so need to
			// recreate a rowAreaRow
			
			if (not _cmifLogRow.isSplit) then
				create rowAreaRow persistent;
			else
				rowAreaRow := _cmifLogRow.myRowAreaRowTo;
			endif;
		
			// Now set width, work out position and update all other things.
			rowAreaRow.setForCreateFromCMIFLogRow(_cmifLogRow);

			if _passport.noErrors then
				rowAreaRow.addController(realController);
			endif;
		endif;
	endif;
		
	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realController, false);	// 09/09/2009 cnwar2 CCMS-1107/#20627
		global.causeEvent(realController.myTerminal.getTerminalEvent(EVENT_ROWCONTROLLER_UPDATE), false, realController);
	endif;

epilog
	delete pxyRestriction;

end;</source>
        <Parameter name="_cmifLogRow" type="CMIF_LogRowRestriction"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateLogRowDownload" id="05dca0c6-3780-4000-9a18-06b799da3594">
        <source>utlUpdateLogRowDownload(_logRowDownloadArray:CMIF_LogRowDownloadArray; _logFileName, _shipFileName : String; _passport : CM_Passport input);
//--------------------------------------------------------------
//Created: August 2002 By: cnwgd1
//--------------------------------------------------------------
//They can create one or the other or both
vars
	logFile, shipFile : File;
	now	: TimeStamp;
	intFaceRow : CMIF_LogRowDownload;
	download : CM_LogVoyageRowDownload;
	tmpLogStructure : CM_LogVoyageStructure;
	tmpStructureSet : CM_LogVoyageStructureSet;
begin

	self.initialiseActivity();
	app.setContinueCMExceptions(true);
	if _logFileName = null and _shipFileName = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Log File Name and/or Ship File Name', null, null);
		app.raiseCMException(Input_required_field_logOrShp, null, null); // cnwdb2	PAR 35364
		return;
	endif;	
	
	if _logFileName &lt;&gt; null then
		create logFile transient;
		logFile.fileName := _logFileName;
		logFile.mode := File.Mode_Output;
		logFile.open;
		logFile.purge();
	endif;

	if _shipFileName &lt;&gt; null then
		create shipFile transient;
		shipFile.fileName := _shipFileName;
		shipFile.mode := File.Mode_Output;
		shipFile.open;
		shipFile.purge();
	endif;

	create tmpStructureSet transient;
	
	foreach intFaceRow in _logRowDownloadArray do
		if intFaceRow.myRowDownload = null then
			// belts and braces, shouldn't happen
			continue;
		endif;
		
		if intFaceRow.myRowDownload.isTransient then
			create download persistent;
			download.setForUpdateFromProxy(intFaceRow.myRowDownload, _passport);
		else
			download := intFaceRow.myRowDownload;
		endif;
		
		if logFile &lt;&gt; null then
			exclusiveLock(download);		
			self.myUpdateAuditAgent.audUpdateGeneric(download, true);
			download.downloadLogFile(intFaceRow.changesOnly, logFile, _passport);
			download.updateLastDownloadTime(now);				
			self.myUpdateAuditAgent.audUpdateGeneric(download, false);
		endif;
		
		if download.myLogVoyageStructure &lt;&gt; null then //&lt;&lt;-- belts an braces, should not be null
			if (not tmpStructureSet.includes(download.myLogVoyageStructure)) then
				tmpStructureSet.add(download.myLogVoyageStructure);			
			endif;
		endif;
		
	endforeach;

	foreach tmpLogStructure in tmpStructureSet do
		// update rows allocated to the voyage
		tmpLogStructure.setAllLogRowDownloads();	
	endforeach;
	
	if shipFile &lt;&gt; null
	and download &lt;&gt; null then
		download.downloadShipFile(shipFile, _passport);		
	endif;

epilog
	if logFile &lt;&gt; null then
		logFile.close;
		delete logFile;	
	endif;
	if shipFile &lt;&gt; null then
		shipFile.close;
		delete shipFile;	
	endif;
	delete tmpStructureSet;
	
end;</source>
        <Parameter name="_logRowDownloadArray" type="CMIF_LogRowDownloadArray"/>
        <Parameter name="_logFileName" type="String"/>
        <Parameter name="_shipFileName" type="String"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateLogRowWidth" id="0730a667-ddf2-4868-9e24-403c2dfc78ee">
        <source>utlUpdateLogRowWidth(_theLogRow : CM_RowAreaRow input; _theWidth : Real);
// ---------------------------------------------------------------------------
// Created:		May  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

