	app.printer.print(self.frmReport);

	self.lblReport_1.caption := self.lblNumOfPlugs.caption;
	self.lblReport.caption := self.txtNumOfPlugs.text;
	app.printer.print(self.frmReport);							

	self.lblReport_1.caption := self.lblTypeOfBay.caption;
