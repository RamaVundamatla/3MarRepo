    <JadeMethod name="initBGP_ManagerShortcutApp" id="07e57db4-14fe-4d29-abcf-51f680c75ef8">
        <updating/>
        <source>initBGP_ManagerShortcutApp() updating;

/*

Date		Who		Reason
23 Sep 2008	cnwkpd1	PAR #18009 - Allow ini file control of transient check
07 Feb 2012	cnwkpd1	PAR #28381 - Update JSM version info correctly in managed environments

*/

vars
	managerName,
	userData		: String;
	pos				: Integer;
	manager			: BGP_Manager;
	root			: CM_Root;
	
begin
	if app.myCnCntrl = null then
		self.setupAppVersion();			// PAR #28381
		self.cnActivateKarmaControl(Cn_Fat_Client, null, null);	//for dumps
	endif;
	userData := self.getUserCommandLine(true);
	
	app.writeCnLog(CnCntrl.CnLogErrors, 'Initializing BGP_ManagerShortcutApp with (' &amp; userData &amp; ')');//25 Nov 2019	NDL	TFS 47053 - pre initialise needs card schema logging
	// 33632 make SDS-aware and exit
	if app.isSDSSecondaryDB() then
		app.writeCnLog(CnCntrl.CnLogErrors, app.name &amp; ' started in SDS secondary mode, terminating');//25 Nov 2019	NDL	TFS 47053 - pre initialise needs card schema logging
		terminate;
	endif;

    pos := 1;
    pos := userData.pos("BGP_Manager=", pos);
    if pos &lt;&gt; 0 then
		managerName := userData[pos +  "BGP_Manager=".length : end];
        root := CM_Root.firstInstance;
        if root &lt;&gt; null and managerName &lt;&gt; null then
        	manager := root.allBGPManagers[managerName];
        	if manager &lt;&gt; null then
        		
        		self.myBGPObject := manager;	
              	app.writeCnLog(CnCntrl.CnLogErrors, 'Initializing manager (' &amp; managerName &amp; ') ....');//25 Nov 2019	NDL	TFS 47053 - pre initialise needs card schema logging
              	manager.initManager();
				self.changeLogLevel(LogWARN);	//22 Nov 2019	NDL	TFS 47053
              	app.writeLog('Initializing manager (' &amp; managerName &amp; ')  complete', LogINFO);
				
//				app.myCnCntrl.setCheckTransientsOnShutDown(false);	- removed PAR #18009
        		return;
        	else
        		app.writeCnLog(CnCntrl.CnLogErrors, 'ERROR &gt;&gt; Manager not found (' &amp; managerName &amp; ')');//25 Nov 2019	NDL	TFS 47053 - pre initialise needs card schema logging
           	endif;
        elseif root = null then
       		app.writeCnLog(CnCntrl.CnLogErrors, 'ERROR &gt;&gt; root is null');//25 Nov 2019	NDL	TFS 47053 - pre initialise needs card schema logging
       	elseif managerName = null then
       		app.writeCnLog(CnCntrl.CnLogErrors, 'ERROR &gt;&gt; managerName is null (' &amp; userData &amp; ')');//25 Nov 2019	NDL	TFS 47053 - pre initialise needs card schema logging
        endif;
    else
		app.writeCnLog(CnCntrl.CnLogErrors, 'ERROR &gt;&gt; managerName not found on command line (' &amp; userData &amp; ')');//25 Nov 2019	NDL	TFS 47053 - pre initialise needs card schema logging
    endif;

    terminate;

end;</source>
    </JadeMethod>
