    <JadeMethod name="hasAvailableAssignedTI" id="9e7667cb-d964-48a1-894d-4617d5496ac8">
        <source>hasAvailableAssignedTI(_request : CM_Request) : Boolean;
/*
Return true if any of the assigned tis are still available

Date		Who		Reason
21 Nov 2014	cnwdw1	Initial creation
24 Apr 2020	NDL		TFS 49095
06 Mar 2025 navma1  MTN-34179 MTN | Dead Lock (1081) on CM_WLEArray
*/
vars
	ti	: CM_TrackedItem;
	lc 	: CM_LocationsController;
begin
	// ### TFS 52721 16NOV2022 NAVAB1 do not check this if we are assigning to BR as we go along
	if _request.isYardDeliveryReq()
	and self.myTerminal.getConfig(DelReqAddToAssigned).Boolean then 
		return false;
	endif;

	foreach ti in self.allTrackedItemsAssigned discreteLock do		//06.03.2025 navma1 #MTN-34179
		
		if ti.hasBeenMerged then
			continue;
		endif;
		
		lc := ti.myPrimaryActualLocation;							//06.03.2025 navma1 #MTN-34179
		
		if ( lc.isVehicle and self.isRoadType ) or
		   ( lc.isWagon and self.isRailType ) or
		     lc.isMachineController or
		     lc.isYardInterchangeAreaLocation then
			continue;
		endif;	
		
		return true;			
	endforeach;
	
	return false;
epilog

end;</source>
        <Parameter name="_request" type="CM_Request"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="hasDocActions" id="8f6fffb5-de76-4b6c-93bb-ebcf4214e2d0">
        <source>hasDocActions():Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 October 2016	cnwndl1	Initial creation	TFS 2655 / 2419

*/

vars

	iter : Iterator;
	reserveDetail : CM_ReserveDetail;
	docActions : CM_DocumentActions;

begin

	iter := self.allReserveDetails.createIterator;
	while iter.next( reserveDetail) do
		docActions := reserveDetail.myReserveDetailActions;
		if docActions = null then
			continue;
		endif;
		if docActions.hasActions then
			return true;
		endif;
	endwhile;
	
	return false;

epilog

	delete iter;

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="hasDocumentActions" id="7bc3cad1-28bc-4c39-9607-4b0626a1dc9b">
        <source>hasDocumentActions( _objArray : ObjectArray input ):Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 September 2016	cnwndl1	Initial creation

*/

vars

	resDet : CM_ReserveDetail;
	iter : Iterator;
	docAction : CM_DocumentActions;
	hasActions : Boolean;

begin

	if _objArray &lt;&gt; null then
		_objArray.clear();
	endif;

	iter := self.allReserveDetails.createIterator;
	while iter.next( resDet ) do
		docAction := resDet.myReserveDetailActions;
		if docAction &lt;&gt; null and docAction.hasActions then
			if _objArray &lt;&gt; null then
				_objArray.add( docAction );
			endif;
			hasActions := true;
		endif;
	endwhile;

	return hasActions;

epilog

	delete iter;

end;</source>
        <Parameter name="_objArray" type="ObjectArray" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
