    </JadeMethod>
    <JadeMethod name="doPrint" id="c162d803-31fe-4cae-922f-dca00866f619">
        <updating/>
        <source>doPrint() updating;
//28 Nov 2017 cnwma1 	TFS# 7591: POL - ##6094## : 8.5.1.111 - Road receipt incorrectly printing when transction incomplete
//30 Jan 2018 jlgsl4	TFS 36534 - POL - Road receipt incorrectly printing when transaction incomplete
vars
	jobStatus	: Integer;
	job 	: CM_RoadJob;
	dialog	: CMUI_ReceiptCopies;
	theResult : Integer;	//14 Jan 2020 NDL	TFS 46815
begin
	
	myCurrentObject := tblData.allSelectedObjects.last.CM_Object;
	
	if myCurrentObject = null then	// moved this test to here and included a return to clarify code RDD 
		app.msgBox("You do not have a job selected","Receipt",MsgBox_Exclamation_Mark_Icon);	
		return;
	endif;
	
	job := myCurrentObject.CM_RoadJob;

	sharedLock(job);
		
	if job.status &lt;&gt; JOB_COMPLETE then
		// old code to patch up the job status, revised for 31890 to check for change first and do update in trx
		// (not clear why it is doing this ...)
		jobStatus := job.getNewStatus();
		if jobStatus &lt;&gt; job.status then
			app.myTrxUA.trxUpdateJobStatusOnly(job, app.myPassport);
			////beginTransaction;
			////job.updateStatus;		//Healing
			////commitTransaction;
		endif;
	endif;

	// if job.vehicleReleased = null or job.areWLEsAllStatus(WLE_UNACTIONED) then   // 28.11.2017 cnwma1 TFS #7591
	if job.vehicleReleased = null or job.areWLEsAllStatus(WLE_COMPLETED) = false then // TFS 36534
		app.msgBox(app.getErrorString1(CannotPrintRoadReceipt, job.jobId), 'Print Receipt', MsgBox_OK_Only + MsgBox_Stop_Icon);	
		//app.msgBox("You cannot print a receipt for this job until all jobs for the vehicle are complete","Receipt",MsgBox_Information_Icon);
		return;
	endif;
	
	create dialog transient;
	dialog.init(true, self.myTerminal.getConfig(GateReceiptCopies).Integer);
	dialog.centreWindow();
	
	if dialog.showModal &lt;&gt; MsgBox_Return_OK then
  		return;		
  	endif;
	app.mousePointer := MousePointer_HourGlass;	
	// consider changing this as printJadeReceipt has a Stop/Cancel dialog	
	app.myPassport.setMyTerminal(self.myTerminal);
	
	//14 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
	while true do
	
		app.myTrxCA.trxCreateRoadJobPrintReceipt(job, dialog.copies, dialog.printPreview, true,app.myPassport);
	
		if app.myPassport.trxCompletedOK then
			break;
		else
			theResult := app.showErrorWarningDialog('Road Receipt', app.myPassport, ErrWarnMode_Update);
			if app.myPassport.noErrors and theResult = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		
		break;
		
	endwhile;
	
epilog

	delete dialog;
	unlock(job);
	app.mousePointer := MousePointer_Default;

end;</source>
    </JadeMethod>
    <JadeMethod name="doSave" id="d1216402-dfac-4ee4-af47-62e1af5f1e57">
        <updating/>
        <source>doSave(): Boolean updating;
/*
Purpose:

Parameters:

Date		Who		Reason
16 Feb 2024	navnk30	ChangeRequest 62414: EUP | Retrospective Operations - [54177.050] - Road Exit
22 Aug 2024 navma1  Bug 65770: Exception on the Road Exit form when Processing Road Exit


*/
vars
	roadJob			: CM_RoadJob;
	userResponse	: Integer;
	theVehicle		: CM_Vehicle;	
	visit 			: CM_VehicleVisitRecord;	
	showWeighForm	: Boolean;	
	weighBridge		: CM_WeighBridgeObj;	
	retroDT,
	lastVvrDtlDT	: TimeStamp;
begin

	//cnwrd1 par 32415 - changed to do normal road exit process all the time, for now.
	if not app.myCurrentUserCan(self.myTerminal, PmGteRoadExitUpdate) then
		app.msgBox("You do not have permission to perform this task", "Road Exit", MsgBox_OK_Only);
		return false;
	endif;
	
	self.myCurrentObject := self.tblData.allSelectedObjects.last().CM_Object;
	
	if self.myCurrentObject &lt;&gt; null and global.isValidObject(self.myCurrentObject) then
		roadJob	:=	self.myCurrentObject.CM_RoadJob;
	endif;
	
	if roadJob = null then
		return false;
	endif;
	
	// Look thru all of its road jobs set and check if any of them still have any devices in their working devices IDs collection.
	if roadJob.status &lt;&gt; JOB_COMPLETE then
		if roadJob.allWorkingDeviceIDs.cnEcIsNotEmpty() then
			userResponse :=	app.msgBox(	"It appears that this job is still being worked, do you wish to continue ?",
								app.getString(Warning),
								MsgBox_Question_Mark_Icon + MsgBox_Yes_No);
			
			if userResponse &lt;&gt; MsgBox_Return_Yes then
				return false;
			endif;
		endif;
	endif;
	
	//08 Jul 2019	NDL	TFS 44965
	visit 		:= roadJob.myVehicleVisit; 
	theVehicle  := roadJob.myVehicle;
	
	if theVehicle &lt;&gt; null and visit &lt;&gt; null and visit.hasWeighInVVRD &lt;&gt; null then
		//check we have an inward weight, cos can't do two reading outward processing without one...
		weighBridge := self.myTerminal.allWeighBridges.getMyTwoReadingsWeighBridge();
		if weighBridge &lt;&gt; null then
			//we do have a 'two readings' weigh bridge, are the rest of the stars aligned.
			showWeighForm := visit.autoShowWeighBridgeAtGate();
			if showWeighForm then
				self.myAssistant.showWeighForm( self, theVehicle, null, null );
			endif;
		endif;
	endif;
	
	retroDT := null;													//22.08.2024 navma1 #65770
	if self.btnRetro.visible and self.btnRetro.enabled then				//16.02.2024 navnk30 #62414
		retroDT.setDate(self.txtRetroDate.getDate());
		retroDT.setTime(self.txtRetroTime.getTime());
		
		if retroDT.isValid then											//22.08.2024 navma1 #65770
			if visit &lt;&gt; null then
				lastVvrDtlDT := visit.allVehicleVisitRecordDetails.last.timeStart;
			endif;
			if lastVvrDtlDT.isValid and not retroDT.cnEcIsGreaterThanOrEqual(lastVvrDtlDT) then
				app.raiseCMException1(Before_Last_Transaction, lastVvrDtlDT.asStringJMT(), null, null);
			endif;
		endif;
	endif;
	
	//epr CCMS 1280 23/8/12 - wanted to be able to road exit after a warning
	while true do
		app.myTrxDA.trxRoadExit(roadJob, retroDT, app.myPassport);	//16.02.2024 navnk30 #62414
		
		if not app.myPassport.trxCompletedOK() then
			userResponse:=app.showErrorWarningDialog('Road Exit', app.myPassport, ErrWarnMode_AddUpdate+ ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
				userResponse = IDOK then
				app.myPassport.warningsAcknowledged     := true;
				continue;
			else
				return false;
			endif;
		endif;
		break;
	endwhile;
	
	return app.myPassport.trxCompletedOK();
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doSendInspection" id="0ad178ad-c02f-4ecc-b3fe-c002da5fc894">
        <updating/>
        <source>doSendInspection( _vvr : CM_VehicleVisitRecord) updating;
/*

Purpose:            

Parameters:            

Return Value:        

Date                Who        Reason
14 December 2022    navmp20    ChangeRequest 55580: EUP - Inspection App checks - Interface and MTN changes
14/02/2024			navcs2	   Bug 62454: FR | 53667 - Inspection App - Resend Message discrepancy

*/

vars
    vvr : CM_VehicleVisitRecord;
    theReturn : Integer;
begin
    vvr := _vvr;
    while true do
        app.myTrxUA.trxUpdateVVRInspection(vvr, app.myPassport);			// 14/02/2024	navcs2 Bug 62454
        if app.myPassport.trxCompletedOK then
            // Clear errors/warnings from form and err/warnings window
            self.clearErrorWarnings();
            global.beep;
            break;
        else
            theReturn := app.showErrorWarningDialog(app.getErrorString(Change_status), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
            if app.myPassport.noErrors and
               theReturn = IDOK then
                // there must have just been warnings that the user has acknowledged so ..
                app.myPassport.warningsAcknowledged    := true;
                continue;
            endif;
            self.setAllErrorWarnings(app.myPassport);    // copies errors to this form and shows in err/warnings window
            return;
        endif;
        break;
    endwhile;

epilog

end;</source>
        <Parameter name="_vvr" type="CM_VehicleVisitRecord"/>
    </JadeMethod>
    <JadeMethod name="doSendToReport" id="171c137d-99f5-47b3-85ac-2ff34e531613">
        <source>doSendToReport(_obj : Object);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 Aug 2025	navhl20 Story MTN-35650: TPT | Uploading of Photos into MTN Production | 2 | Thin Client Changes

*/

vars
	jrwReportName	: String;
	selectedOnly,
	printPreview	: Boolean;
	arrayCheck		: ObjectArray;
	pathList		: StringArray;
	outputType		: Integer;
	filePath		: String;
begin
	app.isReportWriter := true;
	create pathList transient;
	pathList.add( CM_JRWVehicleVisit::allVehicleVisitRecords.name );
	
	//Get the report we want to send our invoice items to and find out whether we want a print preview.
	if app.getReportToSendItems(CM_VehicleVisitView, pathList, selectedOnly , jrwReportName, printPreview, outputType, filePath) then
		//Have to ensure we don't have multiples so check this out here.
		create arrayCheck transient;
		arrayCheck.add(_obj);
		
		app.sendItemsToReport(CM_JRWVehicleVisit, arrayCheck, jrwReportName, printPreview, outputType, filePath);
	endif;
epilog
	delete arrayCheck;
	delete pathList;
	app.isReportWriter := false;
end;</source>
        <Parameter name="_obj" type="Object"/>
    </JadeMethod>
    <JadeMethod name="doShowCargoReview" id="f4e7e718-5aad-4c36-8cac-d0dd94559997">
        <source>doShowCargoReview();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23/02/2023	navkc1 CR 62580 Task 62581: UI - Road Exit Custom Document Details

*/

vars
	roadjob					: CM_RoadJob;
	cgReviewForm			: CMUI_CargoReview;
	criteriaLine			: CM_SelectorCriteriaLine;
	qdef					: CM_QueryDefinition;
	vvr						: CM_VehicleVisitRecord;
	criteriaLines			: CM_SelectorCriteriaLineArray;
	ti						: CM_TrackedItem;
	sa						: StringArray;
begin
	if self.tblData.allSelectedObjects.isEmpty() then
		return;
	endif;
	
	roadjob := self.tblData.allSelectedObjects.first().CM_RoadJob;
	
	if roadjob = null then
		return;
	endif;
	
	//ti := roadjob.getFirstTi();
	ti := roadjob.getFirstTi(false);	//27/05/2024	navkc1 Bug 64295
	
	vvr := roadjob.myVehicleVisit;
	
	if vvr = null then
		return;
	endif;
	
	cgReviewForm := app.loadForm(CMUI_CargoReview, CMUI_Assistant, true, true, false, self.getMyTerminal(), null).CMUI_CargoReview;
	
	if cgReviewForm = null then
		return;
	endif;
	
	qdef := app.myRoot.allQueryDefinitionObjects[CM_QueryDefinition.TrackedItem_Query_Type, CM_QueryDefinition.TrackedItem_Query_Mode];
	
	if qdef = null then
		return;
	endif;
	
	create criteriaLines transient;
	create sa transient; //27/05/2024	navkc1 Bug 64295
	
	sa.add(vvr.visitNumber);
	
	//criteriaLine := qdef.createCriteriaLine(CM_TrackedItem::getVehicleVisitNumber.name, CM_QueryOperator.Operator_Equal, vvr.visitNumber);
	criteriaLine := qdef.createCriteriaLine(CM_TrackedItem::getVehicleVisitNumber.name, CM_QueryOperator.Operator_Range, sa.asCSV(false)); //27/05/2024	navkc1 Bug 64295 - Make it the same as VehicleEnquiry screen
	criteriaLines.add(criteriaLine);
	
	criteriaLine := qdef.createCriteriaLine(CM_TrackedItem::site.name, CM_QueryOperator.Operator_Equal, TI_SITE_ONSITE_str);
	criteriaLines.add(criteriaLine);
	
	//26/03/2024	navkc1 Bug 63153
	if ti &lt;&gt; null then
		criteriaLine := null;
		if ti.isTrailer() then
			// ### TFS BUG 62837 11MAR2024 NAVAB1
			criteriaLine := qdef.createCriteriaLine(CM_TrackedItem::getOnboardStatus.name, CM_QueryOperator.Operator_Equal, app.getErrorString(Trailer));
		elseif ti.isMAFI() then
			criteriaLine := qdef.createCriteriaLine(CM_TrackedItem::getOnboardStatus.name, CM_QueryOperator.Operator_Equal, app.getErrorString(Mafi));
		endif;
		
		if criteriaLine &lt;&gt; null then
			criteriaLines.add(criteriaLine);
		endif;
	endif;
	
	cgReviewForm.createCriteriaLinesFromParent(criteriaLines);
	cgReviewForm.setParentForm(self);
	cgReviewForm.show();
	cgReviewForm.autoDoCustDocFromParent(); //23/02/2023	navkc1 CR 62580 Task 62581
	
epilog
	delete criteriaLines;
	delete sa;
end;</source>
    </JadeMethod>
