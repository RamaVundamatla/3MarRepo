        <updating/>
        <source>utlCreateWorkOrderSchedule(_pxySchedule : CM_WorkOrderSchedule; _schedule : CM_WorkOrderSchedule output; _woDetail : CM_WorkOrderTIDtl; _passport : CM_Passport input) updating;
// -----------------------------------------------------------------------------
// Created:		17 August 2009 by consw1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//
// -----------------------------------------------------------------------------

vars
	schedule : CM_WorkOrderSchedule;
begin
	self.initialiseActivity();
	app.setContinueCMExceptions(true);
	app.myValCA.valWorkOrderSchedule(_pxySchedule);
	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	
	app.setContinueCMExceptions(false);

	//exclusiveLock(_pxySchedule.myParent);
	
	create schedule persistent;
	
	exclusiveLock(schedule);
	_woDetail.addSchedule(schedule);
	schedule.setForCreate(_pxySchedule);	
	_schedule := schedule;

//	if _passport.noErrors then
//		self.myCreateAuditAgent.audCreateGeneric(_pxySchedule);
//	endif;
	
	if _passport.noErrors() then
		_schedule.myParent.causeEvent(_passport.myTerminal.getTerminalEvent(Event_WorkOrderSchedule_Update), false, _schedule);
		_passport.myTerminal.causeEvent(_passport.myTerminal.getTerminalEvent(Event_WorkOrderSchedule_Update), false, _schedule);
	endif;
epilog

end;</source>
