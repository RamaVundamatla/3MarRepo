	self.initDataExtractField(_fields, CM_TrackedItem.name, "importVoyageCode", fieldName, STRING, "Import Voyage Code", "Import voyage code", STRING, "Valid voyage code with a maximum length of 20");

	fieldName := "originalLoadPort";
	self.initDataExtractField(_fields, CM_TrackedItem.name, "originalLoadPort", fieldName, STRING, "Original Load Port", "Original load port", STRING, "Valid port code with a maximum length of 5");


epilog

