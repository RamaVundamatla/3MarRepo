<CollClass name="CM_CodeSet" id="13dc993a-7827-4aae-90e2-7c396d00e4c6">
    <memberType name="CM_Code"/>
    <superclass name="CM_ObjectSet"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="terminal"/>
    <JadeMethod name="getEntriesAsString" id="3de7e907-d6ba-4466-850e-6f58652e7084">
        <source>getEntriesAsString() : String;
// ---------------------------------------------------------------------------
// Created:		April  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 22 Dec 2010	cnwkpd1	PAR #26678 - Tidy up transient leaks
// ---------------------------------------------------------------------------

vars
	theCode : CM_Code;
	theCodeString,
	theString : String;
	iter01 : Iterator;
	invalidCode : Boolean;
begin
	on Exception do app.handleDeletedObject(exception, theCode, invalidCode);
	
	iter01 := self.createIterator;
	while iter01.next(theCode) do
		theCodeString:=theCode.code;
		if invalidCode then
			invalidCode:=false;
			continue;
		endif;
		theString := theString &amp; theCodeString &amp; ",";
	endwhile;
	theString := theString[1 : theString.length - 1];
	
	return theString;
	
epilog
	delete iter01;		// PAR #26678
	
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
</CollClass>
