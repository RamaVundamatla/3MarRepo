    <JadeMethod name="setValuesFromCMIF" id="c550ac56-aae9-4cf2-a43b-a2e8004468f5">
        <updating/>
        <source>setValuesFromCMIF(_cashReceipt : CM_CashReceipt; _controller : CMIF_CashReceiptEnqController) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02/05/2024	navkc1 CR63400 Task 63401: Jade - New REST API getProformaHeadersForDebtor

*/

vars
	cashReceipt : CM_CashReceipt;
	debtorType	: CM_DebtorType;
	id			: String;
	agent		: Object;
	terminal	: CM_Terminal;
begin
	cashReceipt := _cashReceipt;
	
	self.debtorId := cashReceipt.getDebtorAccountCode();
	self.businessUnitId := cashReceipt.getBankCode();
	self.receiptNumber := cashReceipt.sequenceNum;
	//self.effectiveDate := cashReceipt.getEffectiveDateLocalTZ().asStringJSON();
	 self.effectiveDate := cashReceipt.getEffectiveDateLocalTZ().asStringForWebInterface();//23/08/2024	navkc1 Bug 65781
	self.type := cashReceipt.getTypeString(null);
	self.taxValue := cashReceipt.taxValue1 + cashReceipt.taxValue2 + cashReceipt.taxValue3;
	//self.amountValue := cashReceipt.cashValue;
	//self.amountValue := cashReceipt.totalCargoCharges; //04/10/2024	navkc1	JIRA 33018
	self.amountValue   := cashReceipt.totalCargoCharges + cashReceipt.roundingDifference; //27/06/2025 NAVKC1 JIRA 35258 
	self.totalValue := self.taxValue + self.amountValue;
	self.bolNumber := cashReceipt.getBOLNumber();
	self.description := cashReceipt.getDescription();
	self.invoiceType := cashReceipt.getInvoiceTypeDesc();
	self.paymentType := app.paymentTypeEnumToString(cashReceipt.getPaymentType()); // NAVKC1 22/05/2024 DEFECT 64242
	//self.shipReleaseDate := cashReceipt.getShipReleaseDate().asStringJSON();
	self.shipReleaseDate := cashReceipt.getShipReleaseDate().asStringForWebInterface(); //23/08/2024	navkc1 Bug 65781
	self.vesselName := cashReceipt.getVesselName();
	self.voyageCode := cashReceipt.getVoyageCode();
	//self.voyageArrival := cashReceipt.getVoyageArrivalDateLocalTZ().asStringJSON();
	self.voyageArrival := cashReceipt.getVoyageArrivalDateLocalTZ().asStringForWebInterface(); //23/08/2024	navkc1 Bug 65781
	//self.voyageDeparture := cashReceipt.getVoyageSailingDateLocalTZ().asStringJSON();
	self.voyageDeparture := cashReceipt.getVoyageSailingDateLocalTZ().asStringForWebInterface(); //23/08/2024	navkc1 Bug 65781
	self.externalInvoiceNumber := cashReceipt.externalInvoiceNumber;
	//self.dateTime := cashReceipt.createdTime.asStringJSON(); // NAVKC1 22/05/2024 DEFECT 64242
	self.dateTime := cashReceipt.createdTime.asStringForWebInterface(); //23/08/2024	navkc1 Bug 65781
	
	debtorType := _controller.myCashDebtorType;
	agent := cashReceipt.myAgent;
	
	if debtorType &lt;&gt; null and (agent &lt;&gt; null and app.isValidObject(agent)) then
		if debtorType.code = "SDT2" then
			id := agent.CM_ConsigneeConsignor.code;
		elseif debtorType.code = "SDT3" then
			id := agent.CM_ConsigneeConsignor.code;
		elseif debtorType.code = "SDT4" then
			id := agent.CM_Operator.code;
		elseif debtorType.code = "SDT6" then
			id := agent.CM_CustomsAgent.code;
		elseif debtorType.code = "SDT7" then
			id := agent.CM_ConsigneeConsignor.code;
		endif;
		
		self.agentId := id;
	endif;
	
	//8/07/2024	navkc1 CR 64835 Task 64850
	terminal := _controller.myTerminal;
	if terminal = null then
		terminal := cashReceipt.myTerminal;
	endif;
	
	//8/07/2024	navkc1 CR 64835 Task 64850 - set currency code
	if terminal &lt;&gt; null then
		//self.currencyCode := terminal.getConfig(CurrencyCodeForAPI).asStringJSON();
		self.currencyCode := terminal.getConfig(CurrencyCodeForAPI).asString(); //23/08/2024	navkc1 Bug 65781
	endif;
epilog

end;</source>
        <Parameter name="_cashReceipt" type="CM_CashReceipt"/>
        <Parameter name="_controller" type="CMIF_CashReceiptEnqController"/>
    </JadeMethod>
    <JadeMethod name="setValuesFromCMIF2" id="4da1f693-13ed-4804-ad06-8ce663a527af">
        <updating/>
        <source>setValuesFromCMIF2(_cashReceipt : CM_CashReceipt; _controller : CMIF_CashInvoiceProformaCtrl) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
//11/07/2024	navkc1 CR 64837 Task 64851: Jade - New API putProformaForExternal

*/

vars
	cashReceipt : CM_CashReceipt;
	terminal	: CM_Terminal;
begin
	cashReceipt := _cashReceipt;
	
	//self.serviceCode := null;
	self.debtorId := cashReceipt.getDebtorAccountCode();
	self.businessUnitId := cashReceipt.getBankCode();
	self.receiptNumber := cashReceipt.sequenceNum;
	//self.effectiveDate := cashReceipt.getEffectiveDateLocalTZ().asStringJSON();
	self.effectiveDate := cashReceipt.getEffectiveDateLocalTZ().asStringForWebInterface(); //23/08/2024	navkc1 Bug 65781
	self.type := cashReceipt.getTypeString(null);
	self.taxValue := cashReceipt.taxValue1 + cashReceipt.taxValue2 + cashReceipt.taxValue3;
	//self.amountValue := cashReceipt.totalCargoCharges;
	//self.amountValue := cashReceipt.totalCargoCharges; //04/10/2024	navkc1	JIRA 33018 - This value to be amount including invoice lines
	self.amountValue   := cashReceipt.totalCargoCharges + cashReceipt.roundingDifference; //27/06/2025 NAVKC1 JIRA 35258 
	self.totalValue := self.taxValue + self.amountValue;
	self.bolNumber := cashReceipt.getBOLNumber();
	self.description := cashReceipt.getDescription();
	self.invoiceType := cashReceipt.getInvoiceTypeDesc();
	self.paymentType := app.paymentTypeEnumToString(cashReceipt.getPaymentType());
	//self.shipReleaseDate := cashReceipt.getShipReleaseDate().asStringJSON();
	self.shipReleaseDate := cashReceipt.getShipReleaseDate().asStringForWebInterface(); //23/08/2024	navkc1 Bug 65781
	self.vesselName := cashReceipt.getVesselName();
	self.voyageCode := cashReceipt.getVoyageCode();
	//self.voyageArrival := cashReceipt.getVoyageArrivalDateLocalTZ().asStringJSON();
	self.voyageArrival := cashReceipt.getVoyageArrivalDateLocalTZ().asStringForWebInterface(); //23/08/2024	navkc1 Bug 65781
	//self.voyageDeparture := cashReceipt.getVoyageSailingDateLocalTZ().asStringJSON();
	self.voyageDeparture := cashReceipt.getVoyageSailingDateLocalTZ().asStringForWebInterface(); //23/08/2024	navkc1 Bug 65781
	self.externalInvoiceNumber := cashReceipt.externalInvoiceNumber;
	//self.dateTime := cashReceipt.createdTime.asStringJSON();
	self.dateTime := cashReceipt.createdTime.asStringForWebInterface(); //23/08/2024	navkc1 Bug 65781
	
	self.agentId := _controller.myDebtorAgentId;
	
	self.isPaymentAllowed := _controller.isPaymentAllowed; //07/01/2025	navkc1 JIRA Bug MTN-33764
	
	terminal := _controller.myTerminal;
	if terminal = null then
		terminal := cashReceipt.myTerminal;
	endif;
	
	if terminal &lt;&gt; null then
		//self.currencyCode := terminal.getConfig(CurrencyCodeForAPI).asStringJSON();
		self.currencyCode := terminal.getConfig(CurrencyCodeForAPI).asString(); //23/08/2024	navkc1 Bug 65781
	endif;
epilog

end;</source>
        <Parameter name="_cashReceipt" type="CM_CashReceipt"/>
        <Parameter name="_controller" type="CMIF_CashInvoiceProformaCtrl"/>
    </JadeMethod>
</Class>
