    <JadeMethod name="openPackageConfigForm" id="f13c5544-009d-47f7-aaf7-e21eb3f9f263">
        <updating/>
        <source>openPackageConfigForm(_isEdit : Boolean) protected, updating;
// -------------------------------------------
// Created 30 November 2005 by cnwdvb1
// -------------------------------------------
vars

	form			: CMUI_PackageConfigForm;
	package			: CM_Package;

begin

	package := self.myCurrentPackage;
	
	if package = null and _isEdit then
		return;
	endif;
	
	form := app.loadForm(CMUI_PackageConfigForm, CMUI_Assistant, false, false, false, null, null).CMUI_PackageConfigForm;

	if form = null then
		return;
	endif;

	form.setAttributes(_isEdit, 0, package);
	form.centreWindow;

	form.showModal;
	

end;</source>
        <access>protected</access>
        <Parameter name="_isEdit" type="Boolean"/>
    </JadeMethod>
