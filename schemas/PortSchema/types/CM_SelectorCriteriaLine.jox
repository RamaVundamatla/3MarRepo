    <JadeMethod name="set" id="8b8c789b-f82b-4112-858f-290c1a836c0c">
        <updating/>
        <source>set(_property : CM_QueryProperty; _operator : CM_QueryOperator; 
			_unavailableAtRunTime : Boolean) updating;
// -----------------------------------------------------------------------------
// Created:		08 May 2002 by cnwka1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	---------------------------------------------
//
// -----------------------------------------------------------------------------
begin
	self.myQueryProperty 		:= _property;
	self.myQueryOperator 		:= _operator;
	self.propName 				:= _property.propertyName;
	self.propClassName 			:= _property.propertyClassName;
	self.isUnavailableAtRunTime := _unavailableAtRunTime;

end;</source>
        <Parameter name="_property" type="CM_QueryProperty"/>
        <Parameter name="_operator" type="CM_QueryOperator"/>
        <Parameter name="_unavailableAtRunTime" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setDetailsOnClone" id="c834b948-4eda-48dc-8d00-e55e3f63b6d4">
        <updating/>
        <source>setDetailsOnClone(	_isUnavailableAtRunTime : Boolean;
					_myQueryProperty : CM_QueryProperty;
					_myQueryOperator : CM_QueryOperator;
					_propName : String;
					_propClassName : String
					) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
26 July 2011	cnwndl1	Initial creation	Par 27890

*/

vars

	def : CM_QueryDefinition;
	realProp : CM_QueryProperty;
	yaType : Integer;

begin

	self.isUnavailableAtRunTime := _isUnavailableAtRunTime;
	self.myQueryProperty := _myQueryProperty;
	self.myQueryOperator := _myQueryOperator;
	self.propName := _propName;
	self.propClassName := _propClassName;
	
	//12 Jun 2015	NDL	Par 36338
	if _propClassName = CM_Container.name then
		def := CM_QDefContainer.firstInstance;
	elseif _propClassName = CM_TrackedItem.name then
		def := CM_QDefTrackedItem.firstInstance;
	endif;

	if def &lt;&gt; null and _myQueryProperty &lt;&gt; null then
		realProp := def.allQueryProperties.getAtKey(_propName);
		if realProp &lt;&gt; null then
			yaType := realProp.allocationAttribute;
			if yaType &gt; 0 then
				self.myQueryProperty.allocationAttribute := yaType;
			endif;
		endif;
	endif;

epilog

end;</source>
        <Parameter name="_isUnavailableAtRunTime" type="Boolean"/>
        <Parameter name="_myQueryProperty" type="CM_QueryProperty"/>
        <Parameter name="_myQueryOperator" type="CM_QueryOperator"/>
        <Parameter name="_propName" type="String"/>
        <Parameter name="_propClassName" type="String"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="805f1cfe-bbdd-4a5c-853e-a014ea5371f4">
        <updating/>
        <source>setForUpdate(_pxySelectorLine : CM_SelectorCriteriaLine input) updating;
// ---------------------------------------------------------------------------
// Created:     17 April 2003		cnwth2	
//
// Purpose:     Here we are saving self persistently - and as such need to clone
//				the myQueryProperty and myQueryOperator objects referenced by the proxy
//				persistently
// Changed On	By			Reason
// ----------   ----------  --------------------------------------------------
// 08/05/2013	cnwdap1		PAR #31155 CCMS SFW 1321 Imperial Measurements
vars
	realProperty			: CM_QueryProperty;
	realOperator			: CM_QueryOperator;
	
begin
	//no need to clone refs for query property - this will just be used to 'lookup'
	//an existing transient when the query is selected
	// PAR #31155 except for measurement type on decimal property, just just clone references on all 
	realProperty := _pxySelectorLine.myQueryProperty.cloneSelf(false);
	_pxySelectorLine.myQueryProperty.cloneReferences(realProperty);			// PAR #31155
	
	realOperator := _pxySelectorLine.myQueryOperator.cloneSelf(false);
	_pxySelectorLine.myQueryOperator.cloneReferences(realOperator);
	
	self.isUnavailableAtRunTime := _pxySelectorLine.isUnavailableAtRunTime;
	self.myQueryProperty := realProperty;
	self.myQueryOperator := realOperator;
	
	self.propName := realProperty.propertyName;
	self.propClassName := realProperty.propertyClassName;
end;</source>
        <Parameter name="_pxySelectorLine" type="CM_SelectorCriteriaLine" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setForUpdateForRT" id="50010afa-9f51-422c-ab7a-5d79918b5ba4">
        <updating/>
        <source>setForUpdateForRT( _pxySelectorLine : CM_SelectorCriteriaLine input ) updating;
// ---------------------------------------------------------------------------
// Created:     08 May 2008		cnwvu1	
//
// Purpose:     the same as setForUpdate - the difference: need to clone
//				the myQueryProperty and myQueryOperator objects as transient
// ---------------------------------------------------------------------------
vars
	realProperty			: CM_QueryProperty;
	realOperator			: CM_QueryOperator;
	
begin
	//no need to clone refs for query property - this will just be used to 'lookup'
	//an existing transient when the query is selected
	realProperty := _pxySelectorLine.myQueryProperty.cloneSelf( true );
	
	realOperator := _pxySelectorLine.myQueryOperator.cloneSelf( true );
	_pxySelectorLine.myQueryOperator.cloneReferences(realOperator);
	
	self.isUnavailableAtRunTime := _pxySelectorLine.isUnavailableAtRunTime;
	self.myQueryProperty := realProperty;
	self.myQueryOperator := realOperator;
	
	self.propName := realProperty.propertyName;
	self.propClassName := realProperty.propertyClassName;
end;</source>
        <Parameter name="_pxySelectorLine" type="CM_SelectorCriteriaLine" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setMyCriteriaLineHolder" id="a0c22711-48a7-4e0a-b0e6-65eedebc2a4f">
        <updating/>
        <source>setMyCriteriaLineHolder(_criteriaLineHolder : CM_QueryCriteriaLineHolder input) updating;
// ---------------------------------------------------------------------------
// Created:     20 January 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
//25 Nov 2019	jlger1	 TFS 47457
vars

begin
	if (_criteriaLineHolder = null or not _criteriaLineHolder.allCriteriaByPropertyName.includesKey(self.propName, self.propClassName)) then
		self.myCriteriaLineHolder := _criteriaLineHolder;
	endif;

end;</source>
        <Parameter name="_criteriaLineHolder" type="CM_QueryCriteriaLineHolder" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setUnavailableAtRunTime" id="2cbe96d3-e69e-4035-ad47-72606ea1bee8">
