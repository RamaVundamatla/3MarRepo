        <controlMethod name="MenuItem::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>mnuCargoEdit_click(menuItem: MenuItem input) updating;
// ---------------------------------------------------------------------------
// Created:		November 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

	objArray : CM_ObjectArray;						//+cnwml2 PAR19627
begin
	
	create objArray transient;
	self.getSelectedMenuTIs(objArray);

	
	if objArray.size = 1 then
		self.doMnuEditClick(menuItem);
	elseif objArray.isEmpty then
		return;								//should never happen
	else
		self.myAssistant.showCargoEnquiryForTIs(objArray[1].CM_TrackedItem, objArray, self.myMasterMenuAction, true);
	endif;
	
epilog
	delete objArray;	

end;</source>
        <Parameter name="menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="mnuCargoEnquiry_click" id="04b49095-c6db-47f3-82d5-057f4182dceb">
        <controlMethod name="MenuItem::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>mnuCargoEnquiry_click(menuItem: MenuItem input) updating;
// ---------------------------------------------------------------------------
// Created:		March  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	objArray : CM_ObjectArray;						//+cnwml2 PAR19627
begin
	
	//+cnwml2 PAR19627 start
	create objArray transient;
	self.getSelectedMenuTIs(objArray);

	
	if objArray.size = 1 then
		self.myAssistant.showCargoEnquiryForm(	objArray[1].CM_TrackedItem,
												self.myMasterMenuAction,
												true,				// thumbnail only
												false );			// not in edit mode
	elseif objArray.isEmpty then
		return;								//should never happen
	else
		self.myAssistant.showCargoEnquiryForTIs(objArray[1].CM_TrackedItem, objArray, self.myMasterMenuAction, false);
	endif;
	//+cnwml2 PAR19627 end
	
epilog
	delete objArray;				//+cnwml2 PAR19627
end;</source>
