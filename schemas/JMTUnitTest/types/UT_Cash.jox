    <JadeMethod name="cashTestMultipleReceipts4" id="417d9014-046b-4ec5-9d66-cac50c1b2c54">
        <updating/>
        <source>cashTestMultipleReceipts4(_id1 : String; _id2 : String; _drTerm1 : CM_DebtorTerminal; _type : Integer) updating, protected;
/*
Purpose - 	Test pay cash for receive whilst still on ship (TI1). Then test split sand merges and road exits.

				Create cargo on ship (break bulk splittable)
				Receive ship matched ti invoice line calc type Cargo_Quantity.
				
				Pay cash for cargo on ship.
				Then discharge part  (TI2) and release, should release no errors.
				Then discharge part (TI3). Then move part of TI3 to a different location (TI4).
				Release TI4, should release no errors.
				Then discharge part merging into what is left of TI3.
				Release TI3, should release no errors.
				

TEST calc type Cargo Quantity, pay cash on ship then discharge part. The split should have proportional cash payment that matches its own invoice line
				receive ship only.
Who - NAVAB1
Date - 02MAY2025
ADO - JIRA 34760
*/

constants

vars
	now			: TimeStamp;
	cargoId		: String;
	msg			: String;
	invoiceEveryReceipt	: Boolean;
	
	cashReceipt1 : CM_CashReceipt;
	paymentMeth : CM_PaymentMethod;

	invAssistant	: Object;
onsiteTi2,
	onsiteTi1,
	cashTI	: CM_TrackedItem;
	vvrOut	: CM_VehicleVisitRecord;
	carrier	: CM_Carrier;
	truckOut	: CM_Vehicle;

	nowDate,
	baseDate : Date;
	cashToPay,
	cashTotal	: Decimal[23,6];
	
	debtorType	: CM_DebtorType;
	customsAgent	: CM_CustomsAgent;
	operator		: CM_Operator;
	debtor 		: CM_DebtorNode;
	
	allTIs 		: CM_TISet;
	obj				: Object;
	allAgents		: ObjectArray;
	agent,
	agent1	: CM_CashInvoiceProformaAgent;
	type : CM_TerminalAreaType;
	blockStack1,
	blockStack2	: CM_BlockStack;
	chequeBank : String;
	chequeBranch : String;
	chequeNumber : String;
	chequeDate : Date;
	cashId1,
	cashId2,
	cashId3,
	cashId4 : String;
	
	effectiveDate : Date;
	externalInvoiceNumber,
	externalReferenceNumber : String;
	ct : CM_CargoType;
	port : CM_Port;
begin
	msg := method.name;
	if self.myTerminal.getConfig(CashInvoiceEveryReceipt).Boolean then
		invoiceEveryReceipt := true;
	endif;

	//self.assertTrueMsg(ct &lt;&gt; null, "Cargo Type 15104 - UTBY is null");
	if self.opts.includesKey("CargoType") then
		ct := self.opts.obj("CargoType").CM_CargoType;
	endif;
	self.assertNotNullMsg(ct, "Failed to get cargo Type");
	
	port := app.myRoot.allPorts["NZAKL"];
	self.assertTrueMsg(port &lt;&gt; null, "port is null");
	
	type := app.myRoot.allTerminalAreaTypes.getAtKey(1); // Block Stack
	blockStack1 := self.myTerminal.allTerminalAreasByTypeId.getAtKey( type.type, "UT_BS1").CM_BlockStack;
	self.assertTrueMsg(blockStack1 &lt;&gt; null, "Block Stack UT_BS1 not found...");
	blockStack2 := self.myTerminal.allTerminalAreasByTypeId.getAtKey( type.type, "UT_BS2").CM_BlockStack;
	self.assertTrueMsg(blockStack2 &lt;&gt; null, "Block Stack UT_BS2 not found...");
	// use an operator with a known non-cash debtor
	operator := self.getOperator("UTC1");
	if operator = null then
		operator := self.addOperatorSimple("UTC1", "Cash Test Operator");
	endif;
	
	cargoId := _id1;
	cashTI := self.createGCOnShip(null,cargoId, ct,operator,  self.myVoyage,port , 1000 );
	self.assertTrueMsg(cashTI &lt;&gt; null, msg &amp; " On Ship Cargo 1 '" &amp; cargoId &amp; "' not created...");

	create allTIs transient;
	allTIs.add(cashTI);
	// back-date the transactions to get storage
	baseDate := nowDate - 20;
	self.setTransactionDate(cashTI, baseDate);
	
	
	debtorType := app.myRoot.allDebtorTypes["SDT6"];	// customs agent
	customsAgent := app.myRoot.allCustomsAgents['UTCA1'];
	debtor := customsAgent.myDebtor;
	self.applyAgentToCargo(allTIs, debtorType, customsAgent);

	create allAgents transient;
	self.opts.purge();
	self.opts.addAssoc("UseProformaConfig",true);

	agent1 := self.createProformaAgent(now, cashTI);
	allAgents.add(agent1);
	
	cashTotal := agent1.cashPayments;
	cashToPay := agent1.invoicedCashCharges + agent1.estimatedCashCharges - cashTotal;
	
	paymentMeth := app.myRoot.allPaymentMethods[PayMethName];
	if paymentMeth = null then
		paymentMeth := CM_PaymentMethod.firstInstance;
	endif;
	
	// first receipt is for the pro forma only
	//  deselect the invoice lines
	cashToPay := 0;
	foreach obj in allAgents do
		agent := obj.CM_CashInvoiceProformaAgent;
		agent.allCurrentInvLines.clear(); // TFS 45953

		cashToPay := cashToPay + agent.getTotal();
	endforeach;

	cashReceipt1 := self.createBOLCashReceipt(	paymentMeth,	// _payMeth : CM_PaymentMethod;
					cashToPay,				// _amount : Decimal;
					chequeBank,			// _chequeBank : String;
					chequeBranch,		// _chequeBranch : String;
					chequeNumber,		// _chequeNumber : String;
					chequeDate,			// _chequeDate : Date;
					cashId1,			// _cashId1,
					cashId2,			// _cashId2,
					cashId3,			// _cashId3,
					cashId4,			// _cashId4 : String;
					0,					// _payment1 : Decimal;
					0,					// _payment2 : Decimal;
					effectiveDate,		// _effectiveDate : Date;
					externalInvoiceNumber,	// _externalInvoiceNumber,
					externalReferenceNumber,	// _externalReferenceNumber : String;
					cashToPay,
					cashTotal,
					self.myVoyage,
					_drTerm1,			// _drTerm : CM_DebtorTerminal;
					0,
					0,
					0,
					null,
					allAgents,			// _agents : ObjectArray
					"",					// _taxCode1,
					"",					// _taxCode2,
					""					// _taxCode3: String
					);
	self.assertTrueMsg(cashReceipt1 &lt;&gt; null, msg &amp; " Cash Receipt 1 for on ship cargo not created...");

	// move the second container to get some current charges
	self.opts.purge();
	self.opts.addAssoc("TotalQuantity",1000); // Move 1000
	self.move(cashTI, blockStack2);

//	onsiteTi1 := self.myTerminal.allOnsiteTIsByCargoTypeId[ct.id, _id1];
	
	onsiteTi1 := blockStack2.getTiById(_id1);  // ### JIRA 35968 10SEP2025 NAVAB1
	self.assertTrueMsg(onsiteTi1 &lt;&gt; null, "OnsiteTi1 is null");
	self.assertTrueMsg(onsiteTi1.totalQuantity = 1000, "OnsiteTi1 sbe 1000");
	self.assertTrueMsg(onsiteTi1.allCashPayments.isNotEmpty(), "OnsiteTi1 should have cash payments");
	
	
	// gate first container out
	// create carrier and truck
	self.deleteVehicle(VehicleNumOut);
	carrier := self.addCarrier(CarrierName, CarrierName, self.allEmails, false, true, true, self.myDebtor1);
	self.assertNotNull(carrier);
	truckOut := self.addVehicle(VehicleNumOut, carrier, self.myTerminal);
	self.assertTrueMsg(truckOut &lt;&gt; null, "Truck not created...");
	// Clear all the stops
	self.deleteStops(onsiteTi1);

	vvrOut := self.createVVRBBlk( truckOut, onsiteTi1, ct );
	self.assertTrueMsg(vvrOut &lt;&gt; null, msg &amp; " Vehicle Visit Record not created...");
	
	self.gateInTruck( vvrOut, false );
	
	self.workTruck( vvrOut, 2 );

	self.gateOutTruck( vvrOut, false ); 
	
	self.deleteVVR(vvrOut);
	
	self.assertTrueMsg(onsiteTi1.isOffSite, "onsiteTi1 should be Offsite");
	
	// ################### NEXT PART FROM SHIP
	self.opts.purge();
	self.opts.addAssoc("TotalQuantity",1000); // Move 1000
	self.move(cashTI, blockStack2);

	//onsiteTi1 := self.myTerminal.allOnsiteTIsByCargoTypeId[ct.id, _id1];
	onsiteTi1 := blockStack2.getTiById(_id1);  // ### JIRA 35968 10SEP2025 NAVAB1
	
	onsiteTi2 := onsiteTi1;
	self.assertTrueMsg(onsiteTi1 &lt;&gt; null, "OnsiteTi1 is null");
	self.assertTrueMsg(onsiteTi1.totalQuantity = 1000, "OnsiteTi1 sbe 1000");
	self.assertTrueMsg(onsiteTi1.allCashPayments.isNotEmpty(), "OnsiteTi1 should have cash payments");
	
	// ################### NEXT PART SPLIT only release part of the TI discharged
	self.opts.purge();
	self.opts.addAssoc("TotalQuantity",500); // Move 500
	self.move(onsiteTi1, blockStack1);

	//onsiteTi1 := blockStack1.myLocationsController.allTrackedItems.first;
	onsiteTi1 := blockStack1.getTiById(_id1);  // ### JIRA 35968 10SEP2025 NAVAB1
	
	self.assertTrueMsg(onsiteTi1 &lt;&gt; null, "OnsiteTi1 is null");
	self.assertTrueMsg(onsiteTi1.totalQuantity = 500, "OnsiteTi1 sbe 500");
	self.assertTrueMsg(onsiteTi1.allCashPayments.isNotEmpty(), "OnsiteTi1 should have cash payments");
	
	// gate first container out
	// create carrier and truck
	self.deleteVehicle(VehicleNumOut);
	carrier := self.addCarrier(CarrierName, CarrierName, self.allEmails, false, true, true, self.myDebtor1);
	self.assertNotNull(carrier);
	truckOut := self.addVehicle(VehicleNumOut, carrier, self.myTerminal);
	self.assertTrueMsg(truckOut &lt;&gt; null, "Truck not created...");
	// Clear all the stops
	self.deleteStops(onsiteTi1);

	vvrOut := self.createVVRBBlk( truckOut, onsiteTi1, ct );
	self.assertTrueMsg(vvrOut &lt;&gt; null, msg &amp; " Vehicle Visit Record not created...");
	
	self.gateInTruck( vvrOut, false );
	
	self.workTruck( vvrOut, 2 );

	self.gateOutTruck( vvrOut, false ); 

	self.assertTrueMsg(onsiteTi1.isOffSite, "onsiteTi1 should be Offsite");
	self.assertTrueMsg(onsiteTi2.totalQuantity = 500, "OnsiteTi2 sbe 500, is " &amp; onsiteTi2.totalQuantity.String);
	
	// ################### NEXT PART FROM SHIP - ceates a merge
	self.opts.purge();
	self.opts.addAssoc("TotalQuantity",1000); // Move 1000
	self.move(cashTI, blockStack2);

//	onsiteTi1 := self.myTerminal.allOnsiteTIsByCargoTypeId[ct.id, _id1];
	onsiteTi1 := blockStack2.getTiById(_id1);  // ### JIRA 35968 10SEP2025 NAVAB1
	self.assertTrueMsg(onsiteTi1 &lt;&gt; null, "OnsiteTi1 is null");
	self.assertTrueMsg(onsiteTi1.totalQuantity = 1500, "OnsiteTi1 sbe 1500, is " &amp; onsiteTi1.totalQuantity.String);
	self.assertTrueMsg(onsiteTi1.allCashPayments.isNotEmpty(), "OnsiteTi1 should have cash payments");
	
	self.deleteVehicle(VehicleNumOut);
	carrier := self.addCarrier(CarrierName, CarrierName, self.allEmails, false, true, true, self.myDebtor1);
	self.assertNotNull(carrier);
	truckOut := self.addVehicle(VehicleNumOut, carrier, self.myTerminal);
	self.assertTrueMsg(truckOut &lt;&gt; null, "Truck not created...");
	// Clear all the stops
	self.deleteStops(onsiteTi1);

	vvrOut := self.createVVRBBlk( truckOut, onsiteTi1, ct );
	self.assertTrueMsg(vvrOut &lt;&gt; null, msg &amp; " Vehicle Visit Record not created...");
	
	self.gateInTruck( vvrOut, false );
	
	self.workTruck( vvrOut, 2 );

	self.gateOutTruck( vvrOut, false ); 

	self.assertTrueMsg(onsiteTi1.isOffSite, "onsiteTi1 should be Offsite");

epilog
	if allAgents &lt;&gt; null then
		allAgents.purge();
	endif;
	delete allAgents;
	delete allTIs;
	delete invAssistant;
end;</source>
        <access>protected</access>
        <Parameter name="_id1" type="String"/>
        <Parameter name="_id2" type="String"/>
        <Parameter name="_drTerm1" type="CM_DebtorTerminal"/>
        <Parameter name="_type" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="cashTestMultipleReceipts5" id="7bfb331c-2abd-451d-bbb9-93da10bea3f2">
        <updating/>
        <source>cashTestMultipleReceipts5(_id1 : String; _id2 : String; _drTerm1 : CM_DebtorTerminal; _type : Integer) updating, protected;
/*
Purpose - 	Test pay cash for receive whilst still on ship (TI1). Then test split sand merges and road exits.

				Create cargo on ship (break bulk splittable)
				Receive ship matched ti invoice line calc type Cargo_Quantity.
				
				Pay cash for cargo on ship.
				Then discharge part  (TI2) and release, should release no errors.
				Then discharge part (TI3). Then move part of TI3 to a different location (TI4).
				Release TI4, should release no errors.
				Then discharge part merging into what is left of TI3.
				Release TI3, should release no errors.
				

TEST calc type Cargo Quantity, pay cash on ship then discharge part. The split should have proportional cash payment that matches its own invoice line
				receive ship only.
Who - NAVAB1
Date - 16MAY2025
ADO - JIRA 34909
*/

constants

vars
	now			: TimeStamp;
	cargoId		: String;
	msg			: String;
	invoiceEveryReceipt	: Boolean;
	
	cashReceipt1 : CM_CashReceipt;
	paymentMeth : CM_PaymentMethod;

	invAssistant	: Object;
	onsiteTi2,
	onsiteTi1,
	cashTI	: CM_TrackedItem;

	nowDate,
	baseDate : Date;
	cashToPay,
	cashTotal	: Decimal[23,6];
	
	customsAgent	: CM_CustomsAgent;
	operator		: CM_Operator;
	debtor 		: CM_DebtorNode;
	
	allTIs 		: CM_TISet;
	type : CM_TerminalAreaType;
	blockStack1,
	blockStack2	: CM_BlockStack;
	chequeBank : String;
	chequeBranch : String;
	chequeNumber : String;
	chequeDate : Date;
	cashId1,
	cashId2,
	cashId3,
	cashId4 : String;
	allAgents		: ObjectArray;
	agent1	: CM_CashInvoiceProformaAgent;
	
	effectiveDate : Date;
	externalInvoiceNumber,
	externalReferenceNumber : String;
	ct : CM_CargoType;
	port : CM_Port;
	invLine : CM_InvoiceLine;
	realCashPay, pxyCashPay : CM_CashPayment;
begin
	msg := method.name;
	if self.myTerminal.getConfig(CashInvoiceEveryReceipt).Boolean then
		invoiceEveryReceipt := true;
	endif;
	
	//self.myTerminal.setConfig(InvoiceRoundLineTotal,2);
	self.setTerminalConfig(InvoiceRoundLineTotal, 2);

	//self.assertTrueMsg(ct &lt;&gt; null, "Cargo Type 15104 - UTBY is null");
	if self.opts.includesKey("CargoType") then
		ct := self.opts.obj("CargoType").CM_CargoType;
	endif;
	self.assertNotNullMsg(ct, "Failed to get cargo Type");
	
	port := app.myRoot.allPorts["NZAKL"];
	self.assertTrueMsg(port &lt;&gt; null, "port is null");
	
	type := app.myRoot.allTerminalAreaTypes.getAtKey(1); // Block Stack
	blockStack1 := self.myTerminal.allTerminalAreasByTypeId.getAtKey( type.type, "UT_BS1").CM_BlockStack;
	self.assertTrueMsg(blockStack1 &lt;&gt; null, "Block Stack UT_BS1 not found...");
	blockStack2 := self.myTerminal.allTerminalAreasByTypeId.getAtKey( type.type, "UT_BS2").CM_BlockStack;
	self.assertTrueMsg(blockStack2 &lt;&gt; null, "Block Stack UT_BS2 not found...");
	// use an operator with a known non-cash debtor
	operator := self.getOperator("UTC1");
	if operator = null then
		operator := self.addOperatorSimple("UTC1", "Cash Test Operator");
	endif;
	
	cargoId := _id1;
	cashTI := self.createGCOnShipQWV(null,cargoId, ct,operator,  self.myVoyage,port , 40000, 67, 7 );
	
	self.assertTrueMsg(cashTI &lt;&gt; null, "On Ship Cargo 1 '" &amp; cargoId &amp; "' not created...");
	self.assertTrueMsg(cashTI.totalQuantity = 7,  "On Ship Cargo 1 '" &amp; cargoId &amp; "' wrong quantity SBE 7 is " &amp; cashTI.totalQuantity.String);
	self.assertTrueMsg(cashTI.totalVolume = 67,  "On Ship Cargo 1 '" &amp; cargoId &amp; "' wrong volume SBE 67 is " &amp; cashTI.totalVolume.String);
	self.assertTrueMsg(cashTI.totalWeight = 40000,  "On Ship Cargo 1 '" &amp; cargoId &amp; "' wrong weight SBE 40000 is " &amp; cashTI.totalWeight.String);

	customsAgent := app.myRoot.allCustomsAgents['UTCA1'];
	debtor := customsAgent.myDebtor;
	beginTransaction;
	cashTI.setPropertyValue("myCustomsAgent",customsAgent);
	commitTransaction;
	// ### MOVE PART
	self.opts.purge();
	self.opts.addAssoc("TotalQuantity",4); // Move 4
	self.move(cashTI, blockStack2);

	onsiteTi1 := self.myTerminal.allOnsiteTIsByCargoTypeId[ct.id, _id1];
	self.assertTrueMsg(onsiteTi1 &lt;&gt; null, "OnsiteTi1 is null");
	self.assertTrueMsg(onsiteTi1.totalQuantity = 4, "OnsiteTi1 sbe 4");
	self.assertTrueMsg(onsiteTi1.invoiceLines.isNotEmpty(), "OnsiteTi1 should have invoice line");
	self.assertTrueMsg(onsiteTi1.invoiceLines.size = 1, "OnsiteTi1 should have 1 invoice line");
	invLine := onsiteTi1.invoiceLines.first;
	self.assertTrueMsg(invLine &lt;&gt; null, "OnsiteTi1 has no invoice line");
	self.assertTrueMsg(invLine.invoiceLineDesc.narration =  "UT_LneSplitCsh", "OnsiteTi1 has wrong invoice line type");
	
	
	// ### MOVE REST - merge
	self.opts.purge();
	self.opts.addAssoc("TotalQuantity",3); // Move 3
	self.move(cashTI, blockStack2);

	onsiteTi1 := self.myTerminal.allOnsiteTIsByCargoTypeId[ct.id, _id1];
	self.assertTrueMsg(onsiteTi1 &lt;&gt; null, "OnsiteTi1 is null");
	self.assertTrueMsg(onsiteTi1.totalQuantity = 7, "OnsiteTi1 sbe 7");
	self.assertTrueMsg(onsiteTi1.invoiceLines.isNotEmpty(), "OnsiteTi1 should have invoice line");
	self.assertTrueMsg(onsiteTi1.invoiceLines.size = 2, "OnsiteTi1 should have 2 invoice line");
	invLine := onsiteTi1.invoiceLines.first;
	self.assertTrueMsg(invLine &lt;&gt; null, "OnsiteTi1 has no invoice line - 1");
	self.assertTrueMsg(invLine.invoiceLineDesc.narration =  "UT_LneSplitCsh", "OnsiteTi1 has wrong invoice line type - 1");
	self.assertTrueMsg(invLine.lineTotal = 1102.630000, "OnsiteTi1 has wrong invoice line total - 1 is " &amp; invLine.lineTotal.String);
	invLine := onsiteTi1.invoiceLines.last;
	self.assertTrueMsg(invLine &lt;&gt; null, "OnsiteTi1 has no invoice line - 2");
	self.assertTrueMsg(invLine.invoiceLineDesc.narration =  "UT_LneSplitCsh", "OnsiteTi1 has wrong invoice line type - 2");
	self.assertTrueMsg(invLine.lineTotal = 826.970000, "OnsiteTi1 has wrong invoice line total - 2 is " &amp; invLine.lineTotal.String);
	
	
	
	
	
	
	cashTI := onsiteTi1;
	// back-date the transactions to get storage
	baseDate := nowDate - 20;
	self.setTransactionDate(cashTI, baseDate);
	
	paymentMeth := app.myRoot.allPaymentMethods[PayMethName];
	if paymentMeth = null then
		paymentMeth := CM_PaymentMethod.firstInstance;
	endif;
	create allAgents transient;
	self.opts.purge();
	self.opts.addAssoc("UseProformaConfig",true);

	agent1 := self.createProformaAgent(now, cashTI);
	allAgents.add(agent1);
	
	// first receipt is for the pro forma only
	//  deselect the invoice lines
	cashToPay := 0;
	foreach invLine in cashTI.invoiceLines discreteLock do
		cashToPay += invLine.lineTotal;
		cashTotal += invLine.lineTotal;
	endforeach;

	foreach invLine in cashTI.invoiceLines discreteLock do
		create pxyCashPay transient;
		pxyCashPay.setPxyFromInvoiceLine(invLine);
		agent1.allCashPayments.add(pxyCashPay);
	endforeach;
	
	cashReceipt1 := self.createBOLCashReceipt(	paymentMeth,	// _payMeth : CM_PaymentMethod;
					cashToPay,				// _amount : Decimal;
					chequeBank,			// _chequeBank : String;
					chequeBranch,		// _chequeBranch : String;
					chequeNumber,		// _chequeNumber : String;
					chequeDate,			// _chequeDate : Date;
					cashId1,			// _cashId1,
					cashId2,			// _cashId2,
					cashId3,			// _cashId3,
					cashId4,			// _cashId4 : String;
					0,					// _payment1 : Decimal;
					0,					// _payment2 : Decimal;
					effectiveDate,		// _effectiveDate : Date;
					externalInvoiceNumber,	// _externalInvoiceNumber,
					externalReferenceNumber,	// _externalReferenceNumber : String;
					cashToPay,
					cashTotal,
					self.myVoyage,
					_drTerm1,			// _drTerm : CM_DebtorTerminal;
					0,
					0,
					0,
					null,
					allAgents,			// _agents : ObjectArray
					"",					// _taxCode1,
					"",					// _taxCode2,
					""					// _taxCode3: String
					);

	// ### Check cash payments are same as invoice lines				
	self.assertTrueMsg(cashReceipt1 &lt;&gt; null, msg &amp; " Cash Receipt 1 for on ship cargo not created...");
	self.assertTrueMsg(cashReceipt1.allCashPayments.isNotEmpty(), "cashReceipt1 should have payments");
	self.assertTrueMsg(cashReceipt1.allCashPayments.size = 2, "cashReceipt1 should have 2 payments");
	realCashPay := cashReceipt1.allCashPayments.first;
	self.assertTrueMsg(realCashPay &lt;&gt; null, "cashReceipt1 has no cash payment - 1");
	self.assertTrueMsg(realCashPay.myInvoiceLine &lt;&gt; null, "Cashpayment 1 should have an invoice line - 2.1");
	self.assertTrueMsg(realCashPay.cashValue = 1102.630000, "OnsiteTi1 has wrong invoice line total - 2.1 is " &amp; realCashPay.cashValue.String);
	realCashPay := cashReceipt1.allCashPayments.last;
	self.assertTrueMsg(realCashPay &lt;&gt; null, "cashReceipt1 has no cash payment - 2");
	self.assertTrueMsg(realCashPay.myInvoiceLine &lt;&gt; null, "Cashpayment 1 should have an invoice line - 2.2");
	self.assertTrueMsg(realCashPay.cashValue = 826.970000, "OnsiteTi1 has wrong invoice line total - 2.2 is " &amp; realCashPay.cashValue.String);
	

	
	// ### MOVE PART - split again, check split invoice lines
	self.opts.purge();
	self.opts.addAssoc("TotalQuantity",3); // Move 3
	self.move(onsiteTi1, blockStack1);

	// ### NEW split off - quantity 3
//	onsiteTi2 := blockStack1.myLocationsController.allTrackedItemsById[_id1, ct.id];
	onsiteTi2 := blockStack1.getTiById(_id1);  // ### JIRA 35008 05JUN2025 NAVAB1
	self.assertTrueMsg(onsiteTi2 &lt;&gt; null, "onsiteTi2 is null");
	self.assertTrueMsg(onsiteTi2.totalQuantity = 3, "onsiteTi2 sbe 3");
	self.assertTrueMsg(onsiteTi2.invoiceLines.isNotEmpty(), "onsiteTi2 should have invoice line");
	self.assertTrueMsg(onsiteTi2.invoiceLines.size = 2, "onsiteTi2 should have 2 invoice line");  // ### JIRA 35213 01JUL2025 NAVAB1
	
	// ### JIRA 35213 01JUL2025 NAVAB1 added extra checks for 2 lines
	invLine := onsiteTi2.invoiceLines.first;
	self.assertTrueMsg(invLine &lt;&gt; null, "onsiteTi2 has no invoice line - 2");
	self.assertTrueMsg(invLine.invoiceLineDesc.narration =  "UT_LneSplitCsh", "onsiteTi2 has wrong invoice line type - 2");
	self.assertTrueMsg(invLine.lineTotal = 472.55, "2.1 onsiteTi2 has wrong invoice line total - 2 is " &amp; invLine.lineTotal.String);
	
	invLine := onsiteTi2.invoiceLines.last;
	self.assertTrueMsg(invLine &lt;&gt; null, "onsiteTi2 has no invoice line - 2");
	self.assertTrueMsg(invLine.invoiceLineDesc.narration =  "UT_LneSplitCsh", "onsiteTi2 has wrong invoice line type - 2");
	self.assertTrueMsg(invLine.lineTotal = 354.42, "2.2 onsiteTi2 has wrong invoice line total - 2 is " &amp; invLine.lineTotal.String);
	
	
	// ### JIRA 35213 01JUL2025 NAVAB1 added extra checks for 2 payments
	realCashPay := onsiteTi2.allCashPayments.first;
	self.assertTrueMsg(realCashPay &lt;&gt; null, "onsiteTi2 has no cash payments - 1");
	self.assertTrueMsg(realCashPay.cashValue = 472.55, "2.1 onsiteTi2 has wrong cash value total - 1 is " &amp; realCashPay.cashValue.String);
	
	realCashPay := onsiteTi2.allCashPayments.last;
	self.assertTrueMsg(realCashPay &lt;&gt; null, "onsiteTi2 has no cash payments - 1");
	self.assertTrueMsg(realCashPay.cashValue = 354.42, "2.2 onsiteTi2 has wrong cash value total - 1 is " &amp; realCashPay.cashValue.String);
	
	
	// ### original - quantity now 4
	// Invoice line and cash payment should have same values
	
	realCashPay := onsiteTi1.allCashPayments.first;
	self.assertTrueMsg(realCashPay &lt;&gt; null, "OnsiteTi1 has no cash payments - 1");
	self.assertTrueMsg(realCashPay.cashValue =  630.07, "OnsiteTi1 has wrong cash value total - 1 is " &amp; realCashPay.cashValue.String);
	
	realCashPay := onsiteTi1.allCashPayments.last;
	self.assertTrueMsg(realCashPay &lt;&gt; null, "OnsiteTi1 has no cash payments - 2");
	self.assertTrueMsg(realCashPay.cashValue = 472.56, "OnsiteTi1 has wrong cash value total - 2 is " &amp; realCashPay.cashValue.String);

	self.assertTrueMsg(onsiteTi1 &lt;&gt; null, "OnsiteTi1 is null");
	self.assertTrueMsg(onsiteTi1.totalQuantity = 4, "OnsiteTi1 sbe 4");
	self.assertTrueMsg(onsiteTi1.invoiceLines.isNotEmpty(), "OnsiteTi1 should have invoice line");
	self.assertTrueMsg(onsiteTi1.invoiceLines.size = 2, "OnsiteTi1 should have 2 invoice line");
	invLine := onsiteTi1.invoiceLines.first;
	self.assertTrueMsg(invLine &lt;&gt; null, "OnsiteTi1 has no invoice line -3. 1");
	self.assertTrueMsg(invLine.invoiceLineDesc.narration =  "UT_LneSplitCsh", "OnsiteTi1 has wrong invoice line type - 1");
	self.assertTrueMsg(invLine.lineTotal =  630.07, "OnsiteTi1 has wrong invoice line total - 3.2 is " &amp; invLine.lineTotal.String);
	 // ### JIRA 34982 12JUN2025 NAVAB1
	self.assertTrueMsg(invLine.totalAmount = invLine.lineTotal , "OnsiteTi1 has wrong invoice total amount - 3.2 is " &amp; invLine.totalAmount.String);

	invLine := onsiteTi1.invoiceLines.last;
	self.assertTrueMsg(invLine &lt;&gt; null, "OnsiteTi1 has no invoice line - 3.2");
	self.assertTrueMsg(invLine.invoiceLineDesc.narration =  "UT_LneSplitCsh", "OnsiteTi1 has wrong invoice line type - 2");
	self.assertTrueMsg(invLine.lineTotal = 472.56, "OnsiteTi1 has wrong invoice line total - 3.1 is " &amp; invLine.lineTotal.String);
	 // ### JIRA 34982 12JUN2025 NAVAB1
	self.assertTrueMsg(invLine.totalAmount = invLine.lineTotal, "OnsiteTi1 has wrong invoice total  amount - 3.1 is " &amp; invLine.totalAmount.String);
	
	
epilog
	if agent1&lt;&gt; null then
		agent1.allCashPayments.purge();
	endif;
	
	allAgents.purge();
	delete allAgents;
	delete allTIs;
	delete invAssistant;
end;</source>
        <access>protected</access>
        <Parameter name="_id1" type="String"/>
        <Parameter name="_id2" type="String"/>
        <Parameter name="_drTerm1" type="CM_DebtorTerminal"/>
        <Parameter name="_type" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="cashTestMultipleReceipts6" id="03deb7e5-2b0f-4dbb-affa-14793c726180">
        <updating/>
        <source>cashTestMultipleReceipts6(_id1 : String; _id2 : String; _drTerm1 : CM_DebtorTerminal; _type : Integer) updating, protected;
/*
Purpose - 	
Who - NAVAB1
Date -05JUN2025
ADO - JIRA 35008
*/


constants

vars
	now			: TimeStamp;
	cargoId		: String;
	msg			: String;
	invoiceEveryReceipt	: Boolean;
	cashVal : Decimal[23,6];
	cashReceipt1 : CM_CashReceipt;
	paymentMeth : CM_PaymentMethod;

	invAssistant	: Object;
	onsiteTi2,
	onsiteTi1,
	cashTI	: CM_TrackedItem;

	nowDate,
	baseDate : Date;
	
	customsAgent	: CM_CustomsAgent;
	operator		: CM_Operator;
	debtor 		: CM_DebtorNode;
	
	allTIs 		: CM_TISet;
	type : CM_TerminalAreaType;
	blockStack1,
	blockStack2	: CM_BlockStack;
	allAgents		: CM_CashProformaAgentSet;
	agent1	: CM_CashInvoiceProformaAgent;
	dbtTerminal : CM_DebtorTerminal;
	ct : CM_CargoType;
	port : CM_Port;
	invLine : CM_InvoiceLine;
	realCashPay : CM_CashPayment;
	tmpController    : CMIF_ProformaInvLinesForDebtor;
begin
	msg := method.name;
	if self.myTerminal.getConfig(CashInvoiceEveryReceipt).Boolean then
		invoiceEveryReceipt := true;
	endif;
	
	//self.myTerminal.setConfig(InvoiceRoundLineTotal,2);
	self.setTerminalConfig(InvoiceRoundLineTotal, 2);

	//self.assertTrueMsg(ct &lt;&gt; null, "Cargo Type 15104 - UTBY is null");
	if self.opts.includesKey("CargoType") then
		ct := self.opts.obj("CargoType").CM_CargoType;
	endif;
	self.assertNotNullMsg(ct, "Failed to get cargo Type");
	
	port := app.myRoot.allPorts["NZAKL"];
	self.assertTrueMsg(port &lt;&gt; null, "port is null");
	
	type := app.myRoot.allTerminalAreaTypes.getAtKey(1); // Block Stack
	blockStack1 := self.myTerminal.allTerminalAreasByTypeId.getAtKey( type.type, "UT_BS1").CM_BlockStack;
	self.assertTrueMsg(blockStack1 &lt;&gt; null, "Block Stack UT_BS1 not found...");
	blockStack2 := self.myTerminal.allTerminalAreasByTypeId.getAtKey( type.type, "UT_BS2").CM_BlockStack;
	self.assertTrueMsg(blockStack2 &lt;&gt; null, "Block Stack UT_BS2 not found...");
	// use an operator with a known non-cash debtor
	operator := self.getOperator("UTC1");
	if operator = null then
		operator := self.addOperatorSimple("UTC1", "Cash Test Operator");
	endif;
	
	cargoId := _id1;
	cashTI := self.createGCOnShipQWV(null,cargoId, ct,operator,  self.myVoyage,port , 40000, 67, 7 );
	
	self.assertTrueMsg(cashTI &lt;&gt; null, "On Ship Cargo 1 '" &amp; cargoId &amp; "' not created...");
	self.assertTrueMsg(cashTI.totalQuantity = 7,  "On Ship Cargo 1 '" &amp; cargoId &amp; "' wrong quantity SBE 7 is " &amp; cashTI.totalQuantity.String);
	self.assertTrueMsg(cashTI.totalVolume = 67,  "On Ship Cargo 1 '" &amp; cargoId &amp; "' wrong volume SBE 67 is " &amp; cashTI.totalVolume.String);
	self.assertTrueMsg(cashTI.totalWeight = 40000,  "On Ship Cargo 1 '" &amp; cargoId &amp; "' wrong weight SBE 40000 is " &amp; cashTI.totalWeight.String);

	customsAgent := app.myRoot.allCustomsAgents['UTCA1'];
	debtor := customsAgent.myDebtor;
	beginTransaction;
	cashTI.setPropertyValue("myCustomsAgent",customsAgent);
	commitTransaction;
	
	
	// ### MOVE WHOLE
	self.opts.purge();
	self.opts.addAssoc("TotalQuantity",7); // Move whole ti
	self.move(cashTI, blockStack1);

	onsiteTi1 := blockStack1.getTiById(_id1);
	self.assertTrueMsg(onsiteTi1 &lt;&gt; null, "OnsiteTi1 is null");
	self.assertTrueMsg(onsiteTi1.totalQuantity = 7, "OnsiteTi1 sbe 4");
	self.assertTrueMsg(onsiteTi1.invoiceLines.isNotEmpty(), "OnsiteTi1 should have invoice line");
	self.assertTrueMsg(onsiteTi1.invoiceLines.size = 1, "OnsiteTi1 should have 1 invoice line");
	invLine := onsiteTi1.invoiceLines.first;
	self.assertTrueMsg(invLine &lt;&gt; null, "OnsiteTi1 has no invoice line");
	self.assertTrueMsg(invLine.invoiceLineDesc.narration =  "UT_LneSplitCsh", "OnsiteTi1 has wrong invoice line type");
	self.assertTrueMsg(invLine.lineTotal = 1929.600000, "onsiteTi2 has wrong invoice line total - 1 is " &amp; invLine.lineTotal.String);
	self.assertTrueMsg(invLine.totalAmount = invLine.lineTotal, "onsiteTi2 has wrong invoicetotal Amount - 1 is " &amp; invLine.totalAmount.String);
	
	
	// ### MOVE PART - split
	self.opts.purge();
	self.opts.addAssoc("TotalQuantity",3); // Move 3
	self.move(cashTI, blockStack2);

	onsiteTi2 := blockStack2.getTiById(_id1);
	self.assertTrueMsg(onsiteTi2 &lt;&gt; null, "onsiteTi2 is null");
	self.assertTrueMsg(onsiteTi2.totalQuantity = 3, "onsiteTi2 sbe 3");
	self.assertTrueMsg(onsiteTi2.invoiceLines.isNotEmpty(), "onsiteTi2 should have invoice line");
	self.assertTrueMsg(onsiteTi2.invoiceLines.size = 1, "onsiteTi2 should have 2 invoice line");
	invLine := onsiteTi2.invoiceLines.first;
	self.assertTrueMsg(invLine &lt;&gt; null, "onsiteTi2 has no invoice line - 1");
	self.assertTrueMsg(invLine.invoiceLineDesc.narration =  "UT_LneSplitCsh", "onsiteTi2 has wrong invoice line type - 1");
	self.assertTrueMsg(invLine.lineTotal = 826.970000, "onsiteTi2 has wrong invoice line total - 1 is " &amp; invLine.lineTotal.String);
	self.assertTrueMsg(invLine.totalAmount = invLine.lineTotal, "onsiteTi2 has wrong invoicetotal Amount - 2 is " &amp; invLine.totalAmount.String);

	invLine := onsiteTi1.invoiceLines.last;
	self.assertTrueMsg(invLine &lt;&gt; null, "onsiteTi1 has no invoice line - 2");
	self.assertTrueMsg(invLine.invoiceLineDesc.narration =  "UT_LneSplitCsh", "onsiteTi2 has wrong invoice line type - 2");
	self.assertTrueMsg(invLine.lineTotal = 1102.63, "onsiteTi2 has wrong invoice line total - 2 is " &amp; invLine.lineTotal.String);
	self.assertTrueMsg(invLine.totalAmount = invLine.lineTotal, "onsiteTi2 has wrong invoicetotal Amount - 3 is " &amp; invLine.totalAmount.String);
	
	
	
	
	
	
	cashTI := onsiteTi1;
	// back-date the transactions to get storage
	baseDate := nowDate - 20;
	self.setTransactionDate(onsiteTi1, baseDate);
	
	paymentMeth := app.myRoot.allPaymentMethods[PayMethName];
	if paymentMeth = null then
		paymentMeth := CM_PaymentMethod.firstInstance;
	endif;
	create allAgents transient;
	self.opts.purge();
	self.opts.addAssoc("UseProformaConfig",true);

	agent1 := self.createProformaAgent(now, onsiteTi1);
	allAgents.add(agent1);
	agent1 := self.createProformaAgent(now, onsiteTi2);
	allAgents.add(agent1);
	

	cashVal := 1929.6;
	create cashReceipt1 transient;
	cashReceipt1.setPropertyValue("cashValue",cashVal);
	cashReceipt1.setPropertyValue("myDebtorTerminal",_drTerm1);
	
	create tmpController transient; 
	tmpController.proformaProxyCashPayments(cashReceipt1,allAgents, false); 

	// ### Check cash payments are same as invoice lines				
	self.assertTrueMsg(cashReceipt1 &lt;&gt; null, msg &amp; " Cash Receipt 1 for on ship cargo not created...");
	self.assertTrueMsg(cashReceipt1.allCashPayments.isNotEmpty(), "cashReceipt1 should have payments");
	self.assertTrueMsg(cashReceipt1.allCashPayments.size = 2, "cashReceipt1 should have 2 payments");
	realCashPay := cashReceipt1.allCashPayments.first;
	self.assertTrueMsg(realCashPay &lt;&gt; null, "cashReceipt1 has no cash payment - 1");
	self.assertTrueMsg(realCashPay.myInvoiceLine &lt;&gt; null, "Cashpayment 1 should have an invoice line - 2.1");
	self.assertTrueMsg(realCashPay.cashValue = 1102.630000, "OnsiteTi1 has wrong invoice line total - 2.1 is " &amp; realCashPay.cashValue.String);
	realCashPay := cashReceipt1.allCashPayments.last;
	self.assertTrueMsg(realCashPay &lt;&gt; null, "cashReceipt1 has no cash payment - 2");
	self.assertTrueMsg(realCashPay.myInvoiceLine &lt;&gt; null, "Cashpayment 1 should have an invoice line - 2.2");
	self.assertTrueMsg(realCashPay.cashValue = 826.970000, "OnsiteTi1 has wrong invoice line total - 2.2 is " &amp; realCashPay.cashValue.String);
	
epilog
	if agent1&lt;&gt; null then
		agent1.allCashPayments.purge();
	endif;
	if allAgents&lt;&gt; null then
	allAgents.purge();
	endif;
	delete allAgents;
	delete allTIs;
	delete invAssistant;
	delete cashReceipt1;
	delete tmpController;
end;</source>
        <access>protected</access>
        <Parameter name="_id1" type="String"/>
        <Parameter name="_id2" type="String"/>
        <Parameter name="_drTerm1" type="CM_DebtorTerminal"/>
        <Parameter name="_type" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="cashTestMultipleReceipts7" id="f7960446-4b48-4395-a706-b08c2b3f9b18">
        <updating/>
        <source>cashTestMultipleReceipts7(_id1 : String; _id2 : String; _drTerm1 : CM_DebtorTerminal; _type : Integer) updating, protected;
/*
Purpose - 	Test pay cash for volume based cash payments, split move cash residue

				Create cargo on ship (break bulk splittable) Splittable cargo quantity of 10, volume of 1012.8275 weight of 18143.68.
				transaction map has mappings for move from ship to yard and storage. Storage is in ranges 8-12, 13-max. Storage uses volume convert for calculation type. Both ranges have same invoice line type.
				
				Then dischargewhole.
				Pay cash for cargo on site.
				move split whilst on site
				

				Who - NAVAB1
Date - 13JUN2025
ADO - JIRA 34982
*/

constants

vars
	now			: TimeStamp;
	cargoId		: String;
	msg			: String;
	invoiceEveryReceipt	: Boolean;
	
	cashReceipt1 : CM_CashReceipt;
	paymentMeth : CM_PaymentMethod;

	invAssistant	: Object;
	onsiteTi2,
	onsiteTi1,
	cashTI	: CM_TrackedItem;

	nowDate,
	baseDate : Date;
	cashToPay,
	cashTotal	: Decimal[23,6];
	
	customsAgent	: CM_CustomsAgent;
	operator		: CM_Operator;
	debtor 		: CM_DebtorNode;
	
	allTIs 		: CM_TISet;
	type : CM_TerminalAreaType;
	blockStack1,
	blockStack2	: CM_BlockStack;
	chequeBank : String;
	chequeBranch : String;
	chequeNumber : String;
	chequeDate : Date;
	cashId1,
	cashId2,
	cashId3,
	cashId4 : String;
	allAgents		: ObjectArray;
	agent1	: CM_CashInvoiceProformaAgent;
	
	effectiveDate : Date;
	externalInvoiceNumber,
	externalReferenceNumber : String;
	ct : CM_CargoType;
	port : CM_Port;
	invLine : CM_InvoiceLine;
	realCashPay, pxyCashPay : CM_CashPayment;
begin
	msg := method.name;
	if self.myTerminal.getConfig(CashInvoiceEveryReceipt).Boolean then
		invoiceEveryReceipt := true;
	endif;
	
	//self.myTerminal.setConfig(InvoiceRoundLineTotal,2);
	self.setTerminalConfig(InvoiceRoundLineTotal, 2);

	//self.assertTrueMsg(ct &lt;&gt; null, "Cargo Type 15104 - UTBY is null");
	if self.opts.includesKey("CargoType") then
		ct := self.opts.obj("CargoType").CM_CargoType;
	endif;
	self.assertNotNullMsg(ct, "Failed to get cargo Type");
	
	port := app.myRoot.allPorts["NZAKL"];
	self.assertTrueMsg(port &lt;&gt; null, "port is null");
	
	type := app.myRoot.allTerminalAreaTypes.getAtKey(1); // Block Stack
	blockStack1 := self.myTerminal.allTerminalAreasByTypeId.getAtKey( type.type, "UT_BS1").CM_BlockStack;
	self.assertTrueMsg(blockStack1 &lt;&gt; null, "Block Stack UT_BS1 not found...");
	blockStack2 := self.myTerminal.allTerminalAreasByTypeId.getAtKey( type.type, "UT_BS2").CM_BlockStack;
	self.assertTrueMsg(blockStack2 &lt;&gt; null, "Block Stack UT_BS2 not found...");
	// use an operator with a known non-cash debtor
	operator := self.getOperator("UTC1");
	if operator = null then
		operator := self.addOperatorSimple("UTC1", "Cash Test Operator");
	endif;
	
	cargoId := _id1;
	cashTI := self.createGCOnShipQWV(null,cargoId, ct,operator,  self.myVoyage,port , 18143.68, 12.8275,10 );
	
	self.assertTrueMsg(cashTI &lt;&gt; null, "On Ship Cargo 1 '" &amp; cargoId &amp; "' not created...");
	self.assertTrueMsg(cashTI.totalQuantity = 10,  "On Ship Cargo 1 '" &amp; cargoId &amp; "' wrong quantity SBE 10 is " &amp; cashTI.totalQuantity.String);
	self.assertTrueMsg(cashTI.totalVolume = 12.8275,  "On Ship Cargo 1 '" &amp; cargoId &amp; "' wrong volume SBE 12.8275 is " &amp; cashTI.totalVolume.String);
	self.assertTrueMsg(cashTI.totalWeight = 18143.68,  "On Ship Cargo 1 '" &amp; cargoId &amp; "' wrong weight SBE 18143.68 is " &amp; cashTI.totalWeight.String);

	customsAgent := app.myRoot.allCustomsAgents['UTCA1'];
	debtor := customsAgent.myDebtor;
	beginTransaction;
	cashTI.setPropertyValue("myCustomsAgent",customsAgent);
	commitTransaction;
	// ### MOVE WHOLE
	self.opts.purge();
	self.opts.addAssoc("TotalQuantity",10); // Move whole
	self.move(cashTI, blockStack2);

	onsiteTi1 := blockStack2.getTiById(_id1);
	self.assertTrueMsg(onsiteTi1 &lt;&gt; null, "OnsiteTi1 is null");
	self.assertTrueMsg(onsiteTi1.totalQuantity = 10, "OnsiteTi1 sbe 10");
	self.assertTrueMsg(onsiteTi1.invoiceLines.isNotEmpty(), "OnsiteTi1 should have invoice line");
	self.assertTrueMsg(onsiteTi1.invoiceLines.size = 1, "OnsiteTi1 should have 1 invoice line");
	invLine := onsiteTi1.invoiceLines.first;
	self.assertTrueMsg(invLine &lt;&gt; null, "OnsiteTi1 has no invoice line");
	self.assertTrueMsg(invLine.invoiceLineDesc.narration =  "UT_LneSplitCsh", "OnsiteTi1 has wrong invoice line type");
	self.assertTrueMsg(invLine.lineTotal = 369.430000, "OnsiteTi1 has wrong invoice line total - 2.1SA is " &amp; invLine.lineTotal.String);
	
	
	cashTI := onsiteTi1;
	// back-date the transactions to get storage
	baseDate := nowDate - 20;
	self.setTransactionDate(cashTI, baseDate);
	
	paymentMeth := app.myRoot.allPaymentMethods[PayMethName];
	if paymentMeth = null then
		paymentMeth := CM_PaymentMethod.firstInstance;
	endif;
	create allAgents transient;
	self.opts.purge();
	self.opts.addAssoc("UseProformaConfig",true);

	agent1 := self.createProformaAgent(now, cashTI);
	allAgents.add(agent1);
	
	// first receipt is for the pro forma only
	//  deselect the invoice lines
	cashToPay := 0;
	foreach invLine in cashTI.invoiceLines discreteLock do
		cashToPay += invLine.lineTotal;
		cashTotal += invLine.lineTotal;
	endforeach;

	foreach invLine in cashTI.invoiceLines discreteLock do
		create pxyCashPay transient;
		pxyCashPay.setPxyFromInvoiceLine(invLine);
		agent1.allCashPayments.add(pxyCashPay);
	endforeach;
	
	cashReceipt1 := self.createBOLCashReceipt(	paymentMeth,	// _payMeth : CM_PaymentMethod;
					cashToPay,				// _amount : Decimal;
					chequeBank,			// _chequeBank : String;
					chequeBranch,		// _chequeBranch : String;
					chequeNumber,		// _chequeNumber : String;
					chequeDate,			// _chequeDate : Date;
					cashId1,			// _cashId1,
					cashId2,			// _cashId2,
					cashId3,			// _cashId3,
					cashId4,			// _cashId4 : String;
					0,					// _payment1 : Decimal;
					0,					// _payment2 : Decimal;
					effectiveDate,		// _effectiveDate : Date;
					externalInvoiceNumber,	// _externalInvoiceNumber,
					externalReferenceNumber,	// _externalReferenceNumber : String;
					cashToPay,
					cashTotal,
					self.myVoyage,
					_drTerm1,			// _drTerm : CM_DebtorTerminal;
					0,
					0,
					0,
					null,
					allAgents,			// _agents : ObjectArray
					"",					// _taxCode1,
					"",					// _taxCode2,
					""					// _taxCode3: String
					);

	// ### Check cash payments are same as invoice lines				
	self.assertTrueMsg(cashReceipt1 &lt;&gt; null, msg &amp; " Cash Receipt 1 for on ship cargo not created...");
	self.assertTrueMsg(cashReceipt1.allCashPayments.isNotEmpty(), "cashReceipt1 should have payments");
	self.assertTrueMsg(cashReceipt1.allCashPayments.size = 1, "cashReceipt1 should have 1 payment");
	realCashPay := cashReceipt1.allCashPayments.first;
	self.assertTrueMsg(realCashPay &lt;&gt; null, "cashReceipt1 has no cash payment - 1");
	self.assertTrueMsg(realCashPay.myInvoiceLine &lt;&gt; null, "Cashpayment 1 should have an invoice line - 2.1");
	self.assertTrueMsg(realCashPay.cashValue = 369.430000, "OnsiteTi1 has wrong cash value - 2.1 is " &amp; realCashPay.cashValue.String);
	

	
	// ### MOVE PART - split again, check split invoice lines
	self.opts.purge();
	self.opts.addAssoc("TotalQuantity",5); // Move 5
	self.move(onsiteTi1, blockStack1);

	// ### NEW split off - quantity 5
	onsiteTi2 := blockStack1.getTiById(_id1); 
	self.assertTrueMsg(onsiteTi2 &lt;&gt; null, "onsiteTi2 is null");
	self.assertTrueMsg(onsiteTi2.totalQuantity = 5, "onsiteTi2 sbe 5");
	self.assertTrueMsg(onsiteTi2.invoiceLines.isNotEmpty(), "onsiteTi2 should have invoice line");
	self.assertTrueMsg(onsiteTi2.invoiceLines.size = 1, "onsiteTi2 should have 1 invoice line"); 
	
	invLine := onsiteTi2.invoiceLines.first;
	self.assertTrueMsg(invLine &lt;&gt; null, "onsiteTi2 has no invoice line - 2");
	self.assertTrueMsg(invLine.invoiceLineDesc.narration =  "UT_LneSplitCsh", "onsiteTi2 has wrong invoice line type - 2");
	self.assertTrueMsg(invLine.lineTotal = 184.72, "onsiteTi2 has wrong invoice line total - 2 is " &amp; invLine.lineTotal.String);
	realCashPay := onsiteTi2.allCashPayments.first;
	self.assertTrueMsg(realCashPay &lt;&gt; null, "onsiteTi2 has no cash payments - 1");
	self.assertTrueMsg(realCashPay.cashValue = invLine.lineTotal, "onsiteTi2 has wrong cash value total - 1 is " &amp; realCashPay.cashValue.String);
	
	
	// ### original - quantity now 4
	// Invoice line and cash payment should have same values
	
	realCashPay := onsiteTi1.allCashPayments.first;
	self.assertTrueMsg(realCashPay &lt;&gt; null, "OnsiteTi1 has no cash payments - 1");
	self.assertTrueMsg(realCashPay.cashValue = 184.72, "OnsiteTi1 has wrong cash value total - 1 is " &amp; realCashPay.cashValue.String);

	self.assertTrueMsg(onsiteTi1 &lt;&gt; null, "OnsiteTi1 is null");
	self.assertTrueMsg(onsiteTi1.totalQuantity = 5, "OnsiteTi1 sbe 5");
	self.assertTrueMsg(onsiteTi1.invoiceLines.isNotEmpty(), "OnsiteTi1 should have invoice line");
	self.assertTrueMsg(onsiteTi1.invoiceLines.size = 1, "OnsiteTi1 should have 1 invoice line");
	invLine := onsiteTi1.invoiceLines.first;
	self.assertTrueMsg(invLine &lt;&gt; null, "OnsiteTi1 has no invoice line -3. 1");
	self.assertTrueMsg(invLine.invoiceLineDesc.narration =  "UT_LneSplitCsh", "OnsiteTi1 has wrong invoice line type - 1");
	self.assertTrueMsg(invLine.lineTotal =  184.72, "OnsiteTi1 has wrong invoice line total - 3.2 is " &amp; invLine.lineTotal.String);
	self.assertTrueMsg(invLine.totalAmount = invLine.lineTotal , "OnsiteTi1 has wrong invoice total amount - 3.2 is " &amp; invLine.totalAmount.String);

	
	
epilog
	if agent1&lt;&gt; null then
		agent1.allCashPayments.purge();
	endif;
	if allAgents&lt;&gt; null then
	allAgents.purge();
	endif;
	delete allAgents;
	delete allTIs;
	delete invAssistant;
end;</source>
        <access>protected</access>
        <Parameter name="_id1" type="String"/>
        <Parameter name="_id2" type="String"/>
        <Parameter name="_drTerm1" type="CM_DebtorTerminal"/>
        <Parameter name="_type" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="cashTestMultipleReceipts8" id="6bd4ad21-a312-41b7-b8a5-02404b8684d6">
        <updating/>
        <source>cashTestMultipleReceipts8(_id1 : String; _id2 : String; _drTerm1 : CM_DebtorTerminal; _type : Integer) updating, protected;
/*
Purpose - 	Test split and then merge of invoice lines and cash payments

				Create cargo on ship (break bulk splittable) Splittable cargo quantity of 4, volume of 1012.8275 weight of 18143.68.
				transaction map has mapping for move from ship to yard and storage. 
				
				Create Cash Receipt whilst on ship
				
				Discharge 1st item in 2 parts. so merges, will be 1 cash payment
				
				
				Then Split part to a 2nd location
				Then split a bit more to second location.
				
				
				Check that the cash payment and invoice line match value.
				
				
				Who - NAVAB1
Date - 04JUL2025
ADO - JIRA 35068
*/

constants
	LineName =  "UT_LneSplitCsh";	

vars
	now			: TimeStamp;
	cargoId		: String;
	msg			: String;
	invoiceEveryReceipt	: Boolean;
	
	cashReceipt1 : CM_CashReceipt;
	paymentMeth : CM_PaymentMethod;

	invAssistant	: Object;
	onsiteTi1,onsiteTi2,
	cashTI1	: CM_TrackedItem;

	nowDate,
	baseDate : Date;
	cashToPay,
	cashTotal	: Decimal[23,6];
	
	customsAgent	: CM_CustomsAgent;
	operator		: CM_Operator;
	debtor 		: CM_DebtorNode;
	
	allTIs 		: CM_TISet;
	type : CM_TerminalAreaType;
	blockStack1,
	blockStack2	: CM_BlockStack;
	allAgents		: ObjectArray;
	agent1	: CM_CashInvoiceProformaAgent;
	ct : CM_CargoType;
	port : CM_Port;
	invLine : CM_InvoiceLine;
	realCashPay : CM_CashPayment;
	newTiIds: StringArray;
	newProfDetail : CM_ProformaDetails;
	invLineDesc : CM_InvoiceLineDesc;
begin
	msg := method.name;
	if self.myTerminal.getConfig(CashInvoiceEveryReceipt).Boolean then
		invoiceEveryReceipt := true;
	endif;
	
	//self.myTerminal.setConfig(InvoiceRoundLineTotal,2);
	self.setTerminalConfig(InvoiceRoundLineTotal, 2);

	//self.assertTrueMsg(ct &lt;&gt; null, "Cargo Type 15104 - UTBY is null");
	if self.opts.includesKey("CargoType") then
		ct := self.opts.obj("CargoType").CM_CargoType;
	endif;
	self.assertNotNullMsg(ct, "Failed to get cargo Type");
	
	port := app.myRoot.allPorts["NZAKL"];
	self.assertTrueMsg(port &lt;&gt; null, "port is null");
	
	type := app.myRoot.allTerminalAreaTypes.getAtKey(1); // Block Stack
	blockStack1 := self.myTerminal.allTerminalAreasByTypeId.getAtKey( type.type, "UT_BS1").CM_BlockStack;
	self.assertTrueMsg(blockStack1 &lt;&gt; null, "Block Stack UT_BS1 not found...");
	blockStack2 := self.myTerminal.allTerminalAreasByTypeId.getAtKey( type.type, "UT_BS2").CM_BlockStack;
	self.assertTrueMsg(blockStack2 &lt;&gt; null, "Block Stack UT_BS2 not found...");
	// use an operator with a known non-cash debtor
	operator := self.getOperator("UTC1");
	if operator = null then
		operator := self.addOperatorSimple("UTC1", "Cash Test Operator");
	endif;
	
	self.deleteCargo(_id1 &amp; "-01", ct);
	self.deleteCargo(_id1 &amp; "-02", ct);
	self.deleteCargo(_id1 &amp; "-03", ct);
	cargoId := _id1;
	cashTI1 := self.createGCOnShipQWV(null,cargoId, ct,operator,  self.myVoyage,port , 18143.68, 12.8275,4 );
	
	self.assertTrueMsg(cashTI1 &lt;&gt; null, "On Ship Cargo 1 '" &amp; cargoId &amp; "' not created...");
	self.assertTrueMsg(cashTI1.totalQuantity = 4,  "On Ship Cargo 1 '" &amp; cargoId &amp; "' wrong quantity SBE 4 is " &amp; cashTI1.totalQuantity.String);
	self.assertTrueMsg(cashTI1.totalVolume = 12.8275,  "On Ship Cargo 1 '" &amp; cargoId &amp; "' wrong volume SBE 12.8275 is " &amp; cashTI1.totalVolume.String);
	self.assertTrueMsg(cashTI1.totalWeight = 18143.68,  "On Ship Cargo 1 '" &amp; cargoId &amp; "' wrong weight SBE 18143.68 is " &amp; cashTI1.totalWeight.String);

	
	
	customsAgent := app.myRoot.allCustomsAgents['UTCA1'];
	debtor := customsAgent.myDebtor;
	beginTransaction;
	cashTI1.setPropertyValue("myCustomsAgent",customsAgent);
	commitTransaction;

	
//	cashTI1 := onsiteTi1;
	// back-date the transactions to get storage
	baseDate := nowDate - 20;
	self.setTransactionDate(cashTI1, baseDate);
	
	paymentMeth := app.myRoot.allPaymentMethods[PayMethName];
	if paymentMeth = null then
		paymentMeth := CM_PaymentMethod.firstInstance;
	endif;
	create allAgents transient;
	self.opts.purge();
	self.opts.addAssoc("UseProformaConfig",true);

	agent1 := self.createProformaAgent(now, cashTI1);
	allAgents.add(agent1);
	
	cashToPay := 369.44;
	cashTotal := cashToPay;
	
	// ### CASH RECEIPT
	cashReceipt1 := self.createCashReceipt(_drTerm1, paymentMeth, cashToPay,cashTotal, allAgents );
	
	
	invLineDesc := self.myBank.invoiceLineDescriptors[LineName];	
	
	beginTransaction;
	newProfDetail := cashReceipt1.createProformaDetail(cashToPay, 4, 28.8, "",  invLineDesc, cashTI1,TRANS_TYPE_REC_SHIP, false);
	realCashPay := cashReceipt1.createCashPayment(cashToPay, 0, false, cashReceipt1.myDebtorTerminal, cashTI1, null, newProfDetail, cashReceipt1.myCashInvoice);
	realCashPay.setMyTerminal(); 
	commitTransaction;

	// ### Check cash payments are same as invoice lines				
	self.assertTrueMsg(cashReceipt1 &lt;&gt; null, msg &amp; " Cash Receipt 1 for on ship cargo not created...");
	self.assertTrueMsg(cashReceipt1.allCashPayments.isNotEmpty(), "cashReceipt1 should have payments");
	self.assertTrueMsg(cashReceipt1.allCashPayments.size = 1, "cashReceipt1 should have 1 payment");
	realCashPay := cashReceipt1.allCashPayments.first;
	self.assertTrueMsg(realCashPay &lt;&gt; null, "cashReceipt1 has no cash payment - 1");
	self.assertTrueMsg(realCashPay.myInvoiceLine = null, "Cashpayment 1 should not have an invoice line - 2.1");
	self.assertTrueMsg(realCashPay.cashValue = cashToPay, "OnsiteTi1 has wrong cash value - 2.1 is " &amp; realCashPay.cashValue.String);
		

	
	// ### DISCHARGE 1/2 SPLIT
	self.opts.purge();
	self.opts.addAssoc("TotalQuantity",2); // Move part
	self.move(cashTI1, blockStack1);

	onsiteTi1 := blockStack1.getTiById(_id1);
	self.assertTrueMsg(onsiteTi1 &lt;&gt; null, "OnsiteTi1 is null");
	self.assertTrueMsg(onsiteTi1.totalQuantity = 2, "OnsiteTi1 sbe 2");
	self.assertTrueMsg(onsiteTi1.invoiceLines.isNotEmpty(), "OnsiteTi1 should have invoice line");
	self.assertTrueMsg(onsiteTi1.invoiceLines.size = 1, "OnsiteTi1 should have 1 invoice line");
	invLine := onsiteTi1.invoiceLines.first;
	self.assertTrueMsg(invLine &lt;&gt; null, "OnsiteTi1 has no invoice line");
	self.assertTrueMsg(invLine.invoiceLineDesc.narration =  "UT_LneSplitCsh", "OnsiteTi1 has wrong invoice line type");
	self.assertTrueMsg(invLine.lineTotal = (cashToPay/2), "OnsiteTi1 has wrong invoice line total - 2.1SA is " &amp; invLine.lineTotal.String);
	self.assertTrueMsg(onsiteTi1.allCashPayments.isNotEmpty(), "onsiteTi1 should have invoice line");
	self.assertTrueMsg(onsiteTi1.allCashPayments.size = 1, "32.1 onsiteTi1 should have 1 cash payment");
	realCashPay := onsiteTi1.allCashPayments.first;
	self.assertTrueMsg(realCashPay.cashValue = (cashToPay/2), "32.1 onsiteTi1 cash payment value is wrong is " &amp; realCashPay.cashValue.String);


	// ### DISCHARGE 2/2 MERGE
	self.opts.purge();
	self.opts.addAssoc("TotalQuantity",2); // Move part
	self.move(cashTI1, blockStack1);
	
	onsiteTi1 := blockStack1.getTiById(_id1);
	
	self.assertTrueMsg(onsiteTi1 &lt;&gt; null, "OnsiteTi1 is null");
	self.assertTrueMsg(onsiteTi1.totalQuantity = 4, "OnsiteTi1 sbe 4");
	self.assertTrueMsg(onsiteTi1.invoiceLines.isNotEmpty(), "OnsiteTi1 should have invoice line");
	self.assertTrueMsg(onsiteTi1.invoiceLines.size = 2, "OnsiteTi1 should have 1 invoice line");
	invLine := onsiteTi1.invoiceLines.first;
	self.assertTrueMsg(invLine &lt;&gt; null, "OnsiteTi1 has no invoice line");
	self.assertTrueMsg(invLine.invoiceLineDesc.narration =  "UT_LneSplitCsh", "OnsiteTi1 has wrong invoice line type");
	self.assertTrueMsg(invLine.lineTotal = (cashToPay/2), "OnsiteTi1 has wrong invoice line total - 2.2SA is " &amp; invLine.lineTotal.String);
	invLine := onsiteTi1.invoiceLines.last;
	self.assertTrueMsg(invLine &lt;&gt; null, "OnsiteTi1 has no invoice line");
	self.assertTrueMsg(invLine.invoiceLineDesc.narration =  "UT_LneSplitCsh", "OnsiteTi1 has wrong invoice line type");
	self.assertTrueMsg(invLine.lineTotal = (cashToPay/2), "OnsiteTi1 has wrong invoice line total - 2.3SA is " &amp; invLine.lineTotal.String);
	
	self.assertTrueMsg(onsiteTi1.allCashPayments.isNotEmpty(), "onsiteTi1 should have invoice line");
	self.assertTrueMsg(onsiteTi1.allCashPayments.size = 1, "35.1 onsiteTi1 should have 1 cash payment");
	realCashPay := onsiteTi1.allCashPayments.first;
	self.assertTrueMsg(realCashPay.cashValue = cashToPay, "35.1 onsiteTi1 cash payment value is wrong is " &amp; realCashPay.cashValue.String);
	

	
	
	// MOVE 1/4 to 2nd location SPLIT
	self.opts.purge();
	self.opts.addAssoc("TotalQuantity",1); // Move part
	self.move(onsiteTi1, blockStack2);

	onsiteTi2 := blockStack2.getTiById(_id1);
	self.assertTrueMsg(onsiteTi2 &lt;&gt; null, "onsiteTi2 is null");
	self.assertTrueMsg(onsiteTi2.totalQuantity = 1, "onsiteTi2 sbe 4");
	self.assertTrueMsg(onsiteTi2.invoiceLines.isNotEmpty(), "onsiteTi2 should have invoice line");
	self.assertTrueMsg(onsiteTi2.invoiceLines.size = 2, "33.1 onsiteTi2 should have 2 invoice line");
	self.assertTrueMsg(onsiteTi2.allCashPayments.isNotEmpty(), "onsiteTi2 should have invoice line");
	self.assertTrueMsg(onsiteTi2.allCashPayments.size = 1, "33.1 onsiteTi2 should have 1 cash payment");
	realCashPay := onsiteTi2.allCashPayments.first;
	self.assertTrueMsg(realCashPay.cashValue = (cashToPay/4), "33.1 onsiteTi2 cash payment value is wrong is " &amp; realCashPay.cashValue.String);
	invLine := onsiteTi2.invoiceLines.first;
	self.assertTrueMsg(invLine.lineTotal =(cashToPay/8), "33.1 onsiteTi2 inv line total is wrong is " &amp; invLine.lineTotal.String);
	self.assertTrueMsg(onsiteTi1.totalQuantity = 3, "33.1 onsiteTi1 sbe 3");
	
	realCashPay := onsiteTi1.allCashPayments.first;
	self.assertTrueMsg(realCashPay.cashValue = (cashToPay/4)*3, "33.1 onsiteTi1 cash payment value is wrong is " &amp; realCashPay.cashValue.String);

	
	// MOVE 2/4 to 2nd location MERGE
	self.opts.purge();
	self.opts.addAssoc("TotalQuantity",1); // Move part
	self.move(onsiteTi1, blockStack2);

	onsiteTi2 := blockStack2.getTiById(_id1);
	self.assertTrueMsg(onsiteTi2 &lt;&gt; null, "onsiteTi2 is null");
	self.assertTrueMsg(onsiteTi2.totalQuantity = 2, "onsiteTi2 sbe 2");
	self.assertTrueMsg(onsiteTi1.totalQuantity = 2, "33.2 onsiteTi1 sbe 2");
	self.assertTrueMsg(onsiteTi2.allCashPayments.isNotEmpty(), "onsiteTi2 should have invoice line");
	self.assertTrueMsg(onsiteTi2.allCashPayments.size = 1, "33.2 onsiteTi2 should have 1 cash payment");
	
	realCashPay := onsiteTi2.allCashPayments.first;
	self.assertTrueMsg(realCashPay.cashValue = (cashToPay/4)*2, "33.2 onsiteTi2 cash payment value is wrong is " &amp; realCashPay.cashValue.String);
	realCashPay := onsiteTi1.allCashPayments.first;
	self.assertTrueMsg(realCashPay.cashValue = (cashToPay/4)*2, "33.2 onsiteTi1 cash payment value is wrong is " &amp; realCashPay.cashValue.String);
	
	self.assertTrueMsg(onsiteTi2.invoiceLines.isNotEmpty(), "onsiteTi2 should have invoice line");
	self.assertTrueMsg(onsiteTi2.invoiceLines.size = 2, "33.2 onsiteTi2 should have 2 invoice line");

epilog
	
	if agent1&lt;&gt; null then
		beginTransaction;
		agent1.allCashPayments.purge();
		commitTransaction;
	endif;
	if allAgents &lt;&gt; null then
		allAgents.purge();
	endif;
	delete allAgents;
	delete allTIs;
	delete invAssistant;
	delete newTiIds;
end;</source>
        <access>protected</access>
        <Parameter name="_id1" type="String"/>
        <Parameter name="_id2" type="String"/>
        <Parameter name="_drTerm1" type="CM_DebtorTerminal"/>
        <Parameter name="_type" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="cashTestMultipleReceipts9a" id="7118a234-c4a4-4a6e-990d-fef457545c89">
        <updating/>
        <source>cashTestMultipleReceipts9a(_id1 : String; _id2 : String; _drTerm1 : CM_DebtorTerminal; _type : Integer) updating, protected;
/*
Purpose - 	Test split and then merge of invoice lines and cash payments

				Create cargo on ship (break bulk splittable) Splittable cargo quantity of 4, volume of 1012.8275 weight of 18143.68.
				transaction map has mapping for move from ship to yard and storage. 
				
				Discharge 1st item in 2 parts. so merges, will be 2 invoice lines
				Then Split into 4 parts, different IDs using SPLIT TRX
				Should be 2 invoice lines on each TI
				Then Merge into 1 part, using MERGE TRX
				Should be 2 invoice lines
				
				Create Cash Receipt for the 2 invoice lines
				Then Split TI into 4 parts, different IDs using SPLIT TRX
				Should be 2 invoice lines and 2 cash payments on each TI
				Then Merge into 1 part, using MERGE TRX
				Should be 2 invoice lines and 2 cash payments
				
				Discharge 2nd TI whole
				should have an invoice line
				add a cash receipt that includes a manual cash payment with no invoice line
				cash receipt shoudl have 2 cash pyaments, 1 with an invoice line, 1 with the proforma detail
				Then Split TI into 4 parts, different IDs using SPLIT TRX
				Should be 1 invoice lines and 1 cash payments on each TI
				Then Merge into 1 part, using MERGE TRX
				Should be 1 invoice lines and 1 cash payments

				Who - NAVAB1
Date - 30JUN2025
ADO - JIRA 35213
*/

constants

vars
	now			: TimeStamp;
	cargoId		: String;
	msg			: String;
	invoiceEveryReceipt	: Boolean;
	
	cashReceipt1, cashReceipt2 : CM_CashReceipt;
	paymentMeth : CM_PaymentMethod;

	invAssistant	: Object;
	onsiteTi1,onsiteTi2,
	cashTI1, cashTI2	: CM_TrackedItem;

	nowDate,
	baseDate : Date;
	cashToPay,
	cashTotal	: Decimal[23,6];
	
	customsAgent	: CM_CustomsAgent;
	operator		: CM_Operator;
	debtor 		: CM_DebtorNode;
	
	allTIs 		: CM_TISet;
	type : CM_TerminalAreaType;
	blockStack1,
	blockStack2	: CM_BlockStack;
	allAgents		: ObjectArray;
	agent1	: CM_CashInvoiceProformaAgent;
	tempID : String;
	ct : CM_CargoType;
	port : CM_Port;
	invLine : CM_InvoiceLine;
	realCashPay, pxyCashPay : CM_CashPayment;
	newTiIds: StringArray;
	allTisToMerge : CM_TISet;
	newProfDetail : CM_ProformaDetails;
begin
	msg := method.name;
	if self.myTerminal.getConfig(CashInvoiceEveryReceipt).Boolean then
		invoiceEveryReceipt := true;
	endif;
	
	//self.myTerminal.setConfig(InvoiceRoundLineTotal,2);
	self.setTerminalConfig(InvoiceRoundLineTotal, 2);

	//self.assertTrueMsg(ct &lt;&gt; null, "Cargo Type 15104 - UTBY is null");
	if self.opts.includesKey("CargoType") then
		ct := self.opts.obj("CargoType").CM_CargoType;
	endif;
	self.assertNotNullMsg(ct, "Failed to get cargo Type");
	
	port := app.myRoot.allPorts["NZAKL"];
	self.assertTrueMsg(port &lt;&gt; null, "port is null");
	
	type := app.myRoot.allTerminalAreaTypes.getAtKey(1); // Block Stack
	blockStack1 := self.myTerminal.allTerminalAreasByTypeId.getAtKey( type.type, "UT_BS1").CM_BlockStack;
	self.assertTrueMsg(blockStack1 &lt;&gt; null, "Block Stack UT_BS1 not found...");
	blockStack2 := self.myTerminal.allTerminalAreasByTypeId.getAtKey( type.type, "UT_BS2").CM_BlockStack;
	self.assertTrueMsg(blockStack2 &lt;&gt; null, "Block Stack UT_BS2 not found...");
	// use an operator with a known non-cash debtor
	operator := self.getOperator("UTC1");
	if operator = null then
		operator := self.addOperatorSimple("UTC1", "Cash Test Operator");
	endif;
	
	self.deleteCargo(_id1 &amp; "-01", ct);
	self.deleteCargo(_id1 &amp; "-02", ct);
