	theRowHeight,
	theColWidth,
	yPos1, yPos2,
	xPos1, xPos2	: Integer;	
	tmpGA	: CM_GridArea;
	tmpTA : CM_TerminalArea;
	tmpPoint : Point;
	ydc : YRD_ContainerDrawingController;
	aGCol : CM_GridColumn;
begin
	_rows.clear;
