    <JadeMethod name="getDisplayDetails" id="7cff3802-2463-41dd-ba3b-f8bcb89ba79d">
        <source>getDisplayDetails(_short: Boolean): String;
//--------------------------------------------------
// Created:	12 July 2004 By: cnwgd1
//--------------------------------------------------
vars

begin
	if self.myLogLot &lt;&gt; null then
		return 'Lot ' &amp; self.lotNo;
	else			
		return self.consigneeCode &amp; '/' &amp; self.dischargePort &amp; '/' &amp; 'Lot ' &amp; self.lotNo;
	endif;

end;</source>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="0a5eaa79-e10c-44fd-88e3-1c69c2a39bc9">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
//--------------------------------------------------------------
//Created: 23 July 2002 By: cnwgd1
//--------------------------------------------------------------
vars

begin

	if _attrName = ETRow_OrderNo or _attrName = ETRow_MyOperator then
		return self.myStockOrderHeader.getDisplayStringForAttribute(_attrName, _short);
	elseif _attrName = ETRow_AllocVolume then
		return self.calAllocatedAmount.jasVolumeString;
	elseif _attrName = ETRow_MyLogLot or
		_attrName = ETRow_Lot or _attrName = ETRow_LotNo then
		return self.lotNo;	
	elseif _attrName = ETRow_ReqdQuantity or
		_attrName = ETRow_NumItems then
		//par no 14774---reopened
		return self.reqdQuantity.rounded.asStringJMT;			
	elseif _attrName = ETRow_Specifications then
		return self.myProduct.code;
	elseif _attrName = ETRow_Supplier then
		return self.getMyOperator().code;
	else
		return inheritMethod(_attrName, _short);
	endif;

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getExtraInfoLogVoyOps" id="d1cb767e-a078-4f53-8af7-0fb7e78d60d0">
        <source>getExtraInfoLogVoyOps(_array : HugeStringArray input; _terminalForTerminology : CM_Terminal);
//--------------------------------------------------------------
//Created: 23 July 2002 By: cnwgd1
//
//	par 10009 - _terminalForTerminology added to method signature. needed
//	for teminology. is taken from form so terminology will be consistent 
//	depending on what terminal the form was started from - HJG 10/05/05
//--------------------------------------------------------------
vars
	terminology :	String;
	
begin
	inheritMethod(_array,_terminalForTerminology);
	
	terminology := app.getTerminologyAlternate(app.myRoot.allCargoTypesById[TI_CargoType_Log], _terminalForTerminology, 
												CM_TerminologyOperator, CM_TermExpressionSingular, 'Supplier');
	
	_array.add("Customer" &amp; Tab &amp; self.consigneeCode);		
//	par 10009
	_array.add(terminology  &amp; " Reference 1" &amp; Tab &amp; self.operatorRef1);		
	_array.add(terminology  &amp; " Reference 2" &amp; Tab &amp; self.operatorRef2);
//	_array.add("Supplier Reference 1" &amp; Tab &amp; self.operatorRef1);		
//	_array.add("Supplier Reference 2" &amp; Tab &amp; self.operatorRef2);
	_array.add("Max Contract Quantity" &amp; Tab &amp; self.maxContractQuantity.String);		
	_array.add("Min Contract Quantity" &amp; Tab &amp; self.minContractQuantity.String);	
	_array.add("Lot No." &amp; Tab &amp; self.lotNo);		

end;</source>
        <Parameter name="_array" type="HugeStringArray" usage="input"/>
        <Parameter name="_terminalForTerminology" type="CM_Terminal"/>
    </JadeMethod>
