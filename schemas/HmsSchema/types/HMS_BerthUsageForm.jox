    <JadeMethod name="doHarbourSelect" id="24d8398c-d4c6-4fd1-8548-ce6c059df640">
        <source>doHarbourSelect(_row : Integer) protected;
//--------------------------------------------------
// Created:	24 November 2005 By: cnwgd1
//--------------------------------------------------
vars
	tmpWharf	: HMS_Wharf;
	tmpHarbour 	: HMS_Harbour;
	selected 	: Boolean;
	idx			: Integer;
	user		: CM_User;
	term		: CM_Terminal;
	passport	: CM_Passport;
	failedDAC  :CM_DataAccessController;
begin

	tmpHarbour := self.lstHarbours.accessRow(_row).itemObject.HMS_Harbour;
	
	if tmpHarbour = null then
		return;
	endif;

	selected := self.lstHarbours.allSelectedObjects.includes(tmpHarbour);

	passport := app.myPassport;
	user := passport.myUser;

	foreach term in tmpHarbour.allTerminalsByCode do
		idx := null;
		if (not term.canUserAccessSelf(user, failedDAC, passport)) then
			continue;
		endif;
		
		self.lstTerminals.findObjectInRow(term, idx);		
		
		if selected then
			if idx &lt; 1 then
				self.lstTerminals.addItemObject(term.name, term);
			endif;
		elseif idx &gt; 0 then
			//self.lstTerminals.removeItem(idx);
			//	09 Oct 2012	NDL	Par 30490
			self.lstTerminals.accessCell(idx, 1).text := TableCheckBox_NotSelected;
			if self.lstTerminals.allSelectedObjects.includes(term) then
				self.lstTerminals.allSelectedObjects.remove(term);
			endif;
		endif;
		
	endforeach;

	foreach tmpWharf in tmpHarbour.allWharves do
		idx := null;
		if (not tmpWharf.canUserAccessSelf(user, failedDAC, passport)) then
			continue;
		endif;

		self.lstWharves.findObjectInRow(tmpWharf, idx);
					
		if selected then
			if idx &lt; 1 then
				self.lstWharves.addItemObject(tmpWharf.getDisplayString(), tmpWharf);
			endif;
		elseif idx &gt; 0 then
			self.lstWharves.setRowSelect(idx, false);
			self.doWharfSelect(idx);
			self.lstWharves.removeItem(idx);
		endif;
	endforeach;	
	
end;</source>
        <access>protected</access>
        <Parameter name="_row" type="Integer"/>
    </JadeMethod>
