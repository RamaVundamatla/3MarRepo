    <JadeMethod name="getFirstTi" id="f3029b0b-39f3-4eee-80f7-a6826c31f506">
        <source>getFirstTi(_checkStatus : Boolean):CM_TrackedItem;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 Dec 2023 navhl20 ChangeRequest 58400:[61617] EUP | Ship Operations in DD - [54176.050] Mobile App changes
06 Mar 2025 navma1  MTN-34179 MTN | Dead Lock (1081) on CM_WLEArray
*/

vars
	ti 		: CM_TrackedItem;
	wle		: CM_WorkListEntry;
	invalid	: Boolean;
begin
	on Exception do app.handleDeletedObject(exception, ti, invalid); 
	
	foreach wle in self.workListEntries  discreteLock do			//06.03.2025 navma1 #MTN-34179
		
		invalid := false;
		
		if _checkStatus then 										//27/05/2024	navkc1 Bug 64295
			if wle.status = JOB_COMPLETE then
				continue;
			endif;
		endif;
		ti := wle.myTrackedItem;
	
		if ti &lt;&gt; null then
			ti.edition;
			if invalid then
				return null;
			else
				return ti;
			endif;
		endif;
	endforeach;
	return null;
epilog

end;</source>
        <Parameter name="_checkStatus" type="Boolean"/>
        <ReturnType type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="getFirstTrackedItem" id="0256e48d-b729-475e-acf0-44d42906fa28">
