    <JadeMethod name="doDelete" id="493b9f09-abf9-41dd-83b8-50ec81d8c576">
        <updating/>
        <source>doDelete(): Boolean updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
30 March 2012	cnwndl1	Initial creation	Par 29369

*/

vars

	theResult : Integer;	//14 Jan 2020 NDL	TFS 46815

begin

	//14 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
	while true do
	
		app.myTrxDA.trxDeleteWPOperatingHours(self.myCurrentObject.CM_WorkPointOperatingHours, app.myPassport);
	
		if app.myPassport.trxCompletedOK then
			return true;
		else
			theResult := app.showErrorWarningDialog('Crane Timings', app.myPassport, ErrWarnMode_Delete);
			if app.myPassport.noErrors and theResult = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		
		return false;
		
	endwhile;

epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doResize" id="07a00fff-64fd-49b4-80cd-8a19ff797749">
        <updating/>
        <source>doResize() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
10 April 2012	cnwndl1	Initial creation	Par 29369

*/

vars

	newRatio : Integer;

begin
	
	if self.frmDetailsTop.width &lt; 275 then
		newRatio := 100 - (( 275 / self.clientWidth ) * 100).Integer;
		self.sptMain.setLeftToRightRatioAndResize( newRatio );
		self.sptMain.cnEcResizeContents();
	endif;

	inheritMethod();
	
	self.cmbCrane.width := ( self.frmDetailsTop.width - self.cmbCrane.left ) - 3;
	self.txtRemarks.width := ( self.frmDetailsTop.width - self.txtRemarks.left ) - 3;
	self.txtRemarks.height :=  ( self.frmDetailsTop.height - self.txtRemarks.top ) - 10;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doSave" id="45343112-5b45-409c-acf0-ec8fef595eb2">
        <updating/>
        <source>doSave(): Boolean updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
30 March 2012	cnwndl1	Initial creation	Par 29369
//15 9 16 TFS 2679:Multi-timezone issues cnwns1 
25 September 2018	cnwma1	ChangeRequest 41080: PEL1 - Assigning Operators ID to Cranes/Work-Points
*/

vars
	
	pxyWpOperatingHrs : CM_WorkPointOperatingHours;
	obj : Object;
	crane : CM_Crane;
	wp : CM_WorkPoint;
	date : Date;
	time : Time;
	exchangeStartLocal : TimeStamp;
	exchangeEndLocal : TimeStamp;
	labourStartLocal : TimeStamp;
	labourEndLocal : TimeStamp;
	exchangeStartSystem : TimeStamp;	//2679:Multi-timezone issues
	exchangeEndSystem : TimeStamp;		//2679:Multi-timezone issues
	labourStartSystem : TimeStamp;		//2679:Multi-timezone issues
	labourEndSystem : TimeStamp;		//2679:Multi-timezone issues
	
	
	
	rtnValue : Boolean;
	result : Integer;
	user  : CM_User;
begin

	pxyWpOperatingHrs := self.myProxyObject.CM_WorkPointOperatingHours;
	
	if self.mode = Mode_Add then 
		create pxyWpOperatingHrs transient;
		self.myProxyObject := pxyWpOperatingHrs;
	elseif self.mode = Mode_Update then // can update user jobs and jobs created by painting on the voyage
		if self.myProxyObject = null then
			app.raiseUnexpectedProgramError(class.name, method.name, 'Proxy is null for update');
			return false;
		endif;
	else
		app.raiseUnexpectedProgramError(class.name, method.name, 'Unhandled mode (' &amp; self.mode.String &amp; ')');
		return false;
	endif;
	
	exchangeStartLocal := null;
	exchangeEndLocal := null;
	labourStartLocal := null;
	labourEndLocal := null;
	
	if self.cmbCrane.listIndex &gt; 0 then	
		obj := cmbCrane.itemObject[self.cmbCrane.listIndex];
		if obj &lt;&gt; null then
			if obj.isKindOf( CM_Crane ) then
				crane := obj.CM_Crane;
			elseif obj.isKindOf( CM_WorkPoint ) then
				wp := obj.CM_WorkPoint;
			endif;
		endif;
	endif;
	//25.09.2018 cnwma1 TFS #41080
	if self.cmbCraneOpr.listIndex &gt; 0 then	
		obj :=  cmbCraneOpr.itemObject[self.cmbCraneOpr.listIndex];
		if obj &lt;&gt; null then
			if obj.isKindOf( CM_User ) then
					user := obj.CM_User;
			endif;
		endif;
	endif;
	date := self.txtLabourStDt.getDate;
	labourStartLocal.setDate( date );
	time := self.txtLabourStTm.getTime;
	labourStartLocal.setTime( time );
	labourStartSystem := self.localToSystemTime(labourStartLocal);//2679:Multi-timezone issues
	
	date := self.txtExchangeStDt.getDate;
	exchangeStartLocal.setDate( date );
	time := self.txtExchangeStTm.getTime;
	exchangeStartLocal.setTime( time );
	exchangeStartSystem:= self.localToSystemTime(exchangeStartLocal);//2679:Multi-timezone issues
	
	date := self.txtExchangeEndDt.getDate;
	exchangeEndLocal.setDate( date );
	time := self.txtExchangeEndTm.getTime;
	exchangeEndLocal.setTime( time );
	exchangeEndSystem:= self.localToSystemTime(exchangeEndLocal);//2679:Multi-timezone issues
	
	date := self.txtLabourEndDt.getDate;
	labourEndLocal.setDate( date );
	time := self.txtLabourEndTm.getTime;
	labourEndLocal.setTime( time );
	labourEndSystem:= self.localToSystemTime(labourEndLocal);//2679:Multi-timezone issues

	pxyWpOperatingHrs.setProxy(	exchangeStartSystem,	//_exchangeStart : TimeStamp;
								exchangeEndSystem,	//_exchangeEnd : TimeStamp;
								labourStartSystem,	//_labourStart : TimeStamp;
								labourEndSystem,	//_labourEnd : TimeStamp;
								self.txtRemarks.text.trimBlanks,	//_remarks : String;
								crane,	//_myCrane : CM_Crane;
								wp,	//_myWorkPoint : CM_WorkPoint;
								self.myVoyage,	//_myVoyage : CM_Voyage
								user
								);
	
	while true do
		if self.mode = Mode_Add then 
			app.myTrxCA.trxCreateWpOperatingHrs(pxyWpOperatingHrs, self.myCurrentObject,app.myPassport);
		else
			app.myTrxUA.trxUpdateWpOperatingHrs(pxyWpOperatingHrs, app.myPassport);
		endif;
		if app.myPassport.trxCompletedOK then
			rtnValue := true;
			break;
		else
			result := app.showErrorWarningDialog('Crane Timings Maintenance', app.myPassport, ErrWarnMode_Update);
			if app.myPassport.noErrors and
			   result = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		rtnValue := false;
		break;
	endwhile;

	return rtnValue;
	
epilog
	
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doSptMainMove" id="b1a021b7-390a-4623-aef6-29a7b88f938a">
