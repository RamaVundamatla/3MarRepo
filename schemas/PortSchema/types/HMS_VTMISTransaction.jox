    <JadeMethod name="hasResourceTypeForEquipment" id="d14ce5db-421f-4d5c-8731-114ac15f2f72">
        <source>hasResourceTypeForEquipment():Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 Jan 2019	jlgndl1	ChangeRequest 41980: PEL1 - SAP Equipment Details

*/

vars

	voyageProcess : CM_VoyageProcess;
	processHarbour : CM_ProcessHarbour;

begin

	if self.myResourceUsed = null
	or self.myResourceUsed.myResourceType = null
	or self.myTerminal = null
	or self.myTerminal.myHarbour = null
	or self.myVoyage = null
	or self.myVoyage.isUsingDefaultProcessJMT
	then
		return false;
	endif;
	
	voyageProcess := self.myVoyage.myVoyageProcess;
	
	if voyageProcess.allProcessHarbours.isEmpty then
		return false;
	endif;
	
	processHarbour := voyageProcess.allProcessHarbours.getAtKey( voyageProcess, self.myTerminal.myHarbour );
	
	if processHarbour = null or processHarbour.allHMSResourceTypeForEquip.isEmpty then
		return false;
	endif;
	
	return processHarbour.allHMSResourceTypeForEquip.includes( self.myResourceUsed.myResourceType );
		
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isCharged" id="bae09bd3-1ac9-442b-983b-c65d78e8b3e9">
