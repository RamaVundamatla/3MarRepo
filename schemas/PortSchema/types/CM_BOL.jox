    <JadeMethod name="getBOLWeight" id="90733e1d-844b-459e-85f3-4181719588d6">
        <source>getBOLWeight() : Decimal;
// 35991 get BOL weight from details, is not recorded against the BOL itself
vars
	totalWeight	: Decimal[16, 4];
	detail	: CM_BOLDtl;
begin
	foreach detail in self.allBOLDtls do
		//epr TFS 2334 18/7/16
		if detail.myCargoType = null then
			continue;
		endif;
		if not detail.myCargoType.isContainer() then
			continue;
		endif;
		
		if detail.quantity = 0 or detail.weight = 0 then
			continue;
		endif;
		totalWeight := totalWeight + detail.weight;
	endforeach;
	return totalWeight;
end;
</source>
        <ReturnType type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="getBOLWeightForContainer" id="631a359f-5b75-4f79-b9aa-3a3ccaf1bd89">
        <source>getBOLWeightForContainer() : Decimal;
/*

Date		Who		Reason
18 July 2016	cnwer1	Initial creation TFS 2334
21 Oct 2019 cnwma1 Bug 47081: JMT - Decimal amount on Cash needs to be reviewed
*/

vars

	totalWeight	: Decimal[14, 4]; //21.10.2019 cnwma1 TFS #47081
	detail	    : CM_BOLDtl;
	quantity    : Integer;
begin
	foreach detail in self.allBOLDtls do
		if detail.myCargoType = null then
			continue;
		endif;
		if not detail.myCargoType.isContainer() then
			continue;
		endif;
		
		if detail.quantity = 0 or detail.weight = 0 then
			continue;
		endif;
		
		quantity:= quantity + detail.quantity;
		
		totalWeight := totalWeight + detail.weight;
	endforeach;
	
	if quantity &lt;&gt; 0 then
		return totalWeight/quantity;
	endif;
	
	return null;
epilog

end;</source>
        <ReturnType type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="getBOLWeightForInvoice" id="df654899-319a-4ea7-8bc3-296030add3cb">
