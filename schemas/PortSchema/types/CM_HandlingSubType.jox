    <JadeMethod name="create" id="99029a7e-1147-4067-b085-6c771d4b8224">
        <updating/>
        <source>create() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 March 2017	cnwndl1	Initial creation	TFS 3414

*/

vars

begin

	if not self.isTransient then
		self.myRoot := app.myRoot;
	endif;

epilog

end;</source>
