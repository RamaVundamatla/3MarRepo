    <JadeMethod name="create" id="2372951f-ed78-41d7-b59b-d2fc322ba038">
        <updating/>
        <source>create() updating;
// -----------------------------------------------------------------------------
// Created:		05 August 2009 by consw1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//
// -----------------------------------------------------------------------------

vars

begin
	if self.isTransient() then
		self.myCargoType := app.myPassport.getDefaultCargoType();
	endif;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="22e51406-3a0e-4151-a284-14d94ed8fb63">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
12 November 2009	cnwrd1	Initial creation

*/

vars

begin
	
	if _attrName = ETRow_RbtRequestDesc then
		return self.getListDisplay();
	elseif _attrName = ETRow_RbtTotalRequested then
		return self.totalRequested.asStringJMT();
	elseif _attrName = ETRow_RbtActioned then
		return self.totalActioned.asStringJMT();
	elseif _attrName = ETRow_RbtLeft then
		return self.getTotalToAction().asStringJMT();
	elseif _attrName = ETRow_RbtToAction then
		return '';
		//return self.getNumberRemainingToComplete().asStringJMT();
	endif;
	
	return inheritMethod(_attrName, _short);

epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getListDisplay" id="f9856278-f7da-435f-a79e-f58916bcbdab">
        <source>getListDisplay() : String;
// -----------------------------------------------------------------------------
// Created:		04 August 2009 by consw1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//
// -----------------------------------------------------------------------------

vars

begin

	if self.isoType = null then
		return self.totalRequested.asStringJMT &amp; " x " &amp; self.myCargoType.description;
	else
		if self.myOperator &lt;&gt; null then
			return self.totalRequested.asStringJMT &amp; " x " &amp; self.myCargoType.description &amp; '(' &amp; self.isoType &amp;',' &amp; self.myOperator.code &amp; ')';
		else
			return self.totalRequested.asStringJMT &amp; " x " &amp; self.myCargoType.description &amp; '(' &amp; self.isoType &amp; ')';
		endif;
	endif;
	
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getTotalToAction" id="8048cf83-29cc-45a0-b5ce-13d739fa953b">
        <source>getTotalToAction() : Integer;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
12 November 2009	cnwrd1	Initial creation

*/

vars

begin

	return self.totalRequested - self.totalActioned;

epilog

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="hasCargoToAction" id="5f41b401-1ccf-464e-a9c8-6af2b9b8211d">
        <source>hasCargoToAction() : Boolean;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
12 November 2009	cnwrd1	Initial creation

*/

vars

begin
	return self.getTotalToAction() &gt; 0 ;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="myCargoType" id="7044b4f1-055e-491c-a9e0-30d635368874">
        <methodInvocation>mapping</methodInvocation>
        <source>myCargoType( _set : Boolean; _value : CM_CargoType io) mapping;
/*
Date		Who		Reason
17 June 2010	cnwrd1	Initial creation

*/

vars

begin
	if not _set or						// not setting
		self.isTransient or				// don't need to bother for transients
		_value = null or				// new cargo type is null
		self.myCargoType = _value then	// not changing cargo type
		return;
	endif;
	
	if _value &lt;&gt; null then
		_value.updateForNonInversedReference;
	endif;
epilog

end;</source>
        <Parameter name="_set" type="Boolean"/>
        <Parameter name="_value" type="CM_CargoType" usage="io"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="7df54278-7fe0-4ba8-8d51-dba3b32f97ab">
        <source>pxyCreateUpdateProxy(): SelfType;
// -----------------------------------------------------------------------------
// Created:		05 August 2009 by consw1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
// 20/04/2011	cnwmh5		PAR #27401 - Add code to handle prossible exceptions occurring when
//							trying to create the proxy
// -----------------------------------------------------------------------------

vars
	pxy : SelfType;
	completedOK		: Boolean;
	
begin
	pxy := inheritMethod();

	pxy.myCargoType			:= self.myCargoType;
	pxy.myOperator			:= self.myOperator;
	pxy.myOperatorGroup		:= self.myOperatorGroup;
	pxy.myProduct			:= self.myProduct;
	pxy.mySourceLocation	:= self.mySourceLocation;
	
	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return pxy;
	
epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete pxy;
	endif;

end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="f0627f37-a8fa-426c-8522-46976a0d956e">
        <updating/>
        <source>setForCreate( _proxy : SelfType ) updating;
// -----------------------------------------------------------------------------
// Created:		05 August 2009 by consw1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//
// -----------------------------------------------------------------------------

vars

begin
	self.setForUpdate(_proxy);
epilog

end;</source>
        <Parameter name="_proxy" type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="f44e7d7f-561c-419a-89b4-2508350eed9e">
        <updating/>
        <source>setForUpdate( _proxy : SelfType ) updating;
// -----------------------------------------------------------------------------
// Created:		05 August 2009 by consw1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//
// -----------------------------------------------------------------------------

vars

begin
	self.myCargoType		:= _proxy.myCargoType;
	self.isoType			:= _proxy.isoType;
	self.myOperator			:= _proxy.myOperator;
	self.myOperatorGroup	:= _proxy.myOperatorGroup;
	self.mySourceLocation	:= _proxy.mySourceLocation;
	self.totalRequested		:= _proxy.totalRequested;
	//self.doISOGroupCheck	:= _proxy.doISOGroupCheck;  /switched to below
	self.isoGroup 			:= _proxy.isoGroup;
	self.clean				:= _proxy.clean;
	self.heavyRated			:= _proxy.heavyRated;
	self.myProduct			:= _proxy.myProduct;

	self.allAvailabilityGrades.clear();
	_proxy.allAvailabilityGrades.copy(self.allAvailabilityGrades);

epilog

end;</source>
        <Parameter name="_proxy" type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="3f6ecc6d-ded7-4a94-8961-adb94af38a18">
        <updating/>
        <source>setProxy(	_myCargoType		: CM_CargoType;
			_isoType			: String;
			_operator			: CM_Operator;
			_operatorGroup		: CM_OperatorGroup;
			_totalRequested		: Integer;
			_isoGroup			: String;
			_availabilityGrades	: IntegerArray;
			_clean 				: Boolean;
			_heavyRated			: Boolean;
			_sourceLocation		: CM_LocationsController;
			_product			: CM_Product				) updating;
// -----------------------------------------------------------------------------
// Created:		03 August 2009 by consw1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//
// -----------------------------------------------------------------------------

vars

begin
	self.myCargoType		:= _myCargoType;
	self.isoType			:= _isoType;
	self.myOperator			:= _operator;
	self.myOperatorGroup	:= _operatorGroup;
	self.totalRequested		:= _totalRequested;
	//self.doISOGroupCheck	:= _doISOGroupCheck;
	self.isoGroup			:= _isoGroup;
	self.clean				:= _clean;
	self.heavyRated			:= _heavyRated;
	self.mySourceLocation	:= _sourceLocation;
	self.myProduct			:= _product;

	self.allAvailabilityGrades.clear();
	_availabilityGrades.copy(self.allAvailabilityGrades);

epilog

end;</source>
        <Parameter name="_myCargoType" type="CM_CargoType"/>
        <Parameter name="_isoType" type="String"/>
        <Parameter name="_operator" type="CM_Operator"/>
        <Parameter name="_operatorGroup" type="CM_OperatorGroup"/>
        <Parameter name="_totalRequested" type="Integer"/>
        <Parameter name="_isoGroup" type="String"/>
        <Parameter name="_availabilityGrades" type="IntegerArray"/>
        <Parameter name="_clean" type="Boolean"/>
        <Parameter name="_heavyRated" type="Boolean"/>
        <Parameter name="_sourceLocation" type="CM_LocationsController"/>
        <Parameter name="_product" type="CM_Product"/>
    </JadeMethod>
    <JadeMethod name="setTotalActioned" id="4deef753-7dff-4cd1-894e-6d6adad3b99e">
        <updating/>
        <source>setTotalActioned( _actioned : Integer) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
28 July 2009	cnwrd1	Initial creation

*/

vars

begin

	self.totalActioned := _actioned;
epilog

end;</source>
        <Parameter name="_actioned" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="validateForCreate" id="78e5b98d-2c3d-4c79-9b84-ba58e6f2f19b">
        <source>validateForCreate();
// -----------------------------------------------------------------------------
// Created:		05 August 2009 by consw1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//
// -----------------------------------------------------------------------------

vars
	realWorkOrder 			: CM_WorkOrder;
	pxyWorkOrderSource,	
	realWorkOrderSource		: CM_WorkOrderTISource;
begin

	pxyWorkOrderSource := self.myWorkOrderTISource;
	realWorkOrderSource := self.myWorkOrderTISource.pxyGetRealObject();
	
	// we need to find out if we have a real work order yet, could be a first save
	if realWorkOrderSource &lt;&gt; null then
		realWorkOrder := realWorkOrderSource.getWorkOrder();
	else
		//grab the proxy for validation
		realWorkOrder := pxyWorkOrderSource.getWorkOrder();
	endif;
		
	//realWorkOrder := self.myWorkOrderTISource.pxyGetRealObject().getWorkOrder();
	
	if not realWorkOrder.canSourcesBeAdded() then
		app.raiseCMException2(ERR_CannotAddCargoSourcesToWO, realWorkOrder.id.asStringJMT(), realWorkOrder.getStatusString(), null, null);
		return;
	endif;

	self.validateForUpdate();
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="validateForDelete" id="fe0ba238-dcf0-4193-92ad-7273a08b5ab9">
        <source>validateForDelete();
// -----------------------------------------------------------------------------
// Created:		05 August 2009 by consw1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//
// -----------------------------------------------------------------------------

vars
	realWorkOrder : CM_WorkOrder;
	
begin
	realWorkOrder := self.myWorkOrderTISource.getWorkOrder();
	
	if not realWorkOrder.canSourcesBeRemoved() then
		app.raiseCMException2(ERR_CannotDelCargoSourceFromWO, realWorkOrder.id.asStringJMT(), realWorkOrder.getStatusString(), null, null);
	endif;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="validateForUpdate" id="6f6794ac-8982-4daa-8270-869e999673a0">
        <source>validateForUpdate();
// -----------------------------------------------------------------------------
// Created:		05 August 2009 by consw1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//
// -----------------------------------------------------------------------------

vars

begin
	if self.myCargoType = null then
	//	app.raiseCMException1(REQUIRED_FIELD, app.getErrorString(CargoType), null, null);
		app.raiseCMException1(Input_required_field_Required, app.getErrorString(CargoType), null, null); // cnwdb2	PAR 35364
	elseif self.myCargoType.isISOType() and (self.isoType = null  and self.isoGroup = null ) then
	//	app.raiseCMException1(REQUIRED_FIELD, app.getErrorString(CM_ISO_Type), null, null);
		app.raiseCMException1(Input_required_field_Required, app.getErrorString(CM_ISO_Type), null, null); // cnwdb2	PAR 35364
	endif;

	if self.totalRequested = null then
	//	app.raiseCMException1(REQUIRED_FIELD, app.getErrorString(CM_Number_Of_Items), null, null);
		app.raiseCMException1(Input_required_field_Required, app.getErrorString(CM_Number_Of_Items), null, null); // cnwdb2	PAR 35364
	endif;
	
epilog

end;</source>
    </JadeMethod>
</Class>
