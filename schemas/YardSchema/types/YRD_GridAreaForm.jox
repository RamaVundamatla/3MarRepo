    <JadeMethod name="showRestrictionsForm" id="2b3760de-aead-4063-8c0d-255238116cf1">
        <source>showRestrictionsForm(_theTerminalArea : CM_TerminalArea;_areaMode : Integer; _initObject : CM_Object);
// ---------------------------------------------------------------------------
// Created:		June 2003 By Andrew Bishop cnwab1
//
// Purpose:		
// ---------------------------------------------------------------------------
vars

	theTerminalArea : CM_TerminalArea;
	aForm 	: Form;
	menuAction 		: CMUI_MenuAction;
begin
	if _theTerminalArea = null then
		return;
	endif;
	
	theTerminalArea := _theTerminalArea;
	menuAction := app.myController.createMenuAction(PmAdmPadeditView, null, self.myMasterMenuAction, self.myTerminal);
	if menuAction = null then
		return;
	endif;
	
	aForm := menuAction.goToObject(null, null, false, null); 
	if aForm = null then
		return;
	endif;
	
	aForm.sendMsgWithParams("setInitializeWithObject",theTerminalArea,_areaMode,_initObject,self.xmlFlipH,self.xmlFlipV);
	aForm.show;	


end;</source>
        <Parameter name="_theTerminalArea" type="CM_TerminalArea"/>
        <Parameter name="_areaMode" type="Integer"/>
        <Parameter name="_initObject" type="CM_Object"/>
    </JadeMethod>
    <JadeMethod name="sptBottom_splitterMove" id="a9416894-e2d0-4f27-960d-23328158a9a4">
        <controlMethod name="CMUI_SplitContainer::splitterMove"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>sptBottom_splitterMove(pSplitContainer: CMUI_SplitContainer input) updating;
// ---------------------------------------------------------------------------
// Created:		June  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
