    <JadeMethod name="setProxyObject" id="26b46258-10fc-45cd-a53b-73ab30b7f4e0">
        <updating/>
        <source>setProxyObject(_any : Any) updating;
/*
Purpose:			

Date		Who		Reason
24MAR2022	NAVRA1	TFS 53028
08 Jan 2026 navma1  MTN-36897 PEN - Transient File Growth in PEN Production Environment 
*/


vars
	helper 				: 	CMIF_InvMoveEvent;
	ewsOpsView			: 	CM_EWSActivityOpsview;
	wle					:	CM_WorkListEntry;	
	transIter			:	Iterator;
	transaction			:	CM_TITransaction;
	lastTransaction		:	CM_TITransaction;
	requiredMoveEvent 	: 	CM_Move;
	moveAsAny			:	Any;
	
begin
	
	inheritMethod(_any);
	
	//We pass in the WLE to this method, this will always answer true
	if _any.isKindOf(CM_WorkListEntry) then
		wle := _any.CM_WorkListEntry;	
	else
		return;
	endif;	
	
	//Go through the transactions of the WLE and get the last one which 
	//is the move event we are interested in
	transIter :=	wle.myTrackedItem.allTransactions.createIterator();	
	
	lastTransaction := null;
		
	while transIter.next(transaction) do
		if lastTransaction = null and transaction.type = TRANS_TYPE_MOVE then
			lastTransaction := transaction;
		endif;
		
		//Get the last transaction
		if lastTransaction &lt;&gt; null then
			if transaction.type = TRANS_TYPE_MOVE then 
				if lastTransaction.dateTime &lt; transaction.dateTime or lastTransaction.dateTime = transaction.dateTime  then
					lastTransaction := transaction;
				endif;
			endif;
		endif;
	endwhile;
	
	create requiredMoveEvent transient;
	if lastTransaction &lt;&gt; null and lastTransaction.type = TRANS_TYPE_MOVE then	//should never fail
		requiredMoveEvent := lastTransaction.CM_Move;		
	else
		app.writeLog('No moves available for WLE!', LogINFO);
		return;
	endif;
	
	moveAsAny	:=	requiredMoveEvent;
	
	//Now translate it
	create helper transient;
	create ewsOpsView transient;	
	ewsOpsView.initialiseActivity("","", wle.getMyTerminal(), moveAsAny.CM_Object, null,null,false,null);
	helper.initializeForActivity(requiredMoveEvent, ewsOpsView);		
	
	self.tableName					:= 	helper.tableName;
	self.berth						:= 	helper.berth;
	self.carrier_gkey				:=	helper.carrier_gkey;
	self.category 					:= 	helper.category;
	self.fm_pos_loc_gkey			:= 	helper.fm_pos_loc_gkey;
	self.fm_pos_slot				:= 	helper.fm_pos_slot;
	self.fm_pos_bin					:= 	helper.fm_pos_bin;
	self.fm_pos_tier				:= 	helper.fm_pos_tier;
	self.to_pos_bin 				:= 	helper.to_pos_bin;
	self.to_pos_name 				:= 	helper.to_pos_name;
	self.to_pos_tier				:= 	helper.to_pos_tier;
	self.che_carry 					:= 	helper.che_carry;
	self.che_carry_login_name		:= 	helper.che_carry_login_name;
	self.che_fetch					:= 	helper.che_fetch;
	self.che_fetch_login_name		:= 	helper.che_fetch_login_name;
	self.che_put					:= 	helper.che_put;
	self.che_put_login_name			:= 	helper.che_put_login_name;
	self.che_qc						:= 	helper.che_qc;
	self.dist_carry					:= 	helper.dist_carry;
	self.dist_start					:= 	helper.dist_start;
	self.exclude					:= 	helper.exclude;
	self.fm_pos_bin					:= 	helper.fm_pos_bin;	
	self.fm_pos_locid				:= 	helper.fm_pos_locid;
	self.fm_pos_loctype				:= 	helper.fm_pos_loctype;
	self.fm_pos_name				:= 	helper.fm_pos_name;
	self.fm_pos_orientation			:= 	helper.fm_pos_orientation;
	self.fm_pos_orientation_degrees	:= 	helper.fm_pos_orientation_degrees;		
	self.freight_kind				:= 	helper.freight_kind;
	self.line_op					:= 	helper.line_op;
	self.move_kind					:= 	helper.move_kind;
	self.mve_gkey					:= 	helper.mve_gkey;
	self.pow						:= 	helper.pow;
	self.processed					:= 	helper.processed;
	self.rehandle_count				:= 	helper.rehandle_count;
	self.restow_account				:= 	helper.restow_account;
	//self.restow_count - read only field
	self.restow_reason				:= 	helper.restow_reason;
	self.service_order				:= 	helper.service_order;
	self.t_carry_complete			:= 	helper.t_carry_complete;
	self.t_carry_dispatch			:= 	helper.t_carry_dispatch;
	self.t_carry_fetch_ready		:= 	helper.t_carry_fetch_ready;
	self.t_carry_put_ready			:= 	helper.t_carry_put_ready;
	self.t_discharge				:= 	helper.t_discharge;
	self.t_dispatch					:= 	helper.t_dispatch;
	self.t_fetch					:= 	helper.t_fetch;
	self.t_put						:= 	helper.t_put;
	self.t_tz_arrival				:= 	helper.t_tz_arrival;
	self.to_pos_bin					:= 	helper.to_pos_bin;
	self.to_pos_loc_gkey			:= 	helper.to_pos_loc_gkey;
	self.to_pos_loc_slot			:= 	helper.to_pos_loc_slot;
	self.to_pos_locid				:= 	helper.to_pos_locid;
	self.to_pos_loctype				:= 	helper.to_pos_loctype;
	self.to_pos_name				:= 	helper.to_pos_name;
	self.to_pos_orientation			:= 	helper.to_pos_orientation;
	//self.to_pos_orientation_degrees - read only field
	self.to_pos_slot				:= 	helper.to_pos_slot;
	self.to_pos_tier				:= 	helper.to_pos_tier;
	self.twin_carry					:= 	helper.twin_carry;
	self.twin_fetch					:= 	helper.twin_fetch;
	self.twin_put					:= 	helper.twin_put;
	self.ufv_gkey					:= 	helper.ufv_gkey;	

epilog
	delete helper;
	delete ewsOpsView;
	delete transIter;		//08.01.2026 navma1 #MTN-36897
end;
</source>
        <Parameter name="_any" type="Any"/>
    </JadeMethod>
</Class>
