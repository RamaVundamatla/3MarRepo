/*

Purpose:			Creates a new Cargo Forecast from Proxy object passed in and gives a new cargo forecast record out

Parameters:			_pxyCargoForecast	CM_CargoForecast	Proxy cargo forecast to create real object from (Input meaning it gets passed in as a constant)
					_newCargoForecast	CM_CargoForecast	Real cargo forecast created (Output meaning it is passed outwards)
					_passport			CM_Passport			Passport to use for our Trx that holds errors and other useful data

Return Value:		None

Date		Who		Reason
04 April 2022	navpw1	Initial creation TFS: 53132

*/

begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	app.setContinueCMExceptions(false);
	// Start the transaction
	beginTransaction;

	// Perform the operation
	app.myUtilityCA.utlCreateCargoForecast(_pxyCargoForecast, _newCargoForecast, _passport);
	
epilog
	self.finaliseActivityWithPassport(_passport);

end;</source>
