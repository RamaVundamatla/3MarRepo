    <JadeMethod name="removeCommentsFromSource" id="d785e285-28c1-4a65-9dfe-05f0bedd1e58">
        <source>removeCommentsFromSource(pSource: String): String;

/*
Purpose:			To remove the fluff from a method source. Fluff is comment text and the contents of string literals.
					This is for use when checking for leaking transients.
					The purpose of this is two-fold: to reduce the number of (1) tokens to be processed, and (2) false positives
					which occur when the 'never delete a line of code' brigade comment out foreach statements and replace them
					with while statements.

Return Value:		The defluffed source.

Date				Who			Reason
14 Jun 2005			cnwjub1		Creation
02 Sep 2008	cnwkpd1	"Borrowed" code from JSMS

*/

vars
	dq, sq, sa, ss, p, p1, sz, first, eol: Integer;
	src, str: String;

begin
	src:= pSource;
	p:= 1;
	sz:= src.length;
	dq:= src.pos('"', 1);
	sq:= src.pos("'", 1);
	sa:= src.pos("/*", 1);
	ss:= src.pos("//", 1);
	while true do
		if dq &gt; 0 and dq &lt; p then
			dq:= src.pos('"', p);
		endif;
		if sq &gt; 0 and sq &lt; p then
			sq:= src.pos("'", p);
		endif;
		if sa &gt; 0 and sa &lt; p then
			sa:= src.pos("/*", p);
		endif;
		if ss &gt; 0 and ss &lt; p then
			ss:= src.pos("//", p);
		endif;
		first:= 0;
		p1:= sz + 1;
		if dq &gt; 0 then
			first:= 1;
			p1:= dq;
		endif;
		if sq &gt; 0 and sq &lt; p1 then
			first:= 2;
			p1:= sq;
		endif;
		if sa &gt; 0 and sa &lt; p1 then
			first:= 3;
			p1:= sa;
		endif;
		if ss &gt; 0 and ss &lt; p1 then
			first:= 4;
			p1:= ss;
		endif;
		if first = 1 then
			// Double quote: copy up to and including, then discard up to but not including match
			str:= str &amp; src[p:(p1-p+1)];
			p:= p1 + 1;
			if p &gt; sz then
				break;
			endif;
			dq:= src.pos('"', p);
			if dq &lt;= 0 then // No match
				break;
			endif;
			p:= dq + 1;
			str:= str &amp; '"';
		elseif first = 2 then
			// Single quote: copy up to and including, then discard up to but not including match
			str:= str &amp; src[p:(p1-p+1)];
			p:= p1 + 1;
			if p &gt; sz then
				break;
			endif;
			sq:= src.pos("'", p);
			if sq &lt;= 0 then // No match
				break;
			endif;
			p:= sq + 1;
			str:= str &amp; "'";
		elseif first = 3 then
			// Slash asterisk: copy up to but not including, then discard up to and including mate
			str:= str &amp; src[p:(p1-p)];
			p:= p1 + 2;
			if p &gt; sz then
				break;
			endif;
			sa:= src.pos("*/", p);
			if sa &lt;= 0 then // No match
				break;
			endif;
			p:= sa + 2;
		elseif first = 4 then
			// Slash slash: copy up to but not including, then discard up to but not including end of line
			str:= str &amp; src[p:(p1-p)];
			p:= p1 + 2;
			if p &gt; sz then
				break;
			endif;
			eol:= src.pos(Cr, p);
			if eol &lt;= 0 then // No end of line
				break;
			endif;
			p:= eol;
		else
			// No more: copy to end and exit
			str:= str &amp; src[p:end];
			break;
		endif;
		if p &gt; sz then
			break;
		endif;
	endwhile;
	return str;
end;</source>
        <Parameter name="pSource" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="setActiveProfile" id="5ee57777-79b1-4f6d-8aa0-5fec218c8146">
        <updating/>
        <source>setActiveProfile() updating, protected;
//23 October 2008	cnwdw1	
//
begin
	self.testProfile := self.getTestProfile();
	if self.testProfile &lt;&gt; null then
		self.activeProfile := self.testProfile;
	elseif self.testerProfile &lt;&gt; null then
		self.activeProfile := self.testerProfile;
	else
		self.testProfile := self.getDefaultProfile();
		if self.testProfile &lt;&gt; null then
			self.activeProfile := self.testProfile;
		endif;
	endif;
	app.myPassport.setMyTerminal(CM_Root.firstInstance.allTerminals[self.getProfileSetting(UT_Profile.P_TERMINAL).asString]);
	app.myPassport.setMyUserFromCode(self.getProfileSetting(UT_Profile.P_USER).asString);
//	app.setSpecial('31/12/3000'.TimeStamp);

end;</source>
        <access>protected</access>
    </JadeMethod>
