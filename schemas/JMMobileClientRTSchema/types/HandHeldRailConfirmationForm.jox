Created:	12 September 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars

begin
	inheritMethod();
	self.endNotificationForSubscriber(self);
	self.beginClassNotification(CM_Train, false, Any_System_Event, Response_Continuous, null);
	
	
	self.frmInward.zOrder(1);
