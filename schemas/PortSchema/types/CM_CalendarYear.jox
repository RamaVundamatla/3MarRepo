<Class name="CM_CalendarYear" id="80a8d6ba-2f0b-4e0d-b384-4416f0508a6c">
    <superclass name="CM_Object"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="misc"/>
    <ExplicitInverseRef name="allCalendarDates" id="b92722a0-999b-469f-9497-16fe6a980480">
        <kind>parent</kind>
        <transientToPersistentAllowed/>
        <updateMode>automatic</updateMode>
        <type name="CM_CalendarDatesByDateTimedict"/>
        <access>readonly</access>
        <Inverse name="CM_CalendarDate::myCalendarYear"/>
    </ExplicitInverseRef>
    <ExplicitInverseRef name="myCalendar" id="5c913e0c-f506-4f47-9b3c-cac91e36e9ac">
        <kind>child</kind>
        <transientToPersistentAllowed/>
        <updateMode>manual</updateMode>
        <embedded/>
        <type name="CM_Calendar"/>
        <access>readonly</access>
        <Inverse name="CM_Calendar::allCalendarYears"/>
    </ExplicitInverseRef>
    <PrimAttribute name="year" id="bc39f351-9bf6-432e-87ec-b8f8844b6a53">
        <embedded/>
        <type name="Integer"/>
        <access>readonly</access>
    </PrimAttribute>
    <JadeMethod name="pxyCreateUpdateProxy" id="a6ec566c-7480-4797-8449-9eb2efbf6f39">
        <source>pxyCreateUpdateProxy(): SelfType;
// ---------------------------------------------------------------------------
// Created:     28 January 2005	cnwhjg1
//
// Purpose:     
// ----------   ----------  --------------------------------------------------
// 20/04/2011	cnwmh5		PAR #27401 - Add code to handle prossible exceptions occurring when
//							trying to create the proxy

vars
	pxyCalendarYear : CM_CalendarYear;
	date,
	pxyCalendarDate : CM_CalendarDate;
	completedOK		: Boolean;
begin
	pxyCalendarYear := inheritMethod();

	foreach date in self.allCalendarDates do
		pxyCalendarDate := app.createUpdateProxy(date).CM_CalendarDate;
		pxyCalendarDate.setYear(pxyCalendarYear);
		pxyCalendarDate.setCalendar(self.myCalendar);
	endforeach;
	
	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return pxyCalendarYear;
	
epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete pxyCalendarYear;
	endif;	
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setCalendar" id="d540db43-8cef-4181-ad10-a282ba4994a2">
        <updating/>
        <source>setCalendar(_calendar : CM_Calendar)updating;
// ---------------------------------------------------------------------------
// Created:     31 January 2005	cnwhjg1
//
// Purpose:     
// ----------   ----------  --------------------------------------------------
vars

begin
	self.myCalendar := _calendar;
end;</source>
        <Parameter name="_calendar" type="CM_Calendar"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="a6d326c9-d0c1-4c79-97f1-e61f83cc3257">
        <updating/>
        <source>setForCreate(_pxyCalendarYear : CM_CalendarYear; _copyDates : Boolean)updating;
// ---------------------------------------------------------------------------
// Created:     28 January 2005	cnwhjg1
//
// Purpose:     
// ----------   ----------  --------------------------------------------------
vars
	pxyCalendarYear	: CM_CalendarYear;
	aCalendarDate,
	date		: CM_CalendarDate;
begin
	self.setForUpdate(_pxyCalendarYear);
	self.myCalendar	:= _pxyCalendarYear.myCalendar;

	if _copyDates then 
		pxyCalendarYear := _pxyCalendarYear;
		foreach date in pxyCalendarYear.allCalendarDates do
			aCalendarDate := date.cloneSelf(false);
			aCalendarDate.changeYearForCopy(self,date);
			aCalendarDate.setYear(self);
			aCalendarDate.setCalendar(self.myCalendar);
		endforeach;
	endif;	
end;</source>
        <Parameter name="_pxyCalendarYear" type="CM_CalendarYear"/>
        <Parameter name="_copyDates" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="d59dd180-5890-44ac-8be1-b2fdad2d42bd">
        <updating/>
        <source>setForUpdate(_pxyCalendarYear : CM_CalendarYear)updating;
// ---------------------------------------------------------------------------
// Created:     28 January 2005	cnwhjg1
//
// Purpose:     
// ----------   ----------  --------------------------------------------------
vars
	date : CM_CalendarDate;
begin
	self.year:= _pxyCalendarYear.year;

	foreach date in self.allCalendarDates do 
	date.changeYearForCopy(self, date);
	date.setCalendar(self.myCalendar);
	endforeach;

end;</source>
        <Parameter name="_pxyCalendarYear" type="CM_CalendarYear"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="b7698e22-5745-4130-8753-31103ac7e95b">
        <updating/>
        <source>setProxy(	_year : Integer; _myCalendar : CM_Calendar) updating;
// ---------------------------------------------------------------------------
// Created:     28 January 2005	cnwhjg1
//
// Purpose:     
// ----------   ----------  --------------------------------------------------
vars
	date : CM_CalendarDate;
begin
	self.year := _year;
	self.myCalendar := _myCalendar;
//	if year is edidted then all dates within year need to be updated. 	
	foreach date in self.allCalendarDates do 
	date.changeYearForCopy(self,date);
	endforeach;

end;</source>
        <Parameter name="_year" type="Integer"/>
        <Parameter name="_myCalendar" type="CM_Calendar"/>
    </JadeMethod>
    <JadeMethod name="validateForCreate" id="9babb877-713b-4e28-9e66-68ff9e162d17">
        <source>validateForCreate();
// ---------------------------------------------------------------------------
// Created:     28 January 2005	cnwhjg1
//
// Purpose:     
// ----------   ----------  --------------------------------------------------
vars

begin

	if self.myCalendar &lt;&gt; null and self.myCalendar.allCalendarYears[self.year] &lt;&gt; null then
		app.raiseCMException1(VB_DUPLICATED_ITEM, self.year.String, null, null);
	endif;
	
	self.validateMe();
end;</source>
    </JadeMethod>
