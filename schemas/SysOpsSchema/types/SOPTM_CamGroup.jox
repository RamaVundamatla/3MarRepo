    <JadeMethod name="doDelete" id="dc4412a4-d7b6-41ab-b5cf-b2ccdc0555eb">
        <updating/>
        <source>doDelete(pObj: CM_Object io) updating;
// ---------------------------------------------------------------------------
// Created:     10 September 2002 by cnwdf1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
