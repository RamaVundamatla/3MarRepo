    <JadeMethod name="createMenuRoot" id="752365b3-40dd-4341-9115-7e141d863f75">
        <updating/>
        <source>createMenuRoot() updating;
// ---------------------------------------------------------------------------
// Created:     16 July 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	exclusiveLock(self);
	if self.myMenuRoot = null then
		create self.myMenuRoot as CM_MenuRootUserTerminal persistent;
		self.myUser.allUserMenuRoots.add(self.myMenuRoot);
	endif;

end;</source>
    </JadeMethod>
