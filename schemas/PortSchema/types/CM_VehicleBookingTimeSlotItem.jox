    <JadeMethod name="getAuditChildSubjects" id="0ea91d68-8bef-4d96-9e33-fd02ff457339">
        <source>getAuditChildSubjects(_childAuditSubjectNames: StringArray input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 Aug 2023 navhl20 Defect 59936: MTN - Displaying only the first tracked item on the Audit Enquiry for the Vehicle Booking Time Slot

*/

vars

begin
	inheritMethod(_childAuditSubjectNames);
	_childAuditSubjectNames.addTruncated(self.getNiceClassName &amp; Space &amp; self.getItemId());
epilog

end;</source>
        <Parameter name="_childAuditSubjectNames" type="StringArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getAuditText" id="72d8d62f-3bed-49ec-b6b3-88558854ba22">
        <source>getAuditText(): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 Aug 2023	navlw1	ChangeRequest 59132:[59133] EUP | VBS Audits
15 Aug 2023	navma1	ChangeRequest 59875: EUP | VBS - Add Created by user code
23 Aug 2023 navhl20 Defect 59936: MTN - Displaying only the first tracked item on the Audit Enquiry for the Vehicle Booking Time Slot
*/

vars
	txt,
	tmpStr,str	: String;
begin
	txt[10000] 	:= '*';
	txt 		:= null;
	txt 		:= inheritMethod();
	
	self.prepareAudits(txt);																														
	txt := self.getNiceClassName &amp; Space &amp; self.getItemId() &amp; AuditStringSeparator &amp; txt.length.String &amp; AuditStringSeparator &amp; txt &amp; AuditStringSeparator;
	
	return txt;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDirectionString" id="0e53d5ab-3280-44b6-9fea-de4dedebd239">
        <source>getDirectionString(): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 May 2023		navma1	Initial creation

*/

vars
	str : String;
begin

	if self.direction = DIRECTION_DELIVERY then
		return app.getErrorString(VBS_direction_delivery);
	elseif self.direction = DIRECTION_PICKUP then
		return app.getErrorString(VBS_direction_pickup);
	endif;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="edd92c0d-98f1-473b-9988-f5dd096356c9">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 Jul 2022	navcs2  ChangeRequest 53899: EUP - VBS MTN - [3] - Maintaining VBS Slot
03 May 2023 navhl20	ChangeRequest 57402:[57471] EUP - VBS changes MTN - Bulk Edit and Linking of slots [Refinement - 03]
15 Aug 2023	navma1  ChangeRequest 59875: EUP | VBS - Add Created by user code
22 Nov 2023 navlc30 ChangeRequest 61256: EUP | FR | 54329 | VBS - Pending issues - Issue 12
29 Feb 2024 navnk30 ChangeRequest 62708: EUP - FR - 53429 - VBS - Release line details on the Slot maintenance.
*/

vars
	str,type : String;
	operator : CM_Operator;
	object 	 : CM_Object;
begin
	if _attrName = ETRow_Direction then
		return self.getDirectionString();
	elseif  _attrName = ETRow_SourceType then
		if self.sourceType = self.SOURCE_BOOKING then
			return "Booking";
		elseif self.sourceType = self.SOURCE_CARGO then
			return "Cargo Item";
		elseif self.sourceType = self.SOURCE_RELEASE then
			return "Release Request";
		endif;
	elseif  _attrName = ETRow_MyTrackedItem then
		if self.myTrackedItem &lt;&gt; null then
			return self.myTrackedItem.id;
		endif;
	elseif  _attrName = ETRow_MyVehicleBookingSlot then
		if self.myVehicleBookingSlot &lt;&gt; null then
			return self.myVehicleBookingSlot.id;
		endif;
	elseif  _attrName = ETRow_MyBulkRelease then
		if self.myBulkRelease &lt;&gt; null then
			return self.myBulkRelease.code;
		endif;
	elseif  _attrName = ETRow_MyBooking then
		if self.myBooking &lt;&gt; null then
			return self.myBooking.bookingReference;
		endif;
	elseif  _attrName = ETRow_MyBookingItem then
		if self.myBookingItem &lt;&gt; null then
			return self.myBookingItem.getDisplayString();
		endif;
	elseif _attrName = ETRow_MyReserveDetails then
		if self.myReserveDetails &lt;&gt; null then
			return self.myReserveDetails.getShortDescription;
		endif;
	elseif _attrName = ETRow_Quantity then								//03.5.2023 navhl20 #57402[57471]
		if self.quantity &gt; 0 then
			return self.quantity.asStringJMT;
		endif;
		return null;
	elseif _attrName = ETRow_ItemWeight then							//03.5.2023 navhl20 #57402[57471]
		return self.getWeightDisplay();
	elseif _attrName = ETRow_CreatedBy then								//17.08.2023 navma1 #59875
		return self.createdUserCode;
	elseif _attrName = ETRow_Created  then								//17.08.2023 navma1 #59875
		return self.systemToLocalTime(self.createdTime).shortCurrentLocaleFormat();
	elseif _attrName = ETRow_Operator then								//22.11.2023 navlc30 #61256
		operator := self.getOperator();
		if operator &lt;&gt; null then
			return operator.code;
		endif;
	elseif _attrName = ETRow_BeingActioned or			//29.02.2024 navnk30 #62708
			_attrName = ETRow_Outstanding or
			_attrName = ETRow_ExtraCriteriaDisp or
			_attrName = ETRow_ExtraCriteria then
		if self.myReserveDetails &lt;&gt; null then
			return self.myReserveDetails.getDisplayStringForAttribute(_attrName, _short);
		else
			return null;
		endif;
	elseif _attrName = ETRow_Commodity or				//29.02.2024 navnk30 #62708
			_attrName = ETRow_CargoType or
			_attrName = ETRow_CargoSubType or
			_attrName = ETRow_PickerDescription or
			_attrName = ETRow_PickerType then
		if self.myReserveDetails &lt;&gt; null then
			object := self.myReserveDetails;
		elseif self.myBookingItem &lt;&gt; null then
			if _attrName = ETRow_CargoSubType then
				return null;
			endif;
			object := self.myBookingItem;
		elseif self.myTrackedItem &lt;&gt; null then
			object := self.myTrackedItem;
		endif;
		
		if object &lt;&gt; null then
			return object.getDisplayStringForAttribute(_attrName, _short);
		else
			return null;
		endif;
	elseif _attrName.isMeasurementType then
		_attrName.getRowNameMeasureType(str, type);
		return self.getMeasurementStringForAttrib(str, type, _short);
	endif;
epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getExtraInfo" id="ce6bccd1-c6ee-4550-a3d9-551fece31751">
        <source>getExtraInfo(_dataContainer: CM_DataContainer);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 Sep 2022 navma1	ChangeRequest 53900: EUP - VBS MTN - [4] - Search Screen
28 Aug 2023 navma1	Bug 60046: FR | 53429 - VBS MTN - Enquiry Screen issues
04 Sep 2023	navdap1	TFS 60186 EUP | FR 53824 - Road Manifest VBS Booking
*/

vars
	block 	    	: CM_DataContainerBlock;
	booking	    	: CM_BookingRef;
	bulkRelease		: CM_BulkRelease;
	cargoItem		: CM_TrackedItem;
	bookingItem 	: CM_BookingRefItem;
	reserveDetail	: CM_ReserveDetail;
	invalid 		: Boolean;			// TFS 60186
begin
	inheritMethod(_dataContainer);
	
	block := _dataContainer.addNewBlock;
	block.addNewItem('Slot Items', DC_MoreInfo, 1, self);

	block := _dataContainer.addNewBlock;
	block.addNewItem(app.getErrorString(Direction), DC_Label, 1, null);
	block.addNewItem(self.getDirectionString() , DC_Data, 1, null); 
	
	booking := self.myBooking;
	if booking &lt;&gt; null then
		block := _dataContainer.addNewBlock;
		block.addNewItem(app.getErrorString(Booking), DC_Label, 1, booking);
		block.addNewItem(booking.bookingReference , DC_Data, 1, booking); 
	endif;
	
	bookingItem := self.myBookingItem;
	if bookingItem &lt;&gt; null then
		booking := bookingItem.myBookingReference;
		block := _dataContainer.addNewBlock;
		block.addNewItem(app.getErrorString(Booking_item), DC_Label, 1, booking);
		block.addNewItem(bookingItem.getDisplayString() , DC_Data, 1, booking);
	endif;
	
	if self.myBulkRelease &lt;&gt; null then
		on Exception do app.handleDeletedObject(exception, bulkRelease, invalid);	// TFS 60186
		bulkRelease := self.myBulkRelease;
		bulkRelease.edition;														// TFS 60186
		if not invalid then															// TFS 60186
			block := _dataContainer.addNewBlock;
			block.addNewItem(app.getErrorString(ReleaseRequest), DC_Label, 1, bulkRelease);
			block.addNewItem(bulkRelease.code , DC_Data, 1, bulkRelease); 
		endif;
		on Exception do null;														// TFS 60186
	endif;
	
	if self.myReserveDetails &lt;&gt; null then
		on Exception do app.handleDeletedObject(exception, reserveDetail, invalid);	// TFS 60186
		reserveDetail := self.myReserveDetails;
		reserveDetail.edition;														// TFS 60186
		if not invalid then															// TFS 60186
			bulkRelease := reserveDetail.myReserveHeader;
			block := _dataContainer.addNewBlock;
			block.addNewItem('Reserve Detail', DC_Label, 1, bulkRelease);
			block.addNewItem(reserveDetail.getShortDescription() , DC_Data, 1, bulkRelease); 	//28.08.2023 navma1 #60046
		endif;
		on Exception do null;														// TFS 60186
	endif;
	
	if self.myTrackedItem &lt;&gt; null then
		on Exception do app.handleDeletedObject(exception, cargoItem, invalid);		// TFS 60186
		cargoItem := self.myTrackedItem;
		cargoItem.edition;															// TFS 60186
		if not invalid then															// TFS 60186
			block := _dataContainer.addNewBlock;
			block.addNewItem(app.getErrorString(Cargo), DC_Label, 1, cargoItem);
			block.addNewItem(cargoItem.id , DC_Data, 1, cargoItem); 
		endif;
		on Exception do null;														// TFS 60186
	endif;
	
	if self.quantity &gt; 1 then
		block := _dataContainer.addNewBlock;
		block.addNewItem(app.getErrorString(Quantity), DC_Label, 1, null);
		block.addNewItem(self.quantity.String , DC_Data, 1, null); 
	endif;
	
	if self.weight &gt; 0 then
		block := _dataContainer.addNewBlock;
		block.addNewItem(app.getErrorString(Weight), DC_Label, 1, null);
		block.addNewItem(self.getWeightDisplay , DC_Data, 1, null); 
	endif;
epilog

end;</source>
        <Parameter name="_dataContainer" type="CM_DataContainer"/>
    </JadeMethod>
    <JadeMethod name="getItemId" id="1f9268b5-5333-4af1-9e02-60a2f2551f02">
        <source>getItemId():String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 Aug 2023	navma1	Defect 59936: MTN - Displaying only the first tracked item on the Audit Enquiry for the Vehicle Booking Time Slot

*/

vars
	str : String;
begin
	
	str := self.getOidString();
	/*
	if self.direction = DIRECTION_DELIVERY then
		
		if self.sourceType = SOURCE_BOOKING then
			if self.myBookingItem &lt;&gt;null then
				str := myBookingItem.getDisplayString;
			endif;
		elseif  self.sourceType = SOURCE_CARGO then
			if self.myTrackedItem &lt;&gt; null then
				str := self.myTrackedItem.id;
			endif;
		endif;
	elseif   self.direction = DIRECTION_PICKUP then 
		if self.sourceType = SOURCE_RELEASE then
			if self.myReserveDetails &lt;&gt; null then
				str := str &amp; Space &amp; self.myReserveDetails.getShortDescription;			
			endif;
		elseif  self.sourceType = SOURCE_CARGO then
			if self.myTrackedItem &lt;&gt; null then
				str := self.myTrackedItem.id;
			endif;
		endif;
	endif;
	*/
	return str;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getMeasurementStringForAttrib" id="c668c352-96d7-4912-a194-5952488fad8d">
        <source>getMeasurementStringForAttrib(_attrName: String; _measureType: String; _short: Boolean): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 May 2023	navhl20	ChangeRequest 57402:[57471] EUP - VBS changes MTN - Bulk Edit and Linking of slots [Refinement - 03]

*/

vars

begin
	if _attrName = ETRow_ItemWeight then
		return app.convertMeasurementForDisplay(_measureType,self.weight);
	endif;
	
	return inheritMethod(_attrName, _measureType, _short);
epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_measureType" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getOperator" id="c8ae9cc6-7fb4-4f8c-b1d6-f381e59170b1">
        <source>getOperator(): CM_Operator;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 Nov 2023 navlc30 ChangeRequest 61256: EUP | FR | 54329 | VBS - Pending issues - Issue 12

*/

vars
	invalid : Boolean;
	obj		: CM_Object;
	edition	: Integer;
begin
	on Exception do app.handleDeletedObject(exception, obj, invalid);
	if self.direction = DIRECTION_DELIVERY then
		obj	:= self.myBooking;
		if obj = null and self.myTrackedItem &lt;&gt; null then
			return self.myTrackedItem.myOperator;	
		endif;
	else	
		obj	:= self.myBulkRelease;
		if obj = null and self.myTrackedItem &lt;&gt; null then
			return self.myTrackedItem.myOperator;
		endif;
	endif;
	
	if obj &lt;&gt; null then
		invalid := false;
		edition := obj.edition;
		
		if invalid then
			return null;
		endif;
		
		if obj.isKindOf(CM_BookingRef) then
			return obj.CM_BookingRef.myOperator;
		else
			return obj.CM_BulkRelease.myOperator;
		endif;
	endif;
epilog

end;</source>
        <ReturnType type="CM_Operator"/>
    </JadeMethod>
    <JadeMethod name="getWeightDisplay" id="bfe82bbb-0afc-4e21-a3c2-5a941b84a59b">
        <source>getWeightDisplay():String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 May 2023	navhl20	ChangeRequest 57402:[57471] EUP - VBS changes MTN - Bulk Edit and Linking of slots [Refinement - 03]

*/

vars
	measure		: CM_MeasurementType;
	unit		: String;
	converted	: String;
begin
	measure := self.getDefaultMeasurementForType(Type_Weight);
	
	unit := measure.shortName;
	converted := app.convertMeasurementForDisplay(unit, self.weight);
	
	if converted &lt;&gt; null then
		return converted &amp; Space &amp; unit;
	else
		return null;
	endif;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="hasHazard" id="96fad662-260d-4876-a142-38611792a231">
        <source>hasHazard():Boolean;
/*

Purpose:		Returns true if there is hazard or else false	

Parameters:		NONE

Return Value:	Boolean

Date		Who		Reason
22 Jan 2024 navma1  Bug 61963: FR | 57937 - [TKT: 61898] - Kiosk - US.110 'a' - UNDG Code criteria

*/

vars
	str    : String;
	objSet : ObjectSet;
	anyData: Any;
begin
	if self.myTrackedItem &lt;&gt; null then
		if self.myTrackedItem.isHazardous then
			return true;
		endif;
	elseif self.myReserveDetails &lt;&gt; null then
		
		create objSet transient;
		if self.myReserveDetails.isKindOf(CM_ReserveSelection) then
			if self.myReserveDetails.cargoMatchUNDGcode &lt;&gt; null then
				return true;
			endif;

			anyData := self.myReserveDetails.CM_ReserveSelection.getMatchingCriteria(objSet,YACriteriaType_Hazardous);
			if anyData.isKindOf(String)  and anyData.String &lt;&gt; null  then
				return true;
			endif;
			
			anyData := self.myReserveDetails.CM_ReserveSelection.getMatchingCriteria(objSet,YACriteriaType_IsHazardous);
			if anyData.isKindOf(Integer) and anyData.Integer = 1  then  // CM_YADataObjects 1 = 'Yes' , 2 ='No'
				return true;
			endif;
		endif;
		
	endif;
	return false;
epilog
	delete objSet;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="prepareAudits" id="43f820a8-c1b4-4dc6-abc6-1772c7a6bb1e">
        <source>prepareAudits(_str : String io);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 Aug 2023 navhl20 Defect 59936: MTN - Displaying only the first tracked item on the Audit Enquiry for the Vehicle Booking Time Slot
28 Aug 2023	navdap1	TFS 60115 EUP FR CallOff
01 Aug/2023	navdap1	TFS 60186 EUP | FR 53824 - Road Manifest VBS Booking
*/

vars
	tmpStr 		: String;
	wodTodo 	: CM_WodToDo;
	todoTask	: CM_ToDoTaskDesc;
	ti			: CM_TrackedItem;
	pinNo		: String;
	invalidTI : Boolean;
begin
	// TFS 60186 myTrackedItem could be deleted in Transport Manifest processing
	if self.myTrackedItem &lt;&gt; null and app.isValidObject(self.myTrackedItem) then
		tmpStr := self.myTrackedItem.id;
		_str := _str &amp; 'Cargo ID' &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp;tmpStr &amp; AuditStringSeparator;
	endif;
	
	tmpStr := null;
	if self.direction &lt;&gt; null then
		tmpStr := self.getDirectionString;
		_str   := _str &amp; app.getErrorString(Direction) &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp; tmpStr &amp; AuditStringSeparator;
	endif;
	
	tmpStr := null;
	if self.weight &lt;&gt; null then
		tmpStr 	:= self.getWeightDisplay();
		_str   	:= _str &amp; app.getErrorString(Weight) &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp; tmpStr &amp; AuditStringSeparator;
	endif;
	
	tmpStr := null;
	if self.quantity &lt;&gt; null then
		tmpStr 	:= self.quantity.asStringJMT;
		_str   	:= _str &amp; "Quantity" &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp; tmpStr &amp; AuditStringSeparator;
	endif;
	
	tmpStr := null;
	if self.myBooking &lt;&gt; null then
		tmpStr 	:= self.myBooking.bookingReference;
		_str   	:= _str &amp; app.getErrorString(Booking) &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp; tmpStr &amp; AuditStringSeparator;
	endif;
	
	tmpStr := null;
	if self.myBookingItem &lt;&gt; null   then
		tmpStr := self.myBookingItem.getDisplayString();
		_str   	:= _str &amp; app.getErrorString(Booking_Item) &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp; tmpStr &amp; AuditStringSeparator;
	endif;

	tmpStr := null;
	if self.myBulkRelease &lt;&gt; null and app.isValidObject(self.myBulkRelease)then
		tmpStr := self.myBulkRelease.code;
		_str    := _str &amp; app.getErrorString(BulkRelease) &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp; tmpStr &amp; AuditStringSeparator;
	endif;
	
	tmpStr := null;
	// TFS 60115 reserve detail could be deleted here in CallOff processing
	if self.myReserveDetails &lt;&gt; null and app.isValidObject(self.myReserveDetails) then	// TFS 60115
		tmpStr := self.myReserveDetails.getShortDescription;
		_str    := _str &amp; "Reserve Detail" &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp; tmpStr &amp; AuditStringSeparator;
	endif;
	
	tmpStr := null;
	if self.myVehicleBookingSlot &lt;&gt; null then
		tmpStr := self.myVehicleBookingSlot.id;
		_str   := _str &amp; app.getErrorString(Vehicle_booking_slot) &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp; tmpStr &amp; AuditStringSeparator;
	endif;
	
	tmpStr := null;					
	tmpStr := self.createdUserCode;		//17.08.2023 navma1 #59875
	_str    := _str &amp; "Created By " &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp; tmpStr &amp; AuditStringSeparator;
	
epilog

end;</source>
        <Parameter name="_str" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="2ac8f2cd-e705-4fea-8d43-5d7cbb5ec870">
        <source>pxyCreateUpdateProxy(): SelfType;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
30 August 2022	navcs2	53899 EUP - SD - VBS MTN - [3] - Maintaining VBS Slot

*/

vars
	pxy 			: SelfType;
	completedOK		: Boolean;
begin
	pxy :=  inheritMethod();
	
	pxy.myBooking 		 := self.myBooking;
	pxy.myBookingItem 	 := self.myBookingItem;
	pxy.myBulkRelease	 := self.myBulkRelease;
	pxy.myReserveDetails := self.myReserveDetails;
	pxy.myTrackedItem 	 := self.myTrackedItem;
	
	completedOK := true;			
	return pxy;
	
epilog
	if not completedOK then			
		delete pxy;
	endif;
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
