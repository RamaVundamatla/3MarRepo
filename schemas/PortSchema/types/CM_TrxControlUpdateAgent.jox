        <updating/>
        <source>trxDutyDocDutyCharges(_allProxyDutyDocItems : CM_DutyDocItemSet input; _passport : CM_Passport input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 August 2014	cnwma1	Initial creation

*/

vars
	proxyDutyDocItem : CM_DutyDocItem;
begin

	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);
	
	_passport.useTITransactionDeferUpdate := false;
	
	beginTransaction;
	
	foreach proxyDutyDocItem in _allProxyDutyDocItems do
	app.myUtilityUA.utlDutyDocDutyCharge(proxyDutyDocItem, _passport);
		if _passport.hasErrors then
			return;
		endif;
	endforeach;
	
	

epilog
	self.finaliseActivityWithPassport(_passport);
