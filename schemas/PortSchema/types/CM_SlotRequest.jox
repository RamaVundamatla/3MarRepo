    <JadeMethod name="isVoyageAllocDirector" id="655a89f4-bc76-4526-97d6-94f0263c930f">
        <source>isVoyageAllocDirector(): Boolean;

/*

Purpose:		//cnwrd1 ccms 1303 14.11.2012	

Parameters:			

Return Value:		


Date		Who		Reason
12 Nov 2012	cnwrd1	Initial creation
22 Apr 2020 cnwma1  Bug 49078: MTN - UE Floods
*/

vars
	aWle	: CM_WorkListEntry;
begin
	
	if self.myJob &lt;&gt; null then                          // 22.04.2020 cnwma1 #49078
		if not self.myJob.isAllowOutOfOrderLoading then //if we are note out of order we cant be voyage alloc loading
			return false;		
		endif;
	endif;
	
	if self.getFirstAllocation() = null then
		return false;
	endif;
	
	foreach aWle in self.allWorkListEntries do
		if aWle &lt;&gt; null and aWle.myTrackedItem = null then
			return true; // we are out of order, have an allocation and dont have a tracked item
		endif;	
	endforeach;
	
	// we are out of order, have an allocation but dont have an unallocated wle 
	return false;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="moveTypeString" id="250051d6-1641-4bb2-95da-92d61b051511">
        <methodInvocation>mapping</methodInvocation>
        <source>moveTypeString(set: Boolean; _value: String io) mapping;
/*
------------------------------------------------------------------------
Created:			26 March 2003 by cnwdwq1
Purpose:			Dave Q's code
Parameters:		
Returns:			
Changed On		Changed By		Reason
------------	------------	-----------------------------------------
														
------------------------------------------------------------------------
*/
begin
	if set then
		app.raiseSetVirtualError(class.name, method.name);
		return;
	endif;
	if self.moveType = DISCHARGE_MOVETYPE then
		_value := "Discharge";
	elseif self.moveType = LOAD_MOVETYPE then
		_value := "Load";
	elseif self.moveType = DLR_MOVETYPE then
		_value := "DLR";
	elseif self.moveType = SOB_MOVETYPE then
		_value := "SOB";
	elseif self.moveType = NULL_MOVETYPE then
		_value := "Null";
	else
		_value := "Unknown";
	endif;

end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="mySlotDefinition" id="e5765eeb-68eb-46ea-97eb-65717090c1a0">
        <methodInvocation>mapping</methodInvocation>
        <source>mySlotDefinition(set: Boolean; _value: CM_SlotDefnVoyage io) mapping;
/*
------------------------------------------------------------------------
Created:			03 December 2002 by cnwdwq1
Purpose:			
Parameters:		None
Returns:			Nothing
Changed On		Changed By		Reason
------------	------------	-----------------------------------------
---------------------------------------------------------------------------
*/
vars
	tmpSlot	: CM_SlotController;
begin
	if set then
		app.raiseSetVirtualError(class.name, method.name);
		return;
	endif;
	tmpSlot := self.mySlotController;
	if tmpSlot = null then
		_value := null;
	else
		_value := tmpSlot.mySlotDefnVoyage;
	endif;
end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="CM_SlotDefnVoyage" usage="io"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="d4d544e9-d687-41bf-ae89-6bfcf8ceca07">
        <source>pxyCreateUpdateProxy(): SelfType;
// ---------------------------------------------------------------------------
// Created:		March 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 20/04/2011	cnwmh5		PAR #27401 - Add code to handle prossible exceptions occurring when
//							trying to create the proxy
// ---------------------------------------------------------------------------

vars

	lRequestProxy	: CM_SlotRequest;
	completedOK		: Boolean;
	
begin

	lRequestProxy := inheritMethod();

	if not self.useVoyageAllocations then // PAR 24273
		lRequestProxy.myCargoType := self.myCargoType;
		lRequestProxy.myCommodity := self.myCommodity;
		lRequestProxy.myCargoSubtype := self.myCargoSubtype;
		lRequestProxy.myCommodityGroup := self.myCommodityGroup;
		lRequestProxy.myDischargePort := self.myDischargePort;
	endif;
	lRequestProxy.mySlotController := self.mySlotController;
	lRequestProxy.mySlotControllerDischarge := self.mySlotControllerDischarge;
	lRequestProxy.mySlotControllerLoad := self.mySlotControllerLoad;

	lRequestProxy.mySlotRequestForward := self.mySlotRequestForward;
	
	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return lRequestProxy;
	
epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete lRequestProxy;
	endif;	
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="reSetSlotSeqNums" id="79d4e1c3-45a0-483c-8edc-0da3a23b1a67">
        <updating/>
        <source>reSetSlotSeqNums(_params : CMIF_SeqParams io) updating;
// ---------------------------------------------------------------------------
// Created:     
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	oldSeqNum,
 	newSeqNum	: Integer; //ccms 2323 28/4/14
	voyage : CM_Voyage;
begin

	oldSeqNum:= self.getSeqNum();
	newSeqNum:=self.getSeqNumDefn(_params);
	
	if _params.viewingPortSideTo then
		self.numSeqPort := newSeqNum;
	else
		self.numSeqStarBoard :=newSeqNum;
	endif;
	
	//ccms 2323 28/4/14
	voyage:=self.getVoyage;
	if oldSeqNum &lt;&gt; newSeqNum and voyage &lt;&gt;null then
		voyage.incrementPlanningVersion();
	endif;
	
end;</source>
        <Parameter name="_params" type="CMIF_SeqParams" usage="io"/>
    </JadeMethod>
