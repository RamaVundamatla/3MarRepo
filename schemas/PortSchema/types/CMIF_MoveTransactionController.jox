    <JadeMethod name="getTrxQVWvalues" id="447626c3-a939-4d2d-960b-ee617c8f34f9">
        <source>getTrxQVWvalues(_totQ: Integer output; _totV: Decimal output; _totW: Decimal output);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 May 2016	cnwma1	Initial creation  TFS #1991 PAR #37855  QNS - Break Bulk cargo not dividing proportionally charges based on discharged volume

*/

vars

begin

	if self.myTrackedItem &lt;&gt; null then
		_totQ := self.myTrackedItem.totalQuantity;
		_totV := self.myTrackedItem.getChargeVolume;
		_totW := self.myTrackedItem.totalWeight;
	endif;

epilog

end;</source>
        <Parameter name="_totQ" type="Integer" usage="output"/>
        <Parameter name="_totV" type="Decimal" usage="output"/>
        <Parameter name="_totW" type="Decimal" usage="output"/>
    </JadeMethod>
    <JadeMethod name="getWLE" id="9730870a-1d92-41c3-95b1-e3299fcf78d5">
        <source>getWLE() : CM_WorkListEntry;
// ---------------------------------------------------------------------------
// Created:		17 July 2007 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
begin
	return self.myWorkListEntry;
end;</source>
        <ReturnType type="CM_WorkListEntry"/>
    </JadeMethod>
    <JadeMethod name="setFromTransaction" id="53c0e929-9a7d-4526-9c34-45e7744f17ac">
        <updating/>
        <source>setFromTransaction(_txn : CM_Move) updating;
// ---------------------------------------------------------------------------
// Created:     06 June 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
vars

begin
	inheritMethod(_txn);

	self.sourceLocn := _txn.sourceLocn;
	self.targetLocn := _txn.targetLocn;
	self.machineId := _txn.machineId;
end;</source>
        <Parameter name="_txn" type="CM_Move"/>
    </JadeMethod>
    <JadeMethod name="setSourceTargetLocnTA" id="44160be0-a4df-4530-8338-c1356775fc58">
        <updating/>
        <source>setSourceTargetLocnTA(_control : CMIF_MoveController) updating;
//--------------------------------------------------
// Created:	07 September 2004 By: cnwgd1
// 18 Nov 2013	NDL	Par 33014 - truncate to avoid string too long.
// 26 Feb 2025  navhn30 Bug MTN-33952: EUP | 53485 - Warehouse Yard Allocation - Scanning App and Job Lander issues
//--------------------------------------------------
vars

begin

	self.sourceLocn	:= _control.getOriginatingLocationId()[1:30]; // PAR 14387 NOW
	self.myOriginatingLocation:=_control.myOriginatingLocation;  //epr TFS 2884 22/1/16
	if _control.isPlannedToFullGCArea then						//26.02.25	navhn30	 MTN-33952
		self.targetLocn := _control.myToPrimaryLocation.terminalAreaId;
	else
		self.targetLocn := _control.getPrimaryLocationId()[1:30];// PAR 14387 NOW
	endif;
	self.myToPrimaryLocation :=_control.myToPrimaryLocation;  //epr TFS 2884 22/1/16

end;</source>
        <Parameter name="_control" type="CMIF_MoveController"/>
    </JadeMethod>
    <JadeMethod name="setTargetLocation" id="bbe1764b-3b0c-4206-8f3c-fafd74f09ce5">
        <updating/>
        <source>setTargetLocation(_lc : CM_LocationsController) updating;
/*
Purpose:			

Date		Who		Reason
24 November 2021	navab1	TFS 52440
*/

vars

begin
	self.targetLocn := _lc.getFullId();
	self.myToPrimaryLocation := _lc;

epilog

end;</source>
        <Parameter name="_lc" type="CM_LocationsController"/>
    </JadeMethod>
    <JadeMethod name="setTransactionDetails" id="906a6513-4913-419d-91ed-a8067d2ff370">
        <updating/>
        <source>setTransactionDetails(_txn : CM_Move input) updating, protected;
// ---------------------------------------------------------------------------
// Created:     26 September 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	inheritMethod(_txn);

	_txn.setMoveDetails(self.completedDateTime,
			   			self.forced, 		self.machineId,
			   			self.mode, 			self.operational,
						self.rehandle, 		self.sourceLocn,
			   			self.supplementary, self.systemGenerated,
			   			self.targetLocn, 	self.tbaPatch, 
			   			self.unplan, self.isReplan, self.isShiftMove, self.shiftDirection, self.isReQueue,
						// cnwjk3 CCMS 1018 15/01/10
						self.isShufflingInCurrentLocation,
						self.totalQuantity,  //epr TFS 2996 8/12/16 moved to use attributes up on parent
						self.totalWeight,
						self.totalVolume,
						self.isDirectReleaseMove	//10 Sep 2019	NDL	TFS 42882
						);  // TFS 7031


end;</source>
        <access>protected</access>
        <Parameter name="_txn" type="CM_Move" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setWLE" id="03561c6b-8b62-4ba7-b46c-a57034674663">
        <updating/>
        <source>setWLE(_wle : CM_WorkListEntry; _control : CMIF_MoveController io) updating;
// ---------------------------------------------------------------------------
// Created:		28 May 2008 By Andrew Bishop cnwab1 Par 16975
//
// Purpose:		
//
// ---------------------------------------------------------------------------
/*
Date		Who		Reason
14 Sep 2009	CNWER1	PAR 20498 
17 Mar 2025 navma1  MTN-34120 MTN | Dead Lock (1081) on CM_OfflineFutureActorParentDct
*/
vars
	tmpStr 	   : String;
	invalidWLE : Boolean;
begin
	on Exception do app.handleDeletedObject(exception, _wle, invalidWLE); // AKBJUNE11 762 TESTING PAR 16095

	//PAR 16835
	self.myWorkListEntry := _wle;
	
	if self.myWorkListEntry &lt;&gt; null then
			if _control.moveMode &lt;&gt; REAL_MODE // PAR 17789
			and self.myWorkListEntry.myFutureMove &lt;&gt; null then // PAR 17356
				tmpStr := self.myWorkListEntry.myFutureMove.getPrimaryLocationId(); // PAR 17356
				
			else
				if _wle.isKindOf(CM_VoyageWLE) and not _wle.isReceipt then // PAR 18178 load ship jobs do not need to do this, could return here
					tmpStr := self.myWorkListEntry.locationTarget; // PAR 18178 
				else
					if self.targetLocn = app.getErrorString(Nowhere) then
						tmpStr := "";
					else
						tmpStr := self.targetLocn;
					endif;
				endif;
			endif;
		
		//epr TFS 36605 22/1/18if it is an undo load then need to keep the same target 
		if not _control.isTruckUndoLoad then
			// I think this is to update where the wle was actually set down
			// for multi machine moves after the first machine has completed his move this will cause an issue
			self.myWorkListEntry.setLocations(self.myWorkListEntry.locationSource,tmpStr);
		endif;
	endif;

end;</source>
        <Parameter name="_wle" type="CM_WorkListEntry"/>
        <Parameter name="_control" type="CMIF_MoveController" usage="io"/>
    </JadeMethod>
</Class>
