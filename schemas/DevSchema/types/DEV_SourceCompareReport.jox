			concatenatedString &amp;= CrLf &amp; devSchema.name &amp; "::" &amp; devClass.name &amp; " - " &amp; devClass.modifiedBy &amp;  " | " &amp; devClass.modifiedTimeStamp.String;
			classesMissingCount += 1;
		endforeach;
	endforeach;
	
	if classesMissingCount &lt;&gt; 0 then
		concatenatedString &amp;= CrLf &amp; "Missing Classes Count: " &amp; classesMissingCount.String;
	endif;
	
	concatenatedString &amp;= CrLf;
	
	wroteHeaderLine := false;
	foreach devSchema in self.allSchemas do
		foreach devClass in devSchema.allClasses where devClass.reason = DEV_SourceCompareReportAgent.Object_Link do
			foreach devMethod in devClass.allMethods where devMethod.reason = DEV_SourceCompareReportAgent.Object_Missing do
				if not wroteHeaderLine then
