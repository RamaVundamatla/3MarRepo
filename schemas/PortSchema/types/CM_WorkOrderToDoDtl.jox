    <JadeMethod name="getToDoTaskCountByStatus" id="89899b26-c9ff-43f8-a4a9-9dc13b06f265">
        <source>getToDoTaskCountByStatus(_status: Integer): Integer;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
10 March 2023	navcs2	ChangeRequest 54344: EUP - VAS Work Orders - Jobs

*/

vars
	count 		: Integer;
	toDoTask	: CM_ToDoTask;
begin
	foreach toDoTask in self.allToDoTasks do
		if toDoTask.status = _status then
			count += 1;
		endif;
	endforeach;
	
	return count;
epilog

end;</source>
        <Parameter name="_status" type="Integer"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
