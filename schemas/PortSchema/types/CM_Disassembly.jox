    <JadeMethod name="setExtraDetails" id="d726677a-a23b-4a03-8f12-5927e49b39df">
        <updating/>
        <source>setExtraDetails(_residualLength : Integer; _residualVolume : Decimal; _set : CM_ReassemblySet) updating;
// ---------------------------------------------------------------------------
// Created:     29 August 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	self.residualLength	:= _residualLength;
	self.residualVolume	:= _residualVolume;
	_set.copy(self.allReassemblyTransactions);

end;</source>
        <Parameter name="_residualLength" type="Integer"/>
        <Parameter name="_residualVolume" type="Decimal"/>
        <Parameter name="_set" type="CM_ReassemblySet"/>
    </JadeMethod>
    <JadeMethod name="setFromCMIF_TIUpdateController" id="b6f7e706-9d7e-4436-8392-53986a3b85e1">
        <updating/>
        <source>setFromCMIF_TIUpdateController(_tiUpdateCntrlr: CMIF_TIUpdateController; _passport : CM_Passport) updating;
//--------------------------------------------------------------
//Created: 02 October 2002 By: cnwgd1
//--------------------------------------------------------------
vars

begin
	inheritMethod(_tiUpdateCntrlr, _passport);
	self.residualLength		:= _tiUpdateCntrlr.residualLength;
	self.residualVolume		:= _tiUpdateCntrlr.residualVolume;
	self.residualQuantity	:= _tiUpdateCntrlr.residualQuantity;
	self.residualWeight		:= _tiUpdateCntrlr.residualWeight;
	_tiUpdateCntrlr.allReassemblyTrans.copy(self.allReassemblyTransactions);	
end;</source>
        <Parameter name="_tiUpdateCntrlr" type="CMIF_TIUpdateController"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="setNewResidualWeight" id="80732cae-fb59-4d49-83a4-b85758003c64">
        <updating/>
        <source>setNewResidualWeight(_weightPortionPerJas : Decimal) updating;
/* ---------------------------------------------------------------------------
Created:	01 September 2010	by cnwvu1

Purpose:	When updating weight for a docket, weight is recalculated for all logs.
			We need to recalculate new residual weight, too.
   
Change Date		Who		Reason

------------------------------------------------------------------------------*/
vars
	totalWeightOnNewLogs,
	theorWeightForOrigLog	: Decimal[14,4];
	tranReassembly			: CM_Reassembly;
	
begin

	foreach tranReassembly in self.allReassemblyTransactions do
		totalWeightOnNewLogs := totalWeightOnNewLogs + tranReassembly.myTrackedItem.CM_Log.totalWeight;
	endforeach;

	theorWeightForOrigLog	:= (self.myTrackedItem.CM_Log.getMyTotalVolume * _weightPortionPerJas).rounded;
	
	self.residualWeight := theorWeightForOrigLog - totalWeightOnNewLogs;
	
end;</source>
        <Parameter name="_weightPortionPerJas" type="Decimal"/>
    </JadeMethod>
</Class>
