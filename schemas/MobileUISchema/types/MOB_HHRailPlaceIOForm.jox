    <JadeMethod name="doResizeControls" id="74e65486-7161-4f05-a0b2-f96332cb6c29">
        <updating/>
        <source>doResizeControls(_initialSetup: Boolean) updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 February 2015	cnwndl1	Initial creation	Par 35604

*/

vars

	stdLeft : Real;
	top : Real;
	stdWidth : Real;
	stdHeight : Real;
	tabIndex : Integer;

begin

	self.setResizeableMarginAndFontSize();
	tabIndex := 4000;
	stdWidth := self.clientWidth * 2 / 3;
	stdLeft :=  stdWidth / 4;
	stdHeight := self.getStdControlHeight;
	top := ( self.height / 3 ) - stdHeight;
	
	if _initialSetup then
		self.btnInward.setAndIncrementTabIndex( tabIndex );
		self.btnInward.visible := true;
	endif;
	self.btnInward.move(	stdLeft,
							top,
							stdWidth,
							stdHeight );
						 
	top := self.resizedMargin + self.resizedMargin + self.btnInward.height + self.btnInward.top;
	if _initialSetup then
		self.btnOutward.setAndIncrementTabIndex( tabIndex );
		self.btnOutward.visible := true;
	endif;
	self.btnOutward.move( stdLeft,
							top,
							stdWidth,
							stdHeight );
							
	inheritMethod(_initialSetup);

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_initialSetup" type="Boolean"/>
    </JadeMethod>
