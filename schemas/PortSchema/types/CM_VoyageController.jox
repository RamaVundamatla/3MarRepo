    <JadeMethod name="archive" id="46e2cd5c-8690-4944-bf33-abf948c1ef66">
        <updating/>
        <source>archive(_controller: CMIF_ArchiveVoyage; _moveControl: CMIF_MoveController input; _tiArray: CM_TIArray input; _passport: CM_Passport input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 Mar 2020 cnwma1 Bug 48863: JMT - Voyage Archive, Non Worked Cargo Issue

*/

vars
	ti			 : CM_TrackedItem;
	theMonitor   : CMIF_Monitor;
begin
	exclusiveLock(self);
	if _controller = null then
		app.raiseCMException2(MethodWithNullParam, method.name, 'controller', null, null);
		return;
	endif;
	if _passport = null then
		app.raiseCMException2(MethodWithNullParam, method.name, 'passport', null, null);
		return;
	endif;
	if _moveControl = null then
		app.raiseCMException2(MethodWithNullParam, method.name, '_moveControl', null, null);
		return;
	endif;	
	
	//----------------------
	//Unworked Trackeditems on the ship
	//------------------------
	if _controller.myMonitor &lt;&gt; null then
		theMonitor := _controller.myMonitor;
	endif;
	//-------------------------
	//unplan all planned TIs (do this no matter what)
	//-------------------------
	_tiArray.clear;
	self.getAllPlannedTrackedItems(_tiArray, true, false);
	foreach ti in _tiArray do
		exclusiveLock(ti);
		_moveControl.setMoveMode(PLANNING_MODE);
		_moveControl.setMyTrackedItem(ti);
		_moveControl.isFullyUnplan := true;	//For DLR's
		_moveControl.executeUndoMove(_passport);
	endforeach;			
	//-------------------------
	//Unqueue all _tiArray (do this no matter what)
	//-------------------------
	_tiArray.clear;
	self.getAllQueuedTrackedItems(_tiArray, true);
	foreach ti in _tiArray do
		exclusiveLock(ti);
		_moveControl.setMoveMode(QUEUE_MODE);
		_moveControl.setMyTrackedItem(ti);
		_moveControl.executeUndoMove(_passport);
	endforeach;			

epilog

end;</source>
        <Parameter name="_controller" type="CMIF_ArchiveVoyage"/>
        <Parameter name="_moveControl" type="CMIF_MoveController" usage="input"/>
        <Parameter name="_tiArray" type="CM_TIArray" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
