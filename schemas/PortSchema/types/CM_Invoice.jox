    <JadeMethod name="otherInvoices" id="2dd48fa5-332c-46ab-b639-e08ba7e22b4a">
        <source>otherInvoices():String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 Dec 2022 navtnr20	TFS CR 55308 TASK 55552: UI - Add new attribute to Invoice List columns
01/02/2023	navkc1	TFS CR 55305 Task 55537 UI - Invoice List UI changes
06 June 2023 navmv20 Bug 58390: EUP - Copied Invoice Other Invoice
*/

vars
	invoice,
	otherInvoice	: CM_Invoice;
	str				: String;
	trailStr		: String;
begin
	
	//23/08/2024	navkc1 Bug 65766 - First take the otherInvoice
	otherInvoice := self.myOtherInvoice;
	if otherInvoice &lt;&gt; null then
		if otherInvoice.isCreditNote() then
			trailStr := " (cn)";
		else
			trailStr := " (iv)";
		endif;
		str := otherInvoice.sequenceNum.String &amp; trailStr;
	endif;
	
	//23/08/2024	navkc1 Bug 65766 - Then go through the collection
	foreach invoice in self.allOtherInvoices discreteLock do
		if invoice.isCreditNote() then
			trailStr := " (cn)";
		else
			trailStr := " (iv)";
		endif;
		
		if str = null then
			str := invoice.sequenceNum.String &amp; trailStr;
		else
			str := str &amp; ", " &amp; invoice.sequenceNum.String &amp; trailStr;
		endif;
	endforeach;
	
	return str;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="postAllCharges" id="80f0c36e-916e-40cd-8624-f449af60baec">
        <source>postAllCharges(pd : CMS_Progress input);

vars
	charge : CM_Charge;
	ili : CM_InvoiceLine;
	i : Integer;

begin

	i := 1;
	foreach ili in invoiceLines do
		if pd &lt;&gt; null then
			pd.progress.partsDone := i;
		endif;
		i := i + 1;
		ili.postAllCharges();
		//PAR 2699 AJA 8/4/99: Allow cancel button to be pressed mid flow
		if pd &lt;&gt; null then
			pd.doWindowEvents(0);
		endif;

	endforeach;

end;</source>
        <Parameter name="pd" type="CMS_Progress" usage="input"/>
    </JadeMethod>
