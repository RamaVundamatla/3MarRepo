    <JadeMethod name="doMnuEnquire" id="81560ae6-f725-4491-b3f6-74bb8bf7771b">
        <source>doMnuEnquire( _table : CM_DataTable);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
18 March 2010	cnwrd1	Initial creation

*/

vars
	table : CM_DataTable;
	theTi : CM_TrackedItem;
	obj : Object;
begin
	
	table := _table;
	
	if table = null then
		return;
	endif;
	
	obj := table.accessRow(table.row).itemObject;
	
	if CM_TrackedItem.hasInstance(obj) then
		theTi := obj.CM_TrackedItem;
		self.myAssistant.showCargoEnquiry(theTi);
	endif;
epilog

end;</source>
        <Parameter name="_table" type="CM_DataTable"/>
    </JadeMethod>
    <JadeMethod name="doPopCmbOperatorFromDebtor" id="1faf06da-d0c6-41a0-b18c-c1134ddf77ec">
        <updating/>
        <source>doPopCmbOperatorFromDebtor(_debtor	: CM_Debtor) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22/06/2023	navkc1	Bug 58784: EUP - Inv Maint Find Items use Debtor for Operators

*/

vars
	operator 	: CM_Operator;
	combo 		: CMUI_ComboOperator;
	str			: String;
begin
	if _debtor = null or _debtor.operators.isEmpty() then
		return;
	endif;
	
	combo := self.cmbOperatorCode;
	combo.clear();
	
	foreach operator in _debtor.operators discreteLock do
		if operator.isNotAvailableForEntry then
			continue;
		endif;
		str := operator.code &amp; Tab &amp; operator.description;
		combo.addItemObject(str, operator);
	endforeach;
	
	self.isLimitingOperator := true;
	self.chkShowAllOperator.visible := true;
	
	combo.setInitialised(true);
epilog

end;</source>
        <Parameter name="_debtor" type="CM_Debtor"/>
    </JadeMethod>
    <JadeMethod name="doResize" id="aee32a98-e6e0-424f-86ec-eb6f5c97ff37">
