    <JadeMethod name="rebuildStatus" id="72b4226e-f1ac-49af-9247-93372ccef432">
        <updating/>
        <source>rebuildStatus() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 May 2019	jlgzm1	TFS 42840 MSL Direct Release between Voyages and Rail

*/

vars
	drWLE : CM_WorkListEntry;
begin
	inheritMethod();
	
	// if is part of a direct release move, and the other wle is not complete then neither are we
	if self.myFutureMove &lt;&gt; null and
	   self.myFutureMove.myWorkListEntryDR &lt;&gt; null then
		drWLE := self.myFutureMove.myWorkListEntryDR;
		if drWLE.status &lt;&gt; WLE_COMPLETED then
			if self.status = WLE_COMPLETED then
				self.setStatus(WLE_UNACTIONED);
			endif;
		endif;
	endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="seqNumAsString" id="5c9dfa67-df5f-47bb-bbae-245c482edc25">
        <methodInvocation>mapping</methodInvocation>
        <source>seqNumAsString(_set: Boolean; _value: String io) mapping;
//Returns the sequence number for the voyage berth as a string.
vars
	voy	:	CM_Voyage;
	zeroFillSeqNum : Boolean;
	sequenceNum : Integer;
begin
	zeroFillSeqNum := self.doIZeroFillSeqNum();

	if _set then
		app.raiseSetVirtualError(class.name, method.name);
		return;
	endif;
	_value:=null;
	sequenceNum:=self.getSeqNum;
	if zeroFillSeqNum then
		_value :=sequenceNum.String.padZeros(3);
	else
		_value :=sequenceNum.String;
	endif;
end;</source>
        <Parameter name="_set" type="Boolean"/>
        <Parameter name="_value" type="String" usage="io"/>
    </JadeMethod>
