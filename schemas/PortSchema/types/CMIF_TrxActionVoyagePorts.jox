<Class name="CMIF_TrxActionVoyagePorts" id="b6d4c794-5362-4809-aa86-d41d9da72996">
    <superclass name="CMIF_TrxPostAction"/>
    <transient/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <ImplicitInverseRef name="myVoyage" id="d95ec96e-2aaf-4db7-bb9d-9d3938b58c45">
        <embedded/>
        <type name="CM_Voyage"/>
    </ImplicitInverseRef>
    <PrimAttribute name="portCode" id="f610efa3-c88e-4bec-85e2-f7f3f75935a6">
        <length>31</length>
        <embedded/>
        <type name="String"/>
    </PrimAttribute>
    <JadeMethod name="action" id="6cc72095-0d43-4a32-b97f-7e0085d37273">
        <updating/>
        <source>action(_passport: CM_Passport) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 December 2022	jlier1	Initial creation 56234

*/

vars
	port : CM_Port;
	passport : CM_Passport;
begin
	
	if self.myVoyage = null or not global.isValidObject(self.myVoyage) then
		return;
	endif;
	
	port := app.myRoot.allPorts[self.portCode];
	if port = null then
		return;
	endif;
	
	passport := _passport;
	passport.setWarningsIgnored(true);
	passport.setWarningsAcknowledged(true);
	
	app.myTrxUA.trxUpdateVoyageWithPort(self.myVoyage,port,passport);
	
	passport.clearErrorsWarnings;
	passport.initialiseTransaction;
	passport.finaliseTransaction(TRXStatus_Committed);
	
epilog

end;</source>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="createAction" id="ee930915-8247-47f6-b41d-fdf2ac1215aa">
        <options>4</options>
        <source>createAction( _voyage : CM_Voyage input; _portCode : String; _passport : CM_Passport) typeMethod;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 December 2022	jlier1	Initial creation 56234

*/

vars

	voyage					: CM_Voyage;
	trxPA					: CMIF_TrxPostAction;
	tvoyagePortTrxAction		: CMIF_TrxActionVoyagePorts; 
begin
	if (_voyage = null or _portCode = null)  then
		return;
	endif;
	
	foreach trxPA in _passport.allTrxPostActions where trxPA.isKindOf(CMIF_TrxActionVoyagePorts) do
		if trxPA.CMIF_TrxActionVoyagePorts.myVoyage = _voyage and 
			trxPA.CMIF_TrxActionVoyagePorts.portCode = _portCode then
			return;
		endif;
	endforeach;
		
	create tvoyagePortTrxAction transient;
	tvoyagePortTrxAction.myVoyage := _voyage;
	tvoyagePortTrxAction.portCode := _portCode;
		
	_passport.addTrxPostAction(tvoyagePortTrxAction);
		
epilog

end;</source>
        <Parameter name="_voyage" type="CM_Voyage" usage="input"/>
        <Parameter name="_portCode" type="String"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
</Class>
