    <JadeMethod name="tGetNextOrPrevTI" id="64612659-76ba-419b-988b-42ea4500f633">
        <source>tGetNextOrPrevTI(); 
// cnwrs1
// cnwgb1
constants
	POWERED_REEFER = "2231";
vars
	ti1,ti2,ti3 : CM_TrackedItem;
	moveCont : CMIF_MoveController;
	locationID : String;
	loc,nextLoc,prevLoc : CM_GridController;
	termArea : CM_RTGArea;
//	r : CM_GridRow;
//	c : CM_GridColumn;
begin
	// Only transients are used so don't need to delete anything
	self.deleteTerminalArea("CTEST");
	

	termArea := self.addRTGArea("CTEST",2,2,2);
	prevLoc := self.createRTGController("CTEST1",1,1, termArea);
	loc := self.createRTGController("CTEST2",1,2, termArea);
	nextLoc := self.createRTGController("CTEST3",2,1, termArea);
	
	assertNotNull( prevLoc );
	assertNotNull( loc );
	assertNotNull( nextLoc );
	
	
	nextLoc.setMyPreviousController(loc);
	loc.setMyPreviousController(prevLoc);
		
	ti1 := self.createContainer("CPAT007001","2200", "TEST",self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString),true);
	ti2 := self.createContainer("CPAT007002",POWERED_REEFER, "TEST",self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString),true);
	ti3 := self.createContainer("CPAT007003","2200", "TEST",self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString),true);
	
	create moveCont transient;
	
	moveCont.setMyToPrimaryLocation(prevLoc);
	moveCont.setMyTrackedItem(ti1);
	moveCont.setMoveMode(REAL_MODE);
	ti1.setMyLocationsPublic(moveCont);
	
	moveCont.setMyToPrimaryLocation(loc);
	moveCont.setMyTrackedItem(ti2);
	moveCont.setMoveMode(REAL_MODE);
	ti2.setMyLocationsPublic(moveCont);
	
	moveCont.setMyToPrimaryLocation(nextLoc);
	moveCont.setMyTrackedItem(ti3);
	moveCont.setMoveMode(REAL_MODE);
	ti3.setMyLocationsPublic(moveCont);

	app.myMobileAgent.setTraverseColumns(false); //cnwgb1

	// Next checks
	assertEqual(app.myMobileAgent.getNextTI(ti1,false),ti2);
	assertEqual(app.myMobileAgent.getNextTI(ti2,false),ti3);
	// Previous checks
	assertEqual(app.myMobileAgent.getPreviousTI(ti3,false),ti2);
	assertEqual(app.myMobileAgent.getPreviousTI(ti2,false),ti1);
	
	
	// Move ti2 to the first location so that there are 2 containers at 1 location
	moveCont.setMyToPrimaryLocation(prevLoc);
	moveCont.setMyTrackedItem(ti2);
	moveCont.setMoveMode(REAL_MODE);
	ti2.setMyLocationsPublic(moveCont);
	
	// Next checks
	assertEqual(app.myMobileAgent.getNextTI(ti1,false),ti2);
	assertEqual(app.myMobileAgent.getNextTI(ti2,false),ti3);
	// Previous checks
	assertEqual(app.myMobileAgent.getPreviousTI(ti3,false),ti2);
	assertEqual(app.myMobileAgent.getPreviousTI(ti2,false),ti1);
	
	
	// move all 3 containers to same location
	moveCont.setMyToPrimaryLocation(prevLoc);
	moveCont.setMyTrackedItem(ti3);
	moveCont.setMoveMode(REAL_MODE);
	ti3.setMyLocationsPublic(moveCont);
	
	
	// Next checks
	assertEqual(app.myMobileAgent.getNextTI(ti1,false),ti2);
	assertEqual(app.myMobileAgent.getNextTI(ti2,false),ti3);
	// Previous checks
	assertEqual(app.myMobileAgent.getPreviousTI(ti3,false),ti2);
	assertEqual(app.myMobileAgent.getPreviousTI(ti2,false),ti1);
	
	// Check that the reefer search works properly
	ti2.CM_Container.changeISOType(POWERED_REEFER,null,null);
	
	// Next checks - shouldn't find any other reefers
	assertEqual(app.myMobileAgent.getNextTI(ti2,true),null);
	// Previous checks
	assertEqual(app.myMobileAgent.getPreviousTI(ti2,true),null);
	
	ti3.CM_Container.changeISOType(POWERED_REEFER,null,null);
	
	// Next checks
	assertEqual(app.myMobileAgent.getNextTI(ti2,true),ti3);
	
	ti1.CM_Container.changeISOType(POWERED_REEFER,null,null);
	
	// Previous checks
	assertEqual(app.myMobileAgent.getPreviousTI(ti2,true),ti1);
	
	ti2.CM_Container.changeISOType("2200",null,null);
	
	// Next checks - should now skip ti2 as its no longer a reefer
	assertEqual(app.myMobileAgent.getNextTI(ti1,true),ti3);
	
	// Previous checks
	assertEqual(app.myMobileAgent.getPreviousTI(ti3,true),ti1);
	
epilog

	delete ti1;
	delete ti2;
	delete ti3;
	delete moveCont;
	delete prevLoc;
	delete loc;
	delete nextLoc;
end;</source>
    </JadeMethod>
    <JadeMethod name="tGetTIAtLocation" id="34751283-a8eb-4777-bd68-6c9fa8dbf8ce">
        <source>tGetTIAtLocation();
// cnwrs1
// cnwgb1
constants
	POWERED_REEFER = "2231";
vars
	ti1,ti2,ti3 : CM_TrackedItem;
	moveCont : CMIF_MoveController;
	locationID : String;
	loc,loc1,loc2 : CM_LocationsController;
	iter : Iterator;
	termArea : CM_TerminalArea;
	retStr : String;
	lane : CM_RTGLane;

begin
	return;
	self.deleteContainer("CPAT007001");
	self.deleteContainer("CPAT007002");
	self.deleteContainer("CPAT007003");
	self.deleteTerminalArea("CTEST");
	
	termArea := self.addRTGArea("CTEST",2,2,2);
	beginTransaction;
	create lane persistent;
	lane.setMyTerminal(self.getTerminal);
	lane.allTAsByTypeId.add(termArea);
	commitTransaction;
	/*
	foreach bay in lane.allRTGBaysByAreaColumn do
		bay.setRTGAreaForProxy(termArea.CM_RTGArea);
	endforeach;
	*/
	// Create some containers
	ti1 := self.addContainer("CPAT007001",self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString),"2200", "MT",TI_IMEX_STATUS_STORAGE);
	ti2 := self.addContainer("CPAT007002",self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString),"2200", "MT",TI_IMEX_STATUS_STORAGE);
	ti3 := self.addContainer("CPAT007003",self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString),"2200", "MT",TI_IMEX_STATUS_STORAGE);
	
	// Make them all powered Reefers
	beginTransaction;
	ti1.CM_Container.changeISOType(POWERED_REEFER,null,null);
	ti2.CM_Container.changeISOType(POWERED_REEFER,null,null);
	ti3.CM_Container.changeISOType(POWERED_REEFER,null,null);
	
	// Move them to the created locations
	create moveCont transient;
	moveCont.setMyToPrimaryLocation(loc1);
	moveCont.setMyTrackedItem(ti1);
	moveCont.setMoveMode(REAL_MODE);

	ti1.setMyLocationsPublic(moveCont);

	moveCont.setMyToPrimaryLocation(loc1);
	moveCont.setMyTrackedItem(ti2);
	moveCont.setMoveMode(REAL_MODE);

	ti2.setMyLocationsPublic(moveCont);
	
	moveCont.setMyToPrimaryLocation(loc2);
	moveCont.setMyTrackedItem(ti3);
	moveCont.setMoveMode(REAL_MODE);

	ti3.setMyLocationsPublic(moveCont);
	commitTransaction;
	
	
	self.assertEqualMsg(app.myMobileAgent.getTIAtLocation(termArea.id &amp; " " &amp; loc1.displayEntry/*"CTEST &lt;1&gt;011"*/,true, retStr),ti1,"This knowingly fails here - Have been unable to find what search string to use to find the location"/*retStr*/);
	
	
epilog
	//delete lane;
	delete moveCont;
end;
</source>
    </JadeMethod>
    <JadeMethod name="tLoadGradesTable" id="c9ef5168-7cfc-497e-be8a-c8d01d2dffa7">
        <source>tLoadGradesTable();
// cnwrs1
// cnwgb1
vars
	form : UT_TestForm;
	table : Table;
	ti  : CM_TrackedItem;
	con : CM_Container;
	term : CM_Terminal;
	row : Integer;	
	grade	: CM_MTGrade;
	
	gradeDesc : String;
	
begin
	self.deleteContainer("CPAT111112");
	
	// Need to set a super user to allow us to set tasks to be complete
	self.setSpecialUser();
	
	con := self.addContainer("CPAT111112",self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString),"2200","MT",TI_IMEX_STATUS_STORAGE).CM_Container;
	
	form := UT_TestForm.createPrintForm;

	table := form.tblTest;
	
	self.assertNotNull(con);
	
	if con &lt;&gt; null then
		grade := app.myRoot.allAvailabilityGrades[con.availabilityGrade];
		gradeDesc := con.availabilityGradeDescription;
		
		// Load the data into the table
		app.myMobileAgent.loadGradesTable(table,con,row);
				
		// check every available grade was loaded in to a row
		assertEqual(table.rows, app.myRoot.allAvailableAvailabilityGrades.size);
		
		// check that the selected item is in the right row
		assertEqual(grade,table.accessRow(row).itemObject);
		
		// check that the correct item is selected ("1" represents a ticked checkbox)
		assertEqual(table.accessCell(row,1).text.Integer, 1);
	endif;	
	
epilog

	form.unload;
	delete form;
	// return to normal user
	app.setSpecial(app.actualTimeServer.TimeStamp);// 12 May 2016	cnwns1	TFS 488 - Multi Timezone Support
end;</source>
    </JadeMethod>
    <JadeMethod name="tLoadStopsTable" id="44406c37-70c0-44c3-85f4-1528b4c220f4">
        <source>tLoadStopsTable();
// cnwrs1
// cnwgb1
constants
	CHECKBOX_COL = 1;
	DESC_COL = 2;
	INDEX_COL = 3;
	DATA_ROW = 1;
vars
	ti : CM_Container;
	form : UT_TestForm;
	tbl : Table;
	row : Integer;
	intArray : IntegerArray;
	
begin
	self.addUserTerminalToUser(self.getCargoType(self.getProfileSetting(UT_Profile.P_CARGO_TYPE).asString));
	
	ti := self.createContainer("CPAT1111110","2200","MT",self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString),true).CM_Container;
	
	form := UT_TestForm.createPrintForm;
	tbl := form.tblTest;
	tbl.rows := 0;
	tbl.columns := 3;
	
	app.myMobileAgent.loadStopsTable(tbl,ti);
	
//	assertTrueMsg(ti.getAllStops().size = 0,"Container has stops defined");	// cnwrl1 14/12/2009 PAR 21889 - what it was
	assertTrueMsg(ti.getAllActiveStopsSize = 0,"Container has stops defined");
	
	// Check that no stops have been set or completed
	foreach row in tbl.fixedRows + 1 to tbl.rows do
		assertTrue(tbl.accessCell(row,CHECKBOX_COL).text.Integer = 0);
	endforeach;
	
	create intArray transient;
	intArray.add(tbl.accessCell(DATA_ROW,INDEX_COL).text.Integer);
	ti.addStopsProxy(intArray);
	
	// reload the table
	app.myMobileAgent.loadStopsTable(tbl,ti);
	
	// now check that the correct task is checked
	assertTrueMsg(tbl.accessCell(DATA_ROW,CHECKBOX_COL).text.Integer = 1, "Stop not set in table");
	
epilog
	delete intArray;
	delete ti;
	form.unload;
	delete form;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="tLoadTasksTable" id="4bdf0e95-c46b-4d63-b044-4f05827f2f73">
        <source>tLoadTasksTable();
// cnwrs1
// cnwgb1
constants
	DESC_COL = 1;
	SET_COL = 2;
	COMPLETED_COL = 3;
	DATE_COL = 4;
	DATA_ROW = 3;
vars
	ti : CM_Container;
	form : UT_TestForm;
	tbl : Table;
	row : Integer;
	task : CM_ToDoTask;
	taskDesc : CM_ToDoTaskDesc;
	newTrans : CM_TITransaction;	//30 Dec 2009	NDL		MES CCMS 1006 - return transaction...
begin
	self.deleteContainer("CPAT111115");
	
	// Need to set a super user to allow us to set tasks to be complete
	self.setSpecialUser();
	
	ti := self.addContainer("CPAT111115", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString),"2200","MT",TI_IMEX_STATUS_STORAGE).CM_Container;
	
	form := UT_TestForm.createPrintForm;
	tbl := form.tblTest;
	tbl.fixedRows := 1;
	tbl.columns := 6;
		
	app.myMobileAgent.loadTasksTable(tbl,ti);
		
	assertTrueMsg(ti.allToDoTasksToDo.size = 0,"Container has todo tasks");
	assertTrueMsg(ti.allToDoTasksCompleted.size = 0,"Container has completed todo tasks");
	
	// Check that no tasks have been set or completed
	foreach row in tbl.fixedRows + 1 to tbl.rows do
		assertTrue(tbl.accessCell(row,SET_COL).text.Integer = 0);
		assertTrue(tbl.accessCell(row,COMPLETED_COL).text.Integer = 0);
		assertTrue(tbl.accessCell(row,DATE_COL).text = "");
	endforeach;
	
	// add a todo task (the first one entered in the table
	
	taskDesc := tbl.accessCell(DATA_ROW,1).itemObject.CM_ToDoTaskDesc;
	beginTransaction;
	task := ti.addToDoTask(taskDesc.description,app.myPassport);
	commitTransaction;
	// reload the table
	app.myMobileAgent.loadTasksTable(tbl,ti);
	
	// now check that the correct task is checked
	assertTrueMsg(tbl.accessCell(DATA_ROW,SET_COL).text.Integer = 1, "Task not set in table");
	
	beginTransaction;
	task.setTaskComplete(app.myPassport,false,newTrans);
	commitTransaction;
	
	app.myMobileAgent.loadTasksTable(tbl,ti);
	
	// Check now that the correct task is complete
	assertTrue(tbl.accessCell(DATA_ROW,SET_COL).text.Integer = 0);
	assertTrue(tbl.accessCell(DATA_ROW,COMPLETED_COL).text.Integer = 0);
	assertTrue(tbl.accessCell(DATA_ROW,DATE_COL).text = task.dtLastUpdate.asStringJMT);

epilog
	beginTransaction;
	delete task;
	commitTransaction;
	form.unload;
	delete form;
	// return to normal user
	app.setSpecial(app.actualTimeServer.TimeStamp);// 12 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	abortTransaction;
end;
</source>
    </JadeMethod>
    <JadeMethod name="tPreviousFormManipulation" id="5582cc48-4a6a-46bb-b89f-0008803a2c3b">
        <source>tPreviousFormManipulation();
// cnwrs1
// cnwgb1
vars
	form1,form2,form3 : Class;
begin
	// the actual classes of the 'forms' is irrelevant
	form1 := UT_HandHeld.class;
	form2 := UT_DSL.class;
	form3 := Object.class;
	
	assertNull(app.myMobileAgent.peekAtPreviousForm);
	assertNull(app.myMobileAgent.getPreviousForm);
	
	app.myMobileAgent.addPreviousForm(form1);
	
	// Check form was added correctly
	assertEqual(app.myMobileAgent.peekAtPreviousForm,form1);
	assertEqual(app.myMobileAgent.getPreviousForm,form1);
	
	// Using the get previous form method should remove the form1 from the stack so it is now empty
	assertNull(app.myMobileAgent.peekAtPreviousForm);
	assertNull(app.myMobileAgent.getPreviousForm);
	
	// add several 'forms' and then remove them, check the order is maintained
	app.myMobileAgent.addPreviousForm(form1);
	app.myMobileAgent.addPreviousForm(form2);
	app.myMobileAgent.addPreviousForm(form3);
	
	assertEqual(app.myMobileAgent.peekAtPreviousForm,form3);
	assertEqual(app.myMobileAgent.getPreviousForm,form3);
	
	// add back the 3rd 'form'
	app.myMobileAgent.addPreviousForm(form3);
	
	assertEqual(app.myMobileAgent.peekAtPreviousForm,form3);
	assertEqual(app.myMobileAgent.getPreviousForm,form3);
	
	assertEqual(app.myMobileAgent.peekAtPreviousForm,form2);
	assertEqual(app.myMobileAgent.getPreviousForm,form2);
	
	assertEqual(app.myMobileAgent.peekAtPreviousForm,form1);
	assertEqual(app.myMobileAgent.getPreviousForm,form1);
	
	assertNull(app.myMobileAgent.peekAtPreviousForm);
	assertNull(app.myMobileAgent.getPreviousForm);
	
	app.myMobileAgent.addPreviousForm(form1);
	app.myMobileAgent.addPreviousForm(form2);
	app.myMobileAgent.addPreviousForm(form3);
	
	// check the logout clears the previous forms
	app.myMobileAgent.doLogout;
	assertNull(app.myMobileAgent.peekAtPreviousForm);
	assertNull(app.myMobileAgent.getPreviousForm);
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="tRemoveNonReefers" id="7a3a100b-96fc-4c10-bec1-6fcfdc1a65f4">
        <source>tRemoveNonReefers();
// cnwrs1
// cnwgb1
constants
	POWERED_REEFER = "2231";
vars
	ti1,ti2,ti3 : CM_TrackedItem;
	moveCont : CMIF_MoveController;
	isoType: CM_ISOType;
	locationID : String;
	loc,nextLoc,prevLoc : CM_GridController;
	termArea : CM_RTGArea;
	prod : CM_Product;
begin

	app.myMobileAgent.allFoundTIs.clear;
	// Create some containers
	ti1 := self.createContainer("CPAT007001","2200", "TEST",self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString),true);
	ti2 := self.createContainer("CPAT007002","2200", "TEST",self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString),true);
	ti3 := self.createContainer("CPAT007003","2200", "TEST",self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString),true);
	
	app.myMobileAgent.allFoundTIs.add(ti1);
	app.myMobileAgent.allFoundTIs.add(ti2);
	app.myMobileAgent.allFoundTIs.add(ti3);
	
	assertEqual(app.myMobileAgent.allFoundTIs.size, 3);
	
	app.myMobileAgent.removeNonReeferTIs();
	// all should've been removed
	assertEqual(app.myMobileAgent.allFoundTIs.size, 0);
	
	// Make 1 of them a powered Reefers
	ti1.CM_Container.changeISOType(POWERED_REEFER,null,null);
	//ti2.CM_Container.changeISOType(POWERED_REEFER,null,null);
	//ti3.CM_Container.changeISOType(POWERED_REEFER,null,null);
	
	app.myMobileAgent.allFoundTIs.add(ti1);
	app.myMobileAgent.allFoundTIs.add(ti2);
	app.myMobileAgent.allFoundTIs.add(ti3);
	
	app.myMobileAgent.removeNonReeferTIs();
	// check the only one left is the only reefer - ti1
	assertEqual(app.myMobileAgent.allFoundTIs.last, ti1);
	
	ti2.CM_Container.changeISOType(POWERED_REEFER,null,null);
	ti3.CM_Container.changeISOType(POWERED_REEFER,null,null);
	
	app.myMobileAgent.allFoundTIs.add(ti2);
	app.myMobileAgent.allFoundTIs.add(ti3);
	
	app.myMobileAgent.removeNonReeferTIs();
	
	assertEqual(app.myMobileAgent.allFoundTIs.size, 3);
	assertEqual(app.myMobileAgent.allFoundTIs.last, ti3);
epilog
	delete ti1;
	delete ti2;
	delete ti3;
end;</source>
    </JadeMethod>
    <JadeMethod name="tUpdateConnection" id="6abddc1a-bf6b-4c94-8ad2-5cc181fd8240">
        <source>tUpdateConnection();
// cnwrs1
// cnwgb1
constants
	POWERED_REEFER = "2231";
vars
	ti : CM_Container;
	
	termArea : CM_TerminalArea;
	moveCont : CMIF_MoveController;
	l  : CM_LocationsController;
	loc : CM_GridController;
	conParams : CMIF_ConnectParams;
begin
	self.deleteContainer("CPAT111114");
	self.deleteTerminalArea("CTEST1");
	
	termArea := self.addRTGArea("CTEST1",2,2,2);
	
	foreach l in termArea.allLocationsControllers where l.isKindOf(CM_GridController) do
		loc := l.CM_GridController;
	endforeach;
		
	ti := self.addContainer("CPAT111114",self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString), "2200","MT",TI_IMEX_STATUS_STORAGE).CM_Container;
	
	beginTransaction;
	// change to a powered reefer and a commodity that requires power and isn't empty
	ti.changeISOType(POWERED_REEFER,null,null);
	ti.setCommodity("AMFC");
	
	ti.updateContentsStatus();
	
	loc.setPower(true);
	
	create moveCont transient;
	moveCont.setMyToPrimaryLocation(loc);
	moveCont.setMyTrackedItem(ti);
	moveCont.setMoveMode(REAL_MODE);
	
	ti.setMyLocationsPublic(moveCont);
	
	commitTransaction;
	
	// Check that conatiner isn't already connected
	assertFalseMsg(ti.isConnected, "Container Already Connected");
	
	// Connect the container
	assertTrueMsg(app.myMobileAgent.updateTIConnection(ti,true,true,null),"Update 1 failed");
	
	// Check it was connected
	assertTrueMsg(ti.isConnected, "Update did not connect Container");
	
	// Check that the update fails as we cannot connect a container that is already connected
	assertFalseMsg(app.myMobileAgent.updateTIConnection(ti,true,true,null), "Update 2 Failed");
	
	// Check that no change of state took place
	assertTrueMsg(ti.isConnected,"Update disconnected Container");
	
	// Disconnect the container
	assertTrueMsg(app.myMobileAgent.updateTIConnection(ti,true,false,null),"Update 3 failed");
	
	// Check that ti was disconnected
	assertFalseMsg(ti.isConnected, "Update did not disconnect Container");

epilog
	delete moveCont;
end;</source>
    </JadeMethod>
    <JadeMethod name="tUpdateDamages" id="ba5bb4b0-f324-4ca9-b105-543f6714b543">
        <source>tUpdateDamages();
// cnwrs1
// cnwgb1
// This test fills CM_DamageEntryTbl values then call the mobileAgent to update the Damages on a container
// Then the values added/updated are checked. It is app.mobileAgent.updateDamages() that is being tested
// Verified 20.10.2009 cnwgb1
// 24 June 2022 navhl20 TFS 53862 EUP - WMS - Damage Recording Extra Details
vars
	ti : CM_Container;
	form : UT_TestForm;
	tbl : CM_DamageEntryTbl;
	errors : String;
	loc,loc2,sev, sev2 : Integer;
	type, type2	: CM_DamageDefinitionCode;
	damageInterface : IF_DamageDetails;
	qty, qty2 : Integer;
	damageDetailsOptional, damageSeverityOptional : Boolean;
begin
	// This is just testing the handHeld implementation of the Damages table, which doesn't have Damage Party, Reason or Place
	// And given that we're never going to develop anything for handhelds, just suppress the validation on these fields for this test
	damageDetailsOptional := self.setTerminalConfig(DamageDetailsOptional, true).Boolean;
	damageSeverityOptional := self.setTerminalConfig(DamageSeverityOptional, true).Boolean;
	
	//Set up Container for testing. Remove any hanging around from an earlier test
	self.deleteContainer("CPAT111117");
	ti := self.addContainer("CPAT111117", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString), "2200","MT",TI_IMEX_STATUS_STORAGE).CM_Container;
	app.myMobileAgent.setMyProxy(ti);

	// Create dummy form with a DamageEntryTable, add a null row
	form := UT_TestForm.createPrintForm;
	tbl := form.tblDamageTest;
	tbl.init();
	
	damageInterface:=ti.IF_DamageDetails;
	tbl.initCombos(damageInterface);
	tbl.addNewRow();
		
	//// TEST 1: Add a damage entry against a container
	///////////////////////////////////////////////////
	
	// Create a row of values in the table. 
	// First select the second value in the damages combobox ( An all over "dent" of severity 1 )
	tbl.accessCell(2,1).cellControl.ComboBox.listIndex := 2;  
	tbl.accessCell(2,2).cellControl.ComboBox.listIndex := 2;
	tbl.accessCell(2,3).cellControl.ComboBox.listIndex := 2;
	
	// Take the values selected in the combo boxes and put them in the actual table
	tbl.accessCell(2,1).text := tbl.accessCell(2,1).cellControl.ComboBox.text;
	tbl.accessCell(2,2).text := tbl.accessCell(2,2).cellControl.ComboBox.text;
	tbl.accessCell(2,3).text := tbl.accessCell(2,3).cellControl.ComboBox.text;
	tbl.accessCell(2,4).text := 1.String;
	
	//Save off a copy of what wasa added to the table
	loc := tbl.accessCell(2,1).cellControl.ComboBox.itemData[2];
	type := tbl.accessCell(2,2).cellControl.ComboBox.itemObject[2].CM_DamageDefinitionCode;
	sev := tbl.accessCell(2,3).cellControl.ComboBox.itemData[2];	
	qty := tbl.accessCell(2,4).text.Integer;
	
	// This is the container the damages are to apply to 
	app.myMobileAgent.setMyProxy(ti);
	
	
	damageInterface:=app.myMobileAgent.getMyProxyObject.IF_DamageDetails;
	tbl.setProxyFromTable(damageInterface, errors, null);
	// Do it
	assertTrueMsg(app.myMobileAgent.updateDamages(damageInterface,null,3),"Update 1 failed");
	
	//There should be but one damage instance
	assertTrueMsg(ti.allDamageInstancesByPos.size = 1,"Damage entry not created correctly");
	
	// Was the area, type and severity  of damage stored correctly
	assertTrueMsg(ti.allDamageInstancesByPos.first.damageLocation = loc,		"Damage Location not set correctly");
	assertTrueMsg(ti.allDamageInstancesByPos.first.myDamageDefinition = type,"Damage Definition not set correctly");
	//assertTrueMsg(ti.allDamageInstancesByPos.first.severity = sev,			"Damage severity not set correctly");					//24 June 2022 navhl20 TFS 53862
	assertTrueMsg(ti.allDamageInstancesByPos.first.myDamageSeverity.level = sev,			"Damage severity not set correctly");	//24 June 2022 navhl20 TFS 53862
	assertTrueMsg(ti.allDamageInstancesByPos.first.quantity = qty,			"Damage quantity not set correctly");

	
	//// TEST 2: Delete a damage entry from a container
	///////////////////////////////////////////////////
	
	tbl.setTableFromDamageInterface(damageInterface);

	tbl.accessCell(2,1).text := null;
	tbl.accessCell(2,2).text := null;
	tbl.accessCell(2,3).text := null;	
	tbl.accessCell(2,4).text := null;
	
	app.myMobileAgent.setMyProxy(ti);
	damageInterface:=app.myMobileAgent.getMyProxyObject.IF_DamageDetails;
	
	tbl.setProxyFromTable(damageInterface, errors, null);
	// Do It
	assertTrueMsg(app.myMobileAgent.updateDamages(damageInterface,null,3),"Update 2 failed");
	
	assertTrueMsg(ti.allDamageInstancesByPos.size = 0,"Damage entry not removed correctly");
	
	//// TEST 3 Add two damages simultaneously
	//////////////////////////////////////////
	
	tbl.setTableFromDamageInterface(damageInterface); // This seems to create a blank row after the fixed row

	// As above, but create a Hole
	tbl.accessCell(tbl.rows,1).cellControl.ComboBox.listIndex := 3;
	tbl.accessCell(tbl.rows,2).cellControl.ComboBox.listIndex := 3;
	tbl.accessCell(tbl.rows,3).cellControl.ComboBox.listIndex := 3;
	
	tbl.accessCell(tbl.rows,1).text := tbl.accessCell(tbl.rows,1).cellControl.ComboBox.text;
	tbl.accessCell(tbl.rows,2).text := tbl.accessCell(tbl.rows,2).cellControl.ComboBox.text;
	tbl.accessCell(tbl.rows,3).text := tbl.accessCell(tbl.rows,3).cellControl.ComboBox.text;
	tbl.accessCell(tbl.rows,4).text := 1.String;
	
	loc := tbl.accessCell(tbl.rows,1).cellControl.ComboBox.itemData[3];
	type:= tbl.accessCell(tbl.rows,2).cellControl.ComboBox.itemObject[3].CM_DamageDefinitionCode;
	sev := tbl.accessCell(tbl.rows,3).cellControl.ComboBox.itemData[3];
	qty := tbl.accessCell(tbl.rows,4).text.Integer;
	
	tbl.addNewRow();
	
	// As above, but create a dent similar to the one we just deleted
	tbl.accessCell(tbl.rows,1).cellControl.ComboBox.listIndex := 2; 
	tbl.accessCell(tbl.rows,2).cellControl.ComboBox.listIndex := 2;
	tbl.accessCell(tbl.rows,3).cellControl.ComboBox.listIndex := 2;
	
	tbl.accessCell(tbl.rows,1).text := tbl.accessCell(tbl.rows,1).cellControl.ComboBox.text;
	tbl.accessCell(tbl.rows,2).text := tbl.accessCell(tbl.rows,2).cellControl.ComboBox.text;
	tbl.accessCell(tbl.rows,3).text := tbl.accessCell(tbl.rows,3).cellControl.ComboBox.text;
	tbl.accessCell(tbl.rows,4).text := 2.String;
	
	loc2 := tbl.accessCell(tbl.rows,1).cellControl.ComboBox.itemData[2];
	type2:= tbl.accessCell(tbl.rows,2).cellControl.ComboBox.itemObject[2].CM_DamageDefinitionCode;
	sev2 := tbl.accessCell(tbl.rows,3).cellControl.ComboBox.itemData[2];
	qty2 := tbl.accessCell(tbl.rows,4).text.Integer;

	app.myMobileAgent.setMyProxy(ti);
	
	
	damageInterface:=app.myMobileAgent.getMyProxyObject.IF_DamageDetails;
	tbl.setProxyFromTable(damageInterface, errors, null);
	// Do it
	assertTrueMsg(app.myMobileAgent.updateDamages(damageInterface,null,3),"Update 3 failed"); //cnwas3 par 24175
	
	assertTrueMsg(ti.allDamageInstancesByPos.size = 2,"Damage entries not created correctly");
	
	// Note that this collection is ordered by the damage location which happens to be loc2 first
	
	assertTrueMsg(ti.allDamageInstancesByPos.first.damageLocation = loc2, "First Damage Location not set correctly");
	assertTrueMsg(ti.allDamageInstancesByPos.first.myDamageDefinition = type2, "First Damage Definition not set correctly");
	//assertTrueMsg(ti.allDamageInstancesByPos.first.severity = sev2, "First Damage severity not set correctly");		//24 June 2022 navhl20 TFS 53862
	assertTrueMsg(ti.allDamageInstancesByPos.first.myDamageSeverity.level = sev2, "First Damage severity not set correctly");		//24 June 2022 navhl20 TFS 53862
	assertTrueMsg(ti.allDamageInstancesByPos.first.quantity = qty2, "First Damage quantity not set correctly");
	
	assertTrueMsg(ti.allDamageInstancesByPos.last.damageLocation = loc, "Second Damage Location not set correctly");
	assertTrueMsg(ti.allDamageInstancesByPos.last.myDamageDefinition = type, "Second Damage Definition not set correctly");
	//assertTrueMsg(ti.allDamageInstancesByPos.last.severity = sev, "Second Damage severity not set correctly");		//24 June 2022 navhl20 TFS 53862
	assertTrueMsg(ti.allDamageInstancesByPos.last.myDamageSeverity.level = sev, "Second Damage severity not set correctly");		//24 June 2022 navhl20 TFS 53862
	assertTrueMsg(ti.allDamageInstancesByPos.last.quantity = qty, "Second Damage quantity not set correctly");
	
	// OK We're done
epilog
	self.setTerminalConfig(DamageDetailsOptional, damageDetailsOptional);
	self.setTerminalConfig(DamageSeverityOptional, damageSeverityOptional);
	app.myMobileAgent.setMyProxy(null);
	form.unload;
	delete form;
end;</source>
    </JadeMethod>
    <JadeMethod name="tUpdateGrade" id="019244d5-ccdb-4ad0-ac6d-65d326766222">
        <source>tUpdateGrade();
// cnwrs1
// cnwgb1
vars
	ti : CM_Container;
	grade : CM_MTGrade;
begin
	self.deleteContainer("CPAT111111");
	
	grade := app.myRoot.allAvailabilityGrades.last;
	
	ti := self.addContainer("CPAT111111",self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString),"2200","MT",TI_IMEX_STATUS_STORAGE).CM_Container;
		
	if ti.availabilityGrade = grade.code then
	// assumes that the first isnt the same as the last!
		grade := app.myRoot.allAvailabilityGrades.first;
	endif;
	
	assertTrueMsg(app.myMobileAgent.updateGrade(ti,grade),"Update Failed");
	
	assertEqual(ti.availabilityGrade, grade.code);
	
	assertFalseMsg(app.myMobileAgent.updateGrade(ti,null),"Null value did not return false");
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="tUpdateStops" id="ee2dbf78-68c4-4f4e-9d96-5c0600c1f3d5">
        <source>tUpdateStops();
// cnwrs1
// cnwgb1
constants
	CHECKBOX_COL = 1;
	DESC_COL = 2;
	ID_COL = 3;
vars
	ti : CM_Container;
	form : UT_TestForm;
	tbl : Table;

	fieldNames : IntegerArray;
	fieldValues : StringArray;
	row,val : Integer;
	found : Boolean;
	
	stop : CM_StopsTable;

begin
	self.addUserTerminalToUser(self.getCargoType(self.getProfileSetting(UT_Profile.P_CARGO_TYPE).asString));
	
	self.deleteContainer("CPAT111119");
	
	ti := self.addContainer("CPAT111119",self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString),"2200","MT",TI_IMEX_STATUS_STORAGE).CM_Container;
	app.myMobileAgent.setMyProxy(ti);

	form := UT_TestForm.createPrintForm;
	tbl := form.tblTest;
	tbl.columns := 3;
	
	app.myMobileAgent.loadStopsTable(tbl,ti);
	
	foreach row in tbl.fixedRows + 1 to tbl.rows do
		stop := app.getMyUser().getStopsToViewForTerminal(self.getTerminal)[tbl.accessCell(row,ID_COL).text.Integer];
		if app.getMyUser().getStopsToMaintForTerminal(self.getTerminal).includes(stop) then
			found := true;
			break;
		endif;
	endforeach;
	
	if not found then // fail test
		self.assertTrueMsg(false,"User does not have permission to add any stops - run test again with a different user");
	endif;
	
// ***** Test adding a new stop
	tbl.accessCell(2,1).text := "1";
	
	create fieldNames transient;
	create fieldValues transient;
	app.myMobileAgent.findIfStopsRemovalNeedsInfo(tbl,fieldNames,ti);
	
	if fieldNames.size &gt; 0 then
		// have to add extra values;
		foreach val in 1 to fieldNames.size do
			fieldValues.add("1234");
		endforeach;
	endif;
	
	app.myMobileAgent.setMyProxy(ti);
	
	assertTrueMsg(app.myMobileAgent.updateStops(ti,tbl,fieldNames,fieldValues),"Update 1 failed");
	
//	assertTrueMsg(ti.getAllStops().size = 1, "Creation of stop 1 failed");	// cnwrl1 14/12/2009 PAR 21889 - what it was
	assertTrueMsg(ti.getAllActiveStopsSize = 1, "Creation of stop 1 failed");
	
// ******** Add a second stop
	tbl.accessCell(3,1).text := "1";
	
	fieldNames.clear;
	fieldValues.clear;
	app.myMobileAgent.findIfStopsRemovalNeedsInfo(tbl,fieldNames,ti);
	
	if fieldNames.size &gt; 0 then
		// have to add extra values;
		foreach val in 1 to fieldNames.size do
			fieldValues.add("1234");
		endforeach;
	endif;
	
	app.myMobileAgent.setMyProxy(ti);
	
	assertTrueMsg(app.myMobileAgent.updateStops(ti,tbl,fieldNames,fieldValues),"Update 2 failed");
	
//	assertTrueMsg(ti.getAllStops().size = 2, "Creation of stop 2 failed");	// cnwrl1 14/12/2009 PAR 21889 - what it was
	assertTrueMsg(ti.getAllActiveStopsSize = 2, "Creation of stop 2 failed");
	
// ****** Take off one of the stops
	tbl.accessCell(2,1).text := "0";
	
	fieldNames.clear;
	fieldValues.clear;
	app.myMobileAgent.findIfStopsRemovalNeedsInfo(tbl,fieldNames,ti);
	
	if fieldNames.size &gt; 0 then
		// have to add extra values;
		foreach val in 1 to fieldNames.size do
			fieldValues.add("1234");
		endforeach;
	endif;
	
	app.myMobileAgent.setMyProxy(ti);
	
	assertTrueMsg(app.myMobileAgent.updateStops(ti,tbl,fieldNames,fieldValues),"Update 3 failed");
	
//	assertTrueMsg(ti.getAllStops().size = 1, "Removal of stop 1 failed");	// cnwrl1 14/12/2009 PAR 21889 - what it was
	assertTrueMsg(ti.getAllActiveStopsSize = 1, "Removal of stop 1 failed");
	
	// ****** Take off the second stop
	tbl.accessCell(3,1).text := "0";
	
	fieldNames.clear;
	fieldValues.clear;
	app.myMobileAgent.findIfStopsRemovalNeedsInfo(tbl,fieldNames,ti);
	
	if fieldNames.size &gt; 0 then
		// have to add extra values;
		foreach val in 1 to fieldNames.size do
			fieldValues.add("1234");
		endforeach;
	endif;
	
	app.myMobileAgent.setMyProxy(ti);
	
	assertTrueMsg(app.myMobileAgent.updateStops(ti,tbl,fieldNames,fieldValues),"Update 4 failed");
	
//	assertTrueMsg(ti.getAllStops().size = 0, "Removal of stop 2 failed");	// cnwrl1 14/12/2009 PAR 21889 - what it was
	assertTrueMsg(ti.getAllActiveStopsSize = 0, "Removal of stop 2 failed");
	
epilog
	app.myMobileAgent.setMyProxy(null);
	delete fieldNames;
	delete fieldValues;
	if form &lt;&gt; null then
		form.unload;
		delete form;
	endif;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="tUpdateTasks" id="37f112d9-7dc4-4fcf-b1e1-2ef11e5a2d0b">
        <source>tUpdateTasks();
// cnwrs1
// cnwgb1
constants
	DESC_COL = 1;
	SET_COL = 2;
	COMPLETED_COL = 3;
	DATE_COL = 4;
	DATA_ROW = 2;
vars
	ti : CM_TrackedItem;
	form : UT_TestForm;
	tbl : Table;
	row : Integer;
	task : CM_ToDoTask;
	taskDesc : CM_ToDoTaskDesc;
begin
	self.deleteContainer("CPAT111110");
	
	// Need to set a super user to allow us to set tasks to be complete
	app.setSpecial('31/12/3000'.TimeStamp);
	
	ti := self.addContainer("CPAT111110",self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString),"2200","MT",TI_IMEX_STATUS_STORAGE).CM_Container;
	
	form := UT_TestForm.createPrintForm;
	tbl := form.tblTest;
	tbl.fixedRows := 1;
	tbl.columns := 6;
		
	app.myMobileAgent.loadTasksTable(tbl,ti);
		
	assertTrueMsg(ti.allToDoTasksToDo.size = 0,"Container has todo tasks");
	assertTrueMsg(ti.allToDoTasksCompleted.size = 0,"Container has completed todo tasks");
	
	// Check that no tasks have been set or completed
	foreach row in tbl.fixedRows + 1 to tbl.rows do
		assertTrue(tbl.accessCell(row,SET_COL).text.Integer = 0);
		assertTrue(tbl.accessCell(row,COMPLETED_COL).text.Integer = 0);
		assertTrue(tbl.accessCell(row,DATE_COL).text = "");
	endforeach;
	
	taskDesc := tbl.accessCell(DATA_ROW,1).itemObject.CM_ToDoTaskDesc;
	// set a todo task (the first one entered in the table)
	tbl.accessCell(DATA_ROW,SET_COL).text := "1";

	// update the tracked item
	app.myMobileAgent.updateTasks(tbl,ti);
	
	// now check that the correct task is created
	assertTrueMsg(ti.allToDoTasksToDo.size = 1, "Task not created correctly");
	assertTrueMsg(ti.allToDoTasksToDo.first.toDoTaskDescDesc = taskDesc.description, "Incorrect Task created");
	
	// Check the completed check box and enter a date
	tbl.accessCell(DATA_ROW,COMPLETED_COL).text := "1";
	tbl.accessCell(DATA_ROW,DATE_COL).text := "01/01/2009";
	
	// update the tracked item
	app.myMobileAgent.updateTasks(tbl,ti);
	
	// now check that the correct task is checked
	assertTrueMsg(ti.allToDoTasksCompleted.size = 1, "Task not completed correctly");
	assertTrueMsg(ti.allToDoTasksCompleted.first.dtLastUpdate.date = "01/01/2009".Date, "Task not completed on correct date");
	assertTrueMsg(ti.allToDoTasksCompleted.first.toDoTaskDescDesc = taskDesc.description, "Incorrect Task completed");
	
epilog
	form.unload;
	delete form;
	app.setSpecial(app.actualTimeServer.TimeStamp);// 12 May 2016	cnwns1	TFS 488 - Multi Timezone Support
end;</source>
    </JadeMethod>
    <JadeMethod name="tUpdateTemperatures" id="b968bbd4-7fa1-42fe-91d5-07400b3b39d1">
        <source>tUpdateTemperatures();
// Changed On	By			Reason
// ----------	--------	---------------------------------------------
// 19/03/2015	cnwdap1		PAR #35874 TFS 265 New parameters for app.myMobileAgent.updateTemperatureOfProxy
constants
	POWERED_REEFER = "2231";
vars
	ti,pxyTI : CM_TrackedItem;
	moveCont : CMIF_MoveController;
	isoType: CM_ISOType;
	locationID : String;
	loc,nextLoc,prevLoc : CM_GridController;
	termArea : CM_RTGArea;
	prod : CM_Product;
begin
	self.deleteContainer("CPAT111113");
	
	// Create some containers
	ti := self.addContainer("CPAT111113",self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString),"2200","MT",TI_IMEX_STATUS_STORAGE).CM_Container;
	
	beginTransaction;
	// change to a powered reefer and a commodity that requires power and isn't empty
	ti.changeISOType(POWERED_REEFER,null,null);
	ti.setCommodity("AMFC");
	
	ti.updateContentsStatus();
	
	commitTransaction;
	
	app.myMobileAgent.setMyProxy(ti);
	
	assertTrueMsg(app.myMobileAgent.updateTemperatureOfProxy(true,"5.0",null,null),"Update 1 Failed");	// PAR #35874
	
	assertTrueMsg(ti.CM_Container.getAllTemperatureReadings.last.getTemperatureValue = 5.0,"Last Reading temperature not correct (1)");
	
	assertTrueMsg(app.myMobileAgent.updateTemperatureOfProxy(true,"-5.0",null,null),"Update 2 Failed");	// PAR #35874
	
	assertTrueMsg(ti.CM_Container.getAllTemperatureReadings.last.getTemperatureValue = -5.0,"Last Reading temperature not correct (2)");
	
	assertTrueMsg(app.myMobileAgent.updateTemperatureOfProxy(true,"0.0",null,null),"Update 3 Failed");	// PAR #35874
	
	assertTrueMsg(ti.CM_Container.getAllTemperatureReadings.last.getTemperatureValue = 0.0,"Last Reading temperature not correct (3)");
epilog
	// delete the proxy
	app.myMobileAgent.setMyProxy(null);
end;</source>
    </JadeMethod>
</Class>
