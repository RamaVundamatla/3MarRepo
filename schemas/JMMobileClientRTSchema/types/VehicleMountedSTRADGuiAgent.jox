    <JadeMethod name="moveTI" id="87a89b0b-fc9d-438c-a4f8-4a9932d64124">
        <source>moveTI(		_form				: VehicleMounted_STRADForm input;
			_ti					: CM_TrackedItem;
			_setDownLocation	: String;
			_twinTI				: CM_TrackedItem;
			_twinSetDownLocation : String;
			_errorMsgs:  DTO_HandHeldGateErrorDict input): Boolean;
/*
Purpose:			

Parameters:			

Return Value:		


Date			Who		Reason
16 June 2008	concms1	PAR 17123 (ccms 1671) DCT Gdansk RDT Screen to relocate
*/
vars

	packageDTO 		: MobileServerRTThin::DTO_EnquiryGradingTasks;
	rtnValue		: Boolean;

begin
	
	create packageDTO transient;

	rtnValue := self.myVehicleMountedSTRADAgent.moveTI(_setDownLocation, null, packageDTO, _errorMsgs);

	if rtnValue then
		_form.loadMoveTable(packageDTO,null);
	endif;

	return rtnValue;

epilog
	delete packageDTO;
end;</source>
        <Parameter name="_form" type="VehicleMounted_STRADForm" usage="input"/>
        <Parameter name="_ti" type="MobileHandHeldThin::CM_TrackedItem"/>
        <Parameter name="_setDownLocation" type="String"/>
        <Parameter name="_twinTI" type="MobileHandHeldThin::CM_TrackedItem"/>
        <Parameter name="_twinSetDownLocation" type="String"/>
        <Parameter name="_errorMsgs" type="MobileHandHeldThin::DTO_HandHeldGateErrorDict" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
