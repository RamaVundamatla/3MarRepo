    <JadeMethod name="addObjectsToTable" id="6fdc4014-ad48-4f22-8fb8-3cebc0d9e973">
        <updating/>
        <source>addObjectsToTable(_numItems: Integer io) updating;
/*

Purpose:   		Think this is where we do the search 	
					once we find an object call self.addObjectToTable
					that calls tblDataDisplayRow


Return Value:		


Date		Who		Reason
13 September 2007	cnwer1	Initial creation - PAR#xxxx

*/
vars
	allFaultResponses 	: CM_FaultResponsesByReportedTS;
	faultResponse : CM_FaultResponse;
	iter : Iterator;
	breakOut : Boolean;
begin

	allFaultResponses:=self.getCollectionForSearch;
	if allFaultResponses = null or allFaultResponses.size = 0 then
		return;
	endif;
	
	iter := allFaultResponses.createIterator;
	if self.filterFromTS &lt;&gt; null then
		allFaultResponses.startKeyGeq(self.filterFromTS,iter);	
	endif;
	

	while iter.next(faultResponse) do
		
		if self.filterToTS &lt;&gt; null  and self.filterToTS &lt; faultResponse.reportedTS then
			break;
		endif;
		
		
		if self.includeObject(faultResponse, app.myPassport) then
			self.addObjectToTable(faultResponse, _numItems, breakOut);
			
			if breakOut then
				break;
			endif;
		endif;
		
	endwhile;
	
epilog
	delete iter;
end;</source>
        <Parameter name="_numItems" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="addToolbarControls" id="586cb3a3-8eb1-4be1-a259-7ff331cd0924">
        <source>addToolbarControls()  protected;
/*

Purpose:			


