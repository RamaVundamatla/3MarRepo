    </ExplicitInverseRef>
    <PrimAttribute name="sectionName" id="e1bc3c17-14e8-44ca-b261-9021e0a9bb72">
        <length>256</length>
        <embedded/>
        <type name="String"/>
        <access>readonly</access>
    </PrimAttribute>
    <JadeMethod name="addIniKey" id="9da6b41f-70b1-4424-a076-219493fcfb28">
        <source>addIniKey(pKeyName:String; pDefaultValue:String);
// --------------------------------------------------------------------------------
// Created:		01 February 2000 by cnwdad1
//
// Purpose:		Add a key to the receiver section.
//
// Parameters:	pKeyName - The name of the key.
//				pDefaultValue - The default value of the key.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	iniKeyObj	: CnEcIniKey;

begin
	iniKeyObj	:=	self.createKey(pKeyName, pDefaultValue);

	if iniKeyObj &lt;&gt; null then
		if (not app.setProfileString(self.myIniFile.fileName, self.sectionName, pKeyName, pDefaultValue)) then
			delete iniKeyObj;
		endif;
	endif;
end;</source>
        <Parameter name="pKeyName" type="String"/>
        <Parameter name="pDefaultValue" type="String"/>
    </JadeMethod>
    <JadeMethod name="createKey" id="295632c8-f694-49fa-ac2d-eb6e729f8f75">
        <source>createKey(pKeyName:String; pDefaultValue:String):CnEcIniKey;
// --------------------------------------------------------------------------------
// Created:		22 January 2000 by cnwdad1
//
// Purpose:		Create a new key for the receiver section.
//
// Parameters:	pKeyName - The name of the new key.
//				pDefaultValue - The default value of the new key.
//
// Returns:		The newly created key object.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	iniKeyObj	: CnEcIniKey;

begin
	on Exception do cnEcIniExceptionHandler(exception);

	create iniKeyObj transient;
	iniKeyObj.set(pKeyName, self.myIniFile.getKeyValue(self.sectionName, pKeyName, pDefaultValue), pDefaultValue);
	iniKeyObj.setIniSection(self);
	return iniKeyObj;
end;</source>
        <Parameter name="pKeyName" type="String"/>
        <Parameter name="pDefaultValue" type="String"/>
        <ReturnType type="CnEcIniKey"/>
    </JadeMethod>
    <JadeMethod name="deleteIniKey" id="49ff36de-94f2-42dc-8f6e-620547d019a4">
        <source>deleteIniKey(pKeyName:String);
// --------------------------------------------------------------------------------
// Created:		01 February 2000 by cnwdad1
//
// Purpose:		Delete a key from the receiver section.
//
// Parameters:	pKeyName - The name of the key to delete.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	iniKeyObj	: CnEcIniKey;

begin
	iniKeyObj	:=	self.allIniKeys[pKeyName];

	if iniKeyObj &lt;&gt; null then
		if app.setProfileString(self.getFileName(), self.sectionName, pKeyName, ProfileRemoveKey) then
			delete iniKeyObj;
		endif;
	endif;
end;</source>
        <Parameter name="pKeyName" type="String"/>
    </JadeMethod>
    <JadeMethod name="getFileName" id="fbb97e5a-eb88-4e16-a2d1-14a9b00ae1bf">
        <source>getFileName():String;
// --------------------------------------------------------------------------------
// Created:		22 January 2000 by cnwdad1
//
// Purpose:		Get the name of the initialization file.
//
// Parameters:	None
//
// Returns:		The file name of the initialization file.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return self.myIniFile.fileName;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getListDisplay" id="2493f185-5cd6-47bb-8084-e76812fbfbc9">
        <source>getListDisplay():String;
// --------------------------------------------------------------------------------
// Created:		22 January 2000  by cnwdad1
//
// Purpose:		Get the display value for the receiver.
//
// Parameters:	None
//
// Returns:		The display value.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return self.sectionName &amp; " [" &amp; self.allIniKeys.size().String &amp; "]";
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="set" id="12277d1f-d62d-4102-98e8-58cc6b4dadaa">
        <updating/>
        <source>set(pSectionName:String) updating;
// --------------------------------------------------------------------------------
// Created:		22 January 2000 by cnwdad1
//
// Purpose:		Set the receiver's name.
//
// Parameters:	pSectionName - The name of the receiver.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if self.sectionName &lt;&gt; pSectionName then
		self.sectionName	:=	pSectionName;
	endif;
end;</source>
        <Parameter name="pSectionName" type="String"/>
    </JadeMethod>
    <JadeMethod name="setIniFile" id="783f561a-f7bd-4a85-b551-1d416e223245">
        <updating/>
        <source>setIniFile(pIniFileObj:CnEcIniFile) updating;
// --------------------------------------------------------------------------------
// Created:		22 January 2000 by cnwdad1
//
// Purpose:		Set a reference to the receiver's initialization file object.
//
// Parameters:	pIniFileObj - The BaseSchema file object.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if self.myIniFile &lt;&gt; pIniFileObj then
		self.myIniFile	:=	pIniFileObj;
	endif;
end;</source>
        <Parameter name="pIniFileObj" type="CnEcIniFile"/>
    </JadeMethod>
</Class>
