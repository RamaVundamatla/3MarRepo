    <JadeMethod name="utlCreateAndRunBackgroundRpt" id="584c50e7-3d30-4ee8-9643-eb9cc707c3f4">
        <source>utlCreateAndRunBackgroundRpt(	_isForPackage			: Boolean;
								_name,
								_description,
								_profileName,
								_printerName,
								_networkFilePath		: String;
								_destination,
								_outputType 			: Integer;
								_stopEmailWhenNoDataRpt	: Boolean;
								_filter					: CMQF_FilterReports;
