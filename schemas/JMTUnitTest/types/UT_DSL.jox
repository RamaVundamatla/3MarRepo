    <JadeMethod name="addBoom" id="b434eb2c-8d43-4b10-9a99-1e30f5bf0a62">
        <source>addBoom(_code, _description, _ipAddress : String; _portNumber : Integer) : CM_Boom;

/*

Purpose:		Add Boom		

Date			Who		Reason
21/03/2014		cnwmh5	Initial creation

*/

vars

	pxyBoom						: CM_Boom;
	boom						: CM_Boom;

begin

	self.deleteBoom(_code);

	create pxyBoom transient;
	pxyBoom.setProxy(_code, _description, _ipAddress, _portNumber, self.getTerminal(),
						null,	//_channel : Integer;	//14 Feb 2019	NDL	TFS 43403
						null,	//_userCode : String;	//14 Feb 2019	NDL	TFS 43403
						null	//_password : String	//14 Feb 2019
						);
	
	app.myTrxCA.trxCreateBoom(pxyBoom, boom, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
	return boom;

epilog

