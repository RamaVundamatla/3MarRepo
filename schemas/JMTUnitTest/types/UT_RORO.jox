constants
	VoyageName1 = 'VOYSHIP30738_5';
	VoyageName2 = 'VOYSHIP30738_6';
	VoyageName3 = 'VOYSHIP30738_7';
	ShipName = 'JROSO';	//JROSO
	TestOperator = 'MSL';
	UserDefinedDeckPlan	= 'Unit Test Deck Plan';
	UserDefinedStowAdvice = 'Unit Test RORO Stow Advice';
	UserDefinedDeckPlanNoBOL	= 'Unit Test Deck Plan No BOL';
