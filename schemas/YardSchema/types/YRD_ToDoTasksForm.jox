    <JadeMethod name="doBtnEnquireClick" id="db696d48-3b47-4299-bea4-58ffb903399e">
        <source>doBtnEnquireClick(_doEdit : Boolean) protected;
// ---------------------------------------------------------------------------
// Created:     10 September 2003	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	theObject : Object;
	
begin

	if self.tblData.row &lt;= self.tblData.fixedRows then
		return;
	endif;
	
	theObject := self.tblData.accessRow(self.tblData.row).itemObject;
	
	if (not self.tblData.accessedRow.selected) then
		app.msgBox('Please select a container on which to enquire', 'Nothing selected', MsgBox_Exclamation_Mark_Icon);
		return;
	endif;

	if theObject &lt;&gt; null and theObject.isKindOf(CM_TrackedItem) then
		self.myAssistant.showCargoEnquiryForm(theObject.CM_TrackedItem, self.myMasterMenuAction, true, _doEdit);		
	endif;
		
end;</source>
        <access>protected</access>
        <Parameter name="_doEdit" type="Boolean"/>
