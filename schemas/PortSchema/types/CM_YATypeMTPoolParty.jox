    <JadeMethod name="getObjects" id="26568e4d-4059-455b-8b52-0ed51bcaf0f2">
        <source>getObjects(objects: ObjectLongNameDict input);
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 20/12/2016	cnwdap1		Initial creation TFS 3040 SNO Empty Container Management
//
vars
	terminal : CM_Terminal;
	poolParty : CM_MTPoolingParty;

begin
	terminal := app.getMyTerminalDO_NOT_USE();
	
	foreach poolParty in terminal.allMTPoolingParties do
		objects[poolParty.getYAIdentifier] := poolParty;
	endforeach;

epilog

end;</source>
        <Parameter name="objects" type="ObjectLongNameDict" usage="input"/>
    </JadeMethod>
