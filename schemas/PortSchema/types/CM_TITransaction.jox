    </JadeMethod>
    <JadeMethod name="getDateTimeLocalTZ" id="636b0438-9ee5-4a66-89b8-20b5b93295f1">
        <source>getDateTimeLocalTZ() : TimeStamp;
/*

Purpose:			Return the local timezone version of the receiver's dateTime (for JRW)

Parameters:			None

Return Value:		

Date		Who		Reason
07 Apr 2016	cnwkpd1	TFS 488 - Multi Timezone Support

*/

vars

begin
	return self.systemToLocalTime(self.dateTime);
	
epilog

end;</source>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="getDebtorForInvLineUsedCOO" id="e3ed84b6-dd20-465c-af83-cad607d7c483">
        <source>getDebtorForInvLineUsedCOO(_invLineDesc: CM_InvoiceLineDesc; _didWeUseCOO: Boolean output): CM_Debtor;
/*
Purpose:			

Date				Who		Reason
07 February 2024	navab1	CR 58263 TASK 58264
CR 64873 TASK 65509 02AUG2024 - re written for all TI Transactions
23 Oct 2024 		navlw1	JIRA-33107: Invoice Logging Use Levels
25 Feb 2025			navma1	Story 34141: MTN - Performance Improvements - Review for invLog() Methods
*/

vars
	ti : CM_TrackedItem;
	incoTerm : CM_InvoiceINCOTerm;
	bu : CM_Bank;
	incoMapping		: CM_InvoiceINCOMapping;
	debtorType		: CM_DebtorType;
	debtorToUse		: CM_Debtor;
	cooHeader 		: CM_OwnershipChange;
	tiinco 			: String;
	canLogExtra		: Boolean;
begin
	
	ti := self.myTrackedItem;
	
	_didWeUseCOO := false;
	
	if ti = null then
		return null;
	endif;
	
	canLogExtra	:= app.canLogExtraDetail();				//26.02.2025 navma1	#34141
	
	// if INCO term to be used yet?
	cooHeader:= ti.getCOOForDate(self.dateTime);
	if cooHeader = null then
		if canLogExtra then
			app.invLog("No COO found for transaction date " &amp; self.dateTime.String &amp; " INCO Term NOT used - " &amp; ti.id, LogTRACE.String);
		endif;
		return null;
	endif;

	bu := self.getBusinessUnitObject();
	tiinco := self.incoTermCode;
	
	incoTerm := bu.allInvoiceINCOTerms[tiinco];
	
	if incoTerm = null then
		if canLogExtra then
			app.invLog("Transaction has INCO term Code (" &amp; tiinco &amp; ") but it is unknown, INCO Term is NOT used", LogTRACE.String);
		endif;
		return null;
	endif;
	
	incoMapping := incoTerm.allINCOTermMappingsByInvLnType[_invLineDesc];
	
	if incoMapping &lt;&gt; null then
		debtorType := incoMapping.myDebtorType;
		
		if debtorType &lt;&gt; null then
			if canLogExtra then
				app.invLog("TI has INCO term Code (" &amp; tiinco &amp; ") It specifies debtor type " &amp; debtorType.description, LogTRACE.String);
			endif;
			debtorToUse := _invLineDesc.getDebtorFromTIForCOO(ti, debtorType, self.dateTime);
			if debtorToUse &lt;&gt; null then
				_didWeUseCOO := true;
				if canLogExtra then
					app.invLog("TI has INCO term Code (" &amp; tiinco &amp; ") It specifies debtor type " &amp; debtorType.description &amp; " for " &amp; ti.id &amp; " this is " &amp; debtorToUse.name &amp; ". INCO Term " &amp; ti.incoTermCode &amp; " Has been USED", LogTRACE.String);
				endif;
				return debtorToUse;
			endif;
		endif;
	endif;

	return null;
	
epilog

end;</source>
        <Parameter name="_invLineDesc" type="CM_InvoiceLineDesc"/>
        <Parameter name="_didWeUseCOO" type="Boolean" usage="output"/>
        <ReturnType type="CM_Debtor"/>
    </JadeMethod>
    <JadeMethod name="getDebtorForInvoiceLine" id="03c34c30-28cb-43b6-91ed-151327a72f99">
        <source>getDebtorForInvoiceLine(_invLineDesc : CM_InvoiceLineDesc) : CM_Debtor;
/*
Purpose:	TFS 42221	moved from CM_InvoiceLineDesc to CM_TITransaction so that it can be sub classed in CM_WorkOrderExtraTI 	
Date				Who			Reason
DECEMBER 2018		CNWAB1		Initial creation
05/06/2019			jlgdap1		TFS 44554 AAT Stevedore Data Access
04 Nov 2020 		cnwma1 		ChangeRequest 50112: ASPA - GCI Stevedores
01/06/2022	navak20	53195: EUP - GEN/REP/INB - Additional Cargo Field – Shipping Line - Portschema
23 Oct 2024			navlw1		JIRA-33107: Invoice Logging Use Levels
25 Feb 2025			navah1		Story 34141: MTN - Performance Improvements - Review for invLog() Methods
*/

vars
	doLog				  : Boolean;
	debtor				  : CM_Debtor;
	chargeableBusinessUnit: CM_Bank;
	tmpCode,
	lMessageText		  : String;
	tmpConsigneeOr		  : CM_ConsigneeConsignor;
	tmpVoyage			  : CM_Voyage;
	tranOperator, 
	tmpOperator			  : CM_Operator;
	tmpCA 				  : CM_CustomsAgent;
	tmpCarrier			  : CM_Carrier;
	myDebtorTypeCode 	  : String;
	deriveDebtorTypeFrom  : CM_DebtorType;
	debtorType 			  : CM_DebtorType;
	tmpPoolParty 		  : CM_MTPoolingParty;					// TFS 3042
	opTerm 				  : CM_OperatorTerminal;				// TFS 3042
	tmpStevedore 		  : CM_Stevedore;						// TFS 44554
	tmpShipLine			  : CM_ShippingLine;					// TFS 53195
	usedINCO : Boolean;
begin

	// ### TFS CR 64873 TASK 65509 02AUG2024 NAVAB1
	debtor := self.getDebtorForInvLineUsedCOO(_invLineDesc, usedINCO);
	
	if usedINCO and debtor &lt;&gt; null then
		return debtor;
	endif;
	
	doLog := app.canLogExtraDetail(); //27.02.2025 navah1	#34141

	tmpCode := self.operatorCode;
	if tmpCode &lt;&gt; null then
		tranOperator := app.myRoot.allOperators[tmpCode];
	endif;
	
	deriveDebtorTypeFrom := _invLineDesc.myDebtorType;
	if deriveDebtorTypeFrom &lt;&gt; null then
		myDebtorTypeCode := deriveDebtorTypeFrom.code;
	
		if myDebtorTypeCode = CM_DebtorType.DT_CARGO_OPERATOR then
			lMessageText := "Debtor for Cargo Operator Charge";
			tmpCode := self.operatorCode;
			if tmpCode &lt;&gt; null then
				tmpOperator := app.myRoot.allOperators[tmpCode];
				if tmpOperator &lt;&gt; null then
					// ### Check for any mappings
					debtorType := _invLineDesc.bank.getDebtorTypeFromMapTrans( _invLineDesc, tmpOperator, self ); // PAR 17557
					if debtorType = null then // no charge mappings so carry on
						debtor := tmpOperator.debtor;
						if doLog and debtor &lt;&gt; null then
							app.invLog(lMessageText &amp; " " &amp; debtor.name, LogINFO.String);
						endif;
					else
						debtor := _invLineDesc.getDebtorFromTypeTransaction(debtorType, self);
					endif;
				endif;
			endif;
	
		elseif myDebtorTypeCode = CM_DebtorType.DT_CONSIGNEE then
			lMessageText := "Debtor for Consignee Charge";
			tmpCode := self.consignee;
			if tmpCode &lt;&gt; null then
				tmpConsigneeOr := app.myRoot.allConsigneeConsignors[tmpCode];
				if tmpConsigneeOr &lt;&gt; null then
					// ### Check for any mappings
					debtorType := _invLineDesc.bank.getDebtorTypeFromMapTrans( _invLineDesc, tmpConsigneeOr, self ); // PAR 17557
					if debtorType = null then // no charge mappings so carry on
						debtor := tmpConsigneeOr.debtor;
						if doLog and debtor &lt;&gt; null then
							app.invLog(lMessageText &amp; " " &amp; debtor.name, LogINFO.String);
						endif;
					else
						debtor := _invLineDesc.getDebtorFromTypeTransaction(debtorType, self);
					endif;
				endif;
			endif;
	
		elseif myDebtorTypeCode = CM_DebtorType.DT_CONSIGNOR then
			lMessageText := "Debtor for Consignor Charge";
			tmpCode := self.consignor;
			if tmpCode &lt;&gt; null then
				tmpConsigneeOr := app.myRoot.allConsigneeConsignors[tmpCode];
				if tmpConsigneeOr &lt;&gt; null then
					// ### Check for any mappings
					debtorType := _invLineDesc.bank.getDebtorTypeFromMapTrans( _invLineDesc, tmpConsigneeOr, self ); // PAR 17557
					if debtorType = null then // no charge mappings so carry on
						debtor := tmpConsigneeOr.debtor;
						if doLog and debtor &lt;&gt; null then
							app.invLog(lMessageText &amp; " " &amp; debtor.name, LogINFO.String);
						endif;
					else
						debtor := _invLineDesc.getDebtorFromTypeTransaction(debtorType, self);
					endif;
				endif;
			endif;
			
		elseif myDebtorTypeCode = CM_DebtorType.DT_SHIP_OPERATOR then
			lMessageText := "Debtor for Ship Operator Charge";
			tmpVoyage := self.getVoyage();
			if tmpVoyage &lt;&gt; null then // AKB October 2001 - PAR 1518.
				tmpOperator := tmpVoyage.myOperator;
				if tmpOperator &lt;&gt; null then // AKB October 2001 - PAR 1518.
					// ### Check for any mappings
					debtorType := _invLineDesc.bank.getDebtorTypeFromMapTrans( _invLineDesc, tmpOperator, self ); // PAR 17557
					if debtorType = null then // no charge mappings so carry on
						debtor := tmpOperator.debtor;
						if doLog and debtor &lt;&gt; null then
							app.invLog(lMessageText &amp; " " &amp; debtor.name, LogINFO.String);
						endif;
					else
						debtor := _invLineDesc.getDebtorFromTypeTransaction(debtorType, self);
					endif;
				endif;
			endif;
		elseif myDebtorTypeCode = CM_DebtorType.DT_BUSINESS_UNIT then
			lMessageText := "Debtor for Business Unit Charge";
			chargeableBusinessUnit := self.getChargeableBusinessUnit;
			if chargeableBusinessUnit &lt;&gt; null then
				// ### Check for any mappings
				debtorType := _invLineDesc.bank.getDebtorTypeFromMapTrans( _invLineDesc, tmpOperator, self ); // PAR 17557
				if debtorType = null then // no charge mappings so carry on
					debtor := chargeableBusinessUnit.businessUnitDebtor;
					if doLog and debtor &lt;&gt; null then
						app.invLog(lMessageText &amp; " " &amp; debtor.name, LogINFO.String);
					endif;
				else
					debtor := _invLineDesc.getDebtorFromTypeTransaction(debtorType, self);
				endif;
			endif;
	
		elseif myDebtorTypeCode = CM_DebtorType.DT_FREIGHT_FORWARDER then
			lMessageText := "Debtor for Freight Forwarder Charge";
			// PAR 16898 - RJS June 2008 - now that self has the
			// FF we can get from there
			tmpCode := self.freightForwarderCode;
			if tmpCode &lt;&gt; null then
				tmpConsigneeOr := app.myRoot.allConsigneeConsignors[tmpCode];
				if tmpConsigneeOr &lt;&gt; null then
					// ### Check for any mappings
					debtorType := _invLineDesc.bank.getDebtorTypeFromMapTrans( _invLineDesc, tmpConsigneeOr, self ); // PAR 17557
					if debtorType = null then // no charge mappings so carry on
						debtor := tmpConsigneeOr.debtor;
						if doLog and debtor &lt;&gt; null then
							app.invLog(lMessageText &amp; " " &amp; debtor.name, LogINFO.String);
						endif;
					else
						debtor := _invLineDesc.getDebtorFromTypeTransaction(debtorType, self);
					endif;
				endif;
			endif;
		elseif myDebtorTypeCode = CM_DebtorType.DT_CUSTOMS_AGENT then
			lMessageText := "Debtor for Customs Agent Charge";
			tmpCode := self.customsAgentCode;
			if tmpCode &lt;&gt; null then
				tmpCA := app.myRoot.allCustomsAgents[tmpCode];
				if tmpCA &lt;&gt; null then
					// ### Check for any mappings
					debtorType := _invLineDesc.bank.getDebtorTypeFromMapTrans( _invLineDesc, tmpCA, self ); // PAR 17557
					if debtorType = null then // no charge mappings so carry on
						debtor := tmpCA.myDebtor;
						if doLog and debtor &lt;&gt; null then
							app.invLog(lMessageText &amp; " " &amp; debtor.name, LogINFO.String);
						endif;
					else
						debtor := _invLineDesc.getDebtorFromTypeTransaction(debtorType, self);
					endif;
				endif;
			endif;
			// 24094 add carrier
		elseif myDebtorTypeCode = CM_DebtorType.DT_CARRIER then
			lMessageText := "Debtor for Carrier Charge";
			if self.myTrackedItem &lt;&gt; null then
				tmpCode := self.myTrackedItem.carrier;
				if tmpCode &lt;&gt; null then
					tmpCarrier := app.myRoot.allCarriers[tmpCode];
					if tmpCarrier &lt;&gt; null then
						// ### Check for any mappings
						debtorType := _invLineDesc.bank.getDebtorTypeFromMapTrans( _invLineDesc, tmpCarrier, self );
						if debtorType = null then // no charge mappings so carry on
							debtor := tmpCarrier.myDebtor;
							if doLog and debtor &lt;&gt; null then
								app.invLog(lMessageText &amp; " " &amp; debtor.name, LogINFO.String);
							endif;
						else
							debtor := _invLineDesc.getDebtorFromTypeTransaction(debtorType, self);
						endif;
					endif;
				endif;
			endif;
			
		elseif myDebtorTypeCode = CM_DebtorType.DT_EMPTY_POOL_PARTY then						// TFS 3042
			lMessageText := "Debtor for Empty Pool Party";										// TFS 3042
			if self.myTrackedItem &lt;&gt; null then											// TFS 3042
				tmpCode := self.myTrackedItem.myPoolingPartyCode;						// TFS 3042
				if tmpCode &lt;&gt; null then															// TFS 3042
					tmpPoolParty := self.myTrackedItem.myTerminal.allMTPoolingParties[tmpCode];	// TFS 3042
					if tmpPoolParty &lt;&gt; null then												// TFS 3042
						tmpCode := self.myTrackedItem.operatorCode;						// TFS 3042
						foreach opTerm in tmpPoolParty.allOperatorTerminals do					// TFS 3042
							if opTerm.myTerminal &lt;&gt; self.myTrackedItem.myTerminal or opTerm.myOperator.code &lt;&gt; tmpCode then	// TFS 3042
								continue;														// TFS 3042
							endif;																// TFS 3042
							if opTerm.myOperator.debtor &lt;&gt; null then							// TFS 3042
								if not opTerm.myOperator.debtor.isRDT then						// TFS 3042
									debtor := opTerm.myOperator.debtor;							// TFS 3042
								endif;															// TFS 3042
							endif;																// TFS 3042
						endforeach;																// TFS 3042
					endif;																		// TFS 3042
				endif;																			// TFS 3042
			endif;																				// TFS 3042
			if debtor = null then																// TFS 3042
				debtorType := app.myRoot.allDebtorTypes[CM_DebtorType.DT_EMPTY_POOL_PARTY];		// TFS 3042
				debtor := _invLineDesc.getDebtorFromTypeTransaction(debtorType, self);			// TFS 3042
			endif;																				// TFS 3042
		
		// TFS 44554 Stevedore
		elseif myDebtorTypeCode = CM_DebtorType.DT_STEVEDORE_VOYAGE then          //04.11.2020 cnwma1 TFS #50112
			lMessageText := "Debtor for Stevedore for Voyage Charge";                 //04.11.2020 cnwma1 TFS #50112
		//	tmpCode := self.stevedoreCode;
		//	if tmpCode &lt;&gt; null then
		//		tmpStevedore := app.myRoot.allStevedores[tmpCode];
				tmpStevedore := self.myTrackedItem.getStevedore;	//16 Mar 2021	TFS 50866 - As per Bishs comments on TFS 15 Mar
				if tmpStevedore &lt;&gt; null then
					// ### Check for any mappings
					debtorType := _invLineDesc.bank.getDebtorTypeFromMapTrans( _invLineDesc, tmpStevedore, self );
					if debtorType = null then // no charge mappings so carry on
						debtor := tmpStevedore.myDebtor;
						if doLog and debtor &lt;&gt; null then
							app.invLog(lMessageText &amp; " " &amp; debtor.name, LogINFO.String);
						endif;
					else
						debtor := _invLineDesc.getDebtorFromTypeTransaction(debtorType, self);
					endif;
				endif;
		//	endif;
		// TFS 44554 end
		elseif myDebtorTypeCode = CM_DebtorType.DT_STEVEDORE_RECEIVE then   //04.11.2020 cnwma1 TFS #50112
			lMessageText := "Debtor for Stevedore for Receive Charge";
			tmpCode := self.stevedoreCode;
			if tmpCode &lt;&gt; null then
				tmpStevedore := app.myRoot.allStevedores[tmpCode];
				if tmpStevedore &lt;&gt; null then
					// ### Check for any mappings
					debtorType := _invLineDesc.bank.getDebtorTypeFromMapTrans( _invLineDesc, tmpStevedore, self );
					if debtorType = null then // no charge mappings so carry on
						debtor := tmpStevedore.myDebtor;
						if doLog and debtor &lt;&gt; null then
							app.invLog(lMessageText &amp; " " &amp; debtor.name, LogINFO.String);
						endif;
					else
						debtor := _invLineDesc.getDebtorFromTypeTransaction(debtorType, self);
					endif;
				endif;
			endif;
		elseif myDebtorTypeCode = CM_DebtorType.DT_STEVEDORE_RELEASE then   //04.11.2020 cnwma1 TFS #50112
			lMessageText := "Debtor for Stevedore for Release Charge";
			tmpCode := self.stevedoreCode;
			if tmpCode &lt;&gt; null then
				tmpStevedore := app.myRoot.allStevedores[tmpCode];
				if tmpStevedore &lt;&gt; null then
					// ### Check for any mappings
					debtorType := _invLineDesc.bank.getDebtorTypeFromMapTrans( _invLineDesc, tmpStevedore, self );
					if debtorType = null then // no charge mappings so carry on
						debtor := tmpStevedore.myDebtor;
						if doLog and debtor &lt;&gt; null then
							app.invLog(lMessageText &amp; " " &amp; debtor.name, LogINFO.String);
						endif;
					else
						debtor := _invLineDesc.getDebtorFromTypeTransaction(debtorType, self);
					endif;
				endif;
			endif;
		// 01.06.2022 navak20 TFS 53195 Start
		elseif myDebtorTypeCode = CM_DebtorType.DT_SHIPPING_LINE    
		or myDebtorTypeCode = CM_DebtorType.DT_SHIPPING_LINE_DESC then   
			lMessageText := "Debtor for Shipping Line";
			/* // ### TFS BUG 56663 23FEB2023 NAVAB1
			tmpCode := self.shippingLineCode;
			if tmpCode &lt;&gt; null then
				tmpShipLine := app.myRoot.allShippingLines[tmpCode];
				if tmpShipLine &lt;&gt; null then
					// ### Check for any mappings
					debtorType := _invLineDesc.bank.getDebtorTypeFromMapTrans( _invLineDesc, tmpShipLine, self );
					if debtorType = null then // no charge mappings so carry on
						debtor := tmpShipLine.myDebtor;
						if doLog and debtor &lt;&gt; null then
							app.invLog(lMessageText &amp; " " &amp; debtor.name);
						endif;
					else
						debtor := _invLineDesc.getDebtorFromTypeTransaction(debtorType, self);
					endif;
				endif;
			endif;
			*/
			tmpShipLine := self.getShippingLineObject();
			if tmpShipLine &lt;&gt; null then
				// ### Check for any mappings
				debtorType := _invLineDesc.bank.getDebtorTypeFromMapTrans( _invLineDesc, tmpShipLine, self );
				if debtorType = null then // no charge mappings so carry on
					debtor := tmpShipLine.myDebtor;
					if doLog and debtor &lt;&gt; null then
						app.invLog(lMessageText &amp; " " &amp; debtor.name, LogINFO.String);
					endif;
				else
					debtor := _invLineDesc.getDebtorFromTypeTransaction(debtorType, self);
				endif;
			endif;
		/*
		elseif myDebtorTypeCode = CM_DebtorType.DT_SHIPPING_LINE_DESC then   
			lMessageText := "Debtor for Shipping Line Description";
			tmpCode := self.shippingLineCode;
			if tmpCode &lt;&gt; null then
				tmpShipLine := app.myRoot.allShippingLines[tmpCode];
				if tmpShipLine &lt;&gt; null then
					// ### Check for any mappings
					debtorType := _invLineDesc.bank.getDebtorTypeFromMapTrans( _invLineDesc, tmpShipLine, self );
					if debtorType = null then // no charge mappings so carry on
						debtor := tmpShipLine.myDebtor;
						if doLog and debtor &lt;&gt; null then
							app.invLog(lMessageText &amp; " " &amp; debtor.name);
						endif;
					else
						debtor := _invLineDesc.getDebtorFromTypeTransaction(debtorType, self);
					endif;
				endif;
			endif;
			*/
		// TFS 53195 End
		else
			debtorType := deriveDebtorTypeFrom;
			
			//User defined debtor type
			lMessageText := "Debtor for" &amp; debtorType.description;
			debtor := self.allDebtorsByType[myDebtorTypeCode];
			if debtor &lt;&gt; null then
				debtorType := _invLineDesc.bank.getDebtorTypeFromMapTrans( _invLineDesc, debtor, self ); // PAR 17557
				if debtorType &lt;&gt; null then // no charge mappings so carry on
					debtor := _invLineDesc.getDebtorFromTypeTransaction(debtorType, self);
				endif;
			else
				debtor := debtorType.myDefaultDebtor;	// 19/01/2012 cnwar2 #28973
			endif;
		endif;
	
	endif;
	
	if debtor &lt;&gt; null then
		if debtor.isSuspended then
			if doLog and debtor &lt;&gt; null then
				app.invLog(debtor.name &amp; " is suspended, not used", LogINFO.String);
			endif;
			debtor := null;
		endif;
	endif;
	
	if debtor = null then	
		debtor := _invLineDesc.getDefaultDebtorFromTran(doLog,self);
	endif;

	return debtor;
	
end;</source>
        <Parameter name="_invLineDesc" type="CM_InvoiceLineDesc"/>
        <ReturnType type="CM_Debtor"/>
    </JadeMethod>
    <JadeMethod name="getDebtorForSearch" id="6aee7f88-cde4-48f0-bd4e-8dac25972d54">
        <source>getDebtorForSearch():CM_Debtor;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 October 2015	cnwndl1	Initial creation	Par 36694

*/

vars

	iter : Iterator;
	invLine : CM_InvoiceLine;

begin

	iter := self.allInvoiceLines.createIterator;
	while iter.next( invLine ) do
		if invLine.debtor &lt;&gt; null then
			return invLine.debtor;
		endif;
	endwhile;
	
	return null;

epilog

	delete iter;

end;</source>
        <ReturnType type="CM_Debtor"/>
    </JadeMethod>
    <JadeMethod name="getDebtorName" id="54480128-abcb-48aa-974c-98f65f95866c">
        <source>getDebtorName():String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 October 2015	cnwndl1	Initial creation

*/

vars

	debtor : CM_Debtor;
	
begin

	debtor := self.getDebtorForSearch();
	if debtor &lt;&gt; null then
		return debtor.name;
	endif;
	
	return null;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDefaultMeasureTotalVolume" id="f48175f7-1be4-443c-9cfe-392149276cac">
        <source>getDefaultMeasureTotalVolume():String;
/*

Purpose:			returns the TI totalVolume converted to the system default unit for volume measures

Parameters:			

Return Value:		

Date		Who		Reason
18 February 2020	jlgndl1	Initial creation	TFS 48263

*/

vars
	measureType : CM_MeasurementType;

begin
	measureType := app.getDefaultMeasurementForType(Type_Volume);
	if measureType = null then
		return self.totalVolume.asStringJMT;
	endif;
	return app.convertMeasurementForDisplay(measureType.shortName, self.totalVolume);
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDefaultMeasureTotalWeight" id="9beec35a-13f6-47a2-b8bc-7b439c93901b">
        <source>getDefaultMeasureTotalWeight():String;
/*

Purpose:			returns the TI totalWeight converted to the system default unit for weight measures

Parameters:			

Return Value:		

Date		Who		Reason
18 February 2020	jlgndl1	Initial creation	TFS 48623

*/

vars
	measureType : CM_MeasurementType;

begin
	measureType := app.getDefaultMeasurementForType(Type_Weight);
	if measureType = null then
		return self.totalWeight.asStringWeightJMT;
	endif;
	return app.convertMeasurementForDisplay(measureType.shortName, self.totalWeight);
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDeletedDetails" id="3063763f-22e1-49b3-b94a-9e104169e1ea">
        <source>getDeletedDetails(): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25 October 2018	jlgmp6	Initial creation	TFS41191

*/

vars
	detail: String;

begin
	detail := app.getErrorString(Transaction_deleted) &amp; Space &amp; self.deletedByUser &amp; Period &amp; Space &amp; Space;

	if self.deletedReason = null then
		detail := detail &amp; app.getErrorString(No_reason_given);
	else
		detail := detail &amp; app.getErrorString(Reason_given) &amp; Space &amp; self.deletedReason;
	endif;

	return detail;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDeliveryRelease" id="8325f027-4128-46a9-9555-e3a56dcf9fa0">
