    <JadeMethod name="setIsAvailableForEntry" id="89954d24-0d9a-4371-8e00-61d2debd2f06">
        <updating/>
        <source>setIsAvailableForEntry(_value : Boolean) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 18/12/2013	cnwdap1		Initial creation PAR #32849 CCMS PEN 2321 Security Gate
//
vars

begin
	if self.isAvailableForEntry &lt;&gt; _value then
		self.isAvailableForEntry := _value;
	endif;
epilog

end;</source>
        <Parameter name="_value" type="Boolean"/>
    </JadeMethod>
