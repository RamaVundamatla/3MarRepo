    <JadeMethod name="delete" id="7af34757-7e95-4f1b-89cc-d7dcede02a02">
        <updating/>
        <source>delete() updating;
// ---------------------------------------------------------------------------
// Created:     20 April 2010 by cnwcs5
// Purpose:     
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 20/04/2010	cnwcs5		par 23859 - stop kiosk being deleted if it is in use at a gate lane
// ---------------------------------------------------------------------------
vars

begin
	if not self.allLaneDevices.isEmpty then
		app.raiseUnexpectedProgramError (self.class.name, method.name, 'Kiosk is in use so cannot be deleted');
	endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="findGate" id="fa1842d7-3168-4fd6-aa51-07b1f25a75ef">
        <source>findGate():CM_Gate;
/*
Date		Who		Reason
05 September 2011	cnwcs5	Initial creation - CCMS MES 1033 / par 27951 RORO KPI
*/
vars
	ld		:CM_LDKiosk;
	lane	:CM_LaneController;
	area	:CM_GridArea;
	gate	:CM_Gate;
begin
	ld := self.allLaneDevices.first.CM_LDKiosk;
	
	if ld = null then
		return null;
	endif;
	
	lane := ld.myLaneController;
	
	if lane = null then
		return null;
	endif;
	
	area := lane.getMyGridArea;
	
	// we expect the kisok to only be associated with a gate area, not an interchange area
	if area &lt;&gt; null and area.isGateArea then
		// a kiosk is only associated with an a-gate not a p-gate
		// p-gates can belong to more than one gate but an a-gate belongs to one gate.
		gate := area.CM_GateArea.getFirstEntryGate;
	endif;
	
	return gate;
epilog

end;</source>
        <ReturnType type="CM_Gate"/>
    </JadeMethod>
    <JadeMethod name="getAdditionalQuestionByCode" id="78bcf167-4049-4fd1-9b4c-cdb02a47a1ed">
        <source>getAdditionalQuestionByCode(_code : String) : CM_KioskAdditionalQuestion;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 September 2023	jlier1	Initial creation 59732

*/

vars
	addtionalQuestion : CM_KioskAdditionalQuestion;
begin
	
	foreach addtionalQuestion in self.allAdditionalQuestions discreteLock do
		if addtionalQuestion.code.toUpper = _code.toUpper then
			return addtionalQuestion;
		endif;	
	endforeach;

	return null;

epilog

end;</source>
        <Parameter name="_code" type="String"/>
        <ReturnType type="CM_KioskAdditionalQuestion"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="e18b8aa2-3b90-4f1e-9b82-7616c3c7dd82">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 August 2023	jlier1	Initial creation 59547

*/

vars

begin
	if _attrName = ETRow_PrimaryLocale then
		if self.myPrimaryLocale &lt;&gt; null then
			return self.myPrimaryLocale.vLocaleIdAndDescription;
		endif;
		
		return null;
	elseif _attrName = ETRow_MaxPassengersAllowed then
		return self.maxAllowedPassengers.asStringJMT;
	elseif _attrName = ETRow_AllowEditTransport then
		return self.allowEditTransitDetails.asStringJMT;
	else
		return inheritMethod(_attrName, _short);
	endif;
	
epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getPPEQuestionByCode" id="1a245c0c-c2b5-4ff8-b071-7f05c598c3bf">
        <source>getPPEQuestionByCode(_code : String) : CM_KioskPPEQuestion;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 August 2023	jlier1	Initial creation 59732

*/

vars
	ppeQuestion : CM_KioskPPEQuestion;
begin
	
	foreach ppeQuestion in self.allPPEQuestions discreteLock do
		if ppeQuestion.code.toUpper = _code.toUpper then
			return ppeQuestion;
		endif;	
	endforeach;

	return null;
epilog

end;</source>
        <Parameter name="_code" type="String"/>
        <ReturnType type="CM_KioskPPEQuestion"/>
    </JadeMethod>
    <JadeMethod name="printKioskErrors" id="4e3ff291-c342-4852-9819-2a6fe6934bed">
        <source>printKioskErrors(_printer : CM_PrinterDef; _errors: CM_ErrorsByTypeStatusDict input; _regNumber: String; _transportReferences : String );
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason 
11 September 2023	jlier1	Initial creation 59732
20 September 2023	jlizm1	59579 Kiosk error advice report
08 Oct 2024 		navsck1 MTN-19665 EUP |  Kiosk -save truck visit on final confirmation webservice
*/

vars
	jrwManager		: JadeReportWriterManager;
	jrwReport		: JadeReportWriterReport;
	jadeReport		: JadeReport;
	jrwTransient	: CM_JRWVehicleVisit;
	termDict				: CM_TerminalByCodeDict;
	printerName,
	reportName 		: String;
	workFile				: File;
	binary				: Binary;
	file : File;
	findPrinterValue	: Integer;
	fileName : String;
begin
	reportName := self.myTerminal.getConfig(GateKioskErrorAdvice).String;

	if _printer = null then
		return;
	endif;
	
	if app.isDevelopmentSystem and _printer.printerIsPDF then
		if process.isUsingThinClient then
			fileName:="C:\Temp\KioskErrorAdvice_"  &amp; app.actualTimeServer.fileNameFormat &amp; "_" &amp; 
				self.getInstanceIdForObject64(process).String &amp; "_" &amp; 
				self.getInstanceIdForObject64(self).String &amp; ".pdf";
		else
			fileName:=node.getJadeHomeDirectory &amp; "\c_misc\web_report_temp\KioskErrorAdvice_"  &amp; app.actualTimeServer.fileNameFormat &amp; "_" &amp; 
					self.getInstanceIdForObject64(process).String &amp; "_" &amp; 
					self.getInstanceIdForObject64(self).String &amp; ".pdf";
		endif;
	endif;
	app.writeLog(method.qualifiedName &amp; Tab &amp; fileName, LogERROR);
	
	
	printerName:=_printer.physicalPrinterName;
	
	jrwManager 	:= app.createReportWriterManager();
	jrwReport 	:= jrwManager.getReport(reportName);

	if jrwReport = null then
		app.msgBox(app.getErrorString (GTE_VehicleVisit_Msg3), app.getErrorString (GTE_VehicleVisit_Msg4), MsgBox_Exclamation_Mark_Icon);
		return;
	endif;
	
	jrwTransient := app.myQAFilter.createJRWTransient(CM_JRWVehicleVisit).CM_JRWVehicleVisit;
	
	if jrwTransient = null then
		app.raiseUnexpectedProgramError(CM_VehicleVisitRecord.name, method.name, 'Failed to create JRW transient singleton');
		return;
	endif;
	
	if _errors &lt;&gt; null then
		_errors.copy(jrwTransient.allErrorsAndWarnings);
	endif;
	create termDict transient;
	termDict.add(self.myTerminal);
	jrwTransient.setAllTerminals(termDict);
	/*if _vvr &lt;&gt; null then
		jrwTransient.allVehicleVisitRecords.add(_vvr);
	endif;*/
	jrwTransient.setGoToGateOfficeMessage();
	jrwTransient.transportReference:=_transportReferences;
	jrwTransient.regNumber := _regNumber;
	app.printer.abort();
	
	jrwReport.setOutputDestination(JadeReportWriterReport.PRINTER);	
	create jadeReport transient;
	jadeReport.copies:=1;
	jadeReport.description := jrwReport.name;
	
	findPrinterValue :=app.printer.setPrinter(printerName);
	if findPrinterValue &lt;&gt; 0 then
		app.writeLog(method.qualifiedName &amp; Tab &amp; printerName &amp;  " unable to find printer", LogINFO);
			return;
	endif;
	
	app.printer.printPreview := false;
	app.printer.suppressDialog := true;
	if fileName &lt;&gt; null then
		app.printer.setReport(jadeReport);
	endif;
	jrwReport.run();
			
	
	app.writeLog(method.qualifiedName &amp; Tab &amp; printerName, LogINFO);

	if fileName &lt;&gt; null then
		create file transient;
		file.mode := File.Mode_Output;
		file.fileName := fileName;		
		app.printer.setPrintFileName(fileName);
		app.printer.printReport(jadeReport);
	endif;
	
	
	

epilog
	app.printer.abort();	
	abortTransaction;		// to clear any locks held by the report writer
	delete jrwReport;
	delete jrwTransient;
	delete jrwManager;
	delete termDict;
	delete workFile;
	delete file;
end;</source>
        <Parameter name="_printer" type="CM_PrinterDef"/>
        <Parameter name="_errors" type="CM_ErrorsByTypeStatusDict" usage="input"/>
        <Parameter name="_regNumber" type="String"/>
        <Parameter name="_transportReferences" type="String"/>
    </JadeMethod>
    <JadeMethod name="printKioskErrorsFromPPErrors" id="cda55fac-b025-4a90-a649-8ce9d6793f24">
        <source>printKioskErrorsFromPPErrors(_printer : CM_PrinterDef;_regNumber : String; _transportReferences : String);
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
13 September 2023	jlier1	Initial creation 59732
08 Oct 2024 		navsck1 MTN-19665 EUP |  Kiosk -save truck visit on final confirmation webservice

*/

vars
	error : CM_Error;
	persistentError : CM_ErrorPersistent;
	allPrintErrors :  CM_ErrorsByTypeStatusDict;

begin
	if _printer = null then
		return;
	endif;
	
	if app.myPassport.allErrors.isEmpty then
		return;
	endif;
	if self.myPrimaryLocale = null then
		return;
	endif;
	
	create allPrintErrors transient;

	
	foreach error in app.myPassport.allErrors discreteLock do	
					
		create persistentError transient;
		persistentError.setTextValues(error.secondaryText, error.getDetailsAsStringNoCode);
		allPrintErrors.add(persistentError);
	endforeach;
	
	
	self.printKioskErrors(_printer,allPrintErrors,_regNumber,_transportReferences);
	
epilog
	if allPrintErrors &lt;&gt; null then
		allPrintErrors.purge;
	endif;
	delete allPrintErrors;
end;</source>
        <Parameter name="_printer" type="CM_PrinterDef"/>
        <Parameter name="_regNumber" type="String"/>
        <Parameter name="_transportReferences" type="String"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="e8d5608b-37e0-4167-9cc5-14586fccc0d8">
        <source>pxyCreateUpdateProxy(): SelfType;

/*
Date			Who		Reason
06 July 2009	cnwar2	Initial creation
20/04/2011		cnwmh5	PAR #27401 - Add code to handle prossible exceptions occurring when
						trying to create the proxy

*/
vars
	proxy			: SelfType;
	completedOK		: Boolean;
	proxyPPE,
	ppeQuestion 	: CM_KioskPPEQuestion;
	proxyAdditional,
	addtionalQuestion : CM_KioskAdditionalQuestion;
begin
	proxy :=  inheritMethod();
	proxy.myTerminal := self.myTerminal;
	//jlier1 TFS 58511 3/8/22
	proxy.myPrimaryLocale:=self.myPrimaryLocale;
	self.allLocales.copy(proxy.allLocales);
	
	if self.myTermsAndConditions &lt;&gt; null then
		proxy.myTermsAndConditions:=self.myTermsAndConditions.pxyCreateUpdateProxy;
	endif;
	
	foreach  ppeQuestion in self.allPPEQuestions discreteLock do
		proxyPPE := ppeQuestion.pxyCreateUpdateProxy(); 
		proxy.allPPEQuestions.add(proxyPPE);
	endforeach;
	
	foreach  addtionalQuestion in self.allAdditionalQuestions discreteLock do
		proxyAdditional := addtionalQuestion.pxyCreateUpdateProxy(); 
		proxy.allAdditionalQuestions.add(proxyAdditional);
	endforeach;
	
	
	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return proxy;
	
epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete proxy;
	endif;	
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="4f2f2194-607d-40f1-ae1a-da2a39ea7e96">
        <updating/>
        <source>setForCreate(_proxy : CM_Kiosk) updating;

/*
Date			Who		Reason
06 July 2009	cnwar2	Initial creation

*/
vars

begin
	self.myTerminal	:= _proxy.myTerminal;
	
	self.setForUpdate(_proxy);
end;</source>
        <Parameter name="_proxy" type="CM_Kiosk"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="c634ced8-2aa9-4a07-83ce-ab0768d93ed0">
        <updating/>
        <source>setForUpdate(_proxy : CM_Kiosk) updating;

/*
Date			Who		Reason
06 July 2009	cnwar2	Initial creation

*/
vars
	realTandCs : CM_KioskTermsAndConditions;
	pxyPPE, 
	realPPE   : CM_KioskPPEQuestion;
	ppeToDelete : ObjectSet;
	pxyAdditional, 
	realAdditional   : CM_KioskAdditionalQuestion;
	additionalToDelete : ObjectSet;
begin
	if self.myTerminal = null then
		app.raiseUnexpectedProgramError (self.class.name, method.name, 'Terminal is required');
	endif;
	
	self.code 		 := _proxy.code;
	self.description := _proxy.description;
	self.machineName := _proxy.machineName;
	
		//jlier1 TFS 58511
	self.allowEditTransitDetails:=_proxy.allowEditTransitDetails;
	self.maxAllowedPassengers:=_proxy.maxAllowedPassengers;
	self.myPrimaryLocale:=_proxy.myPrimaryLocale;
	self.noPassengersEnabled:=_proxy.noPassengersEnabled;
	self.securityEmailAddresses:=_proxy.securityEmailAddresses;
	self.trailerTypeEnabled:=_proxy.trailerTypeEnabled;
	
	self.allLocales.clear();											
	_proxy.allLocales.copy(self.allLocales);
	
	if _proxy.myTermsAndConditions &lt;&gt; null then
		realTandCs:=_proxy.myTermsAndConditions.pxyGetRealObject;
		if realTandCs  = null then
			create self.myTermsAndConditions persistent;
		endif;
		self.myTermsAndConditions.setForUpdate(_proxy.myTermsAndConditions);
	else
		if self.myTermsAndConditions &lt;&gt; null then
			delete self.myTermsAndConditions;
		endif;
	endif;
	
	create ppeToDelete transient;
	self.allPPEQuestions.copy(ppeToDelete);
	
	foreach pxyPPE in _proxy.allPPEQuestions discreteLock do 
		realPPE := pxyPPE.pxyGetRealObject.CM_KioskPPEQuestion;
		if realPPE = null then
			create realPPE persistent;
			realPPE.setForCreate(pxyPPE.CM_KioskPPEQuestion);
			self.allPPEQuestions.add(realPPE);
		else
			realPPE.setForUpdate(pxyPPE.CM_KioskPPEQuestion);
			ppeToDelete.remove(realPPE);
		endif;
	endforeach;
	
	ppeToDelete.purge;
	
	
	create additionalToDelete transient;
	self.allAdditionalQuestions.copy(additionalToDelete);
	
	foreach pxyAdditional in _proxy.allAdditionalQuestions discreteLock do 
		realAdditional := pxyAdditional.pxyGetRealObject.CM_KioskAdditionalQuestion;
		if realAdditional = null then
			create realAdditional persistent;
			realAdditional.setForCreate(pxyAdditional.CM_KioskAdditionalQuestion);
			self.allAdditionalQuestions.add(realAdditional);
		else
			realAdditional.setForUpdate(pxyAdditional.CM_KioskAdditionalQuestion);
			additionalToDelete.remove(realAdditional);
		endif;
	endforeach;
	
	additionalToDelete.purge;
	
epilog
	delete ppeToDelete;
	delete additionalToDelete;
end;</source>
        <Parameter name="_proxy" type="CM_Kiosk"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="deb76342-887c-4735-beb3-1411e90b004f">
        <updating/>
        <source>setProxy(_code : String;
			_description : String; 
			_machineName : String; 
			_terminal : CM_Terminal;
			_primaryLocale : CM_Locale;
			_allLocales : CM_LocaleArray;
			_noPassengersEnabled : Boolean;
			_maxAllowedPassengers : Integer;
			_securityEmailAddresses : String;
			_allowEditTransportDetails : Boolean;
			_trailerTypeEnabled : Boolean) updating;

/*
Date			Who		Reason
06 July 2009	cnwar2	Initial creation

*/
vars

begin
	self.raiseExceptionIfNotTransient(method);
	
	self.code			:= _code;
	self.description	:= _description;
	self.machineName	:= _machineName;
	self.myTerminal		:= _terminal;
	//jlier1 TFS 58511 3/87/23
	self.myPrimaryLocale:=_primaryLocale;
	self.allLocales.clear;
	if _allLocales &lt;&gt; null then
		_allLocales.copy(self.allLocales);
	endif;
	
	self.noPassengersEnabled:=_noPassengersEnabled;
	self.maxAllowedPassengers:=_maxAllowedPassengers;
	self.securityEmailAddresses:=_securityEmailAddresses;
	self.allowEditTransitDetails:=_allowEditTransportDetails;
	self.trailerTypeEnabled:=_trailerTypeEnabled;
end;</source>
        <Parameter name="_code" type="String"/>
        <Parameter name="_description" type="String"/>
        <Parameter name="_machineName" type="String"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_primaryLocale" type="CM_Locale"/>
        <Parameter name="_allLocales" type="CM_LocaleArray"/>
        <Parameter name="_noPassengersEnabled" type="Boolean"/>
        <Parameter name="_maxAllowedPassengers" type="Integer"/>
        <Parameter name="_securityEmailAddresses" type="String"/>
        <Parameter name="_allowEditTransportDetails" type="Boolean"/>
        <Parameter name="_trailerTypeEnabled" type="Boolean"/>
    </JadeMethod>
