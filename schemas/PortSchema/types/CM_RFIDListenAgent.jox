<Class name="CM_RFIDListenAgent" id="f00ca37b-f19a-4969-8313-c769663e956c">
    <superclass name="CM_TcpIpClientAgent"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="cmtrans"/>
    <ImplicitInverseRef name="allConnections" id="887a0819-6edf-48b6-9299-1b3bdf28da56">
        <memberTypeInverse/>
        <type name="CM_TcpRFIDConnectionDict"/>
        <access>readonly</access>
    </ImplicitInverseRef>
    <JadeMethod name="finish" id="07594dad-46b1-4ee8-9b7f-bf1721840537">
        <updating/>
        <source>finish() updating;
/*
----------   ----------  --------------------------------------------------
Created:	31 August 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	rfidConnection			: CM_TcpRFIDConnection;
begin
	foreach rfidConnection in self.allConnections do
		self.finishConnection(rfidConnection);
	endforeach;
	
	self.allConnections.purge();
	delete self;

end;


</source>
    </JadeMethod>
    <JadeMethod name="finishConnection" id="502ae030-f076-4ca2-bb2c-252a7877fad3">
        <source>finishConnection(_rfidConnection : CM_TcpRFIDConnection input);
/*
----------   ----------  --------------------------------------------------
Created:	31 August 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars

begin
	app.writeLog('Closing connection - IP: ' &amp; _rfidConnection.name &amp; ', Port: ' &amp; _rfidConnection.port.String, LogINFO);
	_rfidConnection.close();
	
end;


</source>
        <Parameter name="_rfidConnection" type="CM_TcpRFIDConnection" usage="input"/>
    </JadeMethod>
    <JadeMethod name="initialize" id="cb112a4f-cf82-4046-a3c2-0833a5b78c66">
        <updating/>
        <source>initialize(_controller : BGP_RFIDListenController) updating;
/*
----------   ----------  --------------------------------------------------
Created:	31 August 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	tagReader			: CM_RFIDTagReader;
begin
	foreach tagReader in _controller.allRFIDTagReaders do
		self.openConnection(tagReader);
	endforeach;

end;


</source>
        <Parameter name="_controller" type="BGP_RFIDListenController"/>
    </JadeMethod>
    <JadeMethod name="openConnection" id="7a58abce-fa18-4e22-af20-2a7b468ff221">
        <source>openConnection(_tagReader : CM_RFIDTagReader);
/*
----------   ----------  --------------------------------------------------
Created:	31 August 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	connection		: CM_TcpRFIDConnection;
begin
	create connection transient;
	connection.init(_tagReader);
	self.allConnections.add(connection);

	
end;


</source>
        <Parameter name="_tagReader" type="CM_RFIDTagReader"/>
    </JadeMethod>
</Class>
