    <JadeMethod name="tblData_dblClick" id="e14d946b-f457-4cee-abc4-19a18c6e4582">
        <controlMethod name="CM_DataTable::dblClick"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblData_dblClick(table: Table input) updating;
/*
Purpose:			

Date		Who		Reason
08AUG2023	NAVAB1	 CR 56094 TASK 59618
*/

vars

begin

	if table.row &gt; table.fixedRows then
		self.dobtnUpdate();
		return;
	endif;

	if table.sortColumn[1] &gt; 0 then
		table.accessCell(1,table.sortColumn[1]).fontBold := false;
	endif;

	table.CM_DataTable.resortTableByColumn(table.column);

	table.accessCell(1,table.column).fontBold := true;
epilog

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="tblDisplayRow" id="fc69ffb5-31e6-4c9d-af0a-0eebb706d82f">
        <source>tblDisplayRow();
/*
Purpose:			

Date		Who		Reason
08AUG2023	NAVAB1	 CR 56094 TASK 59618
*/

vars
	tbl					: CM_DataTable;
	idx					: Integer;
	str 				: String;
	custDoc : CM_CustomDocument;
	theDataLine : String;
begin
	tbl := self.tblData;
	tbl.rows := tbl.fixedRows;
	foreach custDoc in self.myTerminal.allCustomDocuments do
		str := custDoc.getAttributeStringForDefArray(tbl.allTblDataEntRows);
		idx := tbl.addItem(str);
		tbl.accessRow(idx).itemObject := custDoc;
	endforeach;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="translateForm" id="b678652a-74ac-4fc0-a774-4363ade64191">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 29 February 2024 10:18:43.
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0026277, locale);
	btnAdd.translateCaption(Xlat_0026278, locale);
	btnApprove.translateCaption(Xlat_0026279, locale);
	btnAttachment.translateCaption(Xlat_0026280, locale);
	btnAudits.translateCaption(Xlat_0026281, locale);
	btnCancellation.translateCaption(Xlat_0026570, locale);
