    <JadeMethod name="comboBoxVoyageCellular" id="4e0357b1-63d1-4a00-b135-1be8784164cb">
        <source>comboBoxVoyageCellular(_combo : CMUI_ComboBox input);
/*

Date		Who		Reason
22 March 2017	cnwer1	Initial creation TFS 830

*/

vars
	aVoyage : CM_Voyage;
	idx : Integer;
	theVoyages : CM_VoyageSet;
begin
	
	_combo.clear;
	_combo.sorted := true;
	
	create theVoyages transient;
	self.myTerminal.getAllCurrentCellularVoyages(theVoyages, false, false);

	foreach aVoyage in theVoyages discreteLock do
		idx := _combo.addItem(aVoyage.code &amp; " - " &amp; aVoyage.description);
		_combo.itemObject[idx] := aVoyage;
	endforeach;

	//cnwjo3 par 23105
	aVoyage := app.getMyCurrentVoyage();

	if aVoyage &lt;&gt; null then
		idx := _combo.findObject(aVoyage);
		if idx &gt; 0 then
			_combo.listIndex := idx;
		endif;
		_combo.click(_combo);		
	endif;

epilog
	delete theVoyages;

end;</source>
        <Parameter name="_combo" type="CMUI_ComboBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="comboBoxVoyageCode" id="5701798d-d902-4ae2-a83f-ecc3bf45c900">
        <source>comboBoxVoyageCode(pCmb : ComboBox input; pVoyage : CM_Voyage; _includeArchived : Boolean; _includeCompleted : Boolean);
// ---------------------------------------------------------------------------
// Created:     18 December 2000 by cnwrs2
//
// Purpose:     Returns a voyage description to a combo - but no good if
//				you actually need the VOYAGE OBJECT in the combobox - see
//				self.comboboxVoyage
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//	11/6/01			AA		Display in and outbound voyage codes
//	29 Aug 2011	cnwjre1		CCMS 1120 Par 28082 Log voyage operations changes, don't show completed voyages, added param _includeCompleted
// NOTE: this method is re-implemented in LogSchema under Log_Assistant and all calls are actually to that method.
// ---------------------------------------------------------------------------
vars
	inCol		: Boolean;
begin

	// CALL THIS METHOD IF YOU WANT NON CARGO VOYAGES TO BE INCLUDED e.g. HMS voyages
	pCmb.clear();

	self.setAllVoyageCodes(false, _includeArchived);
	
	if pVoyage &lt;&gt; null then
		inCol := self.allVoyages.includes(pVoyage);
	endif;
	
	//AA 11/6: And link list box to the collection of keys
	if pCmb.isKindOf(CMUI_ComboForVoyageActive) then
		pCmb.CMUI_ComboForVoyageActive.init(self.allVoyages, self.myTerminal, _includeArchived);
	else
		pCmb.listCollection(self.allVoyageCodes, false, 0);
	endif;
	
	if pVoyage &lt;&gt; null and inCol then
		pCmb.text := self.displayEntryVoyage(pVoyage.displayEntry());
	endif;

end;</source>
        <Parameter name="pCmb" type="ComboBox" usage="input"/>
        <Parameter name="pVoyage" type="CM_Voyage"/>
        <Parameter name="_includeArchived" type="Boolean"/>
        <Parameter name="_includeCompleted" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="comboBoxVoyageCurrent" id="8f80f14a-f66d-461d-abdf-33897ebd5084">
        <updating/>
        <source>comboBoxVoyageCurrent(pCmb : ComboBox input;  
					_voyage : CM_Voyage; 
					_reset, 
					_includeArchived, 
					_includeDeparted, 
					_includeNonPlannedWorked, 
					_includeNullVoyage,
					_includeLogVoyage,
					_includeGCVoyage,
					_isCellularOnly,		// cnwdad1 14/10/2009 - PAR #20862 (new paramater).
					_excludeInward : Boolean) updating;
//********************************************************************
//
// Created by: cnwsh3
//
// Date: 28 October 2003
//
//********************************************************************

vars
	tmpVoyage : CM_Voyage;
	idx : Integer;
	str,
	code : String;
	failedDAC  :CM_DataAccessController;
	invalidVoyage : Boolean;
begin

	// DOES NOT INCLUDE NON CELLULAR VOYAGES e.g.Log and HMS voyages
		
	pCmb.clear();

	self.setCurrentVoyageCodes(_reset, _includeNonPlannedWorked, _includeArchived, _includeDeparted, _includeNullVoyage, _includeLogVoyage, _includeGCVoyage, _excludeInward);

	on Exception do app.handleDeletedObject(exception,_voyage,invalidVoyage);
	
	if _voyage &lt;&gt; null 
	and (not self.allVoyages.includes(_voyage)) 
	and _voyage.canUserAccessSelf(null, failedDAC, app.myPassport) then
		self.allVoyageCodes.add(_voyage.code);
		self.allVoyages.add(_voyage);
	endif;

	if pCmb.isKindOf(CMUI_ComboForVoyageActive) then
		pCmb.CMUI_ComboForVoyageActive.init(self.allVoyages, self.myTerminal, _includeArchived);
	else
		//if pCmb contains a note then listCollection will not allow you to remove an item
		//from that combobox hence a foreach loop as opposed to a listCollection	
		//cnwth2 - should be this:
		pCmb.addItem('');//Blank entry	
		foreach tmpVoyage in self.allVoyages do
// cnwdad1 14/10/2009 - PAR #20882.
			if _isCellularOnly and tmpVoyage.myCellularVoyageStructure = null then
				continue;
			endif;
			
			// PAR11740
			if pCmb.findObject(tmpVoyage) &gt; 0 then
				//Already add, use inward code instead
				str := tmpVoyage.inwardCode &amp; Tab &amp; tmpVoyage.description;
			else
				str := tmpVoyage.code &amp; Tab &amp; tmpVoyage.description;
			endif;
			if str &lt;&gt; null then
				pCmb.itemObject[pCmb.addItem(str)] := tmpVoyage;
			endif;
			
			/* WAS...			
			pCmb.itemObject[pCmb.addItem(tmpVoyage.displayEntry())] := tmpVoyage;
			*/	
		endforeach;
	endif;

	if _voyage &lt;&gt; null then
		idx := pCmb.findObject(_voyage);
		if idx &gt; -1 then
			pCmb.listIndex := idx;
		endif;
	endif;

end;</source>
        <Parameter name="pCmb" type="ComboBox" usage="input"/>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_reset" type="Boolean"/>
        <Parameter name="_includeArchived" type="Boolean"/>
        <Parameter name="_includeDeparted" type="Boolean"/>
        <Parameter name="_includeNonPlannedWorked" type="Boolean"/>
        <Parameter name="_includeNullVoyage" type="Boolean"/>
        <Parameter name="_includeLogVoyage" type="Boolean"/>
        <Parameter name="_includeGCVoyage" type="Boolean"/>
        <Parameter name="_isCellularOnly" type="Boolean"/>
        <Parameter name="_excludeInward" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="comboBoxVoyageGlobal" id="4e55941f-17e7-4b35-bf9d-46c7fa00d23d">
        <source>comboBoxVoyageGlobal(pCmb: ComboBox input;  
					_voyageCode: String;
					_vessel: CM_Vessel; 
					_includeArchived,
					_cellularOnly: Boolean);
//----------------------------------------------------------------
//	Created:	30 July 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	idx				: Integer;
	voy				: CM_Voyage;
	voyGlbl			: CM_VoyageGlobal;
begin

	pCmb.clear();
	pCmb.addItem("");
	
	if _vessel = null then
		// no point in continuing without a vessel
		return;
	endif;
	
	// add the voyage global as code and arrival date
	// but what do we need to show here??
	// we used to show all the global voyages for this vessel 
	// that haven't called to this terminal yet.

	foreach voyGlbl in app.myRoot.allVoyagesGlobal do
		if voyGlbl.vesselName = _vessel.name 
		// and voyGlbl.allVoyages[self.myTerminal] = null then
		and voyGlbl.noOfVoyageForThisTerminal (self.myTerminal) = 0 then
			idx := pCmb.addItem(voyGlbl.code);
			pCmb.itemObject[idx] := voyGlbl;
		endif;
	endforeach;
	
	if _includeArchived then
		foreach voyGlbl in app.myRoot.allVoyagesGlobalArchived do
			if	voyGlbl.vesselName = _vessel.name
			//and	voyGlbl.allVoyagesArriving[self.myTerminal] = null then
			and not voyGlbl.noOfVoyageForThisTerminal (self.myTerminal)  = 0 then
				idx := pCmb.addItem(voyGlbl.code);
				pCmb.itemObject[idx] := voyGlbl;
			endif;
		endforeach;
	endif;
	
	if _voyageCode &lt;&gt; null then
		idx := pCmb.findString(1, _voyageCode);
		if idx &gt; -1 then
			pCmb.listIndex := idx;
		endif;
	endif;
	
end;</source>
        <Parameter name="pCmb" type="ComboBox" usage="input"/>
        <Parameter name="_voyageCode" type="String"/>
        <Parameter name="_vessel" type="CM_Vessel"/>
        <Parameter name="_includeArchived" type="Boolean"/>
        <Parameter name="_cellularOnly" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="comboBoxVoyageInPort" id="46725992-4fe5-4c87-b811-ee01d4658e63">
        <source>comboBoxVoyageInPort(pCmb : ComboBox input; _voyage : CM_Voyage);
/*
----------   ----------  --------------------------------------------------
Created:	14 February 2007 By cnwmo1

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars

begin
	self.allVoyagesInPort.clear();
	self.myTerminal.getAllVoyagesInPort(self.allVoyagesInPort, false, app.myPassport);
	pCmb.clear;
	pCmb.listCollection(self.allVoyagesInPort,false,0);
	pCmb.listObject := _voyage;
end;
</source>
        <Parameter name="pCmb" type="ComboBox" usage="input"/>
        <Parameter name="_voyage" type="CM_Voyage"/>
    </JadeMethod>
    <JadeMethod name="comboBoxVoyageObject" id="2617e886-e3a8-4f90-a712-2bd960973b9a">
        <source>comboBoxVoyageObject(pCmb : ComboBox input; _voyageCode : String);
// ---------------------------------------------------------------------------
// Created:     18 December 2000 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//20 Aug 2024   navsp1      TFS Bug 65694: MTN | 14008 exception when opening terminal config form
// ---------------------------------------------------------------------------
vars
	voy				: CM_Voyage;
	term			: CM_Terminal;
begin

	term := self.myTerminal;
	
	//6 Jul 2012	NDL	Par 29956
	if pCmb.isKindOf( CMUI_ComboForVoyageActive ) then	
		// CMUI_ComboForVoyageActive uses notifications, so can't use list collection
		pCmb.clear();
		foreach voy in term.allVoyagesByCode do
			pCmb.itemObject[pCmb.addItem(pCmb.CMUI_ComboForVoyageActive.getDisplayString(voy))] := voy;
		endforeach;
	else
		pCmb.listCollection(term.allVoyagesByCode, true, 0);
	endif;
	
	if _voyageCode &lt;&gt; null then 
		voy := term.lookupVoyage (_voyageCode, null, false);
	
		if voy &lt;&gt; null then 
			pCmb.text := self.displayEntryVoyageObject(voy);
			if pCmb.text &lt;&gt; null then	//TFS 65694
				pCmb.listObject := voy;
			endif;						//TFS 65694
		endif;
	endif;		
end;</source>
        <Parameter name="pCmb" type="ComboBox" usage="input"/>
        <Parameter name="_voyageCode" type="String"/>
    </JadeMethod>
    <JadeMethod name="comboBoxVoyageOperatorWithCol" id="1db50a08-61a5-4c1b-a533-659da3b53de9">
        <source>comboBoxVoyageOperatorWithCol(_cmb : CMUI_ComboBox input; _operator : CM_Operator; _col : CM_OperatorByCodeDict);
//--------------------------------------------------
// Created:	05 August 2005 By: cnwgd1
//--------------------------------------------------
// Changed On	Changed By	Reason
// ----------	----------	------------------------
// 08/06/2022	navdap1		TFS 53362 EUP Master Data interface customers between TOS and ERP
vars
	idx : Integer;
	tmpStr : String;
	tmpOperator : CM_Operator;
	passport : CM_Passport;
	failedDAC  :CM_DataAccessController;
	byName : Boolean;			// TFS 53362
begin
	passport := app.myPassport;
	byName := app.myRoot.getConfig(ComboByNameOperator).Boolean;				// TFS 53362
	_cmb.clear();
	
	foreach tmpOperator in _col do
		//if we don't have access to the operator passed in, list it - it SHOULD be included regardless
		if ((not tmpOperator.canUserAccessSelf(null, failedDAC, passport)) 
		or (tmpOperator.isNotAvailableForEntry)) 
		and (tmpOperator &lt;&gt; _operator) then
			continue;
		endif;
		
		// Already done the checks above
		// don't call displayEntryOperator as it may return null for _operator
		// and _operator must be included in the combobox
		if byName then															// TFS 53362
			tmpStr := tmpOperator.description &amp; Tab &amp; tmpOperator.code;			// TFS 53362
		else																	// TFS 53362
			tmpStr := tmpOperator.code &amp; Tab &amp; tmpOperator.description;
		endif;																	// TFS 53362
		idx := _cmb.addItem(tmpStr);
		_cmb.itemObject[idx] := tmpOperator;

	endforeach;

	if _operator &lt;&gt; null then
		_cmb.listIndex := _cmb.findObject(_operator);
	endif;
		
end;</source>
        <Parameter name="_cmb" type="CMUI_ComboBox" usage="input"/>
        <Parameter name="_operator" type="CM_Operator"/>
        <Parameter name="_col" type="CM_OperatorByCodeDict"/>
    </JadeMethod>
    <JadeMethod name="comboBoxVoyagePlanningCode" id="2788c0c1-8b8c-4e3c-b60d-7914475b51ad">
        <source>comboBoxVoyagePlanningCode(_cmb : ComboBox input);
// ---------------------------------------------------------------------------
// Created:		JULY Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	aVPC : CM_VoyagePlanningCode;
	idx : Integer;
begin
	_cmb.clear;
	_cmb.sorted := true;
	
	foreach aVPC in self.myTerminal.allVoyagePlanningCodes do
		if aVPC.notAvailableForEntry then
			continue;
		endif;
		idx := _cmb.addItem(aVPC.code);
		_cmb.itemObject[idx] := aVPC;
		
	endforeach;
	_cmb.sorted := false;
	_cmb.addItemAt("",1);
	
end;</source>
        <Parameter name="_cmb" type="ComboBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="comboBoxVoyageProcess" id="75b7dfcd-1c03-4653-9106-d2ba345302de">
        <source>comboBoxVoyageProcess(_cmb : ComboBox input; _process : CM_VoyageProcess);
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 13/03/2018	jlgdap1		Initial creation TFS 37427 PEL1 Voyage Status Enhancements
//
vars
	iter : Iterator;
	vProcess : CM_VoyageProcess;	
	ls, haveAutoNotAllowed : Boolean;
	idx : Integer; 	

begin
	_cmb.clear();
	_cmb.addItem(Space);
	
	app.cmsBeginLoad(ls);
		
	iter := app.myRoot.allVoyageProcesses.createIterator;	
	while iter.next(vProcess) do
		// ### JIRA 33001 03OCT2024 NAVAB1
		if vProcess.isAutomaticProcess
		and not app.myRoot.canDo(Mod_VoyageAutoClosure) then
			continue;
		endif;
		
		idx := _cmb.addItem(vProcess.code);
		_cmb.itemObject[idx] := vProcess;
	endwhile;
	
	if _process &lt;&gt; null 
	and app.myRoot.allVoyageProcesses.includes(_process) then
		if _cmb.findObject(_process) &gt; 0 then // ### JIRA 33171 24OCT2024 NAVAB1
			_cmb.text := self.displayEntryVoyageProcess(_process);
			_cmb.listObject := _process;
		endif;
	endif;

	epilog
	app.cmsEndLoad(ls);
	delete iter;
end;</source>
        <Parameter name="_cmb" type="ComboBox" usage="input"/>
        <Parameter name="_process" type="CM_VoyageProcess"/>
    </JadeMethod>
    <JadeMethod name="comboBoxVoyageWO" id="5b6260b6-6cb0-42c0-9399-817e30351200">
        <updating/>
        <source>comboBoxVoyageWO(_comboBox 		    	: ComboBox;
				_includeNullVoyage,
				_showVoyageWorkOrderOnly,
				_includeBlankItem, 
				_reset, 
				_includeArchived, 
				_includeDeparted, 
				_includeNonPlannedWorked, 
				_includeLogVoyage,
				_includeGCVoyage,
				_isCellularOnly,		
				_excludeInward : Boolean) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
16 August 2022		navhl20	Bug 54347: MTN - Voyage Work Orders - When selecting any task the voyage gets disappeared
18 August 2022		jlizm1	TFS 54298 EUP - Simplified Voyage Work Order Process

*/

vars
	voyage			: CM_Voyage;
	gracePeriod		: Integer;
	checkDT			: TimeStamp;
	iter			: Iterator;
	failedDAC 		: CM_DataAccessController;
	str				: String;
begin
	
	self.setCurrentVoyageCodes(_reset, _includeNonPlannedWorked, _includeArchived, _includeDeparted, _includeNullVoyage, _includeLogVoyage, _includeGCVoyage, _excludeInward);

	iter   := self.allVoyages.createIterator();	
	
	_comboBox.clear;
	_comboBox.addItem(Empty_String);
	
	while iter.next(voyage) do
		
		if _showVoyageWorkOrderOnly then
			if voyage.isDefaultVoyageProcess then
				continue;
			endif;
		endif;
		
		
		str := voyage.code &amp; Tab &amp; voyage.description;
		_comboBox.itemObject[_comboBox.addItem(str)] := voyage;
	endwhile;
	
epilog
	delete iter;
end;</source>
        <Parameter name="_comboBox" type="ComboBox"/>
