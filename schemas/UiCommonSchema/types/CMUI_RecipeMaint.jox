    <JadeMethod name="doClickCompAdd" id="04079199-1eea-4b60-af73-c46fff4c0c7c">
        <updating/>
        <source>doClickCompAdd()updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 May 2021	navndl1	Initial creation	TFS 51243

*/

vars

	canMaintain : Boolean;
	rowIndex : Integer;

begin

	canMaintain := app.myPassport.myUser.canDo( null, PmAdmCargoTypeMaint );

	self.grpCompMaint.visible := canMaintain;
	
	self.populateCmbCargoType( null, null );
	self.setCompAmountFieldVisibility( null );
	self.txtOrder.text := null;
	self.selectedComponent := null;
	
	foreach rowIndex in 1 to self.tblComponents.rows do
		if self.tblComponents.accessRow( rowIndex ).selected then
			self.tblComponents.accessRow( rowIndex ).selected := false;
		endif;
	endforeach;
	
	self.cmbCargoType.setFocus();
	

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doClickCompCargoType" id="720138ad-154a-46fa-b68f-0ea7774dbade">
        <source>doClickCompCargoType();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 May 2021	navndl1	Initial creation	TFS 51243

*/

vars

	compCargoType : CM_CargoType;

begin

	self.cmbProduct.clear();
	
	compCargoType := self.cmbCargoType.listObject.CM_CargoType;
	
	if compCargoType &lt;&gt; null then
		self.cmbProduct.listCollection( compCargoType.allProducts, false, 0 );
		if compCargoType.allProducts.size = 1 then
			self.cmbProduct.listIndex := 1;
		endif;
	endif;
	
	self.setCompAmountFieldVisibility( compCargoType );

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doClickCompDel" id="3bed3c30-a39d-439b-b127-9ca6a95d5405">
        <updating/>
        <source>doClickCompDel()updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 May 2021	navndl1	Initial creation	TFS 51243

*/

vars

	canMaintain : Boolean;

begin

	canMaintain := app.myPassport.myUser.canDo( null, PmAdmCargoTypeMaint );

	if self.selectedComponent = null or not self.selectedComponent.isTransient or not canMaintain then
		return;
	endif;
	
	delete self.selectedComponent;
	self.selectedComponent := null;

epilog

	self.populateTblComponents();
	self.doShowComponent( null );

end;</source>
    </JadeMethod>
    <JadeMethod name="doClickCompProduct" id="188130ca-1599-4620-939b-4b535076d53e">
        <source>doClickCompProduct();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 May 2021	navndl1	Initial creation	TFS 51243

*/

vars

	product : CM_Product;
	cargoType : CM_CargoType;

begin

	product := self.cmbProduct.listObject.CM_Product;
	if product &lt;&gt; null then
		self.setCompAmountFieldVisibility( product );
		return;
	endif;
	
	cargoType := self.cmbCargoType.listObject.CM_CargoType;
	if product &lt;&gt; null then
		self.setCompAmountFieldVisibility( cargoType );
		return;
	endif;

	self.setCompAmountFieldVisibility( null );

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doClickCompUpd" id="6f8fe549-d124-4700-96f7-fb7d513b9344">
        <updating/>
        <source>doClickCompUpd()updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 May 2021	navndl1	Initial creation	TFS 51243

*/

vars

	component : CM_RecipeComponent;
	
	compCargoType : CM_CargoType;
	compProduct : CM_Product;
	quantity : Integer;
	volume : Decimal[14,4];
	weight : Decimal[14,4];
	order : Integer;
	
	msg : String;

begin

	if self.selectedComponent = null then
		create self.selectedComponent transient;
	endif;
	
	compCargoType := self.cmbCargoType.listObject.CM_CargoType;
	compProduct := self.cmbProduct.listObject.CM_Product;
	
	if compCargoType = null then
		msg := app.getErrorString(No_Cargo_type_selected);
		app.msgBox( msg, app.getErrorString( Error ), MsgBox_OK_Only );
		self.cmbCargoType.setFocus();
		return;
	endif;
	
	if compCargoType &lt;&gt; null and compCargoType.isTrackByVolume then
		volume := self.tblAmount.getConvertedValue();
		if volume &lt;= 0 then
			msg := app.getErrorString(Amount_required);
			app.msgBox( msg, app.getErrorString( Error ), MsgBox_OK_Only );
			self.tblAmount.setFocus();
			return;
		endif;
	elseif compCargoType &lt;&gt; null and compCargoType.isTrackByWeight then
		weight  := self.tblAmount.getConvertedValue();
		if weight &lt;= 0 then
			msg := app.getErrorString(Amount_required);
			app.msgBox( msg, app.getErrorString( Error ), MsgBox_OK_Only );
			self.tblAmount.setFocus();
			return;
		endif;
	else
		quantity := self.txtAmount.text.asIntegerJMT;
		if quantity &lt;= 0 then
			msg := app.getErrorString(Amount_required);
			app.msgBox( msg, app.getErrorString( Error ), MsgBox_OK_Only );
			self.txtAmount.setFocus();
			return;
		endif;
	endif;
	order := self.txtOrder.text.asIntegerJMT;
	
	self.selectedComponent.setProxy(	null,	//_code : String;
										null, //_description : String;
										compCargoType, //_myCargoType : CM_CargoType;
										compProduct,	//_myProduct : CM_Product;
										order,	//_order : Integer;
										quantity,	//_quantity : Integer;
										volume,	//_volume : Decimal;
										weight	//_weight : Decimal
										);
										
	self.selectedComponent.setMyRecipe( self.myPxyRecipe );
	
	self.populateTblComponents();
	self.doShowComponent( null );

epilog

	if self.selectedComponent &lt;&gt; null and self.selectedComponent.myRecipe = null then
		delete self.selectedComponent;
	endif;

end;</source>
    </JadeMethod>
    <JadeMethod name="doClickSaveRecipe" id="c471d186-34ca-4a6e-92c3-c96d4787ca77">
        <updating/>
        <source>doClickSaveRecipe()updating;
/*

Purpose:			

Parameters:			//Creat4es / Updates the proxy Recipe.  ( Cargo Type Maint form 'Save' persists it.) 

Return Value:		

Date		Who		Reason
21 May 2021	navndl1	Initial creation	TFS 51243

*/

vars

	canFactor : Boolean;
	code : String;
	description : String;
	product : CM_Product;
	defaultQuantity : Integer;
	defaultVolume : Decimal[14,4];
	defaultWeight : Decimal[14,4];
	instructions : String;
	msg : String;

begin

	canFactor := self.chkScale.value;
	code := self.txtCode.text;
	description := self.txtDescription.text;
	product := self.cmbRecProduct.listObject.CM_Product;
	defaultQuantity := self.txtQuantity.text.asIntegerJMT;
	defaultVolume := self.tblVolume.getConvertedValue;
	defaultWeight := self.tblWeight.getConvertedValue;
	instructions := self.txtInstructions.text;
	
	if self.myCargoType = null then
		msg := app.getErrorString(No_Cargo_type_selected);
		app.msgBox( msg, app.getErrorString( Error ), MsgBox_OK_Only );
		self.unloadForm();
		return;
	endif;

	if self.myCargoType.isTrackByVolume then
		if defaultVolume &lt;= 0 then
			msg := app.getErrorString(Input_required_field_reqVol);
			app.msgBox( msg, app.getErrorString( Error ), MsgBox_OK_Only );
			self.tblVolume.setFocus();
			return;
		endif;
	elseif self.myCargoType.isTrackByWeight then
		if defaultWeight &lt;= 0 then
			msg := app.getErrorString(Input_required_field_weight);
			app.msgBox( msg, app.getErrorString( Error ), MsgBox_OK_Only );
			self.tblWeight.setFocus();
			return;
		endif;
	else
		if defaultQuantity &lt;= 0 then
			msg := app.getErrorString(Input_required_field_quantity);
			app.msgBox( msg, app.getErrorString( Error ), MsgBox_OK_Only );
			self.txtQuantity.setFocus();
			return;
		endif;
	endif;



	self.myPxyRecipe.setProxy(	canFactor,	//_canFactor : Boolean;
								code,	//_code : String;
								description,	//_description : String;
								self.myCargoType,	//_myCargoType : CM_CargoType;
								product,	//_myProduct : CM_Product;
								defaultQuantity,	//_defaultQuantity : Integer;
								defaultVolume,	//_defaultVolume : Decimal;
								defaultWeight,	//_defaultWeight : Decimal;
								instructions	//_instructions : String
								);
							
	self.unloadForm();

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doShowComponent" id="a84ad564-7f90-45be-b0bf-3d79845359cb">
        <updating/>
        <source>doShowComponent( _component : CM_RecipeComponent ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 May 2021	navndl1	Initial creation	TFS 51243

*/

vars

	cargoType : CM_CargoType;
	measureType : CM_MeasurementType;
	unit : String;
	converted : String;

begin

	self.txtAmount.visible := false;
	self.tblAmount.visible := false;

	if _component = null then
		self.grpCompMaint.visible := false;
		self.cmbCargoType.listIndex := -1;
		self.cmbProduct.listIndex := -1;
		self.setCompAmountFieldVisibility( null );
		self.txtOrder.text := null;
		self.txtAmount.text := null;
		self.selectedComponent := null;
		self.txtAmount.visible := true;
		
	else
		if _component.myProduct &lt;&gt; null then
			self.setCompAmountFieldVisibility( _component.myProduct );
		elseif _component.myCargoType &lt;&gt; null then
			self.setCompAmountFieldVisibility( _component.myCargoType );
		else
			self.setCompAmountFieldVisibility( null );
		endif;
		
		self.selectedComponent := _component;
		self.grpCompMaint.visible := true;
		self.populateCmbCargoType(  _component.myCargoType,  _component.myProduct );
		self.cmbCargoType.listIndex := self.cmbCargoType.findObject( _component.myCargoType );
		self.cmbProduct.listIndex := self.cmbProduct.findObject( _component.myProduct );
		if _component.volume &gt; 0 then
			if  _component.myProduct &lt;&gt; null then
				measureType := _component.myProduct.getDefaultMeasurementForType(Type_Volume);
			else
				measureType := _component.myCargoType.myVolumeMeasurementType;
			endif;
			unit := measureType.shortName;
			converted := app.convertMeasurementForDisplay(unit,  _component.volume);
			self.tblAmount.setValues( converted  &amp; " " &amp; unit );
			self.tblAmount.visible := true;
		elseif _component.weight &gt; 0 then
			if  _component.myProduct &lt;&gt; null then
				measureType := _component.myProduct.getDefaultMeasurementForType(Type_Weight);
			else
				measureType := _component.myCargoType.myWeightMeasurementType;
			endif;
			unit := measureType.shortName;
			converted := app.convertMeasurementForDisplay(unit,  _component.weight);
			self.tblAmount.setValues( converted  &amp; " " &amp; unit );
			self.tblAmount.visible := true;
		else
			self.txtAmount.text := _component.quantity.asStringJMT;
			self.txtAmount.visible := true;
		endif;
		self.txtOrder.text := _component.order.asStringJMT;
		
	endif;
	
	self.setButtons();

epilog

end;</source>
        <Parameter name="_component" type="CM_RecipeComponent"/>
    </JadeMethod>
    <JadeMethod name="populateCmbCargoType" id="06aa54c8-9a4f-4a34-9fb5-0c590ce5b32f">
        <source>populateCmbCargoType( _cargoType : CM_CargoType; _product : CM_Product );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 May 2021	navndl1	Initial creation	TFS 51243

*/

vars

	cargoTypes : CM_CargoTypeSet;
	cargoType : CM_CargoType;
	cmbIndex : Integer;
	realCargoType : CM_CargoType;

begin

	self.cmbCargoType.clear();
	
	create cargoTypes transient;
	
	foreach cargoType in app.myRoot.allCargoTypesById discreteLock do
		if cargoType = self.myCargoType then
			continue;
		endif;
		if cargoType.isBreakBulk or cargoType.isBulk then
			cargoTypes.addNoDuplicates( cargoType, false );
		endif;	
	endforeach;
	
	self.cmbCargoType.listCollection( cargoTypes, false, 0 );
	self.cmbCargoType.setInitialised(true);
	
	if _cargoType &lt;&gt; null then
		cmbIndex := self.cmbCargoType.findObject( _cargoType );
		if cmbIndex &gt; 0 then
			realCargoType := _cargoType;
		else
			realCargoType := _cargoType.pxyGetRealObject();
			if realCargoType &lt;&gt; null then
				cmbIndex := self.cmbCargoType.findObject( realCargoType );
			endif;
		endif;
		if cmbIndex &gt; 0 then
			self.cmbCargoType.listIndex := cmbIndex;
		endif;
	endif;
	
	self.populateCmbProduct( realCargoType, _product );

epilog

end;</source>
        <Parameter name="_cargoType" type="CM_CargoType"/>
        <Parameter name="_product" type="CM_Product"/>
    </JadeMethod>
    <JadeMethod name="populateCmbProduct" id="44fc9eff-5e07-43a4-836c-6d0e0ca5c72c">
        <source>populateCmbProduct( _cargoType : CM_CargoType; _product : CM_Product );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 May 2021	navndl1	Initial creation	TFS 51243

*/

vars

	product : CM_Product;
	cmbIndex : Integer;

begin

	self.cmbProduct.clear();
	
	if _cargoType &lt;&gt; null then
		self.cmbProduct.listCollection( _cargoType.allProducts, false, 0 );
		
		if _product &lt;&gt; null then
			cmbIndex := self.cmbProduct.findObject( _product );
			if cmbIndex &gt; 0 then
				self.cmbProduct.listIndex := cmbIndex;
			endif;
		elseif _cargoType.allProducts.size = 1 then
			self.cmbProduct.listIndex := 1;
		endif;
	
	endif;

epilog

end;</source>
        <Parameter name="_cargoType" type="CM_CargoType"/>
        <Parameter name="_product" type="CM_Product"/>
    </JadeMethod>
    <JadeMethod name="populateFromProxyRecipe" id="d0316ef4-4fac-4a46-b6e0-8dc18c19e286">
        <updating/>
        <source>populateFromProxyRecipe()updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 May 2021	navndl1	Initial creation	TFS 51243

*/

vars

	volMeasureType : CM_MeasurementType;
	wtMeasureType : CM_MeasurementType;
	volUnit : String;
	wtUnit : String;
	volConverted : String;
	wtConverted : String;
	product : CM_Product;

begin

	
	self.tblVolume.setup(Type_Volume, self.backColor);
	if self.myPxyRecipe &lt;&gt; null then
		product := self.myPxyRecipe.myProduct;
	endif;
	
	if product &lt;&gt; null then
		volMeasureType := product.getDefaultMeasurementForType(Type_Volume);
	endif;
	if volMeasureType = null then
		volMeasureType := self.myCargoType.getDefaultMeasurementForType(Type_Volume);
	endif;
	volUnit := volMeasureType.shortName;
	self.tblVolume.setMeasurementType(volMeasureType.measurementType);

	self.tblWeight.setup(Type_Weight, self.backColor);
	if product &lt;&gt; null then
		wtMeasureType := product.getDefaultMeasurementForType(Type_Weight);
	endif;
	if wtMeasureType = null then
		wtMeasureType := self.myCargoType.getDefaultMeasurementForType(Type_Weight);
	endif;
	wtUnit := wtMeasureType.shortName;
	self.tblWeight.setMeasurementType(wtMeasureType.measurementType);
	
	if self.myPxyRecipe &lt;&gt; null then
		self.txtCode.text := self.myPxyRecipe.code;
		self.txtDescription.text := self.myPxyRecipe.description;
		self.chkScale.value := self.myPxyRecipe.canFactor;
		self.txtInstructions.text := self.myPxyRecipe.instructions;
		
		self.cmbRecProduct.enabled := self.myPxyRecipe.pxyGetRealObject = null;
		if self.myPxyRecipe.myProduct &lt;&gt; null then
			self.cmbRecProduct.listIndex := self.cmbRecProduct.findObject( self.myPxyRecipe.myProduct );
		endif;
		
		volConverted := app.convertMeasurementForDisplay(volUnit,  self.myPxyRecipe.defaultVolume);
		self.tblVolume.setValues( volConverted  &amp; " " &amp; volUnit );
	
		wtConverted := app.convertMeasurementForDisplay(wtUnit,  self.myPxyRecipe.defaultWeight);
		self.tblWeight.setValues( wtConverted  &amp; " " &amp; wtUnit );
	
		self.txtQuantity.text := self.myPxyRecipe.defaultQuantity.asStringJMT;
		
		self.populateTblComponents();
		
	//	self.grpCompMaint.visible := self.myPxyRecipe.code &lt;&gt; null;
		self.grpCompMaint.visible := false;
		
	else
		self.tblVolume.setValues( "0 " &amp; volUnit );
		self.tblWeight.setValues( "0 " &amp; wtUnit );
		self.txtQuantity.text := "0";
		
		self.grpCompMaint.visible := false;
		
	endif;
	
	self.selectedComponent := null;
	
	self.setButtons();
	
	if self.viewOnlyMode then
		self.txtCode.enabled := false;
		self.txtDescription.enabled := false;
		self.chkScale.enabled := false;
		self.txtInstructions.enabled := false;
		self.cmbRecProduct.enabled := false;
		self.tblVolume.enabled := false;
		self.tblWeight.enabled := false;
		self.txtQuantity.enabled := false;
	endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="populateTblComponents" id="47e46e0b-12e9-4bb2-831f-139368679bbe">
        <source>populateTblComponents();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 May 2021	navndl1	Initial creation	TFS 51243

*/

vars

	component : CM_RecipeComponent;
	detailString : String;
	rowIndex : Integer;

begin

	self.tblComponents.rows := self.tblComponents.fixedRows;

	if self.myPxyRecipe &lt;&gt; null then
		foreach component in self.myPxyRecipe.allComponentsByOrder do
			detailString := component.getAttributeStringForDefArray( self.tblComponents.allTblDataEntRows );
			rowIndex := self.tblComponents.addItemObject(component, detailString);
		endforeach;
	endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setButtons" id="12f09029-e43f-41aa-b142-a14554c120e2">
        <source>setButtons();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 May 2021	navndl1	Initial creation	TFS 51243

*/

vars

	rowIndex : Integer;
	component : CM_RecipeComponent;
	canMaintain : Boolean;

begin

	canMaintain := app.myPassport.myUser.canDo( null, PmAdmCargoTypeMaint );
	if self.viewOnlyMode then
		canMaintain := false;
	endif;
	
	rowIndex := self.tblComponents.row;
	if rowIndex &gt; self.tblComponents.fixedRows and rowIndex &lt;= self.tblComponents.rows then
		component := self.tblComponents.accessRow(rowIndex).itemObject.CM_RecipeComponent;
	endif;

	self.btnCloseAll.enabled := true;
	self.btnCompAdd.enabled := canMaintain;
	self.grpCompMaint.enabled := canMaintain;
	self.btnSaveRecipe.enabled := canMaintain;
	self.btnCompUpdate.enabled := canMaintain;
	self.btnCompDelete.enabled := canMaintain and component &lt;&gt; null;
	

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setCompAmountFieldVisibility" id="e1b0d98f-35a2-4e6a-a55d-5cd1b09f9cb0">
        <source>setCompAmountFieldVisibility( _obj : CM_Object );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 May 2021	navndl1	Initial creation	TFS 51243

*/

vars

	product : CM_Product;
	cargoType : CM_CargoType;
	measureType : CM_MeasurementType;
	unit : String;

begin

	self.txtAmount.visible := false;
	self.tblAmount.visible := false;
	self.txtAmount.left := self.tblAmount.left;

	if _obj &lt;&gt; null and _obj.isKindOf( CM_Product ) then
		product := _obj.CM_Product;
		cargoType := product.myCargoType;
	elseif _obj &lt;&gt; null and _obj.isKindOf( CM_CargoType ) then
		cargoType := _obj.CM_CargoType;
	else
		self.txtAmount.visible := true;
		return;
	endif;
	
	if cargoType.isTrackByVolume then
		self.tblAmount.visible := true;
		self.tblAmount.setup(Type_Volume, self.backColor);
		if product &lt;&gt; null then
			measureType := product.getDefaultMeasurementForType(Type_Volume);
		else
			measureType := cargoType.myVolumeMeasurementType;
		endif;
		unit := measureType.shortName;
		self.tblAmount.setMeasurementType(measureType.measurementType);
		self.tblAmount.setValues( "0 " &amp; unit );
	elseif cargoType.isTrackByWeight then
		self.tblAmount.visible := true;
		self.tblAmount.setup(Type_Weight, self.backColor);
		if product &lt;&gt; null then
			measureType := product.getDefaultMeasurementForType(Type_Weight);
		else
			measureType := cargoType.myWeightMeasurementType;
		endif;
		unit := measureType.shortName;
		self.tblAmount.setMeasurementType(measureType.measurementType);
		self.tblAmount.setValues( "0 " &amp; unit );
	else
		self.txtAmount.visible := true;
		self.txtAmount.text := '0';
	endif;

epilog

end;</source>
        <Parameter name="_obj" type="CM_Object"/>
    </JadeMethod>
    <JadeMethod name="setMyCargoType" id="d35b8696-bc64-41fe-a04a-e2f8ca45b68d">
