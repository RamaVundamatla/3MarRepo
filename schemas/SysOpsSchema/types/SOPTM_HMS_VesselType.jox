    <JadeMethod name="doSave" id="26b466ea-e38d-48ec-b3c2-884a43fcccf0">
        <updating/>
        <source>doSave(): Boolean updating;
//--------------------------------------------------------------
//Created: 09 July 2003 By: cnwgd1
//--------------------------------------------------------------
vars
	pxyVesselType	:	HMS_VesselType;
	theForm			:	SOP_TableMaintForm;
		
begin
//	return inheritMethod();
	theForm := self.myForm.SOP_TableMaintForm;
	if theForm.myProxyObject = null then
		if theForm.mode = theForm.Mode_Add then
			create theForm.myProxyObject as HMS_VesselType transient;
		else
			app.raiseUnexpectedProgramError(class.name, method.name, 'Proxy is null for update');
			return false;
		endif;
	endif;
	
		pxyVesselType := theForm.myProxyObject.HMS_VesselType;
		theForm.tblInput1.setObjectFromTable(pxyVesselType, null, false);
		pxyVesselType.setProxy(app.myRoot);
		
		//Are we adding or updating
		if theForm.mode = theForm.Mode_Add then
			app.myTrxCA.trxCreateHMSObject( pxyVesselType, theForm.myCurrentObject, app.myPassport );
		elseif theForm.mode = theForm.Mode_Update then
			app.myTrxUA.trxUpdateHMSObject(pxyVesselType, app.myPassport );
		else
			app.raiseUnexpectedProgramError( class.name,
											 method.name, 
											 '  Invalid mode (' &amp; theForm.mode.String &amp; ')' );
			return false;
		endif;
		
		return app.myPassport.trxCompletedOK;
		
	end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
