    <JadeMethod name="utlCreateCheckScaleDtl" id="4e0c0655-cc17-4e40-ba5f-c3fe081c3ea2">
        <updating/>
        <source>utlCreateCheckScaleDtl(_pxyChkScaleDtl : CM_LogCheckScaleDtl input;
						_newChkScaleDtl : CM_LogCheckScaleDtl output;
						_realChkScaleHdr : CM_LogCheckScaleHdr;
						_passport : CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:     13 May 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
vars
	newChkScaleDtl,
	pxyChkScaleDtl			: CM_LogCheckScaleDtl;
	log						: CM_Log;
begin

	self.initialiseActivity();
	
	if _pxyChkScaleDtl.logId = null then
	//	app.raiseCMWarning1(REQUIRED_FIELD, 'Log Id', 'logId', null, _pxyChkScaleDtl);
		app.raiseCMWarning(Input_required_field_logID, 'logId', null, _pxyChkScaleDtl); // cnwdb2	PAR 35364	
		return;
	endif;
	
	log := _pxyChkScaleDtl.findLog(_pxyChkScaleDtl.logId);
	
	if log = null then
		app.raiseCMWarning1(ERR_LOG_NOT_FOUND, _pxyChkScaleDtl.logId, 'logId', null, _pxyChkScaleDtl);
	endif;
	
	_pxyChkScaleDtl.finalizeProxySettings(log);
	
	app.setContinueCMExceptions(true);

	app.myValCA.valCheckScalingDtl(_pxyChkScaleDtl);
	
	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
		
	app.setContinueCMExceptions(false);
	
	create _newChkScaleDtl persistent;
	_newChkScaleDtl.setForCreate(_pxyChkScaleDtl, _realChkScaleHdr);
	
	
end;</source>
        <Parameter name="_pxyChkScaleDtl" type="CM_LogCheckScaleDtl" usage="input"/>
        <Parameter name="_newChkScaleDtl" type="CM_LogCheckScaleDtl" usage="output"/>
        <Parameter name="_realChkScaleHdr" type="CM_LogCheckScaleHdr"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlCreateCheckScalingBatch" id="9624edbb-adc9-42f5-88ce-c51a60935d59">
        <updating/>
        <source>utlCreateCheckScalingBatch(_pxyChkScaleHdr : CM_LogCheckScaleHdr input; 
							_newChkScaleHdr : CM_LogCheckScaleHdr output;
							_passport : CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:     13 May 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
vars
	newChkScaleDtl,
	pxyChkScaleDtl			: CM_LogCheckScaleDtl;
begin

	self.initialiseActivity();
	
	if _pxyChkScaleHdr = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Proxy check scaling header is null');
		return;
	endif;
	
	app.setContinueCMExceptions(true);
	
	app.myValCA.valCheckScalingBatch(_pxyChkScaleHdr);
	
	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
		
	app.setContinueCMExceptions(false);
	
	create _newChkScaleHdr persistent;
	_newChkScaleHdr.setForCreate(_pxyChkScaleHdr);
	
	if not _passport.noErrors then
		return;
	endif;
	
	foreach pxyChkScaleDtl in _pxyChkScaleHdr.allCheckScaleDtls do
		self.utlCreateCheckScaleDtl(pxyChkScaleDtl, 
									newChkScaleDtl,
									_newChkScaleHdr,
									_passport);
	endforeach;
	
	if _passport.noErrors then
		global.causeEvent(EVENT_CHECKSCALE_CREATE, false, _newChkScaleHdr);
	endif;
	
end;</source>
        <Parameter name="_pxyChkScaleHdr" type="CM_LogCheckScaleHdr" usage="input"/>
        <Parameter name="_newChkScaleHdr" type="CM_LogCheckScaleHdr" usage="output"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
