    <JadeMethod name="doApplyScreenColors" id="88304abb-2a55-44cc-8003-50288e2fb251">
        <updating/>
        <source>doApplyScreenColors() updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
26 May 2010	cnwer1	Initial creation

*/

vars
	rtScreenMode	: CM_RTScreenConfig;
begin

	self.doApplyVehicleMountedColours();
	rtScreenMode:=app.myVMAgent.getMyScreenMode();
	self.tblDetails.foreColor:=rtScreenMode.screenForeColour;
	self.tblDetails.backColor:=rtScreenMode.screenBackColour;
	self.resizeControls();
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doChangeMode" id="815452ae-2a67-46f9-a519-8c3028106ea3">
        <updating/>
        <source>doChangeMode(_mode : Integer) protected, updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 October 2012	cnwer1	Initial creation SFW 1295

*/

vars

begin
	self.updateMode := _mode;
	
	self.tblDetails.visible:=self.updateMode = self.UpdateMode_None;
	self.frmPW.visible:=self.updateMode = self.UpdateMode_Password;
	self.frmChgLoc.visible:=self.updateMode = self.UpdateMode_Locale or self.updateMode = self.UpdateMode_ScreenSize;
	self.frmChgQ.visible:=self.updateMode =self.UpdateMode_Queue;
	
	self.lblChgLocale.visible := self.updateMode = self.UpdateMode_Locale;
	self.cmbLocale.visible := self.updateMode = self.UpdateMode_Locale;
	self.lblChgScreenSize.visible := self.updateMode = self.UpdateMode_ScreenSize;
	self.cmbScreenSize.visible := self.updateMode = self.UpdateMode_ScreenSize;
	
	self.btnSave.visible := not (self.updateMode = self.UpdateMode_None or self.updateMode = self.UpdateMode_ScreenSize);	
	
	if self.updateMode = UpdateMode_Password then
		self.txtOldPW.text := null;
		self.txtNewPW.text := null;
		self.txtConfirmPW.text := null;
	endif;
	
	if self.updateMode = self.UpdateMode_Queue and not self.queuesLoaded then
		self.loadQInfo();
		self.queuesLoaded:=true;
	endif;
	
	
	if self.isOnNarrowScreen then
		self.frmMenu.visible:=false;
		self.btnCancel.visible:=true;
	endif;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_mode" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="doComboScreenSizeClick" id="51069034-a290-4547-971c-c1f8453afeea">
        <updating/>
        <source>doComboScreenSizeClick() updating, protected;
/* ---------------------------------------------------------------------------
Created:     17 September 2010 by cnwrs2

Purpose:     
        
Change Date	Who		Reason

------------------------------------------------------------------------------*/
vars
	newScreenSize		: String;
	newX, newY			: Integer;
	
begin

	// LXE VX6 = 1/2 SVGA = 800 x 320
	// LXE VX7 = SVGA = 800 x 600

	newScreenSize := self.cmbScreenSize.text;
	
	if newScreenSize = ScreenSize_Descr_HalfSVGA then
		newX := ScreenSize_HalfSVGA_X;
		newY := ScreenSize_HalfSVGA_Y;
		
	elseif newScreenSize = ScreenSize_Descr_SVGA then
		newX := ScreenSize_SVGA_X;
		newY := ScreenSize_SVGA_Y;

	elseif newScreenSize = ScreenSize_Descr_VGA then
		newX := ScreenSize_VGA_X;
		newY := ScreenSize_VGA_Y;
	elseif newScreenSize = ScreenSize_Descr_QVGA then
		newX := ScreenSize_QVGA_X;
		newY := ScreenSize_QVGA_Y;
	endif;
	
	if newX = 0 then
		// resizeable
		self.borderStyle := BorderStyle_Sizable;

		// use half SVGA as default
		newX := ScreenSize_HalfSVGA_X;
		newY := ScreenSize_HalfSVGA_Y;
	else
		self.borderStyle := BorderStyle_Single;
	endif;
	
	self.width := newX;
	self.height := newY;
	
	self.getSessionAgent().setLastScreenPosition(self.left.Integer, self.top.Integer, self.width.Integer, self.height.Integer );
	self.resizeControls();
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
