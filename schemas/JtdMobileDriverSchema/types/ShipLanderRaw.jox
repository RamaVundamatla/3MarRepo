    <JadeMethod name="handleShowModal" id="bf82d80c-5be8-4c57-af84-7758a40ed64d">
        <updating/>
        <source>handleShowModal():Integer updating;

vars
	sa:StringArray;
	meth:String;
	atcgModalCount:Integer;
begin
	app.logMessage(method.qualifiedName);
	create sa transient;
	app.atcgModalCount:=app.atcgModalCount+1;
	atcgModalCount:=app.atcgModalCount;

	if atcgModalCount = 1 then
		myMB_MsgBoxForm:=app.getForm('MB_MsgBoxForm').MB_MsgBoxForm;
		myMB_MsgBoxForm.show;
		myMB_MsgBoxForm.activate;
		sa.add('slr012m_MMBF_btnDialog1_click');
	
	elseif atcgModalCount = 2 then
		myMB_MsgBoxForm:=app.getForm('MB_MsgBoxForm').MB_MsgBoxForm;
		myMB_MsgBoxForm.show;
		myMB_MsgBoxForm.activate;
		sa.add('slr024m_MMBF_btnDialog1_click');
	endif;

	foreach meth in sa do
		if meth[7:3] &lt;&gt; "mv_" then
			app.doWindowEvents(longPause);
		endif;
		userPreTransaction(meth);
		retCode:=self.sendMsg(meth).Integer;
		userPostTransaction(meth);
		if retCode = 0 then
			app.logMessage("Test "&amp;self.class.name&amp;"::"&amp;meth&amp;" succeeded");
		else
			app.logMessage("Test "&amp;self.class.name&amp;"::"&amp;meth&amp;" failed with error code "&amp;retCode.String);
			app.atcgReplayFailure:=true;
			break;
		endif;
	endforeach;

	if atcgModalCount = 1 then
		if app.isValidObject(myMB_MsgBoxForm) then
			myMB_MsgBoxForm.unloadForm;  // 13:40:46
		endif;
		myMB_MsgBoxForm:=null;
		return 1;
	
	elseif atcgModalCount = 2 then
		if app.isValidObject(myMB_MsgBoxForm) then
			myMB_MsgBoxForm.unloadForm;  // 13:42:04
		endif;
		myMB_MsgBoxForm:=null;
		return 1;
	endif;
epilog
	delete sa;
end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
