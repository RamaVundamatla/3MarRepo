    <JadeMethod name="updateAlternativeId" id="ef520fdb-202b-415a-8acd-85416d92ab40">
        <source>updateAlternativeId(_alternativeId : String; _toDoTask : CM_ToDoTaskDesc; _addingToDo : Boolean) : Boolean;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 15/07/2014	cnwdap1		Initial creation PAR #34568 CCMS SFW 1389 Alternative Id Cargo Check
//
vars
	pxyTI		: CM_TrackedItem;
	result		: Integer;
	toDoCode	: Integer;

begin
	// get the proxy TI
	pxyTI := self.getMyProxy();
	
	if _toDoTask &lt;&gt; null then
		toDoCode := _toDoTask.code;
	endif;
	
	if pxyTI &lt;&gt; null and CM_TrackedItem.hasInstance(pxyTI) then
		
		// update the alternative id
		pxyTI.zSetPxyAlternativeId(_alternativeId);
		
		app.myPassport.clearErrorsWarnings();

		// The Proxy is updated, including the stops , so now update the database
		while true do
			app.myTrxUA.trxUpdateTIWeightToDo(	pxyTI,
												toDoCode,
												_addingToDo,
												false,
												null,
												TI_UPDMODE_NORMAL, 
												null,
												false,
												app.myPassport);
			
			if app.myPassport.trxCompletedOK then
				return true;
			else
				//If there were warnings, give the user a chance to see them. If there are no errors they may decide to acknowledge
				//them and update anyway.
				result := app.showErrorWarningDialog(app.getErrorString(Cargo_item_update), app.myPassport, ErrWarnMode_Add + ErrWarnMode_CanAckWarnings);
				if app.myPassport.noErrors and
				   result = IDOK then
					app.myPassport.warningsAcknowledged	:= true;
					continue;
				endif;
			endif;
			return false;
		endwhile;
	else
		return false;
	endif;
	
epilog
	
end;</source>
        <Parameter name="_alternativeId" type="String"/>
        <Parameter name="_toDoTask" type="CM_ToDoTaskDesc"/>
        <Parameter name="_addingToDo" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="updateContainerDimensions" id="195149ff-8142-4464-abff-93045c91c515">
        <updating/>
        <source>updateContainerDimensions(	_left, _right, _back, _front, _height : Decimal; _toDoTaskCode : Integer; _addCompRemTodo : Integer) : Boolean updating;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11/02/2010	cnwdap1	Initial creation
04/03/2010	cnwdap1	PAR #22741 New parameter _addingToDo so we know whether to add or remove the to do task
*/
vars
	prxyTI	: CM_TrackedItem;
	result	: Integer;

begin
	// get the proxy TI
	prxyTI := self.getMyProxy();
	
	if prxyTI &lt;&gt; null then
		
		// update the container over dimensions information
		prxyTI.CM_Container.setOverWidthLeft(_left, null, app.myPassport);
		prxyTI.CM_Container.setOverWidthRight(_right, null, app.myPassport);
		prxyTI.CM_Container.setOverLengthRear(_back, null, app.myPassport);
		prxyTI.CM_Container.setOverLengthFront(_front, null, app.myPassport);
		prxyTI.CM_Container.setOverHeight(_height, null, app.myPassport);
		
		app.myPassport.clearErrorsWarnings();

		// The Proxy is updated, so now update the database
		while true do
			app.myTrxUA.trxUpdateTIDimensionsToDo(	prxyTI, _toDoTaskCode, _addCompRemTodo, null, TI_UPDMODE_NORMAL, null, app.myPassport);
			
			if app.myPassport.trxCompletedOK then
				return true;
			else
				//If there were warnings, give the user a chance to see them. If there are no errors they may decide to acknowledge
				//them and update anyway.
				result := app.showErrorWarningDialog('Tracked Item Update', app.myPassport, ErrWarnMode_Add + ErrWarnMode_CanAckWarnings);
				if app.myPassport.noErrors and
				   result = IDOK then
					app.myPassport.warningsAcknowledged	:= true;
					continue;
				endif;
			endif;
			return false;
		endwhile;
	else
		return false;
	endif;

epilog

end;</source>
        <Parameter name="_left" type="Decimal"/>
        <Parameter name="_right" type="Decimal"/>
        <Parameter name="_back" type="Decimal"/>
        <Parameter name="_front" type="Decimal"/>
        <Parameter name="_height" type="Decimal"/>
        <Parameter name="_toDoTaskCode" type="Integer"/>
        <Parameter name="_addCompRemTodo" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="updateDamages" id="2d8df0a7-97f1-4aaa-8764-967440b2f4f4">
        <source>updateDamages(_damageInterface : IF_DamageDetails input; _toDoTaskDesc : CM_ToDoTaskDesc; _addCompRemTodo : Integer ) : Boolean;
/*
Date		Who		Reason
28 Jan 2009	cnwcp2	Initial creation
20 Nov 2009	cnwer1	MES 1013 - changed to use interface needed to be able to update wagons aswell	
*/

vars
	cmifUpdateController 	: CMIF_Object;
	result 					: Integer;
	prxyTI					: CM_TrackedItem; //cnwas3 par 24175
	toDoTaskCode			: Integer;
begin
	
	if _damageInterface = null then
		return false;
	endif;
	
	app.myPassport.clearErrorsWarnings();	
	
	cmifUpdateController:=_damageInterface.getDamageCMIFController;
	
	prxyTI := self.getMyProxy();	//cnwas3 par 24175
	
	if _toDoTaskDesc &lt;&gt; null then		//cnwas3 par 24175
		toDoTaskCode := _toDoTaskDesc.code;
	endif;
	
	while true do
		_damageInterface.updateDamageDetails(cmifUpdateController,app.myPassport);			
		
		if app.myPassport.trxCompletedOK then
			app.myPassport.clearErrorsWarnings();
			break;
		else
			//If there were warnings, give the user a chance to see them. If there are no _errors they may decide to acknowledge
			//them and update anyway.
			result := app.showErrorWarningDialog(_damageInterface.getObjectDamageDesc, app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and result = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		return false;
	endwhile;
			
	while true do		
		if toDoTaskCode &lt;&gt; null 								//cnwas3 par 24175 begin
		   then					
			app.myTrxUA.trxUpdateTIDamageToDo(prxyTI,											
											toDoTaskCode,			
											//_addingToDo,
											_addCompRemTodo,
											app.myPassport);
		endif;													//cnwas3 par 24175 end		
		
		if app.myPassport.trxCompletedOK then
			app.myPassport.clearErrorsWarnings();
			return true;
		else
			//If there were warnings, give the user a chance to see them. If there are no _errors they may decide to acknowledge
			//them and update anyway.
			result := app.showErrorWarningDialog(_damageInterface.getObjectDamageDesc, app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and result = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		return false;
	endwhile;
		

	return false;
epilog
	delete cmifUpdateController;
end;</source>
        <Parameter name="_damageInterface" type="IF_DamageDetails" usage="input"/>
        <Parameter name="_toDoTaskDesc" type="CM_ToDoTaskDesc"/>
        <Parameter name="_addCompRemTodo" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="updateGenCargoDimensions" id="3625467d-8ba4-4743-a9aa-858f723aee2f">
        <updating/>
        <source>updateGenCargoDimensions(_length, _width, _height : Decimal; _toDoTaskCode : Integer; _addCompRemTodo : Integer ) : Boolean updating;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09/02/2010	cnwdap1	Initial creation
04/03/2010	cnwdap1	PAR #22741 New parameter _addingToDo so we know whether to add or remove the to do task
*/
vars
	prxyTI	: CM_TrackedItem;
	result	: Integer;

begin
	// get the proxy TI
	prxyTI := self.getMyProxy();
	
	if prxyTI &lt;&gt; null then
		
		// update the seals information
		prxyTI.setLength(_length);
		prxyTI.setWidth(_width);
		prxyTI.setHeight(_height);
		
		app.myPassport.clearErrorsWarnings();

		// The Proxy is updated, so now update the database
		while true do
			app.myTrxUA.trxUpdateTIDimensionsToDo(	prxyTI, _toDoTaskCode, _addCompRemTodo, null, TI_UPDMODE_NORMAL, null, app.myPassport	);
			
			if app.myPassport.trxCompletedOK then
				return true;
			else
				//If there were warnings, give the user a chance to see them. If there are no errors they may decide to acknowledge
				//them and update anyway.
				result := app.showErrorWarningDialog('Tracked Item Update', app.myPassport, ErrWarnMode_Add + ErrWarnMode_CanAckWarnings);
				if app.myPassport.noErrors and
				   result = IDOK then
					app.myPassport.warningsAcknowledged	:= true;
					continue;
				endif;
			endif;
			return false;
		endwhile;
	else
		return false;
	endif;
epilog

end;</source>
        <Parameter name="_length" type="Decimal"/>
        <Parameter name="_width" type="Decimal"/>
        <Parameter name="_height" type="Decimal"/>
        <Parameter name="_toDoTaskCode" type="Integer"/>
        <Parameter name="_addCompRemTodo" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="updateGrade" id="165c2993-f4bd-4469-a9b9-6d7abae98595">
        <updating/>
        <source>updateGrade(_ti : CM_TrackedItem input; _grade : CM_MTGrade) : Boolean updating;
/*
Date		Who		Reason
28 January 2009	cnwcp2	Initial creation
19 Aug 2013 cnwer1	PAR 32261
*/

vars
	result		: Integer;
	tmpGrade	: Integer;
begin

	if _grade = null then
		//checked in form already - msg boxes should only be in app
		//app.msgBox("Error: No Grade has been selected","Error", MsgBox_OK_Only);
		return false;
	endif;

	
	if _ti = null then
		//checked in form already - msg boxes should only be in app
		//app.msgBox("Error: No Container is selected","Error", MsgBox_OK_Only);
		return false;
	endif;
	
	tmpGrade := _ti.getAvailabilityGrade;
	
	if _grade.code = tmpGrade then
		// already set. - checked in form already - msg boxes should only be in app
		//app.msgBox("Error: The selected container already has this grade selected." &amp; CrLf &amp; "Aborting update","Grade already set", MsgBox_OK_Only);
		return false;
	endif;
	
	app.myPassport.clearErrorsWarnings();
	while true do
		//Do the Update
		app.myTrxUA.trxUpdateTIAvailabilityGrade(_ti, _grade.code, app.myPassport);
		
		if app.myPassport.trxCompletedOK then
			app.myPassport.clearErrorsWarnings();
			return true;
		else
			//If there were warnings, give the user a chance to see them. If there are no errors they may decide to acknowledge
			//them and update anyway.
			result := app.showErrorWarningDialog('Reading', app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and result = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		return false;
	endwhile;	
		
epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem" usage="input"/>
        <Parameter name="_grade" type="CM_MTGrade"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="updateSeals" id="ac9f2c7a-bc2f-4220-9122-979c3b4550a6">
        <updating/>
        <source>updateSeals(_customs, _operator, _shipper, _vent : String; _toDoTaskDesc : CM_ToDoTaskDesc; _addingToDo : Boolean) : Boolean updating;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08/02/2010	cnwdap1	Initial creation CCMS 1007 handheld updates
25/03/2010	cnwdap1	PAR #23369 adding to do parameters and handling
31/03/2010	cnwdap1	PAR #23509 Prevent 1090 when _toDoTaskDesc is null
// 13 May 2016	cnwns1	TFS 488 - Multi Timezone Support
// 07 Jun 2017	cnwrs1	TFS 4462 SNO add Terminal Operator, Unknown Seal and support multiple seals
*/
vars
	prxyTI			: CM_TrackedItem;
	result			: Integer;
	toDoTaskCode	: Integer;

begin
	// get the proxy TI
	prxyTI := self.getMyProxy();
	
	// PAR #23509
	if _toDoTaskDesc &lt;&gt; null then
		toDoTaskCode := _toDoTaskDesc.code;
	endif;
	
	if prxyTI &lt;&gt; null and CM_Container.hasInstance(prxyTI) then
		
		// update the seals information
	/*	prxyTI.CM_Container.setSealDetails(_operator, app.actualTimeAppServer, false);
		prxyTI.CM_Container.setSealNumCustoms(_customs);
		prxyTI.CM_Container.setSealNumShippers(_shipper);
		prxyTI.CM_Container.setSealNumVent(_vent); */
		
		//16 Sep 2010	NDL	Par 25608	- Use new CM_SealTI structure.
		prxyTI.createProxySealTIsFromRawData(	_operator,	//_sealNum : String;
												null,	//_prevSealNum : String;
												_shipper,	//_sealNumShippers : String;
												_vent,	//_sealNumVent : String;
												_customs,	//_sealNumCustoms : String;
												null,
												null,
												app.actualTimeServer	//_now : TimeStamp	// 13 May 2016	cnwns1	TFS 488 - Multi Timezone Support
												);
		
		app.myPassport.clearErrorsWarnings();

		// The Proxy is updated, including the stops , so now update the database
		while true do
			app.myTrxUA.trxUpdateTISealsToDo(prxyTI,
											//_toDoTaskDesc.code,	// PAR #23509
											toDoTaskCode,			// PAR #23509
											_addingToDo,
											null,
											TI_UPDMODE_NORMAL, 
											null,
											app.myPassport);
			
			if app.myPassport.trxCompletedOK then
				return true;
			else
				//If there were warnings, give the user a chance to see them. If there are no errors they may decide to acknowledge
				//them and update anyway.
				result := app.showErrorWarningDialog('Tracked Item Update', app.myPassport, ErrWarnMode_Add + ErrWarnMode_CanAckWarnings);
				if app.myPassport.noErrors and
				   result = IDOK then
					app.myPassport.warningsAcknowledged	:= true;
					continue;
				endif;
			endif;
			return false;
		endwhile;
	else
		return false;
	endif;
epilog

end;</source>
        <Parameter name="_customs" type="String"/>
        <Parameter name="_operator" type="String"/>
        <Parameter name="_shipper" type="String"/>
        <Parameter name="_vent" type="String"/>
        <Parameter name="_toDoTaskDesc" type="CM_ToDoTaskDesc"/>
        <Parameter name="_addingToDo" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="updateSpecialLifts" id="85dd2b67-d1d1-4b97-bc8a-fad2f16a4964">
        <source>updateSpecialLifts(_specialLifts : CM_SpecialLiftByCodeDict; _toDoTask : CM_ToDoTaskDesc; _addCompRemTodo : Integer) : Boolean;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
31 May 2010	cnwndl1	Initial creation	Par 23903

*/

vars
	pxyTI : CM_TrackedItem;
	result : Integer;
	extraParams	 : CMIF_TIUpdateExtraParams;
	txnControllerDict : CMIF_TITxnContrlrByTypeDTDict;

begin
	// get the proxy TI
	pxyTI := self.getMyProxy();
	
	if pxyTI = null then
		return false;
	
	else
		
		// update the sprcial lifts information
		create extraParams;
		pxyTI.zSetPxySpecialLifts( _specialLifts );
		
		while true do
			delete txnControllerDict;
			create txnControllerDict transient;
			
			if _toDoTask &lt;&gt; null then
				if _addCompRemTodo = 1 then	//16 Mar 2016	NDL TFS 1673
					extraParams.allTasksToAdd.add(_toDoTask.code);
				elseif _addCompRemTodo = 2 then //16 Mar 2016	NDL TFS 1673
					extraParams.allTasksToComplete.add(_toDoTask.code);
				elseif _addCompRemTodo = 3 then //16 Mar 2016	NDL TFS 1673
					extraParams.allTasksToRemove.add(_toDoTask.code);
				endif;
				extraParams.hasEditedToDoTasks := true;
			endif;
			
			app.myTrxUA.trxUpdateTIandExtraInfo(pxyTI, 
												TI_UPDMODE_NORMAL, 
												extraParams,
												txnControllerDict, 
												null,
												app.myPassport);			
			
			if app.myPassport.trxCompletedOK() then
				app.myPassport.clearErrorsWarnings();
				
				return true;
			else
				result := app.showErrorWarningDialog(app.getErrorString(Cargo_item_update), app.myPassport, ErrWarnMode_Add + ErrWarnMode_CanAckWarnings);
				if app.myPassport.noErrors and
				   result = IDOK then
					app.myPassport.warningsAcknowledged	:= true;
					continue;
				endif;
	
				app.myPassport.clearErrorsWarnings();
				return false;
				
			endif;
			
		endwhile;
		
		return false;
		
	endif;
epilog
	delete txnControllerDict;
	delete extraParams;
end;</source>
        <Parameter name="_specialLifts" type="CM_SpecialLiftByCodeDict"/>
        <Parameter name="_toDoTask" type="CM_ToDoTaskDesc"/>
        <Parameter name="_addCompRemTodo" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="updateStops" id="7316591a-ca1a-4172-9319-5bc5389b0888">
        <source>updateStops(_ti : CM_TrackedItem input; _table : Table input ; _fieldNames : IntegerArray; _fieldValues : StringArray ) : Boolean;
// ---------------------------------------------------------------------------
// Created:	16 January 2009 By Graeme Black cnwgb1
// Purpose:	Update any stops that have been edited in a Stop table such as the 
//          one on the MOB_HandHeldStopssForm. 
// 	        Created to handle the "Save" Button of that form.
//			PNL CCMS 1658 PAR 18787
// 23/06/16	cnwer1 TFS 1013 changes for TFS 1013 webservice and hh share common update method now
// ---------------------------------------------------------------------------
vars
	index : Integer;
	isSet,
	stopExist : Boolean;
	requiredInfo : String;
	stopID : Integer;
	result : Integer;
	allCMIFStops : CMIF_Array;
	cmifStop		: CMIF_CargoStop;
	stopTable : CM_StopsTable;
	idx : Integer;
begin
	//We update the proxy. As well as the Stops, we are potentially editing the tracked
	//item  because some stops require this information to be stored as well.
	if _ti = null then
		return false;
	endif;
	
	//epr TFS 1013 refactored to reuse new update method which is available on web
	create allCMIFStops transient;
	foreach index in 1 to _table.rows do
		stopID := _table.accessCell( index, 3 ).text.Integer;
		stopTable:=app.myRoot.allStopsTable[stopID];
		if stopTable = null then
			continue;
		endif;
		requiredInfo:=null;	
		stopExist	:= _ti.isStopSet( stopID );
		if stopExist and _table.accessCell( index, 1 ).text = "0" then			//Removed it
			isSet:=false;
			if stopTable.requiresInfoType &lt;&gt; 0 then
				idx :=_fieldNames.indexOf(stopTable.requiresInfoType);
				if idx &lt;= _fieldValues.size then
					requiredInfo:=_fieldValues[idx];
				endif;
			endif;
		elseif not stopExist and _table.accessCell( index, 1 ).text = "1" then	//Added it
			isSet :=true;
		else
			continue;
		endif;
		create cmifStop transient;
		cmifStop.setForCargoStopUpdate(stopID,isSet,requiredInfo);
		allCMIFStops.add(cmifStop);
	endforeach;
	
	if allCMIFStops.isEmpty then
		return true;
	endif;
	
	// The Proxy is updated, including the stops , so now update the database
	while true do
		app.myTrxUA.trxUpdateCargoStops(_ti,	allCMIFStops,						
										app.myPassport);
		
		if app.myPassport.trxCompletedOK then
			return true;
		else
			//If there were warnings, give the user a chance to see them. If there are no errors they may decide to acknowledge
			//them and update anyway.
			result := app.showErrorWarningDialog('Cargo Stop Update', app.myPassport, ErrWarnMode_Add + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   result = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		return false;
	endwhile;
	
	return true;
epilog
	
	if allCMIFStops &lt;&gt; null then
		allCMIFStops.purge;
	endif;
	delete allCMIFStops;
	
end;</source>
        <Parameter name="_ti" type="CM_TrackedItem" usage="input"/>
        <Parameter name="_table" type="Table" usage="input"/>
        <Parameter name="_fieldNames" type="IntegerArray"/>
        <Parameter name="_fieldValues" type="StringArray"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="updateTIConnection" id="c25bee8e-5248-4382-acfd-ed3174b5761b">
        <updating/>
        <source>updateTIConnection(_ti : CM_TrackedItem/*CM_Container*/ input;  _noCharge, _connect : Boolean; _powerPoint : CM_GapController) : Boolean updating;
/*
Connects or disconnects a Tracked Item from _powerPoint

Date		Who		Reason
26/01/2009	cnwcp2	Initial creation
11/12/209	cnwdap1	CCMS MES 1007 Any tracked item can now be a reefer, not just containers
						Changed method signature 
08/04/2011	cnwmh5	PAR #27347 - Add cmsEndLoad or endLoad to epilog so that if error occurs it will not leave it in beginLoad state
// 13 May 2016	cnwns1	TFS 488 - Multi Timezone Support
*/

vars
	connectParams			: CMIF_ConnectParams;
	nowTimeStamp,
	connectTimeStamp		: TimeStamp;
	//proxyCOU,
	aDate					: Date;
	aTime					: Time;
	aURNumber				: String;
	txn						: CM_TITransaction;
	action,result			: Integer;
begin
	app.mousePointer := Window.MousePointer_HourGlass;
	if _ti = null then
		// Message boxes should only be in the app. Moved down, checks done on form
		//app.msgBox("Error: Please select a Container first", "Error", MsgBox_OK_Only);
		return false;
	endif;
	
	// Check to see if this container has been connected/disconnected already elsewhere
	if _ti.isConnected = _connect then
		// Message boxes should only be in the app. Moved down, checks done on form
		//app.msgBox("This Container's Connection status has been updated already. The window will now refresh", "Error", MsgBox_OK_Only);
		return false;
	endif;
	
	on CM_Exception do app.validationExHandler(exception, app.myPassport);
	app.setContinueCMExceptions(true);
	app.myPassport.clearErrorsWarnings();
	
	nowTimeStamp := app.actualTimeServer;	// 13 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	
	aDate := app.actualTimeServer.Date;	// 13 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	aTime := app.actualTimeServer.Time;	// 13 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	
	if _connect then
		action := ACTION_CONNECT;
	else
		action := ACTION_DISCONNECT;
	endif;
	//must be at the end of the minute to pass validation as we only accept input to the minute (no seconds)
	
//	aTime.setTime(aTime.hour, aTime.minute, 59, 999);
	//aURNumber := app.//self.tblData.getValueByName(ETRow_UserRequestNumber).String;
	
	if aDate.isValid() then
		connectTimeStamp.setDate(aDate);
		if aTime.isValid() then
			connectTimeStamp.setTime(aTime);
		else
			connectTimeStamp := nowTimeStamp;
		endif;
	else
		connectTimeStamp := nowTimeStamp;
	endif;

	create connectParams transient;
	//epr par 36103 23/4/15 nolonger have to proxy
	connectParams.allTrackedItems.add(_ti);
	//check time stamp will be after the last txn on the _ti
	//have to do this to prevent on going time comaprison errors introduced
	//with the Time EditMask changes (i.e. uses can't input seconds!)
	txn := _ti.allTransactions.last;
	if txn &lt;&gt; null
	and txn.dateTime &gt; connectTimeStamp then
		if txn.dateTime.date = connectTimeStamp.date
		and txn.dateTime.time.hour = connectTimeStamp.time.hour
		and txn.dateTime.time.minute = connectTimeStamp.time.minute then
			//bump it by 1
			connectTimeStamp.setTime(txn.dateTime.time.addSeconds(1));
		endif;
	endif;

	connectParams.dateTime := connectTimeStamp;
	connectParams.noCharge := _noCharge;
	connectParams.myTerminal := _ti.myTerminal;
//	the following is set in the trx when allTrackedItems is used or below for COUs	
//	connectParams.myOtherTrackedItem := self.myTrackedItem.getOtherTrackedItem(self.action);
	connectParams.myTrackedItem := _ti;
	if connectParams.myTrackedItem &lt;&gt; null then
		connectParams.locationsController := connectParams.myTrackedItem.myPrimaryActualLocation; // AKB2004AUG added
	endif;

	connectParams.userId := app.getMyUserCode();
	connectParams.action := action;
	
	connectParams.gapController := _powerPoint; 
	
// All of these below are not set anywhere in this app. TODO: Check that default values are alright
	connectParams.urNumber := null; //aURNumber	
	connectParams.radioTelemetryIgnoreWarnings := true;
	connectParams.radioTelemetryUser := false;
			
	while true do
		//Do the Connection
		if action = ACTION_CONNECT then
			app.myTrxUA.trxUpdateConnect(connectParams, app.myPassport);	
		else
			app.myTrxUA.trxUpdateDisconnect(connectParams, app.myPassport);	
		endif;
		
		if app.myPassport.trxCompletedOK then
			app.myPassport.clearErrorsWarnings();
			return true;
		else
			//If there were warnings, give the user a chance to see them. If there are no errors they may decide to acknowledge
			//them and update anyway.
			result := app.showErrorWarningDialog('Connection', app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and result = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		return false;
	endwhile;
	
epilog	

	delete connectParams;
	app.mousePointer := Window.MousePointer_Default;
end;</source>
        <Parameter name="_ti" type="CM_TrackedItem" usage="input"/>
        <Parameter name="_noCharge" type="Boolean"/>
        <Parameter name="_connect" type="Boolean"/>
        <Parameter name="_powerPoint" type="CM_GapController"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="updateTIToDoTaskCmpltBulk" id="5cc3ac06-287a-4343-a617-8da734529880">
        <source>updateTIToDoTaskCmpltBulk(_toDoTaskDesc : CM_ToDoTaskDesc;
							_tiSet 		: CM_TISet input;
							_resourceUsageProxys : CM_ResourceTypeUsageSet input):Boolean;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
17 February 2010	#cnwdz2	 

*/

vars
	result				: Integer;
begin
	while true do	
		app.myTrxUA.trxUpdateTIToDoTaskCmpltBulk(_toDoTaskDesc, _tiSet, _resourceUsageProxys, app.myPassport);
		
		if app.myPassport.trxCompletedOK then
			app.myPassport.clearErrorsWarnings();
			return true;
		else
			//If there were warnings, give the user a chance to see them. If there are no _errors they may decide to acknowledge
			//them and update anyway.
			result := app.showErrorWarningDialog("", app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and result = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		return false;
	endwhile;
	
epilog

end;</source>
        <Parameter name="_toDoTaskDesc" type="CM_ToDoTaskDesc"/>
        <Parameter name="_tiSet" type="CM_TISet" usage="input"/>
        <Parameter name="_resourceUsageProxys" type="CM_ResourceTypeUsageSet" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="updateTasks" id="149345da-0de1-4c88-b254-6645a7b125ca">
        <source>updateTasks( _table : Table input ; _ti : CM_TrackedItem io) : Boolean;
// ---------------------------------------------------------------------------
// Created:	21 January 2009 By Graeme Black cnwgb1
// Purpose:	Update any tasks that have been edited in a Task table such as the 
//          one on the MOB_HandHeldTasksForm. 
// 	        Created to handle the "Save" Button of that form.
//			PNL CCMS 1658 PAR 18787
// ---------------------------------------------------------------------------
vars
	index : Integer;
	toAdd : IntegerArray;
	toComplete : IntegerArray;
	toRemove : IntegerArray;
	toCheckDate : IntegerArray;
	toUpdateDate : TimeStampArray;
	toCheckRemarks : IntegerArray;
	allRemarks : HugeStringArray;
	taskDesc : CM_ToDoTaskDesc;
	result : Integer;
	timeStamp : TimeStamp;
	debugStr : String;
	hasToDoTask : Boolean;
	tblRow : Integer;
	toDoTask : CM_ToDoTask;
	remarks : String;
	msg : String;
	doRemarks : Boolean;
begin
	create toAdd transient;
	create toComplete transient;
	create toRemove transient;
	create toCheckDate transient;
	create toUpdateDate transient;
	create toCheckRemarks transient;
	create allRemarks transient;
	
	doRemarks := _table.columns &gt;= 5;
	//First determine which Tasks have changed, and what we need to do
	foreach index in 2 to _table.rows do
		taskDesc := _table.accessCell(index,1).itemObject.CM_ToDoTaskDesc;
		hasToDoTask :=  _ti.allToDoTasksToDo.includesToDoDesc(taskDesc.code);
		if doRemarks then
			remarks := _table.accessCell(index,5).text.trimBlanks;
		endif;
		if _table.accessCell(index, 3).text = "1" then
			if not hasToDoTask then	
				toAdd.add(taskDesc.code);
			endif;
			toComplete.add( taskDesc.code );
			toCheckDate.add( index );
			
		elseif _table.accessCell(index, 2).text = "1" then
			if not hasToDoTask then
				toAdd.add(taskDesc.code);
			endif;
			toCheckRemarks.add( index );
			allRemarks.add( remarks );
			
		elseif _table.accessCell(index, 2).text &lt;&gt; "1" then
			if hasToDoTask then
				toRemove.add(taskDesc.code);
			else
			//	if remarks &lt;&gt; null then
				if _table.accessCell(index, 4).text.trimBlanks = null and remarks &lt;&gt; null then	//08 Dec 2015	NDL	Par 
					//Has 'remarks' set, but no date completed and not set...
					msg := app.getErrorString1(Not_updat_remar_task_when_not,_table.accessCell(index,1).text);
					app.msgBox( msg, app.getErrorString(Error), MsgBox_OK_Only );
					return false;
				endif;
			endif;
			
		endif;
		
	endforeach;
	
	//If nothing has changed, get out
	if toAdd.isEmpty() and toComplete.isEmpty() and toRemove.isEmpty() and toCheckRemarks.isEmpty then
		return true;
	endif;

	//For those tasks which have been completed, check if there is a completion date other than current
	foreach index in 1 to toCheckDate.size do
		if _table.accessCell(toCheckDate[index], 4).text &lt;&gt; _table.accessCell(toCheckDate[index], 6 ).text then
			debugStr := _table.accessCell(toCheckDate[index], 4 ).text;
			//toUpdateDate.add(_table.accessCell(toCheckDate[index], 4 ).text.asTimeStampJMT());
			toUpdateDate.add(debugStr.asTimeStampJMT());
		else
			toUpdateDate.add(null);
		endif;
	endforeach;
	app.myPassport.clearErrorsWarnings();

	while true do
		//Update the Tasks
		app.myTrxUA.trxUpdateTIToDoTasks( toAdd, toComplete, toRemove, _ti, app.myPassport);
		
		//Update any timestamps the user manually updated
		if app.myPassport.trxCompletedOK then
			foreach index in 1 to toUpdateDate.size do
				if toUpdateDate[index] &lt;&gt; null then
					app.myTrxUA.trxUpdateToDoTaskTimeStamp(
						toComplete[index], 
						toUpdateDate[index], 
						_ti, app.myPassport );
				endif;
			endforeach;
			
			//11 Nov 2015	NDL	Par 37171
			if doRemarks and not toCheckRemarks.isEmpty then
				foreach index in 1 to toCheckRemarks.size do
					tblRow := toCheckRemarks[index];
					if tblRow &lt;= _table.rows then
						taskDesc := _table.accessCell(tblRow,1).itemObject.CM_ToDoTaskDesc;
						if taskDesc = null then
							continue;
						endif;
						toDoTask := _ti.allToDoTasksToDo.getToDoTask(taskDesc.code);
						if toDoTask = null then
							continue;
						endif;
						remarks := allRemarks[index];
						app.myTrxUA.trxUpdateTaskRemarks(remarks, toDoTask, app.myPassport);
					endif;
				endforeach;
			endif;
				
		endif;
		
		if app.myPassport.trxCompletedOK then
			return true;
		else
			//If there were warnings, give the user a chance to see them. If there are no errors they may decide to acknowledge
			//them and update anyway.
			result := app.showErrorWarningDialog('Tracked Item Update', app.myPassport, ErrWarnMode_Add + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   result = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		return false;
	endwhile;

epilog
	delete toAdd;
	delete toRemove;
	delete toComplete;
	delete toUpdateDate;
	delete toCheckDate;
	delete toCheckRemarks;
	delete allRemarks;
	
end;</source>
        <Parameter name="_table" type="Table" usage="input"/>
        <Parameter name="_ti" type="CM_TrackedItem" usage="io"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="updateTemperatureOfProxy" id="810f9692-8447-49a8-b7ba-b8caa9e5ff26">
        <updating/>
        <source>updateTemperatureOfProxy(_noCharge : Boolean; _newTemp : String; _newHumidity : Decimal; _newVentilation : Real) : Boolean updating;
/*

Date		Who		Reason
26/01/2009	cnwcp2	Initial creation
11/12/2009	cnwdap1	CCMS MES 1007 Reefer properties are now associated with CM_TrackedItem, nor CM_Container
19/03/2015	cnwdap1 PAR #35874 TFS 265 Added humidity and ventilation parameters and updates, changed _newTemp to string

Uses the myProxyObject reference as the Container that is being updated with the new temperature.
13/05/2016	cnwns1	TFS 488 - Multi Timezone Support
03/10/2017	jlgdap1	TFS 7204 STWR Correct real handling for non-standard locales
27/09/2021	navdap1	TFS 52081 MTN Cannot Add Reading for a Reefer for a time other than Now
16/01/2026	navdap1	MTN-36569 CPL | Reefer Runner Integration
*/

vars
	//ti 				: CM_Container;		// CCMS 1007
	ti 					: CM_TrackedItem;	// CCMS 1007
	timeStmp			: TimeStamp;
	tempReadingParams	: CMIF_TempReading;
	humidReadingParams	: CMIF_HumidReading;			// PAR #35874
	ventReadingParams	: CMIF_VentReading;				// PAR #35874
	measure				: CM_MeasurementType;			// PAR #35874
	loadState			: Boolean;
	isFah				: Boolean;
	result				: Integer;
	tempTemp : Real; 
begin
	//ti := self.myProxyObject.CM_Container;	// CCMS 1007
	ti := self.myProxyObject.CM_TrackedItem;	// CCMS 1007
	// Check made in form, but double check here. Msgboxes should only be displayed by the app
	if ti = null or not ti.pxyIsProxy then
		//app.msgBox("Error: Please select a Container first", "Error", MsgBox_OK_Only);
		return false;
	endif;
	
	timeStmp.setDate(app.actualTimeServer.date);	// 13 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	timeStmp.setTime(app.actualTimeServer.time);	// 13 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	
	if _newTemp &lt;&gt; null then												// PAR #35874
		create tempReadingParams transient;	
	/*	tempReadingParams.dateTime := timeStmp;
		tempReadingParams.noCharge := _noCharge;
		tempReadingParams.userId := app.getMyUserCode();
		tempReadingParams.myTerminal := ti.myTerminal;
		
		// All of these below are not set anywhere in this app. TODO: Check that default values are alright
		tempReadingParams.isRefConReading := false;
		tempReadingParams.isRefConAlarm := false;
		tempReadingParams.refConRawData := null; */
	endif;																	// PAR #35874
	if _newHumidity &lt;&gt; null then											// PAR #35874
		create humidReadingParams transient;								// PAR #35874
		humidReadingParams.myTrackedItem := ti;								// PAR #35874
		humidReadingParams.dateTime := timeStmp;							// PAR #35874
		humidReadingParams.noCharge := _noCharge;							// PAR #35874
		humidReadingParams.userId := app.getMyUserCode();					// PAR #35874
		humidReadingParams.myTerminal := ti.myTerminal;						// PAR #35874
		humidReadingParams.setHumidity( _newHumidity );						// PAR #35874
	endif;																	// PAR #35874
	if _newVentilation &lt;&gt; null then											// PAR #35874
		measure := app.getDefaultMeasurementForType(Type_Displacement);		// PAR #35874
		create ventReadingParams transient;									// PAR #35874
		ventReadingParams.myTrackedItem := ti;								// PAR #35874
		ventReadingParams.dateTime := timeStmp;								// PAR #35874
		ventReadingParams.noCharge := _noCharge;							// PAR #35874
		ventReadingParams.userId := app.getMyUserCode();					// PAR #35874
		ventReadingParams.myTerminal := ti.myTerminal;						// PAR #35874
		ventReadingParams.ventilation := app.convertMeasurementForStorage(measure.shortName, _newVentilation.Decimal);	// PAR #35874
	endif;																	// PAR #35874
	
//	tempReadingParams.urNumber := ;
//	tempReadingParams.action := self.action;
				
	isFah  := false;
	if ti &lt;&gt; null then	
		
		if tempReadingParams &lt;&gt; null then									// PAR #35874
		//	tempReadingParams.myTrackedItem := ti;
		//	tempReadingParams.noCharge := ti.noChargeForTemperature(_noCharge, timeStmp);
			if isFah then
				//tempReadingParams.temperature := app.temperatureConversion(false, _newTemp.Real);	// PAR #35874	// TFS 7204
			//	tempReadingParams.temperature := app.temperatureConversion(false, _newTemp.asRealJMT);				// TFS 7204
				tempTemp := app.temperatureConversion(false, _newTemp.asRealJMT);	//01 Sep 2021	NDL	TFS 51874
			else
				//tempReadingParams.temperature := _newTemp.Real;									// PAR #35874	// TFS 7204
			//	tempReadingParams.temperature := _newTemp.asRealJMT;												// TFS 7204
				tempTemp := _newTemp.asRealJMT;	//01 Sep 2021	NDL	TFS 51874
			endif;
			//01 Sep 2021	NDL	TFS 51874 - Use common code instead of 14 different variant copies....
			tempReadingParams.initialise(	ti,	//_reefer : CM_TrackedItem;
											_noCharge,	//_defaultNoChargeValue : Boolean;
											timeStmp,	//_dateTime : TimeStamp;		// TFS 52081
											tempTemp	//_temperature : Real
											);
		endif;																// PAR #35874
		app.myPassport.clearErrorsWarnings();
		
		while true do
			//Do the Reading
			app.myTrxCA.trxCreateReeferReadings(tempReadingParams, humidReadingParams, ventReadingParams, null, null, null, app.myPassport);	// MTN-36569
			
			if app.myPassport.trxCompletedOK then
				app.myPassport.clearErrorsWarnings();
				return true;
			else
				//If there were warnings, give the user a chance to see them. If there are no errors they may decide to acknowledge
				//them and update anyway.
				result := app.showErrorWarningDialog('Reading', app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
				if app.myPassport.noErrors and result = IDOK then
					app.myPassport.warningsAcknowledged	:= true;
					continue;
				endif;
			endif;
			return false;
		endwhile;	
	endif;
	
epilog
	delete tempReadingParams;
	delete humidReadingParams;				// PAR #35874
	delete ventReadingParams;				// PAR #35874
end;</source>
        <Parameter name="_noCharge" type="Boolean"/>
        <Parameter name="_newTemp" type="String"/>
        <Parameter name="_newHumidity" type="Decimal"/>
        <Parameter name="_newVentilation" type="Real"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="updateTemperatureReading" id="2345783a-3ade-4e79-b102-1d56844e25b1">
        <source>updateTemperatureReading(_temperature : Real; _toDoTask : CM_ToDoTaskDesc; _addingToDo : Boolean) : Boolean;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 23/04/2015	cnwdap1		Initial creation PAR #36094 CCMS SFW 1413 TFS 313 Cold Store Enhancements
// 27/09/2021	navdap1		TFS 52081 MTN Cannot Add Reading for a Reefer for a time other than Now
// 16/01/2026	navdap1		MTN-36569 CPL | Reefer Runner Integration
//
vars
	pxyTI		: CM_TrackedItem;
	result		: Integer;
	controller	: CMIF_TIUpdateController;
	toDoCode	: Integer;
	tempParams 	: CMIF_TempReading;

begin
	// get the proxy TI
	pxyTI := self.getMyProxy();
	
	// PAR #23509
	if _toDoTask &lt;&gt; null then
		toDoCode := _toDoTask.code;
	endif;
	
	if pxyTI &lt;&gt; null and CM_TrackedItem.hasInstance(pxyTI) then
		
		// create a temperature reading
		create tempParams transient;
	/*	tempParams.isRefConReading := false;
		tempParams.isRefConAlarm := false;
		tempParams.refConRawData := null;
		tempParams.dateTime := app.actualTimeServer;
		tempParams.noCharge := pxyTI.noChargeForTemperature(false, tempParams.dateTime);
		tempParams.userId := app.getMyUserCode;
		tempParams.myTerminal := pxyTI.myTerminal;
		tempParams.myTrackedItem := pxyTI;
		tempParams.temperature := _temperature; */
		
		//01 Sep 2021	NDL	TFS 51874 - Use common code instead of 14 different variant copies....
		tempParams.initialise(	pxyTI,	//_reefer : CM_TrackedItem;
								false,	//_defaultNoChargeValue : Boolean;
								app.actualTimeServer,	//_dateTime : TimeStamp;		// TFS 52081
								_temperature	//_temperature : Real
								);
	
		app.myPassport.clearErrorsWarnings();

		while true do
			app.myTrxCA.trxCreateReeferReadings(tempParams, null, null, null, null, null, app.myPassport);		// MTN-36569
			
			if app.myPassport.trxCompletedOK then
				return true;
			else
				//If there were warnings, give the user a chance to see them. If there are no errors they may decide to acknowledge
				//them and update anyway.
				result := app.showErrorWarningDialog(app.getErrorString(Cargo_item_update), app.myPassport, ErrWarnMode_Add + ErrWarnMode_CanAckWarnings);
				if app.myPassport.noErrors and
				   result = IDOK then
					app.myPassport.warningsAcknowledged	:= true;
					continue;
				endif;
			endif;
			return false;
		endwhile;
	else
		return false;
	endif;
epilog
	delete controller;
end;</source>
        <Parameter name="_temperature" type="Real"/>
        <Parameter name="_toDoTask" type="CM_ToDoTaskDesc"/>
        <Parameter name="_addingToDo" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="updateTiToDoTask" id="a1c8abd3-16b7-4538-a767-8bae783f54f8">
        <updating/>
        <source>updateTiToDoTask(_toDoTaskCode : Integer; _addingTask : Boolean) : Boolean updating;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 February 2010	cnwdap1	Initial creation
*/
vars
	ti		: CM_TrackedItem;
	result	: Integer;

begin
	// get the TI
	ti := self.mySelectedTI;
	
	if ti &lt;&gt; null then
		
		app.myPassport.clearErrorsWarnings();

		// update the database
		while true do
			if _addingTask then
				app.myTrxUA.trxUpdateTIToDoTaskAdd(	ti,	_toDoTaskCode, app.myPassport);
			else
				app.myTrxUA.trxUpdateTIToDoTaskRemove(ti, _toDoTaskCode, app.myPassport);
			endif;
			
			if app.myPassport.trxCompletedOK then
				return true;
			else
				//If there were warnings, give the user a chance to see them. If there are no errors they may decide to acknowledge
				//them and update anyway.
				result := app.showErrorWarningDialog('Tracked Item Update', app.myPassport, ErrWarnMode_Add + ErrWarnMode_CanAckWarnings);
				if app.myPassport.noErrors and
				   result = IDOK then
					app.myPassport.warningsAcknowledged	:= true;
					continue;
				endif;
			endif;
			return false;
		endwhile;
	else
		return false;
	endif;
epilog

end;</source>
        <Parameter name="_toDoTaskCode" type="Integer"/>
        <Parameter name="_addingTask" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="updateWeight" id="e3173c9b-b926-4156-8c3d-3ca94eba3866">
        <source>updateWeight(	_weight : Decimal;
				_cargoWeight : Decimal;	//26 Jan 2018	NDL	TFS 36697
				_tareWeight : Decimal;	//26 Jan 2018	NDL	TFS 36697
				_certified : Boolean;
				_toDoTask : CM_ToDoTaskDesc;
				_addingToDo : Boolean
				) : Boolean;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25/03/2010	cnwdap1	Initial creation PAR #23369
31/03/2010	cnwdap1	PAR #23509 Stop 1090 errors when no _toDoTask passed in
02/06/2010	NDL		Par 23860 - change CM_Container to CM_TrackedItem
*/
vars
	prxyTI		: CM_TrackedItem;
	result		: Integer;
	controller	: CMIF_TIUpdateController;
	toDoCode	: Integer;		// PAR #23509

begin
	// get the proxy TI
	prxyTI := self.getMyProxy();
	
	// PAR #23509
	if _toDoTask &lt;&gt; null then
		toDoCode := _toDoTask.code;
	endif;
	
	if prxyTI &lt;&gt; null and CM_TrackedItem.hasInstance(prxyTI) then
		
		// update the weight information
		controller := app.createTIUpdateControl(TI_UPDMODE_NORMAL, app.myPassport.userCode, null);
		prxyTI.setTotalWeightAndCertified(_weight, _cargoWeight, _tareWeight, _certified, controller, app.myPassport);
		
		app.myPassport.clearErrorsWarnings();

		// The Proxy is updated, including the stops , so now update the database
		while true do
			app.myTrxUA.trxUpdateTIWeightToDo(	prxyTI,
												//_toDoTask.code,	// PAR #23509
												toDoCode,			// PAR #23509
												_addingToDo,
												false,	//_weighTrx : Boolean;	//13 Mar 2014	NDL	Par 33268
												null,
												TI_UPDMODE_NORMAL, 
												null,
												false,
												app.myPassport);
			
			if app.myPassport.trxCompletedOK then
				return true;
			else
				//If there were warnings, give the user a chance to see them. If there are no errors they may decide to acknowledge
				//them and update anyway.
				result := app.showErrorWarningDialog(app.getErrorString(Cargo_item_update), app.myPassport, ErrWarnMode_Add + ErrWarnMode_CanAckWarnings);
				if app.myPassport.noErrors and
				   result = IDOK then
					app.myPassport.warningsAcknowledged	:= true;
					continue;
				endif;
			endif;
			return false;
		endwhile;
	else
		return false;
	endif;
epilog
	delete controller;
end;</source>
        <Parameter name="_weight" type="Decimal"/>
        <Parameter name="_cargoWeight" type="Decimal"/>
        <Parameter name="_tareWeight" type="Decimal"/>
        <Parameter name="_certified" type="Boolean"/>
        <Parameter name="_toDoTask" type="CM_ToDoTaskDesc"/>
        <Parameter name="_addingToDo" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
