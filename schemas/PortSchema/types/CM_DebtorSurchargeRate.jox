    <JadeMethod name="validateMe" id="39ae7829-434f-4696-8d44-f9672b138717">
        <source>validateMe();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 March 2018	jlgndl1	Initial creation	TFS 37818

*/

vars

	realForCheck : CM_DebtorSurchargeRate;
	existing : CM_DebtorSurchargeRate;

begin

	if self.surchargeRate &lt;= 0 then
		app.raiseCMException(Surch_rate_must_great_than_zer, null,null);
	endif;

	if self.mySurchargeAndExemptions = null then
		app.raiseCMException(Current_surcharge_exemptions, null,null);
		return;
	endif;
	
	if self.getSurchargeInvoiceLineType = null then
		app.raiseCMException(Surcha_invoic_line_type_select, null,null);
		return;
	endif;
	
	if self.myDebtor = null then
		app.raiseCMException(INV_Please_Select_A_Debtor, null,null);
		return;
	endif;
	
	if self.isTransient then
		realForCheck := self.pxyGetRealObject();
	else
		realForCheck := self;
	endif;
	
	existing := self.mySurchargeAndExemptions.allDebtorSurchargeRates.getAtKey( self.myDebtor );
	if existing = null or existing = realForCheck then
		//we can carry on.
	else
		//This key is already used.
		app.raiseCMException(Surch_rate_alrea_exist_this_de, null,null);
		return;
	endif;

epilog

end;</source>
    </JadeMethod>
