    <JadeMethod name="handleBtnOne" id="ec6b974f-20aa-4f22-977b-f15fe48af999">
        <updating/>
        <source>handleBtnOne() updating, protected;
// ---------------------------------------------------------------------------
// Created:	31 December 2008 By Graeme Black cnwgb1
// Status: 	Unfinished
// Purpose:	
// ---------------------------------------------------------------------------
// 14/12/2009	cnwdap1		CCMS MES 1007 Any tracked item can now be a reefer, not just containers
vars
	
begin
		
	if self.myTrackedItem &lt;&gt; null then
		if lblStatus.caption = ConnectedStatusLabel then  // use the caption as otherwise this could be misleading to the user
		//if ti.isConnected then 
			self.doChangeConnectStatus(self.myTrackedItem,false);
		else
			self.doChangeConnectStatus(self.myTrackedItem,true);
		endif;
	endif;
	
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
