    <JadeMethod name="clearThumbnailData" id="bd399d09-7a36-4207-95f7-e78af9ed63f8">
        <updating/>
        <source>clearThumbnailData() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
07 August 2023		jlizm1	Initial creation TFS 59548 Kiosk maintenance locales

*/

vars
	theForm : SOP_TableMaintForm;
	
begin

	theForm := self.myForm;
	theForm.tblInput1.clearValues();
	theForm.mulSelect1.setSelected(null);
	theForm.txtTranslation.text := null;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="create" id="f452f81c-13fa-4eb8-867b-b516b2590b9e">
        <updating/>
        <source>create() updating;

/*
Date			Who		Reason
06 July 2009	cnwar2	Initial creation

*/
vars

begin
	self.name := SOP_TableMaintForm.Table_Kiosk;
	self.permissionView		:= PmAdmKioskView;	
	self.permissionMaint	:= PmAdmKioskMaint;
	self.myDataClass := CM_Kiosk;
end;</source>
    </JadeMethod>
    <JadeMethod name="displayTermsAndConditions" id="4b921810-618a-4ae0-a0c0-9cae6eb471d2">
        <source>displayTermsAndConditions();
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
11 August 2023		jlizm1	Initial creation TFS 59549 Kiosk maintenance terms and conditions

*/

vars
	theForm 	: SOP_TableMaintForm;
	kiosk 		: CM_Kiosk;
	locale 		: CM_Locale;
	xlat		: CM_KioskTranslation;
	
begin
	theForm := self.myForm;
	theForm.txtTranslation.text := "";
	
	if theForm.myProxyObject &lt;&gt; null then
		kiosk := theForm.myProxyObject.CM_Kiosk;
	elseif theForm.myCurrentObject &lt;&gt; null then
		kiosk := theForm.myCurrentObject.CM_Kiosk;
	endif;
	
	if kiosk = null or kiosk.myTermsAndConditions = null then
		return;
	endif;
	
	locale := theForm.cmbLocale2.listObject.CM_Locale;
	
	if locale = null then
		return;
	endif;
	
	xlat := kiosk.myTermsAndConditions.allTermsAndConditions[locale.localeId];
	
	if xlat = null then
		return;
	endif;
	
	theForm.txtTranslation.text := xlat.text;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doBtnSingle1Delete" id="75c33760-246f-4d8d-bfd0-c51af9ac2382">
        <updating/>
        <source>doBtnSingle1Delete() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
18 August 2023		jlizm1	Initial creation TFS 59550 Kiosk PPE Questions

*/

vars
	theForm 	: SOP_TableMaintForm;
	ppeQuestion : CM_KioskPPEQuestion;
	theResult 	: Integer;

begin
	theForm := self.myForm;
	if (theForm.myCurrentObject = null) then
		return;
	endif;
	if not theForm.myCurrentObject.isKindOf(CM_Kiosk) then
		return;
	endif;
	
	if theForm.lstSingleSelect1.listIndex &lt; 0 then
		return;
	endif;
	
	ppeQuestion := theForm.lstSingleSelect1.itemObject[theForm.lstSingleSelect1.listIndex].CM_KioskPPEQuestion;
	if ppeQuestion = null then
		return;
	endif;
	
	while true do
	
		app.myTrxDA.trxDeleteKioskObject(ppeQuestion,app.myPassport);
	
		if app.myPassport.trxCompletedOK then
			break;
		else
			theResult := app.showErrorWarningDialog('PPE Questions', app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and theResult = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		
		break;
		
	endwhile;
	
	theForm.lstSingleSelect1.listCollection(theForm.myCurrentObject.CM_Kiosk.allPPEQuestions, true, 0);

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doBtnSingle1Down" id="9a5a6690-8ae2-4402-8856-ff9d43748ef7">
