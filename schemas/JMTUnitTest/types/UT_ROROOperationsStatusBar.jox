    <JadeMethod name="xPAR31367StatusBarStepB6" id="7cf68873-e0f0-4d95-80dd-56b2f55e2ff2">
        <updating/>
        <source>xPAR31367StatusBarStepB6() updating;

/*

Purpose:		colour code load and check that status bar details are correct	

Date			Who		Reason
23/05/2013		cnwmh5	Initial creation

*/
constants

	ContainerPartialId					: String = 'UT31367';

vars

	port								: CM_Port;
	realAlloc							: CM_VoyageAllocation;
	cargo								: CM_TrackedItem;
	voyageJob							: CM_VoyageJob;
	locnDefnVoyage 						: CM_ROROLocnDefnVoyage;
	slotLC 								: CM_ROROSlotController;
	slotDefn 							: CM_ROROSlotDefn;
	layout								: CM_DeckItemLayout;
	cargoType							: CM_CargoType;
	locnGCDefnVoyage					: CM_ROROGCDefnVoyage;
	gcRequest							: CM_ROROGCRequest;
	location							: CM_ROROLocnDefn;
	
	roroLCsHold 						: CM_LCArray;
	altRoroLCs							: CM_LCArray;
	tiArray								: CM_TIArray;
	
	newPointsArray						: DecimalArray;
	
	index								: Integer;
	isoTypeStr							: String;
	locn								: String;
	
begin

	app.writeLog("STEP B6", LogINFO);
	app.writeLog("Colour coding Load.  Please wait.....", LogINFO);
	
	create roroLCsHold transient;
	create altRoroLCs transient;
	
	// colour code 20' locations
	app.writeLog("Colour coding Load 20'.  Please wait.....", LogINFO);
	port := app.myRoot.allPorts["ITGOA"];
	self.assertNotNull(port);
	
	self.locationArray.clear();
	self.locationArray.add("D4083");
	self.locationArray.add("D4086");
	self.locationArray.add("D4081");
	self.locationArray.add("D4074");
	self.locationArray.add("D4076");
	self.locationArray.add("D4071");
	
	self.roroLCs.clear();
	foreach locn in locationArray do
		locnDefnVoyage := self.myDeck.allROROLocnDefnByCode[locn].CM_ROROLocnDefnVoyage;
		self.assertNotEqual(locnDefnVoyage, null);
		foreach slotDefn in locnDefnVoyage.allROROSlotDefnByOrdinal discreteLock do
			slotLC := slotDefn.CM_ROROSlotDefnVoyage.mySlotController;
			if not slotLC.mySlotDefn.isAvailable then
				continue;
			endif;
			self.getJobROROControllerByID(self.myVoyage.code, self.myDeck.code, null, slotLC.ident, self.roroLCs, true, 1); 
		endforeach;
	endforeach;
	
	realAlloc := self.addVoyageAllocation(self.myVoyage, port.code, "U20G", "", TI_CargoType_Container, false, false);
	self.addLCsToROROAllocation(true, realAlloc, roroLCs, altRoroLCs,1);
	self.roroLCs.copy(roroLCsHold);
	
	// colour code 40' locations
	port := app.myRoot.allPorts["ITGOA"];
	self.assertNotNull(port);
	
	
	// colour code 40' locations
	app.writeLog("Colour coding Load 40'.  Please wait.....", LogINFO);
	self.locationArray.clear();
	self.locationArray.add("D4087");
	self.locationArray.add("D4085");
	self.locationArray.add("D4075");
	self.locationArray.add("D4077");
	
	self.roroLCs.clear();
	foreach locn in locationArray do
		locnDefnVoyage := self.myDeck.allROROLocnDefnByCode[locn].CM_ROROLocnDefnVoyage;
		self.assertNotEqual(locnDefnVoyage, null);
		foreach slotDefn in locnDefnVoyage.allROROSlotDefnByOrdinal discreteLock do
			slotLC := slotDefn.CM_ROROSlotDefnVoyage.mySlotController;
			if not slotLC.mySlotDefn.isAvailable then
				continue;
			endif;
			self.getJobROROControllerByID(self.myVoyage.code, self.myDeck.code, null, slotLC.ident, self.roroLCs, true, 1); 
		endforeach;
	endforeach;
	
	realAlloc := self.addVoyageAllocation(self.myVoyage, port.code, "U40G", "", TI_CargoType_Container, false, false);
	self.addLCsToROROAllocation(true, realAlloc, roroLCs, altRoroLCs,1);
	self.roroLCs.copy(roroLCsHold);
	
	// colour code gc area
	app.writeLog("Colour coding Load GC.  Please wait.....", LogINFO);
	cargoType := self.getCargoType("CANNONBALL");
	self.assertNotNull(cargoType);
	
	//self.myVoyage.myROROStructure.createQuickCargoGC(null, cargoType, 155.0, -0.50, self.myDeck, 15); 
	self.createQuickCargoGC(self.myVoyage.myROROStructure, locnGCDefnVoyage, cargoType, 155.0, -0.50, self.myDeck, 15);				// 27/08/2015 cnwmh5
	self.assertNoTrxErrorsOrWarnings();
		
	locnGCDefnVoyage := self.myDeck.allROROGCDefnByCode.last.CM_ROROGCDefnVoyage;
	self.assertNotNull(locnGCDefnVoyage);
	layout := locnGCDefnVoyage.myLayout;
	create newPointsArray transient;
	newPointsArray.add(156.00);
	newPointsArray.add(9.00);
	newPointsArray.add(165.00);
	newPointsArray.add(9.00);
	newPointsArray.add(165.00);
	newPointsArray.add(2.00);
	newPointsArray.add(156.00);
	newPointsArray.add(2.00);
	newPointsArray.add(156.00);
	newPointsArray.add(9.00);
	beginTransaction;
	layout.setPointsPolygonCMs(newPointsArray);
	commitTransaction;
	
	// delete all tracked items as we are load colour coding
	create tiArray transient;
	tiArray.clear();
	locnGCDefnVoyage.getAllTIs(REAL_MODE, tiArray, true);
	foreach cargo in tiArray do
		self.deleteTrackedItem(cargo, false);
	endforeach;
	
	// colour code GC area
	self.roroLCs.clear();
	self.getJobROROGCControllerByID(self.myVoyage.code, self.myDeck.code, null, locnGCDefnVoyage.myGCController.ident, self.roroLCs, true, 1); 
	
	realAlloc := self.addVoyageAllocation(self.myVoyage, port.code, "", "", cargoType.id, false, false);
	self.addLCsToROROAllocation(true, realAlloc, roroLCs, altRoroLCs,1);
	self.roroLCs.copy(roroLCsHold);
	
	// set the quantity
	gcRequest := locnGCDefnVoyage.myGCController.getRequest(true).CM_ROROGCRequest;
	if gcRequest &lt;&gt; null then
		beginTransaction;
		gcRequest.setForUpdateQuantity(10.00);
		commitTransaction;
	endif;
	
	// colour code OOTL
	
	// colour code OOTL
	location := null;
	// OOTL - Non Rotated / Rotated 20'
	//self.myVoyage.myROROStructure.createQuickCargoOOTL(
	self.createQuickCargoOOTL(self.myVoyage.myROROStructure, location, false, 119.50, -6.20, self.myDeck, 1); 	
	self.assertNoTrxErrorsOrWarnings();
	//self.myVoyage.myROROStructure.createQuickCargoOOTL(
	self.createQuickCargoOOTL(self.myVoyage.myROROStructure, location, false, 128.00, -9.40, self.myDeck, 1); 	
	self.assertNoTrxErrorsOrWarnings();
	//self.myVoyage.myROROStructure.createQuickCargoOOTL(
	self.createQuickCargoOOTL(self.myVoyage.myROROStructure, location, false, 134.50, -9.40, self.myDeck, 1); 	
	self.assertNoTrxErrorsOrWarnings();
	
	//self.myVoyage.myROROStructure.createQuickCargoOOTL(
	self.createQuickCargoOOTL(self.myVoyage.myROROStructure, location, false, 113.00, 10.50, self.myDeck, 1); 	
	self.assertNoTrxErrorsOrWarnings();
	//self.myVoyage.myROROStructure.createQuickCargoOOTL(
	self.createQuickCargoOOTL(self.myVoyage.myROROStructure, location, false, 124.00, 10.50, self.myDeck, 1); 	
	self.assertNoTrxErrorsOrWarnings();
	//self.myVoyage.myROROStructure.createQuickCargoOOTL(
	self.createQuickCargoOOTL(self.myVoyage.myROROStructure, location, false, 124.00, 3.50, self.myDeck, 1); 	
	self.assertNoTrxErrorsOrWarnings();

	// OOTL - Non Rotated / Rotated 40'
	//self.myVoyage.myROROStructure.createQuickCargoOOTL(
	self.createQuickCargoOOTL(self.myVoyage.myROROStructure, location, true, 128.00, -6.20, self.myDeck, 1); 	
	self.assertNoTrxErrorsOrWarnings();
	//self.myVoyage.myROROStructure.createQuickCargoOOTL(
	self.createQuickCargoOOTL(self.myVoyage.myROROStructure, location, true, 113.00, -9.40, self.myDeck, 1); 	
	self.assertNoTrxErrorsOrWarnings();
		
	//self.myVoyage.myROROStructure.createQuickCargoOOTL(
	self.createQuickCargoOOTL(self.myVoyage.myROROStructure, location, true, 118.00, 10.50, self.myDeck, 1); 	
	self.assertNoTrxErrorsOrWarnings();
	
	tiArray.clear();
	self.locationArray.clear();
	self.locationArray.add("D4431O");
	self.locationArray.add("D4432O");
	self.locationArray.add("D4433O");
	self.locationArray.add("D4438O");
	self.locationArray.add("D4439O");
	self.locationArray.add("D4440O");
	
	
	
	
	foreach locn in self.locationArray do
		location := self.myDeck.allROROLocnDefnByCode[locn];
		self.assertNotEqual(location, null);
		
		tiArray.clear();
		location.getAllTIs(REAL_MODE, tiArray, true);
		foreach cargo in tiArray do
			self.deleteTrackedItem(cargo, false);
		endforeach;	
		if locn = "D4434O" or locn = "D4435O" or locn = "D4436O" then
			app.myTrxUA.trxUpdateROROLocnDefnRotate(location, 1, 1, false, app.myPassport, false);
			self.assertNoTrxErrorsOrWarnings();
		endif;
	endforeach;
	
	
	
	return;
	
	
	self.locationArray.clear();
	self.locationArray.add("D4431O");
	self.locationArray.add("D4432O");
	self.locationArray.add("D4436OR");
	self.locationArray.add("D4435OR");
	self.roroLCs.clear();
	foreach locn in locationArray do
		locnDefnVoyage := self.myDeck.allROROLocnDefnByCode[locn].CM_ROROLocnDefnVoyage;
		self.assertNotEqual(locnDefnVoyage, null);
		foreach slotDefn in locnDefnVoyage.allROROSlotDefnByOrdinal discreteLock do
			slotLC := slotDefn.CM_ROROSlotDefnVoyage.mySlotController;
			if not slotLC.mySlotDefn.isAvailable then
				continue;
			endif;
			self.getJobROROControllerByID(self.myVoyage.code, self.myDeck.code, null, slotLC.ident, self.roroLCs, true, 1); 
		endforeach;
	endforeach;
	
	realAlloc := self.addVoyageAllocation(self.myVoyage, port.code, "U20G", "", TI_CargoType_Container, false, false);
	self.addLCsToROROAllocation(true, realAlloc, roroLCs, altRoroLCs,1);
	self.roroLCs.copy(roroLCsHold);
	
	self.locationArray.clear();
	self.locationArray.add("D4438O");
	self.locationArray.add("D4434O");
	
	
	foreach locn in self.locationArray do
		location := self.myDeck.allROROLocnDefnByCode[locn];
		self.assertNotEqual(location, null);
		
		tiArray.clear();
		location.getAllTIs(REAL_MODE, tiArray, true);
		foreach cargo in tiArray do
			self.deleteTrackedItem(cargo, false);
		endforeach;	
		app.myTrxUA.trxUpdateROROLocnDefnRotate(location, 1, 1, false, app.myPassport, false);
		self.assertNoTrxErrorsOrWarnings();
		if locn = "D4434O" then
			app.myTrxUA.trxUpdateROROLocnDefnRotate(location, 1, 1, false, app.myPassport, false);
			self.assertNoTrxErrorsOrWarnings();
		endif;
	endforeach;
	
	self.locationArray.clear();
	self.locationArray.add("D4438O");
	self.locationArray.add("D4434O");
	self.roroLCs.clear();
	foreach locn in locationArray do
		locnDefnVoyage := self.myDeck.allROROLocnDefnByCode[locn].CM_ROROLocnDefnVoyage;
		self.assertNotEqual(locnDefnVoyage, null);
		foreach slotDefn in locnDefnVoyage.allROROSlotDefnByOrdinal discreteLock do
			slotLC := slotDefn.CM_ROROSlotDefnVoyage.mySlotController;
			if not slotLC.mySlotDefn.isAvailable then
				continue;
			endif;
			self.getJobROROControllerByID(self.myVoyage.code, self.myDeck.code, null, slotLC.ident, self.roroLCs, true, 1); 
		endforeach;
	endforeach;
	
	realAlloc := self.addVoyageAllocation(self.myVoyage, port.code, "U40G", "", TI_CargoType_Container, false, false);
	self.addLCsToROROAllocation(true, realAlloc, roroLCs, altRoroLCs,1);
	self.roroLCs.copy(roroLCsHold);
	
	
	// save the details so jobs can be created
	self.roroLCs.clear();
	roroLCsHold.copy(roroLCs);
	
	/*
	// create voyage allocations
	create roroLCsHold transient;
	create altRoroLCs transient;
	self.roroLCs.clear();
	self.getJobROROControllerByID(self.myVoyage.code, self.myDeck.code, null, "D40421", self.roroLCs, true, 1); 
	self.getJobROROControllerByID(self.myVoyage.code, self.myDeck.code, null, "D40422", self.roroLCs, true, 1); 
	self.getJobROROControllerByID(self.myVoyage.code, self.myDeck.code, null, "D40423", self.roroLCs, true, 1); 
	self.getJobROROControllerByID(self.myVoyage.code, self.myDeck.code, null, "D40424", self.roroLCs, true, 1); 
	self.getJobROROControllerByID(self.myVoyage.code, self.myDeck.code, null, "D40425", self.roroLCs, true, 1); 
	self.getJobROROControllerByID(self.myVoyage.code, self.myDeck.code, null, "D40431", self.roroLCs, true, 1); 
	self.getJobROROControllerByID(self.myVoyage.code, self.myDeck.code, null, "D40441", self.roroLCs, true, 1); 
	realAlloc := self.addVoyageAllocation(self.myVoyage, port.code, "U40G", "", TI_CargoType_Container, false, false);
	self.addLCsToROROAllocation(true, realAlloc, roroLCs, altRoroLCs,1);
	self.roroLCs.copy(roroLCsHold);
	
	// save the details so jobs can be created
	self.roroLCs.clear();
	roroLCsHold.copy(roroLCs);
	*/
	
//	voyageJob := self.addVoyageROROJob(self.myVoyage, self.myDeck, "UT_31367Job1", self.roroLCs, false);
//	assertTrue(voyageJob &lt;&gt; null);
	
	/*
	app.writeLog("Checking Status Bar (HIDE) details are correct.  Please wait...", LogAlways);
	
	// check that the details of the status bar is correct - Hide Exports
	self.locationArray.clear();
	self.statusArray.clear();
	self.locationArray.add("D4013");
	self.statusArray.add("D4013 D4013 |  Fwd: D4018 | 3 x CONT NZLYT  U20G| 1 x CONT NZAKA  U20G | UT313670001, UT313670002, UT313670003, UT313670004 Job: 200");
	self.locationArray.add("D4018");
	self.statusArray.add("D4018 D4018 | Aft: D4013 | 3 x CONT NZLYT  U20G| 1 x CONT NZAKA  U20G | UT313670005, UT313670006, UT313670007, UT313670008 Job: 200");
	self.locationArray.add("D4003");
	self.statusArray.add("D4003 D4003 |  Fwd: D4008 | 3 x CONT NZLYT  U20G| 1 x CONT NZAKA  U20G | UT313670009, UT313670010, UT313670011, UT313670012 Job: 201");
	self.locationArray.add("D4005");
	self.statusArray.add("D4005 D4005 |  Fwd: D4010 | 1 x CONT NZLYT  U20G | UT313670019 Job: 205");
	self.locationArray.add("D4006");
	self.statusArray.add("D4006 D4006 |  Fwd: D4011 | 3 x CONT NZLYT  U20G | UT313670013, UT313670014, UT313670015 Job: 203");
	self.locationArray.add("D4033");
	self.statusArray.add("D4033 D4033 | Aft: D4028 | 4 x CONT NZLYT  U20G | UT313670016, UT313670017, UT313670018, UT313670015");
	self.locationArray.add("D4021");
	self.statusArray.add("D4021 D4021 | Aft: D4016 | 5 x CONT AUSYD  U40G | UT313670040, UT313670041, UT313670042, UT313670043, UT313670044 Job: 207");
	
	self.locationArray.add("D4060");
	self.statusArray.add("D4060 D4060 | Aft: D4055 | 4 x CONT AUBRI  U20G| 3 x CONT AUSYD  U40G | UT313670059, UT313670060, UT313670045, UT313670046, UT313670047, UT313670057, UT313670058 Job: 207");
	self.locationArray.add("D4040");
	self.statusArray.add("D4040 D4040 | Aft: D4035 | 4 x CONT AUSYD  U40G | UT313670048, UT313670049, UT313670050, UT313670051 Job: 207");
	self.locationArray.add("D4036");
	self.statusArray.add("D4036 D4036 |  Fwd: D4041 | 5 x CONT AUBRI  U20G | UT313670061, UT313670062, UT313670063, UT313670064, UT313670065 Job: 207");
	self.locationArray.add("D4041");
	self.statusArray.add("D4041 D4041 | Aft: D4036  | ");
	self.locationArray.add("D4037");
	self.statusArray.add("D4037 D4037 |  Fwd: D4042 | 5 x CONT AUBRI  U20G | UT313670066, UT313670067, UT313670068, UT313670069, UT313670070 Job: 207");
	self.locationArray.add("D4042");
	self.statusArray.add("D4042 D4042 | Aft: D4037 | 5 x CONT AUBRI  U20G | UT313670071, UT313670072, UT313670073, UT313670074, UT313670075 Job: 207");
	self.locationArray.add("D4043");
	self.statusArray.add("D4043 D4043 | Aft: D4038 | 6 x CONT AUBRI  U20G| 2 x CONT AUSYD  U40G | UT313670079, UT313670080, UT313670081, UT313670052, UT313670053, UT313670076, UT313670077, UT313670078 Job: 207");
	self.locationArray.add("D4044");
	self.statusArray.add("D4044 D4044 | Aft: D4039 | 4 x CONT AUBRI  U20G| 3 x CONT AUSYD  U40G | UT313670084, UT313670085, UT313670054, UT313670055, UT313670056, UT313670082, UT313670083 Job: 207");
	
	self.xCheckStatusBarCorrect(ShpDisplayMode_Actual, ShpDisplayMode_ColCodeDisch, ShpDisplayModeSub_ExportsHide);

	app.writeLog("Checking Status Bar (SHOW) details are correct.  Please wait...", LogAlways);
	
	// check that the details of the status bar is correct - SHOW EXPORTS
	self.locationArray.clear();
