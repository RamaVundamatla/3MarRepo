    <JadeMethod name="translateConsigneeCode" id="ebd2f1b1-1fe8-4bc9-8bce-3ac1d86684f8">
        <source>translateConsigneeCode(_cCode : String) : String;
/*

Date		Who		Reason
08 Feb 2010	cnwas3	Initial creation
21 mar 2013	cnwcs5	CCMS POL 2097 / par 31259
*/

vars
	operator		: CM_Operator;
	consignee		: CM_ConsigneeConsignor;
	xlatedConsignee	: String;
	foundMatch		: Boolean;
begin
	if _cCode = null then
		return null;
	endif;
	
	consignee := app.myRoot.allConsigneeConsignors[_cCode];	
	
	if consignee = null then
		//Try to translate the code using the operators translation table
		operator := app.myRoot.allOperators[operatorCode];
		
		if operator &lt;&gt; null then
			xlatedConsignee := operator.getXlationSystemCode(_cCode, XLATION_TYPE_CONSIGNEE_BYOP, foundMatch);
		endif;
		
		consignee := app.myRoot.allConsigneeConsignors[xlatedConsignee];
	endif;

	if consignee &lt;&gt; null then

		self.verifyObjectAvailableForEntry( consignee );	//07 Sep 2021	NDL	TFS 51928
	
		return consignee.code;			//Set to translated / short code
	else
		return _cCode[1:5];			
	endif;
end;</source>
        <Parameter name="_cCode" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="translatePortCode" id="1cdecd49-7ad5-48cc-b263-880256a4c39d">
        <source>translatePortCode(portCode : String) : String;
//
//    This has been copied from CM_EDIPrenoteTI  (cnwjo3)
//
// 21 mar 2013	cnwcs5	CCMS POL 2097 / par 31259

vars
	operator		: CM_Operator;
	port			: CM_Port;
	xlatedPort		: String;
	foundMatch		: Boolean;
begin
	if portCode = null then
		return null;
	endif;
	
	port := app.myRoot.allPorts[portCode];	
	
	if port = null then
		// PORT CODES SHOULD ALL BE 5 CHARACTERS AFTER 7.4.2
		//Try to translate the code using the operators translation table
		operator := app.myRoot.allOperators[operatorCode];
		
		if operator &lt;&gt; null then
			xlatedPort := operator.getXlationSystemCode (portCode, XLATION_TYPE_PORT_BYOP, foundMatch);
		endif;
		
		port := app.myRoot.allPorts[xlatedPort];
	endif;

	if port &lt;&gt; null then
		return port.code;			//Set to translated / short code
	else
		return portCode[1:4];			//Must truncate to 4 chars anyway
	endif;
end;</source>
        <Parameter name="portCode" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="translateValue" id="9dc36ce5-59d1-4c17-b56a-9ba529c4e42b">
        <source>translateValue(_fieldName: String; _xlationOperator: CM_Operator; _processedValue: String io) protected;
/*
Date		Who		Reason
11 April 2013	cnwcs5	Initial Creation - CCMS POL 2097/par 31259
*/
vars
	foundMatch	:Boolean;
begin
	// par 31259 - code moved from setEDITIProperty
	if _fieldName = CM_EDILoadListTI::myTranshipToPort.name then
		_processedValue := _xlationOperator.getXlationSystemCode(_processedValue, XLATION_TYPE_PORT_BYOP, foundMatch)[1:5];	
	else
		inheritMethod(_fieldName, _xlationOperator, _processedValue);
	endif;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_fieldName" type="String"/>
        <Parameter name="_xlationOperator" type="CM_Operator"/>
        <Parameter name="_processedValue" type="String" usage="io"/>
    </JadeMethod>
