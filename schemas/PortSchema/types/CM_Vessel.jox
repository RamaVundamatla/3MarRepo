    <JadeMethod name="getNumberOfGCHolds" id="62edaf3a-b980-40bd-87bb-6ae6b9ce81d2">
        <source>getNumberOfGCHolds(): Integer;

/*
Date				Who		Reason
05 February 2015	cnwar2	#35611

*/
vars
	gcHoldDefn 	: CM_GCHoldLocationDefn;
	ia 			: IntegerArray;
	
begin
	create ia transient;
	ia.clear();
	foreach gcHoldDefn in self.myGeneralCargoVesselStructure.allHoldLocnDefnByHatchPlace do
		if not ia.includes(gcHoldDefn.hatch) then
			ia.add(gcHoldDefn.hatch);
		endif;
	endforeach;
	
	return ia.size;
epilog
	delete ia;
end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
