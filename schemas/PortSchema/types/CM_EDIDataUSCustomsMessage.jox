    <JadeMethod name="loadDB" id="fe415e5d-d601-446a-ab71-6c28da8a0b07">
        <updating/>
        <source>loadDB(_mergeCargo: Boolean; _passport: CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:	01 October 2008 By Graeme Black cnwgb1
// Purpose:	
// ---------------------------------------------------------------------------
//21 Feb 2013	cnwrs1	Par 31143 EDI TRX not handling dbLoadErrors after no verify errors take 3
//6/11/2019	JLGNS1	ChangeRequest 46721: PEN - CAMIR Message Processing
vars
	realTerminal			: CM_Terminal;
	bol 						: CM_BOLIn;
	customsStatusMessage 		: CM_CustomsStatusMessage;
	theRealCustomsStatusMessage : CM_CustomsStatusMessage;
	messageTimeStamp			: TimeStamp;
	type						: Integer;
	ediTI						: CM_EDITrackedItem;
	ediCustomMessageTI			: CM_EDIUSCustomsMessageTI;
begin
	on Exception do validationExceptionHandler(exception, _passport);
	app.setContinueCMExceptions(true);
	
	realTerminal := self.ediConfig.myTerminal;

	foreach ediTI in self.allEDITrackedItems where ediTI.isKindOf(CM_EDIUSCustomsMessageTI) do
		ediCustomMessageTI := ediTI.CM_EDIUSCustomsMessageTI;
		
		
		
		
			
		if ediCustomMessageTI.id &lt;&gt; null then
			app.myTrxUA.trxProcessUSCustomsStops(self,false, _passport);
		else
		
			bol := realTerminal.getBOLInByNumber(ediCustomMessageTI.billOfLading, BOLType_GeneralBillOfLading );
			if bol = null then
				app.raiseCMException2(NoBillOfLadingOnVoyage, ediCustomMessageTI.billOfLading, ediCustomMessageTI.voyageCode, 'Bill of Lading', self);
			endif;
		
		
			//PAR19342 - cnwsh3 Set the timestamp to check if the message has already been loaded. 
			messageTimeStamp.setDate(ediCustomMessageTI.postedDate);
			messageTimeStamp.setTime(ediCustomMessageTI.postedTime);
		
			create customsStatusMessage transient;
			customsStatusMessage.setProxy( 	ediCustomMessageTI.dispositionCode, ediCustomMessageTI.entryNumber, ediCustomMessageTI.entryType, 
										ediCustomMessageTI.portForeign, ediCustomMessageTI.portInBond, ediCustomMessageTI.portInTransit, 
										ediCustomMessageTI.portOfEntry, ediCustomMessageTI.quantity, ediCustomMessageTI.remarks, messageTimeStamp, 
										/*ediCustomMessageTI.processedDT*/messageTimeStamp, ediCustomMessageTI.controlNumber, realTerminal, type, bol, ediCustomMessageTI.voyageOperator);
		
		
			app.myTrxCA.trxCreateEDICustomsStatusMessg( customsStatusMessage, theRealCustomsStatusMessage, self, false, _passport ); //ccms1845
			
			if _passport.hasErrors then
				break;
			endif;
			
		endif;	
	endforeach;
epilog
	delete customsStatusMessage;
	
end;</source>
        <Parameter name="_mergeCargo" type="Boolean"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="myOperator" id="d322adde-e2d1-4d07-aa32-25435e16073d">
        <methodInvocation>mapping</methodInvocation>
        <source>myOperator(set : Boolean; _value : CM_Operator io) mapping;
//
//18 August 2017	jlgrs1	TFS 5457 Make JMTInternal XML work//
vars

begin
	if self.myOperator = null then
		if self.allEDITrackedItems.size &gt; 0 then
			if self.allEDITrackedItems.first &lt;&gt; null then
				_value := app.myRoot.allOperators[self.allEDITrackedItems.first.CM_EDIUSCustomsMessageTI.voyageOperator];
			endif;
		endif;
	endif;
epilog

end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="CM_Operator" usage="io"/>
    </JadeMethod>
    <JadeMethod name="verifyEDIData" id="12c919a8-cb46-47d5-9c38-5594e96303fe">
        <updating/>
        <source>verifyEDIData(): Integer updating;
//----------------------------------------------------------------------
// Created by 	cnwsh3
// Date 		17 September 2009
//
// Implemented version: JMT 7.7.3
// Date  		User  		Change

//----------------------------------------------------------------------
vars
	terminal : CM_Terminal;
	bol : CM_BOLIn;
	messageTimeStamp : TimeStamp;
	ediAction : CM_EDIAction;
	ediFile : CM_EDIFile;
begin
	on Exception do validationExceptionHandler(exception, app.myPassport);
	app.setContinueCMExceptions(true);
	
	if self.myOperator = null then
		app.raiseCMException1(ERR_INVALID_OPERATOR, self.operatorCode, null, null);
	endif;
	
/* cnwgb1 28/5/2014 Remove and readd for CAMIR processing	
	terminal := self.getMyTerminal();
	bol := terminal.getBOLInByNumber(self.billOfLading, BOLType_GeneralBillOfLading);
	messageTimeStamp.setDate(self.postedDate);
	messageTimeStamp.setTime(self.postedTime);
	if bol = null or 
	   bol.myCustomsBOLExt = null then
		app.raiseCMException(ERR_CustomsMessageNoBOL, 'Customs Manifest Information', self);
	endif;
	
	if bol &lt;&gt; null and
	   bol.myCustomsBOLExt &lt;&gt; null then
		if bol.myCustomsBOLExt.isMessageLoaded( messageTimeStamp, self.controlNumber) then
			app.raiseCMException(ERR_CustomsMessageExists, 'Customs Message', self);	
		endif;
	endif;
	
	ediFile := self.myEDIFile; // ccms1117 cnwrs1 29 Apr 2010
	if ediFile &lt;&gt; null and
	  ediFile.myEDIFileType &lt;&gt; null then
		if not ediFile.myEDIFileType.hasEDIActionWithKeyword(self.dispositionCode) then
			app.raiseCMException1(CustomsActionDoesNotExist, self.dispositionCode, 'No EDI Action', self);
		endif;
		if not ediFile.myEDIFileType.hasEDIActionForCustomsMessage(self.dispositionCode) then
			app.raiseCMException1(CustomsActionTypeReq, self.dispositionCode, 'No Customs EDI Action', self);	
		endif;
	endif;
    */
epilog
	return app.myPassport.allErrorWarnings.size; 
end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="verifyEDIDataTIs" id="fa103d3f-0306-420d-9656-732d94040c05">
        <updating/>
        <source>verifyEDIDataTIs(_passport: CM_Passport input): Integer updating;
//----------------------------------------------------------------------
// Created by 	cnwsh3
// Date 		17 September 2009
//
// Implemented version: JMT 7.7.3
// Date  		User  		Change

//----------------------------------------------------------------------
vars
	ediTI			: CM_EDITrackedItem;
	ediCusotmsMsg	: CM_EDIUSCustomsMessageTI;
begin	
	// Arm our base exception handlers
	on Exception do validationExceptionHandler(exception, _passport);
	app.setContinueCMExceptions(true);

	foreach ediTI in self.allEDITrackedItems discreteLock where ediTI.isKindOf(CM_EDIUSCustomsMessageTI) do
		ediCusotmsMsg := ediTI.CM_EDIUSCustomsMessageTI;
		ediCusotmsMsg.verifySelf();
	endforeach;
	
	return app.myPassport.allErrorWarnings.size;
epilog

end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="zEventRequestStopsTransaction" id="1a837b66-3777-4126-b5cb-33f734c01f96">
        <source>zEventRequestStopsTransaction(
	_id			: String input;
	_cargoType	: CM_CargoType input;
	_ediStopTI	: CM_EDIUSCustomsMessageTI input;
	_terminal	: CM_Terminal input;
	_ediAction :CM_EDIAction input;
	_passport	: CM_Passport input ) protected;
	
/*
Purpose:	This method provides a common point for the creation and action of the CM_EventRequestStops.

Date				Who		Reason
6/11/2019	JLGNS1	ChangeRequest 46721: PEN - CAMIR Message Processing

*/
	
vars
	isClear				: Boolean;
	stopsTable			: CM_StopsTable;
	user				: CM_User;
	pxyRequestStops		: CM_EventRequestStops;
	cmifEventReq		: CMIF_EventRequestController;
	emailAddresses		: CM_StringArray;
	toDoTask			: CM_ToDoTaskDesc;
	ti 					: CM_TrackedItem;
	toDoRemarks			: String;
		
begin
	
	create cmifEventReq transient;
	create emailAddresses transient;
	
	
	user	:= app.getMyUser();
	
	if _ediAction.myActionObject.isKindOf(CM_StopsTable) then
		stopsTable	:= _ediAction.myActionObject.CM_StopsTable;
	
		isClear	:= _ediAction.actionType = EDIAction_RemoveContHold;	// ie do we want to remove this stop
		create pxyRequestStops transient;
		pxyRequestStops.setProxyRequestStops(	EventRequestTypeStops,
											emailAddresses,						// no actual email is required
											null,								// remarks
											_id,
											user,
											_cargoType,
											user.myOrganisation,
											_terminal,
											EventRequestPending,
											isClear,
											false,								// isNotify
											
											_ediStopTI.billOfLading,			// reference
											true,	
											stopsTable,
											_ediStopTI.entryNumber,								// ie the additional required information for any stop needing it
											null,
											true,null,null,null,
											null,
											null,	
											_ediStopTI.billOfLading,
											false,
											_ediStopTI.description,  			
											_ediStopTI.getTISealNumOperator, 	
											_ediStopTI.getTINotificationType   
											);								
	
		ti := _ediStopTI.getTrackedItem;
		if ti &lt;&gt; null then
			pxyRequestStops.setMyTrackedItem(ti,_passport);
		endif;
				
		cmifEventReq.allPxyCargoUpdateRequests.add(pxyRequestStops);
		
	endif;
	
	
	if _ediAction.myActionObject.isKindOf(CM_ToDoTaskDesc) then
		toDoTask:= _ediAction.myActionObject.CM_ToDoTaskDesc;
		
		isClear	:= _ediAction.actionType = EDIAction_DeleteToDoTask;
		
		toDoRemarks := _ediStopTI.remarks;
		
		create pxyRequestStops transient;
		pxyRequestStops.setProxyRequestStops(	EventRequestTypeToDo,
											emailAddresses,						// no actual email is required
											null,								// remarks
											_id,
											user,
											_cargoType,
											user.myOrganisation,
											_terminal,
											EventRequestPending,
											isClear,
											false,								// isNotify
											
											_ediStopTI.billOfLading,			// reference
											true,	
											null,
											
											null,
											null,
											true,toDoTask,null,null,
											null,	
											toDoRemarks,	
											null,	
											null,	
											_ediStopTI.description,          
											_ediStopTI.getTISealNumOperator, 
											_ediStopTI.getTINotificationType  
											);								
		ti := _ediStopTI.getTrackedItem;
		if ti &lt;&gt; null then
			pxyRequestStops.setMyTrackedItem(ti,_passport);
		endif;

		cmifEventReq.allPxyCargoUpdateRequests.add(pxyRequestStops);
		
	endif;
	
	
	
	cmifEventReq.action(_passport);
	
epilog
	delete emailAddresses;
	cmifEventReq.allPxyCargoUpdateRequests.purge;
	delete cmifEventReq;

	
end;
</source>
        <access>protected</access>
        <Parameter name="_id" type="String" usage="input"/>
        <Parameter name="_cargoType" type="CM_CargoType" usage="input"/>
        <Parameter name="_ediStopTI" type="CM_EDIUSCustomsMessageTI" usage="input"/>
        <Parameter name="_terminal" type="CM_Terminal" usage="input"/>
        <Parameter name="_ediAction" type="CM_EDIAction" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="zLoadDBcont" id="ad6d49ce-483f-48d9-afb4-eb7374b7a505">
        <updating/>
        <source>zLoadDBcont(ediCustomMessageTI :CM_EDIUSCustomsMessageTI input;  _passport: CM_Passport input) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
04 November 2019	jlgns1	Initial creation
6/11/2019	JLGNS1	ChangeRequest 46721: PEN - CAMIR Message Processing
*/
vars
	realTerminal		: CM_Terminal;
	ediAction			: CM_EDIAction;
	tmpEDIFileType		: CM_EDIFileType;
	iter 				: Iterator;
	ediActionCode 		: String;
	
begin
	
	on Exception do validationExceptionHandler(exception, _passport);
	app.setContinueCMExceptions(true);
	
	if ediCustomMessageTI.id &lt;&gt; null then
		realTerminal := self.ediConfig.myTerminal;
		tmpEDIFileType := app.myRoot.allEDIFileTypes.getAtKeyGeq(EDIFileTypeCAMIR_CustomsStatus, null);
		iter := tmpEDIFileType.allEDIActions.createIterator();
		ediActionCode := ediCustomMessageTI.dispositionCode;
		
		while iter.next(ediAction) do
			
			if ediAction.keyword &lt;&gt; ediActionCode then
				continue;
			endif;
			if not ediAction.isForContainer then
				continue;
			endif;
					
			self.zEventRequestStopsTransaction(	ediCustomMessageTI.id,
												ediCustomMessageTI.myCargoType,
												ediCustomMessageTI,
												realTerminal,
												ediAction,
												_passport );
			
		endwhile;					
	endif;
			
epilog
	delete iter;
		
end;</source>
        <Parameter name="ediCustomMessageTI" type="CM_EDIUSCustomsMessageTI" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
</Class>
