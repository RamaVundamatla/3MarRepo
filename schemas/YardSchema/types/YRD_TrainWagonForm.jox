    <JadeMethod name="doBaseFormSave" id="d5b22e14-d794-4be2-875c-4033033ae7ad">
        <updating/>
        <source>doBaseFormSave()protected, updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
26 June 2009	cnwmd1	Initial creation
03/11/2009	cnwmh5	PAR21517 - Add test for mode = Mode_Updating when in edit mode so that
						if warning errors are displayed it processes the wagon correctly when
						'Save' is pressed and changes to wagon are saved.
*/


vars
	newWagon,
	pxyWagon			: CM_Wagon;
	ls,
	retrospectiveOpsEnabled	: Boolean;
	result				: Integer;
	wagonUpdateCtrl : CMIF_WagonUpdateController;
	wagonClass : CM_WagonClass;
	retroDT : TimeStamp;
	prof    	    : JadeProfiler;
	folder   	    : String;
	clock			: String;
begin

	app.cmsBeginLoad(ls);
	create wagonUpdateCtrl transient;
	wagonUpdateCtrl.autoSetEffectiveTimeStamp();	//26 Feb 2021	NDL	TFS 50837
	
	// ### TFS 62857 (62858) 18Mar2024 NAVPW1
	retrospectiveOpsEnabled := app.myRoot.canDo(Sub_RetroWorkOrder);
	if retrospectiveOpsEnabled then
		retroDT.setDate(self.txtRetroDate.getDate());
		retroDT.setTime(self.txtRetroTime.getTime());
		
		if retroDT.isValid then
			wagonUpdateCtrl.setEffectiveTimeStampOverride(retroDT);
			wagonUpdateCtrl.retrospectiveDT := retroDT;
		endif;
	endif;
	// ### TFS 62857 (62858) 18Mar2024 NAVPW1
	
	if self.mode = self.Mode_Add then
		//create pxyWagon transient;
		if self.cmbWagonClass.listObject = null then
			create pxyWagon as app.getWagonVisitClassToCreate( null, self.myTerminal, self.cmbWagonPrenote.text, null ) transient;
		else
			wagonClass := self.cmbWagonClass.listObject.CM_WagonClass;	//15 Mar 2013	NDL	Par 31278
			create pxyWagon as wagonClass.getWagonVisitClassToCreate() transient;	//15 Mar 2013	NDL	Par 31278
		endif;
	elseif self.mode = self.Mode_Update then
		pxyWagon := app.createUpdateProxy(self.myCurrentWagon).CM_Wagon;
	endif;
	
	self.setWagonPxy(pxyWagon, wagonUpdateCtrl);
	app.cmsEndLoad(ls);

	if process.isMohamed or process.isHari then
		clock  := app.clock.String;
		folder := global.getJadeInstallDirServer().replace( CN_C_BIN, CN_C_MISC );
		prof   := process.profiler;	
		prof.methodCount := 50;
		prof.fileName := folder&amp;"\MA" &amp; '\'  &amp;" - Rail Confirm - " &amp; clock &amp;".txt";
		prof.clearMethodCache();
		prof.start;
	endif;
	
	self.doSaveDLRT(wagonUpdateCtrl); // ### TFS CR 64297 TASK 64391 31MAY2024 NAVAB1 - moved below code to doSave()
	/* // ### TFS CR 64297 TASK 64391 31MAY2024 NAVAB1
	while true do
		if self.mode = self.Mode_Add then
			//app.myTrxCA.trxCreateTrainWagon(pxyWagon, newWagon, app.myPassport);
			app.myTrxCA.trxCreateWagonFromCMIF(wagonUpdateCtrl, newWagon, false, app.myPassport);
		//elseif self.mode = self.Mode_Update then
		elseif self.mode = self.Mode_Update or self.mode = self.Mode_Updating then				// 03/11/2009 cnwmh5 PAR21517
			self.mode := Mode_Updating;
			//app.myTrxUA.trxUpdateTrainWagon(pxyWagon, app.myPassport);
			app.myTrxUA.trxUpdateWagonFromCMIF(wagonUpdateCtrl, false, app.myPassport);
		endif;
		
		if app.myPassport.trxCompletedOK then
			self.mode := self.Mode_View;
			if self.myCurrentWagon = null then
				self.myCurrentWagon := newWagon;
			endif;
			self.setControlsForAddEditDelete(true);
			doRefresh();	//06 Oct 2009	NDL	Par 20794 - just in case the "null train" has been auto selected.
			if self.myCurrentWagon &lt;&gt; null and self.myCurrentWagon.id &lt;&gt; self.cmbWagonPrenote.text then	//14 Oct 2009	NDL	Par 20979
				// the user has changed the wagon id of this wagon so the combo needs its display text updated to reflect the change.
				self.cmbWagonPrenote.itemText[self.cmbWagonPrenote.listIndex] := self.myCurrentWagon.id;
			endif;
			return;
		else
			result := app.showErrorWarningDialog(app.getErrorString(Wagon_update), app.myPassport, ErrWarnMode_Add + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   result = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		if self.mode = Mode_Updating then
			self.mode := Mode_Update;
		endif;
		return;
	endwhile;
	*/
epilog
	self.setCaption(app.getErrorString(Wagon) &amp; " " &amp; app.getErrorString(Maintenance));
	delete wagonUpdateCtrl;
	delete pxyWagon;
	app.cmsEndLoad(ls);
	if prof &lt;&gt; null then
		prof.report;
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doCargoAdd" id="3869b312-df14-4b92-a052-50c5dfe8400b">
        <source>doCargoAdd()protected;
// ---------------------------------------------------------------------------
// Created:     14 July 2009 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	cargoForm : YRD_TrainWagonCargoForm;
	wagon : CM_Wagon;
	initObject : CM_Object;

begin

		wagon := self.myCurrentWagon;
		if wagon = null then
			app.msgBox(app.getErrorString(Please_select_wagon_edit_first), app.getErrorString(No_Wagon_selected), MsgBox_Exclamation_Mark_Icon);
			return;
		endif;
		
		/*	24 Aug 2009	NDL	CCMS 1094
		if wagon.confirmed then //confirmed inwards
			app.msgBox(app.getErrorString(Cargo_cannot_added_confir_wago), app.getErrorString(Wagon_confirmed), MsgBox_Exclamation_Mark_Icon);
			return;
		endif;
		*/
		
		app.mousePointer := MousePointer_HourGlass;
		
		cargoForm := app.getForm(YRD_TrainWagonCargoForm.name).YRD_TrainWagonCargoForm;
		if cargoForm = null then
			cargoForm := app.loadForm(YRD_TrainWagonCargoForm, YRD_Assistant, false, false, false, self.myTerminal, self.myMasterMenuAction).YRD_TrainWagonCargoForm;
		endif;
		
		if cargoForm = null then
			return;
		endif;
		
		cargoForm.setParentForm(self);
		cargoForm.setMyTerminal(self.myTerminal);
		cargoForm.initialiseForm(wagon, null, YRD_TrainWagonCargoForm.Mode_Add);
	
		cargoForm.show;
		
	
epilog
	app.mousePointer := MousePointer_Default;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doCargoEdit" id="c6a2e9ca-81d2-4df5-b7d5-74605019c3bc">
        <updating/>
        <source>doCargoEdit()updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
03 July 2009	cnwmd1	Initial creation
// 12 Oct 2016	cnwrs1	TFS 2829 Cams processing failure with Train Events
*/

vars
	theObject : Object;
	objArray : ObjectArray;
	cargoForm : YRD_TrainWagonCargoForm;
	ti : CM_TrackedItem;
	wagon : CM_Wagon;
	initObject : CM_Object;
	invalidObject : Boolean;
	str : String;
begin
	on Exception do app.handleDeletedObject(exception, self.myCurrentWagon, invalidObject);
	if self.myCurrentWagon &lt;&gt; null then
		str := self.myCurrentWagon.creationTime.String;
	endif;
	if invalidObject then
		return;
	endif;
	
	create objArray transient;
	
	if self.tblCargo.row &lt; self.tblCargo.fixedRows then
		return;
	endif;
	self.tblCargo.allSelectedObjects.copy(objArray);
	
	if objArray[1].isKindOf(CM_TrackedItem) then
		ti := objArray[1].CM_TrackedItem;
	else
		return;
	endif;

	wagon := self.myCurrentWagon;
	if wagon = null then
		app.msgBox(app.getErrorString(Please_select_wagon_edit_first), app.getErrorString(No_Wagon_selected), MsgBox_Exclamation_Mark_Icon);
		return;
	endif;
	
	if wagon.confirmed then	// 08 Feb 2011	NDL	Par 26900
		// real cargo
		
		self.doCargoEnquiry( true );
	
	else
		// prenote stuff.
	
		app.mousePointer := MousePointer_HourGlass;
		
		cargoForm := app.getForm(YRD_TrainWagonCargoForm.name).YRD_TrainWagonCargoForm;
		if cargoForm = null then
			cargoForm := app.loadForm(YRD_TrainWagonCargoForm, YRD_Assistant, false, false, false, self.myTerminal, self.myMasterMenuAction).YRD_TrainWagonCargoForm;
		endif;
		
		if cargoForm = null then
			return;
		endif;
		
		cargoForm.setParentForm(self);
		cargoForm.setMyTerminal(self.myTerminal);
		cargoForm.initialiseForm(wagon, ti, YRD_TrainWagonCargoForm.Mode_Update);
	
		cargoForm.show;
	
	endif;
		


epilog
	app.mousePointer := MousePointer_Default;

	delete objArray;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doCargoEnquiry" id="416dfdab-debe-44ad-aaac-cc565d234a23">
        <source>doCargoEnquiry( _edit : Boolean ) protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
03 July 2009	cnwmd1	Initial creation

*/

vars
	objArray : CM_TIArray;
begin
	create objArray transient;
	
	self.tblCargo.allSelectedObjects.copy(objArray);
	if objArray.isEmpty() then
		app.msgBox(app.getErrorString(No_Cargo_For_Wagon), app.getErrorString(Cargo_Enquiry), MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
	else
	
		//self.myAssistant.showCargoEnquiryForTIs(objArray[1].CM_TrackedItem, objArray, self.myMasterMenuAction, false);
		self.myAssistant.showCargoEnquiryForTIs(objArray[1].CM_TrackedItem, objArray, self.myMasterMenuAction, _edit);	// 08 Feb 2011	NDL	Par 26900
		
	endif;

epilog
	delete objArray;
end;</source>
        <access>protected</access>
        <Parameter name="_edit" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doFrmCargoToolbarContext" id="b5ca0410-a1f2-47d0-9eda-127e878f1b6c">
        <updating/>
        <source>doFrmCargoToolbarContext(cntrl: Frame input; conwin: Window input; mouse: Boolean; x: Integer; y: Integer):Boolean updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
16 October 2009	cnwndl1	Initial creation Par 21325

*/

vars
	x1, 
	y1					: Real;
begin

	x1 := x;
	y1 := y;
	if cntrl &lt;&gt; null then
		if (not mouse) then  // if keyboard, use current listIndex value
		    x1 := 20;
		    if cntrl.top &lt; 0 then
		        y1 := 5;
		    else
		        y1 := cntrl.top;
		    endif;
		endif;
		
		conwin.windowToScreen(x1, y1);
	endif;

	self.mnuShowBar2Caption.checked := self.frmCargoToolbar.showCaptions;
	self.mnuShowBar2Caption.visible := true;
	self.mnuShowBar2Caption.enabled := true;
	
	self.screenToWindow(x1, y1);
	self.popupMenu(self.mnuBar2Context, x1.Integer, y1.Integer);
	
	return false;                  // cancel further processing

end;</source>
        <Parameter name="cntrl" type="Frame" usage="input"/>
        <Parameter name="conwin" type="Window" usage="input"/>
        <Parameter name="mouse" type="Boolean"/>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doRefresh" id="65350185-b028-4f0c-8264-ba689b123253">
        <updating/>
        <source>doRefresh() updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
04 August 2009	cnwndl1	Initial creation

*/

vars

begin
	
	inheritMethod();
	
	self.buildComboWagon();
	self.doWagonDisplay(true);
	self.loadCargo(optDirInTB.value);

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doResize" id="c7289d06-f70d-458d-ab77-f6b36aacfa9c">
        <updating/>
        <source>doResize() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
16 October 2009	cnwndl1	Initial creation	Par 21325

*/

vars

begin

	inheritMethod();
	
	self.grpWagonDetails.top := self.frmToolbar.height + 1;
	self.grpWagonDetails.width := self.clientWidth - ( self.grpWagonDetails.left * 2) ;
	
	self.chkAdvanced.top := self.grpWagonDetails.top + self.grpWagonDetails.height + 4;
	
	if self.chkAdvanced.value then
		self.grpAdvancedOpt.visible := true;
		self.grpAdvancedOpt.top := self.chkAdvanced.top + 22;
		self.grpAdvancedOpt.width := self.grpWagonDetails.width;
		self.grpCargoDetail.top := self.grpAdvancedOpt.top  +  self.grpAdvancedOpt.height;
		
	else
		self.grpAdvancedOpt.visible := false;
		self.grpCargoDetail.top := self.chkAdvanced.top + chkAdvanced.height + 5;
	endif;
	
	self.grpCargoDetail.height := self.clientHeight - self.grpCargoDetail.top - 4;
	self.frmCargoToolbar.top := 0;
	self.tblCargo.top := self.frmCargoToolbar.height + 4;
	self.tblCargo.height := self.grpCargoDetail.height - self.tblCargo.top - 6;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doSave" id="ea1dc09b-8328-4a03-ba82-17de4a100fdc">
        <updating/>
        <source>doSave(wagonUpdateCtrl : CMIF_WagonUpdateController input) updating;
/*
Purpose:			

Date		Who		Reason
31 May 2024	navab1	CR 64297 TASK 64391
*/

vars
	newWagon,
	pxyWagon			: CM_Wagon;
	result : Integer;
begin
	while true do
		if self.mode = self.Mode_Add then
			//app.myTrxCA.trxCreateTrainWagon(pxyWagon, newWagon, app.myPassport);
			app.myTrxCA.trxCreateWagonFromCMIF(wagonUpdateCtrl, newWagon, false, app.myPassport);
		//elseif self.mode = self.Mode_Update then
		elseif self.mode = self.Mode_Update or self.mode = self.Mode_Updating then				// 03/11/2009 cnwmh5 PAR21517
			self.mode := Mode_Updating;
			//app.myTrxUA.trxUpdateTrainWagon(pxyWagon, app.myPassport);
			app.myTrxUA.trxUpdateWagonFromCMIF(wagonUpdateCtrl, false, app.myPassport);
		endif;
		
		// ### TFS CR 64297 TASK 64391 31MAY2024 NAVAB1
		if app.myPassport.hadDeadlock = true then
			return;
		endif;
		
		if app.myPassport.trxCompletedOK then
			self.mode := self.Mode_View;
			if self.myCurrentWagon = null then
				self.myCurrentWagon := newWagon;
			endif;
			self.setControlsForAddEditDelete(true);
			doRefresh();	//06 Oct 2009	NDL	Par 20794 - just in case the "null train" has been auto selected.
			if self.myCurrentWagon &lt;&gt; null and self.myCurrentWagon.id &lt;&gt; self.cmbWagonPrenote.text then	//14 Oct 2009	NDL	Par 20979
				// the user has changed the wagon id of this wagon so the combo needs its display text updated to reflect the change.
				self.cmbWagonPrenote.itemText[self.cmbWagonPrenote.listIndex] := self.myCurrentWagon.id;
			endif;
			return;
		else
			result := app.showErrorWarningDialog(app.getErrorString(Wagon_update), app.myPassport, ErrWarnMode_Add + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   result = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		if self.mode = Mode_Updating then
			self.mode := Mode_Update;
		endif;
		return;
	endwhile;
epilog

end;</source>
        <Parameter name="wagonUpdateCtrl" type="CMIF_WagonUpdateController" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doSaveDLRT" id="86ad5939-3a07-4b47-b4a6-8489993d4c6b">
        <updating/>
        <source>doSaveDLRT(wagonUpdateCtrl : CMIF_WagonUpdateController input) updating;
/*
Purpose:	DLRT = DEAD LOCK RE-TRY. If get a dead lock the transaction will be aborted and this method will pause, loop round and retry the TRX. It will do this 10 times		

Date		Who		Reason
31 May 2024	navab1	CR 64297 TASK 64391
7/3/25 navsaa30 14818 MTN | Silent Deadlock Retry Technical Debt
03/11/2025 jlier1 	MTN-34531 - Deadlock retry for everyone
*/

vars
	localCaption : String;
begin

	/*if not app.myRoot.isAsynchronousMethodEnabled() then // EUP ONLY for FOLLOWING CODE
		self.doSave(wagonUpdateCtrl);
		return;
	endif;*/

	localCaption := self.caption;
	
	//set up the silent deadlock handler to attempt to retry
	app.myPassport.setupForDeadlockReplay(220, 3000);
	app.myPassport.silentDeadlockLimit := 10;	
	
	self.mousePointer := Window.MousePointer_HourGlass;
	
	while true do
		//call the code that was originally in this method
		self.doSave(wagonUpdateCtrl);	// original code 
		
		//if we did NOT have a dead lock, just bail out.
		if app.myPassport.noTrxReplayAllowed() then	
			if app.myPassport.hadDeadlock then
				app.showErrorWarningDialog(app.getErrorString(Train), app.myPassport,ErrWarnMode_Update + ErrWarnMode_CanAckWarnings); 
			endif;
			return;
		endif;
			
		self.updateCaptionDeadlockRetry(localCaption);	
	endwhile;

	
epilog

	//set the silent deadlock handler back to the default values i.e. OFF
	
	app.myPassport.resetSilentDeadlockHandler;	//7/3/25 navsaa30 #14818
	self.caption := localCaption;
	self.mousePointer := Window.MousePointer_Default;

end;</source>
        <Parameter name="wagonUpdateCtrl" type="CMIF_WagonUpdateController" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doTransitCargo" id="24e73b81-5103-4d3a-93b5-356811ade0e0">
        <updating/>
        <source>doTransitCargo( _status : Integer) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
05 August 2009	cnwndl1	Initial creation

*/

vars

	ti : CM_TrackedItem;
	selectedTIs : ObjectArray;
	pxyTI : CM_TrackedItem;
	theReturn : Integer;
	obj : Object;
	theResult : Integer;	//15 Jan 2020 NDL	TFS 46815
	
begin
	ti := self.getTrackedItem();
	create selectedTIs transient;
	self.tblCargo.allSelectedObjects.copy(selectedTIs);
	if selectedTIs.isEmpty and self.tblCargo.rows &gt; self.tblCargo.fixedRows then
		//there is cargo on the wagon and we want all cargo, so use the wagon version.
		doTransitWagons(_status);
		return;
	endif;
	
	if warnedOfNoSelectedData(selectedTIs,app.getErrorString(Wagon) ) then
		return;
	endif;
	
	if _status = TI_IMEX_STATUS_REMAINONBOARD then
		if app.msgBox(app.getErrorString1(Please_Confirm_Intransit, ti.id), app.getErrorString(Transit_Rail), MsgBox_Yes_No + MsgBox_Question_Mark_Icon) = MsgBox_Return_No then
			return;
		endif;
	elseif _status = TI_IMEX_STATUS_EXPORT then
		if app.msgBox(app.getErrorString1(Please_Confirm_Not_Intransit, ti.id), app.getErrorString(Transit_Rail), MsgBox_Yes_No + MsgBox_Question_Mark_Icon) = MsgBox_Return_No then
			return;
		endif;
	endif;
	
	foreach obj in selectedTIs do
		ti := obj.CM_TrackedItem;
		pxyTI := app.createUpdateProxy(ti).CM_TrackedItem;
		pxyTI.setImExStatus(_status);
		
		//15 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
		while true do
		
			app.myTrxUA.trxUpdateTrackedItem(pxyTI,	null, TI_UPDMODE_NORMAL, null, app.myPassport);
		
			if app.myPassport.trxCompletedOK then
				break;
			else
				theResult := app.showErrorWarningDialog(app.getErrorString(Transit_Rail), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
				if app.myPassport.noErrors and theResult = IDOK then
					app.myPassport.warningsAcknowledged	:= true;
					continue;
				endif;
			endif;
			
			break;
			
		endwhile;
	
		delete pxyTI;
		
	endforeach;
	
	self.doRefresh();
	self.setControlsForAddEditDelete( true );
		
epilog

	delete pxyTI;
	delete selectedTIs;
	
end;</source>
        <Parameter name="_status" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="doTransitWagons" id="974e1250-d489-46be-b35f-6e4c8b981bbf">
        <updating/>
        <source>doTransitWagons(_status : Integer) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
24 July 2009	cnwndl1	Initial creation

*/

vars
	theReturn : Integer;
	wagon : CM_Wagon;
	wagonSet : CM_WagonSet;
	theResult : Integer;	//15 Jan 2020 NDL	TFS 46815
	
begin

	wagon := self.myCurrentWagon.CM_Wagon;
	
	create wagonSet transient;
	if wagon &lt;&gt; null then
		wagonSet.add(wagon);
	endif;
	
	if warnedOfNoSelectedData(wagonSet,app.getErrorString(Wagon) ) then
		return;
	endif;
	
	if _status = TI_IMEX_STATUS_REMAINONBOARD then
		if app.msgBox(app.getErrorString1(Please_Confirm_Intransit, wagon.id), app.getErrorString(Transit_Rail), MsgBox_Yes_No + MsgBox_Question_Mark_Icon) = MsgBox_Return_No then
			return;
		endif;
	elseif _status = TI_IMEX_STATUS_EXPORT then
		if app.msgBox(app.getErrorString1(Please_Confirm_Not_Intransit, wagon.id), app.getErrorString(Transit_Rail), MsgBox_Yes_No + MsgBox_Question_Mark_Icon) = MsgBox_Return_No then
			return;
		endif;
	endif;
	
	//15 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
	while true do
	
		app.myTrxUA.trxUpdateWagonInTransit(wagonSet, _status, app.myPassport);
	
		if app.myPassport.trxCompletedOK then
			break;
		else
			theResult := app.showErrorWarningDialog(app.getErrorString(Transit_Rail), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and theResult = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		
		break;
		
	endwhile;
 	
	self.doRefresh();
	self.setControlsForAddEditDelete( true );
		
epilog

	delete wagonSet;
	
end;</source>
        <Parameter name="_status" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="doTxtWagonNumberLostFocus" id="3f5b1dfc-3736-4f52-a8ff-65247ba37597">
        <source>doTxtWagonNumberLostFocus();

/*

Purpose:			
	Pre populate some of the fields based on a pre-existing CM_WagonMaster.
Parameters:			

Return Value:		


Date		Who		Reason
08 July 2009	cnwndl1	Initial creation CCMS 1067
16 Aug 2022	jlika1	TFS 54549 - EUP - Max Wagon Payload
*/

vars

	id 					: String;
	wagonMaster 		: CM_WagonMaster;
	defWagonClassId 	: String;
	defWagonClass 		: CM_WagonClass;
	allowWagonWeights 	: Boolean;	
	measureType			: CM_MeasurementType;
begin
	if self.myTerminal &lt;&gt; null then
		allowWagonWeights := self.myTerminal.getConfig(AllowWagonWeightsToBeUpd).Boolean;
	endif;
	
	if myCurrentWagon &lt;&gt; null then
		//Only want to do this to new wagons.
		return;
	endif;
	
	id := self.txtWagonNumber.text.trimBlanks;
	if id = null then
		return;
	endif;
	
	defWagonClassId := app.myRoot.getWagonClassViaHookCode(self.myTerminal,id,null);
	if defWagonClassId &lt;&gt; null then
		defWagonClass := app.myRoot.allWagonClasses[defWagonClassId];
	endif;
	
	wagonMaster := app.myRoot.allWagonMasters.getAtKey(id);
	if wagonMaster = null then
		if defWagonClass &lt;&gt; null then
			self.displayMeasurements( null,  defWagonClass );
		/*	if self.txtTareWeight.text = null then
				self.txtTareWeight.text := defWagonClass.tareWeight.asStringWeightJMT();
			endif;
			if self.txtMaxHeight.text = null then
				self.txtMaxHeight.text := defWagonClass.maxCargoHeight.asStringMeasurementJMT();
			endif;
			if self.txtMaxWeight.text = null then
				self.txtMaxWeight.text := defWagonClass.maxLoadWeight.asStringWeightJMT();
			endif; */
		endif;
		return;
	endif;
	
	if wagonMaster.myWagonClass &lt;&gt; null then
		defWagonClass := wagonMaster.myWagonClass;
	endif;
	if allowWagonWeights and wagonMaster &lt;&gt; null then
		measureType := app.getDefaultMeasurementForType(Type_Weight);
		if self.tblMaxCWeight.text.asDecimalJMT() = 0.0 then
			self.tblMaxCWeight.setup(Type_Weight, self.backColor);
			self.tblMaxCWeight.tabKey := J_key_Tab;
			self.tblMaxCWeight.visible := true;	
			self.tblMaxCWeight.setValues(app.convertMeasurementForDisplay(measureType.shortName, wagonMaster.getMaxCargoWeight) &amp; Space &amp; measureType.shortName);			
		endif;
		if self.txtMaxWeight.text.asDecimalJMT() = 0.0 then
			self.tblTare.setup(Type_Weight, self.backColor);
			self.tblTare.tabKey := J_key_Tab;
			self.tblTare.visible := true;	
			self.tblTare.setValues(app.convertMeasurementForDisplay(measureType.shortName, wagonMaster.getTareWeight) &amp; Space &amp; measureType.shortName);			
		endif;		
	endif; 
	if self.cmbCarrier.listIndex = -1 then
		self.cmbCarrier.setObject(wagonMaster.myCarrier);
	endif;
	
	
epilog

	if defWagonClass &lt;&gt; null then
		if self.cmbWagonClass.listIndex = -1 then
			self.cmbWagonClass.listIndex := cmbWagonClass.findObject(defWagonClass);
		endif;
	endif;

end;</source>
    </JadeMethod>
    <JadeMethod name="doWagonAdd" id="b167ae26-35e4-4df3-b721-ac9bf0dcc6b0">
        <updating/>
        <source>doWagonAdd() updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
25 June 2009	cnwmd1	Initial creation

*/

vars

begin
	self.mode := self.Mode_Add;
	
	self.myCurrentWagon := null; //Only clear for add only, therefore not in clearControls()
	self.cmbWagon.listObject := null; //Only clear for add only, therefore not in clearControls()
	
	self.clearControls();
	self.buildCombos(); //+ cnwmd1 Par 23384, in case user is adding a wagon to a NEW train (this form can remain open for some time)
	self.setDefaults();
	self.setControlsForAddEditDelete(true);
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doWagonDelete" id="c238f8cf-4d10-4b0a-962d-a49cfd93d695">
        <updating/>
        <source>doWagonDelete() updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
29 June 2009	cnwmd1	Initial creation

*/

vars
	wagon			: CM_Wagon;
	result			: Integer;
begin
	wagon := self.myCurrentWagon;
	
	if wagon = null then
		app.msgBox(app.getErrorString(Please_select_wagon_delete), app.getErrorString(No_wagons_selected), MsgBox_OK_Only + MsgBox_Information_Icon);
		return;
	endif;
	
	if app.msgBox(app.getErrorString1(Sure_that_want_delete_wagon, wagon.id),app.getErrorString(Are_You_Sure), MsgBox_Yes_No) &lt;&gt; MsgBox_Return_Yes then
		return;
	endif;
	
	while true do
		app.myTrxDA.trxDeleteWagon(wagon, false, app.myPassport);
		if app.myPassport.trxCompletedOK then
			self.mode := self.Mode_View;
			self.myCurrentWagon := null;
			self.clearControls();
			self.setControlsForAddEditDelete(true);
			return;
		else
			result := app.showErrorWarningDialog(app.getErrorString(Wagon_delete), app.myPassport, ErrWarnMode_Add + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   result = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;	
		return;
	endwhile;
epilog
	
end;


</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doWagonDisplay" id="03e33d43-8c62-452c-885d-1e9b230d9095">
        <updating/>
        <source>doWagonDisplay(_setFocus : Boolean) updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
24 Jun2009	cnwmd1	Initial creation
19 May 2010	cnwkpd1	PAR #20728 - remove isValidObject calls for performance
12 Oct 2016	cnwrs1	TFS 2829 Cams processing failure with Train Events
04 Nov 2020 cnwma1 ChangeRequest 50112: ASPA - GCI Stevedores
1 Nov 2022  navhl20 ChangeRequest 54281: EUP - Wagon Track Planning
*/
vars
	wagon 		  : CM_Wagon;
	wagonMaster   : CM_WagonMaster;
	wagonClass 	  : CM_WagonClass;
	railJob			: CM_RailJob;
	invalidObject,
	retrospectiveOpsEnabled	: Boolean;
	
begin
	on Exception do app.handleDeletedObject(exception, wagon, invalidObject);
	self.clearControls();
	if self.myCurrentWagon &lt;&gt; null then
		wagon := self.myCurrentWagon;
		wagonMaster := wagon.myWagonMaster;
		if invalidObject then
			return;
		endif;
		if wagonMaster &lt;&gt; null then
			wagonClass := wagonMaster.myWagonClass;
		else
			wagonClass := wagon.myWagonClass;
		endif;
		self.txtWagonNumber.text := wagon.id;
		
		self.myAssistant.comboBoxWagonClass(cmbWagonClass, wagonClass );  //cnwrd1 16.3.2010 par 22818
		
		if self.cmbWagonPrenote.findObject(wagon) &lt; 0 then
			self.cmbWagonPrenote.addItemObject(wagon.id, wagon);
		endif;
		self.cmbWagonPrenote.listObject := wagon;
	
		self.displayMeasurements( wagon, null );
		
		self.txtRemaks.text := wagon.remarks;
		
		self.cmbCarrier.setObject(wagon.myCarrier);
		self.cmbWagonClass.listIndex := cmbWagonClass.findObject(wagon.myWagonClass);
		
		if wagon.myTrainInwards &lt;&gt; null then
			if self.cmbTrainIncoming.findObject(wagon.myTrainInwards) &gt; 0 then
				self.cmbTrainIncoming.listObject := wagon.myTrainInwards;
			else
				self.cmbTrainIncoming.addItemObject(wagon.myTrainInwards.code, wagon.myTrainInwards);
				self.cmbTrainIncoming.listObject := wagon.myTrainInwards;
			endif;
		endif;
		
		if wagon.myTrainOutwards &lt;&gt; null then
			if self.cmbTrainOutgoing.findObject(wagon.myTrainOutwards) &gt; 0 then
				self.cmbTrainOutgoing.listObject := wagon.myTrainOutwards;
			else
				self.cmbTrainOutgoing.addItemObject(wagon.myTrainOutwards.code, wagon.myTrainOutwards);//cnwas3 PAR 21792
				self.cmbTrainOutgoing.listObject := wagon.myTrainOutwards;
			endif;
		endif;
		
		if self.myCurrentWagon.myRailLine &lt;&gt; null then
			self.rakePos := self.myCurrentWagon.myRailLine.allWagons.indexOf(self.myCurrentWagon);
			self.myRailRake := self.myCurrentWagon.myRailLine;
			self.cmbRailArea.listObject := self.myRailRake.myRailArea;
			self.buildComboPosition(self.myRailRake.myRailArea);
			self.buildComboDestTerm();	// TFS 2533
		endif;

		self.lblLocation.caption := self.getLocationId(wagon);	
		self.chkConfirmIn.value := wagon.confirmed;
		self.chkConfirmOut.value := wagon.confirmedOutwards;
		
		if self.cmbWagon.findObject(wagon) = -1 then
			self.cmbWagon.itemObject[self.cmbWagon.addItem(wagon.getDisplayDetails(false))] := wagon; //+ cnwmd1, CCMS 1067, Par 19913
		endif;
		self.cmbWagon.listObject := wagon;
		
		if not self.chkAdvanced.value then //show if not already showing and one of the fields have been modified
			self.chkAdvanced.value := self.myCurrentWagon.hasAdvancedOptionsBeenSet();
			self.chkAdvanced.click(self.chkAdvanced);
		endif;
		
		self.cmbStevedoreRec.setObject(wagon.myStevedoreReceive);   //02.10.2020 cnwma1 TFS #50112
		self.cmbStevedoreRel.setObject(wagon.myStevedoreRelease);   //02.10.2020 cnwma1 TFS #50112
		
		//Start 1 Nov 2022 navhl20 TFS 54281
		if self.myCurrentWagon &lt;&gt; null then
			lblPlanLocation.translateCaption(Xlat_0025185, app.myCurrentLocale); // ### TFS BUG 58951 19JUL2023 NAVAB1
			if self.myCurrentWagon.allPlannedFutureMoves.isNotEmpty then
				self.lblPlanLocation.visible := true;
				self.lblPlanLocation.caption := self.lblPlanLocation.caption &amp; Space &amp; self.myCurrentWagon.getPlannedLocation();
			else
				self.lblPlanLocation.visible := false;// ### TFS BUG 58951 19JUL2023 NAVAB1
			endif;
		endif;
		//End 1 Nov 2022 navhl20 TFS 54281
		
		// ### TFS 62857 (62858) 18Mar2024 NAVPW1
		retrospectiveOpsEnabled := app.myRoot.canDo(Sub_RetroWorkOrder);
		if retrospectiveOpsEnabled then
			if wagon.allRailJobs &lt;&gt; null then
				railJob := wagon.allRailJobs.getFirstInwardsRailJob();
			endif;
			
			if railJob &lt;&gt; null and railJob.retrospectiveDT.isValid then
				self.txtRetroDate.text := railJob.retrospectiveDT.date.asStringJMT;
				self.txtRetroTime.text := railJob.retrospectiveDT.time.asStringJMT;
			endif;
			
		endif;
		// ### TFS 62857 (62858) 18Mar2024 NAVPW1
		
	endif;
	
	self.setControlsForAddEditDelete(_setFocus);
	
end;</source>
        <access>protected</access>
        <Parameter name="_setFocus" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doWagonEdit" id="2f578c85-ed07-40f2-8366-34b8cd550a90">
        <updating/>
        <source>doWagonEdit() protected, updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
26 June 2009	cnwmd1	Initial creation

*/

vars

begin
