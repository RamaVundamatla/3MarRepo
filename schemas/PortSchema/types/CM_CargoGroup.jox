    <JadeMethod name="getInfoStr" id="b244742f-1234-48d6-9d76-7fd93fda536b">
        <source>getInfoStr(_inDetail: Boolean): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21/08/2015	cnwndl1	Initial creation	Par 36608
16/01/2018	jlgdap1	TFS 36658 STWR Cargo Scanning Enhancements
*/

vars
//	cgNotified : CM_NotifiedCargoGroup;
	assign : CM_CargoGroupAssignment;
	locStr : String;
	str : String;

begin

	assign := self.getMyCargoGroupAssignment;	//01 Oct 2018	NDL	TFS 39186
	locStr := self.getDefaultLocation;	//01 Oct 2018	NDL	TFS 39186
	
/*	cgNotified := self.myCargoGroupTerminal.getNotifiedGroupForCargoGroup(self);	// TFS 36658
	if cgNotified &lt;&gt; null and cgNotified.myCargoGroupAssignment &lt;&gt; null then		// TFS 36658
		str := "Assignment " &amp; cgNotified.myCargoGroupAssignment.id;				// TFS 36658
		if cgNotified.defaultLocation &lt;&gt; null then									// TFS 36658
			str := str &amp; " / " &amp; cgNotified.defaultLocation;						// TFS 36658
		endif;																		// TFS 36658
		str := str &amp; CrLf;															// TFS 36658
	endif;																			// TFS 36658 */
	
	//01 Oct 2018	NDL	TFS 39186
	if assign &lt;&gt; null then		
		str := "Assignment " &amp; assign.id;			
		if locStr &lt;&gt; null then									
			str := str &amp; " / " &amp; locStr;					
		endif;																	
		str := str &amp; CrLf;														
	endif;
	
	if self.isComplete then
		//str := app.getErrorString(Complete) &amp; CrLf;								// TFS 36658
		str := str &amp; app.getErrorString(Complete) &amp; CrLf;							// TFS 36658
	endif;
	
	str := str &amp; inheritMethod(_inDetail);
	
	return str;

epilog

end;</source>
        <Parameter name="_inDetail" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getLastOnsiteLocation" id="f4c3281c-0718-4e2e-9a69-593e2228ed08">
        <source>getLastOnsiteLocation():CM_LocationsController;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 August 2015	cnwndl1	Initial creation	Par 36338
13 Nov 2019	NDL	TFS 47298

*/

vars

	iter : Iterator;
	ti : CM_TrackedItem;
	
	tmpFoundLC : CM_LocationsController;
	tmpFoundHeight : Integer;

begin

	iter := self.allAssignedTrackedItems.createIterator;
	while iter.back( ti ) do
		if not ti.isOnSite then
			continue;
		endif;
		if ti.isNotified or ti.myPrimaryActualLocation = null then	//15 Feb 2016	NDL	Par 37544
			continue;
		endif;
		
		return ti.myPrimaryActualLocation;
	endwhile;
	
	//02 Oct 2018	NDL	TFS 39186
	if self.getDefaultLocation &lt;&gt; null then
		self.myTerminal.findLocationFromString(self.getDefaultLocation, true, tmpFoundLC, tmpFoundHeight);
	endif;
	
	//return null;
	return tmpFoundLC;	//02 Oct 2018	NDL	TFS 39186

epilog

	delete iter;

end;</source>
        <ReturnType type="CM_LocationsController"/>
    </JadeMethod>
    <JadeMethod name="getMarkNumber" id="ef741d28-04ce-4665-a2cd-36617ed0ca81">
        <source>getMarkNumber():String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 Feb 2024 navhl20 ChangeRequest 62406:[62534] EUP | Scanning App Cargo Group Overview Changes

*/

vars
	ti 		: CM_TrackedItem;
	strArr	: StringArray;
begin
	create strArr transient;
	foreach ti in self.allAssignedTrackedItems do	
		if ti.markNumber &lt;&gt; null and not strArr.includes(ti.markNumber) then
			strArr.add(ti.markNumber);
		endif;
	endforeach;
	
	return strArr.concatenate(Comma);
epilog
	delete strArr;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getMeasureMaxWeightUnit" id="594dd25c-f2ba-4a63-ae51-f7855ac1b3fa">
        <source>getMeasureMaxWeightUnit() : String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 August 2015	cnwndl1	Initial creation	Par 36608

*/

vars
	measureType : CM_MeasurementType;

begin
	measureType := app.getDefaultMeasurementForType(Type_Weight);
	if measureType = null then
		return self.maxWeight.asStringWeightJMT;
	endif;
	return app.convertMeasurementForDisplay(measureType.shortName, self.maxWeight) &amp; "(" &amp; measureType.shortName &amp; ")";
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
