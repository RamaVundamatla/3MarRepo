    <JadeMethod name="translateForm" id="5ad75def-380b-4adb-a31a-913f2d67d41d">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 09 June 2020 07:54:01.
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0023925, locale);
	btnUpdate.translateCaption(Xlat_0023926, locale);
	lblBillOfLading.translateCaption(Xlat_0023927, locale);
	lblCargoBeing.translateCaption(Xlat_0023928, locale);
	lblCargoOper.translateCaption(Xlat_0023929, locale);
	lblCargoQuantity.translateCaption(Xlat_0023930, locale);
	lblCargoWeight.translateCaption(Xlat_0023931, locale);
	lblDischargePort.translateCaption(Xlat_0023932, locale);
	lblNewCargoId.translateCaption(Xlat_0023933, locale);
	lblParts.translateCaption(Xlat_0023934, locale);
	lblSpecialStow.translateCaption(Xlat_0023935, locale);
	lblSplitInto.translateCaption(Xlat_0023936, locale);
	lblTotalWeight.translateCaption(Xlat_0023937, locale);
	lblVoyGroupCode.translateCaption(Xlat_0023938, locale);
	lblVoyage.translateCaption(Xlat_0023939, locale);
end;</source>
    </JadeMethod>
