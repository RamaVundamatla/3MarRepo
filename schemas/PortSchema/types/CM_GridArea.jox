    <JadeMethod name="setNewLabels" id="bd0c5870-7468-4063-88db-771a33344686">
        <updating/>
        <source>setNewLabels(_proxyGridArea : CM_GridArea; _passport : CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:		02 May 2003  by Jason Chapman  (cnwjc2)
// ---------------------------------------------------------------------------

vars
	gridColumn 		: CM_GridColumn;
	gridRow			: CM_GridRow;
	rowLabels,
	columnLabels	: StringArray;
begin
 	create rowLabels transient;
 	create columnLabels transient;
	
	foreach gridColumn in _proxyGridArea.allGridColumns do
		columnLabels.add(gridColumn.label);
	endforeach;
	
	foreach gridRow in _proxyGridArea.allGridRows do
		rowLabels.add(gridRow.label);
	endforeach;
	self.setRowAndColumnLabels(rowLabels, columnLabels , _passport);

epilog
delete rowLabels;
delete columnLabels;
end;</source>
        <Parameter name="_proxyGridArea" type="CM_GridArea"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setOutDeckingReverseOfIn" id="fb5fbca8-7cd2-4090-9a55-f283cac1ea97">
        <source>setOutDeckingReverseOfIn();
//----------------------------------------------------------------
//	Created:	14 April 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	locnCell		: CM_YALocationCell;
begin
	//do default out - reverse of in?
	
	self.myYADeckingOptions.allYALocationCellsOut.clear;
	foreach locnCell in self.myYADeckingOptions.allYALocationCellsIn reversed do
		self.myYADeckingOptions.allYALocationCellsOut.add(locnCell);
	endforeach;

end;</source>
    </JadeMethod>
    <JadeMethod name="setPreviousControllers" id="df71da16-20c3-4232-ac4e-bf244d0cea5c">
        <source>setPreviousControllers();

vars

	row					: CM_GridRow;
	controller, prev	: CM_GridController;

begin

	foreach row in self.allGridRows do
		prev := null;
		foreach controller in row.allControllersByColumn do
			if prev &lt;&gt; null then
				controller.setMyPreviousController(prev);
			endif;
			prev := controller;
		endforeach;
	endforeach;

end;</source>
    </JadeMethod>
    <JadeMethod name="setRowAndColumnLabels" id="9dc9d124-459b-461f-a799-b79bd029b531">
        <updating/>
        <source>setRowAndColumnLabels(_allRowLabels, _allColumnLabels : StringArray input; _passport : CM_Passport input) updating;
// 29 Aug 2012	cnwcs5	par 30292 - use updateObjectEdition instead of updateEdition 
vars
	count	: Integer;
	column	: CM_GridColumn;
	row		: CM_GridRow;
	tmpLC	: CM_LocationsController;
		
begin

	if _allColumnLabels.size = self.allGridColumns.size then
		// Set dummy just in case label already exists.
		foreach column in self.allGridColumns do
			count := count + 1;
			column.setColumnLabel('_' &amp; count.String); // PAR 9036 changed to '_'
		endforeach;
		// ### PAR 8923  AKB2004SEP. Re label all the LCs incase of a rename of columns or rows
		foreach tmpLC in self.allLocationsControllers do 
			if tmpLC.isKindOf(CM_GridController) then
				tmpLC.CM_GridController.setName();
			endif;
		endforeach;


		count := 0;
		foreach column in self.allGridColumns do
			count := count + 1;
			column.setColumnLabel(_allColumnLabels[count]);
		endforeach;
	else
		app.raiseCMException1(ERR_INVALID_ARRAY, null, null, null);
	endif;
	if _allRowLabels.size = self.allGridRows.size then
		count := 0;
		// Set dummy just in case label already exists.
		foreach row in self.allGridRows do
			count := count + 1;
			row.setRowLabel('_' &amp; count.String);// PAR 9036 
		endforeach;
		// ### PAR 8923  AKB2004SEP. Re label all the LCs incase of a rename of columns or rows
		foreach tmpLC in self.allLocationsControllers do 
			if tmpLC.isKindOf(CM_GridController) then
				tmpLC.CM_GridController.setName();
			endif;
		endforeach;

		count := 0;
		foreach row in self.allGridRows do
			count := count + 1;
			row.setRowLabel(_allRowLabels[count]);
		endforeach;
	else
		app.raiseCMException1(ERR_INVALID_ARRAY, null, null, null);
	endif;
	
	if _passport.noErrors then
		foreach tmpLC in self.allLocationsControllers do
			if tmpLC.isKindOf(CM_GridController) then
				tmpLC.CM_GridController.setName();
			endif;
		endforeach;
	endif;
	
	self.updateObjectEdition(self);	/// par 30292
end;</source>
        <Parameter name="_allRowLabels" type="StringArray" usage="input"/>
        <Parameter name="_allColumnLabels" type="StringArray" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setRowsColsAndControllers" id="d489d974-da43-480e-aa7f-1ff9b97d4a11">
        <updating/>
        <source>setRowsColsAndControllers(pProxy : CM_GridArea) updating, protected;
// ---------------------------------------------------------------------------
// Created:     28 January 2002 by cnwrs2
//
// Purpose:     This method updates all the rows, columns and controllers.
//				If a row/col is not present then it adds.  Otherwise it
//				updates.
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	idx,count			: Integer;
	realGridRow,
	pxyGridRow	: CM_GridRow;
	realGridCol,
	realGridColumn,pxyGridCol	: CM_GridColumn;
	pxyGridCntrl,
	realGridCntrl	: CM_GridController;
	tmpClass	: Class;
	created : Boolean;
	newRowSet	: ObjectSet;
	obj 		: Object;
	dupGridLC : CM_GridController;
begin
	if (pProxy.allGridColumns.size = self.allGridColumns.size 
		and pProxy.allGridRows.size = self.allGridRows.size) then
		self.setNewLabels(pProxy,app.myPassport); // PAR 8080 added this. If they have changed the labels the next foreach would delete rows and 
												//			columns and then the foreach after that crashed witha deleted object
	endif;
	// the proxy grid area has had any rows already removed.
	// so compare to real area and delete, for real, the ones that we do not want
	count := 0;
	foreach realGridRow in self.allGridRows do
//		if pProxy.getGridRowFromLabel(realGridRow.label) = null then	
		if realGridRow.pxyGetProxyObject = null then
	//	if pProxy.allGridRows[realGridRow.row] = null then
			delete realGridRow;
			continue;
		endif;
		count := count + 1;
		realGridRow.setRowLabel('_' &amp; count.String); // PAR 9036
	endforeach;
	
	if (not pProxy.allGridRows.isEmpty) then
		tmpClass := pProxy.allGridRows.first.class;
		foreach pxyGridRow in pProxy.allGridRows  do
			realGridRow := pxyGridRow.pxyGetRealObject();
			if realGridRow &lt;&gt; null 
			and global.isValidObject(realGridRow) then
				if  (realGridRow.row &lt;&gt; pxyGridRow.row) and self.allGridRows[pxyGridRow.row] &lt;&gt; null then
					self.allGridRows[pxyGridRow.row].setRow(self.allGridRows.last.row + 1);
				endif;
			
				realGridRow.setForUpdate(pxyGridRow);
			else
				if   self.allGridRows[pxyGridRow.row] &lt;&gt; null then
					self.allGridRows[pxyGridRow.row].setRow(self.allGridRows.last.row + 1);
				endif;
				create realGridRow as tmpClass persistent;
				created := true;// PAR 9036 
				realGridRow.setForCreate(pxyGridRow, self);
			endif;
			
		endforeach;
	endif;
	
	// the proxy grid area has had any columns already removed.
	// so compare to real area and delete, for real, the ones that we do not want
	count := 0;
	foreach realGridColumn in self.allGridColumns do
//		if pProxy.getGridColumnFromLabel(realGridColumn.label) = null then
		if realGridColumn.pxyGetProxyObject = null then
		//if pProxy.allGridColumns[realGridColumn.column] = null then
			delete realGridColumn;
			continue;
		endif;
		count := count + 1;
		realGridColumn.setColumnLabel('_' &amp; count.String); // PAR 9036
	endforeach;

	// Now do the updates
	if (not pProxy.allGridColumns.isEmpty) then
		tmpClass := pProxy.allGridColumns.first.class;
		foreach pxyGridCol in pProxy.allGridColumns reversed do  
			realGridCol := pxyGridCol.pxyGetRealObject();
			
			if realGridCol &lt;&gt; null 
			and global.isValidObject(realGridCol) then
				if (realGridCol.column &lt;&gt; pxyGridCol.column) and self.allGridColumns[pxyGridCol.column] &lt;&gt; null then
					self.allGridColumns[pxyGridCol.column].setColumn(self.allGridColumns.last.column + 1);
				endif;
				realGridCol.setForUpdate(pxyGridCol);
			else
				if  self.allGridColumns[pxyGridCol.column] &lt;&gt; null then
					self.allGridColumns[pxyGridCol.column].setColumn(self.allGridColumns.last.column + 1);
				endif;
				create realGridCol as tmpClass persistent;
				created := true;// PAR 9036 
				realGridCol.setForCreate(pxyGridCol, self);
			endif;
		endforeach;
	endif;
	
	if  app.isConverting and self.isKindOf(CM_RTGArea) then
		//ccms 1076 we don't want to do below when creating the new rtg areas via the conversion scripts
		//this is because we are moving all the location controllers
	else
		foreach pxyGridCntrl in pProxy.allGridControllersByRowColumn reversed do
			tmpClass := pxyGridCntrl.class;
			realGridCntrl := pxyGridCntrl.pxyGetRealObject();
			if realGridCntrl = null then
				realGridCntrl := self.allGridControllersByRowColumn[pxyGridCntrl.row, pxyGridCntrl.column];
			endif;
			
			//epr par 34859 3/9/14
			dupGridLC:= self.allGridControllersByName[pxyGridCntrl.name];
			if dupGridLC &lt;&gt; null then
				dupGridLC.setNameForDuplicates();
			endif;
			
			if realGridCntrl &lt;&gt; null 
			and global.isValidObject(realGridCntrl) then
				// need to check that class has not changed
				if realGridCntrl.class &lt;&gt; tmpClass then
					realGridCntrl.erase(NORMAL_ERASE);
					realGridCntrl := null;
				endif;
			endif;
			
			if realGridCntrl &lt;&gt; null 
			and global.isValidObject(realGridCntrl) then
				if (pxyGridCntrl.id40ft &lt;&gt; null and (realGridCntrl.id40ft &lt;&gt; pxyGridCntrl.id40ft)) and self.allGridControllersBy40ftId[pxyGridCntrl.id40ft] &lt;&gt; null then
					self.allGridControllersBy40ftId[pxyGridCntrl.id40ft].setMy40ftGridArea(null);
				endif;
				realGridCntrl.setForUpdate(pxyGridCntrl, self);
			else
				create realGridCntrl as tmpClass persistent;
				realGridCntrl.setForCreate(pxyGridCntrl, self);
			endif;
		endforeach;
	endif;

	// Finally delete any real objects that are outside the new range.  This is
	// done in the following manner to remove any dependancy on the "row" or
	// "column" attributes being set sequentially
	while self.allGridRows.size &gt; pProxy.numberOfRows do
		realGridRow := self.allGridRows.last;
		realGridRow.erase(NORMAL_ERASE);
	endwhile;

	while self.allGridColumns.size &gt; pProxy.numberOfColumns do
		realGridCol := self.allGridColumns.last;
		realGridCol.erase(NORMAL_ERASE);
	endwhile;
	if (pProxy.allGridColumns.size = self.allGridColumns.size 
		and pProxy.allGridRows.size = self.allGridRows.size) then
		self.setNewLabels(pProxy,app.myPassport); // PAR 8080 added this. If they have changed the labels the next foreach would delete rows and 
												//			columns and then the foreach after that crashed witha deleted object
	endif;

	//epr par 26789 9/2/2011 have to update the row and columns hasGap attribute once all the controllers have been succcessfully updated
	foreach realGridRow in self.allGridRows do
		realGridRow.setHasGap();
	endforeach;
	foreach realGridCol in self.allGridColumns do
		realGridCol.setHasGap();
	endforeach;
	
	
	if created then// PAR 9036 
		if (pProxy.allGridColumns.size = self.allGridColumns.size // PAR 9036 
			and pProxy.allGridRows.size = self.allGridRows.size) then// PAR 9036 
			self.setNewLabels(pProxy,app.myPassport); // PAR 9036 
		endif;
	endif;
epilog
	
end;</source>
        <access>protected</access>
        <Parameter name="pProxy" type="CM_GridArea"/>
    </JadeMethod>
    <JadeMethod name="sizeChanged" id="90dfa70e-b53b-4099-8914-ccd0b811c9cd">
        <source>sizeChanged(_gridArea: CM_GridArea): Boolean;
//----------------------------------------------------------------
//	Created:	23 September 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin
	
	if self.allGridColumns.size &lt;&gt; _gridArea.allGridColumns.size then
		return true;
	endif;
	
	if self.allGridRows.size &lt;&gt; _gridArea.allGridRows.size then
		return true;
	endif;
	
	return false;
		
end;</source>
        <Parameter name="_gridArea" type="CM_GridArea"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="sortLoadTIsByOrder" id="7789d6f0-935e-48ca-9773-b229ce2faf4f">
        <source>sortLoadTIsByOrder(sortOrder : Integer; tis : CM_TIArray io);
// ---------------------------------------------------------------------------
// Created:		June 2001 By Andrew Bishop cnwab1
//
// Purpose:		Takes an array of TIs that have been determined are suitable for loading
//				to a Ship Job, and sorts them by the stacking rule passed in as "sortOrder".
//				ASSUMPTIONS: That the TI's are basically in the stack order the users wi sh
//				to process through (ie, first stack, next stack, next stack...)

// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//		18 Jan2002	DWQ	Originally used an LC to store the tracked items. This no longer works with
//											the advent of inverses on LC class. Rewritten with new object class
// 24/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
// ---------------------------------------------------------------------------

vars
	tiStorage : CM_LCByTISorter;
	lcArray : CM_LCArray;
	tempArray : CM_TIArray;
	ti : CM_TrackedItem;
	newTI	 : CM_TrackedItem;
	tmpLC : CM_LocationsController;
	origLC : CM_GridController;
	mapper : CM_LCByTISorterByLCDict;
	origStackPos : Integer;
	newStackPos : Integer;
	newPos : Integer;
	foundOne : Boolean;
	advanceToNextRow : Boolean;
	currRow : Integer;
	lastRow : Integer;
	rowStacksMT : Boolean;
	numInStack : Integer;

begin

	create lcArray  transient;
 	create tempArray transient;
 	create mapper transient;
 	if sortOrder &lt;&gt; STACK_ALONG_ROW and sortOrder &lt;&gt; STACK_UP_STACK then
 		//Comment 15 March 1999 - DQ. JT of PO has asked for a "stack all at lowest height in area, then to next height"
 		//I have accommodated this, however for this method, it is a little silly, so its been ignored.
 		return;
 	endif;
 	//------------
 	//Copy the passed in array first
 	//------------
 	tis.copy(tempArray);
 	//------------
 	//Depending on the Mode, re-arrange the array
 	//------------
 	//Grunt through, and arrange them all into LC/by upside down TI
 	//order. IE: LC's in original sequential order of the TI's passed, and the
 	//TI's added to the LC in a top down format.
	foreach ti in tempArray do
		tmpLC := ti.getPrimaryLocation(REAL_MODE);
		//Find the tiStorage object for this LC (the mapper is keyed by lc)
		origLC := tmpLC.CM_GridController;
		tiStorage := mapper[origLC];

		if tiStorage &lt;&gt; null then
			//We have seen this sorter with the TI's LC before..
			//Add new TI in stack down order, 
			origStackPos := origLC.getIndexOfTI(REAL_MODE,ti);
			numInStack := origLC.numTIs;
			if origStackPos = numInStack then  
				//TI was at TOP of the stack, add as FIRST in new stack
				newPos := 1;
			elseif origStackPos = 1 then  
				//TI was at BOTTOM of the stack, add as LAST in new stack
				newPos := numInStack +1;
			else
				//TI is in middle of stack somewhere, work out where in relation to
				//others
				foreach newTI in origLC.allTrackedItems do
					//Get original locn of each ti in the stack we have.
					newStackPos := origLC.allTrackedItems.indexOf(newTI);
					if newStackPos &lt; origStackPos then
						//TI in our new stack was originally below TI we are trying to add.
						//Add it at newStackPos
						newPos := newStackPos;
						break;
					endif; 
				endforeach;
			endif;
			//Put TI into correct location.
			if newPos &gt; numInStack then
				tiStorage.trackedItems.add(ti);
			else
				tiStorage.trackedItems.insert(newPos, ti);
			endif;
		else
			//Not found...
			create tiStorage transient;
			//Set ordinal row, for row by row processing.
			tiStorage.ordinalRow := origLC.myGridRow.row;
			tiStorage.currentLC := origLC;
			tiStorage.trackedItems.add(ti);
			mapper.add(tiStorage);
			lcArray.add(origLC);		//Add to array so we process corrctly later.
		endif;
	endforeach;
	//---------------------
	//Clear before we re-set them back
	//---------------------
	tis.clear;
	if sortOrder = STACK_UP_STACK then
		foreach tmpLC in lcArray do
			origLC := tmpLC.CM_GridController;
			tiStorage := mapper[origLC];
			if tiStorage = null then 
				//Should NEVER happen!
				continue;
			endif;
			foreach ti in tiStorage.trackedItems do
				//-----------
				//Add this last ti to our list to return
				//-----------
				tis.add(ti);
			endforeach;
		endforeach;
		
	elseif sortOrder = STACK_ALONG_ROW then
		//Working ALONG THE ROW, take top TI off each stack.
		//Grunt through each LC, take topMost TI off and add
		//into our return array.
		lastRow := -1;
		while true do
			//This level of the loop ensures we zoom through ALL
			//layers of TIs in the lcs
			foundOne := false;	
			currRow := -1;
			advanceToNextRow := true;
			while true do
				//--------------
				//This level of the loop is used for Row processing
				//After each row, we skip back, and do it again until
				//no TIs in row, then we progress to next Row.
				//--------------
				foreach tmpLC in lcArray do
					origLC := tmpLC.CM_GridController;
					tiStorage := mapper[origLC];
					if tiStorage = null then 
						//Should NEVER happen!
						continue;
					endif;
					if tiStorage.ordinalRow &lt;&gt; currRow then
						if advanceToNextRow = false then
							break;	//Not finished emptying row yet, restart.
						endif;
						currRow := origLC.myGridRow.row;
						advanceToNextRow := false;
					endif;

					ti := tiStorage.trackedItems.first;
			  		if ti = null then
						rowStacksMT := true;
						continue;
			  		endif;
					rowStacksMT := false;
					foundOne := true;
					//-----------
					//Add this last ti to our list
					//-----------
					tis.add(ti);
					//-----------
					//Rip out ti, we have just passed it to array to return.
					//-----------
					tiStorage.trackedItems.removeAt(1);
				endforeach;
				if rowStacksMT then
					advanceToNextRow := true;
					break;
				endif;
			endwhile;
			if not foundOne then
				break;
			endif;
		endwhile;
	endif;
epilog
	//----------------------
	//Housekeeping
	//----------------------
	lcArray.clear;
	delete lcArray;
	tempArray.clear;
	delete tempArray;
	mapper.purge;	//We nuke these objects.
	delete mapper;
end;</source>
        <Parameter name="sortOrder" type="Integer"/>
        <Parameter name="tis" type="CM_TIArray" usage="io"/>
    </JadeMethod>
    <JadeMethod name="testFindHuntedTILC" id="485549b5-056d-4b0c-a908-e1d65b7795a2">
        <source>testFindHuntedTILC(obj: CMIF_AutoMovePlan input; attribArea: CM_AttributeArea): CM_YardController;
// ---------------------------------------------------------------------------
// Created:		June 2001 By Andrew Bishop cnwab1
//
// Purpose:		Called by determineAutoPlanLocation on an attributeArea
//				returns the LC of a TI that matches the Voyage, commodity Group, and Discharge
//				port of the matches the one we are trying to automatch against.
//				We start from there...

//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 24/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
// ---------------------------------------------------------------------------

vars
	voy	:	CM_Voyage;
	dischP	: String;
	commGrp	: String;
	lc	:	CM_GridController;
	ti	:	CM_TrackedItem;
	locnId	:	String;
begin

//	return inheritMethod(obj, attribArea);
	if obj.myTrackedItem = null then
		app.raiseCMException2(MethodWithNullParam, method.name, 'Tracked Item Reference',null, null);
		return null;
	endif;
	//-------------
	//Store our checking stuff off..
	//-------------
	voy := obj.myTrackedItem.myVoyage;
	dischP := obj.myTrackedItem.dischargePort.trimRight;
	commGrp := obj.myTrackedItem.commodityGroup.trimRight;	
	//---------------
	//Test each lc
	//---------------
	foreach lc in self.allGridControllersByRowColumn do
		if lc.allAttributeAreas.isEmpty then
			//---------------------------
			//Not included as part of any autoplan
			//---------------------------
			continue;
		endif;
		locnId	:= lc.getFullId;
		if not lc.allAttributeAreas.includes(attribArea) then
			//---------------------------
			//Not included as part of this Attribute plan
			//---------------------------
			//obj.addVerboseLogEntry(locnId &amp; " Not included in selected Attribute Area locations, continuing...", IsForLogging); //- cnwmd1, Par 20524
			obj.addVerboseLogEntry(app.getErrorString1(Inclu_selec_attri_area_locat_c,locnId), IsForLogging, Inclu_selec_attri_area_locat_c);
			continue;
		endif;
		if lc.numTIs &gt; 0 then
			ti := lc.getTIAtIndex(REAL_MODE, 1);
			
		//	if ti.myVoyage = voy then
			if ti &lt;&gt; null and ti.myVoyage = voy then	//10 Nov 2017	NDL	TFS 7635
				if ti.dischargePort.trimRight = dischP then
					if ti.commodityGroup.trimRight = commGrp then
						//Near enough for us, Start from this LC.
						//obj.addVerboseLogEntry("Hunting found location " &amp; locnId &amp; " and is using this location as a start position for the subsequent search.", IsForLogging); //- cnwmd1, Par 20524
						obj.addVerboseLogEntry(app.getErrorString1(Hunti_found_locat_using_this_l,locnId), IsForLogging, Hunti_found_locat_using_this_l);
						return lc;
					endif;
				endif;
			endif;
		endif;
		//-------------------------
		//Attempt the position using planning and queued mode checks
		//-------------------------
		if obj.moveMode = PLANNING_MODE then
			if lc.numPlannedTIs &lt;= 0 then
				//obj.addVerboseLogEntry("No planned Tracked items to hunt to at " &amp;locnId &amp; " continuing...", IsForLogging); //- cnwmd1, Par 20524
				obj.addVerboseLogEntry(app.getErrorString1(Planne_tracke_items_hunt_conti,locnId), IsForLogging, Planne_tracke_items_hunt_conti);
				continue;
			endif;
			ti := lc.getTIAtIndex(PLANNING_MODE, 1);
			
			//10 Nov 2017	NDL	TFS 7635
			if ti = null then	
				obj.addVerboseLogEntry(app.getErrorString1(Planne_tracke_items_hunt_conti,locnId), IsForLogging, Planne_tracke_items_hunt_conti);
				continue;
			endif;
			
			if ti.myVoyage &lt;&gt; voy then
				continue;
			endif;
			if ti.dischargePort.trimRight &lt;&gt; dischP then
				continue;
			endif;
			if ti.commodityGroup.trimRight &lt;&gt; commGrp then
				continue;
			endif;
			//-----------------
			//Near enough for us, Start from this LC.
			//-----------------
			//obj.addVerboseLogEntry("Hunting found location " &amp; locnId &amp; " and is using this location as a start position for the subsequent search.", IsForLogging); //- cnwmd1, Par 20524
			obj.addVerboseLogEntry(app.getErrorString1(Hunti_found_locat_using_this_l,locnId), IsForLogging, Hunti_found_locat_using_this_l);
			return lc;
		elseif obj.moveMode = QUEUE_MODE then
			if lc.numQueuedTIs &lt;=  0 then
				//obj.addVerboseLogEntry("No queued Tracked items to hunt to at " &amp;locnId &amp; " continuing...", IsForLogging); //- cnwmd1, Par 20524
				obj.addVerboseLogEntry(app.getErrorString1(Queued_tracke_items_hunt_conti,locnId), IsForLogging, Queued_tracke_items_hunt_conti);
				continue;
			endif;
			ti := lc.getTIAtIndex(QUEUE_MODE, 1);
			
			//10 Nov 2017	NDL	TFS 7635
			if ti = null then
				obj.addVerboseLogEntry(app.getErrorString1(Queued_tracke_items_hunt_conti,locnId), IsForLogging, Queued_tracke_items_hunt_conti);
				continue;
			endif;
			
			if ti.myVoyage &lt;&gt; voy then
				continue;
			endif;
			if ti.dischargePort.trimRight &lt;&gt; dischP then
				continue;
			endif;
			if ti.commodityGroup.trimRight &lt;&gt; commGrp then
				continue;
			endif;
			//-----------------
			//Near enough for us, Start from this LC.
			//-----------------
			//obj.addVerboseLogEntry("Hunting found location " &amp; locnId &amp; " and is using this location as a start position for the subsequent search.", IsForLogging); //- cnwmd1, Par 20524
			obj.addVerboseLogEntry(app.getErrorString1(Hunti_found_locat_using_this_l,locnId), IsForLogging, Hunti_found_locat_using_this_l);
			return lc;
		endif;
	endforeach;
	//--------------
	//If we've got to here, forget it!
	//--------------
	//obj.addVerboseLogEntry("Hunting in " &amp; self.id.trimRight &amp; " has failed to find a similiar item. Continuing....", IsForLogging); //- cnwmd1, Par 20524
	obj.addVerboseLogEntry(app.getErrorString1(Hunti_faile_find_simil_item_co,self.id.trimRight), IsForLogging, Hunti_faile_find_simil_item_co);
	return null;
end;</source>
