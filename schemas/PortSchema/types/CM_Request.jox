    <JadeMethod name="getReserveSelectionCriteria" id="9f223dc6-fede-4f70-9d73-a01d284b046a">
        <source>getReserveSelectionCriteria(): CM_ReleaseByTypeCriteria;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 June 2015	cnwndl1	Initial creation	Par 36338

*/

vars

	reserveSelection : CM_ReserveSelection;

begin

	if self.myReserveDetail &lt;&gt; null and self.myReserveDetail.isKindOf(CM_ReserveSelection) then
		reserveSelection := self.myReserveDetail.CM_ReserveSelection;
		if CM_ReserveSelection.hasInstance(reserveSelection) then
			return reserveSelection.myReleaseCriteria;
		endif;
	endif;
	
	return null;

epilog

end;</source>
