	// 07.08.2023 navlw1 tfs #59284:#59664
	create qProp as CM_QStrTodoTaskMethod persistent;
	qProp.set('Todo Task Type', CM_WOTransaction::getTodoTaskDesc.name, self.className);	
	qProp.setPerformanceRating( CM_QueryProperty.Simple );	// Simple	= '1', CollKey	= '2', Complex	= '3'
