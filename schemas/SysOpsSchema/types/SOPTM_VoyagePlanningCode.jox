    <JadeMethod name="includeObject" id="f8a62ac7-9e64-495d-bd1d-2c8de13b224a">
        <updating/>
        <source>includeObject(_obj: Object; _passport: CM_Passport): Boolean updating;
// --------------------------------------------------------------------------------
// Created:		24 April 2006 by cnwdad1
//
// Purpose:		Refer to superclass implementation.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//27 Aug 2018	jlgrh7 TFS #40088 STWO - Ticket 39091: Voyage Planning Codes do not show in terminal Admin
// --------------------------------------------------------------------------------
begin
	if self.includeNotAvailableEntries  then
		return true;
	else
		//return   _obj.CM_VoyagePlanningCode.notAvailableForEntry;				//-TFS40088
		return  not _obj.CM_VoyagePlanningCode.notAvailableForEntry;			//+TFS40088
	endif;
end;</source>
        <Parameter name="_obj" type="Object"/>
        <Parameter name="_passport" type="CM_Passport"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
