    <JadeMethod name="getXMLSettingsForSave" id="53b113d3-7481-457d-b635-3c4a2870d412">
        <updating/>
        <source>getXMLSettingsForSave(): String updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 April 2014	cnwndl1	Initial creation

*/

vars
	rtnStr : String;
begin
	rtnStr := inheritMethod();
	rtnStr := rtnStr &amp; global.formatAsXML(CM_DataTable.XMLTag_ColWidth, self.tblAreas.getXMLStrForColWidths());
	rtnStr := rtnStr &amp; global.formatAsXML(self.XML_FormWidth, self.width.String);
	rtnStr := rtnStr &amp; global.formatAsXML(self.XML_FormHeight, self.height.String);
	return rtnStr; 
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="initFromUserWindow" id="21bdd1c0-12fc-4996-994c-98a24852dece">
        <updating/>
        <source>initFromUserWindow(_userWindow: CM_UserWindow) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 April 2014	cnwndl1	Initial creation

*/

vars

	xml : String;
	index : Integer;
	strArray : CnStringArray;
	str : String;

begin

	inheritMethod(_userWindow);
	
	index := 1;
	xml := _userWindow.xmlInfo.cnEcGetNextTagValueOfName(CM_DataTable.XMLTag_ColWidth, index);
	if xml &lt;&gt; null and  xml.isInteger then
		self.width := xml.Integer;
	endif;
	
	
	index := 1;
	xml := _userWindow.xmlInfo.cnEcGetNextTagValueOfName(CM_DataTable.XMLTag_ColWidth, index);
	if xml &lt;&gt; null and  xml.isInteger then
		self.height := xml.Integer;
	endif;
	
	index := 1;
	xml := _userWindow.xmlInfo.cnEcGetNextTagValueOfName(CM_DataTable.XMLTag_ColWidth, index);
	index := 0;	
	if xml &lt;&gt; null then
		strArray := xml.cnGetTokens(",");
		foreach str in strArray do
			index := index + 1;
			if index &lt;= self.tblAreas.columns and str.isInteger then
				self.tblAreas.accessColumn(index).width := str.Integer;
			endif;
		endforeach;
	endif;
	
epilog

	delete strArray;

end;</source>
        <Parameter name="_userWindow" type="CM_UserWindow"/>
    </JadeMethod>
    <JadeMethod name="initTblAreas" id="7fab5c51-b833-4cba-acbe-b64f17a865d2">
        <source>initTblAreas();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 April 2014	cnwndl1	Initial creation	Par 33995

*/

vars

	headingLine : String;
	baseRowHeight : Integer;

begin

	self.tblAreas.clear();
	self.tblAreas.rows := 1;
	self.tblAreas.columns := 8;
	self.tblAreas.fixedRows := 1;
	self.tblAreas.fixedColumns := 0;
	
	headingLine :=    app.getErrorString(CheckBox_Include) &amp; Tab // Col_Incl_TA
					&amp; app.getErrorString(TerminalAreas) &amp; Tab // Col_Ta_Name
					&amp; "+/-" &amp; Tab // Col_Expand_TA
					&amp; app.getErrorString(CheckBox_Include) &amp; Tab // Col_Incl_SubArea
					&amp; app.getErrorString(SubArea) &amp; Tab // Col_SubArea_Name
					&amp; "+/-" &amp; Tab // Col_Expand_SubArea
					&amp; app.getErrorString(CheckBox_Include) &amp; Tab // Col_Incl_Location
					&amp; app.getErrorString(SubSubArea);  //Col_Location_Name
						
	self.tblAreas.setCellText(1,1,headingLine);
	baseRowHeight := self.tblAreas.accessRow(1).height;
//	self.tblAreas.accessRow(1).height := ( baseRowHeight * 2 );
	
	self.tblAreas.accessColumn(Col_Incl_TA).alignment := Table.Alignment_Center_Middle;
	self.tblAreas.accessColumn(Col_Expand_TA).alignment := Table.Alignment_Center_Middle;
	self.tblAreas.accessColumn(Col_Incl_SubArea).alignment := Table.Alignment_Center_Middle;
	self.tblAreas.accessColumn(Col_Expand_SubArea).alignment := Table.Alignment_Center_Middle;
	self.tblAreas.accessColumn(Col_Incl_Location).alignment := Table.Alignment_Center_Middle;
	
	self.tblAreas.accessColumn(Col_Incl_TA).width := 30;
	self.tblAreas.accessColumn(Col_Expand_TA).width := 30;
	self.tblAreas.accessColumn(Col_Incl_SubArea).width := 30;
	self.tblAreas.accessColumn(Col_Expand_SubArea).width := 30;
	self.tblAreas.accessColumn(Col_Incl_Location).width := 30;
	
	self.tblAreas.accessColumn(Col_Incl_TA).gridRight := false;
	self.tblAreas.accessColumn(Col_Ta_Name).gridRight := false;
	self.tblAreas.accessColumn(Col_Expand_TA).gridRight := false;
	self.tblAreas.accessColumn(Col_Incl_SubArea).gridRight := false;
	self.tblAreas.accessColumn(Col_SubArea_Name).gridRight := false;
	self.tblAreas.accessColumn(Col_Expand_SubArea).gridRight := false;
	self.tblAreas.accessColumn(Col_Incl_Location).gridRight := false;
	
	self.tblAreas.accessCell(1,Col_Incl_TA).gridRight := true;
	self.tblAreas.accessCell(1,Col_Ta_Name).gridRight := true;
	self.tblAreas.accessCell(1,Col_Expand_TA).gridRight := true;
	self.tblAreas.accessCell(1,Col_Incl_SubArea).gridRight := true;
	self.tblAreas.accessCell(1,Col_SubArea_Name).gridRight := true;
	self.tblAreas.accessCell(1,Col_Expand_SubArea).gridRight := true;
	self.tblAreas.accessCell(1,Col_Incl_Location).gridRight := true;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="loadTerminalAreaSubObjects" id="1feffd7e-31de-4e63-aa22-2069a94a628b">
        <source>loadTerminalAreaSubObjects( _ta : CM_TerminalArea; _afterIndex : Integer ) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 Apr 2014	cnwndl1	Initial creation	Par 33995
25 Jun 2020	jlgdap1	TFS 49453 ASPA Satellite View Screen for Flexible Terminal Areas
*/

vars

	gridArea : CM_GridArea;
	iter : Iterator;
	gridObject : CM_GridObject;
	obj : Object;
	roroCont : CM_RoRoController;
	afterIndex : Integer; 
	lastIndexAdded : Integer;
	group : CM_GeneralCargoAllocGroup;		// TFS 49453

begin

	afterIndex := _afterIndex;

	if _ta.isKindOf( CM_GridArea ) then
		gridArea := _ta.CM_GridArea;
		iter := gridArea.allGridColumns.createIterator;
		while iter.next( gridObject ) do
			if _afterIndex &gt; 0 then
				lastIndexAdded := self.addGridObjectToTable( gridObject, afterIndex );
				afterIndex := lastIndexAdded;
			else
				self.addGridObjectToTable( gridObject, 0 );
			endif;
		endwhile;
		delete iter;
		iter := gridArea.allGridRows.createIterator;
		while iter.next( gridObject ) do
			if _afterIndex &gt; 0 then
				lastIndexAdded := self.addGridObjectToTable( gridObject, afterIndex );
				afterIndex := lastIndexAdded;
			else
				self.addGridObjectToTable( gridObject, 0 );
			endif;
		endwhile;
		delete iter;
		
	elseif _ta.isKindOf( CM_RoRoLaneArea ) then
		iter := _ta.allLocationsControllers.createIterator;
		while iter.next( roroCont ) do
			if _afterIndex &gt; 0 then
				lastIndexAdded := self.addRoRoLaneToTable( roroCont, afterIndex );
				afterIndex := lastIndexAdded;
			else
				self.addRoRoLaneToTable( roroCont, 0 );
			endif;
		endwhile;
		delete iter;
		
	// TFS 49453 
	elseif _ta.isKindOf(CM_GeneralCargoAllocRowArea) then
		iter := _ta.CM_GeneralCargoAllocRowArea.allRowControllersById.createIterator;
		while iter.next( group ) do
			if _afterIndex &gt; 0 then
				lastIndexAdded := self.addGCAllocGroupToTable( group, afterIndex );
				afterIndex := lastIndexAdded;
			else
				self.addGCAllocGroupToTable( group, 0 );
			endif;
		endwhile;
		delete iter;
	// TFS 49453 end
		
	endif;

epilog

	delete iter;

end;</source>
        <access>protected</access>
        <Parameter name="_ta" type="CM_TerminalArea"/>
        <Parameter name="_afterIndex" type="Integer"/>
    </JadeMethod>
