    <JadeMethod name="getTotalCompleted" id="c3db1396-9179-47ee-b9b2-07fbaa223228">
        <source>getTotalCompleted(_qty: Boolean): Any;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 Oct 2023	navrv30	ChangeRequest 60458: EUP - Change Work Order Progress to be based on QTY or WT
23 Apr 2024 navhl20 ChangeRequest 63251: FR | 53729 - Delivery Dispatch screen - Further issues and Remedial work
30 May 2024 navhl20 Bug 64101: EUP - For the Pack Job the parent and child details are empty on the Complete Job form 
06 Jun 2024 navhl20 Bug 64516: EUP - For Pack Jobs the progress is not calculating the child cargo quantity on the work order enquiry form
12 Aug 2024 navhl20	Bug 65586: Pack Work order - Issues
*/

vars
	qty 		: Integer;
	ti	 		: CM_TrackedItem;
	wt   		: Decimal[14,4];
	invalid		: Boolean;
begin
	on Exception do app.handleDeletedObject(exception, ti, invalid);
	//on Exception do app.handleDeletedObject(exception, childItem, invalid);	//12.08.2024 navhl20 #65586
	
	/*
	//12.08.2024 navhl20 #65586
	if _qty then
		foreach  ti in self.allCompleteTIs  discreteLock do	//28.05.2024 navma1 #64224
			invalid := false;
			ti.edition;
			if invalid then
				continue;
			endif;
			
			if ti.hasChildren then 
				//foreach childItem in ti.allChildren  discreteLock do										//28.05.2024 navma1 #64224 	//06.06.2024 navhl20 #64516
				foreach childItem in ti.allChildren discreteLock where self.allPackingTIs.includes(childItem) do	//06.06.2024 navhl20 #64516
					invalid := false;
					childItem.edition;
					if invalid then
						continue;
					endif;
					
					qty := qty + childItem.totalQuantity;
				endforeach;
			elseif self.allPackingTIs.includes(ti) then
				qty := qty + ti.totalQuantity;
			endif;
		endforeach;
		return qty;
	else
		foreach  ti in self.allCompleteTIs  discreteLock do	//28.05.2024 navma1 #64224
			invalid := false;
			ti.edition;
			if invalid then
				continue;
			endif;
			
			if ti.hasChildren then
				//foreach childItem in ti.allChildren  discreteLock do										//28.05.2024 navma1 #64224 	//06.06.2024 navhl20 #64516
				foreach childItem in ti.allChildren  discreteLock where self.allPackingTIs.includes(childItem) do	//06.06.2024 navhl20 #64516
					invalid := false;
					childItem.edition;
					if invalid then
						continue;
					endif;
					
					wt := wt + childItem.totalWeight;
				endforeach;
			elseif self.allPackingTIs.includes(ti) then
				wt := wt + ti.totalWeight;
			endif;
		endforeach;
		return wt;
	endif;*/
	
	if _qty then															//12.08.2024 navhl20 #65586
		foreach  ti in self.allPackingTIs discreteLock do
			invalid := false;
			ti.edition;
			if invalid then
				continue;
			endif;
			
			qty := qty + ti.totalQuantity;
		endforeach;
		return qty;
	else
		foreach  ti in self.allPackingTIs discreteLock do
			invalid := false;
			ti.edition;
			if invalid then
				continue;
			endif;
			
			wt := wt + ti.totalWeight;
		endforeach;
		return wt;
	endif;
epilog

end;</source>
        <Parameter name="_qty" type="Boolean"/>
        <ReturnType type="Any"/>
    </JadeMethod>
    <JadeMethod name="getTotalRequest" id="2c17a115-4e7c-4abc-b602-650f39c772a0">
        <source>getTotalRequest(_qty: Boolean): Any;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 Jul 2024 navhl20	ChangeRequest 61368: EUP* | Adding Pack Reserve Child to Packing Work order Release Request

*/

vars
	ti		: CM_TrackedItem;
	total	: Integer;
	wt   	: Decimal[14,4];
	invalid	: Boolean;
begin
	on Exception do app.handleDeletedObject(exception, ti, invalid);
	if _qty then
		foreach  ti in self.allPackingTIs discreteLock do
			invalid := false;
			ti.edition;
			if invalid then
				continue;
			endif;
			
			total := total + ti.totalQuantity;
		endforeach;
		return total;
	else
		foreach  ti in self.allPackingTIs discreteLock do
			invalid := false;
			ti.edition;
			if invalid then
				continue;
			endif;
			
			wt := wt + ti.totalWeight;
		endforeach;
		return wt;
	endif;
epilog

end;</source>
        <Parameter name="_qty" type="Boolean"/>
        <ReturnType type="Any"/>
    </JadeMethod>
