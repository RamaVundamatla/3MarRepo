    <JadeMethod name="getDisplayStringForAttribute" id="0b97939f-84f9-4b8a-be84-b549a9e25b50">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
//----------------------------------------------------------------------
//  Created by cnwsh3
//	Date 20 March 2009
//
// Implemented version:
// 
//----------------------------------------------------------------------
// 04 Mar 2019	jlgrs1	TFS 41913 STWR - Reconfiguration of the EDI Operation form to better handle EDI collection locks while loading 
//
vars
	ediData : CM_EDIDataUSCustomsMessage;
begin
	ediData := self.myEDIData.CM_EDIDataUSCustomsMessage;
	if _attrName = ETRow_Bol then
		return self.billOfLading;
	elseif _attrName = ETRow_OperatorCode then
		if ediData.myOperator &lt;&gt; null then
			return ediData.myOperator.code;
		else
			return null;
		endif;
	elseif _attrName = ETRow_VoyageCode then
		return self.voyageCode;
	elseif _attrName = ETRow_PostedDate then
		return self.postedDate.asStringJMT();
	elseif _attrName = ETRow_PostedTime then
		return self.postedTime.asStringJMT();
	endif;
	
	return inheritMethod(_attrName, _short);

epilog
end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
