    <JadeMethod name="addInterchangeArea" id="bfaf485f-9828-4eeb-bc6a-00e236af2a29">
        <source>addInterchangeArea(_id : String; _selectedTerminalAreas: CM_TerminalAreaSet input) : CM_YardInterchangeArea;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
08 March 2011	cnwer1	Initial creation

*/

vars
	proxy			: CM_YardInterchangeArea;
	realTA 			: CM_TerminalAreaMaster;
begin

	self.deleteTerminalArea(_id);
	create proxy transient;
			
	proxy.setIsEmpty(true);
	proxy.pxyCreateNewLane (true);
	proxy.setProxy(_id, null, self.getTerminal, false, false, CM_InterchangeArea.Access_VehicleMachines, null,  _selectedTerminalAreas,0);
	
	if self.opts.includesKey("ActAsReleasePoint") then
		proxy.setPropertyValue(CM_YardInterchangeArea::actAsReleasePoint.name, self.opts.int("ActAsReleasePoint"));
	endif;
	
	if self.opts.includesKey("HideOverview") then
		proxy.setPropertyValue(CM_YardInterchangeArea::hideFromOverView.name, self.opts.bool("HideOverview"));
	endif;	
	
	app.myTrxCA.trxCreateTerminalArea(proxy, realTA, app.myPassport);
	self.assertTrueMsg(app.myPassport.trxCompletedOK(), app.myPassport.getAllErrorsWarningsAsString());

	return realTA.CM_YardInterchangeArea;
	
epilog
	delete proxy;
end;</source>
        <Parameter name="_id" type="String"/>
        <Parameter name="_selectedTerminalAreas" type="CM_TerminalAreaSet" usage="input"/>
        <ReturnType type="CM_YardInterchangeArea"/>
    </JadeMethod>
    <JadeMethod name="addInvoiceRateEntry" id="5f9d45ea-35d8-44e4-9587-d6abe262ae7b">
        <source>addInvoiceRateEntry(_rate : CM_Rate; _start : TimeStamp; _expiry : TimeStamp; _ignoreEntry : Boolean; _costs : DecimalArray;
			_adjustToBase : Decimal;
			_percentOfBase : Decimal;
			_parentRate : CM_Rate) : CM_RateEntry;

vars
	pxyRE, realRE : CM_RateEntry;
	cpu : Real;
	user : String; 
begin
	if _costs.size &gt;= 1 then
		cpu := _costs[1];
	endif;
	
	user := app.myPassport.myUser.code; 
	create pxyRE transient;

	pxyRE.setProxy(_costs, cpu, _rate, user, _start, _expiry, _ignoreEntry, _adjustToBase, _percentOfBase, _parentRate );
	
	app.myTrxCA.trxCreateRateEntry(pxyRE, realRE, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();	
	return realRE;
epilog
	delete pxyRE;
end;
</source>
        <Parameter name="_rate" type="CM_Rate"/>
        <Parameter name="_start" type="TimeStamp"/>
        <Parameter name="_expiry" type="TimeStamp"/>
        <Parameter name="_ignoreEntry" type="Boolean"/>
        <Parameter name="_costs" type="DecimalArray"/>
        <Parameter name="_adjustToBase" type="Decimal"/>
        <Parameter name="_percentOfBase" type="Decimal"/>
        <Parameter name="_parentRate" type="CM_Rate"/>
        <ReturnType type="CM_RateEntry"/>
    </JadeMethod>
    <JadeMethod name="addInvoiceRateEntryPercentage" id="44cd8ee5-3b21-41cd-ada9-40f344375e78">
        <source>addInvoiceRateEntryPercentage(_rate : CM_Rate; _start : TimeStamp; _expiry : TimeStamp; _ignoreEntry : Boolean; _costs : DecimalArray; _isPercentage : Boolean; _isAmount : Boolean) : CM_RateEntry;

vars
	pxyRE, realRE : CM_RateEntry;
	cpu : Real;
	user : String; 
begin
	if _costs.size &gt;= 1 then
		cpu := _costs[1];
	endif;
	
	user := app.myPassport.myUser.code; 
	create pxyRE transient;
	pxyRE.setProxyWithPercentage(_costs, cpu, _rate, user, _start, _expiry, _ignoreEntry,_isPercentage,_isAmount);
	
	app.myTrxCA.trxCreateRateEntry(pxyRE, realRE, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();	
	return realRE;
epilog
	delete pxyRE;
end;
</source>
        <Parameter name="_rate" type="CM_Rate"/>
