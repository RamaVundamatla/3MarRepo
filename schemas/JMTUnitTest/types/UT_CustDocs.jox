    <JadeMethod name="createCargoOnVoyage" id="e995be27-f9ed-42c0-a45d-c82a63939c82">
        <source>createCargoOnVoyage(_delete : Boolean; _contractId,_id : String; _cargoType : CM_CargoType; _operator : CM_Operator; _voyage : CM_Voyage; _port : CM_Port;
								_weight : Decimal; _volume : Decimal; _quantity : Integer; _cargoGroup : CM_CargoGroup input) : CM_TrackedItem;
/*
Purpose:			

Date		Who		Reason
08AUG2023	NAVAB1	 CR 56094 TASK 59616
*/

vars
	cargo : CM_TrackedItem;
	lc : CM_LocationsController;
	product : CM_Product;
	prevOp : CM_Operator;
	realTI,
	pxyTI			: CM_TrackedItem;
	passport		: CM_Passport;
	moveController	: CMIF_MoveController;
	state			: Integer;
	quantity : Integer;
	term : CM_Terminal;
begin
	if _delete then
		self.deleteCargo(_id, _cargoType);
	endif;
	product := _cargoType.allProducts.first;   ////////getProductFromCode("12POUNDER-12");
	if product&lt;&gt; null
	and product.myOperator &lt;&gt; null 
	and product.myOperator &lt;&gt; _operator then
		prevOp := product.myOperator;
		beginTransaction;
		product.setMyOperator(_operator);
		commitTransaction;
	endif;
	
	lc := _voyage.myShipBlockStack;
	term := self.getMyTerminal();
	pxyTI := term.createTI(_cargoType, true);
	pxyTI.zSetPxyId(_id);
	
	pxyTI.zSetPxyTerminal(term);
	app.myPassport.setMyTerminal(term);
	pxyTI.setCargoType(_cargoType.id);
	pxyTI.setMyProduct(product);

	pxyTI.setMyCountryOfOrigin(app.myRoot.allCountries.last);
	pxyTI.setPropertyValue("totalQuantity",_quantity);
	pxyTI.setPropertyValue("TotalVolume",_volume);
	pxyTI.setPropertyValue("TotalWeight",_weight);
	pxyTI.setCommodity("COM2");
	pxyTI.setLength(111.0);
	pxyTI.setWidth(222.0);
	pxyTI.setHeight(333.0);
	pxyTI.setDescription("UT Cust Docs Created ");
	pxyTI.setClientRef( "ClientRef2");
	pxyTI.setConsigneeByString("UTDDC");
	pxyTI.setConsignorByString("UTMO1");
	pxyTI.setContractId(_contractId);
	pxyTI.setMyVoyage(_voyage, app.myPassport);
	pxyTI.setImExStatus(TI_IMEX_STATUS_IMPORT);
	pxyTI.setDischargePort(_port.code);
	
	if app.isSubTerminalsOn(term) then
		pxyTI.setSubTerminalDefaultFromTerm(term);
	endif;

	state := lc.getStateForNewCargo();
	
	if state = 0 then
		app.raiseCMException3(UNEXPECTED_PROGRAM_ERROR, class.name, method.name, 'Invalid State', null, null);
		return null;
	endif;
	
	pxyTI.changeState(state, passport);
	
	pxyTI.setMyCargoGroup(_cargoGroup, passport);
	
	passport.warningsAcknowledged := true;
	passport.setIsBackgroundWarningsIgnored(true);
	
	create moveController transient;
	moveController.setMyToPrimaryLocation(lc);
	
	app.myTrxCA.trxCreateTIWithMove(pxyTI, realTI, moveController, passport);
	if passport.trxCompletedOK() then
		return realTI;
	endif;

	self.assertTrueMsg(cargo.contractId = _contractId, "Cargo Contract Id is wrong");
	
	if prevOp &lt;&gt; null then
		beginTransaction;
		product.setMyOperator(prevOp);
		commitTransaction;
	
	endif;
	
	return cargo;
epilog
	delete moveController;
end;</source>
        <Parameter name="_delete" type="Boolean"/>
        <Parameter name="_contractId" type="String"/>
        <Parameter name="_id" type="String"/>
        <Parameter name="_cargoType" type="CM_CargoType"/>
        <Parameter name="_operator" type="CM_Operator"/>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_port" type="CM_Port"/>
        <Parameter name="_weight" type="Decimal"/>
        <Parameter name="_volume" type="Decimal"/>
        <Parameter name="_quantity" type="Integer"/>
        <Parameter name="_cargoGroup" type="CM_CargoGroup" usage="input"/>
        <ReturnType type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="createCustDocDetail" id="3284d89c-6b1f-431e-95ce-ebaf5ae16cb4">
        <updating/>
        <source>createCustDocDetail(_clearedWeight,_clearedVolume: Decimal;_clearedQuantity : Integer; include: Boolean; parentCustDoc: CM_CustomDocument; ti: CM_TrackedItem): CM_CustomDocumentDetail updating;
/*
Purpose:			

Date		Who		Reason
08AUG2023	NAVAB1	 CR 56094 TASK 59616
// ### TFS CR 60424 TASK 60549 29SEP2023 NAVAB1 - updated for new doc type validation
*/

vars
	realCustDocDetail,
	proxyCustDocDetail		: CM_CustomDocumentDetail;
begin

	create proxyCustDocDetail transient;
	proxyCustDocDetail.setProxy(_clearedQuantity, _clearedWeight,_clearedVolume, include,ti, parentCustDoc, null);
	
	app.myTrxCA.trxCreateCustDocDetail(proxyCustDocDetail,realCustDocDetail,app.myPassport);

	self.assertTrueTrxOKShowPassport("ERRORS");
	
	return realCustDocDetail;
epilog
	delete proxyCustDocDetail;
end;</source>
        <Parameter name="_clearedWeight" type="Decimal"/>
        <Parameter name="_clearedVolume" type="Decimal"/>
        <Parameter name="_clearedQuantity" type="Integer"/>
        <Parameter name="include" type="Boolean"/>
        <Parameter name="parentCustDoc" type="CM_CustomDocument"/>
        <Parameter name="ti" type="CM_TrackedItem"/>
        <ReturnType type="CM_CustomDocumentDetail"/>
    </JadeMethod>
    <JadeMethod name="createCustDocHeader" id="00235022-87dd-41d6-b071-6859e687acf8">
        <source>createCustDocHeader(_code : String) : CM_CustomDocument;
/*
Purpose:			

Date		Who		Reason
08AUG2023	NAVAB1	 CR 56094 TASK 59616
*/

constants
	Code1 = "UT_CD1";
	Code2 = "UT_CD2";
	Code3 = "UT_CD3";
	ExRef1 = "ExternalRef1";
	ExRef2 = "ExternalRef2";
	Rem = "Remarks";
	Rem2 = "Remarkable";
	ItemNum = 980;
	Purge = false;
vars
	pxyCustDocHdr, realCustDocHdr : CM_CustomDocument;
	term : CM_Terminal;
	stopsApply, stopsClear : CM_StopsTableSet;
	stopTablA, stopTablC : CM_StopsTable;
	oArray : ObjectArray; 
	now : TimeStamp;
	docType : CM_CustomDocumentType;
	pxyCustomLiencese, realCustomLicense : CM_CustomLicense;
	ta1, ta2 : CM_TerminalArea;
	allTerminalArea : CM_TerminalAreaSet;
	agent : CM_CustomsAgent;
	itemnum : Integer;
	hsCode : CM_HarmonizedSystem;
begin
	
	term := self.getTerminal();
	itemnum := ItemNum + term.allCustomDocuments.size;
	
	realCustDocHdr := term.allCustomDocuments.getAtKeyGeq(_code,null);
	if realCustDocHdr &lt;&gt; null and realCustDocHdr.code = _code then
		app.myTrxDA.trxDeleteCustDocHeader(realCustDocHdr,app.myPassport);
	endif;
	
	now.setDate(now.date + 10);
	
	hsCode := app.myRoot.allHSCodesActive.last;
	//CUSTOM LICENSE
	ta1 := self.addBlockStack("CD01", 999999, null);
	ta2 := self.addBlockStack("CD02", 999999, null);
	
	self.assertNotNullMsg(ta1, "TA1 is null");
	self.assertNotNullMsg(ta2, "TA2 is null");
	
	create allTerminalArea transient;
	allTerminalArea.add(ta1);
	allTerminalArea.add(ta2);
	
	realCustomLicense := term.allCustomLicenses[_code &amp; "LIC"];
	if realCustomLicense &lt;&gt; null then
		app.myTrxDA.trxDeleteCustLicense(realCustomLicense,app.myPassport);
	endif;
	create pxyCustomLiencese transient;
	pxyCustomLiencese.setProxy(_code &amp; "LIC", _code &amp; "LIC Desciption", term, false, null, allTerminalArea);
	realCustomLicense := self.addCustomLicense(pxyCustomLiencese);
	
	
	//CUSTOM AGENT
	agent := self.addCustomsAgent(_code &amp; "G", _code &amp; "AGT Description");
	
	
    create pxyCustDocHdr transient;
	docType := self.createCustDocType(_code &amp; "TYPE");
	pxyCustDocHdr.setProxy(term, _code,_code &amp; " Description",ExRef1, ExRef2,Rem,now,null,null,CM_CustomDocumentType.CustDocTypeDir_Both,itemnum, docType,realCustomLicense,agent, null, CM_CustomDocument.Status_Active);
	
	app.myTrxCA.trxCreateCustDocHeader(pxyCustDocHdr, realCustDocHdr, app.myPassport);
	
	self.assertNoTrxErrorsOrWarnings();
	self.assertEqual(realCustDocHdr.code,_code);
	self.assertEqual(realCustDocHdr.description,_code &amp; " Description");
	self.assertEqual(realCustDocHdr.myTerminal,term);
	self.assertTrueMsg(realCustDocHdr.myCustomDocumentType &lt;&gt; null,"Doc Type is null");
	self.assertTrueMsg(realCustDocHdr.myCustomLicense &lt;&gt; null,"License is null");
	self.assertTrueMsg(realCustDocHdr.myCustomsAgent &lt;&gt; null,"Agent is null");
	self.assertTrueMsg(realCustDocHdr.myHSCode = null,"HS Code should be null");
	self.assertEqual(realCustDocHdr.externalRef1,ExRef1);
	self.assertEqual(realCustDocHdr.externalRef2,ExRef2);
	self.assertEqual(realCustDocHdr.remarks,Rem);
	self.assertEqual(realCustDocHdr.dateTime,now);
	self.assertEqual(realCustDocHdr.direction,CM_CustomDocumentType.CustDocTypeDir_Both);
	
	// ### UPDATE
	delete pxyCustDocHdr;
	now.setDate(now.date + 2);
	
	pxyCustDocHdr := app.createUpdateProxy(realCustDocHdr).CM_CustomDocument;
	pxyCustDocHdr.setProxy(term, _code,Code2 &amp; " Description",ExRef1, ExRef2,Rem2,now,null,null,CM_CustomDocumentType.CustDocTypeDir_Inward,itemnum, docType,realCustomLicense,agent, hsCode, CM_CustomDocument.Status_Active);
	
	app.myTrxUA.trxUpdateCustDocHeader(pxyCustDocHdr, false, app.myPassport); // ### TFS CR 60424 TASK 60549 24OCT2023 NAVAB1 - partial
	
	self.assertNoTrxErrorsOrWarnings();
	self.assertEqual(realCustDocHdr.code,_code);
	self.assertEqual(realCustDocHdr.description,Code2 &amp; " Description");
	self.assertEqual(realCustDocHdr.myTerminal,term);
	self.assertTrueMsg(realCustDocHdr.myCustomDocumentType &lt;&gt; null,"Updated Doc Type is null");
	self.assertTrueMsg(realCustDocHdr.myCustomLicense &lt;&gt; null,"Updated License is null");
	self.assertTrueMsg(realCustDocHdr.myCustomsAgent &lt;&gt; null,"Updated Agent is null");
	self.assertTrueMsg(realCustDocHdr.myHSCode &lt;&gt; null,"HS Code is null");
	self.assertEqual(realCustDocHdr.externalRef1,ExRef1);
	self.assertEqual(realCustDocHdr.externalRef2,ExRef2);
	self.assertEqual(realCustDocHdr.remarks,Rem2);
	self.assertEqual(realCustDocHdr.dateTime,now);
	self.assertEqual(realCustDocHdr.direction,CM_CustomDocumentType.CustDocTypeDir_Inward);
	
	return realCustDocHdr;
epilog
	delete pxyCustDocHdr;
	delete allTerminalArea;
	delete pxyCustomLiencese;

end;</source>
        <Parameter name="_code" type="String"/>
        <ReturnType type="CM_CustomDocument"/>
    </JadeMethod>
    <JadeMethod name="createCustDocHeaderForSeq" id="d48862c6-9f76-4595-9035-35322f786554">
        <updating/>
        <source>createCustDocHeaderForSeq(_sequence : Integer; _suffix : Integer; _docType : CM_CustomDocumentType; 	cargoGroup1, cargoGroup2 : CM_TrackedItem) : CM_CustomDocument updating;
/*
Purpose:			

Date		Who		Reason
23 August 2023	navab1	CR 59942 TASK 59943 
*/

vars

	allTerminalArea	: CM_TerminalAreaSet;
	rtoLicense, imahaLicense : CM_CustomLicense;
	licenses : CM_CustomLicenseByCode;
	nextTypes : CM_CustomDocumentTypeByCode;
	d126DocType, vatDocType, invDocType, imahDocType : CM_CustomDocumentType;
	cargoId, cgId, opCode, custDocCode : String;
	idy : Integer;
	cargoType : CM_CargoType;
	ti : CM_TrackedItem;
	tis : CM_TISet;
	dateTime : TimeStamp;
	totalQuantity, clearedQuantity: Integer;
	totalWeight, totalVolume, clearedWeight, clearedVolume : Decimal [23,4];
	cargoOp : CM_Operator;
	vessel : CM_Vessel;
	voyage : CM_Voyage;
	aPort : CM_Port;
	cgSuffix : Integer;
	pxyCustDocHdr, realCustDocHdr : CM_CustomDocument;
	realCustomDocumentDetail : CM_CustomDocumentDetail;
	term : CM_Terminal;
	cmifCustDocDetail : CMIF_CustomDocumentDetail;
	theReturn        : Integer;
	proxyCustDocDetail		: CM_CustomDocumentDetail;
begin


	term := self.getTerminal();

   custDocCode := "KM" &amp; dateTime.date.year.String[3:2] &amp; dateTime.date.month.String &amp; dateTime.date.day.String &amp; "-" &amp; _suffix.String;
	realCustDocHdr := term.allCustomDocuments.getAtKeyGeq(custDocCode,null);
	if realCustDocHdr &lt;&gt; null 
	and realCustDocHdr.code = custDocCode then
		app.myPassport.setWarningsIgnored(true);
		app.myPassport.setWarningsAcknowledged(true);
		app.myTrxDA.trxDeleteCustDocHeader(realCustDocHdr, app.myPassport);
	endif;

   create pxyCustDocHdr transient;
	pxyCustDocHdr.setProxy(term, custDocCode,custDocCode &amp; " Description",null, null,null,dateTime,null,null,_docType.direction,_suffix, _docType,_docType.allCustomLicenses.first,null,null,_sequence);
	
	
	create cmifCustDocDetail transient;

	create proxyCustDocDetail transient;
	clearedWeight := cargoGroup1.totalWeight;// ### TFS CR 60922 TASK 60980 09NOV2023 NAVAB1
	clearedVolume := cargoGroup1.totalVolume;
	clearedQuantity := cargoGroup1.totalQuantity;
	proxyCustDocDetail.setProxy(clearedQuantity, clearedWeight,clearedVolume, true,cargoGroup1, pxyCustDocHdr, null);
	cmifCustDocDetail.allProxyCustDocDetails.add(proxyCustDocDetail);

	if cargoGroup2&lt;&gt; null then
		create proxyCustDocDetail transient;
		clearedWeight := cargoGroup2.totalWeight;// ### TFS CR 60922 TASK 60980 09NOV2023 NAVAB1
		clearedVolume := cargoGroup2.totalVolume;
		clearedQuantity := cargoGroup2.totalQuantity;
		proxyCustDocDetail.setProxy(clearedQuantity, clearedWeight,clearedVolume, true,cargoGroup2, pxyCustDocHdr, null);
		cmifCustDocDetail.allProxyCustDocDetails.add(proxyCustDocDetail);
	endif;
	
	app.myTrxCA.trxCreateCustDocAndDetails(pxyCustDocHdr,realCustDocHdr, cmifCustDocDetail, app.myPassport);

	self.assertNoTrxErrorsOrWarnings();
	if realCustDocHdr&lt;&gt; null then
		self.assertEqual(realCustDocHdr.code,custDocCode);
	endif;
	
	return realCustDocHdr;

epilog
	delete pxyCustDocHdr;
	cmifCustDocDetail.allProxyCustDocDetails.purge();
	delete cmifCustDocDetail;
end;</source>
        <Parameter name="_sequence" type="Integer"/>
        <Parameter name="_suffix" type="Integer"/>
        <Parameter name="_docType" type="CM_CustomDocumentType"/>
        <Parameter name="cargoGroup1" type="CM_TrackedItem"/>
        <Parameter name="cargoGroup2" type="CM_TrackedItem"/>
        <ReturnType type="CM_CustomDocument"/>
    </JadeMethod>
    <JadeMethod name="createCustDocHeaderForSeq4TIs" id="78941436-9f28-40e1-b4cb-12ef786ccdca">
        <updating/>
        <source>createCustDocHeaderForSeq4TIs(_sequence : Integer; _suffix : Integer; _docType : CM_CustomDocumentType; 	_tis: CM_TISet) : CM_CustomDocument updating;
/*
Purpose:			

Date		Who		Reason
23 August 2023	navab1	CR 59942 TASK 59943 
*/

vars

	allTerminalArea	: CM_TerminalAreaSet;
	rtoLicense, imahaLicense : CM_CustomLicense;
	licenses : CM_CustomLicenseByCode;
	nextTypes : CM_CustomDocumentTypeByCode;
	d126DocType, vatDocType, invDocType, imahDocType : CM_CustomDocumentType;
	cargoId, cgId, opCode, custDocCode : String;
	idy : Integer;
	cargoType : CM_CargoType;
	ti : CM_TrackedItem;
	tis : CM_TISet;
	dateTime : TimeStamp;
	totalQuantity, clearedQuantity: Integer;
	totalWeight, totalVolume, clearedWeight, clearedVolume : Decimal [23,4];
	cargoOp : CM_Operator;
	vessel : CM_Vessel;
	voyage : CM_Voyage;
	aPort : CM_Port;
	cgSuffix : Integer;
	pxyCustDocHdr, realCustDocHdr : CM_CustomDocument;
	realCustomDocumentDetail : CM_CustomDocumentDetail;
	term : CM_Terminal;
	cmifCustDocDetail : CMIF_CustomDocumentDetail;
	theReturn        : Integer;
	proxyCustDocDetail		: CM_CustomDocumentDetail;
begin


	term := self.getTerminal();

   custDocCode := "KM" &amp; dateTime.date.year.String[3:2] &amp; dateTime.date.month.String &amp; dateTime.date.day.String &amp; "-" &amp; _suffix.String;
	realCustDocHdr := term.allCustomDocuments.getAtKeyGeq(custDocCode,null);
	if realCustDocHdr &lt;&gt; null 
	and realCustDocHdr.code = custDocCode then
		app.myPassport.setWarningsIgnored(true);
		app.myPassport.setWarningsAcknowledged(true);
		app.myTrxDA.trxDeleteCustDocHeader(realCustDocHdr, app.myPassport);
	endif;

   create pxyCustDocHdr transient;
	pxyCustDocHdr.setProxy(term, custDocCode,custDocCode &amp; " Description",null, null,null,dateTime,null,null,_docType.direction,_suffix, _docType,_docType.allCustomLicenses.first,null,null,_sequence);
	
	
	create cmifCustDocDetail transient;
	
	
	foreach ti in _tis discreteLock do
		create proxyCustDocDetail transient;
		clearedWeight := ti.totalWeight; //02/10/2023	navkc1	CR 60423 Task 60762
		clearedVolume := ti.totalVolume;
		clearedQuantity := ti.totalQuantity;
		proxyCustDocDetail.setProxy(clearedQuantity, clearedWeight,clearedVolume, true,ti, pxyCustDocHdr, null);
		cmifCustDocDetail.allProxyCustDocDetails.add(proxyCustDocDetail);
	
	
	endforeach;

	app.myTrxCA.trxCreateCustDocAndDetails(pxyCustDocHdr,realCustDocHdr, cmifCustDocDetail, app.myPassport);

	self.assertNoTrxErrorsOrWarnings();
	if realCustDocHdr&lt;&gt; null then
		self.assertEqual(realCustDocHdr.code,custDocCode);
	endif;
	
	return realCustDocHdr;

epilog
	delete pxyCustDocHdr;
	cmifCustDocDetail.allProxyCustDocDetails.purge();
	delete cmifCustDocDetail;
end;</source>
        <Parameter name="_sequence" type="Integer"/>
        <Parameter name="_suffix" type="Integer"/>
        <Parameter name="_docType" type="CM_CustomDocumentType"/>
        <Parameter name="_tis" type="CM_TISet"/>
        <ReturnType type="CM_CustomDocument"/>
    </JadeMethod>
    <JadeMethod name="createCustDocHeaderForSeqAmt" id="5bee5207-eccb-44e0-ae23-0188e2332769">
        <updating/>
        <source>createCustDocHeaderForSeqAmt(_sequence : Integer; _suffix : Integer; _docType : CM_CustomDocumentType; 	cargoGroup1, cargoGroup2 : CM_TrackedItem; _qty1, _qty2 : Integer; _weight1, _weight2 : Decimal; _vol1, _vol2 : Decimal) : CM_CustomDocument updating;
/*
Purpose:			

Date		Who		Reason
02/10/2023	navkc1	CR 60423 Task 60762: Jade - Custom Doc Summary and Unit Tests
*/

vars

	custDocCode : String;
	dateTime : TimeStamp;
	clearedQuantity: Integer;
	clearedWeight, clearedVolume : Decimal [23,4];
	pxyCustDocHdr, realCustDocHdr : CM_CustomDocument;
	term : CM_Terminal;
	cmifCustDocDetail : CMIF_CustomDocumentDetail;
	proxyCustDocDetail		: CM_CustomDocumentDetail;
begin


	term := self.getTerminal();

   custDocCode := "KM" &amp; dateTime.date.year.String[3:2] &amp; dateTime.date.month.String &amp; dateTime.date.day.String &amp; "-" &amp; _suffix.String;
	realCustDocHdr := term.allCustomDocuments.getAtKeyGeq(custDocCode,null);
	if realCustDocHdr &lt;&gt; null 
	and realCustDocHdr.code = custDocCode then
		app.myPassport.setWarningsIgnored(true);
		app.myPassport.setWarningsAcknowledged(true);
		app.myTrxDA.trxDeleteCustDocHeader(realCustDocHdr, app.myPassport);
	endif;

   create pxyCustDocHdr transient;
	pxyCustDocHdr.setProxy(term, custDocCode,custDocCode &amp; " Description",null, null,null,dateTime,null,null,_docType.direction,_suffix, _docType,_docType.allCustomLicenses.first,null,null,_sequence);
	
	
	create cmifCustDocDetail transient;

	create proxyCustDocDetail transient;
	clearedWeight := _weight1;
	clearedVolume := _vol1;
	clearedQuantity := _qty1;
	proxyCustDocDetail.setProxy(clearedQuantity, clearedWeight,clearedVolume, true,cargoGroup1, pxyCustDocHdr, null);
	cmifCustDocDetail.allProxyCustDocDetails.add(proxyCustDocDetail);

	if cargoGroup2&lt;&gt; null then
		create proxyCustDocDetail transient;
		clearedWeight := _weight2;
		clearedVolume := _vol2;
		clearedQuantity := _qty2;
		proxyCustDocDetail.setProxy(clearedQuantity, clearedWeight,clearedVolume, true,cargoGroup2, pxyCustDocHdr, null);
		cmifCustDocDetail.allProxyCustDocDetails.add(proxyCustDocDetail);
	endif;
	
	app.myTrxCA.trxCreateCustDocAndDetails(pxyCustDocHdr,realCustDocHdr, cmifCustDocDetail, app.myPassport);

	self.assertNoTrxErrorsOrWarnings();
	if realCustDocHdr&lt;&gt; null then
		self.assertEqual(realCustDocHdr.code,custDocCode);
	endif;
	
	return realCustDocHdr;

epilog
	delete pxyCustDocHdr;
	cmifCustDocDetail.allProxyCustDocDetails.purge();
	delete cmifCustDocDetail;
end;</source>
        <Parameter name="_sequence" type="Integer"/>
        <Parameter name="_suffix" type="Integer"/>
        <Parameter name="_docType" type="CM_CustomDocumentType"/>
        <Parameter name="cargoGroup1" type="CM_TrackedItem"/>
