<Class name="CM_YABlock">
    <JadeMethod name="exportPDXMLMyCollections" id="02fd32a6-6677-4950-963b-1cd656ac09fb">
        <source>exportPDXMLMyCollections(_file: File; _objArray: ObjectArray io; _property: Property; _object: Object);

vars
	obj: Object;
begin
	if _property.name = CM_YABlock::allYardControllers.name then
		_file.writeLine('&lt;'&amp;CM_YABlock::allYardControllers.name&amp;'&gt;');
		_file.writeLine('&lt;'&amp;CM_YABlock::myTerminalArea.name&amp;'&gt;'&amp;self.myTerminalArea.theKey()&amp;'&lt;/'&amp;CM_YABlock::myTerminalArea.name&amp;'&gt;');
		foreach obj in self.allYardControllers do
			_file.writeLine('&lt;class&gt;' &amp; obj.class.name &amp; '&lt;/class&gt;');
//			_file.writeLine('&lt;'&amp;CM_LocationsController::myTerminalArea.theKey()&amp;'&gt;'&amp;obj.CM_LocationsController.myTerminalArea.theKey()&amp;'&lt;/'&amp;CM_LocationsController::myTerminalArea.name&amp;'&gt;');
			_file.writeLine('&lt;theKey&gt;' &amp; obj.CM_Object.theKey &amp; '&lt;/theKey&gt;');
		endforeach;
		_file.writeLine('&lt;/'&amp;CM_YABlock::allYardControllers.name&amp;'&gt;');
	endif;
end;</source>
        <Parameter name="_file" type="File"/>
        <Parameter name="_objArray" type="ObjectArray" usage="io"/>
        <Parameter name="_property" type="Property"/>
        <Parameter name="_object" type="Object"/>
    </JadeMethod>
    <JadeMethod name="exportPDXMLMyReferences" id="527671ce-60bd-453f-a52d-77c64bdd9fec">
        <source>exportPDXMLMyReferences(_file: File; _objArray: ObjectArray io; _property: Property; _object: Object);

vars

begin
	if _property.getName() = CM_YABlock::myDeckingOptions.name then
		_file.writeLine("&lt;"&amp;_property.getName&amp;"&gt;");
		self.myDeckingOptions.exportPDXML(_file, _objArray, true, true);
		_file.writeLine("&lt;/"&amp;_property.getName&amp;"&gt;");
	else
		// before we write out the myTerminalArea we write out which terminal we are in
		if _property.name = CM_YABlock::myTerminalArea.name then
			_file.writeLine("&lt;"&amp;CM_TerminalArea::myTerminal.name&amp;"&gt;"&amp;self.myTerminalArea.myTerminal.theKey&amp;"&lt;/"&amp;CM_TerminalArea::myTerminal.name&amp;"&gt;");
		endif;
		inheritMethod(_file, _objArray, _property, _object);
	endif;
end;</source>
        <Parameter name="_file" type="File"/>
        <Parameter name="_objArray" type="ObjectArray" usage="io"/>
        <Parameter name="_property" type="Property"/>
        <Parameter name="_object" type="Object"/>
    </JadeMethod>
    <JadeMethod name="importPLXMLCollections" id="e523aa1e-0c92-475e-b3dc-5f27d9cf5c8a">
        <source>importPLXMLCollections(_name: String; _collectionsBlock: String);

vars
	aClass: Class;
	objBlock, nameBlock, theCode, theKey: String;
	blockLength, pos: Integer;
	termArea: CM_TerminalArea;
	yardController: CM_YardController;
begin
	if _name = CM_YABlock::allYardControllers.name then
		objBlock := _collectionsBlock.cnEcGetTagValueOfName(CM_YABlock::allYardControllers.name);
		if objBlock = null then
			return;
		endif;
		pos := 1;
		blockLength := objBlock.length;
		while pos &lt; blockLength do
			theCode := objBlock.cnEcGetNextTagValueOfName('name', pos);
			if pos &lt; 1 then
				break;
			endif;
			theKey := objBlock.cnEcGetNextTagValueOfName('theKey', pos);
			
			if theCode = null then
				continue;
			endif;
			aClass := currentSchema.getClass(theCode);
			if aClass &lt;&gt; null then
				termArea := self.myTerminalArea;
				if termArea &lt;&gt; null then
					yardController := termArea.getLocationsControllerFromKey(theKey).CM_YardController;
					if yardController &lt;&gt; null then
						self.allYardControllers.add(yardController);
//write class.name&amp;'::'&amp;method.name&amp;' add='&amp;yardController.theKey;
					endif;				
				endif;
			endif;
		endwhile;
//	else
//		inheritMethod(_name, _collectionsBlock);
	endif;
end;</source>
        <Parameter name="_name" type="String"/>
        <Parameter name="_collectionsBlock" type="String"/>
    </JadeMethod>
    <JadeMethod name="importPLXMLListProps" id="301a0f1b-cec8-473c-ac63-9f0c6e33c8c5">
        <source>importPLXMLListProps(_propArray:ObjectArray io);

// the ref myDeckingOptions must be loaded after myTerminalArea
vars
	propColl:PropertyNDict;
	prop: Property;
begin
	create propColl transient;
	self.class.getPropertiesAllSuperclass(propColl);
	foreach prop in propColl do
		if prop.name &lt;&gt; CM_YABlock::myDeckingOptions.name then
			_propArray.add(prop);
		endif;
	endforeach;
	_propArray.add(propColl[CM_YABlock::myDeckingOptions.name]);
end;</source>
        <Parameter name="_propArray" type="ObjectArray" usage="io"/>
    </JadeMethod>
    <JadeMethod name="importPLXMLMyCollectionsOLD" id="1fd73a46-babd-4ad8-9935-3ce1b6cf443d">
        <updating/>
        <source>importPLXMLMyCollectionsOLD(_collectionsBlock: String) updating;

vars
	objArray: ObjectArray;
	object: Object;
	aClass: Class;
	objBlock, nameBlock, theCode, theKey: String;
	blockLength, pos: Integer;
	termArea: CM_TerminalArea;
	yardController: CM_YardController;
begin
//write(class.name&amp;'::'&amp;method.name&amp;' _collectionsBlock='&amp;_collectionsBlock);
	create objArray transient;

	objBlock := _collectionsBlock.cnEcGetTagValueOfName(CM_YABlock::allYardControllers.name);
//write(class.name&amp;'::'&amp;method.name&amp;' allYardControllers');
	if objBlock = null then
//write class.name&amp;'::'&amp;method.name&amp; " return.";
		return;
	endif;
////write class.name&amp;'::'&amp;method.name&amp;' allObjects='&amp;objBlock;
	pos := 1;
	blockLength := objBlock.length;
	while pos &lt; blockLength do
		theCode := objBlock.cnEcGetNextTagValueOfName('name', pos);
		if pos &lt; 1 then
			break;
		endif;
		theKey := objBlock.cnEcGetNextTagValueOfName('theKey', pos);
//write class.name&amp;'::'&amp;method.name&amp;' theCode='&amp;theCode&amp;' theKey='&amp;theKey;
		if theCode = null then
			continue;
		endif;
		aClass := currentSchema.getClass(theCode);
		if aClass &lt;&gt; null then
//			objArray.clear();
//			aClass.allInstances(objArray, 0, false);
//write class.name&amp;'::'&amp;method.name&amp;' aClass='&amp;aClass.name;
			termArea := self.myTerminalArea;
			yardController := termArea.getLocationsControllerFromKey(theKey).CM_YardController;
			if yardController &lt;&gt; null then
					self.allYardControllers.add(yardController);
//write class.name&amp;'::'&amp;method.name&amp;' add='&amp;yardController.theKey;
				endif;				
//			foreach object in objArray do
//				if object.theKey = theKey then
//					self.allYardControllers.add(object.CM_YardController);
//write class.name&amp;'::'&amp;method.name&amp;' add='&amp;object.theKey;
//				endif;				
//			endforeach;
		endif;
	endwhile;
epilog
	delete objArray;
end;</source>
        <Parameter name="_collectionsBlock" type="String"/>
    </JadeMethod>
    <JadeMethod name="importPLXMLReference" id="837c38f4-71a4-41f4-9a70-1d8516fb9a2d">
        <updating/>
        <source>importPLXMLReference(_name: String; _theCode: String; _referencesBlock: String): Object updating;

vars
	deckingOption: CM_YADeckingOptionsBlock;
begin
	if _name = CM_YABlock::myTerminalArea.name then
		return app.getMyTerminalDO_NOT_USE().allTerminalAreaMastersById[_theCode];
	elseif _name = CM_YABlock::myDeckingOptions.name then
		create deckingOption transient;
		deckingOption.setMyBlock(self);
		return null;
//		if self.myTerminalArea &lt;&gt; null then
//			return self.myTerminalArea.myYADeckingOptions;
//		else
//			return null;
//		endif;
	else
		return inheritMethod(_name, _theCode, _referencesBlock);
	endif;
end;</source>
        <Parameter name="_name" type="String"/>
        <Parameter name="_theCode" type="String"/>
        <Parameter name="_referencesBlock" type="String"/>
        <ReturnType type="Object"/>
    </JadeMethod>
</Class>
