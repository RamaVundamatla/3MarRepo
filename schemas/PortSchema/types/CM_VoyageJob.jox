    <JadeMethod name="splitAllRequests" id="c9d9be7e-ee5e-473e-9b8b-031d572dc0b1">
        <updating/>
        <source>splitAllRequests(	_newJob: CM_VoyageJob output; 
						_selectedRequests : CM_RequestSet;
						_newJobNum : String;
						_jobSheetTransTo :CM_VoyageJobSheet;		//+TFS40668
						_newCrane : String;
						_targetJob : CM_VoyageJob ) updating;
// ---------------------------------------------------------------------------
// Created:		6/3/17
//
// Purpose:		Move all the jobs into
//				a new VoyageJob.  TFS3272
//10/10/2018 	jlgrh7 TFS #40668  POL - Transferring Work Between Cranes
// ---------------------------------------------------------------------------

vars
	request : CM_Request;
	reqs : CM_RequestArray;
	avoidUnselectedRequests : Boolean;
	
	isTwinLift : Boolean;		//+TFS40668
	aCrane		: CM_Crane;	//+TFS40668
begin

	if _targetJob &lt;&gt; null then
		_newJob := _targetJob;
	else
		// Only create the one new job 
		// for all unqueued requests to be attached to
		_newJob := self.cloneSelf(false);
		_newJob.status := JOB_UNACTIONED;
		_newJob.actualStartTs:=null;
		_newJob.actualEndTs:=null;
		_newJob.myVoyage:=self.myVoyage;
		_newJob.setJobNum(_newJobNum);
		_newJob.setCrane(null,_newCrane);
	endif;
		
	create reqs transient;
	self.doSortReqsInToSeqOrder(reqs);

	//cnwjo3 par 23366 ccms 1178
	//the above method sets all the requests into sequence order regardless of what is selected
	//now if we are working with select requests I just want to remove them from reqs
	if _selectedRequests &lt;&gt; null then
		avoidUnselectedRequests := true;
	endif;
	
	foreach request in reqs do
		if avoidUnselectedRequests then
			//we have received a list of requests to work with.  only split these WLEs
			if _selectedRequests.includes(request) then
				request.splitAllWLEs(_newJob);
			endif;
		else
			request.splitAllWLEs(_newJob);
		endif;
	endforeach;
	
	//+TFS40668
	isTwinLift := false;
	aCrane := _newJob.getJobCrane(); //jlgzm1 28/12/18 tfs42007
	if aCrane &lt;&gt; null then	
	// CCMS 1414
		if aCrane.machineLiftType = TWIN_LIFT 
		and _newJob.canBeTwinLiftVoyageJobBays() then //ccms1595 27/11/07
			foreach request in _selectedRequests discreteLock do  //cnwjo3 par 23366
				if _newJob.myVoyage.starboardBerthed then
					if request.CM_SlotRequest.isTwinLiftStarboard then
						isTwinLift := true;
						break;
					endif;
				else
					if request.CM_SlotRequest.isTwinLiftPort then
						isTwinLift := true;
						break;
					endif;
				endif;
			endforeach;	
		endif;
	endif;
	_newJob.setTwinLift(isTwinLift);
	//+TFS40668

	self.rebuildStatus();

	// ### NO CARGO, cannot be loaded to voyage job ops
	if _newJob.allReceiveTrackedItems.isEmpty and _newJob.allReleaseTrackeditems.isEmpty
			and _newJob.allSOBTrackedItems.isEmpty then
		_newJob.setIsLoaded(false);
	endif;
	
	
	
	

epilog
	delete reqs;
end;</source>
        <Parameter name="_newJob" type="CM_VoyageJob" usage="output"/>
        <Parameter name="_selectedRequests" type="CM_RequestSet"/>
        <Parameter name="_newJobNum" type="String"/>
        <Parameter name="_jobSheetTransTo" type="CM_VoyageJobSheet"/>
        <Parameter name="_newCrane" type="String"/>
        <Parameter name="_targetJob" type="CM_VoyageJob"/>
    </JadeMethod>
    <JadeMethod name="splitCompletedJobs" id="c2fdc7a9-d4cb-4117-b232-d37cd083c5d3">
        <updating/>
        <source>splitCompletedJobs(_toJob: CM_VoyageJob io; _selectedRequests : CM_RequestSet) updating;
// ---------------------------------------------------------------------------
// Created:		16 September 2010 cnwjo3
//
// Purpose:		Move all completed jobs.  par 23366 ccms 1178
//
// ---------------------------------------------------------------------------

vars
	vJob : CM_VoyageJob;
	theQueue		: CM_RadioTelemetryQueue;
	crane			: CM_Crane;
	request : CM_Request;
	reqs : CM_RequestArray;
begin
	create reqs transient;
	self.doSortReqsInToSeqOrder(reqs);

	foreach request in reqs do
		if _selectedRequests.includes(request) then
			request.splitCompletedWLEs(_toJob);
		endif;
	endforeach;

	self.rebuildStatus();

	vJob := _toJob;

	// ### NO CARGO, cannot be loaded to voyage job ops
	if vJob.allReceiveTrackedItems.isEmpty and vJob.allReleaseTrackeditems.isEmpty
			and vJob.allSOBTrackedItems.isEmpty then
		vJob.setIsLoaded( false); //epr 28/11/2013 CCMS 2323
	endif;
	
	crane := vJob.getJobCrane();
	if crane &lt;&gt; null then
		theQueue := crane.getVoyageCraneQueueForVoyage(self.myVoyage);
	endif;
	//won't really need this since the job has been completed
	if theQueue &lt;&gt; null then
		theQueue.causeEvent(self.myTerminal.getTerminalEvent(RTQueue_Update_Event), true,null);
	endif;
epilog
	delete reqs;
end;</source>
        <Parameter name="_toJob" type="CM_VoyageJob" usage="io"/>
        <Parameter name="_selectedRequests" type="CM_RequestSet"/>
    </JadeMethod>
    <JadeMethod name="splitSelectedWLEs" id="34cda6fc-f0c1-4bd8-92f2-997ed0237d5f">
        <updating/>
        <source>splitSelectedWLEs(_newJob: CM_VoyageJob output; 
						_selectedWLEs : CM_WLESet;
						_newJobNum ,
						_newCrane : String;
						_targetJob : CM_VoyageJob) updating;
/*
Purpose:			
Date				Who			Reason
MARCH 2017		CNWAB1		Initial creation
*/

vars
begin

epilog
end;</source>
        <Parameter name="_newJob" type="CM_VoyageJob" usage="output"/>
        <Parameter name="_selectedWLEs" type="CM_WLESet"/>
        <Parameter name="_newJobNum" type="String"/>
        <Parameter name="_newCrane" type="String"/>
        <Parameter name="_targetJob" type="CM_VoyageJob"/>
    </JadeMethod>
    <JadeMethod name="splitUnactionedRequests" id="3c99f0eb-86a8-4e3d-a261-25a796fd5a93">
        <updating/>
        <source>splitUnactionedRequests(_newJob: CM_VoyageJob output; 
						_selectedRequests : CM_RequestSet;
						_newJobNum : String;
						_jobSheetTransTo :CM_VoyageJobSheet; //+TFS40668
						_newCrane : String;
						_targetJob : CM_VoyageJob ) updating;
// ---------------------------------------------------------------------------
// Created:		07 October 2005  By Andrew Bishop cnwab1
//
// Purpose:		
//// 10/10/2018	jlgrh7 TFS #40668  POL - Transferring Work Between Cranes
// ---------------------------------------------------------------------------

vars
	request : CM_Request;
	reqs : CM_RequestArray;
	avoidUnselectedRequests : Boolean;
	isTwinLift : Boolean;		//+TFS40668
	aCrane		: CM_Crane;	//+TFS40668
	
begin
	
	if self.status &lt;&gt; JOB_PART_COMPLETE then
		app.setContinueCMExceptions(false);
		app.raiseUnexpectedProgramError(class.name, method.name, 'Invalid status for split');
		return;
	endif;

	if _targetJob &lt;&gt; null then
		_newJob := _targetJob;
	else
		 // Only create the one new job 
		 // for all unactioned requests to be attached to
		_newJob := self.cloneSelf(false);
		_newJob.status := JOB_UNACTIONED;
		_newJob.actualStartTs:=null;
		_newJob.actualEndTs:=null;
		_newJob.myVoyage:=self.myVoyage;
		_newJob.setJobNum(_newJobNum);
		_newJob.setCrane(null,_newCrane);
	endif;
	
	// PAR 11144 sort the wles into the sequence order, else RTQs get stuffed up
	// new job is only created if there are requests to split off
	create reqs transient;
	self.doSortReqsInToSeqOrder(reqs);

	//cnwjo3 par 23366 ccms 1178
	//the above method sets all the requests into sequence order regardless of what is selected
	//now if we are working with select requests I just want to remove them from reqs
	if _selectedRequests &lt;&gt; null then
		avoidUnselectedRequests := true;
	endif;	
	
	foreach request in reqs do
		if avoidUnselectedRequests then
		//we have received a list of requests to work with.  only split these WLEs
			if _selectedRequests.includes(request) then
				request.splitUnactionedWLEs(_newJob);
			endif;
		else
			request.splitUnactionedWLEs(_newJob);
		endif;
	endforeach;
	
	//+TFS40668 
	isTwinLift := false;
	aCrane := _newJob.getJobCrane(); //jlgzm1 28/12/18 tfs42007
	if aCrane &lt;&gt; null then	
	// CCMS 1414
		if aCrane.machineLiftType = TWIN_LIFT 
		and _newJob.canBeTwinLiftVoyageJobBays() then //ccms1595 27/11/07
			foreach request in _selectedRequests discreteLock do  //cnwjo3 par 23366
				if _newJob.myVoyage.starboardBerthed then
					if request.CM_SlotRequest.isTwinLiftStarboard then
						isTwinLift := true;
						break;
					endif;
				else
					if request.CM_SlotRequest.isTwinLiftPort then
						isTwinLift := true;
						break;
					endif;
				endif;
			endforeach;	
		endif;
	endif;
		
	_newJob.setTwinLift(isTwinLift);
	//+TFS40668
	
	self.rebuildStatus();

	// ### NO CARGO, cannot be loaded to voyage job ops
	if _newJob.allReceiveTrackedItems.isEmpty
	and _newJob.allReleaseTrackeditems.isEmpty
	and _newJob.allSOBTrackedItems.isEmpty then
	
		_newJob.setIsLoaded(false); //epr 28/11/2013 CCMS 2323
	endif;

epilog
	delete reqs;
end;</source>
        <Parameter name="_newJob" type="CM_VoyageJob" usage="output"/>
        <Parameter name="_selectedRequests" type="CM_RequestSet"/>
        <Parameter name="_newJobNum" type="String"/>
        <Parameter name="_jobSheetTransTo" type="CM_VoyageJobSheet"/>
        <Parameter name="_newCrane" type="String"/>
        <Parameter name="_targetJob" type="CM_VoyageJob"/>
    </JadeMethod>
    <JadeMethod name="splitUnqueuedRequests" id="68f8c587-ec1e-43ba-bc05-e6faf1f01c85">
        <updating/>
        <source>splitUnqueuedRequests(	_newJob: CM_VoyageJob output; 
						_selectedRequests : CM_RequestSet;
						_newJobNum ,
						_newCrane : String) updating;
// ---------------------------------------------------------------------------
// Created:		20 April 2010 cnwjo3
//
// Purpose:		Move all the jobs that are not queued or planned into
//				a new VoyageJob.  for par 23520
//				**** change for par 24242 we are now shifting UNQUEUED work to a new job regardless of its planned state (assuming we are planned all the time realy)
//
// ---------------------------------------------------------------------------

vars
	request : CM_Request;
	reqs : CM_RequestArray;
	avoidUnselectedRequests : Boolean;
begin

	
	// Only create the one new job 
	// for all unqueued requests to be attached to
	_newJob := self.cloneSelf(false);
	_newJob.status := JOB_UNACTIONED;
	_newJob.actualStartTs:=null;
	_newJob.actualEndTs:=null;
	_newJob.myVoyage:=self.myVoyage;
	_newJob.setJobNum(_newJobNum);
	_newJob.setCrane(null,_newCrane);
	_newJob.myShift := self.myShift; // TFS 3558
		
	create reqs transient;
	self.doSortReqsInToSeqOrder(reqs);

	//cnwjo3 par 23366 ccms 1178
	//the above method sets all the requests into sequence order regardless of what is selected
	//now if we are working with select requests I just want to remove them from reqs
	if _selectedRequests &lt;&gt; null then
		avoidUnselectedRequests := true;
	endif;
	
	foreach request in reqs do
		if avoidUnselectedRequests then
			//we have received a list of requests to work with.  only split these WLEs
			if _selectedRequests.includes(request) then
				request.splitUnqueuedWLEs(_newJob);
			endif;
		else
			request.splitUnqueuedWLEs(_newJob);
		endif;
	endforeach;

	self.rebuildStatus();

	// ### NO CARGO, cannot be loaded to voyage job ops
	if _newJob.allReceiveTrackedItems.isEmpty and _newJob.allReleaseTrackeditems.isEmpty
			and _newJob.allSOBTrackedItems.isEmpty then
		_newJob.setIsLoaded(false); //epr 28/11/2013 CCMS 2323
	endif;
	
epilog
	delete reqs;
end;</source>
        <Parameter name="_newJob" type="CM_VoyageJob" usage="output"/>
        <Parameter name="_selectedRequests" type="CM_RequestSet"/>
        <Parameter name="_newJobNum" type="String"/>
        <Parameter name="_newCrane" type="String"/>
    </JadeMethod>
    <JadeMethod name="tbaPatch" id="773f44ae-6251-423f-917b-df7d345f511b">
        <updating/>
        <source>tbaPatch(ti	:	CM_TrackedItem input; tba	:	CM_TrackedItem input) updating;

vars
	workListEntry : CM_VoyageWLE;
	lc : CM_LocationsController;
	fm : CM_FutureMove;
	information : StringArray512;
	controller : CMIF_MoveController;
begin

 	exclusiveLock(self);
	
	// ### get the WLE and the LC so that we can unplan the TBA and then plan the real TI to the same WLE

	workListEntry := self.getWLEForTI(tba).CM_VoyageWLE;
	//--------------
	//If no WLEs yet (not loaded), then nothing to patch
	//--------------
	if workListEntry = null then
		return;
	endif;

	fm := workListEntry.myFutureMove;
	if fm = null then
		return;
	endif;
	
	lc := fm.getPrimaryLocation();

	workListEntry.setMyTrackedItem(ti);
	
	tba.doForcedUnplan(app.myPassport);
	
	if not ti.readyToShip then
		
	endif;
	
	
	create controller transient;
	controller.setMyTrackedItem(ti);
	controller.setMoveMode(PLANNING_MODE);
	controller.isForcedMove := true;
	controller.isSystemMove := true;
	controller.setMyToPrimaryLocation(lc);
	controller.setMyWorkListEntry(workListEntry);
	app.myUtilityUA.utlUpdateMoveTrackedItem(controller, app.myPassport);

	
	create information transient;
	information.add("REAL : " &amp; ti.id);
	information.add("TBA : " &amp; tba.id);
	information.add("REAL Planned to : " &amp; lc.getFullId());

	
	ti.createInfomationTransaction("Matched to TBA " &amp; tba.id, information, null, app.myPassport);
epilog
	delete controller;
	delete information;
end;</source>
        <Parameter name="ti" type="CM_TrackedItem" usage="input"/>
        <Parameter name="tba" type="CM_TrackedItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="testIsMoveForJob" id="65f4b74e-599f-46e8-bb32-20a732307686">
        <source>testIsMoveForJob(_fromLC, _toLC : CM_LocationsController) : Boolean;
// ---------------------------------------------------------------------------
// Created:		December 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	aReq : CM_Request;
	aSlotController : CM_LocationsController;
	moveVoyage,
	targetVoyage	: CM_Voyage;
begin
	foreach aReq in self.allRequests do
		aSlotController := aReq.getVoyageController;
		// TFS 3491 handle hold requests, match on voyage
		if aSlotController = null and
		   self.isKindOf(CM_VoyageHoldJob) then
			targetVoyage := self.myVoyage;
			if _fromLC.isKindOf(CM_VoyageController) then
				moveVoyage := _fromLC.CM_VoyageController.myVoyage;
			elseif _toLC.isKindOf(CM_VoyageController) then
				moveVoyage := _toLC.CM_VoyageController.myVoyage;
			endif;
			if targetVoyage = myVoyage then
				return true;
			endif;
		endif;
		if aSlotController = _fromLC 
		or aSlotController = _toLC then
			return true;
		 endif; 
	endforeach;
	
	return false;
end;</source>
        <Parameter name="_fromLC" type="CM_LocationsController"/>
        <Parameter name="_toLC" type="CM_LocationsController"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="transportMode" id="b462f5d4-697e-45be-a01b-27987521af1a">
        <methodInvocation>mapping</methodInvocation>
        <source>transportMode(set: Boolean; _value: Integer io) mapping;
// ---------------------------------------------------------------------------
// Created:     12 March 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	if set then
		inheritMethod(set, _value);
		return;
	endif;
	
	_value := TI_TRANSMODE_SHIP;

end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="unplanAll" id="6a37a652-ea1a-4acb-8875-6b17e12b08b1">
        <updating/>
        <source>unplanAll() updating;

/*
stg 11/11/99 Jadeised the methods to unplan all items in a job.
03/March/2003 DWQ Converted to Version 7 aware code.
*/
vars
	moveMode : Integer;
	wle : CM_WorkListEntry;
	request : CM_Request;
	lc : CM_LocationsController;
	passport : CM_Passport;
begin
	
	passport := app.myPassport;
	
	foreach wle in self.workListEntries do
		wle.unQueueWLE(passport);
	endforeach;

	foreach request in self.allRequests do
		sharedLock(request);
		
		if jobType = JOB_TYPE_DISCHARGE then
			//Unplan the ACTUAL TI's in the slotController
			moveMode := REAL_MODE;
		else
			//Unplan the plannedTI's in this slot controller
			moveMode := PLANNING_MODE;
		endif;
		lc := request.getVoyageController;
		if lc &lt;&gt; null then
			lc.unplanAllTrackedItems(moveMode);
		endif;
		
	endforeach;
end;</source>
    </JadeMethod>
    <JadeMethod name="unplanFutureMove" id="b8b09b4b-2f04-4425-93e1-a589dea51522">
        <updating/>
        <source>unplanFutureMove(_moveMode : Integer; _selectedRequests : CM_RequestSet; _passport : CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:		May 2003 By Andrew Bishop cnwab1
//
// Purpose:		
// ---------------------------------------------------------------------------
// 13/01/2010	cnwmh5		PAR21487 - Only set slots setSequenced to false if planning_mode 
// 12/05/2010	cnwdap1		CCMS 1116 Tranship changes
// 02/09/2010	cnwjo3		CCMS 1178 instead of using requests and WLEs off self may need to work with selectedRequests only
// 07/12/2010	cnwdap1		PAR #26426 Create a note to update the slots in the planning screen affected by this change
// 07/03/2017	cnwdap1		TFS 3516 Get the corrent future planned move for bulk / break-bulk DLR
vars
	wle : CM_WorkListEntry;
	request : CM_Request;
	theTI : CM_TrackedItem;
	theMoveController : CMIF_MoveController;
	aFM : CM_FutureMove;
	theEvent	: Integer;
	theVoyage	: CM_Voyage;
	isLoad : Boolean;
	wles : CM_WLESet;
	requests : CM_RequestSet;
begin
	create wles transient;
	create requests transient;
	
	if _selectedRequests &lt;&gt; null then
		_selectedRequests.copy(requests);
	else
		self.allRequests.copy(requests);
	endif;
	
	foreach request in requests do
		foreach wle in request.allWorkListEntries do
			wles.add(wle);
		endforeach;
	endforeach;
	
	// CCMS 1367 method changed to handle unqueue as well
	if _moveMode &lt;&gt; QUEUE_MODE
	and _moveMode &lt;&gt; PLANNING_MODE then
		// invalid mode
		return;
	endif;
	
	//cnwjo3 par 23366
	foreach wle in wles do
	//foreach wle in self.workListEntries do
		wle.unQueueWLE(_passport);
	endforeach;
	
	theVoyage := self.myVoyage;
	theEvent := theVoyage.myTerminal.getTerminalEvent(EVENT_PLANNING_TI_UNPLANNED);
	isLoad := self.jobType = JOB_TYPE_LOAD;

	create theMoveController transient;
	theMoveController.isFullyUnplan := _moveMode = PLANNING_MODE; // CCMS 1367
	theMoveController.setMoveMode(_moveMode); // CCMS 1367

	//cnwjo3 par 23366
	foreach request in requests do
	//foreach request in self.allRequests do
		sharedLock(request);
		
		if theMoveController.isFullyUnplan then				// 20/07/2010 cnwmh5 #25072
			request.setSequenced(false);
		endif;

		if request.isKindOf(CM_SlotRequest) then
			theMoveController.mySlotRequest := request.CM_SlotRequest;
		endif;
		
		if self.hasBulkReleaseItem then
			request.setMyBulkReleaseReserveDetail(null);
			request.setMyOriginatingBulkRelease(null);	// 10 May 2012	NDL	Par 29512
		endif;
		
		foreach wle in request.allWorkListEntries do
			if wle.myFutureMove = null then
				continue;
			endif;
		
			if isLoad and wle.CM_VoyageWLE.isRehandle then
				wle.setLocations(null,null);
			else
				wle.setLocations(wle.locationSource,null);
			
			endif;
			
			theTI := wle.myTrackedItem;
			if theTI = null then
				continue;
			endif;

			if theTI &lt;&gt; null and theTI.isTranshipOnInboundVoyage() then
				//aFM := theTI.myTranshipExport.getFutureMoveOfType(PLANNING_MODE,TI_FutureMovePlanned);	// PAR #23645 CCMS 1116
				aFM := theTI.getFutureMoveOfType(PLANNING_MODE,TI_FutureMovePlanned);						// PAR #23645 CCMS 1116
				if aFM &lt;&gt; null and aFM.myWorkListEntry &lt;&gt; null then
					aFM.myWorkListEntry.setLocations(null,aFM.getPrimaryLocationId());
				endif;
			endif;
		
			theMoveController.setMyWorkListEntry(wle);
		
//			theMoveController.setMoveIndex(theTI.allPlannedFutureMoves.indexOf(wle.myFutureMove));
			if theTI.canMergeBreakBulk and wle.CM_VoyageWLE.isRehandle then						// TFS 3516
				theTI.setFMUnplanIndexBulkDLR(theMoveController, wle);							// TFS 3516
			else																				// TFS 3516
				theTI.setFMUnplanIndex(isLoad,theMoveController);
			endif;																				// TFS 3516
			if theMoveController.moveIndex &lt;= 0 then
				continue;
			endif;
			
			theMoveController.setMyTrackedItem(theTI);

			if (not self.isDischarge)
			and _moveMode = PLANNING_MODE then 	// CCMS 1367 unplan and unqueue
				app.myUtilityUA.utlUpdateWLEUnassignTI(theMoveController, _passport); // unplans as well
				request.setSequenced(false);				// 13/01/2010 cnwmh5 #21487
			else
				// CCMS 1367 just unqueue it
				app.myUtilityUA.utlUpdateMoveTrackedItem(theMoveController, _passport);
			endif;
			
			// this cleans up the load list display
			app.myEventManager.createSingleObjInfoNoteEvt(theVoyage, theEvent, theTI);
		endforeach;
	endforeach;
	
	self.setRemarks(null);
	
	// PAR #26426 note to update planning form
	if not requests.isEmpty and CM_SlotRequest.hasInstance(requests.first) then
		foreach request in requests do
			app.myEventManager.createSingleObjInfoNoteEvt(theVoyage, self.myTerminal.getTerminalEvent(EVENT_UPDATE_VOYAGE_AREA), request.getVoyageController);
		endforeach;
	endif;
	// PAR #26426 end
	
epilog
	delete theMoveController;
	delete wles;
	delete requests;
end;</source>
        <Parameter name="_moveMode" type="Integer"/>
        <Parameter name="_selectedRequests" type="CM_RequestSet"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="unqueueRequestsWLEs" id="029ed0c4-cdca-4c15-b5bd-664850a9d086">
        <updating/>
        <source>unqueueRequestsWLEs(_selectedRequests : CM_RequestSet; _passport : CM_Passport input) updating;
// --------------------------------------------------------------------------------
// Created:		15 September 2010 by cnwjo3
//
// Purpose:		par 23366 ccms 1178
//
vars
	request : CM_Request;
	wle : CM_WorkListEntry;
begin
	if _selectedRequests.size &gt; 0 then
		_passport.setMyTerminal(_selectedRequests.first.myTerminal);
	endif;
	foreach request in _selectedRequests do
		foreach wle in request.allWorkListEntries do
			app.myUtilityUA.utlUpdateWLEUnqueue(wle, _passport);
		endforeach;
	endforeach;
end;</source>
        <Parameter name="_selectedRequests" type="CM_RequestSet"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="updateActualAndEndTs" id="a1926991-162b-4673-97e5-b9faa9a68da2">
        <updating/>
        <source>updateActualAndEndTs(_timeStamp : TimeStamp) updating;
/*

Purpose:			


Return Value:		


Date		Who		Reason
20 December 2006	cnwer1	Initial creation - PAR#xxxx

*/
vars

begin
	if self.actualStartTs = null then
		self.actualStartTs:=_timeStamp;
		if self.workListEntries.size &lt;= 1 then
			self.actualEndTs:=_timeStamp;
		endif;
	else
		//epr always set the endTS if start &lt;&gt; null that way its always the last wle compelted
		//if self.actualEndTs = null then
			self.actualEndTs:=_timeStamp;
		//endif;
	endif;

epilog

end;</source>
        <Parameter name="_timeStamp" type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="updateReceiveTI" id="958eb300-4c39-43a6-94e4-98c19be7588f">
        <source>updateReceiveTI(_trackedItem : CM_TrackedItem);

vars

begin
	if (not self.allReceiveTrackedItems.includes(_trackedItem)) then
		self.allReceiveTrackedItems.add(_trackedItem);
	endif;
	if self.allReleaseTrackeditems.includes(_trackedItem) then
		self.allReleaseTrackeditems.remove(_trackedItem);
	endif;		
end;
</source>
        <Parameter name="_trackedItem" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="updateReleaseTI" id="e8a612b4-00be-404a-b96b-ce986c0229c1">
        <source>updateReleaseTI(_trackedItem : CM_TrackedItem);

vars

begin
	if (not self.allReleaseTrackeditems.includes(_trackedItem)) then
		self.allReleaseTrackeditems.add(_trackedItem);
	endif;
	if self.allReceiveTrackedItems.includes(_trackedItem) then
		self.allReceiveTrackedItems.remove(_trackedItem);
	endif;			
end;
</source>
        <Parameter name="_trackedItem" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="updateTICollections" id="61f50afe-4c4a-4b03-87b6-7905c6e5e6e6">
        <updating/>
        <source>updateTICollections(_trackedItem: CM_TrackedItem; _extra :Any) updating;
//--------------------------------------------------------------
//Created: 11 February 2003 By: cnwgd1
//--------------------------------------------------------------
// 01/04/2010	cnwcs5	par 23383 - _extra parameter (not used)
vars

begin
	inheritMethod(_trackedItem, _extra);// 01/04/2010 cnwcs5 par 23383

	if self.jobType = JOB_TYPE_SOB then
		if (not self.allSOBTrackedItems.includes(_trackedItem)) then
			self.allSOBTrackedItems.add(_trackedItem);
		endif;
		self.allReleaseTrackeditems.clear;
		self.allReceiveTrackedItems.clear;	
	elseif self.isDischarge then
		updateReceiveTI(_trackedItem);
	else
		updateReleaseTI(_trackedItem);	
	endif;
	
	// PAR 6967 AKB2003DEC
// this has been moved up into the TRX util layer	self.setRemarks(null); // pass in null will get auto remarks
	
end;</source>
        <Parameter name="_trackedItem" type="CM_TrackedItem"/>
        <Parameter name="_extra" type="Any"/>
    </JadeMethod>
    <JadeMethod name="updateTICollectionsUnassign" id="687484ad-24bf-46ab-9e58-1f34fa4ca72c">
        <updating/>
        <source>updateTICollectionsUnassign(_trackedItem: CM_TrackedItem) updating;
// ---------------------------------------------------------------------------
// Created:		April 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	
	inheritMethod(_trackedItem);
		
	if self.jobType = JOB_TYPE_SOB then
		if ( self.allSOBTrackedItems.includes(_trackedItem)) then
			self.allSOBTrackedItems.remove(_trackedItem);
		endif;
	elseif self.isDischarge then
		if (self.allReceiveTrackedItems.includes(_trackedItem)) then
			self.allReceiveTrackedItems.remove(_trackedItem);
		endif;
	else
		if (self.allReleaseTrackeditems.includes(_trackedItem)) then
			self.allReleaseTrackeditems.remove(_trackedItem);
		endif;
	endif;
end;</source>
        <Parameter name="_trackedItem" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="validateActualTimes" id="0e1c2dc8-0ecc-4363-9078-f955412bbcb7">
        <source>validateActualTimes();
// -------------------------------------------
// Created 24 August 2005 by cnwdvb1
// -------------------------------------------
vars

begin

	if self.actualStartTs.isValid() and self.actualEndTs.isValid() then
		if self.actualStartTs &gt; self.actualEndTs then
			app.raiseCMException1(EndBeforeStart, self.actualStartTs.shortCurrentLocaleFormat(), null, null);
			return;
		endif;
	endif;

	


end;</source>
    </JadeMethod>
    <JadeMethod name="validateForCreate" id="4362201a-91bf-454f-b923-821412eef068">
        <source>validateForCreate();
// ---------------------------------------------------------------------------
// Created:		February 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	aRequest : CM_Request;
begin
	// no validation here
	// NOTE CRANES can be set later
	// NOTE VOYAGE JOBS CAN HAVE AUTO NEXT JOB NUMBERS - see voyage::getNextJobNumber
	self.validateJobNumCreate();
	foreach aRequest in self.allRequests do
		if aRequest.myJob &lt;&gt; null then
			if not aRequest.myJob.isJobComplete() then
				app.raiseCMException1(ERR_JOB_LOADED, self.jobNum, null, null);
			endif;
		endif;
	endforeach;
	
	self.validateActualTimes();

	

end;</source>
    </JadeMethod>
    <JadeMethod name="validateForDelete" id="423aaf54-9d87-4b7c-9fe5-0ac2106f382d">
        <source>validateForDelete();


vars
	jobStatus	:	Integer;
begin

	exclusiveLock(self);

	jobStatus := self.status;

	if jobStatus = JOB_UNACTIONED then
		if self.isLoadedToOperations then
			app.raiseCMException1(ERR_JOB_LOADED, self.jobNum, null, null);
		endif;
		
	elseif jobStatus = JOB_PART_COMPLETE then
		self.validateForSplit(null);

	elseif jobStatus = JOB_COMPLETE then
		if not self.workListEntries.isEmpty() then  // PAR 25968
			app.raiseCMException1(ERR_JOB_COMPLETE, self.jobNum, null, null);
		endif;
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="validateForSplit" id="2752bae4-cb5e-4fd6-a50f-fb7f147cdbfc">
        <source>validateForSplit(_selectedRequests : CM_RequestSet);
//--------------------------------------------------------------
//Created: 24 April 2003 By: cnwgd1
//--------------------------------------------------------------
vars
	request : CM_Request;	
	countComplete,
	countUnactioned : Integer;
	requests : CM_RequestSet;
begin
	create requests transient;
	
	if _selectedRequests &lt;&gt; null then
		_selectedRequests.copy(requests);
	else
		self.allRequests.copy(requests);
	endif;

/*	TFS3272 MAP 3/3/17 *DO* transfer jobs being worked
	// ### PAR DO not transfer jobs if there are any jobs actually being worked by RT
	foreach request in requests do
		foreach wle in request.allWorkListEntries do
			if not wle.areAllEntryTasksEqStatus(TASK_COMPLETE)
			or not wle.areAllEntryTasksEqStatus(TASK_UNACTIONED) then
				app.raiseCMException(CM_Job_Cannot_Be_Transferred, null, null);
				return;		
			endif;
		endforeach;
	endforeach;
*/

	if self.status = JOB_UNACTIONED then
		return;
	endif;
	
	
	if self.allRequests.size &lt; 2 then
		//nothing to split
		return;
	endif;	
	
	//foreach request in self.allRequests do
	foreach request in requests do  //cnwjo3 par 23366
		if self.areWLEsAllStatus(WLE_UNACTIONED) then
			countUnactioned := countUnactioned + 1;
		else				
			countComplete := countComplete + 1;		
		endif;
	endforeach;

	if countUnactioned &gt; 0
	and countComplete &gt; 0 then
		app.raiseCMWarning3(JobSplitUnactioned, self.jobNum, countComplete.String, countUnactioned.String, null, null, self);
	endif;
epilog
	delete requests;
end;</source>
        <Parameter name="_selectedRequests" type="CM_RequestSet"/>
    </JadeMethod>
    <JadeMethod name="validateForSplitNoQueued" id="9088d3ae-2f8e-42c6-bb13-2dcc72db6773">
        <source>validateForSplitNoQueued(_selectedRequests : CM_RequestSet);
//--------------------------------------------------------------
//Created:		16/9/2010 cnwjo3
//
//Purpose:		This method just verifies if any requests are currently queued
//--------------------------------------------------------------
vars
	request : CM_Request;	
	wle : CM_WorkListEntry;
	cannotSplitWLEList : String;
begin
	foreach request in _selectedRequests do 
		foreach wle in request.allWorkListEntries do
			if wle.myFutureMove &lt;&gt; null then
				if wle.myFutureMove.isKindOf(CM_FutureMoveQueued) then //cnwrd1 par 24242 we are now moving unqueued only
					cannotSplitWLEList := cannotSplitWLEList &amp; wle.id &amp; ", ";
				endif;
			endif;
		endforeach;	
	endforeach;
	
	if cannotSplitWLEList.length &gt; 0 then
		app.raiseCMException1(ERR_CannotSplitQueuedItems,cannotSplitWLEList[1:cannotSplitWLEList.length-2],null,null);
	endif;
end;</source>
        <Parameter name="_selectedRequests" type="CM_RequestSet"/>
    </JadeMethod>
    <JadeMethod name="validateForTLSeqNums" id="c7bbb81c-a3a3-4e26-bff8-b21e1c766747">
        <source>validateForTLSeqNums();
// ---------------------------------------------------------------------------
// Created:     February 2010 ANDREW BISHOP
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
// PAR 22174
// ---------------------------------------------------------------------------

vars
	req : CM_Request;
	seqs : IntegerArray;
	sequence, tmpSeq, idx, numDups, totReqs : Integer;
begin
	if not self.isTwinLift then
		return;
	endif;
	
	create seqs transient;
	foreach req in self.allRequests  discreteLock do
		seqs.add(req.allWorkListEntries.first.CM_VoyageWLE.getSeqNum());
	endforeach;
	totReqs := seqs.size;
	
	foreach idx in 1 to totReqs do
		sequence := seqs[idx];
		foreach tmpSeq in 1 to totReqs do
			if tmpSeq = idx  then
				continue;
			endif;
			
			if sequence = seqs[tmpSeq] then
				numDups := numDups + 1;
			endif;
		endforeach;
		if numDups &gt; 1 then
			app.raiseCMException3(VOY_JOB_NO_TL_SEQ_NUM_DUPS,self.id, sequence.String, (numDups + 1).String, null, self );
			return;
		endif;
		
		numDups := 0;
	endforeach;
epilog
	delete seqs;

end;</source>
    </JadeMethod>
    <JadeMethod name="validateForUnplan" id="db623b60-e955-4640-b9f1-e2503db2bf5c">
        <source>validateForUnplan();
// ---------------------------------------------------------------------------
// Created:		December 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	jobStatus	:	Integer;
begin

	exclusiveLock(self);

	jobStatus := self.status;
	// PAR 7215 AKB2004JAN no unplanning LOAD jobs if loaded to ops window
	/* PAR 7215 AKB2004FEB Removed
	if self.isLoadedToOperations and self.isRelease then
		app.raiseCMException1(ERR_JOB_LOADED, self.jobNum, null, null); // AKB
	endif;
	*/
	if jobStatus = JOB_UNACTIONED then
		
	elseif jobStatus = JOB_PART_COMPLETE then

	elseif jobStatus = JOB_COMPLETE then
		app.raiseCMException1(ERR_JOB_COMPLETE, self.jobNum, null, null);
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="validateForUpdate" id="ac6e34e0-42cd-4464-84b5-05bde25a53b0">
        <source>validateForUpdate();
//--------------------------------------------------------------
//Created: 24 April 2003 By: cnwgd1
//--------------------------------------------------------------
vars
	crane : CM_Crane;
begin
	inheritMethod();

	if self.isLoadedToOperations then									// PAR 8739 JPC 2004 Oct AKB
	//	app.raiseCMException1(ERR_JOB_LOADED, self.jobId, null, null);	// PAR 8739 JPC 2004 Oct AKB //epr 11/6/07 removed par 14190
	endif;

	if self.status = JOB_PART_COMPLETE then
		self.validateForSplit(null);
	endif;

	if self.status = JOB_COMPLETE then
		app.raiseCMException1(ERR_JOB_COMPLETE, self.jobNum, null, null);
	endif;

	self.validateJobNumUpdate();
	
	self.validateActualTimes();
	
	if self.isTwinLift and self.myVoyageJobSheet &lt;&gt; null then
		crane := self.myVoyageJobSheet.getMyCrane();
		if crane &lt;&gt; null then
			//if not crane.canTwinLift then
			if crane.machineLiftType = NORMAL_LIFT then//ccms1595 27/11/07
				app.raiseCMException1(Twin_lift_capable, crane.id, null, null);
			endif;
		endif;
	endif;

		//cnwrd1 ccms 1303
	if self.allowOutOfOrderLoading and self.hasMultipleAllocations then
		app.raiseCMException1(Voyage_alloc_loading_count_err, self.jobNum, null, null);	
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="validateForVoyageRequests" id="96c9c636-2b80-4992-a0fe-2ed38350cb33">
        <source>validateForVoyageRequests(_jobParams : CMIF_VoyageJobParams input);
// ---------------------------------------------------------------------------
// Created:		February 2003 By Andrew Bishop cnwab1
//
// Purpose:		
// ---------------------------------------------------------------------------
vars
	aRequest : CM_Request;
	aSlotRequest : CM_SlotRequest;
	theJobNum : String;
	tmpJob		: CM_Job;
	invalidObj 	: Boolean;
begin
	// no validation here
	// NOTE CRANES can be set later
	// NOTE VOYAGE JOBS CAN HAVE AUTO NEXT JOB NUMBERS - see voyage::getNextJobNumber
	
	if _jobParams.allSlotControllers.size &gt; 0 and
	   _jobParams.allHatchLids.size &gt; 0 then
		// if this is ever changed need to look at jobType as if create
		// a job with slots/requests &amp; hatchLids then maybe a problem
		// in the erase as the jobType was set to JOB_TYPE_USER.  This
		// replaces a check in the GUI which prevented users from sending
		// hatchLids &amp; slots through - rjs
		app.raiseCMException(ErrVoyageJobHasSlotsAndHatches, null, null);
		return;
	endif;

	theJobNum := self.jobNum.trimBlanks;
	
	if theJobNum = null then
		theJobNum := "'Auto'";
	endif;
	
	on Exception do app.handleDeletedObject(exception,aSlotRequest, invalidObj);  //epr par 29553 17/5/12
	foreach aSlotRequest in _jobParams.allSlotRequests do
		invalidObj:=false;
		tmpJob := aSlotRequest.myJob;
		
		if  invalidObj then
			continue;
		endif;
		if tmpJob &lt;&gt; null and
		   tmpJob &lt;&gt; self.pxyGetRealObject and 
		   (not tmpJob.isJobComplete()) then
			app.raiseCMException2(ERR_SLOT_HASINCOMPLETE_JOB, aSlotRequest.mySlotController.getFullId, self.jobNum, null, null);
		endif;
// PAR 21746		if aSlotRequest.fortyBack or aSlotRequest.isBackend then
		if aSlotRequest.getAttrIsBackend() then
			app.raiseCMException2(ERR_40_BACKEND_IN_JOB, aSlotRequest.mySlotController.getFullId,theJobNum, null, null);
		endif;
	endforeach;
	
	
	//cnwrd1 ccms 1303
	if _jobParams.allowOutOfOrderLoading and _jobParams.hasMultipleAllocations then
		app.raiseCMException1(Voyage_alloc_loading_count_err, self.jobNum, null, null);	
	endif;	
end;</source>
        <Parameter name="_jobParams" type="CMIF_VoyageJobParams" usage="input"/>
    </JadeMethod>
    <JadeMethod name="validateJobNumCreate" id="ae42b7e3-9e26-44ce-b33d-a2b1af1602dd">
        <source>validateJobNumCreate(); //newJobNum : String) ;
// ---------------------------------------------------------------------------
// Created:		January 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	
begin
	self.raiseExceptionIfNotTransient(method);

	exclusiveLock(self);
	//--------------------------------------------------------------------
	// Check to see if this job number is already present for this voyage
	//--------------------------------------------------------------------
	self.validateUniqueJobNum(self.jobNum);

end;</source>
    </JadeMethod>
    <JadeMethod name="validateJobNumUpdate" id="91f1c2a5-21ae-4b39-8c7f-f4c6a12df497">
        <source>validateJobNumUpdate(); //newJobNum : String) ;
// ---------------------------------------------------------------------------
// Created:		January 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	job,
	realJob		: CM_Job;
	jobSheet	: CM_VoyageJobSheet;
	oldJobNum,
	newTmpJobNum :	String;
	
	isSelectedNum : Boolean;
begin

	newTmpJobNum := self.jobNum.trimBlanks;
	
	if newTmpJobNum = null then
		app.raiseCMException1(ERR_INVALID_JOBNUM, null,null, null);
	endif;
	
	//par 16437
	if self.isLoadedToOperations then
		app.raiseCMException1(ERR_JOB_LOADED, self.id, null, null);
	endif;
	
	if self.isJobComplete then
		app.raiseCMException1(ERR_JOB_COMPLETE, self.id,null, null);
	endif;

	/*if self.fixed then
		app.raiseCMException1(ERR_FIXED_JOBNUM, oldJobNum, null, null);
	endif;*/
	
	if self.isTransient then
		realJob := self.pxyGetRealObject;
	endif;
	

	foreach job in self.myVoyage.allVoyageJobs discreteLock do
		if job = self then
			continue;
		endif;
		
		if job = realJob then
			continue;
		endif;
		
		if job.CM_VoyageJob.jobNum = newTmpJobNum then
			app.raiseCMException1(ERR_NON_UNIQUE_JOB, newTmpJobNum, null, null);
		endif;
	endforeach;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="validateJobNumsUpdate" id="c5978a66-7f16-4b49-9cfb-d083f8f57cee">
        <source>validateJobNumsUpdate(_proxyVoyageJobs :CM_VoyageJobByJobNumDict); //newJobNum : String) ;
// ---------------------------------------------------------------------------
// Created:		January 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	job,
	realJob		: CM_Job;
	vJob		: CM_VoyageJob;
	jobSheet	: CM_VoyageJobSheet;
	oldJobNum,
	newTmpJobNum :	String;
	
	isSelectedNum : Boolean;
	
	proxyJob : CM_VoyageJob;
	realJobs : CM_VoyageJobByJobNumDict;
begin

	newTmpJobNum := self.jobNum.trimBlanks;
	
	if newTmpJobNum = null then
		app.raiseCMException1(ERR_INVALID_JOBNUM, null,null, null);
	endif;

	/*if self.fixed then
		app.raiseCMException1(ERR_FIXED_JOBNUM, oldJobNum, null, null);
	endif;*/
	create realJobs transient;
	foreach proxyJob in _proxyVoyageJobs do 
		realJob := proxyJob.pxyGetRealObject();
		//par 16437
		if proxyJob.isLoadedToOperations then
			app.raiseCMException1(ERR_JOB_LOADED, realJob.id, null, null);
		endif;
		
		if proxyJob.isJobComplete then
			app.raiseCMException1(ERR_JOB_COMPLETE, realJob.id,null, null);
		endif;
	
		
		
		realJobs.add(realJob.CM_VoyageJob);
	endforeach;
	
	if self.isTransient then
		realJob := self.pxyGetRealObject;
	endif;
	
	foreach job in self.myVoyage.allVoyageJobs discreteLock do
		if job = self then
			continue;
		endif;
		
		if job = realJob then
			continue;
		endif;
		
		if job.CM_VoyageJob.jobNum = newTmpJobNum then
			vJob := realJobs.getAtKey(job.CM_VoyageJob.jobNum);
			if vJob = null then
				app.raiseCMException1(ERR_NON_UNIQUE_JOB, newTmpJobNum, null, null);
			endif;
		endif;
	endforeach;

epilog
	delete realJobs;						// 18/02/2014 cnwmh5 - Translient Leak
end;</source>
        <Parameter name="_proxyVoyageJobs" type="CM_VoyageJobByJobNumDict"/>
    </JadeMethod>
    <JadeMethod name="validateMove" id="45623fec-c15c-4d4f-b4f4-febe831dad1f">
        <source>validateMove(control: CMIF_MoveController input);
/*
 ------------------------------------------------------------------------
Created:			25 September 2002 by cnwdwq1
Purpose:			Performs the job tests required for a ship job move.
Parameters:		None
Returns:			Nothing
Changed On		Changed By		Reason
--------------		--------------		-----------------------------------------
---------------------------------------------------------------------------
*/
vars
	moveToShip : Boolean;
	moveFromShip : Boolean;
begin
	if control = null then
		app.raiseCMException2(MethodWithNullParam, method.name, 'Validate Move',null, null);
		return;
	endif;
	if control.myToPrimaryLocation.isKindOf(CM_VoyageController) then
		//Move to ship
		moveToShip := true;
	endif;
	if control.myOriginatingLocation &lt;&gt; null and control.myOriginatingLocation.isKindOf(CM_VoyageController) then
		moveFromShip := true;
	endif;
end;</source>
        <Parameter name="control" type="CMIF_MoveController" usage="input"/>
    </JadeMethod>
    <JadeMethod name="validateShipLoadLanes" id="8af9ec60-27eb-4abb-aa65-535f28960ca4">
        <source>validateShipLoadLanes(_startFromLC : CM_LocationsController;_startFromWLE : CM_WorkListEntry);
// ---------------------------------------------------------------------------
// Created:		January 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	mess : String;
	crane : CM_Crane;
	lanes	: CM_LCArray;
	numLoadLanes	:	Integer;
begin


	crane := self.getJobCrane();
	if crane = null then
//		app.raiseCMException1(REQUIRED_FIELD, "Crane", null,null);
		app.raiseCMException(Input_required_field_crane, null,null);// cnwdb2	PAR 35364
	endif;	
	//----------------
	//OK, ask crane for is LOAD lanes
	//----------------
	if crane.transferArea = null then
		app.raiseCMException1(Crane_no_CTA, self.craneId, null, null);
	endif;
	
	//------------------	
 	//Check for load lanes
	//------------------	
	lanes := crane.transferArea.loadLanes;
	numLoadLanes := lanes.size;
	if numLoadLanes = 0 then
		app.raiseCMException1(CTA_No_Load_Lanes, crane.transferArea.id,  null, null);
	endif;
	//----------------
	//have they passed in a startFromLane??
	//----------------
	if _startFromLC = null then
		app.raiseCMException2(ERR_INV_LANE, self.craneId, "", null, null);
	endif;

	//-----------------
	//Is this a load lane?
	//-----------------
	if not lanes.includes(_startFromLC) then
		app.raiseCMException2(ERR_NOT_LANE, _startFromLC.getID(), "Load lane", null, null);
	endif;


	//-------------------
	//Have we been passed a startWLE
	//-------------------
	if _startFromWLE &lt;&gt; null then
		if not self.workListEntries.includes(_startFromWLE) then
			app.raiseCMException2(ERR_NO_WLE, _startFromWLE.id.trimRight, self.jobId, null, null);
		endif;
	endif;


	if not crane.validateLanesAndCages(mess) then
		app.raiseCMException2(Err_LoadLanesLoadCageMismatch, crane.id.trimRight, mess, null, null);
	endif;

end;</source>
        <Parameter name="_startFromLC" type="CM_LocationsController"/>
        <Parameter name="_startFromWLE" type="CM_WorkListEntry"/>
    </JadeMethod>
    <JadeMethod name="validateShipOpsLoad" id="12db8e56-4ce2-456d-bf59-ac029ecb995c">
        <source>validateShipOpsLoad();
// ---------------------------------------------------------------------------
// Created:		January 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 17/05/2010	cnwdap1		CCMS 1116 Tranship changes
// 29/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
// ---------------------------------------------------------------------------
vars
	ti : CM_TrackedItem;
	numTI : Integer;
	validTI : Boolean;
	tis : CM_TISet;
	theRealMe : CM_VoyageJob;
	tmpStr	: String;
	hasBulkRelease : Boolean;
	
begin
	theRealMe := self.pxyGetRealObject();
	
	if theRealMe = null then
		return;
	endif;
	
	if (self.jobType = JOB_TYPE_DISCHARGE) then
		tis := theRealMe.allReceiveTrackedItems;
	elseif (self.jobType = JOB_TYPE_LOAD) then
		tis := theRealMe.allReleaseTrackeditems;
	elseif (self.jobType = JOB_TYPE_SOB) then
		tis  := theRealMe.allSOBTrackedItems;
	endif;

	if not self.allowOutOfOrderLoading then //ccms 1303 cnwrd1
		if tis.isEmpty 
			and not theRealMe.hasBulkRelease() then
			app.setContinueCMExceptions(false);
			app.raiseCMException1(ERR_NO_WLE_TI, self.jobNum, null, null);
			return;			
		endif;
	endif;

	foreach ti in tis do
		validTI := false;

		if ti.isRehandle then // and not ti.isSOB then
			validTI := (jobType = JOB_TYPE_DISCHARGE) or  (jobType = JOB_TYPE_LOAD);
		elseif	ti.isSOB then
			validTI := (jobType = JOB_TYPE_SOB);
		elseif ti.isEmpty then
			validTI :=  (jobType = JOB_TYPE_DISCHARGE) or  (jobType = JOB_TYPE_LOAD) or (jobType = JOB_TYPE_SOB);
		//elseif ti.isImport then							// PAR #23645 CCMS 1116
		elseif (ti.isImport or ti.isTranshipOnInboundVoyage) and ti.directDelivery then	//cnwrd1 direct deliverys can be import/tranship onto load job or discharge par 31335
			validTI := (jobType = JOB_TYPE_LOAD) or (jobType = JOB_TYPE_DISCHARGE);		
		elseif (ti.isImport or ti.isTranshipOnInboundVoyage) then	// PAR #23645 CCMS 1116
			validTI := (jobType = JOB_TYPE_DISCHARGE);
		//elseif ti.isExport then
		elseif (ti.isExport or ti.isTranshipExport) then	// PAR #23645 CCMS 1116
			validTI := (jobType = JOB_TYPE_LOAD);		// PAR #23645 CCMS 1116
		elseif	ti.isRehandle then
			validTI := (not ti.releasedDT.isValid);
		endif;
		if validTI then
			numTI := numTI +1;
		else
			if tmpStr = null then
				tmpStr := ti.id;
			else
				tmpStr := tmpStr &amp; ', ' &amp; ti.id;
			endif;
		endif;
	endforeach;
	
	if numTI &lt;&gt; tis.size then
		// The IMEX status of cargo items (%1) for job %2 does not match the jobs type.
		app.raiseCMWarning3(ErrCargoImexJobTypeMisMatch, tmpStr, self.jobNum, self.jobTypeId, null, null, self);
	endif;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="validateShipOpsUnload" id="9e5a85e6-bdf3-46c2-bf6d-8e372d32c869">
        <source>validateShipOpsUnload();
// ---------------------------------------------------------------------------
// Created:		January 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

	wle : CM_WorkListEntry;
	realJob : CM_VoyageJob;

begin

	if (not self.isLoadedToOperations) then
		app.raiseCMException1(ERR_JOB_UNLOADING, self.jobNum, null, null);
	endif;
	//11 Jan 2016 NDL	Par 37310
	if self.isTransient then
		realJob := self.pxyGetRealObject().CM_VoyageJob;
	else
		realJob := self;
	endif;
	if realJob &lt;&gt; null then
		foreach wle in realJob.workListEntries do
			if wle.isQueued then
				app.raiseCMException1(Not_unloa_while_tasks_that_que, self.jobNum, null, null);
				break;
			endif;
		endforeach;
	endif;

end;</source>
    </JadeMethod>
    <JadeMethod name="validateUniqueJobNum" id="50ba2f2d-dffe-46a9-aea1-a09be724a55c">
        <source>validateUniqueJobNum(_jobNum : String);
/*

Date		Who		Reason
23 October 2013	cnwer1	Initial creation PAR 32250

*/

vars
	jobSheet : CM_VoyageJobSheet;
	vJob : CM_VoyageJob;
begin
	
	foreach jobSheet in self.myVoyage.allJobSheets do
		//We have to hunt through all cranes, for a dupe.
// PAR 36850		if jobSheet.allJobsByJobNum[_jobNum] &lt;&gt; null then

		vJob := jobSheet.allJobsByJobNum[_jobNum]; // PAR 36850
		if vJob &lt;&gt; null and vJob &lt;&gt; self then // PAR 36850
// PAR 36850			app.raiseCMException1(ERR_NON_UNIQUE_JOB, self.jobNum, null, null);
			app.raiseCMException1(ERR_NON_UNIQUE_JOB, jobSheet.crane &amp; " - " &amp;  _jobNum, null, null);
			return;
		endif;
	endforeach;
epilog

end;</source>
        <Parameter name="_jobNum" type="String"/>
    </JadeMethod>
</Class>
