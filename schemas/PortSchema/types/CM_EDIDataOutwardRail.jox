    <JadeMethod name="findHeadings" id="f000d3a2-51d4-417f-b976-3f0107a89928">
        <source>findHeadings(tiName: String; shortDesc: String io; longDesc: String io; width: Integer io; num: Integer io);
//--------------------------------------------------------------
//Created: December 2001 By: cnwgd1
//--------------------------------------------------------------
// note: num does not have to be order but the largest num must be
//	   greater than the total number of properties.
//	   ie what is return by getNumColumns.
vars

begin
	if tiName = "id" then
		num := 1;
		shortDesc := "Cargo ID";
		longDesc := "Cargo ID";
		width := 100;
	elseif tiName = "imex" then
		num := 2;
		shortDesc := "Content Status";
		longDesc := "Content Status";
		width := 60;				
	elseif tiName = "isoType" then
		num := 3;
		shortDesc := "ISO Type";
		longDesc := "ISO Type";
		width := 60;
	elseif tiName = "operator" then
		num := 4;
		shortDesc := "Freight Payer";
		longDesc := "Freight Payer";
		width := 80;
	elseif tiName = "freightPayerCode" then
		num := 5;
		shortDesc := "Code";
		longDesc := "Freight Payer Code";
		width := 60;
	elseif tiName = "wagon" then
		num := 6;
		shortDesc := "Wagon";
		longDesc := "Wagon No.";
		width := 60;
	elseif tiName = "destination" then
		num := 7;
		shortDesc := "Destination";
		longDesc := "Destination/Receiver";
		width := 150;												
	elseif tiName = "voyage" then
		num := 8;
		shortDesc := "Vessel";
		longDesc := "Vessel Voyage No.";
		width := 60;
	elseif tiName = "weight" then
		num := 9;
		shortDesc := "Weight";
		longDesc := "Weight";
		width := 60;
	elseif tiName = "bookingReleaseNo" then
		num := 10;
		shortDesc := "Release No.";
		longDesc := "Booking Release No.";
		width := 80;
	elseif tiName = "remarks" then
		num := 11;
		shortDesc := "Remarks";
		longDesc := "Remarks";
		width := 150;
	elseif tiName = "status" then
		num := 12;
		shortDesc := "Status";
		longDesc := "Status";
		width := 100;

	else
		num := 0;
		shortDesc := "";
		longDesc := "";
		width := 0;
	endif;
end;</source>
        <Parameter name="tiName" type="String"/>
        <Parameter name="shortDesc" type="String" usage="io"/>
        <Parameter name="longDesc" type="String" usage="io"/>
        <Parameter name="width" type="Integer" usage="io"/>
        <Parameter name="num" type="Integer" usage="io"/>
    </JadeMethod>
