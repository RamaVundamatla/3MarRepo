    <JadeMethod name="isSuitableForTI" id="b8bb727c-b1b8-4ccf-aeb7-898d3ad274e0">
        <source>isSuitableForTI(control: CMIF_MoveController): Boolean;
// ---------------------------------------------------------------------------
// Created:		June 2003 By Andrew Bishop cnwab1
//
// Purpose:		
// ---------------------------------------------------------------------------
vars

begin

	inheritMethod(control);
	if usage = REEFERGANTRY_USE 
	and control.myToPrimaryLocation = self
	and control.myTrackedItem.getActualLength() &gt; 20 then // reefer gantry next to me
		return false;
	else
		return true;
	endif;
end;</source>
        <Parameter name="control" type="CMIF_MoveController"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isSuitableForTIYA" id="f231931b-0466-4094-bc30-d1666fcae150">
        <source>isSuitableForTIYA(_yaAgent: CM_YAAutoplanAgent input): Boolean;

vars
	theTI : CM_TrackedItem;
begin
	
	if not inheritMethod(_yaAgent) then
		return false;
	endif;
	if self.usage &lt;&gt; REEFERGANTRY_USE then
		return true;
	endif;
	
	if  not _yaAgent.checkingSecondary then
		return true;
	endif;
	
	theTI := _yaAgent.getMyCurrentTrackedItem();
	if theTI &lt;&gt; null
	and theTI.getActualLength() &gt; 20 then
		return false;
	endif;
	
	return true;
end;
</source>
        <Parameter name="_yaAgent" type="CM_YAAutoplanAgent" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="needReverseDoor" id="e4ceb385-e940-40f4-98f8-25220a8e2a44">
        <source>needReverseDoor(_is20 : Boolean) : Boolean;
// ---------------------------------------------------------------------------
// Created:		08 November 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	prevRTG : CM_RTGController;
begin
	if self.usage = REEFERGANTRY_USE then
		return false;
	endif;
	
	prevRTG := self.getPreviousControllerOfType(CM_RTGController).CM_RTGController;
	if prevRTG &lt;&gt; null then
		if prevRTG.usage = REEFERGANTRY_USE then
			return true;
		endif;
		if _is20 then
			prevRTG := prevRTG.getPreviousControllerOfType(CM_RTGController).CM_RTGController;
			if prevRTG &lt;&gt; null then
				if prevRTG.usage = REEFERGANTRY_USE then
					return true;
				endif;
			endif;
		endif;
	endif;
	
	return false;
	
end;</source>
        <Parameter name="_is20" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="notSuitableForTIString" id="b64a6609-cda1-4f53-8677-a515b21dbb6d">
        <source>notSuitableForTIString(): String;
// ---------------------------------------------------------------------------
// Created:		April 2003 By Andrew Bishop cnwab1
//
// Purpose:		used if isSuitableForTI returns false
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

	griddedStackHeight : CM_GriddedTAStackHeight;
	firstTi: CM_TrackedItem;

begin
	if self.usage = BUILDING_USE then
		return app.getErrorString(Move_Building);
	elseif self.usage = LIGHT_TOWER_USE then
		return app.getErrorString(Move_Light);
	elseif self.usage = UNAVAILABLE_USE then
		return app.getErrorString(Move_Unavailable);
	elseif availability = PAD_UNAVAILABLE or availability = PAD_USER_UNAVAILABLE then
		return app.getErrorString(Move_Unavailable);
	elseif availability &gt;= PAD_USER_UNAVAILABLE then
		return app.getErrorString(Move_HeightRest);
	endif;
	
	//09 Sep 2020	ND:L	TFS 49984
	griddedStackHeight := self.getGriddedStackHeightObj( firstTi );
	if griddedStackHeight &lt;&gt; null then
		return app.getErrorString2(Height_restri_positi_becuas_fi, griddedStackHeight.name, firstTi.id );
	endif;
	
	return app.getErrorString(Move_Unknown);
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
