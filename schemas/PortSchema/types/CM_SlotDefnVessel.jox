<Class name="CM_SlotDefnVessel" id="a22544de-d8e0-4dc4-9107-90a648c08934">
    <superclass name="CM_SlotDefn"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
