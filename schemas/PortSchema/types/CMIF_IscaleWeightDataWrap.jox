<Class name="CMIF_IscaleWeightDataWrap" id="6de98442-1f5a-43a6-ace7-08a2af9c8951">
    <superclass name="CMIF_DotNetWrap"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>// 16 Aug 2016 cnwrh7            TFS2501</text>
    <DbClassMap file="cmtrans"/>
    <ImplicitInverseRef name="myWeightDataConvertion" id="49c9bf93-d4df-48b4-8580-f26f3cbd7989">
        <embedded/>
        <type name="WeightDataConversion"/>
        <access>readonly</access>
    </ImplicitInverseRef>
    <JadeMethod name="convertFunction" id="9037ef89-9f8a-4a91-8227-48de83bfc677">
        <source>convertFunction(_weightDataString : String; _weightRealData: Real output) : Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 September 2016	cnwrh7	Initial creation

*/

vars
	hadException : Boolean;
begin
	if self.myWeightDataConvertion = null then
		app.writeLog(method.qualifiedName &amp; " myWeightDataConvertion is null", LogDEBUG);	//25 Nov 2019	NDL	TFS 47053
		return false;
	endif;
	
	on Exception do self.handleExceptions(exception, hadException);
	
	if not hadException then
		_weightRealData := self.myWeightDataConvertion.convertFunction(_weightDataString.StringUtf8);
		
		app.writeLog(method.qualifiedName &amp; " result=" &amp;
					   "|" &amp; _weightRealData.Decimal.String &amp; "|", LogDEBUG);	//25 Nov 2019	NDL	TFS 47053
		return true;
	endif;
	
	app.writeLog(method.qualifiedName &amp; " no weight data", LogDEBUG);	//25 Nov 2019	NDL	TFS 47053
	
	return false;
	
epilog

end;</source>
        <Parameter name="_weightDataString" type="String"/>
        <Parameter name="_weightRealData" type="Real" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="create" id="1cb57012-5fbb-4b3e-a13f-904f776ede4c">
        <updating/>
        <source>create() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 September 2016	cnwrh7	Initial creation

*/

vars
	hadException	: Boolean;
	fileName		: String;
	iniValue		: String;
	usePresentation	: Boolean;
begin
	on Exception do self.handleExceptions(exception, hadException);
	create self.myWeightDataConvertion transient;
	if self.myWeightDataConvertion &lt;&gt; null then
		self.myWeightDataConvertion.usePresentationClient := self.usePresentationClient;
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="delete" id="708366da-2747-4c1b-af99-abc3ea6333f7">
        <updating/>
        <source>delete() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 September 2016	cnwrh7	Initial creation

*/

vars

begin
	delete self.myWeightDataConvertion;
epilog

end;</source>
    </JadeMethod>
</Class>
