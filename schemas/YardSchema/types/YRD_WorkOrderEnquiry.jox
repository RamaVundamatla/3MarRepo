    <JadeMethod name="mnuCRPaymentStatusCancel_click" id="4b8cdbe2-d834-43b1-bc0f-fdaecb5295ea">
        <controlMethod name="MenuItem::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>mnuCRPaymentStatusCancel_click(menuItem: MenuItem input) updating;
/*
Purpose:	TFS 42241		
Date				Who			Reason
NOVEMBER 2018		CNWAB1		Initial creation

MARCH19 JLGAB1 changed so that if special can set to any payment status
*/

vars

	obj : Object;
	pxyCashRec, realCashRec : CM_CashReceipt;
	theReturn : Integer;
	woDtl : CM_WorkOrderDtl;
	wo : CM_WorkOrder;
	allcrs : CM_CashReceiptSet;
	newpaymentStatus : Integer;
	ask : Boolean;
begin
	
	create allcrs transient;
	if menuItem.userObject.isKindOf(CM_WorkOrder) then
		newpaymentStatus := menuItem.helpContextId;

		wo := menuItem.userObject.CM_WorkOrder;
		foreach realCashRec in wo.allCashReceipts	discreteLock do
			allcrs.add(realCashRec);
		endforeach;
	

		ask := (allcrs.size &gt; 1);
	else
		newpaymentStatus := CM_CashReceipt.CREDIT_CANCEL_MANUAL;
		realCashRec := menuItem.userObject.CM_CashReceipt;
		
		if realCashRec = null then
			return;
		endif;
		allcrs.add(realCashRec);
	
	endif;
	
	
	foreach realCashRec in allcrs	discreteLock do : outerloop
		if ask then
			if app.msgBox("Change Receipt " &amp; realCashRec.externalInvoiceNumber &amp; " Payment Status to " 
				&amp; app.paymentStatusCashEnumToString(newpaymentStatus),"Payment Status",MsgBox_OK_Cancel) = MsgBox_Return_Cancel then
				continue;
			endif;
		endif;
		
	
	
		pxyCashRec := app.createUpdateProxy(realCashRec).CM_CashReceipt;
		
		while true do
			app.myTrxUA.trxUpdateCashRecPaymentStatus(pxyCashRec ,newpaymentStatus,app.myPassport);
			if app.myPassport.trxCompletedOK then
				// Clear errors/warnings from form and err/warnings window
				self.clearErrorWarnings();
				global.beep;
				break;
			else
				theReturn := app.showErrorWarningDialog("Cash Receipt Payment Status", app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
				if app.myPassport.noErrors and
				   theReturn = IDOK then
					// there must have just been warnings that the user has acknoledged so ..
					app.myPassport.warningsAcknowledged	:= true;
					continue;
				endif;
				self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
				return;
			endif;
			break outerloop;
		endwhile;
		delete pxyCashRec;
	endforeach;
	
	



epilog
	delete allcrs;
	delete pxyCashRec;
end;</source>
        <Parameter name="menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
