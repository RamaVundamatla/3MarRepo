Date		Who		Reason
02 Feb 2023 navtnr20	TFS CR 55646 Task 55665: UI - Contract Details
25 October 2023 navmv20 CR 60503 Task 60505: UI - Contract Rate Entry UI Changes
*/

vars

begin
	//25/10/2023 navmv20 CR 60503 Task 60505 - start
	self.doRemoveRateEntryDates(self.tblData.accessRow(self.tblData.row).itemObject.CMIF_ContractRateEntryDates);
	//self.doRemove(self.tblData.accessRow(self.tblData.row).itemObject.CM_InvoiceContractRateEntry);
