    <JadeMethod name="setComboValues" id="f4016c0d-89b1-4949-9bb2-70240377986d">
        <source>setComboValues(_combo: ComboBox input; _params: CM_QueryCriteriaLineHolder; _queryOperator: CM_QueryOperator; _passport: CM_Passport);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 September 2019	jlgndl1	Initial creation	TFS 46620

*/

vars

	genType : CM_GeneratorType;
	genTypeDict : CM_GeneratorTypeByCodeDict;
	qrl : CM_QReferenceLookup;
	
begin

	_combo.clear();
	
	genTypeDict := app.myRoot.allGeneratorTypes;
	foreach genType in genTypeDict do
		_combo.itemObject[_combo.addItem(genType.code &amp; Tab &amp; genType.description)] := genType;
	endforeach;

	if CM_QReferenceLookup.hasInstance(_queryOperator) then
		qrl := _queryOperator.CM_QReferenceLookup;
		if global.isValidObject(qrl.mySelectionValue) then
			_combo.listObject := qrl.mySelectionValue;
		endif;
	endif;

end;</source>
        <Parameter name="_combo" type="ComboBox" usage="input"/>
        <Parameter name="_params" type="CM_QueryCriteriaLineHolder"/>
        <Parameter name="_queryOperator" type="CM_QueryOperator"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="translateStringToSearchValue" id="af742d99-f40e-4ba3-a6b0-db782dc8ea1f">
        <source>translateStringToSearchValue(_value: Any; _criteriaLine: CM_SelectorCriteriaLine): Any;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 September 2019	jlgndl1	Initial creation	TFS 46620

*/

vars

	genType : CM_GeneratorType;
	genTypeDict	: CM_GeneratorTypeByCodeDict;
	tmpValue: String;

begin

	if _value.isKindOf( CM_CustomsAgent ) then
		return _value;
	endif;
	
	tmpValue := _value.String.toUpper();
	genTypeDict	:= app.myRoot.allGeneratorTypes;
	
	foreach genType in genTypeDict do
		if genType.code.toUpper() = tmpValue then
			return genType;
		endif;
	endforeach;
	
	return inheritMethod(_value, _criteriaLine);

epilog

end;</source>
        <Parameter name="_value" type="Any"/>
        <Parameter name="_criteriaLine" type="CM_SelectorCriteriaLine"/>
        <ReturnType type="Any"/>
    </JadeMethod>
    <JadeMethod name="translateToDisplayValue" id="c101764e-e577-4b99-884c-8866e1ecca54">
        <source>translateToDisplayValue(_value: Any): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 September 2019	jlgndl1	Initial creation	TFS 46620

*/

vars

begin

	if _value &lt;&gt; null then
		return _value.CM_GeneratorType.code;
	endif;

	return null;

epilog

end;</source>
        <Parameter name="_value" type="Any"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="translateToSearchValue" id="945f2fa4-e907-4e9c-bf15-7c8931e8fc41">
        <source>translateToSearchValue(_value: Any): Any;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 September 2019	jlgndl1	Initial creation	TFS 46620

*/

vars

	returnVal : CM_GeneratorType;

begin
	
	if _value &lt;&gt; null and _value.isKindOf(CM_GeneratorType) then
		returnVal := _value.CM_GeneratorType;
	elseif _value &lt;&gt; null and _value.isKindOf(String) then
		returnVal := app.myRoot.allGeneratorTypes[_value.String];
	endif;
	
	return returnVal;

epilog

end;</source>
        <Parameter name="_value" type="Any"/>
        <ReturnType type="Any"/>
    </JadeMethod>
    <JadeMethod name="translateToSearchValueForWeb" id="1b9cbba9-057e-4abf-a303-5607b47f6336">
        <source>translateToSearchValueForWeb(_value: Any; _sending : Boolean): Any;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 September 2019	jlgndl1	Initial creation	TFS 46620

*/

vars

	genType : CM_GeneratorType;

begin

	if _value.isKindOf(CM_GeneratorType) then
		return _value.CM_GeneratorType.code;
	elseif _value.isKindOf(String) then
		genType := app.myRoot.allGeneratorTypes[_value.String];
		if genType &lt;&gt; null then
			return genType.code;
		endif;
	endif;
	
	return inheritMethod(_value, _sending);

epilog

end;</source>
        <Parameter name="_value" type="Any"/>
        <Parameter name="_sending" type="Boolean"/>
        <ReturnType type="Any"/>
    </JadeMethod>
</Class>
