    <JadeMethod name="tToDoTaskResourceCargo" id="877ad6d5-1481-4fcc-8f1c-1c616fd5fd06">
        <source>tToDoTaskResourceCargo();
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who			Reason
23 November 2022	navcs2		ChangeRequest 56635:[54261] EUP - Todo Task Resources Maintenance

*/
constants
	TYPE 	:	Integer = TODO_TYPE_GROUP_TI;
vars
	 resourceType : CM_ResourceType;
	 toDoTask     : CM_ToDoTaskDescBySortKey;
	 toDoTaskDesc :CM_ToDoTaskDesc ;
	 ti1,ti2      : CM_TrackedItem;
	 tiSet		  : CM_TISet;
	 tiTask1 : CM_ToDoTask;
	 tiTask2 : CM_ToDoTask;
	 
begin
	toDoTaskDesc := app.myRoot.allToDoTaskDescsByShortDesc["UTMA1"];
	deleteToDoTaskDescription(toDoTaskDesc);
	toDoTaskDesc := self.createToDoTaskDesc("UTMA1");
	self.assertNotNull(toDoTaskDesc);
	
	create toDoTask transient;
	toDoTask.add(toDoTaskDesc);
	
	self.opts.purge;
	self.opts.addAssoc("Type",TYPE);
	
	resourceType := self.addToDoTaskResource("UTMARESTI",
											 "UT MA Resource",
											 "MAN",
											 1,
											 false,
											 true,
											 toDoTask
											 );
	self.assertNotNull(resourceType);
	self.assertEqual(resourceType.type,TYPE);
	
	self.deleteResourceType(resourceType.code);

epilog
	
	delete toDoTask;
	delete tiSet;
end;</source>
    </JadeMethod>
