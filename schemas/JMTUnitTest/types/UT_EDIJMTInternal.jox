    &lt;id&gt;ZGHJ8063791&lt;/id&gt;
    &lt;imexStatus&gt;Remain On Board&lt;/imexStatus&gt;
    &lt;isoType&gt;2300&lt;/isoType&gt;
    &lt;loadPort&gt;NZNSN&lt;/loadPort&gt;
    &lt;messageMode&gt;A&lt;/messageMode&gt;
    &lt;operatorCode&gt;MSK&lt;/operatorCode&gt;
	&lt;totalQuantity&gt;1&lt;/totalQuantity&gt;
    &lt;voyageCode&gt;'&amp;VoyageName&amp;'&lt;/voyageCode&gt;
  &lt;/CargoOnShip&gt;
  &lt;CargoOnShip&gt;
    &lt;weight&gt;15730.0000&lt;/weight&gt;
    &lt;site&gt;3&lt;/site&gt;
    &lt;bol&gt;BOLVOYSHIPGENXX3&lt;/bol&gt;
    &lt;bookingRef&gt;BOOKVOYSHIPGENXX1&lt;/bookingRef&gt;
    &lt;cargoTypeDescr&gt;ISO Container&lt;/cargoTypeDescr&gt;
    &lt;commodity&gt;GENL&lt;/commodity&gt;
    &lt;companyCode&gt;DFBU&lt;/companyCode&gt;
    &lt;destinationPort&gt;NZAKL&lt;/destinationPort&gt;
    &lt;dischargePort&gt;DEBRV&lt;/dischargePort&gt;
    &lt;id&gt;ZGHJ8063792&lt;/id&gt;
    &lt;imexStatus&gt;Remain On Board&lt;/imexStatus&gt;
    &lt;isoType&gt;2300&lt;/isoType&gt;
    &lt;loadPort&gt;NZNSN&lt;/loadPort&gt;
    &lt;messageMode&gt;A&lt;/messageMode&gt;
    &lt;operatorCode&gt;MSK&lt;/operatorCode&gt;
	&lt;totalQuantity&gt;1&lt;/totalQuantity&gt;
    &lt;voyageCode&gt;'&amp;VoyageName&amp;'&lt;/voyageCode&gt;
  &lt;/CargoOnShip&gt;
  &lt;CargoOnShip&gt;
    &lt;weight&gt;15730.0000&lt;/weight&gt;
    &lt;site&gt;3&lt;/site&gt;
    &lt;bol&gt;BOLVOYSHIPGENXX3&lt;/bol&gt;
    &lt;bookingRef&gt;BOOKVOYSHIPGENXX1&lt;/bookingRef&gt;
    &lt;cargoTypeDescr&gt;ISO Container&lt;/cargoTypeDescr&gt;
    &lt;commodity&gt;GENL&lt;/commodity&gt;
    &lt;companyCode&gt;DFBU&lt;/companyCode&gt;
    &lt;destinationPort&gt;NZAKL&lt;/destinationPort&gt;
    &lt;dischargePort&gt;DEBRV&lt;/dischargePort&gt;
    &lt;id&gt;ZGHJ8063793&lt;/id&gt;
    &lt;imexStatus&gt;Remain On Board&lt;/imexStatus&gt;
    &lt;isoType&gt;2300&lt;/isoType&gt;
    &lt;loadPort&gt;NZNSN&lt;/loadPort&gt;
    &lt;messageMode&gt;A&lt;/messageMode&gt;
    &lt;operatorCode&gt;MSK&lt;/operatorCode&gt;
	&lt;totalQuantity&gt;1&lt;/totalQuantity&gt;
    &lt;voyageCode&gt;'&amp;VoyageName&amp;'&lt;/voyageCode&gt;
    &lt;orderNumber&gt;333333OrderNum&lt;/orderNumber&gt;
    &lt;invoiceNumber&gt;333333InvoiceNum&lt;/invoiceNumber&gt;
	&lt;salesOrderNbr&gt;12345&lt;/salesOrderNbr&gt;
  &lt;/CargoOnShip&gt;
  &lt;/AllCargoOnShip&gt;
	&lt;/DataTransManifest&gt;
	&lt;/AllDataTransManifest&gt;
&lt;/JMTInternalTransManifest&gt;
';
	ediFileObj := self.ediLoadFileName(ediText, EDIFileType_Unknown, USER_DEF_NAME, USER_DEF_NAME&amp;method.name);

	self.assertNotNull(ediFileObj);
	self.assertEqualMsg(true, passportObj.allErrors.isEmpty(), passportObj.getAllErrorsWarningsAsString());	// cnwrl1 25/08/2010 PAR 25559
	self.assertNotNull(ediFileObj.ediData);		// cnwrl1 25/08/2010 PAR 25559
	self.ediVerify(ediFileObj);
	errorMsg := "Verify Failed" &amp; CrLf &amp; passportObj.getErrorsAsString();
	// Status 3 is verify status and 14 is verified with warnings.
//	self.assertIsOneOf(	ediFileObj.fileStatus,
//						errorMsg,
//						CM_EDIFile.EDI_STATUS_VERIFIED,
//						CM_EDIFile.EDI_STATUS_VERIFIED_WARNINGS);
	self.assertEqualMsg(ediFileObj.fileStatus, CM_EDIFile.EDI_STATUS_VERIFIED, errorMsg);
	ediDataObj := ediFileObj.ediData;
	self.ediDBLoad(ediFileObj);
//	self.assertIsOneOf(	ediFileObj.fileStatus,
//						"Load Failed",
//						CM_EDIFile.EDI_STATUS_DBLOADED,
//						CM_EDIFile.EDI_STATUS_DBLOADED_PARTIAL);
	errorMsg := "DB Load Failed" &amp; CrLf &amp; passportObj.getErrorsAsString();
	self.assertEqualMsg(ediFileObj.fileStatus, CM_EDIFile.EDI_STATUS_DBLOADED, errorMsg);
	
	if ediFileObj.fileStatus = CM_EDIFile.EDI_STATUS_DBLOADED_PARTIAL then
		write "EDI message not fully loaded - needs a re-run.";
	endif;
	self.assertEqualMsg(ediDataObj.CM_EDIDataTransManifest.myShipManifest.allEDITrackedItems.size, 54, "incorrect number of EDI trackedItems");
	voyage := self.getVoyage(VoyageName);
	self.assertNotNull(voyage);
	self.assertEqualMsg(voyage.allBOLInByTypeStatusNumDT.size, 4, "");
	self.assertEqualMsg(voyage.allOnshipTIsByIdCargoType.size, 42, "");
	bol := self.getBOL("BOLVOYSHIPGENXX1", 5003, "MSK");
	self.assertNotNull(bol);
	self.assertEqualMsg(bol.allBOLDtls.size, 1, "");
	self.assertEqualMsg(bol.allTrackedItems.size, 0, "");
	bol := self.getBOL("BOLVOYSHIPGENXX12345678901234567890123"[1:35], 5003, "MSK");	// MTN-14781
	self.assertNotNull(bol);
	self.assertEqualMsg(bol.allBOLDtls.size, 3, "");
	self.assertEqualMsg(bol.allTrackedItems.size, 18, "");
	foreach ti in bol.allTrackedItems do
		self.assertEqualMsg(ti.billOfLading, "BOLVOYSHIPGENXX12345678901234567890", "ti bill of lading not as expected");
	endforeach;
	bol := self.getBOL("BOLVOYSHIPGENXX2", 5003, "MSK");
	self.assertNotNull(bol);
	self.assertEqualMsg(bol.allBOLDtls.size, 1, "");
	self.assertEqualMsg(bol.allTrackedItems.size, 8, "");
	bol := self.getBOL("BOLVOYSHIPGENXX3", 5003, "MSK");
	self.assertNotNull(bol);
	self.assertEqualMsg(bol.allBOLDtls.size, 1, "");
	self.assertEqualMsg(bol.allTrackedItems.size, 16, "");
	
	//09 Jun 2017	NDL	TFS 4331
	ti := voyage.allOnshipTIsByIdCargoType.getAtKey("ZGHJ8063793",1);
	self.assertNotNull(ti);
	self.assertTrueMsg( ti.clientRef = "12345", "clientRef should be '12345'");
	ti := voyage.allOnshipTIsByIdCargoType.getAtKey("XGHJ8063770",1);
	self.assertNotNull(ti);
	self.assertEqualMsg(ti.getSealNumShipper(), "SHSEAL1,SHSEAL2", "Incorrect Terminal Operator Seal");
	self.assertEqualMsg(ti.getPortOfOrigin(), "AUBNE", "Incorrect Port Of Origin");
	self.assertEqualMsg(ti.getContainerNumberText(), "Container Number Text Stuff", "Incorrect Container Number Text");
end;
</source>
    </JadeMethod>
    <JadeMethod name="tTransManifestTrainInt" id="5eabaf5f-ffbb-4ff9-9542-f3346dd4f713">
        <source>tTransManifestTrainInt();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 Dec 2023	jlirs1	TFS 59171 User Defined Transport Manifest 
14 Apr 2025	navdap1	MTN-14781 CPL| Increase BOL Field Length
*/
constants
	USER_DEF_NAME : String = "JMTInternalTransManifestTrain";
	TRAIN = "UT-TRAIN02";
vars
	ediFileObj : CM_EDIFile;
	ediDataObj : CM_EDIData;
	passportObj : CM_Passport;
	ti : CM_TrackedItem;
	ediText : String;
	errorMsg : String;
	wagon : CM_Wagon;
	train : CM_Train;
begin
	passportObj	:=	app.myPassport;
	train := self.getTrain(TRAIN, null);
	if train &lt;&gt; null then
		wagon := self.getWagon("UK1022", train);
		self.deleteTrainAndAssociatedObjs(train);
	endif;
	train := self.getTerminal.getNullTrain;
	wagon := self.getWagon("UK1022", train);
	self.deleteWagonAndAssociatedObjs(wagon);
	ediText :=
'
&lt;?xml version="1.0" encoding="UTF-8"?&gt;
&lt;JMTInternalTransManifest&gt;
	&lt;AllDataTransManifest&gt;
	&lt;DataTransManifest&gt;
		&lt;statusString&gt;Create&lt;/statusString&gt;
		&lt;guid&gt;"bd32cfne-24eb-495e-98d2-df19db66dd8&lt;/guid&gt;
		&lt;type&gt;TrainManifest&lt;/type&gt;
		&lt;manifestNumber&gt;Mannumber12345&lt;/manifestNumber&gt;
		&lt;receiver&gt;EBTA&lt;/receiver&gt;
		&lt;sender&gt;Sarge&lt;/sender&gt;
&lt;AllWagon&gt;
&lt;Wagon&gt;
&lt;cargoTypeDescr&gt;ISO Container&lt;/cargoTypeDescr&gt;
&lt;carrierCode&gt;ABC&lt;/carrierCode&gt;
&lt;id&gt;00000002&lt;/id&gt;
&lt;messageMode&gt;A&lt;/messageMode&gt;
&lt;trainCode&gt;UT-TRAIN02&lt;/trainCode&gt;
&lt;wagonClass&gt;UK&lt;/wagonClass&gt;
&lt;wagonNumber&gt;UK1022&lt;/wagonNumber&gt;
&lt;scheduledArrivalDT&gt;05 April 2010, 15:30:00&lt;/scheduledArrivalDT&gt;
&lt;/Wagon&gt;
&lt;/AllWagon&gt;
&lt;AllPrenote&gt;
&lt;Prenote&gt;
&lt;receiveDate&gt;11 August 2014&lt;/receiveDate&gt;
&lt;weight&gt;5000.0000&lt;/weight&gt;
&lt;packTempC&gt;-273&lt;/packTempC&gt;
&lt;packTempF&gt;-273&lt;/packTempF&gt;
&lt;bookingRef&gt;UT_BK_0013&lt;/bookingRef&gt;
&lt;cargoTypeDescr&gt;ISO Container&lt;/cargoTypeDescr&gt;
&lt;carrierCode&gt;ABC&lt;/carrierCode&gt;
&lt;commodity&gt;GENL&lt;/commodity&gt;
&lt;commodityDescription&gt;General&lt;/commodityDescription&gt;
&lt;consignee&gt;UTCC2&lt;/consignee&gt;
&lt;consignor&gt;ABCNR&lt;/consignor&gt;
&lt;customsSeal&gt;MAFSEAL&lt;/customsSeal&gt;
&lt;sealTerminalOperator&gt;TermOpSeal1&lt;/sealTerminalOperator&gt;
&lt;destinationPort&gt;AUBNE&lt;/destinationPort&gt;
&lt;dischargePort&gt;DEBRV&lt;/dischargePort&gt;
&lt;fullOrMT&gt;f&lt;/fullOrMT&gt;
&lt;id&gt;MAEU1111111&lt;/id&gt;
&lt;imexStatus&gt;Export&lt;/imexStatus&gt;
&lt;isoType&gt;2200&lt;/isoType&gt;
&lt;loadPort&gt;NZPOE&lt;/loadPort&gt;
&lt;messageMode&gt;A&lt;/messageMode&gt;
&lt;operatorCode&gt;UTOP&lt;/operatorCode&gt;
&lt;sealNum&gt;OPSEAL&lt;/sealNum&gt;
&lt;sealNumberVent&gt;VSEAL&lt;/sealNumberVent&gt;
&lt;AllSealDetails&gt;
&lt;SealDetails&gt;
&lt;sealEDIType&gt;SH&lt;/sealEDIType&gt;
&lt;sealEDINum&gt;SHSEAL1&lt;/sealEDINum&gt;
&lt;/SealDetails&gt;
&lt;SealDetails&gt;
&lt;sealEDIType&gt;SH&lt;/sealEDIType&gt;
&lt;sealEDINum&gt;SHSEAL2&lt;/sealEDINum&gt;
&lt;/SealDetails&gt;
&lt;/AllSealDetails&gt;
&lt;transportMode&gt;Rail&lt;/transportMode&gt;
&lt;totalQuantity&gt;1&lt;/totalQuantity&gt;
&lt;wagonNumber&gt;UK1022&lt;/wagonNumber&gt;
&lt;/Prenote&gt;
&lt;Prenote&gt;
&lt;receiveDate&gt;11 August 2014&lt;/receiveDate&gt;
&lt;weight&gt;5000.0000&lt;/weight&gt;
&lt;packTempC&gt;-273&lt;/packTempC&gt;
&lt;packTempF&gt;-273&lt;/packTempF&gt;
&lt;bookingRef&gt;UT_BK_0013&lt;/bookingRef&gt;
&lt;cargoTypeDescr&gt;ISO Container&lt;/cargoTypeDescr&gt;
&lt;carrierCode&gt;ABC&lt;/carrierCode&gt;
&lt;commodity&gt;GENL&lt;/commodity&gt;
&lt;commodityDescription&gt;General&lt;/commodityDescription&gt;
&lt;consignee&gt;UTCC2&lt;/consignee&gt;
&lt;consignor&gt;ABCNR&lt;/consignor&gt;
&lt;destinationPort&gt;AUBNE&lt;/destinationPort&gt;
&lt;dischargePort&gt;DEBRV&lt;/dischargePort&gt;
&lt;fullOrMT&gt;f&lt;/fullOrMT&gt;
&lt;id&gt;MAEU2222222&lt;/id&gt;
&lt;imexStatus&gt;Export&lt;/imexStatus&gt;
&lt;isoType&gt;2200&lt;/isoType&gt;
&lt;loadPort&gt;NZPOE&lt;/loadPort&gt;
&lt;messageMode&gt;A&lt;/messageMode&gt;
&lt;operatorCode&gt;UTOP&lt;/operatorCode&gt;
&lt;transportMode&gt;Rail&lt;/transportMode&gt;
&lt;totalQuantity&gt;1&lt;/totalQuantity&gt;
&lt;wagonNumber&gt;UK1022&lt;/wagonNumber&gt;
&lt;/Prenote&gt;
&lt;/AllPrenote&gt;
	&lt;/DataTransManifest&gt;
	&lt;/AllDataTransManifest&gt;
&lt;/JMTInternalTransManifest&gt;
';
//&lt;id&gt;MAEU1111111&lt;/id&gt;

	ediFileObj := self.ediLoadFileName(ediText, EDIFileType_Unknown, USER_DEF_NAME, USER_DEF_NAME&amp;method.name);

	self.assertNotNull(ediFileObj);
	self.assertEqualMsg(true, passportObj.allErrors.isEmpty(), passportObj.getAllErrorsWarningsAsString());	// cnwrl1 25/08/2010 PAR 25559
	self.assertNotNull(ediFileObj.ediData);		// cnwrl1 25/08/2010 PAR 25559
	self.ediVerify(ediFileObj);
	errorMsg := "Verify Failed" &amp; CrLf &amp; passportObj.getErrorsAsString();
	// Status 3 is verify status and 14 is verified with warnings.
//	self.assertIsOneOf(	ediFileObj.fileStatus,
//						errorMsg,
//						CM_EDIFile.EDI_STATUS_VERIFIED,
//						CM_EDIFile.EDI_STATUS_VERIFIED_WARNINGS);
	self.assertEqualMsg(ediFileObj.fileStatus, CM_EDIFile.EDI_STATUS_VERIFIED_WARNINGS, errorMsg);
	ediDataObj := ediFileObj.ediData;
	self.ediDBLoad(ediFileObj);
//	self.assertIsOneOf(	ediFileObj.fileStatus,
//						"Load Failed",
//						CM_EDIFile.EDI_STATUS_DBLOADED,
//						CM_EDIFile.EDI_STATUS_DBLOADED_PARTIAL);
	errorMsg := "DB Load Failed" &amp; CrLf &amp; passportObj.getErrorsAsString();
	self.assertEqualMsg(ediFileObj.fileStatus, CM_EDIFile.EDI_STATUS_DBLOADED, errorMsg);
	
	if ediFileObj.fileStatus = CM_EDIFile.EDI_STATUS_DBLOADED_PARTIAL then
		write "EDI message not fully loaded - needs a re-run.";
	endif;
	self.assertEqualMsg(ediDataObj.CM_EDIDataTransManifest.myTrainConsist.allEDITrackedItems.size, 10, "incorrect number of EDI trackedItems");
	ti := self.getTrackedItem("MAEU1111111");
	self.assertNotNull(ti);
	self.assertEqualMsg(ti.getSealNumTerminalOperator(), "TermOpSeal1", "Incorrect Terminal Operator Seal");
	self.assertEqualMsg(ti.getSealNumShipper(), "SHSEAL1,SHSEAL2", "Incorrect Terminal Operator Seal");
end;
</source>
