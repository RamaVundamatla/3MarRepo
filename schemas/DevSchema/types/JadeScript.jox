    <JadeMethod name="rh_testStringToStringArray1" id="f90a433c-e1ce-4c91-87f6-b2584d6738ec">
        <source>rh_testStringToStringArray1();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26 October 2016	cnwrh7	Initial creation

*/
constants 
	Delimiter  : String = " ";
vars
	weightDataString 			: String;
	weightDataString2			: String;
	weightDataStrArray 		: StringArray;
	weightByteArray 				: ByteArray;
	str											: String;
	int1											: Integer;
	int2										: Integer;
	int3										: Integer;
	weightDataBinary			: Binary;
	t 												: CMIF_IscaleWeightDataWrap;
	binaryA,binaryB,binaryC,binaryD				: Binary;
	weightDataReal				: Real;
	weightDataInKg 				: Decimal[15,3];
begin
	create weightDataStrArray transient;
	create weightByteArray transient;
	create t transient;
	weightByteArray.atPut(4, null);					//set the size
	weightDataString :=  "41 F1 AE 14";
	weightDataString.getTokensForDelimiter(" ",weightDataStrArray);
	
	int1 := 1;
	foreach str in weightDataStrArray do 
			write "str is &gt;&gt;" &amp; str;
			write "str to hexToInteger is &gt;&gt; " &amp; str.cnHexToInteger.String;
			//weightByteArray .atPut(int1,str.cnHexToInteger.Byte);
			weightByteArray .atPut(int1,str.asHex.Byte);
		//	write str.StringUtf8;
			int1 := int1 +1;
	endforeach;
	
	int2 :=1;																							//Binary Array
	while int2 &lt;= weightByteArray.size do
		weightDataBinary := weightDataBinary &amp; weightByteArray[int2].Binary;
			int2 := int2 +1;
	endwhile;
	
	int3 :=1;																							//Back to String
	while int3 &lt;= weightDataBinary.length do		
		write " weightDataBinary[0+int3: 1].String is &gt;&gt; " &amp; weightDataBinary[0+int3: 1].Byte.String;
		weightDataString2 := weightDataString2 &amp; weightDataBinary[0+int3: 1].asHex&amp; Delimiter;
		int3 := int3 +1 ;
	endwhile;
	write "weightDataString2 is &gt;&gt;" &amp; weightDataString2;
	weightDataReal :=  t.myWeightDataConvertion.convertFunction(weightDataString2.trimRight.StringUtf8);
	weightDataInKg := weightDataReal.Decimal *1000;
	write weightDataInKg;
epilog
	delete weightDataStrArray;
	delete weightByteArray;
	delete t;
end;</source>
    </JadeMethod>
    <JadeMethod name="rh_testStringToStringArray2" id="27f01399-8a0f-4b94-bc61-a39297c52552">
        <source>rh_testStringToStringArray2();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26 October 2016	cnwrh7	Initial creation

*/
constants 
	Delimiter  : String = " ";
vars
	weightDataString 			: String;
	weightDataString2			: String;
	weightDataStrArray 		: StringArray;
	weightByteArray 				: ByteArray;
	str											: String;
	int1											: Integer;
	int2										: Integer;
	int3										: Integer;
	weightDataBinary			: Binary;
	t 												: CMIF_IscaleWeightDataWrap;
	binaryA,binaryB,binaryC,binaryD				: Binary;
	weightDataReal				: Real;
	weightDataInKg 				: Decimal[15,3];
begin
	create weightDataStrArray transient;
	create weightByteArray transient;
	create t transient;
	weightByteArray.atPut(4, null);					//set the size
	weightDataString :=  "42 28 00 00";
	//weightDataString :=  "41 F1 AE 14";
	weightDataString.getTokensForDelimiter(" ",weightDataStrArray);
	
	int1 := 1;
	foreach str in weightDataStrArray do 
			write "str is &gt;&gt;" &amp; str;
			write "str to hexToInteger is &gt;&gt; " &amp; str.cnHexToInteger.String;
			//weightByteArray .atPut(int1,str.cnHexToInteger.Byte);
			weightByteArray .atPut(int1,str.cnHexToInteger.Byte);										//only Integer can cast to Byte
		//	write str.StringUtf8;
			int1 := int1 +1;
	endforeach;
	
	int2 :=1;																							//Binary Array
	while int2 &lt;= weightByteArray.size do	
		weightDataBinary := weightDataBinary &amp; weightByteArray[int2].Binary;							//Byte To Binary
			int2 := int2 +1;
	endwhile;
	
	int3 :=1;																							//Back to String
	while int3 &lt;= weightDataBinary.length do		
		write " weightDataBinary[0+int3: 1].String is &gt;&gt; " &amp; weightDataBinary[0+int3: 1].Byte.String;
		weightDataString2 := weightDataString2 &amp; weightDataBinary[0+int3: 1].asHex&amp; Delimiter;											//Binary to Hex String
		int3 := int3 +1 ;
	endwhile;
	write "weightDataString2 is &gt;&gt;" &amp; weightDataString2;
	weightDataReal :=  t.myWeightDataConvertion.convertFunction(weightDataString2.trimRight.StringUtf8);					//Get Real 
	weightDataInKg := weightDataReal.Decimal *1000;																																	//Get Decimal 
	write weightDataInKg;
epilog
	delete weightDataStrArray;
	delete weightByteArray;
	delete t;
end;</source>
    </JadeMethod>
    <JadeMethod name="rh_testTcpIpConnection" id="c01b339b-4185-4411-a9dd-318d92c55acc">
        <source>rh_testTcpIpConnection();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 October 2016	cnwrh7	Initial creation

*/


/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 March 2014	cnwndl1	Initial creation	Par 33268

*/

constants

//	WB1Address : String = "192.168.50.194:10001";
	//WB1Address : String = "143.96.129.49";
	//WB1Address : String = "jade1.cnwdmast.cnw.co.nz";			//works with this address
	WB1Address : String = "143.96.129.49";											//thin client computer address
//	WB1Address : String = "cnwrh7a.cnw.co.nz";

//	WB2Address : String = "192.168.50.195:10001";
	//WB2Address : String = "192.168.50.195";
	//RequestWeightString : String = "s" &amp; CrLf;
	RequestWeightBinary : Binary = #[73 0d 0a];// 15/3/16  cnwns1 PAR 36286 unicode version
	PortNumber : Integer = 80;
	//PortNumber : Integer = 52275;
	Timeout : Integer = 3000; //3 seconds
	
vars

	connection : TcpIpConnection;
	responseString : String;
	binResponse : Binary;

begin

	create connection;
	connection.name := WB1Address;
//	connection.name := "143.96.129.37";
	
	connection.port := PortNumber;
	//connection.port :=8080;
	connection.timeout := Timeout;
	connection.usePresentationClient := true;
	connection.open();
	
	if connection = null then
		responseString := "No connection";
		write responseString;
	elseif connection.state = TcpIpConnection.Connected then
		responseString :=  "Connected";
		write responseString;
	elseif connection.state = TcpIpConnection.Connecting then
		responseString :=  "Connecting";
		write responseString;
	elseif connection.state = TcpIpConnection.Disconnecting then
		responseString :=  "Disconnecting";
		write responseString;
	elseif connection.state = TcpIpConnection.Disconnected then
		responseString :=  "Disconnected";
		write responseString;
	else
		responseString := "invalid connection";
		write responseString;
	endif;
	
	connection.writeBinary(RequestWeightBinary);// 15/3/16  cnwns1 PAR 36286 unicode version
	
	binResponse := connection.readBinary(1000);
	responseString := binResponse.ansiToString();// 15/3/16  cnwns1 PAR 36286 unicode version

	
epilog

	if connection &lt;&gt; null then
		connection.close;
	endif;

	delete connection;

end;</source>
    </JadeMethod>
    <JadeMethod name="rh_testTimeMask" id="24e54584-f0fc-4dd6-958b-e15356fe3dd6">
        <source>rh_testTimeMask();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 November 2018	jlgrh7	Initial creation

*/

vars
	tmpTimeInfo	: TimeFormat;
	sep			: String;
	str			: String;
begin
		tmpTimeInfo := app.currentLocaleInfo.timeInfo;
	
	sep := tmpTimeInfo.separator;

	if 1=1  then
		str := 'hh' &amp; sep &amp; 'mm' &amp; sep &amp; 'ss';
	else
		str := 'hh' &amp; sep &amp; 'mm';
	endif;
	
	write str;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="rh_testVoyage" id="8b7930c4-498f-4c21-950d-276666fb8a80">
        <source>rh_testVoyage();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 May 2017	cnwrh7	Initial creation

*/

vars
	terminal 							: CM_Terminal;
	terminalCode 	    		: String;
	terminalArea			 		: CM_TerminalArea;
	areaView 						:CM_TerminalAreaView;
	areaViewPosition 		: CM_TerminalAreaViewPosition;
	locationsController		: CM_LocationsController;
	trackedItem					: CM_TrackedItem;
	
begin
	app.initialize;
	terminalCode := 'IMT';
	terminal := app.myRoot.allTerminals[terminalCode];
	foreach areaView in terminal.allTerminalAreaViews do
		if areaView.name = 'TERMINAL CNTRS' then
			foreach areaViewPosition in areaView.allTAPositionsByTA do
				terminalArea := areaViewPosition.myTerminalArea;
				foreach locationsController in terminalArea.allLocationsControllers do
					foreach trackedItem in locationsController.allTrackedItems do
						if trackedItem.myVoyage.code = '140442' then
							trackedItem.inspect();
						endif;
					endforeach;
				endforeach;
			endforeach;
		endif;
	endforeach;
epilog

end;</source>
    </JadeMethod>
