        <source>zJMT_To_CICS_1009(_protocol :String; _camGroup :CM_CamGroup; _start, _end :TimeStamp; _damage :String)protected;
/*
Date		Who		Reason
05/06/2012	cnwcs5	Initial creation - MES1006 - Receive Export GC (CAM Protocol 103_MSL Receipt GC Exports
*/
//22 Jan 2016	cnwrs1	37444 Use Cams controller rundate time rathyer than current date time
constants
	PREFIX 		= '1009';
	JRWREPORT	= 'CM_CamEditCargoRecord';
	FILTER		= QFCam_None;
vars
	desc		:CM_CamProtocolDesc;
	trxColl		:StringArray;
	filter		:CMQF_CamTransactionTemplate;
	protocol	:CM_CamProtocol;
	str			:String;
	theLines : HugeStringArray;
	runDateTime : TimeStamp;
begin
	create theLines transient;
	self.deleteCamProtocol (_protocol);
	
	desc 	:= CM_CamUserDefRepDesc.firstInstance;
	
	if FILTER &lt;&gt; null then
		filter	:= desc.CM_CamUserDefRepDesc.allQFCamTransactionTemplates[FILTER];
		
		self.assertNotNullMsg (filter, FILTER &amp; ' - CAM Filter not created');
	endif;
	
	create trxColl transient;
	
	trxColl.add (global.getTiTxnTypeForClass(CM_Edit).asStringJMT);
	
	protocol := self.createCamProtocol (_protocol, _camGroup, desc, PREFIX, JRWREPORT, trxColl, filter);
	
	self.assertNotNullMsg (protocol, _protocol &amp; ' - CAM protocol not created');
	self.assertEqual (protocol.jrwReportName, JRWREPORT);
	self.assertNotNull (protocol.myQFCamTransactionTemplate);
	self.assertEqual (protocol.myQFCamTransactionTemplate.queryDesc, FILTER);
	self.assertEqual (protocol.registeredTransactions.size, 1);
	
	self.runCamsAdhoc (_start, _end, runDateTime, protocol);
	
	self.assertNotNullMsg (protocol.taskHistoryByProtocolSeq.last, protocol.code &amp; ' No history');
	protocol.taskHistoryByProtocolSeq.last.rawDataToHSA(theLines);
	self.assertNotEqualMsg(theLines.size, 0, protocol.code &amp; ' No history');
	
	// expect MT releases by road/rail - must have consignee, have no booking
	// visit number impossible to match so replace with a constant
	//self.zReplaceFields (output, 6, '&lt;visitNumber&gt;');
	// dates are impossible to match so replace with a constant
	self.zReplaceFields(theLines, 3, '&lt;date&gt;');
	
	str := self.zCICS1009_output;
	
	str := str.replaceString('&lt;damage&gt;', _damage); 
app.writeLog("jlirs1 "&amp;class.name&amp;'::'&amp;method.name&amp;' '&amp;self.String, 0);	
	self.zCheckOutput(protocol, theLines, str);
epilog
	delete trxColl;
//	delete output;
	delete theLines;
end;</source>
