	self.assertTrueMsg(realCashPay &lt;&gt; null, "5.6 cashReceipt2 has no cash payment - 1");
	self.assertTrueMsg(realCashPay.myInvoiceLine = null, "5.6 Cashpayment 1 should NOT have an invoice line ");
	self.assertTrueMsg(realCashPay.myProformaDetail &lt;&gt; null, "5.6 Cashpayment 1 should have a proforma detail");
	self.assertTrueMsg(realCashPay.cashValue = 30.0, "5.6 OnsiteTi2 has wrong cash value is " &amp; realCashPay.cashValue.String);	
	
	
	tempID := _id2 &amp; "-01";
	onsiteTi2 := blockStack1.getTiById(tempID);
	allTisToMerge.add(onsiteTi2);
	self.assertTrueMsg(onsiteTi2 &lt;&gt; null, tempID &amp; " onsiteTi2 is null");
	self.assertTrueMsg(onsiteTi2.totalQuantity = 1, tempID &amp; " onsiteTi2 sbe 1");
	self.assertTrueMsg(onsiteTi2.totalVolume = 3.2069, tempID &amp; " onsiteTi2 sbe 3.2069 is " &amp; onsiteTi2.totalVolume.String);

	self.assertTrueMsg(onsiteTi2.invoiceLines.size = 1, tempID &amp; " onsiteTi2 should  have 1 invoice lines");
	self.assertTrueMsg(onsiteTi2.allCashPayments.size = 2, tempID &amp; " onsiteTi2 should have1 cash payment");	
	realCashPay := onsiteTi2.allCashPayments.last;
	self.assertTrueMsg(realCashPay &lt;&gt; null, "5.7 cashReceipt2 has no cash payment - 1");
	self.assertTrueMsg(realCashPay.myInvoiceLine = null, "5.7 Cashpayment 1 should NOT have an invoice line ");
	self.assertTrueMsg(realCashPay.myProformaDetail &lt;&gt; null, "5.7 Cashpayment 1 should have a proforma detail");
	self.assertTrueMsg(realCashPay.cashValue = 30.0, "5.7 OnsiteTi2 has wrong cash value is " &amp; realCashPay.cashValue.String);	
	
	tempID := _id2 &amp; "-02";
	onsiteTi2 := blockStack1.getTiById(tempID);
	allTisToMerge.add(onsiteTi2);
	self.assertTrueMsg(onsiteTi2 &lt;&gt; null, tempID &amp; " onsiteTi2 is null");
	self.assertTrueMsg(onsiteTi2.totalQuantity = 1, tempID &amp; " onsiteTi2 sbe 1");
	self.assertTrueMsg(onsiteTi2.totalVolume = 3.2069, tempID &amp; " onsiteTi2 sbe 3.2069 is " &amp; onsiteTi2.totalVolume.String);

	self.assertTrueMsg(onsiteTi2.invoiceLines.size = 1, tempID &amp; " onsiteTi2 should  have 1 invoice lines");
	self.assertTrueMsg(onsiteTi2.allCashPayments.size = 2, tempID &amp; " onsiteTi2 should have1 cash payment");	
	realCashPay := onsiteTi2.allCashPayments.last;
	self.assertTrueMsg(realCashPay &lt;&gt; null, "5.8 cashReceipt2 has no cash payment - 1");
	self.assertTrueMsg(realCashPay.myInvoiceLine = null, "5.8 Cashpayment 1 should NOT have an invoice line ");
	self.assertTrueMsg(realCashPay.myProformaDetail &lt;&gt; null, "5.8 Cashpayment 1 should have a proforma detail");
	self.assertTrueMsg(realCashPay.cashValue = 30.0, "5.8 OnsiteTi2 has wrong cash value is " &amp; realCashPay.cashValue.String);	
	
	tempID := _id2 &amp; "-03";
	onsiteTi2 := blockStack1.getTiById(tempID);
	allTisToMerge.add(onsiteTi2);
	self.assertTrueMsg(onsiteTi2 &lt;&gt; null, tempID &amp; " onsiteTi2 is null");
	self.assertTrueMsg(onsiteTi2.totalQuantity = 1, tempID &amp; " onsiteTi2 sbe 1");
	self.assertTrueMsg(onsiteTi2.totalVolume = 3.2069, tempID &amp; " onsiteTi2 sbe 3.2069 is " &amp; onsiteTi2.totalVolume.String);

	self.assertTrueMsg(onsiteTi2.invoiceLines.size = 1, tempID &amp; " onsiteTi2 should  have 1 invoice lines");
	self.assertTrueMsg(onsiteTi2.allCashPayments.size = 2, tempID &amp; " onsiteTi2 should have1 cash payment");	
	realCashPay := onsiteTi2.allCashPayments.last;
	self.assertTrueMsg(realCashPay &lt;&gt; null, "5.9 cashReceipt2 has no cash payment - 1");
	self.assertTrueMsg(realCashPay.myInvoiceLine = null, "5.9 Cashpayment 1 should NOT have an invoice line ");
	self.assertTrueMsg(realCashPay.myProformaDetail &lt;&gt; null, "5.9 Cashpayment 1 should have a proforma detail");
	self.assertTrueMsg(realCashPay.cashValue = 30.0, "5.9 OnsiteTi2 has wrong cash value is " &amp; realCashPay.cashValue.String);	
	
	
	// #### MERGE AGAIN
	app.myTrxUA.trxMergeBreakBulk(cashTI2.CM_Cargo,	//_targetTi : CM_BreakBulkGeneric;
										allTisToMerge,	//_allItemsToBeMerged : CM_TISet;
										app.myPassport	//_passport : CM_Passport input
										);
	
	self.assertNoTrxErrorsPassport("TRX ISSUE ON MERGE 3 ");
	
	onsiteTi2 := blockStack1.getTiById(_id2);
	self.assertTrueMsg(onsiteTi2 &lt;&gt; null, "Merged-3 OnsiteTi2 is null");
	self.assertTrueMsg(onsiteTi2.totalQuantity = 4, "Merged-3 OnsiteTi2 sbe 4");
	self.assertTrueMsg(onsiteTi2.invoiceLines.isNotEmpty(), "Merged-3 OnsiteTi2 should have invoice line");
	self.assertTrueMsg(onsiteTi2.invoiceLines.size = 1, "Merged-3 OnsiteTi2 should have 1 invoice line");
	invLine := onsiteTi2.invoiceLines.first;
	self.assertTrueMsg(invLine &lt;&gt; null, "Merged-3 OnsiteTi2 has no invoice line");
	self.assertTrueMsg(invLine.invoiceLineDesc.narration =  "UT_LneSplitCsh", "Merged-3 OnsiteTi2 has wrong invoice line type");
	self.assertTrueMsg(invLine.lineTotal = 369.430000, "Merged-3 OnsiteTi2 has wrong invoice line total - 2.2SA is " &amp; invLine.lineTotal.String);

	
	self.assertTrueMsg(onsiteTi2.invoiceLines.size = 1, tempID &amp; " onsiteTi2 should  have 1 invoice lines");
	self.assertTrueMsg(onsiteTi2.allCashPayments.size = 2, tempID &amp; " onsiteTi2 should have1 cash payment");	
	realCashPay := onsiteTi2.allCashPayments.last;
	self.assertTrueMsg(realCashPay &lt;&gt; null, "5.11 cashReceipt2 has no cash payment - 1");
	self.assertTrueMsg(realCashPay.myInvoiceLine = null, "5.11 Cashpayment 1 should NOT have an invoice line ");
	self.assertTrueMsg(realCashPay.myProformaDetail &lt;&gt; null, "5.11 Cashpayment 1 should have a proforma detail");
	self.assertTrueMsg(realCashPay.cashValue = 120.0, "5.11 OnsiteTi2 has wrong cash value is " &amp; realCashPay.cashValue.String);	
	self.assertTrueMsg(realCashPay.myProformaDetail.lineTotal = 120.0  , "5.11 Cashpayment proforma detail value is wrong, is " &amp; realCashPay.myProformaDetail.lineTotal.String);
	
	
epilog
	
	self.deleteCargo(_id2 &amp; "-01", ct);
	self.deleteCargo(_id2 &amp; "-02", ct);
	self.deleteCargo(_id2 &amp; "-03", ct);
	
	self.deleteCargo(_id1 &amp; "-01", ct);
	self.deleteCargo(_id1 &amp; "-02", ct);
	self.deleteCargo(_id1 &amp; "-03", ct);
	if allTisToMerge&lt;&gt; null then
		beginTransaction;
		allTisToMerge.purge;
		commitTransaction;
	endif;
	delete allTisToMerge;
	if agent1&lt;&gt; null then
		beginTransaction;
		agent1.allCashPayments.purge();
		commitTransaction;
	endif;
	if allAgents &lt;&gt; null then
		allAgents.purge();
	endif;
	delete allAgents;
	delete allTIs;
	delete invAssistant;
	delete newTiIds;
end;</source>
        <access>protected</access>
        <Parameter name="_id1" type="String"/>
        <Parameter name="_id2" type="String"/>
        <Parameter name="_drTerm1" type="CM_DebtorTerminal"/>
        <Parameter name="_type" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="cashTestMultipleReceipts9b" id="c318213a-cbaa-498c-b6db-f873ebc94823">
        <updating/>
        <source>cashTestMultipleReceipts9b(_id1 : String; _id2 : String; _drTerm1 : CM_DebtorTerminal; _type : Integer) updating, protected;
/*
Purpose - 	Test split and then merge of invoice lines and cash payments, with 1 invoice line having an overridden rate.

				Create cargo on ship (break bulk splittable) Splittable cargo quantity of 4, volume of 1012.8275 weight of 18143.68.
				transaction map has mapping for move from ship to yard and storage. 
				
				Discharge 1st item in 2 parts. so merges, will be 2 invoice lines
				override rate on one line
				Then Split into 4 parts, different IDs using SPLIT TRX
				Should be 2 invoice lines on each TI
				each invoice line shodul have a different rate and total
				Then Merge into 1 part, using MERGE TRX
				Should be 2 invoice lines
				each invoice line shodul have a different rate and total
				
				Create Cash Receipt for the 2 invoice lines
				Then Split TI into 4 parts, different IDs using SPLIT TRX
				Should be 2 invoice lines and 2 cash payments on each TI
				each invoice line shodul have a different rate and total
				Then Merge into 1 part, using MERGE TRX
				Should be 2 invoice lines and 2 cash payments
				each invoice line shodul have a different rate and total
	
				Who - NAVAB1
Date - 30JUN2025
ADO - JIRA 35213
*/

constants

vars
	now			: TimeStamp;
	cargoId		: String;
	msg			: String;
	invoiceEveryReceipt	: Boolean;
	
	cashReceipt1, cashReceipt2 : CM_CashReceipt;
	paymentMeth : CM_PaymentMethod;

	invAssistant	: Object;
	onsiteTi1,onsiteTi2,
	cashTI1, cashTI2	: CM_TrackedItem;

	nowDate,
	baseDate : Date;
	cashToPay,
	cashTotal	: Decimal[23,6];
	
	customsAgent	: CM_CustomsAgent;
	operator		: CM_Operator;
	debtor 		: CM_DebtorNode;
	
	allTIs 		: CM_TISet;
	type : CM_TerminalAreaType;
	blockStack1,
	blockStack2	: CM_BlockStack;
	allAgents		: ObjectArray;
	agent1	: CM_CashInvoiceProformaAgent;
	tempID : String;
	ct : CM_CargoType;
	port : CM_Port;
	invLine : CM_InvoiceLine;
	realCashPay, pxyCashPay : CM_CashPayment;
	newTiIds: StringArray;
	allTisToMerge : CM_TISet;
	newProfDetail : CM_ProformaDetails;
begin
	msg := method.name;
	if self.myTerminal.getConfig(CashInvoiceEveryReceipt).Boolean then
		invoiceEveryReceipt := true;
	endif;
	
	//self.myTerminal.setConfig(InvoiceRoundLineTotal,2);
	self.setTerminalConfig(InvoiceRoundLineTotal, 2);

	//self.assertTrueMsg(ct &lt;&gt; null, "Cargo Type 15104 - UTBY is null");
	if self.opts.includesKey("CargoType") then
		ct := self.opts.obj("CargoType").CM_CargoType;
	endif;
	self.assertNotNullMsg(ct, "Failed to get cargo Type");
	
	port := app.myRoot.allPorts["NZAKL"];
	self.assertTrueMsg(port &lt;&gt; null, "port is null");
	
	type := app.myRoot.allTerminalAreaTypes.getAtKey(1); // Block Stack
	blockStack1 := self.myTerminal.allTerminalAreasByTypeId.getAtKey( type.type, "UT_BS1").CM_BlockStack;
	self.assertTrueMsg(blockStack1 &lt;&gt; null, "Block Stack UT_BS1 not found...");
	blockStack2 := self.myTerminal.allTerminalAreasByTypeId.getAtKey( type.type, "UT_BS2").CM_BlockStack;
	self.assertTrueMsg(blockStack2 &lt;&gt; null, "Block Stack UT_BS2 not found...");
	// use an operator with a known non-cash debtor
	operator := self.getOperator("UTC1");
	if operator = null then
		operator := self.addOperatorSimple("UTC1", "Cash Test Operator");
	endif;
	
	self.deleteCargo(_id1 &amp; "-01", ct);
	self.deleteCargo(_id1 &amp; "-02", ct);
	self.deleteCargo(_id1 &amp; "-03", ct);
	cargoId := _id1;
	cashTI1 := self.createGCOnShipQWV(null,cargoId, ct,operator,  self.myVoyage,port , 18143.68, 13.000,4 );
	
	self.assertTrueMsg(cashTI1 &lt;&gt; null, "On Ship Cargo 1 '" &amp; cargoId &amp; "' not created...");
	self.assertTrueMsg(cashTI1.totalQuantity = 4,  "On Ship Cargo 1 '" &amp; cargoId &amp; "' wrong quantity SBE 4 is " &amp; cashTI1.totalQuantity.String);
	self.assertTrueMsg(cashTI1.totalVolume = 13,  "On Ship Cargo 1 '" &amp; cargoId &amp; "' wrong volume SBE 13 is " &amp; cashTI1.totalVolume.String);
	self.assertTrueMsg(cashTI1.totalWeight = 18143.68,  "On Ship Cargo 1 '" &amp; cargoId &amp; "' wrong weight SBE 18143.68 is " &amp; cashTI1.totalWeight.String);

	cargoId := _id2;
	cashTI2 := self.createGCOnShipQWV(null,cargoId, ct,operator,  self.myVoyage,port , 18143.68, 13,4 );
	
	self.assertTrueMsg(cashTI2 &lt;&gt; null, "On Ship Cargo 2 '" &amp; cargoId &amp; "' not created...");
	self.assertTrueMsg(cashTI2.totalQuantity = 4,  "On Ship Cargo 2 '" &amp; cargoId &amp; "' wrong quantity SBE 4 is " &amp; cashTI2.totalQuantity.String);
	self.assertTrueMsg(cashTI2.totalVolume = 13,  "On Ship Cargo 2 '" &amp; cargoId &amp; "' wrong volume SBE 13 is " &amp; cashTI2.totalVolume.String);
	self.assertTrueMsg(cashTI2.totalWeight = 18143.68,  "On Ship Cargo 2 '" &amp; cargoId &amp; "' wrong weight SBE 18143.68 is " &amp; cashTI2.totalWeight.String);
	
	
	customsAgent := app.myRoot.allCustomsAgents['UTCA1'];
	debtor := customsAgent.myDebtor;
	beginTransaction;
	cashTI1.setPropertyValue("myCustomsAgent",customsAgent);
	cashTI2.setPropertyValue("myCustomsAgent",customsAgent);
	commitTransaction;

	// ### MOVE 1/2
	self.opts.purge();
	self.opts.addAssoc("TotalQuantity",2); // Move part
	self.move(cashTI1, blockStack1);

	onsiteTi1 := blockStack1.getTiById(_id1);
	self.assertTrueMsg(onsiteTi1 &lt;&gt; null, "OnsiteTi1 is null");
	self.assertTrueMsg(onsiteTi1.totalQuantity = 2, "OnsiteTi1 sbe 2");
	self.assertTrueMsg(onsiteTi1.invoiceLines.isNotEmpty(), "OnsiteTi1 should have invoice line");
	self.assertTrueMsg(onsiteTi1.invoiceLines.size = 1, "OnsiteTi1 should have 1 invoice line");
	invLine := onsiteTi1.invoiceLines.first;
	self.assertTrueMsg(invLine &lt;&gt; null, "OnsiteTi1 has no invoice line");
	self.assertTrueMsg(invLine.invoiceLineDesc.narration =  "UT_LneSplitCsh", "OnsiteTi1 has wrong invoice line type");
	self.assertTrueMsg(invLine.lineTotal = 187.20000, "OnsiteTi1 has wrong invoice line total - 2.1SA is " &amp; invLine.lineTotal.String);


	// ### MOVE 2/2
	self.opts.purge();
	self.opts.addAssoc("TotalQuantity",2); // Move part
	self.move(cashTI1, blockStack1);
	
	self.assertTrueMsg(onsiteTi1 &lt;&gt; null, "OnsiteTi1 is null");
	self.assertTrueMsg(onsiteTi1.totalQuantity = 4, "OnsiteTi1 sbe 4");
	self.assertTrueMsg(onsiteTi1.invoiceLines.isNotEmpty(), "OnsiteTi1 should have invoice line");
	self.assertTrueMsg(onsiteTi1.invoiceLines.size = 2, "OnsiteTi1 should have 1 invoice line");
	invLine := onsiteTi1.invoiceLines.first;
	self.assertTrueMsg(invLine &lt;&gt; null, "OnsiteTi1 has no invoice line");
	self.assertTrueMsg(invLine.invoiceLineDesc.narration =  "UT_LneSplitCsh", "OnsiteTi1 has wrong invoice line type");
	self.assertTrueMsg(invLine.lineTotal = 187.20000, "OnsiteTi1 has wrong invoice line total - 2.2SA is " &amp; invLine.lineTotal.String);
	invLine := onsiteTi1.invoiceLines.last;
	self.assertTrueMsg(invLine &lt;&gt; null, "OnsiteTi1 has no invoice line");
	self.assertTrueMsg(invLine.invoiceLineDesc.narration =  "UT_LneSplitCsh", "OnsiteTi1 has wrong invoice line type");
	self.assertTrueMsg(invLine.lineTotal = 187.20000, "OnsiteTi1 has wrong invoice line total - 2.3SA is " &amp; invLine.lineTotal.String);
	
	self.setManualRate(invLine.charges.first, 30); // ##### OVERRIDE THE RATE on one line
	self.assertTrueMsg(invLine.lineTotal = 195.0000, "OnsiteTi1 has wrong invoice line total - 2.4SA is " &amp; invLine.lineTotal.String);
	
	// ###### SPLIT
	cashTI1 := onsiteTi1;
	create newTiIds transient;
	newTiIds.add(_id1 &amp; "-01");
	newTiIds.add(_id1 &amp; "-02");
	newTiIds.add(_id1 &amp; "-03");
	app.myTrxUA.trxSplitBreakBulkToNewID(	onsiteTi1.CM_Cargo,	//_sourceTi : CM_Cargo;
											newTiIds,	//_newTiIds : StringArray;
											1,	//_quantity : Integer;
											3.25,	// _weightOrVolume : Decimal;
											onsiteTi1.myOperator,	//_operator : CM_Operator;
											true,
											true,
											true,
											true,
											app.myPassport	//_passport : CM_Passport input
											);
	
	self.assertNoTrxErrorsPassport("TRX ISSUE ON SPLIT 1 ");

	create allTisToMerge transient;
	
	tempID := _id1;
	onsiteTi1 := blockStack1.getTiById(tempID);
	self.assertTrueMsg(onsiteTi1 &lt;&gt; null, tempID &amp; " OnsiteTi1 is null");
	self.assertTrueMsg(onsiteTi1.totalQuantity = 1, tempID &amp; " OnsiteTi1 sbe 2");
	self.assertTrueMsg(onsiteTi1.totalVolume = 3.25, tempID &amp; " OnsiteTi1 sbe 3.25 is " &amp; onsiteTi1.totalVolume.String);

	self.assertTrueMsg(onsiteTi1.invoiceLines.isNotEmpty(), tempID &amp; " OnsiteTi1 should have invoice line");
	self.assertTrueMsg(onsiteTi1.invoiceLines.size = 2, tempID &amp; " OnsiteTi1 should have 2 invoice lines");
	
	invLine := onsiteTi1.invoiceLines.first;
	self.assertTrueMsg(invLine &lt;&gt; null, "Merged OnsiteTi1 has no invoice line");
	self.assertTrueMsg(invLine.invoiceLineDesc.narration =  "UT_LneSplitCsh", "Merged OnsiteTi1 has wrong invoice line type");
	self.assertTrueMsg(invLine.lineTotal = 46.8, "Merged OnsiteTi1 has wrong invoice line total - 2.2DDA is " &amp; invLine.lineTotal.String);
	invLine := onsiteTi1.invoiceLines.last;
	self.assertTrueMsg(invLine &lt;&gt; null, "Merged OnsiteTi1 has no invoice line");
	self.assertTrueMsg(invLine.invoiceLineDesc.narration =  "UT_LneSplitCsh", "Merged OnsiteTi1 has wrong invoice line type");
	self.assertTrueMsg(invLine.lineTotal = 48.75, "Merged OnsiteTi1 has wrong invoice line total - 2.3DDA is " &amp; invLine.lineTotal.String);
	self.assertTrueMsg(invLine.totalAmount = 48.750, "Merged OnsiteTi1 has wrong invoice total amount - 2.4DDA is " &amp; invLine.totalAmount.String);
	self.assertTrueMsg(invLine.totalRate = 30, "Merged OnsiteTi1 has wrong invoice total rate - 2.5DDA is " &amp; invLine.totalAmount.String);
	
	
	
	
	
	
	tempID := _id1 &amp; "-01";
	onsiteTi1 := blockStack1.getTiById(tempID);
	allTisToMerge.add(onsiteTi1);
	self.assertTrueMsg(onsiteTi1 &lt;&gt; null, tempID &amp; " OnsiteTi1 is null");
	self.assertTrueMsg(onsiteTi1.totalQuantity = 1, tempID &amp; " OnsiteTi1 sbe 2");
	self.assertTrueMsg(onsiteTi1.totalVolume = 3.25, tempID &amp; " OnsiteTi1 sbe 3.25 is " &amp; onsiteTi1.totalVolume.String);

	self.assertTrueMsg(onsiteTi1.invoiceLines.isNotEmpty(), tempID &amp; " OnsiteTi1 should have invoice line");
	self.assertTrueMsg(onsiteTi1.invoiceLines.size = 2, tempID &amp; " OnsiteTi1 should have 2 invoice lines");
	
	tempID := _id1 &amp; "-02";
	onsiteTi1 := blockStack1.getTiById(tempID);
	allTisToMerge.add(onsiteTi1);
	self.assertTrueMsg(onsiteTi1 &lt;&gt; null, tempID &amp; " OnsiteTi1 is null");
	self.assertTrueMsg(onsiteTi1.totalQuantity = 1, tempID &amp; " OnsiteTi1 sbe 2");
	self.assertTrueMsg(onsiteTi1.totalVolume = 3.25, tempID &amp; " OnsiteTi1 sbe 3.25 is " &amp; onsiteTi1.totalVolume.String);

	self.assertTrueMsg(onsiteTi1.invoiceLines.isNotEmpty(), tempID &amp; " OnsiteTi1 should have invoice line");
	self.assertTrueMsg(onsiteTi1.invoiceLines.size = 2, tempID &amp; " OnsiteTi1 should have 2 invoice lines");
	
	tempID := _id1 &amp; "-03";
	onsiteTi1 := blockStack1.getTiById(tempID);
	allTisToMerge.add(onsiteTi1);
	self.assertTrueMsg(onsiteTi1 &lt;&gt; null, tempID &amp; " OnsiteTi1 is null");
	self.assertTrueMsg(onsiteTi1.totalQuantity = 1, tempID &amp; " OnsiteTi1 sbe 2");
	self.assertTrueMsg(onsiteTi1.totalVolume = 3.25, tempID &amp; " OnsiteTi1 sbe 3.25 is " &amp; onsiteTi1.totalVolume.String);

	self.assertTrueMsg(onsiteTi1.invoiceLines.isNotEmpty(), tempID &amp; " OnsiteTi1 should have invoice line");
	self.assertTrueMsg(onsiteTi1.invoiceLines.size = 2, tempID &amp; " OnsiteTi1 should have 2 invoice lines");
	
	invLine := onsiteTi1.invoiceLines.first;
	self.assertTrueMsg(invLine &lt;&gt; null, "Merged OnsiteTi1 has no invoice line");
	self.assertTrueMsg(invLine.invoiceLineDesc.narration =  "UT_LneSplitCsh", "Merged OnsiteTi1 has wrong invoice line type");
	self.assertTrueMsg(invLine.lineTotal = 46.8, "Merged OnsiteTi1 has wrong invoice line total - 2.2EEA is " &amp; invLine.lineTotal.String);
	invLine := onsiteTi1.invoiceLines.last;
	self.assertTrueMsg(invLine &lt;&gt; null, "Merged OnsiteTi1 has no invoice line");
	self.assertTrueMsg(invLine.invoiceLineDesc.narration =  "UT_LneSplitCsh", "Merged OnsiteTi1 has wrong invoice line type");
	self.assertTrueMsg(invLine.lineTotal = 48.75, "Merged OnsiteTi1 has wrong invoice line total - 2.3EEA is " &amp; invLine.lineTotal.String);
	self.assertTrueMsg(invLine.totalAmount = 48.750, "Merged OnsiteTi1 has wrong invoice total amount - 2.4EEA is " &amp; invLine.totalAmount.String);
	self.assertTrueMsg(invLine.totalRate = 30, "Merged OnsiteTi1 has wrong invoice total rate - 2.5EEA is " &amp; invLine.totalAmount.String);
	
	
	// #### MERGE
	app.myTrxUA.trxMergeBreakBulk(cashTI1.CM_Cargo,	//_targetTi : CM_BreakBulkGeneric;
										allTisToMerge,	//_allItemsToBeMerged : CM_TISet;
										app.myPassport	//_passport : CM_Passport input
										);
	
	self.assertNoTrxErrorsPassport("TRX ISSUE ON MERGE 1 ");

	onsiteTi1 := blockStack1.getTiById(_id1);
	self.assertTrueMsg(onsiteTi1 &lt;&gt; null, "Merged OnsiteTi1 is null");
	self.assertTrueMsg(onsiteTi1.totalQuantity = 4, "Merged OnsiteTi1 sbe 4");
	self.assertTrueMsg(onsiteTi1.invoiceLines.isNotEmpty(), "Merged OnsiteTi1 should have invoice line");
	self.assertTrueMsg(onsiteTi1.invoiceLines.size = 2, "Merged OnsiteTi1 should have 1 invoice line");
	invLine := onsiteTi1.invoiceLines.first;
	self.assertTrueMsg(invLine &lt;&gt; null, "Merged OnsiteTi1 has no invoice line");
	self.assertTrueMsg(invLine.invoiceLineDesc.narration =  "UT_LneSplitCsh", "Merged OnsiteTi1 has wrong invoice line type");
	self.assertTrueMsg(invLine.lineTotal = 187.20000, "Merged OnsiteTi1 has wrong invoice line total - 2.2SA is " &amp; invLine.lineTotal.String);
	invLine := onsiteTi1.invoiceLines.last;
	self.assertTrueMsg(invLine &lt;&gt; null, "Merged OnsiteTi1 has no invoice line");
	self.assertTrueMsg(invLine.invoiceLineDesc.narration =  "UT_LneSplitCsh", "Merged OnsiteTi1 has wrong invoice line type");
	self.assertTrueMsg(invLine.lineTotal = 195.00000, "Merged OnsiteTi1 has wrong invoice line total - 2.3SA is " &amp; invLine.lineTotal.String);
	self.assertTrueMsg(invLine.totalAmount = 195.00000, "Merged OnsiteTi1 has wrong invoice total amount - 2.4SA is " &amp; invLine.totalAmount.String);
	self.assertTrueMsg(invLine.totalRate = 30, "Merged OnsiteTi1 has wrong invoice total rate - 2.5SA is " &amp; invLine.totalAmount.String);
	
	
	
	
	
	cashTI1 := onsiteTi1;
	// back-date the transactions to get storage
	baseDate := nowDate - 20;
	self.setTransactionDate(cashTI1, baseDate);
	
	paymentMeth := app.myRoot.allPaymentMethods[PayMethName];
	if paymentMeth = null then
		paymentMeth := CM_PaymentMethod.firstInstance;
	endif;
	create allAgents transient;
	self.opts.purge();
	self.opts.addAssoc("UseProformaConfig",true);

	agent1 := self.createProformaAgent(now, cashTI1);
	allAgents.add(agent1);
	
	// first receipt is for the pro forma only
	//  deselect the invoice lines
	cashToPay := 0;
	cashTotal := 0;
	foreach invLine in cashTI1.invoiceLines discreteLock do
		cashToPay += invLine.lineTotal;
		cashTotal += invLine.lineTotal;
	endforeach;

	foreach invLine in cashTI1.invoiceLines discreteLock do
		create pxyCashPay transient;
		pxyCashPay.setPxyFromInvoiceLine(invLine);
		agent1.allCashPayments.add(pxyCashPay);
	endforeach;
	
	// ### CASH RECEIPT
	cashReceipt1 := self.createCashReceipt(_drTerm1, paymentMeth, cashToPay,cashTotal, allAgents );

	// ### Check cash payments are same as invoice lines				
	self.assertTrueMsg(cashReceipt1 &lt;&gt; null, msg &amp; " Cash Receipt 1 for on ship cargo not created...");
	self.assertTrueMsg(cashReceipt1.allCashPayments.isNotEmpty(), "cashReceipt1 should have payments");
	self.assertTrueMsg(cashReceipt1.allCashPayments.size = 2, "cashReceipt1 should have 1 payment");
	realCashPay := cashReceipt1.allCashPayments.first;
	self.assertTrueMsg(realCashPay &lt;&gt; null, "cashReceipt1 has no cash payment - 1");
	self.assertTrueMsg(realCashPay.myInvoiceLine &lt;&gt; null, "Cashpayment 1 should have an invoice line - 2.1");
	self.assertTrueMsg(realCashPay.cashValue = 187.20000, "OnsiteTi1 has wrong cash value - 2.1 is " &amp; realCashPay.cashValue.String);
	realCashPay := cashReceipt1.allCashPayments.last;
	self.assertTrueMsg(realCashPay &lt;&gt; null, "cashReceipt1 has no cash payment - 1");
	self.assertTrueMsg(realCashPay.myInvoiceLine &lt;&gt; null, "Cashpayment 1 should have an invoice line - 2.1");
	self.assertTrueMsg(realCashPay.cashValue = 195.00000, "OnsiteTi1 has wrong cash value - 2.1 is " &amp; realCashPay.cashValue.String);
	

	// ##### SPLIT AGAIN
	app.myTrxUA.trxSplitBreakBulkToNewID(	onsiteTi1.CM_Cargo,	//_sourceTi : CM_Cargo;
											newTiIds,	//_newTiIds : StringArray;
											1,	//_quantity : Integer;
											3.25,	// _weightOrVolume : Decimal;
											onsiteTi1.myOperator,	//_operator : CM_Operator;
											true,
											true,
											true,
											true,
											app.myPassport	//_passport : CM_Passport input
											);
	
	self.assertNoTrxErrorsPassport("TRX ISSUE ON SPLIT 2 ");

	beginTransaction;
	allTisToMerge.purge;
	commitTransaction;
	
	tempID := _id1;
	onsiteTi1 := blockStack1.getTiById(tempID);
	cashTI1 := onsiteTi1;
	self.assertTrueMsg(onsiteTi1 &lt;&gt; null, tempID &amp; " OnsiteTi1 is null");
	self.assertTrueMsg(onsiteTi1.totalQuantity = 1, tempID &amp; " OnsiteTi1 sbe 2");
	self.assertTrueMsg(onsiteTi1.totalVolume = 3.25, tempID &amp; " OnsiteTi1 sbe 3.25 is " &amp; onsiteTi1.totalVolume.String);

	self.assertTrueMsg(onsiteTi1.invoiceLines.isNotEmpty(), tempID &amp; " OnsiteTi1 should have invoice line");
	self.assertTrueMsg(onsiteTi1.invoiceLines.size = 2, tempID &amp; " OnsiteTi1 should have 2 invoice lines");
	invLine := onsiteTi1.invoiceLines.first;
	self.assertTrueMsg(invLine &lt;&gt; null, "Merged-2 OnsiteTi1 has no invoice line");
	self.assertTrueMsg(invLine.invoiceLineDesc.narration =  "UT_LneSplitCsh", "Merged-2 OnsiteTi1 has wrong invoice line type");
	self.assertTrueMsg(invLine.lineTotal = 46.8, "Merged-2 OnsiteTi1 has wrong invoice line total - 2.222SA is " &amp; invLine.lineTotal.String);
	invLine := onsiteTi1.invoiceLines.last;
	self.assertTrueMsg(invLine &lt;&gt; null, "Merged-2 OnsiteTi1 has no invoice line");
	self.assertTrueMsg(invLine.invoiceLineDesc.narration =  "UT_LneSplitCsh", "Merged-2 OnsiteTi1 has wrong invoice line type");
	self.assertTrueMsg(invLine.lineTotal = 48.75, "Merged-2 OnsiteTi1 has wrong invoice line total - 2.222SB is " &amp; invLine.lineTotal.String);
	
	self.assertTrueMsg(onsiteTi1.allCashPayments.isNotEmpty(), tempID &amp; " OnsiteTi1 should have cash payments");
	self.assertTrueMsg(onsiteTi1.allCashPayments.size = 2, tempID &amp; " OnsiteTi1 should have 2 cash payments");
	realCashPay := onsiteTi1.allCashPayments.last;
	self.assertTrueMsg(realCashPay &lt;&gt; null, "cashReceipt1 has no cash payment - 1");
	self.assertTrueMsg(realCashPay.myInvoiceLine &lt;&gt; null, "Cashpayment 1 should have an invoice line - 2.1");
	self.assertTrueMsg(realCashPay.cashValue = 48.75000, "OnsiteTi1 has wrong cash value - 2.SS is " &amp; realCashPay.cashValue.String);
	
	tempID := _id1 &amp; "-01";
	onsiteTi1 := blockStack1.getTiById(tempID);
	allTisToMerge.add(onsiteTi1);
	self.assertTrueMsg(onsiteTi1 &lt;&gt; null, tempID &amp; " OnsiteTi1 is null");
	self.assertTrueMsg(onsiteTi1.totalQuantity = 1, tempID &amp; " OnsiteTi1 sbe 2");
	self.assertTrueMsg(onsiteTi1.totalVolume = 3.25, tempID &amp; " OnsiteTi1 sbe 3.25 is " &amp; onsiteTi1.totalVolume.String);

	self.assertTrueMsg(onsiteTi1.invoiceLines.isNotEmpty(), tempID &amp; " OnsiteTi1 should have invoice line");
	self.assertTrueMsg(onsiteTi1.invoiceLines.size = 2, tempID &amp; " OnsiteTi1 should have 2 invoice lines");
	invLine := onsiteTi1.invoiceLines.first;
	self.assertTrueMsg(invLine &lt;&gt; null, "Merged-2 OnsiteTi1 has no invoice line");
	self.assertTrueMsg(invLine.invoiceLineDesc.narration =  "UT_LneSplitCsh", "Merged-2 OnsiteTi1 has wrong invoice line type");
	self.assertTrueMsg(invLine.lineTotal = 46.8, "Merged-2 OnsiteTi1 has wrong invoice line total - 2.23SA is " &amp; invLine.lineTotal.String);
	invLine := onsiteTi1.invoiceLines.last;
	self.assertTrueMsg(invLine &lt;&gt; null, "Merged-2 OnsiteTi1 has no invoice line");
	self.assertTrueMsg(invLine.invoiceLineDesc.narration =  "UT_LneSplitCsh", "Merged-2 OnsiteTi1 has wrong invoice line type");
	self.assertTrueMsg(invLine.lineTotal = 48.75, "Merged-2 OnsiteTi1 has wrong invoice line total - 2.23SB is " &amp; invLine.lineTotal.String);
	
	self.assertTrueMsg(onsiteTi1.allCashPayments.isNotEmpty(), tempID &amp; " OnsiteTi1 should have cash payments");
	self.assertTrueMsg(onsiteTi1.allCashPayments.size = 2, tempID &amp; " OnsiteTi1 should have 2 cash payments");
	realCashPay := onsiteTi1.allCashPayments.last;
	self.assertTrueMsg(realCashPay &lt;&gt; null, "cashReceipt1 has no cash payment - 1");
	self.assertTrueMsg(realCashPay.myInvoiceLine &lt;&gt; null, "Cashpayment 1 should have an invoice line - 2.1");
	self.assertTrueMsg(realCashPay.cashValue = 48.75000, "OnsiteTi1 has wrong cash value - 2.SwS is " &amp; realCashPay.cashValue.String);
	
	tempID := _id1 &amp; "-02";
	onsiteTi1 := blockStack1.getTiById(tempID);
	allTisToMerge.add(onsiteTi1);
	self.assertTrueMsg(onsiteTi1 &lt;&gt; null, tempID &amp; " OnsiteTi1 is null");
	self.assertTrueMsg(onsiteTi1.totalQuantity = 1, tempID &amp; " OnsiteTi1 sbe 2");
	self.assertTrueMsg(onsiteTi1.totalVolume = 3.25, tempID &amp; " OnsiteTi1 sbe 3.25 is " &amp; onsiteTi1.totalVolume.String);

	self.assertTrueMsg(onsiteTi1.invoiceLines.isNotEmpty(), tempID &amp; " OnsiteTi1 should have invoice line");
	self.assertTrueMsg(onsiteTi1.invoiceLines.size = 2, tempID &amp; " OnsiteTi1 should have 2 invoice lines");
	self.assertTrueMsg(onsiteTi1.allCashPayments.isNotEmpty(), tempID &amp; " OnsiteTi1 should have cash payments");
	self.assertTrueMsg(onsiteTi1.allCashPayments.size = 2, tempID &amp; " OnsiteTi1 should have 2 cash payments");
	
	tempID := _id1 &amp; "-03";
	onsiteTi1 := blockStack1.getTiById(tempID);
	allTisToMerge.add(onsiteTi1);
	self.assertTrueMsg(onsiteTi1 &lt;&gt; null, tempID &amp; " OnsiteTi1 is null");
	self.assertTrueMsg(onsiteTi1.totalQuantity = 1, tempID &amp; " OnsiteTi1 sbe 2");
	self.assertTrueMsg(onsiteTi1.totalVolume = 3.25, tempID &amp; " OnsiteTi1 sbe 3.25 is " &amp; onsiteTi1.totalVolume.String);

	self.assertTrueMsg(onsiteTi1.invoiceLines.isNotEmpty(), tempID &amp; " OnsiteTi1 should have invoice line");
	self.assertTrueMsg(onsiteTi1.invoiceLines.size = 2, tempID &amp; " OnsiteTi1 should have 2 invoice lines");
	self.assertTrueMsg(onsiteTi1.allCashPayments.isNotEmpty(), tempID &amp; " OnsiteTi1 should have cash payments");
	self.assertTrueMsg(onsiteTi1.allCashPayments.size = 2, tempID &amp; " OnsiteTi1 should have 2 cash payments");

	
	// #### MERGE AGAIN
	app.myTrxUA.trxMergeBreakBulk(cashTI1.CM_Cargo,	//_targetTi : CM_BreakBulkGeneric;
										allTisToMerge,	//_allItemsToBeMerged : CM_TISet;
										app.myPassport	//_passport : CM_Passport input
										);
	
	self.assertNoTrxErrorsPassport("TRX ISSUE ON MERGE 2 ");
	
	onsiteTi1 := blockStack1.getTiById(_id1);
	self.assertTrueMsg(onsiteTi1 &lt;&gt; null, "Merged-2 OnsiteTi1 is null");
	self.assertTrueMsg(onsiteTi1.totalQuantity = 4, "Merged-2 OnsiteTi1 sbe 4");
	self.assertTrueMsg(onsiteTi1.invoiceLines.isNotEmpty(), "Merged-2 OnsiteTi1 should have invoice line");
	self.assertTrueMsg(onsiteTi1.invoiceLines.size = 2, "Merged-2 OnsiteTi1 should have 1 invoice line");
	invLine := onsiteTi1.invoiceLines.first;
	self.assertTrueMsg(invLine &lt;&gt; null, "Merged-2 OnsiteTi1 has no invoice line");
	self.assertTrueMsg(invLine.invoiceLineDesc.narration =  "UT_LneSplitCsh", "Merged-2 OnsiteTi1 has wrong invoice line type");
	self.assertTrueMsg(invLine.lineTotal = 187.20000, "Merged-2 OnsiteTi1 has wrong invoice line total - 2.2SA is " &amp; invLine.lineTotal.String);
	invLine := onsiteTi1.invoiceLines.last;
	self.assertTrueMsg(invLine &lt;&gt; null, "Merged-2 OnsiteTi1 has no invoice line");
	self.assertTrueMsg(invLine.invoiceLineDesc.narration =  "UT_LneSplitCsh", "Merged-2 OnsiteTi1 has wrong invoice line type");
	self.assertTrueMsg(invLine.lineTotal = 195.000, "Merged-2 OnsiteTi1 has wrong invoice line total - 2.3SA is " &amp; invLine.lineTotal.String);

	
	self.assertTrueMsg(onsiteTi1.allCashPayments.isNotEmpty(), _id1 &amp; " 4.1 OnsiteTi1 should have cash payments");
	self.assertTrueMsg(onsiteTi1.allCashPayments.size = 2, _id1 &amp; " 4.1 OnsiteTi1 should have 2 cash payments");
	realCashPay := onsiteTi1.allCashPayments.first;
	self.assertTrueMsg(realCashPay &lt;&gt; null, " 4.1 cashReceipt1 has no cash payment - 1");
	self.assertTrueMsg(realCashPay.myInvoiceLine &lt;&gt; null, " 4.1 Cashpayment 1 should have an invoice line");
	self.assertTrueMsg(realCashPay.cashValue = 187.20000, " 4.1 OnsiteTi1 has wrong cash value is " &amp; realCashPay.cashValue.String);
	self.assertTrueMsg(realCashPay.cashValue = realCashPay.myInvoiceLine.lineTotal, " 4.2.1 OnsiteTi1 cash value does not equal invoice line total is " &amp; realCashPay.cashValue.String &amp; "/" &amp; realCashPay.myInvoiceLine.lineTotal.String);

	realCashPay := onsiteTi1.allCashPayments.last;
	self.assertTrueMsg(realCashPay &lt;&gt; null, " 4.2 cashReceipt1 has no cash payment - 1");
	self.assertTrueMsg(realCashPay.myInvoiceLine &lt;&gt; null, " 4.2 Cashpayment 1 should have an invoice line");
	self.assertTrueMsg(realCashPay.cashValue = 195.000000, " 4.2 OnsiteTi1 has wrong cash value is " &amp; realCashPay.cashValue.String);
	self.assertTrueMsg(realCashPay.cashValue = realCashPay.myInvoiceLine.lineTotal, " 4.2.2 OnsiteTi1 cash value does not equal invoice line total is " &amp; realCashPay.cashValue.String &amp; "/" &amp; realCashPay.myInvoiceLine.lineTotal.String);
	
	
	
	
epilog
	
	self.deleteCargo(_id2 &amp; "-01", ct);
	self.deleteCargo(_id2 &amp; "-02", ct);
	self.deleteCargo(_id2 &amp; "-03", ct);
	
	self.deleteCargo(_id1 &amp; "-01", ct);
	self.deleteCargo(_id1 &amp; "-02", ct);
	self.deleteCargo(_id1 &amp; "-03", ct);
	if allTisToMerge&lt;&gt; null then
		beginTransaction;
		allTisToMerge.purge;
		commitTransaction;
	endif;
	delete allTisToMerge;
	if agent1&lt;&gt; null then
		beginTransaction;
		agent1.allCashPayments.purge();
		commitTransaction;
	endif;
	if allAgents &lt;&gt; null then
		allAgents.purge();
	endif;
	delete allAgents;
	delete allTIs;
	delete invAssistant;
	delete newTiIds;
end;</source>
        <access>protected</access>
        <Parameter name="_id1" type="String"/>
        <Parameter name="_id2" type="String"/>
        <Parameter name="_drTerm1" type="CM_DebtorTerminal"/>
        <Parameter name="_type" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="cashTestNoCurrentCharges" id="d3f121f4-48d7-42ba-9d9f-fa52f1824ea3">
        <updating/>
        <source>cashTestNoCurrentCharges(_id : String; _drTerm1 : CM_DebtorTerminal; _truckOut : CM_Vehicle) updating, protected;

/*

Purpose:		Cash module testing, gate out a single item with storage is due and with one full payment.
				No current charges.
Parameters:			

Return Value:		


Date		Who		Reason
11/06/2014	cnwjre1	34378
28/11/2019	jlgsl4	TFS 47529 - JMT - Decimal Values on CM_CashReceipt, CM_CashPayment, CM_CashInvoiceProformaAgent
*/

constants

vars
	now			: TimeStamp;
	cargoId		: String;
	msg			: String;
	count		: Integer;
	
	drTerm1 : CM_DebtorTerminal;
	drTerm2 : CM_DebtorTerminal;
	
	cashReceipt : CM_CashReceipt;
	cashPaymentProForma : CM_CashPayment;
	cashPayment : CM_CashPayment;
	paymentMeth : CM_PaymentMethod;

	onsiteTi : CM_TrackedItem;
	trans	: CM_TITransaction;

	endDate : Date;
	cashToPay,
	cashTotal,
	cargoEstimatedCashCharges : Decimal[23,6];//[16, 6]; // TFS 47529
	cashInvoice	: CM_Invoice;
	invLine : CM_InvoiceLine;
	
	carrier : CM_Carrier;
	
	truckIn : CM_Vehicle;
	truckOut : CM_Vehicle;
	vvrIn : CM_VehicleVisitRecord;
	vvrOut : CM_VehicleVisitRecord;
	
	debtorType	: CM_DebtorType;
	cashInvType,
	invType			: CM_InvoiceDesc;
	invLineType1,
	invLineType2  	: CM_InvoiceLineDesc;
	customsAgent	: CM_CustomsAgent;
	operator		: CM_Operator;
	debtor 		: CM_DebtorNode;
	terminal	: CM_Terminal;
	
	allTIs 		: CM_TISet;
	allAgents		: ObjectArray;
	agent : CM_CashInvoiceProformaAgent;
	chequeBank : String;
	chequeBranch : String;
	chequeNumber : String;
	chequeDate : Date;
	cashId1,
	cashId2,
	cashId3,
	cashId4 : String;

	effectiveDate : Date;
	externalInvoiceNumber,
	externalReferenceNumber : String;
	
begin
	msg := method.name;

	truckOut := _truckOut;
	terminal := _drTerm1.myTerminal;
	//Now create onsite cargo that will be gated out by truck.
	cargoId := _id;
	onsiteTi := self.addOnsiteCargoForId(cargoId, false, 10);
	// has CM_Create, CM_Receive, CM_SubTermxxx
	// is Storage, FCL, operator UTCH, null voyage, no stops, no agent assigned, 
	beginTransaction;
	onsiteTi.setMyVoyage(self.myVoyage, app.myPassport);
	foreach trans in onsiteTi.allTransactions do
		trans.setPropertyValue("voyage", self.myVoyage);
		trans.setPropertyValue("voyageCode", self.myVoyage.code);
		trans.setPropertyValue("myVoyageRelivant", self.myVoyage);
	endforeach;
	commitTransaction;

	self.assertTrueMsg(onsiteTi &lt;&gt; null, msg &amp; " On Site Cargo '" &amp; cargoId &amp; "' not created...");

	create allTIs transient;
	allTIs.add(onsiteTi);
	debtorType := app.myRoot.allDebtorTypes["SDT6"];	// customs agent
	customsAgent := app.myRoot.allCustomsAgents['UTCA1'];
	debtor := customsAgent.myDebtor;
	self.applyAgentToCargo(allTIs, debtorType, customsAgent);

	create allAgents transient;
	agent := self.createProformaAgent(now, onsiteTi);
	allAgents.add(agent);
	self.myAgent := agent;
	
	cashTotal := agent.cashPayments;
	cashToPay := agent.invoicedCashCharges + agent.estimatedCashCharges - cashTotal;

	paymentMeth := app.myRoot.allPaymentMethods[PayMethName];
	if paymentMeth = null then
		paymentMeth := CM_PaymentMethod.firstInstance;
	endif;

	cashReceipt := self.createBOLCashReceipt(	paymentMeth,	// _payMeth : CM_PaymentMethod;
					cashToPay,				// _amount : Decimal;
					chequeBank,			// _chequeBank : String;
					chequeBranch,		// _chequeBranch : String;
					chequeNumber,		// _chequeNumber : String;
					chequeDate,			// _chequeDate : Date;
					cashId1,			// _cashId1,
					cashId2,			// _cashId2,
					cashId3,			// _cashId3,
					cashId4,			// _cashId4 : String;
					0,					// _payment1 : Decimal;
					0,					// _payment2 : Decimal;
					effectiveDate,		// _effectiveDate : Date;
					externalInvoiceNumber,	// _externalInvoiceNumber,
					externalReferenceNumber,	// _externalReferenceNumber : String;
					cashToPay,
					cashTotal,
					self.myVoyage,
					_drTerm1,			// _drTerm : CM_DebtorTerminal;
					0,
					0,
					0,
					null,
					allAgents,			// _agents : ObjectArray
					"",					// _taxCode1,
					"",					// _taxCode2,
					""					// _taxCode3: String
					);

	self.assertTrueMsg(cashReceipt &lt;&gt; null, msg &amp; " Cash Receipt for on site cargo not created...");

	foreach cashPayment in cashReceipt.allCashPayments do
		if cashPayment.isProformaPayment then
			cashPaymentProForma := cashPayment;
		endif;
	endforeach;
	self.assertTrueMsg(cashPaymentProForma &lt;&gt; null, msg &amp; " Cash Payment Pro Forma for on site cargo not created...");
	//self.allCashObjectsToCleanup.add( cashPaymentProForma );
	self.assertTrueMsg(not onsiteTi.allCashPayments.isEmpty, msg &amp; " Pro Forma not on On Site Cargo...");
	
	// Clear all the stops
	self.deleteStops(onsiteTi);

	vvrOut := createVVR( truckOut, onsiteTi );
	self.assertTrueMsg(vvrOut &lt;&gt; null, msg &amp; " Vehicle Visit Record not created...");
	
	self.gateInTruck( vvrOut, false );
	
	self.workTruck( vvrOut, 2 );
	
	// 34378 check that there are no cash-only debtor invoice lines before gate-out
	count := 0;
	foreach invLine in onsiteTi.invoiceLines where invLine.debtor.isCashOnlyDebtor(terminal) do
		if invLine.voided then
			continue;
		endif;
		count := count + 1;
	endforeach;
	assertEqualMsg(count, 0, msg &amp; " Pre-gate cash debtor invoice lines");

	self.gateOutTruck( vvrOut, false ); 

	count := 0;
	foreach cashPayment in onsiteTi.allCashPayments do
		if cashPayment.myCashPaymentForInvoice &lt;&gt; null then // TFS 7357 tax payment ignore
			continue;
		endif;
		count := count + 1;
		self.assertTrueMsg(not cashPayment.isProformaPayment, msg &amp; " " &amp; count.String &amp; " Cargo Cash Payment should NOT be a pro forma after gate out... " );
		if count = 1 then
			self.assertEqualMsg(cashPayment.cashValue, 20.Decimal, msg &amp; " " &amp; count.String &amp; " Cargo Cash payment value ");
		elseif count = 2 then
			self.assertEqualMsg(cashPayment.cashValue, 40.Decimal, msg &amp; " " &amp; count.String &amp; " Cargo Cash payment value ");
		else
			self.assertEqualMsg(cashPayment.cashValue, 60.Decimal, msg &amp; " " &amp; count.String &amp; " Cargo Cash payment value ");
		endif;
	endforeach;
	assertEqualMsg(count, 3, msg &amp; " Cargo cash payments");

	count := 0;
	foreach cashPayment in cashReceipt.allCashPayments do
		count := count + 1;
		self.assertTrueMsg(not cashPayment.isProformaPayment, msg &amp; " " &amp; count.String &amp; " Receipt Cash Payment should NOT be a pro forma after gate out... " );
		if count = 1 then
			self.assertEqualMsg(cashPayment.cashValue, 20.Decimal, msg &amp; " " &amp; count.String &amp; " Receipt Cash payment value ");
		elseif count = 2 then
			self.assertEqualMsg(cashPayment.cashValue, 40.Decimal, msg &amp; " " &amp; count.String &amp; " Receipt Cash payment value ");
		else
			self.assertEqualMsg(cashPayment.cashValue, 60.Decimal, msg &amp; " " &amp; count.String &amp; " Receipt Cash payment value ");
		endif;
	endforeach;
	assertEqualMsg(count, 3, msg &amp; " Receipt cash payments");
	
	cashInvoice := cashReceipt.myCashInvoice;
	count := 0;
	foreach invLine in cashInvoice.invoiceLines do
		count := count + 1;
		if count = 1 then
			self.assertEqualMsg(invLine.invoiceLineDesc.narration, "UT_ILT9", msg &amp; " " &amp; count.String &amp; " Invoice line type" );
			self.assertEqualMsg(invLine.lineTotal, 20.Decimal, msg &amp; " " &amp; count.String &amp; " Invoice line value ");
		elseif count = 2 then
			self.assertEqualMsg(invLine.invoiceLineDesc.narration, "UT_ILT10", msg &amp; " " &amp; count.String &amp; " Invoice line type" );
			self.assertEqualMsg(invLine.lineTotal, 40.Decimal, msg &amp; " " &amp; count.String &amp; " Invoice line value ");
		else
			self.assertEqualMsg(invLine.invoiceLineDesc.narration, "UT_ILT11", msg &amp; " " &amp; count.String &amp; " Invoice line type" );
			self.assertEqualMsg(invLine.lineTotal, 60.Decimal, msg &amp; " " &amp; count.String &amp; " Invoice line value ");
		endif;
	endforeach;
	assertEqualMsg(count, 3, msg &amp; " Receipt invoice lines");

epilog
	if allAgents &lt;&gt; null then
		allAgents.purge();
	endif;
	delete allAgents;
	delete allTIs;
	
end;</source>
        <access>protected</access>
        <Parameter name="_id" type="String"/>
        <Parameter name="_drTerm1" type="CM_DebtorTerminal"/>
        <Parameter name="_truckOut" type="CM_Vehicle"/>
    </JadeMethod>
    <JadeMethod name="cashTestOverPay1" id="0a62e570-9e72-4813-8a29-4979573fa520">
        <updating/>
        <source>cashTestOverPay1(_id : String; _drTerm1 : CM_DebtorTerminal; _truckOut : CM_Vehicle) updating, protected;

/*

Purpose:		Cash module testing, gate out a single item with storage is due and with two part payments.
				Storage charges are in more than one invoice line.
				The payments from the two receipts are split over the last invoice line.
				NOTE - this test is for storage charges, it is directly effected by free storage expiry configuration. 
							if there is a matching free storage in the UT terminal it will change the number of days and hence 
							the amount on the invoice and then this test will fail.
Parameters:			

Return Value:		


Date		Who		Reason
29/04/2014	cnwjre1	After par 33885

*/

constants

vars
/*
	now			: TimeStamp;
	moreNow		: TimeStamp;
	debtorName	: String;
	cargoId		: String;
	msg			: String;
	count		: Integer;
	
	drTerm1 : CM_DebtorTerminal;
	drTerm2 : CM_DebtorTerminal;
	
	cashReceipt1 : CM_CashReceipt;
	cashReceipt2 : CM_CashReceipt;
	cashReceipt : CM_CashReceipt;
	cashPaymentProForma : CM_CashPayment;
	cashPayment : CM_CashPayment;
	paymentMeth : CM_PaymentMethod;

	onsiteTi : CM_TrackedItem;
	trans	: CM_TITransaction;

	endDate : Date;
	cashToPay,
	cashTotal,
	cargoEstimatedCashCharges : Decimal [16,4];
	cashInvoice	: CM_Invoice;
	invLine : CM_InvoiceLine;
	
	carrier : CM_Carrier;
	
	truckIn : CM_Vehicle;
	truckOut : CM_Vehicle;
	vvrIn : CM_VehicleVisitRecord;
	vvrOut : CM_VehicleVisitRecord;
	
	debtorType	: CM_DebtorType;
	cashInvType,
	invType			: CM_InvoiceDesc;
	invLineType1,
	invLineType2  	: CM_InvoiceLineDesc;
	service			: CM_Service;
	customsAgent	: CM_CustomsAgent;
	operator		: CM_Operator;
	debtor 		: CM_DebtorNode;
	
	allTIs 		: CM_TISet;
	allAgents		: ObjectArray;
	agent : CM_CashInvoiceProformaAgent;
	chequeBank : String;
	chequeBranch : String;
	chequeNumber : String;
	chequeDate : Date;
	cashId1,
	cashId2,
	cashId3,
	cashId4 : String;
	payment1 : Decimal[16, 6];
	payment2 : Decimal[16, 6];
	effectiveDate : Date;
	externalInvoiceNumber,
	externalReferenceNumber : String;
	freestorageexpires : Date;
	receivedate : TimeStamp;
	freestoragedays : Integer;
	storagedetail : CM_StorageDetail;
	*/
begin



	// TFS 45953 - It is no longer possible to over pay for cash so this unit test is no longer relevant.
	
	return;




