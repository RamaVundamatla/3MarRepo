    <JadeMethod name="doAutoPlan" id="3947e46b-e876-4a50-bd00-993f089c56de">
        <updating/>
        <source>doAutoPlan() updating;
// ---------------------------------------------------------------------------
// Created:     June 2009 - form cloned from YRD_RailOpsForm and YRD_GridAreasForm
//
// Purpose:		
//
// Parameters:  
//
// Returns:     
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 23/06/2009	consw1		PAR 19913 - SFW1067 Rail Simplifications
// ---------------------------------------------------------------------------

vars

	str		: String;
	result	: Integer;
	ti		: CM_TrackedItem;
	params : CMIF_AutoplanParams;

begin

	create params transient;
	self.myCurrentSDF.getAllSelectedTIs(params.allTrackedItems);
	
	if params.allTrackedItems.isEmpty() then
		return;
	endif;
					
	params.moveMode := QUEUE_MODE;
	params.myTerminalArea := null;
	params.myJob := null;
	params.showWarningWhenNoPlan := true;
		
	while true do
		str := app.myTrxUA.trxUpdateAutoplanTrackedItems(params, app.myPassport);
		if app.myPassport.trxCompletedOK then
			global.beep;
			break;
		else
			result := app.showErrorWarningDialog(app.getErrorString(Move), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
				result = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		break;
	endwhile;	

epilog
	delete params;
end;</source>
    </JadeMethod>
