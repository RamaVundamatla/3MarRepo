        <updating/>
        <source>utlCreateEmailSendRequest(	_checkCanBeProcessed	: Boolean;
							_alertDescription,
							_toAddress,
							_fromAddress,
							_ccAddresses,
							_bccAddresses,
							_sendSubject,
							_sendMessage			: String;
							_allAttachedFilePaths	: HugeStringArray;
							_allFileData			: CM_FileDataStorageHdrSet input;							
							_blob					: Binary;
							_blobFileName			: String;
							_sourceOfEmail			: Integer;
							_updateCallbackObj		: Object;
							_passport 				: CM_Passport input) : Integer updating;


// cnwdvb1 10 February 2003 

vars

	email : BGP_EmailSendRequest;

begin
//write class.name&amp;'::'&amp;method.name&amp;' '&amp;_toAddress;
	app.myValCA.valEmailRequest(_alertDescription, _toAddress, _fromAddress, _passport);
	
	if not self.checkValidationWithPassport(_passport) then
		return null;
	endif;
	
	create email persistent;
	return email.initSendEmail(_checkCanBeProcessed, _alertDescription, _toAddress, _fromAddress, _ccAddresses, _bccAddresses, _sendSubject, _sendMessage,  _allAttachedFilePaths, _allFileData, _blob, _blobFileName, _sourceOfEmail,_updateCallbackObj);

end;</source>
