	inheritMethod();
	self.loadForm();
epilog
	app.mousePointer	:=	Idle;
end;</source>
    </JadeMethod>
    <JadeMethod name="loadForm" id="cda64687-d5d5-45f6-851f-7614b40d815a">
        <updating/>
        <source>loadForm()updating, protected;

vars
	baseRootObj			: CnEcBaseRoot;
	count				: Integer;
	xmlFormatCollObj	: CnEcXmlFormatDict;
	
begin
	baseRootObj	:=	app.myBaseRoot;

	self.centreWindow();
	
	lblSchemaName.caption := "for schema: " &amp; app.myCnEcXmlSchema.name;
	
	create xmlFormatCollObj transient;
	app.myBaseRoot.getAllFormatsForSchema(xmlFormatCollObj, app.myCnEcXmlSchema.name);
	
	if xmlFormatCollObj.size() = 0
	or baseRootObj.getXmlFormat(app.myCnEcXmlSchema.name, CNEC_DEFAULT_FULL) = null
	or baseRootObj.getXmlFormat(app.myCnEcXmlSchema.name, CNEC_DEFAULT_REF) = null
	then
		if baseRootObj.getAllXmlExcludedClasses() &lt;&gt; null and baseRootObj.getAllXmlExcludedClasses().size() &gt; 0 then
			self.createDefaultFormats();
		else
			write "Need to run 'Veto' form to create allExcludedClasses"; 		
		endif;
	endif;
	
	self.cmbOutputFormatsPopulate();
	self.clearExtrasPanel();
epilog 
	delete xmlFormatCollObj;	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="lstFormatAttribsPopulate" id="9466b8ae-e09f-4957-9f48-0ec0bd48add9">
        <updating/>
        <source>lstFormatAttribsPopulate() updating, protected;

vars
	formatObj			: CnEcXmlFormat;
	formatClassObj		: CnEcXmlFormatClass;
	formatPropertyObj	: CnEcXmlFormatProperty; 
	classObj	 		: Class;
	propertyCollObj		: PropertyColl;
	propertyObj 		: Property;
	deadObj				: Object;
	deadCollObj			: ObjectArray;
	methodObj			: Method;
	allMethodsObj		: MethodNDict;
	allParametersObj	: ParameterColl;
	
begin
	classObj	:= app.myCnEcXmlSchema.getClass(lstFormatClasses.text);
	formatObj	:= app.cnEcGetXmlFormat(cmbOutputFormats.text);
	
	if formatObj &lt;&gt; null then
		formatClassObj := formatObj.cnEcGetFormatClass(classObj.name);
	endif;

	lstFormatAttribs.clear();
	cmbEpiMethod.clear();
	cmbNoidProperty.clear();
	propertyCollObj	:=	classObj.allPropertiesUpTo(Object);
	
	foreach propertyObj in propertyCollObj do // all properties for the class and its superclass properties
		if propertyObj.getType = String then
			cmbNoidProperty.addItem(propertyObj.getName());
		elseif propertyObj.getType = Integer then
			cmbNoidProperty.addItem(propertyObj.getName());			
		elseif propertyObj.getType = Real then	//09 Sep 2014	NDL
			cmbNoidProperty.addItem(propertyObj.getName());			
		endif; 
	endforeach;
	
	delete propertyCollObj;
	
	create allMethodsObj transient;
	create allParametersObj transient;
	classObj.getMethods(allMethodsObj);
	
	foreach methodObj in allMethodsObj do
		allParametersObj.clear();
		methodObj.cnGetParameters.copy(allParametersObj);
		
		if allParametersObj.size() = 0 then
			cmbEpiMethod.addItem(methodObj.name);
		endif;
	endforeach;
			
	self.clearExtrasPanel();
	self.clearPropertyPanel();
	self.displayFormatClass();
	propertyCollObj	:=	classObj.allPropertiesUpTo(Object);
	
	foreach propertyObj in propertyCollObj do // all properties for the class and its superclass properties
		if app.isValidObject(formatClassObj) then							// if the formatclass has been set up
			formatPropertyObj := formatClassObj.getFormatProperty(propertyObj.getName()); // get the associated formatProperty 
		else	// create the formatClass
			beginTransaction;
			formatClassObj := self.createFormatClass(formatObj);
			lstFormatClasses.itemObject[lstFormatClasses.listIndex] := formatClassObj;
			lstFormatClasses.itemForeColor[lstFormatClasses.listIndex] := Blue;
			commitTransaction;		
		endif;
		
		lstFormatAttribs.itemObject[lstFormatAttribs.addItem(propertyObj.getName())] := formatPropertyObj; // add to list box and set the object.
		
		if lstFormatAttribs.itemObject[lstFormatAttribs.newIndex] = null then //set up the colours to represent the state of the object.
			lstFormatAttribs.itemForeColor[lstFormatAttribs.newIndex] := Red;
		else
			if formatPropertyObj.isShowTagData = true then
				lstFormatAttribs.itemForeColor[lstFormatAttribs.newIndex] := Blue;
			endif;	
		endif;	
	endforeach;
	
	delete propertyCollObj;
	create deadCollObj transient; //transient collection for any formatProperties that should be deleted.

	foreach formatPropertyObj in formatClassObj.allProperties do
		if 	formatPropertyObj.isKindOf(CnEcXmlFormatLiteral)
		or formatPropertyObj.isKindOf(CnEcXmlFormatMethod)
		then
			lstFormatAttribs.itemObject[lstFormatAttribs.addItem(formatPropertyObj.propertyName)] := formatPropertyObj;
			
			if formatPropertyObj.isShowTagData = true then
				lstFormatAttribs.itemForeColor[lstFormatAttribs.newIndex] := Blue;
			endif;
		else
			if lstFormatAttribs.findObject(formatPropertyObj) = -1 then	// This one used to be in the database, but property has been deleted
				deadCollObj.add(formatPropertyObj);
			endif;		
		endif;
	endforeach;

	foreach deadObj in deadCollObj do
		beginTransaction;
			delete deadObj;
		commitTransaction;
	endforeach; 

	btnAddLiteral.enabled	:= true;
	btnSample.enabled		:= true;
	btnAddMethod.enabled	:= true;
epilog
	delete deadCollObj;
	delete allMethodsObj;
	delete allParametersObj;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="lstFormatAttribs_click" id="fca0bb2a-d622-4eb0-acbe-51d842e59777">
        <controlMethod name="ListBox::click"/>
