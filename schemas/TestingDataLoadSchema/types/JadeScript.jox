    <JadeMethod name="reset43931" id="59dd447d-0dcd-4afa-9b1f-68e5599f7524">
        <source>reset43931();
/*

Purpose:			Reset 43931

Parameters:			

Return Value:		

Date		Who		Reason
04/04/2019	jlgmh5	Initial creation

*/

vars

	terminal				: CM_Terminal;
	dsl						: UT_DSL;
	ti						: Object;
	bs						: CM_BlockStack;
	operator				: CM_Operator;
	cont					: CM_TrackedItem;
	txn						: CM_TITransaction;
	voyage					: CM_Voyage;
	
	tisToDelete				: StringArray;
	tiSet					: CM_TISet;
	
	trackedItemId			: String;
		
begin	

	
	app.initialize();
	
	
	create dsl transient;
	dsl.setActiveProfileMDHONLY();
	
	/*****************************************************
	 * Terminal - TT1
	 *****************************************************/
	 
	 terminal := app.myRoot.allTerminals["TT1"];
	 if terminal = null then
		return;
	endif;
	
	dsl.opts.purge();
	dsl.opts.addAssoc("Terminal", terminal.code);
	
	app.myPassport.setMyTerminal(terminal);
	
	// get the user and set passport's myUser
	app.myPassport.setMyUserFromCode("SUPERUSER");
	
	// get the voyage
	voyage := dsl.getVoyage("MSCK000002");
	if voyage = null then
		app.writeLog("Unable to find Voyage - MSCK000002.  Exiting JadeScript...", LogINFO);
		write "Unable to find Voyage - MSCK000002.  Exiting JadeScript...";
		return;
	endif;
	
	// delete the tracked items
	create tisToDelete transient;
	tisToDelete.add("JLG43931013");
	tisToDelete.add("JLG4393101");
	tisToDelete.add("JLG43931");
	tisToDelete.add("JLGG4393101");
	
	create tiSet transient;
	
	foreach trackedItemId in tisToDelete do
		
		tiSet.clear();
		terminal.lookupAllTIsOfIdCargoType(trackedItemId, null, tiSet, false, false, null);
		
		if tiSet.isEmpty and trackedItemId.pos(".",1) &gt; 0 then
			ti := trackedItemId.asOid;
			if ti &lt;&gt; null and CM_TrackedItem.hasInstance(ti) then
				tiSet.add( ti.CM_TrackedItem );
			endif;
		endif;
		
		if not tiSet.isEmpty then
			dsl.deleteTrackedItem(tiSet.first, false);
		endif;	
		
	endforeach;
	
	// Create cargo on site
	bs := dsl.getTerminalArea("MKBS01").CM_BlockStack;
	if bs = null then
		app.writeLog("Unable to find Block Stack - MKBS03.  Exiting JadeScript...", LogINFO);
		write "Unable to find Block Stack - MKBS03.  Exiting JadeScript...";
		return;
	endif;
	
	operator := app.myRoot.allOperators["O439"];
	if operator = null then
		app.writeLog("Unable to find Operator - O439.  Exiting JadeScript...", LogINFO);
		write "Unable to find Operator - O439.  Exiting JadeScript...";
		return;
	endif;
	
	dsl.opts.purge();
	dsl.opts.addAssoc(UTTI_VoyageCode, voyage.code);
	dsl.opts.addAssoc(UTTI_TotalWeight, 2500.0000.Decimal);
	dsl.opts.addAssoc("ReceivedDate", "02/04/2019 00:10:00");
	dsl.opts.addAssoc("RecTransportMode", 3);
	dsl.opts.addAssoc("CamsDate", "02/04/2019 00:10:00");
	cont := dsl.addContainerAtLocation("JLG43931013", operator, "FLTP", "GEN", 1, bs);
	dsl.createTransaction(cont, global.getTiTxnTypeForClass(CM_ReleaseShip), "02/04/2019 00:50:00".TimeStamp);
	
	foreach txn in cont.allTransactions discreteLock do
	
		if not txn.isKindOf(CM_ReceiveShip) then
			continue;
		endif;
		
		beginTransaction;
		txn.setCAMSTimeStamp("02/04/2019 00:10:00".TimeStamp);
		txn.setPropertyValue("dateTime", "02/04/2019 00:10:00".TimeStamp);
		commitTransaction;
	
	endforeach;
	
	
	dsl.opts.purge();
	dsl.opts.addAssoc(UTTI_VoyageCode, voyage.code);
	dsl.opts.addAssoc(UTTI_TotalWeight, 2500.0000.Decimal);
	dsl.opts.addAssoc("ReceivedDate", "02/04/2019 01:10:00");
	dsl.opts.addAssoc("RecTransportMode", 3);
	dsl.opts.addAssoc("CamsDate", "02/04/2019 01:10:00");
	
	cont := dsl.addContainerAtLocation("JLG4393101", operator, "FLTP", "GEN", 1, bs);
	dsl.createTransaction(cont, global.getTiTxnTypeForClass(CM_ReleaseShip), "02/04/2019 01:50:00".TimeStamp);
	
	foreach txn in cont.allTransactions discreteLock do
	
		if not txn.isKindOf(CM_ReceiveShip) then
			continue;
		endif;
		
		beginTransaction;
		txn.setCAMSTimeStamp("02/04/2019 01:10:00".TimeStamp);
		txn.setPropertyValue("dateTime", "02/04/2019 01:10:00".TimeStamp);
		commitTransaction;
	
	endforeach;
	
	dsl.opts.purge();
	dsl.opts.addAssoc(UTTI_VoyageCode, voyage.code);
	dsl.opts.addAssoc(UTTI_TotalWeight, 2500.0000.Decimal);
	dsl.opts.addAssoc("ReceivedDate", "02/04/2019 02:10:00");
	dsl.opts.addAssoc("RecTransportMode", 3);
	dsl.opts.addAssoc("CamsDate", "02/04/2019 02:10:00");
	cont := dsl.addContainerAtLocation("JLG43931", operator, "TRAI", "GEN", 1, bs);
	dsl.createTransaction(cont, global.getTiTxnTypeForClass(CM_ReleaseShip), "02/04/2019 02:50:00".TimeStamp);
	
	foreach txn in cont.allTransactions discreteLock do
	
		if not txn.isKindOf(CM_ReceiveShip) then
			continue;
		endif;
		
		beginTransaction;
		txn.setCAMSTimeStamp("02/04/2019 02:10:00".TimeStamp);
		txn.setPropertyValue("dateTime", "02/04/2019 02:10:00".TimeStamp);
		commitTransaction;
	
	endforeach;
	
	dsl.opts.purge();
	dsl.opts.addAssoc(UTTI_VoyageCode, voyage.code);
	dsl.opts.addAssoc(UTTI_TotalWeight, 2500.0000.Decimal);
	dsl.opts.addAssoc("ReceivedDate", "02/04/2019 03:10:00");
	dsl.opts.addAssoc("RecTransportMode", 3);
	dsl.opts.addAssoc("CamsDate", "02/04/2019 03:10:00");
	cont := dsl.addContainerAtLocation("JLGG4393101", operator, "2200", "GEN", 1, bs);
	dsl.createTransaction(cont, global.getTiTxnTypeForClass(CM_ReleaseShip), "02/04/2019 03:50:00".TimeStamp);
	
	foreach txn in cont.allTransactions discreteLock do
	
		if not txn.isKindOf(CM_ReceiveShip) then
			continue;
		endif;
		
		beginTransaction;
		txn.setCAMSTimeStamp("02/04/2019 03:10:00".TimeStamp);
		txn.setPropertyValue("dateTime", "02/04/2019 03:10:00".TimeStamp);
		commitTransaction;
	
	endforeach;
	
	

epilog

	delete dsl;
	delete tisToDelete;
	delete tiSet;
	
end;
</source>
    </JadeMethod>
    <JadeMethod name="reset44201" id="0fdcdbc1-2da3-4fa8-b345-08584b6c715d">
        <source>reset44201();

/*

Purpose:	Reset 44201		

Date		Who		Reason
12/04/2019	jlgmk3	Initial creation

*/

vars
	terminal				: CM_Terminal;
	voyage					: CM_Voyage;
	dsl						: UT_DSL;
	iMove					: CM_InterTerminalMove;
	iConfig					: CM_InterTerminalConfig;
	ti						: Object;

	tisToDelete				: StringArray;
	tiSet					: CM_TISet;

	trackedItemId, bolNumber			: String;
begin
	app.initialize();
	
	create dsl transient;
	dsl.setActiveProfileMDHONLY();
	
	/*****************************************************
	 * Terminal - TT1
	 *****************************************************/
	 
	 terminal := app.myRoot.allTerminals["TT1"];
	 if terminal = null then
		return;
	endif;
	
	dsl.opts.purge();
	dsl.opts.addAssoc("Terminal", terminal.code);
	
	
	// delete the logs
	create tisToDelete transient;
	tisToDelete.add("LOG0");
	tisToDelete.add("LOG1");
	tisToDelete.add("LOG2");
	tisToDelete.add("LOG3");
	tisToDelete.add("LOG4");
	tisToDelete.add("LOG5");
	tisToDelete.add("LOG6");
	tisToDelete.add("LOG7");
	tisToDelete.add("LOG8");
	tisToDelete.add("LOG9");
	
	create tiSet transient;
	
	foreach trackedItemId in tisToDelete do
		
		tiSet.clear();
		terminal.lookupAllTIsOfIdCargoType(trackedItemId, null, tiSet, false, false, null);
		
		if tiSet.isEmpty and trackedItemId.pos(".",1) &gt; 0 then
			ti := trackedItemId.asOid;
			if ti &lt;&gt; null and CM_TrackedItem.hasInstance(ti) then
				tiSet.add( ti.CM_TrackedItem );
			endif;
		endif;
		
		if not tiSet.isEmpty then
			dsl.deleteTrackedItem(tiSet.first, false);
		endif;	
		
	endforeach;
	
	// delete BOL
	bolNumber := "BOL44201";
	dsl.deleteBOL(bolNumber, null);
	
	// delete voyage
	voyage := terminal.allVoyagesByCode.getAtKeyGeq("VOY44201", null);
	dsl.deleteVoyage(voyage.code);

epilog
	delete  dsl;
	delete tisToDelete;
	delete tiSet;
end;
</source>
    </JadeMethod>
