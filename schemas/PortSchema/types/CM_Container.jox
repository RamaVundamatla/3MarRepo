    <JadeMethod name="validateWeight" id="b87fc753-54fc-4257-8878-249392078d06">
        <updating/>
        <source>validateWeight(pControl : CMIF_TIUpdateController; _passport : CM_Passport input) updating, protected;
// ---------------------------------------------------------------------------
// Created:     04 January 2001 by cnwrs2
//
// Purpose:     This should be called after the id has been checked and
//				after the commodity has been checked.
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 18/05/2010	cnwcs5		par 24781 - tareWeight defaults on create now so there
//							is no need to default it as part of the validation
//							Also removed commented out code (see method history if u need it)
// ---------------------------------------------------------------------------
vars
	realTI 		: CM_TrackedItem;
	minWeight,
	maxWeight	: Integer;
	allowAutoReset : Boolean;
	child : CM_TrackedItem;
	measureType : CM_MeasurementType;
	weightConvertedStr : String;
begin

	if pControl.mode = TI_UPDMODE_RECEIPT or
		pControl.mode = TI_UPDMODE_BOOKINGREF then
		
		// Moved from able and still do checks even if no container number
		self.fieldIsNull(self.id, app.getString(Id), app.getString(Weight), pControl.myUserObject, _passport);
		
		if self.totalWeight &lt;&gt; NULL_WEIGHT then					//+cnwml2 MSL CCMS 1017
			self.validateMaxWeight(pControl);		//#27158 11/03/2011. Extra method organized to have weight validation coded in one place.
			self.validateWeightContRange(pControl);	//#27181 14/03/2011. Extra method organized to have weight validation from cont range coded in one place.
			self.validateCombindTareCargoWeight();									// + 18/03/2010 cnwmh5 #22546
			
			minWeight := self.myTerminal.getConfig(MinTIWeight).Integer;
			//if self.weight &lt; minWeight then										//-cnwml2 MSL CCMS 1017
			if self.totalWeight &lt; minWeight then									//+cnwml2 MSL CCMS 1017
				//app.raiseCMException2(VB_MIN_LIFT_WEIGHT, self.id, minWeight.String, ETRow_TotalWeight, pControl.myUserObject);
				//21 Oct 2013	NDL	Par 32624
				measureType := app.getDefaultMeasurementForType(Type_Weight);
				if measureType = null or measureType.isSameAsDatabaseValue then
					weightConvertedStr := null;
				else
					weightConvertedStr := measureType.getWeightConvertedStrForError( minWeight.Decimal );
				endif;
				app.raiseCMException3(VB_MIN_LIFT_WEIGHT, self.id, minWeight.String, weightConvertedStr, ETRow_TotalWeight, pControl.myUserObject);
			endif;
		else
			if self.totalWeight = NULL_WEIGHT and						//+cnwml2 MSL CCMS 1017
			   pControl.mode &lt;&gt; TI_UPDMODE_BOOKINGREF then
				// non-machinery items must have a weight				
				app.raiseCMException(Total_weight_should_not_zero, null, pControl.myUserObject);		// cnwdb2	PAR 35364
			endif;
		endif;
		
	elseif pControl.mode = TI_UPDMODE_NORMAL or // CCMS 1420
		   pControl.mode = TI_UPDMODE_TRANSHIP then	// 19/02/2010 cnwar2 #21962
		
		realTI := self.pxyGetRealObject();
		
		if self.totalWeight = NULL_WEIGHT then					//+cnwml2 MSL CCMS 1017
			if self.isNoInfo then
				// assume this is a no-info container and let weight check through???
			else
				//10 Dec 2012	NDL	Par 30845
				if not self.allChildren.isEmpty and (app.getMyUser.canDo(self.myTerminal, PmAdmWeightOverride)) then
					allowAutoReset := self.weightTare &gt; 0;
					if not allowAutoReset then
						foreach child in self.allChildren do
							if child.totalWeight &gt; 0 then
								allowAutoReset := true;
								break;
							endif;
						endforeach;
					endif;
					
				endif;
				
				
				if allowAutoReset then	//10 Dec 2012	NDL	Par 30845
					app.raiseCMWarning(Zero_value_recalculates, app.getString(Total_weight), null, self);
				else
					app.raiseCMException(Total_weight_should_not_zero, null, pControl.myUserObject);		// cnwdb2	PAR 35364
				endif;
			endif;
			
		endif;
		
		self.validateMaxWeight(pControl);		//#27158 11/03/2011. Extra method organized to have weight validation coded in one place.
		self.validateWeightContRange(pControl);	//#27181 14/03/2011. Extra method organized to have weight validation from cont range coded in one place.
		
	endif;

end;</source>
        <access>protected</access>
        <Parameter name="pControl" type="CMIF_TIUpdateController"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="validateWeightAgainstISOType" id="949f154f-a015-4d4f-b471-8724ba6db2d7">
        <source>validateWeightAgainstISOType(_raiseError : Boolean) protected;

// Created by cnwdvb1 on 11 December 2006
// 16/8/22 jlier1 TFS 54410 - changed from errors to warnings.
vars

	isoType 			: CM_ISOType;
	isoGroup			: CM_ISOTypeGroup;
	contentsStatus		: Integer;
	maxTotalWeight,	
	maxTareWeight,
	theTotalWeight		: Decimal[14,4];
	
begin

	isoType := self.getISOTypeObject();
	
	if isoType = null then
		return;
	endif;
	
	maxTotalWeight	:= isoType.maxTotalWeight;
	maxTareWeight	:= isoType.maxTareWeight;
	
	if maxTotalWeight = 0 and maxTareWeight = 0 then
		isoGroup := isoType.myISOTypeGroup;
		if isoGroup = null then
			return;
		endif;
		
		maxTotalWeight	:= isoGroup.maxTotalWeight;
		maxTareWeight	:= isoGroup.maxTareWeight;
		
	endif;
	
	if maxTotalWeight = 0 and maxTareWeight = 0 then
		return;
	endif;
	
	contentsStatus := self.getContentsStatus();
	
	theTotalWeight := self.totalWeight;
	
	if contentsStatus = TI_CONTENTS_STATUS_EMPTY then
		if (theTotalWeight &gt; maxTareWeight and maxTareWeight &lt;&gt; 0) then
				if _raiseError then
					app.raiseCMException1(WeightExceedsIsoLimits, theTotalWeight.asStringWeightJMT(),null,null);
				else
					app.raiseCMWarning1(WeightExceedsIsoLimits, theTotalWeight.asStringWeightJMT(),null,null,null);
				endif;
			return;
		endif;
	elseif contentsStatus = TI_CONTENTS_STATUS_FCL then
		if (theTotalWeight &gt; maxTotalWeight and maxTotalWeight &lt;&gt; 0) then
				if _raiseError then
					app.raiseCMException1(WeightExceedsIsoLimits, theTotalWeight.asStringWeightJMT(),null,null);
				else
					app.raiseCMWarning1(WeightExceedsIsoLimits, theTotalWeight.asStringWeightJMT(),null,null,null);
				endif;
			return;
		endif;
	elseif contentsStatus = TI_CONTENTS_STATUS_LCL then
		if (theTotalWeight &gt; maxTotalWeight and maxTotalWeight &lt;&gt; 0) then
				if _raiseError then
					app.raiseCMException1(WeightExceedsIsoLimits, theTotalWeight.asStringWeightJMT(),null,null);
				else
					app.raiseCMWarning1(WeightExceedsIsoLimits, theTotalWeight.asStringWeightJMT(),null,null,null);
				endif;
			return;
		endif;
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="_raiseError" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validateWeightContRange" id="93387d31-f241-4c0d-9352-eae9feb06403">
        <source>validateWeightContRange(_control : CMIF_TIUpdateController) protected;
/* ---------------------------------------------------------------------------
Created:	14 March 2011	by cnwvu1

Purpose:	#27181. Extra method organized to have weight validation coded in one place.
   
Change Date		Who		Reason
10 APR 2015     cnwma1  PAR #35906 Receiving back an Empty Container via the Road Gate
------------------------------------------------------------------------------*/
vars
	contRange	: CM_ContRange;
	lower,
	upper		: Decimal [16,4];
	measureType : CM_MeasurementType;
	lowerConverted : Decimal [20,10];
	upperConverted : Decimal [20,10];
	totalWeightConv : Decimal [20,10];

begin

	measureType := app.getDefaultMeasurementForType(Type_Weight);
	
	if self.totalWeight = NULL_WEIGHT then					//+cnwml2 MSL CCMS 1017
		return;
	endif;
	
	if app.isUnitTestGarbageCollect then
		return;
	endif;

	contRange := app.myRoot.lookupContainerRange(self.id);
	if contRange = null then
		return;
	endif;
	
	
	lower := contRange.tareKilos;
	upper := contRange.maxKilos + contRange.tareKilos;
	lowerConverted := app.convertMeasurementForDisplay(measureType.shortName, lower).Decimal;    		  // cnwma1 PAR #35906
	upperConverted := app.convertMeasurementForDisplay(measureType.shortName, upper).Decimal; 			  // cnwma1 PAR #35906
	totalWeightConv := app.convertMeasurementForDisplay(measureType.shortName, self.totalWeight).Decimal; // cnwma1 PAR #35906 
	
	/*if lower &lt;&gt; NULL_WEIGHT and       // - cnwma1 PAR #35906
	   upper &lt;&gt; NULL_WEIGHT and
	   ( self.totalWeight &lt; lower or (self.totalWeight &gt; upper and upper &gt; 0) ) then								//+cnwml2 MSL CCMS 1017
		app.raiseCMException3(VB_WEIGHT_RANGE, self.id, lower.String, upper.String, app.getString(Weight), _control.myUserObject);
	endif;*/
	
	if lowerConverted &lt;&gt; NULL_WEIGHT and  // cnwma1 PAR #35906
	   upperConverted &lt;&gt; NULL_WEIGHT and
	   ( totalWeightConv &lt; lowerConverted or (totalWeightConv &gt; upperConverted and upperConverted &gt; 0) ) then							
		app.raiseCMException3(VB_WEIGHT_RANGE, self.id, lowerConverted.String, upperConverted.String, app.getString(Weight), _control.myUserObject);
	endif;

end;</source>
        <access>protected</access>
        <Parameter name="_control" type="CMIF_TIUpdateController"/>
    </JadeMethod>
    <JadeMethod name="validateWeightEDI" id="5fdb01f4-437e-4ed9-8858-e7d18f04c3b6">
        <updating/>
        <source>validateWeightEDI( _control : CMIF_TIUpdateController ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 November 2013	cnwndl1	Initial creation	Par 32931
11 Sep 2018	jlgrh7 	TFS40448 	PEN - Weight Conversion Issue
*/
constants
	Kg = "kg";
vars

	isoTypeObj : CM_ISOType;
	isoGroup : CM_ISOTypeGroup;
	maxTotalWeight : Decimal[14,4];
	tareWeight : Decimal[14,4];
	totalWeightStr : String;
	tareWeightStr : String;
	onShip : Boolean;
	kgMeasurementType : CM_MeasurementType;
	roundedKgWeight : Decimal[14,4];			
begin
	kgMeasurementType := app.myRoot.allMeasurementTypesByShortName[Kg];			//+TFS40448

	isoTypeObj := self.getISOTypeObject();
	if isoTypeObj = null then
		return;
	endif;
	
	maxTotalWeight	:= isoTypeObj.maxTotalWeight;
	tareWeight	:= isoTypeObj.tareKilos;
	
	if maxTotalWeight = 0 then
		isoGroup := isoTypeObj.myISOTypeGroup;
		if isoGroup &lt;&gt; null then
			maxTotalWeight	:= isoGroup.maxTotalWeight;
		endif;
	endif;
	
	if maxTotalWeight &gt; 0 then
		if self.totalWeight &gt; maxTotalWeight then
			totalWeightStr := self.totalWeight.asStringWeightJMT();
			app.raiseCMException1(WeightExceedsIsoLimits, totalWeightStr, "weight", null);
		endif;
	endif;
	
	if tareWeight &gt; 0 then
		if kgMeasurementType &lt;&gt; null then																																//+TFS40448 round the kg totalweight to the Kg's measurement types format
			roundedKgWeight := self.totalWeight.roundedTo(kgMeasurementType.getDecimalPrecision);
			self.setTotalWeightWithoutTrans(roundedKgWeight);
		endif;
		if self.totalWeight &lt; tareWeight then
			totalWeightStr := self.totalWeight.asStringWeightJMT();
			tareWeightStr := tareWeight.asStringWeightJMT();
			if _control &lt;&gt; null and _control.mode = TI_UPDMODE_BAYPLAN then		//24 Jun 2015	NDL	Par 36515
				onShip := true;
			endif;
			if onShip and self.dischargePort &lt;&gt; self.myTerminal.getConfig(PortDestCode).String then	//24 Jun 2015	NDL	Par 36515	 Its considered to be a remain on board
				app.raiseCMWarning3(Total_weigh_not_less_than_tare, totalWeightStr, "(" &amp; self.isoType &amp; ")", tareWeightStr, "weight", null, null);
			else
				app.raiseCMException3(Total_weigh_not_less_than_tare, totalWeightStr, "(" &amp; self.isoType &amp; ")", tareWeightStr, "weight", null);
			endif;
		endif;
	endif;

epilog

end;</source>
        <Parameter name="_control" type="CMIF_TIUpdateController"/>
    </JadeMethod>
