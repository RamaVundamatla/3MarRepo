    <JadeMethod name="setupConsumerInstance" id="add7cb3d-f0ab-4930-b969-8d9e2d4c9cc0">
        <updating/>
        <source>setupConsumerInstance(_consumerClass : Class) updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 Feb 2019	jlgsl4	TFS 40360 - NXL - KiwiRail EDI message

*/

vars
	defaultBaseEndpoint, newEndpoint : String;
begin
	if self.myWebServiceConsumer = null or not self.myWebServiceConsumer.isKindOf(_consumerClass) then
		delete self.myWebServiceConsumer;
		create self.myWebServiceConsumer as _consumerClass transient;

		if self.baseEndpoint &lt;&gt; null then
			// Setup the Endpoint URL using the current baseEndpoint
			defaultBaseEndpoint	:= self.getDefaultBaseEndpoint();
		
			newEndpoint := self.myWebServiceConsumer.getEndpointURL();
			newEndpoint := newEndpoint.replace(defaultBaseEndpoint, self.baseEndpoint);
		
			self.myWebServiceConsumer.setEndpointURL(newEndpoint);
		endif;
		app.writeLog(method.qualifiedName &amp; " consumer " &amp; self.myWebServiceConsumer.String &amp;
					   " created, endpointURL is " &amp; self.myWebServiceConsumer.getEndpointURL(), LogDEBUG);	//25 Nov 2019	NDL	TFS 47053

	endif;	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_consumerClass" type="Class"/>
    </JadeMethod>
    <JadeMethod name="setupFromWebServiceDefinition" id="90bba565-c318-4174-8465-18ea37a4d2a0">
        <updating/>
        <source>setupFromWebServiceDefinition(_definition: CM_KiwiRailCheckInWSDef) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 Mar 2019	jlgsl4	TFS 40360 - NXL - KiwiRail EDI message

*/

vars

begin
	inheritMethod(_definition);
	myWebserviceDef := _definition; // for access to configured values for &lt;metadata&gt; and &lt;checkIn&gt;
epilog

end;</source>
        <Parameter name="_definition" type="CM_KiwiRailCheckInWSDef"/>
    </JadeMethod>
