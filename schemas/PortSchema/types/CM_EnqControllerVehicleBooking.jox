    <JadeMethod name="doQuery" id="4fe50b69-fc24-4c80-8f09-891dde9b5e10">
        <updating/>
        <source>doQuery(_qDef: CM_QueryDefinition) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 May 2023 navlw1 	ChangeRequest 53902: EUP - VBS MTN - [6] - Selector Query and JRW

*/

vars
	now			: TimeStamp;
	crit		: CM_SelectorCriteriaLine;
	termSet		: CM_TerminalSet;
	ut			: CM_UserTerminal;
	term		: CM_Terminal;
	woId, 
	idSearchOp  : String;
	state 	    : Integer;
	days        : Integer;
begin
	self.reset();
	now := app.actualTimeServer();
	
	//date time stuff
	crit := self.myCriteriaLineHolder.allCriteriaByPropertyName[CM_VehicleBookingTimeSlot::bookingTSstart.name, _qDef.className];
	if crit &lt;&gt; null then
		if crit.myQueryOperator.isKindOf(CM_QDateEquals) then
			self.startDateTime := crit.myQueryOperator.getSearchValue().TimeStamp;
			self.endDateTime := crit.myQueryOperator.getSearchValue().TimeStamp;
			self.endDateTime.setTime('23:59:59:999'.Time);
		elseif crit.myQueryOperator.isKindOf(CM_QDateGreaterThan) then
			self.startDateTime := crit.myQueryOperator.getSearchValue().TimeStamp;
			self.endDateTime := now;
		elseif crit.myQueryOperator.isKindOf(CM_QDateLessThan) then
			self.endDateTime := crit.myQueryOperator.getSearchValue().TimeStamp;
			self.endDateTime.setTime('23:59:59:999'.Time);
			self.startDateTime := null;
		elseif crit.myQueryOperator.isKindOf(CM_QDateRange) then
			self.startDateTime := crit.myQueryOperator.CM_QDateRange.getSearchValueFromDate().TimeStamp;
			self.endDateTime := crit.myQueryOperator.CM_QDateRange.getSearchValueToDate().TimeStamp;
			self.endDateTime.setTime('23:59:59:999'.Time);
		elseif crit.myQueryOperator.isKindOf (CM_QDateDayEquals) then  
			if crit.myQueryOperator.getSearchValue() &lt;&gt; null then
				days := crit.myQueryOperator.getSearchValue().Integer;
				self.startDateTime.setDate( app.actualTimeServer.date.addDays(-days));
				self.startDateTime.setTime('00:00:00:000'.Time);
			else
				self.startDateTime :=  app.actualTimeServer;
				self.startDateTime.setTime('00:00:00:000'.Time);
			endif;
		endif;
	endif;
	
	create termSet transient;	
	crit := self.myCriteriaLineHolder.allCriteriaByPropertyName[CM_VehicleBookingTimeSlot::myTerminal.name, _qDef.className];
	if crit &lt;&gt; null then
		crit.myQueryOperator.getSearchValueAsObjectSet(termSet);
	else
		foreach ut in app.myPassport.myUser.allUserTerminals do
			termSet.add(ut.getMyTerminal);
		endforeach;
	endif;
	
	foreach term in termSet discreteLock do
		self.myTerminal := term;
		self.doSearch();
	endforeach;
epilog
	endLoad;
	delete termSet;
end;</source>
        <Parameter name="_qDef" type="CM_QueryDefinition"/>
    </JadeMethod>
    <JadeMethod name="doSearch" id="418609b9-80b6-4634-9e5d-f6849f17e582">
        <updating/>
        <source>doSearch() updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 May 2023 navlw1 	ChangeRequest 53902: EUP - VBS MTN - [6] - Selector Query and JRW

*/

vars
	passport 		: CM_Passport;
	transObj		: CM_VehicleBookingTimeSlot;
	iteratorObj		: Iterator;
	keyTimeStamp	: TimeStamp;
	keyType			: Integer;
	breakOut		: Boolean;
begin
	passport := app.myPassport;
	iteratorObj	:=	myTerminal.myVehicleBookingTerminal.allBookingsByTS.createIterator();
	
	myTerminal.myVehicleBookingTerminal.allBookingsByTS.startKeyGeq(self.startDateTime, self.endDateTime, iteratorObj);

	while iteratorObj.next(transObj) do
		iteratorObj.getCurrentKeys(keyTimeStamp);
		
		if (self.endDateTime &lt;&gt; null and keyTimeStamp &gt; self.endDateTime) then
			break;
		endif;
		
		if self.includesObject(transObj, breakOut, passport) then
			self.addObjectToSet(transObj);
		endif;
			
		if breakOut or self.breakOutOfSearch then
			break;
		endif;
	endwhile;
	
epilog
	delete iteratorObj;
end;
</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setMyFilterClass" id="a3b084ab-2a0e-4036-a96e-e3ed88a4967f">
