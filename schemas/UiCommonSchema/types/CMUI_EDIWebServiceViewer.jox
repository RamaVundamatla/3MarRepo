    <JadeMethod name="addToolbarControls" id="80e64275-a966-49b2-b262-ca96b72460ba">
        <updating/>
        <source>addToolbarControls() updating, protected;
/*****************************************************
Author		: jlgka1 (Karen Alexander)
Date		: 02 September 2019
TFS#		: 45332
Function	:

*** Changes ***
Date			Name		TFS#		Description

****************************************************/
vars
	toolbar			: CMUI_Toolbar;
	showCaptions	: Boolean;
begin
	inheritMethod();

	toolbar 		:= self.frmToolbar;
	showCaptions	:= toolbar.showCaptions;
	
	if not self.btnShowSearcher.isAddedToToolbar then	
		toolbar.addButton(self.btnShowSearcher, CMUI_Toolbar.Control_Alignment_Left);
	endif;
	
	if not self.btnMonitoringOnOff.isAddedToToolbar then	
		toolbar.addButton(self.btnMonitoringOnOff, CMUI_Toolbar.Control_Alignment_Left);
		if self.frmMode = self.Query_Mode then
			self.btnMonitoringOnOff.caption := "Start Monitoring Mode";
		else
			self.btnMonitoringOnOff.caption := "Stop Monitoring Mode";
		endif;
	endif;
	
	if not self.btnCancelBase.isAddedToToolbar then	
		toolbar.addButton(self.btnCancelBase, CMUI_Toolbar.Control_Alignment_Right);
	endif;
			
	toolbar.positionToolbarControls();
	toolbar.visible := true;
	//================================================
	//	Searcher toolbar
	//================================================

	toolbar := self.frmSearchToolbar;
	
	toolbar.showCaptions := showCaptions;	
	
	toolbar.addButton(self.btnSearch, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnResetSearch, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnHideSearcher, CMUI_Toolbar.Control_Alignment_Left);
		
	toolbar.positionToolbarControls();
	toolbar.visible := true;
end;</source>
        <access>protected</access>
    </JadeMethod>
