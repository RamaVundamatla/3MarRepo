    <JadeMethod name="getDisplay" id="f9afcbf5-8cd0-4509-b9ad-95a97ebe64a1">
        <source>getDisplay(): String;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 05/04/2018	jlgdap1		Initial creation TFS 37858 PEL1 Invoice Status Advancement
//
vars
	invalidInvoice : Boolean;
	str, detail : String;
	cargoSubtype : String;

begin
	on Exception do app.handleDeletedObject(exception, self.myInvoice, invalidInvoice);
	
	detail := "Invoice Status Process";
	detail :=  detail &amp;Tab &amp; 
			   self.actionTimeStamp.asStringJMT &amp; Tab &amp;
			   self.myInvoice.myTerminal.code &amp; Tab &amp;
			   self.myInvoice.sequenceNum.String &amp; Tab &amp;
			   self.myInvoice.invoiceType.description &amp; Tab &amp;
			   self.myInvoice.debtor.name &amp; Tab &amp; // TFS 41026
			   "" &amp; Tab &amp;
			   self.myInvoice.getTotalAmount.asStringJMT &amp; Tab &amp;
			   self.myInvoice.fromDT.date.asStringJMT &amp; Tab;
	
	if invalidInvoice then
		return null;
	endif;
	
	return detail;	

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
