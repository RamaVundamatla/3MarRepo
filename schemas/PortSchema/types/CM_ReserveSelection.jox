    <JadeMethod name="getIds" id="ae68a0c9-700f-4e9c-a108-b1f33b8fafdc">
        <source>getIds(pStringArray : StringArray input);
// ---------------------------------------------------------------------------
// Created:		November 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	str : String;
	array : HugeStringArray;
begin
	create array transient;
	pStringArray.clear;
	if self.maskIds = null then
		return;
	endif;
	self.maskIds.getStrings(array);
	foreach str in array do
		if str = null then
			return;
		endif;
		pStringArray.add(str);
	endforeach;
epilog
	delete array;
end;</source>
        <Parameter name="pStringArray" type="StringArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getIdsAsString" id="ebe152fb-cc22-4f80-a893-993bf0192e13">
        <source>getIdsAsString() : String;
// ---------------------------------------------------------------------------
// Created:		November 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	str, longStr : String;
	array : HugeStringArray;
begin

	create array transient;
	if self.maskIds = null then
		return null;
	endif;
	self.maskIds.getStrings(array);
	foreach str in array do
		if str = null then
			continue;
		endif;
		longStr := longStr &amp; str &amp; ', ';
	endforeach;
	longStr := longStr[1 : longStr.length-2];	//Chop off trailing ', '
	return longStr;
epilog
	delete array;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getLength" id="f9628248-af8c-411c-83bf-e217e2ccac27">
        <source>getLength(): Decimal;
/*

Purpose:			

