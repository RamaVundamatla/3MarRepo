    <JadeMethod name="setComboValues" id="a7a774a4-66a7-45d1-ad55-e643515e8fd0">
        <source>setComboValues(_combo : ComboBox input; _params : CM_QueryCriteriaLineHolder; _queryOperator : CM_QueryOperator; _passport : CM_Passport);
// ---------------------------------------------------------------------------
// Created:     17 March 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
// 06 May 2016	cnwns1	TFS 488 - Multi Timezone Support
vars
	crit		: CM_SelectorCriteriaLine;
	wagon		: CM_Wagon;
	idx			: Integer;
	os			: ObjectSet;
	value		: Any;
	ut			: CM_UserTerminal;
	obj			: Object;
	multiTerminal	: Boolean;
	
begin

	_combo.clear;
	
	if _params = null then
		return;
	endif;
	
	

	create os transient;
	_params.getTerminals(os,_passport);
	/*crit := _params.allCriteriaByPropertyName['myTerminal', null];
	if crit &lt;&gt; null then
		crit.myQueryOperator.getSearchValueAsObjectSet(os);
	else
		foreach ut in _passport.myUser.allUserTerminals do
			os.add(ut.getMyTerminal);
		endforeach;
	endif;*/
	
	multiTerminal := (os.size &gt; 1);

	foreach obj in os do
		foreach wagon in obj.CM_Terminal.allWagons do
			if multiTerminal then
				idx := _combo.addItem(wagon.id &amp; " " &amp; self.systemToLocalTime(wagon.dateTime).asStringJMT() &amp; ' - ' &amp; wagon.myTerminal.code); // PAR 19710// 06 May 2016	cnwns1	TFS 488 - Multi Timezone Support
			else
				idx := _combo.addItem(wagon.id &amp; " " &amp; self.systemToLocalTime(wagon.dateTime).asStringJMT()); // PAR 19710// 06 May 2016	cnwns1	TFS 488 - Multi Timezone Support
			endif;
			_combo.itemObject[idx] := wagon;
		endforeach;
	endforeach;
	
epilog
	delete os;
end;</source>
        <Parameter name="_combo" type="ComboBox" usage="input"/>
        <Parameter name="_params" type="CM_QueryCriteriaLineHolder"/>
        <Parameter name="_queryOperator" type="CM_QueryOperator"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="setListValues" id="f524665a-3700-49c1-b5c3-2fff33ac7a9b">
        <source>setListValues(_tbl: Table input; _params: CM_QueryCriteriaLineHolder; _operator: CM_QueryOperator; _passport: CM_Passport);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27/09/2023	navkc1	CR 60428 Task 60702: UI - Cargo Review Option in Transport UI

*/

vars
	wagon		: CM_Wagon;
	idx			: Integer;
	os			: ObjectSet;
	multiTerminal	: Boolean;
	terminal	: CM_Terminal;
	selectionValue : Integer;
begin
	
	_tbl.purgeTableObjects();
	_tbl.clear();
	_tbl.rows := 0;
	
	if _params = null then
		return;
	endif;
	
	create os transient;
	_params.getTerminals(os, _passport);
	
	multiTerminal := (os.size() &gt; 1);
	
	foreach terminal in os as CM_Terminal do
		foreach wagon in terminal.allWagons do
			selectionValue := 0;
			
			if _operator &lt;&gt; null then
				if _operator.CM_QStringIsOneOf.allSelectionValues.includes(wagon.id) then
					selectionValue := 1;
				endif;
			endif;
			
			if multiTerminal then
				idx := _tbl.addItem(selectionValue.String &amp; Tab &amp; wagon.id &amp; " " &amp; self.systemToLocalTime(wagon.dateTime).asStringJMT() &amp; ' - ' &amp; wagon.myTerminal.code);
			else
				idx := _tbl.addItem(selectionValue.String &amp; Tab &amp; wagon.id &amp; " " &amp; self.systemToLocalTime(wagon.dateTime).asStringJMT());
			endif;
			_tbl.accessRow(idx).itemObject := wagon;
			_tbl.row := idx;
			_tbl.change(_tbl);
		endforeach;
	endforeach;
	
epilog
	delete os;
end;</source>
        <Parameter name="_tbl" type="Table" usage="input"/>
        <Parameter name="_params" type="CM_QueryCriteriaLineHolder"/>
        <Parameter name="_operator" type="CM_QueryOperator"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="setValuesFromList" id="47a50a4d-7925-48f9-b14b-42e0dc211024">
        <source>setValuesFromList(_tbl: Table input; _op: CM_QueryOperator input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27/09/2023	navkc1	CR 60428 Task 60702: UI - Cargo Review Option in Transport UI

*/

vars
	str				: String;
	numRows,
	idx				: Integer;
	wagon			: CM_Wagon;
	wagonStrArr		: StringArray;
begin
	
	create wagonStrArr transient;

	numRows := _tbl.rows;
	
	foreach idx in (_tbl.fixedRows + 1) to numRows do
		str := _tbl.accessCell(idx, 1).text;
		if str = TableCheckBox_Selected then
			wagon := _tbl.accessRow(idx).itemObject.CM_Wagon;
			wagonStrArr.add(wagon.id);
		endif;
	endforeach;
	
	_op.setSearchValue(wagonStrArr);
	
epilog
	delete wagonStrArr;
end;</source>
        <Parameter name="_tbl" type="Table" usage="input"/>
        <Parameter name="_op" type="CM_QueryOperator" usage="input"/>
    </JadeMethod>
    <JadeMethod name="translateToDisplayValue" id="69ffb93f-6bbe-47a7-bd8d-f175acd25dd0">
        <source>translateToDisplayValue(_value: Any): String;
// ---------------------------------------------------------------------------
// Created:     17 March 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
/*

Date		Who		Reason
22 Oct 2008	cnwkpd1	PAR #18099 - Handle null objects in selector queries
27/09/2023	navkc1	CR 60428 Task 60702: UI - Cargo Review Option in Transport UI
*/

vars

begin
	if _value &lt;&gt; null then
		if _value.isKindOf(String) then //27/09/2023	navkc1	CR 60428 Task 60702
			return _value.String;
		else
			return _value.CM_Wagon.id;
		endif;
	endif;
	
	return null;

end;</source>
        <Parameter name="_value" type="Any"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="translateToSearchValue" id="425229bf-346b-49af-a44c-da9f42905da5">
        <source>translateToSearchValue(_value: Any): Any;
// ---------------------------------------------------------------------------
// Created:     17 March 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
/*

Date		Who		Reason
06 Oct 2008	cnwkpd1	PAR #18099 - Correct Selector query processing
22 Oct 2008	cnwkpd1	PAR #18348 - Prevent 1002 exceptions in Selector query processing with isOneOf

*/

vars
	invalidObj 		: Boolean;
	object			: CM_Wagon;
	returnVal		: String;
	
begin
	if _value &lt;&gt; null then
		if _value.isKindOf(Collection) then			// PAR #18348
			return _value;
		endif;

		if _value.isKindOf(CM_Wagon) then
			object := _value.CM_Wagon;
		endif;
	endif;
	
	if object &lt;&gt; null then
		on Exception do app.handleDeletedObject(exception, object, invalidObj);
		
		returnVal := object.id;
	endif;
	
	return returnVal;
	
end;
</source>
        <Parameter name="_value" type="Any"/>
        <ReturnType type="Any"/>
    </JadeMethod>
    <JadeMethod name="translateToSearchValueForWeb" id="3d9fc514-6cf1-4995-be35-5dec1d671e53">
        <source>translateToSearchValueForWeb(_value: Any; _sending : Boolean): Any;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 05/09/2019	jlgdap1		Initial creation TFS 45769 JMT Web Portal selector query parameters
//
vars

begin
	if _value.isKindOf(CM_Wagon) then
		return _value.CM_Wagon.id;
		
	elseif _value.isKindOf(String) then
		return _value.String;
		
	endif;
	
	return inheritMethod(_value, _sending);

epilog

end;</source>
        <Parameter name="_value" type="Any"/>
        <Parameter name="_sending" type="Boolean"/>
        <ReturnType type="Any"/>
    </JadeMethod>
</Class>
