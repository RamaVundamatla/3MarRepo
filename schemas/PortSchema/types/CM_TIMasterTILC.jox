    <JadeMethod name="isToDoTaskValid" id="8d922299-0e9d-45d4-a648-c9946a2a0f96">
        <source>isToDoTaskValid(_toDoTaskDesc: CM_ToDoTaskDesc): Boolean;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
10 December 2008	cnwrd1	Initial creation

*/

vars
	cargoTypeObj	: CM_CargoType;
begin

	if not self.isToDoTaskValidForGenSet( _toDoTaskDesc ) then	//Par18032. Jan 2009
		return false;
	endif;

	cargoTypeObj	:=	self.myTILCType.myCargoType;
	return _toDoTaskDesc.allCargoTypes.includes(cargoTypeObj);
	

epilog

end;</source>
        <Parameter name="_toDoTaskDesc" type="CM_ToDoTaskDesc"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isToDoTaskValidForGenSet" id="7044b79a-ad3c-4453-9a0e-99089cc52c23">
        <source>isToDoTaskValidForGenSet( _task : CM_ToDoTaskDesc ) : Boolean protected;
/* ---------------------------------------------------------------------------
Created:	23 January 2009	by cnwvu1

Purpose:	
   
Change Date		Who		Reason

------------------------------------------------------------------------------*/
vars
	trailer : CM_TILC;
	
begin
	
	if _task.trxTypeOnCompletion = TRANS_TYPE_DetachGenerator or _task.trxTypeOnCompletion = TRANS_TYPE_AttachGenerator then
	
		trailer := self.getCurrentTi().CM_TILC;
		
		if _task.trxTypeOnCompletion = TRANS_TYPE_DetachGenerator then
			//if TIMaster says that a Detach Generator todo task needs to be auto set on receival, 
			//this should only be done if the ti has a generator specified.
			if not trailer.hasGeneratorSetAttached() then
				return false;
			endif;
			
		else	// TRANS_TYPE_AttachGenerator
			//if TIMaster says that a Attach Generator todo task needs to be auto set on receival, 
			//this should only be done if the ti has no generator specified.
			if trailer.hasGeneratorSetAttached() then
				return false;
			endif;
			
		endif;
	
	endif;
	
	return true;
	
end;</source>
        <access>protected</access>
        <Parameter name="_task" type="CM_ToDoTaskDesc"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
