    <JadeMethod name="auditId" id="96bbbe9e-6b98-4472-b85f-fc31135c7394">
        <source>auditId(): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 December 2016	cnwma1	Initial creation

*/

vars

	invalid : Boolean;

begin

	on Exception do app.handleDeletedObject( exception, self.myInvoiceLineDesc, invalid ); // found during testing

	if self.myInvoiceLineDesc &lt;&gt; null then
		return self.myInvoiceLineDesc.narration;
	endif;
	
	return null;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
