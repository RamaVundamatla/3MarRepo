    <JadeMethod name="createExportImportClass" id="804642d2-ed8e-4abf-a340-11b0589270bb">
        <updating/>
        <source>createExportImportClass(_cls: Class) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 January 2026	naviv1	Initial creation MTN 36787 - JADE Core Framework - Export Import Class Registry Maintenance Engine

*/

vars
    pxyExportClass, realExportImportClass: CM_ExportImportClass;
    meta: CM_ExportImportClass;
begin
    // Get class metadata
    meta := self.getClassMetadata(_cls.name);
	// Create persistent configuration object
    create pxyExportClass transient;
	pxyExportClass.setProxy(meta);
    
    // Configure all properties via class-specific method
    self.configureClassProperties(pxyExportClass);
	
	app.myTrxCA.trxCreateExportImportClass(pxyExportClass, realExportImportClass, app.myPassport);

	if not app.myPassport.trxCompletedOK then
		app.writeStatement(app.myPassport.getErrorsAsString);
	endif;
    
    self.writeLog("  Created: " &amp; pxyExportClass.displayName &amp; 
        " (" &amp; pxyExportClass.allProperties.size.String &amp; " properties)");
    
epilog
    delete meta;
	delete pxyExportClass;
end;</source>
        <Parameter name="_cls" type="Class"/>
    </JadeMethod>
    <JadeMethod name="deleteExportImportClass" id="96b006e1-3670-47f4-8e90-cd14eb96f826">
        <updating/>
        <source>deleteExportImportClass(_exportClass: CM_ExportImportClass io) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 January 2026	naviv1	Initial creation MTN 36787 - JADE Core Framework - Export Import Class Registry Maintenance Engine

*/

vars
    propCount: Integer;
begin
    propCount := _exportClass.allProperties.size;
	
	app.myTrxDA.trxDeleteExportImportClass(_exportClass,app.myPassport);
	//self.writeLog("  Deleted: " &amp; _exportClass.className &amp; 
       // " (" &amp; propCount.String &amp; " properties removed)");
end;</source>
        <Parameter name="_exportClass" type="CM_ExportImportClass" usage="io"/>
    </JadeMethod>
    <JadeMethod name="deriveLoadMethodName" id="e6eaafda-15de-4227-8e6f-be507abc8f3c">
        <source>deriveLoadMethodName(_className: String): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 January 2026	naviv1	Initial creation  MTN 36787 - JADE Core Framework - Export Import Class Registry Maintenance Engine

*/

vars
	loadMethodName : String;
begin
    if _className[1:3] =  "CM_" then
        loadMethodName := "load" &amp; _className[4:_className.length];
    elseif _className[1:4] =  "HMS_" then
        loadMethodName := "load" &amp; _className[5:_className.length];
    elseif _className[1:5] = "CMIF_" then
        loadMethodName := "load" &amp; _className[6:_className.length];
    else
        loadMethodName := "loadObject";
    endif;
	return loadMethodName;
end;</source>
        <Parameter name="_className" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="formatClassName" id="a02355f7-8ae0-4319-b0c5-6eee4d300cc8">
        <source>formatClassName(_className: String): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 January 2026	naviv1	Initial creation  MTN 36787 - JADE Core Framework - Export Import Class Registry Maintenance Engine

*/
vars
	name : String;
begin
    if _className[1:3] =  "CM_" then
        name :=  _className[4:_className.length];
    elseif _className[1:4] =  "HMS_" then
        name :=  _className[5:_className.length];
    elseif _className[1:5] = "CMIF_" then
        name :=  _className[6:_className.length];
    else
        name := _className;
    endif;
    
    // Format camelCase to Title Case
    return self.formatPropertyName(name);
end;</source>
        <Parameter name="_className" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="formatPropertyName" id="dec5844d-b327-4f93-b0b8-81b04671fcfd">
        <source>formatPropertyName(_propName: String): String;
/*

Purpose:			
	* Converts camelCase/property name to Title Case
	 * 
	 * Examples:
	 *   "myCommodityGroup" -&gt; "My Commodity Group"
	 *   "allCargoTypes" -&gt; "All Cargo Types"
	 *   "code" -&gt; "Code"
Parameters:			

Return Value:		

Date		Who		Reason
06 January 2026	naviv1	Initial creation  MTN 36787 - JADE Core Framework - Export Import Class Registry Maintenance Engine

*/

vars
    result: String;
    i: Integer;
    ch: Character;
    prevWasUpper: Boolean;
	propName : String;
begin
    result := "";
    prevWasUpper := false;
    
    // Skip common prefixes
    if _propName.startsWith("my") then
        propName := _propName[3: _propName.length];
    elseif _propName.startsWith("all") then
        propName := _propName[4:_propName.length];
    endif;
    
    foreach i in 1 to propName.length do
        ch := propName[i];
		if i = 1 then
            // First character always uppercase
            result := result &amp; ch.toUpper();
            prevWasUpper := ch.isUpper();
            
        elseif ch.isUpper() then
            // Add space before uppercase (unless previous was also uppercase)
            if not prevWasUpper then
                result := result &amp; " ";
            endif;
            result := result &amp; ch;
            prevWasUpper := true;
            
        else
            result := result &amp; ch;
            prevWasUpper := false;
        endif;
    endforeach;
    
    return result;
end;

</source>
        <Parameter name="_propName" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getClassMetadata" id="9300e601-2331-4311-a0a4-62bf765c346a">
        <source>getClassMetadata(_className: String): CM_ExportImportClass;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 January 2026	naviv1	Initial creation  MTN 36787 - JADE Core Framework - Export Import Class Registry Maintenance Engine

*/

vars
    registry: CM_ExportImportClassDict;
    meta: CM_ExportImportClass;
begin
    // Build registry
    self.buildClassRegistry(registry);
    
    // Lookup class
    meta := registry[_className];
    
    if meta = null then
        // Fallback - auto-generate for unknown classes
        create meta transient;
        meta.className := _className;
        meta.category := "system-admin";  // Default category
        meta.displayName := self.formatClassName(_className);
        meta.loadMethodName := self.deriveLoadMethodName(_className);
        meta.isExportable := true;
    endif;
    
    return meta;
    
epilog
    delete registry;
end;</source>
        <Parameter name="_className" type="String"/>
        <ReturnType type="CM_ExportImportClass"/>
    </JadeMethod>
    <JadeMethod name="getExportableClasses" id="6eb0f27e-166a-47c6-a686-2d361506df3a">
        <source>getExportableClasses(_classes: ClassColl io);
/*

Purpose:			
	 * Returns curated list of exportable classes IN DEPENDENCY ORDER
 
	* Parent classes MUST come before child classes to ensure
Parameters:			

Return Value:		

Date		Who		Reason
06 January 2026	naviv1	Initial creation  MTN 36787 - JADE Core Framework - Export Import Class Registry Maintenance Engine

*/

begin
    create _classes transient;
    
    // ========================================================================
    // SYSTEM ADMINISTRATION
    // ========================================================================
    _classes.add(CM_CommodityGroup);
    _classes.add(CM_Commodity);
