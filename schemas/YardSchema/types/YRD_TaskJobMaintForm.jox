    <JadeMethod name="translateForm" id="5a0c5b26-ba97-4ac6-b439-08071cea25cb">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 20 September 2018 14:56:33.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0022891, locale);
	btnEmail.translateCaption(Xlat_0012452, locale);
	btnJobCancel.translateCaption(Xlat_0014668, locale);
	btnJobOK.translateCaption(Xlat_0014669, locale);
	btnSchedule.translateCaption(Xlat_0012460, locale);
	btnSourceEdit.translateCaption(Xlat_0012461, locale);
	btnTaskEdit.translateCaption(Xlat_0012462, locale);
	chkSendEmail.translateCaption(Xlat_0012463, locale);
	chkSetArchived.translateCaption(Xlat_0014216, locale);
	grpJobDetails.translateCaption(Xlat_0012465, locale);
	grpSource.translateCaption(Xlat_0012466, locale);
	grpTaskItems.translateCaption(Xlat_0012467, locale);
	lApprovalExpiry.translateCaption(Xlat_0022593, locale);
	lEmail.translateCaption(Xlat_0012468, locale);
	lJobApprovedBy.translateCaption(Xlat_0012469, locale);
	lJobApprovedByAt.translateCaption(Xlat_0012470, locale);
	lJobCompleted.translateCaption(Xlat_0012471, locale);
	lJobEnteredBy.translateCaption(Xlat_0012472, locale);
	lJobEnteredByAt.translateCaption(Xlat_0012473, locale);
	lJobID.translateCaption(Xlat_0012474, locale);
	lJobRemarks.translateCaption(Xlat_0012475, locale);
	lJobRequiredBy.translateCaption(Xlat_0012476, locale);
	lJobStartAt.translateCaption(Xlat_0012477, locale);
	lProgress.translateCaption(Xlat_0012478, locale);
	lReference.translateCaption(Xlat_0012479, locale);
	lStatus.translateCaption(Xlat_0012480, locale);
	lblCargoType.translateCaption(Xlat_0012481, locale);
	lblExternalVoyCode.translateCaption(Xlat_0023025, locale);
	lblOrganisation.translateCaption(Xlat_0012484, locale);
	lblPin.translateCaption(Xlat_0022406, locale);
	lblTotalRequest.translateCaption(Xlat_0012485, locale);
	lblTotalRequired.translateCaption(Xlat_0012486, locale);
	lblVoyage.translateCaption(Xlat_0022519, locale);
	mnuShowBooking.translateCaption(Xlat_0013798, locale);
