    <JadeMethod name="adminSettings" id="b4a2f8de-ae84-45e3-ad08-9548a4b47633">
        <updating/>
        <source>adminSettings(_table : Table input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 October 2012	cnwmc5	Initial creation

*/

vars
	cell 	: JadeTableCell;
	
	isAdmin : Boolean;
begin
	isAdmin := _table.getCellText(_table.row, 1).Integer.Boolean;	

	if isAdmin and _table.column = 1 then
		cell := _table.accessCell(_table.row, 4);
		cell.enabled := true;
		_table.setCellText(_table.row, 4, isAdmin.String);
		cell := _table.accessCell(_table.row, 5);
		cell.enabled := true;
		_table.setCellText(_table.row, 5, isAdmin.String);
		cell := _table.accessCell(_table.row, 6);
		cell.enabled := true;
		_table.setCellText(_table.row, 6, isAdmin.String);
	elseif not isAdmin then 
		cell := _table.accessCell(_table.row, 4);
		cell.enabled := false;
		_table.setCellText(_table.row, 4, null);
		cell := _table.accessCell(_table.row, 5);
		cell.enabled := false;
		_table.setCellText(_table.row, 5, null);
		cell := _table.accessCell(_table.row, 6);
		cell.enabled := false;
		_table.setCellText(_table.row, 6, null);
	endif;
epilog

end;</source>
        <Parameter name="_table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="btnCancel_click" id="a783f8c2-1595-4daf-bbe3-e3de09e4f183">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnCancel_click(btn: Button input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
09 October 2012	cnwmc5	Initial creation
16 April 2025	navpw1	JIRA: MTN-34402: Modified method to make it cancel properly instead of using setupForm

*/

vars
	stringObj : CM_String;
	
begin
	self.lstReports.clearTable;
	
	//Used this over displayCollection in case we need to do scrolling. displayCollection unselects items out of view while scrolling
	foreach stringObj in self.allAvailableReports do
		self.lstReports.addItemObject(stringObj.string, stringObj);
	endforeach;
	
	self.allMethodOwners.clear();
	self.allOwnerMethodsCount.clear();
	
	self.getUserMethodsCount();
	
	self.populateTable();
	
	self.btnCancel.enabled := false;
	self.btnSave.enabled := false;
	self.btnDisableAll.enabled := false;
	self.btnEnableAll.enabled := false;
	
	self.btnEdit.enabled := true;
	self.btnNew.enabled := true;
		
	if self.isNew then
		self.isNew := false;
	endif;
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="btnClear_click" id="aa0c6a81-963a-4743-b309-7561e6976f68">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnClear_click(btn: Button input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
10 October 2012	cnwmc5	Initial creation
16 April 2025	navpw1	JIRA: MTN-34402: Added code to make the clear button function similarly to the cancel button to reload data

*/

vars
	stringObj : CM_String;
	
begin
	self.txtFind.text := null;
	
	self.lstReports.clearTable;
	
	//Used this over displayCollection in case we need to do scrolling. displayCollection unselects items out of view while scrolling
	foreach stringObj in self.allAvailableReports do
		self.lstReports.addItemObject(stringObj.string, stringObj);
	endforeach;
	
	self.allMethodOwners.clear();
	self.allOwnerMethodsCount.clear();
	
	self.getUserMethodsCount();
	
	self.populateTable();
	
	self.btnCancel.enabled := false;
	self.btnSave.enabled := false;
	self.btnDisableAll.enabled := false;
	self.btnEnableAll.enabled := false;
	
	self.btnEdit.enabled := true;
	self.btnNew.enabled := true;
epilog

end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
