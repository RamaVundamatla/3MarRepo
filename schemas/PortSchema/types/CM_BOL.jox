    <JadeMethod name="getBOLQuantityForInvoice" id="6573761c-b722-449b-b9c1-13fc4b2208b8">
        <source>getBOLQuantityForInvoice():Real;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
31 October 2019	jlgndl1	Initial creation	TFS 47100

*/

vars

	totalQuantity	: Integer;
	detail : CM_BOLDtl;

begin

	foreach detail in self.allBOLDtls do
		totalQuantity := totalQuantity + detail.quantity;
	endforeach;
	
	return totalQuantity.Real;

epilog

end;</source>
        <ReturnType type="Real"/>
    </JadeMethod>
