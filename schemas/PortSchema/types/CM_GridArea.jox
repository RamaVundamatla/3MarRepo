    <JadeMethod name="initialiseForDecking" id="965f2f18-a44a-479a-bb0e-39bb9036f073">
        <source>initialiseForDecking(_pxyDeckingOptions: CM_YADeckingOptionsTA input);
//----------------------------------------------------------------
//	Created:	07 April 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	gridObjectDict,
	gridCntrlDict			: CM_MemberKeyDictionary;
	gridObj					: Object;
	gridController			: Object;
	index					: Integer;
	startFromLast			: Boolean;

begin

	index := 0;
	
	startFromLast := self.defaultDeckingStartType = self.DefaultDeckingFromLast;

	gridObjectDict := self.getDictForDecking(DeckingRule_Default);

	if startFromLast then
		foreach gridObj in gridObjectDict reversed do
			gridCntrlDict := gridObj.CM_GridObject.getDictForDecking();
			foreach gridController in gridCntrlDict do
				gridController.CM_YardController.setupForDeckingInTA(1, self.heightOfStack, _pxyDeckingOptions, index);
			endforeach;
		endforeach;
	else
		foreach gridObj in gridObjectDict do
			gridCntrlDict := gridObj.CM_GridObject.getDictForDecking();
			foreach gridController in gridCntrlDict do
				gridController.CM_YardController.setupForDeckingInTA(1, self.heightOfStack, _pxyDeckingOptions, index);
			endforeach;
		endforeach;
	endif;

	//do default out - reverse of in?
	_pxyDeckingOptions.setOutDeckingReverseOfIn();
	
end;</source>
        <Parameter name="_pxyDeckingOptions" type="CM_YADeckingOptionsTA" usage="input"/>
    </JadeMethod>
    <JadeMethod name="initializeForActivity" id="ab7c5da3-1f12-4164-8282-65ded6bd8537">
        <updating/>
        <source>initializeForActivity(_ewsOpsView: CM_EWSActivityOpsview; _opsViewTable : CMIF_OpsViewTables) updating;
/*
Purpose:			

Date		Who		Reason
17 December 2021	navab1	TFS 51855
