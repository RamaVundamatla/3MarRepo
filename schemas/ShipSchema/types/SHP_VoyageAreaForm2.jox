    <JadeMethod name="enableDisableDrawingPens" id="7990e010-e2e5-4024-a820-eebc2a26703d">
        <source>enableDisableDrawingPens(_enabled : Boolean);
// ---------------------------------------------------------------------------
// Created:     08 September 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	theViewMode	: Integer;
	tmpEnabled	: Boolean;

begin

	tmpEnabled := _enabled;

	if _enabled then
		if self.displayMode = ShpDisplayMode_ColCodeDisch then
			self.btnPenDischarge.enabled	:= _enabled;
			self.btnPenDischarge.visible	:= true;
			self.btnPenLoad.visible			:= false;
		elseif self.displayMode = ShpDisplayMode_ColCodeLoad then
			self.btnPenLoad.enabled			:= _enabled;
			self.btnPenDischarge.visible	:= false;
			self.btnPenLoad.visible			:= true;
		else
			// invalid mode for these buttons to be enabled so
			// override the passed in value
			tmpEnabled := false;
			self.btnPenDischarge.enabled	:= tmpEnabled;
			self.btnPenLoad.enabled			:= tmpEnabled;
		endif;
	else
		self.btnPenDischarge.enabled	:= _enabled;
		self.btnPenLoad.enabled			:= _enabled;
	endif;

	self.btnPenEraser.enabled		:= _enabled;
	self.btnPenRehandle.enabled		:= tmpEnabled;
	self.btnPenSOB.enabled			:= tmpEnabled;
	
end;</source>
        <Parameter name="_enabled" type="Boolean"/>
    </JadeMethod>
