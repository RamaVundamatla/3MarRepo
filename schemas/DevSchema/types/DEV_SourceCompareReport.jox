				endif;
				
				concatenatedString &amp;= CrLf &amp; devSchema.name &amp; "::" &amp; devClass.name &amp; "::" &amp; devMethod.name &amp; " - " &amp; devMethod.modifiedBy &amp;  " | " &amp; devMethod.modifiedTimeStamp.String;
				methodsDifferentCount += 1;
			endforeach;
		endforeach;
	endforeach;
	
	if methodsDifferentCount &lt;&gt; 0 then
		concatenatedString &amp;= CrLf &amp; "Different Methods Count: " &amp; methodsDifferentCount.String;
	endif;
	
	concatenatedString &amp;= CrLf;
	
	wroteHeaderLine := false;
	foreach devSchema in self.allSchemas do
		foreach devClass in devSchema.allClasses where devClass.reason = DEV_SourceCompareReportAgent.Object_Link do
			foreach devAttribute in devClass.allAttributes where devAttribute.reason = DEV_SourceCompareReportAgent.Object_Missing do
				if not wroteHeaderLine then
					concatenatedString &amp;= CrLf &amp; "Missing Attributes:";
					wroteHeaderLine := true;
				endif;
				
				concatenatedString &amp;= CrLf &amp; devSchema.name &amp; "::" &amp; devClass.name &amp; "::" &amp; devAttribute.name &amp; " - " &amp; devAttribute.modifiedBy &amp;  " | " &amp; devAttribute.modifiedTimeStamp.String;
				attributesMissingCount += 1;
			endforeach;
		endforeach;
	endforeach;
	
	if attributesMissingCount &lt;&gt; 0 then
		concatenatedString &amp;= CrLf &amp; "Missing Attributes Count: " &amp; attributesMissingCount.String;
	endif;
	
	concatenatedString &amp;= CrLf;
	
	//Issue with Differing Attributes - Check Comparison might have false positives
	wroteHeaderLine := false;
	foreach devSchema in self.allSchemas do
		foreach devClass in devSchema.allClasses where devClass.reason = DEV_SourceCompareReportAgent.Object_Link do
			foreach devAttribute in devClass.allAttributes where devAttribute.reason = DEV_SourceCompareReportAgent.Object_Different do
				if not wroteHeaderLine then
