    <JadeMethod name="setupWeightField" id="3c72ed68-806f-40c0-be7e-2827a8ed295d">
        <source>setupWeightField();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
27 May 2013	cnwrd1	Initial creation
07 Apr 2014 cnwer1	CCMS 1366 changes to work with Bulk
*/

vars
	typeWeight : String;
	measureType : CM_MeasurementType;
	ct : CM_CargoType;
	convertedAmount : String;
	showTareWeight : Boolean;
	top : Real;
	tab : Integer;
begin
	ct := self.myTrackedItem.myCargoType;
	
	//18 Jan 2018	NDL	TFS 36697
	showTareWeight :=  ct.useTareCargoWeight;
	self.lblWeightCargo.visible := showTareWeight;
	self.lblWeightTare.visible := showTareWeight;
	self.tblCargoWeight.visible := showTareWeight;
	self.tblTareWeight.visible := showTareWeight;
	
	// ### TFS 40401 switch total weight and tare weight screen positions
	//### If we are configured for tare and cargo weight put them first and then the total weight
	//### If we are NOT configured for tare and cargo weight put total weight just under quantity
	
	if showTareWeight then
		// TOTAL WEIGHT IS ABOVE TARE WEIGHT
		if tblWeight.top &lt; tblTareWeight.top then
			top := tblTareWeight.top;
			tblTareWeight.top := tblWeight.top;
			tblWeight.top := top;
			
			tab := self.txtAmount.tabIndex;
			tblTareWeight.tabIndex := tab + 1;
			tblCargoWeight.tabIndex := tab + 2;
			tblWeight.tabIndex := tab + 3;
			
			lblWeightTare.top := tblTareWeight.top;
			lblTareWtChg.top := tblTareWeight.top;
			lblWeight.top := tblWeight.top;
			lblTotalWtChg.top := tblWeight.top;
		endif;
	else
		// TARE WEIGHT IS ABOVE TOTAL WEIGHT
		if tblTareWeight.top &lt; tblWeight.top then
			top := tblWeight.top;
			tab := tblWeight.tabIndex;
			tblWeight.top := tblTareWeight.top;
			tblTareWeight.top := top;
			
			lblWeightTare.top := tblTareWeight.top;
			lblTareWtChg.top := tblTareWeight.top;
			lblWeight.top := tblWeight.top;
			lblTotalWtChg.top := tblWeight.top;
		endif;
	
	endif;
	
	
//	self.tblTareWeight.enabled := not self.myTrackedItem.usesAutoWeightCalculate(); //20 Feb 2018 NDL TFS 36697
	
	if ct.isBreakBulkMulti then
		self.tblWeight.setup(Type_Weight, self.backColor);
		measureType := self.myTrackedItem.getDefaultMeasurementForType(Type_Weight);
		if measureType &lt;&gt; null then
			typeWeight:= measureType.shortName;
			self.tblWeight.setValues(app.convertMeasurementForDisplay(typeWeight, null) &amp; Space &amp; typeWeight);
		endif;
		
		if self.myTrackedItem &lt;&gt; null then
			self.tblWeight.setValueDefault( self.myTrackedItem.totalWeight.String );
		endif;
		
	elseif ct.isBulkMulti then
		self.txtAmount.visible:=false;
		self.lblAmount.visible:=false;
		if ct.isTrackByWeight then
			self.tblWeight.setup(Type_Weight, self.backColor);
			convertedAmount:=self.myTrackedItem.getConvertedTotalWeightIn(ct.myWeightMeasurementType.shortName);
			self.tblWeight.setValues(convertedAmount &amp; " " &amp; ct.myWeightMeasurementType.shortName);
		elseif ct.isTrackByVolume then
			self.lblWeight.caption:=app.getErrorString(New_Total_Volume);
			self.tblWeight.setup(Type_Volume, self.backColor);
			convertedAmount:=self.myTrackedItem.getConvertedTotalVolumeIn(ct.myVolumeMeasurementType.shortName);
			self.tblWeight.setValues(convertedAmount &amp; " " &amp; ct.myVolumeMeasurementType.shortName);
		endif;
		self.tblWeight.tabKey:=J_key_Tab;
		
	endif;
	
	
	//18 Jan 2018	NDL	TFS 36697
	if typeWeight = null then
		measureType := app.getDefaultMeasurementForType(Type_Weight);
		if measureType &lt;&gt; null then
			typeWeight := measureType.shortName;
		endif;
	endif;
	if typeWeight &lt;&gt; null then
		self.tblCargoWeight.setup(Type_Weight, self.backColor);
		self.tblTareWeight.setup(Type_Weight, self.backColor);
		self.tblCargoWeight.setValues(app.convertMeasurementForDisplay(typeWeight, null) &amp; Space &amp; typeWeight);
		self.tblTareWeight.setValues(app.convertMeasurementForDisplay(typeWeight, null) &amp; Space &amp; typeWeight);
	endif;
	if self.myTrackedItem &lt;&gt; null then
		self.tblCargoWeight.setValues(app.convertMeasurementForDisplay(typeWeight, self.myTrackedItem.weightCargo) &amp; Space &amp; typeWeight);
		if showTareWeight then
			self.tblTareWeight.setValues(app.convertMeasurementForDisplay(typeWeight, self.myTrackedItem.weightTare) &amp; Space &amp; typeWeight);
		endif;
	endif;
	
epilog

end;</source>
    </JadeMethod>
