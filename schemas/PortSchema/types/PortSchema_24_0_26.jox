	self.setWebPackingIncludePackComp(pControllerObj);  //jlier1 TFS 66302
	self.convertHookCodeInvLog(pControllerObj); // ### JIRA 33364 05NOV2024 NAVAB1
	self.populateOperatorAllCGsByTerm(pControllerObj);		//19/06/2025 jlizm1 MTN 34778
	self.setBestPickDTAndOverstows(pControllerObj);	 //26/8/25 jlier1 JIRA  35632
	self.updateRemoveJadeFromTooltips(pControllerObj);  // ### JIRA 35719 02SEP2025 NAVAB1
	self.convertCargoTypeForContents(pControllerObj); //02/10/2025	navkc1 JIRA 36151
	self.setExtApiLastSuccessfulTS(pControllerObj);			//11.12.2025 navah1 #MTN-36365
epilog

end;</source>
