    <JadeMethod name="canUserSet" id="cee23992-86a4-42c0-a3f4-0cd20712d5bb">
        <source>canUserSet(_propName: String): Boolean;
/*****************************************************
Author		: jlika1 (Karen Alexander)
Date		: 21 February 2023
TFS#		: 56562
Function	:

*** Changes ***
Date			Name		TFS#		Description

****************************************************/

begin
	if _propName = CM_EDIQshipsVesselTI::myQshipsVoyageTI.name then		
		return false;
	else
		return inheritMethod(_propName);
	endif;
end;</source>
        <Parameter name="_propName" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="9016e05e-7615-4de9-a915-f63aff20bc3e">
        <updating/>
        <source>setForUpdate(_proxyEDITI: SelfType) updating;
/*****************************************************
Author		: jlika1 (Karen Alexander)
Date		: 15 February 2023
TFS#		: 56562
Function	:

*** Changes ***
Date			Name		TFS#		Description

****************************************************/

vars
	prop : Property;
	propDict : PropertyNDict;	
begin
	
	propDict := CM_EDIQshipsVesselTI.getProperties;	

	foreach prop in propDict do
		if self.canUserSet(prop.name) then			
			self.setPropertyValue(prop.name, _proxyEDITI.getPropertyValue(prop.name));
		endif;
	endforeach;
	
	inheritMethod(_proxyEDITI);
end;</source>
        <Parameter name="_proxyEDITI" type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setShippingLine" id="74e7fb5d-07ee-4bab-a642-ef95a65ad7e5">
