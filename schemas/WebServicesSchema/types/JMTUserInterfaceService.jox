    <JadeWebServicesMethod name="sendFeedback" id="7ff6985b-d408-488c-9b1a-24646a3111b2">
        <source>sendFeedback(feedbackRequest : WS_SendFeedbackRequest) : WS_Response webService;
/*

Purpose:	Sends feedback to infoatjadelogistics.com

Parameters:		feedback message	

Return Value:	None	

Date			Who		Reason
12 October 2017	jlgam15	Initial creation

*/

vars
	response		: WS_Response;
	completedOK		: Boolean;
	from 			: String;
	toAddress		: String;
	emailContent 	: String;

begin
	// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);
	
	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	
	// Initialise the passport for the new transaction
	// In particular this sets passport myUser and myTerminal
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	
	// Create the response
	create response transient;
		
	toAddress := "info@jadelogistics.com";
	
	if currentSession.myUser.myEmailEntity &lt;&gt; null then
		from := currentSession.myUser.myEmailEntity.getEmailAddress();
	else
		from := currentSession.myUser.userName;
	endif;
	
	emailContent := "User : " &amp; currentSession.myUser.userName &amp; CrLf &amp;
					"Environment : " &amp; app.myRoot.getSystemModeDesc &amp;  CrLf &amp;
					"Feedback :	" &amp; feedbackRequest.feedbackMessage &amp; CrLf;
					
	
	app.myTrxCA.trxCreateEmailSendRequest(	app.getErrorString(Web) &amp; ' ' &amp; $User &amp; ' ' &amp; app.myPassport.getUserCode(),
											toAddress,
											from,
											null,
											null,
											"Web Portal Feedback",
											emailContent,
											null,
											null,
											null,
											null,
											EmailSource_System,
											null,
											app.myPassport);									
												
	

	// Got to here, everything is ok
	completedOK := true;
	return response;
	
epilog
	
	if not completedOK then
		cnSetTransactionError(true);
		delete response;				// prevent transient leaks
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;
	
end;</source>
        <Parameter name="feedbackRequest" type="WS_SendFeedbackRequest"/>
        <ReturnType type="WS_Response"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="sendVoyageRejectEmail" id="de21451b-e4b6-4eb1-a889-65ee6882e182">
        <source>sendVoyageRejectEmail(request : WS_EmailSendRequest) : WS_Response webService; 
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 April 2018	jlger1	Initial creation 37705

*/

vars

	response		: WS_Response;
	completedOK		: Boolean;
	sender			: String;
	toAddress 	: String;

begin
	// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);
	
	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	
	// Initialise the passport for the new transaction
	// In particular this sets passport myUser and myTerminal
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	
	// Create the response
	create response transient;
	
	// Check security access to this message, if required
	app.checkCurrentUserHasAccess(PmSendEmailWeb);
	if app.myPassport.hasErrors then
		completedOK := true;
		return response;
	endif;
		
	//sent from the web user to the terminal 
	/*if app.myPassport.myUser.myEmailEntity &lt;&gt; null then
		sender := app.myPassport.myUser.myEmailEntity.getEmailAddress;
	endif;
	if sender = null then*/
		
//	endif;
	//epr TFS 41012 2/10/18 users email probably not available in the SMPT servers so just use the system config senders email
	sender := app.myRoot.getConfig(AutoSendersEmailAddress).String;
	toAddress := app.myPassport.myTerminal.getConfig(EmailForFinance).String; //epr tfs 39111 8/6/18
	
	//toAddress:= app.myPassport.myTerminal.getConfig(CamsEmailAddress).
	app.myTrxCA.trxCreateEmailSendRequest(app.getErrorString(Web) &amp; ' ' &amp; $User &amp; ' ' &amp; app.myPassport.getUserCode(),	// _alertDescription
										  toAddress,		// _toAddress
										  sender,					// _fromAddress
										  request.ccAddress,		// _ccAddresses
										  request.bccAddress,		// _bccAddresses
										  request.subject,			// _sendSubject
										  request.body,				// _sendMessage
										  null,						// _allAttachedFilePaths
										  null,						// _allFileData
										  null,						// _blob
										  null,						// _blobFileName
										  EmailSource_System,		// _sourceOfEmail
										  null,						// _updateCallbackObj
										  app.myPassport);			// _passport
	
	// Got to here, everything is ok
	completedOK := true;
	return response;
	

epilog
	// Tidy up any local transients
	
	if not completedOK then
		cnSetTransactionError(true);
		delete response;				// prevent transient leaks
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;
end;</source>
