    <JadeMethod name="pxyCreateDefaultLanes" id="0ce0941f-d6a2-40f4-bac5-2b79a01e4ad7">
        <updating/>
        <source>pxyCreateDefaultLanes() updating, protected;
// ---------------------------------------------------------------------------
// Created:     02 September 2009 by cnwcs5:1
// Purpose:     CCMS 1061 - Gate Config Changes  
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	lc	:CM_LaneController;
begin
	self.raiseExceptionIfNotTransient (method);
	
	lc := self.pxyCreateNewLane (true);
	lc.setLockDirection (true);
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="0f9a77b0-36c2-4b1f-872d-2cc8283da387">
        <updating/>
        <source>setForCreate(_proxy: CM_InterchangeArea input; _passport: CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:     24 August 2009 by cnwcs5
// Purpose:     CCMS 1061 - gate config
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//	13/10/2009	cnwcs5		par 21285 - don't create a sub-queue
// ---------------------------------------------------------------------------
vars

begin
	inheritMethod(_proxy, _passport);
epilog

end;</source>
        <Parameter name="_proxy" type="CM_InterchangeArea" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="8294a033-6fcc-41f3-8f62-539d6783e6e9">
        <updating/>
        <source>setForUpdate(_proxy :CM_InterchangeArea)updating;
// ---------------------------------------------------------------------------
// Created:     16 June 2009 by concms1
// Purpose:     CCMS 1061 - Gate Config
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 12/10/2009	cnwcs5		par 21173 - exception when terminal areas have been selected for new IC Area
// ---------------------------------------------------------------------------
vars
	ta 	: CM_TerminalArea;
begin
	inheritMethod (_proxy);
	
	self.myDefaultOutGate	:= _proxy.myDefaultOutGate;
	
	//epr par 24895 6/7/10
	self.allAssociatedTerminalAreas.clear;
	foreach ta in _proxy.allAssociatedTerminalAreas do
		self.allAssociatedTerminalAreas.addNoDuplicates (ta, false);	// PAR 21173 christina - not using proxies
	endforeach;	
epilog

end;</source>
        <Parameter name="_proxy" type="CM_InterchangeArea"/>
    </JadeMethod>
    <JadeMethod name="setForUpdateInUse" id="09b5dff9-f946-4fc2-a1d3-f5424480994e">
        <updating/>
        <source>setForUpdateInUse(_proxy: CM_InterchangeArea; _passport: CM_Passport input) updating;

/*
Date			Who		Reason
11 August 2009	cnwar2	Initial creation

*/
vars
	ta	: CM_TerminalArea;
begin
	inheritMethod(_proxy, _passport);

	self.myDefaultOutGate	:= _proxy.myDefaultOutGate;
	
	//cnwjo3 par 20582. added here because lanecount not updating even though set in other places
	self.laneCount := _proxy.laneCount; 
	
	self.allAssociatedTerminalAreas.clear;
	foreach ta in _proxy.allAssociatedTerminalAreas do
		self.allAssociatedTerminalAreas.addNoDuplicates (ta, false);	// christina - not using proxies
	endforeach;	
epilog

end;</source>
        <Parameter name="_proxy" type="CM_InterchangeArea"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="10059097-52f8-480a-87c6-baec82741da4">
        <updating/>
        <source>setProxy(_id :String; _comment :String; _terminal :CM_Terminal; 
			_releasePoint, _hideFromOverview :Boolean; 
			_accessRule :Integer;	// par 24418
			_defExitGate :CM_Gate; 			
			_selectedTAs : CM_TerminalAreaSet input; _laneCount : Integer )updating;
// ---------------------------------------------------------------------------
// Created:     31 July 2009 by cnwcs5:1
// Purpose:     CCMS 1061 - Gate Config Changes , par 20582
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 26/05/2010	cnwcs5		par 24292 - change _allInterchangeAreas parameter to array
// 18/06/2010	cnwcs5		par 24418 - new parameter _accessRules
// ---------------------------------------------------------------------------
vars

begin
	
	self.setProxyInterchangeArea (_id, _comment, _terminal, TA_TYPE_YARD_INTERCHANGE, _laneCount, _releasePoint, _hideFromOverview, _accessRule, _defExitGate,  _selectedTAs);
epilog

end;</source>
        <Parameter name="_id" type="String"/>
        <Parameter name="_comment" type="String"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_releasePoint" type="Boolean"/>
        <Parameter name="_hideFromOverview" type="Boolean"/>
        <Parameter name="_accessRule" type="Integer"/>
        <Parameter name="_defExitGate" type="CM_Gate"/>
        <Parameter name="_selectedTAs" type="CM_TerminalAreaSet" usage="input"/>
        <Parameter name="_laneCount" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="validate" id="7c6b6fb4-dcfc-488f-afb0-4ea1394dd349">
        <source>validate() protected;
// ---------------------------------------------------------------------------
// Created:     11 September 2009 by cnwcs5:1
// Purpose:     CCMS 1061 - Gate Config Changes  
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	// this method checks that we are not using the same tag reader
	// more than once for the interchange area
	self.validateRFIDTagReaders;
	
	inheritMethod();

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
</Class>
