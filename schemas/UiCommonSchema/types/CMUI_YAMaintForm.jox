    <JadeMethod name="handleBadCriteriaValue" id="84655a0b-b449-49a0-a096-af3baa1de4cc">
        <source>handleBadCriteriaValue(exObj: Exception): Integer;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
18 Mar 2009	cnwrd1	Initial creation par 19084
09 Sep 2009	cnwkpd1	PAR #20504 - Add ID masking to YA Criteria

*/

vars
	errStr : String;
begin

	if exObj.errorCode = ErrYACriteriaNotFound then 
		errStr := 'Error (' &amp; exObj.errorCode.String &amp; '). ' &amp; exObj.extendedErrorText;
		app.msgBox(errStr, 'Error', MsgBox_OK_Only);
		return Ex_Resume_Next;
	endif;
	return Ex_Pass_Back;


epilog

end;</source>
