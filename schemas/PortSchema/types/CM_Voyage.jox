    <JadeMethod name="setProxyVoyageCellullStructure" id="1b52aada-35f7-46fd-97e1-3d89b1033dfc">
        <updating/>
        <source>setProxyVoyageCellullStructure(_pxyCellularVoyage : CM_CellularVoyageStructure) updating;
//--------------------------------------------------
// Created:	03 April 2006 By: cnwgd1
// 08 Aug 2024 	navhn30  Bug 65480: CUX | Issues on POST/PUT Voyage when includes Cargo structure flags
//--------------------------------------------------
vars

begin
	self.raiseExceptionIfNotTransient(method);
	
	if self.myCellularVoyageStructure &lt;&gt; null and _pxyCellularVoyage &lt;&gt; null  then		// 08.08.2024	navhn30		TFS #65480
		app.raiseUnexpectedProgramError(class.name, method.name, 'myCellularVoyageStructure reference is already set');
		return;
	endif;
	
	self.myCellularVoyageStructure := _pxyCellularVoyage;
	
end;</source>
        <Parameter name="_pxyCellularVoyage" type="CM_CellularVoyageStructure"/>
    </JadeMethod>
    <JadeMethod name="setProxyVoyageFromAPI" id="2df458fb-28e0-4078-8ac8-02439298219c">
        <updating/>
        <source>setProxyVoyageFromAPI(	_callSign,
						_voyageCode,
						_inwardsCode,
						_externalCode,
						_remarks,
						_vesselName,
						_imo						: String;
						_status						: Integer;
						_arrivalDateTime,
						_departureDateTime,
						_estimatedArrivalDateTime,
						_estimatedDepartureDateTime	: TimeStamp;
						_operator					: CM_Operator input;
						_trade 						: CM_Trade input;
						_shippingLine 				: CM_ShippingLine input;
						_globalVoyage				: CM_VoyageGlobal input;
						_terminal					: CM_Terminal;
						_allValidOperators			: CM_OperatorByCodeDict input) updating;
/*		

Purpose:			Update a subset of proxy details without clearing everything else!

Parameters:			

Return Value:		

Date				Who		Reason
19 July 2024		navmd1	Initial creation TFS 64828
22 July 2024		navlw1	ChangeRequest 63839: NSW | OnePort - Uniqueness of Inward and External Code
22 July 2024		navdap1	TFS 65286 CUX | Include cargo structure flags in voyage API
EUP | FR 54871 - EDI Message Administration Advanced Filters not working
*/

vars

begin
	self.callSign := _callSign;
	self.lloydsNumber := _imo;
	self.remarks := _remarks;
	self.vesselName := _vesselName;
	
	self.estimatedArrivalDT := _estimatedArrivalDateTime;
	self.estimatedDepartureDT := _estimatedDepartureDateTime;
	
	// Inverses
	self.setArrivalDT(_arrivalDateTime);
	
	if _departureDateTime.isValid then
		self.departedDT := _departureDateTime;
	else
		self.departedDT := null;
	endif;
	
	self.code := _voyageCode;
	self.myOperator := _operator;
	self.myTrade := _trade;
	
	//self.setMyVoyageGlobalArrival(_globalVoyage);
	
	self.myTerminal := _terminal;
	self.status := _status;		// needs to be after terminal is set
	
	_allValidOperators.copyNoDups(self.allOperators);		// TFS 65286
	self.myShippingLine := _shippingLine;
	
	if self.myHMSVoyageData &lt;&gt; null then
		self.myHMSVoyageData.setDatesFromVoyageUpdate(_arrivalDateTime, _departureDateTime);
	endif;
	
	// navlw1 #63839 added .trimBlanks to fields below
	self.inwardCode := _inwardsCode.trimBlanks;
	self.inwardCodeAuto := _inwardsCode.trimBlanks;
	
	self.voyageCodeExternal := _externalCode.trimBlanks;
	self.voyageCodeExternalAuto := _externalCode.trimBlanks;
	
epilog

end;</source>
        <Parameter name="_callSign" type="String"/>
        <Parameter name="_voyageCode" type="String"/>
        <Parameter name="_inwardsCode" type="String"/>
        <Parameter name="_externalCode" type="String"/>
        <Parameter name="_remarks" type="String"/>
        <Parameter name="_vesselName" type="String"/>
        <Parameter name="_imo" type="String"/>
        <Parameter name="_status" type="Integer"/>
        <Parameter name="_arrivalDateTime" type="TimeStamp"/>
        <Parameter name="_departureDateTime" type="TimeStamp"/>
        <Parameter name="_estimatedArrivalDateTime" type="TimeStamp"/>
        <Parameter name="_estimatedDepartureDateTime" type="TimeStamp"/>
        <Parameter name="_operator" type="CM_Operator" usage="input"/>
        <Parameter name="_trade" type="CM_Trade" usage="input"/>
        <Parameter name="_shippingLine" type="CM_ShippingLine" usage="input"/>
        <Parameter name="_globalVoyage" type="CM_VoyageGlobal" usage="input"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_allValidOperators" type="CM_OperatorByCodeDict" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setProxyVoyageFromEDI" id="50411935-e894-4c8e-81a5-2bff24bb9807">
        <updating/>
        <source>setProxyVoyageFromEDI(ediVoyage: CM_EDIVoyageTI; isNew: Boolean ) updating;
// ---------------------------------------------------------------------------
// Created:	13 February 2011 By Graeme Black cnwgb1
// Status: 	
// Purpose:	Copy new information from EDI in a way that doesn't destroy all the 
// 			current information that isn't captured by EDI
//			(PAR 26982 broke the camels back.)
//			Obviously this should only be called from EDI.
/****Changes

Date		Name	TFS#			Description
============================================================================
07/07/2011	cnwcs5	ccms mes 2084 / 
					par 27317  		Handle change of vessel
30 Apr 2012	cnwrs1	Par 29395  		Check the vessel.structureType not CellularStructure type
15 Mar 2013	PJS		PAR # 31232
18 Jan 2018 cnwma1  Bug # 36581: 	ADP - Voyage Integration Issue
15/06/2018 	JLGNS1	Bug 38933: 		ADP - Voyage Integration Issue (TFS7827)
12/10/2018	jlgka1	39346			ADP - Voyage EDI Add Modify option.
16 May 2019	jlgdi1	44762			Set the displayOption attribute to default (VoyageDisplayAlways) ONLY for new voyage
03 Nov 2022	jlika1	54892			POB - Vessel, Voyage and Movement EDI Messages
20 Apr 2023	jlika1	57614			POB - QShips Agent Voyage Number as Voyage External Reference in MTN (agent_voyage_number mapped to external reference.)
01 Sep 2023	jlika1	59854			POB - 59168 - 55715.040 Addition of Movements to Existing Voyages
25 Sep 2023	jlika1	60540			POB - STATUS_TYPE_NAME "CANC" shown as Planned in MTN
19 Oct 2023	navdap1	TFS 60921		POB - QShips External Web Service Last Successful Date Time
29 Nov 2023	navdap1	TFS 61530		POB - QSHIPS - Error When Voyage Movements Updated
29 Nov 2023	navdap1	TFS 61531		POB - QSHIPS - Multiple Identical Shift Movements for Same Voyage
06 Dec 2023	navdap1	TFS 61712		POB - 1090 loading Qships voyage shift information for an existing voyage
11 Dec 2023	navdap1	TFS 61709		POB - QShips - Update to Voyage Removes Manually Added Operators
07 Mar 2023	navadp1	TFS 62133		POB - QShips - Error Preventing Data Being Shown in EDI Ops
23 Aug 2024 navsp1  TFS 63842       ChangeRequest 63842: NSW | OnePort Integration Dev
18 Sep 2024 navsp1  TFS 66169       TFS Defect 66169: NSW - OnePort - voyageNoIn and voyageNoOut field mapping
08 Nov 2024 navcs2	MTN-33359		NSW - Oneport - Some fields are not mapped from Oneport message as expected
05 Dec 2024	navdap1	MTN-33516 		NSW | OnePort - Voyage Already Exists With External Code Error
14 Feb 2025 navsp1  JIRA-34037      NSW | Invoice Line not Generated for Voyage Resource
14 Mar 2025 navsp1  JIRA-34340      NSW | 34310.010 OnePort Integration Voyage Creation
============================================================================*/
vars
	vessel 				: CM_Vessel;
	operatorCode 		: String;
	validOperator 		: CM_Operator;
	operators 			: CM_OperatorByCodeDict;
	vesselChanged		: Boolean;					// cnwcs5 par 27317
    tempBerth       	: HMS_Berth;                // cnwgb1 par 27935 
	arrivalClass		: HMS_TidalClass;
	depatureClass 		: HMS_TidalClass; 			// cnwrd1 par 36509
	ediMovement			: CM_EDIQshipsMovementTI;
	addMovement			: HMS_VoyageMovement;
	defaultTidal		: HMS_TidalClass;
	pilot				: HMS_Pilot;
	pilotObject			: HMS_MovementPilotDetails;
	fromBerth			: HMS_Berth;
	toBerth				: HMS_Berth;
	harbour				: HMS_Harbour;	
	ediMovementCanc		: HMS_VoyageMovement;
	foundMovement		: HMS_VoyageMovement;
	voyageData			: HMS_VoyageData;
	visitType			: HMS_VisitType;			// 08 Nov 2024 navcs2	MTN-33359
	differenceMins      : Integer;
	shippingAgent		: CM_ShippingAgent;			// 08 Nov 2024 navcs2	MTN-33359
	isChargeForMove		: Boolean;					//JIRA-34037
	extDef				: CM_ExternalWebServiceDef; //JIRA-34037
	isNSW				: Boolean;					//JIRA-34340
begin
	self.raiseExceptionIfNotTransient(method);

	self.myTerminal 	:= ediVoyage.myEDIData.ediConfig.myTerminal;
	
	//Are we NSW? NSW want to charge for movements, POB don't					//JIRA-34037
	isChargeForMove := false;													//JIRA-34037
	isNSW			:= false;													//JIRA-34340
	extDef := app.myRoot.getFirstActiveEWSForEndpoint(ETRow_NswVesselMovements);//JIRA-34037
	if extDef &lt;&gt; null then														//JIRA-34037
		isChargeForMove := true;												//JIRA-34037
		isNSW			:= true;												//JIRA-34340
	endif;																		//JIRA-34037
	
	self.code			:= ediVoyage.getVoyageCode();
	//if self.isAutomaticProcess() then						//TFS 66169				// MTN-33516
	if self.myTerminal.getConfig(AllowDupVoyageInOutCodes).Boolean then				// MTN-33516
		self.inwardCodeAuto := ediVoyage.getInwardCode();	//TFS 66169
	else													//TFS 66169
		self.inwardCode		:= ediVoyage.getInwardCode();
	endif;
	self.callSign   	:= ediVoyage.callSign;						//18/01/2018 cnwma1 BUG #36581
	self.lloydsNumber	:= ediVoyage.lloydsNumber; 					//18/01/2018 cnwma1 BUG #36581
	self.vesselCode 	:= ediVoyage.vesselCode;					//Bug 38933
	self.vesselName		:= ediVoyage.vesselName;					// 54892
	self.externalRef    := ediVoyage.externalRef;
	//if self.isAutomaticProcess() then								//TFS 66169		// MTN-33516
	if self.myTerminal.getConfig(AllowDupVoyageInOutCodes).Boolean then				// MTN-33516
		self.voyageCodeExternalAuto	:= ediVoyage.voyageCodeExternal;//TFS 66169
	else															//TFS 66169
		self.voyageCodeExternal	:= ediVoyage.voyageCodeExternal; 	//TFS 66169
	endif;															//TFS 66169
	//vessel := app.myRoot.getVesselByName(_ediVoyage.vesselName); //18/01/2018 cnwma1 BUG #36581
	
	if ediVoyage.vesselCode &lt;&gt; null then						//Bug 38933
		vessel := app.myRoot.allVessels[ediVoyage.vesselCode];	//Bug 38933
	endif;														//Bug 38933
	
	if vessel = null then										//Bug 38933
		if ediVoyage.lloydsNumber &lt;&gt; null then			//18/01/2018 cnwma1 BUG #36581
			vessel := app.myRoot.getVesselByLloydsNumber(ediVoyage.lloydsNumber,true);
		endif;
	endif;														//Bug 38933
	
	if vessel = null then
		if  ediVoyage.callSign &lt;&gt; null then         //18/01/2018 cnwma1 BUG #36581
			vessel := app.myRoot.getVesselByCallSign(ediVoyage.callSign,true);
		endif;
	endif;
	
	if vessel= null then							//18/01/2018 cnwma1 BUG #36581
		vessel := app.myRoot.getVesselByName(ediVoyage.vesselName);
	endif;
	
	if vessel= null then											// 08 Nov 2024 navcs2	MTN-33359
		vessel := app.myRoot.allVessels[ediVoyage.vesselName];		// 08 Nov 2024 navcs2	MTN-33359
	endif;															// 08 Nov 2024 navcs2	MTN-33359
	
	if vessel &lt;&gt; null then
		vesselChanged := self.vesselCode &lt;&gt; vessel.code;	// cnwcs5 par 27317
		
		self.vesselName := vessel.name;
		self.vesselType := vessel.vesselType;
		self.vesselCode := vessel.code;
		
		if ediVoyage.messageMode &lt;&gt; CM_EDITrackedItem.EDI_ACTION_MODIFY then // jlgka1 TFS 39346 11/10/2018 --&gt; 				
			self.setHMSVesselDataForEDI(vessel, self.myTerminal, isNew ); 
		endif; // jlgka1 TFS 39346 11/10/2018 &lt;--
	endif;

	if isNew then
		if ediVoyage.isKindOf(CM_EDIQshipsVoyageTI) then
			if isNSW then									//JIRA-34340
				self.displayOption := VoyageDisplayDefault;	//JIRA-34340
			else
				self.displayOption := VoyageDisplayNever; 
			endif;
		else
			self.displayOption := VoyageDisplayAlways; 
		endif;
	endif;
		
	if vesselChanged or	// cnwcs5 par 27317
		isNew then 		// cnwgb1 10.11.2010 26219
		// 31232
		
		
		/* PAR 33644 removed not required.
		// non planned non worked to be removed eventually
		if vessel &lt;&gt; null and vessel.myCellularVesselStructure &lt;&gt; null then  // 31232
			
			// 31232 changes - vessel chas individual structural elements
			// 
			//if vessel.structureType = CellularStructure then 
			if not vessel.structureIncludesRORO then
				self.isNonPlannedVoyage	:= false;
				self.isNonWorkedVoyage	:= false;
			//elseif vessel.structureType = CellularStructureRORO then  // 31232
			elseif vessel.structureIncludesRORO  then
				self.isNonPlannedVoyage	:= false;
				self.isNonWorkedVoyage	:= true;
			endif;
		elseif vesselChanged then					// cnwcs5 par 27317
			// the new vessel has no cellular structure
			self.isNonPlannedVoyage	:= false;		// cnwcs5 par 27317
			self.isNonWorkedVoyage	:= false;		// cnwcs5 par 27317
		endif;
		*/
		self.useVoyageAllocations := true;			//cnwgb1 26573 8.3.2011 To Be Enhanced
	endif;


	arrivedDT 		:= ediVoyage.arriveTime;
	departedDT 		:= ediVoyage.departureDT;

	if arrivedDT = null and ediVoyage.scheduledArrivalDT &lt;&gt; null then		// MES1008 JMH there are two attributes that are the same thing, use whichever one they have selected on file format
		arrivedDT 	:= ediVoyage.scheduledArrivalDT;
	endif;
	if departedDT = null and ediVoyage.scheduledDepartureDT &lt;&gt; null then
		departedDT 	:= ediVoyage.scheduledDepartureDT;
	endif;
	
	self.arrivedDT := arrivedDT;
	self.departedDT := departedDT;
	self.estimatedArrivalDT := ediVoyage.scheduledArrivalDT;	//09 Nov 2017	NDL	TFS 7407
	self.estimatedDepartureDT := ediVoyage.scheduledDepartureDT;	//09 Nov 2017	NDL	TFS 7407
	
	
	self.myOperator := app.myRoot.allOperators[ediVoyage.operatorCode];
	// TFS 62133 Don't set trade and shipping line to blank, just leave the voyage values for Qships voyages
	// (Qships doesn't know about trade and shipping line, we just get it from the vessel)
	if not ediVoyage.isQshipsVoyageTI() then
		self.myTrade := app.myRoot.allTradesByDescription[ediVoyage.tradeDesc];
	endif;
	
	self.myShippingLine := app.myRoot.allShippingLines[ediVoyage.shippingLineCode];  // 08 Nov 2024 navcs2	MTN-33359
	
	create operators transient;
	foreach operatorCode in ediVoyage.allValidOperatorCodes do
		validOperator := app.myRoot.allOperators[operatorCode];
		if validOperator &lt;&gt; null then
			//operators.add(validOperator);
			operators.addNoDuplicates(validOperator,false);	//10 Jan 2016	NDL	TFS 3188
		endif;
	endforeach;
	
	//10 Jan 2016	NDL	TFS 3188
	if ediVoyage.messageMode &lt;&gt; CM_EDITrackedItem.EDI_ACTION_MODIFY then // jlgka1 TFS 39346 11/10/2018 --&gt;
		// TFS 61709 if this is a Qships voyage, don't clear the existing operators 
		// Because operators can be added and Qships doesn't know about them
		if not ediVoyage.isQshipsVoyageTI() then
			self.allOperators.clear();
		endif;
	endif;																 // jlgka1 TFS 39346 11/10/2018 &lt;--
	
	if not operators.isEmpty then		
		// TFS 61709 if this is a Qships voyage, don't clear the existing operators 
		// Because operators can be added and Qships doesn't know about them
		if not ediVoyage.isQshipsVoyageTI() then
			self.allOperators.clear(); // jlgka1 TFS 39346 11/10/2018 
		endif;
		foreach validOperator in operators do
			self.allOperators.addNoDuplicates(validOperator,false);
		endforeach;
	endif;
		
	// Now update the HMS Voyage Data
	if vessel &lt;&gt; null and vessel.hasHarbourDetails() then		// 2/9/19 MAP TFS46373
	
		//cnwrd1 par 36509 14.7.15
		if ediVoyage.tidalClassArrival &lt;&gt; null then
			arrivalClass := app.myRoot.allTidalClasses[ediVoyage.tidalClassArrival];		
		endif;
		
		if ediVoyage.tidalClassDeparture &lt;&gt; null then
			depatureClass := app.myRoot.allTidalClasses[ediVoyage.tidalClassDeparture];		
		endif;
		
		if arrivalClass &lt;&gt; null or depatureClass &lt;&gt; null then
			self.myHMSVoyageData.setTidalClasses( arrivalClass, depatureClass);
		endif;
		
	
		self.myHMSVoyageData.setDatesFromVoyageUpdate(arrivedDT, departedDT);
		if  self.myHMSVoyageData.allVoyageMovements.size = 0 then
            if vessel &lt;&gt; null then 
                tempBerth := vessel.getDefaultBerth(self.myTerminal.myHarbour); //cnwgb1 PAR 27935 5.8.2011
            endif;
			self.myHMSVoyageData.setProxyDefaultVoyageMovements( tempBerth, null, app.myPassport );//cnwgb1 PAR 27935 5.8.2011
		endif;
		
		//08 Nov 2024 navcs2	MTN-33359 Start
		voyageData := self.myHMSVoyageData;			
		visitType := app.myRoot.allVisitTypes[ediVoyage.visitType];
		shippingAgent := app.myRoot.allShippingAgentsByCode[ediVoyage.shippingAgent];
		if voyageData &lt;&gt; null and visitType &lt;&gt; null then
			voyageData.setMyVisitType(visitType);
		endif;
		if voyageData &lt;&gt; null and shippingAgent &lt;&gt; null then
			voyageData.setShippingAgent(shippingAgent);
		endif;
		// 08 Nov 2024 navcs2	MTN-33359 End
		
		//Ability to add movements
		if ediVoyage.isKindOf(CM_EDIQshipsVoyageTI) and ediVoyage.messageMode = CM_EDITrackedItem.EDI_ACTION_UPDATE then
			harbour := self.myTerminal.myHarbour;
			defaultTidal := app.myRoot.allTidalClasses.first();
			// TFS 62133 Make sure we still have tidal classes (they aren't set when the proxy voyage is created)
			if self.myHMSVoyageData &lt;&gt; null then
				self.myHMSVoyageData.setTidalClasses(defaultTidal, defaultTidal);
			endif;
			foreach ediMovement in ediVoyage.CM_EDIQshipsVoyageTI.allQshipsMovementTIs do
				if ediMovement.moveType = HMSMovementTypeCanceledDepart then
					voyageData := self.myHMSVoyageData;			
					foundMovement := null;
					//Find the Departure movement
					foreach ediMovementCanc in voyageData.allVoyageMovements do
						if ediMovementCanc.moveType = HMSMovementTypeDeparture then
							//When found break to continue working on the logic that will add the cancel departure movement to the departure movement.
							foundMovement := ediMovementCanc;
							break;
						endif;
					endforeach;
					//add the cancel departure movement to the departure movement.
					if foundMovement &lt;&gt; null then
						//Create the Cancel Movement First
							fromBerth := harbour.allBerths[ediMovement.fromBerth];
							toBerth := harbour.allBerths[ediMovement.toBerth];
							create addMovement transient;
							addMovement.setProxyDefaultsForVoyage(self.myHMSVoyageData, ediMovement.moveType, app.myPassport);
							addMovement.setOccursOnDT(ediMovement.occursOnDT);
							addMovement.setSideTo(ediMovement.sideTo);
							addMovement.setTidalClass(defaultTidal);
							addMovement.setPropertyValue(HMS_VoyageMovement::chargeForMove.name, isChargeForMove);		//JIRA-34037
							addMovement.setMoveStatus(ediMovement.qshipStatus);
							addMovement.setPropertyValue(HMS_Movement::myBerth.name, toBerth);	// TFS 60921
							//addMovement.setMyBerth(toBerth);									// TFS 60921
							//addMovement.setNextMovementBerthPrevious(toBerth);				// TFS 60921
							
							pilot := app.myRoot.allPilots[ediMovement.pilotCode];
							
							if pilot &lt;&gt; null then
								create pilotObject transient;
								pilotObject.setProxy(pilot, null, addMovement, null);			
							endif;
							
							ediMovementCanc.setMyCancelledMovement(addMovement);
							ediMovementCanc.setOccursOnDT(addMovement.occursOnDT.addDays(2));
					endif;				
				elseif ediMovement.moveType = HMSMovementTypeArrival then
					voyageData := self.myHMSVoyageData;	
					foundMovement := null;
					//Find the Arrival movement			// TFS 61530
					foreach ediMovementCanc in voyageData.allVoyageMovements do
						if ediMovementCanc.moveType = HMSMovementTypeArrival then
							//When found break to continue working on the logic that will add the cancel departure movement to the departure movement.
							foundMovement := ediMovementCanc;
							break;
						endif;
					endforeach;					
					if foundMovement &lt;&gt; null then
						//Update Arrival Movement
						fromBerth := harbour.allBerths[ediMovement.fromBerth];
						toBerth := harbour.allBerths[ediMovement.toBerth];
						foundMovement.setOccursOnDT(ediMovement.occursOnDT);					// TFS 61530
						foundMovement.setSideTo(ediMovement.sideTo);							// TFS 61530
						foundMovement.setTidalClass(defaultTidal);								// TFS 61530
						foundMovement.setPropertyValue(HMS_VoyageMovement::chargeForMove.name, isChargeForMove);		// TFS 61530 //JIRA-34037
						foundMovement.setMoveStatus(ediMovement.qshipStatus);					// TFS 61530
						foundMovement.setPropertyValue(HMS_Movement::myBerth.name, toBerth);	// TFS 61530
						//ediMovementCanc.setMyBerth(toBerth);									// TFS 60921
						//ediMovementCanc.setNextMovementBerthPrevious(toBerth);				// TFS 60921
						
						pilot := app.myRoot.allPilots[ediMovement.pilotCode];
						
						if pilot &lt;&gt; null then
							create pilotObject transient;
							pilotObject.setProxy(pilot, null, ediMovementCanc, null);			
						endif;
					endif;
				elseif ediMovement.moveType = HMSMovementTypeDeparture then
					voyageData := self.myHMSVoyageData;		
					foundMovement := null;
					//Find the Departure movement
					foreach ediMovementCanc in voyageData.allVoyageMovements do
						if ediMovementCanc.moveType = HMSMovementTypeDeparture then
							//When found break to continue working on the logic that will add the cancel departure movement to the departure movement.
							foundMovement := ediMovementCanc;
							break;
						endif;
					endforeach;					
					if foundMovement &lt;&gt; null then
						//Update Departure Movement
						fromBerth := harbour.allBerths[ediMovement.fromBerth];
						toBerth := harbour.allBerths[ediMovement.toBerth];
						foundMovement.setOccursOnDT(ediMovement.occursOnDT);					// TFS 61530
						foundMovement.setSideTo(ediMovement.sideTo);							// TFS 61530
						foundMovement.setTidalClass(defaultTidal);								// TFS 61530
						foundMovement.setPropertyValue(HMS_VoyageMovement::chargeForMove.name, isChargeForMove);		// TFS 61530 //JIRA-34037
						foundMovement.setMoveStatus(ediMovement.qshipStatus);					// TFS 61530
						foundMovement.setPropertyValue(HMS_Movement::myBerth.name, toBerth);	// TFS 61530
						//ediMovementCanc.setMyBerth(toBerth);									// TFS 60921
						//ediMovementCanc.setNextMovementBerthPrevious(toBerth);				// TFS 60921
						
						pilot := app.myRoot.allPilots[ediMovement.pilotCode];
						
						if pilot &lt;&gt; null then
							create pilotObject transient;
							pilotObject.setProxy(pilot, null, ediMovementCanc, null);			
						endif;
					endif;
				elseif ediMovement.moveType = HMSMovementTypeCanceledShift then					
					//--&gt; Update the Shift Movement to Cancel
					voyageData := self.myHMSVoyageData;			
					foundMovement := null;
					//Find the Shift movement to cancel
					foreach ediMovementCanc in voyageData.allVoyageMovements do
						if ediMovementCanc.moveType = HMSMovementTypeShift and (ediMovementCanc.getMyBerth &lt;&gt; null and ediMovementCanc.getMyBerth.code = ediMovement.toBerth) and
							(ediMovementCanc.getMyBerthPrevious &lt;&gt; null and ediMovementCanc.getMyBerthPrevious.code = ediMovement.fromBerth) and ediMovementCanc.occursOnDT = ediMovement.occursOnDT then
							//When found break to continue working on the logic 
							foundMovement := ediMovementCanc;
							break;
						endif;
					endforeach;
					if foundMovement &lt;&gt; null and foundMovement.isTransient then			
						foundMovement.setMoveType(HMSMovementTypeCanceledShift);						
					endif;
				elseif ediMovement.moveType &lt;&gt; HMSMovementTypeArrival and ediMovement.moveType &lt;&gt; HMSMovementTypeDeparture then
					// TFS 61531 See if we can find a Shift movement that matches on to and from berths
					// (it may have a different date/time though)
					voyageData := self.myHMSVoyageData;				// TFS 61712
					foundMovement := null;
					foreach ediMovementCanc in voyageData.allVoyageMovements do
						if ediMovementCanc.moveType = HMSMovementTypeShift and ediMovementCanc.moveType = ediMovement.moveType then
							if ediMovementCanc.getMyBerth &lt;&gt; null and ediMovementCanc.getMyBerth.code = ediMovement.toBerth and ediMovementCanc.getMyBerthPrevious &lt;&gt; null and ediMovementCanc.getMyBerthPrevious.code = ediMovement.fromBerth then
								foundMovement := ediMovementCanc;
								break;
							endif;
						endif;
					endforeach;
					if ediMovement.clearBerthTime &lt;&gt; null and ediMovement.secureBerthTime &lt;&gt; null then						//TFS 63842	
						differenceMins := ediMovement.clearBerthTime.getDifferenceInMinutes(ediMovement.secureBerthTime);	//TFS 63842	
					endif;																									//TFS 63842	
					// TFS 61531 start
					if foundMovement &lt;&gt; null then
						// Update the Shift movement
						fromBerth := harbour.allBerths[ediMovement.fromBerth];
						toBerth := harbour.allBerths[ediMovement.toBerth];
						foundMovement.setOccursOnDT(ediMovement.occursOnDT);
						foundMovement.setSideTo(ediMovement.sideTo);
						foundMovement.setTidalClass(defaultTidal);
						foundMovement.setPropertyValue(HMS_VoyageMovement::chargeForMove.name, isChargeForMove);		//JIRA-34037 
						foundMovement.setMoveStatus(ediMovement.qshipStatus);
						foundMovement.setPropertyValue(HMS_Movement::myBerth.name, toBerth);
						foundMovement.setPropertyValue(HMS_Movement::myBerthPrevious.name, fromBerth);
						foundMovement.setStreamingTime(differenceMins);														//TFS 63842
					else
						// create one
						fromBerth := harbour.allBerths[ediMovement.fromBerth];
						toBerth := harbour.allBerths[ediMovement.toBerth];
						create addMovement transient;
						addMovement.setProxyDefaultsForVoyage(self.myHMSVoyageData, ediMovement.moveType, app.myPassport);
						addMovement.setOccursOnDT(ediMovement.occursOnDT);
						addMovement.setSideTo(ediMovement.sideTo);
						addMovement.setTidalClass(defaultTidal);
						addMovement.setPropertyValue(HMS_VoyageMovement::chargeForMove.name, isChargeForMove);			//JIRA-34037
						addMovement.setMoveStatus(ediMovement.qshipStatus);
						addMovement.setPropertyValue(HMS_Movement::myBerthPrevious.name, fromBerth);	// TFS 61531
						addMovement.setPropertyValue(HMS_Movement::myBerth.name, toBerth);		// TFS 60921
						//addMovement.setMyBerth(toBerth);										// TFS 60921
						//addMovement.setNextMovementBerthPrevious(toBerth);					// TFS 60921
						addMovement.setStreamingTime(differenceMins);														//TFS 63842
						
						pilot := app.myRoot.allPilots[ediMovement.pilotCode];
						
						if pilot &lt;&gt; null then
							create pilotObject transient;
							pilotObject.setProxy(pilot, null, addMovement, null);			
						endif;				
					endif;		// TFS 61531 end
				endif;				
			endforeach;
			
			self.updateMovementsSequence();
		endif;				
	endif;
	
epilog	
	delete operators;
end;</source>
        <Parameter name="ediVoyage" type="CM_EDIVoyageTI"/>
        <Parameter name="isNew" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setProxyVoyageGeneralCargo" id="e20588f3-f866-4fb2-95da-0f83739c0572">
