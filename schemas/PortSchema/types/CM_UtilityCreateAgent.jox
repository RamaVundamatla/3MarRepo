    <JadeMethod name="utlCreateCarrier" id="62692f28-ea6b-4995-847b-1160c89b9601">
        <source>utlCreateCarrier(pProxyCarrier:CM_Carrier; pNewCarrier:CM_Carrier output;
				_passport : CM_Passport input);
// ---------------------------------------------------------------------------
// Created:     16 July 2001 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	self.initialiseActivity();
	
	app.setContinueCMExceptions(true);
	
	app.myValCA.valCarrier(pProxyCarrier);
    
	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	   
	app.setContinueCMExceptions(false);

	create pNewCarrier persistent;
	
	pNewCarrier.setForCreate(pProxyCarrier, _passport);
	
	if _passport.noErrors then
		self.myCreateAuditAgent.audCreateGeneric(pNewCarrier);
	endif;
	
	// ### TFS 51853 27AUG2021 NAVAB1
	if _passport.isOpsViewEnabled(null) then
		pNewCarrier.createOpsViewEWSActivity(BGP_OpsViewWSRequest.OPS_ACTION_CREATE,
											 BGP_OpsViewWSRequest.OPS_TYPE_CARRIER,
											 pNewCarrier);
	endif;


end;</source>
        <Parameter name="pProxyCarrier" type="CM_Carrier"/>
        <Parameter name="pNewCarrier" type="CM_Carrier" usage="output"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
