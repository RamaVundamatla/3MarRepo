    <JadeMethod name="pilotExemptEnable" id="dffd5e46-a163-48fb-80f5-36b670f21e48">
        <source>pilotExemptEnable() protected;
//--------------------------------------------------
// Created:	11 October 2007 By cnwvu1
//--------------------------------------------------
//15 May 2019	jlgsl4	TFS 44438 - PEL1 - Multiple Pilot Launches for one movement

vars

begin

	if (self.mode = self.Mode_Add) or (self.mode = self.Mode_Update) then
		// Disable / Enable pilot movement services when the checkBox Pilot Exempt is clicked
	//	self.cmbPilot.enabled			:= not self.ckbxPilotExempt.value;	
	//	self.cmbPilot.text				:= '';
		self.cmbPilotLaunch.enabled		:= not self.ckbxPilotExempt.value;
		self.cmbPilotLaunch.text		:= '';
		self.cbxLaunchPosn.enabled		:= not self.ckbxPilotExempt.value;
		self.tbxLaunchOrderAct.enabled	:= not self.ckbxPilotExempt.value;
		self.tbxLaunchRelative.enabled	:= not self.ckbxPilotExempt.value;
		self.lblMins.enabled			:= not self.ckbxPilotExempt.value;
		self.lstPilots.enabled			:= not self.ckbxPilotExempt.value;	//30 Oct 2018	NDL	TFS 41662
		self.tblPilotLaunch.enabled		:= not self.ckbxPilotExempt.value; // TFS 44438
	endif;

end;
</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="populateBollardResources" id="5ad0cec2-7d73-4fe4-863e-b98a61f4e761">
        <updating/>
        <source>populateBollardResources(_toBerth : HMS_Berth) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 Oct 2022	navsj20	ChangeRequest 54739: EUP - PLAN - Berth planning by bollards
05 Sep 2023	navdap1	TFS 59472 EUP | FR 56588 Berth planning by bollards Remedial
*/

vars
	resource :	HMS_Resource;
	idx: Integer;
begin
	self.cmbBowMarkBollard.clear;
	self.cmbSternMarkBollard.clear;
	self.cmbBridgeMarkBollard.clear;
	self.txtBowMarkMeter.text		:= null;
	self.txtBridgeMarkMeter.text	:= null;
	self.txtSternMarkMeter.text 	:= null;
	if _toBerth &lt;&gt; null then
		//foreach resource in _toBerth.allBerthResources where resource.myResourceType.isBollard do 	// TFS 59472
		foreach resource in _toBerth.myWharf.allResources where resource.myResourceType.isBollard do 	// TFS 59472
			idx	:=	self.cmbBowMarkBollard.addItem(resource.code);
			self.cmbBowMarkBollard.itemObject[idx] := resource;
			idx	:=	self.cmbSternMarkBollard.addItem(resource.code);
			self.cmbSternMarkBollard.itemObject[idx] := resource;
			idx	:=	self.cmbBridgeMarkBollard.addItem(resource.code);
			self.cmbBridgeMarkBollard.itemObject[idx] := resource;
		endforeach;
	endif;
end;</source>
        <Parameter name="_toBerth" type="HMS_Berth"/>
    </JadeMethod>
    <JadeMethod name="populateCmbMovements" id="d72ab4f6-dd2f-4a2e-b586-0d452c55aedd">
        <source>populateCmbMovements( _voyage : CM_Voyage );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 November 2018	jlgndl1	Initial creation	TFS 42043

*/

vars

	voyageData : HMS_VoyageData;
	allMovements : HMS_VoyageMovementByDateDict;
	movement : HMS_VoyageMovement;
	displayStr : String;
	cancelledMovements : HMS_VoyageMovementArray;
	unLinkedCancelled : HMS_VoyageMovement;	//10 Dec 2018	NDL	TFS 42043

begin

	self.cmbMovements.clear();

	if _voyage &lt;&gt; null then
		voyageData := _voyage.myHMSVoyageData;
	endif;
	if voyageData &lt;&gt; null then
		if voyageData.isArchived() then
			allMovements := voyageData.allVoyagetMovementsArchived;
		else
			allMovements := voyageData.allVoyageMovements;
		endif;
	endif;

	if allMovements = null or allMovements.isEmpty then
		return;
	endif;
	
	create cancelledMovements transient;
	foreach movement in allMovements do
		displayStr := " " &amp; movement.moveType &amp; '   ' &amp; self.systemToLocalTime(movement.occursOnDTNEW).shortCurrentLocaleFormat();
		self.cmbMovements.itemObject[ self.cmbMovements.addItem( displayStr )] := movement;
		movement.getMyCancelledMovements( cancelledMovements );
	endforeach;
	
	//10 Dec 2018	NDL	TFS 42043
	unLinkedCancelled := _voyage.findUnlinkedCancelledShift();
	if unLinkedCancelled &lt;&gt; null then
		cancelledMovements.add( unLinkedCancelled );
	endif;
	
	foreach movement in cancelledMovements do
		displayStr := movement.moveType &amp; '   ' &amp; self.systemToLocalTime(movement.occursOnDTNEW).shortCurrentLocaleFormat();
		self.cmbMovements.itemObject[ self.cmbMovements.addItem( displayStr )] := movement;
	endforeach; 

epilog

	delete cancelledMovements;

end;</source>
        <Parameter name="_voyage" type="CM_Voyage"/>
    </JadeMethod>
