    <JadeMethod name="rel821_par31305" id="129beb04-89c3-47b7-9b27-840a62f6bee1">
        <source>rel821_par31305();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 March 2013	cnwer1	Initial creation PAR 31305

*/

vars
	term : CM_Terminal;
	nullVoy :CM_Voyage;
	theGraphic : CM_VoyageLayoutGraphic;
begin
	
	foreach term in CM_Terminal.instances do
		nullVoy:=term.getNullVoyage;
		if nullVoy = null then
			continue;
		endif;
		if nullVoy.myLayoutGraphic = null then
			beginTransaction;
			create theGraphic;
			nullVoy.setMyLayoutGraphic(theGraphic);
			commitTransaction;
		endif;	
	endforeach;
epilog

end;</source>
    </JadeMethod>
