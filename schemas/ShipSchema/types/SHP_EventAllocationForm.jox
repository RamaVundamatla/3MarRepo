    <JadeMethod name="doSave" id="1adc3f51-5249-47a9-8d56-47a64515b253">
        <updating/>
        <source>doSave() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 January 2017	cnwns1	Initial creation

*/

vars
	ownerType : Integer;
	theReturn : Integer;
	eventTypes : CM_EventTypesArray;
	pxtEventTypes : CM_EventTypesArray;
begin

	create eventTypes transient;
	self.mulColumns.getSelected(eventTypes);

	ownerType := self.getOwnerType;
		
	if ownerType = Voyage then
	//do form validation
		while true do
			app.myTrxUA.trxUpdateVoyageAllocEvents(self.myVoyage,eventTypes , app.myPassport);
			if app.myPassport.trxCompletedOK then
				global.beep;
				break;
			else
				theReturn := app.showErrorWarningDialog(app.getErrorString(Voyage) &amp; " Problem",  app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
				if app.myPassport.noErrors and
				   theReturn = IDOK then
					continue;
				endif;
				self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
				return;
			endif;
			break;
		endwhile;
			self.unloadForm();

	elseif ownerType = Vessel then
	//do form validation
		while true do
			app.myTrxUA.trxUpdateVesselAllocEvents(self.myVessel,eventTypes , app.myPassport);
			if app.myPassport.trxCompletedOK then
				global.beep;
				break;
			else
				theReturn := app.showErrorWarningDialog(app.getErrorString(Vessel) &amp; " Problem",  app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
				if app.myPassport.noErrors and
				   theReturn = IDOK then
					continue;
				endif;
				self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
				return;
			endif;
			break;
		endwhile;
			self.unloadForm();

	else
		app.msgBox("Nothing selected to update","Problem",MsgBox_Information_Icon);
	endif;
		
epilog
	delete eventTypes;
end;</source>
    </JadeMethod>
    <JadeMethod name="doShowEventCheckList" id="a5b0109c-9e7f-4503-9465-ff3fbd47fe01">
        <source>doShowEventCheckList(_voyage : CM_Voyage);
/*
Purpose:	TFS 3217		
Date		Who		Reason
02 February 2017	cnwab1	Initial creation
*/

vars

	form 		: SHP_VoyageEventCheckList;

begin
	if _voyage = null then
		app.msgBox(app.getErrorString(SHP_Please_Select_A_Voyage),app.getErrorString(ERR_ErrorBoxTitle), MsgBox_OK_Only);
		return;
	endif;
	
	form := app.loadForm(SHP_VoyageEventCheckList, SHP_Assistant, false, false, true, self.myTerminal, null).SHP_VoyageEventCheckList;	
	
	if form = null then
		return;
	endif;	
	
	
	form.setParentForm(self);
	form.myCurrentVoyage := _voyage;
	

	form.show;


epilog

end;</source>
        <Parameter name="_voyage" type="CM_Voyage"/>
    </JadeMethod>
    <JadeMethod name="doShowEventGroupPicker" id="25f58a61-5616-42c3-bf9e-43127618bd88">
        <source>doShowEventGroupPicker();
/*
Purpose:			
Date		Who		Reason
02 February 2017	cnwab1	Initial creation
*/

vars

	form 		: SHP_VoyageEventGroupCopy;

begin
	
	form := app.loadForm(SHP_VoyageEventGroupCopy, SHP_Assistant, false, false, true, self.myTerminal, null).SHP_VoyageEventGroupCopy;	
	
	if form = null then
		return;
	endif;	
	
	
	form.setParentForm(self);
	form.setFormParent(self);
	

	form.showModal;


epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="getEventName" id="b97b2a88-9632-46c6-8a3d-d783a8ddd089">
        <source>getEventName(_obj : Object):String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 January 2017	cnwns1	Initial creation

*/

vars

begin
	if _obj.isKindOf(CM_EventType) then
		return _obj.CM_EventType.name;
	endif;
	
	return null;
epilog

end;</source>
        <Parameter name="_obj" type="Object"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getOwnerType" id="23608b7f-8eef-4f41-95a7-344059cd7970">
        <source>getOwnerType() : Integer;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 January 2017	cnwns1	Initial creation

*/

vars
	myVoyageNotNull : Boolean;
	myVesselNotNull : Boolean;
begin
	myVoyageNotNull := self.myVoyage &lt;&gt; null;
	myVesselNotNull := self.myVessel &lt;&gt; null;

	if myVoyageNotNull and myVesselNotNull then
		return null;
	elseif myVesselNotNull then
		return Vessel;
	elseif myVoyageNotNull  then
		return Voyage;
	endif;
		
	return null;	
	
epilog

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
