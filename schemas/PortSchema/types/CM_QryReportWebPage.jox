<Class name="CM_QryReportWebPage" id="47282c1a-4ea4-4f59-a35e-459209366d0a">
    <superclass name="CM_Object"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="query"/>
    <CompAttribute name="allRows" id="a8b0b579-2725-41e5-9b6e-45ddc9179f20">
        <type name="StringArray"/>
        <access>readonly</access>
    </CompAttribute>
    <ExplicitInverseRef name="myQryReport" id="32ea45ad-2095-4510-bc4f-f21edc26390e">
        <kind>child</kind>
        <updateMode>automatic</updateMode>
        <embedded/>
        <type name="CM_QryReport"/>
        <access>readonly</access>
        <Inverse name="CM_QryReport::allQryReportWebPages"/>
    </ExplicitInverseRef>
    <JadeMethod name="setForCreate" id="4cb966a8-d2cd-4368-ae13-5422c774201a">
        <updating/>
        <source>setForCreate(_rowArray : StringArray; _qryReport : CM_QryReport input) updating;
// ---------------------------------------------------------------------------
// Created:     04 October 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	tmpRow	: EntTableRow;
	tmpName	: String;
begin
	self.allRows.clear();
	if _rowArray = null then
		return;
	endif;
	_rowArray.copy(self.allRows);
	
//	self.myQryReport := _qryReport;
	
	_qryReport.allQryReportWebPages.add(self);

	
end;</source>
        <Parameter name="_rowArray" type="StringArray"/>
        <Parameter name="_qryReport" type="CM_QryReport" usage="input"/>
    </JadeMethod>
</Class>
