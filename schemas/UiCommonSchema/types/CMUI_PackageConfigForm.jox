	idx := _cmb.addItem(CMUI_EDIDBExtract.EDI_FORMAT_MASTER_PLAN);
	_cmb.itemData[idx] := EDIFileType_BayFile;
	
	idx := _cmb.addItem(CMUI_EDIDBExtract.EDI_FORMAT_ANF);
	_cmb.itemData[idx] := EDIFileType_Anf;
	
	idx := _cmb.addItem(CMUI_EDIDBExtract.EDI_FORMAT_XML_TOLLNZ);
	_cmb.itemData[idx] := EDIFileType_XML_TOLL_PREADVICE;
	
	idx := _cmb.addItem(CMUI_EDIDBExtract.EDI_FORMAT_WWL);
	_cmb.itemData[idx] := EDIFileType_WWLCar;
	
	idx := _cmb.addItem(CMUI_EDIDBExtract.EDI_FORMAT_COPRAR); //cnwrs1 June 2009
	_cmb.itemData[idx] := EDIFileType_Coprar;
	
	idx := _cmb.addItem(CMUI_EDIDBExtract.EDI_FORMAT_MOVINS); //cnwrs1 27 July 2010
