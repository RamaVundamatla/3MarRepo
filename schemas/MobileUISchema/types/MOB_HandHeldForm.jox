    <JadeMethod name="getActiveBulkRelease" id="05714bd9-5937-4165-a988-11c0fab65f21">
        <source>getActiveBulkRelease( _term : CM_Terminal; _type : Integer; _includeWayBill : Boolean; _text : String ):CM_BulkRelease;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 August 2014	cnwndl1	Initial creation	Par 34717 / CCMS 2384
// 13 May 2016	cnwns1	TFS 488 - Multi Timezone Support
*/

vars

	firstBulkRelease : CM_BulkRelease;
	iter : Iterator;
	bulkRelease : CM_BulkRelease;
	truckArray : CM_VehicleArray;
	req : CM_Request;
	roadJob : CM_RoadJob;
	truck : CM_Vehicle;
	now : Date;
	tomorrow : TimeStamp;

begin

	now := app.actualTimeServer.Date;		// 13 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	tomorrow.setDate( now + 1 ); // dict uses reverse date order...

	firstBulkRelease := _term.allBulkReleasesByCodeDate.getAtKeyGeq( _text, tomorrow );
	if firstBulkRelease &lt;&gt; null and firstBulkRelease.code = _text then
		iter := _term.allBulkReleasesByCodeDate.createIterator;
		iter.startAtObject( firstBulkRelease );
		while iter.next( bulkRelease ) do
			if bulkRelease.code &lt;&gt; _text then
				break;
			endif;
			if bulkRelease.status &lt;&gt; BR_ACTIVE then
				continue;
			endif;
			if bulkRelease.type &lt;&gt; _type then
				continue;
			endif;
			if bulkRelease.allowCargoOnMultipleReleases and not _includeWayBill then
				continue;
			endif;
			return bulkRelease;
		endwhile;
		
	endif;

epilog

	delete iter;

end;</source>
        <Parameter name="_term" type="CM_Terminal"/>
        <Parameter name="_type" type="Integer"/>
        <Parameter name="_includeWayBill" type="Boolean"/>
        <Parameter name="_text" type="String"/>
        <ReturnType type="CM_BulkRelease"/>
    </JadeMethod>
    <JadeMethod name="getBRPropsectiveChildCargo" id="a3adf066-79eb-48c5-b0c4-def5f1c46d81">
        <source>getBRPropsectiveChildCargo(	_bulkRelease : CM_BulkRelease;
							_reserveSelection : CM_ReserveSelection;
							_stagedYardLocation : CM_LocationsController;
							_targetLocation : CM_LocationsController;
							_tiArray : CM_TIArray io
							) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 August 2014	cnwndl1	Initial creation	Par 34717 CCMS 2384
19 May 2015	NDL	Par 36127 - Treat assigned cargo on a Release by type as if its a release by id, untill there is none left.
                       I.e choose from the assigned list before we allow generic search.
07 Apr	2017	cnwma1	TFS #4017:PAR38663 STWR - Error 1090 when loading outbound truck
19 May 2017		NDL		TFS 4016	
23/06/2023	navkc1	CR 58406 Task 58408: Jade - Release Request All Tracked Items	

*/

vars

	ti : CM_TrackedItem;
	opTerm : CM_OperatorTerminal;
	reserve : CM_ReserveDetail;
	reason : String;
	reserveDetails: CM_ReserveDetailSet;
	allPreStaged : Boolean;
	tiSet : CM_TISet;
	firstStagingLC : CM_LocationsController;
	outStandingItemCount : Integer;
	stagedItemCount : Integer;
	onTruckCount : Integer;
	allowOtherReleases: Boolean;
	parentTi : CM_TrackedItem;
	childTi : CM_TrackedItem;
	usesCargoGroup : Boolean;	//21 Feb 2018	NDL	TFS 37084
	truck : CM_Vehicle;	//21 Feb 2018	NDL	TFS 37084
	roadJob : CM_Job;	//21 Feb 2018	NDL	TFS 37084
	jobReserveDetails : CM_ReserveDetailSet;	//21 Feb 2018	NDL	TFS 37084
	req : CM_Request;	//21 Feb 2018	NDL	TFS 37084
	allTis	: CM_TISet;
begin

	if _tiArray = null then
		return;
	endif;
	create allTis transient;
	usesCargoGroup := app.isCargoGroupEnabled;	//21 Feb 2918	NDL	TFS 37084
	
	allowOtherReleases := _bulkRelease.allowCargoOnMultipleReleases;
	//16 Oct 2915	NDL	Par 37033 - STW version of staged
	if usesCargoGroup then	//09 Feb 2016	NDL	Par 37479
		create tiSet transient;
		if _targetLocation = null and self.myMobileGenericAgent &lt;&gt; null and self.myMobileGenericAgent.myPackTi &lt;&gt; null then
			parentTi := self.myMobileGenericAgent.myPackTi;
		endif;
		
		if _bulkRelease &lt;&gt; null then	
			if _reserveSelection &lt;&gt; null then
				//11 Dec 2015	NDL	Par 37288
				outStandingItemCount := _reserveSelection.getTotalOutstanding;
				stagedItemCount := _reserveSelection.getTotalStaged(tiSet, firstStagingLC, null);
				//onTruckCount := _reserveSelection.getTotalAssignedInLocation(_targetLocation);
				if _targetLocation &lt;&gt; null then
					onTruckCount := _reserveSelection.getTotalAssignedInLocation(_targetLocation);
				//20 Mar 2017	NDL	TFS 3667
				elseif parentTi &lt;&gt; null then
					foreach childTi in parentTi.allChildren do
						//if _reserveSelection.allTrackedItems.includes( childTi ) then	// 20 Dec 2018	NDL	TFS 38083
						if _reserveSelection.includeTrackedItem( childTi , false) then //23/06/2023	navkc1	CR 58406 Task 58408
							onTruckCount := onTruckCount + childTi.totalQuantity.max(1);
						endif;
					endforeach;
				endif;
				if outStandingItemCount &gt; 0 and outStandingItemCount = ( stagedItemCount + onTruckCount ) then
					foreach ti in tiSet do
					
						//20 Mar 2017	NDL	TFS 3667
						if parentTi &lt;&gt; null then
							if ti.isChild then
								continue;
							endif;
						endif;
						
						_tiArray.addExclusive( ti );
					endforeach;
					return;
				endif;
				
			else
				if parentTi &lt;&gt; null then
					//packing type.
					foreach reserve in _bulkRelease.allReservePackingChildren do
						outStandingItemCount := outStandingItemCount + reserve.getTotalOutstanding;
						stagedItemCount := stagedItemCount + reserve.getTotalStaged(tiSet, firstStagingLC, null);
					endforeach;
					foreach childTi in parentTi.allChildren do
						onTruckCount := onTruckCount + childTi.totalQuantity.max(1);
					endforeach;
					if outStandingItemCount &gt; 0 and outStandingItemCount = ( stagedItemCount + onTruckCount ) then
						foreach ti in tiSet do
							if ti.isChild then
								continue;
							endif;
							_tiArray.addExclusive( ti );
						endforeach;
						return;
					endif;
				else
					outStandingItemCount := _bulkRelease.getTotalOutstanding;
				
					stagedItemCount := _bulkRelease.getTotalStaged(tiSet, firstStagingLC);
					//onTruckCount := _bulkRelease.getTotalAssignedInLocation(_targetLocation);	//23 Nov 2015	NDL	Par 37153
					if _targetLocation &lt;&gt; null then
						if _reserveSelection &lt;&gt; null then                           //cnwma1 TFS #4017 07/04/2017
							onTruckCount := _reserveSelection.getTotalAssignedInLocation(_targetLocation);
						else
							 foreach reserve in _bulkRelease.allReserveDetails do    //cnwma1 TFS #4017 07/04/2017
									if  reserve.isKindOf(CM_ReserveSelection) then
										onTruckCount := onTruckCount + reserve.CM_ReserveSelection.getTotalAssignedInLocation(_targetLocation);
									endif;
							 endforeach;
						endif;
					//20 Mar 2017	NDL	TFS 3667
		//			elseif parentTi &lt;&gt; null then
		//				foreach childTi in parentTi.allChildren do
		//					onTruckCount := onTruckCount + childTi.totalQuantity.max(1);
		//				endforeach;
					endif;
					if outStandingItemCount &gt; 0 and outStandingItemCount = ( stagedItemCount + onTruckCount ) then
						foreach ti in tiSet do			
							//20 Mar 2017	NDL	TFS 3667
		//					if parentTi &lt;&gt; null then
		//						if ti.isChild then
		//							continue;
		//						endif;
		//					endif;
							_tiArray.addExclusive( ti );
						endforeach;
						return;
					endif;
				
				endif;
				
			endif;
		endif;
	endif;

	if _stagedYardLocation &lt;&gt; null then
		//all cargo is staged in the interchange area, NO cross-checking is performed
		foreach ti in _stagedYardLocation.allTrackedItems where (not ti.isChild) and (allowOtherReleases or ti.bulkReleaseAssignedCode = null or ti.bulkReleaseAssignedCode = _bulkRelease.code) do	// 1 Nov 2016 cnwmp6 TFS 2858
			if _reserveSelection &lt;&gt; null then
				//If we have a reserve selection and it doesn't match skip it.
				if not ti.testAgainstReserveSelection( _reserveSelection, reason, true, null ) then	//09 Feb 2016	NDL	Par 37479
					continue;
				endif;
			endif;
			_tiArray.addExclusive( ti );
		endforeach;
		return;
		
	endif;
		
	if _bulkRelease = null then
		return;
	endif;
	
	// Release by id or release by type with assigned items
	// get the nominated child cargo
	foreach reserve in _bulkRelease.allReserveDetails do
		if _reserveSelection &lt;&gt; null and reserve &lt;&gt; _reserveSelection then	//03 Oct 2016	NDL	TFS 
			continue;
		endif;
		if reserve.isComplete then	//27 Feb 2018	NDL	TFS 37354
			continue;
		endif;
		
		//27 Feb 2018	NDL	TFS 37354
		if usesCargoGroup then
			if _bulkRelease.isPackingType then
				if reserve.isFullyPacked then
					continue;
				endif;
			else
				if reserve.isFullyLoaded then
					continue;
				endif;
			endif;
		endif;
		
		reserve.getAllTrackedItems(allTis, false); //23/06/2023	navkc1	CR 58406 Task 58408
		
		//foreach ti in reserve.allTrackedItems do
		foreach ti in allTis do //23/06/2023	navkc1	CR 58406 Task 58408
			// 30 Apr 2015	NDL	Par 36140 
			if _bulkRelease.isPackingType then
				if ti.isContainer or ti.isChassis then
					//will be associated so as to be a parent not a child.
					continue;
				endif;
			endif;
			if ti.isChild then
				//already packed
				continue;
			endif; 
			if ti.myPrimaryActualLocation = null then
				continue;
			endif;

			if ti.myPrimaryActualLocation = _targetLocation then
				continue;
			elseif ( _targetLocation &lt;&gt; null and _targetLocation.isWagon ) then	//26 Jan 2017	NDL	TFS 3198/2877
				if ti.myPrimaryActualLocation.isWagon
				and ( ti.myPrimaryActualLocation.CM_WagonController.myWagon = _targetLocation.CM_WagonController.myWagon )
				then
					continue;
				endif;
			endif;
			if _bulkRelease.isRoadType then    // 36127
				if ti.myPrimaryActualLocation.isVehicle then
					continue;
				elseif ti.myPrimaryActualLocation.isTILCController then
					continue;
				endif;
			endif;
			if not ti.isOnSite then
				continue;
			endif;
			_tiArray.addExclusive( ti );
		endforeach;
	endforeach;
	
	//10 Dec 2015	NDL	Par 37288
	if _bulkRelease.isPackingType then
		//packing children
		foreach reserve in _bulkRelease.allReservePackingChildren do
			if _reserveSelection &lt;&gt; null and reserve &lt;&gt; _reserveSelection then	//03 Oct 2016	NDL	TFS 
				continue;
			endif;
			
			reserve.getAllTrackedItems(allTis, false); //23/06/2023	navkc1	CR 58406 Task 58408
			
			//foreach ti in reserve.allTrackedItems do
			foreach ti in allTis do //23/06/2023	navkc1	CR 58406 Task 58408
				if ti.isChild then
					//already packed
					continue;
				endif; 
				if ti.myPrimaryActualLocation = null then
					continue;
				endif;
	
				if ti.myPrimaryActualLocation = _targetLocation then
					continue;
				elseif ( _targetLocation &lt;&gt; null and _targetLocation.isWagon ) then	//26 Jan 2017	NDL	TFS 3198/2877
					if ti.myPrimaryActualLocation.isWagon
					and ( ti.myPrimaryActualLocation.CM_WagonController.myWagon = _targetLocation.CM_WagonController.myWagon )
					then
						continue;
					endif;
				endif;
				
				if not ti.isOnSite then
					continue;
				endif;
				_tiArray.addExclusive( ti );
			endforeach;
		endforeach;
	endif;
		
	if _bulkRelease.releaseByType and _tiArray.isEmpty then
		// release by type
		
		//21 Feb 2018	NDL	TFS 37084
		if usesCargoGroup and _reserveSelection = null then
			
			if _targetLocation &lt;&gt; null then	//16 Apr 2018	NDL TFS 38083
				if _targetLocation.isVehicle then	
					truck := _targetLocation.CM_VehicleController.vehicle;
				elseif _targetLocation.isTILCController then	//27 Feb 2018	NDL	TFS 37354
					truck := _targetLocation.CM_TILCController.getVehicle;
				endif;
			endif;
			if truck &lt;&gt; null then
				//we have a truck, build a set of the reserve details on the associated job.
				create jobReserveDetails transient;
				roadJob := truck.allRoadJobs.first;
				if roadJob &lt;&gt; null then
					foreach req in roadJob.allRequests do
						if req.myReserveDetail &lt;&gt; null then
						//	jobReserveDetails.add(req.myReserveDetail);
							jobReserveDetails.addNoDuplicates(req.myReserveDetail,false);
						endif;
					endforeach;
				endif;
			endif;
			
		endif;

		
		// get the prospective children - i.e. they are for the operator and match the release details
		opTerm := _bulkRelease.myOperatorTerminal;
		if opTerm &lt;&gt; null then
			// PAR 35781 
			if _bulkRelease.isPackingType then
				reserveDetails := _bulkRelease.allReservePackingChildren;
			else
				reserveDetails := _bulkRelease.allReserveDetails;
			endif;
			foreach reserve in reserveDetails do
				if _reserveSelection &lt;&gt; null and reserve &lt;&gt; _reserveSelection then	//03 Oct 2016	NDL	TFS 
					continue;
				endif;
				if not reserve.isKindOf( CM_ReserveSelection ) then
					continue;
				endif;
				
				if reserve.isComplete then	//27 Feb 2018	NDL	TFS 37354
					continue;
				endif;
				
				//21 Feb 2018	NDL	TFS 37084
				if usesCargoGroup then
					
					if truck &lt;&gt; null then
						if jobReserveDetails &lt;&gt; null and not jobReserveDetails.isEmpty then
							if not jobReserveDetails.includes( reserve ) then
								continue;
							endif;
						endif;
					endif;
					
					if _bulkRelease.isPackingType then
						if reserve.isFullyPacked then
							continue;
						endif;
					else
						if reserve.isFullyLoaded then
							continue;
						endif;
					endif;
					
					tiSet.clear;
					self.getNonStagedAvailSTW( reserve.CM_ReserveSelection, tiSet, false, _bulkRelease );
					if not tiSet.isEmpty() then
						foreach ti in tiSet do
							_tiArray.addExclusive( ti );
						endforeach;
						continue;	
					endif;
					
					continue;	//16 Apr 2018	NDL	TFS 38083 - STW unconditionally use cargo id or cargo group id as extra criteria.
					
				endif;

				foreach ti in opTerm.allOnsiteTIsByCargoTypeId do
					if ti.myPrimaryActualLocation = null then
						continue;
					endif;
					if _bulkRelease.isPackingType then
						if ti.isContainer or ti.isChassis then
							//will be associated so as to be a parent not a child.
							continue;
						endif;
						if ti.isChild then
							//already packed
							continue;
						endif; 
					else
						//20 Mar 2017	NDL	TFS 3667
						if parentTi &lt;&gt; null then
							if ti.isChild then
								continue;
							endif;
						endif;
						if self.isTiLoaded(ti, _targetLocation) then
							continue;
						endif;
						if _bulkRelease.isRoadType then    // 36127
							if ti.myPrimaryActualLocation.isVehicle then
								continue;
							elseif ti.myPrimaryActualLocation.isTILCController then
								continue;
							endif;
						endif;
					endif;
					if not ti.testAgainstReserveSelection( reserve.CM_ReserveSelection, reason, true, null ) then
						continue;
					endif;
					//if (not allowOtherReleases) and ti.bulkReleaseAssignedCode &lt;&gt; _bulkRelease.code then	// 1 Nov 2016 cnwmp6 TFS 2858
					if (not allowOtherReleases) and ti.bulkReleaseAssignedCode &lt;&gt; null and ti.bulkReleaseAssignedCode &lt;&gt; _bulkRelease.code then	//09 Jan 2017	NDL	TFS 3138
					// don't want this one, as reserved for someone else
						continue;
					endif;
					_tiArray.addExclusive( ti );		
				endforeach;
			endforeach;
		endif;
		
	endif;

epilog

	delete tiSet;
	delete jobReserveDetails;
	delete allTis;
end;</source>
        <access>protected</access>
        <Parameter name="_bulkRelease" type="CM_BulkRelease"/>
        <Parameter name="_reserveSelection" type="CM_ReserveSelection"/>
        <Parameter name="_stagedYardLocation" type="CM_LocationsController"/>
        <Parameter name="_targetLocation" type="CM_LocationsController"/>
        <Parameter name="_tiArray" type="CM_TIArray" usage="io"/>
    </JadeMethod>
    <JadeMethod name="getBulkWeightValueForMove" id="803277eb-2b8a-4e80-b951-504a04aee0b9">
        <source>getBulkWeightValueForMove( _ti : CM_TrackedItem ; _measureTbl : CMUI_MeasurementTable input ) : Decimal;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 April 2014	cnwndl1	Initial creation

*/

vars

	weight : Decimal [16,4];
	volume : Decimal [16,4];
	measurementType : CM_MeasurementType;

begin

	if _measureTbl = null then
		return weight;
	endif;
	
	if _ti.isBulkByWeight then
		weight := _measureTbl.getConvertedValue();
	elseif _ti.isBulkByVolume then
		volume := _measureTbl.getConvertedValue();
		weight := volume * _ti.getDensity;
	endif;
	
	return weight;

epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_measureTbl" type="CMUI_MeasurementTable" usage="input"/>
        <ReturnType type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="getButtonWidthSetScrollBar" id="a71480ec-70ae-4963-82d1-b21312b8dda5">
        <updating/>
        <source>getButtonWidthSetScrollBar( _size : Integer; _frame : MOB_Frame; _btnHeight : Real; _scroll : VScroll io ):Real updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 February 2015	cnwndl1	Initial creation	Par 35604

*/
	
vars

	buttonWidth : Real;
	partialButtonSize : Integer;
	scrollWidth : Real;

begin

	if ( _size * (_btnHeight + self.resizedMargin) ) &gt; ( _frame.height.Integer - 6 ) then
		scrollWidth := ( self.drawFontSize * 2 ).Integer;
		partialButtonSize := (_frame.height.Integer - 6) mod (_btnHeight ).Integer;
		_scroll.move( _frame.width- scrollWidth-8, 0, scrollWidth, _frame.height-6 );
		_scroll.visible := true;
		_scroll.min := 0;
		_scroll.max := _size * (_btnHeight + self.resizedMargin ).Integer - _frame.height.Integer - 6 + partialButtonSize;
		_scroll.largeChange := _frame.height.Integer - 6 - partialButtonSize;
		_scroll.smallChange := _btnHeight.Integer;
		_scroll.value := 0;
		
		buttonWidth := _frame.width - 8 - _scroll.width;
	else
		buttonWidth := _frame.width - 6;
		_scroll.visible := false;
		
	endif;
	
	return buttonWidth;

epilog

end;</source>
        <Parameter name="_size" type="Integer"/>
        <Parameter name="_frame" type="MOB_Frame"/>
        <Parameter name="_btnHeight" type="Real"/>
        <Parameter name="_scroll" type="VScroll" usage="io"/>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="getCMDButtonsHeight" id="6fb21cd7-ef21-4a68-b10e-52dfdd16cdda">
