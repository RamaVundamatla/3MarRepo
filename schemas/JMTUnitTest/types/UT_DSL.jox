        <Parameter name="_terminalAreas" type="CM_TerminalAreaArray"/>
        <ReturnType type="CM_TerminalAreaStorageGroup"/>
    </JadeMethod>
    <JadeMethod name="addTidalClass" id="4590eb5f-f5d6-4413-8103-845e85cc03c0">
        <source>addTidalClass(_tidalClassId, _tidalClassDesc : String; _maxFloodTideArrival, _maxEbbTideArrival, _maxFloodTideDept, _maxEbbTideDept : Decimal ) : HMS_TidalClass;

/*

Purpose:		Add Tidal Class

Date			Who		Reason
21/12/2011		cnwmh5	Initial creation

*/

vars

	pxyTidalClass			: HMS_TidalClass;
	tidalClass				: HMS_TidalClass;
	conflictManager	 		: CMIF_HMS_ConflictsManager;

begin

	self.deleteTidalClass(_tidalClassId);

	create pxyTidalClass transient;
	pxyTidalClass.setProxy(app.myRoot);
	
	pxyTidalClass.setPropertyValue("code", _tidalClassId);
	pxyTidalClass.setPropertyValue("description", _tidalClassDesc);
	
	app.myTrxCA.trxCreateTidalClass(pxyTidalClass, tidalClass, conflictManager, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
	// must be in this order
	beginTransaction;
	tidalClass.allMaximumCurrents.add(_maxFloodTideArrival);
	tidalClass.allMaximumCurrents.add(_maxEbbTideArrival);
	tidalClass.allMaximumCurrents.add(_maxFloodTideDept);
	tidalClass.allMaximumCurrents.add(_maxEbbTideDept);
	commitTransaction;
	
	return tidalClass;
	
epilog

	delete pxyTidalClass;

end;</source>
        <Parameter name="_tidalClassId" type="String"/>
        <Parameter name="_tidalClassDesc" type="String"/>
        <Parameter name="_maxFloodTideArrival" type="Decimal"/>
        <Parameter name="_maxEbbTideArrival" type="Decimal"/>
        <Parameter name="_maxFloodTideDept" type="Decimal"/>
        <Parameter name="_maxEbbTideDept" type="Decimal"/>
        <ReturnType type="HMS_TidalClass"/>
    </JadeMethod>
    <JadeMethod name="addTidalModel" id="acba9624-d36b-4341-bf7a-672010b132f3">
        <source>addTidalModel(_tidalModelId, _tidalModelDesc, _dataSource, _tideFileName : String; _dataType : Integer; _highestValue, _lowestValue, 
			_declaredDepth, _underKeelClearance : Real) : HMS_TidalModelDefinition;

/*

Purpose:		Create a Tidal Model Definition		

Date			Who		Reason
22 December 2011	cnwmh5	Initial creation

*/

vars

	pxyTidalModelDef				: HMS_TidalModelDefinition;
	tidalModelDef					: HMS_TidalModelDefinition;

begin

	self.deleteTidalModel(_tidalModelId);

	create pxyTidalModelDef transient;
	pxyTidalModelDef.setProxy(_tidalModelId,				// code
							 _tidalModelDesc,				// desc : String;
							 _dataType,						// data type	: Integer;
							 _dataSource,					// data source 	: String;
							 _highestValue,					// highest value  : Real
							 _lowestValue,					// lowest value : Real
							 _declaredDepth,				// declared depth : Real
							 _underKeelClearance,			// under keel clearance : Real;
							 false,							// has gaps	: Boolean;
							 app.myRoot,					// root 			: CM_Root;
							 _tideFileName);				// tide file name : String				
	
	app.myTrxCA.trxCreateTidalModelDef(pxyTidalModelDef, tidalModelDef, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
	return tidalModelDef;
	
epilog

	delete pxyTidalModelDef;

end;</source>
        <Parameter name="_tidalModelId" type="String"/>
        <Parameter name="_tidalModelDesc" type="String"/>
        <Parameter name="_dataSource" type="String"/>
        <Parameter name="_tideFileName" type="String"/>
        <Parameter name="_dataType" type="Integer"/>
        <Parameter name="_highestValue" type="Real"/>
        <Parameter name="_lowestValue" type="Real"/>
        <Parameter name="_declaredDepth" type="Real"/>
        <Parameter name="_underKeelClearance" type="Real"/>
        <ReturnType type="HMS_TidalModelDefinition"/>
    </JadeMethod>
    <JadeMethod name="addToCleanUpObject" id="8c196514-fde4-42e8-89c9-5d1b4cb3dc78">
        <source>addToCleanUpObject(_cleanupObject : CM_ObjectArray io; _objectToAdd : CM_Object);
/*****************************************************
Author		: jlika1 (Karen Alexander)
Date		: 13 April 2022
TFS#		: 53181
Function	: Add transient object to a collection so we can delete each at the end of the unit test to avoid transient leaks

*** Changes ***
Date			Name		TFS#		Description

****************************************************/
begin	
	_cleanupObject.add(_objectToAdd);
end;</source>
        <Parameter name="_cleanupObject" type="CM_ObjectArray" usage="io"/>
        <Parameter name="_objectToAdd" type="CM_Object"/>
    </JadeMethod>
    <JadeMethod name="addToDoTask" id="4628dc6c-6c39-4fe6-8942-de2ecee0af57">
        <source>addToDoTask(_taskDesc : CM_ToDoTaskDesc; _tiSet : CM_TISet input);
//18 December 2009	cnwml2
// 07/02/2014	cnwmh5	Change so that can also call trxUpdateTIToDoAdd based on _tiSet size

vars

begin
	if _tiSet.size = 1 then
		app.myTrxUA.trxUpdateTIToDoTaskAdd(_tiSet.first.CM_TrackedItem, _taskDesc.code, app.myPassport);
	else
		app.myTrxUA.trxUpdateTIToDoTaskAddBulk(_taskDesc, _tiSet, app.myPassport);
	endif;
	self.assertNoTrxErrorsOrWarnings;
epilog

end;</source>
        <Parameter name="_taskDesc" type="CM_ToDoTaskDesc"/>
        <Parameter name="_tiSet" type="CM_TISet" usage="input"/>
    </JadeMethod>
    <JadeMethod name="addToDoTaskResource" id="5d6a0522-806f-44ca-8e7e-5d3ca92b80f8">
        <source>addToDoTaskResource(_resourceCode, 
					_resourceDesc, 
					_unitDescription : String; 
					_numDecimals 	 : Integer; 
					_hasBeenUsed,
					_isAvailable 	 : Boolean; 
					_toDoTasks		 : CM_ToDoTaskDescBySortKey) : CM_ResourceType;

/*

Purpose:		Add To Do Task Resource

Date			Who		Reason
05/02/2012		cnwmh5	Initial creation
02/11/2022 		navds20 ChangeRequest 56635:[54261] EUP - Todo Task Resources Maintenance
23.12.2022   	navds21 ChangeRequest 54349[54262]: EUP - Enable Is Mandatory for ToDo Task Resources
*/

vars

	pxyResourceType				: CM_ResourceType;
	resourceType				: CM_ResourceType;
	
	transTypeSet 				: CM_TransactionTypeSet;
	transResourceBrokers 		: CM_TransSBByTransTypeType;
	eventTypes 					: CM_EventTypeByTypeDict;
	type 						: Integer;	//9/11/2022 navds20 TFS #56635[54261]
begin
	
	self.deleteResourceType(_resourceCode);
	
	//start 9/11/2022 navds20 TFS #56635[54261]
	if self.opts.includesKey("Type") then
		type := self.opts.int("Type");
	endif;
	if type = null then
		type := TODO_TYPE_GROUP_TI;
	endif;
	//end 9/11/2022 navds20 TFS #56635[54261]
	
	create transTypeSet transient;
	create transResourceBrokers transient;
	create eventTypes transient;
	
	create pxyResourceType transient;
	pxyResourceType.setProxy(_resourceCode,					// code
						     _resourceDesc, 				// description
							 _numDecimals,					// number of decimals
							 _unitDescription,				// unit descriptoin
							 _hasBeenUsed, 					// has been used
							 _isAvailable,					// is avaiabile
							 _toDoTasks,				 	// CM_ToDoTaskDescBySortKey;
							 eventTypes,					// CM_EventTypeByTypeDict;
							 transTypeSet,					// CM_TransactionTypeSet;
							 transResourceBrokers,			// CM_TransSBByTransTypeType/
							 false,							//cnwmc5 - 22 Sep 2015 - PAR 36920
							 self.opts.str(JadeCode), 		//cnwmc5 - 22 Sep 2015 - PAR 36920
							 null,
							 self.opts.str(UserCode),		//cnwmc5 - 22 Sep 2015 - PAR 36920
							 type,							//07/11/2022 navds20 TFS #56635[54261]	
							 false,							//23.12.2022 navds21 TFS #54349[54262]
							 null,							// ### TFS 58761 (60739) 16Nov2023 NAVPW1
							 null							// ### TFS 58761 (60739) 16Nov2023 NAVPW1
							 );						
	
	app.myTrxCA.trxCreateResourceType(pxyResourceType, resourceType, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
		
	return resourceType;
	
epilog

	delete pxyResourceType;
	delete transTypeSet;
	delete transResourceBrokers;
	delete eventTypes;
	
end;</source>
        <Parameter name="_resourceCode" type="String"/>
        <Parameter name="_resourceDesc" type="String"/>
        <Parameter name="_unitDescription" type="String"/>
        <Parameter name="_numDecimals" type="Integer"/>
        <Parameter name="_hasBeenUsed" type="Boolean"/>
        <Parameter name="_isAvailable" type="Boolean"/>
        <Parameter name="_toDoTasks" type="CM_ToDoTaskDescBySortKey"/>
