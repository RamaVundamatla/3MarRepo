    <JadeMethod name="getNextQuickPrenoteID" id="6641885c-e883-4541-9668-0bbb87851168">
        <source>getNextQuickPrenoteID(_cargoType : Integer) : String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26 August 2020	jlgndl1	Initial creation	TFS 49950

*/

vars
	aTI : CM_TrackedItem;
	nextID, numId : String;
	nextNum : Integer;
	now : Date;
begin
	nextNum := (now.formatAsYYMMDD() &amp; "1").asIntegerJMT;

	while true do
		nextID := "CNTU" &amp; nextNum.String;
			if self.getTerminal.allNotifiedTIsByIdCargoType[nextID,_cargoType] = null then
				return nextID;
			endif;
		nextNum := nextNum + 1;
	endwhile;
	
	return nextID;
epilog

end;</source>
        <Parameter name="_cargoType" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="tAdhocCamsRequest" id="fde2ee2b-46cc-4242-a30f-953fe2ce822f">
        <source>tAdhocCamsRequest();
/*

Purpose:			

Date		Who		Reason
16 October 2015	cnwmk3	Initial creation

*/
constants
    CamProtocol                                   : String = "UTCam";
	CamDesc                                       : String = "Test Protocol";
	TestOperator	= 'UTOP';
	
vars
    camProtocol                                   : CM_CamProtocol;
    startDate                                     : TimeStamp;
	endDate                                       : TimeStamp;
	bgpManager                                    : BGP_Manager;
	bgpGeneric                                    : BGP_GenericController;
	
	
	allCoarriExportPorts : CM_PortByCodeDict;
	emailCopyAddresses : CM_EmailEntityByTypeNameDict;
	packOperators : CM_OperatorByCodeDict;
	packExportConsignees : CM_ConsignByCodeDict;
	camEditTriggerFields : CM_CamEditTriggerFieldDict;
	camTrainEventTypes : CM_EventTypeByNameDict;
	allPackAreas : CM_TAByIdDict;
	registeredTransactions : StringArray;
	scheduleTimes : TimeArray;
	lRegisteredCargoTypes : IntegerArray;
	camProtocolDesc : CM_CamProtocolDesc;
	emailEntity : CM_EmailEntity;
	camGroup : CM_CamGroup;
	startDateTime : TimeStamp;
	endDateTime : TimeStamp;
begin
    camProtocol := self.getCamProtocol(CamProtocol);
	self.deleteCamProtocol(CamProtocol);
	self.assertIsDeleted(camProtocol);
	create allCoarriExportPorts transient;
	create emailCopyAddresses transient;
	create packOperators transient;
	create packExportConsignees transient;
	create registeredTransactions transient;
	registeredTransactions.add(global.getTiTxnTypeForClass(CM_PackComplete).asStringJMT);
	create scheduleTimes transient;
	create camEditTriggerFields transient;
	create camTrainEventTypes transient;
	create allPackAreas transient;
	create lRegisteredCargoTypes transient;
	lRegisteredCargoTypes.add(TI_CargoType_Container);
	camProtocolDesc := app.myRoot.allCamProtocolDescs["Maersk Codeco"];
	emailEntity := app.myRoot.allEmailEntities[1, "Mr. Testing"];
	camGroup := self.getCamGroup("UT_AST1");
	camProtocol := self.addCamProtocol(CamProtocol, CamDesc, allCoarriExportPorts, camGroup, "NZCHC", emailEntity, false, emailCopyAddresses, false, "CamMessage", "CamSubject",
	                                   startDateTime, startDateTime, false, null, "txt", TestOperator, packOperators, packExportConsignees, '', camProtocolDesc, registeredTransactions,
									   false, 1, false, scheduleTimes, false, false, false, false, false, false, false, false, false, false, false, false, 
									   false, false, false, false, false, false, false, false, false, false, false, false, 
									   0, 0, 0, 0, '', '', '', camEditTriggerFields, camTrainEventTypes, null, false, null, self.getTerminal, true, true, false, true, true, false, false, false, true, 
									   allPackAreas, null, null, lRegisteredCargoTypes);
	self.assertNotNull(camProtocol);
	
	
	app.myTrxUA.trxUpdateCamObjectStatus(camProtocol, CAM_HOLDSTATUS, app.myPassport);
	
	// create the BGPManager
	
	if app.myRoot.allBGPManagers["CAMS"] = null then
	   self.opts.purge();
	   self.opts.addAssoc("IsServer", true);
	   bgpManager := self.addBGPManager("CAMS");
	   self.assertNotNull(bgpManager);
	else
	   bgpManager := app.myRoot.allBGPManagers["CAMS"];
	   self.assertNotNull(bgpManager);
	endif;
	
	// start bgp if not running already
	if not bgpManager.isRunning then
	bgpGeneric := bgpManager.allBGPControllers.last.BGP_GenericController;
	bgpManager.startBackGroundApp(bgpGeneric, false);
	endif;
	
	// create adhoc Cams Request
    app.myTrxCA.trxCreateAdhocCamsRequest(camProtocol, startDate, endDate, false, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	bgpManager.terminateProcessing(app.getMyUserCode());
epilog
    delete allCoarriExportPorts;
	delete emailCopyAddresses;
	delete packOperators;
	delete packExportConsignees;
	delete registeredTransactions;
	delete scheduleTimes;
	delete camEditTriggerFields;
	delete camTrainEventTypes;
	delete allPackAreas;
	delete lRegisteredCargoTypes;
end;</source>
    </JadeMethod>
    <JadeMethod name="tAutoTask" id="84fe9aea-4d5d-43f4-b3ec-33aad3a6ba1d">
        <source>tAutoTask();
/*

Purpose:			

Date		Who		Reason
15 October 2015	cnwmk3	Initial creation

*/

vars
    pxyAutoExDB                       : CM_AutoTaskExternalDB;
	realAutoTask                      : CM_AutoTask;
	pxyAutoTask                       : CM_AutoTask;
	desc                              : String;
begin
    
	realAutoTask := app.myRoot.allAutoTasks[BGP_ExternalDBRequest.name, "Task is Updated by unit test"];
	if realAutoTask &lt;&gt; null then
		app.myTrxDA.trxDeleteAutoTask(realAutoTask, app.myPassport);
		self.assertNoTrxErrorsOrWarnings();
	endif;
    
    create pxyAutoExDB transient;
	pxyAutoExDB.setValueForRow(ETRow_BgpAutoDescription,"UTDSS ");
	pxyAutoExDB.setValueForRow(ETRow_BgpAutoUser, app.getMyUser());
	
    app.myTrxCA.trxCreateAutoTask(pxyAutoExDB, realAutoTask, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	self.assertTrueMsg( realAutoTask &lt;&gt; null,"Database Extract Task not created. " &amp; app.myPassport.getErrorsAndWarningsAsString);
	
	beginLoad;
	pxyAutoTask := realAutoTask.pxyCreateUpdateProxy();
	endLoad;
	
	desc := "Task is Updated by unit test";
	pxyAutoTask.setPropertyValue("description", desc);
	app.myTrxUA.trxUpdateAutoTask(pxyAutoTask, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	self.assertEqual(realAutoTask.description, desc);
epilog
    delete pxyAutoExDB;
	delete pxyAutoTask;
end;</source>
    </JadeMethod>
    <JadeMethod name="tAvailabilityGradeCode" id="08c0c129-e341-4355-8585-7b967f5f2c23">
        <source>tAvailabilityGradeCode();
/*

Purpose:			

Date		Who		Reason
02 November 2015	cnwmk3	Initial creation

*/
constants
   GradeCode                               : String = "UT01";
   GradeDescription                        : String = "Unit Test GradeCode";
vars
   proxyMTGrade                            : CM_MTGradeCode;
   realMTGrade                             : CM_MTGradeCode;
   codeGroup                               : CM_CodeGroup;
   availablity                             : CM_MTGrade;
   proxyUpdateMTGrade                      : CM_MTGradeCode;
begin
   realMTGrade := app.myRoot.allCodeGroups.last.allCodes[GradeCode].CM_MTGradeCode;
   if realMTGrade &lt;&gt; null then 
      app.myTrxDA.trxDeleteAvailabilityGradeCode(realMTGrade, app.myPassport);
	  self.assertNoTrxErrorsOrWarnings();
   endif;
   codeGroup := app.myRoot.allCodeGroups.last;
   availablity := app.myRoot.allAvailabilityGrades[9];
   create proxyMTGrade transient;
   proxyMTGrade.setForProxy(	GradeCode,
								GradeDescription,
								codeGroup,
								availablity);
								
	
	app.myTrxCA.trxCreateAvailabilityGradeCode(proxyMTGrade, realMTGrade, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	self.assertNotNull(realMTGrade);
	
	beginLoad;
	proxyUpdateMTGrade := realMTGrade.pxyCreateUpdateProxy();
	endLoad;
	
	availablity := app.myRoot.allAvailabilityGrades[5];
	proxyUpdateMTGrade.setPropertyValue("myCodeGroup", realMTGrade.myCodeGroup);
	proxyUpdateMTGrade.setPropertyValue("description", "Description is Updated");
	proxyUpdateMTGrade.setPropertyValue("myMTGrade", availablity);
	app.myTrxUA.trxUpdateAvailabilityGradeCode(proxyUpdateMTGrade, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
		
epilog
    delete proxyMTGrade;
	delete proxyUpdateMTGrade;
end;</source>
    </JadeMethod>
    <JadeMethod name="tBGPManager" id="3c3fd8bc-f2cd-4f05-bf00-12d338f67458">
        <source>tBGPManager();
/*

Purpose:			

Date		Who		Reason
19 October 2015	cnwmk3	Initial creation

*/

vars
    bgpManager                        : BGP_Manager;
	startTime                         : TimeStamp;
	bgpGeneric                        : BGP_GenericController;
begin

    if app.myRoot.allBGPManagers["CAMS"] = null then
	   self.opts.purge();
	   self.opts.addAssoc("IsServer", true);
	   bgpManager := self.addBGPManager("CAMS");
	   self.assertNotNull(bgpManager);
	else
	   bgpManager := app.myRoot.allBGPManagers["CAMS"];
	   self.assertNotNull(bgpManager);
	endif;
	
	if not bgpManager.isRunning then
    app.myTrxUA.trxUpdateBGPManagerProcess(bgpManager, null, startTime, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	bgpGeneric := bgpManager.allBGPControllers.last.BGP_GenericController;
	bgpManager.startBackGroundApp(bgpGeneric, false);
	endif;
epilog
	
end;</source>
    </JadeMethod>
    <JadeMethod name="tCalculationType" id="b6673e6a-6d3b-4e55-9ef3-61d4d9686dfb">
        <source>tCalculationType();
/*

Purpose:			

Date		Who		Reason
14 October 2015	cnwmk3	Initial creation
//02/10/2025	navkc1 JIRA 36149 AAT | RotaBox ISO Type and New Attributes - Calculation Type
*/
constants
	UTCALC12 = "UTCAL01";
	UTDESC12 = "UT Berthage - 12 Hours No Units";
    Desc     = "Calculation Type is Updated";
vars
    calcType                        : CM_CalculationType;
	proxyCalculationType            : CM_CalculationType;
begin
    self.deleteCalculationType(UTCALC12, FORCED_ERASE);
	calcType := self.addCalculationType(	INV_CALC_TYPE_TIMEBLCK_HRS_UNT,	//_calcType : Integer;
												UTCALC12,	                //_code : String;
												UTDESC12,	                //_description : String;
												null,	                    //_quantityHookSource : String;
												null,	                    //_rateHookSource : String
												null						//_remarksHookSource: String;
												,12,0,12,12, false, true, false, false,0, null, null);
    assertNotNull(calcType);
	
	beginLoad;
	proxyCalculationType := calcType.pxyCreateUpdateProxy();
	endLoad;
	proxyCalculationType.setPropertyValue("description",Desc);
    app.myTrxUA.trxUpdateCalculationType(proxyCalculationType, app.myPassport);
	assertNoTrxErrorsOrWarnings();
	assertEqual(calcType.description, Desc);
	
epilog
    delete proxyCalculationType;
end;</source>
    </JadeMethod>
    <JadeMethod name="tCalendarMisc" id="cd4a8484-3eb1-46e6-948c-c3c6b4084cdf">
        <source>tCalendarMisc();

/*

Purpose:		Calendar Misc trx's

				trxDeleteCalendarDate
				trxUpdateCalendarDate
				trxUpdateCalendar
				trxCreateCalendarYear
				trxDeleteCalendarYear
				trxUpdateCalendarYear

Date			Who		Reason
21/05/2015		cnwmh5	Initial creation

*/

vars

	calendar				: CM_Calendar;
	pxyCalendar				: CM_Calendar;
	calendarDate			: CM_CalendarDate;
	pxyCalendarDate			: CM_CalendarDate;
	pxyCalendarYear			: CM_CalendarYear;
	calendarYear			: CM_CalendarYear;

begin

	self.deleteCalendar("UTMH", "UTMHDAY");
	
	calendar := self.createCalendar("UTMH", "Michael's UT Test Calendar", false, false, "UTMHDAY");
	self.assertNotNull(calendar);
	
	calendarDate := self.addSingleCalendarDate(app.cnGetServerTime().date, "Day Before Today", calendar);
	self.assertNoTrxErrorsOrWarnings();
	self.assertNotNull(calendarDate);
	
	beginLoad;
	pxyCalendarDate := calendarDate.pxyCreateUpdateProxy();
	pxyCalendarDate.setProxy(calendarDate.date, "Day Before Today - Yeah Right", calendarDate.myCalendar, 
		calendarDate.myCalendarYear, calendarDate.dataSource);	
	endLoad;
	
	app.myTrxUA.trxUpdateCalendarDate(pxyCalendarDate, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	self.assertEqual(calendarDate.description, "Day Before Today - Yeah Right");

	app.myTrxDA.trxDeleteCalendarDate(calendarDate, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	self.assertEqual(calendar.allCalendarDates.size, 0);	

	create pxyCalendarYear transient;
	pxyCalendarYear.setProxy(2014, calendar);
	app.myTrxCA.trxCreateCalendarYear(pxyCalendarYear, calendarYear, app.myPassport, false);
	self.assertNoTrxErrorsOrWarnings();
	self.assertNotNull(calendarYear);
	self.assertEqual(calendar.allCalendarYears.size, 2);
	
	delete pxyCalendarYear;
	beginLoad;
	pxyCalendarYear := calendarYear.pxyCreateUpdateProxy();
	pxyCalendarYear.setProxy(2013, calendar);	
	endLoad;
	
	app.myTrxUA.trxUpdateCalendarYear(pxyCalendarYear, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	self.assertEqual(calendar.allCalendarYears.first.year, 2013);
	
	app.myTrxDA.trxDeleteCalendarYear(calendarYear, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	self.assertEqual(calendar.allCalendarYears.size, 1);
	
	beginLoad;
	pxyCalendar := calendar.pxyCreateUpdateProxy();
	pxyCalendar.setPropertyValue("description", "Michael's UT Test Calendar YAY");
	endLoad;
	app.myTrxUA.trxUpdateCalendar(pxyCalendar, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	self.assertEqual(calendar.description, "Michael's UT Test Calendar YAY");	
	
epilog

	delete pxyCalendarDate;
	delete pxyCalendarYear;
	delete pxyCalendar;

end;</source>
    </JadeMethod>
    <JadeMethod name="tCamTaskHistory" id="0cd3cb38-fb4e-4ece-b11b-c0b65457e088">
        <source>tCamTaskHistory();
/*

Purpose:			

Date		Who		Reason
16 October 2015	cnwmk3	Initial creation
// 28 Sep 2016	cnwrs1	TFS 2756 PAR38267 allow Cams to run per terminal
*/
constants
    CamProtocol                                   : String = "UTCam";
	CamDesc                                       : String = "Test Protocol";
	TestOperator	= 'UTOP';
vars
    proxyCamHistory                                    : CM_CamTaskHistory;
	camHistory                                         : CM_CamTaskHistory;
	runDateTime                                        : TimeStamp;
	camProtocol                                        : CM_CamProtocol;
	camAgent                                           : CM_CamControllerAgent;
	proxyCamTaskHistory                                : CM_CamTaskHistory;
	bgpManager                                         : BGP_Manager;
	bgpGeneric                                         : BGP_GenericController;
	
	allCoarriExportPorts : CM_PortByCodeDict;
	emailCopyAddresses : CM_EmailEntityByTypeNameDict;
	packOperators : CM_OperatorByCodeDict;
	packExportConsignees : CM_ConsignByCodeDict;
	camEditTriggerFields : CM_CamEditTriggerFieldDict;
	camTrainEventTypes : CM_EventTypeByNameDict;
	allPackAreas : CM_TAByIdDict;
	registeredTransactions : StringArray;
	scheduleTimes : TimeArray;
	lRegisteredCargoTypes : IntegerArray;
	camProtocolDesc : CM_CamProtocolDesc;
	emailEntity : CM_EmailEntity;
	camGroup : CM_CamGroup;
	startDateTime : TimeStamp;
	endDateTime : TimeStamp;
	date        : Date;
	clearToDate : Date;
begin
    
	camProtocol := self.getCamProtocol(CamProtocol);
	self.deleteCamProtocol(CamProtocol);
	self.assertIsDeleted(camProtocol);
	create allCoarriExportPorts transient;
	create emailCopyAddresses transient;
	create packOperators transient;
	create packExportConsignees transient;
	create registeredTransactions transient;
	registeredTransactions.add(global.getTiTxnTypeForClass(CM_PackComplete).asStringJMT);
	create scheduleTimes transient;
	create camEditTriggerFields transient;
	create camTrainEventTypes transient;
	create allPackAreas transient;
	create lRegisteredCargoTypes transient;
	lRegisteredCargoTypes.add(TI_CargoType_Container);
	camProtocolDesc := app.myRoot.allCamProtocolDescs["Maersk Codeco"];
	emailEntity := app.myRoot.allEmailEntities[1, "Mr. Testing"];
	camGroup := self.getCamGroup("UT_AST1");
	camProtocol := self.addCamProtocol(CamProtocol, CamDesc, allCoarriExportPorts, camGroup, "NZCHC", emailEntity, false, emailCopyAddresses, false, "CamMessage", "CamSubject",
	                                   startDateTime, startDateTime, false, null, "txt", TestOperator, packOperators, packExportConsignees, '', camProtocolDesc, registeredTransactions,
									   false, 1, false, scheduleTimes, false, false, false, false, false, false, false, false, false, false, false, false, 
									   false, false, false, false, false, false, false, false, false, false, false, false, 
									   0, 0, 0, 0, '', '', '', camEditTriggerFields, camTrainEventTypes, null, false, CAM_HOLDSTATUS, self.getTerminal, true, true, false, true, true, false, false, false, true, 
									   allPackAreas, null, null, lRegisteredCargoTypes);
	self.assertNotNull(camProtocol);
	
    clearToDate := clearToDate + 2;
	app.myTrxDA.trxDeleteCamsHistory(camProtocol, clearToDate, date, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();	
	
	create proxyCamHistory transient;
	proxyCamHistory.set(runDateTime, startDateTime, endDateTime, false, camProtocol, 1, 1, "", CAM_HOLDSTATUS, "error");
	create camAgent transient;
	camAgent.setHistoryStatus(camProtocol, 1);
    app.myTrxCA.trxCreateCamTaskHistory(proxyCamHistory, camHistory, camProtocol, camAgent, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
	beginLoad;
	proxyCamTaskHistory := camHistory.pxyCreateUpdateProxy();
	endLoad;
	
	date := date + 1;
	runDateTime.setDate(date);
	proxyCamTaskHistory.setPropertyValue("runDateTime", runDateTime);
	app.myTrxUA.trxUpdateCamTaskHistory(proxyCamTaskHistory, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
	
	// create the BGPManager
	
	if app.myRoot.allBGPManagers["CAMS"] = null then
	   self.opts.purge();
	   self.opts.addAssoc("IsServer", true);
	   bgpManager := self.addBGPManager("CAMS");
	   self.assertNotNull(bgpManager);
	else
	   bgpManager := app.myRoot.allBGPManagers["CAMS"];
	   self.assertNotNull(bgpManager);
	endif;
	
	// start bgp if not running already
	if not bgpManager.isRunning then
	bgpGeneric := bgpManager.allBGPControllers.last.BGP_GenericController;
	bgpManager.startBackGroundApp(bgpGeneric, false);
	endif;
	
	app.myTrxCA.trxCreateRestartCamsRequest(camHistory,null,null, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	bgpManager.terminateProcessing(app.getMyUserCode());
epilog
    delete proxyCamHistory;
	
	delete allCoarriExportPorts;
	delete emailCopyAddresses;
	delete packOperators;
	delete packExportConsignees;
	delete registeredTransactions;
	delete scheduleTimes;
	delete camEditTriggerFields;
	delete camTrainEventTypes;
	delete allPackAreas;
	delete lRegisteredCargoTypes;
	delete camAgent;
	delete proxyCamTaskHistory;
end;</source>
    </JadeMethod>
    <JadeMethod name="tCargoCheckAndItems" id="bc721f09-1cdc-4d79-8bbc-dc6cee2e6822">
        <source>tCargoCheckAndItems();

/*

Purpose:		

Date			Who		Reason
18/06/2015		cnwmh5	Initial creation

*/

vars

	cargoCheck						: CM_CargoCheck;
	cargoCheckItem					: CM_CargoCheckItem;

	cargoCheckItems					: CM_CargoCheckItemSet;

begin

	create cargoCheckItems transient;
	
	// create cargo check
	cargoCheck := self.addCargoCheck(28091993, false, cargoCheckItems);
	self.assertNotNull(cargoCheck);
	
	// create cargo check item(s)
	cargoCheckItem := self.addCargoCheckItem(cargoCheck, "UTMDHTest", "No Info Reqd", null, null, false);
	self.assertNotNull(cargoCheckItem);
	
	self.opts.purge();
	self.opts.addAssoc("Required", true);
	self.updateCargoCheckItem(cargoCheckItem);
	self.assertEqual(cargoCheckItem.required, true);
	
	cargoCheckItem := self.addCargoCheckItem(cargoCheck, "UTMDHTest1", "Info Reqd", null, null, true);
	self.assertNotNull(cargoCheckItem);
	self.assertEqual(cargoCheck.allCargoCheckItems.first.name, "UTMDHTest");
	self.assertEqual(cargoCheck.allCargoCheckItems.last.name, "UTMDHTest1");
	
	// move item check
	beginTransaction;
	cargoCheck.allCargoCheckItems.moveElement(cargoCheck.allCargoCheckItems.last, true);
	commitTransaction;
	self.assertEqual(cargoCheck.allCargoCheckItems.first.name, "UTMDHTest1");
	self.assertEqual(cargoCheck.allCargoCheckItems.last.name, "UTMDHTest");

epilog

	delete cargoCheckItems;
	
	self.deleteCargoCheck(28091993);
	self.assertNull(self.getTerminal().allCargoChecks[28091193]);

end;</source>
    </JadeMethod>
