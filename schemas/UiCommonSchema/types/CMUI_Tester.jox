    <JadeMethod name="extractTag" id="fcecf189-517e-442f-a2e5-caf634bab690">
        <source>extractTag(pMsgString : String; pPos : Integer io) : String protected;
// ---------------------------------------------------------------------------
// Created:     18 April 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	len,
	sPos,
	ePos	: Integer;
	rtnTag	: String;
	
begin

	sPos := pMsgString.pos("&lt;", pPos);
    ePos := pMsgString.pos("&gt;", pPos);
    rtnTag := "";

    if (sPos &gt; 0 and ePos &gt; 0) and (sPos &lt; ePos) then
    	if pMsgString[ePos-1:1] = "/" then
    		// looking for &lt;TAG_NAME/&gt;
    		ePos := ePos - 1;
    	endif;
    	
    	len := (ePos -1 ) - sPos;
    	rtnTag := pMsgString[sPos + 1 : len];
    	
    	pPos := ePos + 1;
    endif;
    
    return rtnTag;

end;</source>
        <access>protected</access>
        <Parameter name="pMsgString" type="String"/>
        <Parameter name="pPos" type="Integer" usage="io"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="extractValue" id="87819eed-7e6c-4d27-ba9b-bb4c031f7e9d">
        <source>extractValue(pMsgString : String; pPos : Integer io) : String protected;
// ---------------------------------------------------------------------------
// Created:     18 April 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	len,
	sPos,
	ePos	: Integer;
	value	: String;
	
begin

	sPos := pPos;
    ePos := pMsgString.pos(CrLf, pPos);
    value := "";

    if (sPos &gt; 0 and ePos &gt; 0) and (sPos &lt; ePos) then
    	len := ePos - sPos;
    	value := pMsgString[sPos : len];
    	
    	pPos := ePos;
    endif;
    
    return value;

end;</source>
        <access>protected</access>
        <Parameter name="pMsgString" type="String"/>
        <Parameter name="pPos" type="Integer" usage="io"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="fillControlsCombo" id="883dfe89-1a92-4972-ba19-eaaab5ce8965">
        <source>fillControlsCombo(pForm : Form);
// ---------------------------------------------------------------------------
// Created:     18 April 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	numControls,
	idx			: Integer;
	control		: Control;
	
begin

	self.allControls.clear;

	numControls := pForm.controlCount;
	
	foreach idx in 1 to numControls do
		control := pForm.controls(idx);
		self.allControls.add(control);
	endforeach;

	cmbControls.listCollection(self.allControls, false, 0);
	
end;</source>
        <Parameter name="pForm" type="Form"/>
    </JadeMethod>
    <JadeMethod name="fillFormsCombo" id="378677f7-b82f-4083-8cf4-fcaac0b3822c">
        <source>fillFormsCombo();
// ---------------------------------------------------------------------------
// Created:     18 April 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	numForms,
	idx		: Integer;
	form	: Form;
	
begin

	self.allForms.clear;

	numForms := app.formsCount;
	
	foreach idx in 1 to numForms do
		form := app.forms(idx);
		self.allForms.add(form);
	endforeach;

	cmbForms.listCollection(self.allForms, false, 0);
		
end;</source>
    </JadeMethod>
    <JadeMethod name="getValues" id="bf05c678-fe9a-45db-8ff5-89f441ff2cbd">
        <source>getValues(pForm : Form; pControl : Control; pInclChildren : Boolean) : String;
// ---------------------------------------------------------------------------
// Created:     18 April 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	rtnStr	: String;
	numControls,
	idx		: Integer;
	control	: Control;
	
begin

	rtnStr := getValuesForControl(pControl);

	if (not pInclChildren) then
		return rtnStr;
	endif;
	
	numControls := pForm.controlCount;
	
	foreach idx in 1 to numControls do
		control := pForm.controls(idx);
		if control.parent = pControl then
			rtnStr := rtnStr &amp; self.getValues(pForm, control, pInclChildren);
		endif;
	endforeach;
	
	return rtnStr;

end;</source>
        <Parameter name="pForm" type="Form"/>
        <Parameter name="pControl" type="Control"/>
        <Parameter name="pInclChildren" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getValuesForControl" id="e265a048-8f83-4de3-9aef-ceed9f710566">
        <source>getValuesForControl(pControl : Control) : String;
// ---------------------------------------------------------------------------
// Created:     18 April 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	txt,
	tmpStr,
	rtnStr				: String;
	idx					: Integer;
	entTable			: CM_EntryTable;
	entRowTrans			: EntTableRowTransient;
begin

	if pControl.isKindOf(Frame) or
	   pControl.isKindOf(GroupBox) or
	   pControl.isKindOf(CMUI_SplitContainer) then
		return null;
	endif;

	if pControl.isKindOf(TextBox) then
		txt := pControl.TextBox.text;

	elseif pControl.isKindOf(CM_EntryTable) then
		entTable := pControl.CM_EntryTable;
		foreach idx in 1 to entTable.rows do
			entRowTrans := entTable.accessRow(idx).itemObject.EntTableRowTransient;
			if entRowTrans.visible then
				tmpStr := entTable.getValue(idx).String;
				txt := txt &amp; buildXmlForControl(entRowTrans.name, tmpStr, null, true);
			endif;
		endforeach;

	elseif pControl.isKindOf(ComboBox) then
		txt := pControl.ComboBox.text;
	else
		txt := '&lt;unknown&gt;';
	endif;

	rtnStr := buildXmlForControl(pControl.name, txt, null, true);

	return rtnStr;
	
end;</source>
        <Parameter name="pControl" type="Control"/>
        <ReturnType type="String"/>
    </JadeMethod>
