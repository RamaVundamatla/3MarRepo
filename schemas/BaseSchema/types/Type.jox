<Class name="Type">
    <JadeMethod name="cnEcGetMaxLength" id="e5c990e0-957b-4fff-aee4-7e408c8e9302">
        <source>cnEcGetMaxLength():Integer;
// --------------------------------------------------------------------------------
// Created:		05 April 2005 by cnwdad1
//
// Purpose:		Returns the maximum length of the receiver.
//
// Parameters:	None
//
// Returns:		The receiver's maximum length.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if self.name = Character.name and app.isUnicode() then
		return (self.maxLength div 2);
	else	
		return self.maxLength;
	endif;	
end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="cnEcIsCollection" id="453d7fe7-1ae7-47d1-9c30-5d808483f1b6">
        <source>cnEcIsCollection():Boolean;
// --------------------------------------------------------------------------------
// Created:		01 November 2001 by cnwdad1
//
// Purpose:		Returns a flag to indicate whether the receiver is a Collection Type.
//
// Parameters:	None
//
// Returns:		True if the receiver is a Collection Type, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return false;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="cnEcIsPrimitive" id="7b1b0c68-41ae-4353-aea2-01dfba21beea">
        <source>cnEcIsPrimitive():Boolean;
// --------------------------------------------------------------------------------
// Created:		02 November 2001 by cnwdad1
//
// Purpose:		Returns a flag to indicate whether the receiver is a Primitive Type.
//
// Parameters:	None
//
// Returns:		True if the receiver is a Primitive Type, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return false;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
