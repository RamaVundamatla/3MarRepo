    <JadeMethod name="canUserSet" id="4bf58bee-5651-4d80-8e34-b66cdde43c38">
        <source>canUserSet(_propName: String): Boolean;
//
// 05 Nov 2014	cnwrs1	Par 34702 - Add support for JMT XML with implied header
//
vars

begin
	if _propName = CM_EDIDataBayPlan::loadRecordsForPort.name or
	   _propName = CM_EDIDataBayPlan::sendTime.name then
		return false;
	else
		return inheritMethod(_propName);
	endif;
end;
</source>
        <Parameter name="_propName" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
