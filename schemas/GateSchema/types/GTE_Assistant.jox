    <JadeMethod name="setIntFaceObjectReal" id="f9509976-e512-4e6e-9843-3dcf07ec497d">
        <source>setIntFaceObjectReal(_intFaceObject : CMIF_TIObject io; _tblMain, _tblExtra : CM_EntryTable input; 
							_fieldName : String; _nullValue : Real);
//----------------------------------------------------------------
//	Created:	Nov 2008 cnwrs1
