    <JadeMethod name="bnFindNext_click" id="49917d87-0f33-49f0-bb0b-0cb48aceb62c">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>bnFindNext_click(btn: Button input) updating;

/*

Purpose:			Scroll through the current file until there is an after image to 
					view, or the end of the file


Return Value:		


Date		Who		Reason
24 Jan 2005	cnwkpd1	Initial creation

*/

constants
	RefreshTime		= 2000;
	
vars
	lastRefresh		: Decimal[23];
	
begin
	app.mousePointer := Window.MousePointer_HourGlass;

	searchCancelled := false;
	bnCancelFind.enabled := true;
	lastRefresh := app.relativeMachineTime;
	
	while not searchCancelled do
		if getNextRecord = 0 or bnAfterImage.enabled then
			break;
		endif;
		
		if (app.relativeMachineTime - lastRefresh) &gt; RefreshTime then
			refreshNow;
			lastRefresh := app.relativeMachineTime;
		endif;
		bnCancelFind.doWindowEvents(0);
	endwhile;
		

epilog
	bnCancelFind.enabled := false;
	app.mousePointer := Window.MousePointer_Default;

end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="bnLoadRemaps_click" id="511ab671-1051-499f-8dec-2ddf9dd7648d">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>bnLoadRemaps_click(btn: Button input) updating;

begin
	if txRemapFileName.text &lt;&gt; null then
		if txMapClassNo.text &lt;&gt; null then
			postMsg("Error: remap class number has been specified");
		elseif txMapVersionNo.text &lt;&gt; null then
			postMsg("Error: remap version number has been specified");
		else
			jjAccess.loadClassNumberMapsFile(txRemapFileName.text);
		endif;
	else
		if txMapClassNo.text = null then
			postMsg("Error: remap class number has not been specified");
		elseif txMapVersionNo.text = null then
			postMsg("Error: remap version number has not been specified");
		else
			jjAccess.addClassNumberMap(txMapClassNo.text.Integer, txMapAuditClsNo.text.Integer, txMapVersionNo.text.Integer);
		endif;
	endif;
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="bnNextJournal_click" id="65b32166-c687-42cd-990a-659e4632b4e2">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>bnNextJournal_click(btn: Button input) updating;

begin
	on SystemException do handleNextJournalException(exception);
	
	jjAccess.getNextJournal;
	updateCurrentJournal;
	
	postMsg("Next journal selected");
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
