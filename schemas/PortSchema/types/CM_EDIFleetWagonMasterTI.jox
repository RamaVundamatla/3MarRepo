    <JadeMethod name="canUserSet" id="c799931a-707f-4066-89a1-ca642d40d339">
        <source>canUserSet(_propName: String): Boolean;
//
// 30 Jun 2014	cnwrs1	Par 34702 - Add support for JMT XML
//
vars

begin
	if _propName = CM_EDIFleetWagonMasterTI::myCarrier.name or
	   _propName = CM_EDIFleetWagonMasterTI::myWagonClass.name then
		return false;
	else
		return inheritMethod(_propName);
	endif;
end;
</source>
        <Parameter name="_propName" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="b75a3903-1eba-47d5-acfb-4367f2502f27">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 14/06/2013	cnwdap1		Initial creation PAR #31155 CCMS SFW 1321 Imperial Measurements
//
vars
	str, type	: String;

begin
	if _attrName.isMeasurementType then
		// _attrName will be formatted as WTRow_&lt;real ent row name&gt;_&lt;weight unit&gt;
		_attrName.getRowNameMeasureType(str, type);
		return self.getMeasurementStringForAttrib(str, type, _short);
	endif;
	
	return inheritMethod(_attrName, _short);

epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getMyTIDisplayDefName" id="2300c9ab-175f-4ded-ac1a-345a3b883263">
        <source>getMyTIDisplayDefName(): String;

vars

begin
	return ETDef_WagonMasterEDI;
end;
</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="1e7b94de-3b20-410e-a82c-2d01dfc31f26">
        <updating/>
        <source>setForUpdate(_proxyEDITI: SelfType) updating;
/*
Purpose:			
Parameters:			
Return Value:		
Date		Who		Reason
31 August 2009	cnwjmn1	Initial creation
*/
/// 22 Feb 2016	cnwrs1	TFS 3401 fixup EDI Operations update of EDI TIs
// 08 May 2018	jlgrs1	TFS 36425 SingleLine Booking partial processing not working
vars

begin
	inheritMethod(_proxyEDITI);
	
	self.description			:= _proxyEDITI.description;		// PAR21225
	self.maxCargoHeight	:= _proxyEDITI.maxCargoHeight;
	self.maxCargoWeight	:= _proxyEDITI.maxCargoWeight;
	self.tareWeight		:= _proxyEDITI.tareWeight;
	self.myCarrier		:= _proxyEDITI.myCarrier;
	self.myWagonClass	:= _proxyEDITI.myWagonClass;
	self.setId(self.id.toUpper);		// Wagon ids should always be uppercase
	self.carrier := _proxyEDITI.carrier;
	self.wagonClass := _proxyEDITI.wagonClass;
epilog

end;</source>
        <Parameter name="_proxyEDITI" type="SelfType"/>
    </JadeMethod>
</Class>
