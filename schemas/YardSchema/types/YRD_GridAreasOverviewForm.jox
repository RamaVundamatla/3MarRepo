    <JadeMethod name="doMnuRemarksClick" id="6db96382-bf6b-4818-945d-574c51ef5e45">
        <updating/>
        <source>doMnuRemarksClick(_menuItem: MenuItem input) updating;
// ---------------------------------------------------------------------------
// Created:		October 2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	lForm : CMUI_GetData;
	theTI : CM_TrackedItem;
begin
	if _menuItem.userObject = null then
		return;
	endif;
	
	theTI := _menuItem.userObject.CM_TrackedItem;

	create lForm;
	lForm.centreWindow;
	self.mousePointer := MousePointer_Default;
	
	lForm.lblTextCaption := app.getErrorString1( Additional_remarks_ti,theTI.id) ;
	
	lForm.txtReadOnly.visible := true;
	lForm.bigSize := true;
	lForm.txtReadOnly.text := theTI.remarks;
	lForm.txtData.text := null;
//	lForm.txtData.height := lForm.txtData.height * 5;
	lForm.txtData.dataType := TextBox.DataType_AlphaNumeric;
	lForm.myCaller := self;
	lForm.formCaption := app.getErrorString(Additional_remarks);
	lForm.type := self.GetData_Remarks;
	lForm.show;
epilog
	mousePointer := MousePointer_Default;

end;</source>
        <Parameter name="_menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doMnuRemoveLabRestrictClick" id="60e3024b-58d4-4259-ae30-a4acfb3f5364">
