    <JadeMethod name="updateMovementClearances" id="fb48d20d-cb63-4fcf-876c-47cccebd2e38">
        <updating/>
        <source>updateMovementClearances()updating, protected;
//--------------------------------------------------
// Created:	06 October 2005 By: cnwgd1
//--------------------------------------------------
vars
	checkToDT,
	checkFromDT	: TimeStamp;
	iter		: Iterator;
	tmpMove,
	tmpMove2	: HMS_VoyageMovement;
	tmpDict : HMS_VoyageMovementByDateDict;   		
begin

	tmpMove := self.getMovementForMoveType(HMSMovementTypeDeparture);
	
	if tmpMove = null then
		return;
	endif;

	if tmpMove.isLogicalBerth then
		//Clearance don't need re-calculating
		return;
	endif;

	checkFromDT := tmpMove.occursOnDTNEW;
		
	//Rebuild collection for recalculation clearances
	create tmpDict transient;	
	self.myHarbour.buildMoveCollToValidate(tmpDict, checkFromDT.cnEcAddDays(-30), null);

	// Re-calculate clearances for voyages in vicinity
	checkToDT := checkFromDT;
	checkToDT := checkToDT.cnEcAddDays(30);
	
	iter := tmpDict.createIterator();
	
	while iter.next(tmpMove2) do
		if tmpMove2.occursOnDTNEW &gt; checkToDT then
			break;
		endif;
		if (not tmpMove2.isLogicalBerth) then
			if tmpMove2.getMyWharf = tmpMove.getMyWharf then
				//On the same wharf	
				tmpMove2.calc_Set_Clearances(tmpDict);
			endif;
		endif;
	endwhile;

epilog
	delete tmpDict;
	delete iter;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="updateVoyageDataFromVesselData" id="ac51c4a8-1be1-46a1-94ce-63b3877d8dd3">
        <updating/>
        <source>updateVoyageDataFromVesselData(_realVessel : CM_Vessel; _passport : CM_Passport input)updating;
//--------------------------------------------------
// Created:	27 August 2004 By: cnwgd1
//--------------------------------------------------
vars
	movement : HMS_VoyageMovement;
	tmpVDHarbour : HMS_VesselDataHarbour;
	tmpVesselData : HMS_VesselData;
begin
	
	if _realVessel = null then
		app.writeLog('Cannot locate _realVessel ' &amp; self.String, LogINFO);
		return;
	endif;

    self.vesselCode := _realVessel.code;
    self.vesselName := _realVessel.name;
    
	tmpVesselData := _realVessel.myHMSVesselData;
	
	if tmpVesselData = null then
		return;
	endif;
	
	self.coastalServiceVessel	:= tmpVesselData.coastalServiceVessel;
	self.countryCode			:= tmpVesselData.countryCode;

	self.dim_Beam				:= tmpVesselData.dim_Beam;
	self.dim_DeadWeight			:= tmpVesselData.dim_DeadWeight;
	self.dim_DraftAft			:= tmpVesselData.dim_DraftAft;
	self.dim_DraftFore			:= tmpVesselData.dim_DraftFore;
	self.dim_GrossRegTonnes		:= tmpVesselData.dim_GrossRegTonnes;
	self.dim_NetRegTonnes		:= tmpVesselData.dim_NetRegTonnes;		// QNS 2178
	
	//LOA (self.dim_LengthOverall) done last as movement marks may need updating

	self.dist_BowToFwdContainer := tmpVesselData.dist_BowToFwdContainer;
	self.dist_BridgeToBow		:= tmpVesselData.dist_BridgeToBow;
	self.dist_BridgeToStern		:= tmpVesselData.dist_BridgeToStern;
	self.dist_SternToAftContainer:= tmpVesselData.dist_SternToAftContainer;
	self.dist_SternToBunker		:= tmpVesselData.dist_SternToBunker;

	self.hasBowThrust			:= tmpVesselData.hasBowThrust;
	self.hasFixedProp			:= tmpVesselData.hasFixedProp;
	self.hasHoldTanks			:= tmpVesselData.hasHoldTanks;
	self.hasRamp				:= tmpVesselData.hasRamp;
	self.hasSternThrust			:= tmpVesselData.hasSternThrust;

	self.myVesselType			:= tmpVesselData.myVesselType;

	self.remarksGeneral 		:= tmpVesselData.remarksGeneral;
	self.remarksPreviousNames 	:= tmpVesselData.remarksPreviousNames;
	self.requiresTow			:= tmpVesselData.requiresTow;	//21 Aug 2018	NDL	TFS 40347

	// this will update movement marks if necessary
	self.setLOA(tmpVesselData.dim_LengthOverall);    
    
	// Set defaults from vessel data for harbour ---------------------------	
	tmpVDHarbour := tmpVesselData.allVesselDataForHarbour[self.myHarbour];
	if tmpVDHarbour &lt;&gt; null then
		self.berthPriority			:= tmpVDHarbour.berthPriority;
		self.estTieUpTime			:= tmpVDHarbour.estTieUpTime;
		self.excludeReport			:= tmpVDHarbour.excludeReport;
		self.isPilotExempt			:= tmpVDHarbour.isPilotExempt;	
		self.numLCrewLetGo 			:= tmpVDHarbour.numLCrewLetGo;
		self.numLCrewTieUp 			:= tmpVDHarbour.numLCrewTieUp;
		self.numTugsIn 				:= tmpVDHarbour.numTugsIn;
		self.numTugsOut 			:= tmpVDHarbour.numTugsOut;
		self.remarksPilotOnly 		:= tmpVDHarbour.remarksPilotOnly;
		self.myLineCompany 			:= tmpVDHarbour.myLineCompany;
		self.myShippingAgent 		:= tmpVDHarbour.myShippingAgent;
		self.myTidalClass 			:= tmpVDHarbour.myTidalClassArrival;
		self.myTidalClassDept 		:= tmpVDHarbour.myTidalClassDeparture;
	 	self.myVesselCategoryIn 	:= tmpVDHarbour.myVesselCategoryIn;
	 	self.myVesselCategoryOut 	:= tmpVDHarbour.myVesselCategoryOut;
	
	endif; 	
	//----------------------------------------------------------------------	

end;</source>
        <Parameter name="_realVessel" type="CM_Vessel"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="validateConflictsBeforeUpdate" id="4ee09880-538d-43fe-8c75-6261ac5f7fe5">
        <source>validateConflictsBeforeUpdate(_conflictManager: CMIF_HMS_ConflictsManager output; _pxyVoyageData : HMS_VoyageData);
//--------------------------------------------------------------
//Created: 22 July 2003 By: cnwgd1
// 02 Aug 2016	cnwrs1	Stop leakage
//--------------------------------------------------------------
vars
	validationType		: Integer;
	clearanceChecked	: Boolean;
	tmpMovement			: HMS_VoyageMovement;
	
begin
	if _pxyVoyageData = null then
		return;
	endif;
	
	create _conflictManager transient;

	if _pxyVoyageData.myVoyage &lt;&gt; null then // can be null if changing cargo structure type
		if self.myVoyage.arrivedDT &lt;&gt; _pxyVoyageData.myVoyage.arrivedDT
		or self.myVoyage.departedDT &lt;&gt; _pxyVoyageData.myVoyage.departedDT then
			// Move date/time changes
			// Run validation on Tidal window changes
			_conflictManager.buildMoveCollToValidate();
			_conflictManager.allValidationTypes.add(ValidateClearances);
		endif;
	endif;
		
	if self.dim_LengthOverall &lt;&gt; _pxyVoyageData.dim_LengthOverall then
		// Ship length has been changed
		// Run validation on ship length changes
		if _conflictManager.allMovesToValidate.isEmpty then
			_conflictManager.buildMoveCollToValidate();
		endif;		
		_conflictManager.allValidationTypes.add(ValidateShipPosn);
	endif;

	if self.dim_DraftAft &lt;&gt; _pxyVoyageData.dim_DraftAft 
	or self.dim_DraftFore &lt;&gt; _pxyVoyageData.dim_DraftFore then
		// Ship max draft has been changed
		// Run validation on ship draft changes
		_conflictManager.allValidationTypes.add(ValidateShipDraft);
	endif;

	if (not _conflictManager.allValidationTypes.isEmpty()) then
		_conflictManager.myHarbour := self.myHarbour;
		_conflictManager.endDT := self.myVoyage.departedDT;
		_conflictManager.runConflictReport();
	endif;

	if (not _conflictManager.allCMIFConflicts.isEmpty) then
		app.raiseCMWarning(HMSMovementConflict, null, null, _pxyVoyageData.myVoyage);
	endif;
epilog
	delete _conflictManager;
	_conflictManager := null;
end;</source>
        <Parameter name="_conflictManager" type="CMIF_HMS_ConflictsManager" usage="output"/>
        <Parameter name="_pxyVoyageData" type="HMS_VoyageData"/>
    </JadeMethod>
    <JadeMethod name="validateDateTimes" id="cf1062b8-2550-4ff9-a3dc-cd42dccb12c5">
        <source>validateDateTimes(_arriveDT, _departDT : TimeStamp output; _passport: CM_Passport input)protected;
//--------------------------------------------------------------
//Created: 24 July 2003 By: cnwgd1
//
// Changed On	By			Reason
//--------------------------------------------------------------
// 11/12/2023	navdap1		TFS 61734 POB | Qships - Voyage info for EDI errors.
vars
	date		: Date;
	time		: Time;
	movement	: HMS_VoyageMovement;
begin
	if app.isConverting then
		return;
	endif;
	
 	_arriveDT := self.myVoyage.arrivedDT;
 	date := _arriveDT.date;
 	time := _arriveDT.time;
 	if (not date.isValid) then
 		app.raiseCMException(Input_required_field_arrivDate, ETRow_ArriveDT, null); // cnwdb2	PAR 35364
 	endif;
 	if (not time.isValid) then
		app.raiseCMException(Input_required_field_arrivTime, ETRow_ArriveTM, null); // cnwdb2	PAR 35364
 	endif; 	
 	
 	_departDT := self.myVoyage.departedDT;
 	date := _departDT.date;
 	time := _departDT.time;
 	if (not date.isValid) then
 		app.raiseCMException(Input_required_field_deptDate, ETRow_DepartDT, null); // cnwdb2	PAR 35364
 	endif;
 	if (not time.isValid) then
 		app.raiseCMException(Input_required_field_deptTime, ETRow_DepartTM, null); // cnwdb2	PAR 35364
 	endif; 	 	

	if _arriveDT &gt;= _departDT then
		app.raiseCMException1(AutoScheduleDateError, self.myVoyage.code &amp; Space &amp; app.getErrorString(ArrivalDTAfterDepartDT),  null, null);		// TFS 61734
		return;	
	endif;
	
	if _passport.hasErrors() then
		return;
	endif;
	
	//Check no shift movements occur on the day or after the new departure date.  If there are they'll have to be removed first.
	foreach movement in self.allVoyageMovements do
		if movement.moveType = HMSMovementTypeShift then
			if movement.occursOnDTNEW &lt;= _arriveDT then
				app.raiseCMException4(HMSDateTimeShiftMovement, 'arrival', 'after', movement.occursOnDTNEW.shortCurrentLocaleFormat(), self.myVoyage.code, null, null);		// TFS 61734
				break;			
			elseif movement.occursOnDTNEW &gt;= _departDT then
				app.raiseCMException4(HMSDateTimeShiftMovement, 'departure', 'before', movement.occursOnDTNEW.shortCurrentLocaleFormat(), self.myVoyage.code, null, null);	// TFS 61734
				break;
			endif;
		endif;
	endforeach;
	
end;</source>
        <access>protected</access>
        <Parameter name="_arriveDT" type="TimeStamp" usage="output"/>
        <Parameter name="_departDT" type="TimeStamp" usage="output"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="validateDimensions" id="f6a34ec6-8ac0-4136-8d05-aa507afd5ce8">
        <source>validateDimensions()protected;
//--------------------------------------------------
// Created:	25 August 2004 By: cnwgd1
//--------------------------------------------------
vars

begin

	//18/3/08 epr 16214 deleted the code block that validated LOA &gt; 0 because its is doing the same thing here
	// Check 'Length Overall'
	if self.dim_LengthOverall &lt;= LOA_LowerLimit or self.dim_LengthOverall &gt; LOA_UpperLimit then
		app.raiseCMException3(VesselData_Dimension, 'Length Overall (LOA) (m)', LOA_LowerLimit.String, LOA_UpperLimit.String, null, null); 	
	endif;

	if self.dim_GrossRegTonnes &lt; GRT_LowerLimit or self.dim_GrossRegTonnes &gt; GRT_UpperLimit then
		app.raiseCMException3(VesselData_Dimension, 'Gross Reg Tonnes', GRT_LowerLimit.String, GRT_UpperLimit.String, null, null); 
	endif;
	if self.dim_NetRegTonnes &lt; GRT_LowerLimit or self.dim_NetRegTonnes &gt; GRT_UpperLimit then
		app.raiseCMException3(VesselData_Dimension, 'Net Reg Tonnes', GRT_LowerLimit.String, GRT_UpperLimit.String, null, null); 
	endif;

	// Check 'DeadWeight'
	if self.dim_DeadWeight &lt; DWT_LowerLimit or self.dim_DeadWeight &gt; DWT_UpperLimit then
		app.raiseCMException3(VesselData_Dimension, 'Dead Weight', DWT_LowerLimit.String, DWT_UpperLimit.String, null, null); 
	endif;

	// Check 'Beam'
	if self.dim_Beam &lt; BEAM_LowerLimit or self.dim_Beam &gt; BEAM_UpperLimit then
		app.raiseCMException3(VesselData_Dimension, 'Beam', BEAM_LowerLimit.String, BEAM_UpperLimit.String, null, null); 
	endif;

	// Check 'Aft Draft'
	if self.dim_DraftAft &lt; DRAFT_LowerLimit or self.dim_DraftAft &gt; DRAFT_UpperLimit then
		app.raiseCMException3(VesselData_Dimension, 'Draft Aft', DRAFT_LowerLimit.String, DRAFT_UpperLimit.String, null, null); 
	endif;
	
	 // Check 'Fore Draft'
	if self.dim_DraftFore &lt; DRAFT_LowerLimit or self.dim_DraftFore &gt; DRAFT_UpperLimit then
		app.raiseCMException3(VesselData_Dimension, 'Draft Fore', DRAFT_LowerLimit.String, DRAFT_UpperLimit.String, null, null); 
	endif;

	if self.dist_BridgeToBow &lt; Distance_LowerLimit or self.dist_BridgeToBow &gt; Distance_UpperLimit then
		app.raiseCMException3(VesselData_Distance, 'Bridge To Bow', Distance_LowerLimit.String, Distance_UpperLimit.String, null, null); 
	endif;

	// Bridge to Stern
	if self.dist_BridgeToStern &lt; Distance_LowerLimit or self.dist_BridgeToBow &gt; Distance_UpperLimit then
		app.raiseCMException3(VesselData_Distance, 'Bridge To Stern', Distance_LowerLimit.String, Distance_UpperLimit.String, null, null); 
	endif;	

	// Bow to Fwd Container Bay
	if self.dist_BowToFwdContainer &lt; Distance_LowerLimit or self.dist_BridgeToBow &gt; Distance_UpperLimit then
		app.raiseCMException3(VesselData_Distance, 'Bow To Fwd Container', Distance_LowerLimit.String, Distance_UpperLimit.String,null, null); 
	endif;
		
	// Stern to Aft Container Bay
	if self.dist_SternToAftContainer &lt; Distance_LowerLimit or self.dist_BridgeToBow &gt; Distance_UpperLimit then
		app.raiseCMException3(VesselData_Distance, 'Stern To Aft Container', Distance_LowerLimit.String, Distance_UpperLimit.String,null, null); 
	endif;
		
	// Stern to Bunker Point
	if self.dist_SternToBunker &lt; Distance_LowerLimit or self.dist_BridgeToBow &gt; Distance_UpperLimit then
		app.raiseCMException3(VesselData_Distance, 'Stern To Bunker', Distance_LowerLimit.String, Distance_UpperLimit.String, null,null); 
	endif;			
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="validateForConvertFromOther" id="ad2c088c-dd3c-4469-894a-db355eec0542">
        <source>validateForConvertFromOther(_passport: CM_Passport input);
//--------------------------------------------------------------
//Created: 24 July 2003 By: cnwgd1
//--------------------------------------------------------------
vars
	departDT,
	arriveDT 	: TimeStamp;
	shipToCheck : CM_Vessel;
begin

	self.validateVessel(shipToCheck, _passport);
	
	self.validateDateTimes(arriveDT, departDT, _passport);	
	
	self.validateVoyageDelay(_passport);	
	
end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="validateForCreate" id="36444f3d-7331-40aa-8983-07ebc2d8743a">
        <source>validateForCreate(_passport: CM_Passport input);
//--------------------------------------------------------------
//Created: 24 July 2003 By: cnwgd1
//--------------------------------------------------------------
vars
	vessel : CM_Vessel;
	firstMovement,
	lastMovement,
	tmpMovement : HMS_VoyageMovement;
begin

 	vessel := self.getMyVessel();

 	if vessel = null then
 	//	app.raiseCMException1(REQUIRED_FIELD, 'Vessel', null, null);
		app.raiseCMException(Input_required_field_vessel, null, null); // cnwdb2	PAR 35364
 	endif;
 	
 	if vessel &lt;&gt; null then
 		if vessel.myHMSVesselData = null then
	 		app.raiseCMWarning1(HMS_No_VesselData, vessel.name, null, null, vessel);
	 	endif;
 	endif;
 	
 	//Check the default arrival and departure movements have been created
 	if self.allVoyageMovements.size &gt; 1 then
 		// there are two movements, check they are arrival and departure movements
 		firstMovement := self.allVoyageMovements.first;
 		lastMovement := self.allVoyageMovements.last;	 			 		
 		
 		// The first movement must be the arrival movement
 		if firstMovement.moveType &lt;&gt; HMSMovementTypeArrival then
	 		app.raiseUnexpectedProgramError(class.name, method.name, 'Invalid move type, arrival must be first.'); 	 		
 		endif;

 		// The last movement must be the departure movement	 		
 		if lastMovement.moveType &lt;&gt; HMSMovementTypeDeparture then
	 		app.raiseUnexpectedProgramError(class.name, method.name, 'Invalid move type, departure must be last.'); 
		endif;
	else
 		app.raiseUnexpectedProgramError(class.name, method.name, 'Invalid Default movements');
 	endif;
	
 	if _passport.hasErrors() then
 		return;
 	endif;
 	
 	// validated movement including clearances, tidal window.
	if vessel.hasHarbourDetails() then		// 14/8/19 MAP TFS45926
		foreach tmpMovement in self.allVoyageMovements do
			tmpMovement.validateForCreate(_passport);
		endforeach;
	endif;

	inheritMethod(_passport);
	
end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="validateForDelete" id="3f81e35c-485c-4f2c-a205-edb5009ce01e">
        <source>validateForDelete(_passport: CM_Passport input);
//--------------------------------------------------
// Created:	30 March 2004 By: cnwgd1
//--------------------------------------------------
vars

begin
	if _passport.hasErrors then
		return;
	endif;
	
	inheritMethod(_passport);
	
	if (not self.allVoyageMovements.isEmpty) then
		//epr par 16305 29/3/08 terminal has already been nulled before getting here can't refence it
		if not app.isGarbageCollectionProcess then
			app.raiseCMWarning2(HMSConfirmDelete, 'Voyage ' &amp; self.getDisplayString() , 'Movement', null, null, self); 
		endif;
	endif;

end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="validateMe" id="5a92d9f1-4222-4273-ae5f-985cb08ce735">
        <source>validateMe(_passport: CM_Passport input);
//--------------------------------------------------------------
//Created: 24 July 2003 By: cnwgd1
//--------------------------------------------------------------
vars
	departDT,
	arriveDT 	: TimeStamp;
	tmpPref 	: HMS_BerthPreference;
	vessel		: CM_Vessel;
	hasHMS		: Boolean;
begin
	inheritMethod(_passport);

 	vessel := self.getMyVessel();
	if vessel &lt;&gt; null then
		hasHMS := vessel.hasHarbourDetails();
	endif;

	if self.myHarbour = null then
		app.raiseCMException(Input_required_field_harbour, null, null); // cnwdb2	PAR 35364
 	endif;
	
	if self.myPortFrom = null and not global.changeForLicenceForComalco() then
 		app.raiseCMException(Input_required_field_arrFrmPrt, null, null);	 // cnwdb2	PAR 35364		
 	endif;

 	if self.myPortTo = null and not global.changeForLicenceForComalco() then
		app.raiseCMException(Input_required_field_deptToPrt, null, null); // cnwdb2	PAR 35364
 	endif;
 	
	if self.myVesselCategoryIn = null and not global.changeForLicenceForComalco() then
		app.raiseCMException(Input_required_field_vesCatIn, null, null);	 // cnwdb2	PAR 35364
 	endif;
 	
	if self.myVesselCategoryOut = null and not global.changeForLicenceForComalco() then
		app.raiseCMException(Input_required_field_vesCatOut, null, null); // cnwdb2	PAR 35364 
 	endif; 	 	 	 	 	 	 	 	 	 	 	

	if not app.isConverting then
		if hasHMS then		// 14/8/19 MAP TFS45926
			if self.myTidalClass = null then
				app.raiseCMException(Input_required_field_tidClsAr, ETRow_MyTidalClassArrival, null); // cnwdb2	PAR 35364
			endif;

			if self.myTidalClassDept = null then
				app.raiseCMException(Input_required_field_tidClsDpt, ETRow_MyTidalClassDept, null); // cnwdb2	PAR 35364
			endif;
		endif;
	endif;
	
 	if self.getMyBerth = null then
		app.raiseCMException(Input_required_field_berth, ETRow_MyBerth, null); // cnwdb2	PAR 35364
 	endif; 			

	if hasHMS then		// 14/8/19 MAP TFS45926
		self.validateDimensions();
	endif;
	
	foreach tmpPref in self.allBerthPreferencesArray do
		tmpPref.validateMe(_passport);
	endforeach;
	
	if _passport.hasErrors then
		return;
	endif;
	
	self.validateDateTimes(arriveDT, departDT, _passport);
	
	self.validateVoyageDelay(_passport);	
	
	if _passport.hasErrors then
		return;
	endif;			

	if hasHMS then		// 14/8/19 MAP TFS45926
		self.validateVesselInPort(arriveDT, departDT, _passport);
	endif;
end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="validateVessel" id="f53b674a-29ae-4cd0-b338-448c85f65074">
        <source>validateVessel(_vessel : CM_Vessel output; _passport: CM_Passport input)protected;
//--------------------------------------------------------------
//Created: 24 July 2003 By: cnwgd1
//--------------------------------------------------------------
vars

begin

 	_vessel := self.getMyVessel();

 	if _vessel = null then
 	//	app.raiseCMException1(REQUIRED_FIELD, 'Vessel', null, null);
		app.raiseCMException(Input_required_field_vessel, null, null); // cnwdb2	PAR 35364
 		return;
 	endif;
 	
 	if _vessel.myHMSVesselData = null then
 		app.raiseCMWarning1(HMS_No_VesselData, _vessel.name, null, null, _vessel);
 		return;
 	endif;

 	if self.getMyBerth = null then
// 		app.raiseCMException1(REQUIRED_FIELD, 'Berth', ETRow_MyBerth, null);
 		app.raiseCMException(Input_required_field_berth, ETRow_MyBerth, null); // cnwdb2	PAR 35364
 		return;
 	endif; 	

end;</source>
        <access>protected</access>
        <Parameter name="_vessel" type="CM_Vessel" usage="output"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="validateVesselInPort" id="1c79ac97-399c-4978-ba26-548b98e2c94b">
        <source>validateVesselInPort(_arriveDT, _departDT : TimeStamp; _passport : CM_Passport input)protected;
//-----------------------------------------
//Created: July 2003 By: cnwgd1
//-----------------------------------------
vars
	thisVessel : CM_Vessel;
	/*realVoyage,
	voyage		: CM_Voyage;
	terminal	: CM_Terminal;
	tmpVessel,
	thisVessel	: CM_Vessel;
	iter		: Iterator;*/
begin
 	// This method checks to see in the proposed visit for a ship is taking 
 	// place at the same time as an already booked visit of this ship - ie a 
 	// double entry of a booking.
	if not app.isConverting then
	 	if (not _arriveDT.isValid) then
 			app.raiseCMException1(AutoScheduleDateError, 'Arrive Date/Time', ETRow_ArriveDT, null);
	 	endif;
	 	if (not _departDT.isValid) then
	 		app.raiseCMException1(AutoScheduleDateError, 'Departure Date/Time', ETRow_DepartDT, null);
	 	endif; 	
 	 endif;
 	 
 	 
 	thisVessel := self.getMyVessel();
 	if thisVessel = null then
 		return;
 	endif;
 	
 	// Check all voyages in harbour
	self.myHarbour.validateVesselInPort(_arriveDT, _departDT, thisVessel, self.myVoyage, _passport);
 	 	 
	/*terminal := self.myVoyage.myTerminalActive;
	
	if self.myVoyage.isTransient then
		realVoyage := self.myVoyage.pxyGetRealObject();
	endif;		
	
	if realVoyage = null then
		realVoyage := self.myVoyage;
	endif;
	
	if terminal = null then
		return;
	endif;

 	iter := terminal.allVoyagesByDepartDTCode.createIterator();
	terminal.allVoyagesByDepartDTCode.startKeyGeq(_arriveDT, null, iter);

 	while iter.next(voyage) do
 		if voyage.myHMSVoyageData = null then
 			//Only interested in voyages with harbour details
 			continue;
 		endif;
 		tmpVessel := voyage.getMyVessel();
 		if tmpVessel = null then
 			continue;
 		endif;
 		if tmpVessel &lt;&gt; thisVessel then
 			continue;
 		endif;
 		if voyage = realVoyage then
 			continue;
 		endif;

 		if voyage = self.myVoyage then
 			continue;
 		endif; 

 			// Test for overlap
 		if not app.isConverting then
 			if voyage.arrivedDT &lt;= _departDT and voyage.departedDT &gt;= _arriveDT then
				// Overlap occurs - ie there is already a booking in the system for this ship at this time
				app.raiseCMException1(VoyageBookingExists, thisVessel.name &amp; ', arrival ' &amp; voyage.arrivedDT.shortCurrentLocaleFormat() &amp; ' departure ' &amp; voyage.departedDT.shortCurrentLocaleFormat(), null, null); 
				return;
			endif;
		endif;	
 	endwhile;

 	// Proposed visit for this ship is not already booked into the system.
 	
epilog
	delete iter;*/
end;</source>
        <access>protected</access>
        <Parameter name="_arriveDT" type="TimeStamp"/>
        <Parameter name="_departDT" type="TimeStamp"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="validateVoyageDelay" id="c059c391-f24f-44e1-b85b-3b8718af94d5">
        <source>validateVoyageDelay(_passport: CM_Passport input)protected;
//--------------------------------------------------------------
//Created: 24 July 2003 By: cnwgd1
//--------------------------------------------------------------
vars
	tmpDelay 	: HMS_VoyageDelay;
begin

	foreach tmpDelay in self.allVoyageDelays do
		tmpDelay.validateMe(_passport);
	endforeach;
	
end;</source>
        <access>protected</access>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
</Class>
