    <JadeMethod name="updateWagonId" id="56988470-6fcd-494f-bb0e-09b8bb4c1133">
        <updating/>
        <source>updateWagonId(_id : String; _wagon : CM_Wagon) updating;
// 27015 04/2011 allow edit of wagon id (if no cargo and not confirmed)
vars
	result		: Integer;
	pxyWagon	: CM_Wagon;
begin
	pxyWagon := app.createUpdateProxy(_wagon).CM_Wagon;
	pxyWagon.setId(_id);
	while true do
		app.myTrxUA.trxUpdateTrainWagon(pxyWagon, app.myPassport);
		if not app.myPassport.trxCompletedOK then
			result := app.showErrorWarningDialog(app.getErrorString(Transit_Rail), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
				result = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			return;
		endif;
		break;
	endwhile;
epilog
	delete pxyWagon;
end;</source>
        <Parameter name="_id" type="String"/>
        <Parameter name="_wagon" type="CM_Wagon"/>
    </JadeMethod>
    <JadeMethod name="updateWagonRakePos" id="bfa48ea2-2060-4ebc-a515-38a007740690">
        <source>updateWagonRakePos( _wagon : CM_Wagon io ) : Boolean;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
25 August 2010	cnwndl1	Initial creation
08/04/2011	cnwmh5	PAR #27347 - Add cmsEndLoad or endLoad to epilog so that if error occurs it will not leave it in beginLoad state
*/

vars

	rakePos : Integer;
	errorMess : String;
	railLine : CM_RailLine;
	train : CM_Train;
	wagonUpdateCtrl : CMIF_WagonUpdateController;
	pxyWagon : CM_Wagon;
	loadState : Boolean;
	
begin

	rakePos := self.cmbRakePos.itemData[ cmbRakePos.listIndex ];
	railLine := self.myMobileGenericAgent.myCurrentRailLine;
	
	if rakePos &lt; 1 or rakePos &gt; railLine.maximumWagons then
		errorMess := app.getErrorString1(Rail_line_positi_rail_area,rakePos.String);
		self.msgBox(errorMess ,app.getErrorString(Error) &amp; " [" &amp; _wagon.id &amp; "]", MsgBox_OK_Only, true);
		return false;
	endif;
	
	if _wagon = null then
		return false;
	endif;
	
	train := self.myMobileGenericAgent.myCurrentTrain; 
	
	if train = null then
		return false;
	endif;
	
	if not train.allWagonsByOrderInward.includes(_wagon) then
		if _wagon.myTrainInwards &lt;&gt; null and not _wagon.myTrainInwards.isNullTrain then
			return false;
		endif;
	endif;
	
	// ok set the rail position.
	
	app.cmsBeginLoad(loadState);
	pxyWagon :=	_wagon.pxyCreateUpdateProxy();
	app.cmsEndLoad(loadState);
	
	
	create wagonUpdateCtrl transient;
	wagonUpdateCtrl.setBasicDetails(CMIF_WagonUpdateController.Mode_Update,	//_mode : Integer;
									self.myMobileGenericAgent.myCurrentRailLine,// rake
									train,	//_train : CM_Train;
									rakePos, //_wagonPosition : Integer;
									false	// isTrainMode
									);										
	wagonUpdateCtrl.myProxyWagon := pxyWagon;
	wagonUpdateCtrl.expectedEditionWagon := _wagon.edition;
	wagonUpdateCtrl.populateFromExistingWagonAddTi( _wagon, null, 0 );
	
	app.myPassport.clearErrorsWarnings();
	app.myPassport.setWarningsIgnored(true);
	app.myTrxUA.trxUpdateWagonFromCMIF(wagonUpdateCtrl, false, app.myPassport);

	if app.myPassport.hasErrors then
		//errorMess := app.myPassport.getErrorsAsString;
		errorMess := app.myPassport.getAllErrorsWarningsAsString;	// 10 Aug 2012	NDL	Par 29885
		self.msgBox(errorMess ,app.getErrorString(Error) &amp; " [" &amp; _wagon.id &amp; "]" , MsgBox_OK_Only, true);
		return false;
	endif;
	
	return true;
		
epilog
	app.cmsEndLoad(loadState);		// 08/04/2011 cnwmh5 #27347
	delete wagonUpdateCtrl;
	delete pxyWagon;
	
end;</source>
        <Parameter name="_wagon" type="CM_Wagon" usage="io"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="wagonIsForNullTrain" id="92281aa2-e947-4d83-9a50-2ca8c56c672f">
        <source>wagonIsForNullTrain(_wagon: CM_Wagon): Boolean;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
27 August 2010	cnwndl1	Initial creation

*/

vars

	train : CM_Train;
	
begin

	train := _wagon.myTrainInwards;
	
	if train &lt;&gt; null then
		return train.isNullTrain;
	endif;
	
	return false;
	
epilog

end;</source>
        <Parameter name="_wagon" type="CM_Wagon"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</GUIClass>
