    <JadeMethod name="cargoIF_getStringForETRow" id="7003c111-52a8-40be-883f-0b289471ca72">
        <interfaceImplements>
            <JadeInterfaceMethod name="IF_CargoField::getStringForETRow"/>
        </interfaceImplements>
        <source>cargoIF_getStringForETRow(pAttrName : String) : String;

	/*
		this method stub has been automatically generated by Jade to satisfy interface implementation requirements
	*/
/*
	Created on 11 February 2008
	
	by Debby Hutchison
	
	Purpose:
*/

vars
	haz		: CM_Hazard;
	tmpStr  : String;
	iso 	: CM_ISOType;
	int 	: Integer;
//	brItem 	: CM_BookingRefItem;
//	resDtl 	: CM_ReserveDetail;
//	availGrade : CM_MTGrade;
begin
	if pAttrName = ETRow_AvailabilityGradeCode then
		return null;
//	elseif pAttrName = ETRow_BolType then // adm 160310 Par 22937 remove bolType
//		return bolTypeDescr;
	elseif pAttrName = ETRow_CargoType then
		return cargoTypeDescr;
	elseif pAttrName = ETRow_CargoTypeDescr then
		return cargoTypeDescr;
	elseif pAttrName = ETRow_CarriageTempC or  pAttrName = ETRow_TempC then
		return getTempString(false).String;
	elseif pAttrName = ETRow_CarriageTempF or pAttrName = ETRow_TempF then
		return getTempString(true).String;
	elseif pAttrName = ETRow_IsoType then
		iso := app.myRoot.allISOTypes[self.isoType];
		if iso &lt;&gt; null then
			return iso.getTableDisplay;
		else
			return null;
		endif;
	elseif pAttrName = ETRow_IsoTypeCode then
		iso := app.myRoot.allISOTypes[self.isoType];
		if iso &lt;&gt; null then
			return iso.code.String;
		else
			return null;
		endif;
	elseif pAttrName = ETRow_Commodity then
		return commodity;
	elseif pAttrName = ETRow_CarbonDioxide then
		return self.getCarbonDioxide.asNullCarbonDioxide;	
	elseif pAttrName = ETRow_Oxygen then
		return self.getOxygen.asNullOxygen;	
	
	elseif pAttrName = ETRow_CurtainsIn then				// CCMS 1654 - slw 11/09/2008
		if self.isControlledAtmosphere then
			return self.curtainsIn.cnEcGetYesNo;
		else
			return null;
		endif;
	elseif pAttrName = ETRow_Description then
		return description;
	elseif pAttrName = ETRow_Humidity then
		return getHumidity.asNullHumidity;//String;
	elseif pAttrName = ETRow_Quantity or pAttrName = ETRow_QuantityTxt then
		return quantity.String;
	elseif pAttrName = ETRow_Ventilation then
	   	return getVentilation;
	elseif pAttrName = ETRow_WeightTotal then
		return weight.asStringWeightJMT();
	elseif pAttrName = ETRow_MyHeight then
		return height.asStringMeasurementJMT();
	elseif pAttrName = ETRow_MyWeight then
		return weight.asStringWeightJMT();
	elseif pAttrName = ETRow_MyLength then
		return length.asStringMeasurementJMT();
	elseif pAttrName = ETRow_NumItems then
		return quantity.String;
	elseif pAttrName = ETRow_MyWidth then
		return width.asStringMeasurementJMT();
	elseif pAttrName = ETRow_MyQuantity then
		return productQuantity.String;
	elseif pAttrName = ETRow_MyDensity then
		return density.String;
	elseif pAttrName = ETRow_NumOnsiteTIs then
		int := numOnsiteTIs;
		return int.String;
	elseif pAttrName = ETRow_TiRecieved then
		return self.getAssignedIDs();
	elseif pAttrName = ETRow_MyVolume then
		return volume.String;	
	elseif pAttrName = ETRow_AllTIHazards then
		foreach haz in self.allTIHazards do
			if tmpStr &lt;&gt; null then
				tmpStr := tmpStr &amp; '; ';
			endif;
			tmpStr := tmpStr &amp; haz.getTableDisplay(false, true);
		endforeach;
		return tmpStr;
	elseif pAttrName = ETRow_Released then
		return self.req_Released.String;
	elseif pAttrName = ETRow_MaxToRelease then
		return self.req_MaxToRelease.String;
	elseif pAttrName = ETRow_Grade then
		return self.req_Grade;
	elseif pAttrName = ETRow_MyGeneratorType then				//cnwrd1 par 18222 24.2.09
		if self.myGeneratorType &lt;&gt; null then
			return self.myGeneratorType.description;		
		endif;	
	elseif pAttrName = ETRow_Density then						// MES1008 JMH 28/9/09
		return self.density.String;
	elseif pAttrName = ETRow_MarkNumber then					// MES1008 JMH 28/9/09
		return self.markNumber.String;
	elseif pAttrName = ETRow_IsoTypeGroup then					// MES1008 JMH 28/9/09
		return self.isoTypeGroup.String;
	elseif pAttrName = ETRow_ProductVolume then					// MES1008 JMH 28/9/09
		return self.productVolume.String;
	elseif pAttrName = ETRow_ProductWeight then					// MES1008 JMH 28/9/09
		return self.productWeight.String;
	elseif pAttrName = ETRow_VentilationUnits then				// MES1008 JMH 28/9/09
		return self.ventilationUnits.String;	
	endif;
	
	return null;
end;</source>
        <Parameter name="pAttrName" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
