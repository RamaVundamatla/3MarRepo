    <JadeMethod name="setProxyAttribute" id="e86d5495-16ca-447f-961c-7d2da3cf6be4">
        <updating/>
        <source>setProxyAttribute(_srcOOWC: CM_OOWCreation; _attribute: String; _targetJS: CM_VoyageJobSheet; _order, _subOrder : Integer; _is40 : Boolean) updating;
// ---------------------------------------------------------------------------
// Created:		05 May 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
begin
	inheritMethod(_srcOOWC, _attribute, _targetJS,_order, _subOrder, _is40);

	self.is40 := _is40;
	
	self.setPropertyValue(_attribute,_srcOOWC.getPropertyValue(_attribute));
end;</source>
        <Parameter name="_srcOOWC" type="CM_OOWCreation"/>
        <Parameter name="_attribute" type="String"/>
        <Parameter name="_targetJS" type="CM_VoyageJobSheet"/>
        <Parameter name="_order" type="Integer"/>
        <Parameter name="_subOrder" type="Integer"/>
        <Parameter name="_is40" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validateOOWCOrder" id="623a0634-872e-47a0-baf7-1b3bf8ae6556">
        <source>validateOOWCOrder(_firstOOWC : SelfType) : Boolean;
// ---------------------------------------------------------------------------
// Created:		18 September 2007 By Andrew Bishop cnwab1
//
// Purpose:		compare 2 OOWC that are in the order they will be used.
//					Both in the same bay. A bay should always be worked in this order:
//					Discharge on deck, discharge underdeck, load under deck, load on deck
//
// ---------------------------------------------------------------------------
vars
	secondOOWC : SelfType;
begin
	secondOOWC := self;
	
	// SAME BAY?
	if secondOOWC.myBay &lt;&gt; _firstOOWC.myBay then
		return true;
	endif;
	
	// DISCHARGE
	if _firstOOWC.isDischarge then
		
		if _firstOOWC.isOnDeck() then // anything that follows an OD discharge is fine.
			return true;
		else // first is discharge under deck
			if secondOOWC.isDischarge() then
				// second is discharge on deck
				if secondOOWC.isOnDeck then
					return false;
				endif;
			// second is load
			else
				return true;
			endif;
		endif;
	// LOAD
	else
		if _firstOOWC.isOnDeck() then // first is load on deck
			if secondOOWC.isDischarge then // discharge after load in the same bay is always wrong
				return false;
			else // second is a load as well
				if secondOOWC.isOnDeck then
					return true;
				else // 2nd is underdeck, cannot load on deck and then under deck
					return false;
				endif;
			endif;
			
		else// first is load under deck
			if secondOOWC.isDischarge then // discharge after load in the same bay is always wrong
				return false;
			else // 2nd is a load under deck so any load can follow
				return true; 
			endif;
		endif;
	endif;
end;</source>
        <Parameter name="_firstOOWC" type="SelfType"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
