    <JadeMethod name="initTableData" id="0d2183fd-1d40-47e3-88d0-8929edc93176">
        <updating/>
        <source>initTableData(_theEntDef: String) updating;
// ---------------------------------------------------------------------------
// Created:		July 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

begin
	inheritMethod(_theEntDef);
	
	self.tblData.selectMode := Table.SelectMode_Row;
	self.tblData.accessMode := Table.AccessMode_Row;
	self.tblData.multiSelect := CM_BaseTable.MultiSelect_Simple;
	self.tblData.selectionType := CM_BaseTable.SelectionType_Row;
	self.tblData.defaultRowHeight := 17;
	self.tblData.allSelectedObjects.clear;


end;</source>
        <Parameter name="_theEntDef" type="String"/>
