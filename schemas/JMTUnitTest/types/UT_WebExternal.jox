    <JadeMethod name="addOpsBreakBulkCargoAtLocation" id="1a6344c0-40e5-41e1-a675-fa429299c951">
        <source>addOpsBreakBulkCargoAtLocation(cargoType : CM_CargoType;lc: CM_LocationsController;voyage	: CM_Voyage;vessel	: CM_Vessel; _cargoId : String;_imex:Integer):CM_TrackedItem;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 June 2022	navsp1	Initial creation TFS#53956

*/

vars
	cargoOnship, cargoOnSite	: CM_TrackedItem;
begin
	
	deleteCargo(_cargoId, cargoType);
	cargoOnship := self.addCargoBreakBulkAtLocation(_cargoId, cargoType, 100, lc, null, _imex, voyage, vessel.myOperator);
	
	return cargoOnship;

epilog

end;</source>
        <Parameter name="cargoType" type="CM_CargoType"/>
        <Parameter name="lc" type="CM_LocationsController"/>
        <Parameter name="voyage" type="CM_Voyage"/>
        <Parameter name="vessel" type="CM_Vessel"/>
        <Parameter name="_cargoId" type="String"/>
        <Parameter name="_imex" type="Integer"/>
        <ReturnType type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="addPrenoteContainer" id="81ed42be-2076-443d-8039-b127d6594356">
        <source>addPrenoteContainer( _id : String ):CM_Container;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 August 2020	jlgndl1	Initial creation	TFS 49869

*/

vars

	ti: CM_TrackedItem;
	totalWeight: Decimal[12,2];
	commodity: String;
	carrier : CM_Carrier;
	isoType : String;
	operator : CM_Operator;
	cargoType : CM_CargoType;

begin

	self.deleteContainer( _id );
	
	// get the commodity
	commodity := "MT";
	if self.opts.includesKey("commodity") then
		commodity := self.opts.str("commodity");
	endif;	
	
	isoType := "2200";
	if self.opts.includesKey("isoType") then
		isoType := self.opts.str("isoType");
	endif;
	
	operator := getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);
	if self.opts.includesKey("operator") then
		operator := self.opts.obj("operator").CM_Operator;
	endif;
	
	cargoType := app.myRoot.allCargoTypesById[TI_CargoType_Container];
	
	beginTransaction;
	
	ti := self.getTerminal.createTI( cargoType, false );
	ti.setPxyFromDefaultTI( self.getTerminal, cargoType.id, _id, commodity, operator );
	ti.changeState(TI_STATE_NOTIFIED, app.myPassport );
	ti.setISOType( isoType );
	
	// set the mt grade
	if self.opts.includesKey("mtGrade") then
		ti.setAvailabilityGradeRT(self.opts.obj("mtGrade").CM_MTGrade.code, app.myPassport);
	endif;
	
	if self.opts.includesKey("clientRef") then
		ti.setClientRef( self.opts.str("clientRef").trimBlanks );
	endif;
	
	// set the total weight
	totalWeight := 4000.00;
	if self.opts.includesKey('totalWeight') then
		totalWeight := self.opts.dec('totalWeight');
	endif;
	ti.setPropertyValue( "totalWeight", totalWeight );
	
	if self.opts.includesKey('transMode') then
		ti.setReceiptTransportMode( self.opts.int("transMode") );
	endif;
	
	// set the carrier
	if self.opts.includesKey('carrier') then
		ti.setCarrier(self.opts.str('carrier'));
	endif;
	
	if self.opts.includesKey(UTTI_IMEX) then						
		ti.setImExStatus(self.opts.int(UTTI_IMEX));
	endif;
	
	ti.setRemarks(self.createdByUnitTest(ti.remarks), false);					// 10/09/2015 cnwmh5
	
	commitTransaction;
	
	return ti.CM_Container;

epilog

	abortTransaction;

end;</source>
        <Parameter name="_id" type="String"/>
        <ReturnType type="CM_Container"/>
    </JadeMethod>
