    <JadeMethod name="updateBtnCaption" id="6c8070ca-7b22-43a4-b71f-52d69ae8db13">
        <source>updateBtnCaption();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
20 May 2009	#cnwdz2	 ccms1801

*/

vars
	selectedObjs : ObjectArray;
begin

	create selectedObjs transient;
	self.tbl_Items.getAllSelectedObjects(selectedObjs);
	if selectedObjs.size &gt; 0 then
		self.btn_ChangeLoc.caption := "Change Selected Locations...";
		self.btn_SetDown.caption := "Set Down Selected";
	else
		self.btn_ChangeLoc.caption := "Change All Locations...";
		self.btn_SetDown.caption := "Set Down";
	endif;
epilog
	delete selectedObjs;
end;</source>
    </JadeMethod>
    <JadeMethod name="updateTILocation" id="771cfbbc-c229-4933-a8d0-49b38c4692d3">
        <updating/>
        <source>updateTILocation(_trackedItem: CM_TrackedItem) updating;

vars
	location: CM_LocationsController;
	cmifTI: CMIF_TIGenCargo;
begin
	location := self.myMobileDataAgent.getDefaultLocationForTI(_trackedItem);
	cmifTI	:=	tbl_Items.cnEcGetRowObject().CMIF_TIGenCargo;
	if cmifTI &lt;&gt; null then
		cmifTI.setMyNewLocation(location);
		loadTable(tbl_Items);
	endif;
end;
</source>
        <Parameter name="_trackedItem" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="validateCargoID" id="8fa8379b-852e-4ee6-ae33-064b3425be85">
        <source>validateCargoID(_id : String) : Boolean protected;
//01 July 2008	cnwdw1	PAR 17308
// If this is a valid cargo id return true, otherwise false
vars

begin
	if _id = null then
		return false;
	endif;
	return true;
end;</source>
        <access>protected</access>
        <Parameter name="_id" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</GUIClass>
