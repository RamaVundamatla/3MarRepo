    <JadeMethod name="windowCreated" id="ca2dbcd3-6d4b-4f17-8fff-bbed822a6698">
        <controlMethod name="CMUI_ScrollableFrame::windowCreated"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <executionLocation>client</executionLocation>
        <source>windowCreated(cntrl: CMUI_ScrollableFrame input; persistCntrl: CMUI_ScrollableFrame) updating, clientExecution;
/*
Date		    Who			Reason
23 July 2011	cnwas3	  Initial creation: CCMS 1035 CargoSideView form
*/

vars

begin
	inheritMethod(cntrl, persistCntrl);
	self.autoRedraw := true;
	
	/*if self.isInPainter then
		return;
	endif;
	self.hideHLabels();
	self.hideVLabels();
	
	self.bevelInner := Frame.Bevel_None;
	self.bevelOuter := Frame.Bevel_None;
	self.borderStyle := Frame.BorderStyle_None;
	self.boundaryWidth := 0;
	
	
	self.caption := null;
	self.autoRedraw := true;*/
epilog

end;</source>
