    <JadeMethod name="getClientRef" id="baced722-b7a7-4388-89bf-b0999548292e">
        <source>getClientRef(_searchStr : String; _isPartial : Boolean): String;
/*

Purpose:	common method for both the search and ent table data display on table		

Parameters:			

Return Value:		

Date		Who		Reason
07 October 2024	navsp1	Initial creation JIRA 20762 EUP | General Testing - Search on Client Ref on User Screens

*/

vars
	ti 				: CM_TrackedItem;
	cont 			: CM_WagonController;
	data,
	clientRefStr,
	searchStr	 	: String;
begin
	foreach cont in self.allLocationsControllers do
		foreach ti in cont.allTrackedItems do
			clientRefStr := ti.clientRef.toUpper;
			if clientRefStr &lt;&gt; null then
				searchStr := _searchStr.toUpper;
				if searchStr  &lt;&gt; null then					
					if _isPartial then
						if clientRefStr.startsWith(searchStr) then
							if data = null then
								data := clientRefStr;
							else
								data := data &amp; ", " &amp; clientRefStr;
							endif;
						endif;
					else
						if clientRefStr = searchStr then
							if data = null then
								data := clientRefStr;
							else
								data := data &amp; ", " &amp; clientRefStr;
							endif;
						endif;
					endif;
				else
					/*
					///To display the ent table column
					if data.pos(clientRefStr, 1) = 0 then
						if data = null then
							data := clientRefStr;
						else
							data := data &amp; ", " &amp; clientRefStr;
						endif;
					endif;
					*/
					data.addStringToList(clientRefStr, ", "); //04/04/2025	navkc1 JIRA Story MTN-33940
				endif;
			endif;
		endforeach;
	endforeach;
	return data;
epilog

end;</source>
        <Parameter name="_searchStr" type="String"/>
        <Parameter name="_isPartial" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getCommodity" id="0fa81265-8ae7-4897-947b-142dcc30dd0a">
        <source>getCommodity():String;
/*

Purpose:			

