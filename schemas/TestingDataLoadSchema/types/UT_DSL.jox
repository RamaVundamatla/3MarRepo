    <JadeMethod name="updateGridColumnCanTwinLift" id="2c5cb6b7-612d-4dd1-8669-212361c4d81c">
        <source>updateGridColumnCanTwinLift(_gridArea : CM_GridArea; 
							_colNum : Integer; 
							_canTLNext,_canTLPrev : Boolean );
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
29 September 2009	cnwer1	Initial creation

*/

vars
	iter 		: Iterator;
	gridColumn : CM_GridColumn;
	gridController : CM_GridController;
begin
	
	if _gridArea = null then
		return;
	endif;
	
	gridColumn:=_gridArea.allGridColumns[_colNum];
	if gridColumn = null then
		return;
	endif;
	
	iter:=gridColumn.allControllersByRow.createIterator;
	while iter.next(gridController) do
		beginTransaction;
			gridController.setCanTwinLiftWithNext(_canTLNext);
			gridController.setCanTwinLiftWithPrev(_canTLPrev);
		
	
		commitTransaction;
	endwhile;
	
	
epilog
	abortTransaction;
	delete iter;
end;</source>
        <Parameter name="_gridArea" type="CM_GridArea"/>
        <Parameter name="_colNum" type="Integer"/>
        <Parameter name="_canTLNext" type="Boolean"/>
        <Parameter name="_canTLPrev" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="updateGridLocationAvailability" id="5f7ef3d1-672a-4f42-8b6e-47e1f45674bb">
        <source>updateGridLocationAvailability(_area : CM_GridArea input;
								_locations  : CM_LCSet;
								_availability : Integer);
/*

Date		Who		Reason
13 August 2013	cnwer1	Initial creation PAR

*/

vars
	interfaceObjects	: ObjectArray;
	anInterfaceObject	: CMIF_GridTARegion;
begin
	if _area = null or _locations = null then
		return;
	endif;
	
	create interfaceObjects transient;
	create anInterfaceObject transient;
	anInterfaceObject.myGridArea:=_area;
	
	_locations.copy( anInterfaceObject.allLocationControllers);
	anInterfaceObject.availability:=_availability;
	
	if _availability = PAD_AVAILABLE then
		anInterfaceObject.updateMode:=	CMIF_GridTARegion.UpdateMode_LocationAvailable;
	elseif _availability = PAD_UNAVAILABLE then
		anInterfaceObject.updateMode:=	CMIF_GridTARegion.UpdateMode_LocationUnavailable;
	else
		anInterfaceObject.updateMode:=	CMIF_GridTARegion.UpdateMode_HeightRestriction;
	endif;
	
	interfaceObjects.add(anInterfaceObject);
	
	app.myTrxUA.trxUpdateGridControllers(interfaceObjects, _area, app.myPassport);
	
	self.assertNoTrxErrors();
epilog
	delete anInterfaceObject;
	delete interfaceObjects;
end;</source>
        <Parameter name="_area" type="CM_GridArea" usage="input"/>
        <Parameter name="_locations" type="CM_LCSet"/>
        <Parameter name="_availability" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="updateHMSTug" id="4b2e3aed-90c7-48b7-b5dd-b777989ba856">
        <source>updateHMSTug(_tug : HMS_Tug);
/*

Purpose:	Update Tug Details

Date		Who		Reason
05/03/2014	cnwma1	Initial creation

*/

vars
	pxyTug		  	 	: HMS_Tug;
	tugCode			 	: String;
	tugDesc			 	: String;
	harbour			 	: HMS_Harbour;
	arrResource,
	depResource,
	shiftResource	 	: HMS_Resource;
	obj					: Object;

	prxyResourceForTug	: HMS_ResourceForTug;
	
	pxyArray			: ObjectArray;
	
	resourceType			: HMS_Object;
begin

	//harbour := app.myRoot.allHarbours["UTHAVEN"];
	//arrResource := harbour.allResources["UTTUGSH"];
	
	resourceType := app.myRoot.allResourceTypes["UTTUGS"];
	


	beginLoad;
	pxyTug := _tug.pxyCreateUpdateProxy();
	endLoad;
	if self.opts.includesKey("TugDesc") then
		pxyTug.setPropertyValue ("description",self.opts.str("TugDesc"));
	endif;
	if self.opts.includesKey("TugCode") then
		pxyTug.setPropertyValue ("code",self.opts.str("TugCode"));
	endif;
	
	
	create pxyArray transient;
	foreach harbour in app.myRoot.allHarbours do
		
		arrResource := null;
		depResource := null;
		shiftResource := null;
		if self.opts.includesKey("HarbourToCheck") then
			if harbour.code = self.opts.str("HarbourToCheck") then
				arrResource := harbour.allResources[self.opts.obj("ArrResource").HMS_Resource.code];
				depResource := harbour.allResources[self.opts.obj("DepResource").HMS_Resource.code];
				shiftResource := harbour.allResources[self.opts.obj("ShResource").HMS_Resource.code];
			endif;		
		endif;
		
		create prxyResourceForTug transient;
		prxyResourceForTug.setProxy(pxyTug,harbour,arrResource,depResource,shiftResource);
		pxyArray.add(prxyResourceForTug);
	
	
	endforeach;
	
	/*
	//prxyResourceForTug := pxyTug.allResourcesForTug[harbour,pxyTug];
		
		if prxyResourceForTug = null then
				create prxyResourceForTug transient;
		endif;
		prxyResourceForTug.setProxy(pxyTug,harbour,arrResource,null,null);
	*/
		
	app.myTrxUA.trxUpdateTug(pxyTug,app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
	
epilog

	if pxyArray &lt;&gt; null and not pxyArray.isEmpty() then
		foreach obj in pxyArray do
			delete obj;
		endforeach;
	endif;
	delete pxyArray;

	//delete prxyResourceForTug;
	delete pxyTug;

end;</source>
        <Parameter name="_tug" type="HMS_Tug"/>
    </JadeMethod>
    <JadeMethod name="updateHMSVoyageDelay" id="4adf3247-246d-4e81-b4e8-ae816ff14b8c">
