    <JadeMethod name="doBtnToolBarMouseUP" id="aae1fdd0-e284-43e3-8f27-08840489aea9">
        <updating/>
        <source>doBtnToolBarMouseUP(_theIndex : Integer) updating;
// ---------------------------------------------------------------------------
// Created:		January 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	idx : Integer;
begin
	
	if self.myCurrentVoyage = null and _theIndex &lt;&gt; self.BTN_DRAW then
		return;
	endif;

	app.mousePointer := Window.MousePointer_HourGlass;

	if self.frmTips.visible then
		self.showHideTipsFrame();
	endif;
	
	if _theIndex &lt;&gt; VIEW_SEQUENCE then
		self.currentSeqNumber := 0;
		self.setCurrentJob(null);
	endif;
	
	if _theIndex &lt;= VIEW_TEMPERATURE or 
	   _theIndex = VIEW_WEIGHT or 
	   _theIndex = 33 or // ISO TYPE
	   _theIndex = VIEW_LOADPORT then
		self.frmStatusLine.myFrameCaption.caption := self.myCurrentDrawingController.setViewMode(_theIndex);
		self.myCurrentDrawingController.drawSelf(true);
		self.setCaptionForModes(self.displayMode);
		// displayViewModeCodes attempts to build a legend of only the colours used in drawing the grid area else it will carry on as usual
		self.doNotesForLegendStartStop(_theIndex);
	else
		self.myDrawingFrame.enabled := true;
		if _theIndex = VIEW_LEFT_TOP or 
		   _theIndex = VIEW_RIGHT_TOP or 
		   _theIndex = VIEW_LEFT_BOTTOM or 
		   _theIndex = VIEW_RIGHT_BOTTOM then
			self.doScrollToCorners(_theIndex);
		elseif _theIndex = VIEW_REFRESH then
			app.mousePointer := Window.MousePointer_HourGlass;
			self.myCurrentDrawingController.drawSelf(true);
			app.mousePointer := Window.MousePointer_Default;
		elseif _theIndex = VIEW_FLIP_H then 
			app.mousePointer := Window.MousePointer_HourGlass;
			self.myBayDrawingController.drawInReverse := (not self.myBayDrawingController.drawInReverse);
			self.drawHolds(true);
			app.mousePointer := Window.MousePointer_Default;

		elseif _theIndex = VIEW_SEQUENCE then 
			self.switchWorkingMode(self.WorkMode_CustomSeq);
		// ##### ACTUAL
		elseif _theIndex = VIEW_BAYACTUAL then 
			self.switchDisplayMode(ShpDisplayMode_Actual, true);

		// ##### DEFINITION
		elseif _theIndex = self.BTN_BAYDEFN then 
			self.switchDisplayMode(ShpDisplayMode_Defn, true);
		// ##### PROPOSED
		elseif _theIndex = VIEW_BAYPLANNED then 
			self.switchDisplayMode(ShpDisplayMode_Proposed, true);

		// ##### JOB MODE
		elseif _theIndex = VIEW_JOB then 
			self.switchWorkingMode(self.WorkMode_Job);
		// ##### PLANNING MODE
		elseif _theIndex = VIEW_PLAN then 
			self.switchWorkingMode(self.WorkMode_Plan);
		// ##### ACT/PRO MODE
		elseif _theIndex = VIEW_BAYVIEW then 
			self.switchDisplayMode(ShpDisplayMode_Actual, true); // default

		// ##### DISCHARGE
		elseif _theIndex = VIEW_COLOUR_DISCH then 
			self.switchDisplayMode(ShpDisplayMode_ColCodeDisch, true);
		// ##### LOAD
 		elseif _theIndex = VIEW_COLOUR_LOAD then 
			self.switchDisplayMode(ShpDisplayMode_ColCodeLoad, true);
		elseif _theIndex = self.BTN_CLEAR then 
			app.mousePointer := Window.MousePointer_HourGlass;
			self.doClearAllSelectedPoints();
			app.mousePointer := Window.MousePointer_Default;
		elseif _theIndex = self.BTN_DRAW then 
			if self.selectMode = self.SelectModeHold or self.selectMode = self.SelectModeMulti then
				self.showHoldSelector(self.selectMode);
			else
				self.showSelectBays(0,0);
			endif;
		elseif _theIndex = self.BTN_HOLDDRAWMODE then 
			self.myBayDrawingController.drawHoldVertical := (not self.myBayDrawingController.drawHoldVertical);
			self.drawHolds(true);
		elseif _theIndex = self.BTN_40 then 
			self.doBtnToolBarFORTY();
		elseif _theIndex = self.BTN_MT then 
			self.doBtnToolBarMTONLY();
		elseif _theIndex = self.BTN_VOLTAGE then 
			self.doBtnToolBarVOLTAGE();
		elseif _theIndex = self.BTN_HEAVY then 
			self.doBtnToolBarHEAVY();
		elseif _theIndex = self.BTN_12 then 
			self.doBtnToolBarHALFHEIGHT();
		elseif _theIndex = self.BTN_OD then 
			self.doBtnToolBarOD();
		elseif _theIndex = self.BTN_POWER then 
			self.doBtnToolBarPOWER();
		elseif _theIndex = self.BTN_REEFER then  // PORT HOLE ONLY not INTEGS
			self.doBtnToolBarREEFER();
		elseif _theIndex = self.BTN_WATER then 
			self.doBtnToolBarWATER();
		elseif _theIndex = self.BTN_UNAVAIL then 
			self.doBtnToolBarUNAVAIL();
		elseif _theIndex = self.BTN_DELETE then 
			self.doBtnToolBarDELETE();
//		elseif _theIndex = self.BTN_SAVE then 
//			self.doSaveJob(true, false);
		elseif _theIndex = self.BTN_HICUBE then 
			self.doBtnToolBarHICUBE();			

			
		elseif _theIndex = self.BTN_CRIB then 
			self.doBtnToolBarCRIB();
		elseif _theIndex = self.BTN_FRAME then //05 Feb 2018	NDL	TFS 36752
			self.doBtnToolBarFRAME();	
		elseif _theIndex = self.BTN_FLAT then 
			self.doBtnToolBarFLAT();			
		elseif _theIndex = self.BTN_OPENTOP then 
			self.doBtnToolBarOPENTOP();			
		elseif _theIndex = self.BTN_TANK then 
			self.doBtnToolBarTANK();			
			
			
		elseif _theIndex = self.BTN_HAZARD then 
			self.doBtnToolBarHAZARD();			
		elseif _theIndex = self.BTN_RH then 
			self.doBtnToolBarRH();			
		elseif _theIndex = self.BTN_SOB then 
			self.doBtnToolBarSOB();			
		elseif _theIndex = self.BTN_ERASE then 
			self.doBtnToolBarERASE();			
		elseif _theIndex = self.BTN_LOADDRAW then 
			self.doBtnToolBarLOADDRAW();			
		elseif _theIndex = self.BTN_DISCHDRAW then 
			self.doBtnToolBarDISCHDRAW();
		else
			app.raiseUnexpectedProgramError(class.name, method.name, 'Inhandled index (' &amp; _theIndex.String &amp; ')');			
		endif;
	endif;
	
epilog
	app.mousePointer := Window.MousePointer_Default;
	
end;</source>
        <Parameter name="_theIndex" type="Integer"/>
    </JadeMethod>
