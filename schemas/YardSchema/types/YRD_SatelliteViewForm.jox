    <JadeMethod name="doRebuildStats" id="f70622d9-48ab-41ae-9226-8616f4c81da3">
        <source>doRebuildStats( _yaEntityObj : CM_YAEntity; _terminalArea : CM_TerminalArea ) protected;
// --------------------------------------------------------------------------------
// Created:		04 November 2008 by cnwdad1
//
// Purpose:		Rebuilds the statistics for the specified yard Allocation entity.
//
// Parameters:	_yaEntityObj - A reference to the Yard Allocation entity who's
//				statistics we want to rebuild.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 21/04/2009	cnwrl1		PAR 19463 - Satellite View changes
// --------------------------------------------------------------------------------
vars
	movementLogObj	: CMIF_MovementLogController;
	
begin
	create movementLogObj transient;
	movementLogObj.rebuildStats( _yaEntityObj, _terminalArea );
	
	if _yaEntityObj &lt;&gt; null then
		self.tblYAM.drawTableGrid;
	elseif _terminalArea &lt;&gt; null then
		self.tblLocnStats.refreshMe;
	endif;
	
epilog
	delete movementLogObj;
	
end;</source>
        <access>protected</access>
        <Parameter name="_yaEntityObj" type="CM_YAEntity"/>
        <Parameter name="_terminalArea" type="CM_TerminalArea"/>
    </JadeMethod>
    <JadeMethod name="doRefresh" id="b1cd8865-450a-4f67-a2ec-f372f8933762">
        <updating/>
        <source>doRefresh() updating, protected;
//12 August 2008	cnwdw1	
//
vars
	arrSelected, arrExpanded : ObjectArray;
	topRow : Integer;
	obj : Object;
	control : Control;
	index : Integer;
begin
	
	self.visible:=false;
	// Keep the form's copy up to date
	// PAR 19129
	self.defYardBackColSelected := self.myTerminal.getConfig(SatelliteViewBackColour).Integer;	
	self.myDrawingFrame.changeBackColor(self.defYardBackColSelected);
	self.myCurrentDrawingController.satelliteViewGridColour := self.myTerminal.getConfig(SatelliteViewGridColour).Integer;
	self.myCurrentDrawingController.satelliteViewCellColour := self.myTerminal.getConfig(SatelliteViewCellColour).Integer;
	self.myCurrentDrawingController.satelliteViewFontColour := self.myTerminal.getConfig(SatelliteViewFontColour).Integer;
	
	self.myCurrentDrawingController.YRD_GridOViewDrawingController.setMyTerminalAreaView(self.myTerminalAreaView);
	
	
	self.IF_CMUI_Progress.startProgress;
	
	self.IF_CMUI_Progress.updateProgress("Drawing Satellite View ..",0,0);
	self.myCurrentDrawingController.drawSelfALL();
	self.allTerminalAreas.clear;
	self.myCurrentDrawingController.allTerminalAreas.copy(self.allTerminalAreas);
	
	self.doSetCaption();
	// cnwjk3 SFW1030
	create arrSelected transient;
	create arrExpanded transient;
	
	// Record the top row currently being displayed
	topRow := self.tblYAM.topRow;

	// Make a copy of selected items in YAM table
	self.tblYAM.allSelectedObjects.copy(arrSelected);
	
	// Make a copy of expanded items in YAM table
	self.tblYAM.getExpandedObjectsYA(arrExpanded);

	self.initializeTables();
	self.IF_CMUI_Progress.endProgress;
	
	// cnwjk3 SFW1030
	// Re-select all that were already selected
	foreach obj in arrSelected do
		self.tblYAM.selectObject(obj, false);
	endforeach;
	
	// Re-expand rows that were previously expanded
	foreach obj in arrExpanded do
		self.tblYAM.expandYALocations(obj.CM_YardAllocation, true );
	endforeach;
	
	// Restore the top row
	self.tblYAM.topRow := topRow;

	// cnwjk3 SFW1030
	self.doYAMTableSelection();
	
	if self.allColumnFilters &lt;&gt; null and not self.allColumnFilters.isEmpty then
		self.allColumnFilters.replaceAllFiltersForTable( self.tblFailAutoPlan, null );
		self.allColumnFilters.replaceAllFiltersForTable( self.tblFailRequest, null );	//11 Jan 2012	NDL	Par 28953
	endif;
	
epilog
	delete arrSelected;
	delete arrExpanded;	
	self.visible:=true;
end;
	
</source>
        <access>protected</access>
    </JadeMethod>
