    <JadeMethod name="loadDataForFirstTime" id="66a40941-15c2-4ba1-8168-4f9bebbea071">
        <updating/>
        <source>loadDataForFirstTime() updating, protected;
// ---------------------------------------------------------------------------
// Created:		March 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
// 03/02/2010	cnwmh5		PAR 22211 - Add removed code back to allow columns to be sorted
// 22 July 2019	cnwma1		ChangeRequest 45577: ASPA - JMT Interface to AR Oracle
// 13 December 2022   navmv20  TFS CR 55301 Task 55554: UI - Invoice List changes for Selector
// 24 Feb 2023	navmv20 TFS 56403 Task 56404: UI - Invoice List add Category
// 29 Mar 2023	navmv20 Bug 57023: EUP - inconsistent search behaviour with external number
// 11 Sep 2023 	navhl20 ChangeRequest 59376: CPL - Invoice Generation Clocking (avg 25 secs)

vars
	regKeys : IntegerArray;
	allOtherVoyCombo	: ObjectArray; //17/04/2024	navkc1 Bug 63717
begin

	inheritMethod();
	
	//17/04/2024	navkc1 Bug 63717
	create allOtherVoyCombo transient;
	allOtherVoyCombo.add(self.cmbCargoVoyage_);
	
	// 35872 
	if self.myCurrentInvoice &lt;&gt; null then
		self.myCurrentBank := self.myCurrentInvoice.bank;
	endif;
	if self.myCurrentBank = null then
		self.myCurrentBank := self.myTerminal.getDefaultCompanyBank();
	endif;
	self.setCaption(app.getErrorString(INV_Invoice_List) &amp; " " &amp; self.myCurrentBank.code); // 	TFS 2682
	self.useTableSorting := true;					// 03/02/2010 cnwmh5 #22211
	self.setNavigatorHeading(self.caption);
	if self.allInvoices.isEmpty then 	//13/12/2022 navmv20  CR 55301 Task 55554
		// ### TFS CR 62992 TASK 62994 21MAR2024 NAVAB1 - EUP have their own columns that include static (not derived) values for amounts and tax details
		if app.isSpecial then
			if app.msgBox("Do you want to run with Euroports Columns?", "Question",MsgBox_Yes_No) = MsgBox_Return_Yes then
				self.initTableData(ETDef_InvListDataTableEUP);
			else
				self.initTableData(ETDef_InvListDataTable);
			endif;
			
		else
			if app.myRoot.isClientEuroPorts() then
				self.initTableData(ETDef_InvListDataTableEUP);
			else
				self.initTableData(ETDef_InvListDataTable);
			endif;
		endif;
	endif; 	//13/12/2022 navmv20  CR 55301 Task 55554
	self.initInvPropTable(ETDef_InvListInvProperties);
	self.initRateTable();
	
	self.cmbCargoID_.style:=ComboBox.Style_DropDownComboList;
	self.btnQueryDebtor.myToolbarButton.drawButtonDown();
	self.doCmbInvoiceStatusBuild();

	self.doCmbCargoSiteBuild();
	self.doCmbStatusInvPropBuild();	//Par 17895. September 2008
	
	//self.doCmbVoyageBuild(self.cmbVoyage, self.chkArchive.value);//added by cnwyl1 for par 13086	//11.9.2023 navhl20 #59376
	self.doCmbVoyageBuild(self.cmbVoyage, self.btnIncludeArchive.value, allOtherVoyCombo);							//11.9.2023 navhl20 #59376
	self.doCmbInvoiceTypeBuild(self.cmbInvTypeInv, false);
	self.doCmbInvoiceTypeBuild(self.cmbInvoiceType, true);
	self.doCmbInvCategoryBuild(self.cmbInvCategory); //24/02/2023	navmv20 TFS 56403 Task 56404
	self.doCmbSearchFor(self.cmbSearchFor); //29/03/2023 navmv20 Bug 57023
	self.doCmbTermsTradeBuild();
	self.doCmbConsigneeBuild();		// 30931
	self.doCmbDebtorBuild(self.cmbDebtor);
	self.doCmbDebtorBuild(self.cmbDebtorInvProp); 
	//self.cmbDebtorInvProp.removeItem(1); // 01/02/2023	navkc1	TFS CR 55305 TASK 55537
	self.doCmbBankBuild(self.cmbBank);
	self.doCmbDebtorAddressBuild(null); //22.07.2019 cnwma1 TFS #45577
	self.myAssistant.comboBoxInvoiceStatusReason(self.cmbReasonCode); //epr par  36958 29/9/15
	if self.myCurrentInvoice = null then
		self.btnQueryDebtor.value := true;
	else
		self.btnQueryInvoice.value := true;		// to find this invoice in the query
	endif;
	self.setQuery();
	
	self.btnPrint.bubbleHelp := app.getErrorString(Print_InvTIListBubble);  // ### TFS 50421 18OCT2021 NAVAB1    "Print Invoice Detail Showing Tracked Items";
	self.btnPrint.caption := app.getErrorString(Print_InvTIListCaption);  // ### TFS 50421 18OCT2021 NAVAB1
	
	self.mnuContextTable.visible := true;
	self.mnuContextTable.caption := app.getErrorString(INV_Invoice_List);
	self.setContextMenus();

	self.myAssistant.comboBoxCargoTypes(self.cmbCargoType_, app.myPassport.getDefaultCargoType());
	
	create regKeys transient;
	regKeys.add(CMUI_Key_Esc);
	self.addRegisteredKeys(regKeys);
	
	
	if self.myCurrentWorkOrder &lt;&gt; null then // TFS 39349
		self.frmQuery.visible := false;
		self.clearTableFilter();
		if self.allInvoices.isEmpty then //13/12/2022 navmv20  CR 55301 Task 55554
			self.doQuery();
		endif; //13/12/2022 navmv20  CR 55301 Task 55554
	elseif self.myCurrentDebtor &lt;&gt; null then	
		self.frmQuery.visible := false;
		if self.cmbDebtor.findObject(self.myCurrentDebtor) &lt;&gt; -1 then  //cnwrd1 par 23824
			self.cmbDebtor.listObject := self.myCurrentDebtor;
		endif;
		self.clearTableFilter();	// 05/09/2014 cnwar2 #34862
		if self.allInvoices.isEmpty then //13/12/2022 navmv20  CR 55301 Task 55554
			self.doQuery();
		endif; 	//13/12/2022 navmv20  CR 55301 Task 55554
	elseif self.myCurrentInvoice &lt;&gt; null then
		self.cmbDebtor.listIndex := -1;
		self.myCurrentDebtor := null;
		self.frmQuery.visible := false;
		self.textSearch.text := self.myCurrentInvoice.sequenceNum.String;
		self.cmbSearchFor.listIndex := 1; //29/03/2023 navmv20 Bug 57023
		self.textSearch.dataType := TextBox.DataType_Numeric; //29/03/2023 navmv20 Bug 57023
		self.textSearch.maxLength := 9;	//29/03/2023 navmv20 Bug 57023
		//self.optSearchInvoice.value := true; //29/03/2023 navmv20 Bug 57023
		if self.allInvoices.isEmpty then //13/12/2022 navmv20  CR 55301 Task 55554
			self.doQuery();
        endif; //13/12/2022 navmv20  CR 55301 Task 55554
	endif;
epilog
	delete regKeys;
	delete allOtherVoyCombo;
end;</source>
        <access>protected</access>
    </JadeMethod>
