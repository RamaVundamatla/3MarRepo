    <JadeMethod name="canDropInvoiceLine" id="33dc9db6-da1b-4c57-bf26-aac4e10b0117">
        <source>canDropInvoiceLine(win : Window input; table : Window input) : Boolean;
// ---------------------------------------------------------------------------
// Created:		April 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	form : INV_ListLines;
	anInvoiceLine : CM_InvoiceLine;
	anInvoice : CM_Invoice;

begin

	if table = self.tblData then
		if win.isKindOf(Form) and win.Form.isKindOf(INV_ListLines) then
			form := win.INV_ListLines;
			anInvoiceLine := form.myCurrentInvoiceLine;
			if table.Table.dragRow &gt; 1 and table.Table.dragRow &lt;= table.Table.rows then
				table.Table.row := table.Table.dragRow;
				table.Table.column := 1;
				anInvoice := self.myCurrentBank.allInvoices[self.myTerminal, self.myCurrentBank,table.Table.text.Integer];
				if anInvoice &lt;&gt; null and anInvoice &lt;&gt; anInvoiceLine.invoice 
				and not anInvoice.isPosted 
			//	and anInvoiceLine.invoice.status &lt;&gt; CM_Invoice.INVOICE_POSTED then
				and not anInvoiceLine.invoice.isPostedOrReversal then	//04 Sep 2017	NDL	TFS 6759
					return true;
				else
					return false;
				endif;
			else
				return false;
			endif;
		else
			return false;
		endif;
	else
		return false;
	endif;
end;</source>
        <Parameter name="win" type="Window" usage="input"/>
        <Parameter name="table" type="Window" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
