    <JadeMethod name="populateFields" id="4ffb2742-e653-4dd3-82d3-56c51d1b40e9">
        <source>populateFields(	_opHrs : CM_WorkPointOperatingHours; _enabled : Boolean ) protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
02 April 2012	cnwndl1	Initial creation
15 9 16 TFS 2679:Multi-timezone issues cnwns1 
25 September 2018	cnwma1	ChangeRequest 41080: PEL1 - Assigning Operators ID to Cranes/Work-Points
*/

vars

	now 			   : TimeStamp;
	labourStartLocal   : TimeStamp;
	exchangeStartLocal : TimeStamp;
	exchangeEndLocal   : TimeStamp;
	labourEndLocal 	   : TimeStamp;
begin
	
	now := self.systemToLocalTime(app.actualTimeServer);	//TFS 2679
	

	self.cmbCrane.enabled := _enabled;
//	self.cmbCraneOpr.enabled := _enabled;   //25.09.2018 cnwma1 TFS #41080
	self.txtLabourStDt.enabled := _enabled;
	self.txtLabourStTm.enabled := _enabled;
	self.txtExchangeStDt.enabled := _enabled;
	self.txtExchangeStTm.enabled := _enabled;
	self.txtExchangeEndDt.enabled := _enabled;
	self.txtExchangeEndTm.enabled := _enabled;
	self.txtLabourEndDt.enabled := _enabled;
	self.txtLabourEndTm.enabled := _enabled;
	self.txtRemarks.enabled := _enabled;

	if _opHrs &lt;&gt; null then
	
		labourStartLocal 	:= self.systemToLocalTime(_opHrs.labourStart);	//TFS 2679
		exchangeStartLocal 	:=self.systemToLocalTime(_opHrs.exchangeStart);	//TFS 2679
		exchangeEndLocal  	:=self.systemToLocalTime(_opHrs.exchangeEnd);	//TFS 2679
		labourEndLocal 		:=self.systemToLocalTime(_opHrs.labourEnd);		//TFS 2679
	
		if _opHrs.myCrane &lt;&gt; null then
			self.cmbCrane.listIndex := self.cmbCrane.findObject( _opHrs.myCrane );
		elseif _opHrs.myWorkPoint &lt;&gt; null then
			self.cmbCrane.listIndex := self.cmbCrane.findObject( _opHrs.myWorkPoint );
		endif;
		
		//25.09.2018 cnwma1 TFS #41080
		if _opHrs.myUser &lt;&gt; null then
			self.cmbCraneOpr.listIndex := self.cmbCraneOpr.findObject( _opHrs.myUser );
		else
			self.cmbCraneOpr.listIndex := -1;
		endif;
		
		self.txtLabourStDt.setDate(labourStartLocal.Date);		//TFS 2679
		self.txtLabourStTm.setTime(labourStartLocal.Time);		//TFS 2679
		self.txtExchangeStDt.setDate(exchangeStartLocal.Date);	//TFS 2679
		self.txtExchangeStTm.setTime(exchangeStartLocal.Time);	//TFS 2679
		self.txtExchangeEndDt.setDate(exchangeEndLocal.Date);	//TFS 2679
		self.txtExchangeEndTm.setTime(exchangeEndLocal.Time);	//TFS 2679
		self.txtLabourEndDt.setDate(labourEndLocal.Date);		//TFS 2679
		self.txtLabourEndTm.setTime(labourEndLocal.Time);		//TFS 2679
		self.txtRemarks.text := _opHrs.remarks;
		
	else
	
		self.cmbCrane.listIndex := -1;
		self.cmbCraneOpr.listIndex := -1;           //25.09.2018 cnwma1 TFS #41080
		if self.mode = Mode_Add then
			self.txtLabourStDt.setDate(now.Date);	//28 Aug 2012	NDL	Par 30279
			self.txtLabourStTm.setTime(now.Time);	//28 Aug 2012	NDL	Par 30279
		else
			self.txtLabourStDt.setDate(null);
			self.txtLabourStTm.setTime(null);
		endif;
		self.txtExchangeStDt.setDate(null);
		self.txtExchangeStTm.setTime(null);
		self.txtExchangeEndDt.setDate(null);
		self.txtExchangeEndTm.setTime(null);
		self.txtLabourEndDt.setDate(null);
		self.txtLabourEndTm.setTime(null);
		self.txtRemarks.text := null;
		
	endif;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_opHrs" type="CM_WorkPointOperatingHours"/>
        <Parameter name="_enabled" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setControlsForAddEdit" id="8307fa6b-c038-4c35-b568-689ae3c5d899">
        <updating/>
        <source>setControlsForAddEdit() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
30 March 2012	cnwndl1	Initial creation	Par 29369

*/

vars

	proxy : CM_WorkPointOperatingHours;

begin

	proxy := self.myProxyObject.CM_WorkPointOperatingHours;
	self.frmDetailsTop.enabled := true;

	if self.mode = Mode_Add then
		self.populateFields( null, true );
		
	elseif self.mode = Mode_Update then
		self.populateFields( proxy, true );
		
	endif;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setControlsForView" id="03e4bb5d-9773-43d0-acbc-312c421a6b0f">
        <updating/>
        <source>setControlsForView() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
30 March 2012	cnwndl1	Initial creation

*/

vars

	opHrs : CM_WorkPointOperatingHours;

begin

	self.frmDetailsTop.enabled := false;
	
	if self.myCurrentObject &lt;&gt; null then
		opHrs := self.myCurrentObject.CM_WorkPointOperatingHours;
	else
		opHrs := self.myProxyObject.CM_WorkPointOperatingHours;
	endif;
	
	self.populateFields( opHrs, true );
	
	// TFS 2198 CNWAB1
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		self.btnNewTV.enabled:= false;
		self.btnEditTV.enabled:= false;
		self.btnDeleteTV.enabled:= false;
	endif;


epilog

end;</source>
    </JadeMethod>
