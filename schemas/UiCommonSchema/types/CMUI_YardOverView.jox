    <JadeMethod name="doZOrder" id="58e21095-1f79-4380-928e-d7113ab18185">
        <source>doZOrder();
// ---------------------------------------------------------------------------
// Created:		May 2003 By Andrew Bishop cnwab1
//
// Purpose:		
// ---------------------------------------------------------------------------
vars
	theBSDF : CMUI_ScrollableDrawingFrame;
begin


//	self.mySDF.zOrder(1);
	theBSDF := self.mySDFBackground;
	theBSDF.zOrder(1);

	self.mySDF.myHScroll.zOrder(1);
	self.mySDF.myVScroll.zOrder(1);
	self.mySDF.zOrder(1);
	self.mySDF.enabled := true;
	self.mySDF.myDrawingFrame.enabled := true;

	theBSDF.myHLabels.visible := false;
	theBSDF.myVLabels.visible := false;
	theBSDF.myHScroll.visible := false;
	theBSDF.myVScroll.visible := false;

	theBSDF.enabled := true;
	theBSDF.myDrawingFrame.enabled := false;
	
	self.lblToolTip.zOrder(1);


end;</source>
