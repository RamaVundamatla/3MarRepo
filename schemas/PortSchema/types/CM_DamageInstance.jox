    <JadeMethod name="setForCreate" id="0d15a1b2-db90-4566-9bff-d05b31c55069">
        <updating/>
        <source>setForCreate(_pxyDamageInstance : CM_DamageInstance; _realTI : CM_TrackedItem; _realTIMaster : CM_TIMaster; _new : Boolean; _repaired : Boolean io) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 July 2022	navak20	Initial creation

*/

vars

begin
	self.setForUpdate(_pxyDamageInstance, _realTI,  _realTIMaster, _new, _repaired);
epilog

end;</source>
        <Parameter name="_pxyDamageInstance" type="CM_DamageInstance"/>
        <Parameter name="_realTI" type="CM_TrackedItem"/>
        <Parameter name="_realTIMaster" type="CM_TIMaster"/>
        <Parameter name="_new" type="Boolean"/>
        <Parameter name="_repaired" type="Boolean" usage="io"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="0ef8d478-27b8-4eb4-8dab-37c0761e5cec">
        <updating/>
        <source>setForUpdate(_pxyDamageInstance : CM_DamageInstance; _realTI : CM_TrackedItem; _realTIMaster : CM_TIMaster; _new : Boolean; _repaired : Boolean io) updating;
/*
----------   ----------  --------------------------------------------------
Created:	20 September 2006 By cnwth2

Purpose:	

/****Changes

Date		Name	TFS#		Description
============================================================================
13/08/2008	cnwrd1 	ccms 1034 
03/08/2018	jlgrs1	TFS 38804 	SNO Changes to repaired transactions
27/11/2018	jlgka1	TFS 41225	SNO - Repaired Transactions - Revisit.
29/04/2019	jlgdi1	TFS 44530	Added setting the value of timeStamp attribute
10/05/2019	jlgka1	TFS 44287	JMT - Damage Refactoring.
04/05/2022	jlier1	TFS 53313  - refactoring
24/06/2022  navhl20 TFS 53862 EUP - WMS - Damage Recording Extra Details
27/06/2022	navak20 ChangeRequest 53862: EUP - WMS - Damage Recording Extra Details
27/09/2023	navcs2	ChangeRequest 60695: EUP | FR 54536 - Damage and Repair - Transaction Changes
02/10/2023  navma1	Bug 60405: MTN - Damage Date/Time transaction is not saving correctly.
17/07/2025 navbk1   Bug 34529: MTN - Cannot add quick damage correctly when damage details are mandatory configs are set
============================================================================*/
vars
	damagedTrans : CM_TITransaction;
	repairTrans  : CM_TITransaction;
	txnParams 	 : CMIF_TITransactionController;
	locString 	 : String;
	damLocation  : CM_DamageLocation;
	trxDateTime  : TimeStamp;
	newDamageTrx : Boolean;
	repairDetail : CM_RepairDetail;
	pxyTI 		 : CM_TrackedItem;
	isQuickDamage: Boolean;
begin
	self.raiseExceptionIfTransient(method);

	trxDateTime := app.actualTimeServer();
	self.damageLocation := _pxyDamageInstance.damageLocation;
	//self.severity := _pxyDamageInstance.severity;							//24 June 2022 navhl20 TFS 53862
	self.myDamageSeverity := _pxyDamageInstance.myDamageSeverity;			//24 June 2022 navhl20 TFS 53862
	self.description := _pxyDamageInstance.description;
	self.quantity := _pxyDamageInstance.quantity;
	self.isNewDamage := _pxyDamageInstance.isNewDamage;
	self.remarks := _pxyDamageInstance.remarks;
	self.setTimeStamp(_pxyDamageInstance.timeStamp);	// TFS 44530
	self.myTrackedItem := _realTI;
	self.myTIMaster := _realTIMaster; // cnwrd1 ccms 1034 13.8.2008
	
	self.myDamagePlace := _pxyDamageInstance.myDamagePlace;				// Jun 28, 2022 navak20 TFS 53862
	self.myDamageParty := _pxyDamageInstance.myDamageParty;				// Jun 28, 2022 navak20 TFS 53862
	self.myDamageReason := _pxyDamageInstance.myDamageReason;			// Jun 28, 2022 navak20 TFS 53862
	self.damageSize := _pxyDamageInstance.damageSize;					// Jun 28, 2022 navak20 TFS 53862
	self.damageDateTime := _pxyDamageInstance.damageDateTime;			// Jun 28, 2022 navak20 TFS 53862
	self.status := _pxyDamageInstance.status;							// Jun 28, 2022 navak20 TFS 53862
	self.repairedDateTime := _pxyDamageInstance.repairedDateTime;		// Jun 28, 2022 navak20 TFS 53862
	self.myRepairReason := _pxyDamageInstance.myRepairReason;			// Jun 28, 2022 navak20 TFS 53862
	self.repairRemarks := _pxyDamageInstance.repairRemarks;				// Jun 28, 2022 navak20 TFS 53862
	
	if self.myDamageDefinition = null and 								//17.07.25 navbk1 #34529
		self.myDamagePlace = null and 									//17.07.25 navbk1 #34529
		self.myDamageSeverity = null then								//17.07.25 navbk1 #34529
		isQuickDamage := true;											//17.07.25 navbk1 #34529
	endif;																//17.07.25 navbk1 #34529
	
	if self.myTrackedItem &lt;&gt; null then	
		self.mySubject := self.myTrackedItem;
	else
		self.mySubject := self.myTIMaster;
	endif;
	
	// ### TFS BUG 58866 28 JUN2023 NAVAB1
	if self.repairedDateTime.isValid() then
		trxDateTime := self.repairedDateTime;
	endif;
	
	//jlgka1 TFS 41225 --&gt;
	if _pxyDamageInstance.repaired and self.myRepairDetail = null then		
		self.createRepairDetails(_pxyDamageInstance, trxDateTime);
	endif;
	
	pxyTI:=_pxyDamageInstance.myTrackedItem;
	if _realTI &lt;&gt; null then // jlgka1 TFS 44287
		if pxyTI.isAllDamagesRepaired() and	not self.myTrackedItem.isRepairTransCreated() then		
			trxDateTime := pxyTI.getRepairedTSFromDamage(); // ### TFS BUG 58866 28JUN2023 NAVAB1 - this must be on the proxy TI as the proxy damage is on there and that has the correct statuses
			self.createRepairTransaction(_repaired, trxDateTime);	    
		endif;
		
		if not pxyTI.isAllDamagesRepaired() and	self.myTrackedItem.isRepairTransCreated() then
			self.setRepairTransactionDeleted("Not all damage instances has been repaired");
		endif;
	endif;// jlgka1 TFS 44287 

	if not _pxyDamageInstance.repaired and self.myRepairDetail &lt;&gt; null then
		self.setRepairDetailDeleted();
	endif;
	//jlgka1 TFS 41225 &lt;--\
	self.repaired := _pxyDamageInstance.repaired;	
	self.myDamageDefinition := _pxyDamageInstance.myDamageDefinition;
	self.myDamagePosition := _pxyDamageInstance.myDamagePosition; // CCMS SFW1066 PAR20321 - Recording Damage Details Changes. cnwsh3 Now used instead of the self.damageLocation
	
	//epr CCMS BULK 1366 7/3/14 refactored from CM_TrackedItem setDamageInstances
	newDamageTrx := false;
	if self.myTrackedItem &lt;&gt; null and
		//not self.myTrackedItem.damaged and	// 20.10.2022 navak20 TFS 53862
		self.myTrackedItem.amIDamaged() and		// 20.10.2022 navak20 TFS 53862
	   (not _repaired or _new) then
		damagedTrans := self.myTrackedItem.getLastTransOfType(TRANS_TYPE_DAMAGED);
		repairTrans := self.myTrackedItem.getLastTransOfType(TRANS_TYPE_REPAIR);
		if damagedTrans = null then
			newDamageTrx := true;
		elseif damagedTrans &lt;&gt; null and self.myRepairDetail &lt;&gt; null then  // jlgka1 TFS 41225
			if self.myRepairDetail.dateTime &lt;= damagedTrans.dateTime then // jlgka1 TFS 41225
				newDamageTrx := true;
			endif;
		endif;
		if newDamageTrx then
			global.createTxnControllerForType(TRANS_TYPE_DAMAGED, txnParams);
			txnParams.userId 	 := app.myPassport.userCode;
			//txnParams.dateTime := trxDateTime;			//02.10.2023 navma1 #60405
			txnParams.dateTime	 := self.damageDateTime;	//02.10.2023 navma1 #60405
			txnParams.noCharge 	 := false;				 	//TFS 3844 changed to false
			self.myTrackedItem.createTransaction(txnParams, app.myPassport);
			//self.myTrackedItem.setDamagedDT();			//27.07.2022 navsrk20 TFS 53862
			self.myTrackedItem.setDamagedDT(false);			//27.07.2022 navsrk20 TFS 53862
			// jlgka1 TFS 41225 --&gt;
			if repairTrans &lt;&gt; null then	
				if repairTrans.dateTime &lt; trxDateTime then
					self.setRepairTransactionDeleted("Re-Create Repair Transaction to match up repairDT with the last date the Cargo has been repaired.");
					self.createRepairTransaction(_repaired, trxDateTime);
				endif;
			endif;
			 // jlgka1 TFS 41225 &lt;--
			delete txnParams;
		endif;
	endif;
	
	//01 Mar 2016	NDL	TFS 1593
	if (not isQuickDamage) and self.myTrackedItem &lt;&gt; null and								//17.07.25 navbk1 #34529
	   (not _repaired or _new) then
		//see if there is  an existing damage trx matching this one.
		damLocation := self.myDamageLocationTrx;
		if damLocation = null then
			// No matching trx, create a new one.
			global.createTxnControllerForType(TRANS_TYPE_DAMAGE_LOC, txnParams);
			txnParams.userId 	 := app.myPassport.userCode;
			//txnParams.dateTime := trxDateTime;			//02.10.2023 navma1 #60405
			txnParams.dateTime	 := self.damageDateTime;	//02.10.2023 navma1 #60405
			txnParams.noCharge   := false; 					//TFS 3844 changed to false
			
			damLocation := self.myTrackedItem.createTransaction(txnParams, app.myPassport).CM_DamageLocation;
			
			if damLocation &lt;&gt; null then
				// The create was successfull, now add the detail
				if _pxyDamageInstance.locationString &lt;&gt; null then
					// they have supplied a specific location
					locString := _pxyDamageInstance.locationString;
				else
					//just use the current location
					if self.myTrackedItem.myPrimaryActualLocation &lt;&gt; null then
						locString := self.myTrackedItem.myPrimaryActualLocation.getFullId;
					else
						locString := app.getErrorString(Unknown);
					endif;
				endif;
				if locString &lt;&gt; null then
					damLocation.setFromDamageInstance( _pxyDamageInstance, locString );
				endif;
				
				self.setDamageLocationTrx(damLocation);
			endif;
			delete txnParams;
		// 27/09/2023 navcs2 ChangeRequest 60695 start
		else
			if _pxyDamageInstance.locationString &lt;&gt; null then
				locString := _pxyDamageInstance.locationString;
			else
				if self.myTrackedItem.myPrimaryActualLocation &lt;&gt; null then
					locString := self.myTrackedItem.myPrimaryActualLocation.getFullId;
				else
					locString := app.getErrorString(Unknown);
				endif;
			endif;
			if locString &lt;&gt; null then
				damLocation.setFromDamageInstance( _pxyDamageInstance, locString );
			endif;
		endif;
		// 27/09/2023 navcs2 ChangeRequest 60695 end
	endif;
	
	if self.repaired then											//27/09/2023 navcs2 ChangeRequest 60695
		self.updateDamageLocationToDeleted(self.myTrackedItem);		//27/09/2023 navcs2 ChangeRequest 60695
	endif;															//27/09/2023 navcs2 ChangeRequest 60695
	
	self.locationString := null;	//We don't want to persist the location on the damage, just on the transaction
	
epilog
	delete txnParams;
end;</source>
        <Parameter name="_pxyDamageInstance" type="CM_DamageInstance"/>
        <Parameter name="_realTI" type="CM_TrackedItem"/>
        <Parameter name="_realTIMaster" type="CM_TIMaster"/>
        <Parameter name="_new" type="Boolean"/>
        <Parameter name="_repaired" type="Boolean" usage="io"/>
    </JadeMethod>
    <JadeMethod name="setForUpdateSubject" id="6a0679f1-9831-4cc8-9d3b-47d00a457baa">
        <updating/>
        <source>setForUpdateSubject(_pxyDamageInstance : CM_DamageInstance; _realObject : CM_Object) updating;
/*
----------   ----------  --------------------------------------------------
Created:	20 September 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
// cnwrd1 ccms 1034 13.8.2008
//24 June 2022 navhl20 TFS 53862 EUP - WMS - Damage Recording Extra Details
*/
vars

begin
	//self.raiseExceptionIfTransient(method); //epr par 31845 29/10/13 

	self.damageLocation := _pxyDamageInstance.damageLocation;
	//self.severity		:= _pxyDamageInstance.severity;						//24 June 2022 navhl20 TFS 53862
	self.myDamageSeverity		:= _pxyDamageInstance.myDamageSeverity;		//24 June 2022 navhl20 TFS 53862
	self.description 	:= _pxyDamageInstance.description;
	self.quantity		:= _pxyDamageInstance.quantity;
	self.isNewDamage	:= _pxyDamageInstance.isNewDamage;
	self.remarks		:= _pxyDamageInstance.remarks;
	self.repaired		:= _pxyDamageInstance.repaired;
	
	self.mySubject	:= _realObject;
	self.myDamageDefinition	:= _pxyDamageInstance.myDamageDefinition;
	self.myDamagePosition := _pxyDamageInstance.myDamagePosition; // CCMS SFW1066 PAR20321 - Recording Damage Details Changes. cnwsh3 Now used instead of the self.damageLocation
	
	self.myDamagePlace := _pxyDamageInstance.myDamagePlace;				 // ### TFS BUG 58868 27JUN2023 NAVAB1
	self.myDamageParty := _pxyDamageInstance.myDamageParty;				// ### TFS BUG 58868 27JUN2023 NAVAB1
	self.myDamageReason := _pxyDamageInstance.myDamageReason;			// ### TFS BUG 58868 27JUN2023 NAVAB1
	self.damageSize := _pxyDamageInstance.damageSize;					// ### TFS BUG 58868 27JUN2023 NAVAB1
	self.damageDateTime := _pxyDamageInstance.damageDateTime;			// ### TFS BUG 58868 27JUN2023 NAVAB1
	self.status := _pxyDamageInstance.status;							// ### TFS BUG 58868 27JUN2023 NAVAB1
	self.repairedDateTime := _pxyDamageInstance.repairedDateTime;		// ### TFS BUG 58868 27JUN2023 NAVAB1
	self.myRepairReason := _pxyDamageInstance.myRepairReason;			// ### TFS BUG 58868 27JUN2023 NAVAB1
	self.repairRemarks := _pxyDamageInstance.repairRemarks;				// ### TFS BUG 58868 27JUN2023 NAVAB1

end;


</source>
        <Parameter name="_pxyDamageInstance" type="CM_DamageInstance"/>
