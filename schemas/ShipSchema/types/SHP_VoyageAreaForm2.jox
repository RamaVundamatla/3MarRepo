// Purpose:     
// ---------------------------------------------------------------------------
vars

begin
	if (not self.toolbarClickPreProcessing(VIEW_SEQUENCE)) then
		return;
	endif;

	app.mousePointer := MousePointer_HourGlass;

	if self.workingMode = self.WorkMode_CustomSeq then
		// already in plan mode so set to none
		self.switchWorkingMode(self.WorkMode_None);
