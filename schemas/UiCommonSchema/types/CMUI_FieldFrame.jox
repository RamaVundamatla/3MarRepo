        <updating/>
        <source>setIsEnabled(_isEnabled:Boolean) updating, abstract;
// --------------------------------------------------------------------------------
// Created:		27 February 2006 by cnwdad1
//
// Purpose:		Sets the receiver's field control(s) to an enabled state, whilst
//				leaving the label control enabled (and hence more visible).
//
// Parameters:	_isEnabled - True if the field is enabled, otherwise false.
//
// Returns:		Nothing
// --------------------------------------------------------------------------------</source>
