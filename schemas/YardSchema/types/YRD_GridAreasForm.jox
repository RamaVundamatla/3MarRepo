    <JadeMethod name="doMnuGridTBAClick" id="fd368784-f19a-41bb-91af-7ba61d1d3110">
        <updating/>
        <source>doMnuGridTBAClick(menuItem: MenuItem input) updating;
// ---------------------------------------------------------------------------
// Created:		January 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	voyage : CM_Voyage;
	source, target : CM_LocationsController;
begin
	
	if CM_LocationsController.hasInstance(menuItem.userObject) then
		source := menuItem.userObject.CM_LocationsController;
	endif;
	
	if app.myMoveController &lt;&gt; null then
		target := app.myMoveController.myToPrimaryLocation;
		if target &lt;&gt; null then
			if CM_VoyageController.hasInstance(target) then
				voyage := target.CM_VoyageController.myVoyage;
			endif;
		endif;
	else
		//voyage := app.myCurrentVoyage;
		//cnwjo3 par 23105
		voyage := app.getMyCurrentVoyage();
	endif;
	if voyage = null then
		app.msgBox("Cannot show TBA screen without current voyage being set. Run TBA screen from navigator else select voyage in a cellular voyage screen.","TBA Problem",
					MsgBox_Exclamation_Mark_Icon);
		return;
	endif;
	self.myAssistant.showTBAEntryForm(source,target, voyage);		

end;</source>
        <Parameter name="menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doMnuHideSelectorPanel" id="0ed30574-60c1-4e26-aef5-72543804465f">
        <updating/>
        <source>doMnuHideSelectorPanel() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
28 July 2011	cnwndl1	Initial creation	Par 27890

*/

vars

	saveWidth	: Real;

begin

	self.mnuHideSelectorPanel.enabled := true;

	if self.myTerminal.getConfig(GridAreaSelectorSet) = null then
		self.dkbSelectorPane.visible := false;
		self.mnuHideSelectorPanel.caption := self.MNU_SELECTOR_SHOW;
		self.mnuHideSelectorPanel.enabled := false;
		
	elseif self.mnuHideSelectorPanel.caption = self.MNU_SELECTOR_SHOW then
		// save and reset the width as if showing for thw first time
		// then Jade appears to get some odd width 
		saveWidth := self.dkbSelectorPane.width;
		self.dkbSelectorPane.visible := true;
		self.dkbSelectorPane.width := saveWidth;
		self.mnuHideSelectorPanel.caption := self.MNU_SELECTOR_HIDE;
		
	else
		self.dkbSelectorPane.visible := false;
		self.mnuHideSelectorPanel.caption := self.MNU_SELECTOR_SHOW;
		
	endif;
	
	self.xmlSelector := self.mnuHideSelectorPanel.caption = self.MNU_SELECTOR_SHOW;
	
	self.doShowHideSubMainCol();
	
	self.doResize();
	
epilog

end;
</source>
    </JadeMethod>
    <JadeMethod name="doMnuLCLClick" id="f799607e-de5c-4f8a-9e09-e741c1da17ce">
        <updating/>
        <source>doMnuLCLClick(menuItem: MenuItem input) updating;
// ---------------------------------------------------------------------------
// Created:		August  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

	lPackUnpack	: YRD_PackUnpack;
	anObject	: Object;
	theTI 		: CM_Container;
	frm			: Form;
begin
	anObject := menuItem.userObject;
	if anObject = null then 
		return;
	endif;
	
	if not anObject.isKindOf(CM_Container) then
		return;
	endif;
	
	theTI := anObject.CM_Container;
	lPackUnpack := app.loadForm(YRD_PackUnpack,
								CMUI_Assistant,
								false,
								false,
								false,
								self.myTerminal,
								null).YRD_PackUnpack;
	//14/03/2011 cnwdz2 27139
	if lPackUnpack = null then
		return;
	endif;
	
	//create lPackUnpack;
	//lPackUnpack.centreWindow;
	lPackUnpack.myTI := theTI;
	lPackUnpack.setMyTerminal(self.myTerminal);
//	lPackUnpack.myTerminalArea := self.myCurrentTerminalArea;
	lPackUnpack.show;



end;</source>
        <Parameter name="menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
