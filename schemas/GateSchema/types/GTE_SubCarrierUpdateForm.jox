    <JadeMethod name="doSave" id="7fddbb29-19a3-4bc7-bd15-4c2533e4c7e7">
        <updating/>
        <source>doSave() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 May 2022	navhl20	Initial creation 	TFS 53430

*/

vars
	subCarrier : String;
	result : Integer;
	pxyVvr : CM_VehicleVisitRecord;
begin
	if self.cmbSubCarrier.listObject &lt;&gt; null then
		subCarrier := self.cmbSubCarrier.listObject.CM_Carrier.code;
	endif;
	
	beginLoad;
	pxyVvr := self.myCurrentVvr.pxyCreateUpdateProxy();
	endLoad;
	pxyVvr.setSubCarrierCode(subCarrier);
	
	while true do
		app.myTrxUA.trxUpdateVVRSubCarrier(pxyVvr,app.myPassport);
		if app.myPassport.trxCompletedOK then
			self.clearErrorWarnings();
			self.unloadForm;
			break;
		else
			result := app.showErrorWarningDialog(app.getErrorString(Update_Sub_Carrier), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   result = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;

			self.setAllErrorWarnings(app.myPassport);
		endif;
		
		break;
	endwhile;
	
epilog
	delete pxyVvr;
end;</source>
    </JadeMethod>
    <JadeMethod name="initSubCarrierCombo" id="f035915d-fd9d-41f3-bbf6-8e62b240ec27">
        <updating/>
        <source>initSubCarrierCombo() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 May 2022	navhl20	Initial creation 	TFS 53430

*/

vars
	aCarrier : CM_Carrier;
	combo : CMUI_ComboBox;
begin
	combo := self.cmbSubCarrier;
	combo.clear();
	foreach aCarrier in app.myRoot.allSubCarriersRoad discreteLock do
		combo.addItemObject(aCarrier.description, aCarrier);
	endforeach;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="populateMyCurrentVvr" id="0c6b7d98-0213-48b9-91a7-c6b944ef2659">
        <updating/>
        <source>populateMyCurrentVvr() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 May 2022	navhl20	Initial creation	TFS 53430

*/

vars

begin
	self.lblCarrierData.caption := self.myCurrentVvr.carrierCode;
	self.lblRegNumberData.caption := self.myCurrentVvr.regNumber;
	self.cmbSubCarrier.listObject := self.myCurrentVvr.getSubCarrier;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setupForm" id="d24b8032-9abb-4c9d-822b-63369bf3e491">
        <updating/>
        <source>setupForm() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 May 2022	navhl20	Initial creation	TFS 53430

*/

vars

begin
	inheritMethod();
	
	if self.myCurrentVvr = null then
		self.unloadForm();
		return;
	endif;
	
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		self.cmbSubCarrier.enabled := false;
		self.btnSave.enabled := false;
	endif;
	
	self.handleMenusForModalDisplay();
	self.btnOk.visible := false;
	self.btnCancel.visible := false;
	
	self.initSubCarrierCombo;
	self.populateMyCurrentVvr;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="translateForm" id="764343e4-ed89-4fdf-96db-572fc8964b08">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 08 June 2022 07:27:31.
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0024916, locale);
	btnSave.translateCaption(Xlat_0024917, locale);
	btnUpdateCancel.translateCaption(Xlat_0024918, locale);
	lblCarrier.translateCaption(Xlat_0024919, locale);
	lblRegNumber.translateCaption(Xlat_0024920, locale);
	lblSubCarrier.translateCaption(Xlat_0024921, locale);
end;</source>
    </JadeMethod>
</GUIClass>
