    <JadeMethod name="unload" id="ab1c5939-e723-4f96-891a-b1abdb22906f">
        <controlMethod name="Form::unload"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>unload() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
23/12/2009	cnwrd1	Initial creation
19/06/2018	jlgdap1	TFS 38560 PEL1 Voyage Work Orders fix ups
*/

vars

begin
	//self.checkAndDeleteProxies();
	if global.isValidObject(self.myMainForm) then // do not delete if this is the attachments
		self.myMainForm.enabled := true;
	endif;

	inheritMethod();
epilog

end;</source>
