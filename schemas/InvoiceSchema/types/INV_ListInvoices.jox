/*
Purpose:	TFS 39618		
Date				Who			Reason
JANUARY 2019		CNWAB1		Initial creation
*/

vars
	invoiceStatus : CM_InvoiceStatus;
begin
	app.mousePointer := MP_HOURGLASS;
	
	invoiceStatus := self.myCurrentBank.getMyInvoiceProcess.allStatuses[CM_Invoice.INVOICE_APPROVED];
	
	if invoiceStatus = null 
	or not invoiceStatus.userCanSet(self.myTerminal) then
		app.msgBox(app.getErrorString1(VB_SECMOVE, app.getErrorString(Invoice_status_approved)),
										app.getErrorString(INV_Invoice_Security),
										MsgBox_Exclamation_Mark_Icon + MsgBox_OK_Only);
		return;
	endif;
	
	self.doSaveChangeStatus(CM_Invoice.INVOICE_APPROVED);

epilog
	app.mousePointer := MP_DEFAULT;
end;</source>
    </JadeMethod>
