<GUIClass name="CMUI_BlockArea_Labels" id="a20dea07-18d4-4fb3-876b-68912e1b92db">
    <superclass name="CMUI_GridArea_Labels"/>
    <transient/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <JadeMethod name="loadColumns" id="75124bf0-ea1f-4967-8ff2-9de3916913f4">
        <source>loadColumns() protected;
// Load the columns into to form table
vars
	label : String;
	i : Integer;
	oldLabel, newLabel : String;
begin
	i := 1;
	foreach label in self.gridArea.CMUI_BlockArea.columnLabels do
		oldLabel := label;
		newLabel := oldLabel;
		tblLabels2.setValue(tblLabels2.addAttribute(i.String, oldLabel, Table.InputType_TextBox, 0, true), newLabel);
		i := i + 1;
	endforeach;
end;
</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="loadRows" id="717bff2b-2033-4b97-9d83-eb3de50fa016">
        <source>loadRows() protected;
// Load the rows into to form table
vars
	label : String;
	i : Integer;
	oldLabel, newLabel : String;
begin
	i := 1;
	foreach label in self.gridArea.CMUI_BlockArea.rowLabels do
		oldLabel := label;
		newLabel := oldLabel;
		tblLabels2.setValue(tblLabels2.addAttribute(i.String, oldLabel, Table.InputType_TextBox, 0, true), newLabel);
		i := i + 1;
	endforeach;
end;
</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="translateForm" id="db687072-4145-4766-93c2-85d61d56653c">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0014532, locale);
end;</source>
    </JadeMethod>
    <JadeMethod name="updateColumnLabels" id="b3ae1b38-1317-44e6-a1d2-11d20d4aa598">
        <source>updateColumnLabels() protected;
// Check there are no duplicates in the list of labels
vars
	label : String;
	r : Integer;
begin
	foreach r in tblLabels2.fixedRows+1 to tblLabels2.rows do
		label := tblLabels2.getValue(r).String.trimBlanks();
		if checkLabel(label) then
			self.gridArea.CMUI_BlockArea.columnLabels[r - tblLabels2.fixedRows] := label[1:10];
		endif;
	endforeach;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="updateRowLabels" id="70ed59dc-4ae7-472c-9daf-26932d11ffc8">
        <source>updateRowLabels() protected;
// Check there are no duplicates in the list of labels
vars
	label : String;
	r : Integer;
begin
	foreach r in tblLabels2.fixedRows+1 to tblLabels2.rows do
		label := tblLabels2.getValue(r).String.trimBlanks();
		if checkLabel(label) then
			self.gridArea.CMUI_BlockArea.rowLabels[r - tblLabels2.fixedRows] := label[1:10];
		endif;
	endforeach;
end;
</source>
        <access>protected</access>
    </JadeMethod>
</GUIClass>
