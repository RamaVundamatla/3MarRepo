	self.deleteTerminalArea("A");
	self.deleteTerminalArea("C");
	self.deleteLabourRestriction( labRestrictA );
	self.deleteLabourRestriction( labRestrictC );
	
epilog

	abortTransaction;

	beginTransaction;
	app.myRoot.setClient(Client_JadeMaster);		
	commitTransaction;

	delete newLCs;
