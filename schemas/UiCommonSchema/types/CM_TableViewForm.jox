    <JadeMethod name="allowMultiSelectDelete" id="35c208f7-6937-4524-b3d9-5cf9f1e18ac9">
        <methodInvocation>mapping</methodInvocation>
        <updating/>
        <source>allowMultiSelectDelete(set: Boolean; _value: Boolean io) mapping, updating;
// ---------------------------------------------------------------------------
// Created:     19 November 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	if set then
		self.allowMultiSelectDelete := _value;
		if self.allowMultiSelectDelete then
			self.multiSelect := CM_BaseTable.MultiSelect_Simple;
		else
			if (not self.allowMultiSelectEdit) then
				self.multiSelect := CM_BaseTable.MultiSelect_None;
			endif;
		endif;
	else
		_value := self.allowMultiSelectDelete;
	endif;

end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="Boolean" usage="io"/>
    </JadeMethod>
