    <JadeMethod name="createManLineAPIConsol" id="b9d12008-041c-43ab-a71d-9dab9d778915">
        <source>createManLineAPIConsol(_ref : String; _invLineType : CM_InvoiceLineDesc; _rate : Decimal; _invoice : CM_Invoice; _narr : String; _date : Date;   _seq : Integer; _qty : Real) : CM_InvoiceLine;
/*
Purpose:	

Date		Who		Reason
07 May 2025	navab1	JIRA 34738
JIRA 34909
*/

vars
	invoiceLine : CM_InvoiceLine;
begin
	invoiceLine := self.createManualInvoiceLine(_invLineType, _invoice, _qty, _narr, _date);
	
	beginTransaction;
	// ### SET RATE
	invoiceLine.resetMinimumCharge(_rate * invoiceLine.quantity, _rate);
	
	// ### SET EXTREF4
	invoiceLine.setPropertyValue("externalRef4", _ref);
	
	// ### SET SEQUENCE
	invoiceLine.sequenceNum := _seq;
	commitTransaction;
	
	
	return invoiceLine;
epilog

end;</source>
        <Parameter name="_ref" type="String"/>
        <Parameter name="_invLineType" type="CM_InvoiceLineDesc"/>
        <Parameter name="_rate" type="Decimal"/>
        <Parameter name="_invoice" type="CM_Invoice"/>
        <Parameter name="_narr" type="String"/>
        <Parameter name="_date" type="Date"/>
        <Parameter name="_seq" type="Integer"/>
        <Parameter name="_qty" type="Real"/>
        <ReturnType type="CM_InvoiceLine"/>
    </JadeMethod>
    <JadeMethod name="createManualInvoiceLineRate" id="97224172-0972-4290-9aa6-fa6163b1b986">
        <source>createManualInvoiceLineRate(realInvoice : CM_Invoice; ild : CM_InvoiceLineDesc; newRate : Real;_ti : CM_TrackedItem );
/*
Purpose:	TFS 42283		
Date				Who			Reason
DECEMBER 2018		NAVAB1		Initial creation
10 March 2023  navmv20 TFS 56128 Task 56129: UI - Manual Invoice Lines - Multi TI Invoice Line Type
*/

vars
	now			: Date;
	operator	: CM_Operator;
	invLine		: CM_InvoiceLine;
	manController : CMIF_InvoiceLineManual;

	theController : CMIF_ChargesController;
	aCharge, pxyCharge : CM_Charge;
	
begin


	// ### MANUAL INVOICE LINE
	create manController transient;
	create theController transient;

	manController.quantity := 1.0;
	manController.remarks := "Unit Test"; // ### JIRA 33007 10DEC2024 NAVAB1
	manController.chargeTime.setDate(now);
	manController.myInvoice := realInvoice;
	//manController.myInvoiceLineType := ild; //10 March 2023  navmv20 TFS 56128 Task 56129
	manController.allInvoiceLineTypes.add(ild); //10 March 2023  navmv20 TFS 56128 Task 56129
	if _ti &lt;&gt; null then							//26.05.2021 navma1 #51218
		//manController.myTrackedItem := _ti; //10 March 2023  navmv20 TFS 56128 Task 56129
		manController.allTrackedItems.add(_ti); //10 March 2023  navmv20 TFS 56128 Task 56129
	endif;
	app.myTrxCA.trxCreateInvoiceLineManual(manController,invLine, app.myPassport);

	foreach aCharge in invLine.charges do 
		pxyCharge := app.createUpdateProxy(aCharge).CM_Charge;
		pxyCharge.setProxyRateNew(newRate);
		pxyCharge.setOverriden();
		theController.allCharges.add(pxyCharge);
	endforeach;

	app.myTrxUA.trxUpdateChargesManual(theController,app.myPassport);
	
	
epilog
	self.resetDefaultTranMap();
	delete manController;
	delete pxyCharge;
	theController.allCharges.purge();
	delete theController;
end;</source>
        <Parameter name="realInvoice" type="CM_Invoice"/>
        <Parameter name="ild" type="CM_InvoiceLineDesc"/>
        <Parameter name="newRate" type="Real"/>
        <Parameter name="_ti" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="createNamedVesselVoyage" id="4e175ff1-382c-483f-a38c-cfe267d30210">
        <updating/>
        <source>createNamedVesselVoyage(_vesselName : String; _voyageCode : String; _operatorCode : String) : CM_Voyage updating, protected;
// May 2014 create named vessel and voyage with optional named parameters for the cargo
vars
	voyageCode	: String;
	vesselName	: String;
	operatorCode	: String;
	voyage1: CM_Voyage;
	vessel: CM_Vessel; 
	
begin
	if _voyageCode &lt;&gt; null then
		voyageCode := _voyageCode;
	else
		voyageCode := "UTSTOR1";
	endif;
	if _vesselName &lt;&gt; null then
		vesselName := _vesselName;
	else
		vesselName := "UTINVTEST1";
	endif;
	if _operatorCode &lt;&gt; null then
		operatorCode := _operatorCode;
	else
		operatorCode := self.getProfileSetting(UT_Profile.P_OPERATOR).asString;
	endif;
		
	deleteVoyage(voyageCode);
	deleteVessel(vesselName);
	vessel := addVesselCellular(vesselName, self.getOperator(operatorCode));
	self.addVesselDefnReefer40(vessel);
	voyage1 := addVoyageWithContainerStructur(voyageCode, vesselName, operatorCode, self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString);

	return voyage1;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_vesselName" type="String"/>
        <Parameter name="_voyageCode" type="String"/>
        <Parameter name="_operatorCode" type="String"/>
        <ReturnType type="CM_Voyage"/>
    </JadeMethod>
    <JadeMethod name="createPilotWithResource" id="57099082-dbcc-4c96-a1df-c548e279c668">
        <updating/>
        <source>createPilotWithResource(_harbour : HMS_Harbour) : HMS_Pilot updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 Jul 2019	jlgsl4	TFS 44957 - PEL1 - include movement pilot details in voyage-movement UT
21 Mar 2025	navah1	Task 34209: MTN - Fix unit tests that call create a pilot they should delete the pilot before creating it - Phase1
*/
constants
	UTPILOT = 'UTPILOT';
	APILOT = 'GBR1';
vars
	pxyPilot : HMS_Pilot;
	pilot : HMS_Object;
	pxyPilotResource : HMS_ResourceForPilot;
	shiftResource : HMS_Resource;
begin
	shiftResource := _harbour.allResources[APILOT];
	self.assertTrueMsg(shiftResource &lt;&gt; null, "Resource " &amp; APILOT &amp; " does not exist on harbour " &amp; _harbour.description &amp; ".");
	pilot := _harbour.allPilots[UTPILOT];						//21.03.2025 navah1 #34209
	if pilot &lt;&gt; null then										//21.03.2025 navah1 #34209
		app.myTrxDA.trxDeleteHMSObject(pilot, app.myPassport);
		pilot := _harbour.allPilots[UTPILOT]; 
		self.assertNull(pilot);
	endif;
	create pxyPilot transient;
	create pxyPilotResource transient;
	pxyPilot.setProxy(app.myRoot, _harbour);
	pxyPilot.setPropertyValue("code", UTPILOT);
	pxyPilot.setPropertyValue("description", "Unit Test pilot");
	pxyPilotResource.setProxy(pxyPilot, _harbour, null, null, shiftResource);
	app.myTrxCA.trxCreateHMSObject(pxyPilot, pilot, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	return pilot.HMS_Pilot;
epilog
	delete pxyPilotResource;
	delete pxyPilot;
end;</source>
        <Parameter name="_harbour" type="HMS_Harbour"/>
        <ReturnType type="HMS_Pilot"/>
    </JadeMethod>
    <JadeMethod name="createProformaAgent" id="d722875a-0c41-4f4f-a52c-4c6596c0b1b4">
        <source>createProformaAgent(_effective : TimeStamp; _ti : CM_TrackedItem) : CM_CashInvoiceProformaAgent protected;
/*

Purpose:			Create an return a pro

Parameters:			

Return Value:		


Date		Who		Reason
22/10/2013	cnwjre1	Cash testing

*/

vars
	bank 		: CM_Bank;
	agent 		: CM_CashInvoiceProformaAgent;
	effectiveDT : TimeStamp;
	useProformaConfig : Boolean;
	debtor : CM_Debtor;
begin
	 // ### JIRA 34760 02MAY2025 NAVAB1
	useProformaConfig := false;
	if self.opts.includesKey("UseProformaConfig") then
		useProformaConfig :=  self.opts.bool("UseProformaConfig");
	endif;

	create agent transient;
	bank 		:= self.getTerminal.getDefaultCompanyBank();
	effectiveDT := _effective;
	app.myPassport.clearErrorsWarnings;
	agent.init( bank, _ti, effectiveDT.date, useProformaConfig ); // ### JIRA 34760 02MAY2025 NAVAB1
	
	// ### JIRA 34909 16MAY2025 NAVAB1
	if self.opts.includesKey("cashDebtor") then
		debtor :=  self.opts.obj("cashDebtor").CM_Debtor;
		agent.setDebtorFromAgent(debtor);
	endif;
	
		

	agent.createProformaInvLines( null, false, false );		// no consolidation, no extra lines
	agent.getCurrentInvLines();							    // existing invoice lines from transactions
	
	return agent;
epilog
	
	app.allReportObjectSet.purge();		// used as temporary invoice storage
end;</source>
        <access>protected</access>
        <Parameter name="_effective" type="TimeStamp"/>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <ReturnType type="CM_CashInvoiceProformaAgent"/>
    </JadeMethod>
    <JadeMethod name="createProformaInvoiceLines" id="8822bae2-9e50-4ee9-a22a-8a43a5ebf739">
        <source>createProformaInvoiceLines(_effective : TimeStamp; _ti : CM_TrackedItem; _agent : CM_CashInvoiceProformaAgent output) : CM_InvoiceLineBySeqNumDict protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
01 August 2012	cnwer1	Initial creation CCMS MES 1035

*/

vars
	bank 				: CM_Bank;
	agent 				: CM_CashInvoiceProformaAgent;
	effectiveDT 		: TimeStamp;
	lines 			    : CM_InvoiceLineBySeqNumDict;
	extraTransactions	: CM_TransactionTypeArray;

begin

	create agent transient;
	create extraTransactions transient;

	bank 		:= self.getTerminal.getDefaultCompanyBank();
	effectiveDT := _effective;
	app.myPassport.clearErrorsWarnings;
	agent.init( bank, _ti, effectiveDT.date, false );
	
	create lines transient;
	agent.createProformaInvLines( lines, false, false );		// no consolidation
	
	_agent := agent;
	return lines;
epilog
	
	delete extraTransactions;
	app.allReportObjectSet.purge();		// used as temporary invoice storage
end;</source>
        <access>protected</access>
        <Parameter name="_effective" type="TimeStamp"/>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_agent" type="CM_CashInvoiceProformaAgent" usage="output"/>
        <ReturnType type="CM_InvoiceLineBySeqNumDict"/>
    </JadeMethod>
