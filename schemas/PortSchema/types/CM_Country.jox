    <JadeMethod name="setForCreate" id="af95d65e-8c87-4eb1-95f5-94b19e26cd54">
        <updating/>
        <source>setForCreate(pProxyCountry:CM_Country) updating;
// ---------------------------------------------------------------------------
// Created:     16 July 2001 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	pProxyCountry.raiseExceptionIfNotTransient(method);
	
	setForUpdate(pProxyCountry);
	self.myRoot := app.myRoot;

end;</source>
        <Parameter name="pProxyCountry" type="CM_Country"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="8910bbd8-6726-41f1-b0b7-e7f4bb4b9071">
        <updating/>
        <source>setForUpdate(pProxyCountry:CM_Country) updating;
// ---------------------------------------------------------------------------
// Created:     16 July 2001 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	self.code 					:= pProxyCountry.code.trimBlanks;
	self.description 			:= pProxyCountry.description.trimBlanks;
	self.isNotAvailableForEntry	:= pProxyCountry.isNotAvailableForEntry;
	self.isoCode3 := pProxyCountry.isoCode3;	//08 Aug 2013	Par 32305
	self.unNum := pProxyCountry.unNum;	//08 Aug 2013	Par 32305
	self.myCountryRegion := pProxyCountry.myCountryRegion; //03/08/2023	navkc1	CR 59552   Task 59555

end;</source>
        <Parameter name="pProxyCountry" type="CM_Country"/>
    </JadeMethod>
    <JadeMethod name="setMyRoot" id="a5072672-2308-48b7-ae7e-41d6bb462480">
        <updating/>
        <source>setMyRoot() updating;
// ---------------------------------------------------------------------------
// Created:     04 July 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	self.myRoot := app.myRoot;

end;</source>
    </JadeMethod>
    <JadeMethod name="setProxy" id="979e70c8-6785-4844-9a57-a55fe1abe442">
        <updating/>
        <source>setProxy(pCode, pDescription, pCodeISO3, pUnNum : String; _isNotAvailableForEntry : Boolean; _region : CM_CountryRegion) updating;

vars
	aPort : CM_Port;
	aCountry : CM_Country;
	thePorts : CM_PortSet;
begin

	self.raiseExceptionIfNotTransient(method);

	self.code 						:= pCode[1:4];
	self.description 				:= pDescription[1:25];
	
	self.isoCode3 := pCodeISO3[1:3].toUpper;	//08 Aug 2013	Par 32305
	self.unNum := pUnNum[1:3];	//08 Aug 2013	Par 32305
	self.isNotAvailableForEntry		:= _isNotAvailableForEntry;
	self.myRoot 					:= app.myRoot;
	
	self.myCountryRegion			:= _region; //03/08/2023	navkc1	CR 59552   Task 59555
end;</source>
        <Parameter name="pCode" type="String"/>
        <Parameter name="pDescription" type="String"/>
        <Parameter name="pCodeISO3" type="String"/>
        <Parameter name="pUnNum" type="String"/>
        <Parameter name="_isNotAvailableForEntry" type="Boolean"/>
        <Parameter name="_region" type="CM_CountryRegion"/>
    </JadeMethod>
