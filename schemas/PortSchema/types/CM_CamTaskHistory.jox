    <JadeMethod name="writeFileDataToFile" id="6ef9a67c-3848-48d7-9473-3335cb0155e4">
        <source>writeFileDataToFile( _file : File);
/* 
---------------------------------------------------------------------------
 Created:     J Harliwich               

 Purpose:     MES1011 Move code from CM_+CamTask.createOutputFile
	          Write the fileData to the file paramater, must already be open.

 Parameters:  None

 Returns:     Nothing

 Changed On		Changed By	Reason
 ----------		----------	--------------------------------------------------
 02/09/2009		J Harliwich	MES1011 Don't convert User defined reports to uppercase
 20/07/2014		G Black		CCMS DPH 2346 Support Suzano Cams types
 11/11/2014		cnwrs1	 	CCMS 2405 - Alabama Steel Cams
 30/01/2015		cnwrs1		Par 35544 - Refactor Cams file storage to string
 27/07/2015		cnwrs1		Par 36646 - Chestnut Hill XML should not be uppercased
 26/02/2025		navdap1		MTN-19917 MTN - Large CAMS file contains Ż\_(?)_/Ż throughout
---------------------------------------------------------------------------
*/

vars
	message : String;
	str : String;
	count : Integer;
	theLines : HugeStringArray;
begin
	create theLines transient;
	self.rawDataToHSA(theLines);
	if  isUsingFileDataStorage	then 							// MES1011 Initially only used by User-definedreports but if other desc need to do something fancy in the future then they could also use
																// eg. if output is something other than standard text, such as a pdf or word doc is created then you'd need to use this.
		myFileDataStorageHeader.writeDetailToFile (_file);
		
	else
	
		count := 0;
		foreach message in theLines do
			if camProtocol.protocolDesc.class = CM_CamACOSDesc or
			   camProtocol.protocolDesc.class = CM_CamTOLMove or
			   camProtocol.protocolDesc.class = CM_CamTOLWharfNotification then
				count := count + 1;
				str := str &amp; message;
				if count = 3 then
					if camProtocol.noCrLfInMessage then
						_file.writeString(str.toUpper);
					else
						_file.writeLine(str.toUpper);
					endif;
					str := "";
					count := 0;
				endif;
			elseif camProtocol.protocolDesc.class = CM_CamMaerskStockReport then 
				count := count + 1;
				str := str &amp; message;
				if count = 2 then
					if camProtocol.noCrLfInMessage then
						_file.writeString(str.toUpper);
					else
						_file.writeLine(str.toUpper);
					endif;
					str := "";
					count := 0;
				endif;
				
			elseif camProtocol.isUserDefinedReport  or 	// MES1011 this does not do any uppercase conversion, want it to be an exact copy of what was produced by the JRW
				   camProtocol.isUserDefinedEventReport or	// PAR 21905 CCMS MES 1008 - PHB
														// The case can be controlled in the report writer and we don't want to override that
                    camProtocol.protocolDesc.isKindOf(CM_CamAlabamaSteelDesc) or //11 Nov 2014	cnwrs1	 CCMS 2405 - Alabama Steel Cams
                    camProtocol.protocolDesc.isKindOf(CM_CamChestnutHillXML) or //27 Jul 2015	cnwrs1	 Par 36646 - Chestnut Hill XML should not be uppercased
                    camProtocol.protocolDesc.isKindOf(CM_CamOneStopXML) or	//25 Aug 2016	NDL	TFS 2277 / 2567
					camProtocol.protocolDesc.isKindOf(CM_CamSuzanoDesc) then //cnwgb1 CCMS 2346 20.7.2014 PAR 34561                                
				if camProtocol.noCrLfInMessage then
					_file.writeString(message);
				else
					_file.writeLine(message);
				endif;
				
			else
				// MTN-19917 we can get here if we're sending JSON CAMS to a ftp / email, so strip any JSON output delimiter characters
				message := message.replace(CM_CamProtocol.JSON_Output_Delimeter.unicodeToString, "");
				if camProtocol.noCrLfInMessage then
					_file.writeString(message.toUpper);
				else
					_file.writeLine(message.toUpper);
				endif;
			endif;
		endforeach;
	endif;
epilog
	delete theLines;
end;</source>
        <Parameter name="_file" type="File"/>
    </JadeMethod>
</Class>
