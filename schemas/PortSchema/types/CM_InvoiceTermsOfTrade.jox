    <JadeMethod name="setForUpdate" id="7d2eac86-6204-431d-83c0-fa4cdda76c5c">
        <updating/>
        <source>setForUpdate(pProxyInvTermsOfTrade : CM_InvoiceTermsOfTrade) updating;
//----------------------------------------------
//Created: 16 October 2001 By: cnwgd1
//----------------------------------------------

vars
	i : Integer;

begin

	pProxyInvTermsOfTrade.raiseExceptionIfNotTransient(method);
	self.raiseExceptionIfTransient(method);

	self.code := pProxyInvTermsOfTrade.code.toUpper;
	self.description := pProxyInvTermsOfTrade.description;
	self.dueDays := pProxyInvTermsOfTrade.dueDays; //15/01/2023	navkc1 ChangeRequest 59145 Task 61328
	self.dueRule := pProxyInvTermsOfTrade.dueRule; //15/01/2023	navkc1 ChangeRequest 59145 Task 61328
	self.myBank := pProxyInvTermsOfTrade.myBank;
	
end;</source>
        <Parameter name="pProxyInvTermsOfTrade" type="CM_InvoiceTermsOfTrade"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="1f8120cf-8a37-4c12-8c51-b8e78c6897c8">
        <updating/>
        <source>setProxy(pCode:String; pDescription:String; pDueDays, pDueRule : Integer) updating;
//----------------------------------------------
//Created: 16 October 2001 By: cnwgd1
//----------------------------------------------
vars

begin
	self.raiseExceptionIfNotTransient(method);
	self.code := pCode;
	self.description := pDescription;
	self.dueDays := pDueDays; //15/01/2023	navkc1 ChangeRequest 59145 Task 61328
	self.dueRule := pDueRule;	//15/01/2023	navkc1 ChangeRequest 59145 Task 61328
end;</source>
        <Parameter name="pCode" type="String"/>
        <Parameter name="pDescription" type="String"/>
        <Parameter name="pDueDays" type="Integer"/>
        <Parameter name="pDueRule" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="shouldAuditProperty" id="a1383807-2634-4437-a46b-094de548753a">
        <source>shouldAuditProperty(_rootClass: Class; _property: Property): Boolean protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15/01/2023	navkc1 ChangeRequest 59145 Task 61331: Jade - Terms Audits

*/

vars

begin
	if 	_property.name = CM_InvoiceTermsOfTrade::allDebtors.name or
		_property.name = CM_InvoiceTermsOfTrade::allInvoiceTypes.name
		then
		
		return false;
	else
		return inheritMethod(_rootClass, _property);
	endif;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_rootClass" type="Class"/>
        <Parameter name="_property" type="Property"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validate" id="91f22472-2871-4963-8f37-d67c4b2a58b9">
        <source>validate();
//----------------------------------------------
//Created: 16 October 2001 By: cnwgd1
//----------------------------------------------
vars

begin

	if self.code = null then
		app.setContinueCMExceptions(true);
		app.raiseCMException2(ERR_INVALID_VALUE, "Code", "You must enter a code.", null, null);	
	endif;
	if self.description = null then
		app.setContinueCMExceptions(true);
		app.raiseCMException2(ERR_INVALID_VALUE, "Description", "You must enter a description.", null, null);
	endif;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="validateForCreate" id="96f7e422-c2e5-4ad7-bc96-1a006fcf8a8e">
        <source>validateForCreate(_theTerminal : CM_Terminal);
//----------------------------------------------
//Created: 17 October 2001 By: cnwgd1
//----------------------------------------------
vars
	invTerm : CM_InvoiceTermsOfTrade;
begin

	if app.myRoot.myRootCompany.allInvoiceTermsOfTrade.size &gt; 0 then		
		foreach invTerm in app.myRoot.myRootCompany.allInvoiceTermsOfTrade do
			if invTerm.code = self.code then
				app.raiseCMException2(ERR_INVALID_VALUE, "Code", "Code '" &amp; self.code &amp; "' already exists in the system.", null, null);
			endif;
		endforeach;
	endif;	
				 
end;</source>
        <Parameter name="_theTerminal" type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="validateForDelete" id="037050a2-e4e9-4b34-a22f-dfa8da910506">
        <source>validateForDelete();
//----------------------------------------------
//Created: 17 October 2001 By: cnwgd1
//----------------------------------------------

// 08/12/2014 cnwdb2 PAR 35364
vars
	str	: String;
	invType : CM_InvoiceDesc;
begin
	
	if self.isActive then
		app.raiseCMWarning1(WARN_ACTIVE_INV_TERM, self.code, null, null, self);
	endif;	
	
	if self.allInvoiceTypes.size &gt; 0 then
		foreach invType in self.allInvoiceTypes do
			str := str &amp; invType.description &amp; ", ";
		endforeach;
		app.raiseCMWarning2(WARN_DEFAULT_INV_TERM, self.code, str, null, null, self);
	endif;	
	
	if (not self.isActive) and self.allInvoiceTypes.size &lt;= 0 then
	//	app.raiseCMWarning2(CONF_DELETE, "Terms of Trade: ", self.code, null, null, self);	
		app.raiseCMWarning1(Sure_want_delete35364b, self.code, null, null, self);	//cnwdb2 PAR 35364

	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="validateForUpdate" id="6bc3c435-812a-45e1-8ded-8d19f571a077">
        <source>validateForUpdate(pRealInvTermsOfTrade : CM_InvoiceTermsOfTrade);
//----------------------------------------------
//Created: 16 October 2001 By: cnwgd1
//----------------------------------------------
vars
	realCode : String;

begin

	realCode := pRealInvTermsOfTrade.code;

	if self.code &lt;&gt; realCode then		
		app.setContinueCMExceptions(true);
		app.raiseCMException2(ERR_INVALID_VALUE, "Code", "Code cannot be changed!", null, null);
	endif;
			
end;</source>
        <Parameter name="pRealInvTermsOfTrade" type="CM_InvoiceTermsOfTrade"/>
    </JadeMethod>
</Class>
