        <type name="TimeStamp"/>
        <access>readonly</access>
    </PrimAttribute>
    <ExplicitInverseRef name="myTerminal" id="9e4cb03d-ee89-4528-8b50-5e0913e4fc1b">
        <kind>child</kind>
        <transientToPersistentAllowed/>
        <updateMode>manual</updateMode>
        <embedded/>
        <type name="CM_Terminal"/>
        <access>readonly</access>
        <Inverse name="CM_Terminal::allBulkTiTransactions"/>
    </ExplicitInverseRef>
    <PrimAttribute name="transactionType" id="cfd962e7-2c87-4f9e-8743-aa9d2ff5ac77">
        <embedded/>
        <type name="Integer"/>
        <access>readonly</access>
    </PrimAttribute>
    <PrimAttribute name="userCode" id="c38c9d94-5483-4f95-86ad-fe14b39ebf63">
        <length>31</length>
        <embedded/>
        <type name="String"/>
        <access>readonly</access>
    </PrimAttribute>
    <JadeMethod name="addTi" id="a1c64716-f565-474e-8dc7-0e35c5a8e3b4">
        <updating/>
        <source>addTi(_ti : CM_TrackedItem) updating;

// cnwdvb1 28 November 2002 

vars

begin

	self.allTis.add(_ti);

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="getMyTerminal" id="8c1dac29-f1fe-431f-872d-a8824ff42f50">
        <source>getMyTerminal(): CM_Terminal;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26 April 2016	cnwmp6	Initial creation

*/

vars

begin
	return self.myTerminal;

epilog

end;</source>
        <ReturnType type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="getNumberOfTis" id="d2336529-1396-4f1c-ac64-c067d3c4bf40">
        <source>getNumberOfTis() : Integer;

// cnwdvb1 29 November 2002 

begin

	return 0;
	
end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="1980c6be-fcb4-4fb3-a0c2-b6cf9055dc51">
        <updating/>
        <source>setForCreate(_terminal : CM_Terminal; _transactionType : Integer; _userCode : String) updating;

// cnwdvb1 28 November 2002 

vars

begin

	self.transactionType	:= _transactionType;
	self.userCode			:= _userCode;
	self.dateTime			:= app.actualTimeServer;
	self.myTerminal			:= _terminal;

end;</source>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_transactionType" type="Integer"/>
        <Parameter name="_userCode" type="String"/>
    </JadeMethod>
