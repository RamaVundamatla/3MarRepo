    <JadeMethod name="handleContractDetails" id="285ee465-69f8-4de2-acc4-b8b9ae0722de">
        <updating/>
        <source>handleContractDetails()updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 Feb 2023 navtnr20	TFS CR 55646 Task 55664: UI - Contracts Maint

*/

vars

begin
	self.endNotificationForSubscriber(self.myInvoiceContract);

	self.beginNotification(self.myInvoiceContract, self.myTerminal.getTerminalEvent(Event_InvContractDtlCreate), Response_Continuous, null);
	self.beginNotification(self.myInvoiceContract, self.myTerminal.getTerminalEvent(Event_InvContractDtlUpdate), Response_Continuous, null);
	self.beginNotification(self.myInvoiceContract, self.myTerminal.getTerminalEvent(Event_InvContractDtlDelete), Response_Continuous, null);
epilog

