    <JadeMethod name="getAllGTEs" id="8983e1b0-a671-4d7b-ab30-a8dedcc4bd6d">
        <source>getAllGTEs( _allGTEs: CMGTE_EntitySet input );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 October 2013	cnwndl1	Initial creation	Par 31829

*/

vars

	rowIndex : Integer;
	obj : Object;
	attach : CM_Attachment;
	gte : CMGTE_Entity;
	invalid : Boolean;		//10 Jan 2018	NDL	TFS 40479
	edition: Integer;
	objArray : ObjectArray;

begin

	if _allGTEs = null then
		return;
	endif;
	
	on Exception do app.handleDeletedObject( exception, obj, invalid );	//10 Jan 2018	NDL	TFS 40479
	
	if self.tblItems.getCollection &lt;&gt; null then  //28 May 2019	NDL	TFS 44881 - Table::displayCollection doesn't show all data
		create objArray transient;
		self.tblItems.getCollection.copy( objArray );
		foreach obj in objArray do
			if obj &lt;&gt; null and obj.isKindOf( CMGTE_Entity ) then
				invalid:= false;		//10 Jan 2018	NDL	TFS 40479
				edition := obj.edition;		//10 Jan 2018	NDL	TFS 40479
				if invalid then		//10 Jan 2018	NDL	TFS 40479
					continue;
				endif;
				_allGTEs.addNoDuplicates( obj.CMGTE_Entity, false );
				foreach attach in obj.CMGTE_Entity.allAttachments do
					gte := attach.myGTEEntity;
					if gte &lt;&gt; null then
						_allGTEs.addNoDuplicates( gte, false );
					endif;
				endforeach;
				foreach gte in obj.CMGTE_Entity.allChildren do
					if gte &lt;&gt; null then
						_allGTEs.addNoDuplicates( gte, false );
					endif;
				endforeach;
			endif;
		endforeach;
	
	endif;

epilog

	delete objArray;

end;</source>
        <Parameter name="_allGTEs" type="CMGTE_EntitySet" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getChassisLocation" id="567d0684-75b9-4dd9-a099-386fc94823eb">
        <source>getChassisLocation(_chassisId : String; _locText : String output ) : CM_TILC protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
02 June 2009	cnwjk3	Initial creation
// 06 Sep 2016	cnwrs1	TFS 2586 dont always include archived voyages and lookup reveresed even if we found data in non reverese lookup
*/

vars
	theTrailer : CM_TILC;
	allTrailers : CM_TISet;
	selectedTI : CM_TrackedItem;
begin
	if _chassisId = null then
		_locText := null;
		return null;
	endif;
	_locText := self.Trailer_Offsite;
	
	//epr 21011 7/10/09 - changed to null cargo type could be a user defined track as trailer type
	
	theTrailer:= self.myTerminal.lookupTrailerOnsite(_chassisId,null);
	
	if theTrailer = null then
		create allTrailers transient;
		self.myTerminal.lookupAllOnsiteTrailers(null,_chassisId,allTrailers, false, null);

		self.myAssistant.pickerWindowForTrailers(allTrailers,selectedTI);
		if selectedTI &lt;&gt; null then
			theTrailer:=selectedTI.CM_TILC;
		endif;
	endif;
	
	if theTrailer &lt;&gt; null and theTrailer.myPrimaryActualLocation &lt;&gt; null  then 
		self.txtChassisIDOut.text:=theTrailer.id;
		_locText := theTrailer.myPrimaryActualLocation.getFullId();
	endif;
	
	self.txtChassisIDOut.userObject:=theTrailer;
	return theTrailer;
epilog
	delete allTrailers;
end;</source>
        <access>protected</access>
        <Parameter name="_chassisId" type="String"/>
        <Parameter name="_locText" type="String" usage="output"/>
        <ReturnType type="CM_TILC"/>
    </JadeMethod>
    <JadeMethod name="getCollatedWarnings" id="7ce51f8a-b956-491f-9ea1-aba175011e7a">
        <source>getCollatedWarnings(_arrWarnings : HugeStringArray input) protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
18 March 2010	cnwjk3	PAR 23206

*/

vars
	arrObjWarnings 	: HugeStringArray;
	obj				: Object;
	warning			: String;
begin
	foreach obj in self.allWarningsByOid do
		arrObjWarnings := obj.HugeStringArray;
		foreach warning in arrObjWarnings do
			_arrWarnings.add(warning);
		endforeach;
	endforeach;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_arrWarnings" type="HugeStringArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getDefaultGate" id="6994eb15-a691-46e5-aa44-a76762695608">
        <source>getDefaultGate() : CM_Gate protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
15 March 2010	cnwjk3 PAR 23184

*/

vars
	gate : CM_Gate;
begin
	if self.cmbGate.listObject = null then				
		gate := self.myTerminal.getDefaultGate_IN;	
	else
		gate := self.cmbGate.listObject.CM_Gate;
	endif;
	return gate;
epilog

end;</source>
        <access>protected</access>
        <ReturnType type="CM_Gate"/>
    </JadeMethod>
    <JadeMethod name="getDriverId" id="3b7a149a-bb01-4639-9f28-e18e2d0b09dc">
        <source>getDriverId();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
28/08/2009	cnwas3	Initial creation
26/02/2020	jlgdap1	TFS 48688 SNO Driver Identity Check for some variances in road gate process
13/06/2024	jlizm1	FS 63908 Allow duplicate driver names
*/
vars
	aDriver 			: CM_DriverDetails;
	currentDriver 		: CM_DriverDetails;
	currentDriverCode 	: String;
	driverSet 			: CM_DriverDetailsSet;
	
begin

	if self.txtDriverName.text.trimBlanks = null then
		if not self.btnCheckID.visible then			// TFS 48688
			self.cmbDriverCode.clear();
			self.cmbDriverCode.visible := false;
			self.txtDriverCode.visible := true;
			self.txtDriverCode.enabled := true;
			self.lblDriverCode.enabled := true;
			self.txtDriverName.enabled := true;		// TFS 48688
			self.lblDriverName.enabled := true;		// TFS 48688
		endif;										// TFS 48688
		// cnwjk3	09/10/09 PAR 21026 
		//self.txtDriverCode.text := null;
		return;
	endif;

	create driverSet transient;
	if self.myTerminal.getConfig(AllowDupDriverNames).Boolean then	
		self.myTerminal.findDriversWithName(self.txtDriverName.text, driverSet);
		
		if not driverSet.isEmpty then
			if driverSet.size = 1 then
				aDriver := driverSet.first;
			else
				if self.cmbDriverCode.listObject &lt;&gt; null then
					currentDriver := self.cmbDriverCode.listObject.CM_DriverDetails;
				elseif self.txtDriverCode.text &lt;&gt; null then
					currentDriverCode := self.txtDriverCode.text;
				endif;
				
				self.txtDriverCode.text := null;
				self.txtDriverCode.visible := false;
				self.cmbDriverCode.visible := true;
				self.cmbDriverCode.enabled := true;
				self.cmbDriverCode.listCollection(driverSet, false, ComboBox.DisplayCollection_Forward);
				
				if currentDriverCode &lt;&gt; null then
					foreach aDriver in driverSet do
						if aDriver.code.toUpper() = currentDriverCode.toUpper() then
							currentDriver  := aDriver;
							break;
						endif;
					endforeach;
				endif;
				
				if currentDriver &lt;&gt; null then
					self.cmbDriverCode.setIndexFromObject(currentDriver);
				endif;
				
				return;
			endif;
		endif;

	else
		aDriver := self.myTerminal.findDriver(self.txtDriverName.text);		// cnwjk3 PAR 21510 15/02/10
	endif;
	
	self.cmbDriverCode.clear();
	self.cmbDriverCode.visible := false;
	self.txtDriverCode.visible := true;
	
	if aDriver = null and driverSet.isEmpty then
		self.txtDriverCode.enabled := true;
		self.lblDriverCode.enabled := true;
		return;
	endif;

	if aDriver &lt;&gt; null and self.txtDriverCode.text.toUpper() &lt;&gt; aDriver.code.toUpper() then
		self.txtDriverCode.text := aDriver.code;
		self.txtDriverCode.enabled := false;
		self.lblDriverCode.enabled := false;
	endif;

end;</source>
    </JadeMethod>
    <JadeMethod name="getDriverName" id="33e8deb2-aa2f-4161-ac5a-3e5bd12a3f3d">
        <source>getDriverName();
// ---------------------------------------------------------------------------
// Created:     07 August 2008 by cnwab1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
// 26/02/2020		jlgdap1			TFS 48688 SNO Driver Identity Check for some variances in road gate process
// 13/06/2024		jlizm1			TFS 63908 Allow duplicate driver names
// ---------------------------------------------------------------------------
vars
	aDriver : CM_DriverDetails;

begin

	if self.txtDriverCode.text.trimBlanks = null then
		// cnwjk3	09/10/09 PAR 21026 
		//self.txtDriverName.text := null;
		if not self.btnCheckID.visible then				// TFS 48688
			self.lblDriverName.enabled := true;
			self.txtDriverName.enabled := true;
		endif;											// TFS 48688
		return;
	endif;

	// cnwjk3	09/10/09 PAR 21026 
	//self.txtDriverName.text := null;

	//aDriver := self.myAssistant.findDriver(self.txtDriverCode.text, self.myTerminal);
	aDriver := self.myTerminal.findDriver(self.txtDriverCode.text);		// cnwjk3 PAR 21510 15/02/10

	if aDriver = null then
		// cnwjk3	09/10/09 PAR 21026 
		//self.txtDriverName.text := null;
		self.lblDriverName.enabled := true;
		self.txtDriverName.enabled := true;
		return;
	endif;

	if self.txtDriverName.text.toUpper() &lt;&gt; aDriver.name.toUpper() then	
		self.txtDriverName.text := aDriver.name;
		self.txtDriverName.enabled := false;
		self.lblDriverName.enabled := false;
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="getDriverSecureId" id="a9c7432b-84d0-494c-8858-1248486ca7ef">
        <source>getDriverSecureId() : String;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 21/10/2019	jlgdap1		Initial creation TFS 46854 Driver Identity Checking for Cargo Release
//
vars
	inputBox : CMUI_InputBox;
	errorSet : CM_ErrorSet;
	result : String;

begin
	create inputBox transient;
	create errorSet transient;
	
	inputBox.init(	app.getErrorString( Driver_Id ),app.getErrorString( Scan_Driver_Id ),
					'', 64, TextBox.DataType_AlphaNumeric, TextBox.Case_None, false, false);
	
	inputBox.myTerminal := self.myTerminal;
	inputBox.txtInput.passwordField := true;
	inputBox.showModal;
	if inputBox.modalResult &lt;&gt; IDOK then
		return '';
	endif;
	
	result := inputBox.txtInput.getPasswordText;
	return result;

epilog
	
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getMatchingObjectToSelect" id="864479eb-0068-4275-99f9-ab796fae9357">
        <source>getMatchingObjectToSelect(_pCode : String; _pickerShown : Boolean output; isCompleted : Boolean output) : Object protected;
// -----------------------------------------------------------------------------
// Created:		09 September 2009 by consw1
//
// Purpose:		This method is based on method GTE_InOutForm::getMatchingObjectToSelect
//
// Parameters:	None
//
// Returns:		Nothing
//
/* Changes

Date		Name	TFS#		Description
============================================================================
18/10/2016	cnwdap1	TFS 2831 	don't display complete or archived bulk releases
22/05/2018	jlgdap1	TFS 38501 	PEL1 Work Order Changes - new parameter for pickerWindowForObject
12/04/2019	jlgka1	TFS 44368	Add isCompleted flag to identify what error message 
								to display when doing a road gate.
15 Jan 2025	navbs1	Bug MTN-33787: TPT | Need to display the Delivery Party on the Road Gate Screen before the 'Big Save'
============================================================================*/

vars
	bulkRelease			: CM_BulkRelease;
	bookingRef			: CM_BookingRef;
	tmpTI				: CM_TrackedItem;
	objArr				: ObjectArray;
	iter				: Iterator;
	compareCode			: String;
	pickerReturnValue 	: Integer;	//30 May 2011	NDL	Par 27573
	selectedObject 		: Object;	//30 May 2011	NDL	Par 27573
	allowMultiSelect	: Boolean;
	vbt					: CM_VehicleBookingTerminal;	//20 Oct 2014	NDL	Par 35008
	vbsts				: CM_VehicleBookingTimeSlot;	//20 Oct 2014	NDL	Par 35008
	errorMsg 			: String;
	bolSet : CM_BOLSet;	//06 Oct 2020	NDL	TFS 49189
	bol : CM_BOL; //06 Oct 2020	NDL	TFS 49189
	bolDtl : CM_BOLDtl; //06 Oct 2020	NDL	TFS 49189
begin
	create objArr transient;
	
	compareCode := _pCode.toUpper();
	
	//30 May 2011	NDL	Par 27573
//	bulkRelease := self.myTerminal.allBulkReleasesByCodeDate.getAtKeyGeq(compareCode, ts);	
	pickerReturnValue := self.myAssistant.getBulkRelease(compareCode, bulkRelease, isCompleted);	// jlgka1 TFS 44368
	if pickerReturnValue = MsgBox_Return_Cancel then
		//user cancelled, bail
		return null;
	endif;
	//end of	Par 27573	
	// Booking ref items and associated release------------------
	iter := self.myTerminal.allBookingRefsByRef.createIterator;
	self.myTerminal.allBookingRefsByRef.startKeyGeq(_pCode, iter);
	while iter.next(bookingRef) do
		if bookingRef.bookingReference &lt;&gt; _pCode then
			break;
		endif;	
	
		//epr TFS 1602 1/3/17 refactored code block into method
		errorMsg :=bookingRef.getPickerObjectsForGate(objArr,self.myRealVVR,bulkRelease,allowMultiSelect);
		if errorMsg &lt;&gt; null then
			 app.msgBox(errorMsg ,app.getErrorString(Rolled_booking), MsgBox_OK_Only);
			  _pickerShown := true;	//Set this to true so doesn't show another error once returned..
			return null;
		endif;		
	endwhile;
	
	/// Bulk Release----------------------
	if bulkRelease &lt;&gt; null and bulkRelease.code = compareCode and bulkRelease.type = BR_TYPE_ROAD then
		//epr TFS 1602 1/3/17 refactored code block into method
		bulkRelease.getPickerObjectsForGate(objArr);
	endif;
	
	//+cnwml2 PAR26328 MSL CCMS 1091
	//bulk releases assigned to the booking
	bookingRef := self.myTerminal.allBookingRefsByRef[_pCode];
	if bookingRef &lt;&gt; null then
		foreach bulkRelease in bookingRef.allReleaseRequests do
			if bulkRelease.status &lt;&gt; BR_ACTIVE and bulkRelease.status &lt;&gt; BR_PENDING then	// TFS 2831
				continue;																	// TFS 2831
			endif;	
			//epr TFS 1602 1/3/17 refactored code block into method
			bulkRelease.getPickerObjectsForGate(objArr);	
		endforeach;
	endif;
	
	///Inter Term TI-----------------------------------
	tmpTI := self.myTerminal.lookupTrackedItem(_pCode, TI_CargoType_Null, TI_STATE_TRANSFER, null, true);	
	if tmpTI &lt;&gt; null then
		//objArr.add(tmpTI);
		objArr.addExclusive(tmpTI);	//25 Oct 2012	NDL	Par 30621
	endif;
	
	///Pre Note TI -----------------------------------
	 self.getPreNoteTI(_pCode,objArr,allowMultiSelect);
	
	//vehicle booking timeslot has refs to all sorts, add them all...
	//20 Oct 2014	NDL	Par 35008
	if self.myTerminal &lt;&gt; null then
		vbt := self.myTerminal.myVehicleBookingTerminal;
		if vbt &lt;&gt; null then
	//		_pickerShown := true; //vbt would have been used to populate carrier/driver/truck, don't raise error saying nothing was found.
			vbsts := vbt.allVBTimeslotsById.getAtKey( compareCode );
			if vbsts &lt;&gt; null then				
				_pickerShown := true; // Was too soon Par 37215 NDL 07 Jan 2015 //vbt would have been used to populate carrier/driver/truck, don't raise error saying nothing was found.
				foreach tmpTI in vbsts.allBookedTrackedItems do							
					if self.myRealVVR = null or not self.myRealVVR.isPrenoteActioned(tmpTI) then	
						objArr.addExclusive(tmpTI);
						allowMultiSelect := true;
					endif;								
					
				endforeach;
				foreach bulkRelease in vbsts.allBulkReleases do
					//epr TFS 1602 1/3/17 refactored code block into method
					bulkRelease.getPickerObjectsForGate(objArr);			
				endforeach;
				
				foreach bookingRef in vbsts.allBookingRefs do				
					//epr TFS 1602 1/3/17 refactored code block into method
					bookingRef.getPickerObjectsForGate(objArr,self.myRealVVR,bulkRelease,allowMultiSelect);					
				endforeach;
				
			endif;
		endif;
	endif;
	
	//06 Oct 2020	NDL	TFS 49189
	if self.myTerminal &lt;&gt; null then
		if self.myTerminal.roadProcessIsASPA then
			create bolSet transient;
			self.myTerminal.allBOLsReceivedByTypeNumberDT.getAllBolsMatching( bolSet, BOLType_GeneralBillOfLading, compareCode, null );
			foreach bol in bolSet do
				foreach bolDtl in bol.allBOLDtls do
					objArr.add( bolDtl );
				endforeach;
			endforeach;
		endif;
	endif;
	
	/// Bring up the picker window if is needed--------------------
	if objArr.size = 0 then
		return null;
	elseif objArr.size = 1 then
		if objArr.first.isKindOf(CM_BookingRef) then
			bookingRef := objArr.first.CM_BookingRef;
			if objArr.first.CM_BookingRef.allBookingRefItems.size = 1 then
				return objArr.first.CM_BookingRef.allBookingRefItems.first.CM_BookingRefItem;
			else
				_pickerShown := true;
				//return self.pickerWindowForObject(objArr);
				//cnwjo3 par 23674 and 29287 Apr 2012 multi-select pre-notes in road gate add multiSelect parameter
				//self.myAssistant.pickerWindowForObject(objArr, allowMultiSelect, selectedObject, self);			// TFS 38501
				self.myAssistant.pickerWindowForObject(objArr, allowMultiSelect, selectedObject, self, false);		// TFS 38501
				return selectedObject;
			endif;
		elseif objArr.first.isKindOf(CM_ReserveSelection) and self.myTerminal.getConfig(AlwaysShowGatePicker).Boolean then 		//15.01.2024 navbs1 #33787
			_pickerShown := true;
			self.myAssistant.pickerWindowForObject(objArr, allowMultiSelect, selectedObject, self, false);				
			return selectedObject;
		else 
			return objArr.first.CM_Object;
		endif;
	else
		_pickerShown := true;
		//return self.pickerWindowForObject(objArr);
		//cnwjo3 par 23674
		//self.myAssistant.pickerWindowForObject(objArr, allowMultiSelect, selectedObject, self);					// TFS 38501
		self.myAssistant.pickerWindowForObject(objArr, allowMultiSelect, selectedObject, self, false);				// TFS 38501
		return selectedObject;
	endif;
	
epilog
	if objArr &lt;&gt; null then
		delete objArr;
	endif;	
	delete iter;
	delete bolSet;

end;</source>
        <access>protected</access>
        <Parameter name="_pCode" type="String"/>
        <Parameter name="_pickerShown" type="Boolean" usage="output"/>
        <Parameter name="isCompleted" type="Boolean" usage="output"/>
        <ReturnType type="Object"/>
    </JadeMethod>
    <JadeMethod name="getPreNoteTI" id="9a99b004-ec3b-464f-b57f-babb36700bcb">
        <source>getPreNoteTI(_pCode : String;
			 _selectedTIs : ObjectArray input;
			 _allowMultiSelect : Boolean io)  protected;
// ---------------------------------------------------------------------------
// Created:     21 May 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	tmpTI	: CM_TrackedItem;
	tiSet : CM_TISet;
begin
	if _pCode = null then
		return;
	endif;
	
	//epr TFS 1602 1/3/17 find more than one prenotes now
	create tiSet transient;
	
	self.myTerminal.lookupAllNotifiedOnsiteTIs(null,_pCode,tiSet,true,null);
	
	foreach tmpTI in tiSet discreteLock do
		if self.myRealVVR = null or not self.myRealVVR.isPrenoteActioned(tmpTI) then
			_selectedTIs.add(tmpTI);
			_allowMultiSelect:=true;
		endif;
	endforeach;
	
	
epilog
	delete tiSet;
end;</source>
        <access>protected</access>
        <Parameter name="_pCode" type="String"/>
        <Parameter name="_selectedTIs" type="ObjectArray" usage="input"/>
        <Parameter name="_allowMultiSelect" type="Boolean" usage="io"/>
    </JadeMethod>
    <JadeMethod name="getVehicle" id="c55cb149-851c-4401-8469-df4037cf3f56">
        <source>getVehicle() : CM_Vehicle;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 30/09/2016	cnwdap1		Initial creation TFS 2720
//
vars
	state, reg : String;
	vehicle : CM_Vehicle;

begin
	state := self.txtState.text.trimBlanks();
	if self.cmbRegNo.visible then
		reg := self.cmbRegNo.text;
		vehicle := self.cmbRegNo.listObject.CM_Vehicle;
	else
		reg := self.txtRegno.text.trimBlanks();
		if reg = null then
			return null;
		endif;
		vehicle := self.myTerminal.vehicles[reg, state];
	endif;
	
	return vehicle;

epilog

end;</source>
        <ReturnType type="CM_Vehicle"/>
    </JadeMethod>
    <JadeMethod name="getWeighFormObjects" id="fa6a9a33-2ef2-4a83-9187-253590a879f2">
        <source>getWeighFormObjects(_obj: CM_Object; _objArray: ObjectArray input): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 July 2019	jlgndl1	Initial creation	TFS 44965

*/

vars

	vvr : CM_VehicleVisitRecord;
	errStr : String;

begin

	if _obj &lt;&gt; null then
		_objArray.addExclusive(_obj);
	endif;
	
	vvr := self.myRealVVR;
	
	if vvr &lt;&gt; null then
		_objArray.addExclusive(vvr);
		vvr.isWeighBridgeWeighable( _objArray, errStr );
	else
		errStr := "No current vehicle visit found!";	
	endif;
	
	if errStr &lt;&gt; null then
		app.writeLog(method.qualifiedName &amp; " " &amp; errStr, LogINFO);
		app.msgBox( errStr, "Unable to use weigh bridge interface!", MsgBox_OK_Only );
		return false;
	endif;
	
	return true;

epilog

end;</source>
        <Parameter name="_obj" type="CM_Object"/>
        <Parameter name="_objArray" type="ObjectArray" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getWorkOrderDetailsToDisplay" id="cf6964e9-96d5-4c3e-ae14-19c18d5429c9">
        <updating/>
        <source>getWorkOrderDetailsToDisplay(_pinNo : CM_PinNo) : Boolean updating, protected;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 14/05/2018	jlgdap1		Initial creation TFS 38501 PEL1 Work Order Changes
// 22/05/2018	jlgdap1		TFS 38501 PEL1 Work Order Changes - new parameter for pickerWindowForObject
// 19/06/2018	jlgdap1		TFS 39316 Work order Gate PIN 1090
// 07/07/2018   cnwma1		Bug 39525: 1090 on road gate form
//1/04/2019 	JLGNS1	Bug 44134: PEL1 - Container Services - Release Extension (Release Work Order drop down not responding)
//23/06/2023	navkc1	CR 58406 Task 58408: Jade - Release Request All Tracked Items
// 31 Aug 2023 	navhl20 	Bug 60183: FR | 53429 - VBS changes - Quantity assigned in the VBS is not remembered during Road Gate announcement//31.8.2023 navhl20 #60183
// 11 Apr 2025	navah1		Bug 34615: MTN | Getting 1090 in Road Gate When creating Road Job ( For Workorder which gets unapproved and approved again)
vars
	wo : CM_WorkOrderTI;
	woDtl, workOrderDetail : CM_WorkOrderDtl;
	booking : CM_BookingRef;
	release : CM_BulkRelease;
	ti : CM_TrackedItem;
	pos : Integer;
	objArr : ObjectArray;
	obj, selectedObject : Object;
	result : Integer;
	commodity : CM_Commodity;
	pickerShown : Boolean;
	reserveDetail : CM_ReserveDetail;
	itemIDs : StringArray;
	msg : String;

begin
	create objArr transient;
	create itemIDs transient; 
	wo := _pinNo.allItems.first.CM_WorkOrderTI;
	
	//11 Jun 2018	NDL	TFS 38795
	if wo &lt;&gt; null and wo.pinHasExpired then
		msg := app.getErrorString1(Work_order_pin_expired, wo.id);
		app.msgBox( msg, app.getErrorString(Error), MsgBox_OK_Only );
		return true;
	endif;
	
	foreach woDtl in wo.allWoDtls discreteLock do
		if woDtl.isWorkOrderForReceival then
			booking := woDtl.CM_WodReceive.myBookingRef;
			workOrderDetail := woDtl;
			break;
		elseif woDtl.isWorkOrderForRelease then
			release := woDtl.CM_WodRelease.getMyReleaseRequest();	//Bug 44134
			workOrderDetail := woDtl;
			break;
		elseif woDtl.isWorkOrderForReleaseExtension then	//12 Mar 2019	NDL	TFS 43405
			release := woDtl.CM_WodReleaseExtension.getMyReleaseRequest;
			workOrderDetail := woDtl.CM_WodReleaseExtension.myReleaseWorkOrder;
			break;
		elseif woDtl.isWorkOrderForExportReturn then //07.07.2018 cnwma1 TFS #39525
			ti := woDtl.CM_WodExportReturn.allAvailableTIs.first.CM_TrackedItem;
			release := woDtl.CM_WodExportReturn.getMyReleaseRequest;
			workOrderDetail := woDtl;
			break;
		endif;
	endforeach;
	
	if booking &lt;&gt; null then
		booking.getPreNotesForWorkOrder(wo, objArr);
		foreach obj in objArr do
			ti := obj.CM_TrackedItem;
			itemIDs.add(ti.id);
		endforeach;
		ti := objArr.first.CM_TrackedItem; 
		if ti = null then			//11.04.2025 navah1 #34615 
			app.raiseCMException1(There_preno_assoc_with_this_wo, wo.id, null, null);  
			return true;
		endif;
	elseif release &lt;&gt; null then
		release.getReserveDetailsForWorkOrder(wo, objArr);
		//self.myAssistant.pickerWindowForObject(objArr, false, selectedObject, self);
		self.myAssistant.pickerWindowForObject(objArr, false, selectedObject, self, true);
		if selectedObject = null then
			return true;
		endif;
		reserveDetail := selectedObject.CM_ReserveDetail;
		//ti := reserveDetail.allTrackedItems.first;
		ti := reserveDetail.getFirstTI(false); //23/06/2023	navkc1	CR 58406 Task 58408
	else
		return true;							//10.07.2018 TFS #39525
	endif;
	
	if ti &lt;&gt; null then								// TFS 39316
		commodity := ti.getCommodityObject;
	endif;											// TFS 39316
	if self.myRealVVR &lt;&gt; null or self.isOKToProceed() then
		if ti.state = TI_STATE_NORMAL then
			// release
			if commodity &lt;&gt; null then
				if commodity.isEmpty then
					self.myAssistant.showCargoReleaseFromFlexiGate(self, false, CMUI_FlexiCargoForm.FLEXI_CARGO_EMPTY, 2, 200, null, false, null, release, reserveDetail, ti, null, null, self.myRealVVR, wo, null);	//31.8.2023 navhl20 #60183
				else
					self.myAssistant.showCargoReleaseFromFlexiGate(self, false, CMUI_FlexiCargoForm.FLEXI_CARGO_FULL, 2, 200, null, false, null, release, reserveDetail, ti, null, null, self.myRealVVR, wo, null);		//31.8.2023 navhl20 #60183
				endif;
			else
				self.myAssistant.showCargoReleaseFromFlexiGate(self, false, CMUI_FlexiCargoForm.FLEXI_CARGO_GENERAL, 2, 200, null, false, null, release, reserveDetail, ti, null, null, self.myRealVVR, wo, null);		//31.8.2023 navhl20 #60183
			endif;
		elseif ti.state = TI_STATE_NOTIFIED then 
			// receival
			if ti.cargoType = TI_CargoType_Container then
				if commodity &lt;&gt; null then
					if commodity.isEmpty then
						self.myAssistant.showCargoReceiptFromFlexiGate(self, false, CMUI_FlexiCargoForm.FLEXI_CARGO_EMPTY, 3, 160, null, false, null, null, null, ti, ti.myBookingRefItem, null, self.myRealVVR, itemIDs);
					else
						self.myAssistant.showCargoReceiptFromFlexiGate(self, false, CMUI_FlexiCargoForm.FLEXI_CARGO_FULL, 3, 160, null, false, null, null, null, ti, ti.myBookingRefItem, null, self.myRealVVR, itemIDs);
					endif;
				else
					self.myAssistant.showCargoReceiptFromFlexiGate(self, false, CMUI_FlexiCargoForm.FLEXI_CARGO_EMPTY, 3, 160, null, false, null, null, null, ti, ti.myBookingRefItem, null, self.myRealVVR, itemIDs);
				endif;
			else
				self.myAssistant.showCargoReceiptFromFlexiGate(self, false, CMUI_FlexiCargoForm.FLEXI_CARGO_GENERAL, 3, 160, null, false, null, null, null, ti, ti.myBookingRefItem, null, self.myRealVVR, itemIDs);
			endif;
		endif;
	endif;
	self.setTxtPinToNullOrVbsId();
	self.showAdditionalRemarks(ti.remarksAdditional1, ti.remarksAdditional2);
	return true;
epilog
	delete objArr;
	delete itemIDs;
end;</source>
        <access>protected</access>
        <Parameter name="_pinNo" type="CM_PinNo"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getXMLSettingsForSave" id="d95f9c57-3859-46f2-b993-09b636bed141">
        <updating/>
        <source>getXMLSettingsForSave(): String updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
24 November 2009	cnwjk3	PAR 21670
*/

vars
	xmlStr							: String;
	gate 								: CM_Gate;	
begin
	xmlStr := inheritMethod();
	
	gate := self.cmbGate.listObject.CM_Gate;
	if gate &lt;&gt; null then
		xmlStr := xmlStr &amp; formatAsXML('GateName', gate.name);
	endif;
	//20 Sep 2011	NDL	Par 24455
	xmlStr := xmlStr &amp; global.formatAsXML(XML_ReleaseRatio, self.splReleases.leftToRightRatio.String);
	xmlStr := xmlStr &amp; self.tblBulkRelease.getXmlStrForColumns(true);
	xmlStr := xmlStr &amp; self.tblTransfers.getXmlStrForColumns(true);
	xmlStr := xmlStr &amp; self.xmlForReceiveTrailer;		//17 Jan 2019	NDL	TFS 40479
	
	xmlStr := xmlStr &amp; global.formatAsXML( self.optChassisRelID.name, self.optChassisRelID.value.String );	//15 Jun 2021	NDL	TFS 51331
	xmlStr := xmlStr &amp; global.formatAsXML( self.optChassisRelTyp.name, self.optChassisRelTyp.value.String );	//15 Jun 2021	NDL	TFS 51331
	
	return xmlStr;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getXMLSettingsForSetup" id="3621b741-14e3-4c78-ab9e-773f7a8d7af0">
        <updating/>
        <source>getXMLSettingsForSetup()updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
24 November 2009	cnwjk3	PAR 21670
*/

vars
	userWindow	: CM_UserWindow;
	gate		: CM_Gate;
	gateName,
	theXML		: String;
	theXMLValue : String;
	
	
begin
	
	userWindow := app.getUserWindow(self.name, false);
	
	if userWindow = null then
		return;
	endif;

	theXML := userWindow.xmlInfo;
	gateName := theXML.cnEcGetTagValueOfName('GateName');
 	if gateName &lt;&gt; null then
 		gate := self.myTerminal.allGates[gateName];
		self.cmbGate.listObject := gate;
 	endif;	
	//20 Sep 2011	NDL	Par 24455
	theXMLValue := theXML.cnEcGetTagValueOfName(XML_ReleaseRatio);
	if theXMLValue &lt;&gt; null then
		self.splReleases.setLeftToRightRatio( theXMLValue.Integer );
		self.splReleases.cnEcResizeContents();
	endif;
	
	self.setTrailerReceiveDefs( theXML, true );	//17 Jan 2019	TFS 42951 makes it store the part of the XML it needs

	if not self.oneTimeDefaultsApplied then	//24 Jun 2021	NDL	TFS 51331
		self.oneTimeDefaultsApplied := true;	//24 Jun 2021	NDL	TFS 51331
		//17 Jun 2021	NDL	TFS 51331
		theXMLValue := theXML.cnEcGetTagValueOfName(self.optChassisRelID.name);
		if theXMLValue &lt;&gt; null then
			self.optChassisRelID.value := theXMLValue.Boolean;
		endif;
		
		//17 Jun 2021	NDL	TFS 51331
		theXMLValue := theXML.cnEcGetTagValueOfName(self.optChassisRelTyp.name);
		if theXMLValue &lt;&gt; null then
			self.optChassisRelTyp.value := theXMLValue.Boolean;
		endif;
		
		//17 Jun 2021	NDL	TFS 51331
		if self.optChassisRelID.value then
			self.doChangeChassisReleaseBy(true);
		elseif self.optChassisRelTyp.value then
			self.doChangeChassisReleaseBy(false);
		endif;
	endif;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="handleNotifications" id="ef94ccd5-7967-4959-bb0d-1baa76f9f668">
        <updating/>
        <source>handleNotifications(eventType: Integer; theObject: Object; eventTag: Integer; userInfo: Any) updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
11 Apr 2022		navhl20	Initial creation   TFS 52777
12 Jul 2022		navmd1	TFS 52777 Tidy up/review code
21 Feb 2025		naviv1	JIRA-29374- EUP | Transaction Instrumentation - Gate
07 Mar 2025		navhn30 Story MTN-34261: CUX | Update Road Gate Vehicle list when new vehicle is added
28 Mar 2025		navhn30	Bug MTN-34499: CUX | Issues on Road Gate Form when new Vehicle and Driver created
25 June 2025    navbk1  Bug MTN-34959: CUX - Truck Registration Details gets updated Across Multiple Clients in Road Gate Screen
14 Jan 2026 	navhl20 Bug MTN-35897: PEN - System Locking Errors (1000010 - Unknown message)
15 Jan 2026		navma1	MTN-36923 PEN-Latency in PENPJMT - Latency only resolved by reboot
*/

vars
	invalid				: Boolean;
	invalidVehicle		: Boolean;
	gateScanRecord		: CM_GenericGateScanRecord;
	vehicle				: CM_Vehicle;
	
begin
	if theObject = null then
		return;
	endif;
	
	

	if theObject.isKindOf(CM_GenericGateScanRecord) then
		on Exception do app.handleDeletedObject( exception, gateScanRecord, invalid );
		gateScanRecord := theObject.CM_GenericGateScanRecord;
		gateScanRecord.edition;
		
		// If the note is not for our terminal or device, then ignore it
		if invalid or gateScanRecord.myTerminal &lt;&gt; self.myTerminal or self.myAssistant.allAssociatedDevices[gateScanRecord.deviceId] = null then
			return;
		endif;

		if eventType = Object_Create_Event or eventType = Object_Update_Event then
			if not self.clearingForm then
				self.myAssistant.populateScanData(true, false, self.detailsChangedVehicle, self.txtRegno, self.txtDriverCode, self.txtDriverName,self.txtChassisIDIn, null, self.cmbRFID, self.cmbCarrier, null, gateScanRecord);
			endif;
		endif;
	//07.03.25	navhn30	MTN-34261	start
	elseif theObject.isKindOf(CM_Vehicle) then
		on Exception do app.handleDeletedObject(exception, vehicle, invalidVehicle);
		vehicle := theObject.CM_Vehicle;
		
		vehicle.edition;
		if invalidVehicle then					//15.01.2026 navma1 MTN-36923
			return;
		endif;
		if eventType = Object_Create_Event then
			
			if self.cmbRegNo.visible then		//15.01.2026 navma1 MTN-36923
				if invalid or vehicle.myTerminal &lt;&gt; self.myTerminal or self.myTerminal.vehicles.getAtKey(vehicle.regNumber, vehicle.state) = null then
					return;
				endif;

				if not self.clearingForm then
					self.cmbRegNo.addItemObject(vehicle.regNumber, vehicle);	  //28.03.25	navhn30	  MTN-34499	
				endif;
			endif;
		else
			if not self.clearingForm then
				if self.cmbRegNo.visible then									//15.01.2026 navma1 MTN-36923
					if self.cmbRegNo.listObject &lt;&gt; null then														//25.06.25 navbk1 #34959		
						self.myAssistant.comboBoxVehicleObj(self.cmbRegNo, null, vehicle);
						self.cmbDriver.listCollection(vehicle.allDrivers,true,ComboBox.DisplayCollection_Forward);	//28.03.25	navhn30	  MTN-34499
						self.cmbCarrier.cnEcSetObjectIndex(vehicle.carrier);
					else																							//25.06.25 navbk1 #34959
						self.myAssistant.comboBoxVehicleObj(self.cmbRegNo, null, null);								//25.06.25 navbk1 #34959
					endif;
				endif;
				if eventType = Object_Delete_Event then	
					self.cmbCarrier.cnEcSetObjectIndex(null);
				endif;
			endif;
		endif;
	endif;
	//07.03.25	navhn30	MTN-34261	end
epilog
	
end;</source>
        <access>protected</access>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
        <Parameter name="userInfo" type="Any"/>
    </JadeMethod>
    <JadeMethod name="hasBooking" id="062a4615-b44c-49c9-8405-c1578de06626">
        <source>hasBooking() : Boolean;
/*****************************************************
Author		: jlika1 (Karen Alexander)
Date		: 27 February 2023
TFS#		: 56731
Function	:

*** Changes ***
Date			Name		TFS#		Description

****************************************************/

vars	
	booking : CMIF_1StopBookingData;
begin
	foreach booking in self.all1StopVBSDetails do
		if booking.id &lt;&gt; null then
			return true;
		endif;
	endforeach;
	
	return false;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
