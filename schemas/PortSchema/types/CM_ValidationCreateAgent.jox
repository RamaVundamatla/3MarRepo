    <JadeMethod name="valO2Reading" id="473d8860-04f3-4b49-9c7c-b9ca08a63a4c">
        <source>valO2Reading(_o2Params : CMIF_O2Reading);
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 16/12/2025	navdap1		Initial creation MTN-36569 CPL Reefer Runner Integration
//
vars

begin
	if _o2Params.myTrackedItem = null then
		app.raiseCMException2(MethodWithNullParam, method.name, 'tempParams.myContainer', 'myContainer', null);
		return;
	endif;

	if not _o2Params.dateTime.isValid then
		app.raiseCMException2(ERR_INVALID_VALUE, "date/time", "Make sure the date and time fields are valid.", 'dateTime',null);
		return;
	endif;
	
	if not _o2Params.dateTime.date &lt;= app.actualTimeServer().date then
		app.raiseCMException2(ERR_INVALID_VALUE, "date", "You cannot add a temperature reading later than today.", 'dateTime',null);
		return;
	endif;
epilog

end;</source>
        <Parameter name="_o2Params" type="CMIF_O2Reading"/>
    </JadeMethod>
