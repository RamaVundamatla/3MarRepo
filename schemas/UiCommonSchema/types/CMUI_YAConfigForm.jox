    <JadeMethod name="getCriteriaTypeString" id="6c827157-5665-4364-88f5-51d40c222548">
        <source>getCriteriaTypeString( _array : CM_YACriteriaTypeArray ) : String;

/*

Purpose:			

Parameters:			

Return Value:	Comma separate list of Criteria Types.


Date			Who		Reason
30 July 2008	consw1	Initial creation

*/

vars
	ct : CM_YACriteriaType;
	str : String;
	
begin
	foreach ct in _array do
		if str &lt;&gt; null then
			str := str &amp; ", ";
		endif;
		str := str &amp; ct.description;
	endforeach;
	
	return str;
	
epilog

end;</source>
        <Parameter name="_array" type="CM_YACriteriaTypeArray"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getIMEXCriteriaString" id="9d5481a8-4519-49de-8345-6d0979895ba3">
        <source>getIMEXCriteriaString(_imexStatus : Integer) : String;

/*

Purpose:			

Parameters:			

Return Value:		


Date			Who		Reason
30 July 2008	consw1	Initial creation

*/

vars
	imexConfig : CM_YAIMEXConfig;
	opDisplay : String;
	groupLabelDisplay : String;

begin
	imexConfig := self.getRealYAConfig.allYAIMEXConfigs[_imexStatus];

	if imexConfig = null then
		return "Not defined";
	endif;
	
	opDisplay := self.getCriteriaTypeString(imexConfig.allOpCriteria);
	groupLabelDisplay := self.getCriteriaTypeString(imexConfig.allGroupLabelCriteria);
	
	if opDisplay = null and groupLabelDisplay = null then
		return "Not defined";
	endif;

	return "Criteria: " &amp; opDisplay &amp; CrLf &amp; "Group: " &amp; groupLabelDisplay;
	
epilog

end;</source>
        <Parameter name="_imexStatus" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
