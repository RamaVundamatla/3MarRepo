	qProp.setPerformanceRating( CM_QueryProperty.Simple );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add(qProp);

	create qProp as CM_QDateProperty persistent;
	qProp.set('Transaction Date', CM_TITransaction::dateTime.name, self.className);
	qProp.setPerformanceRating( CM_QueryProperty.CollKey );	// Simple	= '1', CollKey	= '2', Complex	= '3'
