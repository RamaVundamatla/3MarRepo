    <JadeMethod name="setDirectory" id="c601451b-b615-42da-9db8-2c56559cffb4">
        <source>setDirectory(_cmif : CMIF_BGPManagerChildren input) : Boolean protected;

// cnwdvb1 11 December 2002 
vars
	classObj	: Object;
	
begin
	_cmif.dirPath			:=	fieldDirPath.getString();
	_cmif.dirPathProcessed	:=	fieldDirProcess.getString();
	_cmif.timerInterval		:=	fieldTimInterval.getInteger();
	_cmif.mask				:=	fieldMask.getString();
	_cmif.myTerminal		:=	fieldTerminal.getObject().CM_Terminal;
	
//	_cmif.dirPath			:= self.tblAddEdit.getValueByName(ETRow_DirectoryPath).String;	
//	_cmif.dirPathProcessed	:= self.tblAddEdit.getValueByName(ETRow_DirectoryPathProcessed).String;
//	_cmif.allClasses.clear();
	
	_cmif.allClasses.clear();
	
	foreach classObj in self.lstTable.allSelectedObjects do
		_cmif.allClasses.add(classObj.Class.name);
	endforeach;
	
	_cmif.allRFIDTagReaders.clear();
	
	foreach classObj in self.lstTagReaders.allSelectedObjects do
		_cmif.allRFIDTagReaders.add(classObj.CM_RFIDTagReader);
	endforeach;
	
//	_cmif.timerInterval		:= self.tblAddEdit.getValueByName(ETRow_TimerInterval).Integer;	
//	_cmif.mask				:= self.tblAddEdit.getValueByName(ETRow_Mask).String;	
//	_cmif.myTerminal		:= self.cmbTerminal.listObject.CM_Terminal;
	
	if _cmif.dirPath = null then
		app.msgBox('You must specify a directory path','Error',MsgBox_OK_Only);
		return false;
	endif;
	
	if _cmif.dirPathProcessed = null then
		app.msgBox('You must specify a processed file(s) directory path','Error',MsgBox_OK_Only);
		return false;
	endif;
	
	if _cmif.timerInterval = null then
		app.msgBox('You must specify a timer Interval','Error',MsgBox_OK_Only);
		return false;
	endif;
	
	if _cmif.myTerminal = null then
		app.msgBox('You must specify a terminal','Error',MsgBox_OK_Only);
		return false;
	endif;
	
	if _cmif.mask = null then
		_cmif.mask := '*.*';
	endif;
	
	return true;	
end;</source>
        <access>protected</access>
        <Parameter name="_cmif" type="CMIF_BGPManagerChildren" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setExtWebService" id="5cac00e2-a843-4614-b979-1562ef2a6ebf">
        <source>setExtWebService(_cmif : CMIF_BGPManagerChildren input) : Boolean  protected;
//
// 11 June 2018	jlgrs1	TFS 39013 (37190) Pelindo BGP Web Service
//
vars

begin
	_cmif.myExtWebService := self.fieldExtWebSrvs.getObject().CM_ExternalWebServiceDef;
	//27 Oct 2018 jlger1 tfs 41625 -  have tasks for each terminal
	_cmif.myTerminal :=self.fieldTerminal.getObject.CM_Terminal;
	
	return true;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_cmif" type="CMIF_BGPManagerChildren" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setFieldsFromController" id="03422c30-a2dc-4125-817a-6ca977da994c">
        <updating/>
        <source>setFieldsFromController(_bgpController : BGP_Controller input) protected, updating;
//
// cnwdvb1 12 November 2002
//
// 21 June 2018	jlgrs1	TFS 39013 (37190) Pelindo BGP Web Service
// 11 Sep 2025	navnk30 JIRA 35718: 6 - YARA | Create a BGP to create a release request from the Order Create/Order Update XML received
//
vars
	proxyObj		: CMIF_BGPManagerChildren;
	classCollObj	: ClassColl;
	className		: String;
	classObj		: Class;
	invalidObj : Boolean;
begin
	if _bgpController.isEditable then
		create classCollObj transient;
		self.loadCombos();
		create proxyObj transient;
		proxyObj.loadFromBGPObject(_bgpController);
		self.updateAutoWarningItemsList(proxyObj);
		
		foreach className in proxyObj.allClasses do
			classObj	:=	_bgpController.getClass(className);
			
			if classObj &lt;&gt; null then
				classCollObj.add(classObj);
			endif;
		endforeach;
		
		self.fieldTcpPort.setValue(proxyObj.tcpIpPort);
		self.fieldNoWorkers.setValue(proxyObj.numberOfWorkers);
		self.fieldLogLevel.setValue(proxyObj.loggingLevel);
		self.fieldWorkerType.setValue(proxyObj.workerClass);
		self.fieldDirPath.setValue(proxyObj.dirPath);
		self.fieldTimInterval.setValue(proxyObj.timerInterval);
		self.fieldMask.setValue(proxyObj.mask);
		self.fieldReqHeading.setValue(proxyObj.requestHeading);
		self.fieldDirProcess.setValue(proxyObj.dirPathProcessed);
		self.fieldServerName.setValue(proxyObj.serverName);
		self.fieldWorkerType2.setValue(proxyObj.workerClass);
		self.fieldTcpAddress.setValue(proxyObj.tcpIpInterfaceAddress);
		self.fieldIsLogTrans.setValue(proxyObj.isLoggingTransactions);
		self.fieldIsDoingKPI.setValue(proxyObj.isDoingKPI);
		self.fieldCellAddress.setValue(proxyObj.cellAddress);
		self.fieldCellNumbers.setValue(proxyObj.cellNumbers);
		self.fieldDaysNotice.setValue(proxyObj.numDaysNotice);	//02 Nov 2010	NDL	Par 25530
		self.fieldDaysNotice.setMaxLength(3);
		self.fieldTempFileLoc.setValue(proxyObj.tempFileLocation); //PAR22336 - cnwsh3 27/07/2010 - Temp directory for managed service systems
		
		self.fieldIsServerEx.setValue(proxyObj.useServerExecution);
		self.fieldCommitFreq.setValue(proxyObj.commitFrequency);
		self.fieldRetainTrack.setValue(proxyObj.retainTrackingDays);
		self.fieldIsDebug.setValue(proxyObj.debug);	//cnwrs1 par 25828 15 Feb 2011
		self.fieldMaxTimeRun.setValue(proxyObj.maxTimeForRemoveToRunInSecs);	//cnwrs1 par 25828 15 feb 2011
		if proxyObj.myUser &lt;&gt; null then
			self.cmbUser.setObject(proxyObj.myUser);
		endif;
		
		if proxyObj.myTerminal &lt;&gt; null then
			self.fieldTerminal.setForText(proxyObj.myTerminal.code);
			self.fieldTerminal.setForObject(proxyObj.myTerminal);
			self.fieldTerminal.change(fieldTerminal);
		endif;
		
		if proxyObj.myPDFPrinter &lt;&gt; null then
			self.fieldPDFPrinter.setForText(proxyObj.myPDFPrinter.logicalPrinterName);
		endif;
		if proxyObj.myExtWebService &lt;&gt; null then
			on Exception do app.handleDeletedObject(exception, proxyObj.myExtWebService, invalidObj);
			self.fieldExtWebSrvs.setForText(proxyObj.myExtWebService.name);
			on Exception do null;
			self.fieldTerminal.enabled := proxyObj.myExtWebService.class.name &lt;&gt; CM_AgGatewayServiceDef.name;	//10.10.2025 navnk30 MTN-35718
		endif;
		
		self.lstTable.setSelected(classCollObj);
		self.lstTagReaders.setSelected(proxyObj.allRFIDTagReaders);
		self.lstEmailAddress.setSelected(proxyObj.allSelectedEmailAddresses);//02 Nov 2010	NDl	Par 25530
		self.tblWarnList.setSelected(proxyObj.allWarningRequests);
	endif;
epilog
	delete proxyObj;
	delete classCollObj;
end;</source>
        <access>protected</access>
        <Parameter name="_bgpController" type="BGP_Controller" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setGeneric" id="d74e5245-30d8-4874-a9cc-9e580abfade4">
        <source>setGeneric(_cmif : CMIF_BGPManagerChildren input) : Boolean protected;

// cnwdvb1 12 December 2002 
// 28 Sep 2016	cnwrs1	TFS 2756 PAR38267 allow Cams to run per terminal

vars
	object	: Object;

begin
	_cmif.allClasses.clear();
	
	foreach object in self.lstTable.allSelectedObjects do
		_cmif.allClasses.add(object.Class.name);
		if object = BGP_CamsRequest then
			_cmif.myTerminal := self.fieldTerminal.getObject().CM_Terminal;
		endif;
	endforeach;
	
	return true;
end;</source>
