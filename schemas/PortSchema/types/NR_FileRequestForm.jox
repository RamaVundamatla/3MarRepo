    <JadeMethod name="unload" id="d1e4030a-32ff-489e-b4fd-90a7e61b569e">
        <controlMethod name="Form::unload"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>unload() updating;
// ---------------------------------------------------------------------------
// Created:     04 July 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin
	self.activityCaptureEnd();
	self.clearTblResults();		// Clear any CM_Associations that might still be in the results table

	if self.myNodeFileRequest &lt;&gt; null then
		beginTransaction;
		delete self.myNodeFileRequest;
		self.allFileNodes.purge;
		commitTransaction;
	endif;
	if self.myNodeFormCountRequest &lt;&gt; null then
		beginTransaction;
		delete self.myNodeFormCountRequest;
		commitTransaction;
	endif;
	if self.myCountTransientsRequest &lt;&gt; null then
		beginTransaction;
		delete self.myCountTransientsRequest;
		commitTransaction;
	endif;
	if self.myParserAgent &lt;&gt; null then
		delete self.myParserAgent;
	endif;

epilog

	self.endNotificationForSubscriber(self);
end;</source>
    </JadeMethod>
    <JadeMethod name="userNotify" id="d8437b0f-d75b-47a8-ac47-101722c3a3db">
        <controlMethod name="Form::userNotify"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>userNotify(eventType: Integer; theObject: Object; eventTag: Integer; userInfo: Any) updating;
// ---------------------------------------------------------------------------
// Created:     04 July 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	theRequest	: NR_NodeFileRequest;

begin

	if eventType = NR_NodeFileRequest.NR_NodeRequestLogEntryEvent then
		tblLogEntries.addItem(userInfo.String);
		return;
	endif;
	
	if eventType = NR_NodeFileRequest.NR_NodeRequestCompleteEvent then
		if NR_NodeFileRequest.hasInstance(userInfo.Object) then
			theRequest := userInfo.NR_NodeFileRequest;
			self.handleFileRequestCompletion(theRequest);
		elseif NR_CountTransients.hasInstance(userInfo.Object) then
			self.handleTransChkReqCompletion(userInfo.NR_CountTransients);
		elseif NR_CountForms.hasInstance(userInfo.Object) then
			self.handleCountFormsReqCompletion(userInfo.NR_CountForms);
		endif;
		return;
	elseif eventType &gt;= EVENT_ACTCAP_PROFILE and eventType &lt;= EVENT_ACTCAP_MAX then
		self.handleActivityNotification(eventType, theObject, eventTag, userInfo);
	endif;

end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
        <Parameter name="userInfo" type="Any"/>
    </JadeMethod>
</GUIClass>
