    <JadeMethod name="tblWorkEntries_mouseDown" id="6674c186-0c7d-4496-90e8-036681960442">
        <controlMethod name="CM_DataTable::mouseDown"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblWorkEntries_mouseDown(table: Table input; button: Integer; shift: Integer; x: Real; y: Real) updating;
//--------------------------------------------------------------
//Created: 18 March 2003 By: cnwgd1
//--------------------------------------------------------------
vars

begin

	// Move to rowColumnChg
	if button = Window.MouseButton_Left then
		self.origXPos := x;
		self.origYPos := y;
	endif;
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
