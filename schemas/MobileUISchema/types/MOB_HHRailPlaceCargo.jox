    <JadeMethod name="checkIsotype" id="f233aef0-5766-4514-89ef-22e954223c0b">
        <source>checkIsotype( _ti : CM_TrackedItem io ):Integer;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
26 August 2010	cnwndl1	Initial creation

*/

vars

	isoTypeStr : String;
	isoType : CM_ISOType;
	mess : String;
	result : Integer;
	updated : Boolean;

begin

	// check for an isotype change.
	isoTypeStr := self.txtIsoType.text.toUpper.trimBlanks;
	if _ti.isKindOf(CM_Generator) then
		return IDOK;
	endif;
	
	if isoTypeStr &lt;&gt; null and _ti.getISOType &lt;&gt; isoTypeStr then
		// need to change isotype...
		isoType := app.myRoot.allISOTypes[isoTypeStr];
		if isoType = null then
			app.mousePointer :=	Idle;
			mess := app.getErrorString3(ERR_INVALID_ISOTYPE, isoTypeStr, null, _ti.id);
			self.msgBox( mess, app.getErrorString(Error) , MsgBox_OK_Only, true);
			return 1;
		endif;
		
		if isoType &lt;&gt; null then
			result := self.doIsoTypeChange( isoType,	//_newIsoType : CM_ISOType;
											_ti,	//_realTrackedItem : CM_TrackedItem io;
											updated	//_updated : Boolean output
											);
			if result &lt;&gt; IDOK then
				return 1;
			endif;
		endif;
		
	endif;
	
	return IDOK;

epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem" usage="io"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="clickBtnCargoChecks" id="591fd3a9-a87c-407c-b864-19304efb3ece">
        <updating/>
        <source>clickBtnCargoChecks() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
19 August 2010	cnwndl1	Initial creation	Par 25215

*/

vars

	cargoCheck : CM_CargoCheck;
	ti : CM_TrackedItem;
	result : Integer;
	state : Integer;
	
begin

	cargoCheck := self.getCargoChecks();
	if cargoCheck = null then
		return;
	endif;
	
	if self.myMobileGenericAgent.inward then
		state := self.myMobileGenericAgent.RailReceipt;
	else
		state := self.myMobileGenericAgent.RailRelease;
	endif;
	
	ti := self.myMobileGenericAgent.myNextTiToAction;
	
	if ti = null then
		// No ti, have to create one.
		ti := self.createNewTrackedItem();
		self.myMobileGenericAgent.setMyNextTiToAction(ti);
		
	else
		result := self.checkIsotype( ti );
		if result &lt;&gt; IDOK then
			return;
		endif;
			
	endif;
	
	app.mousePointer :=	Busy;
	if CM_TrackedItem.hasInstance( ti ) then
		self.myMobileGenericAgent.setChecksState(state);
		self.myMobileGenericAgent.setDisplayIdOnCheckForm(true);
		self.gotoForm( MOB_HHGateCheckCargo, false );	
	endif;

epilog

	app.mousePointer :=	Idle;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="clickBtnConfirm" id="7924cc68-c5c5-4c68-8fa5-b197a9513d81">
        <updating/>
        <source>clickBtnConfirm() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
23 August 2010	cnwndl1	Initial creation	Par 25215

*/

vars

	ti : CM_TrackedItem;
	isoType : CM_ISOType;
	result : Integer;
	cargoCheckConstant : Integer;
	checksSubCargo : CM_TrackedItem;
	
begin

	ti := self.myMobileGenericAgent.myNextTiToAction;
	
	if ti = null then
		// No ti, have to create one.
		ti := self.createNewTrackedItem();
		self.myMobileGenericAgent.setMyNextTiToAction(ti);
		
	else
		result := self.checkIsotype( ti );
		if result &lt;&gt; IDOK then
			return;
		endif;
		
	endif;
	app.mousePointer :=	Busy;
	//need to do cargo checks if any outstanding...
	if self.myMobileGenericAgent.inward then
		cargoCheckConstant := CARGO_CHECK_CONTEXT_RAIL_REC;
	else
		cargoCheckConstant := CARGO_CHECK_CONTEXT_RAIL_REL;
	endif;
	
	if self.myMobileGenericAgent.isWaitingOnRequiredChecks(cargoCheckConstant, ti, checksSubCargo) &lt;&gt; null then
		clickBtnCargoChecks();
		return;
	endif;
	
	//record cargo as confirmed here.... 
	self.myMobileGenericAgent.addConfirmedTi( ti );
	
	
	// don't clear the agents wagon, it is needed when returning to the wagon form.
	self.doBackButtonClick();
	

epilog

	app.mousePointer :=	Idle;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="clickBtnRemoveCargo" id="841333d8-0e8a-4770-b9c3-20d5435c8aaf">
        <updating/>
        <source>clickBtnRemoveCargo() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
19 August 2010	cnwndl1	Initial creation	Par 25215

*/

vars

	ti : CM_TrackedItem;
	locCont : CM_LocationsController;
	wagon : CM_Wagon;
	proxyWagon : CM_Wagon;
	rake : CM_RailLine;
	rakePos : Integer;
	wagonUpdateCtrl : CMIF_WagonUpdateController;
	mess : String;
	
begin

	app.mousePointer :=	Busy;

	ti := self.myMobileGenericAgent.myNextTiToAction;

	if ti = null then
		return;
	endif;
	
	locCont := ti.myPrimaryActualLocation;
	if locCont = null or not locCont.isWagon then
		return;
	endif;
	
	wagon := locCont.CM_WagonController.myWagon;
	
	if wagon = null then
		return;
	endif;
	
	if wagon.confirmedOutwards then
		app.mousePointer :=	Idle;
		mess := app.getErrorString2( ERR_TI_WAGON_CONF_OUT, ti.id, wagon.id);
		self.msgBox( mess, app.getErrorString(Error) , MsgBox_OK_Only, true);
		return;
	endif;
	
	proxyWagon := app.createUpdateProxy( wagon ).CM_Wagon;
	
	create wagonUpdateCtrl transient;
	rake := self.myMobileGenericAgent.myCurrentRailLine;
	if rake &lt;&gt; null then
		rakePos := rake.allWagons.indexOf(wagon);
	endif;
	wagonUpdateCtrl.setBasicDetails(	CMIF_WagonUpdateController.Mode_Update,	//_mode : Integer;
										rake,	//_rake : CM_RailLine;
										wagon.myTrainInwards,	//_train : CM_Train;
										rakePos,	//_wagonPosition : Integer
										true//_trainMode : Boolean;
										);
										
	wagonUpdateCtrl.populateFromExistingWagonAddTi( wagon, null, 0 );
	wagonUpdateCtrl.removeTrackedItem(ti, wagon);
	
	wagonUpdateCtrl.expectedEditionWagon := wagon.edition;
	wagonUpdateCtrl.myProxyWagon := proxyWagon;
	
	app.mousePointer :=	Idle;
	if self.msgBox(app.getErrorString2(CONFIRM_REMOVE, ti.id, wagon.id),app.getErrorString(AreYouSure), MsgBox_Yes_No, false) &lt;&gt; MsgBox_Return_Yes then
		return;
	endif;
	app.mousePointer :=	Busy;
	
	app.myPassport.clearErrorsWarnings;
	app.myPassport.setWarningsIgnored(true);
	app.myTrxUA.trxUpdateWagonFromCMIF(wagonUpdateCtrl, false, app.myPassport);

	if app.myPassport.noErrors then
		self.myMobileGenericAgent.setMyNextTiToAction(null);
		if self.myMobileGenericAgent.tiIsConfirmed(ti) then
			self.myMobileGenericAgent.allConfirmedTis.remove(ti);
		endif;
		handleBtnTwo();
		return;
		
	else
		app.mousePointer :=	Idle;
		self.msgBox(app.myPassport.getAllErrorsWarningsAsString, app.getErrorString(Error), MsgBox_OK_Only, true);
		return;
		
	endif;
	

epilog

	delete proxyWagon;
	delete wagonUpdateCtrl;
	app.mousePointer :=	Idle;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="cmbSearchItem_change" id="2798420a-bb53-4f95-94dd-7378ddb44111">
        <controlMethod name="ComboBox::change"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbSearchItem_change(combobox: ComboBox input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 May 2013	cnwndl1	Initial creation

*/

vars
	thePos,
	i 	: Integer;
begin
	thePos:=combobox.text.pos(app.getErrorString(Cargo_ID),1);
	if thePos  &gt; 0 then
		if app.myVMAgent = null then
			combobox.foreColor:=Control.Color_WindowText;
		else
			combobox.foreColor:=app.myVMAgent.getMyScreenMode.screenForeColour;
		endif;
		combobox.text:=combobox.text[1:thePos-1];
		combobox.selStart:=thePos;
	else
		
		if combobox.text = null then
			combobox.foreColor:=self.cmbSearchItem.getSystemColor(Control.Color_3DShadow);
			combobox.text:=app.getErrorString(Cargo_ID);
			
			i:=1;
			while i &lt;= combobox.listCount do
				if  app.myVMAgent = null then
					combobox.foreColor:=Control.Color_WindowText;
				else
					combobox.itemForeColor[i]:=app.myVMAgent.getMyScreenMode.screenForeColour;
				endif;
				i:=i+1;
			endwhile;
		endif;
	endif;
	
	
epilog

end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
    </JadeMethod>
