    <JadeMethod name="addToolbarControls" id="ee9e3678-d4b4-4c72-bce5-1926c79addaa">
        <updating/>
        <source>addToolbarControls() updating, protected;
// ---------------------------------------------------------------------------
// Created:		09 November 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	frm				: CMUI_Toolbar;
begin	
	frm := self.frmToolbar;
	frm.addButton(self.btnShowSearcher, CMUI_Toolbar.Control_Alignment_Left);
	frm.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	frm.addButton(self.btnPrint, CMUI_Toolbar.Control_Alignment_Left);
	frm.addButton(self.btnSaveBase, CMUI_Toolbar.Control_Alignment_Left);
	frm.addButton(self.btnLocateTI, CMUI_Toolbar.Control_Alignment_Left);
	frm.addButton(self.btnRefresh, CMUI_Toolbar.Control_Alignment_Left);
	frm.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	

	frm.addButton(self.btnExportCSV_SU, CMUI_Toolbar.Control_Alignment_Left);
	frm.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	frm.addFrame(self.frmTBExtras, CMUI_Toolbar.Control_Alignment_Left);
	frm.addButton(self.btnShowKPI, CMUI_Toolbar.Control_Alignment_Left);

	self.btnDelete.bubbleHelp := "Delete Selected Space Utilisation Record";
	frm.addButton(self.btnDelete, CMUI_Toolbar.Control_Alignment_Left); 
	if self.isHazardousLicensed then
		frm.addButton(self.btnHazSet, CMUI_Toolbar.Control_Alignment_Left);
	endif;
	
	inheritMethod();

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="addToolbarControlsQuery" id="5fc7f5d2-a6d3-4c98-b153-818003b6e98f">
        <source>addToolbarControlsQuery() protected;
// ---------------------------------------------------------------------------
// Created:     04 September 2003	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars

	queryToolbar			: CMUI_Toolbar;
begin

	queryToolbar := self.frmQueryToolbar;
	queryToolbar.addButton(self.btnQuery, CMUI_Toolbar.Control_Alignment_Left);
	queryToolbar.addButton(self.btnResetSearch, CMUI_Toolbar.Control_Alignment_Left);
	queryToolbar.addButton(self.btnSelectAll, CMUI_Toolbar.Control_Alignment_Left);
	queryToolbar.addButton(self.btnHideSearcher, CMUI_Toolbar.Control_Alignment_Left);

end;</source>
        <access>protected</access>
    </JadeMethod>
