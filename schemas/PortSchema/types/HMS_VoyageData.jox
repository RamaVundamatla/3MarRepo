    <JadeMethod name="createTransaction" id="3861e553-876f-4c2e-b4d2-5f16c860a73b">
        <source>createTransaction(_type : Integer;
				 _workingVoyage : CMIF_HMS_WorkingVoyage;
				 _pxyVoyageData : HMS_VoyageData;
				 _workingDelay : CMIF_HMS_VoyageDelay;
				 _passport : CM_Passport input);
//-----------------------------------------
//Created: July 2003 By: cnwgd1
//-----------------------------------------
vars
 	cmifTrans : CMIF_HMS_TransactionController;
begin
	// This method creates a cmifTrans for all the changes that take place when the 
	// permanent voyage is added NOTE: A single cmifTrans may cover changes to one or more properties
	create cmifTrans transient;

	// Set general cmifTrans properties and references
	cmifTrans.myHMSVoyageData := self;
	cmifTrans.myWorkingVoyage := _workingVoyage;
	cmifTrans.myProxyHMSObject := _pxyVoyageData;

	if _workingDelay &lt;&gt; null then
		cmifTrans.myWorkingDelay := _workingDelay;
		cmifTrans.myPersistentVoyageDelay := _workingDelay.myPersistentVoyageDelay;
	endif;

	cmifTrans.myTerminal := self.getMyTerminal();
	if cmifTrans.myTerminal = null and
	   _workingVoyage &lt;&gt; null then
		//Must be add mode
		cmifTrans.myTerminal := _workingVoyage.ofTerminal;
	endif;
	cmifTrans.type := _type;
	
	cmifTrans.createTransaction(_passport);

epilog
	delete cmifTrans;
end;</source>
        <Parameter name="_type" type="Integer"/>
        <Parameter name="_workingVoyage" type="CMIF_HMS_WorkingVoyage"/>
        <Parameter name="_pxyVoyageData" type="HMS_VoyageData"/>
        <Parameter name="_workingDelay" type="CMIF_HMS_VoyageDelay"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="delete" id="e7e943af-0519-4835-adfd-ef25e5c8afdf">
        <updating/>
        <source>delete() updating;
// --------------------------------------------------------------------------------
// Created:		13 September 2006 by cnwdad1:2
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	movementObj	: HMS_VoyageMovement;
	
begin
	if self.isTransient() then
		foreach movementObj in self.allVoyageMovements do
			delete movementObj;
		endforeach;
		
		self.allBerthPreferencesArray.purge();
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="getAgentsUsed" id="4d1f91f1-933c-4de2-a8fb-55b15bd0e498">
        <source>getAgentsUsed() : String;
//--------------------------------------------------
// Created:	16 September 2004 By: cnwgd1
//--------------------------------------------------
// 29/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
vars
	agentForMove: CM_ShippingAgent;
	agentsUsed	: String;
	movement	: HMS_VoyageMovement;
begin

	// Check 'Agent' Criteria
	
	foreach movement in self.allVoyageMovements do
		if movement.isAgentDefault
		and movement.myShippingAgent &lt;&gt; null then
	 		agentsUsed	:= agentsUsed &amp; movement.myShippingAgent.description[1:20] &amp; "; ";
	 	else
	 		agentsUsed	:= agentsUsed &amp; "N/A; ";
		endif;
	endforeach;
		
	if agentsUsed.length &gt;1 then
		// Trim last comma and space
	 	agentsUsed	:= agentsUsed[1:(agentsUsed.length - 2)];
	 endif;

	return agentsUsed;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getAllAgentsUsed" id="0505c196-ca15-49ae-91c3-bfb31773410c">
        <source>getAllAgentsUsed() : String;
//--------------------------------------------------
// Created:	16 September 2004 By: cnwgd1
//--------------------------------------------------
vars
	agentForDept,
	agentForArr	: CM_ShippingAgent;
	agentsUsed	: String;
	depMovement,
	arrMovement	: HMS_VoyageMovement;
begin

	arrMovement := self.getMovementForMoveType(HMSMovementTypeArrival);
	depMovement := self.getMovementForMoveType(HMSMovementTypeDeparture);	
	
	if arrMovement &lt;&gt; null then
		agentForArr := arrMovement.myShippingAgent;
	endif;

	if agentForArr &lt;&gt; null then
		agentsUsed := agentForArr.description;
	endif;

	if depMovement &lt;&gt; null then
		agentForDept := depMovement.myShippingAgent;
	endif;
	
	if agentForDept &lt;&gt; null
	and agentForDept &lt;&gt; agentForArr then
		agentsUsed := agentsUsed &amp; '; ' &amp; agentForDept.description;
	endif;	
		
	
	return agentsUsed;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getAllCancelledMovementOids" id="7a7a3808-ae20-42bc-b339-ea1e58a13c86">
        <source>getAllCancelledMovementOids():String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 November 2018	jlgndl1	Initial creation	TFS 42043

*/

vars

	movements : HMS_VoyageMovementArray;
	movement : HMS_VoyageMovement;
	
	retStr : String;

begin

	movements := self.getAllCancelledMovements();
	if not movements.isEmpty then
		foreach movement in movements do
			if retStr &lt;&gt; null then
				retStr := retStr &amp; ",";
			endif;
			retStr := retStr &amp; movement.getOidString();
		endforeach;
	endif;
	
	return retStr;

epilog

	delete movements;

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getAllCancelledMovements" id="966c8055-5023-4438-9276-6655d7578bb7">
        <source>getAllCancelledMovements():HMS_VoyageMovementArray;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 November 2018	jlgndl1	Initial creation	TFS 42043

*/

vars

	allMovements : HMS_VoyageMovementByDateDict;
	cancelledMovesArray : HMS_VoyageMovementArray;
	movement : HMS_VoyageMovement;

begin

	create cancelledMovesArray transient;
	
	if self.isArchived() then
		allMovements := self.allVoyagetMovementsArchived;
	else
		allMovements := self.allVoyageMovements;
	endif;
	
	if not allMovements.isEmpty then
		foreach movement in allMovements do
			movement.getMyCancelledMovements( cancelledMovesArray );
		endforeach;
	endif;
	
epilog

	return cancelledMovesArray;
	

end;</source>
        <ReturnType type="HMS_VoyageMovementArray"/>
    </JadeMethod>
    <JadeMethod name="getAllMovementsPhysicalWharf" id="2e5e99b5-e214-45c4-9384-41f1ec4b0496">
        <source>getAllMovementsPhysicalWharf(_allMovementsFound : Collection input;	
								_orientation : Integer);
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
28 September 2009	cnwer1	Initial creation

*/

vars
	iter : Iterator;
	movement : HMS_VoyageMovement;
begin
	if _allMovementsFound = null then
		return;
	endif;
	
	iter:=self.allVoyageMovements.createIterator;
	while iter.next(movement) do
		if movement.getMyBerth = null then
			continue;
		endif;
		if movement.getMyBerth.isLogicalBerth then
			continue;
		endif;
		if _orientation &lt;&gt; null  and
			movement.sideTo &lt;&gt; _orientation  then
			continue;
		endif;
			
		_allMovementsFound.add(movement);
	
	endwhile;
	
epilog
	delete iter;
end;</source>
        <Parameter name="_allMovementsFound" type="Collection" usage="input"/>
        <Parameter name="_orientation" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getArrivesInPortLocalTZ" id="c15c5473-9618-4231-a1fd-19185dd73486">
        <source>getArrivesInPortLocalTZ() : TimeStamp;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 June 2016	cnwns1	Initial creation
// 07 June 2016	cnwns1	TFS 488 - Multi Timezone Support
*/

vars

begin
	return self.systemToLocalTime(self.arrivesInPort);
epilog

end;</source>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="getBerthForDateTime" id="1ea04695-ea9f-4583-a8fb-ebc628550c35">
        <source>getBerthForDateTime(_dateTime : TimeStamp) : HMS_Berth;
/* ---------------------------------------------------------------------------
Usage:		THIS IS USED IN CUSTOMER REPORTS.  DO NOT RENAME OR REMOVE

Created:	13 July 2009 by cnwrs2
Updated:	14 July 2009 by cnwjo3

Purpose:	CCMS-JMH-1022.  The goal of this method is to find the current Berth of a Voyage.
			If an invalid Voyage (a voyage already left) is used to call this method then
			unexpected results will be returned.  Generally you could say that this
			method should only return allVoyageMomements.last since this will always
			return the most up-to-date berth details but since this method will be used
			in a report it is possible for the report 'designer' to use method to
			report on berth usages on different days (for example How were the berths
			utilizied on Mon, Tues, Wed... etc.
			
        
Change		Date		Who			Reason


------------------------------------------------------------------------------*/
vars
	tmpMovement	: HMS_Movement;

begin
	if self.allVoyageMovements = null then
		return null;
	endif;
	
	if self.allVoyageMovements.size &lt; 1 then
		return null;
	endif;
	
	//match movement to date
	tmpMovement := self.allVoyageMovements.getAtKeyLeq(_dateTime);
	
	if tmpMovement &lt;&gt; null then
		return tmpMovement.getMyBerth();
	else
		return null;
	endif;
end;
</source>
        <Parameter name="_dateTime" type="TimeStamp"/>
        <ReturnType type="HMS_Berth"/>
    </JadeMethod>
    <JadeMethod name="getCommodityDischCodeString" id="c30e7a0a-9fa8-4736-be9f-a96bc6b60ea3">
        <source>getCommodityDischCodeString() : String;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26/02/2013	cnwdap1	Initial creation PAR #31213 CCMS PNL 2255 Additional SQL Feilds
*/
vars
	//commodity	: CM_Commodity;			// ### TFS 53132 21Apr2022 NAVPW1
	cargoForecast	: CM_CargoForecast;	// ### TFS 53132 21Apr2022 NAVPW1
	result 		: String;

begin
	/*foreach commodity in self.allCommodityDischarge do
		result := result &amp; commodity.code &amp; ", ";
	endforeach;*/ // ### TFS 53132 12Apr2022 NAVPW1 - Commented out
	
	// ### TFS 53132 12Apr2022 NAVPW1
	foreach cargoForecast in self.myVoyage.allCargoForecasts where cargoForecast.mode = CM_CargoForecast.Mode_Discharge do
		if cargoForecast.myCargoType = null and cargoForecast.myCommodity = null then
			continue;
			
		elseif cargoForecast.myCargoType &lt;&gt; null then
			result := result &amp; cargoForecast.myCargoType.abbreviation &amp; ", ";
			
		elseif cargoForecast.myCommodity &lt;&gt; null then
			result := result &amp; cargoForecast.myCommodity.code &amp; ", ";
			
		endif;
		
	endforeach;
	// ### TFS 53132 12Apr2022 NAVPW1
	
	return result[1:result.length-2];
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
