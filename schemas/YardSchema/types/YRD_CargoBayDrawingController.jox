    <JadeMethod name="populateLCs" id="7433058a-e3e8-469d-8bfd-a8da0a366756">
        <updating/>
        <source>populateLCs() updating;

/*

Purpose:			Populate LCs collection

Parameters:			

Return Value:		


Date				Who		Reason
11 December 2008	consw1	Initial creation

*/

vars
	tmpTA	: CM_GridArea;
	tmpRow	: CM_GridRow;
	tmpLC	: CM_GridController;

begin
	self.allLCs.clear;

	tmpTA := self.myTerminalArea.CM_GridArea;
	if  tmpTA = null then
		return;
	endif;

	foreach tmpRow in tmpTA.allGridRows where tmpRow.row &gt;= self.minRow do
		if tmpRow.row &gt; self.maxRow then
			break;
		endif;
		
		foreach tmpLC in tmpRow.allControllersByColumn where tmpLC.column &gt;= self.minColumn do
			if tmpLC.column &gt; self.maxColumn then
				break;
			endif;
			self.allLCs.add(tmpLC);
		endforeach;
	endforeach;

epilog

end;</source>
    </JadeMethod>
