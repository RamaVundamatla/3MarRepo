    <JadeMethod name="initialise" id="51fb0e28-9f4a-4a1d-a5bc-3ef28eca0a03">
        <updating/>
        <source>initialise(_qm : CM_QuantityMap) updating;
// CCMS 1043 Snapshot Summary Invoicing 	Oct 2010 	cnwjre1
//	called from CM_SnapShotSummaryBroker creation to populate a default invoice allocation
vars
	itemCode	: String;
	nullValue	: String;
	ssb	: CM_SnapShotServiceBroker;
	obj			: Object;
	oa			: ObjectArray;
	
	criteriaType	: CM_YACriteriaType;
	criteria		: CM_YACriteriaPriority;
	proxyCriteria	: CM_YACriteria;

begin
	self.default := true;
	self.myQuantityMap := _qm;
	ssb := _qm.myParentFinancialObject.CM_SnapShotServiceBroker;
	create oa transient;
	ssb.getYACriteriaTypes(ssb.allYACriteriaTypes, oa);
	foreach obj in oa do
		criteriaType := obj.CM_YACriteriaType;
		create proxyCriteria transient;
		itemCode := criteriaType.description.cnEcUpto(CM_YACriteriaPriority::code.length - 1);
		nullValue := "";
		if criteriaType.isBooleanType() then
			nullValue := CM_YADataBoolean.VALUE_FALSE.String;
		endif;
		proxyCriteria.setProxy(criteriaType, nullValue, itemCode);
		proxyCriteria.CM_YACriteria.setYardAllocation(self);
		
		app.myUtilityCA.utlCreateYACriteriaPriority(proxyCriteria, criteria, app.myPassport);
		delete proxyCriteria;	//06 Sep 2017	NDL	TFS 6759
	endforeach;
epilog
	delete proxyCriteria;	//06 Sep 2017	NDL	TFS 6759
	delete oa;
end;</source>
        <Parameter name="_qm" type="CM_QuantityMap"/>
    </JadeMethod>
    <JadeMethod name="isInvoiceAllocation" id="db387976-ae08-4c38-87a4-e299292348c2">
