    <JadeMethod name="isObjectRelevant" id="e6808a1a-e5aa-448a-8960-fb297dce4e59">
        <source>isObjectRelevant(_obj: Object): Boolean;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 10/05/2017	cnwdap1		Initial creation TFS 4370 Allow pool party operators across terminals
//
vars

begin
	if inheritMethod(_obj) then
		if _obj.CM_MTPoolingParty.myTerminal = self.myForm.myTerminal then
			return true;
		endif;	
	endif;

	return false;
epilog

end;</source>
        <Parameter name="_obj" type="Object"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setControlsForAddEdit" id="a514ef54-35ea-461d-87fa-b0a5f87f434b">
        <updating/>
        <source>setControlsForAddEdit() updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 02/12/2016	cnwdap1		Initial creation TFS 3039 SNO MT Container Pool Management
//
vars
	form : SOP_TableMaintForm;

begin
	form := self.myForm;
	form.tblInput1.userInputEnabled := true;
	
	if form.mode = form.Mode_Add then
		form.tblInput1.clearValues;
		
		form.tblInput1.setValueByName(ETRow_Code, null);
		form.tblInput1.setValueByName(ETRow_Description, null);
		form.tblInput1.setValueByName(ETRow_Operators, null);
	
		form.tblInput1.setFocus;
		form.tblInput1.moveFirst();
		
		form.tblData4.rows := form.tblData4.fixedRows;
	else
		// refresh the data from the newly created proxy
		self.showThumbnail(form.myProxyObject.CM_MTPoolingParty);
	endif;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setCtrlsForView" id="040fa471-4f1d-4762-b2b6-4c2416df43bc">
        <updating/>
        <source>setCtrlsForView() updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 02/12/2016	cnwdap1		Initial creation TFS 3039 SNO MT Container Pool Management
//
vars
	form : SOP_TableMaintForm;

begin
	inheritMethod();
	
	form := self.myForm;
	form.tblInput1.userInputEnabled := false;
	
	form.shtViewTable1.enabled := true;
	form.tblData4.userInputEnabled := false;
	form.tblData4.fitColumnWidths;
	form.tblData4.cnEcResizeContents;
	form.tblData4.accessColumn(1).width := (form.tblData4.width * 1/2).Integer -1;
	form.tblData4.accessColumn(2).width := (form.tblData4.width * 1/2).Integer -1;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setupThumbnailDetails" id="f4689496-0451-4ab6-af05-3bbf1c170944">
        <updating/>
        <source>setupThumbnailDetails() updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 02/12/2016	cnwdap1		Initial creation TFS 3039 SNO MT Container Pool Management
//
vars
	form : SOP_TableMaintForm;
	table : CM_DataTable;

begin
	form := self.myForm;
	form.useProxyObject := true;
	form.setTblDataEntRows(ETDef_MTPoolParty);
	
	form.shtTblInput1.caption := app.getErrorString(Details);
	form.initTblInput(form.tblInput1, ETDef_MTPoolParty);
	form.shtTblInput1.visible := true;
	form.tblInput1.setRowReadOnly(ETRow_Operators);
	
	form.shtViewTable1.caption := app.getErrorString(Pooling_Partners);
	form.shtViewTable1.visible := true;
	form.shtViewTable1.enabled := true;
	// Note: SOPTM_Carrier also uses tblData4 but it sets it up each usage, so we can change it here
	table := form.tblData4;
	// SOPTM_Carrier sets sort columns, clear them here
	table.allTblDataSortColumns.clear();
	table.allTblDataSortDescending.clear();
	table.clearSort();
	table.rows := 0;
	table.fixedRows := 1;
	table.addItem(app.getErrorString(Operator) &amp; Tab &amp; app.getErrorString(Percentage_Charges));
	table.columns := 2;
	table.fixedColumns := 1;
	table.enabled := true;
	table.visible := true;
	// enable tabbing between rows, colour the table like the others on the form
	table.tabKey := Tab.Integer;
	table.backColor := form.backColor;
	table.accessRow(1).backColor := form.colorHeadingColumn;
	table.accessColumn(CM_EntryTable.ColumnHeading).backColor := form.colorHeadingColumn;
	
	form.shtViewTable1.cnEcResizeContents;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="showThumbnail" id="04254f08-93c9-4b9f-a9c0-bb6ac5d4d7cc">
        <updating/>
        <source>showThumbnail(_poolParty : CM_MTPoolingParty) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 02/12/2016	cnwdap1		Initial creation TFS 3039 SNO MT Container Pool Management
//
vars
	form : SOP_TableMaintForm;
	realPool : CM_MTPoolingParty;
	table : CM_DataTable;
	partner : CM_MTPoolingPartner;
	opTerm : CM_OperatorTerminal;
	idx : Integer;

begin
	form := self.myForm;
	form.tblInput1.clearValues;
	
	form.tblInput1.setValueByName(ETRow_Code, _poolParty.code);
	form.tblInput1.setValueByName(ETRow_Description, _poolParty.description);
	if _poolParty.isTransient then
		realPool := _poolParty.pxyGetRealObject();
		form.tblInput1.setValueByName(ETRow_Operators, realPool.getOperatorsString);
	else
		form.tblInput1.setValueByName(ETRow_Operators, _poolParty.getOperatorsString);
	endif;
	
	table := form.tblData4;
	table.userInputEnabled := false;
	table.rows := table.fixedRows;
	table.selectionType := Table.SelectMode_None;
	table.accessCell(1, 1).text := app.getErrorString(Operator) &amp; Tab &amp; app.getErrorString(Percentage_Charges);
	table.accessRow(1).backColor := form.colorHeadingColumn;
	foreach opTerm in _poolParty.allOperatorTerminals do
		idx := table.addItem(opTerm.myOperator.code &amp; Space &amp; opTerm.myOperator.description &amp; Tab);
		table.accessRow(idx).itemObject := opTerm;
		table.accessCell(idx, 2).inputType := Table.InputType_TextNumeric;
		table.accessedCell.decimals := 2;
		table.accessedCell.maxLength := 6;
	endforeach;
	foreach partner in _poolParty.allPoolingPartners do
		foreach idx in table.fixedRows + 1 to table.rows do
			if table.accessRow(idx).itemObject.CM_OperatorTerminal.myOperator = partner.myOperator then
				table.accessCell(idx, 2).text := partner.percentageOfCharges.asStringJMT;
			endif;
		endforeach;
	endforeach;
	if form.mode = form.Mode_Update then
		table.userInputEnabled := true;	
	endif;
epilog

end;</source>
        <Parameter name="_poolParty" type="CM_MTPoolingParty"/>
    </JadeMethod>
</Class>
