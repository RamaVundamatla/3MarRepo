    <JadeMethod name="isSameCriteria" id="ef0e08c8-37cb-4f92-854d-e4fa3bce7451">
        <source>isSameCriteria(_transRailAllocation : CM_RailAllocation) : Boolean;
/*
----------   ----------  --------------------------------------------------
Created:	14 November 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
19/08/2008   Simon Ward  SFW1030 - Promoted method to super-class CM_YardAllocation	
----------   ----------  --------------------------------------------------
*/
/*
vars
	compareCriteria,
	criteria			: CM_YACriteria;
begin
	if _transRailAllocation = self then
		return true;
	endif;
	
	if _transRailAllocation.allCriteria.size &lt;&gt; self.allCriteria.size then
		return false;
	endif;
	
	foreach criteria in self.allCriteria do
		compareCriteria := _transRailAllocation.getCriteriaOfType(criteria.myYACriteriaType);
		if compareCriteria = null then
			return false;
		endif;
		
		if (not criteria.myYAData.isSameCriteria(compareCriteria.myYAData)) then
			return false;
		endif;
	endforeach;

	return true;
end;
*/
begin
	return inheritMethod(_transRailAllocation);
end;


</source>
        <Parameter name="_transRailAllocation" type="CM_RailAllocation"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setForCreateFromTemplate" id="66981faf-af14-4644-867e-9af1c41b81bd">
        <updating/>
        <source>setForCreateFromTemplate(_railAllocation: CM_RailAllocation; _terminal: CM_Terminal) updating;
/*
----------   ----------  --------------------------------------------------
Created:	14 November 2006 By cnwth2

Purpose:	No terminal inverse to be set - see calling method comments

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars

begin
	// Standard set for update.	Builds blocks and primitives.
	self.setForUpdate(_railAllocation);
	
	// Clone criteria using special method.
	self.cloneCriteria(_railAllocation);
	


end;


</source>
        <Parameter name="_railAllocation" type="CM_RailAllocation"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
    </JadeMethod>
</Class>
