    <JadeMethod name="createEmptyChild" id="c8844ddc-3f4c-437b-b5c9-0144bb384e6a">
        <updating/>
        <source>createEmptyChild(_parent :  SOP_ViewModelObject) updating;
// -----------------------------------------------------------------------------
// Created:		11 March 2002 by cnwka1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	---------------------------------------------
//
// -----------------------------------------------------------------------------
begin
	create myObject as CM_SourceLocation transient;
	myObject.CM_SourceLocation.setForProxy(null, null, false, false, _parent.myObject.CM_CodeGroup);
	myParent := _parent;

end;</source>
        <Parameter name="_parent" type="SOP_ViewModelObject"/>
    </JadeMethod>
    <JadeMethod name="createEmptyPeer" id="cafab4a6-646a-49e0-98a4-a023a0b808a0">
        <updating/>
        <source>createEmptyPeer(_parent: SOP_ViewModelObject) updating;
// -----------------------------------------------------------------------------
// Created:		30 April 2002 by cnwka1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	---------------------------------------------
//
// -----------------------------------------------------------------------------
vars
	proxySource : CM_SourceLocation;
begin
	create proxySource transient;
	proxySource.setForProxy(null, null, false, false, _parent.myObject.CM_CodeGroup);
	self.myObject := proxySource;	
	self.myParent := _parent;
end;</source>
        <Parameter name="_parent" type="SOP_ViewModelObject"/>
    </JadeMethod>
    <JadeMethod name="doDelete" id="55768491-093d-45a8-8c8d-370ca3f8a91f">
        <updating/>
        <source>doDelete(): Boolean updating;
// -----------------------------------------------------------------------------
// Created:		14 March 2002 by cnwka1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	---------------------------------------------
//
// -----------------------------------------------------------------------------
begin
	app.myTrxDA.trxDeleteSourceLocation(self.myObject.CM_SourceLocation,app.myPassport);
	return app.myPassport.trxCompletedOK();
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doSave" id="c1dcdf38-f613-428f-8dd6-a689ce23198b">
        <updating/>
        <source>doSave(): Boolean updating;
// -----------------------------------------------------------------------------
// Created:		11 March 2002 by cnwka1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	---------------------------------------------
//
// -----------------------------------------------------------------------------
vars
	proxyLocation, newLocation : CM_SourceLocation;
	tmpObj				: CM_SourceLocation;
	isFSCFromTbl		: Boolean;
	answer				: Integer;
	applyFscToChildren	: Boolean;
	
begin
	if self.myForm.mode = self.myForm.Mode_Add then
		if self.myForm.myProxyObject &lt;&gt; null then
			self.myForm.myProxyObject.erase(NORMAL_ERASE);
		endif;
		
		create self.myForm.myProxyObject as CM_SourceLocation transient;
	endif;
	
	proxyLocation := self.myForm.myProxyObject.CM_SourceLocation;
	
	isFSCFromTbl := self.myForm.tblInput1.getValueByName(ETRow_IsFSC).Boolean;
	
	// When FSC changed, need to ask whether apply FSC for all children. CCMC JML 1105, PAR 21535 Nov 2009
	if self.myForm.mode = self.myForm.Mode_Update then
		tmpObj := self.myObject.CM_SourceLocation;
		if tmpObj.isSourceLocation() and tmpObj.isFSC &lt;&gt; isFSCFromTbl then
			answer := app.msgBox(app.getErrorString(ApplyFscAllCompartmentsStands), "", MsgBox_Yes_No + MsgBox_Question_Mark_Icon);
			if answer = MsgBox_Return_Yes then
				applyFscToChildren := true;
			endif;
		endif;
	endif;
	 
	proxyLocation.setForProxy(self.myForm.tblInput1.getValueByName('code').String.removeTabCrLfs(),	// 18/04/2013 cnwar2 #27130
								self.myForm.tblInput1.getValueByName('description').String,
								isFSCFromTbl,
								self.myForm.tblInput1.getValueByName('notAvailableForEntry').Boolean,
								self.myObject.CM_SourceLocation.myCodeGroup);
								
	if self.myForm.mode = self.myForm.Mode_Add then
		app.myTrxCA.trxCreateSourceLocation(proxyLocation, newLocation, app.myPassport);
		if app.myPassport.trxCompletedOK then
			delete self.myObject;  // delete the transient holder
			self.myObject := newLocation;
		endif;
	elseif self.myForm.mode = self.myForm.Mode_Update then
		app.myTrxUA.trxUpdateSourceLocation(proxyLocation, applyFscToChildren, app.myPassport);
	else
		app.raiseUnexpectedProgramError(class.name, method.name, '  Invalid mode (' &amp; self.myForm.mode.String &amp; ')');
	endif;
	
	self.myForm.myProxyObject := proxyLocation;
	return app.myPassport.trxCompletedOK;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
