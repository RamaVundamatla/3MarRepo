<Class name="CM_EWSActivityCams" id="6587b351-721d-470b-9989-35b5d26a7d5f">
    <superclass name="CM_ExternalWebServiceActivity"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="backgroundprocess"/>
    <PrimAttribute name="msgIndex" id="718001b1-f930-42c2-a4a6-bce58ddaf436">
        <embedded/>
        <type name="Integer"/>
        <access>readonly</access>
    </PrimAttribute>
    <ExplicitInverseRef name="myCamProtocol" id="a4503d9b-8926-4f68-97f7-4c70ebb0c57b">
        <transientToPersistentAllowed/>
        <updateMode>manual</updateMode>
        <embedded/>
        <type name="CM_CamProtocol"/>
        <access>readonly</access>
        <Inverse name="CM_CamProtocol::allEWSCamsActivities"/>
    </ExplicitInverseRef>
    <ImplicitInverseRef name="myCamTaskHistory" id="970187bb-d675-4679-a846-62bbf6301a9c">
