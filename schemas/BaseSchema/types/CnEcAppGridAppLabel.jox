    <JadeMethod name="create" id="56e12cf1-c0cf-4bbb-8f72-4346a6741ea6">
        <updating/>
        <source>create() updating;

begin
	borderStyle	:=	Window.BorderStyle_Single;
	alignment	:=	Label.Alignment_Left_Top;
	show3D		:=	Control.Show3D_Use3D;
	wordWrap	:=	true;
	caption		:=	null;
	sizeable	:=	true;
	moveable	:=	true;
	visible		:=	false;
end;</source>
    </JadeMethod>
