    <JadeMethod name="doOK" id="0102e043-4960-4912-ba1f-8dd589fcd0d3">
        <updating/>
        <source>doOK() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 April 2017	cnwndl1	Initial creation	TFS 3424

*/

vars

	palletDetailsTI : CM_PalletDetailsTI;
	palletType : CM_PalletType;

begin

	palletType := self.cmbPallettType.listObject.CM_PalletType;
//	if palletType = null then
//		app.msgBox(app.getErrorString(Must_select_pallet_type),app.getErrorString(Error),MsgBox_OK_Only);
//		self.cmbPallettType.setFocus();
//		return;
//	endif;

	if self.myPxyBreakBulkGeneric.myPalletDetailsTI = null then
		create palletDetailsTI transient;
		palletDetailsTI.setMyTrackedItem( self.myPxyBreakBulkGeneric );
	else
		palletDetailsTI := self.myPxyBreakBulkGeneric.myPalletDetailsTI;
	endif;
	
	palletDetailsTI.setBaseDetails(	self.chkHeatTreated.value,	//_heatTreated : Boolean;
									self.chkStoreOn.value,	//_storeOnPallets : Boolean;
									palletType	//_myPalletType : CM_PalletType
									) ;

	inheritMethod();
	

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="loadCombo" id="13706a7e-3a98-48f2-9f15-8f2ea6ec6c41">
        <source>loadCombo();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 April 2017	cnwndl1	Initial creation	TFS 3414

*/

vars

	iter : Iterator;
	handlingSubType : CM_HandlingSubType;

begin

	self.cmbPallettType.clear;
	
	self.cmbPallettType.addItem( null );	//16 Jan 2020	TFS 48246
	
	iter := self.allHandlingSubTypes.createIterator;
	while iter.next( handlingSubType ) do
		if handlingSubType.isNotAvailableForEntry then
			continue;
		endif;
		self.cmbPallettType.itemObject[self.cmbPallettType.addItem( handlingSubType.description )] := handlingSubType;
	endwhile;
	
epilog

	delete iter;

end;</source>
    </JadeMethod>
