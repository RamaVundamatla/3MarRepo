        <source>utlDeleteMenuUserItem(pMenuUserItem:CM_MenuUserItem io; _passport : CM_Passport input);
// ---------------------------------------------------------------------------
// Created:		August  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	self.initialiseActivity();

	app.setContinueCMExceptions(true);

	app.myValDA.valMenuUserItem(pMenuUserItem);
	
	if (not self.checkValidationWithPassport(_passport)) then // Show any Errors and Warnings in a list
		return;
	endif;


	app.setContinueCMExceptions(false);

	if _passport.noErrors then
		self.myDeleteAuditAgent.audDeleteGeneric(pMenuUserItem);
	endif;

	if _passport.noErrors then
		if app.myRoot.myQueryMenuRoot &lt;&gt; null then
			app.myRoot.myQueryMenuRoot.causeEvent(Event_Selector_Delete, false, pMenuUserItem);	// 26608 Dec 2010 snap shot definition form issues
		endif;
		pMenuUserItem.erase(NORMAL_ERASE);
	endif;

epilog
	return;

end;</source>
