<CollClass name="CnEcColorArray" id="3f8a14a1-cc12-430b-bf9e-1f649dc7c8ad">
    <memberType name="Integer"/>
    <superclass name="IntegerArray"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
