    <JadeMethod name="getTrackedItemConsignee" id="629cacba-7544-422c-a804-6d3c2589e36f">
        <source>getTrackedItemConsignee():CM_ConsigneeConsignor;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 May 2014	cnwndl1	Initial creation	Par 34142

*/

