	foreach cashPay in onsiteTi2.allCashPayments discreteLock do
		if idx.isOneOf(1,2,3) then // SHIP RECEIVE and  TO DO TASK
			self.assertTrueMsg(cashPay.myCashReceipt = cashReceipt1, idx.String &amp; " TI cash payment should be on cashReceipt1");
			if idx.isOneOf(1) then // SHIP RECEIVE
