<CollClass name="CM_DocumentTasksArray" id="ed5cbe40-0f15-4e50-b43c-c408afafaf54">
    <loadFactor>66</loadFactor>
    <memberType name="CM_DocumentToDoTask"/>
    <superclass name="ObjectArray"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="docActions"/>
    <JadeMethod name="getDocTask" id="e7531066-3907-430f-842c-f08b3d851890">
        <source>getDocTask(	_ti : CM_TrackedItem; _taskDesc : CM_ToDoTaskDesc ):CM_DocumentToDoTask;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 October 2016	cnwndl1	Initial creation	TFS 2001 / 2792	

*/

vars

	docTask : CM_DocumentToDoTask;

begin

	foreach docTask in self do
		if docTask.myTrackedItem &lt;&gt; _ti then
			continue;
		endif;
		if docTask.toDoTaskDesc &lt;&gt; _taskDesc then
			continue;
		endif;
		return docTask;
	endforeach;
	
	return null;

epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_taskDesc" type="CM_ToDoTaskDesc"/>
        <ReturnType type="CM_DocumentToDoTask"/>
    </JadeMethod>
    <JadeMethod name="getTotalAmountForId" id="170b441c-583a-41a4-8991-944aa8ec5759">
        <source>getTotalAmountForId( _id : String; _task : CM_ToDoTaskDesc ):Real;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 October 2016	cnwndl1	Initial creation	TFS 2647 / 2001

*/

vars

	docTask : CM_DocumentToDoTask;
	total : Real;

	invalidObject	: Boolean;

	ti : CM_TrackedItem;
begin
	on Exception do app.handleDeletedObject(exception, ti, invalidObject); // ### TFS 53851 14JUN2022 NAVAB1


	foreach docTask in self do
		ti := docTask.myTrackedItem; // ### TFS 53851 14JUN2022 NAVAB1
		if docTask.myTrackedItem.id &lt;&gt;_id then
			continue;
		endif;
		if docTask.toDoTaskDesc &lt;&gt; _task then
			continue;
		endif;
		total := total + docTask.amount;
	endforeach;
	
	return total;

epilog

end;</source>
        <Parameter name="_id" type="String"/>
        <Parameter name="_task" type="CM_ToDoTaskDesc"/>
        <ReturnType type="Real"/>
    </JadeMethod>
</CollClass>
