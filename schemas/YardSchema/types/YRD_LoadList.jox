    </JadeMethod>
    <JadeMethod name="doContextMenuBuild" id="ff34c32d-c480-4581-9f97-5ade4a24c238">
        <updating/>
        <source>doContextMenuBuild( table: Table input ) updating;
// ---------------------------------------------------------------------------
// Created:		19 September 2005  By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	tiArray : CM_TIArray;
	commonTrain : CM_Train;
	commonTrainName : String;
	obj : Object;
	tblDataHasSelectedTis : Boolean;
begin
	myContextTable := table.CM_DataTable;

	//31 Aug 2009	NDL	CCMS 1067
	create tiArray transient;
	if self.myContextTable = self.tblData then
		foreach obj in self.tblData.allSelectedObjects do
			if CM_TrackedItem.hasInstance(obj) then
				tiArray.add( obj.CM_TrackedItem );
			endif;
		endforeach;
	endif;
	tblDataHasSelectedTis := not tiArray.isEmpty;
	commonTrain := self.getCommonTrain();
	
	self.mnuContextTrainAssign.visible := tblDataHasSelectedTis;
	self.mnuTrainAP.visible := myContextTable = tblData;
	self.mnuContextRailOps.visible := true;
	self.mnuContextTrainPlan.visible := true;
	self.mnuContextTrainEnq.visible := true;
	
	if commonTrain &lt;&gt; null then
		commonTrainName := commonTrain.getCodeDateString;
//		self.mnuContextTrainAssign.enabled := true;
		self.mnuTrainAP.enabled := true;
		self.mnuContextRailOps.enabled := true;
		//self.mnuContextTrainPlan.enabled := true;
		self.mnuContextTrainPlan.enabled := not commonTrain.isDeparted();	// 26/01/2012 cnwar2 #28704
		self.mnuContextTrainEnq.enabled := true;
	else
		commonTrainName := app.getErrorString(Train);
//		self.mnuContextTrainAssign.enabled := false;
		self.mnuTrainAP.enabled := false;
		self.mnuContextRailOps.enabled := false;
		self.mnuContextTrainPlan.enabled := false;
		self.mnuContextTrainEnq.enabled := false;
	endif;
	
//	self.mnuContextTrainAssign.caption := app.getErrorString1(AssignToTrain, commonTrainName &amp; "...");
	self.mnuTrainAP.caption := app.getErrorString1(Autoplan_to_train, commonTrainName);
	self.mnuContextRailOps.caption := app.getErrorString1(Show_Train_in_rail_operations, commonTrainName);
	
	self.mnuContextTrainPlan.caption := app.getErrorString1(Show_Train_in_rail_planning, commonTrainName);
	self.mnuContextTrainEnq.caption := app.getErrorString1(Drill_to_Train_enquiry, commonTrainName);
	self.mnuContextTrainPlan.userObject := commonTrain;
	self.mnuContextTrainEnq.userObject := commonTrain;
	
	self.mnuContextTIEdit.visible := true;
	self.mnuContextTIEnquire.visible := true;
	self.mnuContextLocate.visible := false; // leave for 733 hotfix true;
	self.mnuContextLocate.caption := self.btnLocateYardEnq.caption;
	self.mnuContextLocate.enabled := 	self.btnLocateYardEnq.enabled;		
	self.mnuLoadListPlanLoad.visible := false;
	self.mnuContextSelectAll.visible := true;
	self.mnuLLLocateGridArea.visible := true;
	self.mnuSepTrainStuff.visible := true;
//	self.mnuLLReadyToShip.visible := true;
	self.mnuLLUnplan.visible := false;
	self.mnuContextSep01.visible := true;
	self.mnuContextColourLegend.visible := false;
	
	// cnwrl1 13/02/2009 - (CCMS SFW 1047 - Totals Only Lists) - start of coding
	self.mnuSummarise.visible	:= false;	// default this menu level to invisible, makes sub-menu invisible.
	if self.bAllowSummaryDefn then
		self.mnuSummarise.visible			:= true;
		// the summarise selected is only enabled if something is actually selected.
		self.mnuSummariseSelected.visible	:= not self.getCurrentDataTable.allSelectedObjects.isEmpty;
	endif;
	// cnwrl1 13/02/2009 - (CCMS SFW 1047 - Totals Only Lists) - end of coding
	
epilog

	delete tiArray;
	
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doEdit" id="1d06c63f-129b-4517-a5b4-27c1301ea468">
        <updating/>
        <source>doEdit() updating;
// ---------------------------------------------------------------------------
// Created:		January 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//	08 Dec 2011	NDL	Par 28797
// ---------------------------------------------------------------------------

vars
	theObject : Object;
	objArray : ObjectArray;
begin
	
	create objArray transient;
	getSelectedTIs(objArray);
	
	if objArray.isEmpty then
		return;
	endif;
	
	if objArray[1].isKindOf(CM_TrackedItem) then
		self.myAssistant.showCargoEnquiryForTIs(objArray[1].CM_TrackedItem, objArray, self.myMasterMenuAction, true);
	endif;
epilog
	delete objArray;
end;</source>
    </JadeMethod>
    <JadeMethod name="doFldMainClick" id="b2fdce6d-2fbd-4c90-aacf-977554a51b64">
        <updating/>
        <source>doFldMainClick() updating;
// ---------------------------------------------------------------------------
// Created:		23 August 2005  By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
//08 Dec 2011	NDL	Par 28797

vars
	str : String;
	invalidTrain : Boolean;
begin
	on Exception do app.handleDeletedObject(exception, self.myCurrentTrain, invalidTrain); //10/10/08 cnwdz2 Par 17732
	
	
	str := app.getErrorString(Rail_load_list) &amp; " " ;
	
	if self.myCurrentTrain &lt;&gt; null then
		str := str &amp; self.myCurrentTrain.code &amp; " ";
		//10/10/08 cnwdz2 Par 17732
		if invalidTrain then		
			app.msgBox(app.getErrorString(Train_been_deletedYO),"",MsgBox_OK_Only+MsgBox_Exclamation_Mark_Icon);
			return;
		endif;
	endif;
	
	self.btnCargoUnplan.enabled		:= false;
	self.btnLocateYardEnq.enabled	:= false;
	self.btnLocate.enabled			:= true;
	self.btnSummariseAll.enabled	:= true;
	
	if fldMain.topSheet = self.shtAll then
		self.btnUserColours.enabled := true;
		self.caption := str &amp; app.getErrorString(LOADLIST_ALL);
		if self.newQuery  then
			if self.tblAll.allTableObjects.size &lt;&gt; 0 then
				self.displayAllTable();
				self.frmStatLine.caption := self.statusStub &amp; " " &amp; app.getErrorString(SHP_Selected) &amp; self.tblAll.allSelectedObjects.size.asStringJMT;
				self.btnLocate.enabled := false;
				self.newQuery := false;
			else
				fldMain.topSheet := self.shtNonplanned;
				self.btnUserColours.enabled := false;
			endif;
		endif;
	else
		self.btnUserColours.enabled := false;
		self.frmUserColours.visible := false;
	endif;
	
	if fldMain.topSheet = self.shtNonplanned then
		self.caption := str &amp; app.getErrorString(SHP_NON_PLANNED);
		self.btnLocateYardEnq.enabled := true; 
		self.frmStatLine.caption := self.statusStub &amp; " " &amp; app.getErrorString(SHP_Selected) &amp; self.tblData.allSelectedObjects.size.asStringJMT;
	elseif fldMain.topSheet = self.shtPlanned then
		self.caption := str &amp; app.getErrorString(SHP_PLANNED);
		self.btnCargoUnplan.enabled := true;
		self.frmStatLine.caption := self.statusStub &amp; " " &amp; app.getErrorString(SHP_Selected) &amp; self.tblPlanned.allSelectedObjects.size.asStringJMT;
	elseif fldMain.topSheet = self.shtSummary then	
		self.caption := str &amp; app.getErrorString(SHP_SUMMARY);
		self.btnSummariseAll.enabled	:= false;
	endif;
	
	if self.mode = self.Mode_SummarySelection then
		self.caption := self.caption &amp; " - " &amp; app.getErrorString(SHP_Summary_Selection_Mode);
	endif;

end;</source>
    </JadeMethod>
    <JadeMethod name="doFunctionForMenu" id="086c0eda-8c7d-46f3-80cc-b5cdb5ef3ec8">
        <updating/>
        <source>doFunctionForMenu(_function: Integer; _columnKey: Integer) updating;
//----------------------------------------------------------------
//	Created:	27 September 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	tableObj		: CM_DataTable;
	summaryObj		: CMIF_LoadListSummaryObject;
	allSummariesObj	: CMIF_LoadListSummaryObjectSet;
	rowObj			: JadeTableRow;
	rowPointer		: Integer;
	startRow		: Integer;
	rowCount		: Integer;
	
begin
//app.writeStatement('CNWJC2 ' &amp; class.name &amp; " " &amp; method.name &amp;  " " &amp; _function.String &amp; " col=" &amp; _columnKey.String);
	tableObj	:=	self.tblSummary;
// cnwdad1 14/12/2005 - CCMS #1418 - Changed to handle multi-selected rows.
//	summaryObj	:=	tableObj.accessRow(tableObj.row).itemObject.CMIF_LoadListSummaryObject;
	startRow	:=	tableObj.fixedRows + 1;
	rowCount	:=	tableObj.rows;
	
	create allSummariesObj transient;
	
	foreach rowPointer in startRow to rowCount do
		rowObj	:=	tableObj.accessRow(rowPointer);
		
		if rowObj.selected then
			summaryObj	:=	rowObj.itemObject.CMIF_LoadListSummaryObject;
			//epr par 29963 9/1/14
			if summaryObj  &lt;&gt; null then
				allSummariesObj.add(summaryObj);
			endif;
		endif;
	endforeach;
	
//	if summaryObj = null then
	if allSummariesObj.isEmpty() then
		//nothing to do
		return;
	endif;

//	self.handleFunctionForObject(_function, summaryObj, _columnKey);
	self.handleFunctionForObject(_function, allSummariesObj, _columnKey);
epilog
	delete allSummariesObj;
end;</source>
        <Parameter name="_function" type="Integer"/>
        <Parameter name="_columnKey" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="doGetInfoTableData" id="84980250-3cc2-4f4c-a434-128df36d00fb">
        <updating/>
        <source>doGetInfoTableData(_dataTable: CM_DataTable input; _infoTable : CM_DataTable input) updating;
// ---------------------------------------------------------------------------
// Created:		June 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	theTI : CM_TrackedItem;
	theObject : Object;
	dataContainer : CM_DataContainer;
	theAttribs :	CMUI_GridAttributesArray;
	theAttrib : CMUI_GridAttributes;
begin
	self.mousePointer := Window.MousePointer_HourGlass;

	self.myCurrentTrackedItem := null;
	_infoTable.rows := 0;

	if _dataTable.row &lt;= _dataTable.fixedRows then
		return;
	endif;

	theObject := _dataTable.accessRow(_dataTable.row).itemObject;
	if (not global.isValidObject(theObject)) then
		return;
	endif;
	
	if CM_TrackedItem.hasInstance(theObject) then
		self.myCurrentTrackedItem := theObject.CM_TrackedItem;	
		if self.myCurrentTrackedItem &lt;&gt; null then
			self.btnLocate.enabled := self.myCurrentTrackedItem.myPrimaryActualLocation.isKindOf(CM_GridController);
		endif;
	elseif CM_WorkListEntry.hasInstance(theObject) then
		theObject := theObject.CM_WorkListEntry.myTrackedItem;
		self.myCurrentTrackedItem := theObject.CM_TrackedItem;
	endif;
	
	if useTableInfo then

		if self.mnuContextHide.caption = self.MNU_MACRO_SHOW // this means that the macro info is hidden
		and not app.isDragging then
		else

			create dataContainer transient;
			dataContainer.headerColour := self.colorHeadingColumn;
			dataContainer.valueColour := self.colorValueColumn;
			
			if theObject &lt;&gt; null and theObject.isKindOf(CM_Object) then
				theObject.CM_Object.getExtraInfo(dataContainer);
				self.tblInfo.userObject := theObject;
			endif;
			self.showExtraInformation(dataContainer, _infoTable, true, false, 4, 1, 1, 1, 1);
		endif;
	endif;
epilog
	delete dataContainer;
	delete theAttrib;
	delete theAttribs;
	self.mousePointer := Window.MousePointer_Default;


end;</source>
        <Parameter name="_dataTable" type="CM_DataTable" usage="input"/>
        <Parameter name="_infoTable" type="CM_DataTable" usage="input"/>
    </JadeMethod>
