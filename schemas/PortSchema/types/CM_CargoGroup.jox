    <JadeMethod name="getCargoGroupMyVoyage" id="249ccfdb-9f92-41e2-ba52-fafff33fc845">
        <source>getCargoGroupMyVoyage(_voyages : CM_VoyageSet input) :CM_Voyage;
// ### TFS BUG 58853 03JUL2023 NAVAB1

vars
	tis				: CM_TISet;
	tisCount		: Integer;
	ti				: CM_TrackedItem;
	voyage : CM_Voyage;
	newVoyageCode,
	voyageCode		: String;
	iter			: Iterator;
	
begin
	tis := self.allAssignedTrackedItems;
	if tis.isEmpty then
		return null;
	endif;
	
	foreach ti in tis do
		if ti.myVoyage = null then
			continue;
		endif;
		
		voyage := ti.myVoyage;
		if voyage &lt;&gt; null then
			_voyages.addNoDuplicates(voyage, false);
		endif;
	endforeach;
	
	if _voyages.size = 1 then
		return voyage;
	endif;
	
	return null;

epilog
	delete iter;
	
end;</source>
        <Parameter name="_voyages" type="CM_VoyageSet" usage="input"/>
        <ReturnType type="CM_Voyage"/>
    </JadeMethod>
