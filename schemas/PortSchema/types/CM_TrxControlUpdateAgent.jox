    <JadeMethod name="trxUpdateEDIOperatorStops" id="0f84e939-6d66-4571-9970-57a3950cfd0e">
        <updating/>
        <source>trxUpdateEDIOperatorStops(	_trackedItem : CM_TrackedItem input;
							_opStopTI : CM_EDIOperatorStopTI input;
							_passport : CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:	07 November 2008 By Graeme Black cnwgb1
// Status: 	PAR 18418 CCMS 1743 Maersk Import Release PIN 
// Purpose:	On load of a COREOR file, Operator Stops may be added/removed and 
//			a Release PIN might be removed/added to a tracked Item
// ---------------------------------------------------------------------------
// 16 Jul 2012	cnwrs1	Par 30000 - only clear if the numbers match
// 11 March 2013	cnwrs1	Par 31345
// 15 May 2013	cnwrs1	par31549 stop removal of unused options
// 25/07/0213	cnwcs5		CCMS POL 2221 / par 32094 - use CM_EDITrackedItem constants

vars
	passport : CM_Passport;
	stops : IntegerArray;
	proxyTrackedItem : CM_TrackedItem;
	ediOperatorStopReleasePin : Boolean;
	ediOperatorDeliveryRelease : Boolean;
	tmpStops : IntegerArray; //ccms1845
	int : Integer;
	extraRemarks : String;
	allStops : CM_StopsByIdDict;
	stop : CM_Stops;
	stopTable : CM_StopsTable;
	term : CM_Terminal;
begin
	passport := _passport;
	// Always initialize the activity first
	self.initialiseActivityWithPassport(passport, method);
	
	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, passport);
	on LockException do agtPassportLockExHandler(exception, passport);

	ediOperatorStopReleasePin := _trackedItem.myOperator.getRequiresImpOperatorPIN;
	ediOperatorDeliveryRelease := _trackedItem.myOperator.requiresDeliveryRelease;
	term := _trackedItem.myTerminal;	//02 Jun 2017	NDL	TFS 4455

	beginTransaction;
	proxyTrackedItem := app.createUpdateProxy(_trackedItem).CM_TrackedItem;
	if proxyTrackedItem = null then
		return;
	endif;
	
	//04 Oct 2016	NDL	TFS 2718 / 2536
	extraRemarks := _opStopTI.getPlaceOfReturn();
	if extraRemarks &lt;&gt; null then
		proxyTrackedItem.setRemarks( extraRemarks, true );
	endif;
	
	//31 May 2017	NDL	TFS 4456
	if _opStopTI.freightForwarder &lt;&gt; null and _opStopTI.freightForwarderVerify(null) = _opStopTI.VALID.String then
		proxyTrackedItem.zSetPxyFreightFowarderCode( _opStopTI.freightForwarder );
	endif;
	
	if ediOperatorStopReleasePin then //ccms1845
		//CCMS1807 PAR19528 - cnwsh3 23/4/2009 Remove or add the Operator import pin based on the file function code.  
		if _opStopTI.messageMode = CM_EDITrackedItem.EDI_ACTION_DELETE then
			if proxyTrackedItem.getOperatorImportReleasePIN = _opStopTI.entryNumber[1:11] then	//16 Jul 2012	cnwrs1	Par 30000 - only clear if the numbers match	
				proxyTrackedItem.setOperatorImportReleasePIN(null);
			endif;
		else
			proxyTrackedItem.setOperatorImportReleasePIN(_opStopTI.entryNumber[1:11]);
			//02 Jun 2017	NDL	TFS 4455
			if _opStopTI.expiryDate.isValid and proxyTrackedItem &lt;&gt; null then
				allStops := proxyTrackedItem.getAllStops;
				foreach stop in allStops do
					stopTable := stop.myStopsTable;
					if stopTable &lt;&gt; null
					and stopTable.isOperatorImportReleaseStop( term )
					and stopTable.allowClearanceExpiryDate
					then
						stop.setClearanceExpiryDate( _opStopTI.expiryDate );
					endif;
				endforeach;
			endif;
			
		endif;
	endif;
	//epr par 34732 27/8/14 this 2 flags should be independent
	if ediOperatorDeliveryRelease then
		//ccms 1845 update delivery release number
		if _opStopTI.messageMode = CM_EDITrackedItem.EDI_ACTION_DELETE then
			if proxyTrackedItem.deliveryRelease = _opStopTI.entryNumber then	//16 Jul 2012	cnwrs1	Par 30000 - only clear if the numbers match	
				proxyTrackedItem.setDeliveryRelease(null);
			endif;
		else
			proxyTrackedItem.setDeliveryRelease(_opStopTI.entryNumber);
			//02 Jun 2017	NDL	TFS 4455
			if _opStopTI.expiryDate.isValid and proxyTrackedItem &lt;&gt; null then
				allStops := proxyTrackedItem.getAllStops;
				foreach stop in allStops do
					stopTable := stop.myStopsTable;
					if stopTable &lt;&gt; null
					and stopTable.isOperatorImportDelReleaseStop( term )
					and stopTable.allowClearanceExpiryDate
					then
						stop.setClearanceExpiryDate( _opStopTI.expiryDate );
					endif;
				endforeach;
				
			else
				create tmpStops transient; //ccms1845 cnwrs1 Nov 2009
				app.myRoot.getOperatorImportDelRelStops(tmpStops, proxyTrackedItem.myTerminal);
				foreach int in tmpStops do
					proxyTrackedItem.removeStopProxy(int);
				endforeach;
			endif;
		endif;
	endif;
	
	app.myUtilityUA.utlUpdateTrackedItem(proxyTrackedItem, null, TI_UPDMODE_NORMAL, null,null, null, _passport); //cnwrd1 28.8.09 par 20545
	if app.myPassport.noErrors then	//par 28788 cnwrs1 05 dec 2011 
		_opStopTI.setStatus(CM_EDITrackedItem.EDI_STATUS_DBLOADED);
		//par 18587
		_opStopTI.setTrackedItem(_trackedItem);
		
		app.myUtilityUA.utlSetupEDIInfoTransaction(_trackedItem, _opStopTI.rawEDIDataArray); //ccms1845
	endif;
epilog
	delete proxyTrackedItem;
	delete tmpStops;
	self.finaliseActivityWithPassport(passport);
end;</source>
        <Parameter name="_trackedItem" type="CM_TrackedItem" usage="input"/>
        <Parameter name="_opStopTI" type="CM_EDIOperatorStopTI" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
