epilog

end;</source>
        <Parameter name="_myObjectMatchCriteria" type="CM_ReeferJobCriteria"/>
        <Parameter name="_myListForm" type="CMUI_ObjectCriteriaListForm"/>
    </JadeMethod>
    <JadeMethod name="setCriteriaResizeScrollBar" id="b45fe789-3743-4b56-a0fc-23fd4a3b6b9d">
        <updating/>
        <source>setCriteriaResizeScrollBar() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23/11/2023	navkc1 Bug 60782: FR | 54089 EUP -Invoice Contracts - Criteria screen width issues

*/

vars
	max			: Integer;
	numOfCrit	: Integer;
begin
	numOfCrit := 9;
	max := (numOfCrit * (self.frmCriteria.height)).Integer;
	if self.picCriteria.height &lt; max then
		self.picCriteria.scrollBars := Picture.ScrollBar_Vertical;
		self.picCriteria.setScrollRange(ScrollBar_Vertical, 0, max, 20, 100);
	else
		self.picCriteria.scrollBars := 0;
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setUpTimes" id="d8f15ab2-d3e3-4245-9a53-12a65b453db8">
        <updating/>
        <source>setUpTimes()updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 August 2020	jlgndl1	Initial creation	TFS 49581


*/

vars

	int : Integer;
	hourStr : String;
	timeStr : String;
	timeStringObj : CM_StringWithString;

begin

	self.allTimes.clear();
	foreach int in 1 to 24 do
		hourStr := (int - 1).String.padLeadingZeros(2);
		create timeStringObj transient;
		timeStr := hourStr &amp; ":00";
		timeStringObj.set( timeStr, timeStr );
		self.allTimes.add( timeStringObj );
		create timeStringObj transient;
		timeStr := hourStr &amp; ":30";
		timeStringObj.set( timeStr, timeStr );
		self.allTimes.add( timeStringObj );
	endforeach;
	
	self.mulTimes.setupControl( self.mulTimes.caption, self.allTimes, CMUI_ReeferAutoJobsForm::displayTimeString.name);
	self.mulTimes.setSelected( null ); 
	self.mulTimes.multiSelect := ListBox.MultiSelect_Simple;
	self.mulTimes.myAvailableListBox.sorted := true;
	

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setupForm" id="43c16170-724f-4c3b-911c-5dbd12bda81b">
        <updating/>
        <source>setupForm() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 August 2020	jlgndl1	Initial creation	TFS 49581
28/11/2023		navkc1 Bug 60782: FR | 54089 EUP -Invoice Contracts - Criteria screen width issues
*/

vars

begin

	create self.allTimes transient;
	self.initialSheetIndex := 1; 
	self.handleMenusForModalDisplay();
	//self.moveControlsForSetup(); // 28/11/2023	navkc1 Bug 60782
	self.setUpTimes();
	
	inheritMethod();
	
	self.moveControlsForSetup();	// 28/11/2023	navkc1 Bug 60782
	
	if self.myParentForm &lt;&gt; null then
		self.centreOverParent( 0 );
	endif;
	
	self.grpReeferJob.top := self.picCriteria.height + 5;
	self.grpReeferJob.parentBottomOffset := 5;
	self.txtYACode.setFocus();
	
	self.btnSave.enabled := app.myCurrentUserCan(self.myTerminal, PmAdmReeferAutoMaint);
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="translateForm" id="1dcff14a-cac1-4afd-a666-605805724ccd">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 11 September 2020 15:34:52.
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0024022, locale);
	chkAlarm.translateCaption(Xlat_0024023, locale);
	chkConnect.translateCaption(Xlat_0024024, locale);
	chkDisconnect.translateCaption(Xlat_0024025, locale);
	chkMoitor.translateCaption(Xlat_0024026, locale);
	grpReeferJob.translateCaption(Xlat_0024027, locale);
	lblConnectMins.translateCaption(Xlat_0024028, locale);
	lblDisconMins.translateCaption(Xlat_0024029, locale);
	lblVariance.translateCaption(Xlat_0024030, locale);
	mulTimes.translateCaption(Xlat_0024036, locale);
end;</source>
