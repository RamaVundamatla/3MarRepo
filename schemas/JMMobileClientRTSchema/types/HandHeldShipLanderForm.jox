    <JadeMethod name="doConfirmAftContainer" id="24e12f28-94c0-482f-baa2-724fca0af02f">
        <updating/>
        <source>doConfirmAftContainer() updating, protected;
/*
----------   ----------  --------------------------------------------------
Created:	13 September 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	errorMsgs		: MobileHandHeldThin::DTO_HandHeldGateErrorDict;
	error			: DTO_HandHeldGateError;

begin
	self.containerConfirmedAft := false;
	create errorMsgs transient;
	self.doClearErrors();
	app.myHandHeldShipLanderGuiAgent.doConfirmAftContainer(self.txtVehicle.text.trimBlanks.toUpper, 
														self.txtVoyage.text.trimBlanks.toUpper, 
														self.txtIdAft.text.trimBlanks.toUpper, 
														self.txtSealCustAft.text.trimBlanks.toUpper, 
														self.txtSealOpAft.text.trimBlanks().toUpper,
														self.txtSealShipAft.text.trimBlanks().toUpper, 
														errorMsgs);


	if errorMsgs.isEmpty then

		self.containerConfirmedAft := true;
		self.lblTIAftDtl.caption := "Confirmed " &amp; self.txtIdAft.text.trimBlanks.toUpper &amp; app.myHandHeldShipLanderGuiAgent.myHandHeldShipLanderAgent.isHazardous(false);
		self.doShowFrmMain();
		return;
	endif;
	
	self.doApplyErrors(errorMsgs);
	self.fldMain.topSheet := self.shtError;
	
epilog
	if errorMsgs &lt;&gt; null then
		errorMsgs.purge();
	endif;
	
	delete errorMsgs;
end;


</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doConfirmDamage" id="4abddc11-6ddd-443b-a18d-12f82f079d06">
        <updating/>
        <source>doConfirmDamage(_fwd : Boolean) protected, updating;
/*
----------   ----------  --------------------------------------------------
Created:	13 September 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	damageRemarks,
	containerID, errors			: String;
	// 26/08/2009 	cnwsh3 		CCMS SFW1066 PAR20321 - Recording Damage Details Changes.
	//damageDict			: MobileHandHeldThin::CM_DamageInstanceByLocDict;
	damageDict			: MobileHandHeldThin::CM_DamageInstanceByDmgePos;
	pxyDamageInstance	: MobileHandHeldThin::CM_DamageInstance;
	errorMsgs			: MobileHandHeldThin::DTO_HandHeldGateErrorDict;
begin
	if self.showingFowardContainer then
		containerID := self.txtIdFoward.text.trimBlanks.toUpper();
		if containerID = null then
			app.msgBox('You must enter a value for the forward container ID','Error: No container ID specified',MsgBox_Exclamation_Mark_Icon);
		endif;
	elseif self.showingAftContainer then
		containerID := self.txtIdAft.text.trimBlanks.toUpper();
		if containerID = null then
			app.msgBox('You must enter a value for the aft container ID','Error: No container ID specified',MsgBox_Exclamation_Mark_Icon);
		endif;
		
	endif;
	
	create damageDict transient;
	create errorMsgs transient;
	
	self.tblDamage.setProxyFromTable(damageDict,null, errors);
	
	if errors &lt;&gt; null then
		if app.msgBox(errors &amp; CrLf &amp; 'Continue?', 'Entry Warnings - Continue?', MsgBox_OK_Cancel) &lt;&gt; MsgBox_Return_OK then
			return;
		endif;
	endif;
	
	damageRemarks := self.txtDamage.text.trimBlanks;
	
	app.myHandHeldShipLanderGuiAgent.doConfirmDamageShip(_fwd, self.txtVehicle.text.trimBlanks,
											containerID,
											damageRemarks,
											damageDict,
											errorMsgs);
	
	
	if (not errorMsgs.isEmpty) then
		app.msgBox('Errors occured when applying damage details. They will now be displayed','Errors occurred', MsgBox_Exclamation_Mark_Icon);
		self.doApplyErrors(errorMsgs);
		self.fldMain.topSheet := self.shtError;
	else
//		app.msgBox('Damage details confirmed.','Damage Confirmed', MsgBox_Exclamation_Mark_Icon);
		if self.showingFowardContainer then
			self.doShowFrmFowardCont();
		elseif self.showingAftContainer then
			self.doShowFrmAftCont();
		endif;
	endif;

epilog
	
	if damageDict &lt;&gt; null then
		damageDict.purge();
	endif;
	delete damageDict;

	if errorMsgs &lt;&gt; null then
		errorMsgs.purge();
	endif;
	delete errorMsgs;

end;


</source>
        <access>protected</access>
        <Parameter name="_fwd" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doConfirmFowardContainer" id="1ad52aa6-2368-426e-972c-abf15f5dcd87">
        <updating/>
        <source>doConfirmFowardContainer() updating, protected;
/*
----------   ----------  --------------------------------------------------
Created:	13 September 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	errorMsgs		: MobileHandHeldThin::DTO_HandHeldGateErrorDict;
	error			: DTO_HandHeldGateError;
begin
	self.containerConfirmedFoward := false;
	create errorMsgs transient;
	self.doClearErrors();
	app.myHandHeldShipLanderGuiAgent.doConfirmFowardContainer(self.txtVehicle.text.trimBlanks.toUpper, 
														self.txtIdFoward.text.trimBlanks.toUpper, 
														self.txtVoyage.text.trimBlanks.toUpper, 
														self.txtSealCustFowar.text.trimBlanks.toUpper, 
														self.txtSealOpFoward.text.trimBlanks().toUpper,
														self.txtSealShipFowar.text.trimBlanks().toUpper, 
														errorMsgs);

	
	if errorMsgs.isEmpty then
//		app.msgBox('Forward container information is correct.','Confirmed', MsgBox_OK_Only);
		self.containerConfirmedFoward := true;
		self.lblTIFwdDtl.caption := "Confirmed " &amp; self.txtIdFoward.text.trimBlanks.toUpper &amp; app.myHandHeldShipLanderGuiAgent.myHandHeldShipLanderAgent.isHazardous(true);
		self.doShowFrmMain();
		return;
	endif;
	
	self.doApplyErrors(errorMsgs);
	self.fldMain.topSheet := self.shtError;
	
epilog
	if errorMsgs &lt;&gt; null then
		errorMsgs.purge();
	endif;
	
	delete errorMsgs;
end;


</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doConfirmIMV" id="c22a89e7-8eda-49b3-a501-eb6387a392b7">
        <updating/>
        <source>doConfirmIMV() updating;
// ---------------------------------------------------------------------------
// Created:		24 October 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
// 24 Jun 2009	epr 	Par 20080
vars
	errorMsgs		: MobileHandHeldThin::DTO_HandHeldGateErrorDict;
	error			: DTO_HandHeldGateError;
	vehicleID		: String;
	vinCode : String;
begin
	create errorMsgs transient;
	self.doClearErrors();
	
	vehicleID := self.txtVehicle.text.trimBlanks.toUpper();
	if vehicleID &lt;&gt; self.previousVehicleID then
		self.clearAllInfo(false);
	endif;
	
	self.previousVehicleID := vehicleID;
	
	app.myHandHeldShipLanderGuiAgent.doConfirmVehicle(vehicleID, vinCode, 	errorMsgs);
	if not errorMsgs.isEmpty then
		self.doApplyErrors(errorMsgs);
		self.fldMain.topSheet := self.shtError;
	endif;
	
epilog
	delete errorMsgs;


end;</source>
    </JadeMethod>
