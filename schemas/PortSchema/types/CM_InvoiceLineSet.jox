<CollClass name="CM_InvoiceLineSet" id="4c03099d-f13a-4641-91af-326b050ca058">
    <loadFactor>98</loadFactor>
    <memberType name="CM_InvoiceLine"/>
    <superclass name="CM_ObjectSet"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>For reporting</text>
    <DbClassMap file="invoice"/>
    <JadeMethod name="getProformaDesc" id="b9317609-7c53-49cb-9a98-63bc787f3321">
        <source>getProformaDesc():String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 March 2013	cnwndl1	Initial creation	Par 30901
05/03/2015	cnwjre1	34917 copied from CM_InvoiceLineBySeqNumDict as the proforma agent invoice line collections are all now CM_InvoiceLineSet
*/

vars

	invLine : CM_InvoiceLine;
	str : String;
	proformaDesc : String;

begin

	foreach invLine in self do
		str := invLine.getStringForProformaDesc();
		if proformaDesc = null then
			proformaDesc := str;
		else
			proformaDesc := proformaDesc &amp; CM_CashPayment.ProformaLineSep &amp; str;
		endif;
	endforeach;
	
	return proformaDesc;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
</CollClass>
