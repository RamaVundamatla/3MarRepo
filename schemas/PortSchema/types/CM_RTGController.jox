    <JadeMethod name="executeDisplayNotesForMove" id="8a9262ec-1317-4943-8d20-8d1b3e487cdc">
        <source>executeDisplayNotesForMove(_controller : CMIF_MoveController);
// ---------------------------------------------------------------------------
// Created:		29 August 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
//	theVoyage : CM_Voyage;	
	theTerminal : CM_Terminal;
	theTI : CM_TrackedItem;
	myLane : CM_RTGLane;
begin
	inheritMethod(_controller);
	
	if self.myGridArea  = null then
		//epr par 19115 25/3/09 
		//may as well return because when  app.myEventManager tries to send a note to a null target it will raise an unexcepted program error
		return;
	endif;
	
	myLane := self.myGridArea.CM_RTGArea.allTerminalAreaGroups.first.CM_RTGLane;
	if myLane = null then
		return;
	endif;
	
	theTerminal := self.myTerminal;
	theTI := _controller.myTrackedItem;

	if  self = _controller.myOriginatingLocation then
		app.myEventManager.createSingleObjInfoNoteEvt(myLane, theTerminal.getTerminalEvent(EVENT_TI_MOVE_FROM_LOCATION),theTI);
	elseif self = _controller.myToPrimaryLocation then
		app.myEventManager.createSingleObjInfoNoteEvt(myLane, theTerminal.getTerminalEvent(EVENT_TI_MOVE_TO_LOCATION),theTI);
	endif;
	app.myEventManager.createSingleObjInfoNoteEvt(myLane, theTerminal.getTerminalEvent(EVENT_TI_MOVE),self);
	
end;</source>
        <Parameter name="_controller" type="CMIF_MoveController"/>
    </JadeMethod>
