    <JadeMethod name="getTerminalReceivalCutoff" id="415ad85a-59f2-42a7-8d7c-6f6ae9fe75be">
        <source>getTerminalReceivalCutoff( _terminalDefault : CM_ReceivalCutoffTermDef) : CM_ReceivalCutoffOpTerm;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
27 April 2012	cnwer1	Par 29487

*/

vars
	opTerm 	: CM_OperatorTerminal;
begin
	if _terminalDefault = null then
		return null;
	endif;
	opTerm:=self.allOperatorTerminals[_terminalDefault.myTerminal];
	if opTerm = null then
		return null;
	endif;
	return opTerm.allReceivalCutoffOpTerms[_terminalDefault];
	
epilog

end;</source>
