    <JadeMethod name="userNotify" id="fe5cccaf-3879-417c-94ee-a50f8470b0f0">
        <controlMethod name="Form::userNotify"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>userNotify(eventType: Integer; theObject: Object; eventTag: Integer; userInfo: Any) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 December 2012	cnwer1	Initial creation HAT 2189

*/

vars

begin
	if eventType = self.myTerminal.getTerminalEvent(EVENT_DUTYDOCITEM_UPDATE) then
		self.loadDutyDocItems();
	endif;
	if eventType = self.myTerminal.getTerminalEvent(EVENT_DUTYDOC_UPDATE) then
		self.loadDutyDoc(false);
	endif;
epilog

end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
        <Parameter name="userInfo" type="Any"/>
    </JadeMethod>
</GUIClass>
