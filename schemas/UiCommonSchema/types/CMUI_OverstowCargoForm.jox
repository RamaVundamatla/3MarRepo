    <JadeMethod name="addToolbarControls" id="6f1d1326-49c5-45a5-88eb-7e1274681509">
        <updating/>
        <source>addToolbarControls() updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
17 November 2009	cnwphb1	Initial creation

*/

vars
	frm	: CMUI_Toolbar;
begin
	frm := self.frmToolbar;
	frm.addButton(self.btnPrint, CMUI_Toolbar.Control_Alignment_Left);
	frm.addButton(self.btnExportCSVQE, CMUI_Toolbar.Control_Alignment_Left);
	
	inheritMethod();

	frm.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	frm.addButton(self.btnEnquire, CMUI_Toolbar.Control_Alignment_Left);
	frm.addButton(self.btnEdit, CMUI_Toolbar.Control_Alignment_Left);

	frm.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	frm.addButton(self.btnLocate, CMUI_Toolbar.Control_Alignment_Left);
	//epr  tfs 37584  7/5/18
	if self.myTrackedItem &lt;&gt; null and  self.myTrackedItem.doesCurrentTAUseSideAccess(REAL_MODE) then
		frm.addFrame(self.frmMachine,CMUI_Toolbar.Control_Alignment_Left);
		self.myAssistant.comboBoxMachinesForTA(self.cmbMachine,self.myTrackedItem.myPrimaryActualLocation.myTerminalArea,MACHINETYPEGRP_LIFTER);
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
