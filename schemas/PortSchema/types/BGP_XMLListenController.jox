<Class name="BGP_XMLListenController" id="3e7b7f8b-c949-4d63-9388-2120ea8ec031">
    <superclass name="BGP_Controller"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>&lt;display&gt;TCPIP Server.&lt;/display&gt;</text>
    <DbClassMap file="backgroundprocess"/>
    <PrimAttribute name="loggingLevel" id="b14145ac-2bf3-473b-8fde-f35bcaf9fa26">
        <embedded/>
        <type name="Integer"/>
        <access>readonly</access>
    </PrimAttribute>
