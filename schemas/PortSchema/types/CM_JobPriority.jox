    <JadeMethod name="isJob" id="d5b63a31-2a9d-4c1a-bbc9-2350693250e1">
        <source>isJob() : Boolean;
/*
Purpose:			
Date				Who			Reason
NOVEMBER 2014		CNWAB1		Initial creation
*/
vars
begin
	if self.jobType = JobTypePriority_DischargeDLR20 
	or self.jobType = JobTypePriority_DischargeDLR40 
	or self.jobType = JobTypePriority_DischargeIMP20
	or self.jobType = JobTypePriority_DischargeIMP40 
	or self.jobType = JobTypePriority_SOB
	or self.jobType = JobTypePriority_LoadDLR20 
	or self.jobType = JobTypePriority_LoadDLR40 
	or self.jobType = JobTypePriority_LoadExport20
	or self.jobType = JobTypePriority_LoadExport40 then
		return true;
	endif;
	
	return false;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isLoad" id="d3b57974-23f3-4cea-9e54-861726d5b60f">
        <source>isLoad() : Boolean;
// ---------------------------------------------------------------------------
// Created:		11 May 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
begin
	if self.jobType = JobTypePriority_LoadDLR20 
		or self.jobType = JobTypePriority_LoadDLR40 
		or self.jobType = JobTypePriority_LoadExport20
		or self.jobType = JobTypePriority_LoadExport40 then
		return true;
	endif;
	
	return false;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
