    <JadeMethod name="getReceivalCutoff" id="28a694ff-60bf-40dc-afea-7c8359002e61">
        <source>getReceivalCutoff(_earliestTS, _cutoffTS, _earliestTSPN, _cutoffTSPN : TimeStamp output);
/* 
par 26864 	cnwjre1 May 2011 speed up the code - refactor the setup code out of matchesRecCutoffCriteria
par 29158 	cnwcs5 	March 2012 - ignore EDI cutoffs
01 May 2012 cnwer1 	PAR 29487 - some refactoring done just gets the cutoff from the ti
*/
vars
	voyage 			: CM_Voyage;
	cutoffCode 		: String;
	ti		 		: CM_TrackedItem;
	type	 		: CM_CargoType;
begin
	_earliestTS	:= null;
	_cutoffTS	:= null;
	
	if self.myBookingReference = null then
		return;
	endif;
	
	voyage := self.myBookingReference.myVoyage;
	
	if voyage = null then
		return;
	endif;

	// set dummy ti off booking ref to match criteria fields
	type := self.myCargoType;
	
	if type = null then
		return;
	endif;

	create ti as currentSchema.getClass(type.classNameToCreate) transient;
	
	ti.setTIFromBookingRefItem(self);
	
	if ti.isPreNote() then //04/03/2025	navkc1 JIRA Story MTN-34227
		ti.getReceivalCutoffDetailsPN(cutoffCode,_earliestTSPN,_cutoffTSPN); //04/03/2025	navkc1 JIRA Story MTN-34227
	else
		ti.getReceivalCutoffDetails(cutoffCode,_earliestTS,_cutoffTS);
	endif;

epilog
	delete ti;
end;</source>
        <Parameter name="_earliestTS" type="TimeStamp" usage="output"/>
        <Parameter name="_cutoffTS" type="TimeStamp" usage="output"/>
        <Parameter name="_earliestTSPN" type="TimeStamp" usage="output"/>
        <Parameter name="_cutoffTSPN" type="TimeStamp" usage="output"/>
    </JadeMethod>
