        <updating/>
        <source>cmbVoyage_lostFocus(combobox: CMUI_ComboForVoyageActive input) updating;
// ---------------------------------------------------------------------------
// Created:     21 October 2003	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	tbl			: CM_EntryTable;
	
begin
	if (not CM_EntryTable.hasInstance(combobox.parent)) then
		return;
	endif;
	
	tbl := combobox.parent.CM_EntryTable;	
	
	if combobox.listObject &lt;&gt; null then
		tbl.setValueByControlName(combobox.name, combobox.listObject.CM_Voyage.code);
		//epr par 20675 24/9/09
		self.cmbDisPort.setObjectAndVoyage(self.cmbDisPort.listObject.CM_Port,combobox.listObject.CM_Voyage);
		self.cmbTranship.setObjectAndVoyageDischPort(self.cmbDisPort.listObject.CM_Port,combobox.listObject.CM_Voyage);
	else
		tbl.setValueByControlName(combobox.name, null);
	endif;
	combobox.doChangedCompareForEntryTable();

end;</source>
