    </JadeMethod>
    <JadeMethod name="drawGraphic" id="b4c9124b-bd19-4f47-96e2-c9b95ab6bd80">
        <source>drawGraphic(_frame: Frame input; _scale: Real; _offsetX: Integer; _offsetY: Integer; 
			_flippedH: Boolean; _drawFills : Boolean; _fillColour : Integer ; _lengthScale : Integer; _text : String;
			_length : Integer);
// ---------------------------------------------------------------------------
// Created:		02 December 2005  By Andrew Bishop cnwab1
//
// Purpose:		Default box
//
// ---------------------------------------------------------------------------

vars
	lengthScale, length, fntSize, txtX, txtY, boxWidth : Integer;
	xyS : 	RealArray;
begin
	lengthScale := _lengthScale; // handle 20/40
	if lengthScale = 0 then
		lengthScale := 1;
	endif;
	
	length := _length;
	if length = 0 then
		length := 60;
	endif;
	boxWidth := ((length * lengthScale)).Integer;
/*
	create xyS transient;

	xyS.add((_offsetX - 0));	
	xyS.add((_offsetY - (30 * _scale) ));	

	xyS.add((_offsetX +  boxWidth));	
	xyS.add((_offsetY - (30 * _scale)) );	

	xyS.add((_offsetX + boxWidth) );	
	xyS.add((_offsetY - 0) );	

	xyS.add((_offsetX - 0) );	
	xyS.add((_offsetY - 0) );	

	xyS.add((_offsetX - 0) );	
	xyS.add((_offsetY - (30 * _scale)) );	

	if _drawFills then
		_frame.drawFillColor := _fillColour;
//		_frame.drawFilledPolygon(xyS,Black);
		_frame.drawFilledRectangle(_offsetX,(_offsetY - (30 * _scale) ),(_offsetX + boxWidth),_offsetY,Black);
	else
		_frame.drawPolygon(xyS,Black);
	endif;
*/	

	if _drawFills then
		_frame.drawFillColor := _fillColour;
		_frame.drawFilledRectangle(_offsetX,(_offsetY - (30 * _scale) ),(_offsetX + boxWidth),_offsetY,Black);
	else
		_frame.drawRectangle(_offsetX,(_offsetY - (30 * _scale) ),(_offsetX + boxWidth),_offsetY,Black);
	endif;

	if _text &lt;&gt; null then
		txtX := _offsetX + (boxWidth / 2).Integer;
		txtY := (_offsetY - (11 * _scale) ).Integer;
		_frame.drawTextAlign := Frame.DrawTextAlign_Center;
		fntSize := 6;
		if lengthScale &gt; 1 then
			fntSize := 8;
		endif;
		_frame.drawFontSize := (_scale * fntSize);
		_frame.drawTextAt(_text,txtX,txtY,_fillColour.getInverseColour());
	endif;	
epilog
//	delete xyS;
end;</source>
        <Parameter name="_frame" type="Frame" usage="input"/>
        <Parameter name="_scale" type="Real"/>
        <Parameter name="_offsetX" type="Integer"/>
        <Parameter name="_offsetY" type="Integer"/>
        <Parameter name="_flippedH" type="Boolean"/>
        <Parameter name="_drawFills" type="Boolean"/>
        <Parameter name="_fillColour" type="Integer"/>
        <Parameter name="_lengthScale" type="Integer"/>
        <Parameter name="_text" type="String"/>
        <Parameter name="_length" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getDefaultGraphicXML" id="93a04bb7-cc28-4905-946c-253138fd5c41">
        <source>getDefaultGraphicXML() : String;
/* ---------------------------------------------------------------------------
Created:     03 March 2009 by cnwrs2

Purpose:     PAR 18996
        
Change Date	Who		Reason

------------------------------------------------------------------------------*/
vars

begin
	//return null;
	return self.class.text;  //cnwjo3.  lets store the default xml graphic in the class' text.
	
	//NOTE:  There cannot be line breaks (CrLfs) between &lt; &gt; and between &lt;XML&gt;Value&lt;/XML&gt;
	//changing CM_TIBehaviourGraphic::setXMLData to deal with this just in case
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
