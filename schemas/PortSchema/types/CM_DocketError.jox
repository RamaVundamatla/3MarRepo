vars
	
begin

	self.resetAuditsDuringDelete();	//25 Jan 2021	NDL	TFS 50152

end;</source>
    </JadeMethod>
    <JadeMethod name="getAuditTextForProperty" id="fd4d66d3-ef0d-4c95-8f9c-6dfa84d46489">
        <source>getAuditTextForProperty(_property: Property): String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
12 February 2010	cnwas3	Initial creation

*/

vars

begin
	
	if _property.name = CM_DocketError::myDocketErrorType.name then
		return self.formatAuditText(CM_DocketError::myDocketErrorType.name, self.docketErrorDesc);
	elseif _property.name = CM_DocketError::docketErrorCode.name then
		return self.formatAuditText(CM_DocketError::docketErrorCode.name, self.docketErrorCode);
	/*elseif _property.name = CM_DocketError::docketErrorCount.name then	commented by #2984 21/05/2010
		return self.formatAuditText(CM_DocketError::docketErrorCount.name, self.docketErrorCount.asStringJMT());*/
	endif;
	return inheritMethod(_property);

epilog

end;</source>
        <Parameter name="_property" type="Property"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="b91e405f-ffd8-4ebd-b71a-af84eda96446">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
01 February 2010	cnwas3	Initial creation

*/

vars

begin
//	if _attrName = ETRow_DocketError or 
//	   _attrName = ETRow_DocketErrorDescription then //12/01/2010 cnwdz2 21836
	   
	 if _attrName = ETRow_DocketError then
		return self.getDocketErrorDescription();
		
	/*elseif _attrName = ETRow_PieceCountError then	commented by #23894 21/05/2010
		return self.getIsPieceCountError().String;
	elseif _attrName = ETRow_DriversPieceCount then
		return self.getDocketErrorCount().String;*/

	endif;
	
	return inheritMethod(_attrName, _short);

epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDocketErrorCode" id="8dcda09f-519f-4a9e-ae0a-0cf0778014b4">
        <source>getDocketErrorCode() : String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
01 February 2010	cnwas3	Initial creation

*/

vars

begin
	return self.docketErrorCode.toUpper();
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDocketErrorDescription" id="0e7b8782-bb5d-4ff9-8c60-023162af6edb">
        <source>getDocketErrorDescription() : String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
01 February 2010	cnwas3	Initial creation

*/

vars

begin
	
	if self.myDocketErrorType &lt;&gt; null then
		return self.myDocketErrorType.description;
	else
		return self.docketErrorDesc;
	endif;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="45cd88ff-f461-41a7-a518-1f0c2cb07ec7">
        <source>pxyCreateUpdateProxy(): SelfType;

/*

Purpose:			

Date				Who		Reason
01 February 2010	cnwas3	Initial creation
20/04/2011			cnwmh5	PAR #27401 - Add code to handle prossible exceptions occurring when
							trying to create the proxy
*/

vars
	tempDE : CM_DocketError;
	completedOK		: Boolean;
begin
	
	tempDE :=  inheritMethod();
	
	tempDE.myDocketErrorType := self.myDocketErrorType;
	tempDE.myBol:=self.myBol;
	
	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return tempDE;

epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete tempDE;
	endif;

end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
