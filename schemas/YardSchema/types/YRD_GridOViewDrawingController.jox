    <JadeMethod name="getNewFrameIndex" id="7049df06-afef-4872-80fa-bd0b5a15230a">
        <source>getNewFrameIndex(_obj : Object; _type : String) : Integer;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
04 July 2013	cnwer1	Initial creation par 31523

*/

vars
	classID,instanceID,
	newIdx: Integer;
begin
	_obj.getOidString.oidStringToClassAndInstanceId(classID,instanceID);
	if instanceID.String.length &gt; 4 then
		instanceID:=instanceID.String[instanceID.String.length -3 : instanceID.String.length].Integer;
	endif;
	newIdx:=(_type &amp; instanceID.String).Integer;
	return newIdx;
epilog

end;</source>
