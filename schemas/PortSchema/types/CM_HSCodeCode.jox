    <JadeMethod name="getMyParent" id="e1cc35e5-a28b-4e21-839f-6f0f572d3a10">
        <source>getMyParent() : CM_HSCodeHeading;
/*

Purpose:			

Parameters:			

Return Value:		

Date					Who		Reason
09 December 2022		jlizm1	Initial creation TFS 55280 Harmonized System Codes

*/

vars

begin
	if self.myHSHeading &lt;&gt; null and self.myHSHeading.isTransient and not self.myHSHeading.pxyIsProxy then
		return app.myRoot.allHSHeadings[self.myHSHeading.id];
	endif;
	
	return self.myHSHeading;

epilog

end;</source>
        <ReturnType type="CM_HSCodeHeading"/>
    </JadeMethod>
