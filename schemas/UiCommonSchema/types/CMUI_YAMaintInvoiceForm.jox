vars

begin
	
	inheritMethod(); // TFS 6536

// TFS 6536	if self.saveData(true) then
// TFS 6536		self.populateTable(true);
// TFS 6536	endif;
end;
</source>
    </JadeMethod>
    <JadeMethod name="doTblRowColumChg" id="1a7e7cc3-cf1c-4750-9b62-174c938a9626">
        <updating/>
        <source>doTblRowColumChg(_table : Table input) updating;
//	enable controls and populate from the current 
vars
	theObject 	: Object;
	ct			: TimeStamp;
	invalid		: Boolean;
	invLineDesc	: String;
	mapping : CM_TranMapInvoiceLineMapping;
	ild : CM_InvoiceLineDesc;
begin

	if _table.row &lt;= _table.fixedRows then
		return;
	endif;

	theObject := _table.accessRow(_table.row).itemObject;
	if theObject &lt;&gt; null then
		on Exception do app.handleDeletedObject(exception, theObject, invalid);
		ct := theObject.creationTime;
	endif;
	
	if invalid then
		return;
	endif;
	self.isNew := false;
	if _table.row = 1 then
		self.btnRemove.enabled := false;
	endif;
	
	if theObject.isKindOf(CM_QuantityRangeMap) then	
		self.myYardAllocation := theObject.CM_QuantityRangeMap.myQuantityMap.myInvoiceAllocation;
		self.myQuantityRangeMap := theObject.CM_QuantityRangeMap;
		invLineDesc := _table.accessCell(_table.row, _table.columns).text;
		
		foreach mapping in self.myQuantityRangeMap.allTMInvoiceLineMappings do // TFS 40620
			ild := mapping.myTMInvoiceLineDesc; // TFS 40620
			if ild.narration = invLineDesc then// TFS 40620
				self.myInvoiceLineDesc := ild;// TFS 40620
				break;// TFS 40620
			endif;// TFS 40620
		endforeach;// TFS 40620
		
		
		// TFS 40620 self.myInvoiceLineDesc := self.myQuantityRangeMap.allInvoiceLinesUsed[invLineDesc];
	endif;

	self.setupFromCurrentItem();
end;
</source>
        <Parameter name="_table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="enableCriteriaControls" id="6cd9e07e-0457-4dca-9d3e-a8c783d08f4f">
        <updating/>
        <source>enableCriteriaControls() updating;
// on an add, enable the criteria controls but keep their values
vars
	criteriaCtrl	: CMUI_YACriteriaCntl;
	i				: Integer;

begin
	while true do
		i := i + 1;
		criteriaCtrl := self.frmCriteria.getControl(i);
		if criteriaCtrl = null then
			break;
		endif;
		if criteriaCtrl.visible then	
			criteriaCtrl.enabled := true;
		endif;
	endwhile;

end;
</source>
    </JadeMethod>
    <JadeMethod name="getCriteriaAllCMIF" id="46b35f57-d3f6-4517-bde5-342b53bc460b">
        <source>getCriteriaAllCMIF( _cmifArray	: CMIF_Array input );

vars
	cmifCriteria 	: CMIF_YACriteriaPriority;
	criteria 		: CM_YACriteria;
	criteriaCtrl	: CMUI_YACriteriaCntl;
	i				: Integer;
	invAlloc 		: CM_InvoiceAllocation;
	bValue			: Any;
	nullString		: String;

begin
	//  Create transient maintenance objects for all existing criteria and mark for delete action

	invAlloc := self.myProxyYA.CM_InvoiceAllocation;
	if invAlloc &lt;&gt; null then
		foreach criteria in invAlloc.allCriteria do
			cmifCriteria := criteria.getTransient();
			cmifCriteria.setFlag(false, false, true);	
			_cmifArray.add(cmifCriteria);
		endforeach;
	endif;

	//  For each criteria control - update/add transient maintenance object

	while true do
		i := i + 1;
		criteriaCtrl := self.frmCriteria.getControl(i);
		if criteriaCtrl = null then
			break;
		endif;
		//if criteriaCtrl.visible and criteriaCtrl.hasValue() then			
		if criteriaCtrl.visible then			
			//epr TFS 1822 28/4/16
			bValue := criteriaCtrl.getValue();
			
			if bValue.isKindOf(String) and bValue.String = "(DEFAULT)" then
				bValue := nullString;	// NOTE: nullString rather than null, because a null Any ends up in YA_DATA pattern as '** not initialised **' rather than null
			endif;
			self.getCriteriaSingleCMIF( _cmifArray, criteriaCtrl.getCriteriaType(), bValue );
		endif;
	endwhile;
	
epilog

end;</source>
        <Parameter name="_cmifArray" type="CMIF_Array" usage="input"/>
    </JadeMethod>
