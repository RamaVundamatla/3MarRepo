    <JadeMethod name="trxUpdateSubBlockStack" id="1fc30843-ec53-4625-9fc1-2883d0b2d9df">
        <updating/>
        <source>trxUpdateSubBlockStack(theGridArea : CMIF_GridTARegion input;_theRealSubBlock : CM_SubBlockStack output;
					_passport : CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:		August 2001 By Andrew Bishop cnwab1
//
// Purpose:		to convert a grid area into a sub block stack.
//				This assumes that the proxy sub has all the locations that are to be part of the sub block in its allByPassedControllers
//				The controllers in allByPassedControllers will be proxy copies of the real thing. The proxy copies have had their 
//				real object link set. In updating the sub block we simply update the real controllers mySubBlockStack with the new real subBlockStack  
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	realBlockStack : CM_BlockStack;
	
begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	if theGridArea = null then
		app.raiseCMException1(ERR_NO_OBJECT, "Sub Block Stack TA", null, null);
	endif;

	beginTransaction;
	app.myUtilityUA.utlUpdateSubBlockStack(theGridArea,_theRealSubBlock, _passport); // pass in both to check edition
epilog
	self.finaliseActivityWithPassport(_passport);
end;</source>
        <Parameter name="theGridArea" type="CMIF_GridTARegion" usage="input"/>
        <Parameter name="_theRealSubBlock" type="CM_SubBlockStack" usage="output"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
