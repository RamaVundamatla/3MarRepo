        <source>comboBoxFieldExtWebServices(_fieldObj : CMUI_FieldComboBox input; _extWebService : CM_ExternalWebServiceDef);
//
// 11 June 2018	jlgrs1	TFS 39013 (37190) Pelindo BGP Web Service
//
vars
	extWebService : CM_ExternalWebServiceDef;
begin
	_fieldObj.clear;
	foreach extWebService in app.myRoot.allExternalWebServices where extWebService.canBGPRun do //jlier1 TFS 56856 28/3/23
		_fieldObj.addItemObject(extWebService.name, extWebService);
	endforeach;
	if _extWebService &lt;&gt; null then
		_fieldObj.setForObject(_extWebService);
