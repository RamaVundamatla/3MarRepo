    <JadeMethod name="delete" id="b6f48e4a-1464-42ab-85d3-7a418f191982">
        <updating/>
        <executionLocation>client</executionLocation>
        <source>delete() updating, clientExecution;
/*

Date		Who		Reason
02 March 2017	cnwer1	Initial creation TFS

*/

vars
	tmpAttach			: CMIF_InOutAttachment;
begin
	if self.myIntFacePreNote &lt;&gt; null then
		if self.myIntFacePreNote.hasAttachments then
			// remove reference to attachment to prevent them from being deleted
			foreach tmpAttach in self.allAttachments do
				tmpAttach.setMasterItem(null);
				//proxy parent and children are deleted along with self.myIntFacePreNote;
				tmpAttach.setMyProxyTrackedItem(null);
			endforeach;
		else
			self.allAttachments.purge;
		endif;
		delete self.myIntFacePreNote;
	endif;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="displayRowPreNote" id="2eb0f2b8-613b-443d-8259-26782d659986">
        <source>displayRowPreNote(pTI: CM_TrackedItem): String;
// ---------------------------------------------------------------------------
// Created:     18 April 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	str	: String;
	
begin

	if self.isDataFiltered then
		// data is filtered
		//if filterId &lt;&gt; null and not pTI.id.startsWith(filterId) then
		if filterId &lt;&gt; null and not pTI.id.startsWith(filterId) and not pTI.id.endsWith(filterId) then   // 18/05/2010 cnwmh5 #23339
		   //filterId &lt;&gt; pTI.id then PAR4928
		   	return null;
		endif;
		if filterOperatorCode &lt;&gt; null and
		   filterOperatorCode &lt;&gt; pTI.operatorCode then
		   	return null;
		endif;
		if filterBookingReference &lt;&gt; null and not pTI.bookingReference.startsWith(filterBookingReference) then
		   //filterBookingReference &lt;&gt; pTI.bookingReference then PAR4928
		   	return null;
		endif;

	endif;

/*	str := pTI.consignor &amp; Tab &amp;
		   pTI.consignee &amp; Tab &amp; 
		   pTI.operatorCode &amp; Tab &amp;
		   pTI.wagon &amp; Tab &amp;		   
		   pTI.bookingReference &amp; Tab &amp;
		   pTI.voyageCode &amp; Tab &amp;
		   pTI.id;
		   
	return str;*/
	return pTI.getAttributeStringForDefArray(tblData.allTblDataEntRows);
end;</source>
        <Parameter name="pTI" type="CM_TrackedItem"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="doBookingRefRowChange" id="04822798-28f1-4563-81a2-9c3f36a5c522">
        <source>doBookingRefRowChange(table: CM_EntryTable input);
/*
	Created on 06 March 2008
	
	by Debby Hutchison
	
	Purpose:

Date		Who		Reason
01 Oct 2008	consw1	Par 17090 Replace app.getMyTerminal with form's myTerminal	
*/

vars
	operatorString,
	bookRefNumber,
	opCode				: String;
	bookRef 			: CM_BookingRef;
	terminal			: CM_Terminal;
	currentBRItem 		: CM_BookingRefItem;
begin
	terminal := self.myTerminal;
	bookRefNumber := table.getValueByName(ETRow_BookingReference).String.trimRight;
	if cmbOperator.listObject &lt;&gt; null then
		opCode	:= cmbOperator.listObject.CM_Operator.code;
	endif;
	bookRef := terminal.getBookingReference(opCode, bookRefNumber, cmbVoyage.listObject.CM_Voyage); // adm 150908 Par 17936
	if cmbBRItem.listObject &lt;&gt; null then
		currentBRItem := cmbBRItem.listObject.CM_BookingRefItem;
	endif;
	self.loadBookingRefItems(bookRef);

	if currentBRItem &lt;&gt; null and currentBRItem.myBookingReference = bookRef then
		cmbBRItem.setObject(currentBRItem);	
	elseif bookRef &lt;&gt; null and bookRef.allBookingRefItems.size = 1 then
		cmbBRItem.setObject(bookRef.allBookingRefItems.first);
	else
		cmbBRItem.setObject(null);
	endif;
	cmbBRItem.lostFocus(cmbBRItem);
	inheritMethod(table);
end;	


</source>
        <Parameter name="table" type="CM_EntryTable" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doBtnEditType" id="c6aad7eb-75d2-439d-bbd8-216a3675704a">
        <updating/>
        <source>doBtnEditType() updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 February 2013	cnwmc5	Initial creation

*/

vars
	coll		: CM_TISet;
	saveValue	: Boolean;
	ti			: CM_TrackedItem;
	
begin
	if self.mode &lt;&gt; self.Mode_View then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Invalid mode for bulk type update');
		return;
	endif;
	
	// The form does not currently allow multi-edit but save
	// value and reset later in case ever changed
	saveValue					:= self.allowMultiSelectEdit;
	self.allowMultiSelectEdit	:= true;
	
	self.setDoingMultiEdit();
	
	create coll transient;
	self.tblData.allSelectedObjects.copy( coll );
	
	self.createMyAssistant( GTE_Assistant );		// just in case?
	
	self.myAssistant.GTE_Assistant.showEditTIReceiveType( coll );
epilog
	self.allowMultiSelectEdit := saveValue;
	
	delete coll;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doBtnModalDefaultClick" id="0e9665ea-24b7-4dd3-97b8-b2a06047aec8">
        <updating/>
        <source>doBtnModalDefaultClick() updating;
//--------------------------------------------------------------
//Created: 11 June 2003 By: cnwgd1
