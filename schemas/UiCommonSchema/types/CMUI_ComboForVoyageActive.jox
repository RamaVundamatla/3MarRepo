    <JadeMethod name="addVoyage" id="c120e3ba-f34a-4e02-9079-c10cdc3406be">
        <updating/>
        <source>addVoyage(_voyage : CM_Voyage; _setAsCurrent : Boolean) updating;
// ---------------------------------------------------------------------------
// Created:     24 May 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	idx 	: Integer;
begin
	idx := self.findObject(_voyage);
	if idx &lt;= 0 then
		idx := self.addItemObject(self.getDisplayString(_voyage), _voyage);
	endif;
	
	if _setAsCurrent then
		self.listIndex := idx;
	endif;

end;</source>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_setAsCurrent" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="armNotification" id="06f07f60-03de-4f7c-8657-624613a71f95">
        <updating/>
        <source>armNotification(_terminal : CM_Terminal)  updating;
//********************************************************************
//
// Created by: cnwsh3
//
// Date: 20 October 2003
//
//********************************************************************
vars

begin
	self.endNotificationForSubscriber(self);
	
	self.createEvent := _terminal.getTerminalEvent(Voyage_Create_Event);
	self.updateEvent := _terminal.getTerminalEvent(Voyage_Update_Event);
	self.deleteEvent := _terminal.getTerminalEvent(Voyage_Delete_Event);

	self.beginClassNotification(CM_Voyage, false, self.createEvent, Response_Continuous, 1);
	self.beginClassNotification(CM_Voyage, false, self.updateEvent, Response_Continuous, 2);
	self.beginClassNotification(CM_Voyage, false, self.deleteEvent, Response_Continuous, 3);
	
end;</source>
        <Parameter name="_terminal" type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="delete" id="23f42087-a8fc-4fde-8bf8-38cc73417580">
