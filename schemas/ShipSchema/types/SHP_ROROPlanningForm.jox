    <JadeMethod name="initJobsDataTable" id="3bbabeeb-b554-444d-9cfc-17014934b36f">
        <source>initJobsDataTable(_theEntDef : String);
/*
Date		    Who			Reason
23 September 2011	cnwas3	  Initial creation: CCMS 1035 CargoSideView form
*/

vars
	entTableView	: EntTableView;
	entTableDef		: EntTableDef;
	theTable		: CM_DataTable;
begin
	theTable := self.tblJobsData;
	
	theTable.userInputEnabled := false;
	theTable.selectMode := CM_EntryTable.SelectMode_FixedRow;
	theTable.selectionType := CM_EntryTable.SelectionType_Row;
	theTable.rows := theTable.fixedRows;
	theTable.cnEcResizeContents();
	
	entTableDef := app.myController.getEntTableDef(_theEntDef);
	theTable.setTblDataEntRowsFromDef(entTableDef);
	
	theTable.readOnly := false;	
	theTable.fixedColumns := 0;
	theTable.show3D := Table.Show3D_Not3D;

end;</source>
        <Parameter name="_theEntDef" type="String"/>
    </JadeMethod>
    <JadeMethod name="initJobsTable" id="e623e12e-9e17-4fa6-9058-4466563223d1">
        <source>initJobsTable();
/*
Date		    Who			Reason
23 September 2011	cnwas3	  Initial creation: CCMS 1035 CargoSideView form
*/

vars

	theTable			: CM_DataTable;
	showTimes,
	hideLashInfo, 		
	hideHatchJobs		: Boolean;
	entViewName			: String;
	
begin
		
	theTable := self.tblJobsData;
	self.tblJobsData.disallowColumnSorter := true;
	self.tblJobsData.allowDragSelect := true;
	
	
	self.tblJobsData.rows :=0; // PAR 19921
	self.initJobsDataTable(ETDef_ROROPlanningJobs);	
	self.tblJobsData.sortColumn[1] := 0;
	theTable.fixedColumns := 0;
	
	theTable.fixed3D := false;
	theTable.accessColumn(1).width := 75;
	theTable.multiSelect := CM_BaseTable.MultiSelect_Simple;

	self.setJobsHeaderRows();
	
	theTable.fixedRows := 2;
	theTable.accessRow(1).backColor := self.colorHeadingColumn;
	theTable.accessRow(2).backColor := self.colorHeadingColumn;
	theTable.selectMode := Table.SelectMode_FixedRow;
end;</source>
    </JadeMethod>
    <JadeMethod name="initLoadCCTable" id="b5c9a50c-370b-47e5-89c1-01f25d191d6f">
