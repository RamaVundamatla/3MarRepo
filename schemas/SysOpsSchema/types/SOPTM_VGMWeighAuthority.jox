epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="showThumbnail" id="9214bda0-2f09-46ea-8275-7217bd3808b5">
        <updating/>
        <source>showThumbnail(_weighAuthority : CM_WeighAuthority) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 19/06/2017	cnwdap1		Initial creation TFS 4492 SNO VERMAS Changes
//
vars
	form : SOP_TableMaintForm;

begin
    form := self.myForm;
	form.tblInput1.clearValues;

	form.tblInput1.setValueByName(ETRow_WeightCertifiedBy, _weighAuthority.certifiedName);
	form.tblInput1.setValueByName(ETRow_WeightAuthorisedBy, _weighAuthority.authorisedName);
	form.tblInput1.setValueByName(ETRow_AddressLine1, _weighAuthority.address1);
	form.tblInput1.setValueByName(ETRow_AddressLine2, _weighAuthority.address2);
	form.tblInput1.setValueByName(ETRow_AddressLine3, _weighAuthority.address3);
	form.tblInput1.setValueByName(ETRow_EmailAddress, _weighAuthority.email1);
	form.tblInput1.setValueByName(ETRow_EmailAddress2, _weighAuthority.email2);
	form.tblInput1.setValueByName(ETRow_Phone, _weighAuthority.phone1);
	form.tblInput1.setValueByName(ETRow_Phone2, _weighAuthority.phone2);
	form.tblInput1.setValueByName(ETRow_SolasMethod, _weighAuthority.solasMethod);
	form.cmbSolasType.findStringExact(1, _weighAuthority.solasMethod);
	form.tblInput1.setValueByName(ETRow_NotAvailableForEntry, _weighAuthority.notAvailableForUse);
	
	self.showThumbnail_Terminal(_weighAuthority);
epilog
	
end;</source>
        <Parameter name="_weighAuthority" type="CM_WeighAuthority"/>
    </JadeMethod>
    <JadeMethod name="showThumbnail_Terminal" id="ef283e93-5511-49c2-bc95-aa5dae6de455">
        <source>showThumbnail_Terminal(_weighAuth : CM_WeighAuthority) protected;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 23/06/2017	cnwdap1		Initial creation TFS 4492 SNO VERMAS Changes
//
vars
	table : CM_DataTable;
	terminal : CM_Terminal;
	row : Integer;
	authTerm : CM_WeighAuthTerminal;
	default : Boolean;
	
begin
	table := self.myForm.tblData1;
	table.rows := 0;

	foreach terminal in app.myRoot.allTerminals do		
		row := table.addItemObject(terminal, app.getErrorString(Terminal) &amp; ': ' &amp; terminal.code &amp; Tab &amp; app.getErrorString(Default));
		table.accessRow(row).fontBold := true;
		table.accessRow(row).backColor := Gray;
		
		default := false;
		if _weighAuth &lt;&gt; null then
			authTerm := _weighAuth.allWeighAuthTerminals[terminal];
		endif;
		if authTerm &lt;&gt; null then
			if authTerm.isDefaultForTerminal then
				default := true;
			endif;
			row := table.addItemObject(terminal, "1" &amp; Tab &amp; default.cnEcGetTableCheckBoxValue);
			table.accessCell(row, 1).inputType := Table.InputType_CheckBox;
			table.accessCell(row, 2).inputType := Table.InputType_CheckBox;
		else
			row := table.addItemObject(terminal, "0" &amp; Tab &amp; "0");
			table.accessCell(row, 1).inputType := Table.InputType_CheckBox;
			table.accessCell(row, 2).inputType := Table.InputType_CheckBox;
		endif;
	endforeach;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_weighAuth" type="CM_WeighAuthority"/>
    </JadeMethod>
</Class>
