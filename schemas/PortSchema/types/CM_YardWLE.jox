    <JadeMethod name="getInTargetOrOutSourceForRoad" id="b664c020-21b0-4ca5-b512-23ce67bf229c">
        <source>getInTargetOrOutSourceForRoad(): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 July 2017	jlgndl1	Initial creation	TFS 5312

*/

vars

	rtQueueEntry : CM_RTQueueEntry;
	rtQueueTask : CM_RTQueueTask;
	invalid : Boolean;
	wle : CM_YardWLE;

begin

	if self.isTransient then
		wle := self.pxyGetRealObject().CM_YardWLE;
	else
		wle := self;
	endif;
	
	if wle = null then
		return null;
	endif;
	
	on Exception do app.handleDeletedObject( exception, rtQueueEntry, invalid );
	foreach rtQueueEntry in wle.allRTQueueEntries do
		if rtQueueEntry.status = TASK_COMPLETE then
			continue;
		endif;
		break;
	endforeach;
	
	if rtQueueEntry &lt;&gt; null and rtQueueEntry.status &lt;&gt; TASK_COMPLETE then
		on Exception do app.handleDeletedObject( exception, rtQueueEntry, invalid );
		if self.isReceipt then
			rtQueueTask := rtQueueEntry.allTasks.last;
			if rtQueueTask &lt;&gt; null then
				return rtQueueTask.targetLocationId;
			endif;
		else
			rtQueueTask := rtQueueEntry.allTasks.first;
			if rtQueueTask &lt;&gt; null then
				return rtQueueTask.sourceLocationId;
			endif;
		endif;
	endif;

	return inheritMethod();

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getLocationForMode" id="f4f68585-b03a-4f30-bb97-b05597789b90">
        <source>getLocationForMode(_mode : Integer): CM_LocationsController;
//--------------------------------------------------------------
//Created: 20 May 2003 By: cnwgd1
//--------------------------------------------------------------
/*

Date		Who		Reason
19 May 2010	cnwkpd1	PAR #20728 - remove isValidObject calls for performance

*/

vars
	location : CM_LocationsController;
	req : CM_Request;
	ta : CM_TerminalArea;
	tStr : String;
	theTerminal : CM_Terminal;
	foundHeight		: Integer;
	invalid, hasChassis 		: Boolean;
	ed				: Integer;
	chassis 	: CM_TILC;
begin

	if self.myRequest.isKindOf(CM_ReceivalRequest) then			// cnwjk3 ccms 1018 22/02/10
		// We can't move these anywhere							// cnwjk3 ccms 1018 22/02/10
		return null;											// cnwjk3 ccms 1018 22/02/10
	endif;														// cnwjk3 ccms 1018 22/02/10
	
	if (not self.isReceipt) and _mode = PLANNING_MODE then
		if self.job.isKindOf(CM_RoadJob) then
			
			//get release chassis if there is one should queue to the chassis rather than the truck
			
			chassis := self.job.CM_RoadJob.getChassis(false,hasChassis);
			
			if hasChassis then
			
				if chassis = null then
					location:=self.job.CM_RoadJob.myVehicle.myUnknownChassis;
				else
					if  chassis &lt;&gt; self.myTrackedItem then
						location:=chassis.getNextFreeLC();
					else
						location := self.job.CM_RoadJob.myVehicle.locationsController; //epr par35023 22/10/14
					endif;
				endif;
			else
				location := self.job.CM_RoadJob.myVehicle.locationsController;
			endif;
		endif;
	endif;
	
	if location = null then
		//th2 added 18/05/06 - resolve to the roadJob sheets unknown location is still nul here
		//this happens in the circumstance were an empty truck has come into the yard with
		//only releases by ISO type
		if CM_RoadJob.hasInstance(self.job) and self.myTrackedItem = null then
			location := self.job.myJobSheet.CM_RoadJobSheet.myInTerminalUnknownLC;
		endif;
		
		if CM_RailJob.hasInstance(self.job) then
			location := self.allLocationControllers.first();
		endif;
		
	endif;
	
	
	if location = null then
		req := self.myRequest;
	
		if req.isKindOf(CM_YardDeliveryRequest) then
		
			theTerminal := self.job.CM_YardInternalJob.myTerminal;
		
			tStr	:= req.CM_YardDeliveryRequest.targetLocation;
			ta		:= req.CM_YardDeliveryRequest.myTargetTA;
			
			if ta = null then
				invalid := true;
			else
				on Exception do app.handleDeletedObject(exception, ta, invalid);
				invalid := false;
				ed := ta.edition();
				on Exception do null;
			endif;
			
//			if not global.isValidObject(ta) then
			if invalid then
				ta	:= theTerminal.lookupTerminalArea(tStr);
			endif;
	
			if ta = null then
				//--------------------
				//Try a jadeFindLocation call, tStr maybe a specific location (ie, C 23031)
				//--------------------
				theTerminal.findLocationFromString(tStr, false, location, foundHeight);
			endif;
			
			if location = null and ta &lt;&gt; null then
				location := ta.getLocationsController();
				
			endif;
		elseif req.isKindOf(CM_WOMoveRequest) then
			theTerminal := self.job.CM_YardInternalJob.myTerminal;
		
			tStr	:= req.CM_WOMoveRequest.targetLocation;
			ta		:= req.CM_WOMoveRequest.myTargetTA;

			if ta = null then
				invalid := true;
			else
				on Exception do app.handleDeletedObject(exception, ta, invalid);
				invalid := false;
				ed := ta.edition();
				on Exception do null;
			endif;
			
//			if not global.isValidObject(ta) then
			if invalid then
				ta	:= theTerminal.lookupTerminalArea(tStr);
			endif;
	
			if ta = null then
				//--------------------
				//Try a jadeFindLocation call, tStr maybe a specific location (ie, C 23031)
				//--------------------
				theTerminal.findLocationFromString(tStr, false, location, foundHeight);
			endif;
			
			if location = null and ta &lt;&gt; null then
				location := ta.getLocationsController();
				
			endif;
		
		endif;	
	endif;

	//shifted to end of method so above can take prescedence.
	// cnwrd1 par 23245 27.5.2010
	if location = null then
		location := inheritMethod(_mode);
	endif;
	
	
	return location;

end;</source>
        <Parameter name="_mode" type="Integer"/>
        <ReturnType type="CM_LocationsController"/>
    </JadeMethod>
    <JadeMethod name="getLocationForWOMove" id="25bbd237-8af0-4e82-aa4a-b00efd0bad8a">
        <source>getLocationForWOMove(): CM_LocationsController;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
23 November 2009	cnwrd1	Initial creation
19 May 2010	cnwkpd1	PAR #20728 - remove isValidObject calls for performance

*/

vars
	location 	: CM_LocationsController;
	req 		: CM_Request;
	theTerminal : CM_Terminal;
	ta 			: CM_TerminalArea;
	tStr 		: String;
	foundHeight	: Integer;
	invalid 	: Boolean;
	ed			: Integer;
	
begin

	req := self.myRequest;

	if req.isKindOf(CM_WOMoveRequest) then
		theTerminal := self.job.CM_YardInternalJob.myTerminal;
	
		tStr	:= req.CM_WOMoveRequest.targetLocation;
		ta		:= req.CM_WOMoveRequest.myTargetTA;

		if ta = null then
			invalid := true;
		else
			on Exception do app.handleDeletedObject(exception, ta, invalid);
			invalid := false;
			ed := ta.edition();
			on Exception do null;
		endif;
			
//		if not global.isValidObject(ta) then
		if invalid then
			ta	:= theTerminal.lookupTerminalArea(tStr);
		endif;

		if ta = null then
			//--------------------
			//Try a jadeFindLocation call, tStr maybe a specific location (ie, C 23031)
			//--------------------
			theTerminal.findLocationFromString(tStr, false, location, foundHeight);
		endif;
		
		if location = null and ta &lt;&gt; null then
			location := ta.getLocationsController();
			
		endif;
		
	endif;	
	
	return location;

epilog

end;</source>
        <ReturnType type="CM_LocationsController"/>
    </JadeMethod>
    <JadeMethod name="getMoveAmountDisplay" id="474a0331-5995-49cc-b140-ca98c458d499">
        <source>getMoveAmountDisplay(_showUnit: Boolean): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 May 2020	jlgndl1	Initial creation
12 August 2022 navmv20 Bug 54164: MTN - When using the "Any Amount" option, the Move Amount is not presented correctly
*/

vars

begin
	
	//if self.isAnyAmount then	//20 May 2020	NDL	TFS 49167			//12/08/2022 navmv20 TFS 54164
	if self.status &lt;&gt; WLE_COMPLETED and self.isAnyAmount   then			//12/08/2022 navmv20 TFS 54164
		return app.getErrorString( AnyAmount );
	endif;
	
	return inheritMethod(_showUnit);

epilog

end;</source>
        <Parameter name="_showUnit" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getMoveDescription" id="5c7b6dd6-120b-4387-859e-6721e1c5b774">
        <source>getMoveDescription() : String;
// ---------------------------------------------------------------------------
// Created:     08 September 2008 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	myTI : CM_TrackedItem;
	myLocation : CM_LocationsController;
	//qFM : CM_FutureMoveQueued;
	tmpStr : String;
	fM : CM_FutureMove;
begin

	myTI := self.myTrackedItem;
	//qFM := self.myFutureMove.CM_FutureMoveQueued;//cnwas3 commented out autocompletecnwas3
	
	fM := self.myFutureMove;
	
	if fM &lt;&gt; null then
		myLocation := fM.getPrimaryLocation();
	endif;
	/*if qFM &lt;&gt; null then
		myLocation := qFM.allLocationsControllers.first;
	endif;*///cnwas3 commented out
	
	if myTI = null and myLocation = null then
		return null;
	endif;
	
	if myLocation &lt;&gt; null then
		tmpStr := myLocation.getFullIdTI(myTI);
	else
		if self.isReceipt then
			return "Take " &amp; myTI.id &amp; " to the yard.";
		else
			return "Pick up " &amp; myTI.id &amp; " from the yard.";
		endif;
	endif;
	if self.isReceipt then
		return "Take " &amp; myTI.id &amp; " to yard position " &amp; tmpStr &amp; ".";
	else
		return "Pick up " &amp; myTI.id &amp; " from yard position " &amp; tmpStr &amp; ".";
	endif;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getMySourceLocation" id="8eb03938-0760-4d6d-b29b-37da86a1f89a">
        <source>getMySourceLocation() : CM_LocationsController;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
18 August 2010	cnwrd1	Initial creation
//cnwrd1 par 25488 18.8.2010
*/

vars
	rtqtask : CM_RTQueueTask;
begin

	if not self.allRTQueueEntries.isEmpty then
		rtqtask  := self.allRTQueueEntries.first.getDirectorOrPickupTask();
		if rtqtask &lt;&gt; null then
			return rtqtask.getSourceLocation;
		endif;
	endif;
	
				
	return null;
	
epilog

end;</source>
        <ReturnType type="CM_LocationsController"/>
    </JadeMethod>
    <JadeMethod name="getMyTrackedITem" id="cabac00f-b0fc-483b-b19a-e50f4c016ff7">
        <source>getMyTrackedITem(): CM_TrackedItem;
/*

Purpose:	Here for packages don't delete


Return Value:		


Date		Who		Reason
14 September 2006	cnwer1	Initial creation - PAR#xxxx

*/
vars

begin
	return inheritMethod();


epilog

end;</source>
        <ReturnType type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="getOrigTiFromGTEReceival" id="b52c959e-7bc4-49a5-9573-9847b562cb5f">
        <source>getOrigTiFromGTEReceival():CM_TrackedItem;
/*

Purpose:			
			// cargo that has been unloaded and merged into an existing cargo item then split to be reloaded to the truck will not 
			// be the one originally recorded on the cmgte  ( Splits and Merges )
Parameters:			

Return Value:		

Date		Who		Reason
29 August 2018	jlgndl1	Initial creation	TFS 39769

*/

vars
	vvr 		 : CM_VehicleVisitRecord;
	cmgteReceive : CMGTE_Receival;
	ti			 : CM_TrackedItem;
begin

	ti := self.myTrackedItem;
	
	if ti = null then
		return null;
	endif;

	if self.job &lt;&gt; null and self.job.isRoadJob then
		vvr := self.job.CM_RoadJob.myVehicleVisit;
		if vvr &lt;&gt; null then
			cmgteReceive := vvr.allGateEntities.getMatchingGTEReceive( ti.myCargoType.id, ti.id );
			if cmgteReceive &lt;&gt; null then
				return cmgteReceive.myTrackedItem;
			endif;
		endif;
	endif;	
	
	return null;

epilog

end;</source>
        <ReturnType type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="getQueuedSourceLoc" id="514bcd4c-4f8c-4706-bbdb-cab9d563040c">
        <source>getQueuedSourceLoc(): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 Aug 2025	navbs1	Initial creation Story MTN-35549: TPT | Source Location for RT Moves on the Road Ops Screen - Dev

*/

vars
	queuedLocation 		: String;
	rtEntry 			: CM_RTQueueEntry;
	rtTask 				: CM_RTQueueTask;
	request				: CM_Request;
begin
	if self.isCompleted then 
		return null;
	endif;
	if self.myTrackedItem &lt;&gt; null then 
		return null;
	endif;
	
	if not self.isReleaseByType then 
		return null;
	endif;
	
	request := self.myRequest;
	
	if request.isKindOf(CM_DeliveryRequest) then 
		queuedLocation := request.CM_DeliveryRequest.queuedLocation; 
	endif;
	
	return queuedLocation;
	
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getRTLetter" id="0af66054-ee32-4481-90b0-a4542cb38e6b">
        <source>getRTLetter(): String;

/*

Purpose:			

Parameters:			

Return Value:		


Date			Who		Reason
21 August 2009	cnwndl1	Initial creation	CCMS 1094
22 May 2019		jlgzm1	TFS 42840 MSL Direct Release between Voyages and Rail

*/

vars

	rtState	: String;
	
begin

	rtState := inheritMethod();

	if rtState = null 
	and self.status &lt;&gt; WLE_COMPLETED // AKB2009AUG
	and self.isYardReleaseAssigned then
		rtState := "A";
	endif;
	
	// tfs42840 start
	if self.isDRLinkedByFM then
		if self.myFutureMove &lt;&gt; null and
		   self.myFutureMove.moveType = TI_FutureMoveQueued then
			rtState := "Q DR";
		elseif self.myFutureMoveDR &lt;&gt; null and
		   self.myFutureMoveDR.moveType = TI_FutureMoveQueued then
			rtState := "Q DR";
		else
			rtState := "DR";
		endif;
	endif;
	// tfs42840 end
	
	return rtState;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getRelatedWLE" id="76be888e-a53d-41ae-8ac5-50b2f023970f">
        <source>getRelatedWLE() : CM_WorkListEntry;
//--------------------------------------------------------------
//Created: 21 May 2002 By: cnwgd1
//06 Mar 2025 navma1 MTN-34179 MTN | Dead Lock (1081) on CM_WLEArray
//--------------------------------------------------------------
vars
	tmpWle : CM_WorkListEntry;
	bol	   : CM_BOL;
begin

	bol := self.myBOL;
	
	if bol = null then
		return null;
	endif;

	foreach tmpWle in self.job.workListEntries discreteLock do		//06.03.2025 navma1 #MTN-34179
		if tmpWle.myBOL &lt;&gt; null 
		and tmpWle &lt;&gt; self 
		and tmpWle.myBOL = bol then
			return tmpWle;
		endif;
	endforeach;

	return null;
end;</source>
        <ReturnType type="CM_WorkListEntry"/>
    </JadeMethod>
    <JadeMethod name="getReleaseGateWeight" id="98bc9187-87d0-4bc7-aabb-c96e812044e5">
        <source>getReleaseGateWeight(): Decimal;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who			Reason
11 January 2024	navcs2	ChangeRequest 61549: EUP | Release Request by Weight - Pack/Load, Rail Lander
*/

vars
	request : CM_Request;
	gateEntity	: CMGTE_Entity;
begin
	request := self.myRequest;
	
	if request &lt;&gt; null and request.isKindOf(CM_YardRequest) then
		gateEntity := request.CM_YardRequest.myGateEntity;
		if gateEntity &lt;&gt; null and gateEntity.isKindOf(CMGTE_Release) then
			return gateEntity.CMGTE_Release.releaseWeight;
		else
			return 0;
		endif;
	else
		return 0;
	endif;
epilog

end;</source>
        <ReturnType type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="getReleaseReference" id="f4a2218f-e63f-4d02-92be-d2c7d9ba21bc">
        <source>getReleaseReference() : String;
// CALL BACK JRW REPORT - DO NOT DELETE
// ---------------------------------------------------------------------------
// Created:		January 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	req : CM_YardRequest;
	recReq : CM_ReceivalRequest;
	refStr : String;
	booking : CM_BookingRefItem;
begin
	if self.typeString.trimBlanks = "Receival" then
		if self.myTrackedItem &lt;&gt; null then
			refStr := self.myTrackedItem.bookingReference;
		endif;
	else
		req := self.myRequest.CM_YardRequest;
		if req &lt;&gt; null then
			if  self.myTrackedItem &lt;&gt; null then // PAR 19710
				refStr := self.myTrackedItem.deliveryRelease;
			endif;
			if refStr = null then
				refStr := req.deliveryNumber;		//ISO req usually
			endif;
		endif;
	endif;
	return refStr;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getRequestTargetLC" id="adc5eb95-daf8-4b69-a870-44f07a848d8c">
        <source>getRequestTargetLC() : CM_LocationsController;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
15 February 2010	cnwrd1	Initial creation
19 May 2010	cnwkpd1	PAR #20728 - remove isValidObject calls for performance

*/

vars
	req : CM_Request;
	tStr : String;
	ta : CM_TerminalArea;
	theTerminal : CM_Terminal;
	lc	: CM_LocationsController;
	foundHeight : Integer;
	invalid 		: Boolean;
	ed				: Integer;
	
begin

	req := self.myRequest;

	
	if req.isKindOf(CM_YardDeliveryRequest) then
		theTerminal := 	req.myTerminal;
	
		tStr	:= req.CM_YardDeliveryRequest.targetLocation;
		ta		:= req.CM_YardDeliveryRequest.myTargetTA;
		
		if ta = null then
			invalid := true;
		else
			on Exception do app.handleDeletedObject(exception, ta, invalid);
			invalid := false;
			ed := ta.edition();
			on Exception do null;
		endif;
			
//		if not global.isValidObject(ta) then
		if invalid then
			ta	:= theTerminal.lookupTerminalArea(tStr);
		endif;
	
		if ta = null then
			//--------------------
			//Try a jadeFindLocation call, tStr maybe a specific location (ie, C 23031)
			//--------------------
			theTerminal.findLocationFromString(tStr, false, lc, foundHeight);
			if lc = null then
			// CCMS 1309 Empty target location now valid. DVB 15/02/2005
			//	app.setContinueCMExceptions(false);
			//	app.raiseCMException1(ERR_INVALID_LOCN, tStr, null, null);
			//	return;
			endif;
		endif;
	
	
		if lc = null and ta &lt;&gt; null then
			lc := ta.getLocationsController();
		endif;
		
		return lc;
	else
		return null;
	endif;

epilog

end;</source>
        <ReturnType type="CM_LocationsController"/>
    </JadeMethod>
    <JadeMethod name="getRequestType" id="2441bef4-9590-4698-b109-238ae544058d">
        <source>getRequestType(): Integer;
// ---------------------------------------------------------------------------
// Created:		February  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

	ioType : Integer;
	reqType : Integer;

begin
	//epr par 33221 3/3/14
	if self.myRequest = null then
		return REQ_UNDEFINED;
	endif;
	
	sharedLock(self.myRequest);
	if self.myRequest.isKindOf(CM_DeliveryRequest) then
		reqType := REQ_ISO_RELEASE;
	else
		if self.myRequest.CM_YardRequest.isReceipt then
			reqType := REQ_TI_RECEIPT;
		else
			reqType := REQ_TI_RELEASE;
		endif;
	endif;

	return reqType;

epilog
	unlock(self.myRequest);

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getRoadOpsDelCurEntryOption" id="e353990e-f738-412c-9058-aeb5a0b6ab90">
        <source>getRoadOpsDelCurEntryOption() : Integer;
/*
Purpose: Returns currently selected option when deleting an entry in Road Operation screen

Parameters:			

Return Value:		

Date		Who		TFS		Reason
29 Oct 2019	jlgdi1	46578	Initial creation
*/

vars
	terminal : CM_Terminal;
	selectedOpt : Integer;
	
begin
	terminal := self.getMyTerminal;
	if terminal &lt;&gt; null then
		selectedOpt := terminal.getConfig(RoadOpsDelCurEntryOption).Integer;
	endif;
	
	return selectedOpt;
end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getRoadReceiptLC" id="285339bd-1852-4800-993b-9dc558ea1f4e">
        <source>getRoadReceiptLC() : CM_LocationsController;
/*

Date		Who		Reason
19 May 2014	cnwer1	Initial creation PAR 34107

*/

vars
	hasChassis : Boolean;
	chassis 	: CM_TILC;
	roadJob : CM_RoadJob;
begin
	if self.job = null or not self.job.isKindOf(CM_RoadJob) then
		return null;
	endif;
	
	if not self.isReceipt then
		return null;
	endif;
	
	roadJob:=self.job.CM_RoadJob;
	

	chassis:= roadJob.getChassis(true,hasChassis);
	if hasChassis then
		if chassis &lt;&gt; null then
			return chassis.getNextFreeLC;
		else
			return roadJob.myVehicle.myUnknownChassis;
		endif;
	endif;
	
	return roadJob.myVehicle.locationsController;

epilog

end;</source>
        <ReturnType type="CM_LocationsController"/>
    </JadeMethod>
    <JadeMethod name="getRoadReleaseLC" id="35d6f1e1-3146-4f7e-ad56-7b1689040bde">
        <source>getRoadReleaseLC(): CM_LocationsController;
/*

Date		Who		Reason
14 January 2014	cnwer1	Initial creation PAR 33302

*/

vars
	hasChassis : Boolean;
	chassis 	: CM_TILC;
	roadJob : CM_RoadJob;
begin
	if self.job = null or not self.job.isKindOf(CM_RoadJob) then
		return null;
	endif;
	
	roadJob:=self.job.CM_RoadJob;
	
	if self.isReleaseToChassis then
		chassis:= roadJob.getChassis(false,hasChassis);
		if chassis &lt;&gt; null then
			return chassis.getNextFreeLC;
		else
			return roadJob.myVehicle.myUnknownChassis;
		endif;
	endif;
	
	if self.isReleaseToPack then
		return null;
	endif;
	
	return roadJob.myVehicle.locationsController;

epilog

end;</source>
        <ReturnType type="CM_LocationsController"/>
    </JadeMethod>
    <JadeMethod name="getRowColour" id="51942ac8-bb72-426c-b1ee-de91fd60e94e">
        <source>getRowColour(_foreColour: Integer output; _backColour: Integer output);
//--------------------------------------------------------------
//Created: 07 May 2003 By: cnwgd1
//--------------------------------------------------------------
vars
	alert : CM_SystemAlert;
begin

	if self.job.isKindOf(CM_RoadJob) and 
		job.CM_RoadJob.isTurnAroundJob and
		self.jobHasTurnAroundWLE() then
		_backColour := Red;
		_foreColour := Black;
	//elseif self.alerts.size &gt; 0 then
	
	/*	foreach alert in self.alerts discreteLock where alert.mySystemAlertType &lt;&gt; null  do 
			_foreColour := Black;
			_backColour := White;
			if not alert.reviewed then
				_foreColour := Red;
				_backColour := White;
				break;
			endif;
		endforeach;*/
	else
		inheritMethod(_foreColour, _backColour);
	endif;
	
	

end;</source>
        <Parameter name="_foreColour" type="Integer" usage="output"/>
        <Parameter name="_backColour" type="Integer" usage="output"/>
    </JadeMethod>
    <JadeMethod name="getSourceLocationId" id="14c28406-67c8-4767-b340-8cbb2029c7f7">
        <source>getSourceLocationId() : String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
18 August 2010	cnwrd1	Initial creation
//cnwrd1 par 25488 18.8.2010
*/

vars
	source : String;
	rtqtask : CM_RTQueueTask;
begin

	if self.allRTQueueEntries.isEmpty then
		if self.myRequest &lt;&gt; null then
			return self.myRequest.getSourceLocationID();
		endif;
	else
		rtqtask  := self.allRTQueueEntries.first.getDirectorOrPickupTask();
		if rtqtask &lt;&gt; null then
			return rtqtask.getSourceLocationId;
		endif;
	endif;
	
				
	return null;
	
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getTargetLocation" id="333969f3-2514-4950-a164-e24b5f3510c2">
        <source>getTargetLocation(): CM_LocationsController;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
09 August 2019		jlgzm1	TFS 42840 MSL - Direct Delivery Between LOLO RORO Voyages and Rail

*/

vars
	locCont : CM_LocationsController;
	invalidObject : Boolean;
begin
	locCont := inheritMethod();

	if locCont = null then
		
		if self.myFutureMoveDR &lt;&gt; null then
			on Exception do app.handleDeletedObject( exception, self.myFutureMoveDR, invalidObject );
			locCont := self.myFutureMoveDR.getPrimaryLocation();
		endif;
	endif;
	
	return locCont;

epilog

end;</source>
        <ReturnType type="CM_LocationsController"/>
    </JadeMethod>
    <JadeMethod name="getTargetTIForPack" id="4380a279-ca81-4c8f-b66c-1f09707345c8">
        <source>getTargetTIForPack() : CM_TrackedItem;
/*

Date		Who		Reason
14 Jul 2014	cnwer1	Initial creation PAR
17 Mar 2025 navma1  MTN-34120 MTN | Dead Lock (1081) on CM_OfflineFutureActorParentDct
*/

vars
	roadJob 	: CM_RoadJob;
	gteEntity   : CMGTE_Entity;
	parentTI 	: CM_TrackedItem;
	wle	 		: CM_WorkListEntry;
	request		: CM_Request;
	parentGte   : CMGTE_Entity;
begin
	
	if self.job = null then
		return null;
	endif;
	
	if not self.job.isRoadJob then			//17.03.2025 navma1 #MTN-34120
		return null;
	endif;

	roadJob := self.job.CM_RoadJob;
	
	request := self.myRequest;				//17.03.2025 navma1 #MTN-34120
	
	if request = null or not request.isKindOf(CM_YardRequest) then
		return null;
	endif;
	
	gteEntity := request.CM_YardRequest.myGateEntity;
	
	if gteEntity = null then
		return null;
	endif;
	
	parentGte := gteEntity.myParent;
	
	if parentGte = null then
		return null;
	endif;
	
	parentTI := parentGte.getTI;
	
	if parentTI = null then
		if parentGte.isKindOf(CMGTE_Release) then
			if  parentGte.myYardRequest.isKindOf (CM_DeliveryRequest) then
				wle := parentGte.myYardRequest.CM_DeliveryRequest.allWorkListEntries.first;
				if wle &lt;&gt; null then
					return wle.myTrackedItem;
				endif;
			endif;
		endif;	
		return null;
	endif;
	
	if self.myRequest.isReleaseType then
		if parentTI &lt;&gt; null then
			return parentTI;
		endif;
	else
		if parentTI.getImExStatus &lt;&gt; TI_IMEX_STATUS_REMAINONBOARD then
			return null;
		endif;
		
		if parentTI.myPrimaryActualLocation = roadJob.myVehicle.locationsController then
			return parentTI;
		endif;
	endif;
	
	return null;
epilog

end;</source>
        <ReturnType type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="getTaskTypeDesc" id="492183ae-24d2-4750-adbb-b40db6ee44da">
        <source>getTaskTypeDesc(): String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
17 July 2009	cnwrd1	Initial creation

*/

vars
	str : String;
begin

	/*if self.job.myWODtl &lt;&gt; null then
		str := 'Work Order Move';
	elseif self.myRequest.isKindOf(CM_YardDeliveryRequest ) then
		str := 'Delivery Request';
	elseif self.myRequest.isKindOf( CM_YardMoveRequest) then
		str := 'Move Request';
	else
		return 'Move';
	endif;*/
	
	str := 'Move';
	
	return str;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="id" id="29414425-69d6-415a-bedf-69b43925a9ef">
        <methodInvocation>mapping</methodInvocation>
        <source>id(set: Boolean; value: String io) mapping;
// 29/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
vars
	aStr	:	String;
	ti : CM_TrackedItem;
begin
	if set then
		app.raiseSetVirtualError(class.name, method.name);
		return;
	endif;
	value := "";
	if self.myTrackedItem &lt;&gt; null then
		ti := self.myTrackedItem;
		if self.job &lt;&gt; null and self.job.isKindOf(CM_RailJob) then
			aStr := ti.rakePosition.trimRight &amp; " " &amp; ti.id.trimRight;
		else
			aStr := ti.id;
		endif;
	else
		aStr := self.job.jobId;
	endif;
	//The next line is PAINFULL! Removed to use a const. DQ 6/12/1999
	//maxLen := CM_WorkListEntry.getProperty("id").getLength;
	if aStr = null then
		return;
	endif;
	if aStr.length &gt; WLE_ID_LEN -1 then
		aStr := aStr[1:WLE_ID_LEN -1];
	endif;
	value := aStr;
end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="value" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="initiateDeletion" id="57a55365-609d-416a-9967-fbc67a4111c5">
        <source>initiateDeletion(_tiTransaction : CM_TITransaction io;
				 _reason : String;
				 _setToVoidInvoiceLines : Boolean);
/*
Purpose: Code reusability

Parameters:			

Return Value:		

Date		Who		TFS		Reason
08 Nov 2019	jlgdi1	46578	Initial creation
25 Nov 2019 jlgdi1	46578	Use the parameter '_reason'
*/

begin
	_tiTransaction.setForDelete(_reason);
	_tiTransaction.generateEditAuditForDelete(app.myPassport, null);
	if _setToVoidInvoiceLines then
		self.voidRoadReceiveInvoiceLine(_tiTransaction);
	endif;
end;</source>
        <Parameter name="_tiTransaction" type="CM_TITransaction" usage="io"/>
        <Parameter name="_reason" type="String"/>
        <Parameter name="_setToVoidInvoiceLines" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isChassisToRelease" id="6d4fd153-979b-4b11-abd0-a039eb51143f">
        <source>isChassisToRelease(): Boolean;
/*

Date		Who		Reason
13 January 2014	cnwer1	Initial creation PAR 33302

*/

vars

begin
	if not self.isReleaseTypeRequest then
		return false;
	endif;
	
	if self.job = null then
		return false;
	endif;
	
	if not self.job.isKindOf(CM_RoadJob) then
		return false;
	endif;
	
	if self.myRequest = null or not self.myRequest.isKindOf(CM_YardRequest) then
		return false;
	endif;
	
	if self.myRequest.CM_YardRequest.myGateEntity = null then
		return false;
	endif;
	
	if self.myRequest.CM_YardRequest.myGateEntity.isChassisOut then
		return true;
	endif;
	
	return false;

epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isCompleteForJob" id="6caa421c-0638-4492-819b-ea1dd41b28b3">
        <source>isCompleteForJob(): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
04 Feb 2011	cnwer1	Initial creation 25573
25 May 2011 cnwer1	par 27511 set to return true for turn around receipts
16 May 2016	cnwns1	TFS 488 - Multi Timezone Support
21 Feb 2018 jlgdap1	TFS 37198 NXL Unable to Plan Prenoted Containers to Rail
06 Mar 2025 navma1  MTN-34179 MTN | Dead Lock (1081) on CM_WLEArray
*/

vars
	roadJob				: CM_RoadJob;
	railJob 			: CM_RailJob;
	result,
	turnAround,  
	hasChassis			: Boolean;
	parentLC,
	currentLocation		: CM_LocationsController;
	timeNow				: TimeStamp;
	vehicleC			: CM_VehicleController;
	chassis				: CM_TILC;
	parentToPackTo 		: CM_TrackedItem;
	ti					: CM_TrackedItem;
	request				: CM_Request;
begin

	result	:= inheritMethod();
	timeNow := app.actualTimeServer;// 16 May 2016	cnwns1	TFS 488 - Multi Timezone Support	
	ti 		:= self.myTrackedItem;
	
	if ti = null or ti.isTBAorIsRRP then	// PAR #23794
		return false;
	endif;
	
	currentLocation := ti.getPrimaryLocation(REAL_MODE);
	request			:= self.myRequest;
	
	//get the job types
	if self.job.isRoadJob then
		roadJob		:= self.job.CM_RoadJob;
		turnAround 	:= roadJob.isTurnAroundJob 
						and self.isReceipt
						and self.jobHasTurnAroundWLE();
	elseif self.job.isRail then
		railJob 	:= self.job.CM_RailJob;
		if ti.isNotified then						//06.03.2025 navma1 #MTN-34179
			return false;
		endif;
		
	else
		if request.isYardDeliveryReq() then	
			//delivery request and is in the target location return complete
			if currentLocation = request.CM_YardDeliveryRequest.getTargetLC() then
				return true;	
			endif;
		elseif request.isKindOf(CM_WOMoveRequest)  then
		//move request and is in the planned location return complete
			if currentLocation = self.getLocationForMode(PLANNING_MODE) then
				return true;
			endif;
		elseif request.isTIRequest() then
		
			//ti request return inherited result - this based on rt queue tasks 
			if not self.checkTIRequestTI then
				return false;
			endif;
			return result;
		endif;
	endif;
	
	//epr par 27511 25/5/2011
	if request.isTIRequest and request.CM_TIRequest.trackedItem = null then
		// was turned around no ti to receipt/release
		return true;
	endif;
	
	if currentLocation = null then
		// must of been completed and the deleted
		if ti.state = TI_STATE_DELETED then
			return true;
		endif;
		//epr par 34523 1/8/14
		if roadJob &lt;&gt; null then
			if self.isReleaseTypeRequest then
				//we want to release and it has gone of site then
				return false;
			endif;
		endif;
		//is offsite and gone offsite after it had been received or released out the gate
		if ti.receivedDT.isValid
				and ti.releasedDT.isValid
				and ti.releasedDT.cnEcIsLessThanOrEqual(timeNow)
				and ti.receivedDT.cnEcIsLessThanOrEqual(ti.releasedDT) then
			return true;		
		endif;
	
		return result;
	endif;
	
	if roadJob &lt;&gt; null then
		if currentLocation.isVehicle then
			vehicleC := currentLocation.CM_VehicleController;
		endif;
		if self.isROB then
			//epr par 35023 21/10/14
			if self.isChassisToRelease then		
				if ti.myPrimaryActualLocation &lt;&gt; self.job.CM_RoadJob.myVehicle.locationsController then
					return false;
				endif;
			else
				if not self.isReceipt then
					chassis:=roadJob.getChassis(false,hasChassis);	
					if hasChassis then
						if not ti.myPrimaryActualLocation.isKindOf(CM_TILCController) or
							ti.myPrimaryActualLocation.CM_TILCController.myTILC &lt;&gt; chassis then
							return false;
						endif;
					else
						if ti.myPrimaryActualLocation &lt;&gt; self.job.CM_RoadJob.myVehicle.locationsController then
							return false;
						endif;
					endif;
				endif;
			endif;
			return true;
		endif;
		
		if self.isReleaseTypeRequest then
			if isReleaseToPack then
				parentToPackTo:=self.getTargetTIForPack();
				if parentToPackTo &lt;&gt; null then
					if ti.myParent = parentToPackTo then
						return true;
					else
						return false;
					endif;
				else
					return false;
				endif;
			endif;
			
			if not ti.isKindOf(CM_TILC) then 			
				chassis:=roadJob.getChassis(false,hasChassis);	
			endif;
			
			//epr par 33302 15/1/14
			if not hasChassis  then
				if currentLocation.isVehicle then
					//epr  31/7/14 34523
					return  self.job.CM_RoadJob.myVehicle.locationsController = vehicleC;
				else
					return false;
				endif;
			else
				//epr 34107 19/5/14
				if currentLocation.isKindOf(CM_TILCController)  and chassis &lt;&gt; null then
					if currentLocation.CM_TILCController.myTILC = chassis then
						return true;
					endif;
				endif;
			endif;
			
		else
			if currentLocation.isVehicle then			
				if ti.jobRoadReceive &lt;&gt; null then
					
					// to be receieved through the gate - must be on a different vehicle
					//epr  31/7/14 34523
					if self.job.CM_RoadJob.myVehicle.locationsController  &lt;&gt;  vehicleC then
						return true;
					else
						
						//epr 19/05/14 par 34107 can receive and release on the same chassis 
						if ti.jobRoadRelease &lt;&gt; null and 
							ti.jobRoadRelease = ti.jobRoadReceive then
							return true;
						endif;
						
					// or on same vehicle but is now a turn around job
						if turnAround then
							return true;
						endif;
					endif;
				else
					return false;
				endif;
			else
				//on the chassis and still on the truck then not complete
				if currentLocation.isKindOf(CM_TILCController) then
					parentLC := currentLocation.getParent.CM_LocationsController;
					//epr par 32560 25/9/13
					while parentLC &lt;&gt; null do
						//34523 1/8/14
						if parentLC = roadJob.myVehicle.locationsController then
							return false;
						else
							//check not on a chassis stacked on truck 
							if  parentLC.isKindOf(CM_TILCController) then
								parentLC:=parentLC.getParent.CM_LocationsController;
							else
								break;
							endif;
						endif;
					endwhile;
				endif;
				//not on a vehicle and is receival all gtg
				return true;
			endif;
		endif;
	endif;
	
	if railJob &lt;&gt; null then
		// is a release and is on a wagon
		if self.isReleaseTypeRequest then
			if  currentLocation.isWagon then
				return true;
			endif;	
		else
		
		// is a receival and has been taken of the wagon
			if not currentLocation.isWagon then
				return true;
			endif;
		endif;
	endif;

	
	return false;

epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isDirectDelivery" id="8c42329b-a80d-41ce-adda-bd05eede8d57">
        <source>isDirectDelivery():Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 January 2013	cnwndl1	Initial creation	Par 31102

*/

vars

	invalidObj : Boolean;

begin

	if self.status = WLE_COMPLETED then
		return false;
	endif;

	if self.myTrackedItem &lt;&gt; null then
		on Exception do app.handleDeletedObject( exception, self.myTrackedItem, invalidObj );
		return self.myTrackedItem.directDelivery;
	endif;

	return false;

epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isOpsViewData" id="63fe979c-d71a-4a57-97ee-eae8963c91aa">
        <source>isOpsViewData(): Boolean;
/*
Purpose:			

Date		Who		Reason
26 August 2021	navab1	TFS 51853
*/

vars
	correct : Boolean;
begin

	if self.isRoad 
	or self.isRail then // ### TFS 51855 06JAN2022 NAVAB1
		if self.myTrackedItem &lt;&gt; null then
			if self.myTrackedItem.isOpsViewData() then  // ### TFS 51853 02DEC2021 NAVAB1
				return true;
			endif;
		endif;
	endif;
	
	return false;

epilog

end;</source>
        <ReturnType type="Boolean"/>
