        <source>cmbConsignee_lostFocus(combobox: ComboBox input) updating;
/*
----------   ----------  --------------------------------------------------
Created:	12 September 2007 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars

