    <JadeMethod name="translateForm" id="6fbeda33-bb2c-408f-8c79-841fd29fccba">
        <updating/>
        <source>translateForm(locale : CM_Locale) updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	
begin
	// Determine the locale for translations.
	inheritMethod(locale);
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0013976, locale);
	btnInYardTemp.translateCaption(Xlat_0013977, locale);
	btnOnTruckTemp.translateCaption(Xlat_0013978, locale);
	frmCargoInYard.translateCaption(Xlat_0013979, locale);
	frmCargoOnTruck.translateCaption(Xlat_0013980, locale);
	lblNoCargoTruck.translateCaption(Xlat_0014246, locale);
	lblNoCargoYard.translateCaption(Xlat_0014247, locale);
	shtInYard.translateCaption(Xlat_0013981, locale);
	shtOnTruck.translateCaption(Xlat_0013982, locale);
end;</source>
        <Parameter name="locale" type="CM_Locale"/>
    </JadeMethod>
