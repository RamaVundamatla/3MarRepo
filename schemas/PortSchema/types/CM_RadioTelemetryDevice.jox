    <JadeMethod name="getRolloverValue" id="aae96ca4-a478-4ee0-9f40-becdad31ded9">
        <source>getRolloverValue() : Integer;
// -------------------------------------------
// Created 20 July 2004 by cnwdvb1
// -------------------------------------------
vars

	rollOver	: Integer;

begin

	rollOver := self.myRadioTelemetry.myTerminal.getConfig(LogHandheldRollOver).Integer;
	if rollOver &gt; 0 then
		return rollOver;
	endif;
	// Just return default Northport value.
	return 65535;


end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
