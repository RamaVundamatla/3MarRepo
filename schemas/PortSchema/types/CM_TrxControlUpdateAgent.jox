    <JadeMethod name="trxUpdateTIReleaseSubTerminal" id="64787bd4-5aa5-4d09-91c2-8a73460c4dd9">
        <source>trxUpdateTIReleaseSubTerminal();
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
