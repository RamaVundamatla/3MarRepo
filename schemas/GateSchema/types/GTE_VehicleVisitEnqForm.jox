    <JadeMethod name="addObjectsToTableVehicle" id="23a929e5-8666-4a91-9c17-0ed72d8606a1">
        <updating/>
        <source>addObjectsToTableVehicle(_vehicle : CM_Vehicle; _numItems: Integer io) updating, protected;
/*
----------   ----------  --------------------------------------------------
Created:	28 June 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	dict			: CM_VehicleVisitsByDT;
	iter			: Iterator;
	visit			: CM_VehicleVisitRecord;
	breakOut		: Boolean;
	passport		: CM_Passport;

begin
	passport := app.myPassport;
	
	dict := _vehicle.visitRecords;
	iter := dict.createIterator;
	
	if self.filterTimeIn.isValid() then
		dict.startKeyGeq(self.filterTimeIn, iter);
	endif;
	
	while iter.next(visit) do
		
		if self.includeObject(visit, passport) then
			self.addObjectToTable(visit, _numItems, breakOut);
		endif;
		
		if breakOut then
			break;
		endif;
	endwhile;


epilog
	delete iter;
end;</source>
        <access>protected</access>
        <Parameter name="_vehicle" type="CM_Vehicle"/>
        <Parameter name="_numItems" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="addToolbarControls" id="14512cf6-0a09-4abf-8003-bd24953506d3">
