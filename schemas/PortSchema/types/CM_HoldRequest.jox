    <JadeMethod name="validateWeightQtyUpdate" id="048be971-8dd0-47f6-9e9c-de9ef6e174f1">
        <source>validateWeightQtyUpdate( _wle : CM_WorkListEntry; _newWeight : Decimal; _newQty : Integer );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 June 2017	cnwndl1	Initial creation	TFS 4948

*/

vars

	ti : CM_TrackedItem;
	measure		: CM_MeasurementType;
	unit		: String;
	converted	: String;

begin
	
	if _wle = null then
		app.raiseCMException( Work_list_entry_found, null, self );
		return;
	endif;
	
	ti := _wle.myTrackedItem;
	if ti = null then
		app.raiseCMException( MACH_NO_CONTAINER, null, self );
		return;
	endif;
	
	if ( _wle.weight &gt; 0 and _newWeight = 0 ) or ( _wle.quantity &gt; 0 and _newQty = 0 ) then
		app.raiseCMException1( Must_greater_than_zero, app.getErrorString(Move_amount), null, self );
		return;
	endif;
	
	if _newQty &gt; ti.totalQuantity then
		app.raiseCMException3( Move_amount_gtr_cargo, _newQty.String, ti.id, ti.totalQuantity.String, null, self );
		return;
	endif;
	
	if _newWeight &gt; ti.totalWeight then
		measure := ti.getDefaultMeasurementForType(Type_Weight);
		unit := measure.shortName;
		converted := app.convertMeasurementForDisplay(unit, _newWeight);
		app.raiseCMException3( Move_amount_gtr_cargo, converted &amp; Space &amp; unit, ti.id, ti.getDefaultTotalWeightDisplay, null, self );
		return;
	endif;

epilog

end;</source>
        <Parameter name="_wle" type="CM_WorkListEntry"/>
        <Parameter name="_newWeight" type="Decimal"/>
        <Parameter name="_newQty" type="Integer"/>
    </JadeMethod>
</Class>
