	commitTransaction;
end;</source>
    </JadeMethod>
    <JadeMethod name="cnwdad1_SpellWord_Load" id="27854540-03d9-483c-8c8b-9cc0aec176ea">
        <source>cnwdad1_SpellWord_Load();
// --------------------------------------------------------------------------------
// Created:		24 June 2001 by cnwdad1
//
// Purpose:		This will load spell words from a file that doesn't have CR as
//				file record delimiters.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
constants
	DISPLAY_LIMIT		: Integer = 1000;
	
vars
	fileObj				: File;
	fileOpenObj			: CMDFileOpen;
	fileData			: String;
	fileDataLength		: Integer;
	fileOpenResponse	: Integer;
	startPosition		: Integer;
	endPosition			: Integer;
	wordLength			: Integer;
	allWordTokens		: HugeStringArray;
	currentWord			: String;
	errorMessage		: String;
	spellRootObj		: CnEcSpellRoot;
	spellWordObj		: CnEcSpellWord;
	startTime			: Integer;
	wordCount			: Integer;
	displayCount		: Integer;
	
begin
	startTime		:=	app.clock();
	spellRootObj	:=	CnEcSpellRoot.firstInstance;
	
	if spellRootObj = null then
		app.msgBox("There are no instances of the Spell Word root.", "Error", MsgBox_Stop_Icon + MsgBox_OK_Only);
		return;
	endif;
	
	create fileOpenObj transient;
	fileOpenObj.fileMustExist	:=	true;
	fileOpenObj.createPrompt	:=	false;
	
	fileOpenResponse	:=	fileOpenObj.open;
	
	if fileOpenResponse = 0 then
		create fileObj transient;
		fileObj.kind := File.Kind_Unknown_Text; // 26/2/16  cnwns1 PAR 36286 unicode version
		fileObj.fileName	:=	fileOpenObj.fileName;
		
		fileData		:=	fileObj.readString(fileObj.fileLength());
		fileObj.close();
		fileDataLength	:=	fileData.length;
		startPosition	:=	1;
		
		beginTransaction;

		while true do
			endPosition	:=	fileData.pos(Lf, startPosition);
			
			if endPosition = 0 then
				allWordTokens	:=	fileData[startPosition:end].trimBlanks.getHugeTokens;
				
				foreach currentWord in allWordTokens do
					if (not currentWord.cnEcIsNumeric())
					and spellRootObj.allSpellWords.getAtKey(currentWord) = null
					then
						errorMessage	:=	spellRootObj.spellwordCreate(spellRootObj, currentWord.toLower, spellWordObj);
						wordCount		:=	wordCount + 1;
					endif;
				endforeach;
				
				delete allWordTokens;
				
				break;
			endif;
			
			wordLength		:=	endPosition - startPosition;
			allWordTokens	:=	fileData[startPosition:wordLength].trimBlanks.getHugeTokens;
				
			foreach currentWord in allWordTokens do
				if (not currentWord.cnEcIsNumeric())
				and spellRootObj.allSpellWords.getAtKey(currentWord) = null
				then
					errorMessage	:=	spellRootObj.spellwordCreate(spellRootObj, currentWord.toLower, spellWordObj);
					wordCount		:=	wordCount + 1;
					displayCount	:=	displayCount + 1;
				endif;
			endforeach;
				
			delete allWordTokens;
			
			startPosition	:=	endPosition + 1;
			
			if startPosition &gt; fileDataLength then
				break;
			endif;
			
			if displayCount &gt;= DISPLAY_LIMIT then
				commitTransaction;
				
				write wordCount.String &amp; " words loaded so far...";
				displayCount	:=	0;
				
				beginTransaction;
			endif;
		endwhile;

		commitTransaction;
				
	elseif fileOpenResponse = 1 then
		app.msgBox("The file load was cancelled.", "File Load", MsgBox_Information_Icon + MsgBox_OK_Only);
	else
		app.msgBox("Could not open file - error [" &amp; fileOpenResponse.String &amp; "]", "File Load", MsgBox_Information_Icon + MsgBox_OK_Only);
	endif;
epilog
	delete fileObj;
	delete fileOpenObj;
	
	write wordCount.String &amp; " words were read in " &amp; startTime.cnEcClockDifference().String &amp; " seconds.";
end;</source>
    </JadeMethod>
    <JadeMethod name="cnwdad1_StartService" id="0a3c30f1-6c46-4699-8c4c-56f8d7043ad6">
        <source>cnwdad1_StartService();
// --------------------------------------------------------------------------------
// Created:		06 February 2001 by cnwdad1
//
// Purpose:		Starts an NT Service by name for the Application Server.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	startResult	: Integer;
	serviceName	: String;
	
begin
	serviceName	:=	app.getProfileString(app.getIniFileName(), CNEC_INI_SECTION_BASESCHEMA, CNEC_INI_APPSERV_SERVICENAME, "");

	if serviceName &lt;&gt; null then
		// Start the application server's service.
		node.createExternalProcess('', 'NET START "' &amp; serviceName &amp; '"', null, '', false, true, startResult);
	endif;

	terminate;
end;</source>
    </JadeMethod>
    <JadeMethod name="cnwdad1_TestFileFolderSize" id="efdbab69-5125-4e5e-b908-170158975194">
        <source>cnwdad1_TestFileFolderSize() protected;
// --------------------------------------------------------------------------------
// Created:		22 June 2007 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	folderObj	: FileFolder;
	
begin
	create folderObj transient;
	folderObj.usePresentationFileSystem	:=	true;
	folderObj.fileName	:=	folderObj.browseForFolder("Select Folder", "c:\");
	write folderObj.cnEcGetSize(true).cnEcAsMegabytes().numberFormat();
	//write folderObj.cnEcGetSize(true).cnEcAsKilobytes().numberFormat();
epilog
	delete folderObj;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="cnwdad1_TestFileOpen" id="9118c72f-1737-4c10-9fe5-d5e9b2e456c4">
        <source>cnwdad1_TestFileOpen() protected;
// --------------------------------------------------------------------------------
// Created:		29 December 2005 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
constants
	FilterType	: Integer =	9;
	
vars
	fileOpenObj	: CMDFileOpen;
	
begin
	create fileOpenObj transient;
	
	if FilterType = 1 then
		fileOpenObj.cnEcSetFilters(true, 0, CNEC_FILE_FILTER_AUDIO, CNEC_FILE_FILTER_VIDEO);
	elseif FilterType = 2 then
		fileOpenObj.cnEcSetFilters(true, 0, CNEC_FILE_FILTER_ACCESS);
	elseif FilterType = 3 then
		fileOpenObj.cnEcSetFilters(true, 0, CNEC_FILE_FILTER_COMPRESSED);
	elseif FilterType = 4 then
		fileOpenObj.cnEcSetFilters(true, 0, CNEC_FILE_FILTER_DATA);
	elseif FilterType = 5 then
		fileOpenObj.cnEcSetFilters(true, 0, CNEC_FILE_FILTER_DBASE);
	elseif FilterType = 6 then
		fileOpenObj.cnEcSetFilters(true, 0, CNEC_FILE_FILTER_EXCEL);
	elseif FilterType = 7 then
		fileOpenObj.cnEcSetFilters(true, 0, CNEC_FILE_FILTER_EXEC);
	elseif FilterType = 8 then
		fileOpenObj.cnEcSetFilters(true, 0, CNEC_FILE_FILTER_FONT);
	elseif FilterType = 9 then
		fileOpenObj.cnEcSetFilters(true, 0, CNEC_FILE_FILTER_HTML);
	elseif FilterType = 10 then
		fileOpenObj.cnEcSetFilters(true, 0, CNEC_FILE_FILTER_IMAGE);
	elseif FilterType = 11 then
		fileOpenObj.cnEcSetFilters(true, 0, CNEC_FILE_FILTER_INI);
	elseif FilterType = 12 then
		fileOpenObj.cnEcSetFilters(true, 0, CNEC_FILE_FILTER_LOG);
	elseif FilterType = 13 then
		fileOpenObj.cnEcSetFilters(true, 0, CNEC_FILE_FILTER_TEXT);
	elseif FilterType = 14 then
		fileOpenObj.cnEcSetFilters(true, 0, CNEC_FILE_FILTER_WORD);
	elseif FilterType = 15 then
		fileOpenObj.cnEcSetFilters(true, 0, CNEC_FILE_FILTER_XML);
	endif;
	
	if fileOpenObj.open() = 0 then
	endif;
epilog
	delete fileOpenObj;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="cnwdad1_Test_Amortize" id="012e9190-da28-416a-8b41-249b1b8acaec">
        <source>cnwdad1_Test_Amortize();
// --------------------------------------------------------------------------------
// Created:		29 October 2001 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	amortizeObj		: CnEcAmortize;
	theInstalment	: CnEcLoanInstalment;
	startTime		: Integer;
	
begin
	startTime	:=	app.clock();
	create amortizeObj transient;
	
	amortizeObj.updateMe(12041.96, 8.00, 60, "01/11/1998".Date);
//	amortizeObj.updateMe(20000, 7.50, 60, "01/11/1998".Date);
	
	amortizeObj.calculateInstalments();
	
	foreach theInstalment in amortizeObj.allLoanInstalments do
		write	theInstalment.openingBalance.currencyFormat() &amp; "  " &amp;
				theInstalment.instalmentAmount.currencyFormat() &amp; "  " &amp;
				theInstalment.principalAmount.currencyFormat() &amp; "  " &amp;
				theInstalment.interestAmount.currencyFormat() &amp; "  " &amp;
				theInstalment.closingBalance.currencyFormat();
	endforeach;
	
	write "Total Repayment: " &amp; amortizeObj.getTotalRepayment().currencyFormat();
	write "Total Interest: " &amp; amortizeObj.getTotalInterest().currencyFormat();
epilog
	delete amortizeObj;
	
	write "Amortization completed in " &amp; startTime.cnEcClockDifference().numberFormat() &amp; " seconds.";
end;</source>
    </JadeMethod>
    <JadeMethod name="cnwdad1_Test_Analyzer" id="37bacb30-730b-43a7-b43c-887b19752826">
        <source>cnwdad1_Test_Analyzer() protected;
// --------------------------------------------------------------------------------
// Created:		16 May 2005 by cnwdad1
//
// Purpose:		Tests the BaseSchema Metadata Analyzer subclass.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	methodObj		: Method;
	methodSource	: String;
	analyzerObj		: CnEcBaseAnalyzer;
	errorCode		: Integer;
	errorPos		: Integer;
	errorLen		: Integer;
	message			: String;
	
begin
//	methodObj		:=	BaseSchema::cnEcSetBaseRoot;
	methodObj		:=	CnEcBaseSchemaAgent::trxBaseRootLastLogUpdate;
//	methodObj		:=	CnEcBaseRoot::setLastBackedUpLog;
	methodSource	:=	methodObj.getSource();
	
	create analyzerObj transient;
	
	analyzerObj.validateMethod(	methodSource,
								CnEcBaseSchemaAgent,
								currentSchema,
								errorCode,
								errorPos,
								errorLen,
								message);
	
	if errorCode = 0 then
		write "The method was validated successfully.";
	else
		write process.getErrorText(errorCode);
		
		if errorCode = analyzerObj.AccessCheckFailed then
			write message;
		endif;
	endif;
epilog
	delete analyzerObj;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="cnwdad1_Test_ArrayMove" id="dd662914-c371-49dd-82c6-b793e3422540">
        <source>cnwdad1_Test_ArrayMove() protected;
// --------------------------------------------------------------------------------
// Created:		14 March 2005 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	arrayObj		: ObjectArray;
	element			: Object;
	allSpellWords	: CnEcSpellWordByName;
	wordObj			: CnEcSpellWord;
	counter			: Integer;
	startTime		: Integer;
	
begin
	startTime	:=	app.clock();
	
	create arrayObj transient;
	
	allSpellWords	:=	CnEcSpellRoot.firstInstance().CnEcSpellRoot.allSpellWords;
	counter			:=	0;
	
	foreach wordObj in allSpellWords do
		arrayObj.add(wordObj);
		counter	:=	counter + 1;
		
		if counter &gt;= 6 then
			break;
		endif;
	endforeach;
	
	write "Before: ";
	
	foreach element in arrayObj do
		write element.CnEcSpellWord.name;
	endforeach;
	
	element	:=	arrayObj[4];
	
	arrayObj.cnEcMoveElement(element, false);
	
	write CrLf &amp; "After: ";
	
	foreach element in arrayObj do
		write element.CnEcSpellWord.name;
	endforeach;
epilog
	delete arrayObj;
	write CrLf &amp; "Moved array element in " &amp; startTime.cnEcClockDifference().numberFormat() &amp; " seconds.";
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="cnwdad1_Test_ArrayRandomSelect" id="d5443e1f-83ac-40da-85f5-79e794a9db28">
        <source>cnwdad1_Test_ArrayRandomSelect();
// --------------------------------------------------------------------------------
// Created:		22 March 2003 by cnwdad2
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	allCandidates		: StringArray;
	selectedCandidate	: String;
	counter				: Integer;
	
begin
	create allCandidates transient;
	
	allCandidates.add("Phar Lap");
	allCandidates.add("Sunline");
	allCandidates.add("Northerly");
	allCandidates.add("Ella Vajoy");
	allCandidates.add("Monaro");
	allCandidates.add("Halogen");
	allCandidates.add("Lyell Creek");
	allCandidates.add("Young Rufus");
	allCandidates.add("O'Reilly");
	allCandidates.add("Bob Dobalino");
	allCandidates.add("Desert Holly");
	allCandidates.add("Tuk Tuk");
	
	allCandidates.cnEcRandomSelect(10);
	allCandidates.cnEcSort(false);
	counter	:=	0;
	write "";
	
	foreach selectedCandidate in allCandidates do
		counter	:=	counter + 1;
		write counter.String &amp; ": " &amp; selectedCandidate;
	endforeach;
epilog
	delete allCandidates;
end;</source>
    </JadeMethod>
    <JadeMethod name="cnwdad1_Test_ArrayScramble" id="812e1062-4a97-428b-9906-cb25fad6b6ab">
        <source>cnwdad1_Test_ArrayScramble();
// --------------------------------------------------------------------------------
// Created:		23 March 2003 by cnwdad2
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	allCandidates		: StringArray;
	selectedCandidate	: String;
	counter				: Integer;
	
begin
	create allCandidates transient;
	
	allCandidates.add("Phar Lap");
	allCandidates.add("Sunline");
	allCandidates.add("Northerly");
	allCandidates.add("Ella Vajoy");
	allCandidates.add("Monaro");
	allCandidates.add("Halogen");
	allCandidates.add("Lyell Creek");
	allCandidates.add("Young Rufus");
	allCandidates.add("O'Reilly");
	allCandidates.add("Bob Dobalino");
	allCandidates.add("Desert Holly");
	allCandidates.add("Tuk Tuk");
	
	allCandidates.cnEcSort(false);
	counter	:=	0;	
	write CrLf &amp; "Unscrambled:";
	
	foreach selectedCandidate in allCandidates do
		counter	:=	counter + 1;
		write counter.String &amp; ": " &amp; selectedCandidate;
	endforeach;
	
	allCandidates.cnEcScramble();
	counter	:=	0;
	write CrLf &amp; "Scrambled:";
	
	foreach selectedCandidate in allCandidates do
		counter	:=	counter + 1;
		write counter.String &amp; ": " &amp; selectedCandidate;
	endforeach;
epilog
	delete allCandidates;
end;</source>
    </JadeMethod>
    <JadeMethod name="cnwdad1_Test_Array_Sort" id="af97fa1e-e44a-4371-9f51-91a16e70c88a">
        <source>cnwdad1_Test_Array_Sort();
// --------------------------------------------------------------------------------
// Created:		08 February 2001 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	decimalArray	: DecimalArray;
	decimalValue	: Decimal[23,2];
	startTime		: Integer;
	
begin
	startTime	:=	app.clock();
	create decimalArray transient;
	
	decimalArray.add(12.34);
	decimalArray.add(49.27);
	decimalArray.add(8.03);
	decimalArray.add(91.10);
	decimalArray.add(36.6);
	decimalArray.add(73.43);
	decimalArray.add(1.553);
	decimalArray.add(68.8);
	decimalArray.add(88.21);
	decimalArray.add(25.67);
	decimalArray.add(31.09);
	decimalArray.add(43.54);
	decimalArray.add(98.98);

	write CrLf &amp; "Unsorted:";
	
	foreach decimalValue in decimalArray do
		write decimalValue;
	endforeach;
	
	// Sort the array in descending order...
	decimalArray.cnEcSort(true);

	write CrLf &amp; "Sorted:";
	
	foreach decimalValue in decimalArray do
		write decimalValue;
	endforeach;
epilog
	delete decimalArray;
	
	write "Sort completed in " &amp; startTime.cnEcClockDifference().numberFormat() &amp; " seconds.";
end;</source>
    </JadeMethod>
