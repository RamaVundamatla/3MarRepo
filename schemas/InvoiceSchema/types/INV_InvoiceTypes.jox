    <JadeMethod name="populateEntDetailTable" id="c3c7ba39-325e-4aac-af62-dab7a8e05a05">
        <source>populateEntDetailTable();
// ---------------------------------------------------------------------------
// Created:		May 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
// Changed On	By			Reason
// ----------	---------	--------------------------------------------------
// 15/09/2015	cnwdap1		PAR #36909 CCMS ADP 2537 New Invocie Type of BOL
vars
	entRow			: EntTableRow;
	invoiceType : CM_InvoiceDesc;
	displayValue	: String;	

	entDef		:EntTableDef;
begin
	entDef := app.myController.getEntTableDef(ETDef_InvMainInvTypeData);

	invoiceType := self.myCurrentObject.CM_InvoiceDesc;
	if self.mode = Mode_Add then
		self.tblEntDetail.clearValues();
		return;
	endif;	
	if invoiceType = null then
		return;
	endif;
	
	foreach entRow in entDef.allEntTableRows do
		if invoiceType &lt;&gt; null then
			displayValue := invoiceType.getDisplayStringForAttribute(entRow.name, false).String;
		else
			displayValue := null;
		endif;
		
		tblEntDetail.setValueByName(entRow.name, displayValue);		
	endforeach;

	if invoiceType.myFinancialPeriodEnd = null then
		self.cmbAccuralType.listIndex := 1;
	else
		self.cmbAccuralType.listObject := invoiceType.myFinancialPeriodEnd;
	endif;
	
	if invoiceType.myInvTermsOfTrade = null then
		self.cmbTermsTrade.listIndex := 1;
	else
		self.cmbTermsTrade.listObject := invoiceType.myInvTermsOfTrade;
	
	endif;
	
	if invoiceType.invoiceKey = CM_InvoiceDesc.Key_VoyageGroup then // ### TFS 51219 25MAY2021 NAVAB1
		self.cmbSepInvoices.listIndex := 5; // ### TFS 51219 25MAY2021 NAVAB1
	elseif invoiceType.invoiceKey = CM_InvoiceDesc.Key_BOL then				// PAR #36909
		self.cmbSepInvoices.listIndex := 4;								// PAR #36909
	elseif invoiceType.invoiceKey = CM_InvoiceDesc.Key_Voyage then
		self.cmbSepInvoices.listIndex := 3;
	elseif invoiceType.invoiceKey = CM_InvoiceDesc.Key_CargoItem then	//Par 17895, September 2008
		self.cmbSepInvoices.listIndex := 2;
	else
		self.cmbSepInvoices.listIndex := 1;
	endif;
	
	if invoiceType.triggerOnAction = InvTypeTrigger_Release then
		self.cmbSepInvoices.listIndex := 1;
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="populateEntNarrTable" id="ddfb2af1-5207-4ab1-8dcd-e669f5f488bb">
        <source>populateEntNarrTable();
// ---------------------------------------------------------------------------
// Created:		May 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	entRow			: EntTableRow;
	invoiceType : CM_InvoiceDesc;
	displayValue	: String;	
	numCr, theRow : Integer;
	entDef		:EntTableDef;
begin
	entDef := app.myController.getEntTableDef(ETDef_InvMaintInvTypeNarr);

	if self.mode = Mode_Add then
		self.tblEntNarr.clearValues();
		self.cmbField1.listIndex:= 1;
		
		self.cmbField2.listIndex:= 1;
		self.cmbField3.listIndex:= 1;
		self.cmbField4.listIndex:= 1;
		self.cmbField5.listIndex:= 1;
		self.cmbAccuralType.listIndex:= 1;
		self.cmbTermsTrade.listIndex:= 1;
		self.cmbSepInvoices.listIndex:= 1;
		return;
	endif;
	invoiceType := self.myCurrentObject.CM_InvoiceDesc;
	
	foreach entRow in entDef.allEntTableRows do
		if invoiceType &lt;&gt; null then
			displayValue := invoiceType.getDisplayStringForAttribute(entRow.name, false).String;
		else
			displayValue := null;
		endif;

		self.tblEntNarr.setValueByName(entRow.name, displayValue);		
		// some of the free text has Cr in it so increase to height of the row to show the whole string
		numCr := displayValue.getNumberOfACharacter(Cr);
		if numCr &lt;&gt; 0 then
			theRow := self.tblEntNarr.getRowByName(entRow.name);
			numCr := numCr + 1;
			self.tblEntNarr.accessRow(theRow).height := (numCr * 15);
		endif;
	endforeach;

	self.cmbField1.listIndex := invoiceType.getComboIndex(2);
	self.cmbField2.listIndex := invoiceType.getComboIndex(4);
	self.cmbField3.listIndex := invoiceType.getComboIndex(6);
	self.cmbField4.listIndex := invoiceType.getComboIndex(8);
	self.cmbField5.listIndex := invoiceType.getComboIndex(10);
	
	
	self.txtNarr.text := self.getNarrationEx();
end;</source>
    </JadeMethod>
