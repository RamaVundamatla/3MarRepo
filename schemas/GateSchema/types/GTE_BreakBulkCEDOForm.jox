    <JadeMethod name="doSelectAll" id="76cc04f0-a293-4046-a137-c5fc1282778d">
        <source>doSelectAll();
//----------------------------------------------------------------
//	Created:	06 May 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------

vars
	numRows,
	rowIdx		: Integer;
	jRow		: JadeTableRow;
begin
	numRows := self.tblData.rows;
	self.tblData.allSelectedObjects.clear();

	if self.btnSelectAll.caption = app.getErrorString(SelectAll) then

		foreach rowIdx in self.tblData.fixedRows to numRows do
			jRow := self.tblData.accessRow(rowIdx);
			jRow.selected := true;
			if jRow.itemObject &lt;&gt; null then
				self.tblData.allSelectedObjects.add(jRow.itemObject);
			endif;
		endforeach;
	else
		foreach rowIdx in self.tblData.fixedRows to numRows do
			jRow := self.tblData.accessRow(rowIdx);
			jRow.selected := false;
		endforeach;
	
	endif;	

	inheritMethod();

end;</source>
    </JadeMethod>
    <JadeMethod name="doTblAddCreated" id="6c52e442-6ea6-4e68-83c0-8ff1da623274">
        <source>doTblAddCreated(_cusRes: CM_EDIFile);
//----------------------------------------------------------------
//	Created:	27 May 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	ediTI	: CM_EDITrackedItem;
	tbl		: CM_DataTable;
begin
	
	tbl := self.tblData;
	
	foreach ediTI in _cusRes.allEDITIs do
		if ediTI.cargoType &lt;&gt; TI_CargoType_BreakBulk then
			continue;
		endif;
		
		if self.includeObject(ediTI) then	//do filtering
			tbl.addItemObject(ediTI, ediTI.getAttributeStringForDefArray(tbl.allTblDataEntRows));
			self.armNotesForObject(ediTI);
		endif;
	
	endforeach;

end;</source>
        <Parameter name="_cusRes" type="CM_EDIFile"/>
    </JadeMethod>
    <JadeMethod name="doTblDataClick" id="a9b7650e-6927-4160-b409-75779674fe9c">
        <updating/>
        <source>doTblDataClick(table: Table input) updating;
//----------------------------------------------------------------
//	Created:	27 May 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin

	if self.frmQuery.visible then
		self.frmQuery.visible := false;
	endif;
	
	// TFS 2198 CNWAB1
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		self.btnDelete.enabled:= false;
		self.btnEditItem.enabled:= false;
	
	endif;

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doTblDataContextMenu" id="cae6e013-b645-43ad-a4b2-3ae511731c23">
        <updating/>
        <source>doTblDataContextMenu(cntrl: Table input; conwin: Window input; mouse: Boolean; x: Integer; y: Integer): Boolean updating;
//----------------------------------------------------------------
//	Created:	20 May 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin
	
	self.mnuContextSep01.visible := true;
	self.mnuContextTIEdit.visible := true;

//	uncomment after CCMS 1205/1206 patch
//	if app.isSpecial then
//		self.mnuInspectObject.visible := true;
//	else
		self.mnuInspectObject.visible := false;	
//	endif;
	
	// cnwrl1 16/02/2009 - (CCMS SFW 1047 - Totals Only Lists)
	self.mnuSummarise.visible	:= false;	// default this menu level to invisible, makes sub-menu invisible.
	
	if not self.tblData.allSelectedObjects.isEmpty then
		self.mnuContextTIEdit.enabled := true;
	else
		self.mnuContextTIEdit.enabled := false;
	endif;
	// TFS 2198 CNWAB1
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		self.mnuContextTIEdit.enabled := false;
		self.btnEditItem.enabled:= false;
		self.btnDelete.enabled:= false;
	endif;
	
	return self.showContextMenu(self.mnuContextTable,cntrl,conwin,mouse,x, y);

end;</source>
        <Parameter name="cntrl" type="Table" usage="input"/>
        <Parameter name="conwin" type="Window" usage="input"/>
        <Parameter name="mouse" type="Boolean"/>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doTblRemoveDeleted" id="8fc4b6de-537b-4fdf-bc00-a0d2f59ff34a">
        <source>doTblRemoveDeleted(_ediData: CM_EDIData);
//----------------------------------------------------------------
//	Created:	27 May 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	tbl		: CM_DataTable;
	intRow	: Integer;
	obj		: Object;
begin
	tbl := self.tblData;
	
	intRow := tbl.fixedRows+1;
	
	while intRow &lt;= tbl.rows do
		obj	:= tbl.accessRow(intRow).itemObject;
		if not global.isValidObject(obj) then
			tbl.removeItem(intRow);
			//don't increment row counter if removed
		else
			intRow := intRow + 1;
		endif;
	endwhile;
	
end;</source>
        <Parameter name="_ediData" type="CM_EDIData"/>
    </JadeMethod>
    <JadeMethod name="doTblTextSearchKeyUp" id="2155a417-4970-46a1-b7df-a632355deb10">
        <source>doTblTextSearchKeyUp() ;
//----------------------------------------------------------------
//	Created:	27 May 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	tbl				: CM_EntryTable;
	entTableDef		: EntTableDef;
	entTableView	: EntTableView;
	cellStr			: String;
	intRow			: Integer;

begin
//	tbl := self.tblTextSearch;
	tbl := self.tblSearchText;
	
	foreach intRow in 2 to tbl.rows do
		cellStr := tbl.accessCell(intRow, 2).text;
		if cellStr &lt;&gt; null then
			self.shtQuery2.caption := "Text Search*";
			return;
		endif;
	endforeach;

	self.shtQuery2.caption := "Text Search";

end;</source>
    </JadeMethod>
    <JadeMethod name="doTblUpdateObject" id="9c364336-4a49-4d0c-9029-0f4567e64c19">
        <source>doTblUpdateObject(_ediTI: CM_EDITrackedItem);
//----------------------------------------------------------------
//	Created:	27 May 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	idx		: Integer;
	tbl		: CM_DataTable;
begin
	tbl := self.tblData;
	
	if tbl.findObjectInRow(_ediTI, idx) then
		tbl.setCellText(idx, 1, _ediTI.getAttributeStringForDefArray(tbl.allTblDataEntRows));
		tbl.accessRow(idx).backColor := _ediTI.getDisplayRowColour();		
	endif;


end;</source>
        <Parameter name="_ediTI" type="CM_EDITrackedItem"/>
    </JadeMethod>
