    <JadeMethod name="translateForm" id="c1cdd07d-b635-4e7a-88e3-66dec53d76ad">
        <updating/>
        <source>translateForm(locale : CM_Locale) updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 26 November 2015.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	
begin
	// Determine the locale for translations.
	inheritMethod(locale);
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0013148, locale);
	btnFilter.translateCaption(Xlat_0021057, locale);
	lblCargoId.translateCaption(Xlat_0019050, locale);
	lblFilter.translateCaption(Xlat_0021058, locale);
	mnuContext.translateCaption(Xlat_0015237, locale);
	mnuGrades.translateCaption(Xlat_0015238, locale);
	mnuMove.translateCaption(Xlat_0015239, locale);
	mnuStops.translateCaption(Xlat_0015240, locale);
end;</source>
        <Parameter name="locale" type="CM_Locale"/>
    </JadeMethod>
