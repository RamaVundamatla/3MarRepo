    <JadeMethod name="trxUpdateWagonFromCMIF" id="b0e8c952-d6cf-4689-a2f4-c67813bca42d">
        <updating/>
        <source>trxUpdateWagonFromCMIF(	_wagonController : CMIF_WagonUpdateController input;
						_isValidate : Boolean;
						_passport : CM_Passport input) updating;
//-----------------------------------------
//Created: February 2003 By: cnwgd1
//13 May 2025	navbs1	    Bug MTN-34762: MTN - Add Deferred Updates Rail Operation
//-----------------------------------------
vars

begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);
	
	app.setContinueCMExceptions(false);
	// Start the transaction
	beginTransaction;
	_passport.useEventDeferUpdate := true;								//13.05.2025 navbs1 #34762
	_passport.useTITransactionDeferUpdate := true;						//13.05.2025 navbs1 #34762
	_passport.useTIDictDeferUpdate := true;								//13.05.2025 navbs1 #34762
	
	// Perform the operation
	app.myUtilityUA.utlUpdateWagonFromCMIF(_wagonController, _isValidate, true, _passport);
	
	if _passport.noErrors then
		_passport.doDeferredUpdates();									//13.05.2025 navbs1 #34762
	endif;
	
epilog
	self.finaliseActivityWithPassport(_passport);
end;</source>
