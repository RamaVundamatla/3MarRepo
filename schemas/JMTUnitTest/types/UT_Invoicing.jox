    <JadeMethod name="validateHMSInvoice5b" id="db7f3d50-233a-494c-8757-20a6bc563b0d">
        <source>validateHMSInvoice5b(_invoice : CM_Invoice; _step : Integer);
// tidal class after rate and vessel GRT etc change
vars
	invCount	: Integer;
	qty1,
	qty2		: Real;
	rate1,
	rate2		: Decimal[12, 6];
	total1,
	total2		: Decimal[16, 6];
	invLine		: CM_InvoiceLine;
begin
	// get the expected values
	if _step = 1 then
		qty1 := 1;
		qty2 := 1;
	elseif _step = 2 then
		qty1 := 2200;
		qty2 := 2200;
	elseif _step = 3 then
		qty1 := 200;
		qty2 := 200;
	elseif _step = 4 then
		qty1 := 2000;
		qty2 := 2000;
	elseif _step = 5 then
		qty1 := 20;
		qty2 := 20;
	elseif _step = 6 then
		qty1 := 2400;
		qty2 := 2400;
	elseif _step = 7 then
		qty1 := 6;
		qty2 := 6;
	elseif _step = 8 then
		qty1 := 12;
		qty2 := 6;
	// hook code doubles the quantity
	elseif _step = 9 then
		qty1 := 2;
		qty2 := 2;
	endif;

	rate1 := 7;			// arrival rate from tidal class
	rate2 := 8;			// departure rate from tidal class
	// hook code doubles the rate
	if _step = 9 then
		rate1 := 14;
		rate2 := 16;
	endif;

	total1 := qty1 * rate1;
	total2 := rate2 * qty2;
	// check the actual values
	foreach invLine in _invoice.invoiceLines do
		invCount := invCount + 1;
		if invCount = 1 then
			self.assertEqualMsg(invLine.quantity, qty1, "line 1 " &amp; _step.String &amp; " quantity");
			self.assertEqualMsg(invLine.lineTotal, total1, "line 1 " &amp; _step.String &amp; " value");
		elseif invCount = 2 then
			self.assertEqualMsg(invLine.quantity, qty2, "line 2 " &amp; _step.String &amp; " quantity");
			self.assertEqualMsg(invLine.lineTotal, total2, "line 2 " &amp; _step.String &amp; " value");
		endif;
	endforeach;
	self.assertEqualMsg(invCount, 2, "Invoice lines, invoice " &amp; _step.String);
end;
</source>
        <Parameter name="_invoice" type="CM_Invoice"/>
        <Parameter name="_step" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="validateHMSInvoice6" id="df00493d-fa71-4e92-a7c8-9f351bd607ac">
        <source>validateHMSInvoice6(_invoice : CM_Invoice; _step : Integer; _calcType : Integer);
// original invoice 
vars
	invCount	: Integer;
	qty			: Real;
	rate		: Decimal[12, 6];
	total		: Decimal[16, 6];
	invLine		: CM_InvoiceLine;
begin
	// get the expected values
	rate := 3;
	qty := 3600;		// 3 days 1200 GRT
	total := qty * rate;
	// the following calc types use the qty * GRT (etc) to multiply the rate for the line total, then set the quantity back to the resource used
// AKB 28APR2015 INV_CALC_TYPE_TIMEBLCK_HRS_UNT now uses the UNIT	qty := 3;			// 3  days
	// check the actual values
	foreach invLine in _invoice.invoiceLines do
		invCount := invCount + 1;
		if invCount = 1 then
			self.assertEqualMsg(invLine.quantity, qty, "line 1 " &amp; _step.String &amp; " quantity");
			self.assertEqualMsg(invLine.lineTotal, total, "line 1 " &amp; _step.String &amp; " value");
		endif;
	endforeach;
	self.assertEqualMsg(invCount, 1, "Invoice lines, invoice " &amp; _step.String);
end;
</source>
        <Parameter name="_invoice" type="CM_Invoice"/>
        <Parameter name="_step" type="Integer"/>
        <Parameter name="_calcType" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="validateInclExclStorage" id="2a8e4afc-1e01-40cb-86f1-506468542494">
        <source>validateInclExclStorage(_ti : CM_TrackedItem; _include : Boolean);

vars
	transCount,
	invCount	: Integer;
	trans	: CM_TITransaction;
	invLine	: CM_InvoiceLine;
begin
	foreach trans in _ti.allTransactions do
		if trans.isKindOf(CM_Storage) then
			transCount := transCount + 1;
			if transCount = 2 then
				invCount := 0;
				foreach invLine in trans.allInvoiceLines do
					invCount := invCount + 1;
					if invCount = 1 then
						if _include then
							self.assertEqualMsg(invLine.quantity, 3.Real, "Cargo inv 1 quantity");
						else
							self.assertEqualMsg(invLine.quantity, 4.Real, "Cargo inv 1 quantity");
						endif;
						self.assertEqualMsg(invLine.invoiceLineDesc.narration, "UT_LineTypeStoreFree2", "Cargo inv 1 ILD");
					elseif invCount = 2 then
						if _include then
							self.assertEqualMsg(invLine.quantity, 6.Real, "Cargo inv 2 quantity");
						else
							self.assertEqualMsg(invLine.quantity, 6.Real, "Cargo inv 1 quantity");		// was 5
						endif;
						self.assertEqualMsg(invLine.invoiceLineDesc.narration, "UT_LineTypeStoreFree3", "Cargo inv 2 ILD");
					elseif invCount = 3 then
						if _include then
							self.assertEqualMsg(invLine.quantity, 1.Real, "Cargo inv 3 quantity");
						else
							self.assertEqualMsg(invLine.quantity, 6.Real, "Cargo inv 1 quantity");		// was 5
						endif;
						self.assertEqualMsg(invLine.invoiceLineDesc.narration, "UT_LineTypeStoreFree4", "Cargo inv 3 ILD");
					endif;
				endforeach;
			endif;
			if transCount = 2 then
				if _include then
					self.assertEqualMsg(invCount, 3, "Cargo second storage invoice lines");
				else
					self.assertEqualMsg(invCount, 2, "Cargo second storage invoice lines");
				endif;
			endif;
		endif;
	endforeach;
	self.assertEqualMsg(transCount, 2, "Cargo storage transactions");
end;
</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_include" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validatePostedInvoice" id="3b776ea1-712c-4456-8407-365e98c557a6">
        <source>validatePostedInvoice(_invoice : CM_Invoice);

vars
	invCount	: Integer;
	invLine	: CM_InvoiceLine;
begin
	foreach invLine in _invoice.invoiceLines do
		invCount := invCount + 1;
		if invCount = 1 then
			self.assertEqualMsg(invLine.quantity, 0.Real, "line 1 posted quantity");
		elseif invCount = 2 then
			self.assertEqualMsg(invLine.quantity, 7.Real, "line 2 posted quantity");
		elseif invCount = 3 then
			self.assertEqualMsg(invLine.quantity, 7.Real, "line 3 posted quantity");
		elseif invCount = 4 then
			self.assertEqualMsg(invLine.quantity, 41.Real, "line 4 posted quantity");
		endif;
	endforeach;
	self.assertEqualMsg(invCount, 4, "Invoice lines");
end;
</source>
