<Class name="BGP_AutoTimerController" id="6a622bd4-d33a-4857-a883-0909289df37b">
    <superclass name="BGP_TimerController"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>&lt;display&gt;This auto schedule controller must be running in order for auto schedules from the auto schedule set up window to be processed.&lt;/display&gt;</text>
    <DbClassMap file="backgroundprocess"/>
    <ImplicitInverseRef name="myCurrentAutoTask" id="68cf5a05-9eb2-4e09-9431-c7e6a3f3274d">
        <embedded/>
        <type name="CM_AutoTask"/>
        <access>readonly</access>
    </ImplicitInverseRef>
    <JadeMethod name="createTimerRequest" id="763134c3-2179-4d1c-bd7a-f38ee84d1f54">
        <updating/>
        <source>createTimerRequest() : Boolean updating, protected;

// cnwdvb1 13 December 2002 


	
begin
	
	// Do nothing.
	return true;
	
end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doProcessing" id="402b6452-67d4-46fd-965d-cac4e7fc7b0e">
        <updating/>
        <source>doProcessing(): Boolean updating, protected;

// cnwdvb1 12 December 2002 
//03 Jan 2013	cnwrs1	32983 crash after user deleted.

vars
	tmpClass		: Class;
	task			: CM_AutoTask;
	request			: BGP_Request;
	schedule		: CM_AutoSchedule;
	msg : String;
begin
	schedule := app.myRoot.allAutoSchedulesByStartTs.getAtKeyLeq(CM_AutoSchedule.Schedule_Is_Active, app.actualTimeServer);
	
	if schedule &lt;&gt; null and schedule.canRunOnTimer() then
		msg := 'Starting to process schedule ' &amp; schedule.description;
		app.writeLog(class.name&amp;'::'&amp;method.name&amp;' '&amp;msg, LogDEBUG);	//25 Nov 2019	NDL	TFS 47053
		if not self.tryLock(schedule, Exclusive_Lock, Session_Duration, LockTimeout_Immediate) then
			// Will wait for duration of timer before trying again.
			msg := 'INFO &gt;&gt; Cannot get lock for schedule';
			app.writeLog(msg, LogINFO);	//25 Nov 2019	NDL	TFS 47053
			return false;
		endif;
	
		if schedule.checkEndTime() and
		// Somehow we have already been run. e.g Lock exception. Don't want to run 50 reports twice.
		not schedule.isBeingActioned then
			beginTransaction;
			schedule.setIsBeingActioned(true);
			commitTransaction;
			schedule.runTasks(null, null);
		else
			msg := 'INFO &gt;&gt; Schedule has expired or experienced a lock exception' &amp; schedule.endScheduleTs.String &amp; ' ' &amp; schedule.isActive.String;
			app.writeLog(msg, LogINFO);	//25 Nov 2019	NDL	TFS 47053
			
		endif;

		app.myTrxUA.trxUpdateAutoScheduleRunTs(schedule, CM_AutoSchedule.Make_Process, app.myPassport);
		msg := 'Finished processing schedule ' &amp; schedule.description;
		app.writeLog(msg, LogERROR);
	
		return true;
	endif;
	
	return false;

epilog	
	if schedule &lt;&gt; null then
		self.unlock(schedule);
	endif;
end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
