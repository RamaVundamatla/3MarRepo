    <JadeMethod name="getIsRotatableContainer" id="97b0bbdc-4664-4426-93be-091b761ea093">
        <source>getIsRotatableContainer(): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
30 October 2025		jlizm1	Initial creation MTN 36255 Rotabox Assign Release To Vessel

*/

vars
	reserveSelection : CM_ReserveSelection;
	
begin
	if self.myBulkReleaseReserveDetail = null then
		return false;
	endif;
	
	if not self.myBulkReleaseReserveDetail.isKindOf(CM_ReserveSelection) then
		return false;
	endif;
	
	reserveSelection := self.myBulkReleaseReserveDetail.CM_ReserveSelection;
	
	if reserveSelection.myISOType &lt;&gt; null and reserveSelection.myISOType.isRotatable then
		return true;
	endif;
	
	return false;
	
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
