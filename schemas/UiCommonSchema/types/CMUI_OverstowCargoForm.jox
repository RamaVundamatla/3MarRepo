    <JadeMethod name="displayTable" id="d8f159e2-7216-4b3c-9df7-7bc9f25adb4b">
        <updating/>
        <source>displayTable(_table : CM_DataTable input) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
17 November 2009	cnwphb1	Initial creation

*/

vars
	obj : Object;
	idx : Integer;
	ti	: CM_TrackedItem;
	accessDirection : Integer;
begin
	self.mousePointer := Window.MousePointer_HourGlass;
	_table.rows := _table.fixedRows;
	
	_table.allTableObjects.clear();
	
	//epr tfs 37584 7/5/18  
	self.allTrackedItems.clear;
	if self.myTrackedItem &lt;&gt; null then	
		self.myTrackedItem.getAllOverstowedTIs(self.allTrackedItems,true,accessDirection,self.cmbMachine.listObject.CM_Machine);
	endif;
	
	foreach ti in self.allTrackedItems do
		_table.allTableObjects.addObject(ti);
		self.doQueryAddItem(_table, 0, ti);
	endforeach;

	self.doTblDataRenumberItems(_table, 0);
	// Have to resort the table
	_table.setSortColumnsForMaxNumCols();
					

epilog
	self.mousePointer := Window.MousePointer_Default;
end;</source>
        <Parameter name="_table" type="CM_DataTable" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doBtnEnquireClick" id="4d03e1df-8b4c-4a99-9650-a46d4af66114">
        <source>doBtnEnquireClick();
// ---------------------------------------------------------------------------
// Created:		November 2009 By Pieter Bremmers cnwphb1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	theObject	: Object;
	theTable	: CM_DataTable;
begin
	theTable := self.tblData;

	if theTable.row &lt;= theTable.fixedRows then
		return;
	endif;
	
	theObject := theTable.accessRow(theTable.row).itemObject;
	
	if (not theTable.accessedRow.selected) then
		app.msgBox(app.getErrorString(S_Please_Select_A_Container_On), app.getErrorString(Nothing_Selected), MsgBox_Exclamation_Mark_Icon);
		return;
	endif;

	if theObject &lt;&gt; null and theObject.isKindOf(CM_TrackedItem) then
		self.myAssistant.showCargoEnquiryForm(theObject.CM_TrackedItem, self.myMasterMenuAction, true, false);		
	endif;
end;</source>
    </JadeMethod>
