    <JadeMethod name="doExtractTableToCSV" id="7f927a60-b714-46ac-977f-b98db3683948">
        <source>doExtractTableToCSV( _tableObj : Table input );
// --------------------------------------------------------------------------------
// Created:		20 December 2006 by cnwdad1
//
// Purpose:		Extracts the data in the specified table to a disk file, in CSV format.
//
// Parameters:	_tableObj - A reference to the table who's data we want to extract.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 02/12/2008	cnwdad1		PAR 18578 - Changed to let the BaseSchema method take
//							care of determining the file name.
// 20/05/2009	cnwrl1		PAR 19668 - CCMS 1814 - removed the protected so can be used via SOPTM_Machine etc
// --------------------------------------------------------------------------------
vars
    fileObj         : File;

begin
    create fileObj transient;
	fileObj.mode := File.Mode_Output;	// 1/3/16 cnwmp6 PAR 36286 unicode version
	
//	if not fileObj.cnEcSetSaveName(	"",
//									true,
//									true,
//									CNEC_FILE_FILTER_ALL &amp; "|" &amp; CNEC_FILE_FILTER_DATA) then
//		return;
//	endif;
	
    _tableObj.cnEcExportToCSV(fileObj, true);
epilog
    delete fileObj;
end;
</source>
        <Parameter name="_tableObj" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doFrmToolbarContextMenu" id="d23829b0-7fa7-4f30-99e7-e1c419d52405">
        <updating/>
        <source>doFrmToolbarContextMenu(cntrl: Frame input; conwin: Window input; mouse: Boolean; x: Integer; y: Integer):Boolean updating, protected;
// ---------------------------------------------------------------------------
// Created:     30 July 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
vars
	x1, 
	y1					: Real;
	menuEntity			: CM_MenuEntity;
	terminal			: CM_Terminal;
	showValue			: Boolean;
begin

	x1 := x;
	y1 := y;
	
	if cntrl &lt;&gt; null then
		if (not mouse) then  // if keyboard, use current listIndex value
		    x1 := 20;
		    if cntrl.top &lt; 0 then
		        y1 := 5;
		    else
		        y1 := cntrl.top;
		    endif;
		endif;
		
		conwin.windowToScreen(x1, y1);
	endif;
	
	self.doFrmToolbarShowHideContextMnu();
	
	self.screenToWindow(x1, y1);
	
	self.popupMenu(self.mnuToolbarContext, x1.Integer, y1.Integer);
	
	return false;                  // cancel further processing

end;</source>
        <access>protected</access>
        <Parameter name="cntrl" type="Frame" usage="input"/>
        <Parameter name="conwin" type="Window" usage="input"/>
        <Parameter name="mouse" type="Boolean"/>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
