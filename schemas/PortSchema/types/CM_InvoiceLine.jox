    <JadeMethod name="setProxyWeb" id="976a8c46-5fa2-4f38-a874-6a5811341a24">
        <updating/>
        <source>setProxyWeb( _manual 		  	: Boolean; 
			 _remarks 		  	: String; 
			 _invoiceLineDesc 	: CM_InvoiceLineDesc; 
			 _debtor 		  	: CM_Debtor;
			 _bank 			  	: CM_Bank;
			 _quantity			: Real
			 ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13/06/2023	navcs2	ChangeRequest 56901: [58447]: TAS Invoicing Invoice Endpoint - JADE changes

*/

vars

begin
	self.manual	         := _manual;
	self.remarks         := _remarks;
	self.invoiceLineDesc := _invoiceLineDesc;
	self.debtor 	     := _debtor;	
	self.bank            := _bank;
	if _invoiceLineDesc.myUOM &lt;&gt; null then	
		self.uomCode := _invoiceLineDesc.myUOM.code;
	endif;
	self.quantity		:= _quantity;
epilog
	
end;</source>
        <Parameter name="_manual" type="Boolean"/>
        <Parameter name="_remarks" type="String"/>
        <Parameter name="_invoiceLineDesc" type="CM_InvoiceLineDesc"/>
        <Parameter name="_debtor" type="CM_Debtor"/>
        <Parameter name="_bank" type="CM_Bank"/>
        <Parameter name="_quantity" type="Real"/>
    </JadeMethod>
    <JadeMethod name="setQuantityAndTotal" id="8f7d75fd-b394-4f68-ac26-6bab6ff32a2c">
        <updating/>
        <source>setQuantityAndTotal(_qty : Real) updating;
//	CCMS SFW 1279 May 2012 Storage Escalating Charges
// 23 Oct 2024	navlw1	JIRA-33107: Invoice Logging Use Levels
// 25 Feb 2025	navah1	Story 34141: MTN - Performance Improvements - Review for invLog() Methods
vars
	charge	: CM_Charge;
	canLogExtra	: Boolean;	//27.02.2025 navah1	#34141
begin
	canLogExtra	:= app.canLogExtraDetail();				//27.02.2025 navah1	#34141

	if _qty &lt;&gt; self.quantity then
		self.quantity := _qty;
		foreach charge in self.charges do
			if canLogExtra then	//27.02.2025 navah1	#34141
				app.invLog(method.qualifiedName &amp; " Calling CM_Charge.evaluateRate", LogINFO.String); // TFS 42084
			endif;
			charge.evaluateRate();
		endforeach;
	endif;
end;
</source>
        <Parameter name="_qty" type="Real"/>
    </JadeMethod>
