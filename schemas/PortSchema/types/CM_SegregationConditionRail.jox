<Class name="CM_SegregationConditionRail" id="ec203135-bd74-4c35-b961-e5b50368087a">
    <superclass name="CM_SegregationCondition"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="location"/>
    <JadeMethod name="create" id="9393917c-99a7-4e7a-af7b-9ccaf49a0890">
        <updating/>
        <source>create() updating;
/*
----------   ----------  --------------------------------------------------
Created:	22 August 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars

begin
	self.type := Segregation_Type_Rail;

end;


</source>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="eacc38f0-36ff-45f8-b230-cacea174cc05">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
/*
----------   ----------  --------------------------------------------------
Created:	28 August 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars

begin
	if _attrName = ETRow_NumWagonsApart then
		return self.proximityHorizontal.String;
	elseif _attrName = ETRow_NumRakesApart then
		return self.proximityVertical.String;
	endif;
	
		
	return inheritMethod(_attrName, _short);


end;


</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
</Class>
