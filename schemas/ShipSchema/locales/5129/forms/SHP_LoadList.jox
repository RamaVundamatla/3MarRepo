    <CMUI_CheckBox name="chkIsOverstowed" id="f4e21578-1fa1-4548-af3a-aa362588b429">
        <caption>Is Overstowed</caption>
        <transparent/>
        <fontSize>8.25</fontSize>
        <foreColor>-2147483640</foreColor>
        <parent name="5129::CMUI_QueryEnquiry::shtQuery5"/>
        <parentBottomOffset>119</parentBottomOffset>
        <parentRightOffset>26</parentRightOffset>
        <show3D>3</show3D>
        <tabIndex>609</tabIndex>
        <tabStop/>
        <backColor>-2147483633</backColor>
        <bubbleHelp>If checked the system will search for cargo that is 
currently overstowed by cargo for another voyage.  
This will just show cargo that is overstowed by items for 
a different voyage, or for the same voyage but with a different
 discharge port (in the same way the new Is Overstowed column will work).</bubbleHelp>
        <enabled/>
        <height>17</height>
        <left>20</left>
        <top>148</top>
        <visible/>
        <width>200</width>
    </CMUI_CheckBox>
    <CMUI_CheckBox name="chkOverDiffVoy" id="3d04e7a4-d46c-47bb-91d2-063190ffd6b3">
        <caption>Overstowing Different Voyage</caption>
        <transparent/>
        <fontSize>8.25</fontSize>
