<Class name="CM_QryReportSystem" id="76304c6a-c74e-4709-8ac7-067950d0908d">
    <superclass name="CM_QryReport"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="query"/>
    <JadeMethod name="create" id="bd747e0a-0345-4020-8cc6-33edda6d13a4">
        <updating/>
        <source>create() updating;
// ---------------------------------------------------------------------------
// Created:     27 November 2002		cnwth2	
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars

	str : String;
	userCode : String;
	stack : HugeStringArray;
	stackStr : String;

begin
	self.type := MenuType_DetailSystem;
	self.reportType := self.ReportType_SystemDefined;
	self.isSystemMenuItem := true;
	
	
	//02 Aug 2015	NDL	Find what's generating empty system reports.
	executeWhen JMTDevelopmentEnvironment;
	
		if app.myPassport &lt;&gt; null then
			userCode := app.myPassport.getUserCode();
		endif;
		
		create stack transient;
		app.outputProcessStackToStringArry( stack );
		
		str := self.String &amp; ", created by '" &amp; userCode &amp; "'";
		foreach stackStr in stack do
			str := str &amp; CrLf &amp; stackStr;
		endforeach;
		
		app.createActivityHistory(	ActivityHistoryGeneralSys,	//_type : Integer;
									null,	//_terminal : CM_Terminal;
									stack,	//_objectForExtraDetail : Object;
									str,	//_description : String;
									true,	//_insideTransaction : Boolean;
									false	//_temp: Boolean
									);
									
	endExecuteWhen;
								
epilog

	delete stack;
	
end;</source>
    </JadeMethod>
