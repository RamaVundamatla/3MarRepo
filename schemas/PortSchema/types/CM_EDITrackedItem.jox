    <JadeMethod name="getSealsAsString" id="eecc61bd-2a30-46c5-8b03-988220c9212a">
        <source>getSealsAsString(_sealType : String) : String;
//
// 12 Oct 2016	cnwrs1	TFS 2829 Cams processing failure with Train Events
// 20 Jun 2017	cnwrs1	TFS 4462 SNO add Terminal Operator, Unknown Seal and support multiple seals
//
vars
	ediTI : CM_EDITrackedItem;
	str : String;
begin
	foreach ediTI in self.myAttachedItems do
		if ediTI.isEDISealDetails and
		   ediTI.CM_EDISealTI.sealEDIType = _sealType then
			if str = null then
				str := ediTI.CM_EDISealTI.sealEDINum;
			else
				str :=  str&amp;","&amp;ediTI.CM_EDISealTI.sealEDINum;
			endif;
		endif;
	endforeach;
	return str;
end;
</source>
        <Parameter name="_sealType" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
