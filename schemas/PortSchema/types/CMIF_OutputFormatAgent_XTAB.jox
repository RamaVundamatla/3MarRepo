    <JadeMethod name="getDisplayDateFromKeyValue" id="ebac234c-0cf7-4151-a65e-69c402f4b8c1">
        <source>getDisplayDateFromKeyValue(_str :String):String protected;
// ---------------------------------------------------------------------------
// Created:     12 February 2010 by cnwcs5
// Purpose:     CCMS 1925 / PAR 22295 Release Summaries
// Parameters:  _str - key value used for date grouping property in the 
//					   format &lt;date prefix&gt;&lt;date as integer&gt;
// Returns:     String containing date in the current locale format
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	str		:String;
	date	:Date;
begin
	//DON'T CALL THIS METHOD UNLESS _str IS A VALUE IN THE EXPECTED FORMAT
	str 	:= _str[2:end];	
	
	if str.Integer = null then
		return self.Empty_Property_Text;
	endif;
	
	date	:= str.Integer.Date;
	
	return date.asStringJMT;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_str" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDisplayDateTimeFromKeyValue" id="0118209c-50bb-481e-be3b-ed0bc7511ffb">
        <source>getDisplayDateTimeFromKeyValue(_str :String):String protected;
// ---------------------------------------------------------------------------
// Created:     26 July 2010 by cnwcs5
// Purpose:     
// Parameters:  _str - key value used for date grouping property in the 
//					   format &lt;date prefix&gt;&lt;date as integer&gt;
// Returns:     String containing date in the current locale format
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	strDate, 
	strTime	:String;
	date	:Date;
begin
	//DON'T CALL THIS METHOD UNLESS _str IS A VALUE IN THE EXPECTED FORMAT
	strDate 	:= _str[2:8];	
	strTime		:= _str[10:end];
	
	if strDate.Integer = null then
		return self.Empty_Property_Text;
	endif;
	
	date	:= strDate.Integer.Date;
	
	return date.asStringJMT &amp; ' ' &amp; strTime;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_str" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getKeyValueForMappingLine" id="17794e79-8515-4662-ae97-bf48dd05f81d">
        <source>getKeyValueForMappingLine(_line :CM_XTABMappingLine):String protected;
// ---------------------------------------------------------------------------
// Created:     01 December 2009 by cnwcs5
// Purpose:     CCMS 1028 - summary mappings
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	mapping	:CM_XTABMapping;
begin
	mapping	:= _line.myXTABMapping;
	
	if mapping.order = CM_XTABMapping.ORDER_MAPPING then
		// to everything in mapping order we use a key of '~' and the index of the mapping line.
		// the first mapping line will be '~000001", the second '~000002' and so on
		// we dopn't expect there to be more tha 999998 mapping lines as the user would run out 
		// of table rows when defining them so we should be safe here
		return self.Mapping_Prefix &amp; mapping.allMappingLines.indexOf (_line).padLeadingWith ('0', 6);
	else
		// mapping.order = CM_XTABMapping.ORDER_MAPPING_VALUE 
		return _line.mappedValue; 
	endif;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_line" type="CM_XTABMappingLine"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getKeyValueForMappingOther" id="d4cea8e1-9e50-4158-91ca-88a9a47a7cb1">
        <source>getKeyValueForMappingOther(_mapping :CM_XTABMapping):String protected;
// ---------------------------------------------------------------------------
// Created:     01 December 2009 by cnwcs5
// Purpose:     CCMS 1028 - summary mappings
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	if _mapping.order = CM_XTABMapping.ORDER_MAPPING then
		return self.Mapping_OtherValue;
	else
		// _mapping.order = CM_XTABMapping.ORDER_MAPPING_VALUE 
		return _mapping.otherHeading;
	endif;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_mapping" type="CM_XTABMapping"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getMappingForKeyValue" id="deb8a7d8-83a6-4738-8576-f3bc02da144c">
        <source>getMappingForKeyValue(_value :String; _mapping :CM_XTABMapping):String protected;
// ---------------------------------------------------------------------------
// Created:     01 December 2009 by cnwcs5
// Purpose:     CCMS 1028 - summary mappings
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	index	:Integer;
begin
	if _value.length &lt; 2 or
		_value[1] &lt;&gt; self.Mapping_Prefix then
		return _value;	// not a manufactured mapping key value
	endif;
	
	if _value = Mapping_OtherValue then
		return _mapping.otherHeading;	// the heading that non mapped values are grouped under
	endif;
	
	index := _value[2:end].Integer;
	
	if index = 0 then
		return _value;	// don't expect this to happen
	endif;
	
	if _mapping.allMappingLines.size &lt; index then
		return _value;	// don't expect this to happen
	endif;
	
	return _mapping.allMappingLines[index].mappedValue;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_value" type="String"/>
