    <JadeMethod name="doCentreOnSelectedObject" id="86b4671e-61e1-4a3c-be66-817405c51797">
        <source>doCentreOnSelectedObject();
// ---------------------------------------------------------------------------
// Created:		April 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

	posH, posV : Real;
	theHValue, theVValue : Integer;	
	tmpDkbGridArea	: CMUI_GridAreaDockBar;
	tmpFrame : CMUI_GridAreaScrollableFrame;
	key1, key2 : Point;
begin

	tmpFrame := self.getScrollablleFrame();
	posH := (tmpFrame.getHScrollValue() / tmpFrame.getHScrollMax).Real;
	posV := (tmpFrame.getVScrollValue() / tmpFrame.getVScrollMax).Real;
	

	if self.allSelectedObjects.isEmpty then
		theHValue := (tmpFrame.getHScrollMax * posH).Integer;
		theVValue := (tmpFrame.getVScrollMax * posV).Integer;
	else
		self.allGridObjects.findObjectInDictGetXY(self.allSelectedObjects.first,key1, key2);
		theHValue := key1.x;
		theVValue := key1.y;

		theHValue := (tmpFrame.left + theHValue).Integer - (tmpFrame.width / 2).Integer;
		theVValue := (tmpFrame.top + theVValue).Integer - (tmpFrame.height / 2).Integer;
		
	endif;
	
	tmpFrame.scrollTo(theHValue,theVValue);
	
epilog 

end;</source>
    </JadeMethod>
