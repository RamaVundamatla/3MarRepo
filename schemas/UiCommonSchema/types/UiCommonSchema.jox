    <JadeMethod name="loadForm" id="dd2bb11f-ccbf-40d3-b892-5cdbaa21685e">
        <updating/>
        <source>loadForm(pFormClass, pAssistClass : Class; pMaximized, pShow, pModal : Boolean; 
		 pTerminal : CM_Terminal; _menuAction : CMUI_MenuAction) : Form updating;
/* ---------------------------------------------------------------------------
 Created:     05 April 2001 by cnwrs2

 Purpose:     
 Changes

Date		Name	TFS#		Description
============================================================================
09/09/2008	concms1	par 17903
					ccms 1741 	Welcome Screen (interim version)
20/09/2019 	jlgka1 	TFS 45614 	JMT - Refactoring remove Voyage Commodity Scenario mode
27/03/2020	jlgdap1	TFS 48992 	MTN Automated Testing - Table Navigation
14/03/2022  navma1	TFS 52821   EUP - Documents Linked to Cargo Types
============================================================================*/
vars
	form			: Form;
	savePointer,
	viewPerm		: Integer;
	isCM_BaseForm	: Boolean;
	property 		: Property;
begin
	//on UserInterfaceException do self.interfaceExceptionMsgBox(exception);
	
	if pFormClass = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Window class not found');
		return null;
	endif;
	
	savePointer := self.mousePointer;
	self.mousePointer := Window.MousePointer_HourGlass;

	app.setMyTerminal(pTerminal);
	
	create form as pFormClass;

	if pFormClass = CMS_Logon or
	   CMUI_SuperAppForm2.hasInstance(form) or
	   CMUI_Navigator.hasInstance(form)  or
	   CMUI_ChangePassword.hasInstance(form) then
	else
		// This is done here as terminal is required for some
		// mapping methods based on the parameters below
		if CM_BaseForm.hasInstance(form) then
			isCM_BaseForm := true;
			form.CM_BaseForm.setMyTerminal(pTerminal);
		endif;

		if _menuAction &lt;&gt; null then
			// set the parameters before checking the permissions as
			// these could affect the permissions
			if _menuAction.attr1 &lt;&gt; null then
				property:=form.class.findProperty(_menuAction.attr1);
				if property &lt;&gt; null and property.type = Boolean then //epr par 34945 28/10/14
					form.setPropertyValue(_menuAction.attr1, _menuAction.param1.Boolean);
				else
					form.setPropertyValue(_menuAction.attr1, _menuAction.param1);
				endif;
			endif;
		endif;

		if isCM_BaseForm then
			viewPerm := form.CM_BaseForm.permissionView;
		elseif CMS_MainForm.hasInstance(form) then
			viewPerm := form.CMS_MainForm.permissionView;
		elseif CMS_Modal.hasInstance(form) then
			viewPerm := form.CMS_Modal.permissionView;
		elseif CnEcReleaseHistoryForm.hasInstance(form) then
			viewPerm := PmAdmViewReleaseHistory;
		endif;
		
		if CMUI_QuickFind.hasInstance(form)
		or CMUI_QuickAccessAutomation.hasInstance(form)			// TFS 48992
		or CMUI_Attachments.hasInstance(form)
		or CMUI_AttachBreakBulk.hasInstance(form)
		or CMUI_TicketSequences.hasInstance(form)
		or pModal
		or CMUI_FlexiCargoForm.hasInstance(form)		// PAR 24989
		or CMUI_FileAttachmentsForm.hasInstance(form)	// 14.03.2022 navma1 #52821
		or CMUI_WelcomeForm.hasInstance (form) then		// ppar 17903
			// there forms have a viewValue of 0 so let through for now.
			// they are opened up from Gate In/Out, Pre-note, ... screens
			
		// 03 Aug 2011	NDL	Par 27946
		elseif ( ( CMUI_CalendarMaintForm.hasInstance(form)
			or CMUI_CalendarDateBulkAddForm.hasInstance(form) )	//10 Junn 2013	Par 31666
			and pTerminal = null 
			)then // system wide version...	
			if (not app.myCurrentUserCan(null, PmAdmCalendarMaint)) then
				app.msgBox(app.getErrorString1(VB_SECSHOW, form.caption), "Security Warning", MsgBox_Stop_Icon);
				delete form;
				return null;
			endif;
			
		else
			// need to add pTerminal to user permission check
			if (not app.myCurrentUserCan(pTerminal, viewPerm)) then
				// user does not have access to view form
				app.msgBox(app.getErrorString1(VB_SECSHOW, form.caption), "Security Warning", MsgBox_Stop_Icon);
				delete form;
				return null;
			endif;
		endif;
		
		if isCM_BaseForm then
			form.CM_BaseForm.createMyAssistant(pAssistClass);
			if not self.userSavedWindowSettings then
				form.CM_BaseForm.openWithSavedSettings(); //epr 17/4/07 par 13840
			endif;
		endif;
	endif;

	if (not app.userSavedWindowSettings) then
		if pMaximized then
			form.windowState := Form.WindowState_Maximized;
		else
			form.windowState := Form.WindowState_Normal;
		endif;
	endif;

	app.instrumentFormUsage( form );	//25 Feb 2014 NDL	Par 33587
	
	//show the form
	if pShow then
		if pModal then
			mousePointer := Window.MousePointer_Default;
			form.showModal();
		else	
			form.show();
		endif;
	endif;
	
	return form;

epilog
	self.mousePointer := savePointer;
end;</source>
        <Parameter name="pFormClass" type="Class"/>
        <Parameter name="pAssistClass" type="Class"/>
        <Parameter name="pMaximized" type="Boolean"/>
        <Parameter name="pShow" type="Boolean"/>
        <Parameter name="pModal" type="Boolean"/>
        <Parameter name="pTerminal" type="CM_Terminal"/>
        <Parameter name="_menuAction" type="CMUI_MenuAction"/>
        <ReturnType type="Form"/>
    </JadeMethod>
    <JadeMethod name="lockDialogShowProgress" id="4b222569-c717-432d-8fcb-4cff0d568492">
        <executionLocation>client</executionLocation>
        <source>lockDialogShowProgress(_lockDialog : CMUI_LockDialog io; 
					_caption, _msg1, _msg2 : String) : Boolean clientExecution;
// ---------------------------------------------------------------------------
// Created:     21 November 2003 by cnwrs2
//
// Purpose:     returns true if user presses cancel
// ---------------------------------------------------------------------------
vars
	isFirstTime	: Boolean;

begin

	if _lockDialog = null then
		create _lockDialog transient;
		isFirstTime := true;
		
//		lockDialog.backColor	:= _backColor;
//		_lockDialog.frmMsg1.backColor	:= _backColor;
//		_lockDialog.frmMsg2.backColor	:= _backColor;
//		_lockDialog.frmMsg3.backColor	:= _backColor;
	endif;

	_lockDialog.caption	:= _caption;

	_lockDialog.frmMsg1.caption	:= _msg1;
	_lockDialog.frmMsg2.caption	:= _msg2;
	
	if isFirstTime then
		_lockDialog.centreWindow();
		_lockDialog.show;
		_lockDialog.refreshNow();
		return false;
	else
		return _lockDialog.checkProgress();
	endif;

end;</source>
        <Parameter name="_lockDialog" type="CMUI_LockDialog" usage="io"/>
        <Parameter name="_caption" type="String"/>
        <Parameter name="_msg1" type="String"/>
        <Parameter name="_msg2" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="lockDialogUnload" id="83840085-7f14-4fe0-8cac-3646c3f1e578">
        <source>lockDialogUnload(_lockDialog : CMUI_LockDialog input);
// ---------------------------------------------------------------------------
// Created:     21 November 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin

	if _lockDialog &lt;&gt; null then
		_lockDialog.unloadForm();
	endif;
end;</source>
        <Parameter name="_lockDialog" type="CMUI_LockDialog" usage="input"/>
    </JadeMethod>
    <JadeMethod name="lockExceptionHandlerMsgBox" id="865909b1-6b7c-4b7e-8bb8-84d8243a6c77">
        <source>lockExceptionHandlerMsgBox(lockExObj: LockException): Boolean;
// ---------------------------------------------------------------------------
// Created:     21 November 2003 by cnwrs2
//
// R Barr 27/10/2006 Add lockTarget message (lots of locks in development, lets find out why)
// ---------------------------------------------------------------------------
vars
	lockDialog	: CMUI_LockDialog;
	userStr,
	msg1,
	msg2		: String;
	retryLimit,
	lockTimeout,	
	retries 	: Integer;
	lockTarget	: Object;
	lockTargetMessage, title	: String;
begin

	retries := 0;
	retryLimit := 3;

	userStr := app.getUserForException(lockExObj);
	app.writeLogLockException(lockExObj);

	lockExObj.lockTarget;
	if lockTarget &lt;&gt; null then
		lockTargetMessage := CrLf &amp; 'The lock target is ' &amp; app.cnGetClassAndOid(lockTarget);
	endif;
	
	lockTimeout	:= lockExObj.lockTimeout;
	if lockTimeout = 0 or lockTimeout &gt; 2000 then
		lockTimeout := 2000;		// default to a max of 5 seconds
	endif;

/*
"Your current operation requires data that is already locked and in use by " &amp;
		userStr &amp; "." &amp; CrLf &amp; CrLf &amp;
'Your request will be aborted after 2 retries, or you can press cancel now.';
*/

	msg1 := "Your current operation requires data that is already locked and in use by " &amp;
		userStr &amp; "." &amp; lockTargetMessage &amp; CrLf &amp; CrLf &amp;
		'Your request will be aborted after ' &amp; retryLimit.String &amp; ' retries, or ' &amp;
		'you can press cancel now.';

	// ### JIRA 19932 21OCT2024 NAVAB1
	msg1 := "The system is busy at the moment,"  &amp; CrLf &amp; "your changes will pause momentarily,"  &amp; CrLf &amp; "before retrying; or you can click cancel.";
		
	while true do
		// Prompt the user

		if retries &gt; retryLimit then
			break;
		endif;

		msg2 := "Number of Retries so far: " &amp; retries.String;

		// ### JIRA 19932 21OCT2024 NAVAB1
		title := "Data Locked by another user";
		title := "System Retry";
		if self.lockDialogShowProgress(lockDialog,title, msg1, msg2) then	
			break;
		endif;

		if tryLock(lockExObj.lockTarget, lockExObj.lockType, lockExObj.lockDuration, lockTimeout) then
			// We got the lock
			return true;
		endif;

		retries := retries + 1;

	endwhile;

	return false;

epilog
	if lockDialog &lt;&gt; null then
		self.lockDialogUnload(lockDialog);
	endif;
	
end;</source>
        <Parameter name="lockExObj" type="LockException"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="msgBox" id="eb986196-6c4a-4aea-b27b-a970cac81092">
        <source>msgBox(msg: String; title: String; flags: Integer): Integer;
// --------------------------------------------------------------------------------
// Created:		16 August 2006 by cnwdad1
//
// Purpose:		Re-implementation of app.msgBox.
//
//				If the 'flags' parameter value is positive, then the normal
//				app.msgBox will be presented.
//
// Parameters:	Refer to the "msgBox" method in the JADE Online Help.
//
// Returns:		Refer to the "msgBox" method in the JADE Online Help.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	msgboxFormObj	: CMUI_KioskMsgBoxForm;
	
begin
	
	if self.isKioskApp() then
		create msgboxFormObj transient;
		msgboxFormObj.setMessage(msg, title, flags);
		return msgboxFormObj.showModal();
	else
		return inheritMethod(msg, title, flags);
	endif;
end;</source>
        <Parameter name="msg" type="String"/>
        <Parameter name="title" type="String"/>
        <Parameter name="flags" type="Integer"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="msgBoxScroll" id="378d90f8-f33f-43b8-8c18-00a9dc90eeda">
        <source>msgBoxScroll(_message: String; _messageAsArray: Array; _highLightText: String; _formCaption: String; _options: Integer);
//----------------------------------------------------------------
//	Created:	20 May 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
constants
	OPTION_SEARCHABLE	: Integer = 1;
vars
	msgBoxObj			: CMUI_ScrollMsgBox;
	txtAny				: Any;
	any					: Any;
	text	      			: String;
	txtPos				: Integer;
begin
	if _options = OPTION_SEARCHABLE then
		self.msgBoxSearchable(_message, _messageAsArray, _highLightText, _formCaption);
		return;
	endif;
	
	create msgBoxObj transient;
	
	if _formCaption = null then
		msgBoxObj.caption := self.niceName;
	else
		msgBoxObj.caption := _formCaption;
	endif;
	
	if _messageAsArray = null then
		text := _message;
	else
		foreach any in _messageAsArray do
			if any.isKindOf(Object) then
				if CM_LongString.hasInstance(any.Object) then
					txtAny := any.CM_LongString.string;
				else
					txtAny := any;
				endif;
			elseif any.isKindOf(Binary) then
				txtAny := any.Binary.uncompressToString();		// cnwdad1 20/06/2008 - PAR #17042.
			else
				txtAny := any;
			endif;
			
			if text = "" then
				text := txtAny.String;
			else
				text := text &amp; CrLf &amp; txtAny.String;
			endif;
		endforeach;
	endif;
	
	//set text
	msgBoxObj.txtMessage.text := text;
	
	if _highLightText &lt;&gt; null then
		txtPos := 1;
		txtPos := msgBoxObj.txtMessage.text.pos(_highLightText, 1);
		if txtPos &gt; 0 then
			msgBoxObj.txtMessage.selStart	:=	txtPos-1;
			msgBoxObj.txtMessage.selLength	:=	_highLightText.length;
		endif;
	endif;

	msgBoxObj.load();
	msgBoxObj.show();
end;</source>
        <Parameter name="_message" type="String"/>
        <Parameter name="_messageAsArray" type="Array"/>
        <Parameter name="_highLightText" type="String"/>
        <Parameter name="_formCaption" type="String"/>
        <Parameter name="_options" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="msgBoxSearchable" id="c145eb55-4e2d-4eac-8f8c-cbd0afb8fa65">
        <source>msgBoxSearchable(_message: String; 
				 _messageAsArray: Array; 
				 _highLightText: String; 
				 _formCaption: String);
// --------------------------------------------------------------------------------
// Created:		30 December 2005 by cnwdad1
//
// Purpose:		Copied from the msgBoxScroll method for this searchable version.
//
// Parameters:	None
//
// Returns:		Nothing
//
/*

Date		Who		Reason
23/02/2006	cnwdad1	Changed "find" function to use the native JadeRichText
					find method, instead of using the String::pos method.
29/11/2011	cnwcs5	CCMS POL 2122/ par 28696 - refactoring. Code moved onto form
16 Dec 2014	cnwkpd1	PAR #34713 - Changes for .NET EDI Integration

*/

constants
	LargeMessageSize	= 400000;
	LargeArraySize		= 40000;
	
vars
	form				: CMUI_ScrollMsgBoxSearchable;
	
begin
	create form transient;
	
	if _formCaption = null then
		form.caption := self.niceName;
	else
		form.caption := _formCaption;
	endif;

	// PAR #34713 - determine optimum load mechanism here based on message size
	if _message.length() &gt; LargeMessageSize or (_messageAsArray &lt;&gt; null and _messageAsArray.size() &gt; LargeArraySize) then
		form.loadBigMessage(_message, _messageAsArray, _highLightText);
	else
		form.loadSmallMessage(_message, _messageAsArray, _highLightText);
	endif;
	
	form.load();
	form.show();
	
end;</source>
        <Parameter name="_message" type="String"/>
        <Parameter name="_messageAsArray" type="Array"/>
        <Parameter name="_highLightText" type="String"/>
        <Parameter name="_formCaption" type="String"/>
    </JadeMethod>
    <JadeMethod name="printPreview" id="8caa5a24-5698-4ed7-a2d6-49402045c7f5">
        <source>printPreview(_jadeReport : JadeReport; _eraseReport : Boolean);
// ---------------------------------------------------------------------------
// Created:     03 September 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
/*
Changed On	Changed By	Reason
----------	----------	--------------------------------------------------
18 Sep 2008	cnwdz2		Par17773 - Any report which is in load state when run, and then produces no output is potentially an issue.
									Unconditionally abortTransaction before displaying the message box.
16 Mar 2010	consw1		PAR #22886 - Leaking report transients
*/

vars
	theForm	: CMUI_PrintPreview;
	theReport : JadeReport;
	term : CM_Terminal;
	user : CM_User;
	
begin
	app.printer.close;	//ALWAYS do this, ELSE the app server will CRASH! Woo Hoo
	
	if _jadeReport.pageCount = 0 then
		global.beep;

		abortTransaction;

		app.msgBox(app.getErrorString(No_Print_Output), "No output", MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
		
		if _eraseReport then
			theReport := _jadeReport;
			delete theReport;
		endif;
		
		return;
	endif;
	
	//19 Oct 2017	NDL	TFS 7488
	term := app.getMyTerminalDO_NOT_USE(); // if we have one use it
	if term = null then
		user := app.getMyUser;
		if user &lt;&gt; null then
			if not user.allUserTerminals.isEmpty then
				term := user.allUserTerminals.first.myTerminal;
			endif;
		endif;
	endif;
	
	create theForm transient;
	theForm.setMyTerminal(term);
	theForm.init(_jadeReport, _eraseReport);
	theForm.openWithSavedSettings();
	theForm.show();
	
end;</source>
        <Parameter name="_jadeReport" type="JadeReport"/>
        <Parameter name="_eraseReport" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="printPreviewModal" id="265b9fc6-9135-4960-9117-052d130da960">
        <source>printPreviewModal(_jadeReport: JadeReport);
/*

Date		Who		Reason
01 November 2013	cnwer1	Initial creation PAR 32899

*/

vars
	theForm	: CMUI_PrintPreviewModal;
	theReport : JadeReport;
	
begin

	app.printer.close;	//ALWAYS do this, ELSE the app server will CRASH! Woo Hoo
	if _jadeReport.pageCount = 0 then
		global.beep;

		abortTransaction;

		app.msgBox(app.getErrorString(No_Print_Output), "No output", MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
		
		
		theReport := _jadeReport;
		delete theReport;
		
		
		return;
	endif;

	create theForm transient;
	theForm.setMyTerminal(app.getMyTerminalDO_NOT_USE());
	theForm.init(_jadeReport, true);
	theForm.openWithSavedSettings();
	theForm.showModal();

epilog

end;</source>
        <Parameter name="_jadeReport" type="JadeReport"/>
    </JadeMethod>
    <JadeMethod name="printReportDotMatrix" id="ce7dfebb-bdbc-4c09-9276-6a702af55d30">
        <source>printReportDotMatrix(_reportName: String; _object: CM_Object; _lineUp: Boolean);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 November 2012	cnwndl1	Initial creation	Par 30682

*/

vars

	reportString : String;
	fontName : String;
	pos1 : Integer;
	pos2 : Integer;
	pos3 : Integer;
	count : Integer;
	workStr : String;
	outputType : String;
	baseLeftOffset : String;
	baseTopOffset : String;
	fontSize : String;
	printerName : String;
	defaultPrinterName : String;
	error : Boolean;
	
	reportClassName : String;
	reportClass : Class;
	form : CMUI_DotMatrixBaseForm;
	
	showLabelArea : Boolean; // when testing set to ture to draw a border around the label, only works on std printers...
	
begin

	reportString := _reportName;
	fontSize := "10";
	fontName := "Courier";			// default if not specified
	printerName := app.printer.getPrinterName;
	defaultPrinterName := printerName;
	
	// We can store the additional info in the config (i.e. suffix with "?DOT?offsetLeft?offsetTop?fontSize?fontName?printerName")
	// use "?" delimiter as this is not allowed in JRW report names
	
	// CMUI_AjmanEIR?DOT?-10?-5?10?Courier?EPSON LQ-870 ESC/P 2
	// see CMUI_DotMatrixBaseForm::getParamValues

	pos2 := reportString.pos("?", 1);
	if pos2 &gt; 1 then
		reportClassName := reportString[1:pos2-1];
	else
		reportClassName := reportString;
	endif;
	
	reportClass := currentSchema.getClass(reportClassName);
	
	if reportClass = null
	or not reportClass.inheritsFrom( CMUI_DotMatrixBaseForm )
	then
		app.raiseUnexpectedProgramError(class.name, method.name, app.getErrorString(Matrix_attribute_error) &amp; " : " &amp; reportString &amp; ", " &amp; app.getErrorString(Example) &amp; " " &amp; form.getParamExample() );
		return;
	endif;
	
	//create form as reportClass transient;
	form := reportClass.GUIClass.createPrintForm.CMUI_DotMatrixBaseForm;	// uses less GUI resources
	form.getParamValues(	reportString,	//_inputString : String;
							outputType,	//_outputType : String output;
							baseLeftOffset,	//_baseLeftOffset : String output;
							baseTopOffset,	//_baseTopOffset : String output;
							fontSize,	//_fontSize : String output;
							fontName,	//_fontName : String output;
							printerName,	//_printerName : String output;
							error	//_error : Boolean output
							);

		
	if outputType &lt;&gt; "DOT"
	or fontSize.Integer &lt; 8
	or error
	then
		app.raiseUnexpectedProgramError(class.name, method.name, "Report Dot Matrix print options incorrect: " &amp; reportString &amp; ", expecting format of 'report name?DOT?offsetLeft?offsetTop?fontSize?fontName?printerName'");
		return;
	endif;
	
	app.printer.abort();
	app.printer.setPrinter( printerName );
	app.printer.printPreview := false;
	app.printer.setCustomPaperSize(form.getPageWidth, form.getPageHeight);
	app.printer.drawFontName := fontName;
	app.printer.drawFontSize := fontSize.Integer;
	app.printer.newPage;	
	app.printer.leftMargin := 0;
	app.printer.rightMargin := 0;
	
	form.initiateForm( baseLeftOffset.Integer, baseTopOffset.Integer );
	
	if app.isDevelopmentSystem and app.printer.getPrinterName[1:5].toUpper &lt;&gt; "EPSON" then
		showLabelArea := true;  // can only use this on a printer that is NOT a Dot Matrix printer.
	endif;
	
	form.setDataFieldsFromObject( _object, _lineUp, showLabelArea );
	form.printFields();

	app.printer.close();

epilog

	if app.printer.getPrinterName &lt;&gt; defaultPrinterName then
		app.printer.setPrinter( defaultPrinterName );
	endif;

	delete form;

end;
</source>
        <Parameter name="_reportName" type="String"/>
        <Parameter name="_object" type="CM_Object"/>
        <Parameter name="_lineUp" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="printReportDotMatrixLineUp" id="cf4c4129-f966-4d5e-87a2-d393fe7fe052">
        <source>printReportDotMatrixLineUp( _inputString: String );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 November 2012	cnwndl1	Initial creation	Par 30689

*/

constants

	Indent : String = "  ";
	
vars

	pos : Integer;
	reportClassName : String;
	reportClass : Class;
	
	pos1 : Integer;
	pos2 : Integer;
	pos3 : Integer;
	workStr : String;
	count : Integer;
	outputType : String;
	baseLeftOffset : String;
	baseTopOffset : String;
	fontSize : String;
	fontName : String;
	printerName : String;
	attributes : String;
	msg : String;
	error : Boolean;
	form : CMUI_DotMatrixBaseForm;

begin

	if _inputString &lt;&gt; null then
		pos := _inputString.pos("?DOT",1);
		if pos  &gt; 0 then
			reportClassName := _inputString[1:pos-1];
			reportClass := currentSchema.getClass( reportClassName );
			if reportClass = null or not reportClass.inheritsFrom( CMUI_DotMatrixBaseForm ) then
				return;
			endif;
			
			//create form as reportClass transient;
			form := reportClass.GUIClass.createPrintForm.CMUI_DotMatrixBaseForm;	// uses less GUI resources
			form.getParamValues(	_inputString,	//_inputString : String;
									outputType,	//_outputType : String output;
									baseLeftOffset,	//_baseLeftOffset : String output;
									baseTopOffset,	//_baseTopOffset : String output;
									fontSize,	//_fontSize : String output;
									fontName,	//_fontName : String output;
									printerName,	//_printerName : String output;
									error	//_error : Boolean output
									);
			
			attributes := Indent &amp; "left = " &amp; baseLeftOffset &amp; CrLf; 
			attributes := attributes &amp; Indent &amp; "top = " &amp; baseTopOffset &amp; CrLf;
			if fontSize &lt;&gt; null then
				attributes := attributes &amp; Indent &amp; "font size = " &amp; fontSize &amp; CrLf;
				if fontName &lt;&gt; null then
					attributes := attributes &amp; Indent &amp; "font = " &amp; fontName &amp; CrLf;
					if printerName &lt;&gt; null then
						attributes := attributes &amp; Indent &amp; "printer = " &amp; printerName &amp; CrLf;
					endif;
				endif;
			endif;
			
			if error then
				msg := app.getErrorString(Matrix_attribute_error) &amp; CrLf;
				msg := msg &amp; app.getErrorString(Attributes) &amp; ":" &amp; CrLf;
				msg := msg &amp; attributes &amp; CrLf; 
				msg := msg &amp; CrLf &amp; app.getErrorString(Example) &amp; " " &amp; form.getParamExample();
				app.msgBox( msg, app.getErrorString(Error), MsgBox_OK_Only );
				return;
			endif;
			
			msg := app.getErrorString1(Want_line_test_print, reportClassName) &amp; CrLf;
			msg := msg &amp; app.getErrorString(Attributes) &amp; ":" &amp; CrLf;
			msg := msg &amp; attributes &amp; CrLf; 
			if app.msgBox( msg, app.getErrorString(Test_print) &amp; " ?", MsgBox_Yes_No) = MsgBox_Return_Yes then
				app.printReportDotMatrix( _inputString, null, true );
			endif;
			
		endif;
	endif;

epilog

	delete form;

end;</source>
        <Parameter name="_inputString" type="String"/>
    </JadeMethod>
    <JadeMethod name="refreshToolbar" id="37f101c9-bcc2-41d2-b8d9-c6daa3f4bc92">
