    <JadeMethod name="createTranslatableTextItem" id="b1c015c5-1902-48c3-9d10-adf25fe83ca1">
        <source>createTranslatableTextItem();

vars
	category		 : XLAT_Category;
	constant		 : GlobalConstant;
	translatableText : XLAT_Permission;
begin
	// RBarr 1/9/2006 Localisation changes - create a translatable text object if required
	category := app.myRoot.allXLAT_Categories[XLAT_Permissions];
	constant := category.myConstantCategory.getConstants[constName].GlobalConstant;
	translatableText := category.allTranslatableText[constant.valueAsInteger].XLAT_Permission;
	if translatableText = null then
		create translatableText persistent;
	endif;
	translatableText.updateFromConstant(category, constant, category.constantCategoryName);
end;
</source>
    </JadeMethod>
    <JadeMethod name="getColourForRow" id="45619d51-28a1-4d91-9a6a-f114f117f7b2">
        <source>getColourForRow()  : Integer;
/*
Purpose:	

Date		Who		Reason
20 December 2024	navab1	JIRA 33502
*/

vars

begin
	if  self.constValue = Mod_BaseSystem then
		return PaleGreen;
	elseif self.description.pos("Core", 1) &gt; 0 then
		return PalePink;
	elseif self.constValue = Sub_ReeferJobs
	or self.constValue = Sub_EventStream then
		return Cn_PaleBlue;
	elseif self.constValue = Sub_InvoiceContracts
	or self.constValue = Sub_WorkOrderOperations
	or self.constValue = Sub_OwnershipChange
	or self.constValue = Sub_CustomDocuments then
		return PalePink;
	endif;
	

	return Cn_WedgeWoodBlue;

epilog

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getModulesList" id="c57176ad-d113-4fff-957a-ad55f1df176f">
        <source>getModulesList() : String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 August 2019	jlgab1	Initial creation

*/

vars
	category 	: ConstantCategory;
	constant 	: Constant;
	constvalue : Integer;
	modulesStr : String;
begin
	category := currentSchema.getCategory(XLAT_Permissions);		


	foreach constant in category.getConstants() do
		if constant.getSource.isInteger then
			constvalue := constant.getSource.Integer;
			
			if self.allChildValues.includes(constvalue) then
				if modulesStr = null then
					modulesStr := constant.name;
				else
					modulesStr := modulesStr &amp; ", " &amp; constant.name;
				endif;
			endif;
		endif;

	endforeach;
	
	return modulesStr;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getTranslatedDescription" id="be614732-44e8-435f-876e-8432ba6e401e">
        <source>getTranslatedDescription():String;

// get use the the global constant value (unique key) to get the translation for the current locale

vars
	locale		: CM_Locale;
	translation	: XLAT_Translation;
	constant	: GlobalConstant;
begin
	locale := app.myCurrentLocale;
	constant := app.myRoot.allXLAT_Categories[XLAT_Permissions].myConstantCategory.getConstants[constName].GlobalConstant;
	//constant := currentSchema.getSchema('PortSchema').getCategory(XLAT_Permissions).getConstants[constName].GlobalConstant;
	if constant &lt;&gt; null and locale &lt;&gt; null then
		translation := app.zGetTranslatedText(XLAT_Permissions, constant.valueAsInteger);
		if translation &lt;&gt; null and translation.text &lt;&gt; null then
			
			return translation.text;
		endif;
	endif;

	return self.description;
end;
</source>
        <ReturnType type="String"/>
    </JadeMethod>
