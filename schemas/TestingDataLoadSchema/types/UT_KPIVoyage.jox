    <JadeMethod name="createCargoOnSitePrenote" id="e2b79d87-29f1-4dbb-aed6-3f36046a83c4">
        <updating/>
        <source>createCargoOnSitePrenote() updating;
/*
Purpose:			
Date		Who		Reason
20 October 2011	cnwab1	Initial creation
27 Jul 2022	navsj20	TFS 53862	EUP - WMS - Damage Recording Extra Details
*/
vars
	aPort : CM_Port;
	voy : CM_Voyage;
	op : CM_Operator;

	booking: CM_BookingRef;
	ti: CM_TrackedItem;
	aStop : CM_StopsTable;
	ct : CM_CargoType;
	didRemove : Boolean;
	bookingOversubscribe : Boolean;
	criteria : CM_YACriteria;	//20 Jul 2022	navsj20	TFS 53862
begin
	
	write "Create cargo on site - prenote";
	app.writeLog("Create cargo on site - prenote", LogINFO);

	self.setTerminalConfig(BookingOversubscribe, true);
	
	voy := self.getVoyage(VoyageId);

	aPort := app.myRoot.allPorts["NZAKL"];
	op := app.myRoot.allOperators["MSL"];

	deleteContainer(IdPrefix &amp; "P8899001");
	deleteContainer(IdPrefix &amp; "P8899002");
	deleteContainer(IdPrefix &amp; "P8899003");
	deleteContainer(IdPrefix &amp; "P8899004");
	self.deleteBooking("UT_PNBOOKING");
	
	booking := self.addBookingForContainer("UT_PNBOOKING", op, voy, "NZAKL", "2200", "GENL");
	assertNotNull(booking);
	
	ct := app.myRoot.allCargoTypesById[TI_CargoType_Container];
	aStop := app.myRoot.allStopsTable[2];
	
	//if aStop.allCargoTypesNew.includes(ct) then		//20 Jul 2022	navsj20	TFS 53862
	if aStop.myStopCriteria &lt;&gt; null then
		foreach criteria in aStop.myStopCriteria.allCriteria where criteria.myYACriteriaType.type = YACriteriaType_CargoType
			and criteria.myYAData.CM_YADataObjects.allObjects.includes(ct) do		//27 Jul 2022	navsj20	TFS 53862
			beginTransaction;
			//aStop.allCargoTypesNew.remove(ct);							//20 Jul 2022	navsj20	TFS 53862
			criteria.myYAData.CM_YADataObjects.allObjects.remove(ct);		//27 Jul 2022	navsj20	TFS 53862
			commitTransaction;
			didRemove := true;
	endforeach;
	endif;
	ti := self.addPrenotedContainer(booking.allBookingRefItems.first,  IdPrefix &amp; "P8899001");
	ti := self.addPrenotedContainer(booking.allBookingRefItems.first,  IdPrefix &amp; "P8899002");
	ti := self.addPrenotedContainer(booking.allBookingRefItems.first,  IdPrefix &amp; "P8899003");
	ti := self.addPrenotedContainer(booking.allBookingRefItems.first,  IdPrefix &amp; "P8899004");
	assertNotNull(ti );
	
epilog

	// moved to correct spot
	if didRemove then
		beginTransaction;
		// START 27 Jul 2022	navsj20	TFS 53862
		//aStop.allCargoTypesNew.add(ct);
		if aStop.myStopCriteria &lt;&gt; null then
			foreach criteria in aStop.myStopCriteria.allCriteria where criteria.myYACriteriaType.type = YACriteriaType_CargoType do
				criteria.myYAData.CM_YADataObjects.allObjects.add(ct);
			endforeach;
		endif;
		// END 27 Jul 2022	navsj20	TFS 53862
		commitTransaction;
	endif;

end;</source>
    </JadeMethod>
    <JadeMethod name="createCargoOnship" id="f5591745-7f3e-4c4f-9453-ae930b67fd9a">
