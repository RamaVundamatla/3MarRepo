    <JadeMethod name="doResizeControls" id="21add417-58dd-4123-9541-da410f7feb95">
        <updating/>
        <source>doResizeControls(_initialSetup: Boolean) updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 October 2016	cnwndl1	Initial creation	TFS 2655 / 2419

*/

vars

	cTop : Real;
	cLeft : Real;
	stdWidth : Real;
	cWidth : Real;
	stdHeight : Real;
	cHeight : Real;
	tabIndex : Integer;
	frameHeight : Real;

begin

	self.setResizeableMarginAndFontSize();
	stdWidth := self.clientWidth - self.resizedMargin - self.resizedMargin;
	stdHeight := self.getStdControlHeight;
	
	cTop := self.resizedMargin + stdHeight;
	cLeft := self.resizedMargin;
	cWidth := stdWidth;
	cHeight := stdHeight;
	tabIndex := 4000;
	
	frameHeight := (self.clientHeight - cTop - self.getCMDButtonsHeight() - stdHeight - ( self.resizedMargin * 3 ) );
	
	if _initialSetup then
		self.frmMain.setAndIncrementTabIndex( tabIndex );
		self.frmMain.visible := true;
		self.frmMain.enabled := true;
	endif;
	self.frmMain.move(	0,
						0,
						self.clientWidth,
						frameHeight );
						
	cLeft := stdHeight;
	if _initialSetup then
		self.optBooking.setAndIncrementTabIndex( tabIndex );
		self.optBooking.visible := true;
		self.optBooking.enabled := true;
		self.optBooking.value := false;
		self.optBooking.parent := self.frmMain;
	endif;
	self.optBooking.move(	cLeft,
							cTop,
							cWidth,
							cHeight ); 
						
	cTop := cTop + self.optBooking.height + (self.resizedMargin * 2);
	if _initialSetup then
		self.optRelease.setAndIncrementTabIndex( tabIndex );
		self.optRelease.visible := true;
		self.optRelease.enabled := true;
		self.optRelease.value := false;
		self.optRelease.parent := self.frmMain;
	endif;
	self.optRelease.move(	cLeft,
							cTop,
							cWidth,
							cHeight ); 
						
	cTop := cTop + self.optRelease.height + stdHeight;
	cLeft := self.resizedMargin;
	//28 Nov 2016	NDL	TFS 2955 / 2001
	if _initialSetup then
		self.txtDocumentId.setAndIncrementTabIndex( tabIndex );
		self.txtDocumentId.visible := false;
		self.txtDocumentId.parent := self.frmMain;
	endif;
	self.txtDocumentId.move(cLeft,
							cTop,
							cWidth,
							cHeight ); 
						
	cTop := cTop + self.txtDocumentId.height + stdHeight + self.resizedMargin;
	if _initialSetup then
		self.cmbBookings.setAndIncrementTabIndex( tabIndex );
		self.cmbBookings.visible := false;
		self.cmbBookings.parent := self.frmMain;
	endif;
	self.cmbBookings.move(	cLeft,
							cTop,
							cWidth,
							cHeight ); 
						
	cTop := cTop + self.cmbBookings.height + self.resizedMargin;
	if _initialSetup then
		self.cmbBookingItems.setAndIncrementTabIndex( tabIndex );
		self.cmbBookingItems.visible := false;
		self.cmbBookingItems.parent := self.frmMain;
	endif;
	self.cmbBookingItems.move(	cLeft,
								cTop,
								cWidth,
								cHeight ); 
						
	cTop := cTop + self.cmbBookingItems.height + self.resizedMargin;
	if _initialSetup then
		self.cmbReleases.setAndIncrementTabIndex( tabIndex );
		self.cmbReleases.visible := false;
		self.cmbReleases.parent := self.frmMain;
	endif;
	self.cmbReleases.move(	cLeft,
							cTop,
							cWidth,
							cHeight ); 
						
	cTop := cTop + self.cmbReleases.height + self.resizedMargin;
	if _initialSetup then
		self.cmbReserveDetails.setAndIncrementTabIndex( tabIndex );
		self.cmbReserveDetails.visible := false;
		self.cmbReserveDetails.parent := self.frmMain;
	endif;
	self.cmbReserveDetails.move(	cLeft,
								cTop,
								cWidth,
								cHeight ); 
						
	cTop := cTop + self.cmbReserveDetails.height + self.resizedMargin;
	
	inheritMethod(_initialSetup);

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_initialSetup" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="findBooking" id="7842ebfe-8dfa-4862-b0e4-75831898ae00">
        <source>findBooking( _str : String );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 November 2016	cnwndl1	Initial creation	TFS 2955 / 2001

*/

vars

	index : Integer;

begin
	
	if self.cmbBookings.listCount &lt; 1 then
		self.cmbBookings.listIndex := -1;	
		return;
	elseif self.cmbBookings.listCount = 1 or _str = self.lblDocumentId.caption.toUpper then
		self.cmbBookings.listIndex := 1;	
		return;
	endif;
	
	index := self.cmbBookings.findStringExact( 1, _str );
	
	if index &lt; 1 then
		index := self.cmbBookings.findString( 1, _str );
	endif;
		
	if index &gt; 1 then
		self.cmbBookings.listIndex := index;	
	else
		self.cmbBookings.listIndex := 1;	
	endif;

epilog

	self.cmbBookings.click( self.cmbBookings );

end;</source>
        <Parameter name="_str" type="String"/>
    </JadeMethod>
    <JadeMethod name="findRelease" id="34f31eb3-74bf-4a82-b428-67dfbf1eeea6">
        <source>findRelease( _str : String );
/*

Purpose:			

