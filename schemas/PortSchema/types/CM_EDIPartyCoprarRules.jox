<Class name="CM_EDIPartyCoprarRules" id="d27f93bf-d5a2-4f17-acef-ef854d2fa7e1">
    <superclass name="CM_EDIPartyRules"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="edi"/>
    <JadeMethod name="create" id="53dc8620-1ad8-4618-a78c-6e1ab8f0ef48">
        <updating/>
        <source>create() updating;
//
// 21 Aug 2017	jlgrs1	TFS 6797 Special Stow for Coprar
//
vars
	type : CM_EDIFileType;
begin
	// set file type
	type := app.myRoot.allEDIFileTypes.getAtKeyGeq(EDIFileType_Coprar, null);
	
	if type = null or 
	   type.type &lt;&gt; EDIFileType_Coprar then
		app.raiseUnexpectedProgramError (self.class.name, method.name, 'Coprar file type missing');
	endif;
	
	self.myEDIFileType	:= type;
epilog

end;</source>
    </JadeMethod>
</Class>
