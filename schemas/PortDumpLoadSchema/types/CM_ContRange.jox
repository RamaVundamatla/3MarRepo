<Class name="CM_ContRange">
    <JadeMethod name="importPLXMLReference" id="832ffb39-264f-4380-afe1-fb733200f334">
        <source>importPLXMLReference(_name, _theCode, _referencesBlock: String): Object;

vars

begin
	if _name = CM_ContRange::myRoot.name then
		return app.myRoot;
	else
		return null;
	endif;
end;</source>
        <Parameter name="_name" type="String"/>
        <Parameter name="_theCode" type="String"/>
