    <JadeMethod name="listFlags" id="aba7f79d-2744-481a-998e-b1ae730ba5ac">
        <source>listFlags(): String;
// ---------------------------------------------------------------------------
// Created:     Oct 2004 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	str: String;
begin
	str := str&amp;inheritMethod();
	if self.secondary then
		str := str&amp;"/Secondary ";
	endif; 
	return str;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="saveVersionCopyRefs" id="5b3d0f3a-0450-40b1-8c78-7b2ed8c7c703">
        <source>saveVersionCopyRefs(toClone: CM_Attach input) protected;
/*
 ------------------------------------------------------------------------
Created:			13 September 2002 by cnwdwq1
Purpose:			
Parameters:		None
Returns:			Nothing
Changed On		Changed By		Reason
--------------		--------------		-----------------------------------------
---------------------------------------------------------------------------
*/
vars

begin
	inheritMethod(toClone);
	toClone.otherTrackedItem := self.otherTrackedItem;
end;</source>
        <access>protected</access>
        <Parameter name="toClone" type="CM_Attach" usage="input"/>
    </JadeMethod>
    <JadeMethod name="secondary" id="0797d15d-abda-4442-b871-75f7f8531d51">
        <methodInvocation>mapping</methodInvocation>
        <updating/>
        <source>secondary(set: Boolean; _value: Boolean io) mapping, updating;
/*
 ------------------------------------------------------------------------
Created:			05 April 2002 by cnwdwq1
Purpose:			
Parameters:		None
Returns:			Nothing
Changed On		Changed By		Reason
--------------		--------------		-----------------------------------------
---------------------------------------------------------------------------
*/
begin
	if set then
		if _value then
			flags := flags.bitOr(SecondaryFlag);
		else
			flags := flags.getValueWithBitUnset(SecondaryFlag);
		endif;
	else
		_value := (flags.bitAnd(SecondaryFlag) &lt;&gt; 0);
	endif;
end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="Boolean" usage="io"/>
    </JadeMethod>
    <JadeMethod name="setOtherTrackedItem" id="47e19e5d-235f-4e51-8f65-8ae5ce1770e3">
        <updating/>
        <source>setOtherTrackedItem(pTI : CM_TrackedItem) updating;
// ---------------------------------------------------------------------------
// Created:     13 September 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	self.otherTrackedItem		:= pTI;
	self.otherTrackedItemId		:= pTI.id;
	self.otherTrackedItemCargoType	:= pTI.cargoType;
	
end;</source>
        <Parameter name="pTI" type="CM_TrackedItem"/>
    </JadeMethod>
