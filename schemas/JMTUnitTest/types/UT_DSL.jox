    <JadeMethod name="machineDirector" id="a402b994-3fc8-423c-a8b2-ed32d4050b4a">
        <source>machineDirector(_machine: CM_Machine; _ti: CM_TrackedItem) protected;
//07 January 2009	cnwdw1	
//17 November 2022	navhl20 ChangeRequest 52721: PNL - Delivery Requests - Assign Cargo to Specified Release Request
vars
	mediator : CM_RadioTelemetryMediator;
begin
	create mediator transient;
	mediator.machine := _machine;
	mediator.task := _machine.currentQueueTask;
	mediator.setActiveTerminal(self.getTerminal);
	app.myTrxRT.trxActionDirectorTask(_ti.id , null, mediator, false, true, null,null,null, app.myPassport);
	//Start 17.11.2022 navhl20 TFS 52721
	//self.assertNoTrxErrorsOrWarnings();
	if not app.myPassport.hasErrors then
		self.assertNoTrxErrorsOrWarnings();
	endif;
	//End 17.11.2022 navhl20 TFS 52721
epilog
	delete mediator;
end;</source>
