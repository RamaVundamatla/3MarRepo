    <JadeMethod name="doBrowseFile" id="3928395b-fc23-4160-8f19-b9167ab2a498">
        <source>doBrowseFile();

vars
	dlg : CMDFileSave;
begin
	create dlg;
	dlg.fileName := txtFileName.text;
	dlg.dialogTitle := "Enter Text Translation Export File Name";
	dlg.fileMustExist := false;
	dlg.createPrompt := false;
	dlg.filter := "Comma Separated Variable (*.csv)|*.csv|All Files (*.*)|*.*";
	dlg.defaultExt := "csv";
	if dlg.open = 0 then
		txtFileName.text := dlg.fileName;
	endif;
	statusLine.caption := null;
epilog
	delete dlg;
end;
</source>
    </JadeMethod>
    <JadeMethod name="doExport" id="31c94085-86d3-4d4b-866c-455cf14aa82f">
        <updating/>
        <source>doExport() updating, protected;

vars
	file : File;
	localeName : String;
	selectedCategories : XLAT_CategoryByConstantCategry;
	category : XLAT_Category;
	idx	: Integer;
begin
	statusLine.caption := null;
	statusLine.refreshNow;
	
	on FileException do fileExHandler(exception);

	create file transient;
	file.mode := File.Mode_Output;	// 4/3/16 cnwmp6 PAR 36286 unicode version
	file.fileName := txtFileName.text;
	if file.isAvailable then
		file.purge();
	endif;
	localeName := cmbLocale.listObject.CM_Locale.localeId;

	create selectedCategories transient;
	if chkTextMessages.value then
		selectedCategories.add(agent.myRoot.allXLAT_Categories[XLAT_Exceptions]);
	endif;
	if chkFormCaptions.value then
		selectedCategories.add(agent.myRoot.allXLAT_Categories[XLAT_FormCaptions]);
	endif;
	if chkMenuEntities.value then
		selectedCategories.add(agent.myRoot.allXLAT_Categories[XLAT_Menus]);
	endif;
	if chkPermissions.value then
		selectedCategories.add(agent.myRoot.allXLAT_Categories[XLAT_Permissions]);
	endif;
	if chkReportNames.value then
		selectedCategories.add(agent.myRoot.allXLAT_Categories[XLAT_ReportNames]);
	endif;
	if chkTableEntities.value then
		selectedCategories.add(agent.myRoot.allXLAT_Categories[EntTableRows]);
	endif;

	agent.setupProgressCallback(self,
								SOP_TextTranslationExportForm::zInitialiseProgressMonitor.name,
								SOP_TextTranslationExportForm::zUpdateProgressMonitor.name,
								"Exporting translatable text in CSV format");

	//agent.doExportCSV(file, localeName, self.optAll.value, selectedCategories, false);
	// do the test file
	agent.doExportCSV(file, localeName, self.optAll.value, selectedCategories, app.isDevelopmentSystem);

epilog
	delete file;
	delete selectedCategories;
	if myProgress &lt;&gt; null then
		zFinaliseProgressMonitor;
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="enableButtons" id="bfc84d8b-f1fb-403b-b6a6-a6fe9a1b6af9">
        <source>enableButtons();

vars

begin
	btnExport.enabled := 
			(chkTextMessages.value or 
			chkFormCaptions.value or 
			chkMenuEntities.value or 
			chkPermissions.value or 
			chkReportNames.value or 
			chkTableEntities.value) and 
			cmbLocale.listObject &lt;&gt; null and 
			txtFileName.text &lt;&gt; null;
	
	statusLine.caption := null;
end;</source>
    </JadeMethod>
    <JadeMethod name="fileExHandler" id="40dccc9d-5e88-45f7-bb37-27af5e4c4f8e">
        <source>fileExHandler(ex : FileException) : Integer;

vars

begin
	statusLine.caption := ex.text;
	return Ex_Abort_Action;
end;
</source>
        <Parameter name="ex" type="FileException"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="generateDefaultFileName" id="2e35f8ca-3c20-4ced-b7b9-edfa20ff43f7">
        <source>generateDefaultFileName();

vars

begin
	// If a locale has been selected generate a default one.
	if cmbLocale.listObject &lt;&gt; null then
		txtFileName.text := "C:\Translations_" &amp; cmbLocale.listObject.CM_Locale.localeId &amp; ".csv";
	endif;
	enableButtons;
end;
</source>
    </JadeMethod>
    <JadeMethod name="setAgent" id="d1506450-cab2-46c8-aa29-e618e1619c98">
        <updating/>
        <source>setAgent(agent : CM_TranslationAgent) updating;
// Used by the SOP_TextTransalationForm to pass the agent object
vars

begin
	self.agent := agent;
end;
</source>
        <Parameter name="agent" type="CM_TranslationAgent"/>
    </JadeMethod>
    <JadeMethod name="setupForm" id="2a75aa91-deb1-44e1-956d-6330711a4cfe">
        <updating/>
        <source>setupForm() updating;

//
// Changed On   Changed By  PAR             Reason
// ----------   ----------  --------------  ------------------------------------
//  09/10/2009	cnwmh5		21251			Help file Added
// ---------------------------------------------------------------------------
//

vars
	category : XLAT_Category;
	locale	: CM_Locale;
	idx		: Integer;

begin
	inheritMethod();
	btnOk.visible:= false;
	
	btnCancel.top := btnExport.top;
	btnCancel.left := btnBrowseFile.left;
	btnCancel.width := btnBrowseFile.width;
	btnCancel.parentAspect := Control.ParentAspect_None;
	
	self.height := btnCancel.top + btnCancel.height + statusLine.height + 40;

	cmbLocale.displayCollection(agent.myRoot.allLocales, false, 0, null, null);
	cmbLocale.listIndex := cmbLocale.findObject(agent.myRoot.myDefaultLocale);
	if cmbLocale.listIndex = -1 then
		cmbLocale.listIndex := cmbLocale.findObject(agent.myRoot.getStandardTextLocale(false));
	endif;
	
	self.enableButtons();
	
	self.helpFileName := HelpFile_Admin;				// 09/10/2009 PAR 21251
	
end;</source>
    </JadeMethod>
    <JadeMethod name="translateForm" id="e41e6119-aad1-463b-b62c-3f6d481ce5be">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0007179, locale);
	btnBrowseFile.translateCaption(Xlat_0004098, locale);
	btnExport.translateBubbleHelp(Xlat_0004111, locale);
	btnExport.translateCaption(Xlat_0004112, locale);
	chkFormCaptions.translateCaption(Xlat_0007180, locale);
	chkMenuEntities.translateCaption(Xlat_0007181, locale);
	chkPermissions.translateCaption(Xlat_0007182, locale);
	chkReportNames.translateCaption(Xlat_0007183, locale);
	chkTableEntities.translateCaption(Xlat_0007184, locale);
	chkTextMessages.translateCaption(Xlat_0007185, locale);
	lCategories.translateCaption(Xlat_0014514, locale);
	lFilename.translateCaption(Xlat_0004113, locale);
	lLocale.translateCaption(Xlat_0014515, locale);
	lblExtract.translateCaption(Xlat_0007186, locale);
	optAll.translateCaption(Xlat_0007187, locale);
	optSearchResults.translateCaption(Xlat_0007188, locale);
end;</source>
    </JadeMethod>
