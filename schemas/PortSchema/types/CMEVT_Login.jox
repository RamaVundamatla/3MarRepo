    <JadeMethod name="setDetailsFromCMIF" id="aeea007a-2e16-4598-954c-7785e59aed89">
        <updating/>
        <source>setDetailsFromCMIF(_eventType: CM_EventType; _cmifEventTrx: CMIF_EventTransactionCtrl) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17/02/2025	navkc1 JIRA Bug MTN-33582: MTN | Event Charging Refactor

*/

vars
	excOccurred : Boolean;
begin

	on CM_Exception do app.handleTransactionMapError(exception, excOccurred);
	
	inheritMethod(_eventType, _cmifEventTrx);

epilog
	on CM_Exception do null;
end;</source>
        <Parameter name="_eventType" type="CM_EventType"/>
        <Parameter name="_cmifEventTrx" type="CMIF_EventTransactionCtrl"/>
    </JadeMethod>
    <JadeMethod name="setTimeLoggedOn" id="b77c48c2-406c-497f-91b6-32721ff4b58a">
        <updating/>
        <source>setTimeLoggedOn(_dateTime : TimeStamp) updating;
// ---------------------------------------------------------------------------
// Created:     09 October 2007 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	
begin

	self.timeLoggedOnSeconds := (self.dateTime.cnEcDiff(_dateTime) / 1000).rounded;
	
end;</source>
        <Parameter name="_dateTime" type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="timeLoggedOnMinutes" id="50a093a2-720a-479a-ae30-886c1dfcdbac">
        <methodInvocation>mapping</methodInvocation>
        <source>timeLoggedOnMinutes(set: Boolean; _value: Integer io) mapping;
// ---------------------------------------------------------------------------
// Created:     09 October 2007 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	numSecs	: Integer;
	
begin
	if set then
		// set code here
		app.raiseSetVirtualError(class.name, method.name);
	else
		// get code here
		numSecs := self.timeLoggedOnSeconds;
		if numSecs &gt;= 0 then
			_value := (numSecs / 60).rounded;
		else
			_value := -1;
		endif;
	endif;


end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="timeLoggedOnSeconds" id="a6afd324-7970-4241-8167-da0aa684b75a">
        <methodInvocation>mapping</methodInvocation>
        <source>timeLoggedOnSeconds(set: Boolean; _value: Integer io) mapping;
// ---------------------------------------------------------------------------
// Created:     09 October 2007 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	toTime	: TimeStamp;
	diffMS	: Decimal[16];

begin
	if set then
		// let system set
		
	else
		// get code here
		if self.timeLoggedOnSeconds &gt;= 0 then
			_value := self.timeLoggedOnSeconds;
		else
			if self.myEventLogout = null then
				if self.dateTime &lt; app.getServerStartTime then
					// no logout was created
					_value := -1;
				else
					// assume still logged on
					toTime := app.actualTimeServer;
				endif;
			else
				toTime := self.myEventLogout.dateTime;
			endif;
			
			diffMS := self.dateTime.cnEcDiff(toTime);
			
			_value := (diffMS / 1000).rounded;
			
		endif;
	endif;


end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="Integer" usage="io"/>
    </JadeMethod>
</Class>
