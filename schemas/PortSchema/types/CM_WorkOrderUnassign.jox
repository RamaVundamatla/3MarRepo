<Class name="CM_WorkOrderUnassign" id="393d821a-97fc-45b9-ad6f-c019ee3df51a">
    <superclass name="CM_TITransaction"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="workorder"/>
    <ImplicitInverseRef name="myWorkOrder" id="9d927af3-f581-4327-9a28-1056000b071a">
        <embedded/>
        <type name="CM_WorkOrderTI"/>
        <access>readonly</access>
    </ImplicitInverseRef>
    <JadeMethod name="getDisplayStringForAttribute" id="85d77a27-1c99-48ba-9c92-9d2d23a489f2">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
04 June 2010	cnwndl1	Initial creation	Par 23498
08/03/2011	cnwmh5	PAR #27142 - Change to local variable rather than self for handleDeleteObject exception
*/

vars
	lDetail : String;
	invalidWO : Boolean;
	workOrder	: CM_WorkOrderTI;
begin

	if _attrName = ETRow_Details  then
		if self.deleted then
			return self.getDeletedDetails();		// 15/10/18 MAP TFS41191
			
		else
			on Exception do app.handleDeletedObject(exception, workOrder, invalidWO); 
			workOrder := self.myWorkOrder;
			lDetail := "Unassined from " &amp; workOrder.id;
			return lDetail;
		endif;
							
	else
		return inheritMethod(_attrName, _short);
	
	endif;

epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getEnquiryRow" id="3ccbc48a-2739-4a1f-b0cb-0d1281f414bc">
        <source>getEnquiryRow(): String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
08 December 2009	cnwrd1	Initial creation

*/

vars
	lDetail 	: String;
begin
	lDetail := inheritMethod();

	return lDetail &amp; "Unassined from " &amp; self.myWorkOrder.id;		
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="setFromCMIF_TITransactionCntrl" id="075d648b-4c3d-4e82-873f-492ddf9c577a">
        <updating/>
        <source>setFromCMIF_TITransactionCntrl(_tiTransCntrl: CMIF_WorkOrderTransController; _passport: CM_Passport input) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
08 December 2009	cnwrd1	Initial creation

*/

vars

begin

	self.myWorkOrder := _tiTransCntrl.myWorkOrder;
	inheritMethod(_tiTransCntrl, _passport);

epilog

end;</source>
        <Parameter name="_tiTransCntrl" type="CMIF_WorkOrderTransController"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
</Class>
