	return "RPKRO." &amp; self.getOidString;
	
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getInaportnetSPK" id="4c7ffab7-edb8-4522-80f8-dc9cd7e46311">
