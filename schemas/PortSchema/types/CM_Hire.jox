        <type name="String"/>
    </PrimAttribute>
    <JadeMethod name="canUpdateTransaction" id="22835478-9c7f-452a-8955-5aaf3e1c7e7b">
        <source>canUpdateTransaction(): Boolean;
// ---------------------------------------------------------------------------
// Created:     02 September 2003	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars

begin
	return true;

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="81851873-a9c8-464d-8a53-8a936b919c54">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
04 June 2010	cnwndl1	Initial creation	Par 23498

*/

vars
	lDetail : String;
begin

	if _attrName = ETRow_Details  then
		if self.deleted then
			return self.getDeletedDetails();		// 15/10/18 MAP TFS41191
			
		else
			lDetail := self.getHireDetails() &amp; " " &amp; self.urNumber.String;		
			return lDetail;
			
		endif;
	elseif _attrName = 	ETRow_Disposition	then
		return self.fleetDisposition;
	elseif _attrName = ETRow_HireType then
		return self.hireType;
	elseif _attrName = ETRow_Owner then
		return self.ownership;
	elseif _attrName = ETRow_MessageStatus then
		return self.messageStatus;
	elseif _attrName = ETRow_OtherParty then
		return self.otherParty;
	elseif _attrName = ETRow_Hire then
		return self.getHireDetails();
	else
		return inheritMethod(_attrName, _short);
	
	endif;

epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getEnquiryRow" id="6ba45b44-08a5-4317-aabd-5fb0a1e3b141">
        <source>getEnquiryRow(): String;
// ---------------------------------------------------------------------------
// Created:  May  2001 By Andrew Bishop cnwab1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	lDetail : String;
begin
	lDetail := inheritMethod();

	        
	lDetail := lDetail &amp; self.getHireDetails();

	if lDetail &lt;&gt; "" then
		lDetail := lDetail &amp; " " &amp; self.urNumber.String;
	else
		lDetail := self.urNumber.String;
	endif;			
	
	return lDetail;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getHireDetails" id="157cc4bb-0df0-4759-bd8f-092fa9c8d606">
        <source>getHireDetails() : String protected;
// Jan 2012 factored out of the other methods for CCMS 1262 transaction enquiry
vars
	lDetail		: String;
begin
	if self.hireType = "ONH" or self.hireType = "SRO" then
		lDetail := "Oper: " &amp; self.otherParty.trimBlanks &amp; "-&gt;" &amp; self.operatorCode.trimBlanks &amp; ",";
	else
		lDetail := "Oper: " &amp; self.operatorCode.trimBlanks &amp; "-&gt;" &amp; self.otherParty.trimBlanks &amp; ",";
	endif;
	lDetail := lDetail &amp;  " Ownership: " &amp; self.ownership.trimBlanks &amp; ", Fleet Disp.: " &amp; self.fleetDisposition.trimBlanks;
	return lDetail;
end;
</source>
        <access>protected</access>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="setFromCMIF_TITransactionCntrl" id="5346faf7-f9e6-4541-937c-42dd11afc392">
        <updating/>
        <source>setFromCMIF_TITransactionCntrl(_tiTransCntrl: CMIF_TITransactionController; _passport: CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:     12 June 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
vars

begin
	//th2 PAR 11962 - whoever implemented user defined todo tasks failed to consider
	//the fact that user may associate any TI transaction type to create along with it.
	//For toDoTasks the _tiTransCntrl is always just type CMIF_TITransactionController
	if CMIF_HireTransController.hasInstance(_tiTransCntrl) then
		self.fleetDisposition 		:= _tiTransCntrl.CMIF_HireTransController.fleetDisposition;
		self.hireType			 	:= _tiTransCntrl.CMIF_HireTransController.hireType;
		self.ownership 				:= _tiTransCntrl.CMIF_HireTransController.ownership;
		self.messageStatus 			:= _tiTransCntrl.CMIF_HireTransController.messageStatus;
		self.otherParty		 		:= _tiTransCntrl.CMIF_HireTransController.otherParty;
	endif;
		
	inheritMethod(_tiTransCntrl, _passport);


end;</source>
        <Parameter name="_tiTransCntrl" type="CMIF_TITransactionController"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
</Class>
