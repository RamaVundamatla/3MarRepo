    </JadeMethod>
    <JadeMethod name="setProxyFromObject" id="9e8cea56-83d8-41c7-a2e7-a23f3ae60dc0">
        <updating/>
        <source>setProxyFromObject(kpiTruckCargo : CM_KPITruckByCargo;includeDetails : Boolean) updating;
/*
 
Purpose:			
 
Parameters:			
 
Return Value:		
 
Date		Who		Reason
24 Nov 2025	navbs1	Initial creation Story MTN-36661: MTN | KPI REST API - Truck Turn Around
 
*/
 
vars
		cargo 		:	CM_TrackedItem;
		wsCargo   	: 	WS_RestCargoObject;
		vvr 		:	CM_VehicleVisitRecord;
		wsVVR   	: 	WS_RestVehicleVisit;
		invalidObject 	: Boolean;
begin
	self.cargoCompositeKey	:= kpiTruckCargo.code;
	self.accrualCode := kpiTruckCargo.dateTime.Date.String;
	self.dwellTimeAvg := kpiTruckCargo.dwellTimeAve;
	self.dwellTimeMax := kpiTruckCargo.dwellTimeMax;
	self.dwellTimeMin := kpiTruckCargo.dwellTimeMin;
	self.dwellTimeTotal := kpiTruckCargo.dwellTimeTotal;
	self.numTruck := kpiTruckCargo.numTrucks;
	if includeDetails then 
		on Exception do app.handleDeletedObject(exception, vvr, invalidObject);
		foreach vvr in kpiTruckCargo.allVehicleVisitRecords do 
			vvr.edition;
			if invalidObject = true then 
				invalidObject := false;
				continue;
			endif;
			create wsVVR transient;
			wsVVR.setProxyFromObject(vvr);
			self.vehicleVisits.add(wsVVR);
		endforeach;
		on Exception do null;
		on Exception do app.handleDeletedObject(exception, cargo, invalidObject);
		foreach cargo in kpiTruckCargo.allCargo do 
			cargo.edition;
			if invalidObject then
				invalidObject := false;
				continue;
			endif;
			create wsCargo transient;
			wsCargo.setProxyFromObject(cargo);
			self.cargo.add(wsCargo);
		endforeach;
		on Exception do null;
	endif;	

epilog
 
end;</source>
        <Parameter name="kpiTruckCargo" type="CM_KPITruckByCargo"/>
        <Parameter name="includeDetails" type="Boolean"/>
    </JadeMethod>
</Class>
