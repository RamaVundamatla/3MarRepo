    <JadeMethod name="isDamageParty_Match" id="f0736f27-7706-446a-a9e3-e2b6771fbf17">
        <source>isDamageParty_Match(_yaData: CM_YADataObjects): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
12 July 2022	navsj20	ChangeRequest 53862: EUP - WMS - Damage Recording Extra Details

*/

vars
	numRepaired : Integer;
	party : CM_DamageParty;
begin
	//return inheritMethod();

	if _yaData.isEmpty() then
		return true;
	endif;

	if self.myTransaction = null then
		return false;
	endif;

	if not self.myTransaction.isKindOf(CM_RepairDetail) then
		return false;
	endif;

	if self.myTransaction.CM_RepairDetail.myDamagesInstance &lt;&gt; null then
		party := self.myTransaction.CM_RepairDetail.myDamagesInstance.myDamageParty;
	endif;
	
	if party = null then
		return false;
	endif;
	
	return _yaData.matches(party);
epilog

end;</source>
        <Parameter name="_yaData" type="CM_YADataObjects"/>
        <ReturnType type="Boolean"/>
