    <JadeMethod name="doAddTab" id="1028150a-b1e7-4fbf-a21a-d4cc1ac3b48e">
        <source>doAddTab(_property :CM_QueryProperty; _beforeButton :Button):Button protected;
// ---------------------------------------------------------------------------
// Created:     01 December 2008 by concms1
