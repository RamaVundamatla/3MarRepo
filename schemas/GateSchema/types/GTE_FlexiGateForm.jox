	else
		headingStr := app.getErrorString(TYPE) &amp; Tab &amp; app.getErrorString(DETAIL) &amp; Tab &amp; app.getErrorString(BOOKING_RELEASE);
	endif;
	
	table.addItem( headingStr  );
	table.fixedRows := 1;
	table.selectMode := Table.SelectMode_CurrentRow;
