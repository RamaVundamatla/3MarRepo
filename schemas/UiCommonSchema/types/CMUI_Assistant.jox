    <JadeMethod name="comboBoxSrcLocn" id="36e6b79d-1d35-4283-8c60-cea05369d4f2">
        <source>comboBoxSrcLocn(pCmb : ComboBox input; pSrcLocn : CM_SourceLocation; pCodeGroup:CM_CodesByCodeDict);
//--------------------------------------------------------------
//Created: March 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	code : CM_Code;			//cnwmc5 - 26 Nov 2013 - PAR 33068
begin

	if pCodeGroup &lt;&gt; null then
		//cnwmc5 - 9 Jan 2013 - PAR 33274 - no longer need work around as JADE Plant fixed listCollection issue.. 
		pCmb.listCollection(pCodeGroup, true, 0);
		
		//cnwmc5 - 26 Nov 2013 - PAR 33068 - work around for JADE listCollection issue..
		/*foreach code in pCodeGroup do
			//cnwmc5 - 27 Nov 2013 - PAR 33087 - additional changes for work around of listCollection issue..
			if code.CM_SourceLocation = null then
				continue;
			endif;
		
			if code.CM_SourceLocation.notAvailableForEntry then 
				continue;
			endif;
			
			pCmb.itemObject[pCmb.addItem(code.code &amp; Tab &amp; code.description)] := code;
		endforeach;*/
	else
		pCmb.clear();		
	endif;
	
	if pSrcLocn &lt;&gt; null then
		pCmb.text := self.displayEntrySrcLocn(pSrcLocn);
	else
		pCmb.text := null;
	endif;
end;</source>
