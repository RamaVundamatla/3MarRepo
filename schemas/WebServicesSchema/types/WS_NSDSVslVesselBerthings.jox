    <JadeMethod name="setFromOpsViewTable" id="a905a46b-17f8-4f9a-8469-93888345248c">
        <updating/>
        <source>setFromOpsViewTable(_berth : CMIF_VslVesselBerthings; _seq : Integer io) updating;
/*
Purpose:			

Date		Who		Reason
09 December 2021	navab1	TFS 51853
*/

vars

begin
	inheritMethod(_berth, _seq);
	
	self.tableName := _berth.tableName;
	self.gkey  := _berth.gkey;
	_seq := _seq +1;
	self.seq := _seq;
	
	self.ata := _berth.ata;
	self.atd := _berth.atd;
	self.quay := _berth.quay;
	self.ship_side_to := _berth.ship_side_to;
	self.vvd_gkey := _berth.vvd_gkey;

epilog

end;</source>
        <Parameter name="_berth" type="CMIF_VslVesselBerthings"/>
        <Parameter name="_seq" type="Integer" usage="io"/>
