    <JadeMethod name="getDDExtraCharges" id="6c6283e5-6473-438b-86ad-b32376b875f8">
        <source>getDDExtraCharges( _dd : CM_DutyDoc; _allExtraChargeInvLines : CM_InvoiceLineByDateTimeDict input );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
31 Jan 2014			cnwndl1		Initial creation	Par 33181
21 Apr 2016 		cnwma1 		PAR #37681  QNS - locking issue
21 Oct 2019 		cnwma1 		Bug 47081: JMT - Decimal amount on Cash needs to be reviewed
13 September 2022	navpw1		TFS: 54565 (54384) - EUP - Inv Config - Invoice Surcharges
*/

vars
	debtor 			: CM_Debtor;
	startObject 	: CM_Invoice;
	iter 			: Iterator;
	invoice		    : CM_Invoice;
	invLine 		: CM_InvoiceLine;

begin
	debtor := _dd.getMyDebtor;
	if debtor = null then
		return;
	endif;
	
	if not debtor.isCashOnlyDebtor(self.myTerminal) then
		return;
	endif;
	
	if debtor.allInvoices.isEmpty then
		return;
	endif;
	
	startObject := debtor.allInvoices.getAtKeyGeq(self.myTerminal,null,null);
	if startObject = null or startObject.myTerminal &lt;&gt; self.myTerminal then
		return;
	endif;
	
	iter := debtor.allInvoices.createIterator;
	iter.startAtObject(startObject);
	while iter.next( invoice ) do
		if invoice.myTerminal &lt;&gt; self.myTerminal then
			break;
		endif;
		//if invoice.invoiceType.isCargoItemSpecific() then
		if invoice.invoiceType.isCargoItemSpecificDebtor(debtor) then						// ### TFS 54565 (54384) 22Sep2022 NAVPW1
			continue;
		endif;
		if invoice.isVoided then
			continue;
		endif;
		if invoice.getTotalAmount() = 0 then												//21.10.2019 cnwma1 TFS #47081
			continue;
		endif;
		//foreach invLine in invoice.invoiceLines where not invLine.voided do
		foreach invLine in invoice.invoiceLines discreteLock where not invLine.voided do	//21/04/2016 cnwma1 PAR #37681 
			if invLine.remarks.pos(_dd.id,1) &lt;&gt; 1 then
				continue;
			endif;
			_allExtraChargeInvLines.addNoDuplicates( invLine, false );
		endforeach;
	endwhile;
	
epilog
	delete iter;
	
end;</source>
        <Parameter name="_dd" type="CM_DutyDoc"/>
        <Parameter name="_allExtraChargeInvLines" type="CM_InvoiceLineByDateTimeDict" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getDDOtherReceipts" id="5b7ba747-0285-462c-8096-209ebb729387">
        <source>getDDOtherReceipts( _otherReceipts : CM_CashReceiptDict input );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 February 2014	cnwndl1	Initial creation	Par 33181

*/

vars

	strArray : CnStringArray;
	str : String;
	obj : Object;
	cashReceipt : CM_CashReceipt;
	invalid : Boolean;
	edition : Integer;

begin

	if _otherReceipts = null then
		return;
	endif;

	global.getExtraData( self.allExtraData, self.DD_OtherReceipts, str );
	
	if str.trimBlanks = null then
		return;
	endif;

	on Exception do app.handleDeletedObject(exception, obj, invalid);
	
	strArray := str.cnGetTokens(",");
	
	foreach str in strArray do
		invalid := false;
		obj := str.asOid;
		if obj &lt;&gt; null then
			edition := obj.edition;
			if not invalid then
				if obj.isKindOf( CM_CashReceipt ) then
					cashReceipt := obj.CM_CashReceipt;
					if cashReceipt &lt;&gt; null then
						_otherReceipts.addNoDuplicates( cashReceipt, false );
					endif;
				endif;
			endif;
		endif;
	endforeach;

epilog

	delete strArray;

end;</source>
        <Parameter name="_otherReceipts" type="CM_CashReceiptDict" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getDDParticularsForAjmanRep" id="61ee8275-c424-442e-b9aa-d1b90d503cf2">
        <source>getDDParticularsForAjmanRep( _descsArray : HugeStringArray input;
							_amountsArray : StringArray input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 January 2014	cnwndl1	Initial creation	Par 33181

*/

vars

	str : String;
	amountStr : String;
	invLine : CM_InvoiceLine;
	proDetails : CM_ProformaDetails;
	dd : CM_DutyDoc;
	lastDD : CM_DutyDoc;
	ti : CM_TrackedItem;
	heading : String;
	ddInvLineDesc : CM_InvoiceLineDesc;
	ddtRoot : CM_DutyDocTerminalRoot;
	detailArray : ObjectArray;
	detailStringArray : HugeStringArray;
	headingsStringArray : HugeStringArray;
	obj : Object;
	allDDs : CM_DutyDocByTicket;
	allDDExtraChargeInvLines : CM_InvoiceLineByDateTimeDict;

begin

	create detailArray transient;
	create headingsStringArray transient;
	create allDDs transient;
	
	// get the real invoice lines for the cargo.
	foreach invLine in self.allInvoiceLines do
		ti := invLine.trackedItem;
		str := null;
		if ti &lt;&gt; null then
			dd := ti.getDutyDoc;
			str := ti.id;
		else
			if ddInvLineDesc = null then
				ddInvLineDesc := invLine.bank.invoiceLineDescriptors["Duty Documentation Deposit"];
			endif;
			dd := null;
			if ddInvLineDesc &lt;&gt; null and ddInvLineDesc = invLine.invoiceLineDesc then
				ddtRoot := app.myDutyDocRoot.allDutyDocTerminalRoots.getAtKey(self.myTerminal);
				if ddtRoot &lt;&gt; null and invLine.invoiceLineDesc &lt;&gt; null then
					dd := ddtRoot.allDutyDocsById.getAtKey( invLine.invoiceLineDesc.narration);
				endif;
			endif;
		endif;
		if dd &lt;&gt; null then
			allDDs.addNoDuplicates( dd, false);
			heading := dd.getDDHeadingLineForAjmanRep();
			if not headingsStringArray.includes( heading ) then
				headingsStringArray.add( heading );
			endif;
		else
			heading := "    Unknown Duty Document";
			if not headingsStringArray.includes( heading ) then
				headingsStringArray.add( heading );
			endif;
		endif;
		if invLine.invoiceLineDesc &lt;&gt; null and invLine.invoiceLineDesc.narration &lt;&gt; null then
			str := str &amp; " " &amp; invLine.invoiceLineDesc.narration;
		endif;
		amountStr := invLine.lineTotal.asCurrencyJMT;
		create detailStringArray transient;
		detailStringArray.add( heading );
		detailStringArray.add( str );
		detailStringArray.add( amountStr );
		detailArray.add( detailStringArray );
		
	endforeach;
	
	//get the pro forma invoice lines for the cargo
	foreach proDetails in self.allProformaDetails do
	
		ti := proDetails.myTrackedItem;
		str := null;
		if ti &lt;&gt; null then
			dd := ti.getDutyDoc;
			str := proDetails.myTrackedItem.id &amp; " " &amp; proDetails.remarks;
		endif;
		if dd &lt;&gt; null then
			allDDs.addNoDuplicates( dd, false);
			heading := dd.getDDHeadingLineForAjmanRep();
			if not headingsStringArray.includes( heading ) then
				headingsStringArray.add( heading );
			endif;
		else
			heading := "    Unknown Duty Document";
			if not headingsStringArray.includes( heading ) then
				headingsStringArray.add( heading );
			endif;
		endif;
	
		amountStr := proDetails.lineTotal.asCurrencyJMT;
		create detailStringArray transient;
		detailStringArray.add( heading );
		detailStringArray.add( str );
		detailStringArray.add( amountStr );
		detailArray.add( detailStringArray );
		
	endforeach;
	
	//get the non cargo extra lines for the duty docs. 
	foreach dd in allDDs do
		create allDDExtraChargeInvLines transient;
		self.getDDExtraCharges( dd, allDDExtraChargeInvLines );
		heading := dd.getDDHeadingLineForAjmanRep();
		foreach invLine in allDDExtraChargeInvLines do
			str := dd.id &amp; " ";
			if self.allInvoiceLines.includes( invLine ) then
				continue; // don't see why this should ever be true, but just to be sure.
			endif;
			if invLine.invoiceLineDesc &lt;&gt; null and invLine.invoiceLineDesc.narration &lt;&gt; null then
				str := str &amp; invLine.invoiceLineDesc.narration;
			endif;
			amountStr := invLine.lineTotal.asCurrencyJMT;
			create detailStringArray transient;
			detailStringArray.add( heading );
			detailStringArray.add( str );
			detailStringArray.add( amountStr );
			detailArray.add( detailStringArray );
		
		endforeach;
		delete allDDExtraChargeInvLines;
	endforeach;
	
	//add the heading lines and each of teh related lines in order
	foreach str in headingsStringArray do
		_descsArray.add( str );
		_amountsArray.add(" ");
		foreach obj in detailArray do
			detailStringArray := obj.HugeStringArray;
			heading := detailStringArray[1];
			if heading = str then
				_descsArray.add( detailStringArray[2] );
				_amountsArray.add( detailStringArray[3] );
			endif;
		endforeach;
	endforeach;
	
epilog

	if detailArray.isEmpty then
		detailArray.purge();	//clobbers all the detailStringArray transients
	endif;
	delete detailArray;
	delete headingsStringArray;
	delete allDDs;
	delete allDDExtraChargeInvLines;

end;</source>
        <Parameter name="_descsArray" type="HugeStringArray" usage="input"/>
        <Parameter name="_amountsArray" type="StringArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getDDPrimaryCashReceipt" id="151e1b81-5b29-4765-aa8a-d5b21489e70e">
        <source>getDDPrimaryCashReceipt():CM_CashReceipt;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 February 2014	cnwndl1	Initial creation	Par 33181

*/

vars

	cashReceipt : CM_CashReceipt;
	otherReceipts : CM_CashReceiptDict;
	otherReceipt : CM_CashReceipt;

begin

	cashReceipt := self;
	
	if not self.isPrimaryDDCashReceiptForPrint then
		create otherReceipts transient;
		self.getDDOtherReceipts( otherReceipts );
		foreach otherReceipt in otherReceipts do
			if otherReceipt.isPrimaryDDCashReceiptForPrint then
				cashReceipt := otherReceipt;
				break;
			endif;
		endforeach;
	endif;
	
	return cashReceipt;

epilog

	delete otherReceipts;

end;</source>
        <ReturnType type="CM_CashReceipt"/>
    </JadeMethod>
    <JadeMethod name="getDebtor" id="301c11ec-ee38-44e3-95e6-d9f2304840c5">
