    <JadeMethod name="updateTIs" id="a53fab71-5f36-4f0a-b62f-eee44511b9ae">
        <source>updateTIs(_objArrayTI : ObjectArray input) protected;

// Created by cnwdvb1 on 13 April 2006

vars

	objArrayTI	: ObjectArray;
	obj			: Object;
	port		: CM_Port;
	str,
	str2		: String;
	ti			: CM_TrackedItem;
	count		: Integer;
	strArray	: StringArray;

begin

	create strArray transient;
	beginTransaction;
	foreach obj in _objArrayTI do
		ti := obj.CM_TrackedItem;
		count := count + 1;
		// Get the destination
		self.findPortCodeInCurrentList(ti, CM_TrackedItem::destinationPort.name);
		// Get the discharge port
		self.findPortCodeInCurrentList(ti, CM_TrackedItem::dischargePort.name);
		// Get the load port
		self.findPortCodeInCurrentList(ti, CM_TrackedItem::loadPort.name);
		// Get all discharge ports
		strArray.clear();
		foreach str in ti.allDischargePorts do
		
			if str = null or str.length &gt; 3 then
				continue;
			endif;
			
			port :=  self.mySortedPorts[str].CM_Port;
			if port = null then
				str2 := 'Could not find a port for ' &amp; ti.getOidString() &amp; ' discharge port ' &amp;  str;
				app.writeLog(str, LogINFO);
				app.writeStatement( str);
				continue;
			endif;
			strArray.add(port.code);
		endforeach;
		
		ti.allDischargePorts.clear();
		strArray.copy(ti.allDischargePorts);
	
		if count mod 100 = 0 then
			commitTransaction;
			beginTransaction;
		endif;
		
	endforeach;
	commitTransaction;
epilog
	delete strArray;
end;</source>
        <access>protected</access>
        <Parameter name="_objArrayTI" type="ObjectArray" usage="input"/>
    </JadeMethod>
</Class>
