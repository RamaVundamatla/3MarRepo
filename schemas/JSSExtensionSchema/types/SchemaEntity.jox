    <JadeMethod name="jssGetModifyTimeStamp" id="c1cc5d75-427b-4fdd-b701-33baf7753324">
        <source>jssGetModifyTimeStamp():TimeStamp;

begin
	if self.modifiedTimeStamp = null then
		return creationTime();
	endif;

	return self.modifiedTimeStamp;
end;</source>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="jssIsProtected" id="42419e37-1123-4e19-8b6f-3518eb61b582">
        <source>jssIsProtected():Boolean;
// --------------------------------------------------------------------------------
// Created:		16 August 2001 by cnwdad1
//
// Purpose:		Returns a boolean flag to indicate whether access to the receiver
//				is protected.
//
// Parameters:	None
//
// Returns:		True if the entity is protected, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return (self.access = self.JSS_ACCESS_PROTECTED);
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="jssIsPublic" id="6f868335-88de-4914-a3a9-4f680eecc928">
        <source>jssIsPublic():Boolean;
// --------------------------------------------------------------------------------
// Created:		16 August 2001 by cnwdad1
//
// Purpose:		Returns a boolean flag to indicate whether access to the receiver
//				is public.
//
// Parameters:	None
//
// Returns:		True if the entity is public, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return (self.access = self.JSS_ACCESS_PUBLIC);
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="jssIsReadonly" id="e5b55df3-e40b-4f83-9fbd-0fe4737a5da2">
        <source>jssIsReadonly():Boolean;
// --------------------------------------------------------------------------------
// Created:		16 August 2001 by cnwdad1
//
// Purpose:		Returns a boolean flag to indicate whether access to the receiver
//				is read-only.
//
// Parameters:	None
//
// Returns:		True if the entity is read-only, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return (self.access = self.JSS_ACCESS_READONLY);
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
