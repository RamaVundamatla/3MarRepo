	self.fldCargo.topSheet  	:= self.shtNullVoyage;
	self.buildCmbNullVoyage();
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="loadTabCargoPack" id="65eff940-6829-4224-bb44-fef677fe3e9b">
        <updating/>
        <source>loadTabCargoPack() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 Mar 2022	navma1	ChangeRequest 52351: MTN - Work Order Maintenance Refactor - UI
02 Aug 2022	navcs2	Bug 54396 - MTN - Work Order Maintenance - Discharge Port of Pack Job Should Follow Selected Voyage
29 Aug 2022 navma1	Bug 54682: MTN - Work Orders - Consignee/Consignor dropdown shows the list that are marked as Is Fright Forwarder
24 Jan 2023	navma1  ChangeRequest 56141: EUP - Refactor and Remove CM_WorkOrderTISource from CM_WorkOrderTI
06 Mar 2023 navma1  ChangeRequest 56457:[56458] EUP - [Refactor] - Allowing different sets of cargo items per work order task
18 Apr 2023 navma1  ChangeRequest 55442:[54989] EUP - Pack Cargo Work Order - Enhancement
18 Apr 2023 navhl20 ChangeRequest 55442:[57629] EUP - Pack Cargo Work Order - Enhancement
20 Apr 2023 navma1  ChangeRequest 57324:[57325] EUP - VAS Task linked with Release Cargo Work Order
03 Oct 2023 navhl20 Bug 60373: MTN - Expected to see a validation message to save the changes before closing the work order form.
01 Nov 2023 navhl20 Bug 61057: EUP - Invalid Property exception when selecting a Pack Task to the already existing Work Order
05 Jul 2024 navhl20	ChangeRequest 61368: EUP* | Adding Pack Reserve Child to Packing Work order Release Request
12 Aug 2024 navhl20	Bug 65586: Pack Work order - Issues
04 Nov 2024 navbs1  Bug MTN-19888: MTN - Work Order Pack to mirror Receive Cargo Work Order
03 Apr 2025	navah1  Bug 34509: MTN | Adding a pack after any other work order task type results in an unhandled exception
*/
vars
	imexStatus : CM_IMEXStatus;
	commodity  : CM_Commodity;
	wodtl	   : CM_WodPack;
	woDetail  : CM_WorkOrderDtl;		  //03.04.2025 navah1 #34509
	//pack 	   : CM_WodPack;
	allWoDetails  : CM_WorkOrderDtlArray; //03.04.2025 navah1 #34509
	assistant  : CMUI_Assistant;
	root       : CM_Root;
	grpTop	   : Real; 
begin
	create allWoDetails transient;		  //04.04.2025 navah1 #34509
	
	if self.myPxyTask = null then
		return;
	endif;
	
	wodtl 						:= self.myPxyTask.CM_WodPack;
	assistant 					:= self.myAssistant;
	root						:= app.myRoot;
	
	self.tblItems.visible		   := false;									//01.11.2023 navhl20 #61057
	grpTop 						   := 24;
	self.grpPackReq.visible 	   := true;										//18.4.2023 navhl20 #55442[57629]
	self.grpPackReq.top 	   	   := grpTop;									//18.4.2023 navhl20 #55442[57629]
	self.lblReleaseRequest.parent  := self.grpPackReq;							//18.4.2023 navhl20 #55442[57629]
	self.cmbReleaseRequest.parent  := self.grpPackReq;							//18.4.2023 navhl20 #55442[57629]
	self.btnMaintainRelease.parent := self.grpPackReq;							//18.4.2023 navhl20 #55442[57629]
	self.lblReleaseRequest.visible := true;
	self.cmbReleaseRequest.visible := true;										//18.4.2023 navhl20 #55442[57629]
	self.btnMaintainRelease.visible:= true;										//18.4.2023 navhl20 #55442[57629]
	self.lblReleaseRequest.top 	   := 25;										//18.4.2023 navhl20 #55442[57629]
	self.cmbReleaseRequest.top 	   := 25;										//18.4.2023 navhl20 #55442[57629]
	self.btnMaintainRelease.top    := 25;										//18.4.2023 navhl20 #55442[57629]
	
	if self.hasVasSubscription then												//05.07.2024 navhl20 #61368
		self.grpPackReq.height 			:= 80;
		self.lblReserveDetail.parent 	:= self.grpPackReq;
		self.cmbReserveDetail.parent 	:= self.grpPackReq;
		self.lblReserveDetail.top 		:= 25 + self.cmbReleaseRequest.height + 5;
		self.cmbReserveDetail.top 		:= 25 + self.cmbReleaseRequest.height + 5;
		self.lblReserveDetail.caption	:= "Child Reserve Detail";
	endif;
	
	self.grpPackAttr.top 		   := grpTop + self.grpPackReq.height + 10;		//18.4.2023 navhl20 #55442[57629]
	self.buildCmbRelease();														//18.4.2023 navhl20 #55442[57629]
	//self.cmbReleaseRequest_click(self.cmbReleaseRequest);						//18.4.2023 navhl20 #55442[57629]	//12.08.2024 navhl20 #65586
	self.grpPackReq.enabled 	   := not self.isApproved;
	
	self.shtPack.visible		:= true;
	self.shtToDoTasks.visible	:= true;
	self.fldCargo.topSheet  	:= self.shtPack;
	self.setParentAspect(false);												//03.10.2023 navhl20 #60373
	self.grpPackItems.visible 	:= true;
	self.tblChildItems.visible  := true;
	
	//build combo boxes
	self.cmbPackDishPort.myTerminal  := self.myTerminal;
	self.cmbPackDishPort.myAssistant := assistant;
	self.cmbPackCommodity.listCollection(root.allCommodities, true, 0);
	assistant.comboBoxIMEXStatus(self.cmbPackImExStats, null);
	assistant.comboBoxBookingRef(self.cmbPackBookRef, null);
	assistant.comboBoxContentsStatus(self.cmbPackConStatus, null);
	assistant.comboBoxSubTerminal(self.cmbPackSubTerm, null, self.myTerminal);
	assistant.comboBoxConsignor(self.cmbPackConsignee,wodtl.myConsignee,CONSIGNEE);     //29.08.2022 navma1 #54682
	assistant.comboBoxConsignor(self.cmbPackConsignor,wodtl.myConsignor,CONSIGNOR);     //29.08.2022 navma1 #54682
	self.cmbReleaseRequest_click(self.cmbReleaseRequest);								//12.08.2024 navhl20 #65586
	
	if wodtl.myReleaseRequest = null then										//09.07.2024 navhl20 #61368 
		//wodtl := self.myPxyWorkOrder.allWoDtls.first.CM_WodPack; 				//03.04.2025 navah1 #34509
		allWoDetails.tryCopyFrom(self.myPxyWorkOrder.allWoDtls);  				//03.04.2025 navah1 #34509
		foreach woDetail in allWoDetails do									//03.04.2025 navah1 #34509
			if woDetail.isWorkOrderForPack then 		
				wodtl := woDetail.CM_WodPack;
				self.cmbReleaseRequest.setIndexFromObject(wodtl.myReleaseRequest);
				self.cmbReleaseRequest_click(self.cmbReleaseRequest);
				break;
			endif;
		endforeach;
		
	endif;

	self.cmbPackVoyage.setObject(wodtl.myVoyage);
	
	// 15 August 2022	navcs2	Bug 54396
	if wodtl.myVoyage &lt;&gt; null then 
		self.cmbPackDishPort.setObjectFromCodeAndVoyage (self.cmbPackDishPort.getCode(), wodtl.myVoyage);
		self.cmbPackOperator.resetCollectionForVoyage(wodtl.myVoyage);
		self.cmbPackOperator.setObject(wodtl.myOperator);
		if wodtl.myDischargePort &lt;&gt; null then
			self.cmbPackDishPort.setObject(wodtl.myDischargePort);
		endif;
	endif;

	self.cmbPackBookRef.setObject(wodtl.myBookingRef);
	
	imexStatus := root.allImexStatuses[wodtl.imexStatus].CM_IMEXStatus;
	self.cmbPackImExStats.listObject := imexStatus;
	
	commodity := root.allCommodities[wodtl.commodity].CM_Commodity;
	self.cmbPackCommodity.listObject := commodity;
	
	if wodtl.mySubTerminal &lt;&gt; null then
		self.cmbPackSubTerm.listObject := wodtl.mySubTerminal;
	endif;
	
	if wodtl.myContentsStatus &lt;&gt; null then
		self.cmbPackConStatus.listObject := wodtl.myContentsStatus;
	endif;
	
	self.grpPackAttr.enabled	:= not self.isApproved;					//06.03.2023 navma1 #56457:[56458]
	//buildTblChildItems();												//04.11.2024 navbs1 #19888
	self.tblChildItems.clearAllData();									//04.11.2024 navbs1 #19888
	buildListToDoTasks(null);											//17.04.2023 navma1 #57324:[57325]
epilog
	delete allWoDetails;	//04.04.2025 navah1 #34509
end;</source>
    </JadeMethod>
    <JadeMethod name="loadTabCargoReceive" id="711d5d29-8a21-434a-abd9-5902b8c31bfa">
        <updating/>
        <source>loadTabCargoReceive() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		 Reason
06 Apr 2022	navukv20 ChangeRequest 52351: MTN - Work Order Maintenance Refactor - UI
26 Dec 2022	navdp20  Task 56012:(54979) - Add Transport Mode to Receive and Release work orders
31 Jan 2023	navhl20	 ChangeRequest 55443:[54991] EUP - Receive Cargo Work Order - Enhancements
02 Feb 2023	navhl20	 ChangeRequest 56631:[56185] EUP - Transport Mode change - UI Changes
20 Apr 2023	navma1   ChangeRequest 57324:[57325] EUP - VAS Task linked with Release Cargo Work Order
06 Jul 2023	navhl20  Bug 58952: MTN - Unable to add the tracked item when using the Export Booking for Release Cargo Work Order
01 Nov 2023 navhl20  Bug 61057: EUP - Invalid Property exception when selecting a Pack Task to the already existing Work Order
04 Jan 2024 navlc30 ChangeRequest 59997: EUP | Work Order Transport Mode change - Rail Receive
*/

vars
	cargoType : CM_CargoType;
begin
	if self.myPxyTask = null then
		return;
	endif;
	
	self.shtReceive.visible		:= true;
	self.shtToDoTasks.visible	:= true;
	self.grpReleaseItems.visible:= false;
	self.btnCreateCargo.visible := false;
	self.tblItems.visible		:= true;															//01.11.2023 navhl20 #61057
	
	self.fldCargo.topSheet  			:= self.shtReceive;
	self.cmbTransMode.parent			:= self.grpReceiveDetails;
	self.cmbTransport.parent			:= self.grpReceiveDetails;
	self.lblTransMode.parent			:= self.grpReceiveDetails;
	self.lblTransport.parent			:= self.grpReceiveDetails;
	self.tblItems.parent 		   		:= self.grpBookingItems;   
	self.lblBooking.parent				:= self.grpReceiveDetails;									//06.7.2023 navhl20 #58952
	self.lblBooking.top					:= self.lblTransport.top + self.lblTransport.height + 10;
	self.cmbBooking.parent				:= self.grpReceiveDetails;									//06.7.2023 navhl20 #58952
	self.cmbBooking.top					:= self.lblTransport.top + self.lblTransport.height + 10;
	self.lblBookingItem.parent			:= self.grpReceiveDetails;									//06.7.2023 navhl20 #58952
	self.lblBookingItem.top				:= self.lblBooking.top + self.lblBooking.height + 10;
	self.cmbBookingItem.parent			:= self.grpReceiveDetails;									//06.7.2023 navhl20 #58952
	self.cmbBookingItem.top				:= self.lblBooking.top + self.lblBooking.height + 10;
	self.btnMaintainBooking.parent		:= self.grpReceiveDetails;									//06.7.2023 navhl20 #58952
	self.btnMaintainBooking.top			:= self.lblTransport.top + self.lblTransport.height + 10;
	
	self.grpReceiveDetails.enabled 	    := not self.isApproved;										//8.3.2023 navhl20 #55443[54991]
	
	if self.workOrderMode = self.MODE_UPDATE then													//10.01.2024 navlc30 #59997	
		self.btnChangeTransport.visible := self.hasVasSubscription;									//11.07.2023 navma1 #58952

		if self.myPxyTask.CM_WodReceive.status = WO_STATUS_COMPLETE then							//05.5.2023 navhl20 #56631[56185]
			self.btnChangeTransport.enabled := false;
		else
			self.btnChangeTransport.enabled := self.hasVasSubscription;								//10.07.2023 navma1 #54550
		endif;
	endif;
	
	if self.hasVasSubscription and self.workOrderMode = self.MODE_ADD then
		self.cmbTransMode.enabled := true;
	endif;
	
	self.buildCmbTransportMode();
	
	self.txtCustomNumber.text := self.myPxyTask.CM_WodReceive.customExportEntryNumber;
	
	if self.cmbBookingItem.listObject &lt;&gt; null then										//17.04.2023 navma1 #57324:[57325]
		cargoType := self.cmbBookingItem.listObject.CM_BookingRefItem.myCargoType;
	endif;
	self.buildListToDoTasks(cargoType);													//17.04.2023 navma1 #57324:[57325]
	self.maintainBtnAttachCargo();
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="loadTabCargoRelExtension" id="83a74f99-af03-47c9-9015-97ba09160533">
        <updating/>
        <source>loadTabCargoRelExtension() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		 Reason
06 Apr 2022	navukv20 ChangeRequest 52351: MTN - Work Order Maintenance Refactor - UI
