    <JadeMethod name="loadDB" id="cc40a55c-5ad1-4c2b-8906-6cf15982637f">
        <updating/>
        <source>loadDB(_mergeCargo: Boolean; _passport: CM_Passport input) updating;
/*

Date		Who		Reason
02 June 2015	cnwer1	Initial creation PAR
01 Dec 2025 navlc30 JIRA 36749 - LINX - Audits not getting created for the Debtor with Addressed created through EDI

*/

vars
	ediTrackedItem : CM_EDITrackedItem;
	ediAddress : CM_EDIAddressTI;
	proxyAddress,
	realAddress : CM_Address;
	debtorCode : String;
	debtor : CM_Debtor;
	root   : CM_Root;
begin
	app.myTrxUA.trxProcessEDIDebtor(self,  _passport);	

	//Process EDI Debtor Address After processing the EDI debtor											//01.12.2025 navlc30 #36749
	root := app.myRoot;																						//01.12.2025 navlc30 #36749
	foreach ediTrackedItem in self.allEDITrackedItems where ediTrackedItem.isKindOf(CM_EDIAddressTI) do		//01.12.2025 navlc30 #36749
		ediAddress := ediTrackedItem.CM_EDIAddressTI;
		
		debtorCode := ediAddress.debtorCode;
		
		if debtorCode = null then
			continue;
		endif;
		
		debtor := root.myRootCompany.allDebtorsByCode[debtorCode];
		
		if debtor = null then
			continue;
		endif;
		
		realAddress  := debtor.allAddressesByCode[ediAddress.id];
		proxyAddress := self.createAddressProxy(ediAddress, realAddress, debtor);
		
		if realAddress &lt;&gt; null then
			app.myTrxUA.trxUpdateDebtorAddress(proxyAddress,realAddress, _passport);			
		else
			app.myTrxCA.trxCreateDebtorAddress(proxyAddress,realAddress, _passport);
		endif;
		
		delete proxyAddress;
	endforeach;	
epilog

end;</source>
        <Parameter name="_mergeCargo" type="Boolean"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
