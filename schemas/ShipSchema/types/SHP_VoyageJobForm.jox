    <JadeMethod name="cmbCrane_click" id="fdbe0548-a544-4649-b7fb-b25cb04aa847">
        <controlMethod name="CMUI_ComboBox::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbCrane_click(combobox: ComboBox input) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
28 July 2011	cnwer1	Initial creation CCMS MES 1033

*/

vars
	obj : Object;
begin
	
	obj := combobox.listObject;
	
	if obj.isKindOf(CM_Crane) then
		self.tblJobEdit.showRowByName(ETRow_BayId,false);
		self.tblJobEdit.hideRowByName(ETRow_DeckId,false);
		if self.mode = self.Mode_Add then
			self.tblJobEdit.showRowByName(ETRow_TheHatchLids,false);
				
		endif;
	elseif obj.isKindOf(CM_WorkPoint) then
		self.tblJobEdit.showRowByName(ETRow_DeckId ,false);
		self.tblJobEdit.hideRowByName(ETRow_BayId,false);
		self.tblJobEdit.hideRowByName(ETRow_TheHatchLids,false);
	endif;
epilog

end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
    </JadeMethod>
