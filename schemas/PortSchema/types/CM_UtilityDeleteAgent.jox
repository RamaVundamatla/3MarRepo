        <source>utlDeleteCargoType(pCargoType : CM_CargoType io; _passport : CM_Passport input);
// ---------------------------------------------------------------------------
// Created:     16 July 2001 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	yaType : CM_YATypeCargoType;
	kpiCargoEntity : CM_KPICargoEntity;
begin

	self.initialiseActivity();

	app.setContinueCMExceptions(true);

	app.myValDA.valCargoType(pCargoType);
	
	if (not self.checkValidationWithPassport(_passport)) then // Show any Errors and Warnings in a list
		return;
	endif;


	app.setContinueCMExceptions(false);

	if _passport.noErrors then
		self.myDeleteAuditAgent.audDeleteGeneric(pCargoType);
	endif;
	if _passport.noErrors then
		yaType := CM_YATypeCargoType.firstInstance;
		if yaType &lt;&gt; null then
			yaType.removeMyDataObject(pCargoType);
		endif;
		if app.isJMTUnitTest then	//Unit test - 20 May 2019	NDL
			pCargoType.allKPICargo.purge;
			/*foreach kpiCargoEntity in CM_KPICargoEntity.instances do
				if kpiCargoEntity.myCargoType = pCargoType then
					kpiCargoEntity.erase(NORMAL_ERASE);
				endif;
			endforeach;*/
		endif;
		//navsp1 31MAY2022 TFS#53104 - GC --&gt;&gt;
