    <JadeMethod name="tableDragDropEvent" id="42d2f89b-b141-4b60-ae32-a0badce5facb">
        <updating/>
        <source>tableDragDropEvent(table: Table input; win: Window input; x: Real; y: Real) updating, protected;
//--------------------------------------------------
// Created:	17 October 2003 By: cnwgd1
//--------------------------------------------------
vars

begin
	if win.isKindOf(CM_DataTable) then
		self.receiveDrop(win.CM_DataTable, table.CM_DataTable);
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="win" type="Window" usage="input"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="tableMouseMoveEvent" id="8d2adc1a-0fa3-435b-bb10-965cea7cc970">
        <updating/>
        <source>tableMouseMoveEvent(table: Table input; button: Integer; shift: Integer; x: Real; y: Real) updating, protected;
//--------------------------------------------------
// Created:	17 October 2003 By: cnwgd1
//--------------------------------------------------
// Changed On	By			Reason
// ----------	--------	------------------------------------------------------
// 12/05/2010	cnwdap1		CCMS 1116 Tranship changes
//
vars
	theTI : CM_TrackedItem;
	tmpHeight : Real;	
begin
	
	if button &lt;&gt; 1 then
	   return;
	endif;
	
	if table.fixedRows &gt; 0 then
		tmpHeight := table.accessRow(table.fixedRows).height;
		if self.origYPos &lt;= tmpHeight then
			return;
		endif;
	endif;

	if table.row &lt;= table.fixedRows then	
		return;
	endif;

	// check drag/drop detected	
	if (not app.dragDetected(x, y, self.origXPos, self.origYPos)) then
		return;
	endif;
	
	theTI := table.accessRow(table.row).itemObject.CM_TrackedItem;
	
	if theTI = null then
		return;
	endif;
	
	if (not global.isValidObject(theTI)) then
		self.myCurrentTrackedItem := null;
		return;
	endif;	
	//if theTI.isTranshipItem then // from par13541		// PAR #23645 CCMS 1116
	//	if theTI.isOnSite then							// PAR #23645 CCMS 1116
	//		if theTI.myTranshipExport &lt;&gt; null then		// PAR #23645 CCMS 1116
	//			theTI := theTI.myTranshipExport;		// PAR #23645 CCMS 1116
	//		endif;										// PAR #23645 CCMS 1116
	//	else											// PAR #23645 CCMS 1116
	//		if theTI.myTranshipImport &lt;&gt; null then		// PAR #23645 CCMS 1116
	//			theTI := theTI.myTranshipImport;		// PAR #23645 CCMS 1116
	//		endif;										// PAR #23645 CCMS 1116
	//	endif;											// PAR #23645 CCMS 1116
	//endif;											// PAR #23645 CCMS 1116
	
	self.dragTrackedItem(theTI, table.CM_DataTable);	
end;</source>
        <access>protected</access>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="tableRowChange" id="2216a290-70f6-4706-89a3-04f324bdc355">
        <updating/>
        <source>tableRowChange(_table : CM_DataTable input; _newRow : Integer) updating, protected;

vars
	obj : CM_Object;
begin
	self.myCurrentTable := _table;

	if _newRow &lt; _table.fixedRows then
		return;
	endif;
	obj := _table.accessRow(_newRow).itemObject.CM_Object;

	if not global.isValidObject(obj) then
		return;
	endif;
	if _table = self.tblBOLItems then
		self.btnBOLItemEdit.enabled := true;
		self.btnBOLItemDelete.enabled := true;
	elseif _table = self.tblCargo then
		self.btnCOBEdit.enabled := true;
		self.btnCOBDelete.enabled := true;
	elseif _table = self.tblStowageItems then
		self.btnStowItmEdit.enabled := true;
		self.btnStowItmDelete.enabled := true;
	endif;
	// TFS 2198 CNWAB1
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		self.btnCOBAdd.enabled:= false;
		self.btnCOBDelete.enabled:= false;
		self.btnBOLAdd.enabled:= false;
		self.btnBOLDelete.enabled:= false;
		self.btnBOLItemAdd.enabled:= false;
		self.btnBOLItemDelete.enabled:= false;
		self.btnStowItmEdit.enabled:= false;
		self.btnStowItmDelete.enabled:= false;
		self.btnTransfer.enabled:= false;
		self.mnuTableEdit.enabled:= false;
		self.mnuTableEditStops.enabled:= false;
		self.mnuTransfer.enabled:= false;
		self.mnuTableAdd.enabled:= false;
		self.mnuTableDelete.enabled:= false;
		self.mnuTableUnlink.enabled:= false;
		self.mnuCargo.enabled:= false;
	endif;

end;</source>
        <access>protected</access>
        <Parameter name="_table" type="CM_DataTable" usage="input"/>
        <Parameter name="_newRow" type="Integer"/>
    </JadeMethod>
