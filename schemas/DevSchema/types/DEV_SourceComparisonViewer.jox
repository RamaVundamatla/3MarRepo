    <JadeMethod name="mnuDetails_click" id="141ac52a-ea32-4e8b-94b4-ba4684ff9ff7">
        <controlMethod name="MenuItem::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>mnuDetails_click(menuItem: MenuItem input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 September 2023	navpw1	Initial creation

*/

vars
	listBox		: ListBox;
	selIndex	: Integer;
	anObject	: Object;
	
begin
	if self.mnuLBContext.userObject = null then
		write method.qualifiedName &amp; " No userObject set on mnuLBContext";
		return;
	endif;
	
	listBox := self.mnuLBContext.userObject.ListBox;
	selIndex := listBox.listIndex;
	anObject := listBox.itemObject[selIndex];
	
	if listBox &lt;&gt; null then
		self.showDetails(listBox);
	endif;
	
end;</source>
