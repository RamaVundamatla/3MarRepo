    <JadeMethod name="createYAWithOneCriteria" id="0f09e708-1fe8-46cc-968a-adb38be3a77c">
        <source>createYAWithOneCriteria(_name: String; _terminal: CM_Terminal; _criteria: Integer; _value: Any; _locations: CM_LCArray; proxyYACriteria: CMIF_Array output) : CM_YardAllocation;
//17 July 2008	cnwdw1	
//
begin
	proxyYACriteria := self.createYACriterias( _criteria, _value, 0, 0, 0, 0);
	return self.createYA(_name, _terminal, _locations, YAFillOption_InOrder, YAFillOption_InOrder,false);
end;</source>
