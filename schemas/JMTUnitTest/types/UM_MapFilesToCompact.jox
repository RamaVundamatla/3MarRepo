<Class name="UM_MapFilesToCompact" id="aafdcc2b-8060-4eb9-9004-114b5bd3762c">
    <superclass name="UM_Object"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>Contains the map files that need to be compacted or have been compacted in the past.
They can be compacted weekly (This currently happens) or when the compact method is next run.

The attribute whenToCompact defines when the file(s) compaction happens.
- Weekly : Those files that are currently compacted as part of the SCHEDULE_Weekly run
- Next : Those files that will be compacted the next time the compact method is run.  This could be as part of the Weekly run
- Blank (Null) : currently not in any active run</text>
    <DbClassMap file="unitTest"/>
    <Constant name="WhenToCompactNext" id="893654d1-9d90-4314-9e22-8a8dce551105">
        <source>2</source>
        <type name="Integer"/>
    </Constant>
    <Constant name="WhenToCompactNextStr" id="c040aa25-aae0-47b9-b2a7-52a8f310ecbe">
        <source>"Next"</source>
        <type name="String"/>
    </Constant>
    <Constant name="WhenToCompactNull" id="f4b80d52-96f0-4c53-b09a-47848f54cbf5">
        <source>0</source>
        <type name="Integer"/>
    </Constant>
    <Constant name="WhenToCompactNullStr" id="931071de-6f18-47eb-b208-2575c8155996">
        <source>""</source>
        <type name="String"/>
    </Constant>
    <Constant name="WhenToCompactWeekly" id="c78e1355-a6ca-42ae-a201-c5b45d6a7a49">
        <source>1</source>
        <type name="Integer"/>
    </Constant>
    <Constant name="WhenToCompactWeeklyStr" id="b44a6d81-ea5a-4d37-8a72-22670eda1b7b">
        <source>"Weekly"</source>
        <type name="String"/>
    </Constant>
