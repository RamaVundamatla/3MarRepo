<Class name="CM_Consumed" id="2c178fea-7513-430f-ae5e-24c0e33c1a48">
    <superclass name="CM_TITransaction"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>To record quantity, weight etc consumed in an external system and updated via the EDI cargo field update 
'cargoWeightChange' and 'cargoQuantityChange' methods.</text>
    <DbClassMap file="transact"/>
    <PrimAttribute name="quantity" id="0c5ab341-77d3-49cc-8da6-c40a16c2bef9">
        <embedded/>
        <type name="Integer"/>
        <access>readonly</access>
    </PrimAttribute>
    <PrimAttribute name="volume" id="b8d9e470-72b4-4407-9e79-6f61b936b2fe">
        <precision>16</precision>
        <scaleFactor>4</scaleFactor>
        <embedded/>
        <type name="Decimal"/>
        <access>readonly</access>
    </PrimAttribute>
    <PrimAttribute name="weight" id="807d53e3-05d9-48b5-a1d6-2fb276270276">
        <precision>14</precision>
        <scaleFactor>4</scaleFactor>
        <embedded/>
        <type name="Decimal"/>
        <access>readonly</access>
    </PrimAttribute>
    <JadeMethod name="getDisplayStringForAttribute" id="a28a7a28-afa9-48aa-954f-7d51b3d2e02c">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
10 November 2015	cnwjre1	Initial creation

*/

vars
	lDetail		: String;
begin
	if _attrName = ETRow_Details  then
		if self.deleted then
			return self.getDeletedDetails();		// 15/10/18 MAP TFS41191
		else
			if self.quantity &lt;&gt; 0 then
				lDetail := "Quantity " &amp; self.quantity.asStringJMT;
			elseif self.volume &lt;&gt; 0 then
				lDetail := "Volume " &amp; self.volume.asStringJMT;
			elseif self.weight &lt;&gt; 0 then
				lDetail := "Weight " &amp; self.weight.asStringJMT;
			endif;
			if self.urNumber &lt;&gt; null then
				lDetail := lDetail &amp; " " &amp; self.urNumber.String;
			endif;
			return lDetail;
		endif;

	else
		return inheritMethod(_attrName, _short);
	endif;
epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="setFromCMIF_TITransactionCntrl" id="ae46f6c1-408b-4c5b-beb5-5aa07ba533b9">
        <updating/>
        <source>setFromCMIF_TITransactionCntrl(_tiTransCntrl: CMIF_SplitTransController; _passport: CM_Passport input) updating;
// TFS 456 36912 create a transaction from EDI weight and quantity change
vars

begin

	inheritMethod(_tiTransCntrl, _passport);
	
	self.quantity	:= _tiTransCntrl.quantity;
	self.volume		:= _tiTransCntrl.volume;
	self.weight		:= _tiTransCntrl.weight;
end;
</source>
        <Parameter name="_tiTransCntrl" type="CMIF_SplitTransController"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
</Class>
