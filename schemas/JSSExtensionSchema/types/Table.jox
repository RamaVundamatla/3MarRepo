<GUIClass name="Table">
    <JadeMethod name="jssFindAndUpdateRow" id="867fe201-b35d-43e6-9ea2-fff43e12fe0d">
        <updating/>
        <source>jssFindAndUpdateRow(pTheObject:Object; pCellValue:String) updating;
// --------------------------------------------------------------------------------
// Created:		25 July 2000	By: cnwdad1
//
// Purpose:		Searches for pTheObject and updates the row using the pCellValue parameter.
//
// Parameters:	pTheObject (Object) - The object to find.
//				pCellValue (String) - The value to update the cell with.
//
// Returns:		Nothing.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	rowIndex	: Integer;
	currentRow	: Integer;
	isSelected	: Boolean;

begin
	currentRow	:=	self.row;
	isSelected	:=	self.jssIsRowSelected(currentRow);

	if self.jssFindObject(pTheObject, 2, 1) then
		rowIndex	:=	row;
		deleteRow(rowIndex);
		addItemAt(pCellValue, rowIndex);
		self.jssSetItemObject(rowIndex, 1, pTheObject);
	endif;

	row := currentRow;

	if isSelected then
		self.row	:=	currentRow;
		self.jssSelectRow();
	endif;
end;</source>
        <Parameter name="pTheObject" type="Object"/>
        <Parameter name="pCellValue" type="String"/>
    </JadeMethod>
    <JadeMethod name="jssFindObject" id="d120c90a-ce17-407d-ab59-c1c482d228c0">
        <updating/>
        <source>jssFindObject(pTheObject:Object; pStartRow:Integer; pStartColumn:Integer):Boolean updating;
// --------------------------------------------------------------------------------
// Created:		25 July 2000	By: cnwdad1
//
// Purpose:		Searches the itemObject property values of the table entries for the object
//				specified in the pTheObject parameter, starting with pStartRow and pStartCol.
//				If the specified object is found True is returned.
//
// Parameters:	pTheObject (Object) - The object to find.
//				pStartRow (Integer) - The cell row number from which to start searching.
//				pStartColumn (Integer) - The cell column number from which to start searching.
//
// Returns:		True if the object was found, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	rowIndex	: Integer;
	columnIndex	: Integer;
	rowCount	: Integer;
	columnCount	: Integer;

begin
	rowIndex	:=	pStartRow;
	columnIndex	:=	pStartColumn;
	columnCount	:=	self.columns;
	rowCount	:=	self.rows;

	foreach columnIndex in 1 to columnCount do
		self.column	:=	columnIndex;

		foreach rowIndex in 1 to rowCount do
			self.row	:=	rowIndex;

			if self.itemObject = pTheObject then
				return true;
			endif;			
		endforeach;
	endforeach;

	return false;		
end;</source>
        <Parameter name="pTheObject" type="Object"/>
        <Parameter name="pStartRow" type="Integer"/>
        <Parameter name="pStartColumn" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="jssFindObjectCell" id="ea5cd191-a787-4132-8c03-cb39700e50d9">
        <updating/>
        <source>jssFindObjectCell(pValue:Object):JadeTableCell updating;
// --------------------------------------------------------------------------------
// Created:		04 August 2001 by cnwdad1
//
// Purpose:		This method scans the receiver's cells and returns the first
//				JadeTableCell who's itemObject matches the pValue parameter.
//
// Parameters:	pValue - The object to search for.
//
// Returns:		The JadeTableCell for the (first) cell with a matching object, or
//				null if the object isn't found.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	rowIndex		: Integer;
	columnIndex		: Integer;
	startRow		: Integer;
	startColumn		: Integer;
	rowCount		: Integer;
	columnCount		: Integer;
	theTableCell	: JadeTableCell;
	
begin
	startRow	:=	self.fixedRows + 1;
	startColumn	:=	self.fixedColumns + 1;
	rowCount	:=	self.rows;
	columnCount	:=	self.columns;
	
	foreach rowIndex in startRow to rowCount do
		foreach columnIndex in startColumn to columnCount do
			theTableCell	:=	self.accessCell(rowIndex, columnIndex);
			
			if theTableCell.itemObject = pValue then
				return theTableCell;
			endif;
		endforeach;
	endforeach;
end;</source>
        <Parameter name="pValue" type="Object"/>
        <ReturnType type="JadeTableCell"/>
    </JadeMethod>
    <JadeMethod name="jssFindObjectColumn" id="8601b538-25b2-4cd6-aeaf-37538e84af8e">
        <updating/>
        <source>jssFindObjectColumn(pValue:Object):JadeTableColumn updating;
// --------------------------------------------------------------------------------
// Created:		04 August 2001 by cnwdad1
//
// Purpose:		This method scans the receiver's columns and returns the first
//				JadeTableColumn who's itemObject matches the pValue parameter.
//
// Parameters:	pValue - The object to search for.
//
// Returns:		The JadeTableColumn for the (first) column with a matching object,
//				or null if the object isn't found.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	columnIndex		: Integer;
	startColumn		: Integer;
	columnCount		: Integer;
	theTableColumn	: JadeTableColumn;
	
begin
	startColumn	:=	self.fixedColumns + 1;
	columnCount	:=	self.columns;
	
	foreach columnIndex in startColumn to columnCount do
		theTableColumn	:=	self.accessColumn(columnIndex);
			
		if theTableColumn.itemObject = pValue then
			return theTableColumn;
		endif;
	endforeach;
end;</source>
        <Parameter name="pValue" type="Object"/>
        <ReturnType type="JadeTableColumn"/>
    </JadeMethod>
    <JadeMethod name="jssFindObjectRow" id="7d6dc2e5-1537-468d-a64f-762dbdee34ee">
        <updating/>
        <source>jssFindObjectRow(pValue:Object):JadeTableRow updating;
// --------------------------------------------------------------------------------
// Created:		04 August 2001 by cnwdad1
//
// Purpose:		This method scans the receiver's rows and returns the first
//				JadeTableRow who's itemObject matches the pValue parameter.
//
// Parameters:	pValue - The object to search for.
//
// Returns:		The JadeTableRow for the (first) row with a matching object, or
//				null if the object isn't found.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	rowIndex		: Integer;
	startRow		: Integer;
	rowCount		: Integer;
	theTableRow		: JadeTableRow;
	
begin
	startRow	:=	self.fixedRows + 1;
	rowCount	:=	self.rows;
	
	foreach rowIndex in startRow to rowCount do
		theTableRow	:=	self.accessRow(rowIndex);
			
		if theTableRow.itemObject = pValue then
			return theTableRow;
		endif;
	endforeach;
end;</source>
        <Parameter name="pValue" type="Object"/>
        <ReturnType type="JadeTableRow"/>
    </JadeMethod>
    <JadeMethod name="jssFindObjectRowNo" id="ede097ad-ea8d-4659-8ffa-1937c6261d10">
        <updating/>
        <source>jssFindObjectRowNo(pTheObject:Object):Integer updating;
// --------------------------------------------------------------------------------
// Created:		16 April 2001 by cnwdad1
//
// Purpose:		Searches the itemObject property values for each JadeTableRow in
//				the table for the specified pTheObject parameter.  If the specified
//				object is found, then it's row number is returned.
//
// Parameters:	pTheObject (Object) - The object to find.
//
// Returns:		The row number where the object was found, or zero it it's not found.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
//
// ****************************************************************************
// * NOTE THAT THIS METHOD ONLY USES THE "itemObject" PROPERTY OF THE TABLE's *
// * "JadeTableRow".  IT DOES NOT CHECK THE "itemObject" PROPERTY OF ANY      *
// * INDIVIDUAL TABLE CELLS.                                                  *
// ****************************************************************************
//
vars
	rowPointer	: Integer;
	theTableRow	: JadeTableRow;
	startRow	: Integer;
	rowCount	: Integer;
	
begin
	rowCount	:=	self.rows;
	startRow	:=	self.fixedRows + 1;
	
	foreach rowPointer in startRow to rowCount do
		theTableRow	:=	self.accessRow(rowPointer);
		
		if theTableRow.itemObject = pTheObject then
			return rowPointer;
		endif;
	endforeach;
	
	return 0;
end;</source>
        <Parameter name="pTheObject" type="Object"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="jssFindStringCell" id="53438ed5-e651-4379-9932-a8ebacb760be">
        <updating/>
        <source>jssFindStringCell(pValue:String):JadeTableCell updating;
// --------------------------------------------------------------------------------
// Created:		04 August 2001 by cnwdad1
//
// Purpose:		This method scans the receiver's cells and returns the first
//				JadeTableCell who's text matches the pValue parameter.
//
// Parameters:	pValue - The string to search for.
//
// Returns:		The JadeTableCell for the (first) cell with text matching pValue,
//				or null if the string isn't found.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	rowIndex		: Integer;
	columnIndex		: Integer;
	startRow		: Integer;
	startColumn		: Integer;
	rowCount		: Integer;
	columnCount		: Integer;
	theTableCell	: JadeTableCell;
	
begin
	startRow	:=	self.fixedRows + 1;
	startColumn	:=	self.fixedColumns + 1;
	rowCount	:=	self.rows;
	columnCount	:=	self.columns;
	
	foreach rowIndex in startRow to rowCount do
		foreach columnIndex in startColumn to columnCount do
			theTableCell	:=	self.accessCell(rowIndex, columnIndex);
			
			if theTableCell.text = pValue then
				return theTableCell;
			endif;
		endforeach;
	endforeach;
end;</source>
        <Parameter name="pValue" type="String"/>
        <ReturnType type="JadeTableCell"/>
    </JadeMethod>
    <JadeMethod name="jssFindStringColumn" id="47a20457-c4a5-447f-8626-cda384dfb4b4">
        <updating/>
        <source>jssFindStringColumn(pValue:String):JadeTableColumn updating;
// --------------------------------------------------------------------------------
// Created:		04 August 2001 by cnwdad1
//
// Purpose:		This method scans the receiver's columns and returns the first
//				JadeTableColumn with a cell who's text matches the pValue parameter.
//
// Parameters:	pValue - The string to search for.
//
// Returns:		The JadeTableColumn for the (first) column with a cell with text
//				matching pValue, or null if the string isn't found.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	rowIndex		: Integer;
	columnIndex		: Integer;
	startRow		: Integer;
	startColumn		: Integer;
	rowCount		: Integer;
	columnCount		: Integer;
	
begin
	startRow	:=	self.fixedRows + 1;
	startColumn	:=	self.fixedColumns + 1;
	rowCount	:=	self.rows;
	columnCount	:=	self.columns;
	
	foreach rowIndex in startRow to rowCount do
		foreach columnIndex in startColumn to columnCount do
			if self.getCellText(rowIndex, columnIndex) = pValue then
				return self.accessColumn(columnIndex);
			endif;
		endforeach;
	endforeach;
end;</source>
        <Parameter name="pValue" type="String"/>
        <ReturnType type="JadeTableColumn"/>
    </JadeMethod>
    <JadeMethod name="jssFindStringRow" id="71fbdb2f-edc0-4e5b-8336-52106bd32686">
        <updating/>
        <source>jssFindStringRow(pValue:String):JadeTableRow updating;
// --------------------------------------------------------------------------------
// Created:		04 August 2001 by cnwdad1
