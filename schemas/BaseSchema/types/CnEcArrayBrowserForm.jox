    <JadeMethod name="load" id="504c5d5e-3787-4835-b24a-70d1f7099822">
        <controlMethod name="Form::load"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>load() updating;
// --------------------------------------------------------------------------------
// Created:		21 January 1999 cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 07/07/1999	cnwdad1		Modified form caption to show the name of the object
//							being edited.
//
// --------------------------------------------------------------------------------
begin
	app.mousePointer	:=	Busy;
	centreWindow();
	self.formLoad();
epilog
	self.statusMsg('');
end;</source>
    </JadeMethod>
    <JadeMethod name="loadArray" id="a059cc82-1410-44a9-9ef3-5d075c882311">
        <source>loadArray(pClass:Class);
// --------------------------------------------------------------------------------
// Created:		20 January 1999 by cnwdad1
//
// Purpose:		Loads all entries of an array into the JAC Design Table.
//
// Parameters:	pClass (Class) - The class on which the array is a property.
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	array		: Array;
	table		: Table;
	boolean		: Boolean;
	character	: Character;
	date		: Date;
	integer		: Integer;
	point		: Point;
	real		: Real;
	string		: String;
	time		: Time;
	timeStamp	: TimeStamp;
	any			: Any;
	index		: Integer;

begin
	lblArray.caption		:=	self.myClass.name &amp; "." &amp; self.arrayName;
	lblType.caption			:=	self.myArray.getName();
	lblEntries.caption		:=	self.myArray.size().String;
	table					:=	tblObjects;
	array					:=	self.myArray;

	table.accessMode		:=	Table.AccessMode_Column;
	table.column			:=	1;
	table.inputType			:=	Table.InputType_None;
	table.setCellText(1, 1, "Original Value");
	table.setCellText(1, 2, "Current Value");
	table.columnWidth[1]	:=	table.width div 2;
	table.columnWidth[2]	:=	table.width div 2;
	table.accessMode		:=	Table.AccessMode_Cell;

	if (array.isKindOf(BooleanArray)) then
		foreach boolean in array.BooleanArray do
			index			:=	table.addItem(boolean.String);
			table.row		:=	index;
			table.column	:=	1;
			table.backColor	:=	Cn_LightGray;
			table.column	:=	2;
			table.inputType	:=	Table.InputType_CheckBox;

			if (boolean) then
				table.setCellText(index, 2, "1");
			else
				table.setCellText(index, 2, "0");
			endif;
		endforeach;

	elseif (array.isKindOf(CharacterArray)) then
		foreach character in array.CharacterArray do
			index			:=	table.addItem(character.String &amp; Tab &amp; character.String);
			table.row		:=	index;
			table.column	:=	1;
			table.backColor	:=	Cn_LightGray;
			table.column	:=	2;
			table.inputType	:=	Table.InputType_TextBox;
		endforeach;

	elseif (array.isKindOf(DateArray)) then
		foreach date in array.DateArray do
			index			:=	table.addItem(date.String &amp; Tab &amp; date.String);
			table.row		:=	index;
			table.column	:=	1;
			table.backColor	:=	Cn_LightGray;
			table.column	:=	2;
			table.inputType	:=	Table.InputType_TextBox;
		endforeach;

	elseif (array.isKindOf(DecimalArray)) then
		foreach any in array.DecimalArray do
			index			:=	table.addItem(any.Decimal.String &amp; Tab &amp; any.Decimal.String);
			table.row		:=	index;
			table.column	:=	1;
			table.backColor	:=	Cn_LightGray;
			table.column	:=	2;
			table.inputType	:=	Table.InputType_TextBox;
		endforeach;

	elseif (array.isKindOf(HugeStringArray)) then
		foreach string in array.HugeStringArray do
			index			:=	table.addItem(string &amp; Tab &amp; string);
			table.row		:=	index;
			table.column	:=	1;
			table.backColor	:=	Cn_LightGray;
			table.column	:=	2;
			table.inputType	:=	Table.InputType_TextBox;
		endforeach;

	elseif (array.isKindOf(IntegerArray)) then
		foreach integer in array.IntegerArray do
			index			:=	table.addItem(integer.String &amp; Tab &amp; integer.String);
			table.row		:=	index;
			table.column	:=	1;
			table.backColor	:=	Cn_LightGray;
			table.column	:=	2;
			table.inputType	:=	Table.InputType_TextNumeric;
		endforeach;

	elseif (array.isKindOf(PointArray)) then
		foreach point in array.PointArray do
			index			:=	table.addItem(point.String &amp; Tab &amp; point.String);
			table.row		:=	index;
			table.column	:=	1;
			table.backColor	:=	Cn_LightGray;
			table.column	:=	2;
			table.inputType	:=	Table.InputType_TextBox;
		endforeach;

	elseif (array.isKindOf(RealArray)) then
		foreach real in array.RealArray do
			index			:=	table.addItem(real.String &amp; Tab &amp; real.String);
			table.row		:=	index;
			table.column	:=	1;
			table.backColor	:=	Cn_LightGray;
			table.column	:=	2;
			table.inputType	:=	Table.InputType_TextBox;
		endforeach;

	elseif (array.isKindOf(StringArray)) then
		foreach string in array.StringArray do
			index			:=	table.addItem(string &amp; Tab &amp; string);
			table.row		:=	index;
			table.column	:=	1;
			table.backColor	:=	Cn_LightGray;
			table.column	:=	2;
			table.inputType	:=	Table.InputType_TextBox;
		endforeach;

	elseif (array.isKindOf(TimeArray)) then
		foreach time in array.TimeArray do
			index			:=	table.addItem(time.String &amp; Tab &amp; time.String);
			table.row		:=	index;
			table.column	:=	1;
			table.backColor	:=	Cn_LightGray;
			table.column	:=	2;
			table.inputType	:=	Table.InputType_TextBox;
		endforeach;

	elseif (array.isKindOf(TimeStampArray)) then
		foreach timeStamp in array.TimeStampArray do
			index			:=	table.addItem(timeStamp.String &amp; Tab &amp; timeStamp.String);
			table.row		:=	index;
			table.column	:=	1;
			table.backColor	:=	Cn_LightGray;
			table.column	:=	2;
			table.inputType	:=	Table.InputType_TextBox;
		endforeach;

	endif;

	table.clearAllSelected;
end;</source>
        <Parameter name="pClass" type="Class"/>
    </JadeMethod>
    <JadeMethod name="resize" id="0b0a48e3-7230-4874-b8f6-7fbbdb4a0528">
        <controlMethod name="Form::resize"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>resize() updating;
// --------------------------------------------------------------------------------
// Created:		23 January 1999 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	btnCancel.move(((self.width - btnCancel.width) - 18), ((self.height - btnCancel.height) - 36), btnCancel.width, btnCancel.height);
	btnOk.move(((btnCancel.left - btnOk.width) - 6), ((self.height - btnOk.height) - 36), btnOk.width, btnOk.height);
	btnDelete.move(((btnOk.left - btnDelete.width) - 6), ((self.height - btnDelete.height) - 36), btnDelete.width, btnDelete.height);
	btnInsert.move(((btnDelete.left - btnInsert.width) - 6), ((self.height - btnInsert.height) - 36), btnInsert.width, btnInsert.height);
	btnAdd.move(((btnInsert.left - btnAdd.width) - 6), ((self.height - btnAdd.height) - 36), btnAdd.width, btnAdd.height);
	btnClearAll.move(((btnAdd.left - btnClearAll.width) - 6), ((self.height - btnClearAll.height) - 36), btnClearAll.width, btnClearAll.height);
	tblObjects.move(tblObjects.left, tblObjects.top, (self.width - (tblObjects.left * 3) + 2), (btnCancel.top - 46));
	tblObjects.columnWidth[1]	:=	tblObjects.width div 2;
	tblObjects.columnWidth[2]	:=	tblObjects.width div 2;
end;</source>
    </JadeMethod>
    <JadeMethod name="setArrayName" id="053dad83-3d88-486c-8a22-b764c68e72e9">
