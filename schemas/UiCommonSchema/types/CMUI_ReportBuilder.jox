    <JadeMethod name="doPicDefaultDblClick" id="45d3bcd6-efd4-4004-9af9-b450e346275d">
        <source>doPicDefaultDblClick() protected;
// ---------------------------------------------------------------------------
// Created:     25 August 2003	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	tbl				: CM_EntryTable;
	openDialog		: CMDFileOpen;

begin
	tbl := self.tblParamEnt;
	
	if (tbl.row &lt;&gt; tbl.getRowByName(ETRow_DefaultValBinary)) then
		return;
	endif;
	
	create openDialog transient;
	openDialog.filter := '*.jpg; *.jpeg; *.bmp';
	openDialog.filterIndex := 1;
	openDialog.hideReadOnly := true;
	
	if openDialog.open = 0 then
	    self.picDefault.picture := app.loadPicture(openDialog.fileName);
	endif;
	
epilog
	delete openDialog;	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doQryParamAdd" id="1fdd5900-6e22-4afc-bd2c-7bcde746d334">
        <source>doQryParamAdd() protected;
// ---------------------------------------------------------------------------
// Created:     20 August 2003	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	
	pxyQryParam			: CM_QueryReportParam;
	tbl					: CM_EntryTable;
	paramName			: String;
	paramType			: Integer;
	entTableRow			: EntTableRow;
	defaultValue		: Any;
	entDef				: EntTableDef;
	idx					: Integer;
begin
	if self.mode = self.Mode_View then
		return;
	endif;
	
	self.tblParamData.clearAllSelected();
	
	create pxyQryParam transient;
	if (not self.setQueryParamFromTable(pxyQryParam)) then
		delete pxyQryParam;
		return;
	endif;
	
	//self.allPxyReportParams.add(pxyQryParam);
	entDef := app.myController.getEntTableDef(ETDef_ParamData);
	self.addTblParamDataRow(pxyQryParam, entDef, null);
	self.tblParamEnt.setFocus();
	self.tblParamEnt.moveFirst();
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doQryParamRemove" id="9ce7025e-6eac-4dae-8d92-aed027d16c33">
        <source>doQryParamRemove() protected;
// ---------------------------------------------------------------------------
// Created:     21 August 2003	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	row					: Integer;
	tbl					: CM_DataTable;
	qryParam			: CM_QueryReportParam;
begin
	if self.mode = self.Mode_View then
		return;
	endif;
	
	tbl := self.tblParamData;
	row := tbl.row;
	qryParam := tbl.accessRow(row).itemObject.CM_QueryReportParam;

	if qryParam = null then
		app.msgBox('Please select a parameter to remove', 'Nothing selected', MsgBox_Exclamation_Mark_Icon);
		return;
	endif;
	
	tbl.removeItem(row);
	//if self.allPxyReportParams.includes(qryParam) then
	//	self.allPxyReportParams.remove(qryParam);
	//endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doQryParamUpdate" id="6e2011e7-f6ad-4926-93a3-21f552e3c880">
        <source>doQryParamUpdate() protected;
// ---------------------------------------------------------------------------
// Created:     21 August 2003	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	qryParam			: CM_QueryReportParam;
	tbl					: CM_DataTable;
	row					: Integer;
	entDef				: EntTableDef;
	
begin
	if self.mode = self.Mode_View then
		return;
	endif;
	
	tbl := self.tblParamData;
	row := tbl.row;
	
	qryParam := tbl.accessRow(row).itemObject.CM_QueryReportParam;
	if (qryParam = null) or (not tbl.accessedRow.selected) then
		app.msgBox('You must select a parameter to update', 'Nothing selected', MsgBox_Exclamation_Mark_Icon);
		return;
	endif;
	
	if (not self.setQueryParamFromTable(qryParam)) then
		return;
	endif;
	
	entDef := app.myController.getEntTableDef(ETDef_ParamData);
	tbl.removeItem(row);
	self.addTblParamDataRow(qryParam, entDef, row);
	tbl.accessRow(row).selected := true;
	tbl.row := row;

	
end;</source>
        <access>protected</access>
    </JadeMethod>
