	self.thePoints.add(49);self.thePoints.add(15);
	self.thePoints.add(46);self.thePoints.add(17);
	self.thePoints.add(6);self.thePoints.add(17);
	self.thePoints.add(2);self.thePoints.add(14);
	self.thePoints.add(6);self.thePoints.add(12);
	self.thePoints.add(1);self.thePoints.add(11);
	self.thePoints.add(7);self.thePoints.add(9);
	self.thePoints.add(3);self.thePoints.add(7);
	self.thePoints.add(7);self.thePoints.add(6);
