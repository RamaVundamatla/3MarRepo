    <JadeMethod name="bubbleHelp" id="9f9d1316-a3a7-46e0-be40-26e06b92f627">
        <methodInvocation>mapping</methodInvocation>
        <updating/>
        <source>bubbleHelp(set: Boolean; value: String io) updating, mapping;
// ---------------------------------------------------------------------------
// Created:     28 August 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
/*

Date		Who		Reason
29 May 2009	cnwkpd1	PAR #19791 - add in "if set" to prevent inadvertent clearing of
					toolbar overlay bubbleHelp

*/
vars

begin

	inheritMethod(set, value);
	
	if set and self.myToolbarOverlay &lt;&gt; null then
		self.myToolbarOverlay.bubbleHelp := value;
	endif;
end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="value" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="changePicture" id="6281a2f9-1e0c-4192-8900-1d92924c2fce">
        <updating/>
        <source>changePicture(_pic : Picture) updating;
// ---------------------------------------------------------------------------
// Created:		September 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

begin
	self.myToolbarPicture.picture := _pic.picture;
	self.myToolbarPictureCaption.picture := _pic.picture;
end;</source>
        <Parameter name="_pic" type="Picture"/>
    </JadeMethod>
    <JadeMethod name="click" id="8e2c98fd-9639-416c-a892-faea4807a185">
        <updating/>
        <source>click(frame: CMUI_ToolbarButton input) updating;
// ---------------------------------------------------------------------------
// Created:     28 July 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	btn			: CMUI_ButtonForToolbar;
	tmpStyle	: Integer;
	newValue	: Boolean;
	
begin
	if self.referenceType = self.ReferenceType_Button then
		btn := self.myButtonForToolbar;
		tmpStyle := self.style;

		if tmpStyle = Button.Style_Auto2State then
			// when auto-2-state button is clicked then always set to true
			newValue := true;
			btn.value := newValue;
			self.resetButtonState(newValue);

		elseif tmpStyle = Button.Style_2State then
			newValue := (not btn.value);
			btn.value := newValue;
		endif;

		btn.click(self.myButtonForToolbar);

		if tmpStyle = Button.Style_Auto2State then
			if newValue then
				self.myToolbar.resetButtonStateForParent(self, btn.parent);
			endif;
		elseif self.style = Button.Style_2State then
			/*
			self.resetButtonState(newValue);
			if (not newValue) then
				frame.drawButtonUp();
			endif;
			*/
			// need to use btn.value here in case user has overridden change in the click method (RJS 18 Feb 2010)
			self.resetButtonState(btn.value);
			if (not btn.value) then
				frame.drawButtonUp();
			endif;
		elseif (not btn.enabled) then
			frame.clearGraphics();
		endif;

	elseif self.referenceType = self.ReferenceType_MenuUserToolbar then
		self.myToolbar.doMenuUserToolbarClick(app.isControlKeyDown(), self.myMenuUserToolbar);
	endif;
epilog
	app.mousePointer := MousePointer_Default;
end;</source>
        <Parameter name="frame" type="CMUI_ToolbarButton" usage="input"/>
    </JadeMethod>
    <JadeMethod name="create" id="9ea283e7-e2c6-44c9-9f7c-e14f3368ab15">
        <updating/>
        <source>create() updating;
// ---------------------------------------------------------------------------
// Created:     24 July 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
vars

begin

	self.borderStyle 		:= BorderStyle_None;
	self.boundaryWidth 		:= 0;
	self.bevelInnerWidth 	:= 0;
	self.bevelOuterWidth 	:= 0;
	self.caption 			:= null;
	self.alignment			:= Alignment_Center_Bottom;
	self.enabled 			:= true;
	self.autoRedraw 		:= true;

end;</source>
    </JadeMethod>
    <JadeMethod name="createClickAreaOverlay" id="de141ab9-0a8a-4e61-b7cf-54da858473bc">
        <updating/>
        <source>createClickAreaOverlay() protected, updating;
// ---------------------------------------------------------------------------
// Created:     29 July 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
vars
	tmpOverlay	: CMUI_ToolbarOverlay;

begin
	if self.myToolbarOverlay = null then
		create tmpOverlay transient;
		self.myToolbarOverlay	:= tmpOverlay;
		tmpOverlay.parent 	:= self;
		self.form.addControl(tmpOverlay);
	else
		tmpOverlay := self.myToolbarOverlay;
	endif;
	
	tmpOverlay.top 				:= 0;
	tmpOverlay.left 			:= 0;
	tmpOverlay.transparent 		:= true;
	tmpOverlay.transparentColor := White;
	tmpOverlay.borderStyle		:= Picture.BorderStyle_None;
	tmpOverlay.zOrder(1);
	tmpOverlay.visible			:= true;

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="createToolbarPicture" id="beb605ee-9a98-42eb-b459-be76de906299">
        <updating/>
        <source>createToolbarPicture() protected, updating;
// ---------------------------------------------------------------------------
// Created:     29 July 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
vars

begin
	if self.myToolbarPicture = null then
		create self.myToolbarPicture transient;
		self.myToolbarPicture.parent 	:= self;
		self.form.addControl(self.myToolbarPicture);
		self.myToolbarPicture.height := CMUI_ToolbarButton.HeightPicture; // CNWAB1 METRO
		self.myToolbarPicture.width := CMUI_ToolbarButton.WidthPicture; // CNWAB1 METRO
	endif;

	self.myToolbarPicture.left	:= 2;
	self.myToolbarPicture.top 	:= 5;
	
	
	
	if self.myToolbarPictureCaption = null then
		create self.myToolbarPictureCaption transient;
		self.myToolbarPictureCaption.parent 	:= self;
		self.form.addControl(self.myToolbarPictureCaption);
		self.myToolbarPictureCaption.stretch := Picture.Stretch_Proportional;
		self.myToolbarPictureCaption.parentAspect := Picture.ParentAspect_StretchBoth;
		self.myToolbarPictureCaption.height := CMUI_ToolbarButton.HeightPictureWithCaption; // CNWAB1 METRO
		self.myToolbarPictureCaption.width := CMUI_ToolbarButton.WidthPictureWithCaption; // CNWAB1 METRO
	endif;
		self.myToolbarPictureCaption.top := 1;
		self.myToolbarPictureCaption.left := ((self.WidthTotalWithCaption / 2) - (CMUI_ToolbarButton.WidthPictureWithCaption / 2) + 2).Integer;

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="drawButtonDown" id="0a587153-dbb0-4140-923d-6a58a9c0e6c9">
        <updating/>
        <source>drawButtonDown() updating;
// ---------------------------------------------------------------------------
// Created:     11 December 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	tmpBackColor	: Integer;
begin
	inheritMethod();

	tmpBackColor := self.origBackColor + 2563867; 	// gives a lighter gray;
	if tmpBackColor &gt; White then
		tmpBackColor := self.origBackColor - 2563867;	// just use the same offset the other way;
	endif;
	self.backColor := tmpBackColor;

end;</source>
    </JadeMethod>
    <JadeMethod name="drawButtonNormal" id="052e0aa4-3446-416d-83f3-9c59da71742c">
