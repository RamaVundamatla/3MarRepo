begin

	self.hasBeenUsed := _value;
	
epilog

end;</source>
        <Parameter name="_value" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="ae3d0d73-8b91-447b-ba23-f9f27578a77a">
        <updating/>
        <source>setProxy(	_code 						: String;
			_description 				: String;
			_numDecimals 				: Integer;
			_unitDescription 			: String;
			_hasBeenUsed 				: Boolean;
			_isAvailable 				: Boolean;
			_toDoColl 					: CM_ToDoTaskDescBySortKey;
			_eventTypes 				: CM_EventTypeByTypeDict;
			_transTypeSet 				: CM_TransactionTypeSet;
			_transResourceBrokers 		: CM_TransSBByTransTypeType;	//CM_TransResourceBrokerDict
			_isFromToDateTimeRequired 	: Boolean;
			_jadeCode 					: String;
			_addInfo 					: String;		 				//13 Apr 2017	NDL	TFS 3414
			_userCode					: String;
			_type 						: Integer;       				//31/10/2022 navds20 TFS #56635[54261]
			_mandatory					: Boolean;						// 23.12.2022 navds21 TFS #54349[54262]
			_resourceTypeGroup			: CM_ResourceTypeGroup;			// ### TFS 58761 (60739) 16Nov2023 NAVPW1
			_autoApplyResourceType		: CM_ResourceType) updating;	// ### TFS 58761 (60739) 16Nov2023 NAVPW1
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
18 December 2009	cnwndl1	Initial creation
31 October 	2022	navds20 ChangeRequest 56635:[54261] EUP - Todo Task Resources Maintenance
23 December 2022    navds21 ChangeRequest 54349[54262]: EUP - Enable Is Mandatory for ToDo Task Resources
*/

vars
	obj 		: CM_Object;
	hookLink 	: CM_HookLink;		//cnwmc5 - 23 Sep 2015 - PAR 36920
begin

	self.raiseExceptionIfNotTransient(method);

	self.code						:= _code;
	self.description				:= _description;
	self.decimalPlaces				:= _numDecimals;
	self.unitDescription			:= _unitDescription;
	self.hasBeenUsed				:= _hasBeenUsed;
	self.isAvailable				:= _isAvailable;
	self.isFromToDateTimeRequired	:= _isFromToDateTimeRequired;	//cnwmc5 - 22 Sep 2015 - PAR 36920
	self.additionalInfo				:= _addInfo;					//13 Apr 2017	NDL	TFS 3414
	self.type						:= _type;						//31/10/2022 navds20 TFS #56635[54261]
	self.mandatory					:= _mandatory;					//23.12.2022 navds21 TFS #54349[54262]
	self.myResourceTypeGroup		:= _resourceTypeGroup;			// ### TFS 58761 (60739) 16Nov2023 NAVPW1
	self.myAutoApplyResourceType	:= _autoApplyResourceType;		// ### TFS 58761 (60739) 16Nov2023 NAVPW1
	self.allUsageContexts.clear();
	
	foreach obj in _toDoColl do
		self.allUsageContexts.add(obj);
	endforeach;
	
	foreach obj in _eventTypes do
		self.allUsageContexts.add(obj);
	endforeach;
	
	foreach obj in _transTypeSet do
		self.allUsageContexts.add(obj);
	endforeach;
	
	foreach obj in _transResourceBrokers do
		self.allUsageContexts.add(obj);
	endforeach;
	
	//cnwmc5 - 23 Sep 2015 - PAR 36920
	if _jadeCode &lt;&gt; null then
		if self.myHookCode &lt;&gt; null then
			self.myHookCode.setForProxy(self.code, app.myRoot.allHookTypes[HookType_ToDoTaskResource]);
			self.myHookCode.setJadeCodeForProxy(_jadeCode, _userCode);
		else
			create self.myHookCode transient;
			self.myHookCode.setJadeCodeForProxy(_jadeCode, _userCode);
			self.myHookCode.setForProxy(self.code, app.myRoot.allHookTypes[HookType_ToDoTaskResource]);
			self.myHookCode.createProxyHookLinkForParent(HookType_ToDoTaskResource, self);
		endif;
	else
		if self.myHookCode &lt;&gt; null then
			delete self.myHookCode;
		endif;
		if self.myHookLink &lt;&gt; null then
			hookLink := self.myHookLink;
			delete hookLink;
		endif;
	endif;
	
epilog

end;</source>
        <Parameter name="_code" type="String"/>
        <Parameter name="_description" type="String"/>
        <Parameter name="_numDecimals" type="Integer"/>
        <Parameter name="_unitDescription" type="String"/>
        <Parameter name="_hasBeenUsed" type="Boolean"/>
        <Parameter name="_isAvailable" type="Boolean"/>
        <Parameter name="_toDoColl" type="CM_ToDoTaskDescBySortKey"/>
        <Parameter name="_eventTypes" type="CM_EventTypeByTypeDict"/>
        <Parameter name="_transTypeSet" type="CM_TransactionTypeSet"/>
        <Parameter name="_transResourceBrokers" type="CM_TransSBByTransTypeType"/>
        <Parameter name="_isFromToDateTimeRequired" type="Boolean"/>
        <Parameter name="_jadeCode" type="String"/>
        <Parameter name="_addInfo" type="String"/>
        <Parameter name="_userCode" type="String"/>
        <Parameter name="_type" type="Integer"/>
        <Parameter name="_mandatory" type="Boolean"/>
        <Parameter name="_resourceTypeGroup" type="CM_ResourceTypeGroup"/>
        <Parameter name="_autoApplyResourceType" type="CM_ResourceType"/>
    </JadeMethod>
