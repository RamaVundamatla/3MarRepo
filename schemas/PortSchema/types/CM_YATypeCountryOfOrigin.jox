    <JadeMethod name="isCMIFDataMatch" id="b1d8c44e-5953-41fe-88c6-2cb25e7053dd">
        <source>isCMIFDataMatch(_cmifAutoPlan : CMIF_YAAutoPlan; _yaData: CM_YADataObjects): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 March 2023	navmv20 TFS 56216 Task 56217: Jade - New YA Criteria

*/
vars

begin
	return _cmifAutoPlan.isCountryOfOrigin_Match(_yaData);
	
end;</source>
