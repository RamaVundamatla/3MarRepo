<Class name="CnEcTime" id="87cafb21-9476-4651-acac-47c2ebac1fe3">
    <superclass name="CnEcPrimitiveValue"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
