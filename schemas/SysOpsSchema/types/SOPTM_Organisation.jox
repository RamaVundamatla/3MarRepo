    <JadeMethod name="setControlsForAddEdit" id="cff56266-e3e7-4944-be29-f5422dc4dc4c">
        <updating/>
        <source>setControlsForAddEdit() updating;

vars
	theForm : SOP_TableMaintForm;

begin
  
	theForm := self.myForm;
	theForm.tblInput1.userInputEnabled := true;
	
	//07 Jul 2015	NDL	Par 36588
	if theForm.txtEmailName.getControl(2) &lt;&gt; null then
		theForm.mulSelect2.userInputEnabled := true;
		theForm.txtEmailName.getControl(2).enabled := true;
		theForm.txtName.getControl(2).enabled := true;
		theForm.btnAddNew.getControl(2).enabled := true;
	endif;
	
			
	if theForm.mode = theForm.Mode_Add then
		theForm.tblInput1.clearValues;
	   	theForm.cmbDebtor.setObject(null);
	  	theForm.cmbDACarrier.setObject(null);
	  	theForm.cmbDAConsignee.setObject(null);
	  	theForm.cmbDAOperator.setObject(null);
	  	theForm.cmbDAOrg.setObject(null);
		theForm.cmbDAAgent.setObject(null);
		theForm.tblInput1.enableRowByName(ETRow_Name);
		//theForm.tblInput1.enableRowByName(ETRow_IsExternal);
//		theForm.tblInput1.setFocus;
		theForm.tblInput1.moveFirst();
		// call this last as sets cell input type (case etc)
		// if not called can get problems with case on entry. 
		theForm.tblInput1.gotFocus(theForm.tblInput1);		
		
	else
		// refresh the data from the newly created proxy
		self.showThumbnail(theForm.myProxyObject.CM_Organisation);
		// cannot update code		
		theForm.tblInput1.disableRowByName(ETRow_Name);
		//theForm.tblInput1.disableRowByName(ETRow_IsExternal);//09/03/2010 cnwdz2 par22587
		theForm.tblInput1.goToRowByName(ETRow_DataAccessCarrier);
	endif;
	theForm.tblInput1.enableRowByName(ETRow_IsExternal); //09/03/2010 cnwdz2 par22587
	
end;</source>
    </JadeMethod>
    <JadeMethod name="setCtrlsForView" id="8928b2e1-4d2d-4cd8-a911-9049023c3e19">
        <updating/>
        <source>setCtrlsForView() updating;

vars

	theForm : SOP_TableMaintForm;

begin
	//cnwmc5 - 17 Oct 2013 - PAR 32622
	inheritMethod();
	
	theForm := self.myForm;
	theForm.tblInput1.userInputEnabled := false;
	
	//07 Jul 2015	NDL	Par 36588
	if theForm.txtEmailName.getControl(2) &lt;&gt; null then
		theForm.txtEmailName.getControl(2).enabled := false;
		theForm.txtName.getControl(2).enabled := false;
		
		theForm.btnAddNew.getControl(2).enabled := false;
	endif;

end;</source>
    </JadeMethod>
    <JadeMethod name="setupMulSelectSheet2" id="07dcb4fd-9f92-4080-b615-de2196fad46d">
        <source>setupMulSelectSheet2();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 July 2015	cnwndl1	Initial creation	Par 36588

*/

vars

	theForm	: SOP_TableMaintForm;
	localTxtEmailName : CMUI_TextBox;
	localTxtEmailAddress : CMUI_TextBox;
	localButton : CMUI_Button;
	
begin

	theForm := self.myForm;
	theForm.shtMultiSelect2.caption := 'Emails';
	self.setupMultiSelect2('Email Addresses',app.myRoot.allEmailAddressesByAddress,SOP_TableMaintForm::displayEntryEmailAddress.name);
	
	theForm.lblName2.visible := true;
	theForm.lblName2.caption := "Add New:";
	
	theForm.lblName3.visible := true;
	theForm.lblName3.caption := "Name";
	
	localTxtEmailName := theForm.txtEmailName.getControl(2);
	if localTxtEmailName = null then
		localTxtEmailName := theForm.txtEmailName.loadControl(2).CMUI_TextBox;
		localTxtEmailName.parent := theForm.shtMultiSelect2;
	endif;
	localTxtEmailName.visible := true;
	localTxtEmailName.enabled := false;
	localTxtEmailName.move(110, 32,205, 18);
	localTxtEmailName.text := "";
	
	theForm.lblName4.visible := true;
	theForm.lblName4.caption := "E-Mail Address";
	theForm.lblName4.move(50, 42,100, 18);
	
	localTxtEmailAddress := theForm.txtName.getControl(2);
	if localTxtEmailAddress = null then
		localTxtEmailAddress := theForm.txtName.loadControl(2).CMUI_TextBox;
		localTxtEmailAddress.parent := theForm.shtMultiSelect2;
	endif;
	localTxtEmailAddress.visible := true;
	localTxtEmailAddress.enabled := false;
	localTxtEmailAddress.move(110, 54,205, 18);	
	localTxtEmailAddress.text := "";	
	localTxtEmailAddress.case := TextBox.Case_Lower; 
	
	localButton := theForm.btnAddNew.getControl(2);
	if localButton = null then
		localButton := theForm.btnAddNew.loadControl(2).CMUI_Button;
		localButton.parent := theForm.shtMultiSelect2;
	endif;
	localButton.visible := true;
	localButton.enabled := false;
	localButton.bubbleHelp := "Enter a new email address and click here to add";
	localButton.move(localTxtEmailAddress.left + localTxtEmailAddress.width + 5, localTxtEmailAddress.top, 20, 20);
			
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setupThumbnailDetails" id="001ec6b3-c0d0-484b-8cd1-abf3235c1966">
        <source>setupThumbnailDetails();

vars
	theForm 		: SOP_TableMaintForm;
	row				: Integer;
	entRowTrans		: EntTableRowTransient;
begin
  
	theForm := self.myForm;
	theForm.useProxyObject := true;
	theForm.setTblDataEntRows(ETDef_OrgTbl);
	//theForm.zAddColumn('Name', 'name', Table.InputType_None, 100);
	//12/01/2011 cnwdz2 25840
	//theForm.zClearSortColumns();
	//theForm.zAddSortColumn(ETRow_Name, false);

	theForm.shtTblInput1.caption := 'Details';
	theForm.initTblInput(theForm.tblInput1, ETDef_OrgMaint);
	theForm.shtTblInput1.visible := true;

end;</source>
    </JadeMethod>
    <JadeMethod name="showThumbnail" id="aab0f696-9fe0-4a0a-86d6-e8eda1dbf20e">
        <updating/>
        <source>showThumbnail(pOrg : CM_Organisation) updating;

vars

	theForm : SOP_TableMaintForm;
	dac	: CM_DataAccessController;
	
begin
  
  	theForm := self.myForm;
	theForm.tblInput1.clearValues();

	theForm.tblInput1.setValueByName(ETRow_Name, 	pOrg.name);
	
	if pOrg.isKindOf(CM_ExternalOrganisation) then
		theForm.tblInput1.setValueByName(ETRow_IsExternal, 	true);
	else
		theForm.tblInput1.setValueByName(ETRow_IsExternal, 	false);
	endif;
	if pOrg.myDebtor &lt;&gt; null then
		theForm.tblInput1.setValueByName(ETRow_MyDebtor, pOrg.myDebtor.name);
		theForm.cmbDebtor.setObject(pOrg.myDebtor);
	else
		theForm.cmbDebtor.listObject := null;
	endif;
	
	theForm.tblInput1.setValueByName(ETRow_NotAvailableForEntry, pOrg.isNotAvailableForEntry);
	theForm.tblInput1.setValueByName(ETRow_AvailForLabourRestrict, pOrg.isAvailableForLabourRestiction);
	
	theForm.tblInput1.setPictureByName(ETRow_Logo,	pOrg.logo);

  	theForm.cmbDACarrier.setObject(null);
  	theForm.cmbDAConsignee.setObject(null);
  	theForm.cmbDAOperator.setObject(null);
  	theForm.cmbDAOrg.setObject(null);
	theForm.cmbDAAgent.setObject(null);
  	
	foreach dac in pOrg.allDataAccessControllers do
		if dac.myClassContained = CM_Carrier then
			theForm.tblInput1.setValueByName(ETRow_DataAccessCarrier, dac.name);
			theForm.cmbDACarrier.setObject(dac);
		elseif dac.myClassContained = CM_ConsigneeConsignor then
			theForm.tblInput1.setValueByName(ETRow_DataAccessConsignee, dac.name);
			theForm.cmbDAConsignee.setObject(dac);

		elseif dac.classContainedName = CM_Operator.name then
			theForm.tblInput1.setValueByName(ETRow_DataAccessOperator, dac.name);
			theForm.cmbDAOperator.setObject(dac);

		elseif dac.classContainedName = CM_Organisation.name then
			theForm.tblInput1.setValueByName(ETRow_DataAccessOrganisation, dac.name);
			theForm.cmbDAOrg.setObject(dac);
		elseif dac.classContainedName = CM_CustomsAgent.name then		// TFS 525
			theForm.tblInput1.setValueByName(ETRow_DataAccessCustomsAgent, dac.name);
			theForm.cmbDAAgent.setObject(dac);
		endif;
	endforeach; 
	
	//08 Jul 2015	NDL	Par 36588
	theForm.mulSelect2.setSelected( pOrg.allSelectedEmailAddresses );
	
epilog

end;</source>
        <Parameter name="pOrg" type="CM_Organisation"/>
    </JadeMethod>
</Class>
