    <JadeMethod name="getAttrByType" id="95b6f7ca-1026-4d6c-b2ea-222600ce441c">
        <source>getAttrByType(_type : Integer) : CM_YACriteria;

// ---------------------------------------------------------------------------
// Created:     MARCH 2010 ANDREW BISHOP
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//// PAR 23263 
// ---------------------------------------------------------------------------

vars
	criteria : CM_YACriteria;	
	voyAlloc : CM_VoyageAllocation;
begin
	
	if self.useVoyageAllocations  then 
		voyAlloc := self.allAllocations.first().CM_VoyageAllocation;
		if voyAlloc = null then
			return null;
		endif;
		criteria := voyAlloc.getCriteriaOfTypeValue(_type);
		
		return criteria;
	endif;
	return null;
epilog

end;</source>
        <Parameter name="_type" type="Integer"/>
        <ReturnType type="CM_YACriteria"/>
    </JadeMethod>
    <JadeMethod name="getAttrCargoSubtype" id="14ae2e5b-e719-4d4a-aaaa-05f20ab5322b">
