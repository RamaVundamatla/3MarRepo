    <JadeMethod name="setForCreate" id="e2be0313-c4a6-48a6-bfb3-13bd2a47cc89">
        <updating/>
        <source>setForCreate(_pxyObj: HMS_Object; _passport: CM_Passport input) updating;
//--------------------------------------------------
// Created:	07 April 2004 By: cnwgd1
//--------------------------------------------------
// Changed On	By			Reason
// ==========	========	=======================================================
// 09/08/2012	cnwdap1		PAR #29111 Refactor Invoice update code to its own method
// 04/03/2019	jlgdap1		TFS 43667 PNL Two pilots on Departure Resources Used
vars
	aMove : HMS_VoyageMovement;
	hmsData : HMS_VoyageData;
	aVoy : CM_Voyage;
begin
	inheritMethod(_pxyObj, _passport);
	// TFS 43667 inheritMethod calls setForUpdate, which creates a transaction					// TFS 43667
	// Don't do that again here if a transaction has already been created						// TFS 43667
	if self.myResource = null and _pxyObj.HMS_ResourceUsed.myResource &lt;&gt; null then				// TFS 43667
		self.createTransaction(self.myVoyageMovement, TRANS_TYPE_ResourceBooked, _passport);
	endif;																						// TFS 43667
	
	self.setVoyageInvoiceStatus();			// PAR #29111
	/*// CCMS 1350							code removed as part of PAR #29111
	aMove := self.myVoyageMovement;
	if aMove &lt;&gt; null then
		hmsData := aMove.myHMSVoyageData;
		if hmsData &lt;&gt; null then
			aVoy :=hmsData.myVoyage;
			if aVoy &lt;&gt; null and aVoy.statusInvoice = Voyage_Invoice_Status_FullGen then // PAR 12384
				aVoy.setInvoiceStatus(Voyage_Invoice_Status_PartGen);
			endif;
		endif;
	endif;	*/

end;</source>
        <Parameter name="_pxyObj" type="HMS_Object"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="1c6bd379-3220-4922-a4f1-6748d286d430">
        <updating/>
        <source>setForUpdate(_pxyResourceUsed : HMS_ResourceUsed; _passport: CM_Passport input) updating;
//--------------------------------------------------
// Created:	07 April 2004 By: cnwgd1
// 13.11.2018 cnwma1 Bug 41988: Error 1210 on Create Cash Receipt
// 22/11/2018	jlgdap1	TFS 42123 Correct setting of myWorkOrderVoyageDtl - this is needed for deriving payment type 
//--------------------------------------------------
vars
	createTran : Boolean;
	voyage : CM_Voyage;
begin
	inheritMethod(_pxyResourceUsed, _passport);

	self.archived 		:= _pxyResourceUsed.archived;
	self.archivedDT 	:= _pxyResourceUsed.archivedDT;
	self.code 			:= _pxyResourceUsed.code.toUpper.trimBlanks;
	self.description 	:= _pxyResourceUsed.description;
	self.fromDateTime 	:= _pxyResourceUsed.fromDateTime;
	self.toDateTime 	:= _pxyResourceUsed.toDateTime;
	self.unitsUsed 		:= _pxyResourceUsed.unitsUsed;	
	self.partOfContract := _pxyResourceUsed.partOfContract;
	self.myHarbour 		:= _pxyResourceUsed.myHarbour;			
	self.myHMSObject := _pxyResourceUsed.myHMSObject; // for invoicing
	
	if self.myWorkOrderVoyageDtl &lt;&gt; null and _pxyResourceUsed.myWorkOrderVoyageDtl &lt;&gt; null then		// TFS 42123
		self.myWorkOrderVoyageDtl := null;															// TFS 42123
	endif;																							// TFS 42123
	// TFS 42123 reinstated the following line as well
	self.myWorkOrderVoyageDtl := _pxyResourceUsed.myWorkOrderVoyageDtl;	//31 Oct 2018	NDL	TFS 41281 //13.11.2018 cnwma1 Bug # 41988

	//A default resource used object is created without the resource set, the user sets it later
	createTran := (self.myResource = null and _pxyResourceUsed.myResource &lt;&gt; null);
	
	self.myResource := _pxyResourceUsed.myResource;
	if self.myResource &lt;&gt; null then
		self.myResourceType := self.myResource.myResourceType;
	else
		//A default resource used must have the resourceType set
		self.myResourceType := _pxyResourceUsed.myResourceType;
	endif;
	
	//26 Nov 2018	NDL	TFS 41980
	if _pxyResourceUsed.myDebtor &lt;&gt; null then
		self.myDebtor := _pxyResourceUsed.myDebtor;	
	endif;
	
	if app.isInProformaMode then
		self.myVoyageMovement := _pxyResourceUsed.myVoyageMovement;
	elseif app.isConverting then
		self.myVoyageMovementArchive := _pxyResourceUsed.myVoyageMovementArchive;
		self.myVoyageMovement := _pxyResourceUsed.myVoyageMovement;
	
	elseif createTran then
		self.createTransaction(self.myVoyageMovement, TRANS_TYPE_ResourceBooked, _passport);
	endif;
	
	if _pxyResourceUsed.myVTMISTransaction &lt;&gt; null then
		if _pxyResourceUsed.myVTMISTransaction.isTransient then
			//Create invoice charge
			self.createInvoiceTransaction(_passport);
		endif;
	endif;

	/* epr TFS 42043 29/11/18 shouldn't create this anymore
		if not app.isInProformaMode then // TFS 40236

		if self.myVoyageMovement &lt;&gt; null and _pxyResourceUsed.myResource &lt;&gt; null then
			voyage:=self.myVoyageMovement.getMyVoyage;
			if not self.myVoyageMovement.isMovementTypeShift then
			//	if voyage &lt;&gt; null and voyage.isInaportnetVoyageProcess or voyage.isPelindoVoyageProcess then
				if voyage &lt;&gt; null and not voyage.isUsingDefaultProcessJMT then	//23 Jul 2018	NDL	TFS 39882
					app.myUtilityUA.utlUpdateWorkOrderMarine(voyage,null,self.myVoyageMovement.isArrival,self,null,
												self.myVoyageMovement.occursOnDT,null,null,
												0,0,0,false,false,_passport); // TFS 40236
				endif;
			endif;
		endif;
	endif;*/
end;</source>
        <Parameter name="_pxyResourceUsed" type="HMS_ResourceUsed"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setFromWorkingResourceUsed" id="795f12d4-91c8-4828-9e59-920674b2eea8">
        <updating/>
        <source>setFromWorkingResourceUsed(_workingResource : CMIF_HMS_ResourceUsed;
							_permMovement : HMS_VoyageMovement;
							_transType : Integer;
							_passport : CM_Passport input) updating;
//--------------------------------------------------------------
//Created: 30 July 2003 By: cnwgd1
//--------------------------------------------------------------
// Changed On	By			Reason
// ==========	========	================================================================
// 09/08/2012	cnwdap1		PAR #29111 Reset voyage invoice status if we created a new resource used
vars

begin
	
	if self.myVTMISTransaction &lt;&gt; null then
		//Already charged, therefore it can't be updated, just ignore it
		return;
	endif;
	
	self.fromDateTime := _workingResource.fromDateTime;
	self.toDateTime := _workingResource.toDateTime;
	self.unitsUsed := _workingResource.unitsUsed;
	self.partOfContract := _workingResource.isPartOfContract;
	
	self.myHarbour := _permMovement.myHarbour;
	self.myResource := _workingResource.myResource;
	
	if self.myResource &lt;&gt; null then
		self.code := self.myResource.code.toUpper.trimBlanks;
		self.description := self.myResource.description;
		self.myResourceType := self.myResource.myResourceType;
		if _transType = TRANS_TYPE_ResourceBooked then
			self.createTransaction(_permMovement, TRANS_TYPE_ResourceBooked, _passport);
		endif;
		
	else
		//They have added a type but not selected the actual resource yet so don't create trans
		self.myResourceType := _workingResource.myResourceType;
		self.code := self.myResourceType.code.toUpper.trimBlanks;
		self.description := self.myResourceType.description;		
	endif;
	
	//Set after transaction is create
	self.myVoyageMovement := _permMovement;
	// PAR #29111 if myResource is not null, and transType is TRANS_TYPE_ResourceBooked, we've just created a 
	// transaction, and need to set my voyage's invoice status appropriately. We can do this here now because 
	// self.myVoyageMovement has just been set
	if self.myResource &lt;&gt; null and _transType = TRANS_TYPE_ResourceBooked then
		self.setVoyageInvoiceStatus();
	endif;
	// PAR #29111 end
	
	if self.myVTMISTransaction = null
	and _workingResource.isCharged then
		//Create charge
		self.validateInvoiceData(_passport);
		self.createInvoiceTransaction(_passport);
	endif;
		
end;</source>
        <Parameter name="_workingResource" type="CMIF_HMS_ResourceUsed"/>
        <Parameter name="_permMovement" type="HMS_VoyageMovement"/>
        <Parameter name="_transType" type="Integer"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setHMSObject" id="e09c9336-eb68-4cc2-adcb-7a64a688bf9c">
