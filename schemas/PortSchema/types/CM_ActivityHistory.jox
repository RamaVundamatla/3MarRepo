    <JadeMethod name="addToArray" id="31cd47c7-9a6e-4b1f-8b18-5a489582628e">
        <source>addToArray(_heading, _str : String; _array : HugeStringArray input) protected;
// -------------------------------------------
// Created 29 March 2004 by cnwdvb1
// -------------------------------------------
vars

begin

	if _str &lt;&gt; null then
		_array.add(_heading &amp; Tab &amp;  _str[1:200]);
	endif;

end;</source>
        <access>protected</access>
        <Parameter name="_heading" type="String"/>
        <Parameter name="_str" type="String"/>
        <Parameter name="_array" type="HugeStringArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="auditId" id="a92fd548-2b57-4f8c-a5c6-918994c1d41a">
        <source>auditId(): String;
// ---------------------------------------------------------------------------
// Created:     May 2006 by cnwrs1
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin
	return self.activityType.String&amp;' '&amp;self.description.trimBlanks();
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="create" id="4d34ecbc-70ae-4efb-97e0-021655e5a6da">
        <updating/>
        <source>create() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26 September 2019	jlger1	Initial creation

*/

vars
	user : CM_User;
begin
	user := app.getMyUser;
	if user &lt;&gt; null then
		self.userCode := user.code;
	endif;
epilog	

end;</source>
    </JadeMethod>
    <JadeMethod name="erase" id="f07c3671-91cf-4a15-ba84-40e18bf55e15">
        <updating/>
        <source>erase(_eraseLevel: Integer) updating;
// -------------------------------------------
// Created 30 March 2004 by cnwdvb1
// -------------------------------------------
// 10/05/2012	cnwcs5	par 29450 - use local variables instead of implied getPropertyValue
vars
	terminal	:CM_Terminal;
	root		:CM_Root;
begin
	terminal 	:= self.myTerminal;
	root		:= self.myRoot;
	
	if terminal &lt;&gt; null then
		terminal.causeEvent(terminal.getTerminalEvent(EventTerminalActivityDelete), false, self);
		
	elseif root &lt;&gt; null then
		root.causeEvent(EventSystemActivityDelete, false, self);
	endif;
	
	inheritMethod(_eraseLevel);
end;</source>
        <Parameter name="_eraseLevel" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getDetailForDisplay" id="a35a18a1-4f9e-4d44-929b-e4164bd78cde">
        <source>getDetailForDisplay(_array : HugeStringArray input) : Boolean;
// -------------------------------------------
// Created 29 March 2004 by cnwdvb1
// -------------------------------------------
vars

begin

	if _array = null then
		return false;
	endif;
	return true;


end;</source>
        <Parameter name="_array" type="HugeStringArray" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="2c8d1c47-7e02-4960-b615-c03df7a526c5">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
// -------------------------------------------
// Created 23 August 2004 by cnwdvb1
// -------------------------------------------
// 13 Apr 2016	cnwmp6	TFS 488 - Multi Timezone Support
vars

begin
	if _attrName = ETRow_Date2 then
		return self.systemToLocalTime(self.dateTime).Date.shortFormatJMT();
	elseif _attrName = ETRow_Time then
		return self.systemToLocalTime(self.dateTime).Time.String;
	elseif _attrName = ETRow_Description then
		return self.description;
	elseif _attrName = ETRow_Type then
		return self.getTypeDescription();
	elseif _attrName = ETRow_ActivityDateTime then
		return self.systemToLocalTime(self.dateTime).shortCurrentLocaleFormatSecs();
	elseif _attrName = ETRow_Pic then	//13 Jul 2016	NDL Make Activity History form use column organiser
		return null;
	elseif _attrName = ETRow_Terminal then	//13 Jul 2016	NDL Make Activity History form use column organiser
		if self.myTerminal = null then
			return app.getErrorString(System_GC);
		else
			return self.myTerminal.code;
		endif;
	elseif _attrName = ETRow_Status then	//27 Sep 2019	NDL	TFS 46758
		return self.getStatusDescription();
	elseif _attrName = ETRow_User then	//30 Sep 2019	NDL TFS 46758
		return userCode;
	elseif _attrName = ETRow_InterfaceName then	//30 Sep 2019	NDL TFS 46758
		return null;
	elseif _attrName = ETRow_ReprocessDT then	//30 Sep 2019	NDL TFS 46758
		return null;
	else
		return inheritMethod(_attrName, _short);
	endif;


end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
