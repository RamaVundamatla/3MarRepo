    <JadeMethod name="setFromSystemMenuItem" id="2bdeab56-b699-4ed2-8487-3aad8d8eb619">
        <updating/>
        <source>setFromSystemMenuItem(_sysMenuDtl : CM_MenuDtl; _menuRoot: CM_MenuRoot) updating;
// ---------------------------------------------------------------------------
// Created:     02 December 2002		cnwth2	
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars

begin
	self.level					:= 3;
	self.myMenuItem				:= _sysMenuDtl;
	self.myMenuRoot				:= _menuRoot;
	self.heading 				:= _sysMenuDtl.heading;
	self.pictureStringButton	:= _sysMenuDtl.pictureStringButton;
	self.pictureStringButtonDown:= _sysMenuDtl.pictureStringButtonDown;
	self.pictureStringIcon		:= _sysMenuDtl.pictureStringIcon;
	self.toolTip				:= _sysMenuDtl.toolTip;
	

end;</source>
        <Parameter name="_sysMenuDtl" type="CM_MenuDtl"/>
        <Parameter name="_menuRoot" type="CM_MenuRoot"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="bbd03aa2-67b0-404b-8f35-84fe611bb8d8">
        <updating/>
        <source>setProxy(_heading, 
		_pictureButton,
		_pictureButtonDown, 
		_pictureIcon,_toolTip : String; 
		_menuDtl : CM_MenuDtl; 
		_menuRoot : CM_MenuRoot) updating;

vars

begin

	self.setProxyMenuUserItem(_heading, _pictureButton,_pictureButtonDown, _pictureIcon,_toolTip, _menuDtl, _menuRoot);

end;</source>
        <Parameter name="_heading" type="String"/>
        <Parameter name="_pictureButton" type="String"/>
        <Parameter name="_pictureButtonDown" type="String"/>
        <Parameter name="_pictureIcon" type="String"/>
        <Parameter name="_toolTip" type="String"/>
        <Parameter name="_menuDtl" type="CM_MenuDtl"/>
        <Parameter name="_menuRoot" type="CM_MenuRoot"/>
    </JadeMethod>
    <JadeMethod name="setProxyToolbar" id="e76a1e48-6c0b-422c-b4ac-c1df014ac4a9">
        <updating/>
        <source>setProxyToolbar(_theRealUserTerminal : CM_UserTerminal input) updating;
// ---------------------------------------------------------------------------
// Created:		August  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin
	self.myUserTerminalIFOnToolbar := _theRealUserTerminal;

end;</source>
        <Parameter name="_theRealUserTerminal" type="CM_UserTerminal" usage="input"/>
    </JadeMethod>
    <JadeMethod name="validateToolbarAdd" id="d21cca15-3bea-49a7-a9e3-0ba2470fce38">
        <source>validateToolbarAdd();
// ---------------------------------------------------------------------------
// Created:		August  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin
	if self.pictureStringButton.trimBlanks = null then
		app.raiseCMException2(ERR_INVALID_VALUE, "'Up Picture'", "Please select a picture", null,null);
	endif;
	if self.pictureStringButtonDown.trimBlanks = null then
		app.raiseCMException2(ERR_INVALID_VALUE, "'Down Picture'", "Please select a picture", null,null);
	endif;
	if self.myUserTerminalIFOnToolbar &lt;&gt; null then
		app.raiseCMException2(ERR_INVALID_VALUE, "'Add To Toolbar'", "'" &amp; self.heading.trimBlanks &amp; "' is already on the Toolbar.", null,null);
	endif;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="validateToolbarRemove" id="97b20231-5843-4a36-805e-c848d2c63466">
        <source>validateToolbarRemove();
// ---------------------------------------------------------------------------
// Created:		August  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin

	if self.myUserTerminalIFOnToolbar = null then
		app.raiseCMException2(ERR_INVALID_VALUE, "'Remove From Toolbar'", "'" &amp; self.heading.trimBlanks &amp; "' is not on the Toolbar.", null,null);
	endif;

end;</source>
    </JadeMethod>
</Class>
