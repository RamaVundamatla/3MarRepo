    <JadeMethod name="cloneMySelf" id="02bc4883-95dd-496a-8fe2-533b17ca81ba">
        <source>cloneMySelf(_newLayer: CM_DeckLayerLayout; _copy: Boolean; _nextOrd: Boolean): CM_ROROLaneDefnVoyage;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
03 June 2011	cnwer1	Initial creation CCMS MES 1116

*/

vars

	newMe : CM_ROROLaneDefnVoyage;
begin
	newMe := inheritMethod(_newLayer, _copy, _nextOrd).CM_ROROLaneDefnVoyage;
	
	newMe.myVoyageStructure:=_newLayer.myDeckLayout.myDeck.CM_DeckVoyage.myVoyageStructure;
	
	return newMe;

epilog

end;</source>
        <Parameter name="_newLayer" type="CM_DeckLayerLayout"/>
        <Parameter name="_copy" type="Boolean"/>
        <Parameter name="_nextOrd" type="Boolean"/>
        <ReturnType type="CM_ROROLaneDefnVoyage"/>
    </JadeMethod>
    <JadeMethod name="createLaneController" id="f465d33f-cb45-4247-8df9-2a1f61ec304d">
        <updating/>
        <source>createLaneController() updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
01 June 2011	cnwer1	Initial creation CCMS MES 1116

*/

vars

begin
	if self.myLaneController &lt;&gt; null then
		return;
	endif;
	
	if self.isTransient then 
		create self.myLaneController transient;
	else
		create self.myLaneController persistent;
	endif;
	self.myLaneController.setFromROROLaneDefn();
epilog

end;</source>
    </JadeMethod>
