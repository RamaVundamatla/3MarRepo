        <updating/>
        <source>setDimensions(_diameter: Decimal; _height: Decimal; _volume: Decimal; _rollingLength: Decimal; _length: Decimal; _grammage: Decimal; _width: Decimal) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 July 2022	navak20	ChangeRequest 53862: EUP - WMS - Damage Recording Extra Details

*/

vars

begin
	
