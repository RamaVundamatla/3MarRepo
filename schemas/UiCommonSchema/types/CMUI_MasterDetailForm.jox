    <JadeMethod name="getXMLSettingsForSave" id="0da881f1-763a-4f9a-9276-4b6d96f6a3e4">
        <updating/>
        <source>getXMLSettingsForSave(): String updating;
// ---------------------------------------------------------------------------
// Created:     30 March 2004	cnwth2
//
// Purpose:     //developer to inherit
//			 
// ----------   ----------  --------------------------------------------------
vars
	str			: String;
begin
	str := inheritMethod();

	str := str &amp; self.tblDataMaster.getXmlStrForColumns(true);
	str := str &amp; self.tblDataDetail.getXmlStrForColumns(true);	
		
	str := str &amp; self.XMLTag_SPLMAIN_RATIO.asXmlPrefix &amp;
					self.splMain.leftToRightRatio.String &amp;
				self.XMLTag_SPLMAIN_RATIO.asXmlSuffix &amp;
				self.XMLTag_SPLTOP_RATIO.asXmlPrefix &amp;
					self.splTop.leftToRightRatio.String &amp;
				self.XMLTag_SPLTOP_RATIO.asXmlSuffix;

	return str;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
