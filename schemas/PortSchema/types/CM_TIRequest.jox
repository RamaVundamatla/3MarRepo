    <JadeMethod name="isPlanOnPickup" id="f4a9a4bd-9989-43cd-9d48-41c272d10e4b">
        <source>isPlanOnPickup() : Boolean;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
23 Mar 2011	cnwrd1	Initial creation
06 Mar 2025 navma1  MTN-34179 MTN | Dead Lock (1081) on CM_WLEArray
*/

vars
	result : Boolean;
	wle : CM_WorkListEntry;
begin
	if self.allWorkListEntries.isEmpty then
		return false;
	endif;
	
	foreach wle in self.myJob.workListEntries discreteLock do //06.03.2025 navma1 #MTN-34179
		if wle.isPlanOnPickup then
			return true;
		endif;
	endforeach;
	
	return false;
	
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
