    <JadeMethod name="create" id="a4ecedfa-1e63-4044-a188-23b6208cf03f">
        <updating/>
        <source>create() updating;
// ---------------------------------------------------------------------------
// Created:     05 March 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
vars

begin
	self.searchValue := true;//as a default
	self.description := self.Operator_Equal;

end;</source>
