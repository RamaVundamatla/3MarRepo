    <JadeMethod name="allVMObjectsInsert" id="74ef1f10-54e0-4db2-9c44-d39de2575f02">
        <source>allVMObjectsInsert(_index: Integer; _allVMs: ViewModelObjectArray input);
// -----------------------------------------------------------------------------
// Created:		30 April 2002 by cnwka1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	---------------------------------------------
//
// -----------------------------------------------------------------------------
vars
	speciesHolder 	: SOPVM_SpeciesHolder;
	typeHolder 		: SOPVM_LogTypeHolder;
	treatHolder 	: SOPVM_LogTreatmentHolder;
	lengthHolder 	: SOPVM_LogLengthHolder;
begin
	inheritMethod(_index, _allVMs);
	
	create speciesHolder transient;
	speciesHolder.initializeMe(self.myObject, self.index + 1, self);
	speciesHolder.myForm := self.myForm;
	speciesHolder.allVMObjectsInsert(_index +1, _allVMs);
	
	create typeHolder transient;
	typeHolder.initializeMe(self.myObject, self.index + 1, self);
	typeHolder.myForm := self.myForm;
	typeHolder.allVMObjectsInsert(_index +2, _allVMs);
	
	create treatHolder transient;
	treatHolder.initializeMe(self.myObject, self.index + 1, self);
	treatHolder.myForm := self.myForm;
	treatHolder.allVMObjectsInsert(_index +3, _allVMs);

	create lengthHolder transient;
	lengthHolder.initializeMe(self.myObject, self.index + 1, self);
	lengthHolder.myForm := self.myForm;
	lengthHolder.allVMObjectsInsert(_index +4, _allVMs);
end;</source>
        <Parameter name="_index" type="Integer"/>
        <Parameter name="_allVMs" type="ViewModelObjectArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="allVMObjectsRemove" id="64836dc7-1651-4da3-8338-53d699e2dc5c">
        <updating/>
        <source>allVMObjectsRemove(_allVMs: ViewModelObjectArray input) updating;
// -----------------------------------------------------------------------------
// Created:		30 April 2002 by cnwka1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	---------------------------------------------
//
// -----------------------------------------------------------------------------
vars
	holder : CMUI_ViewModelObject;
begin
	foreach holder in self.allHolders do
		_allVMs.remove(holder);
	endforeach;
	inheritMethod(_allVMs);
end;</source>
        <Parameter name="_allVMs" type="ViewModelObjectArray" usage="input"/>
    </JadeMethod>
