    <JadeMethod name="setKPIVoyageBayMoves" id="528d1be5-58e5-4a50-84e8-04b28079fec0">
        <source>setKPIVoyageBayMoves(_clear : Boolean);
// ---------------------------------------------------------------------------
// Created:		19 September 2007 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
// 02/08/2011		cnwcs5	Tidy up when removing old KPI classes
//							CCMS MES RORO 1033 - RORO KPI - removed 'TRAN' from end of method name

vars
	coll	: ObjectArray;
	aJS 	: CM_VoyageJobSheet;
	aBay 	: CM_Bay;
begin
	if _clear then
		// delete all bay KPIs
		create coll transient;
		
		self.allVoyageKPIEntities.getKPIByType (KPI_Type_VoyageBayCrane, coll);
		
		coll.purge;
	endif;
	
	if self.myCellularVoyageStructure = null then
		return;
	endif;


	foreach aBay in self.myCellularVoyageStructure.allBayVoyagesByOrdinal discreteLock do
		aBay.setKPIVoyageBayCrane(); 					// PAR 25719 CCMS 1134 new 2010 KPIs
	endforeach;
epilog
	delete coll;
end;</source>
        <Parameter name="_clear" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setKPIVoyageDeckMoves" id="a4124314-c8ad-4206-8c76-8f262f65cf09">
        <source>setKPIVoyageDeckMoves(_clear :Boolean);
/*
Date		Who		Reason
10 August 2011	cnwcs5	Initial creation - CCMS MES 1033 / par 27951 RORO KPI
*/
vars
	coll	: ObjectArray;
	deck	: CM_Deck;
begin
	if _clear then
		// delete all deck KPIs
		create coll transient;
		
		self.allVoyageKPIEntities.getKPIByType (KPI_Type_VoyageDeckWorkPoint, coll);
		
		coll.purge;
	endif;
	
	if self.myROROStructure = null then
		return;
	endif;

	foreach deck in self.myROROStructure.allDecks discreteLock do
		deck.CM_DeckVoyage.setKPIVoyageDeckWorkPoint ();
	endforeach;
epilog
	delete coll;
end;</source>
        <Parameter name="_clear" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setKPIVoyageMoves" id="36070f9f-7000-4d22-9d1c-804debbf9f83">
        <updating/>
        <source>setKPIVoyageMoves() updating;
// ---------------------------------------------------------------------------
// Created:	06 June 2008 By Graeme Black cnwgb1 PAR 16900
// Purpose:	(Re)create the KPIs for a whole voyage
// ---------------------------------------------------------------------------
// 02/08/2011		cnwcs5	Tidy up when removing old KPI classes
// 04/08/2011		cnwcs5 	CCMS MES 1033 RORO KPI
vars
	kpi 			: CM_KPIVoyageTotals;
	aTransaction 	: CM_TITransaction;
begin
	kpi := self.getKPIByType(KPI_Type_Voyage).CM_KPIVoyageTotals;

	delete kpi;
	
	create kpi;
	
	kpi.setKPIForCreate(self, self.arrivedDT ); // NEW KPI 2010 CCMS SFW 1134
	
	foreach aTransaction in self.allTITransactionsByTypeDT discreteLock do
		if aTransaction.isKindOf(CM_ReleaseShip) or aTransaction.isKindOf(CM_ReceiveShip) then
			kpi.setFromTransaction( aTransaction ); // PAR 25719 CCMS 1134 new 2010 KPIs
		endif;
	endforeach;
	
	kpi.setNumLids();
	kpi.setHours();

	// PAR 25719 CCMS 1134 new 2010 KPIs. If we are regenerating then we will need to update the extra move KPI from the event transactions
	kpi.setFromEventTransactions();
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setKPIVoyageShiftMoves" id="174caf86-2d51-4732-b98d-4c4081a2f4fc">
        <source>setKPIVoyageShiftMoves(_clear : Boolean);
// ---------------------------------------------------------------------------
// Created:		01 May 2007 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
// 02/08/2011		cnwcs5	Tidy up when removing old KPI classes
// 04/08/2011		cnwcs5	CCMS MES 1033 RORO KPI - renamed method
vars
	coll		: ObjectArray;
	js 			: CM_VoyageJobSheet;
	shifts 		: CM_ShiftStartDateCodeDict;
begin
	if _clear then
		// delete all shift KPIs (LOLO and RORO)
		create coll transient;
		
		self.allVoyageKPIEntities.getKPIByType (KPI_Type_VoyageCraneShift, coll);
		self.allVoyageKPIEntities.getKPIByType (KPI_Type_VoyageWorkPointShift, coll);
		
		coll.purge;
	endif;
	
	create shifts transient;
	
	foreach js in self.allJobSheets discreteLock do
		shifts.clear(); 									// cnwrd1 par 22533 6.5.2010 

		self.getShiftsFromRangeForJobSheet(shifts, js); 	// cnwrd1 par 22533 6.5.2010 
		
		// update based on jobsheet (could be RORO or LOLO)
		js.setKPIVoyageJobSheetShift(shifts); 				// PAR 25719 NEW 2010 KPIs 
	endforeach;
epilog
	delete shifts;
	delete coll;
end;</source>
        <Parameter name="_clear" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setKPIVoyageTotalMovesTRAN" id="c9d06b92-df3d-430a-80e3-8c7a40e09777">
        <source>setKPIVoyageTotalMovesTRAN(_tran : CM_TITransaction);
/*
Purpose:	Update voyage totals for a single transaction

Date			Who		Reason
13 August 2008	concms1	Initial creation

*/

vars
	kpi : CM_KPIVoyageTotals;
	aTransaction : CM_TITransaction;
begin
	kpi := self.getKPIByType(KPI_Type_Voyage).CM_KPIVoyageTotals;
	
	// first create the cm_KPIVoyage instance if it does not exist
	if kpi = null then
		create kpi;
		kpi.setKPIForCreate(self, self.arrivedDT );
	endif;
	
	kpi.setFromTransaction (_tran);
epilog

end;</source>
        <Parameter name="_tran" type="CM_TITransaction"/>
    </JadeMethod>
    <JadeMethod name="setLoadStartDTStatus" id="7a987a43-dacf-4182-9ee1-b72709dab8c3">
        <updating/>
        <source>setLoadStartDTStatus(_loadStartDT : TimeStamp; _status : Integer) updating;
//--------------------------------------------------------------
//Created: 07 January 2003 By: cnwgd1
//--------------------------------------------------------------
// Changed On	By			Reason
// ----------	--------	------------------------------------
// 12/04/2023	navdap1		TFS 57362 CUX Changes to Outgoing Message Formats
vars
	
begin
	self.loadStartDT 	:= _loadStartDT;
	self.status			:= _status;

	// ### TFS 55215 22Nov2022 NAVPW1
	if self.status = Voyage_Status_Arrived then
		CMIF_TrxActionTransport@createAction(self, null, null, CMIF_TrxActionTransport.ProcessVoyageArrival, app.myPassport);		// TFS 57362
	elseif self.status = Voyage_Status_Departed then
		CMIF_TrxActionTransport@createAction(self, null, null, CMIF_TrxActionTransport.ProcessVoyageDeparture, app.myPassport);		// TFS 57362
	endif;
	// ### TFS 55215 22Nov2022 NAVPW1
	
	if self.loadEndDT.isValid
	and self.loadEndDT &lt;= self.loadStartDT then
		self.loadEndDT := null;
	endif;	
end;</source>
        <Parameter name="_loadStartDT" type="TimeStamp"/>
        <Parameter name="_status" type="Integer"/>
    </JadeMethod>
