    <JadeMethod name="doCmbDebtorBuild" id="e55d08f0-39b3-4066-855d-e9a9b0cfda1c">
        <source>doCmbDebtorBuild( );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 March 2023  navmv20 TFS 56128 Task 56129: UI - Manual Invoice Lines - Multi TI Invoice Line Type

*/
vars

	debtor : CM_Debtor;
	theCombo : CMUI_ComboBox;
begin
	theCombo := self.cmbDebtor;
	theCombo.clear;
	theCombo.sorted := true;
	
	foreach debtor in app.myRoot.myRootCompany.debtors where not debtor.isSuspended do
		theCombo.addItem(debtor.name);
		theCombo.itemObject[theCombo.newIndex] := debtor;
	endforeach;

	theCombo.listIndex := 1;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doCmbInvoiceBuild" id="518d0c01-507d-40d8-9244-d7ba429f0e7e">
        <source>doCmbInvoiceBuild(_debtor : CM_Debtor);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 March 2023  navmv20 TFS 56128 Task 56129: UI - Manual Invoice Lines - Multi TI Invoice Line Type

*/
vars
	theCombo : CMUI_ComboBox;
	anInvoice : CM_Invoice;
	idx : Integer;
	error : Boolean;
begin
	theCombo := self.cmbInvNumber;
	theCombo.clear;
	theCombo.sorted := true;
	
	if _debtor = null then
		foreach anInvoice in self.myCurrentBank.allInvoices discreteLock, reversed 
			where anInvoice.status = CM_Invoice.INVOICE_OPEN 
			or anInvoice.status = CM_Invoice.INVOICE_PENDING 
			or anInvoice.status = CM_Invoice.INVOICE_DISPUTED
			or anInvoice.status = CM_Invoice.INVOICE_SUSPENSE
		do 
			if idx &gt;= 32000 then
				error := true;
				break;
			endif;

			theCombo.addItemObject(anInvoice.sequenceNum.String, anInvoice);	
			idx := idx + 1;
		endforeach;
	
	else
		foreach anInvoice in _debtor.allInvoices discreteLock, reversed 
			where anInvoice.status = CM_Invoice.INVOICE_OPEN 
			or anInvoice.status = CM_Invoice.INVOICE_PENDING
			or anInvoice.status = CM_Invoice.INVOICE_POSTED_DRAFT  // ### JIRA 35468 31JUL2025 NAVAB1
			or anInvoice.status = CM_Invoice.INVOICE_DISPUTED
			or anInvoice.status = CM_Invoice.INVOICE_SUSPENSE
		do 
			if idx &gt;= 32000 then
				error := true;
				break;
			endif;

			theCombo.addItemObject(anInvoice.sequenceNum.String, anInvoice);	
			idx := idx + 1;
		endforeach;
	endif;
	
	if error then
		app.msgBox("You have more than 32,000 invoices with a status of OPEN or PENDING." &amp; Cr 
					&amp; "It is recommended that you set the pending invoices to CLOSED", "Invoice Status Problem", MsgBox_Exclamation_Mark_Icon);
	endif;
	
epilog

end;</source>
        <Parameter name="_debtor" type="CM_Debtor"/>
    </JadeMethod>
    <JadeMethod name="doCmbLineTypeBuild" id="d8e83d16-f6a0-4e80-8e2e-354d8845c41f">
        <source>doCmbLineTypeBuild();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
31 Jul 2023	navmv20 Bug 58739: LNX - Invoice Line Type Combo Box
05 Oct 2023 navhl20 Bug 60768: CPL - Invoice Line New - Invoice Line Types "Not Available for Entry" are showing
*/

vars
	lineType : CM_InvoiceLineDesc;
	theCombo : CMUI_ComboBox;
begin
	theCombo := self.cmbLineType;
	theCombo.clear;
	theCombo.sorted := true;
	
	if self.myCurrentBank &lt;&gt; null then
		foreach lineType in self.myCurrentBank.invoiceLineDescriptors do
			if not lineType.isNotAvailableForEntry then			  //05.10.2023 navhl20 #60768
				theCombo.addItem(lineType.getComboDescription()); // ### TFS BUG 59913 31AUG2023 NAVAB1    narration);
				theCombo.itemObject[theCombo.newIndex] := lineType;
			endif;
		endforeach;
	endif;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doMnuColumnOrganiserClick" id="857aac2c-0a98-487f-be39-b377e04210d1">
        <source>doMnuColumnOrganiserClick(menuItem : MenuItem);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 March 2023  navmv20 TFS 56128 Task 56129: UI - Manual Invoice Lines - Multi TI Invoice Line Type

*/

vars
	tbl  	: CM_DataTable;
	iter 	: Iterator;
	ti   	: CM_TrackedItem;
	count,
	idx	 	: Integer;
begin
	tbl := menuItem.userObject.CM_DataTable;

	self.tblResults.showColumnOrganiserFrm(self.myTerminal, self.tblResults.allTblDataEntRows);
	
	iter := self.allTIs.createIterator();
	self.tblResults.setMyDataClass(CM_TrackedItem);

	while iter.next(ti) do
		count := count + 1;
		idx := self.tblResults.updateItemObject(ti, self.colorRow1, self.colorRow2, app.myPassport);
		self.tblResults.accessRow(idx).itemObject := ti;
	endwhile;
epilog

end;</source>
        <Parameter name="menuItem" type="MenuItem"/>
    </JadeMethod>
    <JadeMethod name="doMsgLineTypeBuild" id="703dd4a3-1452-44f1-ae4c-cedfa18e3058">
        <source>doMsgLineTypeBuild();
/*
Purpose:			

Date		Who		Reason
10 Mar 2023 navmv20 TFS 56128 Task 56129: UI - Manual Invoice Lines - Multi TI Invoice Line Type
05 Oct 2023 navhl20 Bug 60768: CPL - Invoice Line New - Invoice Line Types "Not Available for Entry" are showing
*/

vars
	invoicelines : CM_InvoiceLineDescSet;
	invoiceline : CM_InvoiceLineDesc;
begin
	
	if self.myCurrentBank &lt;&gt; null then
		create invoicelines transient;
		foreach invoiceline in self.myCurrentBank.invoiceLineDescriptors discreteLock do
			if not invoiceline.isNotAvailableForEntry then			//05.10.2023 navhl20 #60768
				invoicelines.add(invoiceline);
			endif;
		endforeach;
	endif;
	
	self.msgInvLineType.myAvailableListBox.sorted 	:= true;
	self.msgInvLineType.mySelectedListBox.sorted 	:= true;
	self.msgInvLineType.setupControl(null, invoicelines, INV_InvoiceLineNew::getLineTypeDescription.name);
	self.msgInvLineType.availableHeading	:= app.getErrorString(Available);
	self.msgInvLineType.selectedHeading	:= app.getErrorString(Selected);
	self.msgInvLineType.myBaseForm	:= self;
	self.msgInvLineType.setSelected(null);
	self.msgInvLineType.multiSelect :=  ListBox.MultiSelect_Extended; // ### TFS BUG 58783 22JUN2023 NAVAB1


epilog
	delete invoicelines;
end;</source>
    </JadeMethod>
    <JadeMethod name="doSave" id="fb9ca060-26ff-4057-99d6-5ffa9cc6eea8">
        <updating/>
        <source>doSave(
	   _saveNext : Boolean //31/07/2023 navmv20 Bug 58741
	   ) updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 March 2023  navmv20 TFS 56128 Task 56129: UI - Manual Invoice Lines - Multi TI Invoice Line Type
31 July 2023   navmv20 Bug 58741: LNX - Invoice Line - Save Next Button

*/
vars
	manController   : CMIF_InvoiceLineManual;
	theTable 		: CM_DataTable;
	realInvLine,
	pxyInvLine 	    : CM_InvoiceLine;
	theReturn 	    : Integer;
	ls 			    : Boolean;
	tmpQty 			: Real;
	cargoId         : String;
	startTS			: TimeStamp;
begin
 	theTable := self.tblResults;
		
	create manController transient;
	manController.quantity 			:= self.txtQuantity.text.String.asRealJMT();
	manController.myInvoice 		:= self.cmbInvNumber.listObject.CM_Invoice;
	manController.chargeTime.setDate(self.mskStartDT.getDate());
	manController.allInvoiceLineTypes.clear();
	manController.useCalcTypeForQuantity := self.chkQuantity.value; // ### TFS BUG 58787 22JUN2023 NAVAB1
	manController.remarks := self.txtRemarks.text.String;	// ### JIRA 33007 03DEC2024 NAVAB1

	self.msgInvLineType.getSelected(manController.allInvoiceLineTypes);
	manController.allTrackedItems.clear();
	self.allTIs.copy(manController.allTrackedItems);
	
	if manController.allTrackedItems.size() &gt; 1 or manController.allInvoiceLineTypes.size() &gt; 1 then
		if app.msgBox(app.getErrorString2(Pleas_confi_invLines_items,manController.allInvoiceLineTypes.size().String,
						manController.allTrackedItems.size().String),app.getErrorString(Confirmation),MsgBox_OK_Cancel) = MsgBox_Return_Cancel then
			global.beep;
			return;
		endif;
	endif;
	
	while true do
		app.myTrxCA.trxCreateInvoiceLineManual(manController,realInvLine, app.myPassport);
		if app.myPassport.trxCompletedOK then
			global.beep;
			break;
		else
			theReturn := app.showErrorWarningDialog("Manual Invoice Line", app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
				  theReturn = IDOK then
				  // there must have just been warnings that the user has acknoledged so ..
				  app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			return;
		endif;
			
		break;
	endwhile;
	
	//31/07/2023 navmv20 Bug 58741 - start
	//self.tblResults.clear();
	if _saveNext then
		self.cmbLineType.listIndex := -1;
		self.msgInvLineType.setSelected(null);
		self.txtQuantity.text := "1.0000";
		self.txtRemarks.text := null;	// ### JIRA 33007 03DEC2024 NAVAB1
	else
	//31/07/2023 navmv20 Bug 58741 - end
		self.unloadForm();
	endif; //31/07/2023 navmv20 Bug 58741
	
epilog
	app.cmsEndLoad(ls);
	delete manController;
	delete pxyInvLine;
end;</source>
        <access>protected</access>
        <Parameter name="_saveNext" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doTblSelectorContMenu" id="306e2502-0aa1-4339-be23-2251ba8b4f8c">
        <updating/>
        <source>doTblSelectorContMenu(cntrl: Table input; conwin: Window input; mouse: Boolean; x: Integer; y: Integer):Boolean updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 March 2023  navmv20 TFS 56128 Task 56129: UI - Manual Invoice Lines - Multi TI Invoice Line Type

*/

vars
	canEdit		: Boolean;
	x1,
	y1			: Real;
begin
	x1 := x;
	y1 := y;
	if (not mouse) then
	    x1 := 1;
	    y1 := 1;
	endif;
	conwin.windowToScreen(x1, y1);
	self.screenToWindow(x1, y1);
	self.mnuColumnOrganizer.visible := true;
	self.mnuColumnOrganizer.userObject := self.tblResults;
	self.popupMenu(self.mnuContextMenu, x1.Integer, y1.Integer);
	return false;

end;</source>
