    <JadeMethod name="doTableContext" id="92db2bf2-19be-44f1-8081-16fe1da621e5">
        <updating/>
        <source>doTableContext(cntrl: Table input; conwin: Window input; mouse: Boolean; x: Integer; y: Integer):Boolean updating;
//--------------------------------------------------
// Created:	17 October 2003 By: cnwgd1
// 02 Mar 2021	cnwma1  ChangeRequest 50854: ASPA - Hold Planning Change Planned Amount
// 26 Aug 2025	navdap1	MTN-35615 ENS | Bulk Creation of Yard Allocations
// 28 Oct 2025	jlizm1	MTN 36255 Rotabox Assign Release To Vessel
//--------------------------------------------------
vars
	xLeft 	: Real;
	yTop	: Real;
	loadTo  : CM_LocationsController;
	cargoSelected : Boolean;		// MTN-35615
begin

	xLeft := x;
	yTop := y;

	self.mnuCargoCreateNew.caption := app.getErrorString(Create_cargo);
	
	

	if cntrl&lt;&gt; null then
		self.mnuCargoCreateNew.helpKeyword := cntrl.name; // TFS 3218 store the table so that we can send a different location to the create new cargo screen
		if self.mnuCargoCreateNew.helpKeyword = self.tblOnship.name then
			self.mnuCargoCreateNew.caption := app.getErrorString(Create_cargo_voyage);
		elseif self.mnuCargoCreateNew.helpKeyword = self.tblOnsite.name then
			self.mnuCargoCreateNew.caption := app.getErrorString(Create_cargo_terminal);
		endif;

	endif;
	
	self.mnuCargoTestAp.visible := cntrl = self.tblOnship;		//17 Jul 2014	NDL	Par 34559
	self.mnuCargoTestAPChild.visible := cntrl = self.tblOnship;	//17 Jul 2014	NDL	Par 34559
	self.mnuAssignRels.visible := false;						//16 Jan 2017	NDL	TFS 3190/2876
	self.mnuResDetail.visible := false;							//16 Jan 2017	NDL	TFS 3190/2876
	self.mnuUnassignRels.visible := false; 						// TFS 3190
	self.mnuPrenote.visible := cntrl = self.tblPreNote;			//09Feb2022 navsp1 TFS#52785
	conwin.windowToScreen(xLeft, yTop);
	self.screenToWindow(xLeft, yTop);
	self.mnuVoyageContext.userObject := cntrl;	
	
	// MTN-35615 Hide / show Bulk YA menu items
	if app.getMyUser.canDo(self.myTerminal, PmAdmBulkYAMaint) then
		cargoSelected := cntrl.isKindOf(CM_BaseTable) and not cntrl.CM_BaseTable.allSelectedObjects.isEmpty;
		self.mnuBulkYAExport.visible := (cntrl = self.tblOnsite or cntrl = self.tblOnship or cntrl = self.tblPreNote) and cargoSelected;
		self.mnuBulkYAExport.userObject := cntrl;
		self.mnuBulkYAImport.visible := (cntrl = self.tblOnsite or cntrl = self.tblOnship) and cargoSelected;
		self.mnuBulkYAImport.userObject := cntrl;
	else
		self.mnuBulkYAExport.visible := false;
		self.mnuBulkYAImport.visible := false;
	endif;
	// MTN-35615 end
	
	//16 Jan 2017	NDL	TFS 3190/2876
	if cntrl = self.tblOnship then
		loadTo := self.cmbLoadLocation.listObject.CM_LocationsController;
		if loadTo &lt;&gt; null 
		and (loadTo.isGeneralCargoController()
		or loadTo.isShipBlockStack) then //.i.e. we have a location in a hold
			self.doContextMenuAssignRelease( loadTo.CM_VoyageController );
		endif;
	endif;
	
	self.doBuildMnuForTI();		
	self.doBuildMnuSeparators();
	self.doBuildChangeMoveMenu();                                        //01.03.2021 cnwma1 #50854
	self.popupMenu(self.mnuVoyageContext, xLeft.Integer, yTop.Integer);

	return false;
end;</source>
        <Parameter name="cntrl" type="Table" usage="input"/>
        <Parameter name="conwin" type="Window" usage="input"/>
        <Parameter name="mouse" type="Boolean"/>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doTableDblClick" id="804e1067-42ee-48c2-a94b-7f033b8935ed">
        <updating/>
        <source>doTableDblClick(table: Table input) updating;
//--------------------------------------------------
// Created:	17 October 2003 By: cnwgd1
//--------------------------------------------------
// Changed On	By			Reason
// ----------	--------	---------------------------------------------
// 12/05/2010	cnwdap1		CCMS 1116 Tranship changes
// 12/12/2023	jlizm1		TFS 61665 Display RTL Reason
//
vars
	ti : CM_TrackedItem;
	dataTable : CM_DataTable;
	colIdx : Integer;
	reason : String;
begin
	ti := self.myCurrentTrackedItem;//cnwrs1 Mar 2007 par13541
	dataTable := table.CM_DataTable;//06 Jan 2014	NDL	Par 32501
	
	if table.row = table.fixedRows then
		dataTable.resortTableByColumn(table.column);
		self.colourTableRows( dataTable );
		
	elseif table.row &gt; table.fixedRows then
		colIdx := dataTable.getColumnByRowName(ETRow_ReadyToLoad);
		if colIdx &gt; 0 and table.column = colIdx then
			if not ti.evaluateReadyToLoadReason(reason) then
				app.msgBox(reason, app.getErrorString(Not_RTL_reason), MB_OKONLY);
			endif;
			return;
		endif;
		
		self.myAssistant.showCargoEnquiryForm(ti, self.myMasterMenuAction, true, false);
	endif;
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doTableDisplayContextMenu" id="8ec08a7b-046f-4fa0-b16f-6c65ff477f5b">
        <updating/>
        <source>doTableDisplayContextMenu( _frame : CMUI_Frame; _x : Real; _y : Real):Boolean updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
20 November 2009	cnwndl1	Initial creation	CCMS 1031

*/

vars

	lLeft : Real;
	tTop : Real;
	frame : CMUI_Frame;
	statusLine : CMUI_StatusLine;
	parentFrame : Frame;
	container, parentContainer : JadeDockContainer;
	
begin

	frame := _frame;
	statusLine := _frame.parent.CMUI_StatusLine;
	parentFrame := statusLine.parent.Frame;
	container := parentFrame.parent.JadeDockContainer;
	parentContainer := container.parent.JadeDockContainer;
	lLeft := _x;
	tTop := _y;
	
	frame.windowToScreen(lLeft, tTop);
	self.screenToWindow(lLeft, tTop);   // convert x, y relative to form

	self.doBuildMenuDisplaySub(DISPLAY_MODE_ACTUAL, PicDisplayModeI, DISPLAY_MODE_ACTUAL_CAPTION,frame);
	if _frame &lt;&gt; self.frmDispPreNote then	// prenotes can't be queued
		self.doBuildMenuDisplaySub(DISPLAY_MODE_QUEUE, PicDisplayModeQ, DISPLAY_MODE_QUEUE_CAPTION,frame);
	else
		if self.mnuStatusDisplay.getMenuItem(DISPLAY_MODE_QUEUE) &lt;&gt; null then
			self.mnuStatusDisplay.getMenuItem(DISPLAY_MODE_QUEUE).visible := false;
		endif;
	endif;
	self.doBuildMenuDisplaySub(DISPLAY_MODE_PLAN, PicDisplayModeP, DISPLAY_MODE_PLAN_CAPTION,frame);
	if container.isFloating then
		// lLeft and tTop are already relative to current position
	else
		tTop := statusLine.top + parentContainer.top /*+ self.frmMain.top */+ 60;
	endif;
	
	self.myActiveDisplayMenuFrame := _frame;
	self.popupMenu(self.mnuStatusDisplay, lLeft.Integer, tTop.Integer);
	
epilog

	return true;
	
end;</source>
        <Parameter name="_frame" type="CMUI_Frame"/>
        <Parameter name="_x" type="Real"/>
        <Parameter name="_y" type="Real"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
