end;</source>
        <Parameter name="_types" type="IntegerArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getEDIDataTypeChildren" id="9f702ae5-5279-4aac-9821-e097b4e1cbea">
        <source>getEDIDataTypeChildren(_ediDataType: Integer; _childrenDataTypes: IntegerArray input);
/*****************************************************
Author		: jlika1 (Karen Alexander)
Date		: 27 October 2022
TFS#		: 54892
Function	:

*** Changes ***
Date			Name		TFS#		Description

****************************************************/

begin
	if _ediDataType = EDIDataType_JMTInternal then
		_childrenDataTypes.add(EDIDataType_Voyage);
	elseif _ediDataType = EDIDataType_Voyage then
		_childrenDataTypes.add(EDIDataType_Port);
		_childrenDataTypes.add(EDIDataType_VoyageRecCutoff);		
		_childrenDataTypes.add(EDIDataType_VoyageMovement);
		_childrenDataTypes.add(EDIDataType_VoyageVessel);
	endif;

end;</source>
        <Parameter name="_ediDataType" type="Integer"/>
        <Parameter name="_childrenDataTypes" type="IntegerArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getEDITIType" id="eddf7952-012a-4732-b1e5-8900fb32a518">
        <source>getEDITIType(_ediDataType: Integer): Class;
/*****************************************************
Author		: jlika1 (Karen Alexander)
Date		: 26 October 2022
TFS#		: 54892
Function	:

*** Changes ***
Date			Name		TFS#		Description

****************************************************/


begin
	if _ediDataType =  EDIDataType_Voyage then
		return CM_EDIQshipsVoyageTI;
	elseif _ediDataType = EDIDataType_VoyageMovement then
		return CM_EDIQshipsMovementTI;
	elseif _ediDataType = EDIDataType_VoyageVessel then
		return CM_EDIQshipsVesselTI;
	endif;
	
	return inheritMethod(_ediDataType);
end;</source>
        <Parameter name="_ediDataType" type="Integer"/>
        <ReturnType type="Class"/>
    </JadeMethod>
