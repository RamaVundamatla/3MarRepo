        <updating/>
        <source>myRow(set: Boolean; _value: CM_RowAreaRow io) mapping, updating;
// ---------------------------------------------------------------------------
// Created:     13 August 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	if set and _value &lt;&gt; null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'This end of the inverse is only for setting to null to remove');
	endif;

end;</source>
