    <JadeMethod name="doProcessSelectedGate" id="6c621f6f-cd8a-4a3a-9998-7f2e8799e99b">
        <updating/>
        <source>doProcessSelectedGate() updating;
/*
Purpose:		Process the selected gate	

Parameters:			

Return Value:		

Date		Who		Reason
02 February 2010	conkc1	Initial creation

*/
vars
	gate : CM_Gate;
begin
	if self.cmbDefaultGate.listIndex &gt; 0 and self.cmbDefaultGate.listIndex &lt;= self.cmbDefaultGate.listCount then
		gate := self.cmbDefaultGate.listObject.CM_Gate;
	else
		return;
	endif;
	
	self.getGateInformation(gate);

	self.myGate := gate;
	if self.myInterTerminalConfig &lt;&gt; null then
		self.cmbDefaultLane.listIndex := self.cmbDefaultLane.findObject(self.myInterTerminalConfig.myLaneController);
		if self.cmbDefaultLane.listIndex &gt; 0 then
			self.cmbDefaultLane.click(self.cmbDefaultLane);
		endif;
	endif;

epilog

end;</source>
    </JadeMethod>
