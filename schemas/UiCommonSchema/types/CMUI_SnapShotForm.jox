    <JadeMethod name="doNotableClear" id="16654620-0870-4a07-8f4e-0296dc525769">
        <source>doNotableClear();
// ---------------------------------------------------------------------------
// Created:		23 February 2010 cnwjo3
//
// Purpose:		par 21915.  Each form should implement doNotableClear without an inheritMethod();
//
vars
	removedNotification : Integer;
	anObject : Object;
begin

	foreach anObject in self.allNotableObjects do
		/*if anObject.isKindOf(____OBJECT TYPE____) then
			endNotification(anObject, self.myTerminal.getTerminalEvent(____EVENT_NAME_____));
			removedNotification := removedNotification + 1;
		endif;*/
	endforeach;

	validateNotificationRemoval(removedNotification,self.allNotableObjects.size);
	
	self.allNotableObjects.clear;
end;</source>
    </JadeMethod>
    <JadeMethod name="doQuery" id="d89d1077-7aa1-4725-89f9-5d1b3234e44c">
        <updating/>
        <source>doQuery() updating;
/*
Purpose:	TFS 40336		
Date				Who			Reason
SEPTEMBER 2018		CNWAB1		Initial creation
*/
vars
	snapShot 		: CM_SnapShot;
	rowIdx			: Integer;
	tbl				: CM_DataTable;
	bckColour		: Integer;
begin
	tbl := self.tblData;

	tbl.rows := tbl.fixedRows;
	
	foreach snapShot in self.allSnapShots do
		rowIdx := tbl.addItemObject(snapShot, snapShot.getAttributeStringForDefArray(tbl.allTblDataEntRows));
		
		if not self.isFromItemSelector() then 
			bckColour := snapShot.getDisplayRowColour();
			if bckColour &gt; 0 then
				tbl.accessRow(rowIdx).backColor := bckColour;
			endif;
		
		endif;
		self.armNotesForObject(snapShot);

	endforeach;

end;</source>
    </JadeMethod>
