    <JadeMethod name="setModeOnBackFrames" id="e410df78-e1b8-4f39-b9c6-5a1ba030d5be">
        <source>setModeOnBackFrames(_mode : Integer);
// ---------------------------------------------------------------------------
// Created:     07 January 2011 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	obj : Object;
	layerFrame : CMUI_PointDrawingFrame;
begin
	
	foreach obj in self.allBackgroundFrames discreteLock do
		layerFrame := obj.CMUI_PointDrawingFrame;
		
		layerFrame.mode := _mode;
	endforeach;

epilog

end;</source>
        <Parameter name="_mode" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setScale" id="c4395022-0916-491c-9d69-5693c5f7ae57">
        <updating/>
        <source>setScale(_newScale : Decimal) updating;
// ---------------------------------------------------------------------------
// Created:     28 January 2011 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------
constants
	MaxZoom = 1.5;
	MinZoom = .5;
vars
	newScale, pc : Decimal[12,2];
begin

	newScale := _newScale;

	self.btnZoomPlus.enabled := (newScale&lt;&gt; MaxZoom);
	self.btnZoomMinus.enabled := (newScale&lt;&gt; MinZoom);
	
	pc := (100/(1/newScale));
	self.setScaleOnFrames(newScale);
//	self.lblScale.caption := " " &amp; app.getErrorString(Scale) &amp; ": " &amp; newScale.String &amp; " (" &amp; pc.asStringJMTWithPrecision(2, false) &amp; "%)";
	self.lblScale.caption := " " &amp; pc.asStringJMTWithPrecision(2, false) &amp; "%";
	self.doDrawLabelV();
	self.doDrawLabelH();
	self.doDrawLayers();
	self.doDrawCurrentPoly4CurrentLayer();
	
	// PAR 29975 - cnwmc5
	self.frmScrollable.myHScroll.zOrder(1);
	self.frmScrollable.myVScroll.zOrder(1);
	self.frmScrollable.myTopLeftFillerFrame.zOrder(1);

epilog

end;</source>
        <Parameter name="_newScale" type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="setScaleOnFrames" id="fccc7abc-d57e-4b2f-bd82-e31dbcee8bd9">
        <updating/>
        <source>setScaleOnFrames(_scale : Decimal) updating;
// ---------------------------------------------------------------------------
// Created:     07 January 2011 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	obj : Object;
	layerFrame : CMUI_PointDrawingFrame;
begin
	self.frmScrollable.myDrawingFrame.CMUI_PointDrawingFrame.scaleFactor := _scale;
	self.scaleFactor := _scale;
	
	foreach obj in self.allBackgroundFrames reversed, discreteLock do
		layerFrame := obj.CMUI_PointDrawingFrame;
		layerFrame.scaleFactor := _scale;

	endforeach;

epilog

end;</source>
        <Parameter name="_scale" type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="setShowTextOnFrames" id="ca04ee75-e253-430e-ac76-d2dd950ee4fc">
        <updating/>
        <source>setShowTextOnFrames() updating;
/*
Purpose:			
Date				Who			Reason
APRIL 2011		CNWAB1		Initial creation
*/

vars
	obj : Object;
	layerFrame : CMUI_PointDrawingFrame;
	showText : Boolean;
begin
	showText := self.btnShowText.value;
	
	self.frmScrollable.myDrawingFrame.CMUI_PointDrawingFrame.showText := showText;
	
	foreach obj in self.allBackgroundFrames reversed, discreteLock do
		layerFrame := obj.CMUI_PointDrawingFrame;
		layerFrame.showText := showText;

	endforeach;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setTableDataFromOrganiser" id="f526a657-5988-4c00-b966-5b3434d4c5bc">
        <updating/>
        <source>setTableDataFromOrganiser(_theTable: CM_DataTable input) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
15 April 2011	cnwer1	Initial creation CCMS 1031

*/

vars

begin
	
	if _theTable = self.tblDeckItems then
		self.tblDeckItems.clearAllData;
		self.loadDeckItems();
	
	else

		inheritMethod(_theTable);
	endif;
epilog

end;</source>
        <Parameter name="_theTable" type="CM_DataTable" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setupDeckItemTable" id="ac8e55ca-fd67-4c3a-9440-b4db4096ac84">
        <source>setupDeckItemTable();
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
12 April 2011	cnwer1	Initial creation CCMS 1031

*/

vars
	entTableDef : EntTableDef;
begin
	self.tblDeckItems.selectMode:= Table.SelectMode_WholeRows;
	self.tblDeckItems.disallowColumnSorter	:=	true;
	entTableDef:=app.myController.getEntTableDef(ETDef_DeckItem);
	self.tblDeckItems.setTblDataEntRowsFromDef(entTableDef);
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setupForm" id="033fe3e0-d1b4-40de-9e71-7871e4851c21">
        <updating/>
        <source>setupForm() updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
24 March 2011	cnwer1	Initial creation

*/

vars
	pc : Decimal[12,2];
begin
	self.rulerHPixels := 3000;
	self.rulerVPixels := 1500;
	
	inheritMethod();
	self.toolbarStyle	:=	self.ToolbarStyle_ShowNoHide;
	self.showToolbar	:=	true;
	
	self.cmbDeck.style:=ComboBox.Style_DropDownList;
	self.txtMaxTier.maxLength:=1;
	self.scaleFactor := 1;

	pc := 100;

	self.setCaption(null);
	
	self.fldDefinition.left:=0;
	self.fldDefinition.width:= self.clientWidth;
	self.fldDefinition.height:=self.clientHeight - self.frmToolbar.clientHeight-1;
	self.fldDefinition.top:=self.frmToolbar.top + self.frmToolbar.clientHeight +1 ;
	
	self.lblArea.width := 125;
	self.frmTBArea.width := 135;
	self.minimumHeight := 550;
	self.minimumWidth := 450;

	self.setNavigatorHeading(self.caption);
	self.frmScrollable.myDrawingFrame.transparent := true;
	self.frmScrollable.myDrawingFrame.name := "RORO"; //##### DO NOT TRANSLATE
	self.frmScrollable.myDrawingFrame.CMUI_PointDrawingFrame.mode := CMUI_PointDrawingFrame.Mode_DisplayOnly;
	self.frmScrollable.transparent := true;
	self.frmScrollable.myHLabels.backColor := Yellow;
	self.frmScrollable.myVLabels.backColor := Blue;
	self.frmScrollable.myTopLeftFillerFrame.autoRedraw := true;
	self.frmScrollable.myTopLeftFillerFrame.drawPictureAt(self.picJade.picture,0,10);
	self.frmScrollable.myTopLeftFillerFrame.backColor := White;
	self.frmScrollable.myTopLeftFillerFrame.visible := true;
	self.frmScrollable.myTopLeftFillerFrame.move(0,0,50,70);
	
	
	self.frmScrollable.myParentForm := self;
	self.frmScrollable.myHLabels.zOrder(1);
	self.frmScrollable.myVLabels.zOrder(1);
	self.frmScrollable.myTopLeftFillerFrame.zOrder(1);
	self.frameLabelLineH.zOrder(1);
	self.frameLabelLineV.zOrder(1);
	self.frmScrollable.myHScroll.zOrder(1);
	self.frmScrollable.myVScroll.zOrder(1);

	// PAR 27513
	self.frameLabelLineH.ignoreSkin := true;
	self.frameLabelLineV.ignoreSkin := true;
	self.frmScrollable.myHLabels.ignoreSkin := true;
	self.frmScrollable.myVLabels.ignoreSkin := true;
	self.frmScrollable.myTopLeftFillerFrame.ignoreSkin := true;
	self.frmScrollable.myTopLeftFillerFrame.zOrder(1);
	
	self.doDrawLabelV();
	self.doDrawLabelH();
	self.initFrmLabelLine();
	self.setScale(self.scaleFactor);
	self.mnuGrphMain.visible := false; // PAR 27517
	
	self.getXMLSettingsForSetup(); // PAR 27512
	self.doResize(); // PAR 28014
		
	self.viewModeOnly := (not app.myCurrentUserCan(null, PmShipBayDefMaint)); // TFS 2101
	
	// TFS 2198 CNWAB1
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		self.btnNewDeck.enabled:= false;
		self.btnNewDeckItem.enabled:= false;
		self.btnEditDeckItem.enabled:= false;
		self.btnNewSubDeck.enabled:= false;
		self.btnEditDeck.enabled:= false;
		self.btnDeleteDeck.enabled:= false;
		self.btnCopyDeck.enabled:= false;
		self.btnDelDeckItem.enabled:= false;
		self.mnuDeleteDeckItem.enabled:= false;
		self.mnuNewDeckItem.enabled:= false;
		
	endif;


epilog

end;</source>
    </JadeMethod>
