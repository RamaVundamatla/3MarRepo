    <JadeMethod name="checkMoveMethodChanged" id="aad94c23-7b02-4df9-8e2d-c42e714ffadd">
        <updating/>
        <source>checkMoveMethodChanged(_ta : CM_TerminalArea) protected, updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
02 March 2011	cnwer1	Initial creation

*/

vars
	newMultiRule 	: CM_RTQueueMultiRule;
	newMoveMethod : CM_RTMoveMethod;
	moveMethodRule : CM_RTMoveMethodRule;
	newLC : CM_LocationsController;
	iter 	: Iterator;
begin

	if _ta = null then
		return;
	endif;
	
	newLC:=_ta.allLocationsControllers.first;
	
	//epr par 32440 12/3/15
	if self.myOrigSourceLoc = null then
		return;
	endif;
	
	newMultiRule := self.myTerminal.getRTQueueMultiRule( self.myOrigSourceLoc,newLC);
	if newMultiRule &lt;&gt; null then
		if newMultiRule.isRuleRTGToRTGSameLane( self.myOrigSourceLoc,newLC) then
			newMoveMethod:= app.myRoot.allRTMoveMethods[RTMoveMethod_22];
		else
			moveMethodRule:=newMultiRule.getDefaultRTMoveMethodRule;
			if moveMethodRule &lt;&gt; null then
				newMoveMethod :=moveMethodRule.myRTMoveMethod;
			endif;
		endif;
	endif;
	//write self.myCurrentMoveMethod;
	if self.myCurrentMoveMethod &lt;&gt; null and newMoveMethod = self.myCurrentMoveMethod then
		return;	
	endif;
	
	self.cmbMoveMethod.clear;
	if self.myOrigMoveMethod &lt;&gt;  newMoveMethod  then
		// make the move method frame visible and  populate the combo with valid move methods
		self.frmMoveMethod.visible:=true;
		self.myCurrentMoveMethod:=newMoveMethod;
		
		self.loadMoveMethodCombo(newLC);
		self.height:=self.frmDetails.clientHeight + self.frmMoveMethod.clientHeight + self.btnCancel.clientHeight + 40;
	else
		self.frmMoveMethod.visible:=false;
		self.height:=self.frmDetails.clientHeight + self.btnCancel.clientHeight ;
	endif;
	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_ta" type="CM_TerminalArea"/>
    </JadeMethod>
