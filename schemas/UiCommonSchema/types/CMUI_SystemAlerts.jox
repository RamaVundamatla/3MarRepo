	btnEditRemote.translateBubbleHelp(Xlat_0000978, locale);
	btnEditRemote.translateCaption(Xlat_0000992, locale);
	btnErrors.translateBubbleHelp(Xlat_0000979, locale);
	btnErrors.translateCaption(Xlat_0000993, locale);
	btnExport.translateBubbleHelp(Xlat_0004967, locale);
	btnExport.translateCaption(Xlat_0004968, locale);
	btnHideSearcher.translateCaption(Xlat_0005320, locale);
	btnInfo.translateBubbleHelp(Xlat_0000980, locale);
	btnInfo.translateCaption(Xlat_0000994, locale);
	btnPrint.translateBubbleHelp(Xlat_0000981, locale);
	btnPrint.translateCaption(Xlat_0000995, locale);
	btnQuery.translateCaption(Xlat_0005321, locale);
	btnReefer.translateBubbleHelp(Xlat_0000982, locale);
	btnReefer.translateCaption(Xlat_0000996, locale);
	btnRefresh.translateBubbleHelp(Xlat_0000983, locale);
	btnRefresh.translateCaption(Xlat_0000997, locale);
