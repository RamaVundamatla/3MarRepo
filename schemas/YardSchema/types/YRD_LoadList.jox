    <JadeMethod name="tblAll_contextMenu" id="e63a16f5-bb30-4071-b4e4-ef1231fc8ef5">
        <controlMethod name="Table::contextMenu"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblAll_contextMenu(table: Table input; conwin: Window input; mouse: Boolean; x: Integer; y: Integer):Boolean updating;
// ---------------------------------------------------------------------------
// Created:		08 January 2008  By Anca Rosca cnwaer1
//
// Purpose:		
//
// ---------------------------------------------------------------------------


vars
	theRow : Integer;
	theTI : CM_TrackedItem;
	xLeft 	: Real;
	yTop	: Real;
begin

	xLeft := x;
	yTop := y;

	conwin.windowToScreen(xLeft, yTop);
	self.screenToWindow(xLeft, yTop);   

	// TFS 2198 CNWAB1
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		return false;
	endif;

	self.mnuLoadListPlanLoad.visible := false;
	self.mnuContextTable.visible := true;
	self.mnuContextHide.visible := true;
	if app.isAllowedToInspect then
		self.mnuInspectObject.visible := true;
	else
		self.mnuInspectObject.visible := false;	
	endif;


	theRow := table.CM_BaseTable.getRowFromY(y);
	if theRow &gt; table.fixedRows then
		theTI := table.accessRow(theRow).itemObject.CM_TrackedItem;

		self.mnuInspectObject.userObject := theTI;
	endif;	
	self.doContextMenuBuild(table);
	self.mnuLLUnplan.visible := true;
	self.mnuLLReadyToShip.visible := false;

	self.popupMenu(mnuContextTable, xLeft.Integer, yTop.Integer);

	return false;


end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="conwin" type="Window" usage="input"/>
        <Parameter name="mouse" type="Boolean"/>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
