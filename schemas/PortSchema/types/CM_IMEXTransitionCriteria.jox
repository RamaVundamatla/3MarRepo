        <source>setBaseData(_description, _name : String; _myTerminal : CM_Terminal; _transitionIMEX : Integer) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
28 March 2018	jlgsl4	TFS 37410 Import MTs IMEX transition status

*/

vars

begin
	self.setDescription(_description);
	self.name := _name;
	self.setTransitionIMEX(_transitionIMEX);
	self.myTerminal := _myTerminal;
epilog

end;</source>
        <Parameter name="_description" type="String"/>
        <Parameter name="_name" type="String"/>
        <Parameter name="_myTerminal" type="CM_Terminal"/>
        <Parameter name="_transitionIMEX" type="Integer"/>
    </JadeMethod>
