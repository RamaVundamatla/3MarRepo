    <JadeMethod name="onRectSelected" id="4273f071-54d3-4812-a402-e1412f89dd92">
        <interfaceImplements>
            <JadeInterfaceMethod name="IF_CMUI_RectangleHandler::onRectSelected"/>
        </interfaceImplements>
        <updating/>
        <source>onRectSelected(_rect: CMUI_ResizableRectFrame input) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
04 February 2009	cnwjk3	SFW1030

*/

vars
	x ,rectLeft,
	rectWidth,
	adjustment : Real;
	allOtherMachineWorkzones : ObjectArray;
	obj : Object;
	cmifMachineWorkzone,
	otherMachineWorkzone :CMIF_MachineWorkzone;
begin
	if _rect.name = self.frmResizableRect.name then
		self.myCurrentDrawingController.getOverlayEditFrame().onRectSelected(_rect);
	elseif _rect.name = self.frmWorkZone.name then
	//epr par 20853 9/10/09
		
		if _rect.isInResizeMode then
			cmifMachineWorkzone:=_rect.userObject.CMIF_MachineWorkzone;
			if cmifMachineWorkzone = null then	//PAR 21756 Jan 2010
				return;
			endif;	
			
			rectLeft:=_rect.getAdjustedOrigLeft;
			rectWidth:=_rect.getAdjustedOrigWidth;
			
			if _rect.resizingLeft or _rect.resizingTop then
				x:=rectLeft;
			else
				x:=rectLeft + rectWidth;
			endif;
			adjustment:= _rect.drawWidth;
		
			self.doMachWorkzoneFindLinkOverlap(x,adjustment,rectLeft,rectWidth,cmifMachineWorkzone,_rect.resizingLeft or _rect.resizingTop);
		
		endif;
		
	endif;
epilog

end;</source>
        <Parameter name="_rect" type="CMUI_ResizableRectFrame" usage="input"/>
    </JadeMethod>
