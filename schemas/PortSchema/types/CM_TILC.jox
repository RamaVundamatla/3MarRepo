    <JadeMethod name="hasTIonChassis" id="fad5149f-8f06-408c-bfe0-4293ed5d3124">
        <source>hasTIonChassis(_ti : CM_TrackedItem) : Boolean;
/*
Date		Who		Reason
09 July 2013	cnwer1	Initial creation
*/

vars
	lc : CM_LocationsController;
begin
	foreach lc in self.allLCs do
		if lc.allTrackedItems.includes(_ti) then
			return true;
		endif;
	endforeach;
	
	return false;
epilog

end;</source>
