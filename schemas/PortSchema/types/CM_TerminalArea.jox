    <JadeMethod name="numAttachments" id="ab5209c6-3e85-4795-a6d8-94f9e38f3b5d">
        <source>numAttachments(_type:Integer):Integer;
/*
Purpose - 	
Who - NAVAB1
Date - 28DEC2023
ADO -  CR 58499 TASK 61455
*/


vars
	iter : Iterator;
	attachment : CM_Attachment;
	numAttachments : Integer;
begin
	numAttachments := 0;
	iter := self.allAttachments.createIterator();
	self.allAttachments.startKeyGeq(CM_Attachment.Type_Photo,iter);
	while iter.next(attachment) do
		if attachment.type &lt;&gt; _type then
			break;
		endif;
		numAttachments := numAttachments + 1;
	endwhile;
	
	return numAttachments;
epilog
	delete iter;
end;</source>
        <Parameter name="_type" type="Integer"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="purgeCargoPhotos" id="bc1a8b28-caad-4d3c-a121-3363a47f3a26">
        <source>purgeCargoPhotos(_ts : TimeStamp; _agent : CM_DBPurgeAgent input);
/*
Purpose - 	
Who - NAVAB1
Date - 28DEC2023
ADO -  CR 58499 TASK 61455
*/

vars
	iter : Iterator;
	photo : CM_Attachment;
	completed : Integer;
	ts : TimeStamp;
begin
	completed := 0;
	iter := self.allAttachments.createIterator();
	self.allAttachments.startKeyGeq(CM_Attachment.Type_Photo, iter);
	while iter.next(photo) do
		if photo.type &lt;&gt; CM_Attachment.Type_Photo then
			break;
		endif;
		
		ts := photo.getLoadTimeStamp();	
		if ts &lt;= _ts then
			self.exclusiveLock(photo);
			delete photo;
			completed := completed + 1;
		endif;
	endwhile;

	if completed &gt; 0 then
		_agent.addNumCompleted(completed);
		_agent.setStats(app.getErrorString(Purged)&amp;' for '&amp;self.id&amp;' '&amp;completed.String&amp;' '&amp;app.getErrorString(Cargo_Photos)&amp;' '&amp;"0"&amp;' '&amp;app.getErrorString(Errors));
	else
		_agent.setStats('');
	endif;

epilog	
	delete iter;
end;</source>
        <Parameter name="_ts" type="TimeStamp"/>
        <Parameter name="_agent" type="CM_DBPurgeAgent" usage="input"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="a9f0710a-bbe6-49c0-bdfd-3fcfc67c19b6">
        <source>pxyCreateUpdateProxy(): SelfType;

// 20/04/2011	cnwmh5		PAR #27401 - Add code to handle prossible exceptions occurring when
//							trying to create the proxy

vars

	pxyTerminalArea : CM_TerminalArea;
	pxyGL 			: CM_LayoutGraphic;
	deckingOpt		: CM_YADeckingOptionsTA;
	completedOK		: Boolean;
	
begin

	pxyTerminalArea := inheritMethod();
	
	self.allCargoBOLTypes.copy(pxyTerminalArea.allCargoBOLTypes);

	if self.myLayoutGraphic &lt;&gt; null then
		pxyTerminalArea.myLayoutGraphic := self.myLayoutGraphic.pxyCreateUpdateProxy();
	else
		pxyTerminalArea.initDefaultLayout();
	endif;
	
	//th2 added 21/8/06 - to avoid having to rebuild every update
	if self.myYADeckingOptions &lt;&gt; null then
		deckingOpt := self.myYADeckingOptions.pxyCreateUpdateProxy();
		deckingOpt.setProxy(deckingOpt.showHeightsForCustom,
							deckingOpt.useReverseOfIn,
							pxyTerminalArea);
	endif;
	
	self.allAssociatedInterchangeAreas.copy(pxyTerminalArea.allAssociatedInterchangeAreas);
	
	pxyTerminalArea.myDefaultInterchangeArea:=self.myDefaultInterchangeArea;
	
	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return pxyTerminalArea;
	
epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete pxyTerminalArea;
	endif;	

end;

</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
