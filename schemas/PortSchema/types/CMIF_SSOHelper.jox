    <JadeMethod name="getUserRemSSOSession" id="f83ab058-69e7-44ad-99c0-2aabd2199b57">
        <source>getUserRemSSOSession(): Boolean protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
21 September 2022	navam1	54866 - MTN - SSO - User gets stuck when Locking the current session
24 Nov  2025 		navec1	MTN-36234: Okta SSO - Remember SSO Session
*/

vars
	userRememberSSOSession : Integer;
	ssoProvider				: Integer;
begin
	userRememberSSOSession := app.getMyUser().getStateData(ConfigGrp_System, UserRememberSSOSession).Integer;
	
	if userRememberSSOSession = RemSSOSessionDefault then
		// MTN-36234 - navec1 - Okta Remember SSO Session
		ssoProvider	:=  app.myRoot.getConfig(SsoProvider).Integer;
		if ssoProvider = app.mySSOAgent.SSO_Provider_Microsoft then
			return app.myRoot.getConfig(SsoAzureRememberTokenDef).Boolean;	//system default for Azure
		elseif ssoProvider = app.mySSOAgent.SSO_Provider_Okta then
			return app.myRoot.getConfig(SsoOktaRememberTokenDef).Boolean;	//system default for Okta
		else
			return false;	// unknown Provider, default false.
		endif;
	elseif userRememberSSOSession = RemSSOSessionEnabled then
		return true;
	else
		return false;
	endif;
epilog

end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="handleExceptions" id="b26d435c-87f8-4ed5-a10f-c9aea7683c43">
        <source>handleExceptions(_exc: Exception; _excOccurred: Boolean io): Integer protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date					Who		Reason
01 February 2024		navmd1	Initial creation TFS 60905

*/

vars

begin

	// If its just the user closing the popup, then don't show any errors/warnings
	if _exc.extendedErrorText.cnContains("User canceled authentication") then
		_excOccurred := true;
		if app.myPassport &lt;&gt; null then
			app.myPassport.addErrorFull(0, "User cancelled authentication", null, null, _exc);	// Add a dummy error to the passport to suppress the 'Invalid Username/Password' one	
		endif;
		
		return Ex_Resume_Next;
	endif;

	return inheritMethod(_exc, _excOccurred);

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_exc" type="Exception"/>
        <Parameter name="_excOccurred" type="Boolean" usage="io"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="handleValidationError" id="646b17b1-fc7d-47b8-a0ea-01e7b8eeaa7f">
        <source>handleValidationError(_exc : CM_Exception) : Integer protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
31 January 2024		navmd1	Initial creation TFS 60905

*/

vars
	
begin
	app.myPassport.addErrorFull(_exc.errorCode, _exc.extendedErrorText, _exc.userString, _exc.myUserObject, _exc);
	app.writeLog(app.myPassport.getErrorsAsString(), LogERROR);
	
	return app.normalExceptionHandler(_exc);
	
epilog
	
end;</source>
        <access>protected</access>
        <Parameter name="_exc" type="CM_Exception"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="login" id="3d04dfcd-4d75-4c81-9889-8f443b848b63">
        <updating/>
        <source>login(): Boolean updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
20 July 2022 		navam1 ChangeRequest 52824: EUP - Azure Active Directory Single Sign On - MTN
24 January 2024		navmd1	TFS 60905 Refactor SSO for Superuser
25 Aug 2025 		navec1	MTN-35151: Single Sign On via Okta for MTN Thin Client
*/

vars
	
begin
	// Create a temporary passport to hold errors to send back to the logon form
	app.createPassport();

	if self.provider = CMIF_SSOHelper.SSO_Provider_Microsoft then
		if not self.loginMicrosoft() then
			app.writeLog(method.qualifiedName &amp; " Error getting Microsoft Token", LogERROR);
			return false;
		endif;
	elseif self.provider = CMIF_SSOHelper.SSO_Provider_Okta then  // MTN-35151 - navec1 - Okta SSO
		if not self.loginOktaStart() then
			app.writeLog(method.qualifiedName &amp; " Error Starting Okta SSO", LogERROR);
			return false;
		else
			return true; // Okta SSO started, leave and timer event will wait for result from Okta SSO redirect
		endif;
	else
		app.raiseUnexpectedProgramError(class.name, method.name, "New SSO provider - need to implement specific login method");
		return false;
	endif;
	
	if not self.validateToken() then
		app.writeLog(method.qualifiedName &amp; " Failed to verify token", LogERROR);
		return false;
	endif;
	
	self.isLoggedInUsingSSO := true;
	return true;
epilog
	app.mousePointer := Idle;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="loginMicrosoft" id="4db6dc79-d862-418e-be45-ae0268cee36f">
        <updating/>
        <source>loginMicrosoft() : Boolean protected, updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
24 January 2024		navmd1	Initial creation TFS 60905 Refactor SSO for Superuser

*/

vars
	hadException			: Boolean;
	tenantId, clientId		: StringUtf8;
	accessToken				: StringUtf8;
	uid						: StringUtf8;
	logMessages				: StringUtf8;
begin
	on Exception do self.handleExceptions(exception, hadException);
	
	tenantId := app.myRoot.getConfig(SsoAzureTenantId).StringUtf8;
	clientId := app.myRoot.getConfig(SsoAzureClientId).StringUtf8;
	
	if (tenantId = null) then
		app.writeLog(method.qualifiedName &amp; " Tenant id has not been set. Please specify the tenant id in the system config &gt; security config ", LogERROR);	
		return false;
	endif;
	
	if (clientId = null) then
		app.writeLog(method.qualifiedName &amp; " Client id has not been set. Please specify the client id in the system config &gt; security config ", LogERROR);	
		return false;
	endif;
	
	self.msalAuthResult := self.mySSOHelper.login(clientId, tenantId, false, accessToken, uid, logMessages);
	app.mousePointer := Busy;	// Doesn't actually seem to do this properly, but leaving in case it does decide to work
	
	if logMessages &lt;&gt; null then
		app.writeLog(method.qualifiedName &amp; " " &amp; logMessages.String, LogINFO);
	endif;
	
	if (self.msalAuthResult = null or hadException) then
		app.writeLog(method.qualifiedName &amp; " Error retrieving SSO authToken ", LogERROR);	
		return false;
	endif;
	
	app.writeLog(method.qualifiedName &amp; " UID: " &amp; uid.String &amp; " Access Token: " &amp; accessToken.String, LogTRACE);
	
	self.jwtAccessToken := accessToken.String;
	self.uidUniqueId := uid.String;
	
	return true;
epilog

end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="loginOktaPostSSO" id="f8a01b84-c15b-41c1-b7a1-b3a9ac96fa4d">
        <updating/>
        <source>loginOktaPostSSO() updating, protected;
/*

Purpose:			post Okta SSO actions, perform MTN login

Parameters:			

Return Value:		

Date		Who		Reason
08 Sept  2025 navec1	MTN-35151: Single Sign On via Okta for MTN Thin Client

*/

vars
	result		: Integer;
	msg			: String;

begin
	if not self.validateToken() then
		app.writeLog(method.qualifiedName &amp; " Failed to verify Okta token", LogERROR);
		return;
	endif;
	
	result := app.validateUserSSO(app.mySSOAgent.upnMatchingId, app.mySSOAgent.uidUniqueId);

	if result = 0 then
		// MTN user found and login success
		isLoggedInUsingSSO := true;
		oktaSsoInFlight := false; // this must be set after isLoggedInUsingSSO, this will stop timer in CMS_Logon
		return;
	endif;
	
	oktaSsoInFlight := false;
	
	// handle error
	msg := app.getErrorString(result); 
	
	app.myRoot.resolveMessagesWithExtraInfo(result, msg); //+ cnwmd1 Par 22287
	
	// Only show the generic error if we haven't already shown a more specific one
	if app.myPassport.allErrors.size = 0 then
		app.msgBox(msg, "Single Sign On", MsgBox_Exclamation_Mark_Icon + MsgBox_OK_Only );
	else
		app.myPassport.clearErrorsWarnings();
	endif;
	
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="loginOktaStart" id="c790f698-b12c-420f-a28a-ec23c647562e">
        <updating/>
        <source>loginOktaStart(): Boolean protected, updating;
/*

Purpose:			Start Okta SSO login process, call DLL, start default browser for login. This is an async process

Parameters:			

Return Value:		

Date			Who		Reason
08 Sept  2025 	navec1	MTN-35151: Single Sign On via Okta for MTN Thin Client

*/

vars
	clientId, domain, clientSecret, issuerUri, audience: StringUtf8;
	hadException			: Boolean;
	logMessages				: StringUtf8;
	fieldName				: String;
	startSsoResult			: Boolean;
    optOut, msRemaining  	: Integer;

begin
	on Exception do self.handleExceptions(exception, hadException);
	
	clientId := app.myRoot.getConfig(SsoOktaClientId).StringUtf8;
	domain := app.myRoot.getConfig(SsoOktaDomain).StringUtf8;
	clientSecret := app.myRoot.getConfig(SsoOktaClientSecret).StringUtf8;
	issuerUri := app.myRoot.getConfig(SsoOktaIssuerURI).StringUtf8;
	audience := app.myRoot.getConfig(SsoOktaAudience).StringUtf8;
			
	fieldName := "";
	if (clientId = null ) then
		fieldName := fieldName &amp; ", Client ID";
	endif;
	if domain = null then
		fieldName := fieldName &amp; ", Domain";
	endif;
	if issuerUri = null then
		fieldName := fieldName &amp; ", Issuer URI";
	endif;
	if audience = null then
		fieldName := fieldName &amp; ", Audience";
	endif;
	if fieldName.length &gt; 0 then
		app.writeLog(method.qualifiedName &amp; " " &amp;  fieldName[3: fieldName.length] &amp; " has not been set. Please specify in the system config &gt; security config ", LogERROR);
		return false;
	endif;

	// start the Sso Auth on Default browser, start a listener to wait for the result, this is async function which is non-blocking
	startSsoResult := self.myOktaSsoHelper.startSsoAuth(clientId, domain, clientSecret, logMessages);
	
	if logMessages &lt;&gt; null then
		app.writeLog(method.qualifiedName &amp; " " &amp; logMessages.String, LogINFO);
	endif;
	
	if (startSsoResult = null or not startSsoResult) then
		app.writeLog(method.qualifiedName &amp; " Error starting Okta SSO", LogERROR);	
		return false;
	endif;
	
	// Arm timer to poll status
	self.oktaSsoInFlight := true;
	if not self.getTimerStatus(OKTA_SSO_TIMER_TAG, optOut, msRemaining) then
		self.beginTimer(500, Timer_Continuous, OKTA_SSO_TIMER_TAG);
	endif;

	return true;

epilog

end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="loginSpecial" id="02377d1f-5a0f-465c-9680-4d88b4862820">
        <updating/>
        <source>loginSpecial(_isSuper, _isSupport : Boolean output; _silent : Boolean; _username : String): Boolean updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
23 February 2023	navmd1	Initial creation TFS 60905 Refactor SSO for Superuser

*/
constants
	CLAIM_ROLES			: StringUtf8 = "roles";
	ROLE_SUPERUSER		: String = "Superuser";
	ROLE_SUPPORT		: String = "Supportuser";
vars
	hadException		: Boolean;
	tenantId, clientId	: StringUtf8;
	accessToken			: StringUtf8;
	uid					: StringUtf8;
	logMessages			: StringUtf8;
	jsonArrayStr		: StringUtf8;
	parser				: JadeJson;
	hadJSONParsingEx	: Boolean;
	jsonObjects			: ObjectArray;
	roles				: StringArray;
	role				: String;
	loggingInAsSupport	: Boolean;
begin
	// Create a temporary passport to hold errors to send back to the logon form
	if app.myPassport = null then
		app.createPassport();
	endif;
	
	on Exception do self.handleExceptions(exception, hadException);
	
	tenantId := self.getMTNTenantId();
	clientId := self.getMTNSSOClientId();
	
	self.msalAuthResult := self.mySSOHelper.login(clientId, tenantId, not _silent, accessToken, uid, logMessages);
	app.mousePointer := Busy;	// Doesn't actually seem to do this properly, but leaving in case it does decide to work
	
	if logMessages &lt;&gt; null then
		app.writeLog(method.qualifiedName &amp; " " &amp; logMessages.String, LogINFO);
	endif;
	
	if self.msalAuthResult = null or hadException then
		app.writeLog(method.qualifiedName &amp; " Error retrieving SSO authToken ", LogERROR);	
		return false;
	endif;
	
	app.writeLog(method.qualifiedName &amp; " UID: " &amp; uid.String &amp; " Access Token: " &amp; accessToken.String, LogTRACE);
	
	self.jwtAccessToken := accessToken.String;
	
	if not self.validateTokenMicrosoft(true) then
		app.writeLog(method.qualifiedName &amp; " Error validation SSO authToken", LogERROR);
		return false;
	endif;
	
	jsonArrayStr := self.mySSOHelper.getJsonArrayClaim(accessToken, CLAIM_ROLES);
	app.writeLog(method.qualifiedName &amp; " Roles: " &amp; jsonArrayStr.String, LogINFO);
	if jsonArrayStr = null then
		app.writeLog(method.qualifiedName &amp; " Invalid SSO Token, no user roles defined", LogERROR);
		return false;
	endif;
	
	create parser transient;
	create jsonObjects transient;
	
	on Exception do app.handleJSONParsingException(exception, hadJSONParsingEx);
	roles := parser.parse(jsonArrayStr.String, StringArray, jsonObjects).StringArray;
	on Exception do null;
	
	foreach role in roles do
		app.writeLog("Checking [" &amp; role &amp; "]", LogTRACE);
		if role = ROLE_SUPERUSER then
			app.writeLog("Found Superuser role!", LogDEBUG);
			_isSuper := true;
		elseif role = ROLE_SUPPORT then
			app.writeLog("Found Support user role!", LogDEBUG);
			_isSupport := true;
		endif;
	endforeach;
	
	app.writeLog(method.qualifiedName &amp; " Is Superuser: " &amp; _isSuper.String, LogINFO);
	app.writeLog(method.qualifiedName &amp; " Is Supportuser: " &amp; _isSupport.String, LogINFO);
	
	if not hadException then
		// If we're going into special after having logged in via a non-SSO user, then make sure we set this to true
		// so when we log out, we clear the token
		loggingInAsSupport := _username = JMTSUPPORT_Str and _isSupport;
		if _isSuper or loggingInAsSupport then
			self.isLoggedInUsingSSO := true;
		endif;
	endif;
	
	return not hadException;
epilog
	app.mousePointer := Idle;

	delete parser;
	if jsonObjects &lt;&gt; null then
		jsonObjects.purge();
		delete jsonObjects;
	endif;
end;</source>
        <Parameter name="_isSuper" type="Boolean" usage="output"/>
        <Parameter name="_isSupport" type="Boolean" usage="output"/>
        <Parameter name="_silent" type="Boolean"/>
        <Parameter name="_username" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="logout" id="0bf05e02-2256-4836-8377-ffa60d98d701">
        <updating/>
        <source>logout(_clearSession: Boolean) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
20 July 2022 		navam1 	ChangeRequest 52824: EUP - Azure Active Directory Single Sign On - MTN
10 March 2023		navmd1	Further changes to allow clearing of sesions when explicitly logging out
24 January 2024		navmd1	TFS 60905 Refactor SSO for Superuser
15 July 2024		navsck1 Bug 63949: MTN - Logging out of MTN causing 75768 error
15 Sept  2025 		navec1	MTN-35151: Single Sign On via Okta for MTN Thin Client
24 Nov  2025 		navec1	MTN-36234: Okta SSO - Remember SSO Session
*/

vars

begin
	app.writeLog(method.qualifiedName &amp; " Clear Session: " &amp; _clearSession.String, LogINFO);
	
	if app.myPassport.myUser.code.isOneOf(SUPERUSER_Str, JMTSUPPORT_Str) or app.isSpecial then
		self.logoutMicrosoft(_clearSession);	// always true ?
	elseif self.provider = CMIF_SSOHelper.SSO_Provider_Microsoft then
		self.logoutMicrosoft(_clearSession);	
	elseif self.provider = CMIF_SSOHelper.SSO_Provider_Okta then  // MTN-35151 - navec1 - Okta SSO
		self.logoutOkta(_clearSession);	// MTN-36234 - navec1 - Okta Remember SSO Session
	else
		app.raiseUnexpectedProgramError(class.name, method.name, "New SSO provider - need to implement specific logout method");
		return;
	endif;
	
	self.isLoggedInUsingSSO := false;
epilog

end;</source>
        <Parameter name="_clearSession" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="logoutMicrosoft" id="a2b77ba7-1202-4345-9654-90ff4d19ad30">
        <updating/>
        <source>logoutMicrosoft(_clearSession: Boolean) updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
24 January 2024		navmd1	TFS 60905 Refactor SSO for Superuser
*/

vars
	hadException		: Boolean;
	tenantId,
	clientId			: StringUtf8;
	saveSession 		: Boolean;
	logMessages			: StringUtf8;
begin
	on Exception do self.handleExceptions(exception, hadException);
	
	tenantId := app.myRoot.getConfig(SsoAzureTenantId).StringUtf8;
	clientId := app.myRoot.getConfig(SsoAzureClientId).StringUtf8;
	
	if self.msalAuthResult = null then
		app.writeLog(method.qualifiedName &amp; " SSO auth token is null ", LogERROR);	
		return;
	endif;
	
	if not _clearSession then
		saveSession := self.getUserRemSSOSession();
	endif;
	
	self.mySSOHelper.logout(clientId, tenantId, self.msalAuthResult, saveSession, logMessages); //54866
	if logMessages &lt;&gt; null then
		app.writeLog(method.qualifiedName &amp; " " &amp; logMessages.String, LogINFO);
	endif;
	
	delete self.msalAuthResult;
	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_clearSession" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="logoutOkta" id="a34fdecf-357d-4af7-a9a0-a27271c89efd">
        <source>logoutOkta(_clearSession: Boolean) protected;
/*

Purpose:			Call DLL to perform Okta logout

Parameters:			

Return Value:		

Date				Who		Reason
15 September 2025	navec1	Initial creation
24 Nov  2025 		navec1	MTN-36234: Okta SSO - Remember SSO Session

*/

vars
	logMessages: StringUtf8;
	saveSession: Boolean;

begin
	if not self.isLoggedInUsingSSO then 
		return; // not logged in, do nothing
	endif;
	
	if not _clearSession then
		saveSession := self.getUserRemSSOSession();
	endif;
		
	// try catch block, if error occurred, it could be DLL throw exception or DLL not found, just skip the exception.
	on Exception do self.skipOktaExpcept(exception);
	self.myOktaSsoHelper.logout(saveSession, logMessages);	// MTN-36234 - navec1 - Okta Remember SSO Session
	on Exception do null;
	
	if logMessages &lt;&gt; null then
		app.writeLog(method.qualifiedName &amp; " " &amp; logMessages.String, LogINFO);
	endif;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_clearSession" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setOktaSsoInFlightOff" id="12aa6746-3df7-4e98-aa26-a5f94fe46fd8">
        <updating/>
        <source>setOktaSsoInFlightOff() updating;
/*

Purpose:			call DLL to set status as cancal, stop listener

Parameters:			

Return Value:		

Date		Who		Reason
08 September 2025	navec1	Initial creation for MTN-35151: Single Sign On via Okta for MTN Thin Client

*/

vars
	_1, _2, _3, _4 : StringUtf8;

begin
	// if Okta SSO in progress
	if self.myOktaSsoHelper.getStatus(_1, _2, _3, _4) = self.myOktaSsoHelper.AuthStatus_WaitingForLogin then
		self.myOktaSsoHelper.cancel();
	endif;
	
	self.oktaSsoInFlight := false;
	return;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="skipOktaExpcept" id="14148acd-dc9e-4f90-a6a0-f19f6f4f33fa">
        <source>skipOktaExpcept(ex: Exception): Integer protected;
/*

Purpose:			Skip any exception to skip, this should be called only when try to execute an Okta method that execution not mandatory

Parameters:			

Return Value:		

Date			Who		Reason
15 Sept  2025 	navec1	MTN-35151: Single Sign On via Okta for MTN Thin Client

*/

vars

begin
	// Okta exception to skip, should be called when try to execute an Okta method that execution not mandatory
	return Ex_Resume_Next; // skip the exception, do next line
epilog

end;</source>
        <access>protected</access>
        <Parameter name="ex" type="Exception"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="timerEvent" id="890fea83-c46c-47f9-bc29-d18a0b368d41">
        <updating/>
        <source>timerEvent(eventTag: Integer) updating;
/*

Purpose:			Timer Event

Parameters:			

Return Value:		

Date			Who		Reason
08 Sept 2025	navec1	Initial creation - MTN-35151: Single Sign On via Okta for MTN Thin Client

*/

vars

begin
	// Okta SsoTimerTag 
	if eventTag = OKTA_SSO_TIMER_TAG then
		timerOktaSsoStatus(eventTag);
		return;
	endif;


epilog

end;</source>
        <Parameter name="eventTag" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="timerOktaSsoStatus" id="07270278-7f07-48ae-957b-5cfc156e1180">
        <updating/>
        <source>timerOktaSsoStatus(eventTag: Integer) protected, updating;
/*

Purpose:			handle Okta SSO timer event

Parameters:			

Return Value:		

Date			Who		Reason
10 Sept 2025 	navec1	MTN-35151: Single Sign On via Okta for MTN Thin Client

*/

vars
  ssoStatus    : Integer;
  accessToken, subject, email, logMessages  : StringUtf8;

begin
	// only process Okta SSO event
	if eventTag &lt;&gt; OKTA_SSO_TIMER_TAG then
		return;
	endif;
	
	// if not SSO provider is not Okta, should not run this timer
	if self.provider &lt;&gt; CMIF_SSOHelper.SSO_Provider_Okta then
		self.endTimer(OKTA_SSO_TIMER_TAG);
		return;
	endif;

	// Guard: nothing to poll
	if not self.oktaSsoInFlight then
		self.endTimer(OKTA_SSO_TIMER_TAG);
		return;
	endif;

	ssoStatus := self.myOktaSsoHelper.getStatus(accessToken, subject, email, logMessages);
	
	if ssoStatus = self.myOktaSsoHelper.AuthStatus_WaitingForLogin then
		return; // still waiting; do nothing
	endif;

	if logMessages &lt;&gt; null then
		app.writeLog("Okta getStatus: " &amp; logMessages.String, LogTRACE);
	endif;
	
	// status not in waiting, stop timer
	self.endTimer(OKTA_SSO_TIMER_TAG);

	if ssoStatus = self.myOktaSsoHelper.AuthStatus_Success then
		if accessToken = null then
			app.writeLog(method.qualifiedName &amp; "SSO succeeded but missing token.", LogERROR);
			return;
		endif;
		
		// save uid and matchingId
		self.uidUniqueId := subject.String;
		self.upnMatchingId := email.String;

		// For normal login path
		self.jwtAccessToken := accessToken.String;

		// post-SSO actions, perform MTN login
		loginOktaPostSSO();
		return;

	elseif ssoStatus = self.myOktaSsoHelper.AuthStatus_NotStarted then
		app.writeLog(method.qualifiedName &amp; "SSO authentication has not been started.", LogTRACE);
	elseif ssoStatus = self.myOktaSsoHelper.AuthStatus_Cancelled then
		app.writeLog(method.qualifiedName &amp; "SSO authentication has been cancelled.", LogTRACE);
	elseif ssoStatus = self.myOktaSsoHelper.AuthStatus_TimedOut or ssoStatus =  self.myOktaSsoHelper.AuthStatus_Failed then
		app.writeLog(method.qualifiedName &amp; " Error retrieving SSO authToken (status=" &amp; ssoStatus.String &amp; ")", LogERROR);
		self.myOktaSsoHelper.cancel();  // just in case if the listener still running, call cancel to stop it.
	else
		app.writeLog(method.qualifiedName &amp; " Unknown SSO status: " &amp; ssoStatus.String, LogERROR);
		self.myOktaSsoHelper.cancel();  // just in case if the listener still running, call cancel to stop it.
	endif;
	
	// if Auth success, set in flight off after MTN login, since in flight status will be used by CMS_Logon to stop it's timer
	if ssoStatus &lt;&gt; self.myOktaSsoHelper.AuthStatus_Success then
		self.oktaSsoInFlight := false;
	endif;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="eventTag" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="validateToken" id="7c5f857a-6057-4151-9645-222e621c44ff">
        <updating/>
        <source>validateToken() : Boolean protected, updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
24 January 2024		navmd1	TFS 60905 Refactor SSO for Superuser
15 Sept  2025 		navec1	MTN-35151: Single Sign On via Okta for MTN Thin Client
24 Nov  2025 		navec1	MTN-36234: Okta SSO - Remember SSO Session
*/

vars
	isValid		: Boolean;
begin
	if self.jwtAccessToken = null then
		app.raiseUnexpectedProgramError(class.name, method.name, "Error calling validateToken when jwtAccessToken is null");
		return false;
	endif;
	
	on CM_Exception do self.handleValidationError(exception);

	if self.provider = CMIF_SSOHelper.SSO_Provider_Microsoft then
		isValid := self.validateTokenMicrosoft(false);
	elseif self.provider = CMIF_SSOHelper.SSO_Provider_Okta then  // MTN-35151 - navec1 - Okta SSO
		isValid := self.validateTokenOkta();
	else
		app.raiseUnexpectedProgramError(class.name, method.name, "New SSO provider - need to implement specific validation method");
		return false;
	endif;
	
	on CM_Exception do null;
	
	if not isValid and self.provider = CMIF_SSOHelper.SSO_Provider_Microsoft then
		// If we've been unable to validate the token, then try and logout/clear the cache in the even it was a silent login
		self.logoutMicrosoft(true);
	elseif not isValid and self.provider = CMIF_SSOHelper.SSO_Provider_Okta then  // MTN-35151 - navec1 - Okta SSO
		self.logoutOkta(true);	// MTN-36234 - navec1 - Okta Remember SSO Session
	endif;
	
	return isValid;
epilog

end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validateTokenMicrosoft" id="0dceb324-9116-414c-922f-471e31b2f61d">
        <updating/>
        <source>validateTokenMicrosoft(_isSpecial : Boolean) : Boolean protected, updating;
/*

Purpose:			Lets basically do the same stuff as what the Web Services do when they get a token

Parameters:			

Return Value:		

Date				Who		Reason
24 January 2024		navmd1	Initial creation TFS 60905
15 February 2024	navmd1	TFS 62505 - Work around NBF timezone check too

*/
constants
	CLAIM_APP_ID	: String = "appid";
	CLAIM_UPN		: String = "upn";
	CLAIM_EXPIRY	: String = "exp";
	CLAIM_NOTBEFORE	: String = "nbf";
vars
	token		: String;
	appId		: String;
	iss			: String;
//	errors		: String;
	upn			: String;
	expiry		: String;
	expiryUTC,
	expiryLocal	: TimeStamp;
begin
	token := self.jwtAccessToken;

	// TODO: Check token signature
	// I don't think JADE handles this very well, so will probably need to go out to the MSAL Support library again
//	if not JadeJWTValidator@validateAsymmetricTokenRS(token, errors) then
//		app.raiseCMException1(ErrApiAuthInvalid, "SSO - Invalid Signature", null, null);		process.isMPD;	// TODO: Fix error
//		return false;
//	endif;
	
	//2. Make sure the token hasn't expired
//	if not JadeJWTValidator@verifyExpiryClaim(false, token) then
	// The JADE method can't be used here, as it seems to be not converting the epoch time correctly
	// So, lets do the same, but manually
	expiry := JadeJWTParser@getClaimValue(token, CLAIM_EXPIRY);
	if expiry &lt;&gt; null then
		expiryUTC.setFromUnixEpoch(expiry.Integer64);
		expiryLocal := expiryUTC.utcToLocalTime();
	endif;
	if expiry = null or expiryLocal &lt; app.actualTimeAppServer() then
		app.writeLog(method.qualifiedName &amp; Space &amp; token, LogERROR);
		app.raiseCMException(SSO_Auth_Err_Expired, null, null);
		return false;
	endif;
	//if not JadeJWTValidator@verifyNotBeforeClaim(true, token) then
	expiry := JadeJWTParser@getClaimValue(token, CLAIM_NOTBEFORE);
	if expiry &lt;&gt; null then
		expiryUTC.setFromUnixEpoch(expiry.Integer64);
		expiryLocal := expiryUTC.utcToLocalTime();
	endif;
	if expiry = null or expiryLocal &gt; app.actualTimeAppServer() then
		app.writeLog(method.qualifiedName &amp; Space &amp; token, LogERROR);
		app.raiseCMException(SSO_Auth_Err_Future, null, null);
		return false;
	endif;
	
	//3. verify token issuer
	if _isSpecial then
		iss := "https://sts.windows.net/" &amp; self.getMTNTenantId().String &amp; "/";
	else
		iss := "https://sts.windows.net/" &amp; app.myRoot.getConfig(SsoAzureTenantId).asString &amp; "/";
	endif;
	if not JadeJWTValidator@verifyIssuerClaim(token, iss) then
		app.writeLog(method.qualifiedName &amp; Space &amp; token, LogERROR);
		app.raiseCMException(SSO_Auth_Err_Issuer, null, null);
		return false;
	endif;
	
	//4. verify Application (client) ID 
	appId := JadeJWTParser@getClaimValue(token, CLAIM_APP_ID);
	if (not _isSpecial and appId &lt;&gt; app.myRoot.getConfig(SsoAzureClientId).asString) or
		(_isSpecial and appId &lt;&gt; self.getMTNSSOClientId().String)
	then
		app.writeLog(method.qualifiedName &amp; Space &amp; token, LogERROR);
		app.raiseCMException(SSO_Auth_Err_ClientId, null, null);
		return false;
	endif;
	
	//5. verify token has UPN
	if not _isSpecial then
		upn := JadeJWTParser@getClaimValue(token, CLAIM_UPN);
		if upn = null then
			app.writeLog(method.qualifiedName &amp; Space &amp; token, LogERROR);
			app.raiseCMException1(SSO_Auth_Err_Claim, 'UPN', null, null);
		endif;
		self.upnMatchingId := JadeJWTParser@getClaimValue(token, CLAIM_UPN);
	endif;
	
	// More ?
	
	
	
	return true;	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_isSpecial" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validateTokenOkta" id="4b634955-b7dc-4e9b-882d-b8537355032c">
        <updating/>
        <source>validateTokenOkta() : Boolean protected, updating;
/*

Purpose:			Validate Okta SSO token similar to Microsoft Azure token validation

Parameters:			

Return Value:		Boolean - true if token is valid, false otherwise

Date				Who		Reason
08 Sept  2025 		navec1	MTN-35151: Single Sign On via Okta for MTN Thin Client

*/
constants
	CLAIM_CLIENT_ID	: String = "cid";
	CLAIM_SUBJECT	: String = "sub";
	CLAIM_EXPIRY	: String = "exp";
	CLAIM_ISSUED_AT	: String = "iat";
	CLAIM_AUDIENCE	: String = "aud";
vars
	token		: String;
	clientId	: String;
	iss			: String;
	aud			: String;
	subject		: String;
	expiry		: String;
	issuedAt	: String;
	expiryUTC,
	expiryLocal	: TimeStamp;
	issuedAtUTC,
	issuedAtLocal : TimeStamp;
begin
	token := self.jwtAccessToken;

	//1. Make sure the token hasn't expired
	expiry := JadeJWTParser@getClaimValue(token, CLAIM_EXPIRY);
	if expiry &lt;&gt; null then
		expiryUTC.setFromUnixEpoch(expiry.Integer64);
		expiryLocal := expiryUTC.utcToLocalTime();
	endif;
	if expiry = null or expiryLocal &lt; app.actualTimeAppServer() then
		app.writeLog(method.qualifiedName &amp; Space &amp; token, LogERROR);
		app.raiseCMException(SSO_Auth_Err_Expired, null, null);
		return false;
	endif;
	
	//2. Verify token is not used before issued time
	issuedAt := JadeJWTParser@getClaimValue(token, CLAIM_ISSUED_AT);
	if issuedAt &lt;&gt; null then
		issuedAtUTC.setFromUnixEpoch(issuedAt.Integer64);
		issuedAtLocal := issuedAtUTC.utcToLocalTime();
	endif;
	if issuedAt = null or issuedAtLocal &gt; app.actualTimeAppServer() then
		app.writeLog(method.qualifiedName &amp; Space &amp; token, LogERROR);
		app.raiseCMException(SSO_Auth_Err_Future, null, null);
		return false;
	endif;
	
	//3. verify token issuer (Okta domain format)
	iss := app.myRoot.getConfig(SsoOktaIssuerURI).asString;
	if not JadeJWTValidator@verifyIssuerClaim(token, iss) then
		app.writeLog(method.qualifiedName &amp; Space &amp; token, LogERROR);
		app.raiseCMException(SSO_Auth_Err_Issuer, null, null);
		return false;
	endif;
	
	//4. verify audience claim
	aud := JadeJWTParser@getClaimValue(token, CLAIM_AUDIENCE);
	if aud &lt;&gt; app.myRoot.getConfig(SsoOktaAudience).asString then
		app.writeLog(method.qualifiedName &amp; Space &amp; token, LogERROR);
		app.raiseCMException(SSO_Auth_Err_Audience, null, null);
		return false;
	endif;
	
	
	//5. verify Client ID (cid in Okta)
	clientId := JadeJWTParser@getClaimValue(token, CLAIM_CLIENT_ID);
	if (clientId &lt;&gt; app.myRoot.getConfig(SsoOktaClientId).asString) then
		app.writeLog(method.qualifiedName &amp; Space &amp; token, LogERROR);
		app.raiseCMException(SSO_Auth_Err_ClientId, null, null);
		return false;
	endif;
	
	//6. verify token has subject, which is user ID look like an email (sub in Okta, equivalent to UPN in Microsoft)
	subject := JadeJWTParser@getClaimValue(token, CLAIM_SUBJECT);
	if subject = null then
		app.writeLog(method.qualifiedName &amp; Space &amp; token, LogERROR);
		app.raiseCMException1(SSO_Auth_Err_Claim, 'SUB', null, null);
		return false;
	endif;
		
	return true;	
epilog

end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
