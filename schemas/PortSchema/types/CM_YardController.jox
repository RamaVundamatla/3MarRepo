    <JadeMethod name="getTAIndexForYALocnCell" id="78f73476-7fa2-43f4-ae3c-6131b6edf39c">
        <source>getTAIndexForYALocnCell(_stackHeight: Integer; _forIn: Boolean): Integer;
//----------------------------------------------------------------
//	Created:	07 April 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin
	if _stackHeight &gt; self.allYAYardLocationCells.size 
	or (not CM_GridArea.hasInstance(self.myTerminalArea)) then
		return 0;
	endif;
	
	if _forIn then
		return self.myTerminalArea.CM_GridArea.myYADeckingOptions.allYALocationCellsIn.indexOf(self.allYAYardLocationCells[_stackHeight]);
	else
		return self.myTerminalArea.CM_GridArea.myYADeckingOptions.allYALocationCellsOut.indexOf(self.allYAYardLocationCells[_stackHeight]);
	endif;
end;</source>
        <Parameter name="_stackHeight" type="Integer"/>
        <Parameter name="_forIn" type="Boolean"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getTIAtHeight" id="0ee1a6c8-abf3-4894-b1ef-418364611a6d">
        <source>getTIAtHeight(ti : CM_TrackedItem io; height : Integer; moveMode: Integer);
//Method to retrieve the TI at the specified height
//It follwos the following rules:
//If planned move, and no TI, check atcual, then queued
//If queued move, and no TI, check actual, then planned
vars

begin
	ti := null;
	if moveMode = REAL_MODE then
		//Real mode only checks the ti's
		if (numTIs &gt; 0) and (height &lt;= numTIs) then
			ti := self.allTrackedItems.at(height);
		endif;

	elseif moveMode = PLANNING_MODE then
		if (self.numPlannedTIs &gt; 0) and (height &lt;= self.numPlannedTIs) then
			ti := self.getTIAtIndex(moveMode, height);
		endif;
		if ti = null then
			//Check for a real mode TI there as well!
			if (self.numTIs &gt; 0) and (height &lt;= self.numTIs) then
				ti := self.allTrackedItems.at(height);
			endif;
		endif;
		if ti = null then
			//Nothing here, finally check for a queued mode TI there as well!
			if (self.numQueuedTIs &gt; 0) and (height &lt;= self.numQueuedTIs) then
				ti := self.getTIAtIndex(QUEUE_MODE, height);
			endif;
		endif;

	elseif moveMode = QUEUE_MODE then
		if (self.numQueuedTIs &gt; 0) and (height &lt;= self.numQueuedTIs) then
			ti := self.getTIAtIndex(moveMode, height);
		endif;
		if ti = null then
			//Test for a real box
			if (self.numTIs &gt; 0) and (height &lt;= self.numTIs) then
				ti := self.allTrackedItems.at(height);
			endif;
		endif;
		if ti = null then
			//Test for a planned box
			if (self.numPlannedTIs &gt; 0) and (height &lt;= self.numPlannedTIs) then
				ti := self.getTIAtIndex(PLANNING_MODE, height);
			endif;
		endif;
	endif;
end;</source>
        <Parameter name="ti" type="CM_TrackedItem" usage="io"/>
        <Parameter name="height" type="Integer"/>
        <Parameter name="moveMode" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getTiTxnTypesForMoveFromToNULL" id="91142f82-6a29-4596-b8cb-107522b36fec">
        <source>getTiTxnTypesForMoveFromToNULL(_moveController: CMIF_MoveController; _intArray: IntegerArray input);
// ---------------------------------------------------------------------------
// Created:     06 January 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
/*

Date		Who		Reason
10 Jun 2008	cnwkpd1	PAR #16753 - CCMS SFW 1003 - General Cargo Graphical Screens

*/

vars
	theTI	 : CM_TrackedItem;
	termArea : CM_TerminalArea;
	
begin
	inheritMethod(_moveController, _intArray);
	
	if _moveController.moveContext = CMIF_MoveController.CONTEXT_UPDATED_VEHICLEVISIT then			// 26/09/2025	navcs2	MTN-35846  
		_intArray.add(TRANS_TYPE_CARGORETURNED);													// 26/09/2025	navcs2	MTN-35846  
	endif;																							// 26/09/2025	navcs2	MTN-35846  
	
	theTI 		:= _moveController.myTrackedItem;
	termArea	:= self.myTerminalArea;
	
	// release from yard to offsite I guess??
	if termArea &lt;&gt; null then

		
		if termArea.type = TA_TYPE_INTERTERM_TRANS_AREA then
			// In release transfer area, 3rd party release I guess??
			app.addTiTxnSubTerminalRelease(theTI, TI_TRANSMODE_ROAD, _intArray);	// PAR 20706 (swap order)
			_intArray.add(TRANS_TYPE_REL_ROAD_INTER_TERM);
			// TFS 42277 ALL CM_Release transaction create a storage transaction, so this is not needed. 			_intArray.add(TRANS_TYPE_STORAGE);
			
		elseif termArea.type = TA_TYPE_RELTRANS then
			// In release transfer area, 3rd party release I guess??
			app.addTiTxnSubTerminalRelease(theTI, TI_TRANSMODE_ROAD, _intArray);	// PAR 20706 (swap order)
			_intArray.add(TRANS_TYPE_REL_ROAD);
			// TFS 42277 ALL CM_Release transaction create a storage transaction, so this is not needed. 			_intArray.add(TRANS_TYPE_STORAGE);
			
		elseif termArea.type = TA_TYPE_IRREGULAR_BLOCK_AREA 		// was TA_TYPE_GENERAL_CARGO_AREA
		and theTI.site = TI_SITE_OFFSITE then
			//probably a direct load out - create a release
			app.addTiTxnSubTerminalRelease(theTI, null, _intArray);		// PAR 20706 (swap order)
			_intArray.add(TRANS_TYPE_RELEASE);
		// TFS 42277 ALL CM_Release transaction create a storage transaction, so this is not needed. 			_intArray.add(TRANS_TYPE_STORAGE);
			
		elseif theTI.myVoyage &lt;&gt; null then	
			//epr par 34837 1/9/14 always create of moving cargo offsite via NWNP if it has lolo slots is irrrelevant
			if _moveController.isNonCraneVoyageMove then //cnwrd1 par 24097 14.5.2010 only for npnw voyage drag and drop
				// TFS 45731 Do not create multiple receive an drelease if dragging and dropping between onsite and offsite	
				if theTI.getTransReleaseLast() = null then
					//They are dragging from a blockstack to offsite via the Nonplanned/Nonworked voyage form
					app.addTiTxnSubTerminalRelease(theTI, TI_TRANSMODE_ROAD, _intArray);		// PAR 20706 (swap order)
					_intArray.add(TRANS_TYPE_REL_ROAD);
					// TFS 42277 ALL CM_Release transaction create a storage transaction, so this is not needed. 			_intArray.add(TRANS_TYPE_STORAGE);							
				endif;
			endif;
		endif;
	endif;
end;</source>
        <Parameter name="_moveController" type="CMIF_MoveController"/>
        <Parameter name="_intArray" type="IntegerArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getTiTxnTypesForMoveToFromLC" id="19aed476-4478-441c-b228-953b57bdb82d">
        <source>getTiTxnTypesForMoveToFromLC(_fromController: CM_LocationsController; _intArray: IntegerArray input; _moveController : CMIF_MoveController);
// ---------------------------------------------------------------------------
// Created:     06 January 2004 by cnwrs2
//
// Purpose:   
// 26/09/2025	navcs2	MTN-35846  
// ---------------------------------------------------------------------------
vars

	voyageJob : CM_VoyageJob;
	
begin

	inheritMethod(_fromController, _intArray, _moveController);

	if _moveController.moveContext = CMIF_MoveController.CONTEXT_UPDATED_VEHICLEVISIT and _fromController.isVehicle then	// 26/09/2025	navcs2	MTN-35846 
		_intArray.add(TRANS_TYPE_CARGORETURNED);																			// 26/09/2025	navcs2	MTN-35846 
	endif;																													// 26/09/2025	navcs2	MTN-35846 
	
	if _fromController.isKindOf(CM_VoyageController) then
	/*	_intArray.add(TRANS_TYPE_REC_SHIP);
		_intArray.add(TRANS_TYPE_WHARFAGE);
		app.addTiTxnSubTerminalReceive(_moveController.myTrackedItem, TI_TRANSMODE_SHIP, _intArray);			// PAR 20706 (swap order)

		if CM_VoyageJob.hasInstance(_moveController.jobForMove) then
			voyageJob := _moveController.jobForMove.CM_VoyageJob;
		elseif _moveController.myWorkListEntry &lt;&gt; null and CM_VoyageJob.hasInstance(_moveController.myWorkListEntry.job) then
			voyageJob := _moveController.myWorkListEntry.job.CM_VoyageJob;		
		endif;

		if ( voyageJob &lt;&gt; null and voyageJob.isExportReturn ) or _moveController.isExportReturn then	//07 Sep 2012	NDL	Par 30319
			_intArray.add(TRANS_TYPE_EXPORT_RETURNED);			
		endif;
	*/
	else
		// so Wellington can re-implement on their controllers
		_fromController.getTiTxnTypesForMoveToYard(_intArray);
	endif;
	
end;</source>
        <Parameter name="_fromController" type="CM_LocationsController"/>
        <Parameter name="_intArray" type="IntegerArray" usage="input"/>
        <Parameter name="_moveController" type="CMIF_MoveController"/>
    </JadeMethod>
    <JadeMethod name="getTiTxnTypesForMoveToFromNULL" id="61236bb8-76b4-41ae-abbd-29b1154ae755">
        <source>getTiTxnTypesForMoveToFromNULL(_moveController: CMIF_MoveController; _intArray: IntegerArray input);
// ---------------------------------------------------------------------------
// Created:     06 January 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
/*

Date		Who		Reason
12 Oct 2012	cnwkpd1	PAR #30400 - SFW 1290 - Transaction EDI file type
// 26/09/2025	navcs2	MTN-35846 
*/

vars
	transReceive, 
	basicReceive	: CM_Receive;
	transRelease	: CM_Release;
	tmpTI			: CM_TrackedItem;
	termArea		: CM_TerminalArea;
begin
	inheritMethod(_moveController, _intArray);

	termArea := self.myTerminalArea;
	
	if _moveController.moveContext = CMIF_MoveController.CONTEXT_UPDATED_VEHICLEVISIT then			// 26/09/2025	navcs2	MTN-35846  
		_intArray.add(TRANS_TYPE_CARGORETURNED);													// 26/09/2025	navcs2	MTN-35846  
	endif;																							// 26/09/2025	navcs2	MTN-35846  
	
	if termArea &lt;&gt; null and termArea.type &lt;&gt; TA_TYPE_DELETE then
	
		tmpTI := _moveController.myTrackedItem;
		if termArea.type = TA_TYPE_RECTRANS  then
			//must be a 3rd party receipt		
			_intArray.add(TRANS_TYPE_REC_ROAD);
			app.addTiTxnSubTerminalReceive(tmpTI, TI_TRANSMODE_ROAD, _intArray);
			
		elseif termArea.type = TA_TYPE_INTERTERM_TRANS_AREA then
			_intArray.add(TRANS_TYPE_REC_ROAD_INTER_TERM);
			app.addTiTxnSubTerminalReceive(tmpTI, TI_TRANSMODE_ROAD, _intArray);

		else
			// PAR 18442 - ensure we always create a receive transaction
			// need to check we don't already have a receive transaction (case here
			// for Reinstating Log Rejects.
			transReceive := tmpTI.getTransReceive();
			if transReceive = null then
				// SFW 1090 PAR #30400 - create right kind of Receive transaction in EDI Onsite Cargo load
				if tmpTI.receiptTransportMode = TI_TRANSMODE_ROAD then
					_intArray.add(TRANS_TYPE_REC_ROAD);
				elseif tmpTI.receiptTransportMode = TI_TRANSMODE_RAIL then
					_intArray.add(TRANS_TYPE_REC_RAIL);
				elseif tmpTI.receiptTransportMode = TI_TRANSMODE_SHIP then
					_intArray.add(TRANS_TYPE_REC_SHIP);
				else
					_intArray.add(TRANS_TYPE_RECEIVE);
				endif;
				app.addTiTxnSubTerminalReceive(tmpTI, null, _intArray);
			else		
				if _moveController.isNonCraneVoyageMove	then // TFS 45731 Do not create multiple receive an drelease if dragging and dropping between onsite and offsite	
					basicReceive := tmpTI.getTransactionOfType(TRANS_TYPE_RECEIVE).CM_Receive; // TFS 45731
				endif;
				
				if basicReceive = null then // TFS 45731 from any non voyage ops screen this will be null
					// check we don't have a later RELEASE transaction
					transRelease := tmpTI.getTransRelease();
					if transRelease &lt;&gt; null and transRelease.dateTime &gt; transReceive.dateTime then
						_intArray.add(TRANS_TYPE_RECEIVE);
						app.addTiTxnSubTerminalReceive(tmpTI, null, _intArray);
					endif;
				endif;
			endif;
			
		endif;
	endif;
end;</source>
        <Parameter name="_moveController" type="CMIF_MoveController"/>
        <Parameter name="_intArray" type="IntegerArray" usage="input"/>
    </JadeMethod>
