    <JadeMethod name="auditClass" id="bfff98cc-1093-42dc-9670-fbcbef720eee">
        <options>4</options>
        <source>auditClass():Class typeMethod;
/*

Purpose:	
		
		This method is used during upgrades to determine whether or not to create an instance of
		'CM_AuditConfig' for this class, which in turn determines whether or not Auditing is permitted.
					
		This method should be re-implemented on the highest class of any branch of classes is capable of being audited.
		It should return the class to use when auditing, i.e. the one we look for the 'CM_AuditConfig' with.
		I.e. the Class 'CM_Code' would return 'CM_Code', and all sub-classes such as CM_CurrencyCode, that
		were being audited would get that value.
		
Parameters:			

Return Value:		

Date		Who		Reason
28 January 2021	jlgndl1	Initial creation	TFS 50152

*/

vars

begin

	return null;
		
epilog

end;</source>
        <ReturnType type="Class"/>
    </JadeMethod>
    <JadeMethod name="auditId" id="d3db97a8-1f62-4234-8170-399dd3bcf7c1">
        <source>auditId() : String;
// ---------------------------------------------------------------------------
// Created:     May 2006 by cnwrs1
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	str: String;
	property: Property;
begin
	property := self.class.findProperty("code");
	if property = null then
		property := self.class.findProperty("id");
	endif;
	if property = null then
		property := self.class.findProperty("type");
	endif;
	if property = null then
		property := self.class.findProperty("docket");
	endif;
	if property = null then
		property := self.class.findProperty("name");
	endif;
	if property = null then
		property := self.class.findProperty("description");
	endif;
	if property = null then
		property := self.class.findProperty("label");
	endif;
	if property = null then		// for RT Queue audit, CM_VoyageCraneQueue
		property := self.class.findProperty("ident");
	endif;
	if property = null then

	else
		str := self.getPropertyValue(property.name).String.trimBlanks();
if str = null then

endif;
	endif;
	return str; 
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="auditIdDisplay" id="3c9d930f-9c55-40e1-b9c4-5762b953c72c">
        <source>auditIdDisplay() : String;
// ---------------------------------------------------------------------------
// Created:     May 2006 by cnwrs1
//
// Purpose:     
// 31 Mar 2025 navma1  MTN-34387 MTN - Removing Unnecessary Audits
// ---------------------------------------------------------------------------
vars
	auditIdStr : String;
begin
	auditIdStr := self.auditId();										//31.03.2025 navma1 #MTN-34387
	
	if auditIdStr &lt;&gt; null then
		return self.class.getUserFriendlyName()&amp;' - '&amp; auditIdStr;		//31.03.2025 navma1 #MTN-34387
	else
		return self.class.getUserFriendlyName();
	endif;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
