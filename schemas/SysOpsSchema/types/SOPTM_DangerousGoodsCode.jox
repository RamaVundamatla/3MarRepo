    <JadeMethod name="setupThumbnailDetails" id="e9bce6be-b477-4124-8069-1881e1931d7a">
        <updating/>
        <source>setupThumbnailDetails() updating;

vars
	theForm : SOP_TableMaintForm;
    row     : Integer;
begin
  
  	theForm := self.myForm;
	theForm.useProxyObject := true;
	theForm.setTblDataEntRows(ETDef_UNDGCodeMaint);
	//12/01/2011 cnwdz2 25840
	//theForm.zClearSortColumns();
	//theForm.zAddSortColumn(ETRow_Code, false);

	theForm.shtTblInput1.caption := 'Details';
	theForm.initTblInput(theForm.tblInput1, ETDef_UNDGCodeMaint);
	theForm.shtTblInput1.visible := true;
//	theForm.btnImport.visible := true;

	theForm.mulSelect1.formDisplayEntryMethodName := null;
	theForm.mulSelect2.formDisplayEntryMethodName := null;

	self.colourColumn := theForm.tblData.getColumnByRowName(ETRow_Colour);			
end;</source>
    </JadeMethod>
    <JadeMethod name="showThumbnail" id="776896ef-38dc-44b5-9053-b45bb9544cfc">
        <updating/>
        <source>showThumbnail(_undgCode : CM_UNDangerousGoods) updating;
//
// Changed On	By			Reason
// ----------	--------	--------------------------------------------------------
// 11/06/2015	cnwdap1		PAR #36421 Hazardous Materials Handling
// 07/11/2016	cnwdap1		TFS 2841 STWR Hazardous Details Enhancements
vars
	theForm : SOP_TableMaintForm;
	hazString : String;
	cell 	: JadeTableCell;
	str : String;						// PAR #36421
	row : Integer;						// PAR #36421
begin
  
	theForm := self.myForm;
	theForm.tblInput1.clearValues;
	theForm.tblInput1.setValueByName(ETRow_Code, _undgCode.code);
	theForm.tblInput1.setValueByName(ETRow_NameDesc, _undgCode.nameDesc);
	cell:=theForm.tblInput1.accessCell(theForm.tblInput1.getRowByName(ETRow_NameDesc),2);
	cell.wordWrap:=true;
	
	theForm.tblInput1.accessRow(cell.row).height:=theForm.tblInput1.getTextHeightForWidth(_undgCode.nameDesc,cell.getCellWidth) +5;
	//theForm.tblInput1.optimiseHeightForRow(Table.InputType_TextBox,theForm.tblInput1.getRowByName(ETRow_NameDesc),_undgCode.nameDesc);
	
	//theForm.tblInput1.setValueByName(ETRow_AllClassCodes, _undgCode.allClassCodes.asCSV(false));		// PAR #36421
	theForm.tblInput1.setValueByName(ETRow_SecondaryClasses, _undgCode.allClassCodes.asCSV(false));		// PAR #36421
	
	if _undgCode.myHazardClass &lt;&gt; null then
		hazString:=_undgCode.myHazardClass.code &amp; Tab &amp; _undgCode.myHazardClass.description;		
	endif;
	theForm.tblInput1.setValueByName(ETRow_HazardClass, hazString);
	theForm.comboBox1.text :=hazString;
	theForm.tblInput1.setValueByName(ETRow_AllPackingGroups, _undgCode.allPackingGroups.asCSV(false));
	theForm.tblInput1.setValueByName(ETRow_NoLongerUsed, _undgCode.noLongerUsed);
	
	theForm.tblInput1.setValueByName(ETRow_Additional, _undgCode.additionalDesc);
	theForm.tblInput1.setValueByName(ETRow_Emergency, _undgCode.emergencyNumber);
	theForm.tblInput1.setValueByName(ETRow_MarinePollutant, _undgCode.marinePollutant);
	theForm.tblInput1.setValueByName(ETRow_Symbols,_undgCode.symbols);
	
	theForm.cmbMarinePoll.clear;
	theForm.cmbMarinePoll.addItem(MarinePollutant_NullString);																	// TFS 2841
	theForm.cmbMarinePoll.addItem(MarinePollutant_YesString);																	// TFS 2841
	theForm.cmbMarinePoll.addItem(MarinePollutant_NoString);																	// TFS 2841
	theForm.tblInput1.setValueByName(ETRow_IsMarinePollutant, app.isMarinePollutantEnumToString(_undgCode.isMarinePollutant));	// TFS 2841
	theForm.cmbMarinePoll.listIndex := theForm.cmbMarinePoll.findStringExact(1, app.isMarinePollutantEnumToString(_undgCode.isMarinePollutant));	// TFS 2841
	theForm.tblInput1.setValueByName(ETRow_IsMarinePollutantMand, _undgCode.isMarinePollutantMandatory);						// TFS 2841
	
	theForm.lstPackGroup.rows := 0;											// PAR #36421
	theForm.lstPackGroup.addItem(Tab &amp; Tab &amp; "I");							// PAR #36421
	theForm.lstPackGroup.addItem(Tab &amp; Tab &amp; "II");							// PAR #36421
	theForm.lstPackGroup.addItem(Tab &amp; Tab &amp; "III");						// PAR #36421
	foreach str in _undgCode.allPackingGroups do							// PAR #36421
		foreach row in 1 to theForm.lstPackGroup.rows do					// PAR #36421
			if theForm.lstPackGroup.accessCell(row, 3).text = str then		// PAR #36421
				theForm.lstPackGroup.accessCell(row, 1).text := "1";		// PAR #36421
			endif;															// PAR #36421
		endforeach;															// PAR #36421
	endforeach;																// PAR #36421
end;</source>
        <Parameter name="_undgCode" type="CM_UNDangerousGoods"/>
    </JadeMethod>
</Class>
