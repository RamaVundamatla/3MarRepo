    <JadeMethod name="updateForCreate" id="1eea689e-47dd-413a-8ed9-0a844700dd6b">
        <updating/>
        <source>updateForCreate(_name : String; _updating : Boolean; _process : ProcessDescriptor) updating;

begin
	self.name := _name.trimBlanks;
	self.isUpdating := _updating;
	self.myProcessDescriptor := _process;
end;</source>
        <Parameter name="_name" type="String"/>
        <Parameter name="_updating" type="Boolean"/>
        <Parameter name="_process" type="ProcessDescriptor"/>
