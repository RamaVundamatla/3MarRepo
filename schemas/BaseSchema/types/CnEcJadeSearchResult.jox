    <PrimAttribute name="isText" id="37b03626-1e15-4e35-bc45-a18c6c54adf8">
        <embedded/>
        <type name="Boolean"/>
        <text>If true, the search got a result in the receiver's text.</text>
    </PrimAttribute>
    <ImplicitInverseRef name="myObject" id="13000e18-0708-4437-9ae6-6e41cbb5fa78">
