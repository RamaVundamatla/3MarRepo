    <JadeMethod name="setProxy" id="b36e13bc-8a31-41e8-bac2-66edaf8593ea">
        <updating/>
        <source>setProxy(_allocQuantity : Real;
		 _allocTypeStr : String;
		 _locnController : CM_LocationsController;
		 _sohLocation : CM_SOHLocation;
		 _stockOrderSummary : CM_StockOrderSummary) updating;
//--------------------------------------------------------------
//Created: 26 July 2002 By: cnwgd1
//--------------------------------------------------------------
vars

begin
	self.setProxyForAllocation(_allocQuantity, _allocTypeStr, _locnController, _sohLocation);
	self.myStockOrderSummary := _stockOrderSummary;
end;</source>
        <Parameter name="_allocQuantity" type="Real"/>
        <Parameter name="_allocTypeStr" type="String"/>
        <Parameter name="_locnController" type="CM_LocationsController"/>
        <Parameter name="_sohLocation" type="CM_SOHLocation"/>
        <Parameter name="_stockOrderSummary" type="CM_StockOrderSummary"/>
