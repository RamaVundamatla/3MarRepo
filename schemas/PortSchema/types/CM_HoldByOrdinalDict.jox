<CollClass name="CM_HoldByOrdinalDict" id="c20f4fea-8e0d-4b76-84bd-93295d630f5f">
    <memberType name="CM_Hold"/>
    <superclass name="CM_MemberKeyDictionary"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="vessel"/>
    <MemberKey>
        <property name="CM_Hold::ordinalHold"/>
    </MemberKey>
    <JadeMethod name="getDescription" id="90c73853-5ab2-4451-b415-51d625022fc2">
        <source>getDescription(_holds : Boolean) : String;
// ---------------------------------------------------------------------------
// Created:		March 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

	aHold : CM_Hold;
	aBay : CM_Bay;
	theString : String;
begin

	if _holds then	
		if self.size = 1 then
			theString := "Hold ";
		else
			theString := "Holds ";
		endif;
		foreach aHold in self do
			theString := theString &amp; aHold.ordinalHold.String.padLeadingZeros(2) &amp; " ";
		endforeach;
	else
		theString := "Bays ";
		foreach aHold in self do
			foreach aBay in aHold.allBays do
				theString := theString &amp; aBay.id &amp; " ";
			endforeach;
		endforeach;
	
	endif;
	return  theString;


end;</source>
        <Parameter name="_holds" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getShortDescription" id="241708c9-1cfd-45e9-a610-18c18a32ffeb">
        <source>getShortDescription() : String;
// ---------------------------------------------------------------------------
// Created:		March 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

	aHold : CM_Hold;
	theString : String;
	idx : Integer;

begin
	
	if self.size = 1 then
		theString := "Hold ";
	else
		theString := "Holds ";
	endif;
	foreach aHold in self do
		theString := theString &amp; aHold.ordinalHold.String.padLeadingZeros(2) &amp; " ";
		idx := idx + 1;
		if idx &gt; 4 then
			theString := theString &amp; "...";
			break;
		endif;
	endforeach;
	return  theString;


end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
</CollClass>
