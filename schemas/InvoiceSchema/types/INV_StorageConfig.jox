	_availYACriteria.add(app.myRoot.allYACriteriaTypes[YACriteriaType_SecondBarcodeId]);	// ### TFS 58429 (58517) 20Jun2023 NAVPW1
	_availYACriteria.add(app.myRoot.allYACriteriaTypes[YACriteriaType_Itemized]);			// ### TFS 58429 (58517) 20Jun2023 NAVPW1
	//14/08/2023	navkc1	Bug 59753
	_availYACriteria.add(app.myRoot.allYACriteriaTypes[YACriteriaType_ShippingLine]);
	
end;</source>
