    <JadeMethod name="zCloneMenu" id="5d6a712b-90c1-411b-ae64-8cea2bfe055c">
        <updating/>
        <source>zCloneMenu(_cloneMaster, _sourceMenu : MenuItem input; _loadAsSubMenu : Boolean): MenuItem updating, protected;
// ---------------------------------------------------------------------------
// Created:     22 July 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	oidStr	: String;
	newMenu	: MenuItem;
	invalidObject : Boolean;
	edition : Integer;
begin
	oidStr := _sourceMenu.description;
	if oidStr &lt;&gt; null then
		newMenu := oidStr.asOid.MenuItem;
	endif;

	on Exception do app.handleDeletedObject(exception,newMenu,invalidObject);
	
	if newMenu &lt;&gt; null then	//06 Oct 2015	NDL	Par 37011 - to cause the exc at the right time.
		edition := newMenu.edition;
	endif;
	
	if newMenu = null or invalidObject then
		self.clonedMenuCount := self.clonedMenuCount + 1;
		
		if _loadAsSubMenu then
			newMenu := _cloneMaster.loadSubMenu(self.clonedMenuCount);
		else
			newMenu := _cloneMaster.loadMenu(self.clonedMenuCount);
		endif;
		newMenu.userObject	:= _sourceMenu;
		
		_sourceMenu.description	:= newMenu.getOidString;
	endif;
	
	newMenu.caption 		:= _sourceMenu.caption;
	newMenu.checked 		:= _sourceMenu.checked;
	newMenu.disableReason	:= _sourceMenu.disableReason;
	newMenu.enabled			:= _sourceMenu.enabled;
	newMenu.helpContextId	:= _sourceMenu.helpContextId;
	newMenu.helpKeyword		:= _sourceMenu.helpKeyword;
	newMenu.picture			:= _sourceMenu.picture;
	newMenu.visible 		:= _sourceMenu.visible;
	
	return newMenu;
	
end;</source>
        <access>protected</access>
        <Parameter name="_cloneMaster" type="MenuItem" usage="input"/>
        <Parameter name="_sourceMenu" type="MenuItem" usage="input"/>
        <Parameter name="_loadAsSubMenu" type="Boolean"/>
        <ReturnType type="MenuItem"/>
    </JadeMethod>
    <JadeMethod name="zDoAdd" id="52473333-2ab2-4fc4-af45-80422d240554">
        <updating/>
        <source>zDoAdd() updating, protected;
// ---------------------------------------------------------------------------
// Created:     21 November 2000 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	idx	: Integer;
	breakOut	: Boolean;
begin
	//par 18625
	//when the user attempts to add an item if the thumbnail is hidden
	//it will show it.
	if self.isThumbnailVisible = false then
		self.hideShowThumbnail();
	endif;


	if self.allowUpdate = false then
		return;
	endif;
	
	if self.mode &lt;&gt; Mode_View then
		//Must not be already editing an object
		return;
	endif;
	self.clearErrorWarnings();
	
	self.zClearProxyDetails();
	self.myLastCurrentObject := self.myCurrentObject;
	self.myCurrentObject := null;
	self.zClearThumbnailData();				

	self.mode := Mode_Add;
	self.zSetControlsForAddEdit();
	
	if self.useTblData then
		self.createPlaceHolder();
		
		// Need to review if we need to add to dyna dict now that
		// not using list collection (rjs)
		self.addObjectToTable(self.myPlaceHolderObject, idx, breakOut);
		self.zTblDataSelectObject(self.myPlaceHolderObject);
	endif;

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="zDoCancel" id="a9c0bbfc-25b0-4daf-9b48-1d757170f97e">
        <updating/>
        <source>zDoCancel() updating, protected;
// ---------------------------------------------------------------------------
// Created:     31 January 2001 by cnwrs2
//
// Purpose:     Called when the cancel button is pressed.
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	saveOldMode 	: Integer;
begin

	app.mousePointer := Window.MousePointer_HourGlass;
	
	if (not self.doCancel()) then // AKB2003MAR added
		return;
	endif;

	saveOldMode := self.mode;
		
	self.zSetControlsForView();
	self.zClearProxyDetails();
	self.clearErrorWarnings();

	if self.useTblThumb then
		self.tblThumb.repositionAfterResize();
	endif;

	self.mode := Mode_View;	
		
	if saveOldMode = Mode_Update then
		self.zDoTblDataRefresh();
		if self.myCurrentObject &lt;&gt; null then
			self.zShowThumbnailData(self.myCurrentObject);
		else
			self.zClearThumbnailData();
		endif;

	elseif saveOldMode = Mode_Add then
		self.zClearPlaceHolderObject();
		// cancelled an add so reselect the last selected object
		if self.myLastCurrentObject &lt;&gt; null then 
			self.zTblDataSelectObject(self.myLastCurrentObject);
			self.myLastCurrentObject := null;
		else
			//if there is no previous object it means there no objects at all in the table, so clear the table
			self.tblData.clearAllData();
		endif;
	endif;

	if self.initialMode = Mode_Add then
		//As per Richard Smith 19/11/04
		self.unloadForCancel(saveOldMode);
	endif;
		
epilog
	app.mousePointer := Window.MousePointer_Default;
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="zDoDelete" id="65e54fda-1cb5-48d2-b0a5-bc116ed07f77">
        <updating/>
        <source>zDoDelete() updating, protected;
// ---------------------------------------------------------------------------
// Created:     02 March 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	selectedItemDescr,
	msgStr			: String;
	row				: Integer;
	idx	: Integer;
	selectedObj 	: Object;
begin

	self.doingMultiDelete := false;
	
	selectedItemDescr := self.getSelectedItemDescr();
	
	if self.multiSelect &lt;&gt; CM_BaseTable.MultiSelect_None and
	   tblData.allSelectedObjects.size &gt; 1 then
	   	if (not self.allowMultiSelectDelete) then
	   		app.msgBox(app.getErrorString(Please_Select_An_Item_Fiirst), app.getErrorString(Error), MsgBox_OK_Only + MsgBox_Information_Icon);
	   		return;
	   	endif;
	   	self.doingMultiDelete := true;
		if selectedItemDescr = null then
			selectedItemDescr := 'these items';
		endif;
	   	self.myCurrentObject := tblData.allSelectedObjects.last.CM_Object;
	else
		if selectedItemDescr = null then
			selectedItemDescr := 'the selected item';
		endif;
	endif;

	msgStr := app.getErrorString2(ConfirmDelete, '', selectedItemDescr);

	if self.myCurrentObject &lt;&gt; null then
		if (not self.canDoDelete()) then
			return;
		endif;
		if app.msgBox(msgStr, 'Confirm Deletion', MsgBox_Yes_No + MsgBox_Question_Mark_Icon + MsgBox_Default_Second) = MsgBox_Return_Yes then
			if self.doDelete() then
				idx := tblData.row;
				// may need to redisplay table here!
				//will need to redisplay table as item has been deleted
				self.tblData.removeDeletedObject(self.myCurrentObject);
				self.myCurrentObject := null;
				
				
				//selectedObj := self.zSetRowAfterDelete(idx);
			
				if self.doingMultiDelete then //cnwrd1 par 21358 16.10.09
					// multi delete and we could have deleted the one above too!
					selectedObj := self.zSetRowAfterMultiDelete(idx);
				else
					//Move to the row that was immediately above the deleted object.
					selectedObj := self.zSetRowAfterDelete(idx);
				endif;

				if selectedObj &lt;&gt; self.myPlaceHolderObject then
					self.zShowThumbnailData(selectedObj);
				else
					self.zShowThumbnailData(null);
				endif;
			endif;
		endif;
	else
		app.msgBox(app.getErrorString(Please_Select_An_Item_Fiirst), 'Error', MsgBox_OK_Only);
	endif;

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="zDoEdit" id="75bd4015-b829-41bb-b635-ad307cdcb515">
        <updating/>
        <source>zDoEdit() updating, protected;
// ---------------------------------------------------------------------------
// Created:     16 November 2000 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//	17/5/01			AA		Can only start edit if in view mode &amp; updates allowed
// ---------------------------------------------------------------------------
vars
//	obj			: Object;
//	tmpProxy	: CM_Object;

begin 
	//par 18625
	//when the user attempts to edit an item if the thumbnail is hidden
	//it will show it.
	if self.isThumbnailVisible = false then
		self.hideShowThumbnail();
	endif;

	if (self.allowUpdate = false) or
	   (self.mode &lt;&gt; Mode_View) then 
		//Must not be already editing an object
		return;
	endif;
	
	self.clearErrorWarnings();
	self.zClearProxyArray;

	self.setDoingMultiEdit();
	
	if (not self.doPreEditValidation())  then
		return;
	endif;
	
	if self.myCurrentObject &lt;&gt; null then
		self.createProxiesForEdit();
		// Redisplay to ensure latest version of object is shown
		// app.createUpadteProxy will have ensured latest version is in cache
		//self.zShowThumbnailData(self.myCurrentObject);
		self.mode := Mode_Update;

		// WAS GETTING MULTIPLE LOADS. TOOK THIS OUT, BUT MAY NEED TO PUT BACK IF THERE ARE REPERCUSSIONS.
		// need to reshow data as might have changed.  Some forms edit in same controls as are used
		// to display the thumbnail.
		// *** this reshow should be done in the forms setControlsForAddEdit method
		self.zShowThumbnailData(self.myProxyObject);	// changed RJS as should be the proxy which is updated
		
		// With latest version confirm that the object can be editted.
		if self.canDoEdit() then
			self.zSetControlsForAddEdit();
		else
			self.zDoCancel();
		endif;
	else
		app.msgBox('Cannot perform edit as there is no item selected.', 'Error', MsgBox_Stop_Icon  + MsgBox_OK_Only);
	endif;

epilog
//process.profilerStop;
//process.profilerReport('d:\cnwdmast\logs\edit.log');
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="zDoNext" id="59d4a79a-3f61-4968-bd58-2551890ffd3b">
        <updating/>
        <source>zDoNext() : Boolean updating, protected;
// ---------------------------------------------------------------------------
// Created:     08 March 2001 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	cont	: Boolean;
	idx		: Integer;
	theRow	: Integer;
	breakOut	: Boolean;	
begin

	if self.mode &lt;&gt; Mode_Add then
		app.raiseUnexpectedProgramError(class.name, method.name, 'You can only do a Next when adding');
		return false;
	endif;

	app.mousePointer := Window.MousePointer_HourGlass;


	if self.doSave() then
		self.clearErrorWarnings();
		if self.useTblData then
			self.zClearPlaceHolderObject();
			self.zClearProxyDetails();
			
			if self.myCurrentObject &lt;&gt; null
			and (not self.tblData.findObjectInRow(self.myCurrentObject, theRow))
			and self.includeObject(self.myCurrentObject, app.myPassport) then
				
				self.addObjectToTable(self.myCurrentObject, theRow, breakOut);
				self.needTblDataRefresh := true;
				tblData.allSelectedObjects.add(self.myCurrentObject);
				
			else
				// always force a redisplay (this should never happen).
				self.zTblDataSelectObject(null);
			endif;

			if self.needTblDataRefresh then
				self.zDoTblDataRefresh();
			endif;
		endif;

		self.zSetControlsForNext();

		return true;
	else
		return false;
	endif;

epilog
	app.mousePointer := Window.MousePointer_Default;

end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="zDoPrintCurrent" id="cd35e611-08d2-4fed-8426-a9ebc5cbe7d8">
        <updating/>
        <source>zDoPrintCurrent() updating, protected;
// ---------------------------------------------------------------------------
// Created:     24 May 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 17 Mar 2008	cnwkpd1		PAR #16145 - Handle row exceptions in table printing
// ---------------------------------------------------------------------------
vars

begin
	//AA 20/6/01: Protects against object being deleted from under us by a notification
	if not global.isValidObject(myCurrentObject) then
		myCurrentObject := null;
	endif;
	
	if self.myCurrentObject = null then
		app.msgBox(app.getErrorString(Please_Select_An_Item_Fiirst), 'Error', MsgBox_OK_Only + MsgBox_Stop_Icon);
		return;
	endif;
	
	on Exception do self.handlePrintTableRowException(exception);		// PAR #16145
	
	self.doPrint();
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="zDoResetSearcher" id="436000c0-de47-473c-9f83-67ff440b7bd0">
        <updating/>
        <source>zDoResetSearcher() updating, protected;
// ---------------------------------------------------------------------------
// Created:     19 January 2001 by cnwrs2
//
// Purpose:     This clears the filtered data and reload the table.
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	app.mousePointer := MousePointer_HourGlass;
	self.zClearThumbnailData();
	self.isDataFiltered := false;

	self.tblSearch.clearValues();
	self.setFilterDefaults();		// overridden in sub-form to set the values

	if self.filterAppliesToThumbnail then
		self.zShowThumbnailData(self.myCurrentObject);
	else
		self.tblData.clearAllData();
		self.doResetSearcher();
	endif;
	
	if self.isSearcherFloating then
		self.tblSearch.moveFirst();
		self.tblSearch.setFocus();
	endif;
	
	//self.lblFiltered.visible := false;

epilog
	app.mousePointer := MousePointer_Default;

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="zDoSave" id="cdbd43fa-09b3-4cf0-8450-fd582012bb78">
        <updating/>
        <source>zDoSave() : Boolean updating, protected;
// ---------------------------------------------------------------------------
// Created:     08 March 2001 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
/*

Date		Who		Reason
19 May 2010	cnwkpd1	PAR #20728 - remove isValidObject calls for performance
29/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
*/

vars
	cont	: Boolean;
	numRows,
	idx		: Integer;
	theRow	: JadeTableRow;
	invalid : Boolean;
	rowObj	: Object;
	ed		: Integer;
	
begin

	app.mousePointer := Window.MousePointer_HourGlass;

	self.addUpdateTransactionComplete := false;

	if self.doSave() then
		self.addUpdateTransactionComplete := true;
		self.zClearPlaceHolderObject();
		self.zClearProxyDetails();
		self.zSetControlsForView();
		self.clearErrorWarnings();

		if self.mode = Mode_Add then
			if self.myCurrentObject &lt;&gt; null then
				self.zHandleObjectAdd();
				tblData.selectObject(self.myCurrentObject, true);
			else
				// always force a redisplay (this should never happen (Oh yes it does, when adding a new terminal)).
				self.zTblDataSelectObject(null);
			endif;

		elseif self.mode = Mode_Update then
			// redisplay any rows on the table that may have been updated
			numRows := tblData.rows;
			
			on Exception do app.handleDeletedObject(exception, rowObj, invalid);
			
			foreach idx in 1 to numRows do
				theRow := tblData.accessRow(idx);
				if theRow.selected then
					rowObj := theRow.itemObject;
//					if global.isValidObject(theRow.itemObject) then
					if rowObj &lt;&gt; null then
						invalid := false;
						ed := rowObj.edition();		// Dereference to check it is valid
						if not invalid then
							tblData.accessCell(idx, 1).text := self.zTblDataDisplayRow(tblData, rowObj);
						endif;
					endif;
				endif;
			endforeach;
			
			on Exception do null;
			
		endif;

		self.zDoTblDataRefresh();
		self.mode := Mode_View;
		self.zShowThumbnailData(self.myCurrentObject);

		return true;
	else
		return false;
	endif;

epilog
	app.mousePointer := Window.MousePointer_Default;

end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="zDoSearch" id="46bf806a-1741-4621-9066-0f0cfb09b311">
        <updating/>
        <source>zDoSearch() updating, protected;
// ---------------------------------------------------------------------------
// Created:     19 January 2001 by cnwrs2
//
// Purpose:     Filters the data.  This should be overridden at the lower level to
//				do the actual filtering of the data.
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 07 Oct 2024  navsp1      JIRA 20762 EUP | General Testing - Search on Client Ref on User Screens
// ---------------------------------------------------------------------------
vars
	tmpStr                  : String;
	processStackArray       : ProcessStackArray;
	methodCallDesc          : MethodCallDesc;
begin
	//
	// Check that no one else is instrumenting
	//
	if app.myCnTransactionStack.tags.isEmpty() then
		// PAR 21787
		create processStackArray transient;
		process.currentStack(processStackArray);
	
		if processStackArray.size &gt; 2 then
			methodCallDesc := processStackArray[3];
			tmpStr := methodCallDesc.method.qualifiedName;
		else
			tmpStr := method.qualifiedName;
		endif;
		
		self.cnStartTransaction(tmpStr[1:50]);
	endif;

	app.mousePointer := MousePointer_HourGlass;
	
	if self.isSearcherFloating and self.isSearcherVisible then
		self.zHideSearcher();
	endif;

	app.myPassport.myActivityCapture.startCaptureSearch(self.String);
	
	self.zClearThumbnailData();
	
	if not self.validateForm() then	//JIRA 20762
		return;						//JIRA 20762
	endif;							//JIRA 20762
	
	// Need to move below lines to a general "initSearch" method
	self.mode 				:= Mode_Search;
	self.numItemsShown		:= 0;
	self.numItemsSearched	:= 0;
	self.isDataFiltered 	:= true;
	self.modalDialogReturnValue	:= ModalDialogReturn_Null;
	self.modalDialogShow(null, app.getErrorString(Cancel), null, null, app.getErrorString(SearchingForData), null);
	// to here

	self.setFilterValues();
	
	if self.filterAppliesToThumbnail then
		self.zShowThumbnailData(self.myCurrentObject);
	else
		self.zTblDataSortAndShow(true);
		self.postSearchProcessing();

		if self.numItemsShown = 0
		and self.isSearcherFloating
		then
		// as no items were found reshow the filter
			self.zShowSearcher();
		endif;
	endif;
epilog
	self.frmModalDialog.visible := false;
	self.mode := Mode_View;
	app.mousePointer := MousePointer_Default;
	app.myPassport.myActivityCapture.stopCaptureSearch();

	// PAR 21787
	if processStackArray &lt;&gt; null then
		processStackArray.purge();
		delete processStackArray;
	endif;

	if tmpStr &lt;&gt; null then
		self.cnEndTransaction();
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="zDoTableDataContextMenu" id="c3c9f346-e3e1-42f3-9c37-43c82e82ca62">
        <updating/>
        <source>zDoTableDataContextMenu(cntrl: Table input; conwin: Window input; mouse: Boolean; x: Integer; y: Integer) : Boolean protected, updating;

vars

begin
	if self.mode &lt;&gt; Mode_View then
		//disallow context menu whilst editing
		return false;
	endif;

// refer to notes in CM_TableViewForm::contextMenu for adding to this context menu

	return self.doMnuFormContextMenu(conwin, mouse, x, y);
	
end;</source>
        <access>protected</access>
        <Parameter name="cntrl" type="Table" usage="input"/>
        <Parameter name="conwin" type="Window" usage="input"/>
        <Parameter name="mouse" type="Boolean"/>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="zDoTblDataRefresh" id="96f49083-cf20-40a3-ab08-afe5f840459e">
        <updating/>
        <source>zDoTblDataRefresh() updating, protected;
// ---------------------------------------------------------------------------
// Created:     11 May 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	theObj	: Object;
begin

	if (not self.useTblData) then
		return;
	endif;

 	if self.needTblDataRefresh then
		self.needTblDataRefresh := false;
		if self.myCurrentObject = null then
			theObj := tblData.accessRow(tblData.topRow).itemObject;
		else
			theObj := self.myCurrentObject;
		endif;
		// hmmm - need to determine how best to redisplay the
		// table at this point - maybe do a resynch on all
		// objects in the table ???
		//self.zTblDataShowData(theObj);
		self.zTblDataSelectObject(theObj);
	endif;

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="zDoThumbnailContextMenu" id="d08e032d-6989-456b-930c-921dca16c27a">
        <updating/>
        <source>zDoThumbnailContextMenu(x,y : Integer; mouse : Boolean) : Boolean protected, updating;
// ---------------------------------------------------------------------------
// Created:  May  2001 By Andrew Bishop cnwab1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

/*
Date		      Who		Reason
30 June 2008	cnwdz2	    Par17352 - Context menu is attached to the table thumb.
*/

vars

begin
	if self.mode &lt;&gt; Mode_View then
		//disallow context menu whilst editing
		return false;
	endif;
	
	return self.doMnuFormContextMenu(tblThumb,mouse, x, y);
end;</source>
        <access>protected</access>
