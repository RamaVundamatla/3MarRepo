    <JadeMethod name="doCSVFilename" id="c4fcdf84-215a-4179-bcf6-319c7196121d">
        <source>doCSVFilename(_eTDefRow : String; _filePath : String ; _ssDef : String);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
10 December 2009	cnwas3	Initial creation

*/

vars
	filePath : String;
begin
	if _filePath &lt;&gt; null and _ssDef &lt;&gt; null then
		filePath := _filePath;
		
		if _filePath[_filePath.length()] &lt;&gt; "\" then 
			filePath := _filePath &amp; "\";
		endif;
		
		self.tblTaskCreation.setValueByName(_eTDefRow, filePath &amp; _ssDef &amp; "_YYYYMMDDHHMM.csv");
	else
		self.tblTaskCreation.setValueByName(_eTDefRow, null);
	endif;
	
epilog

end;</source>
        <Parameter name="_eTDefRow" type="String"/>
        <Parameter name="_filePath" type="String"/>
        <Parameter name="_ssDef" type="String"/>
    </JadeMethod>
    <JadeMethod name="doCancel" id="669e0215-53e1-4452-9f45-94f734eecc49">
        <updating/>
        <source>doCancel() protected, updating;

// cnwdvb1 15 January 2003
// Date			Who		Reason
// 25/07/2025	jlizm1	MTN 35372 Add table filter to auto schedule form

vars

begin

	delete self.myProxyAutoSchedule;
	if self.typeOfSheet = self.Sheet_Schedule then
		self.doLoadSchedules();
		self.tblSchedules.setFocus();
	else
		self.doLoadTasks();
		self.tblTaskDisplay.setFocus();
	endif;
//	self.changeButtonStates();
	self.state := self.State_View;

	self.frmTableFilter.doTableFilter();
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doDelete" id="22459550-e3fc-4e3e-96c7-dac70cbd5f1d">
        <updating/>
        <source>doDelete() protected, updating;

// cnwdvb1 15 January 2003 
// 27 May 2015	cnwrs1	Par 36285 Make the BGP Auto Schedule Form multiselect
// 25/07/2025	jlizm1	MTN 35372 Add table filter to auto schedule form
vars
	schedule		: CM_AutoSchedule;
	msgStr			: String;
	obj : Object;
begin
	if self.tblSchedules.allSelectedObjects.size &gt; 0 then
		foreach obj in self.tblSchedules.allSelectedObjects do
			schedule := obj.CM_AutoSchedule;
//	schedule := self.getSelectedSchedule();
			if schedule &lt;&gt; null then
				msgStr := app.getErrorString2(ConfirmDelete, 'schedule', schedule.description);
				if app.msgBox(msgStr, app.getErrorString(ConfirmDeletion), MsgBox_Yes_No + MsgBox_Question_Mark_Icon ) = MsgBox_Return_Yes then
					app.myTrxDA.trxDeleteAutoSchedule(schedule,app.myPassport);
				endif;
			endif;
		endforeach;
		self.doLoadSchedules();
	endif;
	
	self.frmTableFilter.doTableFilter();
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doDeleteTask" id="92af4cda-27d2-408c-84a1-495af7f58abe">
        <updating/>
        <source>doDeleteTask() updating, protected;

// cnwdvb1 16 January 2003
// Date			Who		Reason
// 25/07/2025	jlizm1	MTN 35372 Add table filter to auto schedule form

vars

	realTask 		: CM_AutoTask;
	expectedEdition	: Integer;
	msgStr			: String;

begin

	if not self.isNewTask and self.mySelectedAutoTask &lt;&gt; null then
		if self.mySelectedAutoTask &lt;&gt; null then
			msgStr := app.getErrorString2(ConfirmDelete, 'task', self.mySelectedAutoTask.description);
			if app.msgBox(msgStr, app.getErrorString(ConfirmDeletion), MsgBox_Yes_No + MsgBox_Question_Mark_Icon ) = MsgBox_Return_Yes then
				app.myTrxDA.trxDeleteAutoTask(self.mySelectedAutoTask,app.myPassport);
				self.doLoadSchedules();
				self.doLoadTasks();
			endif;
		endif;
	endif;
	
	self.frmTableFilter.doTableFilter();

end;</source>
        <access>protected</access>
    </JadeMethod>
