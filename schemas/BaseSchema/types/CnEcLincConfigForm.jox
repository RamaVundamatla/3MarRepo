    <JadeMethod name="load" id="73ccde17-8df5-4289-b004-4520d8dc0035">
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>/*******************************************************
*
* Description :	Trap exceptions when deleting database
*				objects
*
* Parameters :	e		Exception code
*
* Return :		Indicates following action :
*				continue | abort | propagate error
*
* Notes :		Modified from handler produced by Jade
*				Form Wizard
*
* History :		rmb	12/12/96	Initial version
*
*******************************************************/
load() updating;

vars
	root		: CnEcLincDefRoot;

begin
	centreWindow();

	// Set the Linc system root. Create one if it doesn't already exist
	root := CnEcLincDefRoot.firstInstance;

	// Handle database create/update exceptions
	on SystemException do saveExceptionHandler(exception);
	on LockException do saveExceptionHandler(exception);

	if root = null then
		beginTransaction;
			// No Linc systems currently defined, creating a system root
			create root;
		commitTransaction;
	endif;

	// Set the currently selected Linc definition to the first in the list
    setCurrentLincSystem(null);
	populateAllControls();

	// Set the combo edit area to display the selected item
	if CnEcLincDefRoot.firstInstance.allLincSystemDefs.size() &gt;= 1 then
		comboLincSystem.listIndex := 1;
	endif;

	// Set the combo edit area to display the selected item
	if currentLincSystem &lt;&gt; null then
		if currentLincSystem.allLincIspecDefs.size() &gt;= 1 then
			comboIspec.listIndex := 1;
		endif;
	endif;

	// disable the updating button

	btnOK.enabled := false;
end;</source>
    </JadeMethod>
