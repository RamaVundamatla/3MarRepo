    <JadeMethod name="pxyCreateUpdateProxy" id="517c1cfb-071f-4429-922b-1faee3d95240">
        <source>pxyCreateUpdateProxy(): SelfType;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 July 2022	navds20	ChangeRequest 53862: EUP - WMS - Damage Recording Extra Details

*/

vars

	pxyRelByTypeCrit : CM_StopCriteria;
	completedOK : Boolean;

begin

	pxyRelByTypeCrit := inheritMethod();
	
	completedOK := true;
	
	return pxyRelByTypeCrit;

epilog

	if not completedOK then
		delete pxyRelByTypeCrit;
	endif;

end;</source>
        <ReturnType type="SelfType"/>
