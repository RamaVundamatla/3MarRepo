<Class name="WS_OnsiteCargoIdentifier" id="26967d99-b18a-423e-bedc-2d6919d48be6">
    <superclass name="WS_ProxyObject"/>
    <transient/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>Contains the keys required to exclusively identify any
individual cargo item that is on-site.
Generally 'cargoId' is sufficient, however duplicates are
permitted on-site where a items have different a 'cargoType'
Additionally if a specific 'cargoType' is set to 'allowDuplicates'
then items with the same 'cargoId' and 'cargoType' are permitted
on site in parallel, if the individual locations of those items 
is different.
So the minimum data to uniquely identify a cargo item is its 'cargoId'
however it is possible this will be insufficient.</text>
    <DbClassMap file="webservice"/>
    <PrimAttribute name="cargoId" id="17006898-a145-477c-84ec-96ce38467e0b">
        <length>31</length>
        <embedded/>
        <type name="String"/>
        <access>readonly</access>
        <text>The primary key that would lead to uniquely identifying
a piece of on-site cargo.</text>
    </PrimAttribute>
    <ImplicitInverseRef name="cargoType" id="4c0d4e8a-a2a7-43c3-a814-b6ddbe8d0c03">
        <embedded/>
        <type name="WS_CargoType"/>
        <access>readonly</access>
        <text>The secondary key that would lead to uniquely identifying
a piece of on-site cargo.</text>
    </ImplicitInverseRef>
    <PrimAttribute name="locnActual" id="aa6d3b7c-0b1d-45c7-9fa9-42f419150882">
        <type name="String"/>
        <access>readonly</access>
        <text>The tertiary key that would lead to uniquely identifying
a piece of on-site cargo. The actual on-site location.</text>
    </PrimAttribute>
    <JadeMethod name="delete" id="e8b19846-1eaa-4420-aa95-5cdf6e7b2bb4">
        <updating/>
        <source>delete() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 September 2015	cnwndl1	Initial creation	Par 36951

*/

vars

begin

	delete self.cargoType;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="findMatchingCargoItem" id="47b79c94-d61f-437a-b38f-5615fc645c43">
        <source>findMatchingCargoItem( _terminal : CM_Terminal ):CM_TrackedItem;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25 September 2015	cnwndl1	Initial creation	Par 36951
// 06 Sep 2016	cnwrs1	TFS 2586 dont always include archived voyages and lookup reveresed even if we found data in non reverese lookup
*/

vars

	tiSet : CM_TISet;
	ti : CM_TrackedItem;
	cargoTypeId : Integer;

begin

	if self.cargoType &lt;&gt; null then
		cargoTypeId := self.cargoType.id;
	endif;

	create tiSet transient;
	_terminal.lookupAllOnsiteTrackedItems(	cargoTypeId,	//_cargoType : Integer;
											self.cargoId	,	//_id : String; 
											tiSet,	//_tis : Btree input; 
											false,
											null	//_cmifMonitor : CMIF_Monitor input
											);
											
	if tiSet.size = 1 then
		ti := tiSet.first;
		//22 Feb 2016	NDL	Par 37563
		if ti.id &lt;&gt; self.cargoId then
			return null;
		endif;
		if self.locnActual = null or ti.myPrimaryActualLocation.getFullId = self.locnActual then
			return ti;
		else
			return null;
		endif;
	
	elseif tiSet.isEmpty then
		return null;
		
	else
		foreach ti in tiSet do
			//22 Feb 2016	NDL	Par 37563
			if ti.id &lt;&gt; self.cargoId then
				continue;
			endif;
			if self.locnActual = null or ti.myPrimaryActualLocation.getFullId = self.locnActual then
				return ti;
			endif;
		endforeach;
		return null;
		
	endif;

epilog

	delete tiSet;

end;</source>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <ReturnType type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="setProxyFromObject" id="225d270e-d252-4f2f-9d6c-3e5fcd3372fb">
        <updating/>
        <source>setProxyFromObject(obj: CM_TrackedItem) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 September 2015	cnwndl1	Initial creation	Par 

*/

vars

	realCargoType : CM_CargoType;

begin

	inheritMethod(obj);
	
	self.cargoId := obj.id;
	
	realCargoType := obj.myCargoType;
	if realCargoType &lt;&gt; null then
		create self.cargoType transient;
		self.cargoType.setProxyFromObject(realCargoType);
	endif;
	
	self.locnActual := obj.locationId;
	
	
epilog

end;</source>
        <Parameter name="obj" type="CM_TrackedItem"/>
    </JadeMethod>
</Class>
