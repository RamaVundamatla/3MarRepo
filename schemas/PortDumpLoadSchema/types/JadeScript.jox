	self.importObjects(CM_WarehouseRowArea, dirName, 0, deleteAll);
	self.importObjects(CM_Rail, dirName, 0, deleteAll);
	self.importObjects(CM_YardTransferArea, dirName, 0, deleteAll);
	self.importObjects(CM_CraneTransferArea, dirName, 0, deleteAll);
	self.importObjects(CM_Crane, dirName, 0, deleteAll);
	self.importObjects(CM_Vehicle, dirName, 0, deleteAll);
	
// auto planning
	self.importObjects(CM_YardAllocation, dirName, 0, deleteAll);
	self.importObjects(CM_YACriteria, dirName, 0, deleteAll);
	self.importObjects(CM_YAPriority, dirName, 0, deleteAll);

//	self.importObjects(CM_CellularVoyage, dirName, 0, deleteAll);

	self.importObjects(CM_CamProtocol, dirName, 0, deleteAll);
	self.importObjects(CM_CodeGroup, dirName, 0, deleteAll);
//rs	self.importObjects(CM_DataAccessController, dirName, 0, deleteAll);
//rs	self.importObjects(CM_ExternalOrganisation, dirName, 0, deleteAll);
//	self.importObjects(CM_InternalOrganisation, dirName, 0, deleteAll);
//rs	self.importObjects(CM_LineGroupDebtor, dirName, 0, deleteAll);
	//self.importObjects(CM_Teklogix_Narrow, dirName, 0, deleteAll);		// TFS #43007 - Remove Teklogix	jlgmd1 22/01/2019
//no file	self.importObjects(CM_TerminalAreaGroup, dirName, 0, deleteAll);
//	self.importObjects(CM_ToDoTaskDescGroup, dirName, 0, deleteAll);
	self.importObjects(CM_Xlation, dirName, 0, deleteAll);
//rs	self.importObjects(CM_YardTransferArea, dirName, 0, deleteAll);

	result := true;
epilog
	if result then
		write "Fin Successfully.";
	else
		write "Fin failure.";
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="importObjects" id="3ce2e4a7-f7d7-47f9-8010-b596c39d07f8">
        <source>importObjects(_classNew: Class; _dirName: String; _phase: Integer; _deleteAll : Boolean) protected;
// ---------------------------------------------------------------------------
// Created:     10 March 2004	cnwrs1
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	file: File;
	attributeBlock,
	classTag,
	classTagEnd,
	classBlock,
	lineStr: String;
	newObj: Object;
	cnt: Integer;
	fileName: String;
	result: Boolean;	
	objArray: ObjectArray;
	object: Object;
	countError, countOK: Integer;
	classXMLName: String;
	methodName: String;
	agent : DEV_LoadAgent;
begin
	result := false;
	classXMLName := _classNew.name;
	fileName := _dirName&amp;classXMLName&amp;'.xml';
	create agent transient;
	create file transient;
	file.fileName := fileName;
	if not file.isAvailable() then
		write("fileName "&amp;fileName&amp;" was not found.");
		return;
	endif;
	file.kind := File.Kind_Unknown_Text; // 4/3/16  cnwns1 PAR 36286 unicode version
	file.openInput(fileName);
	
	if classXMLName = null then
		app.raiseUnexpectedProgramError(classXMLName, method.name, 'Class name passed in is null');
		return;
	endif;
	write classXMLName&amp;" to "&amp;_classNew.name;
	
//	class := currentSchema.getClass(_classNew.name);
	if _classNew = null then
		app.raiseUnexpectedProgramError(_classNew.name, method.name, 'Class with name "'&amp;_classNew.name&amp;'" could not be found');
		return;
	endif;
	
	create objArray transient;
	if _phase = 0 then //only do this once per run
		_classNew.allInstances(objArray, 0, false);
		if _deleteAll then
			beginTransaction;
			foreach object in objArray do
				delete object;
			endforeach;
			commitTransaction;
		endif;
	endif;

	classTag := '&lt;'&amp;classXMLName&amp;'&gt;';
	classTagEnd := '&lt;/'&amp;classXMLName&amp;'&gt;';
	app.writeLog('Started importing instances of '&amp;classXMLName&amp;' at '&amp;app.actualTimeServer.String, LogINFO);
	countError := 0;
	countOK := 0;
	
	while not file.endOfFile do
		lineStr := file.readLine();
		
		if lineStr = classTag then
			classBlock := classTag&amp;CrLf;
		else
			classBlock := classBlock&amp;lineStr&amp;CrLf;
		endif;
//write lineStr&amp;' '&amp;classTagEnd;		
		if lineStr = classTagEnd then
			
			attributeBlock := classBlock.cnEcGetTagValueOfName(classXMLName&amp;'Attributes');
			
			cnt := cnt + 1;
			create newObj as _classNew transient;
			newObj.importPLXML(classXMLName, classBlock);
			if _classNew.name[1:3] = "CM_" then
				methodName := "load"&amp;_classNew.name[4:_classNew.name.length];
			elseif _classNew.name[1:4] = "HMS_" then
				methodName := "load"&amp;_classNew.name[5:_classNew.name.length];
			elseif _classNew.name[1:5] = "CMIF_" then
				methodName := "load"&amp;_classNew.name[6:_classNew.name.length];
			else
				methodName := "loadObject";
			endif;
			result := agent.sendMsgWithParams(methodName, newObj).Boolean;
			if result then
				countOK := countOK + 1;
			else
				countError := countError + 1;
			endif;
			if cnt mod 200 = 0 then
				app.writeLog('Imported '&amp;cnt.String&amp;' instances of '&amp;_classNew.name&amp;' at '&amp;app.actualTimeServer.String, LogINFO);
			endif;
		endif;
	endwhile;
	file.close;
	
	app.writeLog('Finished importing instances of '&amp;_classNew.name&amp;' at '&amp;app.actualTimeServer.String, LogINFO);
	app.writeLog('Total instances of class '&amp;_classNew.name&amp;' input from file : '&amp;cnt.String, LogINFO);
	app.writeLog('  '&amp;_classNew.name &amp;' OK count='&amp;countOK.String&amp;' Error count='&amp;countError.String, LogINFO);
	write _classNew.name &amp;' OK count='&amp;countOK.String&amp;' Error count='&amp;countError.String;
	if countError &gt; 0 then
		write "***************************************************";
	endif;
epilog
	abortTransaction;
	delete file;
	delete objArray;
	delete agent;	
end;</source>
        <access>protected</access>
        <Parameter name="_classNew" type="Class"/>
        <Parameter name="_dirName" type="String"/>
        <Parameter name="_phase" type="Integer"/>
        <Parameter name="_deleteAll" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="importSingle" id="a8789a01-e19e-49f5-a886-98c80ecb38b4">
        <source>importSingle();
// ---------------------------------------------------------------------------
// Created:     18 March 2004	cnwrs1
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------

vars
	dirName: String;
	theUser: CM_User;
	result : Boolean;
	deleteAll	: Boolean;
begin
	dirName := DIR_NAME;
	
	on Exception do null global;
	app.initialize;
	app.isConverting := true; // ignore warnings
	app.myPassport.setMyTerminal(CM_Terminal.firstInstance);
	if theUser = null then
		theUser := CM_Root.firstInstance.allUsers[SUPERUSER_Str];
	endif;
	app.myPassport.setMyUser(theUser);
	app.myPassport.warningsAcknowledged	:= true;
	on Exception do null global;
	app.setPassBackExceptions(false, false);
	if dirName = null then
		dirName := 'C:\temp\';
	elseif dirName[dirName.length] &lt;&gt; '\' then
		dirName := dirName &amp; '\';
	endif;
	
	deleteAll	:= false;	// true means choose to delete all existing objects first
	self.importObjects(CM_ShipPortGroup, dirName, 0, deleteAll);
	result := true;
epilog
	if result then
		write "Fin Successfully.";
	else
		write "Fin failure.";
	endif;
end;
</source>
    </JadeMethod>
    <JadeMethod name="loadWharfDisplayOrder" id="b93b65e2-ad15-40cc-9d6d-dd250412f64b">
        <source>loadWharfDisplayOrder() protected;

vars
	wharf: HMS_Wharf;
	harbour: HMS_Harbour;
begin
	foreach harbour in HMS_Harbour.instances do
		beginTransaction;
		foreach wharf in harbour.allWharves reversed do 
			harbour.allWharfDisplayOrderArray.add(wharf);
		endforeach;
		commitTransaction;
	endforeach;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="processAllQueueTasks" id="fb2b8844-e857-42e6-a044-191582d52a7d">
        <source>processAllQueueTasks();

vars
	queueEntry: CM_RTQueueEntry;
	
	queueTask: CM_RTQueueTask;
	error: CM_Error;
	theUser: CM_User;
	taskArray, entryArray: ObjectArray;
	obj: Object;
	loopCount: Integer;
begin
	app.initialize;
	app.myPassport.setMyTerminal(CM_Terminal.firstInstance);
	if theUser = null then
		theUser := CM_Root.firstInstance.allUsers["SUPERUSER"];
	endif;
	app.myPassport.setMyUser(theUser);
	app.myPassport.warningsAcknowledged	:= true;

	create entryArray transient;
	create taskArray transient;
	foreach obj in CM_RTQueueEntry.instances do
		entryArray.add(obj);
	endforeach;
	foreach obj in entryArray do
		queueEntry := obj.CM_RTQueueEntry;
		if queueEntry.status = ENTRY_UNACTIONED or
		   queueEntry.status = ENTRY_USER_HELD then
			
			
			taskArray.clear();
			foreach queueTask in queueEntry.allTasks do
				taskArray.add(queueTask);
			endforeach;
			foreach obj in taskArray do
				queueTask := obj.CM_RTQueueTask;
				
				if not global.isValidObject(queueTask) then
					continue;
				endif;
				// Task can be deleted during process.
				if global.isValidObject(queueTask) then
					while true do
						loopCount := loopCount + 1;
						app.myTrxUA.trxUpdateQueueTaskStatus(queueTask, TASK_COMPLETE, app.myPassport);
						if app.myPassport.trxCompletedOK then
							// Clear errors/warnings from form and err/warnings window
	write class.name&amp;'::'&amp;method.name&amp;' '&amp;queueTask.String&amp;" OK";
							break;
						else
							foreach error in app.myPassport.allWarnings do
								write class.name&amp;'::'&amp;method.name&amp;' '&amp;queueTask.String&amp;" WARNING: "&amp;error.text;
							endforeach;
							foreach error in app.myPassport.allErrors do
								write class.name&amp;'::'&amp;method.name&amp;' '&amp;queueTask.String&amp;" ERROR: "&amp;error.text;
							endforeach;
							if app.myPassport.noErrors then
	//					   		result = IDOK then
								// there must have just been warnings that the user has acknoledged so ..
								app.myPassport.warningsAcknowledged	:= true;
								if loopCount &gt; 5 then
									break;
								endif;
								continue;
							else
								break;
							endif;
						endif;
					endwhile;
				endif;
			endforeach;
		endif;
	endforeach;
epilog
	delete entryArray;
	delete taskArray;
end;</source>
    </JadeMethod>
    <JadeMethod name="processConnectAllReefers" id="200f42e7-e197-4258-b0d8-b35bbdaf7d42">
        <source>processConnectAllReefers();
// 08/04/2011	cnwmh5	PAR #27347 - Add cmsEndLoad or endLoad to epilog so that if error occurs it will not leave it in beginLoad state
// 13 May 2016	cnwns1	TFS 488 - Multi Timezone Support
vars
	theUser: CM_User;
	ti: CM_TrackedItem;
	connectParams: CMIF_ConnectParams;
	nowTimeStamp: TimeStamp;
	index, conNum: Integer;
	error: CM_Error;
	loadState: Boolean;
begin
	app.initialize;
	on Exception do handleException(exception);
	app.setPassBackExceptions(true, true);
//	app.setPassBackExceptions(false, false);
//	theUser := CM_Terminal.firstInstance.users["SUPERUSER"];
	if theUser = null then
		theUser := CM_Root.firstInstance.allUsers["SUPERUSER"];
	endif;
	app.myPassport.setMyUser(theUser);
	app.myPassport.setMyTerminal(CM_Terminal.firstInstance);
	app.myPassport.warningsAcknowledged	:= true;
	app.myPassport.setIsBackgroundWarningsIgnored(true);

	create connectParams transient;
	connectParams.dateTime := app.actualTimeServer();	// 13 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	connectParams.noCharge := true;
	connectParams.myTerminal := app.getMyTerminalDO_NOT_USE();
//	the following is set in the trx when allTrackedItems is used or below for COUs	
//	connectParams.urNumber := aURNumber;
	connectParams.userId := app.getMyUserCode();
	connectParams.action := ACTION_CONNECT;
//	connectParams.gapController := self.myPowerPoint;
	connectParams.radioTelemetryIgnoreWarnings := true;
	connectParams.radioTelemetryUser := false;

	foreach ti in app.getMyTerminalDO_NOT_USE().allOnsiteTIsByCargoTypeId do
		if ti.cargoType = TI_CargoType_Container and
		   ti.CM_Container.requiresPower then
			app.cmsBeginLoad(loadState);
			connectParams.allTrackedItems.add(ti.pxyCreateUpdateProxy());
			app.cmsEndLoad(loadState);
		endif;
	endforeach;

	app.myTrxUA.trxUpdateConnect(connectParams, app.myPassport);

	if app.myPassport.trxCompletedOK and
	   app.myPassport.allErrorWarnings.size = 0 then
		write class.name&amp;'::'&amp;method.name&amp;' '&amp;ti.id&amp;" OK";
	else
		foreach error in app.myPassport.allWarnings do
			write class.name&amp;'::'&amp;method.name&amp;' '&amp;ti.id&amp;" WARNING: "&amp;error.text;
		endforeach;
		foreach error in app.myPassport.allErrors do
			write class.name&amp;'::'&amp;method.name&amp;' '&amp;ti.id&amp;" ERROR: "&amp;error.text;
		endforeach;
	endif;
epilog
	app.cmsEndLoad(loadState);		// 08/04/2011 cnwmh5 #27347
end;</source>
    </JadeMethod>
    <JadeMethod name="processCreateVTMSIVoyage" id="5ed06517-5357-4827-9887-208e84ecaf38">
        <source>processCreateVTMSIVoyage();
// ---------------------------------------------------------------------------
// Created:     14 January 2005 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	root: CM_TestDataRoot;
	pxyVoyage,
	realVoyage: CM_Voyage;
	tmpVessel: CM_Vessel;
	idx	: Integer;

begin	

	beginTransaction;
	CM_TestDataBerth.instances.purge;
	commitTransaction;
	
	app.initialize();
	app.myPassport.setMyUserFromCode('SUPERUSER');
	app.myPassport.setMyTerminal(CM_Terminal.firstInstance);

	root := CM_TestDataRoot.firstInstance;
	if root  = null then
		beginTransaction;
		create root persistent;
		commitTransaction;
	endif;
	
	foreach idx in 1 to 5 do
	
		delete pxyVoyage;
		create pxyVoyage as CM_Voyage transient;
		
		root.setupVTMISVoyageData(app.myPassport, pxyVoyage, tmpVessel);
		
		app.myTrxCA.trxCreateVoyage(pxyVoyage, realVoyage, tmpVessel, null, false, app.myPassport);
	
		if (not app.myPassport.trxCompletedOK) then
			app.showErrorsAsMsgBox(app.myPassport.allErrorWarnings, app.myPassport.noErrors);	
			break;
		else
			//realVoyage.inspect; 
		endif;
	endforeach;
epilog
	delete pxyVoyage;
end;</source>
    </JadeMethod>
    <JadeMethod name="processGateInReefers" id="b029ff51-4a5d-4e62-a6e6-c43e940685e2">
        <source>processGateInReefers();

vars
	theUser: CM_User;
	intFaceArray : CMIF_TIObjectArray;
	intFaceCommon : CMIF_InOutCommon;
	intFaceItem	: CMIF_Receival;
	index, conNum: Integer;
	error: CM_Error;
begin
	app.initialize;
	on Exception do handleException(exception);
	app.setPassBackExceptions(true, true);
//	app.setPassBackExceptions(false, false);
//	theUser := CM_Terminal.firstInstance.users["SUPERUSER"];
	if theUser = null then
		theUser := CM_Root.firstInstance.allUsers["SUPERUSER"];
	endif;
	app.myPassport.setMyUser(theUser);
	app.myPassport.setMyTerminal(CM_Terminal.firstInstance);
	app.myPassport.warningsAcknowledged	:= true;
	app.myPassport.setIsBackgroundWarningsIgnored(true);

	create intFaceCommon transient;
	intFaceCommon.myTerminal := app.getMyTerminalDO_NOT_USE();
	intFaceCommon.carrierCode := "AZTEC";
	intFaceCommon.regNumber := "NB1102";
	intFaceCommon.roadTransAreaId := "VTA";
	intFaceCommon.autoComplete := true;

	create intFaceArray transient;
	conNum := 4735500;
	foreach index in 1 to 80 do
		create intFaceItem as CMIF_Receival transient;
		intFaceItem.setMyInOutCommon(intFaceCommon);
		intFaceItem.myTerminal := intFaceCommon.myTerminal;
		while true do
			intFaceItem.id := "HLCW"&amp;conNum.stringWithLeadingZeros(7);
			conNum := conNum + 1;
			if conNum &gt; 4735990 then
				index := 100;
				break;
			endif;
			if app.checkDigitContainerId(intFaceItem.id) then
				break;
			endif;
		endwhile;
		intFaceItem.cargoType := TI_CargoType_Container;
		intFaceItem.imExStatus := app.myRoot.allImexStatuses[TI_IMEX_STATUS_EXPORT].CM_IMEXStatus;
		intFaceItem.isoType	:= "4232";
		intFaceItem.operatorCode := "PON";
		intFaceItem.voyageCode := "PNR0000";
		intFaceItem.commodity := "CHBF";
		intFaceItem.companyCode := "DFBU";
		intFaceItem.dischargePort := "HAL";
		intFaceItem.carriageTempC := -1;
		intFaceItem.weight := 22000;
		intFaceItem.weightTotal := 26000;
		intFaceItem.bookingReference := intFaceItem.id;
		intFaceArray.add(intFaceItem);
	endforeach;
	//app.myTrxCA.trxCreateInOutVehicle(intFaceCommon, app.myPassport);		//cnwmc5 - 22 Jan 2015 - PAR 35518
	app.myTrxCA.trxCreateInOut(intFaceCommon, intFaceArray, app.myPassport, null); //TFS 53107, AjitM, navam1
	if app.myPassport.trxCompletedOK and
	   app.myPassport.allErrorWarnings.size = 0 then
		write class.name&amp;'::'&amp;method.name&amp;' '&amp;intFaceItem.id&amp;" OK";
	else
		foreach error in app.myPassport.allWarnings do
			write class.name&amp;'::'&amp;method.name&amp;' '&amp;intFaceItem.id&amp;" WARNING: "&amp;error.text;
		endforeach;
		foreach error in app.myPassport.allErrors do
			write class.name&amp;'::'&amp;method.name&amp;' '&amp;intFaceItem.id&amp;" ERROR: "&amp;error.text;
		endforeach;
	endif;

end;</source>
    </JadeMethod>
    <JadeMethod name="processGeneral" id="e17a7bdc-dbb8-4ec9-bbab-cabf8230987c">
        <source>processGeneral();

vars
