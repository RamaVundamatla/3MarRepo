end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setForCreateInternal" id="1b2adb6f-4c4d-462b-874c-812237d665ab">
        <updating/>
        <source>setForCreateInternal(_releaseCargoJobParam : CMIF_WorkOrderJobParams;_terminal : CM_Terminal) updating;

/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 Jul 2022	navcs2	Initial creation ChangeRequest 53038: MTN - Work Order Maintenance Refactor - PortSchema
12 Apr 2023 navma1  ChangeRequest 57569:[57570] EUP - [Framework] Refactor Actioning Work Order Tasks
02 Jun 2023 navma1  ChangeRequest 58296: EUP - [Framework] Delivery Dispatch Screen - Linking Road Jobs
28 Jun 2023 navma1	Bug 58920: MTN - 1090 Exception when actioning the Release Cargo Work Order for Export Bookings
06 Jan 2024 navma1	Bug 62758: EUP | FR | Work Order status - complete without loading all items
*/



vars
	req        : CM_WOReleaseCargoRequest;
	wod        : CM_WorkOrderDtl;
	bulkReleae : CM_BulkRelease;
	reserve	   : CM_ReserveDetail;
begin

	inheritMethod(_releaseCargoJobParam, _terminal);									//02.06.2023 navma1 #58296
	//---------------
	//Build a Request
	//---------------
	create req;	
	req.setForCreateInternal(self, _releaseCargoJobParam);
	
	wod := self.myWODtl;
	if wod &lt;&gt; null then																	//18.04.2023 navma1 #57569:[57570]
		bulkReleae := wod.CM_WodRelease.myReleaseRequest;
		if bulkReleae &lt;&gt; null and bulkReleae.releaseByType then							//28.06.2023 navma1 #58920
			reserve := self.myWODtl.CM_WodRelease.myReserveDetail;
			if reserve &lt;&gt; null then
				req.setReserveDetail(reserve );
				req.setTotalRequested(reserve.totalRequested);							//06.03.2024 navma1 #62758
			endif;
		endif;	
	endif;
	//---------------
	//Build the WLEs' from the request.
	//---------------
	self.createWLEs();

end;</source>
        <Parameter name="_releaseCargoJobParam" type="CMIF_WorkOrderJobParams"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
    </JadeMethod>
</Class>
