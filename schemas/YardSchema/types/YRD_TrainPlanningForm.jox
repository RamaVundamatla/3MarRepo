    <JadeMethod name="doScrollToCorners" id="d7c2ed04-4e41-4267-b4b8-4e894dc7dcba">
        <source>doScrollToCorners(pCorner : Integer) protected;
// ---------------------------------------------------------------------------
// Created:     June 2009 - form cloned from YRD_RailOpsForm and YRD_GridAreasForm
//
// Purpose:		
//
// Parameters:  
//
// Returns:     
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 23/06/2009	consw1		PAR 19913 - SFW1067 Rail Simplifications
// ---------------------------------------------------------------------------
vars
	lHLabHeight, lVLabHeight,lFarRight, lFarBottom : Integer;
	lScrollBarV, lScrollBarH : Integer;
	theSDF : CMUI_ScrollableDrawingFrame;
	drawingFrame : CMUI_DrawingFrame;

begin
	theSDF := self.myCurrentSDF;
	if theSDF = null then
		return;
	endif;
	
	drawingFrame := theSDF.myDrawingFrame;
	if drawingFrame = null then
		return;
	endif;
	
	lFarBottom := drawingFrame.height.Integer - theSDF.height.Integer;
	lScrollBarV := drawingFrame.height.Integer;
	if theSDF.myHLabels.visible then
		lHLabHeight := theSDF.myHLabels.height.Integer;
	else
		lHLabHeight := 0;
	endif;
	lFarBottom := 1 - (lFarBottom + lHLabHeight);

	lFarRight := drawingFrame.width.Integer - theSDF.width.Integer;
	lScrollBarH := drawingFrame.width.Integer;
	if theSDF.myVLabels.visible then
		lVLabHeight := theSDF.myVLabels.width.Integer;
	else
		lVLabHeight := 0;
	endif;
	lFarRight := 1 - (lFarRight + lVLabHeight);

	if pCorner = VIEW_LEFT_TOP then
		lFarBottom := lHLabHeight;
		lScrollBarV := 1;
		lFarRight := lVLabHeight;
		lScrollBarH := 1;
	elseif pCorner = VIEW_RIGHT_TOP then
		lFarBottom := lHLabHeight;
		lScrollBarV := 1;
	elseif pCorner = VIEW_LEFT_BOTTOM then
		lFarRight := lVLabHeight;
		lScrollBarH := 1;
	elseif pCorner = VIEW_RIGHT_BOTTOM then
		// use defaults
	endif;
	// VERTICAL
	drawingFrame.top := lFarBottom;
	if theSDF.myVLabels &lt;&gt; null then
		theSDF.myVLabels.top := lFarBottom;
		theSDF.myHScroll.value := lScrollBarH;
	endif;
	// HORIZONTAL
	drawingFrame.left := lFarRight;
	if theSDF.myHLabels &lt;&gt; null then
		theSDF.myHLabels.left := lFarRight;
		theSDF.myVScroll.value := lScrollBarV;
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="pCorner" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="doTableClick" id="5ca1ed38-3658-4341-92c6-ca45820714d0">
        <updating/>
        <source>doTableClick(table: Table input) updating;
// ---------------------------------------------------------------------------
// Created:		January 2005 By Andrew Bishop cnwab1
//
// Purpose:		DO NOT DELETE Call back from CMUI_ColourLegendFrame
//
// ---------------------------------------------------------------------------
vars
	anObject : CM_Object;
begin

	// TFS 2198 CNWAB1
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		return;
	endif;

	if table = null then
		return;
	endif;
	if table.row &lt;= table.fixedRows then
		return;
	endif;

	if table.CM_ColourLegendTable.myCaller.CMUI_ColourLegendFrame.viewMode &lt;&gt; VIEW_YARD_ALLOC then
		return;
	endif;
	anObject := table.accessRow(table.row).itemObject.CM_Object ;

	self.doDisplayYardAllocation(anObject.CM_YardAllocation);
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doTableDblClick" id="a3a89e6a-da3a-4a06-9590-32de2c071512">
        <updating/>
        <source>doTableDblClick(table: Table input) updating;
// ---------------------------------------------------------------------------
// Created:		January 2005 By Andrew Bishop cnwab1
//
// Purpose:		DO NOT DELETE Call back from CMUI_ColourLegendFrame
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 16/06/2009	consw1		PAR 19913 - SFW1067 Rail Simplifications
// ---------------------------------------------------------------------------
vars
	anObject : CM_Object;
	aForm 	: Form;
	menuAction 		: CMUI_MenuAction;
begin

	// TFS 2198 CNWAB1
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		return;
	endif;

	if table = null then
		return;
	endif;
	if table.row &lt;= table.fixedRows then
		return;
	endif;

	anObject := table.accessRow(table.row).itemObject.CM_Object ;
	if anObject &lt;&gt; null then
		if anObject.isKindOf(CM_Voyage) then
			self.myAssistant.showVoyageDefForm(anObject.CM_Voyage, self.myMasterMenuAction, false, false);
		elseif anObject.isKindOf(CM_Train) then
			self.myAssistant.showTrainMaintenance(anObject.CM_Train, self.myMasterMenuAction, null, self);
		else
			self.myAssistant.showTableMaintForm(anObject, self.myMasterMenuAction, false, false);
		endif;
	endif;

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doTblInfoContextMnu" id="8bf9f368-f354-458e-a0f9-28dac1f4920b">
        <updating/>
        <source>doTblInfoContextMnu(table: Table input; conwin: Window input; mouse: Boolean; x: Integer; y: Integer): Boolean updating;
// ---------------------------------------------------------------------------
// Created:     June 2009 - form cloned from YRD_RailOpsForm and YRD_GridAreasForm
