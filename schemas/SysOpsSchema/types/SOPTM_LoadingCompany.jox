    <JadeMethod name="includeObject" id="6c7224b6-a5dc-4071-bfef-07a745718853">
        <updating/>
        <source>includeObject(_obj: Object; _passport: CM_Passport): Boolean updating;
// --------------------------------------------------------------------------------
// Created:		04 August 2006 by cnwdad1
//
// Purpose:		Refer to superclass implementation.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if self.includeNotAvailableEntries then
		return true;
	else
		return not _obj.CM_LoadingCompany.isNotAvailableForEntry;
	endif;
end;</source>
        <Parameter name="_obj" type="Object"/>
        <Parameter name="_passport" type="CM_Passport"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="initShtMultiSelect" id="3a8416da-d0cb-4fae-93f0-6420e10a4402">
        <source>initShtMultiSelect();
//------------------------------------------------
// Created: 06 April 2006 By: cnwgd1
//------------------------------------------------
vars
	theForm	: SOP_TableMaintForm;
	tmpCol : ObjectSet;
begin

	theForm := self.myForm;
	inheritMethod;	
	theForm.lstSingleSelect1.visible := true;
	
	create tmpCol transient;
	app.myRoot.getEmailAddresses(tmpCol,false);
	self.setupMultiSelect1("Contacts",tmpCol,SOP_TableMaintForm::displayEntryEmailAddress.name);	

epilog
	delete tmpCol;
end;</source>
    </JadeMethod>
