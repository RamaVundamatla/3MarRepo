    <JadeMethod name="splitUnactionedWLEs" id="08be7dec-53be-483f-aab5-eb67a18c567c">
        <updating/>
        <source>splitUnactionedWLEs(_newJob : CM_Job) updating;
//-----------------------------------------
//Created: April 2003 By: cnwgd1
//-----------------------------------------
// 24/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
vars
	ti			: CM_TrackedItem;
	tiSet		: CM_TISet;
	yardWle		: CM_YardWLE;
	wle 		: CM_WorkListEntry;
	iter	 	: Iterator;
	newRequest 	: CM_DeliveryRequest;
	rJob2 		: CM_RailJob;
	newTotReq	: Integer;
	tmpReserve	: CM_ReserveDetail;
begin

	inheritMethod(_newJob);	
	sharedLock(self);
	
	//Only rail jobs get split at present	
	if (not CM_RailJob.hasInstance(self.myJob)) then
		return;
	endif;
	
	rJob2 := self.myJob.CM_RailJob;
	create tiSet transient;

	//Now get rid of unactioned WLEs as they will be created for new request.
	iter := self.allWorkListEntries.createIterator;
	while iter.next(wle) do
		yardWle := wle.CM_YardWLE;
		sharedLock(yardWle);		
		//unplan all that has been planned thus far.
		if yardWle.ghostTrackedItem &lt;&gt; null then
			
			//yardWle.ghostTrackedItem.moveToLocation(null, null, yardWle, null, PLANNING_MODE, true, true, false, false, false, false,null,null, app.myPassport);		// TFS 2651
			yardWle.ghostTrackedItem.moveToLocation(null, null, yardWle, null, PLANNING_MODE, true, true, false, false, false, false, null, null, null, null, null, app.myPassport);	// TFS 2651
		endif;
		if (yardWle.status = WLE_UNACTIONED) then
			if yardWle.myTrackedItem &lt;&gt; null then
				tiSet.add(yardWle.myTrackedItem);
				yardWle.unassignTI();
			endif;
			yardWle.erase(NORMAL_ERASE);
			newTotReq := newTotReq + 1;      			
		endif;
	endwhile;	

	//Set new total to number of WLEs remaining after unactioned were erases			
	self.totalRequested := self.allWorkListEntries.size;
	
	//Create and clone new request for the new unactioned job
	newRequest := self.cloneSelf(false);
	newRequest.cloneReferences(self);
	newRequest.myJob := _newJob;
	newRequest.totalRequested := newTotReq;
	
	// Shift the reserve details and bulk release to new job
	// as this job can be set back to rail releases for editing
	self.setMyOriginatingBulkRelease(null);	
	tmpReserve := self.myReserveDetail;
	self.myReserveDetail := null;
	newRequest.myReserveDetail := tmpReserve;	
	
	foreach ti in tiSet do
		if newRequest.allWorkListEntries.size &gt;= newTotReq then
			break;
		endif;
		newRequest.createYardWLE(newRequest, WLE_UNACTIONED, ti);
	endforeach;

	if newRequest.allWorkListEntries.size &lt; newTotReq then
		newRequest.createWLEs();
	endif;

epilog
	delete tiSet;
	delete iter;
end;</source>
        <Parameter name="_newJob" type="CM_Job"/>
    </JadeMethod>
    <JadeMethod name="testCandidateTI" id="d3b45733-da2a-4ebd-9dda-117549b1ac5a">
        <source>testCandidateTI(ti: CM_TrackedItem;
				machine : CM_Machine;
				task : CM_RTQueueTask): Boolean;

/*

Purpose:			Test the passed in TI against the receiver to see if it matches the request

Parameters:			TI to test, machine, and task

Return Value:		True if it matches, false otherwise


Date		Who		Reason
13 Feb 2009	cnwkpd1	PAR #18743 - CCMS 1784 - Voice Directed Changes for Twin Lift
					Signature change to allow refactoring of Director methods
					Also change to handle ignored warnings
					
*/

vars
	aMsg	:	String;
 	entry	:	CM_RTQueueEntry;

begin
	if ti = null then
		machine.addLogEntry("Tracked Item is null");
		return false;
	endif;
	entry := task.myEntry;
	//----------------
	//If there is an over-ride flag in place, then let her go through.
	//----------------
	if entry.overRideFlags &lt;&gt; 0 then
		machine.addLogEntry("Control Override flag in place... Ignoring tests.");
		return true;
	endif;

	sharedLock(ti);
	//--------------------
	// Check properties
	//--------------------
	if machine.logSearch = true then
		aMsg := "Testing Tracked Item " &amp; ti.id.trimRight &amp; " ";
		machine.addLogEntry(aMsg);
	endif;
	
	ti.testAgainstRequest(self);
	//This throws an exception if there is a problem
	if app.myPassport.hasErrorsOrNonIgnoredWarnings() then
		return false;
	endif;
	return true;
	
	
epilog
	if isLockedByMe(ti) then
		unlock(ti);	
	endif;
	
end;</source>
        <Parameter name="ti" type="CM_TrackedItem"/>
        <Parameter name="machine" type="CM_Machine"/>
        <Parameter name="task" type="CM_RTQueueTask"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="testCandidateTIForBulkRelease" id="82fff63c-3493-4495-9bd0-c40425c00351">
        <source>testCandidateTIForBulkRelease(ti: CM_TrackedItem);
// ---------------------------------------------------------------------------
// Created:     30 October 2002 by cnwdf1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 08/05/2013	cnwpjs		PAR #31294 	
// ---------------------------------------------------------------------------
vars
	theBulkRelease	: CM_BulkRelease;
	stCode			: String;
	
begin

	theBulkRelease	:=	self.myOriginatingBulkRelease;
	
	if self.myOriginatingBulkRelease &lt;&gt; null then
		self.myOriginatingBulkRelease.testCandidateTI(ti);
	endif;
	if not ti.isBulkByQuantity and self.allTrackedItemsAllocated.includes(ti) then
		app.raiseCMException2(Inter_move_pleas_compl_that_mo, ti.id, ti.releaseRequest.myJob.jobId, null, null);	
	endif;
	
	
	//13 May 2010	NDL	Par 24183	
	// 36127 doesn't apply for delivery requests
	if ti.releaseRequest &lt;&gt; null and not ti.releaseRequest.isDeliveryRequest and  ti.releaseRequest &lt;&gt; self then		
		app.raiseCMException2(Inter_move_pleas_compl_that_mo, ti.id, ti.releaseRequest.myJob.jobId, null, null);		
	endif;

		
end;</source>
        <Parameter name="ti" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="testISOGroup" id="60650d6f-f31d-4e56-bf41-3dafeb741659">
        <source>testISOGroup(_testGroup : String; _testISOGroup : CM_ISOTypeGroup): Boolean;

/*

Purpose:	For CCMS 2185 POL iso group substitution		

Parameters:			

Return Value:		


Date		Who		Reason
25 September 2012	cnwrd1	Initial creation

*/

vars
	result : Boolean;
	testISOGroup,
	mainISOGroup,
	anISOGroup		: CM_ISOTypeGroup;
	aRelease : CM_BulkRelease;
begin
	
	if self.isoGroup = null then
		return true; //if we dont have one then its a match by default!
	endif;
	
	mainISOGroup :=  app.myRoot.allISOTypeGroups[self.isoGroup];
	
	if _testISOGroup &lt;&gt; null then
		testISOGroup := _testISOGroup;
	elseif _testGroup &lt;&gt; null then
		testISOGroup := app.myRoot.allISOTypeGroups[_testGroup];
	endif;
		
	if testISOGroup = null then
	//we havnt found one to test - but (here) we do have an ISO group we must match
		return false;
	endif;
	
	if testISOGroup = mainISOGroup then
		return true; // a straight match
	endif;
	
	//cnwrd1 par 32336
	if self.isKindOf(CM_YardDeliveryRequest) then
		aRelease := self.CM_YardDeliveryRequest.myRelease;
		
		if aRelease &lt;&gt; null and aRelease.canBeHiLoCube then
			if mainISOGroup.allSubstitutingISOGroups[testISOGroup.code] &lt;&gt; null then 
				return true;
			endif;
		endif;

	endif;
	
	

	if self.myOriginatingBulkRelease = null then
		return false;
	endif;
	
	if not self.myOriginatingBulkRelease.canBeHiLoCube then
		return false; // we dont want to check substitute groups
	endif;
	
	if mainISOGroup.allSubstitutingISOGroups[testISOGroup.code] &lt;&gt; null then 
		return true;
	endif;
	
	/*
	foreach anISOGroup in mainISOGroup.allSubstitutingISOGroups do
		if testISOGroup = anISOGroup then
			return true;
		endif;
	endforeach;
	*/
		
	//no match
	return false;
epilog
	
end;</source>
        <Parameter name="_testGroup" type="String"/>
        <Parameter name="_testISOGroup" type="CM_ISOTypeGroup"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="unallocateTrackedItem" id="3aa4cf64-50d3-4891-9174-1354982a9e7a">
        <source>unallocateTrackedItem(_ti	: CM_TrackedItem);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 May 2013	cnwpjs1	Initial creation

*/

vars

begin
	inheritMethod(_ti);
	
	if self.allTrackedItemsAllocated.includes(_ti) then
		self.allTrackedItemsAllocated.remove(_ti);
	endif;

epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="updateForRelease" id="67017637-1742-4bfe-a980-04aae887dad3">
        <updating/>
        <source>updateForRelease(_ti : CM_TrackedItem input;
					_totalQuantity : Integer) updating;
// ---------------------------------------------------------------------------
// Created:     20 June 2008 by cnwab1
//
// Purpose:     PAR 16929
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin
	if _ti = null then
		return;
	endif;
	
	if self.myReserveDetail = null then
		return;
	endif;
	
	if not (self.myJob.isRelease
	and self.isReleaseType
	and self.myJob.isKindOf(CM_RailJob)) then
		return;
	endif;
	
	_ti.setBulkReleaseReleased(self.myReserveDetail.myReserveHeader, self,_totalQuantity);
	
epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem" usage="input"/>
        <Parameter name="_totalQuantity" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="updateWLEs" id="1ff3965e-0ebf-4dd7-9eae-4b38f5feabd3">
        <source>updateWLEs();
//--------------------------------------------------------------
//Created: 01 April 2003 By: cnwgd1
//--------------------------------------------------------------
vars
	wle		: CM_WorkListEntry;
	aWLE	:	CM_YardWLE;
begin
	//------------
	//Create the appropriate WLEs
	//------------
	if self.totalRequested = 0  then
		return;
	endif;
	//--------------
	//They can amend the totals as appropriate. Either up or down
	//--------------
	if self.totalRequested &lt; self.allWorkListEntries.size then
		//We have to nuke some
		while self.allWorkListEntries.size &gt; self.totalRequested do
			self.allWorkListEntries.last.erase(NORMAL_ERASE);
		endwhile;
	endif;

	if self.allWorkListEntries.size = self.totalRequested then
		//Already exist.
		// 23098 update the bestPick option on these
		foreach wle in self.allWorkListEntries do
			wle.setBestPick(self.isBestPick);
		endforeach;
		return;
	endif;

	while self.allWorkListEntries.size &lt; self.totalRequested do
		create aWLE;
		aWLE.setForCreate(self.myJob, self);
		aWLE.setBestPick(self.isBestPick);		// 23098
		aWLE.causeEvent(aWLE.job.getMyTerminal.getTerminalEvent(WLE_Create_Event), false, aWLE);				  	
	endwhile;

end;</source>
    </JadeMethod>
    <JadeMethod name="validate" id="8ca7a232-ecc8-42c2-b576-e1f03f3fa31c">
        <source>validate(pUserObject : Object);
// ---------------------------------------------------------------------------
// Created:     15 January 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
begin
	inheritMethod(pUserObject);
	self.validateStatus(pUserObject); // FD for Xpose 1881	
	self.validateQuantity(pUserObject);
	self.validateISOType(pUserObject);
	self.validateOperatorCode(pUserObject);
	self.validateOperatorGroup(pUserObject);
	self.validateOperatorRequirements(pUserObject);

	// cnwdad1 02/07/2009 - CCMS 1735
	if app.isSubTerminalsOn(self.myTerminal)
	and self.mySubTerminalSource = null
	and not self.myTerminal.getConfig(IsSubTerminalAreaDefined).Boolean	//28 Nov 2014	NDL	Par 35295
	then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Sub-Terminal', ETRow_MySubTerminal, null);
		app.raiseCMException(Input_required_field_subTerm, ETRow_MySubTerminal, null); // cnwdb2	PAR 35364
	endif;
end;</source>
        <Parameter name="pUserObject" type="Object"/>
    </JadeMethod>
    <JadeMethod name="validateDocActionsComplete" id="f8a20218-c88c-4062-ab10-c26b9aa4a35a">
        <source>validateDocActionsComplete();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 September 2016	cnwndl1	Initial creation	TFS 2649 / 2001

*/

vars

	docActions : CM_DocumentActions;
	vvrTis : CM_TIArray;
	iter : Iterator;
	ti : CM_TrackedItem;
	docActionsTis : CM_TIArray;
	reason : String;
	vvr : CM_VehicleVisitRecord;
	
begin

	if not self.isReleaseType then
		return;
	endif;
	
	if self.myReserveDetail &lt;&gt; null and self.myReserveDetail.myReserveDetailActions &lt;&gt; null then
		docActions := self.myReserveDetail.myReserveDetailActions;
		create docActionsTis transient;
		docActions.getAllTis(docActionsTis);
		if not docActionsTis.isEmpty then
			vvr := self.myJob.CM_RoadJob.myVehicleVisit;
			if vvr &lt;&gt; null then
				create vvrTis transient;
				vvr.allReleasedTrackedItems.copy(vvrTis);
				if not vvrTis.isEmpty then
					iter := vvrTis.createIterator;
					while iter.next( ti ) do
						if not docActionsTis.includes( ti ) then
							continue;
						endif;
// TFS 4052						if not docActions.areAllActionsCompleteFor( ti, reason ) then
						if not docActions.areAllActionsCompletedFor( ti, reason ) then // TFS 4052
//	 TFS 3972						app.raiseCMWarning4(Incomplete_document_actions, ti.id, docActions.getParentDocId , docActions.getDocumentId, reason, null, null, null );
							app.raiseCMException4(Incomplete_document_actions, ti.id, docActions.getParentDocId , docActions.getDocumentId, reason, null, null );
						endif;
					endwhile;
				endif;
			endif;
		endif;
	endif;

epilog

	delete vvrTis;
	delete iter;
	delete docActionsTis;

end;</source>
    </JadeMethod>
    <JadeMethod name="validateForCreate" id="1b671c36-710c-4ee8-b48e-8a0868fee372">
        <source>validateForCreate(pUserObject : Object);
//--------------------------------------------------
// Created:	09 January 2006 By: cnwgd1
//
// Changed On   Changed By  Reason
// ----------   ----------  ------------------------
// 29/09/2009	consw1		SFW1035 - allow for multiple ReserveDetail on a Bulk Release
// 22/04/2025  navma1  		MTN-34387 MTN - Removing Unnecessary Audits
//--------------------------------------------------
vars
	theBulkRelease			: CM_BulkRelease;
	deliveryRequest			: CM_Request;
	totalRequestedThisJob,
	numReleased,
	numRequested,
	numCurrentlyActioned,
	numShouldReceive		: Integer;
	releaseDesc				: String;
	reserveDetail			: CM_ReserveDetail;
begin

	self.validate(pUserObject);

	theBulkRelease := self.myOriginatingBulkRelease;
	
	if theBulkRelease = null then
		return;
	endif;
	

	reserveDetail  := self.myReserveDetail;
	
	if theBulkRelease.status &lt;&gt; BR_ACTIVE then
		// only applicable when creating a new release
		app.raiseCMException2(Rel_Req_Status_Must_Active, theBulkRelease.getDescription(true), theBulkRelease.statusString, ETRow_Status, pUserObject);//13 Sep 2012	NDL	Par 30366
	endif;
	
	// CCMS 1412
	if CM_RoadJob.hasInstance(self.myJob) then

		if self.myJob.CM_RoadJob.carrierId &lt;&gt; theBulkRelease.carrierId then
			app.raiseCMWarning2(Carrier_not_assigne_release, self.myJob.CM_RoadJob.carrierId, theBulkRelease.getDescription(true), ETRow_CarrierId, pUserObject, self);//13 Sep 2012	NDL	Par 30366
		endif;
		
		//th2 for PAR 14966 - Released more containers than on release
		foreach deliveryRequest in self.myJob.allRequests  discreteLock do
			if (not CM_DeliveryRequest.hasInstance(deliveryRequest)) or
			   deliveryRequest.myOriginatingBulkRelease &lt;&gt; theBulkRelease then
				continue;
			endif;
			if deliveryRequest.myReserveDetail &lt;&gt; reserveDetail then
				if CM_ReserveSelection.hasInstance(reserveDetail) then
					continue;
				endif;
			endif;
			
			//th2 observes the totalRequested is always one. 
			//Even for a road release where more than one box is being released, there will be a single requests
			//created for erach with a totalRequested of one.
			totalRequestedThisJob := totalRequestedThisJob + deliveryRequest.CM_DeliveryRequest.totalRequested;
		endforeach;

		releaseDesc := theBulkRelease.code;
		
		if reserveDetail &lt;&gt; null and  (reserveDetail.isReserveSelection or reserveDetail.isBestPick) then  // PAR 26482
			if theBulkRelease.allReserveDetails.size &gt; 1 then
				releaseDesc := theBulkRelease.code &amp; " (" &amp; reserveDetail.getShortDescription() &amp; ")";
			endif;
			numReleased 			:= reserveDetail.allTrackedItemsReleased.size;
			numRequested 			:= reserveDetail.totalRequested;
			numCurrentlyActioned 	:= reserveDetail.getNumItemsBeingActioned(self.myJob);
		else
			numReleased 			:= theBulkRelease.getTotalReleased();
			numRequested 			:= theBulkRelease.getTotalRequested();
			numCurrentlyActioned 	:= theBulkRelease.getNumItemsBeingActionedEx(self.myJob);
		endif;
		
		if numRequested &lt;= null then
			return;
		endif;

		numShouldReceive 			:= numRequested - (numReleased + numCurrentlyActioned);
		if totalRequestedThisJob &gt; numShouldReceive then
			//Par 15487 - clients need a red warning to avoid of changing requested amount of containers in the Gate Out screen for an existing relese request. The practise is - to edit quantity in the Release Request maintenance screen.
			app.raiseCMException5(Er_relea_items_alrea_relea_exc, releaseDesc, numReleased.String, numCurrentlyActioned.String, totalRequestedThisJob.String, numRequested.String, ETRow_Quantity, theBulkRelease);
		endif;
			
	endif;	
end;</source>
        <Parameter name="pUserObject" type="Object"/>
    </JadeMethod>
    <JadeMethod name="validateForReturnJob" id="7d3e7aa0-137d-42f0-9b97-5447e3af2d36">
        <source>validateForReturnJob();
// Changed By: GD 2/4/2003 WLEs are now created when request is created
// and no longer deleted in the return unless splitting off actioned ones
// Split validation and actual work into separate methods.
/*

General method is like this:
Check all the WLEs in the job to see which are unactioned.
If all unactioned, then return original job
If all actioned, then it's too late to return the job
If some are unactioned then, if the user agrees, we can split off the
unactioned part and return it.

/*

Date		Who		Reason
PAR 3525 AJA 11/5/00: Rewritten so that it actually works...
23 Dec 2010	cnwkpd1	PAR #26678 - Tidy up transient leaks

*/

vars
	wle 		: CM_WorkListEntry;
	rJob 		: CM_RailJob;	
	iter	 	: Iterator;
	countUnWorked,
	countWorked : Integer;
begin

	rJob := self.myJob.CM_RailJob;		//Only rail jobs ever returned

	iter := self.allWorkListEntries.createIterator;
	while iter.next(wle) do
		sharedLock(wle);

		if (wle.status = WLE_UNACTIONED) then
			// find out the number unactioned
			//countUnWorked := countUnWorked + 1;
			countUnWorked := countUnWorked + wle.quantity.max(1);	//03 Feb 2016	NDL	Par 37492
		else // it's either complete or part complete
			// find out the number worked rs 5/09/2000		
			//countWorked := countWorked + 1;
			countWorked := countWorked + wle.quantity.max(1);	//03 Feb 2016	NDL	Par 37492
		endif;
	endwhile;

	if countUnWorked = self.totalRequested then
		// None of the WLEs are worked, nothing to split.
	elseif countUnWorked = 0 then
		// All WLE's have been worked, none are left unactioned, nothing to split.
		// cannot return job to build priority as it is not unactioned and can't be split
		app.raiseCMException1(CannotReturnSplitJob, rJob.getTreeDescription(), null, null);
	else
		// Ask if user wants to split job into two parts, one unactioned, one complete/part complete
		app.raiseCMWarning3(JobSplitUnactioned, rJob.jobId, (self.totalRequested - countUnWorked).String, countUnWorked.String, null, null, self);
	endif;

epilog
	delete iter;			// PAR #26678
	
end;</source>
    </JadeMethod>
    <JadeMethod name="validateISOType" id="94269ae2-8bc0-4920-98eb-3cdf1415c614">
        <source>validateISOType(pUserObject : Object) protected;
// ---------------------------------------------------------------------------
// Created:     15 January 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 16/12/2014  cnwdb2	PAR 35364
// ---------------------------------------------------------------------------
vars
	theBulkRelease	: CM_BulkRelease;
	hasBOL 			: Boolean;
	ct				: CM_CargoType;
begin

	theBulkRelease := self.bulkRelease;
	
	if theBulkRelease = null then
		theBulkRelease := self.myOriginatingBulkRelease;
	endif;
	
	if theBulkRelease &lt;&gt; null then
		if not theBulkRelease.releaseByType then
			return;
		endif;
	endif;

	ct := self.myCargoType;
	
	if ct &lt;&gt; null and (ct.type &lt;&gt; TI_CargoType_Container or  ct.isAllowDuplicates()) then
		// not a release by ISO type therefore we're out of here
		return;
	endif; 
	
	hasBOL := (self.voyageCode &lt;&gt; null and  self.billOfLading &lt;&gt; null);	//18 Feb 2014	NDL	Par 33524


	if self.isoType = null and self.isoGroup = null and not hasBOL then	//18 Feb 2014	NDL	Par 33524
		app.raiseCMException(Input_required_field_IsoType, ETRow_IsoType, pUserObject); // cnwdb2	PAR 35364
	// cnwjk3 PAR 21742 11/01/09
	elseif self.isoGroup =  null and not hasBOL then	//18 Feb 2014	NDL	Par 33524
		if app.myRoot.allISOTypes[self.isoType] = null then
			app.raiseCMException3(ERR_INVALID_ISOTYPE, self.isoType, 'Delivery Request', self.deliveryNumber, ETRow_IsoType, pUserObject);
		endif;
	endif;
	
end;</source>
        <access>protected</access>
        <Parameter name="pUserObject" type="Object"/>
    </JadeMethod>
    <JadeMethod name="validateOperatorCode" id="db27b7dc-191b-4905-bdd6-4ffd8dafb0d6">
        <source>validateOperatorCode(pUserObject : Object) protected;
// ---------------------------------------------------------------------------
// Created:     15 January 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

	hasBOL : Boolean;

begin

	hasBOL := (self.voyageCode &lt;&gt; null and  self.billOfLading &lt;&gt; null);	//18 Feb 2014	NDL	Par 33524

	if self.operatorCode &lt;&gt; null then
		if app.myRoot.allOperators[self.operatorCode] = null then
			app.raiseCMException1(ERR_INVALID_OPERATOR, self.operatorCode, ETRow_Operator, pUserObject);
		endif;
	//elseif self.myOperatorGroup = null then
	elseif self.myOperatorGroup = null and not hasBOL then	//18 Feb 2014	NDL	Par 33524
	//	app.raiseCMException1(REQUIRED_FIELD, 'Operator or Operator Group', ETRow_Operator, pUserObject);	
		app.raiseCMException(Input_required_field_opOrOpGrp, ETRow_Operator, pUserObject);	 // cnwdb2	PAR 35364
	endif;
	
end;</source>
        <access>protected</access>
        <Parameter name="pUserObject" type="Object"/>
    </JadeMethod>
    <JadeMethod name="validateOperatorGroup" id="0ba61d0c-e06e-4f30-91be-bb667fe97b3a">
        <source>validateOperatorGroup(pUserObject : Object) protected;
// ---------------------------------------------------------------------------
// Created:     23 October 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	tmpOperator	: CM_Operator;
	
begin

	if self.myOperatorGroup &lt;&gt; null then
		tmpOperator := app.myRoot.allOperators[self.operatorCode];
		if tmpOperator &lt;&gt; null and
		   (not self.myOperatorGroup.allOperators.includes(tmpOperator)) then
			app.raiseCMException2(OperatorNotInOperatorGroup, tmpOperator.code, 
								self.myOperatorGroup.code, ETRow_MyOperatorGroup, null);
		endif;
	endif;

end;</source>
        <access>protected</access>
        <Parameter name="pUserObject" type="Object"/>
    </JadeMethod>
    <JadeMethod name="validateOperatorRequirements" id="80669f20-82e0-4d4a-ad30-d2f615df586a">
        <source>validateOperatorRequirements(pUserObject : Object) protected;
//This tests the request against the operators requirements esp wrt CAMS configuration
vars
	operator : CM_Operator;
begin
	if self.operatorCode &lt;&gt; null then
		operator := app.myRoot.allOperators[self.operatorCode];
	endif;

	if operator = null then 
		return; 				//That was quick...
	endif;
	
	//if this is done from new form there is no way currently of entering delivery number or consignee/or code 
	if  self.myTerminal.getConfig(UseBookingSummView).Boolean then
		return;
	endif;
	
	//th2 - changed to warning on request from Tony Quayle
	if self.bulkRelease = null then
		// This is an actual release
		if operator.requiresDeliveryRelease and self.deliveryNumber = null then
		    app.raiseCMWarning2(OPERATOR_REQUIRES_DELIVERY_REL, operatorCode, 'to be released', ETRow_DeliveryRelease, pUserObject, self);
		endif;
	endif;
	

	
	if operator.requiresCVC and consignorVoyageCode = null then
	    app.raiseCMWarning2(OPERATOR_REQUIRES_CONSIGN_VOY, operatorCode, 'to be released', ETRow_ConsignorVoyageCode, pUserObject, self);
	endif;	
	
	// check the consignee
	if operator.requiresConsigneeConsignor and consignee = null then
		app.raiseCMWarning2(OPERATOR_REQUIRES_CONSIGNEE, operatorCode, 'to be released', ETRow_Consignee, pUserObject, self);
	endif;

end;</source>
        <access>protected</access>
        <Parameter name="pUserObject" type="Object"/>
    </JadeMethod>
    <JadeMethod name="validateQuantity" id="f90203c9-83e4-41b4-9f60-7c01457c5730">
        <source>validateQuantity(pUserObject : Object) protected;
/*
Purpose:			
Parameters:			
Return Value:		

Date		Who		Reason
========================================================
31 Mar 2025 navma1  MTN-34387 MTN - Removing Unnecessary Audits
*/

vars
	theBulkRelease		: CM_BulkRelease;
	outstandingQTY		: Integer;
	outstandingWT 		: Decimal[14,4];
begin

	theBulkRelease := self.bulkRelease;
	if theBulkRelease = null then
		theBulkRelease := self.myOriginatingBulkRelease;
	endif;
	
	//Only check the originating bulk release as the bulkrelease won't have correct totals.
	theBulkRelease := self.myOriginatingBulkRelease;
	
	if theBulkRelease &lt;&gt; null then
		//th2 PAR 14996 - Completed packing releases to be moved to Active rail
		
		if theBulkRelease.getWeightRequested() &gt; 0 then						//14 Mar 2018	NDL	TFS 37408 - found during testing 37408
			outstandingWT := theBulkRelease.getWeightOutstanding();			//31.03.2025 navma1 #MTN-34387
			if  outstandingWT &lt; 0 then
				app.raiseCMWarning1(MTRequestExceedsNumBulkRequest, theBulkRelease.code &amp; 
				' (' &amp; outstandingWT.String &amp; ' kgs outstanding)', ETRow_Quantity, pUserObject, self);
			endif;
		else
			outstandingQTY := theBulkRelease.getTotalOutstanding();		//31.03.2025 navma1 #MTN-34387
			if  outstandingQTY &lt; 0 then									//31.03.2025 navma1 #MTN-34387
				//changed to this by Tim for new release request stuff
				app.raiseCMWarning1(MTRequestExceedsNumBulkRequest, theBulkRelease.code &amp; 
				' (' &amp; outstandingQTY.String &amp; ' items outstanding)', ETRow_Quantity, pUserObject, self);
			endif;
		endif;
	endif;
	
end;</source>
        <access>protected</access>
        <Parameter name="pUserObject" type="Object"/>
    </JadeMethod>
    <JadeMethod name="validateStatus" id="139ff588-a07f-46c6-abac-a43ef0acba68">
        <source>validateStatus(pUserObject : Object) protected;
// ---------------------------------------------------------------------------
// Created:     03 May 2002 by cnwdf1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
// FD for Xpose 1881: if the status of the bulk release has been set to complete, 
// cancel the empty release request 
vars
	theBulkRelease	: CM_BulkRelease;
begin
	theBulkRelease := self.myOriginatingBulkRelease;
	if theBulkRelease &lt;&gt; null then
		if theBulkRelease.status = BR_COMPLETE then
			app.raiseCMException1(MTRequestStatusAlreadyComplete, theBulkRelease.code, ETRow_Status, pUserObject);
		endif;
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="pUserObject" type="Object"/>
    </JadeMethod>
</Class>
