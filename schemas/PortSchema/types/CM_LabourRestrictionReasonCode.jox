	self.isCodeGroupNOTRequired := true;
end;</source>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="713118fd-5bc9-4605-a4eb-aa7dafb8ed12">
        <updating/>
        <source>setForCreate(pProxy: CM_Code) updating;
