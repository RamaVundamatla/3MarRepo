    <JadeMethod name="isFullyPacked" id="1b64bfdc-d2d4-4702-aea4-c8f56333fb0d">
        <source>isFullyPacked():Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 December 2015	cnwndl1	Initial creation	Par 37288

*/

vars

	totalPacked : Integer;
	weightPacked : Decimal [16,4];

begin

	if self.isPackingChild then
		if totalRequested &gt; 0 then
			totalPacked := self.getTotalPacked;
			if totalPacked &lt; totalRequested then
				return false;
			endif;
		endif;
		if weightRequested &gt; 0 then
			weightPacked := self.getWeightPacked;
			if weightPacked &lt; weightRequested then
				return false;
			endif;
		endif;
		return true;
	endif;
	
	return false;

epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
