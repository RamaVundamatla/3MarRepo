    <JadeMethod name="tblData_click" id="dbd7ca84-24eb-4979-a6a1-6f26135d11f5">
        <controlMethod name="Table::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblData_click(table: Table input) updating;
/*
	// rs1 jan 2006 get column organiser to be table dependant

Date		Who		Reason
20 Mar 2023 navra1 	TFS 57124 - A cancelled EDI should not be editable, when user clicks on 
								the empty space in the form, if the selected item(if there is one) is
								cancelled, disable the edit button
// ---------------------------------------------------------------------------*/

vars
	ediData		: CM_EDIData;
begin
	self.myCurrentDataTable	:=	table.CM_DataTable;
	self.setControls();		// cnwdad1 12/04/2006.
	
	ediData := self.myCurrentObject.CM_EDIData;							//navra1 - TFS 57124 - 20th Mar 2023
	if ediData = null then												//navra1 - TFS 57124 - 20th Mar 2023
		return;															//navra1 - TFS 57124 - 20th Mar 2023
	else																//navra1 - TFS 57124 - 20th Mar 2023
		if ediData.status = CM_EDIFile.EDI_STATUS_CANCELLED then		//navra1 - TFS 57124 - 20th Mar 2023
			self.btnEditTV.enabled := false;							//navra1 - TFS 57124 - 20th Mar 2023
		else															//navra1 - TFS 57124 - 20th Mar 2023
			self.btnEditTV.enabled := true;								//navra1 - TFS 57124 - 20th Mar 2023
		endif;															//navra1 - TFS 57124 - 20th Mar 2023
	endif;																//navra1 - TFS 57124 - 20th Mar 2023
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
