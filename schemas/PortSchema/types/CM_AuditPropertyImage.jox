    <JadeMethod name="getDisplayString" id="28a8cc6e-61a9-4984-89a9-49ace5a6df27">
        <source>getDisplayString() : String;
// ---------------------------------------------------------------------------
// Created:     12 March 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	s : String;
	audType : Integer;
	
begin
	if self.name = null or self.myObjectImage = null then
		return null;
	endif;

	s := self.name;
	
	audType := self.myObjectImage.auditType;
	
	if audType = AuditCreated or audType = AuditDeleted then
		s := s &amp; Tab &amp; self.afterValue;
	elseif audType = AuditUpdated then
		s := s &amp; Tab &amp; self.beforeValue &amp; Tab &amp; self.afterValue;
	endif;
	
	return s;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
