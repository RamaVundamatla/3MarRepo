    <JadeMethod name="getStatusForApproved" id="6ad1adc5-bc1d-4973-b958-715b4fed9836">
        <source>getStatusForApproved(_voyage: CM_Voyage): CM_VoyageStatus;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 19/07/2018	jlgdap1		Initial creation TFS 39815 PEL1 WO Approved Set Voyage Status
// 23/9/2021	jlier1		TFS 51963
// 19/08/2022	jlizm1		TFS 54298 EUP - Simplified Voyage Work Order Process
//
vars
	oldStatus,
	status : CM_VoyageStatus;
	 
begin
	oldStatus:=_voyage.getVoyageStatusObject;
	
	if _voyage.myVoyageProcess.isMTNWOProcess then
		if self.hasCargo then
			status := app.myRoot.allVoyageStatuses[Voyage_Status_CargoReqPending];
		else
			status := app.myRoot.allVoyageStatuses[Voyage_Status_ServicesPending];
		endif;
		
	elseif _voyage.myVoyageProcess.isEUPDefaultProcess then					// TFS 54298
		status := app.myRoot.allVoyageStatuses[Voyage_Status_EUP_Pending];	// TFS 54298
	endif;
	
	if status = null then
		return null;
	endif;
	
	if oldStatus.priority &gt; status.priority then
		return null;
	endif;
	
	return status;
epilog

end;</source>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <ReturnType type="CM_VoyageStatus"/>
    </JadeMethod>
