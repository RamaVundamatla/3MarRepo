<Class name="ExplicitInverseRef">
    <JadeMethod name="jssGetInverses" id="055c81dd-b185-464c-922d-6c518c52dff7">
        <source>jssGetInverses():InverseSet;
// --------------------------------------------------------------------------------
// Created:		24 April 2003 by cnwdad1
//
// Purpose:		Returns a set of the receiver's inverse references.
//
// Parameters:	None
//
// Returns:		A set of references to the receiver's inverse references.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return self.inverses;
end;</source>
        <ReturnType type="InverseSet"/>
    </JadeMethod>
</Class>
