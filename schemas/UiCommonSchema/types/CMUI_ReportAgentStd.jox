    <JadeMethod name="doLoadVoyages" id="12449df1-2bad-4a6c-9eef-2a5b38226442">
        <source>doLoadVoyages(_combo : CMUI_ComboBox input; _voyageCode : String) protected;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04/09/2009	cnwndl1	Initial creation
14/06/2019	jlgdap1	TFS 44554 AAT Stevedore Data Access
*/
vars
	voy	 : CM_Voyage;
	term : CM_Terminal;
	failedDAC :CM_DataAccessController;
	user : CM_User;							// TFS 44554
	passport : CM_Passport;					// TFS 44554
	
begin

	if _combo = null then
		return;
	endif;
	
	term := app.getMyTerminalDO_NOT_USE;
	
	if term = null then
		return;
	endif;
	
//	_combo.listCollection(term.allVoyagesByCode, true, 0);							// TFS 44554
	user := app.getMyUser;															// TFS 44554
	passport := app.myPassport;														// TFS 44554
	foreach voy in term.allVoyagesByCode discreteLock do							// TFS 44554
		if not voy.canUserAccessSelf(user, failedDAC, passport) then				// TFS 44554
			continue;																// TFS 44554
		endif;																		// TFS 44554
		_combo.itemObject[_combo.addItem(voy.getDisplayDetails(false))] := voy;		// TFS 44554
	endforeach;																		// TFS 44554
	
	if _voyageCode &lt;&gt; null then
		voy := term.lookupVoyage (_voyageCode, null, false);
	
		if voy &lt;&gt; null then
		
			if (not voy.canUserAccessSelf(null, failedDAC, app.myPassport)) then
				return;
			endif;
	
			_combo.text := voy.getDisplayDetails(false);
		   	_combo.listObject := voy;
		endif;
	endif;	
	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_combo" type="CMUI_ComboBox" usage="input"/>
        <Parameter name="_voyageCode" type="String"/>
    </JadeMethod>
    <JadeMethod name="doLoadWOStatus" id="d4394fc2-3044-4e0d-8aae-83a6d5b93776">
        <updating/>
        <source>doLoadWOStatus(
	_lstTblWOStatus	: CMUI_ListTable input;
	_filterObject	: CMQF_FilterReports ) updating, protected;
	
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 Aug 2023 navhl20 ChangeRequest 58568: EUP - Delivery Dispatch – Reporting

*/
vars
	taskType			: CM_WorkOrderDetailType;
	idx,
	select,
	count				: Integer;
	defaultStatus		: StringArray;
	obj					: Object;
	statusArr			: ObjectArray;
	status				: CM_Association;
begin
	create defaultStatus transient;
	create statusArr transient;
	if CMQF_WorkOrder.hasInstance(_filterObject) then
		_filterObject.CMQF_WorkOrder.getWOStatusStringArray(defaultStatus);
	endif;
	
	if _lstTblWOStatus = null then
		return;
	endif;
	
	_lstTblWOStatus.rows := _lstTblWOStatus.fixedRows;
	_lstTblWOStatus.clearSelected();
	
	count := 1;
	while count &lt; WO_STATUS_MAX + 1 do		
		create status transient;
		status.setValue(count);
		statusArr.insert( count, status);
		count := count + 1;		
	endwhile;

	foreach obj in statusArr do
		select := 0;
		if defaultStatus &lt;&gt; null and defaultStatus.includes(app.workOrderStatusEnumToString(obj.CM_Association.getValue().Integer)) &lt;&gt; null then
			select := 1;
			_lstTblWOStatus.allSelectedObjects.add(obj);
		endif;
		
		idx := _lstTblWOStatus.addItem(select.String &amp; Tab &amp; app.workOrderStatusEnumToString(obj.CM_Association.getValue().Integer)); 
		_lstTblWOStatus.accessRow(idx).itemObject := obj;
	endforeach;
epilog
	
end;
</source>
        <access>protected</access>
        <Parameter name="_lstTblWOStatus" type="CMUI_ListTable" usage="input"/>
        <Parameter name="_filterObject" type="CMQF_FilterReports"/>
    </JadeMethod>
    <JadeMethod name="doLoadWOType" id="96b7d148-fa75-41d3-a971-8ee6b18b9729">
        <updating/>
        <source>doLoadWOType(
	_lstTblWOType	: CMUI_ListTable input;
	_filterObject	: CMQF_FilterReports ) updating, protected;
	
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 Aug 2023 navhl20 ChangeRequest 58568: EUP - Delivery Dispatch – Reporting

*/
vars
	taskType			: CM_WorkOrderDetailType;
	idx					: Integer;
	defaultTypes		: StringArray;
	select				: Integer;
	
begin
	create defaultTypes transient;
	if CMQF_WorkOrder.hasInstance(_filterObject) then
		_filterObject.CMQF_WorkOrder.getWOTypeStringArray(defaultTypes);
	endif;
	
	if _lstTblWOType = null then
		return;
	endif;
	
	_lstTblWOType.rows := _lstTblWOType.fixedRows;
	_lstTblWOType.clearSelected();

	foreach taskType in app.myRoot.allWorkOrderTaskTypes do
		select := 0;
		if defaultTypes &lt;&gt; null and defaultTypes.includes(taskType.description) &lt;&gt; null then
			select := 1;
			_lstTblWOType.allSelectedObjects.add(taskType);	
		endif;
		
		idx := _lstTblWOType.addItem(select.String &amp; Tab &amp; taskType.description); 
		_lstTblWOType.accessRow(idx).itemObject := taskType;
	endforeach;
epilog
	
end;
</source>
        <access>protected</access>
        <Parameter name="_lstTblWOType" type="CMUI_ListTable" usage="input"/>
        <Parameter name="_filterObject" type="CMQF_FilterReports"/>
    </JadeMethod>
    <JadeMethod name="doLoadWoTxnTypes" id="5157bd2d-b897-43ab-92b7-0ca1fe6a9912">
        <updating/>
        <source>doLoadWoTxnTypes(
	_lstTblWOTransact	: CMUI_ListTable input;
	_filterObject	: CMQF_FilterReports ) updating, protected;
	
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 March 2023 navhl20 Defect 57144: Send to Report showing Error

*/
vars
	strColl				: CM_ObjectArray;
	stringWithObject	: CM_StringWithObject;
	defaultTypes		: StringArray;
	cm_TransactionType	: CM_TransactionType;
	aClass				: Class;
	iter1				: Iterator;
	
begin
	if _filterObject &lt;&gt; null and CMQF_WOTransactions.hasInstance( _filterObject ) then
		// get the default transactions for this report if set
		create defaultTypes transient;
		_filterObject.CMQF_WOTransactions.getTransTypeStringArray( defaultTypes );
	endif;
	
	// strColl is a reference to all of the possible allowed transactions set below.
	strColl := self.allAllowedTransactionTypes;
	if not strColl.isEmpty then
		strColl.purge();
	endif;
	
	// clears allSelectedObjects on the listTable
	if _lstTblWOTransact &lt;&gt; null then
		_lstTblWOTransact.clearSelected();
	endif;
	
	// now populate the allow transactions and set defaulted ones on the listTable allSelectedObjects.
	iter1	:= app.myRoot.allTransactionTypesByDesc.createIterator;
	while iter1.next( cm_TransactionType ) do : cond_loop
		if cm_TransactionType.trxGroup &lt;&gt; TRANS_TYPE_GROUP_WO then		// ie not Cargo
			continue cond_loop;
		endif;
		
		// do not include transaction types that do not have a classNameToCreate or the class is abstract.
		aClass	:= currentSchema.getClass( cm_TransactionType.classNameToCreate );
		if aClass = null or aClass.abstract then
			continue cond_loop;
		endif;
		
		create stringWithObject transient;
		stringWithObject.string	:= cm_TransactionType.description;
		stringWithObject.object	:= cm_TransactionType;
		strColl.add( stringWithObject );					// add to all allowed transactions
		if _lstTblWOTransact &lt;&gt; null and defaultTypes &lt;&gt; null and defaultTypes.includes( cm_TransactionType.description ) then
			// set the default (previously selected ) ones.
			_lstTblWOTransact.allSelectedObjects.add( stringWithObject );
		endif;
	endwhile cond_loop;
	
	if _lstTblWOTransact &lt;&gt; null then
		// now populate the listTable
		_lstTblWOTransact.displayCollection( strColl, false, Table.DisplayCollection_Forward, null );
		_lstTblWOTransact.lostFocus( _lstTblWOTransact );
	endif;
	
	
epilog
	delete iter1;
	delete defaultTypes;
end;
</source>
        <access>protected</access>
        <Parameter name="_lstTblWOTransact" type="CMUI_ListTable" usage="input"/>
        <Parameter name="_filterObject" type="CMQF_FilterReports"/>
    </JadeMethod>
    <JadeMethod name="doLoadWtMeasureTypes" id="7cb31dc3-11e6-46a8-b766-7a80851a56e2">
        <source>doLoadWtMeasureTypes( _combo : CMUI_ComboBox; _defaultValueStr : String );
