    <JadeMethod name="doFullyPlan" id="f9c07acc-25ae-4196-b98b-3c4c2109ea12">
        <updating/>
        <source>doFullyPlan() updating;
// --------------------------------------------------------------------------------
// Created:		23 November 2010 by cnwjo3
//
// Purpose:		
//// 17 May 2016	cnwns1	TFS 488 - Multi Timezone Support
vars
	cmifMonitor		: CMIF_Monitor;
	tmpHeight, idx : Integer;
	tmpOptionsUsed : IntegerArray;
	now : TimeStamp;
begin
	cmifMonitor := app.myPassport.myCMIFMonitor;
	if cmifMonitor = null then
		create cmifMonitor transient;
		cmifMonitor.myParent := self;
		app.myPassport.setMyCMIFMonitor(cmifMonitor);
	endif;

	self.myAssistant.doFullyPlan(allJobs, self.myCurrentVoyage, cmifMonitor,self.shipController);

	now := app.actualTimeServer;// 17 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	
	if self.shipController &lt;&gt; null then
		self.startDateTime := now;
		self.displayShipControllerInfo();
	endif;
epilog
	delete cmifMonitor;	
	app.myPassport.setMyCMIFMonitor(null);
	self.frmModalDialog.visible := false;
end;</source>
    </JadeMethod>
    <JadeMethod name="doResize" id="67630d2e-fc37-4623-a6b6-1310973b6b6b">
        <updating/>
        <source>doResize() updating;
// --------------------------------------------------------------------------------
// Created:		19 November 2010 by cnwjo3
//
// Purpose:		
//
vars

begin
	self.tblInfo.width := self.clientWidth - 10;
	self.tblErrors.width := self.clientWidth - 10;
	self.btnClose.left := (self.tblErrors.width+5-self.btnClose.width);
	
	self.tblErrors.height := self.clientHeight - self.btnClose.height - self.tblInfo.height - self.frmToolbar.height - 80;
	self.btnClose.top := self.tblErrors.top + self.tblErrors.height + 10;
	
	inheritMethod();
end;</source>
    </JadeMethod>
    <JadeMethod name="doUnplan" id="ad891554-bcfb-463b-af5f-da8560a172f5">
        <updating/>
        <source>doUnplan() updating;
// --------------------------------------------------------------------------------
// Created:		23 November 2010 by cnwjo3
//
// Purpose:		
//// 17 May 2016	cnwns1	TFS 488 - Multi Timezone Support
vars
	jobs : CM_VoyageJobSet;
	result : Integer;
	seconds : Integer;
	startTime : TimeStamp;
begin
	//need to set terminal passport!
	app.myPassport.setMyTerminal(self.myTerminal);
	
	self.allJobs.removeInvalidObjects(); //par 19267

	if self.allJobs.isEmpty then
		app.raiseCMException(ERR_JOBS_EMPTY,null,null);
		return;
	endif;
	
	create jobs transient;
	self.allJobs.copy(jobs);
	
	while true do
		app.myTrxUA.trxUpdateVoyageJobsUnplan(jobs, app.myPassport);	
		if app.myPassport.trxCompletedOK then
			// Clear errors/warnings from form and err/warnings window
			self.clearErrorWarnings();
			global.beep;
			break;
		else
			result := app.showErrorWarningDialog(app.getErrorString(LoadPlanInfo_UnplanVoyageJobs), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   result = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
		endif;
		break;
	endwhile;
	
	//reset the table
	self.tblInfo.clear();
	self.tblInfo.rows := 0;
	self.tblInfo.columns := 2;
	self.tblInfo.fixedColumns := 0;	
	
	self.tblErrors.clear();

	self.tblInfo.addItem("");
	
	self.tblInfo.addItem(app.getErrorString(Voyage) &amp; ":" &amp; Tab &amp; self.myCurrentVoyage.code);
	self.tblInfo.addItem("");
	
	seconds := (startTime.cnEcDiff(app.actualTimeServer)/1000).Integer;// 17 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	self.tblInfo.addItem(app.getErrorString(LoadPlanInfo_UnplanningDuratio) &amp; ":" &amp; Tab &amp; seconds.getHMS());
	self.tblInfo.addItem("");	

	self.tblInfo.addItem(app.getErrorString(LoadPlanInfo_Crane) &amp; ": " &amp; Tab &amp; self.allJobs.first().CM_VoyageJob.craneId);
	if self.allJobs.size &gt; 50 then
		self.tblInfo.addItem(app.getErrorString(LoadPlanInfo_JobOrJobs) &amp; ":" &amp; Tab &amp; self.allJobs.size.String &amp; " " &amp; app.getErrorString(Jobs));
	else
		self.tblInfo.addItem(app.getErrorString(LoadPlanInfo_JobOrJobs) &amp; ":" &amp; Tab &amp; self.allJobs.getName());
	endif;
	self.tblInfo.addItem("");	
epilog
	//self.init(false);
	delete jobs;
end;</source>
    </JadeMethod>
