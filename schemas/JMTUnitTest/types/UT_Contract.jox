    <JadeMethod name="uContractTestData" id="d4b5ba86-5dc1-4096-bef6-3f9e9c2a5fb2">
        <updating/>
        <source>uContractTestData() updating;
/*
Purpose:			

Date		Who		Reason
09 December 2022	navab1	TFS CR 55623 TASK 55678
*/


constants
	CONTRACTID = "JJ_343098_21";
	OPID = "ABOS";// ABOC ABOS
	CTYPE = "BARRELS"; // CONT BBLK2
vars
	realCon : CM_InvoiceContract;
	realConDtl : CM_InvoiceContractDetails;
	realRate : CM_InvoiceContractRate;
	pxyRateEntry, realRateEntry01, realRateEntry02, realRateEntry03 : CM_InvoiceContractRateEntry;
	fromTS, toTS, stTS, enTS : TimeStamp;
	calcType : CM_CalculationType;
	invLineType100 : CM_InvoiceLineDesc;
	service100, service200 : CM_Service;
	operator : CM_Operator;
	debtor : CM_Debtor;
	cargoType : CM_CargoType;
begin
//	operator := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);
	operator := self.getOperator(OPID); 
	self.assertTrueMsg(operator &lt;&gt; null, "Operator is null");
	debtor := operator.debtor;

	self.assertTrueMsg(debtor &lt;&gt; null, "Debtor is null");
	

//	self.purgeAllContractData();
	invLineType100 := "2222.2471874".asOid.CM_InvoiceLineDesc;
//	invLineType100 := "2222.1492099".asOid.CM_InvoiceLineDesc;
//	invLineType100 := "2222.568555".asOid.CM_InvoiceLineDesc;
	
	fromTS := app.actualTimeAppServer();
	fromTS := fromTS.addDays(-3);
	toTS := fromTS.addDays(15);

	// ### CREATE a CONTRACT
	realCon := self.createContract(debtor, CONTRACTID,false,false, fromTS, toTS,true);

	// ### CREATE A CONTRACT DETAIL
	cargoType := app.myRoot.getCargoTypeFromAbbrev(CTYPE);
	realConDtl := self.createContractDetail(realCon,operator,cargoType);
	
	// ### CHANGE DETAIL DATES and LINE TYPE
	fromTS := fromTS.addDays(1);
	toTS := toTS.addHours(-52);
	self.updateDetailDates(realConDtl, fromTS,toTS, invLineType100);

	calcType := invLineType100.myCalculationType;

	// ### CREATE RATE
	service100 := invLineType100.services.first;
	service200 := invLineType100.services.last;

	realRate := self.createContractRate(realConDtl,service100);
	
	// ### CREATE RATE ENTRIES
	realRateEntry01 := self.createContractRateEntry(realRate,3456.4321,0,500,realConDtl.fromTS, realConDtl.toTS);
	realRateEntry02 := self.createContractRateEntry(realRate,2256.78,501,5000,realConDtl.fromTS, realConDtl.toTS);
	realRateEntry03 := self.createContractRateEntry(realRate,87910.12,5001,99999999,realConDtl.fromTS, realConDtl.toTS);
	

	
epilog
	delete pxyRateEntry;

end;</source>
    </JadeMethod>
    <JadeMethod name="uContractTestData1000" id="d31c9760-5236-4e96-8b69-bde618df76c7">
        <updating/>
        <source>uContractTestData1000() updating;
/*
Purpose:			

Date		Who		Reason
30 December 2022	navab1	TFS CR 55645 TASK 55662
*/
constants
	OPID = "BISH";// ABOC ABOS ATPL BISH
	CTYPE = "CONT"; // CONT BBLK2 BARRELS
	DODELETE = true; //  if TRUE this will purge all contracts for the BU
	AMOUNTTOCREATE = 4;
vars
	realCon : CM_InvoiceContract;
	fromTS, toTS : TimeStamp;
	calcType : CM_CalculationType;
	invLineType100 : CM_InvoiceLineDesc;
	service100, service200 : CM_Service;
	operator : CM_Operator;
	debtor : CM_Debtor;
	cargoType : CM_CargoType;
	contractId : String;
	idx,contractSeq : Integer;
	terminal : CM_Terminal;
	bank : CM_Bank;
	services : CM_ServiceByNameDict;
	invType : CM_InvoiceDesc;
	doDelete : Boolean;
begin
	doDelete := DODELETE;
	
	terminal := self.getTerminal();
	bank := terminal.getDefaultCompanyBank();
	
	if doDelete then
		self.deleteAllContractsForBU(bank);
		self.assertTrueMsg(bank.allInvoiceContractsById.isEmpty(), "Bank still has contracts!!!");
		self.deleteInvoiceService("UT_ServiceContract-1",0);
		self.deleteInvoiceService("UT_ServiceContract-2",0);
		self.deleteInvoiceType("UT_InvTypeContract");
		self.deleteInvoiceLineType("UT_LineTypeContract",0);

		service100 := self.createInvoiceService("UT_ServiceContract-1","1- Unit test for TFS 55623", calcType, null);
		self.assertNotNullMsg(service100, "UT_ServiceContract-1 not created");
		service200 := self.createInvoiceService("UT_ServiceContract-2","2- Unit test for TFS 55623", calcType, null);
		self.assertNotNullMsg(service100, "UT_ServiceContract-2 not created");
		create services transient;
		services.add(service100);
		services.add(service200);

		invType := self.createInvoiceType("UT_InvTypeContract", InvoiceTypeGeneral);
		self.assertNotNullMsg(invType, "Invoice type UT_InvTypeContract not created");
		
		invLineType100 := self.createInvoiceLineType("UT_LineTypeContract", calcType, invType, services,"SDT6");
		self.assertNotNullMsg(invLineType100, "UT_LineTypeContract not created");
	else
		
	endif;
	
	calcType := app.myRoot.allCalculationTypesByCode["CCT00"];
	
	
	cargoType := app.myRoot.getCargoTypeFromAbbrev(CTYPE);
	
	operator := self.getOperator(OPID); 
	self.assertTrueMsg(operator &lt;&gt; null, "Operator is null");
	debtor := operator.debtor;

	self.assertTrueMsg(debtor &lt;&gt; null, "Debtor is null");
	
	fromTS.setFromYYYYMMDDHHmm("200506010000");
	toTS.setFromYYYYMMDDHHmm("202512310000");
	
	foreach idx in 1 to AMOUNTTOCREATE do
		contractSeq := idx;
		contractId := debtor.name.removeInvalidChars() &amp; contractSeq.padLeadingWith("0",4);
		
		if idx mod 50 = 0 then
			write contractId;
		
		endif;
		
		// ### CONTRACT
		realCon := self.createContract(debtor,contractId,false,false,fromTS,toTS,false);
		
		// ### DETAIL 1 - first 2 timestamps are for the detail, the others are for the rate entries for that detail.
		self.createContractDetail1000d(realCon,operator, cargoType,"200506010000", "200512310000", "200506010000", "20050820000", "200508210000", "200509250000");
		
		// ### DETAIL 2
		self.createContractDetail1000d(realCon,operator, cargoType,"200601010000", "201012310000", "200601010000", "200712310000", "200701010000", "200912310000");
		
		// ### DETAIL 3
		self.createContractDetail1000d(realCon,operator, cargoType,"201101010000", "201512310000", "201101010000", "201312310000", "201401010000", "201512310000");

		// ### DETAIL 4
		self.createContractDetail1000d(realCon,operator, cargoType,"201601010000", "202512310000", "201601010000", "201912310000", "202001010000", "202312310000");
		

		
		
	endforeach;

epilog
	delete services;
end;</source>
    </JadeMethod>
    <JadeMethod name="uContractTestData2000" id="2f80a78c-a716-41fa-a41b-1062101dc511">
        <updating/>
        <source>uContractTestData2000() updating;
/*
Purpose:			

Date		Who		Reason
30 December 2022	navab1	TFS CR 55645 TASK 55662
*/
constants
	OPID = "ABOC";// ABOC ABOS
	CTYPE = "BBLK2"; // CONT BBLK2
	DODELETE = false; //  if TRUE this will purge all contracts for the BU
	AMOUNTTOCREATE = 3;

vars
	realCon : CM_InvoiceContract;
	fromTS, toTS : TimeStamp;
	calcType : CM_CalculationType;
	invLineType100 : CM_InvoiceLineDesc;
	service100, service200 : CM_Service;
	operator : CM_Operator;
	debtor : CM_Debtor;
	cargoType : CM_CargoType;
	contractId : String;
	idx,contractSeq : Integer;
	terminal : CM_Terminal;
	bank : CM_Bank;
	services : CM_ServiceByNameDict;
	invType : CM_InvoiceDesc;
	doDelete : Boolean;
begin
	doDelete := DODELETE;
	
	terminal := self.getTerminal();
	bank := terminal.getDefaultCompanyBank();
	
	if doDelete then
		self.deleteAllContractsForBU(bank);
		self.assertTrueMsg(bank.allInvoiceContractsById.isEmpty(), "Bank still has contracts!!!");
		self.deleteInvoiceService("UT_ServiceContract-1",0);
		self.deleteInvoiceService("UT_ServiceContract-2",0);
		self.deleteInvoiceType("UT_InvTypeContract");
		self.deleteInvoiceLineType("UT_LineTypeContract",0);

		service100 := self.createInvoiceService("UT_ServiceContract-1","1- Unit test for TFS 55623", calcType, null);
		self.assertNotNullMsg(service100, "UT_ServiceContract-1 not created");
		service200 := self.createInvoiceService("UT_ServiceContract-2","2- Unit test for TFS 55623", calcType, null);
		self.assertNotNullMsg(service100, "UT_ServiceContract-2 not created");
		create services transient;
		services.add(service100);
		services.add(service200);

		invType := self.createInvoiceType("UT_InvTypeContract", InvoiceTypeGeneral);
		self.assertNotNullMsg(invType, "Invoice type UT_InvTypeContract not created");
		
		invLineType100 := self.createInvoiceLineType("UT_LineTypeContract", calcType, invType, services,"SDT6");
		self.assertNotNullMsg(invLineType100, "UT_LineTypeContract not created");
	else
		
	endif;
	
	calcType := app.myRoot.allCalculationTypesByCode["CCT00"];
	
	
	cargoType := app.myRoot.getCargoTypeFromAbbrev(CTYPE);
	
	operator := self.getOperator(OPID); 
	self.assertTrueMsg(operator &lt;&gt; null, "Operator is null");
	debtor := operator.debtor;

	self.assertTrueMsg(debtor &lt;&gt; null, "Debtor is null");
	
	fromTS.setFromYYYYMMDDHHmm("201506010000");
	toTS.setFromYYYYMMDDHHmm("204512310000");
	
	foreach idx in 1 to AMOUNTTOCREATE do
		contractSeq := idx;
		contractId := debtor.name &amp; contractSeq.padLeadingWith("0",4);
		
		if idx mod 50 = 0 then
			write contractId;
		
		endif;
		
		// ### CONTRACT
		realCon := self.createContract(debtor,contractId,false,false,fromTS,toTS,false);
		
		// ### DETAIL 1
		self.createContractDetail1000d(realCon,operator, cargoType,"201501010000", "201512310000", "201501010000", "201505200000", "201506210000", "201512310000");
		
		// ### DETAIL 2
		self.createContractDetail1000d(realCon,operator, cargoType,"201601010000", "202012310000", "201601010000", "201712310000", "201701010000", "201912310000");
		
		// ### DETAIL 3
		self.createContractDetail1000d(realCon,operator, cargoType,"202101010000", "202512310000", "202101010000", "202312310000", "202401010000", "202512310000");

		// ### DETAIL 4
		self.createContractDetail1000d(realCon,operator, cargoType,"202601010000", "204512310000", "202601010000", "202912310000", "203001010000", "204512310000");
		

		
		
		endforeach;

epilog
	delete services;
end;</source>
    </JadeMethod>
    <JadeMethod name="uContractVolBsdTestData" id="e2019f86-3511-42df-afa7-533554c930f1">
        <updating/>
        <source>uContractVolBsdTestData() updating;
/*
Purpose:			

Date		Who		Reason
23JAN2023	NAVAB1	CR 55624 TASK 55699 
*/

constants
	CONTRACTID = "VB_343098_20";
	OPID = "ABOS";// ABOC ABOS
	CTYPE = "BARRELS"; // CONT BBLK2
vars
	realCon : CM_InvoiceContract;
	realConDtl : CM_InvoiceContractDetails;
	realRate : CM_InvoiceContractRate;
	pxyRateEntry, realRateEntry01, realRateEntry02, realRateEntry03 : CM_InvoiceContractRateEntry;
	fromTS, toTS, stTS, enTS : TimeStamp;
	calcType : CM_CalculationType;
	invLineType100 : CM_InvoiceLineDesc;
	service100, service200 : CM_Service;
	operator : CM_Operator;
	debtor : CM_Debtor;
	cargoType : CM_CargoType;
	criteriaCargoTypes : CM_CargoBOLTypeSet;
begin
	operator := self.getOperator(OPID); 
	self.assertTrueMsg(operator &lt;&gt; null, "Operator is null");
	debtor := operator.debtor;

	self.assertTrueMsg(debtor &lt;&gt; null, "Debtor is null");
	

//	self.purgeAllContractData();
	invLineType100 := "2222.2471874".asOid.CM_InvoiceLineDesc;
//	invLineType100 := "2222.1492099".asOid.CM_InvoiceLineDesc;
//	invLineType100 := "2222.568555".asOid.CM_InvoiceLineDesc;
	
	fromTS := app.actualTimeAppServer();
	fromTS := fromTS.addDays(-3);
	toTS := fromTS.addDays(15);

	// ### CREATE a CONTRACT
	realCon := self.createContract(debtor, CONTRACTID,false,false, fromTS, toTS,true);

	// ### CREATE A CONTRACT DETAIL
	create criteriaCargoTypes transient; // ### TFS CR 55624 TASK 55700 27JAN2023 NAVAB1
	cargoType := app.myRoot.getCargoTypeFromAbbrev(CTYPE);
	criteriaCargoTypes.add(cargoType); // ### TFS CR 55624 TASK 55700 27JAN2023 NAVAB1
	realConDtl := self.createContractDetailVolBased(realCon,operator,criteriaCargoTypes, INV_VOL_BASED_VOYAGE, true,"CCT04");  // ### TFS BUG 57505 13APR2023 NAVAB1 added Calc Type
	
	// ### CHANGE DETAIL DATES and LINE TYPE
	fromTS := fromTS.addDays(1);
	toTS := toTS.addHours(-52);
	self.updateDetailDates(realConDtl, fromTS,toTS, invLineType100);

	calcType := invLineType100.myCalculationType;

	// ### CREATE RATE
	service100 := invLineType100.services.first;
	service200 := invLineType100.services.last;

	realRate := self.createContractRate(realConDtl,service100);
	
	// ### CREATE RATE ENTRIES
	realRateEntry01 := self.createContractRateEntry(realRate,3456.4321,0,500,realConDtl.fromTS, realConDtl.toTS);
	realRateEntry02 := self.createContractRateEntry(realRate,2256.78,501,5000,realConDtl.fromTS, realConDtl.toTS);
	realRateEntry03 := self.createContractRateEntry(realRate,87910.12,5001,99999999,realConDtl.fromTS, realConDtl.toTS);
	
	self.deleteUTInvoiceLineTypes();

	
epilog
	delete pxyRateEntry;
	delete criteriaCargoTypes;

end;</source>
    </JadeMethod>
    <JadeMethod name="uPurgeALLContracts" id="a1ff0e41-8a0b-456d-9bed-1910b15d347e">
