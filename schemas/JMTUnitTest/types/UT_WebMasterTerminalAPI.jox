                    "tare": 0
                },
                "description": "SINGLE TRAILER",
                "childCargo": [],
                "hazards": [],
                "customsReferences": [
                    {
                        "id": "CH-CR63619-04",
                        "typeId": "AESEXIT",
                        "position": 1
                    }
                ]
            }
        ],
        "hazards": [],
        "customsReferences": [
            {
                "id": "CR63619-04",
                "typeId": "AESEXIT",
                "position": 1
            }
        ],
        "voyageId": "UTVOY63113",
        "locationId": "BS01"
    }
]';
	IncomingStringJSON = '
	{
    
        "cargoId":"API804A25",
        "cargoTypeId": "CONT",
        "state": "1",
        "bookingId": "",
        "mode": "Instant",
        "roadReceival":false,
        "quantity":1,
        "roadRelease":true,
        "dateTime":"2024-09-20T10:22:59+12:00",
        "targetLocationId":"TEST03",
        "weight":"500.000"
    
}';
	
IncomingStringJSON1 = '
	{
    "cargoId": "API804A25",
    "cargoTypeId": "CONT",
        "state": "1",
        "bookingId": "",
        "mode": "Instant",
        "roadReceival":false,
        "quantity":1,
        "roadRelease":true,
        "dateTime":"2024-09-20T10:22:59+12:00",
        "targetLocationId":"BS01",
        "weight":"500.000"
}';

vars
	realTI				: CM_TrackedItem;
	terminal			: CM_Terminal;
	incomingJsonString,
	terminalCode,
	loginJson			: String;
	expectFailure		: Boolean;
	root				: CM_Root;
	params				: String;
	operator			: CM_Operator;
	passport			: CM_Passport;
	cargoType			: CM_CargoType;
	vessel				: CM_Vessel;
	voyage				: CM_Voyage;
begin
	
	root := app.myRoot;
	passport := app.myPassport;
	terminalCode := self.getProfileSetting(UT_Profile.P_TERMINAL).asString;
	self.assertNotNullMsg(terminalCode, "Terminal Code not set in Unit Test Profile");
	terminal := root.allTerminals[terminalCode];
	
	self.deleteCargo("API804A25","CONT");
	self.deleteCargo("TEST03","UTMAFI");
	self.deleteCargo("CHILD03","PAPER");
	
	// Check cargo types
	cargoType := root.getCargoTypeFromAbbrevOrDescr("UTMAFI");
	self.assertNotNullMsg(cargoType, "UTMAFI Cargo Type not found");
	cargoType := root.getCargoTypeFromAbbrevOrDescr("PAPER");
	self.assertNotNullMsg(cargoType, "PAPER Cargo Type not found");
	cargoType := root.getCargoTypeFromAbbrevOrDescr("CONT");
	self.assertNotNullMsg(cargoType, "Container Cargo Type not found");
	
	loginJson := null;	// Use default (REST) operator
	self.deleteVoyage(ThisVoyage);
	voyage := self.getVoyage(ThisVoyage);
	self.assertTrueMsg(voyage = null, "Voyage " &amp; ThisVoyage &amp; " not deleted");
	self.deleteVessel(ThisVessel);
	vessel := self.getVessel(ThisVessel);
	self.assertTrueMsg(vessel = null, "Vessel " &amp; ThisVessel &amp; " not deleted");
	
	// Create Vessel / Voyage
	self.createVesselVoyage(ThisVoyage, ThisVessel, operator);
	voyage := self.getVoyage(ThisVoyage);
	self.assertNotNullMsg(voyage, "Voyage " &amp; ThisVoyage &amp; " not found");
	operator := root.allOperators["WEST"];
	self.assertTrueMsg(operator &lt;&gt; null, method.name &amp; " | Setup: operator is null/could not be found | Operator Code: " &amp; "WEST");
	
	//post container
	incomingJsonString := IncomingPostJsonString;
	expectFailure := false;
	self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTPostCargo.name, loginJson, incomingJsonString,expectFailure);
	
	realTI := self.getTrackedItem("API804A25");
	assertNotNullMsg(realTI, "TrackedItem not found" );
	assertTrueMsg(realTI.locationId = "BS01", "API804A25 not found in BS01");
	
	//post MAFI
	incomingJsonString := PostOnsiteJson;
	self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTPostCargo.name, loginJson, incomingJsonString,expectFailure);
	
	realTI := self.getTrackedItem("TEST03");
	assertNotNullMsg(realTI, "MAFI not found" );
	assertTrueMsg(realTI.locationId = "BS01", "TEST03 not found in BS01");
	
	//postmove cargo to MAFI trailer
	params := "WarningsAcknowledged=true";
	incomingJsonString := IncomingStringJSON;
	self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTPostMoveCargo.name, loginJson, incomingJsonString,params,expectFailure);
	
	realTI	:= getTrackedItem("API804A25");
	assertTrueMsg(realTI.locationId = "TEST03 1", "API804A25 not found in TEST03 1");
	
	//postmove cargo to onsite location
	incomingJsonString := IncomingStringJSON1;
	self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTPostMoveCargo.name, loginJson, incomingJsonString,params,expectFailure);
	
	assertTrueMsg(realTI.locationId = "BS01", "API804A25 not found in BS01");
	
epilog
	
end;</source>
    </JadeMethod>
    <JadeMethod name="tPostPack" id="91806d06-47f7-4fda-984a-6b2404c9ced9">
        <source>tPostPack();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 September 2024	navcs2	ChangeRequest 65967: CUX | MasterTerminalAPI - Pack and Unpack APIs

*/
constants
Ref 				: String = "65967";
UTContId1 			: String = "CNTU659671";
UTContId2 			: String = "CNTU659672";
UTContId3			: String = "CNTU659673";
UTContId4			: String = "CNTU659674";
UTContId5			: String = "CNTU659675";
BlockStackId		: String = "BS65967";
CargoTypeParent		: String = "CONT";
CargoTypeChild		: String = "STEEL COIL";
CargoTypeChildErr	: String = "STEEL POIL";
CargoIsoCode		: String = "2200";
VoyageUT 			: String = "UATRELEASEREQ";
VesselUT 			: String = "AalekhTestVessel";
RelById 			: String = "RelId65967";
RelByType			: String = "RELTYPE65967";
BlockStack 			: String = "BS65967";
BreakBulkId1		: String = "UTBreakBulk01";
BreakBulkId2 		: String = "UTBreakBulk02";
BreakBulkId3 		: String = "UTBreakBulk03";
BreakBulkId4 		: String = "UTBreakBulk04";
BreakBulkId5 		: String = "UTBreakBulk05";
BreakBulkId6 		: String = "UTBreakBulk06";
BreakBulkId7 		: String = "UTBreakBulk07";
BreakBulkId8 		: String = "UTBreakBulk08";
BreakBulkId9 		: String = "UTBreakBulk09";
BreakBulkId10 		: String = "UTBreakBulk10";

IncomingJsonStringNoRel = '{
    "parent": {
        "id": "'&amp; UTContId1 &amp;'",
        "cargoTypeId": "'&amp; CargoTypeParent &amp;'"
    },
     "cargo": [
            {
				"id": "'&amp; BreakBulkId1 &amp;'",
				"cargoTypeId": "'&amp; CargoTypeChild &amp;'",
				"quantity": 1
            },
            {
				"id": "'&amp; BreakBulkId2 &amp;'",
				"cargoTypeId": "'&amp; CargoTypeChild &amp;'",
				"quantity": 1
            }
        ],
    "complete": true
}';

IncomingJsonStringNoRelNotComplete = '{
    "parent": {
        "id": "'&amp; UTContId2 &amp;'",
        "cargoTypeId": "'&amp; CargoTypeParent &amp;'"
    },
     "cargo": [
            {
				"id": "'&amp; BreakBulkId3 &amp;'",
				"cargoTypeId": "'&amp; CargoTypeChild &amp;'",
				"quantity": 1
            },
            {
				"id": "'&amp; BreakBulkId4 &amp;'",
				"cargoTypeId": "'&amp; CargoTypeChild &amp;'",
				"quantity": 1
            }
        ],
    "complete": false
}';

IncomingJsonStringRelById = '{ 
    "parent": {
        "id": "'&amp; UTContId3 &amp;'",
        "cargoTypeId": "'&amp; CargoTypeParent &amp;'"
    },
     "cargo": [
            {
				"id": "'&amp; BreakBulkId5 &amp;'",
				"cargoTypeId": "'&amp; CargoTypeChild &amp;'",
				"quantity": 1,
				"releaseRequest" : {
					"id" : "'&amp; RelById &amp;'"
				}
            },
            {
				"id": "'&amp; BreakBulkId6 &amp;'",
				"cargoTypeId": "'&amp; CargoTypeChild &amp;'",
				"quantity": 1,
				"releaseRequest" : {
					"id" : "'&amp; RelById &amp;'"
				}
            }
        ],
    "complete": true
}';

IncomingJsonStringRelByType = '{
    "parent": {
        "id": "'&amp; UTContId4 &amp;'",
        "cargoTypeId": "'&amp; CargoTypeParent &amp;'"
    },
     "cargo": [
            {
				"id": "'&amp; BreakBulkId7 &amp;'",
				"cargoTypeId": "'&amp; CargoTypeChild &amp;'",
				"quantity": 1,
				"releaseRequest" : {
					"id" : "'&amp; RelByType &amp;'"
				}
            },
            {
				"id": "'&amp; BreakBulkId8 &amp;'",
				"cargoTypeId": "'&amp; CargoTypeChild &amp;'",
				"quantity": 1,
				"releaseRequest" : {
					"id" : "'&amp; RelByType &amp;'"
				}
            }
        ],
    "complete": true
}';

IncomingJsonWithErrorCont = '{
    "parent": {
        "id": "'&amp; UTContId5 &amp;'",
        "cargoTypeId": "'&amp; CargoTypeParent &amp;'"
    },
     "cargo": [
            {
            "id": "'&amp; BreakBulkId9 &amp;'",
            "cargoTypeId": "'&amp; CargoTypeChild &amp;'",
            "quantity": 1,
            },
            {
            "id": "'&amp; BreakBulkId10 &amp;'",
            "cargoTypeId": "'&amp; CargoTypeChildErr &amp;'",
            "quantity": 1,
            }
        ],
    "complete": true
}';

vars
	incomingJsonString,
	terminalCode,
	loginJson					: String;
	expectFailure				: Boolean;
	root						: CM_Root;
	cargoId1,
	cargoId2,
	cargoId3,
	cargoId4,
	cargoId5,
	breakBulk1Id,
	breakBulk2Id,
	breakBulk3Id,
	breakBulk4Id,
	breakBulk5Id,
	breakBulk6Id,
	breakBulk7Id,
	breakBulk8Id,
	breakBulk9Id,
	breakBulk10Id				: String;
	vessel 						: CM_Vessel;
	voyage						: CM_Voyage;
	cont1,
	cont2,
	cont3,
	cont4,
	cont5,
	breakBulk1,
	breakBulk2,
	breakBulk3,
	breakBulk4,
	breakBulk5,
	breakBulk6,
	breakBulk7,
	breakBulk8,
	breakBulk9,
	breakBulk10					: CM_TrackedItem;
	dischargePort 				: CM_Port;
	operator 					: CM_Operator;
	relByType,
	relById						: CM_BulkRelease;
	tiSet						: CM_TISet;
	bs1							: CM_BlockStack;
	cargoType					: CM_CargoType;
	qParameters					: String;
begin
	cargoId1 := UTContId1;
	cargoId2 := UTContId2;
	cargoId3 := UTContId3;
	cargoId4 := UTContId4;
	cargoId5 := UTContId5;
	
	breakBulk1Id := BreakBulkId1;
	breakBulk2Id := BreakBulkId2;
	breakBulk3Id := BreakBulkId3;
	breakBulk4Id := BreakBulkId4;
	breakBulk5Id := BreakBulkId5;
	breakBulk6Id := BreakBulkId6;
	breakBulk7Id := BreakBulkId7;
	breakBulk8Id := BreakBulkId8;
	breakBulk9Id := BreakBulkId9;
	
	loginJson := null;
	
	root := self.getRoot();
	self.setTerminalConfig(IsSubTerminalsOn, false);
	terminalCode := self.getProfileSetting(UT_Profile.P_TERMINAL).asString;
	self.assertNotNullMsg(terminalCode, "Terminal Code not set in Unit Test Profile");
	
	self.opts.purge();
	self.opts.addAssoc("CargoType", TI_CargoType_Container);	
	
	operator := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);	
	
	self.deleteTrackedItem(cargoId1, false);
	self.deleteTrackedItem(cargoId2, false);
	self.deleteTrackedItem(cargoId3, false);
	self.deleteTrackedItem(cargoId4, false);
	self.deleteTrackedItem(cargoId5, false);
	self.deleteTrackedItem(breakBulk1Id, false);
	self.deleteTrackedItem(breakBulk2Id, false);
	self.deleteTrackedItem(breakBulk3Id, false);
	self.deleteTrackedItem(breakBulk4Id, false);
	self.deleteTrackedItem(breakBulk5Id, false);
	self.deleteTrackedItem(breakBulk6Id, false);
	self.deleteTrackedItem(breakBulk7Id, false);
	self.deleteTrackedItem(breakBulk8Id, false);
	self.deleteTrackedItem(breakBulk9Id, false);
	
	self.deleteReleaseRequest(RelById);
	self.deleteReleaseRequest(RelByType);
	
	// Create a blockstack to store the cargo
	bs1 := self.addBlockStack(BlockStackId, 1000, null);
	
	// Create the tracked items to pack and be packed
	cont1 := self.addContainer(cargoId1, operator, CargoIsoCode, "MT", TI_IMEX_STATUS_STORAGE);
	self.assertTrueMsg(cont1 &lt;&gt; null, "No TrackedItem: " &amp; cargoId1 &amp; " Created");
	cont2 := self.addContainer(cargoId2, operator, CargoIsoCode, "MT", TI_IMEX_STATUS_STORAGE);
	self.assertTrueMsg(cont2 &lt;&gt; null, "No TrackedItem: " &amp; cargoId2 &amp; " Created");
	cont3 := self.addContainer(cargoId3, operator, CargoIsoCode, "MT", TI_IMEX_STATUS_STORAGE);
	self.assertTrueMsg(cont3 &lt;&gt; null, "No TrackedItem: " &amp; cargoId3 &amp; " Created");
	cont4 := self.addContainer(cargoId4, operator, CargoIsoCode, "MT", TI_IMEX_STATUS_STORAGE);
	self.assertTrueMsg(cont4 &lt;&gt; null, "No TrackedItem: " &amp; cargoId4 &amp; " Created");
	cont5 := self.addContainer(cargoId5, operator, CargoIsoCode, "MT", TI_IMEX_STATUS_STORAGE);
	self.assertTrueMsg(cont5 &lt;&gt; null, "No TrackedItem: " &amp; cargoId5 &amp; " Created");
	
	cargoType := self.getCargoType(CargoTypeChild);
	self.assertTrueMsg(cargoType &lt;&gt; null, "No CargoType: " &amp; CargoTypeChild &amp; " Found");
	
	self.deleteVoyage(VoyageUT);
	
	// vessel and voyage	
	voyage := self.getVoyage(NULL_VOYAGE_CODE);
	self.assertNotNull(voyage);
	
	self.opts.purge();
	self.opts.addAssoc("Product", cargoType.getProductFromCode("TIEWIRE10G"));
	
	// Create child cargo to be packed
	breakBulk1 := self.addCargoBreakBulkAtLocation(BreakBulkId1, cargoType, 1,  bs1.myLocationsController, null, TI_IMEX_STATUS_IMPORT, voyage, operator);
	self.assertTrueMsg(breakBulk1 &lt;&gt; null, "No TrackedItem: " &amp; BreakBulkId1 &amp; " Created");
	breakBulk2 := self.addCargoBreakBulkAtLocation(BreakBulkId2, cargoType, 1,  bs1.myLocationsController, null, TI_IMEX_STATUS_IMPORT, voyage, operator);
	self.assertTrueMsg(breakBulk2 &lt;&gt; null, "No TrackedItem: " &amp; BreakBulkId2 &amp; " Created");	
	breakBulk3 := self.addCargoBreakBulkAtLocation(BreakBulkId3, cargoType, 1,  bs1.myLocationsController, null, TI_IMEX_STATUS_IMPORT, voyage, operator);
	self.assertTrueMsg(breakBulk3 &lt;&gt; null, "No TrackedItem: " &amp; BreakBulkId3 &amp; " Created");	
	breakBulk4 := self.addCargoBreakBulkAtLocation(BreakBulkId4, cargoType, 1,  bs1.myLocationsController, null, TI_IMEX_STATUS_IMPORT, voyage, operator);
	self.assertTrueMsg(breakBulk4 &lt;&gt; null, "No TrackedItem: " &amp; BreakBulkId4 &amp; " Created");
	breakBulk5 := self.addCargoBreakBulkAtLocation(BreakBulkId5, cargoType, 1,  bs1.myLocationsController, null, TI_IMEX_STATUS_IMPORT, voyage, operator);
	self.assertTrueMsg(breakBulk5 &lt;&gt; null, "No TrackedItem: " &amp; BreakBulkId5 &amp; " Created");
	breakBulk6 := self.addCargoBreakBulkAtLocation(BreakBulkId6, cargoType, 1,  bs1.myLocationsController, null, TI_IMEX_STATUS_IMPORT, voyage, operator);
	self.assertTrueMsg(breakBulk6 &lt;&gt; null, "No TrackedItem: " &amp; BreakBulkId6 &amp; " Created");
	breakBulk7 := self.addCargoBreakBulkAtLocation(BreakBulkId7, cargoType, 1,  bs1.myLocationsController, null, TI_IMEX_STATUS_IMPORT, voyage, operator);
	self.assertTrueMsg(breakBulk7 &lt;&gt; null, "No TrackedItem: " &amp; BreakBulkId7 &amp; " Created");
	breakBulk8 := self.addCargoBreakBulkAtLocation(BreakBulkId8, cargoType, 1,  bs1.myLocationsController, null, TI_IMEX_STATUS_IMPORT, voyage, operator);
	self.assertTrueMsg(breakBulk8 &lt;&gt; null, "No TrackedItem: " &amp; BreakBulkId8 &amp; " Created");
	breakBulk9 := self.addCargoBreakBulkAtLocation(BreakBulkId9, cargoType, 1,  bs1.myLocationsController, null, TI_IMEX_STATUS_IMPORT, voyage, operator);
	self.assertTrueMsg(breakBulk9 &lt;&gt; null, "No TrackedItem: " &amp; BreakBulkId9 &amp; " Created");
	breakBulk10 := self.addCargoBreakBulkAtLocation(BreakBulkId10, cargoType, 1,  bs1.myLocationsController, null, TI_IMEX_STATUS_IMPORT, voyage, operator);
	self.assertTrueMsg(breakBulk10 &lt;&gt; null, "No TrackedItem: " &amp; BreakBulkId10 &amp; " Created");
	
	
	///////////////////////////////////////
	//////////// TEST NUMBER 1 ////////////
	//// NO BULK RELEASE PACK COMPLETE ////
	///////////////////////////////////////
	
	
	incomingJsonString := IncomingJsonStringNoRel;
	expectFailure := false;
	self.opts.purge();
	self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTPostPack.name, loginJson, qParameters, incomingJsonString, expectFailure);
	
	// Assert everything is okay
	self.assertTrueMsg(cont1.isParent, "Tracked item: " &amp; cont1.id &amp; " is not a parent after test 1");
	self.assertTrueMsg(cont1.isPackingComplete, "Tracked item: " &amp; cont1.id &amp; " is not 'pack complete' after test 1 ");
	self.assertTrueMsg(breakBulk1.isChild, "Tracked item: " &amp; breakBulk1.id &amp; " is not a child after test 1");
	self.assertTrueMsg(breakBulk2.isChild, "Tracked item: " &amp; breakBulk2.id &amp; " is not a child after test 1");
	self.assertTrueMsg(cont1.allChildren.includes(breakBulk1), "Tracked item: " &amp; cont1.id &amp; " does not include " &amp; breakBulk1.id &amp; " as a child after test 1");
	self.assertTrueMsg(cont1.allChildren.includes(breakBulk2), "Tracked item: " &amp; cont1.id &amp; " does not include " &amp; breakBulk2.id &amp; " as a child after test 1");
	

	///////////////////////////////////////
	//////////// TEST NUMBER 2 ////////////
	// NO BULK RELEASE PACK NOT COMPLETE //
	///////////////////////////////////////
	
	
	incomingJsonString := IncomingJsonStringNoRelNotComplete;
	expectFailure := false;
	self.opts.purge();
	self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTPostPack.name, loginJson, qParameters, incomingJsonString, expectFailure);
	
	// Assert everything is okay
	self.assertTrueMsg(cont2.isParent, "Tracked item: " &amp; cont2.id &amp; " is not a parent after test 2");
	self.assertTrueMsg(not cont2.isPackingComplete, "Tracked item: " &amp; cont2.id &amp; " is 'pack complete' after test 2 when it should not be");
	self.assertTrueMsg(breakBulk3.isChild, "Tracked item: " &amp; breakBulk3.id &amp; " is not a child after test 2");
	self.assertTrueMsg(breakBulk4.isChild, "Tracked item: " &amp; breakBulk4.id &amp; " is not a child after test 2");
	self.assertTrueMsg(cont2.allChildren.includes(breakBulk3), "Tracked item: " &amp; cont2.id &amp; " does not include " &amp; breakBulk3.id &amp; " as a child after test 2");
	self.assertTrueMsg(cont2.allChildren.includes(breakBulk4), "Tracked item: " &amp; cont2.id &amp; " does not include " &amp; breakBulk4.id &amp; " as a child after test 2");
	
	
	///////////////////////////////////////
	//////////// TEST NUMBER 3 ////////////
	////// BULK BY ID PACK COMPLETE ///////
	///////////////////////////////////////
	
	
	// Create TISET to add to the release by id
	create tiSet transient;
	tiSet.add(cont3);
	tiSet.add(breakBulk5);
	tiSet.add(breakBulk6);	
	
	// Create the release requests to match the cargo to and check it has been created
	self.opts.purge();
	self.opts.addAssoc("TotalRequested", 1);
	
	relById := self.addReleaseById(RelById, BR_TYPE_PACKING, tiSet);
	self.assertTrueMsg(relById &lt;&gt; null, "No Bulk Release: " &amp; RelById &amp; " Created");
	
	incomingJsonString := IncomingJsonStringRelById;
	expectFailure := false;
	self.opts.purge();
	self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTPostPack.name, loginJson, qParameters, incomingJsonString, expectFailure);
	
	// Assert everything is okay
	self.assertTrueMsg(cont3.isParent, "Tracked item: " &amp; cont3.id &amp; " is not a parent after test 3");
	self.assertTrueMsg(cont3.isPackingComplete, "Tracked item: " &amp; cont3.id &amp; " is not 'pack complete' after test 3");
	self.assertTrueMsg(breakBulk5.isChild, "Tracked item: " &amp; breakBulk5.id &amp; " is not a child after test 3");
	self.assertTrueMsg(breakBulk6.isChild, "Tracked item: " &amp; breakBulk6.id &amp; " is not a child after test 3");
	self.assertTrueMsg(cont3.allChildren.includes(breakBulk5), "Tracked item: " &amp; cont3.id &amp; " does not include " &amp; breakBulk5.id &amp; " as a child after test 3");
	self.assertTrueMsg(cont3.allChildren.includes(breakBulk6), "Tracked item: " &amp; cont3.id &amp; " does not include " &amp; breakBulk6.id &amp; " as a child after test 3");
	self.assertTrueMsg(relById.allTrackedItemsAssigned.includes(cont3), "Bulk Release : " &amp; relById.code &amp; " does not include " &amp; cont3.id &amp; " as a tracked item assigned after test 3");
	self.assertTrueMsg(relById.allTrackedItemsAssigned.includes(breakBulk5), "Bulk Release : " &amp; relById.code &amp; " does not include " &amp; breakBulk5.id &amp; " as a tracked item assigned after test 3");
	self.assertTrueMsg(relById.allTrackedItemsAssigned.includes(breakBulk6), "Bulk Release : " &amp; relById.code &amp; " does not include " &amp; breakBulk6.id &amp; " as a tracked item assigned after test 3");

	delete tiSet;
	
	
	///////////////////////////////////////
	//////////// TEST NUMBER 4 ////////////
	////// BULK BY TYPE PACK COMPLETE /////
	///////////////////////////////////////	
	
	
	// Create the release requests to match the cargo to and check it has been created
	self.opts.purge();
	self.opts.addAssoc("TotalRequested", 1);
	self.opts.addAssoc("PackType1", 1);
	
	relByType := self.addReleaseByTypeRequest(RelByType, BR_TYPE_PACKING, cargoType.id, null);
	self.assertTrueMsg(relByType &lt;&gt; null, "No Bulk Release: " &amp; RelByType &amp; " Created");
	
	incomingJsonString := IncomingJsonStringRelByType;
	expectFailure := false;
	self.opts.purge();
	self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTPostPack.name, loginJson, qParameters, incomingJsonString, expectFailure);
	
	// Assert everything is okay
	self.assertTrueMsg(cont4.isParent, "Tracked item: " &amp; cont4.id &amp; " is not a parent after test 4");
	self.assertTrueMsg(cont4.isPackingComplete, "Tracked item: " &amp; cont4.id &amp; " is not 'pack complete' after test 4");
	self.assertTrueMsg(breakBulk7.isChild, "Tracked item: " &amp; breakBulk7.id &amp; " is not a child after test 4");
	self.assertTrueMsg(breakBulk8.isChild, "Tracked item: " &amp; breakBulk8.id &amp; " is not a child after test 4");
	self.assertTrueMsg(cont4.allChildren.includes(breakBulk7), "Tracked item: " &amp; cont4.id &amp; " does not include " &amp; breakBulk7.id &amp; " as a child after test 4");
	self.assertTrueMsg(cont4.allChildren.includes(breakBulk8), "Tracked item: " &amp; cont4.id &amp; " does not include " &amp; breakBulk8.id &amp; " as a child after test 4");
	self.assertTrueMsg(relByType.allTrackedItemsAssigned.includes(breakBulk7), "Bulk Release : " &amp; relByType.code &amp; " does not include " &amp; breakBulk7.id &amp; " as a tracked item assigned after test 4");
	self.assertTrueMsg(relByType.allTrackedItemsAssigned.includes(breakBulk8), "Bulk Release : " &amp; relByType.code &amp; " does not include " &amp; breakBulk8.id &amp; " as a tracked item assigned after test 4");
	
	
	///////////////////////////////////////
	//////////// TEST NUMBER 5 ////////////
	////// CONTINUE ON ERROR SUCESS ///////
	///////////////////////////////////////	
	
	qParameters := "?MasterTerminalAPI&amp;warningsAcknowledged=true&amp;continueOnError=true";
	
	incomingJsonString := IncomingJsonWithErrorCont;
	expectFailure := true;
	self.opts.purge();
	self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTPostPack.name, loginJson, qParameters, incomingJsonString, expectFailure);
	
	// Assert everything is okay should only be one tracked item that "Worked"
	self.assertTrueMsg(cont5.isParent, "Tracked item: " &amp; cont5.id &amp; " is not a parent after test 1");
	self.assertTrueMsg(cont5.isPackingComplete, "Tracked item: " &amp; cont5.id &amp; " is not 'pack complete' after test 1 ");
	self.assertTrueMsg(breakBulk9.isChild, "Tracked item: " &amp; breakBulk9.id &amp; " is not a child after test 1");
	self.assertTrueMsg(not breakBulk10.isChild, "Tracked item: " &amp; breakBulk10.id &amp; " is a child after test 1");
	self.assertTrueMsg(cont5.allChildren.includes(breakBulk9), "Tracked item: " &amp; cont5.id &amp; " does not include " &amp; breakBulk9.id &amp; " as a child after test 1");
	self.assertTrueMsg(not cont5.allChildren.includes(breakBulk10), "Tracked item: " &amp; cont5.id &amp; " includes " &amp; breakBulk10.id &amp; " as a child after test 1");
	
epilog
	delete tiSet;
end;</source>
    </JadeMethod>
    <JadeMethod name="tPostPutGetCargoCUX" id="a2e502ab-8e86-48b2-b499-8b9dda761aef">
        <source>tPostPutGetCargoCUX();
/*

Purpose:			Cuxport specific POST and PUT /Cargo flow

Parameters:			

Return Value:		

Date				Who		Reason
04 July 2024		navmd1	Initial creation TFS 65034

*/

constants
	DELETE_XLATIONS			: Boolean = true;
	
	OPERATOR_CUX			: String = "Cuxport";
	CUST_PRI_FOREIGN_P1		: String = "SomethingOtherThanP1";
	CUST_PRI_FOREIGN_P2		: String = "SomethingOtherThanP2";
	CUST_PRI_FOREIGN_P3		: String = "SomethingOtherThanP3";
	CUST_PRI_DMAST_P1		: String = "P1";
	CUST_PRI_DMAST_P2		: String = "P2";
	CUST_PRI_DMAST_P3		: String = "P3";
	CUST_PRI_WMAST_P1		: String = "CP1";
	CUST_PRI_WMAST_P2		: String = "CP2";
	CUST_PRI_WMAST_P3		: String = "CP3";
	
	PARENT_CARGO_ID			: String = "TIPE5988399";
	CHILD_CARGO_ID			: String = "DFDSCargo-116354736";
	
	CREATE_CARGO			: String = '[
    {
        "operatorId": "&lt;REPLACEME&gt;",
		"consignorId": "UTCOE",
        "destinationPortId": "GBIMM",
        "dischargePortId": "GBIMM",
        "loadPortId": "DECUX",
        "imexStatus": "EXP",
        "prenotified": true,
        "receivalDetails": {
            "type": "Truck"
        },
        "voyageId": "********************",
        "id": "' &amp; PARENT_CARGO_ID &amp; '",
        "bookingId": "69840062",
        "cargoTypeId": "UTMAFI",
        "trailerTypeId": "UTMAFI",
        "weights": {
            "gross": 14500,
            "tara": 7000
        },
        "totalQuantity": 1,
		"customerPriority": "' &amp; CUST_PRI_FOREIGN_P2 &amp; '",
        "childCargo": [
            {
                "operatorId": "&lt;REPLACEME&gt;",
                "destinationPortId": "GBIMM",
                "dischargePortId": "GBIMM",
                "loadPortId": "DECUX",
                "imexStatus": "EXP",
                "prenotified": true,
                "receivalDetails": {
                    "type": "Truck",
					"id": "F89YPJ"
                },
                "voyageId": "********************",
                "id": "' &amp; CHILD_CARGO_ID &amp; '",
                "cargoTypeId": "PAPER",
                "cargoSubTypeId": "REELS",
                "weights": {
                    "gross": 14500,
                    "tara": 0
                },
                "description": "PLASTIC CHAIRS",
                "totalQuantity": 1,
				"shipmentNumber":"2024-07-02T14:29:00.000+2:00",
				"customerPriority":"' &amp; CUST_PRI_FOREIGN_P1 &amp; '"
            }
        ]
    }
]';

	UPDATE_CARGO			: String = '{
	"operatorId": "&lt;REPLACEME&gt;",
	"consignorId": "UTCOE",
	"destinationPortId": "GBIMM",
	"dischargePortId": "GBIMM",
	"loadPortId": "DECUX",
	"imexStatus": "EXP",
	"prenotified": true,
	"receivalDetails": {
		"type": "Truck"
	},
	"voyageId": "********************",
	"id": "' &amp; PARENT_CARGO_ID &amp; '",
	"bookingId": "69840062",
	"cargoTypeId": "UTMAFI",
	"trailerTypeId": "UTMAFI",
	"weights": {
		"gross": 14500,
		"tara": 7000
	},
	"customerPriority": "' &amp; CUST_PRI_FOREIGN_P1 &amp; '",
	"totalQuantity": 1,
	"childCargo": [
		{
			"operatorId": "&lt;REPLACEME&gt;",
			"destinationPortId": "GBIMM",
			"dischargePortId": "GBIMM",
			"loadPortId": "DECUX",
			"imexStatus": "EXP",
			"prenotified": true,
			"receivalDetails": {
				"type": "Truck",
				"id": "F89YPJ"
			},
			"voyageId": "********************",
			"id": "' &amp; CHILD_CARGO_ID &amp; '",
			"cargoTypeId": "PAPER",
			"cargoSubTypeId": "REELS",
			"weights": {
				"gross": 14500,
				"tara": 0
			},
			"description": "PLASTIC CHAIRS",
			"totalQuantity": 1,
			"shipmentNumber":"2024-07-02T14:29:00.000+2:00",
			"customerPriority":"' &amp; CUST_PRI_FOREIGN_P3 &amp; '"
		}
	]
}';

	FIND_CARGO			: String = '{
	"id": "' &amp; PARENT_CARGO_ID &amp; '",
	"state": ' &amp; TI_STATE_NOTIFIED.String &amp; '
}';

vars
	terminal				: CM_Terminal;
	operator				: CM_Operator;
	incomingCreateJsonString,
	incomingUpdateJsonString,
	restOperator,
	systemPriorityCodeP1,
	systemPriorityCodeP2,
	systemPriorityCodeP3,
	queryParam,
	path,
	response,
	body					: String;
	expectFailure,
	foundXlat				: Boolean;
	logLevel				: Integer;
	parentCargo,
	childCargo				: CM_TrackedItem;
	priority,
	pxyPriority				: CM_CustomerPriority;
	matches					: JadeRegexResult;
	mafiCargoType			: CM_CargoType;
begin
	logLevel := app.logLevel;
//	app.changeLogLevel(LogTRACE);

	terminal := app.myRoot.allTerminals[self.getProfileSetting(UT_Profile.P_TERMINAL).asString];
	self.assertNotNullMsg(terminal, "Terminal Code not set in Unit Test Profile");
	operator := app.myRoot.allOperators[self.getProfileSetting(UT_Profile.P_OPERATOR).asString];
	self.assertNotNullMsg(operator, "Operator Code not set in Unit Test Profile");
	restOperator := OPERATOR_CUX;
	
	// Variable Substitution
	incomingCreateJsonString := JadeRegex@replaceAll(CREATE_CARGO, '"operatorId": "' &amp; operator.code &amp; '"', '\"operatorId\": \"(\&lt;REPLACEME\&gt;)\"', false);
	incomingUpdateJsonString := JadeRegex@replaceAll(UPDATE_CARGO, '"operatorId": "' &amp; operator.code &amp; '"', '\"operatorId\": \"(\&lt;REPLACEME\&gt;)\"', false);
	
	// Cleanup
	self.deleteCargo(CHILD_CARGO_ID, "PAPER");
	self.deleteCargo(PARENT_CARGO_ID, "TRAILER");
	
	// Setup
	// Should we enable duplicate prenotes by booking id ?
	self.opts.purge();
	self.opts.addAssoc("TrackAs", ProductType_Trailer);
	mafiCargoType := self.addCargoType("UTMAFI", false);
	self.assertEqualMsg(mafiCargoType.productType, ProductType_Trailer, "MAFI Cargo Type created without being Tracked as Trailer. Onboard Cargo are not going to be added correctly");
	self.addTrailerType("UTMAFI", "UTMAFI - MAFI Trailer Type", mafiCargoType, 1, 600, 600, 30000, 6000, 300, TRAILER_CATEGORY_MAFI, null);
	
	// Check for Customer Priority P1 and create if missing
	priority := app.myRoot.allCustomerPriorities[self.stringIfDmast(CUST_PRI_DMAST_P1, CUST_PRI_WMAST_P1)];
	if priority = null then
		create pxyPriority transient;
		pxyPriority.setProxy(self.stringIfDmast(CUST_PRI_DMAST_P1, CUST_PRI_WMAST_P1), "1", 1);
		app.myTrxCA.trxCreateCustomerPriority(pxyPriority, priority, app.myPassport);
		self.assertNoTrxErrorsOrWarnings();
		delete pxyPriority;
	endif;
	priority := app.myRoot.allCustomerPriorities[self.stringIfDmast(CUST_PRI_DMAST_P2, CUST_PRI_WMAST_P2)];
	if priority = null then
		create pxyPriority transient;
		pxyPriority.setProxy(self.stringIfDmast(CUST_PRI_DMAST_P2, CUST_PRI_WMAST_P2), "2", 2);
		app.myTrxCA.trxCreateCustomerPriority(pxyPriority, priority, app.myPassport);
		self.assertNoTrxErrorsOrWarnings();
		delete pxyPriority;
	endif;
	priority := app.myRoot.allCustomerPriorities[self.stringIfDmast(CUST_PRI_DMAST_P3, CUST_PRI_WMAST_P3)];
	if priority = null then
		create pxyPriority transient;
		pxyPriority.setProxy(self.stringIfDmast(CUST_PRI_DMAST_P3, CUST_PRI_WMAST_P3), "3", 3);
		app.myTrxCA.trxCreateCustomerPriority(pxyPriority, priority, app.myPassport);
		self.assertNoTrxErrorsOrWarnings();
		delete pxyPriority;
	endif;
	
	// Create Operator translation if missing
	systemPriorityCodeP1 := operator.getXlationSystemCode(CUST_PRI_FOREIGN_P1, XLATION_TYPE_CUSTPRIORITY_BYOP, foundXlat);
	if not foundXlat then
		self.logMessage("P1 EDI Translation does not exist, creating");
		if self.createEDIXlation(CUST_PRI_FOREIGN_P1, self.stringIfDmast(CUST_PRI_DMAST_P1, CUST_PRI_WMAST_P1), XLATION_TYPE_CUSTPRIORITY_BYOP, true, operator, null, null) then
			systemPriorityCodeP1 := self.stringIfDmast(CUST_PRI_DMAST_P1, CUST_PRI_WMAST_P1);
		else
			// Should have already failed the assert before now, so lets throw a IDK what happened error;
			self.assertTrueMsg(false, "Unknwon error creating EDI Translation");
		endif;
	endif;
	
	systemPriorityCodeP2 := operator.getXlationSystemCode(CUST_PRI_FOREIGN_P2, XLATION_TYPE_CUSTPRIORITY_BYOP, foundXlat);
	if not foundXlat then
		self.logMessage("P2 EDI Translation does not exist, creating");
		if self.createEDIXlation(CUST_PRI_FOREIGN_P2, self.stringIfDmast(CUST_PRI_DMAST_P2, CUST_PRI_WMAST_P2), XLATION_TYPE_CUSTPRIORITY_BYOP, true, operator, null, null) then
			systemPriorityCodeP2 := self.stringIfDmast(CUST_PRI_DMAST_P2, CUST_PRI_WMAST_P2);
		else
			// Should have already failed the assert before now, so lets throw a IDK what happened error;
			self.assertTrueMsg(false, "Unknwon error creating EDI Translation");
		endif;
	endif;
	
	systemPriorityCodeP3 := operator.getXlationSystemCode(CUST_PRI_FOREIGN_P3, XLATION_TYPE_CUSTPRIORITY_BYOP, foundXlat);
	if not foundXlat then
		self.logMessage("P3 EDI Translation does not exist, creating");
		if self.createEDIXlation(CUST_PRI_FOREIGN_P3, self.stringIfDmast(CUST_PRI_DMAST_P3, CUST_PRI_WMAST_P3), XLATION_TYPE_CUSTPRIORITY_BYOP, true, operator, null, null) then
			systemPriorityCodeP3 := self.stringIfDmast(CUST_PRI_DMAST_P3, CUST_PRI_WMAST_P3);
		else
			// Should have already failed the assert before now, so lets throw a IDK what happened error;
			self.assertTrueMsg(false, "Unknwon error creating EDI Translation");
		endif;
	endif;
	
	
	if app.logLevel = LogTRACE then
		self.logMessage(incomingCreateJsonString);
	endif;
	expectFailure := false;
	self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTPostCargo.name, restOperator, incomingCreateJsonString, expectFailure);
	
	// Check MAFI was created
	parentCargo := self.getMyTerminal().findPrenoteCargo(PARENT_CARGO_ID.toUpper(), app.myRoot.getCargoTypeIDFromAbbrev("UTMAFI"), null, null);
	self.assertNotNullMsg(parentCargo, "Prenote " &amp; PARENT_CARGO_ID);
	// The assumption is that the normal postCargo test has actually checked all the attributes are set correctly...... :|
	
	// Lets just check that the Cuxport EDI Translations for 'Customer Priority' have actually worked though
	priority := parentCargo.myCustomerPriority;
	self.assertNotNullMsg(priority, "[Create] Check EDI Translation worked correctly, Prenote " &amp; PARENT_CARGO_ID &amp; " Customer Priority");
	self.assertEqualMsg(priority.code, systemPriorityCodeP2, "[Create] Unexpected Customer Priority set on Prenote " &amp; PARENT_CARGO_ID);
	
	// Now Check its onboard cargo
	childCargo := self.getMyTerminal().findPrenoteCargo(CHILD_CARGO_ID.toUpper(), app.myRoot.getCargoTypeIDFromAbbrev("PAPER"), parentCargo, null);
	self.assertNotNullMsg(childCargo, "Prenote " &amp; CHILD_CARGO_ID);
	// The assumption is that the normal postCargo test has actually checked all the attributes are set correctly...... :|
	
	// Lets just check that the Cuxport EDI Translations for 'Customer Priority' have actually worked though
	priority := childCargo.myCustomerPriority;
	self.assertNotNullMsg(priority, "[Create] Check EDI Translation worked correctly, Prenote " &amp; CHILD_CARGO_ID &amp; " Customer Priority");
	self.assertEqualMsg(priority.code, systemPriorityCodeP1, "[Create] Unexpected Customer Priority set on Prenote " &amp; CHILD_CARGO_ID);
	
	// Create worked, lets do an Update
	if app.logLevel = LogTRACE then
		self.logMessage(incomingUpdateJsonString);
	endif;
	expectFailure := false;
	queryParam := "/Cargo/TIPE5988399/UTMAFI/" &amp; TI_STATE_NOTIFIED.String &amp; "?MasterTerminalAPI";
	self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTPutCargo.name, restOperator, incomingUpdateJsonString, queryParam, expectFailure);
	
	// We should still hold our reference to the cargo item, so just update priority
	priority := parentCargo.myCustomerPriority;
	self.assertNotNullMsg(priority, "[Update] Check EDI Translation worked correctly, Prenote " &amp; PARENT_CARGO_ID &amp; " Customer Priority");
	self.assertEqualMsg(priority.code, systemPriorityCodeP1, "[Update] Unexpected Customer Priority set on Prenote " &amp; PARENT_CARGO_ID);
	priority := childCargo.myCustomerPriority;
	self.assertNotNullMsg(priority, "[Update] Check EDI Translation worked correctly, Prenote " &amp; CHILD_CARGO_ID &amp; " Customer Priority");
	self.assertEqualMsg(priority.code, systemPriorityCodeP3, "[Update] Unexpected Customer Priority set on Prenote " &amp; CHILD_CARGO_ID);
	
	// Now lets to a GET and see if we get the outbound xlat too
	expectFailure := false;
	path := "/Cargo/" &amp; PARENT_CARGO_ID &amp; "/UTMAFI/" &amp; TI_STATE_NOTIFIED.String &amp; "?MasterTerminal";
	queryParam := "";
	self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTGetCargo.name, restOperator, queryParam, path, expectFailure, response);
	self.assertNotNullMsg(response, "GET /Cargo response");
	
	if app.logLevel = LogTRACE then
		self.logMessage(response);
	endif;
	
	if JadeRegex@findAll(response, '\"customerPriority\":\"(\w+)\"', false, true, matches) = 0 then
		self.assertTrueMsg(false, "CustomerPriority not found in GET /Cargo response");
	endif;
	// "childCargo" is before "customerPriority", so the first match is actually the child
	self.assertEqualMsg(matches.at(2).at(1).value, CUST_PRI_FOREIGN_P1.toUpper(), "[Get] Unexpected Customer Priority set on Prenote " &amp; PARENT_CARGO_ID);
	self.assertEqualMsg(matches.at(1).at(1).value, CUST_PRI_FOREIGN_P3.toUpper(), "[Get] Unexpected Customer Priority set on Prenote " &amp; CHILD_CARGO_ID);
	delete matches;
	matches := null;
	
	// And /Find/Cargo
	expectFailure := false;
	path := "/Find/Cargo";
	queryParam := "?MasterTerminal";
	body := FIND_CARGO;
	self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTFindCargo.name, restOperator, queryParam, body, expectFailure, response);
	self.assertNotNullMsg(response, "GET /Find/Cargo response");
	
	if app.logLevel = LogTRACE then
		self.logMessage(response);
	endif;
	
	if JadeRegex@findAll(response, '\"customerPriority\":\"(\w+)\"', false, true, matches) = 0 then
		self.assertTrueMsg(false, "CustomerPriority not found in GET /Find/Cargo response");
	endif;
	self.assertEqualMsg(matches.at(1).at(1).value, CUST_PRI_FOREIGN_P1.toUpper(), "[Find] Unexpected Customer Priority set on Prenote " &amp; PARENT_CARGO_ID);
	self.assertEqualMsg(matches.at(2).at(1).value, CUST_PRI_FOREIGN_P3.toUpper(), "[Find] Unexpected Customer Priority set on Prenote " &amp; CHILD_CARGO_ID);
	delete matches;
	matches := null;

epilog
	app.changeLogLevel(logLevel);
	
	// It might be problematic if we leave the outgoing Xlations, so lets just remove then all
	if DELETE_XLATIONS and operator &lt;&gt; null then
		self.deleteEDIInwardXlation(CUST_PRI_FOREIGN_P1.toUpper(), XLATION_TYPE_CUSTPRIORITY_BYOP, operator, null);
		self.deleteEDIOutwardXlation(self.stringIfDmast(CUST_PRI_DMAST_P1, CUST_PRI_WMAST_P1), XLATION_TYPE_CUSTPRIORITY_BYOP, operator, null);
		self.deleteEDIInwardXlation(CUST_PRI_FOREIGN_P2.toUpper(), XLATION_TYPE_CUSTPRIORITY_BYOP, operator, null);
		self.deleteEDIOutwardXlation(self.stringIfDmast(CUST_PRI_DMAST_P2, CUST_PRI_WMAST_P2), XLATION_TYPE_CUSTPRIORITY_BYOP, operator, null);
		self.deleteEDIInwardXlation(CUST_PRI_FOREIGN_P3.toUpper(), XLATION_TYPE_CUSTPRIORITY_BYOP, operator, null);
		self.deleteEDIOutwardXlation(self.stringIfDmast(CUST_PRI_DMAST_P3, CUST_PRI_WMAST_P3), XLATION_TYPE_CUSTPRIORITY_BYOP, operator, null);
	endif;
	
	delete pxyPriority;
	delete matches;
end;</source>
    </JadeMethod>
    <JadeMethod name="tPostReleaseRequest" id="dc839620-6a66-4757-b120-f0cce5c54128">
        <updating/>
        <source>tPostReleaseRequest() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who			Reason
29 March 2023	navak20		Task 56915: CUX - MTN-EDBIC - 100 - Process Release Request - Unit Test
14 April 2023 	navlw1 		CR 56852 Task 56915: CUX - MTN-EDBIC - 100 - Process Release Request - Unit Test
31 Jan 2024		navlw1 		CR 61852: Post release request changes to match swagger definition
21 Aug 2024 	navsp1  	TFS Bug 65496: CUX | POST/releaseRequest by Id - Issues on Total Quantity Field
*/
constants
Ref 				: String = "61852";
UTCargoId 			: String = "EDBIC1200";
UTCargoId1 			: String = "EDBIC1201";
UTCargoId2			: String = "EDBIC1202";
UTCargoId3			: String = "EDBIC1203";
VoyageUT 			: String = "UATRELEASEREQ";
VesselUT 			: String = "AalekhTestVessel";
RelId 				: String = "AK12456";
RelById 			: String = "Rel61852";
RelRailById 		: String = "RelRail61852";
RelByType			: String = "RelType61852";
RelTypeId			: String = "RelByType61852";
RelByTypeMulti		: String = "RelMulti61852";
RelWithBooking		: String = "RelWithBooking";
RelWithInvalidType 	: String = "RelWithInvalidType";
BlockStack 			: String = "BS61852";
BulkCargo1			: String = "UTBul01";
BulkCargo2 			: String = "UTBul02";

IncomingJsonString = '[{
    "id" : "'&amp;RelId&amp;'",
    "bookingId" : "",
    "itemsDelivered" : "'&amp; UTCargoId &amp;'",
    "carrierId" : "",
    "consigneeId" : "",
    "consignorId" : "",
    "consignorVoyageId" : "",
    "destinationTerminalId" : "",
    "dischargePortId" : "",
    "estimatedRequiredDateTime" : "2021-08-01T16:30:00Z",
    "freightForwarderId" : "",
    "fullRelease" : false,
    "subTerminalId" : "",
    "operatorId" : "ANZ",
    "releaseByType" : false, 
    "requestDateTime" : "2023-04-04T12:57:00Z",
    "status" : 1,
    "requestType" : "Road",
    "voyageExternalId" : "",
    "voyageId" : "'&amp;VoyageUT&amp;'"
	}]';
JsonNoIdString = '[{
    "id" : "",
    "bookingId" : "",
    "itemsDelivered" : "'&amp; UTCargoId &amp;'",
    "carrierId" : "",
    "consigneeId" : "",
    "consignorId" : "",
    "consignorVoyageId" : "",
    "deliveredToDate" : 3,
    "destinationTerminalId" : "",
    "dischargePortId" : "",
    "estimatedRequiredDateTime" : "2021-08-01T16:30:00Z",
    "freightForwarderId" : "",
    "freightPayerCode" : "",
    "fullRelease" : false,
    "isoTypeId" : "",
    "pinNo" : "",
    "subTerminalId" : "",
    "operatorId" : "ANZ",
    "releaseByType" : false, 
    "remarks" : "hello aalekh",
    "requestDateTime" : "2023-04-04T12:57:00Z",
    "status" : 1,
    "totalRequested" : 10,
    "totalWeightRequested": 0,
    "totalVolumeRequested" : 0,
    "requestType" : "Road",
    "voyageExternalId" : "",
    "voyageId" : "ADV20000"
	}]';
JsonNoVoyageString = '[{
    "id" : "AK12456",
    "bookingId" : "",
    "itemsDelivered" : "'&amp; UTCargoId &amp;'",
    "carrierId" : "",
    "consigneeId" : "",
    "consignorId" : "",
    "consignorVoyageId" : "",
    "deliveredToDate" : 3,
    "destinationTerminalId" : "",
    "dischargePortId" : "",
    "estimatedRequiredDateTime" : "2021-08-01T16:30:00Z",
    "freightForwarderId" : "",
    "freightPayerCode" : "",
    "fullRelease" : false,
    "subTerminalId" : "",
    "operatorId" : "ANZ",
    "releaseByType" : false, 
    "requestDateTime" : "2023-04-04T12:57:00Z",
    "status" : 1,
    "requestType" : "Road",
    "voyageExternalId" : "",
    "voyageId" : ""
	}]';
JsonReleaseTypeString = '[{
    "id" : "AK12456",
    "bookingId" : "",
    "itemsDelivered" : "",
    "carrierId" : "",
    "consigneeId" : "",
    "consignorId" : "",
    "consignorVoyageId" : "",
    "deliveredToDate" : 3,
    "destinationTerminalId" : "",
    "dischargePortId" : "",
    "estimatedRequiredDateTime" : "2021-08-01T16:30:00Z",
    "freightForwarderId" : "",
