<GUIClass name="CMUI_ComboBoxCargoTypeForTerm" id="038bc0af-0846-472f-92b5-2dedaea24e66">
    <superclass name="CMUI_ComboBoxObject"/>
    <transient/>
    <sharedTransientAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="_usergui"/>
    <ImplicitInverseRef name="myTerminal" id="34829ea2-b2fb-4174-bba7-444ca294ffb0">
        <embedded/>
        <type name="CM_Terminal"/>
    </ImplicitInverseRef>
    <JadeMethod name="displayEntry" id="84e43710-2a6a-4d02-b624-3cd661aaff77">
        <controlMethod name="ComboBox::displayEntry"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <executionLocation>client</executionLocation>
        <source>displayEntry(combobox: ComboBox input; _cargoType: CM_CargoBOLType; lstIndex: Integer): String updating, clientExecution;
// ---------------------------------------------------------------------------
// Created:     26 July 2005	cnwhjg1
//
// Purpose:     
// ----------   ----------  --------------------------------------------------
vars

	 failedDAC  :CM_DataAccessController;

begin

	if _cargoType = null then
		return null;
	endif;

	if (not CM_CargoType.hasInstance(_cargoType)) then
		return null;
	endif;

	if (not _cargoType.canUserAccessSelf(null, failedDAC, app.myPassport)) then
		return null;
	endif;
	
	
	return _cargoType.description;

end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
        <Parameter name="_cargoType" type="CM_CargoBOLType"/>
        <Parameter name="lstIndex" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getCollectionJMT" id="4f4c4116-78ce-437b-92ac-ce7f14b2c6a4">
        <source>getCollectionJMT(): Collection protected;
// ---------------------------------------------------------------------------
// Created:     26 July 2005	cnwhjg1
//
// Purpose:     
// ----------   ----------  --------------------------------------------------
vars

begin

	if self.myTerminal = null then 
		app.writeStatement(class.name &amp; '::' &amp; method.name &amp; " -  Developer needs to set Terminal for this combobox");
		return null;
	else 
		return self.myTerminal.allCargoBOLTypes;
	endif;
end;</source>
        <access>protected</access>
        <ReturnType type="Collection"/>
    </JadeMethod>
