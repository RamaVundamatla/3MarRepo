    <JadeMethod name="initialPopulate" id="595acaef-a373-431b-a47e-73dc50856657">
        <source>initialPopulate(listbox: ListBox; level : Integer);
// 35386
vars
	pic : Picture;
	tmc : CMIF_TranMapController;

begin
	if level &gt; 3 then
		return;
	endif;
	listbox.addItem(itemName);
	listbox.itemLevel[listbox.newIndex] := level;
	listbox.itemObject[listbox.newIndex] := self;
	listbox.itemData[listbox.newIndex] := self.getType(); //epr TFS 3051 29/11/16
	pic := getPicture(listbox.form.INV_TransactionMap);
	if pic &lt;&gt; null then
		listbox.itemPicture[listbox.newIndex] := pic.picture;
	endif;
	listbox.itemPictureType[listbox.newIndex] := ListBox.ItemPictureType_Closed;
	foreach tmc in self.CMIF_TMCGroup.allGroupMembers do
		tmc.initialPopulate(listbox, level + 1);
	endforeach;

end;
</source>
        <Parameter name="listbox" type="ListBox"/>
        <Parameter name="level" type="Integer"/>
    </JadeMethod>
