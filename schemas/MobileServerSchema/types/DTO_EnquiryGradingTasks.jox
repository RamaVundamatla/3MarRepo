    <JadeMethod name="delete" id="55442640-4caa-48ff-8140-0fd7fcec715b">
        <updating/>
        <source>delete() updating;
// -------------------------------------------
// Created 23 January 2006 by cnwdvb1
//
// 28 Feb 2008	cnwkpd1	PAR #16010 - CCMS Otago 1502 - Thin Client RT Enhancements
// -------------------------------------------
vars

begin

	self.allToDoTasks.purge();
	self.allGrades.purge();
	self.allContainerSearchResults.purge();			// PAR #16010
	self.allQueueEntries.purge();
	self.allQueues.purge();

end;</source>
    </JadeMethod>
    <JadeMethod name="extrapolateToDoTaskStates" id="b201b084-950f-4dfd-b084-7b310d05ea61">
        <source>extrapolateToDoTaskStates(_allTasksToAdd, _allTasksToComplete, _allTasksToRemove : IntegerArray input);
// -------------------------------------------
// Created 23 January 2006 by cnwdvb1
// -------------------------------------------
vars

	toDoTask	: DTO_ToDoTask;

begin

	foreach toDoTask in self.allToDoTasks do
		if toDoTask.state = DTO_ToDoTask.Add and not _allTasksToAdd.includes(toDoTask.code) then
			_allTasksToAdd.add(toDoTask.code);
		elseif toDoTask.state= DTO_ToDoTask.Remove and not _allTasksToRemove.includes(toDoTask.code) then
			_allTasksToRemove.add(toDoTask.code);
		elseif toDoTask.state= DTO_ToDoTask.Complete and not _allTasksToComplete.includes(toDoTask.code) then
			_allTasksToComplete.add(toDoTask.code);
		endif;
	endforeach;

end;</source>
        <Parameter name="_allTasksToAdd" type="IntegerArray" usage="input"/>
        <Parameter name="_allTasksToComplete" type="IntegerArray" usage="input"/>
        <Parameter name="_allTasksToRemove" type="IntegerArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setFromFindAllQEntriesResults" id="fcfb9dba-c844-417e-9bbe-22bbdcab2d21">
        <updating/>
        <source>setFromFindAllQEntriesResults(_queueEntries : CM_RTQueueEntrySet) updating;

/*

Purpose:			Set up the list of queue entry results on the receiver from the
					passed in set of results


Return Value:		allQueueEntries updated accordingly


Date		Who		Reason
13 Mar 2008	cnwkpd1	PAR #16010 - CCMS Otago 1502 - Thin Client RT Enhancements

*/

vars
	queueEntry		: CM_RTQueueEntry;
	dtoQueueEntry	: DTO_RTQueueEntry;
	maxResults,
	resultCount		: Integer;
	
begin
	// Clear any prior results
	self.allQueueEntries.purge;
	self.searchWarningMessage := null;
	
	maxResults := app.getMyTerminalDO_NOT_USE().myRTVehicleConfig.maxNumberQueueEntries.max(1); //epr CCMS 1099 moved config
	resultCount := 0;
	
	// Copy the results set to the receiver
	foreach queueEntry in _queueEntries do
		resultCount := resultCount + 1;
		if resultCount &gt; maxResults then
			self.searchWarningMessage := app.getErrorString1(Max_Queue_Entries_Displayed, maxResults.asStringJMT);
			break;
		endif;
		
		create dtoQueueEntry transient;
		dtoQueueEntry.setFromPersistent(queueEntry);
		
		self.allQueueEntries.add(dtoQueueEntry);
	endforeach;
	
	
epilog
		
end;</source>
        <Parameter name="_queueEntries" type="CM_RTQueueEntrySet"/>
    </JadeMethod>
    <JadeMethod name="setFromFindQueuesResults" id="8fec1f7d-0f77-427a-8876-779e73e4ebf2">
        <updating/>
        <source>setFromFindQueuesResults(_queues : CM_RTQueueSet) updating;

/*

Purpose:			Set up the list of avaialble queues on the receiver from the
					passed in set of queues


Return Value:		allQueues updated accordingly


Date		Who		Reason
11 Mar 2008	cnwkpd1	PAR #16010 - CCMS Otago 1502 - Thin Client RT Enhancements

*/

vars
	queue			: CM_RadioTelemetryQueue;
	dtoQueue		: DTO_RTQueue;
	
begin
	// Clear any prior results
	self.allQueues.purge;
	
	// Copy the results set to the receiver
	foreach queue in _queues do
		create dtoQueue transient;
		dtoQueue.setFromPersistent(queue);
		
		self.allQueues.add(dtoQueue);
	endforeach;
	
	
epilog
	
end;
</source>
        <Parameter name="_queues" type="CM_RTQueueSet"/>
    </JadeMethod>
    <JadeMethod name="setFromMediator" id="c1b86ae0-212a-440e-848c-b830a16fc19c">
        <updating/>
        <source>setFromMediator(_mediator : CM_RadioTelemetryMediator input) updating;
// -------------------------------------------
// Created 11 January 2006 by cnwdvb1
// -------------------------------------------
vars

	task		: CM_RTQueueTask;
	ti,
	overstowTI	: CM_TrackedItem;
	str,
	strDoors,
	coolingTypeStr,
	lenOfTI		: String;
	location	: CM_LocationsController;
	request		: CM_Request;
	wle			: CM_WorkListEntry;

begin

	task := _mediator.task;
	if not global.isValidObject(task) then
		return;
	endif;
	
	self.taskType 					:= task.taskTypeId;
	if task.sourceLocation &lt;&gt; null then
		self.currentLocationID			:= task.sourceLocation.getFullIdForTI(false);
	endif;
	
	location				:= task.ultimateTargetLocation;
	if location &lt;&gt; null then
		// Par 11342
		//self.targetLocation				:= location.getFullId();
		self.targetLocation				:= location.getFullIdForTI(true);
	endif;
	

	if task.taskType = TASK_DIRECTOR then
		str := task.tiId.trimRight;
		if task.myEntry.myJob &lt;&gt; null then
			str := str &amp;  " " &amp; task.myEntry.getRequestRemarks();
			str := str &amp;  task.myEntry.myJob.getSelectedTiIds();
		endif;
		self.remarks := str; 
		return;
	endif;
		
	ti := task.ti;
	
	if ti = null then
		return;
	endif;
	
	// ccms 1536
	if ti.isContainer() then
		self.isControlledAtmosphere := ti.CM_Container.isControlledAtmosphere;
		if ti.CM_Container.getCoolingType &lt;&gt; ContainerCooledNull then
			coolingTypeStr := ' ' &amp; app.coolingTypeENumToString(ti.CM_Container.getCoolingType, false);
		endif;
	endif;
	
	wle		:= task.myEntry.myWorkListEntry;
	request := wle.myRequest;
	
	if request &lt;&gt; null then
		strDoors := request.getDoorDirectionDescription(wle.getTargetLocation(), wle.myTrackedItem);
		if strDoors &lt;&gt; null then
			strDoors := 'Doors ' &amp; strDoors;
		endif;
	endif;
	 	
 	self.containerID				:= ti.id;// &amp; lenOfTI;
 	self.commodity					:= ti.commodity;
 	self.dischargePort				:= ti.dischargePort;
 	self.hasStops					:= ti.hasStops;
 	self.imexStatusDesc				:= app.getIMEXStringFromIMEXStatus(ti.getImExStatus());
 	self.isoType					:= (ti.getISOType() &amp; coolingTypeStr)[1:30];
 	if ti.myOperator &lt;&gt; null then
	 	self.operatorCode			:= ti.myOperator.code;
	endif;
	self.receivedDateTime			:= ti.receivedDT;
	self.remarks					:= (ti.remarks.trimRight() &amp; ' ' &amp; strDoors ).trimRight().trimLeft();	//when strDoors=null, we have to trim
	self.voyageCode					:= ti.voyageCode;
	self.weight						:= ti.totalWeight.Integer;//ti.weight.Integer; //1/07/2009 cnwdz2 par19681
	self.hazards					:= ti.getHazardsAsString();
	self.queuedLocationID			:= ti.queuedLocnId; //epr 14/12/07 CCMS1626
	self.setToDoTasks(ti);
	self.setGrades(ti);
	
	// 03/02/2008 cnwar2 #16377
	if ti.isOverStowed(REAL_MODE) then
		overstowTI := ti.getTandemLiftBox();
		if overstowTI &lt;&gt; null then
			self.overstowContainerID := overstowTI.id;
		endif;
	endif;

end;</source>
        <Parameter name="_mediator" type="CM_RadioTelemetryMediator" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setFromTI" id="dd14851c-6526-44bb-ac31-caca52c8446c">
        <updating/>
        <source>setFromTI(_ti : CM_TrackedItem) updating;
// -------------------------------------------
// Created 16 January 2006 by cnwdvb1
// -------------------------------------------
vars

	location 		: CM_LocationsController;
	coolingTypeStr	: String;
	container		: CM_Container;
	overstowTI		: CM_TrackedItem;
	doorDir			: String;
	
begin

	if _ti = null then
		return;
	endif;
	
	// CCMS 1448
	if _ti.isContainer() then
		container := _ti.CM_Container;
		if container.getCoolingType &lt;&gt; ContainerCooledNull then
			coolingTypeStr := ' ' &amp; app.coolingTypeENumToString(_ti.CM_Container.getCoolingType, false);
		endif;
	endif;
	

	self.containerID				:= _ti.id;// &amp; lenOfTI;
 	self.commodity					:= _ti.commodity;
 	self.dischargePort				:= _ti.dischargePort;
 	self.hasStops					:= _ti.hasStops;
 	self.imexStatusDesc				:= app.getIMEXStringFromIMEXStatus(_ti.getImExStatus());
 	self.isoType					:= (_ti.getISOType() &amp; coolingTypeStr)[1:30];
 	if _ti.myOperator &lt;&gt; null then
	 	self.operatorCode			:= _ti.myOperator.code;
	endif;
	self.receivedDateTime			:= _ti.receivedDT;
	
	location := _ti.getPrimaryLocation(REAL_MODE);
	if location &lt;&gt; null then
		doorDir := location.getDoorDirectionWording(_ti.getISOTypeGroup());
		if doorDir &lt;&gt; null then
			doorDir := "Doors " &amp; doorDir;
		endif;
	endif;
	self.remarks					:= (_ti.remarks.trimRight() &amp; ' ' &amp; doorDir ).trimRight().trimLeft();
	self.voyageCode					:= _ti.voyageCode;
	self.weight						:= _ti.totalWeight.Integer;//_ti.weight.Integer; //1/07/2009 cnwdz2 par19681
	self.queuedLocationID			:= _ti.queuedLocnId; //epr 14/12/07 CCMS1626
	//location						:= _ti.getPrimaryLocation(REAL_MODE);
	//if location &lt;&gt; null then
		//self.currentLocationID			:= location.getFullId();
		//self.currentLocationID			:= location.getFullIdForTI(false);
		self.currentLocationID	:= _ti.getPrimaryLocationId(REAL_MODE);
//	endif;
	self.hazards					:= _ti.getHazardsAsString();
	self.setToDoTasks(_ti);
	self.setGrades(_ti);

	// ccms 1536
	if _ti.isContainer() then
		self.isControlledAtmosphere := _ti.CM_Container.isControlledAtmosphere;
	endif;
	
	// 03/02/2008 cnwar2 #16377
	if _ti.isOverStowed(REAL_MODE) then
		overstowTI := _ti.getTandemLiftBox();
		if overstowTI &lt;&gt; null then
			self.overstowContainerID := overstowTI.id;
		endif;
	endif;
end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="setFromTISearchResults" id="135860e2-4db3-4379-8315-26688597eb06">
        <updating/>
        <source>setFromTISearchResults(_tiSet : CM_TISet) updating;

/*

Purpose:			Set up the list of container search results on the receiver from the
					passed in set of results


Return Value:		allContainerSearchResults updated accordingly


Date		Who		Reason
04 Mar 2008	cnwkpd1	PAR #16010 - CCMS Otago 1502 - Thin Client RT Enhancements

*/

vars
	iter			: Iterator;
	container		: CM_Container;
	dtoContainer	: DTO_ContainerSearchInfo;
	maxResults,
	resultCount		: Integer;
	
begin
	// Clear any prior results
	self.allContainerSearchResults.purge;
	self.searchWarningMessage := null;
	
	maxResults := app.getMyTerminalDO_NOT_USE().myRTVehicleConfig.maxNumberSearchResults.max(1); //epr 25/5/10  CCMS 1099 moved config
	resultCount := 0;
	
	// Copy the results set to the receiver
	iter := _tiSet.createIterator;
	while iter.next(container) do
	
		resultCount := resultCount + 1;
		if resultCount &gt; maxResults then
			self.searchWarningMessage := app.getErrorString1(Max_Search_Results_Exceeded, maxResults.asStringJMT);
			break;
		endif;
		
		create dtoContainer transient;
		dtoContainer.setFromPersistent(container);
		
		self.allContainerSearchResults.add(dtoContainer);
	endwhile;
	
	
epilog
	delete iter;
	
end;</source>
        <Parameter name="_tiSet" type="CM_TISet"/>
    </JadeMethod>
    <JadeMethod name="setGrades" id="98a4425d-55cf-4fb0-ac38-1ddc182d78de">
        <source>setGrades(_ti	: CM_TrackedItem) protected;
// -------------------------------------------
// Created 23 January 2006 by cnwdvb1
// -------------------------------------------
vars

	currentGrade	: Integer;
	grade			: CM_MTGrade;
	dto				: DTO_Grade;
	code			: CM_MTGradeCode;
	canDisplay		: Boolean;

begin

	self.allGrades.purge();
	if not _ti.canSetAvailabilityGrade() then
		return;
	endif;
	
	currentGrade := _ti.getAvailabilityGrade;
	
	foreach grade in app.myRoot.allAvailableAvailabilityGrades do
		grade.getTranslationForOperator(grade, _ti.myOperator, null, code, canDisplay);
		create dto transient;
		if code = null then
			dto.description := grade.description;
		else
		 	dto.description	:= code.description;
		endif;
			
		self.allGrades.add(dto);
		dto.code 		:= grade.code;
		if grade.code = currentGrade then
			dto.isCurrentGrade := true;
		endif;
	endforeach;

end;</source>
        <access>protected</access>
        <Parameter name="_ti" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="setToDoTasks" id="6cd69036-1306-4a4e-be7d-e898333ea3ad">
        <source>setToDoTasks(_ti	: CM_TrackedItem) protected;
// -------------------------------------------
// Created 23 January 2006 by cnwdvb1
// -------------------------------------------
vars

	descArray		: CM_ToDoTaskDescArray;
	toDoTask		: CM_ToDoTask;
	toDoTaskDesc	: CM_ToDoTaskDesc;
	dto				: DTO_ToDoTask;
	trans			: CM_TITransaction;
	
begin

	self.allToDoTasks.purge();
	create descArray transient;
    foreach toDoTask in _ti.allToDoTasksToDo do
    	descArray.add(toDoTask.toDoTaskDesc);
    	create dto transient;
    	self.allToDoTasks.add(dto);
    	dto.code		:= toDoTask.toDoTaskDescCode;
    	dto.description	:= toDoTask.toDoTaskDescShort.trimRight();
		//dto.completedTs	:= _ti.getLastToDoTaskDate(toDoTask.toDoTaskDescCode);
		toDoTaskDesc := toDoTask.getMyToDoTaskDesc();
		if toDoTaskDesc &lt;&gt; null then
			// Par 15240
			dto.txnType := toDoTaskDesc.trxTypeOnCompletion;
			trans	:= _ti.getLastTransOfType(toDoTaskDesc.trxTypeOnCompletion);
			if trans &lt;&gt; null then
				dto.completedTs := trans.dateTime;
			endif;
		endif;
		dto.state		:= dto.Selected;
	endforeach;


	foreach toDoTaskDesc in app.myRoot.allToDoTaskDescsBySortOrder where toDoTaskDesc.isAvailableForCargoType(_ti.cargoType) do
		if descArray.includes(toDoTaskDesc) then 
			continue;
		endif;
		create dto transient;
    	self.allToDoTasks.add(dto);
    	dto.code		:= toDoTaskDesc.code;
    	dto.description	:= toDoTaskDesc.shortDescription.trimRight();
		//dto.completedTs	:= _ti.getLastToDoTaskDate(toDoTaskDesc.code);
		trans	:= _ti.getLastTransOfType(toDoTaskDesc.trxTypeOnCompletion);
		if trans &lt;&gt; null then
			dto.completedTs := trans.dateTime;
		// Par 15075
		elseif _ti.isContainer() and toDoTaskDesc.trxTypeOnCompletion = TRANS_TYPE_PRETRIP then
			dto.completedTs := _ti.CM_Container.getPreTripDT;
		endif;
		dto.state		:= dto.UnSelected;
		// Par 15240
		dto.txnType := toDoTaskDesc.trxTypeOnCompletion;
	endforeach;
	
epilog
	delete descArray;
end;</source>
        <access>protected</access>
        <Parameter name="_ti" type="CM_TrackedItem"/>
    </JadeMethod>
</Class>
