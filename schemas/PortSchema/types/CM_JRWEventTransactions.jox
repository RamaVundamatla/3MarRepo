    <JadeMethod name="getFromDTLocalTZ" id="af82a748-4ac2-40ab-a59d-268ad3993d97">
        <source>getFromDTLocalTZ():TimeStamp;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 January 2020	jlgndl1	Initial creation	TFS 47780

*/

vars

begin

	return self.systemToLocalTime(self.fromDT);

epilog

end;</source>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="getToDTLocalTZ" id="e837a5ce-ec28-4ef6-983a-beb5eeb31028">
