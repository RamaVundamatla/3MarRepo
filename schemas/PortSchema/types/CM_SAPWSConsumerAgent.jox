    <JadeMethod name="setBaseEndpoint" id="a8da6c8d-b791-4453-9b06-08b163358a02">
        <updating/>
        <source>setBaseEndpoint(_endPoint: String) updating;
/*

Purpose:			Update the base endpoint for the SAP consumer(s)

Parameters:			Base endpoint to set

Return Value:		None

Date		Who		Reason
11 Jun 2018	jlgkpd1	TFS #37190 - Pelindo 1 INAPORTNET Integration

*/

vars
	
begin
	inheritMethod(_endPoint);
	
	// For SAP, we create a new consumer for each call if required, so will need to set the real base endpoint
	// then. To force this when the baseEndpoint is updated, just delete any current Web Service Consumer
	delete self.myWebServiceConsumer;
	
epilog
	
end;
</source>
        <Parameter name="_endPoint" type="String"/>
    </JadeMethod>
</Class>
