    <JadeMethod name="setCaption" id="fd26758a-c14d-4f1a-9f05-786ed88f9bd8">
        <updating/>
        <source>setCaption(_caption: String) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
//06/06/2025	navkc1 JIRA MTN 34779 MTN | Cash Status Change for Special Users.

*/

vars
	captionStr : String;
begin
	captionStr := _caption &amp; " " &amp; self.myCashReceipt.sequenceNum.String;
	
	inheritMethod(captionStr);

epilog

end;</source>
        <Parameter name="_caption" type="String"/>
    </JadeMethod>
