<Class name="CMIF_TMCQuantityRangeGroupDeft" id="a602854d-22ef-4be3-8963-3922cfbdeaf6">
    <superclass name="CMIF_TMCQuantityRangeGroup"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>
This transient class is used to represent the CM_SERVICEBROKER object's mappings.

This is the DEFAULT</text>
    <DbClassMap file="invoice"/>
    <JadeMethod name="initialise" id="12e8e28e-3dbc-4ac5-8d5a-93d1ccf6554b">
        <updating/>
        <source>initialise(_groupCount : Integer io) updating;
//09/02/2017 cnwma1  TFS #2901:ADP - Variable storage charges based on weight and time

vars
	ild: CM_InvoiceLineDesc;
	tmcS : CMIF_TMCInvLineDesc;
	resContractIn : CMIF_TMCResourceContractIN;
	resContractOut : CMIF_TMCResourceContractOUT;
	sb : CM_ServiceBroker;
	finObj : CM_FinancialObject;
	lineMapDict		: CM_TMInvLineMapByCargoAttrDict;
	lineMapping		: CM_TranMapInvoiceLineMapping;
	tmcQRSubM : CMIF_TMCQuantitySubRangeGroup;  //09/02/2017 cnwma1 TFS #2901
	invalidObj : Boolean;	//17 Dec 2019	NDL	TFS 48039
	edition : Integer;	//17 Dec 2019	NDL	TFS 48039
begin
	self.myTMCController := self.myGroup.myTMCController;	// April 2010, cnwjre1, par 23659, invoice transaction map extract enhancements for Tranship IMEX status
	self.hidePictures := self.myTMCController.hidePictures;
	finObj := self.myQuantityRangeMap.myQuantityMap.myParentFinancialObject;
	if finObj.isKindOf(CM_DebtorMap) then
		sb := finObj.CM_DebtorMap.myServiceBroker;
	elseif finObj.isKindOf(CM_QuantityRangeMap) then  //09/02/2017 cnwma1 TFS #2901
		//Pending cnwma1
	else
		sb := finObj.CM_ServiceBroker;
	endif;
	if sb.isKindOf(CM_ResourceServiceBroker) then
	
		create resContractIn;
		resContractIn.myDebtorMap := null;
		resContractIn.myDebtor := null;
		resContractIn.myServiceBroker := finObj.CM_ResourceServiceBroker; 
		resContractIn.itemName := resContractIn.getItemName();
		resContractIn.extractName := resContractIn.getItemName();	// 23659
		resContractIn.myGroup := self;
		resContractIn.myQuantityRangeMap := self.myQuantityRangeMap;
		resContractIn.initialise(_groupCount);

		create resContractOut;
		resContractOut.myDebtorMap := null;
		resContractOut.myDebtor := null;
		resContractOut.myQuantityRangeMap := self.myQuantityRangeMap;
		resContractOut.myServiceBroker := finObj.CM_ResourceServiceBroker; 
		resContractOut.itemName := resContractOut.getItemName();
		resContractOut.extractName := resContractOut.getItemName();	// 23659
		resContractOut.myGroup := self;
		resContractOut.initialise(_groupCount);
		
	else
		//09/02/2017 cnwma1 TFS #2901
		if self.myQuantityRangeMap &lt;&gt; null then
			if self.myQuantityRangeMap.myChildQuantityMap &lt;&gt; null then
				create tmcQRSubM;
				tmcQRSubM.myGroup := self;
				//tmcQRSubM.itemName := self.myQuantityRangeMap.myChildQuantityMap.getExtractDetails();	 //23/02/2017 cnwma1 TFS 2901
				tmcQRSubM.itemName := self.myQuantityRangeMap.myChildQuantityMap.getName();	             //23/02/2017 cnwma1 TFS 2901
				tmcQRSubM.extractName := self.myQuantityRangeMap.myChildQuantityMap.getExtractDetails();		
				tmcQRSubM.myQuantityRangeMap := self.myQuantityRangeMap;
				tmcQRSubM.initialise(_groupCount);
				_groupCount := _groupCount + 1;	//17 Dec 2019	NDL	TFS 48039
				return;
			endif;
		endif;
		//09/02/2017 cnwma1 TFS #2901
		
		on Exception do app.handleDeletedObject( exception, ild , invalidObj );		//17 Dec 2019	NDL	TFS 48039
		
		lineMapDict := self.myQuantityRangeMap.allTMInvoiceLineMappings;
		foreach lineMapping in lineMapDict do
			ild := lineMapping.myTMInvoiceLineDesc;
			
			//17 Dec 2019	NDL	TFS 48039
			edition := ild.edition;
			if invalidObj then
				invalidObj := false;
				continue;
			endif;
			
			//add in each service in the list
			if self.allGroupMembers[ild.narration] = null then
				create tmcS;
				tmcS.itemName := ild.narration;
				tmcS.extractName := ild.narration;	// 23659
				tmcS.myQuantityRangeMap := self.myQuantityRangeMap;
				tmcS.myGroup := self;
				tmcS.myInvoiceLineDesc := ild;
				tmcS.hidePictures := self.myTMCController.hidePictures;
				_groupCount := _groupCount + 1;
			endif;
		endforeach;
	endif;
	
	_groupCount := _groupCount + 1;
end;</source>
        <Parameter name="_groupCount" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="isDefault" id="eaa3ba55-571d-4382-bde0-e97851d09378">
        <source>isDefault() : Boolean;
// ---------------------------------------------------------------------------
// Created:		03 October 2007 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
begin
	return true;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isVTMIS" id="792b33e9-89ff-4934-94b7-36edbfb26490">
        <source>isVTMIS(): Boolean;
// for 23659
//09/02/2017 cnwma1  TFS #2901:ADP - Variable storage charges based on weight and time
//21/09/2017 cnwma1  TFS #7043:CPL - High priority issue: Transaction map csv load
vars
	aTransSB : CM_ServiceBroker; 
	isVTMIS	: Boolean;
	finObject : CM_FinancialObject;
begin
	
	/*21.09.2017 cnwma1 TFS #7043
	if self.myQuantityRangeMap.myQuantityMap.myParentFinancialObject.isKindOf(CM_ServiceBroker) then  //09/02/2017 cnwma1 TFS #2901
		aTransSB := self.myQuantityRangeMap.myQuantityMap.myParentFinancialObject.CM_ServiceBroker;
	elseif  self.myQuantityRangeMap.myQuantityMap.myParentFinancialObject.isKindOf(CM_QuantityRangeMap) then
		aTransSB := self.myQuantityRangeMap.myQuantityMap.myParentFinancialObject.CM_QuantityRangeMap.myQuantityMap.myParentFinancialObject.CM_ServiceBroker;
	endif;
	*/
	
	// 21.09.2017 cnwma1 TFS #7043
	finObject := self.myQuantityRangeMap.myQuantityMap.myParentFinancialObject;
	
	if finObject.isKindOf(CM_ServiceBroker) then
		aTransSB := finObject.CM_ServiceBroker;
	elseif finObject.isKindOf(CM_QuantityRangeMap) then
		if finObject.CM_QuantityRangeMap.myQuantityMap.myParentFinancialObject.isKindOf(CM_ServiceBroker) then
		
			aTransSB := finObject.CM_QuantityRangeMap.myQuantityMap.myParentFinancialObject.CM_ServiceBroker;
			
		elseif finObject.CM_QuantityRangeMap.myQuantityMap.myParentFinancialObject.isKindOf(CM_DebtorMap) then
			aTransSB := finObject.CM_QuantityRangeMap.myQuantityMap.myParentFinancialObject.CM_DebtorMap.myServiceBroker;
		endif;
	endif;
	// 21.09.2017 cnwma1 TFS #7043
	
	if aTransSB.isKindOf(CM_ResourceServiceBroker) then
		isVTMIS := true;
	endif;

	return isVTMIS;
end;
</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setControllerCurrent" id="280be2c9-c307-4f9d-ac51-f5d5f1115792">
        <source>setControllerCurrent() ;
// April 2010, cnwjre1, par 23659, invoice transaction map extract enhancements for Tranship IMEX status
vars
	aTransSB : CM_ServiceBroker; 
	aCommMap : CM_CommodityMap;
	isEvent, isVTMIS : Boolean;
	isBOL : Boolean;	//04 Nov 2019	NDL TFS 47100
begin
	inheritMethod();

	aTransSB := self.myQuantityRangeMap.myQuantityMap.myParentFinancialObject.CM_ServiceBroker;
	if aTransSB.isKindOf(CM_TransServiceBroker) then
		aCommMap := aTransSB.CM_TransServiceBroker.commodityMap;
	elseif aTransSB.isKindOf(CM_ResourceServiceBroker) then
		isVTMIS := true;
	elseif aTransSB.isKindOf(CM_EventServiceBroker) then
		isEvent := true;
	elseif aTransSB.isKindOf(CM_MoveServiceBroker) then
		aCommMap := aTransSB.CM_MoveServiceBroker.commodityMap;
	elseif aTransSB.isKindOf(CM_BOLServiceBroker) then	//04 Nov 2019	NDL TFS 47100
		isBOL := true;
	else
		return;
	endif;

	myTMCController.myCurrentMapQuantity := self.myQuantityRangeMap.myQuantityMap;
	myTMCController.myCurrentMapQuantityRange := self.myQuantityRangeMap;
	
	if aTransSB.isKindOf(CM_ResourceServiceBroker) then
		myTMCController.myCurrentMapTMVoyage := aTransSB.CM_ResourceServiceBroker.myTransMap;
		myTMCController.myCurrentMapDebtor := null;
		myTMCController.myCurrentMapServiceBroker := aTransSB;
	elseif aTransSB.isKindOf(CM_EventServiceBroker) then
		myTMCController.myCurrentMapTMEvent := aTransSB.CM_EventServiceBroker.myTranMap;
		myTMCController.myCurrentMapDebtor := null;
		myTMCController.myCurrentMapServiceBroker := aTransSB;
	elseif aTransSB.isKindOf(CM_BOLServiceBroker) then		//04 Nov 2019	NDL TFS 47100
		myTMCController.myCurrentMapTMBOL := aTransSB.CM_BOLServiceBroker.myTransMap;
		myTMCController.myCurrentMapDebtor := null;
		myTMCController.myCurrentMapServiceBroker := aTransSB;
	else
		myTMCController.myCurrentMapDebtor := null;
		myTMCController.myCurrentMapServiceBroker := aTransSB;
		myTMCController.myCurrentMapCommodity := aCommMap;
		myTMCController.myCurrentMapContents := aCommMap.contentsMap;
		myTMCController.myCurrentMapIMEX := myTMCController.myCurrentMapContents.imexMap;
		myTMCController.myCurrentMapProduct := myTMCController.myCurrentMapIMEX.myProductMap;
		myTMCController.myCurrentMapProdGrp := myTMCController.myCurrentMapProduct.myProductGroupMap;
		myTMCController.myCurrentMapTIService := myTMCController.myCurrentMapProdGrp.myCargoTypeMap;
		myTMCController.myCurrentMapTM := myTMCController.myCurrentMapTIService.transactionMap;

	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="setEnableObjects" id="4b5d2471-2202-4f4c-ba9b-18f46903dbf2">
        <source>setEnableObjects(form: INV_TransactionMap io);
// ---------------------------------------------------------------------------
// Created:		25 July 2005  By Andrew Bishop cnwab1
//
// Purpose:		
// 09/02/2017 	cnwma1  TFS #2901:ADP - Variable storage charges based on weight and time
// 15/01/2019	jlgdap1	TFS 39160 Transaction Map Issues
// 15/05/2023	navkc1	CR 57927 Task 54268 - Transaction Map
// ---------------------------------------------------------------------------

vars
	allowUpdate, allowDelete 			: Boolean;
	isEvent, isVTMIS, isWO 	: Boolean;
	aTransSB 				: CM_ServiceBroker;
	debtorMap 				: CM_DebtorMap;
	isBOL, showLineMapping 					: Boolean;
	isToDoResource 			: Boolean; // 15/05/2023	navkc1	CR 57927 Task 54268
	calcType : CM_CalculationType;
begin
	inheritMethod(form);

	if self.myQuantityRangeMap = null then
		return;
	endif;
	if self.myGroup.isKindOf(CMIF_TMCQuantitySubRangeGroup) then //09/02/2017 cnwma1 TFS #2901
		if self.myGroup.CMIF_TMCQuantitySubRangeGroup.myQuantityRangeMap.myQuantityMap.myParentFinancialObject.isKindOf(CM_ServiceBroker)then
			aTransSB := self.myGroup.CMIF_TMCQuantitySubRangeGroup.myQuantityRangeMap.myQuantityMap.myParentFinancialObject.CM_ServiceBroker; //09/02/2017 cnwma1 TFS #2901
		
		elseif self.myGroup.CMIF_TMCQuantitySubRangeGroup.myQuantityRangeMap.myQuantityMap.myParentFinancialObject.isKindOf(CM_DebtorMap) then //17/02/2017 cnwma1 TFS #2901
			debtorMap := self.myGroup.CMIF_TMCQuantitySubRangeGroup.myQuantityRangeMap.myQuantityMap.myParentFinancialObject.CM_DebtorMap; //09/02/2017 cnwma1 TFS #2901
			if debtorMap &lt;&gt; null then				  //17/02/2017 cnwma1 TFS #2901
				aTransSB := debtorMap.myServiceBroker; //17/02/2017 cnwma1 TFS #2901
			endif;
		endif;
	else
		aTransSB := self.myGroup.CMIF_TMCQuantityGroupDefault.myServiceMap;
	endif;
	if aTransSB.isKindOf(CM_ResourceServiceBroker) then
		isVTMIS := true;
	elseif aTransSB.isKindOf(CM_WorkOrderServiceBroker) then // TFS 39236
		isWO := true;
	elseif aTransSB.isKindOf(CM_BOLServiceBroker) then //01 Nov 2019	NDL	TFS 47100
		isBOL := true;
	elseif aTransSB.isKindOf(CM_EventServiceBroker) then
		isEvent := true;
	elseif aTransSB.isToDoRsrcServiceBroker() then // 15/05/2023	navkc1	CR 57927 Task 54268
		isToDoResource := true;
	endif;

	allowUpdate := not self.myQuantityRangeMap.myQuantityMap.isDefault();
	
	// TFS 2198 CNWAB1
	if not app.myCurrentUserCan(form.myTerminal, form.permissionMaint) then
		allowUpdate := false;
	endif;

	// ### TFS BUG 59956 31AUG2023 NAVAB1
	allowDelete := (self.myQuantityRangeMap.myQuantityMap.allQuantityRanges.size &gt; 1);
	calcType := self.myQuantityRangeMap.myQuantityMap.myCalculationType;
	if calcType &lt;&gt; null then
		if allowUpdate then
			allowUpdate := (calcType.allQuantityRanges.size = 0);
		endif;
		if allowDelete then
			allowDelete := (calcType.allQuantityRanges.size = 0);
		endif;
	endif;
	
	// ### JIRA 34596 14APR2025 NAVAB1
	showLineMapping := not isVTMIS;
	if showLineMapping then
		showLineMapping := not self.allGroupMembers.first.isKindOf(CMIF_TMCQuantitySubRangeGroup);
	endif;
	
	form.modePropertyNew := INV_TransactionMap.ModeProperty_QuantityRange;
	form.modePropertyUpdate := INV_TransactionMap.ModeProperty_QuantityRange;
	form.modePropertyDelete := INV_TransactionMap.ModeProperty_QuantityRange;
	form.btnDelete.enabled := allowDelete;// ### TFS BUG 59956 31AUG2023 NAVAB1
	form.btnNew.enabled := false;
	form.btnProperties.enabled := allowUpdate;
	form.menuSItemDelete.visible := allowDelete;// ### TFS BUG 59956 31AUG2023 NAVAB1
	// from 29499 QNS 2177 development, for Voyage tran map, only allow update of invoice line descs at IIN/OUT contract level, otherwise the update code gets it wrong
	form.mnuSItemUpdate.visible := showLineMapping; // ### JIRA 34596 14APR2025 NAVAB1
	form.menuSItemProperties.visible := allowUpdate;
	
	//09/02/2017 cnwma1 TFS #2901
	if self.myQuantityRangeMap &lt;&gt; null then						
		if self.myQuantityRangeMap.myChildQuantityMap = null then
			if allowUpdate then									// TFS 39160
				form.btnNew.enabled := true;
				form.menuSItemNew.visible := true;
				form.menuSINewSubQTY.visible :=allowUpdate;
				form.menuSINewSubQTY.enabled := allowUpdate;
			endif;												// TFS 39160
		endif;
		if self.myQuantityRangeMap.myQuantityMap.myParentFinancialObject.isKindOf(CM_QuantityRangeMap) then
			form.btnNew.enabled := false;
			form.menuSItemNew.visible := false;
			form.menuSINewSubQTY.visible :=false;
			form.menuSINewSubQTY.enabled := false;
		endif;
	endif;
	//09/02/2017 cnwma1 TFS #2901
	if isVTMIS then
		form.menuTMVnew.visible := allowUpdate;  // MAIN VTMIS NEW MENU
		form.menuSINewSubQTY.visible := false;   //09/02/2017 cnwma1 TFS #2901
		form.menuSItemNew.visible := false;      //09/02/2017 cnwma1 TFS #2901
	elseif isEvent then
		form.menuTMEnew.visible := false; // TFS 2906 allowUpdate;  // MAIN EVENT NEW MENU
		form.menuSINewSubQTY.visible := false;  //09/02/2017 cnwma1 TFS #2901    
		form.menuSItemNew.visible := false;    //09/02/2017 cnwma1 TFS #2901
	elseif isWO then
		form.menuTMWOnew.visible := false; // MAIN WO NEW MENU
		form.menuSINewSubQTY.visible := false;     
		form.menuSItemNew.visible := false;  
	elseif isBOL then	//01 Nov 2019	NDL	TFS 47100
		form.menuTMBOLnew.visible := false; // MAIN BOL NEW MENU
		form.menuSINewSubQTY.visible := false;     
		form.menuSItemNew.visible := false; 
	elseif isToDoResource then // 15/05/2023	navkc1	CR 57927 Task 54268
		form.menuTMEnew.visible := false;
		form.menuTMWOnew.visible := false;
		form.menuSINewSubQTY.visible := false;
		form.menuSItemNew.visible := false;
	else
		//form.menuSItemNew.visible := false; // TFS 2906 allowUpdate;  // MAIN CARGO NEW MENU //09/02/2017 cnwma1 TFS #2901
		 //form.menuSItemNew.visible := allowUpdate; // 09/02/2017 cnwma1 TFS #2901
	endif;
	end;</source>
        <Parameter name="form" type="INV_TransactionMap" usage="io"/>
    </JadeMethod>
    <JadeMethod name="setMyCurrent" id="a5a4bebf-b890-4b78-8d09-aba96100eae4">
        <updating/>
        <source>setMyCurrent(form: INV_TransactionMap io) updating;
// ---------------------------------------------------------------------------
// Created:		February 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//09/02/2017 cnwma1  TFS #2901:ADP - Variable storage charges based on weight and time
// 15/05/2023	navkc1	CR 57927 Task 54268 - Transaction Map
// ---------------------------------------------------------------------------

vars
	aTransSB 						: CM_ServiceBroker; 
	aTransSB2						: CM_ServiceBroker; 
	aCommMap 						: CM_CommodityMap;
	isEvent, isVTMIS, isWorkOrder 	: Boolean;
	debtorMap 						: CM_DebtorMap;
	isBOL 							: Boolean;	//04 Nov 2019	NDL	TFS 47100
	isToDoResource 					: Boolean; // 15/05/2023	navkc1	CR 57927 Task 54268
	isTDREvent						: Boolean; // 15/05/2023	navkc1	CR 57927 Task 54268
	isTDRWO 						: Boolean; // 15/05/2023	navkc1	CR 57927 Task 54268
begin
	inheritMethod(form);

	form.myTMCQuantityRange := self;
	
	if self.myQuantityRangeMap.myQuantityMap.myParentFinancialObject.isKindOf(CM_QuantityRangeMap) then  //09/02/2017 cnwma1 TFS #2901
		if self.myQuantityRangeMap.myQuantityMap.myParentFinancialObject.CM_QuantityRangeMap.myQuantityMap.myParentFinancialObject.isKindOf(CM_ServiceBroker) then
			aTransSB := self.myQuantityRangeMap.myQuantityMap.myParentFinancialObject.CM_QuantityRangeMap.myQuantityMap.myParentFinancialObject.CM_ServiceBroker;
			form.myCurrentMapQuantity := self.myQuantityRangeMap.myQuantityMap;
			form.myCurrentMapQuantityRange := self.myQuantityRangeMap;
		elseif self.myQuantityRangeMap.myQuantityMap.myParentFinancialObject.CM_QuantityRangeMap.myQuantityMap.myParentFinancialObject.isKindOf(CM_DebtorMap) then //17/02/2017 cnwma1 TFS #2901
			debtorMap := self.myQuantityRangeMap.myQuantityMap.myParentFinancialObject.CM_QuantityRangeMap.myQuantityMap.myParentFinancialObject.CM_DebtorMap;
			aTransSB := debtorMap.myServiceBroker;
			form.myCurrentMapQuantity := self.myQuantityRangeMap.myQuantityMap;
			form.myCurrentMapQuantityRange := self.myQuantityRangeMap;
		endif;
	else 
		aTransSB := self.myQuantityRangeMap.myQuantityMap.myParentFinancialObject.CM_ServiceBroker;
	
	endif;
	if aTransSB.isKindOf(CM_TransServiceBroker) then
		aCommMap := aTransSB.CM_TransServiceBroker.commodityMap;
	elseif aTransSB.isKindOf(CM_ResourceServiceBroker) then
		isVTMIS := true;
	elseif aTransSB.isKindOf(CM_EventServiceBroker) then
		isEvent := true;
	elseif aTransSB.isKindOf(CM_WorkOrderServiceBroker) then // TFS 39236
		isWorkOrder := true; // TFS 39236
	elseif aTransSB.isKindOf(CM_MoveServiceBroker) then
		aCommMap := aTransSB.CM_MoveServiceBroker.commodityMap;
	elseif aTransSB.isKindOf(CM_BOLServiceBroker) then	//04 Nov 2019	NDL	TFS 47100
		isBOL := true;
	elseif aTransSB.isToDoRsrcServiceBroker() then // 15/05/2023	navkc1	CR 57927 Task 54268
		isToDoResource := true;
		aTransSB2 := aTransSB.CM_ToDoResourceServiceBroker.myServiceBroker;
		if aTransSB2 &lt;&gt; null then
			if aTransSB2.isEventServiceBroker() then
				isTDREvent := true;
			elseif aTransSB2.isWOServiceBroker() then
				isTDRWO := true;
			endif;
		endif;
	else
		return;
	endif;

	form.myCurrentMapQuantity := self.myQuantityRangeMap.myQuantityMap;
	form.myCurrentMapQuantityRange := self.myQuantityRangeMap;
	
	if aTransSB.isKindOf(CM_ResourceServiceBroker) then
		form.myCurrentMapTMVoyage := aTransSB.CM_ResourceServiceBroker.myTransMap;
		form.myCurrentMapDebtor := null;
		form.myCurrentMapServiceBroker := aTransSB;
	elseif aTransSB.isKindOf(CM_EventServiceBroker) then
		form.myCurrentMapTMEvent := aTransSB.CM_EventServiceBroker.myTranMap;
		form.myCurrentMapDebtor := null;
		form.myCurrentMapServiceBroker := aTransSB;
	elseif isWorkOrder then // TFS 39236
		form.myCurrentMapTMWorkOrder := aTransSB.CM_WorkOrderServiceBroker.myTransMap;
		form.myCurrentMapDebtor := null;
		form.myCurrentMapServiceBroker := aTransSB;
	elseif isBOL then //04 Nov 2019	NDL	TFS 47100
		form.myCurrentMapTMBOL := aTransSB.CM_BOLServiceBroker.myTransMap;
		form.myCurrentMapDebtor := null;
		form.myCurrentMapServiceBroker := aTransSB;
	elseif isToDoResource then// 15/05/2023	navkc1	CR 57927 Task 54268
		if isTDREvent then
			form.myCurrentMapTMEvent := aTransSB2.CM_EventServiceBroker.myTranMap;
		elseif isTDRWO then
			form.myCurrentMapTMWorkOrder := aTransSB2.CM_WorkOrderServiceBroker.myTransMap;
		endif;
		form.myCurrentMapDebtor := null;
		form.myCurrentMapServiceBroker := aTransSB;
	else
		form.myCurrentMapDebtor := null;
		form.myCurrentMapServiceBroker := aTransSB;
		form.myCurrentMapCommodity := aCommMap;
		form.myCurrentMapContents := aCommMap.contentsMap;
		form.myCurrentMapIMEX := form.myCurrentMapContents.imexMap;
		form.myCurrentMapProduct := form.myCurrentMapIMEX.myProductMap;
		form.myCurrentMapProdGrp := form.myCurrentMapProduct.myProductGroupMap;
		form.myCurrentMapTIService := form.myCurrentMapProdGrp.myCargoTypeMap;
		form.myCurrentMapTM := form.myCurrentMapTIService.transactionMap;

	endif;
end;</source>
        <Parameter name="form" type="INV_TransactionMap" usage="io"/>
    </JadeMethod>
</Class>
