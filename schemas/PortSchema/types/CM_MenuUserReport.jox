    <JadeMethod name="getBGPReportRequest" id="1eea4ee2-e9da-4a57-8da0-c3d7e681e97e">
        <source>getBGPReportRequest() : BGP_ReportRequest;
//----------------------------------------------------------------------
// Created by 	cnwsh3
// Date 		18 February 2010
//
// Implemented version: JMT 7.7.3
// Date  		User  		Change
//PAR22361 - cnwsh3 - 18/02/2010 - Remove references to CM_MenuUserReport.myReportRequest 
//mapped method.  Now using getBGPReportRequest method
//----------------------------------------------------------------------
vars

begin
	if self.myReportTemplate &lt;&gt; null then
		 return self.myReportTemplate.myReportRequest;
	endif;
	
	return null;
epilog
end;</source>
        <ReturnType type="BGP_ReportRequest"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="b39d4b6e-ea51-4e67-84e0-768a49f4c40a">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
// ---------------------------------------------------------------------------
// Created:     05 December 2002		cnwth2	
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars

begin
	if _attrName = ETRow_ReportName then
		return self.name;
	elseif _attrName = ETRow_ReportDescr then
		return self.description;	
	elseif _attrName = ETRow_CreatedDateTime then
		//return self.createdDateTime.String;
			return self.createdDateTime.shortCurrentLocaleFormatSecs();
	elseif _attrName = ETRow_QryReportName or
		_attrName = ETRow_ReportType then
		if self.myReportTemplate &lt;&gt; null then
			return self.myReportTemplate.qryReportType;
		else
			return null;
		endif;
	elseif _attrName = ETRow_Status or 
		_attrName = ETRow_CompletedDateTime then
		if self.myMenuRoot &lt;&gt; null and self.myMenuRoot.isKindOf(CM_MenuRootUserTemplates) then
			return 'Template';
		endif;
		
		if self.completedDateTime.isValid then
			// Dvb changed 18/04/05
			//return self.completedDateTime.String; // epr par 11905 changed 14/6/05 was shortCurrentLocaleFormat();
			//par#12447 4/10/2006
			//return self.completedDateTime.shortCurrentLocaleFormatSecs();	// pre-25989
			// 25989 to get dates sorted as expected, return as yyyy/mm/dd regardless of user locale Jan 2011
			return self.completedDateTime.date.format("yyy/MM/dd") &amp; " " &amp; self.completedDateTime.time.format("HH:mm:ss");
		else
			return self.errorString;
		endif;
	
	endif;
	
	return inheritMethod(_attrName, _short);

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
