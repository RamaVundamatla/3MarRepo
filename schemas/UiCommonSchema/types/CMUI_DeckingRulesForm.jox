//	Created:	22 April 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	locnCell	: CM_YALocationCell;
begin

	locnCell := obj.CM_YALocationCell;
	
	if self.chkShowHeights.value then
		return locnCell.myYardController.myTerminalArea.id &amp; " " &amp; locnCell.myYardController.ident &amp; " " &amp; locnCell.height.String;
	else
		return locnCell.myYardController.myTerminalArea.id &amp; " " &amp; locnCell.myYardController.ident;
	endif;

end;</source>
