    <JadeMethod name="fullEmptyStatus" id="52cdd5e4-274c-49d1-9a3b-7f65e6e56750">
        <source>fullEmptyStatus(_imexStatus : Integer; _contentsStatus : Integer): String;
/*
	Changed On	By			Reason
	----------	--------	----------------------------------------------
	18/05/2010	cnwdap1		CCMS 1116 Tranship changes
*/
vars
	fullEmptyString:String;
begin
	if _contentsStatus = TI_CONTENTS_STATUS_EMPTY then
		fullEmptyString := "E";
	else
		if _imexStatus =TI_IMEX_STATUS_EXPORT then
			fullEmptyString := "F"; //was X
		elseif _imexStatus = TI_IMEX_STATUS_IMPORT then
			fullEmptyString := "F";  //was I
		elseif _imexStatus = TI_IMEX_STATUS_TRANSHIP then	// PAR #23645 CCMS 1116
			fullEmptyString := "F";							// PAR #23645 CCMS 1116
		endif;
	endif;

	return fullEmptyString;
end;</source>
        <Parameter name="_imexStatus" type="Integer"/>
        <Parameter name="_contentsStatus" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getAsiSeqNum" id="55bd2a82-51b4-4d6b-ba7e-e9cd4545513d">
        <source>getAsiSeqNum( _sequenceNumber : Integer; _messageCount : Integer ):Integer;
/*

Purpose:			

Parameters:			Trying to return a value up to 9 digits long
					where the first 7 are the seq num amd the last two are the cargo index in the file

Return Value:		

Date		Who		Reason
24 February 2020	jlgndl1	Initial creation	TFS	48545

*/

vars

	seqAsStr : String;
	returnInteger : Integer;

begin

	seqAsStr := _sequenceNumber.String;
	if seqAsStr.length &gt; 7 then
		returnInteger := ( seqAsStr[ seqAsStr.length - 6 : end ]).Integer;
	else
		returnInteger := _sequenceNumber;
	endif;
	
	returnInteger := returnInteger * 100;
	
	returnInteger := returnInteger + _messageCount;
	
	return returnInteger;

epilog

end;</source>
        <Parameter name="_sequenceNumber" type="Integer"/>
        <Parameter name="_messageCount" type="Integer"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getCodeForStowageLoc" id="22d01f9c-d7be-4674-8b9e-329c99c5d2eb">
        <source>getCodeForStowageLoc(_fullStowageLoc : String) : String protected;
/*

Purpose:			

Parameters:			

Return Value:	Strips the voyage off the sotwage location (if there is one - don't ask)	

Date			Who		Reason
23 May 2018		jlgmd1	Initial creation TFS 38657 Penn fix stowageLoc including the voyage

*/

vars
	firstSpacePos 	: Integer;
	stowageLoc 		: String;
begin
	firstSpacePos := _fullStowageLoc.pos(' ', 1);
	
	if firstSpacePos &gt; 0 then
		stowageLoc := _fullStowageLoc[firstSpacePos+1:end];
	else
		stowageLoc := _fullStowageLoc;
	endif;
	
	return stowageLoc;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_fullStowageLoc" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getCodeForVoyage" id="90c4e7da-4d8e-4de8-9c1b-8e4ffa2692be">
        <source>getCodeForVoyage(_ti :CM_TrackedItem; _voyage :CM_Voyage; _camProtocol :CM_CamProtocol):String protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
25 February 2014	cnwrd1	Initial creation

*/

vars
	code	:String;
begin
	if _ti.isExport or _ti.isTranshipOutbound then		// PAR #25021
		code := _voyage.code.trimBlanks;

	elseif _ti.isImport or _ti.isTranshipInbound then	// PAR #25021
		if _camProtocol.allCoarriExportPorts.includesKey(_ti.loadPort) then
			code := _voyage.code.trimBlanks;
		else
			code := _voyage.inwardCode.trimBlanks;
			
			if code = null then
				code := _voyage.code.trimBlanks;
			endif;
		endif;
		
	elseif _ti.isStorage then
		code := _voyage.inwardCode.trimBlanks;
		
		if code = null then
			code := _voyage.code.trimBlanks;
		endif;
	else
		code := _voyage.code.trimBlanks;
	endif;
	
	if code = null then	//inward may be blank - in which case...
		code := _voyage.code.trimBlanks;
	endif;

	return code;
epilog
end;</source>
        <access>protected</access>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_camProtocol" type="CM_CamProtocol"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getVoyage" id="2ebcf93a-a454-4679-8c36-ccbab296338b">
        <source>getVoyage(_transaction :CM_TITransaction; _ti :CM_TrackedItem):CM_Voyage;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
25 February 2014	cnwrd1	Initial creation

*/

vars
	voyage	:CM_Voyage;
begin
	voyage 	:= _transaction.getVoyage();
	
	if voyage = null then
		app.writeLog("Error : Transaction for " &amp; _ti.id.trimRight &amp; " has an null voyage. " &amp; _transaction.String, LogINFO);
		
		if _ti.myVoyage = null then
			app.writeLog("Error : Container " &amp; _ti.id.trimRight &amp; " has an null voyage. " &amp; _transaction.String, LogINFO);
		else
			voyage := _ti.myVoyage;
		endif;
	endif;

	return voyage;
epilog

end;</source>
        <Parameter name="_transaction" type="CM_TITransaction"/>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <ReturnType type="CM_Voyage"/>
    </JadeMethod>
    <JadeMethod name="makeHazardMessages" id="6588425c-4d45-458c-a4f3-b0d6ec25e6fb">
        <source>makeHazardMessages(_ti : CM_TrackedItem; _camProtocol : CM_CamProtocol; _camMessage : CM_CamMessage io; _segmentCount : Integer io);
//
// 09 Aug 2017	cnwrs1	TFS 5727 Penn Seaboard fixups
//
vars
	aHazard : CM_Hazard;
	undgCode : String;
	imdgClass : String;
	hazDesc : String;
	aMessageString : String;
begin
	foreach	aHazard in _ti.allTIHazards do
		foreach undgCode in aHazard.CM_TIHazard.allUNDGCodes do
			imdgClass := aHazard.code;
			hazDesc := aHazard.description.toUpper;
			aMessageString := self.makeMessage_H1(_camProtocol, undgCode, imdgClass, hazDesc);
			self.addMessage(_camMessage.group3, aMessageString);
			_segmentCount := _segmentCount +1;
			endforeach;
	endforeach;
epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_camProtocol" type="CM_CamProtocol"/>
        <Parameter name="_camMessage" type="CM_CamMessage" usage="io"/>
        <Parameter name="_segmentCount" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="makeMessagePackUnpack" id="6cff7221-d4cc-49a2-9421-a02e3377ad37">
        <source>makeMessagePackUnpack(_trackedItem : CM_TrackedItem; _transaction : CM_TITransaction; _camProtocol : CM_CamProtocol; _camMessage : CM_CamMessage input; _xlVoyageId : String; _terminal: CM_Terminal; _runDateTime : TimeStamp);

/*

Purpose:			

Parameters:			

Return Value:		


/* Changes

Date		Name	TFS#		Description
============================================================================
29 Jan 2015	cnwrd1				Initial creation
22 Jan 2016	cnwrs1	37444 		Use Cams controller rundate time rather than current date time
13 Apr 2016	cnwjre1	TFS 1839 	use the voyage id parameter as it is from the import/export voyage as required
09 Aug 2017	cnwrs1	TFS 5727 	Penn Seaboard fixups
28 Sep 2017	cnwrs1	TFS 7183 	Penn Chassis N&amp; using carrier code not shipper code
04 Oct 2017	jlgrs1	TFS 7269 	Penn Transaction Set Control Number is incorrect
11 Jan 2018	jlgrs1	TFS 2299 	add VGM Details to X12 322
15 Mar 2019	jlgka1  TFS 41641	SSL - X12 322 Equipment ID Check.
11 Dec 2019	jlgdap1	TFS 47731	PEN Uniqueness of Various Control Numbers in X12 322 Message
============================================================================*/
vars
	ti 						: CM_TrackedItem;
	senderID,
	receiverID 				: String;
	shipStatusCode			: String;
	tranDate				: Date;
	tranTime				: Time;
	containerPrefix			: String;
	containerNumeric		: String;
	containerCheckDigit		: String;
	grossWeight				: String;
	tareWeight				: String;
	isoTypeCode				: String;
	sealOperator			: String;
	sealCustoms				: String;
	sealShipper				: String;
	commodityCode			: String;
	lloydsNumber			: String;
	vesselName				: String;
	translatedVoyageCode	: String;
	translatedDischargePort	: String;
	translatedLoadPort		: String;
	portQual				: String;
	portName				: String;
	translatedCarrier		: String;
	translatedConsignor	 	: String;
	aTerminal 				: CM_Terminal;
	theCamProtocol			: CM_CamProtocol;
	aPort 					: CM_Port;
	sequenceNumber 			: Integer;
	dailySeqNumber			: Integer;
	status					: Integer;
	aMessageString 			: String;
	segmentCount			: Integer;	
	equipStatusDesc			: String;
	equipLength 			: String;
	aCarrier				: CM_Carrier;
	carrierDescription		: String;
	weightQualifier 		: String;
	asiSeqNum : Integer;	//24 Feb 2020	NDL	TFS 48585
begin
	ti := _transaction.myTrackedItem;
	aTerminal := ti.myTerminal;
	theCamProtocol := _camProtocol;
	// jlgka1 TFS 41641 --&gt;
	if ti.isKindOf(CM_Container) then //should be!	
		self.splitContainerID(ti.id, containerPrefix, containerNumeric, containerCheckDigit, theCamProtocol);
	endif;
	// jlgka1 TFS 41641 &lt;--
	tranDate := _transaction.camsTimeStamp.date;
	tranTime := _transaction.camsTimeStamp.time;
	//headers
	senderID := _camProtocol.camGroup.senderCode;  
	receiverID := _camProtocol.camGroup.recipient;
	
	translatedCarrier := receiverID;
	
	theCamProtocol.getNextSeqNumber(sequenceNumber, dailySeqNumber, status);		// TFS 47731		//24 Feb 2020	NDL	TFS 48585
	//sequenceNumber := _camMessage.camFile.messageCount + 1;							// TFS 47731		//24 Feb 2020	NDL	TFS 48585
	asiSeqNum := getAsiSeqNum( sequenceNumber, _camMessage.camFile.messageCount + 1 );	//24 Feb 2020	NDL	TFS 48585
	
	if ti.isEmpty then
		equipStatusDesc := 'E';
	else
		equipStatusDesc := 'L';
	endif;
	
	if _transaction.isCamsPackType then
		shipStatusCode := 'ST';
	else
		shipStatusCode := 'SP'; //unpack
	endif;
	
	if ti.carrier &lt;&gt; null then
		translatedCarrier := ti.carrier;
		aCarrier := app.myRoot.allCarriers[ti.carrier]; 
		translatedCarrier 	:= self.getXlatedForeignCode(_camProtocol.operatorXlationCode.trimBlanks, translatedCarrier, XLATION_TYPE_CARRIER_BYOP, aTerminal);
	endif;
	
	if aCarrier &lt;&gt; null then
		carrierDescription := aCarrier.description;
	endif;
	
//	aMessageString := self.makeHeader_ISA(_camProtocol, sequenceNumber, senderID, receiverID, _runDateTime);
	aMessageString := self.makeHeader_ISA(_camProtocol, asiSeqNum, senderID, receiverID, _runDateTime);	//24 Feb 2020	NDL	TFS 48585
	self.addMessage(_camMessage.group3, aMessageString);

//	aMessageString :=  self.makeHeader_GS(_camProtocol, senderID, receiverID, sequenceNumber.String, _runDateTime);
	aMessageString :=  self.makeHeader_GS(_camProtocol, senderID, receiverID, asiSeqNum.padLeadingWith('0',9).String, _runDateTime);	//24 Feb 2020	NDL	TFS 48585
	self.addMessage(_camMessage.group3, aMessageString);

//	aMessageString :=  self.makeHeader_ST(_camProtocol, sequenceNumber.String);
	aMessageString :=  self.makeHeader_ST(_camProtocol, asiSeqNum.padLeadingWith('0',9).String);	//24 Feb 2020	NDL	TFS 48585
	self.addMessage(_camMessage.group3, aMessageString);
	segmentCount := segmentCount +1;
	
	//body
	
	//Q5
	aMessageString :=  self.makeMessage_Q5(_camProtocol, shipStatusCode, tranDate, tranTime, 'LT');	
	self.addMessage(_camMessage.group3, aMessageString);
	segmentCount := segmentCount +1;
	
	//N7	
	isoTypeCode := ti.getISOType;
	isoTypeCode := self.getXlatedForeignCode(_camProtocol.operatorXlationCode.trimBlanks, isoTypeCode, XLATION_TYPE_ISOTYPE_BYOP, aTerminal);	
	
	grossWeight := ti.weight.Integer.asStringJMT;
	tareWeight := ti.getTareWeight.Integer.asStringJMT;
	if ti.isKindOf(CM_Container) then
		equipLength	:= ti.getActualLength.Integer.padLeadingWith('0',3).String &amp; '00';
	else
		//equipLength	:= ti.length.String;
		equipLength := self.formatLengthAsFFFII( ti.length );	//13 May 2019	NDL	TFS 44710
	endif;	
	weightQualifier := 'G';
	if _camProtocol.useVGM and
	   ti.isWeightCertified then
		weightQualifier := "A6";
	endif;
	
	aMessageString :=  self.makeMessage_N7(_camProtocol, containerPrefix, containerNumeric, grossWeight, weightQualifier, tareWeight, 'CN', _camProtocol.camGroup.shippersCode, containerCheckDigit, isoTypeCode, equipLength);
	self.addMessage(_camMessage.group3, aMessageString);
	segmentCount := segmentCount +1;
	
	
	//DTM
	aMessageString := self.makeMessage_DTM(_camProtocol, tranDate, tranTime, 'LT'); //timecode as 'LT'
	self.addMessage(_camMessage.group3, aMessageString);
	segmentCount := segmentCount +1;
	
	
	//W2	
	aMessageString := self.makeMessage_W2(_camProtocol, containerPrefix, containerNumeric, containerCheckDigit, commodityCode, 'CN', equipStatusDesc, null, null); //cnwrd1 par 35254 ccms 2439 //cnwrd1 par 35709
	self.addMessage(_camMessage.group3, aMessageString);
	segmentCount := segmentCount +1;
	
	
	//V1
	//translatedVoyageCode := ti.voyageCode;
	//translatedVoyageCode := self.getXlatedForeignCode(_camProtocol.operatorXlationCode.trimBlanks, translatedVoyageCode, XLATION_TYPE_VOYAGETERMINAL, aTerminal);
	translatedVoyageCode := _xlVoyageId;			// 13/04/2016 cnwjre1 TFS 1839 use the input parameter as it is for the correct voyage
	
	if ti.myVoyage &lt;&gt; null then
		lloydsNumber := ti.myVoyage.lloydsNumber;//cnwrd1 par 33914
		vesselName := ti.myVoyage.vesselName;//cnwrd1 par 33914
	endif;
	
	if ti.myVoyage &lt;&gt; null and not ti.myVoyage.isNullVoyage then //33989
		aMessageString := self.makeMessage_V1(_camProtocol, lloydsNumber, vesselName, translatedVoyageCode, translatedCarrier);
		self.addMessage(_camMessage.group3, aMessageString);
		segmentCount := segmentCount +1;
	endif;
	
	
	//R4 port or terminals 	
	// discharge port
	aPort := app.myRoot.lookupScheduleDKPortCode(ti.dischargePort, '');
	
	if aPort = null then
		//no US location try general 
		translatedDischargePort := ti.dischargePort;
		translatedDischargePort 	:= self.getXlatedForeignCode(_camProtocol.operatorXlationCode.trimBlanks, translatedDischargePort, XLATION_TYPE_PORT_BYOP, aTerminal);
		portQual := 'UN';
	else
		translatedDischargePort	:= aPort.usLocationID;
		if aPort.countryCode= 'US' then
			portQual := 'D';
		else
			portQual := 'K';
		endif;
		portName := aPort.description;
	endif;
	
	if translatedDischargePort &lt;&gt; null then
		aMessageString := self.makeMessage_R4(_camProtocol, 'D', portQual, translatedDischargePort, portName);
		self.addMessage(_camMessage.group3, aMessageString);
		segmentCount := segmentCount +1;
	endif;
	
	// load port
	
	aPort := app.myRoot.lookupScheduleDKPortCode(ti.loadPort, '');
	
	if aPort = null then
		//no US location try general 
		translatedLoadPort := ti.loadPort;
		translatedLoadPort 	:= self.getXlatedForeignCode(_camProtocol.operatorXlationCode.trimBlanks, translatedLoadPort, XLATION_TYPE_PORT_BYOP, aTerminal);
		portQual := 'UN';
	else
		translatedLoadPort	:= aPort.usLocationID;
		if aPort.countryCode= 'US' then
			portQual := 'D';
		else
			portQual := 'K';
		endif;
		portName := aPort.description;
	endif;
	
	
	if translatedLoadPort &lt;&gt; null then
		aMessageString :=  self.makeMessage_R4(_camProtocol, 'L', portQual, translatedLoadPort, portName);
		self.addMessage(_camMessage.group3, aMessageString);
		segmentCount := segmentCount +1;
	endif;
	
	//cnwrd1 par 33989 added a facilityCode as intrim port R4 segment
	if _camProtocol.camGroup.facilityCode &lt;&gt; null then
	 	aMessageString :=  self.makeMessage_R4(_camProtocol, 'I', portQual, _camProtocol.camGroup.facilityCode, null);
		self.addMessage(_camMessage.group3, aMessageString);
		segmentCount := segmentCount +1;
	endif;
		
	
	//N9 reference numbers
	if ti.billOfLading &lt;&gt; null then
		aMessageString := self.makeMessage_N9(_camProtocol, 'BM', ti.billOfLading);
		self.addMessage(_camMessage.group3, aMessageString);
		segmentCount := segmentCount +1;
	endif;
	
	
	if theCamProtocol.x12UseClientRefAsBooking and ti.isEmpty and (_transaction.isCamsRoadReleaseType() or _transaction.isCamsRailReleaseType()) then // cnwrd par 34369
		if ti.clientRef &lt;&gt; null then
			aMessageString := self.makeMessage_N9(_camProtocol, 'BN', ti.clientRef);
			self.addMessage(_camMessage.group3, aMessageString);
			segmentCount := segmentCount +1;
		endif;	
	else
		if ti.bookingReference &lt;&gt; null then
			aMessageString := self.makeMessage_N9(_camProtocol, 'BN', ti.bookingReference);
			self.addMessage(_camMessage.group3, aMessageString);
			segmentCount := segmentCount +1;
		endif;
	endif;
	
	// tir number ??? - carrierrelease number //33989
	 if ti.getCarrierReference &lt;&gt; null then
		_camMessage.group4.add(self.makeMessage_N9(_camProtocol, 'TI', ti.getCarrierReference.trimRight));
	endif;
	
	//footers
	segmentCount := segmentCount +1;
//	aMessageString :=  self.makeTrailer_SE(_camProtocol, segmentCount.String, sequenceNumber.String);
	aMessageString :=  self.makeTrailer_SE(_camProtocol, segmentCount.String, asiSeqNum.padLeadingWith('0',9).String);	//24 Feb 2020	NDL	TFS 48585
	self.addMessage(_camMessage.group3, aMessageString);

	
//	aMessageString :=  self.makeTrailer_GE(_camProtocol, sequenceNumber.String); //cnwrd1 par 35645
	aMessageString :=  self.makeTrailer_GE(_camProtocol, asiSeqNum.padLeadingWith('0',9).String);	//24 Feb 2020	NDL	TFS 48585
	self.addMessage(_camMessage.group3, aMessageString);

//	aMessageString :=  self.makeTrailer_IEA(_camProtocol, sequenceNumber.padLeadingWith('0',9).String); //cnwrd1 par  35645
	aMessageString :=  self.makeTrailer_IEA(_camProtocol, asiSeqNum.padLeadingWith('0',9).String);	//24 Feb 2020	NDL	TFS 48585
	self.addMessage(_camMessage.group3, aMessageString);
epilog

end;</source>
        <Parameter name="_trackedItem" type="CM_TrackedItem"/>
        <Parameter name="_transaction" type="CM_TITransaction"/>
        <Parameter name="_camProtocol" type="CM_CamProtocol"/>
        <Parameter name="_camMessage" type="CM_CamMessage" usage="input"/>
        <Parameter name="_xlVoyageId" type="String"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_runDateTime" type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="makeMessageShip" id="6ad7989d-5bf0-4b23-9bef-f6a304c9068f">
        <source>makeMessageShip(_trackedItem:CM_TrackedItem; _transaction: CM_TITransaction; _camProtocol: CM_CamProtocol; _camMessage: CM_CamMessage input; _xlVoyageId: String; _terminal: CM_Terminal; _runDateTime : TimeStamp);

/*

Purpose:			

Parameters:			

Return Value:		


/* Changes

Date		Name	TFS#		Description
============================================================================
28/01/2015  cnwrd1				Initial creation
23/03/2015  cnwgb1  PAR 36892 	Invalid V4 segments 
22 Jan 2016	cnwrs1	37444 		Use Cams controller rundate time rathyer than current date time
19 Jun 2017	cnwrs1	TFS 4462 	SNO add Terminal Operator, Unknown Seal and support multiple seals
28 Sep 2017	cnwrs1	TFS 7183 	Penn Chassis N&amp; using carrier code not shipper code
04 Oct 2017	jlgrs1	TFS 7269 	Penn Transaction Set Control Number is incorrect
11 Jan 2018	jlgrs1	TFS 2299 	add VGM Details to X12 322
23 May 2018	jlgmd1	TFS 38657 	Penn fix stowageLoc including the voyage
15 Mar 2019	jlgka1  TFS 41641	SSL - X12 322 Equipment ID Check.
11 Dec 2019	jlgdap1	TFS 47731	PEN Uniqueness of Various Control Numbers in X12 322 Message
============================================================================*/

vars
	ti 						: CM_TrackedItem;
	senderID,
	receiverID 				: String;
	shipStatusCode			: String;
	tranDate				: Date;
	tranTime				: Time;
	containerPrefix			: String;
	containerNumeric		: String;
	containerCheckDigit		: String;
	grossWeight				: String;
	tareWeight				: String;
	isoTypeCode				: String;
	sealOperator			: String;
	sealCustoms				: String;
	sealShipper				: String;
	commodityCode			: String;
	lloydsNumber			: String;
	vesselName				: String;
	translatedVoyageCode	: String;
	translatedDischargePort	: String;
	translatedLoadPort		: String;
	portQual				: String;
	portName				: String;
	translatedCarrier		: String;
	translatedConsignor	 	: String;
	aTerminal 				: CM_Terminal;
	theCamProtocol			: CM_CamProtocol;
	aPort 					: CM_Port;
	sequenceNumber 			: Integer;
	dailySeqNumber			: Integer;
	status					: Integer;
	aMessageString 			: String;
	segmentCount			: Integer;	
	equipStatusDesc			: String;
	equipLength 			: String;
	aCarrier				: CM_Carrier;
	carrierDescription		: String;
	stowageLoc				: String;
	weightQualifier 		: String;
	asiSeqNum : Integer;	//24 Feb 2020	NDL	TFS 48585
	
begin
	ti := _transaction.myTrackedItem;
	aTerminal := ti.myTerminal;
	theCamProtocol := _camProtocol;
	
	//jlgka1 TFS 41641 --&gt;
	if ti.isKindOf(CM_Container) then //should be!			
		self.splitContainerID(ti.id, containerPrefix, containerNumeric, containerCheckDigit, theCamProtocol);
	endif;
	//jlgka1 TFS 41641 &lt;--
	
	tranDate := _transaction.camsTimeStamp.date;
	tranTime := _transaction.camsTimeStamp.time;
	//headers
	senderID := _camProtocol.camGroup.senderCode;  
	receiverID := _camProtocol.camGroup.recipient;
	
	translatedCarrier := receiverID;
	
	theCamProtocol.getNextSeqNumber(sequenceNumber, dailySeqNumber, status);		// TFS 47731	//24 Feb 2020	NDL	TFS 48585
	//sequenceNumber := _camMessage.camFile.messageCount + 1;							// TFS 47731	//24 Feb 2020	NDL	TFS 48585
	asiSeqNum := getAsiSeqNum( sequenceNumber, _camMessage.camFile.messageCount + 1 );	//24 Feb 2020	NDL	TFS 48585
	
	if ti.isEmpty then
		equipStatusDesc := 'E';
	else
		equipStatusDesc := 'L';
	endif;
	
	if _transaction.isReleaseType then
		shipStatusCode := 'AE';
		//stowageLoc := _transaction.CM_ReleaseShip.locationShip.removeSubstringPlusExtraChars(_transaction.voyageCode&amp;' ', 0);
		stowageLoc := self.getCodeForStowageLoc(_transaction.CM_ReleaseShip.locationShip);		// TFS 38657
	else
		shipStatusCode := 'UV';
		//stowageLoc := _transaction.CM_ReceiveShip.locationShip.removeSubstringPlusExtraChars(_transaction.voyageCode&amp;' ', 0);
		stowageLoc := self.getCodeForStowageLoc(_transaction.CM_ReceiveShip.locationShip);		// TFS 38657
	endif;
	
	
	
	if ti.carrier &lt;&gt; null then
		translatedCarrier := ti.carrier;
		aCarrier := app.myRoot.allCarriers[ti.carrier]; 
		translatedCarrier 	:= self.getXlatedForeignCode(_camProtocol.operatorXlationCode.trimBlanks, translatedCarrier, XLATION_TYPE_CARRIER_BYOP, aTerminal);
	endif;
	
	if aCarrier &lt;&gt; null then
		carrierDescription := aCarrier.description;
	endif;
	
//	aMessageString := self.makeHeader_ISA(_camProtocol, sequenceNumber, senderID, receiverID, _runDateTime);
	aMessageString := self.makeHeader_ISA(_camProtocol, asiSeqNum, senderID, receiverID, _runDateTime);	//24 Feb 2020	NDL	TFS 48585
	self.addMessage(_camMessage.group3, aMessageString);

//	aMessageString :=  self.makeHeader_GS(_camProtocol, senderID, receiverID, sequenceNumber.String, _runDateTime); 
   	aMessageString :=  self.makeHeader_GS(_camProtocol, senderID, receiverID, asiSeqNum.padLeadingWith('0',9).String, _runDateTime);	//24 Feb 2020	NDL	TFS 48585
	self.addMessage(_camMessage.group3, aMessageString);

//	aMessageString :=  self.makeHeader_ST(_camProtocol, sequenceNumber.String);
	aMessageString :=  self.makeHeader_ST(_camProtocol, asiSeqNum.padLeadingWith('0',9).String);	//24 Feb 2020	NDL	TFS 48585
	self.addMessage(_camMessage.group3, aMessageString);
	segmentCount := segmentCount +1;
	
	//body
	
	//Q5
	aMessageString :=  self.makeMessage_Q5(_camProtocol, shipStatusCode, tranDate, tranTime, 'LT');	
	self.addMessage(_camMessage.group3, aMessageString);
	segmentCount := segmentCount +1;
	
		
	//N7	
	isoTypeCode := ti.getISOType;
	isoTypeCode := self.getXlatedForeignCode(_camProtocol.operatorXlationCode.trimBlanks, isoTypeCode, XLATION_TYPE_ISOTYPE_BYOP, aTerminal);	
	
	grossWeight := ti.weight.Integer.asStringJMT;
	tareWeight := ti.getTareWeight.Integer.asStringJMT;
	if ti.isKindOf(CM_Container) then
		equipLength	:= ti.getActualLength.Integer.padLeadingWith('0',3).String &amp; '00';
	else
		//equipLength	:= ti.length.String;
		equipLength := self.formatLengthAsFFFII( ti.length );	//13 May 2019	NDL	TFS 44710
	endif;	
	weightQualifier := 'G';
	if _camProtocol.useVGM and
	   ti.isWeightCertified then
		weightQualifier := "A6";
	endif;
	
	aMessageString :=  self.makeMessage_N7(_camProtocol, containerPrefix, containerNumeric, grossWeight, weightQualifier, tareWeight, 'CN', _camProtocol.camGroup.shippersCode, containerCheckDigit, isoTypeCode, equipLength);
	self.addMessage(_camMessage.group3, aMessageString);
	segmentCount := segmentCount +1;
	
	
	//V4 cargo location ref
    if stowageLoc &lt;&gt; null then //cnwgb1 PAR 35892 23/3/2015
        aMessageString :=  self.makeMessage_V4(_camProtocol, stowageLoc);
        self.addMessage(_camMessage.group3, aMessageString);
        segmentCount := segmentCount +1;
	endif;
    
	//DTM
	aMessageString := self.makeMessage_DTM(_camProtocol, tranDate, tranTime, 'LT'); //timecode as 'LT'
	self.addMessage(_camMessage.group3, aMessageString);
	segmentCount := segmentCount +1;
	
	
	//M7 seal numbers - can be up to 3..
	// CA/CM/SH
	// operator, customs, shipper
	sealOperator := ti.getSealNum();
	
	if sealOperator &lt;&gt; null then
		aMessageString := self.makeMessage_M7(_camProtocol, sealOperator, 'CA');
		self.addMessage(_camMessage.group3, aMessageString);
		segmentCount := segmentCount +1;
	endif;
	
	sealCustoms := ti.getSealNumCustoms();
	if sealCustoms &lt;&gt; null then
		aMessageString := self.makeMessage_M7(_camProtocol, sealCustoms, 'CM');
		self.addMessage(_camMessage.group3, aMessageString);
		segmentCount := segmentCount +1;
	endif;
	
	sealShipper := ti.getSealNumShipper();
	if sealShipper &lt;&gt; null then
		aMessageString := self.makeMessage_M7(_camProtocol, sealShipper, 'SH');
		self.addMessage(_camMessage.group3, aMessageString);
		segmentCount := segmentCount +1;
	endif;
	

	
	//W2	
	aMessageString := self.makeMessage_W2(_camProtocol, containerPrefix, containerNumeric, containerCheckDigit, commodityCode, 'CN', equipStatusDesc, null, null); //cnwrd1 par 35254 ccms 2439 //cnwrd1 par 35709
	self.addMessage(_camMessage.group3, aMessageString);
	segmentCount := segmentCount +1;
	
	
	//V1
	//translatedVoyageCode := ti.voyageCode;
	//translatedVoyageCode := self.getXlatedForeignCode(_camProtocol.operatorXlationCode.trimBlanks, translatedVoyageCode, XLATION_TYPE_VOYAGETERMINAL, aTerminal);
	translatedVoyageCode := _xlVoyageId;			// 13/04/2016 cnwjre1 TFS 1839 use the input parameter as it is for the correct voyage
	
	if ti.myVoyage &lt;&gt; null then
		lloydsNumber := ti.myVoyage.lloydsNumber;//cnwrd1 par 33914
		vesselName := ti.myVoyage.vesselName;//cnwrd1 par 33914
	endif;
	
	if ti.myVoyage &lt;&gt; null and not ti.myVoyage.isNullVoyage then //33989
		aMessageString := self.makeMessage_V1(_camProtocol, lloydsNumber, vesselName, translatedVoyageCode, translatedCarrier);
		self.addMessage(_camMessage.group3, aMessageString);
		segmentCount := segmentCount +1;
	endif;
	
	
	//R4 port or terminals 	
	// discharge port
	aPort := app.myRoot.lookupScheduleDKPortCode(ti.dischargePort, '');
	
	if aPort = null then
		//no US location try general 
		translatedDischargePort := ti.dischargePort;
		translatedDischargePort 	:= self.getXlatedForeignCode(_camProtocol.operatorXlationCode.trimBlanks, translatedDischargePort, XLATION_TYPE_PORT_BYOP, aTerminal);
		portQual := 'UN';
	else
		translatedDischargePort	:= aPort.usLocationID;
		if aPort.countryCode= 'US' then
			portQual := 'D';
		else
			portQual := 'K';
		endif;
		portName := aPort.description;
	endif;
	
	if translatedDischargePort &lt;&gt; null then
		aMessageString := self.makeMessage_R4(_camProtocol, 'D', portQual, translatedDischargePort, portName);
		self.addMessage(_camMessage.group3, aMessageString);
		segmentCount := segmentCount +1;
	endif;
	
	// load port
	
	aPort := app.myRoot.lookupScheduleDKPortCode(ti.loadPort, '');
	
	if aPort = null then
		//no US location try general 
		translatedLoadPort := ti.loadPort;
		translatedLoadPort 	:= self.getXlatedForeignCode(_camProtocol.operatorXlationCode.trimBlanks, translatedLoadPort, XLATION_TYPE_PORT_BYOP, aTerminal);
		portQual := 'UN';
	else
		translatedLoadPort	:= aPort.usLocationID;
		if aPort.countryCode= 'US' then
			portQual := 'D';
		else
			portQual := 'K';
		endif;
		portName := aPort.description;
	endif;
	
	
	if translatedLoadPort &lt;&gt; null then
		aMessageString :=  self.makeMessage_R4(_camProtocol, 'L', portQual, translatedLoadPort, portName);
		self.addMessage(_camMessage.group3, aMessageString);
		segmentCount := segmentCount +1;
	endif;
	
	//cnwrd1 par 33989 added a facilityCode as intrim port R4 segment
	if _camProtocol.camGroup.facilityCode &lt;&gt; null then
	 	aMessageString :=  self.makeMessage_R4(_camProtocol, 'I', portQual, _camProtocol.camGroup.facilityCode, null);
		self.addMessage(_camMessage.group3, aMessageString);
		segmentCount := segmentCount +1;
	endif;
	
	
	//N1 party ident
	if translatedCarrier &lt;&gt; null then
		aMessageString :=  self.makeMessage_N1(_camProtocol, 'MC', translatedCarrier, '94', translatedCarrier);
		self.addMessage(_camMessage.group3, aMessageString);
		segmentCount := segmentCount +1;
	endif;
	
	//consignor
	if ti.consignor &lt;&gt; null then
		translatedConsignor :=  ti.consignor ;
		translatedConsignor := self.getXlatedForeignCode(_camProtocol.operatorXlationCode.trimBlanks, translatedConsignor, XLATION_TYPE_CONSIGNEE_BYOP, aTerminal);
		aMessageString :=  self.makeMessage_N1(_camProtocol, 'CN', translatedConsignor, '94', translatedConsignor);
		self.addMessage(_camMessage.group3, aMessageString);
		segmentCount := segmentCount +1;
	endif;
	
	//freight forwarder
	if ti.freightForwarderCode &lt;&gt; null then
		aMessageString :=  self.makeMessage_N1(_camProtocol, 'FW', ti.freightForwarderCode, '94', ti.freightForwarderCode);
		self.addMessage(_camMessage.group3, aMessageString);
		segmentCount := segmentCount +1;
	endif;
	

	//K1
	aMessageString := self.makeMessage_K1(_camProtocol, '', ti.remarks);
	self.addMessage(_camMessage.group3, aMessageString);
	segmentCount := segmentCount +1;

	
	
	//N9 reference numbers
	if ti.billOfLading &lt;&gt; null then
		aMessageString := self.makeMessage_N9(_camProtocol, 'BM', ti.billOfLading);
		self.addMessage(_camMessage.group3, aMessageString);
		segmentCount := segmentCount +1;
	endif;
	
	
	if theCamProtocol.x12UseClientRefAsBooking and ti.isEmpty and (_transaction.isCamsRoadReleaseType() or _transaction.isCamsRailReleaseType()) then // cnwrd par 34369
		if ti.clientRef &lt;&gt; null then
			aMessageString := self.makeMessage_N9(_camProtocol, 'BN', ti.clientRef);
			self.addMessage(_camMessage.group3, aMessageString);
			segmentCount := segmentCount +1;
		endif;	
	else
		if ti.bookingReference &lt;&gt; null then
			aMessageString := self.makeMessage_N9(_camProtocol, 'BN', ti.bookingReference);
			self.addMessage(_camMessage.group3, aMessageString);
			segmentCount := segmentCount +1;
		endif;
	endif;
	
	// tir number ??? - carrierrelease number //33989
	 if ti.getCarrierReference &lt;&gt; null then
		_camMessage.group4.add(self.makeMessage_N9(_camProtocol, 'TI', ti.getCarrierReference.trimRight));
	endif;
	
	//footers
	segmentCount := segmentCount +1;
//	aMessageString :=  self.makeTrailer_SE(_camProtocol, segmentCount.String, sequenceNumber.String); //cnwrd1 par 35645
	aMessageString :=  self.makeTrailer_SE(_camProtocol, segmentCount.String, asiSeqNum.padLeadingWith('0',9).String);	//24 Feb 2020	NDL	TFS 48585
	self.addMessage(_camMessage.group3, aMessageString);

	
//	aMessageString :=  self.makeTrailer_GE(_camProtocol, sequenceNumber.String); //cnwrd1 par 35645
	aMessageString :=  self.makeTrailer_GE(_camProtocol, asiSeqNum.padLeadingWith('0',9).String);	//24 Feb 2020	NDL	TFS 48585
	self.addMessage(_camMessage.group3, aMessageString);

	
//	aMessageString :=  self.makeTrailer_IEA(_camProtocol, sequenceNumber.padLeadingWith('0',9).String); //cnwrd1 par  35645
	aMessageString :=  self.makeTrailer_IEA(_camProtocol, asiSeqNum.padLeadingWith('0',9).String);	//24 Feb 2020	NDL	TFS 48585
	self.addMessage(_camMessage.group3, aMessageString);
epilog

end;</source>
        <Parameter name="_trackedItem" type="CM_TrackedItem"/>
        <Parameter name="_transaction" type="CM_TITransaction"/>
        <Parameter name="_camProtocol" type="CM_CamProtocol"/>
        <Parameter name="_camMessage" type="CM_CamMessage" usage="input"/>
        <Parameter name="_xlVoyageId" type="String"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_runDateTime" type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="makeMessages" id="4c759f8a-816e-42ed-8057-5a5a848f5036">
        <source>makeMessages(_trackedItem:CM_TrackedItem; _transaction: CM_TITransaction; _camProtocol: CM_CamProtocol; _camMessage: CM_CamMessage input; _xlVoyageId: String; _terminal: CM_Terminal; _runDateTime : TimeStamp);

/*

Purpose:			

Parameters:			

Return Value:		

/* Changes

Date		Name	TFS#		Description
============================================================================
25 Feb 2014	cnwrd1				Initial creation
27 Jan 2015	cnwrd1	CCMS 2451	reworked for Penn 
22 Jan 2016	cnwrs1	37444 		Use Cams controller rundate time rathyer than current date time
07 Aug 2017	cnwrs1	TFS 5727 	Penn Seaboard fixups
28 Sep 2017	cnwrs1	TFS 7183 	Penn Chassis N&amp; using carrier code not shipper code
04 Oct 2017	jlgrs1	TFS 7269 	Penn Transaction Set Control Number is incorrect
11 Jan 2018	jlgrs1	TFS 2299 
					36604 		add VGM Details to X12 322
02 May 2018 jlgrs1	TFS 38432 	Penn Dont procude W09 if no data
13 Mar 2019	jlgka1	TFS 41641	SSL - X12 322 Equipment ID Check.
03 Dec 2019	jlgsl4	TFS 47731	PEN - unique ISA sequence number
============================================================================*/
vars
	ti 						: CM_TrackedItem;
	senderID,
	receiverID 				: String;
	shipStatusCode			: String;
	tranDate				: Date;
	tranTime				: Time;
	timeCode 				: String;
	containerPrefix			: String;
	containerNumeric		: String;
	containerCheckDigit		: String;
	grossWeight				: String;
	tareWeight				: String;
	isoTypeCode				: String;
	sealOperator			: String;
	sealCustoms				: String;
	sealShipper				: String;
	commodityCode			: String;
	lloydsNumber			: String;
	vesselName				: String;
	translatedVoyageCode	: String;
	translatedDischargePort	: String;
	translatedLoadPort		: String;
	portQual				: String;
	specialLift				: String;
	handlingCode			: String;
	portName				: String;
	translatedCarrier		: String;
	translatedConsignor	 	: String;
	aHazard					: CM_TIHazard;
	undgCode				: String;
	imdgClass				: String;
	translationOperator 	: CM_Operator;
	aTerminal 				: CM_Terminal;
	theCamProtocol			: CM_CamProtocol;
	aPort 					: CM_Port;
	sequenceNumber 			: Integer;
	dailySeqNumber			: Integer;
	status					: Integer;
	aMessageString 			: String;
	segmentCount			: Integer;	
	equipStatusDesc			: String;
	equipCode				: String;
	lowTemp					: String;
	highTemp				: String;
	unitType				: String;
	message					: String;
	ventSetting				: String;
	humidity				: String;
	quantity 				: String;
	equipLength 			: String;
	vehicleVisitRecord 		: CM_VehicleVisitRecord;
	aCarrier 				: CM_Carrier;
	carrierDescription 		: String;
	isInvalid				: Boolean;
	aTempReading 			: CM_TempReading;
	camMessage	 			: CM_CamMessage;
	hazDesc 				: String;
	weightQualifier 		: String;
	asiSeqNum : Integer;	//24 Feb 2020	NDL	TFS 48585
begin
	ti := _transaction.myTrackedItem;
	aTerminal := ti.myTerminal;
	theCamProtocol := _camProtocol;
	//_camProtocol.myCamControllerAgent.processSeqNumber;
	
	// need to go through each segment and create.
	/*if _camProtocol.operatorXlationCode &lt;&gt; null then
		translationOperator := app.myRoot.allOperators[_camProtocol.operatorXlationCode];
	else
	// ??
	endif;*/
	
	on Exception do app.handleDeletedObject(exception, vehicleVisitRecord, isInvalid);
	
	//jlgka1 TFS 41641 --&gt;
	if ti.isKindOf(CM_Container) then //should be!	
		self.splitContainerID(ti.id, containerPrefix,containerNumeric,containerCheckDigit, theCamProtocol);
	endif;
	//jlgka1 TFS 41641 &lt;--
	
	tranDate := _transaction.camsTimeStamp.date;
	tranTime := _transaction.camsTimeStamp.time;
	//headers
	senderID := _camProtocol.camGroup.senderCode;  
	receiverID := _camProtocol.camGroup.recipient;
//	sequenceNumber := _camMessage.camFile.messageCount + 1; // TFS 47731 - //24 Feb 2020	NDL	TFS 48585
	theCamProtocol.getNextSeqNumber(sequenceNumber, dailySeqNumber, status); // TFS 47731 - //24 Feb 2020	NDL	TFS 48585 
	asiSeqNum := getAsiSeqNum( sequenceNumber, _camMessage.camFile.messageCount + 1 );	//24 Feb 2020	NDL	TFS 48585
	
	vehicleVisitRecord := ti.getVehicleVisit(); //cnwrd1 par 35471
	
	if vehicleVisitRecord &lt;&gt; null and vehicleVisitRecord.carrierCode &lt;&gt; null then //cnwrd1 par 35471
		translatedCarrier := vehicleVisitRecord.carrierCode;
		aCarrier := app.myRoot.allCarriers[translatedCarrier]; 
		translatedCarrier 	:= self.getXlatedForeignCode(_camProtocol.operatorXlationCode.trimBlanks, translatedCarrier, XLATION_TYPE_CARRIER_BYOP, aTerminal);
	elseif ti.carrier &lt;&gt; null then
		translatedCarrier := ti.carrier;
		aCarrier := app.myRoot.allCarriers[ti.carrier]; //cnwrd1 par 35395
		translatedCarrier 	:= self.getXlatedForeignCode(_camProtocol.operatorXlationCode.trimBlanks, translatedCarrier, XLATION_TYPE_CARRIER_BYOP, aTerminal);
	endif;
	
	if aCarrier &lt;&gt; null then //cnwrd1 par 35494
		carrierDescription := aCarrier.description;
	endif;
	
/*	if _camProtocol.myCamControllerAgent &lt;&gt; null then
		sequenceNumber := _camProtocol. myCamControllerAgent.processSeqNumber;
	else
		sequenceNumber := 1;
	endif;*/
	
//	aMessageString := self.makeHeader_ISA(_camProtocol, sequenceNumber, senderID,receiverID, _runDateTime);
	aMessageString := self.makeHeader_ISA(_camProtocol, asiSeqNum, senderID,receiverID, _runDateTime);		//24 Feb 2020	NDL	TFS 48585
	self.addMessage(_camMessage.group3, aMessageString);

	//if seafreight this needs to be SFL - set from cam group
//	aMessageString :=  self.makeHeader_GS(_camProtocol,senderID,receiverID,sequenceNumber.String, _runDateTime);    // ???? 'group control number
	aMessageString :=  self.makeHeader_GS(_camProtocol,senderID,receiverID,asiSeqNum.padLeadingWith('0',9).String, _runDateTime);	//24 Feb 2020	NDL	TFS 48585
	
	self.addMessage(_camMessage.group3, aMessageString);

//	aMessageString :=  self.makeHeader_ST(_camProtocol, sequenceNumber.String); //cnwrd1 par 35645
	aMessageString :=  self.makeHeader_ST(_camProtocol, asiSeqNum.padLeadingWith('0',9).String);	//24 Feb 2020	NDL	TFS 48585
	self.addMessage(_camMessage.group3, aMessageString);
	segmentCount := segmentCount +1; //cnwrd1 par 35645
	
	//body
	if _transaction.isReleaseType then
		shipStatusCode := 'OA';
	else
		shipStatusCode := 'I';
	endif;
	aMessageString :=  self.makeMessage_Q5(_camProtocol, shipStatusCode,tranDate,tranTime,'LT');	
	self.addMessage(_camMessage.group3, aMessageString);
	segmentCount := segmentCount +1;
	
	isoTypeCode := ti.getISOType;
	isoTypeCode := self.getXlatedForeignCode(_camProtocol.operatorXlationCode.trimBlanks, isoTypeCode, XLATION_TYPE_ISOTYPE_BYOP, aTerminal);	
	
	grossWeight := ti.weight.Integer.asStringJMT;
	tareWeight := ti.getTareWeight.Integer.asStringJMT;
	if ti.isKindOf(CM_Container) then
		equipLength	:= ti.getActualLength.Integer.padLeadingWith('0',3).String &amp; '00';
	else
		if ti.length &gt; 0 then
			//equipLength	:= ti.length.String;
			equipLength := self.formatLengthAsFFFII( ti.length );	//13 May 2019	NDL	TFS 44710
		endif;
	endif;	
	weightQualifier := 'G';
	if _camProtocol.useVGM and
	   ti.isWeightCertified then
		weightQualifier := "A6";
	endif;
	
	aMessageString :=  self.makeMessage_N7(_camProtocol, containerPrefix, containerNumeric, grossWeight, weightQualifier, tareWeight, 'CN', _camProtocol.camGroup.shippersCode, containerCheckDigit, isoTypeCode, equipLength);
	self.addMessage(_camMessage.group3, aMessageString);
	segmentCount := segmentCount +1;
	
	aMessageString := self.makeMessage_DTM(_camProtocol, tranDate, tranTime, 'LT'); //timecode as 'LT'
	self.addMessage(_camMessage.group3, aMessageString);
	segmentCount := segmentCount +1;
	
	//M7 seal numbers - can be up to 3..
	// CA/CM/SH
	// operator, customs, shipper
	sealOperator := ti.getSealNum();
	
	if sealOperator &lt;&gt; null then
		aMessageString := self.makeMessage_M7(_camProtocol, sealOperator, 'CA');
		self.addMessage(_camMessage.group3, aMessageString);
		segmentCount := segmentCount +1;
	endif;
	
	sealCustoms := ti.getSealNumCustoms();
	if sealCustoms &lt;&gt; null then
		aMessageString := self.makeMessage_M7(_camProtocol, sealCustoms, 'CM');
		self.addMessage(_camMessage.group3, aMessageString);
		segmentCount := segmentCount +1;
	endif;
	
	sealShipper := ti.getSealNumShipper();
	if sealShipper &lt;&gt; null then
		aMessageString := self.makeMessage_M7(_camProtocol, sealShipper, 'SH');
		self.addMessage(_camMessage.group3, aMessageString);
		segmentCount := segmentCount +1;
	endif;
	
	//cnwrd1 par 34693 add W09 equipment/temperature segment
	if ti.isReefer then
		if ti.myReeferProperties &lt;&gt; null then
			if ti.isPortHole or ti.isFantainer then
				equipCode := 'CJ';
			else
				equipCode := 'CZ';
			endif;
			
			/*if _trackedItem.myOperator.displayTempFahrenheit then
				unitType := 'FA';
				lowTemp := app.temperatureConversion(true,_trackedItem.getCommodityMinTemp).asStringJMT;			
				highTemp := app.temperatureConversion(true,_trackedItem.getCommodityMaxTemp).asStringJMT;		
			else
				lowTemp := _trackedItem.getCommodityMinTemp.asStringJMT;			
				highTemp := _trackedItem.getCommodityMaxTemp.asStringJMT;		
				unitType := 'CE';
			endif;*/
			
			//cnwrd1 par 35771
			if ti.myOperator.displayTempFahrenheit then
				unitType := 'FA';
				lowTemp := app.temperatureConversion(true, ti.getTemperature).asStringJMT;			
				//cnwrd1 par 35806
				aTempReading := ti.getLastTempReading;
				if aTempReading &lt;&gt; null then
					highTemp := app.temperatureConversion(true, aTempReading.getTemperatureValue).asStringJMT;		
				endif;	
			else
				lowTemp := ti.getTemperature.asStringJMT;			
				//cnwrd1 par 35806
				aTempReading := ti.getLastTempReading;
				if aTempReading &lt;&gt; null then
					highTemp := aTempReading.getTemperatureValue.asStringJMT;		
				endif;
				unitType := 'CE';
			endif;		
			message := null; // not setting this now?
			if ti.myReeferProperties.ventilation &gt; 0 then
				quantity := ti.myReeferProperties.ventilation.asStringJMT;
			endif;
			humidity := ti.myReeferProperties.getHumidityAsString();
			aMessageString := self.makeMessage_W09(_camProtocol, equipCode, lowTemp, highTemp, unitType, message, ventSetting, humidity, quantity);
			self.addMessage(_camMessage.group3, aMessageString);	
			segmentCount := segmentCount +1; //cnwrd1 par 35883
		endif;
	endif;
	
	//cnwrd1 par 34352
	if ti.isEmpty then
		equipStatusDesc := 'E';
	else
		equipStatusDesc := 'L';
	endif;
		
	aMessageString := self.makeMessage_W2(_camProtocol, containerPrefix, containerNumeric, containerCheckDigit, commodityCode, 'CN', equipStatusDesc, null, null); //cnwrd1 par 35254 ccms 2439 //cnwrd1 par 35709
	self.addMessage(_camMessage.group3, aMessageString);
	segmentCount := segmentCount +1;
	
	aMessageString := self.makeMessage_NA(_camProtocol, containerPrefix, containerNumeric, 'F');
	self.addMessage(_camMessage.group3, aMessageString);
	segmentCount := segmentCount +1;
	
	//translatedVoyageCode := ti.voyageCode;
	//translatedVoyageCode := self.getXlatedForeignCode(_camProtocol.operatorXlationCode.trimBlanks, translatedVoyageCode , XLATION_TYPE_VOYAGETERMINAL, aTerminal);
	translatedVoyageCode := _xlVoyageId;			// 13/04/2016 cnwjre1 TFS 1839 use the input parameter as it is for the correct voyage
	
	if ti.myVoyage &lt;&gt; null then
		lloydsNumber := ti.myVoyage.lloydsNumber;//cnwrd1 par 33914
		vesselName := ti.myVoyage.vesselName;//cnwrd1 par 33914
	endif;
	
	if ti.myVoyage &lt;&gt; null and not ti.myVoyage.isNullVoyage then //33989
		aMessageString := self.makeMessage_V1(_camProtocol,lloydsNumber, vesselName, translatedVoyageCode, translatedCarrier);
		self.addMessage(_camMessage.group3, aMessageString);
		segmentCount := segmentCount +1;
	endif;
	
	// discharge port
	aPort := app.myRoot.lookupScheduleDKPortCode(ti.dischargePort, '');
	
	if aPort = null then
		//no US location try general 
		translatedDischargePort := ti.dischargePort;
		translatedDischargePort	:= self.getXlatedForeignCode(_camProtocol.operatorXlationCode.trimBlanks, translatedDischargePort, XLATION_TYPE_PORT_BYOP, aTerminal);
		portQual := 'UN';
	else
		translatedDischargePort	:= aPort.usLocationID;
		if aPort.countryCode= 'US' then
			portQual := 'D';
		else
			portQual := 'K';
		endif;
		portName := aPort.description;
	endif;
	
	if translatedDischargePort &lt;&gt; null then
		aMessageString := self.makeMessage_R4( _camProtocol, 'D', portQual, translatedDischargePort, portName);
		self.addMessage(_camMessage.group3, aMessageString);
		segmentCount := segmentCount +1;
	endif;
	
	// load port
	
	aPort := app.myRoot.lookupScheduleDKPortCode(ti.loadPort, '');
	
	if aPort = null then
		//no US location try general 
		translatedLoadPort := ti.loadPort;
		translatedLoadPort 	:= self.getXlatedForeignCode(_camProtocol.operatorXlationCode.trimBlanks, translatedLoadPort, XLATION_TYPE_PORT_BYOP, aTerminal);
		portQual := 'UN';
	else
		translatedLoadPort	:= aPort.usLocationID;
		if aPort.countryCode= 'US' then
			portQual := 'D';
		else
			portQual := 'K';
		endif;
		portName := aPort.description;
	endif;
	
	
	if translatedLoadPort &lt;&gt; null then
		aMessageString :=  self.makeMessage_R4(_camProtocol, 'L', portQual, translatedLoadPort, portName);
		self.addMessage(_camMessage.group3, aMessageString);
		segmentCount := segmentCount +1;
	endif;
	
	//cnwrd1 par 33989 added a facilityCode as intrim port R4 segment
	if _camProtocol.camGroup.facilityCode &lt;&gt; null then
	 	aMessageString :=  self.makeMessage_R4(_camProtocol, 'I', portQual, _camProtocol.camGroup.facilityCode, null);
		self.addMessage(_camMessage.group3, aMessageString);
		segmentCount := segmentCount +1;
	endif;

	//special handling?
	specialLift :=  ti.getSpecialLiftsDescriptions();
	if ti.isExport then
		handlingCode := 'XP';
	else
		handlingCode := 'IP';
	endif;
	
	if specialLift &lt;&gt; null then
		aMessageString := self.makeMessage_H3(_camProtocol,handlingCode, specialLift);
		self.addMessage(_camMessage.group3, aMessageString);
		segmentCount := segmentCount +1;
	endif;
	
	//name segment
	if translatedCarrier &lt;&gt; null then
		aMessageString :=  self.makeMessage_N1(_camProtocol, 'MC', translatedCarrier, '94', translatedCarrier); //epr par 36448 22/6/15 it was 'SFL'
		self.addMessage(_camMessage.group3, aMessageString);
		segmentCount := segmentCount +1;
	endif;
	
	//consignor
	if ti.consignor &lt;&gt; null then
		translatedConsignor :=  ti.consignor ;
		translatedConsignor := self.getXlatedForeignCode(_camProtocol.operatorXlationCode.trimBlanks, translatedConsignor, XLATION_TYPE_CONSIGNEE_BYOP, aTerminal);
		aMessageString :=  self.makeMessage_N1(_camProtocol, 'CN', translatedConsignor, '94', 'SFL');
		self.addMessage(_camMessage.group3, aMessageString);
		segmentCount := segmentCount +1;
	endif;
	
	//freight forwarder
	if ti.freightForwarderCode &lt;&gt; null then
		aMessageString :=  self.makeMessage_N1(_camProtocol, 'FW', ti.freightForwarderCode, '94', 'SFL');
		self.addMessage(_camMessage.group3, aMessageString);
		segmentCount := segmentCount +1;
	endif;
	
	//shipper ??
	/*
	if _trackedItem. &lt;&gt; null then
		_camMessage.group4.add(  self.makemessage_N1( _camProtocol,'SH',_trackedItem.freightForwarderCode,'94','SFL'));
	endif;
	*/
	
	// ISIS move code?
	//_camMessage.group4.add( self.makeMessage_K1( _camProtocol,isisMoveCode,''));
	aMessageString := self.makeMessage_K1(_camProtocol, '', ti.remarks);
	self.addMessage(_camMessage.group3, aMessageString);
	segmentCount := segmentCount +1;

	//bol/booking number
	if ti.billOfLading &lt;&gt; null then
		aMessageString := self.makeMessage_N9(_camProtocol, 'BM', ti.billOfLading);
		self.addMessage(_camMessage.group3, aMessageString);
		segmentCount := segmentCount +1;
	endif;	

	if theCamProtocol.x12UseClientRefAsBooking and ti.isEmpty and (_transaction.isCamsRoadReleaseType() or _transaction.isCamsRailReleaseType()) then // cnwrd par 34369
		if ti.clientRef &lt;&gt; null then
			aMessageString := self.makeMessage_N9(_camProtocol, 'BN', ti.clientRef);
			self.addMessage(_camMessage.group3, aMessageString);
			segmentCount := segmentCount +1;
		endif;	
	else
		if ti.bookingReference &lt;&gt; null then
			aMessageString := self.makeMessage_N9(_camProtocol, 'BN', ti.bookingReference);
			self.addMessage(_camMessage.group3, aMessageString);
			segmentCount := segmentCount +1;
		endif;
	endif;
	
	// tir number ??? - carrierrelease number //33989
	 if ti.getCarrierReference &lt;&gt; null then
		_camMessage.group4.add( self.makeMessage_N9(_camProtocol, 'TI', ti.getCarrierReference.trimRight));
	endif;
	
	aMessageString := self.makeMessage_L0(_camProtocol, '1', grossWeight, 'N', '1', 'CNT');
	self.addMessage(_camMessage.group3, aMessageString);
	segmentCount := segmentCount +1;
	
	aMessageString := self.makeMessage_L5(_camProtocol, '1', '1 PCS', commodityCode, '');
	self.addMessage(_camMessage.group3, aMessageString);
	segmentCount := segmentCount +1;
	
	if ti.isHazardous then
		// up to 3 of these
		camMessage := _camMessage;
		self.makeHazardMessages(ti, _camProtocol, camMessage, segmentCount);
/*		aHazard := ti.getHazard1;
		if aHazard &lt;&gt; null then
			undgCode := aHazard.undgCodes.asStringJMT;
			imdgClass := aHazard.code;
			hazDesc := aHazard.description;
			aMessageString := self.makeMessage_H1(_camProtocol, undgCode, imdgClass, hazDesc);
			self.addMessage(_camMessage.group3, aMessageString);
			segmentCount := segmentCount +1;
		endif;
		
		aHazard := ti.getHazard2;
		if aHazard &lt;&gt; null then
			undgCode := aHazard.undgCodes.asStringJMT;
			imdgClass := aHazard.code;
			hazDesc := aHazard.description;
			aMessageString :=  self.makeMessage_H1(_camProtocol, undgCode, imdgClass, hazDesc);
			self.addMessage(_camMessage.group3, aMessageString);
			segmentCount := segmentCount +1;
		endif;

		aHazard := ti.getHazard3;
		if aHazard &lt;&gt; null then
			undgCode := aHazard.undgCodes.asStringJMT;
			imdgClass := aHazard.code;
			hazDesc := aHazard.description;
			aMessageString :=  self.makeMessage_H1(_camProtocol, undgCode, imdgClass, hazDesc);
			self.addMessage(_camMessage.group3, aMessageString);
			segmentCount := segmentCount +1;
		endif;*/
	endif;
	
	//footers
	segmentCount := segmentCount +1; //cnwrd1 par  35645
//	aMessageString :=  self.makeTrailer_SE( _camProtocol, segmentCount.String, sequenceNumber.String); //cnwrd1 par 35645
	aMessageString :=  self.makeTrailer_SE( _camProtocol, segmentCount.String, asiSeqNum.padLeadingWith('0',9).String);//24 Feb 2020	NDL	TFS 48585
	self.addMessage(_camMessage.group3, aMessageString);

//	aMessageString :=  self.makeTrailer_GE( _camProtocol, sequenceNumber.String); //cnwrd1 par 35645
	aMessageString :=  self.makeTrailer_GE( _camProtocol, asiSeqNum.padLeadingWith('0',9).String);//24 Feb 2020	NDL	TFS 48585
	self.addMessage(_camMessage.group3, aMessageString);
	
//	aMessageString :=  self.makeTrailer_IEA(_camProtocol, sequenceNumber.padLeadingWith('0',9).String); //cnwrd1 par  35645
	aMessageString :=  self.makeTrailer_IEA(_camProtocol, asiSeqNum.padLeadingWith('0',9).String);//24 Feb 2020	NDL	TFS 48585
	self.addMessage(_camMessage.group3, aMessageString);
epilog

end;</source>
        <Parameter name="_trackedItem" type="CM_TrackedItem"/>
        <Parameter name="_transaction" type="CM_TITransaction"/>
        <Parameter name="_camProtocol" type="CM_CamProtocol"/>
        <Parameter name="_camMessage" type="CM_CamMessage" usage="input"/>
        <Parameter name="_xlVoyageId" type="String"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_runDateTime" type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="processTransaction" id="2f3caa61-05c2-407f-a598-7ea9e8504f34">
        <updating/>
        <source>processTransaction(_transaction: CM_TITransaction; _camProtocol: CM_CamProtocol; _camAgent: CM_CamControllerAgent input; _camFile: CM_CamFile input) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
25 February 2014	cnwrd1	Initial creation
*/
//22 Jan 2016	cnwrs1	37444 Use Cams controller rundate time rathyer than current date time
//06 Jul 2016	cnwrs1	Par 38021 - Review Cam logging
//20 dec 2016	cnwrs1	TFS 3158 Cams Exclusion report does not include the rehandles and sobs

vars
	camMessage : CM_CamMessage;
	fCode : String;
	code : String;
	messageCount : Integer;
	commodity : String;
	emptyFullIndicator : String;
	temperaturePart : String;
	dischargePortPart : String;
	destinationPortPart : String;
	carrierPart : String;
	roadRailPart : String;
	wagonPart : String;
	messagePart : String;
	outwardMovementPart : String;
	tonnage : Real;
	theTI : CM_TrackedItem;
	vesselName : String;
	pos3, pos4, pos5	: Integer;
begin
	_camAgent.writeDebugLog(class.name&amp;'::'&amp;method.name&amp;" process "&amp;_transaction.getCamsDisplayDetails);

	theTI := _transaction.myTrackedItem;

	//get the voyage code
	//if theTI.isExport then								// PAR #25021
	if theTI.isExport or theTI.isTranshipOutbound then		// PAR #25021
		code := theTI.myVoyage.code;
	//elseif theTI.isImport then							// PAR #25021
	elseif theTI.isImport or theTI.isTranshipInbound then	// PAR #25021
		code := theTI.myVoyage.inwardCode;
	elseif theTI.isStorage then
		code := theTI.myVoyage.inwardCode;
	else
		code := theTI.myVoyage.code;
	endif;
	
	if code = null then	//inward may be blank - in which case...
		code := theTI.myVoyage.code;
	endif;
	vesselName := theTI.myVoyage.vesselName; //par18987 cnwrs1 Mar 2009
	//translate the voyage Code
	fCode := self.getXlatedForeignCode(_camProtocol.operatorXlationCode.trimBlanks, code, XLATION_TYPE_VOYAGETERMINAL, _camProtocol.terminal);

	if theTI.voyageCode.trimRight = "HOLD"
	or theTI.voyageCode.trimRight = "********" then
		app.writeLog("Error : Container " &amp; theTI.id.trimRight &amp; " has an invalid voyage of " &amp; fCode &amp; ".", LogINFO);
		camMessage := null;
	else
		if _transaction.isCamsRoadReceiveType()
		or _transaction.isCamsRailReceiveType() then
			camMessage := self.getCamMessage(_camFile, fCode, vesselName, CODECO_GATEIN, _camProtocol.singleContainerPerBGM); 
		elseif _transaction.isCamsRoadReleaseType()
		or _transaction.isCamsRailReleaseType() then
			camMessage := self.getCamMessage(_camFile, fCode, vesselName, CODECO_GATEOUT, _camProtocol.singleContainerPerBGM); 
		elseif _transaction.isCamsShipReceiveType() then
			camMessage := self.getCamMessage(_camFile, fCode, vesselName, CODECO_GATEIN, _camProtocol.singleContainerPerBGM);  
		elseif _transaction.isCamsShipReleaseType() then
			camMessage := self.getCamMessage(_camFile, fCode, vesselName, CODECO_GATEOUT, _camProtocol.singleContainerPerBGM);  
		elseif _transaction.isCamsPackType or _transaction.isCamsUnpackType then
			camMessage := self.getCamMessage(_camFile, fCode, vesselName, CODECO_GATEOUT, _camProtocol.singleContainerPerBGM);  
		else
			//do nothing			
			camMessage := null;
		endif;
	endif;

	if camMessage &lt;&gt; null then
		if _transaction.isCamsShipReceiveType() or _transaction.isCamsShipReleaseType() then
			self.makeMessageShip(null, _transaction, _camProtocol, camMessage, fCode, theTI.myTerminal, _camAgent.runDateTime);
		elseif _transaction.isCamsPackType or _transaction.isCamsUnpackType then
			self.makeMessagePackUnpack(null, _transaction,_camProtocol, camMessage, fCode, theTI.myTerminal, _camAgent.runDateTime);
		else	
			self.makeMessages(null, _transaction, _camProtocol, camMessage, fCode, theTI.myTerminal, _camAgent.runDateTime);
		endif;
		_camFile.incrementMessageCount; //cnwrd1 par 33914
        //cnwrd1 par 34440 create cams transaction
        camMessage.setupCAMSInfoDetails(_camProtocol, pos3, pos4, pos5, _transaction);
	else
		if _camAgent.logExcludedTransactions then
			_camAgent.logReasonForExclusion(_transaction, "CAM Message is null " &amp; _transaction.String &amp; ".");
		endif;
	endif;
	
epilog
end;</source>
        <Parameter name="_transaction" type="CM_TITransaction"/>
        <Parameter name="_camProtocol" type="CM_CamProtocol"/>
        <Parameter name="_camAgent" type="CM_CamControllerAgent" usage="input"/>
        <Parameter name="_camFile" type="CM_CamFile" usage="input"/>
    </JadeMethod>
</Class>
