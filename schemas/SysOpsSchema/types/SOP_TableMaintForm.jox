    <JadeMethod name="cmbCertName_click" id="7fd73c50-f4da-4531-ac43-b0b679263199">
        <controlMethod name="CMUI_ComboBox::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbCertName_click(combobox: ComboBox input) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 04/07/2017	cnwdap1		Initial creation TFS 4492 SNO VERMAS Changes
//
vars
	weighAuth, wa : CM_WeighAuthority;
	iter : Iterator;
	idx : Integer;

begin
	self.cmbAuthName.clear();
	weighAuth := combobox.listObject.CM_WeighAuthority;
	if weighAuth = null then
		return;
	endif;
	
	self.tblInput2.setValueByName(ETRow_DefaultWeightCertifiedBy, weighAuth.certifiedName);
	iter := app.myRoot.allWeighAuthorities.createIterator;
	app.myRoot.allWeighAuthorities.startKeyGeq(weighAuth.certifiedName, null, iter);
	while iter.next(wa) do
		if wa.certifiedName &lt;&gt; weighAuth.certifiedName then
			break;
		endif;
		idx := self.cmbAuthName.addItemObject(wa.authorisedName, wa);
	endwhile;
	if self.cmbAuthName.listCount = 1 then
		self.cmbAuthName.listIndex := 1;
		self.tblInput2.setValueByName(ETRow_DefaultAuthPersonWeight, self.cmbAuthName.listObject.CM_WeighAuthority.authorisedName);
	endif;
epilog

end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
    </JadeMethod>
