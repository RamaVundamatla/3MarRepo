    <JadeMethod name="hasRestrictions" id="01acb062-7535-401f-98c9-226722c7eb26">
        <source>hasRestrictions(mode : Integer) : Boolean;

vars
	value : Boolean;

begin

	if mode = NULL_RESTRICTION then
		if self.allLabourRestrictions.size &lt;&gt; 0 or 
		   self.myLocationRestriction &lt;&gt; null then
			value := true;
		endif;
	elseif mode = LABOUR_RESTRICTION then
		return (not self.allLabourRestrictions.isEmpty);
		//if self.allLabourRestrictions.size &lt;&gt; 0 then
		//	value := true;
		//endif;
	elseif mode = LOCATION_RESTRICTION then
		return (self.myLocationRestriction &lt;&gt; null);
		//if self.myLocationRestriction &lt;&gt; null then
		//	value := true;
		//endif;
	else //oops this should never happen
		app.setContinueCMExceptions(false);
	//	app.raiseCMException(ERR_INVALID_MODE, null, null);
		app.raiseCMException1( Invalid_move_mode_passed, method.qualifiedName, null, null );	//13 Apr 2021	NDL	TFS 50906
		return false;	
	endif;

	return value;
end;</source>
        <Parameter name="mode" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
