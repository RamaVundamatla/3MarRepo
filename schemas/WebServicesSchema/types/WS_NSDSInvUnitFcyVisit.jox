    <JadeMethod name="setProxyObject" id="50a02014-0f32-4625-bfb4-5981eb20856b">
        <updating/>
        <source>setProxyObject(_any : Any) updating;

/*
Date		Who		Reason
31 Mar 2022	navra1 	TFS53028 	
*/


vars
	helper 	: CMIF_InvUnitFcyVisit;
	ewsOpsView: CM_EWSActivityOpsview;
begin
	
	inheritMethod(_any);
	
	create helper transient;
	create ewsOpsView transient;
	ewsOpsView.initialiseActivity("","",_any.CM_Object.getMyTerminal(),_any.CM_Object, null,null,false,null);
	helper.initializeForActivity(_any, ewsOpsView);
	
	self.tableName		:= helper.tableName;	
	self.gkey			:= helper.gkey ;
	self.create_time	:= helper.create_time;
	self.fcy_gkey		:= helper.fcy_gkey;
	self.unit_gkey		:= helper.unit_gkey;
	self.time_in		:= helper.time_in;
	self.time_out		:= helper.time_out;	
	self.transit_state	:= helper.transit_state;
	self.visit_state	:= helper.visit_state;
	self.actual_ib_cv	:= helper.actual_ib_cv;
	self.actual_ob_cv	:= helper.actual_ob_cv;
	self.last_pos_bin	:= helper.last_pos_bin;
	self.last_pos_tier	:= helper.last_pos_tier;	
	
	self.arrive_pos_loctype := helper.arrive_pos_loctype;
	self.arrive_pos_locid := helper.arrive_pos_locid;
	self.arrive_pos_loc_gkey := helper.arrive_pos_loc_gkey;
	self.arrive_pos_name := helper.arrive_pos_name;
	self.arrive_pos_bin := helper.arrive_pos_bin;
	self.last_pos_loctype := helper.last_pos_loctype;
	self.last_pos_locid := helper.last_pos_locid;
	self.last_pos_name := helper.last_pos_name;
	
epilog
	delete helper;
	delete ewsOpsView;
end;</source>
        <Parameter name="_any" type="Any"/>
    </JadeMethod>
