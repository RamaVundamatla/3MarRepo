<Class name="CM_ServiceGroup" id="11758794-be24-45de-9e6a-44acfc459699">
    <superclass name="CM_ServiceObject"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="invoice"/>
    <ExplicitInverseRef name="groupMembers" id="b02e3239-17b6-4d5e-bc3c-ae09ecc0e1d7">
        <transientToPersistentAllowed/>
        <updateMode>automatic</updateMode>
        <type name="CM_ServiceObjectByNameDict"/>
        <Inverse name="CM_ServiceObject::group"/>
    </ExplicitInverseRef>
    <JadeMethod name="hasShippingLineRate" id="7a779c43-3c68-4861-993e-4762c03c7dfd">
        <source>hasShippingLineRate(_service : CM_Service output): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
12 May 2009	cnwer1	Initial creation

*/

vars
	mem : CM_ServiceObject;
begin

	foreach mem in self.groupMembers do
		if mem.hasShippingLineRate(_service) then
			return true;
		endif;
	endforeach;
	

epilog

end;</source>
        <Parameter name="_service" type="CM_Service" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
