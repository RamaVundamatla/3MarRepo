    <JadeMethod name="populateCGOperators" id="75690f8c-8031-4489-aaa1-4f02c6ba134c">
        <source>populateCGOperators(_updController : CnEcReleaseController);
/*

Purpose:			
			This script will populate the CM_CargoGroup.allOperators from CM_CargoGroup.myOperator. 
			
Parameters:			

Return Value:		

Date		Who		Reason
30/11/2023	navkc1 ChangeRequest 58254 Task 61100: Jade - Cargo Group Multi Operators Upgrade Script

 // ### JIRA 36467 31OCT2025 NAVAB1 Rewritten STWR upgrade to 22.0.24 was taking 20-30 hours for this method.
*/

vars
	cargoGroup		: CM_CargoGroup;
	objArray		: ObjectArray;
	operator		: CM_Operator;
begin
	
	if self.hasScriptBeenRunAtAll(method.name, null) then
		return;
	endif;
	
	on Exception do self.addNoDupsHaltExHandler(exception);

	app.writeLog(method.qualifiedName &amp; "Populating CM_CargoGroup.allOperators from CM_CargoGroup.myOperator.", LogINFO);
	
	if _updController &lt;&gt; null then
		_updController.logEntry("Populating CM_CargoGroup.allOperators from CM_CargoGroup.myOperator.") ;	
	endif;
	
	create objArray transient;
	CM_CargoGroup.allInstances(objArray, 0, true);
	
	beginTransaction;
	
	foreach cargoGroup in objArray as CM_CargoGroup do : outer
		operator := cargoGroup.myOperator;
		
		cargoGroup.allOperators.tryAddIfNotNull(operator);

	endforeach;
	
	commitTransaction;
	
	app.writeLog(method.qualifiedName &amp; "CompletedCM_CargoGroup.allOperators from CM_CargoGroup.myOperator.", LogINFO);
	
	if _updController &lt;&gt; null then
		_updController.logEntry("Completed CM_CargoGroup.allOperators from CM_CargoGroup.myOperator.") ;
	endif;
	
	self.addScriptRun(method.name);
epilog
	delete objArray;
end;</source>
        <Parameter name="_updController" type="CnEcReleaseController"/>
    </JadeMethod>
    <JadeMethod name="populateCGOperatorsOLD" id="6782b7a8-204d-4289-a206-b71d6fee058b">
        <source>populateCGOperatorsOLD(_updController : CnEcReleaseController);
/*

Purpose:			
			This script will populate the CM_CargoGroup.allOperators from CM_CargoGroup.myOperator. 
			
Parameters:			

Return Value:		

Date		Who		Reason
30/11/2023	navkc1 ChangeRequest 58254 Task 61100: Jade - Cargo Group Multi Operators Upgrade Script
*/

vars
	cgInOperator,
	cargoGroup		: CM_CargoGroup;
	objArray		: ObjectArray;
	operator		: CM_Operator;
begin
	
	if self.hasScriptBeenRunAtAll(method.name, null) then
		return;
	endif;

	app.writeLog(method.qualifiedName &amp; "Populating CM_CargoGroup.allOperators from CM_CargoGroup.myOperator.", LogINFO);
	
	if _updController &lt;&gt; null then
		_updController.logEntry("Populating CM_CargoGroup.allOperators from CM_CargoGroup.myOperator.") ;	
	endif;
	
	create objArray transient;
	CM_CargoGroup.allInstances(objArray, 0, true);
	
	beginTransaction;
	
	foreach cargoGroup in objArray as CM_CargoGroup do : outer
		operator := cargoGroup.myOperator;
		
		// Gonna have valid object
		if operator = null or not app.isValidObject(operator) or cargoGroup = null or not app.isValidObject(cargoGroup) then
			continue;
		endif;
		
		// No duplicate operator allowed
		if cargoGroup.allOperators.includes(operator) then
			continue;
		endif;
		
		// Just in case there is trash data where multiple cargo groups have the same id.
		foreach cgInOperator in operator.allCargoGroups as CM_CargoGroup do : inner
			if cgInOperator.id = cargoGroup.id then
				continue outer;
			endif;
		endforeach;
		
		cargoGroup.allOperators.addNoDuplicates(operator, true);
	endforeach;
	
	commitTransaction;
	
	app.writeLog(method.qualifiedName &amp; "CompletedCM_CargoGroup.allOperators from CM_CargoGroup.myOperator.", LogINFO);
	
	if _updController &lt;&gt; null then
		_updController.logEntry("Completed CM_CargoGroup.allOperators from CM_CargoGroup.myOperator.") ;
	endif;
	
	self.addScriptRun(method.name);
epilog
	delete objArray;
end;</source>
        <Parameter name="_updController" type="CnEcReleaseController"/>
    </JadeMethod>
    <JadeMethod name="populateCargoForecasts" id="fb14aa53-e0c0-4e93-a465-22de014663f1">
        <source>populateCargoForecasts(_controller : CnEcReleaseController);
/*

Purpose:			Populates the CM_Voyage::allCargoForecasts based on HMS_VoyageData::allLoadCommodities and HMS_VoyageData::allDischargeCommodities

Parameters:			_controller	CnEcReleaseController	Controller to use for processing the script

Return Value:		NONE

Date		Who		Reason
11 April 2022	navpw1	Initial creation TFS: 53132

*/

vars
	terminal 			: CM_Terminal;
	voyage				: CM_Voyage;
	cargoType			: CM_CargoType;
	commodity			: CM_Commodity;
 	realCargoForecast	: CM_CargoForecast;
	
begin
	if self.hasScriptBeenRunAtAll(method.name, _controller) then
		return;
	endif;
	
	app.writeLog(method.qualifiedName &amp; " Populating CM_Voyage::allCargoForecasts", LogINFO);
	if _controller &lt;&gt; null then
		_controller.logEntry(" Populating CM_Voyage::allCargoForecasts") ;	
	endif;

	beginTransaction;
	foreach terminal in app.myRoot.allTerminals do
		foreach voyage in terminal.allVoyagesSet do
			if voyage.myHMSVoyageData = null then
				continue;
				
			elseif voyage.myHMSVoyageData.allCommodityDischarge.size = 0 and voyage.myHMSVoyageData.allCommodityLoad.size = 0 then
				continue; //If our collections are not populated then process next voyage
				
			endif;
			
			if voyage.myHMSVoyageData.allCommodityDischarge.size &gt; 0 then
				foreach commodity in voyage.myHMSVoyageData.allCommodityDischarge do
					if commodity.allCargoTypes.size = 1 then
						cargoType := commodity.allCargoTypes.first;
					
					else
						cargoType := null;
						
					endif;
					
					create realCargoForecast persistent;
					realCargoForecast.setPropertyValue(CM_CargoForecast::myCargoType.name, cargoType);
					realCargoForecast.setPropertyValue(CM_CargoForecast::myCommodity.name, commodity);
					realCargoForecast.setPropertyValue(CM_CargoForecast::mode.name, CM_CargoForecast.Mode_Discharge);
					realCargoForecast.setPropertyValue(CM_CargoForecast::totalWeight.name, 0.Decimal);
					realCargoForecast.setPropertyValue(CM_CargoForecast::totalVolume.name, 0.Decimal);
					realCargoForecast.setPropertyValue(CM_CargoForecast::totalQuantity.name, 0);
					realCargoForecast.setPropertyValue(CM_CargoForecast::myParent.name, voyage);
					
				endforeach;
				
				voyage.myHMSVoyageData.allCommodityDischarge.clear;
			endif;
			
			if voyage.myHMSVoyageData.allCommodityLoad.size &gt; 0 then
				foreach commodity in voyage.myHMSVoyageData.allCommodityLoad do
					if commodity.allCargoTypes.size = 1 then
						cargoType := commodity.allCargoTypes.first;
					
					else
						cargoType := null;
						
					endif;
					
					create realCargoForecast persistent;
					realCargoForecast.setPropertyValue(CM_CargoForecast::myCargoType.name, cargoType);
					realCargoForecast.setPropertyValue(CM_CargoForecast::myCommodity.name, commodity);
					realCargoForecast.setPropertyValue(CM_CargoForecast::mode.name, CM_CargoForecast.Mode_Load);
					realCargoForecast.setPropertyValue(CM_CargoForecast::totalWeight.name, 0.Decimal);
					realCargoForecast.setPropertyValue(CM_CargoForecast::totalVolume.name, 0.Decimal);
					realCargoForecast.setPropertyValue(CM_CargoForecast::totalQuantity.name, 0);
					realCargoForecast.setPropertyValue(CM_CargoForecast::myParent.name, voyage);
					
				endforeach;
				
				voyage.myHMSVoyageData.allCommodityLoad.clear;
			endif; 
			
		endforeach;
		
	endforeach;
	commitTransaction;
	
	app.writeLog(method.qualifiedName &amp; " Completed Populating CM_Voyage::allCargoForecasts", LogINFO);
	if _controller &lt;&gt; null then
		_controller.logEntry("Completed Populating CM_Voyage::allCargoForecasts");
	endif;
	self.addScriptRun(method.name);
	
epilog
	
end;</source>
        <Parameter name="_controller" type="CnEcReleaseController"/>
    </JadeMethod>
    <JadeMethod name="populateDamageSeverities" id="abc80a59-0c21-48ef-9d47-e9ee2d89c88e">
        <source>populateDamageSeverities(_controller : CnEcReleaseController);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 June 2022	navhl20	ChangeRequest 53862: EUP - WMS - Damage Recording Extra Details

*/

vars
	terminal : CM_Terminal;
	int :Integer;
	pxyDamageSeverity,newDamageSeverity : CM_DamageSeverity;
begin
	if self.hasScriptBeenRunAtAll(method.name, _controller) then
		return;
	endif;
	
	app.writeLog(method.qualifiedName &amp; " Populate Damage Severity Objects", LogINFO);
	if _controller &lt;&gt; null then
		_controller.logEntry(" Populate Damage Severity Objects") ;	
	endif;
	
	foreach terminal in app.myRoot.allTerminals do
		foreach int in 1 to 5 do
			create pxyDamageSeverity transient;
			pxyDamageSeverity.setProxy(int.String,int.asWords.properCase,false,int,terminal);
			app.myTrxCA.trxCreateDamageSeverity(pxyDamageSeverity, newDamageSeverity, app.myPassport);
			delete pxyDamageSeverity;
		endforeach;
	endforeach;
	
	app.writeLog(method.qualifiedName &amp; " Completed Populating CM_DamageSeverity", LogINFO);
	if _controller &lt;&gt; null then
		_controller.logEntry("Completed Populating CM_DamageSeverity");
	endif;
	self.addScriptRun(method.name);
epilog
	delete pxyDamageSeverity;
end;</source>
        <Parameter name="_controller" type="CnEcReleaseController"/>
    </JadeMethod>
    <JadeMethod name="populateInvTypeDbtorSepInvType" id="033e6c3b-b481-427b-9747-ae897ab5d56f">
        <source>populateInvTypeDbtorSepInvType(_updController : CnEcReleaseController);
/*

Purpose:			Updates the Invoice Type Number on all the Invoice Type Debtor Separations in the database

Parameters:			_updController	CnEcReleaseController	The update controller to use when making the updates

Return Value:		NONE

Date		Who		Reason
31 October 2022	navpw1	Initial creation TFS: 55235 - To populate the Invoice Type Debtor Separation's Invoice Type Number used as a key for a collection on CM_Debtor

*/

vars
	invoiceType						: CM_InvoiceDesc;
	terminal						: CM_Terminal;
	company							: CM_Bank;
	surchargesAndExemptions			: CM_InvoiceTypeSurchargeExempt;
	invoiceDebtorSeparation			: CM_InvTypeDebtorSeparation;
	
begin
	if self.hasScriptBeenRunAtAll(method.name, _updController) then
		return;
	endif;
	
	app.writeLog(method.qualifiedName &amp; " Populating Invoice Type Debtor Separation's Invoice Type Number", LogINFO);
	if _updController &lt;&gt; null then
		_updController.logEntry(" Populating Invoice Type Debtor Separation's Invoice Type Number") ;	
	endif;
	
	beginTransaction;
	
	//Loop all terminals
	foreach terminal in app.myRoot.allTerminals do :terminalLoop
		if terminal.companies.isEmpty then
			continue terminalLoop;
		endif;
		
		//Loop all companies
		foreach company in terminal.companies do :companyLoop
			if company.invoiceTypes.isEmpty then
				continue companyLoop;
			endif;
			
			//Loop all invoice types
			foreach invoiceType in company.invoiceTypes do :invoiceTypeLoop
				if invoiceType.mySurchargeAndExemptions = null then
					continue invoiceTypeLoop;
				endif;
				
				surchargesAndExemptions := invoiceType.mySurchargeAndExemptions;
				if surchargesAndExemptions = null then
					continue invoiceTypeLoop;
				endif;
				
				foreach invoiceDebtorSeparation in surchargesAndExemptions.allInvoiceTypeDebtorSeparation do
					if invoiceDebtorSeparation.invoiceDescNumber &lt;&gt; null then
						continue;
					endif;
					
					invoiceDebtorSeparation.setPropertyValue(CM_InvTypeDebtorSeparation::invoiceDescNumber.name, invoiceType.number); //Readonly Property
					
				endforeach;
				
			endforeach;
			
		endforeach;
		
	endforeach;
	
	commitTransaction;
	
	app.writeLog(method.qualifiedName &amp; " Populating Invoice Type Debtor Separation's Invoice Type Number complete", LogINFO);
	if _updController &lt;&gt; null then
		_updController.logEntry(" Populating Invoice Type Debtor Separation's Invoice Type Number complete") ;	
	endif;
	
	self.addScriptRun(method.name);
	
end;</source>
        <Parameter name="_updController" type="CnEcReleaseController"/>
    </JadeMethod>
    <JadeMethod name="populateOperatorAllCGsByTerm" id="8b8030f6-fbed-44ca-ac05-c546e9a1bac2">
        <source>populateOperatorAllCGsByTerm(_updController : CnEcReleaseController);
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
19 June 2025		jlizm1	Initial creation MTN 34778 Add terminal as key for operator cargo group collection

*/

vars
	cargoGroup		: CM_CargoGroup;
	objArray		: ObjectArray;
	operator		: CM_Operator;
	
begin
	
	if self.hasScriptBeenRunAtAll(method.name, null) then
		return;
	endif;

	app.writeLog(method.qualifiedName &amp; "Populating Cargo Groups by Terminal for Operators", LogINFO);
	
	if _updController &lt;&gt; null then
		_updController.logEntry("Populating Cargo Groups by Terminal for Operators") ;	
	endif;
	
	create objArray transient;
	CM_Operator.allInstances(objArray, 0, true);
	
	beginTransaction;
	
	foreach operator in objArray as CM_Operator do
		if operator.allCargoGroups.size = operator.allCargoGroupsByTerminal.size then
			// either empty or already match, so skip
			continue;
		endif;
		
		foreach cargoGroup in operator.allCargoGroups as CM_CargoGroup do
			operator.allCargoGroupsByTerminal.addNoDuplicates(cargoGroup, false);
		endforeach;
	endforeach;
	
	commitTransaction;
	
	app.writeLog(method.qualifiedName &amp; "Completed Populating Cargo Groups by Terminal for Operators", LogINFO);
	
	if _updController &lt;&gt; null then
		_updController.logEntry("Completed Populating Cargo Groups by Terminal for Operators") ;
	endif;
	
	self.addScriptRun(method.name);
	
epilog
	delete objArray;
	
end;</source>
        <Parameter name="_updController" type="CnEcReleaseController"/>
    </JadeMethod>
    <JadeMethod name="populateRootCompanyCode" id="a795a952-7421-4102-986c-6b0ff01b68bb">
        <source>populateRootCompanyCode(_updController : CnEcReleaseController);
/*
Purpose: For OpsView, MTN generates unique keys for all the objects sent to OpsView, this is called the GKEY. 
		In the OpsView database  there is also a PKEY value, which is the real unique key and is the COMPLEX ID and the GKEY concatinated.
		The COMPLEX ID sent to OpsView is the CM_Root.companyCode value.	
		
		In theory there could be multiple clients in one instance of OpsView so we need the company code (COMPLEX ID) to be set correctly (uniquely) in each customer environment.

Date		Who		Reason
01FEB2022	NAVAB1	TFS 51855
*/

vars
	mess : String;
	root : CM_Root;
	compCode : String;
begin
	if self.hasScriptBeenRunAtAll(method.name, _updController) then
		return;
	endif;
	
	mess := " Updating Root Company Code";
	app.writeLog(method.qualifiedName &amp; mess, LogINFO);
	if _updController &lt;&gt; null then
		_updController.logEntry(mess) ;	
	endif;
	
	root := CM_Root.firstInstance();
	
	if root &lt;&gt; null then
		if not root.isClientC3() // not including C3 as some log screens use root company code and company name.
		and not root.isClientJadeMaster() then // one of our systems, so ignore
			if root.companyCode = ""
			or root.companyCode = "JMT" then
				compCode := root.deriveCompanyCode();
				
				if compCode &lt;&gt; null then
					beginTransaction;
						root.setPropertyValue("companyCode", compCode);

					commitTransaction;
				
				endif;
					
			endif;
		endif;
		
		app.writeLog(method.qualifiedName &amp; mess &amp; " complete", LogINFO);
		if _updController &lt;&gt; null then
			_updController.logEntry(mess &amp; " complete") ;	
		endif;
		
		self.addScriptRun(method.name);
	else
		app.writeLog(method.qualifiedName &amp; " Root is not set!", LogINFO);

	endif;
epilog

end;</source>
        <Parameter name="_updController" type="CnEcReleaseController"/>
    </JadeMethod>
    <JadeMethod name="populateWorkOrderTIDtl" id="a3553b72-6b6f-4d78-8bbe-a5ce4101f275">
        <source>populateWorkOrderTIDtl(_updController : CnEcReleaseController);
/*

Purpose:			
	This script will be used to populate CM_WorkOrderTIDtl::allSelectedTIs from  CM_WorkOrderTI::allTIs or CM_WorkOrderTI::mySource
Parameters:			

Return Value:		

Date		Who		Reason
15 Mar 2023 navma1  ChangeRequest 56457:[56458] EUP - [Refactor] - Allowing different sets of cargo items per work order task

*/

vars
	wod 		: CM_WorkOrderDtl ;
	workOrderTI	: CM_WorkOrderTI;
	objArray 	: ObjectArray;
	obj 		: Object;
	wodToDo		: CM_WodToDo;
	tiSet		: CM_TISet;
begin
	
	if self.hasScriptBeenRunAtAll(method.name, null) then
		return;
	endif;

	app.writeLog(method.qualifiedName &amp; " Populating CM_WorkOrderTIDtl::allSelectedTIs", LogINFO);
	
	if _updController &lt;&gt; null then
		_updController.logEntry("Populating CM_WorkOrderTIDtl::allSelectedTIs") ;	
	endif;
	
	create objArray transient;
	CM_WorkOrderTI.allInstances( objArray, 0, true );
	
	beginTransaction;
	foreach obj in objArray do 
		workOrderTI 	:= obj.CM_WorkOrderTI;
		
		delete tiSet;
		create tiSet transient;
		
		if not workOrderTI.allTIs.isEmpty then
			workOrderTI.allTIs.copyNoDuplicates(tiSet,false);
		else
			if workOrderTI.mySource &lt;&gt; null then
				workOrderTI.mySource.getAllTIs(tiSet);
			endif;
		endif;
		
		if tiSet.isEmpty then
			continue;
		endif;
		
		foreach wod in  workOrderTI.allWoDtls do
			if wod.CM_WorkOrderTIDtl.allSelectedTIs.isNotEmpty then
				continue;
			endif;
			
			tiSet.copyNoDuplicates(wod.CM_WorkOrderTIDtl.allSelectedTIs,false);
			
			if wod.CM_WorkOrderTIDtl.allToDoRequests.isNotEmpty then
				foreach wodToDo in wod.CM_WorkOrderTIDtl.allToDoRequests do
					tiSet.copyNoDuplicates(wodToDo.allSelectedTIs,false);
				endforeach;
			endif;
		endforeach;
			
	endforeach;
	commitTransaction;
	
	app.writeLog(method.qualifiedName &amp; " Completed Populating CM_WorkOrderTIDtl::allSelectedTIs", LogINFO);
	
	if _updController &lt;&gt; null then
		_updController.logEntry("Completed Populating CM_WorkOrderTIDtl::allSelectedTIs") ;
	endif;
	
	self.addScriptRun(method.name);
	
epilog
	delete objArray;
end;</source>
        <Parameter name="_updController" type="CnEcReleaseController"/>
    </JadeMethod>
    <JadeMethod name="setBestPickDTAndOverstows" id="bb6f7f08-dc14-499d-83d5-b50d0c7f2c37">
        <source>setBestPickDTAndOverstows(_updController : CnEcReleaseController);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26 August 2025	jlier1	Initial creation 35632

*/

vars
	terminal : CM_Terminal;
	iter : Iterator;
	ti : CM_TrackedItem;
begin
	if self.hasScriptBeenRunAtAll(method.name, null) then
		return;
	endif;

	app.writeLog(method.qualifiedName &amp; " Setting Best Pick Date/Time to the Recieval DT", LogINFO);
	if _updController &lt;&gt; null then
		_updController.logEntry(" Setting Best Pick Date/Time to the Recieval DT") ;	
	endif;
	
	beginTransaction;
	foreach terminal in app.myRoot.allTerminals discreteLock do
		delete iter;
		iter := terminal.allOnsiteTIsByIdCargoType.createIterator;
		while iter.next( ti ) do
			if ti.myPrimaryActualLocation = null then
				continue;
			endif;
			ti.calcNumOverstows; //jlier1 JIRA# 35636
			if ti.bestPickDT &lt;&gt; null then
				continue;
			endif;
			if ti.receivedDT = null or not ti.receivedDT.isValid then
				continue;
			endif;
			ti.setPropertyValue(CM_TrackedItem::bestPickDT.name,ti.receivedDT);//not calling setBestPickDT because do not want a transaction
		endwhile;
	endforeach;
	commitTransaction;
	
	app.writeLog(method.qualifiedName &amp; "Setting Best Pick Date/Time to the Recieval DT -complete", LogINFO);
	if _updController &lt;&gt; null then
		_updController.logEntry("Setting Best Pick Date/Time to the Recieval DT -complete") ;
	endif;

	self.addScriptRun(method.name);

epilog
	delete iter;
end;</source>
        <Parameter name="_updController" type="CnEcReleaseController"/>
    </JadeMethod>
    <JadeMethod name="setCargoForecastMandatory" id="7093ee13-cecc-4b96-be88-8263796c12a8">
        <source>setCargoForecastMandatory(_controller: CnEcReleaseController);
/*

Purpose:			

Parameters:			

Return Value:		

