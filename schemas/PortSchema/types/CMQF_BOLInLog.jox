    <JadeMethod name="canUserRunReport" id="4725ea1c-0243-4e3e-8e46-2cc5c4b6cc1c">
        <source>canUserRunReport(_user: CM_User): Class;
// -------------------------------------------
// Created 15 December 2004 by cnwdvb1
// -------------------------------------------
vars

	class : Class;

begin
	
	class := inheritMethod(_user);
	if class &lt;&gt; null then
		return class;
	endif;
	
	if not _user.canUserAccessObj(app.myRoot.allCarriers[self.carrierCode], CM_Carrier) then
		return CM_Carrier;
	endif;
	
	return null;


end;</source>
        <Parameter name="_user" type="CM_User"/>
        <ReturnType type="Class"/>
    </JadeMethod>
    <JadeMethod name="cloneReferences" id="f09bb637-69ab-40fc-88f0-deaf909dc035">
        <updating/>
        <source>cloneReferences(_obj: CMQF_BOLInLog; _transient : Boolean) updating;
// ---------------------------------------------------------------------------
// Created:     18 October 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	inheritMethod(_obj, _transient);
	
	self.setMyLogGrade( _obj.getMyLogGrade );
	self.setMyLogLength( _obj.getMyLogLength );
	self.setMyLogSpecies( _obj.getMyLogSpecies );
	self.setMyLogTreatment( _obj.getMyLogTreatment );
	self.setMyLogType( _obj.getMyLogType );

end;</source>
        <Parameter name="_obj" type="CMQF_BOLInLog"/>
        <Parameter name="_transient" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="filterObjects" id="ac31876a-cee2-483f-aa89-92e2b3bb9098">
        <updating/>
        <source>filterObjects(_collection  : Collection input; _passport : CM_Passport) updating;
// ---------------------------------------------------------------------------
// Created:     06 September 2002 by cnwth2
//
// Purpose:     
//	14/07/2025	naviv1	MTN-35226	MTN - Usage of Iterator.getCurrentKeys  
// ----------   ----------  --------------------------------------------------

vars
	bol				: CM_BOL;
	iter			: Iterator;
	terminal		: CM_Terminal;
	breakOut,
	byStartDate,
	byMatchDate		: Boolean;
	typeKey			: Integer;
	tmpDocketNumber,
	bolKey			: String;
	dateKey			: TimeStamp;
begin
	
	tmpDocketNumber := self.docketNumber;
	if tmpDocketNumber &lt;&gt; null then
		foreach terminal in self.allTerminals do
			delete iter;
			iter := terminal.allBOLsReceivedByTypeNumberDT.createIterator();
			terminal.allBOLsReceivedByTypeNumberDT.startKeyGeq(BOLType_Log, tmpDocketNumber, null, iter);
		
			while iter.next(bol) do
				iter.getCurrentKeys(typeKey, bolKey, dateKey); //MTN-35226
				if (not bolKey.startsWith(tmpDocketNumber)) then
					break;
				endif;
				if typeKey &lt;&gt; BOLType_Log then
					break;
				endif; 
				if checkStatusIncludesObject(bol.CM_BOLIn, _passport, breakOut) then
//				if self.includesObject(bol.CM_BOLIn, _passport, breakOut) then
					_collection.add(bol);
				endif;
			endwhile;

//			bol := terminal.allBOLsReceivedByTypeNumberDT.getAtKeyGeq(BOLType_Log, tmpDocketNumber, null);
//			if bol &lt;&gt; null and CM_BOLIn.hasInstance(bol) and self.includesObject(bol.CM_BOLIn, _passport, breakOut) then
//				_collection.add(bol);
//				return;
//			endif;
		endforeach;
		return;
	endif;
	
	byMatchDate := self.matchEndDate.isValid;
	byStartDate := self.startDate.isValid;

	foreach terminal in self.allTerminals do : terminalLoop
		delete iter;
		iter := terminal.allBOLsReceivedByDTType.createIterator;
		
		if self.matchStartDate.isValid then
			//bols are never matched before they're created, so this is safe
			terminal.allBOLsReceivedByDTType.startKeyGeq(BOLType_Log, self.matchStartDate, iter);
		else
			terminal.allBOLsReceivedByDTType.startKeyGeq(BOLType_Log, self.startDate.TimeStamp, iter);
		endif;
		
		while iter.next (bol) do
			if bol.bolType &lt;&gt; BOLType_Log then
				break;
			endif;
			
			if byMatchDate then
				if bol.matchTime &gt; self.matchEndDate then
					break;
				endif;
			elseif byStartDate then
				if bol.dateTime.date &gt; self.endDate then
					break;
				endif;				
			endif;
			
			if checkStatusIncludesObject(bol.CM_BOLIn, _passport, breakOut) then
//			if self.includesObject(bol.CM_BOLIn, _passport, breakOut) then
				_collection.add(bol);
//				if breakOut then
//					break terminalLoop;
//				endif;
			endif;
		
		endwhile;
	endforeach;
	
epilog
	delete iter;
end;</source>
        <Parameter name="_collection" type="Collection" usage="input"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="eb334085-e672-4065-a46f-d954a5447473">
        <source>getDisplayStringForAttribute(_attrName : String; _getCalculatedDate : Boolean) : String;
// ---------------------------------------------------------------------------
// Created:     19/07/2010 cnwdz2	
//
// Purpose:     PAR24513 extend the current existing getDisplayStringForAttribute method to return an object's oid.		 
// ----------   ----------  --------------------------------------------------
vars
	runDate			: Date;
	oid    : String;
begin
	return self.getOIDAndDescForAttribute(_attrName, _getCalculatedDate, oid);
	/*
	if _attrName = ETRow_CarrierCode or
	   _attrName = ETRow_Carrier then
		return self.carrierCode;
		
	elseif _attrName = ETRow_GangNumber then
		return self.gangNumber;
	
	elseif _attrName = ETRow_DocketError then			//ccms 1110 begins
		if self.myDocketErrorType &lt;&gt; null then
			return self.myDocketErrorType.code;
		endif;
		return Any_String;
		//return self.logDocketErrorCode;		// for 781 should be this
		
	elseif _attrName = ETRow_PieceCountError then
		return self.isPieceCountError.cnEcGetTableCheckBoxValue(); // #24306	01/06/2010
		
	elseif _attrName = ETRow_HasComments then
		return self.hasComments.cnEcGetTableCheckBoxValue;
	
	elseif _attrName = ETRow_MyLogSpecies or
		_attrName = ETRow_LogSpecies then
		if self.myLogSpecies &lt;&gt; null then
			return self.myLogSpecies.code;
		endif;
		return Any_String;
		
	elseif _attrName = ETRow_MyLogGrade or
		_attrName = ETRow_LogGrade then
		if self.myLogGrade &lt;&gt; null then
			return self.myLogGrade.code;
		endif;
		return Any_String;
		
	elseif _attrName = ETRow_MyLogType or
		_attrName = ETRow_LogType then
		if self.myLogType &lt;&gt; null then
			return self.myLogType.code;
		endif;
		return Any_String;

	elseif _attrName = ETRow_MyLogTreatment or
		_attrName = ETRow_LogTreatment then
		if self.myLogTreatment &lt;&gt; null then
			return self.myLogTreatment.code;
		endif;
		return Any_String;

	elseif _attrName = ETRow_MyLogLength or
		_attrName = ETRow_LogLength then
		if self.myLogLength &lt;&gt; null then
			return self.myLogLength.code;
		endif;
		return Any_String;
	
	elseif _attrName = ETRow_LoggingOrganisation then
		return self.loggingOrganisation;
	
	elseif _attrName = ETRow_LoggingOperation then
		return self.loggingOperation;
		
	elseif _attrName = ETRow_MatchDateStart then
		if _getCalculatedDate then
			return self.setDateFromTemplate(self.matchStartDateTplType, self.matchStartDateTplFactor, runDate).shortFormatJMT();
		else
			return self.getTemplateDateStr(self.matchStartDateTplType, self.matchStartDateTplFactor);
		endif;
		
	elseif _attrName = ETRow_MatchDateEnd then
		if _getCalculatedDate then
			return self.setDateFromTemplate(self.matchEndDateTplType, self.matchEndDateTplFactor, runDate).shortFormatJMT();
		else
			return self.getTemplateDateStr(self.matchEndDateTplType, self.matchEndDateTplFactor);
		endif;
		
	elseif _attrName = ETRow_MatchTimeStart then
		//return self.matchStartDate.time.String;
		return self.matchStartDate.time.asStringJMT(); //par 18944 cnwjo3
		
	elseif _attrName = ETRow_MatchTimeEnd then
		//return self.matchEndDate.time.String;
		return self.matchEndDate.time.asStringJMT();  //par 18944 cnwjo3
	
	elseif _attrName = ETRow_SrcLocation then
		return self.sourceLocation;
	
	elseif _attrName = ETRow_SrcSubLocation then
		return self.sourceSubLocation;
	
	elseif _attrName = ETRow_SrcSubSubLocation then
		return self.sourceSubSubLocation;
	endif;

	return inheritMethod(_attrName, _getCalculatedDate);
*/

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_getCalculatedDate" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getMyLogGrade" id="36119a26-18fb-42b2-9e4e-dcbd025e910b">
        <source>getMyLogGrade():CM_LogGrade;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 July 2016	cnwndl1	Initial creation	TFS 2329

*/

vars

	object : CM_LogGrade;
	edition : Integer;
	invalidObj : Boolean;

begin

	object := self.myLogGrade;

	if object = null then
		return null;
	endif;
	
	on Exception do app.handleDeletedObject( exception, object, invalidObj );
	edition := object.edition;
	
	if invalidObj then
		return null;
	endif;
	
	return object;

epilog

end;</source>
        <ReturnType type="CM_LogGrade"/>
    </JadeMethod>
