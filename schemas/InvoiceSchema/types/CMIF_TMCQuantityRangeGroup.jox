    <JadeMethod name="initialise" id="25c2ca17-4988-46cd-97cb-45b0668e2f5d">
        <updating/>
        <source>initialise(_groupCount : Integer io) updating;
//09/02/2017 cnwma1  TFS #2901:ADP - Variable storage charges based on weight and time

vars
	ild: CM_InvoiceLineDesc;
	tmcS : CMIF_TMCInvLineDesc;
	sb : CM_ServiceBroker;
	resContractIn : CMIF_TMCResourceContractIN;
	resContractOut : CMIF_TMCResourceContractOUT;
	finObj : CM_FinancialObject;
	debtorMap  : CM_DebtorMap;
	tmcQRSubM : CMIF_TMCQuantitySubRangeGroup;
	mapping : CM_TranMapInvoiceLineMapping;
begin
	self.myTMCController := self.myGroup.myTMCController;	// April 2010, cnwjre1, par 23659, invoice transaction map extract enhancements for Tranship IMEX status
	self.hidePictures := self.myTMCController.hidePictures;

	finObj := self.myQuantityRangeMap.myQuantityMap.myParentFinancialObject;
	if finObj.isKindOf(CM_DebtorMap) then
		sb := finObj.CM_DebtorMap.myServiceBroker;
	elseif finObj.isKindOf(CM_QuantityRangeMap) then  //09/02/2017 cnwma1 TFS #2901
		if finObj.CM_QuantityRangeMap.myQuantityMap.myParentFinancialObject.isKindOf(CM_DebtorMap) then  //17/02/2017 cnwma1 TFS #2901
			debtorMap :=finObj.CM_QuantityRangeMap.myQuantityMap.myParentFinancialObject.CM_DebtorMap;
			if debtorMap &lt;&gt; null then
				sb := debtorMap.myServiceBroker;
			endif;
		endif;
	else
		sb := finObj.CM_ServiceBroker;
	endif;
	if sb.isKindOf(CM_ResourceServiceBroker) then
		create resContractIn;
		resContractIn.myDebtorMap := finObj.CM_DebtorMap;
		resContractIn.myDebtor := resContractIn.myDebtorMap.myDebtorNode;
		resContractIn.myServiceBroker := null; 
		resContractIn.itemName := resContractIn.getItemName();
		resContractIn.extractName := resContractIn.getItemName();	// 23659
		resContractIn.myGroup := self;
		resContractIn.myQuantityRangeMap := self.myQuantityRangeMap;
		resContractIn.initialise(_groupCount);
		
		create resContractOut;
		resContractOut.myDebtorMap := finObj.CM_DebtorMap;
		resContractOut.myDebtor := resContractOut.myDebtorMap.myDebtorNode;
		resContractOut.myServiceBroker := null; //self.myServiceBroker.CM_ResourceServiceBroker;
		resContractOut.itemName := resContractOut.getItemName();
		resContractOut.extractName := resContractOut.getItemName();	// 23659
		resContractOut.myQuantityRangeMap := self.myQuantityRangeMap;
		resContractOut.myGroup := self;
		resContractOut.initialise(_groupCount);
		
	else
		//17/02/2017 cnwma1 TFS #2901
		if self.myQuantityRangeMap &lt;&gt; null then
			if self.myQuantityRangeMap.myChildQuantityMap &lt;&gt; null then
				create tmcQRSubM;
				tmcQRSubM.myGroup := self;
				//tmcQRSubM.itemName := self.myQuantityRangeMap.myChildQuantityMap.getExtractDetails();	  //23/02/2017 cnwma1 TFS 2901
				tmcQRSubM.itemName := self.myQuantityRangeMap.myChildQuantityMap.getName();	             //23/02/2017 cnwma1 TFS 2901
				tmcQRSubM.extractName := self.myQuantityRangeMap.myChildQuantityMap.getExtractDetails();		
				tmcQRSubM.myQuantityRangeMap := self.myQuantityRangeMap;
				tmcQRSubM.initialise(_groupCount);
				_groupCount := _groupCount + 1;		//17 Dec 2019	NDL	TFS 48039
				return;
			endif;
		endif;
		//1702/2017 cnwma1 TFS #2901
		
// TFS 40620		foreach ild in self.myQuantityRangeMap.allInvoiceLineMaps discreteLock do
		foreach mapping in self.myQuantityRangeMap.allTMInvoiceLineMappings do // TFS 40620
			ild := mapping.myTMInvoiceLineDesc; // TFS 40620
			
			//add in each service in the list
			if self.allGroupMembers[ild.narration] = null then
				create tmcS;
				tmcS.itemName := ild.narration;
				tmcS.extractName := ild.narration;		// 23659
				tmcS.myQuantityRangeMap := self.myQuantityRangeMap;
				tmcS.myGroup := self;
				tmcS.myInvoiceLineDesc := ild;
				tmcS.hidePictures := self.myTMCController.hidePictures;
				_groupCount := _groupCount + 1;	//17 Dec 2019	NDL	TFS 48039
			endif;
		endforeach;
	endif;
	_groupCount := _groupCount + 1;		//17 Dec 2019	NDL	TFS 48039
end;</source>
        <Parameter name="_groupCount" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="isBOL" id="c19f0acd-2f06-4dc7-a14d-b1b08f4c8d08">
        <source>isBOL():Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 November 2019	jlgndl1	Initial creation	TFS 47100

*/

vars
	aTransSB : CM_ServiceBroker; 
	isBOL	: Boolean;
begin
	if self.myGroup.isKindOf(CMIF_TMCQuantityRangeGroupDeft)    then 
		aTransSB := self.myGroup.myGroup.CMIF_TMCQuantityGroupDefault.myServiceMap;
	elseif self.myGroup.isKindOf(CMIF_TMCQuantityGroupDefault)   then 						
		aTransSB := self.myGroup.CMIF_TMCQuantityGroupDefault.myServiceMap;
	elseif self.myGroup.isKindOf(CMIF_TMCQuantityGroup)   then 						
		aTransSB := self.myGroup.CMIF_TMCQuantityGroup.myDebtorMap.myServiceBroker;
	elseif self.myGroup.isKindOf(CMIF_TMCQuantityRangeGroup)   then
		
		if self.myGroup.CMIF_TMCQuantityRangeGroup.myQuantityRangeMap.myQuantityMap.myParentFinancialObject.isKindOf(CM_DebtorMap) then
			aTransSB := self.myGroup.CMIF_TMCQuantityRangeGroup.myQuantityRangeMap.myQuantityMap.myParentFinancialObject.CM_DebtorMap.myServiceBroker;
		elseif self.myGroup.CMIF_TMCQuantityRangeGroup.myQuantityRangeMap.myQuantityMap.myParentFinancialObject.isKindOf(CM_MoveServiceBroker) then
			aTransSB := self.myGroup.CMIF_TMCQuantityRangeGroup.myQuantityRangeMap.myQuantityMap.myParentFinancialObject.CM_ServiceBroker;
		else
			aTransSB := self.myGroup.CMIF_TMCQuantityRangeGroup.myQuantityRangeMap.myQuantityMap.myParentFinancialObject.CM_ServiceBroker;
		endif;
	endif;
	if aTransSB.isKindOf(CM_BOLServiceBroker) then
		isBOL := true;
	endif;
	
	return isBOL;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isDefault" id="51f82e67-ba1d-42f4-aed9-2e51601045fa">
