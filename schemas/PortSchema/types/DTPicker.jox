    <JadeMethod name="setDate" id="d692a187-2f9c-44c0-88b9-ec335fa3be9b">
        <updating/>
        <source>setDate(date: Date) updating;

begin

	// Set the day to a value that is valid for all months.
	// Otherwise if the current day happens to be invalid for
	// the new month, you get an exception.
	setDay(1);

	setMonth(date.month);
	setYear(date.year);
	setDay(date.day);

end;</source>
        <Parameter name="date" type="Date"/>
    </JadeMethod>
