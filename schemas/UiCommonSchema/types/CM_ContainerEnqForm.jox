    <JadeMethod name="doMAFILoadDragTI" id="38148e4d-4592-4172-9bd2-a0ab562d22e8">
        <updating/>
        <source>doMAFILoadDragTI(_table : Table) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 April 2023	navkc1	Initial creation CR 57036 Task 57589: UI - Cargo Enquiry Drag Drop

*/

vars
	tbl		: CM_DataTable;
	theTI	: CM_TrackedItem;
	pic		: Picture;
	
begin
	
	tbl := _table.CM_DataTable;
	
	theTI := tbl.allSelectedObjects.first().CM_TrackedItem;
	
	if theTI = null then
		return;
	endif;

	app.myDraggedTrackedItem := theTI;
	self.moveTrackedItem(theTI, self.tblView2);
	self.tblView2.dragMode := DragMode_Drag;

	create pic transient;
	
	self.setPictureDragCursor(pic);
	
	if pic.picture &lt;&gt; null then
		self.tblView2.dragCursor := pic.picture;
		app.isDragging := true;
	endif;
	
epilog
	delete pic;
end;</source>
        <Parameter name="_table" type="Table"/>
    </JadeMethod>
    <JadeMethod name="doMAFIOnboardUpdateNotify" id="8ecd74c3-caa0-462b-95ff-736be37663c0">
        <source>doMAFIOnboardUpdateNotify(_table : Table; _eventType : Integer; _obj : Object; _eventTag : Integer);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 April 2023	navkc1	Initial creation CR 57036 Task 57589: UI - Cargo Enquiry Drag Drop

*/

vars
	index,
	row		: Integer;
begin
	if self.allMAFIOnboardNotify.isEmpty() then
		return;
	endif;
	
	index := self.allMAFIOnboardNotify.indexOf(_obj);
	
	if index = 0 then
		return;
	endif;
	
	row := self.tblView2.updateItemObject(_obj, 0, 0, app.myPassport);
	self.doShowDataSpecial(self.tblView2, row, _obj);
epilog

end;</source>
        <Parameter name="_table" type="Table"/>
        <Parameter name="_eventType" type="Integer"/>
        <Parameter name="_obj" type="Object"/>
        <Parameter name="_eventTag" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="doMTChangeSubTerminalPackInfo" id="011b4d92-5a24-4588-9888-7a337d2d51d9">
        <source>doMTChangeSubTerminalPackInfo( _extraInfo : CMIF_TIUpdateExtraParams) : Boolean;
/*

Purpose: CCMS 1804 if we've chanegd an MTs sub-terminal to a pack type (warehouse) we want to ask for some extra info.
assuming self.myProxyObject is up to date with edits 

Parameters:			

Return Value:		

Date		Who		Reason
25 May 2009	cnwrd1	Initial creation

*/
vars
	packInfoForm 	: CMUI_ReleaseToPackSubTermForm;
	tmpCommodity	: CM_Commodity;
	mousePointer 	: Integer;
	isEmpty 		: Boolean;
	result 			: Boolean;
	
begin
	result := true;
	
	mousePointer := MousePointer_HourGlass;
	
	//only for systems with sub terminals
	if not app.isSubTerminalsOn(self.myTerminal) then
		return result;
	endif;
	
	// only for containers
	if not self.myProxyObject.isKindOf(CM_Container) then
		return result;
	endif;
	
	tmpCommodity := self.myProxyObject.CM_Container.getCommodityObject();
	
	if tmpCommodity &lt;&gt; null and tmpCommodity.isEmpty then
		isEmpty := true;
	endif;
	/*
	// only on empties
	if not self.myProxyObject.CM_TrackedItem.isEmpty  or  not (tmpCommodity &lt;&gt; null and not tmpCommodity.isEmpty) then
		return;
	endif;
	*/
	
	if not isEmpty then
		return result;
	endif;
	
	//	if we'e changed the sub terminal and the new one is of type for packing (SubTermType_Warehouse_Int) then away we go.
	
	if self.myCurrentObject.CM_TrackedItem.mySubTerminal &lt;&gt; self.myProxyObject.CM_TrackedItem.mySubTerminal
	and self.myProxyObject.CM_TrackedItem.mySubTerminal.type = SubTermType_Warehouse_Int
	then
		create packInfoForm;
		packInfoForm.myCurrentTrackedItem := self.myProxyObject.CM_TrackedItem;
		packInfoForm.myTIUpdateInfo := _extraInfo;
		//packInfoForm.initForTrackedItem();
		
		mousePointer := app.mousePointer;
		app.mousePointer := MousePointer_Default;
		packInfoForm.showModal();
		//result := packInfoForm.modalResult;
		
		if packInfoForm.modalResult = ModalResultCancel then
			result := false;
		endif;
	endif;
	
	return result;
epilog
	delete packInfoForm;
	app.mousePointer := mousePointer;
end;</source>
        <Parameter name="_extraInfo" type="CMIF_TIUpdateExtraParams"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
