    <JadeMethod name="getIs30" id="85fc62e2-389b-4b2a-8f27-14da6df4373e">
        <source>getIs30() : Boolean;
// ---------------------------------------------------------------------------
// Created:     15 March 2010 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	criteria : CM_YACriteria;
begin

	criteria := self.getCriteriaOfTypeValue(YACriteriaType_IsThirty);
	if criteria &lt;&gt; null then

		if criteria.myYAData.CM_YADataBoolean.getValueAsBoolean() then 
			return true;
		endif;
	endif;

	criteria := self.getCriteriaOfTypeValue(YACriteriaType_ISO);
	if criteria &lt;&gt; null then
		if  criteria.myYAData.CM_YADataObjects.allObjects.first().CM_ISOType.is30ftLong() then
			return true;
		endif;
	endif;

	criteria := self.getCriteriaOfTypeValue(YACriteriaType_ISOGroup);
	if criteria &lt;&gt; null then
		if  criteria.myYAData.CM_YADataObjects.allObjects.first().CM_ISOTypeGroup.is30ftLong() then
			return true;
		endif;
	endif;
	
	return  false;

epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
