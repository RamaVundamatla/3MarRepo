    <JadeMethod name="doClearItemLevel" id="22e6988a-7911-4855-94dd-4e5c51e3e270">
        <source>doClearItemLevel(pListbox: ListBox; pIndex : Integer);
// ---------------------------------------------------------------------------
// Created:		January  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	lListCount : Integer;
	lLevel : Integer;
begin

	lListCount := pListbox.listCount;
	lLevel := pListbox.itemLevel[pIndex];
	
	if pIndex &lt;= lListCount then
		while true do
			// Something with the same level as us or above us, so stop
			if pListbox.itemLevel[pIndex + 1] &lt;= lLevel then
				break;
			endif;
			pListbox.removeItem(pIndex + 1);
			lListCount := lListCount - 1;
			// check that we have not just got rid of the bottom item
			if pIndex + 1 &gt; lListCount then 
				break;
			endif;
		endwhile;
	endif;



end;</source>
        <Parameter name="pListbox" type="ListBox"/>
        <Parameter name="pIndex" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="doClonedMenuClickSpecial" id="f2a83d19-6e7d-4082-9916-fde3a677502a">
        <updating/>
        <source>doClonedMenuClickSpecial(menuItem: MenuItem input) updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 October 2015	cnwndl1	Initial creation	Par 37011

*/

vars

	obj	: Object;
	ti : CM_TrackedItem;
	realTiSet : CM_TISet;
	taskFormName : String;
	taskFormNameLength : Integer;
	passedAction : Integer;
	selectedCargo : CM_TIArray;

begin
	
	taskFormName := CMUI_TasksForm.name;
	taskFormNameLength := taskFormName.length;
	if menuItem.helpKeyword.length &gt; taskFormNameLength and menuItem.helpKeyword[1:taskFormNameLength] = taskFormName then
		passedAction := menuItem.helpKeyword[taskFormNameLength + 2:1].Integer;
		create realTiSet transient;
		create selectedCargo transient;
		self.mySDF.getAllSelectedTIs( selectedCargo );
		if not selectedCargo.isEmpty then
			selectedCargo.copy(realTiSet);
		endif;
		ti  := self.myCurrentTrackedItem;
		if ti = null and realTiSet.isEmpty then
			return;
		endif;
		self.myAssistant.showTasksForm (ti, realTiSet, true, passedAction );
		return;
	endif;

	inheritMethod(menuItem);

epilog

	delete realTiSet;
	delete selectedCargo;

end;</source>
        <access>protected</access>
        <Parameter name="menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doDeleteJob" id="2cb4f831-d375-4447-a8a0-b22b793e4285">
        <updating/>
        <source>doDeleteJob() updating;
//-----------------------------------------
//Created: May 2003 By: cnwgd1
//-----------------------------------------

vars
	result : Integer;
begin

	if self.myCurrentJob = null then
		return;	
	endif;

	app.mousePointer := MousePointer_HourGlass;	

	while true do
		app.myTrxDA.trxDeleteJob(self.myCurrentJob, app.myPassport);
		if app.myPassport.trxCompletedOK then
			// Clear errors/warnings from form and err/warnings window
			self.clearErrorWarnings();
			break;
		else
			result := app.showErrorWarningDialog('Erase Job', app.myPassport,  ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   result = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
		endif;
		break;
	endwhile;

epilog 
	app.mousePointer := MousePointer_Default;	
end;</source>
    </JadeMethod>
    <JadeMethod name="doDeleteTIQueueEntry" id="e1dd3548-0c64-4dff-9a8b-ba13239ef2b9">
        <updating/>
        <source>doDeleteTIQueueEntry() updating;
// ---------------------------------------------------------------------------
// Created:		February  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

	lWLE, proxyWLE	 : CM_WorkListEntry;
	idx : Integer;
	lTI	: CM_TrackedItem;
	aStr : String;
	lResult : Integer;
	lMoveControl : CMIF_MoveController;
	lTransferArea : CM_TerminalArea;
	rtnValue : Boolean;
	lQEntry : CM_RTQueueEntry;
	theResult : Integer;	//13 Jan 2020 NDL	TFS 46815
begin
	mousePointer := MousePointer_HourGlass;	

	if self.myCurrentTrackedItem = null then
		app.msgBox("Please select a WLE in the table.","Unqueueing", MsgBox_OK_Only);
		return;
	else
		// This clears up the RT Queue Tasks etc. and  then calls the TRXUTL to undo the TI move
		lQEntry := self.myCurrentTrackedItem.getQueueEntry();
		if lQEntry &lt;&gt; null then
		
			//13 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
			while true do
			
				app.myTrxDA.trxDeleteQueueEntry(lQEntry, app.myPassport);
			
				if app.myPassport.trxCompletedOK then
					break;
				else
					theResult := app.showErrorWarningDialog('Unqueue', app.myPassport, ErrWarnMode_Update);
					if app.myPassport.noErrors and theResult = IDOK then
						app.myPassport.warningsAcknowledged	:= true;
						continue;
					endif;
				endif;
				
				break;
				
			endwhile;
	
		else
			self.moveToLocation(null, self.myCurrentWLE, QUEUE_MODE);
		endif;
	endif;
epilog 
	mousePointer := MousePointer_Default;	
	if lMoveControl &lt;&gt; null then
		delete lMoveControl;
	endif;
	if proxyWLE &lt;&gt; null then
		delete proxyWLE;
	endif;



end;</source>
    </JadeMethod>
