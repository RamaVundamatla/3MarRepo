<Class name="CMIF_RoadOpPreGate" id="12ac81e6-e832-496e-b42d-afdc7042edfd">
    <superclass name="CMIF_RoadOpObject"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="Yard"/>
    <JadeMethod name="addVehicleToDataTable" id="a3764479-2b6a-4f74-a119-6029eeb5127a">
        <source>addVehicleToDataTable(_vehicle: CM_Vehicle input);
/*

Purpose:			


Return Value:		


Date		Who		Reason
22 August 2006	cnwer1	Initial creation - PAR#xxxx

*/
vars
	wle : CM_WorkListEntry;
	wleArray : CM_WLEArray;
begin

	// 25/09/2014 cnwar2 #34333
	if self.myRoadOpController.hideCompletedJobs then
		if not _vehicle.hasIncompleteRoadJobs then
			return;
		endif;
	endif;

	inheritMethod(_vehicle);
	create wleArray transient;
	_vehicle.getAllWLEs(wleArray);
	foreach wle in wleArray do
		if not self.allWLEs.includes(wle) then 		// PAR 17703
			if self.addDataTableObject(wle) then	// cms10/09/2009
				self.allWLEs.add(wle);
			endif;									// cms10/09/2009
		endif;
	endforeach;

epilog
	delete wleArray;
end;	</source>
        <Parameter name="_vehicle" type="CM_Vehicle" usage="input"/>
    </JadeMethod>
