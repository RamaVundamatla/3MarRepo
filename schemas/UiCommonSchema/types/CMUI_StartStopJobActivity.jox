    <JadeMethod name="translateForm" id="8af5c55e-d5f4-4658-94a0-71ee19a1e5bc">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 26 March 2024 14:00:30.
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0026791, locale);
	btnCancel.translateCaption(Xlat_0026792, locale);
	btnSave.translateCaption(Xlat_0026793, locale);
	lblComplete.translateCaption(Xlat_0026794, locale);
	lblDescription.translateCaption(Xlat_0026795, locale);
	lblStart.translateCaption(Xlat_0026796, locale);
end;</source>
    </JadeMethod>
</GUIClass>
