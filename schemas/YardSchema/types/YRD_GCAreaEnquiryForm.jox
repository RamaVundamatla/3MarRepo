    <JadeMethod name="tblGridAreaInfo_mouseMove" id="53455667-a135-4908-b5da-e4ce1a003de6">
        <controlMethod name="Table::mouseMove"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblGridAreaInfo_mouseMove(table: Table input; button: Integer; shift: Integer; x: Real; y: Real) updating;
// ---------------------------------------------------------------------------
// Created:		October 2003 By Andrew Bishop cnwab1
//
// Purpose:		was playing with un docking the extra info table
//
// ---------------------------------------------------------------------------

vars

begin
	return;

	if button = Window.MouseButton_Left 
	and table.dragMode &lt;&gt; DragMode_Drag
	and app.dragDetected(x, y, self.origXPos, self.origYPos) then
		table.dragMode := DragMode_Drag;
		self.frmInfoDrag.move(self.tblGridAreaInfo.left,self.tblGridAreaInfo.top,self.tblGridAreaInfo.width,self.tblGridAreaInfo.height);
		self.frmInfoDrag.visible := true;
//		table.dragCursor := null;
	endif;
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="translateForm" id="0858e84e-33a6-46d8-833f-9a237efcbb66">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 11 March 2019 19:55:14.
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0023463, locale);
	btnFlipH.translateBubbleHelp(Xlat_0023471, locale);
	btnFlipH.translateCaption(Xlat_0023470, locale);
	btnFlipV.translateBubbleHelp(Xlat_0023469, locale);
	btnFlipV.translateCaption(Xlat_0023468, locale);
	btnMoveBotLeft.translateBubbleHelp(Xlat_0023481, locale);
	btnMoveBotLeft.translateCaption(Xlat_0023480, locale);
	btnMoveBotLeftPs.translateBubbleHelp(Xlat_0023489, locale);
	btnMoveBotLeftPs.translateCaption(Xlat_0023488, locale);
	btnMoveBotRighPs.translateBubbleHelp(Xlat_0023491, locale);
	btnMoveBotRighPs.translateCaption(Xlat_0023490, locale);
	btnMoveBotRight.translateBubbleHelp(Xlat_0023483, locale);
	btnMoveBotRight.translateCaption(Xlat_0023482, locale);
	btnMoveTopLeft.translateBubbleHelp(Xlat_0023477, locale);
	btnMoveTopLeft.translateCaption(Xlat_0023476, locale);
	btnMoveTopLeftPs.translateBubbleHelp(Xlat_0023485, locale);
	btnMoveTopLeftPs.translateCaption(Xlat_0023484, locale);
	btnMoveTopRight.translateBubbleHelp(Xlat_0023479, locale);
	btnMoveTopRight.translateCaption(Xlat_0023478, locale);
	btnMoveTopRightP.translateBubbleHelp(Xlat_0023487, locale);
	btnMoveTopRightP.translateCaption(Xlat_0023486, locale);
	btnRefresh.translateBubbleHelp(Xlat_0023475, locale);
	btnRefresh.translateCaption(Xlat_0023474, locale);
	btnSelectTAs.translateBubbleHelp(Xlat_0023473, locale);
	btnSelectTAs.translateCaption(Xlat_0023472, locale);
	btnSummariseAll.translateBubbleHelp(Xlat_0019312, locale);
	btnSummariseAll.translateCaption(Xlat_0019313, locale);
