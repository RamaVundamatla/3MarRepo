/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 July 2022	navds21	ChangeRequest 53913: MTN - Rail Operations Inspect Object

*/

vars
	anObject : Object;
begin
	if (not app.isAllowedToInspect()) then
		return;
	endif;
	
	if self.tblWorkEntries.row &gt; 0 and self.tblWorkEntries.column &gt; 0 then
		anObject := self.tblWorkEntries.accessRow(self.tblWorkEntries.row).itemObject;
		if anObject &lt;&gt; null and anObject.CM_WorkListEntry.job &lt;&gt; null then
			anObject.CM_WorkListEntry.job.inspect;
		endif;
	endif;

epilog

end;</source>
        <Parameter name="menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
