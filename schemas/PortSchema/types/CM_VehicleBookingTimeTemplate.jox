    <JadeMethod name="setForUpdate" id="6d11b292-4a5e-4282-bfab-8a8e2e2c4824">
        <updating/>
        <source>setForUpdate( _proxy : CM_VehicleBookingTimeTemplate ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 April 2013	cnwndl1	Initial creation	Par 31393

*/

vars

begin

	self.duration := _proxy.duration;
	self.numberOfSlots := _proxy.numberOfSlots;
	self.remarks := _proxy.remarks;
	self.startTime := _proxy.startTime;
	self.endTime := _proxy.endTime;
	self.myVBTimeslotType := _proxy.myVBTimeslotType;	//01 Oct 2014	NDL	Par 35008
	
	self.myVehicleBookingDayTemplate := _proxy.myVehicleBookingDayTemplate;
	
	

epilog

end;</source>
        <Parameter name="_proxy" type="CM_VehicleBookingTimeTemplate"/>
