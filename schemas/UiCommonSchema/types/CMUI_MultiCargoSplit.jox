    <JadeMethod name="validate" id="b1e8ea92-33eb-410b-8842-9c4972b454d7">
        <source>validate(	_allTiIdsToCreate : StringArray input; 
			_quantityArray : IntegerArray input;
			_weightArray : DecimalArray input;
			_voyageArray : CM_VoyageArray input
			):Boolean protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 June 2020	jlgndl1	Initial creation	TFS 49401

*/

vars

	size : Integer;
	startIndex : Integer;
	row : Integer;
	voyage : CM_Voyage;
	weightStr : String; // value &amp; unit  or Integer quantity
	weightValueArray : CnStringArray; 
	kgValue : Decimal[14,4];
	volume : Decimal[14,4];
	totalQuantity : Integer;
	totalWeight : Decimal[14,4];
	proposedId : String;

	msg : String;
	iter : Iterator;
	startObject : Object;
	existingTi : CM_TrackedItem;
	allJobs : CM_JobSet;
	job : CM_Job;
	wle : CM_WorkListEntry;
	usingAll : Boolean;
	
begin

	size := self.tblSplits.rows;
	startIndex := 2;
	foreach row in startIndex to size do
		voyage := self.tblSplits.accessCell( row, 1 ).itemObject.CM_Voyage;
		weightStr := self.tblSplits.accessCell( row, 2 ).text.trimBlanks;
		proposedId := self.tblSplits.accessCell( row, 3 ).text;
		
		if _allTiIdsToCreate.includes( proposedId ) then
			msg := "Proposed Cargo Id '" &amp; proposedId &amp; "' used more than once!";
			app.msgBox(msg,app.getErrorString(Error),MsgBox_OK_Only);
			return false;
		endif;
		
		_allTiIdsToCreate.add( proposedId ); 
		if self.myTrackedItem.isBulkByVolume then
			weightValueArray := weightStr.cnGetTokens(" ");
			volume := app.convertMeasurementForStorage(weightValueArray[2], weightValueArray[1].asDecimalJMT);
			kgValue:= volume * self.myTrackedItem.getDensity;
			_weightArray.add( kgValue );
			totalWeight := totalWeight + kgValue;	 // I.e. Total weight for all lines
		elseif self.myTrackedItem.myCargoType.isTrackByWeight then	
			weightValueArray := weightStr.cnGetTokens(" ");
			kgValue := app.convertMeasurementForStorage(weightValueArray[2], weightValueArray[1].asDecimalJMT);
			_weightArray.add( kgValue );
			totalWeight := totalWeight + kgValue;	 // I.e. Total weight for all lines
		else
			_quantityArray.add( weightStr.Integer );
			totalQuantity := totalQuantity + weightStr.Integer;	 // I.e. Total quantity for all lines
		endif;
		_voyageArray.add( voyage );
					
	endforeach;

	
	
	if self.myTrackedItem.isBulkByVolume or self.myTrackedItem.myCargoType.isTrackByWeight then
		if totalWeight &gt; self.myTrackedItem.totalWeight then
			if self.myTrackedItem.myCargoType.isTrackByWeight then
				msg := app.getErrorString1(Not_decla_quant_great_than_tot, self.myTrackedItem.id &amp; " (" &amp; self.myTrackedItem.getDefaultTotalWeightDisplay &amp; ")");
			else
				msg := app.getErrorString1(Not_decla_quant_great_than_tot, self.myTrackedItem.id &amp; " (" &amp; self.myTrackedItem.getDefaultTotalVolumeDisplay &amp; ")");
			endif;
			app.msgBox(msg,app.getErrorString(Error),MsgBox_OK_Only);
			return false;
		elseif totalWeight &gt; self.myTrackedItem.totalWeight then
			usingAll := true;
		endif;	
	endif;
	
	if self.myTrackedItem.isBulkByQuantity then
		if totalQuantity &gt; self.myTrackedItem.totalQuantity then
			msg := app.getErrorString1(Not_decla_quant_great_than_tot, self.myTrackedItem.id &amp; " (" &amp; self.myTrackedItem.totalQuantity.String &amp; ")");
			app.msgBox(msg,app.getErrorString(Error),MsgBox_OK_Only);
			return false;
		elseif totalQuantity = self.myTrackedItem.totalQuantity then
			usingAll := true;
		endif;
	endif;
	
	if usingAll then		
		create allJobs transient;
		self.myTrackedItem.getAllJobs(allJobs);
		foreach job in allJobs discreteLock do
			if not job.isJobComplete then
				msg := app.getErrorString1(Not_split_items_while_incom_jo, self.myTrackedItem.id);
				app.msgBox(msg,app.getErrorString(Error),MsgBox_OK_Only);
				return false;
			endif;
		endforeach;	
		foreach wle in self.myTrackedItem.allWorklistEntries discreteLock do
			if wle.status &lt;&gt; WLE_COMPLETED then
				msg := app.getErrorString1(Not_split_items_while_incom_wo, self.myTrackedItem.id);
				app.msgBox(msg,app.getErrorString(Error),MsgBox_OK_Only);
				return false;
			endif;
		endforeach; 	
	endif;
	
	foreach proposedId in _allTiIdsToCreate do
	
		startObject := self.myTerminal.allOnsiteTIsByCargoTypeId.getAtKeyGeq( myTrackedItem.cargoType, proposedId );
	
		//Check each proposed id would be unique
		//Because its break bulk which is allowed to be split or merged, we can have only one of each id per location per cargo type
		//Using an id that was alreday in use in the area would imply an intent to merge!!!
		if startObject &lt;&gt; null then
			iter := self.myTerminal.allOnsiteTIsByCargoTypeId.createIterator;
			iter.startAtObject(startObject);
			while iter.next(existingTi) do
				if existingTi.cargoType &lt;&gt; myTrackedItem.cargoType then
					//differnt cargo type. All done
					break;
				endif;
				if existingTi.id &lt;&gt; proposedId then
					break;
				endif;
				if existingTi.myPrimaryActualLocation &lt;&gt; myTrackedItem.myPrimaryActualLocation then
					//not in the same location, so we don't care
					continue;
				endif;
				
				msg := app.getErrorString1(Propos_alread_used_this_locati,proposedId);
				app.msgBox(msg,app.getErrorString(Error),MsgBox_OK_Only);
				return false;
				
			endwhile;
		endif;
	
	endforeach;
	
	return true;
	
epilog

	delete iter;
	delete allJobs;

end;</source>
        <access>protected</access>
        <Parameter name="_allTiIdsToCreate" type="StringArray" usage="input"/>
        <Parameter name="_quantityArray" type="IntegerArray" usage="input"/>
        <Parameter name="_weightArray" type="DecimalArray" usage="input"/>
        <Parameter name="_voyageArray" type="CM_VoyageArray" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</GUIClass>
