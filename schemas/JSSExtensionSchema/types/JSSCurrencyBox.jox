    <JadeMethod name="controlNamePrefix" id="42d41024-4309-47c3-a1cd-eb2a2daa04ed">
        <source>controlNamePrefix(): String;
// --------------------------------------------------------------------------------
// Created:		04 February 2003 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return "cub";
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getCurrencyFormat" id="a55daa4c-a30e-4f44-a70a-333203e1dfae">
        <source>getCurrencyFormat():CurrencyFormat;
// --------------------------------------------------------------------------------
// Created:		04 February 2003 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return self.myCurrencyFormat;
end;</source>
        <ReturnType type="CurrencyFormat"/>
    </JadeMethod>
    <JadeMethod name="gotFocus" id="ebd3f153-b6a3-481c-acfa-94669f939b81">
        <updating/>
        <source>gotFocus(textbox: TextBox input) updating;
// --------------------------------------------------------------------------------
// Created:		04 February 2003 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	textValue		: String;
	
begin
	inheritMethod(textbox);
	
	textValue	:=	textbox.text.jssAsNumeric(self.myCurrencyFormat);
	
	self.setIsIgnoreState(true);
	textbox.text	:=	null;
	self.dataType	:=	self.DataType_SignedNumeric;
	self.decimals	:=	self.myCurrencyFormat.decimalPlaces;
	self.setIsIgnoreState(false);
	textbox.text	:=	textValue;
	
	if self.selectionStyle = TextBox.SelectionStyle_SelectAll then	// cnwdad1 13/03/2002.
		textbox.selStart	:=	0;									// cnwdad1 13/03/2002.
		textbox.selLength	:=	textValue.length;					// cnwdad1 13/03/2002.
	endif;															// cnwdad1 13/03/2002.
end;</source>
        <Parameter name="textbox" type="TextBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="jssDate" id="44c67293-d424-4a14-92c6-3d1a4e4f66b3">
        <source>jssDate(): Date;
// --------------------------------------------------------------------------------
// Created:		04 February 2003 by cnwdad1
//
// Purpose:		This reimplementation returns a null value since a date value is
//				not relevant in the context of this control.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return null;
end;</source>
        <ReturnType type="Date"/>
    </JadeMethod>
    <JadeMethod name="jssDecimal" id="715c7281-db0e-410c-aa28-b2f9021dc5ff">
        <source>jssDecimal(): Decimal;
// --------------------------------------------------------------------------------
// Created:		04 February 2003 by cnwdad1
//
// Purpose:		Returns the receiver's currency value as a Decimal value.
//
// Parameters:	None
//
// Returns:		The decimal value.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if self.myCurrencyFormat &lt;&gt; null then 
		return self.text.jssAsNumeric(self.myCurrencyFormat).Decimal;
	else
		return self.text.jssAsNumeric(null).Decimal;
	endif;
end;</source>
        <ReturnType type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="jssInteger" id="0603a64c-d6c3-479a-8f6c-92d8c3a2dda6">
        <source>jssInteger(): Integer;
// --------------------------------------------------------------------------------
// Created:		04 February 2003 by cnwdad1
//
// Purpose:		Returns the receiver's currency value as an Integer value.
//
// Parameters:	None
//
// Returns:		The integer value.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return self.text.jssAsNumeric(self.myCurrencyFormat).Integer;
end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="jssReal" id="2e7c077c-517f-4e2e-b37e-294a10bf6fbb">
        <source>jssReal(): Real;
// --------------------------------------------------------------------------------
// Created:		04 February 2003 by cnwdad1
//
// Purpose:		Returns the receiver's currency value as a Real value.
//
// Parameters:	None
//
// Returns:		The real value.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return self.text.jssAsNumeric(self.myCurrencyFormat).Real;
end;</source>
        <ReturnType type="Real"/>
    </JadeMethod>
