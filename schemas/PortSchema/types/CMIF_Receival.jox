vars

begin
	self.wasCreatedFromMobileApp := true;
end;</source>
    </JadeMethod>
    <JadeMethod name="validateCargoTypeContents" id="b1c20602-9f3e-41bf-a434-253eec076b3e">
        <source>validateCargoTypeContents();
//
// Purpose:			Validates that cargoTypeContents is a valid cargo type
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 02/10/2025	navdap1		Initial creation MTN-36141 AAT | RotaBox Creation (EDI/API/Manual)
//
vars
	isoTypeObj : CM_ISOType;
	cargoTypeObj : CM_CargoType;

begin
	// DO we have an ISO type, and are we a container?
	if self.isoType = null or self.cargoType &lt;&gt; TI_CargoType_Container then
		return;
	endif;
	
	// Is the ISO type a Rotatable type?
	isoTypeObj := app.myRoot.allISOTypes[self.isoType];
	if isoTypeObj = null or not isoTypeObj.isRotatable() then
		return;
	endif;
	
	// Is contents status EMPTY or is my commodity the terminal's MT commodity?
	if self.contentsStatus = TI_CONTENTS_STATUS_EMPTY or (self.commodity &lt;&gt; null and commodity = self.myTerminal.getConfig(DefCommodity).String) then
		return;
	endif;
	
	// We need a Cargo Type for Contents if we're rotatable
	if self.cargoTypeContents = null then
		app.raiseCMException(Cargo_Type_Contents_Required, null, null);
		return;
	endif;
	cargoTypeObj := app.myRoot.allCargoTypesById[self.cargoTypeContents];
	if cargoTypeObj = null then
		app.raiseCMException1(Cargo_Type_Invalid, self.cargoTypeContents.String, null, null);
		return;
	endif;
	
	// The Cargo Type for Contents must be valid for this terminal
	if not self.myTerminal.allCargoBOLTypes.includes(cargoTypeObj) then
		app.raiseCMException2(Cargot_not_valid_cargot_termin, cargoTypeObj.description, self.myTerminal.name, null, null);
		return;
	endif;
	
	// The product (cargo subtype) must be supplied if the cargo type requires cargo sub types
	if cargoTypeObj.isSubCargoTypeRequired and self.myProduct = null then
		app.raiseCMException(Must_select_cargo_subtype, null, null);
		return;
	endif;
	
	// The product (cargo subtype) must be valid for the Cargo Type for Contents
	if self.myProduct &lt;&gt; null and self.myProduct.myCargoType &lt;&gt; cargoTypeObj then
		app.raiseCMException2(CargoSubtype_Invalid, cargoTypeObj.description, self.myProduct.code, null, null);
		return;
	endif;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="validateForAttachment" id="72db7d47-67ea-409d-9402-c5c1f8ccd04a">
        <updating/>
        <source>validateForAttachment(_passport: CM_Passport input): Boolean updating;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08/09/2009	cnwdap1	Initial creation
17/12/2009	cnwdap1	PAR #21827 Allow attachment to be edited directly from this form - correct setting of proxies
17/04/2018    jlgrh7 TFS 38055 MSL - coparn deletes stop fields
*/
vars
	tiUpdCntrl		: CMIF_TIUpdateController;
	theCargoType	: CM_CargoType;
	prenoteTI		: CM_TrackedItem;
	
begin
	theCargoType := app.myRoot.allCargoTypesById[self.cargoType];
	if theCargoType = null then
//		app.raiseCMException1(REQUIRED_FIELD, 'cargo type', 'cargoType', self.myUserObject);
		app.raiseCMException(Input_required_field_cargoType, 'cargoType', self.myUserObject); // cnwdb2	PAR 35364
		return _passport.noErrors();
	endif;

	// always delete the proxy for create (RJS 3/5/01)
	if self.myProxyTrackedItem &lt;&gt; null then
		self.eraseProxyTrackedItem();
	endif;

	//AA 15/6/01: If we are updating an existing TI we must generate an update proxy so that we can
	//perform integrity checking on the edition prior to updating the real object
	prenoteTI := self.myTerminal.lookupTrackedItem(id, self.cargoType, TI_STATE_NOTIFIED, null, false);
	if prenoteTI &lt;&gt; null then
		// 25/07/2008 cnwar2 #17525
		if self.tiEdition &lt;&gt; 0 and self.tiEdition &lt;&gt; prenoteTI.edition then
			if _passport.noErrors then
				app.raiseCMException1(ObjectUpdatedByAnotherUserSave, 'Pre-Notified Item', null, null);
				return false;
			endif;
		endif;
		// PAR #21827 Correct proxy handling for attachments
		self.myProxyTrackedItem := prenoteTI.pxyGetProxyObject();
		if self.myProxyTrackedItem = null then
			self.myProxyTrackedItem := app.createUpdateProxy(prenoteTI).CM_TrackedItem;
		endif;
	else
		//create the proxy from scratch
		self.myProxyTrackedItem := self.myTerminal.createTI(theCargoType, true);		
	endif;
	
	// set the values on the transient tracked item
	
	if not preservePrenoteData then	// dh this check added for ccms 1618 2/5/2008 +
		self.setTrackedItemData(null,self.myProxyTrackedItem, _passport);								//+TFS38055
	endif;																// +												

	tiUpdCntrl := app.createTIUpdateControl(TI_UPDMODE_RECEIPT, null, self.myUserObject);
	tiUpdCntrl.setInterfaceAttributes(self);

	self.myProxyTrackedItem.validateForAttachment(tiUpdCntrl, _passport);
	
epilog
	if tiUpdCntrl &lt;&gt; null then
		delete tiUpdCntrl;
	endif;
	
	return _passport.noErrors();
end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validateForCreate" id="7e2302dd-1bea-4454-9ab8-81902be348d8">
        <updating/>
        <source>validateForCreate(_passport : CM_Passport input) : Boolean updating;
// ---------------------------------------------------------------------------
// Created:     14 December 2000 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
// 01/04/2010	cnwdap1	PAR #23378 Update carrier and registration number on tracked item.
//							preservePrenoteData is only set to true in the mobile app,
//							myIntFaceInOutCommon.setTrackedItemData only sets terminal, carrier
//							and vehicle number.
// 14/03/2011	cnwcs5	PAR 26909 - 7.8.2 hotfix - remove operator export release number warning message
//								  - 7.9.1 - display message based on operator configuration
// 01/09/2014	cnwdap1	PAR #34771 Skip some validation (operator / cargo blocked, receival outside cutoff) if I'm a piece of child cargo
// 28/09/2015   cnwma1  PAR #36924 Voyage cut-off early receival error message
// 08/03/2018	jlgsl4	TFS 37348 - Stop 'Booking is unknown or invalid' for child added to booked TI
// 17/04/2018	jlgrh7 TFS 38055 MSL - coparn deletes stop fields
// 21/11/2018	jlgrs1	TFS 42276 STWR Make EDI MultiThreaded Stage 7
// 06/10/2025	navdap1	MTN-36141 AAT | RotaBox Creation (EDI/API/Manual)
vars	
	updateMode				: Integer;
	tiUpdCntrl				: CMIF_TIUpdateController;
	theCargoType			: CM_CargoType;
	parent,
	pxyParent,
	prenoteTI				: CM_TrackedItem;
	subItemError			: Boolean;
	theIsoType 				: CM_ISOType;
	theVoy 					: CM_Voyage;
	theOp 					: CM_Operator;
	job 					: CM_RoadJob;	
	isUpdateTI				: Boolean;										//+TFS38055
	crit            		: CM_ReceivalCutoffCriteria; //TFS 52538 NAVLW 06 Jan 2022
	ignoreCutOffCheck 		: Boolean; //TFS 52538 NAVLW 06 Jan 2022
	allCriteria 			: CM_ReceivalCutoffCriteriaDict; //TFS 52538 NAVLW 06 Jan 2022
	cutoffPreNote			: Boolean; //07/03/2025	navkc1 JIRA Story MTN-34225
	tiId					: String; //07/03/2025	navkc1 JIRA Story MTN-34225
	cutoffTS,
	earliestTS				: TimeStamp; //07/03/2025	navkc1 JIRA Story MTN-34225
begin
	isUpdateTI := false;															//+TFS38055										
	theOp := app.myRoot.allOperators[self.operatorCode];
	theVoy := self.myTerminal.lookupVoyage (self.voyageCode, null, false);
	
	// 08/02/2013 cnwar2 #3112
	if theVoy &lt;&gt; null and theVoy.isKindOf(CM_VoyageInlandTerminal) then
		theVoy := theVoy.CM_VoyageInlandTerminal.myVoyage;
	endif;
	
	// cnwjk3 22/01/09 CCMS 1620
	self.validateISOType();
		
	// PAR 18537 - give a warning if the operator release number not set
	// par 26909 - 7.8.2 hotfix - remove operator export release number warning
	// par 26909 - 7.9.1 - display operator export release number warning based on operator config setting
	if theOp &lt;&gt; null and 
		self.receiptTransportMode = TI_TRANSMODE_ROAD and 	// road receipt
		self.operatorExportReleaseNumber = null	and 		// no release number entered
		theOp.getRequiresExportOperatorNo and				// release number required
		theOp.getShowOpExportReleaseWarning	then			// they want a warning
		app.raiseCMWarning2(Operat_releas_number_requir_op, theOp.description, self.id, "operatorExportReleaseNumber", null, null);
	endif;

	theCargoType := app.myRoot.allCargoTypesById[self.cargoType];
	
	if theCargoType = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'cargo type', 'cargoType', self.myUserObject);
		app.raiseCMException(Input_required_field_cargoType, 'cargoType', self.myUserObject); // cnwdb2	PAR 35364
		return _passport.noErrors();
	endif;
	
//PAR6694 IsoType check is made when receiving to check the isoType matches a valid cargo type 13012004	
	theIsoType := app.myRoot.allISOTypes[self.isoType];
	if theIsoType &lt;&gt; null and theIsoType.myCargoType &lt;&gt; theCargoType then
		app.raiseCMException2(CargoTypeDoesNotMatchIsoType, theIsoType.myCargoType.description, theCargoType.description, 'Test',self.myUserObject);
		return _passport.noErrors();
	endif;	
	
	self.validateCargoTypeContents();		// MTN-36141
	
// need to be able have user indicate if container was washed or pre-tripped prior to coming on-site
// if checked then set the cleaned / pre-tripped date-time to today (ie time actually booked onsite).

	// always delete the proxy for create (RJS 3/5/01)
	if self.myProxyTrackedItem &lt;&gt; null then
		self.eraseProxyTrackedItem();
	endif;

	//AA 15/6/01: If we are updating an existing TI we must generate an update proxy so that we can
	//perform integrity checking on the edition prior to updating the real object
	
	//08 Nov 2016	NDL TFS 2919 / 2419
	if self.isEDI
	and self.myTerminal.getConfig( AllowDuplicatePreNotes ).Boolean
	and self.myUserObject &lt;&gt; null
	and self.myUserObject.isKindOf( CM_EDIPrenoteTI )
	and self.myUserObject.CM_EDIPrenoteTI.messageMode = "A"
	and self.myUserObject.CM_EDIPrenoteTI.cargoTypeAllowsDuplicates
	then
		//doing an add for a preote that allows duplicates, in an environment that supports this 
		//unconditionally create a new one
		prenoteTI := null;
	else
		if self.myMasterObject &lt;&gt; null then
			pxyParent:= self.myMasterObject.getMyProxyTrackedItem;
			if pxyParent &lt;&gt; null then
				parent:=pxyParent.pxyGetRealObject;
			endif;
		endif;
		//epr TFS 3880 4/4/17
		prenoteTI:=self.myTerminal.findPrenoteCargo(id,self.cargoType,parent,self.cargoGroupId);			//navra1 - TFS 60776 - 10th Oct 2023
	
	endif;

	if prenoteTI &lt;&gt; null then
		self.myProxyTrackedItem := app.createUpdateProxy(prenoteTI).CM_TrackedItem;
	else
		//create the proxy from scratch
		self.myProxyTrackedItem := self.myTerminal.createTI(theCargoType, true);		
	endif;
	
	// set the values on the transient tracked item
	
	if not self.preservePrenoteData then	// dh this check added for ccms 1618 2/5/2008 +
		self.setTrackedItemData(isUpdateTI,  self.myProxyTrackedItem, _passport);																	//+TFS38055
	endif;																// +												
	
	tiId := self.myProxyTrackedItem.id; //07/03/2025	navkc1 JIRA Story MTN-34225
	
	cutoffPreNote := theVoy &lt;&gt; null and theVoy.shipCutoffsForPrenotes; //07/03/2025	navkc1 JIRA Story MTN-34225
	// 28/05/2009 cnwar2 CCMS1040/#19796
	if self.myProxyTrackedItem.originallyCreatedAfterCutOff(cutoffTS) and not self.isChild then	//20 Jan 2016	NDL	Par 37409
		//epr TFS 5062 29/6/17 
		if self.myProxyTrackedItem.isPreNote() then //07/03/2025	navkc1 JIRA Story MTN-34225
				if cutoffPreNote then
				if self.myTerminal.getConfig(ShipCutoffsShowError).Boolean = true then
					app.raiseCMException2(Receival_Outside_CutoffPN, tiId, cutoffTS.asStringJMT(), null, null);
				else
					app.raiseCMWarning2(Receival_Outside_CutoffPN, tiId, cutoffTS.asStringJMT(), null, null, null);
				endif;
			endif;
		else
			if self.myTerminal.getConfig(ShipCutoffsShowError).Boolean = true then // PAR 35397
				app.raiseCMException1(Receival_Outside_Cutoff, tiId, null, null); // PAR 35397
			else
				app.raiseCMWarning1(Receival_Outside_Cutoff, tiId, null, null, null);
			endif;
		endif;
	else
		// Same as above, only check if it's not child //25/03/2025	navkc1 JIRA Defect Sub-task MTN-34476
		if not self.isChild then
			self.myProxyTrackedItem.validateForPrenoteCutoff(); //25/03/2025	navkc1 JIRA Defect Sub-task MTN-34476 - This is a prenote created way before. Validate the cutoff time
		endif;
	endif;
		
	if theVoy &lt;&gt; null and not self.isChild then
		earliestTS := self.myProxyTrackedItem.earliestReceivalTS; //07/03/2025	navkc1 JIRA Story MTN-34225
		if (earliestTS.isValid()
		and earliestTS &gt; app.actualTimeServer())
		then
			//TFS 52538 NAVLW 06 Jan 2022
			allCriteria := self.myProxyTrackedItem.getReceivalCutoffCriteria();
			if allCriteria &lt;&gt; null then
				foreach crit in allCriteria do
					if crit.myYACriteriaType.isKindOf(CM_YATypeIsPrenote) and crit.myYAData.isKindOf(CM_YADataBoolean) and crit.myYAData.CM_YADataBoolean.value = CM_YADataBoolean.VALUE_FALSE then
						ignoreCutOffCheck := true;
						break;
					endif;
				endforeach;
			endif;
			if not ignoreCutOffCheck then //TFS 52538 NAVLW 06 Jan 2022
				if self.myProxyTrackedItem.isPreNote()then
					if cutoffPreNote then
						if  self.myTerminal.getConfig(ShipCutoffsShowError).Boolean = true then
							app.raiseCMException2(Receival_Outside_EarliestPN, tiId, earliestTS.asStringJMT(), null, null);
						else
							app.raiseCMWarning2(Receival_Outside_EarliestPN, tiId, earliestTS.asStringJMT(),null, null, null);
						endif;
					endif;
				else
					if self.myTerminal.getConfig(ShipCutoffsShowError).Boolean = true then // PAR 35397
						app.raiseCMException1(Receival_Outside_Earliest, tiId, null, null); // PAR 35397
					else
						app.raiseCMWarning1(Receival_Outside_Earliest, tiId, null, null, null);
					endif;
				endif;
			endif;
		endif;
	endif;
	
	if self.myIntFaceInOutCommon &lt;&gt; null then
		//if not preservePrenoteData then  // dh for ccms 1618 2/5/2008		// PAR #23378
			self.myIntFaceInOutCommon.setTrackedItemData(self.myProxyTrackedItem);
		//endif;															// PAR #23378
		// dh 30/4/2008 changes made for ccms 1618 - added lines marked +
		if self.myIntFaceInOutCommon.myProxyRoadJob &lt;&gt; null then 	// +
			job := self.myIntFaceInOutCommon.myProxyRoadJob;		// +
		else														// +
			job := self.myIntFaceInOutCommon.myRoadJob;				// +
		endif;														// +
//		if self.myIntFaceInOutCommon.myProxyRoadJob.autoComplete then// -
		if job &lt;&gt; null then											// +
			if job.autoComplete then								// +
				self.validatePlannedLocation();						
			endif;													// +
		endif;														// +
	endif;

	subItemError := self.validateForSubItemDuplicates();

	if (not subItemError) then
		self.validateSubItems(_passport);
	endif;
	
	//self.myProxyTrackedItem.setTotalQVW();	//Count our children now				//-cnwml2 MSL CCMS 1017
	
	// 22991 set validation mode for on-ship BOL items
	updateMode := TI_UPDMODE_RECEIPT;
	if self.isBOLItem() then // PAR 28400 if self.isKindOf(CMIF_OnshipCargo) then
		updateMode := TI_UPDMODE_BOLITEM;
	endif;
	tiUpdCntrl := app.createTIUpdateControl(updateMode, null, self.myUserObject);
	tiUpdCntrl.setInterfaceAttributes(self);
	
	self.myProxyTrackedItem.addParent(self.myPackParent); // TFS 37348 - make sure validation knows when this is child cargo

	self.myProxyTrackedItem.validateTrackedItem(tiUpdCntrl, _passport);	//Sub items are recursively validated here
epilog
	if tiUpdCntrl &lt;&gt; null then
		delete tiUpdCntrl;
	endif;
	
	return _passport.noErrors();
end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validateForSubItemDuplicates" id="922e2216-5c05-4ebc-9ef2-4b0e27c9df0d">
        <source>validateForSubItemDuplicates() : Boolean protected;
// ---------------------------------------------------------------------------
// Created:     24 July 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	subItem,
	subItem2	: CMIF_TIObject;
	numRows,
	idx1,
	idx2,
	type1,
	type2		: Integer;
	subItemError	: Boolean;

begin

	// Check that a duplicate sub-item has not been entered.
	
	numRows := self.allSubItems.size;
	
	foreach idx1 in 1 to numRows - 1 do
		subItem := self.allSubItems[idx1];
		if (not (subItem.isKindOf(CMIF_InOutCOU) or
		   subItem.isKindOf(CMIF_InOutAttachment))) then
		   	continue;
		endif;
		
		foreach idx2 in (idx1+1) to numRows do
			subItem2 := self.allSubItems[idx2];
			if (not (subItem2.isKindOf(CMIF_InOutCOU) or
			   subItem2.isKindOf(CMIF_InOutAttachment))) then
			   	continue;
			endif;

			if subItem &lt;&gt; subItem2 and	
			   subItem.getPropertyValue('id') = subItem2.getPropertyValue('id') then
			   	// id is the same so check the type
				if subItem.isKindOf(CMIF_InOutCOU) then
					type1 := TI_CargoType_COU;
				else
					type1 := subItem.getPropertyValue('cargoType').Integer;
				endif;
				if subItem2.isKindOf(CMIF_InOutCOU) then
					type2 := TI_CargoType_COU;
				else
					type2 := subItem2.getPropertyValue('cargoType').Integer;
				endif;
				if type1 = type2 then
					subItemError := true;
					app.raiseCMException2(AttachedSameItemMoreThanOnce, subItem.getPropertyValue('id').String, self.id, null, null);
				endif;
			endif;
		endforeach;
	endforeach;
	
	return subItemError;

end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validateForUpdate" id="186d7632-5679-4421-931e-65bb9dd380ff">
        <updating/>
        <source>validateForUpdate(_passport: CM_Passport input): Boolean updating;
// --------------------------------------------------------------------------------
// Created:		08 May 2009 by cnwdad1
//
// Purpose:		Standard validation method when receiver is updated.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 06/10/2025	navdap1		MTN-36141 AAT | RotaBox Creation (EDI/API/Manual)
// --------------------------------------------------------------------------------
begin
	self.validateCargoTypeContents();		// MTN-36141
	
	return inheritMethod(_passport);
	
	// cnwdad1 08/05/2009 - CCNS 1735.
	if app.isSubTerminalsOn(self.myTerminal) then
		if self.mySubTerminal = null
		and not self.myTerminal.getConfig(IsSubTerminalAreaDefined).Boolean	//28 Nov 2014	NDL	Par 35295
		then
		//	app.raiseCMException1(REQUIRED_FIELD, app.getString(SubTerminal_GC), ETRow_MySubTerminal, null);
			app.raiseCMException1(Input_required_field_Required, app.getString(SubTerminal_GC), ETRow_MySubTerminal, null); // cnwdb2	PAR 35364
		endif;
	endif;
end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validateISOType" id="2cc83046-05aa-4118-b884-21225a84dba1">
        <source>validateISOType();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
22 January 2009	cnwjk3	CCMS 1620
20/05/2010		cnwdad1	Whilst testing PAR #24275, found the iter wasn't being deleted.
*/

vars
	iter 	: Iterator;
	ti 		: CM_TrackedItem; 
	items 	: ObjectArray;
	isoType : String;
begin
	if self.cargoType = TI_CargoType_Container then
		if self.myTerminal.getConfig(GateInCheckISOTypes).Boolean then
			create items transient;
			iter := self.myTerminal.allOffsiteTIsByIdCargoType.createIterator();
			self.myTerminal.allOffsiteTIsByIdCargoType.startKeyGeq(self.id, self.cargoType, null, iter);
			while iter.next(ti) do
				if ti.id &lt;&gt; self.id then
					break;
				endif;
				items.add(ti);
			endwhile;
			if items.size() &gt; 0 and items[items.size()].isKindOf(CM_Container) then
				// Check the isoType of the last entry in the array, as this would be the last time that it visited the terminal
				if items[items.size()].CM_Container.isoType &lt;&gt; self.isoType then
					if  self.isoType = null then
						isoType := "UNSPECIFIED";
					else 
						isoType := self.isoType; 
					endif;
					app.raiseCMWarning4(ISO_Types_Differ, self.id, isoType, items[items.size()].CM_Container.isoType, null, null, null, null);
				endif;
			endif;
		endif;
	endif;
epilog
	delete iter;	// cnwdad1 20/05/2010 - PAR 24275.
	delete items;	
end;</source>
    </JadeMethod>
    <JadeMethod name="validatePackDetails" id="fe99ea3c-78b7-454e-bf35-7c7f7a4790ca">
        <updating/>
        <source>validatePackDetails() updating;
//Validate the details entered. Rules are:
//1: You must enter a valid date time if you also want to record the pack temps
//2: If either a date or a time is entered the other value must also be valid
//3: Only one pack temp is used, the other is converted from the first
vars

begin
	if packDate &lt;&gt; null or packTime &lt;&gt; null then
		if packDate.isValid = false or packTime.isValid = false then
			//return;
			app.raiseCMWarning2(ERR_INVALID_VALUE, "pack Date Time", packDate.String &amp; ", " &amp; packTime.String,"", null, self.myProxyTrackedItem);
		endif;
//		if packTempC &lt;&gt; null or packTempF &lt;&gt; null then
		if packTempC &lt;&gt; NULL_TEMPERATURE then
			if self.myProxyTrackedItem.myOperator.displayTempFahrenheit then
				packTempC := app.myRoot.convFahrenheitToCelsius(packTempF);			
			else
				packTempF := app.myRoot.convCelsiusToFahrenheit(packTempC);						
			endif;
		endif;
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="validatePlannedLocation" id="09186453-8c91-4a57-b6f5-813a5deee41e">
        <source>validatePlannedLocation(): CM_LocationsController;
//--------------------------------------------------------------
//Created: 19 February 2003 By: cnwgd1
//--------------------------------------------------------------
vars
	foundLC		: CM_LocationsController;
	foundHeight	: Integer;
begin
	if self.yardLocationTxt = null then
		app.raiseCMWarning1(WARN_INVALID_LOCN, '[blank]', null, null,self.myBookingRefItem);
		return null;
	endif;
	
	self.myTerminal.findLocationFromString(self.yardLocationTxt, false, foundLC, foundHeight);
	
	if foundLC = null then
		app.raiseCMWarning1(WARN_INVALID_LOCN, self.yardLocationTxt, null, null, null);
	endif;
	
	return foundLC;
end;</source>
        <ReturnType type="CM_LocationsController"/>
    </JadeMethod>
    <JadeMethod name="validateSubItems" id="7e326000-c752-47f9-a7d0-51704e0dc522">
        <source>validateSubItems(_passport : CM_Passport input) protected;
// ---------------------------------------------------------------------------
// Created:     24 July 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 24/02/2010	cnwdap1		PAR #21827 Allow for editing a tracked item with attachments
//								We may need to validateForUpdate rather than always validateForCreate
// 07/03/2012	cnwcs5		par 29158 - EDI Booking cutoff - fix exception
// ---------------------------------------------------------------------------
vars
	idx,
	numRows			: Integer;
	origChildren	: CM_TIArray;
	subItem			: CMIF_TIObject;
	matchFound,
	couFound		: Boolean;
	child, attachTI	: CM_TrackedItem;
	attach			: CMIF_TIObject;

begin
	create origChildren transient;

	if self.myProxyTrackedItem &lt;&gt; null then	// par 29158
		self.myProxyTrackedItem.allChildren.copy(origChildren);//cnwsh3 - PAR25103 - allChildren collection has been unprotected reversing the need for changes from PAR22954
	endif;					// par 29158

	// Check if Attachment sub-items have a proxy.  If not then try and match
	// to an existing child on proxy
	foreach subItem in self.allSubItems do
		// subitems will be either CMIF_InOutAttachment from old prenote or
		// CMIF_PreNote from new prenote  CCMS 1071
		attach := subItem;
		
		// Check to see if the attachment already has a proxy and that the
		// user has not changed the Id and/or type.
		attachTI := attach.getMyProxyTrackedItem();
		if attachTI &lt;&gt; null and attachTI.id = attach.getID and attachTI.cargoType = attach.getCargoType then
			if origChildren.includes(attachTI) then
			   origChildren.remove(attachTI);
			endif;
		   	continue;
		endif;
		
		
		// Search through proxy children to see if have one with the same id/type
		matchFound := false;
		numRows := origChildren.size;
		foreach idx in 1 to numRows do
			child := origChildren[idx];
			
			if child.id = attach.getID and
			   child.cargoType = attach.getCargoType then
			   	// A match has been found
			   	matchFound := true;
			   	if attachTI &lt;&gt; null then
			   		// found a match but for a different proxy so treat as a delete
			   		if (not self.myProxyTrackedItem.allChildren.includes(attachTI)) then//cnwsh3 - PAR25103 - allChildren collection has been unprotected reversing the need for changes from PAR22954
					//if (not proxy.hasChild(attachTI)) then //PAR 22954
			   			// attachment proxy is not in the list here to be erased so delete here.
			   			attachTI.erase(NORMAL_ERASE);
			   		endif;
			   	endif;
			   	
			   	// Attach this child to the attachment
			   	attach.setMyProxyTrackedItem(child);
			   	//origChildren.remove(attachTI);	// PAR #21827
			   	origChildren.remove(child);			// PAR #21827
			   	break;
			endif;
			
			if (not matchFound) and attachTI &lt;&gt; null then
			  	// User has updated id or type so delete proxy
		   		if (not self.myProxyTrackedItem.allChildren.includes(attachTI)) then //cnwsh3 - PAR25103 - allChildren collection has been unprotected reversing the need for changes from PAR22954
		   			// attachment proxy is not in the list here to be erased so delete here.
		   			attachTI.erase(NORMAL_ERASE);
			   	endif;
			   	attach.setMyProxyTrackedItem(null);
			endif;
		endforeach;
	endforeach;
	
	// delete any remaing proxies in origChildren
	while origChildren.size &gt; 0 do
		child := origChildren.last;
		self.myProxyTrackedItem.detachChild(child);
		origChildren.remove(child);
		child.erase(NORMAL_ERASE);
	endwhile;

	// Finally validate the sub-items

	foreach subItem in self.allSubItems do
		subItem.defaultDetailsFromParentItem(self);
		// PAR #21827 we could be updating a receival from a tracked item with children being edited in the prenote screen
		if subItem.isKindOf(CMIF_Receival) and subItem.CMIF_Receival.myOriginalProxyTI &lt;&gt; null then
			subItem.validateForUpdate(_passport);
		else
			subItem.validateForCreate(_passport);
		endif;
		if subItem.isKindOf(CMIF_InOutCOU) then
			if couFound then
				app.raiseCMException1(AttemptToAttachMoreThanOneCOU, self.id, null, null);
			else
				couFound := true;
			endif;
		endif;
	endforeach;
		
	if (not couFound)  and 
		self.myProxyTrackedItem.isKindOf(CM_Container) and // PAR 17703
		self.myProxyTrackedItem.CM_Container.getCou &lt;&gt; null then
		// new item has no COU so detach and delete proxy object
		child := self.myProxyTrackedItem.CM_Container.getCou;
		self.myProxyTrackedItem.detachCOU(_passport);
		child.erase(NORMAL_ERASE);
	endif;

epilog
	delete origChildren;
end;</source>
        <access>protected</access>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
</Class>
