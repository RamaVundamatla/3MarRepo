        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="70daa5ef-9e94-4bec-8df4-f8f5abb0d82b">
        <updating/>
        <source>setForUpdate(_proxyDeckItem: SelfType;_passport : CM_Passport input) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
11 April 2011	cnwer1	Initial creation CCMS 1031

*/

vars

begin
	inheritMethod(_proxyDeckItem,_passport);

	self.width := _proxyDeckItem.width;
	self.length := _proxyDeckItem.length;
	self.standardGap := _proxyDeckItem.standardGap;
	self.ordinal := _proxyDeckItem.ordinal;
	self.myDeckLayerLayout := self.myLayout.myDeckLayer;
epilog

end;</source>
        <Parameter name="_proxyDeckItem" type="SelfType"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setLengthFromLayout" id="d6738629-9e06-4fb1-9cc7-924aef82af6d">
        <updating/>
        <source>setLengthFromLayout(_points : PointArray) updating;
/*

Purpose:	 // TFS 39254		

Parameters:			

Return Value:		

Date		Who		Reason
31 July 2018	jlgab1	Initial creation

*/
 
vars

	x1, x2, y1 : Decimal[12,2];
begin
	// 10 pixels = 1 metre
	x1 := _points[1].x / ROROStructurePixelsPerMetre;
	x2 := _points[2].x / ROROStructurePixelsPerMetre;
	
	self.length := (x2 - x1);

	
	


epilog

end;</source>
        <Parameter name="_points" type="PointArray"/>
    </JadeMethod>
