    <JadeMethod name="cnwdad1_Test_CSV_File" id="da331587-8076-4487-8a70-82c10658b483">
        <updating/>
        <source>cnwdad1_Test_CSV_File() updating;
// --------------------------------------------------------------------------------
// Created:		30 August 2000 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	csvFileObj	: CnEcCsvFile;
	fileDefObj	: CnEcFileDefinition;
	recordObj	: CnEcFileRecord;
	fieldObj	: CnEcFileField;
	startTime	: Integer;

begin
	startTime			:=	app.clock();
	app.mousePointer	:=	Busy;
	create csvFileObj;
	csvFileObj.headerFieldNo		:=	1;
	csvFileObj.headerIdentifier	:=	"H";
	create fileDefObj transient;

//	fileDefObj.set("swans.csv", "c:\temp\swans.csv", "c:\temp\");
	fileDefObj.set("Another_test.csv", "c:\temp\Another_test.csv", "c:\temp\");
	csvFileObj.cnEcLoadCsvFile(fileDefObj, true, 10);

	if (csvFileObj.isCancelled) then
		write "The file load was cancelled.";
		return;
	endif;

	write "CSV File read in " &amp; ((app.clock - startTime) / 1000).String &amp; " seconds.";

	foreach recordObj in fileDefObj.allRecords do
//		foreach field in recordObj.allFields do
//			write recordObj.recordNo.String &amp; ": " &amp; field.fieldName &amp; "=" &amp; field.fieldValue;
//		endforeach;

		// Alternatively, we could simply get a string of all fields delimited by a
		// specified character.  In this case, a "|" is used as the delimiter.

		write recordObj.recordNo.String &amp; ": " &amp; recordObj.getDelimitedRecord("|");
	endforeach;
epilog
	delete csvFileObj;
	delete fileDefObj;		// This will also delete the collections of Records and Fields.
	app.mousePointer	:=	Idle;
	
	write "All done in " &amp; startTime.cnEcClockDifference().numberFormat() &amp; " seconds.";
end;</source>
    </JadeMethod>
    <JadeMethod name="cnwdad1_Test_CalendarEvent" id="ee6fe740-62ef-49c6-802f-5d22649f414b">
        <source>cnwdad1_Test_CalendarEvent() protected;
// --------------------------------------------------------------------------------
// Created:		22 May 2008 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	eventObj	: CnEcCalendarEvent;
	allEventsObj	: CnEcCalendarEventByDate;
	today		: Date;
	date		: Date;
	start		: Date;
	finish		: Date;
begin
	create allEventsObj transient;
	
	date	:=	today;
	create eventObj transient;
	eventObj.setEventDate(date);
	eventObj.setDisplayText("Event on " &amp; date.String);
	allEventsObj.add(eventObj);
	
	date	:=	today.cnEcAddWeeks(-12);
	create eventObj transient;
	eventObj.setEventDate(date);
	eventObj.setDisplayText("Event on " &amp; date.String);
	allEventsObj.add(eventObj);
	
	date	:=	today.cnEcAddWeeks(3);
	create eventObj transient;
	eventObj.setEventDate(date);
	eventObj.setDisplayText("Event on " &amp; date.String);
	allEventsObj.add(eventObj);
	
	date	:=	today.cnEcAddMonths(-6);
	create eventObj transient;
	eventObj.setEventDate(date);
	eventObj.setDisplayText("Event on " &amp; date.String);
	allEventsObj.add(eventObj);
	
	date	:=	today.cnEcAddMonths(5);
	create eventObj transient;
	eventObj.setEventDate(date);
	eventObj.setDisplayText("Event on " &amp; date.String);
	allEventsObj.add(eventObj);
	
	date	:=	today.cnEcAddYears(-1);
	create eventObj transient;
	eventObj.setEventDate(date);
	eventObj.setDisplayText("Event on " &amp; date.String);
//	eventObj.setRepeat(true, 1, CnEcCalendarEvent.REPEAT_YEAR, 0);
//	start.setDate(1, today.month, today.year);
//	finish.setDate(today.cnEcDaysInMonth(), today.month, today.year);
//	eventObj.isRepeatInRange(start, finish);
	allEventsObj.add(eventObj);
	
	date	:=	today.cnEcAddYears(1);
	create eventObj transient;
	eventObj.setEventDate(date);
	eventObj.setDisplayText("Event on " &amp; date.String);
	allEventsObj.add(eventObj);
	
	allEventsObj.inspectModal();
epilog
	allEventsObj.purge();
	delete allEventsObj;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="cnwdad1_Test_ClassTree" id="6f72ac94-efba-413d-92e9-e3898432ffdd">
