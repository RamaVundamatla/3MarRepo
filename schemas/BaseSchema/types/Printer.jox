<Class name="Printer">
    <JadeMethod name="cnEcPrintToFitPage" id="73c26a15-3392-4fcb-a6dc-5c82494628c7">
        <updating/>
        <source>cnEcPrintToFitPage(	pFrameObj:Frame input;
					pLabelObj:Label input;
					pTextWidth:Integer):Integer updating;
// --------------------------------------------------------------------------------
// Created:		04 November 2000 by cnwdad1
//
// Purpose:		Not all of the frame text to print will fit on the page, so we need
//				to print upto the amount of text that *will* fit on the page, and
//				keep doing so until all of the text is printed.
//
// Parameters:	pFrameObj (Frame)
//				pLabelObj (Label)
//				pTextWidth (Integer)
//
// Returns:		Integer - The result of the last print request.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	fullTextLength		: Integer;
	fullFrameText		: String;
	thisTokenIndex		: Integer;
	lastTokenIndex		: Integer;
	textToken			: String;
	tentativeFrameText	: String;
	currentFrameText	: String;
	printResult			: Integer;

begin
	fullFrameText	:=	pLabelObj.caption;
	fullTextLength	:=	fullFrameText.length;
	thisTokenIndex	:=	1;
	lastTokenIndex	:=	1;

	while thisTokenIndex &lt; fullTextLength do
		// We can't use the value returned by the "String::getNextToken" method
		// because it doesn't include the token character, which we do need to
		// print.  Instead we'll get the substring ourselves.
		fullFrameText.getNextToken(thisTokenIndex);

		if thisTokenIndex &gt; fullTextLength then
			textToken	:=	fullFrameText[lastTokenIndex:end];
		else
			textToken	:=	fullFrameText[lastTokenIndex:(thisTokenIndex - lastTokenIndex)];
		endif;

		if tentativeFrameText = null then
			tentativeFrameText	:=	textToken;
		else
			tentativeFrameText	:=	tentativeFrameText &amp; textToken;
		endif;

		pLabelObj.caption	:=	tentativeFrameText;
		pLabelObj.width		:=	pTextWidth;
		pFrameObj.height	:=	pLabelObj.height;

		if self.frameFits(pFrameObj) then
			currentFrameText	:=	tentativeFrameText;
		else
			pLabelObj.caption	:=	currentFrameText.trimBlanks;
			pLabelObj.width		:=	pTextWidth;
			pFrameObj.height	:=	pLabelObj.height;
			printResult			:=	self.print(pFrameObj);		// Print the current page.

			if printResult = Print_Successful then
				printResult			:=	self.newPage;			// This page is full, so start a new one (we cannot rely upon Windows to automatically work this out for us correctly).
				currentFrameText	:=	textToken;				// Set to start a new page.
				tentativeFrameText	:=	textToken;				// Set to start a new page.
			endif;
		endif;

		lastTokenIndex	:=	thisTokenIndex;

		if printResult &lt;&gt; Print_Successful then
			break;
		endif;
	endwhile;

	// If there's any residual text left to print, then print it.

	if currentFrameText &lt;&gt; null then
		pLabelObj.caption	:=	currentFrameText;
		pLabelObj.width		:=	pTextWidth;
		pFrameObj.height	:=	pLabelObj.height;
		printResult			:=	self.print(pFrameObj);					// Print the current page.
	endif;
epilog
	return printResult;
end;</source>
        <Parameter name="pFrameObj" type="Frame" usage="input"/>
        <Parameter name="pLabelObj" type="Label" usage="input"/>
        <Parameter name="pTextWidth" type="Integer"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="cnEcTranslateConstant" id="9c487a85-308a-4b41-a8cb-fb89e87200b1">
        <source>cnEcTranslateConstant(pValue:Integer):String;
// --------------------------------------------------------------------------------
// Created:		01 February 2000	By:	cnwdad1
//
// Purpose:		Translates a Printer global constant into the appropriate message.
//
// Parameters:	The Printer constant for which string is to be returned.
//
// Returns:		The translated message.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
// A Translatable String has been defined in the BaseSchema for each Printer Global
// Constant that is returned by one of the Print instructions.
//
// This method will find that Printer constant by matching the requested value (the
// pValue parameter of this method) against each of the values of the Global
// Constants for the "Printer" category.  If a constant is found, then the
// Translatable String will be located (within the current Locale) by searching for
// one with a name of:
//
//		"CNEC_"+&lt;global constant name&gt;
//
// ... for example; the value of "0" is defined by the Printer Global Constant
// called "Print_Successful", therefore we'd look for a Translatable String in the
// current Locale called:
//
//		"CNEC_PRINT_SUCCESSFUL"
//
// If the Translatable String is found, then the value of that string is returned,
// otherwise the value of another Translatable String will be returned stating
// that a string couldn't be found for the requested Printer return value.
//
vars
	constantColl		: ConstantNDict;
	constantObj			: Constant;
	translatableValue	: String;

begin
	global.cnEcGetConstants("Printer", constantColl);

	if constantColl.cnEcIsNotEmpty() then
		foreach constantObj in constantColl do
			if constantObj.valueAsInteger = pValue then
				translatableValue	:=	app.currentLocale.getStringValue("CNEC_" &amp; constantObj.name.toUpper[1:25].trimBlanks);
				break;
			endif;
		endforeach;
	endif;

	if translatableValue = null then
		return $CNEC_PRINT_UNKNOWN_VALUE(pValue.String);
	else
		return translatableValue;
	endif;
end;</source>
        <Parameter name="pValue" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
</Class>
