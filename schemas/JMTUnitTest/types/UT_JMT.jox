    <JadeMethod name="checkNotUseAssertMsg" id="84b8863f-3241-4ee8-bd2e-8edc8f732565">
        <source>checkNotUseAssertMsg(_mth : Method; _sourceNotOK : HugeStringArray io; _assertMthNoMsg : MethodSet input);
/*

Purpose:			This method goes through all classes, all methods in UT_DSL and check for unit tests that are not using assertMsg methods.

Parameters:			

Return Value:		

Date		Who		Reason
01 July 2025	navkc1	Initial Creation JIRA 34205 MTN - Unit Test to find Unit Tests that are not using AssertMsg methods - Phase1

*/

vars
	tokens			: HugeStringArray;
	
	methodSource	: String;
	tokensSize		: Integer;
	token			: String;
	tokenPos		: Integer;
	assertMthName	: String;
	assertMsgMthName: String;
	mth				: Method;
begin
	if _mth = null then
		return;
	endif;
	
	methodSource := self.removeCommentsFromSource(_mth.getSource());
	methodSource.replaceChar(Cr, " ");
	methodSource.replaceChar(Lf, " ");
	
	delete tokens;
	tokens := methodSource.getHugeTokens();
	tokensSize := tokens.size();
	
	foreach tokenPos in 1 to tokensSize do
		token := tokens[tokenPos];
		
		foreach mth in _assertMthNoMsg do
			assertMthName := mth.name;
			assertMsgMthName := assertMthName &amp; "Msg";
			
			// Check whether we have assert Method, eg assertTrue/assertTrueMsg
			if token.cnContains(assertMthName) then
				// Check whether it's assertTrueMsg
				if not token.cnContains(assertMsgMthName) then
					// It's not, flag as error
					_sourceNotOK.add("Method: " &amp; _mth.schemaType.name &amp; "::" &amp; _mth.name);
					// This method is flagged as error, can return now
					return;
				endif;
			endif;
		endforeach;
	endforeach;
	
epilog
	delete tokens;
end;</source>
        <Parameter name="_mth" type="Method"/>
        <Parameter name="_sourceNotOK" type="HugeStringArray" usage="io"/>
        <Parameter name="_assertMthNoMsg" type="MethodSet" usage="input"/>
    </JadeMethod>
    <JadeMethod name="check_SetConfAndTerminalConf" id="00447d86-7c53-4f3b-9d93-63389d1ac353">
        <source>check_SetConfAndTerminalConf(_method : Method; _sourceNotOK : HugeStringArray io);

/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 Aug 2025	navhn30	MTN-34211: MTN - Unit Test to check for use of setConfig vs setTerminalConfig - Phase2
*/

vars

	tokens			: HugeStringArray;

	methodSource	: String;
	configMatches, 
	terminalConfigMatches	: JadeRegexResult;
	
begin

	// method null then nothing to do
	if _method = null then
		return;
	endif;
	
	// get the source
	methodSource := self.removeCommentsFromSource(_method.getSource());
	methodSource.replaceChar(Cr, " ");
	methodSource.replaceChar(Lf, " ");
	
	create configMatches transient;
	create terminalConfigMatches transient;

	JadeRegex@findAll(methodSource,"setConfig",false,true,configMatches);
	JadeRegex@findAll(methodSource,"setTerminalConfig",false,true,terminalConfigMatches);

	if not (configMatches.numMatches=0 and terminalConfigMatches.numMatches=0) then
		_sourceNotOK.add(CrLf &amp; _method.schemaType.name &amp; "::" &amp; _method.name &amp; CrLf &amp;
							configMatches.numMatches.String &amp;' calls to setConfig'  &amp; CrLf&amp;
							terminalConfigMatches.numMatches.String &amp; ' calls to setTerminalConfig ' &amp;  CrLf);
	endif;
	
epilog
	
	delete tokens;
	delete terminalConfigMatches;
	delete configMatches;
	
end;</source>
        <Parameter name="_method" type="Method"/>
        <Parameter name="_sourceNotOK" type="HugeStringArray" usage="io"/>
    </JadeMethod>
    <JadeMethod name="check_pxyCreateUpdateProxyCode" id="b62c159f-1fe8-45da-a7cb-5cbda266a224">
        <source>check_pxyCreateUpdateProxyCode(_method : Method; _sourceNotOK : HugeStringArray io);

/*

Purpose:			Checks the methods source to see comforms to having completedOK and epilog stuff
					I'm making the assumption that if the epilog has the delete of the attribute then
					it's using something along of
					
						completedOK := true;
						return proxy;
					epilog
						if completedOK then
							delete proxy;
						endif;				
						
					if it doesn't then it will be flagged as in error.

Parameters:			_method - Method 
					_sourceNotOK - Huge String Array for error details

Date		Who		Reason
20 April 2011	cnwmh5	Initial creation #27401

*/

vars

	tokens			: HugeStringArray;

	methodSource	: String;
	tokensSize		: Integer;
	token			: String;
	inEpilog		: Boolean;
	deleteOK		: Boolean;
	returnAttribOK	: Boolean;
	returnInherit	: Boolean;
	tokenPos		: Integer;
	attrib 			: String;
	isOK			: Boolean;
	
begin

	// method null then nothing to do
	if _method = null then
		return;
	endif;
	
	// get the source
	methodSource := self.removeCommentsFromSource(_method.getSource());
	methodSource.replaceChar(Cr, " ");
	methodSource.replaceChar(Lf, " ");

	// Break method source into tokens
	delete tokens;
	tokens := methodSource.getHugeTokens;
	tokensSize := tokens.size;
	
	inEpilog := false;
	returnAttribOK := false;
	deleteOK := false;
	returnInherit := false;

	foreach tokenPos in 1 to tokensSize do
	
		token := tokens[tokenPos];
		
		if attrib = null and (token.cnContains('inheritMethod') or token.cnContains("cloneSelf")) then
			if tokens[tokenPos-1] = 'return' then
				returnAttribOK := true;
				deleteOK := true;
				returnInherit := true;
				attrib := tokens[tokenPos-1];
			else
				attrib := tokens[tokenPos-2];
			endif;
		elseif token = 'return' then
			if tokens[tokenPos+1] = attrib and tokens[tokenPos+2] = 'epilog' then
				returnAttribOK := true;
			endif;
		elseif token = 'delete' then
			if inEpilog and tokens[tokenPos+1] = attrib then
				deleteOK := true;
			endif;
		elseif token = "epilog" then
			inEpilog := true;
		endif;
		
	endforeach;
	
	// set is ok
	isOK := returnAttribOK and deleteOK and (inEpilog or returnInherit);
	
	// if not ok then return details of what's not ok
	if not isOK then
		_sourceNotOK.add('class: ' &amp; _method.schemaType.name &amp; CrLf &amp; 
			'attribute: ' &amp; attrib &amp; CrLf &amp;
			'returnAttributeOK: ' &amp; returnAttribOK.String &amp; CrLf &amp;
			'deleteOK: ' &amp; deleteOK.String &amp; CrLf &amp;
			'returns inheritMethod: ' &amp; returnInherit.String &amp; CrLf &amp;
			'has epilog: ' &amp; inEpilog.String &amp; CrLf &amp;
			'isOK: ' &amp; isOK.String &amp; CrLf &amp; CrLf);
	endif;
	
epilog
	
	delete tokens;
	
end;</source>
        <Parameter name="_method" type="Method"/>
        <Parameter name="_sourceNotOK" type="HugeStringArray" usage="io"/>
    </JadeMethod>
    <JadeMethod name="getAssertMethodsNoMsg" id="97ed6f80-616b-4785-98a4-3890667cf9fd">
        <source>getAssertMethodsNoMsg(_assertMthNoMsg : MethodSet io);
/*

Purpose:			This method returns a list of "assert" method that does not have Msg.
					For Example
						assertTrue
						assertTrueMsg
						
						assertDelete
						'there is not assertDeleteMsg'
						
					add 'assertTrue' to the return list

Parameters:			

Return Value:		

Date		Who		Reason
01 July 2025	navkc1	Initial Creation JIRA 34205 MTN - Unit Test to find Unit Tests that are not using AssertMsg methods - Phase1

*/
constants
	UTUnitTest		= "UT_UnitTest";
	JMTUNITTEST 	= "JMTUnitTest";
vars
	scm					: Schema;
	utCls				: Class;
	mth,
	mth2				: Method;
	methods				: MethodSet;
	assertMsgMthName	: String;

begin
	// Get JMTUnitTest Schema
	scm := rootSchema.getSchema(JMTUNITTEST);
	self.assertNotNullMsg(scm, "Failed to get '" &amp; JMTUNITTEST &amp; "' schema");
	
	// Get UT_UnitTest class
	utCls := scm.getClass(UTUnitTest);
	self.assertNotNullMsg(utCls, "Failed to get '" &amp; UTUnitTest &amp; "' class");
	
	create methods transient;
	
	// Get all methods in the class
	utCls.allMethods(methods);
	
	// Get the assert methods
	foreach mth in methods do
		
		if mth.name[1:6] &lt;&gt; "assert" then
			continue;
		endif;
		
		assertMsgMthName := mth.name &amp; "Msg";
		
		foreach mth2 in methods do
			if mth2.name.toLower() = assertMsgMthName.toLower() then
				_assertMthNoMsg.add(mth);
				break;
			endif;
		endforeach;
	endforeach;
	
epilog
	delete methods;
end;</source>
        <Parameter name="_assertMthNoMsg" type="MethodSet" usage="io"/>
    </JadeMethod>
    <JadeMethod name="getProxyRefsCodedFor" id="82ceece4-3ac9-4879-8ae0-040ba6e7f110">
        <source>getProxyRefsCodedFor(_method : Method; _proxyRefsCodedFor : StringArray io);

/*

Purpose:			Return all the references that are used in the method
					
Parameters:			_method - Method 
					_proxyRefsCodedFor - String Array of references coded for

Date		Who		Reason
28/04/2011	cnwmh5	Initial creation 

*/

vars

	tokens			: HugeStringArray;

	methodSource	: String;
	tokensSize		: Integer;
	token,
	tokenPlus1,
	arrayToken		: String;
	inEpilog		: Boolean;
	deleteOK		: Boolean;
	returnAttribOK	: Boolean;
	returnInherit	: Boolean;
	tokenPos		: Integer;
	attrib 			: String;
	isOK			: Boolean;
	pos				: Integer;
	
begin

	// method null then nothing to do
	if _method = null then
		return;
	endif;
	
	_proxyRefsCodedFor.clear();
	
	// get the source
	methodSource := self.removeCommentsFromSource(_method.getSource());
	methodSource.replaceChar(Cr, " ");
	methodSource.replaceChar(Lf, " ");

	// Break method source into tokens
	delete tokens;
	tokens := methodSource.getHugeTokens;
	tokensSize := tokens.size;
	
	inEpilog := false;

	foreach tokenPos in 1 to tokensSize do
	
		token := tokens[tokenPos];
		
		if attrib = null and (token.cnContains('inheritMethod') or token.cnContains("cloneSelf")) then
			if tokens[tokenPos-1] = 'return' then
				// don't care nothing to check so return
				return;
			else
				attrib := tokens[tokenPos-2];
			endif;
		else
			if token.cnContains(attrib) then
				pos := token.pos('.', 1);
				if pos &gt; 0 then
					_proxyRefsCodedFor.add(token[pos+1:end]);
				endif;
			endif;	
		endif;
		
	endforeach;

epilog
	
	delete tokens;
	
end;</source>
        <Parameter name="_method" type="Method"/>
        <Parameter name="_proxyRefsCodedFor" type="StringArray" usage="io"/>
    </JadeMethod>
    <JadeMethod name="iCheckTIsGettingDeleted" id="47574cfe-8c8a-4833-901b-ccba009cf3ae">
        <source>iCheckTIsGettingDeleted();

/*

Purpose:		Check that all the TI's created by the unit tests get created. 
				e.g. ti's creation date &gt;= today - week

Date			Who		Reason
28/08/2012 		cnwmh5	Initial creation
06/01/2015		cnwmh5	Rewrite

*/

vars
	
	ti							: CM_TrackedItem;
	terminal					: CM_Terminal;
	schema						: Schema;
	klass						: Class;
	
	tiSet						: CM_TISet;
	
	mergeIter					: MergeIterator;
	iter						: Iterator;
	
	classes						: ClassColl;
	
	voyagesToIgnore				: StringArray;
	containersToIgnore			: StringArray;
		
	dateToCheck					: Date;
	outputStr					: String;
	count 						: Integer;
	extraDataValue				: String;
	ignoreVoyagesToIgnore		: Boolean;
	ignoreContainersToIgnore	: Boolean;
	voyageCode					: String;
	invalidObject				: Boolean;
	
begin
	
	on Exception do app.handleDeletedObject(exception, ti, invalidObject);
	on Exception do app.handleDeletedObject(exception, ti.myTerminal, invalidObject);
	
	schema := rootSchema.getSchema("PortSchema");
	self.assertNotNull(schema);
	
	klass := schema.getClass("CM_TrackedItem");
	self.assertNotNull(klass);
	
	create classes transient;
	klass.allLocalSubclasses(classes);
	classes.add(klass);
	
	// get all tracked items
	create tiSet transient;
	foreach klass in classes do
		write 'klass: ' &amp; klass.String &amp; Tab &amp; klass.name &amp; Tab &amp; klass.instances.size.String;
		count := count + klass.instances.size;
		klass.instances.copyNoDups(tiSet);
	endforeach;
	
	write 'count: ' &amp; count.String &amp; Tab &amp; tiSet.size.String;
	////tiSet.removeInvalidObjects();
	
	terminal := self.getTerminal();
	
	dateToCheck := dateToCheck.addDays(-30);
	
	count := 0;
	iter := tiSet.createIterator;
	while iter.next(ti) do
		invalidObject := false;
		if not global.isValidObject(ti) or ti.myTerminal = null or ti.myTerminal.code &lt;&gt; terminal.code then
			continue;
		endif;
		if not invalidObject then
			write ti.String &amp; Tab &amp; ti.id &amp; Tab &amp; ti.myTerminal.code &amp; Tab &amp; ti.creationTime.date.format("dd/MM/yyyy") &amp; Tab &amp; 
				ti.creationTime.time.String &amp; Tab &amp; global.isValidObject(ti).String &amp; Tab &amp; (ti.myTerminal = null).String &amp; Tab &amp; 
				ti.myTerminal.code &amp; Tab &amp; terminal.code &amp; Tab &amp; ti.voyageCode;
			count := count + 1;
		endif;
	endwhile;
	
	write 'final count: ' &amp; count.String;
	
	
epilog
	
	delete mergeIter;
	delete tiSet;
	delete voyagesToIgnore;
	delete containersToIgnore;
	delete classes;
	delete iter;
	
end;

/*
vars
	
	ti							: CM_TrackedItem;
	terminal					: CM_Terminal;
	
	tiSet							: CM_tiSetet;
	
	mergeIter					: MergeIterator;
	
	voyagesToIgnore				: StringArray;
	containersToIgnore			: StringArray;
		
	dateToCheck					: Date;
	outputStr					: String;
	count 						: Integer;
	extraDataValue				: String;
	ignoreVoyagesToIgnore		: Boolean;
	ignoreContainersToIgnore	: Boolean;
	voyageCode					: String;
	
begin
	
	terminal := self.getTerminal();
	
	dateToCheck := dateToCheck.addDays(-30);
	
	create tiSet transient;

	ignoreVoyagesToIgnore := false;
	ignoreContainersToIgnore := false;
	
	// ignore the following voyages as they are part of a u unit test
	create voyagesToIgnore transient;
	voyagesToIgnore.add("VCCMS1096");						// UT_HMS_Voyage::uVoyageDetailsDiscrepancies
	voyagesToIgnore.add("UTKPVOY01");						// UT_TrackedItem::uCreateDataForKPICount
	voyagesToIgnore.add("UTDIAM1");							// UT_ROROVessel::uCreatePlannedDIAMVoyage
	
	// ignore the following containers
	create containersToIgnore transient;
	containersToIgnore.add("RJD99010102");
	containersToIgnore.add("RJD01010101");
	
	// get the ti's that aren't on a ship
	create mergeIter transient;
	mergeIter.addCollection(terminal.allNotifiedtiSetByCargoTypeId);
	mergeIter.addCollection(terminal.allOffsitetiSetByCargoTypeId);
	mergeIter.addCollection(terminal.allOnsitetiSetByCargoTypeId);
		
	while mergeIter.next(ti) do
	
		// check to see if container to ignore
		if not ignoreContainersToIgnore and containersToIgnore.includes(ti.id) then
			continue;
		endif;
	
		// get the voyage code
		voyageCode := null;
		if ti.myVoyage &lt;&gt; null then
			voyageCode := ti.myVoyage.code;
		endif;
	
		// checking voyage so do
		if voyageCode &lt;&gt; null and not ignoreVoyagesToIgnore and voyagesToIgnore.includes(voyageCode) then
			continue;
		endif;
	
		if ti.creationTime.date &gt;= dateToCheck then
			continue;
		endif;
		tiSet.add(ti);
	endwhile;
	
	foreach ti in tiSet do
		if outputStr = null then
			outputStr := "The following ti's were created before " &amp; dateToCheck.String &amp; " and aren't deleted: " &amp; CrLf;
		endif;
		global.getExtraData(ti.allExtraData, "createdByUnitTest", extraDataValue);
		outputStr := outputStr &amp; ti.String &amp; Tab &amp; ti.id &amp; Tab &amp; ti.creationTime.date.format("dd/MM/yyyy") &amp; Tab &amp; 
			'value: ' &amp; extraDataValue &amp; CrLf;
		count := count + 1;
	endforeach;
	
	if outputStr &lt;&gt; null then
		outputStr := outputStr &amp; "Count: " &amp; count.String;
		app.writeLog(outputStr, LogAlways);
	endif;
	self.assertNull(outputStr);
	
epilog
	delete mergeIter;
	delete tiSet;
	delete voyagesToIgnore;
	delete containersToIgnore;
end;
*/</source>
    </JadeMethod>
    <JadeMethod name="iClearBGPRequests" id="eed5ad5d-9534-494d-8600-006f24c62aa6">
        <source>iClearBGPRequests();

/*

Purpose:		Clear all BGP Requests, leaving report requests (report template used in invoicing test)

Date			Who		Reason
29/03/2012		cnwmh5	Initial creation

*/

vars

	schema							: Schema;
	klass							: Class;
	obj								: Object;
	
	subClasses						: ClassColl;

begin

	// get the schema
	schema := rootSchema.getSchema("PortSchema");
	self.assertNotNullMsg(schema, "Schema PortSchema not found");

	// get the class
	klass := schema.getClass("BGP_Request");
	self.assertNotNullMsg(klass, "Class BGP_Request not found");
	
	// get all the subclasses for the class
	create subClasses transient;
	klass.allLocalSubclasses(subClasses);
	
	foreach klass in subClasses do
		foreach obj in klass.instances do
			if obj.isKindOf(BGP_ReportRequest) then
				continue;
			endif;
			app.myTrxDA.trxDeleteBGPRequest(null, obj.BGP_Request, false, app.myPassport);
			self.assertNoTrxErrorsOrWarnings();
		endforeach;
	endforeach;
	
epilog
	delete subClasses;
end;</source>
    </JadeMethod>
    <JadeMethod name="tAusCustomsAuthorityNumCheck" id="41bb0093-2d2c-43b1-8902-72ab5fe48a3e">
        <source>tAusCustomsAuthorityNumCheck();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 September 2016	cnwndl1	Initial creation	TFS 2695	/ 2714

*/

vars

	str : String;
	debugReason : String;
	retVal : Boolean;
	
	validValues : StringArray;
	invalidValues : StringArray;

	taType : CM_TerminalAreaType;
	bs1 : CM_BlockStack;
	oper : CM_Operator;
	ti1 : CM_TrackedItem;
	ti2 : CM_TrackedItem;
	lc : CM_LocationsController;

begin

	create validValues transient;
	create invalidValues transient;

	//Try the valid 'Exception' values
	validValues.add("EXCC");
	validValues.add("EXDC");
	validValues.add("EXDD");
	validValues.add("EXLV");
	validValues.add("EXML");
	validValues.add("EXPE");
	validValues.add("EXSP");
	validValues.add("EXTI");
	
	//Try the valid 'example' values that were provided.
	validValues.add("CY46W3XAH");
	validValues.add("A76GG9FEG");
	
	//set up some invalid values
	invalidValues.add("BY46W3XAH");	//incorrect value in pos 1
	invalidValues.add("CD46W3XAH");	//incorrect value in pos 2
	invalidValues.add("CYI6W3XAH");	//incorrect value in pos 3
	invalidValues.add("CY4OW3XAH");	//incorrect value in pos 4
	invalidValues.add("CY46Q3XAH");	//incorrect value in pos 5
	invalidValues.add("CY46WSXAH");	//incorrect value in pos 6
	invalidValues.add("CY46W35AH");	//incorrect value in pos 7
	invalidValues.add("CY46W3X8H");	//incorrect value in pos 8
	invalidValues.add("CY46W3XA0");	//incorrect value in pos 9
	invalidValues.add("CY46W3XA");	//too short
	invalidValues.add("CY46W3XAHH");	//too long
	invalidValues.add("CY46W3XAR");	//Incorrect check digit
	
	
	foreach str in validValues do
		retVal := app.validateAustCAN( str, debugReason );
		self.assertTrueMsg( retVal, "Australian CAN validation for " &amp; str &amp; " should have returned true.");
	endforeach;
	
	foreach str in invalidValues do
		retVal := app.validateAustCAN( str, debugReason );
		self.assertTrueMsg( not retVal, "Australian CAN validation for " &amp; str &amp; " should have returned false.");
	endforeach; 
	
	taType := app.myRoot.allTerminalAreaTypes.getAtKey(1); // Block Stack
	bs1 := self.getTerminal.allTerminalAreasByTypeId.getAtKey( taType.type, "UT_BS1").CM_BlockStack;
	if bs1 = null then
		bs1 := addBlockStack("UTBS1", 1, null);
	endif;
	oper := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);
	lc := bs1.allLocationsControllers.first;
	
	self.deleteContainer("AATC0000001");
	self.deleteContainer("AATC0000002");
	
	ti1 := self.addContainerOpts( "AATC0000001", "2200", "APPL", oper );
	self.assertTrueMsg(ti1 &lt;&gt; null, "Failed to create cargo. - AATC0000001");
	
	self.move(ti1, lc);
	self.assertTrueMsg(ti1.myPrimaryActualLocation = lc, "Failed to move cargo. - AATC0000001");
	
	self.opts.purge();
	self.opts.addAssoc("Mark", "XXX");
	self.opts.addAssoc("TotalWeight", 5000);
	self.opts.addAssoc("IMEXStatus", TI_IMEX_STATUS_EXPORT);
	
	self.updateTI(ti1);
	self.assertTrueMsg(ti1.mark = "XXX", "Failed to update cargo. - AATC0000001");
	
	//turn on the validation.
	self.setTerminalConfig( ValidateAustCAN, true );
	
	self.opts.purge();
	self.opts.addAssoc("Mark", "YYY");
	self.opts.addAssoc("DontDoAssert", true);
	
	self.updateTI(ti1);
	self.assertTrueMsg(ti1.mark = "XXX", "Update should have failed, becuase no Customs Export Entry Number supplied. - AATC0000001");
	self.assertTrueMsg(app.myPassport.allErrors.includesErrorCode(Austr_custo_autho_numbe_does_n), "Update should have failed, no Customs Export Entry Number supplied. - AATC0000001");
	
	self.opts.purge();
	self.opts.addAssoc("Mark", "YYY");
	self.opts.addAssoc("IMEXStatus", TI_IMEX_STATUS_STORAGE);
	
	self.updateTI(ti1);
	self.assertTrueMsg(ti1.mark = "YYY", "Update should have worked, becuase storage items do NOT require Customs Export Entry Number supplied. - AATC0000001");
	
	self.opts.purge();
	self.opts.addAssoc("Mark", "ZZZ");
	self.opts.addAssoc("IMEXStatus", TI_IMEX_STATUS_EXPORT);
	self.opts.addAssoc("CustomsExportEntryNumber", "CY46W3XAH");
	
	self.updateTI(ti1);
	self.assertTrueMsg(ti1.mark = "ZZZ", "Update should have worked Export with valid Cust Exp Entry Num. - AATC0000001");
	
	self.opts.purge();
	self.opts.addAssoc("DontDoAssert", true);
	ti2 := self.addContainerOpts( "AATC0000002", "2200", "APPL", oper );
	self.assertTrueMsg(ti2 = null, "Create should have failed, becuase no Customs Export Entry Number supplied. - AATC0000002");
	self.assertTrueMsg(app.myPassport.allErrors.includesErrorCode(Austr_custo_autho_numbe_does_n), "Create should have failed, no Customs Export Entry Number supplied. - AATC0000002");
	
	self.opts.purge();
	self.opts.addAssoc("DontDoAssert", true);
	self.opts.addAssoc("CustomsExportEntryNumber", "CY46W3BOB");
	ti2 := self.addContainerOpts( "AATC0000002", "2200", "APPL", oper );
	self.assertTrueMsg(ti2 = null, "Create should have failed, becuase no Customs Export Entry Number supplied. - AATC0000002");
	self.assertTrueMsg(app.myPassport.allErrors.includesErrorCode(Austr_custo_autho_numbe_does_n), "Create should have failed, invalid Customs Export Entry Number supplied. - AATC0000002");
	
	self.opts.purge();
	self.opts.addAssoc(UTTI_IMEX, TI_IMEX_STATUS_STORAGE);
	ti2 := self.addContainerOpts( "AATC0000002", "2200", "APPL", oper );
	self.assertTrueMsg(ti2 &lt;&gt; null, "Create should have worked, becuase no Customs Export Entry Number required for storage. - AATC0000002");
	
epilog

	self.setTerminalConfig(ValidateAustCAN,false);

	delete validValues;
	delete invalidValues;

end;</source>
    </JadeMethod>
    <JadeMethod name="tBtreeCopyNoDups" id="63ef41a3-8d95-45f9-85b9-a1fda3ecebdd">
        <updating/>
        <source>tBtreeCopyNoDups() updating;
// jlgmd1
// cnwkpd1
/*

Purpose:			Test the Btree::copyNoDuplcates method

Parameters:			None

Return Value:		None


Date		Who		Reason
19 Aug 2010	cnwkpd1	PAR #25506 - Upgrade issue for DCT 

*/

vars
	sourceSet,
	targetSet		: ObjectSet;
	sourceDict,
	targetDict		: CM_CargoCheckDict;
	cc				: CM_CargoCheck;
	checks			: ObjectArray;
	i				: Integer;
	
begin
	create checks transient;
	
	foreach i in 1 to 5 do
		create cc transient;
		cc.setProxy(i, false, null, app.myPassport);
		checks.add(cc);
		
		create cc transient;
		cc.setProxy(i, false, null, app.myPassport);
		checks.add(cc);
	endforeach;
	
	create sourceSet transient;
	create targetSet transient;
	create sourceDict transient;
	create targetDict transient;
	
//Test 1. Nothing to copy
	sourceSet.copyNoDuplicates(targetSet,false);
	self.assertEqual(targetSet.size, 0);

//Test 2. Duplicates in sourceSet, targetDict contains no data
	sourceSet.clear();
	targetDict.clear();
	
	checks.copy(sourceSet);
	sourceSet.copyNoDuplicates(targetDict, false);
	self.assertEqual(targetDict.size, 5);

//Test 2a. Duplicates in sourceSet, targetDict contains no data, raise exception
	sourceSet.clear();
	targetDict.clear();
	checks.copy(sourceSet);
	
	on Exception do self.exHandlerAssertException(exception);
	sourceSet.copyNoDuplicates(targetDict, true);
	on Exception do null;
	self.assertExceptionRaised(VB_DUPLICATED_ITEM, null);
	self.assertEqual(targetDict.size, 1);
	
//Test 3. Duplicates in sourceSet, targetDict contains 1 item
	sourceSet.copyNoDuplicates(targetDict, false);
	self.assertEqual(targetDict.size, 5);
	
//Test 3a. Duplicates in sourceSet, targetDict contains 5 items, raise exception
	on Exception do self.exHandlerAssertException(exception);
	sourceSet.copyNoDuplicates(targetDict, true);
	on Exception do null;
	self.assertExceptionRaised(VB_DUPLICATED_ITEM, null);
	self.assertEqual(targetDict.size, 5);
	
//Test 4. No duplicates in sourceDict, targetSet contains the same data
	targetDict.copy(sourceDict);
	targetDict.copy(targetSet);
	sourceDict.copyNoDuplicates(targetSet, false);
	self.assertEqual(targetSet.size, 5);
	
//Test 5. No duplicates in sourceDict, targetSet no data
	targetSet.clear();
	sourceDict.copyNoDuplicates(targetSet, false);
	self.assertEqual(targetSet.size, 5);
	
//Test 6. No duplicates in sourceDict, targetDict contains same data
	targetDict.clear();
	sourceDict.copy(targetDict);
	sourceDict.copyNoDuplicates(targetDict, false);
	self.assertEqual(targetDict.size, 5);
	
//Test 7. Duplicates in sourceSet, targetDict one item
	sourceSet.clear();
	checks.copy(sourceSet);
	targetDict.clear();
	targetDict.add(checks[1].CM_CargoCheck);
	sourceDict.copyNoDuplicates(targetDict, false);
	self.assertEqual(targetDict.size, 5);
	
//Test 7a. Duplicates in sourceSet, targetDict one item, raise exception
	sourceSet.clear();
	checks.copy(sourceSet);
	targetDict.clear();
	targetDict.add(checks[1].CM_CargoCheck);
	
	on Exception do self.exHandlerAssertException(exception);
	sourceDict.copyNoDuplicates(targetDict, true);
	on Exception do null;
	self.assertExceptionRaised(VB_DUPLICATED_ITEM, null);
	self.assertEqual(targetDict.size, 1);
epilog
	delete sourceSet;
	delete targetSet;
	delete sourceDict;
	delete targetDict;
	checks.purge;
	delete checks;
end;</source>
    </JadeMethod>
    <JadeMethod name="tCMStringsFunctions" id="ab2eefc1-9f66-4673-932b-6a35c8fd1ee9">
        <source>tCMStringsFunctions();
// jlgmd1
// cnwkpd1

/*

Purpose:			Check functionality of CM_Strings

Parameters:			None

Return Value:		None


Date		Who		Reason
03 Jul 2015	cnwkpd1	PAR #36286 - Changes for Unicode JADE

*/

vars
	strings			: CM_Strings;
	arr,
	arr2			: HugeStringArray;
	i				: Integer;
	
begin
	// Test empty array
	create arr transient;
	create strings transient;
	
	strings.addStrings(arr);
	assertEqual(strings.numStrings, 0);
	
	delete arr;
	delete strings;
	
	// Test single string
	create arr transient;
	create arr2 transient;
	create strings transient;
	
	arr.add("test value 1");
	
	strings.addStrings(arr);
	assertEqual(strings.numStrings, 1);
	strings.getStrings(arr2);
	assertEqual(arr2.size, 1);
	assertEqual(arr2.first(), arr.first);
	assertEqual(arr2.first(), strings.at(1));
	
	delete arr;
	delete arr2;
	delete strings;

	// Test multiple strings
	create arr transient;
	create arr2 transient;
	create strings transient;
	
	arr.add("test value 1");
	arr.add("test value 2");
	arr.add("test value 3");
	arr.add("test value 4");
	arr.add("test value 5");
		
	strings.addStrings(arr);
	assertEqual(strings.numStrings, 5);
	strings.getStrings(arr2);
	assertEqual(arr2.size, 5);
	
	foreach i in 1 to 5 do
		assertEqual(arr2[i], arr[i]);
		assertEqual(arr2[i], strings.at(i));
	endforeach;
	
epilog
	delete arr;
	delete arr2;
	delete strings;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="tCargoEnqColumns" id="8d58fad8-72d5-45c5-9066-61971f933629">
        <source>tCargoEnqColumns();
// cnwrs1
// ===============================================================
// This test checks that the column organiser for Cargo Enquiry (and Location Enquiry) contains all columns available in the entry tables.
// i.e. if you can see a field in the right-hand table of Cargo Enquiry then you should be able to select the field as a column.
// There are five EntTblDefs for the column organiser depending on the cargo type.
// 
// If this test fails there are two ways to fix it:
// A) if field should be available as a column - fix by adding the field to the relevant column org ETDef
// B) if field should not be available as a column - change this test and add the field to the exceptions collection in the relevant
//    section, noting the reason why the field shouldn't be added to the column org ETDef
// ===============================================================
// 26 Jun 2017	cnwrs1	TFS 4462 SNO add Terminal Operator, Unknown Seal and support multiple seals
// 18/05/2023	jlika1	TFS 57154 CUX | New mafi related fields for display in the vehicle app
vars
	etRoot				: EntTableDataRoot;
	etGroup				: EntTableGroup;
	etDefsEntryTbl		: EntTableDefSet;
	etDef				: EntTableDef;
	etDefColOrg			: EntTableDef;
	etRow				: EntTableRow;
	etRow2				: EntTableRow;
	etRowsEntryTbl		: EntTableRowArray;
	exceptions			: StringArray;
	usedRows			: EntTableRowDictByName;
	missingRows			: EntTableRowDictByName;
	included			: Boolean;
	name				: String;
	count				: Integer;
	entryTableDefsUsed	: String;
	
begin
	etRoot := app.myRoot.myEntTableDataRoot;
	
	create usedRows transient;
	create missingRows transient;
	create etDefsEntryTbl transient;
	create etRowsEntryTbl transient;
	create exceptions transient;
	
	
	//----------------------------------------------------------------------------------
	// The Cargo Enquiry Column Organiser for each of the following cargo types is based on ETDef_DefaultDataTable
	// BBLK, Tracked-as-BreakBulk, Tracked-as-Bulk, Tracked-as-PieceBreakBulk,
	// CAR, Tracked-as-Vehicle,
	// CHAS, Tracked-as-Trailer,
	// COU, LCL, TMBR, TOWR
	
	etGroup := etRoot.allEntTableGroups[ETGrp_TrackedItemDetails];
	etDefColOrg := etGroup.allEntTableDefsByName[ETDef_DefaultDataTable];
	app.writeLog("Checking ETDef_DefaultDataTable column org:", LogINFO);
	app.writeLog("(used by cargo types BBLK, CAR, CHAS, COU, LCL, TMBR, TOWR, Tracked-as-BreakBulk, Tracked-as-Bulk, Tracked-as-PieceBreakBulk, Tracked-as-Vehicle, Tracked-as-Trailer)", LogINFO);
	
	// The cargo types BBLK, Tracked-as-BreakBulk, Tracked-as-Bulk, Tracked-as-PieceBreakBulk, CAR, Tracked-as-Vehicle, CHAS, Tracked-as-Trailer
	// each use entry table fields from ETDef_WHGeneralData, ETDef_LocationMoveData, ETDef_ReceiveData, ETDef_StatusData, ETDef_ShipOpsData, 
	// ETDef_TranshipData.
	// The cargo types COU, LCL, TOWR use entry table fields from ETDef_DefaultCargoEnt.
	// Additional entry table fields:
	// BBLK, Tracked-as-BreakBulk, Tracked-as-Bulk, Tracked-as-PieceBreakBulk:	ETDef_BreakBulkEnt
	// CAR, Tracked-as-Vehicle:													ETDef_CarExtra
	// CHAS, Tracked-as-Trailer:												ETDef_TrailorData
	// COU:																		ETDef_COUMain
	// TMBR:																	ETDef_TimberCargoEnt
	
	etDefsEntryTbl.clear();
	etDef := etGroup.allEntTableDefsByName[ETDef_WHGeneralData];
	etDefsEntryTbl.add(etDef);
	etDef := etGroup.allEntTableDefsByName[ETDef_LocationMoveData];
	etDefsEntryTbl.add(etDef);
	etDef := etGroup.allEntTableDefsByName[ETDef_ReceiveData];
	etDefsEntryTbl.add(etDef);
	etDef := etGroup.allEntTableDefsByName[ETDef_StatusData];
	etDefsEntryTbl.add(etDef);
	etDef := etGroup.allEntTableDefsByName[ETDef_ShipOpsData];
	etDefsEntryTbl.add(etDef);
	etDef := etGroup.allEntTableDefsByName[ETDef_TranshipData];
	etDefsEntryTbl.add(etDef);
	etDef := etGroup.allEntTableDefsByName[ETDef_DefaultCargoEnt];
	etDefsEntryTbl.add(etDef);
	etDef := etGroup.allEntTableDefsByName[ETDef_CarExtra];
	etDefsEntryTbl.add(etDef);
	etDef := etGroup.allEntTableDefsByName[ETDef_TrailorData];
	etDefsEntryTbl.add(etDef);
	etDef := etGroup.allEntTableDefsByName[ETDef_TimberCargoEnt];
	etDefsEntryTbl.add(etDef);
	etGroup := etRoot.allEntTableGroups[ETGrp_GateReceivals];
	etDef := etGroup.allEntTableDefsByName[ETDef_COUMain];
	etDefsEntryTbl.add(etDef);
	etGroup := etRoot.allEntTableGroups[ETGrp_BreakBulkMaint];
	etDef := etGroup.allEntTableDefsByName[ETDef_BreakBulkEnt];
	etDefsEntryTbl.add(etDef);
	
	// some rows from the entry tables shouldn't be included in the column org
	exceptions.clear;
	exceptions.add('isoType');					// only relevant for containers
	exceptions.add('isoTypeGroup');				// only relevant for containers
	exceptions.add('isOverDimensions');			// only relevant for containers
	exceptions.add('sealNumShippers');			// only relevant for containers
	exceptions.add('sealNumCustoms');			// only relevant for containers
	exceptions.add('sealNumVent');				// only relevant for containers
	exceptions.add('sealNumTerminalOperator');				// only relevant for containers
	exceptions.add('sealNumUnknown');				// only relevant for containers
	exceptions.add('otherSeals');				// only relevant for containers
	exceptions.add('generator');				// only relevant for containers
	exceptions.add('washDT');					// only relevant for containers
	exceptions.add('couType');					// only relevant for COU
	exceptions.add('couId');					// only relevant for COU
	exceptions.add('trailerTypeUpd');			// only relevant for trailers
	exceptions.add('engineNo');					// only relevant for cars
	exceptions.add('certificate1');				// only relevant for cars
	exceptions.add('certificate1Expiry');		// only relevant for cars
	exceptions.add('certificate2');				// only relevant for cars
	exceptions.add('certificate2Expiry');		// only relevant for cars
	exceptions.add('chassisNo');				// only relevant for cars
	exceptions.add('registration');				// only relevant for cars
	exceptions.add('vin');						// only relevant for cars
	exceptions.add('myCarProduct');						// only relevant for cars
	exceptions.add('myOperator');				// already including ETRow_OperatorCode
	exceptions.add('location');					// already including ETRow_LocationID
	exceptions.add('receiptTransModePreNote');	// already including ETRow_ReceiptTransMode
	exceptions.add('cargoType');				// already including ETRow_CargoTypeDesc
	exceptions.add('productGroupDesc');			// already including ETRow_ProductGroupCode
	exceptions.add('debtorTypes');				// user-defined debtor type columns created dynamically
	exceptions.add('transhipActualLocation');	// heading 'Actual Location' ambiguous (only relevant for tranships)
	exceptions.add('transhipPlannedLocation');	// heading 'Planned Location' ambiguous (only relevant for tranships)
	exceptions.add('cargoOnboard');				// heading 'Cargo Onboard' ambiguous (only relevant for trailers)
	exceptions.add('cargoQueuedOnboard');		// heading 'Cargo Onboard' ambiguous (only relevant for trailers)
	exceptions.add('cargoPlannedOnboard');		// heading 'Cargo Onboard' ambiguous (only relevant for trailers)
	exceptions.add('lengthCM');					// heading 'Length (cm)' ambiguous (only relevant for cars)
	exceptions.add('widthCM');					// heading 'Width (cm)' ambiguous (only relevant for cars)
	exceptions.add('heightCM');					// heading 'Height (cm)' ambiguous (only relevant for cars)
	exceptions.add('pieces');					// heading 'Quantity' ambiguous (same heading as ETRow_Quantity)
	exceptions.add('preTripDT');				// included as ETRow_PreTripDTSort
	exceptions.add('inspectDT');				// included as ETRow_InspectDTSort
	exceptions.add('fumigateDT');				// included as ETRow_FumigateDTSort
	exceptions.add('damagedDT');				// included as ETRow_DamagedDTSort
	exceptions.add('repairDT');					// included as ETRow_RepairDTSort
	exceptions.add('moveDT');					// included as ETRow_MoveDTSort
	exceptions.add('plannedDT');				// included as ETRow_PlannedDTSort
	exceptions.add('inputDT');					// included as ETRow_InputDTSort
	exceptions.add('releasedDT');				// included as ETRow_ReleasedDTSort
	exceptions.add('earliestRecTS');			// included as ETRow_EarliestRecDTSort
	exceptions.add('dischargeDT');				// included as ETRow_DischargeDTSort
	exceptions.add('loadDT');					// included as ETRow_LoadDTSort
	exceptions.add('repackedDT');				// included as ETRow_RepackedDTSort
	exceptions.add('packedDT');					// included as ETRow_PackedDTSort
	exceptions.add('unpackedDT');				// included as ETRow_UnpackedDTSort
	exceptions.add('freeStorageExpiryDate');	// included as ETRow_FreeStorageExpDTSort
	exceptions.add('dwellDays');				// included as ETRow_DwellDaysNumeric
	exceptions.add('allTIHazardsNew');			// intentionally excluded (see TFS3126)
	exceptions.add('externalCode');				// already in use as ETRow_VoyageExternalCode
    exceptions.add('obQuantity');			    // "Onboard Quantity"                       //JIRA-34864
	
	// gets all entrows in entry tables, excluding duplicates
	etRowsEntryTbl.clear();
	usedRows.clear();
	foreach etDef in etDefsEntryTbl do
		foreach etRow in etDef.allEntTableRows do
			if usedRows[etRow.name] = null 
			and not exceptions.includes(etRow.name) then
				etRowsEntryTbl.add(etRow);
				usedRows.add(etRow);
			endif;
		endforeach;
	endforeach;
		
	missingRows.clear();
	count := 0;
	foreach etRow in etRowsEntryTbl do
		included := false;
		foreach etRow2 in etDefColOrg.allEntTableRows do
			if etRow.name = etRow2.name then
				included := true;
				break;
			endif;
		endforeach;
		if not included and not missingRows.includes(etRow) then
			count := count + 1;
			missingRows.add(etRow);
			name := etRow.name;
			name.firstCharToUpper;
			app.writeLog(etRow.getHeadingUnaltered &amp; " (ETRow_" &amp; name &amp; ")", LogINFO);

		endif;
	endforeach;
	
	entryTableDefsUsed := "" &amp; CrLf;
	
	foreach etDef in etDefsEntryTbl do
		foreach etRow in etDef.allEntTableRows do
			if not missingRows.includes(etRow) then
				continue;
			endif;
			entryTableDefsUsed &amp;= etDef.constantName &amp; Space &amp; "-" &amp; Space &amp; etRow.name &amp; CrLf;
		endforeach;
	endforeach;
	if entryTableDefsUsed &lt;&gt; "" &amp; CrLf then
		app.writeLog("Row defined in the following entry table ETDef's: " &amp; entryTableDefsUsed, LogINFO);
	endif;
	app.writeLog(count.String &amp; " rows used in entry tables but missing from ETDef_DefaultDataTable column org." &amp; CrLf, LogINFO);
	self.assertEqualMsg(count, 0, count.String &amp; " rows used in entry tables but missing from ETDef_DefaultDataTable column org.");
	
	
	//----------------------------------------------------------------------------------
	// The Cargo Enquiry Column Organiser for cargo type ISO Container is based on ETDef_ContainerData
	
	etGroup := etRoot.allEntTableGroups[ETGrp_TrackedItemDetails];
	etDefColOrg := etGroup.allEntTableDefsByName[ETDef_ContainerData];
	app.writeLog("Checking ETDef_ContainerData column org:", LogINFO);
	app.writeLog("(used by cargo type CONT)", LogINFO);
	
	// The cargo type CONT uses entry table fields from ETDef_GeneralData, ETDef_LocationMoveData, ETDef_ReceiveData, ETDef_StatusData, 
	// ETDef_ReeferData, ETDef_ShipOpsData, ETDef_TranshipData.
		
	etDefsEntryTbl.clear();
	etDef := etGroup.allEntTableDefsByName[ETDef_GeneralData];
	etDefsEntryTbl.add(etDef);
	etDef := etGroup.allEntTableDefsByName[ETDef_LocationMoveData];
	etDefsEntryTbl.add(etDef);
	etDef := etGroup.allEntTableDefsByName[ETDef_ReceiveData];
	etDefsEntryTbl.add(etDef);
	etDef := etGroup.allEntTableDefsByName[ETDef_StatusData];
	etDefsEntryTbl.add(etDef);
	etDef := etGroup.allEntTableDefsByName[ETDef_ReeferData];
	etDefsEntryTbl.add(etDef);
	etDef := etGroup.allEntTableDefsByName[ETDef_ShipOpsData];
	etDefsEntryTbl.add(etDef);
	etDef := etGroup.allEntTableDefsByName[ETDef_TranshipData];
	etDefsEntryTbl.add(etDef);
	
	// some rows from the entry tables shouldn't be included in the column org
	exceptions.clear();
	exceptions.add('myOperator');				// already including ETRow_OperatorCode
	exceptions.add('isWeightCertifiedRO');		// already including ETRow_IsWeightCertified
	exceptions.add('receiptTransModePreNote');	// already including ETRow_ReceiptTransMode
	exceptions.add('myParent');					// already including ETRow_Parent
	exceptions.add('debtorTypes');				// user-defined debtor type columns created dynamically
	exceptions.add('transhipActualLocation');	// heading 'Actual Location' ambiguous (only relevant for tranships)
	exceptions.add('transhipPlannedLocation');	// heading 'Planned Location' ambiguous (only relevant for tranships)
	exceptions.add('preTripDT');				// included as ETRow_PreTripDTSort
	exceptions.add('inspectDT');				// included as ETRow_InspectDTSort
	exceptions.add('fumigateDT');				// included as ETRow_FumigateDTSort
	exceptions.add('damagedDT');				// included as ETRow_DamagedDTSort
	exceptions.add('repairDT');					// included as ETRow_RepairDTSort
	exceptions.add('moveDT');					// included as ETRow_MoveDTSort
	exceptions.add('plannedDT');				// included as ETRow_PlannedDTSort
	exceptions.add('inputDT');					// included as ETRow_InputDTSort
	exceptions.add('releasedDT');				// included as ETRow_ReleasedDTSort
	exceptions.add('earliestRecTS');			// included as ETRow_EarliestRecDTSort
	exceptions.add('dischargeDT');				// included as ETRow_DischargeDTSort
	exceptions.add('loadDT');					// included as ETRow_LoadDTSort
	exceptions.add('repackedDT');				// included as ETRow_RepackedDTSort
	exceptions.add('packedDT');					// included as ETRow_PackedDTSort
	exceptions.add('unpackedDT');				// included as ETRow_UnpackedDTSort
	exceptions.add('freeStorageExpiryDate');	// included as ETRow_FreeStorageExpDTSort
	exceptions.add('firstConnectDT');			// included as ETRow_FirstConnectDTSort
	exceptions.add('lastDisconnectDT');			// included as ETRow_LastDisconnectDTSort
	exceptions.add('lastConnectDT');			// included as ETRow_LastConnectDTSort
	exceptions.add('washDT');					// included as ETRow_WashDTSort
	exceptions.add('dwellDays');				// included as ETRow_DwellDaysNumeric
	exceptions.add('allTIHazardsNew');			// intentionally excluded (see TFS3126)
	
	// gets all entrows in entry tables, excluding duplicates
	etRowsEntryTbl.clear();
	usedRows.clear();
	foreach etDef in etDefsEntryTbl do
		foreach etRow in etDef.allEntTableRows do
			if usedRows[etRow.name] = null 
			and not exceptions.includes(etRow.name) then
				etRowsEntryTbl.add(etRow);
				usedRows.add(etRow);
			endif;
		endforeach;
	endforeach;
		
	missingRows.clear();
	count := 0;
	foreach etRow in etRowsEntryTbl do
		included := false;
		foreach etRow2 in etDefColOrg.allEntTableRows do
			if etRow.name = etRow2.name then
				included := true;
				break;
			endif;
		endforeach;
		if not included and not missingRows.includes(etRow) then
			count := count + 1;
			missingRows.add(etRow);
			name := etRow.name;
			name.firstCharToUpper;
			app.writeLog(etRow.getHeadingUnaltered &amp; " (ETRow_" &amp; name &amp; ")", LogINFO);

		endif;
	endforeach;
	
	entryTableDefsUsed := "" &amp; CrLf;
	
	foreach etDef in etDefsEntryTbl do
		foreach etRow in etDef.allEntTableRows do
			if not missingRows.includes(etRow) then
				continue;
			endif;
			entryTableDefsUsed &amp;= etDef.constantName &amp; Space &amp; "-" &amp; Space &amp; etRow.name &amp; CrLf;
		endforeach;
	endforeach;
	if entryTableDefsUsed &lt;&gt; "" &amp; CrLf then
		app.writeLog("Row defined in the following entry table ETDef's: " &amp; entryTableDefsUsed, LogINFO);
	endif;
	app.writeLog(count.String &amp; " rows used in entry tables but missing from ETDef_ContainerData column org." &amp; CrLf, LogINFO);
	self.assertEqualMsg(count, 0, count.String &amp; " rows used in entry tables but missing from ETDef_ContainerData column org.");
	
	
	//----------------------------------------------------------------------------------
	// The Cargo Enquiry Column Organiser for cargo type Generator is based on ETDef_GeneratorData
	
	etGroup := etRoot.allEntTableGroups[ETGrp_TrackedItemDetails];
	etDefColOrg := etGroup.allEntTableDefsByName[ETDef_GeneratorData];
	app.writeLog("Checking ETDef_GeneratorData column org:", LogINFO);
	app.writeLog("(used by cargo type GEN)", LogINFO);
	
	// The cargo type GEN uses entry table fields from ETDef_GeneratorEnt, ETDef_DefaultCargoEnt, ETDef_TranshipData.
		
	etDefsEntryTbl.clear();
	etDef := etGroup.allEntTableDefsByName[ETDef_GeneratorEnt];
	etDefsEntryTbl.add(etDef);
	etDef := etGroup.allEntTableDefsByName[ETDef_DefaultCargoEnt];
	etDefsEntryTbl.add(etDef);
	etDef := etGroup.allEntTableDefsByName[ETDef_TranshipData];
	etDefsEntryTbl.add(etDef);
	
	// some rows from the entry tables shouldn't be included in the column org
	exceptions.clear();
	exceptions.add('isOverDimensions');			// only relevant for containers
	exceptions.add('hasRadio');					// only relevant for cars
	exceptions.add('debtorTypes');				// user-defined debtor type columns created dynamically
	exceptions.add('transhipActualLocation');	// heading 'Actual Location' ambiguous (only relevant for tranships)
	exceptions.add('transhipPlannedLocation');	// heading 'Planned Location' ambiguous (only relevant for tranships)
	exceptions.add('purchaseOrder');			// not relevant for generators
	exceptions.add('serviceOrder');			// not relevant for generators
	exceptions.add('allTIHazardsNew');			// intentionally excluded (see TFS3126)
	
	// gets all entrows in entry tables, excluding duplicates
	etRowsEntryTbl.clear();
	usedRows.clear();
	foreach etDef in etDefsEntryTbl do
		foreach etRow in etDef.allEntTableRows do
			if usedRows[etRow.name] = null 
			and not exceptions.includes(etRow.name) then
				etRowsEntryTbl.add(etRow);
				usedRows.add(etRow);
			endif;
		endforeach;
	endforeach;
		
	missingRows.clear();
	count := 0;
	foreach etRow in etRowsEntryTbl do
		included := false;
		foreach etRow2 in etDefColOrg.allEntTableRows do
			if etRow.name = etRow2.name then
				included := true;
				break;
			endif;
		endforeach;
		if not included and not missingRows.includes(etRow) then
			count := count + 1;
			missingRows.add(etRow);
			name := etRow.name;
			name.firstCharToUpper;
			app.writeLog(etRow.getHeadingUnaltered &amp; " (ETRow_" &amp; name &amp; ")", LogINFO);

		endif;
	endforeach;
	
	entryTableDefsUsed := "" &amp; CrLf;
	
	foreach etDef in etDefsEntryTbl do
		foreach etRow in etDef.allEntTableRows do
			if not missingRows.includes(etRow) then
				continue;
			endif;
			entryTableDefsUsed &amp;= etDef.constantName &amp; Space &amp; "-" &amp; Space &amp; etRow.name &amp; CrLf;
		endforeach;
	endforeach;
	if entryTableDefsUsed &lt;&gt; "" &amp; CrLf then
		app.writeLog("Row defined in the following entry table ETDef's: " &amp; entryTableDefsUsed, LogINFO);
	endif;
	
	app.writeLog(count.String &amp; " rows used in entry tables but missing from ETDef_GeneratorData column org." &amp; CrLf, LogINFO);
	self.assertEqualMsg(count, 0, count.String &amp; " rows used in entry tables but missing from ETDef_GeneratorData column org.");
	
	
	//----------------------------------------------------------------------------------
	// The Cargo Enquiry Column Organiser for cargo type Log is based on ETDef_LogDataTable
	
	etGroup := etRoot.allEntTableGroups[ETGrp_TrackedItemDetails];
	etDefColOrg := etGroup.allEntTableDefsByName[ETDef_LogDataTable];
	app.writeLog("Checking ETDef_LogDataTable column org:", LogINFO);
	app.writeLog("(used by cargo type LOG)", LogINFO);
	
	// The cargo type LOG uses entry table fields from ETDef_LogData, ETDef_TranshipData.
		
	etDefsEntryTbl.clear();
	etDef := etGroup.allEntTableDefsByName[ETDef_LogData];
	etDefsEntryTbl.add(etDef);
	
	// some rows from the entry tables shouldn't be included in the column org
	exceptions.clear();
	exceptions.add('logData');					// logData represents a combination of other data fields
	
	// gets all entrows in entry tables, excluding duplicates
	etRowsEntryTbl.clear();
	usedRows.clear();
	foreach etDef in etDefsEntryTbl do
		foreach etRow in etDef.allEntTableRows do
			if usedRows[etRow.name] = null 
			and not exceptions.includes(etRow.name) then
				etRowsEntryTbl.add(etRow);
				usedRows.add(etRow);
			endif;
		endforeach;
	endforeach;
		
	missingRows.clear();
	count := 0;
	foreach etRow in etRowsEntryTbl do
		included := false;
		foreach etRow2 in etDefColOrg.allEntTableRows do
			if etRow.name = etRow2.name then
				included := true;
				break;
			endif;
		endforeach;
		if not included and not missingRows.includes(etRow) then
			count := count + 1;
			missingRows.add(etRow);
			name := etRow.name;
			name.firstCharToUpper;
			app.writeLog(etRow.getHeadingUnaltered &amp; " (ETRow_" &amp; name &amp; ")", LogINFO);

		endif;
	endforeach;
	
	entryTableDefsUsed := "" &amp; CrLf;
	
	foreach etDef in etDefsEntryTbl do
		foreach etRow in etDef.allEntTableRows do
			if not missingRows.includes(etRow) then
				continue;
			endif;
			entryTableDefsUsed &amp;= etDef.constantName &amp; Space &amp; "-" &amp; Space &amp; etRow.name &amp; CrLf;
		endforeach;
	endforeach;
	if entryTableDefsUsed &lt;&gt; "" &amp; CrLf then
		app.writeLog("Row defined in the following entry table ETDef's: " &amp; entryTableDefsUsed, LogINFO);
	endif;
	app.writeLog(count.String &amp; " rows used in entry tables but missing from ETDef_LogDataTable column org." &amp; CrLf, LogINFO);
	self.assertEqualMsg(count, 0, count.String &amp; " rows used in entry tables but missing from ETDef_LogDataTable column org.");
	
	
	//----------------------------------------------------------------------------------
	// The Cargo Enquiry Column Organiser when no cargo type is selected is based on ETDef_CargoEnqDefaultData
	
	etGroup := etRoot.allEntTableGroups[ETGrp_TrackedItemDetails];
	etDefColOrg := etGroup.allEntTableDefsByName[ETDef_CargoEnqDefaultData];
	app.writeLog("Checking ETDef_CargoEnqDefaultData column org:", LogINFO);
	app.writeLog("(used when no cargo type selected)", LogINFO);
	
	// Need to compare to ALL entry table fields.
		
	etDefsEntryTbl.clear();
	etDef := etGroup.allEntTableDefsByName[ETDef_GeneralData];
	etDefsEntryTbl.add(etDef);
	etDef := etGroup.allEntTableDefsByName[ETDef_WHGeneralData];
	etDefsEntryTbl.add(etDef);
	etDef := etGroup.allEntTableDefsByName[ETDef_LocationMoveData];
	etDefsEntryTbl.add(etDef);
	etDef := etGroup.allEntTableDefsByName[ETDef_ReceiveData];
	etDefsEntryTbl.add(etDef);
	etDef := etGroup.allEntTableDefsByName[ETDef_StatusData];
	etDefsEntryTbl.add(etDef);
	etDef := etGroup.allEntTableDefsByName[ETDef_ShipOpsData];
	etDefsEntryTbl.add(etDef);
	etDef := etGroup.allEntTableDefsByName[ETDef_TranshipData];
	etDefsEntryTbl.add(etDef);
	etDef := etGroup.allEntTableDefsByName[ETDef_DefaultCargoEnt];
	etDefsEntryTbl.add(etDef);
	etDef := etGroup.allEntTableDefsByName[ETDef_CarExtra];
	etDefsEntryTbl.add(etDef);
	etDef := etGroup.allEntTableDefsByName[ETDef_TrailorData];
	etDefsEntryTbl.add(etDef);
	etDef := etGroup.allEntTableDefsByName[ETDef_TimberCargoEnt];
	etDefsEntryTbl.add(etDef);
	etDef := etGroup.allEntTableDefsByName[ETDef_ReeferData];
	etDefsEntryTbl.add(etDef);
	etDef := etGroup.allEntTableDefsByName[ETDef_GeneratorEnt];
	etDefsEntryTbl.add(etDef);
	etDef := etGroup.allEntTableDefsByName[ETDef_LogData];
	etDefsEntryTbl.add(etDef);
	etGroup := etRoot.allEntTableGroups[ETGrp_GateReceivals];
	etDef := etGroup.allEntTableDefsByName[ETDef_COUMain];
	etDefsEntryTbl.add(etDef);
	etGroup := etRoot.allEntTableGroups[ETGrp_BreakBulkMaint];
	etDef := etGroup.allEntTableDefsByName[ETDef_BreakBulkEnt];
	etDefsEntryTbl.add(etDef);
	
	// some rows from the entry tables shouldn't be included in the column org
	exceptions.clear();
	exceptions.add('isoType');					// only relevant for containers
	exceptions.add('isoTypeGroup');				// only relevant for containers
	exceptions.add('isOverDimensions');			// only relevant for containers
	exceptions.add('sealNumShippers');			// only relevant for containers
	exceptions.add('sealNumCustoms');			// only relevant for containers
	exceptions.add('sealNumVent');				// only relevant for containers
	exceptions.add('sealNumTerminalOperator');				// only relevant for containers
	exceptions.add('sealNumUnknown');				// only relevant for containers
	exceptions.add('otherSeals');				// only relevant for containers
	exceptions.add('generator');				// only relevant for containers
	exceptions.add('couType');					// only relevant for COU
	exceptions.add('couId');					// only relevant for COU
	exceptions.add('trailerTypeUpd');			// only relevant for trailers
	exceptions.add('engineNo');					// only relevant for cars
	exceptions.add('certificate1');				// only relevant for cars
	exceptions.add('certificate1Expiry');		// only relevant for cars
	exceptions.add('certificate2');				// only relevant for cars
	exceptions.add('certificate2Expiry');		// only relevant for cars
	exceptions.add('chassisNo');				// only relevant for cars
	exceptions.add('registration');				// only relevant for cars
	exceptions.add('vin');						// only relevant for cars
	exceptions.add('myCarProduct');				// only relevant for cars
	exceptions.add('attachedTo');				// only relevant for generators
	exceptions.add('myOperator');				// already including ETRow_OperatorCode
	exceptions.add('location');					// already including ETRow_LocationID
	exceptions.add('receiptTransModePreNote');	// already including ETRow_ReceiptTransMode
	exceptions.add('cargoType');				// already including ETRow_CargoTypeDesc
	exceptions.add('productGroupDesc');			// already including ETRow_ProductGroupCode
	exceptions.add('bookingReference');			// already including ETRow_BookingRef
	exceptions.add('isWeightCertifiedRO');		// already including ETRow_IsWeightCertified
	exceptions.add('destTerminalForPrenote');	// already including ETRow_DestinationTerminal
	exceptions.add('debtorTypes');				// user-defined debtor type columns created dynamically
	exceptions.add('transhipActualLocation');	// heading 'Actual Location' ambiguous (only relevant for tranships)
	exceptions.add('transhipPlannedLocation');	// heading 'Planned Location' ambiguous (only relevant for tranships)
	exceptions.add('cargoOnboard');				// heading 'Cargo Onboard' ambiguous (only relevant for trailers)
	exceptions.add('cargoQueuedOnboard');		// heading 'Cargo Onboard' ambiguous (only relevant for trailers)
	exceptions.add('cargoPlannedOnboard');		// heading 'Cargo Onboard' ambiguous (only relevant for trailers)
	exceptions.add('lengthCM');					// heading 'Length (cm)' ambiguous (only relevant for cars)
	exceptions.add('widthCM');					// heading 'Width (cm)' ambiguous (only relevant for cars)
	exceptions.add('heightCM');					// heading 'Height (cm)' ambiguous (only relevant for cars)
	exceptions.add('pieces');					// heading 'Quantity' ambiguous (same heading as ETRow_Quantity)
	exceptions.add('logData');					// logData represents a combination of other data fields
	exceptions.add('dwellDays');				// included as ETRow_DwellDaysNumeric
	exceptions.add('preTripDT');				// "Pre Trip Date/Time" ambiguous
	exceptions.add('inspectDT');				// "Inspect Date/Time" ambiguous
	exceptions.add('fumigateDT');				// "Fumigate Date/Time" ambiguous
	exceptions.add('damagedDT');				// "Damaged Date/Time" ambiguous
	exceptions.add('repairDT');					// "Repair Date/Time" ambiguous
	exceptions.add('moveDT');					// "Last Moved On" ambiguous
	exceptions.add('freeStorageExpiryDate');	// "Free Storage Expiry Date" ambiguous
	exceptions.add('inputDT');					// "Input Date/Time" ambiguous
	exceptions.add('releasedDT');				// "Released Date/Time" ambiguous
	exceptions.add('earliestRecTS');			// "Earliest Receival Time" ambiguous
	exceptions.add('firstConnectDT');			// "First Connect Date/Time" ambiguous
	exceptions.add('lastDisconnectDT');			// "Last Disconnect DT" ambiguous
	exceptions.add('lastConnectDT');			// "Last Connect DT" ambiguous
	exceptions.add('dischargeDT');				// "Discharge Date/Time" ambiguous
	exceptions.add('loadDT');					// "Load Date/Time" ambiguous
	exceptions.add('repackedDT');				// "Repacked Date/Time" ambiguous
	exceptions.add('packedDT');					// "Packed Date/Time" ambiguous
	exceptions.add('unpackedDT');				// "Unpacked Date/Time" ambiguous
	exceptions.add('obCargoSubtypes');			// "Onboard Cargo Sub Types"
	exceptions.add('obCargoTypes');				// "Onboard Cargo Type"
	exceptions.add('obDamage');					// "Onboard Damag"e
	exceptions.add('obHaz');					// "Onboard Haz"
	exceptions.add('obHazDetails');				// "Onboard Haz Details"
	exceptions.add('obISOTypes');				// "Onboard ISO Types"
	exceptions.add('obId');						// "Onboard Id"
	exceptions.add('obReefer');					// "Onboard Reefer"
	exceptions.add('obStopTypes');				// "Onboard Stop Types"
	exceptions.add('obStops');					// "Onboard Stops"	
	exceptions.add('allTIHazardsNew');			// intentionally excluded (see TFS3126)
    exceptions.add('obQuantity');			    // "Onboard Quantity"                       //JIRA-34864
	
	// gets all entrows in entry tables, excluding duplicates
	etRowsEntryTbl.clear();
	usedRows.clear();
	foreach etDef in etDefsEntryTbl do
		foreach etRow in etDef.allEntTableRows do
			if usedRows[etRow.name] = null 
			and not exceptions.includes(etRow.name) then
				etRowsEntryTbl.add(etRow);
				usedRows.add(etRow);
			endif;
		endforeach;
	endforeach;
		
	missingRows.clear();
	count := 0;
	foreach etRow in etRowsEntryTbl do
		included := false;
		foreach etRow2 in etDefColOrg.allEntTableRows do
			if etRow.name = etRow2.name then
				included := true;
				break;
			endif;
		endforeach;
		if not included and not missingRows.includes(etRow) then
			count := count + 1;
			missingRows.add(etRow);
			name := etRow.name;
			name.firstCharToUpper;
			app.writeLog(etRow.getHeadingUnaltered &amp; " (ETRow_" &amp; name &amp; ")", LogINFO);

		endif;
	endforeach;
	
	entryTableDefsUsed := "" &amp; CrLf;
	
	foreach etDef in etDefsEntryTbl do
		foreach etRow in etDef.allEntTableRows do
			if not missingRows.includes(etRow) then
				continue;
			endif;
			entryTableDefsUsed &amp;= etDef.constantName &amp; Space &amp; "-" &amp; Space &amp; etRow.name &amp; CrLf;
		endforeach;
	endforeach;
	if entryTableDefsUsed &lt;&gt; "" &amp; CrLf then
		app.writeLog("Row defined in the following entry table ETDef's: " &amp; entryTableDefsUsed, LogINFO);
	endif;
	app.writeLog(count.String &amp; " rows used in entry tables but missing from ETDef_CargoEnqDefaultData column org.", LogINFO);
	self.assertEqualMsg(count, 0, count.String &amp; " rows used in entry tables but missing from ETDef_CargoEnqDefaultData column org.");
epilog
	delete etDefsEntryTbl;
	delete etRowsEntryTbl;
	delete exceptions;
	delete usedRows;
	delete missingRows;
end;</source>
    </JadeMethod>
    <JadeMethod name="tCheckDecAsCurrencyJMTWords2" id="f113843a-b9b5-4493-87f2-2f97fd77fb30">
        <source>tCheckDecAsCurrencyJMTWords2();

/*

Purpose:		Check that decimals asCurrentJMTWords2 works correctly (QNS)

Date			Who		Reason
14/05/2014		cnwmh5	Initial creation

*/

vars

	amount					: Decimal[10,2];


begin

	amount := 3560487;	
	self.assertEqual(amount.asCurrencyJMTWords2(),'Dollars Three million five hundred sixty thousand four hundred and eighty-seven');
	
	amount := 3560487.23;	
	self.assertEqual(amount.asCurrencyJMTWords2(), 'Dollars Three million five hundred sixty thousand four hundred eighty-seven and twenty-three cents');
	
	amount := 10789100.00;	
	self.assertEqual(amount.asCurrencyJMTWords2(), 'Dollars Ten million seven hundred eighty-nine thousand one hundred');
	
	amount := 10789000.00;	
	self.assertEqual(amount.asCurrencyJMTWords2(), 'Dollars Ten million seven hundred eighty-nine thousand');
	
	amount := 10700000.00;	
	self.assertEqual(amount.asCurrencyJMTWords2(), 'Dollars Ten million seven hundred thousand');
	
	amount := 10000000.00;	
	self.assertEqual(amount.asCurrencyJMTWords2(), 'Dollars Ten million');
	
	amount := 10789123.45;	
	self.assertEqual(amount.asCurrencyJMTWords2(), 'Dollars Ten million seven hundred eighty-nine thousand one hundred twenty-three and forty-five cents');
	
	amount := 10789100.45;	
	self.assertEqual(amount.asCurrencyJMTWords2(), 'Dollars Ten million seven hundred eighty-nine thousand one hundred and forty-five cents');
	
	amount := 10789000.45;	
	self.assertEqual(amount.asCurrencyJMTWords2(), 'Dollars Ten million seven hundred eighty-nine thousand and forty-five cents');
	
	amount := 10700000.20;	
	self.assertEqual(amount.asCurrencyJMTWords2(), 'Dollars Ten million seven hundred thousand and twenty cents');

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="tCheckNotUsingAssertMsg" id="be07dc57-3818-409d-8aad-9865ab35beb2">
        <source>tCheckNotUsingAssertMsg();
/*

Purpose:			This UT goes through all unit tests in UT_DSL and get a list of those that are not using assertMsg methods.

Parameters:			

Return Value:		

Date		Who		Reason
01 July 2025	navkc1	Initial Creation JIRA 34205 MTN - Unit Test to find Unit Tests that are not using AssertMsg methods - Phase1

*/
constants
	JMTUNITTEST 	= "JMTUnitTest";
	UTDSL 			= "UT_DSL";
vars
	scm						: Schema;
	cls						: Class;
	mth						: Method;
	
	assertMsgMthNameCol		: StringArray;
	sourceNotOK				: HugeStringArray;
	classes					: ClassColl;
	
	assertMthNoMsgSet,
	methods					: MethodSet;
	
	str						: String;

begin
	
	scm := rootSchema.getSchema(JMTUNITTEST);
	self.assertNotNullMsg(scm, "Failed to get '" &amp; JMTUNITTEST &amp; "' schema");
	
	cls := scm.getClass(UTDSL);
	self.assertNotNullMsg(cls, "Failed to get '" &amp; UTDSL &amp; "' class");
	
	create classes transient;
	create assertMsgMthNameCol transient;
	create assertMthNoMsgSet transient;
	create sourceNotOK transient;
	
	// Get assert methods that has doesnt not have Msg as params
	self.getAssertMethodsNoMsg(assertMthNoMsgSet);
	
	// Get the name of the method
	foreach mth in assertMthNoMsgSet do
		assertMsgMthNameCol.add(mth.name);
	endforeach;
	
	// Get all subclass of UT_DSL, where all our unit tests are
	cls.allLocalSubclasses(classes);
	
	foreach cls in classes discreteLock do
		delete methods;
		create methods;
		cls.allMethods(methods);
		
		foreach mth in methods discreteLock do
			self.checkNotUseAssertMsg(mth, sourceNotOK, assertMthNoMsgSet);
		endforeach;
	endforeach;
	
	if sourceNotOK.size() &gt; 0 then
		foreach str in sourceNotOK do
			app.writeStatement(str);
		endforeach;
	endif;
	
	self.assertEqualMsg(sourceNotOK.size(), 0, "1 or more unit tests are not using assertMsg methods. E.g. using 'assertTrue' instead of 'assertTrueMsg'");
	
epilog
	delete sourceNotOK;
	delete classes;
	delete methods;
	delete assertMsgMthNameCol;
	delete assertMthNoMsgSet;
end;</source>
    </JadeMethod>
    <JadeMethod name="tCheckSetConfAndTerminalConf" id="3656cc4a-effd-4a0b-a902-9f8aeb1ff76e">
        <source>tCheckSetConfAndTerminalConf();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 Aug 2025	navhn30	MTN-34211: MTN - Unit Test to check for use of setConfig vs setTerminalConfig - Phase2

*/

vars

	schema		: Schema;
	klass		: Class;
	meth		: Method;
	
	sourceNotOK	: HugeStringArray;
	classes		: ClassColl;
	
	str			: String;
	methodSet   : MethodSet;

begin

	// get the schema
	schema := rootSchema.getSchema("JMTUnitTest");
	self.assertNotNullMsg(schema,"No Schema found");
	
	// get the class
	klass := schema.getClass("UT_UnitTest");
	self.assertNotNullMsg(klass, "No class found");
	
	// get all the subclasses
	create classes transient;
	klass.allLocalSubclasses(classes);
	
	create methodSet transient;
	create sourceNotOK transient;
	
	// go through the class and sub-classes
	foreach klass in classes do
		
		methodSet.clear();
		sourceNotOK.clear();
		klass.allMethods(methodSet);
		foreach meth in methodSet do
			if meth = null  or  (meth.name = "setTerminalConfig" and klass.name = "UT_DSL") then
				continue;
			endif;
			// go through the method and check setConfig and setTerminalConfig
			self.check_SetConfAndTerminalConf(meth, sourceNotOK);
		endforeach;	
		
		if sourceNotOK.size &gt; 0 then
			foreach str in sourceNotOK do
				app.writeLog(str,LogINFO);
			endforeach;
		endif;
	endforeach;
	
	self.assertEqualMsg(sourceNotOK,0,"SetConfig or SetTerminalConfig found");

epilog

	delete classes;
	delete sourceNotOK;
	delete methodSet;
	

end;</source>
    </JadeMethod>
    <JadeMethod name="tClearAuditObjects" id="e639a0d3-45db-4e0d-b5bf-5e1858962329">
        <source>tClearAuditObjects();
// jlgmd1
/*

Purpose:			Clear any old "expired" CM_AuditObject instances from the database.
					Unit Test runs are creating significant numbers of CM_AuditObject instances,
					which should be purged after a short period of time.
					Also very old CM_AuditObject instances should be tidied up from development
					environments as well.
					
Parameters:			None

Return Value:		None

Date		Who		Reason
13 Aug 2012	cnwkpd1	Development environment database size management

*/

constants
	MaxTimeToRun	= 10;			// Max time to run (minutes)
	MaxAuditAge		= 24;			// Maximum "standard" audit age to keep (months)
	MaxUTAuditAge	= 30;			// Maximum Unit Test audit age to keep (days)
	MaxNumDeletes	= 1000000;		// Maximum number of deletes per execution
	MaxTrxTime		= 4000;			// Maximum time between commits (milliseconds)
	UTStartHour		= 0;			// Defines time period when audits are likely to be UT created
	UTEndHour		= 7;			
	UTUserCode		= "UNITTEST";	// Usercode automated tests usually run under 
	
vars
	audit 			: CM_AuditObject;
	oa 				: ObjectArray;
	iter			: Iterator;
	hour			: Integer;
	date			: Date;
	time			: Time;
	firstDateToKeep,
	firstUTDateToKeep	: Date;
	lastCommit		: Decimal[23];
	deletedCount	: Integer;
	now,
	finishTime		: TimeStamp;
	
begin
	create oa transient;
	CM_AuditObject.allInstances(oa, 0, true);
	
	app.writeLog(method.qualifiedName &amp; " - Analysing " &amp; oa.size.String &amp; " CM_AuditObject instances", LogINFO);
	
	now := app.actualTimeServer();
	firstDateToKeep := now.date().addMonths(-1 * MaxAuditAge);
	firstUTDateToKeep := now.date().addDays(-1 * MaxUTAuditAge);
	finishTime := now.addMinutes(MaxTimeToRun);
	
	beginTransaction;
	lastCommit := app.relativeMachineTime();
	
	iter := oa.createIterator();
	while iter.next(audit) do
		
		if app.actualTimeServer() &gt; finishTime then
			app.writeLog(method.qualifiedName &amp; " - Passed maximum run time, exiting", LogINFO);
			break;
		endif;
	
		if app.relativeMachineTime() - lastCommit &gt; MaxTrxTime then
			commitTransaction;
			app.writeLog(method.qualifiedName &amp; " - Deleted " &amp; deletedCount.String &amp; " CM_AuditObject instances, continuing", LogINFO);
			beginTransaction;
			lastCommit := app.relativeMachineTime();
		endif;
		
		date := audit.creationTime.date();

		// Don't delete anything newer than firstUTDateToKeep
		if date &gt;= firstUTDateToKeep then
			continue;
		endif;
		
		// Check time created for anything newer than the firstDateToKeep, and keep any not in the overnight time window
		if date &gt;= firstDateToKeep then
			time := audit.creationTime.time();
			hour := time.hour();
			if audit.userCode &lt;&gt; UTUserCode and (hour &lt; UTStartHour or hour &gt; UTEndHour) then
				continue;
			endif;
		endif;
		
		// Got to here, then the audit can be deleted
		delete audit;
		
		deletedCount := deletedCount + 1;
		if deletedCount &gt;= MaxNumDeletes then
			app.writeLog(method.qualifiedName &amp; " - Deleted maximum number, exiting", LogINFO);
			break;
		endif;
	
	endwhile;
	
	commitTransaction;
	
	app.writeLog(method.qualifiedName &amp; " - Deleted " &amp; deletedCount.String &amp; " CM_AuditObject instances", LogINFO);
	
	
epilog
	delete oa;
	delete iter;

end;</source>
    </JadeMethod>
    <JadeMethod name="tFormTransBlank" id="7b8c80fb-3069-4a92-a727-08e56a9d3025">
        <source>tFormTransBlank();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 July 2018	jlgns1	Initial creation

*/

vars
	 userSummaryDict: CM_AssociationDict ;
begin
	if not app.isDevelopmentSystemMain() and not app.isUnicode then
		create userSummaryDict transient;
	
		xCheckHelpKeywords(true,userSummaryDict);
	endif;	
epilog	
	
	delete userSummaryDict;

end;</source>
    </JadeMethod>
