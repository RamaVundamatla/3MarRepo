    <JadeMethod name="doClearAllRequests" id="23cd0c6f-6330-4597-a19e-f20331721b31">
        <updating/>
        <source>doClearAllRequests() protected, updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 June 2024	navra1	Initial creation for //navra1 - TFS 60149/Task 64397 - 12th June 2024

*/

vars

	controller	: BGP_Controller;
	str			: String;	

begin

	app.mousePointer := MousePointer_HourGlass;	
	if self.myBGPObject.isManager then
		return;
	endif;
	controller := self.myBGPObject.BGP_Controller;
	if global.isValidObject(controller) then
		controller.myBGPManager.doClearAllRequests(controller);
		self.doLoadFutureActorsTable();
	endif;
epilog
	app.mousePointer := MousePointer_Default;	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doClearFutureActorMulti" id="23b56ce4-8c51-48f9-948f-12e6003a5a91">
        <updating/>
        <source>doClearFutureActorMulti(_redisplay : Boolean output) protected, updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 June 2024	navra1	Initial creation for //navra1 - TFS 60149/Task 64397 - 10th June 2024
*/
vars
	objArray : CM_ObjectArrayActual;
	rtnValue : Integer;
begin
	
	create objArray transient;
	self.tblRequests.allSelectedObjects.copy(objArray);
	
	_redisplay := true;
	while true do
		app.myTrxDA.trxDeleteCMObjects(objArray, app.myPassport);
		if app.myPassport.trxCompletedOK then
			// Clear errors/warnings from form and err/warnings window
			self.clearErrorWarnings();
			global.beep;
			break;
		else
			rtnValue := app.showErrorWarningDialog("Deletion", app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   rtnValue = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
			_redisplay := false;
			break;
		endif;
		break;
	endwhile;

epilog
	delete objArray;
end;</source>
        <access>protected</access>
        <Parameter name="_redisplay" type="Boolean" usage="output"/>
    </JadeMethod>
    <JadeMethod name="doClearFutureActorSingle" id="ac4bdd9a-e4c8-4824-a76e-2267bea01baf">
        <updating/>
        <source>doClearFutureActorSingle(_request : CM_Object io; _redisplay : Boolean io) updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 June 2024	navra1	Initial creation for //navra1 - TFS 60149/Task 64397 - 10th June 2024
*/
vars
	rtnValue : Integer;
	invalidObj : Boolean;
	
begin
	on Exception do app.handleDeletedObject(exception,_request,invalidObj);
	
	_redisplay := true;
	while true do
		app.myTrxDA.trxDeleteCMObject(_request, app.myPassport);
		if app.myPassport.trxCompletedOK then
			// Clear errors/warnings from form and err/warnings window
			self.clearErrorWarnings();
			global.beep;
			break;
		else
			rtnValue := app.showErrorWarningDialog("Deletion", app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   rtnValue = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
			_redisplay := false;
			break;
		endif;
		break;
	endwhile;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_request" type="CM_Object" usage="io"/>
        <Parameter name="_redisplay" type="Boolean" usage="io"/>
    </JadeMethod>
    <JadeMethod name="doClearRequest" id="c71c782d-b7f7-44f2-9604-44c900f8ee5b">
        <updating/>
        <source>doClearRequest() protected, updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 June 2024	navra1	Initial creation for //navra1 - TFS 60149/Task 64397 - 13th June 2024

*/

vars
	redisplay : Boolean;	
begin	
	
	redisplay := true;
	
	app.mousePointer := MousePointer_HourGlass;	

	if not self.tblRequests.allSelectedObjects.isEmpty and self.tblRequests.allSelectedObjects.first.isKindOf(CM_OfflineFutureActor) then
		if self.tblRequests.allSelectedObjects.size = 1 then			
			self.doClearFutureActorSingle(self.tblRequests.allSelectedObjects.first.CM_Object, redisplay);
		else
			self.doClearFutureActorMulti(redisplay);
		endif;
	endif;
	
	self.doLoadFutureActorsTable();	
	
epilog
	
	app.mousePointer := MousePointer_Default;	

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doLoadFutureActorsTable" id="fb2fdb33-d7cf-4ae5-8f77-dbd20d067b26">
        <updating/>
        <source>doLoadFutureActorsTable()  updating,protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 June 2024	navra1	Initial creation for //navra1 - TFS 60149/Task 64397 - 10th June 2024
*/

vars
	iter		: Iterator;
	displayStr : String;	
	obj 		: Object;
	offlineActor : CM_OfflineFutureActor;
	invalidActor : Boolean;
	etDef : EntTableDef;
	
	fromDtTime : CM_DateTime;
	toDtTime : CM_DateTime;
	terminal : CM_Terminal;
	reqType : String;
	cargoType : CM_CargoType;
	cargoId : String;
	invalidObj : Boolean;
	
	dyna : DynaDictionary;
	form : CM_BaseForm;
	
begin	
	
	etDef := app.myController.getEntTableDef(ETDef_BgpFutureActors);	
	self.tblRequests.setColumnHeadingsFromDef(etDef.name, false);
	self.tblRequests.setMyEntTableDef(etDef);
	self.tblRequests.setTblDataEntRowsFromDef(etDef);

	if self.offlineFutureActors = null then
		create self.offlineFutureActors transient;
	endif;
	
	self.offlineFutureActors.clear();	
	
	CM_OfflineFutureActor.allInstances(self.offlineFutureActors, null, true);
	
	on Exception do app.handleDeletedObject(exception,offlineActor,invalidActor);	
	
	if self.paginationEnabled then																								//navra1 - TFS 60149/Task 64732 - 25th June 2024
		self.tblRequests.displayCollection(self.offlineFutureActors, false, Table.DisplayCollection_Forward, null);	
		self.tableUsingDisplayCollection := true;
	else																														//navra1 - TFS 60149/Task 64732 - 25th June 2024		
		self.tblRequests.rows := 1;
		form := self;	
		tblRequests.getDataAndDisplayRowsMultith(self.offlineFutureActors, true, form, true);
		self.tableUsingDisplayCollection := false;
	endif;																														//navra1 - TFS 60149/Task 64732 - 25th June 2024
	
	if self.selectedRequestRow &gt; 0 and self.selectedRequestRow &lt;= self.tblRequests.rows then
		self.selectRequest(self.selectedRequestRow, false);
	endif;
	
	if self.tableUsingDisplayCollection then
		self.lblCount.caption := (self.offlineFutureActors.size()).String  &amp; ' table entries(' &amp; (self.tblRequests.rows - 1).String  &amp; ' displayed)';	
		self.filterTable.visible := false;
		self.chkPagination.left:=10;
	else
		self.lblCount.caption := (self.offlineFutureActors.size()).String  &amp; ' table entries';
		self.filterTable.visible := true;
		self.chkPagination.left:=250;
	endif;
	
epilog
	delete iter;	
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doProcessRequest" id="d9379c76-bede-4488-9f6e-9149277920ac">
        <updating/>
        <source>doProcessRequest() protected, updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 June 2024	navra1	Initial creation for for //navra1 - TFS 60149/Task 64397 - 13th June 2024

*/
vars
	selectedObjects : ObjectSet;
	obj : Object;
	isFutureStorage : Boolean;
	futureHandler	: CM_OfflineFutureActorHandler;
	invalidObj 	: Boolean;
begin
	
	on Exception do app.handleDeletedObject(exception,obj,invalidObj);
	create selectedObjects transient;
	create futureHandler transient;
	foreach obj in self.tblRequests.allSelectedObjects do
		if obj.isKindOf(CM_OfflineFutureActor) then
			isFutureStorage:=true;
			futureHandler.processOfflineFutureActorTrx(obj.CM_OfflineFutureActor);
		endif;
	endforeach;
	
	if isFutureStorage then
		self.doLoadFutureActorsTable();
		return;
	endif;
	
epilog
	delete selectedObjects;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="getXMLSettingsForSave" id="092f8588-4a9f-4bc8-b3b3-5e631d06c7c7">
        <updating/>
        <source>getXMLSettingsForSave(): String updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 May 2024	navra1	Initial creation for //navra1 - TFS 60149/Task 64397 - 13th June 2024

*/

vars
	xmlStr : String;
	userName : String;

begin
	xmlStr := inheritMethod();
	
	xmlStr := xmlStr &amp; global.formatAsXML("searchCargoId", self.txtCargoId.text);
	xmlStr := xmlStr &amp; global.formatAsXML("searchCargoIdRegex", self.chkRegex.value.asStringJMT());					//navra1 - TFS 60149/Task 64397 - 1 - 13th June 2024
	xmlStr := xmlStr &amp; global.formatAsXML("searchCargoTypeId", self.cmbCargoType.listIndex.String);
	xmlStr := xmlStr &amp; global.formatAsXML("searchTerminal", self.cmbTerminal.listIndex.String);
	xmlStr := xmlStr &amp; global.formatAsXML("searchRequestType", self.cmbRequestType.listIndex.String);
	xmlStr := xmlStr &amp; global.formatAsXML("searchFromDT", self.mskDateFrom.getDate().asStringJMT());
	xmlStr := xmlStr &amp; global.formatAsXML("searchFromTime", self.mskTimeFrom.getTime().asStringJMT());
	xmlStr := xmlStr &amp; global.formatAsXML("searchToDT", self.mskDateTo.getDate().asStringJMT());
	xmlStr := xmlStr &amp; global.formatAsXML("searchToTime", self.mskTimeTo.getTime().asStringJMT());
	
	xmlStr := xmlStr &amp; global.formatAsXML("paginationEnabled", self.chkPagination.value.asStringJMT());					//navra1 - TFS 60149/Task 64732 - 25th June 2024
	
	return xmlStr;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="initFromUserWindow" id="dc8abfa3-993f-44cf-891e-3d61c080cae2">
        <updating/>
        <source>initFromUserWindow(_userWindow: CM_UserWindow) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 May 2024	navra1	Initial creation for //navra1 - TFS 60149/Task 64397 - 13th June 2024

*/

vars
	idx : Integer;
begin
	inheritMethod(_userWindow);
	
	self.searchCargoId := _userWindow.xmlInfo.cnEcGetTagValueOfName("searchCargoId").String;	
	self.searchCargoIdRegex := _userWindow.xmlInfo.cnEcGetTagValueOfName("searchCargoIdRegex").Boolean;					//navra1 - TFS 60149/Task 64397 - 1 - 13th June 2024
	self.savedCargoTypeIndex := _userWindow.xmlInfo.cnEcGetTagValueOfName("searchCargoTypeId").Integer;	
	self.savedTerminalIndex := _userWindow.xmlInfo.cnEcGetTagValueOfName("searchTerminal").Integer;
	self.savedRequestTypeIndex := _userWindow.xmlInfo.cnEcGetTagValueOfName("searchRequestType").Integer;	
	if self.searchFromDT = null then
		create self.searchFromDT transient;
	endif;
	self.searchFromDT.dateTime.setDate(_userWindow.xmlInfo.cnEcGetTagValueOfName("searchFromDT").Date);
	self.searchFromDT.dateTime.setTime( _userWindow.xmlInfo.cnEcGetTagValueOfName("searchFromTime").Time);
	if self.searchToDT = null then
		create self.searchToDT transient;
	endif;
	self.searchToDT.dateTime.setDate(_userWindow.xmlInfo.cnEcGetTagValueOfName("searchToDT").Date);
	self.searchToDT.dateTime.setTime( _userWindow.xmlInfo.cnEcGetTagValueOfName("searchToTime").Time);	
	
	self.paginationEnabled := _userWindow.xmlInfo.cnEcGetTagValueOfName("paginationEnabled").Boolean;				//navra1 - TFS 60149/Task 64732 - 25th June 2024
	
epilog

end;</source>
        <Parameter name="_userWindow" type="CM_UserWindow"/>
    </JadeMethod>
    <JadeMethod name="load" id="8339f209-b501-4789-97f3-15575eb398cf">
        <controlMethod name="Form::load"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>load() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 June 2024	navra1	Initial creation for //navra1 - TFS 60149/Task 64397 - 10th June 2024

*/

vars
	width  : Real;
	height : Real;
	startLabelLeft : Real;
	startLabelTop : Real;
	etDef : EntTableDef;
	
begin
	inheritMethod();

	width 	:= self.width;
	height	:= self.height;
	
	startLabelLeft := self.width/8;
	startLabelTop := 10;
	
	self.lblRequestType.left := startLabelLeft;
	self.lblRequestType.top :=  startLabelTop;
	self.cmbRequestType.left := startLabelLeft+100;
	self.cmbRequestType.top := startLabelTop;
	
	self.lblDateFrom.left := startLabelLeft-55;
	self.lblDateFrom.top := startLabelTop+30;	
	self.mskDateFrom.left := startLabelLeft-55+153;
	self.mskDateFrom.top := startLabelTop+30;	
	self.mskTimeFrom.left := startLabelLeft-55+233;
	self.mskTimeFrom.top := startLabelTop+30;
	
	self.lblDateTo.left := startLabelLeft-55;
	self.lblDateTo.top := startLabelTop+30+30;	
	self.mskDateTo.left := startLabelLeft-55+153;
	self.mskDateTo.top := startLabelTop+30+30;	
	self.mskTimeTo.left := startLabelLeft-55+233;
	self.mskTimeTo.top := startLabelTop+30+30;
	
	
	self.lblTerminal.left := startLabelLeft+300;
	self.lblTerminal.top :=  startLabelTop;
	self.cmbTerminal.left := startLabelLeft+380;
	self.cmbTerminal.top := startLabelTop;
	
	self.lblCargoType.left := startLabelLeft+300;
	self.lblCargoType.top :=  startLabelTop+30;
	self.cmbCargoType.left := startLabelLeft+380;
	self.cmbCargoType.top := startLabelTop+30;
	
	self.lblCargoId.left := startLabelLeft+300;
	self.lblCargoId.top :=  startLabelTop+30+30;
	self.txtCargoId.left := startLabelLeft+380;
	self.txtCargoId.top := startLabelTop+30+30;
	
	self.chkRegex.left := startLabelLeft+300+250;					//navra1 - TFS 60149/Task 64397 - 1 - 13th June 2024
	self.chkRegex.top := startLabelTop+30+30+2;						//navra1 - TFS 60149/Task 64397 - 1 - 13th June 2024
	
	if self.tableUsingDisplayCollection then
		self.filterTable.top := startLabelTop+30+30+30;	
		self.filterTable.left := 10;
	
		self.chkPagination.top := startLabelTop+30+30+30+13;					//navra1 - TFS 60149/Task 64732 - 25th June 2024
		self.chkPagination.left := 10;									//navra1 - TFS 60149/Task 64732 - 25th June 2024
	else
		self.filterTable.top := startLabelTop+30+30+30;	
		self.filterTable.left := 10;
	
		self.chkPagination.top := startLabelTop+30+30+30+13;					//navra1 - TFS 60149/Task 64732 - 25th June 2024
		self.chkPagination.left := 250;									//navra1 - TFS 60149/Task 64732 - 25th June 2024
	endif;
	
	self.btnRefresh.top := startLabelTop+10;
	self.btnRefresh.left := startLabelLeft+650;						//navra1 - TFS 60149/Task 64397 - 1 - 13th June 2024
	
	self.btnClearTable.top := startLabelTop+45;
	self.btnClearTable.left := startLabelLeft+650;					//navra1 - TFS 60149/Task 64397 - 1 - 13th June 2024
	
	self.tblRequests.left := 10;
	self.tblRequests.top := self.lblCargoId.top + 35+30+10;
	self.tblRequests.height := self.txtCargoId.top +height -250-13;
	self.tblRequests.width := width - 40;
	
	self.lblCount.left := self.tblRequests.left;
	self.lblCount.top := self.tblRequests.top + self.tblRequests.height;
	self.lblCount.caption := '0 table entries';
	
	self.tblRequests.selectMode 		:= CM_DataTable.SelectMode_FixedRow;
	self.tblRequests.selectionType 		:= CM_DataTable.SelectionType_Row;
	self.tblRequests.multiSelect 		:= CM_DataTable.MultiSelect_Simple;
	
	loadTerminalCombo();	
	loadCargoTypeCombo();
	loadRequestTypeCombo();
	
	self.reloadFromSavedCriteria();
	
	etDef := app.myController.getEntTableDef(ETDef_BgpFutureActors);	
	self.tblRequests.setColumnHeadingsFromDef(etDef.name, false);
	self.tblRequests.setMyEntTableDef(etDef);
	self.tblRequests.setTblDataEntRowsFromDef(etDef);
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="loadCargoTypeCombo" id="7255775c-df7e-4be3-8950-d4797a71710f">
        <source>loadCargoTypeCombo() protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 June 2024	navra1	Initial creation for //navra1 - TFS 60149/Task 64397 - 10th June 2024

*/

vars
	cargoType : CM_CargoType;
	iter : Iterator;
begin
	
	cmbCargoType.addItemAt("&lt;&lt;ALL CARGO TYPES&gt;&gt;", 1);
	
	iter := CM_Root.firstInstance().allCargoTypesById.createIterator();
	
	while iter.next(cargoType) do	
		cmbCargoType.addItemObject(cargoType.description, cargoType);	
	endwhile;
	
	cmbCargoType.listIndex := 1;	
	
epilog

	delete iter;
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="loadRequestTypeCombo" id="d7fd43b9-335f-4e10-8598-fbe99d64d428">
        <source>loadRequestTypeCombo() protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 June 2024	navra1	Initial creation for //navra1 - TFS 60149/Task 64397 - 10th June 2024

*/

vars
	
begin	
	
	cmbRequestType.addItemAt("&lt;&lt;ALL FUTURE ACTORS&gt;&gt;", 1);
	cmbRequestType.addItem("Invoice Status Process");
	cmbRequestType.addItem("Future Storage Process");
	cmbRequestType.addItem("Free Storage Expiry Stop Create");
	cmbRequestType.addItem("Cash Receipt Status Process");
	cmbRequestType.addItem("Barrier Code Release Process");
	
	self.cmbRequestType.listIndex := 1;
	
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="loadTerminalCombo" id="82adea1b-b4fb-494b-8b74-f2b785ea29ec">
        <source>loadTerminalCombo() protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 June 2024	navra1	Initial creation for //navra1 - TFS 60149/Task 64397 - 10th June 2024

*/

vars
	t: CM_Terminal;
begin	
	
	cmbTerminal.addItemAt("&lt;&lt;ALL TERMINALS&gt;&gt;", 1);
	foreach t in CM_Root.firstInstance.allTerminals do
		cmbTerminal.addItemObject(t.name, t);	
	endforeach;
	
	self.cmbTerminal.listIndex := 1;
	
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
