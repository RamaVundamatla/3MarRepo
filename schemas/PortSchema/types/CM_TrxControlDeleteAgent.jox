    <JadeMethod name="trxDeleteWorkOrderAndTI" id="a7885f96-9314-4092-aefc-e6d4164fc302">
        <updating/>
        <source>trxDeleteWorkOrderAndTI(_workOrder : CM_WorkOrder input; _allBOLs : ObjectArray input; _manifestNumber : String; _isSingleWO : Boolean; _passport : CM_Passport input) updating;
/*

Purpose:			

Parameters:			
	_isSingleWO : Temporary flag to check whether the single workorder per transport enabled for this manifest(Road, Rail, Ship).
Return Value:		

Date		Who		Reason
12 July 2023	navsp1	Initial creation TFS 58055
17 July 2023	jlirs1	TFS 58884 (57807) 
22/11/2023	navcs2	ChangeRequest 60866: EUP | Manifest - Single Work Order per transport
18/03/2024	navcs2	ChangeRequest 58059[58497]: EUP | Manifest - Change of Transport Mode
22/11/2024 	navsp1  JIRA 33407 EUP | FR 53824 - Unable to update Manifest/VBS Appointment after WO Approved
04/04/2025  navsp1  JIRA-34535 Unit Test Performance Improvement: Transport Manifest related unit tests take Large Time to Finish
11/04/2025	navdap1	12349-EUP - Transport Manifest load after locking does not add all cargo to work order - complete rewrite
*/

vars
	deleteTISet ,
	tisWithWarnSet  : CM_TISet;
	canDeleteWOTI 	: Boolean;
	wodReceive 		: CM_WodReceive;
	wod, wodToDel	: CM_WorkOrderDtl;
	ti 				: CM_TrackedItem;
	tmpTI 			: CM_TrackedItem;
	invalidTi 		: Boolean;
	errorSet		: CM_ErrorSet;
	invalidTI : Boolean;
	object : Object;
	bol : CM_BOL;
	existingCG : CM_CargoGroup;
	obArray : CM_ObjectArray;
	complete : Boolean;									// 18/03/2024 navcs2 ChangeRequest 58059[58497]
	invalidWO : Boolean;
	prevStatus, newStatus : String;
	woDtlArr	: CM_WorkOrderDtlArray;					//JIRA-34535
	canDelWod   : Boolean;								//JIRA-34535
	hadLock : Boolean;
	userCode : String;
begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);
	
	on DeadlockException do agtPassportSilDLckExHandlerFlg(exception, hadLock, _passport);			//navsaa30 16/4/25 #12349

	// Set up the deadlock reply values
	_passport.setupForDeadlockReplay(-200, 300 + app.random(300));
	_passport.silentDeadlockLimit := 5;	
	
	userCode := _passport.getUserCode();			// MTN-12349

	app.setContinueCMExceptions(false);
	
	create deleteTISet transient;
	create obArray transient;
	create errorSet transient;
	canDeleteWOTI := true;
	create woDtlArr transient;						//JIRA-34535
	on Exception do app.handleDeletedObject(exception, ti, invalidTI);      // 17 Jul 2023	jlirs1	TFS 58444 (57807)
	
	foreach wod in _workOrder.allWoDtls do
		wodReceive := wod.CM_WodReceive;
		if not _isSingleWO or (_isSingleWO and wodReceive.taskID = _manifestNumber) then		//04.Jan.2023 navsp1 TFS 61915 / 60866
			wodToDel := wod;
			wodReceive.allSelectedTIs.copyNoDupsToCol(deleteTISet, false);	// 16.Nov.2023 navsp1 TFS 61039
			canDelWod := true;						//JIRA-34535
			foreach ti in wodReceive.allSelectedTIs discreteLock do
				if ti.receivedDT &lt;&gt; null then
					canDeleteWOTI := false;
					break;
				endif;	
				if ti.isAssignedToMultipleWO(_workOrder) then	//22.Aug.2023 navsp1 TFS Bug 59872
					deleteTISet.remove(ti);
					canDelWod := false;				//JIRA-34535
					app.writeLog(method.qualifiedName &amp; Tab &amp; userCode &amp; " Unable to delete the TI("&amp;ti.id&amp;") as it is attached to another Work Order.", LogDEBUG);
				endif;
				if ti.isCargoGroupItem then			// 22/11/2023	navcs2	ChangeRequest 60866
					deleteTISet.remove(ti);			// 22/11/2023	navcs2	ChangeRequest 60866
					canDelWod := false;				//JIRA-34535
				endif;								// 22/11/2023	navcs2	ChangeRequest 60866
			endforeach;
			if canDelWod then						//JIRA-34535
				woDtlArr.add(wodToDel);				//JIRA-34535
			endif;									//JIRA-34535
		endif;
	endforeach;
	
	if not canDeleteWOTI then
		app.writeLog(method.qualifiedName &amp; Tab &amp; userCode &amp; " Unable to delete the work order and TI", LogERROR);
		app.raiseCMException1( WorkOrder_CannotDel_TIReceived, _workOrder.id, null, self);
	endif;
	
	// Loop to cater for deadlock retries
	while true do		: whileLoop
		// START THE TRANSACTION
		beginTransaction;
		app.writeLog(method.qualifiedName &amp; Tab &amp; userCode &amp; " Started the transaction", LogINFO);
		
		// Have we already deleted the work order because we got a deadlock when doing TIs?
		// Don't try again, and make sure we clear any invalid objects from the work order detail array
		on Exception do app.handleDeletedObject(exception, _workOrder, invalidWO);
		_workOrder.edition;
		if invalidWO then
			canDeleteWOTI := false;
			canDelWod := false;
			woDtlArr.rebuild();
			app.writeLog(method.qualifiedName &amp; Tab &amp; userCode &amp; " _workOrder is invalid - rebuilt woDtlArr", LogDEBUG);
		endif;
		// Clear any invalid objects from the TI delete set
		deleteTISet.rebuild();
		// And the cargo group delete array
		obArray.rebuild();
		
		// Clear any Errors/Warnings we might have
		_passport.clearErrorsWarnings();		
		
		//delete WO and TI
		if canDeleteWOTI then	
			//Un-Approve the WO first, if it is already approved.						//JIRA-33407 
			if _workOrder.taskStatus = WO_STATUS_APPROVED then							//JIRA-33407
				prevStatus := app.workOrderStatusEnumToString(_workOrder.taskStatus);	//JIRA-33407			
				_workOrder.doUnapprove(_passport);										//JIRA-33407
				newStatus := app.workOrderStatusEnumToString(_workOrder.taskStatus);	//JIRA-33407
				if prevStatus &lt;&gt; newStatus then											//JIRA-33407
					app.writeLog(method.qualifiedName &amp; " Work Order status temporarily changed from "&amp;prevStatus&amp; " to "&amp;newStatus, LogDEBUG);
				endif;																	//JIRA-33407
			endif;																		//JIRA-33407
			
			if not _isSingleWO or (_isSingleWO and _workOrder.allWoDtls.size &lt; 2) then		//04.Jan.2023 navsp1 TFS 61915 / 60866
				// delete an entire single work order
				app.writeLog(method.qualifiedName &amp; Tab &amp; userCode &amp; " deleting single work order " &amp; _workOrder.id &amp; " with " &amp; _workOrder.allWoDtls.size.String &amp; " details", LogINFO);
				app.myUtilityDA.utlDeleteWorkOrder(_workOrder, _passport);
				
				// Deadlock? try, try and try again &gt;.&gt;
				if hadLock then
					if _passport.silentDeadlockRetryCount &gt; _passport.silentDeadlockLimit then
						// Too many errors!
						app.writeLog(method.qualifiedName &amp; Tab &amp; userCode &amp; " Too many deadlocks trying to delete work order " &amp; _workOrder.id &amp; ", giving up", LogINFO);
						break whileLoop;
					else
						hadLock := false;				
						_passport.silentDeadlockRetryCount := _passport.silentDeadlockRetryCount + 1;
						app.writeLog(method.qualifiedName &amp; Tab &amp; "Deadlock Retry " &amp; _passport.silentDeadlockRetryCount.String &amp; " deleting work order " &amp; _workOrder.id &amp; ", continuing", LogINFO);
						process.sleep(_passport.silentDeadlockSleepTime);
						continue whileLoop;
					endif;
				endif;
				
			elseif _isSingleWO and woDtlArr.isNotEmpty then									//JIRA-34535 - replace wodToDel with the woDtlArr
				// Delete work order details
				woDtlArr.rebuild();
				foreach wod in woDtlArr do												//JIRA-34535
					app.writeLog(method.qualifiedName &amp; Tab &amp; userCode &amp; " deleting multiple work order details - this one is " &amp; wod.getOidString, LogINFO);
					app.myUtilityDA.utlDeleteWorkOrderTaskMani(wod, _passport);				//04.Jan.2023 navsp1 TFS 61915	/ 60866				// 18/03/2024 navcs2 ChangeRequest 58059[58497]
					
					// If we had a deadlock, then try, try and try again &gt;.&gt;
					if hadLock then
						if _passport.silentDeadlockRetryCount &gt; _passport.silentDeadlockLimit then
							// Too many deadlocks!
							app.writeLog(method.qualifiedName &amp; Tab &amp; userCode &amp; " Too many deadlocks deleting work order detail " &amp; wod.getOidString &amp; ", giving up", LogINFO);
							break whileLoop;
						else
							hadLock := false;				
							_passport.silentDeadlockRetryCount := _passport.silentDeadlockRetryCount + 1;
							app.writeLog(method.qualifiedName &amp; Tab &amp; _passport.silentDeadlockRetryCount.String &amp; " deadlocks 2, continuing", LogINFO);
							process.sleep(_passport.silentDeadlockSleepTime);
							continue whileLoop;
						endif;
					endif;
				endforeach;																//JIRA-34535
				
				// Mark work order as completed if we deleted all its tasks
				complete := true;																// 18/03/2024 navcs2 ChangeRequest 58059[58497]
				foreach wod in _workOrder.allWoDtls where wod &lt;&gt; wodToDel do 					// 18/03/2024 navcs2 ChangeRequest 58059[58497]
					if wod.status &lt;&gt; WO_STATUS_COMPLETE then									// 18/03/2024 navcs2 ChangeRequest 58059[58497]
						complete := false;														// 18/03/2024 navcs2 ChangeRequest 58059[58497]
					endif;																		// 18/03/2024 navcs2 ChangeRequest 58059[58497]
				endforeach;																		// 18/03/2024 navcs2 ChangeRequest 58059[58497]
				if complete then																// 18/03/2024 navcs2 ChangeRequest 58059[58497]
					app.writeLog(method.qualifiedName &amp; Tab &amp; userCode &amp; " Completing the work order " &amp; _workOrder.id, LogDEBUG);
					_workOrder.completeMe();													// 18/03/2024 navcs2 ChangeRequest 58059[58497]
				endif;																			// 18/03/2024 navcs2 ChangeRequest 58059[58497]
			endif;
		endif;
			
		// Work order and/or work order details have been deleted / updated
		if _passport.hasErrors then
			_passport.moveErrorsToSet(errorSet);
		endif;
		// Commit what we've done so far
		if _passport.isOkToCommit(false) then
			app.writeLog(method.qualifiedName &amp; Tab &amp; userCode &amp; " Committing what we've done so far - no errors", LogINFO);
			app.cmsCommitTransaction(_passport);
		else
			// Haven't even been able to delete the work order - just bail with whatever errors we have
			app.cmsAbortTransaction();
			_passport.addErrorsFromSet(errorSet);
			app.writeLog(method.qualifiedName &amp; Tab &amp; userCode &amp; " We had errors so bailing from the transaction - " &amp; _passport.getErrorsAsString, LogINFO);
			break;
		endif;
		_passport.initialiseTransaction();
		app.writeLog(method.qualifiedName &amp; Tab &amp; userCode &amp; " Beginning transaction to delete TIs", LogDEBUG);
		// Start the next set of transactions
		beginTransaction;
		
		// Now delete TIs associated with the deleted work order or work order detail
		on SystemException do app.cnHandleNullOrInvObjectRef(exception, tmpTI, invalidTi);//navsp1 UT fixes
		foreach tmpTI in deleteTISet do
			invalidTi := false;
			exclusiveLock(tmpTI);
			if invalidTi then	//30 May 2013	NDL	Par 31548
				app.writeLog(method.qualifiedName &amp; Tab &amp; userCode &amp; " Invalid TI - continuing", LogDEBUG);
				continue;
			endif;
			
			if tmpTI.myCargoGroup &lt;&gt; null and not obArray.includes(tmpTI.myCargoGroup) then		//20.Nov.2023 navsp1 TFS 61039
				obArray.add(tmpTI.myCargoGroup);
			endif;
			
			app.myUtilityDA.utlDeleteTI(tmpTI, false, _passport);
			
			// Deadlock? Retry
			if hadLock then
				if _passport.silentDeadlockRetryCount &gt; _passport.silentDeadlockLimit then
					// Too many deadlocks
					app.writeLog(method.qualifiedName &amp; Tab &amp; userCode &amp; " Too many deadlocks deleting TI " &amp; tmpTI.id &amp; " - giving up at this point", LogINFO);
					break whileLoop;
				else
					hadLock := false;				
					_passport.silentDeadlockRetryCount := _passport.silentDeadlockRetryCount + 1;
					app.writeLog(method.qualifiedName &amp; Tab &amp; _passport.silentDeadlockRetryCount.String &amp; " deadlocks deleting TI " &amp; ti.id &amp; ", continuing", LogINFO);
					process.sleep(_passport.silentDeadlockSleepTime);
					continue whileLoop;
				endif;
			endif;
			
			// Did we succeed in deleting the TI?
			if _passport.isOkToCommit(false)  then
				app.cmsCommitTransaction(_passport);
				_passport.initialiseTransaction();
			else
				app.cmsAbortTransaction();
				app.writeLog(method.qualifiedName &amp; Tab &amp; userCode &amp; " Aborted after trying to delete TI " &amp; tmpTI.id &amp; " errors are " &amp; _passport.getErrorsAsString, LogINFO);
				_passport.initialiseTransaction();
				if invalidTi then	//30 May 2013	NDL	Par 31548
					continue;
				endif;
				_passport.moveErrorsToSet(errorSet);
			endif;
			beginTransaction;
			
		endforeach;
		
		// Now delete any cargo groups					//20.Nov.2023 navsp1 TFS 61039
		obArray.rebuild();
		foreach object in obArray do
			existingCG := object.CM_CargoGroup;
			if existingCG.allAssignedTrackedItems.size = 0 then
				app.writeLog(method.qualifiedName &amp; Tab &amp; userCode &amp; " Trying to delete cargo group " &amp; existingCG.id, LogDEBUG);
				app.myUtilityDA.utlDeleteTI(object.CM_CargoGroup, false, _passport);					
			endif;
			if _passport.isOkToCommit(false)  then
				app.cmsCommitTransaction(_passport);
				app.writeLog(method.qualifiedName &amp; Tab &amp; userCode &amp; " Cargo group deleted", LogDEBUG);
			else
				app.writeLog(method.qualifiedName &amp; Tab &amp; userCode &amp; " Failed to delete Cargo group - " &amp; _passport.getErrorsAsString, LogDEBUG);
				_passport.moveErrorsToSet(errorSet);
				app.cmsAbortTransaction();
			endif;
			_passport.initialiseTransaction();
			beginTransaction;
		endforeach;
			
		// Finally delete any BOLs
		_allBOLs.rebuild();
		foreach object in _allBOLs do
			bol := object.CM_BOL;
			app.writeLog(method.qualifiedName &amp; Tab &amp; userCode &amp; " Trying to delete BOL " &amp; bol.number, LogINFO);
			app.myUtilityDA.utlDeleteBOL(bol, _passport);
			
			// Deadlock? Retry
			if hadLock then
				if _passport.silentDeadlockRetryCount &gt; _passport.silentDeadlockLimit then
					// Too many errors!
					app.writeLog(method.qualifiedName &amp; Tab &amp; "Too many deadlocks deleting BOL " &amp; bol.number &amp; " - giving up at this point", LogINFO);
					break whileLoop;
				else
					hadLock := false;				
					_passport.silentDeadlockRetryCount := _passport.silentDeadlockRetryCount + 1;
					app.writeLog(method.qualifiedName &amp; Tab &amp; _passport.silentDeadlockRetryCount.String &amp; " Deadlocks deleting BOL " &amp; bol.number &amp; ", continuing", LogINFO);
					process.sleep(_passport.silentDeadlockSleepTime);
					continue whileLoop;
				endif;
			endif;
		endforeach;
		
		// Got this far, all done
		app.writeLog(method.qualifiedName &amp; Tab &amp; userCode &amp; " Phew finished", LogINFO);
		break;
	endwhile;
	
	_passport.addErrorsFromSet(errorSet);
	
epilog
	app.writeLog(method.qualifiedName &amp; Tab &amp; userCode &amp; " epilog - passport errors are " &amp; _passport.getErrorsAsString, LogINFO);
	_passport.resetSilentDeadlockHandler;	//11/4/25 navsaa30 #12349
	self.finaliseActivityWithPassport(_passport);
	if _passport.trxCompletedOK() then	// 18 Jul 2023	jlirs1	TFS 58056 (58444)
		_passport.doTrxPostActions();		
	endif;
	delete errorSet;
	delete tisWithWarnSet;
	delete deleteTISet;
	delete obArray;
	delete woDtlArr;		//JIRA-34535
end;</source>
        <Parameter name="_workOrder" type="CM_WorkOrder" usage="input"/>
        <Parameter name="_allBOLs" type="ObjectArray" usage="input"/>
        <Parameter name="_manifestNumber" type="String"/>
        <Parameter name="_isSingleWO" type="Boolean"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxDeleteWorkOrderSchedule" id="3d5d7677-9ba0-490c-b6b3-0557e0f3c2b5">
