    <JadeMethod name="drawSelf" id="27792943-f0d8-4cd3-83d2-aadeb7b6d82a">
        <updating/>
        <source>drawSelf(pFrame: CMUI_Frame) updating;
// ---------------------------------------------------------------------------
// Created:     22 January 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
constants
	LeftTextMargin	: Integer = 10;

vars

	yPoint : Integer;
	textHeight : Integer;
	pointHeight : Integer;
	caption : String;
	frame	: CMUI_Frame;

begin
	if self.label[1:1] &lt;&gt; "_" then
		caption := self.label;
	endif;
	if self.label[1:1] = "&lt;" then
		caption := self.label[4:end];
	endif;
	// TFS 3422 stretch the row frame width for irregular block stacks only to fit the area description
	frame := pFrame;
	frame.width := 40;
	if self.myGridArea.isKindOf(YRD_PadArea) then
		if self.myGridArea.YRD_PadArea.type = TA_TYPE_IRREGULAR_BLOCK_AREA then
			frame.width := 100;
		endif;
	endif;

	pointHeight := (y2 - y1).Integer;
	textHeight := pFrame.getTextHeight(self.label.trimBlanks);
	yPoint := (y1 + ((pointHeight - textHeight) / 2)).Integer;
	pFrame.drawTextAt(caption.trimBlanks, LeftTextMargin, yPoint, Black);

end;</source>
        <Parameter name="pFrame" type="CMUI_Frame"/>
    </JadeMethod>
