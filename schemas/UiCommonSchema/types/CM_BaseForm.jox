    <JadeMethod name="doResetDefaultPrinter" id="e553af01-a2e6-40e6-b60b-d94ce902e65e">
        <updating/>
        <source>doResetDefaultPrinter() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 December 2017	jlgndl1	Initial creation	TFS 8086

*/

vars

	printerName : String;
	transUserWindow	: CM_UserWindowForOpen;
	user : CM_User;

begin

	on Exception do app.handleNoDefaultPrinter(exception, false);

	printerName := null;
	app.printer.setPrinter( printerName );
	
	user := app.getMyUser;
	transUserWindow := app.getUserWindow(self.name, true);	// gets the transient creating if necessary.
	if transUserWindow &lt;&gt; null then 
		transUserWindow.setProxy( user, self.name, self.getXMLSettingsForSave(), self.top, self.left, self.width, self.height, self.windowState );
		app.myTrxUA.trxUpdateUserWindow( user, transUserWindow, app.myPassport );
		if app.myPassport.noErrors then
			app.allUserWindows.remove(transUserWindow);
			delete transUserWindow;
			app.getUserWindow(self.name, true);	// creat=es a new transient for use in teh close / exit process.
		endif;
	endif;

epilog

end;</source>
    </JadeMethod>
