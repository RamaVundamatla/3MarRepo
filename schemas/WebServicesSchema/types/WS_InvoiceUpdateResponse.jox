<Class name="WS_InvoiceUpdateResponse" id="ca4ce019-f919-4db2-9b47-afdc2c495ace">
    <superclass name="WS_Response"/>
    <transient/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="webservice"/>
    <ImplicitInverseRef name="myInvoice" id="43c8c9c4-9957-49eb-930e-24791e3c5bcd">
        <embedded/>
        <type name="WS_Invoice"/>
    </ImplicitInverseRef>
    <JadeMethod name="delete" id="a36e8f35-6851-48bc-a882-2c46f6edcf4c">
        <updating/>
        <source>delete() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 September 2018	jlgndl1	Initial creation	TFS 40889

*/

vars

begin

	delete self.myInvoice;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setMyInvoice" id="b4bb58db-df73-4720-962e-aeefda6e5b41">
        <updating/>
        <source>setMyInvoice( invoice : CM_Object ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 September 2018	jlgndl1	Initial creation	TFS 40889

*/

vars

	ws_Invoice : WS_Invoice;

begin

	if self.myInvoice &lt;&gt; null then
		delete self.myInvoice;
		self.myInvoice := null;
	endif;
	
	if invoice &lt;&gt; null then
		create ws_Invoice transient;
		self.myInvoice := ws_Invoice;
		//epr TFS 41012 3/10/18 make it work with cash receipts
		if invoice.isKindOf(CM_Invoice) then
			ws_Invoice.setProxyFromObject( invoice.CM_Invoice );
		elseif invoice.isKindOf(CM_CashReceipt) then
			ws_Invoice.setFromCashReceipt(invoice.CM_CashReceipt);
		endif;
	endif;

epilog

end;</source>
        <Parameter name="invoice" type="CM_Object"/>
    </JadeMethod>
</Class>
