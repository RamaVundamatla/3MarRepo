    <JadeMethod name="standardRelease" id="23bb2f4f-654d-44fe-aa1e-67d438b3e078">
        <updating/>
        <source>standardRelease(pControllerObj: CnEcReleaseController) updating;
// --------------------------------------------------------------------------------
// Created:		19 August 2001 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	inheritMethod(pControllerObj);
	pControllerObj.logEntry('***** Processing release for ' &amp; self.class().name &amp; '... *****');
end;</source>
        <Parameter name="pControllerObj" type="CnEcReleaseController"/>
    </JadeMethod>
