    <JadeMethod name="getVoyageMoveTypeDescr" id="c598c968-cb4c-4d79-9b93-88bf324f0e3e">
        <source>getVoyageMoveTypeDescr(_moveType : Integer) : String;
/* ---------------------------------------------------------------------------
Created:     06 July 2010 by cnwrs2

Purpose:     
        
Change Date	Who		Reason

------------------------------------------------------------------------------*/
vars
	transitStatus	: CM_TransitStatus;
begin

	// Deliberately do not return translated strings here as that would return
	// the string for the user who created the kpi, and not the current user

	if _moveType = VoyageMoveType_Discharge then
		return 'Discharge';
	elseif _moveType = VoyageMoveType_Load then
		return 'Load';
	elseif _moveType = VoyageMoveType_DLR then
		transitStatus := app.myRoot.allTransitStatuses[VoyageMoveType_DLR];
		if transitStatus &lt;&gt; null then
			return transitStatus.abbreviation;
		endif;
		return 'DLR';
	elseif _moveType = VoyageMoveType_SOB then
		transitStatus := app.myRoot.allTransitStatuses[VoyageMoveType_SOB];
		if transitStatus &lt;&gt; null then
			return transitStatus.abbreviation;
		endif;
		return 'SOB';
	else
		return null;
	endif;
	
epilog

end;</source>
        <Parameter name="_moveType" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getVoyageStageFromDesc" id="63b59e4a-a74e-4509-9a27-a055194d07cb">
        <source>getVoyageStageFromDesc(_desc : String) : Integer;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
//20/06/2024	navkc1 CR 64611 Task 64623: Jade - New Voyage Process

*/

vars

begin
	if _desc = app.getErrorString(VoyStage_DischManLoadStr) then
		return CM_VoyageStage.VoyStage_DischManLoad;
	elseif _desc = app.getErrorString(VoyStage_LoadManLoadStr) then
		return CM_VoyageStage.VoyStage_LoadManLoad;
	elseif _desc = app.getErrorString(VoyStage_LoadListLoadStr) then
		return CM_VoyageStage.VoyStage_LoadListLoad;
	elseif _desc = app.getErrorString(VoyStage_DischListLoadStr) then
		return CM_VoyageStage.VoyStage_DischListLoad;
	elseif _desc = app.getErrorString(VoyStage_LoadCompLoadStr) then
		return CM_VoyageStage.VoyStage_LoadCompLoad;
	elseif _desc = app.getErrorString(VoyStage_DischCompLoadStr) then
		return CM_VoyageStage.VoyStage_DischCompLoad;
	elseif _desc = app.getErrorString(VoyStage_DischManMovedStr) then
		return CM_VoyageStage.VoyStage_DischManMoved;
	elseif _desc = app.getErrorString(VoyStage_LoadManMovedStr) then
		return CM_VoyageStage.VoyStage_LoadManMoved;
	elseif _desc = app.getErrorString(VoyStage_InvoiceGeneratedStr) then
		return CM_VoyageStage.VoyStage_InvoiceGenerated;
	elseif _desc = app.getErrorString(VoyStage_InvoicePostedStr) then
		return CM_VoyageStage.VoyStage_InvoicePosted;
	elseif _desc = app.getErrorString(VoyStage_VoyageClosedStr) then
		return CM_VoyageStage.VoyStage_VoyageClosed;
	endif;
	
	return null;
epilog

end;</source>
