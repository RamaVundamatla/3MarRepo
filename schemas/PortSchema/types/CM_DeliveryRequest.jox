    <JadeMethod name="getLocnsForAnyIdAnyAmount" id="74701dee-293a-46d4-9cca-9651cac91dac">
        <source>getLocnsForAnyIdAnyAmount( _locations : CM_LCArray input; _cargoTypeStrings : StringArray512 input );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 September 2018	jlgndl1	Initial creation	TFS 39950

*/

vars

	iter : Iterator;
	resDetail : CM_ReserveDetail;
	ti : CM_TrackedItem;
	lc : CM_LocationsController;
	index : Integer;
	allCargoTypes : ObjectArray;
	cargoTypes : CM_CargoTypeSet;
	cargoType : CM_CargoType;
	cargoTypeString : String;
	cts : String;

begin

	create allCargoTypes transient;

	if self.myOriginatingBulkRelease = null then
		return;
	endif;

	iter := self.myOriginatingBulkRelease.allReserveDetails.createIterator();
	while iter.next( resDetail) do
		if not resDetail.isAllocationById then
			//its by type...  nothing here for us.
			continue;
		endif;
		ti := resDetail.CM_ReserveTI.getTI;
		if not ti.isOnSite then
			continue;
		endif;
		if not ti.isTiAvailableForAnyIdSelection then
			continue;
		endif;
		lc := ti.myPrimaryActualLocation.CM_LocationsController;
		if lc.isVehicle
		or lc.isMachineController
		then
			//not one we want to allow
			continue;
		endif;
		cargoType := ti.myCargoType;
		index := _locations.indexOf( lc ); 
		if index &lt; 1 then
			// add new location, and first cargo type
			_locations.add( lc );
			create cargoTypes transient;
			cargoTypes.add( cargoType );
			allCargoTypes.add( cargoTypes );
		else
			//add extra cargo type to existing location if not already there
			cargoTypes := allCargoTypes[ index ].CM_CargoTypeSet;
			if not cargoTypes.includes( cargoType ) then
				cargoTypes.add( cargoType );
			endif;
		endif;
	endwhile;
	
	if not _locations.isEmpty then
		foreach index in 1 to _locations.size do
			cargoTypes := allCargoTypes[ index ].CM_CargoTypeSet;
			foreach cargoType in cargoTypes do
				cts := cargoType.description.trimBlanks;
				if cts = null then
					cts := cargoType.abbreviation.trimBlanks;
				endif;
				if cargoTypeString = null then
					cargoTypeString := cts;
				elseif ( cargoTypeString.length + 2 + cts.length ) &lt; 512 then
					cargoTypeString := cargoTypeString &amp; ", " &amp; cts;
				else
					break;
				endif;
			endforeach;
			_cargoTypeStrings[index] := cargoTypeString;
			cargoTypeString := null;
		endforeach;
	endif;

epilog

	delete iter;
	delete allCargoTypes;

end;</source>
        <Parameter name="_locations" type="CM_LCArray" usage="input"/>
        <Parameter name="_cargoTypeStrings" type="StringArray512" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getMark" id="71d40366-b0ce-48cc-bed9-b7044b897d4a">
