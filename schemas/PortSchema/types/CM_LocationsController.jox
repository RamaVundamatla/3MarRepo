    <JadeMethod name="executePostMoveForOrigLocation" id="7c4011e4-0a82-49c3-9ef1-901d591ae2c6">
        <updating/>
        <source>executePostMoveForOrigLocation(control : CMIF_MoveController; _passport : CM_Passport input)updating;
/*
 ------------------------------------------------------------------------
Created:			04 November 2003 by cnwgd1
Purpose:			Move has been done, transaction has been written. Prior location has been set.
							(see CM_TrackedItem::executeControlPostMove). Do any work required on the
							locations controller here.
Parameters:		None
Returns:			Nothing
Changed On		Changed By		Reason
--------------		--------------		-----------------------------------------
---------------------------------------------------------------------------
*/
vars
begin
	if control = null then
		app.setContinueCMExceptions(false);
		app.raiseUnexpectedProgramError(class.name, method.name, 'Null _moveController. Contact Developer.');
		return;
	endif;
	
	if self.myTerminalArea &lt;&gt; null then
		self.myTerminalArea.handleAutoRestrictionsFrom(control, _passport);
	endif;
	
	self.updateGridLocationQueueEntries(); //cnwrd1 par 31239 send notes for gridded area height display
end;</source>
        <Parameter name="control" type="CMIF_MoveController"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
