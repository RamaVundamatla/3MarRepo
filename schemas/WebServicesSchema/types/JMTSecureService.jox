<JadeWebServiceProviderClass name="JMTSecureService" id="51f226ff-367a-472d-8f70-de89d6663626">
    <superclass name="WS_WebServiceProvider"/>
    <transient/>
    <sharedTransientAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>The JMTSecureService provides all the User and Session management services.  Prior to using any of the web services provided, an external client must complete a successful logon and use the returned JadeSessionHeader sessionId for all subsequent requests.</text>
    <JadeWebServicesMethod name="changePassword" id="7ff0845b-c274-43ff-b250-ed1152c33bdf">
        <usesRPC>default</usesRPC>
        <source>changePassword(oldPass, newPass, newPass2: String) : String webService;

/*

Purpose:			Change password of current logged on User

Parameters:			Old password, and new password to be validated (twice)

Return Value:		Null string for a successful change, error message otherwise


Date		Who		Reason
17 Dec 2008	cnwkpd1	PAR #17554 - Development of new RIA Web Service application

*/


vars
	errorString		: String;
	error			: CM_Error;
	completedOK		: Boolean;
	user			: CM_User;

begin
	// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);
	
	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	
	// Initialise the passport for the new transaction
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	
	user := app.getMyUser();
	if user = app.myPublicUser then
		return null;
	endif;
	
	app.myTrxUA.trxUpdatePassword(true, user.code, oldPass, newPass, newPass2, app.myPassport);
	
	completedOK := true;

	if app.myPassport.trxCompletedOK then
		return null;
	else
		foreach error in app.myPassport.allErrors do
			errorString := errorString &amp; error.text &amp; CrLf;
		endforeach;
		
		return errorString;
	endif;	

	
epilog
	if not completedOK then
		cnSetTransactionError(true);
	endif;
	
	cnEndTransaction;			

end;
</source>
        <wsdlName>changePassword</wsdlName>
        <Parameter name="oldPass" type="String"/>
        <Parameter name="newPass" type="String"/>
        <Parameter name="newPass2" type="String"/>
        <ReturnType type="String"/>
    </JadeWebServicesMethod>
    <JadeMethod name="forceOffOldSessions" id="45394ebd-ed15-4518-aabe-ec860af92c90">
        <source>forceOffOldSessions(_passport: CM_Passport input) protected;
/*

Purpose:			Allows log on of users with "Single User Session" enabled, by forcing off any existing sessions they may have.
					NB. This should not apply to "external" web service calls made via the 'logon' request - we only want this for our .net apps.
					Users require the "Single User Session Allow Override" config set to use this method.

Parameters:			

Return Value:		

Date			Who		Reason
16 August 2021	navmd1	Initial creation TFS 51226
26 May 2025		navnk30 JIRA 34707: SSO Implementation for Mobile App - Jade Portion

*/

vars
	user			: CM_User;
	oldWebSession	: WebSession;
	invalidSession	: Boolean;
	oldWSAppName,
	sessionId		: String;
	result			: Integer;
	resultStr		: String;
	proc			: Process;
	machine			: CM_Machine;
begin
	user := _passport.myUser;
	
	if user &lt;&gt; null and user.getUserSingleSignAllowOverride() then
		// Ignore sessions that might be killed while we're working with them
		on Exception do app.handleDeletedObject(exception, oldWebSession, invalidSession);

		// Look for any existing WEB sessions the user may have thats preventing them from logging in.
		while app.myRoot.hasCurrentWebSession(user, oldWSAppName, oldWebSession) do
			sessionId := oldWebSession.getPropertyValue('_encryptedSessionId').String;
			app.writeLog(user.code &amp; " is forcing off Old Web Session " &amp; sessionId, LogWARN);
			machine := oldWebSession.SWebServiceSchema.myCurrentMachine;
			app.myTrxUA.trxUpdateLogoff(machine, _passport);			
			
			// Next, try and reset any process names that match our machine
			// ... this may or may not be a good idea - although setting the process name on a web service doesn't make much sense either
			if machine &lt;&gt; null then
				beginTransaction;
				foreach proc in node.processes do
					if proc.userCode = machine.code then
						proc.changeUserCode(proc.signOnUserCode);
					endif;
				endforeach;
				commitTransaction;
			endif;
			
			oldWebSession.removeSession();
		endwhile;
	else
		//app.writeLog("User (" &amp; _request.userId &amp; ") requested to Force Off old sessions, but doesn't have permission to do so", LogERROR);	//26.05.2025 navnk30 JIRA 34707
		if user &lt;&gt;	null then	//26.05.2025 navnk30 JIRA 34707
			app.writeLog("User (" &amp; user.code &amp; ") requested to Force Off old sessions, but doesn't have permission to do so", LogERROR);
		endif;
		result := Err_InsufficientPermission;
		resultStr := app.getErrorString(result);
		_passport.addErrorFull(result, resultStr, null, null, null);
	endif;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="logIncomingMessage" id="c9281d82-2fdf-45fa-b4cf-220963634975">
