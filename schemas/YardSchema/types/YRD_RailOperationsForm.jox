        <updating/>
        <source>frmGridArea_dragOver(frame: Frame input; win: Window input; x: Real; y: Real; state: Integer) updating;
// -----------------------------------------------------------------------------
// Created:		16 July 2009 by consw1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
// 16/07/2009	consw1		Par 20293 - UE 1090
// -----------------------------------------------------------------------------

vars

begin
	if app.myMoveController &lt;&gt; null or app.myWagonMoveController &lt;&gt; null then
		if app.activeForm &lt;&gt; self then
			self.setFocus();
			self.zOrder(1);
		endif;
	endif;

epilog

end;</source>
        <Parameter name="frame" type="Frame" usage="input"/>
        <Parameter name="win" type="Window" usage="input"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
