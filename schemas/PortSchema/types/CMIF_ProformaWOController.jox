    <JadeMethod name="cleanupProformaReferences" id="a0c14ff5-62ce-4670-85f0-a981e49b35e3">
        <source>cleanupProformaReferences();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 June 2018	jlgab1	Initial creation

*/

vars
	agent : CM_CashProformaWorkOrderAgent;
	obj : Object;

begin
	foreach obj in self.allAgents	discreteLock do
		agent := obj.CM_CashProformaWorkOrderAgent;
		
		if agent.myTrackedItem &lt;&gt; null then
			if not global.isValidObject(agent.myTrackedItem) then
				agent.nullMyTrackedItem();
			endif;
		endif;
	endforeach;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="createPxyWOTransaction" id="c393dcf6-1caf-4a26-b804-a51bfc890343">
        <source>createPxyWOTransaction(_tranType : Integer) : CM_WOTransaction;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 June 2018	jlgab1	Initial creation

*/

vars

	woTransaction : CM_WOTransaction;

	numItemsRBT : Integer;
	aClass : Class;
begin

	aClass := global.getTiTxnClassForType(_tranType, false);

	create woTransaction as aClass transient;	

	woTransaction.setBaseAttributes( app.serverTimestampAtTrxStart, self.myWorkOrder, _tranType, self.myWorkOrder.getMyTerminal()); 
	
	return woTransaction;

epilog

end;</source>
        <Parameter name="_tranType" type="Integer"/>
        <ReturnType type="CM_WOTransaction"/>
    </JadeMethod>
    <JadeMethod name="createWOTransaction" id="ae02e1e3-1ffa-480f-9d4a-e53ec31502f6">
        <source>createWOTransaction(_tranType : Integer) : CM_WOTransaction;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 June 2018	jlgab1	Initial creation

*/

vars

	woTransaction : CM_WOTransaction;
	numItemsRBT : Integer;
	aClass : Class;
begin

	aClass := global.getTiTxnClassForType(_tranType, false);

	create woTransaction as aClass persistent;	

	woTransaction.setBaseAttributes( app.serverTimestampAtTrxStart, self.myWorkOrder, _tranType, self.myWorkOrder.getMyTerminal()); 
	
	return woTransaction;

epilog

