    <JadeMethod name="doPrintHistory" id="490956fe-ee7f-4a6e-ad9c-2ce1136d7dff">
        <source>doPrintHistory();
// ---------------------------------------------------------------------------
// Created:     10 January 2006	cnwhjg1
//
// Purpose:     
// ----------   ----------  --------------------------------------------------
vars
	machine		: CM_Machine;
	tempStr		: String;
	theForm		: SOP_TableMaintForm;
	
begin
	// cnwrl1 19/05/2009 PAR 19668 - CCMS 1814 - start of coding
	// Change to print either the move History or the Interface History depending on which sheet is active.
	theForm	:= self.myForm;
	machine	:= theForm.myCurrentObject.CM_Machine;
	if machine = null then
		// hopefully never happens but just in case...
		return;
	endif;
	
	if theForm.fldInput.topSheet &lt;&gt; theForm.shtViewTable1 and theForm.fldInput.topSheet &lt;&gt; theForm.shtViewTable3 then
		return;
	endif;
	
	if theForm.fldInput.topSheet = theForm.shtViewTable1 then
		if machine.history.isEmpty then
			return;
		endif;
		tempStr	:= app.getErrorString1( Move_History, machine.getDisplayDetails( false ) );
		theForm.doPrintOutTable( theForm.tblDataView1, tempStr, true, true, false, true );
	else
		if machine.allInterfaceHistories.isEmpty then
			return;			// nothing to actually print
		endif;
		tempStr	:= app.getErrorString1( Interface_History, machine.getDisplayDetails( false ) );
		// now print out using preview, whiteBG not useOrigTableColumnWidths and portrait mode
		theForm.doPrintOutTable( theForm.tblDataView3, tempStr, true, true, false, true );
	endif;

	
end;</source>
    </JadeMethod>
    <JadeMethod name="doSave" id="ddd3e023-9a7d-4a96-b4ba-32d5852d8c1e">
        <updating/>
        <source>doSave() : Boolean updating;
// ---------------------------------------------------------------------------
// Created:     17 December 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 27/11/2014   cnwma1      PAR #35281 Terminal Admin Machines
// 02 Oct  2018    cnwma1  ChangeRequest 41234: SAP Integration - Mapping fields
// ---------------------------------------------------------------------------
vars
	theForm			:SOP_TableMaintForm;
	theTable1,
	theTable2		:CM_EntryTable;
	proxyMachine	:CM_Machine;
    intMachineType	: Integer;
    cmif_Machine	:CMIF_Machine;
    tmpJT : CM_JobType;
	
begin
	theForm := self.myForm;
	theTable1 := theForm.tblInput1;
	theTable2 := theForm.tblInput2;
	create cmif_Machine transient;
	
	cmif_Machine.code := theForm.tblInput1.getValueByName(ETRow_Id).String;
	cmif_Machine.description := theForm.tblInput1.getValueByName(ETRow_Description).String;
	cmif_Machine.externalRef := theForm.tblInput1.getValueByName(ETRow_ExternalRef).String;  //02.10.2018 cnwma1 TFS #41234
    cmif_Machine.machineType := theForm.cmbMachineType.listObject.CM_MachineType;
    if (cmif_Machine.machineType &lt;&gt; null) then
	    intMachineType := cmif_Machine.machineType.type;
	else
		app.raiseCMException1(ERR_MACH_TYPE_NULL, cmif_Machine.code, null, null); //03/07/2009 cnwdz2 par20171
		return false;
 	endif;
    
  	cmif_Machine.colour 					:= theTable1.getValueByName(ETRow_Colour).Integer;
	cmif_Machine.available 					:= theTable1.getValueByName(ETRow_Available).Boolean;
    cmif_Machine.canLift40Foot 				:= theTable1.getValueByName(ETRow_CanLift40Foot).Boolean;
    cmif_Machine.canLift30Foot 				:= theTable1.getValueByName(ETRow_CanLift30Foot).Boolean; // PAR 16415 CCMS 1029
    cmif_Machine.canLift45Foot 				:= theTable1.getValueByName(ETRow_CanLift45Foot).Boolean; // PAR 16415 CCMS 1029
    cmif_Machine.canLift53Foot 				:= theTable1.getValueByName(ETRow_CanLift53Foot).Boolean; // PAR 16415 CCMS 1029
	//12 Mar 2014	NDL	Par 33268
	cmif_Machine.maxLiftWeight := self.getConvertedDisplayValue( ETRow_MaxLiftWeight, weightType ).Integer;
	
    cmif_Machine.minItemsForTLJob 			:= theTable1.getValueByName(ETRow_MinItemsForTLJob).Integer; // CCMS 1529
    cmif_Machine.maxLiftWeightTL 			:= theTable1.getValueByName(ETRow_MaxLiftWeightTL).Integer; // CCMS 1061
	
    cmif_Machine.maxStackHeightMT 			:= theTable1.getValueByName(ETRow_MaxStackHeightEmpty).Real;
    cmif_Machine.maxStackHeightFull 		:= theTable1.getValueByName(ETRow_MaxStackHeightFull).Real;
    cmif_Machine.isNotAvailableForEntry		:= theTable1.getValueByName(ETRow_NotAvailableForEntry).Boolean;
	cmif_Machine.myRFIDTag					:= theForm.cmbRFIDTag.listObject.CM_RFIDTag;
	//cmif_Machine.weightDifference			:= theTable1.getValueByName(ETRow_WeightDifference).Integer;	// ccms jmt 1032, Par18649. Dec 2008  // -cnwma1 28/11/2014 cnwma1 PAR #35281
	cmif_Machine.weightDifference			:= self.getConvertedDisplayValue(ETRow_WeightDifference, weightType).Integer;						   // +cnwma1 28/11/2014 cnwma1 PAR #35281
	//12 Mar 2014	NDL	Par 33268
	cmif_Machine.tareWeight := self.getConvertedDisplayValue( ETRow_TareWeight, weightType ).Integer;
	
	cmif_Machine.machineLiftType			:= theForm.myAssistant.getMachineLiftType(null, theForm.cmbMchLiftType.text).Integer;//CCMS 1595
	cmif_Machine.loadingPosition			:= theForm.cmbMchLoadPos.getCurrentItemData();
	cmif_Machine.interactionType			:= theForm.cmbRMGInter.getCurrentItemData();
	cmif_Machine.myPhysicalStartBay			:= theForm.cmbMachPhyStart.listObject.CM_RTGColumn;
	cmif_Machine.myPhysicalEndBay			:= theForm.cmbMachPhysEnd.listObject.CM_RTGColumn;
	cmif_Machine.bucketVolume				:=self.getConvertedDisplayValue(ETRow_BucketVolume,app.getDefaultMeasurementForType(Type_Volume)).Decimal;
	
	tmpJT := self.myForm.cmbJobType_1.listObject.CM_JobType;
	if tmpJT &lt;&gt; null then
		cmif_Machine.allHatchJobTypes.putAtKey(CM_Crane.HatchJobType_BoomUp,tmpJT);
	endif;
	tmpJT := self.myForm.cmbJobType_2.listObject.CM_JobType;
	if tmpJT &lt;&gt; null then
		cmif_Machine.allHatchJobTypes.putAtKey(CM_Crane.HatchJobType_LidRemove,tmpJT);
	endif;
	tmpJT := self.myForm.cmbJobType_3.listObject.CM_JobType;
	if tmpJT &lt;&gt; null then
		cmif_Machine.allHatchJobTypes.putAtKey(CM_Crane.HatchJobType_LidReplace,tmpJT);
	endif;
	tmpJT := self.myForm.cmbJobType_4.listObject.CM_JobType; // PAR 20474
	if tmpJT &lt;&gt; null then
		cmif_Machine.allHatchJobTypes.putAtKey(CM_Crane.HatchJobType_LongTravel,tmpJT); // PAR 20474
	endif;

    cmif_Machine.craneTransferArea	 		:= theForm.cmbCraneArea.listObject.CM_CraneTransferArea;
	cmif_Machine.targetRatePH	 			:= theTable1.getValueByName(ETRow_TargetRatePH).Integer;
	cmif_Machine.craneJobSeed		 		:= theTable1.getValueByName(ETRow_JobSeed).Integer;
	
	cmif_Machine.ratePerHourOD		:= theTable1.getValueByName(ETRow_RatePerHourOvD).Integer;	//par 22065 begin
	cmif_Machine.ratePerHourSLOD	:= theTable1.getValueByName(ETRow_RatePerHourSLOD).Integer;
	cmif_Machine.ratePerHourSLUD	:= theTable1.getValueByName(ETRow_RatePerHourSLUD).Integer;	
	cmif_Machine.ratePerHourTLOD	:= theTable1.getValueByName(ETRow_RatePerHourTLOD).Integer;
	cmif_Machine.ratePerHourTLUD	:= theTable1.getValueByName(ETRow_RatePerHourTLUD).Integer;	////par 22065 end
	//epr TFS 37584 27/4/18
	cmif_Machine.accessMaxHeightDiff        :=  theTable1.getValueByName(ETRow_AccessMaxHeightDiff).Integer;	
	cmif_Machine.accessMaxLocationReach        :=  theTable1.getValueByName(ETRow_AccessMaxLocationReach).Integer;	
	cmif_Machine.accessMaxOverstowHeight        :=  theTable1.getValueByName(ETRow_AccessMaxOverstowHeight).Integer;	
	
	cmif_Machine.hasRadioTelemetry 			:= theTable2.getValueByName(ETRow_HasRadioTelemetry).Boolean;
    cmif_Machine.maxRejectedTasks 			:= theTable2.getValueByName(ETRow_MaxRejectedTasks).Integer;
    cmif_Machine.canWeigh 					:= theTable2.getValueByName(ETRow_CanWeighBoxes).Boolean;
    cmif_Machine.canCertifyWeight			:= theTable2.getValueByName(ETRow_CanCertifyWeight).Boolean;		// TFS 2357 14/07/2016
	
	if cmif_Machine.hasRadioTelemetry then
		theForm.mulSelect1.getSelected(cmif_Machine.terminalAreas);
    	theForm.mulSelect2.getSelected(cmif_Machine.cargoTypes);
    	theForm.mulAlign1.getSelected(cmif_Machine.allSelectedQueues);
    	theForm.mulSelect3.getSelected(cmif_Machine.allAllowableContentStatuses);
    endif;  
	
	cmif_Machine.myOwner					:= theForm.cmbOrganisation.listObject.CM_Organisation;	//15 May 2018	NDL	TSF 38570

	if theForm.myProxyObject = null then
		if theForm.mode = theForm.Mode_Add then
			if intMachineType = MACHINETYPE_PORTAINER_CRANE then
				create theForm.myProxyObject as CM_Crane transient;
			else
				create theForm.myProxyObject as CM_Machine transient;
			endif;
		else
			app.raiseUnexpectedProgramError(class.name, method.name, 'Proxy object is null for update');
			return false;
		endif;
	endif;
	
	proxyMachine := theForm.myProxyObject.CM_Machine;

	proxyMachine.setProxyFromCMIF_Machine(cmif_Machine, app.myPassport);

	if theForm.mode = theForm.Mode_Add then
		app.myTrxCA.trxCreateMachine(proxyMachine, theForm.myCurrentObject,app.myPassport);
	elseif theForm.mode = theForm.Mode_Update then
		app.myTrxUA.trxUpdateMachine(proxyMachine,app.myPassport);
	else
		app.raiseUnexpectedProgramError(class.name, method.name, 'Invalid mode (' &amp; theForm.mode.String &amp; ')');
		return false;
	endif;
	
	return app.myPassport.trxCompletedOK;
	
epilog
	delete cmif_Machine;

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
