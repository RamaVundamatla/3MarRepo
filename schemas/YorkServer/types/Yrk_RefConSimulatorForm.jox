    <JadeMethod name="processLength" id="550d8927-3ae2-4f3c-ae12-a92c836c2bd2">
        <updating/>
        <source>processLength(_buff: Binary) updating;
//----------------------------------------------------------------
//	Created:	02 July 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

	messageLength		: Integer;
	bin, data, extra	: Binary;

begin

	data 	:= null;
	extra := _buff;
	
	while extra &lt;&gt; null do
		if extra.length &gt;= 2 then
			bin[1:1] := _buff[2:1];
			bin[2:1] := _buff[1:1];
			messageLength := bin.Integer;
		else
			extra := null;
			break;
		endif;
			
		if extra.length &lt;= messageLength then
			data := extra;
			extra := null;
		elseif extra.length &gt; messageLength then
			data := extra[1 : messageLength];
			extra := extra[messageLength + 1 : end]; 
		endif;
	
		self.processReadData(data);
		
	endwhile;


end;</source>
        <Parameter name="_buff" type="Binary"/>
    </JadeMethod>
    <JadeMethod name="processReadData" id="8ad35b84-2d46-4565-b55f-02526307d4e6">
        <updating/>
        <source>processReadData(_buf:Binary) updating;
vars
	opCode:Binary[1];
	subOpCode:Binary[1];
begin

	if self.staMain.boundaryColor = Red then
		self.staMain.boundaryColor := Green;
	else
		self.staMain.boundaryColor := Red;
	endif;

	if _buf.length &lt; 9 then
		self.logMonitor("Small buffer " &amp; _buf.asHex);
		return;
	endif;

	opCode := _buf[4:1];
	subOpCode := _buf[9:1];
	if opCode = #02.Binary[1:1] then
		if subOpCode = #04.Binary[1:1] then
			self.processImAlive(_buf);
			self.logMonitor("CMS Broadcast received"); 
		elseif subOpCode = #10.Binary[1:1] then
			self.processInitialise(_buf);
			self.logMonitor("Initialize"); 
		else
			self.logMonitor("UNKNOWN 1" &amp; _buf[1:10].asHex&amp;' '&amp;_buf.String); 
		endif;
	elseif opCode = #03.Binary[1:1] then
		if subOpCode = #01.Binary[1:1] then
			self.processReeferData(_buf);
			self.logMonitor("processReeferData"); 
		elseif subOpCode = #02.Binary[1:1] then
			self.processReeferDelete(_buf);
			self.logMonitor("processReeferDelete"); 
		elseif subOpCode = #03.Binary[1:1] then
			self.processReeferKeyChange(_buf);
			self.logMonitor("processReeferKeyChange"); 
		elseif subOpCode = #04.Binary[1:1] then
			self.processReeferMonitor(_buf);
			self.logMonitor("processReeferMonitor"); 
		elseif subOpCode = #05.Binary[1:1] then
			self.processRecallReeferData(_buf);
			self.logMonitor("processRecallReeferData"); 
		elseif subOpCode = #06.Binary[1:1] then
			self.processReeferMonitorRequest(_buf);
			self.logMonitor("processReeferMonitorRequest"); 
		else
			self.logMonitor("UNKNOWN 2 " &amp; _buf[1:10].asHex&amp;' '&amp;_buf.String); 
		endif;
	else
		self.logMonitor("UNKNOWN 3" &amp; _buf[1:10].asHex&amp;' '&amp;_buf.String); 
	endif;
end;</source>
        <Parameter name="_buf" type="Binary"/>
    </JadeMethod>
    <JadeMethod name="processRecallReeferData" id="601560a7-9fb1-439a-8ace-76e0f841d905">
        <source>processRecallReeferData(_buf:Binary) protected;

vars
	message	: Binary;
	ti		: CM_Container;	
	iter	: Iterator;

begin
	write  class.name&amp;"::"&amp;method.name&amp;" Server ";
	self.staMain.caption := "Processed Recall Reefer Data message";
	iter := self.myTerminal.allOnsiteTIsByCargoTypeId.createIterator;
	self.myTerminal.allOnsiteTIsByCargoTypeId.startKeyGeq(TI_CargoType_Container, null, iter);
	while iter.next(ti) do
		if ti.cargoType &lt;&gt;  TI_CargoType_Container then
			break;
		endif;
		if ti.requiresHumidity or
		   ti.requiresTemperature or
		   ti.requiresVentilation then
			message := self.recallReeferDataTelegram();
			self.sendTelegram(message);
		endif;
	endwhile;
epilog
	delete iter;
end;</source>
        <access>protected</access>
        <Parameter name="_buf" type="Binary"/>
    </JadeMethod>
    <JadeMethod name="processReeferData" id="b90fc7a1-a091-4b4d-a0d9-02fa80772a3c">
        <source>processReeferData(_buf:Binary) protected;

vars
	tmpTI, ti:Yrk_Container;
	alarm,bulbMode,client,comMode,contType,drains,facType,fanSet,id,remark,strLocation:String;
	tiHeight,length:Integer;
	intervalDefrost,hmc,tempActSetpoint,tempDefrost,tempExpSetpoint,tempMax,tempMin,tempReturn,tempSupply,vent:Real;
	location:Yrk_Location;
	voyIn	: String;
	voyOut	: String;
	commod	: String;
begin
	self.staMain.caption := "Processed Reefer Data message";
	exclusiveLock(config);
//	write  class.name&amp;"::"&amp;method.name&amp;" Server ";
	if _buf.length &lt; 241 then
		return;
	endif;
//	write _buf[1:end].String;
	write class.name&amp;"::"&amp;method.name&amp;" Server locationID 50:16 "&amp;_buf[50:16].String;//

/*	
	write  class.name&amp;"::"&amp;method.name&amp;" Server "&amp;_buf[25:4].String&amp;_buf[30:7].String;
	write  class.name&amp;"::"&amp;method.name&amp;" Server "&amp;_buf[50:16].String;//
	write  class.name&amp;"::"&amp;method.name&amp;" Server "&amp;_buf[66:8].String;//Real;
	write  class.name&amp;"::"&amp;method.name&amp;" Server "&amp;_buf[75:8].String;//Real;
	write  class.name&amp;"::"&amp;method.name&amp;" Server "&amp;_buf[84:8].String;//Real;
	write  class.name&amp;"::"&amp;method.name&amp;" Server "&amp;_buf[93:8].String;//Real;
	write  class.name&amp;"::"&amp;method.name&amp;" Server "&amp;_buf[102:8].String;//Real;
	write  class.name&amp;"::"&amp;method.name&amp;" Server "&amp;_buf[111:8].String;//Real;
	write  class.name&amp;"::"&amp;method.name&amp;" Server "&amp;_buf[120:8].String;//Real;
	write  class.name&amp;"::"&amp;method.name&amp;" Server "&amp;_buf[129:8].String;//Real;
	write  class.name&amp;"::"&amp;method.name&amp;" Server "&amp;_buf[138:1].String;
	write  class.name&amp;"::"&amp;method.name&amp;" Server "&amp;_buf[139:1].String;
	write  class.name&amp;"::"&amp;method.name&amp;" Server "&amp;_buf[140:1].String;
	write  class.name&amp;"::"&amp;method.name&amp;" Server "&amp;_buf[141:8].String;//Real;
	write  class.name&amp;"::"&amp;method.name&amp;" Server "&amp;_buf[150:8].String;//Real;
	write  class.name&amp;"::"&amp;method.name&amp;" Server "&amp;_buf[159:3].String;
	write  class.name&amp;"::"&amp;method.name&amp;" Server "&amp;_buf[162:2].String;//Integer;
	write  class.name&amp;"::"&amp;method.name&amp;" Server "&amp;_buf[164:2].String;//Integer;
	write  class.name&amp;"::"&amp;method.name&amp;" Server "&amp;_buf[166:2].String;
	write  class.name&amp;"::"&amp;method.name&amp;" Server "&amp;_buf[168:1].String;
	write  class.name&amp;"::"&amp;method.name&amp;" Server "&amp;_buf[169:1].String;
	write  class.name&amp;"::"&amp;method.name&amp;" Server "&amp;_buf[170:1].String;
	write  class.name&amp;"::"&amp;method.name&amp;" Server "&amp;_buf[171:80].String;
*/
	id 				:= _buf[25:4].String&amp;_buf[30:7].String;
	strLocation 	:= _buf[50:16].String;
	tempExpSetpoint := _buf[66:8].String.Real;
	tempActSetpoint := _buf[75:8].String.Real;
	tempSupply 		:= _buf[84:8].String.Real;
	tempReturn 		:= _buf[93:8].String.Real;
	tempMin 		:= _buf[102:8].String.Real;
	tempMax 		:= _buf[111:8].String.Real;
//	write class.name&amp;"::"&amp;method.name&amp;" Server "&amp;tempMin.String&amp;"::"&amp;tempMax.String;
	hmc 			:= _buf[120:8].String.Real;
	vent 			:= _buf[129:8].String.Real;
	drains 			:= _buf[138:1].String;
	bulbMode 		:= _buf[139:1].String;
	fanSet 			:= _buf[140:1].String;
	tempDefrost 	:= _buf[141:8].String.Real;
	intervalDefrost := _buf[150:8].String.Real;
	client 			:= _buf[159:3].String;
	length 			:= _buf[162:2].String.Integer;
	tiHeight 		:= _buf[164:2].String.Integer;
	contType 		:= _buf[166:2].String;
	facType 		:= _buf[168:1].String;
	comMode 		:= _buf[169:1].String;
	alarm 			:= _buf[170:1].String;
	remark 			:= _buf[171:80].String;
	voyIn 			:= _buf[251:12].String;
	voyOut 			:= _buf[263:12].String;
	commod 			:= _buf[275:35].String;

	write class.name&amp;"::"&amp;method.name&amp;' '&amp; voyIn &amp; voyOut &amp; commod;
 	
	tmpTI 			:= self.config.allRfcContainers[id];

	beginTransaction;
	if tmpTI &lt;&gt; null then
		//already has it
		tmpTI.setForUpdate(alarm,bulbMode,client,comMode,contType,drains,facType,fanSet,id,remark,
	                tiHeight,length,intervalDefrost,
	                hmc,tempActSetpoint,tempDefrost,tempExpSetpoint,tempMax,tempMin,tempReturn,tempSupply,vent,
	                self.config,strLocation);
	else
		create ti;
		ti.setForUpdate(alarm,bulbMode,client,comMode,contType,drains,facType,fanSet,id,remark,
	                tiHeight,length,intervalDefrost,
	                hmc,tempActSetpoint,tempDefrost,tempExpSetpoint,tempMax,tempMin,tempReturn,tempSupply,vent,
	                self.config,strLocation);
	endif;
	commitTransaction;
//	config := self.config;
//	myRfcLocation := location;
epilog
	unlock(config);	
end;</source>
        <access>protected</access>
        <Parameter name="_buf" type="Binary"/>
    </JadeMethod>
