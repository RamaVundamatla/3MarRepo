    <JadeMethod name="initCells" id="14c0d736-4454-447d-8423-5eaead04e8ce">
        <source>initCells() protected;
/*

Date		Who		Reason
25 November 2013	cnwer1	Initial creation PAR

*/
constants
	Margin = 5; 
vars

begin
	self.myTable.columns:=self.dataColumn+1;
	self.myTable.accessRow(1).height:=Margin;
	self.myTable.accessRow(1).enabled:=false;

	self.myTable.accessColumn(headingColumn-1).enabled:=false;
	self.myTable.accessColumn(headingColumn-1).width:=Margin;
	
	self.myTable.accessColumn(self.myTable.columns).enabled:=false;
	self.myTable.accessColumn(self.myTable.columns).width:=40;
	
	self.myTable.accessColumn(headingColumn).alignment:=Table.Alignment_Right_Middle;
	self.myTable.accessColumn(headingColumn).marginRight:=5;
	self.myTable.accessColumn(headingColumn).width:=60;
	
	self.myTable.accessColumn(dataColumn).alignment:=Table.Alignment_Left_Middle;
	self.myTable.accessColumn(dataColumn).marginLeft:=5;
	self.myTable.accessColumn(dataColumn).fontBold := true;
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="initTable" id="8f583668-3ea0-457d-b4cb-d3bcafbfa22d">
        <updating/>
        <source>initTable() updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
04/05/2010	cnwer1	Initial creation
27/01/2015	cnwdap1	PAR #37374 Refactor initCells and column setting code
*/

constants
	Margin = 5; //epr par 30678 HAT 2200 decreased the margin size
vars
	parent : Window;
	splitRows : IntegerArray;
	entTableRow : EntTableRow;
begin
	self.myTable.clear;

	self.dataColumn:=3;
	self.headingColumn:=self.dataColumn-1;
	
	self.myTable.borderStyle:=Table.BorderStyle_None;
	self.myTable.parentAspect:=Table.ParentAspect_StretchRight;
	self.myTable.fixedColumns:=0;
	self.myTable.fixedRows:=0;
	
	
	self.myTable.rows:=1;
	self.myTable.gridLines:=true;
	self.myTable.gridColor:=self.myTable.getSystemColor(Control.Color_3DFace);
	self.myTable.accessSheet(1).gridBottom:=false;
	self.myTable.accessSheet(1).gridRight:=false;
	
	self.setColumns();					// PAR #37374
	/*self.initCells();					// PAR #37374
	
	//if global.cnwer1 then
		self.myTable.columns:=self.dataColumn + 3;
		self.myTable.accessColumn(self.dataColumn + 1).enabled:=false;
		self.myTable.accessColumn(self.dataColumn + 1).width:=Margin;
		
		self.myTable.accessColumn(dataColumn+ 2).alignment:=Table.Alignment_Left_Middle;
		self.myTable.accessColumn(dataColumn+ 2).marginLeft:=5;
		self.myTable.accessColumn(dataColumn+ 2).fontBold := true;
		
		self.myTable.accessColumn(self.myTable.columns).enabled:=false;
		self.myTable.accessColumn(self.myTable.columns).width:=40;
	//endif;*/
	
	
	self.myTable.fixed3D:=false;
	self.myTable.selectMode := Table.SelectMode_None;
	self.myTable.autoSize:=Table.AutoSize_Column;
	
	//epr par 34682 4/8/14
	if self.myEntTableDef &lt;&gt; null then
		foreach entTableRow in self.myEntTableDef.allEntTableRows do
			self.addNewEntRow(entTableRow);
		endforeach;
	endif;
	
	self.myTable.fitColumnWidth(2,0);
	self.myTable.scrollBars:=Table.ScrollBars_Both;
	self.myTable.dropDown:=Table.DropDown_None;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="insertRowAfterEntRow" id="92f3e270-b67a-412c-a908-a57c150da53a">
        <source>insertRowAfterEntRow(_entRowName: String; _newEntTableRow : EntTableRow; _rowheight : Integer);
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
04 May 2010	cnwer1	Initial creation

*/

vars

	accessedCell : JadeTableCell;
	row			 : Integer;
	heading : String;
begin
	
	

	row:=self.findRowWithEntRowName(_entRowName);
	if row = 0 then
		return;
	endif;
	
	row:=row+1;
	
	self.myTable.addItemAt(null,row);
	self.formatGapRow(row);
	row:=row+1;
	self.myTable.addItemAt(null,row);
	if _newEntTableRow &lt;&gt; null then
		heading:=_newEntTableRow.getHeading(null, self.myTerminal, app.myCurrentLocale);
	endif;
	self.myTable.accessCell(row, self.headingColumn).text:=heading;
	accessedCell:=self.myTable.accessCell(row,self.dataColumn);
	self.myTable.accessRow(row).itemObject:=_newEntTableRow;
	if _newEntTableRow = null then
		self.myTable.accessRow(row).enabled:=false;
	endif;
	if _rowheight &gt; 0 then
		self.myTable.accessRow(row).height:=_rowheight;
	endif;
epilog

end;</source>
        <Parameter name="_entRowName" type="String"/>
        <Parameter name="_newEntTableRow" type="EntTableRow"/>
        <Parameter name="_rowheight" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="mergeEntRowTableCells" id="4660437f-b80d-49d6-b643-edb5740317e2">
        <source>mergeEntRowTableCells(	_entRowName: String;
						_column: Integer; 
						_numNewColumns: Integer;
						_inputType: Integer);
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
04 May 2010	cnwer1	Initial creation

*/

vars
	row : Integer;
begin
	
	row:=self.findRowWithEntRowName(_entRowName);
	if row = 0 then
		return;
	endif;
	self.mergeTableCells(row,_column, _numNewColumns, _inputType);
epilog

end;</source>
        <Parameter name="_entRowName" type="String"/>
        <Parameter name="_column" type="Integer"/>
        <Parameter name="_numNewColumns" type="Integer"/>
        <Parameter name="_inputType" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="mergeTableCells" id="ccb60f59-6531-40ee-8892-d33d681ae110">
        <source>mergeTableCells(_row, _column,_numNewColumns : Integer;
				_inputType : Integer);
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
04 May 2010	cnwer1	Initial creation

*/

vars

begin
	self.myTable.accessCell(_row,_column).mergeCells:=Table.MergeCells_Merge;
	self.myTable.accessCell(_row,_column+_numNewColumns).mergeCells:=Table.MergeCells_NotAvailable;
	self.changeCellInputType(_row,_column,_inputType);
	
epilog

end;</source>
        <Parameter name="_row" type="Integer"/>
        <Parameter name="_column" type="Integer"/>
        <Parameter name="_numNewColumns" type="Integer"/>
        <Parameter name="_inputType" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="removeGridAroundCell" id="998147a2-f2a1-40f6-89d7-674017257956">
        <source>removeGridAroundCell(_row,_column : Integer) protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
30 April 2010	cnwer1	Initial creation

*/

vars
	topCell : JadeTableCell;
	table : Table;
begin
	table:=self.myTable;
	if table.accessCell(_row,_column).inputType = Table.InputType_TextBox then
		table.accessCell(_row,_column).inputType:=Table.InputType_None;
	endif;
	table.accessCell(_row,_column).backColor:=table.parent.backColor;
	if table.rows &gt;= _row-1 then
		topCell:=table.accessCell(_row-1,_column);
		if topCell.inputType = Table.InputType_None then
			table.accessCell(_row-1,_column).gridBottom:=false;
		endif;
		if table.accessCell(_row,_column).mergeCells &lt;&gt; null then
			table.accessCell(_row-1,_column+1).gridBottom:=false;
		endif;
	endif;
	if table.rows &gt;= _row + 1 then
		if  table.accessCell(_row + 1, _column).inputType = Table.InputType_None then
			table.accessCell(_row,_column).gridBottom:=false;
		endif;
	else
		table.accessCell(_row,_column).gridBottom:=false;
	endif;
	
	if table.accessCell(_row, _column + 1).inputType = Table.InputType_None then
		table.accessCell(_row,_column).gridRight:=false;
	endif;
	
	if table.columns &gt;= _column-1 and table.accessCell(_row,_column-1).inputType = Table.InputType_None then
		table.accessCell(_row,_column-1).gridRight:=false;
	endif;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_row" type="Integer"/>
        <Parameter name="_column" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setColumns" id="65daba94-1bb5-419e-9a8b-6c0d3895dc59">
        <updating/>
        <source>setColumns() updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 27/01/2016	cnwdap1		Initial creation PAR #37374
//
constants
	Margin = 5;

vars

begin
	self.initCells();
	
	self.myTable.columns:=self.dataColumn + 3;
	self.myTable.accessColumn(self.dataColumn + 1).enabled:=false;
	self.myTable.accessColumn(self.dataColumn + 1).width:=Margin;
	
	self.myTable.accessColumn(dataColumn+ 2).alignment:=Table.Alignment_Left_Middle;
	self.myTable.accessColumn(dataColumn+ 2).marginLeft:=5;
	self.myTable.accessColumn(dataColumn+ 2).fontBold := true;
	
	self.myTable.accessColumn(self.myTable.columns).enabled:=false;
	self.myTable.accessColumn(self.myTable.columns).width:=40;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setEntRowVisible" id="e61d1439-4f03-4a06-84cf-8a8b2e224686">
        <source>setEntRowVisible(_entRowName: String; _visible : Boolean);
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
04 May 2010	cnwer1	Initial creation

*/

vars
	entRow : EntTableRow;
	theRow,
	gapRow: JadeTableRow;
	col, row,currentRow,
	prevRowToCheck: Integer;
begin
	entRow := self.myEntTableDef.getEntTableRow(_entRowName);
	if entRow = null then
		return;
	endif;
	currentRow:=self.findRowWithEntRow(entRow);
	if currentRow = 0 then
		return;
	endif;
	theRow:=self.myTable.accessRow(currentRow);
	
	theRow.visible:=_visible;
	prevRowToCheck:=currentRow-1;
	gapRow:=self.myTable.accessRow(prevRowToCheck);
	gapRow.visible:=_visible;
	
	if not _visible then
		return;
	endif;

	col:=1;
	while col &lt; self.myTable.columns do
		if prevRowToCheck &gt; 1 then
			if self.myTable.accessCell(currentRow,col).inputType = Table.InputType_TextBox or
				 self.myTable.accessCell(currentRow,col).inputType = Table.InputType_ComboBox then
				
				self.myTable.accessCell(prevRowToCheck,col).gridBottom:= true;
			else
				self.myTable.accessCell(prevRowToCheck,col).gridBottom:=false;
			endif;
		
			if self.myTable.accessCell(currentRow,col).mergeCells = 1 then
				if self.myTable.accessCell(currentRow,col).inputType = Table.InputType_TextBox or
				 self.myTable.accessCell(currentRow,col).inputType = Table.InputType_ComboBox then
					self.myTable.accessCell(prevRowToCheck,col+1).gridBottom:=true;
				else
					self.myTable.accessCell(prevRowToCheck,col+1).gridBottom:=false;
				endif;
				col:=col+1;
			endif;
		endif;
			
		col:=col+1;
	endwhile;	
	
	
epilog
	self.myTable.fitColumnWidth(2,0); //self.resizeColumnWidth(2);
end;</source>
        <Parameter name="_entRowName" type="String"/>
        <Parameter name="_visible" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setHeaderForEntRowName" id="e41eb389-731f-4c14-a095-7bde827115ec">
        <source>setHeaderForEntRowName(_entRowName: String; _caption: String);
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
04 May 2010	cnwer1	Initial creation

*/

vars
	row : Integer;
begin
	row:=self.findRowWithEntRowName(_entRowName);
	self.myTable.accessCell(row,self.headingColumn).text:=_caption;
epilog

