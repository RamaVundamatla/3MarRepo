// ---------------------------------------------------------------------------
// Created:     26 June 2009 by concms1
// Purpose:     CCMS 1061 - Gate Config Changes  
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	inheritMethod();
	
	txtName.text			:= null;
	chkEntry.value			:= false;
	cmbTroubleIn.listIndex	:= -1;
	cmbICArea.listIndex		:= -1;
	chkExit.value			:= false;
	
	tblGateAreas.rows	:= tblGateAreas.fixedRows;
	tblGateLanes.rows	:= tblGateLanes.fixedRows;
epilog

end;</source>
