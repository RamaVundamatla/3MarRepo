    <JadeMethod name="setForUpdate" id="d60e23c1-ae69-4f64-add0-eab1f4e6481c">
        <updating/>
        <source>setForUpdate(_proxy: CM_LaneController; _terminalArea: CM_GridArea) updating;
// ---------------------------------------------------------------------------
// Created:     22 June 2009 by concms1:1
// Purpose:     CCMS SFW 1047 - Totals Only Lists
// Parameters:  None
// Returns:     Nothing
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 25/05/2010	cnwcs5		par24292 - interchange area changes
// ---------------------------------------------------------------------------
vars
	ld, pxyLD	:CM_LaneDevice;
	coll	:CM_ObjectSet;
begin
	if _proxy.isDefaultLane and not _proxy.lockDirection then
		//app.raiseUnexpectedProgramError (self.class.name, method.name, 'Default lane must have lock direction set');
	endif;
	
	inheritMethod(_proxy, _terminalArea);
	
	self.ident			:= _proxy.ident;
	self.laneDirection	:= _proxy.laneDirection;
	self.lockDirection	:= _proxy.lockDirection;
	self.isUnavailable	:= _proxy.isUnavailable;
	self.capacity		:= _proxy.capacity;		// 25/05/2010 cnwcs5 par24292
	
	if not self.hasVehicles then
		// only change vehcle direction if no vehicles
		self.vehicleDirection := _proxy.laneDirection;		// not a typo
	endif;
	// keep track of any lane devices that should be deleted
	create coll transient;
	
	self.allLaneDevices.copy (coll);
	
	self.updateLaneDevices (_proxy);
	
	foreach ld in self.allLaneDevices do
		coll.removeIfPresent (ld);
	endforeach;
	
	// coll now contains lane devices that are no longer needed
	coll.purge;
epilog
	delete coll;
end;</source>
        <Parameter name="_proxy" type="CM_LaneController"/>
        <Parameter name="_terminalArea" type="CM_GridArea"/>
    </JadeMethod>
