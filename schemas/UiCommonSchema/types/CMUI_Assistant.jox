    <JadeMethod name="displayEntryMTGradeList" id="93280978-fb56-48f8-b686-d307fe424a32">
        <source>displayEntryMTGradeList(pMTGrade : CM_MTGrade; pSelected : Boolean) : String;
// ---------------------------------------------------------------------------
// Created:     20 December 2000 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	if pMTGrade &lt;&gt; null then
		if pSelected then
			return TableCheckBox_Selected &amp; Tab &amp; pMTGrade.code.String &amp; Tab &amp; pMTGrade.description;
		else
			if pMTGrade.isNotAvailableForEntry then
				return null;
			else
				return TableCheckBox_NotSelected &amp; Tab &amp; pMTGrade.code.String &amp; Tab &amp; pMTGrade.description;
			endif;
		endif;
	endif;
	
	return null;

end;</source>
