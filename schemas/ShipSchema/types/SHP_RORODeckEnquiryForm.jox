    <JadeMethod name="doDeleteDecks" id="69a7b86b-8e23-47cd-aa2d-47a9374cdb03">
        <updating/>
        <source>doDeleteDecks() protected, updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
25 March 2011	cnwer1	Initial creation CCMS 1031

*/

vars
	obj				: Object;
	selectedDecks : ObjectArray;
	deck : CM_Deck;
	result : Integer;
	deckCodes : String;
begin

	create selectedDecks transient;
	
	// PAR 27605	self.tbRoRolDecks.allSelectedObjects.copy(selectedDecks);
	// PAR 27605 do not add in sub decks if their parent is in the list as the parent deletes the child
	foreach obj in self.tbRoRolDecks.allSelectedObjects do
		if obj.isKindOf(CM_DeckVesselSub) then
			if selectedDecks.includes(obj.CM_DeckVesselSub.myParentDeck) then
				continue;
			endif;
		elseif obj.isKindOf(CM_DeckVoyageSub) then
			if selectedDecks.includes(obj.CM_DeckVoyageSub.myParentDeck) then
				continue;
			endif;
		
		endif;
		selectedDecks.add(obj);
	endforeach;

	if selectedDecks.first = null then
		return;
	endif;

	deck:=selectedDecks.first.CM_Deck;

	foreach obj in selectedDecks do
		deckCodes:=deckCodes &amp; obj.CM_Deck.code;
		if selectedDecks.last &lt;&gt; obj then
			deckCodes:=deckCodes &amp; ", ";
		endif;
	endforeach;
	
	if app.msgBox(app.getErrorString2(ConfirmDelete,app.getErrorString(Decks),deckCodes),app.getErrorString(Warning), MsgBox_Yes_No + MsgBox_Question_Mark_Icon) &lt;&gt;  MsgBox_Return_Yes then
		return;
	endif;
	
	while true do
	
		app.myTrxDA.trxDeleteROROVesselDecks (selectedDecks,app.myPassport);
	
		if app.myPassport.trxCompletedOK then
			
			break;
		else
			result := app.showErrorWarningDialog(app.getErrorString(Vessel) &amp; " " &amp; app.getErrorString(Deck), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and result = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		
		endif;
		
		break;
	endwhile;
epilog
	delete selectedDecks;
end;</source>
        <access>protected</access>
    </JadeMethod>
