    <JadeMethod name="isUnitTestMethod" id="476fabea-b236-4407-8e4d-914b38d98e58">
        <source>isUnitTestMethod(_meth: Method): Boolean;
//08 March 2010	cnwdw1	
//
vars

begin
	//Unit Test methods must be public and start with t,u or i
	return _meth.access.Integer = 0 and (_meth.name[1] = "t" or _meth.name[1] = "u" or _meth.name[1] = "i") and
		(_meth.name.length &gt; 2 and _meth.name[2].isUpper);
end;</source>
        <Parameter name="_meth" type="Method"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="log" id="2ebd80bd-3fa0-4c69-8fef-5cfb085902f8">
        <source>log(_log: String);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25 March 2021	navndl1	Initial creation	TFS 51023  - Cut down on teh noise logging messages in unit test

*/

vars

begin
	
	if app.isJMTUnitTest then
		if app.hideDebug then
			if _log.length &gt; 2 then
				if _log[1:2] = "0," then
					//its just an autoplan message, don't bother writing it here.
					return;
				elseif _log.pos("CM_EDIData::loadDBToCMS",1) &gt; 1 then
					return;
				elseif _log.pos("CM_EDIControllerAgent::verifyEdiData",1) &gt; 1 then
					return;
				elseif _log.pos("CM_EDIFileType::processFileData",1) &gt; 1 then
					return;
				elseif _log.pos("CM_EDIControllerAgent::getFileData",1) &gt; 1 then
					return;
				elseif _log.pos("CM_EDIControllerAgent::loadAndProcessFileForTerminal",1) &gt; 1 then
					return;
				endif;
			endif;
		endif;
	endif;

//	write _log;

	inheritMethod(_log);

epilog

end;</source>
        <Parameter name="_log" type="String"/>
    </JadeMethod>
    <JadeMethod name="logTimeStamp" id="8f725373-9183-480c-978d-3273a185b5d0">
        <source>logTimeStamp(_timestamp : TimeStamp; _indent : Integer; _message : String) : String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 July 2023	navpw1	Initial creation

*/

vars
	ts			: TimeStamp;
	timeString,
	padStr,
	retStr : String;
	
begin
	padStr := " " &amp; null.String.padBlanks(_indent * 4);
	ts := _timestamp;
	timeString := ts.literalFormat;
	if ts.time.milliSecond = 0 then
		timeString := timeString &amp; ".000";
	endif;
	timeString := timeString[1:10].replace(":", "/") &amp; " " &amp; timeString[12:end];
	
	retStr := timeString &amp; padStr &amp; _message;
	
	return retStr;
	
end;</source>
        <Parameter name="_timestamp" type="TimeStamp"/>
        <Parameter name="_indent" type="Integer"/>
        <Parameter name="_message" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="main" id="1b700665-50a1-47fc-b0f7-91fdd6d2997f">
        <updating/>
        <source>main(commandLine: String) updating;
//03 February 2009	cnwdw1	
// 01/08/2011	cnwmh5	Remove iniitalize, initLogFile, and terminate.  Now done in methods that call.  
// [class=&lt;className&gt;] [method=&lt;methodName&gt;] [profile=&lt;profileName&gt;] [schedule=&lt;scheduleName&gt;] [sendEmail] [checkLeaks] [logResult] [disableOvernightSave]
// 05/07/2013	cnwmh5 	Comment out checkLeaks, as will take too long to run as needs to copy 2400 - 5500 at the start and end and say takes 1 second then
//						at this point will be about 861 seconds x 2.
// 05/12/2013	cnwmh5	checkLeaks has now been uncommented.  Kevin has changed the way that the check leaker works.  No longer checks to Lock leaks
// 12/12/2016	cnwmh5	Add call to kill off debugger processes that are running when the automated tests fire up
// 08/05/2025	navhn30	MTN-34403: MTN - Sending Unit Tests Failing Summary Report by Team to Users that are Interested in it - Part 4 - Phase1
// 09 Sep 2025  navah1  MTN-34969: MTN - Investigate formatting Unit Test Emails in HTML - Phase2 
// 15 Oct 2025  navsp1  MTN-34201  MTN - Dump Config before first unit test and last unit test for comparison - Phase2
vars
	testRunner 					: JMTTestController;
	////runTestDailyONSave			: UM_TestRunONightSave;
	runTestDailyONSave			: UM_UnitTestRun;						// 05/09/2013 cnwmh5
	profile 					: UT_Profile;
	verAdmin					: UT_Verification_Admin;
	logCertify					: UT_ZJMTLogicalCertify;
	fileFolder					: FileFolder;
	file						: File;
	dummyUnitTestRun			: UM_UnitTestRun;
	
	userSummaryDict				: CM_AssociationDict;
	userIgnoreDict				: CM_AssociationDict;
	association					: CM_Association;
	
	klass 						: Class;
	meth 						: Method;
	
	iter 						: Iterator;
	
	paramNames					: StringArray;
	paramValues					: StringArray;
	args 						: HugeStringArray;
	
	stateObjectArray 			: CM_StateObjectArray;
	
	log 						: File;
	
	sendEmail 					: Boolean;
	checkLeaks 					: Boolean;
	logResult 					: Boolean;
	sendEmailMH5Only 			: Boolean;
	disableONightRunSave		: Boolean;
	checkAllTime				: Boolean;
	byTeam 						: Boolean; 
	
	teamName					: String;
	summary 					: String;
	param 						: String;
	scheduleName				: String;
	xmlString					: String;
	klassName 					: String;
	methodName 					: String;
	profileName 				: String;
	user						: String;
	userSummary 				: String;
	userIgnore 					: String;
	tempStr						: String;
	srcCompareErrors			: String;
	
	startTime					: TimeStamp;
	endTime						: TimeStamp;
	
	i 							: Integer;
	whichToCompact				: Integer;
	isHtml						: Boolean; //09.09.2025 navah1 #34969
    runSTartTS                  : TimeStamp;    //MTN-34201
    runSTartTSStr               : String;       //MTN-34201
begin
	
	beginTransaction;
	app.myRoot.setClient(Client_JadeMaster);		// Run all tests as JMT client
	commitTransaction;
	
	sendEmail := false;			// 18/01/2011 cnwmh5 - Changed from true;
	checkLeaks := false;
	byTeam := true;				// 28/04/2025  navhn30 	MTN-34403
	isHtml := true;			//09.09.2025 navah1 #34969
	create log;
	log.usePresentationFileSystem := false;
	log.openOutput(app.myCnCntrl.logPath &amp; "\JMTUnitTest_" &amp; app.actualTimeServer.getNumeralString &amp; ".log");// 12 May 2016		cnwns1			TFS 488 - Multi Timezone Support
	log.writeLine("TestRunner "&amp;commandLine);
	
	app.overnightRun := true;						// 20/03/2012 cnwmh5
	app.findBlameForNoDays := UM_Blame.DateThreshold;
	
	create paramNames transient;
	create paramValues transient;
	self.parseCommandLine(commandLine, paramNames, paramValues);
	
	foreach i in 1 to paramNames.size do
		param := paramNames[i].toUpper;
		if param = "CLASS" then
			klassName := paramValues[i];
			
		elseif param = "METHOD" then
			methodName := paramValues[i];
		elseif param = "PROFILE" then
			profileName := paramValues[i];
		elseif param = "SENDEMAIL" then
			sendEmail := true;
		elseif param = "CHECKLEAKS" then
			checkLeaks := true;											
		elseif param = "LOGRESULT" then
			logResult := true;
		elseif param = "SCHEDULE" then
			scheduleName := paramValues[i];
		elseif param = "CNWMH5EMAIL" then
			sendEmail := false;
			sendEmailMH5Only := true;
		elseif param = "disableOvernightSave".toUpper() then
			disableONightRunSave := true;
		endif;
	endforeach;

	if paramNames.size &lt; 1 or (klassName = null and scheduleName = null) then
		log.writeLine(klassName);
		log.writeLine("UnitTestRunner [class=&lt;className&gt;] [method=&lt;methodName&gt;] [profile=&lt;profileName&gt;] [schedule=&lt;scheduleName&gt;] [sendEmail] [checkLeaks] [logResult] [disableOvernightSave]");
		app.writeLog("UnitTestRunner [class=&lt;className&gt;] [method=&lt;methodName&gt;] [profile=&lt;profileName&gt;] [schedule=&lt;scheduleName&gt;] [sendEmail] [checkLeaks] [logResult] [disableOvernightSave]", LogINFO);	// 28/04/2011 cnwmh5
		terminate;

	endif;
	
	app.writeLog('Parameters: ' &amp; CrLf &amp; 
		'class: ' &amp; klassName &amp; CrLf &amp;
		'method: ' &amp; methodName &amp; CrLf &amp;
		'profile: ' &amp; profileName &amp; CrLf &amp;
		'schedule: ' &amp; scheduleName &amp; CrLf &amp; 
		'sendEmail: ' &amp; sendEmail.String &amp; CrLf &amp;
		'checkLeaks: ' &amp; checkLeaks.String &amp; CrLf &amp;
		'logResult: ' &amp; logResult.String &amp; CrLf &amp;
		'disableOvernightRunSave: ' &amp; disableONightRunSave.String, LogINFO);
	
	// 08/01/2012 cnwmh5 - Now no longer needed schedule the cleanup only
	if scheduleName = "SCHEDULE_Cleanup" then
		app.startApplication(currentSchema.name, "JMTCleanUpLogResultDetails");	
		return;
	endif;
	
	// create the daily test run record
	////if app.overnightRun and not disableONightRunSave and (scheduleName &lt;&gt; null or klassName = "UT_DSL") then
		beginTransaction;
		create runTestDailyONSave persistent;
		///runTestDailyONSave.setCommandLineDetails(scheduleName, checkLeaks, logResult, false);
		///app.myUMTestRunONight := runTestDailyONSave;
		runTestDailyONSave.updateCommandLineDetails(scheduleName, checkLeaks, logResult);					// 05/09/2013 cnwmh5
		app.myUMTestRunONight := runTestDailyONSave;
		commitTransaction;
		
		// 03/12/2013 cnwmh5 - write run start / end timestamp to file for transient leak check
		// 13/06/2016 cnwmh5 - move creation here
		create fileFolder transient;
		fileFolder.fileName := app.cnGetServerMiscPath &amp; "\AutomatedRunDetails";
		fileFolder.usePresentationFileSystem := false;
		if not fileFolder.isAvailable() then
			fileFolder.make();
		endif;
		startTime := app.myUMTestRunONight.startTS;
		create file transient;
		file.fileName := fileFolder.fileName &amp; "\unitTestRunTime" &amp; startTime.date.format('yyyMMdd') &amp; ".txt";
		file.mode := File.Mode_Append;
		file.usePresentationFileSystem := false;
		if file.isAvailable then
			file.purge();
		endif;
		// write the start / end times to the file
		file.writeLine(startTime.date.String &amp; Tab &amp; startTime.time.String);
		file.close();
		
	////endif;
	
	create testRunner transient;
	create userSummaryDict transient;
	create userIgnoreDict transient;
	create verAdmin transient;
	
	runSTartTSStr := runSTartTS.String;                                 //MTN-34201
    
	// 15/11/2016 cnwmh5 - Check for uncompiled methods before the run
	userSummaryDict.clear();
	userIgnoreDict.clear();
	verAdmin.sendMsgWithIOParams('vCheckUncompiledMthdsProdScms', userSummaryDict);
	iter := userSummaryDict.createIterator();
	while iter.next(association) do
		userSummaryDict.getIteratorKeys(user, iter);
		self.emailReports(association.asStringWithoutFailures(), "Uncompiled Production Schema(s)", 2, testRunner,null,false);
	endwhile;
	
	// 07/04/2016 cnwmh5 - Check to see if Release Documentation Copy has been set up
	verAdmin.sendMsgWithIOParams('vSetupReleaseDocumentationCopy', testRunner);
	
	// 12/12/2016 cnwmh5 - Kill any running debug processes
	userSummaryDict.clear();
	userIgnoreDict.clear();
	delete iter;
	verAdmin.sendMsgWithIOParams('vKillRunningDebugProcesses', userSummaryDict);
	iter := userSummaryDict.createIterator();
	while iter.next(association) do
		userSummaryDict.getIteratorKeys(user, iter);
		self.emailReports(association.asStringWithoutFailures(), "Debug Process(es) Killed", 2, testRunner,null,false);
	endwhile;
	
	// 03/08/2016 cnwmh5 - Check that release documentation has been copied
	/*userSummaryDict.clear();
	userIgnoreDict.clear();
	verAdmin.sendMsgWithIOParams('vCheckReleaseDocCopied', runTestDailyONSave, userSummaryDict);
	iter := userSummaryDict.createIterator();
	while iter.next(association) do
		userSummaryDict.getIteratorKeys(user, iter);
		self.emailReports(association.asStringWithoutFailures(), "Release Documentation Copy Issue", 2, testRunner);
	endwhile;*/
	
	// 11/05/2015 cnwmh5 - Check to see that UT Sub Terminals are set
	userSummaryDict.clear();
	userIgnoreDict.clear();
	delete iter;
	verAdmin.sendMsgWithIOParams('vUTSubTerminalSetCashNotEnable', runTestDailyONSave, userSummaryDict);
	iter := userSummaryDict.createIterator();
	while iter.next(association) do
		userSummaryDict.getIteratorKeys(user, iter);
		self.emailReports(association.asStringWithoutFailures(), "UT Sub Terminals Cleared", 2, testRunner,null,false);
	endwhile;
	
	app.mySaveDataObjsToRestore.saveAllStateData(null, self, stateObjectArray);			// 07/01/2015 cnwmh5

	/*                                                                          //MTN-34201 - moved down, after the run
	// 17/06/2015 cnwmh5 - Check for config changes
	userSummaryDict.clear();
	userIgnoreDict.clear();
	delete iter;
	verAdmin.sendMsgWithIOParams('vCheckForConfigChanges', userSummaryDict, dummyUnitTestRun);
	iter := userSummaryDict.createIterator();
	while iter.next(association) do
		userSummaryDict.getIteratorKeys(user, iter);
		self.emailReports(association.asStringWithoutFailures(), "Check Config Changes Failed", 2, testRunner,null,false);
	endwhile;
	*/
	// 19/02/2015 cnwmh5 - Clear all BGP Requests before the test run starts
	userSummaryDict.clear();
	userIgnoreDict.clear();
	delete iter;
	verAdmin.sendMsgWithIOParams('vClearAllBGPRequests', runTestDailyONSave, userSummaryDict);
	iter := userSummaryDict.createIterator();
	while iter.next(association) do
		userSummaryDict.getIteratorKeys(user, iter);
		self.emailReports(association.asStringWithoutFailures(), "Clear All BGP Requests Failed", 2, testRunner,null,false);
	endwhile;
	
	// 09/09/2015 cnwmh5 - Check that Financial IO Class has been set for all terminals
	userSummaryDict.clear();
	userIgnoreDict.clear();
	delete iter;
	verAdmin.sendMsgWithIOParams('vUTSetTerminalConfig', runTestDailyONSave, userSummaryDict);
	iter := userSummaryDict.createIterator();
	while iter.next(association) do
		userSummaryDict.getIteratorKeys(user, iter);
		self.emailReports(association.asStringWithoutFailures(), "Terminal Config Set", 2, testRunner,null,false);
	endwhile;
	
	// 30/06/2015 cnwmh5 - Update the Master Terminal licenses
	if app.isUnicode then
		userSummaryDict.clear();
		userIgnoreDict.clear();
		delete iter;
		verAdmin.sendMsgWithIOParams('vUpdateLicense', runTestDailyONSave, userSummaryDict);
		iter := userSummaryDict.createIterator();
		while iter.next(association) do
			userSummaryDict.getIteratorKeys(user, iter);
			self.emailReports(association.asStringWithoutFailures(), "Update JADE Master Terminal License Error", 2, testRunner,null,false);
		endwhile;
	endif;
	
	
	userSummaryDict.clear();
	userIgnoreDict.clear();
	delete iter;
	
	testRunner.setSendEmail(sendEmail);
	testRunner.setCheckLeaks(checkLeaks);
	testRunner.setScheduleName(scheduleName);
	//testRunner.setLogMessages(false);
	testRunner.setLogMessages(true);
	testRunner.setLogResult(logResult);
	testRunner.run(klassName, methodName, profileName, null);
	summary := testRunner.getResultsSummary(userSummaryDict, userIgnoreDict);
	///summary := summary &amp; CrLf &amp; testRunner.getTrxSummary;
	log.writeLine(summary);
	
	self.emailReports(summary, "Summary", 1, testRunner,null,false);			//cnwmc5 - 12/10/2012
	
    //Check config changes                                                                                  //MTN-34201
    //1.Compare the changes with the last run.                                                              //MTN-34201
    //2.Compare the changes within the current run.                                                         //MTN-34201
	userSummaryDict.clear();
	userIgnoreDict.clear();
	delete iter;
	verAdmin.sendMsgWithIOParams('vCheckForConfigChanges', userSummaryDict, dummyUnitTestRun, runSTartTSStr);
	iter := userSummaryDict.createIterator();
	while iter.next(association) do
		userSummaryDict.getIteratorKeys(user, iter);
		self.emailReports(association.asStringWithoutFailures(), "Check Config Changes Failed", 2, testRunner,null,false);
	endwhile;
    
    
	// 17/02/2020 jlgmh5 - summary with just the failures in it
	userSummaryDict.clear();
	userIgnoreDict.clear();
	delete iter;
	
	summary := ""; 
	//summary := testRunner.getResultsSumFailOnly(userSummaryDict, userIgnoreDict, false, true);  //09.09.2025 navah1 #34969
	if isHtml and byTeam then //09.09.2025 navah1 #34969
		summary := testRunner.getResSumFailOnlyHTML(userSummaryDict, userIgnoreDict);
	else
		summary := testRunner.getResultsSumFailOnly(userSummaryDict, userIgnoreDict, false, byTeam);
	endif;
	log.writeLine(summary);
	// 28/04/2025  navhn30 	MTN-34403	 start
	if not byTeam then
		if not summary.cnContains("Failed: 0 ") then
			summary &amp;= CrLf &amp; "Note: This is tabbed delimited. If the spacing looks in-correct that will be because you are not viewing it with a monospace font. Please copy and paste the message into notepad, which uses a monospace font";
			app.emailReports(summary, "Failure Summary", 1, testRunner, byTeam,false);
		endif;
	else
		if not userSummaryDict.isEmpty then
			iter := userSummaryDict.createIterator;
			while iter.next(association) do
				iter.getCurrentKeys(teamName);
				if isHtml then //09.09.2025 navah1 #34969
					summary := "&lt;h3&gt;&lt;hr/&gt;Team " &amp; teamName &amp; "&lt;hr/&gt;&lt;/h3&gt;&lt;table border='1'&gt;&lt;tr&gt;&lt;th&gt;Pass/Fail&lt;/th&gt;&lt;th&gt;Time(Sec)&lt;/th&gt;&lt;th&gt;Start Date&lt;/th&gt;&lt;th&gt;Test Class/Name&lt;/th&gt;&lt;/tr&gt;" &amp; association.asString &amp; "&lt;/table&gt;";				
				else
					summary := "====================" &amp; CrLf &amp;
								"Team " &amp; teamName &amp; CrLf &amp;
								"====================" &amp; CrLf &amp;
								"P/F" &amp; Tab &amp; "Time (Sec)" &amp; Tab &amp; "Start Date" &amp; Tab &amp; Tab &amp; "Test Class/Name" &amp;
								association.asString;
					summary &amp;= CrLf &amp; "Note: This is tabbed delimited. If the spacing looks in-correct that will be because you are not viewing it with a monospace font. Please copy and paste the message into notepad, which uses a monospace font";
				endif;
				app.emailReports(summary, teamName, 1, testRunner, byTeam, isHtml);
				//write summary;
			endwhile;
		endif;
	endif;
		// 28/04/2025  navhn30 	MTN-34403	 end
	
	userSummaryDict.clear();
	userIgnoreDict.clear();
	
	summary := testRunner.getResultsSummary(userSummaryDict, userIgnoreDict);
	
	testRunner.getResultsSumFailOnly(userSummaryDict, userIgnoreDict, false, false);	//Need to re-run as results from above are by team
	
	iter := userSummaryDict.createIterator();
	summary := "";
	while iter.next(association) do
		userSummaryDict.getIteratorKeys(user, iter);
		summary := summary &amp; CrLf &amp; user &amp; app.masterAddress &amp; CrLf &amp; association.asStringWithoutFailures() &amp; CrLf; //association.asString;	// 24/03/2011 cnwmh5
		self.emailReports(app.formatFailureDetails(association.asString), user, 0, testRunner,null,false);		// 27/06/2017 cnwmh5
		//self.emailReports(association.asString, user, 0, testRunner);			//cnwmc5 - 12/10/2012
		//self.emailReports(summary, user, 0, testRunner);
	endwhile;
	
	self.emailReports(summary, "User Summary", 2, testRunner,null,false);			//cnwmc5 - 12/10/2012
	
	delete iter;
	iter := userIgnoreDict.createIterator();
	userIgnore := "";
	while iter.next(association) do
		userIgnoreDict.getIteratorKeys(user, iter);
		userIgnore := userIgnore &amp; CrLf &amp; user &amp; app.masterAddress &amp; CrLf &amp; association.asStringWithoutFailures() &amp; CrLf; //association.asString;	// 24/03/2011 cnwmh5
	endwhile;
	
	self.emailReports(userIgnore, "User Ignore Summary", 3, testRunner,null,false);			//cnwmc5 - 12/10/2012
	
	// navmd1 22/04/2022 Run the source comparison checj and send an email to the Devs
	// Run this after all the emails have been sent, just in case something goes wrong
	app.writeLog("Source Compare: IS WMAST: " &amp; app.isRunningInWMAST.String, LogINFO);
	if app.isRunningInWMAST then
		app.writeLog("Source Compare: Running Source Compare", LogINFO);
		checkAllTime := false;	// false = check only the last 7 days, true = check all time
		verAdmin.sendMsgWithIOParams(UT_Verification_Admin::vSourceComparison.name, runTestDailyONSave, checkAllTime, srcCompareErrors);
		
		if srcCompareErrors.length &gt; 0 then
			self.emailReports(srcCompareErrors, "Source Comparison Check Failed", 2, testRunner,null,false);
		endif;
	endif;
	
	// if running SCHEDULE_Weekly we need spawn an app to delete specified number of 
	// Log Result run(s)
	if scheduleName = "SCHEDULE_Weekly" and not disableONightRunSave then
		app.startApplication(currentSchema.name, "JMTCleanUpLogResultDetails");	
	endif;
	
	// 13/06/2016 cnwmh5 - write the end timestamp to the file
	if file &lt;&gt; null then
		endTime := app.myUMTestRunONight.endTS;
		file.open();
		file.writeLine(endTime.date.String &amp; Tab &amp; endTime.time.String);
		file.close();
	endif;
	
	// 17/04/2015 cnwmh5 - Compact of dat / map files
	userSummaryDict.clear();
	userIgnoreDict.clear();
	delete iter;
	whichToCompact := UM_MapFilesToCompact.WhenToCompactNext;
	if scheduleName = "SCHEDULE_Weekly" then
		whichToCompact := UM_MapFilesToCompact.WhenToCompactWeekly;
	endif;
	verAdmin.sendMsgWithIOParams('vCompactDatFiles', whichToCompact, userSummaryDict, runTestDailyONSave);
	iter := userSummaryDict.createIterator();
	while iter.next(association) do
		userSummaryDict.getIteratorKeys(user, iter);
		self.emailReports(association.asStringWithoutFailures(), "Compact Map / Dat files", 2, testRunner,null,false);
	endwhile;
	
epilog
	delete iter;
	delete userSummaryDict;
	delete userIgnoreDict;				// 13/09/2012 cnwmc5
	delete testRunner;
	delete paramNames;
	delete paramValues;
	delete profile;
	delete log;
	delete verAdmin;
	delete file;
	delete fileFolder;
	delete logCertify;
	delete stateObjectArray;
end;</source>
        <Parameter name="commandLine" type="String"/>
    </JadeMethod>
    <JadeMethod name="matchesScheduleDetails" id="afe3abec-eac5-4698-b111-ece1540d9a46">
        <source>matchesScheduleDetails(_obj : Object; _scheduleName : String) : Boolean;

/*

Purpose:		Matches the passed in schedule details

Date			Who		Reason
16/12/2014		cnwmh5	Initial creation

*/
constants
	XMLHeader						: String = "&lt;?xml version=";
	XMLAdditional					: String = "UT_Additional";
	XMLEndString					: String = XMLAdditional &amp; "&gt;";
	XMLCategories					: String = "Categories";	
	XMLCategory						: String = "Category";
vars

	xmlDocument						: JadeXMLDocument;
	xmlElementAdditional,
	xmlElementCategories,
	xmlElementCategory				: JadeXMLElement;
	xmlAttributeCategories			: JadeXMLAttribute;
	
	categoryElements				: JadeXMLElementArray;
	
	matchesScheduleDetails			: Boolean;
	text							: String;
	xmlHeaderPos					: Integer;
	xmlEndPos						: Integer;
	xmlText							: String;
	categoryText					: String;

begin

	on Exception do self.handleXMLExceptions(exception);
	
	// either null then dont care
	if _obj = null or _scheduleName = null then
		return matchesScheduleDetails;
	endif;
	
	// get the text.  if null don't care
	text := _obj.getPropertyValue("text").String;
	if text = null then
		return matchesScheduleDetails;
	endif;

	xmlHeaderPos := text.pos(XMLHeader, 1);
	xmlEndPos := text.reversePos(XMLEndString);
	if xmlHeaderPos &lt;&gt; 0 then
		xmlText := text[xmlHeaderPos:xmlEndPos + XMLEndString.length - xmlHeaderPos];
	endif;
	
	// xmlText null dont care
	if xmlText = null then
		return matchesScheduleDetails;
	endif;
	
	create xmlDocument transient;
	xmlDocument.parseString(xmlText);
	
	// check if there is a XMLAdditional element
	xmlElementAdditional := xmlDocument.getElementByTagName(XMLAdditional);
	if xmlElementAdditional = null then
		return matchesScheduleDetails;
	endif;

	// check to see if there is a XMLCategories element
	xmlElementCategories := xmlElementAdditional.getElementByTagName(XMLCategories);
	if xmlElementCategories = null then
		return matchesScheduleDetails;
	endif;
	
	// get all categories for the element
	create categoryElements transient;
	xmlElementCategories.getAllElementsByTagName(XMLCategory, categoryElements);
		
	// read through the category elements and update the category appropriately
	/////beginTransaction;
	foreach xmlElementCategory in categoryElements do
		categoryText := xmlElementCategory.text;
		if categoryText = _scheduleName then
			matchesScheduleDetails := true;
			text := text.replaceString(Cr, "");
			text := text.replaceString(Lf, " ");
			write Tab &amp; Tab &amp; method.qualifiedName() &amp; Tab &amp; _obj.String &amp; Tab &amp; _obj.getName() &amp; Tab &amp; text;
			break;
		endif;
	endforeach;
	
	return matchesScheduleDetails;

epilog

	delete xmlDocument;
	delete categoryElements;

end;</source>
        <Parameter name="_obj" type="Object"/>
        <Parameter name="_scheduleName" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="parseCommandLine" id="5a920ca8-561d-4809-a1e9-26ceb2a7d502">
        <source>parseCommandLine(_cmdLine: String; _paramNames: StringArray input; _paramValues: StringArray input);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
18 January 2011	cnwmh5	Initial creation

*/

vars

	tokensArray	: StringArray;
	
	line		: String;
	pos 		: Integer;
	paramName,
	paramValue	: String;
	
begin
	///inheritMethod(_cmdLine, _paramNames, _paramValues);

	create tokensArray transient;
	
	_cmdLine.getTokensForDelimiter(" ", tokensArray);
	
	foreach line in tokensArray do
		paramName := null;
		paramValue := null;
		if line.trimBlanks = null then
			continue;
		endif;
		pos := line.pos("=", 1);
		if pos = 0 then
			paramName := line.trimBlanks();
		else
			paramName := line[1:pos-1];
			paramValue := line[pos+1:end].trimBlanks();
		endif;
		_paramNames.add(paramName);
		_paramValues.add(paramValue);
	endforeach;
	
epilog

	delete tokensArray;
	
end;</source>
        <Parameter name="_cmdLine" type="String"/>
        <Parameter name="_paramNames" type="StringArray" usage="input"/>
        <Parameter name="_paramValues" type="StringArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="populateAllCategories" id="544e63f7-8123-47f5-8872-3de623ae4572">
        <source>populateAllCategories(_className, _methodName, _scheduleName : String; _logResult : Boolean);

/*

Purpose:		Get all Categories	

Parameters:			

Return Value:		


Date			Who		Reason
23 August 2011	cnwmh5	Initial creation
04/09/2012		cnwmh5	Add running of code coverage method
24/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls

*/

vars

	klass							: Class;
	meth							: Method;
	category						: UM_Category;
		
	classes							: ClassColl;
	methodsDict						: MethodNDict;
	
	methodsAddedArray				: ObjectArray;
	
	count 							: Integer;
	overnightRun					: Boolean;
	
begin
	
	overnightRun := app.isOvernightRun;
		
	self.allCategories.clear();
	
	// schedule name = SCHEDULE_FullRunNoLogResult get all classes
	if _scheduleName = "SCHEDULE_FullRunNoLogResult" then							// 17/04/2014 cnwmh5
		self.updateAllCatFullNoLogResult();	
		return;
	endif;
	
	// have class, and/or method
	if _className &lt;&gt; "UT_DSL" and (_className &lt;&gt; null or _methodName &lt;&gt; null) then
		create category transient;
		category.updateCategoryName(null);
		self.allCategories.add(category);
		category.updateCanBeDeleted(true);
			
		klass := currentSchema.getClass(_className);
		if klass &lt;&gt; null then
			meth := klass.getMethod(_methodName);
		endif;	
		if meth &lt;&gt; null then
			category.updateClassMethodCollection(meth);
		else
			category.updateClassMethodCollection(klass);
		endif;
		return;
	endif;
	
	// get the main unit test class, not found the leave
	klass := currentSchema.getClass("UT_DSL");
		
	// get the class and subclasses to see what categories we have
	create classes transient;
	classes.add(klass);
	//klass.allLocalSubclasses(classes);
	self.getListOfClassesToCheck(klass, classes);					// 02/11/2012 cnwmh5
	
	create methodsDict transient;
	create methodsAddedArray transient;
	
	foreach klass in classes do
		
		methodsAddedArray.clear();
		
		// check to see if the class's text has a category in it
		if _methodName = null then //and not _overnightRun then
			self.updateAllCategories(klass, _className, _methodName, _scheduleName, _logResult, methodsAddedArray);
			//if overnightRun and methodsAddedArray.size = 0 then
			//	continue;
			//endif;
		endif;
		
		// now check the methods to see if they are in a category
		if _methodName = null then
			//methodsDict := klass.cnGetMethods();
			//cnwmc5 - 13 Sep 2012
			methodsDict.clear();
			klass.cnGetMethods.copy(methodsDict);
		else
			methodsDict.add(klass.getMethod(_methodName));
		endif;
		
		methodsAddedArray.clear();
		count := 0;
		
		foreach meth in methodsDict do
			// if not runnable unit test method then next - or ignored..
			//if not meth.isRunnableUnitTestMethod() then
			if not meth.isTestToBeCounted() then		//cnwmc5 - 27 Sep 2012
				continue;
			endif;
			
			count := count + 1;
			
		
			// check to see if the method's text has a category in it
			self.updateAllCategories(meth, _className, _methodName, _scheduleName, _logResult, methodsAddedArray);
									
		//	endif;
			
		endforeach;
		
		if overnightRun then
		
			category := app.allCategories[null];
			if category = null then
				create category transient;
				category.updateCategoryName(null);
				app.allCategories.add(category);
			endif;
			if count &gt; 0 and count = methodsAddedArray.size then
				category.allCategoryClassMethods.add(klass);
			else
				methodsAddedArray.copy(category.allCategoryClassMethods);
			endif;
		
		endif;
		
	endforeach;
	
	// check to see if allCategories includes SCHEDULE_FullRunNoLogResult
	category := app.allCategories["SCHEDULE_FullRunNoLogResult"];								// 17/04/2014 cnwmh5
	if category &lt;&gt; null then
		self.updateAllCatFullNoLogResult();	
	endif;
	
	// add any methods that need to be run once the unit tests have finished
	/*
	if overnightRun and _logResult then						// 04/09/2012 cnwmh5
		category := app.allCategories[null];
		if category &lt;&gt; null then
			klass := currentSchema.getClass("UT_JMT");
			if klass &lt;&gt; null then
				meth := klass.getMethodInHTree("uCodeCoverage");
				if meth &lt;&gt; null then
					category.allCategoryClassMethods.add(meth);
				endif;
				/////if app.myUMTestRunONightSave &lt;&gt; null and app.overnightRun then					// 28/09/2012 cnwmh5	// 05/09/2013 cnwmh5 - Removed
				/////	beginTransaction;
				/////	app.myUMTestRunONightSave.setTotalRunnable(app.myUMTestRunONightSave.runnable + 1);
				/////	commitTransaction;
				/////endif;
			endif;
		endif;		
	endif;
	*/
	
epilog

	delete classes;
	delete methodsAddedArray;
	delete methodsDict;

end;</source>
        <Parameter name="_className" type="String"/>
        <Parameter name="_methodName" type="String"/>
        <Parameter name="_scheduleName" type="String"/>
        <Parameter name="_logResult" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="postXNumOpenInvoicesB4Date" id="c2655dd2-f46e-4529-b489-b58530c1ac5e">
        <source>postXNumOpenInvoicesB4Date();

/*

Purpose:		Post / Close invoices over X number of weeks	

Date			Who		Reason
20/03/2013		cnwmh5	Initial creation
24/04/2013		cnwcs5	par 30652 - remove resynch/resynchObject method calls
11/06/2015		cnwmh5	Change to use new cleanUpDetails class
*/
constants

	DELIM							: String = Tab;
	NoInvoicesToPost				: Integer = 15000;

vars

	invoice							: CM_Invoice;
	pxyInvoice						: CM_Invoice;
	bank							: CM_Bank;
	param							: CMIF_InvoiceSelection;
	terminal						: CM_Terminal;
	theStatus 						: CMIF_InvoiceStatus;
	debtor							: CM_Debtor;
	trackedItem						: CM_TrackedItem;
	//cleanUpDetails					: UM_CleanUpResultsDetails;
	cleanUpDetails					: UM_CleanUpDetails;
	
	invoices						: CM_InvoiceBySeqNumDict;
	
	statuses						: CMIF_Array;
	oa								: ObjectArray;
	termInvPostStatus				: BooleanArray;

	invPostWithoutAuditQual			: Boolean;
	debtorName 						: String;
	trackedItemId					: String;
	narration						: String;
	count							: Integer;
	finished						: Boolean;
	index 							: Integer;
	startTS							: TimeStamp;
	endTS							: TimeStamp;

begin

	// initializations
	//app.initialize();
	
	endTS.setDate(endTS.date.addMonths(-2));
	endTS.setDate(endTS.date.addDays(-1));
	endTS.setTime("23:59:59".Time);
	
	startTS := app.cnGetServerTime();
	
	create invoices transient;
	create param transient;
	
	create statuses transient;
	create oa transient;
	
	create termInvPostStatus transient;
	
	delete param;
	create param transient;
	param.status := CM_Invoice.INVOICE_PENDING;
	
	// 02/04/2013 cnwmh5 - Go through each terminal and set InvPostWithoutAuditQual = true
	foreach terminal in app.myRoot.allTerminals discreteLock do
		
		// set the terminals InvPostWithoutAuditQual
		//invPostWithoutAuditQual := terminal.getConfig(InvPostWithoutAuditQual).Boolean;
		termInvPostStatus.add(terminal.getConfig(InvPostWithoutAuditQual).Boolean);
		beginTransaction;
		terminal.setConfig(InvPostWithoutAuditQual, true);
		commitTransaction;
		
		
	//	if not terminal.getConfig(InvPostWithoutAuditQual).Boolean then
	//		app.writeLog("Terminal (" &amp; terminal.code &amp; ") InvPostWithoutAuditQual has not been set correctly", LogINFO);
	//	endif;
		
	endforeach;
	
	// PENDING
	finished := false;
	foreach terminal in app.myRoot.allTerminals discreteLock do
		
		// set the passports terminal - required in trx level
		app.myPassport.setMyTerminal(terminal);
		
		// set the terminals InvPostWithoutAuditQual
		///invPostWithoutAuditQual := terminal.getConfig(InvPostWithoutAuditQual).Boolean;
		///beginTransaction;
		///terminal.setConfig(InvPostWithoutAuditQual, true);
		///commitTransaction;
		
		foreach bank in terminal.companies discreteLock do
			
			statuses.clear();
			
			// Set the status for invoice / invoice lines to POSTED
			foreach invoice in bank.allInvoices discreteLock where invoice.status = CM_Invoice.INVOICE_OPEN do
		
				// if the invoice date &gt; end date then get next record
				if invoice.fromDT &gt; endTS then
					continue;
				endif;
				
				debtor := invoice.debtor;
				debtorName := null;
				if debtor &lt;&gt; null then
					debtorName := debtor.name;
				endif;
			
				trackedItem := invoice.myTrackedItem;
				trackedItemId := null;
				if trackedItem &lt;&gt; null then
					trackedItemId := trackedItem.id;
				endif;
		
				narration := invoice.narration;
				narration := narration.replaceString(CrLf, " ");
			
				pxyInvoice := app.createUpdateProxy(invoice).CM_Invoice;
				oa.add(pxyInvoice);	
				if not invoices.includes(invoice) then
					invoices.add(invoice);
				endif;
				
				create theStatus transient;
				theStatus.myInvoice := pxyInvoice;
				theStatus.newStatus := CM_Invoice.INVOICE_PENDING;
				theStatus.purchaseOrderNumber := 666.String;
				theStatus.narration := invoice.narration;
				theStatus.isZeroRatedTax := invoice.isZeroRatedTax;
				theStatus.myTermsOfTrade := invoice.invoiceType.myInvTermsOfTrade;
				theStatus.debtorReference := invoice.debtorReference;
				theStatus.toDT.setDate(invoice.toDT.date);
				theStatus.toDT.setTime('23:59:59.999'.Time);
				theStatus.doExport := false;
				statuses.add(theStatus);
				
		//		app.writeLog("Changing invoice (" &amp; invoice.sequenceNum.String &amp; ") status from OPEN to PENDING.  " &amp; 
		//			terminal.code &amp; DELIM &amp; bank.code &amp; DELIM &amp; invoice.fromDT.String &amp; DELIM &amp; debtorName &amp; DELIM &amp; 
		//			trackedItemId &amp; DELIM &amp; narration, LogINFO);
				
				count := count + 1;
				if count &gt;= NoInvoicesToPost then
					finished := true;
					break;
				endif;
				
			endforeach;
			
			// update the invoice / invoice lines to PENDING
			if not statuses.isEmpty() then
				app.myTrxUA.trxUpdateInvoiceStatuses(statuses, app.myPassport);
				if not app.myPassport.trxCompletedOK then
		//			app.writeLog("Error during PENDING" &amp; Tab &amp; app.myPassport.getAllErrorsAndWarningsAsStr(), LogINFO);
					beginTransaction;
					create cleanUpDetails persistent;
					///cleanUpDetails.createRecord(startTS, app.cnGetServerTime(), count, "Posted - Error", 0, 0);
					cleanUpDetails.updateDetails(startTS, app.cnGetServerTime(), count, UM_CleanUpDetails.TaskDescriptionPostInvoiceErr, null);
					commitTransaction;
					return;
				endif;
			endif;
			
			if finished then
				break;
			endif;
			
		endforeach;
	
		///beginTransaction;
		///terminal.setConfig(InvPostWithoutAuditQual, invPostWithoutAuditQual);
		///commitTransaction;
		
		if finished then
			break;
		endif;

	endforeach;
	
	// POSTED
	if oa &lt;&gt; null then
		oa.purge;
	endif;
	delete oa;
	create oa transient;
	statuses.clear();
	delete param;
	create param transient;
	param.status := CM_Invoice.INVOICE_POSTED;
	foreach invoice in invoices do
	
		// set the passports terminal - required in trx level
		app.myPassport.setMyTerminal(invoice.myTerminal);
	///	invPostWithoutAuditQual := invoice.myTerminal.getConfig(InvPostWithoutAuditQual).Boolean;
	///	beginTransaction;
	///	invoice.myTerminal.setConfig(InvPostWithoutAuditQual, true);
	///	commitTransaction;
		
		debtor := invoice.debtor;
		debtorName := null;
		if debtor &lt;&gt; null then
			debtorName := debtor.name;
		endif;
	
		trackedItem := invoice.myTrackedItem;
		trackedItemId := null;
		if trackedItem &lt;&gt; null then
			trackedItemId := trackedItem.id;
		endif;

		narration := invoice.narration;
		narration := narration.replaceString(CrLf, " ");
	
		pxyInvoice := app.createUpdateProxy(invoice).CM_Invoice;
		oa.add(pxyInvoice);		
	
		create theStatus transient;
		theStatus.myInvoice := pxyInvoice;
		theStatus.newStatus := CM_Invoice.INVOICE_POSTED;
		theStatus.purchaseOrderNumber := 666.String;
		theStatus.narration := invoice.narration;
		theStatus.isZeroRatedTax := invoice.isZeroRatedTax;
		theStatus.myTermsOfTrade := invoice.invoiceType.myInvTermsOfTrade;
		theStatus.debtorReference := invoice.debtorReference;
		theStatus.toDT.setDate(invoice.toDT.date);
		theStatus.toDT.setTime('23:59:59.999'.Time);
		theStatus.doExport := false;
		statuses.add(theStatus);
	
	//	app.writeLog("Changing invoice (" &amp; invoice.sequenceNum.String &amp; ") status from PENDING to POSTED.  " &amp; 
	//		terminal.code &amp; DELIM &amp; bank.code &amp; DELIM &amp; invoice.fromDT.String &amp; DELIM &amp; debtorName &amp; DELIM &amp; 
	//		trackedItemId &amp; DELIM &amp; narration, LogINFO);
		
		///beginTransaction;
		///invoice.myTerminal.setConfig(InvPostWithoutAuditQual, invPostWithoutAuditQual);
		///commitTransaction;
		
	endforeach;
	
	// update the invoice / invoice lines to POSTED
	if not statuses.isEmpty() then
		app.myTrxUA.trxUpdateInvoiceStatuses(statuses, app.myPassport);
		if not app.myPassport.trxCompletedOK then
	//		app.writeLog("Error during POSTING" &amp; Tab &amp; app.myPassport.getAllErrorsAndWarningsAsStr(), LogINFO);
			beginTransaction;
			create cleanUpDetails persistent;
			//cleanUpDetails.createRecord(startTS, app.cnGetServerTime(), count, "Posted - Error", 0, 0);
			cleanUpDetails.updateDetails(startTS, app.cnGetServerTime(), count, UM_CleanUpDetails.TaskDescriptionPostInvoiceErr, null);
			commitTransaction;
			return;
		endif;
	endif;

	// 02/04/2013 cnwmh5 - Go through each terminal and set InvPostWithoutAuditQual = true
	index := 1;
	foreach terminal in app.myRoot.allTerminals discreteLock do
		
		// set the terminals InvPostWithoutAuditQual
		beginTransaction;
		terminal.setConfig(InvPostWithoutAuditQual, termInvPostStatus[index]);
		commitTransaction;
		
		
	//	if terminal.getConfig(InvPostWithoutAuditQual).Boolean &lt;&gt; termInvPostStatus[index] then
	//		app.writeLog("Terminal (" &amp; terminal.code &amp; ") InvPostWithoutAuditQual has not been correctly set to " &amp; 
	//			termInvPostStatus[index].String, LogINFO);
	//	endif;
		
		index := index + 1;
		
	endforeach;
	
	beginTransaction;
	create cleanUpDetails persistent;
	//cleanUpDetails.createRecord(startTS, app.cnGetServerTime(), count, "Posted", 0, 0);
	cleanUpDetails.updateDetails(startTS, app.cnGetServerTime(), count, UM_CleanUpDetails.TaskDescriptionPostInvoice, null);
	commitTransaction;
	
epilog

	delete termInvPostStatus;
	delete invoices;
	if oa &lt;&gt; null then
		oa.purge;
	endif;
	delete oa;
	if statuses &lt;&gt; null then
		statuses.purge;
	endif;
	delete statuses;
	delete param;

end;</source>
    </JadeMethod>
    <JadeMethod name="restoreTermActiveCargoMap" id="6622d64a-f338-40d9-ad79-1277feb29b22">
        <source>restoreTermActiveCargoMap(_saveCargoMapArray : ObjectArray io);

/*

Purpose:		Restore the terminals active cargo maps to what they were saved to

Date			Who		Reason
20 March 2013	cnwmh5	Initial creation

*/

vars

	cargoMap				: CM_TranMap;
	obj						: Object;
	terminal				: CM_Terminal;

begin

	// set back to original cargo map
	foreach obj in _saveCargoMapArray do
		cargoMap := obj.CM_TranMap;
		terminal := cargoMap.bank.terminal;
		app.myPassport.setMyTerminal(terminal);
		app.myTrxUA.trxUpdateBankTMActive(cargoMap, app.myPassport);
	endforeach;
	
	app.myPassport.setMyTerminal(app.myRoot.allTerminals["UT"]);			// 22/03/2013 cnwmh5
	
epilog

end;</source>
        <Parameter name="_saveCargoMapArray" type="ObjectArray" usage="io"/>
    </JadeMethod>
    <JadeMethod name="returnCorrectUserName" id="6c16f9da-4377-4174-a19d-4e3a30bc03ff">
        <source>returnCorrectUserName(_userName : String; _isSave : Boolean) : String;

/*

Purpose:		

Date			Who		Reason
04 July 2017	cnwmh5	Initial creation

*/
/*
vars

	userName				: String;

begin

	userName := _userName.toUpper();
	if app.masterAddress = "@jadeworld.com" then
		if not _isSave then
			userName := userName.replaceString("JLG", "CNW");
		else
			userName := userName.replaceString("CNW", "JLG");
		endif;
	else
		if _isSave then
			userName := userName.replaceString("CNW", "JLG");
		endif;
	endif;
	
	return userName;

epilog

end;
*/
/*
18/02/2020		jlgmh5	Rewrite for split between Navis and JLI
*/

vars

	userName				: String;

begin


	userName := app.returnCorrectUserName_Navis(_userName, _isSave);
	return userName;

epilog

end;
</source>
        <Parameter name="_userName" type="String"/>
        <Parameter name="_isSave" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="returnCorrectUserName_JLI" id="e97ce043-de30-490e-a6b1-a63ef3c768d2">
        <source>returnCorrectUserName_JLI(_userName : String; _isSave : Boolean) : String;

/*

Purpose:		

Date			Who		Reason
04 July 2017	cnwmh5	Initial creation
18/02/2020		jlgmh5	Change to handle non JLI users set to 1st admin
*/

vars

	user					: CM_User;
	userEmail				: UM_UserEmailAddress;
	root					: UM_Root;

	
	userName				: String;
	origUserName			: String;

begin

	root := UM_Root.firstInstance();
	
	userName := _userName.toUpper();
	origUserName := userName;
	
	if userName[1:3] = "CNW" or userName[1:3] = "JLG" then
		userName := "JLI" &amp; userName[4:end];
	endif;
	
	user := app.myRoot.allUsers[userName];
	if user = null then
		foreach userEmail in root.allUserEmailAddresses where userEmail.isAdmin do
			
			if userEmail.isDisabled then
				continue;
			endif;
			
			if not userEmail.isAdmin then
				continue;
			endif;
			
			userName := userEmail.user;
			userName := userName.replaceString("JLG", "CNW");
			break;
		
		endforeach;
	else
		userName := origUserName;
	endif;
	
	userName := "JLG" &amp; userName[4:end];
	
	return userName;

epilog

end;

/*
vars

	userEmail				: UM_UserEmailAddress;
	root					: UM_Root;

	userName				: String;
	userName2				: String;

begin

	root := UM_Root.firstInstance();

	userName := _userName.toUpper();
	write method.qualifiedName() &amp; Tab &amp; userName;
	
	// check to see whether the user is no longer JLI
	userName := app.returnCorrectUserName_Navis(_userName, _isSave);
	if userName[1:3] = "NSL" then
		write "found a match for a Navis dev: " &amp; _userName;
		
		foreach userEmail in root.allUserEmailAddresses where userEmail.isAdmin do
			
			if userEmail.isDisabled then
				continue;
			endif;
			
			if not userEmail.isAdmin then
				continue;
			endif;
			
			userName := userEmail.user;
			break;
		
		endforeach;
		
		write "found first admin: " &amp; userName;
	endif;	
	
	
	if app.masterAddress = "@jadeworld.com" or app.masterAddress = "@jadelogistics.com" then
		if not _isSave then
			userName := userName.replaceString("JLG", "CNW");
		else
			userName := userName.replaceString("CNW", "JLG");
		endif;
	else
		if _isSave then
			userName := userName.replaceString("CNW", "JLG");
		endif;
	endif;
		
	return userName;

epilog

end;
*/</source>
        <Parameter name="_userName" type="String"/>
        <Parameter name="_isSave" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="returnCorrectUserName_Navis" id="46977d46-c216-45bc-8c3f-e45efad97b3b">
        <source>returnCorrectUserName_Navis(_userName : String; _isSave : Boolean) : String;

/*

Purpose:		

Date			Who		Reason
18/02/2020		jlgmh5	Initial write

*/

vars

	user					: CM_User;

	userName				: String;

begin

	userName := _userName.toUpper();
	
	if userName[1:3] = "CNW" or userName[1:3] = "JLG" then
		userName := "NSL" &amp; userName[4:end];
	endif;
	
	user := app.myRoot.allUsers[userName];
	if user = null then
		userName := _userName.toUpper();
	endif;
	
	return userName;

epilog

end;</source>
        <Parameter name="_userName" type="String"/>
        <Parameter name="_isSave" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="saveTermActiveCargoMapSet2Dflt" id="2989075d-e43d-44cb-a9b1-9c687cd94c67">
        <source>saveTermActiveCargoMapSet2Dflt(_savedCargoMapArray : ObjectArray io);

/*

Purpose:		Save all terminals active cargo maps and set to default	

Date			Who		Reason
20/03/2013		cnwmh5	Initial creation
16/01/2014		cnwmh5	Change to use sendMsgWithParams rather than creating a transient and deleting it
						because delete clears sets CMIF_Logger to null which means no writeLogs come out.
17/05/2016 		cnwmh5	After talking to John E have removed the creating of the default tran map as not needed
*/

vars

	bank				: CM_Bank;
	cargoMap			: CM_TranMap;
	terminal			: CM_Terminal;
	obj					: Object;

	fileName 			: String;
	mapName				: String;
	fileContent			: String;
	
begin
	
	_savedCargoMapArray.clear();
	
	// read through all the terminals and save the current active cargo map.  Set terminal to default
	foreach terminal in app.myRoot.allTerminals do
		
		app.myPassport.setMyTerminal(terminal);
		
		// get the terminal's default company bank
		bank := terminal.getDefaultCompanyBank();
		if bank &lt;&gt; null then
			foreach cargoMap in bank.myCurrentTranMapCargo do
				// active cargo map found so exit
				if cargoMap.isActive then
					break;
				endif;
			endforeach;
			
			// if active cargo map found then save to array
			if cargoMap &lt;&gt; null then
				_savedCargoMapArray.add(cargoMap);
			endif;
			
			
		endif;
	endforeach;

epilog

end;</source>
        <Parameter name="_savedCargoMapArray" type="ObjectArray" usage="io"/>
    </JadeMethod>
