    <JadeMethod name="setForUpdate" id="419db058-f784-4d27-9be4-2063c910631f">
        <updating/>
        <source>setForUpdate( _proxy : CM_InvTypeGroupingMinCharge ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 March 2019	jlgndl1	Initial creation	TFS 43687

*/

vars

begin

	self.allLineTypesForMinimumCharge.clear();
	if not _proxy.allLineTypesForMinimumCharge.isEmpty then
		_proxy.allLineTypesForMinimumCharge.copy( self.allLineTypesForMinimumCharge );
	endif;

	self.description := _proxy.description;
	self.groupLinesBy := _proxy.groupLinesBy;
	self.minimumChargeAmount := _proxy.minimumChargeAmount;
	self.moveType := _proxy.moveType;
	self.myMinimumChargeInvoiceLineType := _proxy.myMinimumChargeInvoiceLineType;
	self.mySurchargesAndExemptions := _proxy.mySurchargesAndExemptions;
	

epilog

end;</source>
        <Parameter name="_proxy" type="CM_InvTypeGroupingMinCharge"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="c6594024-e420-487e-8688-69722f31d012">
        <updating/>
        <source>setProxy(	_allLineTypesForMinimumCharge : CM_InvoiceLineDescSet;
			_description : String;
			_groupLinesBy : Integer;
			_minimumChargeAmount : Real;
			_moveType : String;
			_myMinimumChargeInvoiceLineType : CM_InvoiceLineDesc;
			_mySurchargesAndExemptions : CM_InvoiceTypeSurchargeExempt
			) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 March 2019	jlgndl1	Initial creation	TFS 43687

*/

vars

begin

	self.allLineTypesForMinimumCharge.clear();
	if not _allLineTypesForMinimumCharge.isEmpty then
		_allLineTypesForMinimumCharge.copy( self.allLineTypesForMinimumCharge );
	endif;

	self.description := _description;
	self.groupLinesBy := _groupLinesBy;
	self.minimumChargeAmount := _minimumChargeAmount;
	self.moveType := _moveType;
	self.myMinimumChargeInvoiceLineType := _myMinimumChargeInvoiceLineType;
	
	self.mySurchargesAndExemptions := _mySurchargesAndExemptions;

epilog

end;</source>
        <Parameter name="_allLineTypesForMinimumCharge" type="CM_InvoiceLineDescSet"/>
        <Parameter name="_description" type="String"/>
        <Parameter name="_groupLinesBy" type="Integer"/>
        <Parameter name="_minimumChargeAmount" type="Real"/>
        <Parameter name="_moveType" type="String"/>
        <Parameter name="_myMinimumChargeInvoiceLineType" type="CM_InvoiceLineDesc"/>
        <Parameter name="_mySurchargesAndExemptions" type="CM_InvoiceTypeSurchargeExempt"/>
    </JadeMethod>
