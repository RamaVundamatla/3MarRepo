    <JadeMethod name="translateForm" id="01dbcdbc-a3a5-49b7-874d-e14243205d9b">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 16 July 2024 14:55:16.
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0026900, locale);
	btnAudits.translateCaption(Xlat_0026901, locale);
	btnCancel.translateCaption(Xlat_0026902, locale);
	btnEmail.translateCaption(Xlat_0026903, locale);
	btnNew.translateBubbleHelp(Xlat_0026904, locale);
	btnNew.translateCaption(Xlat_0026905, locale);
	btnRemove.translateCaption(Xlat_0026906, locale);
	btnSave.translateCaption(Xlat_0026907, locale);
	chkIncludeLoad.translateCaption(Xlat_0026908, locale);
	chkIncludeVerify.translateCaption(Xlat_0026909, locale);
	lblCode.translateCaption(Xlat_0026910, locale);
	lblDesc.translateCaption(Xlat_0026911, locale);
	lblEmail.translateCaption(Xlat_0026912, locale);
	mnuColumnOrganiser.translateCaption(Xlat_0026913, locale);
	mnuContextMenu.translateCaption(Xlat_0026914, locale);
	mnuInspectObject.translateCaption(Xlat_0026915, locale);
	msgEDITypes.translateCaption(Xlat_0026916, locale);
end;</source>
    </JadeMethod>
