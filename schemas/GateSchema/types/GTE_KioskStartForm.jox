    <JadeMethod name="doClear" id="5dc0449b-343a-4b7c-aab7-09df49d50460">
        <updating/>
        <source>doClear() updating, protected;
// --------------------------------------------------------------------------------
// Created:		29 June 2006 by cnwdad1
//
// Purpose:		Refer to superclass implementation.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	inheritMethod();
	
	txtRegoNo.cnEcSet(null);
	cmbCarrier.cnEcSet(CNEC_NULL_INDEX);
	self.aMyProxyLoad.clearMe();
	self.doEnableControls();
end;</source>
