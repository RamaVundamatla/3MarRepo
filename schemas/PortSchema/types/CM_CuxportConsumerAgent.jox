    <JadeMethod name="sendShipReleaseToEDBIC" id="04bb96a5-885d-4bed-8d10-8e8a291b1681">
        <updating/>
        <source>sendShipReleaseToEDBIC(_activeCuxportExtDef : CM_CuxportServiceDef; _trackedItem : CM_TrackedItem; _terminal : CM_Terminal) : Boolean updating;
/*

Purpose:			User Story 53730.050 - Send Export Cargo Details to EDBIC for Each Unit of Cargo Loaded to the Vessel

Parameters:			

Return Value:		

Date		Who		Reason
22 Nov 2022	navpw1	Initial creation TFS: 55215
11 Apr 2023	navdap1	TFS 57362 CUX Changes to Outgoing Message Formats
17 Apr 2023	navdap1	TFS 57207 EUP - Refactor Inspection App API Message
20 Jun 2023	navdap1	TFS 58722 EUP "Class of object is invalid in this context" error when gating in cargo
*/

vars
	extWebService			: CM_ExternalWebServiceDef;		// TFS 58722
