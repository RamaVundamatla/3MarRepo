    <JadeMethod name="doAddItem" id="719d00d9-9ada-4bbf-b810-7bb48bbb27d5">
        <updating/>
        <source>doAddItem() protected, updating;
/*

Purpose:			Sets up the UI to add an item

Parameters:			NONE

Return Value:		NONE

Date			Who		Reason
10 October 2022	navpw1	Initial creation TFS: 54566

*/

begin
	self.mode := self.Mode_Add;
	self.initCreateEditFrame(null);
	self.btnShowSearcher.enabled := false;
	self.searcherShowHideControls(false);
	self.setControlsForView();
	self.btnAddItem.enabled := false;
	self.frmProperties.visible := (not self.frmProperties.visible);
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doBaseFormSave" id="0959cd58-c812-4dcc-b58c-655871c6a230">
        <updating/>
        <source>doBaseFormSave() updating, protected;
/*

Purpose:			Saves the new invoice line mapping

Parameters:			NONE

Return Value:		NONE

Date			Who		Reason
10 October 2022	navpw1	Initial creation TFS: 54566

*/

vars
	selectedInvLineDescMapping,
	pxyMapping, 
	realMapping						: CM_InvoiceLineDescMapping;
	ls								: Boolean;
	theReturn						: Integer;
	selectedDebtor					: CM_Debtor;
	selectedInvoiceLineType			: CM_InvoiceLineDesc;
	selectedInvoiceType				: CM_InvoiceDesc;
	
begin
	self.btnShowSearcher.enabled	:= true;
	
	selectedInvLineDescMapping		:= self.myCurrentInvLineMapping;
	
	selectedDebtor			:= self.cmbDebtor.listObject.CM_Debtor;
	selectedInvoiceLineType	:= self.cmbInvoiceLineType.listObject.CM_InvoiceLineDesc;
	selectedInvoiceType		:= self.cmbInvoiceType.listObject.CM_InvoiceDesc;
	
	if selectedInvLineDescMapping &lt;&gt; null and self.mode = self.Mode_Update then
		realMapping := self.myCurrentBank.allInvoiceLineDescMappings[selectedInvLineDescMapping.myDebtor.CM_Debtor, selectedInvLineDescMapping.myInvoiceLineDesc, selectedInvLineDescMapping.myInvoiceType];
	endif;
	
	if realMapping &lt;&gt; null then	
		app.cmsBeginLoad(ls);
		pxyMapping := app.createUpdateProxy(realMapping).CM_InvoiceLineDescMapping;
		app.cmsEndLoad(ls);
	else
		create pxyMapping transient;
	endif;
	
	pxyMapping.setProxy(self.myCurrentBank, selectedDebtor, selectedInvoiceLineType, selectedInvoiceType);
	
	while true do
		if self.mode = self.Mode_Update and realMapping &lt;&gt; null and selectedInvoiceLineType.invoiceType = selectedInvoiceType then
			app.myTrxDA.trxDeleteInvoiceLineDescMap(realMapping, app.myPassport);
		elseif self.mode = self.Mode_Update then
			app.myTrxUA.trxUpdateInvoiceLineDescMap(pxyMapping, app.myPassport);
		else
			app.myTrxCA.trxCreateInvoiceLineDescMap(pxyMapping, realMapping, app.myPassport);
		endif;
		
		if app.myPassport.trxCompletedOK then
			// Clear errors/warnings from form and err/warnings window
			self.clearErrorWarnings();
			self.frmProperties.visible := false;
			global.beep;
			break;
		else
			theReturn := app.showErrorWarningDialog("Mapping Entry", app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   theReturn = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
			return;
		endif;
		break;
	endwhile;
	
	self.frmProperties.visible := false;
	self.searcherShowHideControls(true);
	
epilog
	app.cmsEndLoad(ls);
	delete pxyMapping;
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doCancel" id="7d9813c8-8032-4ba9-a564-9dcb85d6344f">
