    <JadeMethod name="unload" id="5f190423-b6bf-4d46-8199-7d30e92e7672">
        <controlMethod name="Form::unload"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>unload() updating;
// ---------------------------------------------------------------------------
// Created:		January 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars

begin
	inheritMethod();
	self.allDrawingControllers.purge;
	self.allDockBars.purge;

	self.clearupMenuParams();
	self.allMenuTransients.purge; // PAR 18723

	self.allParameters.purge();
	
	if self.deleteEnqSelector then	//03 Aug 2011	NDl	Par 27890
		if self.mySelectorEnquiryController &lt;&gt; null then
			delete self.mySelectorEnquiryController.allObjects;
			delete self.mySelectorEnquiryController.myCriteriaLineHolder;
		endif;
		delete self.mySelectorEnquiryController;
	endif;

end;</source>
    </JadeMethod>
    <JadeMethod name="updateTableColumnFilters" id="ba461729-6fb1-4528-8fff-fbaaadffe4d4">
        <updating/>
        <source>updateTableColumnFilters(_table: Table; _allFilterColumns: CM_ColumnFilterDict) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
09 January 2012	cnwndl1	Initial creation	Par 28889

*/

vars

begin

	if self.allColumnFilters = null then
		create self.allColumnFilters transient;  // this is a non exclusive collection.
	endif;
	
	self.allColumnFilters.replaceAllFiltersForTable( _table, _allFilterColumns );

epilog

end;</source>
        <Parameter name="_table" type="Table"/>
        <Parameter name="_allFilterColumns" type="CM_ColumnFilterDict"/>
    </JadeMethod>
    <JadeMethod name="userNotify" id="9e1643fa-d9dc-4a10-a807-ac19a8f5fef7">
        <controlMethod name="Form::userNotify"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>userNotify(eventType: Integer; theObject: Object; eventTag: Integer; userInfo: Any) updating;
// ---------------------------------------------------------------------------
// Created:		October 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
begin

	if eventType = EVENT_CODE_COLOUR_CHANGE then
		self.frmColLegendTIs.redisplayViewModeCodes();
		// need to redraw to update colours of displayed TIs
		self.redraw();
		return;
	endif;
	
	if eventType = EVENT_DrawingAttrControllerAdd then
//		self.frmColLegendTIs.addRow();
	endif;

	inheritMethod(eventType, theObject, eventTag, userInfo);

epilog
	// belts and braces to ensure any possible locks are cleared.
	// We should not be in loadstate anyway
	endLoad;

end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
        <Parameter name="userInfo" type="Any"/>
    </JadeMethod>
    <JadeMethod name="viewForMode" id="00022854-42a2-4bce-a9b1-68d7cea68478">
        <updating/>
        <source>viewForMode(_theIndex : Integer) updating, protected;
// ---------------------------------------------------------------------------
// Created:     08 September 2003 by cnwrs2
//
// Purpose:     
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 15/06/2009	consw1		PAR 19913 - SFW1067 Rail Simplifications
// 19 May 2022	navtnr20	ChangeRequest 53204: EUP - GEN/REP/INB - Additional Cargo Field – Shipping Line - UI
// ---------------------------------------------------------------------------
vars
	ydc : YRD_ContainerDrawingController;
	anObj : Object;
	oldYDCMode : Integer;
begin

	if _theIndex &lt;= VIEW_TEMPERATURE or 
	   _theIndex = VIEW_WEIGHT or 
	   _theIndex = VIEW_LOADPORT or
	   _theIndex = VIEW_DESTPORT or 
	   _theIndex = VIEW_TRAIN or
	   _theIndex = VIEW_DWELL_DAYS or	//20 Jul 2011	NDL	Par 27890
	   _theIndex = VIEW_MTGRADE or	//29 Jul 2011	NDL	Par 27890
	   _theIndex = VIEW_YARD_ALLOC or
	   _theIndex = VIEW_CARRIERIN or	// 9/6/17 MAP TFS4209
	   _theIndex = VIEW_SHIPPINGLINE or		//19-may-2022 navtnr20 53204
	   _theIndex = VIEW_CARRIEROUT then	// 9/6/17 MAP TFS4209

		if _theIndex &lt;&gt; VIEW_YARD_ALLOC then
			self.enableCargoToolButtons(true);
			self.btnViewYardAlloc.value := false;
			self.viewModePrev4YardAlloc := null;
		endif;

		foreach anObj in self.allDrawingControllers do
			ydc := anObj.YRD_ContainerDrawingController;
			if ydc.viewMode = _theIndex then
				continue;
			endif;
			if _theIndex = VIEW_YARD_ALLOC then
				ydc.setViewMode(_theIndex);
			else
				oldYDCMode := ydc.viewMode;
				self.frmStatusLine.myFrameCaption.caption := ydc.setViewMode(_theIndex);
				if (oldYDCMode = VIEW_YARD_ALLOC and _theIndex &lt;&gt; self.viewModePrev4YardAlloc)
				or (oldYDCMode &lt;&gt; VIEW_YARD_ALLOC) then
					ydc.drawSelf(false);
				endif;
			endif;
			if _theIndex = VIEW_IMPORT or 
			   _theIndex = VIEW_EXPORT then
			else
				self.setCaptionForModesGetView(_theIndex);
				self.doNotesForLegendStartStop(_theIndex,ydc);
			endif;
		endforeach;
				
	else
		app.raiseUnexpectedProgramError(class.name, method.name, 'Invalid _index (' &amp; _theIndex.String &amp; ')');
	endif;
	

end;</source>
        <access>protected</access>
        <Parameter name="_theIndex" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="xmlToolbar" id="26384593-0285-40a7-8fbf-8f8ccc1c5dfe">
        <methodInvocation>mapping</methodInvocation>
        <updating/>
        <source>xmlToolbar(set: Boolean; _value: Boolean io) mapping, updating;
// ---------------------------------------------------------------------------
// Created:		August 2003 By Andrew Bishop cnwab1
//
// Purpose:		This means HIDE the toolbars
//
// ---------------------------------------------------------------------------

vars

begin
	if set then
		if not _value then
			self.mnuGridHideToolbar.caption := self.MNU_TOOLBAR_HIDE;
		else
			self.showHideToolbars(true);
			self.mnuGridHideToolbar.caption := self.MNU_TOOLBAR_SHOW;
		endif;
	endif;
end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="Boolean" usage="io"/>
    </JadeMethod>
</GUIClass>
