    <JadeMethod name="getTerminalFromEvent" id="d8a65816-ce46-43e4-bdc0-27c4e853b69c">
        <source>getTerminalFromEvent(_event : Integer) : CM_Terminal;

// cnwdvb1 01 November 2002 
/*

Date		Who		Reason
14 Sep 2012	cnwkpd1	PAR #29274 - Replace Object::getInstanceIdForObjectXX with RootSchema methods
	
*/

vars
	terminal	: CM_Terminal;
	iter		: Iterator;
	instanceId	: Integer;

begin
	instanceId := _event div TERMINAL_EVENTS_FACTOR;
	iter := self.allTerminals.createIterator;
	while iter.next(terminal) do
		if instanceId = self.getInstanceIdForObject64(terminal).Integer then
			break;
		endif;
		terminal := null;
	endwhile;
	return terminal;

epilog
	delete iter;
	
end;</source>
        <Parameter name="_event" type="Integer"/>
        <ReturnType type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="getTerminalsUnassignedToHarbou" id="fb50538a-5d70-4cea-bd79-2b1e5a0e7a68">
        <source>getTerminalsUnassignedToHarbou(_termDict : CM_TerminalByCodeDict input);
//--------------------------------------------------
// Created:	17 November 2004 By: cnwgd1
//--------------------------------------------------
vars
	term : CM_Terminal;
begin
	if _termDict = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Null dict passed to method');
		return;
	endif;
	
	//Do not clear dict as may have already added extra termianls required for view
	foreach term in self.allTerminals do
		if term.myHarbour = null then
			_termDict.add(term);
		endif;
	endforeach;
end;</source>
        <Parameter name="_termDict" type="CM_TerminalByCodeDict" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getTranslatedRequiredInfoType" id="1a0bd078-69e0-41d0-9923-b56fa8b13e3e">
        <source>getTranslatedRequiredInfoType( _requiresInfoType : Integer ) : String;

/*
Purpose:	Return the translated string for the StopsTable requiredInfoType field.

Date			Who		Reason
31 August 2010	cnwrl1	Initial creation as part of PAR 23697 - CCMS 1097 - Stop Expiry - retain info after expiry.
*/
	
vars
	returnStr	: String;
	
begin
	if _requiresInfoType = CEDO then
		returnStr	:= app.getErrorString( CM_CEDO );
	elseif _requiresInfoType = CustomsEntryNumber then
		returnStr	:= app.getErrorString( CM_Customs_Entry_Number );
	elseif _requiresInfoType = ImportReleasePIN then
		returnStr	:= app.getErrorString( CM_Operator_Import_PIN );
	elseif _requiresInfoType = ExportReleaseNumber then
		returnStr	:= app.getErrorString( CM_Operator_Export_Rel_Number );
	elseif _requiresInfoType = DeliveryRelease then
		returnStr	:= app.getErrorString( Delivery_Release_Number );
	elseif _requiresInfoType = CustomsReference then	//30 Jun 2015	NDL	Par 36543
		returnStr	:= app.getErrorString( Customs_reference );
	elseif _requiresInfoType = SOLAS then
		returnStr 	:= app.getErrorString(SOLAS_VGM_Details); //epr TFS 1946 23/5/16
	endif;
	
	return returnStr;
	
epilog
	
end;
</source>
        <Parameter name="_requiresInfoType" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getVersionAndPatchLevel" id="5de89a68-fb23-4df2-b95e-2e3f718870b8">
        <source>getVersionAndPatchLevel() : String;
// ---------------------------------------------------------------------------
// Created:     11 November 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 08 Sep 2009	cnwkpd1		PAR #20144 - Change format to n.n.n.nnn for use in
//							app.appVersion
// ---------------------------------------------------------------------------

vars
	patch,
	returnVal				: String;
	
begin
	returnVal := self.versionString;
	patch := self.patchLevel.trimBlanks();
	if patch &lt;&gt; null then
		returnVal := returnVal &amp; '.' &amp; patch;
	endif;
	
	return returnVal;
	

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getVersionAndPatchLevelDisplay" id="bb0fce18-6cdb-469f-b514-39785aca1c2a">
        <source>getVersionAndPatchLevelDisplay() : String;
// ---------------------------------------------------------------------------
// Created:     26 October 2021 by navmd1
//
// Purpose:     Hides the last digit of a monthly release so we can use it for silent supersedes/.net patches
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	patch,
	returnVal				: String;
	patchLength				: Integer;
	
begin
	returnVal := self.versionString;
	patch := self.patchLevel.trimBlanks();
	if patch &lt;&gt; null then
		patchLength := patch.length;
		if patchLength &gt;= 3 then
			patch := patch[1:patchLength-1];
		endif;
		returnVal := returnVal &amp; '.' &amp; patch;
	endif;
	
	return returnVal;
	

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getVersionString" id="83f8f1d5-5bfa-4b44-8166-c88f424e8ff3">
        <source>getVersionString() : String;
//
// this returns version number a 3 chars eg 772
//
vars
	str : String;
	pos : Integer;
begin
	//str := self.versionString.removeString('.').Integer.String[1:3];
	
	// 29/04/2021 navmd1 JADE 2020/JMT 20.0.21 changes
	
	// Return the first 3 segments instead.
	// ie, 8.6.2.120 -&gt; 862
	// and, 20.0.21.010 -&gt; 20021
	
	pos := 1;
	str := str &amp; self.versionString.scanUntil(".", pos);	// Segment 1
	pos := pos + 1;
	str := str &amp; self.versionString.scanUntil(".", pos);	// Segment 2
	pos := pos + 1;
	str := str &amp; self.versionString.scanUntil(".", pos);	// Segment 3
	
	return str;
end;
</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getVessel" id="e2307309-14f6-457b-aac4-7ce66226c081">
        <source>getVessel(_vesselName : String; _llyodsNumber : String; _callSign : String; _oper : CM_Operator  ):CM_Vessel;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 April 2018	jlgndl1	Initial creation	TFS 38135

*/

vars

	vessel : CM_Vessel;
	foreignCode : String;
	matchFound : Boolean;
	xlatedVessCode : String;

begin

	vessel := self.getVesselByName( _vesselName );
	if vessel &lt;&gt; null then
		return vessel;
	endif;
	
	if _oper &lt;&gt; null then
		foreignCode := _oper.getXlationForeignCode( _vesselName, XLATION_TYPE_VESSEL_BYOP, matchFound );
		if not matchFound then
			foreignCode := _oper.getXlationForeignCode( _vesselName, XLATION_TYPE_VESSEL, matchFound );
		endif;
	else
		foreignCode := self.getXlationForeignCode( _vesselName, XLATION_TYPE_VESSEL, matchFound );
	endif;
	
	if matchFound then 
		vessel := self.getVesselByName( foreignCode );
	endif;
	
	if vessel &lt;&gt; null then
		return vessel;
	endif;
	//epr TFS 42606 17/12/18
	if _callSign &lt;&gt; null and _callSign.trimBlanks.Integer &lt;&gt; 0 then
		vessel := self.getVesselByCallSign(_callSign,false );
	endif;
	
	if vessel &lt;&gt; null then
		return vessel;
	endif;
	
	//epr TFS 42606 17/12/18
	if _llyodsNumber &lt;&gt; null and _llyodsNumber.trimBlanks.Integer &lt;&gt; 0  then
		vessel := self.getVesselByLloydsNumber( _llyodsNumber,false );
	endif;
	
	
	
	return vessel;
epilog

end;</source>
        <Parameter name="_vesselName" type="String"/>
        <Parameter name="_llyodsNumber" type="String"/>
        <Parameter name="_callSign" type="String"/>
        <Parameter name="_oper" type="CM_Operator"/>
        <ReturnType type="CM_Vessel"/>
    </JadeMethod>
    <JadeMethod name="getVesselByCallSign" id="3d687a54-faa3-4eb6-8c97-2f7057f5511f">
        <source>getVesselByCallSign( _callSign : String; _canCreateVoyages : Boolean ) : CM_Vessel;

/*
Purpose:		Attempt to find the matching vessel for the CallSign supplied.
				if the canCreateVoyages parameter is true then this is also checked.

Date				Who		Reason
11 November 2010	cnwrl1	Initial creation as part of PAR 26099 - Performance enhancement of vessel access.
*/
	
vars
	vessel		: CM_Vessel;
	iter1		: Iterator;
	
begin
	if _callSign = null then
		return null;
	endif;
	
	iter1		:= self.allVesselsByCallSign.createIterator;
	self.allVesselsByCallSign.startKeyGeq( _callSign, iter1 );
	
	while iter1.next( vessel ) do : vessel_loop
		if vessel.callSign &gt; _callSign then
			break vessel_loop;
		endif;
		
		if vessel.callSign &lt;&gt; _callSign then
			// should never happen?
			continue vessel_loop;
		endif;
		
		if _canCreateVoyages and not vessel.canCreateVoyages then
			continue vessel_loop;
		endif;
		
		return vessel;
	endwhile vessel_loop;
	
	return null;
	
epilog
	delete iter1;
	
end;
</source>
        <Parameter name="_callSign" type="String"/>
        <Parameter name="_canCreateVoyages" type="Boolean"/>
        <ReturnType type="CM_Vessel"/>
    </JadeMethod>
    <JadeMethod name="getVesselByLloydsNumber" id="cb2a5c20-3a2f-4288-89ad-515544e6d734">
        <source>getVesselByLloydsNumber( _lloydsNumber : String; _canCreateVoyages : Boolean ) : CM_Vessel;

/*
Purpose:		Attempt to find the matching vessel for the LloydsNumber supplied.
				if the canCreateVoyages parameter is true then this is also checked.

Date				Who		Reason
11 November 2010	cnwrl1	Initial creation as part of PAR 26099 - Performance enhancement of vessel access.
*/
	
vars
	vessel		: CM_Vessel;
	iter1		: Iterator;
	
begin
	if _lloydsNumber = null then
		return null;
	endif;
	
	iter1	:= self.allVesselsByLloydsNumber.createIterator;
	self.allVesselsByLloydsNumber.startKeyGeq( _lloydsNumber, iter1 );
	
	while iter1.next( vessel ) do : vessel_loop
		if vessel.lloydsNumber &gt; _lloydsNumber then
			break vessel_loop;
		endif;
		
		if vessel.lloydsNumber &lt;&gt; _lloydsNumber then
			// should never happen?
			continue vessel_loop;
		endif;
		
		if _canCreateVoyages and not vessel.canCreateVoyages then
			continue vessel_loop;
		endif;
		
		return vessel;
	endwhile vessel_loop;
	
	return null;
	
epilog
	delete iter1;
	
end;
</source>
        <Parameter name="_lloydsNumber" type="String"/>
        <Parameter name="_canCreateVoyages" type="Boolean"/>
        <ReturnType type="CM_Vessel"/>
    </JadeMethod>
    <JadeMethod name="getVesselByName" id="44f34f1b-967a-4551-8cea-0b6dec837bec">
        <source>getVesselByName( _name : String ) : CM_Vessel;
//----------------------------------------------------------------
//	Created:	18 November 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	vName		: String;
	vesselName	: String;
	vesselObj	: CM_Vessel;
	failedDAC	: CM_DataAccessController;
	iter1		: Iterator;
	
begin
	vName	:=	_name.trimBlanks().toUpper(); //cmwrs1 Mar 2007 par 13723
	
	// cnwrl1 09/11/2010 PAR 26099 - start of replacement coding
	iter1	:= self.allVesselsByName.createIterator;
	self.allVesselsByName.startKeyGeq( vName, iter1 );
	
	while iter1.next( vesselObj ) do : vessel_loop
		vesselName	:= vesselObj.name.trimBlanks().toUpper();
		if vesselName &gt; vName then
			break vessel_loop;
		endif;
		if vesselName = vName then
			if vesselObj.canUserAccessSelf(null, failedDAC, app.myPassport) then	// For Comalco.
				return vesselObj;
			endif;
		endif;
	endwhile vessel_loop;
	// cnwrl1 09/11/2010 PAR 26099 - end of coding
	
	return null;
	
epilog
	delete iter1;
	
end;
</source>
        <Parameter name="_name" type="String"/>
        <ReturnType type="CM_Vessel"/>
    </JadeMethod>
    <JadeMethod name="getVoyJobTransferTypeByCode" id="5f8c7eb1-2784-434e-b3a5-205b0d29b1e7">
        <source>getVoyJobTransferTypeByCode(_code : String ) : CM_VoyageJobTransferType;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 July 2018	jlger1	Initial creation

*/

vars
	voyJobType : CM_VoyageJobTransferType;
begin
	if _code = null then
		return null;
	endif;
	
	foreach voyJobType in self.allVoyageJobTransferTypes discreteLock do
		if voyJobType.code = _code then
			return voyJobType;
		endif;
	endforeach;
	return null;
epilog

end;</source>
        <Parameter name="_code" type="String"/>
        <ReturnType type="CM_VoyageJobTransferType"/>
    </JadeMethod>
    <JadeMethod name="getVoyageBusUnit" id="f5017274-dcc1-4dd8-b78c-28cfa9914e72">
        <source>getVoyageBusUnit( _term : CM_Terminal; _voyage : CM_Voyage):CM_Bank;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 March 2018	jlgndl1	Initial creation	TFS 37562

*/

vars

	term : CM_Terminal;
	voyage : CM_Voyage;
	bank : CM_Bank;

begin

	term := _term;
	voyage := _voyage;
	bank := app.myHookAgent.runHookLinkPublic(	HookType_VoyageBusUnit,
												term,
												term,
												term,
												voyage
												).CM_Bank;
												
	return bank;

epilog

end;</source>
