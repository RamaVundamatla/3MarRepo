    <JadeMethod name="doCoparn_mtrel_gensetrequired" id="3db37ef5-0eea-4054-961c-5312396ee206">
        <source>doCoparn_mtrel_gensetrequired(_sender, _voyageCode, _vesselName, _consignorCode, _releaseNo :String; _mt :Character; _operator :CM_Operator; _ediPartyRules :CM_EDIPartyCoparnRules)protected;
/*
Date		        Who		Reason
01 December 2011	cnwcs5	Initial creation - CCMS POL 2122 / par 28696 - Empty Releases via COPARN
9 January 2013      cnwgb1  CCMS POL 2216/ par 30902 Heavy Rated Releases      
// 31 Oct 2017	jlgrs1	TFS 5705 - SNO - EDIDataBooking Prenote release Req
*/
constants
	ADDITIONAL_TEXT	= "//GENSET REQUIRED";
	ISOTYPE 		= '45R1';
	QUANTITY		= 4;
vars
	text	:String;
	ediFile	:CM_EDIFile;
	ediData	:CM_EDIData;
	ediTI	:CM_EDIRequestHeaderTI;
	ediItemTI : CM_EDIRequestDetailTI;
	ediRelReq : CM_EDIReleaseRequestTI;
	release	:CM_BulkRelease;
	item	:CM_ReserveSelection;
	isoType	:CM_ISOType;
	tempStr : String;
	ediItem : CM_EDITrackedItem;
begin
	// ---------------------------------------
	// delete the release if it already exists
	// ---------------------------------------
	self.deleteReleaseRequest (_releaseNo);
	
	// ---------------------------------------
	// get edi file to load
	// ---------------------------------------
	text := self.zCoparn_mtrel_gensetrequired (_sender, _voyageCode, _vesselName, _consignorCode, _releaseNo, ADDITIONAL_TEXT, ISOTYPE, QUANTITY.String, _mt);

	// ---------------------------------------
	// load edi file to create EDI tracked items
	// ---------------------------------------
	ediFile := self.ediLoadFileName(text, EDIFileType_Unknown, "COPARN", "COPARN"&amp;method.name);
	
	self.assertNotNull(ediFile);
	
	// ---------------------------------------
	// find the release request ediData
	// ---------------------------------------
	if ediFile.ediData.isKindOf(CM_EDIDataGateDoc) or
	   ediFile.ediData.isKindOf(CM_EDIDataReleaseRequest) then
		ediData := ediFile.ediData;
	else
		ediData := ediFile.allEDIData.first;
	endif;
	
	self.assertNotNullMsg (ediData, 'No edi data for release requests');
	
	// ---------------------------------------
	// find the edi tracked item
	// ---------------------------------------
//	ediTI := ediData.allEDITrackedItems.first.CM_EDIRequestHeaderTI;
	if ediData.isKindOf(CM_EDIDataGateDoc) then
		foreach ediItem in ediData.allEDITrackedItems do
			if  ediItem.isKindOf(CM_EDIRequestHeaderTI) then
				ediTI := ediItem.CM_EDIRequestHeaderTI;
				break;
			endif;
		endforeach;
		self.assertNotNullMsg(ediTI, 'EDI tracked items not created');
		ediItemTI := self.getMatchingEDIItemTI(ediTI);
		// ---------------------------------------
		// check values on EDI TI
		// ---------------------------------------
		self.doCheckEDITiRequestMulti(ediTI, ediItemTI, "A", _releaseNo, _voyageCode, _vesselName,  _operator.code,_consignorCode, null, ISOTYPE, ADDITIONAL_TEXT,  null, null, QUANTITY, _ediPartyRules, null, null, false, true, true, false, false, true);
	endif;
	if ediData.isKindOf(CM_EDIDataReleaseRequest) then
		foreach ediItem in ediData.allEDITrackedItems do
			if  ediItem.isKindOf(CM_EDIReleaseRequestTI) then
				ediRelReq := ediItem.CM_EDIReleaseRequestTI;
				break;
			endif;
		endforeach;
		self.assertNotNullMsg(ediRelReq, 'EDI tracked items not created');
		// ---------------------------------------
		// check values on EDI TI
		// ---------------------------------------
		self.doCheckEDITIReleaseRequest(ediRelReq, "A", _releaseNo, _voyageCode, _vesselName,  _operator.code,_consignorCode, null, ISOTYPE, ADDITIONAL_TEXT,  null, null, QUANTITY, _ediPartyRules, null, null, false, true, true, false, false, true);
	endif;
	
	// ---------------------------------------
	// do verify (all edi data)  
	// ---------------------------------------
	self.ediVerify(ediFile);
	tempStr	:= 'Verify failed' &amp; CrLf &amp; app.myPassport.getErrorsAsString;
	self.assertEqualMsg(ediData.status, CM_EDIFile.EDI_STATUS_VERIFIED, tempStr);
	
	// ---------------------------------------
	// load to DB
	// ---------------------------------------
	self.ediDBLoad(ediFile);
	tempStr	:= 'DBLoad failed' &amp; CrLf &amp; app.myPassport.getErrorsAsString;
	self.assertEqualMsg(ediData.status, CM_EDIFile.EDI_STATUS_DBLOADED, tempStr);
	
	// ---------------------------------------
	// find the release
	// ---------------------------------------
	release := self.getReleaseRequest (_releaseNo);
	
	self.assertNotNull (release);
	
	// ---------------------------------------
	// do standard checks
	// ---------------------------------------
	self.doCheckPartyRules_AddRelease (release, _ediPartyRules, false, true, true);
	
	self.assertTrueMsg (release.releaseByType, 'Release by type is not set');
	self.assertEqualMsg (release.code, _releaseNo, 'Release number is incorrect');
	self.assertEqualMsg (release.myVoyage.code, _voyageCode, 'Voyage codeis incorrect');
	// self.assertEqualMsg (release.myOperator, ???, 'Operator is incorrect');// operator ???
	self.assertEqualMsg (release.consignorCode, _consignorCode, 'Consignor is incorrect');

	// we expect the release cargo remarks to include the addition text
	item := release.allReserveDetails.first.CM_ReserveSelection;
	
	self.assertNotNull (item);
	if ediTI &lt;&gt; null then
		self.assertTrueMsg (ediTI.remarks.pos (ADDITIONAL_TEXT, 1) &gt; 0, 'Additionl text from FTX not stored in cargo remarks');
	endif;
	if ediRelReq &lt;&gt; null then
		self.assertTrueMsg (ediRelReq.remarks.pos (ADDITIONAL_TEXT, 1) &gt; 0, 'Additionl text from FTX not stored in cargo remarks');
	endif;
	self.assertNotNullMsg (item.myISOType, 'ISO Type not set');
	self.assertEqualMsg (item.myISOType.code, ISOTYPE, 'ISO type is incorrect');
	
	// Availability grade - defaults for this file
	
	// total requested
	self.assertEqualMsg (item.totalRequested, QUANTITY, 'Total requested not set');
	
	// we expect theRE TO BE A GENERATOR RELEASE
	item := release.allReserveDetails.last.CM_ReserveSelection;
	
	self.assertNotNull (item);

	self.assertNotNullMsg (item.myISOType, 'Generator ISO Type not set');
	self.assertEqualMsg (item.myISOType.code, _ediPartyRules.myISOTypeForEQD_plus_RD.code, 'Generator ISO type is incorrect');
	
	// Availability grade - defaults for this file
	
	// total requested
	self.assertEqualMsg (item.totalRequested, 1, 'Generator total requested not set');
	
	// check ediFile collection has been updated
	self.assertTrueMsg (release.allEDIFiles.includes (ediFile), 'Update the edi files collection !!!');
	self.assertTrueMsg (release.allEDIFiles.size = 1, _releaseNo &amp; ' EDI the edi files collection should have 1 entry!!!');	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_sender" type="String"/>
        <Parameter name="_voyageCode" type="String"/>
        <Parameter name="_vesselName" type="String"/>
        <Parameter name="_consignorCode" type="String"/>
        <Parameter name="_releaseNo" type="String"/>
        <Parameter name="_mt" type="Character"/>
        <Parameter name="_operator" type="CM_Operator"/>
        <Parameter name="_ediPartyRules" type="CM_EDIPartyCoparnRules"/>
    </JadeMethod>
    <JadeMethod name="doCoparn_mtrel_mtgrade" id="996e9d66-cd1d-4ea1-a216-7fcc21c9fc5f">
        <source>doCoparn_mtrel_mtgrade(_sender, _voyageCode, _vesselName, _consignorCode, _consigneeCode, _releaseNo:String; 
						_reqTS, _estReqTS :TimeStamp; _mt :Character; _operator :CM_Operator; _ediPartyRules :CM_EDIPartyCoparnRules)protected;
/*
Date		        Who		Reason
01 December 2011	cnwcs5	Initial creation - CCMS POL 2122 / par 28696 - Empty Releases via COPARN
9 January 2013      cnwgb1  CCMS POL 2216/ par 30902 Heavy Rated Releases      
//13 May 2016	cnwrs1	TFS 1987 CargoSubType EDI Xlation
// 31 Oct 2017	jlgrs1	TFS 5705 - SNO - EDIDataBooking Prenote release Req
*/
constants
	MTGRADE1		= 'GENERAL';
	MTGRADE2		= 'CHILLED';
	ISOTYPE 		= '22G1';
	QUANTITY		= 10;
	TEXT			= 'CHILLED/PROBESX2/JORDAN';
	TEMP			= -01.8;
vars
	text	:String;
	ediFile	:CM_EDIFile;
	ediData	:CM_EDIData;
	ediTI	:CM_EDIRequestHeaderTI;
	ediItemTI : CM_EDIRequestDetailTI;
	ediRelReq : CM_EDIReleaseRequestTI;
	release	:CM_BulkRelease;
	item	:CM_ReserveSelection;
	isoType	:CM_ISOType;
	tempStr :String;
	tokens 	:StringArray;
	foundMatch	:Boolean;
	mtGrade	:CM_MTGrade;
	ediItem : CM_EDITrackedItem;
begin
	// DELETE AND RE-ADD XLATIONS
	self.deleteEDIInwardXlation (MTGRADE1, XLATION_TYPE_MTGRADE_BYOP, _operator, null);
	self.deleteEDIInwardXlation (MTGRADE2, XLATION_TYPE_MTGRADE_BYOP, _operator, null);
	
	mtGrade := app.myRoot.allAvailabilityGrades[98];
	
	if mtGrade = null then
		mtGrade := self.createAvailabilityGradeAndDesc (98, 'Grade 98 - General Unit Test');  
	endif;
	
	mtGrade := app.myRoot.allAvailabilityGrades[19];
	
	if mtGrade = null then
		mtGrade := self.createAvailabilityGradeAndDesc (19, 'Grade 19 - Alliance Chilled -2.0');  
	endif;
	
	mtGrade := app.myRoot.allAvailabilityGrades[17];
	
	if mtGrade = null then
		mtGrade := self.createAvailabilityGradeAndDesc (17, 'Grade 17 - TS Chilled -1.7');  
	endif;
	
	self.createEDIXlation (MTGRADE1, '98', XLATION_TYPE_MTGRADE_BYOP, false, _operator, null, NULL_TEMPERATURE, NULL_TEMPERATURE, null);
	self.createEDIXlation (MTGRADE2, '19', XLATION_TYPE_MTGRADE_BYOP, false, _operator, null, -2, -2, null);
	self.createEDIXlation (MTGRADE2, '17', XLATION_TYPE_MTGRADE_BYOP, false, _operator, null, -1.7, -1.7, null);
	self.createEDIXlation (MTGRADE2, '18', XLATION_TYPE_MTGRADE_BYOP, false, _operator, null, -1.8, -1.8, null);
	self.createEDIXlation (MTGRADE2, '42', XLATION_TYPE_MTGRADE_BYOP, false, _operator, null, -1.8, -1.8, 'JORDAN');
	
	// ---------------------------------------
	// delete the release if it already exists
	// ---------------------------------------
	self.deleteReleaseRequest (_releaseNo);
	
	// ---------------------------------------
	// get edi file to load
	// ---------------------------------------
	text := self.zCoparn_mtrel_mtgrade (_sender, _voyageCode, _vesselName, _consignorCode, _consigneeCode, _releaseNo, MTGRADE1, null, ISOTYPE, QUANTITY.String, null, _estReqTS, _mt, 5);

	// ---------------------------------------
	// load edi file to create EDI tracked items
	// ---------------------------------------
	ediFile := self.ediLoadFileName(text, EDIFileType_Unknown, "COPARN", "COPARN1"&amp;method.name);
	
	self.assertNotNull(ediFile);
	
	// ---------------------------------------
	// find the release request ediData
	// ---------------------------------------
	if ediFile.ediData.isKindOf(CM_EDIDataGateDoc) or
	   ediFile.ediData.isKindOf(CM_EDIDataReleaseRequest) then
		ediData := ediFile.ediData;
	else
		ediData := ediFile.allEDIData.first;
	endif;
	
	self.assertNotNullMsg (ediData, 'No edi data for release requests');
	
	// ---------------------------------------
	// find the edi tracked item
	// ---------------------------------------
//	ediTI := ediData.allEDITrackedItems.first.CM_EDIRequestHeaderTI;
	if ediData.isKindOf(CM_EDIDataGateDoc) then
		foreach ediItem in ediData.allEDITrackedItems do
			if  ediItem.isKindOf(CM_EDIRequestHeaderTI) then
				ediTI := ediItem.CM_EDIRequestHeaderTI;
				break;
			endif;
		endforeach;
		self.assertNotNullMsg(ediTI, 'EDI tracked items not created');
		ediItemTI := self.getMatchingEDIItemTI(ediTI);
		// ---------------------------------------
		// check values on EDI TI
		// ---------------------------------------
		self.doCheckEDITiRequestMulti(ediTI, ediItemTI, "A", _releaseNo, _voyageCode, _vesselName,  _operator.code,_consignorCode, _consigneeCode, ISOTYPE, null,  null, null, QUANTITY, _ediPartyRules, null, _estReqTS, false, false, false, true, false, true);
		
	endif;
	if ediData.isKindOf(CM_EDIDataReleaseRequest) then
		foreach ediItem in ediData.allEDITrackedItems do
			if  ediItem.isKindOf(CM_EDIReleaseRequestTI) then
				ediRelReq := ediItem.CM_EDIReleaseRequestTI;
				break;
			endif;
		endforeach;
		self.assertNotNullMsg(ediRelReq, 'EDI tracked items not created');
		// ---------------------------------------
		// check values on EDI TI
		// ---------------------------------------
		self.doCheckEDITIReleaseRequest(ediRelReq, "A", _releaseNo, _voyageCode, _vesselName,  _operator.code,_consignorCode, _consigneeCode, ISOTYPE, null,  null, null, QUANTITY, _ediPartyRules, null, _estReqTS, false, false, false, true, false, true);
		
	endif;

	// destination - LOC+7+AUSYD:139:6'
	if ediTI &lt;&gt; null then
		//11 Jan 2018	NDL	36400 - Temp of 5 passed in, but should be lost because isotype is not a reefer so
		self.assertTrueMsg(ediTI.remarks.pos ("5", 1) &lt; 1, _releaseNo &amp; ' Temp incorrectly included in remarks for non reefer ISO');
		self.assertEqualMsg(ediTI.destinationPort, "AUSYD", "Destination shoudl be AUMEL");
	endif;
	if ediRelReq &lt;&gt; null then
		//11 Jan 2018	NDL	36400 - Temp of 5 passed in, but should be lost because isotype is not a reefer so
		self.assertTrueMsg(ediRelReq.remarks.pos ("5", 1) &lt; 1, _releaseNo &amp; ' Temp incorrectly included in remarks for non reefer ISO');
		self.assertEqualMsg(ediRelReq.destinationPort, "AUSYD", "Destination shoudl be AUMEL");
	endif;
	// Availability grade - should equal translation
	if ediItemTI &lt;&gt; null then
		tokens := ediItemTI.availabilityGrades.getTokens;
	endif;
	if ediRelReq &lt;&gt; null then
		tokens := ediRelReq.availabilityGrades.getTokens;
	endif;
	self.assertTrueMsg (tokens.includes ('98'), _releaseNo &amp; ' Incorrect availability grade');

	delete tokens;
	// ---------------------------------------
	// do verify (all edi data)  
	// ---------------------------------------
	self.ediVerify(ediFile);
	tempStr	:= 'Verify failed' &amp; CrLf &amp; app.myPassport.getErrorsAsString;
	self.assertEqualMsg(ediData.status, CM_EDIFile.EDI_STATUS_VERIFIED, tempStr);
	
	// ---------------------------------------
	// load to DB
	// ---------------------------------------
	self.ediDBLoad(ediFile);
	tempStr	:= 'DBLoad failed' &amp; CrLf &amp; app.myPassport.getErrorsAsString;
	self.assertEqualMsg(ediData.status, CM_EDIFile.EDI_STATUS_DBLOADED, tempStr);
	
	// ---------------------------------------
	// find the release
	// ---------------------------------------
	release := self.getReleaseRequest (_releaseNo);
	
	self.assertNotNull (release);
	
	// ---------------------------------------
	// do standard checks
	// ---------------------------------------
	self.doCheckPartyRules_AddRelease (release, _ediPartyRules, false, false, false);
	
	self.assertTrueMsg (release.releaseByType, 'Release by type is not set');
	self.assertEqualMsg (release.code, _releaseNo, 'Release number is incorrect');
	self.assertEqualMsg (release.myVoyage.code, _voyageCode, 'Voyage code is incorrect');
	self.assertEqualMsg (release.myOperator, _operator, 'Operator is incorrect');
	self.assertEqualMsg (release.consignorCode, _consignorCode, 'Consignor is incorrect');
	self.assertEqualMsg (release.consigneeCode, _consigneeCode, 'Consignee is incorrect');

	// we expect the release cargo remarks to include the addition text
	item := release.allReserveDetails.first.CM_ReserveSelection;

	self.assertNotNullMsg (item.myISOType, 'ISO Type not set');
	self.assertEqualMsg (item.myISOType.code, ISOTYPE, 'ISO type is incorrect');
	
	// Availability grade - should equal translation
	self.assertEqualMsg (item.allAvailabilityGrades.first, 98, _releaseNo &amp; ' Incorrect availability grade');
	// total requested
	self.assertEqualMsg (item.totalRequested, QUANTITY, 'Total requested not set');

	// check ediFile collection has been updated
	self.assertTrueMsg (release.allEDIFiles.includes (ediFile), 'Update the edi files collection !!!');
	self.assertTrueMsg (release.allEDIFiles.size = 1, _releaseNo &amp; ' EDI the edi files collection should have 1 entry!!!');	
	
	// ---------------------------------------
	// get edi file to load
	// ---------------------------------------
	text := self.zCoparn_mtrel_mtgrade (_sender, _voyageCode, _vesselName, _consignorCode, _consigneeCode, _releaseNo, MTGRADE2, null, ISOTYPE, QUANTITY.String, null, _estReqTS, _mt, -1.8);

	// ---------------------------------------
	// load edi file to create EDI tracked items
	// ---------------------------------------
	ediFile := self.ediLoadFileName(text, EDIFileType_Unknown, "COPARN", "COPARN2"&amp;method.name);
	
	self.assertNotNull(ediFile);
	
	// ---------------------------------------
	// find the release request ediData
	// ---------------------------------------
	if ediFile.ediData.isKindOf(CM_EDIDataGateDoc) or
	   ediFile.ediData.isKindOf(CM_EDIDataReleaseRequest) then
		ediData := ediFile.ediData;
	else
		ediData := ediFile.allEDIData.first;
	endif;
	
	self.assertNotNullMsg (ediData, 'No edi data for release requests');
	
	// ---------------------------------------
	// find the edi tracked item
	// ---------------------------------------
//	ediTI := ediData.allEDITrackedItems.first.CM_EDIRequestHeaderTI;
	if ediData.isKindOf(CM_EDIDataGateDoc) then
		foreach ediItem in ediData.allEDITrackedItems do
			if  ediItem.isKindOf(CM_EDIRequestHeaderTI) then
				ediTI := ediItem.CM_EDIRequestHeaderTI;
				break;
			endif;
		endforeach;
		self.assertNotNullMsg(ediTI, 'EDI tracked items not created');
		ediItemTI := self.getMatchingEDIItemTI(ediTI);
		// ---------------------------------------
		// check values on EDI TI
		// ---------------------------------------
		self.doCheckEDITiRequestMulti(ediTI, ediItemTI, "A", _releaseNo, _voyageCode, _vesselName,  _operator.code,_consignorCode, _consigneeCode, ISOTYPE, null,  null, null, QUANTITY, _ediPartyRules, null, _estReqTS, false, false, false, true, false, true);
	endif;
	if ediData.isKindOf(CM_EDIDataReleaseRequest) then
		foreach ediItem in ediData.allEDITrackedItems do
			if  ediItem.isKindOf(CM_EDIReleaseRequestTI) then
				ediRelReq := ediItem.CM_EDIReleaseRequestTI;
				break;
			endif;
		endforeach;
		self.assertNotNullMsg(ediRelReq, 'EDI tracked items not created');
		// ---------------------------------------
		// check values on EDI TI
		// ---------------------------------------
		self.doCheckEDITIReleaseRequest(ediRelReq, "A", _releaseNo, _voyageCode, _vesselName,  _operator.code,_consignorCode, _consigneeCode, ISOTYPE, null,  null, null, QUANTITY, _ediPartyRules, null, _estReqTS, false, false, false, true, false, true);
	endif;
	
	// destination - LOC+7+AUSYD:139:6'
	if ediTI &lt;&gt; null then
		self.assertEqualMsg (ediTI.destinationPort, "AUSYD", "Destination shoudl be AUMEL");
	endif;
	// Availability grade - should equal translation
	if ediItemTI &lt;&gt; null then
		tokens := ediItemTI.availabilityGrades.getTokens; 
	endif;
	if ediRelReq &lt;&gt; null then
		self.assertEqualMsg (ediRelReq.destinationPort, "AUSYD", "Destination shoudl be AUMEL");
		tokens := ediRelReq.availabilityGrades.getTokens; 
	endif;
	self.assertTrueMsg (tokens.includes ('18'), _releaseNo &amp; ' Incorrect availability grade');

	delete tokens;
	
		// ---------------------------------------
	// get edi file to load
	// ---------------------------------------
	text := self.zCoparn_mtrel_mtgrade (_sender, _voyageCode, _vesselName, _consignorCode, _consigneeCode, _releaseNo, MTGRADE2, 'JORDAN', ISOTYPE, QUANTITY.String, null, _estReqTS, _mt, -1.8);

	// ---------------------------------------
	// load edi file to create EDI tracked items
	// ---------------------------------------
	ediFile := self.ediLoadFileName(text, EDIFileType_Unknown, "COPARN", "COPARN3"&amp;method.name);
	
	self.assertNotNull(ediFile);
	
	// ---------------------------------------
	// find the release request ediData
	// ---------------------------------------
	if ediFile.ediData.isKindOf(CM_EDIDataGateDoc) or
	   ediFile.ediData.isKindOf(CM_EDIDataReleaseRequest) then
		ediData := ediFile.ediData;
	else
		ediData := ediFile.allEDIData.first;
	endif;
	
	self.assertNotNullMsg (ediData, 'No edi data for release requests');
	
	// ---------------------------------------
	// find the edi tracked item
	// ---------------------------------------
//	ediTI := ediData.allEDITrackedItems.first.CM_EDIRequestHeaderTI;
	if ediData.isKindOf(CM_EDIDataGateDoc) then
		foreach ediItem in ediData.allEDITrackedItems do
			if  ediItem.isKindOf(CM_EDIRequestHeaderTI) then
				ediTI := ediItem.CM_EDIRequestHeaderTI;
				break;
			endif;
		endforeach;
		self.assertNotNullMsg(ediTI, 'EDI tracked items not created');
		ediItemTI := self.getMatchingEDIItemTI(ediTI);
		// ---------------------------------------
		// check values on EDI TI
		// ---------------------------------------
		self.doCheckEDITiRequestMulti(ediTI, ediItemTI, "A", _releaseNo, _voyageCode, _vesselName,  _operator.code,_consignorCode, _consigneeCode, ISOTYPE, 'JORDAN',  null, null, QUANTITY, _ediPartyRules, null, _estReqTS, false, false, false, true, false, true);
	endif;
	if ediData.isKindOf(CM_EDIDataReleaseRequest) then
		foreach ediItem in ediData.allEDITrackedItems do
			if  ediItem.isKindOf(CM_EDIReleaseRequestTI) then
				ediRelReq := ediItem.CM_EDIReleaseRequestTI;
				break;
			endif;
		endforeach;
		self.assertNotNullMsg(ediRelReq, 'EDI tracked items not created');
		// ---------------------------------------
		// check values on EDI TI
		// ---------------------------------------
		self.doCheckEDITIReleaseRequest(ediRelReq, "A", _releaseNo, _voyageCode, _vesselName,  _operator.code,_consignorCode, _consigneeCode, ISOTYPE, 'JORDAN',  null, null, QUANTITY, _ediPartyRules, null, _estReqTS, false, false, false, true, false, true);
	endif;
	
	// destination - LOC+7+AUSYD:139:6'
	if ediTI &lt;&gt; null then
		self.assertEqualMsg (ediTI.destinationPort, "AUSYD", "Destination shoudl be AUMEL");
	endif;
	// Availability grade - should equal translation
	if ediItemTI &lt;&gt; null then
		tokens := ediItemTI.availabilityGrades.getTokens; 
	endif;
	if ediRelReq &lt;&gt; null then
		self.assertEqualMsg (ediRelReq.destinationPort, "AUSYD", "Destination shoudl be AUMEL");
		tokens := ediRelReq.availabilityGrades.getTokens; 
	endif;
	self.assertTrueMsg (tokens.includes ('42'), _releaseNo &amp; ' Incorrect availability grade');

	delete tokens;

epilog
	delete tokens;
end;</source>
        <access>protected</access>
        <Parameter name="_sender" type="String"/>
        <Parameter name="_voyageCode" type="String"/>
        <Parameter name="_vesselName" type="String"/>
        <Parameter name="_consignorCode" type="String"/>
        <Parameter name="_consigneeCode" type="String"/>
        <Parameter name="_releaseNo" type="String"/>
        <Parameter name="_reqTS" type="TimeStamp"/>
        <Parameter name="_estReqTS" type="TimeStamp"/>
        <Parameter name="_mt" type="Character"/>
        <Parameter name="_operator" type="CM_Operator"/>
        <Parameter name="_ediPartyRules" type="CM_EDIPartyCoparnRules"/>
    </JadeMethod>
    <JadeMethod name="doCoparn_mtrel_multi" id="a888d810-a833-4dc4-a5a0-8b44aae94614">
        <source>doCoparn_mtrel_multi(_sender, _voyageCode, _vesselName, _consignorCode :String; _reqTS, _estReqTS :TimeStamp;
						_operator :CM_Operator; _ediPartyRules :CM_EDIPartyCoparnRules)protected;
/*
Date		        Who		Reason
01 December 2011	cnwcs5	Initial creation - CCMS POL 2122 / par 28696 - Empty Releases via COPARN
9 January 2013      cnwgb1  CCMS POL 2216/ par 30902 Heavy Rated Releases      
// 18 Oct 2017	jlgrs1	TFS 5705 - SNO - EDIDataBooking Prenote release Req
// 01 Jun 2018	jlgrs1	TFS 38992 JMT Booking and ReleaseReq for GateDoc
*/
constants
	RELEASE1 = "GB100001"; ISOTYPEREL1A = '22G1'; ISOTYPEREL1B = '42G1';
	RELEASE2 = "GB100003"; ISOTYPEREL2A = '2201'; ISOTYPEREL2B = '4201';
	BOOKING1 = "GB100002"; ISOTYPEBK1A = '22R1'; ISOTYPEBK1B = '45R1';
	BOOKING2 = "GB100004"; ISOTYPEBK2A = '2201'; ISOTYPEBK2B = '4501';
vars
	text	:String;
	ediFile	:CM_EDIFile;
	ediDataRR, ediDataBooking	:CM_EDIData;
	ediTI	:CM_EDITrackedItem;
	ediItemTI : CM_EDIRequestDetailTI;
	ediRelReq : CM_EDIReleaseRequestTI;
	release	:CM_BulkRelease;
	booking	:CM_BookingRef;
	item	:CM_ReserveDetail;
	isoType	:CM_ISOType;
	tempStr : String;
begin
	// ---------------------------------------
	// delete the release if it already exists
	// ---------------------------------------
	self.deleteReleaseRequest (RELEASE1);
	self.deleteBooking (BOOKING1);
	self.deleteReleaseRequest (RELEASE2);
	self.deleteBooking (BOOKING2);
	
	// ---------------------------------------
	// get edi file to load
	// ---------------------------------------
	text := self.zCoparn_mtrel_multi (_sender, _voyageCode, _vesselName, null, _reqTS, _estReqTS);

	// ---------------------------------------
	// load edi file to create EDI tracked items
	// ---------------------------------------
	ediFile := self.ediLoadFileName(text, EDIFileType_Unknown, "COPARN", "COPARN"&amp;method.name);
	
	self.assertNotNull(ediFile);
	
	// ---------------------------------------
	// find the release request ediData
	// ---------------------------------------
	if ediFile.ediData.isKindOf(CM_EDIDataGateDoc) then
		ediDataRR 		:= ediFile.ediData;
		ediDataBooking	:= ediFile.ediData;
	elseif ediFile.ediData.isKindOf(CM_EDIDataReleaseRequest) then
		ediDataRR := ediFile.ediData;
		ediDataBooking	:= ediFile.ediData;
	else
		ediDataRR := ediFile.allEDIData.first;
		ediDataBooking	:= ediFile.allEDIData.first;
	endif;
	
	self.assertNotNullMsg (ediDataRR, 'No edi data for release requests');
	self.assertNotNullMsg (ediDataBooking, 'No edi data for bookings');
	if ediDataRR.isKindOf(CM_EDIDataReleaseRequest) then
		self.assertTrueMsg (ediDataRR.allEDITrackedItems.size = 4, 'EDI tracked items not created for releases - expecting 4');
	elseif ediDataRR.isKindOf(CM_EDIDataGateDoc) then
		self.assertTrueMsg (ediDataRR.allEDITrackedItems.size = 12, 'EDI tracked items not created for releases - expecting 12');
	endif;
	self.assertTrueMsg (ediDataBooking.allEDITrackedItems.size &gt; 0, 'EDI tracked items not created for bookings');
	// ---------------------------------------
	// find the edi tracked items
	// ---------------------------------------
	if ediDataRR.isKindOf(CM_EDIDataReleaseRequest) then
		foreach ediTI in ediDataRR.allEDITrackedItems do
			self.assertTrue (ediTI.isKindOf (CM_EDIReleaseRequestTI));
			// ---------------------------------------
			// check values on EDI TI
			// ---------------------------------------
			if ediTI.CM_EDIReleaseRequestTI.releaseRequestNumber = RELEASE1 then
				if ediTI.CM_EDIReleaseRequestTI.isoType = ISOTYPEREL1A then
					self.doCheckEDITIReleaseRequest (ediTI.CM_EDIReleaseRequestTI, "A", RELEASE1, _voyageCode, _vesselName, _operator.code, _consignorCode, _consignorCode, ISOTYPEREL1A, null,  null, null, 1, _ediPartyRules, _reqTS, _estReqTS, false, true, false, false, false, true);
				else
					self.doCheckEDITIReleaseRequest (ediTI.CM_EDIReleaseRequestTI, "A", RELEASE1, _voyageCode, _vesselName, _operator.code, _consignorCode, _consignorCode, ISOTYPEREL1B, null,  null, null, 1, _ediPartyRules, _reqTS, _estReqTS, false, true, false, false, true, true);
				endif;
	//			self.doCheckEDITrackedItem (ediTI.CM_EDIReleaseRequestTI, "A", RELEASE1, _voyageCode, _vesselName, _operator.code, _consignorCode, null, ISOTYPEREL1A, null,  null, null, 1, _ediPartyRules, _reqTS, _estReqTS, false, true, false, false);
			elseif ediTI.CM_EDIReleaseRequestTI.releaseRequestNumber = RELEASE2 then
				if ediTI.CM_EDIReleaseRequestTI.isoType = ISOTYPEREL2A then
					self.doCheckEDITIReleaseRequest (ediTI.CM_EDIReleaseRequestTI, "A", RELEASE2, _voyageCode, _vesselName, _operator.code, _consignorCode, _consignorCode, ISOTYPEREL2A, "Heavy Rated",  null, null, 1, _ediPartyRules, _reqTS, _estReqTS,  false, true, false, false, true, true);
				else
					self.doCheckEDITIReleaseRequest (ediTI.CM_EDIReleaseRequestTI, "A", RELEASE2, _voyageCode, _vesselName, _operator.code, _consignorCode, _consignorCode, ISOTYPEREL2B, null,  null, null, 1, _ediPartyRules, _reqTS, _estReqTS,  false, true, false, false, true, true);
				endif;
	//			self.doCheckEDITrackedItem (ediTI.CM_EDIReleaseRequestTI, "A", RELEASE2, _voyageCode, _vesselName, _operator.code, _consignorCode, _consignorCode, ISOTYPEREL2A, null,  null, null, 1, _ediPartyRules, _reqTS, _estReqTS,  false, true, false, false);
			endif;
		endforeach;
	elseif ediDataRR.isKindOf(CM_EDIDataGateDoc) then
		foreach ediTI in ediDataRR.allEDITrackedItems do
			if ediTI.isKindOf(CM_EDIRequestHeaderTI) then
				ediItemTI := self.getMatchingEDIItemTI(ediTI.CM_EDIRequestHeaderTI);
			// ---------------------------------------
			// check values on EDI TI
			// ---------------------------------------
			if ediTI.CM_EDIRequestHeaderTI.releaseRequestNumber = RELEASE1 then
				if ediItemTI.isoType = ISOTYPEREL1A then
					self.doCheckEDITiRequestMulti (ediTI.CM_EDIRequestHeaderTI, ediItemTI, "A", RELEASE1, _voyageCode, _vesselName, _operator.code, _consignorCode, _consignorCode, ISOTYPEREL1A, null,  null, null, 1, _ediPartyRules, _reqTS, _estReqTS, false, true, false, false, false, true);
				else
					self.doCheckEDITiRequestMulti (ediTI.CM_EDIRequestHeaderTI, ediItemTI, "A", RELEASE1, _voyageCode, _vesselName, _operator.code, _consignorCode, _consignorCode, ISOTYPEREL1B, null,  null, null, 1, _ediPartyRules, _reqTS, _estReqTS, false, true, false, false, true, true);
				endif;
	//			self.doCheckEDITrackedItem (ediTI.CM_EDIRequestHeaderTI, "A", RELEASE1, _voyageCode, _vesselName, _operator.code, _consignorCode, null, ISOTYPEREL1A, null,  null, null, 1, _ediPartyRules, _reqTS, _estReqTS, false, true, false, false);
			elseif ediTI.CM_EDIRequestHeaderTI.releaseRequestNumber = RELEASE2 then
				if ediItemTI.isoType = ISOTYPEREL2A then
					self.doCheckEDITiRequestMulti (ediTI.CM_EDIRequestHeaderTI, ediItemTI, "A", RELEASE2, _voyageCode, _vesselName, _operator.code, _consignorCode, _consignorCode, ISOTYPEREL2A, "Heavy Rated",  null, null, 1, _ediPartyRules, _reqTS, _estReqTS,  false, true, false, false, true, true);
				else
					self.doCheckEDITiRequestMulti (ediTI.CM_EDIRequestHeaderTI, ediItemTI, "A", RELEASE2, _voyageCode, _vesselName, _operator.code, _consignorCode, _consignorCode, ISOTYPEREL2B, null,  null, null, 1, _ediPartyRules, _reqTS, _estReqTS,  false, true, false, false, true, true);
				endif;
	//			self.doCheckEDITrackedItem (ediTI.CM_EDIRequestHeaderTI, "A", RELEASE2, _voyageCode, _vesselName, _operator.code, _consignorCode, _consignorCode, ISOTYPEREL2A, null,  null, null, 1, _ediPartyRules, _reqTS, _estReqTS,  false, true, false, false);
			endif;
			endif;
		endforeach;
	endif;
	foreach ediTI in ediDataBooking.allEDITrackedItems do
		// ---------------------------------------
		// check values on EDI TI
		// ---------------------------------------
		//self.doCheckEDITrackedItem (ediTI, "A", _releaseNo, _voyageCode, _vesselName, _consignorCode, ISOTYPE, ADDITIONAL_TEXT, QUANTITY, _ediPartyRules, false, true);

	endforeach;
	// ---------------------------------------
	// do verify (all edi data)  
	// ---------------------------------------
	self.ediVerify(ediFile);
	tempStr	:= 'File Verify failed' &amp; CrLf &amp; app.myPassport.getErrorsAsString;
	self.assertEqualMsg(ediFile.fileStatus, CM_EDIFile.EDI_STATUS_VERIFIED, tempStr);
	
	// ---------------------------------------
	// load to DB
	// ---------------------------------------
	self.ediDBLoad(ediFile);
	tempStr	:= 'DBLoad failed' &amp; CrLf &amp; app.myPassport.getErrorsAsString;
	self.assertEqualMsg(ediFile.fileStatus, CM_EDIFile.EDI_STATUS_DBLOADED, tempStr);
	
	// ---------------------------------------
	// find the first release
	// ---------------------------------------
	release := self.getReleaseRequest (RELEASE1);
	
	self.assertNotNullMsg (release.code, RELEASE1 &amp; 'was not created');
	
	// ---------------------------------------
	// do standard checks
	// ---------------------------------------
	self.doCheckPartyRules_AddRelease (release, _ediPartyRules, false, true, false);
	
	self.assertTrueMsg (release.releaseByType, 'Release by type is not set');
	self.assertEqualMsg (release.code, RELEASE1, 'Release number is incorrect');
	self.assertEqualMsg (release.myVoyage.code, _voyageCode, 'Voyage code is incorrect');
	self.assertEqualMsg (release.myOperator, _operator, 'Operator is incorrect');
	self.assertEqualMsg (release.consignorCode, _consignorCode, 'Consignor is incorrect');
	self.assertTrueMsg (release.allReserveDetails.size = 2, 'Expecting 2 release lines');

	foreach item in release.allReserveDetails do
	
		self.assertNotNullMsg (item.CM_ReserveSelection.myISOType, 'ISO Type not set');

		if item.CM_ReserveSelection.myISOType.code = ISOTYPEREL1A then
		
		elseif item.CM_ReserveSelection.myISOType.code = ISOTYPEREL1B then
		
		else 
			self.assertTrueMsg (1=2, RELEASE1 &amp; ' ' &amp; item.CM_ReserveSelection.myISOType.code &amp; ' ISO type is incorrect');
		endif;
		
		// Availability grade - defaults for this file
		
		// total requested
		self.assertEqualMsg (item.totalRequested, 1, 'Total requested not set');
	endforeach;
	
	// check ediFile collection has been updated
	self.assertTrueMsg (release.allEDIFiles.includes (ediFile), 'Update the edi files collection !!!');
	self.assertTrueMsg (release.allEDIFiles.size = 1, RELEASE1 &amp; ' EDI the edi files collection should have 1 entry!!!');	
	// ---------------------------------------
	// find the second release
	// ---------------------------------------
	release := self.getReleaseRequest (RELEASE2);
	
	self.assertNotNullMsg (release, RELEASE2 &amp; 'was not created');
	
	// ---------------------------------------
	// do standard checks
	// ---------------------------------------
	self.doCheckPartyRules_AddRelease (release, _ediPartyRules, false, true, false);
	
	self.assertTrueMsg (release.releaseByType, 'Release by type is not set');
	self.assertEqualMsg (release.code, RELEASE2, 'Release number is incorrect');
	self.assertEqualMsg (release.myVoyage.code, _voyageCode, 'Voyage code is incorrect');
	self.assertEqualMsg (release.myOperator, _operator, 'Operator is incorrect');
	self.assertEqualMsg (release.consignorCode, _consignorCode, 'Consignor is incorrect');
	self.assertTrueMsg (release.allReserveDetails.size = 2, 'Expecting 2 release lines');

	foreach item in release.allReserveDetails do
	
		self.assertNotNullMsg (item.CM_ReserveSelection.myISOType, 'ISO Type not set');

		if item.CM_ReserveSelection.myISOType.code = ISOTYPEREL2A then
		
		elseif item.CM_ReserveSelection.myISOType.code = ISOTYPEREL2B then
		
		else
			self.assertTrueMsg (1=2, RELEASE2 &amp; ' ' &amp; item.CM_ReserveSelection.myISOType.code &amp; ' ISO type is incorrect');
		endif;
		
		// Availability grade - defaults for this file
		
		// total requested
		self.assertEqualMsg (item.totalRequested, 1, 'Total requested not set');
	endforeach;
	
	// check ediFile collection has been updated
	self.assertTrueMsg (release.allEDIFiles.includes (ediFile), 'Update the edi files collection !!!');
	self.assertTrueMsg (release.allEDIFiles.size = 1, RELEASE2 &amp; ' EDI the edi files collection should have 1 entry!!!');
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_sender" type="String"/>
        <Parameter name="_voyageCode" type="String"/>
        <Parameter name="_vesselName" type="String"/>
        <Parameter name="_consignorCode" type="String"/>
        <Parameter name="_reqTS" type="TimeStamp"/>
        <Parameter name="_estReqTS" type="TimeStamp"/>
        <Parameter name="_operator" type="CM_Operator"/>
        <Parameter name="_ediPartyRules" type="CM_EDIPartyCoparnRules"/>
    </JadeMethod>
    <JadeMethod name="doCoparn_mtrel_multi_grpMatch" id="e47e8070-a23f-4632-9457-5a3551ba32d4">
        <source>doCoparn_mtrel_multi_grpMatch(_sender, _voyageCode, _vesselName, _consignorCode :String; _reqTS, _estReqTS :TimeStamp;
						_operator :CM_Operator; _ediPartyRules :CM_EDIPartyCoparnRules) protected;
/*
Date		        Who		Reason
10/1102014			cnwjre1	Par 35137 test release item match on ISO Group when ISO type doesn't match
// 18 Oct 2017	jlgrs1	TFS 5705 - SNO - EDIDataBooking Prenote release Req
// 01 Jun 2018	jlgrs1	TFS 38992 JMT Booking and ReleaseReq for GateDoc
*/
constants
	RELEASE1 = "GB100001"; ISOTYPEREL1A = '22G1'; ISOTYPEREL1B = '42G1';
	RELEASE2 = "GB100003"; ISOTYPEREL2A = '2201'; ISOTYPEREL2B = '4201';
	BOOKING1 = "GB100002"; ISOTYPEBK1A = '22R1'; ISOTYPEBK1B = '45R1';
	BOOKING2 = "GB100004"; ISOTYPEBK2A = '2201'; ISOTYPEBK2B = '4501';
	ISOTYPE 		= '2100';	// in GEN2 but not 22G1 to match group but not type
	QUANTITY		= 1;
	CONTAINER1		= 'UT_2243001';
	CONTAINER2		= 'UT_2243002';
	VEHICLE			= 'UT_2243';
	BS				= 'BS2243';
vars
	found	: Boolean;
	count	: Integer;
	text	:String;
	ediFile	:CM_EDIFile;
	ediDataRR, ediDataBooking	:CM_EDIData;
	ediTI	:CM_EDITrackedItem;
	ediItemTI : CM_EDIRequestDetailTI;
	ediRelReq : CM_EDIReleaseRequestTI;
	release	:CM_BulkRelease;
	booking	:CM_BookingRef;
	item	:CM_ReserveDetail;
	isoType	:CM_ISOType;
	tempStr : String;
	ti				:CM_Container;
	ta				:CM_TerminalArea;
	gate			:CM_Gate;
	vvr				:CM_VehicleVisitRecord;
	wle				:CM_WorkListEntry;
	request			:CM_Request;
	terminal		:CM_Terminal;
	subTerminal		:CM_SubTerminal;
begin
	// ---------------------------------------
	// delete the release if it already exists
	// ---------------------------------------
	self.deleteReleaseRequest (RELEASE1);
	self.deleteBooking (BOOKING1);
	self.deleteReleaseRequest (RELEASE2);
	self.deleteBooking (BOOKING2);
	
	// ---------------------------------------
	// get edi file to load
	// ---------------------------------------
	text := self.zCoparn_mtrel_multi (_sender, _voyageCode, _vesselName, null, _reqTS, _estReqTS);

	// ---------------------------------------
	// load edi file to create EDI tracked items
	// ---------------------------------------
	ediFile := self.ediLoadFileName(text, EDIFileType_Unknown, "COPARN", "COPARN"&amp;method.name);
	
	self.assertNotNull(ediFile);
	
	// ---------------------------------------
	// find the release request ediData
	// ---------------------------------------
	if ediFile.ediData.isKindOf(CM_EDIDataGateDoc) then
		ediDataRR 		:= ediFile.ediData;
		ediDataBooking	:= ediFile.ediData;
	elseif ediFile.ediData.isKindOf(CM_EDIDataReleaseRequest) then
		ediDataRR := ediFile.ediData;
		ediDataBooking	:= ediFile.ediData;
	else
		ediDataRR := ediFile.allEDIData.first;
		ediDataBooking	:= ediFile.allEDIData.first;
	endif;
	
	self.assertNotNullMsg (ediDataRR, 'No edi data for release requests');
	self.assertNotNullMsg (ediDataBooking, 'No edi data for bookings');

	if ediDataRR.isKindOf(CM_EDIDataReleaseRequest) then
		self.assertTrueMsg (ediDataRR.allEDITrackedItems.size = 4, 'EDI tracked items not created for releases - expecting 4');
	elseif ediDataRR.isKindOf(CM_EDIDataGateDoc) then
		self.assertTrueMsg (ediDataRR.allEDITrackedItems.size = 12, 'EDI tracked items not created for releases - expecting 12');
	endif;
	self.assertTrueMsg (ediDataBooking.allEDITrackedItems.size &gt; 0, 'EDI tracked items not created for bookings');
	// ---------------------------------------
	// find the edi tracked items
	// ---------------------------------------
	if ediDataRR.isKindOf(CM_EDIDataReleaseRequest) then
		foreach ediTI in ediDataRR.allEDITrackedItems do
			self.assertTrue (ediTI.isKindOf (CM_EDIReleaseRequestTI));
			// ---------------------------------------
			// check values on EDI TI
			// ---------------------------------------
			if ediTI.CM_EDIReleaseRequestTI.releaseRequestNumber = RELEASE1 then
				if ediTI.CM_EDIReleaseRequestTI.isoType = ISOTYPEREL1A then
					self.doCheckEDITIReleaseRequest (ediTI.CM_EDIReleaseRequestTI, "A", RELEASE1, _voyageCode, _vesselName, _operator.code, _consignorCode, _consignorCode, ISOTYPEREL1A, null,  null, null, 1, _ediPartyRules, _reqTS, _estReqTS, false, true, false, false, false, true);
				else
					self.doCheckEDITIReleaseRequest (ediTI.CM_EDIReleaseRequestTI, "A", RELEASE1, _voyageCode, _vesselName, _operator.code, _consignorCode, _consignorCode, ISOTYPEREL1B, null,  null, null, 1, _ediPartyRules, _reqTS, _estReqTS, false, true, false, false, true, true);
				endif;
	//			self.doCheckEDITrackedItem (ediTI.CM_EDIReleaseRequestTI, "A", RELEASE1, _voyageCode, _vesselName, _operator.code, _consignorCode, null, ISOTYPEREL1A, null,  null, null, 1, _ediPartyRules, _reqTS, _estReqTS, false, true, false, false);
			elseif ediTI.CM_EDIReleaseRequestTI.releaseRequestNumber = RELEASE2 then
				if ediTI.CM_EDIReleaseRequestTI.isoType = ISOTYPEREL2A then
					self.doCheckEDITIReleaseRequest (ediTI.CM_EDIReleaseRequestTI, "A", RELEASE2, _voyageCode, _vesselName, _operator.code, _consignorCode, _consignorCode, ISOTYPEREL2A, "Heavy Rated",  null, null, 1, _ediPartyRules, _reqTS, _estReqTS,  false, true, false, false, true, true);
				else
					self.doCheckEDITIReleaseRequest (ediTI.CM_EDIReleaseRequestTI, "A", RELEASE2, _voyageCode, _vesselName, _operator.code, _consignorCode, _consignorCode, ISOTYPEREL2B, null,  null, null, 1, _ediPartyRules, _reqTS, _estReqTS,  false, true, false, false, true, true);
				endif;
	//			self.doCheckEDITrackedItem (ediTI.CM_EDIReleaseRequestTI, "A", RELEASE2, _voyageCode, _vesselName, _operator.code, _consignorCode, _consignorCode, ISOTYPEREL2A, null,  null, null, 1, _ediPartyRules, _reqTS, _estReqTS,  false, true, false, false);
			endif;
		endforeach;
	elseif ediDataRR.isKindOf(CM_EDIDataGateDoc) then
		foreach ediTI in ediDataRR.allEDITrackedItems do
			if ediTI.isKindOf(CM_EDIRequestHeaderTI) then
				ediItemTI := self.getMatchingEDIItemTI(ediTI.CM_EDIRequestHeaderTI);
			// ---------------------------------------
			// ---------------------------------------
			// check values on EDI TI
			// ---------------------------------------
			if ediTI.CM_EDIRequestHeaderTI.releaseRequestNumber = RELEASE1 then
				if ediItemTI.isoType = ISOTYPEREL1A then
					self.doCheckEDITiRequestMulti (ediTI.CM_EDIRequestHeaderTI, ediItemTI, "A", RELEASE1, _voyageCode, _vesselName, _operator.code, _consignorCode, _consignorCode, ISOTYPEREL1A, null,  null, null, 1, _ediPartyRules, _reqTS, _estReqTS, false, true, false, false, false, true);
				else
					self.doCheckEDITiRequestMulti (ediTI.CM_EDIRequestHeaderTI, ediItemTI, "A", RELEASE1, _voyageCode, _vesselName, _operator.code, _consignorCode, _consignorCode, ISOTYPEREL1B, null,  null, null, 1, _ediPartyRules, _reqTS, _estReqTS, false, true, false, false, true, true);
				endif;
	//			self.doCheckEDITrackedItem (ediTI.CM_EDIRequestHeaderTI, "A", RELEASE1, _voyageCode, _vesselName, _operator.code, _consignorCode, null, ISOTYPEREL1A, null,  null, null, 1, _ediPartyRules, _reqTS, _estReqTS, false, true, false, false);
			elseif ediTI.CM_EDIRequestHeaderTI.releaseRequestNumber = RELEASE2 then
				if ediItemTI.isoType = ISOTYPEREL2A then
					self.doCheckEDITiRequestMulti (ediTI.CM_EDIRequestHeaderTI, ediItemTI, "A", RELEASE2, _voyageCode, _vesselName, _operator.code, _consignorCode, _consignorCode, ISOTYPEREL2A, "Heavy Rated",  null, null, 1, _ediPartyRules, _reqTS, _estReqTS,  false, true, false, false, true, true);
				else
					self.doCheckEDITiRequestMulti (ediTI.CM_EDIRequestHeaderTI, ediItemTI, "A", RELEASE2, _voyageCode, _vesselName, _operator.code, _consignorCode, _consignorCode, ISOTYPEREL2B, null,  null, null, 1, _ediPartyRules, _reqTS, _estReqTS,  false, true, false, false, true, true);
				endif;
	//			self.doCheckEDITrackedItem (ediTI.CM_EDIRequestHeaderTI, "A", RELEASE2, _voyageCode, _vesselName, _operator.code, _consignorCode, _consignorCode, ISOTYPEREL2A, null,  null, null, 1, _ediPartyRules, _reqTS, _estReqTS,  false, true, false, false);
			endif;
			endif;
		endforeach;
	endif;
	foreach ediTI in ediDataBooking.allEDITrackedItems do
		// ---------------------------------------
		// check values on EDI TI
		// ---------------------------------------
		//self.doCheckEDITrackedItem (ediTI, "A", _releaseNo, _voyageCode, _vesselName, _consignorCode, ISOTYPE, ADDITIONAL_TEXT, QUANTITY, _ediPartyRules, false, true);

	endforeach;
	// ---------------------------------------
	// do verify (all edi data)  
	// ---------------------------------------
	self.ediVerify(ediFile);
	tempStr	:= 'File Verify failed' &amp; CrLf &amp; app.myPassport.getErrorsAsString;
	self.assertEqualMsg(ediFile.fileStatus, CM_EDIFile.EDI_STATUS_VERIFIED, tempStr);
	
	// ---------------------------------------
	// load to DB
	// ---------------------------------------
	self.ediDBLoad(ediFile);
	tempStr	:= 'DBLoad failed' &amp; CrLf &amp; app.myPassport.getErrorsAsString;
	self.assertEqualMsg(ediFile.fileStatus, CM_EDIFile.EDI_STATUS_DBLOADED, tempStr);
	
	// ---------------------------------------
	// find the first release
	// ---------------------------------------
	release := self.getReleaseRequest (RELEASE1);
	
	self.assertNotNullMsg (release.code, RELEASE1 &amp; 'was not created');
	
	// ---------------------------------------
	// do standard checks
	// ---------------------------------------
	self.doCheckPartyRules_AddRelease (release, _ediPartyRules, false, true, false);
	
	self.assertTrueMsg (release.releaseByType, 'Release by type is not set');
	self.assertEqualMsg (release.code, RELEASE1, 'Release number is incorrect');
	self.assertEqualMsg (release.myVoyage.code, _voyageCode, 'Voyage code is incorrect');
	self.assertEqualMsg (release.myOperator, _operator, 'Operator is incorrect');
	self.assertEqualMsg (release.consignorCode, _consignorCode, 'Consignor is incorrect');
	self.assertTrueMsg (release.allReserveDetails.size = 2, 'Expecting 2 release lines');

	foreach item in release.allReserveDetails do
	
		self.assertNotNullMsg (item.CM_ReserveSelection.myISOType, 'ISO Type not set');

		if item.CM_ReserveSelection.myISOType.code = ISOTYPEREL1A then
		
		elseif item.CM_ReserveSelection.myISOType.code = ISOTYPEREL1B then
		
		else 
			self.assertTrueMsg (1=2, RELEASE1 &amp; ' ' &amp; item.CM_ReserveSelection.myISOType.code &amp; ' ISO type is incorrect');
		endif;
		
		// Availability grade - defaults for this file
		
		// total requested
		self.assertEqualMsg (item.totalRequested, 1, 'Total requested not set');
	endforeach;
	
	// check ediFile collection has been updated
	self.assertTrueMsg (release.allEDIFiles.includes (ediFile), 'Update the edi files collection !!!');
	self.assertTrueMsg (release.allEDIFiles.size = 1, RELEASE1 &amp; ' EDI the edi files collection should have 1 entry!!!');	
	// ---------------------------------------
	// find the second release
	// ---------------------------------------
	release := self.getReleaseRequest (RELEASE2);
	
	self.assertNotNullMsg (release, RELEASE2 &amp; 'was not created');
	
	// ---------------------------------------
	// do standard checks
	// ---------------------------------------
	self.doCheckPartyRules_AddRelease (release, _ediPartyRules, false, true, false);
	
	self.assertTrueMsg (release.releaseByType, 'Release by type is not set');
	self.assertEqualMsg (release.code, RELEASE2, 'Release number is incorrect');
	self.assertEqualMsg (release.myVoyage.code, _voyageCode, 'Voyage code is incorrect');
	self.assertEqualMsg (release.myOperator, _operator, 'Operator is incorrect');
	self.assertEqualMsg (release.consignorCode, _consignorCode, 'Consignor is incorrect');
	self.assertTrueMsg (release.allReserveDetails.size = 2, 'Expecting 2 release lines');

	foreach item in release.allReserveDetails do
	
		self.assertNotNullMsg (item.CM_ReserveSelection.myISOType, 'ISO Type not set');

		if item.CM_ReserveSelection.myISOType.code = ISOTYPEREL2A then
		
		elseif item.CM_ReserveSelection.myISOType.code = ISOTYPEREL2B then
		
		else
			self.assertTrueMsg (1=2, RELEASE2 &amp; ' ' &amp; item.CM_ReserveSelection.myISOType.code &amp; ' ISO type is incorrect');
		endif;
		
		// Availability grade - defaults for this file
		
		// total requested
		self.assertEqualMsg (item.totalRequested, 1, 'Total requested not set');
	endforeach;
	
	// check ediFile collection has been updated
	self.assertTrueMsg (release.allEDIFiles.includes (ediFile), 'Update the edi files collection !!!');
	self.assertTrueMsg (release.allEDIFiles.size = 1, RELEASE2 &amp; ' EDI the edi files collection should have 1 entry!!!');
	
	// EXTRA STUFF fro 35137
	terminal		:= self.getTerminal;
	
	if terminal.isSubTerminalsOn then
		subTerminal		:= terminal.getDefaultSubTerminal (CM_SubTerminal.Type_BulkRelease, BR_TYPE_ROAD, 0, null, false);
	endif;
	self.opts.purge;
	self.opts.addAssociation(UTTI_Consignor, _consignorCode);
	self.opts.addAssociation(UTTI_DeliveryRelease, RELEASE2);
	self.opts.addAssociation('deliveryNumber', RELEASE2);
	self.opts.addAssociation(UTTI_IMEX, TI_IMEX_STATUS_STORAGE);
	
	// create a container that matches on iso group but not type with the first release item
	ti := self.addContainerOpts (CONTAINER1, ISOTYPE, 'MT', _operator).CM_Container;
	
	self.assertEqual (ti.consignor, _consignorCode);
	self.assertEqual (ti.deliveryRelease, RELEASE2);
	
	ta := self.addBlockStack (BS, null, null);
	
	self.move (ti, ta);
	assertEqual(ti.myPrimaryActualLocation, ta.allLocationsControllers.first);
	
	foreach gate in self.getTerminal.allGates do
		if not gate.hasPGateAreas then
			// single
			break;
		endif;
		gate := null;
	endforeach;
	
	self.assertNotNull (gate);
	
	release := self.getReleaseRequest (RELEASE1);
	beginTransaction;
	release.setPropertyValue (CM_BulkRelease::mySubTerminal.name, subTerminal);
	ti.setPropertyValue (CM_TrackedItem::mySubTerminal.name, subTerminal);
	commitTransaction;
	
	self.opts.addAssoc("release", release);
	vvr := self.gateOutContainer(VEHICLE, "", self.getDriverName , ti.CM_Container, true, gate , ta.id);
	self.assertNotNull (vvr);
	
	// At this point there will be a queued entry on the road ops form
	request := release.allRequestsBeingActioned.first;
	// need to null the reserve detail so ift will go looking on CM_TrackedItem::setBulkReleaseReleased to CM_ReserveSelection::doesTIMatchForRelease
	beginTransaction;
	request.setPropertyValue("myReserveDetail", null);
	commitTransaction;
	self.assertEqualMsg (release.allRequestsBeingActioned.size, 1, 'Expecting 1 request being actioned');
	wle := vvr.myRoadJob.workListEntries.first;
	self.assertEqual(vvr.myRoadJob.workListEntries.size, 1); 
	self.assertEqual(wle.myTrackedItem, ti);

	self.moveQueuedCargo (wle);
	self.roadExit (vvr);
	
	self.assertNullMsg (vvr.vehicle.myPrimaryActualLocation, 'Vehicle is still on site');
	// specific test
	foreach item in release.allReserveDetails do
		count := count + 1;
		if item.allTrackedItemsReleased.includes(ti) then
			break;
		endif;
	endforeach;
	self.assertEqualMsg(count, 1, "Request reserve detail matched");
	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_sender" type="String"/>
        <Parameter name="_voyageCode" type="String"/>
        <Parameter name="_vesselName" type="String"/>
        <Parameter name="_consignorCode" type="String"/>
        <Parameter name="_reqTS" type="TimeStamp"/>
        <Parameter name="_estReqTS" type="TimeStamp"/>
        <Parameter name="_operator" type="CM_Operator"/>
        <Parameter name="_ediPartyRules" type="CM_EDIPartyCoparnRules"/>
    </JadeMethod>
    <JadeMethod name="doCoparn_mtrel_withid" id="c404b6f3-6036-4308-8aa5-ea70286bae14">
        <source>doCoparn_mtrel_withid(_sender, _voyageCode, _vesselName, _consignorCode, _releaseNo :String; 
					_reqTS, _estReqTS :TimeStamp; _mt :Character; _operator :CM_Operator; _ediPartyRules :CM_EDIPartyCoparnRules)protected;
/*
Date		        Who		Reason
01 December 2011	cnwcs5	Initial creation - CCMS POL 2122 / par 28696 - Empty Releases via COPARN
9 January 2013      cnwgb1  CCMS POL 2216/ par 30902 Heavy Rated Releases      
// 31 Oct 2017	jlgrs1	TFS 5705 - SNO - EDIDataBooking Prenote release Req
*/
constants
	ADDITIONAL_TEXT	= "//PREASSIGNED CONTAINER TCLU2214123";
	ISOTYPE 		= '22G1';
	QUANTITY		= 8;
vars
	text	:String;
	ediFile	:CM_EDIFile;
	ediData	:CM_EDIData;
	ediTI	:CM_EDIRequestHeaderTI;
	ediItemTI : CM_EDIRequestDetailTI;
	ediRelReq : CM_EDIReleaseRequestTI;
	release	:CM_BulkRelease;
	item	:CM_ReserveSelection;
	isoType	:CM_ISOType;
	tempStr : String;
	ediItem : CM_EDITrackedItem;
begin
	// ---------------------------------------
	// delete the release if it already exists
	// ---------------------------------------
	self.deleteReleaseRequest (_releaseNo);
	
	// ---------------------------------------
	// get edi file to load
	// ---------------------------------------
	text := self.zCoparn_mtrel_withid (_sender, _voyageCode, _vesselName, _consignorCode, _releaseNo, ADDITIONAL_TEXT, ISOTYPE, QUANTITY.String, _reqTS, _estReqTS,_mt);
	
	// Est required TS - DTM+133:201109160500:203'

	// Request date - DTM+201:201109060900:203'
	
	// ---------------------------------------
	// load edi file to create EDI tracked items
	// ---------------------------------------
	ediFile := self.ediLoadFileName(text, EDIFileType_Coparn, "COPARN", "COPARN - Release by id"&amp;method.name);
	
	self.assertNotNull(ediFile);
	
	// ---------------------------------------
	// find the release request ediData
	// ---------------------------------------
	if ediFile.ediData.isKindOf(CM_EDIDataGateDoc) or
	   ediFile.ediData.isKindOf(CM_EDIDataReleaseRequest) then
		ediData := ediFile.ediData;
	else
		ediData := ediFile.allEDIData.first;
	endif;
	
	self.assertNotNullMsg (ediData, 'No edi data for release requests');
	
	// ---------------------------------------
	// find the edi tracked item
	// ---------------------------------------
//	ediTI := ediData.allEDITrackedItems.first.CM_EDIRequestHeaderTI;
	if ediData.isKindOf(CM_EDIDataGateDoc) then
		foreach ediItem in ediData.allEDITrackedItems do
			if  ediItem.isKindOf(CM_EDIRequestHeaderTI) then
				ediTI := ediItem.CM_EDIRequestHeaderTI;
				break;
			endif;
		endforeach;
		self.assertNotNullMsg(ediTI, 'EDI tracked items not created');
		ediItemTI := self.getMatchingEDIItemTI(ediTI);
		// ---------------------------------------
		// check values on EDI TI
		// ---------------------------------------
		self.doCheckEDITiRequestMulti(ediTI, ediItemTI, "A", _releaseNo, _voyageCode, _vesselName,  _operator.code,_consignorCode, null, ISOTYPE, ADDITIONAL_TEXT, null, null, QUANTITY, _ediPartyRules, null, null, false, true, false, false, false, true);
	endif;
	if ediData.isKindOf(CM_EDIDataReleaseRequest) then
		foreach ediItem in ediData.allEDITrackedItems do
			if  ediItem.isKindOf(CM_EDIReleaseRequestTI) then
				ediRelReq := ediItem.CM_EDIReleaseRequestTI;
				break;
			endif;
		endforeach;
		self.assertNotNullMsg(ediRelReq, 'EDI tracked items not created');
		// ---------------------------------------
		// check values on EDI TI
		// ---------------------------------------
		self.doCheckEDITIReleaseRequest(ediRelReq, "A", _releaseNo, _voyageCode, _vesselName,  _operator.code,_consignorCode, null, ISOTYPE, ADDITIONAL_TEXT, null, null, QUANTITY, _ediPartyRules, null, null, false, true, false, false, false, true);
	endif;
	
	// ---------------------------------------
	// do verify (all edi data)  
	// ---------------------------------------
	self.ediVerify(ediFile);
	tempStr	:= 'Verify failed' &amp; CrLf &amp; app.myPassport.getErrorsAsString;
	self.assertEqualMsg(ediData.status, CM_EDIFile.EDI_STATUS_VERIFIED, tempStr);
	
	// ---------------------------------------
	// load to DB
	// ---------------------------------------
	self.ediDBLoad(ediFile);
	tempStr	:= 'DBLoad failed' &amp; CrLf &amp; app.myPassport.getErrorsAsString;
	self.assertEqualMsg(ediData.status, CM_EDIFile.EDI_STATUS_DBLOADED, tempStr);
	
	// ---------------------------------------
	// find the release
	// ---------------------------------------
	release := self.getReleaseRequest (_releaseNo);
	
	self.assertNotNull (release);
	
	// ---------------------------------------
	// do standard checks
	// ---------------------------------------
	self.doCheckPartyRules_AddRelease (release, _ediPartyRules, false, true, false);
	
	self.assertTrueMsg (release.releaseByType, 'Release by type is not set');
	self.assertEqualMsg (release.code, _releaseNo, 'Release number is incorrect');
	self.assertEqualMsg (release.myVoyage.code, _voyageCode, 'Voyage code is incorrect');
	// self.assertEqualMsg (release.myOperator, ???, 'Operator is incorrect');// operator ???
	self.assertEqualMsg (release.consignorCode, _consignorCode, 'Consignor is incorrect');

	// we expect the release cargo remarks to include the addition text
	item := release.allReserveDetails.first.CM_ReserveSelection;
	
	self.assertNotNull (item);
	self.assertTrueMsg (item.remarks = ADDITIONAL_TEXT, 'Additionl text from FTX not stored in cargo remarks');

	self.assertNotNullMsg (item.myISOType, 'ISO Type not set');
	self.assertEqualMsg (item.myISOType.code, ISOTYPE, 'ISO type is incorrect');
	
	// Availability grade - defaults for this file
	
	// total requested
	self.assertEqualMsg (item.totalRequested, QUANTITY, 'Total requested not set');
	
	// check ediFile collection has been updated
	self.assertTrueMsg (release.allEDIFiles.includes (ediFile), 'Update the edi files collection !!!');
	self.assertTrueMsg (release.allEDIFiles.size = 1, _releaseNo &amp; ' EDI the edi files collection should have 1 entry!!!');	
epilog

end;</source>
