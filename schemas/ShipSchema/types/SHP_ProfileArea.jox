    <JadeMethod name="hasColumnsAfterBridge" id="93d2401b-1615-48f5-9e90-edebb6372445">
        <source>hasColumnsAfterBridge() : Boolean;
// ---------------------------------------------------------------------------
// Created:		December 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	aCol : CMUI_GridColumn;
begin
	foreach aCol in self.allGridColumns do
		if aCol.SHP_BayColumn.afterBridge then
