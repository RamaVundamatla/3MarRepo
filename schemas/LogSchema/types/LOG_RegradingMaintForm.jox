    </JadeMethod>
    <JadeMethod name="clearCombos" id="94ec2f24-7ef5-456c-8a54-1ca5364ce925">
        <source>clearCombos() protected;

vars

begin

	// Clear combos.
	self.cmbTOLocation.listIndex := -1;
	self.cmbNewGrade.clear;
	self.cmbNewGrade.setObjectAndSpecies(null,null);
	self.cmbNewLength.clear;
	self.cmbNewLength.setObjectAndGrade(null,null);
	self.cmbNewSpecies.clear;
	self.cmbNewSpecies.setObjectAndOperator(null,null);
	//self.cmbConsignor.clear();	// ccms 1116, #26786 27/01/2011
	self.cmbNewSupplier.clear;
	self.cmbNewTreatment.clear;
	self.cmbNewTreatment.setObjectAndGrade(null,null);
	self.cmbNewType.clear;
	self.cmbNewType.setObjectAndGrade(null,null);
	self.cmbRegrade.setObject(null); // added PAR11493 23/03/06
		
	self.tblActionData.setValueByName(ETRow_Location, null);
	//self.tblActionData.setValueByName(ETRow_Consignor, null);	//commented ccms 1116, #26786 27/01/2011
	self.tblActionData.setValueByName(ETRow_NewSupplier, null);
	self.tblActionData.setValueByName(ETRow_Species, null);
	self.tblActionData.setValueByName(ETRow_Length, null);
	self.tblActionData.setValueByName(ETRow_Grade, null);
	self.tblActionData.setValueByName(ETRow_Treatment, null);
	self.tblActionData.setValueByName(ETRow_Type, null);
	//self.tblActionData.setValueByName(ETRow_SedMin, null);		// 32210 don't enter these now
	//self.tblActionData.setValueByName(ETRow_SedMax, null);
	
end;</source>
        <access>protected</access>
    </JadeMethod>
