    <JadeMethod name="trxBNZBuyLineMgrUpdate" id="419404fd-a622-4eb2-a780-4eceb4105551">
        <updating/>
        <source>trxBNZBuyLineMgrUpdate(	pBNZBuyLineMgrToUpdate : CnEcBNZBuyLineMgr io;
						pRequiredEdition : Integer;
						pBuyLineAdminEmailAddress : String;
						pBuyLineETLpassword : String;
						pBuyLineOPSId : Integer;
						pBuyLinePath : String;
						pBuyLineRpassword : String;
						pBuyLineServer : String;
						pTimeOut : Integer;
						pBuyLineVpassword : String): String updating; 
// --------------------------------------------------------------------------------
// Purpose:		Transaction method to update a BNZBuyLineMgr object.
//
// Parameters:	The object being updated, and its key and property values.
//              If pRequiredEdition is greater than zero, the transaction will
//				check that the latest edition of the object is equal to
//				pRequiredEdition. If not, then an 'Object out-of-date' message
//				will be returned.
//
// Returns:		Null if the transaction is successful, otherwise an error message
//				is returned.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	errorMessage	: String;

begin
	// Initialize the activity first.
	self.agentInitializeActivity();

	// Arm our base exception handlers (local exception handlers which are
	// disarmed when the method returns).
	on Exception do self.agentExceptionHandler(exception);
	on LockException do self.agentLockExceptionHandler(exception);

	// Validate the request.

	if pBNZBuyLineMgrToUpdate = null then
		return self.agentSetError('No BNZBuyLineMgr selected to update  ');
	endif;

	// If the owner object is invalid, then we want our exception handlers to
	// return a message saying so.  After registering the object and a message
	// here, if any subsequent invalid object exceptions occur, the exception
	// handler will then find the registered object and set the 'errorMsg'
	// property on the app class.  Therefore, by checking this errorMsg value
	// after performing an operation on the object (app.getLastError), the
	// appropriate error message can be returned for the exception.
	self.agentRegisterObjectAndError(pBNZBuyLineMgrToUpdate, 'Invalid BNZBuyLineMgr Object.');

	beginTransaction;

	// Exclusive transaction lock to obtain the latest edition of the object and
	// lock it. We need the latest edition to check it against pRequiredEdition.
	// This lock will be released automatically at the next commit/abort transaction.
	// We obtain an exclusive lock (as opposed to a shared lock) because we're
	// about to update the object, and JADE will automatically try to lock it
	// exclusively (if we don't already have it) before updating it. Getting an
	// exclusive lock up front avoids JADE having to upgrade the lock from shared
	// to exclusive at the point the object is updated.
	exclusiveLock(pBNZBuyLineMgrToUpdate);

	// If the exclusiveLock gets an exception, our handler will resume to here.
	if self.lastError = null and pRequiredEdition &gt; 0 then
		// We obtained the lock, now check the edition.
		if pBNZBuyLineMgrToUpdate.edition() &lt;&gt; pRequiredEdition then
			// The edition has changed, so the object on which the sender based
			// this update is out-of-date.
			self.agentSetError('Object is out-of-date.');
		endif;
	endif;

	// If we're still error free, then perform the operation.
	if self.lastError = null then
		pBNZBuyLineMgrToUpdate.updateMe(	pBuyLineAdminEmailAddress,
											pBuyLineETLpassword,
											pBuyLineOPSId,
											pBuyLinePath,
											pBuyLineRpassword,
											pBuyLineServer,
											pTimeOut,
											pBuyLineVpassword
											);
	endif;

	// If the operation raises an exception, our handler will resume to here.
	if self.lastError = null then
		// No errors, so commit.
		commitTransaction;
	else
		// We got an error so abort the transaction. Although TransactionAgent
		// exception handlers abort the transaction before resuming, we do so
		// here as well for completeness and symmetry with the beginTransaction.
		// An abortTransaction when not in transaction state does nothing.
		abortTransaction;
	endif;
epilog
	// Always return the error to the caller (which will be null if no errors).
	return self.lastError;
end;</source>
