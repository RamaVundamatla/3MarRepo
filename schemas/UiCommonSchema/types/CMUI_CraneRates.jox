    <JadeMethod name="create" id="22cb592e-6b32-4faf-a869-bfe2af9312c5">
        <updating/>
        <source>create() updating;
/*

Purpose:			


Return Value:		


Date		Who		Reason
01 February 2007	cnwer1	Initial creation - PAR#xxxx

*/
vars

begin
	self.permissionView  := PmShpCraneMoveRatesView; // TFS 2101
	self.permissionMaint := PmShpCraneMoveRates;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doOK" id="c1aadc09-5883-4f74-81b7-81e818d91ef9">
        <updating/>
        <source>doOK() updating;
/*

Purpose:			


Return Value:		


Date				Who		Reason
01 February 2007	cnwer1	Initial creation - PAR#xxxx
08/04/2011			cnwmh5	PAR #27347 - Add cmsEndLoad or endLoad to epilog so that if error occurs it will not leave it in beginLoad state
*/
vars
	pxyCraneMoveRate, 
	realCraneMoveRate: CM_CraneMoveRates;
	crane : CM_Crane;
	isAdd : Boolean;	//13 Jan 2020 NDL	TFS 46815
	isUpdate : Boolean;	//13 Jan 2020 NDL	TFS 46815
	theResult : Integer;	//13 Jan 2020 NDL	TFS 46815
begin
							
	if self.myCraneMoveRates = null then
		if self.myCrane = null then
		//	app.raiseCMException1(REQUIRED_FIELD,app.getErrorString(CM_Crane_GC),null,null);
			app.raiseCMException1(Input_required_field_Required,app.getErrorString(CM_Crane_GC),null,null); // cnwdb2	PAR 35364

			return;
		
		endif;
	
		create  pxyCraneMoveRate transient;
		pxyCraneMoveRate.setProxy(self.txtSLOD.text.Integer,
										self.txtSLUD.text.Integer,
										self.txtTLOD.text.Integer,
										self.txtTLUD.text.Integer,
										self.txtOD.text.Integer);
									
		isAdd := true;								
										
//		app.myTrxCA.trxCreateCraneMoveRates(pxyCraneMoveRate,realCraneMoveRate,self.myCrane,self.myVessel,app.myPassport);	
	else
	//updating crane move obj
		beginLoad;
		pxyCraneMoveRate:=self.myCraneMoveRates.pxyCreateUpdateProxy;
		endLoad;
		pxyCraneMoveRate.setProxy(self.txtSLOD.text.Integer,
										self.txtSLUD.text.Integer,
										self.txtTLOD.text.Integer,
										self.txtTLUD.text.Integer,
										self.txtOD.text.Integer);
										
		isUpdate := true;
		
//		app.myTrxUA.trxUpdateCraneMoveRates(pxyCraneMoveRate,app.myPassport);
	endif;
	
	//13 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
	while true do
	
		if isAdd then
			app.myTrxCA.trxCreateCraneMoveRates(pxyCraneMoveRate,realCraneMoveRate,self.myCrane,self.myVessel,app.myPassport);
		elseif isUpdate then
			app.myTrxUA.trxUpdateCraneMoveRates(pxyCraneMoveRate,app.myPassport);
		endif;
	
		if app.myPassport.trxCompletedOK then
			self.loadCraneRateDetails;
			break;
		else
			theResult := app.showErrorWarningDialog('Crane Move Rates', app.myPassport, ErrWarnMode_Update);
			if app.myPassport.noErrors and theResult = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		
		break;
		
	endwhile;

epilog
	endLoad;				// 08/04/2011 cnwmh5 #27347
	delete pxyCraneMoveRate;
end;</source>
    </JadeMethod>
    <JadeMethod name="loadCmbCranes" id="a9125137-412a-4158-a174-81faebc9543e">
        <updating/>
        <source>loadCmbCranes() updating;
/*

Purpose:			


Return Value:		


Date		Who		Reason
01 February 2007	cnwer1	Initial creation - PAR#xxxx

*/
vars
	indx: Integer;
	iter : Iterator;
	machine : CM_Machine;
begin

	cmbCranes.clear;
	if self.myCrane &lt;&gt; null then
		cmbCranes.listIndex:=cmbCranes.addItem(self.myCrane.getDisplayDetails(false));
		cmbCranes.enabled:=false;
		self.loadCraneRateDetails();
	else
		iter:=app.myRoot.allMachines.createIterator;
		while iter.next(machine) do
			if not machine.isKindOf(CM_Crane) then
				continue;
			endif;
			cmbCranes.itemObject[cmbCranes.addItem(machine.getDisplayDetails(false))]:=machine;
		endwhile;
	endif;

epilog
	delete iter;
end;</source>
    </JadeMethod>
    <JadeMethod name="loadCraneRateDetails" id="6313b935-3786-4dd4-ab0f-251c0c5bd7d9">
        <updating/>
        <source>loadCraneRateDetails() updating;
/*

Purpose:			


Return Value:		


Date		Who		Reason
01 February 2007	cnwer1	Initial creation - PAR#xxxx

*/
vars

begin
	self.txtSLOD.text:=null;
	self.txtSLUD.text:=null;
	self.txtTLOD.text:=null;
	self.txtTLUD.text:=null;
	self.txtOD.text:=null;
	
	
	//do the vessel first because otherwise will look at crane.moverates
	if self.myVessel &lt;&gt; null then
		self.myCrane:=self.cmbCranes.itemObject[cmbCranes.listIndex].CM_Crane;
		if self.myCrane &lt;&gt; null then
			self.myCraneMoveRates:=self.myVessel.allCraneRates[self.myCrane];
		endif;		
	elseif	 self.myCrane &lt;&gt; null then
		self.myCraneMoveRates:= self.myCrane.myMoveRate;
		
	endif;
	if self.myCraneMoveRates &lt;&gt; null then
		self.txtSLOD.text:=self.myCraneMoveRates.ratePerHourSLOD.String;
		self.txtSLUD.text:=self.myCraneMoveRates.ratePerHourSLUD.String;
		self.txtTLOD.text:=self.myCraneMoveRates.ratePerHourTLOD.String;
		self.txtTLUD.text:=self.myCraneMoveRates.ratePerHourTLUD.String;
		self.txtOD.text:=self.myCraneMoveRates.ratePerHourOD.String;
	endif;
	
	
	
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setMyObject" id="2e162094-57ca-4a3a-8f84-2a854846cfda">
        <updating/>
        <source>setMyObject(_object : CM_Object) : Boolean updating;
/*

Purpose:			


Return Value:		


Date		Who		Reason
01 February 2007	cnwer1	Initial creation - PAR#xxxx

*/
vars

begin
	if _object.isKindOf(CM_Crane) then
		self.myCrane:=_object.CM_Crane;
		self.myVessel:=null;
		return true;
	elseif _object.isKindOf(CM_Vessel) then
		self.myVessel:=_object.CM_Vessel;
		self.myCrane:=null;
		return true;
	else
		return false;
	endif;

epilog

end;</source>
        <Parameter name="_object" type="CM_Object"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setupForm" id="74c1e164-cdee-4fce-9fd4-d4ba863fc452">
        <updating/>
        <source>setupForm() updating;
/*

Purpose:			


Return Value:		


Date		Who		Reason
01 February 2007	cnwer1	Initial creation - PAR#xxxx

*/
vars

begin
	inheritMethod();
	self.btnOk.caption:= app.getString(Save);
	self.btnCancel.caption:= app.getString(Close);
	if myCrane &lt;&gt; null then
		self.setCaption(app.getString(Crane_move_rates));
		self.myCraneMoveRates:=self.myCrane.myMoveRate;		
	elseif myVessel &lt;&gt; null then
		self.setCaption(app.getString(Vessel_crane_move_rates)&amp; " - " &amp; self.myVessel.getDisplayDetails(true));		
		//self.cmbCranes.myTerminal:=self.myVessel.myTerminal;
		
	endif;
	self.loadCmbCranes();

	
	// TFS 2101 CNWAB1
	if not app.myCurrentUserCan(null, self.permissionMaint) then
		self.grpRates.enabled := false;
		self.btnOk.enabled := false;
	endif;	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="translateForm" id="4527340a-768b-439d-8e0f-dc02fd24f741">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
//	self.translateCaption(Xlat_0017317, locale);
	lblCrane.translateCaption(Xlat_0005013, locale);
	lblOD.translateCaption(Xlat_0005014, locale);
	lblSLOD.translateCaption(Xlat_0005015, locale);
	lblSLUD.translateCaption(Xlat_0005016, locale);
	lblTLOD.translateCaption(Xlat_0005017, locale);
	lblTLUD.translateCaption(Xlat_0005018, locale);
end;</source>
    </JadeMethod>
    <JadeMethod name="txtSLOD_lostFocus" id="03539885-b667-4f4c-bbce-0e7e1182e123">
        <controlMethod name="TextBox::lostFocus"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>txtSLOD_lostFocus(textbox: TextBox input) updating;
/*

Purpose:			


Return Value:		


Date		Who		Reason
02 February 2007	cnwer1	Initial creation - PAR#xxxx

*/
vars
	rate: Integer;
begin

	if textbox.text &lt;&gt; null and self.txtTLOD.text = null then
		rate:=textbox.text.Integer;
		//epr par  18425 16/10/09
		if (rate*2) &lt;= 99 then
			self.txtTLOD.text:=(rate*2).String;
		endif;
	endif;
	
epilog

end;</source>
        <Parameter name="textbox" type="TextBox" usage="input"/>
    </JadeMethod>
