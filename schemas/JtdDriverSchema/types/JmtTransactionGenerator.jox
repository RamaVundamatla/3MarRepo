    <JadeMethod name="assert" id="5b255252-8774-4f65-a4b2-70c56f8e3fe7">
        <source>assert(okCondition:Boolean; displayObject:Object);
vars
	error		: CM_Error;
	errorSet	: CM_ErrorSet;
begin
	if not okCondition then
//		process.debug;
		app.logMessage("assertion failed ");
		if displayObject &lt;&gt; null then
			app.logMessage(displayObject.display);
			if CM_ErrorSet.hasInstance(displayObject) then
				errorSet := displayObject.CM_ErrorSet;
				foreach error in errorSet do
					app.logMessage("CM_Error code:" &amp; error.errorCode.String &amp; " Descr:" &amp; error.text &amp; " errorUserOjb:" &amp; error.myUserObject.String);
				endforeach;
			endif;
		endif;
		if 1/0=1 then /* deliberate exception */ endif;
	endif;
end;
</source>
        <Parameter name="okCondition" type="Boolean"/>
        <Parameter name="displayObject" type="Object"/>
    </JadeMethod>
