    <JadeMethod name="trxUpdateBOLOutLog" id="93d8c30b-296e-467f-bdc6-3d57030e3ce0">
        <updating/>
        <source>trxUpdateBOLOutLog(_proxyBOL : CM_BOL input; _intFaceItem : CMIF_BOLOut;
				   _ignoreWarnings : Boolean; _passport : CM_Passport input) updating;
//-----------------------------------------
//Created: October 2002 By: cnwgd1
//-----------------------------------------
vars
	realBOL			: CM_BOL;
	expectedEdition	: Integer;
	terminal		: CM_Terminal;

begin

	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	app.setContinueCMExceptions(false);

	_proxyBOL.raiseExceptionIfNotProxy(method);
	
	//validate and update the proxy docket first as attachments are set from the docket
	app.myValUA.valBOL(_proxyBOL, false, _passport);
	
	endLoad;		// free up validation locks
	
	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	
	_proxyBOL.pxyGetRealObjectAndEdition(realBOL, expectedEdition);

	if realBOL = null then	
		app.raiseCMException1(ProxyMgrCannotLocateReal, CM_BOL.number.String, null, null);
		return;
	endif;

	beginTransaction;
	terminal := _passport.myTerminal;
	
	exclusiveLock(realBOL);

	if _passport.noErrors and realBOL.edition &lt;&gt; expectedEdition then
		app.raiseCMException1(ObjectUpdatedByAnotherUserSave, 'Docket', null, null);
		return;
	endif;
	
	if _passport.noErrors then
		app.myUtilityUA.myUpdateAuditAgent.audUpdateGeneric(realBOL, true);
	endif;
	
	if _passport.noErrors then
		realBOL.setForUpdate(_proxyBOL, _passport);
	endif;
	
	if _passport.noErrors then
		realBOL.myExtension.setTIsFromCMIF_BOL(_intFaceItem, _passport);
	endif;

	if _passport.noErrors then
		realBOL.executeMoveForMode(REAL_MODE, _passport);
	endif;

	if _passport.noErrors then
		app.myUtilityUA.myUpdateAuditAgent.audUpdateGeneric(realBOL, false);
		terminal.causeEvent(terminal.getTerminalEvent(BOLRecon_Update_Event), false, realBOL);
	endif;
	
epilog
	self.finaliseActivityWithPassport(_passport);

end;</source>
        <Parameter name="_proxyBOL" type="CM_BOL" usage="input"/>
        <Parameter name="_intFaceItem" type="CMIF_BOLOut"/>
        <Parameter name="_ignoreWarnings" type="Boolean"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
