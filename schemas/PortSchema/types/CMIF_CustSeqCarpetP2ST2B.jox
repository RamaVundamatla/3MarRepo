<CollClass name="CMIF_CustSeqCarpetP2ST2B" id="480ef4ca-1b30-4588-9ad9-d9e5594686ef">
    <duplicatesAllowed/>
    <memberType name="CMIF_CustomSequenceObject"/>
    <superclass name="CMIF_CustomSeqObjectDict"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>Sort Slot Request by Bay Deck Cell and Tier. Duplicates are allowed in case across several bays.

In this order:

123
456
789</text>
    <DbClassMap file="cmtrans"/>
    <MemberKey>
        <keyPath>
            <ImplicitInverseRef name="CMIF_CustomSequenceObject::mySlotController"/>
            <ExplicitInverseRef name="CM_SlotController::myBayVoyage"/>
        </keyPath>
        <property name="CM_Bay::ordinalBay"/>
    </MemberKey>
    <MemberKey>
        <keyPath>
            <ImplicitInverseRef name="CMIF_CustomSequenceObject::mySlotController"/>
        </keyPath>
        <property name="CM_SlotController::ordinalDeck"/>
    </MemberKey>
    <MemberKey>
        <keyPath>
            <ImplicitInverseRef name="CMIF_CustomSequenceObject::mySlotController"/>
        </keyPath>
        <property name="CM_SlotController::ordinalTier"/>
        <descending/>
    </MemberKey>
    <MemberKey>
        <keyPath>
            <ImplicitInverseRef name="CMIF_CustomSequenceObject::mySlotController"/>
        </keyPath>
        <property name="CM_SlotController::ordinalCell"/>
        <descending/>
    </MemberKey>
</CollClass>
