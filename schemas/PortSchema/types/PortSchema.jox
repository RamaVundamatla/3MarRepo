    <JadeMethod name="initializeLocaleInfo" id="3886e9fc-f479-45c0-aad1-249ab08f3138">
        <updating/>
        <source>initializeLocaleInfo() protected, updating;
// --------------------------------------------------------------------------------
// Created:		31 August 2010 by cnwdad1
//
// Purpose:		Initializes the JMT LocaleFullInfo object on app.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 31/08/2010	cnwdad1		Initial creation.  PAR 20064.
// --------------------------------------------------------------------------------
vars
	jmtFullInfo		: LocaleFullInfo;
	
begin	
	create jmtFullInfo transient;
	currentSchema.getLocaleFullInfo(currentSchema.getCurrentLocaleId(), jmtFullInfo);
	self.myLocaleInfoJMT	:=	jmtFullInfo;
end;</source>
