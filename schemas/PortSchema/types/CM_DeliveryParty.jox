    <JadeMethod name="getAuditChildSubjects" id="c01b1608-87f8-4741-b285-62c93bfce851">
        <source>getAuditChildSubjects(_childAuditSubjectNames: StringArray input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 June 2022	jlier1	Initial creation

*/

vars
	address : CM_Address;
begin
	inheritMethod(_childAuditSubjectNames);
	foreach address  in self.allAddresses discreteLock do	
		address.getAuditChildSubjects(_childAuditSubjectNames);
	endforeach;	

epilog

end;</source>
        <Parameter name="_childAuditSubjectNames" type="StringArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getAuditText" id="a7729aa5-3ff3-4a67-99b9-c351a677d0a9">
        <source>getAuditText(): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 June 2022	jlier1	Initial creation TFS 53679

*/

vars
	auditStr,
	tmpStr 		: String;
	address : CM_Address;
begin
	auditStr[10000] := '*';
	auditStr := null;
	auditStr := inheritMethod();

	foreach address  in self.allAddresses discreteLock do	
		auditStr := auditStr &amp; address.getAuditText();
	endforeach;	

epilog
	return auditStr;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDefaultAddress" id="3c0b3868-a99d-424c-99f9-61cea6fd4bab">
        <source>getDefaultAddress():CM_Address;
/*

/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 June 2022	jlier1	Initial creation 53679

*/

vars
	address : CM_Address;
begin
	
	
	foreach address in self.allAddresses discreteLock where address.isDefault  do	
		return address;
	endforeach;
	
	return null ;

epilog

end;</source>
        <ReturnType type="CM_Address"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="eccb6e33-9538-4b1f-8511-fafec67960dc">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
/*****************************************************
Author		: jlika1 (Karen Alexander)
Date		: 09 June 2022
TFS#		: 53679
Function	:

*** Changes ***
Date			Name		TFS#		Description

****************************************************/

vars

begin
	if _attrName = ETRow_Code then
		return self.code.String;
	elseif _attrName = ETRow_Name then
		return self.name.String;
	elseif _attrName = ETRow_Nafe then
		return self.nafe.display;
	else
		return inheritMethod(_attrName, _short);
	endif;

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="cd19ee2f-b702-4017-8b1e-d2de624f1ada">
        <source>pxyCreateUpdateProxy(): SelfType;
/*****************************************************
Author		: jlika1 (Karen Alexander)
Date		: 13 June 2022
TFS#		: 53679
Function	:

*** Changes ***
Date			Name		TFS#		Description

****************************************************/

vars
	proxy 		: CM_DeliveryParty;	
	completedOK	: Boolean;
	allAddress	: CM_AddressByCode;
	address		: CM_Address;
	pxyAddress	: CM_Address;
begin
	proxy := inheritMethod();
	
	foreach address in self.allAddresses do
		pxyAddress := address.pxyCreateUpdateProxy();
		proxy.allAddresses.add(pxyAddress);
	endforeach;
		
	self.allReserveDetails.copy(proxy.allReserveDetails);
	self.allTerminals.copy(proxy.allTerminals);	
	proxy.myRoot:=self.myRoot;
	
	completedOK := true;
	
	return proxy;
epilog
	if not completedOK then
		delete proxy;
	endif;	
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="3f0a37b6-07ae-4387-8a59-513385cf3026">
        <updating/>
        <source>setForCreate(pProxyDeliveryParty: CM_DeliveryParty) updating;
/*****************************************************
Author		: jlika1 (Karen Alexander)
Date		: 13 June 2022
TFS#		: 
Function	:

*** Changes ***
Date			Name		TFS#		Description

****************************************************/

begin

	pProxyDeliveryParty.raiseExceptionIfNotTransient(method);
	
	setForUpdate(pProxyDeliveryParty);
	self.myRoot := app.myRoot;

end;</source>
        <Parameter name="pProxyDeliveryParty" type="CM_DeliveryParty"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="0e20f771-c912-4177-a7c5-54959b474aa4">
        <updating/>
        <source>setForUpdate(_proxy: CM_DeliveryParty) updating;
/*****************************************************
Author		: jlika1 (Karen Alexander)
Date		: 13 June 2022
TFS#		: 53679
Function	:

*** Changes ***
Date			Name		TFS#		Description

****************************************************/
vars
	address 	 : CM_Address;
	_realAddress : CM_Address;
	allAddresseToDelete : ObjectSet;
begin
	self.code 					:= _proxy.code;
	self.name 					:= _proxy.name.trimBlanks;
	self.nafe					:= _proxy.nafe;
	
	self.allTerminals.clear();
	
	if not _proxy.allTerminals.isEmpty then
		_proxy.allTerminals.copy( self.allTerminals );
	endif;
	create allAddresseToDelete transient;
	self.allAddresses.copy(allAddresseToDelete);	

	foreach address in _proxy.allAddresses discreteLock do			
		_realAddress := address.pxyGetRealObject();
		if _realAddress = null then
			app.myUtilityCA.utlCreateDebtorAddress(address,_realAddress, app.myPassport);
			if app.myPassport.hasErrors then
				return;
			endif;
			self.allAddresses.add(_realAddress);
		else
			allAddresseToDelete.remove(_realAddress);
			app.myUtilityUA.utlUpdateDebtorAddress(address,_realAddress, app.myPassport);
			
		endif;		
	endforeach;	
	
	if app.myPassport.noErrors then
		allAddresseToDelete.purge;
	endif;
epilog
	delete allAddresseToDelete;
end;</source>
        <Parameter name="_proxy" type="CM_DeliveryParty"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="9e8be053-eaff-4b86-b58a-df6bac952b57">
        <updating/>
        <source>setProxy(_code: String;
		 _name: String;
		 _nafe: Boolean;
		 _selectedTerminals : CM_TerminalSet) updating;
/*****************************************************
Author		: jlika1 (Karen Alexander)
Date		: 13 June 2022
TFS#		: 
Function	:

*** Changes ***
Date			Name		TFS#		Description

****************************************************/

begin

	self.raiseExceptionIfNotTransient(method);

	self.code := _code;
	self.name := _name[1:200];
	self.nafe := _nafe;
	self.myRoot := app.myRoot;
	
	self.allTerminals.clear();
	if _selectedTerminals &lt;&gt; null and not _selectedTerminals.isEmpty then
		_selectedTerminals.copy( self.allTerminals );
	endif;
end;</source>
        <Parameter name="_code" type="String"/>
        <Parameter name="_name" type="String"/>
        <Parameter name="_nafe" type="Boolean"/>
        <Parameter name="_selectedTerminals" type="CM_TerminalSet"/>
    </JadeMethod>
    <JadeMethod name="validateForCreate" id="ea1cc4df-4564-4d0c-9ecf-298d73fce57e">
        <source>validateForCreate();
/*****************************************************
Author		: jlika1 (Karen Alexander)
Date		: 13 June 2022
TFS#		: 53679
Function	:

*** Changes ***
Date			Name		TFS#		Description

****************************************************/

begin

	if app.myRoot.allDeliveryParties[code] &lt;&gt; null then
		app.raiseCMException1(VB_DUPLICATED_ITEM, self.code.String, null, null);
	endif;

	self.validateMe;

end;</source>
    </JadeMethod>
    <JadeMethod name="validateForDelete" id="1f20284a-b34b-4aab-be30-569ef8440a2e">
        <source>validateForDelete();
/*****************************************************
Author		: jlika1 (Karen Alexander)
Date		: 13 June 2022
TFS#		: 53679
Function	:

*** Changes ***
Date			Name		TFS#		Description

****************************************************/

begin
	if not self.allReserveDetails.isEmpty then
		app.raiseCMException1(Canno_delet_deliv_party, self.code, null, null);
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="validateForUpdate" id="48835e1a-9b60-4b6b-ac1f-a59ae3edf46b">
        <source>validateForUpdate();
/*****************************************************
Author		: jlika1 (Karen Alexander)
Date		: 13 June 2022
TFS#		: 53679
Function	:

*** Changes ***
Date			Name		TFS#		Description

****************************************************/

begin
	self.validateMe();
end;</source>
    </JadeMethod>
    <JadeMethod name="validateMe" id="6191c70c-12c9-4062-babe-12ecee8c6319">
        <source>validateMe() protected;
/*****************************************************
Author		: jlika1 (Karen Alexander)
Date		: 13 June 2022
TFS#		: 53679
Function	:

*** Changes ***
Date			Name		TFS#		Description

****************************************************/

begin

	if self.name = null then	
		app.raiseCMException(Input_requi_deliv_party_name, null, null); 
	endif;
	
	if self.myRoot = null then	
		app.raiseCMException(ERROR_Root, null, null);
	endif;

end;</source>
        <access>protected</access>
    </JadeMethod>
</Class>
