<CollClass name="CM_LabourRestrictionByIdDict" id="ac23998f-7dd2-4968-8118-83b103693029">
    <memberType name="CM_LabourRestriction"/>
    <superclass name="CM_MemberKeyDictionary"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="location"/>
    <MemberKey>
        <property name="CM_LabourRestriction::id"/>
    </MemberKey>
    <JadeMethod name="getAllCodes" id="10e634a4-e270-4708-9b3f-e780d8b8385f">
        <source>getAllCodes() : String;
// ---------------------------------------------------------------------------
// Created:		September 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	aLR : CM_LabourRestriction;
	theCodes : String;
begin
	foreach aLR in self do
		if theCodes &lt;&gt; null then
			theCodes := theCodes &amp; " ";
		endif;
		theCodes := theCodes &amp; aLR.id[1:1];
	endforeach;
	
	return theCodes;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getAllIDs" id="a0023d5a-c6bd-447b-9cbb-15839647fc96">
        <source>getAllIDs() : String;
// ---------------------------------------------------------------------------
// Created:		September 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	aLR : CM_LabourRestriction;
	theCodes : String;
begin
	foreach aLR in self do
		if theCodes &lt;&gt; null then
			theCodes := theCodes &amp; ", ";
		endif;
		theCodes := theCodes &amp; aLR.id;
	endforeach;
	
	return theCodes;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
</CollClass>
