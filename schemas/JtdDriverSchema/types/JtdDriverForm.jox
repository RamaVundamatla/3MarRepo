    <JadeMethod name="jtdBeginNotifications" id="bc4a3241-f0c4-4928-a67f-8b1e5b37e102">
        <updating/>
        <source>jtdBeginNotifications() updating, protected;

vars
	jtd : JtdContext;
	
begin
	self.endNotificationForSubscriber(self);

	jtd := app.jtdMyContext;
	
	self.beginNotification(system, jtd.jtdCommandEventNumber, Response_Continuous, 0);
	self.beginNotification(node, jtd.jtdCommandEventNumber, Response_Continuous, 0);
	self.beginNotification(process, jtd.jtdCommandEventNumber, Response_Continuous, 0);
	
	self.beginNotification(self, self.JtdRunTransactionsEventNumber, Response_Continuous, 0);
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="jtdCmdClear" id="49135528-0de5-4dcf-9a50-318e4073085e">
        <updating/>
        <source>jtdCmdClear(param : String) updating, protected;

vars
	mthDesc : JtdTrxGenMethodDesc;
	
begin
	self.jtdCmdStop(null);
	
	app.jtdMyContext.jtdSetTotalRunSecs(0);
	
	self.jtdMySummary.jtdInitialize;
	
	foreach mthDesc in app.jtdMyContext.jtdAllTrxGenMethodDescs do
		mthDesc.jtdMySummary.jtdInitialize;
	endforeach;

	self.jtdWaitingOnPingAck := false;
	
	self.jtdRefreshWindow(true);
end;</source>
        <access>protected</access>
        <Parameter name="param" type="String"/>
    </JadeMethod>
    <JadeMethod name="jtdCmdClone" id="4a7e8ef2-777d-40f8-9116-d2d5fb7a0fad">
        <source>jtdCmdClone(param : String) protected;

// 13 June 2016	cnwns1	TFS 488 - Multi Timezone Support

vars
	numClones, screenWidth, screenHeight, i, n, len : Integer;
	appServer, appServerPort, s, profileName : String;
	aip, aipExternal : JtdAppInitializationParameter;
	cloneFatClientsExternally : Boolean;
	cmdLine : JtdCommandLine;
	notUsedResult : Integer;
	sa : JtdStringArray200;
	jtd : JtdContext;
	x, y : Real;
		
begin
	jtd := app.jtdMyContext;
	
	if jtd.jtdMyDriverProfile = null or jtd.jtdMyDriverProfile.isKindOf(JtdDefaultDriverProfile) then
		profileName := null;
	else
		profileName := jtd.jtdMyDriverProfile.jtdName;
	endif;

	create cmdLine transient;
	
	numClones := 1;
	appServer := null;
	appServerPort := null;
	cloneFatClientsExternally := false;
	
	i := 1;
	n := 1;
	len := param.length;

	while n &lt;= len do
		s := param.scanUntil(';', n).trimBlanks;
		
		if n &lt; 1 then
			break;
		endif;

		if i = 1 then
			numClones := s.Integer;
		elseif i = 2 then
			cloneFatClientsExternally := s.Boolean;
		elseif i = 3 then
			appServer := s;
		elseif i = 4 then
			appServerPort := s;
			break;
		endif;

		n := n + 1;
		i := i + 1;
	endwhile;		

	if numClones &lt; 1 then
		numClones := 1;
	endif;
	if appServer = null then
		appServer := cmdLine.jtdAppServer;
	endif;
	if appServerPort = null or appServerPort.Integer &lt; 1 then
		appServerPort := cmdLine.jtdAppServerPort;
	endif;

	if process.isUsingThinClient or cloneFatClientsExternally then
		create aipExternal transient;
		aipExternal.jtdFormWidth := self.width;
		aipExternal.jtdFormHeight := self.height;
		aipExternal.jtdTrxDelay := jtd.jtdTrxDelay;
		aipExternal.jtdAutoPingResponseInterval := jtd.jtdAutoPingResponseInterval;
		aipExternal.jtdProfileName := profileName;
		aipExternal.jtdStatusDisplayEnabled := self.grpDetails.enabled;
		aipExternal.jtdStartupDelaySecs := jtd.jtdStartupDelaySecs;
		aipExternal.jtdShutdownDelaySecs := jtd.jtdShutdownDelaySecs;
	endif;

	screenWidth := self.getSystemMetrics(SM_cxFullScreen);
	screenHeight := self.getSystemMetrics(SM_cyFullScreen);

	x := self.left;
	y := self.top;
		
	foreach n in 1 to numClones do
		if jtd.jtdStartupDelaySecs &gt; 0 then
			// sleep for a random period up to jtdStartupDelayIntervalSecs
			// seconds before starting each app in order to stagger the
			// application initialization a bit
			process.sleep(((app.random(app.actualTimeServer.time.milliSecond) mod// 13 June 2016	cnwns1	TFS 488 - Multi Timezone Support
				jtd.jtdStartupDelaySecs) + 1) * 1000);
		endif;

		y := y + self.height;
		
		if (y + self.height) &gt; screenHeight then
			y := 0;
			x := x + self.width;
		endif;
		
		if (x + self.width) &gt; screenWidth then
			x := 0;
			y := 0;
		endif;
		
		if process.isUsingThinClient or cloneFatClientsExternally then
			aipExternal.jtdFormTop := y;
			aipExternal.jtdFormLeft := x;

			if sa = null then
				create sa transient;
			else
				sa.clear;
			endif;
			if process.isUsingThinClient then
				sa.add("schema=" &amp; currentSchema.name);
				sa.add("app=JtdDriverExternalCloneApp");
				sa.add('appServer="' &amp; appServer &amp; '"');
				sa.add("appServerPort=" &amp; appServerPort);
			else
				sa.add('path="' &amp; app.dbPath &amp; '"');
				sa.add("schema=" &amp; currentSchema.name);
				sa.add("app=JtdDriverExternalCloneApp");
				if app.isMultiUser then
					sa.add("server=multiUser");
				else
					sa.add("server=singleUser");
				endif;
			endif;
			sa.add('ini="' &amp; app.getIniFileName &amp; '"');
			sa.add("endJade");
			sa.add(aipExternal.jtdAsString);

			node.createExternalProcess(app.getJadeInstallDir, "jade.exe", sa, null,
				process.isUsingThinClient, false, notUsedResult);
		else		
			beginTransientTransaction;
			create aip sharedTransient;
			aip.jtdFormTop := y;
			aip.jtdFormLeft := x;
			aip.jtdFormWidth := self.width;
			aip.jtdFormHeight := self.height;
			aip.jtdTrxDelay := jtd.jtdTrxDelay;
			aip.jtdAutoPingResponseInterval := jtd.jtdAutoPingResponseInterval;
			aip.jtdProfileName := profileName;
			aip.jtdStatusDisplayEnabled := self.grpDetails.enabled;
			aip.jtdStartupDelaySecs := jtd.jtdStartupDelaySecs;
			aip.jtdShutdownDelaySecs := jtd.jtdShutdownDelaySecs;
			commitTransientTransaction;
			
			app.startApplicationWithParameter(currentSchema.name, "JtdDriverCloneApp", aip);
		endif;
	endforeach;
	
epilog
	delete sa;
	delete cmdLine;
	delete aipExternal;
end;</source>
        <access>protected</access>
        <Parameter name="param" type="String"/>
    </JadeMethod>
    <JadeMethod name="jtdCmdEnableStatusDisplay" id="17a22b6d-6b61-4cf2-8af1-a3abd621f6a5">
        <updating/>
        <source>jtdCmdEnableStatusDisplay(param : String) updating, protected;

constants
	DisabledMsg = "Status display disabled";
	
begin
	if param.Boolean then
		if (not self.statusLine.enabled) or (not self.grpDetails.enabled) then
			self.statusLine.enabled := true;
			self.grpDetails.enabled := true;
			self.jtdRefreshWindow(true);
			self.jtdSetState(self.jtdState, null);
		endif;
	else
		if self.statusLine.enabled or self.grpDetails.enabled then
			self.statusLine.caption := DisabledMsg;
			self.statusLine.backColor := self.backColor;
			self.caption := getOidStringForObject(process) &amp; ": " &amp; DisabledMsg;
			self.statusLine.enabled := false;
			self.grpDetails.enabled := false;
			self.refreshNow;
			self.statusLine.refreshNow;
		endif;
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="param" type="String"/>
    </JadeMethod>
    <JadeMethod name="jtdCmdPing" id="71148049-6845-45b8-a0b6-e3354f1da79f">
        <updating/>
        <source>jtdCmdPing(param : String) updating, protected;

vars
	mthDesc : JtdTrxGenMethodDesc;
	
begin
	if self.jtdWaitingOnPingAck then
		// we haven't received an acknowledgement of our last ping, so don't
		// send any more responses until we do get an ack (otherwise we risk
		// flooding controllers with notifications)
		return;
	endif;
	
	self.jtdWaitingOnPingAck := true;
	
	system.causeEvent(app.jtdMyContext.jtdPingResponseEventNumber, true,
		self.jtdGetPingResponseString);
	
	foreach mthDesc in app.jtdMyContext.jtdAllTrxGenMethodDescs do
		if mthDesc.jtdMySummary.jtdTotalTransactions &gt; 0 then
			system.causeEvent(app.jtdMyContext.jtdTrxPingResponseEventNumber, true,
				mthDesc.jtdGetPingResponseString);
		endif;
	endforeach;
end;</source>
        <access>protected</access>
        <Parameter name="param" type="String"/>
    </JadeMethod>
    <JadeMethod name="jtdCmdPingAck" id="06e0c14e-e885-4496-9d71-727a29a4062d">
        <updating/>
        <source>jtdCmdPingAck(param : String) updating, protected;

begin
	self.jtdWaitingOnPingAck := false;
end;</source>
        <access>protected</access>
        <Parameter name="param" type="String"/>
    </JadeMethod>
    <JadeMethod name="jtdCmdProfileMethod" id="dd6cb787-8887-4780-a0c1-2e3dfe60f46a">
        <updating/>
        <source>jtdCmdProfileMethod(param : String) updating, protected;

vars
	n, len : Integer;
	
begin
	len := param.length;
	
	if len &lt; 3 then
		// need at least 3 characters, so can't do anything
		return;
	endif;
	
	// method name and output file name are separated by a ';'
	n := param.pos(';', 1);
	
	if n &lt; 2 or n &gt;= len then
		// Either there's no ';' delimiter or it appears as the
		// first or last character. In all cases it means that
		// the parameter string is bad, so we can't do anything.
		return;
	endif;
	
	app.jtdMyContext.jtdSetMethodNameToProfile(param[1 : n - 1]);
	app.jtdMyContext.jtdSetProfilerOutputFileName(param[n + 1 : end]);
end;</source>
        <access>protected</access>
        <Parameter name="param" type="String"/>
    </JadeMethod>
    <JadeMethod name="jtdCmdReloadProfile" id="0aabd1ea-68c6-4683-a9ae-baab3781b6e7">
        <updating/>
        <source>jtdCmdReloadProfile(param : String) updating, protected;

// Force the current profile to be reloaded. If we don't currently
// have a profile (ie: we're running from the default profile) or
// the current profile no longer exists, the default profile will
// be loaded.

begin
	if app.jtdMyContext.jtdMyDriverProfile = null or
	   JtdDefaultDriverProfile.hasInstance(app.jtdMyContext.jtdMyDriverProfile)
	then
		self.jtdCmdSetProfile(null);
		return;
	endif;
	
	self.jtdCmdSetProfile(app.jtdMyContext.jtdMyDriverProfile.jtdName);
end;</source>
        <access>protected</access>
        <Parameter name="param" type="String"/>
    </JadeMethod>
    <JadeMethod name="jtdCmdSetPingInterval" id="33d40606-f5d3-49f4-aeb3-6944152bb25b">
