    <JadeMethod name="toBitString" id="26665119-40d7-42cc-b6bb-0b8467d065aa">
        <source>toBitString() : String;

vars
	bitString : String;
	idx : Integer;
	int : Integer;
begin
	int := self.Integer;
	if int.bitAnd(#80) = 0 then
		bitString := bitString&amp;'0';
	else
		bitString := bitString&amp;'1';
	endif;
	if int.bitAnd(#40) = 0 then
		bitString := bitString&amp;'0';
	else
		bitString := bitString&amp;'1';
	endif;
	if int.bitAnd(#20) = 0 then
		bitString := bitString&amp;'0';
	else
		bitString := bitString&amp;'1';
	endif;
	if int.bitAnd(#10) = 0 then
		bitString := bitString&amp;'0';
	else
		bitString := bitString&amp;'1';
	endif;
	if int.bitAnd(#08) = 0 then
		bitString := bitString&amp;'0';
	else
		bitString := bitString&amp;'1';
	endif;
	if int.bitAnd(#04) = 0 then
		bitString := bitString&amp;'0';
	else
		bitString := bitString&amp;'1';
	endif;
	if int.bitAnd(#02) = 0 then
		bitString := bitString&amp;'0';
	else
		bitString := bitString&amp;'1';
	endif;
	if int.bitAnd(#01) = 0 then
		bitString := bitString&amp;'0';
	else
		bitString := bitString&amp;'1';
	endif;
	return bitString;
end;

</source>
        <ReturnType type="String"/>
    </JadeMethod>
</PrimType>
