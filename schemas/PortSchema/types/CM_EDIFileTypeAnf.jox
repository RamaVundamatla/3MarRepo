    <JadeMethod name="processFile" id="61301533-b56a-489e-b7a3-eaa75219d02b">
        <updating/>
        <source>processFile(_ediFile: CM_EDIFile input)protected, updating;
// 07 Mar 2013	cnwcs5	CCMS POL 2097 / par 31259 - include foundMatch in method signatures
//12 Jan 2015	cnwrs1	Par 35504 - Refactor EDI file load for .NET
//08 Oct 2015	cnwrs1	Par 36863 - make EDI consistant times when refreshing progress bar
// 13 May 2016	cnwns1	TFS 488 - Multi Timezone Support
// 08 May 2018	jlgrs1	TFS 36425 SingleLine Booking partial processing not working
// 18 Jan 2019	jlgrs1	TFS 41659 42276 STWR Make EDI MultiThreaded Stage 8
// 07 Apr 2019	jlgrs1	TFS 41913 STWR - Reconfiguration of the EDI Operation form to better handle EDI collection locks while loading 
//
constants
	ProgressBarRefresh	: Integer = 2000;	
vars
	container				: CM_EDIPrenoteTI;
	ediDataPrenote			: CM_EDIDataPrenote;
	message					: String;
	generatedContainerNo	: Integer;
	group					: Integer;
	portDestCode			: String;
	terminal				: CM_Terminal;
	isotype					: String;
	operator				: CM_Operator;
	msgCount, numMsgs		: Integer;
	passport				: CM_Passport;
	foundMatch				: Boolean;
	theLines : HugeStringArray;
	progressInt	: TimeStampInterval;
	progressTS : TimeStamp;
begin
	progressTS := app.actualTimeServer();// 13 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	passport			:=	app.myPassport;	
	terminal			:=	passport.myTerminal;
	ediDataPrenote		:=	_ediFile.ediData.CM_EDIDataPrenote;
	portDestCode		:=	terminal.getConfig(PortDestCode).String.trimBlanks;	

	create theLines transient;
	self.rawDataToHSA(_ediFile, theLines);
	numMsgs	:= theLines.size;
	foreach message in theLines do
		msgCount	:=	msgCount + 1;
		
		progressInt := app.actualTimeServer() - progressTS;// 13 May 2016	cnwns1	TFS 488 - Multi Timezone Support
		if passport.myCMIFMonitor &lt;&gt; null and (progressInt.getMilliseconds &gt;= ProgressBarRefresh) then
			passport.myCMIFMonitor.updateProgress("Processing file", numMsgs, msgCount);
			progressTS := app.actualTimeServer();// 13 May 2016	cnwns1	TFS 488 - Multi Timezone Support
		endif;
		
		if container &lt;&gt; null		//first time through
		and container.id = null		// if the last container has no id
		then
			self.addFileErrors("Container has no id, using generated number" &amp; Tab &amp; group.String &amp; Tab &amp; message, msgCount, _ediFile);
			generatedContainerNo	:=	generatedContainerNo + 1;
			container.setIdDefault(generatedContainerNo.String);
		endif;
		
		//epr par 29399  13/4/12
		if message.length &lt; 131 then
			continue;
		endif;
		
		ediDataPrenote.createPrenoteTI(container, message[21:11]);
		container.operatorCode	:=	message[45:3];
		operator	:=	app.myRoot.allOperators[container.operatorCode];
		isotype		:=	message[52:4];
		
		if operator &lt;&gt; null then
			container.isoType	:=	operator.getXlationSystemCode(isotype, XLATION_TYPE_ISOTYPE_BYOP, foundMatch)[1:4];	// par 31259 March 2013
		else
			container.isoType	:=	isotype[1:4];
		endif;
		
		container.fullOrMT				:=	"";
		container.setCargoType(TI_CargoType_Container);
		container.loadPort				:=	message[42:3];
		container.locationId			:=	message[10:6];
		container.commodityDescription	:=	message[75:12];
		container.destinationPort		:=	message[95:3];
		container.dischargePort			:=	message[92:3];
		container.length				:=	message[119:4].Integer;
		container.commodity				:=	message[119:4];
		container.weight				:=	message[87:5].Integer;
		
		if message.length() &gt; (131) then
			container.width			:=	message[126:3].Integer;
//			container.height		:=	message[129:3].Integer;
			container.temperature	:=	message[132:4].asEDIReal();
			
			if message[131:1] = "-" then
				container.temperature	:=	-container.temperature;
			endif;
		endif;
		
		container.transportMode	:=	TI_TRANSMODE_ROAD_STR;
	endforeach;
epilog
	delete theLines;
end;</source>
        <access>protected</access>
        <Parameter name="_ediFile" type="CM_EDIFile" usage="input"/>
    </JadeMethod>
    <JadeMethod name="rawDataToHSA" id="c238341a-6383-4765-88de-473c34024118">
        <source>rawDataToHSA(_ediFile : CM_EDIFile; _theLines: HugeStringArray input);
//
//15 Jan 2015	cnwrs1	Par 35504 - Refactor EDI file load for .NET
// 28 Jul 2015	cnwrs1	Par 36683 since new data is in rawData suport old data (8.3.2) from compressedFilelines
//
vars
	ediFile : CM_EDIFile;
	fileLine : String;
	theLines: HugeStringArray;
begin
	_theLines.clear;
	create theLines transient;
	fileLine := self.rawDataToString(_ediFile);
	if fileLine = null then
		self.compressedDataToHSD(_ediFile, _theLines);
	else
		fileLine.getHugeTokensForDelimiter(Cr, theLines);
		foreach fileLine in theLines do
			if fileLine.isBlank then
				continue;
			endif;
			if fileLine[1:8] = self.DollarsHeader then			// eg "$$$HDR**"
				// start next line
				continue;
			elseif fileLine[1:8] = self.DollarsTrailer then		// eg "$$$EOT**"
				// we have finished
				break;
			else
				_theLines.add(fileLine);
			endif;
		endforeach;
		ediFile := _ediFile;
		if process.isInTransactionState then
			ediFile.setNumContainers(_theLines.size);
		endif;
	endif;
epilog
	delete theLines;
end;
</source>
        <Parameter name="_ediFile" type="CM_EDIFile"/>
        <Parameter name="_theLines" type="HugeStringArray" usage="input"/>
    </JadeMethod>
</Class>
