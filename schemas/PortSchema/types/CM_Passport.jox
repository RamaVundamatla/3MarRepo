    <JadeMethod name="getObjectOfTypeFromOid" id="886495b5-3f56-4ead-8db6-3a13e84e6c03">
        <source>getObjectOfTypeFromOid(_oid : String;  _type : Class input) : Object;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 August 2017	jlger1	Initial creation TFS 5535

*/

vars
	object :Object;
	invalidObj 	: Boolean;
	ed			: Integer;
	failedDAC		: CM_DataAccessController;
	terminalId : String;
	niceName : String;
begin
	
	if _oid = null then
		return null;
	endif;
	
	object := _oid.asOid;
	if object = null then
		return null;
	endif;
	
	on Exception do app.handleDeletedObject(exception,object,invalidObj);
	ed := object.edition;
	if invalidObj then
		//object has been deleted
		//"The object %1 has been deleted"
		app.raiseCMException1(Object_been_deleted,_oid,null,null);
		return null;
	endif;
	
	if not object.isKindOf(_type) then	
		//"The object %1 is not the expected object type %2"
		app.raiseCMException2(Object_not_expecte_type,_oid,_type.name,null,null);
		return null;
	endif;
	
	//epr tfs 7329 11/10/17
	if object.isKindOf(CM_Object) then
		niceName:=object.CM_Object.auditId;
	else
		niceName:=_oid;
	endif;
	
	if object.getMyTerminal &lt;&gt; null then
		if object.getMyTerminal &lt;&gt; self.myTerminal then
			//"The object %1 does not belong to the users current terminal'
			
			if self.myTerminal &lt;&gt; null then
				terminalId:=self.myTerminal.code;
			endif;
			app.raiseCMException2(Object_not_current_terminal,niceName,terminalId,null,null);
			return null;
		endif;
	endif;
	
	if  not object.CM_Object.canUserAccessSelf(self.myUser, failedDAC,self) then   
		app.raiseCMException3(ERR_USER_NO_ACCESS,self.myUser.userName,niceName,null, null, null);
		return null;
	endif;
	
	return object;
epilog

end;</source>
        <Parameter name="_oid" type="String"/>
        <Parameter name="_type" type="Class" usage="input"/>
        <ReturnType type="Object"/>
    </JadeMethod>
    <JadeMethod name="getProcessStatsDelta" id="ffff30a9-5a71-45ff-8cc5-7aa02360a056">
        <source>getProcessStatsDelta(jdo1, jdo2 : JadeDynamicObject; attributeName : String) : Real protected;
// ---------------------------------------------------------------------------
// Created:     06 October 2004 by cnwrs2
//
// Purpose:     Based on CnNodeControl::delta()
// ---------------------------------------------------------------------------
vars
	dec1	: Decimal[23];
	dec2	: Decimal[23];
	dec3	: Decimal[23];
begin
	dec1	:= jdo1.getAttributeValue(attributeName).Decimal;
	dec2	:= jdo2.getAttributeValue(attributeName).Decimal;
	
	if dec2 &gt;= dec1 then
		return (dec2 - dec1).Real;
	else
		//the value must have wrapped
		dec3	:= ((2.Decimal ^ 64.Decimal) - dec1 + dec2).Real;
		if dec3 &gt; Max_Integer then
			app.raiseUnexpectedProgramError(class.name, method.name, "Computed delta value is greater than Max_Integer.");
		endif;
		return dec3;
	endif;	
end;</source>
        <access>protected</access>
        <Parameter name="jdo1" type="JadeDynamicObject"/>
        <Parameter name="jdo2" type="JadeDynamicObject"/>
        <Parameter name="attributeName" type="String"/>
        <ReturnType type="Real"/>
    </JadeMethod>
