	sa.add('ecl020v_CEF_optSpecifyTypclick');
	sa.add('ecl022_CEF_cmbLoadAsTypeclick');
	sa.add('ecl022v_CEF_cmbLoadAsTypeclick');
	sa.add('ecl024_CEF_btnBrowse_click');
	sa.add('ecl024v_CEF_btnBrowse_click');
	sa.add('ecl026_CEF_picture_click');
	sa.add('ecl026v_CEF_picture_click');
	sa.add('ecl028_CEF_fldDetail_click');
	sa.add('ecl028v_CEF_fldDetail_click');
	sa.add('ecl030_CEF_tblData_click');
	sa.add('ecl030v_CEF_tblData_click');
	sa.add('ecl032_CEF_mnuTblVCloneTop_cli');
	sa.add('ecl034_CEF_frame_click');
	sa.add('ecl034v_CEF_frame_click');
	sa.add('ecl036_CEF_frame_click');
	sa.add('ecl036v_CEF_frame_click');
	sa.add('ecl038_CEF_picture_click');
	sa.add('ecl038v_CEF_picture_click');
	sa.add('ecl040_CEUDT_cmbFileDef_click');
	sa.add('ecl040v_CEUDT_cmbFileDef_click');
	sa.add('ecl042_CEF_tblEDITIErrorclick');
	sa.add('ecl042v_CEF_tblEDITIErrorclick');
	sa.add('ecl044_CEF_tblEDITIErrorclick');
	sa.add('ecl044v_CEF_tblEDITIErrorclick');
	sa.add('ecl999_tidyUp');

	foreach meth in sa do
		if meth[7:2] &lt;&gt; "v_" then
			app.doWindowEvents(longPause);
		endif;
		userPreTransaction(meth);
		retCode:=self.sendMsg(meth).Integer;
		userPostTransaction(meth);
		if app.atcgReplayFailure then
			app.atcgReplayFailure:=false;
			break;
		elseif retCode = 0 then
			app.logMessage("Test "&amp;self.class.name&amp;"::"&amp;meth&amp;" succeeded");
		else
			app.logMessage("Test "&amp;self.class.name&amp;"::"&amp;meth&amp;" failed with error code "&amp;retCode.String);
			break;
		endif;
	endforeach;
	app.atcgDetectMissedMsgBoxes;
	app.logMessage("Finished");
	return 0;
epilog
	delete sa;
end;</source>
