    <JadeMethod name="buildLabel" id="f521c1b3-eac1-4ff5-83b9-852addb1897e">
        <updating/>
        <source>buildLabel() updating, protected;
// --------------------------------------------------------------------------------
// Created:		16 February 2006 by cnwdad1
//
// Purpose:		Sets up the Label control.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	labelObj	: Label;
	
begin
	create labelObj transient;
	labelObj.caption		:=	self.caption;
	labelObj.alignment		:=	Label.Alignment_Right_Middle;	//Label.Alignment_Left_Middle;
	labelObj.transparent	:=	true;
	self.myLabel			:=	labelObj;
	labelObj.parent			:=	self;
	self.form.addControl(labelObj);
	labelObj.move(0, 0, self.labelWidth, labelObj.height);
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="buildSelf" id="5bb9ad15-59dc-44e8-ae5c-fb0b8fd36220">
        <updating/>
        <source>buildSelf() updating, protected;
// --------------------------------------------------------------------------------
// Created:		16 February 2006 by cnwdad1
//
// Purpose:		Instantiates the appropriate controls, and sets them all up.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.buildLabel();
	self.caption	:=	null;
end;</source>
        <access>protected</access>
    </JadeMethod>
