    <JadeMethod name="setTextValues" id="17e47eb3-bf0a-4214-a45b-09fcfc024f48">
        <source>setTextValues(_txt: TextBox input; _params: CM_QueryCriteriaLineHolder; _operator: CM_QueryOperator; _passport: CM_Passport);
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02/12/2009	cnwdap1	Initial creation
10/05/2013	cnwdap1	PAR #31155 CCMS SFW 1321 Imperial Measurements
03/10/2017	jlgdap1	TFS 7204 STWR Issues with decimal values in locales where decimal place is not a .
*/
vars

begin
	if _txt = null or (not  CM_QueryDecimalOperator.hasInstance(_operator)) then
		return;
	endif;
	
	if self.myMeasurementType = null then													// PAR #31155
		//_txt.text := _operator.CM_QueryDecimalOperator.searchValue.String;		// TFS 7204
		_txt.text := _operator.CM_QueryDecimalOperator.searchValue.asStringJMT;		// TFS 7204
	else																					// PAR #31155
		_txt.text := app.convertMeasurementForDisplay(self.myMeasurementType.shortName, _operator.CM_QueryDecimalOperator.searchValue);	// PAR #31155
	endif;																					// PAR #31155
end;</source>
        <Parameter name="_txt" type="TextBox" usage="input"/>
        <Parameter name="_params" type="CM_QueryCriteriaLineHolder"/>
        <Parameter name="_operator" type="CM_QueryOperator"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="translateToDisplayValue" id="08865185-5d70-4fd8-9791-45fd6df82d20">
        <source>translateToDisplayValue(_value: Any): String;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who					Reason
02/12/2009	cnwdap1				Initial creation
05/05/2013	cnwdap1	PAR #31155 	CCMS SFW 1321 Imperial Measurements
31/08/2018  jlgka1	TFS #40200	Change Decimal from 2 to 4 to address filter issue.
*/
vars
	measure : CM_MeasurementType;				// PAR #31155
	value 	: String;							// PAR #31155

begin
	measure := self.myMeasurementType;													// PAR #31155
	if measure = null then																// PAR #31155
		return _value.Decimal.asStringJMTWithPrecision(4, false);
	else																				// PAR #31155
		return app.convertMeasurementForDisplay(measure.shortName, _value.Decimal) &amp; Space &amp; measure.shortName;	// PAR #31155
	endif;																				// PAR #31155
epilog

end;</source>
        <Parameter name="_value" type="Any"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="translateToSearchValue" id="0a00d62a-bac2-42ce-92ea-494d3501261e">
        <source>translateToSearchValue(_value: Any): Any;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 10/05/2013	cnwdap1		Initial creation PAR #31155 CCMS SFW 1321 Imperial Measurements
//
vars

begin
	if _value.isKindOf(Decimal) and self.myMeasurementType &lt;&gt; null then
		return app.convertMeasurementForStorage(self.myMeasurementType.shortName, _value.Decimal).Decimal;
	endif;
	return inheritMethod(_value);

epilog

end;</source>
        <Parameter name="_value" type="Any"/>
        <ReturnType type="Any"/>
    </JadeMethod>
</Class>
