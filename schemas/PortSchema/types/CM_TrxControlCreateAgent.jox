    <JadeMethod name="trxCreateEDIDataBOLOutLog" id="3703a6d5-f088-4bfb-9777-9ea3e00fa20f">
        <updating/>
        <source>trxCreateEDIDataBOLOutLog(_pxyEDIDataBOLOutLog : CM_EDIDataBOLOutLog input; 
						_copyFileToServer : Boolean;
						_newEDIDataBOLOutLog : CM_EDIDataBOLOutLog output;
						_voyageGlobal			: CM_VoyageGlobal;
						_passport : CM_Passport input) updating;

vars
	tmpMonitor : CMIF_Monitor;
begin

	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	// This is done differently to others as it does considerable
	// work prior to going into transactions state

	app.writeLog("Shipside Scanning Import File :: creating data from file (" &amp; _pxyEDIDataBOLOutLog.logOutFileName &amp; ')', LogINFO);

	app.myValCA.valEDIDataBOLOutLog(_pxyEDIDataBOLOutLog,_voyageGlobal, _passport);

	if _passport.hasErrors then 
		app.writeLog("Shipside Scanning Import File Error :: 1 (" &amp; _pxyEDIDataBOLOutLog.logOutFileName &amp; ')', LogINFO);
		app.convertErrorsWarningsToAlert("Shipside Scanning Import File Error", _passport.allErrorWarnings);
		return;
	endif;

	app.setContinueCMExceptions(true);

	if (not _pxyEDIDataBOLOutLog.readFile(_copyFileToServer, _voyageGlobal, _passport)) then
		app.writeLog("Shipside Scanning Import File Error :: 2 (" &amp; _pxyEDIDataBOLOutLog.logOutFileName &amp; ')', LogINFO);
		app.convertErrorsWarningsToAlert("Shipside Scanning Import File Error", _passport.allErrorWarnings);
		return;
	endif;

	app.setContinueCMExceptions(false);
		
	// Start the transaction
	beginTransaction;

	// Perform the operation
	app.writeLog("Shipside Scanning Import File :: converting to persistent (" &amp; _pxyEDIDataBOLOutLog.logOutFileName &amp; ')', LogINFO);

	create _newEDIDataBOLOutLog persistent;
	_newEDIDataBOLOutLog.setForCreate(_pxyEDIDataBOLOutLog, _passport);

	tmpMonitor := _passport.myCMIFMonitor;
	if tmpMonitor &lt;&gt; null then
		if tmpMonitor.monitorReturnValue &lt;&gt; null then
			app.raiseCMException(VB_USER_CANCELED_TRANS, null, null);	
			return;
		endif;
	endif;
		
	if _passport.hasErrors then 
		app.writeLog("Shipside Scanning Import File Error :: 3 (" &amp; _pxyEDIDataBOLOutLog.logOutFileName &amp; ')', LogINFO);
		app.convertErrorsWarningsToAlert("Shipside Scanning Import File Error", _passport.allErrorWarnings);
		return;
	endif;		

epilog
	app.writeLog("Shipside Scanning Import File :: creating data from file - complete (" &amp; _pxyEDIDataBOLOutLog.logOutFileName &amp; ')', LogINFO);
	self.finaliseActivityWithPassport(_passport);
end;</source>
        <Parameter name="_pxyEDIDataBOLOutLog" type="CM_EDIDataBOLOutLog" usage="input"/>
        <Parameter name="_copyFileToServer" type="Boolean"/>
        <Parameter name="_newEDIDataBOLOutLog" type="CM_EDIDataBOLOutLog" usage="output"/>
        <Parameter name="_voyageGlobal" type="CM_VoyageGlobal"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
