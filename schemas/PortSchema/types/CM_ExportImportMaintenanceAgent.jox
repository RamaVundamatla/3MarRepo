    <JadeMethod name="addInternalClasses" id="a7489084-5371-4f05-9cc9-e32eefad44de">
        <source>addInternalClasses(_registry: CM_ExportImportClassDict io);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 January 2026	naviv1	Initial creation  MTN 36787 - JADE Core Framework - Export Import Class Registry Maintenance Engine

*/

begin
		 self.registerClass(_registry,
			CM_CommodityGroup.name,
			ExportImportInternal,
			"Commodity Group",
			CM_CommodityGroup::code.name,
			"loadCommodityGroup",
			false
		);
		
		self.registerClass(_registry,
        CM_YardInterchangeArea.name,
        ExportImportInternal,
        "Yard Interchange Area Definition",
        CM_YardInterchangeArea::id.name,
        "loadYardInterchangeArea",
        false
    );
		
		self.registerClass(_registry,
			CM_Debtor.name,
			ExportImportInternal,
			"Debtor",
			CM_Debtor::name.name,
			"",
			false
		);
	
		// Terminal
		self.registerClass(_registry,
			CM_Terminal.name,
			ExportImportInternal,
			"Terminal",
			CM_Terminal::code.name,
			"",
			false
		);
		
		// Terminal Area
		self.registerClass(_registry,
			CM_TerminalArea.name,
			ExportImportInternal,
			"Terminal Area",
			CM_TerminalArea::id.name,
			"",
			false
		);
		 
		// Terminal Area Master
		self.registerClass(_registry,
			CM_TerminalAreaMaster.name,
			ExportImportInternal,
			"Terminal Area Master",
			CM_TerminalAreaMaster::id.name,
			"",
			false
		);
		
		// Terminal Area Type
		self.registerClass(_registry,
			CM_TerminalAreaType.name,
			ExportImportInternal,
			"Terminal Area Type",
			CM_TerminalAreaType::type.name,
			"",
			false
		);
		
		// Interchange Area
		self.registerClass(_registry,
			CM_InterchangeArea.name,
			ExportImportInternal,
			"Interchange Area",
			CM_InterchangeArea::id.name,
			"",
			false
		);
		
		// Terminal Area View Position
		self.registerClass(_registry,
			CM_TerminalAreaViewPosition.name,
			ExportImportInternal,
			"Terminal Area View Position",
			"",
			"",
			false
		);
		
		// Terminal Area Product Min Max
		self.registerClass(_registry,
			CM_TerminalAreaProductMinMax.name,
			ExportImportInternal,
			"Max Values Applied To Terminal Area",
			"",
			"",
			false
		);
		
		// Grid Row
		self.registerClass(_registry,
			CM_GridArea.name,
			ExportImportInternal,
			"Grid Area",
			"",
			"",
			false
		);
		
		// Grid Row
		self.registerClass(_registry,
			CM_GridRow.name,
			ExportImportInternal,
			"Grid Row",
			"",
			"",
			false
		);
		
		// Grid Column
		self.registerClass(_registry,
			CM_GridColumn.name,
			ExportImportInternal,
			"Grid Column",
			"",
			"",
			false
		);
		
		self.registerClass(_registry,
			CM_DataAccessController.name,
			ExportImportInternal,
			"Data Access Controller",
			CM_DataAccessController::name.name,
			"",
			false
		);
		
		self.registerClass(_registry,
			CM_GriddedTAStackHeight.name,
			ExportImportInternal,
			"Gridded TA Stack Height",
			CM_GriddedTAStackHeight::name.name,
			"",
			false
		);
		
		self.registerClass(_registry,
			CM_YACriteria.name,
			ExportImportInternal,
			"YA Criteria",
			CM_YACriteria::code.name,
			"",
			false
		);
		
		self.registerClass(_registry,
			CM_YACriteriaPriority.name,
			ExportImportInternal,
			"YA Criteria Priority",
			CM_YACriteriaPriority::code.name,
			"",
			false
		);
		
		self.registerClass(_registry,
			CM_YACriteriaType.name,
			ExportImportInternal,
			"YA Criteria Type",
			CM_YACriteriaType::type.name,
			"",
			false
		);
		
		self.registerClass(_registry,
			CM_YADataObjects.name,
			ExportImportInternal,
			"YA Data Objects",
			"",
			"",
			false
		);
		
		self.registerClass(_registry,
			CM_ObjectSet.name,
			ExportImportInternal,
			"Object Set",
			"",
			"",
			false
		);
		
	end;</source>
        <Parameter name="_registry" type="CM_ExportImportClassDict" usage="io"/>
    </JadeMethod>
    <JadeMethod name="addSystemAdminClasses" id="e64c729e-9a4e-4d52-a562-0af3fcf64c79">
        <source>addSystemAdminClasses(_registry: CM_ExportImportClassDict io);
/*

Purpose:			
 * Registers all system-wide administrative classes
 * These apply to all terminals in the system
Parameters:			

Return Value:		

Date		Who		Reason
06 January 2026	naviv1	Initial creation  MTN 36787 - JADE Core Framework - Export Import Class Registry Maintenance Engine

*/

begin
    self.registerClass(_registry,
        CM_Commodity.name,
        ExportImportSystemAdmin,
        "Commodity",
        CM_Commodity::code.name,
        "loadCommodity",
        true
    );
    
   /* self.registerClass(_registry,
        CM_CommodityGroup.name,
        ExportImportSystemAdmin,
        "Commodity Group",
        CM_CommodityGroup::code.name,
        "loadCommodityGroup",
        true
    );*/
	
	 self.registerClass(_registry,
        CM_Carrier.name,
       ExportImportSystemAdmin,
        "Carrier",
        CM_Carrier::code.name,
        "loadCarrier",
        true
    );
	
	/*self.registerClass(_registry,
        CM_EventType.name,
        ExportImportSystemAdmin,
        "Event Type",
        CM_Carrier::code.name,
        "loadEventType",
        true
    );*/
    
    // Add more system-admin classes here...
end;</source>
        <Parameter name="_registry" type="CM_ExportImportClassDict" usage="io"/>
    </JadeMethod>
