    <JadeMethod name="valGateEntities" id="fe098a03-5ec2-4e67-b40b-4e6b50bc8bcd">
        <source>valGateEntities(_vvr : CM_VehicleVisitRecord input; _pxyGTEArray : CMGTE_EntityArray input; pxyTIs : CM_ObjectByStringDict io;_passport : CM_Passport input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 May 2025	jlier1	Initial creation MTN-34221

*/

vars
	gte,pxyGTE :  	CMGTE_Entity;
	gtes : CMGTE_EntitySet;
begin
	self.raiseExceptionIfNull(_pxyGTEArray, 'Gate Entity Proxy Array');
	self.raiseExceptionIfNull(_vvr, 'Gate Entity Proxy');
	self.raiseExceptionIfNull(pxyTIs, 'TIs Proxy');
	
	create gtes transient;
	foreach pxyGTE in _pxyGTEArray do
		gtes.add(pxyGTE);
		pxyGTE.validateMe(_passport,pxyTIs);
	
		if app.myPassport.hasErrorsIgnored then
			return;
		endif;
	endforeach;
	
	if app.myPassport.hasErrorsIgnored then
		return;
	endif;
	
	foreach gte in _vvr.allGateEntities discreteLock do
		pxyGTE:= gte.pxyGetProxyObject;
		if pxyGTE = null or not _pxyGTEArray.includes(pxyGTE) then
			gtes.add(gte);
		endif;
	endforeach;
	
	// jlgka1 TFS 41708 --&gt;
	if _passport.myTerminal.getConfig(UseTotReqAllowedFld).Boolean then
		_vvr.validateReserveTI(gtes);
	endif;
	
	if app.myPassport.hasErrorsIgnored then
		return;
	endif;
	
	_vvr.validateForFlexiDuplicates(gtes);
	
	if app.myPassport.hasErrorsIgnored then
		return;
	endif;
	
epilog
	delete gtes;	
end;</source>
        <Parameter name="_vvr" type="CM_VehicleVisitRecord" usage="input"/>
        <Parameter name="_pxyGTEArray" type="CMGTE_EntityArray" usage="input"/>
        <Parameter name="pxyTIs" type="CM_ObjectByStringDict" usage="io"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="valGateEntity" id="9995de9c-4efc-4f0d-b444-cf7857a9a7c5">
        <source>valGateEntity(_vvr : CM_VehicleVisitRecord input; _pxyGateEntity : CMGTE_Entity input; pxyTIs : CM_ObjectByStringDict io; _passport : CM_Passport input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 May 2025	jlier1	Initial creation MTN-34221

*/

vars
	gte,pxyGTE :  	CMGTE_Entity;
	gtes : CMGTE_EntitySet;
begin
	self.raiseExceptionIfNull(_pxyGateEntity, 'Gate Entity Proxy');
	self.raiseExceptionIfNull(_vvr, 'Gate Entity Proxy');
	self.raiseExceptionIfNull(pxyTIs, 'TIs Proxy');
		
	_pxyGateEntity.validateMe(_passport,pxyTIs);
		
	if app.myPassport.hasErrorsIgnored then
		return;
	endif;
	
	// jlgka1 TFS 41708 --&gt;
	create gtes transient;
	gtes.add(_pxyGateEntity);
	foreach gte in _vvr.allGateEntities discreteLock do
		pxyGTE:= gte.pxyGetProxyObject;
		if pxyGTE = null or pxyGTE &lt;&gt; _pxyGateEntity then
			gtes.add(gte);
		endif;
	endforeach;
	
	if _vvr.myTerminal.getConfig(UseTotReqAllowedFld).Boolean then
		
		_vvr.validateReserveTI(gtes);
	endif;
	
	if app.myPassport.hasErrorsIgnored then
		return;
	endif;
	
	_vvr.validateForFlexiDuplicates(gtes);
	
	if app.myPassport.hasErrorsIgnored then
		return;
	endif;
	
	
epilog

	delete gtes;

end;</source>
        <Parameter name="_vvr" type="CM_VehicleVisitRecord" usage="input"/>
        <Parameter name="_pxyGateEntity" type="CMGTE_Entity" usage="input"/>
        <Parameter name="pxyTIs" type="CM_ObjectByStringDict" usage="io"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
