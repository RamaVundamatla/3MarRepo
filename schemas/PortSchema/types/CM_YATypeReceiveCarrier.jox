    <JadeMethod name="getAllCriteriaValues" id="5ef58871-3458-4c23-8026-e62676735a20">
        <source>getAllCriteriaValues(_terminalObj: CM_Terminal; _allCriteriaValues: ObjectSet input; _filter: Integer; _allDependentObjs: CM_ObjectArray);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 Apr 2024 navlc30 Bug 56071: PEN- VVR Package not sent

*/

vars

begin
	if _filter = YAFilterOpt_Rail then
		app.myRoot.allCarriersRail.copy(_allCriteriaValues);
	else
		app.myRoot.allCarriers.copy(_allCriteriaValues);
	endif;
epilog

end;</source>
        <Parameter name="_terminalObj" type="CM_Terminal"/>
        <Parameter name="_allCriteriaValues" type="ObjectSet" usage="input"/>
        <Parameter name="_filter" type="Integer"/>
        <Parameter name="_allDependentObjs" type="CM_ObjectArray"/>
    </JadeMethod>
