    <JadeMethod name="doNotableAdd" id="964a4896-620f-48b7-9a6b-840c326c8915">
        <source>doNotableAdd(_ti : CM_TrackedItem);
// ---------------------------------------------------------------------------
// Created:     June 2009 - form cloned from YRD_RailOpsForm and YRD_GridAreasForm
//
// Purpose:     
//
// Parameters:  
//
// Returns:     
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	if _ti = null then
		return;
	endif;
	
	if (not global.isValidObject(_ti)) then
		return;
	endif;
	
	if (not self.allNotableTIs.includes(_ti)) then
		self.allNotableTIs.add(_ti);
		beginNotification(_ti, Object_Update_Event, Response_Continuous, null);
	endif;
	
end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="doNotableClear" id="4d977cd8-261b-4223-93df-49948babb0b1">
        <source>doNotableClear();
// ---------------------------------------------------------------------------
// Created:     June 2009 - form cloned from YRD_RailOpsForm and YRD_GridAreasForm
//
// Purpose:     
//
// Parameters:  
//
// Returns:     
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	ti : CM_TrackedItem;
begin
	foreach ti in self.allNotableTIs do
		endNotification(ti, Object_Update_Event);
	endforeach;

	self.allNotableTIs.clear;
end;</source>
    </JadeMethod>
    <JadeMethod name="doNotableRemove" id="2425afdc-b405-4701-9004-b8858a4aa01d">
        <source>doNotableRemove(_ti : CM_TrackedItem);
// ---------------------------------------------------------------------------
// Created:     June 2009 - form cloned from YRD_RailOpsForm and YRD_GridAreasForm
//
// Purpose:     
//
// Parameters:  
//
// Returns:     
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	if _ti = null then
		return;
	endif;
	if (not global.isValidObject(_ti)) then
		return;
	endif;
	if  self.allNotableTIs.includes(_ti) then
