<Class name="WS_RestCargoOIDObject" id="eb9157d7-735d-47cc-b8c8-0b966c539c46">
    <superclass name="WS_RestCargoObject"/>
    <transient/>
    <sharedTransientAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
