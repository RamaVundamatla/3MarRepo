<Class name="FindJadeEntityLiterals" id="6c45a866-e2be-4008-aab6-701e11d94643">
    <superclass name="LocalisationSupportAgents"/>
    <transient/>
    <subclassTransientAllowed/>
    <subschemaFinal/>
    <transientAllowed/>
    <text>JadeEntities referenced by literals using

sendMsg
sendMsgWithParams
getPropertyValue
setPropertyValue</text>
    <DbClassMap file="dev"/>
    <JadeMethod name="go" id="e64074af-ac6b-477c-97cc-0022fe9af68c">
        <source>go();

vars
	meth		: Method;
	methods 	: MethodSet;
	refs		: MethodSet;
	allRefs		: FeatureSet;
	ref			: Feature;
	visited 	: FeatureSet;
	startSchema	: Schema;
	lsSchema	: LSschema;
	appSchemas	: SchemaColl;
begin
	startSchema	:= rootSchema.getSchema(PortSchemaName);
	fillSchemas;
	
	create methods transient;
	methods.add(Object::sendMsg);
	methods.add(Object::sendMsgWithParams);
	methods.add(Object::getPropertyValue);
	methods.add(Object::setPropertyValue);
	
	create refs transient;
	create allRefs transient;
	create visited transient;
	
	create appSchemas transient;
	foreach lsSchema in allSchemas do
		appSchemas.add(lsSchema.mySchema);
	endforeach;
	
	foreach meth in methods do
		refs.clear;
		meth.getMethodRefs(refs);

		foreach ref in refs where 
			appSchemas.includes(ref.getSchema) and	// only interested in application schemas
			not allRefs.includes(ref)				// skip duplicates
		do
			allRefs.add(ref);
		endforeach;
	endforeach;
	
	allRefs.inspectModal;
	
epilog
	delete refs;
	delete allRefs;
	delete methods;
	delete visited;
	delete appSchemas;
end;
</source>
    </JadeMethod>
</Class>
