    <JadeMethod name="drawLetter" id="3e79c206-397d-4fb5-97ea-4a35380f98c3">
        <updating/>
        <source>drawLetter(_theFrame: CMUI_GridAreaFrame input; _theLetter : String; _theX : Integer; _theY : Integer; _theColour : Integer;
				_theX1: Real; _theY1: Real; _theX2: Real; _theY2: Real;_theFill : Integer;_mode : Integer;_tiIndex : Integer) updating;
// ---------------------------------------------------------------------------
// Created:		November 2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	is40 : Boolean;
	xOffset, yOffset,yOffsetFnt,xOffsetFnt,xWidth : Integer;
	theLetter : String;
begin
	_theFrame.drawFillColor := _theFill;
	_theFrame.drawFilledRectangle(_theX1, _theY1, _theX2, _theY2,  _theFill);
	_theFrame.drawTextAt(_theLetter, _theX, _theY, _theColour);

end;</source>
