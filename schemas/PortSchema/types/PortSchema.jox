	elseif _type = JobTypePriority_LoadDLR20 then
		return "Load DLR 20";
	elseif _type = JobTypePriority_LoadDLR40 then
		return "Load DLR 40";
	elseif _type = JobTypePriority_LoadExport20 then
		return "Load Export 20";
	elseif _type = JobTypePriority_LoadExport40 then
