    <JadeMethod name="getCalculatedDate" id="aeeaec4c-f745-45c5-b288-1900b5e29b83">
        <source>getCalculatedDate(): Date;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 Oct 2025	navah1	Initial creation
06 Oct 2025	navah1	MTN-36161: NSWP | Implement Date String Parsing and Conversion Logic
*/

vars 
	filterReport		: CMQF_FilterReports;
	runDate,
	paramDate			: Date;
begin
	create filterReport transient; 
	runDate := self.systemToLocalTime(app.actualTimeServer()).Date; 
	paramDate := filterReport.getParameterDate(self.getTemplateDate, self.paramName, runDate);
	return paramDate.asStringJMT.asDateJMT();
epilog
	delete filterReport;
end;</source>
        <ReturnType type="Date"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="f636333c-9a60-43dd-bdd0-9baf8bc67ff7">
        <source>getDisplayStringForAttribute(_attrName : String; _getCalculatedDate : Boolean) : String;
// ---------------------------------------------------------------------------
// Created:     20 August 2003	cnwth2
//
// Purpose:     
//	03/10/2018 TFS40544 		CIG - Problems with Reports 
//	06 Oct 2025	navah1			MTN-36161: NSWP | Implement Date String Parsing and Conversion Logic
// ----------   ----------  --------------------------------------------------
vars
	
begin
	if _attrName = ETRow_DisplayName then
		return self.displayName;
	elseif _attrName = ETRow_DefaultValDate then
		//return self.getParamValue.Date.shortFormatJMT();			//-TFS40544
		//return self.getParamValue.asStringJMT;					//+TFS40544 
		return self.getTemplateDate();								//06.10.2025 navah1 #36161
	elseif _attrName = ETRow_DefaultValTime then
		return self.getParamValue.Time.shortFormatJMT();
	elseif _attrName = ETRow_DefaultValue or
	   _attrName = ETRow_DefaultValBinary or
	   _attrName = ETRow_DefaultValBoolean or
	   _attrName = ETRow_DefaultValChar or
	   _attrName = ETRow_DefaultValDecimal or
	   _attrName = ETRow_DefaultValInteger or
	   _attrName = ETRow_DefaultValString or
	   _attrName = ETRow_DefaultValRef or
	   _attrName = ETRow_DefaultValData then
		return self.getParamValue.String;

	elseif _attrName = ETRow_IsVisible then
		return self.isVisible.cnEcGetTableCheckBoxValue;

	elseif _attrName = ETRow_ParamName then
		return self.paramName;

	elseif _attrName = ETRow_ParamType then
		return self.getTypeDescription();
	endif;
		
	return inheritMethod(_attrName, _getCalculatedDate);


end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_getCalculatedDate" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getParamValue" id="2fcff012-7ee8-4cfe-a763-1b470e38f29c">
        <source>getParamValue() : Any;
// ---------------------------------------------------------------------------
// Created:     26 August 2003	cnwth2
//
// Purpose:     
//// 03/10/2018		jlgrh7 TFS #40544	CIG - Problems with Reports
//// 06 Oct 2025	navah1	MTN-36161: NSWP | Implement Date String Parsing and Conversion Logic	
// ----------   ----------  --------------------------------------------------
vars

begin
	if self.type = Binary.number then
		return self.defaultValueBinary;
	
	elseif self.type = Boolean.number then
		return self.defaultValueBoolean;
	
	elseif self.type = Character.number then
		return self.defaultValueChar;
	
	elseif self.type = Date.number then
		//return self.defaultValueDate.shortFormatJMT();					//-TFS40544
		//return self.defaultValueDate.asStringJMT.asDateJMT();				//+TFS40544
		return self.getCalculatedDate();									//06.10.2025 navah1 #36161
		
	elseif self.type = Decimal.number then
		return self.defaultValueDecimal;
		
	elseif self.type = Integer.number then
		return self.defaultValueInteger;
		
	elseif self.type = String.number then
		return self.defaultValueString;
		
	elseif self.type = Time.number then
		return self.defaultValueTime.shortFormatJMT();
	endif;

end;</source>
        <ReturnType type="Any"/>
    </JadeMethod>
    <JadeMethod name="getTemplateDate" id="1dcda775-03d3-4076-9f57-827f9507de20">
        <source>getTemplateDate(): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 Oct 2025	navah1	Initial creation
06 Oct 2025	navah1	MTN-36161: NSWP | Implement Date String Parsing and Conversion Logic
30 Oct 2025 navah1  MTN-36162: NSWP | Handle Existing Date Parameters Stored and Ensure Legacy Report Support	 
*/

vars
	paramDate : Date;
begin
	if self.defaultValueDate &lt;&gt; null and self.defaultValueDate.isValid() then //30.10.2025 navah1 #36162
		return self.defaultValueDate.asStringJMT();
	endif;
	paramDate := self.defaultValueString.asDate();
	if paramDate.isValid() then
		return paramDate.asStringJMT();
	endif;
	return self.defaultValueString; 
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getTypeDescription" id="97740380-d83a-4a4c-a87f-3469ddcee2b4">
        <source>getTypeDescription() : String;
// ---------------------------------------------------------------------------
// Created:     20 August 2003	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars

begin

	if self.type = Binary.number then
		return Binary.name;
	elseif self.type = Boolean.number then
		return Boolean.name;
	elseif self.type = Character.number then
		return Character.name;
	elseif self.type = Date.number then
		return Date.name;
	elseif self.type = Decimal.number then
		return Decimal.name;
	elseif self.type = Integer.number then
		return Integer.name;
	elseif self.type = String.number then
		return String.name;
	elseif self.type = Time.number then
		return Time.name;
	elseif self.type = TimeStamp.number then
		return TimeStamp.name;
	else
		return null;
	endif;


end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getViewNameForType" id="f86bbb7f-01ab-4ac3-8d09-dd19e586d99f">
        <source>getViewNameForType(_type : Integer): String;
// ---------------------------------------------------------------------------
// Created:     20 August 2003	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars

begin
	if _type = Binary.number then
		return 'binaryView';
	elseif _type = Boolean.number then
		return 'booleanView';
	elseif _type = Character.number then
		return 'charView';
	elseif _type = Date.number then
		return 'dateView';
	elseif _type = Decimal.number then
		return 'decimalView';
	elseif _type = Integer.number then
		return 'integerView';
	elseif _type = String.number then
		return 'stringView';
	elseif _type = Time.number then
		return 'timeView';
	elseif _type = TimeStamp.number then
		return 'timeStampView';
	elseif _type = Reference.number then
		return 'referenceView';
	else
		return 'default';
	endif;

end;</source>
        <Parameter name="_type" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="initCellForType" id="d7cb1414-949c-4b72-8c01-01e0cc124342">
        <source>initCellForType(_jCell : JadeTableCell input);
// ---------------------------------------------------------------------------
// Created:     25 August 2003	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars

begin
	if _jCell = null then
		return;
	endif;
	
	if self.type = Character.number then
		_jCell.maxLength := 1;
				
	elseif self.type = Decimal.number then
		_jCell.maxLength := 12;
		_jCell.decimals := 3;		
	
	elseif self.type = Integer.number then
		_jCell.maxLength := 9;
		_jCell.decimals := 0;		
		
	elseif self.type = String.number then
		_jCell.maxLength := 30;
	endif;

end;</source>
        <Parameter name="_jCell" type="JadeTableCell" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setDefaultValue" id="7a098990-eb1b-4d81-a46d-575819119956">
        <updating/>
        <source>setDefaultValue(_value : Any) updating;
// ---------------------------------------------------------------------------
// Created:     26 August 2003	cnwth2
//
// Purpose:     
// 18/12/2015  	cnwma1		PAR #36940 	Report Parameter Type
// 14/02/2019	jlgzm1		TFS 42465	RIA/Webapp report issues from date format
// 06 Oct 2025	navah1		MTN-36161: NSWP | Implement Date String Parsing and Conversion Logic
// 29 Oct 2025  navah1 		MTN-36162: NSWP | Handle Existing Date Parameters Stored and Ensure Legacy Report Support	 
// ----------   ----------  --------------------------------------------------
vars
	tmpString : String;
begin
	
	if self.type = Binary.number then
		self.defaultValueBinary := _value.Binary;
	
	elseif self.type = Boolean.number then
		self.defaultValueBoolean := _value.Boolean;
	
	elseif self.type = Character.number then
		self.defaultValueChar := _value.Character;
	
	elseif self.type = Date.number then
		tmpString := _value.asStringJMT;
		if app.isWebApp then
			//self.defaultValueDate := tmpString.asDateFromWebInterface(); //tfs42465 //06.10.2025 navah1 #36161
			tmpString := tmpString.asDateFromWebInterface().asStringJMT();			  //06.10.2025 navah1 #36161
		else
			//self.defaultValueDate := tmpString.asDateJMT();  						  //06.10.2025 navah1 #36161
			tmpString := tmpString.asStringJMT();									  //06.10.2025 navah1 #36161
		endif;
		self.defaultValueString := tmpString;										  //06.10.2025 navah1 #36161
		// Date Validation
		self.getCalculatedDate();													  //06.10.2025 navah1 #36161  
		self.defaultValueDate := null;												  //30.10.2025 navah1 #36162 
		
	elseif self.type = Decimal.number then
		self.defaultValueDecimal := _value.Decimal;
		
	elseif self.type = Integer.number then
		self.defaultValueInteger := _value.Integer;
		
	elseif self.type = String.number then
		self.defaultValueString := _value.String;
		
	elseif self.type = Time.number then
		self.defaultValueTime := _value.Time;
	
	endif;

end;</source>
        <Parameter name="_value" type="Any"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="c4652dc9-3d1d-4f6d-a18a-b5fed0a891e9">
        <updating/>
        <source>setForCreate(_pxyQryParam : CM_QueryReportParam) updating;
// ---------------------------------------------------------------------------
// Created:     20 August 2003	cnwth2
//
// Purpose:     There is only setForCreate - no update. When editing a user report all existing params
//				are purged and new ones created.
//			 
// ----------   ----------  --------------------------------------------------
vars

begin
	self.paramName 					:= _pxyQryParam.paramName;
	self.displayName 				:= _pxyQryParam.displayName;
	self.isVisible 					:= _pxyQryParam.isVisible;
	self.type						:= _pxyQryParam.type;
	
	self.defaultValueBinary			:= _pxyQryParam.defaultValueBinary;	
	self.defaultValueBoolean		:= _pxyQryParam.defaultValueBoolean;	
	self.defaultValueChar			:= _pxyQryParam.defaultValueChar;	
	self.defaultValueDate			:= _pxyQryParam.defaultValueDate;	
	self.defaultValueDecimal		:= _pxyQryParam.defaultValueDecimal;	
	self.defaultValueInteger		:= _pxyQryParam.defaultValueInteger;	
	self.defaultValueString			:= _pxyQryParam.defaultValueString;	
	self.defaultValueTime			:= _pxyQryParam.defaultValueTime;	
	 
end;</source>
        <Parameter name="_pxyQryParam" type="CM_QueryReportParam"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="cd9c887f-97cd-49c8-b715-f33fe3c669f5">
        <updating/>
        <source>setProxy(_paramName,
			_displayName : String;
			_isVisible : Boolean;
			_type : Integer;
			_defaultValue : Any) updating;
// ---------------------------------------------------------------------------
// Created:     20 August 2003	cnwth2
//
// Purpose:     
// 06 Oct 2025	navah1	MTN-36161: NSWP | Implement Date String Parsing and Conversion Logic
// 30 Oct 2025  navah1  MTN-36162: NSWP | Handle Existing Date Parameters Stored and Ensure Legacy Report Support	 			 
// ----------   ----------  --------------------------------------------------
vars

begin
	self.paramName		:= _paramName;
	self.displayName 	:= _displayName;
	self.isVisible		:= _isVisible;
	self.type 			:= _type;

	if _type = Binary.number then
		self.defaultValueBinary := _defaultValue.Binary;
	
	elseif _type = Boolean.number then
		self.defaultValueBoolean := _defaultValue.Boolean;
	
	elseif _type = Character.number then
		self.defaultValueChar := _defaultValue.Character;
	
	elseif _type = Date.number then
		//self.defaultValueDate := _defaultValue.Date;		//06.10.2025 navah1 #36161
		self.defaultValueString := _defaultValue.String;	//06.10.2025 navah1 #36161
		// Date Validation
		self.getCalculatedDate();							//06.10.2025 navah1 #36161
		self.defaultValueDate := null;						//30.10.2025 navah1 #36162
		
	elseif _type = Decimal.number then
		self.defaultValueDecimal := _defaultValue.Decimal;
	
	elseif _type = Integer.number then
		self.defaultValueInteger := _defaultValue.Integer;
	
	elseif _type = String.number then
		self.defaultValueString := _defaultValue.String;
	
	elseif _type = Time.number then
		self.defaultValueTime := _defaultValue.Time;
	
	endif;
	
end;</source>
        <Parameter name="_paramName" type="String"/>
        <Parameter name="_displayName" type="String"/>
        <Parameter name="_isVisible" type="Boolean"/>
        <Parameter name="_type" type="Integer"/>
        <Parameter name="_defaultValue" type="Any"/>
    </JadeMethod>
    <JadeMethod name="validateMe" id="713cb69a-00d4-4db1-971f-a4a7ea8e9c6e">
        <source>validateMe();
// ---------------------------------------------------------------------------
// Created:     20 August 2003	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars

begin
	if (not self.isTransient) then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Proxy object ' &amp; self.String &amp; ' was not transient');
	endif;
		
	if self.paramName = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Param Name', ETRow_ParamName, null); 
		app.raiseCMException(Input_required_field_paramName, ETRow_ParamName, null); // cnwdb2	PAR 35364
	endif;

	if self.displayName = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Display Name', ETRow_DisplayName, null);
		app.raiseCMException(Input_required_field_dispName, ETRow_DisplayName, null); // cnwdb2	PAR 35364
	endif;

	if self.type = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Param Type', ETRow_ParamType, null);
		app.raiseCMException(Input_required_field_paramType, ETRow_ParamType, null); // cnwdb2	PAR 35364
	endif;


end;</source>
    </JadeMethod>
</Class>
