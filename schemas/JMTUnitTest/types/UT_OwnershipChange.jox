    <JadeMethod name="verifyOwnershipChange" id="82cb5854-d16f-4752-b920-ae1c43e86dff">
        <source>verifyOwnershipChange(_pxyOwnershipChange,_realOwnershipChange : CM_OwnershipChange);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 August 2023	navmv20	CR 59440 Task 59441: Jade - Ownership Change Release Request Validation

*/

vars

begin
	self.assertEqual(_realOwnershipChange.refNumber,_pxyOwnershipChange.refNumber);
	self.assertEqual(_realOwnershipChange.userCodeApproved,app.getMyUserCode());
	self.assertEqual(_realOwnershipChange.condition,_pxyOwnershipChange.condition);
	self.assertEqual(_realOwnershipChange.userCode,app.getMyUserCode());
	self.assertEqual(_realOwnershipChange.dateTimeCOO,_pxyOwnershipChange.dateTimeCOO);
	self.assertEqual(_realOwnershipChange.dateTimeApproved,_pxyOwnershipChange.dateTimeApproved);
	self.assertEqual(_realOwnershipChange.storageExpiryOperatorNew,_pxyOwnershipChange.storageExpiryOperatorNew);
	self.assertEqual(_realOwnershipChange.freeDaysAdditional,_pxyOwnershipChange.freeDaysAdditional);
	self.assertEqual(_realOwnershipChange.freeDaysOperatorNew,_pxyOwnershipChange.freeDaysOperatorNew);
	self.assertEqual(_realOwnershipChange.freeDaysOperatorOld,_pxyOwnershipChange.freeDaysOperatorOld);
	self.assertEqual(_realOwnershipChange.transferredQuantity,_pxyOwnershipChange.transferredQuantity);
	self.assertEqual(_realOwnershipChange.transferredWeight,_pxyOwnershipChange.transferredWeight);
	self.assertEqual(_realOwnershipChange.transferredVolume,_pxyOwnershipChange.transferredVolume);
	self.assertEqual(_realOwnershipChange.remarks,_pxyOwnershipChange.remarks);
	self.assertEqual(_realOwnershipChange.myFreightForwarder,_pxyOwnershipChange.myFreightForwarder);
	self.assertEqual(_realOwnershipChange.myIncoterm,_pxyOwnershipChange.myIncoterm);
	self.assertEqual(_realOwnershipChange.myOperatorNew,_pxyOwnershipChange.myOperatorNew);
	self.assertEqual(_realOwnershipChange.myOperatorOld,_pxyOwnershipChange.myOperatorOld);
	self.assertEqual(_realOwnershipChange.myOperatorOrig,_pxyOwnershipChange.myOperatorOrig);
	self.assertEqual(_realOwnershipChange.myOperatorStorage,_pxyOwnershipChange.myOperatorStorage);
	self.assertEqual(_realOwnershipChange.myOwnershipChangePrevious,null);
	self.assertEqual(_realOwnershipChange.myTerminal,_pxyOwnershipChange.myTerminal);
epilog

end;</source>
        <Parameter name="_pxyOwnershipChange" type="CM_OwnershipChange"/>
        <Parameter name="_realOwnershipChange" type="CM_OwnershipChange"/>
    </JadeMethod>
    <JadeMethod name="verifyOwnershipChangeDtls" id="e6e634ae-9280-4a92-909d-2c0e04285327">
        <source>verifyOwnershipChangeDtls(_detailsSet : ObjectArray ; _realOwnershipChange : CM_OwnershipChange);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 August 2023	navmv20	CR 59440 Task 59441: Jade - Ownership Change Release Request Validation
*/

vars
	ownershipChangeDetail : CM_OwnershipChangeDetail;
	idx : Integer;
begin
	foreach ownershipChangeDetail in _realOwnershipChange.allDetails do
	idx := idx + 1;
	self.assertEqual(ownershipChangeDetail.transferredQuantity,_detailsSet[idx].CM_OwnershipChangeDetail.transferredQuantity);
	self.assertEqual(ownershipChangeDetail.transferredWeight,_detailsSet[idx].CM_OwnershipChangeDetail.transferredWeight);
	self.assertEqual(ownershipChangeDetail.transferredVolume,_detailsSet[idx].CM_OwnershipChangeDetail.transferredVolume);
	self.assertEqual(ownershipChangeDetail.included,_detailsSet[idx].CM_OwnershipChangeDetail.included);
	self.assertEqual(ownershipChangeDetail.myOwnershipChange,_realOwnershipChange);
	self.assertEqual(ownershipChangeDetail.myParentOwnershipChangeDetail,null);
	self.assertEqual(ownershipChangeDetail.myTrackedItem,_detailsSet[idx].CM_OwnershipChangeDetail.myTrackedItem);
	endforeach;
epilog

end;</source>
        <Parameter name="_detailsSet" type="ObjectArray"/>
        <Parameter name="_realOwnershipChange" type="CM_OwnershipChange"/>
    </JadeMethod>
</Class>
