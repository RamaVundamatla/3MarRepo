	&lt;totalWeight&gt;25840&lt;/totalWeight&gt;
	&lt;commodityDescription&gt;'&amp;Commodity3&amp;'&lt;/commodityDescription&gt;
	&lt;cargoTypeDescr&gt;CONT&lt;/cargoTypeDescr&gt;
	&lt;/BookingItem&gt;
	&lt;BookingItem&gt;
	&lt;id&gt;'&amp;BookingRefNo&amp;'&lt;/id&gt;
