<Class name="CM_EDIFileConfig" id="a76ed0c4-aba2-4cbb-a1eb-dbd8ba1fcc55">
    <superclass name="CM_Object"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>
This class holds config information used when loading an EDI file to the DB.

For User Defined EDI (CM_EDIFileTypeUser) there is a 1-1 relationship and this is
setup when the user is defining the file load.

For all other types this is determined by the operator and the file type 
(AT THIS STAGE NO GUI TO SETUP)</text>
    <DbClassMap file="edi"/>
    <ExplicitInverseRef name="allStateData" id="0b2226a0-762a-4473-819c-9fe0f6f2d2dc">
        <kind>parent</kind>
        <transientToPersistentAllowed/>
        <updateMode>automatic</updateMode>
        <type name="CM_StateDataDict"/>
        <access>readonly</access>
        <Inverse name="CM_StateData::myParent"/>
    </ExplicitInverseRef>
    <ExplicitInverseRef name="allWarningsToIgnore" id="0a17741e-9804-4655-83ad-8a5f0761d938">
        <type name="CM_WarningsToIgnoreByNo"/>
        <access>readonly</access>
        <Inverse name="CM_InterestedWarning::myEDIFileConfig"/>
    </ExplicitInverseRef>
    <ExplicitInverseRef name="myEDIFileType" id="403ddc7b-cde5-4457-ad1f-161b4f7f6dfa">
        <kind>child</kind>
        <updateMode>automatic</updateMode>
        <embedded/>
        <type name="CM_EDIFileType"/>
        <access>readonly</access>
        <text>
Need to inverse back to CM_EDIFileTypeUser::myEDIFileConfig

</text>
        <Inverse name="CM_EDIFileTypeUser::myEDIFileConfig"/>
    </ExplicitInverseRef>
    <JadeMethod name="delete" id="fbf4c48a-9867-45ed-9763-f3f64787a7f1">
        <updating/>
        <source>delete() updating;

vars

begin
	allStateData.purge;
end;
</source>
    </JadeMethod>
    <JadeMethod name="getConfig" id="eb5c210b-4c0d-4f6b-874d-a70c23d5289a">
        <updating/>
        <source>getConfig(_key : String) : Any updating;
/* ---------------------------------------------------------------------------
Created:     16 June 2008 by cnwrs2

Purpose:     
        
Change Date	Who		Reason

------------------------------------------------------------------------------*/
vars
	value	: Any;
begin
	global.getExtraData(self.allStateData, _key, value);
	
	return value;

epilog

end;</source>
        <Parameter name="_key" type="String"/>
        <ReturnType type="Any"/>
    </JadeMethod>
    <JadeMethod name="setConfig" id="d5858967-1d64-4928-b73a-3781b9bea019">
        <updating/>
        <source>setConfig(_key : String; _value : Any) updating;
/* ---------------------------------------------------------------------------
Created:     16 June 2008 by cnwrs2

Purpose:     
        
Change Date	Who		Reason

------------------------------------------------------------------------------*/
vars

begin
	global.setExtraData(self.allStateData, self, _key, _value);

epilog

end;</source>
        <Parameter name="_key" type="String"/>
        <Parameter name="_value" type="Any"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="9c465eb9-44e2-410a-8663-8120d4674929">
        <updating/>
        <source>setForUpdate(_pxyEDIFileConfig : CM_EDIFileConfig) updating;

vars
	stateData : CM_StateData;
	realInterestedWarn,
	pxyInterestedWarn		: CM_InterestedWarning;
begin
	foreach stateData in _pxyEDIFileConfig.allStateData do
		setConfig(stateData.key, stateData.getValue);
	endforeach;
	
	// cnwrd1 ccms 1660 8.8.2008 start
	//first figure out warnings that we may have been removed from
	foreach realInterestedWarn in self.allWarningsToIgnore do
		if _pxyEDIFileConfig.allWarningsToIgnore[realInterestedWarn.errorCode] = null then
			delete realInterestedWarn;
		endif;
	endforeach;
	//now add into any newly added (or existing - checks for already included)
	foreach pxyInterestedWarn in _pxyEDIFileConfig.allWarningsToIgnore do
		realInterestedWarn := self.allWarningsToIgnore[pxyInterestedWarn.errorCode];
		
		if realInterestedWarn = null then
			create realInterestedWarn persistent;
			realInterestedWarn.setForUpdate(pxyInterestedWarn);
			self.allWarningsToIgnore.add(realInterestedWarn);
		endif;
	endforeach;
	// cnwrd1 ccms 1660 8.8.2008 end
end;</source>
        <Parameter name="_pxyEDIFileConfig" type="CM_EDIFileConfig"/>
    </JadeMethod>
</Class>
