    <JadeMethod name="displayMessage" id="8762dae5-868e-4183-8eda-ea9821d24b52">
        <source>displayMessage(_messageToDisplay : CMIF_ITSInterfaceMsg);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
05 January 2010	#cnwdz2	 par21593

*/

vars
	str : String;
	backColour,
	idx : Integer;
begin
	str := _messageToDisplay.getAttributeStringForDefArray(self.tblData.allTblDataEntRows);
	idx := self.tblData.addItemObject(_messageToDisplay, str);
	if idx mod 2 = 0 then
		backColour := self.colorRow1;
	else
		backColour := self.colorRow2;
	endif;			
	self.tblData.accessRow(idx).backColor := backColour;
epilog

end;</source>
        <Parameter name="_messageToDisplay" type="CMIF_ITSInterfaceMsg"/>
    </JadeMethod>
    <JadeMethod name="doFilterMessages" id="e018adf9-79d0-4985-8525-e72485f505e8">
        <source>doFilterMessages();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
05 January 2010	#cnwdz2	 par21593

*/

vars
	startDate,
	endDate   		: Date;
	startTime,
	endTime			: Time;
	startTimeStamp,
	endTimeStamp	: TimeStamp;
	machine			: CM_Machine;
	iter 			: Iterator;
	message			: CM_ITSInterfaceMessage;
	messageToDisplay : CMIF_ITSInterfaceMsg;
	
	messageType 	: String;
	messageStatus 	: String;
	
	failedDAC  :CM_DataAccessController;
begin
	self.tblData.rows := self.tblData.fixedRows;
	self.allMessagesToDisplay.purge();
	
	startDate := self.tblSearch.getValueByName(ETRow_StartDate).Date;
	startTime := self.tblSearch.getValueByName(ETRow_StartTime).Time;
	startTimeStamp.setDate(startDate);
	startTimeStamp.setTime(startTime);
	
	endDate := self.tblSearch.getValueByName(ETRow_EndDate).Date;
	endTime := self.tblSearch.getValueByName(ETRow_EndTime).Time;
	endTimeStamp.setDate(endDate);
	endTimeStamp.setTime(endTime+60000);
	
	if endTimeStamp.isValid and startTimeStamp &gt; endTimeStamp then
		app.msgBox("End Date Time cannot be earlier than Start Date Time.",
						"Parameter invalid", MsgBox_OK_Only + MsgBox_Information_Icon);
		return;
	endif;
	
	if startTimeStamp.isValid then
		if self.cmbMachineFilter.listIndex &gt; 0 then
			machine := self.cmbMachineFilter.listObject.CM_Machine;
			if	machine &lt;&gt; null then
				iter := machine.allITSInterfaceMessages.createIterator();
				machine.allITSInterfaceMessages.startKeyGeq(startTimeStamp, iter);
			endif;
		else
			iter := self.myInterface.allMessages.createIterator();
			self.myInterface.allMessages.startKeyGeq(startTimeStamp,iter);
		endif;		
	endif;
	
	if	iter = null then
		iter := self.myInterface.allMessages.createIterator();
	endif;
	
	messageType := self.tblSearch.getValueByName(ETRow_MessageType).String;
	messageStatus := self.tblSearch.getValueByName(ETRow_SentReceived).String;

	while iter.next(message) do
		if endTimeStamp.isValid and message.createdTS &gt;= endTimeStamp then
			break;
		endif;
			
		if not message.canUserAccessSelf(app.getMyUser, failedDAC, app.myPassport) then
			continue;
		endif;
		
		if messageStatus &lt;&gt; null then
			if messageStatus = ITSMessageSent and not message.isKindOf(CM_ITSInterfaceResponse) then
				continue;
			endif;
			
			if messageStatus = ITSMessageReceived and not message.isKindOf(CM_ITSInterfaceRequest) then
				continue;
			endif;
		endif;
		
		create messageToDisplay transient;
		messageToDisplay.setMessage(message,false);
		self.allMessagesToDisplay.add(messageToDisplay);
		
		if messageType &lt;&gt; null and messageType &lt;&gt; messageToDisplay.messageType then
			continue;
		endif;

		self.displayMessage(messageToDisplay);
	endwhile;
epilog
	delete iter;
end;</source>
    </JadeMethod>
    <JadeMethod name="doResetSearch" id="9c6bd898-efa3-4ec5-9184-948b085cd6ed">
        <source>doResetSearch();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
29 December 2009	#cnwdz2	 par21593

*/

vars
	now : Date;
	nowTime : Time;
begin
	now := app.actualTimeServer().date();	// 16 Sept 2016	cnwns1	TFS 488 - Multi Timezone Support
	nowTime := app.actualTimeServer().time();	// 16 Sept 2016	cnwns1	TFS 488 - Multi Timezone Support
	self.tblSearch.clearValues();
	if self.myMachine &lt;&gt; null then
		self.cmbMachineFilter.text := self.myAssistant.displayEntryMachine(self.myMachine);
	endif;
	self.tblSearch.setValueByName(ETRow_StartDate, now);
	self.tblSearch.setValueByName(ETRow_StartTime, (nowTime-3600000));
	self.tblSearch.setValueByName(ETRow_EndDate, now);	
	self.tblSearch.setValueByName(ETRow_EndTime, nowTime);
epilog

end;</source>
    </JadeMethod>
