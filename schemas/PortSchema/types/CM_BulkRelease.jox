    <JadeMethod name="getDataForDefSpecial" id="991b74eb-68d6-441e-929a-16959ae1e73e">
        <source>getDataForDefSpecial(_attrName: String; _heading: String; _headings: StringArray input; _data: HugeStringArray input): Boolean protected;
// ---------------------------------------------------------------------------
// Created:     13 May 2002 by cnwth2
//
// Purpose:
//
// Changed On	Changed By	Reason
// ----------	----------	--------------------------------------------------
// 25/08/2010	cnwjo3		par 25538.  Removed ETRow_AllocatedItems
// 24/10/2012 	cnwmh5		Par 30539 - Check way TotalRequested got for Release by ID
// 26/06/14 	cnwer1		PAR 34406  - more bulk changes get display values for releasing cargo that is bulk by volume/weight
// 26/04/2018 	JLGNS1 		Bug 38191: STWR - Release Request - String Too Long
// 20/02/2019 	jlger1		TFS	41298 - For relase by id for bulk/bb showing all totals
// 16/06/2022	navdap1		TFS 53362 EUP Master Data interface customers between TOS and ERP
// 19/07/2022	navtnr20	ChangeRequest 53974: EUP - OUT - Additional Fields on Release Line Level		
// 16/12/2022   navsa20     Bug 55878: SNO - Error 4033 happens while trying to update a Release Request
// 06/12/2023	navcs2		ChangeRequest 57537: EUP | Release Request By Type - with Weight
// 03/12/2024	navdap1		MTN-33563 PIBT - UE 1081 On Performing a Bulk Gate Out
// 03/11/2025	jlizm1		MTN 36255 Rotabox Assign Release To Vessel
// ---------------------------------------------------------------------------     
vars
	aReserve 		: CM_ReserveDetail;
	ti 				: CM_TrackedItem;
	headingStr,
	tmpStr,
	tmpDisplay,
	relStr			: String;
	req				: CM_Request;
	tmpConsignee 	: CM_ConsigneeConsignor;
	tmpCarrier		: CM_Carrier;
	ao				: CM_AuditObject;
	cnt			: Integer;	
	relByTypeByWeight	: Boolean;
begin
	if _attrName = ETRow_ReleaseNo then
		_headings.add(_heading);
		_data.add(self.code);
		return true;

	elseif _attrName = ETRow_Attachments then
		_headings.add(''); _data.add('');	
		headingStr := _heading;
		foreach ti in self.allTrackedItemsAssigned do
			_headings.add(headingStr); _data.add(ti.id);		
			headingStr := null;
		endforeach;
		if headingStr &lt;&gt; null then
			// no tis so just add the heading
			_headings.add(headingStr); _data.add(tmpStr);			
		endif;
		return true;
			
	elseif _attrName = ETRow_Audit then
		_headings.add(''); _data.add('');	
		_headings.add(_heading &amp; ' Details'); _data.add('');
		foreach ao in self.allAuditObjectsForClass do	//21 Jan 2021	NDL	TFS 50251
			_headings.add(ao.typeCode &amp; ' By:'); 
			_data.add(ao.userCode &amp; ' on ' &amp; self.systemToLocalTime(ao.timestamp).date.display &amp; ' at ' &amp; self.systemToLocalTime(ao.timestamp).time.currentLocaleFormatJMT);	// 15/4/16 cnwmp6 TFS 488 - Multi timezone support
			headingStr := null;
		endforeach;	
		if headingStr &lt;&gt; null then
			// no audit details so just add the heading
			_headings.add(headingStr); _data.add(tmpStr);			
		endif;
		return true;
	
	elseif _attrName = ETRow_CompletedStatusDate then
		//Show the status date for completed BR's only (ie. Completetion date)
		if self.statusString = BR_COMPLETE_STRING then
			headingStr := _heading;
			_headings.add(headingStr); _data.add(self.statusDate.String);
		endif;
		return true;
										
	elseif _attrName = ETRow_RequestsBeingActioned then
		_headings.add(''); _data.add('');	 //cnwrd1 par 25900
		
		if self.type = BR_TYPE_PACKING then //cwnrd1 par 25900 22.11.2010
			cnt := self.getNumItemsBeingActionedIncom(); //cwnrd1 par 25900 22.11.2010
		else
			cnt := self.getNumItemsBeingActioned();
		endif;
		
		_headings.add(_heading); _data.add(cnt.String);	
		return true;
	// PAR 25980
	elseif _attrName = ETRow_ItemsBeingActioned then
		cnt := self.getNumItemsBeingActioned();
		if cnt &gt; 0 then
			headingStr :=_heading;
			foreach req in self.allRequestsBeingActioned do
				if self.type &lt;&gt; BR_TYPE_PACKING then //cwnrd1 par 25900 22.11.2010
					_headings.add(headingStr); 
				else
					_headings.add(''); 
				endif;
				if req.myJob &lt;&gt; null then
					_data.add(req.myJob.jobId &amp; ' ' &amp; req.getId() &amp; ' (' &amp; req.getTotalRequestedDisplay() &amp; ')'); //cnwer1 par 32330 29/8/13	
				else
					_data.add(req.getId() &amp; ' (' &amp; req.getTotalRequestedDisplay()  &amp; ')' ); //cwnrd1 par 25900 22.11.2010
				endif;
				headingStr := null;
			endforeach;	
			if headingStr &lt;&gt; null then
				// no released items so just add the heading
				_headings.add(headingStr); _data.add(tmpStr);			
			endif;
		endif;
		return true;
	
	elseif _attrName = ETRow_RequestsDelivered then //cnwrd1 par 25900 
		if self.type &lt;&gt; BR_TYPE_PACKING then
			return true;
		endif;
		
		headingStr := _heading;
		foreach relStr in self.releasedItemStrings do
			_headings.add(headingStr); _data.add(relStr);		
			headingStr := null;
		endforeach;
		if headingStr &lt;&gt; null then
			// no tis so just add the heading
			_headings.add(headingStr); _data.add(tmpStr);			
		endif;
		return true;		
		
	
	elseif _attrName = ETRow_RequestsOutstanding or _attrName = ETRow_QuantityRemaining then //cnwrd1 par 25900 
		if self.type = BR_TYPE_PACKING then
			return true;
		endif;
		
		_headings.add(_heading); 
		if self.releaseByType then		
			tmpStr := "";
			cnt    := 1;
			if self.allReserveDetails.size &gt; 1 and self.releaseByType then
				foreach aReserve in self.allReserveDetails discreteLock do
					tmpDisplay := aReserve.getTotalOutstandingDisplay;
					if tmpDisplay &lt;&gt; null then
						tmpStr := tmpStr &amp; tmpDisplay &amp; "[" &amp; cnt.String &amp; "], ";
					endif;
					cnt := cnt + 1;
				endforeach;
				tmpStr := tmpStr[1:tmpStr.length-2];
			else
				aReserve := self.allReserveDetails.first;
				if aReserve &lt;&gt; null then
					tmpStr := aReserve.getTotalOutstandingDisplay.asStringJMT;
				endif;
			endif;
			_data.addTruncated(tmpStr);	//Bug 38191
			
		else			
			_data.add( self.getTotalOutstandingDisplay);	
		endif;
			
		
		return true;		
	elseif _attrName = ETRow_DeliveredToDate then
	
		if self.type = BR_TYPE_PACKING then
			return true;
		endif;
		
		_headings.add(_heading); 
		if self.releaseByType then		
			tmpStr := "";
			cnt    := 1;
			if self.allReserveDetails.size &gt; 1 and self.releaseByType then
				foreach aReserve in self.allReserveDetails discreteLock do
					tmpDisplay := aReserve.getTotalReleasedDisplay;
					if tmpDisplay &lt;&gt; null then
						tmpStr := tmpStr &amp; tmpDisplay &amp; "[" &amp; cnt.String &amp; "], ";
					endif;
					cnt := cnt + 1;
				endforeach;
				tmpStr := tmpStr[1:tmpStr.length-2];
			else
				aReserve := self.allReserveDetails.first;
				if aReserve &lt;&gt; null then
					tmpStr := aReserve.getTotalReleasedDisplay.asStringJMT;
				endif;
			endif;
			_data.addTruncated(tmpStr);	//Bug 38191
			
		else
			_data.add( self.getTotalReleasedDisplay() );	
		endif;

		
		return true;
	// PAR 25980
	elseif _attrName = ETRow_ItemsDelivered then
		cnt := self.releasedItemStrings.size;
		headingStr := _heading;

		if self.type = BR_TYPE_PACKING then
			return true; //cnwrd1 par 25900 19.11.2010
		else
			if cnt &gt; 0  then
				foreach ti in self.allTrackedItemsReleased  discreteLock do
					relByTypeByWeight := false;																	// 6/12/2023 navcs2 ChangeRequest 57537
					// MTN-33563 try to avoid reading every reserve detail for every TI release
					// PIBT had a release with over 850 released TIs - which could have
					// resulted in over 700,000 reads just to get some display info.
					foreach aReserve in ti.allReserveDetailsReleased do
						if aReserve.myReserveHeader &lt;&gt; self then
							continue;
						endif;
						if aReserve.byTypeByWeight then
							relByTypeByWeight := true;
							break;
						endif;
					endforeach;
					/*foreach aReserve in self.allReserveDetails discreteLock do								// 6/12/2023 navcs2 ChangeRequest 57537
						if aReserve.allTrackedItemsReleased.includes(ti) and aReserve.byTypeByWeight then		// 6/12/2023 navcs2 ChangeRequest 57537
							relByTypeByWeight := true;															// 6/12/2023 navcs2 ChangeRequest 57537
							break;																				// 6/12/2023 navcs2 ChangeRequest 57537
						endif;																					// 6/12/2023 navcs2 ChangeRequest 57537
					endforeach;																					// 6/12/2023 navcs2 ChangeRequest 57537*/
					_headings.add(headingStr); 
					if ti.isBulkByQuantity and not relByTypeByWeight then										// 6/12/2023 navcs2 ChangeRequest 57537
						_data.add( ti.totalQuantity.asStringJMT &amp; " x " &amp;  ti.id &amp; ' on ' &amp; ti.releasedDT.date.display &amp; ' at ' &amp; ti.releasedDT.time.currentLocaleFormatJMT());		
					elseif ti.isBulkByWeight or ti.isBulkByVolume then
						_data.add(ti.myCargoType.getBulkTrackByDisplayForWeight(ti.totalWeight,ti.getDensity,true) &amp; " x " &amp;  ti.id &amp; ' on ' &amp; ti.releasedDT.date.display &amp; ' at ' &amp; ti.releasedDT.time.currentLocaleFormatJMT());
					elseif relByTypeByWeight then
						_data.add(ti.myCargoType.getConvertedWeightDisplay(ti.totalWeight,true) &amp; " x " &amp;  ti.id &amp; ' on ' &amp; ti.releasedDT.date.display &amp; ' at ' &amp; ti.releasedDT.time.currentLocaleFormatJMT());
					else
						_data.add(ti.id &amp; ' on ' &amp; ti.releasedDT.date.display &amp; ' at ' &amp; ti.releasedDT.time.currentLocaleFormatJMT());		
					endif;
					headingStr := null;
				endforeach;	
				if headingStr &lt;&gt; null then
					// no released items so just add the heading
					_headings.add(headingStr); _data.add(tmpStr);			
				endif;
			endif;		
		endif;
		return true;
	
	elseif _attrName = ETRow_OperatorCode then
		_headings.add(_heading);
		if self.myOperator &lt;&gt; null then
			if app.myRoot.getConfig(ComboByNameOperator).Boolean then					// TFS 53362
				_data.add(self.myOperator.description &amp; Tab &amp; self.myOperator.code);	// TFS 53362
			else																		// TFS 53362
				_data.add(self.myOperator.code &amp; '  ' &amp; self.myOperator.description);
			endif;																		// TFS 53362
		else
			_data.add(null);
		endif;
		return true;	
	elseif _attrName = ETRow_MyOperatorGroup then
		_headings.add(_heading);
		if self.myOperatorGroup &lt;&gt; null then
			_data.add(self.myOperatorGroup.code &amp; '  ' &amp; self.myOperatorGroup.description);		
		else
			_data.add(null);
		endif;
		return true;			
	elseif _attrName = ETRow_MyTransferToTerminal then
		// DVB changed to use new flags 05/04/05
		if app.isInterTerminalTransferEnabled then
			_headings.add(_heading);
			if self.myTransferToTerminal &lt;&gt; null then
				_data.add(self.myTransferToTerminal.code &amp; '  ' &amp; self.myTransferToTerminal.name);		
			else
				_data.add(null);
			endif;
			return true;	
		endif;
	elseif _attrName = ETRow_CarrierCode then
		tmpCarrier	:= app.myRoot.allCarriers[self.carrierId];
		if tmpCarrier &lt;&gt; null then
			_headings.add(_heading);
			_data.add(self.carrierId &amp; '  ' &amp; tmpCarrier.description);		
			return true;
		endif;	
	elseif _attrName = ETRow_Consignee then
		tmpConsignee := app.myRoot.allConsigneeConsignors[self.consigneeCode];
		if tmpConsignee &lt;&gt; null then
			_headings.add(_heading);
			_data.add(self.consigneeCode &amp; '  ' &amp; tmpConsignee.description);
			return true;
		else
			_headings.add(_heading);
			_data.add(self.consigneeCode);
			return true;		
		endif;
	elseif _attrName = ETRow_ImexStatusString then
		return true;
	elseif _attrName = ETRow_IsoType or 		// 12/08/2008 cnwar2 #16563
		//_attrName = ETRow_TotalRequested or		// if multiple reserve lines, list attributes for all reserves  // 26/10/2012 cnwmh5 #30539
		_attrName = ETRow_DoISOGroupCheck or
		_attrName = ETRow_DoISOGroupCheckStr or
		_attrName = ETRow_Clean or
		_attrName = ETRow_HeavyRated or 
		_attrName = ETRow_Remarks or
		_attrName = ETRow_Id or
		_attrName = ETRow_IdMask or
		_attrName = ETRow_IsoTypeGroup or	// 24/11/2009 cnwar2 #21696
		_attrName = ETRow_AllMTGrades or
		_attrName = ETRow_CargoType or 
		//_attrName = ETRow_LineNumber or  //27-07-2022 navtnr20 53974	//16.12.2022 navsa20 TFS 55878
		_attrName = ETRow_LineNumberHdr or //16.12.2022 navsa20 TFS 55878
		_attrName = ETRow_CustomerReference or	//27-07-2022 navtnr20 53974
		_attrName = ETRow_CargoTypeCodeForCntnt or
		_attrName = ETRow_CargoSubTypeCodeForCntnt then
		
		if _attrName = ETRow_Remarks and not self.releaseByType then
			return false;
		endif;
		
		_headings.add(_heading);				
		tmpStr := "";
		cnt    := 1;
		if self.allReserveDetails.size &gt; 1 and self.releaseByType then
			foreach aReserve in self.allReserveDetails discreteLock do
				tmpDisplay := aReserve.getDisplayStringForAttribute( _attrName, true );
				if tmpDisplay &lt;&gt; null then
					tmpStr := tmpStr &amp; tmpDisplay &amp; "[" &amp; cnt.String &amp; "], ";
				endif;
				cnt := cnt + 1;
			endforeach;
			tmpStr := tmpStr[1:tmpStr.length-2];
		else
			aReserve := self.allReserveDetails.first;
			if aReserve &lt;&gt; null then
				tmpStr := aReserve.getDisplayStringForAttribute( _attrName, true );
			endif;
		endif;
	//	_data.add(tmpStr);
		_data.addTruncated(tmpStr);	//21 Feb 2018	NDL	TFS 37084	//Bug 38191
		return true;
	
	elseif _attrName = ETRow_TotalRequested then							// 26/10/2012 cnwmh5 #30539
		_headings.add(_heading);
		if self.releaseByType then		
			tmpStr := "";
			cnt    := 1;
			if self.allReserveDetails.size &gt; 1 and self.releaseByType then
				foreach aReserve in self.allReserveDetails discreteLock do
					tmpDisplay := aReserve.getTotalRequestedDisplay();
					if tmpDisplay &lt;&gt; null then
						tmpStr := tmpStr &amp; tmpDisplay &amp; "[" &amp; cnt.String &amp; "], ";
					endif;
					cnt := cnt + 1;
				endforeach;
				tmpStr := tmpStr[1:tmpStr.length-2];
			else
				aReserve := self.allReserveDetails.first;
				if aReserve &lt;&gt; null then
					tmpStr := aReserve.getTotalRequestedDisplay();
				endif;
			endif;
			_data.addTruncated(tmpStr);	//Bug 38191
			
		else
			//epr TFS 41398 19/2/19
			_data.add( self.getTotalRequestedDisplay());
		endif;
		return true;
	endif;
	
	return inheritMethod(_attrName, _heading, _headings, _data);

end;</source>
        <access>protected</access>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_heading" type="String"/>
        <Parameter name="_headings" type="StringArray" usage="input"/>
        <Parameter name="_data" type="HugeStringArray" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getDateEstedRequiredLocalTZ" id="afdd15b9-875d-4c5f-a9f4-3a3c074f6418">
        <source>getDateEstedRequiredLocalTZ() : TimeStamp;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 May 2016	cnwns1	Initial creation
// 27 May 2016	cnwns1	TFS 488 - Multi Timezone Support
*/

vars

begin
	return self.systemToLocalTime(self.dateEstimatedRequired);// 27 May 2016	cnwns1	TFS 488 - Multi Timezone Support
epilog

end;</source>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="getDateRequestedLocalTZ" id="363914ff-ac6d-454c-b0b2-8798d1a3cf34">
        <source>getDateRequestedLocalTZ() : TimeStamp;
/*

Purpose:			

Parameters:			

Return Value:		
cm_ca
Date		Who		Reason
27 May 2016	cnwns1	Initial creation
// 27 May 2016	cnwns1	TFS 488 - Multi Timezone Support
*/

vars

begin
	return	self.systemToLocalTime(self.dateRequested);// 27 May 2016	cnwns1	TFS 488 - Multi Timezone Support
epilog

end;</source>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="getDeliveryReleaseNumber" id="b4757b41-49eb-44b3-bf97-b8039b9a449d">
        <source>getDeliveryReleaseNumber() : String;

/*

Purpose:		Returns the delivery release number based on the following rules	
				1) If deliveryReleaseNumber &lt;&gt; null then returns this
				2) If deliveryReleaseNumber = null then return code
Parameters:			

Return Value:		


Date		Who		Reason
30 November 2010	cnwmh5	Initial creation #26400

*/

vars
	deliveryReleaseNumber	: String;
begin
	
	deliveryReleaseNumber := self.deliveryReleaseNumber;
	if deliveryReleaseNumber = null then
		deliveryReleaseNumber := self.code;
	endif;
	return deliveryReleaseNumber;
	
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDeliveryRequest" id="f2ec4a0d-4e92-4649-8c7b-648b5eaeec9e">
        <source>getDeliveryRequest(pGiveError : Boolean) : CM_DeliveryRequest;
// ---------------------------------------------------------------------------
// Created:     14 March 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 23/09/2009	consw1		SFW1035 - get info from ReserveDetail rather than Yard Request
// ---------------------------------------------------------------------------
vars
	req		: CM_Request;
	
begin

	req := self.requests.last;
	
	if req &lt;&gt; null and req.isKindOf(CM_DeliveryRequest) then
		return req.CM_DeliveryRequest;
	endif;
	
	
	return null;

end;</source>
        <Parameter name="pGiveError" type="Boolean"/>
        <ReturnType type="CM_DeliveryRequest"/>
    </JadeMethod>
    <JadeMethod name="getDescription" id="7b7fae03-ed77-408f-828d-ae86d52261bb">
        <source>getDescription(_short : Boolean) : String;
// ---------------------------------------------------------------------------
// Created:		November 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	str : String;
begin
	
	str := self.code &amp; " - " &amp; self.getTypeDescription();
	str := str &amp; " Bulk Release Request";
	return str;
end;</source>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDestination" id="0c08ec50-a7ab-4454-b8a9-0e6f908c3c6f">
        <source>getDestination(): String;
//----------------------------------------------------------------
//	Created:	30 May 2005	by Jason Chapman  (cnwjc2)
//
//	Return the Consignee Description
//
//	Used by reports
//----------------------------------------------------------------
vars
	cons	: CM_ConsigneeConsignor;
begin
	
	if self.myTerminal = null then
		return self.consigneeCode;
	endif;
	
	cons := self.myTerminal.myRoot.allConsigneeConsignors[self.consigneeCode];
	
	if cons = null then
		return self.consigneeCode;
	endif;
	
	return cons.description;
	
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDestinationCode" id="df8fd567-c92d-4b9f-b1d9-9e4406ce6884">
        <source>getDestinationCode() : String;
//
// 23 Mar 2017	cnwrs1	TFS3648
vars

begin
	if self.myDestinationPort &lt;&gt; null then
		return self.myDestinationPort.code;
	endif;
end;
</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDischargePortCode" id="b4f8e19d-e44b-4fb8-83cf-7ce16908880e">
        <source>getDischargePortCode() : String;

vars

begin
	if self.myDischargePort &lt;&gt; null then
		return self.myDischargePort.code;
	endif;
end;
</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDisplayObject" id="7a20a382-1e2a-414f-ae31-298b5316626f">
        <source>getDisplayObject(): CM_DisplayObject;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
20 November 2008	cnwer1	Initial creation

*/

vars

	displayObject : CM_DisplayObject;
begin

	create displayObject transient;
	displayObject.myDisplayClass:=self.class;

	displayObject.addDisplayProperty(CM_BulkRelease::releaseByType,null,"Reserved Only");
	displayObject.addDisplayProperty(CM_BulkRelease::carrierId,null,"Carrier");
	displayObject.addDisplayProperty(CM_BulkRelease::deliveryReasonDescr,null,"Delivery rel. rsn");
	displayObject.addDisplayProperty(CM_BulkRelease::myLoadPort,null,"Load port");
	displayObject.addDisplayProperty(CM_BulkRelease::myDischargePort,null,"Disch Port");
	displayObject.addDisplayProperty(CM_BulkRelease::preventEquivTypes,null,"Prevent equivalent type");
	displayObject.addDisplayProperty(CM_BulkRelease::myPoolPartner,null,"Pool Partner");
	
	return displayObject;

epilog

end;</source>
        <ReturnType type="CM_DisplayObject"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="625b6afb-8162-4bf5-97be-15e939ddcb6c">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
// ---------------------------------------------------------------------------
// Created:     14 May 2002 by cnwth2
//
// Purpose:     
/* Changes

Date		Name	TFS#			Description
============================================================================
22/04/2010 	cnwmh5	PAR23416		Change so ISOGroup is now got from the reserve detail 
									rather than the bulk release
25/8/2010 	cnwjo3	PAR 25538 		Removed ETRow_AllocatedItems
10/03/2011	cnwmh5	PAR #27142		Change to local variable rather than self for handleDeleteObject exception
24/11/2011	cnwcs5	CCMS POL 2122 
					/ PAR 28696 	FILTER USING NEEDS REVIEW
23/04/2012	cnwcs5	Initial creation - CCMS POL 2172 / par 29480 coparn release updates
01/08/2013	cnwcs5	CCMS POL 2221 
					/ par 32094(2) 	Add ETRow_Ignore
28/08/2013	cnwcs5	CCMS POL 2221 
					/ par 32094(3) 	Things found during qual
29/08/2014  cnwma1  PAR# 34699		Remarks Field
22/12/2016	cnwdap1	TFS 3039 		SNO Empty Container Pool Management
24/01/2019	jlgka1	41708			STWO CCRO Management - Add ETRow_BillOfLadingCmbAnyId.
20/02/2019 	jlger1	41398 			Outstanding column shows -value and value that doesn't relate to bulk (weight/volume)
16/06/2022	navdap1	TFS 53362 		EUP Master Data interface customers between TOS and ERP
//19/07/2022	navtnr20	ChangeRequest 53974: EUP - OUT - Additional Fields on Release Line Level	
20 Oct 2022 navtnr20 ChangeRequest 54967: EUP - INB/OUT - Operational Instructions	
//16 Dec 2022   navsa20     Bug 55878: SNO - Error 4033 happens while trying to update a Release Request															
//22/06/2023	navkc1	CR 57496 Task 58405: UI - Release Request Cargo Group
28 Aug 2023 navhl20 ChangeRequest 55019: MTN - Show creation time/date for release requests
18 Dec 2024 navbs1	Bug MTN-33650: CUX - Missing Additional Remarks pop up When Gated in Booking Item without reviewing cargo individually
20 Aug 2025	navnk30	JIRA 35619: FR [35043].011: Add "Is Hazardous" as an available email field
20 Aug 2025	navnk30	JIRA 35620: FR [35043].021: Add "Hazardous Info" as an available email field
03 Nov 2025	jlizm1	MTN 36255 Rotabox Assign Release To Vessel
============================================================================*/
vars
	consign			: CM_ConsigneeConsignor;
	aReserve 		: CM_ReserveDetail;
	packingReserve	: CM_ReserveDetail;
	tmpTI			: CM_TrackedItem;
	str, tmpStr		: String;
	carrier			: CM_Carrier;
	failedDAC  		: CM_DataAccessController;
	total			: Integer;
	gotException	: Boolean;	// we can use same local variable whenever we arm the exception handler - it will only be armed once for a given method call
	businessUnit	: CM_Bank;
	voyage			: CM_Voyage;
	dischargePort 	: CM_Port;
	loadPort		: CM_Port;
	transferToTerminal : CM_Terminal;
	operator		: CM_Operator;
	operatorGroup	: CM_OperatorGroup;
	myPinNo			: CM_PinNo;
	bookingRefStock	: CM_BookingRef;
	assignedTrain	: CM_Train;
	destinationPort	: CM_Port;
	vessel			: CM_Vessel;
	isoStr 			: String;
	measurmentTypes : StringArray;
	cargoGroup		: String;
begin
	// this set of ETRows are used in EDI Comparison
	if _attrName = ETRow_Ignore then
		return " ";
	elseif _attrName = ETRow_ReleaseRequestNumber then
		return self.code;
	elseif _attrName = ETRow_StatusBulkRelease then
		return self.statusString;
	elseif _attrName = ETRow_VesselName then
		voyage := self.myVoyage;
		
		if voyage &lt;&gt; null then
			vessel	:= voyage.myVessel;
			
			if vessel &lt;&gt; null then
				return vessel.name;
			endif;
		endif;
		
		return null;	// par 32094(3)
	endif;
	
	if _attrName = ETRow_ReleaseNo or _attrName = ETRow_Id then
		return self.code;
		
	elseif _attrName = ETRow_WeightTotal then											//+cnwml2 MSL CCMS 1017
		return self.getAverageWeight().String;

	elseif _attrName = ETRow_EstimatedRequiredDate then
		if self.dateEstimatedRequired.isValid() then
			return self.systemToLocalTime(self.dateEstimatedRequired).date.asStringJMT;	// 14/4/16 cnwmp6 TFS 488 - Multi timezone support
		else
			return app.getErrorString(Unknown);
		endif;
		
	elseif _attrName = ETRow_EstimatedRequiredTime then
		if self.dateEstimatedRequired.isValid() then
			return self.systemToLocalTime(self.dateEstimatedRequired).time.asStringJMT;	// 14/4/16 cnwmp6 TFS 488 - Multi timezone support
		else
			return app.getErrorString(Unknown);
		endif;
		
	//13 Feb 2017	NDL	TFS 3368
	elseif _attrName = ETRow_ExpiryDate then
		if self.expiryTimeStamp.isValid() then
			return self.systemToLocalTime(self.expiryTimeStamp).date.asStringJMT;
		else
			return null;
		endif;
	//13 Feb 2017	NDL	TFS 3368	
	elseif _attrName = ETRow_ExpiryTime then
		if self.expiryTimeStamp.isValid() then
			return self.systemToLocalTime(self.expiryTimeStamp).time.asStringJMT;
		else
			return null;
		endif;
	//13 Feb 2017	NDL	TFS 3368	
	elseif _attrName = ETRow_ExpiryTimeStamp then
		if self.expiryTimeStamp.isValid() then
			return self.systemToLocalTime(self.expiryTimeStamp).asStringJMT;
		else
			return null;
		endif;
		
	elseif _attrName = ETRow_RequestedCountFromOps then
		return self.numberWLECreated.asStringJMT();
		
	elseif _attrName = ETRow_BusinessUnit then
		businessUnit := self.myBusinessUnit;
		if businessUnit &lt;&gt; null then
			on Exception do app.handleDeletedObject(exception, businessUnit, gotException);
			return businessUnit.code;
		else
			return null;
		endif;
		
	elseif _attrName = ETRow_CargoType or _attrName = ETRow_CargoTypeDescr then
		return self.getMyCargoTypeDescription;
		
	elseif _attrName = ETRow_CargoId  then
		foreach tmpTI in self.allTrackedItemsReleased do
			str := str &amp; tmpTI.id &amp; ',';
			if str.length &gt; 30 then
				return str[1:26] &amp; '...';
			endif;
		endforeach;
		
		return str;
		
	elseif _attrName = ETRow_RequestDate then
		if self.dateRequested.isValid() then
			return self.systemToLocalTime(self.dateRequested).date.asStringJMT();	// 14/4/16 cnwmp6 TFS 488 - Multi timezone support
		else
			return app.getErrorString(Unknown);
		endif;
		
	elseif _attrName = ETRow_RequestTime then
		if self.dateRequested.isValid() then
			return self.systemToLocalTime(self.dateRequested).time.currentLocaleFormatJMT();	// 14/4/16 cnwmp6 TFS 488 - Multi timezone support
		else
			return app.getErrorString(Unknown);
		endif;		
		
	elseif _attrName = ETRow_BookingConfirmation then	
		return self.bookingConfirmation;
		
	elseif _attrName = ETRow_VoyageArrival then	
		voyage := self.myVoyage;
		if voyage = null then 
			return null;
		else 
			on Exception do app.handleDeletedObject(exception, voyage, gotException);
			return self.systemToLocalTime(voyage.arrivedDT).date.asStringJMT;	// 14/4/16 cnwmp6 TFS 488 - Multi timezone support
		endif;
		
	elseif _attrName = ETRow_DeliveryReleaseNumber then
		return self.deliveryReleaseNumber;
		
	elseif _attrName = ETRow_GatePass then	
		return self.code;
		
	elseif _attrName = ETRow_DischargePort then
		dischargePort := self.myDischargePort;
		if dischargePort &lt;&gt; null then
			on Exception do app.handleDeletedObject(exception, dischargePort, gotException);
			return dischargePort.code &amp; " - " &amp; dischargePort.description;
		endif;
		
		return null;
		
	elseif _attrName = ETRow_DeliveryReason then
		return self.deliveryReasonDescr;
		
	elseif _attrName = ETRow_Destination then
		//03 Nov 2009 NDL Par 21519
		if self.myDestinationPort &lt;&gt; null then
			return self.myDestinationPort.code;
		endif;
		return null;
		
	elseif _attrName = ETRow_EmailOptions then
		return DblClickToUpdate;
		
	elseif _attrName = ETRow_LoadPort then
		loadPort := self.myLoadPort;
		if loadPort &lt;&gt; null then
			on Exception do app.handleDeletedObject(exception, loadPort, gotException);
			return loadPort.code &amp; " - " &amp; loadPort.description;
		endif;
		
		return null;
		
	elseif _attrName = ETRow_PackLocation then
		return self.getPackLocationString();
		
	elseif _attrName = ETRow_TotalPacked then
		return self.getPackQuantity().String;
	
	elseif _attrName = ETRow_Type then
		return self.getTypeDescription();
		
	elseif _attrName = ETRow_AvailabilityGradeCode or _attrName = ETRow_AllMTGrades then
		return self.getAvailabilityGrades();

	elseif _attrName = ETRow_WorkNumber or//&lt;&lt;-- Port Everett
		_attrName = ETRow_Clerk or
		_attrName = ETRow_Trucker or
		_attrName = ETRow_Gate or
		_attrName = ETRow_PickupDate or
		_attrName = ETRow_TimeOut or
		_attrName = ETRow_TimeIn or
		_attrName = ETRow_Loader or	
		_attrName = ETRow_TransportId or
		_attrName = ETRow_BolNumber or
		_attrName = ETRow_Mark or
		_attrName = ETRow_Exception or	
		_attrName = ETRow_ReceivedBy or	
		_attrName = ETRow_BillOfLading or 
		_attrName = ETRow_ReleaseVehicle then
		
		foreach tmpTI in self.allTrackedItemsReleased discreteLock do
			return tmpTI.getDisplayStringForAttribute(_attrName, _short);
		endforeach;

	elseif _attrName = ETRow_Bundles then
		return self.totalRequested.String;
		
	elseif _attrName = ETRow_DeliveryReason then
		return self.deliveryReasonDescr;
	
	elseif _attrName = ETRow_FreightPayerCode then
		return self.freightPayerCode;
		
/* TFS 2686	
	elseif _attrName = ETRow_RemoveStops or
		   _attrName = ETRow_RemoveStopsStr then
		return self.removeStops.cnEcGetYesNo;
	*/	
	elseif _attrName = ETRow_PowerRequirements then
		return null;//no longer used
		
	elseif _attrName = ETRow_VoyageCode then
		voyage := self.myVoyage;
		if voyage &lt;&gt; null then
			on Exception do app.handleDeletedObject(exception, voyage, gotException);
			return voyage.code;
		else
			return null;
		endif;
	
	elseif _attrName = ETRow_MyTransferToTerminal then
		transferToTerminal := self.myTransferToTerminal;
		if transferToTerminal &lt;&gt; null then
			on Exception do app.handleDeletedObject(exception,transferToTerminal, gotException);
			return transferToTerminal.code;
		else
			return null;
		endif;
		
	elseif _attrName = ETRow_ConsignorVoyageCode then
		return self.consignorVoyageCode;
	//20 Jan 2014	NDL	Par 33313 - commented
	//elseif _attrName = ETRow_Remarks then
		//return self.cargoRemarks;
	
	elseif _attrName = ETRow_DoISOGroupCheck or
		_attrName = ETRow_DoISOGroupCheckStr or
		_attrName = ETRow_Remarks or	//20 Jan 2014	NDL	Par 33313 - un commented
		_attrName = ETRow_IdMask or
		_attrName = ETRow_IsoType or
		_attrName = ETRow_ImexStatusString or
		_attrName = ETRow_Clean or
		_attrName = ETRow_CleanString or
		_attrName = ETRow_HeavyRated or
		_attrName = ETRow_HeavyRatedString or
		_attrName = ETRow_EmptyReleaseItemDescr or
		_attrName = ETRow_IsoTypeGroup	or 	// 22/04/2010 cnwmh5 PAR23416
		//_attrName = ETRow_LineNumber or //11-07-2022	navtnr20 53974	//16.12.2022 navsa20 TFS 55878 
		_attrName = ETRow_LineNumberHdr or //16.12.2022 navsa20 TFS 55878  
		_attrName = ETRow_CustomerReference or //11-07-2022	navtnr20 53974
		_attrName = ETRow_IsHazardous or		//20AUG2025 navnk30 JIRA-35619
		_attrName = ETRow_AllTiHazards or		//20AUG2025 navnk30 JIRA-35620
		_attrName = ETRow_CargoTypeCodeForCntnt or
		_attrName = ETRow_CargoSubTypeCodeForCntnt then
		
		foreach aReserve in self.allReserveDetails discreteLock do
			tmpStr := tmpStr &amp; " " &amp; aReserve.getDisplayStringForAttribute(_attrName,_short);
		endforeach;
		
		//20 Jan 2014	NDL	Par 33313
		if _attrName = ETRow_Remarks then
			if tmpStr = null then
				tmpStr := self.cargoRemarks;
			else
				tmpStr := tmpStr &amp; " " &amp; self.cargoRemarks;
			endif;
		endif;
		
		tmpStr :=  tmpStr.trimBlanks();
		
		/*if tmpStr.length() &gt; 40 then        // cnwma1 29 Aug 2014 PAR#34699
			tmpStr := tmpStr[1:40] &amp; "...";
		endif;*/
		return tmpStr;

	elseif _attrName = ETRow_OperatorCode or  _attrName = ETRow_Operator then
		operator 		:= self.myOperator;
		operatorGroup 	:= self.myOperatorGroup;
		if operator &lt;&gt; null then
			on Exception do app.handleDeletedObject(exception, operator, gotException);
			if app.myRoot.getConfig(ComboByNameOperator).Boolean then	// TFS 53362
				return operator.description;							// TFS 53362
			else														// TFS 53362
				return operator.code;
			endif;														// TFS 53362
		elseif operatorGroup &lt;&gt; null then
			on Exception do app.handleDeletedObject(exception, operatorGroup, gotException);
			return operatorGroup.code &amp; "'";	//the blip on the end highlights the fact that this is an operator group code not an operator code
		else
			if _attrName = ETRow_Operator then	//15 Mar 2017	NDL	TFS 3758
				return 'n/a';
			endif;
			return null;
		endif;

	elseif _attrName = ETRow_Consignee then
		consign := app.myRoot.allConsigneeConsignors[self.consigneeCode];
		//TFS#53362 navsp1 20Jun2022
		if app.myRoot.getConfig(ConsigneeConsignorCmbOrdDescr).Boolean then  
			if consign &lt;&gt; null then
				return consign.description;
			endif;
		endif;		
		
		if consign &lt;&gt; null then
			return self.consigneeCode &amp; ' ' &amp; consign.description;
		endif;
		
		return self.consigneeCode;	
		
	elseif _attrName = ETRow_FreightForwarderCode then
		return self.freightForwarderCode;

	elseif _attrName = ETRow_MyOperator then
		operator := self.myOperator;
		if operator = null then
			operatorGroup := self.myOperatorGroup; 
			if operatorGroup &lt;&gt; null then
				on Exception do app.handleDeletedObject(exception, operatorGroup, gotException);
				return operatorGroup.code &amp; "'";
			else
				//drop through
			endif;
		else
			on Exception do app.handleDeletedObject(exception, operator, gotException);
			return operator.code;
		endif;
		
	elseif _attrName = ETRow_Attachments then
		return self.getAssignedIDs();
		
	elseif _attrName = ETRow_Quantity then
		
		
		return self.totalRequested.String;
	
	elseif _attrName = ETRow_PackQuantity then
		// Total up all the packing children PAR 17368
		total := 0;
		foreach packingReserve in self.allReservePackingChildren do 
			if packingReserve.CM_ReserveSelection &lt;&gt; null then
				total := total + packingReserve.CM_ReserveSelection.totalRequested;
			endif;
		endforeach;			
		return total.String;
		
	elseif _attrName = ETRow_PackProduct or _attrName = ETRow_MyProduct then
		on Exception do app.handleDeletedObject(exception, packingReserve.CM_ReserveSelection.myProduct, gotException);
		//change for old screen - a hack in that it assumes there is only a single packing request line
		packingReserve := self.allReservePackingChildren.first.CM_ReserveSelection;
		if packingReserve  &lt;&gt; null then
			return packingReserve.CM_ReserveSelection.getProductDescr();
		else
			return null;
		endif;	
		
	elseif _attrName = ETRow_ReleaseCarrier then
		return self.carrierId;
		
	elseif _attrName = ETRow_CarrierCode then
		return self.carrierId;
		
	elseif _attrName = ETRow_RequestsBeingActioned then
		if type = BR_TYPE_RAIL then	// 31 Jul 2009	NDL only return those TIs associated with a job.
			return self.quantityOnSiteWithJobRail.String;
		endif;
		return self.getNumItemsBeingActioned.String;
	
	elseif _attrName = ETRow_CompletedStatusDate then		
		if self.statusString = BR_COMPLETE_STRING then
			if self.statusDate.isValid then
				return self.systemToLocalTime(self.statusDate).asStringJMT;	// 14/4/16 cnwmp6 TFS 488 - Multi timezone support
			else
				return app.getErrorString(Unknown);
			endif;
		else
			return app.getErrorString(NotApplicable);
		endif;
				
	elseif _attrName = ETRow_DeliveredToDate then
		//epr TFS 41398 19/2/19
		return self.getTotalReleasedDisplay();
		//return self.releasedItemStrings.size.String;
		
	elseif _attrName = ETRow_MyPinNo then
		myPinNo := self.myPinNo;
		if myPinNo &lt;&gt; null then
			on Exception do app.handleDeletedObject(exception, myPinNo, gotException);
			carrier := self.getCarrier;
			
			if carrier = null or carrier.canUserAccessSelf(null, failedDAC, app.myPassport) then
				return myPinNo.pinNo;		
			else
				return "****";		
			endif;
		else
			return null;
		endif;
		
	elseif _attrName = ETRow_PinEmailAddresses then
		if self.myPinNo &lt;&gt; null then
			tmpStr := self.myPinNo.allEmailRecipients.getFirstElementsDelimited(0, ',');
			return tmpStr.replaceString(',', CrLf);
		else
			return "";
		endif;elseif _attrName = ETRow_ContainerNumber then
		
		return null;
		
	elseif _attrName = ETRow_MyBookingRefStock or 
		 _attrName = ETRow_Booking then //cnwrd1 par 23922
		bookingRefStock := self.myBookingRefStock;
		if bookingRefStock &lt;&gt; null then
			on Exception do app.handleDeletedObject(exception, bookingRefStock, gotException);
			return bookingRefStock.bookingReference;
		else
			return null;
		endif;
		
	elseif _attrName = ETRow_TotalRequested then	// 16/06/2008 cnwar2 #17095
		
		//epr TFS 41398 19/2/19
		return self.getTotalRequestedDisplay;	
		//return self.getTotalRequested.String;
		
	elseif _attrName = ETRow_ReleaseRecordQty then	// 31/03/2009 cnwar2 #18986
		total := 0;
		foreach tmpTI in self.allTrackedItemsReleased do
			total := total + tmpTI.quantity;
		endforeach;
		return total.String;
		
	elseif _attrName = ETRow_MySubTerminal then   //16/04/2009 cnwdz2 ccms1735
		if self.mySubTerminal &lt;&gt; null then
			return self.mySubTerminal.code;
		else 
			return null;
		endif;
	elseif _attrName = ETRow_MySubTerminalTarget then  //cnwrd1 par 23219 17.3.2010
		if self.mySubTerminalTarget &lt;&gt; null then
			return self.mySubTerminalTarget.code;
		else 
			return null;
		endif;		
	elseif _attrName = ETRow_QuantityRemaining or _attrName = ETRow_Outstanding then 		 // PAR 19710
		//epr TFS 41398 19/2/19
		return self.getTotalOutstandingDisplay();
		//return self.getTotalOutstanding().String;		 // PAR 19710
	elseif _attrName = ETRow_SubTerminalDesc then
		if self.mySubTerminal = null then
			return null;
		else
			return self.mySubTerminal.code;
		endif;
	elseif _attrName = ETRow_IsoTypeGroup then  //cnwjo3, CCMS 1091 (needs to be altered)
		return "WHAT";
	
	elseif _attrName = ETRow_TrainAssignedID or _attrName = ETRow_MyTrainAssigned then	//03 Nov 2009 NDL Par 21519
		assignedTrain := self.myAssignedTrain;
		if assignedTrain &lt;&gt; null then
			on Exception do app.handleDeletedObject(exception,assignedTrain, gotException);
			return assignedTrain.getCodeDateString;
		endif;
		
		if not self.isRailType then	// 01 Aug 2016	NDL	TFS 2473
			return null;
		endif;
		
		return self.getTrainsUsed(); // PAR 25980
		
	
	elseif _attrName = ETRow_DestinationPort then	//03 Nov 2009 NDL Par 21519
		destinationPort := self.myDestinationPort;
		if destinationPort &lt;&gt; null then
			on Exception do app.handleDeletedObject(exception, destinationPort, gotException);
			return destinationPort.code &amp; " - " &amp; destinationPort.description;
		endif;
		return null;
	elseif _attrName = ETRow_AllowCargoOnMultiRel or
		   _attrName = ETRow_AllowCargoOnMultiRelStr or _attrName = ETRow_AllowCargoMultiReleases then //epr 23/1/13 par 32539
		return self.allowCargoOnMultipleReleases.getYesNo();
	
	elseif _attrName = ETRow_CustomsAgent then
		return self.customsAgent;
		
	elseif _attrName = ETRow_CustomsAssistance or
		   _attrName = ETRow_CustomsAssistanceStr then
		return self.customsAssistance.getYesNo();
	
	elseif _attrName = ETRow_InterTerminalRelease or
		   _attrName = ETRow_InterTerminalReleaseStr then
		return self.isInterTerminalBulkRelease().asStringJMT();
	
	elseif _attrName = ETRow_MtRelease or
		   _attrName = ETRow_MtReleaseStr then
		return self.isForMTs().asStringJMT();
	
	elseif _attrName = ETRow_HiLowCube or
		   _attrName = ETRow_HiLowCubeStr then
		return self.canBeHiLoCube.getYesNo();
	
	elseif _attrName = ETRow_ReleaseByTypeStr then
		return self.releaseByType.getYes();
	
	elseif _attrName = ETRow_NeedsReview then
		return self.needsReview.getYes();

	elseif _attrName = ETRow_NeedsReviewCB then
		return self.needsReview.Integer.String;
		
	elseif _attrName = ETRow_BlockEDIUpdates then		// par 29480 April 2012
		return self.blockEDIUpdates.getYes;				// par 29481 May 2012
		
	elseif _attrName = ETRow_BlockEDIUpdatesCB then		// par 29480 April 2012
		return self.blockEDIUpdates.Integer.String;		// par 29481 May 2012
		
	elseif _attrName = ETRow_ViewEDIMessages then
		return null;	// let the form sort it out
	elseif _attrName = ETRow_StatusDesc then			//cnwmc5 - PAR 32473 - 23 Sep 2013
		return self.statusString;						//cnwmc5 - PAR 32473 - 23 Sep 2013
	elseif _attrName = ETRow_VehicleBookingSlots then	//23 Oct 2014	NDL	Par 35008
		return self.getVBTimeslotsAsString();
	elseif _attrName = ETRow_VoyageInward then
		//epr par 34857 19/11/14 CCMS 2374
		if self.myVoyage &lt;&gt; null then
			return self.myVoyage.inwardCode;
		endif;
		
		return null;
		
	elseif _attrName = ETRow_PoolParty then					// TFS 3039
		if self.myPoolingParty &lt;&gt; null then					// TFS 3039
			return self.myPoolingParty.code;				// TFS 3039
		endif;												// TFS 3039
		
	elseif _attrName = ETRow_PickerType then	//15 Mar 2017	NDL	TFS 3758
		return 'Release';
		
	elseif _attrName = ETRow_PickerDescription then	//15 Mar 2017	NDL	TFS 3758
		if self.myCargoType &lt;&gt; null and  self.myOperator &lt;&gt; null then
			return self.myCargoType.id.String&amp;' x '&amp; self.totalRequested.String;
		elseif self.myCargoType &lt;&gt; null then
			return self.myCargoType.id.String&amp;' x ' &amp; self.totalRequested.String;
		else
			return self.totalRequested.String;		
		endif;
		
	elseif _attrName = ETRow_PickerId or _attrName = ETRow_ItemId then	//15 Mar 2017	NDL	TFS 3758
		return self.code;
		
	elseif _attrName = ETRow_RequestDateTime then	//15 Mar 2017	NDL	TFS 3758
		return self.dateRequested.asStringJMT;
	
	elseif _attrName = ETRow_Iso then	//15 Mar 2017	NDL	TFS 3758
		isoStr := self.getDisplayStringForAttribute(ETRow_IsoType,false);
		if isoStr = null then
			isoStr := self.getDisplayStringForAttribute(ETRow_IsoTypeGroup,false);
		endif;
		return isoStr;
		
	elseif _attrName = ETRow_Bol then	//17 Mar 2017	NDL	TFS 3758																//+cnwml2 PAR21090
		return null;
		
	elseif _attrName = ETRow_RemarksAdditional1 or _attrName = ETRow_PickerRelReqRemarks1 then	//02 May 2018	NDL	TFS 37795		//18.12.2024 navbs1 #33650
		return self.remarksAdditional1;
		
	elseif _attrName = ETRow_RemarksAdditional2 or _attrName = ETRow_PickerRelReqRemarks2 then	//02 May 2018	NDL	TFS 37795		//18.12.2024 navbs1 #33650
		return self.remarksAdditional2;
	//jlgka1 TFS 41708 --&gt;
	elseif _attrName = ETRow_BillOfLadingCmbAnyId then	
		if self.myBOLIn &lt;&gt; null then
			return self.myBOLIn.number;
		else
			return null;
		endif;	
	//jlgka1 TFS 41708 &lt;--	
	// Start 20.10.2022 navtnr20 TFS 54967
	elseif _attrName = ETRow_InstructionInternal then		
		if self.myInstructions &lt;&gt; null then
			return self.myInstructions.internalInstructions.formatWithEllipsis(1,50,true);
		endif;
		return null;
	elseif _attrName = ETRow_InstructionExternal then
		if self.myInstructions &lt;&gt; null then
			return self.myInstructions.externalInstruction.formatWithEllipsis(1,50,true);
		endif;
		return null;
	elseif _attrName = ETRow_InstructionCode then
		if self.myInstructions &lt;&gt; null then
			return self.myInstructions.getInstructionCode();
		endif;
		return null;
	elseif _attrName = ETRow_InstructionDesc then		
		if self.myInstructions &lt;&gt; null then
			return self.myInstructions.getInstructionDesc();
		endif;
		return null;
	// End 20.10.2022 navtnr20 TFS 54967
	elseif _attrName = ETRow_CargoGroup then //22/06/2023	navkc1	CR 57496 Task 58405
		foreach aReserve in self.allReserveDetails do
			if cargoGroup &lt;&gt; null then
				cargoGroup := cargoGroup &amp; ",";
			endif;
			cargoGroup := cargoGroup &amp; aReserve.getMyCargoGroupId();
		endforeach;
		return cargoGroup;
	elseif _attrName = ETRow_CreationDateTime then									//29.8.2023 navhl20 #55019
		return self.systemToLocalTime(self.createdTime).asStringJMT();
	elseif _attrName = ETRow_PickerCargoRemarks1 or _attrName = ETRow_PickerCargoRemarks2 then 		//18.12.2024 navbs1 #33650
		return null;
	else
		return inheritMethod(_attrName, _short);			
		
	endif;
epilog
	delete measurmentTypes;
end;
</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDoCheckForISOGroup" id="235cda10-5a07-4748-a02d-4a2f3de408d3">
        <source>getDoCheckForISOGroup(): Boolean;
//----------------------------------------------------------------
//  Created:    04 April 2005   by Jason Chapman  (cnwjc2)
//
//	Used in JRW Report Writer!
//----------------------------------------------------------------
  
vars
    detail   : CM_ReserveDetail;
begin

    foreach detail in self.allReserveDetails do
        if CM_ReserveSelection.hasInstance(detail) then
            return detail.CM_ReserveSelection.doISOGroupCheck;
            break;
        endif;
    endforeach;

    return false;
end;
</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
