        <updating/>
        <source>tp018_GIOF_cmbCommodityclick():Integer updating;

vars
	cmbCommodity:ComboBox;
	tblExtra:Table;
begin
	cmbCommodity:=myGTE_InOutForm_2.getPropertyValue('cmbCommodity').ComboBox.getControl(1);
	cmbCommodity.listIndex:=app.atcgGetComboStringIndex(cmbCommodity, 1, 'SKIN	Skins (Dry)', 149);
	cmbCommodity.closeup(cmbCommodity);
	cmbCommodity:=myGTE_InOutForm_2.getPropertyValue('cmbCommodity').ComboBox.getControl(1);
	tblExtra:=myGTE_InOutForm_2.getPropertyValue('tblExtra').Table.getControl(1);
	app.doWindowEvents(shortPause);
	cmbCommodity.listIndex:=app.atcgGetComboStringIndex(cmbCommodity, 1, 'SKIN	Skins (Dry)', 149);
	tblExtra.accessCell(16, 2).text:='SKIN	Skins (Dry)';
	cmbCommodity.click(cmbCommodity);  // 16:06:13
	return 0;
end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
