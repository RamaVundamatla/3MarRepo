    <JadeMethod name="keyDown" id="6e3b8d77-9459-4834-8a40-9f9108910fb2">
        <controlMethod name="Form::keyDown"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>keyDown(keyCode: Integer io; shift: Integer) updating;
// ---------------------------------------------------------------------------
// Created:     09 April 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	if keyCode = J_key_Tab and
	   tblSearch.visible then
		tblSearch.handleFormTab(keyCode, shift, tblData, tblData);
		return;
	endif;

	if keyCode = CMUI_Key_F3 and self.allowSearch then
		if self.mode = self.Mode_Add or 
		   self.mode = self.Mode_Update then
			return;
		endif;
		app.mousePointer := MousePointer_HourGlass;
		if self.isSearcherVisible then
			self.zHideSearcher();
		else
			self.zShowSearcher();
		endif;
		return;
	endif;
	
	if keyCode = CMUI_Key_F5 then
		// F5 does a refresh of the screen.
		self.doRefresh;
		return;
	endif;
	
	if keyCode = CMUI_Key_F11 and shift = 0 then
		self.mnuTblVInspectObject_click(mnuTblVInspectObject);
	endif;
	
	inheritMethod(keyCode, shift);

epilog
	app.mousePointer := MousePointer_Default;
end;</source>
        <Parameter name="keyCode" type="Integer" usage="io"/>
        <Parameter name="shift" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="loadDataForFirstTime" id="d5c81344-cf44-458a-87ab-b33925cf0c0e">
        <updating/>
        <source>loadDataForFirstTime() updating, protected;
// ---------------------------------------------------------------------------
// Created:     14 May 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	inheritMethod();

	// DVB changed order so am initialising is checked first. 
	// otherwise it didn't load correct object. 19/09/03
	if self.amInitialisingWithObject then
		if self.useTblData then
			self.initForCurrentObject();
			self.zTblDataSortAndShow(false);
		else
			if self.amInitialisingInEditMode then
				// OK not to call zTblDataSelectObject(..) first as at this point
				// self.useTblData = false so it just calls zShowThumbnailData()
				// which is called by zDoEdit for the proxy
				self.zDoEdit();
				return;
			else
				self.zTblDataSelectObject(self.myCurrentObject);
			endif;
		endif;
	elseif self.showDataOnStartup then
		self.zTblDataSortAndShow(false);
		//Double up, already done in self.zGetDataForTable() via self.zTblDataSortAndShow(false);
		//self.zTblDataSelectObject(null);
	endif;

	// Do this here otherwise the above clears all the preset values
	if self.initialMode &lt;&gt; 0 then
		if self.initialMode = Mode_Add then
			// Open in add mode
			self.zDoAdd();
		elseif self.initialMode = Mode_Update 
		and (not amInitialisingInEditMode) then
			// Edit not done above so do it now
			self.zDoEdit();
		endif;
	endif;
	
end;</source>
        <access>protected</access>
    </JadeMethod>
