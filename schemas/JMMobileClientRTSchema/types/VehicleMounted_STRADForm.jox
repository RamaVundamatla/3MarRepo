    <JadeMethod name="loadTaskTable" id="a702ef86-67c4-4a0c-b977-645f442fb305">
        <updating/>
        <source>loadTaskTable() updating, protected;
/*

Purpose:			


Return Value:		


Date		Who		Reason
14 September 2006	cnwer1	Initial creation - PAR#xxxx

*/
vars
	theTable : Table;
	row : Integer;
	selectedRows : ObjectArray;
begin
	theTable:=tblJobs;
	
	create selectedRows transient;
	
	row:=theTable.fixedRows + 1;
	while row &lt;= theTable.rows do
	
		if  theTable.accessCell(row,1).text.Integer = true.Integer then
			selectedRows.add(theTable.accessRow(row).itemObject);
		endif;
		theTable.deleteRow(row);
	endwhile;
	
	
	app.myVehicleMountedSTRADGuiAgent.loadTable(theTable);
	if selectedRows.size &gt; 0 then
		row:=theTable.fixedRows + 1;
		while row &lt;=  theTable.rows do
			if theTable.accessRow(row).itemObject = null then
				row:=row+1;
				continue;
			endif;
			if selectedRows.includes(theTable.accessRow(row).itemObject) then
				theTable.accessCell(row,1).text:=true.Integer.String;
				selectedRows.remove(theTable.accessRow(row).itemObject);
			endif;
			if selectedRows.size = 0 then
				break;
			endif;
			row:=row+1;
		endwhile;
	endif;
	//this just updates the colors
	self.updateTableElapsedTimes();	
	
	self.updateButtonCaptions();
	
	if theTable.rows &gt; theTable.fixedRows then
		if (not self.timerRefreshActive) then
			self.beginTimerForRefresh();
		endif;
	endif;
	
	
	
epilog
	delete selectedRows;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setMargins" id="9ea5e510-d66a-43f4-9a00-87cab4c4c8d1">
        <source>setMargins();
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
27 February 2009	cnwer1	Initial creation

*/

vars
	i,
	numSheets	: Integer;
	tmpSheet	: JadeTableSheet;
begin
	inheritMethod();

	numSheets := self.tblMove.sheets;
	foreach i in 1 to numSheets do
		tmpSheet := self.tblMove.accessSheet(i);
		tmpSheet.marginLeft := 2;
		tmpSheet.marginRight := 2;
		tmpSheet.marginTop := 1;
	endforeach;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setupForm" id="7afac887-193a-4624-b1f4-174ccd7419d4">
        <updating/>
        <source>setupForm() updating;
/*

Purpose:			


Return Value:		


Date				Who		Reason
13 September 2006	cnwer1	Initial creation - PAR#xxxx
17 June 2008		concms1	PAR 17123 (CCMS 1671) DCT Gdansk - RDT Screen to relocate container

*/
vars
	errorStr : String;
begin
	inheritMethod();	
	if not app.isRunningOnCE then
		self.borderStyle := self.BorderStyle_Single;
		self.caption := 'STRADDLE APP Dev mode (has control box)';
		self.height := self.height + 25;
	endif;	

	self.setupJobTable;
	self.setupMoveTable;
	self.setupTaskCaption;
	self.loadTaskTable();
	self.loadReasonCombo;
	self.clearMoveDetails;	// PAR 17123
	
	configElapsedTime:=app.myHandHeldGuiAgent.getTerminalConfig(HandHeldAgent.ConfigElapsedTimeExceeded).Integer;
	self.changeDefaultButtons(btnMsgOK,btnAccept);
	self.changeCancelButtons(btnMsgCancel,btnLogoff);
	
epilog
	
end;</source>
    </JadeMethod>
    <JadeMethod name="setupJobTable" id="b4956ae6-4b9d-4e4c-91ce-5bf6df11524c">
        <updating/>
        <source>setupJobTable() updating, protected;
/*

Purpose:			


Return Value:		


Date		Who		Reason
14 September 2006	cnwer1	Initial creation - PAR#xxxx

*/
vars
	theTable : Table;
begin
	theTable := self.tblJobs;
	theTable.clear;
	theTable.rows := 0;
	theTable.selectMode := Table.SelectMode_CurrentRow;
	theTable.alignment := Table.Alignment_Center_Top;
	theTable.accessColumn(1).inputType :=Table.InputType_None;

	colNoTime:=7;
	theTable.columns:=9;
	theTable.rows:=1;
	theTable.row:=1;
	theTable.text:="" &amp; Tab &amp; ColType &amp; Tab  &amp; ColTwinNum &amp; Tab &amp; self.ColVehicle &amp;  Tab &amp; ColId &amp; Tab &amp; ColSource &amp; Tab &amp; ColTarget &amp; Tab &amp; ColTime &amp; Tab &amp; ColDoorDir;
	theTable.fixedRows := 1;
	theTable.column := 1;
	theTable.accessColumn(1).inputType := Table.InputType_CheckBox;
	
	/*if app.myVehicleMountedSTRADGuiAgent.canTwinLift then
		theTable.selectMode:= Table.SelectMode_CurrentRow;
	else
		theTable.selectMode:= Table.SelectMode_WholeRows;
	endif;*/
epilog

end;</source>
