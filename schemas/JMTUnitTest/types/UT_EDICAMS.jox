		pxyEndpoint.setProxy(ETRow_DamageAndRepair, "damagerepair", "POST", pxyExtWebServiceDef);	// TFS 57207
		app.myUtilityCA.utlCreateExtWebService(pxyExtWebServiceDef, extWebServiceDef, app.myPassport);
		camProtocol.setMyWebServiceDef(extWebServiceDef.CM_APIEndpointServiceDef);			
		
	endif;
	
	commitTransaction;
	
	self.assertTrueMsg(camProtocol.allRegisteredCargoTypes.includes(TI_CargoType_Container), "ISO Cargo Type Container is not registered");    
	
	//================================UC1 - 1 Damage Location transaction=================================	
	
	container1Obj := self.addCtrAtLocnDischWithBol(Container1, "2200", "GENL", TI_IMEX_STATUS_EXPORT, bs.myLocationsController, voyage.allPorts.first, voyage, "123456");	
	
	//make sure the debtor of the operator of the container has an external reference
	assertTrueMsg(container1Obj.myOperator.debtor.externalReference &lt;&gt; null, 'The operator of container 3 is null');
	
	//add 1 damage to container
	addDamageWithDate(container1Obj, "BENT", "All", null, 1, "container1 damage1", now);				
	
	// RUNS CAMS
	removeStopsAndAddOneKnownStop(container1Obj);
	//endDateTime := startDateTime.addMinutes(1);
	endDateTime := app.actualTimeServer;
	self.runCamsAdhoc(startDateTime, endDateTime, runDateTime, camProtocol);	
	
	//check if it was successful and the response was not 401, ideally it should be 201(CREATED)
	self.assertTrueMsg(camProtocol.allEWSCamsActivities.first() &lt;&gt; null, "camProtocol.allEWSCamsActivities.first() is null");	
	self.assertTrueMsg(camProtocol.allEWSCamsActivities.first.responseCode &lt;&gt; 400 ,"The error response from the server is : "&amp;camProtocol.allEWSCamsActivities.first.response);		
	
	camTaskHistory := camProtocol.taskHistoryByProtocolSeq.first;
	
	//VERIFY THE MESSAGE SENT
	self.assertNotNull(camTaskHistory);	
	
	create theLines transient;
	camTaskHistory.rawDataToHSA(theLines);
	
	self.assertTrueMsg(theLines.size &gt; 0, 'Nothing was recorded in the history');	
	
	//DEBUG
	if debug then
		write CrLf &amp; CrLf &amp; "output of 1 " &amp; CrLf;
		foreach s in theLines do
			write CrLf &amp; "output of 1 in loop"&amp;CrLf&amp; s;
		endforeach;
