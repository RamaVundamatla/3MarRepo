    <JadeMethod name="initFldEdit" id="5f373fc2-7ef3-4479-bb71-885167b53a0f">
        <source>initFldEdit();
// ---------------------------------------------------------------------------
// Created:     28 January 2003		cnwth2	
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	sht			: CMUI_Sheet;
	idx			: Integer;
begin

	self.fldEdit.stretchToParent := true;
	
//	self.tblAlpha.stretchToParent := true;
	self.tblGeneral.stretchToParent := true;

	
	//////////////11465
	self.tblGeneral.allowResize := Table.AllowResize_Column;
	self.tblInputTop.allowResize := Table.AllowResize_Column;
	///////////////////////////
	
//	self.tblView2.stretchToParent := true;
//	self.setColorsForTable(self.tblView2);
end;</source>
