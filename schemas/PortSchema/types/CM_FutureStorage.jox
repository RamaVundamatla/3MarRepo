    <JadeMethod name="setFromCMIF_TITransactionCntrl" id="d10b8066-b8b4-495c-9a49-800e525d10e9">
        <updating/>
        <source>setFromCMIF_TITransactionCntrl(_tiTransCntrl: CMIF_TITransactionController; _passport: CM_Passport input) updating;
//21 Jul 2017	cnwma1	TFS #5409:STWO - Storage Slab Auto Commercial Hold
vars
	ti : CM_TrackedItem;
begin
	inheritMethod(_tiTransCntrl, _passport);
	// CCMS DPH 2278 set this up before creating invoice lines where the quantity uses this
	if _tiTransCntrl.isKindOf(CMIF_StorageTransController) then
		self.setDaysCharged(_tiTransCntrl.CMIF_StorageTransController.daysCharged);
		ti :=_tiTransCntrl.myTrackedItem;
		ti.createFutureStorageStop(_tiTransCntrl,_passport); //21.07.2017 cnwma1 TFS #5409
	endif;
end;</source>
        <Parameter name="_tiTransCntrl" type="CMIF_TITransactionController"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
</Class>
