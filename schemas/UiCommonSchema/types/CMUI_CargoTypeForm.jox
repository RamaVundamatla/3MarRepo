    <JadeMethod name="setShtBlendingRecipes" id="4c025f00-0636-4e7a-8511-796aa0840c27">
        <source>setShtBlendingRecipes(_editMode : Boolean) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 May 2021	navndl1	Initial creation	TFS 51243

*/

vars

	cargoType : CM_CargoType;
	recipe : CM_Recipe;
	detailString : String;
	rowIndex : Integer;

begin

	if _editMode then
		cargoType := self.myProxyObject.CM_CargoType;
	else
		cargoType := self.myCurrentObject.CM_CargoType;
	endif;
	
	self.grpRecipeBtns.enabled := true;	
	self.tblRecipes.rows := self.tblRecipes.fixedRows;
	
	if cargoType &lt;&gt; null then
		foreach recipe in cargoType.allRecipes do
			detailString := recipe.getAttributeStringForDefArray( self.tblRecipes.allTblDataEntRows );
			rowIndex := self.tblRecipes.addItemObject(recipe, detailString);
		endforeach;
	endif;
	
	self.tblRecipes.row := 1;
	
	self.resetRecipeButtons();
	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_editMode" type="Boolean"/>
    </JadeMethod>
