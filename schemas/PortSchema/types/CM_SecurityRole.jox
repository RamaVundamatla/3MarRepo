        <source>getNoOfUserTermsRecursive(_numberOfTerms : Integer io);
// -------------------------------------------
// Created 08 December 2004 by cnwdvb1
// -------------------------------------------
vars

	
begin

	if self.myParentRole &lt;&gt; null then
		self.myParentRole.getNoOfUserTermsRecursive(_numberOfTerms);
	endif;
	
	_numberOfTerms := _numberOfTerms + self.allUserTerminals.size;


end;</source>
