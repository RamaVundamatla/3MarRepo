    <JadeMethod name="setUserHeading" id="7523827c-f2d9-4137-bf12-f6336834037f">
        <updating/>
        <source>setUserHeading(_searchFor, _replaceWith : String) updating, protected;
// ---------------------------------------------------------------------------
// Created:     11 August 2004	cnwth2
//
// Purpose:     Seek and replace
//			 
// ----------   ----------  --------------------------------------------------
vars
	newHeading,
	origHeading,
	searchStr,
	replaceStr	: String;
begin
	searchStr := _searchFor;
	replaceStr := _replaceWith;
	
	origHeading := self.userHeading;

	// first do a replace with case as is
	newHeading := origHeading.replaceWord(searchStr, replaceStr);
	if newHeading &lt;&gt; origHeading then
		
		self.userHeading := newHeading[1:60];
		return;
	endif;

	// now look for lower case version
	searchStr := _searchFor.toLower;
	replaceStr := _replaceWith;
// Par 10009
//	replaceStr := _replaceWith.toLower;

	newHeading := origHeading.replaceWord(searchStr, replaceStr);

	self.userHeading := newHeading[1:60];
	

end;</source>
        <access>protected</access>
        <Parameter name="_searchFor" type="String"/>
        <Parameter name="_replaceWith" type="String"/>
    </JadeMethod>
    <JadeMethod name="setUserShortHeading" id="3af41038-f254-4949-a287-b01293450db9">
        <updating/>
        <source>setUserShortHeading(_searchFor, _replaceWith : String) updating, protected;
// ---------------------------------------------------------------------------
// Created:     11 August 2004	cnwth2
//
// Purpose:     Seek and replace
//			 
// ----------   ----------  --------------------------------------------------
vars
	newHeading,
	origHeading,
	searchStr,
	replaceStr	: String;
begin
	searchStr := _searchFor;
	replaceStr := _replaceWith;
	
	origHeading := self.userShortHeading;

	// first do a replace with case as is
	newHeading := origHeading.replaceWord(searchStr, replaceStr);
	if newHeading &lt;&gt; origHeading then
	
		self.userShortHeading := newHeading[1:30]; //PAR 9842 string too long - was 60
		return;
	endif;

	// now look for lower case version
	searchStr := _searchFor.toLower;
	replaceStr := _replaceWith;
// Par 10009
//	replaceStr := _replaceWith.toLower;

	newHeading := origHeading.replaceWord(searchStr, replaceStr);

	self.userShortHeading := newHeading[1:30]; //PAR 9842 string too long - was 60
	
end;</source>
        <access>protected</access>
        <Parameter name="_searchFor" type="String"/>
        <Parameter name="_replaceWith" type="String"/>
    </JadeMethod>
    <JadeMethod name="systemHeading" id="f1b25b5c-e4b2-49ce-8249-c01fccffa5b5">
        <methodInvocation>mapping</methodInvocation>
        <source>systemHeading(set: Boolean; _value: String io) mapping;
// ---------------------------------------------------------------------------
// Created:     11 August 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars

begin
	if set then
		app.raiseSetVirtualError(class.name, method.name);
	else
		_value := self.myTerminologyTypeDtl.systemEntRowHeading;
	endif;

end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="validateForUpdate" id="ffe22f8f-de16-4ec9-ac12-aa551f520f48">
        <source>validateForUpdate();
// ---------------------------------------------------------------------------
// Created:     10 August 2004	cnwth2
//
// Purpose:     
//27/06/2022 		NAVDS20 			TFS 53760  DuplicateItem not Translatable			 
// ----------   ----------  --------------------------------------------------
vars
	existingDtl,
	realDtl			: CM_TerminologyDtl;
begin
	self.raiseExceptionIfNotTransient(method);
	
	if self.myTerminologyDef = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Terminology header is null');
		return;
	endif;
	
	if self.userHeading = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'heading', 'heading', null);
		app.raiseCMException(Input_required_field_heading, 'heading', null); // cnwdb2	PAR 35364
		return;
	endif;
	
	if self.myTerminologyTypeDtl = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Terminology detail object is null for dtl with heading :' &amp; self.userHeading);
		return;
	endif;
	
	realDtl := self.pxyGetRealObject();
	existingDtl := self.myTerminologyDef.allTerminologyDtls[self.rowName, self.rowName];
	
	if existingDtl &lt;&gt; null and realDtl = null then //creating new detail, but key already in use - this should never happen
		//app.raiseCMException2(DuplicateItem, 'Terminology Dtl: ' &amp; self.groupName &amp; '/' &amp; self.rowName, 'Terminology Header: ' &amp; self.myTerminologyDef.name, null, null); //27/06/2022 NAVDS20 TFS 53760
		// Terminology Dtl: %1 / %2 already exists for Terminology Header %3 : Termin_alread_exists_termin_he
		app.raiseCMException3(Termin_alread_exists_termin_he, self.groupName , self.rowName, self.myTerminologyDef.name, null, null); //27/06/2022 NAVDS20 TFS 53760
	endif;

	if (existingDtl &lt;&gt; null and realDtl &lt;&gt; null) and
	   (existingDtl &lt;&gt; realDtl) then //updating header to a key already in use - this also should never happen
		//app.raiseCMException2(DuplicateItem, 'Terminology Dtl: ' &amp; self.groupName &amp; '/' &amp; self.rowName, 'Terminology Header: ' &amp; self.myTerminologyDef.name, null, null); //27/06/2022 NAVDS20 TFS 53760
		// Terminology Dtl: %1 / %2 already exists for Terminology Header: %3 : Termin_alread_exists_termin_he
		app.raiseCMException3(Termin_alread_exists_termin_he, self.groupName , self.rowName, self.myTerminologyDef.name, null, null);//27/06/2022 NAVDS20 TFS 53760
	endif;
	
	
end;</source>
    </JadeMethod>
</Class>
