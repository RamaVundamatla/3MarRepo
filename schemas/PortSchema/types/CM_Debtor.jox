end;</source>
    </JadeMethod>
    <JadeMethod name="erase" id="e8dca8b7-b5eb-4541-8a11-d10fedf9db7b">
        <updating/>
        <source>erase(_eraseLevel: Integer) updating;
// ---------------------------------------------------------------------------
// Created:		August 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
//Date		Who		Reason
//13 September 2022	navpw1		TFS: 54565 (54384) - EUP - Inv Config - Invoice Surcharges
// ---------------------------------------------------------------------------

vars
	operator: CM_Operator;
	con		: CM_ConsigneeConsignor;
	carrier	: CM_Carrier;
	
	//15 Jul 2016	NDL	TFS 2329
	iter	: Iterator;
	cmqfCC	: CMQF_CashCredit;
	cmqfCR	: CMQF_CashReceipt;
	cmqfCT	: CMQF_CashTransactions;
	invLineDescMapping : CM_InvoiceLineDescMapping; // ### TFS 54571 05Dec2022 NAVPW1
	cmqfIC	: CMQF_InvoiceContract;
	
begin
	if self.isTransient then		// from 37200 review of 'erase' code
		inheritMethod(_eraseLevel);
		return;
	endif;
	
	foreach operator in self.operators do
		operator.debtor := self.bank.rootDebtor;
	endforeach;
	foreach con in self.consignors do
		con.setDebtor(self.bank.rootDebtor);
	endforeach;
	foreach carrier in self.allCarriers do //+ cnwmd1, CCMS 1067, Par 19913
		carrier.setDebtor(self.bank.rootDebtor);
	endforeach;
	
	//15 Jul 2016	NDL	TFS 2329
	iter := CMQF_CashCredit.instances.createIterator;
	while iter.next(cmqfCC) do
		if cmqfCC.allDebtors.includes(self) then
			cmqfCC.allDebtors.remove(self);
		endif;
	endwhile; 
	delete iter;
	
	iter := CMQF_CashReceipt.instances.createIterator;
	while iter.next(cmqfCR) do
		if cmqfCR.allDebtors.includes(self) then
			cmqfCR.allDebtors.remove(self);
		endif;
	endwhile; 
	delete iter;
	
	iter := CMQF_CashTransactions.instances.createIterator;
	while iter.next(cmqfCT) do
		if cmqfCT.allDebtors.includes(self) then
			cmqfCT.allDebtors.remove(self);
		endif;
	endwhile; 
	delete iter;
	
	// ### TFS 54571 05Dec2022 NAVPW1 - Start
	iter := CM_InvoiceLineDescMapping.instances.createIterator;
	while iter.next(invLineDescMapping) do
		if invLineDescMapping.myDebtor = self then
			delete invLineDescMapping;
		endif;
	endwhile; 
	delete iter;
	// ### TFS 54571 05Dec2022 NAVPW1 - End
	
	iter := CMQF_InvoiceContract.instances.createIterator;
	while iter.next(cmqfIC) do
		if cmqfIC.allDebtors.includes(self) then
			cmqfIC.allDebtors.remove(self);
		endif;
	endwhile;
	delete iter;
	
	self.allInvTypeDebtorSeparations.purge; // ### TFS 54565 (54384) 29Aug2022 NAVPW1
	
	inheritMethod(_eraseLevel);
	
epilog
	delete iter;
	
end;</source>
        <Parameter name="_eraseLevel" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="exportAsXMLDocIgnoreAttr" id="0afd9b8d-7913-4d65-9c35-aac52035d6ad">
        <source>exportAsXMLDocIgnoreAttr(_property: Property input): Boolean;

vars

begin
	if _property = CM_Debtor::allCarriers then
		return true;
	elseif _property = CM_Debtor::allConsolidatedInvoiceLineDesc then
		return true;
	elseif _property = CM_Debtor::allContacts then
		return true;
	elseif _property = CM_Debtor::allCustomsAgents then
		return true;
	elseif _property = CM_Debtor::allDebtorBankInvTypeDtls then
		return true;
	elseif _property = CM_Debtor::allDebtorInvLineTypes then
		return true;
	elseif _property = CM_Debtor::allDebtorInvTypes then
		return true;
	elseif _property = CM_Debtor::allDebtorMaps then
		return true;
	elseif _property = CM_Debtor::allDebtorTerminals then
		return true;
	elseif _property = CM_Debtor::allDebtorTypes then
		return true;
	elseif _property = CM_Debtor::allInvoices then
		return true;
	elseif _property = CM_Debtor::allMappedInvoiceLineTypes then
		return true;
	elseif _property = CM_Debtor::allOrganisations then
		return true;
	elseif _property = CM_Debtor::allSpecialReleaseTxnTypes then
		return true;
	elseif _property = CM_Debtor::allDebtorInvLineTypes then
		return true;
	elseif _property = CM_Debtor::allDebtorInvLineTypes then
		return true;
	elseif _property = CM_Debtor::consignors then
		return true;
	elseif _property = CM_Debtor::invoiceLines then
		return true;
	elseif _property = CM_Debtor::invoicesByStatus then
		return true;
	elseif _property = CM_Debtor::invoicesByType then
		return true;
	elseif _property = CM_Debtor::myServiceBroker then
		return true;
	elseif _property = CM_Debtor::operators then
		return true;
	endif;


	return inheritMethod(_property);
end;
</source>
        <Parameter name="_property" type="Property" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="exportAsXMLInverseRef" id="64495ce2-0410-47fe-ba02-d23e0f56dd01">
        <source>exportAsXMLInverseRef(_property: Reference): Integer protected;

vars

begin
	if _property = CM_Debtor::myTermsOfTrade then
		return ExportAsParent;
	endif;
	
	return inheritMethod(_property);
end;
</source>
        <access>protected</access>
        <Parameter name="_property" type="Reference"/>
