    <JadeMethod name="createDelaysDictionary" id="df39dffc-628c-4cf5-9f14-3650aae6a753">
        <source>createDelaysDictionary(_dd: DynaDictionary output) protected;
/*
	Purpose:			
	Parameters:			
	Return Value:		

Date			Who		Reason
05 August 2008	concms1	Initial creation
*/

vars

begin
	create _dd transient; 
	_dd.setMembership (CM_Delay);
	_dd.addMemberKey (CM_Delay::myDelayType.name, null, null);
	_dd.addMemberKey (CM_Delay::myMachine.name, null, null);
	_dd.endKeys (true);
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_dd" type="DynaDictionary" usage="output"/>
    </JadeMethod>
    <JadeMethod name="doLoad" id="4eee2360-85d8-4cf3-bbd3-4b3e116311a4">
        <source>doLoad() protected;
/*
	Purpose:			
	Parameters:			
	Return Value:		

Date		Who		Reason
22 July 2008	concms1	Initial creation
*/

vars
	cranesArray	: ObjectArray;
	dd			: DynaDictionary;
begin
	inheritMethod;
	
	self.setupTable_Voyage();

	// get cranes we need to display data for
	self.getCranes (cranesArray);
	
	// get delays for the voyage
	self.getDelays (dd);
	
	// display move data in table
	self.setupTable_Moves (cranesArray);
		
	// display data in hours table
	self.setupTable_Hours (cranesArray, dd);

	// display data in comments table
	self.setupTable_Comments (dd);

	// display data in times table
	self.setupTable_Times;
epilog
	delete cranesArray;
	delete dd;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="getMoveData" id="64108c92-e9ca-45cc-817c-62ba9d73395e">
        <source>getMoveData(_cranesArray :ObjectArray; _dataArray :ObjectArray output;_totalsArray :DecimalArray output)protected;
/*
	Purpose:		Populate arrays that will be used to print table	
	Parameters:		_cranesArray	- one entry per crane, index corresponds to column in table 
									  the cranes data will be displayed in
					_dataArray		- array
					_totalsArray
	Return Value:		

Date		Who		Reason
24 July 2008	concms1	Initial creation
*/

vars
	voyage		:CM_Voyage;
	index, size	:Integer;
begin
	voyage	:= self.getVoyage;
	
	create _dataArray transient;
	create _totalsArray transient;	_totalsArray [self.CRANE_VALUES_SIZE] := null;	// so we don't have to check size
		
	size := _cranesArray.size;
	
	foreach index in 1 to size do
		self.getMoveDataForCrane (_cranesArray, index, _dataArray);
	endforeach;
	
	self.getMoveDataTotals (_totalsArray);

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_cranesArray" type="ObjectArray"/>
        <Parameter name="_dataArray" type="ObjectArray" usage="output"/>
        <Parameter name="_totalsArray" type="DecimalArray" usage="output"/>
    </JadeMethod>
    <JadeMethod name="getMoveDataForCrane" id="a28d9450-e614-47f5-9ced-c242b88d18d2">
        <source>getMoveDataForCrane(_cranesArray :ObjectArray; _index :Integer; _array :ObjectArray input) protected;
/*
	Purpose:		we accumulate values in the array in the order they will be printed
					if print order changes this method must change to
	Parameters:		_crane	- the crane to get data for
					_array	_ array of decimal arrays containing data for each crane
	Return Value:		

Date		Who		Reason
24 July 2008	concms1	Initial creation
28/10/2010		cnwcs5	par 26154 - correct error where voyage was not being checked while adding up crane totals
*/

vars
	voyage		:CM_Voyage;
	crane		:CM_Crane;
// not used	kpi			:CM_KPI;
// not used	kpiBay		:CM_KPIVoyageBayCrane;
	kpiCrane 	: CM_KPIVoyageCraneShift;
	valuesArray	:DecimalArray;
	value		:Decimal [23, 8];
	index, total, indexTwinLift,
// not used	indexHatchLid,
	indexTotal, amount	:Integer;
// not used	isAftBay, 
	firstKPI 	: Boolean;
	iter		: Iterator;			//28/10/2010 cnwcs5	par 26154
begin
	firstKPI := true;
	voyage	:= self.getVoyage;
	crane	:= _cranesArray[_index].CM_Crane;
	
	create valuesArray transient;
	
	valuesArray[self.CRANE_VALUES_SIZE] := null;
	
	_array.add (valuesArray);
	
	iter := crane.allVoyageKPICraneShifts.createIterator;					//28/10/2010 cnwcs5	par 26154
	crane.allVoyageKPICraneShifts.startKeyGeq (voyage, null, null, iter);	//28/10/2010 cnwcs5	par 26154
	
	// go through the kpi bay collection and add up totals for crane
//	foreach kpi in voyage.allVoyageKPIEntities where kpi.type = KPI_Type_VoyageBay do
	//foreach kpi in voyage.allVoyageKPIEntities where kpi.type = KPI_Type_VoyageShift do
	//foreach kpiCrane in crane.allVoyageKPICraneShifts discreteLock do		//28/10/2010 cnwcs5	par 26154
	while iter.next (kpiCrane) do
//		kpiBay	:= kpi.CM_KPIVoyageBayCrane;
//		kpiCrane := kpi.CM_KPIVoyageCraneShift;
		
//		if kpiCrane.myCrane &lt;&gt; crane then
//			continue;
//		endif;
		
		//isAftBay := kpiCrane.myBayVoyage.isAftBay(); // PAR 22125
		
		if kpiCrane.myVoyage &lt;&gt; voyage then	//28/10/2010 cnwcs5	par 26154
			break;							//28/10/2010 cnwcs5	par 26154
		endif;								//28/10/2010 cnwcs5	par 26154
		
		index := 0;
		
		// Discharged 20, 30, 40, 45, 53
		index := index + 1;	self.updateArrayEntry (valuesArray, index, kpiCrane.getDisch20AllItems());
		index := index + 1;	self.updateArrayEntry (valuesArray, index, kpiCrane.getDisch30AllItems());
		/*
		if isAftBay then // PAR 22125
			index := index + 1;	self.updateArrayEntry (valuesArray, index, 0); // 40 // PAR 22125
			index := index + 1;	self.updateArrayEntry (valuesArray, index, 0); // 45 // PAR 22125
			index := index + 1;	self.updateArrayEntry (valuesArray, index, 0); // 53 // PAR 22125
		else
		*/
			index := index + 1;	self.updateArrayEntry (valuesArray, index, kpiCrane.getDisch40AllItems());
			index := index + 1;	self.updateArrayEntry (valuesArray, index, kpiCrane.getDisch45AllItems());
			index := index + 1;	self.updateArrayEntry (valuesArray, index, kpiCrane.getDisch53AllItems());
		
		//endif;
		
		// Loaded 20, 30, 40, 45, 53
		index := index + 1;	self.updateArrayEntry (valuesArray, index, kpiCrane.getLoad20AllItems());
		index := index + 1;	self.updateArrayEntry (valuesArray, index, kpiCrane.getLoad30AllItems);
		/*
		if isAftBay then // PAR 22125
			index := index + 1;	self.updateArrayEntry (valuesArray, index, 0); // 40 // PAR 22125
			index := index + 1;	self.updateArrayEntry (valuesArray, index, 0); // 45 // PAR 22125
			index := index + 1;	self.updateArrayEntry (valuesArray, index, 0); // 53 // PAR 22125
		else
		*/
			index := index + 1;	self.updateArrayEntry (valuesArray, index, kpiCrane.getLoad40AllItems);
			index := index + 1;	self.updateArrayEntry (valuesArray, index, kpiCrane.getLoad45AllItems);
			index := index + 1;	self.updateArrayEntry (valuesArray, index, kpiCrane.getLoad53AllItems);
		//endif;
		// Out of Gauge items
		index := index + 1; self.updateArrayEntry (valuesArray, index, kpiCrane.getAllOD);
		// Total Containers
		index := index + 1; self.updateArrayEntry (valuesArray, index, kpiCrane.getTotalContainers);
		// discharged TEU
		index := index + 1; 
		value := kpiCrane.getDischargeAllTEU();
		self.updateArrayEntry (valuesArray, index, value);	
		total := value.Integer;
		// load TEU
		index := index + 1; 
		value := kpiCrane.getLoadAllTEU();
		self.updateArrayEntry (valuesArray, index, value);		
		total := total + value.Integer;
		// total TEU - not using kpiCrane.totalTEU as think it may include extras etc
		index := index + 1; self.updateArrayEntry (valuesArray, index, total);
		// restows - SOB 20, 30, 35, 40, 53
		index := index + 1;	self.updateArrayEntry (valuesArray, index, kpiCrane.getSOB20AllItems);
		index := index + 1;	self.updateArrayEntry (valuesArray, index, kpiCrane.getSOB30AllItems);
		/*
		if isAftBay then
			index := index + 1;	self.updateArrayEntry (valuesArray, index, 0); // 40 // PAR 22125
			index := index + 1;	self.updateArrayEntry (valuesArray, index, 0); // 45 // PAR 22125
			index := index + 1;	self.updateArrayEntry (valuesArray, index, 0); // 53 // PAR 22125
		else
		*/
			index := index + 1;	self.updateArrayEntry (valuesArray, index, kpiCrane.getSOB40AllItems);
			index := index + 1;	self.updateArrayEntry (valuesArray, index, kpiCrane.getSOB45AllItems);
			index := index + 1;	self.updateArrayEntry (valuesArray, index, kpiCrane.getSOB53AllItems);
		//endif;
		
		// restows - DLR  20, 30, 35, 40, 53
		index := index + 1;	self.updateArrayEntry (valuesArray, index, kpiCrane.getDLR20AllItems);
		index := index + 1;	self.updateArrayEntry (valuesArray, index, kpiCrane.getDLR30AllItems);
		/*
		if isAftBay then
			index := index + 1;	self.updateArrayEntry (valuesArray, index, 0); // 40 // PAR 22125
			index := index + 1;	self.updateArrayEntry (valuesArray, index, 0); // 45 // PAR 22125
			index := index + 1;	self.updateArrayEntry (valuesArray, index, 0); // 53 // PAR 22125
		else
		*/
			index := index + 1;	self.updateArrayEntry (valuesArray, index, kpiCrane.getDLR40AllItems);
			index := index + 1;	self.updateArrayEntry (valuesArray, index, kpiCrane.getDLR45AllItems);
			index := index + 1;	self.updateArrayEntry (valuesArray, index, kpiCrane.getDLR53AllItems);
		//endif;
		// total restows
		index := index + 1;	
		self.updateArrayEntry (valuesArray, index, (kpiCrane.getDLRAllItems + kpiCrane.getSOBAllItems));
		// twin lift %	- calculated by CM_KPIVoyage so save off index so we can update it later	
		index 			:= index + 1; 
		indexTwinLift	:= index;	
		valuesArray [indexTwinLift] := kpiCrane.getTwinLiftPercentage();
		
		// hatch lid moves
		index 			:= index + 1;	
		self.updateArrayEntry (valuesArray, index, kpiCrane.movesLid);
		// hatch lid moves are stored on CM_KPIVoyageShift so save off index so we can update it later
//		indexHatchLid	:= index;
		// lashing bin moves
		index := index + 1;	
		// The bin moves are stored against the voyage so only show for first crane
		if firstKPI and _index = 1 then
			self.updateArrayEntry (valuesArray, index, kpiCrane.getNumLashingBinMoves);	
		else
			self.updateArrayEntry (valuesArray, index, 0);	
		endif;
		// #
		index := index + 1;	self.updateArrayEntry (valuesArray, index, 0); // kpiCrane.x_getLashingBinCount);	
		// last entry is total moves - we can't update that here so save off the index for later
		index 		:= index + 1;
		amount := kpiCrane.getTotalMoves ();
//		if firstKPI and _index = 1 then
//			amount := amount + kpiCrane.getNumLashingBinMoves;
//		endif;
		
		self.updateArrayEntry (valuesArray, index, amount);
		firstKPI := false;
	//endforeach;		//28/10/2010 cnwcs5	par 26154
	endwhile;			//28/10/2010 cnwcs5	par 26154
	
	if indexTotal = null then
		// there was no data for this crane
		// most likely cause is bad data in test system
		return;
	endif;
	
	/*
	// now work out hatch lid moves - we have saved off the position in the array we need to store them in
	foreach kpi in voyage.allVoyageKPIEntities where kpi.type = KPI_Type_VoyageShift do	
		if kpi.CM_KPIVoyageCraneShift.myCrane &lt;&gt; crane then
			continue;
		endif;
		
		self.updateArrayEntry (valuesArray, indexHatchLid, kpi.CM_KPIVoyageCraneShift.movesLid);
	endforeach;
	*/
//	kpi	:= voyage.getKPIByTypeNEW(KPI_Type_Voyage);
	
	// now work out twin lift percentage - we have saved off the position in the array we need to store them in
//	if kpi &lt;&gt; null then
//		valuesArray [indexTwinLift] := kpi.CM_KPIVoyageTotals.getTwinLiftPercentage_Crane (crane);
//	endif;
	
	// the last entry is total moves	
//	if kpi &lt;&gt; null then
//		valuesArray [indexTotal] := kpi.CM_KPIVoyageTotals.getTotalMoves_Crane (crane);
//	endif;
epilog
	delete iter;
end;</source>
        <access>protected</access>
        <Parameter name="_cranesArray" type="ObjectArray"/>
        <Parameter name="_index" type="Integer"/>
        <Parameter name="_array" type="ObjectArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getMoveDataTotals" id="aa15fe51-2952-45ea-ab1a-108eaae42118">
        <source>getMoveDataTotals(_array :DecimalArray input) protected;
/*
	Purpose:		we accumulate values in the array in the order they will be printed
					if print order changes this method must change to
					this gets values for last column
	Parameters:		_array	_ array of decimal arrays containing data for each crane
	Return Value:		

Date		Who		Reason
24 July 2008	concms1	Initial creation
*/

vars
	voyage			:CM_Voyage;
	kpi				:CM_KPIVoyageTotals;
	index, total	:Integer;
	value			:Decimal[23,8];
begin
	voyage	:= self.getVoyage;
	kpi		:= voyage.getKPIByType(KPI_Type_Voyage).CM_KPIVoyageTotals;
	
	if kpi = null then
		return;	// what else can we do?
	endif;	
		
	// Discharged 20, 30, 40, 45, 53
	index := index + 1;	self.updateArrayEntry (_array, index, kpi.getDisch20AllItems);
	index := index + 1;	self.updateArrayEntry (_array, index, kpi.getDisch30AllItems);
	index := index + 1;	self.updateArrayEntry (_array, index, kpi.getDisch40AllItems);
	index := index + 1;	self.updateArrayEntry (_array, index, kpi.getDisch45AllItems);
	index := index + 1;	self.updateArrayEntry (_array, index, kpi.getDisch53AllItems);
	// Loaded 20, 30, 40, 45, 53
	index := index + 1;	self.updateArrayEntry (_array, index, kpi.getLoad20AllItems);
	index := index + 1;	self.updateArrayEntry (_array, index, kpi.getLoad30AllItems);
	index := index + 1;	self.updateArrayEntry (_array, index, kpi.getLoad40AllItems);
	index := index + 1;	self.updateArrayEntry (_array, index, kpi.getLoad45AllItems);
	index := index + 1;	self.updateArrayEntry (_array, index, kpi.getLoad53AllItems);
	// Out of Gauge items
	index := index + 1; self.updateArrayEntry (_array, index, kpi.getAllOD);
	// Total Containers
	index := index + 1; self.updateArrayEntry (_array, index, kpi.getTotalContainers);
	// twin lift percentage
//	index := index + 1; self.updateArrayEntry (_array, index, kpi.getTwinLiftPercentage);
	// total container moves
//	index := index + 1; self.updateArrayEntry (_array, index, kpi.getTotalContainerMoves);
	// discharged TEU
	index := index + 1; 
	value := kpi.getDischargeAllTEU;
	self.updateArrayEntry (_array, index, value);	
	total := value.Integer;
	// load TEU
	index := index + 1; 
	value := kpi.getLoadAllTEU;
	self.updateArrayEntry (_array, index, value);		
	total := total + value.Integer;
	// total TEU - not using kpiBay.totalTEU as think it may include extras etc
	index := index + 1; self.updateArrayEntry (_array, index, total);
	// restows - SOB 20, 30, 35, 40, 53
	index := index + 1;	self.updateArrayEntry (_array, index, kpi.getSOB20AllItems);
	index := index + 1;	self.updateArrayEntry (_array, index, kpi.getSOB30AllItems);
	index := index + 1;	self.updateArrayEntry (_array, index, kpi.getSOB40AllItems);
	index := index + 1;	self.updateArrayEntry (_array, index, kpi.getSOB45AllItems);
	index := index + 1;	self.updateArrayEntry (_array, index, kpi.getSOB53AllItems);
	// restows - DLR  20, 30, 35, 40, 53
	index := index + 1;	self.updateArrayEntry (_array, index, kpi.getDLR20AllItems);
	index := index + 1;	self.updateArrayEntry (_array, index, kpi.getSOB30AllItems);
	index := index + 1;	self.updateArrayEntry (_array, index, kpi.getSOB40AllItems);
	index := index + 1;	self.updateArrayEntry (_array, index, kpi.getSOB45AllItems);
	index := index + 1;	self.updateArrayEntry (_array, index, kpi.getSOB53AllItems);
	// total restows
	index := index + 1;	self.updateArrayEntry (_array, index, (kpi.getDLRAllItems + kpi.getSOBAllItems));	
	// twin lift percentage
	index := index + 1; self.updateArrayEntry (_array, index, kpi.getTwinLiftPercentage);
	// hatch lid
	index := index + 1;	self.updateArrayEntry (_array, index, kpi.getTotalLidMoves);
	// lashing bin moves
	index := index + 1;	self.updateArrayEntry (_array, index, kpi.getNumLashingBinMoves());
	// #
	index := index + 1;	self.updateArrayEntry (_array, index, 0); //kpi.x_getLashingBinCount);
	// totals moves
	index := index + 1;	self.updateArrayEntry (_array, index, kpi.getTotalMoves());

end;</source>
        <access>protected</access>
        <Parameter name="_array" type="DecimalArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="run" id="9c3c14d0-1a8d-4a24-a4df-a8a856e0216b">
        <updating/>
        <source>run(_isPrintPreview: Boolean; _isCSV: Boolean; _extraDetail: CM_ExtraDetail): Binary updating;
/*

Date			Who		Reason
22 July 2008	concms1	Par 17592 / 17593 Initial creation
*/

vars

begin
	app.printer.setMargins(Print_Portrait, 0, 0, 10, 10);

	return inheritMethod(_isPrintPreview, _isCSV, _extraDetail);
epilog

end;</source>
