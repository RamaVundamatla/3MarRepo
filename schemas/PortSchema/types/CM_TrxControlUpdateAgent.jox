    <JadeMethod name="trxUpdateHoldVessel" id="b73bd889-c9d6-461e-a5d7-f14119c27f2f">
        <updating/>
        <source>trxUpdateHoldVessel(_pxyHold : CM_VesselHold input; 
					_realHold : CM_VesselHold output;
					_passport : CM_Passport input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 February 2013	cnwer1	Initial creation HAT 2189
14/07/2025	naviv1	35226	MTN - Usage of Iterator.getCurrentKeys  
*/

vars
	hold	: CM_Hold;
	realHold : CM_VesselHold;
	newBayOrdinal,
	bayOrdinal,
	newHoldOrdinal,
	holdOrdinal,
	oldHoldOrdinal: Integer;
	oldHoldOrdinals,
	newHoldOrdinals,
	oldBayOrdinals,
	newBayOrdinals : IntegerArray;
	realVesselStructure : CM_CellularVesselStructure;
	i, numBays	: Integer;
	bay, realBay : CM_Bay;
	baysToDelete : CM_BaySet;
	baysByOrdinal,
	holdsByOrdinal : DynaDictionary;
	iter : Iterator;
	id :String;
	pxyHatchLid,realHatchLid : CM_HatchLid;
begin

	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);


	app.setContinueCMExceptions(false);
	
	create oldHoldOrdinals transient;
	create newHoldOrdinals transient;
	create oldBayOrdinals transient;
	create newBayOrdinals transient;
	create baysToDelete transient;
	
	create holdsByOrdinal transient;
	holdsByOrdinal.setMembership(CM_Hold);
	holdsByOrdinal.addExternalKey(Integer,4, false,false);
	holdsByOrdinal.endKeys(false);
	
	create baysByOrdinal transient;
	baysByOrdinal.setMembership(CM_Bay);
	baysByOrdinal.addExternalKey(Integer,4, false,false); //ordinal
	baysByOrdinal.addExternalKey(String,20, false,false); //id
	baysByOrdinal.endKeys(false);
	
	realVesselStructure:=_pxyHold.myCellularVesselStructure;
	
	foreach hold in realVesselStructure.allHolds discreteLock do
		oldHoldOrdinals.add(hold.ordinalHold);
		newHoldOrdinals.add(hold.ordinalHold);
	endforeach;
	
	foreach bay in realVesselStructure.allBaysByOrdinal discreteLock do
		oldBayOrdinals.add(bay.ordinalBay);
		newBayOrdinals.add(bay.ordinalBay);
	endforeach;
	
	realHold:=_pxyHold.pxyGetRealObject.CM_VesselHold;
	numBays:= _pxyHold.allBays.size;
	// its an update
	if realHold &lt;&gt; null then
		oldHoldOrdinal:=realHold.ordinalHold;
		if oldHoldOrdinal &lt;&gt; _pxyHold.ordinalHold then
			newHoldOrdinals.remove(_pxyHold.ordinalHold);
			newHoldOrdinals.insert(realHold.ordinalHold,_pxyHold.ordinalHold);
		endif;
		
		realHold.allBays.copy(baysToDelete);
		
		foreach bay in _pxyHold.allBays do
			realBay:=bay.pxyGetRealObject.CM_Bay;
			if realBay &lt;&gt; null then
				baysToDelete.remove(realBay);
				if realBay.ordinalBay &lt;&gt;  bay.ordinalBay then
					// hold has moved position have to change ordinal holds
					//oldBayOrdinals.remove(realBay.ordinalBay);
					newBayOrdinals.remove(bay.ordinalBay );
					newBayOrdinals.insert(realBay.ordinalBay,bay.ordinalBay);
				endif;
			else
				// hold is being inserted + 1 from _pxyHold.ordinalHold
				foreach bayOrdinal in oldBayOrdinals reversed do
					if bayOrdinal &lt; bay.ordinalBay then
						break;
					endif;
					newBayOrdinals[bayOrdinal] := bayOrdinal + numBays;
				endforeach;
			endif;
		endforeach;
	else
		// hold is being inserted + 1 from _pxyHold.ordinalHold
		foreach holdOrdinal in oldHoldOrdinals reversed do
			if holdOrdinal &lt; _pxyHold.ordinalHold then
				break;
			endif;
			newHoldOrdinals[holdOrdinal] := holdOrdinal + 1;
		endforeach;
		foreach bay in _pxyHold.allBays do
			// hold is being inserted + 1 from _pxyHold.ordinalHold
			foreach bayOrdinal in oldBayOrdinals reversed do
				if bayOrdinal &lt; bay.ordinalBay then
					break;
				endif;
				newBayOrdinals[bayOrdinal] := bayOrdinal + numBays;
			endforeach;
		endforeach;
	endif;
	
	//have to insert/update all the other hold ordinals so not to get duplicate key errors
	//write "holds";
	i:=1;
	foreach holdOrdinal in oldHoldOrdinals do
		newHoldOrdinal:=newHoldOrdinals[i];
		if holdOrdinal &lt;&gt; newHoldOrdinal then
			realHold:=realVesselStructure.allHolds[holdOrdinal].CM_VesselHold;
			if realHold &lt;&gt; null then
				holdsByOrdinal.putAtKey(newHoldOrdinal,realHold);
			endif;
		endif;
		i:=i+1;
	endforeach;
	
	//remove any bays that have been deleted
	//write "bays to delete";
	foreach bay in baysToDelete do
		//write bay.ordinalBay;
		oldBayOrdinals.remove(bay.ordinalBay);
		newBayOrdinals.remove(newBayOrdinals.last);
	endforeach;
	
	//write "bays" &amp; oldBayOrdinals.size.String;
	i:=1;
	foreach bayOrdinal in oldBayOrdinals do
		newBayOrdinal:=newBayOrdinals[i];
		if bayOrdinal &lt;&gt; newBayOrdinal then
		//	write bayOrdinal.String &amp; Tab  &amp;newBayOrdinal .String;		
			bay:= realVesselStructure.allBaysByOrdinal[bayOrdinal];
			if bay &lt;&gt; null then
				id := ((newBayOrdinal *2) -1).padLeadingWith("0",2);
				baysByOrdinal.putAtKey(newBayOrdinal,id,bay);
			endif;
		endif;
		i:=i+1;
	endforeach;
	
	beginTransaction;
	
	iter := holdsByOrdinal.createIterator;
	while iter.next(hold) do
		iter.getCurrentKeys(newHoldOrdinal); //MTN-35226
		hold.CM_VesselHold.updateOrdinalNoDups(newHoldOrdinal);
	endwhile;
	
	delete iter;
	
	baysToDelete.purge;
	
	delete iter;
	iter := baysByOrdinal.createIterator;
	while iter.next(bay) do
		iter.getCurrentKeys(newBayOrdinal,id); //MTN-35226
		bay.CM_BayDefn.updateOrdinalIdsNoDups(newBayOrdinal,id);
		if _passport.hasErrors then
			return;
		endif;
		
	endwhile;
	
	//create hold bays have to update all the bay ordinals in the other holds so not to get duplicate key errors
	
	//create new hold and new bays
	
	_realHold:=_pxyHold.pxyGetRealObject;
	if _realHold = null then
		create realHold persistent;
		realHold.setForCreate(_pxyHold);
		_realHold:=realHold;
	// don't need to update ordinals have already been changed
	endif;
	
	if _passport.hasErrors then
		return;
	endif;
	
	//create update bays
	foreach bay in _pxyHold.allBays discreteLock do
		realBay:=bay.pxyGetRealObject;
		if  realBay = null then
			app.myUtilityCA.utlCreateBay(bay.CM_BayDefn,realBay,realVesselStructure,_passport);
		else
			app.myUtilityUA.utlUpdateBay(true,bay.CM_BayDefn,_passport); 
		endif;		
		
		if _passport.hasErrors then
			return;
		endif;
		
		foreach pxyHatchLid in bay.allHatchLids discreteLock do
			realHatchLid:=pxyHatchLid.pxyGetRealObject; 
			if realHatchLid = null then
				app.myUtilityCA.utlCreateHatchLid(pxyHatchLid, realHatchLid,realVesselStructure,_passport);
			else
				app.myUtilityUA.utlUpdateHatchLid(pxyHatchLid,_passport);
			endif;
			
			if _passport.hasErrors then
				return;
			endif;
		endforeach;
	endforeach;
	
	if _passport.hasErrors then
		return;
	endif;
	
	// set bay forward/aft references;
	realVesselStructure.updateBayLinks();
	
	self.updateObjectEdition(realVesselStructure); // PAR 32286 - need a note for Jade when the hold is update by Web Service
epilog

	self.finaliseActivityWithPassport(_passport);
	
	delete oldHoldOrdinals;
	delete newHoldOrdinals;
	delete oldBayOrdinals;
	delete newBayOrdinals;
	delete baysToDelete;
	delete baysByOrdinal;
	delete holdsByOrdinal;
	delete iter;
end;</source>
        <Parameter name="_pxyHold" type="CM_VesselHold" usage="input"/>
        <Parameter name="_realHold" type="CM_VesselHold" usage="output"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
