    <JadeMethod name="getDisplayStringForAttribute" id="e2523f50-3ee2-46fe-998f-b6107466a395">
        <source>getDisplayStringForAttribute(_attrName :String; _short:Boolean) :String;
// ---------------------------------------------------------------------------
// Created:     26 June 2002 by cnwth2
//
// Purpose:     
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	if _attrName = ETRow_CargoType then
		return self.myCargoType.description;

	elseif _attrName = ETRow_Id then
		return self.id.String;
	elseif _attrName = ETRow_IsoType then
		return self.isoType.String;		
	elseif _attrName = ETRow_MyProduct then
		return self.myProduct.code &amp; '  ' &amp; self.myProduct.description;
	elseif _attrName = ETRow_Remarks then
		return	self.remarks;
	elseif _attrName = ETRow_Quantity then
		return self.quantity.String;
	elseif _attrName = ETRow_Volume then
		return self.volume.String;
	elseif _attrName = ETRow_WeightTareTonnes then
		return (self.weight /1000).asStringWeightJMT(); // cnwrd1 ccms JMT 1060 Imp Measurements
	elseif _attrName = ETRow_WeightTotal then
		return self.weight.asStringWeightJMT();	 	// cnwrd1 ccms JMT 1060 Imp Measurements
	elseif _attrName = ETRow_GeneratorType then		// CCMS SFW1039 PAR18889 - US Customs &amp; Border Protection messaging changes.
		return self.myGeneratorType.description;
	elseif _attrName = ETRow_CouType then			// CCMS SFW1039 PAR18889 - US Customs &amp; Border Protection messaging changes.
		app.couTypeEnumToString(self.couType);
	elseif _attrName = ETRow_TrailerType or _attrName = ETRow_MyTrailerType then	// 17 Oct 2012	NDL	Par 30095
		if self.myTrailerType &lt;&gt; null then
			return self.myTrailerType.description;
		else
			return null;
		endif;
	endif;
	
	
	return inheritMethod(_attrName, _short);
end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
