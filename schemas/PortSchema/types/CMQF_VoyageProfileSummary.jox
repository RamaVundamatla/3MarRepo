<Class name="CMQF_VoyageProfileSummary" id="1eeb2cb4-646c-4e68-9252-cdee38922608">
    <superclass name="CMQF_VoyageSummary"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>CCMS #1036</text>
    <DbClassMap file="cmtrans"/>
    <JadeMethod name="filterForActualSummary" id="80a5e892-2706-48aa-81ff-d348a0e3f283">
        <updating/>
        <source>filterForActualSummary(_voySummaryDict: CMIF_VoyageSummaryByValueDict input) updating;
// ---------------------------------------------------------------------------
// Created:     12 May 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
vars
	hold				: CM_Hold;
	bay					: CM_Bay;
	slotController		: CM_SlotController;
	ti					: CM_TrackedItem;
	summaryObj			: CMIF_VoyageSummary;
	querySelf			: CMQF_VoyageProfileSummary;
	breakOut			: Boolean;
	filterLoadPort		: String;
	voyage				: CM_Voyage;
	edition 			: Integer;	//18 July 2016	NDL	TFS 2329
	invalid 			: Boolean;	//18 July 2016	NDL	TFS 2329
begin
	querySelf := self;
	
	on Exception do app.handleDeletedObject( exception, hold, invalid );	//18 July 2016	NDL	TFS 2329

	//filterLoadPort :=
	foreach hold in querySelf.allHolds do
	
		//18 July 2016	NDL	TFS 2329
		invalid := false;
		edition := hold.edition;
		if invalid then
			continue;
		endif;
		
		foreach bay in hold.allBays do
			if not bay.isKindOf(CM_BayVoyage) then
				continue;
			endif;
	
			foreach slotController in bay.CM_BayVoyage.allSlotControllersByOrdinal discreteLock do
				foreach ti in slotController.allTrackedItems where ti.myPrimaryActualLocation = slotController do
					summaryObj := querySelf.getSummaryObjectForOrder(_voySummaryDict, ti, null, null);
					if summaryObj &lt;&gt; null then
						self.updateMonitor(breakOut);
						summaryObj.totalSelf(ti);	
					endif;	
				endforeach;
			endforeach;
		endforeach;
	endforeach;

end;</source>
        <Parameter name="_voySummaryDict" type="CMIF_VoyageSummaryByValueDict" usage="input"/>
    </JadeMethod>
    <JadeMethod name="filterForLoadDischarge" id="393e261d-0c48-4072-a3bf-3ddd95626403">
        <updating/>
        <source>filterForLoadDischarge(_voySummaryDict: CMIF_VoyageSummaryByValueDict input) updating;
// ---------------------------------------------------------------------------
// Created:     12 May 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
vars
	hold			: CM_Hold;
	bay				: CM_Bay;
	slotController	: CM_SlotController;
	slotRequest		: CM_SlotRequest;
	ti				: CM_TrackedItem;
	summaryObj		: CMIF_VoyageSummary;
	wle				: CM_WorkListEntry;
	querySelf			: CMQF_VoyageProfileSummary;
	breakOut			: Boolean;
	edition 		: Integer;	//18 July 2016	NDL	TFS 2329
	invalid 		: Boolean;	//18 July 2016	NDL	TFS 2329
begin
	querySelf := self;
	
	on Exception do app.handleDeletedObject( exception, hold, invalid );	//18 July 2016	NDL	TFS 2329
	
	//nesting from hell here - but no other way really
	foreach hold in querySelf.allHolds do
	
		//18 July 2016	NDL	TFS 2329
		invalid := false;
		edition := hold.edition;
		if invalid then
			continue;
		endif;
		
		foreach bay in hold.allBays do
			foreach slotController in bay.CM_BayVoyage.allSlotControllersByOrdinal discreteLock do
				if slotController.isFortyBack then
					continue;
				endif;
				
				if querySelf.loadDischargeOption = querySelf.MODE_OPT_DISCHARGE then
					foreach slotRequest in slotController.allSlotRequestsDischarge do
						foreach wle in slotRequest.allWorkListEntries do
							ti := wle.myTrackedItem;
							summaryObj := querySelf.getSummaryObjectForOrder(_voySummaryDict, ti, null, null);
							if summaryObj &lt;&gt; null then
								self.updateMonitor(breakOut);
								summaryObj.totalSelf(ti.CM_Container);
							endif;	
						endforeach;
					endforeach;
				elseif querySelf.loadDischargeOption = querySelf.MODE_OPT_LOAD then
					foreach slotRequest in slotController.allSlotRequestsLoad do
						foreach wle in slotRequest.allWorkListEntries do
							ti := wle.myTrackedItem;
							summaryObj := querySelf.getSummaryObjectForOrder(_voySummaryDict, ti, null, null);
							if summaryObj &lt;&gt; null then
								self.updateMonitor(breakOut);
								summaryObj.totalSelf(ti.CM_Container);
							endif;	
						endforeach;
					endforeach;
				endif;
			endforeach;
		endforeach;
	endforeach;
	
	

end;</source>
        <Parameter name="_voySummaryDict" type="CMIF_VoyageSummaryByValueDict" usage="input"/>
    </JadeMethod>
    <JadeMethod name="filterForProposedSummary" id="473c0e85-f934-46c7-b5a1-fcf8be921720">
        <updating/>
        <source>filterForProposedSummary(_voySummaryDict: CMIF_VoyageSummaryByValueDict input) updating;
// ---------------------------------------------------------------------------
// Created:     12 May 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
vars
	hold				: CM_Hold;
	bay					: CM_Bay;
	slotController		: CM_SlotController;
	sotRequest			: CM_SlotRequest;
	ti					: CM_TrackedItem;
	summaryObj			: CMIF_VoyageSummary;
	futureMove			: CM_FutureMove;
	querySelf			: CMQF_VoyageProfileSummary;
	breakOut			: Boolean;
	edition 			: Integer;	//18 July 2016	NDL	TFS 2329
	invalid 			: Boolean;	//18 July 2016	NDL	TFS 2329
begin
	querySelf := self;
	
	on Exception do app.handleDeletedObject( exception, hold, invalid );	//18 July 2016	NDL	TFS 2329
	
	foreach hold in querySelf.allHolds do
	
		//18 July 2016	NDL	TFS 2329
		invalid := false;
		edition := hold.edition;
		if invalid then
			continue;
		endif;
		
		foreach bay in hold.allBays do
			if not bay.isKindOf(CM_BayVoyage) then
				continue;
			endif;
	
			foreach slotController in bay.CM_BayVoyage.allSlotControllersByOrdinal discreteLock do
				if slotController.isFortyBack then
					continue;
				endif;
				
				foreach futureMove in slotController.allPlannedFutureMoves do
					ti := futureMove.CM_FutureMovePlanned.myTrackedItem;
					summaryObj := querySelf.getSummaryObjectForOrder(_voySummaryDict, ti, null, null);
					if summaryObj &lt;&gt; null then
						self.updateMonitor(breakOut);
						summaryObj.totalSelf(ti.CM_Container);
					endif;
				endforeach;
			endforeach;
		endforeach;
	endforeach;

end;</source>
        <Parameter name="_voySummaryDict" type="CMIF_VoyageSummaryByValueDict" usage="input"/>
    </JadeMethod>
    <JadeMethod name="filterObjects" id="58594334-b81e-4a70-bcab-c1aad66425f8">
        <updating/>
        <source>filterObjects(_collection: Collection input; _passport : CM_Passport) updating;
// ---------------------------------------------------------------------------
// Created:     11 May 2003		cnwth2	
//
// Purpose:     This summary report prints automatically as the front page of a ship profile
//				printout from the SHP_VoyageAreaForm
// ----------   ----------  --------------------------------------------------
vars
	voySummaryDict			: CMIF_VoyageSummaryByValueDict;
	terminal				: CM_Terminal;
begin
	if (not _collection.isKindOf(CMIF_VoyageSummaryByValueDict)) then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Invalid collection type');
		return;
	endif;
	
	if self.allHolds.isEmpty then
		return;
	endif;
	
	self.initFields();
	foreach terminal in self.allTerminals do
		self.allFilterLoadPorts.add(terminal.getConfig(PortDestCode).String);
	endforeach;
	
	voySummaryDict := _collection.CMIF_VoyageSummaryByValueDict;
	
	if self.actualProposedOption = self.MODE_OPT_ACTUAL then
		self.filterForActualSummary(voySummaryDict);
	elseif self.actualProposedOption = self.MODE_OPT_PROPOSED then
		self.filterForProposedSummary(voySummaryDict);
	elseif self.loadDischargeOption = self.MODE_OPT_LOAD or
	   self.loadDischargeOption = self.MODE_OPT_DISCHARGE then
		self.filterForLoadDischarge(voySummaryDict);
	else
		return;
	endif;

end;</source>
        <Parameter name="_collection" type="Collection" usage="input"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="updateMonitor" id="bb211a71-275d-4007-91fc-f5d7a205340b">
        <updating/>
        <source>updateMonitor(_breakOut : Boolean output) updating, protected;
// ---------------------------------------------------------------------------
// Created:     11 November 2003	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	querySelf				: CMQF_VoyageProfileSummary;
begin
	querySelf := self;
	querySelf.numFound := querySelf.numFound + 1;
	querySelf.numSearched := querySelf.numSearched + 1;
	
	querySelf.checkStatusIncludesObject(null, app.myPassport, _breakOut);

end;</source>
        <access>protected</access>
        <Parameter name="_breakOut" type="Boolean" usage="output"/>
    </JadeMethod>
</Class>
