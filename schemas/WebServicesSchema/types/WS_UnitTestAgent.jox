		_errors &amp;= "JMTUserInterfaceService::validateCurrentSession for Public access to " &amp; methodName &amp; " failed" &amp; CrLf;
	endif;
	
	methodName := JMTUserInterfaceService::getMeasurementTypes.name;
	provider.setPropertyValue("_methodName", methodName);
	if not provider.sendMsgWithParams(JMTUserInterfaceService::validateCurrentSession.name, checkUser).Boolean then
		_errors &amp;= "JMTUserInterfaceService::validateCurrentSession for Public access to " &amp; methodName &amp; " failed" &amp; CrLf;
	endif;
	
	methodName := JMTUserInterfaceService::getIMEXStatuses.name;
	provider.setPropertyValue("_methodName", methodName);
	if not provider.sendMsgWithParams(JMTUserInterfaceService::validateCurrentSession.name, checkUser).Boolean then
		_errors &amp;= "JMTUserInterfaceService::validateCurrentSession for Public access to " &amp; methodName &amp; " failed" &amp; CrLf;
	endif;
	
	methodName := JMTUserInterfaceService::getSiteSate.name;
	provider.setPropertyValue("_methodName", methodName);
	if not provider.sendMsgWithParams(JMTUserInterfaceService::validateCurrentSession.name, checkUser).Boolean then
		_errors &amp;= "JMTUserInterfaceService::validateCurrentSession for Public access to " &amp; methodName &amp; " failed" &amp; CrLf;
	endif;
	
	methodName := JMTUserInterfaceService::getTransportModes.name;
	provider.setPropertyValue("_methodName", methodName);
	if not provider.sendMsgWithParams(JMTUserInterfaceService::validateCurrentSession.name, checkUser).Boolean then
		_errors &amp;= "JMTUserInterfaceService::validateCurrentSession for Public access to " &amp; methodName &amp; " failed" &amp; CrLf;
	endif;
	
	methodName := JMTUserInterfaceService::getVehicleType.name;
	provider.setPropertyValue("_methodName", methodName);
	if not provider.sendMsgWithParams(JMTUserInterfaceService::validateCurrentSession.name, checkUser).Boolean then
		_errors &amp;= "JMTUserInterfaceService::validateCurrentSession for Public access to " &amp; methodName &amp; " failed" &amp; CrLf;
	endif;
	
	methodName := JMTUserInterfaceService::getVehicleMake.name;
	provider.setPropertyValue("_methodName", methodName);
	if not provider.sendMsgWithParams(JMTUserInterfaceService::validateCurrentSession.name, checkUser).Boolean then
		_errors &amp;= "JMTUserInterfaceService::validateCurrentSession for Public access to " &amp; methodName &amp; " failed" &amp; CrLf;
	endif;
	
	methodName := JMTUserInterfaceService::getVehicleModel.name;
	provider.setPropertyValue("_methodName", methodName);
	if not provider.sendMsgWithParams(JMTUserInterfaceService::validateCurrentSession.name, checkUser).Boolean then
		_errors &amp;= "JMTUserInterfaceService::validateCurrentSession for Public access to " &amp; methodName &amp; " failed" &amp; CrLf;
	endif;
	
	methodName := JMTUserInterfaceService::getSystemSpecialLifts.name;
	provider.setPropertyValue("_methodName", methodName);
	if not provider.sendMsgWithParams(JMTUserInterfaceService::validateCurrentSession.name, checkUser).Boolean then
		_errors &amp;= "JMTUserInterfaceService::validateCurrentSession for Public access to " &amp; methodName &amp; " failed" &amp; CrLf;
	endif;
	
	methodName := JMTUserInterfaceService::getCoolingTypes.name;
	provider.setPropertyValue("_methodName", methodName);
	if not provider.sendMsgWithParams(JMTUserInterfaceService::validateCurrentSession.name, checkUser).Boolean then
		_errors &amp;= "JMTUserInterfaceService::validateCurrentSession for Public access to " &amp; methodName &amp; " failed" &amp; CrLf;
	endif;
	
	// Now try something that we expect to fail
	methodName := JMTEDIService::sendEDI.name;
	provider.setPropertyValue("_methodName", methodName);
	if provider.sendMsgWithParams(JMTEDIService::validateCurrentSession.name, checkUser).Boolean then
		_errors &amp;= "JMTEDIService::validateCurrentSession for Public access to " &amp; methodName &amp; " succeeded (when it shouldn't have)" &amp; CrLf;
	endif;
	methodName := JMTUserInterfaceService::setUserEmail.name;
	provider.setPropertyValue("_methodName", methodName);
	if provider.sendMsgWithParams(JMTUserInterfaceService::validateCurrentSession.name, checkUser).Boolean then
		_errors &amp;= "JMTUserInterfaceService::validateCurrentSession for Public access to " &amp; methodName &amp; " succeeded (when it shouldn't have)" &amp; CrLf;
	endif;
	methodName := JMTUserInterfaceService::setUserLocale.name;
	provider.setPropertyValue("_methodName", methodName);
	if provider.sendMsgWithParams(JMTUserInterfaceService::validateCurrentSession.name, checkUser).Boolean then
		_errors &amp;= "JMTUserInterfaceService::validateCurrentSession for Public access to " &amp; methodName &amp; " succeeded (when it shouldn't have)" &amp; CrLf;
	endif;
	
	return null;
	
	// Not used,just to provide a reference from the super schema super class method 
	ref := CM_UnitTestAgent::wsCheckWhiteListedMethods.name;

epilog
	delete session;
	delete provider;
	
	// small hack to get around JadeSOAPException transients being leaked
	create oa transient;
	process.allTransientInstances(oa, 0);
	foreach obj in oa do
		if obj.class = JadeSOAPException then
			delete obj;
		endif;
	endforeach;
	delete oa;
end;</source>
        <Parameter name="_errors" type="String" usage="output"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="wsCompareWebSearches" id="b4accb9b-baa6-409a-9621-3dd605de3951">
        <source>wsCompareWebSearches(): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 January 2014	cnwndl1	Initial creation	Par 33347

*/

vars

	ref : String;
	queryRequest : WS_TrackedItemQueryRequest;
	queryReqService : JMTUserInterfaceService;
	queryResponse : WS_TrackedItemQueryResponse;
	totalFound : Integer;
	lastTotalFound : Integer;
	id : String;
	index : Integer;
	str : String;

begin

	if app.name &lt;&gt; "JMTUnitTest" and app.name &lt;&gt; "JMTUnitTestRunner" then
		return "Pre-test check: App.name = '" &amp; app.name &amp; "' test will fail...";
	endif;

	//Query trackeditems
	create queryRequest transient;
	queryRequest.setPropertyValue("filterId","UT");
	// just looking for any cargo that starts with 'UT' anywhere related to terminal 'UT'
	
	
	queryRequest.maxReturnedItems := 0;
	queryRequest.startFrom := 0;
	
	
	create queryReqService transient;
	queryResponse := queryReqService.findCargo(queryRequest);
	if queryResponse = null then
		return "test a, queryResponse not returned.";
	endif;
	if queryResponse.hasErrors then
		return "test b, " &amp; queryResponse.getErrorsAsStringForTesting;
	endif;
	totalFound := queryResponse.allTrackedItems.size;
	if totalFound &lt; 100 then
		return "test c, queryResponse found less than 100 items, probably wrong. " &amp; queryResponse.allTrackedItems.size.String &amp; " items were found.";
	endif;
	delete queryResponse;
	
	queryRequest.maxReturnedItems := 10;
	queryRequest.startFrom := 0;	// should be the same as the last one of the previous list
	queryResponse := queryReqService.findCargo(queryRequest);
	id := queryResponse.allTrackedItems.last.idTextBox;
	if queryResponse.allTrackedItems.size &lt;&gt; 10 then
		return "test e, queryResponse requested 10 items. returned wrong number of objects";
	endif;
	delete queryResponse;
	
	queryRequest.maxReturnedItems := 10;
	queryRequest.startFrom := 10;	// should be the same as the last one of the previous list
	queryResponse := queryReqService.findCargo(queryRequest);
	if queryResponse.allTrackedItems.first.idTextBox &lt;&gt; id then
		return "test e, queryResponse requested 10 items, starting at 10. returned incorrect first object";
	endif;
	delete queryResponse;
	
	queryRequest.maxReturnedItems := 0;
	queryRequest.startFrom := 0;
	foreach index in 1 to 14 do
		str := self.checkEachCriteria( queryReqService, queryRequest, queryRequest, index, "getTIsForCargoEnquiry" );
		if str &lt;&gt; null then
			return str;
		endif;
	endforeach;
	
	foreach index in 1 to 14 do
		str := self.checkEachCriteria( queryReqService, queryRequest, queryRequest, index, "getTIsForImportRelease" );
		if str &lt;&gt; null then
			return str;
		endif;
	endforeach; 
	
	foreach index in 1 to 14 do
		str := self.checkEachCriteria( queryReqService, queryRequest, queryRequest, index, "getTIsForPreNotes" );
		if str &lt;&gt; null then
			return str;
		endif;
	endforeach;
	
	return null;
	
	// Not used,just to provide a reference from the super schema super class method 
	ref := CM_UnitTestAgent::wsCompareWebSearches.name;

epilog

	delete queryResponse;
	delete queryRequest;
	delete queryReqService;
	
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="wsCrUpDelPrenoteCarrierDAG" id="41801f99-fa43-43bb-bbb2-d9877cb6cceb">
        <source>wsCrUpDelPrenoteCarrierDAG(_id: String): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25/09/2017	jlgmp6	Initial creation
21/08/2019	jlgdap1	TFS 45836 PEN Approved Carrier for ISO Type and Trailer Type
02 Oct 2020 cnwma1  ChangeRequest 50112: ASPA - GCI Stevedores
*/
constants
	CarrierId: String = "UTVSS";
	TrainId: String = "UTTR50";
	WagonId: String = "NICK123";

vars
	ref : String;
	updateRequest : WS_PreNoteUpdateRequest;
	//updateService : JMTUpdateService;
	webService : JMTUserInterfaceService;
	updateResponse : WS_TrackedItemUpdateResponse;
	now : TimeStamp;
	ti : CM_TrackedItem;
	deleteResponse : WS_Response;
	measureType : CM_MeasurementType;
	weigthValue : String;
	carrier					: CM_Carrier;
	dac						: CM_DataAccessController;
	train, proxyTrain		: CM_Train;
	wagon, proxyWagon		: CM_Wagon;
	wagonClass				: CM_WagonClass;
	railLine				: CM_RailLine;
	operator : CM_Operator;		
	carrierSet : CM_CarrierSet;		
	cargoType : CM_CargoType;					// TFS 45836
	pxyCriteria : CM_YACriteria;				// TFS 45836
	criteria : CMIF_Array;						// TFS 45836
	cmifCriterion : CMIF_YACriteriaPriority;	// TFS 45836
	pxyOpCrit : CM_OperatorCarrierCriteria;		// TFS 45836
	realOpCrit : CM_ObjectMatchCriteria;		// TFS 45836
begin
	


	operator := app.myRoot.allOperators["UTOP"];
	
	create carrierSet transient;
	create criteria transient;					// TFS 45836
	
	carrier := app.myRoot.allCarriers["UT_OTHER"];
	carrierSet.add(carrier);
	cargoType := app.myRoot.allCargoTypesById[1];									// TFS 45836
	create pxyCriteria transient;													// TFS 45836
	pxyCriteria.setProxy(app.myRoot.allYACriteriaTypes[YACriteriaType_CargoType], cargoType.getYAIdentifier, "Cargo Type");	// TFS 45836
	cmifCriterion := pxyCriteria.getTransient();									// TFS 45836
	criteria.add(cmifCriterion);													// TFS 45836
	create pxyOpCrit transient;														// TFS 45836
	pxyOpCrit.setProxy(criteria, null);												// TFS 45836
	carrierSet.copy(pxyOpCrit.allCarriers);											// TFS 45836
	pxyOpCrit.setMyOperator(operator);												// TFS 45836
	app.myTrxCA.trxCreateObjMatchCrit(pxyOpCrit, realOpCrit, app.myPassport);		// TFS 45836
	//app.myTrxUA.trxUpdateOperatorAdvSettings(operator, null, null, carrierSet, carrierCargoType, app.myPassport);	// TFS 45836


carrier := app.myRoot.allCarriers[CarrierId];


	if app.name &lt;&gt; "JMTUnitTest" and app.name &lt;&gt; "JMTUnitTestRunner" then
		return "Pre-test check: App.name = '" &amp; app.name &amp; "' test will fail...";
	endif;
	now := app.actualTimeServer();
	measureType := app.getDefaultMeasurementForType(Type_Weight);
	weigthValue := app.convertMeasurementForDisplay( measureType.shortName, 4000 );

	train := app.myPassport.myTerminal.allTrainsOnTerminal.getAtKeyGeq(TrainId, null);
	if train &lt;&gt; null then
		wagon := train.allWagonsByIdInward.first();
		while wagon &lt;&gt; null do		
			beginTransaction;
			if wagon.myRailLine &lt;&gt; null then
				wagon.myRailLine.removeWagon(wagon);
			endif;
			if wagon.myTrainOutwards &lt;&gt; null then
				wagon.myTrainOutwards.removeWagon(false, wagon);
			endif;
			if wagon.myTrainInwards &lt;&gt; null then
				wagon.myTrainInwards.removeWagon(true, wagon);
			endif;
			wagon.setMyTrain(false, null);
			wagon.setMyTrain(true, null);
			wagon.setPropertyValue("myTerminalDeparted",null);
			wagon.setPropertyValue("myTerminal",null);
			wagon.setPropertyValue("myWagonMaster",null);
			wagon.setPropertyValue("myWagonClass",null);
			wagon.setPropertyValue("myCarrier",null);
			delete wagon;
			commitTransaction;
			wagon := train.allWagonsByIdInward.first();		
		endwhile;
		app.myTrxDA.trxDeleteTrain(train, false, app.myPassport);
	endif;
	
	wagon := app.myPassport.myTerminal.allWagons.getAtKeyGeq(WagonId, "31,12,3001".Date.TimeStamp);
	
	if wagon &lt;&gt; null then
		app.myTrxDA.trxDeleteWagon(wagon,false,app.myPassport);
	endif;
	
	
	create proxyTrain transient;
	proxyTrain.setProxy(TrainId,
						TrainId,
						null,
						null,
						null,
						null,
						app.myPassport.myTerminal,
						null,
						null,//navsp1 17MAY2022 TFS#53619
						null,
						null,
						null,
						null,
						null,
						null,
						null,
						carrier,
						app.actualTimeServer,
						null,
						null,
						null,
						null,
						null,	//_myTrackClearance : CM_TrackClearance
						false,
						null,  //02.10.2020 cnwma1 TFS #50112
						null); //02.10.2020 cnwma1 TFS #50112
//	beginTransaction;
	app.myTrxCA.trxCreateTrain(proxyTrain, train, false, app.myPassport);

	wagonClass := app.myRoot.allWagonClasses["NICK"];
	create proxyWagon as CM_FlatcarVisit transient;
	proxyWagon.setProxy(app.myPassport.myTerminal,
						WagonId,
						wagonClass,
						train,
						train,
						null,
						null,
						null,
						null,
						carrier,
						null,      //02.10.2020 cnwma1 TFS #50112
						null		//02.10.2020 cnwma1 TFS #50112
						);  
//	beginTransaction;
	app.myTrxCA.trxCreateWagon(proxyWagon, wagon, railLine, null, null, app.myPassport);

	
	create updateRequest transient;
	updateRequest.setPropertyValue("idTextBox",_id);
	updateRequest.cargoType := "1";
	updateRequest.bookingReference := "book1";
	updateRequest.setPropertyValue("isoType","2200");
	updateRequest.setPropertyValue("operatorCode","UTOP");
	updateRequest.setPropertyValue("mark","");
	updateRequest.setPropertyValue("sealNum","Seal1");
	updateRequest.setPropertyValue("sealNumCustoms","Cus1,Cus2");
	updateRequest.setPropertyValue("sealNumShippers","Ship1");
	updateRequest.setPropertyValue("sealNumVent","Vent1");	
	updateRequest.setPropertyValue("voyageCode","");
	updateRequest.setPropertyValue("weightTotal",weigthValue);	
	updateRequest.setPropertyValue("transportMode",TI_TRANSMODE_RAIL_STR);
	updateRequest.setPropertyValue("commodity","MT");
	updateRequest.setPropertyValue("remarks","Remarks1");
	updateRequest.setPropertyValue("expectedArrivalDate", now.Date.format("dd MM yyy") );
	updateRequest.setPropertyValue("expectedArrivalTime", now.Time.format("hh mm") );
	updateRequest.setPropertyValue("wagon", WagonId);
	updateRequest.setPropertyValue("imexStatusString", "Export");
	updateRequest.setPropertyValue("carrier",CarrierId);
	
	create webService transient;
	updateResponse := webService.createPreNote(updateRequest);
//	if updateResponse = null then
//		return "test 1, updateResponse not returned.";
//	endif;
	if updateResponse.hasErrors  then
		
			return "test 2, " &amp; updateResponse.getErrorsAsStringForTesting ;
			
			
			
		
	else
				
		beginTransaction;
		train.setPropertyValue("myCarrier", null);	// continue down to the update without a carrier
		wagon.setPropertyValue("myCarrier", null);
		commitTransaction;
		delete updateResponse;
		updateResponse := webService.createPreNote(updateRequest);
	
		
	endif;
	
	ti := self.myTerminal.lookupPrenoteByIDExact( _id );
	if ti = null then
		return "test 3, updateResponse pre note not created. " &amp; updateResponse.getErrorsAsStringForTesting;
	endif;	
	delete updateResponse;
	
	
	//Now update the Pre-note
	beginTransaction;
	train.setPropertyValue("myCarrier", carrier);	// reinstate carrier
	wagon.setPropertyValue("myCarrier", carrier);
	commitTransaction;
	updateRequest.setPropertyValue("cmObjectId", ti.getOidString);
	updateRequest.setPropertyValue("cmObjectEdition", ti.edition);
	updateRequest.bookingReference := "book2";
	updateResponse := webService.updatePreNote(updateRequest);
	if updateResponse = null then
		return "test 4, updateResponse not returned.";
	endif;
	if updateResponse.hasErrors then
		
		return "test 5, " &amp; updateResponse.getErrorsAsStringForTesting;
		
	else			
		beginTransaction;
		train.setPropertyValue("myCarrier", null);	// continue down to the delete without a carrier
		wagon.setPropertyValue("myCarrier", null);
		commitTransaction;
		delete updateResponse;
		updateResponse := webService.updatePreNote(updateRequest);
	endif;
	ti := self.myTerminal.lookupPrenoteByIDExact( _id );
	if ti = null then
		return "test 6, updateResponse updated pre note not found.";
	endif;
	if ti.bookingReference &lt;&gt; "book2" then
		return "test 7, updateResponse updating bookingreference id on pre note failed.";
	endif;
	delete updateResponse;
	
	
	//Now delete the prenote
	deleteResponse := webService.deletePreNote(updateRequest);
	if deleteResponse = null then
		return "test 8, deleteResponse not returned.";
	endif;
	if deleteResponse.hasErrors then
		return "test 9, " &amp; deleteResponse.getErrorsAsStringForTesting;
	endif;
	ti := self.myTerminal.lookupPrenoteByIDExact( _id );
	if ti &lt;&gt; null then
		return "test 10, deleteResponse failed pre note not deleted.";
	endif;
	delete deleteResponse;
	
	

	return null;
	
	// Not used,just to provide a reference from the super schema super class method 
	ref := CM_UnitTestAgent::wsCrUpDelPrenoteCarrierDAG.name; 

epilog
	if process.isInTransactionState then
		abortTransaction;
	endif;

	beginTransaction;
    //operator.allCarriersByCargoTypeId.clear();						// TFS 45836
	operator.allOperatorCarrierCriteria.purge();						// TFS 45836
	commitTransaction;
	
	delete	carrierSet;
	delete updateRequest;
	delete webService;
	delete updateResponse;
	delete deleteResponse;
	delete proxyTrain;
	delete proxyWagon;
	if criteria &lt;&gt; null then			// TFS 45836
		criteria.purge;					// TFS 45836
	endif;								// TFS 45836
	delete criteria;					// TFS 45836
	delete pxyOpCrit;					// TFS 45836
end;</source>
        <Parameter name="_id" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="wsCrUpDelPrenoteCarrierDAG2" id="e3489fdc-5f0f-40c4-8711-704f5c5f2969">
        <source>wsCrUpDelPrenoteCarrierDAG2(_id: String): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 September 2018	jlgns1	Initial creation

*/

constants
	CarrierId				: String = "UTVSS";
	
vars
	ref 					: String;
	bulkRelease				: WS_BulkRelease;
	webService 				: JMTUserInterfaceService;
	request  				: 	WS_BulkReleaseUpdateRequest ; 
	response				: WS_Response ; 
	responseUpdate 			: 	WS_BulkReleaseUpdateResponse ; 
	bulkType 				: WS_BulkReleaseType ; 
	bulkReserve				:  WS_ReserveTI ; 
	bulkOperator 			: WS_Operator ; 
	bulkSubTeminal 			: WS_SubTerminal ; 
	realBulkRelease 		: CM_BulkRelease ; 
	bulkCargoType 			: WS_CargoType ; 
	bulkReserveSelection 	: WS_ReserveSelection ; 
	bulkISOType				: WS_ISOType ; 
	bulkCarrier				: WS_Carrier;
	carrier					: CM_Carrier;
	dac						: CM_DataAccessController;
			


begin
	carrier := app.myRoot.allCarriers[CarrierId];
	dac := app.myRoot.allDataAccessControllers["CM_Operator", CarrierId];
	if not carrier.allDataAccessControllersRel.includes(dac) then
		if dac &lt;&gt; null then
			beginTransaction;
			carrier.allDataAccessControllersRel.add(dac);
			commitTransaction;
		endif;
	endif;
		



	





	// Test1 CREATE
	if app.name &lt;&gt; "JMTUnitTest" and app.name &lt;&gt; "JMTUnitTestRunner" then
		return "Pre-test check: App.name = '" &amp; app.name &amp; "' test will fail...";
	endif;

	create bulkCargoType transient ; 
	bulkCargoType.setPropertyValue("id",1) ; 
	bulkCargoType.setPropertyValue("description", "ISO Container") ; 

	create bulkISOType transient ; 
	bulkISOType.setPropertyValue("code","2200" ); 
	bulkISOType.setPropertyValue("description","GENERAL") ; 
	

	create bulkReserveSelection transient ; 
	bulkReserveSelection.setPropertyValue("cargoType",bulkCargoType) ; 
	bulkReserveSelection.setPropertyValue("isoType",bulkISOType) ; 
	bulkReserveSelection.setPropertyValue( "totalRequested",10) ; 
	
	create bulkType transient ; 
	bulkType.setPropertyValue("id",1) ; 
	
	create bulkOperator transient ; 
	bulkOperator.setPropertyValue("code","123") ; 

	create bulkCarrier transient ; 
	bulkCarrier.setPropertyValue("code", CarrierId);

	create bulkSubTeminal ; 
	bulkSubTeminal.setPropertyValue("code","UT_Depot")  ;
	
	create bulkRelease transient ; 
	bulkRelease.setPropertyValue("releaseNo","WebRel6") ; 
	
	bulkRelease.setPropertyValue("type",bulkType)  ; 
	bulkRelease.setPropertyValue("operator",bulkOperator) ; 
	bulkRelease.setPropertyValue("mySubTerminal",bulkSubTeminal) ; 
	bulkRelease.setPropertyValue("releaseByType",true ) ;
	bulkRelease.setPropertyValue("cargoType","ISO Container") ; 
	bulkRelease.setPropertyValue("carrier", bulkCarrier);
	
	//myOperatorTerminal
	
	bulkRelease.allReserveDetails.add(bulkReserveSelection) ; 

	create request transient;
	request.setPropertyValue('myBulkRelease', bulkRelease );
	
	create webService transient;
	response := webService.createBulkRelease(request);

	if response = null then
		return "test 1, response not returned.";
	endif;
	
	if response.hasErrors then
		if response.getErrorsAsStringForTesting.pos("90495", 1) = 0 then
		
			return "test 2, " &amp; response.getErrorsAsStringForTesting;
		else
			//bulkRelease.setPropertyValue("carrier", null);	// continue down to the update without a carrier
			//delete bulkCarrier;
		//	delete response;
		//	response := webService.createBulkRelease(request);
		endif;
	else
		
		return "test 2, error 90495 should have occurred";
	endif;
	
	//delete all the crap
	delete response;
	delete request ; 

	//create without a carrier 
	create bulkCargoType transient ; 
	bulkCargoType.setPropertyValue("id",1) ; 
	bulkCargoType.setPropertyValue("description", "ISO Container") ; 

	create bulkISOType transient ; 
	bulkISOType.setPropertyValue("code","2200" ); 
	bulkISOType.setPropertyValue("description","GENERAL") ; 
	

	create bulkReserveSelection transient ; 
	bulkReserveSelection.setPropertyValue("cargoType",bulkCargoType) ; 
	bulkReserveSelection.setPropertyValue("isoType",bulkISOType) ; 
	bulkReserveSelection.setPropertyValue( "totalRequested",10) ; 
	
	create bulkType transient ; 
	bulkType.setPropertyValue("id",1) ; 
	
	create bulkOperator transient ; 
	bulkOperator.setPropertyValue("code","123") ; 

	create bulkSubTeminal ; 
	bulkSubTeminal.setPropertyValue("code","UT_Depot")  ;
	
	create bulkRelease transient ; 
	bulkRelease.setPropertyValue("releaseNo","WebRel6") ; 
	
	bulkRelease.setPropertyValue("type",bulkType)  ; 
	bulkRelease.setPropertyValue("operator",bulkOperator) ; 
	bulkRelease.setPropertyValue("mySubTerminal",bulkSubTeminal) ; 
	bulkRelease.setPropertyValue("releaseByType",true ) ;
	bulkRelease.setPropertyValue("cargoType","ISO Container") ; 

	
	//myOperatorTerminal
	
	bulkRelease.allReserveDetails.add(bulkReserveSelection) ; 

	create request transient;
	request.setPropertyValue('myBulkRelease', bulkRelease );
	response := webService.createBulkRelease(request);
	if response = null then
		return "test 2b, updated Response not returned.";
	else 
		if response.hasErrors then
			return "test 2b created without carrier has errors";
		endif;
	endif;
	
	//delete all the crap
	delete response;
	delete request ; 
	
	//Test 2 Update
	realBulkRelease := self.myTerminal.getBulkReleaseFromCode("WebRel6") ; 

	create bulkRelease transient;
	//bulkRelease.setProxyCollectionsFromObject(realBulkRelease, true);	// ### TFS 59830 (59831) 04Oct2023 NAVPW1
	bulkRelease.setProxyCollectionsFromObject(realBulkRelease, false);	// ### TFS 61036 01Nov2023 NAVPW1
	
	bulkType := bulkRelease.type;
	if bulkType &lt;&gt; null then
		bulkType.setPropertyValue("id",2) ;
	endif;
	
	create bulkCarrier transient;		// reinstate the dodgy carrier
	bulkCarrier.setPropertyValue("code", CarrierId);
	bulkRelease.setPropertyValue("carrier", bulkCarrier);

	create request transient;
	request.setPropertyValue('myBulkRelease', bulkRelease);
	

	responseUpdate := webService.updateBulkRelease(request).WS_BulkReleaseUpdateResponse;

	if responseUpdate = null then
		return "test 3, updated Response not returned.";
	endif;
	if responseUpdate.hasErrors then
		if responseUpdate.getErrorsAsStringForTesting.pos("90495", 1) = 0 then
			return "test 4, " &amp; responseUpdate.getErrorsAsStringForTesting;
		else
			//bulkRelease.setPropertyValue("carrier", null);	// continue down to the delete without a carrier	
			//delete responseUpdate;
			//responseUpdate := webService.updateBulkRelease(request).WS_BulkReleaseUpdateResponse;
		endif;
	else
		return "test 4, error 90495 should have occurred";
	endif;
	
	
	delete responseUpdate;
	delete request ; 

	
	// TEST 3 delete the Bulk Release	
	realBulkRelease := self.myTerminal.getBulkReleaseFromCode("WebRel6") ; 
	create bulkRelease transient;
	//bulkRelease.setProxyCollectionsFromObject(realBulkRelease, true);	// ### TFS 59830 (59831) 04Oct2023 NAVPW1
	bulkRelease.setProxyCollectionsFromObject(realBulkRelease, false);	// ### TFS 61036 01Nov2023 NAVPW1
	
	//update the values
	create request transient;
	request.setPropertyValue('myBulkRelease', bulkRelease);
	
	// make the delete call
	response := webService.deleteBulkRelease(request) ; 
	// check the response again
	if response = null then
		return "test 5, response not returned.";
	endif;
	if response.hasErrors then
		return "test 6, " &amp; response.getErrorsAsStringForTesting;
	endif;
	
	realBulkRelease := self.myTerminal.getBulkReleaseFromCode("WebRel6") ; 
	if realBulkRelease &lt;&gt; null then
		return "test 7, code group not deleted" ; 
	endif; 	
	
	

	return null;
	
	// Not used,just to provide a reference from the super schema super class method 
	ref := CM_UnitTestAgent::wsCrUpDelPrenoteCarrierDAG2.name; 

epilog
	if process.isInTransactionState then
		abortTransaction;
	endif;
	beginTransaction;
	carrier.allDataAccessControllersRel.clear();
	commitTransaction;


	delete response;
	//delete bulkRelease ;
	delete request ; 
	delete webService ; 

end;</source>
        <Parameter name="_id" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="wsCreateLogDocketData" id="db10a677-e4b9-49ee-9345-3bdf424ef088">
        <source>wsCreateLogDocketData(_dockNum : String): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 April 2014	cnwmc5	Initial creation	CCMS 1127
13 Nov 	2017 	jlger1	TFS 7541 - unit test should not delete any transient ws object only requests and responses
									otherwise we are hiding the real transient leaks
*/

vars
	ref 		: String;
	request		: WS_LogDocketDataRequest;
	logDocket 	: WS_LogDocket;
	
	webService 	: JMTUserInterfaceService;
	response 	: WS_Response;
	
begin
	
	if app.name &lt;&gt; "JMTUnitTest" and app.name &lt;&gt; "JMTUnitTestRunner" then
		return "Pre-test check: App.name = '" &amp; app.name &amp; "' test will fail...";
	endif;
	
	create logDocket transient;
	//logDocket.setPropertyValue('backload', '');
	logDocket.setPropertyValue('carrierCode', 'ABC');
	logDocket.setPropertyValue('chhSupplier', 'CHH_TEST');
	logDocket.setPropertyValue('compartment', 'C3');
	logDocket.setPropertyValue('consignorCode', 'BOEIN');
	logDocket.setPropertyValue('customer', 'UT_CUST');
	logDocket.setPropertyValue('docketError', 'AT3ST');
	logDocket.setPropertyValue('docketNumber', _dockNum);
	//logDocket.setPropertyValue('driverId', '');
	//logDocket.setPropertyValue('driversPieceCountError', '');
	logDocket.setPropertyValue('fellingDate', '25/3/2014'.Date.asStringForWebInterface);
	logDocket.setPropertyValue('forest', 'F2');
	//logDocket.setPropertyValue('fsc', '');
	//logDocket.setPropertyValue('gangNumber', '');
	logDocket.setPropertyValue('grade', 'HIGH');
	//logDocket.setPropertyValue('jasScaled', '');
	logDocket.setPropertyValue('length', '2M');
	//logDocket.setPropertyValue('loaderNumber', '');
	logDocket.setPropertyValue('loadingContractor', 'SWED');
	logDocket.setPropertyValue('logType', 'AA');
	logDocket.setPropertyValue('loggingContractor', 'AAAA');
	logDocket.setPropertyValue('loggingOperation', 'CF');
	logDocket.setPropertyValue('loggingOrganisation', 'FED');
	//logDocket.setPropertyValue('nightshift', '');
	logDocket.setPropertyValue('numItems', 8);
	//logDocket.setPropertyValue('numberOfLifts', '');
	logDocket.setPropertyValue('operatorCode', 'DOUG');
	//logDocket.setPropertyValue('opid', '');
	//logDocket.setPropertyValue('percentScaled', '');
	//logDocket.setPropertyValue('pickupPoint', '');
	//logDocket.setPropertyValue('pieceCountError', '');
	//logDocket.setPropertyValue('receiptRequired', '');
	//logDocket.setPropertyValue('remarks', '');
	logDocket.setPropertyValue('scalerCode', 'CNWMH5');
	logDocket.setPropertyValue('species', 'DUGFIR');
	logDocket.setPropertyValue('stand', 'S3');
	//logDocket.setPropertyValue('ticketedAll', '');
	//logDocket.setPropertyValue('trailerNumber', '');
	logDocket.setPropertyValue('treatment', 'NONE');
	//logDocket.setPropertyValue('truckCategory', '');
	//logDocket.setPropertyValue('truckNumber', '');
	//logDocket.setPropertyValue('unloadPoint', '');
	logDocket.setPropertyValue('vehicleID', 'ABC123');
	//logDocket.setPropertyValue('weighbridge', '');
	logDocket.setPropertyValue('weightGross', '1000'.Integer);
	logDocket.setPropertyValue('weightNet', '700'.Integer);
	logDocket.setPropertyValue('weightTare', '300'.Integer);
	logDocket.setPropertyValue('yardLocation', 'UT_LOGA1 LGR1');
	
	create request transient;
	request.setPropertyValue('myLogDocket', logDocket);
	
	create webService transient;
	response := webService.createLogDocketData(request);
	if response = null then
		return "test 1, updateResponse not returned.";
	endif;
	if response.hasErrors then
		return "test 2, " &amp; response.getErrorsAsStringForTesting;
	endif;
	
	return null;
	
	// Not used,just to provide a reference from the super schema super class method 
	ref := CM_UnitTestAgent::wsCreateLogDocketData.name;

epilog

	delete webService;
	delete request;
	delete response;
	
end;</source>
