    <JadeMethod name="setProxy" id="3dd4e2de-ba27-47d0-a8e0-3806624e2eb3">
        <updating/>
        <source>setProxy(_type : Integer;
		_root : CM_Root; 
		_operator : CM_Operator;
		_operatorTerminal : CM_OperatorTerminal; 
		_cargoType : CM_CargoBOLType;
		_terminal : CM_Terminal) updating;
//
//19 May 2016	cnwrs1	TFS 1987 CargoSubType EDI Xlation
//
vars

begin
	self.myRoot 			:= _root;
	self.myOperator 		:= _operator;
	self.myOperatorTerminal := _operatorTerminal;
	self.myCargoType := _cargoType;
	self.myTerminal := _terminal; //epr TFS 42095 22/11/18
	// note this must be done last
	self.type 				:= _type;
end;
</source>
        <Parameter name="_type" type="Integer"/>
        <Parameter name="_root" type="CM_Root"/>
        <Parameter name="_operator" type="CM_Operator"/>
        <Parameter name="_operatorTerminal" type="CM_OperatorTerminal"/>
        <Parameter name="_cargoType" type="CM_CargoBOLType"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
    </JadeMethod>
