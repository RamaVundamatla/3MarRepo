    <JadeMethod name="myTerminal" id="14e3fd9d-4526-4bf9-a429-6346bc932f9f">
        <methodInvocation>mapping</methodInvocation>
        <source>myTerminal(set: Boolean; _value: CM_Terminal io) mapping;
// ---------------------------------------------------------------------------
// Created:     30 August 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	txn		: CM_Transaction;
begin
	if set then
		app.raiseSetVirtualError(class.name, method.name);
	else
		txn := self.getMyTransaction();				// PAR 15848
		if txn &lt;&gt; null and
		   CM_TITransaction.hasInstance(txn) then
			_value := txn.CM_TITransaction.myTerminal;
		elseif self.myVoyage &lt;&gt; null then
			// PAR 26801: User defined snapshots do not have a transaction but they
			// should have a voyage, so get terminal off that.
			_value := self.myVoyage.myTerminal;
		endif;
	endif;



end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="CM_Terminal" usage="io"/>
    </JadeMethod>
    <JadeMethod name="myTrackedItem" id="00b7eed5-bcbb-4d29-a649-ac7e0dd875c3">
