    <JadeMethod name="isIncomplete" id="1d4bb160-e989-4f75-928d-22afbdf85cd5">
        <source>isIncomplete() : Boolean;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 16/12/2013	cnwdap1		Initial creation PAR #32849 CCMS PEN 2321 Security Gate
//
vars

begin
	return not self.isCancelled and not self.status = self.Status_Complete;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isIncompleteForSecurityGate" id="38bdfbea-4ced-49ca-867c-1f0a1cefa6d2">
        <source>isIncompleteForSecurityGate() : Boolean;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 19/12/2013	cnwdap1		Initial creation PAR #32849 CCMS PEN 2321 Security Gate
// 17/05/2016	cnwdap1		TFS STWR #1970 We may be configured for Security Gate but this visit might have skipped the security gate
//
vars
	detail : CM_VehicleVisitRecordDetail;

begin
	detail := self.getSecurityGateExitDetail;
	if detail = null and self.myTerminal.getConfig(SiteHasSecurityGate).Boolean and self.getSecurityGateArrivalTS &lt;&gt; null then
		return true;
	// TFS #1970 May have skipped Security Gate																							// TFS #1970
	elseif detail = null and self.myTerminal.getConfig(SiteHasSecurityGate).Boolean and self.getSecurityGateArrivedDetail = null then	// TFS #1970
		if self.isIncomplete then																										// TFS #1970
			return true;																												// TFS #1970
		else																															// TFS #1970
			return false;																												// TFS #1970
		endif;																															// TFS #1970
	endif;
	return false;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isOK" id="07677dd7-4403-4f6b-b4ee-58256a0a59f9">
        <source>isOK() : Boolean;
// ---------------------------------------------------------------------------
// Created:     09 September 2008 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	err : CM_ErrorPersistent;
begin
	foreach err in self.allErrorsWarningsByTranNum discreteLock do
		if err.type = err.Type_Statement then
			continue;
		endif;
		if err.status = CM_ErrorPersistent.Status_Closed 
		or err.status = CM_ErrorPersistent.Status_Ignore then
			continue;
		endif;
		return false;
	endforeach;
	
	return true;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isOnlyReceivingCargo" id="913c11cd-08f2-42f4-9b3d-41908f408035">
        <source>isOnlyReceivingCargo() : Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 June 2019	jlger1	Initial creation 44965

*/

vars
	gteEntity : CMGTE_Entity;
	countReceival : Integer;
begin
	
	
	foreach gteEntity in self.allGateEntities discreteLock do
		if gteEntity.isKindOf(CMGTE_Release) then
			return false;
		elseif gteEntity.isKindOf(CMGTE_Receival) then
			countReceival:=countReceival + 1;
		endif;
		
	endforeach;
	
	return countReceival &gt; 0;
	
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isOnlyReleasingCargo" id="12b26b58-b069-4d3f-8a3e-4c4258e10ddc">
        <source>isOnlyReleasingCargo(): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason 
20 June 2019	jlger1	Initial creation 44965

*/

vars
	gteEntity : CMGTE_Entity;
	countRelease : Integer;
begin
	
	
	foreach gteEntity in self.allGateEntities discreteLock do
		if gteEntity.isKindOf(CMGTE_Release) then
			countRelease:=countRelease + 1;
		elseif gteEntity.isKindOf(CMGTE_Receival) then
			return false;	
		endif;
	endforeach;
	
	return countRelease &gt; 0;

epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isOpsViewData" id="6fbf0095-2a5c-4805-aa2f-7d450dd2b62b">
        <source>isOpsViewData(): Boolean;
/*
Purpose:			

Date		Who		Reason
26 August 2021	navab1	TFS 51853
*/

vars
	ti : CM_TrackedItem;
begin

	if self.allReceivedTrackedItems.isEmpty
	and self.allReleasedTrackedItems.isEmpty then
		return true;
	endif;

	foreach ti in self.allReceivedTrackedItems discreteLock do
		if ti.isOpsViewData() then
			return true;
		endif;
	endforeach;

	foreach ti in self.allReleasedTrackedItems discreteLock do
		if ti.isOpsViewData() then
			return true;
		endif;
	endforeach;


	return false;

epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isOwnerChassis" id="8ed141b5-266a-4ac4-9eed-0f9e7a98c22c">
        <source>isOwnerChassis() : Boolean;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
