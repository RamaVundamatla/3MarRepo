<Class name="CMIF_JsonLoadNotificationEUP" id="afb67d0a-5388-4d7d-a598-a193823b3ba7">
    <superclass name="CMIF_JsonTransform"/>
    <transient/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <ImplicitInverseRef name="dossiers" id="415a8dee-5d11-4331-a82b-c7c3456e499d">
        <memberTypeInverse/>
        <type name="CMIF_JsonDossierArray"/>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="header" id="86707063-c528-497c-ad80-a8697a04d3c9">
        <embedded/>
        <type name="CMIF_JsonHeaderEUP"/>
    </ImplicitInverseRef>
    <JadeMethod name="createDossiersForTIs" id="ada9d7b6-87d8-4835-95c9-3e02bd2c512e">
        <source>createDossiersForTIs(dossierDict : CM_ObjectByStringDict; _vbsSlot: CM_VehicleBookingTimeSlot input) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 July 2023	jlier1	Initial creation 58840
09 Apr 2024	jlika1	TFS 63078 EUP | FR 54026 - LOADNA LOADCO - Status for LOADCO is 'Create' Instead of 'Replace'
*/

vars
	missions : CM_ObjectByStringDict;
	iter : Iterator;
	ti : CM_TrackedItem;
	release,
	prevRelease  : CM_BulkRelease;
	dossier : CMIF_JsonDossierEUP;
	
begin
	create missions transient;

	iter:=dossierDict.createIterator;
	while iter.next(ti) do
		release:=iter.getCurrentKey(1).String.asOid.CM_BulkRelease;
	
		if  prevRelease &lt;&gt; 	release then
			if dossier &lt;&gt; null then
				dossier.createMissionsForTIs(missions,_vbsSlot,release);
			endif;
			
			missions.clear;
			create dossier transient;
			dossier.setFromVehicleBookingItem(_vbsSlot, release);	
			dossier.status := CMIF_JsonHeaderEUP.Status_Replace;
			self.dossiers.add(dossier);	
		endif;	
			
		if ti.allReserveDetailsReleased.first &lt;&gt; null and ti.allReserveDetailsReleased.first.myDeliveryParty &lt;&gt; null then
			missions.putAtKey(ti.allReserveDetailsReleased.first.myDeliveryParty.code,ti);
		else
			missions.putAtKey(" ",ti);
		endif;
		prevRelease:=release;
		
	endwhile;

	if not missions.isEmpty and dossier &lt;&gt; null then		
		dossier.createMissionsForTIs(missions,_vbsSlot,release);
	endif;
	
	
epilog
	delete iter;
	delete missions;
end;</source>
        <access>protected</access>
        <Parameter name="dossierDict" type="CM_ObjectByStringDict"/>
        <Parameter name="_vbsSlot" type="CM_VehicleBookingTimeSlot" usage="input"/>
    </JadeMethod>
    <JadeMethod name="createDossiersForVBS" id="deb79296-d2db-443a-b6b8-f71110fcf1da">
        <source>createDossiersForVBS(dossierDict : DynaDictionary; _vbsSlot: CM_VehicleBookingTimeSlot input) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 June 2023	jlier1	Initial creation 58839
09 Apr 2024	jlika1	TFS 63078 EUP | FR 54026 - LOADNA LOADCO - Status for LOADCO is 'Create' Instead of 'Replace'
*/

vars
	missions : CM_ObjectByStringDict;
	iter : Iterator;
	vehicleBookingItem : CM_VehicleBookingTimeSlotItem;
	release,
	prevRelease  : CM_BulkRelease;
	dossier : CMIF_JsonDossierEUP;
begin
	create missions transient;	
	iter:=dossierDict.createIterator;
	while iter.next(vehicleBookingItem) do
		release:=iter.getCurrentKey(1).CM_BulkRelease;
	
		if prevRelease &lt;&gt; release then
			if dossier &lt;&gt; null then
				dossier.createMissionsForVBS(missions,_vbsSlot,release);
			endif;
		
			missions.clear;
			create dossier transient;
			dossier.setFromVehicleBookingItem(vehicleBookingItem.myVehicleBookingSlot, release);	
			dossier.status := CMIF_JsonHeaderEUP.Status_Create;
			
			self.dossiers.add(dossier);
		endif;
	
		if vehicleBookingItem.myReserveDetails.myDeliveryParty &lt;&gt; null then
			missions.putAtKey(vehicleBookingItem.myReserveDetails.myDeliveryParty.code,vehicleBookingItem);
		else
			missions.putAtKey(" ",vehicleBookingItem);
		endif;
		prevRelease:=release;
	endwhile;

	if not missions.isEmpty  and dossier &lt;&gt; null then		
		dossier.createMissionsForVBS(missions,_vbsSlot,release);
	endif;
	
	
epilog
	delete iter;
	delete missions;
end;</source>
        <access>protected</access>
        <Parameter name="dossierDict" type="DynaDictionary"/>
        <Parameter name="_vbsSlot" type="CM_VehicleBookingTimeSlot" usage="input"/>
    </JadeMethod>
    <JadeMethod name="delete" id="6fb4cf6b-29f7-4f1e-9264-18233fb19176">
        <updating/>
        <source>delete() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26 June 2023	jlier1	Initial creation 58839

*/

vars

begin
	delete self.header;
	self.dossiers.purge;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setFromVehicleBooking" id="9dfc02b3-6798-4233-b299-fc633ee5d655">
        <updating/>
        <source>setFromVehicleBooking(_vehicleBooking : CM_VehicleBookingTimeSlot input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26 June 2023	jlier1	Initial creation 58839

*/

vars
	vehicleBookingItem : CM_VehicleBookingTimeSlotItem;
	dynaDictionary 	: DynaDictionary;
begin

	if _vehicleBooking = null then
		return;
	endif;

	create self.header transient;
	self.header.setFromVehicleBooking(_vehicleBooking, "LOADNA");
	
	//group vehicle Booking items by release request number
	create dynaDictionary transient;
	dynaDictionary.setMembership(CM_VehicleBookingTimeSlotItem);
	dynaDictionary.addMemberKey(CM_VehicleBookingTimeSlotItem::myBulkRelease.name,false,false);

	dynaDictionary.endKeys(true);
	
	foreach vehicleBookingItem in _vehicleBooking.allVehicleBookingItems discreteLock do
		if vehicleBookingItem.myReserveDetails =  null  or vehicleBookingItem.myBulkRelease = null then
			continue;
		endif;
		if vehicleBookingItem.myBulkRelease.myFreightForwarder = null then
			continue;
		endif;
		if not vehicleBookingItem.myBulkRelease.myFreightForwarder.isInternal then
			continue;
		endif;
		
		dynaDictionary.add(vehicleBookingItem);
	endforeach;
	
	self.createDossiersForVBS(dynaDictionary,_vehicleBooking);		
		
	
epilog
	
	delete dynaDictionary;
end;</source>
        <Parameter name="_vehicleBooking" type="CM_VehicleBookingTimeSlot" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setFromVehicleVisit" id="a461c5e9-3aa7-4596-8b5c-35256dbb2547">
        <updating/>
        <source>setFromVehicleVisit(_vehicleVisit : CM_VehicleVisitRecord input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 July 2023	jlier1	Initial creation 58840

*/

vars
	ti : CM_TrackedItem;
	tisByBulkReleaseOid 	: CM_ObjectByStringDict;
begin

	if _vehicleVisit.myVehicleBookingTimeslot = null then
		return;
	endif;
	
	if _vehicleVisit.myVehicleBookingTimeslot.allBulkReleases = null then
		return;
	endif;
	
	create self.header transient;
	self.header.setFromVehicleBooking(_vehicleVisit.myVehicleBookingTimeslot , "LOADCO");
	//it is different group all the cargo released by bulk release
	//then one mission per delivery party
	//then one product but  only sum the cargo that was release for the weight and quantity
	
	//group vehicle Booking items by release request number
	create tisByBulkReleaseOid transient;

	foreach ti in _vehicleVisit.allReleasedTrackedItems discreteLock do
		if   ti.getBulkReleaseReleased = null  or not _vehicleVisit.myVehicleBookingTimeslot.allBulkReleases.includes(ti.getBulkReleaseReleased) then
			continue;
		endif;
		
		if ti.getBulkReleaseReleased.myFreightForwarder = null then
			continue;
		endif;
		if not ti.getBulkReleaseReleased.myFreightForwarder.isInternal then
			continue;
		endif;
		
		tisByBulkReleaseOid.putAtKey(ti.getBulkReleaseReleased.getOidAsString, ti);
	endforeach;
	
	self.createDossiersForTIs(tisByBulkReleaseOid,_vehicleVisit.myVehicleBookingTimeslot);
epilog
	delete tisByBulkReleaseOid;
end;</source>
        <Parameter name="_vehicleVisit" type="CM_VehicleVisitRecord" usage="input"/>
    </JadeMethod>
</Class>
