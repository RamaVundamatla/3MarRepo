    <JadeMethod name="canBeReprocessedByBGP" id="37668e16-ccb2-482d-b210-51b96cc47ab8">
        <source>canBeReprocessedByBGP(): Boolean;
//
//15 Apr 2016	cnwrs1	TFS 1600 VERMAS EDI
//
vars
	result		:Boolean;
	status		:Integer;
	purgeDate	:Date;
	createTS	:TimeStamp;
begin
	result := inheritMethod();
	
	if not result then
		status := self.status;
		
		if status = CM_EDIFile.EDI_STATUS_LOADED or	
			status = CM_EDIFile.EDI_STATUS_VERIFIED_ERRORS or 
			status = CM_EDIFile.EDI_STATUS_VERIFIED or 
	        status = CM_EDIFile.EDI_STATUS_LOCKERROR or
			status = CM_EDIFile.EDI_STATUS_VERIFIED_WARNINGS then
			
			if self.canBePartiallyLoaded then	
				result := true;
			endif;
		endif;
	endif;

	if result then
		if self.getEDIAction = CM_EDITrackedItem.EDI_ACTION_DELETE then
			result := false;
		endif;
	endif;
	if result then
		// we may have passed the expiry for unprocessed files in which case we should not re-process it after all
//		purgeDate := VGM Expiry date from voyage cutoff;
		createTS := self.createdTime;
			
		if createTS.date &lt; purgeDate then
			// we are expired - we don't want to re-process
//			app.writeLog('VGM EDI expired ' &amp; self.displayName &amp; ' created ' &amp; createTS.String &amp; ' purge date ' &amp; purgeDate.String, LogDebug3);
//			result := false;
		endif;
	endif;

	return result;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
