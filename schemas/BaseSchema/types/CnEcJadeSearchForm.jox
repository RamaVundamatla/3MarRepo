    <JadeMethod name="doEnableControls" id="01db81f7-1b7f-4b0f-9e1d-5b71b50dcbfe">
        <source>doEnableControls() protected;
// --------------------------------------------------------------------------------
// Created:		30 March 2010 by cnwdad1
//
// Purpose:		Enables controls on the form according to the current state.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if lstResults.listCount() &gt; 0 then
		btnPrint.enabled	:=	true;
	else
		btnPrint.enabled	:=	false;
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doFormLoad" id="444b4f40-75fd-4153-82ac-5c6de4796f83">
        <updating/>
        <source>doFormLoad() updating, protected;
// --------------------------------------------------------------------------------
// Created:		26 November 2008 by cnwdad1
//
// Purpose:		Sets up the receiver when being loaded.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.centreWindow();
	
	lstSchemasAv.populateMe();
	
	optMetaphone.enabled	:=	false;
	optSoundex.enabled		:=	false;
	lblResults.cnEcSet(null);
	self.tablePrintInitialize();
	
	if app.myCnKarmaCntrl &lt;&gt; null then
		self.caption	:=	"Jade Search: " &amp; app.myCnKarmaCntrl.masterEnvironmentId;
	endif;
	
	create self.aMySearchAgent transient;
	self.doEnableControls();
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doPopulateResults" id="6e978401-17b4-4c49-8f21-c1e4a5944aee">
        <source>doPopulateResults() protected;
// --------------------------------------------------------------------------------
// Created:		23 April 2009 by cnwdad1
//
// Purpose:		Populates the list of search results.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	resultObj		: CnEcJadeSearchResult;
	theObject		: Object;
	listboxObj		: ListBox;
	listPointer		: Integer;
	typeName		: String;
	
begin
	listboxObj	:=	lstResults;
	listboxObj.clear();
	
	if self.aMySearchAgent.doSearch() then
		foreach resultObj in self.aMySearchAgent.allSearchResults do
			theObject	:=	resultObj.myObject;
			
			if theObject.isKindOf(Schema) then
				typeName	:=	"Schema";
				
			elseif theObject.isKindOf(Class) then
				typeName	:=	"Class";
				
			elseif theObject.isKindOf(PrimType) then
				typeName	:=	"Primitive";
				
			elseif theObject.isKindOf(Method) then
				typeName	:=	"Method";
				
			elseif theObject.isKindOf(Property) then
				if theObject.Property.cnEcIsAttribute() then
					typeName	:=	"Attribute";
				elseif theObject.Property.cnEcIsReference() then
					typeName	:=	"Reference";
				else
					typeName	:=	theObject.class.name;
				endif;
				
			elseif theObject.isKindOf(Constant) then
				if theObject.isKindOf(GlobalConstant) then
					typeName	:=	"Global Constant";
					
				elseif theObject.isKindOf(TranslatableString) then
					typeName	:=	"Translatable String";
				
				else
					typeName	:=	"Class Constant";
				endif;
			endif;
			
			listPointer	:=	listboxObj.cnEcAddItemDataObject(typeName &amp; ": " &amp; theObject.getName(), 0, resultObj);
			listboxObj.itemLevel[listPointer]	:=	1;
			
			listPointer	:=	listboxObj.cnEcAddItemDataObject(resultObj.getOwnershipPath(), 0, theObject);
			listboxObj.itemLevel[listPointer]	:=	2;
		endforeach;
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doPrintResults" id="0ebe7bfc-5ea7-443d-9f0d-4e43042b2c1f">
        <source>doPrintResults() protected;
// --------------------------------------------------------------------------------
// Created:		01 May 2009 by cnwdad1
//
// Purpose:		Prints the search results.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	tableObj	: Table;
	listboxObj	: ListBox;
	rowPointer	: Integer;
	maxRows		: Integer;
	stepCount	: Integer;
	displayRow	: String;
	typeName	: String;
	heading		: String;
	position	: Integer;
	
begin
	listboxObj		:=	lstResults;
	maxRows			:=	listboxObj.listCount();
	tableObj		:=	tblPrint;
	tableObj.rows	:=	1;
	stepCount		:=	1;
	
	if maxRows &lt;= 1 then
		app.msgBox("There is nothing to print.", "Print Results", MsgBox_Exclamation_Mark_Icon + MsgBox_OK_Only);
		return;
	endif;
	
	// Populate the printing table.
	
	foreach rowPointer in 1 to maxRows do
		if stepCount = 1 then
			typeName	:=	listboxObj.itemText[rowPointer];
			position	:=	typeName.pos(":", 1);
			
			if position &gt; 1 then
				typeName	:=	typeName[1:position - 1];
			endif;
			
			stepCount	:=	2;
			
		elseif stepCount = 2 then
			displayRow	:=	typeName &amp; Tab &amp; listboxObj.itemText[rowPointer];
			tableObj.addItem(displayRow);
			stepCount	:=	1;
			
		endif;
	endforeach;
	
	// Print the tabke.
	
	tableObj.cnEcResort(2, true, true);
	
	if app.myCnKarmaCntrl = null then
		heading	:=	"Jade Search Results";
	else
		heading	:=	"Jade Search Results: " &amp; app.myCnKarmaCntrl.masterEnvironmentId;
	endif;
	
	tableObj.cnEcPrintReport(heading, "Search for: '" &amp; txtSearchFor.cnEcString() &amp; "'", false, true);
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doSearch" id="d3f2e4b3-47c2-4ca7-9b29-87762a204920">
        <source>doSearch() protected;
// --------------------------------------------------------------------------------
// Created:		09 December 2008 by cnwdad1
//
// Purpose:		Starts the Schema search.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	allSchemasObj	: SchemaColl;
	startTime		: Integer;
	
begin
	startTime	:=	app.clock();
	lblResults.cnEcSet(null);
	lstResults.clear();
	create allSchemasObj transient;
	self.getSelectedSchemas(allSchemasObj);
	
	self.aMySearchAgent.setOptions(	txtSearchFor.cnEcString(),
									allSchemasObj,
									chkIsWhole.value,
									chkIsCase.value,
									chkIsWildcards.value,
									chkSoundsLike.value,
									optMetaphone.value,
									optSoundex.value,
									chkSchemaText.value,
									chkStrings.value,
									chkPrimitives.value,
									chkGlbConstants.value,
									chkClassText.value,
									chkMethodText.value,
									chkPropertyText.value,
									chkConstants.value);
	
	self.doPopulateResults();
	lblResults.cnEcSet(self.aMySearchAgent.allSearchResults.size().cnEcNumberFormat() &amp; " results found in " &amp; startTime.cnEcClockDifference().numberFormat() &amp; " seconds.");
	self.doEnableControls();
	shtResults.setFocus();
epilog
	delete allSchemasObj;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doSelectSchema" id="1a5e9070-4b18-46e6-af0d-db95c2f6572c">
        <source>doSelectSchema(pIsSelect:Boolean; pIsMoveAll:Boolean; pIsAllBelow:Boolean) protected;
// --------------------------------------------------------------------------------
// Created:		27 November 2008 by Darrell
//
// Purpose:		Moves selected schemas between the available and selected lists.
//
// Parameters:	pIsSelect - True if an entry is being selected, otherwise de-selecting.
//				pIsMoveAll - True if all entries at to be moved.
//				pIsAllBelow - True if all sub-schemas are being selected/de-selected.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	listFromObj		: CnEcListBox;
	listToObj		: CnEcListBox;
	selectedObj		: Object;
	rowPointer		: Integer;
	newPointer		: Integer;
	lastRow			: Integer;
	startRow		: Integer;
	entryLevel		: Integer;
	parentLevel		: Integer;
	
begin
	if pIsSelect then
		listFromObj	:=	lstSchemasAv;
		listToObj	:=	lstSchemasSel;
	else
		listFromObj	:=	lstSchemasSel;
		listToObj	:=	lstSchemasAv;
	endif;
	
	lastRow	:=	listFromObj.listCount();
	
	if pIsSelect and pIsMoveAll then
		listToObj.clear();
	endif;
	
	if pIsAllBelow then
		if listFromObj.selectedCount() &lt;&gt; 1 then
			app.msgBox(	"Please select the schema who's subschemas you wish to use.",
						"Select Subschemas",
						MsgBox_Information_Icon + MsgBox_OK_Only);
			return;
		endif;
		
		startRow	:=	listFromObj.listIndex + 1;
		parentLevel	:=	listFromObj.itemLevel[listFromObj.listIndex];
		
		foreach rowPointer in startRow to lastRow do
			entryLevel	:=	listFromObj.itemLevel[rowPointer];
			
			if entryLevel &lt;= parentLevel then
				break;
			endif;
			
			selectedObj	:=	listFromObj.itemObject[rowPointer];
			
			if listToObj.findObject(selectedObj) = CNEC_NULL_INDEX then
				newPointer	:=	listToObj.addItem(listFromObj.itemText[rowPointer]);
				listToObj.itemObject[newPointer]	:=	selectedObj;
			endif;
		endforeach;
	else
		rowPointer	:=	1;
		
		while rowPointer &lt;= lastRow do
			if not pIsMoveAll and not listFromObj.itemSelected[rowPointer] then
				rowPointer	:=	rowPointer + 1;
				continue;
			endif;
			
			if pIsSelect then
				selectedObj	:=	listFromObj.itemObject[rowPointer];
				
				if listToObj.findObject(selectedObj) = CNEC_NULL_INDEX then
					newPointer	:=	listToObj.addItem(listFromObj.itemText[rowPointer]);
					listToObj.itemObject[newPointer]	:=	selectedObj;
				endif;
				
				rowPointer	:=	rowPointer + 1;
			else
				listFromObj.removeItem(rowPointer);
				lastRow	:=	listFromObj.listCount();
			endif;
		endwhile;
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="pIsSelect" type="Boolean"/>
        <Parameter name="pIsMoveAll" type="Boolean"/>
        <Parameter name="pIsAllBelow" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getSelectedSchemas" id="81710ed6-531e-418c-aa9f-c4d368db1dfc">
        <source>getSelectedSchemas(pAllSchemasObj:SchemaColl input) protected;
// --------------------------------------------------------------------------------
// Created:		27 November 2008 by Darrell
//
// Purpose:		Populates the specified collection with all selected schemas.
//
// Parameters:	pAllSchemasObj - A reference to a collection of schemas.
//
// Returns:		The populated schema collection.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	listboxObj	: CnEcListBox;
	schemaObj	: Schema;
	rowPointer	: Integer;
	lastRow		: Integer;
	
begin
	pAllSchemasObj.clear();
	listboxObj	:=	lstSchemasSel;
	lastRow		:=	listboxObj.listCount();
	
	foreach rowPointer in 1 to lastRow do
		schemaObj	:=	listboxObj.itemObject[rowPointer].Schema;
		
		if schemaObj &lt;&gt; null then
			pAllSchemasObj.add(schemaObj);
		endif;
	endforeach;
end;</source>
        <access>protected</access>
        <Parameter name="pAllSchemasObj" type="SchemaColl" usage="input"/>
    </JadeMethod>
    <JadeMethod name="load" id="03fd9141-9d17-4b78-9839-9414e0ff0672">
        <controlMethod name="Form::load"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>load() updating;
// --------------------------------------------------------------------------------
// Created:		26 November 2008 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	app.mousePointer	:=	Busy;
	inheritMethod();
	self.doFormLoad();
epilog
	app.mousePointer	:=	Idle;
end;</source>
    </JadeMethod>
    <JadeMethod name="lstResults_mouseMove" id="35dc73c3-c4c5-481f-82fd-ea5e4cd1abaa">
        <controlMethod name="ListBox::mouseMove"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>lstResults_mouseMove(listbox: ListBox input; button: Integer; shift: Integer; x: Real; y: Real) updating;
// --------------------------------------------------------------------------------
// Created:		24 April 2009 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	rowPointer	: Integer;
	resultObj	: CnEcJadeSearchResult;
	theObject	: Object;
	helpText	: String;
	
begin
	rowPointer	:=	listbox.getListIndex(x, y);
	
	if rowPointer &gt; 0 then
		if listbox.itemLevel[rowPointer] = 1 then
			resultObj	:=	listbox.itemObject[rowPointer].CnEcJadeSearchResult;
			
			if resultObj &lt;&gt; null then
				helpText	:=	"Position = " &amp; resultObj.resultPos.String;
				
				if resultObj.isText then
					helpText	:=	helpText &amp; " in the text";
				endif;
				
				listbox.bubbleHelp	:=	helpText;
			endif;
		elseif listbox.itemLevel[rowPointer] = 2 then
			theObject	:=	listbox.itemObject[rowPointer];
			
			if theObject &lt;&gt; null then
				helpText	:=	theObject.display();
				listbox.bubbleHelp	:=	helpText;
			endif;
		else
			listbox.bubbleHelp	:=	null;
		endif;
	endif;
end;</source>
        <Parameter name="listbox" type="ListBox" usage="input"/>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="lstResults_pictureClick" id="f7360051-675a-4e9b-b7e9-7dd3f09302f9">
