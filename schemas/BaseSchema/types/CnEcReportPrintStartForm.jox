	self.doGetPrintFile();
epilog
	app.mousePointer	:=	Idle;
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="btnValue_click" id="9a8d795e-50c4-4775-b83c-190a88fbfdd3">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnValue_click(btn: Button input) updating;

vars
	paramForm		: CnEcReportParameterValueSuper;
	cellObject		: Object;
	theParameter	: CnEcReportParameter;
	rowIndex		: Integer;
	rowCount		: Integer;
	paramValue		: CnEcReportParameterValue;

begin
	// Show an hourglass and create a form.
	app.mousePointer	:=	Busy;

	create paramForm as global.cnEcGetReportModuleForm(CnEcReportParameterValueSuper);

	// Step through the parameters table ...
	rowCount	:=	tblParameters.rows;
	rowIndex	:=	2;

	foreach rowIndex in 2 to rowCount do
		cellObject	:=	tblParameters.cnEcGetCellObject(rowIndex, 1);

		if (cellObject.isKindOf(CnEcReportParameter)) then
			theParameter	:=	cellObject.CnEcReportParameter;
		else
			theParameter	:=	cellObject.CnEcReportParameterValue.myReportParameter;
		endif;

		// ...and load parameter values into the form.
		if  (tblParameters.getCellText(rowIndex, 4) &lt;&gt; "") or
			(tblParameters.cnEcGetCellObject(rowIndex, 4) &lt;&gt; null)	then

			create paramValue transient;
			paramValue.updateMe(null, theParameter, tblParameters.cnEcGetCellObject(rowIndex, 4), tblParameters.getCellText(rowIndex, 4));
			paramForm.aAllReportParameterValues.add(paramValue);
		endif;

		// If selected row ...
		if (rowIndex = tblParameters.row) then
			// ...store the parameter reference into the form.
			paramForm.setReportParameter(theParameter);

			if (theParameter.isPrimitiveType()) then
			// ...as primitive type.
				paramForm.setStringValue(tblParameters.getCellText(tblParameters.row, 4));	
			else
			// ...as object reference.
				paramForm.setObjectValue(tblParameters.cnEcGetItemObject(tblParameters.row, 4));
			endif;
		endif;
	endforeach;

	// Show parameter value maintenance form, and ...
    paramForm.showModal();

    // ...if parameter value updated ...
    if (paramForm.modalResult = 0) then
    	// ...update the value in a table ...
    	if (paramForm.aMyReportParameter.isPrimitiveType()) then
    		// ...as primitive type
	    	tblParameters.setCellText(tblParameters.row, 4, paramForm.aStringValue);
    	else
    		// ...as object reference
	    	tblParameters.cnEcSetItemObject(tblParameters.row, 4, paramForm.aMyObjectValue);

	    	if paramForm.aMyObjectValue = null then
 	    		tblParameters.setCellText(tblParameters.row, 4, '');
 	    	else
 	    		tblParameters.setCellText(tblParameters.row, 4, paramForm.aMyObjectValue.cnEcReportDisplay());
 	    	endif;
	    endif;
    endif;
epilog
	if (not paramForm = null) then
		paramForm.aAllReportParameterValues.purge();
		delete paramForm;
	endif;

	app.mousePointer	:=	Idle;
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="chkPrintToFile_click" id="64cceff6-8f7d-4f69-bfce-ecc4e326a1ed">
        <controlMethod name="CheckBox::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>chkPrintToFile_click(checkbox: CheckBox input) updating;

begin
	btnPrintFile.enabled	:=	checkbox.value;

	if checkbox.value then
		cmbPrinter.listIndex	:=	CNEC_NULL_INDEX;
		cmbPrinter.enabled		:=	false;
	else
		txtDestination.text		:=	null;
		cmbPrinter.enabled		:=	true;
		self.doSetPrinterListToDefault();
	endif;
end;</source>
        <Parameter name="checkbox" type="CheckBox" usage="input"/>
    </JadeMethod>
