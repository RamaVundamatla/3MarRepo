    <JadeMethod name="assignQueryHeadings" id="501b9662-7b5a-450b-ba60-d2b46c2b84fc">
        <source>assignQueryHeadings(_heading1, _heading2 : String output);
// ---------------------------------------------------------------------------
// Created:     02 August 2002 by cnwth2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//// 20 May 2016	cnwns1	TFS 488 - Multi Timezone Support
// ---------------------------------------------------------------------------
vars
	filtOpenLocalTS	:TimeStamp;
	filtCloseLocalTS:TimeStamp;
begin
	if self.queryType = QueryType_StkMoveByLocation then	
		if self.filtLocationType = LocationType_LC then
			_heading1 := 'Stock movements by Location: ' &amp; self.myFiltLC.getID;			
		elseif self.filtLocationType = LocationType_TA then
			_heading1 := 'Stock movements by Terminal Area: ' &amp; self.myFiltTA.id;			
		elseif self.filtLocationType = LocationType_Terminal then
			_heading1 := 'Stock movements by Terminal: ' &amp; self.myFiltTerminal.name;			
		elseif self.filtLocationType = LocationType_Voyage then
			_heading1 := 'Stock movements by Voyage: ' &amp; self.myFiltVoyage.code;						
		endif;
		
	endif;
	
	filtOpenLocalTS.cnEcSetDateAndTime(self.filtOpenDate,TimeStartOfDay);	// 20 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	filtCloseLocalTS.cnEcSetDateAndTime(self.filtCloseDate,TimeEndOfDay);	// 20 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	filtOpenLocalTS :=self.systemToLocalTime(filtOpenLocalTS);				// 20 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	filtCloseLocalTS := self.systemToLocalTime(filtCloseLocalTS);			// 20 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	
	_heading2 := 'Open date: ' &amp; filtOpenLocalTS.String &amp; ' Close Date: ' &amp; filtCloseLocalTS.String;
//	_heading2 := 'Open date: ' &amp; self.filtOpenDate.String &amp; ' Close Date: ' &amp; self.filtCloseDate.String;
end;</source>
        <Parameter name="_heading1" type="String" usage="output"/>
        <Parameter name="_heading2" type="String" usage="output"/>
    </JadeMethod>
