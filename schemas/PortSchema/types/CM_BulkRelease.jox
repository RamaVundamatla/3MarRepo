    <JadeMethod name="getExtraInfo" id="49c4fe49-d470-4273-a27f-7268a633cf7b">
        <source>getExtraInfo(_dataContainer: CM_DataContainer);
// ---------------------------------------------------------------------------
// Created:		August 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	ti	: CM_TrackedItem;
	str : String;
	block : CM_DataContainerBlock;

begin
	inheritMethod(_dataContainer);

	foreach ti in self.allTrackedItemsAssigned do
		//epr par 33924 16/3/15
		if str = null then
			str:= ti.id;
		else
			str := ti.id &amp;  CrLf &amp;  str;
		endif;
	endforeach;

	block := _dataContainer.addNewBlock;
	block.addNewItem(app.getErrorString(Attachments), DC_Label, 1, self);
	block.addNewItem(str, DC_Data, 1, self);
	// May 2011 cnwjre1 27097 CCMS 2043
	block := _dataContainer.addNewBlock;
	block.addNewItem(app.getErrorString(CanBeHiLowCube), DC_Label, 1, null);
	block.addNewItem(app.getYesNo(self.canBeHiLoCube), DC_Data, 1, null);
end;</source>
        <Parameter name="_dataContainer" type="CM_DataContainer"/>
    </JadeMethod>
