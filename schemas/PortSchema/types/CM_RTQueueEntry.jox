    <JadeMethod name="isBreakBulkGenericMaster" id="8f2d8bd2-98ea-49b6-933f-2f47d9a736bd">
        <source>isBreakBulkGenericMaster() : Boolean;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
07 May 2013	cnwrd1	Initial creation

*/

vars
	aTask : CM_RTQueueTask;
