    <JadeMethod name="doBuildComboNextPrevLane" id="fb24bdae-8640-4824-ae37-7b19b96a9e84">
        <source>doBuildComboNextPrevLane();
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
17 August 2009	cnwer1	Initial creation

*/

vars
	rtgLane : CM_RTGLane;
begin
	rtgLane :=self.cmbLaneGroup.listObject.CM_RTGLane;
	if rtgLane = null then
		self.cmbNextArea.clear;
		self.cmbPrevArea.clear;
		return;
	endif;
	if self.cmbNextArea.listObject &lt;&gt; null and self.cmbNextArea.listObject = rtgLane  then
		return;
	endif;
	if self.cmbPrevArea.listObject &lt;&gt; null and self.cmbNextArea.listObject = rtgLane  then
		return;
	endif;
	
	self.myAssistant.comboBoxRTGsLane(rtgLane,self.cmbNextArea,self.myCurrentObject.CM_RTGArea);
	self.myAssistant.comboBoxRTGsLane(rtgLane,self.cmbPrevArea,self.myCurrentObject.CM_RTGArea);

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doBuildComboStackDirIn" id="6c24c7de-da66-401c-8a4b-55f7a75717d4">
        <source>doBuildComboStackDirIn();
// ---------------------------------------------------------------------------
// Created:		September  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	idx : Integer;

begin

	self.cmbStackDirIn.clear();
	self.cmbStackDirIn.sorted := false;	
	idx := self.cmbStackDirIn.addItem("Stack pad position to maximum height, then move to next pad position in Row");
	self.cmbStackDirIn.itemData[idx] := STACK_UP_STACK;
	idx := self.cmbStackDirIn.addItem("Stack all pad positions one layer at a time, then move to next height in first Row");
	self.cmbStackDirIn.itemData[idx] := STACK_ALONG_ROW;
	idx := self.cmbStackDirIn.addItem("Stack pad position one layer at a time, then move to next height in Row");
	self.cmbStackDirIn.itemData[idx] := STACK_ALL_HEIGHT;	
end;</source>
    </JadeMethod>
    <JadeMethod name="doBuildComboStackDirOut" id="1cf46a7d-b71c-49c0-9e6e-ee1595a7db49">
        <source>doBuildComboStackDirOut();
// ---------------------------------------------------------------------------
// Created:		September  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	self.cmbStackDirOut.clear();
	self.cmbStackDirOut.sorted := false;		
	self.cmbStackDirOut.addItem("Lift all from the pad position, then move to next pad position in Row");
	self.cmbStackDirOut.addItem("Lift from top pad position one layer at a time, then move to next height in Row");
	self.cmbStackDirOut.addItem("Lift all from top pad position one layer at a time, then move to next height in first Row");
end;</source>
    </JadeMethod>
    <JadeMethod name="doBuildComboWorkPoints" id="0005857c-d036-47fc-8191-72cdb895759e">
        <source>doBuildComboWorkPoints(_ta : CM_TerminalAreaMaster);
// 28604 Nov 2011 don't show work points already assigned to another interchange, as these can't be used
vars
	workPoint : CM_WorkPoint;
begin
	self.cmbWorkPoint.clear();
	foreach workPoint in self.myTerminal.allWorkPointsByCode do
		if workPoint.myWorkPointInterchangeArea = null or
		   workPoint.myWorkPointInterchangeArea = _ta then
			self.cmbWorkPoint.addItemObject(workPoint.code, workPoint);
		endif;
	endforeach;
end;</source>
        <Parameter name="_ta" type="CM_TerminalAreaMaster"/>
    </JadeMethod>
    <JadeMethod name="doBuildCombos" id="e9fb2d01-d75f-4e63-b5b5-9ccfc70bd79a">
        <source>doBuildCombos();
//----------------------------------------------------------------
//	Created:	01 June 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
// 18/06/2010	cnwcs5	par 24418 - vehcile access combo
vars

begin

	self.doBuildComboStackDirIn();
	self.doBuildComboStackDirOut();
	//self.doBuildProductCombo();
	self.doBuildGateCombo();
	self.doBuildVehicleAccessCombo();	// par 24418
	
	self.myAssistant.comboBoxCargoTypes(self.cmbCargoType,null); //epr 31/3/14 CCMS 1366
	
	self.myAssistant.comboBoxGridDirection(self.cmbColumnDir, null);
	self.myAssistant.comboBoxGridDirection(self.cmbRowDir, null);
	self.myAssistant.comboBoxSideInterchange(self.cmbSideICPos);
	self.myAssistant.comboBoxWorkPoint(self.cmbWorkPoint, self.myTerminal);
end;</source>
    </JadeMethod>
    <JadeMethod name="doBuildDefaultInterchangeCombo" id="08c987f0-16e6-480a-ae99-b99ae457d55b">
        <source>doBuildDefaultInterchangeCombo(_defaultICArea : CM_InterchangeArea);

/*
Date			Who		Reason
11 Aug 2009		cnwar2	Initial creation
24 Feb 2010 	cnwer1  If in edit mode I need to also change the cmbTBICAreas 
*/
vars
	combo 		: ComboBox;
	ta, saveTA	: CM_TerminalArea;
	idx			: Integer;
	taSet		: CM_TerminalAreaSet;
begin
	combo 	:= self.cmbInterchange;
	saveTA	:= self.cmbInterchange.listObject.CM_TerminalArea;
	
	self.cmbInterchange.clear;
	self.cmbInterchange.sorted := true;
	self.cmbInterchange.addItem("");
	
	self.cmbTBICAreas.clear;
	self.cmbTBICAreas.sorted := true;
	self.cmbTBICAreasGC.clear;
	self.cmbTBICAreasGC.sorted := true;
	
	create taSet transient;
	self.listsTermAreas.getSelected( taSet);
	
	foreach ta in taSet discreteLock do	
		idx := self.cmbInterchange.addItem(ta.id);
		self.cmbInterchange.itemObject[idx] := ta;
		
		idx := self.cmbTBICAreas.addItem(ta.id);
		self.cmbTBICAreas.itemObject[idx] := ta;
		
		idx := self.cmbTBICAreasGC.addItem(ta.id);
		self.cmbTBICAreasGC.itemObject[idx] := ta;
	endforeach;
	
	if _defaultICArea &lt;&gt; null then
		if self.cmbInterchange.findObject(_defaultICArea) &gt; 0 then
			self.cmbInterchange.listObject := _defaultICArea;
			self.cmbInterchange.text 		 := _defaultICArea.id;
		endif;
		
		if self.cmbTBICAreas.findObject(_defaultICArea) &gt; 0 then
			self.cmbTBICAreas.listObject := _defaultICArea;
			self.cmbTBICAreas.text 		 := _defaultICArea.id; 
		endif;
		
		if self.cmbTBICAreasGC.findObject(_defaultICArea) &gt; 0 then
			self.cmbTBICAreasGC.listObject := _defaultICArea;
			self.cmbTBICAreasGC.text 		 := _defaultICArea.id; 
		endif;
	endif;
	
	tblMain.setValueByName(ETRow_InterchangeArea, self.cmbInterchange.text );
	
	//if in edit mode this gets called when changing the associated IC areas need to change the CMIF_GridLCsAssoc
	if mode &lt;&gt; self.Mode_View then
		self.updateAllCMIFGridLCsAssocIC(taSet);
			
	endif;

epilog
	delete taSet;
end;</source>
        <Parameter name="_defaultICArea" type="CM_InterchangeArea"/>
    </JadeMethod>
    <JadeMethod name="doBuildGateCombo" id="343929e8-3c57-4d60-9121-ba97943166a6">
        <source>doBuildGateCombo();

/*
Date			Who		Reason
11 August 2009	cnwar2	Initial creation

*/
vars
	combo 	: ComboBox;
	gate	: CM_Gate;
	idx		: Integer;
	
begin
	combo :=  self.cmbDefExitGate;
	combo.clear;
	combo.sorted := true;
	
	combo.addItem("");
	foreach gate in self.myTerminal.allGates discreteLock do
		if not gate.isOutGate then
			continue;
		endif;
		
		idx := combo.addItem(gate.name);
		combo.itemObject[idx] := gate;
	endforeach;

end;</source>
    </JadeMethod>
    <JadeMethod name="doBuildProductCombo" id="aece6f1b-3c3d-43a3-a72b-0ea8a1dfc5cb">
        <source>doBuildProductCombo();
// ---------------------------------------------------------------------------
// Created:		03 March 2008 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars	
	
begin	
	//epr TFS 1876 18/4/16
	self.myAssistant.comboBoxProduct(self.cmbProduct,self.cmbCargoType.listObject.CM_CargoType,null,null);
		
end;</source>
    </JadeMethod>
    <JadeMethod name="doBuildRailTransferCombo" id="97d48e07-6381-45f8-9460-40f9bcafde17">
        <source>doBuildRailTransferCombo(_transferArea : CM_YardTransferArea);

/*
Date		Who		Reason
13 Dec 2010	cnwar2	#25956
11 Jan 2011	cnwkpd1	PAR #26678 - Tidy up transient leaks

*/
vars
	ta		: CM_TerminalArea;
	idx		: Integer;
	theTAs	: CM_TAByTypeIdDict;
	iter	: Iterator;
	str		: String;
	
begin
	self.cmbRailTransfer.clear;
	self.cmbRailTransfer.sorted := true;
	self.cmbRailTransfer.addItem("");
		
	theTAs 	:= self.myTerminal.allTerminalAreasByTypeId;
	iter 	:= theTAs.createIterator();

	theTAs.startKeyGeq(TA_TYPE_RAIL_TRANS, null, iter);
	while iter.next(ta) do
		if iter.getCurrentKey(1).Integer = TA_TYPE_RAIL_TRANS then
			if ta = _transferArea
			or ta.CM_YardTransferArea.allTerminalAreas.isEmpty then	// only rail transfer areas not already associated with a rail track
				idx := self.cmbRailTransfer.addItem(ta.id);
				self.cmbRailTransfer.itemObject[idx] := ta;
			endif;
		else
			break;
		endif;
	endwhile;
	
	if _transferArea &lt;&gt; null then
		if self.cmbRailTransfer.findObject(_transferArea) &gt; 0 then
			self.cmbRailTransfer.listObject	:= _transferArea;
			self.cmbRailTransfer.text 		:= _transferArea.id;
		endif;
	endif;
	
	tblMain.setValueByName(ETRow_RailTransferArea, self.cmbRailTransfer.text );

epilog
	delete iter;		// PAR #26678
	
end;</source>
        <Parameter name="_transferArea" type="CM_YardTransferArea"/>
    </JadeMethod>
    <JadeMethod name="doBuildRowsForCages" id="51bdfded-76c2-42ad-8ccf-76753c3c4473">
        <updating/>
        <source>doBuildRowsForCages(_ta : CM_CraneTransferArea; _isShow : Boolean) protected, updating;
// -------------------------------------------
// Created 28 September 2005 by cnwdvb1
// -------------------------------------------
vars

	idx,
	start 		: Integer;
	craneLane	: CM_LocationsController;
	theName		: String;

begin

	self.numCraneLanes := self.tblMain.getValueByName(ETRow_NumLanes).Integer;
	if _isShow then
		foreach craneLane in _ta.lanes do
			idx := idx + 1;
			theName := 'craneLane' &amp; idx.String;
			self.tblMain.showRowByName(theName, false);
			self.tblMain.setValueByName(theName, craneLane.CM_CraneLaneController.numOfTwinLiftCages &gt; 0);
		endforeach;
		
		start := idx + 1;
		foreach idx in start to 8 do
			theName := 'craneLane' &amp; idx.String;
			self.tblMain.hideRowByName(theName, false);
		endforeach;
	else

		foreach idx in 1 to 8 do
			theName := 'craneLane' &amp; idx.String;
			if idx &lt;= self.numCraneLanes then
				self.tblMain.showRowByName(theName, false);
			else
				self.tblMain.hideRowByName(theName, false);
			endif;
		endforeach;
	endif;
	
	

end;</source>
        <access>protected</access>
        <Parameter name="_ta" type="CM_CraneTransferArea"/>
        <Parameter name="_isShow" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doBuildVehicleAccessCombo" id="a15ae9f4-cb9f-4f8c-a362-ba407c241602">
        <source>doBuildVehicleAccessCombo()protected;
// ---------------------------------------------------------------------------
// Created:     18 June 2010 by cnwcs5
// Purpose:     
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 18/06/2010	cnwcs5		par 24418
// ---------------------------------------------------------------------------
vars
	combo	:CMUI_ComboBox;
	int		:Integer;
begin
	combo := self.cmbVehicleAccess;
	
	combo.clear;
	
	combo.sorted	:= false;
	
	// Vehicles/Machines
	int := combo.addItem (app.getErrorString (Vehicles_And_Machines));
	combo.itemData[int] := CM_InterchangeArea.Access_VehicleMachines;
	// Vehicles Only
	int := combo.addItem (app.getErrorString (Vehicles_Only));
	combo.itemData[int] := CM_InterchangeArea.Access_Vehicles;
	// Machines Only
	int := combo.addItem (app.getErrorString (Machines_only));
	combo.itemData[int] := CM_InterchangeArea.Access_Machines;
	
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doCancel" id="947c3594-d02d-4b80-82ac-5ab2f335f25c">
        <updating/>
        <source>doCancel(): Boolean updating;
//-----------------------------------------------------------------------
//
//  Created by: cnwsh3
//
//	Date: 24 September 2003
//
//-----------------------------------------------------------------------

vars

begin
	//PAR 5846 23092003 CNWSH3
	//Added to include changeMode on CM_Entry tables which is set in init methods (ie. initExtraTable)
	//Has been set to ChangeMode_FirstOnly
	if self.tblAPYardStack.hasChanged or
		self.tblMain.hasChanged or
		self.tblExtra.hasChanged or
		self.oldRows &gt; 0 then		// 34353
			self.confirmCancel(app.getErrorString(The_Current_Item));
	endif;
	
	self.frmStrictGrid.visible := false;
	self.doClearClipBoard( false );	//21 Aug 2013	NDL	Par 32308
	self.oldRows := 0;		// 34353 change detection
	
	return inheritMethod();

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doChangeCargoType" id="d3104c9c-aea2-437e-a9b5-b5a97750358f">
        <updating/>
        <source>doChangeCargoType() updating;
/*

Date		Who		Reason
01 Apr 2014	cnwer1	Initial creation PAR
23 Jun 2020	jlgdap1	TFS 49453 ASPA Satellite View Screen for Flexible Terminal Areas
*/

vars
	cargoType : CM_CargoType;
	prod : CM_Product;
	prodMinMax : CM_TerminalAreaProductMinMax;
	measureType	 : CM_MeasurementType;
	measureTable : CMUI_MeasurementTable;
	unit		: String;
	converted	: String;
//	isGCArea 	: Boolean;						// TFS 49453
	weightRow, volumeRow, qtyRow : String;		// TFS 49453
begin

	tblExtra.setValueByControlName(self.cmbCargoType.name, self.cmbCargoType.text);
	
	cargoType:=self.cmbCargoType.listObject.CM_CargoType;
		
	if cmbProduct.listCount &gt; 0 then
		prod:=	self.cmbProduct.itemObject[1].CM_Product;
	endif;
	
	// TFS 49453
//30 Mar 2021	NDL 49912
//	if self.terminalAreaType = TA_TYPE_GEN_CARGO_ALLOC_ROW then	
//		isGCArea := true;
//		weightRow := ETRow_MaxWeightPerCol;
//		volumeRow := ETRow_TaMaxVolPerCol;
//		qtyRow := ETRow_MaxQtyPerCol;
//	else
		weightRow := ETRow_MaxWeight;
		volumeRow := ETRow_TaMaxVolume;
		qtyRow := ETRow_MaxQuantity;
//	endif;
	// TFS 49453
	
	if prod = null or  prod.myCargoType &lt;&gt; cargoType then
		self.doBuildProductCombo();		
	endif;
	if cargoType &lt;&gt; null then
		prodMinMax := self.tblExtraList.accessRow(self.tblExtraList.row).itemObject.CM_TerminalAreaProductMinMax;
		if cargoType.isBulkMulti then
			//self.tblExtra.hideRowByName(ETRow_MaxQuantity,false);						// TFS 49453
			self.tblExtra.hideRowByName(qtyRow,false);									// TFS 49453
			if cargoType.isTrackByWeight then
				//self.tblExtra.hideRowByName(ETRow_TaMaxVolume,false);					// TFS 49453
				//self.tblExtra.showRowByName(ETRow_MaxWeight,false);					// TFS 49453
				self.tblExtra.hideRowByName(volumeRow,false);							// TFS 49453
				self.tblExtra.showRowByName(weightRow,false);							// TFS 49453
				measureType:=cargoType.myWeightMeasurementType;
				unit := measureType.shortName;
				//measureTable:=self.tblExtra.getMeasurementTableForRowName(ETRow_MaxWeight);	// TFS 49453
				measureTable:=self.tblExtra.getMeasurementTableForRowName(weightRow);	// TFS 49453
				if prodMinMax &lt;&gt; null then
					converted := app.convertMeasurementForDisplay(unit, prodMinMax.maxWeight);
				endif;
				
			else
				//self.tblExtra.showRowByName (ETRow_TaMaxVolume,false);				// TFS 49453
				//self.tblExtra.hideRowByName(ETRow_MaxWeight,false);					// TFS 49453
				self.tblExtra.showRowByName (volumeRow,false);							// TFS 49453
				self.tblExtra.hideRowByName(weightRow,false);							// TFS 49453
				measureType:=cargoType.myVolumeMeasurementType;
				unit := measureType.shortName;
				//measureTable:=self.tblExtra.getMeasurementTableForRowName(ETRow_TaMaxVolume);	// TFS 49453
				measureTable:=self.tblExtra.getMeasurementTableForRowName(volumeRow);	// TFS 49453
				if prodMinMax &lt;&gt; null then
					converted := 	app.convertMeasurementForDisplay(unit, prodMinMax.maxVolume);
				endif;
						
			endif;
			measureTable.setMeasurementType(measureType.measurementType);
			measureTable.setValues( converted  &amp; " " &amp; unit );
			tblExtra.setValueByControlName(measureTable.name, converted  &amp; " " &amp; unit );
		else
			//self.tblExtra.showRowByName (ETRow_MaxQuantity,false);					// TFS 49453
			//self.tblExtra.hideRowByName(ETRow_MaxWeight,false);						// TFS 49453
			//self.tblExtra.hideRowByName(ETRow_TaMaxVolume,false);						// TFS 49453
			self.tblExtra.showRowByName (qtyRow,false);									// TFS 49453
			self.tblExtra.hideRowByName(weightRow,false);								// TFS 49453
			self.tblExtra.hideRowByName(volumeRow,false);								// TFS 49453
			if prodMinMax &lt;&gt; null then
				converted:=prodMinMax.maxQuantity.asStringJMT;
			endif;
			//tblExtra.setValueByName(ETRow_MaxQuantity,converted);						// TFS 49453
			tblExtra.setValueByName(qtyRow,converted);									// TFS 49453
		endif;
	endif;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doCheckNumLaneChange" id="40a7171d-1054-4bdb-9057-ae448676eda6">
        <source>doCheckNumLaneChange(): Boolean protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
11 February 2010	cnwjk3	ccms 1018

*/

vars
	laneNum,
	numLanes 	: Integer;
	pxyTA,
	realTA 		: CM_RoRoLaneArea;
	lane		: CM_RoRoController;
begin
	if terminalAreaType &lt;&gt; TA_TYPE_RORO_LANE_AREA then
		return false;
	endif;
	
	if self.myProxyObject = null then
		return false;
	endif;
	pxyTA := self.myProxyObject.CM_RoRoLaneArea;
	
	realTA := pxyTA.pxyGetRealObject().CM_RoRoLaneArea;
	if realTA = null then
		// Asume that the roro lane area is being created
		return true;
	endif;
	
	numLanes := tblMain.getValueByName(ETRow_LaneCount).Integer;
	
	if numLanes &gt;= realTA.laneCount then
		return true;
	endif;
	
	//user has specified less lanes then real object already has, so we need to check if there is any cargo in there
	foreach laneNum in numLanes + 1 to realTA.laneCount do
		lane := realTA.allLanesByLaneNumber[laneNum];
		if lane.hasQueuedPlannedActualTIs() then
			app.msgBox(app.getErrorString(RoRo_LaneHasCargo), lane.myTerminalArea.getID(), MsgBox_OK_Only);	
			
			self.tblMain.setValueByName(ETRow_LaneCount, realTA.laneCount.String);
			pxyTA.setLaneCount(realTA.laneCount);
			self.shtDefData.setFocus();
			return false;
		endif;
	endforeach;
	
	return true;
epilog

end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doClearClipBoard" id="d77836c5-dd61-4735-9425-bc7921876b85">
        <updating/>
        <source>doClearClipBoard(_refresh : Boolean) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 August 2013	cnwndl1	Initial creation	Par 32308

*/

vars

begin

	if self.frmBlkArea.myDrawingController &lt;&gt; null  then
		self.frmBlkArea.myDrawingController.allCopiedItems.clear();
		self.frmBlkArea.myDrawingController.allSelectedObjects.clear();
		self.mnuPaste.userObject := null;
		if _refresh then
			self.frmBlkArea.myDrawingController.refreshLocations();
		endif;
	endif;
	self.mnuPaste.caption := app.getErrorString(Paste); //"Paste";

epilog

end;</source>
        <Parameter name="_refresh" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doClonedMenuClickSpecial" id="b2f1f387-addb-4931-8d5b-3dce08798b18">
        <updating/>
        <source>doClonedMenuClickSpecial(menuItem: MenuItem input) updating, protected;
// ---------------------------------------------------------------------------
// Created:		August 2004 By Andrew Bishop cnwab1
//
// Purpose:		hack to get the show captions going on the designer toolbar
//
// ---------------------------------------------------------------------------

vars

begin
	self.frmToolbarDesign.showCaptions := not self.frmToolbarDesign.showCaptions;
	self.frmMain.top := self.frmToolbarDesign.clientHeight + 2;
