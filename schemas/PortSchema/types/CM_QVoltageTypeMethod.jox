    <JadeMethod name="translateToSearchValue" id="68ccf39e-1e8f-4a65-8fc3-3c9e032a28f0">
        <source>translateToSearchValue(_value: Any): Any;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 December 2009	cnwdap1	Initial creation
*/
