    <JadeMethod name="cmbTable_keyUp" id="3c6c477c-95f7-4ee5-9e74-f69f511b4467">
        <controlMethod name="ComboBox::keyUp"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbTable_keyUp(combobox: ComboBox input; keyCode: Integer io; shift: Integer) updating;
// --------------------------------------------------------------------------------
// Created:		2 March 2010 by cnwjo3
//
// Purpose:		par 22729
//
vars

begin
	if not combobox.isDroppedDown then
		if keyCode = 38 or keyCode = 40 or keyCode = 33 or keyCode = 34 then  //38 = up arrow, 40 = down arrow, 33 = page up, 34 = page down
			self.cmbTable_closeup(combobox);
		endif;
	endif;
end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
        <Parameter name="keyCode" type="Integer" usage="io"/>
        <Parameter name="shift" type="Integer"/>
    </JadeMethod>
