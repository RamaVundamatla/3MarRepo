    <JadeMethod name="getAdvWOTransactionType" id="6c39ce66-9d70-45f8-9c8c-c77472c181c5">
        <source>getAdvWOTransactionType(transType : Integer): Integer;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
04 October 2022		navcs2	ChangeRequest 56633:[56211] 54253.101 - Work order Transactions

*/

vars

begin
	if transType = TRANS_CREATED then
		return TRANS_TYPE_WO_TODO_VOY_CREATED;
	elseif transType = TRANS_UPDATED then
		return TRANS_TYPE_WO_TODO_VOY_UPDATED;
	else
		return TRANS_TYPE_WO_TODO_VOY_COMPLET;
	endif;
epilog

end;</source>
        <Parameter name="transType" type="Integer"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
