    <JadeMethod name="doBaseFormSave" id="8099acc6-1eb2-4eed-bc76-44288adb1a0f">
        <updating/>
        <source>doBaseFormSave() updating, protected;
//----------------------------------------------------------------
//	Created:	20 May 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	fileObj		: File;
	
begin
	create fileObj transient;
	
	if not fileObj.cnEcSetSaveName(null, false, true, null) then
		return;
	endif;
	
	fileObj.openOutput(fileObj.fileName);
	fileObj.writeString(self.txtData.text);
epilog
	delete fileObj;	// This will also close the file.
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doResize" id="9571c79d-f654-4239-a933-c4f741fb9d82">
        <updating/>
        <source>doResize() updating;
//----------------------------------------------------------------
//	Created:	20 May 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
/*

Date		Who		Reason
21 Oct 2010	cnwkpd1	Fixed resize to use clientHeight and client width to prevent clipping
29/11/2011	cnwcs5	CCMS POL 2122 / par 28696 - txtData not has parentAspect set

*/
begin
	frmToolbar.width := self.clientWidth;
	
	frmToolbar.positionToolbarControls();
end;</source>
    </JadeMethod>
    <JadeMethod name="highlightText" id="efbcfb63-f824-4fd1-bfac-c34514fc0681">
        <source>highlightText(_highLightText :String);
/*
Date		Who		Reason
29 Nov 2011	cnwcs5	Initial creation - CCMS POL 2122 / par 28696 - Empty Releases via COPARN
*/
vars
	rtf		:CMUI_RichText;
	length, pos	:Integer;
begin
	rtf	:=	self.txtData;
	
	if _highLightText &lt;&gt; null then
		length			:=	rtf.text.length();
		pos				:=	rtf.find(_highLightText, 1, length, JadeRichText.Find_Default);
		rtf.selStart	:=	pos;
		rtf.selLength	:=	_highLightText.length();
	endif;
epilog

end;</source>
        <Parameter name="_highLightText" type="String"/>
    </JadeMethod>
    <JadeMethod name="keyDown" id="82ed767e-0b52-4497-b364-0be0c843b5bb">
        <controlMethod name="Form::keyDown"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>keyDown(keyCode: Integer io; shift: Integer) updating;
// --------------------------------------------------------------------------------
// Created:		20 February 2006 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if shift.cnEcIsCtrlKey() and keyCode = J_key_F then
		app.mousePointer	:=	Busy;
		txtData.showFindDialogJmt(true, true);
	endif;
	
	inheritMethod(keyCode, shift);
epilog
	app.mousePointer	:=	Idle;
end;</source>
        <Parameter name="keyCode" type="Integer" usage="io"/>
        <Parameter name="shift" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="loadBigMessage" id="c2d68fb8-b68d-4d5b-a22b-242e5ebdf903">
        <updating/>
        <source>loadBigMessage(_message : String;
			   _messageAsArray : Array; 
			   _highLightText: String) updating;

/*
Purpose:		It writes the big text to a temp file on a disk and shows progressBar
 				Then uses loadFromFile to set RTF text value (140000 rows - quicker up to 11 times)	

Date		Who		Reason
29 Nov 2011	cnwcs5	Initial creation - CCMS POL 2122 / par 28696 - Empty Releases via COPARN
15 Dec 2014	cnwkpd1	PAR #34713 - Changes for .NET EDI Integration
//10 Nov 2015	cnwrs1	Par 36863 - make EDI consistant times when refreshing progress bar - dont add CrLf when doing writline
*/
constants
	TempFileName		: String	= 'editemp.txt';
vars
	any					: Any;
	file				: File;	
	cmifMonitor 		: CMIF_Monitor;
	passport			: CM_Passport;
	rowsDone, rowsToDo	: Integer;
	updateMonitor		: Boolean;
	stepMonitor			: Integer;
	line				: String;
	pos					: Integer;
	
begin
// --------------------------------------
// 	   creating file and JadeRichText
// --------------------------------------
	create file;
	file.fileName := app.getTempDir() &amp; '\' &amp; app.getFileName( TempFileName );
	file.openOutput(file.fileName);
	rowsDone := 0;

// --------------------------------------
// 			CMIF_Monitor
// --------------------------------------
	if _messageAsArray &lt;&gt; null then
		rowsToDo := _messageAsArray.size;
	
		if rowsToDo &gt; 100 then
			stepMonitor := rowsToDo div 100;
		else
			stepMonitor := 1;
		endif;
		passport := app.myPassport;
		cmifMonitor := passport.myCMIFMonitor;
		if cmifMonitor &lt;&gt; null then
			delete cmifMonitor;
		endif;
		
		create cmifMonitor transient;
		cmifMonitor.myParent := self;
		passport.setMyCMIFMonitor(cmifMonitor);
		updateMonitor := passport &lt;&gt; null;
	
		self.modalDialogShow(null, app.getErrorString (Cancel), null, null, 'Loading EDI File...',  'Please Wait....');
		self.pbProgressBar.visible := true;
		
		foreach any in _messageAsArray discreteLock do	
			if any.isKindOf(Object) and CM_LongString.hasInstance(any.Object) then
				file.writeLine(any.CM_LongString.string); 
			elseif any.isKindOf(Binary) then
				file.writeLine(any.Binary.uncompressToString()); 
			else
				file.writeLine(any.String); 
			endif;
			
			rowsDone := rowsDone + 1;
			
			if updateMonitor and (rowsDone mod stepMonitor = 0) then
				if not cmifMonitor.updateProgress(cmifMonitor.message, rowsToDo, rowsDone) then
					return;
				endif;
			endif;
		endforeach;	
		
		if updateMonitor then	// to show the last 100% picture
			cmifMonitor.updateProgress(cmifMonitor.message, rowsToDo, rowsToDo);
		endif;

	else
		// PAR #34713 - just create a file with the raw message
		file.writeString(_message);
	endif;	
	
	
	file.close;
	file.commit;
// --------------------------------------
// 	   			set text
// --------------------------------------
	self.txtData.loadFromFile( file.fileName, CMUI_RichText.LoadFromFile_ReplaceAll, CMUI_RichText.LoadFromFile_PlainText );
	
	file.purge();	
	
// ---------------------------------------
//			hightlight text
// ---------------------------------------
	if _highLightText &lt;&gt; null then
		self.highlightText (_highLightText);
	endif;

epilog
	if file &lt;&gt; null then
		delete file;
	endif;
	
	if cmifMonitor &lt;&gt; null then
		delete cmifMonitor;
	endif;
	
	app.myPassport.setMyCMIFMonitor(null);
	
	self.frmModalDialog.visible := false;					
end;</source>
        <Parameter name="_message" type="String"/>
        <Parameter name="_messageAsArray" type="Array"/>
        <Parameter name="_highLightText" type="String"/>
    </JadeMethod>
    <JadeMethod name="loadSmallMessage" id="e78db53f-c52c-435a-b738-f12fa520ace4">
        <source>loadSmallMessage(_message: String; _messageAsArray: Array; _highLightText :String);
/*
Date		Who		Reason
29 November 2011	cnwcs5	Initial creation - CCMS POL 2122 / par 28696 - Empty Releases via COPARN

*/
vars
	rtf		: CMUI_RichText;
	txtAny	: Any;
	any		: Any;
	text	: String;
	lastLength : Integer;	//05 Apr 2017	NDL	TFS 3991


begin
	rtf	:=	self.txtData;

	
	if _messageAsArray = null then
		rtf.text	:=	_message;

	else
		foreach any in _messageAsArray do
			if any.isKindOf(Object) then
				if CM_LongString.hasInstance(any.Object) then
					txtAny	:=	any.CM_LongString.string;
				else
					txtAny	:=	any;
				endif;
			elseif any.isKindOf(Binary) then
				txtAny	:=	any.Binary.uncompressToString();		
			else
				txtAny	:=	any;
			endif;

				
			if text = "" then
				text	:=	txtAny.String;
			else
				if lastLength = 2047 then	//05 Apr 2017	NDL	TFS 3991
					text	:=	text &amp; txtAny.String;
				else
					text	:=	text &amp; CrLf &amp; txtAny.String;
				endif;
			endif;
			lastLength := txtAny.String.length;	//05 Apr 2017	NDL	TFS 3991
		endforeach;
		
		rtf.text	:=	text;

	endif;

// ---------------------------------------
//			hightlight text
// ---------------------------------------
	if _highLightText &lt;&gt; null then
		self.highlightText (_highLightText);
	endif;


epilog

end;
</source>
        <Parameter name="_message" type="String"/>
        <Parameter name="_messageAsArray" type="Array"/>
        <Parameter name="_highLightText" type="String"/>
    </JadeMethod>
    <JadeMethod name="mnuCopy_click" id="612d7d41-bee7-4b42-913f-eaf53c155aa8">
        <controlMethod name="MenuItem::click"/>
