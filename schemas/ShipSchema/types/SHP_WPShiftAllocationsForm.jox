    <JadeMethod name="doAddToJob" id="1ae03ff0-bece-4cc7-b643-d79496496aec">
        <updating/>
        <source>doAddToJob():Boolean protected, updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 June 2017	cnwndl1	Initial creation	TFS 4948

*/

vars

	jobToAddTo : CM_VoyageHoldJob;
	pxyJob : CM_VoyageHoldJob;
	idx : Integer;
	ctrl : Control;
	obj : Object;
	fromTable : CM_DataTable;
	tisToAdd : CM_TISet;
	ti : CM_TrackedItem;
	moveAmount : String;
	moveType : Integer;
	pos : Integer;
	wle : CM_VoyageWLE;
	toTable : CM_DataTable;
	str : String;
	rowIndex : Integer;
	
begin

	foreach idx in 1 to self.allocatedTableCount do
		ctrl := self.shtAllocatedGang.getControl(idx);
		if ctrl &lt;&gt; null and ctrl.isKindOf(CMUI_Sheet) then
			if ctrl.enabled then
				obj := ctrl.userObject;
				if obj.isKindOf( CM_VoyageHoldJob ) then
					jobToAddTo := obj.CM_VoyageHoldJob;
					toTable := self.tblAllocatedGang.getControl(idx+1).CM_DataTable;
					break;
				endif;
			endif;
		endif;
	endforeach;
	
	if jobToAddTo = null then
		return false;
	endif;
	
	pxyJob := jobToAddTo.pxyGetProxyObject;
	if pxyJob &lt;&gt; self.myPxyJobForEdit then
		self.setMyPxyJobForEdit(jobToAddTo,false);
	endif;
	
	if jobToAddTo.isDischarge then
		fromTable := self.tblOnShip;
	else
		fromTable := self.tblOnSite;
	endif;
	
	if fromTable = null or not fromTable.enabled then
		return false;
	endif;
	
	create tisToAdd transient;
	fromTable.allSelectedObjects.copy( tisToAdd );
	
	if tisToAdd.isEmpty then
		app.msgBox( "No Unallocated Cargo selected to add", app.getErrorString(Warning), MsgBox_OK_Only );
		return false;
	endif;
	
	foreach ti in tisToAdd do
		if (self.chkDLR.value or self.chkSOB.value) and ti.getImExStatus &lt;&gt; TI_IMEX_STATUS_REMAINONBOARD then
			app.raiseCMException4(Cargo_must_be_ROB_for_DLRSOB, ti.id, app.getErrorString(In_Transit), app.getErrorString(CM_DLR), app.getErrorString(CM_SOB), null, null);
			return false;
		endif;
	endforeach;
	
	// create the transient wles
	foreach ti in tisToAdd do	
		wle := null;
		if ti.canMergeBreakBulk() then										
			moveAmount := null;													
			if self.getQuantityForMove(ti, moveAmount, moveType) then			
				create wle transient;											
				wle.setMyTrackedItem(ti);
				wle.setJob( jobToAddTo );
				if moveType = self.ByQuantity then								
					pos := moveAmount.pos(Tab, 1);								
					wle.setQuantity(moveAmount[pos+1:end].Integer);				
				elseif moveType = self.ByVolume or moveType = self.ByWeight then
					pos := moveAmount.pos(Tab, 1);								
					wle.setWeight(moveAmount[pos+1:end].Decimal);				
				endif;															
				self.allPxyWles.add(wle);																						
			endif;
		else
			create wle transient;											
			wle.setMyTrackedItem( ti );
			wle.setJob( jobToAddTo );
			wle.setQuantity( ti.totalQuantity.max(1) );
			wle.setWeight( ti.totalWeight );
			self.allPxyWles.add( wle );	
		endif;	
		
		//add to the job table
		str := ti.getAttribStringForDefArrayJob(toTable.allTblDataEntRows, jobToAddTo);
		rowIndex := toTable.addItem(str);
		toTable.accessRow(rowIndex).itemObject := ti;
		toTable.accessCell(rowIndex,1).itemObject := wle;
		self.doColourTableRow(ti, null, toTable, jobToAddTo, rowIndex);
		
		//remove them from the unallocated table
		idx := null;
		if fromTable.findObjectInRow(ti, idx) then
			fromTable.removeItem(idx);
		endif;
		
	endforeach;
	
	return true;

epilog

	delete tisToAdd;

end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doAssignToDirectRelease" id="75c1721e-9ed6-4fee-ab4d-b7e91c488417">
        <updating/>
        <source>doAssignToDirectRelease(wles : CM_WLEArray) updating;
/*

Purpose:			Assigns the currently selected load WLE as a Direct Release if possible

Parameters:			

Return Value:		

Date				Who		Reason
19 August 2019		jlgzm1	Initial creation TFS 42872 Direct Release Between HOLD Voyages and Rail
23 October 2019		jlgzm1	TFS 47085 Direct Release Ship to Ship
09 October 2023		jlizm1	Initial creation TFS 59730 Kiosk Load Sequence

*/

vars
	result			: Integer;
	wlesWithWarnings,
	wleSet 			: CM_WLESet;
	
begin
	create wleSet transient;
	create wlesWithWarnings transient;
	
	if wles &lt;&gt; null then		// TFS 47085
		wles.copyNoDups(wleSet);		// TFS 47085
	else
		self.getCurrentlySelectedWLEs(wleSet);
	endif;
	
	while true do
		app.myTrxUA.trxUpdateWLEsSetDirectRelease(wleSet, wlesWithWarnings, app.myPassport);
		if app.myPassport.trxCompletedOK then
			// Clear errors/warnings from form and err/warnings window
			self.clearErrorWarnings();
			break;
		else
			result := app.showErrorWarningDialog(self.caption, app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnSkipErr);
			if result = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				
				// only reprocess the wles that had warnings.
				wleSet.clear;
				wlesWithWarnings.copy(wleSet);
				wlesWithWarnings.clear;
				continue;
			endif;
			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
		endif;
		break;
	endwhile;
	
epilog
	delete wleSet;
	delete wlesWithWarnings;
end;</source>
        <Parameter name="wles" type="CM_WLEArray"/>
    </JadeMethod>
    <JadeMethod name="doBaseFormCancel" id="1ee1ee69-ebdf-4bd1-8454-2ea9c8de1736">
        <updating/>
        <source>doBaseFormCancel() updating, protected;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 09/01/2017	cnwdap1		Initial creation TFS 3219 LNX Voyage Operations Enhancements
//
vars
	returnValue : Integer;

begin
	if self.mode = self.Mode_Add or self.mode = self.Mode_Update then
		if self.isFormChanged then
			returnValue := app.msgBox(app.getErrorString1(ConfirmCancel, app.getErrorString(Job) &amp; Space &amp; self.fldData.topSheet.caption), app.getErrorString(ConfirmCancelHeading), MsgBox_Yes_No + MsgBox_Question_Mark_Icon + MsgBox_Default_Second);
			
			if returnValue = MsgBox_Return_No then
				return;
			endif;
		endif;
	
		self.mode := self.Mode_View;
		self.doRefresh();
		self.setControlsForView();
		return;
	endif;
	
	inheritMethod();
	self.unloadForm();
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doBaseFormSave" id="6aeb1bab-9214-4382-bfde-6b0029101936">
        <updating/>
        <source>doBaseFormSave() updating, protected;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 24/01/2017	cnwdap1		Initial creation TFS 3219 LNX Voyage Operations Enhancements
// 01/03/2017	cnwdap1		TFS 3516 LNX Hold Planning Quantity
// 20/09/2017	jlgdap1		TFS 6935 SNO Correct possible error 4 
// 15/06/2018	jlger1		tfs 39166 this form was driving me crazy with pxy errors and leaking transients
// 23/10/2019	jlgzm1		TFS 47085 Direct Release Ship to Ship
// 16/07/2020   cnwma1      Bug 49445: MTN - Removing final cargo from job in hold planning causes Error 4
// 22/10/2024	navcs2		MTN-28961 EUP | Transaction Instrumentation - Voyage Planning
// 14 Jan 2026 	navhl20 	Bug MTN-35897: PEN - System Locking Errors (1000010 - Unknown message)
//
vars
	pxyJob, 
	job 		        : CM_VoyageHoldJob;
	jobParams           : CMIF_VoyageJobParams;
	allocatedTIs        : CM_TISet;
	idx, 
	result              : Integer;
	ctrl	            : Control;
	wles                : CM_WLEArray;										
	hadValidationErrors : Boolean;
	isDRTranship        : Boolean;	
begin
	create jobParams transient;
	create allocatedTIs transient;
	create wles transient;								// TFS 3516
	if self.mode = self.Mode_Add then
		create pxyJob transient;
	else
		pxyJob := self.myPxyJobForEdit;
		job := pxyJob.pxyGetRealObject.CM_VoyageHoldJob;
		foreach idx in 1 to self.allocatedTableCount do
			ctrl := self.shtAllocatedGang.getControl(idx);
			if ctrl &lt;&gt; null and ctrl.enabled then
				if job = ctrl.userObject.CM_VoyageHoldJob then
					self.fldData.topSheet := ctrl.CMUI_Sheet;
					break;
				endif;
			endif;
		endforeach;
	endif;
	

	if not self.setProxyAndParams(pxyJob, jobParams, allocatedTIs, wles,  self.mode = self.Mode_Add) then			
		hadValidationErrors:=true;
		return;  //epr 40322 30/8/18	
	endif;// TFS 3516

	
	if self.mode = self.Mode_Add then
		if jobParams.myLocation= null then
			
			app.msgBox(app.getErrorString(WARN_DoorDirectionRuleLocation),app.getErrorString(Voyage), MsgBox_OK_Only);
			hadValidationErrors:=true;
			return;
		endif;
		
		if self.fldData.topSheet = self.shtTranship and chkDirectRelease.value then // TFS 47085
			isDRTranship := true;	// TFS 47085
		endif;
	endif;
	
	while true do
		if self.mode = self.Mode_Add then
			app.myTrxCA.trxCreateVoyageHoldJob(jobParams, job, app.myPassport, wles);	// TFS 3516
		else
			app.myTrxUA.trxUpdateVoyageHoldJob(jobParams, pxyJob, job, app.myPassport, wles);
		endif;
		if app.myPassport.trxCompletedOK then
			global.beep;
			break;
		else
			result := app.showErrorWarningDialog(app.getErrorString(Voyage_job), app.myPassport, ErrWarnMode_Add + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   result = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				// job sheet on the params gets deleted if we abort the transaction due to warnings	// TFS 6935
				if not app.isValidObject(jobParams.myJobSheet) then									// TFS 6935
					jobParams.myJobSheet := null;													// TFS 6935
				endif;																				// TFS 6935
				continue;
			endif;
		endif;
		return;
	endwhile;

	if not hadValidationErrors and isDRTranship and job &lt;&gt; null then	// TFS 47085
		// Once job created successfully, attempt to assign everything to direct release
		// Doesn't matter if anything in here fails. Still want the job created,
		// the user can manually reassign cargo to DR later
		self.doAssignToDirectRelease(job.workListEntries); // TFS 47085
	endif;
	
epilog
	// non-null errorMsg means Save pressed without creating a job first - 
	// don't delete proxies and go back to view mode, just let them Create Job 
	
	if self.mode = self.Mode_Add then           //16.07.2020 cnwma1 #49445
		if pxyJob &lt;&gt; null 
		and pxyJob.myShift &lt;&gt; null 
		and pxyJob.myShift.isTransient then
			delete pxyJob.myShift;
		endif;
		delete pxyJob;	
	endif;
	
	if not hadValidationErrors and (app.myPassport.trxCompletedOK or isDRTranship) then	// TFS 47085
		
		self.mode := self.Mode_View;
		self.doRefresh();
		self.setControlsForView(); 
		
		self.setFormChanged(false, null, null, null, null);
	endif;

	delete jobParams;
	delete wles;
	delete allocatedTIs;// TFS 3516
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doBtnEventAlloc" id="d5235e40-2272-43ed-9927-1fa299e9d48c">
        <source>doBtnEventAlloc();
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 25/01/2017	cnwdap1		Initial creation TFS 3219 LNX Voyage Operations Enhancements
//
vars
	form : Form;
	
begin
	
	form := app.loadForm(SHP_EventAllocationForm, CMUI_Assistant, false, false, false, self.myTerminal, null);
	if form = null or self.myCurrentVoyage = null then
		return;
	endif;	
	form.SHP_EventAllocationForm.setVoyage(self.myCurrentVoyage);

	form.show;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doBtnEventTrans" id="60992403-5f98-47fc-b940-00ea836df4cc">
        <source>doBtnEventTrans();
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 17/02/2017	cnwdap1		Initial creation TFS 3220 LNX Voyage Operations Enhancements
// 20/04/2017	cnwdap1		TFS 4174 Additional Information in Voyage Events
//
vars
	job : CM_VoyageJob;					// TFS 4174
	shift : CM_Shift;					// TFS 4174
	jobSheet : CM_VoyageJobSheet;		// TFS 4174
	
begin
	if self.myCurrentVoyage &lt;&gt; null then
		if self.fldData.topSheet.userObject &lt;&gt; null then										// TFS 4174
			job := self.fldData.topSheet.userObject.CM_VoyageJob;								// TFS 4174
			shift := job.myShift;																// TFS 4174
			jobSheet := job.myJobSheet.CM_VoyageJobSheet;										// TFS 4174
		endif;																					// TFS 4174
		//self.myAssistant.showEventTransactions(self.myCurrentVoyage, null);					// TFS 4174
		self.myAssistant.showEventTransactions(self.myCurrentVoyage, shift, jobSheet, job);		// TFS 4174
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doBuildComboVoyages" id="192409ab-425d-41c0-8a72-8e3463512344">
        <source>doBuildComboVoyages();
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 09/01/2017	cnwdap1		Initial creation TFS 3219 LNX Voyage Operations Enhancements
//
vars

begin
	self.allVoyages.clear;
//	self.myTerminal.getAllVoyagesOperational(self.allVoyages, false, app.myPassport);
	self.myTerminal.getAllVoyagesOperational(self.allVoyages, self.chkCurrentVoys.value, app.myPassport);	//23 Feb 2021	NDL	TFS 50836
	self.cmbVoyage.listCollection(self.allVoyages, false, 0);
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doBuildContextMenu" id="22352d20-33c8-4e5c-b2bf-f9280b3b1982">
        <updating/>
        <source>doBuildContextMenu(cntrl: Table input; conwin: Window input; mouse: Boolean; x: Integer; y: Integer):Boolean updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 17/01/2017	cnwdap1		Initial creation TFS 3219 LNX Voyage Operations Enhancements
// 19/08/2019	jlgzm1		TFS 42872 Direct Release Between HOLD Voyages and Rail
//
vars
	xLeft : Real;
	yTop : Real;
	obj : Object;
	currentTI : CM_TrackedItem;
	hasCurrentTI : Boolean;
	useTaskForm : Boolean;
	currentWle : CM_WorkListEntry;
	topSheet : CMUI_Sheet;
	holdJob : CM_VoyageHoldJob;
	wle : CM_WorkListEntry;
	iter : Iterator;

begin
	xLeft := x;
	yTop := y;
	
	conwin.windowToScreen(xLeft, yTop);
	self.screenToWindow(xLeft, yTop);
	self.mnuVoyageContext.userObject := cntrl;	
	self.mnuColourLegend.userObject := cntrl.CM_DataTable;	//24 Nov 2017	NDL	TFS 7801
	
	useTaskForm := self.myTerminal.getConfig(UseTaskFormCount).Boolean;
	obj := self.mnuVoyageContext.userObject;
	currentTI := self.myCurrentTrackedItem;
	currentWle := self.myCurrentWLE; 				// TFS 42872
	if currentTI = null and currentWle &lt;&gt; null then	// TFS 42872
		currentTI := currentWle.myTrackedItem;		// TFS 42872
	endif;											// TFS 42872
	
	//28 Jun 2017	NDL	TFS 4948
	mnuInspectObject.userObject := null;
	
	/* TFS42872
	// myCurrentWLE is now set in tableRowChange, so wle can be used everywhere in the form
	if currentTI &lt;&gt; null then
		topSheet := cntrl.parent.CMUI_Sheet;
		if topSheet.userObject &lt;&gt; null and topSheet.userObject.isKindOf( CM_VoyageHoldJob ) then
			holdJob := topSheet.userObject.CM_VoyageHoldJob;
		endif;
		if holdJob &lt;&gt; null and not  holdJob.workListEntries.isEmpty then
			iter := holdJob.workListEntries.createIterator;
			while iter.next( wle) do
				if wle.status &lt;&gt; WLE_UNACTIONED then
					continue;
				endif;
				if wle.myTrackedItem &lt;&gt; currentTI then
					continue;
				endif;
				currentWle := wle;
				break;
			endwhile;
		endif;
	endif;
	*/
	self.mnuCargo.visible := true;	

	self.mnuSetStops.visible := false;
	self.mnuTasksAdd.visible := false;
	self.mnuTasksComp.visible := false;
	self.mnuTasksRemove.visible := false;
	self.mnuCargoTaskAdd.visible := false;
	self.mnuCargoTaskComplete.visible := false;
	self.mnuCargoTaskRemove.visible := false;
	self.mnuQtyChg.visible := false;
	
	//28 Jun 2017	NDL	TFS 4948
	if self.mode &lt;&gt; Mode_View then
		self.mnuQtyChg.visible := true;
		self.mnuQtyChg.enabled := false;
		self.mnuQtyChg.userObject := null;
		if currentTI &lt;&gt; null and currentWle &lt;&gt; null then
			if currentTI.myCargoType.isBreakBulkMulti or currentTI.myCargoType.isBulkMulti then
				self.mnuQtyChg.enabled := true;
				self.mnuQtyChg.userObject := currentWle;
			endif;
		elseif currentWle = null then
			self.mnuQtyChg.visible := false;
		endif;
	endif;
	//12 Mar 2018	NDL	TFS 37444
	self.mnuRemoveJob.visible:=false;
	if self.mode &lt;&gt; Mode_View then
		self.mnuRemoveJob.visible := app.myCurrentUserCan(self.myTerminal, self.permissionMaint);
		if self.mnuRemoveJob.visible then
			self.mnuRemoveJob.enabled := false;
			self.mnuRemoveJob.userObject := null;
			if currentTI &lt;&gt; null and currentWle &lt;&gt; null and currentWle.status = WLE_UNACTIONED then
				self.mnuRemoveJob.enabled := true;
				self.mnuRemoveJob.userObject := currentWle;
			else
				self.mnuRemoveJob.visible := false;
			endif;
		endif;
	endif;
	
	if currentTI &lt;&gt; null then 
		hasCurrentTI := true;
		
		self.mnuCargoEnquiry.visible 	:= true;	
		self.mnuCargoEdit.visible 		:= true;
		self.mnuCargoEnquiry.userObject := currentTI;	
		self.mnuCargoEdit.userObject 	:= currentTI;
		
		self.mnuSetStops.userObject	:= currentTI;
		self.mnuSetStops.visible 	:= true;
		self.mnuSetStops.enabled 	:= true;
		
		if useTaskForm then
			self.mnuCargoTaskAdd.visible := true;
			self.mnuCargoTaskComplete.visible := true;
			self.mnuCargoTaskRemove.visible := true;
		else
			self.myAssistant.buildMnuTasksAdd(self.mnuTasksAdd, self.mnuTasksAddSub, currentTI);
			self.myAssistant.buildMnuTasksComplete(self.mnuTasksComp, self.mnuTasksCompSub, currentTI);
			self.myAssistant.buildMnuTasksRemove(self.mnuTasksRemove, self.mnuTasksRemoveSub, currentTI);
		endif;
	
		self.mnuCargo.userObject := currentTI; //&lt;-- used by sub menus click events	
	else 
		hasCurrentTI := false;
		self.mnuCargoEnquiry.visible := false;	
		self.mnuCargoEdit.visible := false;
		self.mnuCargoEnquiry.userObject := null;	
		self.mnuCargoEdit.userObject := null;
		self.mnuCargo.userObject := null;
	endif;
		
	self.mnuSummarise.visible := false;	// default this menu level to invisible, makes sub-menu invisible.
	
	if self.allowSummaryDefn then
		self.mnuSummarise.visible := true;
		// the summarise selected is only enabled if something is actually selected.
		self.mnuSummariseSel.visible :=	self.myCurrentContextTbl &lt;&gt; null and not self.myCurrentContextTbl.allSelectedObjects.isEmpty;
	endif;
	
	self.mnuCargo.visible := 	self.mnuQtyChg.visible or
								self.mnuCargoEnquiry.visible or
								self.mnuCargoEdit.visible or
								self.mnuSetStops.visible or
								self.mnuTasksAdd.visible or
								self.mnuTasksComp.visible or
								self.mnuTasksRemove.visible;								
								
	self.mnuColOrganiser.userObject := obj;
	
	self.mnuDirectRelease.visible := false;	 // TFS 42872
	self.mnuUnassignDR.visible := false;	// TFS 42872
	// Direct Release button only visible on Load Jobs
	// Dischage wles are set for direct release by drag/drop
	if self.myCurrentWLE &lt;&gt; null and 							// TFS 42872
	   not self.myCurrentWLE.isReceipt and						// TFS 42872
	   self.myCurrentWLE.myTrackedItem &lt;&gt; null and				// TFS 42872
	   app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		currentTI := self.myCurrentWLE.myTrackedItem;			// TFS 42872
		
	    if currentTI.myPrimaryActualLocation &lt;&gt; null then		// TFS 42872
			// Only show the button if the cargo is currently on a wagon, or tuck
			// if it's in the yard, it can't be assigned to direct release
			if currentTI.myPrimaryActualLocation.isWagon or		// TFS 42872
			   currentTI.myPrimaryActualLocation.isVehicle or	// TFS 42872
			   currentTI.isTranshipOnInboundVoyage	then		// TFS 47085 jlgzm1 31/10/2019
				self.mnuDirectRelease.visible := true;			// TFS 42872
				self.mnuDirectRelease.enabled := true;			// TFS 42872
				self.mnuUnassignDR.visible := true;			// TFS 42872
				self.mnuUnassignDR.enabled := true;			// TFS 42872
			endif;
		endif;
	endif;
	
	if app.isAllowedToInspect then
		if currentWle &lt;&gt; null then
			mnuInspectObject.userObject := currentWle;
		endif;
		self.mnuInspectSep.visible := true;
		self.mnuInspectObject.visible := true;
	else
		self.mnuInspectSep.visible := false;
		self.mnuInspectObject.visible := false;
	endif;
	
	self.popupMenu(self.mnuVoyageContext, xLeft.Integer, yTop.Integer);
	return false;
	
epilog

	delete iter;

end;</source>
        <Parameter name="cntrl" type="Table" usage="input"/>
        <Parameter name="conwin" type="Window" usage="input"/>
        <Parameter name="mouse" type="Boolean"/>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doBuildSubAreaCombo" id="ad65f60c-974d-4887-9b42-e1a3b41a1f73">
        <source>doBuildSubAreaCombo();
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 01/02/2017	cnwdap1		Initial creation TFS 3220 LNX Voyage Operations Enhancements
// 25/06/2020	jlgdap1		TFS 49453 ASPA Satellite View Screen for Flexible Terminal Areas
//
vars
	obj : CM_Object;
	termArea : CM_TerminalArea;
	lc : CM_LocationsController;
	col : CM_GridColumn;
	rc : CM_RoRoController;
	row : CM_GridRow;
	idx : Integer;

begin
	self.cmbSubArea.clear;
	obj := self.cmbDischLoad.listObject.CM_Object;
	if obj = null or not obj.isKindOf(CM_TerminalArea) then
		return;
	endif;
	
	termArea := obj.CM_TerminalArea;
	if not termArea.isGridArea then
		if not termArea.isIrregularBlockArea() and not termArea.type = TA_TYPE_RORO_LANE_AREA 
		and not termArea.isGeneralCargoAllocArea then				// TFS 49453
			return;
		endif;
	endif;
	
	if termArea.isIrregularBlockArea then
		foreach lc in termArea.CM_IrregularBlockArea.allLocationsControllers discreteLock do
			self.cmbSubArea.addItemObject(termArea.id &amp; " - " &amp; lc.ident, lc);
		endforeach;
	elseif termArea.type = TA_TYPE_FORK_LIFT_STACK then
		foreach col in termArea.CM_GridArea.allGridColumns discreteLock do
			self.cmbSubArea.addItemObject(termArea.id &amp; " - " &amp; col.label, col);
		endforeach;
	elseif termArea.type = TA_TYPE_RORO_LANE_AREA then
		foreach rc in termArea.CM_RoRoLaneArea.allLanesById discreteLock do	
			self.cmbSubArea.addItemObject(termArea.id &amp; " - " &amp; rc.ident, rc);
		endforeach;
	// TFS 49453 start
	elseif termArea.isGeneralCargoAllocArea then
		foreach lc in termArea.CM_GeneralCargoAllocRowArea.allRowControllersById do
			self.cmbSubArea.addItemObject(termArea.id &amp; " - " &amp; lc.ident, lc);
		endforeach;
	// TFS 49453 end
	else
		foreach row in termArea.CM_GridArea.allGridRows discreteLock do
			self.cmbSubArea.addItemObject(termArea.id &amp; " - " &amp; row.label, row);
		endforeach;
	endif;
	
	if self.cmbSubArea.listCount = 1 then
		self.cmbSubArea.listIndex := 1;
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doClonedMenuClickSpecial" id="442d2850-95af-43ca-a9e2-4e4eae70c298">
        <updating/>
        <source>doClonedMenuClickSpecial(menuItem: MenuItem input) updating, protected;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 25/01/2017	cnwdap1		Initial creation TFS 3219 LNX Voyage Operatinos Enhancements
//
vars
	obj	: Object;
	ti : CM_TrackedItem;
	realTiSet : CM_TISet;
	taskFormName : String;
	taskFormNameLength : Integer;
	passedAction : Integer;
	selectedCargo : CM_TIArray;

begin
	taskFormName := CMUI_TasksForm.name;
	taskFormNameLength := taskFormName.length;
	if menuItem.helpKeyword.length &gt; taskFormNameLength and menuItem.helpKeyword[1:taskFormNameLength] = taskFormName then
		passedAction := menuItem.helpKeyword[taskFormNameLength + 2:1].Integer;
		create realTiSet transient;
		self.getCurrentlySelectedTIs(realTiSet);
		ti  := self.myCurrentTrackedItem;
		if ti = null and realTiSet.isEmpty then
			return;
		endif;
		self.myAssistant.showTasksForm (ti, realTiSet, true, passedAction );
		return;
	endif;

	inheritMethod(menuItem);

epilog
	delete realTiSet;
	delete selectedCargo;
end;</source>
        <access>protected</access>
        <Parameter name="menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doColourTableRow" id="83a6f2e8-3eb7-4503-adf8-b6b1968be032">
        <source>doColourTableRow(_ti : CM_TrackedItem; _wle : CM_WorkListEntry; _table : CM_DataTable input; _job : CM_VoyageHoldJob; _row : Integer) protected;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 08/03/2017	cnwdap1		Initial creation TFS 3516 LNX Hold Planning Quantity
// 18/07/2019	jlgzm1		TFS 42872 Direct Release Between HOLD Voyages and Rail - All Cargo Types
//
vars
	tmpWle : CM_WorkListEntry;
	complete, started, jobFound : Boolean;
	foreColour, backColour : Integer;
	rtCol : Integer; // TFS 42872

begin
	if _row= 0 then // TFS 3646
		return;
	endif;
	complete := true;
	started := false;
	
	if _ti &lt;&gt; null and _wle = null then		// TFS 42872
		if _ti.allWorklistEntries.isEmpty then
			complete := false;
		endif;
		foreach tmpWle in _ti.allWorklistEntries where tmpWle.job = _job do
			jobFound := true;
			if tmpWle.status = WLE_COMPLETED then
				started := true;
			else
				complete := false;
			endif;
		endforeach;
		if not jobFound then
			complete := false;
		endif;
	elseif _wle &lt;&gt; null then				// TFS 42872
		if _wle.status = WLE_COMPLETED then	// TFS 42872
			started := true;				// TFS 42872
		else								// TFS 42872
			complete := false;				// TFS 42872
		endif;								// TFS 42872
	endif;
	
	rtCol := _table.CM_DataTable.getColumnByRowName(ETRow_RadioTelemetry); // TFS 42872
	self.displayWLEsShowRT(_table, _row, rtCol); // TFS 42872
	
	if not started and not complete then
		return;
	endif;
	
	foreColour := _table.foreColor;
	backColour := _table.backColor;
	if started then
		if complete then
			foreColour := White;
			if _job.isDischarge then
				backColour := _job.Colour_ReceiptComplete;
			else
				backColour := _job.Colour_ReleaseComplete;
			endif;
		else
			if _job.isDischarge then
				backColour := _job.Colour_ReceiptPartComplete;
			else
				backColour := _job.Colour_ReleasePartComplete;
			endif;
		endif;
	elseif complete then
		foreColour := White;
		if _job.isDischarge then
			backColour := _job.Colour_ReceiptComplete;
		else
			backColour := _job.Colour_ReleaseComplete;
		endif;
	endif;
	_table.accessRow(_row).foreColor := foreColour;
	_table.accessRow(_row).backColor := backColour;

end;</source>
        <access>protected</access>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_wle" type="CM_WorkListEntry"/>
        <Parameter name="_table" type="CM_DataTable" usage="input"/>
        <Parameter name="_job" type="CM_VoyageHoldJob"/>
        <Parameter name="_row" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="doDRAssignToJob" id="d11b7c8c-dec9-4426-9ca6-60f7887dd447">
        <updating/>
        <source>doDRAssignToJob(_moveController : CMIF_MoveController input; _job : CM_VoyageHoldJob) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
15 July 2019	jlgzm1	Initial creation TFS 42872 JMT - Direct Release Between HOLD Voyages and Rail - All Cargo Types

*/

vars
	yWLE : CM_YardWLE;
	theTI : CM_TrackedItem;
	result : Integer;
begin
	if _moveController = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'app.myMoveController = null');
		return;
	endif;
	
	if _job = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'job = null');
		return;
	endif;
	
	theTI := _moveController.myTrackedItem;
	if theTI = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'app.myMoveController.myTrackedItem = null');
		return;
	endif;
	
	// direct release WLE drgged from road or rail to load to voyage
	if not _job.isDischarge then
		if _moveController.myWorkListEntry &lt;&gt; null then
			// we must be a direct release move then
			_moveController.isDirectReleaseMove := true;
			
			if _moveController.myWorkListEntry.isKindOf(CM_YardWLE) then
				// if TI is splittable, then need to determine how much to move
				if theTI.canMergeBreakBulk and
				   _moveController.moveMode = PLANNING_MODE then
					if not self.myAssistant.showMoveAmountForm(_moveController) then
						return;
					endif;
				endif;
			endif;
		endif;
		
		
		while true do
			//app.myTrxUA.trxMoveTIAssignToHoldJob(_moveController, _job.CM_VoyageHoldJob, app.myPassport);
			if app.myPassport.trxCompletedOK then
				// Clear errors/warnings from form and err/warnings window
				self.clearErrorWarnings();
				break;
			else
				result := app.showErrorWarningDialog(app.getErrorString(Move_it), app.myPassport, ErrWarnMode_Update + ErrWarnMode_CanAckWarnings);
				if app.myPassport.noErrors and result = IDOK then
					// there must have just been warnings that the user has acknoledged so ..
					app.myPassport.warningsAcknowledged	:= true;
					_moveController.allOtherWLEs.clear(); // PAR 21148 if get warning from TRX then extra WLEs from a multi break bulk move are left as invalid objects.
					continue;
				endif;
				self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
			endif;
			break;
		endwhile;
	endif;

epilog
	
end;</source>
        <Parameter name="_moveController" type="CMIF_MoveController" usage="input"/>
        <Parameter name="_job" type="CM_VoyageHoldJob"/>
    </JadeMethod>
    <JadeMethod name="doDeleteJob" id="764593a7-1136-459d-82b1-bb601d41385b">
        <updating/>
        <source>doDeleteJob() updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 20/01/2017	cnwdap1		Initial creation TFS 3219 LNX Voyage Operations Enhancements
// 22/10/2024	navcs2		MTN-28961 EUP | Transaction Instrumentation - Voyage Planning
// 14 Jan 2026 	navhl20 	Bug MTN-35897: PEN - System Locking Errors (1000010 - Unknown message)
vars
	job 	: CM_VoyageJob;
	jobId 	: String;
	sheet 	: CMUI_Sheet;
	result 	: Integer;
begin
	sheet := self.fldData.topSheet.CMUI_Sheet;
	job := sheet.userObject.CM_VoyageJob;
	if job = null then
		app.msgBox(app.getErrorString(Job_must_entered_selected),app.getErrorString(Job) &amp; " " &amp; app.getErrorString(Error),MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
		return;
	endif;

	jobId := job.jobNum;
	
	if app.msgBox(app.getErrorString1(Lit_Confirm_Delete, app.getErrorString(Job) &amp; Space &amp; jobId), app.getErrorString1(Confirm_delete_something, app.getErrorString(Job)), MsgBox_Yes_No + MsgBox_Question_Mark_Icon) = MsgBox_Return_No then
		return;
	endif;
	
	while true do
		app.myTrxDA.trxDeleteVoyageJob(job, app.myPassport);
		if app.myPassport.trxCompletedOK then
			global.beep;
			break;
		else
			result := app.showErrorWarningDialog(app.getErrorString(Voyage_job), app.myPassport, ErrWarnMode_Add + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   result = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;

		endif;
		return;
	endwhile;

epilog
	if app.myPassport.trxCompletedOK then
		self.doRefresh();
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="doEditCargo" id="e0fe53ca-32b6-4c0a-a376-b41c624e32e3">
        <source>doEditCargo(_ti : CM_TrackedItem; _editCurrentObject : Boolean);
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 25/01/2017	cnwdap1		Initial creation TFS 3219 LNX Voyage Operations Enhancements
//
vars
	objArr : ObjectArray;
	tiSet : CM_TISet;
	ti : CM_TrackedItem;
begin
	create objArr transient;
	create tiSet transient;
	self.getCurrentlySelectedTIs(tiSet);
	tiSet.copy(objArr);
	if (not tiSet.includes(_ti)) then
		tiSet.add(_ti);
	endif;
	
	self.myAssistant.showCargoEnquiryForTIs(tiSet.first, objArr, self.myMasterMenuAction, _editCurrentObject);
epilog
	delete objArr;
	delete tiSet;
end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_editCurrentObject" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doMnuColourLegend" id="51efb25e-f30b-4b4f-aa77-106664dbaa7e">
        <source>doMnuColourLegend( _table : CM_DataTable);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 November 2017	jlgndl1	Initial creation	TFS 7801

*/

vars
	colLegend : CMUI_ColourLegend;
begin

	create colLegend;
	self.setNavigatorHeading(colLegend.caption); 
	colLegend.centreWindow;
	colLegend.addLegendItem(app.getErrorString(Unactioned), _table.foreColor, _table.backColor, null, false);
	colLegend.addLegendItem(app.getErrorString(Partially_worked_receipt), CM_Job.Colour_ReceiptPartComplete, White, null, false);
	colLegend.addLegendItem(app.getErrorString(Partially_worked_release), CM_Job.Colour_ReleasePartComplete, White, null, false);
	colLegend.addLegendItem(app.getErrorString(Completed_receipt), White, CM_Job.Colour_ReceiptComplete, null, false);
	colLegend.addLegendItem(app.getErrorString(Completed_release), White, CM_Job.Colour_ReleaseComplete, null, false);
	
	colLegend.showModal;


epilog

end;</source>
        <Parameter name="_table" type="CM_DataTable"/>
    </JadeMethod>
    <JadeMethod name="doMnuSetStopsClick" id="f319f53d-a0bb-4817-bc58-96f27bf3c1ca">
        <updating/>
        <source>doMnuSetStopsClick(_menuItem: MenuItem input) updating, protected;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 25/01/2017	cnwdap1		Initial creation TFS 3219 LNX Voyage Operations Enhancements
//
vars
	ti : CM_TrackedItem;
begin
	ti := _menuItem.userObject.CM_TrackedItem; 
	self.myAssistant.showStopsForm_TI(ti, null, app.getMyUser.canUpdateStops(self.myTerminal));
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doMnuSummariseAll" id="1eae3f56-5195-4f19-af5e-2e8a613d9154">
        <source>doMnuSummariseAll();
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 25/01/2017	cnwdap1		Initial creation TFS 3219 LNX Voyage Operations Enhancements
// 20/08/2018	jlgdap1		TFS 39964 PEL1 Hold Job Ops Loading Changes
// 23/10/2019	jlgzm1		TFS 47085 Direct Release Ship to Ship
//
vars
	coll : ObjectSet;
	idx : Integer;
	ctrl : Control;
	wleSet : CM_WLESet;
	wle : CM_WorkListEntry;
	
begin
	app.mousePointer := Busy;
	create coll transient;
	create wleSet transient;

	// Get a collection of ALL the objects to pass to the Summary Definition form.
	self.tblOnShip.getAllRowObjects(coll);
	self.tblOnSite.getAllRowObjects(coll);
	self.tblPreNote.getAllRowObjects(coll);						// TFS 39964
	self.tblTranship.getAllRowObjects(coll);					// TFS 47085
	
	// tblAllocatedGang contains WLEs not TIs, so need to get the TI out of it first before adding to collection
	foreach idx in 1 to self.allocatedTableCount do
		ctrl := self.tblAllocatedGang.getControl(idx);
		if ctrl &lt;&gt; null and ctrl.isKindOf(CM_DataTable) then
			wleSet.clear();											// TFS 47085
			ctrl.CM_DataTable.getAllRowObjects(wleSet);				// TFS 47085
			foreach wle in wleSet do								// TFS 47085
				if wle.CM_WorkListEntry.myTrackedItem &lt;&gt; null then	// TFS 47085
					// If a splitable TI is partially planned or planned to multiple jobs, then could end up with duplicates
					coll.addNoDuplicates(wle.CM_WorkListEntry.myTrackedItem, false);	// TFS 47085
				endif;
			endforeach;
		endif;
	endforeach;
	self.myAssistant.showXTABSummaryDefinitionForm(coll, false, false, false, true);
	
epilog
	delete coll;
	delete wleSet;
	app.mousePointer := Idle;
end;</source>
    </JadeMethod>
    <JadeMethod name="doMnuSummariseSel" id="16a3d48a-d0a8-4be5-ab56-6211fea4eaed">
        <source>doMnuSummariseSel();
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 25/01/2017	cnwdap1		Initial creation TFS 3219 LNX Voyage Operations Enhancements
// 23/10/2019	jlgzm1		TFS 47085 Direct Release Ship to Ship
//
vars
	coll : ObjectSet;
	obj : Object;		// TFS 47085
	
begin
	app.mousePointer := Busy;
	create coll transient;
	
	// Get a collection of all the objects SELECTED to pass to the Summary Definition form.
	if self.myCurrentContextTbl &lt;&gt; null then
		self.myCurrentContextTbl.allSelectedObjects.copy(coll);
	endif;
	
	// tblAllocatedGang contains WLEs not TIs, WLEs can't currently be summerised
	// so will want to remove them, and replace with their TI
	foreach obj in coll do															// TFS 47085
		if obj.isKindOf(CM_WorkListEntry) then										// TFS 47085
			coll.remove(obj);														// TFS 47085
			if obj.CM_WorkListEntry.myTrackedItem &lt;&gt; null then						// TFS 47085
				coll.addNoDuplicates(obj.CM_WorkListEntry.myTrackedItem, false);	// TFS 47085
			endif;
		endif;
	endforeach;
	
	self.myAssistant.showXTABSummaryDefinitionForm(coll, false, false, false, true);
	
epilog
	delete coll;
	app.mousePointer := Idle;
end;</source>
    </JadeMethod>
    <JadeMethod name="doMnuTasksAddClick" id="35cf5c96-94ab-4050-81bc-14cd4b286aa3">
        <updating/>
        <source>doMnuTasksAddClick(menuItem: MenuItem input) updating, protected;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 25/01/2017	cnwdap1		Initial creation TFS 3219 LNX Voyage Operatinos Enhancements
//
vars
	tmpTI : CM_TrackedItem;
	taskDesc : CM_ToDoTaskDesc;
	tiSet : CM_TISet;
	result : Integer;
	
begin
	if menuItem = null then
		return;
	else
		taskDesc := menuItem.userObject.CM_ToDoTaskDesc;
	endif;

	tmpTI := self.mnuCargo.userObject.CM_TrackedItem;
	if tmpTI = null then
		return;
	endif;
	
	create tiSet transient;
	self.getCurrentlySelectedTIs(tiSet);
	
	if (not tiSet.includes(tmpTI)) then
		tiSet.add(tmpTI);
	endif;
	
	while true do
		app.myTrxUA.trxUpdateTIToDoTaskAddBulk(taskDesc, tiSet, app.myPassport);
		if app.myPassport.trxCompletedOK then
			break;
		else
			result := app.showErrorWarningDialog(app.getErrorString(Todo_task_ADDd), app.myPassport, ErrWarnMode_Add + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   result = IDOK then
				// there must have just been warnings that the user has acknowledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			
		endif;
		
		break;
	endwhile;

epilog
	delete tiSet;
end;</source>
        <access>protected</access>
        <Parameter name="menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doMnuTasksCompleteClick" id="e625bd9f-266b-40aa-a07f-5b668dc077cb">
        <updating/>
        <source>doMnuTasksCompleteClick(menuItem: MenuItem input) updating, protected;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 25/01/2017	cnwdap1		Initial creation TFS 3219 LNX Voyage Operations Enhancements
//
vars
	tmpTI : CM_TrackedItem;
	taskDesc : CM_ToDoTaskDesc;
	realTiSet : CM_TISet;
	result : Integer;
	ti : CM_TrackedItem;
	tiTask : CM_ToDoTask;
	pxyTiSet : CM_TISet;
	resourceUsageProxys : CM_ResourceTypeUsageSet;
	
begin
	if menuItem = null then
		return;
	endif;
	
	if menuItem.userObject = null then
		return;
	endif;
	
	taskDesc := menuItem.userObject.CM_ToDoTaskDesc;
	
	tmpTI := self.mnuCargo.userObject.CM_TrackedItem;
	if tmpTI = null then
		return;
	endif;
	
	create realTiSet transient;
	self.getCurrentlySelectedTIs(realTiSet);
	
	if (not realTiSet.includes(tmpTI)) then
		realTiSet.add(tmpTI);
	endif;
	
	create pxyTiSet transient;
	if not self.myAssistant.doTaskProxySetForComplete( taskDesc.code, pxyTiSet, tmpTI, realTiSet, resourceUsageProxys) = IDOK then
		return;
	endif;
				
	while true do
		app.myTrxUA.trxUpdateTIToDoTaskCmpltBulk(taskDesc, pxyTiSet, resourceUsageProxys, app.myPassport);
		if app.myPassport.trxCompletedOK then
			break;
		else
			result := app.showErrorWarningDialog(app.getErrorString(Complete_todo_task), app.myPassport, ErrWarnMode_Add + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   result = IDOK then
				// there must have just been warnings that the user has acknowledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		break;
	endwhile;

epilog
	if pxyTiSet &lt;&gt; null and not pxyTiSet.isEmpty then
		pxyTiSet.purge;
	endif;
	delete pxyTiSet;
	delete realTiSet;
end;</source>
        <access>protected</access>
        <Parameter name="menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doMnuTasksRemoveClick" id="a16ad590-7da0-4d2a-bb7b-bcbc8304f949">
        <updating/>
        <source>doMnuTasksRemoveClick(menuItem: MenuItem input) updating, protected;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 25/01/2017	cnwdap1		Initial creation TFS 3219 LNX Voyage Operations Enhancements
//
vars
	tmpTI : CM_TrackedItem;
	taskDesc : CM_ToDoTaskDesc;
	tiSet : CM_TISet;
	result : Integer;
	
begin
	if menuItem = null then
		return;
	endif;
	if menuItem.userObject = null then
		return;
	endif;

	taskDesc := menuItem.userObject.CM_ToDoTaskDesc;
	tmpTI := self.mnuCargo.userObject.CM_TrackedItem;
	if tmpTI = null then
		return;
	endif;
	
	create tiSet transient;
	self.getCurrentlySelectedTIs(tiSet);
	
	if (not tiSet.includes(tmpTI)) then
		tiSet.add(tmpTI);
	endif;
	
	while true do
		app.myTrxUA.trxUpdateTIToDoTaskRemBulk(taskDesc, tiSet, app.myPassport);
		if app.myPassport.trxCompletedOK then
			break;
		else
			result := app.showErrorWarningDialog(app.getErrorString(Remove_todo_task), app.myPassport, ErrWarnMode_Add + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   result = IDOK then
				// there must have just been warnings that the user has acknowledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		break;
	endwhile;

epilog
	delete tiSet;
end;</source>
        <access>protected</access>
        <Parameter name="menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doNotableAdd" id="bbf4c9b9-9c5b-453a-8563-05a0e6e6fdf2">
        <source>doNotableAdd(_ti : CM_TrackedItem);
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 10 January 2017	cnwdap1		Initial creation PAR #
//
vars

begin
	if _ti = null then
		return;
	endif;
	
	if (not global.isValidObject(_ti)) then
		return;
	endif;
	
	if (not self.allDisplayedTIs.includes(_ti)) then
		self.allDisplayedTIs.add(_ti);
	endif;
epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="doNotableClear" id="9f807283-8522-4499-b831-3f8ddf97cabc">
        <updating/>
        <source>doNotableClear() updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On		By			Reason
// ----------		--------	-----------------------------------------------------
// 09 January 2017	cnwdap1		Initial creation PAR #
// 22 July	2019	jlgzm1		TFS 42872 Direct Release Between HOLD Voyages and Rail - All Cargo Types
//
vars

begin
	if self.listeningForClassNotes then
		self.listeningForClassNotes := false;
		self.endClassNotification( CM_TrackedItem, false, Any_System_Event );
	endif;
	self.allDisplayedTIs.clear;
	self.allDisplayedWLEs.clear;	// TFS 42872
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doRefresh" id="b38240a8-03f1-4902-97db-253230ba423f">
        <updating/>
        <source>doRefresh() updating, protected;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 09/01/2017	cnwdap1		Initial creation TFS 3219 LNX Voyage Operations Enhancements
// 28/09/2018 	JLGNS1		Bug 40500: STWO - Hold Planning(STWUJMT2)
// 23/10/2019	jlgzm1		TFS 47085 Direct Release Ship to Ship
// 22/10/2024	navcs2		MTN-28961 EUP | Transaction Instrumentation - Voyage Planning
// 14 Jan 2026 	navhl20 	Bug MTN-35897: PEN - System Locking Errors (1000010 - Unknown message)
vars
	voyage 	: CM_Voyage;
	idx 	: Integer;
begin
	app.mousePointer	:=	Busy;
	inheritMethod();
	
	self.clearDetails;
	voyage := self.myCurrentVoyage;
	
	self.myCurrentVoyage := null;

	self.doBuildComboVoyages();
	
	if voyage &lt;&gt; null and global.isValidObject(voyage) and self.cmbVoyage.findObject(voyage) &lt;&gt; null then
		self.setMyCurrentVoyage(voyage);
	else
		voyage := app.getMyCurrentVoyage();
		// Check if voyage is for this terminal
		if voyage &lt;&gt; null and voyage.myTerminal &lt;&gt; self.myTerminal then
			voyage := null;
		endif;
	endif;
	
	if self.myCurrentVoyage = null and voyage &lt;&gt; null and global.isValidObject(voyage) then
		self.setMyCurrentVoyage(voyage);
	endif;
	self.cmbVoyage.listIndex := self.cmbVoyage.findObject(self.myCurrentVoyage);
	
	self.loadCurrentVoyage();
	
	self.tblOnShip.allSelectedObjects.clear();		//Bug 40500
	self.tblOnSite.allSelectedObjects.clear();		//Bug 40500
	self.tblPreNote.allSelectedObjects.clear();		//Bug 40500
	self.tblTranship.allSelectedObjects.clear();	//TFS 47085
	
epilog
	app.mousePointer	:=	Idle;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doRemoveTIsFromJob" id="02eb16f5-4c9e-4836-9661-608deba6d321">
        <updating/>
        <source>doRemoveTIsFromJob(_table : CM_DataTable) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 20/01/2017	cnwdap1		Initial creation TFS 3219 LNX Voyage Operations Enhancements
// 22/07/2019	jlgzm1		TFS 42872 Direct Release Between HOLD Voyages and Rail - All Cargo Types
//
vars
	wlesToRemove : CM_WLESet; // TFS 42872
	tisToRemove : CM_TISet;
	wle : CM_WorkListEntry; // TFS 42872
	ti : CM_TrackedItem;
	sheet : CMUI_Sheet;
	job : CM_VoyageHoldJob;

begin
	sheet := self.fldData.topSheet.CMUI_Sheet;
	job := sheet.userObject.CM_VoyageHoldJob;
	if job = null then
		return;
	endif;
	create wlesToRemove transient;					// TFS 42872
	_table.allSelectedObjects.copy(wlesToRemove);	// TFS 42872
	create tisToRemove transient;
	//_table.allSelectedObjects.copy(tisToRemove);	// TFS 42872
	foreach wle in wlesToRemove do								// TFS 42872
		tisToRemove.addNoDuplicates(wle.myTrackedItem, false);	// TFS 42872
	endforeach;
	
	if not job.validateRemoveTIsFromJob(tisToRemove) then
		return;
	endif;
	
	foreach ti in tisToRemove do
		self.handleDeletedTI(ti, false);
	endforeach;

epilog
	delete wlesToRemove; // TFS 42872
	delete tisToRemove;
end;
</source>
        <Parameter name="_table" type="CM_DataTable"/>
    </JadeMethod>
    <JadeMethod name="doResize" id="ea43c970-5574-43c5-b49a-8e1bd00a799a">
        <updating/>
        <source>doResize() updating;
// TFS 3549 handle closing and reopening with caption set
vars

begin
	self.frmTop.top := self.frmToolbar.height + 1;
	self.fldData.top := self.frmTop.top + self.frmTop.height + 2;

	inheritMethod();
end;
</source>
    </JadeMethod>
    <JadeMethod name="doSOBSwitchDischargeLoad" id="efaa0411-ae62-41a6-b97e-0347c783f17b">
        <updating/>
        <source>doSOBSwitchDischargeLoad(_sob : Boolean) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 22/02/2017	cnwdap1		Initial creation TFS 3489 LNX DLR/SOB
//	23/10/2018 	JLGNS1	Bug 40500: STWO - Hold Planning(STWUJMT2)
//
vars

begin
	if _sob then
		// SOB check box is ticked - change discharge combo to have ship locations and disappear the sub-area combo
		self.lblSubArea.visible := false;
		self.cmbSubArea.visible := false;
		self.cmbDischLoad.width := 200;	//Bug 40500
		self.loadLocationsCombo(false);
	else
		// SOB Check box is unticked - refill the discharge combo with yard locations and re-appear the sub-area combo
		self.lblSubArea.visible := true;
		self.cmbSubArea.visible := true;
		self.cmbDischLoad.width := 150;	//Bug 40500
		self.loadLocationsCombo(true);
	endif;
epilog

end;</source>
        <Parameter name="_sob" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doSelectShift" id="8dd1eaeb-2d31-4692-9fb6-cccf38b80f20">
        <source>doSelectShift(_shift : CM_Shift);
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 10/01/2017	cnwdap1		Initial creation TFS 3219 LNX Voyage Operations Enhancements
//
vars
	shift : String;

begin
	if _shift = null then
		return;
	endif;
	
	shift := _shift.getShiftDay &amp; Space &amp; _shift.code &amp; Space &amp; _shift.startDateTime.asStringJMT();
	if txtJobId.text = null then
		self.txtJobId.text := shift.trimCharacters(Space)[1:30];
	endif;
	self.txtShiftStartDate.text := _shift.startDateTime.date.asStringJMT;
	self.txtShiftStartTime.text := _shift.startDateTime.time.asStringJMT;
	self.txtShiftEndDate.text := _shift.endDateTime.date.asStringJMT;
	self.txtShiftEndTime.text := _shift.endDateTime.time.asStringJMT;
	
	if _shift.remarks &lt;&gt; null then
		self.txtShiftRemarks.text := _shift.remarks;
	endif;
epilog

end;</source>
        <Parameter name="_shift" type="CM_Shift"/>
    </JadeMethod>
    <JadeMethod name="doSelectWorkPoint" id="d236c350-2cb4-4f84-8c96-7e213b2b5b3b">
        <source>doSelectWorkPoint(_workPoint : CM_WorkPoint);
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 10/01/2017	cnwdap1		Initial creation TFS 3219 LNX Voyage Operations Enhancements
//
vars
	workPoint : CM_WorkPoint;
	holdJobSheet : CM_VoyageHoldJobSheet;
	jobSheet : CM_VoyageJobSheet;
	notok : Boolean;
begin
	if _workPoint = null then
		return;
	endif;
	
	// default job Id field to the next sequencwe number for the work point
	workPoint := _workPoint;
	// TFS 3631 jobSheet := self.myCurrentVoyage.allJobSheets[workPoint.code].CM_VoyageHoldJobSheet;

	// ### TFS 3631 - Work Points are used by RORO Deck job sheets as well.
	foreach jobSheet in self.myCurrentVoyage.allJobSheets discreteLock do
		if jobSheet.isVoyageHoldJobSheet and jobSheet.crane = workPoint.code then
			holdJobSheet := jobSheet.CM_VoyageHoldJobSheet;
		endif;
	
	endforeach;
	
	// TFS 3631
	if holdJobSheet = null then
		foreach jobSheet in self.myCurrentVoyage.allJobSheets discreteLock do
			if jobSheet.isVoyageROROJobSheet() and jobSheet.crane = workPoint.code then
				notok := true;
				break;
			endif;
		
		endforeach;
		if notok then
			app.msgBox(app.getErrorString1(Alloc_deck_sheet_this_voyag_ca,  workPoint.code),app.getErrorString(Job_Sheet),MsgBox_OK_Only);
			self.cmbWorkPoint.listIndex := -1;
			return;
		endif;
	
	endif;

	self.txtJobId.text := self.myCurrentVoyage.getNextJobNumber(holdJobSheet, workPoint.CM_WorkPoint.IF_VoyageWorkPoint);
epilog

end;</source>
        <Parameter name="_workPoint" type="CM_WorkPoint"/>
    </JadeMethod>
    <JadeMethod name="doTblDblClick" id="08f015c2-114c-4313-b0d9-64020b278857">
        <updating/>
        <source>doTblDblClick(_tbl : CM_DataTable io) updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 Apr 2024	navnk30	Bug 63744: GPHA-Unable to sort the columns in Hold Planning and Hold Job operations screens.

*/

vars

begin
	if _tbl.row = _tbl.fixedRows then
		_tbl.resortTableByColumn(_tbl.column);
	endif;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_tbl" type="CM_DataTable" usage="io"/>
    </JadeMethod>
    <JadeMethod name="doUnassignDirectRelease" id="a45f18c1-155b-42fd-92d5-72d9b1011781">
        <updating/>
        <source>doUnassignDirectRelease() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date					Who		Reason
06 September 2019		jlgzm1	Initial creation TFS 42872 Direct Release Between HOLD Voyages and Rail

*/
vars
	wle				: CM_WorkListEntry;
	result			: Integer;
	wleSet 			: CM_WLESet;
	wlesWithWarnings,
	wleArray		: CM_WLEArray;
	
begin
	create wleSet transient;
	create wleArray transient;
	create wlesWithWarnings transient;
	self.getCurrentlySelectedWLEs(wleSet);
	
	//only want to unplan wles already set as direct release
	foreach wle in wleSet do
		if wle.isDRLinkedByFM then
			wleArray.add(wle);
		endif;
	endforeach;
	
	while true do
		app.myTrxUA.trxUpdateWLEsUnplan(wleArray, wlesWithWarnings, NO_MODE, app.myPassport);
		if app.myPassport.trxCompletedOK then
			// Clear errors/warnings from form and err/warnings window
			self.clearErrorWarnings();
			break;
		else
			result := app.showErrorWarningDialog(self.caption, app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnSkipErr);
			if result = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				
				// only reprocess the wles that had warnings.
				wleArray.clear;
				wlesWithWarnings.copy(wleArray);
				wlesWithWarnings.clear;
				continue;
			endif;
			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
		endif;
		break;
	endwhile;

epilog
	delete wleSet;
	delete wleArray;
	delete wlesWithWarnings;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="dragWorkListEntry" id="8ad6e34c-7196-462d-9d0f-2d9a0c7e855d">
        <updating/>
        <source>dragWorkListEntry(_wle : CM_WorkListEntry; _control : Control input) updating;
/*

Purpose:			Handles the event of dragging a  WorkListEntry

Parameters:			

Return Value:		

Date				Who		Reason
17 July 2019		jlgzm1	Initial creation TS42872 Direct Release Between HOLD Voyages and Rail - All Cargo Types

*/

vars
	picture : Picture;
	wle : CM_WorkListEntry;
	obj : Object;
	tmpTi : CM_TrackedItem;
	moveController	: CMIF_MoveController;
	effectiveTimeStamp : TimeStamp;
begin
	delete app.myMoveController;
	
	if _wle &lt;&gt; null then
		if _wle.status &lt;&gt; WLE_UNACTIONED then
			app.raiseCMException2(VB_JOB_NOT_UNACTIONED, _wle.job.jobId, _wle.statusString, null, null);
			return;
		endif;
	endif;
	
	create moveController transient;
	
	app.myMoveController := moveController;	
	tmpTi := _wle.myTrackedItem;
	moveController.setMyTrackedItem(tmpTi);
	
	if _wle &lt;&gt; null then
		moveController.setMyWorkListEntry(_wle);
		_wle.setMoveControllerAllOtherTIs(moveController);
	endif;
	
	moveController.setMoveMode(PLANNING_MODE);
	moveController.isDirectReleaseMove := true;
	
	
	if tmpTi &lt;&gt; null and _wle.myFutureMove &lt;&gt; null then
		moveController.setMoveIndex(tmpTi.allPlannedFutureMoves.indexOf(_wle.myFutureMove));
		moveController.setMyOriginatingLocation(tmpTi.getPrimaryLocation(PLANNING_MODE));
	endif;
	
	foreach obj in _control.CM_DataTable.allSelectedObjects do
		if obj = _wle then
			continue;
		endif;
		if (not CM_WorkListEntry.hasInstance(obj)) then
			continue;
		endif;
		wle := obj.CM_WorkListEntry;
		if wle.status &lt;&gt; WLE_UNACTIONED then
			continue;
		endif;
		if self.moveModeForm = QUEUE_MODE and wle.queue &lt;&gt; null then
			// Already queued			
			continue;
		elseif self.moveModeForm = PLANNING_MODE and wle.myFutureMove &lt;&gt; null then
			// Already planned or queued
			continue;				
		endif;
		if wle.myTrackedItem &lt;&gt; null then
			moveController.allOtherWLEs.add(wle);
		endif;
	endforeach;	
	
	_control.dragMode := DragMode_Drag;
	
	create picture transient;
	picture.picture := self.picMvPlanCur.picture;
	if picture &lt;&gt; null then
		_control.dragCursor := picture.picture;
	endif;

epilog
	if picture &lt;&gt; null then
		delete picture;
	endif;
end;</source>
        <Parameter name="_wle" type="CM_WorkListEntry"/>
        <Parameter name="_control" type="Control" usage="input"/>
    </JadeMethod>
    <JadeMethod name="enableVoyageButtons" id="7b68073d-75ee-4cbe-b291-9fd6e55f4acb">
        <updating/>
        <source>enableVoyageButtons() updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 09/01/2017	cnwdap1		Initial creation TFS 3219 LNX Voyage Operations Enhancements
//
vars
	enableButtons : Boolean;
	
begin
	enableButtons := self.myCurrentVoyage &lt;&gt; null;
	
	self.btnVoyageDef.enabled := enableButtons;
	self.btnShipDelays.enabled := enableButtons;
	self.btnShipDelaysEnq.enabled := enableButtons;
	self.btnHoldSorting.enabled := enableButtons and self.myCurrentVoyage.myGeneralCargoVoyage &lt;&gt; null;
	self.btnEventAlloc.enabled := enableButtons;
	self.btnCraneShifts.enabled := enableButtons;
	self.btnCopyCargo.enabled := enableButtons;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="firstChange" id="9d6dee96-e169-464c-b77e-2fda16584028">
        <controlMethod name="Form::firstChange"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>firstChange(cntrl: Control input) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 18/01/2017	cnwdap1		Initial creation TFS 3219 LNX Voyage Operations Enhancements
// 22/10/2024	navcs2		MTN-28961 EUP | Transaction Instrumentation - Voyage Planning
// 14 Jan 2026 	navhl20 	Bug MTN-35897: PEN - System Locking Errors (1000010 - Unknown message)
vars
	
begin
	if app.myCurrentUserCan(self.myTerminal, PmShipShiftAllocationMaint) then
		self.btnSaveBase.enabled := true;
	endif;
	self.setFormChanged(true, null, null, null, null);
epilog
	
end;</source>
        <Parameter name="cntrl" type="Control" usage="input"/>
    </JadeMethod>
    <JadeMethod name="fldData_sheetChg" id="06127dd2-c3d9-4363-8db9-d5323d885f5c">
        <controlMethod name="Folder::sheetChg"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>fldData_sheetChg(folder: Folder input) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 19/01/2017	cnwdap1		Initial creation TFS 3219 LNX Voyage Operations Enhancements
// 06/12/2021	navdap1		TFS 52293 SAL Direct Loading - Marking Job as Direct Delivery
//
vars
	sheet : CMUI_Sheet;
	job : CM_VoyageHoldJob;

begin
	sheet := folder.topSheet.CMUI_Sheet;
	job := sheet.userObject.CM_VoyageHoldJob;
	// TFS 52293
	if (sheet.name = self.shtAllocatedGang.name or sheet = self.shtPreNote)
	and self.myTerminal.getConfig(DirectTruck2VesselMult).Boolean then
		self.chkDirectDelivery.visible := true;
	else
		self.chkDirectDelivery.visible := false;
	endif;
	// TFS 52293 end
	if self.mode = self.Mode_View then
		self.populateJobDetails(job);
		self.setButtonStates(job);
	elseif self.mode = self.Mode_Add then
		self.handleLoadDischarge();

	endif;
epilog

end;</source>
        <Parameter name="folder" type="Folder" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getCurrentlySelectedTIs" id="8b36b680-fa05-4ae6-abfd-bf850b48979e">
        <source>getCurrentlySelectedTIs(_tiSet : CM_TISet input) protected;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 25/01/2017	cnwdap1		Initial creation TFS 3219 LNX Voyage Operations Enhancements
// 20/08/2018	jlgdap1		TFS 39964 PEl1 Hold Job Ops Loading Changes
// 06/09/2019	jlgzm1		TFS 42872 Direct Release Between HOLD Voyages and Rail
// 23/10/2019	jlgzm1		TFS 47085 Direct Release Ship to Ship
//
vars
	objArray : ObjectArray;
	obj : Object;
	wleSet : CM_WLESet;		// TFS 42872
	wle : CM_WorkListEntry;	// TFS 42872
	invalidObj : Boolean;	// TFS 42872
begin
	_tiSet.clear();
	if self.fldData.topSheet = self.shtOnShip then
		objArray := self.tblOnShip.allSelectedObjects;
	elseif self.fldData.topSheet = self.shtOnSite then
		objArray := self.tblOnSite.allSelectedObjects;
	elseif self.fldData.topSheet = self.shtPreNote then				// TFS 39964
		objArray := self.tblPreNote.allSelectedObjects;				// TFS 39964
	elseif self.fldData.topSheet = self.shtTranship then			// TFS 47085
		objArray := self.tblTranship.allSelectedObjects;			// TFS 47085
	else
		on Exception do app.handleDeletedObject(exception, wle, invalidObj);	// TFS 42872
		create wleSet transient;				// TFS 42872
		self.getCurrentlySelectedWLEs(wleSet);	// TFS 42872
		foreach wle in wleSet do				// TFS 42872
			if wle.myTrackedItem &lt;&gt; null then	// TFS 42872
				_tiSet.addNoDuplicates(wle.myTrackedItem, false);	// TFS 42872
			endif;
		endforeach;
		return;		// TFS 42872
	endif;

	foreach obj in objArray do
		if (not CM_TrackedItem.hasInstance(obj)) then
			continue;
		endif;
		
		_tiSet.add(obj.CM_TrackedItem);
	endforeach;
epilog
	delete wleSet;
end;</source>
        <access>protected</access>
        <Parameter name="_tiSet" type="CM_TISet" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getCurrentlySelectedWLEs" id="ea0ee08d-4dc7-418d-960d-3275f8695068">
        <source>getCurrentlySelectedWLEs(_wleSet : CM_WLESet input);
/*

Purpose:			

Parameters:			

Return Value:		

Date					Who		Reason
06 September 2019		jlgzm1	Initial creation TFS 42872 Direct Release Between HOLD Voyages and Rail

*/

vars
	objArray : ObjectArray;
	obj : Object;
	
begin
	if self.fldData.topSheet &lt;&gt; self.shtOnShip
	and self.fldData.topSheet &lt;&gt; self.shtOnSite
	and self.fldData.topSheet &lt;&gt; self.shtPreNote then
	
		objArray := self.tblAllocatedGang.getControl(self.fldData.topSheet.tag.Integer+1).CM_DataTable.allSelectedObjects;
		foreach obj in objArray do
			if (not CM_WorkListEntry.hasInstance(obj)) then
				continue;
			endif;
			_wleSet.add(obj.CM_WorkListEntry);
		endforeach;
	endif;
	
epilog

end;</source>
        <Parameter name="_wleSet" type="CM_WLESet" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getLocationForJob" id="a91dcc1d-c64c-4cf0-aae0-1c228b0b65d0">
        <source>getLocationForJob() : CM_LocationsController;
/*
Purpose:			
Date		Who		Reason
13 Feb 2017	cnwab1	Initial creation
17 Feb 2017 cnwdap1	TFS 3469 Fix error messages
25 Jun 2020	jlgdap1	TFS 49453 ASPA Satellite View Screen for Flexible Terminal Areas
*/

vars
	listObject: CM_Object;
	ta :CM_TerminalArea; 
	targetLocn :CM_LocationsController;
	gridObject :CM_GridObject;
begin
	listObject := self.cmbDischLoad.listObject.CM_Object;
	if CM_TerminalArea.hasInstance(listObject) then
		ta := listObject.CM_TerminalArea; 
	elseif CM_LocationsController.hasInstance(listObject) then
		targetLocn := listObject.CM_LocationsController;
	elseif CM_Wagon.hasInstance(listObject) then
		targetLocn := self.cmbSubArea.listObject.CM_LocationsController;
	endif;
	
	if targetLocn = null then
		if self.fldData.topSheet = self.shtOnSite then
			//app.msgBox(app.getErrorString(Please_select_load_location), app.getErrorString(Select_discharge_area), MsgBox_Stop_Icon + MsgBox_OK_Only);			// TFS 3469
			app.msgBox(app.getErrorString(Please_select_load_location), app.getErrorString(Select_plan_load), MsgBox_Stop_Icon + MsgBox_OK_Only);					// TFS 3469
			return null;
		
		else
			if ta = null then
				app.msgBox(app.getErrorString(PleaseSelectLocation), app.getErrorString(Select_discharge_area), MsgBox_Stop_Icon + MsgBox_OK_Only);
				return null;
			else
				if ta.isGridArea() then
					gridObject := self.cmbSubArea.listObject.CM_GridObject;
					if gridObject = null then
						//app.msgBox(app.getErrorString(PleaseSelectLocation), app.getErrorString(Select_discharge_area_row), MsgBox_Stop_Icon + MsgBox_OK_Only);	// TFS 3469
						app.msgBox(app.getErrorString(PleaseSelectLocation), app.getErrorString(Select_discharge_subarea), MsgBox_Stop_Icon + MsgBox_OK_Only);		// TFS 3469
						return null;
					endif;
					targetLocn := gridObject.getNextAvailableLocation(REAL_MODE);
					if targetLocn = null then
						app.msgBox(app.getErrorString2(There_empty_locations,ta.id, gridObject.label), app.getErrorString(Select_discharge_area), MsgBox_Stop_Icon + MsgBox_OK_Only);	 //+ cnwmd1 Par 24382
						return null;
					endif;
				
				elseif ta.isIrregularBlockArea()  or ta.type=TA_TYPE_RORO_LANE_AREA 
				or ta.isGeneralCargoAllocArea then										// TFS 49453
					targetLocn := self.cmbSubArea.listObject.CM_LocationsController;
					if targetLocn = null then
						app.msgBox(app.getErrorString1(Please_select_locatio_within, ta.id), app.getErrorString(Select_discharge_area), MsgBox_Stop_Icon + MsgBox_OK_Only);
						return null;
					endif;
				else
					targetLocn := ta.getLocationsController();		
				endif;
			endif;
		endif;
	endif;
	
	return targetLocn;
epilog

end;</source>
        <ReturnType type="CM_LocationsController"/>
    </JadeMethod>
    <JadeMethod name="getQuantityForMove" id="6b6b5be9-2c99-4452-beab-f763fadfabe8">
        <source>getQuantityForMove(_ti : CM_TrackedItem; _result : String output; _qtyWgtVol : Integer output) : Boolean;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 01/03/2017	cnwdap1		Initial creation TFS 3516 LNX Hold Planning Quantity
//
vars
	form : CMUI_MoveAmountForm;
	controller : CMIF_MoveController;

begin
	if _ti = null then
		return true;
	endif;
	if not (_ti.myCargoType.isBreakBulkMulti or _ti.myCargoType.isBulkMulti) then
		return true;
	endif;
	
	create controller transient;
	app.myMoveController := controller;
	controller.setMyTrackedItem(_ti);
	create form transient;
	form.myTrackedItem := _ti;
	form.excludeWLEs := true;
	if self.fldData.topSheet = self.shtOnShip then
		form.isHoldPlanningDischarge := true;
	elseif self.fldData.topSheet = self.shtTranship then	// TFS 47085 jlgzm1 23/10/2019
		form.isHoldPlanningTranship := true;
	endif;
	if self.chkDLR.value or self.chkSOB.value or _ti.getTransitStatus.isOneOf(TI_TransitStatusDLR, TI_TransitStatusSOB) then
		form.isHoldPlanningDLRSOB := true;
	endif;
	if self.cmbDischLoad.listObject &lt;&gt; null then
		form.targetLocation := self.getLocationForJob.getFullId;
	else
		form.targetLocation := "Off Site";
	endif;
		
	if form.showModal &lt;&gt; IDOK then
		return false;
	endif;
	if form.byQuantity then
		_result := _ti.id &amp; Tab &amp; form.getQuantity.String;
		_qtyWgtVol := self.ByQuantity;
	else
		_result := _ti.id &amp; Tab &amp; form.getWeightMovedKgs.String;
		if _ti.myCargoType.isTrackByWeight then
			_qtyWgtVol := self.ByWeight;
		else
			_qtyWgtVol := self.ByVolume;
		endif;
	endif;
	
	return true;
epilog
	app.myMoveController := null;
	delete controller;
end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_result" type="String" usage="output"/>
        <Parameter name="_qtyWgtVol" type="Integer" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getVoyJobTransferType" id="cb6f1e7f-f840-40d5-a587-6f6b52183a8f">
        <source>getVoyJobTransferType():Integer;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 March 2018	jlgndl1	Initial creation	TFS 37444

*/

vars

	voyTfrType : CM_VoyageJobTransferType;

begin

	if self.cmbTransferType.listIndex &gt; 0 then
		voyTfrType := self.cmbTransferType.listObject.CM_VoyageJobTransferType;
	endif;
	
	if voyTfrType &lt;&gt; null then
		return voyTfrType.id;
	endif;

	return VESSEL_TYPE_RORO;

epilog

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getXMLSettingsForSave" id="a8d72e2b-1f70-4f14-ae6c-56032f2f2c0c">
        <updating/>
        <source>getXMLSettingsForSave(): String updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 17/01/2017	cnwdap1		Initial creation TFS 3219 LNX Voyage Operations Enhancements
// 20/08/2018	jlgdap1		TFS 39964 Hold Job Ops Loading Changes
// 23/10/219	jlgzm1		TFS 47085 Direct Release Ship to Ship
//
vars
	xmlStr	: String;
	idx : Integer;
	table : CM_DataTable;

begin
	xmlStr := inheritMethod();

	xmlStr := xmlStr &amp; self.tblOnShip.getXmlStrForColumns(true);
	xmlStr := xmlStr &amp; self.tblOnSite.getXmlStrForColumns(true);
	xmlStr := xmlStr &amp; self.tblPreNote.getXmlStrForColumns(true);			// TFS 39964
	xmlStr := xmlStr &amp; self.tblTranship.getXmlStrForColumns(true);			// TFS 47085
	
	xmlStr := xmlStr &amp; self.xmlDischargeTableStr.replace(CrLf,Lf);	//09 May 2018	NDL	TFS 38460
	xmlStr := xmlStr &amp; self.xmlLoadTableStr.replace(CrLf,Lf);		//09 May 2018	NDL	TFS 38460
	
	xmlStr := xmlStr &amp; self.tblAllocatedGang.getXmlStrForColumns(true);
/*	foreach idx in 1 to self.allocatedTableCount do
		if self.tblAllocatedGang.getControl(idx) &lt;&gt; null then
			table := self.tblAllocatedGang.getControl(idx).CM_DataTable;
			xmlStr := xmlStr &amp; 
						global.formatAsXMLPrefix(XMLTag_Job_Table &amp; table.parent.CMUI_Sheet.caption) &amp; 
						table.getXmlStrForColumns(true) &amp;
						global.formatAsXMLSuffix(XMLTag_Job_Table &amp; table.parent.CMUI_Sheet.caption);
		endif;
	endforeach; */
	
	xmlStr := xmlStr &amp; global.formatAsXML( self.chkCurrentVoys.name, self.chkCurrentVoys.value.String );	//22 Feb 2021	NDL	TFS 50834
	
	return xmlStr;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="handleDeletedTI" id="fa049fd6-0f43-4197-994d-14362c706ddc">
        <source>handleDeletedTI(_ti : CM_TrackedItem; _notify: Boolean);
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 18/01/2017	cnwdap1		Initial creation TFS 3219 LNX Voyage Operations Enhancements
// 20/08/2018	jlgdap1		TFS 39964 PEL1 Hold Job Ops Loading Changes
// 25/09/2018	jlgmp6		TFS41031 Handle 'remove from job' on a job properly
// 22/07/2019	jlgzm1		TFS 42872 Direct Release Between HOLD Voyages and Rail - All Cargo Types
// 02/10/2019	jlgzm1		TFS 46848 Error 4
// 23/10/2019	jlgmz1		TFS 47085 Direct Release Ship to Ship
//
vars
	idx : Integer;
	controlIdx : Integer;
	cntrl : Control;
	table : CM_DataTable;
	wle : CM_WorkListEntry;	// TFS 42872
	invalidObj : Boolean; 	// TFS 46848

begin
	// a deleted object could have come from the onship table, or a prenote in the on site table, or any of the 
	// cloned allocation tables
	idx := 1;
	if _notify and self.tblOnShip.findObjectInRow(_ti, idx) then
		self.tblOnShip.removeItem(idx);
	elseif _notify and self.tblOnSite.findObjectInRow(_ti, idx) then
		self.tblOnSite.removeItem(idx);
	elseif _notify and self.tblPreNote.findObjectInRow(_ti, idx) then		// TFS 39964
		self.tblPreNote.removeItem(idx);									// TFS 39964
	elseif _notify and self.tblTranship.findObjectInRow(_ti, idx) then		// TFS 47085
		self.tblTranship.removeItem(idx);									// TFS 47085
		self.setTranshipVisibility();										// TFS 47085
	elseif not _notify then													// TFS 46848
		// if was notified, then TI will be invalid so can't iterate through its WLEs, so skip.
		
		on Exception do app.handleDeletedObject(exception, _ti, invalidObj); // TFS 46848
		_ti.edition; 				// TFS 46848
		if not invalidObj then		// TFS 46848
			foreach controlIdx in 1 to self.allocatedTableCount do
				cntrl := self.tblAllocatedGang.getControl(controlIdx);
				if cntrl &lt;&gt; null and cntrl.isKindOf(CM_DataTable) then
					table := cntrl.CM_DataTable;
					//tblAllocatedGang displays WLEs not TIs
					foreach wle in _ti.allWorklistEntries do		// TFS 42872
						if table.findObjectInRow(wle, idx) then		// TFS 42872
							table.removeItem(idx);					// TFS 42872
						endif;
					endforeach;
				endif;
			endforeach;
		endif;
	endif;
epilog
end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_notify" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="handleDeletedWLE" id="e73f7142-41f8-4027-b5d0-ff2b7c409bff">
        <source>handleDeletedWLE(_wle : CM_WorkListEntry);
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
18 July 2019		jlgzm1	Initial creation TFS 42872 Direct Release Between HOLD Voyages and Rail - All Cargo Types

*/

vars
	idx : Integer;
	controlIdx : Integer;
	cntrl : Control;
	table : CM_DataTable;
begin
	foreach controlIdx in 1 to self.allocatedTableCount do
		cntrl := self.tblAllocatedGang.getControl(controlIdx);
		if cntrl &lt;&gt; null and cntrl.isKindOf(CM_DataTable) then
			table := cntrl.CM_DataTable;
			if table.findObjectInRow(_wle, idx) then
				table.removeItem(idx);
			endif;
		endif;
	endforeach;
epilog

end;</source>
        <Parameter name="_wle" type="CM_WorkListEntry"/>
    </JadeMethod>
    <JadeMethod name="handleExceptionTI" id="576ec5b7-0c0e-4178-a3f5-7a02b9e2ea7e">
        <source>handleExceptionTI(exObj : Exception; _ti : CM_TrackedItem io) : Integer protected;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 10/01/2017	cnwdap1		Initial creation TFS 3219 LNX Voyage Operations Enhancements
//
constants
	ObjectNotFound	: Integer = 4;
	ObjectDeleted	: Integer = 1072;
vars

begin
	if exObj.errorCode = ObjectNotFound 
	or exObj.errorCode = ObjectDeleted then
		_ti := null;
		return Ex_Resume_Next;
	endif;

	return Ex_Pass_Back;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="exObj" type="Exception"/>
        <Parameter name="_ti" type="CM_TrackedItem" usage="io"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="handleLoadDischarge" id="ee995bab-7725-4f85-b192-5d342b2cdbe9">
        <updating/>
        <source>handleLoadDischarge() updating;
/*
Purpose:			
Date		Who		Reason
13/02/2017	cnwab1	Initial creation
17/02/2017	cnwdap1	TFS 3489 DLR / SOB
16/03/2017	cnwdap1	TFS 3516 LNX Hold Planning Quantity
 28/09/2018 	JLGNS1	Bug 40500: STWO - Hold Planning(STWUJMT2)
23/10/2019	jlgzm1	TFS 47085 Direct Release Ship to Ship
*/
vars
	sheet : CMUI_Sheet;
	
begin
	self.lblDischLoad.visible := true;
	
	sheet := self.fldData.topSheet.CMUI_Sheet;
	if sheet &lt;&gt; null and sheet = self.shtOnShip then
		self.lblDischLoad.caption := app.getErrorString(Plan_discharge);

		self.cmbDischLoad.visible := true;
		self.cmbSubArea.visible := true;
		self.lblSubArea.visible := true;
		self.loadLocationsCombo(true);
		self.cmbDischLoad.width := 150;									//Bug 40500
		self.chkDLR.visible := true;									// TFS 3489
		self.chkSOB.visible := true;									// TFS 3489
		self.chkDirectRelease.visible := false;							// TFS 47085
		self.btnTranship.enabled := true; // TFS 3561
		self.showDLRDischargeFields(self.tblOnShip, null);			// TFS 3516
	elseif sheet &lt;&gt; null and sheet = self.shtOnSite then
		self.lblDischLoad.caption := app.getErrorString(Plan_load);
		self.cmbDischLoad.visible := true;
		self.cmbSubArea.visible := false;
		self.lblSubArea.visible := false;
		self.loadLocationsCombo(false);
		self.cmbDischLoad.width := 200;									//Bug 40500
		self.chkDLR.visible := false;									// TFS 3489
		self.chkSOB.visible := false;									// TFS 3489
		self.chkDirectRelease.visible := false;							// TFS 47085
		self.showDLRDischargeFields(self.tblOnSite, null);			// TFS 3516
	else
		self.lblDischLoad.caption := app.getErrorString(Plan_load);
		self.cmbDischLoad.visible := true;
		self.cmbSubArea.visible := false;
		self.lblSubArea.visible := false;
		self.loadLocationsCombo(false);
		self.cmbDischLoad.width := 200;									//Bug 40500
		self.chkDLR.visible := false;									// TFS 3489
		self.chkSOB.visible := false;									// TFS 3489
		self.showDLRDischargeFields(self.tblOnSite, null);			// TFS 3516
		if sheet &lt;&gt; null and sheet = self.shtTranship and self.mode = self.Mode_Add then // TFS 47085			
			self.chkDirectRelease.visible := true;	// TFS 47085
		else
			self.chkDirectRelease.visible := false;	// TFS 47085
		endif;
	endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="hideColOrgSaveAsSysDefauilt" id="75277f49-aa40-4768-bb08-62e91885b29b">
        <source>hideColOrgSaveAsSysDefauilt(_table: Table): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 May 2018	jlgndl1	Initial creation	TFS 38460

*/

vars

begin
	
	if _table.index &lt;&gt; null then
		// this is a cloned table
		return true;
	else
		return inheritMethod(_table);
	endif;

epilog

end;</source>
        <Parameter name="_table" type="Table"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="initTable" id="3b5070b3-1287-4885-a246-22c0d1f4e4c5">
        <updating/>
        <source>initTable(_table : CM_DataTable input)updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 10/01/2017	cnwdap1		Initial creation TFS 3219 LNX Voyage Operations Enhancements
//
vars

begin
	if _table = null then
		return;
	endif;
	
	self.setTableHeadings(_table);
	
	_table.userInputEnabled := false;
	_table.multiSelect := CM_DataTable.MultiSelect_Simple;
	_table.selectMode := Table.SelectMode_Row;
	_table.selectionType := CM_DataTable.SelectionType_Row;
	self.setColorsForTable(_table);

epilog

end;</source>
        <Parameter name="_table" type="CM_DataTable" usage="input"/>
    </JadeMethod>
    <JadeMethod name="initailiseXMLstrs" id="4cfe54cc-3555-47f4-8668-c1a623198f5e">
        <updating/>
        <source>initailiseXMLstrs() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 May 2018	jlgndl1	Initial creation	TFS 38460

*/

vars

	userWindow : CM_UserWindow;
	startPos : Integer;

begin

	userWindow := app.getUserWindow(self.name, false);
	if userWindow &lt;&gt; null then
		startPos := 1;
		self.xmlDischargeTableStr := userWindow.xmlInfo.cnEcGetNextTagValueOfName( CM_DataTable.XMLTag_Table &amp; self.tblAllocatedGang.name &amp; "DISCHARGE", startPos);
		if self.xmlDischargeTableStr.trimBlanks &lt;&gt; null then
			 self.xmlDischargeTableStr := J_key_LessThan.Character &amp; CM_DataTable.XMLTag_Table &amp; self.tblAllocatedGang.name &amp; "DISCHARGE" &amp; J_key_GreaterThan.Character &amp; 
											self.xmlDischargeTableStr.trimBlanks &amp;
											J_key_LessThan.Character &amp; J_key_Slash.Character &amp; CM_DataTable.XMLTag_Table &amp; self.tblAllocatedGang.name &amp; "DISCHARGE" &amp; J_key_GreaterThan.Character;
		endif;
		
		startPos := 1;
		self.xmlLoadTableStr := userWindow.xmlInfo.cnEcGetNextTagValueOfName( CM_DataTable.XMLTag_Table &amp; self.tblAllocatedGang.name &amp; "LOAD", startPos);
		if self.xmlLoadTableStr.trimBlanks &lt;&gt; null then
			 self.xmlLoadTableStr := J_key_LessThan.Character &amp; CM_DataTable.XMLTag_Table &amp; self.tblAllocatedGang.name &amp; "LOAD" &amp; J_key_GreaterThan.Character &amp; 
											self.xmlLoadTableStr.trimBlanks &amp;
											J_key_LessThan.Character &amp; J_key_Slash.Character &amp; CM_DataTable.XMLTag_Table &amp; self.tblAllocatedGang.name &amp; "LOAD" &amp; J_key_GreaterThan.Character;
		endif;
	endif;
	
	if self.xmlDischargeTableStr.trimBlanks = null then
		self.xmlDischargeTableStr := self.tblOnShip.getXmlStrForColumns(true);
		self.xmlDischargeTableStr.cnReplaceString( self.tblOnShip.name, self.tblAllocatedGang.name &amp; "DISCHARGE");
	endif;
	
	if self.xmlLoadTableStr.trimBlanks = null then
		self.xmlLoadTableStr := self.tblOnSite.getXmlStrForColumns(true);
		self.xmlLoadTableStr.cnReplaceString( self.tblOnSite.name, self.tblAllocatedGang.name &amp; "LOAD");
	endif;
	
	if userWindow &lt;&gt; null then	//16 Mar 2021	NDL	TFS 50836
		self.chkCurrentVoys.value := userWindow.xmlInfo.cnEcGetTagValueOfName(self.chkCurrentVoys.name).Boolean;	//22 Feb 2021	NDL	TFS 50834
	endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="isPrimaryActualSameAsShipBlock" id="ba3efdc6-1db7-4ef8-97df-7da7f76bfe29">
        <source>isPrimaryActualSameAsShipBlock(_ti : CM_TrackedItem; _shipBlockStack : CM_ShipBlockController) : Boolean;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 18/01/2017	cnwdap1		Initial creation TFS 3219 LNX Voyage Operations Enhancements
//
vars
	isSameAsShipBlockStack : Boolean;

begin
	isSameAsShipBlockStack := false;
	if _ti.myPrimaryActualLocation.isKindOf(CM_ShipBlockController) then
		if _ti.myPrimaryActualLocation = _shipBlockStack then
			isSameAsShipBlockStack := true;
		endif;
	elseif _ti.myPrimaryActualLocation.isKindOf(CM_GeneralCargoController) then
		isSameAsShipBlockStack := true;
	endif;

	return isSameAsShipBlockStack;

epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_shipBlockStack" type="CM_ShipBlockController"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="loadCargoForTable" id="9950d427-6ff9-4562-9ce7-0a7715cb2b3c">
        <source>loadCargoForTable(	_ti : CM_TrackedItem io; 
					_rowIdx : Integer io; 
					_table : CM_DataTable input;
					_allocatedWLEs : CM_WLEArray	);						// TFS 3516
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 10/01/2017	cnwdap1		Initial creation TFS 3219 LNX Voyage Operations Enhancements
// 20/02/2017	cnwdap1		TFS 3489 LNX DLR/SOB
// 01/03/2017	cnwdap1		TFS 3516 LNX Hold Planning Quantity
// 29/03/2017	cnwdap		TFS 3902 Hold Planning not finding all onsite cargo
// 18/04/2017	cnwdap1		TFS 4087 LNX Incorrect Quantity Showing in Hold Planning
// 01/08/2018	jlgdap1		TFS 39964 PEL1 Hold Job Ops Loading Changes
// 13/11/2018	jlgdap1		TFS 41300 PEL1 Unable to load to vessel from truck in Job Lander
// 19/08/2019 	JLGNS1		Bug 46156: LNX - Cargo not available to allocate to a Job (Hold Planning)
// 23/10/2019	jlgzm1		TFS 47085 Direct Release Ship to Ship
// 15/11/2021	navdap1		TFS 52360 SAL Direct Prenote to Voyage Incorrect Job Values
//
vars
	str : String;
	idx : Integer;								// TFS 3516
	amount : String;							// TFS 3516
	wle : CM_WorkListEntry;						// TFS 3516
	job : CM_VoyageHoldJob;			// TFS 4087
	sheet : CMUI_Sheet;				// TFS 4087
	directPrenote : Boolean;				// TFS 52360

begin
	if _ti = null then
		return;
	endif;	
	
	on Exception do self.handleExceptionTI(exception, _ti);
	_ti.fetchLatest();
	if _ti = null then
		return;
	endif;	
	
	if _ti.hasBeenMerged then	//12 Mar 2018	NDL	TFS 37444
		return;
	endif;
	//epr TFS 37995 6/4/18 pelindo create load jobs for notified cargo so have to show notified
	
	if _table = null then
		return;
	endif;
		
	if _ti.isChild then
		return;
	endif;
	
	if _table = self.tblOnShip then
		//if _ti.getJobShipReleaseId &lt;&gt; null or _ti.getJobShipReceiveId &lt;&gt; null then						// TFS 3489
		if _ti.getJobShipReleaseId &lt;&gt; null or _ti.getJobShipReceiveId &lt;&gt; null or _ti.isExport then			// TFS 3489
			if self.checkTIFullyAssigned(_ti, false) then				// TFS 3516
				return;
			endif;														// TFS 3516
		endif;
	elseif _table = self.tblOnSite then
		// TFS 3489 need to show any planned DLRs on site so the second lift can be added to a load job		// TFS 3489
		//if _ti.getJobShipReleaseId &lt;&gt; null or _ti.getJobShipReceiveId &lt;&gt; null or _ti.isImport then		// TFS 3489
		if _ti.getJobShipReleaseId &lt;&gt; null or (_ti.getJobShipReceiveId &lt;&gt; null and _ti.isImport) then		// TFS 3489
			if self.checkTIFullyAssigned(_ti, true) then				// TFS 3516
				return;
			endif;														// TFS 3516
		elseif _ti.isRehandle and self.checkTIFullyAssigned(_ti, true) then	// TFS 3516
			return;														// TFS 3516
		endif;
		if _ti.allWorklistEntries.size = 1 and _ti.allWorklistEntries.first.isCompleteForJob() and not _ti.isRehandle then	// TFS 3516
		//	if _ti.allWorklistEntries.first.isKindOf(CM_VoyageWLE) then					// TFS 3902
			if _ti.allWorklistEntries.first.isKindOf(CM_VoyageWLE) and _ti.allWorklistEntries.first.CM_VoyageWLE.getVoyage = self.myCurrentVoyage then	//24 Sep 2018	NDL	TFS 41018
				return;																										// TFS 3516
			endif;																		// TFS 3902
		endif;																												// TFS 3516
		// TFS 41300 if this item was prenoted, see if it's part of an already fully-allocated TI
		if _ti.canMergeBreakBulk and _ti.wasPrenotified then	//Bug 46156
			if _ti.isHoldJobFullyAllocated then					//Bug 46156
				return;											//Bug 46156
			endif;												//Bug 46156
		endif;													//Bug 46156
		
		// TFS 52360 Don't show fully-planned Direct to ship prenoted cargo
		directPrenote := self.myTerminal.getConfig(DirectTruck2VesselMult).Boolean;
		if directPrenote and not _ti.allPlannedFutureMoves.isEmpty then
			return;
		endif;
		// TFS 52360 end

	elseif _table = self.tblPreNote then								// TFS 39964
		if _ti.getJobShipReleaseId &lt;&gt; null then							// TFS 39964
			if self.checkTIFullyAssigned(_ti, true) then				// TFS 39964
				return;													// TFS 39964
			endif;														// TFS 39964
		endif;															// TFS 39964
	
	elseif _table = self.tblTranship then						// TFS 47085
		if _ti.getJobShipReleaseId &lt;&gt; null then					// TFS 47085
			if self.checkTIFullyAssigned(_ti, true) then		// TFS 47085	
				return;											// TFS 47085	
			endif;
		endif;
	endif;
	
	//if _table = self.tblOnShip or _table = self.tblOnSite then									// TFS 4087	// TFS 39964
	if _table = self.tblOnShip or _table = self.tblOnSite or _table = self.tblPreNote then			// TFS 4087	// TFS 39964
		str := _ti.getAttributeStringForDefArray(_table.allTblDataEntRows);
	else																							// TFS 4087
		sheet := _table.parent.CMUI_Sheet;															// TFS 4087
		job := sheet.userObject.CM_VoyageHoldJob;		
		//epr 29/3/18 TFS 37664 pelindo cargo creation will create jobs with cargo but not planned yet so we still need to display the job
		// TFS 4087
	/*	if not job.isTransient then 																// TFS 4087
			if (job.isDischarge and not job.isRehandle and not job.isSOB and _ti.isOnShip and _ti.myPrimaryPlannedLocation = null)	// TFS 4087
			or (not job.isDischarge and _ti.isOnSite and _ti.myPrimaryPlannedLocation = null) then	// TFS 4087
				return;																				// TFS 4087
			endif;																					// TFS 4087
		endif;	*/																					// TFS 4087
		str := _ti.getAttribStringForDefArrayJob(_table.allTblDataEntRows, job);					// TFS 4087
	endif;																							// TFS 4087
	_rowIdx := _table.addItem(str);
	_table.accessRow(_rowIdx).itemObject := _ti;	
	self.doNotableAdd(_ti);
	if _allocatedWLEs &lt;&gt; null then										// TFS 3516
		foreach wle in _allocatedWLEs do								// TFS 3516
			if wle.myTrackedItem = _ti then								// TFS 3516
				_table.accessCell(_rowIdx, 1).itemObject := wle;		// TFS 3516
				break;													// TFS 3516
			endif;														// TFS 3516
		endforeach;														// TFS 3516
	endif;																// TFS 3516
epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem" usage="io"/>
        <Parameter name="_rowIdx" type="Integer" usage="io"/>
        <Parameter name="_table" type="CM_DataTable" usage="input"/>
        <Parameter name="_allocatedWLEs" type="CM_WLEArray"/>
    </JadeMethod>
    <JadeMethod name="loadCombos" id="ed856a7d-ff92-447b-bd79-a5ccbfc9f766">
        <source>loadCombos();
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 10/01/2017	cnwdap1		Initial creation TFS 3219 LNX Voyage Operations Enhancenments
//
vars
	startDT, endDT : TimeStamp;
	workPoint : CM_WorkPoint;
	idx : Integer;

begin
	// load work points 
	self.cmbWorkPoint.sorted := true;
	self.cmbWorkPoint.clear;
	foreach workPoint in self.myTerminal.allWorkPointsByCode where not workPoint.isNotAvailableForEntry do
		idx := self.cmbWorkPoint.addItem(workPoint.code &amp; " - " &amp; workPoint.description);
		self.cmbWorkPoint.itemObject[idx] := workPoint;
	endforeach;
	
	
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="loadCurrentVoyage" id="0b4757fc-5d2d-4de2-a5d6-b09b6eef72b5">
        <updating/>
        <source>loadCurrentVoyage() updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 09/01/2017	cnwdap1		Initial creation TFS 3219 LNX Voyage Operations Enhancements
// 01/03/2017	cnwdap1		TFS 3516 LNX Hold Planning Quantity
// 01/08/2018	jlgdap1		TFS 39964 PEL1 Hold Job Ops Loading Changes
//	3/11/2019	jlgns1		TFS 3827 XLAT_FormCaptions need to be sorted out
// 22/07/2019	jlgzm1		TFS 42872 Direct Release Between HOLD Voyages and Rail - All Cargo Types
// 23/10/219	jlgzm1		TFS 47085 Direct Release Ship to Ship
//
vars
	idx : Integer;
	sheet : CMUI_Sheet;
	table : CM_DataTable;
	job : CM_Job;
	vessel : CM_Vessel;
	str : String;
	js : CM_JobSheet;
begin
	self.doNotableClear();
	
	if self.myCurrentVoyage = null then
		self.tblOnShip.rows := self.tblOnShip.fixedRows;
		self.tblOnSite.rows := self.tblOnSite.fixedRows;
		self.tblPreNote.rows := self.tblPreNote.fixedRows;			// TFS 39964
		self.tblTranship.rows := self.tblTranship.fixedRows;		// TFS 47085
		self.tblAllocatedGang.rows := self.tblAllocatedGang.fixedRows;
		return;
	endif;
	
	if not self.listeningForClassNotes then
		self.listeningForClassNotes := true;
		self.beginClassNotification( CM_TrackedItem, false, Any_System_Event, Response_Continuous, 1);
		self.beginNotification(self.myCurrentVoyage, self.myTerminal.getTerminalEvent(WLE_Create_Event), Response_Continuous, null);	// TFS 42872
		self.beginNotification(self.myCurrentVoyage, self.myTerminal.getTerminalEvent(WLE_Update_Event), Response_Continuous, null);	// TFS 42872
		self.beginNotification(self.myCurrentVoyage, self.myTerminal.getTerminalEvent(WLE_Delete_Event), Response_Continuous, null);	// TFS 42872
	endif;
	
	vessel := self.myCurrentVoyage.getMyVessel();
	str := str &amp;  app.getFormCaptionsString(Xlat_0000046);

	
	str := str &amp; " " &amp; self.myCurrentVoyage.getId.trimBlanks;


	self.setCaption(str);
	self.setNavigatorHeading(str);
	self.loadOnShipTable();
	self.loadOnSiteTable();
	self.loadPreNoteTable();										// TFS 39964
	self.loadTranshipTable();										// TFS 47085
	
	// delete all cloned tables and sheets, and rebuild them
	foreach idx in 1 to self.allocatedTableCount do
		sheet := self.shtAllocatedGang.getControl(idx);
		if sheet &lt;&gt; null then
			delete sheet;
		endif;
	endforeach;
	self.allocatedTableCount := null;
	// now recreate the job tables
	
	/* TFS 3558 display in the OOW order
	foreach job in self.myCurrentVoyage.allVoyageJobs where job.isKindOf(CM_VoyageHoldJob) do
		if job.CM_VoyageHoldJob.hasBulkRelease() then // TFS 3190
			continue;
		endif;
		self.setClonedSheetAndTable(job.CM_VoyageHoldJob, sheet, table);
	endforeach;
	*/
	
	foreach js in self.myCurrentVoyage.allJobSheets where js.isKindOf(CM_VoyageHoldJobSheet) do
		foreach job in js.allJobsByOrder where job.isKindOf(CM_VoyageHoldJob) do
			if job.CM_VoyageHoldJob.hasBulkRelease() then // TFS 3190
				continue;
			endif;
			
		//self.setClonedSheetAndTable(job.CM_VoyageHoldJob, sheet, table);				// TFS 3516
		self.setClonedSheetAndTable(job.CM_VoyageHoldJob, sheet, table, null);			// TFS 3516
		endforeach;
	
	endforeach;
	
	// load combos if we don't have them loaded yet
	if  self.cmbWorkPoint.listCount = 0 then
		self.loadCombos;
	endif;
	// load shifts for the period the voyage is in harbour
	self.loadShifts();
	
	self.enableVoyageButtons();
	self.setButtonStates(null);
	
	self.handleLoadDischarge();
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="loadDataForFirstTime" id="efdf4045-9f52-4a11-ae20-497c584e7b8d">
        <updating/>
        <source>loadDataForFirstTime() updating, protected;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 09/01/2017	cnwdap1		Initial creation TFS 3219 LNX Voyage Operations Enhancements
//
vars
	
begin
	inheritMethod();
	self.doRefresh(); // Gets the voyages and sets the current voyage
	
	if self.cmbVoyage.findObject(self.myCurrentVoyage) &gt; 0 then
		self.cmbVoyage.listObject := self.myCurrentVoyage;
	endif;
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="loadLocationsCombo" id="fbdd7563-d577-4423-b26a-3ae220139c9e">
        <updating/>
        <source>loadLocationsCombo(_discharge : Boolean) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 02/02/2017	cnwdap1		Initial creation TFS 3220 LNX Voyage Operations Enhancements
//
vars
	area : CM_TerminalArea;
	dict : CM_GeneralCCtrByHatchPlaceDict;
	hatch : CM_LocationsController;

begin
	self.cmbDischLoad.clear();
	
	if _discharge then
		// load terminal areas
		foreach area in self.myTerminal.allTerminalAreas discreteLock do
			if area.isSwapStack or area.isGateArea then
				continue;
			endif;
			
			self.cmbDischLoad.addItemObject(area.id, area);
		endforeach;
		self.cmbSubArea.listIndex := -1;
	else
		if self.myCurrentVoyage &lt;&gt; null then
			// load ship block stack and holds
			if self.myCurrentVoyage.myShipBlockStack &lt;&gt; null then
				self.cmbDischLoad.addItemObject(self.myCurrentVoyage.myShipBlockStack.getFullId(), self.myCurrentVoyage.myShipBlockStack);
			endif;
			
			if self.myCurrentVoyage.myGeneralCargoVoyage &lt;&gt; null then
				dict := self.myCurrentVoyage.myGeneralCargoVoyage.allLocationsByHatchPlace;
			
				foreach hatch in dict discreteLock, reversed do
					self.cmbDischLoad.addItemObject(hatch.getFullId, hatch);		
				endforeach;
			endif;
		endif;
	endif;

epilog

end;</source>
        <Parameter name="_discharge" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="loadOnShipTable" id="44b27813-3e9a-481d-9e82-d7c77de61196">
        <source>loadOnShipTable();
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 09/01/2017	cnwdap1		Initial creation TFS 3219 LNX Voyage Operations Enhancements
// 01/03/2017	cnwdap1		TFS 3516 LNX Hold Planning Quantity
//
vars
	voyage : CM_Voyage;
	ti : CM_TrackedItem;
	rowIdx : Integer;

begin
	// unallocated cargo on ship is all cargo on ship that is not currently assigned to a job
	voyage := self.myCurrentVoyage;
	if voyage = null then
		return;
	endif;
	
	self.tblOnShip.rows := tblOnShip.fixedRows;
	foreach ti in voyage.allOnshipTIsByIdCargoType discreteLock do
		//self.loadCargoForTable(ti, rowIdx, self.tblOnShip);				// TFS 3516
		self.loadCargoForTable(ti, rowIdx, self.tblOnShip, null);			// TFS 3516
	endforeach;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="loadOnSiteTable" id="5483e048-54d2-493d-a545-f9c1da0aa26c">
        <source>loadOnSiteTable();
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 10/01/2017	cnwdap1		Initial creation TFS 3219 LNX Voyage Operations Enhancements
// 20/02/2017	cnwdap1		TFS 3489 LNX DLR/SOB
// 01/03/2017	cnwdap1		TFS 3516 LNX Hold Planning Quantity
// 01/08/2018	jlgdap1		TFS 39964 PEL1 Hold Job Ops Loading Changes
// 10/11/2021	navdap1		TFS 52360 SAL Direct Prenote to Voyage Invalid Job Values
//
vars
	voyage : CM_Voyage;
	ti : CM_TrackedItem;
	rowIdx : Integer;
	directPrenote : Boolean;		// TFS 52360

begin
	// unallocated cargo on site is all cargo on site for the current voyage that is not currently assigned to a job
	voyage := self.myCurrentVoyage;
	if voyage = null then
		return;
	endif;
	
	// on site cargo includes prenotes - TFS 39964 not any more, they're in their own table
	directPrenote := self.myTerminal.getConfig(DirectTruck2VesselMult).Boolean;		// TFS 52360
	self.tblOnSite.rows := tblOnSite.fixedRows;
	foreach ti in voyage.allOnsiteTIsByIdCargoType discreteLock do
		// TFS 52360 Ignore Direct Delivery TIs with jobs
		if directPrenote and not ti.allPlannedFutureMoves.isEmpty then
			continue;
		endif;
		// TFS 52360 end
		//self.loadCargoForTable(ti, rowIdx, self.tblOnSite);				// TFS 3516
		self.loadCargoForTable(ti, rowIdx, self.tblOnSite, null);			// TFS 3516
	endforeach;
	// TFS 39964 foreach ti in voyage.allNotifiedTIsByIdCargoType discreteLock do
	// TFS 39964 	if ti.getJobNumber(true) &lt;&gt; null or ti.isChild then
	// TFS 39964 		continue;
	// TFS 39964 	endif;
	// TFS 39964 	//self.loadCargoForTable(ti, rowIdx, self.tblOnSite);				// TFS 3516
	// TFS 39964 	self.loadCargoForTable(ti, rowIdx, self.tblOnSite, null);			// TFS 3516
	// TFS 39964 endforeach;
	// TFS 3489 On site also includes any DLR cargo with a planned future move to a terminal area
	foreach ti in voyage.allOnshipTIsByIdCargoType discreteLock do
		if ti.getTransitStatus &lt;&gt; TI_TransitStatusDLR then
			continue;
		endif;
		//self.loadCargoForTable(ti, rowIdx, self.tblOnSite);				// TFS 3516
		self.loadCargoForTable(ti, rowIdx, self.tblOnSite, null);			// TFS 3516
	endforeach;
	
	
	// TFS 47085 jlgzm1 23/10/2019
	// Tranship cargo is now displayed on tblTranship, so this has been moved to loadTranshipTable
	/*
	// TFS 3561
	foreach ti in voyage.allTranshipTIsExport discreteLock do
		if ti.getJobNumber(false) &lt;&gt; null or ti.isChild then
			continue;
		endif;
		if ti.isOnSite then // TFS 3561
			continue; // TFS 3561
		endif;
		
		//self.loadCargoForTable(ti, rowIdx, self.tblOnSite);				// TFS 3516
		self.loadCargoForTable(ti, rowIdx, self.tblOnSite, null);			// TFS 3516
	endforeach;
	*/
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="loadPreNoteTable" id="9cb482db-9883-4435-ab2f-cf325d83e99d">
        <source>loadPreNoteTable();
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 01/08/2018	jlgdap1		Initial creation TFS 39964 PEL1 Hold Job Ops Loading Changes
//
vars
	voyage : CM_Voyage;
	ti : CM_TrackedItem;
	rowIdx : Integer;

begin
	// unallocated pre note cargo is all pre-noted cargo for the current voyage that is not currently assigned to a job
	voyage := self.myCurrentVoyage;
	if voyage = null then
		return;
	endif;
	
	self.tblPreNote.rows := tblOnSite.fixedRows;
	foreach ti in voyage.allNotifiedTIsByIdCargoType discreteLock do
		if ti.getJobNumber(true) &lt;&gt; null or ti.isChild then
			continue;
		endif;
		self.loadCargoForTable(ti, rowIdx, self.tblPreNote, null);
	endforeach;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="loadShifts" id="7c4255ef-d35d-4fda-bdbe-9216f62b3da0">
        <updating/>
        <source>loadShifts() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 August 2018	jlger1	Initial creation
19 Sep 2022 navtnr20	ChangeRequest 54840: MTN - Hold Planning Shift List
*/

vars
	startDT, endDT : TimeStamp;
	msg : String;
begin
	startDT := self.myCurrentVoyage.getArrivalDT;
	endDT := self.myCurrentVoyage.getDepartureDT;
	self.allShiftsDays.purge;
	self.cmbShifts.clear;
	
	//19 Sep 2019	NDL	TFS 46628
	if not self.toldAboutShifts and (not startDT.isValid or not endDT.isValid) then
		if not startDT.isValid then		//21.09.2022 navtnr20 54840
			msg := app.getErrorString(Unabl_deriv_shift_voyag_not_sh);	
			app.msgBox( msg, app.getErrorString(Warning), MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon );
			self.toldAboutShifts := true; // TFS 46628 JLGAB1
			return;
	//start //21.09.2022 navtnr20 54840
		elseif not endDT.isValid then
			endDT := startDT.addDays(7);
			msg := app.getErrorString2(Unable_derive_shift_voyag_not_,startDT.date.String, endDT.date.String);
			app.msgBox( msg, app.getErrorString(Warning), MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon );
			self.toldAboutShifts := true;
		endif;
	else
		if not endDT.isValid then
			endDT := startDT.addDays(7);
			msg := app.getErrorString2(Unable_derive_shift_voyag_not_,startDT.date.String, endDT.date.String);
			app.msgBox( msg, app.getErrorString(Warning), MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon );
		endif;
	endif;
	//end //21.09.2022 navtnr20 54840
	self.myTerminal.getShiftsFromRange(self.allShiftsDays, startDT, endDT);
	self.cmbShifts.listCollection(self.allShiftsDays, false, ComboBox.DisplayCollection_Forward);
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="loadTranshipTable" id="9674d8f4-f1b0-4ae8-9d6d-f07f28aed847">
        <source>loadTranshipTable();
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
23 October 2019		jlgzm1	Initial creation TFS 47085 Direct Release Ship to Ship

*/

vars
	voyage 	: CM_Voyage;
	ti 		: CM_TrackedItem;
	rowIdx 	: Integer;
	job		: CM_VoyageJob;
begin
	// unallocated tranship cargo is all tranship cargo for the current voyage that is not currently assigned to a job
	voyage := self.myCurrentVoyage;
	if voyage = null then
		return;
	endif;
	
	self.tblTranship.rows := tblTranship.fixedRows;
	
	foreach ti in voyage.allTranshipTIsExport discreteLock do
		if ti.isOnSite then
			continue;
		endif;
		job := ti.getFirstAvailableDischargeJob();
		if job = null then
			continue;
		endif;
		self.loadCargoForTable(ti, rowIdx, self.tblTranship, null);
	endforeach;
	
	self.setTranshipVisibility();
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="loadVoyageJobTable" id="7ec8e55e-53a6-4bce-bbbb-48b703421724">
        <updating/>
        <source>loadVoyageJobTable(	_job : CM_VoyageHoldJob; 
					_table : CM_DataTable input;
					_allocatedWLEs : CM_WLEArray	) updating, protected;			// TFS 3516
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 18/01/2017	cnwdap1		Initial creation TFS 3219 LNX Voyage Operations Enhancements
// 02/03/2017	cnwdap1		TFS 3489 LNX DLR/SOB
// 01/03/2017	cnwdap1		TFS 3516 LNX Hold Planning Quantity
// 18/07/2019	jlgzm1		TFS 42872 Direct Release Between HOLD Voyages and Rail
// 15/10/2021	navdap1		TFS 51935 SAL Direct Loading Partial Prenoted Cargo from Truck to Vessel
// 16/11/2021	navdap1		TFS 52360 SAL Direct Prenote to Voyage Incorrect Job Values
//
vars
	allTIs : CM_TISet;
	ti : CM_TrackedItem;
	rowIdx : Integer;
	wle : CM_WorkListEntry;	// TFS 42872
	str : String;			// TFS 42872
	
begin
	_table.rows := _table.fixedRows;
	
	// TFS 42872 Start
	foreach wle in _job.workListEntries do
		if wle.showDirectDeliveryInHoldForms() then				// TFS 52360
			str := wle.getAttributeStringForDefArray(_table.allTblDataEntRows);
			rowIdx := _table.addItem(str);
			_table.accessRow(rowIdx).itemObject := wle;
			self.doColourTableRow(ti, wle, _table, _job, rowIdx);
			if not self.allDisplayedWLEs.includes(wle) then
			self.allDisplayedWLEs.add(wle);
			endif;
		endif;
	endforeach;
	// TFS 42872 End
	
	/* ** Voyage Job Tables now display WorkListEntries not Tracked Items
	 below is how  it was **
	if _job.isDischarge then
		allTIs := _job.allReceiveTrackedItems;
	else
		allTIs := _job.allReleaseTrackeditems;
	endif;
	
	//foreach ti in allTIs do												// TFS 3516
	foreach ti in allTIs where not ti.hasBeenMerged do						// TFS 3516
		//self.loadCargoForTable(ti, rowIdx, _table);						// TFS 3516
		self.loadCargoForTable(ti, rowIdx, _table, _allocatedWLEs);			// TFS 3516
		self.doColourTableRow(ti, _table, _job, rowIdx);					// TFS 3516
	endforeach;
	
	if not _job.isDischarge and _job.myDLRDischargeJob &lt;&gt; null then			// TFS 3516
		self.showDLRDischargeFields(_table, _job.myDLRDischargeJob);		// TFS 3516
	endif;																	// TFS 3516
	*/
	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_job" type="CM_VoyageHoldJob"/>
        <Parameter name="_table" type="CM_DataTable" usage="input"/>
        <Parameter name="_allocatedWLEs" type="CM_WLEArray"/>
    </JadeMethod>
