    <JadeMethod name="getExtraInfo" id="a23e3acb-f568-46f0-a440-4d5edc6a35da">
        <source>getExtraInfo(_dataContainer: CM_DataContainer);
/*

Purpose:		TFS 39718	

Parameters:			

Return Value:		

Date		Who		Reason
11 July 2018	jlgab1	Initial creation

*/

vars
	block : CM_DataContainerBlock;
	tmpTS : TimeStamp;
	wodres : CM_WodMarineServiceDetail;
begin
	inheritMethod(_dataContainer);

	tmpTS := self.systemToLocalTime(self.occursOnDT); // PEL UAT WP testing 30SEP18

	block := _dataContainer.addNewBlock;
	block.addNewItem(app.getErrorString(DepartureNEW), DC_Label, 1, null);
	block.addNewItem(tmpTS.asStringJMT() , DC_Data, 1, null); // PEL UAT WP testing 30SEP18
	
	
	if self.oldDepartureDT &lt;&gt; null then
		tmpTS := self.systemToLocalTime(self.oldDepartureDT); // PEL UAT WP testing 30SEP18
		block := _dataContainer.addNewBlock;
		block.addNewItem(app.getErrorString(Old_Departure), DC_Label, 1, null);
		block.addNewItem(tmpTS.asStringJMT() , DC_Data, 1, null); // PEL UAT WP testing 30SEP18
	endif;
	
	//19 Feb 2019	NDL	TFS 43374
	foreach wodres in self.allMarineServiceDetails do
		wodres.getExtraInfo(_dataContainer);
	endforeach;

epilog

end;</source>
        <Parameter name="_dataContainer" type="CM_DataContainer"/>
    </JadeMethod>
    <JadeMethod name="getMyBerth" id="0ab100ab-838d-43dc-9b07-a5fbbfec958e">
        <source>getMyBerth(): HMS_Berth;
/*

Purpose:			TFS 42161

Parameters:			

Return Value:		

Date		Who		Reason
12 December 2018	jlgab1	Initial creation

*/

vars

	voyage : CM_Voyage;
	departMovement : HMS_VoyageMovement;
	prevMovement : HMS_VoyageMovement;
	theMovement : HMS_VoyageMovement;
begin

	voyage := self.getMyVoyageObject();

	if voyage &lt;&gt; null then
		
		departMovement := voyage.getMovementDeparture();
		if departMovement &lt;&gt; null then
			prevMovement := departMovement.myPreviousMovement.HMS_VoyageMovement;
			if prevMovement &lt;&gt; null then
				return prevMovement.getMyBerth;
			endif;
		endif;
		
	endif;
	
	return inheritMethod();
	

epilog

end;</source>
        <ReturnType type="HMS_Berth"/>
    </JadeMethod>
