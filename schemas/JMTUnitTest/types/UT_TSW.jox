    <JadeMethod name="zTSWDTRFileBOL" id="bc846173-a147-4d2d-bdd7-3a3ec35e96c1">
        <source>zTSWDTRFileBOL(_vesselCode, _voyageCode, _roleCode, _nameCode, _bolNumber : String; _packCount : Integer; _agency : String) : String protected;
