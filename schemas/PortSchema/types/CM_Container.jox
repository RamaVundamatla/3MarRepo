    <JadeMethod name="getInfoStr" id="93535e98-008a-457b-9812-364af25f775f">
        <source>getInfoStr(_inDetail: Boolean): String;
//----------------------------------------------------------------
//	Created:	18 August 2003	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	str		: String;
begin

	if self.hasReeferRemarks then
		if str &lt;&gt; null then
			str := str &amp; CrLf &amp; self.getReeferRemarks.trimBlanks;
		else
			str := self.getReeferRemarks.trimBlanks;
		endif;
	endif;
	
	if str &lt;&gt; null then
		str := str &amp; CrLf;
	endif;
	
	str := str &amp; inheritMethod(_inDetail);
	
	if self.getCou &lt;&gt; null then
		if str &lt;&gt; null then
	    	str := str &amp; CrLf &amp; app.getErrorString(Info_HasCOU);
	    else
	    	str := app.getErrorString(Info_HasCOU);
	    endif;
	    if _inDetail then
	    	str := str &amp; "(" &amp; self.getCou.id &amp; ")";
	    endif;
	endif;
	
	// has a Gen Set attached? Par 17775. ccms1045 APM - yard Ops - new generator Type. September 2008
	// for generator types: nose-mounted and under-slung
	if self.getGenerator &lt;&gt; null and self.getGenerator.isNoseMounted()
	then
		if str &lt;&gt; null then
	    	str := str &amp; CrLf &amp; app.getErrorString1(Info_HasGenSetAttached, self.getGenerator.myGeneratorType.getDisplayDetails(false) );
	    else
	    	str := app.getErrorString1(Info_HasGenSetAttached, self.getGenerator.myGeneratorType.getDisplayDetails(false) );
	    endif;
	    if _inDetail then
	    	str := str &amp; "(" &amp; self.getGenerator.getDisplayDetails(false) &amp; ")";
	    endif;
	endif;
	
	return str;
	
end;</source>
        <Parameter name="_inDetail" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
