    <JadeMethod name="doSave" id="6b033601-7b2b-424c-bbf5-8ca7513eaaf3">
        <source>doSave() : Boolean;
/*

Purpose:			


Return Value:		


Date		Who		Reason
01 March 2007	cnwer1	Initial creation - PAR#xxxx
//22/01/17 cnwns1 TFS3153:PKT - Bulk Process - WeighBridge Integration
*/
vars
	pxySerialConnection,
	realSerialConnection: CM_WinCEJadeSerialDetails;
	portName : String;
	speedBps,
	dataBits,
	parity,
	stopBits,
	flowControl,
	timeout: Integer;
	deviceType : Integer;
begin

	portName:=self.txtName.text;
	speedBps:=self.txtSpeed.text.Integer;
	if self.cmbDataBits.listIndex &lt;&gt; -1 then
		dataBits:=self.myAssistant.getDataBitsFromDesc(self.cmbDataBits.itemText[self.cmbDataBits.listIndex].String);
	endif;
	
	if self.cmbParity.listIndex &lt;&gt; -1 then
		parity:=self.myAssistant.getParityFromDesc(self.cmbParity.itemText[self.cmbParity.listIndex].String);
	endif;
	
	if self.cmbFlowControl.listIndex &lt;&gt; -1 then
		flowControl:=self.myAssistant.getFlowControlFromDesc(self.cmbFlowControl.itemText[self.cmbFlowControl.listIndex].String);
	endif;
	
	if self.cmbStopBits.listIndex &lt;&gt; -1 then
		stopBits:=self.myAssistant.getSopBitsFromDesc(cmbStopBits.itemText[self.cmbStopBits.listIndex].String);
	endif;
	
	if self.cmbDeviceType.listIndex &lt;&gt; -1 then
		deviceType:=self.myAssistant.getDeviceTypeFromDesc(self.cmbDeviceType.itemText[self.cmbDeviceType.listIndex].String);
	endif;
	
	timeout:=self.txtTimeout.text.Integer;
	create pxySerialConnection transient;
	pxySerialConnection.setProxy(	portName,
										speedBps,
										dataBits,
										parity,
										stopBits,
										flowControl,
										timeout,
										deviceType);	//cnwjo3 par 23992
										
										
	if self.myDevice &lt;&gt; null then									
		if self.myDevice.myWinCESerialDetails = null then
			app.myTrxCA.trxCreateWinCESerialDetails(pxySerialConnection,realSerialConnection,self.myDevice,app.myPassport,null);
		else
			app.myTrxUA.trxUpdateWinCESerialDetails(pxySerialConnection,self.myDevice.myWinCESerialDetails,app.myPassport);
		endif;
	elseif self.myWeighbridgeObj &lt;&gt; null then
		if self.myWeighbridgeObj.mySerialDetails = null then
			app.myTrxCA.trxCreateWinCESerialDetails(pxySerialConnection,realSerialConnection,null,app.myPassport,self.myWeighbridgeObj);
		else
			app.myTrxUA.trxUpdateWinCESerialDetails(pxySerialConnection,self.myWeighbridgeObj.mySerialDetails,app.myPassport);
		endif;
	endif;
	
	
	return true;
	
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
