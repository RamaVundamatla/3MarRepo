    </JadeMethod>
    <JadeMethod name="getDescription" id="6cb5e24c-7c16-4993-801a-03e821ee8138">
        <source>getDescription() : String;
/*
Purpose:	TFS 45953		
Date				Who			Reason
OCTOBER 2019		JLGAB1 Try to add more meaningful message when cash receipt does not work.
*/


vars
	trannum : Integer;
	tran : CM_TransactionType;
	message, extra : String;
	commapos : Integer;
	count : Integer;
begin
	foreach trannum in self.allTITransTypes	discreteLock do
		tran := app.myRoot.allTransactionTypes[trannum];
		
		if tran &lt;&gt; null then
			count := count + 1;
			if message= "" then
				message:= tran.description;
			else
				message := message &amp; ", " &amp;  tran.description;
			endif;
		endif;
	endforeach;
	
	foreach trannum in self.allWOTransactions	discreteLock do
		tran := app.myRoot.allTransactionTypes[trannum];
		
		if tran &lt;&gt; null then
			count := count + 1;
			extra := "";
			if trannum = TRANS_TYPE_WO_MARINESERVICEDEP then
				extra := " - (Departure WO does not charge)";
			
			endif;
			if message= "" then
				message:= tran.description &amp; extra;
			else
				message := message &amp; ", " &amp;  tran.description &amp; extra;
			endif;
		endif;
	endforeach;
	
	if message &lt;&gt; "" then
		if count = 1 then
			message := "Transaction is " &amp; message;
		else
			message := "Transactions are " &amp; message;
		endif;
		message := message &amp; ".";
		
		commapos := message.reversePos(",");
		if commapos &gt; 0 then
			message := message[1:commapos - 1] &amp; " and" &amp; message[commapos+1:end];
		endif;
		
		
	endif;
	
	return message;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="initialise" id="0d219dac-768f-4995-8a6e-0603c877cae5">
        <updating/>
        <source>initialise(_wo : CM_WorkOrder) updating;
/*

Purpose:			TFS 38524

Parameters:			

Return Value:		

Date		Who		Reason
18 May 2018	jlgab1	Initial creation

*/

vars

begin
	self.myWorkOrder := _wo;
	
	if _wo = null then
		return;
	endif;
	
	create allTITransTypes transient;
	create allWOTransactions transient;
	
	self.setResources();
	self.setTransactions();
	self.setWOTransactions();
epilog

end;</source>
        <Parameter name="_wo" type="CM_WorkOrder"/>
    </JadeMethod>
    <JadeMethod name="purger" id="49f3208f-007d-4dc6-a31c-24d0cf12467c">
        <updating/>
        <source>purger() updating	;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 May 2018	jlgab1	Initial creation

*/

vars
	proDebtor : CMIF_ProformaInvLinesForDebtor;

begin
	self.allAgents.purge;
	delete self.allTITransTypes;
	delete self.allWOTransactions;
	
	//19 Sep 2018	NDL	TFS 40933
	if not self.allResources.isEmpty then
		self.allResources.purge();
	endif;
	//24 May 2019	NDL	TFS 44774
	if not self.allProformaInvLineDebtor.isEmpty then
		foreach proDebtor in self.allProformaInvLineDebtor do
			proDebtor.allProformaAgents.purge();
		endforeach;
		self.allProformaInvLineDebtor.purge();
	endif;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setResources" id="0bac4c25-4c39-48be-aeca-f1319e00a838">
        <source>setResources();
/*

Purpose:			 // TFS 38524

Parameters:			

Return Value:		

Date		Who		Reason
17 May 2018	jlgab1	Initial creation

*/

vars
	pxyResUsed : HMS_ResourceUsed;
	resource : HMS_Resource;
	voyage : CM_Voyage;
	movement : HMS_VoyageMovement;
	hmsBerth : HMS_Berth;
	fromTS, toTS : TimeStamp;
	harbour : HMS_Harbour;
	wod : CM_WorkOrderDtl;
	
begin
	voyage := self.myWorkOrder.getMyVoyageObject();

	if voyage = null then
		return;
	endif;
	
	movement := self.myWorkOrder.getMyHMSVoyageMovement();	//08 Apr 2019	NDL	TFS 43687
	if movement = null then
		movement := voyage.getMovementArrival();
	endif;
	if movement = null then
		return;
	endif;
	
	hmsBerth := movement.getMyBerth();
	if hmsBerth = null then
		return;
	endif;
	fromTS:= hmsBerth.getFromTimeStamp(movement);
	toTS := hmsBerth.getToTimeStamps(movement);
	harbour := movement.myHarbour;

	foreach wod in self.myWorkOrder.allWoDtls discreteLock do
		wod.createPxyHMSResourceProformas(self.allResources, movement);
	endforeach;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setTransactions" id="7cc101fe-ca42-4ce8-ba64-edaaaf4e6602">
        <source>setTransactions();
/*

Purpose:			 // TFS 38524

Parameters:			

Return Value:		

Date		Who		Reason
17 May 2018	jlgab1	Initial creation
15 Mar 2023 navhl20 ChangeRequest 56614:[56615] EUP - Allow Multi ToDo Tasks Description on Cargo ToDo Work Order
02 Apr 2025 navsp1  JIRA-34535 Unit Test Performance Improvement: Transport Manifest related unit tests take Large Time to Finish
*/

vars
	wod 	 : CM_WorkOrderDtl;
	trantype : Integer;
	wodToDo  : CM_WodToDo;
	toDoTask :	CM_ToDoTaskDesc;
begin

	if self.myWorkOrder = null then
		return;
	endif;
	
	foreach wod in self.myWorkOrder.allWoDtls	discreteLock do
		// TFS 42221
		if wod.isWorkOrderForPermitTIPenalty() then
			self.allTITransTypes.add(TRANS_TYPE_WORKORDER_EXTRATI);
			continue;
		endif;
	
		if not wod.isWorkOrderTIDtl() then
			continue;
		endif;
		
		trantype := wod.getWOTransactionType();
		if trantype &lt;&gt; TRANS_TYPE_NULL 
		and not self.allTITransTypes.includes(trantype) then					//JIRA-34535
			self.allTITransTypes.add(trantype);
		endif;
		
		//trantype := wod.getTITransactionType();								//15.3.2023 navhl20	#56614[56615]
		trantype := wod.getTITransactionType(null);								//15.3.2023 navhl20	#56614[56615]
		if trantype &lt;&gt; TRANS_TYPE_NULL 
		and not self.allTITransTypes.includes(trantype) then					//JIRA-34535
			self.allTITransTypes.add(trantype);
		endif;
		
		//14 Feb 2019	NDL	TFS 43402
		if wod.hasExtraWodToDos() then
			foreach wodToDo in wod.CM_WorkOrderTIDtl.allToDoRequests do
				foreach toDoTask in wodToDo.CM_WodToDo.allToDoTasksDescs do		//15.3.2023 navhl20	#56614[56615]
					//trantype := wodToDo.getTITransactionType();				//15.3.2023 navhl20	#56614[56615]
					trantype := wodToDo.getTITransactionType(toDoTask);			//15.3.2023 navhl20	#56614[56615]
					if trantype &lt;&gt; TRANS_TYPE_NULL 
					and not self.allTITransTypes.includes(trantype) then		//JIRA-34535
						self.allTITransTypes.add(trantype);
					endif;
				endforeach;														//15.3.2023 navhl20	#56614[56615]
			endforeach;
		endif;
		
	endforeach;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setWOTransactions" id="2183bb11-6db3-49e4-be7f-7f8826a1a031">
        <source>setWOTransactions();
/*
Purpose:	TFS 39236		
Date				Who			Reason
JUNE 2018		CNWAB1		Initial creation
15 Mar 2023  	navhl20  	ChangeRequest 56614:[56615] EUP - Allow Multi ToDo Tasks Description on Cargo ToDo Work Order
02 Apr 2025 	navsp1  	JIRA-34535 Unit Test Performance Improvement: Transport Manifest related unit tests take Large Time to Finish
*/

vars
	wod 		: CM_WorkOrderDtl;
	trantype	: Integer;
	wodToDo	 	: CM_WodToDo;
	toDoTask	: CM_ToDoTaskDesc; 
begin
	if self.myWorkOrder = null then
		return;
	endif;
	
	foreach wod in self.myWorkOrder.allWoDtls	discreteLock do
		if not wod.isWorkOrderVoyageDtl() then
			continue;
		endif;
		
		trantype := wod.getWOTransactionType();
		if trantype &lt;&gt; TRANS_TYPE_NULL 
		and not self.allWOTransactions.includes(trantype) then					//JIRA-34535
			self.allWOTransactions.add(trantype);
		endif;
		
		//trantype := wod.getTITransactionType();								//15.3.2023 navhl20	#56614[56615]
		trantype := wod.getTITransactionType(null);								//15.3.2023 navhl20	#56614[56615]
		if trantype &lt;&gt; TRANS_TYPE_NULL 
		and not self.allTITransTypes.includes(trantype) then					//JIRA-34535
			self.allTITransTypes.add(trantype);
		endif;
		
		//14 Feb 2019	NDL	TFS 43402
		if wod.hasExtraWodToDos() then
			foreach wodToDo in wod.CM_WorkOrderTIDtl.allToDoRequests do
				foreach toDoTask in wodToDo.CM_WodToDo.allToDoTasksDescs do		//15.3.2023 navhl20	#56614[56615]
					//trantype := wodToDo.getTITransactionType();				//15.3.2023 navhl20	#56614[56615]
					trantype := wodToDo.getTITransactionType(toDoTask);			//15.3.2023 navhl20	#56614[56615]
					if trantype &lt;&gt; TRANS_TYPE_NULL 
					and not self.allTITransTypes.includes(trantype) then		//JIRA-34535
						self.allTITransTypes.add(trantype);
					endif;
				endforeach;
			endforeach;
		endif;
		
	endforeach;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="sortProformaLines" id="e32e7daf-cfdc-4c12-9065-1f6178be3774">
        <updating/>
        <source>sortProformaLines(_lines : CM_InvoiceLineBySeqNumDict) updating;
/*

Purpose:			TFS 39349

Parameters:			

Return Value:		

Date			Who		Reason
01 August 2018	jlgab1	Initial creation
23 Oct 2024		navlw1	JIRA-33107: Invoice Logging Use Levels
25 Feb 2025		navah1	Story 34141: MTN - Performance Improvements - Review for invLog() Methods
*/

vars
	line : CM_InvoiceLine;
	invoiceType : CM_InvoiceDesc;
	proformaAgent : CM_CashProformaWorkOrderAgent;
	woProfromaAgent : CM_CashProformaWorkOrderAgent;
	obj : Object;
	linesForDebtor : CMIF_ProformaInvLinesForDebtor;
	debtor : CM_Debtor;
	name : String;
	ti : CM_TrackedItem;
	invalidTI : Boolean;
	tiEd : Integer;
	paymentType : Integer;
	canLogExtra	: Boolean;	//27.02.2025 navah1	#34141
begin
	canLogExtra	:= app.canLogExtraDetail();				//27.02.2025 navah1	#34141
	self.allProformaInvLineDebtor.clear();
	
	if canLogExtra then	//28.02.2025 navah1	#34141
		app.invLog(method.qualifiedName &amp; "Group Lines by debtor and invoice type for " &amp; self.allAgents.size.String &amp; " Agents", LogTRACE.String); // LOG CASH
	endif;
	on Exception do app.handleDeletedObject(exception,ti,invalidTI);
	
	foreach obj in self.allAgents	discreteLock do
		proformaAgent := obj.CM_CashProformaWorkOrderAgent;
		ti:=proformaAgent.myTrackedItem;
		if ti &lt;&gt; null then	//21 Aug 2018	NDL - tripped over during testing of TFS 40127
			tiEd :=ti.edition;
		endif;
		if invalidTI then
			proformaAgent.nullMyTrackedItem();
			invalidTI:=false;
		endif;

		
		/* TFS 40324
		debtor := proformaAgent.myDebtor;
		 
		if debtor = null then
			name := "UNKNOWN";
		else	
			name := debtor.name;
		endif;
		
		app.invLog(method.qualifiedName &amp; " " &amp; proformaAgent.allOwingInvoicedLines.size.String &amp; " Owing Lines  for " &amp; name); // LOG CASH
		*/
		
		foreach line in proformaAgent.allOwingInvoicedLines 	discreteLock do
			invoiceType := line.invoiceLineDesc.invoiceType;
			
			// TFS 40324
			debtor := line.debtor;
			if debtor = null then
				name := "UNKNOWN";
			else	
				name := debtor.name;
			endif;
			
			paymentType := line.paymentType; // TFS 41281 - getProformaPaymentType(); //09 Oct 2018	NDL	TFS 41281
			if canLogExtra then	//28.02.2025 navah1	#34141
				app.invLog(method.qualifiedName &amp; " " &amp; proformaAgent.allOwingInvoicedLines.size.String &amp; " Owing Lines  for " &amp; name, LogTRACE.String); // LOG CASH
			endif;
			
		
			linesForDebtor := self.allProformaInvLineDebtor[debtor,invoiceType,paymentType];
			if linesForDebtor = null then
				create linesForDebtor transient;
				linesForDebtor.myDebtor := debtor;
				linesForDebtor.myInvoiceType := invoiceType;
				linesForDebtor.paymentType := paymentType;	 //09 Oct 2018	NDL	TFS 41281
				
				self.allProformaInvLineDebtor.add(linesForDebtor);
				
				create woProfromaAgent transient;
				linesForDebtor.allProformaAgents.add(woProfromaAgent);
				
							
				woProfromaAgent.initialise(proformaAgent.myWorkOrder,proformaAgent.myTrackedItem);
			endif;

			linesForDebtor.allInvoiceLines.add(line);
			if proformaAgent.myTrackedItem&lt;&gt; null then
				if not linesForDebtor.allTIs.includes(proformaAgent.myTrackedItem) then
					linesForDebtor.allTIs.add(proformaAgent.myTrackedItem);
				endif;
			endif;
			
			woProfromaAgent := linesForDebtor.allProformaAgents.first.CM_CashProformaWorkOrderAgent;
			woProfromaAgent.addProformaLine(line); 
		endforeach;
				
		
	endforeach;
	if canLogExtra then	//28.02.2025 navah1	#34141
		app.invLog(method.qualifiedName &amp; "Grouped for " &amp; self.allProformaInvLineDebtor.size.String &amp; " Debtors", LogTRACE.String); // LOG CASH
	endif;
epilog

end;</source>
        <Parameter name="_lines" type="CM_InvoiceLineBySeqNumDict"/>
    </JadeMethod>
</Class>
