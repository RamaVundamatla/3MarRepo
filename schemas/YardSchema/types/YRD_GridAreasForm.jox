    <JadeMethod name="doMnuAddLabourRestrictClick" id="edae97ca-5874-4a5f-8623-d9b45cf8f117">
        <updating/>
        <source>doMnuAddLabourRestrictClick(menuItem: MenuItem input) updating;
// ---------------------------------------------------------------------------
// Created:     07 June 2005	cnwhjg1
//
// Purpose:     
// ----------   ----------  --------------------------------------------------
vars
	theTA : CM_TerminalArea;
	rowNum : Integer;
begin
	if menuItem.helpKeyword &lt;&gt; "MAIN" then
		if menuItem.helpKeyword = "DEFINE" then 
			self.doRestrictionOpenLabour(menuItem.userObject.CM_TerminalArea);
		elseif menuItem.helpKeyword = "ALL" then 		
			theTA := menuItem.userObject.CM_TerminalArea;
			if theTA = null then
				return;
			endif;
			self.showLabourRestrictionForm(null, theTA);
		else
			self.showLabourRestrictionForm(menuItem.userObject.CM_TerminalSubArea, null);
		endif;
	endif;
end;</source>
