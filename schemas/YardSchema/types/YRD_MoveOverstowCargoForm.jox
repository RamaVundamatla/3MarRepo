    <JadeMethod name="doQuery" id="fddda7f4-b91c-44af-bdb3-6a3c1f1cdcd5">
        <updating/>
        <source>doQuery(_viewMode : Integer) updating;
// ---------------------------------------------------------------------------
// Created:		November 2009 By Pieter Bremmers cnwphb1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

constants	
	MinRowsShown  = 6;
vars
	cdc					: YRD_ContainerDrawingController;	//: YRD_CargoBayDrawingController;
	currentLC			: CM_GridController;
	tmpDkbGridArea	:	YRD_ContainerGridAreaDockBar;
	tmpScrollableFrame	: CMUI_ScrollableFrame;
	minRow,maxRow,
	minCol,
	maxCol,diffCols,
	padByCols 			: Integer;
	lc					: CM_LocationsController;
	isEndView : Boolean;
begin
	isEndView := self.optViewEnd.value; // PAR 25634
	
	tmpDkbGridArea	:= self.dkbGridAreas;
	tmpDkbGridArea.setHLabelDetails(0, false);
	tmpDkbGridArea.setVLabelDetails(0, false);
	tmpDkbGridArea.isForEndView:=isEndView; // PAR 25634
	tmpDkbGridArea.postCreate();
	tmpDkbGridArea.left :=10;
	tmpDkbGridArea.myDrawingFrame.myDragSelectFrame.visible := true;
	tmpDkbGridArea.borderStyle:=Frame.BorderStyle_Single;
	// when able add labels as virtual to CMUI_GridAreaDockBar and
	// make dkbGridArea.myScrollableFrame protected
	tmpScrollableFrame := tmpDkbGridArea.myScrollableFrame;
	tmpScrollableFrame.labels := ScrollBars_Both;
	
	//create cdc transient;
	cdc:=tmpDkbGridArea.myDrawingController;
	self.setMyCurrentDrawingController(cdc);
	cdc.showDrawingFrame(false);
	
	//get min max rows 
	if self.myTrackedItem.myPrimaryActualLocation.isKindOf(CM_GridController) then
		currentLC:=self.myTrackedItem.myPrimaryActualLocation.CM_GridController;
		foreach lc in self.myTrackedItem.allLocations do
			self.allLCs.addNoDuplicates(lc.CM_GridController,false);
		endforeach;
		
		if isEndView then  // PAR 25634
			minCol:=self.allLCs.first.CM_GridController.column;
			maxCol:=self.allLCs.last.CM_GridController.column;
			minRow:= currentLC.getMyGridArea.allGridRows.first.row;
			maxRow:=currentLC.getMyGridArea.allGridRows.last.row;
		else  // PAR 25634
			minCol:=currentLC.getMyGridArea.allGridColumns.first.column;
			maxCol:=currentLC.getMyGridArea.allGridColumns.last.column;
			minRow:= self.allLCs.first.CM_GridController.row - 1;
			if minRow &lt; currentLC.getMyGridArea.allGridRows.first.row then
				minRow := currentLC.getMyGridArea.allGridRows.first.row;
			endif;
			maxRow:=minRow + 2;
			if maxRow &gt; currentLC.getMyGridArea.allGridRows.last.row then
				maxRow := currentLC.getMyGridArea.allGridRows.last.row;
			endif;
		endif;

	endif;
	
	
	cdc.setScale(CMUI_GridDrawingController.ScaleFactor_3, true, true);
	cdc.setFlip(self.xmlFlipH,self.xmlFlipV); // PAR 25634
	if cdc.isKindOf(YRD_CargoBayDrawingController) then
		self.allLCs.copy(cdc.YRD_CargoBayDrawingController.allLCs);
	endif;
	cdc.useSelectorObjects:=true;
	cdc.allSelectorTIs.add(self.myTrackedItem);
	
	cdc.setRange(minRow, maxRow, minCol,maxCol);
	cdc.init(self.allLCs.first.CM_GridController.myTerminalArea,null);
	cdc.setViewMode(_viewMode);
	cdc.clearAllSelectedObjects();
	self.allOverstowingTIs.copy(cdc.allSelectedObjects);
	cdc.autoMask := false;
	cdc.changeBackColor(self.backColor     );//self.defYardBackColSelected);
	cdc.drawSelf(false);
	if cdc.myHighlighter &lt;&gt; null then // PAR 25634
		cdc.myHighlighter.durationInSeconds:=0;
	endif;
	
	cdc.startHighlighter();
	cdc.notableObjectsClear();
	cdc.notableObjectAdd(self.allLCs.first.CM_GridController.myTerminalArea);
	cdc.doCentreOnSelectedObject();// PAR 25634
	tmpDkbGridArea.myDrawingController.showDrawingFrame(true);
	tmpDkbGridArea.cnEcResizeContents();
	self.refreshNow();
	
epilog

end;</source>
        <Parameter name="_viewMode" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="doRefresh" id="1383666c-12cc-402f-b4d5-deba80e0716c">
        <updating/>
        <source>doRefresh() updating, protected;
// ---------------------------------------------------------------------------
// Created:		November 2009 By Pieter Bremmers cnwphb1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	ti : CM_TrackedItem;
begin
	inheritMethod();
	self.doQuery(VIEW_DISPORT);
	if self.allOverstowingTIs.isEmpty then
		self.txtOverstow.text:= app.getErrorString1(Not_overstowed,self.myTrackedItem.id);
	else
	
		self.txtOverstow.text:=app.getErrorString1(TI_Overstowed_by,self.myTrackedItem.id);
		foreach ti in self.allOverstowingTIs do
			self.txtOverstow.text:=self.txtOverstow.text &amp; CrLf &amp; " - "  &amp; ti.id;
		endforeach;
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doResize" id="c203e5c4-c699-499d-9b11-b4b1b6172836">
        <updating/>
        <source>doResize() updating;
// ---------------------------------------------------------------------------
// Created:     20 September 2010 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	roomLeft : Real;
	osTextHeight : Real;
	
begin
	inheritMethod();
	
	self.dkbGridAreas.cnEcResizeContents();
	self.dkbGridAreas.top := self.frmToolbar.clientHeight + 4;
	
	if self.cmbMachine.visible then
		self.lblMachine.top := self.frmToolbar.clientHeight + 4;
		self.cmbMachine.top := self.lblMachine.top + self.lblMachine.clientHeight + 4;
				
		self.txtOverstow.top:= self.cmbMachine.top + self.cmbMachine.clientHeight + 8;
	endif;
	//epr par 25527 19/1/11
	if self.btnSave.top &lt; (self.frmOptions.top + self.frmOptions.clientHeight) then
		roomLeft:=(self.frmOptions.top + self.frmOptions.clientHeight) -self.btnSave.top ;
		self.txtOverstow.height:=self.txtOverstow.clientHeight-roomLeft;
		//self.frmOptions.top:=self.frmOptions.top-roomLeft;
	else
			//epr par 25527 19/1/11
		osTextHeight:= self.getTextHeightForWidth(self.txtOverstow.text,self.txtOverstow.clientWidth);
		// has to scroll to see the overstow entries lets see if we can fit them all in
		if  osTextHeight &gt; self.txtOverstow.clientHeight then
			roomLeft:= self.btnSave.top - self.frmOptions.clientHeight - self.frmToolbar.clientHeight;
			if roomLeft &gt; osTextHeight then
				self.txtOverstow.height:=osTextHeight +1;	
			else
				self.txtOverstow.height:=roomLeft;
			endif;
			
		endif;
		
	endif;
	self.frmOptions.top:=self.txtOverstow.top+self.txtOverstow.clientHeight;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doSave" id="22fd0df0-0767-4163-92a0-9b697a387f88">
        <updating/>
        <source>doSave() updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
05 January 2010	cnwer1	Initial creation

*/

vars
	ta : CM_TerminalArea;
	icArea : CM_InterchangeArea;
	ti : CM_TrackedItem;
	yardAllocLogging,
	str: String;
	allWarnings : HugeStringArray;
	result : Integer;
	allSelectedOverstowedTIs : CM_TIArray;
	strs,remainingStrs 	: StringArray;
	foundLC	: CM_LocationsController;
	foundHeight,
	theReturn,
	laneID 		: Integer;
	gridColumn	: CM_GridColumn;
	gridRow 	: CM_GridRow;
	allFoundTAs : CM_TerminalAreaSet;
	doClose : Boolean;
	
begin
	
	gridColumn:=null;
	gridRow:=null;	 
	foundLC:=null;
	ta:=null;
	
	create allSelectedOverstowedTIs transient;
	//need this to be in order of overstowed
	foreach ti in self.allOverstowingTIs do
		if self.myDrawingController.allSelectedObjects.includes(ti) then
			allSelectedOverstowedTIs.add(ti);
		endif;	
	endforeach;
	
	
	if allSelectedOverstowedTIs.isEmpty then
		app.msgBox(app.getErrorString(Please_select_some_overst_carg),app.getErrorString(Errors),MsgBox_OK_Only);
		return;
	endif;
	
	//queue to interchange area
	if self.optICArea.value then
		icArea:=self.cmbICArea.listObject.CM_InterchangeArea;
	else
		
		if self.optCurrent.value then
			ta:=self.cmbTA.listObject.CM_TerminalArea;
		elseif self.optQtoLocation.value then
			create strs transient;
			create remainingStrs transient;
			create allFoundTAs transient;
			self.txtQtoLocation.text.getTokensForDelimiter(Space,strs);
			self.myTrackedItem.myTerminal.findTAFromString(strs, remainingStrs,true,allFoundTAs);
			foreach ta in allFoundTAs do
				if ta &lt;&gt; null then
					ta.findLocation(remainingStrs, true, foundLC, foundHeight);
					if foundLC = null then
						if remainingStrs.size &gt; 0 then
							str:=remainingStrs[1];
							//might of entered just a column 
							//look for column if a RTG or any Gridded area that uses a side access rules
							if ta.isKindOf(CM_RTGArea) or
								(ta.isKindOf(CM_GridArea) and ta.CM_GridArea.useSideAccessRules) then
								gridColumn:=ta.CM_GridArea.allGridColumnsByLabel[str];
							//look for row
							elseif (ta.isKindOf(CM_GridArea) and not ta.CM_GridArea.useSideAccessRules) then
								gridRow:=ta.CM_GridArea.allGridRowsByLabel[str];
							endif;
						endif;
					endif;
					if foundLC &lt;&gt; null then
						break;
					endif;
				endif;
			endforeach;
		endif;
		
		if ta.isKindOf(CM_InterchangeArea) then
			if foundLC &lt;&gt; null then
				laneID:=foundLC.CM_LaneController.row; 
			endif;
			icArea:=ta.CM_InterchangeArea;
		endif;
	endif;
	
	
	while true do
		
		if icArea &lt;&gt; null then
			app.myTrxUA.trxQueueOverstowCargoToICArea(self.myTrackedItem,allSelectedOverstowedTIs,icArea,laneID,app.myPassport);
		else
			app.myTrxUA.trxAutoPlanOverstowedCargo(self.myTrackedItem,allSelectedOverstowedTIs,ta,gridRow,gridColumn,foundLC,app.myPassport);
		endif;
		
		if app.myPassport.trxCompletedOK then
			// Clear errors/warnings from form and err/warnings window
			self.clearErrorWarnings();
			doClose := true;	//10 Dec 2010	NDL	Par 26494
		else
			theReturn := app.showErrorWarningDialog(app.getErrorString(Move_Overstow_Cargo), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   theReturn = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			break;
		endif;
		break;
	endwhile;
	
	//10 Dec 2010	NDL	Par 26494
	if doClose then
		self.unloadForm();
	endif;
		
epilog
	delete allSelectedOverstowedTIs;
	delete allWarnings;
	delete strs;
	delete remainingStrs;
	delete allFoundTAs;
end;</source>
    </JadeMethod>
    <JadeMethod name="getOverstowedTIs" id="fa405699-a779-4bc1-a699-ddd4395ec951">
        <source>getOverstowedTIs(_machine : CM_Machine);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 May 2018	jlger1	Initial creation

*/

vars
	sideAccessDirection : Integer;
	ti : CM_TrackedItem;
	lc : CM_LocationsController;
begin
	
	self.allOverstowingTIs.clear;
	self.allLCs.clear;
	if self.myTrackedItem &lt;&gt;  null then
		self.myTrackedItem.getAllOverstowedTIs(self.allOverstowingTIs,true,sideAccessDirection,_machine);
		
		foreach ti in self.allOverstowingTIs do
			lc := ti.getPrimaryLocation(REAL_MODE);
			if lc &lt;&gt; null and
			   lc.isKindOf(CM_GridController) then
				self.allLCs.addNoDuplicates(lc.CM_GridController, false);
			endif;
		endforeach;
	endif;
	
epilog

end;</source>
        <Parameter name="_machine" type="CM_Machine"/>
    </JadeMethod>
    <JadeMethod name="getXMLSettingsForSave" id="69760533-e878-4f51-86ee-c766b302b8ea">
        <updating/>
        <source>getXMLSettingsForSave(): String updating;
// ---------------------------------------------------------------------------
// Created:		May 2003 By Andrew Bishop cnwab1
//
// Purpose:		// PAR 25634
// ---------------------------------------------------------------------------

vars
	theXML		: String;
	
begin
	theXML := inheritMethod();

	theXML := theXML &amp; global.formatAsXML("EndVIEW",self.optViewEnd.value.Integer.String);
	theXML := theXML &amp; global.formatAsXML("FlipH",self.dkbGridAreas.myDrawingController.flipHorizontal.Integer.String);
	theXML := theXML &amp; global.formatAsXML("FlipV",self.dkbGridAreas.myDrawingController.flipVertically.Integer.String);
	return theXML;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getXMLSettingsForSetup" id="840f663b-6e37-453e-9f88-076aa85cacee">
        <updating/>
        <source>getXMLSettingsForSetup() updating;
// ---------------------------------------------------------------------------
// Created:		May 2003 By Andrew Bishop cnwab1
//// PAR 25634
// Purpose:		Get the user preferences from the user details for this form
// ---------------------------------------------------------------------------
vars
	userWindow		: CM_UserWindow;
	theXML, theXMLValue : String;
	
begin
	userWindow := self.myUserWindow;
	if userWindow = null then
		userWindow := app.getUserWindow(self.name, false);
		if userWindow = null then
			return;
		endif;
	endif;

	theXML := userWindow.xmlInfo;

 	theXMLValue := theXML.cnEcGetTagValueOfName("EndVIEW");
 	self.optViewEnd.value := true;
 	self.optViewFace.value := false;
	
 	if theXMLValue &lt;&gt; null then
		self.optViewEnd.value := theXMLValue.Integer.Boolean;
		self.optViewFace.value := not self.optViewEnd.value;
 	endif;

 	
	theXMLValue := theXML.cnEcGetTagValueOfName("FlipH");
 	if theXMLValue &lt;&gt; null then
		self.xmlFlipH := theXMLValue.Integer.Boolean;
 	endif;
 	
	theXMLValue := theXML.cnEcGetTagValueOfName("FlipV");
 	if theXMLValue &lt;&gt; null then
		self.xmlFlipV := theXMLValue.Integer.Boolean;
 	endif;

epilog

end;</source>
    </JadeMethod>
