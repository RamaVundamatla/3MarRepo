    <JadeMethod name="doRelabelColumns" id="e66bcbae-76b7-49bd-b6e6-e07568d9b785">
        <source>doRelabelColumns();
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
31 July 2009	cnwer1	Initial creation

*/

vars
	new40ftLabel : String;
	gridColumn : CMUI_GridColumn;
	lastColLabel,
	newColLabel 	: String;
begin
	
	if self.myCurrentSOPGridArea = null then
		return;
	endif;
	//sopColumn.getGridFrame.clearGraphics;
	self.myCurrentSOPGridArea.myHLabelsFrame.clearGraphics;
	lastColLabel:=null;
	foreach gridColumn in self.myCurrentSOPGridArea.allGridColumns do

		self.myCMIFTerminalArea.CMIF_GridArea.getNextColLabelNum(lastColLabel);
	
		gridColumn.label:=lastColLabel;// setLabel(lastColLabel, sopColumn.myGridArea.SOP_GridArea);
		new40ftLabel:=self.myCMIFTerminalArea.CMIF_GridArea.get40ftColId(gridColumn.label);
		gridColumn.set40ftLabel(new40ftLabel);
		gridColumn.drawSelf(null);
	endforeach;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doResize" id="f3e87702-2783-4e25-954e-a1aea9256e6f">
        <updating/>
        <source>doResize() updating;
// ---------------------------------------------------------------------------
// Created:		September  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin
	inheritMethod();
	
	self.frmMain.top := self.frmToolbarDesign.clientHeight + 2; // TFS 52333

	self.tblAPYardStack.move(5,5,self.shtAutoPlan.clientWidth - 10, self.shtAutoPlan.clientHeight - 10);
	//self.tblAPYardStack.accessColumn(CM_EntryTable.ColumnValue).width := 200;\
	doResizeTerminalAreasSheet;
	// 34353 in progress to get scroll bars
	self.sptThumbEdit.cnEcResizeContents();
	self.frmDetailsBottom.cnEcResizeContents();
	self.tblExtra.cnEcResizeContents();
	self.tblExtraList.height := self.frmDetailsBottom.height - self.tblExtraList.top;
	

	
end;</source>
    </JadeMethod>
    <JadeMethod name="doResizeMachinesSheet" id="8856722f-5928-48ab-bc51-895165ed8b7c">
