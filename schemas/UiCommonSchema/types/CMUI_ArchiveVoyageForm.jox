        <source>loadDataForFirstTime() updating, protected;
//--------------------------------------------------
// Created:	11 August 2005 By: cnwgd1
//--------------------------------------------------
vars

begin
	inheritMethod();
	if self.myVoyage &lt;&gt; null then
		self.setCaption(self.caption &amp; ' ' &amp; self.myVoyage.getId());
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
