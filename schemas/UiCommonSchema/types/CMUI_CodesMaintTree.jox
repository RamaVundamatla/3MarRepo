// -----------------------------------------------------------------------------
// Created:		20 March 2002 by cnwka1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	---------------------------------------------
//
// -----------------------------------------------------------------------------
begin
	if not global.isValidObject(self.myCurrentVMObject) then
		if self.currentGroupType = CodeGroup_LogSpecs then
			return SOPVM_LogSpecs;
		endif;
		return SOPVM_CodeGroup;
