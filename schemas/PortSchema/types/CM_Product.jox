    <JadeMethod name="getProdAttrFromName" id="6b6a6d04-7549-4161-8211-79044ecd78c5">
        <source>getProdAttrFromName(_prodAttrName : String) : CM_ProductAttr;
// ---------------------------------------------------------------------------
// Created:     23 October 2002		cnwth2	
//
// Purpose:     
//			 
// Changed On	By			Reason
// ----------   ----------  --------------------------------------------------
// 10/05/2013	cnwdap1		PAR #31155 CCMS SFW 1321 Imperial Measurements
//							Add ETRow_TotalWeight to weight condition
// 20/03/2014	cnwdap1		PAR #33606 CCMS SFW 1366 Added Stowage Factor attribute
vars

begin
	if _prodAttrName = ETRow_MyWidthString or
	   _prodAttrName = ETRow_WidthString then
		return self.myWidthString;
	elseif _prodAttrName = ETRow_MyHeightString or
	   _prodAttrName = ETRow_HeightString then
		return self.myHeightString;
	elseif _prodAttrName = ETRow_MyLengthString or
	   _prodAttrName = ETRow_LengthString then
		return self.myLengthString;
	
	elseif _prodAttrName = ETRow_MyWidth or
	   _prodAttrName = ETRow_Width then
		return self.myWidth;
	elseif _prodAttrName = ETRow_MyHeight or
	   _prodAttrName = ETRow_Height then
		return self.myHeight;
	elseif _prodAttrName = ETRow_MyLength or
	   _prodAttrName = ETRow_Length then
		return self.myLength;
	
	elseif _prodAttrName = ETRow_MyQuantity or
	   _prodAttrName = ETRow_Quantity or		// 35440 handle 'quantity' as well for pieces
	   _prodAttrName = ETRow_Pieces then
		return self.myQuantity;
	elseif _prodAttrName = ETRow_MyVolume or
	   _prodAttrName = ETRow_Volume then
		return self.myVolume;
	elseif _prodAttrName = ETRow_MyDensity or
	   _prodAttrName = ETRow_Density then
		return self.myDensityDec;								// ### TFS 52193 22Nov2021 NAVPW1
	elseif _prodAttrName = ETRow_MyWeight or					// PAR #31155
	   _prodAttrName = ETRow_TotalWeight then					// PAR #31155
	 //  _prodAttrName = ETRow_Weight then						//-cnwml2 MSL CCMS 1017
		return self.myWeight;
	
	elseif _prodAttrName = ETRow_MyType or
	   _prodAttrName = ETRow_Type then
		return self.myType;

	elseif _prodAttrName = ETRow_MyStowageFactor then			// PAR #33606
		return self.myStowageFactor;							// PAR #33606
		
	endif;
	
	return null;
end;</source>
        <Parameter name="_prodAttrName" type="String"/>
        <ReturnType type="CM_ProductAttr"/>
    </JadeMethod>
    <JadeMethod name="getReqdQuantityForStockOrders" id="7b3e4605-4ad2-47f8-91a3-89c551f47bc4">
        <source>getReqdQuantityForStockOrders() : Integer;
// ---------------------------------------------------------------------------
// Created:     19 May 2004	cnwth2
//
// Purpose:     Used in reports - do not delete
//			 
// ----------   ----------  --------------------------------------------------
vars
	stockOrderLine			: CM_StockOrderLine;
	quantity				: Integer;
begin
	foreach stockOrderLine in self.allStockOrderProductLines do
		quantity:= quantity + stockOrderLine.getReqdQuantity().Integer;
	endforeach;

	return quantity;
end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getSOHLevelsForDateLocation" id="caa305df-1b2c-4ab2-9d9c-b994da179a15">
        <source>getSOHLevelsForDateLocation(_locCon 		: CM_LocationsController;
							_date 			: Date; 
							_closingLevel 	: Boolean; 
							_totQty			: Integer output;
							_totVol			: Decimal output; 
							_totWeight 		: Decimal output);
// ---------------------------------------------------------------------------
// Created:     14 August 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// R Barr 8/11/2006 Comalco -- Refactor to use common CM_SOHLocation::getSOHLevelsForDate
// R Smith 3/6/2010	use dict to get object
// ---------------------------------------------------------------------------
vars
	//iter			: Iterator;
	sohLoc			: CM_SOHLocation;
	
begin

	sohLoc := self.allSOHLocations[_locCon];
	if sohLoc &lt;&gt; null then
		sohLoc.getSOHLevelsForDate(_date, _closingLevel, _totQty, _totVol, _totWeight);
	endif;

	/*  R Smith 3/6/2010 - change to just get the LC as above
	iter := self.allSOHLocations.createIterator();
	
	while iter.next(sohLoc) do
		if sohLoc.myLocationsController &lt;&gt; _locCon then
			continue;
		endif;
		sohLoc.getSOHLevelsForDate(_date, _closingLevel, _totQty, _totVol, _totWeight);
	endwhile;
	*/
epilog
	//delete iter;
end;</source>
        <Parameter name="_locCon" type="CM_LocationsController"/>
        <Parameter name="_date" type="Date"/>
        <Parameter name="_closingLevel" type="Boolean"/>
        <Parameter name="_totQty" type="Integer" usage="output"/>
        <Parameter name="_totVol" type="Decimal" usage="output"/>
        <Parameter name="_totWeight" type="Decimal" usage="output"/>
    </JadeMethod>
    <JadeMethod name="getSOHLevelsForDateTA" id="d1a98daa-21b7-4770-b712-bf3c9eb3062b">
        <source>getSOHLevelsForDateTA(_ta : CM_TerminalArea;
					_date 			: Date; 
					_closingLevel 	: Boolean; 
					_totQty			: Integer output;
					_totVol			: Decimal output; 
					_totWeight 		: Decimal output);
// ---------------------------------------------------------------------------
// Created:     14 August 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// R Barr 8/11/2006 Comalco -- Refactor to use common CM_SOHLocation::getSOHLevelsForDate
// ---------------------------------------------------------------------------
vars
	iter			: Iterator;
	sohLoc			: CM_SOHLocation;
	
begin
	iter := self.allSOHLocations.createIterator();
	
	while iter.next(sohLoc) do
		if sohLoc.myLocationsController.myTerminalArea &lt;&gt; _ta then
			continue;
		endif;
		sohLoc.getSOHLevelsForDate(_date, _closingLevel, _totQty, _totVol, _totWeight);
	endwhile;
epilog
	delete iter;
end;</source>
        <Parameter name="_ta" type="CM_TerminalArea"/>
        <Parameter name="_date" type="Date"/>
        <Parameter name="_closingLevel" type="Boolean"/>
        <Parameter name="_totQty" type="Integer" usage="output"/>
        <Parameter name="_totVol" type="Decimal" usage="output"/>
        <Parameter name="_totWeight" type="Decimal" usage="output"/>
    </JadeMethod>
    <JadeMethod name="getSOHLevelsForDateTerminal" id="22d081c4-5aab-424b-a17a-047ff0068cf3">
        <source>getSOHLevelsForDateTerminal(_terminal : CM_Terminal;
					_date 			: Date; 
					_closingLevel 	: Boolean; 
					_totQty			: Integer output;
					_totVol			: Decimal output; 
					_totWeight 		: Decimal output);
// ---------------------------------------------------------------------------
// Created:     14 August 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// R Barr 8/11/2006 Comalco -- Refactor to use common CM_SOHLocation::getSOHLevelsForDate
// RJS	  3/6/2010 	Change to only look at on-site locations
// ---------------------------------------------------------------------------
vars
	iter			: Iterator;
	sohLoc			: CM_SOHLocation;
	
begin
	iter := self.allSOHLocations.createIterator();
	
	while iter.next(sohLoc) do
		// RJS - 3/6/2010 - only interested in on-site details. PAR15591/18081.
		if (not sohLoc.myLocationsController.isKindOf(CM_YardController)) or
		   sohLoc.myTerminal &lt;&gt; _terminal then
			continue;
		endif;
		sohLoc.getSOHLevelsForDate(_date, _closingLevel, _totQty, _totVol, _totWeight);
	endwhile;
epilog
	delete iter;
end;</source>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_date" type="Date"/>
        <Parameter name="_closingLevel" type="Boolean"/>
        <Parameter name="_totQty" type="Integer" usage="output"/>
        <Parameter name="_totVol" type="Decimal" usage="output"/>
        <Parameter name="_totWeight" type="Decimal" usage="output"/>
    </JadeMethod>
    <JadeMethod name="getSOHLevelsForDateVoyage" id="a139c545-d544-46f8-9b80-e4aee9e0ef96">
        <source>getSOHLevelsForDateVoyage(_voyage 		: CM_Voyage;
						 _date 			: Date; 
						 _closingLevel 	: Boolean; 
						 _totQty		: Integer output;
						 _totVol		: Decimal output; 
						 _totWeight 	: Decimal output);
//--------------------------------------------------------------
//Created: October 2002 By: cnwgd1
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// R Barr 8/11/2006 Comalco -- Refactor to use common CM_SOHLocation::getSOHLevelsForDate
//--------------------------------------------------------------
vars
	iter			: Iterator;
	sohLoc			: CM_SOHLocation;
	
begin
	iter := self.allSOHLocations.createIterator();
	
	while iter.next(sohLoc) do
		if (not sohLoc.myLocationsController.isKindOf(CM_VoyageController)) then
			continue;
		endif;
		if sohLoc.myLocationsController.CM_VoyageController.myVoyage &lt;&gt; _voyage then
			continue;
		endif;		
		sohLoc.getSOHLevelsForDate(_date, _closingLevel, _totQty, _totVol, _totWeight);
	endwhile;
epilog
	delete iter;
end;</source>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_date" type="Date"/>
        <Parameter name="_closingLevel" type="Boolean"/>
        <Parameter name="_totQty" type="Integer" usage="output"/>
        <Parameter name="_totVol" type="Decimal" usage="output"/>
        <Parameter name="_totWeight" type="Decimal" usage="output"/>
    </JadeMethod>
