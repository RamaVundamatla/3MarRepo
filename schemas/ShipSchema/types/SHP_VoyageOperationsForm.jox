    <JadeMethod name="getWLETableForJob" id="6499e332-6d38-4026-9eb1-9dcfdaf6c718">
        <source>getWLETableForJob(_job : CM_Job) : CM_DataTable;
//--------------------------------------------------------------
//Created: 7 October 2003 By: cnwgd1
//--------------------------------------------------------------
vars
	obj		: Object;
	job		: CM_Job;
	table	: CM_DataTable;
begin
	
	// OBJECT BEING PASSED IN HAS TO BE A WLE OR A JOB!!!!
		
	if _job = null then
		return null;
	endif;
	
	foreach obj in self.allClonedWLETables do
		table := obj.CM_DataTable;
		if table.userObject.String = _job.String then
			break;
		endif;
		table := null;
	endforeach;
	
	return table;
		
end;</source>
        <Parameter name="_job" type="CM_Job"/>
        <ReturnType type="CM_DataTable"/>
    </JadeMethod>
    <JadeMethod name="getWLETableForWLE" id="dd4e4cfb-f45c-4a3c-b7a9-d906a00b12cd">
        <source>getWLETableForWLE(_wle : CM_WorkListEntry) : CM_DataTable protected;

// Created by cnwdvb1 on 26 February 2007

vars

	
begin

	return self.allTablesByWle.getAtKey(_wle).CM_DataTable;

end;</source>
        <access>protected</access>
        <Parameter name="_wle" type="CM_WorkListEntry"/>
        <ReturnType type="CM_DataTable"/>
    </JadeMethod>
    <JadeMethod name="getXMLSettingsForSave" id="7511fb75-4bf2-4a71-8ce2-136cfe3010fb">
        <updating/>
        <source>getXMLSettingsForSave(): String updating;
//--------------------------------------------------------------
//Created: 15 January 2003 By: cnwgd1
//--------------------------------------------------------------
vars
	xmlStr	: String;
	entRow	: EntTableRow;	
begin
	xmlStr := inheritMethod();
	
	xmlStr := xmlStr &amp; self.tblWorkEntries.getXmlStrForColumns(true);
	
	// Horizontal splitter ratio
	// Table columns for disharge and load jobs
	xmlStr := xmlStr &amp; 
			global.formatAsXMLPrefix(XMLTag_Splitter &amp; ' ' &amp; self.name &amp; ' ' &amp; self.splTables.name) &amp;
			global.formatAsXML(XMLTag_Ratio, self.splTablesRatio.String) &amp;
			global.formatAsXML(XMLTag_HideExtraInfo, self.hideExtraInfo.String) &amp;			
			global.formatAsXMLSuffix(XMLTag_Splitter &amp; ' ' &amp; self.name &amp; ' ' &amp; self.splTables.name)&amp;
		   	global.formatAsXML(XMLTag_DischargeView, self.xmlStrDischarge) &amp;
		   	global.formatAsXML(XMLTag_LoadView, self.xmlStrLoad);

	return xmlStr;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="handleExceptionJob" id="5efac2a3-9595-4530-a9c2-97684cb0ec07">
        <source>handleExceptionJob(exObj : Exception; _job : CM_VoyageJob io) : Integer protected;
//--------------------------------------------------
// Created:	22 June 2004 By: cnwgd1
//--------------------------------------------------
constants
	ObjectNotFound	: Integer = 4;
	ObjectDeleted	: Integer = 1072;
begin

	if exObj.errorCode = ObjectNotFound 
	or exObj.errorCode = ObjectDeleted then
		_job := null;
		return Ex_Resume_Next;
	endif;

	return Ex_Pass_Back;

end;</source>
        <access>protected</access>
        <Parameter name="exObj" type="Exception"/>
        <Parameter name="_job" type="CM_VoyageJob" usage="io"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="handleExceptionWLE" id="2717b2dc-e11c-44f8-83d4-dd32bca5fcf5">
        <source>handleExceptionWLE(exObj : Exception; _wle : CM_WorkListEntry io) : Integer protected;
//--------------------------------------------------
// Created:	22 April 2004 By: cnwgd1
//--------------------------------------------------
constants
	ObjectNotFound	: Integer = 4;
	ObjectDeleted	: Integer = 1072;
begin

	if exObj.errorCode = ObjectNotFound 
	or exObj.errorCode = ObjectDeleted then
		_wle := null;
		return Ex_Resume_Next;
	endif;

	return Ex_Pass_Back;

end;</source>
        <access>protected</access>
        <Parameter name="exObj" type="Exception"/>
        <Parameter name="_wle" type="CM_WorkListEntry" usage="io"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="handleListJobsLoad" id="e40e0e90-e397-4918-9956-648bedecb723">
        <source>handleListJobsLoad();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 Oct 2012	cnwpjs1	Initial creation  Par #30438

*/

vars

begin

	// PAR 36296 if myInitVoyage &lt;&gt; null then
