    <JadeMethod name="doQuery" id="46fb8e76-0843-4d78-bfcc-3907bd05cf64">
        <updating/>
        <source>doQuery(_qDef: CM_QueryDefinition) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 May 2014	cnwndl1	Initial creation	Par 34142

*/

vars

	crit : CM_SelectorCriteriaLine;
	obj : Object;
	voyageCode	: String;
	int : Integer;
	term : CM_Terminal;
	termSet : ObjectSet;
	userTermDict : CM_UserTerminalByTerminalDict;
	userTerm : CM_UserTerminal;
	bank : CM_Bank;
	invNum : Integer;
	voyage : CM_Voyage;
	drTerm : CM_DebtorTerminal;
	bankCode : String;

begin

	self.reset();
	
	create termSet transient;

	crit := self.myCriteriaLineHolder.allCriteriaByPropertyName[CM_CashPayment::myTerminal.name, _qDef.className];
	if crit &lt;&gt; null then
		if crit.myQueryOperator.description = CM_QueryOperator.Operator_IsOneOf then
			crit.myQueryOperator.getSearchValueAsObjectSet(termSet);
		elseif crit.myQueryOperator.description = CM_QueryOperator.Operator_Equal then
			self.myTerminal := crit.myQueryOperator.getSearchValue().CM_Terminal;
		endif;
	endif;
	if termSet.isEmpty then
		if self.myTerminal &lt;&gt; null then
			termSet.add(self.myTerminal);
		else
			userTermDict := app.myPassport.myUser.allUserTerminals;
			foreach userTerm in userTermDict do
				termSet.add(userTerm.getMyTerminal);
			endforeach;
		endif;
	endif;
	
	crit := self.myCriteriaLineHolder.allCriteriaByPropertyName[CM_CashPayment::getBankCode.name, _qDef.className];
	if crit &lt;&gt; null then
		if crit.myQueryOperator.description = CM_QueryOperator.Operator_Equal then
			bankCode := crit.myQueryOperator.getSearchValue().String;
			if bankCode &lt;&gt; null and self.myTerminal &lt;&gt; null then
				self.myBank := self.myTerminal.companies.getAtKey(bankCode);
			endif;
		endif;
	endif;
	
	crit := self.myCriteriaLineHolder.allCriteriaByPropertyName[CM_CashPayment::getDebtor.name, _qDef.className];
	if crit &lt;&gt; null then
		if crit.myQueryOperator.description = CM_QueryOperator.Operator_Equal then
			self.myDebtor := crit.myQueryOperator.getSearchValue().CM_Debtor;
		endif;
	endif;
	
	crit := self.myCriteriaLineHolder.allCriteriaByPropertyName[CM_CashPayment::getInvoiceNumber.name, _qDef.className];
	if crit &lt;&gt; null then
		if crit.myQueryOperator.description = CM_QueryOperator.Operator_Equal then
			invNum := crit.myQueryOperator.getSearchValue().Integer;
		endif;
	endif;
	
	crit := self.myCriteriaLineHolder.allCriteriaByPropertyName[CM_CashPayment::getVoyageCode.name, _qDef.className];
	if crit &lt;&gt; null then
		if crit.myQueryOperator.description = CM_QueryOperator.Operator_Equal then
			voyageCode := crit.myQueryOperator.getSearchValue().String;
			foreach obj in termSet do
				voyage := obj.CM_Terminal.lookupVoyage (voyageCode, null, true);
				if voyage &lt;&gt; null then
					break;
				endif;
			endforeach;
		endif;
	endif;
	
	if invNum &gt; 0 then
		if self.myTerminal &lt;&gt; null and self.myBank &lt;&gt; null then
			if self.myDebtor &lt;&gt; null then
				self.myInvoice := self.myDebtor.allInvoices.getAtKey( self.myTerminal, self.myBank, invNum );
			elseif voyage &lt;&gt; null then
				self.myInvoice := voyage.allInvoices.getAtKey( self.myTerminal, self.myBank, invNum );
			endif;
		endif;
	endif;
	
	if self.myInvoice = null and self.myTerminal &lt;&gt; null and self.myDebtor &lt;&gt; null then
		self.myDebtorTerminal := self.myTerminal.allDebtorTerminals.getAtKey(self.myDebtor);
	endif;
	
	if self.myInvoice &lt;&gt; null then
		self.doSearch();
		
	// 34364 handle multiple terminals
	elseif not termSet.isEmpty then
		foreach obj in termSet do
			self.myTerminal := obj.CM_Terminal;
			if self.myInvoice = null and self.myTerminal &lt;&gt; null and self.myDebtor &lt;&gt; null then
				self.myDebtorTerminal := self.myTerminal.allDebtorTerminals.getAtKey(self.myDebtor);
			endif;
			self.doSearch;
		endforeach;
		
	endif;
	
epilog

	delete termSet;

end;</source>
        <Parameter name="_qDef" type="CM_QueryDefinition"/>
    </JadeMethod>
    <JadeMethod name="doSearch" id="2e8e3b55-a20f-4ce7-8766-bee5dde15a43">
        <updating/>
        <source>doSearch() updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 May 2014	cnwndl1	Initial creation	Par 34142
18 Jan 2019 cnwma1	Bug 42984: QNS - RE: Report - Revenues by Service Lines
*/

vars

	iter : Iterator;
	cashPayment : CM_CashPayment;
	breakOut : Boolean;
	passport : CM_Passport;
	startObject : Object;
	selectorCrLine : CM_SelectorCriteriaLine;
	qfromDate       : CM_QueryOperator;
	fromDate        : Date;
	toDate          : Date;
begin

	passport := app.myPassport;
	
	if self.myInvoice &lt;&gt; null then
		iter := self.myInvoice.allCashPayments.createIterator;
		while iter.next(cashPayment) do
			if self.includesObject(cashPayment, breakOut, passport) then
				self.addObjectToSet(cashPayment);
			endif;
			if breakOut	or self.breakOutOfSearch then
				break;
			endif;
		endwhile;
	
	elseif self.myDebtorTerminal &lt;&gt; null then
		iter := self.myDebtorTerminal.allCashPayments.createIterator;
		while iter.next(cashPayment) do
			if self.includesObject(cashPayment, breakOut, passport) then
				self.addObjectToSet(cashPayment);
			endif;
			if breakOut	or self.breakOutOfSearch then
				break;
			endif;
		endwhile;
				
	elseif self.myTerminal &lt;&gt; null then
		iter := self.myTerminal.allCashPayments.createIterator;
		
		//18.01.2019 cnwma1	Bug 42984
		fromDate := null;
		toDate   := null;
		if self.myCriteriaLineHolder.allCriteriaByPropertyName.isNotEmpty then	
			selectorCrLine:= self.myCriteriaLineHolder.allCriteriaByPropertyName[CM_CashPayment::getReceiptDate.name,CM_CashPayment.name];
			if selectorCrLine &lt;&gt; null then
				
				if selectorCrLine.myQueryOperator &lt;&gt; null then
					qfromDate := selectorCrLine.myQueryOperator;
					if qfromDate.isKindOf(CM_QDateRange) then
						if qfromDate.CM_QDateRange.fromDate.isValid then
							fromDate :=qfromDate.CM_QDateRange.fromDate;
							self.myTerminal.allCashPayments.startKeyGeq(fromDate.TimeStamp,iter);
						
						endif;
						if qfromDate.CM_QDateRange.toDate.isValid then
							toDate :=qfromDate.CM_QDateRange.toDate + 1;
						endif;
					endif;
				endif;
			endif;
		endif;
		
		
		while iter.next(cashPayment) do
			
			if toDate.isValid then               				//18.01.2019 cnwma1	Bug 42984
				if cashPayment.dateTime &gt; toDate.TimeStamp then
					break;
				endif;
			endif;
			
			if self.myBank &lt;&gt; null then
				if cashPayment.getBank &lt;&gt; self.myBank then
					continue;
				endif;
			endif;

			if self.includesObject(cashPayment, breakOut, passport) then
				self.addObjectToSet(cashPayment);
			endif;
			if breakOut	or self.breakOutOfSearch then
				break;
			endif;
		endwhile;
		
	endif;

epilog

	delete iter;

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="reset" id="f7b28d94-3b65-4b87-b941-680a672b85e5">
        <updating/>
        <source>reset() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 May 2014	cnwndl1	Initial creation	Par 34142

*/

vars

begin
	inheritMethod();
	
	self.myTerminal := null;
	self.myBank := null;
	self.myDebtor := null;
	self.myDebtorTerminal := null;
	self.myInvoice := null;

epilog

end;</source>
    </JadeMethod>
