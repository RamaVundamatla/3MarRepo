    <JadeMethod name="initializeTest" id="a080110a-b272-4642-936a-2d2e19243e37">
        <updating/>
        <source>initializeTest(_test: Method) updating, protected;
//11 November 2008	cnwdw1	
//
// 13 June 2016	cnwns1	TFS 488 - Multi Timezone Support
// 10 Oct 2017	cnwma1  TFS #7257 JMT - Refactoring - Commodity Planning
vars
	logger: CMIF_Logger;
begin
	self.testStartTime := app.actualTimeServer();// 13 June 2016	cnwns1	TFS 488 - Multi Timezone Support

	//epr if I don't initializze this here if the Unit Test creates the app.myYAAgent then
	// it always fails because the transient leak checker 
	// app.myYAAgent is deleted in the app.finalize
//	app.initialiseForStartAutoPlan(app.myPassport);
	
	self.ignoreTrxWarnings(false);
	//app.myPassport.setWarningsIgnored(false);
	app.myPassport.warningsAcknowledged := true;
	app.addStackToErrorObjForJadeEx  := true;		// get stack dump for errors
	create logger transient;
	app.setLogger(logger);
	
	self.assertException := false;
	self.exceptionFailure := false;
	self.exceptionCode := 0;
	self.exceptionMethodName := "";
	self.exceptionMethodPosition := 0;
	self.exceptionMessage := null;
	self.clearExpectedTrxErrors();
	app.myProxyManager.clearAllProxies();
	receivedNotes.clear();
	self.setActiveProfile;
	opts.purge();
	
	/*
	if self.checkForLeaks then							// 04/07/2013 cnwmh5
		create self.leakChecker transient;
		if self.logResult then
			self.leakChecker.findSource := true;
		endif;
	endif;
	*/
	
	self.currentMethodBeingRun := _test;				// 11/12/2014 cnwmh5
	
end;</source>
        <access>protected</access>
        <Parameter name="_test" type="Method"/>
    </JadeMethod>
