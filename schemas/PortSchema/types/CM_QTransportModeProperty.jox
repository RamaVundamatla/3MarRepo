    <JadeMethod name="setComboValues" id="bf03377c-36e5-4145-8f0a-116e3a29ea9f">
        <source>setComboValues(_combo : ComboBox input; _params : CM_QueryCriteriaLineHolder; _queryOperator : CM_QueryOperator; _passport : CM_Passport);
// ---------------------------------------------------------------------------
// Created:     06 March 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
vars

begin
	_combo.clear();
	
	_combo.addItem(app.transModeToString(TI_TRANSMODE_SHIP));
	_combo.addItem(app.transModeToString(TI_TRANSMODE_ROAD));
	_combo.addItem(app.transModeToString(TI_TRANSMODE_RAIL));
	
	if CM_QIntegerLookupEqual.hasInstance(_queryOperator) then
		_combo.text := app.transModeToString(_queryOperator.CM_QIntegerLookupEqual.searchValue);
	elseif CM_QIntegerLookupNotEqual.hasInstance(_queryOperator) then
		_combo.text := app.transModeToString(_queryOperator.CM_QIntegerLookupNotEqual.searchValue);
	endif;

end;</source>
        <Parameter name="_combo" type="ComboBox" usage="input"/>
        <Parameter name="_params" type="CM_QueryCriteriaLineHolder"/>
        <Parameter name="_queryOperator" type="CM_QueryOperator"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="setListValues" id="21ea4f1e-0b49-4a5a-a2fe-bc0c3a0274da">
        <source>setListValues(_tbl : Table input; _params : CM_QueryCriteriaLineHolder; _operator : CM_QIntegerIsOneOf; _passport : CM_Passport);
// ---------------------------------------------------------------------------
// Created:     06 March 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
vars
	intArray	: IntegerArray;
	idx,intSite	: Integer;
	strObj		: CM_String;
begin

	_tbl.purgeTableObjects();
	_tbl.clear;
	_tbl.rows := _tbl.fixedRows;
	
	create intArray transient;
	
	intArray.add(TI_TRANSMODE_SHIP);
	intArray.add(TI_TRANSMODE_ROAD);
	intArray.add(TI_TRANSMODE_RAIL);

	self.setListTableFromIntConstants(_tbl, _operator, intArray, TI_TRANSMODE_Constant);	

epilog
	delete intArray;
end;

/*	vars
