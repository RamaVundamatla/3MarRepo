<Class name="CM_EDIFileTypeX12EDI3154010" id="fe9168c5-dc0a-4980-aad5-2975cddc7be6">
    <superclass name="CM_EDIFileTypeX12EDI315"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="edi"/>
    <JadeMethod name="checkPartyB403" id="8d61cb25-8212-487e-a262-e3b733d7ea72">
        <source>checkPartyB403( _operatorCode : String; _b303Text : String; _stopCode : String io; _stopAction : String io; _isImport : Boolean io) : Boolean;

/*

Purpose:			

Parameters:		
return stopcode (string but number)
action A/D?	

Return Value:		


Date		Who		Reason
12 May 2015	cnwrd1	Initial creation
26 Feb 2024	jlirs1	TFS 57192 - 57193, 62335 Pen Support Import Voyage Translation
*/

vars
	stopsProcessing : Boolean;
	senderParty			: CM_EDIParty;
	senderPartyRules 	: CM_EDIPartyRules;	
	anEDIRule 			: CM_EDIRule;
	a315Rule			: CM_EDI315Rule;
	terminal 			: CM_Terminal;
	aStopsTable			: CM_StopsTable;
	stopID 				: String;
	stopAction 			: String;
begin
	terminal 		:= app.myPassport.myTerminal;
	
	if _operatorCode &lt;&gt; null and terminal &lt;&gt; null then
        senderParty := terminal.allEDIPartiesBySenderCode[_operatorCode];

		if senderParty &lt;&gt; null then
			senderPartyRules 	:= self.getEDIPartyRules (senderParty);
		endif;
		
		
		if senderPartyRules &lt;&gt; null and senderPartyRules.isKindOf(CM_EDIPartyX12315Rules) then  
			_isImport := senderPartyRules.CM_EDIPartyX12315Rules.isImport;		//26 Feb 2024	jlirs1	TFS 57192 - 57193, 62335 Pen Support Import Voyage Translation
			foreach anEDIRule in senderPartyRules.allEDIPartyRules do
				if not anEDIRule.isKindOf(CM_EDI315Rule) then
					continue;
				endif;
				
				a315Rule := anEDIRule.CM_EDI315Rule;
				
				//check its for B403
				if a315Rule.item &lt;&gt; CM_EDI315Rule.Item_B403 then
					continue;
				endif;
				
				//check if we are matching the B403 value
				if a315Rule.value &lt;&gt;  _b303Text then
					continue;
				endif;
				
				//ok what are we meant to do
				
				if a315Rule.function = CM_EDI315Rule.Function_B403_StopAdd then
					//add one
					stopAction := CM_EDITrackedItem.EDI_ACTION_ADD;
				elseif a315Rule.function =CM_EDI315Rule.Function_B403_StopRemove then
					//remove one
					stopAction := CM_EDITrackedItem.EDI_ACTION_DELETE;
				else
					stopAction := '';
				endif;
				
				//which stop				
				aStopsTable := self.getStopsTableFromHeading( a315Rule.stopTable);
				
				if aStopsTable &lt;&gt; null then
					stopsProcessing :=	true;
					stopID := aStopsTable.id.String;
					break;
				endif;
			endforeach;
		endif;
				
	endif;

	if stopsProcessing then
		_stopCode := stopID;
		_stopAction := stopAction;
	endif;
	return stopsProcessing;
epilog

end;</source>
        <Parameter name="_operatorCode" type="String"/>
        <Parameter name="_b303Text" type="String"/>
        <Parameter name="_stopCode" type="String" usage="io"/>
        <Parameter name="_stopAction" type="String" usage="io"/>
        <Parameter name="_isImport" type="Boolean" usage="io"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="checkPartyN903" id="2d7fa869-f97a-40bf-ba24-54ef6d9c126c">
        <source>checkPartyN903(_operatorCode :String; _n903Text :String) :Boolean;
/*

Purpose:			

Parameters:		
returns if we need to create a release request for a carrier


Date		Who		Reason
22 May 2018	jlggb1	Initial creation

*/

vars
	releaseProcessing 	:Boolean;
	senderParty			:CM_EDIParty;
	senderPartyRules 	:CM_EDIPartyRules;	
	anEDIRule 			:CM_EDIRule;
	a315Rule			:CM_EDI315Rule;
	terminal 			:CM_Terminal;

begin
	terminal:= app.myPassport.myTerminal;
	if terminal &lt;&gt; null then
        senderParty := terminal.allEDIPartiesBySenderCode[_operatorCode];
		if senderParty &lt;&gt; null then
			senderPartyRules 	:= self.getEDIPartyRules (senderParty);
		endif;
		if senderPartyRules &lt;&gt; null and senderPartyRules.isKindOf(CM_EDIPartyX12315Rules) then  
			foreach anEDIRule in senderPartyRules.allEDIPartyRules do
				if not anEDIRule.isKindOf(CM_EDI315Rule) then
					continue;
				endif;
				a315Rule := anEDIRule.CM_EDI315Rule;
				
				//check it's for N903
				if a315Rule.item &lt;&gt; CM_EDI315Rule.Item_N903 then
					continue;
				endif;
				
				//check if the N903 value is valid. Should check the SCAC list when it's available?
				if _n903Text &lt;&gt; null then
					releaseProcessing := true;
					break;
				endif;

			endforeach;
		endif;
	endif;
	return releaseProcessing;
end;</source>
        <Parameter name="_operatorCode" type="String"/>
        <Parameter name="_n903Text" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="create" id="e44c7b0b-75e5-4c3c-92ce-5fb164403c73">
        <updating/>
        <source>create() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 September 2013	cnwgb1	Initial creation

*/
begin
	self.name := "X12 315 - Status Details";
	self.type := EDIFileTypeX12_315_4010;
end;</source>
    </JadeMethod>
    <JadeMethod name="findEDIDataType" id="162249b3-1e11-4aec-917a-2f9605513503">
        <source>findEDIDataType(_ediDataClass: Class io; _dataType, _fileTypeCode: Integer io); // cnwrs1 Par 24207 ccms 1117 11 May 2010
//----------------------------------------------------------------------
//
//  Created by cnwsh3
//
//	Date 17 October 2007
//
//----------------------------------------------------------------------

vars

begin
	_ediDataClass 	:= CM_EDIDataBOL;
	_dataType 			:= EDIDataType_BOL;
    _fileTypeCode := self.type;

end;</source>
        <Parameter name="_ediDataClass" type="Class" usage="io"/>
        <Parameter name="_dataType" type="Integer" usage="io"/>
        <Parameter name="_fileTypeCode" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="getCreateBOLs" id="510f5427-0911-46f7-9cc7-274f0afa5b4a">
        <source>getCreateBOLs( _operatorCode : String) : Boolean;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
18 February 2014	cnwrd1	Initial creation

*/

vars
	createBOLs : Boolean;
	senderParty			: CM_EDIParty;
	senderPartyRules 	: CM_EDIPartyRules;	
	terminal 			: CM_Terminal;
begin
	terminal 		:= app.myPassport.myTerminal;
	
	if _operatorCode &lt;&gt; null and terminal &lt;&gt; null then
        senderParty := terminal.allEDIPartiesBySenderCode[_operatorCode];

		if senderParty &lt;&gt; null then
			senderPartyRules 	:= self.getEDIPartyRules (senderParty);
		endif;
		
		
		if senderPartyRules &lt;&gt; null and senderPartyRules.isKindOf(CM_EDIPartyX12315Rules) then  
			createBOLs := senderPartyRules.CM_EDIPartyX12315Rules.createBOLs;			
		endif;
				
	endif;

	return createBOLs;
epilog

end;</source>
        <Parameter name="_operatorCode" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getEDIPartyRules" id="0ebc48b4-5548-4a3d-b37f-19f6bc9aa49d">
        <source>getEDIPartyRules(_ediParty: CM_EDIParty): CM_EDIPartyRules protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
18 February 2014	cnwrd1	Initial creation

*/

vars

begin
	if _ediParty = null then
		return null;
	endif;
	
	return _ediParty.getRulesForFileType (EDIFileTypeX12_315_4010);

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_ediParty" type="CM_EDIParty"/>
        <ReturnType type="CM_EDIPartyRules"/>
    </JadeMethod>
    <JadeMethod name="processFile" id="0ea85eb8-b8fb-4fa2-a96c-f71e8b39f6f6">
        <updating/>
        <source>processFile(_ediFile: CM_EDIFile input) updating, protected;
/*

Purpose: Process an ASC X12 315 File (CCMS JMT 2317 Seafreight EDI)
		 A 315 file may provoke various actions inside JMT.
		 The default action is to update a tracked item with a BOL#
		 If there is an EDI Party setting createBOL checked, then create the BOL as well if it isn't already.
		 If the B403 rule is invoked then do not update any BOLS, Create a Stop action relating to the B403 field
		 If the N903 rule is invoked when N901=EQ (There is a SCAC code) then create a release request for that carrier

Parameters:			

Return Value:		

Date		Who		Reason
06 November 2013	cnwgb1	Initial creation
//12 Jan 2015	cnwrs1	Par 35504 - Refactor EDI file load for .NET
16/04/2015		cnwrd1	par 36063 - refactor for multiple releases in seaboard 315's
//10 Sep 2015	cnwrs1	Par 32883 - EDI File Type sequence number
*/
//08 Oct 2015	cnwrs1	Par 36863 - make EDI consistant times when refreshing progress bar
// 04 Aug 2016	cnwrs1	Par 38117 make deleted EDI for finable
// 08 May 2018	jlgrs1	TFS 36425 SingleLine Booking partial processing not working
// 22  May 2018 jlggb1	TFS 36933 Crowley Release Requests
// 18 Jan 2019	jlgrs1	TFS 41659 42276 STWR Make EDI MultiThreaded Stage 8
// 08 Apr 2019	jlgrs1	TFS 41913 STWR - Reconfiguration of the EDI Operation form to better handle EDI collection locks while loading 
// 26 Feb 2024	jlirs1	TFS 57192 - 57193, 62335 Pen Support Import Voyage Translation
// 16 Apr 2024  jlier1	TFS 63254 POE | EDI 315 Status Details - remove special characters in Cargo ID
// 03 Apr 2025	navdap1	MTN-14781 CPL | Increase BOL Field Length
constants
	ProgressBarRefresh	: Integer = 2000;	
vars
	msgHelper			: CMIF_EDIX12Helper;
	ediDataBOL			: CM_EDIDataBOL;
	ediDataBOLHdr		: CM_EDIBOLHdrTI;
	ediDataBOLDtl		: CM_EDIBOLDtlTI;
	ediDataCargoFieldUpdate 	: CM_EDIDataCargoFieldUpdate;
	ediDataCargoFieldUpdateTi	: CM_EDICargoFieldUpdateTI;
	ediDataCargoRelease : CM_EDIDataReleaseRequest;
	ediDataCargoReleaseTi		: CM_EDIReleaseRequestTI;
	ediDataCargoStop 	: CM_EDIDataStop;
	ediDataCargoStopTi	: CM_EDIStopTI;		
	anEDIData 			: CM_EDIData;
	passport			: CM_Passport;
	operatorOid			: CM_Operator;	
	aPort 				: CM_Port;
	operatorCode		: String;
	untCount			: Integer;
	numMsgs				: Integer;
	msgCount			: Integer;
	lineStr				: String;
	fileID				: String;
	message				: String;
	currentTag			: String;
	callSign			: String;
    fieldStr            : String;
    r4Loop              : Integer;
	lloydsNumber		: String;
	vesselCode 			: String;
	voyageCode			: String;
	bolNumber			: String;
	cargoID				: String;
	loadPort 			: String;
	dischPort			: String;	
	destPort			: String;		
	portCodeString		: String;
	portDescString		: String;	
	shipStatusCode		: String;
	foundMatch			: Boolean;
	createBOLs			: Boolean;
	bookingNumber		: String;
	tirNumber			: String;
	shipperID			: String;
	agentsRefNo			: String;
	contIDpt1,
	contIDpt2,
	contIDpt3			: String;
	isoTypeRaw			: String;
	isoType 			: String;
	ediType	 			: Integer;
	ediFileType 		: CM_EDIFileType;
	theLines 			: HugeStringArray;
	releaseInitialised 	: Boolean;
	releaseProcessing   : Boolean;
	stopsInitialised 	: Boolean;
	stopsProcessing		: Boolean;
	stopCode			: String;
	stopAction			: String;
	equipDescription	: String;
	date 				: Date;
	time 				: Time;
	str 				: String;
	creationTS 			: TimeStamp;
	sequence 			: String;
	sender 				: String;
	recipient 			: String;
	sequenceNumber 		: Integer;
	progressInt			: TimeStampInterval;
	progressTS 			: TimeStamp;
	isImport : Boolean;
begin
	progressTS := app.actualTimeServer();// 13 May 2016	cnwns1	TFS 488 - Multi Timezone Support
		
	passport := app.myPassport;
	fileID := _ediFile.fileName.getFileName();       
	
	create msgHelper transient;
	msgHelper.setEDIFile(_ediFile);
	
	create theLines transient;
	self.rawDataToHSA(_ediFile, theLines);
	numMsgs	:= theLines.size;
	foreach lineStr in theLines do
		msgCount	:=	msgCount + 1;
		
		progressInt := app.actualTimeServer() - progressTS;// 13 May 2016	cnwns1	TFS 488 - Multi Timezone Support
		if passport.myCMIFMonitor &lt;&gt; null  and (progressInt.getMilliseconds &gt;= ProgressBarRefresh) then
			passport.myCMIFMonitor.updateProgressWithCaption("Processing File Data", numMsgs, msgCount, "Loading EDI file Step 3 of 3.");
			progressTS := app.actualTimeServer();// 13 May 2016	cnwns1	TFS 488 - Multi Timezone Support
		endif;
		msgHelper.setNextMessage(lineStr);	//set the current message
		message := msgHelper.currentMessage;
		currentTag := msgHelper.currentTag;

		if currentTag = "ISA" then
			untCount := untCount + 1;
			// pull this apart here and get the operator
			msgHelper.setNextField();  // ISA01 
			msgHelper.setNextField();  // ISA02
			msgHelper.setNextField();  // ISA03
			msgHelper.setNextField();  // ISA04
			msgHelper.setNextField();  // ISA05
			msgHelper.setNextField();  // ISA06  Operator/supplier
			operatorCode := app.myRoot.getXlationSystemOperatorCode(operatorOid, msgHelper.currentSubItem.trimBlankCharacters, foundMatch);
			
			if operatorCode &lt;&gt; null then
				operatorOid := app.myRoot.allOperators[operatorCode];
			endif;
					
			createBOLs := self.getCreateBOLs(operatorCode);
			sender := msgHelper.currentSubItem;
			
			msgHelper.setNextField();  // ISA07
			msgHelper.setNextField();  // ISA08
			recipient := msgHelper.currentSubItem;
			msgHelper.setNextField();  // ISA09
			str := msgHelper.currentSubItem;
			date.setDate(str[5:2].Integer, str[3:2].Integer, str[1:2].Integer); 
			msgHelper.setNextField();  // ISA10
			str := msgHelper.currentSubItem;
			time.setTime(str[1:2].Integer, str[3:2].Integer, 0, 0);
			creationTS.setDate(date);
			creationTS.setTime(time);
			msgHelper.setNextField();  // ISA11
			msgHelper.setNextField();  // ISA12
			msgHelper.setNextField();  // ISA13
			sequence := msgHelper.currentSubItem;
			sequenceNumber := sequence.Integer; // Interchange Control Number
			msgHelper.setNextField();  // ISA14
			if _ediFile.ediData.status &lt;&gt; CM_EDIFile.EDI_STATUS_OUTOFSEQUENCE and
			   not self.processSenderRecipientSeq(sender, recipient, "X12-315", "", _ediFile.ediData.fileName, creationTS, sequence, _ediFile.ediData, passport.myTerminal) then
				_ediFile.ediData.status := CM_EDIFile.EDI_STATUS_OUTOFSEQUENCE;
			endif;
			
		elseif currentTag = "GS" then
		elseif currentTag = "ST" then  // Transaction Set Header 
			msgHelper.setNextField();  // ST01 Transaction Set Identier Code
			fieldStr := msgHelper.currentSubItem;
            if fieldStr &lt;&gt; "315" then
                //Exception
            endif;
			msgHelper.setNextField();  // ST02 Transaction Set Control Number
		elseif currentTag = "B4" then  // Beginning Segment for Inquiry or Reply
			msgHelper.setNextField();  // B401 Special Handling Code
			msgHelper.setNextField();  // B402 Inquiry Request Number
			msgHelper.setNextField();  // B403 Shipment Status Code
			shipStatusCode := msgHelper.currentSubItem;
			msgHelper.setNextField();  // B404 Date
			msgHelper.setNextField();  // B405 Status Time
			msgHelper.setNextField();  // B406 Status Location
			msgHelper.setNextField();  // B407 Equipment Initial
			contIDpt1  := msgHelper.currentSubItem; 
			msgHelper.setNextField();  // B408 Equipment Number
			contIDpt2  := msgHelper.currentSubItem; 
			msgHelper.setNextField();  // B409 Equipment Status Code
			msgHelper.setNextField();  // B410 Equipment Type
			isoTypeRaw := msgHelper.currentSubItem;
			msgHelper.setNextField();  // B411 Location Identifiew
			msgHelper.setNextField();  // B412 Location Qualifier
			msgHelper.setNextField();  // B413 Equipment Number Check Digit
			contIDpt3  := msgHelper.currentSubItem; 
			
			cargoID := contIDpt1 &amp; contIDpt2 &amp; contIDpt3;
			if operatorOid &lt;&gt; null then
				isoType := operatorOid.getXlationSystemCode(isoTypeRaw, XLATION_TYPE_ISOTYPE_BYOP, foundMatch)[1:5]; //22 May 2018 jlggb1 TFS 36933
			else
				isoType := isoTypeRaw.trimBlanks[1:4];
			endif;

			
			stopsProcessing := self.checkPartyB403(operatorCode, shipStatusCode, stopCode, stopAction, isImport);		//26 Feb 2024	jlirs1	TFS 57192 - 57193, 62335 Pen Support Import Voyage Translation
			
			if stopsProcessing and not stopsInitialised then			
			
			
				if _ediFile.ediData &lt;&gt; null  then				
					if _ediFile.ediData.isKindOf(CM_EDIDataStop) then
						ediDataCargoStop := _ediFile.ediData.CM_EDIDataStop;
					else
						anEDIData := _ediFile.ediData; 						
					endif;
				endif;
		
				if ediDataCargoStop = null then
					_ediFile.ediData := null;
					ediType := EDIDataType_Stop;
					if _ediFile.ediData = null then
						app.myUtilityCA.utlCreateEDIData(_ediFile.ediData, CM_EDIDataStop, ediType, EDIFileTypeX12_315_4010, _ediFile.ediConfig, _ediFile, ediFileType, app.myPassport);
						_ediFile.ediData.setStatus(CM_EDIFile.EDI_STATUS_LOADED);
					endif;			
					ediDataCargoStop := _ediFile.ediData.CM_EDIDataStop;
					
					if anEDIData &lt;&gt; null then					
						delete anEDIData;
					endif;
				endif;
				stopsInitialised := true;
			endif;

		
		elseif currentTag = "N9" then  // Reference Identification  *** up to 30 of these
			msgHelper.setNextField();  // N901 Reference Identification Qualifier
			if msgHelper.currentSubItem = 'BM' then
				msgHelper.setNextField();  // N902 Reference Identification
				bolNumber :=  msgHelper.currentSubItem;
				msgHelper.setNextField();  // N903 Free Form Description
				msgHelper.setNextField();  // N904 Date
				msgHelper.setNextField();  // N905 Time
				msgHelper.setNextField();  // N906 Time Code
				msgHelper.setNextField();  // N907 Reference Identifier
			elseif msgHelper.currentSubItem = 'BN' then
				msgHelper.setNextField();  // N902 Reference Identification
				bookingNumber :=  msgHelper.currentSubItem;
				msgHelper.setNextField();  // N903 Free Form Description
				msgHelper.setNextField();  // N904 Date
				msgHelper.setNextField();  // N905 Time
				msgHelper.setNextField();  // N906 Time Code
				msgHelper.setNextField();  // N907 Reference Identifier			
			elseif msgHelper.currentSubItem = 'SI' then
				msgHelper.setNextField();  // N902 Reference Identification
				shipperID :=  msgHelper.currentSubItem;
				msgHelper.setNextField();  // N903 Free Form Description
				msgHelper.setNextField();  // N904 Date
				msgHelper.setNextField();  // N905 Time
				msgHelper.setNextField();  // N906 Time Code
				msgHelper.setNextField();  // N907 Reference Identifier			
			elseif msgHelper.currentSubItem = 'TI' then  // **** should it be TI?
				msgHelper.setNextField();  // N902 Reference Identification
				tirNumber :=  msgHelper.currentSubItem;
				msgHelper.setNextField();  // N903 Free Form Description
				msgHelper.setNextField();  // N904 Date
				msgHelper.setNextField();  // N905 Time
				msgHelper.setNextField();  // N906 Time Code
				msgHelper.setNextField();  // N907 Reference Identifier		
			elseif msgHelper.currentSubItem = 'FN' then 
				msgHelper.setNextField();  // N902 Reference Identification
				agentsRefNo :=  msgHelper.currentSubItem;
				msgHelper.setNextField();  // N903 Free Form Description
				msgHelper.setNextField();  // N904 Date
				msgHelper.setNextField();  // N905 Time
				msgHelper.setNextField();  // N906 Time Code
				msgHelper.setNextField();  // N907 Reference Identifier						
			elseif msgHelper.currentSubItem = 'EQ' then 
				msgHelper.setNextField();  // N902 Reference Identification
				//jlier1 TFS 63254 16/4/24 - for POE the cargoID is correct in the B4 segment but the N9 EQ has spaces so if the cargoID here has invalidChars then use the one from B4
				if cargoID = null or not msgHelper.currentSubItem.hasInvalidChars then
					cargoID :=  msgHelper.currentSubItem;
				endif;
				msgHelper.setNextField();  // N903 Free Form Description
				equipDescription := msgHelper.currentSubItem;
				msgHelper.setNextField();  // N904 Date
				msgHelper.setNextField();  // N905 Time
				msgHelper.setNextField();  // N906 Time Code
				msgHelper.setNextField();  // N907 Reference Identifier	
				
				releaseProcessing := self.checkPartyN903(operatorCode, equipDescription);
			
			endif;
			

		elseif currentTag = "Q2" then  // Status Details (Ocean)
			msgHelper.setNextField();  // Q201 Vessel Code
			vesselCode := msgHelper.currentSubItem;
			msgHelper.setNextField();  // Q202 Country Code
			msgHelper.setNextField();  // Q203 Date (Pier Date)
			msgHelper.setNextField();  // Q204 Date (Departure)
			msgHelper.setNextField();  // Q205 Date (Unload)
			msgHelper.setNextField();  // Q206 Lading Quality
			msgHelper.setNextField();  // Q207 Weight
			msgHelper.setNextField();  // Q208 Weight Qualifier
			msgHelper.setNextField();  // Q209 Flight/Voyage Number
			voyageCode := msgHelper.currentSubItem;
			

			
			msgHelper.setNextField();  // Q210 Reference Identifiction Qualifier
			msgHelper.setNextField();  // Q211 Reference Identification 
			msgHelper.setNextField();  // Q212 Vessel Code Qualifier
			msgHelper.setNextField();  // Q213 Vessel Name
			lloydsNumber := msgHelper.currentSubItem;
			msgHelper.setNextField();  // Q214 Volume
			msgHelper.setNextField();  // Q215 Volume Unit Qualifier
			msgHelper.setNextField();  // Q216 Weight Unit Code
			
			if operatorOid &lt;&gt; null then
				voyageCode := operatorOid.getXlationSystemCode_VoyageEx(voyageCode, vesselCode, lloydsNumber, callSign, 0, foundMatch, isImport);		//26 Feb 2024	jlirs1	TFS 57192 - 57193, 62335 Pen Support Import Voyage Translation
			else
				if voyageCode = null then
					voyageCode := msgHelper.currentSubItem.trimBlanks[1:30];
				endif;
			endif;			
		elseif currentTag = "R4" then  // Port or Terminal
            r4Loop := r4Loop +1;
            msgHelper.setNextField();  // R401 Port or Terminal Function Code
			
			if msgHelper.currentSubItem = "D" then
				msgHelper.setNextField();  // R402 Location Qualifier
				msgHelper.setNextField();  // R403 Location Identifier
				portCodeString := msgHelper.currentSubItem;
				
				msgHelper.setNextField();  // R404 Port Name
				portDescString := msgHelper.currentSubItem;
				
				if portCodeString.cnEcIsNumeric then
					//need to check the K or D schedule port code here.
					aPort := app.myRoot.lookupScheduleDKPortCode(portCodeString, portDescString);
					
					if aPort &lt;&gt; null then
						dischPort := aPort.code;
					else
						if operatorOid &lt;&gt; null then
							dischPort := operatorOid.getXlationSystemCode(portCodeString, XLATION_TYPE_PORT_BYOP, foundMatch)[1:5];
						else
							dischPort := portCodeString.trimBlanks[1:5];
						endif;
					endif;
				else				
					if operatorOid &lt;&gt; null then
						dischPort := operatorOid.getXlationSystemCode(portCodeString, XLATION_TYPE_PORT_BYOP, foundMatch)[1:5];
					else
						dischPort := portCodeString.trimBlanks[1:5];
					endif;
				endif;
				
				
				
			elseif msgHelper.currentSubItem = "L" then
				msgHelper.setNextField();  // R402 Location Qualifier
				msgHelper.setNextField();  // R403 Location Identifier
				portCodeString := msgHelper.currentSubItem;
				
				msgHelper.setNextField();  // R404 Port Name
				portDescString := msgHelper.currentSubItem;
				
				if portCodeString.cnEcIsNumeric then
					//need to check the K or D schedule port code here.
					aPort := app.myRoot.lookupScheduleDKPortCode(portCodeString, portDescString);
					
					if aPort &lt;&gt; null then
						loadPort := aPort.code;
					else
						if operatorOid &lt;&gt; null then
							loadPort := operatorOid.getXlationSystemCode(portCodeString, XLATION_TYPE_PORT_BYOP, foundMatch)[1:5];
						else
							loadPort := portCodeString.trimBlanks[1:5];
						endif;
					endif;
				else				
					if operatorOid &lt;&gt; null then
						loadPort := operatorOid.getXlationSystemCode(portCodeString, XLATION_TYPE_PORT_BYOP, foundMatch)[1:5];
					else
						loadPort := portCodeString.trimBlanks[1:5];
					endif;
				endif;		
			elseif msgHelper.currentSubItem = "E" then
				msgHelper.setNextField();  // R402 Location Qualifier
				msgHelper.setNextField();  // R403 Location Identifier
				portCodeString := msgHelper.currentSubItem;
				
				msgHelper.setNextField();  // R404 Port Name
				portDescString := msgHelper.currentSubItem;
				
				if portCodeString.cnEcIsNumeric then
					//need to check the K or D schedule port code here.
					aPort := app.myRoot.lookupScheduleDKPortCode(portCodeString, portDescString);
					
					if aPort &lt;&gt; null then
						destPort := aPort.code;
					else
						if operatorOid &lt;&gt; null then
							destPort := operatorOid.getXlationSystemCode(portCodeString, XLATION_TYPE_PORT_BYOP, foundMatch)[1:5];
						else
							destPort := portCodeString.trimBlanks[1:5];
						endif;
					endif;
				else				
					if operatorOid &lt;&gt; null then
						destPort := operatorOid.getXlationSystemCode(portCodeString, XLATION_TYPE_PORT_BYOP, foundMatch)[1:5];
					else
						destPort := portCodeString.trimBlanks[1:5];
					endif;
				endif;						
			else
			    msgHelper.setNextField();  // R402 Location Qualifier
				msgHelper.setNextField();  // R403 Location Identifier
				msgHelper.setNextField();  // R404 Port Name
				msgHelper.setNextField();  // R405 Country Code
				msgHelper.setNextField();  // R406 Terminal Name
				msgHelper.setNextField();  // R407 Pier Number
				msgHelper.setNextField();  // R408 State or Province Code
			endif;
			

        elseif currentTag = "DTM" then // Date/Time Reference
            msgHelper.setNextField();  // DTM01 Date/Time Qualifier
            msgHelper.setNextField();  // DTM02 Date
            msgHelper.setNextField();  // DTM03 Time
            msgHelper.setNextField();  // DTM04 Time Code
            msgHelper.setNextField();  // DTM05 Date Time Format Qualifier
            msgHelper.setNextField();  // DTM06 Date Time Period
		elseif currentTag = "SE" then  // Transaction Set Trailer
			msgHelper.setNextField();  // SE01 Number of Included Segments
			fieldStr := msgHelper.currentSubItem;
            if msgCount &lt;&gt; fieldStr.Integer-2 then
                // Exception
            endif;
			msgHelper.setNextField();  // SE02 Transaction Set Control Number
			
			
			if stopsProcessing then
				create ediDataCargoStopTi;
				ediDataCargoStopTi.setMyEDIData(_ediFile.ediData);
				ediDataCargoStopTi.setId(cargoID);
				ediDataCargoStopTi.setVoyageCode(voyageCode);
				ediDataCargoStopTi.setStopAction(stopAction);
				ediDataCargoStopTi.setStopCode(stopCode);
				ediDataCargoStopTi.setCargoType(TI_CargoType_Container);
			endif;
			
			if releaseProcessing then //TFS 36933 jlggb1 22 ay 2018
				if not releaseInitialised then
					//_ediFile.ediData := null;
					ediType := EDIDataType_ReleaseRequest;
					app.myUtilityCA.utlCreateEDIData(anEDIData, CM_EDIDataReleaseRequest, ediType, EDIFileTypeX12_315_4010, _ediFile.ediConfig, _ediFile, ediFileType, app.myPassport);
					ediDataCargoRelease := anEDIData.CM_EDIDataReleaseRequest;
					anEDIData.setStatus(CM_EDIFile.EDI_STATUS_LOADED);
					releaseInitialised := true;
				endif;
				create ediDataCargoReleaseTi;
				ediDataCargoReleaseTi.setId(cargoID);
				ediDataCargoReleaseTi.setVoyageCode(voyageCode);
				
				ediDataCargoReleaseTi.cargoTypeDescr := "ISO Container";
				ediDataCargoReleaseTi.isoType := isoType;
				
				ediDataCargoReleaseTi.releaseType :=  BR_TYPE_ROAD;		
				ediDataCargoReleaseTi.releaseTypeStr	:= app.releaseRequestTypeEnumToString(ediDataCargoReleaseTi.releaseType);
				ediDataCargoReleaseTi.statusBulkRelease := BR_ACTIVE_STRING;
				ediDataCargoReleaseTi.operatorCode := operatorCode;
				ediDataCargoReleaseTi.carrierCode := equipDescription;
				
				if bookingNumber &lt;&gt; null then
					ediDataCargoReleaseTi.releaseRequestNumber := bookingNumber;
				elseif bolNumber &lt;&gt; null then
					ediDataCargoReleaseTi.releaseRequestNumber := bolNumber[1:30];			// MTN 14781
				else
					ediDataCargoReleaseTi.releaseRequestNumber := cargoID; //Guess jlggb1
				endif;
				ediDataCargoReleaseTi.setMyEDIData(ediDataCargoRelease);
				releaseProcessing := false;
			endif;
		
		
		elseif currentTag = "GE" then 
		elseif currentTag = "IEA" then 
		endif;

	endforeach;
	

	if stopsProcessing then
		// Everything is done if we've hit a rule that does anything other than update BOLs
	elseif createBOLs then //Actually create a BOL object
				
		if _ediFile.ediData &lt;&gt; null  then				
			if _ediFile.ediData.isKindOf(CM_EDIDataBOL) then
				ediDataBOL := _ediFile.ediData.CM_EDIDataBOL;
				else
				anEDIData := _ediFile.ediData; 						
			endif;
		endif;
				
		if ediDataBOL = null then
			_ediFile.ediData := null;
			ediType := EDIDataType_BOL;
			if _ediFile.ediData = null then
				app.myUtilityCA.utlCreateEDIData(_ediFile.ediData, CM_EDIDataBOL, ediType, EDIFileTypeX12_315_4010, _ediFile.ediConfig, _ediFile, ediFileType, app.myPassport);
				_ediFile.ediData.setStatus(CM_EDIFile.EDI_STATUS_LOADED);
			endif;			
			ediDataBOL := _ediFile.ediData.CM_EDIDataBOL;
			
			if anEDIData &lt;&gt; null then					
				delete anEDIData;
			endif;
		endif;
				
		
		_ediFile.ediData := ediDataBOL;
		create ediDataBOLHdr persistent;
		ediDataBOLHdr.setMyEDIData(ediDataBOL);
		ediDataBOLHdr.setId(bolNumber);
		ediDataBOLHdr.dischargePort := dischPort;
		ediDataBOLHdr.destinationPort := destPort;
		ediDataBOLHdr.loadPort := loadPort;
		ediDataBOLHdr.setOperator(operatorOid);
		ediDataBOLHdr.operatorCode := operatorCode;
		ediDataBOLHdr.setVoyageCode(voyageCode);
		
				
		create ediDataBOLDtl persistent;
		ediDataBOLDtl.setMyEDIData(ediDataBOL);
		ediDataBOLDtl.setVoyageCode(voyageCode);
		ediDataBOLDtl.setOperator(operatorOid);		
		ediDataBOLDtl.myParent :=ediDataBOLHdr;
		ediDataBOLDtl.setId(cargoID);
		
	else //Just Update the BOL number on the cargo
	
		if _ediFile.ediData &lt;&gt; null  then				
			if _ediFile.ediData.isKindOf(CM_EDIDataCargoFieldUpdate) then
				ediDataCargoFieldUpdate := _ediFile.ediData.CM_EDIDataCargoFieldUpdate;
				else
				anEDIData := _ediFile.ediData; 						
			endif;
		endif;
						
		if ediDataCargoFieldUpdate = null then
			_ediFile.ediData := null;
			ediType := EDIDataType_CargoFieldUpdate;  //jlier1 TFS 63254 18/4/24
			if _ediFile.ediData = null then
				app.myUtilityCA.utlCreateEDIData(_ediFile.ediData, CM_EDIDataCargoFieldUpdate, ediType, EDIFileTypeX12_315_4010, _ediFile.ediConfig, _ediFile, ediFileType, app.myPassport);
				_ediFile.ediData.setStatus(CM_EDIFile.EDI_STATUS_LOADED);
			endif;			
			ediDataCargoFieldUpdate := _ediFile.ediData.CM_EDIDataCargoFieldUpdate;
			
			if anEDIData &lt;&gt; null then					
				delete anEDIData;
			endif;
		endif;

		create ediDataCargoFieldUpdateTi;
		ediDataCargoFieldUpdateTi.setMyEDIData(_ediFile.ediData);
		ediDataCargoFieldUpdateTi.fieldName:= ediDataCargoFieldUpdateTi.F_BOL;
		ediDataCargoFieldUpdateTi.fieldValue := bolNumber;
		ediDataCargoFieldUpdateTi.setId(cargoID);
	endif;
epilog
	delete theLines;
	delete msgHelper;
end;
</source>
        <access>protected</access>
        <Parameter name="_ediFile" type="CM_EDIFile" usage="input"/>
    </JadeMethod>
</Class>
