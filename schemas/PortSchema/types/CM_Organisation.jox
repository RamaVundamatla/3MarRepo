    <JadeMethod name="getAuditText" id="65ee197d-5f4f-4aa8-9f73-fd7e1f62f616">
        <source>getAuditText(): String;
// ---------------------------------------------------------------------------
// Created:     29 October 2001 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	txt,
	tmpStr	: String;
	dac		: CM_DataAccessController;
		
begin
	txt[10000] := '*';
	txt := null;

	txt := inheritMethod();

	foreach dac in self.allDataAccessControllers do
		tmpStr := dac.name;
		txt := txt &amp; dac.getClassName &amp; ' Data Access' &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp; tmpStr &amp; AuditStringSeparator;
	endforeach;

	return txt;

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
