<Class name="CMIF_KPIYardMove" id="be4a4000-1cb4-42a9-8f85-eefe640dbbf6">
    <superclass name="CMIF_KPIController"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="cmtrans"/>
    <ImplicitInverseRef name="myLocationSource" id="e6bff71e-95f6-46d1-ae64-6091bb90ee71">
        <embedded/>
        <type name="CM_LocationsController"/>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="myLocationTarget" id="c9fff6f7-4870-493c-b836-9e02bcb6e8c1">
        <embedded/>
        <type name="CM_LocationsController"/>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="myTrackedItem" id="629e159f-c581-4c92-8acb-dd5282e8bb3e">
        <embedded/>
        <type name="CM_TrackedItem"/>
    </ImplicitInverseRef>
    <PrimAttribute name="numKPISource" id="0487e98f-4ef7-41aa-b5c0-0fd428967e44">
        <embedded/>
        <type name="Integer"/>
    </PrimAttribute>
    <PrimAttribute name="numKPITarget" id="9036c174-4af8-4bcf-ad86-e53016d642a9">
        <embedded/>
        <type name="Integer"/>
    </PrimAttribute>
    <JadeMethod name="processKPI" id="097d312e-76ec-4ab6-b909-bb77de9468de">
        <updating/>
        <source>processKPI() updating;
// ---------------------------------------------------------------------------
// Created:		15 January 2008 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
constants
	Delimiter = "^";
vars
	theTerminal		: CM_Terminal;
	lControllerS, 
	lControllerT, tmpLC	: CM_LocationsController;
	taS, taT : CM_TerminalArea;
	is40, invalidLC : Boolean;
	localInfo : String;
	beforeKPISource, beforeKPITarget : Integer;
	stackValue, teu, totTEU,padsMT, padsOccupied, padsFull  : Real;
	afterKPISource, afterKPITarget : Integer;
	
	stackIndex, maxStack, totTI: Integer;
	
	kpiController : CMIF_KPIYardMove;
begin
	on Exception do app.handleDeletedObject(exception, tmpLC, invalidLC); // PAR 17449

	//	app.createAlert(class.name &amp; '::' &amp; method.name &amp;  ' 1. ' &amp; self.myLocationSource.String &amp; "&lt;&gt;" &amp; self.myLocationTarget.String &amp; "&lt;&gt;" &amp; self.myTrackedItem.String &amp; "&lt;&gt;" &amp; self.numKPISource.String &amp;"&lt;&gt;" &amp; self.numKPITarget.String, true);
	theTerminal := self.myTrackedItem.myTerminal;	
	
	lControllerS := self.myLocationSource;
	lControllerT := self.myLocationTarget; 

	beforeKPISource := self.numKPISource;
	beforeKPITarget := self.numKPITarget;
	teu := self.myTrackedItem.getNumTEU(); // PAR 16415 CCMS 1029
	/*
	is40 := self.myTrackedItem.isForty();
	if is40 then
		teu := 2;
	else
		teu := 1;
	endif;
	*/

	tmpLC := lControllerS; // PAR 17449
	invalidLC := false; // PAR 17449
	
	// ### SOURCE
	// ### At the source it is about an item leaving 
	if lControllerS &lt;&gt; null 
	and lControllerS.isYardLocation() then
		taS := lControllerS.myTerminalArea;
		if taS &lt;&gt; null then
			afterKPISource := lControllerS.allTrackedItems.size;
			maxStack := lControllerS.getMaxStackingHeight();
			if not invalidLC then // PAR 17449
				totTI := -1;
				totTEU := (-1 * teu);
				
				if afterKPISource = 0 then // NOW EMPTY
					padsMT := (1 * teu);
					padsOccupied := (-1 * teu);
					if beforeKPISource = maxStack then
						padsFull := (-1 * teu);
					else
						padsFull := 0;
					endif;
					stackIndex := 1;
					stackValue := (1 * teu);
				else // IS OCCUPIED
					padsMT := 0;
					padsOccupied := 0;
					if afterKPISource = maxStack then // NOW FULL
						padsFull := (1 * teu);
					else
						if beforeKPISource = maxStack then // WAS FULL
							padsFull := (-1 * teu);
						else
							padsFull := 0; // do not adjust
						endif;
					endif;
					stackIndex := beforeKPISource;
					stackValue := (1 * teu);
				endif;
				localInfo := totTI.String &amp; Delimiter &amp;  totTEU.asStringJMTWithPrecision(1,false) &amp; Delimiter &amp;  padsMT.String &amp; Delimiter &amp;  padsOccupied.String &amp; 
								Delimiter &amp;  padsFull.String &amp; Delimiter &amp; stackIndex.String &amp; Delimiter  &amp; stackValue.String &amp; Delimiter &amp; "0";
				taS.causeEvent(theTerminal.getTerminalEvent(EVENT_KPIYARDMOVE),true,localInfo );				
			endif;
		endif;
	endif;
	
	// ### TARGET
	// ### At the target it is about an item being received.
	tmpLC := lControllerT; // PAR 17449
	invalidLC := false; // PAR 17449

	if lControllerT &lt;&gt; null 
	and lControllerT.isYardLocation() then
		taT := lControllerT.myTerminalArea;
		if taT &lt;&gt; null then
			afterKPITarget := lControllerT.allTrackedItems.size;
			maxStack := lControllerT.getMaxStackingHeight();
			if not invalidLC then // PAR 17449
				totTI := 1;
				totTEU := (1 * teu);
				
				if beforeKPITarget = 0 then // WAS EMPTY
					padsMT := (-1 * teu);
					padsOccupied := 1;
					if afterKPITarget = maxStack then // NOW FULL
						padsFull := (1 * teu);
					else
						padsFull := 0;
					endif;
					stackIndex := 1;
					stackValue := (-1 * teu);
				else // WAS OCCUPIED
					padsMT := 0;
					padsOccupied := 0;
					if afterKPITarget = maxStack then // NOW FULL
						padsFull := (1 * teu);
					else
						padsFull := 0;
					endif;
					stackIndex := afterKPITarget;
					stackValue := (-1 * teu);
						
				endif;
				localInfo := totTI.String &amp; Delimiter &amp;  totTEU.asStringJMTWithPrecision(1,false) &amp; Delimiter &amp;  padsMT.String &amp; Delimiter &amp;  padsOccupied.String &amp; 
								Delimiter &amp;  padsFull.String &amp; Delimiter &amp;  stackIndex.String &amp; Delimiter  &amp; stackValue.String &amp; Delimiter &amp; "0";
				taT.causeEvent(theTerminal.getTerminalEvent(EVENT_KPIYARDMOVE),true,localInfo );				
			endif;
//	app.createAlert(class.name &amp; '::' &amp; method.name &amp;  ' 2. '  , true);

		endif;
	endif;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="setControllerFromUserInfo" id="7184937c-deef-4fad-aa0a-5ec42d21ef18">
        <updating/>
        <source>setControllerFromUserInfo(_userInfo : String) updating;
// ---------------------------------------------------------------------------
// Created:		15 January 2008 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
constants
	Delimiter = "^";
vars
	sub : String;
	val, pos, idx, len  : Integer;
begin
//	app.createAlert(class.name &amp; '::' &amp; method.name &amp;  ' 1. ' &amp; _userInfo, true);


	len := _userInfo.length();
	idx := 1;
	while true do
		pos := _userInfo.pos(Delimiter, idx);
		if pos = 0 then
			break;
		endif;
		sub := _userInfo[idx:pos - idx];
		val := val + 1;
		if val = 1 then
			self.myLocationSource := sub.asOid().CM_LocationsController;
		elseif val = 2 then
			self.myLocationTarget :=  sub.asOid().CM_LocationsController;
		elseif val = 3 then
			self.myTrackedItem :=  sub.asOid().CM_TrackedItem;
		elseif val = 4 then
			self.numKPISource :=  sub.Integer;
		endif;
		
		idx := pos + 1;
		if idx &gt; len then
			break;
		endif;
	endwhile;
	// don't forget the last item
	sub := _userInfo[idx:end];
	self.numKPITarget :=  sub.Integer;

//	app.createAlert(class.name &amp; '::' &amp; method.name &amp;  ' 1. ' &amp; self.myLocationSource.String &amp; "&lt;&gt;" &amp; self.myLocationTarget.String &amp; "&lt;&gt;" &amp; self.myTrackedItem.String &amp; "&lt;&gt;" &amp; self.numKPISource.String &amp;"&lt;&gt;" &amp; self.numKPITarget.String, true);

end;</source>
        <Parameter name="_userInfo" type="String"/>
    </JadeMethod>
</Class>
