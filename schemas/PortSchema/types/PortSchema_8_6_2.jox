    <JadeMethod name="setTermSecurityEventTypes" id="2e6f4e69-a78a-4fad-9ff6-06ff26ba822d">
        <source>setTermSecurityEventTypes(_controller : CnEcReleaseController);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 March 2020	jlgndl1	Initial creation	TFS 48784

*/

vars

	role : CM_SecurityRoleTerminal;
	rootRole : CM_SecurityRoleTerminalRoot;
	eventType : CM_EventType;
	coll : CM_EventTypeByTypeDict;

begin

	if self.hasScriptBeenRunAtAll(method.name, _controller) then
		return;
	endif;
	
	app.writeLog(method.qualifiedName &amp; " Add all Event Types to every Terminal Security Role", LogINFO);
	if _controller &lt;&gt; null then
		_controller.logEntry(" Add all Event Types to every Terminal Security Role") ;	
	endif;
	
	create coll transient;
	foreach eventType in app.myRoot.allEventTypesByType do
		if eventType.canIncludeInSecurityRole then
			coll.add( eventType );
		endif;
	endforeach;
	
	beginTransaction;
	foreach role in CM_SecurityRoleTerminal.instances do
		role.setEventTypes( coll );
	endforeach;
	foreach rootRole in CM_SecurityRoleTerminalRoot.instances do
		rootRole.setEventTypes( coll );
	endforeach;
	commitTransaction;
	
	
	app.writeLog(method.qualifiedName &amp; " Add all Event Types to every Terminal Security Role Completed", LogINFO);
	if _controller &lt;&gt; null then
		_controller.logEntry(" Add all Event Types to every Terminal Security Role Completed") ;
	endif;
	
	self.addScriptRun(method.name);

epilog

	delete coll;

end;</source>
        <Parameter name="_controller" type="CnEcReleaseController"/>
    </JadeMethod>
    <JadeMethod name="setWeighBridgePermissions" id="ac1ef39d-50f8-47dd-9af9-94016169c73b">
        <source>setWeighBridgePermissions( _updController : CnEcReleaseController );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 July 2019	jlgndl1	Initial creation	TFS 44965

*/

vars

	newPerms : IntegerArray;
	srt : CM_SecurityRoleTerminal;
	hasCargoEnqView : Boolean;

begin

	if self.hasScriptBeenRunAtAll(method.name, _updController) then
		return;
	endif;
	
	app.writeLog( method.qualifiedName &amp; 'Configuring Weigh Bridge for permissions ', LogINFO);
	
	create newPerms transient;
	newPerms.add(PmWeighForm);
	
	foreach srt in CM_SecurityRoleTerminal.instances do
		if srt.permissions.size &lt; PmAdmCargoEnquiryView then
			continue;
		endif;
		hasCargoEnqView := srt.permissions[PmAdmCargoEnquiryView];
		if hasCargoEnqView then
			beginTransaction;
			srt.setPermissionsFromIntArray(newPerms,true);
			commitTransaction;
		endif;
	endforeach;
	
	app.writeLog( method.qualifiedName &amp; 'Completed Configuring Weigh Bridge for permissions ', LogINFO);
	
	self.addScriptRun(method.name);
	
epilog

	delete newPerms;

end;</source>
        <Parameter name="_updController" type="CnEcReleaseController"/>
    </JadeMethod>
    <JadeMethod name="setupCashCreditSequNum" id="e17a0ca0-32dc-4bf5-912e-91b29fd49326">
        <updating/>
        <source>setupCashCreditSequNum(_controller: CnEcReleaseController) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 Sep 2019	jlgsl4	TFS 45872 - JMT - Cash Credit UI changes
*/

vars
	keySeries : CM_KeySeries;
	seriesKey : CM_SeriesKey;
	bank : CM_Bank;
	objectArray : ObjectArray; 
	iterator : Iterator;
	isOK : Boolean;
begin
	if self.hasScriptBeenRunAtAll(method.name, null) then
		return;
	endif;
	app.myPassport.setMyUserFromCode(SUPERUSER_Str);

	create objectArray transient;
	CM_Bank.allInstances(objectArray, 0, false);
	iterator := objectArray.createIterator;
	app.writeLog(method.qualifiedName &amp; "***** Started -&gt; Create Cash Credit sequence numbers for banks listed:-", LogINFO);

	if _controller &lt;&gt; null then
		_controller.logEntry(" Start Create Cash Credit sequence numbers");
	endif;

	while iterator.next(bank) do
		if not bank.isBusinessUnit then
			continue;
		endif;
		if bank.keySeries[SN_CashCredit] = null then
			beginTransaction;
			create keySeries;
			keySeries.set(SN_CashCredit, "Cash Credit External Id", null);
			create seriesKey;
			keySeries.nextKey := seriesKey;
			seriesKey.setForUpdate(null, "CTL", 10000, null, null);
			bank.keySeries.add(keySeries);
			commitTransaction;
			app.writeLog(method.qualifiedName &amp; " -&gt; terminal " &amp; bank.getMyTerminal().code &amp; ", bank " &amp; bank.code, LogINFO);
		endif;
	endwhile;
	app.writeLog(method.qualifiedName &amp; "***** Finished -&gt; Create Cash Credit sequence numbers", LogINFO);	
	if _controller &lt;&gt; null then
		_controller.logEntry("Completed Create Cash Credit sequence numbers");
	endif;
	self.addScriptRun(method.name);
	isOK := true;
epilog
	if not isOK then
		abortTransaction;
	endif;
	delete objectArray;
end;</source>
        <Parameter name="_controller" type="CnEcReleaseController"/>
    </JadeMethod>
    <JadeMethod name="setupMvmntPilotDetails" id="6796b918-cf8f-46a2-bb4d-f3ccf8fcf196">
        <updating/>
        <source>setupMvmntPilotDetails(_controller: CnEcReleaseController) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 May 2019	jlgsl4	TFS 44438 - PEL1 - Multiple Pilot Launches for one movement

*/

vars
	voyageMovement : HMS_VoyageMovement;
	pilot : HMS_Pilot;
	movementPilotDetails : HMS_MovementPilotDetails;
	canSetPilotLaunch,
	setPilotLaunchBefore, isOK : Boolean;
	voyage : CM_Voyage;
	voyageGlobal : CM_VoyageGlobal;
	terminalCode : String;
	pilotLaunch : HMS_PilotLaunch;
begin
	if self.hasScriptBeenRunAtAll(method.name, null) then
		return;
	endif;
	app.myPassport.setMyUserFromCode(SUPERUSER_Str);

	app.writeLog(class.name &amp; '::' &amp; method.name &amp; " - Start Upgrade Multiple Pilot Movement", LogINFO);
	if _controller &lt;&gt; null then
		_controller.logEntry(" Start Upgrade Multiple Pilot Movement");
	endif;

	beginTransaction;
	foreach voyageMovement in HMS_VoyageMovement.instances where voyageMovement.allMovementPilotDetails.isEmpty do
		if not voyageMovement.allPilots.isEmpty then
			setPilotLaunchBefore := false; // pilot launch hasn't been set for any of this movement's pilots yet
			canSetPilotLaunch := true; // if not Pelindo, pilot launch can always be set for a movement's pilots
			pilotLaunch := voyageMovement.myPilotLaunch; // one pilot launch per movement
			foreach pilot in voyageMovement.allPilots do
				create movementPilotDetails persistent;
				movementPilotDetails.setMyPilot(pilot);
				if pilotLaunch &lt;&gt; null and setPilotLaunchBefore then // if movement has a valid pilot launch and it's been set for a pilot before,
					voyageGlobal := voyageMovement.myVoyageGlobal; // need to check for Pelindo voyage process; first get voyage details
					if voyageGlobal &lt;&gt; null then
						voyage := voyageGlobal.allVoyages.first;
						if voyage &lt;&gt; null then // voyage is valid, what's its voyage process?
							if voyage.myVoyageProcess = CM_VoyageProcessIPN1.firstInstance or voyage.myVoyageProcess = CM_VoyageProcessPEL1.firstInstance then
								canSetPilotLaunch := false; // Pelindo - can't use launch again, it's been used already
								terminalCode := "Unknown";
								if voyage.myTerminalActive &lt;&gt; null then
									terminalCode := voyage.myTerminalActive.code;
								endif; // log info so someone can set pilot's launch manually
								app.writeLog(class.name &amp; '::' &amp; method.name &amp; " *** Have not set pilot launch for pilot " &amp; pilot.description &amp;
									" on voyage " &amp; voyage.code &amp; ", terminal " &amp; terminalCode &amp; " - needs to be set manually ***", LogINFO);
							endif;
						endif;
					endif;
				endif;
				if canSetPilotLaunch and pilotLaunch &lt;&gt; null then
					movementPilotDetails.setMyPilotLaunch(pilotLaunch);
					setPilotLaunchBefore := true; // record that the pilot launch has been used
				endif;
				voyageMovement.allMovementPilotDetails.add(movementPilotDetails);
			endforeach;
		elseif voyageMovement.myPilot &lt;&gt; null then // Empty allPilots means the terminal's using now-deprecated myPilot...
			create movementPilotDetails persistent;
			movementPilotDetails.setMyPilot(voyageMovement.myPilot);
			movementPilotDetails.setMyPilotLaunch(voyageMovement.myPilotLaunch);
			voyageMovement.allMovementPilotDetails.add(movementPilotDetails);
		endif;
		voyageMovement.setUnusedMyPilotRefToNull();
		voyageMovement.setUnusedMyPilotLaunchNull();
	endforeach;
	commitTransaction;

	app.writeLog(class.name &amp; '::' &amp; method.name &amp; " - Completed Upgrade Multiple Pilot Movement", LogINFO);
	if _controller &lt;&gt; null then
		_controller.logEntry("Completed Upgrade Multiple Pilot Movement");
	endif;
	self.addScriptRun(method.name);
	isOK := true;
epilog
	if not isOK then
		abortTransaction;
	endif;
end;</source>
        <Parameter name="_controller" type="CnEcReleaseController"/>
    </JadeMethod>
    <JadeMethod name="specificPostStandard" id="21ea0604-0a62-4c19-a250-9d58a17a8620">
        <updating/>
        <source>specificPostStandard(pControllerObj: CnEcReleaseController) updating;
/*

Purpose:			

Parameters:			

Return Value:		
/* Changes

Date		Name	TFS#	Description
============================================================================
14 Feb 2019	jlger1			Initial creation
02 Apr 2019	jlgka1	43817	JMT - Change Lock Keeper/KPI name.
15 Apr 2019	jlgka1	43863	AAT - Set Recurring Unit and Value for Monthly Intervals.
15 May 2019 jlgsl4	44438   PEL1 - Multiple Pilot Launches for one movement
05 Jun 2019	jlgdap1	TFS 44554 AAT Stevedore Data Access
06 Jun 2019	jlgsl4	45059	PEL1 - tidy up orphaned movement pilot details objects
15 Jul 2019	jlgdi1	45301	JMT - Set the cash payment status to CM_CashPayment.Status_Merged 
							when the cash payment is 'Void' and is link to a zombie (CM_TrackedItem.hasBeenMerged)
03 Sep 2019	jlgsl4	45872	JMT - Cash Credit UI changes
01 Oct 2019	jlgdi1	45802		Update form permission's new attribute 'formType'
05 Nov 2019	jlgdap1	TFS 46405	AAT Flat Rack and OOG in LOLO Planning Screen
//6/11/2019	JLGNS1	ChangeRequest 46721: PEN - CAMIR Message Processing
18 Sep 2020 jlgdap1	TFS 49316 MTN Machine Idle Time
02 Oct 2020 cnwma1  ChangeRequest 50112: ASPA - GCI Stevedores
10 Mar 2021	navdap1	TFS 50889 PRP Yard Allocation Performance Improvement
19 Mar 2021 cnwma1  ChangeRequest 50925: ASPA - New Total Column in Invoice Form
24 Sep 2021 navpw1  Bug 52047: MTN - Invoice Status not added to Terminal Security role for new Starter DBs
============================================================================*/

vars

begin
	inheritMethod(pControllerObj);
	self.fixupReserveTIs(pControllerObj);					//epr TFS 43404 14/2/19
	self.changeLockKeeperKPIname(pControllerObj);			// jlgka1 TFS 43817
	self.setBGPMonthlyRecurUnitAndValue(pControllerObj);	// jlgka1 TFS 43863
	self.setupMvmntPilotDetails(pControllerObj);			// TFS 44438	
	self.createStevedoreDebtorType(pControllerObj);			// TFS 44554
	self.setNewTransResyncPerm(pControllerObj);				// TFS 44554 jlgdap1 11/06/2019 
	self.deleteMvmtPilotDetlsOrphans(pControllerObj);		// TFS 45059
	self.createDefaultInvEmail(pControllerObj); //25 Jan 2019	NDL	TFS 39618 (TFS 52158 this was in 861, but missing from 862)
	self.updateRoadGateReleasedCargo(pControllerObj);		// 20/2/19 MAP TFS40701
	self.setWeighBridgePermissions(pControllerObj);			//09 Jul 2019	NDL	TFS 44965
	self.setCashPaymentToMerged(pControllerObj);			// 15 Jul 2019 jlgdi1 TFS 45301
	self.setNoConsolidateRoadExit(pControllerObj);			// 15 Jul 2019 jlgndl1 TFS 45300
	self.convertToUseStorageConfig(pControllerObj);			// 23 Jul 2019 jlgndl1 TFS 45574
	self.setupCashCreditSequNum(pControllerObj);			// TFS 45872
	self.setQueryPerformanceRatings(pControllerObj);		// 05 Sep 2019 jlgndl1 TFS 45891
	self.convertOperatorCarriers(pControllerObj);			// 10 Sep 2019 jlgdap1 TFS 45836
	self.updatePermissionViewType(pControllerObj);			// 01 Oct 2019 TFS 45802
	self.updateLicenseModules(pControllerObj);				//08 Oct 2019	NDL	TFS 46169
	self.createBOLCalcTypes(pControllerObj);				//31 Oct 2019	NDL	TFS 47100
	self.createBOLDebtorTypes(pControllerObj);				//31 Oct 2019	NDL	TFS 47100
	self.setSpecialStowConfigs(pControllerObj);				//05 Nov 2019 jlgdap1 TFS 46405
	self.updateDrawingAttributes3(pControllerObj);			//05 Nov 2019 jlgdap1 TFS 46405
	self.updateEDIActionActionTypes(pControllerObj);		//31/10/2019	JLGNS1	ChangeRequest 46721
	self.updateQueryProperties(pControllerObj);				//18/12/19 jlers TFS 47132
	self.setTermSecurityEventTypes(pControllerObj);			//09 Mar 2020	NDL	TFS 48784
	self.convertOldStyleTBAsToRRPs(pControllerObj);			//30 Mar 2020	NDL	TFS 47004
	self.setEventStreamEvtTypeObjects(pControllerObj);		//03 July 2020	NDL	TFS 49590
	self.defaultIdleTimeSettings(pControllerObj);			// TFS 49316
	self.createRoadProcessObjs(pControllerObj);				//01 Oct 2020	NDL TFS 49189
	self.renameDebtorTypeStevedore(pControllerObj);			//02.10.2020 cnwma1 TFS #50112
	self.setAuditConfigsEnabled(pControllerObj);			//29 Jan 2021	NDL	TFS 50152
	self.resetZombieLocations(pControllerObj);				//10 Mar 2021	NDL	TFS 50796
	self.populateTerminalMarkExtDict(pControllerObj);		// TFS 50889
	self.convertInvRoundLineTotalConfig(pControllerObj);	// 22.03.2021 cnwma1 #50925
	self.createInventoryCalcTypes(pControllerObj);			// ### TFS 51219 03JUN2021 NAVAB1
	self.clearOffSiteFuturePlans( pControllerObj );			//30 Jun 2021	NDL	TFS 51421
	self.setNSPReeferLayout(pControllerObj);				// ### TFS 51361 13JUL2021 NAVAB1
	self.clearNonYardAllocsFromTermColl(pControllerObj);	//26 Jul 2021	NDL	TFS 49952
	self.convertRelReqValConfig(pControllerObj);			//17 Aug 2021	NDL	TFS 51785
	self.encryptPasswords(pControllerObj);					//27 Aug 2021	NDL	TFS 51632
	self.setOrderPickingPermissions(pControllerObj); 		//27/8/21 jlier1 TFS 51626
	self.encryptPassPhrases(pControllerObj);				//06 Sep 2021	NDL	TFS 51165
	self.convertAllMutexes(pControllerObj);					//16 Sep 2021	NDL	TFS 51142
	self.updateVoyageProcesses(pControllerObj);				//21 Sep 2021 jlizm1 TFS 51963
	self.updateInvoiceProcessPelindo(pControllerObj);		// ### TFS 52047 24Sep2021 NAVPW1
	self.createWorkOrderDetailTypes(pControllerObj);		//29.09.2021 navma1 #51925
	self.updateMeasurementInCargoType(pControllerObj);		//TFS#52718 28MAR2022 NAVSP1
epilog

end;</source>
