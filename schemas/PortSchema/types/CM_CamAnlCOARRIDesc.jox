    <JadeMethod name="makeMessageRFF_ABT" id="31f188aa-bd1d-4cae-80ba-e22670236440">
        <source>makeMessageRFF_ABT(_protocol :CM_CamProtocol; _group :HugeStringArray input; _activity :Integer; _ti :CM_TrackedItem):String protected;
/*
Purpose:			
Parameters:			
Return Value:		

Date		Who		Reason
22 May 2011	cnwcs5	Initial creation - CCMS SCT 2058/par 27460
//29 Jan 2015	cnwrs1	Par 35544 - Change CamMessage to use HugeStringArray
*/
vars
	msg	:String;
begin
	if _ti.customExportEntryNumber.trimRight &lt;&gt; null then
		msg := self.makeRFFSegment (_protocol, _group, "ABT", _ti.getCustExpEntryNoMinusSlash);
	endif;
	
	return msg;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_protocol" type="CM_CamProtocol"/>
        <Parameter name="_group" type="HugeStringArray" usage="input"/>
        <Parameter name="_activity" type="Integer"/>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="outputHeader_NAD" id="d4970dc9-f617-4ceb-ba00-f531f2eb7f4d">
        <updating/>
        <source>outputHeader_NAD(_protocol :CM_CamProtocol; _camTaskHistory :CM_CamTaskHistory input; _camMessage :CM_CamMessage input; _coll :HugeStringArray input) : String updating, protected;
/*
Date		Who		Reason
20/12/2012	cnwcs5	CCMS SFW 1294 /par 30855
//29 Jan 2015	cnwrs1	Par 35544 - Change CamMessage to use HugeStringArray
//25 Feb 2015	cnwrs1	Par 35544 - Refactor Cams file storage to string
*/
vars
	strLine : String;
begin
	//new NAD
	strLine := strLine &amp; self.outputFileMessage(_camTaskHistory, self.makeNADSegment (_protocol, null, "MS", _protocol.camISOPortDesc, null, null), _coll);
	
	_camMessage.segmentCount := _camMessage.segmentCount + 1;
	
	//NAD header
	strLine := strLine &amp; self.outputFileMessage(_camTaskHistory, self.makeNADSegment (_protocol, null, "CA", _protocol.camGroup.shippersCode.trimBlanks, '172', '20'), _coll);
	
	_camMessage.segmentCount := _camMessage.segmentCount + 1;
	return strLine;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_protocol" type="CM_CamProtocol"/>
        <Parameter name="_camTaskHistory" type="CM_CamTaskHistory" usage="input"/>
        <Parameter name="_camMessage" type="CM_CamMessage" usage="input"/>
        <Parameter name="_coll" type="HugeStringArray" usage="input"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="outputHeader_RFF" id="62193ccb-a806-4716-8e74-fc034f970c31">
        <updating/>
        <source>outputHeader_RFF(_protocol :CM_CamProtocol; _camTaskHistory :CM_CamTaskHistory input; _camMessage :CM_CamMessage input; _coll :HugeStringArray input) : String updating, protected;
/*
Date		Who		Reason
20/12/2012	cnwcs5	CCMS SFW 1294 /par 30855
*/
//29 Jan 2015	cnwrs1	Par 35544 - Change CamMessage to use HugeStringArray
//25 Feb 2015	cnwrs1	Par 35544 - Refactor Cams file storage to string
vars
	code, vCode	:String;
	strLine : String;
begin
	code 	:= _camMessage.camVoyage.getSanitisedVoyageCode();
	vCode 	:= self.getXlatedForeignCode(_protocol.operatorXlationCode.trimBlanks , code, XLATION_TYPE_VOYAGETERMINAL, _protocol.terminal);
	
	strLine := strLine &amp; self.outputFileMessage(_camTaskHistory, self.makeRFFSegment (_protocol, null, "VON",  vCode), _coll);
	_camMessage.segmentCount := _camMessage.segmentCount + 1;
	return strLine;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_protocol" type="CM_CamProtocol"/>
        <Parameter name="_camTaskHistory" type="CM_CamTaskHistory" usage="input"/>
        <Parameter name="_camMessage" type="CM_CamMessage" usage="input"/>
        <Parameter name="_coll" type="HugeStringArray" usage="input"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="outputHeader_TDT" id="7df7d55a-1683-4569-871d-ce6097482d77">
        <updating/>
        <source>outputHeader_TDT(_camTaskHistory :CM_CamTaskHistory input; _protocol :CM_CamProtocol; _camVoyage :CM_CamVoyage; _count :Integer io; _coll :HugeStringArray input) : String updating, protected;
/*
Purpose:		Output TDT+20 segment for voyage			

Date		Who		Reason
17 May 2011	cnwcs5	Initial creation - CCMS SCT 2058/par 27460
19 Dec 2012	cnwcs5	CCMS SFW 1294 /par 30855
//29 Jan 2015	cnwrs1	Par 35544 - Change CamMessage to use HugeStringArray
//25 Feb 2015	cnwrs1	Par 35544 - Refactor Cams file storage to string
*/
vars
	code, vCode, msg 	:String;
	voyage				:CM_Voyage;
	strLine : String;
begin
	voyage	:= _camVoyage.voyageOid;
	code 	:= _camVoyage.getSanitisedVoyageCode();
	vCode 	:= self.getXlatedForeignCode(_protocol.operatorXlationCode.trimBlanks , code, XLATION_TYPE_VOYAGETERMINAL, _protocol.terminal).trimRight;

	if _protocol.camGroup.useCallSign then
		strLine := strLine &amp; self.outputFileMessage(_camTaskHistory, self.makeTDT20Segment (_protocol, vCode, '1', 
													null, null, null, null, null, null, voyage.callSign.trimRight, '103', null, voyage.vesselName.trimRight.toUpper), _coll);
	else
		strLine := strLine &amp; self.outputFileMessage(_camTaskHistory, self.makeTDT20Segment (_protocol, vCode, '1', 
													null, null, null, null, null, null, voyage.lloydsNumber, '146', null, voyage.vesselName.trimRight.toUpper), _coll);
	endif;

	_count := _count + 1;
	return strLine;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_camTaskHistory" type="CM_CamTaskHistory" usage="input"/>
        <Parameter name="_protocol" type="CM_CamProtocol"/>
        <Parameter name="_camVoyage" type="CM_CamVoyage"/>
        <Parameter name="_count" type="Integer" usage="io"/>
        <Parameter name="_coll" type="HugeStringArray" usage="input"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="outputHeader_UNB" id="a110f385-bc27-4377-bad0-e03fe7706533">
        <updating/>
        <source>outputHeader_UNB(_protocol :CM_CamProtocol; _camTaskHistory :CM_CamTaskHistory input; _seqNumber :Integer; _coll :HugeStringArray input) : String updating, protected;
/*
Date		Who		Reason
20/12/2012	cnwcs5	CCMS SFW 1294 /par 30855
//29 Jan 2015	cnwrs1	Par 35544 - Change CamMessage to use HugeStringArray
*/
//22 Jan 2016	cnwrs1	37444 Use Cams controller rundate time rathyer than current date time
vars
	msg :String;
begin
	if _protocol.camGroup.code.trimBlanks = "COL" and _protocol.terminal.getConfig(PortDestCode).String = "POE" then
		return self.outputFileMessage (_camTaskHistory, 
								self.makeUNBSegment (_protocol, "UNOA", 2, "POTOTAGO", "ZZ", _protocol.camGroup.recipient.trimBlanks, "ZZ", _seqNumber, null, true, _camTaskHistory.runDateTime), _coll);	
	else
		return self.outputFileMessage (_camTaskHistory, 
								self.makeUNBSegment (_protocol, "UNOA", 2, self.getSenderCode_UNB (_protocol), "ZZ", _protocol.camGroup.recipient.trimBlanks, "ZZ", _seqNumber, null, false, _camTaskHistory.runDateTime), _coll); 	
	endif;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_protocol" type="CM_CamProtocol"/>
        <Parameter name="_camTaskHistory" type="CM_CamTaskHistory" usage="input"/>
        <Parameter name="_seqNumber" type="Integer"/>
        <Parameter name="_coll" type="HugeStringArray" usage="input"/>
        <ReturnType type="String"/>
    </JadeMethod>
</Class>
