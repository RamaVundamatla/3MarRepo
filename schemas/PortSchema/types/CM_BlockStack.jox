    <JadeMethod name="getDisplayStringForAttribute" id="44c33891-44ba-4463-83e1-d2309f765a3a">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
// ---------------------------------------------------------------------------
// Created:     15 September 2003 by cnwrs2
//
// Purpose:     
//15 9 16 TFS 2679:Multi-timezone issues cnwns1 
// ---------------------------------------------------------------------------
vars
	cnt 	: Integer;
	fifoTS 	: TimeStamp;
begin
	if _attrName = ETRow_NumItemsStr then
		return self.getNumTIs(REAL_MODE).String; //rs oct 2005 par 10886
	elseif _attrName = ETRow_NumTIs then
		return self.getNumTIs(REAL_MODE).String; //rs oct 2005 par 10886
	elseif _attrName = ETRow_MaxCapacity then //epr 10/8/09 ccms 1076
		return self.maxCapacity.asStringJMT;
	elseif _attrName = ETRow_EnforceMaxCapacity then //29 Aug 2011	NDL	Par 28076
		return self.getEnforceMaxCapacity.asStringJMT;
	elseif _attrName = 	ETRow_EffectiveFIFODateStr then					  //2679:Multi-timezone issues
		fifoTS.cnEcSetDateAndTime(self.effectiveFIFODate,TimeStartOfDay); //2679:Multi-timezone issues
		return self.systemToLocalTime(fifoTS).date().shortFormatJMT();	  //2679:Multi-timezone issues
	elseif _attrName = ETRow_Cols then //29 Aug 2011	NDL	Par 28076
		return self.getColumns(false).asStringJMT;
	elseif _attrName = ETRow_Rows then //29 Aug 2011	NDL	Par 28076
		return self.getRows(false).asStringJMT;
	elseif _attrName = ETRow_DoCreateLogicalDelTrx then	//04 Aug 2017	NDL	TFS 5679
		return self.doCreateLogicalDelTrx.String;
	elseif _attrName = ETRow_AutoRelease then	//28 May 2018	NDL	TFS 38897
		return self.autoRelease.String;
	elseif _attrName = ETRow_TrxTypeOnRelease then	//28 May 2018	NDL	TFS 38897
		return self.trxTypeOnRelease.String;
	else
		return inheritMethod(_attrName, _short);
	endif;

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
