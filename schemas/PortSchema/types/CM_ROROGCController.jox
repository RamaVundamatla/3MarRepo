    <JadeMethod name="getFullId" id="f6fd1905-315c-448f-8c13-b5e94c74ee7b">
        <source>getFullId() : String;
// ---------------------------------------------------------------------------
// Created:     
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
//	ti : CM_TrackedItem;
	tmpStr : String;
begin
	
	if self.myVoyage &lt;&gt; null then
		tmpStr := self.myVoyage.code.trimRight;
	endif;
	return tmpStr &amp; " " &amp; self.ident;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
