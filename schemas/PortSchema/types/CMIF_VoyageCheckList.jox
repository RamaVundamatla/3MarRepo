<Class name="CMIF_VoyageCheckList" id="b0969df8-9b54-4a5e-b866-e83d248c04d1">
    <superclass name="CMIF_Object"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>



PAR 35397 CCMS 1394</text>
    <DbClassMap file="voyages"/>
    <ImplicitInverseRef name="allItems" id="e5255b07-9b83-4720-bee0-0a49d0f62819">
        <memberTypeInverse/>
        <type name="ObjectArray"/>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="myTerminal" id="03422327-6f92-4fbf-b79f-0d202156869f">
        <embedded/>
        <type name="CM_Terminal"/>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="myVoyage" id="1e6fbf27-cca0-47aa-8108-fa4700fa8eb0">
        <embedded/>
        <type name="CM_Voyage"/>
    </ImplicitInverseRef>
    <JadeMethod name="addItem" id="e506dcd1-f142-4f31-b053-9de91d6185d8">
        <source>addItem(_name : String; _amount : String);
/*
Purpose:			
Date		Who		Reason
12 January 2015	cnwab1	Initial creation
*/

vars
	item : CMIF_VoyageCheckListItem;
begin
	create item transient;
	item.name := _name;
	item.amount := _amount;
	
	allItems.add(item);
epilog

end;</source>
        <Parameter name="_name" type="String"/>
        <Parameter name="_amount" type="String"/>
    </JadeMethod>
    <JadeMethod name="buildList" id="7e37fcbf-61a9-4d32-8ef9-c719d3e2e6c9">
        <source>buildList();
/*
Purpose:			
Date		Who		Reason
12 January 2015	cnwab1	Initial creation
*/

vars
	edi : CM_EDIData;
	agent : CM_EDIControllerAgent;
	amount : Integer;
begin
	self.allItems.purge();
	// ### EDI
	create agent transient;
	
	foreach edi in self.myTerminal.myEdiConfig.allEDIDatasByDateStatus discreteLock do
		if not edi.isForVoyage(self.myVoyage) then
			continue;
		endif;
		
		self.addItem(app.getErrorString(EDI) &amp; " "  &amp; agent.displayStatus(edi.status), edi.fileVersion);
	endforeach;
	
	self.addItem(app.getErrorString(Exchange_details), self.myVoyage.getExchangeDetailsSetPC().String &amp; "%");
	self.addItem(app.getErrorString(Call_sign), self.myVoyage.callSign);
	self.addItem(app.getErrorString(PRENotes), self.myVoyage.allNotifiedTIsByCargoTypeId.size.String);
	self.addItem(app.getErrorString(Cutoffs), self.myVoyage.allReceivalCutoffs.size.String);
	
	if self.myVoyage.myCellularVoyageStructure &lt;&gt; null then
		amount := amount + self.myVoyage.myCellularVoyageStructure.getTotalColourCode(true,true,false);
	endif;
	if self.myVoyage.myROROStructure &lt;&gt; null then
		amount := amount + self.myVoyage.myROROStructure.getTotalColourCode(true,true,false);
	endif;
	if self.myVoyage.myROROStructure &lt;&gt; null or self.myVoyage.myCellularVoyageStructure &lt;&gt; null then
		self.addItem(app.getErrorString(Load_colour_coding), amount.String);
	endif;
	amount := 0;
	
	if self.myVoyage.myCellularVoyageStructure &lt;&gt; null then
		amount := amount + self.myVoyage.myCellularVoyageStructure.getTotalColourCode(true,true,true);
	endif;
	if self.myVoyage.myROROStructure &lt;&gt; null then
		amount := amount + self.myVoyage.myROROStructure.getTotalColourCode(true,true,true);
	endif;
	if self.myVoyage.myROROStructure &lt;&gt; null or self.myVoyage.myCellularVoyageStructure &lt;&gt; null then
		self.addItem(app.getErrorString(Load_colour_codingJOB), amount.String);
	endif;
	amount := 0;
	
	if self.myVoyage.myCellularVoyageStructure &lt;&gt; null then
		amount := amount + self.myVoyage.myCellularVoyageStructure.getTotalPlanned(true,true);
	endif;
	if self.myVoyage.myROROStructure &lt;&gt; null then
		amount := amount + self.myVoyage.myROROStructure.getTotalPlanned(true,true);
	endif;
	if self.myVoyage.myGeneralCargoVoyage &lt;&gt; null then
		amount := amount + self.myVoyage.myGeneralCargoVoyage.getTotalPlanned(true,true);
	endif;
	if self.myVoyage.myShipBlockStack &lt;&gt; null then
		amount := amount + self.myVoyage.getTotalPlanned(true,true);
	endif;
	self.addItem(app.getErrorString(Load_planned), amount.String);
	amount := 0;
		
	if self.myVoyage.myCellularVoyageStructure &lt;&gt; null then
		amount := amount + self.myVoyage.myCellularVoyageStructure.getTotalColourCode(false,true,false);
	endif;
	if self.myVoyage.myROROStructure &lt;&gt; null then
		amount := amount + self.myVoyage.myROROStructure.getTotalColourCode(false,true,false);
	endif;
	if self.myVoyage.myROROStructure &lt;&gt; null or self.myVoyage.myCellularVoyageStructure &lt;&gt; null then
		self.addItem(app.getErrorString(Discharge_colour_coding), amount.String);
	endif;
	amount := 0;

	if self.myVoyage.myCellularVoyageStructure &lt;&gt; null then
		amount := amount + self.myVoyage.myCellularVoyageStructure.getTotalColourCode(false,true,true);
	endif;
	if self.myVoyage.myROROStructure &lt;&gt; null then
		amount := amount + self.myVoyage.myROROStructure.getTotalColourCode(false,true,true);
	endif;
	if self.myVoyage.myROROStructure &lt;&gt; null or self.myVoyage.myCellularVoyageStructure &lt;&gt; null then
		self.addItem(app.getErrorString(Discharge_colour_codJOB), amount.String);
	endif;
	amount := 0;

	if self.myVoyage.myCellularVoyageStructure &lt;&gt; null then
		amount := amount + self.myVoyage.myCellularVoyageStructure.getTotalPlanned(false,true);
	endif;
	if self.myVoyage.myROROStructure &lt;&gt; null then
		amount := amount + self.myVoyage.myROROStructure.getTotalPlanned(false,true);
	endif;
	if self.myVoyage.myGeneralCargoVoyage &lt;&gt; null then
		amount := amount + self.myVoyage.myGeneralCargoVoyage.getTotalPlanned(false,true);
	endif;
	if self.myVoyage.myShipBlockStack &lt;&gt; null then
		amount := amount + self.myVoyage.getTotalPlanned(false,true);
	endif;
	self.addItem(app.getErrorString(Discharge_planned), amount.String);
	amount := 0;

epilog
	delete agent;
end;</source>
    </JadeMethod>
    <JadeMethod name="buildListMOCK" id="ae2cc2b3-afe6-4a88-a79a-08f78ecda3d0">
        <source>buildListMOCK();
/*
Purpose:			
Date		Who		Reason
12 January 2015	cnwab1	Initial creation
*/

vars

begin
	self.addItem("EDI Db Loaded", "BAPLIE");
	self.addItem("EDI Db Loaded", "MOVINS");
	self.addItem("EDI Db Loaded", "BolMSK");
	self.addItem("Exchange Details", "89%");

epilog

end;</source>
    </JadeMethod>
</Class>
