    <JadeMethod name="cloneReferences" id="440467b2-03ee-48ea-8285-8f87340dbed3">
        <updating/>
        <source>cloneReferences(_obj: CMQF_InvoiceContract; _transient: Boolean) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
// 24/04/2023	navkc1	CR 55654 Task 55670: Jade - Contract reporting

*/

vars

begin
	
	self.myBusinessUnit := _obj.myBusinessUnit;
	
	self.allCalculationTypes.clear();
	_obj.allCalculationTypes.copy(self.allCalculationTypes);
	
	self.allDebtors.clear();
	_obj.allDebtors.copy(self.allDebtors);
	
	self.allInvoiceLineTypes.clear();
	_obj.allInvoiceLineTypes.copy(self.allInvoiceLineTypes);
	
	self.allRateServices.clear();
	_obj.allRateServices.copy(self.allRateServices);
	
	self.allUnitOfMeasures.clear();
	_obj.allUnitOfMeasures.copy(self.allUnitOfMeasures);
	
	inheritMethod(_obj, _transient);

epilog

end;</source>
        <Parameter name="_obj" type="CMQF_InvoiceContract"/>
        <Parameter name="_transient" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="filterObjects" id="4e20a004-8037-4607-a155-a7a6a077128f">
        <updating/>
        <source>filterObjects(_collection: Collection input; _passport: CM_Passport) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
// 24/04/2023	navkc1	CR 55654 Task 55670: Jade - Contract reporting

*/

vars

begin
	
	if (not self.allQueryCriteriaHolders.isEmpty()) then
		self.filterSelectorQuery(_collection, _passport);
		return;
	endif;
	
	// Dates for rate entries
	if 	self.rateFromStartDate.isValid() or
		self.rateFromEndDate.isValid() or
		self.rateToStartDate.isValid() or
		self.rateToEndDate.isValid() then
			self.getContractsForRateDates();
	// Dates for contract details
	elseif 	self.detailsFromStartDate.isValid() or 
			self.detailsFromEndDate.isValid() or
			self.detailsToStartDate.isValid() or
			self.detailsToEndDate.isValid() then
				self.getContractsForDetailDates();
	// Dates for contracts
	elseif 	self.contractFromStartDate.isValid() or
			self.contractFromEndDate.isValid() or
			self.contractToStartDate.isValid() or
			self.contractToEndDate.isValid() then
				self.getContractsForDates();
	// Debtors
	elseif self.allDebtors.isNotEmpty() then
				self.getContractsForDebtors();
	// Contract ID
	elseif self.contractId &lt;&gt; null then
				self.getContractsForId();
	// Default
	else
		self.getContractsForBU();
	endif;
	
	self.allContracts.copy(_collection);
	
epilog

end;</source>
        <Parameter name="_collection" type="Collection" usage="input"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="filterSelectorQuery" id="b42c7ebb-8fe7-41f5-9e86-64891ca7743a">
        <source>filterSelectorQuery(_collection : Collection input; _passport : CM_Passport) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
// 24/04/2023	navkc1	CR 55654 Task 55670: Jade - Contract reporting

*/

vars
	criteriaHolder 		: CM_QueryCriteriaLineHolder;
	qDef				: CM_QueryDefinition;
	enqController		: CM_EnquiryController;
	queryAgent			: CM_QueryAgentFilter;
	
begin
	on CM_BreakOutException do app.myQAFilter.xHandlerBreakOut(exception);
	
	queryAgent := app.myQAFilter;
	
	if queryAgent = null then
		return;
	endif;
	
	qDef := app.myRoot.allQueryDefinitionObjects[CM_QueryDefinition.Invoicing_Query_Type, self.selectorMode];
	queryAgent.createEnqControllerForMode(self.selectorMode, CM_QueryDefinition.Invoicing_Query_Type, enqController);
	delete enqController.allObjects;
	create enqController.allObjects as _collection.class transient;
	
	foreach criteriaHolder in self.allQueryCriteriaHolders discreteLock do
		enqController.myCriteriaLineHolder := criteriaHolder;
		enqController.doQuery(qDef);
	endforeach;

	enqController.allObjects.copy(_collection);
	
epilog
	if enqController &lt;&gt; null then
		delete enqController.allObjects;
	endif;
	delete enqController;
end;</source>
        <access>protected</access>
        <Parameter name="_collection" type="Collection" usage="input"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="getContractsForBU" id="302e5272-238b-45aa-aa7f-6b3b8ff12607">
        <source>getContractsForBU();
/*
Purpose:			

Date		Who		Reason
// 24/04/2023	navkc1	CR 55654 Task 55670: Jade - Contract reporting
*/

vars
	contract 	: CM_InvoiceContract;
	bank		: CM_Bank;
begin
	
	bank := self.myBusinessUnit;
	
	if bank = null then
		return;
	endif;
		
	foreach contract in bank.allInvoiceContractsById discreteLock do
		
		if not self.includeContract(contract, true) then
			continue;
		endif;
		
		self.allContracts.add(contract);
	endforeach;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="getContractsForDates" id="157ee598-205b-4db3-a73a-a7c376fa6880">
        <source>getContractsForDates();
/*
Purpose:			

Date		Who		Reason
// 24/04/2023	navkc1	CR 55654 Task 55670: Jade - Contract reporting
*/

vars
	debtor 		: CM_Debtor;
	contract 	: CM_InvoiceContract;
	iter 		: Iterator;
	bank		: CM_Bank;
begin
	
	bank := self.myBusinessUnit;
	
	if bank = null then
		return;
	endif;
	
	// Contract From Start Date
	if self.contractFromStartDate.isValid() then
		contract := bank.allInvoiceContractsByFromTS.getAtKeyGeq(self.contractFromStartDate.TimeStamp);
		
		if contract = null then
			return;
		endif;
		
		iter := bank.allInvoiceContractsByFromTS.createIterator();
		iter.startAtObject(contract);
		
		while iter.next(contract) do : outerloop
			if self.contractFromEndDate.isValid() then
				if contract.fromTS.date() &gt; self.contractFromEndDate then
					break outerloop;
				endif;
			endif;
			
			if not self.includeContract(contract, true) then
				continue;
			endif;
			
			self.allContracts.add(contract);
			
		endwhile;
		
		delete iter;
		
		return;
	endif;
	
	
	// Contract From End End
	if self.contractFromEndDate.isValid() then
		contract := bank.allInvoiceContractsByFromTS.first();
		
		if contract = null then
			return;
		endif;
		
		iter := bank.allInvoiceContractsByFromTS.createIterator();
		iter.startAtObject(contract);
		
		while iter.next(contract) do : outerloop
			if contract.fromTS.date() &gt; self.contractFromEndDate then
				break outerloop;
			endif;
			
			if not self.includeContract(contract, true) then
				continue;
			endif;
			
			self.allContracts.add(contract);
			
		endwhile;
		
		delete iter;
		
		return;
	endif;
	
	// Contract To Start Date
	if self.contractToStartDate.isValid() then
		contract := bank.allInvoiceContractsByToTS.getAtKeyGeq(self.contractToStartDate.TimeStamp);
		
		if contract = null then
			return;
		endif;
		
		iter := bank.allInvoiceContractsByToTS.createIterator();		
		iter.startAtObject(contract);
		
		while iter.next(contract) do : outerloop
			if self.contractToEndDate.isValid() then
				if contract.toTS.date() &gt; self.contractToEndDate then
					break outerloop;
				endif;
			endif;
			
			if not self.includeContract(contract, true) then
				continue;
			endif;
			
			self.allContracts.add(contract);
			
		endwhile;
		
		delete iter;
		
		return;
	endif;
	
	// Contract To End Date
	if self.contractToEndDate.isValid() then
		contract := bank.allInvoiceContractsByToTS.first();
		
		if contract = null then
			return;
		endif;
		
		iter := bank.allInvoiceContractsByToTS.createIterator();
		iter.startAtObject(contract);
		
		while iter.next(contract) do : outerloop
			if contract.toTS.date() &gt; self.contractToEndDate then
				break outerloop;
			endif;
			
			if not self.includeContract(contract, true) then
				continue;
			endif;
			
			self.allContracts.add(contract);
			
		endwhile;
		
		delete iter;
		
		return;
	endif;
	
epilog
	delete iter;
end;</source>
    </JadeMethod>
    <JadeMethod name="getContractsForDebtors" id="f7df6ca5-12ad-46da-989c-c1ce73e3327b">
        <source>getContractsForDebtors();
/*
Purpose:			

Date		Who		Reason
// 24/04/2023	navkc1	CR 55654 Task 55670: Jade - Contract reporting
*/

vars
	contract 	: CM_InvoiceContract;
	debtor 		: CM_Debtor;
begin
	
	foreach debtor in self.allDebtors discreteLock do
		foreach contract in debtor.allInvoiceContracts discreteLock do
			
			if not self.includeContract(contract, true) then
				continue;
			endif;
			
			self.allContracts.add(contract);
			
		endforeach;
	endforeach;
	
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="getContractsForDetailDates" id="0af320c5-1cf3-4d73-80ef-6ddd5093367d">
        <source>getContractsForDetailDates();
/*
Purpose:			

Date		Who		Reason
// 24/04/2023	navkc1	CR 55654 Task 55670: Jade - Contract reporting
// 22/11/2023	navkc1 Bug 61266: FR | 54089 - EUP - Invoice Contracts - Reporting
*/

vars
	debtor 		: CM_Debtor;
	contract 	: CM_InvoiceContract;
	detail 		: CM_InvoiceContractDetails;
	iter 		: Iterator;
	contractSet : CM_InvoiceContractSet;
	bank		: CM_Bank;
	addDetail	: Boolean; // 22/11/2023	navkc1 Bug 61266
begin
	create contractSet transient;
	
	bank := self.myBusinessUnit;
	
	if bank = null then
		return;
	endif;
	
	addDetail := self.isDetailDatesEntered();
	
	// Details From Start Date
	// Details From End Date
	if self.detailsFromStartDate.isValid() or
		self.detailsFromEndDate.isValid() then
		if self.detailsFromStartDate.isValid() then
			detail := bank.allInvoiceContractDetailByFrom.getAtKeyGeq(self.detailsFromStartDate.TimeStamp);
		endif;
		
		if detail = null then
			detail := bank.allInvoiceContractDetailByFrom.first;
		endif;
		
		if detail = null then
			return;
		endif;
		
		iter := bank.allInvoiceContractDetailByFrom.createIterator();
		iter.startAtObject(detail);
		
		while iter.next(detail) do : outerloop
			if self.detailsFromEndDate.isValid() then
				if detail.fromTS.date &gt; self.detailsFromEndDate then
					break outerloop;
				endif;
			endif;
			
			if not self.includeDetail(detail, false) then
				continue;
			endif;
			
			contract := detail.myInvoiceContract;
			contractSet.tryAdd(contract);
			
			if addDetail then
				self.allContractDetails.tryAdd(detail); // 22/11/2023	navkc1 Bug 61266
			endif;
		endwhile;
		
		delete iter;
	// Details To Start Date
	// Details To End Date
	elseif self.detailsToStartDate.isValid() or
		self.detailsToEndDate.isValid() then
		
		if self.detailsToStartDate.isValid() then
			detail := bank.allInvoiceContractDetailByTo.getAtKeyGeq(self.detailsToStartDate.TimeStamp);
		endif;
		
		if detail = null then
			detail := bank.allInvoiceContractDetailByTo.first;
		endif;
		
		if detail = null then
			return;
		endif;
		
		iter := bank.allInvoiceContractDetailByTo.createIterator();
		iter.startAtObject(detail);
		
		while iter.next(detail) do : outerloop
			if self.detailsToEndDate.isValid() then
				if detail.toTS.date &gt; self.detailsToEndDate then
					break outerloop;
				endif;
			endif;
			
			if not self.includeDetail(detail, false) then
				continue;
			endif;
			
			contract := detail.myInvoiceContract;
			contractSet.tryAdd(contract);
			
			if addDetail then
				self.allContractDetails.tryAdd(detail); // 22/11/2023	navkc1 Bug 61266
			endif;
		endwhile;
		
		delete iter;
	endif;
	
	foreach contract in contractSet discreteLock do
		
		if not self.includeContract(contract, false) then
			continue;
		endif;
		
		self.allContracts.add(contract);
	endforeach;
	
epilog
	delete iter;
	delete contractSet;

end;</source>
    </JadeMethod>
    <JadeMethod name="getContractsForId" id="e470b513-17dc-4d52-b1bf-69101a4adb69">
        <source>getContractsForId();
/*
Purpose:			

Date		Who		Reason
// 24/04/2023	navkc1	CR 55654 Task 55670: Jade - Contract reporting
*/

vars
	contract 	: CM_InvoiceContract;
	iter 		: Iterator;
	bank		: CM_Bank;
begin
	
	bank := self.myBusinessUnit;
	
	if bank = null then
		return;
	endif;
	
	contract := bank.allInvoiceContractsById[self.contractId,null];
	
	if contract &lt;&gt; null then
		iter := bank.allInvoiceContractsById.createIterator();
		iter.startAtObject(contract);
		
		while iter.next(contract) do : outerloop
			if contract.contractId &lt;&gt; self.contractId then
				break;
			endif;
			
			if not self.includeContract(contract, true) then
				continue;
			endif;
			
			self.allContracts.add(contract);
		endwhile;
		
	else 
		foreach contract in bank.allInvoiceContractsById discreteLock do
			
			if not self.includeContract(contract, true) then
				continue;
			endif;
			
			self.allContracts.add(contract);
		endforeach;
	endif;

epilog
	delete iter;
end;</source>
    </JadeMethod>
    <JadeMethod name="getContractsForRateDates" id="345f7649-3b1b-44ec-9490-248120b60fa2">
        <source>getContractsForRateDates();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
// 24/04/2023	navkc1	CR 55654 Task 55670: Jade - Contract reporting
// 22/11/2023	navkc1 Bug 61266: FR | 54089 - EUP - Invoice Contracts - Reporting
16 Oct 2024 navlc30 JIRA 19508 UI - Contract Enquiry extra tables for results
*/

vars
	rate 		: CM_InvoiceContractRate;
	rateEntry 	: CM_InvoiceContractRateEntry;
	contract 	: CM_InvoiceContract;
	detail 		: CM_InvoiceContractDetails;
	iter 		: Iterator;
	contractSet : CM_InvoiceContractSet;
	bank		: CM_Bank;
	addRate		: Boolean; // 22/11/2023	navkc1 Bug 61266
	addDetail	: Boolean; // 22/11/2023	navkc1 Bug 61266
begin
	create contractSet transient;
	
	bank := self.myBusinessUnit;
	
	if bank = null then
		return;
	endif;
	
	// 22/11/2023	navkc1 Bug 61266
	addRate := self.isRateDatesEntered();
	addDetail := self.isDetailDatesEntered();
	
	// Rate From Start Date
	// Rate From End Date
	if self.rateFromStartDate.isValid() 
	or self.rateFromEndDate.isValid() then
		if self.rateFromStartDate.isValid() then
			rateEntry := bank.allInvoiceContractRteEntByFrom.getAtKeyGeq(self.rateFromStartDate.TimeStamp);
		else
			rateEntry := bank.allInvoiceContractRteEntByFrom.first;
		endif;
		
		if rateEntry = null then
			return;
		endif;
		
		iter := bank.allInvoiceContractRteEntByFrom.createIterator();
		iter.startAtObject(rateEntry);
		
		while iter.next(rateEntry) do : outerloop
			if self.rateFromEndDate.isValid() then
				if rateEntry.fromTS.date() &gt; self.rateFromEndDate then
					break outerloop;
				endif;
			endif;
			
			if not self.includeRateEntry(rateEntry) then
				continue;
			endif;
			
			rate := rateEntry.myInvoiceContractRate;
			
			if not self.includeRate(rate,false) then
				continue;
			endif;
			
			detail := rate.myInvoiceContractDetail;
			contract := detail.myInvoiceContract;
			contractSet.tryAdd(contract);
			
			if addRate then
				self.allContractRateEntries.tryAdd(rateEntry); // 22/11/2023	navkc1 Bug 61266
			endif;
			
			//if addDetail and self.includeDetail(detail, false) then				//16.10.2024 navlc30 #19508
			if self.includeDetail(detail, false) then								//16.10.2024 navlc30 #19508			
				self.allContractDetails.tryAdd(detail); // 22/11/2023	navkc1 Bug 61266
			endif;
		endwhile;
		
		delete iter;
	
	// Rate To Start Date
	// Rate To End Date
	elseif self.rateToStartDate.isValid()
	or self.rateToEndDate.isValid() then
		if self.rateToStartDate.isValid() then
			rateEntry := bank.allInvoiceContractRteEntByTo.getAtKeyGeq(self.rateToStartDate.TimeStamp);
		else
			rateEntry := bank.allInvoiceContractRteEntByTo.first();
		endif;
		
		if rateEntry = null then
			return;
		endif;
		
		iter := bank.allInvoiceContractRteEntByTo.createIterator();
		iter.startAtObject(rateEntry);
		
		while iter.next(rateEntry) do : outerloop
			if self.rateToEndDate.isValid() then
				if rateEntry.toTS.date() &gt; self.rateToEndDate then
					break outerloop;
				endif;
			endif;
			
			if not self.includeRateEntry(rateEntry) then
				continue;
			endif;
			
			rate := rateEntry.myInvoiceContractRate;
			
			if not self.includeRate(rate,false) then
				continue;
			endif;
			
			detail := rate.myInvoiceContractDetail;
			contract := detail.myInvoiceContract;
			contractSet.tryAdd(contract);
			
			if addRate then
				self.allContractRateEntries.tryAdd(rateEntry); // 22/11/2023	navkc1 Bug 61266
			endif;
			
			//if addDetail and self.includeDetail(detail, false) then						//16.10.2024 navlc30 #19508
			if self.includeDetail(detail, false) then										//16.10.2024 navlc30 #19508			
				self.allContractDetails.tryAdd(detail); // 22/11/2023	navkc1 Bug 61266
			endif;
		endwhile;
		
		delete iter;
		
	endif;

	
	foreach contract in contractSet discreteLock do
		
		if not self.includeContract(contract, false) then
			continue;
		endif;
		
		self.allContracts.add(contract);
	endforeach;
	
epilog
	delete iter;
	delete contractSet;
end;</source>
    </JadeMethod>
    <JadeMethod name="getMyBusinessUnit" id="f03f1053-752c-45f0-8d53-71ae92369bce">
        <source>getMyBusinessUnit() : CM_Bank;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 12 May 2023	navdap1		Initial creation TFS 
//
vars
	object : CM_Bank;
	edition : Integer;
	invalidObj : Boolean;

begin
	object := self.myBusinessUnit;

	if object = null then
		return null;
	endif;
	
	on Exception do app.handleDeletedObject( exception, object, invalidObj );
	edition := object.edition;
	
	if invalidObj then
		return null;
	endif;
	
	return object;
epilog

end;</source>
        <ReturnType type="CM_Bank"/>
    </JadeMethod>
    <JadeMethod name="getOIDAndDescForAttribute" id="31521ffd-dec0-4b8d-9321-8dc86d6e8a1f">
        <source>getOIDAndDescForAttribute(_attrName: String; _getCalculatedDate: Boolean; _oid: String output): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
// 24/04/2023	navkc1	CR 55654 Task 55670: Jade - Contract reporting

*/

vars
	debtor	 	: CM_Debtor;
	invLineType : CM_InvoiceLineDesc;
	service		: CM_Service;
	calType		: CM_CalculationType;
	uom			: CM_InvoiceUnitOfMeasure;
	bank		: CM_Bank;
begin
	
	if _attrName = ETRow_Active then
		
		return self.isActive.cnEcGetTableCheckBoxValue();
		
	elseif _attrName = ETRow_Company then
		
		bank := self.myBusinessUnit;
		
		if bank &lt;&gt; null then
			_oid := bank.getOidAsString();
			return bank.getNameWithTerminalString();
		endif;
		
	elseif _attrName = ETRow_ContractFromStartDate then
		
		return self.contractFromStartDate.asStringJMT();
		
	elseif _attrName = ETRow_ContractFromEndDate then
		
		return self.contractFromEndDate.asStringJMT();
		
	elseif _attrName = ETRow_ContractId then
		
		return self.contractId;
		
	elseif _attrName = ETRow_ContractToStartDate then
		
		return self.contractToStartDate.asStringJMT();
		
	elseif _attrName = ETRow_ContractToEndDate then
		
		return self.contractToEndDate.asStringJMT();
		
	elseif _attrName = ETRow_Debtor then
		
		debtor := self.allDebtors.first();
		
		if debtor &lt;&gt; null then
			_oid := debtor.getOidAsString();
			return debtor.name;
		endif;
		
	elseif _attrName = ETRow_Description then
		
		return self.description;
		
	elseif _attrName = ETRow_DetailFromStartDate then
		
		return self.detailsFromStartDate.asStringJMT();
		
	elseif _attrName = ETRow_DetailFromEndDate then
		
		return self.rateToEndDate.asStringJMT();
		
	elseif _attrName = ETRow_CalculationType then
		
		calType := self.allCalculationTypes.first();
		
		if calType &lt;&gt; null then
			_oid := calType.getOidAsString();
			return calType.code;
		endif;
		
	elseif _attrName = ETRow_DetailToStartDate then
		
		return self.detailsToStartDate.asStringJMT();
		
	elseif _attrName = ETRow_DetailToEndDate then
		
		return self.detailsToEndDate.asStringJMT();
		
	elseif _attrName = ETRow_InvLineType then
		
		invLineType := self.allInvoiceLineTypes.first();
		
		if invLineType &lt;&gt; null then
			_oid := invLineType.getOidAsString();
			return invLineType.getDescriptionWithTerminalStr();
		endif;
		
	elseif _attrName = ETRow_Primary then
		
		return self.isPrimary.cnEcGetTableCheckBoxValue();
		
	elseif _attrName = ETRow_RateFromStartDate then
		
		return self.rateFromStartDate.asStringJMT();
		
	elseif _attrName = ETRow_RateFromEndDate then
		
		return self.rateFromEndDate.asStringJMT();
		
	elseif _attrName = ETRow_RateToStartDate then
		
		return self.rateToStartDate.asStringJMT();
		
	elseif _attrName = ETRow_RateToEndDate then
		
		return self.rateToEndDate.asStringJMT();
		
	elseif _attrName = ETRow_Service then
		
		service := self.allRateServices.first();
		
		if service &lt;&gt; null then
			_oid := service.getOidAsString();
			return service.name;
		endif;
		
	elseif _attrName = ETRow_UnitOfMeasureCode then
		
		uom := self.allUnitOfMeasures.first();
		
		if uom &lt;&gt; null then
			_oid := uom.getOidAsString();
			return uom.code;
		endif;
		
	endif;
	
	return inheritMethod(_attrName, _getCalculatedDate, _oid);

epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_getCalculatedDate" type="Boolean"/>
        <Parameter name="_oid" type="String" usage="output"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="includeContract" id="57e88b74-9bd8-4a53-b52a-1b5619a4056d">
        <source>includeContract(_contract : CM_InvoiceContract; _checkDetails : Boolean) : Boolean;
/*
Purpose:			

Date		Who		Reason
// 24/04/2023	navkc1	CR 55654 Task 55670: Jade - Contract reporting
*/

vars
	invalid,
	detailOK 	: Boolean;
	contDetail 	: CM_InvoiceContractDetails;
begin
	on Exception do app.handleDeletedObject(exception, _contract, invalid);

	if not self.allDebtors.isEmpty()
	and not self.allDebtors.includes(_contract.myDebtor) then
		return false;
	endif;
	
	if invalid then
		return false;
	endif;
	
	if self.isPrimary then
		if not _contract.primary then
			return false;
		endif;
	endif;
	
	if self.isActive then
		if not _contract.active then
			return false;
		endif;
	endif;
	
	if self.contractId &lt;&gt; "" then
		if _contract.contractId.toUpper().pos(self.contractId,1) &lt; 1 then
			return false;
		endif;
	endif;
	
	if self.description &lt;&gt; "" then
		if _contract.description.toUpper().pos(self.description,1) &lt; 1 then
			return false;
		endif;
	endif;

	if self.contractFromStartDate.isValid() then
		if _contract.fromTS.date() &lt; self.contractFromStartDate then
			return false;
		endif;
	endif;
	
	if self.contractFromEndDate.isValid() then
		if _contract.fromTS.date() &gt; self.contractFromEndDate then
			return false;
		endif;
	endif;
	
	if self.contractToStartDate.isValid() then
		if _contract.toTS.date() &lt; self.contractToStartDate then
			return false;
		endif;
	endif;
	
	if self.contractToEndDate.isValid() then
		if _contract.toTS.date() &gt; self.contractToEndDate then
			return false;
		endif;
	endif;

	if _checkDetails
	and _contract.allInvoiceContractDetails.isNotEmpty() then
		detailOK := false;
		foreach contDetail in _contract.allInvoiceContractDetails discreteLock do
			if self.includeDetail(contDetail, true) then
				detailOK := true;
				break;
			endif;
		endforeach;
		
		if not detailOK then 
			return false;
		endif;
	endif;
	return true;
epilog

end;</source>
        <Parameter name="_contract" type="CM_InvoiceContract"/>
        <Parameter name="_checkDetails" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="includeDetail" id="f16ca11b-3fd4-4e3e-ad3e-232cf8bf6e0c">
        <source>includeDetail(_detail : CM_InvoiceContractDetails; _includeRates : Boolean) : Boolean;
/*
Purpose:			

Date		Who		Reason
// 24/04/2023	navkc1	CR 55654 Task 55670: Jade - Contract reporting
// 22/11/2023	navkc1 Bug 61266: FR | 54089 - EUP - Invoice Contracts - Reporting
*/

vars
	rate 			: CM_InvoiceContractRate;
	rateOK,
	hasRateEntries 	: Boolean;
	
begin

	if self.detailsFromStartDate.isValid() then
		if _detail.fromTS.date() &lt; self.detailsFromStartDate then
			return false;
		endif;
	endif;
	
	if self.detailsFromEndDate.isValid() then
		if _detail.fromTS.date() &gt; self.detailsFromEndDate then
			return false;
		endif;
	endif;
	
	if self.detailsToStartDate.isValid() then
		if _detail.toTS.date() &lt; self.detailsToStartDate then
			return false;
		endif;
	endif;
	
	if self.detailsToEndDate.isValid() then
		if _detail.toTS.date() &gt; self.detailsToEndDate then
			return false;
		endif;
	endif;
	
	if self.allInvoiceLineTypes &lt;&gt; null
	and not self.allInvoiceLineTypes.isEmpty()
	and not self.allInvoiceLineTypes.includes(_detail.myInvoiceLineType) then
		return false;
	endif;
	
	if self.allCalculationTypes.isNotEmpty() and
	_detail.myCalculationType &lt;&gt; null and
	not self.allCalculationTypes.includes(_detail.myCalculationType) then
		return false;
	endif;
	
	if self.allUnitOfMeasures.isNotEmpty() and
	_detail.myUnitOfMeasure &lt;&gt; null and
	not self.allUnitOfMeasures.includes(_detail.myUnitOfMeasure) then
		return false;
	endif;
	
	// 22/11/2023	navkc1 Bug 61266
	if self.isVolBased then
		if not _detail.isVolumeBased() then
			return false;
		endif;
	endif;
	
	if _includeRates 
	and _detail.allInvoiceContractRates.isNotEmpty() then
		rateOK := false;
		hasRateEntries := false;
		
		foreach rate in _detail.allInvoiceContractRates discreteLock do
			if rate.allInvoiceContractRateEntries.isEmpty() then
				continue;
			endif;
			
			hasRateEntries := true;
			
			if self.includeRate(rate, _includeRates) then
				rateOK := true;
				break;
			endif;
		endforeach;
		
		if not hasRateEntries then
			return true;
		endif;
		
		if not rateOK then 
			return false;
		endif;	
	endif;
	
	return true;
	
epilog

end;</source>
        <Parameter name="_detail" type="CM_InvoiceContractDetails"/>
        <Parameter name="_includeRates" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="includeRate" id="3b3264de-3e33-4415-b034-734f5eea88d6">
        <source>includeRate(_rate : CM_InvoiceContractRate; _includeEntries : Boolean) : Boolean;
/*
Purpose:			

Date		Who		Reason
// 24/04/2023	navkc1	CR 55654 Task 55670: Jade - Contract reporting
*/

vars
	rateEntry 	: CM_InvoiceContractRateEntry;
	includeRate : Boolean;
begin
	
	if self.allRateServices &lt;&gt; null
	and not self.allRateServices.isEmpty()
	and not self.allRateServices.includes(_rate.myService) then
		return false;
	endif;

	if _includeEntries then
		includeRate := false;
		
		foreach rateEntry in _rate.allInvoiceContractRateEntries discreteLock do
			if self.includeRateEntry(rateEntry) then
				includeRate := true;
				break;
			endif;
		endforeach;
		
		return includeRate;
	endif;

	return true;
epilog

end;</source>
        <Parameter name="_rate" type="CM_InvoiceContractRate"/>
        <Parameter name="_includeEntries" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="includeRateEntry" id="14aac4c5-fd94-4ee2-8689-774ec600f9a3">
        <source>includeRateEntry(rateEntry : CM_InvoiceContractRateEntry) : Boolean;
/*
Purpose:			

Date		Who		Reason
// 24/04/2023	navkc1	CR 55654 Task 55670: Jade - Contract reporting
14 Oct 2024 navlc30 JIRA 19508 UI - Contract Enquiry extra tables for results
*/

vars

begin

	if rateEntry.costPerUnit &lt; self.rateAmountFrom				//14.10.2024 navlc30 #19508
	or rateEntry.costPerUnit &gt; self.rateAmountTo then
		return false;
	endif;
	
	if self.rateFromStartDate.isValid() then
		if rateEntry.fromTS.date &lt; self.rateFromStartDate then
			return false;
		endif;
	endif;
	
	if self.rateFromEndDate.isValid() then
		if rateEntry.fromTS.date &gt; self.rateFromEndDate then
			return false;
		endif;
	endif;
	
	if self.rateToStartDate.isValid() then
		if rateEntry.toTS.date() &lt; self.rateToStartDate then
			return false;
		endif;
	endif;
	
	if self.rateToEndDate.isValid() then
		if rateEntry.toTS.date() &gt; self.rateToEndDate then
			return false;
		endif;
	endif;
	
	return true;
epilog

end;</source>
        <Parameter name="rateEntry" type="CM_InvoiceContractRateEntry"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isDetailDatesEntered" id="54aefd33-d384-4258-8a52-17a7b783e174">
        <source>isDetailDatesEntered() : Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22/11/2023	navkc1 Bug 61266: FR | 54089 - EUP - Invoice Contracts - Reporting

*/

vars

begin
	return self.detailsFromStartDate.isValid() or self.detailsFromEndDate.isValid() or self.detailsToStartDate.isValid() or self.detailsToEndDate.isValid();
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
