    <JadeMethod name="verifyReleaseStevedore" id="3b358c23-776b-41a2-be12-2a1eb0454034">
        <source>verifyReleaseStevedore()protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 Oct 2020 cnwma1 ChangeRequest 50112: ASPA - GCI Stevedores
*/

vars
	stevedoreObj : CM_Stevedore;
begin
	if self.releaseStevedore = null then
		return;
