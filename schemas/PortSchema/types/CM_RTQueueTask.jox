    <JadeMethod name="setForCreate" id="970234da-7c01-4d2c-b766-9117e1297d0e">
        <updating/>
        <source>setForCreate(proxyTask : CM_RTQueueTask input) updating;
/*
 ------------------------------------------------------------------------
Created:			28 August 2002 by cnwdwq1
Purpose:			
Parameters:		None
Returns:			Nothing
Changed On		Changed By		Reason
--------------		--------------		-----------------------------------------
---------------------------------------------------------------------------
*/
vars

begin
	proxyTask.raiseExceptionIfNotTransient(method);

	self.isOverstowTask := proxyTask.isOverstowTask;
	self.myEntry := proxyTask.myEntry;
	self.queue := proxyTask.queue;
	
	self.setDetails(	proxyTask.sourceLocation, 
						proxyTask.targetLocation,
						proxyTask.status,
						proxyTask.taskType,
						 proxyTask.ti);
						 
	
	self.targetLocationPreSwap := proxyTask.targetLocationPreSwap;
	self.targetLocationQualifier := proxyTask.targetLocationQualifier;
	
end;</source>
        <Parameter name="proxyTask" type="CM_RTQueueTask" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setMachine" id="678f81b7-f33b-4939-b833-01fb8d32bbbb">
        <updating/>
        <source>setMachine(_machine : CM_Machine) updating;
/*
 ------------------------------------------------------------------------
Created:			24 April 2002 by cnwdwq1
Purpose:			
Parameters:			None
Returns:			Nothing
Changed On			Changed By			Reason
--------------		--------------		-----------------------------------
11 Jul 2008			cnwkpd1/cnwer1		PAR #17278 - Remove unnecessary unlock - can
										result in error 4 following aborted create
31/08/2010			cnwcs5				par 25313 - update self.myMachine
23/12/2014			cnwdap1				PAR #35451 Avoid 1090 if machine manages (somehow) to lose its status
---------------------------------------------------------------------------
*/

vars
	tmpMachine : CM_Machine;
begin
	exclusiveLock(self);
	
	if self.machine = _machine then
		return;
	endif;
	
	tmpMachine:=self.machine;
	
	if self.machine &lt;&gt; null then
		//Remove inverse.
		if _machine = null then
			if self.machine.myNextPrimaryQueue &lt;&gt; null then
				self.machine.doDelayedMoveToQueue();
			endif;
		endif;
		self.machine := null;
	endif;

	self.machine := _machine;
	self.setAssignedDT();
	
	// self.myMachine will contain the machine that worked the task - even after
	// task has been completed
	if _machine &lt;&gt; null then			// 31/08/2010 cnwcs5 par25313
		self.myMachine	:= _machine;	// 31/08/2010 cnwcs5 par25313
	endif;								// 31/08/2010 cnwcs5 par25313

	//epr par 18991 6/3/09
	if self.machine = null and tmpMachine &lt;&gt; null then
		if  tmpMachine.allCurrentQueueTasks.size = 0 then
				tmpMachine.setMachineStatus(STATUS_IDLE,"",false);
		endif;
	//epr par 25873 28/9/10
	//elseif  self.machine &lt;&gt; null and tmpMachine = null and self.machine.status.status = STATUS_IDLE then									// PAR #35451
	elseif  self.machine &lt;&gt; null and tmpMachine = null and (self.machine.status = null or self.machine.status.status = STATUS_IDLE) then	// PAR #35451
		if  self.machine.allCurrentQueueTasks.size &gt; 0 then
			self.machine.setMachineStatus(STATUS_ASSIGNED,"",false);
			self.machine.setMachineStatus(STATUS_WORKING,"",false);
		endif;
	endif;
	
epilog
//	unlock(self);		// PAR #17278
end;</source>
        <Parameter name="_machine" type="CM_Machine"/>
    </JadeMethod>
    <JadeMethod name="setMyBestPickTI" id="bcb97b50-2e99-4800-82f0-af99f2421c42">
