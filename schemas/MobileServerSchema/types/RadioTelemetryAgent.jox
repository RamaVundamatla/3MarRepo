    <JadeMethod name="setdownWithTask" id="c8e1d93e-1f1d-489d-bda4-b04d997633d6">
        <updating/>
        <source>setdownWithTask(_setDownLocation : String; _dto : DTO_EnquiryGradingTasks input; _tandemTIid : String; _stateInfo : DTO_StateInfo input) : Boolean updating;
// -------------------------------------------
// Created 12 January 2006 by cnwdvb1
// -------------------------------------------
vars

	passport	: CM_Passport;
	task		: CM_RTQueueTask;

begin

	// Have changed code so warnings should have appeared during pick up.
	passport := app.myPassport;
	passport.warningsAcknowledged := true;

	 app.myTrxRT.trxSetdownWithTask(self.myMediator, _setDownLocation, _tandemTIid, null, passport);
	
	if not passport.trxCompletedOK then
		_stateInfo.errorString :=  passport.getAllErrorsWarningsAsString();
		_stateInfo.guiState	:= self.Error;
		return false;
	endif;
	
	//epr CCMS 1032 refactored to remove returning integerif extraInfo = 1 then
	if self.myMediator.machine.currentQueueTask &lt;&gt; null then
	
		// Overstow stuff.
		_dto.setFromMediator(self.myMediator);
		self.setMediatorState(self.AcceptedTask);
		_stateInfo.guiState	:= self.AcceptedTask;	
	else
		_dto.setFromTI(self.myMediator.myCurrentTi);
		self.setMediatorState(self.LoggedOn_Reset);
		_stateInfo.guiState	:= self.LoggedOn_Reset;	
	endif;
	return true;
epilog
	_stateInfo.hasWarningsOnly := ((not passport.hasErrors) and (passport.hasWarnings));
end;</source>
        <Parameter name="_setDownLocation" type="String"/>
        <Parameter name="_dto" type="DTO_EnquiryGradingTasks" usage="input"/>
        <Parameter name="_tandemTIid" type="String"/>
        <Parameter name="_stateInfo" type="DTO_StateInfo" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="updateGradeForTI" id="9fb7c441-773d-47e5-9124-526a3a68e7f1">
        <updating/>
        <source>updateGradeForTI(_grade : Integer; _dto : DTO_EnquiryGradingTasks input; _stateInfo : DTO_StateInfo input) : Boolean updating;
// -------------------------------------------
// Created 23 January 2006 by cnwdvb1
// -------------------------------------------
vars

	passport	: CM_Passport;

begin

	passport := app.myPassport;
	passport.warningsAcknowledged := _stateInfo.warningsAcknowledged;
	
	app.myTrxRT.trxUpdateGradeForTI(_grade, self.myMediator, passport);
	if not passport.trxCompletedOK then
		_stateInfo.errorString :=  passport.getAllErrorsWarningsAsString();
		_stateInfo.guiState	:= self.Error;
		return false;
	endif;
	
	_dto.setFromTI(self.myMediator.myCurrentTi);
	
	self.setMediatorState(self.Display_TI);
	_stateInfo.guiState	:= self.Display_TI;
		
	return true;

epilog
	_stateInfo.hasWarningsOnly := ((not passport.hasErrors) and (passport.hasWarnings));
end;</source>
        <Parameter name="_grade" type="Integer"/>
        <Parameter name="_dto" type="DTO_EnquiryGradingTasks" usage="input"/>
        <Parameter name="_stateInfo" type="DTO_StateInfo" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="updateToDoTaskTs" id="50e873f3-22f1-4b5f-88ce-085cbe769e9e">
