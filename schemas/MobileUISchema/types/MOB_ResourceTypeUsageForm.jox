    <JadeMethod name="doEditSave" id="82cac363-3e4f-4538-aa72-3a89a3eef11a">
        <updating/>
        <source>doEditSave(_editForm : MOB_ResourceTypeEditForm input) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
15 February 2010	#cnwdz2	 
08 June 2016	cnwns1	TFS 488 - Multi Timezone Support
08 Mar 2019 cnwma1	Ticket 43624: ADP - TO Resource Quantity gets truncated.
*/

vars
	proxy 			: CM_ResourceTypeUsage;
	realUsage 		: CM_ResourceTypeUsage;
	resourceType 	: CM_ResourceType;
	noCharge 		: Boolean;
	quantity 		: Decimal [23,4];
	remarks 		: String;
	lFromDateTime,
	lToDateTime		: TimeStamp;
	errorMsg	    : String;
	palletType 		: CM_PalletType;
	isHeatTreated   : Boolean;
	isStoreOnPallet : Boolean;
	
begin
	// populate local variables with the data.
	resourceType := _editForm.cmbResourceType.listObject.CM_ResourceType;
	//quantity := _editForm.txtQuantity.text.Decimal;
	quantity := _editForm.txtQuantity.text.asDecimalJMT();// 01 APR 2010	NDL	Par 23556
	noCharge := _editForm.chkNoCharge.value;
	remarks := _editForm.txtRemarks.text;
	
	//cnwmc5 - 22 Sep 2015 - PAR 36920
	lFromDateTime.setDate(_editForm.txtFromDate.getDate(errorMsg));
	if errorMsg &lt;&gt; null then
		app.msgBox(_editForm.lblFromDateTime.caption &amp; " : " &amp; errorMsg, app.getErrorString(Error), 0);
		return;
	endif;
	lFromDateTime.setTime(_editForm.txtFromTime.getTime(errorMsg));
	if errorMsg &lt;&gt; null then
		app.msgBox(_editForm.lblFromDateTime.caption &amp; " : " &amp; errorMsg, app.getErrorString(Error), 0);
		return;
	endif;
	lToDateTime.setDate(_editForm.txtToDate.getDate(errorMsg));
	if errorMsg &lt;&gt; null then
		app.msgBox(_editForm.lblToDateTime.caption &amp; " : " &amp; errorMsg, app.getErrorString(Error), 0);
		return;
	endif;
	lToDateTime.setTime(_editForm.txtToTime.getTime(errorMsg));
	if errorMsg &lt;&gt; null then
		app.msgBox(_editForm.lblToDateTime.caption &amp; " : " &amp; errorMsg, app.getErrorString(Error), 0);
		return;
	endif;
	
	//18 Apr 2017	NDL	TFS 3414
	palletType := _editForm.cmbPalletType.listObject.CM_PalletType;
	isStoreOnPallet := _editForm.chkStoreOnP.value;	//21 Jan 2020	NDL TFS 48248
	isHeatTreated := _editForm.chkHeatTreated.value;	//21 Jan 2020	NDL TFS 48248
	
	_editForm.unloadForm();
	// if no current proxy to update, create new proxy.
	if self.myCurrentProxyUsage = null then
		create proxy transient;
		self.allNewProxyResourceTypeUsages.add(proxy);
	else
		proxy := self.myCurrentProxyUsage;
	endif;
	
	//update / populate the proxy
	proxy.setProxy(	resourceType,	//_resourceType : CM_ResourceType;
					null,	//_transaction : CM_Transaction;
					noCharge,	//_noCharge : Boolean;
					quantity,	//_quantity : Decimal;
					remarks,	//_remarks : String;
					0,	//_status : Integer
					self.localToSystemTime(lFromDateTime),		//cnwmc5 - 22 Sep 2015 - PAR 36920	// 08 June 2016	cnwns1	TFS 488 - Multi Timezone Support
					self.localToSystemTime(lToDateTime),		//cnwmc5 - 22 Sep 2015 - PAR 36920	// 08 June 2016	cnwns1	TFS 488 - Multi Timezone Support
					palletType,//_palletType : CM_PalletType;
					isHeatTreated,	//_isHeatTreated : Boolean;
					isStoreOnPallet	//_isStoreOnPallet : Boolean
					);
			
	if self.myCurrentProxyUsage &lt;&gt; null then
		realUsage := self.myCurrentProxyUsage.pxyGetRealObject().CM_ResourceTypeUsage;
		if realUsage &lt;&gt; null then
			if not realUsage.allInvoiceLines.isEmpty then
				app.msgBox( app.getErrorString(Changing_Invoiced_Resource), app.getErrorString(Warning), MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);				
			endif;
		endif;
	endif;
	
	//refresh the form
//	self.clearExtraInfo();
	self.loadDataToTable();
	self.btnOne.enabled := true;
epilog

end;</source>
        <Parameter name="_editForm" type="MOB_ResourceTypeEditForm" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doResizeControls" id="6593a0a1-c19f-4f16-8d8f-b18269c8ed94">
        <updating/>
        <source>doResizeControls(_initialSetup: Boolean) updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 February 2015	cnwndl1	Initial creation	Par 35604

*/

vars

	vTop : Real;
	vHeight : Real;
	stdHeight : Real;
	btnWidth : Real;
	btnTop : Real;
	btnHeight : Real;
	vLeft : Real;
	count : Integer;

begin

	self.setResizeableMarginAndFontSize();
	stdHeight := self.getStdControlHeight;
	
	inheritMethod(_initialSetup);
	
	btnWidth := self.btnOne.width;	
	btnHeight := self.btnOne.height;
	
	self.txtCargoId.move( self.resizedMargin,
						  self.resizedMargin,
						  self.clientWidth,
						  stdHeight );
						  
	if _initialSetup then
		self.txtCargoId.readOnly := true;
		if self.templateOnly then
			if self.myCallingForm &lt;&gt; null and myCallingForm.isKindOf(MOB_HHMultiCargoToDoComplete) then
				count := myCallingForm.MOB_HHMultiCargoToDoComplete.tblSelected.rows - 1;
			elseif self.myCallingForm &lt;&gt; null and myCallingForm.isKindOf(MOB_HHDocumentActions) then	//21 Sep 2016	NDL	TFS 2647 / 2001
				count := myCallingForm.MOB_HHDocumentActions.resourceTICount;
			endif;
			self.txtCargoId.text := app.getErrorString1(Num_Selected_items, count.String);
		else
			self.txtCargoId.text := self.myTrackedItem.id;
		endif;
	endif;

	vTop := self.txtCargoId.top + self.txtCargoId.height + self.resizedMargin;
	vHeight := self.btnOne.top - vTop - btnHeight - ( 4 * self.resizedMargin ) ;
	self.tblResources.move( self.resizedMargin, 
							vTop, 
							self.clientWidth - ( 2 * self.resizedMargin ),  
							vHeight
							);	
							
	self.tblResources.cnAdjustColumnWidths();
	
	vTop := self.tblResources.top + self.tblResources.height + 2* self.resizedMargin;
	if (( btnWidth + self.resizedMargin) * 3 ) + self.resizedMargin &gt; self.clientWidth then
		btnWidth := ( self.clientWidth - ( 4 * self.resizedMargin )) / 3;
		
		self.btnAdd.move(	self.resizedMargin,
							vTop,					 
							btnWidth,
							btnHeight
							);
		self.btnUpdate.move(self.btnAdd.left + btnWidth + self.resizedMargin,
							vTop,					 
							btnWidth,
							btnHeight
							);
		self.btnDelete.move(self.btnUpdate.left + btnWidth + self.resizedMargin,
							vTop,					 
							btnWidth,
							btnHeight
							);
	else
	
		self.btnDelete.move(	self.btnOne.left,
								vTop,					 
								btnWidth,
								btnHeight
								);
	//03 Mar 2017	NDL	TFS 3633							
	/*	self.btnUpdate.move(	self.btnTwo.left,
								vTop,					 
								btnWidth,
								btnHeight
								); */
		
		self.btnAdd.move(	self.resizedMargin, //self.btnTwo.left - btnWidth - self.resizedMargin,
							vTop,					 
							btnWidth,
							btnHeight
							);
							
		self.btnUpdate.move(	(self.clientWidth / 2 ) - ( btnWidth / 2 ),
								vTop,					 
								btnWidth,
								btnHeight
								);
								
	endif;
						 				 
	inheritMethod(_initialSetup);

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_initialSetup" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doTblResourcesClick" id="951e519b-3eff-42c7-bbc9-6ae534f87a7c">
        <updating/>
        <source>doTblResourcesClick()updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
16 February 2010	#cnwdz2	 

*/

vars
	proxyUsage : CM_ResourceTypeUsage;
	decPlaces : Integer;
	realUsage : CM_ResourceTypeUsage;
begin
	if self.tblResources.row &gt; self.tblResources.fixedRows and self.tblResources.row &lt;= self.tblResources.rows then
		proxyUsage := self.tblResources.accessRow(self.tblResources.row).itemObject.CM_ResourceTypeUsage;
	endif;
	
	if proxyUsage = null then
		return;
	endif;
	self.myCurrentProxyUsage := proxyUsage;
	
	realUsage := proxyUsage.pxyGetRealObject();
	if realUsage &lt;&gt; null then
		// no longer allowed to delete persistant usages.
		self.btnDelete.enabled := false;
	else
		self.btnDelete.enabled := true;
	endif;
	
	self.btnUpdate.enabled := true;
epilog

end;</source>
    </JadeMethod>
