    <JadeMethod name="sdlMoveContainerToVoyage" id="c8089f76-d046-429a-837f-80d4f0adf1b4">
        <updating/>
        <source>sdlMoveContainerToVoyage() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25 August 2017	jlgsl4	Initial creation, based on moveLogToVoyage

*/

//--------------------------------------------------
// Created:	02 February 2004 By: cnwgd1
//--------------------------------------------------
//'4496.4426'.asOid.CM_LogVoyageController.inspect;
//'4023.6646106'.asOid.CM_TrackedItem.inspect;
//CM_LogVoyage/4050.317

vars
	container : CM_TrackedItem;
	moveControl : CMIF_MoveController;
	voyage : CM_Voyage;
	locations : StringArray;
	slotControl : CM_LocationsController;
	index : Integer;
begin
	container := '2367.26977490'.asOid.CM_TrackedItem; // BAPLIEMAN01
	app.initialize();
	app.myPassport.setMyTerminal('2351.35'.asOid.CM_Terminal); //T01
	app.myPassport.setMyUserFromCode('SUPERUSER');
//	voyage := self.getVoyage("LYA0008");
	create locations transient;
	locations.add("070413");

	create moveControl transient;

	moveControl.isSystemMove 	:= true;
	moveControl.isForcedMove 	:= true;
	moveControl.setMoveMode(REAL_MODE);
	moveControl.setMyTrackedItem(container);
//	moveControl.setMyToPrimaryLocation('2286.2004383'.asOid.CM_SlotController); // LYA0008 -&gt; Bay 050113
//	moveControl.setMyOriginatingLocation('0931000008DC'.asOid.CM_BlockController); // QREPACK
	moveControl.setMyToPrimaryLocation('2286.2004440'.asOid.CM_SlotController); // LYA0008 -&gt; Bay 090413
	moveControl.setMyOriginatingLocation('2286.2004434'.asOid.CM_SlotController); // LYA0008 -&gt; Bay 090213
	//voyage.findLocation(locations, false, slotControl, index);
	//container := self.add
	beginTransaction;
//	container.changeVoyage('4480.9071'.asOid.CM_Voyage, app.myPassport);
	app.myUtilityUA.utlUpdateMoveTrackedItem(moveControl, app.myPassport);
	
	commitTransaction;

epilog
	delete moveControl;
	delete locations;
end;</source>
    </JadeMethod>
    <JadeMethod name="sdlMvmntPilotDetailsOrphans" id="8ba327b1-d456-4829-b1f2-80c9e4a01031">
        <updating/>
        <source>sdlMvmntPilotDetailsOrphans() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 Jun 2019	jlgsl4	TFS 45059 - PEL1 - tidy up orphaned movement pilot details objects

*/

vars
	movementPilotDetails : HMS_MovementPilotDetails;
	pilotLaunchDesc : String;
	isOK : Boolean;
begin
	app.initialize();
	app.writeLog(class.name &amp; '::' &amp; method.name &amp; " - Start Movement Pilot Details orphan cleanup *****", LogINFO);
	beginTransaction;
	foreach movementPilotDetails in HMS_MovementPilotDetails.instances where movementPilotDetails.myMovement = null do
		if movementPilotDetails.myPilotLaunch &lt;&gt; null then
			pilotLaunchDesc := movementPilotDetails.myPilotLaunch.description;
		else
			pilotLaunchDesc := "n.a.";
		endif;
		app.writeLog(class.name &amp; '::' &amp; method.name &amp; " *** Deleting orphan with pilot " &amp; movementPilotDetails.myPilot.description &amp;
			", launch " &amp; pilotLaunchDesc, LogINFO);
		delete movementPilotDetails;
	endforeach;
	commitTransaction;
	app.writeLog(class.name &amp; '::' &amp; method.name &amp; " - Finish Movement Pilot Details orphan cleanup *****", LogINFO);
	isOK := true;
epilog
	if not isOK then
		abortTransaction;
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="sdlNullifyMyPilot" id="955cf2b0-9faa-47ac-b039-c106570b5b48">
        <updating/>
        <source>sdlNullifyMyPilot() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 May 2019	jlgsl4	TFS 44438 - PEL1 - Multiple Pilot Launches for one movement

*/

vars
	voyageMovement : HMS_VoyageMovement;
	movementPilotDetails : HMS_MovementPilotDetails;
	samePilot : String;
begin
	app.initialize();
	foreach voyageMovement in HMS_VoyageMovement.instances where voyageMovement.myPilot &lt;&gt; null do
		samePilot := "not ";
		foreach movementPilotDetails in voyageMovement.allMovementPilotDetails where movementPilotDetails.myPilot = voyageMovement.myPilot do
			samePilot := "";
		endforeach;
		write "myPilot is " &amp; voyageMovement.myPilot.code &amp; " and it is " &amp; samePilot &amp; "in movementPilotDetails";
	endforeach;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="sdlRunBGPWSRequest" id="73977bb4-2e5f-4bbc-a610-cd58296c3c8b">
        <source>sdlRunBGPWSRequest();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 Mar 2019	jlgsl4	TFS 40360 - NXL - KiwiRail EDI message

*/

vars
	bgpRequest : BGP_Request;
	bgpController : BGP_ExternalWSController;
begin
	app.initialize();
	app.setIsBackGroundApp(true);
	foreach bgpController in BGP_ExternalWSController.instances do
		if global.isValidObject(bgpController.myExternalWSDef) and
		   bgpController.myExternalWSDef.isKindOf(CM_KiwiRailCheckInWSDef) then
			break;
		endif;
	endforeach;
	bgpRequest := BGP_KiwiRailWSRequest.instances.first.BGP_Request;
	process.profiler.methodCount := 50;
	process.profiler.start();
	app.myTrxUA.trxUpdateBGPControllerPre(bgpController, app.actualTimeServer, bgpRequest, app.myPassport);
	app.myBGPObject := bgpController;
	bgpRequest.action();
	process.profiler.stop();
	process.profiler.report();
	app.myTrxUA.trxUpdateBGPControllerPost(bgpController, app.myPassport);
epilog
	app.setIsBackGroundApp(false);
end;</source>
    </JadeMethod>
    <JadeMethod name="sdlSetHireDT" id="40099c4f-7285-4a56-9858-1fa6e7f20996">
        <updating/>
        <source>sdlSetHireDT() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 Feb 2018	jlgsl4	Initial creation
05 Oct 2022 navma1	Bug 52967: STWO - Cargo Delivery Process &amp; System Lock Details
21 June 2023 navmv20 CR 58373 Task 58381: Jade - Future Storage Additional Days
*/

vars
	container		: CM_TrackedItem;
	count 			: Integer;
	hiredate 		: TimeStamp;
	storageDetail 	: CM_StorageDetail;

begin
	//lastBegin := lastBegin.systemToLocalTime(app.actualTimeServer); // to make commits time-based...
	write "There are " &amp; CM_Container.instances.size.String &amp; " containers to examine";
	
	foreach container in CM_Container.instances discreteLock do
		count := count + 1;
		if count mod 50000 = 0 then
			write Tab &amp; "processed " &amp; count.String &amp; " containers ";
		endif;
		hiredate := container.hireDT;
		if hiredate &lt;&gt; null and container.plannedDT = null then // if hireDT is valid and plannedDT null, plannedDT := hireDT
			beginTransaction; // OK in dev, but could take long time in prod -&gt; move o/s foreach there...
				//container.setFutureStorageAnniversary(hiredate.Date,storageDetail);			//05.10.2022 navma1 #52967 //21/06/2023 navmv20 CR 58373 Task 58381
				container.setFutureStorageAnniversary(hiredate.Date,storageDetail,false); //21/06/2023 navmv20 CR 58373 Task 58381
			commitTransaction; // see above...
			write "Updated plannedDT for container " &amp; container.id.String;
		endif;
		//if lastBegin.systemToLocalTime(app.actualTimeServer) - lastBegin &gt; 
	endforeach;

	//isOk := true;
epilog
	//if not isOk then
	//	abortTransaction;
	//	write "** Aborted transaction! **";
	//endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="sdlSetZombieCashPmtMerged" id="5b8d6072-e772-423a-9ea7-febd5454a956">
        <updating/>
        <source>sdlSetZombieCashPmtMerged(_controller: CnEcReleaseController) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 Jul 2019	jlgsl4	TFS 44274 - JMT - Cash Credit
*/

vars
	cashPayment : CM_CashPayment;
	count : Integer;
	isOK : Boolean;
begin
	//if self.hasScriptBeenRunAtAll(method.name, null) then // upgrade-script specific
	//	return;
	//endif;
	app.myPassport.setMyUserFromCode(SUPERUSER_Str);

	app.writeLog(class.name &amp; '::' &amp; method.name &amp; " - Set zombie Cash Payments to Status_Merged start *************", LogINFO);
		if _controller &lt;&gt; null then
		_controller.logEntry(" Start Set zombie Cash Payments to Status_Merged");
	endif;

	beginTransaction;
	foreach cashPayment in CM_CashPayment.instances where cashPayment.voided and cashPayment.myTrackedItem &lt;&gt; null do
		if cashPayment.myTrackedItem.hasBeenMerged() then
			cashPayment.setStatus(CM_CashPayment.Status_Merged);
			count := count + 1;
		endif;
	endforeach;
	commitTransaction;

	app.writeLog(class.name &amp; '::' &amp; method.name &amp; " - Set zombie Cash Payments to Status_Merged done, updated " &amp; count.asStringJMT() &amp; " zombie-related cash payments *************", LogINFO);
	if _controller &lt;&gt; null then
		_controller.logEntry("Completed Set zombie Cash Payments to Status_Merged");
	endif;
	//self.addScriptRun(method.name);
	isOK := true;
epilog
	if not isOK then
		app.writeLog(class.name &amp; '::' &amp; method.name &amp; " - Set zombie Cash Payments to Status_Merged ERROR *************", LogINFO);
		abortTransaction;
	endif;
end;</source>
        <Parameter name="_controller" type="CnEcReleaseController"/>
    </JadeMethod>
    <JadeMethod name="sdlSetupIMEXtransition" id="317613c8-13f6-489a-ab8e-349a5c7459cf">
        <updating/>
        <source>sdlSetupIMEXtransition() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 April 2018	jlgsl4	Initial creation

*/

vars
	theTerminal : CM_Terminal;
	transitionProxy, transition: CM_IMEXTransitionCriteria;
	realTransition : CM_ObjectMatchCriteria;
	criteriaCargoType,
	criteriaIMEX,
	criteriaStatus : CM_YACriteria;

begin
	app.initialize;
	app.myPassport.setMyUserFromCode(SUPERUSER_Str);
	foreach theTerminal in app.myRoot.allTerminals do
		if not theTerminal.getConfig(MTImportIfIntendedOffsite).Boolean then
			create transitionProxy transient;
			create transition transient;
			create criteriaCargoType transient;
			transitionProxy.allCriteria.add(criteriaCargoType);
			criteriaCargoType.setProxy(CM_YATypeCargoType.firstInstance, "CONT", "Cargo Type");
			
			create criteriaStatus transient;
			transitionProxy.allCriteria.add(criteriaStatus);
			criteriaStatus.setProxy(CM_YATypeContentsStatus.firstInstance, "MT", "Contents S");
			
			create criteriaIMEX transient;
			transitionProxy.allCriteria.add(criteriaIMEX);
			criteriaIMEX.setProxy(CM_YATypeImexStatus.firstInstance, "IMP", "IMEX Statu");
			
			transitionProxy.setBaseData(transitionProxy.getTableDisplayString, "MT IMPORT CONT", theTerminal, TI_IMEX_STATUS_STORAGE);
			
			realTransition := transition;
			app.myTrxCA.trxCreateObjMatchCrit(transitionProxy, realTransition, app.myPassport );
			
			delete transitionProxy;
			delete transition;

		endif;
	endforeach;
	
epilog

end;</source>
    </JadeMethod>
