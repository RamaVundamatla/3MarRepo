	endif;
	
	return null;
epilog

end;</source>
        <Parameter name="_inBoom" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="6b6cb2c0-e9d6-442d-96cf-c5dd112cebec">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
// ---------------------------------------------------------------------------
// Created:     27 July 2009 by cnwcs5:1
// Purpose:     CCMS 1061 - Gate Config Changes  
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

begin
	if _attrName = ETRow_Lane_id then
		return self.getLaneId;
	elseif _attrName = ETRow_Lane_in then
		return (self.laneDirection = self.Is_In_Lane).String;
	elseif _attrName = ETRow_Lane_out then
		return (self.laneDirection = self.Is_Out_Lane).String;
	elseif _attrName = ETRow_Lane_direction_locked then
		return (self.lockDirection).String;
	elseif _attrName = ETRow_Lane_closed then
		return self.isUnavailable.String;
	elseif _attrName = ETRow_Lane_printer then
		return self.getPrinterName;
	elseif _attrName = ETRow_Lane_rfid_tag_read then
		return self.getRFIDTagReaderName (true);
	elseif _attrName = ETRow_Lane_rfid_tag_assign then
		return self.getRFIDTagReaderName (false);
	elseif _attrName = ETRow_Lane_boom_in then
		return self.getBoomName (true);
	elseif _attrName = ETRow_Lane_boom_out then
		return self.getBoomName (false);
	elseif _attrName = ETRow_Lane_kiosk	 then
		return self.getKioskName;
	elseif _attrName = ETRow_Lane_scale	 then
		return self.getWeighBridgeName;
	// ### TFS 52773 04MAY2022 NAVPW1
	elseif _attrName = ETRow_Lane_scan_reader then
		return self.getScanReaderName();
	// ### TFS 52773 04MAY2022 NAVPW1
	endif;
	
	return inheritMethod(_attrName, _short);

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getFullId" id="556d6415-9353-4388-abb1-2514d6447047">
        <source>getFullId(): String;
// ---------------------------------------------------------------------------
// Created:     09 September 2009 by cnwcs5
// Purpose:     CCMS 1061 - gate config
// Parameters:  None
// Returns:     &lt;terminal area name&gt; &lt;lane #&gt;
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 01/03/2010	cnwcs5		par 22580 - gate area &amp; yard IC area lanes use same method
// ---------------------------------------------------------------------------
vars
	laneId	: String;

begin
	laneId := self.getID();
	
	if laneId = null then
		return self.myGridArea.id;
	endif;
	
	return self.myGridArea.id &amp; " " &amp; laneId;
epilog

end;
/*vars
	ta	:CM_TerminalArea;
	str	:String;
begin
	ta := self.getParent;
	
	str := ta.getID;
	
	if self.isDefaultLane then
		// just the terminal area
		return str;
	endif;
	
	// a real lane
	return str &amp; '/' &amp; self.getLaneNumber.String;
epilog

end;*/</source>
        <ReturnType type="String"/>
    </JadeMethod>
