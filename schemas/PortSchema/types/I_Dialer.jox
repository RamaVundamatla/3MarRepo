    <Constant name="GUID" id="ca949990-a5a6-424e-babd-54420531415e">
        <source>"{243C7CAD-F62D-11D3-B6D1-0060972BF7DF}"</source>
        <type name="String"/>
    </Constant>
    <PrimAttribute name="activeEntryName" id="d8665119-6030-42f1-8a52-7bb6084a5101">
        <virtual/>
        <type name="String"/>
        <access>readonly</access>
        <text>Returns the name of the phonebook entry that is currently connected.  Returns an empty string if no connection is active.  Read-only.</text>
    </PrimAttribute>
    <PrimAttribute name="dialerAvailable" id="dd843817-0b14-4a1e-a91a-00b340cdd6b6">
        <embedded/>
        <virtual/>
        <type name="Integer"/>
        <access>readonly</access>
        <text>Returns True (-1) if Remote Access Service is installed and configured.</text>
    </PrimAttribute>
    <PrimAttribute name="domain" id="6279ca9e-2c68-4dd7-bffc-74b94f74e6b7">
        <type name="String"/>
        <text>Optional NT domain login parameter that  will be used for the next Dial operation.  Only required if dialing to an NT Server.</text>
    </PrimAttribute>
    <PrimAttribute name="entryName" id="b33c7959-8625-492b-9732-d1f558890aeb">
        <type name="String"/>
        <text>Specifies the phonebook entry name that will be used for the next Dial operation.</text>
    </PrimAttribute>
    <PrimAttribute name="oSType" id="0604481e-54ba-4789-bbd8-a9d1ae156e10">
        <embedded/>
        <virtual/>
        <type name="Integer"/>
        <access>readonly</access>
        <text>Returns a short integer that specifies the type of operating system.</text>
    </PrimAttribute>
    <PrimAttribute name="password" id="17f6f481-6b50-4134-97b1-4359b6b22045">
        <type name="String"/>
        <text>Specifies the password that will be used by the next Dial operation as a login parameter. </text>
    </PrimAttribute>
    <PrimAttribute name="phoneNumber" id="e14ec482-a052-4647-ac30-86a452705553">
        <type name="String"/>
        <text>Specifies the phone number  that will be used for the next Dial operation.  Not used if EntryName is specified.</text>
    </PrimAttribute>
    <PrimAttribute name="userName" id="18a45ccd-ea0d-4025-81a1-7bdfc66c2434">
        <type name="String"/>
        <text>Specifies the user name (login name) that will be used by the next Dial operation as a login parameter. </text>
    </PrimAttribute>
    <PrimAttribute name="windowsVersion" id="d2ea9566-91b5-48a8-8404-e6e6a058a08e">
        <embedded/>
        <virtual/>
        <type name="Real"/>
        <access>readonly</access>
        <text>Returns a floating point number that is the OS version.</text>
    </PrimAttribute>
    <JadeMethod name="activeEntryName" id="ba3aab8b-0438-4d27-94b3-d044e9f7043b">
        <methodInvocation>mapping</methodInvocation>
        <updating/>
        <source>activeEntryName(set_:Boolean; value_:String io) updating, mapping;
	// Returns the name of the phonebook entry that is currently connected.  Returns an empty string if no connection is active.  Read-only.

begin
	_jadeActiveXProperty('ActiveEntryName', '', set_, value_);
end;
</source>
        <Parameter name="set_" type="Boolean"/>
        <Parameter name="value_" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="dial" id="1cd8520e-69b4-4251-a967-2611b354b214">
        <updating/>
        <source>dial() updating;
	// Initiates a connection to the device specified by the EntryName or PhoneNumber properties.


begin

	_jadeActiveXMethod('Dial', '', 1);

end;
</source>
    </JadeMethod>
