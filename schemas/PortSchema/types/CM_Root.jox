// --------------------------------------------------------------------------------
begin
	app.processGlobalConstantGroup(PortSchema.name, TransactionTypeConstant, CM_Root::resetTrxType.name, self);
end;</source>
    </JadeMethod>
    <JadeMethod name="resolveMessagesWithExtraInfo" id="c23cad26-6936-4aa6-8d2e-21d78508b164">
        <source>resolveMessagesWithExtraInfo(_errorCode : Integer; _errorMsg : String io);

/*

Purpose:			During logon, the error code is passed back and resolved at form level.
					To add parameters to your message:
					1.  Add Parameters to app.myPassport.allExtraInformation
					2.  Change this method to add the parameters to the passed in _errorMsg

Parameters:			

Return Value:		


Date		Who		Reason
10 September 2010	cnwmd1	Initial creation  Par 22287

*/

vars
	i			: Integer;
	extraInfo 	: StringArray512;
	seperator	: String;
begin
	if _errorCode = One_Session_Login or _errorCode = One_Session_Login_Simple then
		
		if _errorCode = One_Session_Login_Simple then
			seperator := ' ';
		else
			seperator := CrLf;
		endif;
		
		create extraInfo transient;
		app.myPassport.allExtraInformation.copy(extraInfo);
		foreach i in 1 to extraInfo.size do
			_errorMsg := _errorMsg &amp; seperator &amp; extraInfo[i];
		endforeach;
	endif;
epilog
	delete extraInfo;
end;</source>
        <Parameter name="_errorCode" type="Integer"/>
        <Parameter name="_errorMsg" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="revealAllFinancialTypes" id="918ba821-4825-4c7f-8ab4-89bb231baeb0">
        <source>revealAllFinancialTypes();
/*
Purpose:			 // PAR 36631
Date		Who		Reason
03 August 2015	cnwab1	Initial creation
*/

vars
	ioClass:   CM_ExtFinanceIO;
	default : CM_ExtFinanceIO;
	clsCol : ClassNDict; 
	cls : Class;
	str : String;
begin
	
	create clsCol transient;
	cls := currentSchema.getClass(CM_ExtFinanceIO.name);
	cls.getAllSubclassesAnywhere(clsCol); 

	foreach cls in clsCol do
		if not cls.abstract then
			if cls.name = "Nimbus" then // AKB2014JAN Unit Testing this was intended for Port Nelson but they did not go a head
				continue;
			endif;
			if cls.name = "Decfin" then // PAR 35572 this is Port Otago's old system no longer used
				continue;
			endif;
			if cls.name = "Maximise" then // PAR 35572 this is Centreport's old system no longer used
				continue;
			endif;
			if cls.name = "CODA" then // PAR 35572 this is Centreport's old system no longer used
				continue;
			endif;
			
			if cls.instances.size = 0 then
				ioClass := app.myUtilityCA.utlCreateExternalFinanceClass(cls);
			endif;
		endif;
	endforeach;
epilog

delete clsCol;	
end;</source>
    </JadeMethod>
