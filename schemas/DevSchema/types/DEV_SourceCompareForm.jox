    <JadeMethod name="doRunCodeComparison" id="c61352da-fef2-4ac1-b8b5-0e6dd01ca90e">
        <source>doRunCodeComparison(_sevenDays : Boolean);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26 July 2022	navpw1	Initial creation

*/

constants
	ReleasesFolderM24 = "\\cnwchcm24.cnw.co.nz\cnwpod$\Releases\";
	SchemaFilePathDMast = "\SCMCompare\DailyExtracts";	// ReleasesFolderM24 + CM_Root::getVersionString() + SchemaFilePathDMast = \\cnwchcm24\cnwpod$\Releases\20021\SCMCompare\DailyExtracts
	SchemaFilePathWMast = "\Daily\JadeMaster\schemas";	// ReleasesFolderM24 + CM_Root::getVersionString() + SchemaFilePathWMast = \\cnwchcm24\cnwpod$\Releases\20021\Daily\JadeMaster\schemas

vars
	devSourceCompareAgent 	: DEV_SourceCompareAgent;
	fileNode				: FileNode;
	folder					: FileFolder;
	concatanatedMessage,
	schemaFilePath			: String;
	sourceCompareProgress	: DEV_SourceCompareProgress;
	reportType				: Integer;
	interrupted				: Boolean;
	startTime,
	estDuration				: Time;
	currSecs,
	maxFilesNum,
	curFileNum				: Integer;
	
begin
	on Exception do self.handleUserInterrupt(exception, interrupted);
	
	create sourceCompareProgress transient;
	
	self.mnuRun7DayComparison.enabled := false;
	self.mnuRunFullComparison.enabled := false;
	
	if _sevenDays then
		reportType := DEV_SourceCompareReport.ReportType_Automatic;
		estDuration := DEV_SourceCompareRoot.firstInstance.averageWeeklyDuration;
	else
		reportType := DEV_SourceCompareReport.ReportType_Manual;
		estDuration := DEV_SourceCompareRoot.firstInstance.averageFullDuration;
	endif;
	
	//self.lblModalMessage.caption := "Running Source Comparison";
	//self.frmModalDialog.visible := true;
	//self.lblModalInfo.caption := "";
	
	sourceCompareProgress.run();
	//sourceCompareProgress.doWindowEvents(2);
	sourceCompareProgress.centreWindow();
	sourceCompareProgress.show();
	
	self.slStatus.caption := "Source Comparison Running";
	
	app.mySourceCompareRoot.setIsRunningComparison(true);
	
	//Create Source Comparison Agent
	create devSourceCompareAgent transient;
	
	sourceCompareProgress.setupPbCleanup();
	//sourceCompareProgress.doWindowEvents(2);
	sourceCompareProgress.refreshNow();
	
	//Run cleanup script
	devSourceCompareAgent.cleanUpReports();
	
	//Run Source Comparison Code
	if app.myCnKarmaCntrl.environmentId.toUpper = "NAVDMAST" then //ToDO: Look for a better way to get envId
		schemaFilePath := ReleasesFolderM24 &amp; app.myRoot.getVersionString() &amp; SchemaFilePathWMast;
	else
		schemaFilePath := ReleasesFolderM24 &amp; app.myRoot.getVersionString() &amp; SchemaFilePathDMast;
	endif;
	
	create folder transient;
	folder.fileName := schemaFilePath;
	folder.usePresentationFileSystem := true; //Use clients connection
	folder.mask := "*.scm";
	
	if not folder.isAvailable() then
		devSourceCompareAgent.logMessage("Folder " &amp; folder.fileName &amp; " not found, exiting", LogFATAL);
		return;
	endif;
	
	//self.pbProgressBar.partsInJob := folder.files.size + 1;
	maxFilesNum := folder.files.size;
	sourceCompareProgress.setupPb(maxFilesNum);
	
	startTime := app.actualTime.time;
	
	foreach fileNode in folder.files do
		curFileNum += 1;
		if (not fileNode.isKindOf(FileFolder)) then
			sourceCompareProgress.updatePb("Loading " &amp; fileNode.name.replace(".scm", ""));
			if estDuration &lt;&gt; null then
				currSecs := estDuration.Integer - (app.actualTime.time - startTime).max(0);
				sourceCompareProgress.setAdditionalInfo("[" &amp; curFileNum.String &amp; "/" &amp; maxFilesNum.String &amp; "] Estimated Time Remaining: " &amp; currSecs.Time.String);
			endif;
			
			//sourceCompareProgress.doWindowEvents(2);
			sourceCompareProgress.refreshNow();
			if _sevenDays then
				devSourceCompareAgent.doGetRecentlyModified(fileNode.fileName, fileNode.name.replace(".scm", ""), false, reportType);
			else
				devSourceCompareAgent.doSchemaComparison(fileNode.fileName, fileNode.name.replace(".scm", ""), false, reportType);
			endif;
		endif;
	endforeach;
	
	devSourceCompareAgent.reportAgent.setDuration(startTime);

	//self.lblModalInfo.caption := "Finishing Up";
	sourceCompareProgress.updatePb("Finishing Up");
	if estDuration &lt;&gt; null then
		sourceCompareProgress.setAdditionalInfo("[" &amp; curFileNum.String &amp; "/" &amp; maxFilesNum.String &amp; "] Estimated Time Remaining: Done");
	endif;
	//sourceCompareProgress.doWindowEvents(2);
	sourceCompareProgress.refreshNow();
	
	devSourceCompareAgent.setReportAvailable();
	
	concatanatedMessage := devSourceCompareAgent.getReport();
	
	if concatanatedMessage.length &gt; 0 then
		devSourceCompareAgent.logMessage(concatanatedMessage, LogERROR);
	endif;
	
	//self.pbProgressBar.partsDone := self.pbProgressBar.partsDone + 1;
	sourceCompareProgress.updatePb("Complete");
	sourceCompareProgress.pbProgressBar.foreColor := Green;
	sourceCompareProgress.stop();
	
epilog
	app.mySourceCompareRoot.setIsRunningComparison(false);
	delete devSourceCompareAgent;
	delete folder;
	//Hide progress bar frames
	
	if not sourceCompareProgress.controlBox then
		sourceCompareProgress.updatePb("ERROR");
		sourceCompareProgress.pbProgressBar.foreColor := Red;
		sourceCompareProgress.refreshNow();
		sourceCompareProgress.stop();
	endif;
	
end;</source>
        <Parameter name="_sevenDays" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doRunComparison" id="99ce86e7-d942-4be4-a8c7-8d846c3c64df">
        <source>doRunComparison();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 November 2021	navpw1	Initial creationTFS: 52202

*/

constants
	SchemaFileName 			= "100DevSchema8621";
	SchemaFilePath 			= "C:\JMT_Source\wmast\";
	SchemaFileExtension 	= ".scm";
	
vars
	devSourceCompareAgent 	: DEV_SourceCompareAgent;
	
	
	fileNode				: FileNode;
	folder					: FileFolder;
	
begin
	create devSourceCompareAgent transient;
	
	/*
	**	Multiple File Processing
	*/
	
	create folder transient;
	folder.fileName := SchemaFilePath;
	folder.mask := "*.scm";
	
	if not folder.isAvailable() then
		devSourceCompareAgent.logMessage("Folder " &amp; folder.fileName &amp; " not found, exiting", LogFATAL);
		return;
	endif;
	
	foreach fileNode in folder.files do
		if (not fileNode.isKindOf(FileFolder)) then
		fileNode.cnEcFilePath();
			devSourceCompareAgent.doSchemaComparison(fileNode.fileName, fileNode.name.replace(".scm", ""), true, DEV_SourceCompareReport.ReportType_Manual);
		endif;
	endforeach;
	
	/*
	**	Single File Processing
	*/
	
	//devSourceCompareAgent.runComparison(SchemaFilePath, SchemaFileName, SchemaFileExtension);
	
	
	app.msgBox("Finished Processing", "Finished!!", MsgBox_OK_Only);
	
epilog
	delete devSourceCompareAgent;
	delete folder;
	
end;</source>
    </JadeMethod>
