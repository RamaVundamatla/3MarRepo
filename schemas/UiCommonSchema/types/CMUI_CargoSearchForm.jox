/*

Date		Who		Reason
05 September 2014	cnwer1	Initial creation PAR

*/

vars

begin
	inheritMethod();
	self.jdcResults.width:=self.clientWidth;
	self.frmResults.width:=self.clientWidth;
	self.frmResults.height:= self.jdcResults.clientHeight;
	self.jdcSelected.width:=self.clientWidth;
	self.frmSelectedItems.width:=self.clientWidth;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doSave" id="1de49d11-03c8-4c34-9b8d-f97568d1682f">
        <updating/>
        <source>doSave(): Boolean updating, protected;
//08 September 2009	cnwml2
//13 April 2018	jlgrh7 TFS #38078	Searcher on Road Gate for Release Requests
//12 July  2022 navcs2	ChangeRequest 53899: EUP - VBS MTN - [3] - Maintaining VBS Slot
//22 Sep 2022 	navhl20 ChangeRequest 53900: EUP - VBS MTN - [4] - Search Screen
//16 Oct 2023   navlc30 ChangeRequest 58996: EUP | VBS changes MTN - Adding multiple items at once (From Ticket FR 53429)
//18 Dec 2023	naviv1	ChangeRequest 61793: FR | 54329 - VBS - Adding Multiple items from prenoted cargo (without booking)
vars

begin

	// NAVCS2 12/07/2022 53899
	/*if self.myParentForm.isKindOf(CMUI_VehicleBookingItemMaint) then	//18.12.2023 naviv1 #61973
		if not self.allSelectedTrackedItems.size = 1 and not self.myParentForm.CMUI_VehicleBookingItemMaint.chkMultipleItems.value then //16.10.2023 navlc30 #58996
			app.raiseCMException(Pleas_selec_only_carg_item_vbs, null, null);
			return false;
		endif;
	endif;*/
	
	//Start 22.09.2022 navhl20 TFS 53900
	if self.myParentForm.isKindOf(CMUI_VehicleBookingEnqForm) then
		if not self.allSelectedTrackedItems.size = 1 then
			app.raiseCMException(Please_select_only_cargo_item, null, null);
			return false;
		endif;
		self.unloadForm;
	endif;
	//End 22.09.2022 navhl20 TFS 53900

	if self.myParentForm.IF_CMUI_TrackedItems.saveSelectedTrackedItems(self.allSelectedTrackedItems) then
		//self.myParentForm.CMUI_ReleaseCargoForm.lstCargoIDvalues.setSelected(self.allSelectedTrackedItems);						//+TFS38078
		self.unloadForm;
		return inheritMethod();
	endif;
	
	return false;
epilog

end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doSearchAll" id="5dbb6e19-ea73-4364-83b7-3c601827c158">
        <source>doSearchAll();
//07 September 2009	cnwml2
//
// Changed On	By			Reason
// ----------	--------	-------------------------------------------------
// 23/08/2013	cnwdap1		PAR #32331 Added Colour and Mark to searcher
// 09/12/2013 	cnwmh5		PAR 28731 - Delete results
// 27/05/2022	navcs2		ChangeRequest 52351: MTN - Work Order Maintenance Refactor - UI
// 14/07/2022	navcs2		ChangeRequest 53932: MTN - Jobs Changes
//06/10/2022 	navgm20		ChangeRequest 54979: EUP - Cargo Work Orders Enhancements
// 13/12/2022 	navcs2 		Defect 55789: MTN - Getting 1090 error when searching the cargo with Parents Only checkbox to true
// 20.12.2022 	navcs2 		ChangeRequest 56149: EUP - VAS Cargo Search Screen
// 12 jan 2023	navcs2		ChangeRequest 56149:[56150] EUP - VAS Cargo Search Screen
// 04 Jul 2023	navlw1		ChangeRequest 58730: EUP | Link bill of lading item to Receive work orders
// 06 Jul 2023 	navhl20 	Bug 58952: MTN - Unable to add the tracked item when using the Export Booking for Release Cargo Work Order
// 13 July 2023 navmv20 	CR 58233 Task 58236: UI - Add Item
// 16 Oct 2023  navlc30 	ChangeRequest 58996: EUP | VBS changes MTN - Adding multiple items at once (From Ticket FR 53429)
// 03 Jun 2024  navbs1	 	Bug 64318: MTN | Work order cargo search not finding items for a release
// 24 Jul 2025 	navhn30 	MTN-35315: MTN | Pagination - Work Order Maintenance
vars
	agent 			: CM_QueryBuilderAgent;
	results 		: CM_TISet;
	ti 				: CM_TrackedItem;
	iter 			: Iterator;
	count, 
	idx 			: Integer;
	colour 			: String;			
	mark 			: String;					
	unpackedFrom,
	cargoGroupID	: String;
	obj				: Object;
	form			: CM_BaseForm;			//navra1 - TFS 64266 - 28th May 2024
begin
	
	create agent transient;
	create results transient;
	agent.setResultArray(results);
	
	self.tblResults.clearAllData();	//12 Mar 2012	NDL	Par 28864
	
	if self.cmbCargoTypes.myObject &lt;&gt; null then
		agent.setQueryMode(self.cmbCargoTypes.myObject.CM_CargoType);
	else
		agent.setQueryMode(null);
	endif;
	
	//set Terminal to current terminal, this can't be manually changed
	agent.addCriteria(CM_TrackedItem::myTerminal.name, CM_QueryOperator.Operator_Equal, self.myTerminal);
	
	if self.cmbSite.getString() &lt;&gt; null then
		agent.addCriteria(CM_TrackedItem::site.name, CM_QueryOperator.Operator_Equal, self.cmbSite.getString());
	endif;
	
	if self.txtCargoID.getString() &lt;&gt; null then
		agent.addCriteria(CM_TrackedItem::id.name, CM_QueryOperator.Operator_Contains, self.txtCargoID.getString());
	endif;
		
	// 27/05/2022 nvacs2 TFS 52351
	if self.myParentForm &lt;&gt; null and ( self.myParentForm.name = "YRD_WorkOrder" or self.myParentForm.name = "CMUI_VehicleBookingItemMaint" ) then	//16.10.2023 navlc30 #58996
		obj := cmbRelease.getCurrentItemObject;
		if obj &lt;&gt; null then
			agent.addCriteria(CM_TrackedItem::bulkReleaseAssignedCode.name, CM_QueryOperator.Operator_Contains, obj.CM_BulkRelease.code);
		endif;
		
		obj := cmbBooking.getCurrentItemObject;
		if obj &lt;&gt; null then
			agent.addCriteria(CM_TrackedItem::bookingReference.name, CM_QueryOperator.Operator_Contains, obj.CM_BookingRef.bookingReference);
		endif;
		
		// 04/07/2023 navlw1 tfs #58730
		
		obj := self.myContextSearchObject;
		if obj &lt;&gt; null then
			if obj.isKindOf(CM_WodReceive) and obj.CM_WodReceive.transport &lt;&gt; TI_TRANSMODE_SHIP then
				agent.addCriteria(CM_TrackedItem::receiptTransportMode.name, CM_QueryOperator.Operator_Equal, app.transportModeENumToString(obj.CM_WodReceive.transport));		//06.7.2023 navhl20 #58952
			/*03.06.2024 navbs1 #64318
			elseif obj.isKindOf(CM_WodRelease) and obj.CM_WodRelease.transport &lt;&gt; TI_TRANSMODE_SHIP then 
				agent.addCriteria(CM_TrackedItem::releasedTransportMode.name, CM_QueryOperator.Operator_Equal, app.transportModeENumToString(obj.CM_WodRelease.transport));		//06.7.2023 navhl20 #58952*/
			endif;
		endif;
			
	endif;
	
	if self.cmbOperatorCode.myObject &lt;&gt; null then
		agent.addCriteria(CM_TrackedItem::operatorCode.name, CM_QueryOperator.Operator_Equal, self.cmbOperatorCode.myObject);
	endif;
	
	if self.cmbCargoTypes.myObject &lt;&gt; null then
		agent.addCriteria(CM_TrackedItem::cargoType.name, CM_QueryOperator.Operator_Equal, self.cmbCargoTypes.myObject);
		if self.cmbCargoTypes.myObject.CM_CargoType.id = TI_CargoType_Container then
			if self.cmbIsoTypeGroup.myObject &lt;&gt; null then
				agent.addCriteria(CM_Container::isoGroup.name, CM_QueryOperator.Operator_Equal, self.cmbIsoTypeGroup.myObject);//cnwas3 PAR 20932
			endif;
	
			if self.cmbIsoTypes.myObject &lt;&gt; null then
				agent.addCriteria(CM_Container::isoType.name, CM_QueryOperator.Operator_Equal, self.cmbIsoTypes.myObject); //cnwas3 PAR 20932
			endif;
		endif;		
	endif;
	
	if cmbSubCargoTypes.myObject &lt;&gt; null then
		agent.addCriteria(CM_TrackedItem::myProduct.name, CM_QueryOperator.Operator_Equal, self.cmbSubCargoTypes.myObject);
	endif;
	
	if self.cmbForwarders.myObject &lt;&gt; null then
		agent.addCriteria(CM_TrackedItem::freightForwarderCode.name, CM_QueryOperator.Operator_Equal, self.cmbForwarders.myObject);
	endif;
	
	if self.cmbVoyages.myObject &lt;&gt; null then
		agent.addCriteria(CM_TrackedItem::voyageCode.name, CM_QueryOperator.Operator_Equal, self.cmbVoyages.myObject);
	endif;
	
	//epr par 11/11/13 32964
	if self.cmbBOLIns.listObject &lt;&gt; null then
		agent.addCriteria(CM_TrackedItem::billOfLading.name, CM_QueryOperator.Operator_Equal, self.cmbBOLIns.listObject.CM_BOL.number);
	endif;
	
	if self.cmbConsignees.myObject &lt;&gt; null then
		agent.addCriteria(CM_TrackedItem::consignee.name, CM_QueryOperator.Operator_Equal, self.cmbConsignees.myObject );	//14 Mar 2013	NDL	Par 30919 
	endif;
	
	if self.chkEmptiesOnly.getBoolean then
		agent.addCriteria(CM_TrackedItem::commodity.name, CM_QueryOperator.Operator_Equal, app.myRoot.allCommodities[self.myTerminal.getDefaultEmptyCommodity()]);
	endif;
	
	//06/10/2022 navgm20	TFS 54979-Start
	if self.chkParentOnly.getBoolean then
		agent.addCriteria(CM_TrackedItem::hasChildren.name, CM_QueryOperator.Operator_Equal, self.chkParentOnly.getBoolean.getYes);	// 13/12/2022 navcs2 Defect 55789
	endif;
	//06/10/2022 navgm20	TFS 54979-End
	
	//+cnwml2 PAR21663
	if self.cmbImex.myObject &lt;&gt; null then
		agent.addCriteria(CM_TrackedItem::imexStatus.name, CM_QueryOperator.Operator_Equal, self.cmbImex.myObject );	//14 Mar 2013	NDL	Par 30919 
	endif;
	
	//+cnwml2 PAR21663
	if self.txtLocation.getString &lt;&gt; null then
		agent.addCriteria(CM_TrackedItem::locationId.name, CM_QueryOperator.Operator_StartsWith, self.txtLocation.getString());	//14 Mar 2013	NDL	Par 30919 
	endif;
	
	//+cnwml2 PAR21663
	if self.cmbAvailGrade.myObject &lt;&gt; null then
		agent.addCriteria(CM_Container::availabilityGrade.name, CM_QueryOperator.Operator_Equal, self.cmbAvailGrade.myObject);	//14 Mar 2013	NDL	Par 30919 
	endif;
	
	if self.cmbCommodities.myObject &lt;&gt; null then
		agent.addCriteria(CM_Container::commodity.name, CM_QueryOperator.Operator_Equal, self.cmbCommodities.myObject);		// 12.01.2023 navcs2 #56149:[56150]
	endif;
	
	colour := self.myAssistant.getColourString(self.lstColourList, self.txtColourList);				// PAR #32331
	if colour &lt;&gt; null then																			// PAR #32331
		agent.addCriteria(CM_TrackedItem::getColour.name, CM_QueryOperator.Operator_Equal, colour);	// PAR #32331
	endif;																							// PAR #32331
	mark := self.txtMark.getString;																	// PAR #32331
	if mark &lt;&gt; null then																			// PAR #32331
		agent.addCriteria(CM_TrackedItem::mark.name, CM_QueryOperator.Operator_Equal, mark);		// PAR #32331
	endif;
	//09 Dec 2013	NDL	Par 32854
	unpackedFrom := self.txtUnpackedFrom.getString;
	if unpackedFrom &lt;&gt; null then
		agent.addCriteria(CM_TrackedItem::getMyUnpackedFromContainerId.name, CM_QueryOperator.Operator_Equal, unpackedFrom);
	endif;
	
	cargoGroupID := self.txtCargoGroupID.getString;																			// 20.12.2022 navcs2 #56149:[56150]
	if cargoGroupID &lt;&gt; null then																							// 20.12.2022 navcs2 #56149:[56150]
		agent.addCriteria(CM_TrackedItem::getMyCargoGroupId.name, CM_QueryOperator.Operator_Equal, cargoGroupID);			// 20.12.2022 navcs2 #56149:[56150]
	endif;																													// 20.12.2022 navcs2 #56149:[56150]
			
	agent.doQuery();

	//+cnwml2 PAR21663
	iter := agent.allObjects.createIterator();
	self.tblResults.setMyDataClass(CM_TrackedItem);
	
	//navra1 - TFS 64266 - 28th May 2024 - start
	form := self;
	//self.tblResults.getDataAndDisplayRowsMultith(agent.allObjects, true, form, true);
	self.tblResults.getDataAndDisplayRowsPaginat(Table.DisplayCollection_Forward, null, agent.allObjects, true);			 //24.07.2025	navhn30  MTN-35315
		
	/*
	while iter.next(ti) do
		count := count + 1;
		//13/07/2023 navmv20 CR 58233 Task 58236 - start
		if not self.includeForApprovedDetail(ti) then
			continue;
		endif;
		//13/07/2023 navmv20 CR 58233 Task 58236 - end
		if self.myBookingItem &lt;&gt; null and self.myBookingItem &lt;&gt; ti.myBookingRefItem then				//16.10.2023 navlc30 #58996
			continue;
		endif;
		
		if myParentForm &lt;&gt; null and self.myParentForm.name = "CMUI_VehicleBookingItemMaint" then		//18.10.2023 navlc30 #58996
			if ti.allVehicleBookingSlotItems.isNotEmpty() then												
				continue;
			endif;
		endif;
		
		idx := self.tblResults.updateItemObject(ti, self.colorRow1, self.colorRow2, app.myPassport);
		self.tblResults.accessRow(idx).itemObject := ti;
		// navcs2 14/07/2022 53932
		if tblSelectedItems.doSearch(ti.id, tblResults.getColumnByHeading("id")) &lt;&gt; null then
			tblResults.removeItemObject(ti);
		endif;
	endwhile;
	*/
	//navra1 - TFS 64266 - 28th May 2024 - end

epilog
	delete results;									// 09/12/2013 cnwmh5
	delete agent;
	delete iter;
	delete results;

end;</source>
    </JadeMethod>
    <JadeMethod name="doSearchResults" id="e6e8af34-261c-4664-b77f-90617f47610a">
        <source>doSearchResults();
//10 September 2009	cnwml2


vars
	oa : ObjectArray;
begin
	create oa transient;
	self.tblResults.getAllRowObjects(oa);
	
	write oa.size.String;
epilog
	delete oa;
end;</source>
    </JadeMethod>
    <JadeMethod name="doTbResultsDblClick" id="b53c9cfd-a647-41dd-8298-4583cad38681">
        <source>doTbResultsDblClick();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
18 March 2010	cnwrd1	Initial creation
//cnwrd1 18.3.2010 par 21166
// 11 Mar 2022   navhl20    TFS #53052 MTN - Cargo Searcher Issues
*/

vars
	theTi : CM_TrackedItem;
	obj : Object;
	tbl : CM_DataTable;								//11 mar 2022 navhl20 TFS #53052
begin
	
	//obj := self.tblResults.accessRow(self.tblResults.row).itemObject;
	tbl := self.tblResults;							//11 mar 2022 navhl20 TFS #53052
	obj := tbl.accessRow(tbl.row).itemObject;		//11 mar 2022 navhl20 TFS #53052	
	
	if tbl.rows &gt; 1 then							//11 mar 2022 navhl20 TFS #53052
		if tbl.row = tbl.fixedRows then				//11 mar 2022 navhl20 TFS #53052
			tbl.resortTableByColumn(tbl.column);	//11 mar 2022 navhl20 TFS #53052
		endif;										//11 mar 2022 navhl20 TFS #53052
	endif;                                          //11 mar 2022 navhl20 TFS #53052
	
	if CM_TrackedItem.hasInstance(obj) then
		theTi := obj.CM_TrackedItem;
		self.myAssistant.showCargoEnquiry(theTi);
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doTbSelectedDblClick" id="5affc30b-377c-4fbd-894f-6ee30ad0c115">
        <source>doTbSelectedDblClick();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
18 March 2010	cnwrd1	Initial creation
11 Mar 2022   navhl20    TFS #53052 MTN - Cargo Searcher Issues

*/

vars

	theTi : CM_TrackedItem;
	obj : Object;
	tbl : CM_DataTable;								//11 mar 2022 navhl20 TFS #53052
			cargoEnquiry : CM_ContainerEnqForm;
begin

	
	tbl := self.tblSelectedItems;					//11 mar 2022 navhl20 TFS #53052
	//obj := self.tblSelectedItems.accessRow(self.tblSelectedItems.row).itemObject;		//11 mar 2022 navhl20 TFS #53052
	obj := tbl.accessRow(tbl.row).itemObject;		//11 mar 2022 navhl20 TFS #53052
	
	
	if tbl.rows&gt; 1  then							//11 mar 2022 navhl20 TFS #53052
		if tbl.row = tbl.fixedRows then				//11 mar 2022 navhl20 TFS #53052
			tbl.resortTableByColumn(tbl.column);	//11 mar 2022 navhl20 TFS #53052
		endif;										//11 mar 2022 navhl20 TFS #53052
	endif;											//11 mar 2022 navhl20 TFS #53052
	
	if CM_TrackedItem.hasInstance(obj) then
		theTi := obj.CM_TrackedItem;
		//self.myAssistant.showCargoEnquiry(theTi);
		
		

	cargoEnquiry := app.loadForm(CM_ContainerEnqForm, CMUI_Assistant, false, false, false, self.myTerminal, null).CM_ContainerEnqForm;	
	if cargoEnquiry = null then
		return;
	endif;
	cargoEnquiry.setMyTerminal(self.myTerminal);	
	cargoEnquiry.isModal();
	cargoEnquiry.showWithObject(theTi, true, false);

	endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="getRowValues" id="247b26f8-5ac3-4931-9fbe-603500a12b64">
        <source>getRowValues(ti: CM_TrackedItem): String;
//28 September 2009	cnwdw1	
//
vars
	code : String;
begin
	if ti.myCargoType.id = TI_CargoType_Container then
		code := " - " &amp; ti.isoTypeDesc;
	else
		if ti.myProduct &lt;&gt; null then
			code := " - " &amp; ti.myProduct.code;
		endif;
	endif;
	return ti.id &amp; Tab &amp; ti.cargoTypeDescr &amp; code &amp; Tab &amp; ti.voyageCode &amp; Tab &amp; ti.operatorCode;
end;</source>
        <Parameter name="ti" type="CM_TrackedItem"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getXMLSettingsForSave" id="a1419df1-bc18-4c69-8ed5-61b176fea07a">
        <updating/>
        <source>getXMLSettingsForSave(): String updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
12 March 2012	cnwndl1	Initial creation	Par 28864

*/

vars

	xmlStr	: String;

begin

	xmlStr := inheritMethod();

	xmlStr := xmlStr &amp; self.tblResults.getXmlStrForColumns(true);
	xmlStr := xmlStr &amp; self.tblSelectedItems.getXmlStrForColumns(true);
	
	return xmlStr;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="hideSelectedControls" id="8f140e8f-7ee7-4d3c-999c-d87974bdf3c3">
        <updating/>
        <source>hideSelectedControls() updating, protected;
//14 October 2009	cnwml2
// 16 Oct 2023  	navlc30 	ChangeRequest 58996: EUP | VBS changes MTN - Adding multiple items at once (From Ticket FR 53429)


vars
	hideCmbRelease	: Boolean;
begin
	inheritMethod();

	if self.cmbCargoTypes.myObject &lt;&gt; null then
		if self.cmbCargoTypes.myObject.CM_CargoType.id = TI_CargoType_Container then
			self.cmbISOType.isHidden := false;
			self.cmbISOGroup.isHidden := false;
			self.cmbSubCargo.isHidden := true;
		elseif self.cmbCargoTypes.myObject.CM_CargoType.isSubCargoTypeRequired then
			self.cmbISOType.isHidden := true;
			self.cmbISOGroup.isHidden := true;
			self.cmbSubCargo.isHidden := false;
		elseif not self.cmbCargoTypes.myObject.CM_CargoType.isSubCargoTypeRequired then
			self.cmbISOType.isHidden := true;
			self.cmbISOGroup.isHidden := true;
			self.cmbSubCargo.isHidden := true;
		endif;
	else
		self.cmbISOType.isHidden := true;
		self.cmbISOGroup.isHidden := true;
		self.cmbSubCargo.isHidden := true;
	endif;
	
	if myBookingItem = null then
		cmbBookings.isHidden := true;
	endif;
	
	/*if self.myReserveDetail = null then																	//16.10.2023 navlc30 #58996
		self.cmbReleases.isHidden := true;
	endif;*/
	
	hideCmbRelease := true;																					//16.10.2023 navlc30 #58996
	if self.myContextSearchObject &lt;&gt; null and self.myContextSearchObject.isKindOf(CM_BulkRelease) then		//16.10.2023 navlc30 #58996
		hideCmbRelease := false;
	endif;
	
	if self.myReserveDetail = null and hideCmbRelease then													//16.10.2023 navlc30 #58996
		self.cmbReleases.isHidden := true;
	endif;
		
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="includeForApprovedDetail" id="6be97d92-c10b-4e7f-96ec-d9a472deaed6">
        <source>includeForApprovedDetail(_ti : CM_TrackedItem): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 July 2023 navmv20 CR 58233 Task 58236: UI - Add Item

*/

vars
	ownershipChangeDtl : CM_OwnershipChangeDetail;
	ownershipChange    : CM_OwnershipChange;
begin
	if self.myParentForm.isKindOf(CMUI_OwnershipChangeMaint) then
		if _ti.getCOOHasAnyIncluded() then // ### TFS CR 64164 TASK 64733 20JUNE024 NAVAB1
			foreach ownershipChangeDtl in _ti.allOwnershipChangeDetails discreteLock where ownershipChangeDtl.included do // ### TFS CR 64164 TASK 64733 20JUNE024 NAVAB1
				ownershipChange := ownershipChangeDtl.getOwnershipChangeHeader(); // ### TFS BUG 60189 31AUG2023 NAVAB1 ownershipChangeDtl.myOwnershipChange;
				
				if not ownershipChange.isApproved() then // ### TFS CR 64164 TASK 64733 20JUNE024 NAVAB1
					return false;
				endif;
			endforeach;
		endif;
	endif;
	return true;
epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
