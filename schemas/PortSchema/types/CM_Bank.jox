        <source>setSelectedProformaCriteria( _strArray : StringArray ) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
23 July 2012	cnwndl1	Initial creation

*/

vars

begin

	self.allSelectedProformaQueryProps.clear();
