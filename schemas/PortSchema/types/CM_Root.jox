    <JadeMethod name="setForSysMenu" id="719c6ea8-529d-4f71-81c8-01da2eeacec6">
        <updating/>
        <source>setForSysMenu(_value : Integer; _data : Any io) updating, protected;
// ---------------------------------------------------------------------------
// Created:     05 April 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	byteIndex		: Integer;
	byteValue		: Integer;
	bitPointer		: Integer;
	binData			: Binary;

begin

	if (not _data.isKindOf(Binary)) then
		return;
	endif;
	
	binData := _data.Binary;

	byteIndex	:=	((_value - 1) div 8) + 1;
	if byteIndex &gt; binData.length then
		byteValue	:= 0;
	else
		byteValue	:= binData[byteIndex];
	endif;
	bitPointer	:=	(_value mod 8);
	
	if bitPointer = 1 then			// Right-most bit.
		byteValue	:=	byteValue.bitOr(1);
	elseif bitPointer = 2 then
		byteValue	:=	byteValue.bitOr(2);
	elseif bitPointer = 3 then
		byteValue	:=	byteValue.bitOr(4);
	elseif bitPointer = 4 then
		byteValue	:=	byteValue.bitOr(8);
	elseif bitPointer = 5 then
		byteValue	:=	byteValue.bitOr(16);
	elseif bitPointer = 6 then
		byteValue	:=	byteValue.bitOr(32);
	elseif bitPointer = 7 then
		byteValue	:=	byteValue.bitOr(64);
	elseif bitPointer = 0 then		// Left-most bit.
		byteValue	:=	byteValue.bitOr(128);
	endif;
	
	binData[byteIndex]	:=	byteValue;
	
	_data := binData;

end;</source>
        <access>protected</access>
        <Parameter name="_value" type="Integer"/>
        <Parameter name="_data" type="Any" usage="io"/>
    </JadeMethod>
