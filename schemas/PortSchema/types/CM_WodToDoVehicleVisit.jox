    <JadeMethod name="getAdvWOTransactionType" id="f75e36bc-04bd-4ca9-bb37-28adb20f376a">
        <source>getAdvWOTransactionType(transType : Integer): Integer;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
04 October 2022		navcs2	ChangeRequest 56633:[56211] 54253.101 - Work order Transactions

*/

vars

begin
	if transType = TRANS_CREATED then
		return TRANS_TYPE_WO_TODO_TRK_CREATED;
	elseif transType = TRANS_UPDATED then
		return TRANS_TYPE_WO_TODO_TRK_UPDATED;
	else
		return TRANS_TYPE_WO_TODO_TRK_COMPLET;
	endif;
epilog

end;</source>
        <Parameter name="transType" type="Integer"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
