    <JadeMethod name="setMyService" id="45122e13-7ff8-4113-8126-3df47ad501ee">
        <updating/>
        <source>setMyService( _object : CM_Service ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 July 2016	cnwndl1	Initial creation	TFS 2329

*/

vars

