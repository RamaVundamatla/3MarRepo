			unloadArray.add("C,A,,,,,ISO Container,,,GENL,General,,,DFBU,,,,,NZPOE,D2200O,,0.0000,,OOTL6307370,Import,2200,0.0000,,,,,,,MSL,,,0.0000,0.0000,0.0000,0.0000,0.0000,00:00:00," &amp; self.createdByUnitTest(null) &amp; ",,,,12589,,,,0.000,VOYSHIP30951_2,,,0.0000,,,");
			unloadArray.add("C,A,,,,,ISO Container,,,GENL,General,,,DFBU,,,,,NZPOE,D2200O,,0.0000,,OOTL6309511,Import,4262,0.0000,,,,,,,MSL,,,0.0000,0.0000,0.0000,0.0000,0.0000,00:00:00," &amp; self.createdByUnitTest(null) &amp; ",,,,12589,,,,0.000,VOYSHIP30951_2,,,0.0000,,,");
			unloadArray.add("C,A,,,,,ISO Container,,,GENL,General,,,DFBU,,,,,NZPOE,D2201OR,,0.0000,,OOTL6309510,Import,2200,0.0000,,,,,,,MSL,,,0.0000,0.0000,0.0000,0.0000,0.0000,00:00:00," &amp; self.createdByUnitTest(null) &amp; ",,,,12589,,,,0.000,VOYSHIP30951_2,,,0.0000,,,");
			unloadArray.add("C,A,,,,,ISO Container,,,GENL,General,,,DFBU,,,,,NZPOE,D2210OR,,0.0000,,OOTL6309512,Import,2200,0.0000,,,,,,,MSL,,,0.0000,0.0000,0.0000,0.0000,0.0000,00:00:00," &amp; self.createdByUnitTest(null) &amp; ",,,,12589,,,,0.000,VOYSHIP30951_2,,,0.0000,,,");
			unloadArray.add("C,A,,,,,ISO Container,,,GENL,General,,,DFBU,,,,,NZPOE,D2211O,,0.0000,,OOTL6309513,Import,2200,0.0000,,,,,,,MSL,,,0.0000,0.0000,0.0000,0.0000,0.0000,00:00:00," &amp; self.createdByUnitTest(null) &amp; ",,,,12589,,,,0.000,VOYSHIP30951_2,,,0.0000,,,");
			unloadArray.add("C,A,,,,,ISO Container,,,GENL,General,,,DFBU,,,,,NZPOE,D2225O,,0.0000,,OOTL6309516,Import,2200,0.0000,,,,,,,MSL,,,0.0000,0.0000,0.0000,0.0000,0.0000,00:00:00," &amp; self.createdByUnitTest(null) &amp; ",,,,12589,,,,0.000,VOYSHIP30951_2,,,0.0000,,,");
			unloadArray.add("C,A,,,,,ISO Container,,,GENL,General,,,DFBU,,,,,NZPOE,D2226OR,,0.0000,,OOTL6309515,Import,2200,0.0000,,,,,,,MSL,,,0.0000,0.0000,0.0000,0.0000,0.0000,00:00:00," &amp; self.createdByUnitTest(null) &amp; ",,,,12589,,,,0.000,VOYSHIP30951_2,,,0.0000,,,");
			unloadArray.add("C,A,,,,,ISO Container,,,GENL,General,,,DFBU,,,,,NZPOE,D2226OR,,0.0000,,OOTL6309517,Import,4262,0.0000,,,,,,,MSL,,,0.0000,0.0000,0.0000,0.0000,0.0000,00:00:00," &amp; self.createdByUnitTest(null) &amp; ",,,,12589,,,,0.000,VOYSHIP30951_2,,,0.0000,,,");
			unloadArray.add("C,A,,,,,ISO Container,,,GENL,General,,,DFBU,,,,,NZPOE,D2400OR,,0.0000,,OOTL6307371,Import,4262,0.0000,,,,,,,MSL,,,0.0000,0.0000,0.0000,0.0000,0.0000,00:00:00," &amp; self.createdByUnitTest(null) &amp; ",,,,12589,,,,0.000,VOYSHIP30951_2,,,0.0000,,,");
			unloadArray.add("C,A,,,,,ISO Container,,,GENL,General,,,DFBU,,,,,NZPOE,D2401OR,,0.0000,,OOTL6307372,Import,4262,0.0000,,,,,,,MSL,,,0.0000,0.0000,0.0000,0.0000,0.0000,00:00:00," &amp; self.createdByUnitTest(null) &amp; ",,,,12589,,,,0.000,VOYSHIP30951_2,,,0.0000,,,");
			unloadArray.add("C,A,,,,,ISO Container,,,GENL,General,,,DFBU,,,,,NZPOE,D2402OR,,0.0000,,OOTL6307373,Import,2200,0.0000,,,,,,,MSL,,,0.0000,0.0000,0.0000,0.0000,0.0000,00:00:00," &amp; self.createdByUnitTest(null) &amp; ",,,,12589,,,,0.000,VOYSHIP30951_2,,,0.0000,,,");
			unloadArray.add("C,A,,,,,ISO Container,,,GENL,General,,,DFBU,,,,,NZPOE,D2403OR,,0.0000,,OOTL6307374,Import,2200,0.0000,,,,,,,MSL,,,0.0000,0.0000,0.0000,0.0000,0.0000,00:00:00," &amp; self.createdByUnitTest(null) &amp; ",,,,12589,,,,0.000,VOYSHIP30951_2,,,0.0000,,,");

			idx := 0;
	ediFile.myEDIFileType.rawDataToHSA(ediFile, theLines);
	foreach ediText in theLines do
				idx := idx + 1;
//				write ediText;
				self.assertEqualMsg(ediText, unloadArray[idx], "line "&amp;idx.String&amp;" error.");
			endforeach;
		endif;
	endif;
	
	// 15/09/2015 cnwmh5 
	create tiSet transient;
	voyage := self.getVoyage(VoyageName1);
	voyage.getAllTrackedItems(tiSet);
	voyage := self.getVoyage(VoyageName2);
	voyage.getAllTrackedItems(tiSet);
	beginTransaction;
	foreach ti in tiSet do
		ti.setRemarks(self.createdByUnitTest(ti.remarks), true);
	endforeach;	
	commitTransaction;
	
epilog
	delete ediControllerAgent;
	delete pxyFileTypeUser;
	delete ediDataParams;
	delete allTIs;
	delete theLCs;
	delete unloadArray;
	delete theLines;
	delete tiSet;
end;
</source>
        <text>&lt;?xml version="1.0"?&gt;
&lt;UT_Additional&gt;
  &lt;Categories&gt;
    &lt;Category CanDelete="true"&gt;Michael_PAR31258&lt;/Category&gt;
  &lt;/Categories&gt;
&lt;/UT_Additional&gt;</text>
