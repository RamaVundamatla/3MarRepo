<Class name="CM_WorkOrderReleaseExt" id="8aee468f-9463-4708-97ce-169fbe8e40b8">
    <superclass name="CM_WorkOrderAssign"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="workorder"/>
    <JadeMethod name="getDisplayStringForAttribute" id="37144a62-c8c4-4335-b20c-f7ee98b6c2f1">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 March 2019	jlgndl1	Initial creation	TFS 43405

*/

vars
	workOrder : CM_WorkOrderTI;
	invalidWO : Boolean;
	returnStr : String;
	br : CM_BulkRelease;
begin
	if _attrName = ETRow_Details  then
		if self.deleted then
			return self.getDeletedDetails();	
		else
			on Exception do app.handleDeletedObject(exception, workOrder, invalidWO); 
			workOrder := self.myWorkOrder;
			if workOrder &lt;&gt; null then
				br := workOrder.getReleaseRequest(); 
				if br &lt;&gt; null then
					returnStr := app.getErrorString(AssignedTo) &amp; " " &amp; workOrder.id &amp; " : " &amp; app.getErrorString(ReleaseExtension) &amp; " " &amp; br.code;
				else
					returnStr := app.getErrorString(AssignedTo) &amp; " " &amp; workOrder.id &amp; " : " &amp; workOrder.getDisplayString(); // TFS 38524
				endif;
			endif;
			return returnStr;			
		endif;
	endif;
	
	return inheritMethod(_attrName, _short);
epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
</Class>
