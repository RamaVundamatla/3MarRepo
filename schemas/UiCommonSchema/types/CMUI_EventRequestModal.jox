    <JadeMethod name="addRemoveTime" id="10b202ad-a5e8-4039-b9e5-7fe948a90ae0">
        <source>addRemoveTime(_add : Boolean);
//--------------------------------------------------
// Created:	19 May 2005 By: cnwgd1
//--------------------------------------------------
vars
	cnt,
	lstCnt : Integer;
	theTime : String;
begin
	lstCnt := self.lstTime.listCount();
	if _add then
		theTime := self.timeMask.getTime().String;	
		while cnt &lt; lstCnt do
			cnt := cnt+1;			
			if self.lstTime.itemText[cnt] = theTime then
				return;
			endif;	
		endwhile;
		self.lstTime.addItem(theTime);
	else
		while cnt &lt; lstCnt do
			cnt := cnt+1;			
			if self.lstTime.itemSelected[cnt] = true then
				self.lstTime.removeItem(cnt);
				lstCnt := lstCnt-1;
				cnt := cnt -1;
			endif;	
		endwhile;
	endif;
end;</source>
        <Parameter name="_add" type="Boolean"/>
    </JadeMethod>
