    <JadeMethod name="atcgSchemaExtract" id="2df4a0f0-8784-4bf9-b9bb-a49bc4892e7f">
        <source>atcgSchemaExtract(schemaName:String; option:String);

vars
	s,t,schemaPath,result,param,path,cmdLine,suffix:String;
	retCode:Integer;
begin
	if option = "encrypt" then
		suffix:="_Encrypted";
		t:=' "&lt;encrypt&gt;"';
	elseif option = "partial" then
		suffix:="_Partial";
	endif;
	path:=app.getJadeInstallDirAppServer;
	//schemaPath:=app.dbPath.atcgReplace("server\c_system", "schemaExtracts\");
	schemaPath:="u:\SchemaExtracts\";
	s:=schemaPath&amp;schemaName&amp;suffix;
	if option = "partial" then
		param:=" File "&amp;s&amp;".scm "&amp;s&amp;".ddb "&amp;s&amp;".unl "&amp;schemaName;
	else
		param:=" Single "&amp;s&amp;".scm "&amp;s&amp;".ddb "&amp;schemaName&amp;t;
	endif;
	cmdLine:=path&amp;"\jadclient ini="&amp;path&amp;"\jjms6217.ini"&amp;" path="&amp;app.dbPath&amp;" server=multiUser"
					&amp;" schema=JadeSchema app=JadeBatchExtract"&amp;" endJade"&amp;param;
	//write cmdLine;
	node.createExternalProcess(null,'cmd /c '&amp;cmdLine,null,null,false,true,retCode);
end;
</source>
        <Parameter name="schemaName" type="String"/>
        <Parameter name="option" type="String"/>
    </JadeMethod>
    <JadeMethod name="atcgSchemaExtracts" id="b778b417-63db-4698-8101-bcf4ef2afea7">
        <source>atcgSchemaExtracts();
//	use this to extract all schemas for banking
//	driver partial schema is also automated, but if application definitions change, re-extract them (selective extract, no classes or methods, all atcg schemas) to the save folder as JtdDriverSchema_Apps before running this script
vars
	s,t,sq:String;
	f,g:File;
	doneTG:Boolean;
begin
	atcgSchemaExtract("JtdCommonSchema", null);
	atcgSchemaExtract("JtdCommonSchema", "encrypt");
	atcgSchemaExtract("JtdDriverSchema", null);/**/
	atcgSchemaExtract("JtdDriverSchema", "partial");
	
	// add atcg attribute definitions to driver partial scm file
	create f transient;
	f.kind := File.Kind_Unknown_Text; // 2/3/16  cnwns1 PAR 36286 unicode version
	f.fileName:="u:\schemaExtracts\JtdDriverSchema_Partial.scm";
	f.usePresentationFileSystem:=false;
	f.mode:=File.Mode_Input;
	create g transient;
	g.fileName:="u:\schemaExtracts\JtdDriverSchema_Partial2.scm";
	g.mode:=File.Mode_Output;
	g.usePresentationFileSystem:=false;
	
	while not f.endOfFile do
		s:=f.readLine;
		g.writeLine(s.atcgReplace("atcgGetControlOptions", "atcgGetControlOptionsSample").atcgReplace("atcgRecordAppInit", "atcgRecordAppInitSample"));
		if s.atcgContains("JtdTransactionGenerator(") and not doneTG then
			doneTG:=true;
			g.writeLine(Tab&amp;Tab&amp;"constantDefinitions");
			g.writeLine(Tab&amp;Tab&amp;Tab&amp;'BackSlash:String="\";');
			g.writeLine(Tab&amp;Tab&amp;Tab&amp;'SemiColon:String=";";');
			sq:="'";
			g.writeLine(Tab&amp;Tab&amp;Tab&amp;'Sq:String="'&amp;sq&amp;'";');
			
			g.writeLine(Tab&amp;Tab&amp;"attributeDefinitions");
			g.writeLine(Tab&amp;Tab&amp;Tab&amp;"cancel:Integer;");
			g.writeLine(Tab&amp;Tab&amp;Tab&amp;"longPause:Integer;");
			g.writeLine(Tab&amp;Tab&amp;Tab&amp;"retCode:Integer;");
			g.writeLine(Tab&amp;Tab&amp;Tab&amp;"shortPause:Integer;");
		endif;
	endwhile;
	f.close;
	f.purge;
	g.close;
	g.rename("u:\schemaExtracts\JtdDriverSchema_Partial.scm");
	
	// fix up driver ddb file
	create f transient;
	f.kind := File.Kind_Unknown_Text; // 2/3/16  cnwns1 PAR 36286 unicode version
	f.fileName:="u:\schemaExtracts\save\JtdDriverSchema_Apps.ddb";
	f.usePresentationFileSystem:=false;
	f.mode:=File.Mode_Input;
	create g transient;
	g.fileName:="u:\schemaExtracts\JtdDriverSchema_Partial.ddb";
	g.mode:=File.Mode_Output;
	g.usePresentationFileSystem:=false;
	
	while not f.endOfFile do
		s:=f.readLine;
		g.writeLine(s);
	endwhile;
	f.close;
	g.close;
epilog
	delete f;
	delete g;
end;
</source>
    </JadeMethod>
    <JadeMethod name="atcgTester99" id="876f129f-5567-493d-a95d-af240a2d1b67">
        <source>atcgTester99();

vars
s, s2 : String;
b : Boolean;
begin
