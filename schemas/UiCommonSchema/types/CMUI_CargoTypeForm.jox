    <JadeMethod name="mnuEditAttributes_click" id="bc68d637-7c52-4a23-aed8-b8aedacd6e0c">
        <controlMethod name="MenuItem::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>mnuEditAttributes_click(menuItem: MenuItem input) updating;
/* ---------------------------------------------------------------------------
Created:	27 May 2009	by cnwvu1

Purpose:	
   
Change Date		Who		Reason

------------------------------------------------------------------------------*/
vars

begin

	self.doMenuEditAttributes();	//CCMS 1080, PAR 19704 User-defined Cargo Types. May 2009

end;</source>
