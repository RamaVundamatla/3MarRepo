    <JadeMethod name="updateTotals" id="7839bc36-7608-4380-8638-e2d843b619db">
        <updating/>
        <source>updateTotals() updating, protected;
//---------------------------------------
// Created: April 2006 By: cnwgd1
//---------------------------------------
vars
	qtyOnSite,
	qtyOnShip,
	qtyOffSite,
	row,
	numRows,
	fixed,
	totalQty,
	numDelivered : Integer;
	tmpTI : CM_TrackedItem;
	obj : Object;
begin
	
	if self.myCurrentBOL &lt;&gt; null then

		totalQty := self.myCurrentBOL.getTotalTIQty();
		numDelivered := self.myCurrentBOL.getTotalTIQtyDelivered();
		
		self.txtTotalQty.text := totalQty.String;
		self.txtNumDelivered.text := numDelivered.String;
		self.txtNumRemaining.text := (totalQty - numDelivered).String;				
										
	else
		numRows := self.tblData.rows;
		fixed := self.tblData.fixedRows;
		foreach row in fixed to numRows do
			obj := self.tblData.accessRow(row).itemObject;
			if CM_TrackedItem.hasInstance(obj) then
				tmpTI := obj.CM_TrackedItem;	
				if tmpTI.site = TI_SITE_ONSITE then
					qtyOnSite := qtyOnSite + tmpTI.totalQuantity;		
				elseif tmpTI.site = TI_SITE_ONSHIP then
					qtyOnShip := qtyOnShip + tmpTI.totalQuantity;				
				elseif tmpTI.site = TI_SITE_OFFSITE then
					qtyOffSite := qtyOffSite + tmpTI.totalQuantity;				
				endif;
			endif;
		endforeach;
	
		self.txtTotalQty.text := (qtyOnShip + qtyOffSite + qtyOnSite).String;
		self.txtNumDelivered.text := qtyOffSite.String;
		self.txtNumRemaining.text := (qtyOnShip + qtyOnSite).String;							
	
	endif;
	
	
end;</source>
        <access>protected</access>
    </JadeMethod>
</GUIClass>
