<Class name="CM_QDefBreakBulkGeneric" id="93c2df5c-cd05-4478-a0ec-9012a694ba2c">
    <superclass name="CM_QDefBreakBulk"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="query"/>
    <JadeMethod name="createProperties" id="090fa18b-1e46-46a0-a7cb-f113e723f843">
        <source>createProperties();
//15 December 2009	cnwml2
//
// Changed On	By			Reason
// ----------	--------	-------------------------------------------------------------
// 07/05/2013	cnwdap1		PAR #31155 CCMS SFW 1321 This class is called CM_QDefBreakBulkGeneric,
//							and all of the properties below are properties of the CM_BreakBulkGeneric class,
//							but the Selector screen "Break-Bulk Cargo" mode points at the system Cargo Type
//							CM_BreakBulk. So if any of the properties below are added to the Selector column
//							organiser for Break-Bulk Cargo mode, a "1011 The requested property is not defined for 
//							this object class" unhandled exception is raised. It's pretty obvious that no one uses
//							Break-Bulk Cargo mode on the Selector because this has never been raised as an issue,
// 							so the properties below will be removed for now.
// 23/05/2013	cnwdap1		PAR #31486 Re-jig querys so BreakBulkGeneric actually works, and change the type of the 
//							colour attribute to just a String one (I have an idea CM_QColourProperty may originally 
//							have been the integer representation of a colour, but for query purposes, colour is a string)
// 09/08/2013	cnwdap1		PAR #32037 Colour and Type moved up to the CM_QDefTrackedItem level
// 21/08/2014	cnwdap1		PAR #33235 Measurement types in Summaries
vars
	tmpProp : CM_QueryProperty;
begin
	inheritMethod();
	
	// PAR #32-37 moved up to the CM_QDefTrackedItem level
	//create tmpProp as CM_QColourProperty persistent;								// PAR #31486
	//create tmpProp as CM_QStringProperty persistent;								// PAR #31486
	//tmpProp.set( 'Colour', CM_BreakBulkGeneric::colour.name, self.className);
	//tmpProp.needToUpperCase := true;												// PAR #31486
	//self.allQueryProperties.add(tmpProp);
	
	create tmpProp as CM_QStringProperty persistent;
	tmpProp.set( 'Width String', CM_BreakBulkGeneric::widthString.name, self.className);
	tmpProp.setPerformanceRating( CM_QueryProperty.Simple );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add(tmpProp);
	
	create tmpProp as CM_QStringProperty persistent;
	tmpProp.set( 'Height String', CM_BreakBulkGeneric::heightString.name, self.className);
	tmpProp.setPerformanceRating( CM_QueryProperty.Simple );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add(tmpProp);
	
	create tmpProp as CM_QStringProperty persistent;
	tmpProp.set( 'Length String', CM_BreakBulkGeneric::lengthString.name, self.className);
	tmpProp.setPerformanceRating( CM_QueryProperty.Simple );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add(tmpProp);
	
	create tmpProp as CM_QIntegerProperty persistent;
	tmpProp.set( 'Quantity', CM_TrackedItem::quantity.name, self.className);
	tmpProp.setPerformanceRating( CM_QueryProperty.Simple );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add(tmpProp);
	
	//create tmpProp as CM_QIntegerProperty persistent;																						// PAR #33235
	//tmpProp.set( 'Density', CM_TrackedItem::density.name, self.className);																// PAR #33235
	//self.allQueryProperties.add(tmpProp);																									// PAR #33235
	self.createMeasurementProperties(CM_QIntegerProperty, Type_Density, 'Density', CM_TrackedItem::density.name, self.className, null);		// PAR #33235
	
	//create tmpProp as CM_QDecimalTotalWeightProperty persistent;																										// PAR #33235
	//tmpProp.set( 'Sub-Cargo Weight', CM_BreakBulkGeneric::unsplitWeight.name, self.className);																		// PAR #33235
	//self.allQueryProperties.add(tmpProp);																																// PAR #33235
	self.createMeasurementProperties(CM_QDecimalTotalWeightProperty, Type_Weight, 'Sub-Cargo Weight', CM_BreakBulkGeneric::unsplitWeight.name, self.className, null);	// PAR #33235
	
	// PAR #32-37 moved up to the CM_QDefTrackedItem level
	//create tmpProp as CM_QStringProperty persistent;
	//tmpProp.set( 'Type', CM_BreakBulkGeneric::type.name, self.className);
	//tmpProp.needToUpperCase := true;												// PAR #31486
	//self.allQueryProperties.add(tmpProp);
	
epilog

end;</source>
    </JadeMethod>
</Class>
