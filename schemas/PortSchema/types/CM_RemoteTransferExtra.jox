    <JadeMethod name="getDescription" id="36b1ecfe-21af-40bc-9c60-29c497af84fc">
        <source>getDescription(): String;

// cnwdvb1 13 June 2003 

vars

begin
	return 'Transfer No Number Extra';

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="saveFromArray" id="65a650dc-117f-4491-accc-11515c538f1c">
        <updating/>
        <source>saveFromArray(_array: StringArray) updating;

// cnwdvb1 13 June 2003 

vars

	i		: Integer;
	string	: String;

begin

	if _array.size &gt; 0 then
		if _array[1] = NNDetailHeading then
			self.allNNTis.clear;
			foreach i in 2 to _array.size do
				if _array[i] &lt;&gt; null then
					self.allNNTis.add(_array[i]);
				endif;
			endforeach;
		endif;
	endif;


end;</source>
        <Parameter name="_array" type="StringArray"/>
    </JadeMethod>
    <JadeMethod name="saveFromTable" id="4fc15303-ac53-4bc3-bed9-09ca661bed8a">
        <updating/>
        <source>saveFromTable(_table: Table input; _entryTableColumns: Integer) updating;

// cnwdvb1 13 June 2003 

vars

begin

	self.operator	:= _table.accessCell(2,_entryTableColumns).text.trimBlanks;
	self.species	:= _table.accessCell(3,_entryTableColumns).text.trimBlanks;
	self.grade		:= _table.accessCell(4,_entryTableColumns).text.trimBlanks;
	self.type		:= _table.accessCell(5,_entryTableColumns).text.trimBlanks;
	self.treatment	:= _table.accessCell(6,_entryTableColumns).text.trimBlanks;
	self.length		:= _table.accessCell(7,_entryTableColumns).text.trimBlanks;
	
end;</source>
        <Parameter name="_table" type="Table" usage="input"/>
        <Parameter name="_entryTableColumns" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="14ec7157-43f8-44f4-8ae7-389208ebc701">
        <updating/>
        <source>setForCreate(_proxy: CM_RemoteTransferExtra; _remoteDataDtl: CM_RemoteDataDtl) updating;

// cnwdvb1 13 June 2003 

vars

begin

	self.operator	:= _proxy.operator;
	self.species	:= _proxy.species;
	self.grade		:= _proxy.grade;
	self.type		:= _proxy.type;
	self.treatment	:= _proxy.treatment;
	self.length		:= _proxy.length;
	_proxy.allNNTis.copy(self.allNNTis);
	inheritMethod(_proxy, _remoteDataDtl);

end;</source>
        <Parameter name="_proxy" type="CM_RemoteTransferExtra"/>
        <Parameter name="_remoteDataDtl" type="CM_RemoteDataDtl"/>
    </JadeMethod>
    <JadeMethod name="setProxyForTransferExtra" id="78224266-7944-4f92-a62d-229dec9d2418">
        <updating/>
        <source>setProxyForTransferExtra(_remoteDtl : CM_RemoteDataDtl; _operator, _species, _grade, _type, _treatment, _length : String; _allNNTis : StringArray) updating;

// cnwdvb1 13 June 2003 

vars

begin

	self.operator		:= _operator;
	self.species		:= _species;
	self.grade			:= _grade;
	self.type			:= _type;
	self.treatment		:= _treatment;
	self.length			:= _length;
	_allNNTis.copy(self.allNNTis);
	self.setProxy(_remoteDtl);

end;</source>
        <Parameter name="_remoteDtl" type="CM_RemoteDataDtl"/>
        <Parameter name="_operator" type="String"/>
        <Parameter name="_species" type="String"/>
        <Parameter name="_grade" type="String"/>
        <Parameter name="_type" type="String"/>
        <Parameter name="_treatment" type="String"/>
        <Parameter name="_length" type="String"/>
        <Parameter name="_allNNTis" type="StringArray"/>
    </JadeMethod>
</Class>
