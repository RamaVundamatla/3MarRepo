        <source>machinePickup(_machine: CM_Machine input);
//07 January 2009	cnwdw1	
//
vars
	quantity : Integer;
begin

	if self.opts.includesKey("QUANTITY") then
		quantity := self.opts.int("QUANTITY");
	endif;
	
	self.ignoreTrxWarnings(true);
	app.myTrxUA.trxMachinePickupTask(_machine,quantity,null,app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
epilog
end;</source>
