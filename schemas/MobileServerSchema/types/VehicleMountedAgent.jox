    <JadeMethod name="loadRTTaskTable" id="54ed9ba9-83b0-4e80-9a56-59b8b0f59388">
        <updating/>
        <source>loadRTTaskTable(_table: Table input; _startRTQueueEntry : CM_RTQueueEntry input) updating;
/*

Purpose:			


Return Value:		


Date		Who		Reason
14 September 2006	cnwer1	Initial creation - PAR#xxxx
28 Jun 2010	cnwkpd1	PAR #24763 - Prevent 1090 and 14051 exceptions.  Ensure allAvailableRTQueueEntries
					is not populated with null objects
02 Sep 2010 cnwer1 	PAR 25206
*/

vars
	rtQueueEntry : CM_RTQueueEntry;
	allEntries : CM_RTQueueEntryArray;
	order : Integer;
	invalidObject : Boolean;
	objectEdition,
	maxDisplayEntries 	: Integer;
	dtoRTQueueEntry : DTO_RTQueueEntry;
	iter			: Iterator;

begin
	on Exception do app.handleDeletedObject(exception,rtQueueEntry,invalidObject);
	
	if self.useNewTableLoad then
		self.loadTaskTableNew(_table);
		return;
	endif;
	
	allEntries := self.myRTQueue.allEntries.cloneSelf(true);
	iter:=allEntries.createIterator;
	self.allQueuedNoteInfo.purge;
	order:=1;
// just incase all entries changes copy to a collection
//	create allEntries transient;
	
	while iter.next(rtQueueEntry) do
		invalidObject := false;
		objectEdition:=rtQueueEntry.edition;
		if invalidObject then
			continue;
		endif; 
		
		if not self.queryDisplayRTEntry(rtQueueEntry) then
			continue;
		endif;
		
		loadRTTaskTableEntry(rtQueueEntry,_table,order);	
		
		order:=order+1;
	endwhile;
		
	_table.resort;
epilog
	delete allEntries;
	delete iter;
end;</source>
        <Parameter name="_table" type="Table" usage="input"/>
        <Parameter name="_startRTQueueEntry" type="CM_RTQueueEntry" usage="input"/>
    </JadeMethod>
    <JadeMethod name="loadRTTaskTableEntry" id="373d7332-f6f0-403e-a25e-f9eab4e2b677">
