    <JadeMethod name="createProxyWorkOrderTasks" id="65800c9f-3b59-4b09-aa5f-882446bd8a57">
        <source>createProxyWorkOrderTasks(_detailType: Integer; _reqByDT: TimeStamp; _startDT: TimeStamp; _toDoTask: CM_ToDoTaskDesc);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 Sep 2022	navcs2	ChangeRequest 54344: EUP - VAS Work Orders - Jobs
24 Jan 2023	navma1  ChangeRequest 56141: EUP - Refactor and Remove CM_WorkOrderTISource from CM_WorkOrderTI
27 Jan 2023 navcs2	ChangeRequest 54344: EUP - VAS Work Orders - Jobs (Task 54263)
*/

vars
	pxyWODtl		    : CM_WorkOrderDtl;
	wodClass   		    : Class;
	workOrderDetailType	: CM_WorkOrderDetailType;
begin
	inheritMethod(_detailType, _reqByDT, _startDT, _toDoTask);	//24.01.2023 navma1 #56141 Task#56147
	
	/*
	 * 27 Jan 2023 navcs2 #54344 (Task 54263)
	 */
	
	if _toDoTask &lt;&gt; null then
		workOrderDetailType := app.myRoot.allWorkOrderTaskTypes[WorkOrderMode_ToDo, WO_TASK_ToDo_NONOPS];
	else
		workOrderDetailType := app.myRoot.allWorkOrderTaskTypes[WorkOrderMode_ToDo,_detailType];
	endif;
	
	if workOrderDetailType &lt;&gt; null then
		
		wodClass := workOrderDetailType.getWodClass(WorkOrderMode_ToDo);
		
		create pxyWODtl as wodClass transient;
		self.setProxyWorkOrderTask( pxyWODtl, _reqByDT, _startDT, false,_detailType, _toDoTask);
	endif;
	/*
	 * 27 Jan 2023 navcs2 #54344 (Task 54263)
	 */
epilog

end;
</source>
        <Parameter name="_detailType" type="Integer"/>
        <Parameter name="_reqByDT" type="TimeStamp"/>
        <Parameter name="_startDT" type="TimeStamp"/>
        <Parameter name="_toDoTask" type="CM_ToDoTaskDesc"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="865ae4a8-eb58-46ed-84cd-48b20c382ed3">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 March 2023		navhl20	Defect 57172: MTN - Voyage is empty for the To Do Voyage task

*/

vars
	voyage 		: CM_Voyage;
	invalid 	: Boolean;
	edition 	: Integer; 
begin

	if _attrName = ETRow_Voyage then
		on Exception do app.handleDeletedObject( exception, voyage, invalid );
		voyage := self.getMyVoyageObject();
		if voyage &lt;&gt; null then
			edition := voyage.edition;
			if invalid then
				return null;
			endif;
			return voyage.code;
		endif;
		return null;
	else
		return inheritMethod(_attrName, _short);
	endif;	
epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getExtraInfo" id="6c162c54-a2d0-413f-ac5d-d9f9f937e6be">
        <source>getExtraInfo(_dataContainer: CM_DataContainer);
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
06 January 2023	navcs2	ChangeRequest 54698:[54264] EUP - [Framework] - Enable VAS Work Order in Work Order Enquiry Screen

*/

vars
	wod : CM_WorkOrderDtl;
begin
	
	inheritMethod(_dataContainer);
	
	foreach wod in self.allWoDtls do 
		wod.getExtraInfo(_dataContainer);
	endforeach;
epilog

end;</source>
        <Parameter name="_dataContainer" type="CM_DataContainer"/>
    </JadeMethod>
    <JadeMethod name="getMyDebtor" id="d4f655d9-24e8-417d-bb32-4c1eb4c7c7de">
        <source>getMyDebtor(): CM_Debtor;
/*
Purpose:			

Date		Who		Reason
 // ### TFS CR 56814 TASK 56813 07JUL2023 NAVAB1
 
 */

vars
		wod : CM_WorkOrderToDoDtl;
begin

	foreach wod in self.allWoDtls as CM_WorkOrderToDoDtl discreteLock do
		if wod.myDebtor &lt;&gt; null then
			return wod.myDebtor;
		endif;
	endforeach;
	
	return inheritMethod();

epilog

end;</source>
        <ReturnType type="CM_Debtor"/>
    </JadeMethod>
    <JadeMethod name="getMyVoyageObject" id="a9df4d6f-0f1b-418b-b2f6-96e2859e3774">
        <source>getMyVoyageObject(): CM_Voyage;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 March 2023		navma1	Defect 57172: MTN - Voyage is empty for the To Do Voyage task

*/

vars
	wod : CM_WorkOrderDtl;
begin
	
	foreach wod in self.allWoDtls do 
		if not wod.isKindOf(CM_WodToDoVoyage) then
			continue;
		endif;
		
		return wod.CM_WodToDoVoyage.getMyVoyageObject();
		
	endforeach;
	
	return null;
epilog

end;</source>
        <ReturnType type="CM_Voyage"/>
    </JadeMethod>
    <JadeMethod name="getProgressString" id="725eeb62-0a24-4b9d-b2b8-4bf1c29f4512">
        <source>getProgressString(): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 Mar 2023	navcs2	ChangeRequest 54344: EUP - VAS Work Orders - Jobs
*/

vars
	task   		: CM_WorkOrderDtl;
	result 		: String;
	completed	: Integer;
	required	: Integer;
begin

	foreach  task in self.allWoDtls do
		completed := completed + task.getTotalComplete();			//23.03.2023 navma1 #54344
		required  := required  + task.getTotalRequested();          //23.03.2023 navma1 #54344
	endforeach;
	
	result := app.getErrorString2(N_of_n_Complete, completed.String, required.String);
	return result;
	
	return result;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getToDoTasksByStatus" id="b72d53ba-47f9-47aa-a5d2-a338a9ff27e0">
        <source>getToDoTasksByStatus(_status: Integer): Integer;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
10 March 2023	navcs2	ChangeRequest 54344: EUP - VAS Work Orders - Jobs

*/

vars
	count 		: Integer;
	toDoTask	: CM_ToDoTask;
	wodtl		: CM_WorkOrderDtl;
begin
	foreach wodtl in self.allWoDtls do
		count += wodtl.CM_WorkOrderToDoDtl.getToDoTaskCountByStatus(_status);
	endforeach;
	
	return count;
epilog

end;</source>
        <Parameter name="_status" type="Integer"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
