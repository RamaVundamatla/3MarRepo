    <JadeMethod name="createCargoMultiSurcharge" id="143cc587-febf-4f9d-8db2-eedbe47834b0">
        <source>createCargoMultiSurcharge(_updController : CnEcReleaseController);
/*

Purpose:			Migrates the old Cargo Surcharge objects to use the new Cago Multi Surcharge Objects

Parameters:			_updController	CnEcReleaseController	The update controller to use when making the updates

Return Value:		NONE

Date		Who		Reason
20 September 2022	navpw1	Initial creation TFS: 54571 (54394)

*/

vars
	invoiceType						: CM_InvoiceDesc;
	cargoSurchargeInvLineType		: CM_InvoiceLineDesc;
	terminal						: CM_Terminal;
	company							: CM_Bank;
	surchargesAndExemptions			: CM_InvoiceTypeSurchargeExempt;
	invTypeCargoSurcharge			: CM_InvTypeCargoSurcharge;
	newInvTypeCargoMultiSurcharge	: CM_InvTypeCargoMultiSurcharge;
	validFromTimeStamp				: TimeStamp;
	
begin
	if self.hasScriptBeenRunAtAll(method.name, _updController) then
		return;
	endif;
	
	
	app.writeLog(method.qualifiedName &amp; " Creating Cargo Multi Surcharge objects", LogINFO);
	if _updController &lt;&gt; null then
		_updController.logEntry(" Creating Cargo Multi Surcharge objects") ;	
	endif;
	
	beginTransaction;
	
	//Better to go through Terminal level or through app.myRoot.myRootCompany.subCompanies
	
	foreach terminal in app.myRoot.allTerminals do :terminalLoop
		if terminal.companies.isEmpty then
			continue terminalLoop;
		endif;
		
		foreach company in terminal.companies do :companyLoop
			if company.invoiceTypes.isEmpty then
				continue companyLoop;
			endif;
			
			foreach invoiceType in company.invoiceTypes do :invoiceTypeLoop
				if invoiceType.mySurchargeAndExemptions = null then
					continue invoiceTypeLoop;
				endif;
				
				surchargesAndExemptions := invoiceType.mySurchargeAndExemptions;
				if surchargesAndExemptions = null then
					continue invoiceTypeLoop;
				endif;
				
				if surchargesAndExemptions.allInvTypeCargoSurcharges.isEmpty then
					continue invoiceTypeLoop;
				endif;
				
				foreach invTypeCargoSurcharge in surchargesAndExemptions.allInvTypeCargoSurcharges do
					validFromTimeStamp:= app.actualTimeServer();
					
					create newInvTypeCargoMultiSurcharge persistent;
					
					if invTypeCargoSurcharge.myCargoType &lt;&gt; null then
						newInvTypeCargoMultiSurcharge.allCargoTypes.add(invTypeCargoSurcharge.myCargoType);
					endif;
					
					if invTypeCargoSurcharge.mySubCargoType &lt;&gt; null then
						newInvTypeCargoMultiSurcharge.allCargoSubTypes.add(invTypeCargoSurcharge.mySubCargoType);
					endif;
					
					if invTypeCargoSurcharge.myCommodity &lt;&gt; null then
						newInvTypeCargoMultiSurcharge.allCommodities.add(invTypeCargoSurcharge.myCommodity);
					endif;
					
					if not invTypeCargoSurcharge.allSelectedInvLineTypes.isEmpty then
						invTypeCargoSurcharge.allSelectedInvLineTypes.copy(newInvTypeCargoMultiSurcharge.allSelectedInvLineTypes);
					endif;
					
					cargoSurchargeInvLineType := invTypeCargoSurcharge.myCargoSurchargeInvLineType;
					if cargoSurchargeInvLineType &lt;&gt; null then
						newInvTypeCargoMultiSurcharge.setPropertyValue(CM_InvTypeCargoMultiSurcharge::myCargoSurchargeInvLineType.name, cargoSurchargeInvLineType);
					endif;
					
					newInvTypeCargoMultiSurcharge.setPropertyValue(CM_InvTypeCargoMultiSurcharge::mySurchargesAndExemptions.name, invTypeCargoSurcharge.mySurchargesAndExemptions);
					newInvTypeCargoMultiSurcharge.setPropertyValue(CM_InvTypeCargoMultiSurcharge::surchargeRate.name, invTypeCargoSurcharge.surchargeRate);
					
					//Populate validFrom Date time as now
					//Get current Date time from server
					newInvTypeCargoMultiSurcharge.setPropertyValue(CM_InvTypeCargoMultiSurcharge::validFrom.name, validFromTimeStamp);
					
				endforeach;
				
				surchargesAndExemptions.allInvTypeCargoSurcharges.purge;
				
			endforeach;
			
		endforeach;
		
	endforeach;
	
	commitTransaction;
	
	app.writeLog(method.qualifiedName &amp; " Creating Cargo Multi Surcharge objects complete", LogINFO);
	if _updController &lt;&gt; null then
		_updController.logEntry(" Creating Cargo Multi Surcharge objects complete") ;	
	endif;
	
	self.addScriptRun(method.name);
	
epilog
	
end;</source>
        <Parameter name="_updController" type="CnEcReleaseController"/>
    </JadeMethod>
