<Class name="CMIF_TMCBOLTrxGroup" id="82e7d277-15c8-4881-a541-5a766a21edcd">
    <superclass name="CMIF_TMCGroup"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="invoice"/>
    <PrimAttribute name="bolTrxType" id="db49c01d-f820-47d2-99bb-e068e40b823b">
        <embedded/>
        <type name="Integer"/>
    </PrimAttribute>
    <ImplicitInverseRef name="myBOLBroker" id="611871a3-d104-45bb-a2aa-9f0ee597663c">
        <embedded/>
        <type name="CM_BOLServiceBroker"/>
    </ImplicitInverseRef>
    <JadeMethod name="getPicture" id="dbbcc4b7-b00d-4b67-b679-b37bda3470a9">
        <source>getPicture(form: INV_TransactionMap): Picture;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 November 2019	jlgndl1	Initial creation	TFS 47100

*/

vars

begin
	if self.hidePictures then
		return null;
	endif;
	return form.picTrans;

epilog

end;</source>
        <Parameter name="form" type="INV_TransactionMap"/>
        <ReturnType type="Picture"/>
    </JadeMethod>
    <JadeMethod name="getRealMapObject" id="24537449-a6ca-42de-96de-b6d2bc200512">
        <source>getRealMapObject(): Object;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 November 2019	jlgndl1	Initial creation	TFS 47100

*/

vars

begin
	return self.myBOLBroker;

epilog

end;</source>
        <ReturnType type="Object"/>
    </JadeMethod>
    <JadeMethod name="initialise" id="0b6102f0-976a-409e-a661-9150a58bc4f3">
        <updating/>
        <source>initialise(_groupCount: Integer io) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 November 2019	jlgndl1	Initial creation	TFS 47100

*/

vars
	tmcDebtor : CMIF_TMCDebtorGroup;
	aDM : CM_DebtorMap;
begin
	self.myTMCController := self.myGroup.myTMCController;	
	self.hidePictures := self.myTMCController.hidePictures;

	create tmcDebtor as CMIF_TMCDebtorGroupDefault;
	tmcDebtor.myDebtor := null;
	tmcDebtor.myDebtorMap := null;
	tmcDebtor.myServiceBroker := self.myBOLBroker;
	tmcDebtor.itemName := tmcDebtor.getItemName();
	tmcDebtor.extractName := tmcDebtor.getItemCode();		
	tmcDebtor.myGroup := self;
	tmcDebtor.initialise(_groupCount);
	
	foreach aDM in self.myBOLBroker.allDebtorMapsByDebtor do
		create tmcDebtor;
		tmcDebtor.myDebtor := aDM.myDebtorNode;
		tmcDebtor.myDebtorMap := aDM;
		tmcDebtor.itemName := tmcDebtor.getItemName();
		tmcDebtor.extractName := tmcDebtor.getItemCode();		
		tmcDebtor.myGroup := self;
		tmcDebtor.initialise(_groupCount);
	endforeach;
	_groupCount := _groupCount + 1; 
end;</source>
        <Parameter name="_groupCount" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="setControllerCurrent" id="fb40e86f-a40c-46d2-a71e-7355400a6769">
        <source>setControllerCurrent();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 November 2019	jlgndl1	Initial creation	TFS 47100

*/

vars

begin
	inheritMethod();
	
	myTMCController.myCurrentMapTMBOL := self.myBOLBroker.myTransMap;
	myTMCController.myCurrentMapServiceBroker := self.myBOLBroker;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setEnableObjects" id="0a6c82d0-a2a2-46a2-bfdf-0a740482109f">
        <source>setEnableObjects(form: INV_TransactionMap io);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 November 2019	jlgndl1	Initial creation	TFS 47100

*/

vars

begin
	inheritMethod(form);
	
	form.menuTMBOLnew.visible := true;  // MAIN WO NEW MENU
	form.menuSItemNew.visible := false;  // MAIN CARGO NEW MENU	
	form.modePropertyNew := INV_TransactionMap.ModeProperty_Debtor;
	form.modePropertyUpdate := INV_TransactionMap.ModeProperty_TransType;
	form.modePropertyDelete := INV_TransactionMap.ModeProperty_BOL;

	form.menuTMBOLnew.enabled := true;
	form.menuTMBOLdebtor.visible := true;
	form.menuSItemDelete.enabled := true;
	
	form.btnDelete.enabled := true;
	form.btnNew.enabled := true;


epilog

end;</source>
        <Parameter name="form" type="INV_TransactionMap" usage="io"/>
    </JadeMethod>
    <JadeMethod name="setMyCurrent" id="a31e8af3-1705-4452-a73e-93fefc1a9c8d">
        <updating/>
        <source>setMyCurrent(form: INV_TransactionMap io) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 November 2019	jlgndl1	Initial creation	TFS 47100

*/

