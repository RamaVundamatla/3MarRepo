/*

Purpose:			Opens the panel for Invoice Type Debtor Separation if an item in the table is double clicked

Parameters:			table	Table	The table to get the selected object from

Return Value:		NONE

Date		Who		Reason
25 August 2022	navpw1	Initial creation TFS: 54565 (54384) - EUP - Inv Config - Invoice Surcharges

*/

begin
	if table.row &lt;= table.fixedRows then
		table.CM_DataTable.resortTableByColumn(table.column);
		table.accessRow(1).fontBold := false;
		table.accessCell(1,table.column).fontBold := true;
	else
		self.btnISAEdit.click(self.btnISAEdit);
	endif;
	
end;</source>
