<Class name="CM_QStrCountryOfOriginMethod" id="d61b3c3e-2c26-4e03-9511-7711cb9896b2">
    <superclass name="CM_QStringLookupMethod"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="query"/>
    <JadeMethod name="create" id="7c1c64af-baed-41f8-aefd-46efaab82968">
        <updating/>
        <source>create() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 Aug 2022 navtnr20 ChangeRequest 54441: EUP - Additional Field - Country of Origin

*/

vars
	operator : CM_QueryOperator;

begin
	if self.isTransient then
		return;
	endif;
	
	create operator as CM_QStringIsOneOf persistent;
	self.allAllowedOperators.add(operator);
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="getControlNameForOperator" id="f7ef4b80-69dc-46ba-853b-841c0062b0db">
        <source>getControlNameForOperator(_operator: CM_QueryOperator): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 Aug 2022 navtnr20 ChangeRequest 54441: EUP - Additional Field - Country of Origin
*/

vars

begin
	if CM_QReferenceLookup.hasInstance(_operator) then
		return "cmbCountryOfOrigin";
	endif;

epilog

end;</source>
        <Parameter name="_operator" type="CM_QueryOperator"/>
        <ReturnType type="String"/>
    </JadeMethod>
