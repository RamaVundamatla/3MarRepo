        <source>searchForNotifiedTI(tiId : String; matches : Integer output) : CM_TrackedItem;
//Call this when you DONT know the TI type, hunts for each type.
//We only look onsite, and for a NOTIFIED state ti. (speeds up the search)
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 29/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
// ---------------------------------------------------------------------------
vars
	ti		: CM_TrackedItem;
begin

	ti := self.lookupNumTIMatchesWithId(tiId, TI_CargoType_Null, TI_STATE_NOTIFIED, matches);

	return ti;
end;</source>
