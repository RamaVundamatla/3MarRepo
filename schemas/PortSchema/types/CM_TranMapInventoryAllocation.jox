    <JadeMethod name="shouldAuditProperty" id="3b732820-6ddd-4861-8ca5-e5ec21c05171">
        <source>shouldAuditProperty(_rootClass: Class; _property: Property): Boolean protected;
/*
Purpose:			

Date		Who		Reason
25MAY2021	NAVAB1	TFS 51219
*/

vars
		propName	: String;
begin
	if _property = null then
		return false;
	endif;
	
	propName := _property.name;
	
	if	propName = CM_TranMapCargoAllocation::myChildQuantityMap.name or
		propName = CM_TranMapCargoAllocation::myInvoiceAllocationConfig.name or
		propName = CM_TranMapCargoAllocation::myBank.name 
		
		then
		return false;
	else
		return inheritMethod(_rootClass, _property);
	endif;
epilog
end;</source>
        <access>protected</access>
        <Parameter name="_rootClass" type="Class"/>
        <Parameter name="_property" type="Property"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validateForCreate" id="e4f8647b-9f0a-4dc6-9442-3b83f0104aee">
        <source>validateForCreate();
/*
Purpose:			

Date		Who		Reason
25MAY2021	NAVAB1	TFS 51219
*/


vars

	c : CM_YACriteriaType;
begin

	if self.name = null then
		app.raiseCMException1( Input_required_field_Required, app.getString( Name ), self.name, null );
	endif;

	if self.myBank &lt;&gt; null then
		if self.myBank.allCargoAllocTranMaps[self.name] &lt;&gt; null then
			app.raiseCMException1(Already_exists_transMap,self.name,null,null); 
		endif;
	endif;
	

	if self.myInvoiceAllocationConfig &lt;&gt; null then
		if self.myInvoiceAllocationConfig.allOpCriteria.isEmpty() then
		
			app.raiseCMException(No_Criteria_values_selected,null,null);
		endif;

		c := self.myInvoiceAllocationConfig.getCriteriaByType(YACriteriaType_InventoryType);
			
		if c = null then
			app.raiseCMException(Pleas_selec_some_inven_type_cr,null,null);
		
		endif;
	endif;
end;	</source>
    </JadeMethod>
    <JadeMethod name="validateForDelete" id="327bfa8f-6dde-423e-9a2d-260b798dadae">
        <source>validateForDelete();
/*
Purpose:			

Date		Who		Reason
25MAY2021	NAVAB1	TFS 51219
*/

vars

begin
	if self.myBank.myCurrentTranMapInventory = self then
		app.raiseCMException(ERR_TRANSMAP_ACTIVE, null, null);
	endif;

end;</source>
    </JadeMethod>
    <JadeMethod name="validateForUpdate" id="7db28295-ba85-4d1f-8624-89e54c301f0a">
        <source>validateForUpdate();
/*
Purpose:			

Date		Who		Reason
25MAY2021	NAVAB1	TFS 51219
*/

vars
	original,
	existingTM	: CM_TranMapInventoryAllocation;
begin
	if self.name = null then
		app.raiseCMException1( Input_required_field_Required, app.getString( Name ), self.name, null ); // cnwdb2	PAR 35364
	endif;

	
	if self.myBank &lt;&gt; null then
		original := self.pxyGetRealObject();
		if existingTM &lt;&gt; null and existingTM &lt;&gt; original then
			app.raiseCMException1(Already_exists_transMap,self.name,null,null); //cnwdb2	PAR 35364

		endif;
	endif;
	
end;</source>
    </JadeMethod>
</Class>
