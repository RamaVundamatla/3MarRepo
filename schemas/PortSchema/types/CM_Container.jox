    <JadeMethod name="getDirectionMotor" id="f1820a41-9f0a-4943-83ec-41fc4abe6e0b">
        <source>getDirectionMotor() : Integer;
// ---------------------------------------------------------------------------
// Created:		November 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	aWLE : CM_WorkListEntry;
	
begin
	//epr TFS 7006 29/9/17
	if not self.isIntegral then
		return Motor_Null;
	endif;
	
	// try to get the info from the Slot Request
	foreach aWLE in self.allWorklistEntries reversed do // PAR 8151 added reversed
		if CM_VoyageWLE.hasInstance(aWLE) then
			if aWLE.myRequest.getAttrIsLoad then // PAR 8151 added, only want to look at the latest LOAD colour coding
				return aWLE.myRequest.getMotorDirection; //epr TFS 7006 29/9/17
			endif;
		endif;
	endforeach;
	
	return Motor_Null;
	
end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getDisplayPackTempForReports" id="3911971e-9f60-458c-848e-8240f6b7ea45">
        <source>getDisplayPackTempForReports(): String;
// ---------------------------------------------------------------------------
// Created:     11 July 2005	cnwhjg1
//
// Purpose:     
// ----------   ----------  --------------------------------------------------
// Changed		By		Why
// ----------	-------	------------------------------------------------------
// 07/12/2009	cnwdap1	CCMS MES 1007 moved reefer properties up to CM_TackedItem level
vars
	tempR	: String;
	units	: String;
begin
	return inheritMethod();
	
/*	if self.packTempC = null then
		return null;
	endif;
	
	if not self.requiresTemperature then
		return null;
	endif;
	
	if self.displayTempFahrenheit then
		tempR := self.packTempF;
		units := Degrees_F;
	else
		tempR := self.packTempC;
		units := Degrees_C;
	endif;
	//Do not call the method on app as app is not handled by reports
	if tempR.Real &gt; 0.0 then
		return "+" &amp; tempR.String &amp; units;
	else
		return tempR.String &amp; units;
	endif;	*/

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDisplayPackTemperature" id="403fb4e5-2a1a-44d9-b7ec-3b06b1950095">
        <source>getDisplayPackTemperature(inCelsius: Boolean): String;
//
// 03/12/2009	cnwdap1	CCMS MES 1007 - move reefer properties to CM_trackedItem level
//
vars
	tempR	: String;
	units	: String;
begin
	return inheritMethod(inCelsius);
	
	/*if inCelsius then
		if self.packTempC = null then
			return null;
		endif;
	else 
		if self.packTempF = null then
			return null;
		endif;
	endif;
	
	if not self.requiresTemperature then
		return null;
	endif;
	
	if not inCelsius then
		tempR := self.packTempF;
		units := Degrees_F;
	else
		tempR := self.packTempC;
		units := Degrees_C;
	endif;
	//Do not call the method on app as app is not handled by reports
	if tempR.Real &gt; 0.0 then
		return "+" &amp; tempR.String &amp; units;
	else
		return tempR.String &amp; units;
	endif;
	*/
end;</source>
        <Parameter name="inCelsius" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="5f3925fc-d973-4c5c-8af7-c7466d9ee1cd">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
// ---------------------------------------------------------------------------
// Created:		December 2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 04/11/2009	cnwdap1		CCMS 1017 - add over dimensions fields
// 03/12/2009	cnwdap1		CCMS MES 1007 - move reefer properties up to CM_TrackedItem level
// 19/02/2010	cnwdap1		PAR #21624 Return over dimension details with no decimal places
// 07/04/2010	cnwjre1		PAR 23277 CCMS 1922 additional columns in Invoice Lines form
// 01/03/2013	cnwdap1		PAR #31155 CCMS SFW 1321 Imperial Measurements
// 14/06/2018	jlgsl4		TFS 38813 - STWO - date fields not sorting properly for 'no Anniversary' cargo
// 30/10/2018 	jlgrh7 	TFS #41372 MSL - MGW on Cargo Enquiry
// 04/11/2019	jlgdap1		TFS 46405 AAT Flat Rack and OOG in LOLO Planning Screen
// 01 Nov 2022 navtnr20 ChangeRequest 54967: EUP - INB/OUT - Operational Instructions
// 19 Jul 2025 jlier1  JIRA-34771 MTN | Pagination - Cargo Enquiry Form - performance improvements  
// ---------------------------------------------------------------------------

vars
	tmpStatus			: CM_ContentsStatus;
	theISOType			: CM_ISOType;
	doorDir			: Integer;
	row, measure			: String;			// PAR #31155
begin
	//if  _attrName = ETRow_AmTemp then		// CCMS 1007
		//return self.getAMTemp;			// CCMS 1007
	if _attrName = ETRow_IsPreTrip then
		return app.getYesNo(self.offsitePreTrip);
	elseif _attrName = ETRow_OffsiteCleaned then
		return app.getYesNo(self.offsiteCleaned);
	elseif _attrName = ETRow_BookingRef then
		return self.bookingReference;
	elseif _attrName = ETRow_ContainerVolume then
	//	if self.getMyTotalVolume &gt; NULL_VOLUME then
	//		return self.getMyContainerVolume.asStringJMT();	//** #25592 18/11/2010 fixed ITALIAN locale
		
		//05 Nov 2012	NDL	Par 30615
		if self.getMaxVolume() &gt; NULL_VOLUME then	//05 Nov 2012	NDL	Par 30615
			return self.getMaxVolume().asStringJMT();
		else
			return null;
		endif;
	elseif _attrName = ETRow_ContainerWeight then
		return self.weightTare.asStringWeightJMT();
	elseif _attrName = ETRow_ContentsStatus then
		tmpStatus := app.myRoot.allContentsStatuses[self.contentsStatus];
		if tmpStatus &lt;&gt; null then
			return tmpStatus.description;
		else
			return null;
		endif;		
	
	elseif _attrName = ETRow_Inspected then
		return app.getYesNo(self.getPreTripDT.isValid);		
						
	elseif _attrName = ETRow_Is40 then
		return app.getYesNo(self.is40);
	
	elseif _attrName = ETRow_IsClean then
		return app.getYesNo(self.isClean);

	elseif _attrName = ETRow_IsoType then
		theISOType := self.getISOTypeObject();
		if theISOType &lt;&gt; null then
			return theISOType.code.trimBlanks;
		endif;
	elseif _attrName = ETRow_IsoTypeDesc then
		theISOType := self.getISOTypeObject();
		if theISOType &lt;&gt; null then
			return theISOType.code.trimBlanks &amp; " - " &amp; theISOType.description.trimBlanks;
		endif;		
	elseif _attrName = ETRow_IsHeavyDuty then
		return app.getYesNo(self.isHeavyDuty);
		
	elseif _attrName = ETRow_IsTranshipItem then
		return app.getYesNo(self.isTranshipItem);
	// par 23277 CCMS 1922 alternative version returning Yes/null
	elseif _attrName = ETRow_CargoIsTranship then
		return app.getYesBlank(self.isTranshipItem);
	elseif _attrName = ETRow_OffsiteCleaned then
		return app.getYesNo(self.offsiteCleaned);
		
	elseif _attrName = ETRow_OffsitePreTrip then
		return app.getYesNo(self.offsitePreTrip);

	elseif _attrName = ETRow_OutOfGauge then
		return app.getYesNo(self.isNonStandardHeight);
	
	elseif _attrName = ETRow_OverHeight then
		return self.overHeight.asStringMeasurementJMT();		// PAR #21624
	elseif _attrName = ETRow_OverLengthFront then
		return self.overLengthFront.asStringMeasurementJMT();	// PAR #21624
	elseif _attrName = ETRow_OverLengthBack then
		return self.overLengthRear.asStringMeasurementJMT();	// PAR #21624
	elseif _attrName = ETRow_OverWidthLeft then
		return self.overWidthLeft.asStringMeasurementJMT();		// PAR #21624
	elseif _attrName = ETRow_OverWidthRight then
		return self.overWidthRight.asStringMeasurementJMT();	// PAR #21624	
	elseif _attrName = ETRow_PreTripDate then
		if not self.getPreTripDT.isValid then
			return null;
		else
			return self.systemToLocalTime(self.getPreTripDT).date.shortFormatJMT(); // Par 11176	
		endif;

	elseif  _attrName = ETRow_PreTripDT or  _attrName = ETRow_PreTripDTSort then // PAR 36941
		if self.getPreTripDT.isValid then
			return systemToLocalTime(getPreTripDT).asStringJMT();
		else
			return null;
		endif;
	elseif _attrName = ETRow_RepackedDT or  _attrName = ETRow_RepackedDTSort then // PAR 36941
		if self.repackedDT.isValid then
			return self.systemToLocalTime(self.repackedDT).asStringJMT();
		else 
			return null;
		endif;		
	elseif _attrName = ETRow_SeqNumAsString then
		//return self.sealNum;
		return null;//15 Sep 2010	NDL	Par 25608 - Certainly shouldn't be sealNum, agreed with Doug return null in interim.
	elseif _attrName = ETRow_ToBeInspected then
		return app.getYesNo(self.hasInspectionStop);
	elseif _attrName = ETRow_UnpackedDT then
		if self.unpackedDT.isValid then
			return self.systemToLocalTime(self.unpackedDT).asStringJMT();
		else
			return null;
		endif;		
	elseif _attrName = ETRow_WashDT or _attrName = ETRow_WashDTSort then // PAR 36941
		if self.washDT.isValid then
//			if self.isClean then // TFS 38813
//				return self.systemToLocalTime(self.washDT).asStringJMT(); // TFS 38813
 			if _attrName = ETRow_WashDTSort or self.isClean then // TFS 38813
				return self.systemToLocalTime(self.washDT).asStringJMT(); // TFS 38813
			else // TFS 38813 - here if it's WashDT and not isClean...
				return  self.systemToLocalTime(self.washDT).asStringJMT() &amp; ' - Expired.';
			endif;
		else
			return null;
		endif;
	elseif _attrName = ETRow_Wet then
		return null;
	elseif _attrName = ETRow_ImportVoyageCode then //ccms 1602 cnwrs1 mar 2005
		return self.importVoyageCode;
	elseif _attrName = ETRow_OriginalLoadPort then //ccms 1602 cnwrs1 mar 2005
		return self.originalLoadPort;
	elseif _attrName = ETRow_Ostow then
		
		return self.isOverStowedRTQueue(null).getYes.asStringJMT;
	elseif _attrName = ETRow_Ptid then //cnwrd1 par 28274 30.9.11 ccms 1241
		return app.getYesNo(self.getPreTripDT.isValid);
	elseif _attrName = ETRow_PtidOffsite then //cnwrd1 par 28274 30.9.11 ccms 1241
		return app.getYesBlank(self.offsitePreTrip);
		
	elseif _attrName = ETRow_MaxTotalWeight then												//+TFS41372
			// TFS 45590 return self.getISOTypeObject.maxTotalWeight.asStringJMT();
			
			theISOType := self.getISOTypeObject(); // TFS 45590 
			if theISOType&lt;&gt; null then // TFS 45590 
				return theISOType.maxTotalWeight.asStringJMT(); // TFS 45590 
			endif;
			return null;
		
	elseif _attrName = ETRow_FlatRackStatus then					// TFS 46405
		return app.flatRackEndsEnumToString(self.doorsDirn);		// TFS 46405
	// Start 20.10.2022 navtnr20 TFS 54967
	elseif _attrName = ETRow_InstructionInternal then		
		if self.myInstructions &lt;&gt; null then
			return self.myInstructions.internalInstructions.formatWithEllipsis(1,50,true);
		endif;
		return null;
	elseif _attrName = ETRow_InstructionExternal then
		if self.myInstructions &lt;&gt; null then
			return self.myInstructions.externalInstruction.formatWithEllipsis(1,50,true);
		endif;
		return null;
	elseif _attrName = ETRow_InstructionCode then
		if self.myInstructions &lt;&gt; null then
			return self.myInstructions.getInstructionCode();
		endif;
		return null;
	elseif _attrName = ETRow_InstructionDesc then		
		if self.myInstructions &lt;&gt; null then
			return self.myInstructions.getInstructionDesc();
		endif;
		return null;
	/* this is done on CM_TrackedItem::getDisplayStringForAttribute - so doing _attrName.isMeasurementType  here is doing it twice and it is quite expensive
	elseif _attrName.isMeasurementType then											// PAR #31155
		_attrName.getRowNameMeasureType(row, measure);								// PAR #31155
		return self.getMeasurementStringForAttrib(row, measure, _short);			// PAR #31155*/
	else
		return inheritMethod(_attrName, _short);
	endif;

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDisplayTempFahrenheit" id="a7da6cde-7dcf-4cfa-85d0-c5bd23ab2551">
        <source>getDisplayTempFahrenheit() : String;
// ---------------------------------------------------------------------------
// Created:     18 December 2003	cnwth2
//
// Purpose:     
// ----------   ----------  --------------------------------------------------
// 03/12/2009	cwdap1		CCMS 1007 - move reefer properties to CM_TrackedItem level
vars

begin
	return inheritMethod();
	
	/*if self.getTemperature = NULL_TEMPERATURE then
		return null;
	endif;
	
	if not self.requiresTemperature then
		return null;
	endif;
	
	//return app.temperatureDisplayString(self.temperatureInFahrenheit) &amp; Degrees_F;
	return app.temperatureDisplayString(self.temperatureInFahrenheit);
	*/
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDisplayTempForReports" id="f2543a72-e71e-4a7b-b5d9-df519e965125">
        <source>getDisplayTempForReports(): String;
//----------------------------------------------------------------
//	Created:	05 September 2003	by Jason Chapman  (cnwjc2)
//	For reports
//----------------------------------------------------------------
// Changed		By		Why
// ----------	-------	------------------------------------------------------
// 07/12/2009	cnwdap1	CCMS MES 1007 moved reefer properties up to CM_TrackedItem level
vars
	tempR	: Real;
	units	: String;
begin
	return inheritMethod();
	
/*	if self.getTemperature = NULL_TEMPERATURE then
		return null;
	endif;
	
	if not self.requiresTemperature then
		return null;
	endif;
	
	if self.displayTempFahrenheit then
		tempR := self.temperatureInFahrenheit;
		units := Degrees_F;
	else
		tempR := self.getTemperature;
		units := Degrees_C;
	endif;
	//Do not call the method on app as app is not handled by reports
	if tempR &gt; 0.0 then
		return "+" &amp; tempR.String &amp; units;
	else
		return tempR.String &amp; units;
	endif;	*/

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDisplayTemperature" id="284e9785-de5d-4a57-9a5b-92f27c87a780">
        <source>getDisplayTemperature(_displayBoth: Boolean; _returnCelcius: Boolean): String;
// ---------------------------------------------------------------------------
// Created:		06 June 2003  by Jason Chapman  (cnwjc2)
// ---------------------------------------------------------------------------
// Changed		By		Why
// ----------	-------	------------------------------------------------------
// 07/12/2009	cnwdap1	CCMS MES 1007 moved reefer properties up to CM_TrackedItem level
vars

begin
	return inheritMethod(_displayBoth, _returnCelcius);
	
/*	if self.getTemperature = NULL_TEMPERATURE then
		return null;
	endif;

	if not self.requiresTemperature then
		return null;
	endif;
	
	if not _returnCelcius then
		if _displayBoth then
			return app.temperatureDisplayString(self.temperatureInFahrenheit) &amp; Degrees_F &amp; " / " &amp; app.temperatureDisplayString(self.getTemperature) &amp; Degrees_C;
		elseif self.displayTempFahrenheit then
			return app.temperatureDisplayString(self.temperatureInFahrenheit) &amp; Degrees_F;
		endif;
	endif;
	
//	return app.temperatureDisplayString(self.temperature) &amp; Degrees_C;
	return app.temperatureDisplayString(self.getTemperature); 	*/
		
end;</source>
