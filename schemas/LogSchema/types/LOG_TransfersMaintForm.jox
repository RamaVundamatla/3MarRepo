/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
17 September 2008	cnwar2	Initial creation

*/

vars
	row,	
	theColumn,
	max,
	fixed		: Integer;
	cell		: JadeTableCell;
begin

	max 		:= self.tblSelectData.rows;
	fixed 		:= self.tblSelectData.fixedRows;
	theColumn 	:= self.tblSelectData.getColumnByRowName(ETRow_SelectedDocket);
	if theColumn &lt;&gt; 0 then
		foreach row in fixed + 1 to max do
			cell 		:=	self.tblSelectData.accessCell(row, theColumn);
			cell.text 	:= null;
		endforeach;
	endif;

	/*
	Date		Who		Reason
	24 Sep 2008	cnwdz2	PAR 17987 - clear tolocation combo
	*/
	self.reselectToCombo(self.cmbTOLocation, self.tblActionData);
	
end;</source>
