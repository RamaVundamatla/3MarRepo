    <JadeMethod name="deleteAllCargo" id="c04427bc-8bbe-472b-af07-07969757c8ec">
        <source>deleteAllCargo(id: String; _cargoType: Any);
/*

Purpose:		will delete all cargo in terminal of particular cargo type
				- only relevant really for cargo types with duplicates

Parameters:			

Return Value:		

Date		Who		Reason
10 May 2013	cnwer1	Initial creation CCMS DPH 2274

*/

vars

begin
	
	while true do
		if not self.deleteCargo(id,_cargoType) then
			break;
		endif;
	endwhile;
epilog

end;</source>
        <Parameter name="id" type="String"/>
