    <JadeMethod name="getJobInstructions" id="f27b6d38-facf-487a-a03f-402c1e6a17c4">
        <source>getJobInstructions(_instructions: CM_InstructionsIssuedSet io);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 Apr 2025	navbs1	Initial Creation Bug MTN-34396: EUP | Additional Operational Instructions - more issues (part 2)

*/

vars
	wod 		: CM_WorkOrderDtl;
	workorder	: CM_WorkOrder;
	relReq		: CM_BulkRelease;
	resDtl		: CM_ReserveDetail;
	book		: CM_BookingRef;
	bookDtl		: CM_BookingRefItem;
	wle			: CM_WorkListEntry;
	woWle		: CM_WOWLE;
	trackedItem  : CM_TrackedItem;
	wodSet 		: CM_WorkOrderDtlSet;

begin
	create wodSet transient;
	foreach wle in self.workListEntries discreteLock do
			woWle := wle.myWorkOrderWLE;			
			if woWle &lt;&gt; null and woWle.job &lt;&gt; null  then
				wodSet.tryAddIfNotNull(woWle.job.myWODtl);
			endif;
	endforeach;
	
	foreach wod in wodSet discreteLock do
	
		if wod &lt;&gt; null then
			workorder := wod.myParent;
		endif;
		
		if workorder &lt;&gt; null then
			_instructions.tryAddIfNotNull(workorder.getInstructions());
		endif;
			
		
		if wod &lt;&gt; null then
			_instructions.tryAddIfNotNull(wod.getInstructions());
		endif;
		
		if wod &lt;&gt; null then	
			if wod.isKindOf(CM_WodRelease) then
				relReq := wod.CM_WodRelease.myReleaseRequest;
				resDtl := wod.CM_WodRelease.myReserveDetail;
				book	:= wod.CM_WodRelease.myBookingRef;
				bookDtl	:= wod.CM_WodRelease.myBookingRefItem;
			elseif wod.isKindOf(CM_WodReceive) then
				book := wod.CM_WodReceive.myBookingRef;
				bookDtl	:= wod.CM_WodReceive.myBookingRefItem;
			endif;
			if relReq &lt;&gt; null then
				_instructions.tryAddIfNotNull(relReq.getInstructions());
			endif;

			if book &lt;&gt; null then
				_instructions.tryAddIfNotNull(book.getInstructions());
			endif;

			
			if resDtl &lt;&gt; null then
				_instructions.tryAddIfNotNull(resDtl.getInstructions());
			endif;
			
			if bookDtl &lt;&gt; null then
				_instructions.tryAddIfNotNull(bookDtl.getInstructions());
			endif;
		endif;
	endforeach;
		
	
	foreach wle in self.workListEntries do 
		trackedItem := wle.myTrackedItem;
		if trackedItem &lt;&gt; null then
			_instructions.tryAddIfNotNull(trackedItem.getInstructions());
		endif;		
	endforeach;

epilog
	delete wodSet;
end;</source>
        <Parameter name="_instructions" type="CM_InstructionsIssuedSet" usage="io"/>
    </JadeMethod>
