    <JadeMethod name="mnuGridPlanLoad_click" id="f47e21b0-cbe9-4061-961c-37ea61c79320">
        <controlMethod name="MenuItem::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>mnuGridPlanLoad_click(menuItem: MenuItem input) updating;
// ---------------------------------------------------------------------------
// Created:		January 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	theTI : CM_TrackedItem;
begin
	// PAR7631 AKB2004FEB from here
	if app.myMoveController &lt;&gt; null then
		theTI := app.myMoveController.myTrackedItem;
		if theTI &lt;&gt; null then
			if theTI.getFutureMoveOfType(PLANNING_MODE,TI_FutureMoveDLRLoad) &lt;&gt; null  
			or  theTI.getFutureMoveOfType(PLANNING_MODE,TI_FutureMovePlanned) &lt;&gt; null  then
//				app.msgBox(theTI.id &amp; " is already planned to load, cannot plan again. Unplan and re-plan.","Planning Error",MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
				
				app.raiseCMException1(Alread_planne_unplan_replan_ne,theTI.id, null, null);
				return;
			endif;
		endif;
	endif;
	// PAR7631 AKB2004FEB to here

	// NOTE the TI and the source location have already been set on the build of the context menu

	if menuItem.userObject.isKindOf(CM_LocationsController) then
		self.moveTrackedItemSource();
	else
		// ### BULK LOAD PLANNING
		self.moveTrackedItemsSource(self.myCurrentDrawingController);
	endif;



end;</source>
        <Parameter name="menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
