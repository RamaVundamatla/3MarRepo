    <DbClassMap file="CnEcXML"/>
    <ImplicitInverseRef name="myFormat" id="fce6d94c-cb71-4591-a671-b3000693214a">
        <embedded/>
        <type name="CnEcXmlFormat"/>
        <access>readonly</access>
    </ImplicitInverseRef>
    <JadeMethod name="createNewCopy" id="815fbda6-78e9-4af2-8c79-a1ea681b7b5f">
        <updating/>
        <source>createNewCopy(pNewFormatClass: CnEcXmlFormatClass): CnEcXmlFormatProperty updating;

vars
	retVal : CnEcXmlFormatReference;
	
begin
	create retVal as app.myCnEcXmlSchema.getClass(self.class().name);
	retVal.initializeMe(self.propertyName, self.tagName, self.isShowTagData, pNewFormatClass);
	
	if self.myFormat = self.myFormatClass.myFormat then  
    	retVal.setMyFormat(pNewFormatClass.myFormat);
    else
    	retVal.setMyFormat(self.myFormat);
    endif;

	return retVal;
end;</source>
        <Parameter name="pNewFormatClass" type="CnEcXmlFormatClass"/>
        <ReturnType type="CnEcXmlFormatProperty"/>
    </JadeMethod>
    <JadeMethod name="setMyFormat" id="eae967ee-8190-4c57-a35e-63569c547e35">
        <updating/>
        <source>setMyFormat(pMyFormat : CnEcXmlFormat) updating;

begin
	if self.myFormat &lt;&gt; pMyFormat then
		self.myFormat := pMyFormat;
	endif;
end;</source>
        <Parameter name="pMyFormat" type="CnEcXmlFormat"/>
    </JadeMethod>
</Class>
