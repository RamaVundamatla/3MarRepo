    <JadeMethod name="addObjectsToTable" id="8c1bf93a-07c2-4c3a-9667-f087da501784">
        <updating/>
        <source>addObjectsToTable(_numItems: Integer io) updating;
// ---------------------------------------------------------------------------
// Created:     10 August 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	termType			: CM_TerminologyType;
	termHdr				: CM_TerminologyDef;
	breakOut			: Boolean;
	termTypeDict		: CM_TerminologyTypeByNameDict;
	passport			: CM_Passport;
begin
	passport := app.myPassport;
	termTypeDict := app.myRoot.allTerminologyTypes;
	
	foreach termType in termTypeDict do
		foreach termHdr in termType.allTerminologyDefs where
		   self.includeObject(termHdr, passport) do
			self.addObjectToTable(termHdr, _numItems, breakOut);
			
			if breakOut then
				break;
			endif;
		endforeach;
	endforeach;

end;</source>
        <Parameter name="_numItems" type="Integer" usage="io"/>
    </JadeMethod>
