05 September 2014	cnwer1	Initial creation PAR

*/

vars

begin
	self.frmResults.height:=dockCont.clientHeight;
	self.frmSelectedItems.height:=self.jdcSelected.clientHeight - self.frmButtons.clientHeight;
epilog

end;</source>
        <Parameter name="dockCont" type="JadeDockContainer" usage="input"/>
    </JadeMethod>
    <JadeMethod name="loadCmbCommodity" id="88b14042-b737-43d6-8663-d9faa58b4045">
        <source>loadCmbCommodity();
/*

Purpose:			

