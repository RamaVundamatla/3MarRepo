    <JadeMethod name="checkLockErrorStatus" id="2f0553bb-49db-4d03-8352-a2dbe30009e0">
        <source>checkLockErrorStatus( _passport : CM_Passport; _hasOnlyLockErrors  : Boolean output; _hasNonLockErrors   : Boolean output);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 May 2025	naviv1	Initial creation

*/

vars
    error : CM_Error;
begin
    _hasOnlyLockErrors := false;
    _hasNonLockErrors  := false;

    if not _passport.hasErrors() then
        return;
    endif;

    _hasOnlyLockErrors := true;

    foreach error in _passport.allErrors do
        if error.errorCode &lt;&gt; System_Lock_Error_Code then
            _hasOnlyLockErrors := false;
            _hasNonLockErrors  := true;
            break;
        endif;
    endforeach;
end;</source>
        <Parameter name="_passport" type="CM_Passport"/>
        <Parameter name="_hasOnlyLockErrors" type="Boolean" usage="output"/>
        <Parameter name="_hasNonLockErrors" type="Boolean" usage="output"/>
    </JadeMethod>
    <JadeMethod name="copyErrors" id="ce359d6d-9034-46ca-a83d-45b323313c06">
        <updating/>
        <source>copyErrors()updating;
//
// par27392 cnwrs1 13 Apr 2011
//
// 08/08/2013	cnwcs5	CCMS POL 2221 / par 32094(2) - move all error saving to copyErrors
// 24 Jan 2014	cnwrs1	Par 32463 - reduce the journal activity from EDI
// 02 Mar 2018	jlgrs1	TFS 37419 - QNS Sundry
vars
	ediError : CM_EDIError;
	trxError : CM_Error;
	allErrorsMatched : Boolean;
	errorMatched : Boolean;
	currentErrors : DynaDictionary;
	iter : Iterator;
begin
	// clear any errors that were saved from previous runs
	
	if not self.storePersistentErrors then
		// no need to save
		self.allErrorWarnings.purge();
		return;
	endif;
	if self.allErrorWarnings.size &lt;&gt; app.myPassport.allErrorWarnings.size then
		// if we dont have the same number of messages
		// dont try and match them up
		allErrorsMatched := false;
	else
		allErrorsMatched := true;
		create currentErrors transient;
		currentErrors.setMembership(CM_EDIError);
		currentErrors.addMemberKey(CM_EDIError::errorCode.name, false, false);
		currentErrors.addMemberKey(CM_EDIError::warningOnly.name, false, false);
		currentErrors.addMemberKey(CM_EDIError::myUserObject.name, false, false);
		currentErrors.endKeys(true);
		self.allErrorWarnings.copy(currentErrors);
		iter := currentErrors.createIterator;
		// for each passport error see if we already have an existing matching pesistant error
		foreach trxError in app.myPassport.allErrorWarnings do
			errorMatched := false;
			currentErrors.startKeyGeq(trxError.errorCode, trxError.warningOnly, trxError.myUserObject, iter);
			while iter.next(ediError) do
				if trxError.text = ediError.text then
					errorMatched := true;
					break;
				endif;
			endwhile;
			if errorMatched = false then
				allErrorsMatched := false;
				break;
			endif;
		endforeach;
	endif;
	if not allErrorsMatched then
		if self.isKindOf(CM_EDIDataPrenote) or self.isKindOf(CM_EDIDataTransManifest) then	//23 May 2016	NDL	TFS 2004		//MTN-33568
			self.addPassportToEDIErrors();
		else
			self.allErrorWarnings.purge();
			// for each passport error create a persistent copy
			foreach trxError in app.myPassport.allErrorWarnings do
				create ediError;
				ediError.set(trxError.errorCode, trxError.text, trxError.warningOnly, trxError.fieldName, trxError.myUserObject);
				self.allErrorWarnings.add(ediError);
			endforeach;
		endif;
	else
	endif;
epilog
	delete iter;
	delete currentErrors;
end;
</source>
    </JadeMethod>
    <JadeMethod name="createBayPlanTI" id="a87c9227-1b22-4a78-b55b-6547f48d7df8">
        <source>createBayPlanTI(_ediTI:CM_EDIBayPlanTI io; _key : String);
//
// 08 May 2018	jlgrs1	TFS 36425 SingleLine Booking partial processing not working
// 08 Apr 2019	jlgrs1	TFS 41913 STWR - Reconfiguration of the EDI Operation form to better handle EDI collection locks while loading 
//
vars
	dummy	: Integer;
	cmpny	: Any;
	term	: CM_Terminal;
	lookupTI : CM_EDIBayPlanTI;
begin 
	lookupTI := self.allEDITrackedItems[_key].CM_EDIBayPlanTI; //ccms1811 cnwrs1 May 2009
	if lookupTI &lt;&gt; null then
		_ediTI := lookupTI;
	else
		if self.isTransient then
			create _ediTI as CM_EDIBayPlanTI transient;
		else
			create _ediTI as CM_EDIBayPlanTI;
		endif;
		while self.allEDITrackedItems.includesKey(_ediTI.id) do
			dummy := dummy + 1;
			_ediTI.setIdDefault(dummy.String);
		endwhile;
	endif;

	_ediTI.setMyEDIData(self);
	
	term := self.getMyTerminal();
	
	if term = null then
		return;
	endif;
	
	//cmpny := term.getConfig(DefCompany);
	cmpny := term.getDefaultCompanyBank();	//17 Apr 2012	NDL	Par 29393
	
	if cmpny &lt;&gt; null then
		_ediTI.companyCode := cmpny.CM_Bank.code;
	endif;
end;</source>
        <Parameter name="_ediTI" type="CM_EDIBayPlanTI" usage="io"/>
        <Parameter name="_key" type="String"/>
    </JadeMethod>
    <JadeMethod name="createCargoTesting" id="689e1dad-e55d-4d89-a1f4-f83cd1e20a45">
        <source>createCargoTesting(_terminal: CM_Terminal; _terminalArea: CM_TerminalArea);
//----------------------------------------------------------------
//	Created:	19 July 2005	by Jason Chapman  (cnwjc2)
//
//	Create the cargo that would be loaded to the ship for this load port
//	
//	THIS IS A TESTING METHOD AND SHOULD ONLY BE CALLED FOR DEV/TEST SYSTEMS
//----------------------------------------------------------------
vars
	ediItem	: CM_EDITrackedItem;
	theMC	: CMIF_MoveController;
begin

	//double check
	if not app.isSpecial() then
		return;
	endif;

	create theMC transient;
	theMC.setMyToPrimaryLocation(_terminalArea.CM_BlockStack.myLocationsController);
	theMC.setMoveMode(REAL_MODE);
	theMC.isSystemMove := true;
	theMC.setMyPassport(app.myPassport);
	
	foreach ediItem in self.allEDITrackedItems do
		ediItem.createAndGateInTesting(_terminal, theMC);
	endforeach;

epilog
	delete theMC;
end;</source>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_terminalArea" type="CM_TerminalArea"/>
    </JadeMethod>
    <JadeMethod name="createPrenoteTI" id="918a56de-5dfd-40fa-b843-ca2b2b916932">
        <source>createPrenoteTI(_ediTI:CM_EDIPrenoteTI io; _key : String);

//NFS 3833 AA 16/10/01: Because the COPINO message contains GID and EQD
//fields that both hold ID, we must check that we have not already created
//the TI on one of the other messages. Otherwise we create 2 with the same id

//---------------------------------------------------------------------------------------
// Prenotes are the exception when creating - return the matching edi prenote for update.
// All others see CM_EDITrackedItem::setForCreateNew.  Don't use createXXTI.
//---------------------------------------------------------------------------------------
// 08 May 2018	jlgrs1	TFS 36425 SingleLine Booking partial processing not working
// 08 Apr 2019	jlgrs1	TFS 41913 STWR - Reconfiguration of the EDI Operation form to better handle EDI collection locks while loading 
//
vars
	lookupTI 	: CM_EDIPrenoteTI;
	tmpTerm		: CM_Terminal;
begin
	tmpTerm := self.getMyTerminal();
	
	lookupTI := self.allEDITrackedItems[_key].CM_EDIPrenoteTI;
	if lookupTI &lt;&gt; null then
		//NFS 3833: Exists ! Return original
		_ediTI := lookupTI;
	else
		//Create a new object and set basic defaults
		if self.isTransient then
			create _ediTI as CM_EDIPrenoteTI transient;
		else
			create _ediTI as CM_EDIPrenoteTI;
		endif;
		
		//ediTrackedItems.add(ediTI);
		_ediTI.setMyEDIData(self);
	
		//Setup some default values. This is done in new gate app too
		//We rely on data in the EDI file to overwrite these defaults later
		_ediTI.setId(_key);
		_ediTI.loadPort := tmpTerm.getConfig(PortDestCode).String;
//		_ediTI.voyageCode := tmpTerm.getDefaultVoyageCode();	// cnwrl1 09/06/2010 PAR 24299 - what it was
		// make sure the manual collection on CM_EDIConfig gets maintained
		_ediTI.setVoyageCode( tmpTerm.getDefaultVoyageCode() );
		_ediTI.operatorCode := tmpTerm.getDefaultOperatorCode;

		_ediTI.setCargoType(TI_CargoType_Container);
		_ediTI.statusString := "Storage";
	endif;
end;</source>
        <Parameter name="_ediTI" type="CM_EDIPrenoteTI" usage="io"/>
        <Parameter name="_key" type="String"/>
    </JadeMethod>
