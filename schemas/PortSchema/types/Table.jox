<GUIClass name="Table">
    <JadeMethod name="fitColumnWidth" id="bf4afe13-d04d-4129-8586-7b169dbfae66">
        <updating/>
        <source>fitColumnWidth(_col : Integer;_adjustment : Integer) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
10 May 2010	cnwer1	Initial creation

*/

vars
	textWidth,
	irow	: Integer;
	theColumn : JadeTableColumn;
begin

	textWidth := 0;
	theColumn:=self.accessColumn(_col);
	foreach irow in 1 to self.rows do
		if self.accessRow(irow).visible and not self.accessCell(irow,_col).mergeCells &gt; 0  then
			textWidth := textWidth.max( self.getTextExtent( self.getCellText(irow, _col)) + theColumn.marginLeft + theColumn.marginRight);
		endif;
	endforeach;			
		
	theColumn.width := textWidth + theColumn.marginLeft + theColumn.marginRight + _adjustment;
epilog

end;</source>
        <Parameter name="_col" type="Integer"/>
        <Parameter name="_adjustment" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="fitColumnWidths" id="8618a94c-d741-4a8c-a3f1-c982c5323f74">
        <source>fitColumnWidths();

vars
	col:        Integer;
	irow:       Integer;
	textWidth:  Integer;
	lastRow:    Integer;
begin
	lastRow := lastVisibleRow;

	foreach col in 1 to columns do
		if not columnVisible[col] then
			continue;
		endif;

		textWidth := 0;

		foreach irow in 1 to rows do
			if rowVisible[irow] then
				textWidth := textWidth.max(getTextExtent(getCellText(irow, col)) + 5);
			endif;
		endforeach;			
		/*foreach irow in 1 to fixedRows do
			if rowVisible[irow] then
				textWidth := textWidth.max(getTextExtent(getCellText(irow, col)) + 5);
			endif;
		endforeach;	
		foreach irow in topRow to lastRow do
			if rowVisible[irow] then
				textWidth := textWidth.max(getTextExtent(getCellText(irow, col)) + 5);
			endif;
		endforeach;*/	

		columnWidth[col] := textWidth;

	endforeach;

end;</source>
    </JadeMethod>
    <JadeMethod name="fitTableHeight" id="0a29b995-f838-4163-9036-49ba7649630e">
        <updating/>
        <source>fitTableHeight() updating;

vars
	irow:         Integer;
	totalHeight:  Integer;
begin
	totalHeight := 0;
	foreach irow in 1 to rows do
		if not rowVisible[irow] then
			continue;
		endif;

		totalHeight := totalHeight + rowHeight[irow];
	endforeach;

	height := totalHeight;

end;</source>
    </JadeMethod>
