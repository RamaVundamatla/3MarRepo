/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 July 2009	cnwdap1	Initial creation
*/
vars
	labelLeft	: Real;

begin
	// put button on the right hand side, check box on the left hand side, 
	// and stretch the label to fit in between these two
	self.btnAttachments.move(_fieldGeneric.width - self.btnAttachments.width, 0, self.btnAttachments.width, _fieldGeneric.height);
	labelLeft := _fieldGeneric.myLabel.width + _fieldGeneric.HORIZONTAL_SPACING;
	self.cmbAttachments.move(labelLeft, 0, self.btnAttachments.left - labelLeft - 5, _fieldGeneric.height);

epilog

end;</source>
