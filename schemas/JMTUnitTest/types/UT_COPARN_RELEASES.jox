constants
	ShipName = "CCMS1913";//Was MAERSK DUNFARE
	VoyageName = "CCMS1913VOY";
	RELEASE1 = 'ACD0278846';
//	RELEASE2 = 'ACD0281728';
//	RELEASE3 = 'ACD0282044';
	OPERATOR = 'ANL';
	SENDER1	= 'ANLCOPARN';
	SENDER2 = 'ANL';
