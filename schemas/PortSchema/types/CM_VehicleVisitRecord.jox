    <JadeMethod name="hasCargoRemovedForCargoId" id="a592e89a-b423-4b4a-a198-6cf15f37263b">
        <source>hasCargoRemovedForCargoId(_id : String) : Boolean;
/*

Date		Who		Reason
09 October 2013	cnwer1	Initial creation PAR 32730

*/

vars
	vvrd	:CM_VehicleVisitRecordDetail;
begin

	
	foreach vvrd in self.allVehicleVisitRecordDetails do
		if vvrd.recordType = VisitRecord_CargoRemoved then
			if _id =  vvrd.getExtraInfo_TrackedItemId then
				return true;
