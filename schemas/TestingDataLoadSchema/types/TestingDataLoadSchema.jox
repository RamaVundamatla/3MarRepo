    <JadeMethod name="loadAutomationData" id="0ad4bb51-3f27-412e-aa99-39e2c502ff73">
        <updating/>
        <source>loadAutomationData(commandLine: String) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
05/10/2017	jlgmh5	Initial creation

*/

vars

	loadOrderFile				: File;
	fileToLoad					: File;
	fileFolder					: FileFolder;
	fileNode					: FileNode;
	tempFileNode				: FileNode;
	fileFolder2					: FileFolder;
	errorFile					: File;
	fileFolder1					: FileFolder;
	
	xmlDocParser				: JadeXMLDocumentParser;
	xmlDoc						: JadeXMLDocument;
	rootElement					: JadeXMLElement;

	dataToLoad					: UT_DataSetupDestroy;
	
	filesToCopyArray			: FileNodeArray;
	paramNames					: StringArray512;
	paramValues					: StringArray512;
	paramArray					: StringArray512;

	methodStr					: String;
	startTS						: TimeStamp;
	endTS						: TimeStamp;
	
	line						: String;
	fileName					: String;
	methodName					: String;
	tempFileName				: String;
	pos							: Integer;
	result						: String;
	tempFileFolderName			: String;
	directoryName				: String;
	fileMask					: String;
	tempFileMask				: String;
	commandLineStr				: String;
	posEqual					: Integer;
	posEqual2					: Integer;
	paramName					: String;
	paramValue					: String;
	posSpace					: Integer;
	tempStr						: String;
	timeToLeave					: Boolean;
	errorLogDirectory			: String;
	
begin
	
	startTS := app.actualTimeAppServer();
	
	app.initialize();
	
	isOpsviewTest := false;
	
	create dataToLoad transient;
	dataToLoad.setActiveProfileMDHONLY();
	
	// read the command line to get the path and search for file parameters
	commandLineStr := commandLine;
	create paramArray transient;
	pos := commandLineStr.toLower().pos("endjade", 1);
	if pos &lt;&gt; 0 then
		commandLineStr := commandLineStr[pos + 7:end];
	endif;
	
	//write "commandLineStr: " &amp; commandLineStr;
	
	while (true) do
	
		// Get the 1st =
		posEqual := commandLineStr.pos("=", 1);
		if posEqual = 0 then
			break;
		endif;
		//write "posEqual: " &amp; posEqual.String;
		
		// get the next =
		posEqual2 := commandLineStr.pos("=", posEqual + 1);
		//write "posEqual2: " &amp; posEqual2.String;
		
		
		// work out what the string is
		if posEqual2 &gt; 0 then
			posSpace := commandLineStr.reversePosIndex(" ", posEqual2);
			//write "posSpace: " &amp; posSpace.String;
			tempStr := commandLineStr[1:posSpace].trimBlanks();
			commandLineStr := commandLineStr[posSpace:end].trimBlanks();
		else
			tempStr := commandLineStr;
			timeToLeave := true;
		endif;
		//write 'tempStr: ' &amp; tempStr;
				
		// get the parameters
		paramArray.clear();
		tempStr.getTokensForDelimiter("=", paramArray);
		if paramArray[1] = "Directory" then
			directoryName := paramArray[2];
			//write 'directoryName: ' &amp; directoryName;
		elseif paramArray[1] = "SearchFor" then
			fileMask := paramArray[2];
			//write 'fileMask: ' &amp; fileMask;
		elseif paramArray[1] = "JadeErrorLogDirectory" then
			errorLogDirectory := paramArray[2];
		endif;	
		
		// break out as no more items on the line
		if timeToLeave then
			break;
		endif;
	
	endwhile;
	
	
	
	
	/*
	// read the command line to get the path and search for file parameters
	commandLineStr := commandLine.replaceString("\MTN Automated Testing\", "\MTN_Automated_Testing\");
	create paramNames transient;
	create paramValues transient;
	self.parseCommandLine(commandLineStr, paramNames, paramValues);
	
	// Check the number of parameters passed and return if &lt; 2
	if paramNames.size &lt;&gt; 2 then
		app.writeLog("Command Line Parameter Error:  Expecting 2 parameters but only " &amp; paramNames.size.String &amp; "." &amp; CrLf &amp; 
			"Parameters should be: [Directory=&lt;DirectoryName&gt;] [SearchFor=&lt;Filename Mask&gt;]", LogINFO);
		return;
	endif;
	
	directoryName := paramValues[1];
	directoryName := directoryName.replaceString("\MTN_Automated_Testing\", "\MTN Automated Testing\");
	fileMask := paramValues[2];
	*/
	
	create loadOrderFile transient;
	loadOrderFile.usePresentationFileSystem := true;
	loadOrderFile.fileName := directoryName &amp; "\OrderToLoad.csv";

	
	while not loadOrderFile.endOfFile do
	
		line := loadOrderFile.readLine();
		if line = null then
			continue;
		endif;
		
		fileName := line &amp; ".xml";
		tempFileMask := fileMask &amp; line;
		
		tempFileFolderName := directoryName;
		
		app.writeLog("line: " &amp; line &amp; Tab &amp; "fileName: " &amp; fileName &amp; Tab &amp; "tempFileMask: " &amp; tempFileMask, LogINFO);
		
		if line.toUpper().cnContains("Vessels".toUpper()) then
			// load the vessels
			methodName := "process" &amp; line &amp; "Automation";
			tempFileMask := fileMask &amp; "Vessel_";
		elseif line.toUpper().cnContains("EDIFiles".toUpper()) then
			// load the EDI files
			methodName := "process" &amp;  line &amp; "Automation";
			tempFileMask := fileMask &amp; "EDI_";
		elseif line.toUpper().cnContains('SystemConfigs'.toUpper()) or line.toUpper().cnContains('TerminalConfig'.toUpper()) then
			methodName := 'processConfigs';
			tempFileMask := fileMask &amp; "Configs_";
		elseif line.toUpper().cnContains('SecurityRole'.toUpper()) then
			methodName := 'processSecurityRoles';
			tempFileMask := fileMask &amp; "SecurityRole_";
		elseif line.toUpper().cnContains('2ndYardAllocations'.toUpper()) then
			methodName := 'processYardAllocations';
			tempFileMask := fileMask &amp; "2ndYardAllocations_";
		else
			methodName := "process" &amp; line;
		endif;
		
		app.writeLog("line: " &amp; line &amp; Tab &amp; "fileName: " &amp; fileName &amp; Tab &amp; "tempFileMask: " &amp; tempFileMask &amp; Tab &amp; 
			"methodName: " &amp; methodName, LogINFO);
			
		app.writeLog('fileName : ' &amp; fileName &amp; Tab &amp; "methodName: " &amp; methodName, LogINFO);
	
		delete fileFolder;
		create fileFolder transient;
		fileFolder.fileName := tempFileFolderName;
		fileFolder.usePresentationFileSystem := true;
		fileFolder.mask := "*" &amp; tempFileMask &amp; "*";
		app.writeLog("fileFolder.fileName: " &amp; fileFolder.fileName &amp; Tab &amp; "fileFolder.mask: " &amp; fileFolder.mask, LogINFO);
		
		tempFileNode := null;
		tempFileName := null;
		
		foreach fileNode in fileFolder.files do
			
			app.writeLog(Tab &amp; Tab &amp; fileNode.fileName, LogINFO);
			
			// Setup the method
			methodStr := dataToLoad.MethodString;
			methodStr.cnReplaceString("&lt;^%For^%&gt;", methodName);
			
			// if EDI need to add the filename before the method string
			if methodName.cnContains("processEDIFilesAutomation") then
				methodStr := fileNode.fileName &amp; "&lt;EDI&gt;" &amp; methodStr;
			endif;
			
			// Parse the document
			delete xmlDocParser;
			create xmlDocParser transient;
			delete xmlDoc;
			create xmlDoc transient;
			xmlDocParser.parseDocumentFile(xmlDoc, fileNode.fileName);
			rootElement := xmlDoc.rootElement;
			
			// Run the method
			dataToLoad.sendMsgWithIOParams(methodName, rootElement, methodStr);
			
			// set whether updating method or not
			if methodName = "processLoadColorCodeJobToOps" then
				methodStr.cnReplaceString('&lt;^%updating^%&gt;', 'updating');
			else
				methodStr.cnReplaceString('&lt;^%updating^%&gt;', '');
			endif;
				
			app.writeLog("Before", LogINFO);	
			app.writeLog(methodStr &amp; CrLf &amp; CrLf, LogINFO);
			if methodStr.pos("&lt;^%vars^%&gt;", 1) &gt; 0 or methodStr.pos("&lt;^%code^%&gt;", 1) &gt; 0 or 
					methodStr.pos("&lt;^%epilog^%&gt;", 1) &gt; 0 then
				app.writeLog(methodName &amp; ' not processed, no details found.', LogINFO);
				//write methodName &amp; ' not processed, no details found.';
				continue;
			endif;
			
			app.writeLog(methodStr &amp; CrLf &amp; CrLf, LogINFO);
			
			//execute the transient method
			result := dataToLoad.executeMethod(methodStr);
			
		endforeach;
		
	endwhile;
	
epilog
	
	delete paramNames;
	delete paramValues;
	delete paramArray;

	delete loadOrderFile;
	delete fileToLoad;
	delete dataToLoad;
	delete fileFolder;
	delete fileFolder2;
	
	delete xmlDoc;
	delete xmlDocParser;
	
	if not app.myPassport.allErrors.isEmpty() then
	
		// Check folder actually exists is not then create
		create fileFolder1 transient;
		fileFolder1.fileName := errorLogDirectory;
		if not fileFolder1.isAvailable() then
			fileFolder1.make();
		endif;
		
		create errorFile transient;
		//create app.automatedOutputFile transient;
		errorFile.fileName := fileFolder1.fileName &amp; "\Load" &amp; fileMask &amp; "ErrorLog_" &amp; 
			startTS.date.year.String &amp; startTS.date.month.String.padLeadingZeros(2) &amp; startTS.date.day.String.padLeadingZeros(2) &amp; "_" &amp;
			startTS.time.hour.String.padLeadingZeros(2) &amp; startTS.time.minute.String.padLeadingZeros(2) &amp; 
			startTS.time.second.String.padLeadingZeros(2) &amp; ".log";
		errorFile.writeLine(app.myPassport.getAllErrorsAndWarningsAsStr);
		
		delete errorFile;
		delete fileFolder1;
			
	endif;

end;</source>
        <Parameter name="commandLine" type="String"/>
    </JadeMethod>
    <JadeMethod name="loadTestData" id="b97aeefd-85b9-4da5-b938-302adf22932f">
        <source>loadTestData();
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
05/10/2017	jlgmh5	Initial creation

*/

vars

	loadOrderFile				: File;
	fileToLoad					: File;
	fileFolder					: FileFolder;
	fileNode					: FileNode;
	tempFileNode				: FileNode;
	fileFolder2					: FileFolder;
	
	xmlDocParser				: JadeXMLDocumentParser;
	xmlDoc						: JadeXMLDocument;
	rootElement					: JadeXMLElement;

	dataToLoad					: UT_DataSetupDestroy;
	
	filesToCopyArray			: FileNodeArray;

	methodStr					: String;
	startTS						: TimeStamp;
	endTS						: TimeStamp;
	
	line						: String;
	fileName					: String;
	methodName					: String;
	tempFileName				: String;
	pos							: Integer;
	result						: String;
	tempFileFolderName			: String;
	
begin
	
	startTS := app.actualTimeAppServer();
	
	app.initialize();
	
	create dataToLoad transient;
	dataToLoad.setActiveProfileMDHONLY();
	
	
	create loadOrderFile transient;
	loadOrderFile.fileName := OrderToLoadFile;
	
	create filesToCopyArray transient;
	
	while not loadOrderFile.endOfFile do
	
		//methodStr := dataToLoad.MethodString;
	
		line := loadOrderFile.readLine();
		if line = null then
			continue;
		endif;
		
		fileName := line &amp; "*.xml";
		
		// need to change the name for EDI file loads
		tempFileFolderName := DataLoadedCopyFrom &amp; "\";
		if line.toUpper().cnContains("Vessels".toUpper()) then
			tempFileFolderName := DataLoadedCopyFromVessels &amp; "\";
			methodName := "process" &amp; line;
			methodStr := dataToLoad.MethodString;
			methodStr.cnReplaceString("&lt;^%For^%&gt;", methodName);
		elseif line.toUpper().cnContains("EDIFiles".toUpper()) then
			methodName := 'processEDIFiles';
			tempFileFolderName := DataLoadedCopyFromEDIFiles &amp; "\";
			methodStr := dataToLoad.MethodString;
			methodStr.cnReplaceString("&lt;^%For^%&gt;", methodName);
		elseif line.toUpper().cnContains('SystemConfigs'.toUpper()) or line.toUpper().cnContains('TerminalConfig'.toUpper()) then
			methodName := 'processConfigs';
		elseif line.toUpper().cnContains('AFLReleaseRequests'.toUpper()) then
			methodName := 'processReleaseRequests';
		elseif line.toUpper().cnContains('SecurityRole'.toUpper()) then
			methodName := 'processSecurityRoles';
		elseif line.toUpper().cnContains('2ndYardAllocations'.toUpper()) then
			methodName := 'processYardAllocations';
		else
			methodName := "process" &amp; line;
		endif;
		//methodStr.cnReplaceString("&lt;^%For^%&gt;", methodName);
		write 'fileName : ' &amp; fileName &amp; Tab &amp; "methodName: " &amp; methodName;
		app.writeLog('fileName : ' &amp; fileName &amp; Tab &amp; "methodName: " &amp; methodName, LogINFO);
		write 'tempFileFolderName: ' &amp; tempFileFolderName;
	
		delete fileFolder;
		create fileFolder transient;
		fileFolder.fileName := tempFileFolderName;
		fileFolder.usePresentationFileSystem := true;
		fileFolder.mask := fileName;
		
		tempFileNode := null;
		tempFileName := null;
		filesToCopyArray.clear();
		
		foreach fileNode in fileFolder.files do
		
			if fileNode.fileName.toUpper().cnContains("HandSetup".toUpper()) or 
					fileNode.fileName.toUpper().cnContains("HandCreate".toUpper()) then
				continue;
			endif;
		
			methodStr := dataToLoad.MethodString;
			methodStr.cnReplaceString("&lt;^%For^%&gt;", methodName);
		
			delete xmlDocParser;
			create xmlDocParser transient;
			delete xmlDoc;
			create xmlDoc transient;
			xmlDocParser.parseDocumentFile(xmlDoc, fileNode.fileName);
			rootElement := xmlDoc.rootElement;
			
			dataToLoad.sendMsgWithIOParams(methodName, rootElement, methodStr);
			tempFileNode := fileNode;
			tempFileName := DataLoadedCopyTo &amp; "\" &amp; tempFileNode.cnGetSimpleFileName();
			filesToCopyArray.add(fileNode);
		
			
			
			// set whether updating method or not
			if methodName = "processLoadColorCodeJobToOps" then
				methodStr.cnReplaceString('&lt;^%updating^%&gt;', 'updating');
			else
				methodStr.cnReplaceString('&lt;^%updating^%&gt;', '');
			endif;
				
			
			if methodStr.pos("&lt;^%vars^%&gt;", 1) &gt; 0 or methodStr.pos("&lt;^%code^%&gt;", 1) &gt; 0 or 
					methodStr.pos("&lt;^%epilog^%&gt;", 1) &gt; 0 then
				app.writeLog(methodName &amp; ' not processed, no details found.', LogINFO);
				write methodName &amp; ' not processed, no details found.';
				continue;
			endif;
			
			write methodStr &amp; CrLf &amp; CrLf;
			
			//execute the transient method
			result := dataToLoad.executeMethod(methodStr);
			
			
		
		endforeach;
		
		// catch those methods that fall through like vessels, edi files
		if methodName = 'processEDIFiles' then
			dataToLoad.sendMsgWithIOParams(methodName, methodStr);
			delete fileFolder2;
			create fileFolder2 transient;
			fileFolder2.fileName := DataLoadedCopyFromEDIFiles &amp; "\";
			fileFolder2.usePresentationFileSystem := true;
			fileFolder2.mask := "*.xml";
			if not fileFolder2.files.isEmpty() then
				fileFolder2.files.copy(filesToCopyArray);
			endif;
			
			// set whether updating method or not
			if methodName = "processLoadColorCodeJobToOps" then
				methodStr.cnReplaceString('&lt;^%updating^%&gt;', 'updating');
			else
				methodStr.cnReplaceString('&lt;^%updating^%&gt;', '');
			endif;
				
			
			if methodStr.pos("&lt;^%vars^%&gt;", 1) &gt; 0 or methodStr.pos("&lt;^%code^%&gt;", 1) &gt; 0 or 
					methodStr.pos("&lt;^%epilog^%&gt;", 1) &gt; 0 then
				app.writeLog(methodName &amp; ' not processed, no details found.', LogINFO);
				write methodName &amp; ' not processed, no details found.';
				continue;
			endif;
			
			write methodStr &amp; CrLf &amp; CrLf;
			
			//execute the transient method
			result := dataToLoad.executeMethod(methodStr);
		elseif methodName = "processVessels" then
			dataToLoad.sendMsgWithIOParams(methodName &amp; 'FromFile', methodStr);
			delete fileFolder2;
			create fileFolder2 transient;
			fileFolder2.fileName := DataLoadedCopyFromVessels &amp; "\";
			fileFolder2.usePresentationFileSystem := true;
			fileFolder2.mask := "*.xml";
			if not fileFolder2.files.isEmpty() then
				fileFolder2.files.copy(filesToCopyArray);
			endif;
			
			// set whether updating method or not
			if methodName = "processLoadColorCodeJobToOps" then
				methodStr.cnReplaceString('&lt;^%updating^%&gt;', 'updating');
			else
				methodStr.cnReplaceString('&lt;^%updating^%&gt;', '');
			endif;
				
			
			if methodStr.pos("&lt;^%vars^%&gt;", 1) &gt; 0 or methodStr.pos("&lt;^%code^%&gt;", 1) &gt; 0 or 
					methodStr.pos("&lt;^%epilog^%&gt;", 1) &gt; 0 then
				app.writeLog(methodName &amp; ' not processed, no details found.', LogINFO);
				write methodName &amp; ' not processed, no details found.';
				continue;
			endif;
			
			write methodStr &amp; CrLf &amp; CrLf;
			
			//execute the transient method
			result := dataToLoad.executeMethod(methodStr);
		endif;
		
		if (result = null and not filesToCopyArray.isEmpty) then
			foreach tempFileNode in filesToCopyArray do
				if tempFileNode.fileName.cnContains(DataLoadedCopyFromEDIFiles) then
					tempFileName := DataLoadedCopyToEDIFiles &amp; "\" &amp; tempFileNode.cnGetSimpleFileName();
				elseif tempFileNode.fileName.cnContains(DataLoadedCopyFromVessels) then
					tempFileName := DataLoadedCopyToVessels &amp; "\" &amp; tempFileNode.cnGetSimpleFileName();
				else
					tempFileName := DataLoadedCopyTo &amp; "\" &amp; tempFileNode.cnGetSimpleFileName();
				endif;
				self.copyFileEx(tempFileNode.fileName, true, tempFileName, true);
				if (not tempFileNode.fileName.toUpper().cnContains("_EVERYRUN".toUpper()) or 
						not tempFileNode.fileName.toUpper().cnContains("HandSetup".toUpper())) then
					tempFileNode.purge();
				endif;
			endforeach;
		endif;
	
	endwhile;
	
epilog

	endTS := app.actualTimeAppServer;
	write startTS.String &amp; Tab &amp; endTS.String &amp; Tab &amp; (endTS - startTS).String;

	delete loadOrderFile;
	delete fileToLoad;
	delete dataToLoad;
	delete fileFolder;
	delete fileFolder2;
	
	delete xmlDoc;
	delete xmlDocParser;

end;</source>
    </JadeMethod>
    <JadeMethod name="loadTestDataAutomation" id="0042c3af-68b1-4451-bc1d-672f0e60aa9b">
        <updating/>
        <source>loadTestDataAutomation() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 March 2020	jlgmh5	Initial creation

*/

vars

begin

	app.initialize();
	self.loadAutomationData(self.getThinClientCommandLine());

epilog
	app.finalize();
	terminate;
end;</source>
    </JadeMethod>
    <JadeMethod name="loadTestingChanges2" id="aa2fa116-4654-42bc-ba5c-ae03647db0dd">
        <source>loadTestingChanges2();

/*

Purpose:	Load those values which are specific to the system we are in
			Things like:
				Colour
				Web Config


Date		Who		Reason
02/02/2018	jlgmh5	Initial	 

*/

vars
	
	webSiteConfig				: CM_WebSiteConfig;
	user						: CM_User;
	printer						: CM_PrinterDef;
	form						: HiddenDataLoadForm;
	terminal					: CM_Terminal;

	systemName					: String;
	pos							: Integer;

begin

	app.initialize();
	
	create form transient;

	// get the sytsem that we are running in
	systemName := app.cnGetServerMiscPath()[4:end];
	pos := 1;
	systemName := systemName[1:end].scanUntil("\", pos);
	
	// get the web user
	user := app.myRoot.allUsers["WEB"];
	if user = null then
		app.msgBox("Unable to find Web user (WEB).   Please create this user and rerun this application.", 
			"Unable to find Web User", MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
		return;
	endif;	
	
	// get the PDF Printer
	printer := app.myRoot.allPrinterDefsByLogicalName["PDF"];
	if printer = null then
		app.msgBox("Unable to find PDF Printer (PDF).   Please create this printer and rerun this application.", 
			"Unable to find PDF Printer", MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
		return;
	endif;
	
	beginTransaction;
	if systemName.toUpper() = "NAVOMAST" then
		// set the system colour
		app.myRoot.setConfig(AppBackgroundColor, 5280398, true);
		app.myRoot.setConfig(SystemBackgroundPic, form.picManila.picture, true);
		//app.myRoot.setConfig(SystemTitle, "20.0.21 Regression Testing - Manila", true);
		app.myRoot.setConfig(SystemTitle, "NAVOMAST - Test - " &amp; app.myRoot.getVersionAndPatchLevelDisplay(), true);
		
		// update the webstie config stuff
		webSiteConfig := app.myRoot.allWebSiteConfigs["WebServiceDefault"];
		if webSiteConfig &lt;&gt; null then
			webSiteConfig.setPropertyValue("sessionTimeoutMinutes", 30);
			webSiteConfig.setPropertyValue("downloadFileRemoteCopy", true);
			webSiteConfig.setPropertyValue("publicUser", user.code);
			webSiteConfig.setPropertyValue("myPDFPrinter", printer);
			webSiteConfig.setPropertyValue("downloadFileDirectoryPath" ,"D:\jlgOjmt\server\c_misc\report_extract_temp");
			webSiteConfig.setPropertyValue("downloadFileDirectoryURL", "https://jlgojmt.jadelogistics.com/downloads");
			webSiteConfig.setPropertyValue("downloadFileTimeout", 5);
			webSiteConfig.setPropertyValue("helpFileURL", "https://jlgojmt.jadelogistics.com/HTML5");
		endif;
	
		// 16/05/2018 jlmh5 - Add code to change Manila to be Singapore Standard Time
		foreach terminal in app.myRoot.allTerminals discreteLock do
			terminal.setTimeZoneID("Singapore Standard Time");
		endforeach;
	
	elseif systemName.toUpper() = "NAVHMAST" then
		// set the system colour
		app.myRoot.setConfig(AppBackgroundColor, 12615808, true);
		app.myRoot.setConfig(SystemBackgroundPic, form.picCreate.picture, true);
		//app.myRoot.setConfig(SystemTitle, "20.0.21 Regression Testing - Create / Design", true);
		app.myRoot.setConfig(SystemTitle, "NAVHMAST - Create - " &amp; app.myRoot.getVersionAndPatchLevelDisplay(), true);
		
		// update the webstie config stuff
		webSiteConfig := app.myRoot.allWebSiteConfigs["WebServiceDefault"];
		if webSiteConfig &lt;&gt; null then
			webSiteConfig.setPropertyValue("sessionTimeoutMinutes", 30);
			webSiteConfig.setPropertyValue("downloadFileRemoteCopy", true);
			webSiteConfig.setPropertyValue("publicUser", user.code);
			webSiteConfig.setPropertyValue("myPDFPrinter", printer);
			webSiteConfig.setPropertyValue("downloadFileDirectoryPath" ,"D:/cnwhmast/server/c_misc/report_extract_temp");
			webSiteConfig.setPropertyValue("downloadFileDirectoryURL", "https://web1.cnwhmast.cnw.co.nz/downloads");
			webSiteConfig.setPropertyValue("downloadFileTimeout", 5);
			webSiteConfig.setPropertyValue("helpFileURL", "");
		endif;
	
	elseif systemName.toUpper() = "NAVTMAST" then
		// set the system colour
		app.myRoot.setConfig(AppBackgroundColor, 12687648, true);
		app.myRoot.setConfig(SystemBackgroundPic, form.picReview.picture, true);
		//app.myRoot.setConfig(SystemTitle, "20.0.21 Regression Testing - Review", true);
		app.myRoot.setConfig(SystemTitle, "NAVTMAST - Review - " &amp; app.myRoot.getVersionAndPatchLevelDisplay(), true);
		
		// update the webstie config stuff
		webSiteConfig := app.myRoot.allWebSiteConfigs["WebServiceDefault"];
		if webSiteConfig &lt;&gt; null then
			webSiteConfig.setPropertyValue("sessionTimeoutMinutes", 30);
			webSiteConfig.setPropertyValue("downloadFileRemoteCopy", true);
			webSiteConfig.setPropertyValue("publicUser", user.code);
			webSiteConfig.setPropertyValue("myPDFPrinter", printer);
			webSiteConfig.setPropertyValue("downloadFileDirectoryPath" ,"D:/cnwtmast/server/c_misc/report_extract_temp");
			webSiteConfig.setPropertyValue("downloadFileDirectoryURL", "https://web1.cnwtmast.cnw.co.nz/downloads");
			webSiteConfig.setPropertyValue("downloadFileTimeout", 5);
			webSiteConfig.setPropertyValue("helpFileURL", "");
		endif;
		
	elseif systemName.toUpper() = "NAVXMAST" then
		// set the system colour
		app.myRoot.setConfig(AppBackgroundColor, 16776960, true);
		app.myRoot.setConfig(SystemBackgroundPic, form.picMaster.picture, true);
		//app.myRoot.setConfig(SystemTitle, "20.0.21 Regression Testing - Master", true);
		app.myRoot.setConfig(SystemTitle, "NAVXMAST - Master - " &amp; app.myRoot.getVersionAndPatchLevelDisplay(), true);
		
		// update the webstie config stuff
		webSiteConfig := app.myRoot.allWebSiteConfigs["WebServiceDefault"];
		if webSiteConfig &lt;&gt; null then
			webSiteConfig.setPropertyValue("sessionTimeoutMinutes", 30);
			webSiteConfig.setPropertyValue("downloadFileRemoteCopy", true);
			webSiteConfig.setPropertyValue("publicUser", user.code);
			webSiteConfig.setPropertyValue("myPDFPrinter", printer);
			webSiteConfig.setPropertyValue("downloadFileDirectoryPath" ,"D:/cnwxmast/server/c_misc/report_extract_temp");
			webSiteConfig.setPropertyValue("downloadFileDirectoryURL", "https://web1.cnwxmast.cnw.co.nz/downloads");
			webSiteConfig.setPropertyValue("downloadFileTimeout", 5);
			webSiteConfig.setPropertyValue("helpFileURL", "");
		endif;
		
	elseif systemName.toUpper().cnContains("DataBaseTestLoad".toUpper()) then
		// set the system colour
		app.myRoot.setConfig(AppBackgroundColor, 11037868, true);
		app.myRoot.setConfig(SystemBackgroundPic, form.picDevelopment.picture, true);
		//app.myRoot.setConfig(SystemTitle, "20.0.21 Regression Testing - Development", true);
		app.myRoot.setConfig(SystemTitle, "Development - " &amp; app.myRoot.getVersionAndPatchLevelDisplay(), true);
		
		// update the webstie config stuff
		webSiteConfig := app.myRoot.allWebSiteConfigs["WebServiceDefault"];
		if webSiteConfig &lt;&gt; null then
			webSiteConfig.setPropertyValue("sessionTimeoutMinutes", 30);
			webSiteConfig.setPropertyValue("downloadFileRemoteCopy", true);
			webSiteConfig.setPropertyValue("publicUser", user.code);
			webSiteConfig.setPropertyValue("myPDFPrinter", printer);
			webSiteConfig.setPropertyValue("downloadFileDirectoryPath" ,"D:/cnwxmast/server/c_misc/report_extract_temp");
			webSiteConfig.setPropertyValue("downloadFileDirectoryURL", "https://web1.cnwxmast.cnw.co.nz/downloads");
			webSiteConfig.setPropertyValue("downloadFileTimeout", 5);
			webSiteConfig.setPropertyValue("helpFileURL", "");
		endif;
		
	else
		
		app.msgBox("Trying to update a system other than NAVXMAST; NAVHMAST; NAVTMAST; or NAVOMAST." &amp; CrLf &amp;
			"Please run in one of these systems or change the code to include this system.", 
			"Unable to Update", MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
		return;
	
	endif;
	commitTransaction;
	
epilog

	delete form;

end;
</source>
    </JadeMethod>
    <JadeMethod name="parseCommandLine" id="f4be778b-f0f0-4b30-b840-96b7d7cc23ab">
        <source>parseCommandLine(_cmdLine: String; _paramNames: StringArray512 input; _paramValues: StringArray512 input);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
18 January 2011	cnwmh5	Initial creation

*/

vars

	tokensArray	: StringArray512;
	
	line		: String;
	pos 		: Integer;
	paramName,
	paramValue	: String;
	
begin
	///inheritMethod(_cmdLine, _paramNames, _paramValues);

	create tokensArray transient;
	
	_cmdLine.getTokensForDelimiter(" ", tokensArray);
	
	foreach line in tokensArray do
		paramName := null;
		paramValue := null;
		if line.trimBlanks = null then
			continue;
		endif;
		pos := line.pos("=", 1);
		if pos = 0 then
			paramName := line.trimBlanks();
		else
			paramName := line[1:pos-1];
			paramValue := line[pos+1:end].trimBlanks();
		endif;
		_paramNames.add(paramName);
		_paramValues.add(paramValue);
	endforeach;
	
epilog

	delete tokensArray;
	
end;</source>
        <Parameter name="_cmdLine" type="String"/>
        <Parameter name="_paramNames" type="StringArray512" usage="input"/>
        <Parameter name="_paramValues" type="StringArray512" usage="input"/>
    </JadeMethod>
    <JadeMethod name="runAutomationScript" id="bd560e7c-fdbc-4c7c-9f8c-573ac407996f">
        <updating/>
        <source>runAutomationScript(commandLine: String) updating;
/*

Purpose:		This will run an automation script 	

Parameters:		endJade ErrorLogDirectory='' ScriptToRun=''
				e.g. endJade ErrorLogDirectory=C:\Users\jlgmh5\source\repos\MTNAutomatedTests\MTNAutomatedTests\bin\Debug\JadeErrorLog ScriptToRun=resetData_44210

Return Value:		

Date		Who		Reason
06/07/2020	jlgmh5	Initial creation

*/

vars

	errorFile						: File;
	fileFolder						: FileFolder;
	utScripts						: UT_Scripts;

	paramNames						: StringArray512;
	paramValues						: StringArray512;
	paramArray						: StringArray512;

	pos								: Integer;
	posEqual						: Integer; 
	posEqual2						: Integer;
	startTS							: TimeStamp;
	tempStr							: String;
	posSpace						: Integer;
	timeToLeave						: Boolean;
	commandLineStr					: String;
	
	errorDirectoryName 				: String;
	scriptToRun 					: String;

begin

	app.initialize();
	
	isOpsviewTest := false;

	startTS := app.actualTimeAppServer();
	
	commandLineStr := commandLine;
	create paramArray transient;
	pos := commandLineStr.toLower().pos("endjade", 1);
	if pos &lt;&gt; 0 then
		commandLineStr := commandLineStr[pos + 7:end];
	endif;

	while (true) do
	
		// Get the 1st =
		posEqual := commandLineStr.pos("=", 1);
		if posEqual = 0 then
			break;
		endif;
		
		// get the next =
		posEqual2 := commandLineStr.pos("=", posEqual + 1);
		
		// work out what the string is
		if posEqual2 &gt; 0 then
			posSpace := commandLineStr.reversePosIndex(" ", posEqual2);
			tempStr := commandLineStr[1:posSpace].trimBlanks();
			commandLineStr := commandLineStr[posSpace:end].trimBlanks();
		else
			tempStr := commandLineStr;
			timeToLeave := true;
		endif;
						
		// get the parameters
		paramArray.clear();
		tempStr.getTokensForDelimiter("=", paramArray);
		if paramArray[1] = "ErrorLogDirectory" then
			errorDirectoryName := paramArray[2];
		elseif paramArray[1] = "ScriptToRun" then
			scriptToRun := paramArray[2];
		endif;	
		
		// break out as no more items on the line
		if timeToLeave then
			break;
		endif;
	
	endwhile;
	
	on Exception do self.runScriptExceptionHandler(exception, errorDirectoryName, scriptToRun, startTS, "_ErrorLog_");
	
	// call the script to run
	// There are no paramaters to pass as the scripts are self contained
	create utScripts transient;
	utScripts.setActiveProfileMDHONLY();
	
	utScripts.sendMsg(scriptToRun);
	
epilog
	
	delete paramNames;
	delete paramValues;
	delete paramArray;
	
	//delete app.automatedOutputFile;
	
	delete utScripts;
	
	// messages in app.myPassport.allWarningErrorMsgs
	if not app.myPassport.allErrors.isEmpty() then
	
		// Check folder actually exists is not then create
		create fileFolder transient;
		fileFolder.fileName := errorDirectoryName;
		if not fileFolder.isAvailable() then
			fileFolder.make();
		endif;
		
		create errorFile transient;
		//create app.automatedOutputFile transient;
		errorFile.fileName := fileFolder.fileName &amp; "\" &amp; scriptToRun &amp; "_ErrorLog_" &amp; 
			startTS.date.year.String &amp; startTS.date.month.String.padLeadingZeros(2) &amp; startTS.date.day.String.padLeadingZeros(2) &amp; "_" &amp;
			startTS.time.hour.String.padLeadingZeros(2) &amp; startTS.time.minute.String.padLeadingZeros(2) &amp; 
			startTS.time.second.String.padLeadingZeros(2) &amp; ".log";
		errorFile.writeLine(app.myPassport.getAllErrorsAndWarningsAsStr);
		
		delete errorFile;
		delete fileFolder;
			
	endif;
		
	app.finalize();
	terminate;

end;</source>
        <Parameter name="commandLine" type="String"/>
    </JadeMethod>
    <JadeMethod name="runJadloadB" id="a308635e-bdfc-44f6-91e2-19a9496c6827">
        <source>runJadloadB(_scmFile, _ddbFile, _rwaFile, _scmToDelete : String) : Boolean;
/*

Purpose:			Facilitate extracting the RWA pre cut. Runs on the app server

Parameters:			

Return Value:		

Date		Who		Reason
02 December 2020	jlgmd1	Initial creation TFS 50459

*/
	
vars
	dir,
	command			: String;
	args			: StringArray512;
	result,
	result2			: Integer;
	
begin
	dir := app.getJadeInstallDirAppServer;
	command := "jadloadb";
	
	create args transient;
	args.add("path=" &amp; app.dbPath);
	args.add("ini=" &amp; app.getIniFileNameAppServer);
	args.add("server=multiUser");	
	
	// Bail early when we have 1 set of arguments to add
	while true do
		if _scmFile &lt;&gt; null then
			args.add("schemaFile=" &amp; _scmFile);
			if _ddbFile = null then
				break;
			endif;
		endif;
		
		if _ddbFile &lt;&gt; null then
			args.add("ddbFile=" &amp; _ddbFile);
			break;
		endif;
		
		if _rwaFile &lt;&gt; null then
			args.add("reportLoadAllFile=" &amp; _rwaFile);
			args.add("reportReplaceView=true");
			break;
		endif;
		
		if _scmToDelete &lt;&gt; null then
			args.add("deleteSchema=" &amp; _scmToDelete);
			break;
		endif;
		
		break;
	endwhile;	// load args loop
	
	// Now run the process (run modally, so we wait until it's complete)
	app.writeLog("Running command " &amp; command &amp; Space &amp; args.concatenate(Space), LogDEBUG);
	result := node.createExternalProcess(dir, command, args, null, false, true, result2);

	if result &lt;&gt; Node.ExternalProcess_Successful or result2 &lt;&gt; 0 then
		app.writeLog("Possible problem: result = " &amp; result.String &amp; ", result2 = " &amp; result2.String, LogERROR);
	endif;

	return result = Node.ExternalProcess_Successful;

epilog
	delete args;
	
end;</source>
        <Parameter name="_scmFile" type="String"/>
        <Parameter name="_ddbFile" type="String"/>
        <Parameter name="_rwaFile" type="String"/>
        <Parameter name="_scmToDelete" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="runOpsViewGateTest" id="f30ffb0e-ff56-47b5-8348-4d1fe2932d27">
        <updating/>
        <source>runOpsViewGateTest(commandLine : String) updating;
/*

Purpose:		This will run required script to setup OpsView Data

Parameters:		

Return Value:		

Date		Who		Reason
08/12/2021	navgmh5	Initial creation

*/
constants

	ScriptToRun						: String = "runOpsviewGateScript";
	ErrorDirectoryName 				: String = "C:\temp\OpsView_Logs";
	ErrorLogName 					: String = "_OpsView_Test";
	UserName						: String = "MTN-OPS";
	TerminalId						: String = "MTNQ";
	
vars

	errorFile						: File;
	fileFolder						: FileFolder;
	utScripts						: UT_Scripts;
	terminal						: CM_Terminal;
	passportTerm					: CM_Terminal;
	user							: CM_User;
	
	paramNames						: StringArray512;
	paramValues						: StringArray512;
	paramArray						: StringArray512;
	
	startTS							: TimeStamp;
	commandLineStr					: String;
	pos								: Integer;
	posEqual						: Integer;
	posEqual2						: Integer;
	posSpace						: Integer;
	tempStr							: String;
	timeToLeave						: Boolean;

begin

	// Initialize
	app.initialize();
	
	isOpsviewTest := true;
	 
	startTS := app.actualTimeAppServer();
	app.delayTime := 5000;
	
	commandLineStr := commandLine;
	create paramArray transient;
	pos := commandLineStr.toLower().pos("endjade", 1);
	if pos &lt;&gt; 0 then
		commandLineStr := commandLineStr[pos + 7:end];
	endif;
	
	while (true) do
	
		// Get the 1st =
		posEqual := commandLineStr.pos("=", 1);
		if posEqual = 0 then
			break;
		endif;
		
		// get the next =
		posEqual2 := commandLineStr.pos("=", posEqual + 1);
		
		// work out what the string is
		if posEqual2 &gt; 0 then
			posSpace := commandLineStr.reversePosIndex(" ", posEqual2);
			tempStr := commandLineStr[1:posSpace].trimBlanks();
			commandLineStr := commandLineStr[posSpace:end].trimBlanks();
		else
			tempStr := commandLineStr;
			timeToLeave := true;
		endif;
						
		// get the parameters
		paramArray.clear();
		tempStr.getTokensForDelimiter("=", paramArray);
		if paramArray[1] = "DelayTime" then
			delayTime := paramArray[2].Integer;
		elseif paramArray[1] = "ShiftLength" then
			shiftLength := paramArray[2].Integer;
		endif;	
		
		// break out as no more items on the line
		if timeToLeave then
			break;
		endif;
	
	endwhile;
	
	// setup the terminal
	terminal := app.myRoot.allTerminals[TerminalId];
	if terminal = null then
		app.writeLog("Unable to find terminal: " &amp; TerminalId &amp; ".   Exiting JadeScript...", LogINFO);
		return;
	endif;
	
	passportTerm := app.myPassport.myTerminal;
	app.myPassport.setMyTerminal(terminal);
	
	// get the user and set passport's myUser
	user := app.myRoot.allUsers[UserName].CM_User;
	if user = null then
		app.writeLog("Unable to find user: " &amp; UserName &amp; ".   Exiting JadeScript...", LogINFO);
		return;
	endif;
	app.myPassport.setMyUserFromCode(user.code);
	
	app.writeLog("ErrorDirectoryName: " &amp; ErrorDirectoryName &amp; CrLf &amp; "ScriptToRun: " &amp; ScriptToRun &amp; CrLf &amp; 
		"ErrorLogName: " &amp; ErrorLogName &amp; CrLf &amp; "userName: " &amp; user.code, LogINFO);
	on Exception do self.runScriptExceptionHandler(exception, ErrorDirectoryName, ScriptToRun, startTS, "_");
		
	// call the script to run
	// There are no paramaters to pass as the scripts are self contained
	create utScripts transient;
	utScripts.setActiveProfileMDHONLY();
		
	utScripts.sendMsg(ScriptToRun);
	
epilog
	
	delete utScripts;
	
	// messages in app.myPassport.allWarningErrorMsgs
	if not app.myPassport.allErrors.isEmpty() then
	
		// Check folder actually exists is not then create
		create fileFolder transient;
		fileFolder.fileName := ErrorDirectoryName;
		if not fileFolder.isAvailable() then
			fileFolder.make();
		endif;
		
		create errorFile transient;
		//create app.automatedOutputFile transient;
		errorFile.fileName := fileFolder.fileName &amp; "\" &amp; ScriptToRun &amp; ErrorLogName &amp;
			startTS.date.year.String &amp; startTS.date.month.String.padLeadingZeros(2) &amp; startTS.date.day.String.padLeadingZeros(2) &amp; "_" &amp;
			startTS.time.hour.String.padLeadingZeros(2) &amp; startTS.time.minute.String.padLeadingZeros(2) &amp; 
			startTS.time.second.String.padLeadingZeros(2) &amp; ".log";
		errorFile.writeLine(app.myPassport.getAllErrorsAndWarningsAsStr);
		
		delete errorFile;
		delete fileFolder;
			
	endif;
		
	app.finalize();
	terminate;

end;</source>
        <Parameter name="commandLine" type="String"/>
    </JadeMethod>
    <JadeMethod name="runOpsViewRailTest" id="dbefc42e-c48f-45bd-a0df-7a81a9a0bdb6">
        <updating/>
        <source>runOpsViewRailTest(commandLine : String) updating;

/*

Purpose:		This will run required script to generate OpsView Rail reports data

Parameters:		

Return Value:		

Date		Who		Reason
07/09/2022	navgmk3	Initial creation

*/
constants

	ScriptToRun						: String = "runOpsviewRailScript";
	ErrorDirectoryName 				: String = "C:\temp\OpsView_Logs";
	ErrorLogName 					: String = "_OpsView_Test";
	UserName						: String = "MTN-OPS";
	TerminalId						: String = "MTNQ";
	
vars

	errorFile						: File;
	fileFolder						: FileFolder;
	utScripts						: UT_Scripts;
	terminal						: CM_Terminal;
	passportTerm					: CM_Terminal;
	user							: CM_User;
	
	paramNames						: StringArray512;
	paramValues						: StringArray512;
	paramArray						: StringArray512;
	
	startTS							: TimeStamp;
	commandLineStr					: String;
	pos								: Integer;
	posEqual						: Integer;
	posEqual2						: Integer;
	posSpace						: Integer;
	tempStr							: String;
	timeToLeave						: Boolean;

begin

	// Initialize
	app.initialize();
	
	isOpsviewTest := true;
	 
	startTS := app.actualTimeAppServer();
	app.delayTime := 5000;
	
	commandLineStr := commandLine;
	create paramArray transient;
	pos := commandLineStr.toLower().pos("endjade", 1);
	if pos &lt;&gt; 0 then
		commandLineStr := commandLineStr[pos + 7:end];
	endif;
	
	while (true) do
	
		// Get the 1st =
		posEqual := commandLineStr.pos("=", 1);
		if posEqual = 0 then
			break;
		endif;
		
		// get the next =
		posEqual2 := commandLineStr.pos("=", posEqual + 1);
		
		// work out what the string is
		if posEqual2 &gt; 0 then
			posSpace := commandLineStr.reversePosIndex(" ", posEqual2);
			tempStr := commandLineStr[1:posSpace].trimBlanks();
			commandLineStr := commandLineStr[posSpace:end].trimBlanks();
		else
			tempStr := commandLineStr;
			timeToLeave := true;
		endif;
						
		// get the parameters
		paramArray.clear();
		tempStr.getTokensForDelimiter("=", paramArray);
		if paramArray[1] = "DelayTime" then
			delayTime := paramArray[2].Integer;
		elseif paramArray[1] = "ShiftLength" then
			shiftLength := paramArray[2].Integer;
		endif;	
		
		// break out as no more items on the line
		if timeToLeave then
			break;
		endif;
	
	endwhile;
	
	// setup the terminal
	terminal := app.myRoot.allTerminals[TerminalId];
	if terminal = null then
		app.writeLog("Unable to find terminal: " &amp; TerminalId &amp; ".   Exiting JadeScript...", LogINFO);
		return;
	endif;
	
	passportTerm := app.myPassport.myTerminal;
	app.myPassport.setMyTerminal(terminal);
	
	// get the user and set passport's myUser
	user := app.myRoot.allUsers[UserName].CM_User;
	if user = null then
		app.writeLog("Unable to find user: " &amp; UserName &amp; ".   Exiting JadeScript...", LogINFO);
		return;
	endif;
	app.myPassport.setMyUserFromCode(user.code);
	
	app.writeLog("ErrorDirectoryName: " &amp; ErrorDirectoryName &amp; CrLf &amp; "ScriptToRun: " &amp; ScriptToRun &amp; CrLf &amp; 
		"ErrorLogName: " &amp; ErrorLogName &amp; CrLf &amp; "userName: " &amp; user.code, LogINFO);
	on Exception do self.runScriptExceptionHandler(exception, ErrorDirectoryName, ScriptToRun, startTS, "_");
		
	// call the script to run
	// There are no paramaters to pass as the scripts are self contained
	create utScripts transient;
	utScripts.setActiveProfileMDHONLY();
		
	utScripts.sendMsg(ScriptToRun);
	
epilog
	
	delete utScripts;
	
	// messages in app.myPassport.allWarningErrorMsgs
	if not app.myPassport.allErrors.isEmpty() then
	
		// Check folder actually exists is not then create
		create fileFolder transient;
		fileFolder.fileName := ErrorDirectoryName;
		if not fileFolder.isAvailable() then
			fileFolder.make();
		endif;
		
		create errorFile transient;
		//create app.automatedOutputFile transient;
		errorFile.fileName := fileFolder.fileName &amp; "\" &amp; ScriptToRun &amp; ErrorLogName &amp;
			startTS.date.year.String &amp; startTS.date.month.String.padLeadingZeros(2) &amp; startTS.date.day.String.padLeadingZeros(2) &amp; "_" &amp;
			startTS.time.hour.String.padLeadingZeros(2) &amp; startTS.time.minute.String.padLeadingZeros(2) &amp; 
			startTS.time.second.String.padLeadingZeros(2) &amp; ".log";
		errorFile.writeLine(app.myPassport.getAllErrorsAndWarningsAsStr);
		
		delete errorFile;
		delete fileFolder;
			
	endif;
		
	app.finalize();
	terminate;

end;</source>
        <Parameter name="commandLine" type="String"/>
    </JadeMethod>
    <JadeMethod name="runOpsViewTest" id="96bbb532-a339-4650-b00b-9f3cc12d5612">
        <updating/>
        <source>runOpsViewTest(commandLine : String) updating;
/*

Purpose:		This will run required script to setup OpsView Data

Parameters:		

Return Value:		

Date		Who		Reason
08/12/2021	navgmh5	Initial creation

*/
constants

	ScriptToRun						: String = "tMain";
	ErrorDirectoryName 				: String = "C:\temp\OpsView_Logs";
	ErrorLogName 					: String = "_OpsView_Test";
	UserName						: String = "MTN-OPS";
	TerminalId						: String = "MTNQ";
	
vars

	errorFile						: File;
	fileFolder						: FileFolder;
	utScripts						: UT_KPIVoyage;
	terminal						: CM_Terminal;
	passportTerm					: CM_Terminal;
	user							: CM_User;
	
	paramNames						: StringArray512;
	paramValues						: StringArray512;
	paramArray						: StringArray512;
	
	startTS							: TimeStamp;
	commandLineStr					: String;
	pos								: Integer;
	posEqual						: Integer;
	posEqual2						: Integer;
	posSpace						: Integer;
	tempStr							: String;
	timeToLeave						: Boolean;

begin

	// Initialize
	app.initialize();
	
	isOpsviewTest := true;
	 
	startTS := app.actualTimeAppServer();
	app.delayTime := 5000;
	
	commandLineStr := commandLine;
	create paramArray transient;
	pos := commandLineStr.toLower().pos("endjade", 1);
	if pos &lt;&gt; 0 then
		commandLineStr := commandLineStr[pos + 7:end];
	endif;
	
	while (true) do
	
		// Get the 1st =
		posEqual := commandLineStr.pos("=", 1);
		if posEqual = 0 then
			break;
		endif;
		
		// get the next =
		posEqual2 := commandLineStr.pos("=", posEqual + 1);
		
		// work out what the string is
		if posEqual2 &gt; 0 then
			posSpace := commandLineStr.reversePosIndex(" ", posEqual2);
			tempStr := commandLineStr[1:posSpace].trimBlanks();
			commandLineStr := commandLineStr[posSpace:end].trimBlanks();
		else
			tempStr := commandLineStr;
			timeToLeave := true;
		endif;
						
		// get the parameters
		paramArray.clear();
		tempStr.getTokensForDelimiter("=", paramArray);
		if paramArray[1] = "DelayTime" then
			delayTime := paramArray[2].Integer;
		elseif paramArray[1] = "ShiftLength" then
			shiftLength := paramArray[2].Integer;
		endif;	
		
		// break out as no more items on the line
		if timeToLeave then
			break;
		endif;
	
	endwhile;
	
	// setup the terminal
	terminal := app.myRoot.allTerminals[TerminalId];
	if terminal = null then
		app.writeLog("Unable to find terminal: " &amp; TerminalId &amp; ".   Exiting JadeScript...", LogINFO);
		return;
	endif;
	
	passportTerm := app.myPassport.myTerminal;
	app.myPassport.setMyTerminal(terminal);
	
	// get the user and set passport's myUser
	user := app.myRoot.allUsers[UserName].CM_User;
	if user = null then
		app.writeLog("Unable to find user: " &amp; UserName &amp; ".   Exiting JadeScript...", LogINFO);
		return;
	endif;
	app.myPassport.setMyUserFromCode(user.code);
	
	app.writeLog("ErrorDirectoryName: " &amp; ErrorDirectoryName &amp; CrLf &amp; "ScriptToRun: " &amp; ScriptToRun &amp; CrLf &amp; 
		"ErrorLogName: " &amp; ErrorLogName &amp; CrLf &amp; "userName: " &amp; user.code, LogINFO);
	on Exception do self.runScriptExceptionHandler(exception, ErrorDirectoryName, ScriptToRun, startTS, "_");
		
	// call the script to run
	// There are no paramaters to pass as the scripts are self contained
	create utScripts transient;
	utScripts.setActiveProfileMDHONLY();
		
	utScripts.sendMsg(ScriptToRun);
	
epilog
	
	delete utScripts;
	
	// messages in app.myPassport.allWarningErrorMsgs
	if not app.myPassport.allErrors.isEmpty() then
	
		// Check folder actually exists is not then create
		create fileFolder transient;
		fileFolder.fileName := ErrorDirectoryName;
		if not fileFolder.isAvailable() then
			fileFolder.make();
		endif;
		
		create errorFile transient;
		//create app.automatedOutputFile transient;
		errorFile.fileName := fileFolder.fileName &amp; "\" &amp; ScriptToRun &amp; ErrorLogName &amp;
			startTS.date.year.String &amp; startTS.date.month.String.padLeadingZeros(2) &amp; startTS.date.day.String.padLeadingZeros(2) &amp; "_" &amp;
			startTS.time.hour.String.padLeadingZeros(2) &amp; startTS.time.minute.String.padLeadingZeros(2) &amp; 
			startTS.time.second.String.padLeadingZeros(2) &amp; ".log";
		errorFile.writeLine(app.myPassport.getAllErrorsAndWarningsAsStr);
		
		delete errorFile;
		delete fileFolder;
			
	endif;
		
	app.finalize();
	terminate;

end;</source>
        <Parameter name="commandLine" type="String"/>
    </JadeMethod>
    <JadeMethod name="runResetConfigData" id="9b6d22ac-2805-4237-bd53-edd87bc866f7">
        <updating/>
        <source>runResetConfigData(commandLine: String) updating;
/*

Purpose:		This will run required script to reset Config data

Parameters:		endJade ErrorLogDirectory='' ScriptToRun=''
				e.g. endJade ErrorLogDirectory=C:\Users\jlgmh5\source\repos\MTNAutomatedTests\MTNAutomatedTests\bin\Debug\JadeErrorLog ScriptToRun=reset_CashModuleConfigData User=Cash User

Return Value:		

Date		Who		Reason
06/07/2020	jlgmh5	Initial creation
25/10/2023	navmh5	60961 - Enable the passing of killBPG to resetTerminalConfigs
*/

vars

	errorFile						: File;
	fileFolder						: FileFolder;
	utScripts						: UT_Scripts;

	paramNames						: StringArray512;
	paramValues						: StringArray512;
	paramArray						: StringArray512;

	pos								: Integer;
	posEqual						: Integer; 
	posEqual2						: Integer;
	startTS							: TimeStamp;
	tempStr							: String;
	posSpace						: Integer;
	timeToLeave						: Boolean;
	commandLineStr					: String;
	
	errorDirectoryName 				: String;
	scriptToRun 					: String;
	userName						: String;
	setMeasurementTypeTo			: String;
	killBGP							: String;
	exitCode						: Integer;
	
begin

	// Default to error
	exitCode := 63;

	app.initialize();
	
	isOpsviewTest := false;

	startTS := app.actualTimeAppServer();
	
	commandLineStr := commandLine;
	//write "commandLineStr: " &amp; commandLineStr;
	create paramArray transient;
	pos := commandLineStr.toLower().pos("endjade", 1);
	if pos &lt;&gt; 0 then
		commandLineStr := commandLineStr[pos + 7:end];
	endif;

	while (true) do
	
		// Get the 1st =
		posEqual := commandLineStr.pos("=", 1);
		if posEqual = 0 then
			break;
		endif;
		
		// get the next =
		posEqual2 := commandLineStr.pos("=", posEqual + 1);
		
		// work out what the string is
		if posEqual2 &gt; 0 then
			posSpace := commandLineStr.reversePosIndex(" ", posEqual2);
			tempStr := commandLineStr[1:posSpace].trimBlanks();
			commandLineStr := commandLineStr[posSpace:end].trimBlanks();
		else
			tempStr := commandLineStr;
			timeToLeave := true;
		endif;
						
		// get the parameters
		paramArray.clear();
		tempStr.getTokensForDelimiter("=", paramArray);
		if paramArray[1] = "ErrorLogDirectory" then
			errorDirectoryName := paramArray[2];
		elseif paramArray[1] = "ScriptToRun" then
			scriptToRun := paramArray[2];
		elseif paramArray[1] = "User" then
			userName := paramArray[2];
		elseif paramArray[1] = "SetMeasurementTypeTo" then
			setMeasurementTypeTo := paramArray[2];
		elseif paramArray[1] = "KillBGP" then
			killBGP := paramArray[2];
		endif;	
		
		
		// break out as no more items on the line
		if timeToLeave then
			break;
		endif;
	
	endwhile;
	
	//write "errorDirectoryName: " &amp; errorDirectoryName &amp; CrLf &amp;
	//	"scriptToRun: " &amp; scriptToRun &amp; CrLf &amp;
	//	"userName: " &amp; userName;
	app.writeLog("errorDirectoryName: " &amp; errorDirectoryName &amp; CrLf &amp; "scriptToRun: " &amp; scriptToRun &amp; CrLf &amp; "userName: " &amp; userName &amp; CrLf &amp;
	"setMeasurementTypeTo: " &amp; setMeasurementTypeTo &amp; CrLf &amp;
	"killBGP: " &amp; killBGP, LogINFO);
	
	on Exception do self.runScriptExceptionHandler(exception, errorDirectoryName, scriptToRun, startTS, "_ErrorLog_ResetConfig_Data");
			
	// call the script to run
	// There are no paramaters to pass as the scripts are self contained
	create utScripts transient;
	utScripts.setActiveProfileMDHONLY();
	
	utScripts.sendMsgWithParams(scriptToRun, userName, setMeasurementTypeTo, killBGP);
	
	exitCode := 0;

	
epilog
	
	delete paramNames;
	delete paramValues;
	delete paramArray;
	
	//delete app.automatedOutputFile;
	
	delete utScripts;
	
	// messages in app.myPassport.allWarningErrorMsgs
	if not app.myPassport.allErrors.isEmpty() or exitCode &lt;&gt; 0 then
	
		// Check folder actually exists is not then create
		create fileFolder transient;
		fileFolder.fileName := errorDirectoryName;
		if not fileFolder.isAvailable() then
			fileFolder.make();
		endif;
		
		create errorFile transient;
		//create app.automatedOutputFile transient;
		errorFile.fileName := fileFolder.fileName &amp; "\" &amp; scriptToRun &amp; "_ErrorLog_ResetConfig_Data" &amp; 
			startTS.date.year.String &amp; startTS.date.month.String.padLeadingZeros(2) &amp; startTS.date.day.String.padLeadingZeros(2) &amp; "_" &amp;
			startTS.time.hour.String.padLeadingZeros(2) &amp; startTS.time.minute.String.padLeadingZeros(2) &amp; 
			startTS.time.second.String.padLeadingZeros(2) &amp; ".log";
		errorFile.writeLine(app.myPassport.getAllErrorsAndWarningsAsStr);
		
		delete errorFile;
		delete fileFolder;
			
	endif;
		
	app.writeLog("exitCode: " &amp; exitCode.String, LogINFO);
			
	app.finalize();
	
	beginTransaction;
	node.userExitCode := exitCode;
	commitTransaction;
	
	terminate;

end;</source>
        <Parameter name="commandLine" type="String"/>
    </JadeMethod>
