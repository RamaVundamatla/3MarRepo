    <PrimAttribute name="workOrderType" id="9bf7a1c7-9fc0-4f1c-917a-3b3032864290">
        <embedded/>
        <type name="Integer"/>
        <access>readonly</access>
        <text>

VOYAGE WORK ORDER TRANSACTION TYPE


WO_TRANS_CANCEL = Cancel Work Order Request
WO_TRANS_CARGOREQADDITIONAL = Additional Cargo Request
WO_TRANS_CARGOREQINITIAL = Initial Cargo Rquest
WO_TRANS_EXTENSION = Extension to Request
WO_TRANS_MARINESERVICEDEPART = Departure Marine Services Request
WO_TRANS_MARINESERVICEINITIAL = Initial Marine Services Request
WO_TRANS_SHIFT = Shift Request
WO_TRANS_TIMECHANGE = Request Time Change
WO_TRANS_VOYAGEREQUEST = Voyage Request
WO_TRANS_WATERREQUEST = Water Request
</text>
    </PrimAttribute>
    <JadeMethod name="auditId" id="2cb2eaa1-ec69-4cd7-b990-3ff2ae5526f2">
        <source>auditId(): String;
/*
Purpose:	TFS 39236		
Date				Who			Reason
JUNE 2018		CNWAB1		Initial creation
*/

vars

begin
	return self.getTranMapBreadCrumb;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="auditIdDisplay" id="2cd38b0a-a231-426b-80f2-abe89b1eedc5">
        <source>auditIdDisplay(): String;
/*
Purpose:	TFS 39236		
Date				Who			Reason
JUNE 2018		CNWAB1			Initial creation
31 Mar 2025 	navma1  		MTN-34387 MTN - Removing Unnecessary Audits
*/


vars
	auditIdStr : String;
begin
	auditIdStr := self.auditId();								//31.03.2025 navma1 #MTN-34387
	
	if auditIdStr &lt;&gt; null then
		return 'Work Order Map' &amp; ' - ' &amp; auditIdStr;
	else
		return 'Work Order Map';
	endif;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getAuditText" id="a19d0db5-47a7-4ee4-951d-571523bfb296">
        <source>getAuditText(): String;
/*
Purpose:	TFS 39236		
Date				Who			Reason
JUNE 2018		CNWAB1		Initial creation
*/

vars
	txt,
	tmpStr	: String;
begin
	txt[10000] 	:= '*';
	txt 		:= null;
	txt 		:= inheritMethod();
	tmpStr := self.getTranMapBreadCrumb;
	txt := txt &amp; 'Item Path' &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp;tmpStr &amp; AuditStringSeparator;
	
	tmpStr := null;
	if self.myTransMap &lt;&gt; null then
		tmpStr := self.getWOClassName;
		txt := txt &amp; 'Transaction Type' &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp;tmpStr &amp; AuditStringSeparator; // TFS 39518
	endif;
	
	if self.getMyTerminal &lt;&gt; null then
		tmpStr := self.getMyTerminal.name;
		txt := txt &amp; app.getErrorString(Terminal) &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp;tmpStr &amp; AuditStringSeparator;
	endif;
	
	tmpStr := null;
	if self.myTransMap.getBank &lt;&gt; null then
		tmpStr := self.myTransMap.getBank.mailingName;
		txt := txt &amp; app.getErrorString(CM_Business_Unit) &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp;tmpStr &amp; AuditStringSeparator;
	endif;
	
	
	return txt;
epilog
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
