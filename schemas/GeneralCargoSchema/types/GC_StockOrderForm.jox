    <JadeMethod name="includesObject" id="13f3537d-0e47-474d-9b47-a170926cf5a2">
        <source>includesObject(_obj: Object): Boolean;
// ---------------------------------------------------------------------------
// Created:     29 April 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	stkOrd			: CM_StockOrderHeaderGeneric;
	startPos		: Integer;
begin
	stkOrd := _obj.CM_StockOrderHeaderGeneric;
	startPos := 1;
	
	if (self.myFiltOperator &lt;&gt; null and self.myFiltOperator &lt;&gt; stkOrd.myOperator) or
	   (self.filtFulfillStatus &lt;&gt; null and self.filtFulfillStatus &lt;&gt; stkOrd.fulfilledStatus) or
	   (self.filtOrderNo &lt;&gt; null and (stkOrd.orderNo.pos(self.filtOrderNo, startPos) = 0)) then
		return false;
	endif;
	
	return true;
	
end;</source>
        <Parameter name="_obj" type="Object"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="initForm" id="21e7bf9d-5c07-48b0-bece-3c224a111059">
        <updating/>
        <source>initForm() updating;
// ---------------------------------------------------------------------------
// Created:     31 March 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	user			: CM_User;
begin
	inheritMethod();
	
	
	user := app.getMyUser();
	if user.canDo(self.myTerminal, self.permissionMaint) then
		self.allowMasterNew := true;
		self.allowMasterEdit := true;
		self.allowMasterDelete := true;
		self.allowDetailAdd := true;
		self.allowDetailUpdate := true;
		self.allowDetailRemove := true;
	endif;
	self.mnuDetailNew.caption := 'Add Stock Order Line...'; 
	self.mnuDetailEdit.caption := 'Edit Stock Order...'; 
	self.mnuDetailRemove.caption := 'Remove Stock Order Line...';		
	self.showTblDetailCount := true;
	
	self.cmbLineType.automaticCellControl	:= true;
	self.cmbCargoType.automaticCellControl	:= true;
	self.cmbProduct.automaticCellControl	:= true;
	self.cmbTI.automaticCellControl	:= true;
	
	self.doRefresh();//populate combos
end;</source>
    </JadeMethod>
