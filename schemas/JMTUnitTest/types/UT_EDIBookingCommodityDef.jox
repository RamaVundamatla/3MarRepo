    <JadeMethod name="tUserDefCommodityDescrDefault1" id="4d7ed97a-f652-4bb8-8e46-d4ba7d6fa2b2">
        <updating/>
        <source>tUserDefCommodityDescrDefault1() updating;
///25 Jun 2015	cnwrs1	Par 33901/36027 - Default booking commodity
// Test the loading of commodity description default when FTX+AAA is after TMP
// 10 Sep 2019	cnwrs1	TFS 46030
constants
	VoyageName = "UTV101";
	ShipName = "UTBOAT";
	BookingRefNo = "528282977";
	Commodity1 = "FROZEN VEGAN";
	Commodity2 = "FROZEN FISHERMAN";
	Commodity3 = "A PILE OF STUFF";
	UserDefinedBooking	= 'Unit Test Booking XML';
	Commodity4 = "DANGEROUS HOT FISH";
vars
	vessel: CM_Vessel;
	voyage: CM_Voyage;
	ediFile : CM_EDIFile;
	booking : CM_BookingRef;
	text : String;
	bookingItem : CM_BookingRefItem;
	operatorCode : String;
	tempStr	: String;
	isDoClearanceCheck : Boolean;
begin
	isDoClearanceCheck := self.getMyTerminal.myHarbour.isDoClearanceCheck;
	self.setHarbourIsDoClearanceCheck(false);
	self.setTerminalConfig(EdiBookingCommodity, true);
	self.deleteVoyage(VoyageName);
	self.deleteVessel("UTBOAT");
	self.deleteBooking(BookingRefNo);
	self.opts.addAssoc( ETRow_LloydsNumber, '9227314' );
	operatorCode := self.getProfileSetting(UT_Profile.P_OPERATOR).asString;
	vessel := self.addVesselCellular(ShipName, self.getOperator(operatorCode));
	self.assertNotNullMsg(vessel, "Add vessel failed");
	voyage := self.addVoyageWithContainerStructur(VoyageName, ShipName, operatorCode, self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString);
	text :="&lt;Booking&gt;&lt;BookingH&gt;&lt;ID&gt;"&amp;BookingRefNo&amp;"&lt;/ID&gt;&lt;Consignee&gt;DOUG&lt;/Consignee&gt;&lt;Destination&gt;ABCNR&lt;/Destination&gt;&lt;DischargePort&gt;AEHAM&lt;/DischargePort&gt;&lt;Voyage&gt;"&amp;VoyageName&amp;"&lt;/Voyage&gt;&lt;Vessel&gt;"&amp;ShipName&amp;"&lt;/Vessel&gt;&lt;Operator&gt;"&amp;operatorCode&amp;"&lt;/Operator&gt;"&amp;
	"&lt;BookingIt&gt;&lt;ID&gt;"&amp;BookingRefNo&amp;"&lt;/ID&gt;&lt;ISOType&gt;22R1&lt;/ISOType&gt;&lt;ItemNumber&gt;5&lt;/ItemNumber&gt;&lt;TotalWeight&gt;18830&lt;/TotalWeight&gt;&lt;CommodityDescr&gt;"&amp;Commodity1&amp;"&lt;/CommodityDescr&gt;&lt;CargoType&gt;CONT&lt;/CargoType&gt;&lt;Temperature&gt;-20&lt;/Temperature&gt;&lt;/BookingIt&gt;"&amp;
	"&lt;BookingIt&gt;&lt;ID&gt;"&amp;BookingRefNo&amp;"&lt;/ID&gt;&lt;ISOType&gt;45R1&lt;/ISOType&gt;&lt;ItemNumber&gt;5&lt;/ItemNumber&gt;&lt;TotalWeight&gt;25840&lt;/TotalWeight&gt;&lt;CommodityDescr&gt;"&amp;Commodity2&amp;"&lt;/CommodityDescr&gt;&lt;CargoType&gt;CONT&lt;/CargoType&gt;&lt;Temperature&gt;-20&lt;/Temperature&gt;&lt;Hazards&gt;1.2 (0450, 0440)&lt;/Hazards&gt;&lt;/BookingIt&gt;"&amp;
	"&lt;BookingIt&gt;&lt;ID&gt;"&amp;BookingRefNo&amp;"&lt;/ID&gt;&lt;ISOType&gt;4230&lt;/ISOType&gt;&lt;ItemNumber&gt;5&lt;/ItemNumber&gt;&lt;TotalWeight&gt;25840&lt;/TotalWeight&gt;&lt;CommodityDescr&gt;"&amp;Commodity3&amp;"&lt;/CommodityDescr&gt;&lt;CargoType&gt;CONT&lt;/CargoType&gt;&lt;/BookingIt&gt;"&amp;
	"&lt;BookingIt&gt;&lt;ID&gt;"&amp;BookingRefNo&amp;"&lt;/ID&gt;&lt;ISOType&gt;42G1&lt;/ISOType&gt;&lt;ItemNumber&gt;5&lt;/ItemNumber&gt;&lt;TotalWeight&gt;25840&lt;/TotalWeight&gt;&lt;CommodityDescr&gt;"&amp;Commodity4&amp;"&lt;/CommodityDescr&gt;&lt;CargoType&gt;CONT&lt;/CargoType&gt;&lt;Hazards&gt;1.2 (0450, 0440)&lt;/Hazards&gt;&lt;/BookingIt&gt;"&amp;
	"&lt;/BookingH&gt;&lt;/Booking&gt;";
	ediFile := self.ediLoadFileName(text, EDIFileType_XML, UserDefinedBooking, UserDefinedBooking);
	self.assertNotNull(ediFile);
	self.ediVerify(ediFile);
	tempStr	:= 'Verified failed' &amp; CrLf &amp; app.myPassport.getErrorsAsString;
	self.assertEqualMsg(ediFile.fileStatus, CM_EDIFile.EDI_STATUS_VERIFIED_WARNINGS, tempStr);
	self.ediDBLoad(ediFile);
	tempStr	:= 'DB Load failed' &amp; CrLf &amp; app.myPassport.getErrorsAsString;
	self.assertEqualMsg(ediFile.fileStatus, CM_EDIFile.EDI_STATUS_DBLOADED, tempStr);
	booking := self.getBooking(BookingRefNo);
	self.assertNotNull(booking);
	foreach bookingItem in booking.allBookingRefItems do
		if bookingItem.isoType = "22R1" then
			self.assertEqual(bookingItem.commodity, "REEF");
			self.assertEqual(bookingItem.getEDICommodityDescription(), Commodity1);
		elseif bookingItem.isoType = "45R1" then
			self.assertEqual(bookingItem.commodity, "REEF");
			self.assertEqual(bookingItem.getEDICommodityDescription(), Commodity2);
		elseif bookingItem.isoType = "4230" then
			self.assertEqual(bookingItem.commodity, "TBA");
			self.assertEqual(bookingItem.getEDICommodityDescription(), Commodity3);
		elseif bookingItem.isoType = "42G1" then
			self.assertEqual(bookingItem.commodity, "HAZD");
			self.assertEqual(bookingItem.getEDICommodityDescription(), Commodity4);
		else
			self.assertEqual(bookingItem.commodity, "********************");
		endif;
	endforeach;
epilog
	self.setHarbourIsDoClearanceCheck(isDoClearanceCheck);
end;</source>
    </JadeMethod>
    <JadeMethod name="tUserDefCommodityDescrDefault2" id="2e1ae02e-bc6e-4474-a441-c82efb789501">
