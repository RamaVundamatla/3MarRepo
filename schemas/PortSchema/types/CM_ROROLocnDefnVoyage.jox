    <JadeMethod name="getKPIArea" id="eee4ac99-7bd0-440f-8435-734163822d90">
        <source>getKPIArea(_mode: Integer; _tis: CM_TIArray input; _area, _volume : Decimal output);
/*
Purpose:			
Date		Who		Reason
01 September 2011	cnwab1	Initial creation
*/

vars
	tmpTI : CM_TrackedItem;
begin
	//_tis.clear();
	_volume := 0;
	_area :=  0;
	
	// ### ACTUAL VIEW
	if _mode = REAL_MODE then
		self.getAllTIs(ShpDisplayMode_Actual, _tis, true);
	// ### PROPOSED VIEW
	elseif _mode = ShpDisplayMode_Proposed then
		self.getProposedTIs( _tis, true);
	endif;
	
	if not _tis.isEmpty() then
		_area := self.getAreaInSquareMetres();
	endif;
	
	foreach tmpTI in _tis discreteLock do
		_volume := _volume + tmpTI.totalVolume;
	endforeach;
epilog

end;</source>
        <Parameter name="_mode" type="Integer"/>
        <Parameter name="_tis" type="CM_TIArray" usage="input"/>
        <Parameter name="_area" type="Decimal" usage="output"/>
        <Parameter name="_volume" type="Decimal" usage="output"/>
    </JadeMethod>
    <JadeMethod name="getLC" id="5c99a6c8-9aa7-4981-be8d-231fafc1e0c7">
        <source>getLC() : CM_LocationsController;
/*
Purpose:			
Date		Who		Reason
24 June 2011	cnwab1	Initial creation
*/

vars
	slotDefn : CM_ROROSlotDefn;
begin
	foreach slotDefn in self.allROROSlotDefnByOrdinal discreteLock do
		if slotDefn.CM_ROROSlotDefnVoyage.mySlotController.myRORORequestDischarge = null 
		and slotDefn.CM_ROROSlotDefnVoyage.mySlotController.myRORORequestLoad = null then
			return slotDefn.CM_ROROSlotDefnVoyage.mySlotController;
		endif;
	endforeach;
	
	return null;
epilog

end;</source>
        <ReturnType type="CM_LocationsController"/>
    </JadeMethod>
    <JadeMethod name="getLCForRotation" id="bd54fa59-077e-4113-aba1-ff33b8341162">
        <source>getLCForRotation(_slot : CM_ROROSlotController) : CM_VoyageROROController;
/*
Purpose:		PAR 32021. To get the corresponding Slot LC on a rotated linked RORO location defn	
Date		Who		Reason
19 July 2013	cnwab1	Initial creation
*/

vars
	locnDefn : CM_ROROLocnDefnVoyage;
	other : CM_ROROSlotDefn;
begin
	if not self.isPlannedRotated then
		return null;
	endif;
	
	locnDefn := _slot.getDefn().CM_ROROLocnDefnVoyage;
	
	other := self.allROROSlotDefnByOrdinal[self.ordinal,_slot.mySlotDefn.ordinal];
	
	if other = null then
		return null;
	endif;
	
	return other.CM_ROROSlotDefnVoyage.mySlotController;
epilog

end;</source>
        <Parameter name="_slot" type="CM_ROROSlotController"/>
        <ReturnType type="CM_VoyageROROController"/>
    </JadeMethod>
    <JadeMethod name="getLCNoTI" id="82ba9965-452c-4be1-a1fd-e40a6dbe0237">
        <source>getLCNoTI(_mode : Integer) : CM_LocationsController;
/*
Purpose:			
Date				Who			Reason
SEPTEMBER 2011		CNWAB1		Initial creation
*/


vars
	slotDefn : CM_ROROSlotDefn;
	slotLC : CM_ROROSlotController;
begin
	foreach slotDefn in self.allROROSlotDefnByOrdinal discreteLock  where slotDefn.isAvailable = true do // PAR 29030
		slotLC := slotDefn.CM_ROROSlotDefnVoyage.mySlotController;
		if _mode = REAL_MODE then
			if slotLC.allTrackedItems.isEmpty then
				return slotLC;
			endif;
		elseif _mode = PLANNING_MODE then
			if slotLC.allPlannedFutureMoves.isEmpty() then
				return slotLC;
			endif;
		elseif _mode = QUEUE_MODE then
			if slotLC.allQueuedFutureMoves.isEmpty() then
				return slotLC;
			endif;
		endif;
	endforeach;
	
	return null;
epilog

end;</source>
        <Parameter name="_mode" type="Integer"/>
        <ReturnType type="CM_LocationsController"/>
    </JadeMethod>
    <JadeMethod name="getLCWithTI" id="03262fad-871d-442a-95c2-0e052c94f880">
        <source>getLCWithTI(_mode : Integer) : CM_LocationsController;
/*
Purpose:			
Date				Who			Reason
SEPTEMBER 2011		CNWAB1		Initial creation
*/


vars
	slotDefn : CM_ROROSlotDefn;
	slotLC : CM_ROROSlotController;
	theTI : CM_TrackedItem;
begin
	foreach slotDefn in self.allROROSlotDefnByOrdinal discreteLock  where slotDefn.isAvailable = true do // PAR 29030
		slotLC := slotDefn.CM_ROROSlotDefnVoyage.mySlotController;
		theTI := slotLC.allTrackedItems.first;
		
		if theTI = null then
			continue;
		endif;
		
		
		if _mode = REAL_MODE then
			return slotLC;
		elseif _mode = PLANNING_MODE then
			if theTI.myPrimaryPlannedLocation = null then // not planned
				return slotLC;
			endif;
		elseif _mode = QUEUE_MODE then
			if theTI.myPrimaryQueuedLocation = null then // not queued
				return slotLC;
			endif;
		endif;
	endforeach;
	
	return null;
epilog

end;</source>
        <Parameter name="_mode" type="Integer"/>
        <ReturnType type="CM_LocationsController"/>
    </JadeMethod>
    <JadeMethod name="getLCs" id="2a5fc25a-23ac-49e8-9113-1070b42e7899">
        <updating/>
        <source>getLCs(_lcs: CM_LCSet input; _clear : Boolean) updating;
/*
Purpose:			
Date		Who		Reason
28 June 2011	cnwab1	Initial creation
*/

vars
	slotDefn : CM_ROROSlotDefn;
begin

	if _lcs = null then
		return;
	endif;
	if _clear then
		_lcs.clear();
	endif;
	
	foreach slotDefn in self.allROROSlotDefnByOrdinal discreteLock do
		if not slotDefn.isAvailable then
			continue;
		endif;
	
		_lcs.addNoDuplicates(slotDefn.CM_ROROSlotDefnVoyage.mySlotController, false);
	endforeach;


epilog

end;</source>
        <Parameter name="_lcs" type="CM_LCSet" usage="input"/>
        <Parameter name="_clear" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getMyVoyageObject" id="6a9e3dd4-7d79-4b85-a3b2-172a08735562">
        <source>getMyVoyageObject(): CM_Voyage;
// ---------------------------------------------------------------------------
// Created:     12 July 2013 by cnwab1
