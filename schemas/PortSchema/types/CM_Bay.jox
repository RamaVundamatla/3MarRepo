        <source>isBridgeAfterBay() : Boolean;

vars

begin
	return false;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isFirstInHold" id="9223e75b-148f-4adb-aec3-2fcf697c2b2e">
        <source>isFirstInHold() : Boolean;
/*
------------------------------------------------------------------------
Created:			21 November 2002 by cnwdwq1
Purpose:			Returns boolean indicating if this bay is first in hold
Parameters:		None
Returns:			Nothing
Changed On		Changed By		Reason
------------	------------	-----------------------------------------
---------------------------------------------------------------------------
*/
begin
	if self.myHold = null then
		return false;
	endif;
	return (self.myHold.allBays.first = self);
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isForwardBay" id="aadccee8-a772-4274-9fe6-b13d7e794ce4">
        <source>isForwardBay() : Boolean;
// ---------------------------------------------------------------------------
// Created:		March 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
begin

	if self.myHold &lt;&gt; null then
		if self.bayType = BAY_TYPE_TRIPLE then
			return self.myHold.allBays.indexOf(self) &lt;= 2;
		else
			return self.myHold.allBays.indexOf(self) = 1;
		endif;
	endif;
	return false;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
