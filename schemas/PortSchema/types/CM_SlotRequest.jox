    <JadeMethod name="getCommodityGroup" id="2e4e5052-0cb8-4cd1-a3ad-cd26bfaa95e0">
        <source>getCommodityGroup() : String;
// ---------------------------------------------------------------------------
// Created:     
//
// Purpose:     reads the commodity of the colour code, and returns the commodity group
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	term : CM_Terminal;
	defCmdty : String;
	defCmdtyGrp : String;
	cmdty : CM_Commodity;
begin
	term := self.myTerminal;
	defCmdtyGrp := term.getConfig(DefCommodityGroup).String;
	if self.commodity.trimRight = null then
		//--------------
		//Slot request has no commodity, return the default commodity group
		//--------------
		return defCmdtyGrp;
	endif;
	//----------
	//Lookup
	//----------
	cmdty := app.myRoot.allCommodities[self.commodity];
	if cmdty = null then
		//--------------
		//Could not locate the commodity object used here, return the default
		//--------------
		return defCmdtyGrp;
	endif;
	if cmdty.myCommodityGroup = null then
		//--------------
		//The commodity is not part of a group, return the default
		//--------------
		return defCmdtyGrp;
	endif;
	return cmdty.myCommodityGroup.code.trimRight;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getCrane" id="712772ee-a2f4-4c0a-a6f7-ab7a4d9f053c">
        <source>getCrane() : CM_Crane;
// ---------------------------------------------------------------------------
// Created:     18 May 2010 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	job : CM_VoyageJob;
	crane : CM_Crane;

begin
	job := self.myJob.CM_VoyageJob;
	if job &lt;&gt; null then
		crane := job.getJobCrane();
		if crane &lt;&gt; null then
			return crane;
		endif;
	endif;

		return null;
epilog

end;</source>
        <ReturnType type="CM_Crane"/>
    </JadeMethod>
