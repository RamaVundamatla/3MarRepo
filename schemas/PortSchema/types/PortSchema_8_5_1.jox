    <JadeMethod name="updateVermasEditTriggers" id="35edcfa8-5af9-47e8-9806-560e504e3876">
        <source>updateVermasEditTriggers(_controller: CnEcReleaseController);
/*

Date		Who		Reason
21 July 2016	cnwer1	Initial creation TFS 2395

*/

vars
	camProtocolDesc : CM_CamProtocolDesc;
	camProtocol : CM_CamProtocol;
	allEditTriggerFields : CM_CamEditTriggerFieldDict;
	camTriggerField : CM_CamEditTriggerField;
begin
	if self.hasScriptBeenRunAtAll(method.name, _controller) then
		return;
	endif;
	app.writeLog(method.qualifiedName &amp; " Updating VERMAS with Any VGM Details edit trigger ",LogINFO );
	if _controller &lt;&gt; null then
		_controller.logEntry("Updating VERMAS with Any VGM Details edit trigger") ;	
	endif;
	camProtocolDesc:=app.myRoot.allCamProtocolDescs["UN/EDIFACT Vermas"];
	
	if camProtocolDesc = null then 
		return;
	endif;
	
	if CM_CamUserDefRepDesc.firstInstance &lt;&gt; null then
		allEditTriggerFields := CM_CamUserDefRepDesc.firstInstance.allCamEditTriggerFields;
		camTriggerField:=allEditTriggerFields["String","Any VGM Details"];
	endif;
	
	if camTriggerField = null then
		return;
	endif;
	
	foreach camProtocol in camProtocolDesc.protocols do
		if not camProtocol.allEditTriggerFields.includes(camTriggerField) then
			beginTransaction;
				camProtocol.allEditTriggerFields.add(camTriggerField);
			commitTransaction;
		endif;
		
	endforeach;
	
	
	self.addScriptRun(method.name);
epilog
	

end;</source>
