        <embedded/>
        <type name="Object"/>
        <access>readonly</access>
    </ImplicitInverseRef>
    <PrimAttribute name="secondaryText" id="db3ed597-bebd-426a-8a3b-6f5acd213bea">
        <type name="String"/>
    </PrimAttribute>
    <PrimAttribute name="userString" id="57be1ae9-2cdb-44fb-afe3-254403e4964a">
        <type name="String"/>
        <access>readonly</access>
    </PrimAttribute>
    <JadeMethod name="isJadeException" id="d06f26f0-af16-4eab-bb39-0212121ea378">
        <source>isJadeException():Boolean;
// --------------------------------------------------------------------------------
// Created:		02 August 2006 by cnwdad1
//
// Purpose:		Refer to superclass implementation.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return false;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="set" id="f1c353fd-e3c8-41c5-bfc1-f28c35d16ea1">
        <updating/>
        <source>set(pCode : Integer; pText : String; pWarning : Boolean; pUserString : String; pUserObject : Object; _subject : CM_Object) updating;
// ---------------------------------------------------------------------------
// Created:     17 January 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	str : String;
begin

	self.errorCode := pCode;
	if pWarning then
		str := app.name &amp; " warning " &amp; pCode.String;	
	else
		str := app.name &amp; " error " &amp; pCode.String;
	endif;
	self.errorItem 		:= str;
	if app.useShortErrorMsg then
		self.extendedErrorText := pText;
	else
		self.extendedErrorText := 'Code :' &amp; pCode.String &amp; '. ' &amp; pText;
	endif;
	self.isWarning 		:= pWarning;
	
	if pWarning or app.continueCMExceptions then
		self.continuable := true;
	endif;
	
	self.userString 	:= pUserString;
	self.myUserObject 	:= pUserObject;
	self.mySubject 		:= _subject;

end;</source>
        <Parameter name="pCode" type="Integer"/>
        <Parameter name="pText" type="String"/>
        <Parameter name="pWarning" type="Boolean"/>
        <Parameter name="pUserString" type="String"/>
        <Parameter name="pUserObject" type="Object"/>
        <Parameter name="_subject" type="CM_Object"/>
    </JadeMethod>
    <JadeMethod name="setUserObject" id="c780a2d5-b990-4ebf-b71f-972c403984ba">
        <updating/>
        <source>setUserObject(_value :Object)updating;
/*
Date		Who		Reason
28 May 2012	cnwcs5	Initial creation - par 29583
*/
vars

begin
	self.myUserObject := _value;
epilog

end;</source>
        <Parameter name="_value" type="Object"/>
    </JadeMethod>
</ExceptionClass>
