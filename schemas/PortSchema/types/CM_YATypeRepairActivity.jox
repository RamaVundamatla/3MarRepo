        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="isCMIFDataMatch" id="02eb2202-890c-4ef9-97dd-69114c619eca">
        <source>isCMIFDataMatch(_cmifAutoPlan: CMIF_YAAutoPlan; _yaData: CM_YADataObjects): Boolean;
/*
Purpose - 	
Who - NAVAB1
Date - 14AUG2024
ADO - CR 65144 TASK 65396
*/



