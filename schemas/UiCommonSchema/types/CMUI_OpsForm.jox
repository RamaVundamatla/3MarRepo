        <updating/>
        <source>tblWorkEntries_dragDrop(table: Table input; win: Window input; x: Real; y: Real) updating;
//--------------------------------------------------------------
//Created: 18 March 2003 By: cnwgd1
//--------------------------------------------------------------
vars

begin
/*
	if table.row &lt;= table.fixedRows then
		app.msgBox(app.getErrorString(OPS_Select_Entry_For_Drop),'Make Selection', MsgBox_Information_Icon + MsgBox_OK_Only);
		return;
	endif;
	*/
	if (win = self.tblWorkEntries) then	// dont allow drop from same table	PAR 7234
		return;
	endif;
	
	self.tblWLEDragDropEvent(table, win, x, y);
end;</source>
