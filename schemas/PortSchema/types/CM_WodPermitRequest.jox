    <PrimAttribute name="permitType" id="15090bc3-f840-4493-a795-222c9d8f7605">
        <embedded/>
        <type name="Integer"/>
        <access>readonly</access>
        <text>


INV_WO_PERMIT_MANUALETMAL = 1
INV_WO_PERMIT_CARGOPENALTY = 2
INV_WO_PERMIT_CARGONOPENALTY = 3
INV_WO_PERMIT_CONTINUNOPENALTY = 4
INV_WO_PERMIT_CONTINUEPENALTY = 5



</text>
