    <JadeMethod name="setForCreate" id="ee5532ee-eb7d-46c2-aaea-263c650d1f33">
        <updating/>
        <source>setForCreate(_proxyCamProtocol:CM_CamProtocol) updating;
// ---------------------------------------------------------------------------
// Created:     11 September 2002 by cnwdf1
//
// Purpose:
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	_proxyCamProtocol.raiseExceptionIfNotTransient(method);
	self.setForUpdate(_proxyCamProtocol);
	self.terminal := _proxyCamProtocol.terminal;
end;</source>
        <Parameter name="_proxyCamProtocol" type="CM_CamProtocol"/>
    </JadeMethod>
    <JadeMethod name="setForJMT831_Par34159" id="8213bb44-f046-4543-a57f-2c487c79c9ae">
        <updating/>
        <source>setForJMT831_Par34159() updating;
//
// 15 May 2014	cnwrs1	Par 34159 - include Chassis in Codeco
//
vars
	cc : ClassColl;
	cls : Class;
	tmpCargoType : CM_CargoType;
begin
	create cc transient;
	if self.allRegisteredCargoTypes	= null then
		create self.allRegisteredCargoTypes;
	endif;
	if self.allRegisteredCargoTypes.isEmpty then
		if self.protocolDesc.type = EDIFileTypeCams_Codeco then
			if not self.getIncludeChassis() then
				self.allRegisteredCargoTypes.add(TI_CargoType_Container);
				return;
			endif;
		endif;
		self.protocolDesc.availableCargoTypes(cc);
		if self.protocolDesc.type &lt;&gt; EDIFileTypeCams_UserDef and
		   self.protocolDesc.type &lt;&gt; EDIFileTypeCams_UserDefEvent then
			foreach cls in cc do
				//For each CM_TrackedItem type find all the cargotypes that craete this type of ti
				foreach tmpCargoType in app.myRoot.allCargoTypesById do
					if tmpCargoType.classNameToCreate = cls.name then
						if (not self.allRegisteredCargoTypes.includes(tmpCargoType.id)) then
							self.allRegisteredCargoTypes.add(tmpCargoType.id);
						endif;
					endif;
				endforeach;
			endforeach;
		endif;
	endif;
epilog
	delete cc;
end;
</source>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="5ecfc02c-ccd6-4447-b95d-ed4708e183d4">
        <updating/>
        <source>setForUpdate(_proxy : CM_CamProtocol) updating;
// ---------------------------------------------------------------------------
// Created:     11 September 2002 by cnwdf1
//
// Purpose:
//
// Parameters:  None
//
// Returns:     Nothing
//
/* Changes

Date		Name	TFS#			Description
============================================================================
18/05/2011	cnwcs5	CCMS SCT 2058 
					/ par 27460 	user defined special characters
20/09/2012	cnwcs5					Removed unused special fields from CM_CamProtocol
15 May 2014	cnwrs1	Par 34159 		include Chassis in Codeco
11 Jun 2014	cnwrs1	Par 34159 		include CargoType in cam protocol
30 Apr 2015	cnwrs1	Par35784 		increased exclusion reason logging to include non excluded
28 Jun 2016 cnwma1  TFS #2226 		POL - Update to VERMAS structure from Ship Operators
05 Oct 2016	cnwma1	TFS #2712 		CPL - Container Number in VERMAS DOC segment
12 Jul 2017	jlgrs1	TFS 4465 		SNO standard Codedo/Coarri
22 Aug 2017	jlgrs1	TFS 6560 		SNO Damaged/Repair
19 Sep 2017	jlgrs1	TFS 6957 		Codeco/Coarri VGM extra details
18 Dec 2017 jlgrh7	TFS 7781 		SNO - VERMAS with EDIFACT codes required
12 Nov 2018	jlgsl4	TFS 39345 		SNO - add LOC+7,LOC+PDS/LOC+11 to TDT+30
13 Mar 2019	jlgka1  TFS 41641		SSL - X12 322 Equipment ID Check.
19 Mar 2019	jlgsl4	TFS 41786 		SNO - output DAM segment for Standard Coarri/Codeco
24 Apr 2019 jlgka1	TFS 43785		STWR - CAMS STANDARD CODECO for Non-Structure Voyage.
28 May 2019 jlgsl4	TFS 43706		PEN - output Enhanced Genset segment details
25 Jun 2019 jlgka1	TFS 44737		PNL - Hapag Codeco on Weighing.
11 Mar 2020	jlgdap1	TFS 48785		SNO COARRI Issue
03 Feb 2021	jlgdap1	TFS 50726		GPHA CODECO Message to Differentiate Between Inter-Terminal Transfer and Delivery
29 Mar 2022	jlika1	TFS 53181		GPHA - Voyage Code Translation for Multiple Terminals and Co-Loaders
18 Jul 2022	jlizm1	TFS 54142		AAT - Add NAD+MS to Standard COARRI SMDG213
06 Dec 2022	navdap1	TFS 55159 		MTN - Export CAMS to JSON API Endpoint
26 Jul 2023	jlika1	TFS 55938		EUP Load Confirmation Message
============================================================================*/
vars
	port 				: CM_Port;
	tmpCargoType 		: CM_CargoType;
	cargoTypeCode 		: Integer;
	collClass 			: ClassColl;
	class 				: Class;
	availableCargoTypes : IntegerArray;
begin
	create collClass transient;
	create availableCargoTypes transient;
	if self.allRegisteredCargoTypes = null then
		create self.allRegisteredCargoTypes;
	endif;
	self.code 			:= _proxy.code;
	self.description 	:= _proxy.description;

	self.camGroup 		:= _proxy.camGroup;
	self.camISOPortDesc := _proxy.camISOPortDesc;
	self.myEmailEntity 	:= _proxy.myEmailEntity;
	self.myFTPEntity 	:= _proxy.myFTPEntity;	// CCMS 1143 cnwrs1 10 Aug 2010
	
	self.allCopyEmailEntities.clear();
	_proxy.allCopyEmailEntities.copy(self.allCopyEmailEntities);
	
	self.emailFileImbedded 	:= _proxy.emailFileImbedded;
	self.emailMessage 		:= _proxy.emailMessage;
	self.emailSubject 		:= _proxy.emailSubject;
	self.firstRunDateTime 	:= _proxy.firstRunDateTime;
	self.lastRunDateTime 	:= _proxy.lastRunDateTime;
	self.filePrefix 		:= _proxy.filePrefix;
	self.fileSuffix 		:= _proxy.fileSuffix;
	
	self.operatorXlationCode := _proxy.operatorXlationCode;
	
	self.packConsignor 				:= _proxy.packConsignor;
	self.protocolDesc 				:= _proxy.protocolDesc;
	self.sendMtFiles 				:= _proxy.sendMtFiles;
	self.sendType 					:= _proxy.EMAIL;
	self.useVoyageOperator 			:= _proxy.useVoyageOperator;
	self.useTiOperator 				:= _proxy.useTiOperator;
//AKB	self.includeNonPlannedVoyage 	:= _proxy.includeNonPlannedVoyage;
// AKB	self.includeNonWorkedVoyage		:= _proxy.includeNonWorkedVoyage;
	self.gateInForNullVoyageChange 	:= _proxy.gateInForNullVoyageChange;
	self.gateInForNullOperatorChange:= _proxy.gateInForNullOperatorChange  ;
	self.noSNTOnPackTrans 			:= _proxy.noSNTOnPackTrans;
	self.noRCVOnUnpackTrans 		:= _proxy.noRCVOnUnpackTrans;
	self.special_MSCForNZPOE 		:= _proxy.special_MSCForNZPOE;
	self.daysToLookBack 			:= _proxy.daysToLookBack;
	self.tempLeadingZerosNoDecimal 	:= _proxy.tempLeadingZerosNoDecimal;
	self.supressSealNumbers 		:= _proxy.supressSealNumbers;
	self.singleContainerPerBGM 		:= _proxy.singleContainerPerBGM;
	self.setSingleContainerPerUNB(_proxy.singleContainerPerUNB);	//10 Apr 2018	NDL	TFS 7556
	self.singleTransactionPerFile 	:= _proxy.singleTransactionPerFile;
	self.reprocessOnIdChange 		:= _proxy.reprocessOnIdChange;
	self.sendCancellationMessage 	:= _proxy.sendCancellationMessage;
	self.sendUpdateMessage 			:= _proxy.sendUpdateMessage;
	self.debug 						:= _proxy.debug;
	self.useContainerOperator_NAD_CF:= _proxy.useContainerOperator_NAD_CF; //par19423 cnwrs1 May 2009
	self.sendCarrier_RFF_CN 		:= _proxy.sendCarrier_RFF_CN;
	self.useCarrierForBooking 		:= _proxy.useCarrierForBooking;
	self.isIncludeChild				:= _proxy.isIncludeChild;	// cnwdad1 26/01/2010 - PAR #22199.
	self.specialFileName 			:= _proxy.specialFileName;
	self.noCrLfInMessage 			:= _proxy.noCrLfInMessage;
	self.status 					:= _proxy.status;
//ccms 1535
	self.terminalActivity 			:= _proxy.terminalActivity;
	self.depotActivity 				:= _proxy.depotActivity;
	self.useSubTerminals 			:= _proxy.useSubTerminals;
	self.packGateInFull 			:= _proxy.packGateInFull;
	self.packGateOutMT 				:= _proxy.packGateOutMT;
	self.unpackGateInMT 			:= _proxy.unpackGateInMT;
	self.unpackGateOutFull 			:= _proxy.unpackGateOutFull;
	self.delayMinutes				:= _proxy.delayMinutes;	//08 Sep 2015	NDL	Par 36876
	
	self.allPackAreas.clear();
	
	self.myConsignee 				:= _proxy.myConsignee;
	self.prcNullVoyageTransaction 	:= _proxy.prcNullVoyageTransaction;
	
	//ccms 1011
	self.isEmailEnabled				:= _proxy.isEmailEnabled;
	self.isSingleTransPerFile		:= _proxy.isSingleTransPerFile;
	self.isFileTransferEnabled		:= _proxy.isFileTransferEnabled;
	self.transferFileFormat			:= _proxy.transferFileFormat;
	self.transferFileRollOver		:= _proxy.transferFileRollOver;
	self.transferFileSeqLength		:= _proxy.transferFileSeqLength;
	self.transferFileStartSeq		:= _proxy.transferFileStartSeq;
	self.lastSequenceNumberUsed		:= _proxy.lastSequenceNumberUsed;
	self.destinationFilePath		:= _proxy.destinationFilePath;
	self.jrwReportName				:= _proxy.jrwReportName;
	self.myQFCamTransactionTemplate	:= _proxy.myQFCamTransactionTemplate;
	self.anyEditTriggerField		:= _proxy.anyEditTriggerField;
	
	self.decimalCharacter			:= _proxy.decimalCharacter;		// par 27460 cnwcs5
	self.elementSeparator			:= _proxy.elementSeparator;		// par 27460 cnwcs5
	self.escapeCharacter			:= _proxy.escapeCharacter;		// par 27460 cnwcs5
	self.segmentTerminator			:= _proxy.segmentTerminator;		// par 27460 cnwcs5
	self.subElementSeparator		:= _proxy.subElementSeparator;	// par 27460 cnwcs5
	
	self.x12UseClientRefAsBooking 	:= _proxy.x12UseClientRefAsBooking; //cnwrd1 par 35207
	
	self.changeCOARRIBGM 			:= _proxy.changeCOARRIBGM;			//cnwmc5 - 11 Feb 2016 - PAR 37503
	self.changeCOARRIBGM4446		:= _proxy.changeCOARRIBGM4446;		//27Jan2023 navsp1 TFS 56282
	
	self.allCoarriExportPorts.clear;
	self.allCopyEmailEntities.clear;
	self.packOperators.clear;
	self.packExportConsignees.clear;
	self.registeredTransactions.clear;
	self.allRegisteredCargoTypes.clear;
	self.scheduleTimes.clear;
	self.allEditTriggerFields.clear;
	self.allTrainEventTypes.clear;	// PAR 21905 CCMS MES 1008 - PHB
	
	foreach port in _proxy.allCoarriExportPorts do
		port.setMyCamProtocol(self);
	endforeach;
	
	_proxy.allCopyEmailEntities.copy(self.allCopyEmailEntities);
	_proxy.packOperators.copy(self.packOperators);
	_proxy.packExportConsignees.copy(self.packExportConsignees);
	_proxy.allPackAreas.copy(self.allPackAreas);
	_proxy.allEditTriggerFields.copy(self.allEditTriggerFields);
	_proxy.allTrainEventTypes.copy(self.allTrainEventTypes);		// PAR 21905 CCMS MES 1008 - PHB
	_proxy.registeredTransactions.copy(self.registeredTransactions);
	
	self.protocolDesc.availableCargoTypes(collClass);
	foreach class in collClass do
		//For each CM_TrackedItem type find all the cargotypes that craete this type of ti
		foreach tmpCargoType in app.myRoot.allCargoTypesById do
			if tmpCargoType.classNameToCreate = class.name then
				cargoTypeCode := tmpCargoType.id;
				if (not availableCargoTypes.includes(cargoTypeCode)) then
					availableCargoTypes.add(cargoTypeCode);
				endif;
			endif;
		endforeach;
	endforeach;
	foreach cargoTypeCode in _proxy.allRegisteredCargoTypes do
		if availableCargoTypes.includes(cargoTypeCode) then
			self.allRegisteredCargoTypes.add(cargoTypeCode);
		endif;
	endforeach;
//	_proxy.allRegisteredCargoTypes.copy(self.allRegisteredCargoTypes);
	_proxy.scheduleTimes.copy(self.scheduleTimes);
	
	self.scheduleTimes.cnEcSort(false); //par 12942 cnwrs1 nov 2006 code assumes this has been sorted
	self.setIncludeChassis(_proxy.getIncludeChassis());
	self.setVermasNAD(_proxy.getVermasNAD());     //28/06/2016 cnwma1 TFS #2226 
	self.setVermasDOC(_proxy.getVermasDOC());     // 05/10/2016 cnwma1 TFS #2712
	self.setVermasVer10(_proxy.getVermasVer10());																//+TFS7781
	self.setCoarri95BLocPDS(_proxy.getCoarri95BLocPDS()); // TFS 39345
	self.setLogExcludedTransactions(_proxy.getLogExcludedTransactions());
	self.setLogIncludedTransactions(_proxy.getLogIncludedTransactions());
	self.setPackUnpackStatusChange(_proxy.getPackUnpackStatusChange());
	self.setIncludeRestowShifter(_proxy.getIncludeRestowShifter());
	self.mySelector:=_proxy.mySelector;
	self.useVGM :=_proxy.useVGM; //epr TFS 1429 16/2/16 par 37551
	self.setDamageCodecoCode(_proxy.getDamageCodecoCode);
	self.setRepairCodecoCode(_proxy.getRepairCodecoCode);
	self.setIncludeExtraVGM(_proxy.getIncludeExtraVGM);
	self.setUseRelaxedIDChecking(_proxy.useRelaxedIdChecking); // jlgka1 TFS 41641
	self.setProduceDAMSegment(_proxy.getProduceDAMSegment()); // TFS 41786
	self.setUseCodecoForNonStrucVoy(_proxy.useCodecoForNonStrucVoyage); // jlgka1 TFS 43785
	self.setEnhancedGensetInfo(_proxy.getEnhancedGensetInfo()); // TFS 43706	
	self.setCodecoVGMBGMMessageCode(_proxy.getCodecoVGMBGMMessageCode()); //jlgka1 TFS 44737
	self.setTranshipImportsVoyageOp(_proxy.getTranshipImportsVoyageOp());		// TFS 48785
	self.setIncludeRFFBM162( _proxy.includeRFFBM162 );	//26 Jan 2021	NDL	TFS 50708
	self.setIncludeLOC7InterTerm(_proxy.getIncludeLOC7InterTerm);		// TFS 50726
	self.setIsCustomsProtocol(_proxy.getIsCustomsProtocol()); //jlika1 TFS 53181
	self.setIncludeNADMSCOARRISMDG213(_proxy.getIncludeNADMSCOARRISMDG213); // TFS 54142
	self.myExternalWebServiceDef := _proxy.myExternalWebServiceDef;			// TFS 55159
	self.messageGroupingOption := _proxy.messageGroupingOption;
	self.setDGSDetailsInGroup14(_proxy	.dgsDetailsInGroup14);	//JIRA-20814
epilog
	delete collClass;
	delete availableCargoTypes;
end;</source>
        <Parameter name="_proxy" type="CM_CamProtocol"/>
    </JadeMethod>
