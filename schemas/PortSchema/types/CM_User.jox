    <JadeMethod name="shouldAuditProperty" id="b58dd75a-2070-4406-a8d8-fa752e42611c">
        <source>shouldAuditProperty(_rootClass: Class; _property: Property): Boolean protected;

vars

begin
	if _property.name = null or
	   _property.name = CM_User::allSubSystemStateObjects.name or
	   _property.name = CM_User::colorBackgroundRT.name or
	   _property.name = CM_User::colorForegroundRT.name or
	   _property.name = CM_User::colorTableBackRT.name or
	   _property.name = CM_User::colorTableForeRT.name or
	   _property.name = CM_User::currentPassword.name or
	   //_property.name = CM_User::currentRTScreen.name or		// TFS 43007 - Remove Teklogix jlgmd1 21/01/2019
	   _property.name = CM_User::externApps.name or
	   _property.name = CM_User::isExternal.name or
	   _property.name = CM_User::isNewEncryptionImplemented.name or
	   _property.name = CM_User::isUseStrongPassword.name or
	   _property.name = CM_User::lastLoginTS.name or
	   _property.name = CM_User::myMenuRootBGRCurrent.name or
	   _property.name = CM_User::myMenuRootBGRSaved.name or
	   _property.name = CM_User::myMenuRootBGRTemplate.name or
	   _property.name = CM_User::myMenuRootForSysEntities.name or
	   _property.name = CM_User::myMenuUserToolbarRoot.name or
	   _property.name = CM_User::myOrganisation.name or
	   _property.name = CM_User::mySystemSecurityRole.name or
	   _property.name = CM_User::numberOfFailedLogons.name or
	   _property.name = CM_User::radioTelemetryDevice.name or
	   _property.name = CM_User::screenLayouts.name 
	   then
		return false;
	else
		return inheritMethod(_rootClass, _property);
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="_rootClass" type="Class"/>
        <Parameter name="_property" type="Property"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="updateMenuUserDtlsOnExit" id="5e9ba9a8-ef57-43b8-916c-ddf98684dc5a">
        <source>updateMenuUserDtlsOnExit(_userWinSet : CM_UserWindowForStartupSet);

vars
	tmpUserWin,
	pxyUserWin,
	realUserWin	: CM_UserWindowForStartup;
	
begin

	self.allUserWindowsForStartup.purge();
	
	//if _userWinSet = null then
	if _userWinSet = null or self.isSuperUser then //09 Jun 2016 NDL 
		return;
	endif;
	
	foreach pxyUserWin in _userWinSet do : mainLoop

		//par15695
		foreach tmpUserWin in self.allUserWindowsForStartup do
			if tmpUserWin.isSameAs(pxyUserWin) then
				// exact same window being saved so do not save.  
				// (refer to comment on CM_UserWindow::isSameAs)
				continue mainLoop;
			endif;
		endforeach;

		create realUserWin persistent;
		realUserWin.setForCreate(pxyUserWin, self);
	endforeach;
	
end;</source>
        <Parameter name="_userWinSet" type="CM_UserWindowForStartupSet"/>
    </JadeMethod>
    <JadeMethod name="updateNumberLogonAttempts" id="265194c2-2a11-44cf-8080-77c81417ef96">
        <updating/>
        <source>updateNumberLogonAttempts(_value : Integer) updating;
// ---------------------------------------------------------------------------
// Created:			06 April 2001 by cnwdwq1
// Purpose:			!     
// Parameters:	None
// Returns:			Nothing
// Changed On	Changed By		Reason
// ----------			----------			--------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	numAttempts : Integer;
begin
	// This method should be used only to update persistents
	self.raiseExceptionIfTransient(method);

	numAttempts := app.myRoot.getConfig(MaxPasswordAttempts).Integer;
	if numAttempts = 0 then
		numAttempts := 3;	//3 is the system default if config not set to another value.
		//Removed this 22/5/01
		//app.getMyTerminal().createStringAlert(SEVERE_WARNING, "Max Passwords not set", "Configuration does not have the maximum # of passwords, defaulting to 3");
	endif;
	// Lock self before comparing values to ensure we have the latest edition.
	// We assume that we're called within a transaction, so the lock will be
	// released at commit/abort transaction.
	exclusiveLock(self);
	if self.numberOfFailedLogons &lt;&gt; _value then
		app.myAA.auditUpdate(self, CM_User::numberOfFailedLogons.name, self.numberOfFailedLogons);
		self.numberOfFailedLogons := _value;
	endif;
//	if self.numberOfFailedLogons &gt; numAttempts and self.code &lt;&gt; "SUPERUSER" then
	if self.numberOfFailedLogons &gt;= numAttempts and self.code &lt;&gt; SUPERUSER_Str then
		self.updateStatus(SuspendedBadPasswordsUser);
	endif;
	
	// CCMS 1051
	// // DVB changed 20/11/06
	self.lastLoginTS := app.serverTimestampAtTrxStart;

end;</source>
        <Parameter name="_value" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="updatePreferences" id="b6ea3f3d-89fc-4fec-b783-19258a815bef">
        <updating/>
        <source>updatePreferences(_cmif : CMIF_UserPreference) updating;
// ---------------------------------------------------------------------------
// Created:     cnwyl1  Yi Liu
//
// Purpose:     
// ---------------------------------------------------------------------------
/*

Date		Who		Reason
26 May 2014	cnwkpd1	PAR #34210 - CCMS SFW 1350 - Online Documentation
	
*/

begin
	self.setLocale(_cmif.myLocale);
	self.setAcknowledgeTodoStop(_cmif.ackTodoStop);
	self.setUseAppSkins(_cmif.appSkin);
	self.setPartialTextIndication(_cmif.isUsePartialTxt);
	self.setHelpFileBaseURL(_cmif.helpFileBaseURL);		// PAR #34210
	self.setHelpFileFormat(_cmif.helpFileFormat);
	self.setRememberSSOSession(_cmif.ssoRememberSession); //21.09.2022 navam1 #54866
	
	self.causeEvent(EVENT_USERPRE_UPDATE, false, null);	
end;</source>
        <Parameter name="_cmif" type="CMIF_UserPreference"/>
    </JadeMethod>
    <JadeMethod name="updateStatus" id="cec2270e-6fce-439f-aea1-8e41cf8afb8c">
        <updating/>
        <source>updateStatus(_value : Integer) updating;
// ---------------------------------------------------------------------------
// Created:			06 April 2001 by cnwdwq1
