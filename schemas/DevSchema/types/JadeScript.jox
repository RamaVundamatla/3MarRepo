    <JadeMethod name="jreTestDebtorExtract" id="0149fad8-9af0-46ad-ac8d-1c9bb5b38e87">
        <source>jreTestDebtorExtract();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
19 April 2012	cnwjre1	Initial creation

*/

vars
	ela		: CM_ExtractLoadAgent;
	file	: File;
begin
	app.initialize();
	
	create ela transient;
	create file transient;
	file.usePresentationFileSystem := true;
	file.allowReplace := true;
	file.openOutput("c:\temp\debtors.xml");
	ela.extractDebtors(file);
epilog
	delete ela;
	if file &lt;&gt; null then
		if file.isOpen() then
			file.close();
		endif;
		delete file;
	endif;
end;</source>
    </JadeMethod>
