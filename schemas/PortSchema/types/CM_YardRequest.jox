    <JadeMethod name="createWLEs" id="be31561d-a16e-4eb6-ac19-35174e64a8b3">
        <source>createWLEs();
//
// 10/11/2010	cnwdap1		PAR #23794 Create TBA tracked items for each WLE on rail jobs
// 30/11/2010	cnwdap1		PAR #26426 CCMS MES 1102 new _transient parameter for createPlanningTrackedItem method
// 06/09/2013	cnwer1		PAR 32408
// 26/6/2014 	cnwer1		PAR 34406
// 02/06/2023 	navma1  	ChangeRequest 58296: EUP - [Framework] Delivery Dispatch Screen - Linking Road Jobs
// 06/06/2023   navma1 		ChangeRequest 58339: EUP | Delivery Dispatch Screen - Road Operation
// 12/09/2024	navpw1		TFS: 65623 (65624) - Added code to create a new wowle if it is required for Any ID Any Amount.
//													If its a cargo type that does not allow duplicates then don't create one as all wles are created upfront.
// 25 Oct 2024 	navhl20 	Bug 33146: EUP | Release cargo workorder completing early when split across multiple Vehicle Bookings
// 11/11/2024	navpw1		JIRA: MTN-33361 - Refactored code and moved it into a seperate method
vars
	newWLEQuantity				: Integer;
	newWLEWeight,
	i ,
	collStart,
	collSize ,
	totalRequested				: Decimal[14,4];
	ti							: CM_TrackedItem;
	isBulkMultiReleaseByType	: Boolean;
	term						: CM_Terminal;
	showRelReqOnRailLoad		: Boolean;
	request						: CM_Request;
	wle							: CM_WorkListEntry;
begin
	if self.myJob = null then
		return;
	endif;
	
	if not CM_YardJob.hasInstance(self.myJob) then
		return;
	endif;

	collStart := 0;
	//epr par 34296 13/6/14
	isBulkMultiReleaseByType:=self.isBulkMultiReleaseByType;
	
	if isBulkMultiReleaseByType then
		collSize 	   := self.getWLEWeight();
		totalRequested := self.weightRequested;
	else
		
		collSize	   := self.getWLEQuantity();
		totalRequested := self.getTotalRequested();
	endif;
	
	
	if collSize &gt; 0 then
		if totalRequested = collSize then
			return;
		else
			if (collSize &gt; totalRequested) then
				if isBulkMultiReleaseByType then
					return;
				endif;
				app.setContinueCMExceptions(false);
				app.raiseCMException(ERR_HAS_WL_ENTRIES, null, null);
				return;				
			endif;
			collStart := collSize;
		endif;
	endif;

	ti 	 := self.getTrackedItem();
	term := self.myTerminal;																	//02.06.2023 navma1 #58296
	
	//OK, we have the request Struct, depending on what it is, produce wl entries.
	if ti = null then
		i 						:= collStart;
		showRelReqOnRailLoad	:= term.getConfig(ShowRelReqOnRailLoadList).Boolean;			//02.06.2023 navma1 #58296
		
		while (i &lt; totalRequested) do
			// PAR #23794 if this is for a Rail Job, create a TBA tracked item for each WLE
			if showRelReqOnRailLoad then														//02.06.2023 navma1 #58296
				if CM_RailJob.hasInstance(self.myJob) and self.myReserveDetail &lt;&gt; null then
					ti := self.myReserveDetail.createPlanningTrackedItem(null, null, false);	// PAR #26426
				endif;
			endif;
			// PAR #23794 end
			
			//epr par 34296 13/6/14
			if isBulkMultiReleaseByType then
				newWLEWeight := self.weightRequested - self.getWLEWeight();
				if ti &lt;&gt; null then
					ti.setTotalWeightWithoutTrans( newWLEWeight );								//24 Feb 2017	NDL	TFS 3514
				endif;
			else
				newWLEQuantity := totalRequested.Integer - self.getWLEQuantity();
				if ti &lt;&gt; null then
					if self.isBreakBulkReleaseByType then										//18 May 2018	NDL	TFS 38664
						ti.setTotalQuantity( newWLEQuantity );									//24 Feb 2017	NDL	TFS 3514
					else
						ti.setTotalQuantity( 1 );												//18 May 2018	NDL	TFS 38664
					endif;
				endif;
			endif;
			wle := self.createYardWLE(self, WLE_UNACTIONED, ti);
			
			//epr par 32408
			if self.isBreakBulkReleaseByType then
				wle.setQuantity(newWLEQuantity);
			endif;
			
			if isBulkMultiReleaseByType then
				wle.setWeight(newWLEWeight);
			endif;
			
			//epr par 30221 10/10/12 always send note - by not sending this was causing issue on road ops form
			app.myEventManager.createSingleObjInfoNoteEvt(wle, term.getTerminalEvent(WLE_Update_Event), wle);		//02.06.2023 navma1 #58296
		
			if isBulkMultiReleaseByType then
				i:= i + wle.weight;
			else
				i := i + wle.quantity.max(1);
			endif;
		endwhile; //wle
	else
		wle := self.createYardWLE(self, WLE_UNACTIONED, ti);
	endif;
	
	/*
	//02.06.2023 navma1 #58296
	///////////////////////////////////
	Link /Create Work Order Jobs &amp; Wle
	//////////////////////////////////
	*/
	if wle &lt;&gt; null and self.canLinkWorkOrderJobs(wle) then
		// ### TFS 65623 (65624) 06Sep2024 NAVPW1
		request := self.myJob.allRequests.first;
		self.doCreateAndLinkWoWle(request, wle, ti);
		
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="createWorkOrderWLE" id="131f5cde-0338-41df-b2d3-cc464b557229">
        <source>createWorkOrderWLE(_request : CM_Request; _wle : CM_WorkListEntry; _ti : CM_TrackedItem) : CM_WOWLE protected;
/*

Purpose:			

Parameters:			_request	CM_Request			
					_wle		CM_WorkListEntry	
					_ti			CM_TrackedItem		

Return Value:		CM_WOWLE	Returns the new Work Order Wle

Date				Who		Reason
06 September 2024	navpw1	Initial creation TFS: 65623 (65624)
*/

vars
	originalWowle,
	woWle			: CM_WOWLE;
	
begin
	//Get Work Order Wle from DeliveryRequest.
	
	if _request.allWorkListEntries.first.myWorkOrderWLE = null then
		return null;
	endif;
	
	originalWowle := _request.allWorkListEntries.first.myWorkOrderWLE;
	
	woWle := originalWowle.myRequest.CM_WOReleaseCargoRequest.createWLE().CM_WOWLE;
	woWle.setQuantity(_wle.quantity);
	
	// ### JIRA: MTN-33630 17Jan2025 NAVPW1
	if _ti &lt;&gt; null then
		woWle.job.updateTICollections(_ti, null);
	endif;
	// ### JIRA: MTN-33630 17Jan2025 NAVPW1
	
	return woWle;
	
end;</source>
        <access>protected</access>
        <Parameter name="_request" type="CM_Request"/>
        <Parameter name="_wle" type="CM_WorkListEntry"/>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <ReturnType type="CM_WOWLE"/>
    </JadeMethod>
    <JadeMethod name="createYardWLE" id="9fdba609-29f0-4c7d-bbf1-99a1bf8d9b56">
        <source>createYardWLE(_request : CM_Request; _status : Integer; _ti : CM_TrackedItem) : CM_WorkListEntry;
//
// Changed On	By			Reason
// ----------	--------	------------------------------------------------------------------
// 22/02/2018	jlgdap1		TFS 37198 NXL Unable to Plan Prenote Containers to Rail
vars
	wle : CM_YardWLE;
	pin : CM_PinNo;
begin

	create wle;
	wle.setForCreate(self.myJob, _request);

	if _ti = null then 
		return wle;
	endif;
	
	if  _ti.isGhost then
		wle.ghostTrackedItem := _ti;
	else
		wle.assignTIandBOL(_ti, null);
	endif;

	//31 March 2011	#cnwdz2	 par27146 start
	pin := _ti.myPinNo;
	//if pin &lt;&gt; null then								// TFS 37198
	if pin &lt;&gt; null and not _ti.isNotified then			// TFS 37198
		pin.updateStatus(PIN_InProcess);
	endif;
	
	
	return wle;

end;</source>
        <Parameter name="_request" type="CM_Request"/>
        <Parameter name="_status" type="Integer"/>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <ReturnType type="CM_WorkListEntry"/>
    </JadeMethod>
    <JadeMethod name="doCreateAndLinkWoWle" id="35f549bb-9ec0-4419-a6a7-1cc0469b92b1">
        <source>doCreateAndLinkWoWle(_request : CM_Request; _wle : CM_WorkListEntry; _ti : CM_TrackedItem);
/*

Purpose:			Links WLE to a Work Order WLE and creates a new one if it needs to for loading

Parameters:			_request	CM_Request			The request to use in case a new wowle needs to be created
					_wle		CM_WorkListEntry	The wle that needs to be linked to a work order wle
					_ti			CM_TrackedItem		The tracked item that is linked to the wle and used for the new wowle if it needs to be created

Return Value:		NONE

Date				Who		Reason
30 Oct 2024			navhl20 Bug 33146: EUP | Release cargo workorder completing early when split across multiple Vehicle Bookings
05 Nov 2024			navhl20 Bug MTN-33232: EUP - Start End Times for Road and Rail jobs
11 Nov 2024			navpw1	Initial creation JIRA: MTN-33361
18 Dec 2024			navhl20 Bug MTN-33681: MTN - Unexpected Program error on the Road Gate form
06 Mar 2025 		navma1 MTN-34179 MTN | Dead Lock (1081) on CM_WLEArray
*/

vars
	doSplit,
	doLink			: Boolean;
	ti				: CM_TrackedItem;
	ct				: CM_CargoType;
	woWle,
	woWleFirst,
	wleFirst		: CM_WorkListEntry;
	wod				: CM_WorkOrderDtl;
	woRequest		: CM_Request;
	woJob,
	job				: CM_Job;
	isReleaseJob    : Boolean;
begin
	ti := _ti;
	
	ct := self.getCargoType;
	
	if ct &lt;&gt; null and ct.allowDuplicates and self.canCreateWorkOrderWLE(_request, _wle) then
		self.createWorkOrderWLE(_request, _wle, ti);
	endif;
	
	if self.myJob.isRoadJob then
		isReleaseJob := self.myJob.isRelease;						//06.03.2025 navma1 #MTN-34179
		// ### TFS 65623 (65624) 06Sep2024 NAVPW1
		if isReleaseJob and self.isDeliveryRequest then				//18.12.2024 navhl20 #33681
			job 	 := _wle.job;
			wleFirst := job.getIncompleteWleTi();
			
			if wleFirst &lt;&gt; null then
				doLink := true;
			endif;
		endif;
		
		if not doLink or not isReleaseJob then						//18.12.2024 navhl20 #33681	//06.03.2025 navma1 #MTN-34179
			self.doLinkWorkOrderJob(_wle);
		endif;
	else
		self.doLinkWorkOrderJob(_wle);
	endif;
	
	woWle := _wle.myWorkOrderWLE;
	
	// ### TFS 65623 (65624) 26Sep2024 NAVPW1
	//Non Duplicate cargo work order wles are created when the work order release cargo request is created therefore it only creates x amount of these. So if you request 5 you will get 5.
	//The problem is that there is a placeholder wle assigned to one of these 5. Therefore you only have 4 to assign a yard wle to.
	//Therefore once these are used we will need a new one created. Hence the case below.
	if woWle = null and ct &lt;&gt; null and not ct.allowDuplicates then
		woWle := self.createWorkOrderWLE(_request, _wle, ti);
		self.doLinkWorkOrderJob(_wle);
	endif;
	
	// ### TFS 65623 (65624) 26Sep2024 NAVPW1
	
	woWle := _wle.myWorkOrderWLE;
	
	//if there is no matching WLE
	//06.06.2023 navma1 #58339
	//if wle.myWorkOrderWLE = null  and ti = null then																	//15.08.2023 navma1 #59218
	if woWle = null then
		if ti = null then
			doSplit := true;
		else
			if ti.isTBAorIsRRP then
				doSplit := true;
			endif;
		endif;
		if doSplit then
			if  self.isDeliveryRequest then
				if self.myReserveDetail &lt;&gt; null then
					wod := self.myReserveDetail.allWodReleases.first;
				endif;
				if wod &lt;&gt; null and wod.isKindOf(CM_WodRelease) then
					woJob := wod.CM_WodRelease.allJobs.first;
					if woJob &lt;&gt; null then
						woRequest := woJob.allRequests.first;
						if woRequest &lt;&gt; null and woRequest.isKindOf(CM_WOReleaseCargoRequest) then
							if self.myJob.isRoadJob then													//05.11.2024 navhl20 #33232
								//Only if road job get first linked yard wle with wo wle 
								woWleFirst := woJob.getFirstLinkedWle();
								if woWleFirst = null then
									//If nothing got linked taking first wle
									woWleFirst := woJob.getFirstWle();
								endif;
								job := _wle.job;
								if job &lt;&gt; null then
									//Get first trackeditem in job
									ti := job.getFirstTi(true);
									//First in complete wle but trackeditem assigned
									wleFirst := job.getIncompleteWleTi();
								endif;
								if ti = null then
									//When doing road gate first wle quantity is not same as requested then it will go inside if otherwise will go inside else
									if woWleFirst.quantity &lt;&gt; self.getTotalRequested then
										woWle := woRequest.CM_WOReleaseCargoRequest.createSplittedWle(_wle.quantity,_wle.weight);
										woWle.CM_WOWLE.setMyOperationalWLE(_wle);
									else
										woWleFirst.CM_WOWLE.setMyOperationalWLE(_wle);
									endif;
								else
									//When doing load operation
									woWle := woRequest.CM_WOReleaseCargoRequest.createSplittedWle(ti.totalQuantity,ti.totalWeight);
									woWleFirst.CM_WOWLE.setMyOperationalWLE(null);
								endif;
								
								//After creating new wle updating old wle quantity
								if woWleFirst &lt;&gt; null and woWle &lt;&gt; null then
									woWleFirst.setQuantity(woWleFirst.quantity - woWle.quantity);
									if _wle.myWorkOrderWLE = null then
										woWleFirst.CM_WOWLE.setMyOperationalWLE(_wle);
									endif;
								endif;
								
								//First incomplete wle with trackeditem is availble then will go and do link with that or else will go with new wle
								if wleFirst &lt;&gt; null then
									self.doLinkWorkOrderJob(wleFirst);
								else
									self.doLinkWorkOrderJob(_wle);
								endif;
							else
								//For rail
								woWle := woRequest.CM_WOReleaseCargoRequest.createSplittedWle(_wle.quantity,_wle.weight);
								self.doLinkWorkOrderJob(_wle);
							endif;
						endif;
					endif;
				endif;
			endif;
		endif;
	endif;
	
end;</source>
        <Parameter name="_request" type="CM_Request"/>
        <Parameter name="_wle" type="CM_WorkListEntry"/>
        <Parameter name="_ti" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="doUpdateAuditing" id="0c7858a9-d97b-4eb1-a509-d2048ded4600">
        <source>doUpdateAuditing(pBulkRelease : CM_BulkRelease; pProxyRequest : CM_YardRequest);
// ---------------------------------------------------------------------------
// Created:     23 February 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	if self.consignee &lt;&gt; pProxyRequest.consignee then
		app.myAA.auditUpdate(pBulkRelease, "consignee", self.consignee);
	endif;

	if self.consignorVoyageCode &lt;&gt; pProxyRequest.consignorVoyageCode then
		app.myAA.auditUpdate(pBulkRelease, "consignorVoyageCode", self.consignorVoyageCode);
	endif;

	if self.needCOU &lt;&gt; pProxyRequest.needCOU then
		app.myAA.auditUpdate(pBulkRelease, "needCOU", self.needCOU);
	endif;

	if self.needGenerator &lt;&gt; pProxyRequest.needGenerator then
		app.myAA.auditUpdate(pBulkRelease, "needGenerator", self.needGenerator);
	endif;

	if self.reasonCodeDescr &lt;&gt; pProxyRequest.reasonCodeDescr then
		app.myAA.auditUpdate(pBulkRelease, "reasonCodeDescr", self.reasonCodeDescr);
	endif;

	if self.remarks &lt;&gt; pProxyRequest.remarks then
		app.myAA.auditUpdate(pBulkRelease, "remarks", self.remarks);
	endif;

	if self.removeStops &lt;&gt; pProxyRequest.removeStops then
		app.myAA.auditUpdate(pBulkRelease, "removeStops", self.removeStops);
	endif;

end;</source>
        <Parameter name="pBulkRelease" type="CM_BulkRelease"/>
        <Parameter name="pProxyRequest" type="CM_YardRequest"/>
    </JadeMethod>
    <JadeMethod name="doorsDirectionString" id="1551c98b-c52b-47cc-864e-b7a99f7fea6b">
        <source>doorsDirectionString() : String;
//AA 29/3/01: For use in message strings etc.
vars

begin
	if doorsDirection = TI_DOORSDIRN_FWD then
		return "Forward";
	elseif doorsDirection = TI_DOORSDIRN_AFT then
		return "Aft";
	else
		return "Any";
	endif;	
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="doorsForward" id="cd0c6e2f-4aac-4d97-92b0-3e483e140c3d">
        <methodInvocation>mapping</methodInvocation>
        <updating/>
        <source>doorsForward(set: Boolean; _value: Boolean io) mapping, updating;
/* Now a virtual property. We use doorsDirection to store the direction of
the doors. This is left in to provide backward compatability with legacy code
AA 29/3/01
*/
vars
	ti : CM_TrackedItem;
begin
	if set then
		//epr par 31704 11/6/13
		ti:= self.getTrackedItem ;
		if ti &lt;&gt; null and not ti.isContainer then
			self.doorsDirection:=TI_DOORSDIRN_NULL;
		else
			//Mimics the old bi-state property. Ignore null doors possibility
			if _value = true then
				self.doorsDirection := TI_DOORSDIRN_FWD;
			else
				self.doorsDirection := TI_DOORSDIRN_AFT;
			endif; 		
		endif;
		
		
	else
		_value := false;
		if self.doorsDirection = TI_DOORSDIRN_FWD then
			_value := true;
		endif;
	endif;
end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="Boolean" usage="io"/>
    </JadeMethod>
    <JadeMethod name="erase" id="b59ea652-41ea-498a-a81a-324d81cf901e">
        <updating/>
        <source>erase(_eraseLevel: Integer) updating;

vars
	wle : CM_WorkListEntry;
begin
	exclusiveLock(self);

	foreach wle in self.allWorkListEntries do
		wle.erase(_eraseLevel);
	endforeach;
	
	//Par 8380 - reduce the number requested
	//epr 11/9/17 TFS 6723 deleted reference to method that did nothing
	

	inheritMethod(_eraseLevel);

end;</source>
        <Parameter name="_eraseLevel" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getBOL" id="ebc5c214-0cee-45c8-aac7-f19e5d487cb0">
        <source>getBOL(): CM_BOLIn;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 Oct 2025	navlw1	JIRA-35699:STWO - Missing Key Details in OM_DriverDetails2-NF Report when released by Any Id/amount

*/

vars
	voyage : CM_Voyage;
begin
	voyage := self.getVoyage;
	if voyage = null then
		return null;
	endif;
	if self.myOriginatingBulkRelease &lt;&gt; null and self.myOriginatingBulkRelease.myVoyage &lt;&gt; null and self.myOriginatingBulkRelease.myBOLIn &lt;&gt; null then
		return voyage.getBOL(self.myOriginatingBulkRelease.myBOLIn.number);
	endif;
	return null;
epilog

end;</source>
        <ReturnType type="CM_BOLIn"/>
    </JadeMethod>
    <JadeMethod name="getConsignee" id="a3a01b8f-21b9-45eb-82bd-dfed719bfb07">
        <source>getConsignee(): CM_ConsigneeConsignor;

// Created by cnwdvb1 on 12 September 2006
// 22 Nov 2024 navma1 MTN-33459 STWO - Missing Consignee Details when Released by any ID in Road operations
vars

begin
	
	if self.consignee = null then   //22.11.2024 navma1 #MTN-33459
		return null;
	endif;
	
	return app.myRoot.allConsigneeConsignors[self.consignee];

end;</source>
        <ReturnType type="CM_ConsigneeConsignor"/>
