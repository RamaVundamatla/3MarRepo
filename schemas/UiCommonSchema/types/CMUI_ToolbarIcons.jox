    <JadeMethod name="btnUpdateDisFromIcon2002_click" id="cae55d11-9d67-4a69-98bb-ab96132fabfd">
        <controlMethod name="CMUI_Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnUpdateDisFromIcon2002_click(btn: Button input) updating;
/*
Purpose:			

Date		Who		Reason
13 August 2021	navab1	TFS 50669
*/

vars
	button : CMUI_ToolbarIcon;
	icon : CMUI_IconFile;
	idx : Integer;
begin

//	self.tblData.allSelectedObjects.inspectModal;
	
	icon := self.cmbIconFiles2002.listObject.CMUI_IconFile;
	
	foreach button in self.tblData.allSelectedObjects as CMUI_ToolbarIcon do
	
			beginTransaction;
				if icon &lt;&gt; null then
					button.disabledIconNameDisk := icon.name;
					button.myDisabledIconFile := icon;
				else
					button.disabledIconNameDisk := null;
					button.myDisabledIconFile := null;
				
				endif;
//				button.enabledIconNameDisk := icon.name;
	//			button.myEnabledIconFile := icon;
			commitTransaction;
	
		// ### DISABLED KEY
		if button.myDisabledIconFile &lt;&gt; null then
			self.tblData.findObjectInRow(button,idx);
			self.tblData.accessCell(idx,10).picture := button.myDisabledIconFile.icon;
			self.tblData.accessCell(idx,1).text := button.myDisabledIconFile.name;
		endif;
	
	endforeach;
	
	self.tblData.deselectAll();
epilog

end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="btnUpdateDisFromIcon2021_click" id="5527908d-8782-4351-a7d5-24c544262be7">
