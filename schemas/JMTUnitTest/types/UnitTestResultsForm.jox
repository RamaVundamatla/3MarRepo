    <JadeMethod name="mnuAssignJira_click" id="b89da963-90a9-4b76-957b-b3f59e0ea956">
        <controlMethod name="MenuItem::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>mnuAssignJira_click(menuItem: MenuItem input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 Oct 2025	navbs1	Initial creation Story MTN-34979: MTN - Unit Test Results App - Add Jira Item Column - Phase2

*/

vars
	
	schema 		: Schema;
	form 		: Form;
	class 		: Class;
	mth			: Method;
	jiraItem 	: String;
	row 		: Integer;
	selectedResult  : UM_UnitTestResult;
	errorText,defaultValue   : String;
	modalStatus 			:  Integer;
	
begin
	row := self.tblResults.accessedRow.row;
	selectedResult := self.tblResults.accessRow(row).itemObject.UM_UnitTestResult;
	class := JMTUnitTest.getClass(selectedResult.myClassMethod.className);
	mth := class.getMethod(selectedResult.myClassMethod.methodName);
	
	if mth.text &lt;&gt; null then 
		defaultValue := mth.text;
	else
		defaultValue := "MTN-XXXXX";
	endif;
	
	while true do
		self.getUserInputJiraItem("Enter Jira Item", errorText, defaultValue, jiraItem, modalStatus);
		if modalStatus = Form.CNEC_MODAL_CANCEL then 
			return;
		endif;
		
		if jiraItem &lt;&gt; null and not jiraItem.startsWith("MTN-") then
			errorText := "Jira Number should start with 'MTN-'";
			defaultValue := jiraItem;
		else
			break;		
		endif;
		
	endwhile;

	self.updateJiraItem(mth, jiraItem, selectedResult);

	self.tblResults.accessCell(row,10).text := mth.text;
	
epilog
	app.mousePointer := Idle;
end;</source>
        <Parameter name="menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
