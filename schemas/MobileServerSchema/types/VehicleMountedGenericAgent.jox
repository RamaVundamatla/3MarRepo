    <JadeMethod name="canDisplayDirectorTasks" id="a5d8dd4a-cd1e-44f8-b30e-91d7846d974a">
        <updating/>
        <source>canDisplayDirectorTasks(): Boolean protected, updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
23 April 2010	cnwer1	Initial creation

*/

vars

begin
	if self.isIMV then
		return false;
	endif;
	
	/* cnwjo3 par 26296.  Want to display items in the table even if machine does not do seperate pickup and setdowns.
	
	if not self.doesSeperatePickupSetdown then
		return false;
	endif;
	*/
	
	return true;
epilog

end;</source>
