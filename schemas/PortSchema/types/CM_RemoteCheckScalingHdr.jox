<Class name="CM_RemoteCheckScalingHdr" id="6f76648a-3fd5-4f1d-a554-af51cb1f4e9d">
    <superclass name="CM_RemoteDataHdr"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>&lt;display&gt;Check Scaling&lt;/display&gt;</text>
    <DbClassMap file="remoteDataProcessing"/>
    <JadeMethod name="getDescription" id="75989af3-c045-4715-9d1f-ef5476a4cec1">
        <source>getDescription(): String;

// cnwdvb1 07 April 2003 

vars

begin
	return 'Check Scaling';

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getMessageResponseType" id="2f38b414-6cee-4662-ac43-9aa669ee7e7f">
