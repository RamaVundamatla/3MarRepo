        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="setComboValues" id="f5a0919c-d0b6-471a-aeb3-81fe51602c9c">
        <source>setComboValues(_combo: ComboBox input; _params: CM_QueryCriteriaLineHolder; _queryOperator: CM_QueryOperator; _passport: CM_Passport);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 October 2019	jlgndl1	Initial creation	TFS 47198

*/

vars

	serviceGrpObjSet : ObjectSet;
	obj : Object;
	serviceGrp : CM_ServiceGroup;
	qrl : CM_QReferenceLookup;
	edition : Integer;
	invalidObj : Boolean;

begin
	
	_combo.clear();

	//We get services in play based on the banks in play.
	create serviceGrpObjSet  transient;
	self.getServiceGroupsInPlay( _params, serviceGrpObjSet );
	
	if serviceGrpObjSet.isEmpty then
		//nothing to do
		return;
	endif;
	
	//so populate the services based on the banks found
	foreach obj in serviceGrpObjSet do
		serviceGrp := obj.CM_ServiceGroup;
		_combo.itemObject[ _combo.addItem( self.translateToDisplayValue(serviceGrp).String ) ] := serviceGrp;
	endforeach;
	
	//now set the value in the combo
	if CM_QReferenceLookup.hasInstance(_queryOperator) then
		qrl := _queryOperator.CM_QReferenceLookup;
		on Exception do app.handleDeletedObject( exception, qrl.mySelectionValue, invalidObj );
		if qrl.mySelectionValue &lt;&gt; null then
			edition := qrl.mySelectionValue.edition;
			if not invalidObj then
				if _combo.findObject(qrl.mySelectionValue) &gt; 0 then
					_combo.listObject := qrl.mySelectionValue;
				endif;
			endif;
		endif;
	endif;

epilog

	delete serviceGrpObjSet;

end;</source>
        <Parameter name="_combo" type="ComboBox" usage="input"/>
        <Parameter name="_params" type="CM_QueryCriteriaLineHolder"/>
        <Parameter name="_queryOperator" type="CM_QueryOperator"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="setListValues" id="0a0d60f4-6b56-44ae-b38f-b282a000c92a">
        <source>setListValues(_tbl: Table input; _params: CM_QueryCriteriaLineHolder; _operator: CM_QReferenceIsOneOf; _passport: CM_Passport);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 October 2019	jlgndl1	Initial creation	TFS 47198

*/

vars

	serviceGrpObjSet : ObjectSet;
	obj : Object;
	serviceGroup : CM_ServiceGroup;
	selectionValue : Integer;
	idx : Integer;

begin

	_tbl.clear;
	_tbl.rows := 0;
	_tbl.sortColumn[1] := 2;
	
	//We get services in play based on the banks in play.
	create serviceGrpObjSet  transient;
	self.getServiceGroupsInPlay( _params, serviceGrpObjSet );
	
	if serviceGrpObjSet.isEmpty then
		//nothing to do
		return;
	endif;
	
	//so populate the services based on the banks found
	foreach obj in serviceGrpObjSet do
		serviceGroup := obj.CM_ServiceGroup;
		selectionValue := 0;
		if _operator &lt;&gt; null and _operator.allSelectionValues.includes(serviceGroup) then
			selectionValue := 1;
		endif;
		idx := _tbl.addItem( selectionValue.String &amp; Tab &amp; self.translateToDisplayValue(serviceGroup).String );
		_tbl.accessRow(idx).itemObject := serviceGroup;
		_tbl.row := idx;
		_tbl.change(_tbl);
	endforeach;

epilog

	delete serviceGrpObjSet;

end;</source>
        <Parameter name="_tbl" type="Table" usage="input"/>
        <Parameter name="_params" type="CM_QueryCriteriaLineHolder"/>
        <Parameter name="_operator" type="CM_QReferenceIsOneOf"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="translateToDisplayValue" id="a705a5fa-b8bb-496c-8132-2502c0996eca">
        <source>translateToDisplayValue(_value: Any): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 October 2019	jlgndl1	Initial creation	TFS 47198

*/

vars

	serviceGrp : CM_ServiceGroup;

begin
	if _value.isKindOf(CM_ServiceGroup) then
		if _value &lt;&gt; null then
			serviceGrp := _value.CM_ServiceGroup;
			return serviceGrp.name &amp; "  [" &amp; serviceGrp.bank.code &amp; "/" &amp; serviceGrp.bank.terminal.code &amp; "]";
		else
			return null;
		endif;
	else
		return _value.String;
	endif;

epilog

end;</source>
        <Parameter name="_value" type="Any"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="translateToSearchValue" id="bd27bc71-a947-4bea-8118-d9916ed63424">
        <source>translateToSearchValue(_value: Any): Any;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 October 2019	jlgndl1	Initial creation	TFS 47198

*/

vars

begin
	if _value &lt;&gt; null then
		if _value.isKindOf(Collection) then	
			return _value;
		endif;
	
		if _value.isKindOf(CM_ServiceGroup) then
			return _value.CM_ServiceGroup;
		endif;
	endif;
	
	return null;

epilog

end;</source>
        <Parameter name="_value" type="Any"/>
        <ReturnType type="Any"/>
    </JadeMethod>
</Class>
