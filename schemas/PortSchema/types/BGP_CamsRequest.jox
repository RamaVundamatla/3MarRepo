    <JadeMethod name="initAdhocRequest" id="c05a8926-7809-41ac-9bad-231777d30bdd">
        <updating/>
        <source>initAdhocRequest(_camProtocol:  CM_CamProtocol; _startDate, _endDate:TimeStamp; _logExcludedTransactions :Boolean) updating;
// ---------------------------------------------------------------------------
// Created:		23 May 2003  by Jason Chapman  (cnwjc2)
// ---------------------------------------------------------------------------
// 16/07/2012	cnwcs5	par 29601 - log excluded transactions
//28 Jun 2013	cnwrs1	Par31047 - Cams Exception Handler
vars

begin
	self.myAdhocCamProtocol 	:= _camProtocol;
	self.startDate 		:= _startDate;
	self.endDate 		:= _endDate;
	
	self.setLogExcludedTransactions (_logExcludedTransactions);	// par 29601 July 2012
	
	self.myTerminal 	:= _camProtocol.terminal;
	self.isAdhoc 		:= true;
	
	self.initRequestEvent(true, false, _camProtocol);
end;</source>
        <Parameter name="_camProtocol" type="CM_CamProtocol"/>
        <Parameter name="_startDate" type="TimeStamp"/>
        <Parameter name="_endDate" type="TimeStamp"/>
        <Parameter name="_logExcludedTransactions" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="initForTerminal" id="f838b6aa-4eda-4368-96ce-2bec1dae9c17">
        <source>initForTerminal(_camsController: CM_CamControllerAgent input; _terminal: CM_Terminal) protected;
/*----------------------------------------------------------------------------
   Created:		16 May 2003  by Jason Chapman  (cnwjc2)
------------------------------------------------------------------------------ 
Date		Who		Reason
15 May 2012	cnwkpd1	PAR #29594 - Use specific lock exception handler for CAMS with extended timeout on the retries				
25 May 2012	cnwrs1	Par 26914 - make cams restart after lock error
17/07/2012	cnwcs5	par 29601 - log excluded transactions
21/08/2012	cnwcs5	par 30176 - data conversion for above
27 March 2013	cnwmh5	par 31047 
*/
//28 Jun 2013	cnwrs1	Par31047 - Cams Exception Handler
//03 Jan 2013	cnwrs1	32983 crash after user deleted.
//30 Apr 2015	cnwrs1	Par35784 - increased exclusion reason logging to include non excluded
vars
	runDateTime	: TimeStamp;
	msg 		: String;
begin
	app.myPassport.setMyBGPAgent(_camsController);
	_camsController.setCAMSEmail(_terminal);	//need to do this early as next exHandler sends emails
	runDateTime := app.actualTimeServer;
	
//	on Exception do _camsController.controllerXhandler(exception);
//	on LockException do _camsController.lockExceptionHandler(exception);		// PAR #29594
	
	msg := "=====================  CAMS   Agent   Start  =====================";
	
	app.writeLog(msg, LogINFO);	//25 Nov 2019	NDL	TFS 47053
	
	_camsController.setExceptionHandler(false);	//should be false for JMT releases, production systems
	_camsController.setMyTerminal(_terminal);
	
	if self.isAdhoc then
		// will run a "one off" task for the protocol
		_camsController.adhocTask(self.myAdhocCamProtocol, self.startDate, self.endDate, runDateTime, self.logExcludedTransactions, true);	// par 29601 July 2012
	
	elseif self.isRestart then
		// will restart a specific task based on history number
		if self.sequenceNumber &gt; Adhoc_Key then
			_camsController.restartTask(self.myAdhocCamProtocol, self.sequenceNumber,self.msgIndex);	//jlier1 TFS 58637 20/6/23 
		else
			_camsController.restartTask(self.myAdhocCamProtocol, Adhoc_Reprocess,msgIndex);	//jlier1 TFS 58637 20/6/23
		endif;
		
	else
		_camsController.run();	//will do tasks now due	
	endif;	
epilog
	msg := "=====================  CAMS   Agent   Finish  ====================";
	
	app.writeLog(msg, LogINFO);	//25 Nov 2019	NDL	TFS 47053
	
end;</source>
        <access>protected</access>
        <Parameter name="_camsController" type="CM_CamControllerAgent" usage="input"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="initRequestEvent" id="faab2676-a3f0-4fbc-903b-a99c68053842">
        <updating/>
        <source>initRequestEvent(_checkRequestCanBeProcessed: Boolean; _isImmediate: Boolean; _updateCallbackObj: Object) updating;
//
// 03 Oct 2016	cnwrs1	TFS 2756 PAR38267 allow Cams to run per terminal
//
vars

begin	
	if _checkRequestCanBeProcessed then
		self.checkRequestCanBeProcessed();
	endif;
	if _updateCallbackObj &lt;&gt; null and not _updateCallbackObj.isTransient then
		self.myUpdateCallbackObject := _updateCallbackObj;
	endif;
	app.writeLog(class.name&amp;'::'&amp;method.name&amp;' '&amp;' cause Event '&amp;BGP_Object.BGP_ActionRequest.String, LogDEBUG);	//25 Nov 2019	NDL	TFS 47053
	self.causeEvent(BGP_Object.BGP_ActionRequest, _isImmediate, self.myTerminal.code);
end;</source>
        <Parameter name="_checkRequestCanBeProcessed" type="Boolean"/>
        <Parameter name="_isImmediate" type="Boolean"/>
        <Parameter name="_updateCallbackObj" type="Object"/>
    </JadeMethod>
    <JadeMethod name="initRestartRequest" id="9fa646e7-0e6d-485c-9036-2613de235ae1">
        <updating/>
        <source>initRestartRequest(_camTaskHistory: CM_CamTaskHistory; _msgIndex : Integer) updating;
// ---------------------------------------------------------------------------
// Created:		27 May 2003  by Jason Chapman  (cnwjc2)
// ---------------------------------------------------------------------------
//05 Apr 2013	cnwrs1	Par 31258 EDI RORO Deck Plan extracting OOTL containers in incorrect order
//28 Jun 2013	cnwrs1	Par31047 - Cams Exception Handler
vars

begin
	self.myAdhocCamProtocol := _camTaskHistory.camProtocol;
	self.sequenceNumber := _camTaskHistory.seqNumber;
	self.myTerminal := self.myAdhocCamProtocol.terminal;
	self.isRestart := true;
	self.msgIndex:=_msgIndex; //jlier1 TFS 58637 20/6/23

	self.initRequestEvent(true, false, self.myAdhocCamProtocol);
end;</source>
        <Parameter name="_camTaskHistory" type="CM_CamTaskHistory"/>
        <Parameter name="_msgIndex" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="initRestartTask" id="359ed6ba-cb97-4447-b613-6cd4ad470156">
        <updating/>
        <source>initRestartTask(_camProtocol:  CM_CamProtocol; _seqNumber: Integer) updating;
// ---------------------------------------------------------------------------
// Created:		23 May 2003  by Jason Chapman  (cnwjc2)
// ---------------------------------------------------------------------------
//05 Apr 2013	cnwrs1	Par 31258 EDI RORO Deck Plan extracting OOTL containers in incorrect order
//28 Jun 2013	cnwrs1	Par31047 - Cams Exception Handler
vars

begin
// Your stuff.
	self.myAdhocCamProtocol := _camProtocol;
	self.sequenceNumber := _seqNumber;
	self.myTerminal := _camProtocol.terminal;
	self.isRestart := true;
	self.initRequestEvent(true, false, _camProtocol);

end;</source>
        <Parameter name="_camProtocol" type="CM_CamProtocol"/>
        <Parameter name="_seqNumber" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="runCams" id="2b734714-9edc-4bd0-971d-316a0efe3015">
        <source>runCams() protected;

// cnwdvb1 17 March 2003 
//12 Mar 2014	cnwrs1	Par 33690 set myPassport.setMyBGPAgent to null wehn deleteing
vars

	camsAgent 	: CM_CamControllerAgent;

begin

	if self.myTerminal = null then
		app.raiseCMException1(BackgroundErrorGeneral, 'Unable to run CAMS  because terminal is null', null, null);
	endif;
	if app.myPassport &lt;&gt; null then
		app.myPassport.setMyTerminal(self.myTerminal);
	endif;
	
	create camsAgent transient;
	
	self.initForTerminal(camsAgent, self.myTerminal);
	
epilog
	app.myPassport.setMyBGPAgent(null);
	delete camsAgent;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setLogExcludedTransactions" id="8b9d4fd0-0271-410e-b6b1-46e390df6ee2">
        <updating/>
        <source>setLogExcludedTransactions(_value :Boolean)updating;
/*
Date		Who		Reason
16/07/2012	cnwcs5	Initial creation - par 29601
21/08/2012	cnwcs5	par 30176 - conversion for above
*/
vars

begin
	self.logExcludedTransactions	:= _value;
epilog

end;</source>
        <Parameter name="_value" type="Boolean"/>
    </JadeMethod>
</Class>
