    <JadeMethod name="cargoIsoGroup" id="dfae035b-53a1-486c-816d-9210af88812a">
        <source>cargoIsoGroup():String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 Jan 2015	cnwndl1	Initial creation	Par 33965
05 Jun 2025 navma1  MTN-34114  MTN - Performance Improvements - Remove Class::FirstInstance usage  

*/

vars
	ti 		: CM_TrackedItem;
	isoGrp	: CM_ISOTypeGroup;
begin

	ti := self.myTrackedItem;		//05.06.2025 navma1 #MTN-34114
	
	if ti = null then
		return null;
	endif;
	
	isoGrp := ti.getISOTypeGroup();

	if isoGrp &lt;&gt; null then
		return isoGrp.code;
	endif;
	
	return null;

epilog

end;</source>
