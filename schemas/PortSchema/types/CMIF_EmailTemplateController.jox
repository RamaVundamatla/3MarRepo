    <JadeMethod name="addEmailAddress" id="f8b6b0a1-b3a0-4a1f-9d43-ec9a78a9eb08">
        <updating/>
        <source>addEmailAddress(_email : CM_EmailEntity; _mode : Integer)updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
07 August 2009	cnwmd1	Initial creation

*/

vars

begin
	if _mode = self.Mode_To then
		self.allToAddresses.add(_email);
	elseif _mode = self.Mode_CC then
		self.allCcAddresses.add(_email);
	elseif _mode = self.Mode_BCC then
		self.allBccAddresses.add(_email);
	endif;
epilog

end;</source>
        <Parameter name="_email" type="CM_EmailEntity"/>
        <Parameter name="_mode" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="clear" id="bfaa8845-9451-459a-8d6b-42b492763d16">
        <updating/>
        <source>clear() updating;

// Created by cnwdvb1 on 19 October 2006

vars

begin

	self.allToAddresses.clear();
	self.allCcAddresses.clear();
	self.allBccAddresses.clear();
	
	self.freeTxtToAddesses	:= null;
	self.freeTxtCcAddesses 	:= null;
	self.freeTxtBccAddesses	:= null;

end;</source>
    </JadeMethod>
