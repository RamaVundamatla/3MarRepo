		pxyDecking.allDeckingRulesOut.first.setProxy(_isIn, _areaRule, _stackRule, _rowRule, _patternRule, _topupTier);
	endif;
	app.myTrxUA.trxApplyDeckingRule(pxyDecking, DeckingLevel_YA, app.myPassport);	
