    <JadeMethod name="resetTIBehaviourTypeGraphics" id="53e1e0c8-c3fe-43a1-b05d-f365440e4ac1">
        <source>resetTIBehaviourTypeGraphics();
/*
Purpose:	 // CNWAB1 PAR 37161 - ALL NEW VEHICLE GRAPHICS		
Date				Who			Reason
NOVEMBER 2015		CNWAB1		Initial creation
*/


vars
	allBehaviourTypes : ObjectArray;
	  obj : Object;
begin
	if self.hasScriptBeenRunAtAll(method.name, null) then
		return;
	endif;
	app.writeLog(method.qualifiedName &amp; " Resetting TI Behaviour Graphics", LogINFO);
	create allBehaviourTypes transient;
	CM_TIBehaviourType.allInstances(allBehaviourTypes,null,true);
	
	foreach obj in allBehaviourTypes do
		beginTransaction;
		if obj.CM_TIBehaviourType.myGraphic &lt;&gt; null then
			obj.CM_TIBehaviourType.myGraphic.allCommands.purge;
		endif;
		obj.CM_TIBehaviourType.createDefaultGraphic();
		commitTransaction;
	endforeach;
	
	app.writeLog(method.qualifiedName &amp; " Resetting TI Behaviour Graphics - Complete", LogINFO);
	self.addScriptRun(method.name);
epilog
	delete allBehaviourTypes;

end;</source>
    </JadeMethod>
    <JadeMethod name="setArchiveStatusSecurityRoles" id="874bc1e7-542b-42d1-8664-2df2dba631a8">
        <source>setArchiveStatusSecurityRoles(_controller : CnEcReleaseController);
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 11/04/2018	jlgdap1		Initial creation TFS 37966 PEL1 Archive Status
//
vars
	voyageStatus : CM_VoyageStatus;
	role : CM_SecurityRoleTerminal;
	rootRole : CM_SecurityRoleTerminalRoot;

begin
	if self.hasScriptBeenRunAtAll(method.name, _controller) then
		return;
	endif;
	
	app.writeLog(method.qualifiedName &amp; " Add 'Vessel Archived' Statuses to every Terminal Security Role", LogINFO);
	if _controller &lt;&gt; null then
		_controller.logEntry(" Add 'Vessel Archived' Statuses to every Terminal Security Role") ;	
	endif;
	
	beginTransaction;
	voyageStatus := app.myRoot.allVoyageStatuses[Voyage_Status_VesselArchived];
	if voyageStatus &lt;&gt; null then
		foreach role in CM_SecurityRoleTerminal.instances do
			role.allVoyageStatusesMaint.addNoDuplicates(voyageStatus, false);
		endforeach;
		foreach rootRole in CM_SecurityRoleTerminalRoot.instances do
			rootRole.allVoyageStatusesMaint.addNoDuplicates(voyageStatus, false);
		endforeach;
	endif;
	voyageStatus := app.myRoot.allVoyageStatuses[Voyage_Status_IVesselArchived];
	if voyageStatus &lt;&gt; null then
		foreach role in CM_SecurityRoleTerminal.instances do
			role.allVoyageStatusesMaint.addNoDuplicates(voyageStatus, false);
		endforeach;
		foreach rootRole in CM_SecurityRoleTerminalRoot.instances do
			rootRole.allVoyageStatusesMaint.addNoDuplicates(voyageStatus, false);
		endforeach;
	endif;
	commitTransaction;
	
	app.writeLog(method.qualifiedName &amp; " Add 'Vessel Archived' Statuses to every Terminal Security Role Completed", LogINFO);
	if _controller &lt;&gt; null then
		_controller.logEntry(" Add 'Vessel Archived' Statuses to every Terminal Security Role Completed") ;
	endif;
	
	self.addScriptRun(method.name);
epilog

end;</source>
