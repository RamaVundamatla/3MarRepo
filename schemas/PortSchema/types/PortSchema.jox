    <JadeMethod name="showErrorsAsMsgBox" id="5cf9d453-4d1d-4c41-9896-bb78714186ed">
        <source>showErrorsAsMsgBox(_arr : CM_ErrorSet; _noErrors : Boolean) : Boolean;
// ---------------------------------------------------------------------------
// Created:     18 October 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	err		: CM_Error;
	str 	: String;
	rtnCode	: Boolean;
begin

	foreach err in _arr do
		str := str &amp; err.text &amp; CrLf;
	endforeach;
	
	if _noErrors then
		// must all be warnings
		str := str &amp; CrLf &amp;
			   'Press OK to Continue or Cancel to abort';
		if app.msgBox(str, "Warnings", MsgBox_OK_Cancel) = MsgBox_Return_OK then
			rtnCode := true;
		endif;
	else
		app.msgBox(str, "Error!", MsgBox_Stop_Icon + MsgBox_OK_Only); 
	endif;
	
	return rtnCode;
	
end;</source>
        <Parameter name="_arr" type="CM_ErrorSet"/>
        <Parameter name="_noErrors" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
