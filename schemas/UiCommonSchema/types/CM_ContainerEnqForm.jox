    <JadeMethod name="mnuCargoMoveIt_click" id="c0c763a0-73e2-4644-8ff4-8c3d60f14d78">
        <controlMethod name="MenuItem::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>mnuCargoMoveIt_click(menuItem: MenuItem input) updating;
//--------------------------------------------------
// Created:	23 December 2003 By: cnwgd1
//--------------------------------------------------
// Changed On	By			Reason
// ----------	--------	------------------------
// 17/01/2018	jlgdap1		TFS 36658 STWR Cargo Scanning Enhancements
//							Cargo Groups can use the Move it form, but only in Planned mode
vars

	tiArray	: CM_TIArray;
	ti		: CM_TrackedItem;
begin

	create tiArray transient;
	self.tblData.allSelectedObjects.copy(tiArray);
	
	if tiArray.size &gt; 1 then
		ti := tiArray.first;											// TFS 36658
		if ti.isCargoGroupItem then										// TFS 36658
			self.myAssistant.showMoveItForm(tiArray, PLANNING_MODE);	// TFS 36658
			return;														// TFS 36658
		endif;															// TFS 36658
		self.myAssistant.showMoveItForm(tiArray, AUTO_PLAN_MODE);
		return;
	elseif tiArray.size &lt;= 0 then
		ti := menuItem.userObject.CM_TrackedItem;
		if ti = null then
			return;
		endif;
		tiArray[1] := ti;
		//01 Oct 2018	NDL	TFS 39186
		if ti.isCargoGroupItem then										
			self.myAssistant.showMoveItForm(tiArray, PLANNING_MODE);	
			return;														
		endif;
	endif;
	//self.myAssistant.showMoveItForm(tiArray, REAL_MODE);
	self.myAssistant.showMoveItForm(tiArray, self.getMoveMode);//25 Aug 2011	NDL	Par 28035
	
epilog
	delete tiArray;
end;</source>
        <Parameter name="menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
