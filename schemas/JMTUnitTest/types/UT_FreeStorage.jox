        <source>tConfigFirstDay() updating;
// cnwmp6
// cnwjre1
/*

Purpose:			Test using storage config with include first day but all else default options and no free storage days

Parameters:			

Return Value:		


Date		Who		Reason
02 October 2012	cnwjre1	Initial creation

*/

vars
