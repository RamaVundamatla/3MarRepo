    <JadeMethod name="cloneSelf" id="0b7c5a2a-5be6-4899-8173-3cdcf06fbf0a">
        <source>cloneSelf(bTransient: Boolean): SelfType;
// ---------------------------------------------------------------------------
// Created:     cnwyl1  Yi Liu
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	theClone 			: SelfType;
	//clonedTransText		: XLAT_TranslatableText;
	theKeyword,
	tmpKeyword			: XLAT_Keyword;
begin
	theClone := inheritMethod(bTransient);
	/*
	foreach theKeyword in self.allKeywords do 
		tmpKeyword:= theKeyword.cloneSelf(true);
		theClone.allKeywords.add(tmpKeyword);
	endforeach;
	*/
	//self.allKeywords.copy(theClone.allKeywords);
	
	theClone.myTranslatableText := self.myTranslatableText.cloneSelf(bTransient);
	return theClone;
epilog

end;</source>
        <Parameter name="bTransient" type="Boolean"/>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="containsSubstring" id="ae55a1d6-8be4-495c-a8c9-1cf63a064efc">
        <source>containsSubstring(searchText:String):Boolean;

vars

begin
	return text.pos(searchText,1) &lt;&gt; 0;
end;</source>
