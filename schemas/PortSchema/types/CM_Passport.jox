    <JadeMethod name="getWarningsAsString" id="2526210d-ff7e-45c9-b659-12b87f0b7210">
        <source>getWarningsAsString() : String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 December 2024	navsck1	Initial creation

*/
vars
	error : CM_Error;
	str : String;
	
begin
	foreach error in self.allWarnings do
		if str = null then
			str := error.getDetailsAsString;
		else
			str := str &amp; CrLf &amp; error.getDetailsAsString;
		endif;
	endforeach;
	
	return str;
end;</source>
        <text>This function used to return all warning in the passport as a string.</text>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="hadReplayableDeadlock" id="b9e8a48d-bb0c-440c-b5d2-55cf38ff5a86">
        <source>hadReplayableDeadlock():Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 January 2013	cnwndl1	Initial creation	Par 30920

*/
vars

begin

	if not self.hadDeadlock then
		//we haven't had a deadlock.
		return false;
	endif;

	if self.silentDeadlockRetryCount &gt; self.silentDeadlockLimit then
		//nah we've blown it, had too many deadlocks.
		return false;
	endif;
	
	//we had a deadlock, but we are within our limits
	return true;

end;
</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="hasErrors" id="3de815fa-a9a5-4598-8f13-57a07ee193ce">
        <source>hasErrors() : Boolean;
// ---------------------------------------------------------------------------
// Created:     12 December 2000 by cnwrs2
