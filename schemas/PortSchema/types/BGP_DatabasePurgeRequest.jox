    <JadeMethod name="action" id="37053592-5acf-4951-9384-603ff7d4840e">
        <updating/>
        <source>action(): Boolean updating;
// -------------------------------------------
// Created 20 August 2004 by cnwdvb1
// -------------------------------------------
vars

	errCode	: Integer;
	errTxt	: String;
	success	: Boolean;
	
begin

	on Exception do app.alertExceptionHandler(exception, null, self.getErrorDesc(), errCode, errTxt, true, false);
	on LockException do app.alertLockExceptionHandler(exception);
	
	self.setUser();
	
	app.isGarbageCollectionProcess := true;

	success := self.runDBPurge();

epilog
	
	if errCode &lt;&gt; null then
		app.myTrxUA.trxUpdateBGPRequest(self, true, errCode, errTxt, app.myPassport);
		// Want different timestamp for display.
		process.sleep(1000);
		app.createActivityHistory(ActivityHistoryDBPurge, self.myTerminal, self, app.getErrorString(Process_Unsuccessful), false, false);
	elseif success then
		// Want different timestamp for display.
		process.sleep(1000);
		app.createActivityHistory(ActivityHistoryDBPurge, self.myTerminal, self, app.getErrorString(Process_Complete), false, false);
	else
		process.sleep(1000);
		app.createActivityHistory(ActivityHistoryDBPurge, self.myTerminal, self, app.getErrorString(Process_Aborted), false, false);
	endif;
	inheritMethod();
	app.isGarbageCollectionProcess := false;

	return true;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getDisplay" id="e6098015-4a0f-4237-bf2c-3df9db745a82">
        <source>getDisplay(): String;
// -------------------------------------------
// Created 20 August 2004 by cnwdvb1
// -------------------------------------------
vars

	str	: String;
	
begin
	
	str := inheritMethod();
	
	if self.myTerminal &lt;&gt; null then
		return str &amp; Tab &amp; app.getErrorString(Terminal) &amp; ' ' &amp; self.myTerminal.code;
	endif;
	return str;
	
	


end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getInstances" id="c61bd27d-282f-4e4f-8087-535d32532fa7">
        <source>getInstances(_task: CM_AutoTask): Integer;
//
// SFW 1121 cnwrs1  Sept 2011
//
// 21 Sep 2016	cnwrs1	TFS 2705 - ignore isProcessed requests
// 03 Oct 2016	cnwrs1	TFS 2756 PAR38267 allow Cams to run per terminal
vars
	count : Integer;
	request : BGP_DatabasePurgeRequest;
	obj : Object;
	invalid : Boolean;	//02 Jul 2020 NDL	TFS 49711 
begin
	
	on Exception do app.handleDeletedObject( exception, request, invalid );	//02 Jul NDL	TFS 49711 
	
	foreach obj in self.class.instances do
		request := obj.BGP_DatabasePurgeRequest;
		if request.isProcessed and
		   self.myProcessingController = null then
			continue;
		endif;
		if invalid then	//02 Jul 2020 NDL	TFS 49711 
			invalid:= false;
			continue;
		endif;
		if request.myTerminal = _task.myTerminal then
			count := count + 1;
		endif;
	endforeach;
	return count;
end;
</source>
        <Parameter name="_task" type="CM_AutoTask"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
