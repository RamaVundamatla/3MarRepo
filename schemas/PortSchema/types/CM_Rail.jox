    <JadeMethod name="getQueues" id="7e111742-d84b-42c9-9b1f-d899ca2dd293">
        <source>getQueues(queueSet: CM_RTQueueSet io);
//Returns the queue(s) associated with this terminal area.
//Because Rail areas are special, the Target location here is a Transfer Area, not the
//Rail rake itself. (as its so dynamic, its NOT funny). We ask the RTA for its Queues!
//17/10/08		cnwer1		PAR 18102  - queues was de-implemted in 7.5.3 and replaced by allRTSubqueues but this method was never changed
vars
	term : CM_Terminal;
	tmpQueueSet : CM_RTQueueSet;
	rtQ	:	CM_RadioTelemetryQueue;
begin
	queueSet.clear;
	//Use the Rail's Queues if there are any first.
	/*if queues.size &gt; 0 then
		queues.copy(queueSet);
		return;
	endif;*/
	
	if not self.allSubQueues.isEmpty() then
		self.allSubQueues.copy(queueSet);
		return;
	endif;
	//Nope, no rail specific Q, ask its transfer area
	if self.myTransferArea = null then
		//No rail transfer area, Not setup correctly, so call the Terminal
		self.myTerminal.getQueues(queueSet);
		return;
	endif;
	//-------------
	//DONT call getQueues on the rail transfer area, as IT CALLS US! we eventually run out of stack space!
	//Simply get the queues from the area.
	//-------------
	if self.myTransferArea.allSubRTQueues.size &gt; 0 then
		if queueSet.size &gt; 0 then
			create tmpQueueSet transient;
		else
			self.myTransferArea.allSubRTQueues.copy(queueSet);
			return;
		endif;
  	//Get the transfer areas queues, check to make sure we aint already got em.
		self.myTransferArea.allSubRTQueues.copy(tmpQueueSet);
		foreach rtQ in tmpQueueSet do
			if not queueSet.includes(rtQ) then
				queueSet.add(rtQ);
			endif;
		endforeach;
	endif;
epilog
	if tmpQueueSet &lt;&gt; null then 
		tmpQueueSet.clear;
		delete tmpQueueSet;		
	endif;
end;</source>
        <Parameter name="queueSet" type="CM_RTQueueSet" usage="io"/>
    </JadeMethod>
    <JadeMethod name="getRailJSInOutRake" id="b86317e1-5815-4ede-848a-717f7db48575">
        <source>getRailJSInOutRake( _ioType : Integer ):CM_RailJSInOutRake;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 March 2020	jlgndl1	Initial creation	TFS 47004

*/

vars

	railIO : CM_RailJSInOut;
	obj : Object;
	railIORake : CM_RailJSInOutRake;

begin

	foreach obj in self.allRailJSInOut do
		railIORake := obj.CM_RailJSInOutRake;
		railIO := railIORake.inOut.CM_RailJSInOut;
		if railIO.outwards = _ioType then
			return railIORake;
		endif;
	endforeach;
	
	return null;

epilog

end;</source>
        <Parameter name="_ioType" type="Integer"/>
        <ReturnType type="CM_RailJSInOutRake"/>
    </JadeMethod>
    <JadeMethod name="getValidLCsCollectionForMove" id="fe922a9f-db4f-4e6c-b7f5-9dbdefa0698e">
        <source>getValidLCsCollectionForMove( _lcSet : CM_LCSet input );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 March 2013	cnwndl1	Initial creation	Par 31278

*/

vars

	lc : CM_LocationsController;
	wagon : CM_Wagon;
begin

	foreach lc in self.allLocationsControllers do
		if lc.CM_WagonController.isDeparted then
			continue;
		endif;
		_lcSet.add( lc );
	endforeach;

epilog

end;</source>
        <Parameter name="_lcSet" type="CM_LCSet" usage="input"/>
    </JadeMethod>
