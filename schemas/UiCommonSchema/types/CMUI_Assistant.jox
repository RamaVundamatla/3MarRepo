        <source>comboBoxHMSBerthPreference(pCmb : ComboBox input; _vesselDataHarbour : HMS_VesselDataHarbour; _voyageData : HMS_VoyageData);
//--------------------------------------------------------------
//Created: March 2004 By: cnwgd1
