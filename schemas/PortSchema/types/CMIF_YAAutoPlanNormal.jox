    <JadeMethod name="isWeight_Compare" id="d46a7d2d-ed69-45e2-be7f-c30023d2dc2b">
        <source>isWeight_Compare(range: Object; weight: Integer): Boolean;
//
// Changed On	By			Reason
// ----------	--------	-------------------------------------------------------------------
// 02/05/2013	cnwdap1		PAR #31155 CCMS SFW 1321 Imperial Measurements - range may not be in kgs
//
vars
	weightRange		: CM_WeightRange;										// PAR #31155
	measure			: CM_MeasurementType;									// PAR #31155
	lower, upper	: Decimal [23,10];										// PAR #31155
	
begin
	weightRange := range.CM_WeightRange;													// PAR #31155
	measure := weightRange.myMeasurementType;												// PAR #31155
	if measure &lt;&gt; null then																	// PAR #31155
		lower := app.convertMeasurementForStorage(measure.shortName, weightRange.lower);	// PAR #31155
		upper := app.convertMeasurementForStorage(measure.shortName, weightRange.upper);	// PAR #31155
	else																					// PAR #31155
		lower := weightRange.lower;															// PAR #31155
		upper := weightRange.upper;															// PAR #31155
	endif;																					// PAR #31155
	return weight &gt;= lower and weight &lt;= upper;												// PAR #31155
	//return weight &gt;= range.CM_WeightRange.lower and
	//	   weight &lt;= range.CM_WeightRange.upper;
end;</source>
        <Parameter name="range" type="Object"/>
        <Parameter name="weight" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isWeight_Match" id="70c25038-f65d-4fc1-8758-47a3d12879e7">
        <source>isWeight_Match(_yaData: CM_YADataObjects): Boolean;
// -------------------------------------------
// Created 27 May 2005 by cnwdvb1
// -------------------------------------------
vars
	weight	: Decimal[14,4];
begin

	weight := self.myTrackedItem.totalWeight;
	
	// Only priorities will be empty.
	if _yaData.isEmpty() then
		return true;
	endif;
	
	return _yaData.visitObjectsUntilTrue(self, CMIF_YAAutoPlanNormal::isWeight_Compare, weight);
end;</source>
        <Parameter name="_yaData" type="CM_YADataObjects"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
