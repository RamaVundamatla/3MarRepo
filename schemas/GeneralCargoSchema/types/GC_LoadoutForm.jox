	tmpProduct 		:= combo.listObject.CM_Product;
	
	theRow  := tbl.row;

	self.myCurrentDetailObject.CMIF_BOLOutLine.myProduct := tmpProduct;	// make sure proxy in table is updated as we go

	
	tmpCell := tbl.accessCell(theRow, tbl.getColumnByRowName(ETRow_Id));	
	cmbId := tmpCell.cellControl.CMUI_ComboBox;


	if 	tmpProduct 	&lt;&gt; null then 
		//self.myAssistant.comboBoxTIsByProduct(cmbId, tmpProduct, cmbId.text); 
		self.maintainIDCombos(null);
	else // if no product then list all TIs for cargo type. 
		tmpCell := tbl.accessCell(theRow, tbl.getColumnByRowName(ETRow_CargoType));
		cmbCargoType := tmpCell.cellControl.CMUI_ComboBox;
		tmpCargoType := cmbCargoType.listObject.CM_CargoType;
		if tmpCargoType &lt;&gt; null and tmpCargoType.id &lt; TI_CargoBOLType_Max then
			self.myAssistant.comboBoxTrackedItemToPack(cmbId , tmpCargoType.id, TI_STATE_NORMAL, cmbId.text); 	
		endif;
	
	endif;
/* old code 
	cmb					: CMUI_ComboBox;
	tmpProduct			: CM_Product;
	tmpCargoType		: CM_CargoType;
begin
	cmb := self.cmbProduct;
	
	if cmb.text = self.tblDetailEnt.getValueByName(ETRow_Product).String then 
	//have already selected the item previously so no need to redo and clear other combos. 
		return;
	endif;

	self.tblDetailEnt.setValueByControlName(cmb.name, cmb.text);
	
	tmpProduct := cmb.listObject.CM_Product;
	if tmpProduct &lt;&gt; null then
		self.myAssistant.comboBoxTIsByProduct(self.cmbItem, tmpProduct, self.cmbItem.text); 
	else //if no product selected, list all the TIs of the selected cargo type - then
		//when a TI is selected, the product combo will prefill.
		tmpCargoType := self.cmbCargoType.listObject.CM_CargoType;
		if tmpCargoType &lt;&gt; null then
			self.myAssistant.comboBoxTrackedItemID(self.cmbItem, tmpCargoType.id, TI_STATE_NORMAL, self.cmbItem.text); 	
		endif;
	endif;

	self.tblDetailEnt.setValueByName(ETRow_Location, null); // clear as selecting new product neans any old location is wrong
	self.tblDetailEnt.setValueByName(ETRow_Id, null); */
end;</source>
        <access>protected</access>
        <Parameter name="combo" type="CMUI_ComboBox"/>
    </JadeMethod>
    <JadeMethod name="doCmbTATypeClick" id="cbe7815d-759b-47ad-acd2-d0f367593d3a">
        <updating/>
        <source>doCmbTATypeClick() updating, protected;
// ---------------------------------------------------------------------------
// Created:     03 June 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	taType		: CM_TerminalAreaType;
	ta			: CM_TerminalArea;
