    <JadeMethod name="chkBarrierCodes_change" id="c1752019-76c9-49ca-8411-73a1d7d2b7f9">
        <controlMethod name="CheckBox::change"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>chkBarrierCodes_change(checkbox: CheckBox input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 May 2023	jlier1	Initial creation 57936

*/

vars

begin
	if self.mode &lt;&gt; self.Mode_Add and self.mode &lt;&gt; self.Mode_Update then
		return;
	endif;
	
	if self.myProxyObject = null then
		return;
	endif;
	
	self.myProxyObject.CM_Gate.setUseBarrierCodes (checkbox.value);
epilog	

end;</source>
        <Parameter name="checkbox" type="CheckBox" usage="input"/>
    </JadeMethod>
