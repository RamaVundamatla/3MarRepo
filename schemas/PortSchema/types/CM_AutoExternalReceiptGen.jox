*/

vars

begin
	self.myExtFinanceIO := _proxy.myExtFinanceIO;
	inheritMethod(_proxy);

epilog

end;</source>
        <Parameter name="_proxy" type="CM_AutoExternalReceiptGen"/>
    </JadeMethod>
    <JadeMethod name="setLastAndNextValues" id="e9d175c9-8986-463d-8aa9-a3e4ffd1dd97">
        <updating/>
        <source>setLastAndNextValues(	_lastIdGenerated: String;
					//	_lastIdGeneratedYear: String;
						_nextSeqNum: Real;
						_seqYear: Integer;
						_lastGeneratedDate : Date
						) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 November 2018	jlgma1	Bug 41688: PEL1 - Estimation ID sequence

*/

vars

begin
	
	self.lastIdGenerated := _lastIdGenerated;
	//self.lastIdGeneratedYear := _lastIdGeneratedYear;
	self.nextSequenceNumArray[ _seqYear ] := _nextSeqNum;
	self.lastGeneratedDate := _lastGeneratedDate;	//23 Jan 2019	NDL	TFS 43018

epilog

end;</source>
        <Parameter name="_lastIdGenerated" type="String"/>
        <Parameter name="_nextSeqNum" type="Real"/>
        <Parameter name="_seqYear" type="Integer"/>
        <Parameter name="_lastGeneratedDate" type="Date"/>
    </JadeMethod>
