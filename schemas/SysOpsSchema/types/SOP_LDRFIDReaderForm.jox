    <JadeMethod name="doOK" id="86b03510-1e70-42ed-9a82-77c1eb69a89d">
        <updating/>
        <source>doOK() updating;

/*
Date			Who		Reason
03 July 2009	cnwar2	Initial creation

*/
vars
	pxyReader : CM_RFIDTagReader;
	theResult : Integer;	//14 Jan 2020 NDL	TFS 46815
	
begin
	pxyReader := self.myProxyObject.CM_RFIDTagReader;
	
	pxyReader.setProxy(	txtCode.text, 
						txtDescription.text, 
						txtDeviceName.text, 
						txtListenerIP.text, 
						txtDeviceIP.text, 
						txtPort.text.Integer, 
						TagReaderContext_LaneDevice,//TagReaderContext_GateLane,
						null,
						self.myGateLane,
						null, 
						"");
	
	//14 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
	while true do
	
		if self.mode = self.Mode_Add then
			app.myTrxCA.trxCreateRFIDTagReader(pxyReader, self.updateObject, self.myTerminal, app.myPassport);
		else
			app.myTrxUA.trxUpdateRFIDTagReader(pxyReader, self.myTerminal, app.myPassport);
		endif;
	
		if app.myPassport.trxCompletedOK then
			inheritMethod();	// unload form
			break;
		else
			theResult := app.showErrorWarningDialog(app.getErrorString(Gate_configuration), app.myPassport, ErrWarnMode_Update);
			if app.myPassport.noErrors and theResult = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		
		break;
		
	endwhile;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="setupForm" id="a85a72b7-a577-499d-ae8f-a5027a030bfe">
        <updating/>
        <source>setupForm() updating;

/*
Date			Who		Reason
03 July 2009	cnwar2	Initial creation

*/
vars
	reader : CM_RFIDTagReader;
begin
	inheritMethod();
	
	if mode = self.Mode_Update then
		self.myProxyObject 	:= self.updateObject.pxyGetProxyObject();
		if self.myProxyObject = null then
			self.myProxyObject 	:= app.createUpdateProxy(self.updateObject);
		endif;
		reader := self.myProxyObject.CM_RFIDTagReader;
		
		self.txtCode.text			:= reader.code;
		self.txtDescription.text	:= reader.description;
		self.txtDeviceIP.text		:= reader.ipAddress;
		self.txtDeviceName.text		:= reader.deviceName;
		self.txtListenerIP.text		:= reader.ipAddressListener;
		self.txtPort.text			:= reader.portNumber.asStringJMT;
		
	else
		create self.myProxyObject as CM_RFIDTagReader transient;
		
		self.txtCode.text			:= "";
		self.txtDescription.text	:= "";
		self.txtDeviceIP.text		:= "";
		self.txtDeviceName.text		:= "";
		self.txtListenerIP.text		:= "";
		self.txtPort.text			:= "";
		self.btnOk.caption			:= app.getErrorString(AddUpper);
	endif;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="translateForm" id="6e151c84-2f58-4f0f-9623-a57e5a71913e">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0011666, locale);
	lblCode.translateCaption(Xlat_0011667, locale);
	lblDescription.translateCaption(Xlat_0011668, locale);
	lblDeviceIP.translateCaption(Xlat_0011669, locale);
	lblDeviceName.translateCaption(Xlat_0011670, locale);
	lblListenerIP.translateCaption(Xlat_0011671, locale);
	lblPort.translateCaption(Xlat_0011672, locale);
end;</source>
    </JadeMethod>
    <JadeMethod name="unload" id="a4c65232-57ae-42dc-8b92-133eeb6947d9">
        <controlMethod name="CMUI_Modal::unload"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>unload() updating;

/*
Date			Who		Reason
03 July 2009	cnwar2	Initial creation

*/
vars

begin
	inheritMethod();
	delete self.myProxyObject;
end;</source>
    </JadeMethod>
    <JadeMethod name="unloadForm" id="89e0c298-a95f-495e-96af-d57ea15c72ea">
        <updating/>
        <source>unloadForm(): Boolean updating;

/*
Date			Who		Reason
10 July 2009	cnwar2	Initial creation

*/
vars

begin
	delete self.myProxyObject;
	return inheritMethod();

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</GUIClass>
