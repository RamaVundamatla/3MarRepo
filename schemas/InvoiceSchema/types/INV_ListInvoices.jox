    <JadeMethod name="setEnableInvRecheckFin" id="0c7c7b07-6ae8-4425-a800-863fb53735a1">
        <source>setEnableInvRecheckFin();

/*

Purpose:			

Parameters:			

Return Value:		


12 Oct 2018	cnwma1	ChangeRequest 41380: PEL1 - Resend option for failed SAP WSDLs
15 Nov 2018 cnwma1	ChangeRequest 42045: PEL1 - SAP Integration : Additional Changes - Extended
19 Nov 2018 cnwma1  Bug 42081: PEL1 - Recheck Finance Option does not show
31 Dec 2018 cnwma1	Bug 42747: PEL1 - Recheck Finance for Post Pay Replacement Invoice
11/06/2025	navcs2	MTN-34987 MTN -  Disable SAP Integration

*/

vars
	invoiceSelected : Boolean;
	finIO 		    : CM_ExtFinanceIO;
	paymentStatus   : Integer;
	paymentType     : Integer;
begin
	/*
	
	No longer Using SAP	11/06/2025	navcs2	MTN-34987 MTN -  Disable SAP Integration
	
	self.mnuRecheckFin.visible := false;
	
	invoiceSelected := self.myCurrentInvoice &lt;&gt; null;
	
	if invoiceSelected then
		
		paymentStatus := self.myCurrentInvoice.paymentStatus;
		paymentType   := self.myCurrentInvoice.paymentType;
	endif;
	
	if paymentType = PaymentType_None then
		return;
	endif;
	
	if not  self.myTerminal.isSapFinancialEnabled then
		return;
	endif;
	
	if not   app.getMyUser.canDo(self.myTerminal,PmAdmRecheckFinance) then	//19.11.2018 cnwma1 Bug #42081	 
		return;
	endif;
	
	if self.myCurrentInvoice.status = CM_Invoice.INVOICE_PENDING then
		//PaymentType_AutoCollection
		if paymentType = PaymentType_AutoCollection then 
			if  paymentStatus = CM_Invoice.INVOICE_PAYMENT_NOTPAID or  
			    paymentStatus = CM_Invoice.INVOICE_PAYMENT_PAID then
				
				self.mnuRecheckFin.visible := true;
			endif;
		
		//PaymentType_PostPay	
		elseif paymentType = PaymentType_PostPay then 
			if paymentStatus = CM_Invoice.INVOICE_PAYMENT_NOTPAID or 
		  	   paymentStatus = CM_Invoice.INVOICE_PAYMENT_CANCEL then     // 31.12.2018 cnwma1 TFS #42747
				/*
					37189.007 Send Invoice/Data for Post-Billing Customer
					WSDL 1.7: Post-Billing - Billing Payment Process
					PaymentType_PostPay 
				*/
	/*
				self.mnuRecheckFin.visible := true;
			endif;
			
		//PaymentType_PrePay
		elseif paymentType = PaymentType_PrePay then  
			if paymentStatus = CM_Invoice.INVOICE_PAYMENT_NOTPAID or 
			   paymentStatus = CM_Invoice.INVOICE_PAYMENT_PAID    then
				self.mnuRecheckFin.visible := true;
			endif;
		endif;
	
	elseif self.myCurrentInvoice.status = CM_Invoice.INVOICE_POSTED then
		//PaymentType_PrePay
		if paymentType = PaymentType_PrePay then
			if paymentStatus = CM_Invoice.INVOICE_PAYMENT_PAID    then
				/*
					15.11.2018 cnwma1 TFS #42045
					41022.020 Re-sending failed transactions to SAP
					WSDL 1.12
				*/
	/*
				self.mnuRecheckFin.visible := true;
			endif;
		//PaymentType_AutoCollection
		elseif paymentType = PaymentType_AutoCollection then  
			if paymentStatus = CM_Invoice.INVOICE_PAYMENT_PAID then
				/*
					23.11.2018 cnwma1 TFS #42045
					41022.020 Re-sending failed transactions to SAP
					WSDL 1.3
				*/
	/*
				self.mnuRecheckFin.visible := true;
			endif;
		endif;
	endif;
	*/
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setEnableInvReturn" id="768cdac2-4f5b-48c4-bf09-b4e2112f8a1a">
        <source>setEnableInvReturn();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
31 August 2017	jlgndl1	Initial creation	TFS 6759
12 Nov    2018	cnwma1	ChangeRequest 41945: PEL1 - SAP - Invoice changes restriction
*/

vars
	invoiceSelected : Boolean;
	canReturn : Boolean;
begin

	invoiceSelected := self.myCurrentInvoice &lt;&gt; null;
	// TFS 39618 PATCH 1 canReturn		:= app.getMyUser().canDo(self.myTerminal,PmAdmInvListStatusReturn);
	canReturn := self.myCurrentBank.userCanSet(CM_Invoice.INVOICE_POSTED_REVERSE);  // TFS 39618 PATCH 1 
	
	//self.btnStatusReturn.enabled := canReturn and invoiceSelected and self.myCurrentInvoice.canBeReturned and self.tblData.allSelectedObjects.size = 1;                                   //12.11.2018 cnwma1 TFS #41945
	// TFS 39618 861.010 self.btnStatusReturn.enabled := canReturn and invoiceSelected and self.myCurrentInvoice.canBeReturned and self.tblData.allSelectedObjects.size = 1 and self.myCurrentInvoice.canUpdate; //12.11.2018 cnwma1 TFS #41945
	// TFS 39618 861.010 self.mnuInvReturned.enabled := self.btnStatusReturn.enabled;	
	// TFS 39618 861.010 	
	self.mnuInvReturned.enabled :=  canReturn and invoiceSelected and self.myCurrentInvoice.canBeReturned and self.tblData.allSelectedObjects.size = 1 and self.myCurrentInvoice.canUpdate;
	
	
	self.mnuInvReturned.visible := invoiceSelected;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setEnableInvUpdatePayStatus" id="9c874693-e457-4899-9b19-904a43d4817c">
        <source>setEnableInvUpdatePayStatus();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
