    <JadeMethod name="getMoveMatchingPreNote" id="fd7dd967-61b7-47d9-9422-d227dc105f38">
        <source>getMoveMatchingPreNote( preNote : CM_TrackedItem ):CM_InterTerminalMove;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
17 February 2010	cnwndl1	Initial creation

*/

vars

	iter : Iterator;
	move : CM_InterTerminalMove;
	
begin

	if preNote = null then
		return null;
	endif;
	
	if self.allInterTerminalMoves.isEmpty then
		return null;
	endif;
	
	iter := self.allInterTerminalMoves.createIterator;
	while iter.next( move ) do
		if move.myTargetTI &lt;&gt; null then
			// its populated once loaded
			if move.myTargetTI = preNote then
				return move;
			endif;
		endif;
		
		// but not during loading...
		if move.mySourceTI = null then
			continue;
		endif;
		if move.cargoID &lt;&gt; preNote.id then
			continue;
		endif;
		if move.mySourceTI.cargoType &lt;&gt; preNote.cargoType then
			continue;
		endif;
		return move;
		
	endwhile;
	
	return null;
	
epilog

	delete iter;

end;</source>
        <Parameter name="preNote" type="CM_TrackedItem"/>
        <ReturnType type="CM_InterTerminalMove"/>
    </JadeMethod>
    <JadeMethod name="includesMoveForTi" id="c6ec2f5e-0d47-4a08-9554-6992da90869c">
        <source>includesMoveForTi( _ti : CM_TrackedItem ):Boolean;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
17 February 2010	cnwndl1	Initial creation

*/

vars
	iter : Iterator;
	move : CM_InterTerminalMove;
begin

	if self.allInterTerminalMoves.isEmpty then
		return false;
	endif;
	
	iter := self.allInterTerminalMoves.createIterator;
	while iter.next( move ) do
		if move.mySourceTI = _ti then
			return true;
		endif;
		if move.myTargetTI = _ti then
			return true;
		endif;
		
	endwhile;

	return false;

epilog

	delete iter;
	
end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="includesMovesForTargetTerm" id="76412a11-0a80-4ca6-a1e1-d5c0dbd2bfe1">
        <source>includesMovesForTargetTerm( _targetTerm : CM_Terminal ):Boolean;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
18 February 2010	cnwndl1	Initial creation

*/

vars
	iter : Iterator;
	move : CM_InterTerminalMove;
begin

	if self.allInterTerminalMoves.isEmpty then
		return false;
	endif;
	
	iter := self.allInterTerminalMoves.createIterator;
	while iter.next( move ) do
		if move.myTargetTerminal = _targetTerm then
			return true;
		endif;
	endwhile;

	return false;

epilog

	delete iter;
	
end;</source>
        <Parameter name="_targetTerm" type="CM_Terminal"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
