    <JadeMethod name="displayFields" id="ca658bf5-38af-4b85-b9e3-9b8dcf8418f2">
        <updating/>
        <source>displayFields() updating;
/*
Purpose:	

Date		Who		Reason
09 July 2024	navab1	CR 64617 TASK 64638
*/

vars
	types : CM_EDIFileTypeByNameDict;
begin
	if self.myCurrentEDIIssue = null then
		self.updateMode := false;
		return;
	endif;
	
	self.updateMode := true;
	
	delete self.myProxyEmailTemplate;
	
	self.txtCode.text := self.myCurrentEDIIssue.code;
	self.txtDesc.text := self.myCurrentEDIIssue.description;
	
	self.chkIncludeLoad.value := self.myCurrentEDIIssue.includeLoadIssue;
	self.chkIncludeVerify.value := self.myCurrentEDIIssue.includeVerifyIssue;
	
	create types transient;
	self.myCurrentEDIIssue.getEDIFileTypes(types, self.myTerminal);
	self.msgEDITypes.setAvailable(self.myEDIFilTypeAgent.allEDIFileTypes, true);
	self.msgEDITypes.setSelected(types);

	if self.myCurrentEDIIssue.myEmailTemplate &lt;&gt; null then
		self.lblEmail.caption := "Email has been set";
	else
		self.lblEmail.caption := "No email has been set";
		
	endif;
epilog
	delete types;
end;</source>
    </JadeMethod>
    <JadeMethod name="doButtonAddClick" id="29491041-288b-444c-923c-f17a07c75e19">
        <updating/>
