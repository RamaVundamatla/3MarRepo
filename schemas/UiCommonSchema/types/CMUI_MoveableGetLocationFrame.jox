    <JadeMethod name="createMyControls" id="7853e049-5883-4cd4-8967-522a67d3a122">
        <updating/>
        <source>createMyControls() protected, updating;
// -------------------------------------------
// Created 07 November 2003 by cnwdvb1
// -------------------------------------------
vars

begin

	create self.cmbTAType transient;
	create self.cmbTermArea transient;
	create self.cmbYardLocation transient;
	create self.tblMove transient;
	
	self.form.addControl(self.cmbTAType);
	self.form.addControl(self.cmbTermArea);
	self.form.addControl(self.cmbYardLocation);
	self.form.addControl(self.tblMove);
			
	self.cmbTAType.parent := self;
	self.cmbTermArea.parent := self;
	self.cmbYardLocation.parent := self;
	self.tblMove.parent	:= self;
	
	self.cmbTAType.setMyFrame(self);
	self.cmbTermArea.setMyFrame(self);
	self.cmbYardLocation.setMyFrame(self);
	
	self.cmbTAType.name			:= 'cmbTAType';
	self.cmbTermArea.name		:= 'cmbTermArea';
	self.cmbYardLocation.name	:= 'cmbYardLocation';
	self.tblMove.name			:= 'tblMove';
	
	self.cmbYardLocation.style := ComboBox.Style_DropDownComboList; //cnwgb1 26 May 2008 PAR 16709

	self.tblMove.distanceFromRight	:= 0;
	self.tblMove.distanceFromBottom	:= 0;
	self.tblMove.top				:= 0;
	self.tblMove.left				:= 0;
	self.tblMove.stretchWidth		:= true;
	self.tblMove.stretchHeight		:= true;

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="delete" id="e5f088e6-54a6-428a-8a95-b59c6349efb2">
        <updating/>
        <source>delete() updating;
// -------------------------------------------
// Created 07 November 2003 by cnwdvb1
