    <JadeMethod name="getSuperUserPassword" id="7c8155dc-6770-4808-9e76-bf93ee7dc769">
        <source>getSuperUserPassword();
// ---------------------------------------------------------------------------
// Created:     23 July 2008 by cnwab1
//
// Purpose:     IsSpecial extra check is used outside JMT Plant - PAR 17588
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	------------------------------------------
// 30/01/2024		navmd1			TFS 60905 Refactor SSO for Superuser
// ---------------------------------------------------------------------------

vars
	lForm 		: CMUI_GetData;
	isSuperuser,
	isSupport	: Boolean;
	ssoEnabled	: Boolean;
	silent		: Boolean;
begin
	ssoEnabled := not app.myRoot.getConfig(DisableSSOSuperuser).Boolean;

	if ssoEnabled then
		silent := true;
		while true do
			if app.mySSOAgent.loginSpecial(isSuperuser, isSupport, silent, app.getMyUserCode()) then
				if isSuperuser then
					app.setSpecial('01/12/3000'.TimeStamp);
					self.CMUI_SuperAppForm2.lblUserName.foreColor := Red;
				else
					app.msgBox("User is not authorised", "Invalid User", MsgBox_Stop_Icon + MsgBox_OK_Only);
					if silent then
						silent := false;
						continue;
					endif;
				endif;
			endif;
			break;
		endwhile;
	else
		create lForm;
		lForm.centreWindow;
		app.mousePointer := MousePointer_Default;
		
		lForm.lblTextCaption := "Superuser Password";
		lForm.txtData.text := null;
		lForm.txtData.maxLength := 20;
		lForm.txtData.dataType := TextBox.DataType_AlphaNumeric;
		// SU PW is now case sensitive lForm.txtData.case := TextBox.Case_Upper;		
		lForm.txtData.passwordField := true;
		lForm.myCaller := self;
		lForm.formCaption := "Enter Superuser Password";
		lForm.type := CMUI_SuperAppForm2.GetData_SUPasswordIsSpecial;
		lForm.show; // this calls GetData on SuperApp2Form
	endif;
epilog
	app.mousePointer := MousePointer_Default;

end;</source>
    </JadeMethod>
