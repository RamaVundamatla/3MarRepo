    <JadeMethod name="appendXML" id="e5323a36-9e8e-4e24-a6ef-4fb32dd5bfc1">
        <source>appendXML(	_messageXML		: String io;
			_tagName		: String;
			_data			: String	);

/*

Purpose:			Appends data in XML format.

Parameters:			

Return Value:		None


Date		Who		Reason
23 Nov 2009	consw1	PAR #21593 - Development of CCMS MES 1014 - RDT ITS Interface

*/

vars

begin
	if _data = null then
		_messageXML := _messageXML &amp; "&lt;" &amp; _tagName &amp; "/&gt;";
	else
		_messageXML := _messageXML &amp; "&lt;" &amp; _tagName &amp; "&gt;" &amp; _data &amp; "&lt;/" &amp; _tagName &amp; "&gt;";
	endif;
	
epilog

end;</source>
        <Parameter name="_messageXML" type="String" usage="io"/>
        <Parameter name="_tagName" type="String"/>
        <Parameter name="_data" type="String"/>
    </JadeMethod>
    <JadeMethod name="doACK" id="e496aaeb-461c-42ea-8143-220e47fa924a">
        <updating/>
        <source>doACK(_acknowledgedTS : TimeStamp; _passport : CM_Passport input) updating;

/*

Purpose:			Acknowledge response received by ITS.

Parameters:			Time acknowledged.

Return Value:		None


Date		Who		Reason
25 Nov 2009	consw1	PAR #21593 - Development of CCMS MES 1014 - RDT ITS Interface

*/

vars
	activeResponse	: CM_ITSInterfaceResponse;
	alert 			: CM_SystemAlert;
	alertDetails	: String;
	terminal		: CM_Terminal;
	
begin
	if self.messageType = ITS_MESSAGETYPE_QUEUEENTRY then
		if self.isNAK or
		   self.isTimedOut then
			self.handleLateAcknowledgement(_passport);
		endif;
	
	elseif self.messageType = ITS_MESSAGETYPE_DELETEQE then
		if self.isDeleteAllQueueEntryResponse() then
			foreach activeResponse in self.myMachine.allITSInterfaceResponsesActive do
				activeResponse.removeFromActiveResponses();
			endforeach;
		else
			self.removeFromActiveResponses();
		endif;
	endif;

	//self.acknowledgedTS := _acknowledgedTS;
	self.setAcknowledgedTS(_acknowledgedTS); //cnwjo3 par 25401
	self.isNAK			:= false;
	self.isTimedOut		:= false;
		
	// There may be another response for the current machine in the To Send queue.
	// Was tempted to not include this notification as the next queue entry change for any machine will trigger the send.
	terminal := self.myITSInterfaceDefinition.myTerminal;
	terminal.causeEvent(terminal.getTerminalEvent(Event_ITS_SendResponse), false, null);
	
epilog

end;</source>
        <Parameter name="_acknowledgedTS" type="TimeStamp"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doAutoAcknowledge" id="d748384e-ca9a-451f-a93f-caf6fbcab3c6">
        <updating/>
        <source>doAutoAcknowledge(_passport : CM_Passport input) updating;

/*

Purpose:			Responses waiting for acknowledgement that have been NAK, or timed out, remain on the
					waiting list until further communication from the machine.  This prevents further
					queue entry responses being sent to the machine.
					This method removes the response from the waiting acknowledge list.
					For a response that has been NAK, it is completed like a response that has been ACK.
					For an active response that has been timed out, the response is resent.
					
Parameters:			None

Return Value:		None


Date		Who		Reason
05 Jan 2010	consw1	PAR #21593 - Development of CCMS MES 1014 - RDT ITS Interface

*/

vars
	activeResponse	: CM_ITSInterfaceResponse;
	proxyResponse	: CM_ITSInterfaceResponse;
	realResponse	: CM_ITSInterfaceResponse;
	
begin
	if self.acknowledgedTS &lt;&gt; null then
		return;
	endif;

	if self.isNAK then
		if self.messageType = ITS_MESSAGETYPE_DELETEQE then
			if self.isDeleteAllQueueEntryResponse() then
				foreach activeResponse in self.myMachine.allITSInterfaceResponsesActive do
					activeResponse.removeFromActiveResponses();
				endforeach;
			else
				self.removeFromActiveResponses();
			endif;
		endif;
			
	elseif self.isTimedOut then
		// Resend active response
		if self.isActive() then
			create proxyResponse transient;
			proxyResponse.setProxyForResend(self);
			app.myUtilityCA.utlCreateITSInterfaceResponse(proxyResponse, realResponse, null, _passport);
		endif;
	endif;
	
	//self.acknowledgedTS := app.actualTimeServer();
	self.setAcknowledgedTS(app.actualTimeServer());  //cnwjo3 par 25401

epilog
	delete proxyResponse;
	
end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doNAK" id="20eeb3ff-9968-4fff-83b6-45d8015c0d8d">
        <updating/>
        <source>doNAK() updating;

/*

Purpose:			Negative acknowledge response received by ITS.

Parameters:			None

Return Value:		None


Date		Who		Reason
05 Jan 2010	consw1	PAR #21593 - Development of CCMS MES 1014 - RDT ITS Interface

*/

vars
	alert 	: CM_SystemAlert;
		
begin
	if self.isNAK then
		return;
	endif;
	
	self.isNAK := true;
	
	if self.myMachine = null then
		return;
	endif;

	// Raise alert
	create alert transient;
	alert.myTerminal	:= self.myITSInterfaceDefinition.myTerminal;
	alert.details 		:= app.getErrorString1(ALERT_ITS_Response_NAK, self.myMachine.id);
	alert.setSeverity(SEVERE_ERROR);
	alert.add;
	app.commitAlert();

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doTimeout" id="a9ab7cb4-0bf2-47b6-89ab-12fc5013039f">
        <updating/>
        <source>doTimeout() updating;

/*

Purpose:			Timeout response that has not been acknowledged by ITS.

Parameters:			None

Return Value:		None


Date		Who		Reason
05 Jan 2010	consw1	PAR #21593 - Development of CCMS MES 1014 - RDT ITS Interface

*/

vars
	alert 	: CM_SystemAlert;
		
begin
	if self.isTimedOut then
		return;
	endif;
	
	self.isTimedOut := true;
	
	if self.myMachine = null then
		return;
	endif;

	// Raise alert
	create alert transient;
	alert.myTerminal	:= self.myITSInterfaceDefinition.myTerminal;
	alert.details 		:= app.getErrorString1(ALERT_ITS_Response_TimedOut, self.myMachine.id);
	alert.setMySystemAlertType(app.myRoot.allSystemAlertTypes[EVENT_AT_ExternalInterface]);
	alert.setSeverity(SEVERE_ERROR);
	alert.setLinkedTo(self.myITSInterfaceDefinition);
	alert.add;
	app.commitAlert();

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="formatTimeStampXML" id="8ce55d56-9dbd-43f6-8371-74d5e7155c7c">
        <source>formatTimeStampXML(_timeStamp : TimeStamp) : String;

/*

Purpose:			

Parameters:			None

Return Value:		Returns time stamp in format for Response message (W3C recommended XML format, without time zone modifier)


Date		Who		Reason
19 Nov 2009	consw1	PAR #21593 - Development of CCMS MES 1014 - RDT ITS Interface

*/

vars

begin
	if _timeStamp = null or
	   not _timeStamp.isValid() then
		return null;
	endif;
	
	return _timeStamp.date.format('yyy-MM-dd') &amp; "T" &amp; _timeStamp.time.format('HH:mm:ss');
	
epilog

end;</source>
        <Parameter name="_timeStamp" type="TimeStamp"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getErrorText" id="5478049f-812b-4e2a-91b1-24c8d319fe73">
        <source>getErrorText() : String;

/*

Purpose:			

Parameters:			None

Return Value:		Returns the error text truncated to the maximum length expected by ITS.
					Truncated errors are suffixed with "..."


Date		Who		Reason
08 Dec 2009	consw1	PAR #21593 - Development of CCMS MES 1014 - RDT ITS Interface

*/

vars

begin
	return self.errorMessage.truncateWithDotDotDot(CM_ITSInterfaceMessage.Length_ErrorText);
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getLocationType" id="163f6674-6aae-42d4-a450-0f0e21cd406b">
        <source>getLocationType(_location 	: CM_LocationsController;
				_isTarget	: Boolean 					) : String;

/*

Purpose:			Get Location Type.

Parameters:			Source or Target location.

Return Value:		Location Type as per table in section 9.2 of functional specification for RDT ITS Interface.


Date		Who		Reason
12 Jan 2010	consw1	PAR #21593 - Development of CCMS MES 1014 - RDT ITS Interface

*/
constants
	TypeVessel	= "901";
	TypeWagon	= "902";
	TypeMachine	= "903";
	TypeVehicle	= "904";
	TypeChassis	= "905";

vars

begin
	if _location = null then
		if _isTarget and
		   self.myRTQueueEntry &lt;&gt; null and
		   self.myRTQueueEntry.myNextRelatedEntry &lt;&gt; null and
		   self.myRTQueueEntry.myNextRelatedEntry.machineTypeGroup = MACHINETYPEGRP_IMV then
			return TypeMachine;
		endif;
		return null;
	endif;
	
	if _location.isKindOf(CM_YardController) then
		if _location.myTerminalArea &lt;&gt; null then
			return _location.myTerminalArea.type.stringWithLeadingZeros(3);
		endif;
	elseif _location.isKindOf(CM_VoyageController) then
		return TypeVessel;
	elseif _location.isKindOf(CM_WagonController) then
		return TypeWagon;
	elseif _location.isKindOf(CM_MachineController) then
		return TypeMachine;
	elseif _location.isKindOf(CM_VehicleController) then
		return TypeVehicle;
	elseif _location.isKindOf(CM_TILCController) then
		return TypeChassis;
	endif;
	
	return null;

epilog

end;</source>
        <Parameter name="_location" type="CM_LocationsController"/>
        <Parameter name="_isTarget" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getMessageXML" id="5000d50c-f5b8-49ba-8bf3-cc742c3cfc57">
        <source>getMessageXML(_timeSent : TimeStamp) : String;

/*

Purpose:			Get response message in XML format.

Parameters:			Time message is being sent.

Return Value:		Response in XML format.


Date		Who		Reason
24 Nov 2009	consw1	PAR #21593 - Development of CCMS MES 1014 - RDT ITS Interface

*/

vars
	machineId	: String;
	message		: String;
	msgContent	: String;
	msgHeader	: String;
	
begin
	if self.myMachine &lt;&gt; null then
		machineId := self.myMachine.id;
	endif;
	
	// Message Header

	self.appendXML(msgHeader, CM_ITSInterfaceMessage.XMLTag_MessageType, self.messageType);
	self.appendXML(msgHeader, CM_ITSInterfaceMessage.XMLTag_MachineId, machineId);
	self.appendXML(msgHeader, CM_ITSInterfaceMessage.XMLTag_MessageNumber, self.messageNumber.String);
	self.appendXML(msgHeader, CM_ITSInterfaceMessage.XMLTag_OriginalMsgNo, self.originalMsgNo.String);
	self.appendXML(msgHeader, CM_ITSInterfaceMessage.XMLTag_MessageVersion, self.messageVersion.String);
	
	self.appendXML(msgHeader, CM_ITSInterfaceMessage.XMLTag_TimeSent, self.formatTimeStampXML(_timeSent));
	
	if self.messageType = ITS_MESSAGETYPE_ERROR then
		self.appendXML(msgHeader, CM_ITSInterfaceMessage.XMLTag_ErrorCode, self.errorNumber.String);
		self.appendXML(msgHeader, CM_ITSInterfaceMessage.XMLTag_ErrorText, self.getErrorText().asXML());
	endif;

	// Message Content
	
	self.appendXML(msgContent, CM_ITSInterfaceMessage.XMLTag_MessageHeader, msgHeader);
	self.appendXML(msgContent, CM_ITSInterfaceMessage.XMLTag_MessageBody, self.messageBodyXML);
	
	self.appendXML(message, CM_ITSInterfaceMessage.XMLTag_Message, msgContent);
	
	return message;
	
epilog

end;</source>
        <Parameter name="_timeSent" type="TimeStamp"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getTargetLocation" id="95e040b2-75b3-495b-a02f-33bd8b6c11b4">
        <source>getTargetLocation(_task : CM_RTQueueTask) : CM_LocationsController;

/*

Purpose:			Get Target Location

Parameters:			Task

Return Value:		None


Date		Who		Reason
28 Jan 2010	consw1	PAR #21593 - Development of CCMS MES 1014 - RDT ITS Interface
25 Nov 2010	cnwkpd1	PAR #25681 - Multi machine Director task changes
31 May 2011	cnwkpd1	PAR #27656 - Handle invalid task object being passed in

*/

vars
	location	: CM_LocationsController;
	imvTask		: CM_RTQueueTask;
	relatedQE	: CM_RTQueueEntry;
	invalidTask	: Boolean;
	
begin
	on Exception do app.handleDeletedObject(exception, _task, invalidTask);
	
	location := _task.ultimateTargetLocation();
	
	relatedQE := _task.myEntry.getNextRelatedEntry(); //epr par 35702 17/2/15
	if relatedQE &lt;&gt; null and
	   relatedQE.machineTypeGroup = MACHINETYPEGRP_IMV then
		location := null;
		if relatedQE.status = ENTRY_WORKING then
//			imvTask := relatedQE.allTasks.first;				// PAR #25681 - first task can now be a Director
			imvTask := relatedQE.getFirstUncompletedTask();		// so find first incomplete on, which will be the Move
			if imvTask &lt;&gt; null then
				if imvTask.machine &lt;&gt; null then
					location := imvTask.machine.myMachineController;
				elseif imvTask.intendedMachine &lt;&gt; null then
					location := imvTask.intendedMachine.myMachineController;
				endif;
			endif;
		endif;
	endif;
	
	return location;
	
epilog

end;</source>
        <Parameter name="_task" type="CM_RTQueueTask"/>
        <ReturnType type="CM_LocationsController"/>
    </JadeMethod>
    <JadeMethod name="handleLateAcknowledgement" id="09968f18-a2ac-4ce7-add6-0e463d917b22">
        <updating/>
        <source>handleLateAcknowledgement(_passport : CM_Passport input) updating;

/*

Purpose:			This method is invoked when we have received an acknowledgement for a Queue Entry response
					that has already been NAK or has been timed out.  We need to check if the Queue Entry
					should be restored to the machines's active list or advise ITS to remove it from the Driver's list.

Parameters:			None

Return Value:		None


Date		Who		Reason
16 Dec 2009	consw1	PAR #21593 - Development of CCMS MES 1014 - RDT ITS Interface

*/

vars
	proxyResponse	: CM_ITSInterfaceResponse;
	realResponse	: CM_ITSInterfaceResponse;
	
begin
	if self.isActive() then
		return;
	endif;

	// Exit if the Queue Entry for this response is on the machine's active list
	if self.myMachine.allITSInterfaceResponsesActive[self.queueEntryID] &lt;&gt; null then
		return;
	endif;

	if self.myRTQueueEntry = null then
		// Handle deleted Queue Entry by requesting a delete at ITS
		create proxyResponse transient;
		proxyResponse.setProxyForDeleteQueueEntry(self);
		app.myUtilityCA.utlCreateITSInterfaceResponse(proxyResponse, realResponse, null, app.myPassport);
	else
		// Restore response to machine's active list
		self.restoreToActiveResponses(_passport);
	endif;		

epilog
	delete proxyResponse;
end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="hasEntryTypeChangedFromDirect" id="dbd721de-3237-48e5-81c7-93019fbac411">
        <source>hasEntryTypeChangedFromDirect(_task : CM_RTQueueTask) : Boolean;

/*

Purpose:			Check if the entry has been converted from a Director to a Move
					since this Queue Entry response was created.

Parameters:			The current task

Return Value:		True if the entry type has changed


Date		Who		Reason
25 Nov 2010	cnwkpd1	PAR #25681 - Multi Machine Director task changes

*/

vars
	entryValue		: String;
	startPos 		: Integer;

begin
	if _task.taskType &lt;&gt; TASK_DIRECTOR then
		startPos := 1;
		entryValue := self.messageBodyXML.getNextTagValueForName(CM_ITSInterfaceRequestMessage.XMLTag_EntryType, startPos);
		return entryValue = ITS_ENTRYTYPE_DIRECTOR;
	endif;
	
	return false;
	
epilog

end;</source>
        <Parameter name="_task" type="CM_RTQueueTask"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="hasTargetLocationChanged" id="f1204537-6fd6-4710-beb2-5f5ba01de626">
        <source>hasTargetLocationChanged(_task : CM_RTQueueTask) : Boolean;

/*

Purpose:			Check if the target location has changed since this Queue Entry response was created
					for a set down.

Parameters:			The current set down task

Return Value:		True if the target location has changed


Date		Who		Reason
14 Dec 2009	consw1	PAR #21593 - Development of CCMS MES 1014 - RDT ITS Interface

*/

vars
	location		: CM_LocationsController;
	locationValue	: String;
	startPos 		: Integer;

begin
	location := self.getTargetLocation(_task);
	if location &lt;&gt; null then
		locationValue := location.getFullIdForTI(true).asXML();
	endif;
		
	startPos := 1;
	return locationValue &lt;&gt; self.messageBodyXML.getNextTagValueForName(CM_ITSInterfaceRequestMessage.XMLTag_TargetLocation, startPos);
	
epilog

end;</source>
        <Parameter name="_task" type="CM_RTQueueTask"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isActive" id="b8b7fbdf-5d3e-4d7d-9b21-e56863ae2c65">
        <condition/>
        <source>isActive():Boolean condition;
// -----------------------------------------------------------------------------
// Created:		11 November 2009 by consw1
//
// Purpose:		Indicates Queue Entry is currently displayed by ITS (or will be once this message has been sent and acknowledged).
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//
// -----------------------------------------------------------------------------

begin
	if self.isReset then
		return false;
	endif;
	
	if self.messageType = ITS_MESSAGETYPE_QUEUEENTRY or
	   self.messageType = ITS_MESSAGETYPE_DELETEQE then
		return self.isCurrent;
	endif;
	
	return false;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isDeleteAllQueueEntryResponse" id="19ec57c5-9b1c-4edd-8da4-3c0fafe8fdff">
        <source>isDeleteAllQueueEntryResponse() : Boolean;

/*

Purpose:			

Parameters:			None

Return Value:		True when this response is a Delete Queue Entry response for ALL the machine's entries


Date		Who		Reason
22 Dec 2009	consw1	PAR #21593 - Development of CCMS MES 1014 - RDT ITS Interface

*/

vars

begin
	if self.messageType &lt;&gt; ITS_MESSAGETYPE_DELETEQE or
	   self.myRTQueueEntry &lt;&gt; null or
	   self.queueEntryID &lt;&gt; null then
		return false;
	endif;
	
	return true;
	
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isDisplayed" id="c7e4df44-ec57-4ad9-a812-fcda4071922b">
        <condition/>
        <source>isDisplayed():Boolean condition;
// -----------------------------------------------------------------------------
// Created:		11 November 2009 by consw1
//
// Purpose:		Indicates Queue Entry is currently displayed by ITS.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//
// -----------------------------------------------------------------------------

begin
	if not self.isUpdateToActiveQE then
		if self.processedTS = null or
		   self.acknowledgedTS = null or
		   self.isNAK or
		   self.isTimedOut then
			return false;
		endif;
	endif;
	
	return self.isActive();
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isToBeSent" id="0daadb1a-f53e-4c0d-abec-ba2b402dc891">
        <condition/>
        <source>isToBeSent():Boolean condition;
// -----------------------------------------------------------------------------
// Created:		11 November 2009 by consw1
//
// Purpose:		Indicates message is waiting to be sent to ITS.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//
// -----------------------------------------------------------------------------

begin
	if self.isReset then
		return false;
	endif;
	
	if self.messageType = ITS_MESSAGETYPE_QUEUEENTRY or
	   self.messageType = ITS_MESSAGETYPE_DELETEQE then
		return self.processedTS = null and self.isCurrent;
	endif;
	
	return self.processedTS = null;
end;</source>
        <text>Is waiting to be sent to ITS.</text>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isWaitingAcknowledge" id="e6df340f-e2b7-4f70-a9b1-ee599f3f3dcd">
        <condition/>
        <source>isWaitingAcknowledge():Boolean condition;
// -----------------------------------------------------------------------------
// Created:		11 November 2009 by consw1
//
// Purpose:		Indicates message has been sent to ITS and JMT is waiting for an acknowledgement from ITS.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//
// -----------------------------------------------------------------------------

begin
	if self.isReset then
		return false;
	endif;
	
	return self.processedTS &lt;&gt; null and self.acknowledgedTS = null;
end;</source>
        <text>Is waiting for acknowledgement from ITS.</text>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="populateCmifMessage" id="b2ca9392-ba10-442f-b7df-d755d23c79a8">
        <source>populateCmifMessage(_cmifMsg: CMIF_ITSInterfaceMsg input; _validateFormat: Boolean);

/*

Purpose:			Get property values that may be stored in xml data.

Parameters:			_validateFormat - if true, an exception will be raised when invalid xml data is encountered.

Return Value:		_cmifMsg will be populated with values from message.


Date		Who		Reason
19 Nov 2009	consw1	PAR #21593 - Development of CCMS MES 1014 - RDT ITS Interface

*/

vars
	invalidXML		: Boolean;
	msgContent		: String;
	xmlDoc			: JadeXMLDocument;
	
begin
	inheritMethod(_cmifMsg, _validateFormat);
	
	// Header Section

	_cmifMsg.messageType		:= self.messageType;
	_cmifMsg.messageNumber		:= self.messageNumber;
	_cmifMsg.originalMsgNo		:= self.originalMsgNo;
	_cmifMsg.messageVersion		:= self.messageVersion;
	_cmifMsg.timeSent			:= self.formatTimeStampXML(self.processedTS);
	_cmifMsg.errorCode			:= self.errorNumber;
	_cmifMsg.errorText			:= self.getErrorText();

	if self.messageType = ITS_MESSAGETYPE_ERROR then
		// Just the header values
		return;
	endif;
	
	// Body Section
	
	self.appendXML(msgContent, CM_ITSInterfaceMessage.XMLTag_MessageBody, self.messageBodyXML);
	
	on JadeXMLException do handleXMLException(exception, invalidXML);

	create xmlDoc transient;
	xmlDoc.parseString(msgContent);
	
	if invalidXML then
		if _validateFormat then
			app.raiseCMException1(ERR_Parsing_XML, msgContent , null, null);
		endif;
		return;
	endif;
	
	_cmifMsg.queueEntryId	:= self.findXMLInteger( xmlDoc, self.XMLTag_QueueEntryId, _validateFormat );
	_cmifMsg.containerId	:= self.findXMLString( xmlDoc, self.XMLTag_CargoId, self.Length_CargoID, _validateFormat );
		
	if self.messageType = ITS_MESSAGETYPE_DELETEQE then
		return;
	endif;
	
	_cmifMsg.entryType			:= self.findXMLString( xmlDoc, self.XMLTag_EntryType, self.Length_EntryType, _validateFormat );
	_cmifMsg.cargoAttributes	:= self.findXMLString( xmlDoc, self.XMLTag_CargoAttributes, self.Length_CargoAttributes, _validateFormat );
	_cmifMsg.despatchNow		:= self.findXMLString( xmlDoc, self.XMLTag_DespatchNow, self.Length_DespatchNow, _validateFormat );

	_cmifMsg.sourceLocationType	:= self.findXMLString( xmlDoc, self.XMLTag_SourceLocationType, self.Length_LocationType, _validateFormat );
	_cmifMsg.sourceLocation		:= self.findXMLString( xmlDoc, self.XMLTag_SourceLocation, self.Length_Location, _validateFormat );
	_cmifMsg.sourceAttributes	:= self.findXMLString( xmlDoc, self.XMLTag_SourceAttributes, self.Length_LocationAttributes, _validateFormat );
	
	_cmifMsg.targetLocationType	:= self.findXMLString( xmlDoc, self.XMLTag_TargetLocationType, self.Length_LocationType, _validateFormat );
	_cmifMsg.targetLocation		:= self.findXMLString( xmlDoc, self.XMLTag_TargetLocation, self.Length_Location, _validateFormat );
	_cmifMsg.targetAttributes	:= self.findXMLString( xmlDoc, self.XMLTag_TargetAttributes, self.Length_LocationAttributes, _validateFormat );
	
	_cmifMsg.weight				:= self.findXMLInteger( xmlDoc, self.XMLTag_Weight, _validateFormat );
	_cmifMsg.requiresWeighing	:= self.findXMLString( xmlDoc, self.XMLTag_RequiresWeighing, self.Length_RequiresWeighing, _validateFormat );
	
epilog
	delete xmlDoc;
end;</source>
        <Parameter name="_cmifMsg" type="CMIF_ITSInterfaceMsg" usage="input"/>
        <Parameter name="_validateFormat" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="removeFromActiveResponses" id="5fc36157-ba0e-4679-9cf5-fa4c97e46621">
        <updating/>
        <source>removeFromActiveResponses() updating;

/*

Purpose:			Remove response from list of active responses

Parameters:			

Return Value:		None


Date		Who		Reason
23 Nov 2009	consw1	PAR #21593 - Development of CCMS MES 1014 - RDT ITS Interface

*/

vars

begin
	//self.isCurrent := false;
	self.setIsCurrent(false);  //cnwjo3 par 25401
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="restoreToActiveResponses" id="9949e739-2215-499d-be49-4d3043721b66">
        <updating/>
        <source>restoreToActiveResponses(_passport : CM_Passport input) updating;

/*

Purpose:			Restore this Queue Entry response to the machine's list of active responses

Parameters:			

Return Value:		None


Date		Who		Reason
16 Dec 2009	consw1	PAR #21593 - Development of CCMS MES 1014 - RDT ITS Interface

*/

vars
	lastRequest		: CM_ITSInterfaceReqAddQEntry;
	proxyRequest	: CM_ITSInterfaceReqAddQEntry;
	realRequest		: CM_ITSInterfaceRequest;
	
begin
	//self.isCurrent	:= true;
	self.setIsCurrent(true);  //cnwjo3 par 25401

	// Need to check if the Queue Entry is still appropriate for machine etc.
	// Get the usual RT Queue change processing to do the tidy up.
	
	lastRequest := self.myRTQueueEntry.allITSInternalAddRequests.last;

	// Exit when there is already a change request waiting to be actioned
	if lastRequest &lt;&gt; null and
	   lastRequest.isToBeActioned() then
		return;
	endif;
	
	create proxyRequest transient;
	proxyRequest.setProxy(self.myRTQueueEntry, self.myITSInterfaceDefinition);
	app.myUtilityCA.utlCreateITSInterfaceRequest(proxyRequest, realRequest, _passport);
	
epilog
	delete proxyRequest;
end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setAcknowledgedTS" id="e4031889-9425-4b5c-a948-4d1cc4155082">
        <updating/>
        <source>setAcknowledgedTS(_acknowledgedTS : TimeStamp) updating;
// --------------------------------------------------------------------------------
// Created:		23 August 2010 by cnwjo3
//
// Purpose:		par 25401
//
vars

begin
