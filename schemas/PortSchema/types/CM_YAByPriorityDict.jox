<CollClass name="CM_YAByPriorityDict" id="33ee4139-5338-4ae4-8b32-5f35c50509db">
    <duplicatesAllowed/>
    <loadFactor>66</loadFactor>
    <memberType name="CM_YardAllocation"/>
    <superclass name="MemberKeyDictionary"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <access>protected</access>
