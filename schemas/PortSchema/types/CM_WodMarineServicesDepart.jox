    <JadeMethod name="getExtraInfo" id="51675358-e64b-4215-a2ec-75b870a9414c">
        <source>getExtraInfo(_dataContainer: CM_DataContainer);
/*

Purpose:		TFS 39718	

Parameters:			

Return Value:		

Date		Who		Reason
11 Jul 2018	jlgab1	Initial creation
30 Nov 2021 navma1	Bug 52482: SAL - Web Portal - Cargo Work Orders
*/

vars
	block  : CM_DataContainerBlock;
	wodres : CM_WodMarineServiceDetail;
begin
	inheritMethod(_dataContainer);

	block := _dataContainer.addNewBlock;
	block.addNewItem(app.getErrorString(Occurs_datetime), DC_Label, 1, null);
	block.addNewItem( self.systemToLocalTime(self.getOccursDT()).asStringJMT() , DC_Data, 1, null);
	
	//19 Sep 2018	NDL	TFS 40810
	// ### BOW MARK
	block := _dataContainer.addNewBlock;
	block.addNewItem(app.getErrorString(MOVEHEAD_MarkBow), DC_Label, 1, null);
	block.addNewItem(self.bowMarkTo.asStringJMT() , DC_Data, 1, null);
	
	// ### DRAFT AFT
	block := _dataContainer.addNewBlock;
	block.addNewItem(app.getErrorString(Draft_aft), DC_Label, 1, null);
	block.addNewItem(self.draftAft.asStringJMT() , DC_Data, 1, null);
	
	// ### DRAFT FORWARD
	block := _dataContainer.addNewBlock;
	block.addNewItem(app.getErrorString(Draft_fore), DC_Label, 1, null);
	block.addNewItem(self.draftFwd.asStringJMT() , DC_Data, 1, null); 
	
	if self.myTowingVoyage &lt;&gt; null then
		block := _dataContainer.addNewBlock;
		block.addNewItem(app.getErrorString(Towing_voyage_code), DC_Label, 1, null);
		block.addNewItem(self.myTowingVoyage.code , DC_Data, 1, self.myTowingVoyage);                      //30.11.2021 navma1 #52482
	endif;
	
	foreach wodres in self.allMarineServiceDetails do
	
		wodres.getExtraInfo(_dataContainer);
	endforeach;
epilog

end;</source>
        <Parameter name="_dataContainer" type="CM_DataContainer"/>
    </JadeMethod>
    <JadeMethod name="getInvFromDateTime" id="2869bd18-5415-4966-a8a3-2575cc62c74d">
        <source>getInvFromDateTime(): TimeStamp;
/*

Purpose:		TFS 39237	

					get the oldest time stamp from the possible collection of WODs
					if these WO are created on the web portal for Pelindo1 there will be only one wod

Return Value:		

Date		Who		Reason
25 June 2018	jlgab1	Initial creation

*/

vars
	msd : CM_WodMarineServiceDetail;
	fdt, msdfdt : TimeStamp;
	d : Date;
	found : Boolean;
begin
	d.setDate(31,12,3000);
	fdt.setDate(d);

	
	foreach msd in self.allMarineServiceDetails	discreteLock do
		msdfdt :=msd.getInvFromDateTime();
		
		if msdfdt.isValid() then
			if msdfdt &lt; fdt then
				fdt := msdfdt;
				found := true;
			endif;
		endif;
	endforeach;

	if found then
		return fdt;
	else
		return null;
	endif;
epilog

end;</source>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="getInvToDateTime" id="9dcace1b-4724-4625-a8c5-210ce488337e">
        <source>getInvToDateTime(): TimeStamp;
/*

Purpose:		TFS 39237	

Parameters:	get the oldest time stamp from the possible collection of WODs
					if these WO are created on the web portal for Pelindo1 there will be only one wod

Return Value:		

Date		Who		Reason
25 June 2018	jlgab1	Initial creation

*/

vars
	msd : CM_WodMarineServiceDetail;
	tdt, msdtdt : TimeStamp;
	d : Date;
	found : Boolean;
begin
	d.setDate(31,12,3000);
	tdt.setDate(d);

	
	foreach msd in self.allMarineServiceDetails	discreteLock do
		msdtdt :=msd.getInvToDateTime();
		
		if msdtdt.isValid() then
			if msdtdt &lt; tdt then
				tdt := msdtdt;
				found := true;
			endif;
		endif;
	endforeach;

	if found then
		return tdt;
	else
		return null;
	endif;
epilog

end;</source>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="getInvUnitsUsed" id="ec900231-b0ae-4d3e-a5a6-68d2ec15e058">
        <source>getInvUnitsUsed(): Real;
/*

Purpose:	TFS 39237		

Parameters:			

Return Value:		

Date		Who		Reason
25 June 2018	jlgab1	Initial creation

*/

vars
	msd : CM_WodMarineServiceDetail;
	uu : Real;
begin

	foreach msd in self.allMarineServiceDetails	discreteLock do
		uu := uu + msd.getInvUnitsUsed();
	endforeach;
	

	return uu;

epilog

end;</source>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="getMyBerth" id="ac914940-4709-43b0-9145-bab6e4cc5a72">
        <source>getMyBerth(): HMS_Berth;
/*

Purpose:			TFS 42161

Parameters:			

Return Value:		

Date		Who		Reason
10 December 2018	jlgab1	Initial creation

*/

vars

	voyage : CM_Voyage;
	departMovement : HMS_VoyageMovement;
	prevMovement : HMS_VoyageMovement;

begin

	voyage := self.getMyVoyageObject();

	if voyage &lt;&gt; null then
		departMovement := voyage.getMovementDeparture();
		if departMovement &lt;&gt; null then
			prevMovement := departMovement.myPreviousMovement.HMS_VoyageMovement;
			if prevMovement &lt;&gt; null then
				return prevMovement.getMyBerth;
			endif;
		endif;
	endif;
	
	return inheritMethod();
	

epilog

end;</source>
        <ReturnType type="HMS_Berth"/>
    </JadeMethod>
    <JadeMethod name="getOccursDT" id="63bbaefd-07e7-497a-a231-87e2cd4f233b">
        <source>getOccursDT() : TimeStamp;
/*

Purpose:			// TFS 40747 

Parameters:			

Return Value:		

Date		Who		Reason
07 September 2018	jlgab1	Initial creation

*/

vars
	voyage : CM_Voyage;
begin
	//19 Sep 2018	NDL	TFS 40810
	if self.requiredByDT.date.isValid then
		return self.requiredByDT;
	endif;

	voyage := self.getMyVoyageObject();
	if voyage &lt;&gt; null then
		return voyage.departedDT;
	endif;
	
	return self.createdTime;
epilog

end;</source>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="getStatusForApproved" id="687ee358-3c9d-4410-90cd-8ef7dad50ce1">
        <source>getStatusForApproved(_voyage: CM_Voyage): CM_VoyageStatus;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 19/07/2018	jlgdap1		Initial creation TFS 39815 PEL1 WO Approved Set Voyage Status
//
vars
	status : CM_VoyageStatus;

begin
	if _voyage.myVoyageProcess.isMTNWOProcess then //jlier1 TFS 51963 1/10/21
		status := app.myRoot.allVoyageStatuses[Voyage_Status_DepServApproved];
	endif;
	
	return status;
epilog

end;</source>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <ReturnType type="CM_VoyageStatus"/>
    </JadeMethod>
    <JadeMethod name="getSternMark" id="16f6bd09-a145-4fa4-b758-61df6ad163ef">
        <source>getSternMark(): Decimal;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 November 2018	jlger1	Initial creation

*/

vars	
	voyage : CM_Voyage;
	voyageData : HMS_VoyageData;
begin	
	voyage := self.getMyVoyageObject;
	
	if voyage = null then
		return null;
	endif;
	
	voyageData:=voyage.myHMSVoyageData;
	if voyageData = null then
		return null;
	endif;
	
	return self.bowMarkTo + voyageData.dim_LengthOverall;

epilog

end;</source>
        <ReturnType type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="getWOTransactionType" id="f09d6bf6-70cb-477c-97b4-308c6eef33f1">
        <source>getWOTransactionType(): Integer;
/*

Purpose:			 // TFS 38524

Parameters:			

Return Value:		

Date		Who		Reason
17 May 2018	jlgab1	Initial creation

*/

vars

begin
	return TRANS_TYPE_WO_MARINESERVICEDEP; 

epilog

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="30defa6a-9721-4d9b-a50d-71c3cf214666">
        <source>pxyCreateUpdateProxy(): SelfType;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 June 2018	jlger1	Initial creation

*/

vars
	pxySelf : CM_WodMarineServicesDepart;
	completedOK : Boolean;
	pxyMarineService,
	marineService : CM_WodMarineServiceDetail;
	
begin
	
	pxySelf:= inheritMethod();
	foreach marineService in self.allMarineServiceDetails discreteLock do
		pxyMarineService:= marineService.pxyCreateUpdateProxy;
		if pxyMarineService &lt;&gt; null then	//17 Jul 2018	NDL	TFS 39742
			pxySelf.allMarineServiceDetails.add(pxyMarineService);
		endif;
	endforeach;
	pxySelf.myTowingVoyage := self.myTowingVoyage;	//20 Sep 2018	NDL	TFS 40810
	
	completedOK:=true;
	return pxySelf;
epilog
	if not completedOK then
		delete pxySelf;
	endif;
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="requiresLengthOfTime" id="3e7c21ec-d596-44cf-9aba-2b7f4613cea3">
