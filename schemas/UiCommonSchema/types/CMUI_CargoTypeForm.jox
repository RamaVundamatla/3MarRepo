        <updating/>
        <source>displayProductDefaultsNew(_cargoType : CM_CargoType;_productType : Integer) updating;
/*

Purpose:			


Return Value:		


Date		Who		Reason
05/04/2007	cnwer1	Initial creation - PAR#xxxx
19/03/2014	cnwdap1	PAR #33606 CCMS SFW 1366 Bulk
16/02/2018  cnwer1	TFs 7766 tidied up the attributes for bulk and car for web portal 
07/05/2020	jlgdap1	TFS 49252 CPL Cargo Types not showing in System Admin
*/
vars
	proDefault				: String;
	table					: CM_DataTable;
	entRow					: EntTableRow;
	entDef					: EntTableDef;
	isViewable				: Boolean;
	idx, colDefVal			: Integer;
	editMode				: Boolean;
	cargoSubtypeRequired	: Boolean;	
	systemProdType		: CM_Product;
begin
	table := self.tblDefaultValues;
	if _cargoType &lt;&gt; null then
		if _cargoType.isSystemCargoBOLType or							// PAR #33606
		   //_cargoType.id &gt; TI_CargoBOLType_JMTMax then										// TFS 49252
		   (_cargoType.id &gt; TI_CargoBOLType_JMTMax and not app.myRoot.isClientCentrePort) then	// TFS 49252
			table.visible := false;
			return;
		endif;
	endif;
	
	
	editMode := (self.mode = self.Mode_Add) or (self.mode = self.Mode_Update);
	if editMode then	//Edit mode
		cargoSubtypeRequired := self.tblEntDetail.getValueByName(ETRow_IsSubCargoTypeRequired).Boolean;	//PAR 21339 Oct 2009
		systemProdType := self.pxySystemProductType;
		if self.pxySystemProductType = null then
			self.getSystemProduct(cargoSubtypeRequired);
			systemProdType:=self.pxySystemProductType;
		endif;
	else		// VIEW mode
		if _cargoType &lt;&gt; null then
			cargoSubtypeRequired := _cargoType.isSubCargoTypeRequired;
			systemProdType := _cargoType.mySystemProductType;
		endif;
	endif;
	self.showProductTypeAttributes(not cargoSubtypeRequired);
	self.displayProductTypeAttributes(_cargoType,_productType);
	if (not self.tblAttributes.visible and not self.tblDefaultValues.visible) then
		return;
	endif;
	//when isSubCargoTypeRequired then show tblAttributes 
	if not cargoSubtypeRequired then
		self.displayAttributes(systemProdType,_productType);
		return;
	endif;
	
	table.visible := true;
	entDef := self.getAllAttributesDef;
	
	table.rows := table.fixedRows;
	colDefVal := table.getColumnByRowName(ETRow_DefaultProdValue);

	foreach entRow in entDef.allEntTableRows do
	
		isViewable := true;

		if _productType = ProductType_Bulk then
			if  (entRow.name = ETRow_MyType or entRow.name =ETRow_MyLengthString or entRow.name = ETRow_MyWidthString or entRow.name = ETRow_MyHeightString)   then
				continue;
			endif;
		elseif _productType = ProductType_Vehicle  then
			if entRow.name &lt;&gt; ETRow_MyLength and  entRow.name &lt;&gt; ETRow_MyWidth and entRow.name &lt;&gt; ETRow_MyHeight then
				continue;
			endif;
		endif;
		
		if _cargoType &lt;&gt; null then
			if ( not _cargoType.allAttributesOnProduct.includes(entRow.name) ) then
			// This is the new one for after 7.4.1 release	
			//if not _cargoType.getAttributeValue(entRow.name).Boolean then
				isViewable := false;
			endif;
			proDefault := _cargoType.getDefaultValueByName(entRow.name);
		endif;
		
		idx := table.addItem(entRow.getHeading(_cargoType, self.myTerminal, app.myCurrentLocale) &amp; Tab &amp; 
				isViewable.cnEcGetTableCheckBoxValue &amp; Tab &amp;
				proDefault); 
				
		if 	entRow.name	= ETRow_MyType or
			entRow.name = ETRow_MyWidthString or 
			entRow.name = ETRow_MyHeightString or 
			entRow.name = ETRow_MyLengthString then 
			// is string
			table.accessCell(idx , colDefVal).inputType := CM_DataTable.InputType_TextBox;	
			table.accessCell(idx , colDefVal).maxLength := 30; // any more than this and it will get ex. 
		elseif entRow.name = ETRow_MyVolume then 
			// is decimal		
			table.accessCell(idx , colDefVal).inputType := CM_DataTable.InputType_TextNumeric;
			table.accessCell(idx , colDefVal).decimals := 3;
			table.accessCell(idx , colDefVal).maxLength := 12; // any more than this and it will get ex. 
		else		
			// will be an integer (all other attributes are currently integers)
			table.accessCell(idx , colDefVal).inputType := CM_DataTable.InputType_TextNumeric;
			table.accessCell(idx , colDefVal).maxLength := 9; // any more than this and it will get ex. 
		endif;			

		// R Barr 2/11/2006 Comalco - Bulk product restricted attribute list means storing EntTableRow against table row for reconcilliation when saving
		table.accessRow(idx).itemObject := entRow;

	endforeach;
	
epilog

end;</source>
        <Parameter name="_cargoType" type="CM_CargoType"/>
        <Parameter name="_productType" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="displayProductTypeAttributes" id="17296ece-b389-48de-a8ef-ba9e45c1037b">
        <source>displayProductTypeAttributes(_cargoType : CM_CargoType; _productType : Integer) protected;
/* ---------------------------------------------------------------------------
Created:	22 May 2009	by cnwvu1

Purpose:	Product Type means Cargo Subtype
   
Change Date		Who		Reason
20/03/2014		cnwdap1	PAR #33606 CCMS SFW 1366 Bulk - Track as Vehicle should be allowed attributes
16/02/2018 		cnwer1	TFs 7766 removed code that was already called and need product type for add/edit
18.05.2022		navds20 ChangeRequest 53508: EUP - Cargo Uniqueness - UI
21 July 2022    navvt20 ChangeRequest 53917: MTN - Cargo Types TEUs for GC
09/08/2022      navds20	ChangeRequest 54219: EUP - Cargo Group to be mandatory
01/05/2023		jlizm1	TFS 55453 Cargo uniqueness by subtype
11 July 2023 navmv20 CR 58244 Task 58245: UI - Multiple Operators
------------------------------------------------------------------------------*/
vars
	tbl : CM_EntryTable;
begin
	
	tbl := self.tblEntDetail;						//08.09.2022 navma1 #54219
	
	//02 Jun 2015	NDL	Par 36338
	if _productType = ProductType_CargoGroup then
		tbl.hideRowByName(ETRow_IsCommodityRequired, false);
		tbl.hideRowByName(ETRow_DefaultCommodityCode, false);
		tbl.hideRowByName(ETRow_IsSubCargoTypeRequired, false);											
		tbl.hideRowByName(ETRow_NumberOfProducts, false);
		tbl.hideRowByName(ETRow_IsWeighable, false);
		tbl.hideRowByName(ETRow_IsCheckMaxLift, false);
		tbl.hideRowByName(ETRow_IncludeInStorage, false);
		tbl.hideRowByName(ETRow_ShowDamageCodes, false);
		tbl.hideRowByName(ETRow_AllowDuplicates, false);
		tbl.hideRowByName(ETRow_UseCGForUniqueness,false);	//18.05.2022 navds20 TFS 53508
		tbl.hideRowByName(ETRow_UseSubTypeForUniqueness,false);	// TFS 55453
		tbl.hideRowByName(ETRow_IsCargoGroupRequired,false);  //09/08/2022 navds20 TFS 54219
		tbl.hideRowByName(ETRow_AllowMultiOperators, false); //11/07/2023 navmv20 CR 58244 Task 58245
		tbl.hideRowByName(ETRow_DefaultWeightType, false);
		tbl.hideRowByName(ETRow_DefaultVolumeType, false);
		tbl.hideRowByName(ETRow_DrawAttribute, false);
		tbl.hideRowByName(ETRow_CreateBOL, false);		
		tbl.hideRowByName(ETRow_ChgToStorageOnUnpack, false);
		tbl.hideRowByName(ETRow_UseTareCargoWeight, false);
		tbl.hideRowByName(ETRow_AutoTareCargoWeightCalc, false);					//navra1 - TFS 63624 - 15th Apr 2024
		tbl.hideRowByName(ETRow_CanWeightBeCertified, false);
		tbl.hideRowByName(ETRow_BehaviourType, false);
		tbl.hideRowByName(ETRow_TeuMultiplier, false);
		tbl.hideRowByName(ETRow_TeuConversionGC, false);
		tbl.hideRowByName(ETRow_SaveLocationActivity, false);		//13 Apr 2021	NDL	TFS 50906
		tbl.hideRowByName(ETRow_TeuConversionGCBreakBulk,false);	// 21 July 2022 navvt20 53917
		tbl.hideRowByName(ETRow_TeuConversionGCBulk,false);			 // 21 July navvt20 53917
	else
		tbl.showRowByName(ETRow_IsCommodityRequired, false);
		tbl.showRowByName(ETRow_DefaultCommodityCode, false);
		tbl.showRowByName(ETRow_IsSubCargoTypeRequired, false);											
		tbl.showRowByName(ETRow_NumberOfProducts, false);
		tbl.showRowByName(ETRow_IsWeighable, false);
		tbl.showRowByName(ETRow_IsCheckMaxLift, false);
		tbl.showRowByName(ETRow_IncludeInStorage, false);
		tbl.showRowByName(ETRow_ShowDamageCodes, false);
		tbl.showRowByName(ETRow_AllowDuplicates, false);
		tbl.showRowByName(ETRow_DefaultWeightType, false);
		tbl.showRowByName(ETRow_DefaultVolumeType, false);
		tbl.showRowByName(ETRow_DrawAttribute, false);
		tbl.showRowByName(ETRow_CreateBOL, false);		
		tbl.showRowByName(ETRow_ChgToStorageOnUnpack, false);
		tbl.showRowByName(ETRow_UseTareCargoWeight, false);
		tbl.showRowByName(ETRow_CanWeightBeCertified, false);
		tbl.showRowByName(ETRow_BehaviourType, false);
		tbl.showRowByName(ETRow_TeuMultiplier, false);
		tbl.showRowByName(ETRow_SaveLocationActivity, false);	//13 Apr 2021	NDL	TFS 50906
		
		if tbl.getValueByName((ETRow_UseTareCargoWeight)).Boolean then					//navra1 - TFS 63624 - 15th Apr 2024
			tbl.showRowByName(ETRow_AutoTareCargoWeightCalc, false);					//navra1 - TFS 63624 - 15th Apr 2024
		else																			//navra1 - TFS 63624 - 15th Apr 2024
			tbl.hideRowByName(ETRow_AutoTareCargoWeightCalc, false);					//navra1 - TFS 63624 - 15th Apr 2024
		endif;																			//navra1 - TFS 63624 - 15th Apr 2024
		
		//start 09/08/2022 navds20 TFS 54219
		if app.isCargoGroupEnabled then
			tbl.showRowByName(ETRow_IsCargoGroupRequired, false);
			//11/07/2023 navmv20 CR 58244 Task 58245- start
			if tbl.getValueByName((ETRow_IsCargoGroupRequired)).Boolean then
				tbl.showRowByName(ETRow_AllowMultiOperators, false);
		    else
				tbl.hideRowByName(ETRow_AllowMultiOperators, false);
			endif;
			//11/07/2023 navmv20 CR 58244 Task 58245 - end
		else
			tbl.hideRowByName(ETRow_IsCargoGroupRequired, false);
			tbl.hideRowByName(ETRow_AllowMultiOperators, false); //11/07/2023 navmv20 CR 58244 Task 58245
		endif;
		//end 09/08/2022 navds20 TFS 54219
		
		//Start 18.05.2022 navds20 TFS 53508
		if app.isCargoGroupEnabled and tbl.getValueByName((ETRow_AllowDuplicates)).Boolean and 
		(_productType = ProductType_Bulk or _productType = ProductType_BreakBulk) then
			tbl.showRowByName(ETRow_UseCGForUniqueness,false);
		else
			tbl.hideRowByName(ETRow_UseCGForUniqueness,false);
			tbl.setValueByName(ETRow_UseCGForUniqueness, null);
		endif;
		//End 18.05.2022 navds20 TFS 53508 
		
		if tbl.getValueByName((ETRow_AllowDuplicates)).Boolean
		and (_productType = ProductType_Bulk or _productType = ProductType_BreakBulk) then	// TFS 55453
			tbl.showRowByName(ETRow_UseSubTypeForUniqueness,false);		// TFS 55453
		else
			tbl.hideRowByName(ETRow_UseSubTypeForUniqueness,false);		// TFS 55453
			tbl.setValueByName(ETRow_UseSubTypeForUniqueness, null);	// TFS 55453
		endif;
		
		// START 02/06/2022 navvt20 TFS 53751 &amp; 53758
		if _productType=ProductType_Vehicle or _productType=ProductType_Trailer then
			tbl.hideRowByName(ETRow_AllowDuplicates, false);
			tbl.setValueByName(ETRow_AllowDuplicates, null);
			tbl.hideRowByName(ETRow_UseCGForUniqueness,false);
			tbl.setValueByName(ETRow_UseCGForUniqueness, null);
			
		endif;
		if _productType=ProductType_Bulk then
			tbl.showRowByName(ETRow_DefaultVolumeType,false);
			tbl.showRowByName(ETRow_DefaultWeightType,false);
		else
			tbl.hideRowByName(ETRow_DefaultVolumeType,false);
			tbl.setValueByName(ETRow_DefaultVolumeType, null);
			tbl.hideRowByName(ETRow_DefaultWeightType,false);
			tbl.setValueByName(ETRow_DefaultWeightType, null);
		endif;
		// END 02/06/2022 navvt20 TFS 53751 &amp; 53758
	endif; 
	
	if _cargoType &lt;&gt; null and _cargoType.isSystemCargoBOLType
	or _productType = ProductType_Trailer 
	or _productType = ProductType_CargoGroup 
	then
		self.tblAttributes.visible := false;
		self.tblDefaultValues.visible := false;
		return;	// tables are hidden for system cargo types all the time
	endif;
	
end;</source>
        <access>protected</access>
        <Parameter name="_cargoType" type="CM_CargoType"/>
        <Parameter name="_productType" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="displaySealTypes" id="0a5320cc-3a2a-45bb-b08a-63f10117ab88">
        <source>displaySealTypes(_sealType : CM_SealType) : String;
//16 August 2010	cnwml2
//+cnwml2 PAR23715 SFW CCMS 1131

vars

begin
	return _sealType.sealType;
epilog

