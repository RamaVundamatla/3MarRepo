begin
	txtEnvid.text		:=myBmkControl.envid;
	txtRunid.text		:=myBmkControl.runid;
	txtRapHost.text		:=myBmkControl.rapHost;
	txtHost.text		:=myBmkControl.appServerHost;
	txtControlPort.text	:=myBmkControl.controlPort;
	txtProduct.text		:=myBmkControl.product;
	txtSchema.text		:=myBmkControl.schemaName;
