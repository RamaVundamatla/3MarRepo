    <JadeMethod name="createEmptyPeer" id="4651677a-49e2-4770-8fa0-4f06dd743870">
        <updating/>
        <source>createEmptyPeer(_parent : SOP_ViewModelObject) updating;
// -----------------------------------------------------------------------------
// Created:		19 March 2002 by cnwka1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	---------------------------------------------
//
// -----------------------------------------------------------------------------
begin
	create myObject as self.getPeerClass() transient;
	self.myParent := _parent;
end;</source>
        <Parameter name="_parent" type="SOP_ViewModelObject"/>
    </JadeMethod>
    <JadeMethod name="createPeer" id="43002333-f094-4edd-9ec1-95d6e449372a">
        <updating/>
        <source>createPeer() : SOP_ViewModelObject updating;
// -----------------------------------------------------------------------------
// Created:		19 March 2002 by cnwka1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	---------------------------------------------
//
// -----------------------------------------------------------------------------
vars
	peer : SOP_ViewModelObject;
begin
	
	create peer as self.class transient;
	peer.createEmptyPeer(self.myParent);
	return peer;
end;</source>
        <ReturnType type="SOP_ViewModelObject"/>
    </JadeMethod>
