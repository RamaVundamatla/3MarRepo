    <JadeMethod name="tblContainer_cellInputReady" id="99096e3e-c887-4b32-bfc6-0a1e34eb1f0f">
        <controlMethod name="CM_EntryTable::cellInputReady"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblContainer_cellInputReady(table: Table input; inputControl: Control input; cleft: Real io; ctop: Real io; cwidth: Real io; cheight: Real io) updating;
//23 August 2010	cnwml2
//+cnwml2 PAR23715 SFW CCMS1131
//09/04/2013	cnwdap1		PAR #31155 CCMS SFW 1321 Imperial Measurements
//20/05/2013	cnwdap1		PAR #31574 Allowable time off power editing
vars
	seal : CM_SealTI;
begin
	
	if inputControl.isKindOf(CM_Table) and inputControl.CM_Table.name.startsWith("tblSeals") then
		inputControl.CM_Table.rows := 10;  
		inputControl.CM_Table.selectMode := inputControl.CM_Table.SelectMode_CurrentRow; 
		if self.myTI &lt;&gt; null then
			foreach seal in self.myTI.allSeals do
				if inputControl.CM_Table.name = "tblSeals" &amp; seal.sealType then
					self.setSealTable(table.CM_EntryTable.getValueByName("DtRow_" &amp; seal.sealType).String);
					break;
				endif;
			endforeach;
		endif;
		table.accessRow(table.row).height := 120;
	endif;
	
	// PAR #31155 measurement tables
	if CMUI_MeasurementTable.hasInstance(inputControl) and not inputControl = self.tblMeasurement then	// PAR #31155
		app.doMeasureTableCellInputReady(table, inputControl);											// PAR #31155
	endif;																								// PAR #31155
	
	if inputControl = self.txtTimeOffPower then																// PAR #31574
		self.txtTimeOffPower.text := table.CM_EntryTable.getValueByName(ETRow_AllowableTimeOffPower).String;// PAR #31574
	endif;																									// PAR #31574
epilog

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="inputControl" type="Control" usage="input"/>
        <Parameter name="cleft" type="Real" usage="io"/>
        <Parameter name="ctop" type="Real" usage="io"/>
        <Parameter name="cwidth" type="Real" usage="io"/>
        <Parameter name="cheight" type="Real" usage="io"/>
    </JadeMethod>
    <JadeMethod name="tblContainer_contextMenu" id="a5141fc5-aca4-49af-a7ae-93d79d81ec32">
        <controlMethod name="Table::contextMenu"/>
