    <JadeMethod name="getStatusString" id="672a06b3-76ea-4dff-a64c-a1f3bee9ed1e">
        <source>getStatusString() : String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 December 2012	cnwer1	Initial creation HAT 2189

*/

vars

begin
	if self.status = DutyDoc_Pending then 
		return app.getErrorString(Pending);
	elseif self.status = DutyDoc_Validated then
		return app.getErrorString(Validated);
	elseif self.status = DutyDoc_Approved then
		return app.getErrorString(Approved);
	elseif self.status = DutyDoc_Rejected then
		return app.getErrorString(Rejected);
	endif;
	


end;</source>
