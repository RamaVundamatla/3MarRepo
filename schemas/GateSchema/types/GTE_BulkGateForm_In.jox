        <source>doCmbRegNoClick() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 April 2018	jlgns1	Initial creation
19 April 2018	jlgns1 Bug 38134: PKT - Weight Discrepancy
*/

vars

begin
    self.onRegChanged();
	if self.cmbRegNo.listObject &lt;&gt; null then
		self.detailsChangedVehicle := true;
	endif;
end;
</source>
    </JadeMethod>
    <JadeMethod name="doFKeys" id="553cf864-2800-4f32-860b-fe577a30cfaa">
        <updating/>
        <source>doFKeys(keyCharCode: Integer io) updating;
// ---------------------------------------------------------------------------
// Created:     09 December 2016 by cnwns1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin
	return ;
	
	if keyCharCode = J_key_F3 then
		self.btnFind.click(self.btnFind);
	endif;
	if keyCharCode = J_key_F4 then
		self.btnSave.click(self.btnSave);
