    <JadeMethod name="tswLogMessage" id="4b27e5d8-0510-4856-8177-b31800d4e126">
        <source>tswLogMessage(message : String);
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 16 August 2016	cnwdap1		Initial creation PAR #
