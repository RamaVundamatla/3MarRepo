<PrimType name="Time">
    <JadeMethod name="addHours" id="fedd1a31-5110-41e4-8a57-e81c94c227fa">
        <source>addHours(_amountToAdd: Integer):Time;
//----------------------------------------------------------------
//	Created:	25 November 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin

	return self + (((_amountToAdd * 60) * 60) * 1000);

end;</source>
        <Parameter name="_amountToAdd" type="Integer"/>
        <ReturnType type="Time"/>
    </JadeMethod>
