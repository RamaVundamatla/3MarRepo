    <JadeMethod name="validateTransportMode" id="8ce78ecc-3c62-4e6b-af18-86769eb4a84e">
        <source>validateTransportMode(pControl : CMIF_TIUpdateController) protected;
//--------------------------------------------------------------
//Created: 08 July 2002 By: cnwsb1
//--------------------------------------------------------------
vars
	transModeStr	: String;

begin
		
	transModeStr := app.transModeToString(self.transportMode);
	
	if self.transportMode &lt; TI_TRANSMODE_NULL or
			self.transportMode &gt; TI_TRANSMODE_MAX then
		app.raiseCMException1(InvalidTransportMode, self.transportMode.String, ETRow_TransportMode, null);
	endif;
	
	// REQUIRED attributes for transport mode
	if self.transportMode = TI_TRANSMODE_ROAD then
		if self.carrierCode = null then
			app.raiseCMException2(RequiredAttrForTransportMode, 'Carrier',
					transModeStr, ETRow_CarrierCode, pControl.myUserObject);
		endif;
		if self.vehicle = null then
			app.raiseCMException2(RequiredAttrForTransportMode, 'Vehicle No.',
					transModeStr, ETRow_RegNumber, pControl.myUserObject);
		endif;
	elseif self.transportMode = TI_TRANSMODE_RAIL then
	elseif self.transportMode = TI_TRANSMODE_SHIP then
	endif;

	// INVALID attributes for transport mode
	if self.transportMode &lt;&gt; TI_TRANSMODE_ROAD then
		if self.carrierCode &lt;&gt; null then
			app.raiseCMException2(InvalidAttrForTransportMode, 'Carrier',
					transModeStr, ETRow_CarrierCode, pControl.myUserObject);
		endif;
		if self.vehicle &lt;&gt; null then
			app.raiseCMException2(InvalidAttrForTransportMode, 'Vehicle No.',
					transModeStr, ETRow_RegNumber, pControl.myUserObject);
		endif;
	endif;
	if self.transportMode &lt;&gt; TI_TRANSMODE_RAIL then
	endif;
	if self.transportMode &lt;&gt; TI_TRANSMODE_SHIP then
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="pControl" type="CMIF_TIUpdateController"/>
    </JadeMethod>
    <JadeMethod name="validateWeights" id="dff9fd90-b233-4662-a5f5-c05ce08f64dc">
        <source>validateWeights() protected;
// ---------------------------------------------------------------------------
// Created:     13 August 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin

	if self.weightGross &lt;&gt; null then //PAR 10282 don't validate if they have not entered a gross weight
		if (self.weightNet + self.weightTare) &lt;&gt; self.weightGross then
			// The net weight (%1) + tare weight (%2) does not equal the entered gross weight (%3) for BOL %4.
			app.raiseCMException4(Err_NetTareGrossWeightError, self.weightNet.String, self.weightTare.String, self.weightGross.String, self.number, ETRow_NetWeight, null);
		endif;
	endif;

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="weightGrossTonnes" id="e507513e-f18e-4904-9eaf-78d547f90522">
        <methodInvocation>mapping</methodInvocation>
        <updating/>
        <source>weightGrossTonnes(set: Boolean; _value: Decimal io) mapping, updating;
// ---------------------------------------------------------------------------
// Created:     05 June 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	if set then
		self.weightGross := (_value * 1000).rounded;
	else
		_value := (self.weightGross / 1000).roundedTo(3);
	endif;

end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="Decimal" usage="io"/>
    </JadeMethod>
