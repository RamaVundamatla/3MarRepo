    <JadeMethod name="isSetdownDelayed" id="e3499a3b-e212-41f7-ad14-c02ae4f825a5">
        <source>isSetdownDelayed(_mins : Integer output; _delayHist : CM_MachineHistory output) : Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03/10/2022	navds21	TFS 50083 MTN - Machine Delay Idle Time

*/

vars
	iter : Iterator;
	config : CM_RTVehicleConfig;
	hist : CM_MachineHistory;
	now : TimeStamp;
	int : TimeStampInterval;
	mins : Integer;
begin
	if not self.loggedOn then
		return false;
	endif;
	
	if not self.myTerminal.getConfig(DelayTimeEnabled).Boolean then
		return false;
	endif;
	                          
	config := self.myTerminal.getRTVehicleConfigForObject(self);  
	
	if config = null then
		return false;
	endif;
	
	if config.delayTimeAllowable  = null then
		return false;
	endif;
	
	now := app.actualTimeServer;
	iter := self.history.createIterator;
	while iter.back(hist) do
		// ignore Information history
		//if hist.type = hist.Type_Info then 	//20/10/2022 navds21 TFS 50083
		//Start 20/10/2022 navds21 TFS 50083
		if hist.type = hist.Type_Info or 
		hist.type = hist.Type_Idle or
		hist.type = hist.Type_GoOffline or 
		hist.type = hist.Type_GoOnline or 
		hist.type = hist.Type_LogOff or 
		hist.type = hist.Type_LogOn or 
		hist.type = hist.Type_DelayStart or 
		hist.type = hist.Type_DelayEnd then
		//End 20/10/2022 navds21 TFS 50083
			continue;
		endif;
		if hist.type = hist.Type_SetdownDelay then
			_delayHist := hist;
		endif;
		// it's not delayed if the last thing it did was a setdown
		if hist.type = hist.Type_SetDown then
			return false;
		endif;
		int := now - hist.dateTime;
		mins := int.asMinutes.Integer;
		if _delayHist &lt;&gt; null then
			mins := mins + config.delayTimeAllowable ;
		endif;
		if mins &gt; config.delayTimeAllowable  then
			_mins := mins.Integer;
			return true;
		else	
			return false;
		endif;
	endwhile;
	
	return false;

epilog
	delete iter;
end;</source>
        <Parameter name="_mins" type="Integer" usage="output"/>
        <Parameter name="_delayHist" type="CM_MachineHistory" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isStraddleSeparated" id="ea40503b-c6bc-4cd7-8766-2645817da7c8">
        <source>isStraddleSeparated(sourceLocn	:	CM_LocationsController;_otherMachine : CM_Machine output)	:	Boolean;
//We check the OTHER machines, to see where they "are".
//If they are within "straddle separation" rules, of this source location, then 
//return FALSE, else return true.
/*
Date		Who		Reason
17 Feb 2010	consw1	PAR #22276 - Machine straddle separation 1090 error

*/
vars
	mach		: CM_Machine;
	task		: CM_RTQueueTask;
	invalidTask	: Boolean;
	
begin
	_otherMachine := null;
	
	if not sourceLocn.isKindOf(CM_StackController) then
		//--------------
		//Not a stack, ignore. We let many machines access block stacks.
		//--------------
		return true;
	endif;
	
	on Exception do app.handleDeletedObject(exception, task, invalidTask);
		
	// DVB Changed 6/09/04 for not available for entry
//	foreach mach in self.myTerminal.machines discreteLock where (not mach.isNotAvailableForEntry) do
	foreach mach in self.myTerminal.machines discreteLock 
			where (mach &lt;&gt; self) and 
				//(not mach.isKindOf(CM_Crane)) and 
				mach.machineType = MACHINETYPE_STRADDLE and	//27 Sep 2013	NDL	Par 32439
				(not mach.isNotAvailableForEntry) do

		invalidTask := false;
		task := mach.currentQueueTask;
		
		if task &lt;&gt; null and
		   task.isWithinSeparationLimits(sourceLocn) then
			if not invalidTask then
				_otherMachine := mach;
				return false;
			endif;
		endif;
	endforeach;
	
	return true;

end;</source>
        <Parameter name="sourceLocn" type="CM_LocationsController"/>
        <Parameter name="_otherMachine" type="CM_Machine" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
