    <JadeMethod name="initFilterTable" id="3097e54a-477b-4e7a-a122-47d2bbaf855f">
        <updating/>
        <source>initFilterTable() updating;
// ---------------------------------------------------------------------------
// Created:		20 June 2003  by Jason Chapman  (cnwjc2)
// ---------------------------------------------------------------------------
/* Changes

Date		Name	TFS#		Description
============================================================================
04/09/2023	jlika1	TFS 59168 - 55715.060 Display of Voyage EDI data in the EDI Operations Screen
06 Oct 2023	jlika1	TFS 60232 - EUP | FR 54871 - EDI Management for New EDI Types
============================================================================*/
vars
	tmpCombo		: ComboBox;
	tmpTypeId		: Integer;
	theType			: CM_CargoBOLType;	
begin

	if (not self.setFilterTblDef()) then
		return;
	endif;
	
	//self.myAssistant.comboBoxEDITypeCategories(self.cmbFiltEdiType, false, BAY_PLAN);
	self.myAssistant.comboBoxEDITypeCategories(self.cmbFiltEdiType, false, EDIDataType_BayPlan);
	self.tblSearch.setValueByControlName(self.cmbFiltEdiType.name, self.cmbFiltEdiType.text);
	self.loadEDIFileTypes(self.cmbLoadAsType, null);

	tmpCombo := cmbFiltVoyage;
	self.myAssistant.comboBoxVoyageCurrent(	tmpCombo,
											null,
											true,
											false,
											true,
											true,
											true,
											false,
											true,
											false,
											true); //cnwrs1 par 15258 nov 2007 exclude archived voyages
	self.myAssistant.comboBoxEDIStatus(self.cmbFiltStatus, 999, self.myEDIConfig); //ccms1906
	self.tblSearch.setValueByControlName(self.cmbFiltStatus.name, self.cmbFiltStatus.text); //ccms1906
//	self.loadEDIFileTypes(self.cmbLoadAsType, null);
	
	//jlika1 TFS 60232 --&gt;
	self.setAddlFilterRows();
	//jlika1 TFS 60232 &lt;--
	
	self.sptDataFilter.setLeftToRightRatioAndResize(35);		
end;</source>
    </JadeMethod>
    <JadeMethod name="initForm" id="1f938258-2e39-4f99-a2e1-090ee45fa2f3">
        <updating/>
        <source>initForm() updating;
// ---------------------------------------------------------------------------
// Created:		19 June 2003  by Jason Chapman  (cnwjc2)
// ---------------------------------------------------------------------------
// 02/05/2010	cnwcs5	par 23580 - enhanced EDI Form

vars

begin
	self.allowAdd	 := false;
	self.allowDelete := false;
	self.allowUpdate := false;
	
	
	self.filterAppliesToThumbnail := false;
	self.allowSearch := true;
	self.showFilterOnStartup := true;
	self.showDataOnStartup := false;	// true; PAR 18169
	self.frmDetailsBottom.visible := true;
	self.ediTIDynaDictFirstUse := true;
	self.useTblThumb := false;
	self.allowPrint		:= false;
	self.allowExportCSV	:= false;
	self.initEDITables(0);
	self.initDetailControls();

	self.initEDIAgent();
	
	self.fldDetail.useSheetBackColors := true;
	self.fldDetail.setDefaultSheetBackColors();
	self.fldDetail.initSheetBackColors();
	
	//initialise to true
	self.ediTIDataNeedsRefresh := true;
	
	self.setNavigatorHeading('EDI Files');
	self.myCurrentDataTable := self.tblData;	
	
	if self.amInitialisingWithObject then 
		//self.allowSearch 			:= false; //epr par 37090 2/11/15
		self.showFilterOnStartup	:= false;
		self.showDataOnStartup		:= false;
	endif;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="initFrmFindReplace" id="a4d2fd3c-ff13-4596-b4ea-bd4ac7761992">
        <source>initFrmFindReplace();
//----------------------------------------------------------------
//	Created:	04 August 2003	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
//	frame includes controls:
//		tblFindReplace
//		tblMultiReplace
//		btnAddReplace		&gt;&gt;
//		btnRemoveReplace	&lt;&lt;
//		btnReplace
//		btnReplaceAll
//		btnFindFirst
//		btnFindNext
//----------------------------------------------------------------
// 02/12/2009	cnwmh5		PAR21651 - Move setting top, left, width, height to 
//							own method
//----------------------------------------------------------------
vars
	/*
	// 02/12/2009 cnwmh5 #21651 - Removed
	tableHeight,
	tableTop : Real;
	*/
begin

	self.setFrmFindRCntrlsTopLeftHeight();		// 02/12/2009 cnwmh5 #21651
	/*
	// 02/12/2009 cnwmh5 #21651 - Replaced by above line
	tableTop := self.frmFindRToolBar.height;
	tableHeight	:= self.frmFindReplace.clientHeight - tableTop;
	self.tblFindReplace.top := tableTop;
	self.tblFindReplace.left := 0;
	self.tblFindReplace.height := tableHeight;
		
	self.tblMultiReplace.top := tableTop;
	self.tblMultiReplace.width := self.frmFindReplace.clientWidth - self.tblMultiReplace.left;
	self.tblMultiReplace.height := tableHeight;
	*/
	
	self.tblMultiReplace.scrollBars := Table.ScrollBars_Both;
	
	self.frmFindReplace.centreWindow();
			
	self.tblMultiReplace.clear;
	self.tblMultiReplace.rows := 1;
	self.tblMultiReplace.fixedRows := 1;
	self.tblMultiReplace.columns := 6;
	self.tblMultiReplace.selectMode := Table.SelectMode_CurrentRow;
//	self.tblMultiReplace.selectionType := CM_BaseTable.SelectionType_Row;

	self.tblMultiReplace.accessCell(1, 1).text := 'Field'&amp;Tab&amp;'Replace'&amp;Tab&amp;'With'&amp; Tab&amp;'Full Word' &amp; Tab&amp;'Selected' &amp; Tab&amp;'Count';
	
	self.tblFindReplace.clear;
	self.tblFindReplace.rows := 3;
	self.tblFindReplace.fixedRows := 0;
	self.tblFindReplace.columns := 2;
	self.tblFindReplace.userInputEnabled := true;
		
end;</source>
    </JadeMethod>
    <JadeMethod name="initFromUserWindow" id="a1c6c64e-c084-4835-abc1-f77f081cb82f">
        <updating/>
        <source>initFromUserWindow(_userWindow: CM_UserWindow) updating;
/*
----------   ----------  --------------------------------------------------
Created:	24 August 2006 By cnwth2

Changed On  Changed By  Reason
----------  ----------  --------------------------------------------------
04/03/2012	cnwcs5		par 31087 - 
*/
vars
	userWindow			: CM_UserWindow;
	theXML, theXMLValue : String;

begin
	inheritMethod(_userWindow);

	userWindow := app.getUserWindow(self.name, false);
	
	if userWindow = null then
		return;
	endif;
	
	// get the saved xml and save to attribute on form
	self.getTblEDITIXML (userWindow);	// par 31087 March 2013
	
	theXML 		:= userWindow.xmlInfo;
	// #### BIG FONT
 	theXMLValue := theXML.cnEcGetTagValueOfName(self.XML_SPLITMAINT);
	
 	self.sptMain.setLeftToRightRatio(theXMLValue.Integer);
end;

</source>
        <Parameter name="_userWindow" type="CM_UserWindow"/>
    </JadeMethod>
    <JadeMethod name="initModalDialog" id="e385082a-ad87-4529-b543-f85d9a9cd0d5">
        <source>initModalDialog();
//----------------------------------------------------------------
//	Created:	29 August 2003	by Jason Chapman  (cnwjc2)
// 08 Dec 2022  navma1	Bug 55014: MSL - EDI operation - loading a big file
//----------------------------------------------------------------
vars

begin
	self.frmModalDialog.height 		:= 100;
	self.frmModalDialog.width  		:= 300;
	self.frmModalDialog.centreWindow;
	self.frmModalDialog.zOrder(1);							//08.12.2022 navma1 #55014
	self.frmProgressCtr.move(0,0,self.frmModalDialog.clientWidth,self.frmModalDialog.clientHeight);
	self.frmProgressCtr.visible 	:= true;
	self.lblModalMessage.height     := 34;
	self.lblModalMessage.visible	:= true;
	self.lblModalInfo.visible 		:= true;
	self.lblModalInfo.caption 		:= "";
	self.frmModalDialog.visible 	:= true;
	self.frmModalDialog.backColor 	:= self.backColor;
	self.pbProgressBar.partsInJob 	:= 1;
	self.pbProgressBar.partsDone 	:= 0;
	self.pbProgressBar.visible 		:= true;
	self.btnModalDefault.visible 	:= false;
	self.pbProgressBar.top 			:= 38;
	self.lblModalInfo.top 			:= self.pbProgressBar.top + self.pbProgressBar.height + 2;
	self.pbProgressBar.zOrder(0);
end;</source>
