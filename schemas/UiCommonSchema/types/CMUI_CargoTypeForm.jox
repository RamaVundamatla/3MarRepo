    <JadeMethod name="addObjectsToTable" id="1428f6cd-d16d-4b76-bd33-7f3d1309bda7">
        <updating/>
        <source>addObjectsToTable(_numItems: Integer io) updating;
// ---------------------------------------------------------------------------
// Created:     22 October 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	iter 				: Iterator;
	cargoType			: CM_CargoType;
	root				: CM_Root;
	breakOut	: Boolean;
	tmpPassport	: CM_Passport;
begin
	root := app.myRoot;
	tmpPassport	:= app.myPassport;
	
	iter := root.allCargoTypesById.createIterator;
	
	while iter.next(cargoType) do
		if self.includeObject(cargoType, tmpPassport) then
			self.addObjectToTable(cargoType, _numItems, breakOut);
			if breakOut then
				break;
			endif;
		endif;
	endwhile;
epilog

	delete iter;
end;</source>
        <Parameter name="_numItems" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="addTblAttributeRow" id="d74fd73e-646e-4cc9-b2f1-57d9d917be11">
        <source>addTblAttributeRow(_prodAttr : CM_ProductAttr) protected;
/* ---------------------------------------------------------------------------
Created:	26 May 2009	by cnwvu1

Purpose:	
   
Change Date		Who			Reason

------------------------------------------------------------------------------*/
vars
	idx			: Integer;
	debugStr,
	str			: String;
	entRow		: EntTableRow;
		
begin

	if _prodAttr = null then
		return;
	endif;
	
	foreach	entRow in self.getTblAttributesDef.allEntTableRows do
		str := str &amp; _prodAttr.getDisplayStringForAttribute(entRow.name, true) &amp; Tab;
	endforeach;
		
	idx := self.tblAttributes.addItem(str);
	self.tblAttributes.accessRow(idx).itemObject := _prodAttr;
end;</source>
        <access>protected</access>
        <Parameter name="_prodAttr" type="CM_ProductAttr"/>
    </JadeMethod>
    <JadeMethod name="addToolbarControls" id="77e377e3-36ba-427a-986f-eb1b8a27aa8a">
        <source>addToolbarControls() protected;
// ---------------------------------------------------------------------------
// Created:     14 February 2006	cnwhjg1
//
// Purpose:  
// Changed On By Reason
// ---------- ---------- --------------------------------------------------
// 03/03/2022  navak20   #52821 - 020 Cargo Type Maint File List
// ----------   ----------  --------------------------------------------------
vars

begin
	inheritMethod();
	if (app.myCurrentUserCan(self.myTerminal, PmGCProductMaint) or app.myCurrentUserCan(self.myTerminal, PmGCProductView)) then 
		self.frmToolbar.addButton(self.btnProductsForm, CMUI_Toolbar.Control_Alignment_Left);
		self.btnProductsForm.visible := true;
	endif;
	
	if (app.myCurrentUserCan(self.myTerminal, PmAdmCargoTypeDocView) or  app.myCurrentUserCan(self.myTerminal, PmAdmCargoTypeDocMaint)) then
	  self.frmToolbar.addButton(self.btnAttachment, CMUI_Toolbar.Control_Alignment_Left);		  // #52821 03.03.2022 navak20 
	  self.btnAttachment.visible := true;	 													  // #52821 03.03.2022 navak20
	  else																						  // #52821 03.03.2022 navak20
	   self.btnAttachment.visible := false;									  					  // #52821 03.03.2022 navak20
	endif;																						  // #52821 03.03.2022 navak20
	
	self.frmToolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	self.frmToolbar.addFrame(self.frmShowNotAvail, CMUI_Toolbar.Control_Alignment_Left);	// ccms 1080. May 2009 cnwvu1
/*	//05/06/2024	navkc1 CR 63736 Task 63770 replaced with new control		
	// ### TFS#52786 04Feb2022 NAVSP1 -- start
	self.frmToolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	self.frmToolbar.addFrame(self.frmFilter,CMUI_Toolbar.Control_Alignment_Left);
	self.txtFilterBox.parent 	:= self.frmFilter;
	self.txtFilterBox.visible 	:= true;
	self.txtFilterBox.left 		:= 0;
	self.txtFilterBox.top 		:= 2;
	self.frmToolbar.addButton(self.btnClearFilter,CMUI_Toolbar.Control_Alignment_Left);
	// ### TFS#52786 04Feb2022 NAVSP1 -- end
*/
	self.frmToolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);					//05/06/2024	navkc1 CR 63736 Task 63770
	self.frmToolbar.addFrame(self.frmTableFilter,CMUI_Toolbar.Control_Alignment_Left);	//05/06/2024	navkc1 CR 63736 Task 63770
end;</source>
        <access>protected</access>
    </JadeMethod>
