begin
	create webService transient;
	create transientJSONObjs transient;
	create parser transient;
	
	self.loginREST(webService);
	
	// set up the WS_Request object
	webService.setPropertyValue(WS_RestWebServiceProvider::requestPath.name, "/releaseRequest");
	
	if _urlParams &lt;&gt; null then
		pos := 1;
		relId := _urlParams.scanUntil("/", pos);
		pos += 1;
		epochTime := _urlParams.scanUntil("/", pos).Integer64;
		response := webService.deleteReleaseRequest(request, relId, epochTime);
	else
		if _incomingJson &lt;&gt; null then
			request := parser.parse(_incomingJson, WS_RestDelReleaseRequestArray, transientJSONObjs).WS_RestDelReleaseRequestArray;
		endif;
		
		response := webService.deleteReleaseRequest(request);
	endif;
	
	// If we're expecting to fail, then return early
