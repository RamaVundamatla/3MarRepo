    <JadeMethod name="hasMixedCargoTypes" id="1015b6fd-2e71-4722-8bb9-56a3d2f65e09">
        <source>hasMixedCargoTypes() : Boolean protected;

/*

Purpose:			


Return Value:		


Date		Who		Reason
20 May 2008	cnwkpd1	PAR #16753 - CCMS SFW 1003 - General Cargo Graphical Screens

*/

vars
	tmpTI			: CM_TrackedItem;
	lastType		: Integer;
	
begin
	foreach tmpTI in self.allTrackedItems do
		if lastType &lt;&gt; null and tmpTI.cargoType &lt;&gt; lastType then
			return true;
		endif;
		lastType := tmpTI.cargoType;
	endforeach;
	
	return false;
	
		
epilog

end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="hasMixedLogGrades" id="f3c2c263-fdf1-4543-a848-14a7018d28cd">
        <source>hasMixedLogGrades() : Boolean  protected;
// ---------------------------------------------------------------------------
// Created:      11 June 2003 by cnwsgp1
// ---------------------------------------------------------------------------
vars
	soh : CM_SOHLocation;
	prod : CM_Product;
	logGrade : CM_LogGrade;
	lastLogGrade : CM_LogGrade;

begin
	lastLogGrade := null;
	foreach soh in self.allProductLocations do
		if soh.numTIs &lt; 1 then
			continue;
		endif;
	
		prod := soh.myProduct;
		if prod &lt;&gt; null and CM_ProductLog.hasInstance(prod) then
			logGrade := prod.CM_ProductLog.myLogGrade;
			if logGrade &lt;&gt; null and lastLogGrade &lt;&gt; null and logGrade &lt;&gt; lastLogGrade then
				return true;
			endif;
			lastLogGrade := logGrade;
		endif;
	endforeach;	
				
	return false;
end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="hasMixedOperators" id="87fc432d-e789-495d-807e-99c799b8c749">
        <source>hasMixedOperators() : Boolean protected;
// ---------------------------------------------------------------------------
// Created:      10 June 2003 by cnwsgp1
// ---------------------------------------------------------------------------
vars
	soh : CM_SOHLocation;
	op, lastOp : CM_Operator;

begin
	lastOp := null;
	foreach soh in self.allProductLocations do
		if soh.numTIs &lt; 1 then
			continue;
		endif;
		
		op := soh.myOperator;
		if lastOp &lt;&gt; null 
		and op &lt;&gt; null 
		and op &lt;&gt; lastOp then
			return true;
		endif;
		lastOp := op;
	endforeach;

	return false;
end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="hasMixedVoyages" id="9c1f91d6-0ae3-4a4a-9419-12275b210408">
        <source>hasMixedVoyages() : Boolean protected;
// ---------------------------------------------------------------------------
// Created:      11 June 2003 by cnwsgp1
// ---------------------------------------------------------------------------
/*

Date		Who		Reason
20 May 2008	cnwkpd1	PAR #16753 - CCMS SFW 1003 - General Cargo Graphical Screens
			cnwrs2	Allow for non-log locations by going direct to the tracked items

*/
vars
	stockAlloc 		: CM_StockOrderAllocation;
	voy 			: CM_Voyage;
	lastVoy 		: CM_Voyage;
	tmpTI			: CM_TrackedItem;

begin
	lastVoy := null;
	
	// Handle logs allocations via stock order allocations
	if not self.allStockOrderAllocations.isEmpty() then
		foreach stockAlloc in self.allStockOrderAllocations do
			voy := stockAlloc.myStockOrderHeader.myVoyage;
			if voy &lt;&gt; null and lastVoy &lt;&gt; null and voy &lt;&gt; lastVoy then
				return true;
			endif;
			lastVoy := voy;
		endforeach;
		return false;
		
	else
		// Handle other location types using tracked items directly 
		foreach tmpTI in self.allTrackedItems do
			voy := tmpTI.myVoyage;
			if voy &lt;&gt; null and lastVoy &lt;&gt; null and voy &lt;&gt; lastVoy then
				return true;
			endif;
			lastVoy := voy;
		endforeach;
	endif;
				
	return false;
	

epilog

end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="hasOversizedBackendsByMode" id="6f0c2651-f0b6-4c0f-a4e7-6af82cfea663">
        <source>hasOversizedBackendsByMode(_mode : Integer; _stackPos : Integer; _tmpTIs : CM_TIArray input; _includeOnlyMode : Boolean) : CM_TrackedItem;
// ---------------------------------------------------------------------------
// Created:		15 May 2008 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	prevGC : CM_GridController;
begin
	_tmpTIs.clear;
	if _mode = DISPLAY_MODE_ACTUAL then
		self.allTrackedItemOSBackEnds.copy(_tmpTIs);
	endif;
	if _mode = DISPLAY_MODE_QUEUE then
		self.allTrackedItemOSBackEndsQd.copy(_tmpTIs);
	endif;
	if _mode = DISPLAY_MODE_PLAN then
		self.allTrackedItemOSBackEndsPd.copy(_tmpTIs);
	endif;

	if _tmpTIs.size &gt; 0 and _stackPos &lt;= _tmpTIs.size then
		return _tmpTIs[_stackPos];
	endif;

	return null;
end;</source>
        <Parameter name="_mode" type="Integer"/>
        <Parameter name="_stackPos" type="Integer"/>
        <Parameter name="_tmpTIs" type="CM_TIArray" usage="input"/>
        <Parameter name="_includeOnlyMode" type="Boolean"/>
        <ReturnType type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="hasOversizedFrontEndsByMode" id="84652068-a3e7-4b9a-a232-ba5911191d90">
        <source>hasOversizedFrontEndsByMode(_mode : Integer; _stackPos : Integer; _tmpTIs : CM_TIArray input) : CM_TrackedItem;
// ---------------------------------------------------------------------------
// Created:		15 May 2008 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	tmpTI : CM_TrackedItem;
begin

	if _stackPos &lt;= self.allTrackedItems.size then
		tmpTI := self.allTrackedItems[_stackPos];
		if tmpTI.isOverSizedContainer() then
			return tmpTI;
		endif;
	endif;
	
	
	return null;
end;</source>
        <Parameter name="_mode" type="Integer"/>
        <Parameter name="_stackPos" type="Integer"/>
        <Parameter name="_tmpTIs" type="CM_TIArray" usage="input"/>
        <ReturnType type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="hasPlannedTIs" id="62818d84-7590-428f-92d2-894fbd0c0e75">
        <source>hasPlannedTIs(_isLoad: Boolean): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
05 August 2011	cnwer1	Initial creation CCMS MES 1033

*/

vars

	aOK : Boolean;
	aTI : CM_TrackedItem;
begin

	aOK := false;
	if _isLoad then
		aOK := self.hasTIsOfMode(PLANNING_MODE);
	else
		foreach aTI in self.allTrackedItems do
			if aTI.getPrimaryLocation(PLANNING_MODE) &lt;&gt; null then
				aOK := true;
				break;
			endif;
		endforeach;	
	endif;
	
	return aOK;
epilog

end;</source>
        <Parameter name="_isLoad" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
