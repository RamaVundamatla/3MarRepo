    <JadeMethod name="setRemarks" id="29dfe836-ac7c-4567-9178-70ed6b2f8a0d">
        <updating/>
        <source>setRemarks() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 Dec 2017	jlgab1	Initial creation
11 Feb 2020 cnwma1	Bug 48511: JMT - Duplicate Narration for Manual Cash Payment on Cash Collection Screen    
*/

vars
	linetype : CM_InvoiceLineDesc;
begin

	linetype:= self.myInvoiceLineType;
	if linetype &lt;&gt; null then
		if linetype.unitNarration &lt;&gt; null then  //11.02.2020 cnwma1 #48511
			self.remarks := linetype.narration &amp; " (" &amp; self.quantity.String &amp; " " &amp; linetype.unitNarration &amp; ") " &amp; self.lineTotal.asCurrencyJMT;
		else
			self.remarks := linetype.narration &amp; " (" &amp; self.quantity.String &amp; ") " &amp; self.lineTotal.asCurrencyJMT;
		endif;
	endif;
epilog

end;</source>
    </JadeMethod>
