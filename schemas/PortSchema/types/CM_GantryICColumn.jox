<Class name="CM_GantryICColumn" id="0f1257a2-c0e4-496c-8848-5e027bd7ec3f">
    <superclass name="CM_GridColumn"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="location"/>
    <ExplicitInverseRef name="myRTGColumn" id="25636b3c-3dbb-4938-b852-8499fee160e1">
        <kind>child</kind>
        <transientToPersistentAllowed/>
        <updateMode>automatic</updateMode>
        <embedded/>
        <type name="CM_RTGColumn"/>
        <access>readonly</access>
        <Inverse name="CM_RTGColumn::myBottomGantryICColumn"/>
        <Inverse name="CM_RTGColumn::myTopGantryICColumn"/>
    </ExplicitInverseRef>
    <JadeMethod name="setForUpdate" id="fed2070d-085e-492c-a754-bbe4e96a8bb8">
        <updating/>
        <source>setForUpdate(pProxy: CM_GantryICColumn) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
10 August 2009	cnwer1	Initial creation

*/

vars
	realRTGColumn :CM_RTGColumn;
	rtgArea : CM_RTGArea;
	icArea  : CM_GantryInterchangeArea;
begin
	inheritMethod(pProxy);
	
	if self.myRTGColumn &lt;&gt; null then
		if  self = self.myRTGColumn.myBottomGantryICColumn then
			self.myRTGColumn.setMyBottomGantryICCol(null);
		elseif self = self.myRTGColumn.myTopGantryICColumn then
			self.myRTGColumn.setMyTopGantryICCol(null);
		endif;
	endif;
	

	//get real area
	rtgArea:=pProxy.myGridArea.CM_GantryInterchangeArea.allAssociatedTerminalAreas.first.pxyGetRealObject.CM_RTGArea;
	
	
	realRTGColumn:=rtgArea.allGridColumns[self.column].CM_RTGColumn; //pProxy.myRTGColumn.pxyGetRealObject.CM_RTGColumn;
	if realRTGColumn  = null then

		//get the real RTG area
		app.setContinueCMExceptions(false);
		app.raiseCMException2(MethodCalledForNonTransient, method.name, self.class.String, null, null);
	endif;
	
	if pProxy.myGridArea.CM_GantryInterchangeArea.interchangePosition = CM_RTGArea.ICPosition_BeforeRow1 then
		realRTGColumn.setMyTopGantryICCol(self);
	elseif  pProxy.myGridArea.CM_GantryInterchangeArea.interchangePosition = CM_RTGArea.ICPosition_AfterLastRow then
		realRTGColumn.setMyBottomGantryICCol(self);
	endif;

epilog

end;</source>
        <Parameter name="pProxy" type="CM_GantryICColumn"/>
    </JadeMethod>
</Class>
