    <JadeMethod name="chkRotatable_click" id="eb768dfb-ae08-4028-b155-fe6e9c7779ab">
        <controlMethod name="CMUI_CheckBox::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>chkRotatable_click(checkbox: CheckBox input) updating;
/*
Purpose:			
Date		Who		Reason
05 May 2011	cnwab1	Initial creation
*/

vars

begin
	self.doPropertiesChange();
	if self.myROROLocnDefn.isTransient() then
		self.myROROLocnDefn.setProxyIsRotatable(checkbox.value);
	endif;
epilog

end;</source>
        <Parameter name="checkbox" type="CheckBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="chkSelectAll_click" id="ed09dc00-e5be-4209-96da-38a425c11526">
        <controlMethod name="CMUI_CheckBox::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>chkSelectAll_click(checkbox: CheckBox input) updating;
/*
Date		    Who			Reason
04 May 2011	cnwas3	  Initial creation: CCMS 1031
*/

vars

begin
	self.doPropertiesChange();
	if checkbox.value = true then
		self.lstHazard.setAllToTrue();
	else
		self.lstHazard.setAllToFalse();
	endif;
epilog

end;</source>
        <Parameter name="checkbox" type="CheckBox" usage="input"/>
    </JadeMethod>
