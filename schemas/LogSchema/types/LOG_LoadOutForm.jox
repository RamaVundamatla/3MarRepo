    <JadeMethod name="initTblsLocation" id="08437884-61b3-4dc4-a29f-d420eec63bec">
        <updating/>
        <source>initTblsLocation()updating;
// ---------------------------------------------------------------------------
// Created:     22 April 2005	cnwhjg1
//
// Purpose:     
