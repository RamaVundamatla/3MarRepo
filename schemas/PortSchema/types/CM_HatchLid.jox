    <JadeMethod name="isOverSlot" id="161b1d46-915d-476c-80f5-9a19c62e866d">
        <source>isOverSlot(_slot : CM_SlotDefn) : Boolean;
/*
------------------------------------------------------------------------
Created:			03 March 2003 by cnwdwq1
Purpose:			Dave Q's code
Parameters:		
Returns:			
Changed On		Changed By		Reason
------------	------------	-----------------------------------------
														
------------------------------------------------------------------------
*/
begin
	if _slot = null then
		app.raiseCMException2(MethodWithNullParam, method.name, '_slot Ref', null, null);	
	endif;	
	if _slot.ordinalDeck = DeckOnDeck then
		return false;
	endif;
	return ((_slot.ordinalCell &lt;= self.ordinalUDEndCell) and (_slot.ordinalCell &gt;= self.ordinalUDStartCell));
end;</source>
        <Parameter name="_slot" type="CM_SlotDefn"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isSameHatch" id="9da88e85-d6fd-4ff1-8741-9cb82d30c66e">
        <source>isSameHatch(_hatch : CM_HatchLid) : Boolean;
/*
------------------------------------------------------------------------
Created:			03 February 2003 by cnwdwq1
Purpose:			Dave Q's code
Parameters:		See Method signature above. Special comment:
Returns:			See Method signature above. Special comment:
Changed On		Changed By		Reason
------------	------------	-----------------------------------------
29/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
------------------------------------------------------------------------
*/
vars

begin
	if _hatch = null then
		app.raiseCMException2(MethodWithNullParam, method.name, '_hatch reference', null, null);
	endif;
	
	if self.ordinalEndBay &lt;&gt; _hatch.ordinalEndBay then
		return false;
	endif;
	if self.ordinalODEndCell &lt;&gt; _hatch.ordinalODEndCell then
		return false;
	endif;
	if self.ordinalODStartCell &lt;&gt; _hatch.ordinalODStartCell then
		return false;
	endif;
	if self.ordinalStartBay &lt;&gt; _hatch.ordinalStartBay then
		return false;
	endif;
	if self.ordinalUDEndCell &lt;&gt; _hatch.ordinalUDEndCell then
		return false;
	endif;
	if self.ordinalUDStartCell &lt;&gt; _hatch.ordinalUDStartCell then
		return false;
	endif;
	if self.startsMidCell &lt;&gt; _hatch.startsMidCell then
		return false;
	endif;
	return true;
end;</source>
        <Parameter name="_hatch" type="CM_HatchLid"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isUnderSlot" id="9db1d11a-bd9b-416f-a4bb-7d8f50489db9">
