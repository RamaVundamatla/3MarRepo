    <JadeMethod name="getLoadEndTimeByIndex" id="3fd9c6ab-1da3-4b40-a4df-55397cff595d">
        <source>getLoadEndTimeByIndex(_index :Integer):TimeStamp;
/*	
Date		Who		Reason
22 September 2011	cnwcs5	Initial creation - CCMS RIO 2041 / par 28220 Start/Stop Times
*/
vars
	count		:Integer;
	interval	:CM_TimeStampInterval;
	ts			:TimeStamp;
begin
	foreach interval in self.allCargoOperationsIntervals do
		count := count + 1;
		
		if count = _index then
			ts := interval.endDT;		// 28805 Dec 2011 cnwjre1 get the correct end date - was startDT
			return ts;
		endif;
	endforeach;
	
	return null;
epilog

end;</source>
        <Parameter name="_index" type="Integer"/>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="getLoadStartTimeByIndex" id="d68639e0-9d1d-474d-8f48-146dc862cfa6">
        <source>getLoadStartTimeByIndex(_index :Integer):TimeStamp;
/*	
Date		Who		Reason
22 September 2011	cnwcs5	Initial creation - CCMS RIO 2041 / par 28220 Start/Stop Times
*/
vars
	count		:Integer;
	interval	:CM_TimeStampInterval;
	ts			:TimeStamp;
begin
	foreach interval in self.allCargoOperationsIntervals do
		count := count + 1;
		
		if count = _index then
			ts := interval.startDT;
			return ts;
		endif;
	endforeach;
	
	return null;
epilog

end;</source>
        <Parameter name="_index" type="Integer"/>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
