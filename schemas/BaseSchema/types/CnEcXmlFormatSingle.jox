    <DbClassMap file="CnEcXML"/>
    <JadeMethod name="cnEcXmlFormatOutput" id="ca4a87a1-6fc1-42fe-8bc0-f5e7554044de">
        <source>cnEcXmlFormatOutput(pObject: Object; pIsDebug: Boolean; pMaxObjectCount: Integer io; pCurrentObjectCount: Integer io; pMaxResponseSize: Integer io): String;

vars
	xmlString		: String;
	errorStr		: String;
    referenceObject	: Object;
    
begin
	on CnEcBaseXmlException do self.handleXMLException(exception, errorStr);

	if not self.isShowTagData then
		return null;
	endif;

    referenceObject := pObject.getPropertyValue(self.propertyName).Object;
    
    if app.isValidObject(referenceObject) and app.isValidObject(self.myFormat)then
    	xmlString := getFormatXmlString(self.myFormat.formatName, referenceObject, pIsDebug, pMaxObjectCount, pCurrentObjectCount, pMaxResponseSize);
    	xmlString := cnEcXmlTagIt(self.tagName, xmlString, pIsDebug);
    endif;
    
    if errorStr &lt;&gt; "" then
    	xmlString := xmlString &amp; cnEcXmlTagIt("ERROR", errorStr, pIsDebug);
    endif;
    
	return xmlString;		
end;</source>
        <Parameter name="pObject" type="Object"/>
        <Parameter name="pIsDebug" type="Boolean"/>
        <Parameter name="pMaxObjectCount" type="Integer" usage="io"/>
        <Parameter name="pCurrentObjectCount" type="Integer" usage="io"/>
        <Parameter name="pMaxResponseSize" type="Integer" usage="io"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="cnEcXmlOutput" id="42cc43de-37bd-4fda-a896-e48b69ac8984">
        <source>cnEcXmlOutput(	pObject:Object;
				pIsDebug:Boolean;
				pMaxObjectCount:Integer io;
				pCurrentObjectCount:Integer io;
				pMaxResponseSize:Integer io): String;

vars
	xmlString		: String;
	errorStr		: String;
    referenceObject	: Object;
    
begin
	on CnEcBaseXmlException do self.handleXMLException(exception, errorStr);

	if not self.isShowTagData then
		return null;
	endif;

    referenceObject := pObject.getPropertyValue(self.propertyName).Object;
    
    if app.isValidObject(referenceObject) and app.isValidObject(self.myFormat)then
    	xmlString := getXmlString(self.myFormat.formatName, referenceObject, pIsDebug, pMaxObjectCount, pCurrentObjectCount, pMaxResponseSize);
    	//xmlString := referenceObject.cnEcXmlFormat(self.myFormat.formatName, pIsDebug, pMaxObjectCount, pCurrentObjectCount, pMaxResponseSize);
    	xmlString := cnEcXmlTagIt(self.tagName, xmlString, pIsDebug);
    endif;
    
    if errorStr &lt;&gt; "" then
    	xmlString := xmlString &amp; cnEcXmlTagIt("ERROR", errorStr, pIsDebug);
    endif;
    
	return xmlString;		
end;</source>
        <Parameter name="pObject" type="Object"/>
        <Parameter name="pIsDebug" type="Boolean"/>
        <Parameter name="pMaxObjectCount" type="Integer" usage="io"/>
        <Parameter name="pCurrentObjectCount" type="Integer" usage="io"/>
        <Parameter name="pMaxResponseSize" type="Integer" usage="io"/>
        <ReturnType type="String"/>
    </JadeMethod>
</Class>
