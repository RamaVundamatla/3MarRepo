begin

	self.gotoFirstOfChar(keyCode.Character);

end;
</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="keyCode" type="Integer" usage="io"/>
        <Parameter name="shift" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="translateForm" id="b12cf23b-d87d-447e-9741-b4608b253666">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0008026, locale);
	btnAddNewAddress.translateCaption(Xlat_0004930, locale);
	btnBcc.translateCaption(Xlat_0000736, locale);
	btnCc.translateCaption(Xlat_0000737, locale);
	btnTo.translateCaption(Xlat_0000738, locale);
	lblContacts.translateCaption(Xlat_0000735, locale);
	lblMessageRecipi.translateCaption(Xlat_0000739, locale);
	mnuColumnOrganiser.translateCaption(Xlat_0008027, locale);
	mnuContext.translateCaption(Xlat_0008028, locale);
	optViewSystem.translateCaption(Xlat_0004931, locale);
	optViewUser.translateCaption(Xlat_0004932, locale);
end;</source>
    </JadeMethod>
</GUIClass>
