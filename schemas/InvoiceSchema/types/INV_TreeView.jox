    <JadeMethod name="doLstDataClick" id="fa600b60-71c2-4ea9-95c2-c913d58f0a0b">
        <updating/>
        <source>doLstDataClick(listbox: ListBox input) updating;
// ---------------------------------------------------------------------------
// Created:		May 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

begin
	self.myCurrentListObject := null;
	self.tblExtraInfo.rows := 0;	
	if listbox.listIndex &lt; 0 then
		return;
	endif;
	self.myCurrentListObject := listbox.itemObject[listbox.listIndex].CM_Object;
	self.showExtraInfo(self.myCurrentListObject);
end;</source>
        <Parameter name="listbox" type="ListBox" usage="input"/>
    </JadeMethod>
