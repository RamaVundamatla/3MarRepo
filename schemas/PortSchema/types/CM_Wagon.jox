    <JadeMethod name="getLoadWeight" id="6df1fe9c-d2a8-49fa-a95c-20c631bc8021">
        <source>getLoadWeight() : Decimal;
// ---------------------------------------------------------------------------
// Created:		January  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	lTIArray	: CM_TIArray;
	lWeight	: Decimal[14,4];
	lTI	: CM_TrackedItem;
begin
	create lTIArray transient;
	self.getAllTrackedItems(true, lTIArray, false);
	foreach lTI in lTIArray do
		if lTI = null then
			continue;
		endif;
		lWeight := lWeight + lTI.totalWeight;
	endforeach;
	
	return lWeight;
epilog
	delete lTIArray;
end;</source>
        <ReturnType type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="getLocationContClassToCreate" id="3476c8d0-f18b-4340-ae6f-a34706aecbed">
        <source>getLocationContClassToCreate():Class;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 March 2013	cnwndl1	Initial creation	par 31278

*/

vars

begin

	if self.isBoxcar then
		return CM_BoxcarWagonController;
	elseif self.isFlatcar then
		return CM_FlatcarWagonController;
	elseif self.isSkeletonCar then
		return CM_SkeletonCarWagonController;
	else
		return null;
	endif;

epilog

end;</source>
        <ReturnType type="Class"/>
    </JadeMethod>
    <JadeMethod name="getLocationControllerForTI" id="1c65912e-406e-4fe3-a2c8-36529fc80105">
        <source>getLocationControllerForTI(_ti : CM_TrackedItem) : CM_LocationsController;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
22 July 2009	cnwmd1	Initial creation

*/

vars
	lController	: CM_LocationsController;
	lTI			: CM_TrackedItem;
begin

	//foreach lController in self.allLocationsControllers do
	foreach lController in self.allLocationsControllersArray do	//04 Dec 2014	NDL	Par 35345
		foreach lTI in lController.allTrackedItems do
			if lTI = _ti then
				return lController;
			endif;
		endforeach;
	endforeach;
epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <ReturnType type="CM_LocationsController"/>
