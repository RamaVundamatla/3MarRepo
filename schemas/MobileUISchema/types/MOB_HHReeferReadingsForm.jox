    <Constant name="HELP_DESCRIPTION" id="a3a45328-e1dd-452f-af7b-d8109ae658c9">
        <constantUsages>
            <GlobalConstant name="CrLf"/>
        </constantUsages>
        <source>"Type a partial container ID in the search box and click the search button to find a Container. This search will only find Reefer Containers." &amp; CrLf &amp; CrLf &amp;
"Use the location text box to enter a location and click the search button to find the container at that location" &amp; CrLf &amp; CrLf &amp;
"The value in the Current Temperature box is the lastest reading of the selected container or if there have been no previous reading then it will display the set temperature"  &amp; CrLf &amp; CrLf &amp;
"Click the edit button to enter a new reading for the container. Click 'Save', or 'Next' or 'Prev' to save this reading" &amp; CrLf &amp; CrLf &amp;
"The next and prev buttons will move to the appropriate reefer container, saving any entry in the current temperature box as the latest reading" &amp; CrLf &amp; CrLf &amp;
"The 'No Charge' check box determines whether or not the client will be charged for the temperature reading."</source>
        <type name="String"/>
    </Constant>
