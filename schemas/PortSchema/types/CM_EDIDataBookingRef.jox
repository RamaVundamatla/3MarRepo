    <JadeMethod name="findHeadings" id="3497db24-8be8-4d9f-8c2a-00dde804b50c">
        <source>findHeadings(tiName: String; shortDesc: String io; longDesc: String io; width: Integer io; num: Integer io);
// note: num does not have to be order but the largest num must be
//	   greater than the total number of properties.
//	   ie what is return by getNumColumns.
vars

begin
	if tiName = "id" then
		num := 1;
		shortDesc := "Container";
		longDesc := "Container";
		width := 140;
	elseif tiName = "locationId" then
		num := 2;
		shortDesc := "Location";
		longDesc := "Location";
		width := 50;
	elseif tiName = "operatorCode" then
		num := 3;
		shortDesc := "Oper";
		longDesc := "Operator";
		width := 50;
	elseif tiName = "dischargePort" then
		num := 4;
		shortDesc := "Disch";
		longDesc := "Discharge Port";
		width := 50;
	elseif tiName = "destinationPort" then
		num := 5;
		shortDesc := "Dest";
		longDesc := "Destination";
		width := 50;
	elseif tiName = "loadPort" then
		num := 6;
		shortDesc := "Load";
		longDesc := "Load Port";
		width := 50;
	elseif tiName = "isoType" then
		num := 7;
		shortDesc := "ISO";
		longDesc := "ISO Type";
		width := 50;
	elseif tiName = "fullOrMT" then
		num := 8;
		shortDesc := "MT";
		longDesc := "MT of Full (E/F)";
		width := 30;
	elseif tiName = "weight" then
		num := 9;
		shortDesc := "Weight";
		longDesc := "Weight";
		width := 50;
	elseif tiName = "commodity" then
		num := 10;
		shortDesc := "Cmdty";
		longDesc := "Commodity";
		width := 50;
	elseif tiName = "commodityDescription" then
		num := 11;
		shortDesc := "Description";
		longDesc := "Commodity Description";
		width := 120;
	elseif tiName = "consignor" then
		num := 12;
		shortDesc := "Consign";
		longDesc := "Consignor/Consignee Code";
		width := 50;
	elseif tiName = "temperature" then
		num := 13;
		shortDesc := "Temp";
		longDesc := "Temperature";
		width := 50;
	elseif tiName = "remarks" then
		num := 14;
		shortDesc := "Remarks";
		longDesc := "Remarks";
		width := 100;
	elseif tiName = "imCodes" then
		num := 15;
		shortDesc := "IMCodes";
		longDesc := "IM Codes";
		width := 50;
	elseif tiName = "height" then
		num := 16;
		shortDesc := "Hght";
		longDesc := "Height";
		width := 30;
	elseif tiName = "length" then
		num := 17;
		shortDesc := "Lght";
		longDesc := "Length";
		width := 30;
	elseif tiName = "width" then
		num := 18;
		shortDesc := "Wdth";
		longDesc := "Width";
		width := 30;
	elseif tiName = "voyageCode" then
		num := 19;
		shortDesc := "Voyage";
		longDesc := "Voyage Code";
		width := 100;
	elseif tiName = "messageMode" then
		num := 20;
		shortDesc := "Mode";
		longDesc := "Message Mode";
		width := 30;
	else
		num := 0;
		shortDesc := "";
		longDesc := "";
		width := 0;
	endif;
end;</source>
        <Parameter name="tiName" type="String"/>
        <Parameter name="shortDesc" type="String" usage="io"/>
        <Parameter name="longDesc" type="String" usage="io"/>
        <Parameter name="width" type="Integer" usage="io"/>
        <Parameter name="num" type="Integer" usage="io"/>
    </JadeMethod>
