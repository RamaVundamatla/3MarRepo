<CollClass name="CM_DwellDayRangeByLowerDict" id="3e0c1ed0-21f2-47fa-aefa-54846c18a9b2">
    <loadFactor>66</loadFactor>
    <memberType name="CM_DwellDayRange"/>
    <superclass name="MemberKeyDictionary"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="dwell"/>
    <MemberKey>
        <property name="CM_DwellDayRange::lower"/>
    </MemberKey>
    <JadeMethod name="removeObject" id="be06ba49-0def-4847-b706-eee946384fdc">
        <lockReceiver/>
        <updating/>
        <source>removeObject(_obj: MemberType): Boolean updating, lockReceiver;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
01 August 2011	cnwndl1	Initial creation	Par 27890

*/

vars
	iter	: Iterator;
	tmpObj	: MemberType;
	keyCode	: Integer;
begin
	iter := self.createIterator();
	
	while iter.next(tmpObj) do
		if tmpObj = _obj then
			self.getIteratorKeys(keyCode, iter);
			self.removeKey(keyCode);
			return true;
		endif;
	endwhile;

	return false;

epilog
	delete iter;
end;</source>
        <Parameter name="_obj" type="MemberType"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</CollClass>
