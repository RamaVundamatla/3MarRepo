begin

	self.initialiseActivity();
	
	// do validation
	self.raiseExceptionIfNull(_pxyTIMasterGen, 'Test Object');
	
	app.setContinueCMExceptions(true);
	app.myValUA.valCM_Object(_pxyTIMasterGen, _passport);
	
	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	
	realTIMasterGen := self.getRealObjectAndEditionCheck(_pxyTIMasterGen, 'Master Generator', _passport).CM_TIMasterGenerator;
	
	// realTIMasterGen.setForUpdate(_pxyTIMasterGen);
	
	if _passport.noErrors then
		// This is only required if the class is being auditted
		self.myUpdateAuditAgent.audUpdateGeneric(realTIMasterGen, true);
	endif;

	if _passport.noErrors then
		realTIMasterGen.setForUpdate(_pxyTIMasterGen);
	endif;

	if _passport.noErrors then
		// This is only required if the class is being auditted
		self.myUpdateAuditAgent.audUpdateGeneric(realTIMasterGen, false);
	endif;
	

epilog

end;</source>
