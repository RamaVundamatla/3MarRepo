    <JadeMethod name="convertToNZT" id="e3965d30-2654-4bf2-bb30-c3a8807489d1">
        <source>convertToNZT(_ts: TimeStamp): TimeStamp;

/*
Date			Who		Reason
13 July 2016	cnwar2	Initial creation

*/
vars
	t  		: Time;
	ts 		: TimeStamp;
	tsInt 	: TimeStampInterval;
	
begin
	t := _ts.time;
	if self.isDaylightSavingsNZ() then
		t := t + ((13-self.getGMTDiff())*1000*60*60);
	else
		t := t + ((12-self.getGMTDiff())*1000*60*60);
	endif;	
	
	ts.setDate(_ts.date);
	ts.setTime(t);
	
	return ts;
end;</source>
        <Parameter name="_ts" type="TimeStamp"/>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="convertToNZT_ignoreDST" id="6d5da42f-d168-4f67-a56e-aee636a8e46a">
        <source>convertToNZT_ignoreDST(_ts: TimeStamp): TimeStamp;

/*
Date			Who		Reason
13 July 2016	cnwar2	Initial creation

*/
vars
	t  		: Time;
	ts 		: TimeStamp;
	tsInt 	: TimeStampInterval;
	
begin
	t := _ts.time;
	t := t + ((12-self.gmtDiff)*1000*60*60);
	
	ts.setDate(_ts.date);
	ts.setTime(t);
	
	return ts;
end;</source>
        <Parameter name="_ts" type="TimeStamp"/>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="getGMTDiff" id="7b1e76e7-c01b-458f-b2fc-d4770a11ad4d">
        <source>getGMTDiff(): Integer;

/*
Date			Who		Reason
13 July 2016	cnwar2	Initial creation

*/
vars

begin
	if self.isDaylightSavings then
		return self.gmtDiff+1;
	endif;

	return self.gmtDiff;
end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getLocalHoursStr" id="d632d7ad-469e-4689-8b85-b57e874a96a7">
        <source>getLocalHoursStr(): String;

/*
Date			Who		Reason
13 July 2016	cnwar2	Initial creation

*/
vars
	ts  : TimeStamp;
	str : String;
	
begin
	ts  := self.getNextStartOfBusinessHours(ts);
	str := ts.time.String &amp; "  -  ";
	ts  := self.getNextEndOfBusinessHours(ts);
	str := str &amp; ts.time.String;
	
	return str;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getNextEndOfBusinessHours" id="12f119b6-9a02-4e3a-ab95-7976c51a050b">
        <source>getNextEndOfBusinessHours(_ts:TimeStamp): TimeStamp;

/*
Date			Who		Reason
11 July 2016	cnwar2	Initial creation

*/
vars
	t  		: Time;
	ts 		: TimeStamp;
	tsInt 	: TimeStampInterval;
	
begin
	// 9-5 working hours end (in NZT) 17:00 + (12-gmtDiff)
	// e.g. USA is GMT -4, so working hours start 17:00+16 --&gt; 09:00 the next day

	t.setTime(17,0,0,0);
	ts.setDate(_ts.date);
	ts.setTime(t);
	ts := self.convertToNZT(ts);
	
	if _ts &gt; ts then
		tsInt.set(1,0);
		ts := ts + tsInt;
	endif;
	
	if self.isDateWeekend(ts) then
		tsInt.set(1,0);
		return getNextEndOfBusinessHours(_ts+tsInt);
	endif;
	
	return ts;
end;</source>
        <Parameter name="_ts" type="TimeStamp"/>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="getNextStartOfBusinessHours" id="980bed59-63d0-48c6-85ad-d8247ddca2d3">
        <source>getNextStartOfBusinessHours(_ts:TimeStamp): TimeStamp;

/*
Date			Who		Reason
11 July 2016	cnwar2	Initial creation

*/
vars
	t 		: Time;
	ts		: TimeStamp;
	tsInt	: TimeStampInterval;
	
begin
	// 9-5 working hours start (in NZT) 09:00 + (12-gmtDiff)
	// e.g. USA is GMT -4, so working hours start 09:00+16 --&gt; 01:00 the next day

	t.setTime(9,0,0,0);
	ts.setDate(_ts.date);
	ts.setTime(t);
	ts := self.convertToNZT(ts);
	
	if _ts &gt; ts then
		tsInt.set(1,0);
		ts := ts + tsInt;
	endif;

	if self.isDateWeekend(ts) then
		tsInt.set(1,0);
		return getNextStartOfBusinessHours(_ts+tsInt);
	endif;
	
	return ts;
end;</source>
        <Parameter name="_ts" type="TimeStamp"/>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="isDateWeekend" id="21e31fab-81ad-4953-871e-e696a302a76a">
        <source>isDateWeekend(_ts : TimeStamp): Boolean;

/*
Date			Who		Reason
12 July 2016	cnwar2	Initial creation

*/
vars
	t		: Time;
	ts 		: TimeStamp;
	date	: Date;
	
begin
	// convert local midnight to NZT
	// e.g. Iraq (GMT+3) midnight is 09:00NZT
	t.setTime(0,0,0,0);
	ts.setDate(_ts.date);
	ts.setTime(t);
	ts := self.convertToNZT(ts);

	// compare local time to local midnight
	if _ts &lt; ts then
		// local time is the previous day to NZ
		// e.g. Iraq 18:00 Friday is 03:00NZT Saturday (_ts) &lt; Iraq midnight Saturday is 09:00NZT (ts)
		date := _ts.date - 1;
	else
		// local time is the same day as NZ
		// e.g. Iraq 04:00 Friday is 13:00NZT Friday (_ts) &lt; Iraq midnight Friday is 09:00NZT (ts)
		date := _ts.date;
	endif;	
	
	if date.dayName = 'Saturday' or date.dayName = 'Sunday' then
		return true;
	endif;

	return false;
end;</source>
        <Parameter name="_ts" type="TimeStamp"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isDaylightSavings" id="ad2500d0-c35c-4afd-8e5d-3f63a4292831">
        <source>isDaylightSavings(): Boolean;

/*
Date			Who		Reason
13 July 2016	cnwar2	Initial creation

*/
vars
	currentTS,
	dstStart, dstEnd : TimeStamp;
	date : Date;
	time : Time;
	
begin
	currentTS := app.actualTimeServer();

	if self.name = 'NZ' then
		return self.isDaylightSavingsNZ();
		
	elseif self.name = 'Europe' then
	// Italy and Netherlands have same daylight savings rule
	// starts last Sunday in March (2am-&gt;3am)
	// ends last Sunday in October (3am-&gt;2am)
		date.setDate(31,3,currentTS.Date.year);
		while date.dayName &lt;&gt; 'Sunday' do
			date := date - 1;
		endwhile;
		time.setTime(2,0,0,0);
		dstStart.setDate(date);
		dstStart.setTime(time);
		dstStart := self.convertToNZT_ignoreDST(dstStart);
		
		date.setDate(31,10,currentTS.Date.year);
		while date.dayName &lt;&gt; 'Sunday' do
			date := date - 1;
		endwhile;
		time.setTime(3,0,0,0);
		dstEnd.setDate(date);
		dstEnd.setTime(time);
		dstEnd := self.convertToNZT_ignoreDST(dstEnd);
		
		if currentTS &lt; dstEnd and currentTS &gt; dstStart then
			return true;
		endif;
	
	elseif self.name = 'USA (West)' or self.name = 'USA (East)' then
	// All of US observes DST except Arizona, Hawaii and overseas territories
	// starts second Sunday in March (2am-&gt;3am)
	// ends first Sunday in November (2am-&gt;1am)
		date.setDate(1,3,currentTS.Date.year);
		while date.dayName &lt;&gt; 'Sunday' do
			date := date + 1;
		endwhile;
		date := date + 1;
		while date.dayName &lt;&gt; 'Sunday' do
			date := date + 1;
		endwhile;
		time.setTime(2,0,0,0);
		dstStart.setDate(date);
		dstStart.setTime(time);
		dstStart := self.convertToNZT_ignoreDST(dstStart);
		
		date.setDate(1,11,currentTS.Date.year);
		while date.dayName &lt;&gt; 'Sunday' do
			date := date + 1;
		endwhile;
		time.setTime(2,0,0,0);
		dstEnd.setDate(date);
		dstEnd.setTime(time);
		dstEnd := self.convertToNZT_ignoreDST(dstEnd);
		
		if currentTS &lt; dstEnd and currentTS &gt; dstStart then
			return true;
		endif;
	
	elseif self.name = 'Mexico' then
	// The states of Sonora and Quintana Roo do not observe daylight saving time.
	// Some border municipalities observe daylight saving time consistent with US instead of normal Mexico DST.
	// starts first Sunday in April (2am-&gt;3am)
	// ends last Sunday in October (2am-&gt;1am)
		date.setDate(1,4,currentTS.Date.year);
		while date.dayName &lt;&gt; 'Sunday' do
			date := date + 1;
		endwhile;
		time.setTime(2,0,0,0);
		dstStart.setDate(date);
		dstStart.setTime(time);
		dstStart := self.convertToNZT_ignoreDST(dstStart);
		
		date.setDate(31,10,currentTS.Date.year);
		while date.dayName &lt;&gt; 'Sunday' do
			date := date - 1;
		endwhile;
		time.setTime(2,0,0,0);
		dstEnd.setDate(date);
		dstEnd.setTime(time);
		dstEnd := self.convertToNZT_ignoreDST(dstEnd);
		
		if currentTS &lt; dstEnd and currentTS &gt; dstStart then
			return true;
		endif;
	endif;
	
	// UAE, Qatar, Oman, Iraq and Ghana do not observe DST
	
	return false;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isDaylightSavingsNZ" id="a1b9ca66-1c54-4460-bdc2-ab3185226c2b">
        <source>isDaylightSavingsNZ(): Boolean;

/*
Date			Who		Reason
13 July 2016	cnwar2	Initial creation

*/
vars
	currentTS,
	dstStart, dstEnd : TimeStamp;
	date : Date;
	time : Time;
	
begin
	currentTS := app.actualTimeServer();
	
	// starts last Sunday in September (2am-&gt;3am)
	// ends first Sunday in April (3am-&gt;2am)
	date.setDate(30,9,currentTS.Date.year);
	while date.dayName &lt;&gt; 'Sunday' do
		date := date - 1;
	endwhile;
	time.setTime(2,0,0,0);
	dstStart.setDate(date);
	dstStart.setTime(time);
	
	date.setDate(1,4,currentTS.Date.year);
	while date.dayName &lt;&gt; 'Sunday' do
		date := date + 1;
	endwhile;
	time.setTime(3,0,0,0);
	dstEnd.setDate(date);
	dstEnd.setTime(time);
	
	if currentTS &lt; dstEnd or currentTS &gt; dstStart then
		return true;
	endif;

	return false;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
