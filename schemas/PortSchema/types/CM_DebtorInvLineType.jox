    <JadeMethod name="validateForCreate" id="7b078362-ea0a-4d7b-bc7e-2f550f31f8e7">
        <source>validateForCreate();
// 20 September 2011	cnwjre1	CCMS 2120 Electronic Invoicing
begin

	if self.myDebtor = null then
	 //	app.raiseCMException1(REQUIRED_FIELD, "Debtor", null, null);
		app.raiseCMException(Input_required_field_debtor, null, null);
		
	endif;
	if self.myInvoiceLineType = null then
	 //	app.raiseCMException1(REQUIRED_FIELD, "Invoice line type", null, null);
		app.raiseCMException(Input_required_field_invLneTyp, null, null); // cnwdb2	PAR 35364
	endif;

end;</source>
    </JadeMethod>
