    <JadeMethod name="getValidYardGridAreaViewMode" id="e1ada5fb-496f-4e24-b39e-35248046a3c0">
        <source>getValidYardGridAreaViewMode(_viewMode: Integer): Integer;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
06 April 2009	cnwjk3	PAR 19329

*/

vars

begin
	if _viewMode = VIEW_IMEX or 
	   _viewMode = VIEW_HEIGHT or
	   _viewMode = VIEW_WEIGHT or
	   _viewMode = VIEW_HAZ  //or
	  // _viewMode = VIEW_DWELL	//20 Jul 2011	NDL	Par 27890
	   then		// cnwjk3 PAR 23025 17/03/2010
	   
	   // When we open up the yard grid areas from from the Satellite View, these modes aren't supported, so 
	   // default to view by voyage
	   return VIEW_VOYAGE;
	else
		return inheritMethod(_viewMode);
	endif;
epilog

end;</source>
