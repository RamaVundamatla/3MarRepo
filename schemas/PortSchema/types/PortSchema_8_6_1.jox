    <JadeMethod name="setupMvmntPilotDetails" id="a10cd69e-7cd9-4280-bc1f-34becb404b27">
        <updating/>
        <source>setupMvmntPilotDetails(_controller: CnEcReleaseController) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 May 2019	jlgsl4	TFS 44438 - PEL1 - Multiple Pilot Launches for one movement

*/

vars
	voyageMovement : HMS_VoyageMovement;
	pilot : HMS_Pilot;
	movementPilotDetails : HMS_MovementPilotDetails;
	canSetPilotLaunch,
	setPilotLaunchBefore, isOK : Boolean;
	voyage : CM_Voyage;
	voyageGlobal : CM_VoyageGlobal;
	terminalCode : String;
	pilotLaunch : HMS_PilotLaunch;	
begin
	if self.hasScriptBeenRunAtAll(method.name, null) then
		return;
	endif;
	app.myPassport.setMyUserFromCode(SUPERUSER_Str);

	app.writeLog(class.name &amp; '::' &amp; method.name &amp; " - Start Upgrade Multiple Pilot Movement", LogINFO);
	if _controller &lt;&gt; null then
		_controller.logEntry(" Start Upgrade Multiple Pilot Movement");
	endif;

	beginTransaction;
	foreach voyageMovement in HMS_VoyageMovement.instances where voyageMovement.allMovementPilotDetails.isEmpty do
		if not voyageMovement.allPilots.isEmpty then
			setPilotLaunchBefore := false; // pilot launch hasn't been set for any of this movement's pilots yet
			canSetPilotLaunch := true; // if not Pelindo, pilot launch can always be set for a movement's pilots
			pilotLaunch := voyageMovement.myPilotLaunch; // one pilot launch per movement
			foreach pilot in voyageMovement.allPilots do
				create movementPilotDetails persistent;
				movementPilotDetails.setMyPilot(pilot);
				if pilotLaunch &lt;&gt; null and setPilotLaunchBefore then // if movement has a valid pilot launch and it's been set for a pilot before,
					voyageGlobal := voyageMovement.myVoyageGlobal; // need to check for Pelindo voyage process; first get voyage details
					if voyageGlobal &lt;&gt; null then
						voyage := voyageGlobal.allVoyages.first;
						if voyage &lt;&gt; null then // voyage is valid, what's its voyage process?
							if voyage.myVoyageProcess = CM_VoyageProcessIPN1.firstInstance or voyage.myVoyageProcess = CM_VoyageProcessPEL1.firstInstance then
								canSetPilotLaunch := false; // Pelindo - can't use launch again, it's been used already
								terminalCode := "Unknown";
								if voyage.myTerminalActive &lt;&gt; null then
									terminalCode := voyage.myTerminalActive.code;
								endif; // log info so someone can set pilot's launch manually
								app.writeLog(class.name &amp; '::' &amp; method.name &amp; " *** Have not set pilot launch for pilot " &amp; pilot.description &amp;
									" on voyage " &amp; voyage.code &amp; ", terminal " &amp; terminalCode &amp; " - needs to be set manually ***", LogINFO);
							endif;
						endif;
					endif;
				endif;
				if canSetPilotLaunch and pilotLaunch &lt;&gt; null then
					movementPilotDetails.setMyPilotLaunch(pilotLaunch);
					setPilotLaunchBefore := true; // record that the pilot launch has been used
				endif;
				voyageMovement.allMovementPilotDetails.add(movementPilotDetails);
			endforeach;
		elseif voyageMovement.myPilot &lt;&gt; null then // Empty allPilots means the terminal's using now-deprecated myPilot...
			create movementPilotDetails persistent;
			movementPilotDetails.setMyPilot(voyageMovement.myPilot);
			movementPilotDetails.setMyPilotLaunch(voyageMovement.myPilotLaunch);
			voyageMovement.allMovementPilotDetails.add(movementPilotDetails);
		endif;
		voyageMovement.setUnusedMyPilotRefToNull();
		voyageMovement.setUnusedMyPilotLaunchNull();
	endforeach;
	commitTransaction;

	app.writeLog(class.name &amp; '::' &amp; method.name &amp; " - Completed Upgrade Multiple Pilot Movement", LogINFO);
	if _controller &lt;&gt; null then
		_controller.logEntry("Completed Upgrade Multiple Pilot Movement");
	endif;
	self.addScriptRun(method.name);
	isOK := true;
epilog
	if not isOK then
		abortTransaction;
	endif;
end;</source>
        <Parameter name="_controller" type="CnEcReleaseController"/>
    </JadeMethod>
    <JadeMethod name="specificPostStandard" id="f0433b21-2898-4842-a625-09b604fe9ed4">
        <updating/>
        <source>specificPostStandard(pControllerObj: CnEcReleaseController) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
/* Changes

Date		Name	TFS#		Description
============================================================================
19 Jan 2017	cnwdap1				Initial creation PAR #
03 Feb 2017	cnwrs1	TFS 3247 	not deleting emails at NXL
14 Nov 2017	jlgrs1	TFS 5705 	SNO - EDIDataBooking Prenote release Req
26 Feb 2018	jlgsl4	TFS 37088  	use plannedDT instead of hireDT
16/03/2018	jlgdap1	TFS 37540 	PEL1 Voyage Statuses Pelindo 1
22/03/2018	jlgdap1	TFS 37445 	PEL1 Voyage Status Security
18/01/2019	jlgdap1	TFS 41738 	System Items icon is missing in Navigator
07/03/2019	jlgdap1	TFS 41570 	PNL no PIN for Cargo Type
02 Apr 2019	jlgka1	43817		JMT - Change Lock Keeper/KPI name.
15 Apr 2019	jlgka1	43863		AAT - Set Recurring Unit and Value for Monthly Intervals.
15 May 2019 jlgsl4	44438   	PEL1 - Multiple Pilot Launches for one movement
06 Jun 2019	jlgsl4	45059		PEL1 - tidy up orphaned movement pilot details objects
05 Jun 2019	jlgdap1	TFS 44554	AAT Stevedore Data Access
22 Jul2019	cnwma1	ChangeRequest 45577: ASPA - JMT Interface to AR Oracle
15 Jul 2019	jlgdi1	45301		JMT - Set the cash payment status to CM_CashPayment.Status_Merged 
								when the cash payment is 'Void' and is link to a zombie (CM_TrackedItem.hasBeenMerged)
21/08/2019	jlgdap1	TFS 45836 PEN Approved Carrier for ISO Type and Trailer Type
03 Sep 2019	jlgsl4	TFS 45872	JMT - Cash Credit UI changes
01 Oct 2019	jlgdi1	45802		Update form permission's new attribute 'formType'
05 Nov 2019	jlgdap1	TFS 46405	AAT Flat Rack and OOG in LOLO Planning Screen
//6/11/2019	JLGNS1	ChangeRequest 46721: PEN - CAMIR Message Processing
31 Jan 2020	jlgzm1	TFS 48378	8.6.2 Prep - script differences between Wmast and Dmast 
============================================================================*/
vars

begin
	inheritMethod(pControllerObj);
	
	self.createMTPoolPartyDebtorType(pControllerObj);					// TFS 3043
	self.convertEmailReceivalSetting(pControllerObj);
	
	self.setPmAdmIsExternallyMonitored(pControllerObj); //epr TFS 3581 7/3/17
	self.setNewPmAdmInvoice(pControllerObj); // 17/03/2016 cnwma1 TFS #3661
	self.updatePoolingPartners();			// TFS 4370 cnwdap1
	self.fixInvoiceAllocations(pControllerObj);		// TFS 4542 cnwkpd1
	self.cleanUpStorageDetailPriority(pControllerObj); // TFS 4271 cnwab1
	self.updateMSKCodecoPackUnpack(pControllerObj);	//TFS 4465 SNO standard Codeco
	self.setNewPmWebservices(pControllerObj); //TFS 5535 web service security audit;
	self.updateContainerVGMDetails(pControllerObj);		// TFS 4492 SNO VERMAS Changes
	self.tfs5685STWRFinancialInstance();	//12 Sep 2017	NDL	TFS 6938
	self.tfs6962Conversion();
	self.setDoorDirectionConfig(pControllerObj); //epr TFS 7006 29/9/17
	self.initRTConfigAutoSearchDir(pControllerObj);	//10 Nov 2017	NDL:	TFS 7427
	self.updateUseOldCoparn(pControllerObj);
	self.updateDrawingAttributes(pControllerObj);	// 13/12/17 MAP TFS7493
	self.updateDrawingAttributes2(pControllerObj);	//05 Feb 2018	NDL	TFS 36752
	self.setNewPermDelUser(pControllerObj);	//14 Feb 2018	NDL	TFS 36947
	self.fixCargoAndProductAttributes(pControllerObj); //epr 19 Feb 2018 tfs 7756 tidy up for web portal prenotes
	self.copyHireDTtoPlannedDT(pControllerObj); // TFS 37088 SDL 26 Feb 2018
	self.upgradeVoyageTransfer(pControllerObj); // 09 Mar 2018	NDL	TFS 37444
	self.setupDefaultVoyageProcess(pControllerObj);	// 13/03/2018	jlgdap1 TFS 37427
	self.updateVoyageEDIBayPlanStatus(pControllerObj);	// 20 Mar 2018	jlgrs1	TFS 37484 - QNS Allow DB Loading of Bay Plan files
	self.setSecondaryCurrencies(pControllerObj); // 21 Mar 2018	NDL	TFS 37550
	self.setupDefaultVoyageProcess(pControllerObj);				// TFS 37540
	self.setVoyageStatusSecurityRoles(pControllerObj);			// TFS 37445
	self.fixMachTypesThatDontSuppRT(pControllerObj);	// TFS 38555 jlgmd1 14/05/2018
	self.fixReportTemplatePrinters(pControllerObj);		// TFS 7140 jlgmd1
	self.fixImportConfirmedListReport(pControllerObj);	//	Bug 38553 JLGNS1	18/05/18
	self.updateCashDrErrConfig(pControllerObj);	//30 May 2018	NDL	TFS 38952
	self.createNullVessel(pControllerObj);	//07 Jun 2018	NDL	TFS 38914
	self.fixupWorkOrderTransactions(); // 26JUN2018JLGAB1 TFF 39237
	self.updateCargoGroupComplete(pControllerObj);		// 27/06/2018 TFS #39132
	self.convertTidalClassRates(pControllerObj);	//29 Jun 2018	NDL	TFS 39338
	self.fixupVoyageProcess(); // 29JUN2018JLGAB1 TFS 39236
	self.createWorkOrderCalcTypes(pControllerObj); // 12JUL2018JLGAB1 TFS 39236
	self.setUseRelReqAnyVoyLoad( pControllerObj ); //16 Jul 2018	NDL	TFS 38679
	self.upgradeCargoGroupAssign( pControllerObj );//05 Oct 2018	NDL	TFS 39186
	self.renameRenumberPELVoyageSatuses(pControllerObj);  // 25OCT18 TFS 41539
	self.renumberPriPELVoyageSatuses(pControllerObj);  // 25OCT18 TFS 41539
	self.convertTermConfigToBank( pControllerObj );//08 Jan 2019	NDL	TFS 40010
	self.resetSystemMenuIcon(pControllerObj);	// 18 Jan 2019 jlgdap1 TFS 41738
	self.convertAutoGenIdResetSeq(pControllerObj); //23 Jan 2019	NDL	TFS 43018
	
	// TFS 43188(TFS 39618 PATCH 2) this method must be first for TFS 39618 because it creates the process and status objects.
	self.createInvProcStatus(pControllerObj); //25 Jan 2019	NDL	TFS 39618

	self.createDefaultInvEmail(pControllerObj); //25 Jan 2019	NDL	TFS 39618
