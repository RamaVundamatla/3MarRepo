<Class name="Script">
    <JadeMethod name="cnEcSetSource" id="4ee6e819-e303-4d07-b960-27f38d966843">
        <updating/>
        <source>cnEcSetSource(pSource:String) updating;
// --------------------------------------------------------------------------------
// Created:		16 August 2001 by cnwdad1
//
// Purpose:		Updates the source of the receiver.
//
// Parameters:	pSource - The receiver's (new) source.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if self.source &lt;&gt; pSource then
		self.source	:=	pSource;
	endif;
end;</source>
        <Parameter name="pSource" type="String"/>
    </JadeMethod>
</Class>
