    <JadeMethod name="createConversionTransaction" id="096374dd-6434-49fd-b62d-40c8293c556c">
        <updating/>
        <source>createConversionTransaction(_passport : CM_Passport input): HMS_Transaction updating;
//--------------------------------------------------------------
//Created: 25 July 2003 By: cnwrs1
// only used for adding old transactions during conversion
// remove after HMS Conversion
//--------------------------------------------------------------
vars
	theClass : Class;
	trans : HMS_Transaction;
begin
	if not app.isConverting then
		return null;
	endif;
	// Check for the basics first
	self.validate();
	if _passport.hasErrors then
		return null;
	endif;
	
	theClass := global.getHMSTxnClassForType(self.type);
	if theClass = null then
		return null;
	endif;
	
	create trans as theClass;
		
	if trans.validate(self) then
		trans.setFromTransController(self, _passport);
	else
		delete trans;
		return null;
	endif;
	
	// Delete transaction if there are no changes to properties
//	if trans.allPropertyChanges.isEmpty then
//		delete trans;
//		return null;
//	endif;	
	
	if _passport.hasErrors then
		delete trans;
		return null;
	endif;
	return trans;
end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <ReturnType type="HMS_Transaction"/>
    </JadeMethod>
    <JadeMethod name="createTransaction" id="eb4f2a89-e3cb-4d39-8ec5-beceffe68c46">
        <updating/>
        <source>createTransaction(_passport : CM_Passport input) updating;
//--------------------------------------------------------------
//Created: 25 July 2003 By: cnwgd1
//--------------------------------------------------------------
vars
	theClass : Class;
	trans : HMS_Transaction;
begin

	// Check for the basics first
	self.validate();
	if _passport.hasErrors then
		return;
	endif;
	
	theClass := global.getHMSTxnClassForType(self.type);
	if theClass = null then
		return;
	endif;
	
	create trans as theClass;
		
	if trans.validate(self) then
		trans.setFromTransController(self, _passport);
	else
		delete trans;
		return;
	endif;
	
	// Delete transaction if there are no changes to properties
	if trans.allPropertyChanges.isEmpty then
		delete trans;
		return;
	endif;	
	
	if _passport.hasErrors then
		delete trans;
		return;
	endif;

end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="validate" id="1ee0bbb9-4a4f-4602-8918-37a5f9c7c4e5">
        <source>validate();
//--------------------------------------------------------------
//Created: 29 July 2003 By: cnwgd1
//--------------------------------------------------------------
vars

begin
	if self.myTerminal = null then
		app.raiseCMException2(InvalidAttrForUpdate, 'Terminal', 'Null', null, null);
	endif;
	if self.myHMSVoyageData = null then
		app.raiseCMException2(InvalidAttrForUpdate, 'HMS Voyage', 'Null', null, null);
	endif;
	if self.type = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Type', null, null);
		app.raiseCMException(Input_required_field_type, null, null); // cnwdb2	PAR 35364
	endif;		
end; </source>
    </JadeMethod>
</Class>
