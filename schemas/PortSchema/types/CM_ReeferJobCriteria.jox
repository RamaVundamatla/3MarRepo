    <JadeMethod name="setForUpdate" id="e13790b3-28bc-488e-b832-c328b5bbdeda">
        <updating/>
        <source>setForUpdate( _proxy: CM_ReeferJobCriteria ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 July 2020	jlgndl1	Initial creation	TFS 49581

*/

vars

begin

	inheritMethod( _proxy );
	
	self.alarm := _proxy.alarm;
	self.allTimes.clear();
	if _proxy.allTimes &lt;&gt; null and not _proxy.allTimes.isEmpty then
		_proxy.allTimes.copy( self.allTimes );
	endif;
	self.connect := _proxy.connect;
	self.connectDelayMins := _proxy.connectDelayMins;
	self.disconnect := _proxy.disconnect;
	self.disconnectDelayMins := _proxy.disconnectDelayMins;
	self.monitor := _proxy.monitor;
	self.name := _proxy.name;
	self.variance := _proxy.variance;
	self.myTerminal := _proxy.myTerminal;

epilog

end;</source>
        <Parameter name="_proxy" type="CM_ReeferJobCriteria"/>
    </JadeMethod>
    <JadeMethod name="setProxyBaseData" id="c11a89a4-f7e9-4f0a-b17d-d9cbc77341fd">
        <updating/>
        <source>setProxyBaseData(	_alarm : Boolean;
					_allTimes : TimeArray;
					_connect : Boolean;
					_connectDelayMins : Integer;
					_disconnect : Boolean;
					_disconnectDelayMins : Integer;
					_monitor : Boolean;
					_name : String;
					_variance : TimeStampInterval;
					_myTerminal : CM_Terminal
					)updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 July 2020	jlgndl1	Initial creation	TFS 49581

*/

vars

begin

	self.alarm := _alarm;
	self.allTimes.clear();
	if _allTimes &lt;&gt; null and not _allTimes.isEmpty then
		_allTimes.copy( self.allTimes );
	endif;
	self.connect := _connect;
	self.connectDelayMins := _connectDelayMins;
	self.disconnect := _disconnect;
	self.disconnectDelayMins := _disconnectDelayMins;
	self.monitor := _monitor;
	self.name := _name;
	self.variance := _variance;
	self.myTerminal := _myTerminal;

epilog

end;</source>
        <Parameter name="_alarm" type="Boolean"/>
        <Parameter name="_allTimes" type="TimeArray"/>
        <Parameter name="_connect" type="Boolean"/>
        <Parameter name="_connectDelayMins" type="Integer"/>
        <Parameter name="_disconnect" type="Boolean"/>
        <Parameter name="_disconnectDelayMins" type="Integer"/>
        <Parameter name="_monitor" type="Boolean"/>
        <Parameter name="_name" type="String"/>
        <Parameter name="_variance" type="TimeStampInterval"/>
        <Parameter name="_myTerminal" type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="validateMe" id="b6bece28-8b37-4af3-8bb5-9eee96b70126">
        <source>validateMe();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 July 2020	jlgndl1	Initial creation	TFS 49581

*/

vars

begin

	if self.myTerminal = null then
		app.raiseCMException(Terminal_reference_set, null, null);
	endif;
	
	if not self.alarm
	and not self.monitor
	and not self.connect
	and not self.disconnect
	then
		app.raiseCMWarning(Action_selected, null, null, null);
	endif;
	
	if self.monitor and self.allTimes.isEmpty then
		app.raiseCMException(Monitor_times_selected, null, null);
	endif;

epilog

end;</source>
    </JadeMethod>
</Class>
