    <JadeMethod name="setEmailControllerAddresses" id="97dcd982-a4a4-4422-b15c-a6b1e06cd1de">
        <source>setEmailControllerAddresses(_emailController : CMIF_EmailTemplateController input);
/*
Purpose - 	
Who - NAVAB1
Date - 08JUL2024
ADO -  CR 64617 TASK 64638
*/

vars
	bccs, ccs, tos : StringArray;
	str : String;
	email : CM_EmailEntity;

begin
	create bccs transient;
	create ccs transient;
	create tos transient;
	bccs.cnGetTokens(self.bccAddresses, SemiColon, false);
	ccs.cnGetTokens(self.ccAddresses, SemiColon, false);
	tos.cnGetTokens(self.toAddresses, SemiColon, false);
	foreach str in bccs do
		email := app.myRoot.allEmailAddressesByAddress[str.trimBlanks];
		if email &lt;&gt; null then
			_emailController.allBccAddresses.add(email);
		endif;
	endforeach;
	foreach str in ccs do
		email := app.myRoot.allEmailAddressesByAddress[str.trimBlanks];
		if email &lt;&gt; null then
			_emailController.allCcAddresses.add(email);
		endif;
	endforeach;
	foreach str in tos do
		email := app.myRoot.allEmailAddressesByAddress[str.trimBlanks];
		if email &lt;&gt; null then
			_emailController.allToAddresses.add(email);
		endif;
	endforeach;
epilog
	delete bccs;
	delete ccs;
	delete tos;
end;</source>
        <Parameter name="_emailController" type="CMIF_EmailTemplateController" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="81a4fdc0-d8e4-4a43-aa53-d65a36b21379">
        <updating/>
        <source>setForCreate(_entTable: String; _fields: StringArray; _message: String; _subject: String; _name: String; _objectType: String; _type: Integer; _terminal: CM_Terminal; _copyTo: String; _sendToCarrier: Boolean; _sendToConsignee: Boolean) updating;
/*
Purpose - 	
Who - NAVAB1
Date - 08JUL2024
ADO -  CR 64617 TASK 64638
*/

vars

begin
	inheritMethod(_entTable, _fields, _message, _subject, _name, _objectType, _type, _terminal, _copyTo, _sendToCarrier, _sendToConsignee);
	
	self.myRoot := app.myRoot;
epilog

end;</source>
        <Parameter name="_entTable" type="String"/>
        <Parameter name="_fields" type="StringArray"/>
        <Parameter name="_message" type="String"/>
        <Parameter name="_subject" type="String"/>
        <Parameter name="_name" type="String"/>
        <Parameter name="_objectType" type="String"/>
        <Parameter name="_type" type="Integer"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_copyTo" type="String"/>
        <Parameter name="_sendToCarrier" type="Boolean"/>
        <Parameter name="_sendToConsignee" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setFromEmailTemplate" id="8734b35b-772f-42c5-a7d1-4a8bc8907b31">
        <updating/>
        <source>setFromEmailTemplate(_emailTemplate : CM_EmailTemplate) updating;
/*
Purpose - 	
Who - NAVAB1
Date - 08JUL2024
ADO -  CR 64617 TASK 64638
*/

vars
	emailController : CMIF_EmailTemplateController;
begin
	if _emailTemplate = null then
		return;
	endif;
	
	if self.myEmailController &lt;&gt; null then
	
		emailController := self.myEmailController;
		
		//collections
		emailController.allToAddresses.clear;
		emailController.allBccAddresses.clear;
		emailController.allCcAddresses.clear;
		if _emailTemplate.allToAddresses &lt;&gt; null then
			_emailTemplate.allToAddresses.copy(emailController.allToAddresses);
		endif;
		if _emailTemplate.allBCCAddresses &lt;&gt; null then
			_emailTemplate.allBCCAddresses.copy(emailController.allBccAddresses);
		endif;
		if _emailTemplate.allCCAddresses &lt;&gt; null then
			_emailTemplate.allCCAddresses.copy(emailController.allCcAddresses);
		endif;
		//free text
		emailController.freeTxtToAddesses	:= _emailTemplate.toAddresses;
		emailController.freeTxtBccAddesses	:= _emailTemplate.bccAddresses;
		emailController.freeTxtCcAddesses	:= _emailTemplate.ccAddresses;
	
	endif;
	
	self.allIncludedFields.clear;
	if _emailTemplate.allIncludedFields &lt;&gt; null then
		_emailTemplate.allIncludedFields.copy(self.allIncludedFields);
	endif;

	self.entTableName	:= _emailTemplate.entTableName;
	self.message		:= _emailTemplate.body;
	self.name			:= _emailTemplate.name;
	self.objectType		:= _emailTemplate.objectType;
	self.subjectLine	:= _emailTemplate.subject;
	self.type			:= _emailTemplate.type;
	
	self.copyTo				:= _emailTemplate.copyTo;
	self.showFirst5Issues		:= _emailTemplate.sendtoOperatorVoyage;
	
epilog

end;</source>
        <Parameter name="_emailTemplate" type="CM_EmailTemplate"/>
    </JadeMethod>
    <JadeMethod name="setProxyStatusEmail" id="796c30c1-a399-4a6f-8c93-f5f58f73a13e">
        <updating/>
        <source>setProxyStatusEmail(	_subject : String;
						_message : String;
						_includedFields : StringArray;
						_enabled : Boolean;
						_copyTo : String;
						_showFirst5Issues : Boolean
						) updating;
/*
Purpose - 	
Who - NAVAB1
Date - 08JUL2024
ADO -  CR 64617 TASK 64638
*/

vars

begin
	self.subjectLine := _subject;
	self.message := _message;
	self.allIncludedFields.clear;
	_includedFields.copy(self.allIncludedFields);
	self.enabled := _enabled;
	self.copyTo := _copyTo;
	
	self.entTableName := ETDef_EDIEmailFields;
	
	self.myRoot := app.myRoot;
epilog

end;</source>
        <Parameter name="_subject" type="String"/>
        <Parameter name="_message" type="String"/>
        <Parameter name="_includedFields" type="StringArray"/>
        <Parameter name="_enabled" type="Boolean"/>
        <Parameter name="_copyTo" type="String"/>
        <Parameter name="_showFirst5Issues" type="Boolean"/>
    </JadeMethod>
</Class>
