<Class name="CM_RailAllocation" id="45e557c0-ed37-47d9-869b-168019c2ea1b">
    <superclass name="CM_YardAllocation"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>
TH2: Required for Gdansk - extremely simplified yard allocation, only for wagon's.
Requires only Freight-forwarder, destination and release request (new) criteria.
So simplified in fact that it hardly uses any of superclass attributes or methods, but
a subclass of yard allocation nonetheless - for convienience at the time of initial 
development as per design discussion with RS2 09/11/06.</text>
    <DbClassMap file="yardAllocations"/>
    <ExplicitInverseRef name="allWagonControllers" id="47ad364c-0d3a-46a0-9931-133f272e52bf">
        <kind>child</kind>
        <transientToPersistentAllowed/>
        <type name="CM_WagonLCByIdDict"/>
        <access>readonly</access>
        <Inverse name="CM_WagonController::myRailAllocation"/>
    </ExplicitInverseRef>
    <JadeMethod name="getAllocationColor" id="b095a56e-9fad-4f89-8f5f-96f3cf041cc1">
        <source>getAllocationColor() : Integer;
/*
----------   ----------  --------------------------------------------------
Created:	15 November 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	//criteria			: CM_YACriteria;
	//destPort			: CM_Port;
begin
	return self.color;	//+ cnwmd1, CCMS 1067, Par 19710
	/*					//- cnwmd1, CCMS 1067, Par 19710
	foreach criteria in self.allCriteria do
		if criteria.myYACriteriaType.type = YACriteriaType_DestinationPort then
			destPort := criteria.myYAData.CM_YADataObjects.getFirstObject().CM_Port;
			if destPort  &lt;&gt; null then
				return destPort.colour;
			else
				return null;
			endif;
		endif;
	endforeach;

	return null;
	*/
end;


</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getConsignee" id="4b7a45b5-9eb9-46e9-8cf8-f5f37e702f93">
        <source>getConsignee() : CM_ConsigneeConsignor;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
19 May 2009	cnwmd1	Initial creation

*/

vars
	criteria			: CM_YACriteria;
begin
	foreach criteria in self.allCriteria do
		if criteria.myYACriteriaType.type = YACriteriaType_Consignee then
			return criteria.myYAData.CM_YADataObjects.getFirstObject().CM_ConsigneeConsignor;
		endif;
	endforeach;
end;
</source>
        <ReturnType type="CM_ConsigneeConsignor"/>
    </JadeMethod>
    <JadeMethod name="getCriteriaOfType" id="ca336eba-ee47-46bb-8158-bac00fc9c5b1">
        <source>getCriteriaOfType(_criteriaType : CM_YACriteriaType) : CM_YACriteria;
/*
----------   ----------  --------------------------------------------------
Created:	15 November 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
19/08/2008   Simon Ward  SFW1030 - Promoted method to super-class CM_YardAllocation
----------   ----------  --------------------------------------------------
*/
/*
vars
	criteria		: CM_YACriteria;
begin
	foreach criteria in self.allCriteria do
		if criteria.myYACriteriaType = _criteriaType then
			return criteria;
		endif;
	endforeach;

	return null;
end;
*/
begin
	return inheritMethod(_criteriaType);
end;


</source>
        <Parameter name="_criteriaType" type="CM_YACriteriaType"/>
        <ReturnType type="CM_YACriteria"/>
    </JadeMethod>
    <JadeMethod name="getDestinationPort" id="4dbfba64-2302-45e3-9635-c505e7f9586b">
        <source>getDestinationPort() : CM_Port;
/*
----------   ----------  --------------------------------------------------
Created:	14 November 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	criteria			: CM_YACriteria;
begin
	foreach criteria in self.allCriteria do
		if criteria.myYACriteriaType.type = YACriteriaType_DestinationPort then
			return criteria.myYAData.CM_YADataObjects.getFirstObject().CM_Port;
		endif;
	endforeach;

end;


</source>
        <ReturnType type="CM_Port"/>
    </JadeMethod>
    <JadeMethod name="getExtraInfo" id="538b5b90-31ab-4a21-b0f0-55aca1f110cc">
        <source>getExtraInfo(_dataContainer: CM_DataContainer);
// ---------------------------------------------------------------------------
// Created:		May 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	block : CM_DataContainerBlock;
//	terminal : CM_Terminal;
//	tmpPort : CM_Port;
//	ffwd : CM_ConsigneeConsignor;
//	br : CM_BulkRelease;
	criteria : CM_YACriteria;
begin


	block := _dataContainer.addNewBlock;
	block.addNewItem("Code", DC_Label, 1, self);
	block.addNewItem(self.code, DC_Data, 1, self);

	block := _dataContainer.addNewBlock;
	block.addNewItem("Description", DC_Label, 1, self);
	block.addNewItem(self.description, DC_Data, 1, self);

	foreach criteria in self.allCriteria discreteLock do
		if criteria.myYACriteriaType &lt;&gt; null then // PAR 22051
			if criteria.myYACriteriaType.type = YACriteriaType_ImexStatus then
				continue;
			endif;
			block := _dataContainer.addNewBlock;
			block.addNewItem(criteria.myYACriteriaType.description, DC_Label, 1, self);
			block.addNewItem(criteria.getRawDescription, DC_Data, 1, self);
		endif;
	endforeach;
	
	if app.isSpecial() then
		block := _dataContainer.addNewBlock;
		block.addNewItem("OID", DC_Label, 1, self);
		block.addNewItem(self.String, DC_Data, 1, self);

	endif;
	
	/*

	block := _dataContainer.addNewBlock;
	block.addNewItem("Code", DC_Label, 1, self);
	block.addNewItem(self.code, DC_Data, 1, self);

	block := _dataContainer.addNewBlock;
	block.addNewItem("Description", DC_Label, 1, self);
	block.addNewItem(self.description, DC_Data, 1, self);

	tmpPort := self.getDestinationPort();
	if tmpPort &lt;&gt; null then
		block := _dataContainer.addNewBlock;
		block.addNewItem("Destination", DC_Label, 1, self);
		block.addNewItem(tmpPort.code, DC_Data, 1, self);
	endif;
	
	ffwd := self.getFreightForwarder();
	if ffwd &lt;&gt; null then
		block := _dataContainer.addNewBlock;
		block.addNewItem("Freight Forwarder", DC_Label, 1, self);
		block.addNewItem(ffwd.code, DC_Data, 1, self);
	endif;
	
	br := self.getReleaseRequest();
	if br &lt;&gt; null then
		block := _dataContainer.addNewBlock;
		block.addNewItem("Release", DC_Label, 1, self);
		block.addNewItem(br.code, DC_Data, 1, self);
	endif;
	
	ffwd := self.getConsignee();
	if ffwd &lt;&gt; null then
		block := _dataContainer.addNewBlock;
		block.addNewItem("Consignee", DC_Label, 1, self);
		block.addNewItem(ffwd.code, DC_Data, 1, self);
	endif;
	
	if app.isSpecial() then
		block := _dataContainer.addNewBlock;
		block.addNewItem("OID", DC_Label, 1, self);
		block.addNewItem(self.String, DC_Data, 1, self);

	endif;

	*/
end;</source>
        <Parameter name="_dataContainer" type="CM_DataContainer"/>
    </JadeMethod>
    <JadeMethod name="getFreightForwarder" id="fd699917-6627-4481-9db5-0b11f8384060">
        <source>getFreightForwarder() : CM_ConsigneeConsignor;
/*
----------   ----------  --------------------------------------------------
Created:	15 November 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	criteria			: CM_YACriteria;
begin
	foreach criteria in self.allCriteria do
		if criteria.myYACriteriaType.type = YACriteriaType_FreightForward then
			return criteria.myYAData.CM_YADataObjects.getFirstObject().CM_ConsigneeConsignor;
		endif;
	endforeach;

end;



</source>
        <ReturnType type="CM_ConsigneeConsignor"/>
    </JadeMethod>
