    <JadeMethod name="copyFromOccurs" id="fb3deff4-e534-4ccb-b6e5-08e4da4f264f">
        <source>copyFromOccurs(ispecName : String; fieldName:String) : Integer;

vars
	lincIspec : CnEcLincIspecDef;
	lincField : CnEcLincFieldDef;
	strFormattedValue : String;

begin
	// first get the field definition object 

	lincIspec := myLincSystemDef.allLincIspecDefs [ispecName.toLower];
	
	if lincIspec = null then
		return null;
	endif;	

	lincField := lincIspec.allLincFieldDefs [fieldName.toLower];
	if lincField = null then
		return null;
	endif;

	// return the copy from value

	return lincField.copyFromOccurs;
end;</source>
        <Parameter name="ispecName" type="String"/>
        <Parameter name="fieldName" type="String"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="formatOutField" id="40ef9063-2a5f-4dba-85cb-408bc418ef0e">
        <source>formatOutField(inString : String; type : String ; itemLength : Integer; itemDecimals : Integer;
				decimalsKeyed : Boolean	) : String;

//  inString is field.String, type is Linc edit, itemLength and itemDecimals are Linc item length
//  and decimals.  The method returns a formatted string formatted as a Linc screen would expect
//  the field, based on the inputs.

vars
	count		: Integer;
	decLength	: Integer;
	intLength	: Integer;
	inputLength	: Integer;
	intString	: String;
	decString	: String;
	signString 	: String;
	testString	: String;
	workString	: String;
	outString	: String;

begin
	if type = 'A' then				// alphanumeric
		outString := inString.padBlanks(itemLength);
	else							// numeric
		inputLength := inString.length;
        testString := inString[1];
        workString := inString;
        signString := '';

		//  check for sign (leading)

        if testString = '-' or 
         	testString = '+' then
        	inputLength := inputLength - 1;
        	workString := inString[2:inputLength];

        	// is this really a signed field ... if not then drop the sign now

        	if type = "N" then 
        		signString := ''; 
        	else
        		signString := testString;
        	endif;
        endif;

        // now split up so that  we have the integer and decimals parts to 
        // work with

		count := workString.pos('.', 1);
		if count &lt;&gt; 0 then
			decLength := inputLength - count;
			intLength := count - 1;
			intString := workString[1: (count - 1)];

			if decLength &gt; 0  then
				decString := workString[(count + 1):end];
			else
				decString := '';
			endif;
		else
		 	intLength := inputLength;
		 	intString := workString;
		endif;

		// now that we have split up, then check the parts 
		// should there really be an 'integer' part to this		

		if itemLength - itemDecimals &gt;  0 then 

			// check to see if there is  we need to truncate or add leading zeros 

			if intLength &gt; (itemLength - itemDecimals) then

    			workString := intString [( intLength - (itemLength - itemDecimals) + 1) : end]; 
				intString := workString;
				intLength := itemLength - itemDecimals;
			elseif intLength &lt; (itemLength - itemDecimals) then
				count := itemLength - intLength - itemDecimals;
				workString := '';
				while count &gt; 0 do
					workString := workString &amp; '0';
					count := count - 1;
				endwhile;
				workString := workString &amp; intString;
				intString := workString;
				intLength := inString.length;
			endif;
		else    // there is no integer part ... drop if there is some

			intString := '';
			intLength := 0;
		endif; // of having an integer value

		// now repeat for the decimals part of this

		if itemDecimals &gt;  0 then 

			// check to see if there is  we need to truncate from the right or add trailing zeros 

			if decLength &gt; itemDecimals then

    			workString := decString [1: itemDecimals]; 
				decString := workString;
				decLength := itemDecimals;
			elseif decLength &lt; itemDecimals then
				count := itemDecimals - decLength;
				workString := decString;
				while count &gt; 0 do
					workString := workString &amp; '0';
					count := count - 1;
				endwhile;
				decString := workString;
				decLength := itemDecimals;
			endif;
		else    // there is no integer part ... drop if there is some

			decString := '';
			decLength := 0;
		endif; // of having an decimal value

		// now put all the bits together 

		if decimalsKeyed then
			outString := intString &amp; "." &amp; decString;
		else
			outString := intString &amp; decString;
		endif;

		//  add any sign to the end

		if type = '+' or type = 'S' then
			if type = '+' and signString = '' then
				signString := '+';
			endif;
			if type = 'S' then
				if signString = '' then
					signString := "DR"; 
				else
					signString := "CR";
				endif;
			endif;
			workString := outString &amp; signString;
			outString := workString;
		endif;
	endif;
						// end of type test
	return outString;
end;</source>
        <Parameter name="inString" type="String"/>
        <Parameter name="type" type="String"/>
        <Parameter name="itemLength" type="Integer"/>
        <Parameter name="itemDecimals" type="Integer"/>
        <Parameter name="decimalsKeyed" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
