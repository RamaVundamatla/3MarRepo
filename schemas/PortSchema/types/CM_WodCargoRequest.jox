    <JadeMethod name="setForCreate" id="6e62a219-f737-442a-ad28-724eca5c4b45">
        <updating/>
        <source>setForCreate(_pxyWoDDtl: CM_WorkOrderDtl io; _realWorkOrder: CM_WorkOrder) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 June 2018	jlger1	Initial creation 39166

*/

vars

begin
	
	if _realWorkOrder &lt;&gt; null then
	
		inheritMethod(_pxyWoDDtl, _realWorkOrder);
	else
		self.setForUpdate(_pxyWoDDtl.CM_WodCargoRequest);
	endif;
		
epilog

