    <JadeMethod name="getDebtorName" id="605729ef-dfde-4746-a8ef-94c5b8e6efce">
        <source>getDebtorName():String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
15 August 2012	cnwndl1	Initial creation	Par 29968

*/

vars

	dr : CM_Debtor;

begin

	if self.myDebtorTerminal &lt;&gt; null then
		dr := self.myDebtorTerminal.myDebtor;
		if dr &lt;&gt; null then
			return dr.name;
		endif;
	endif;
	
	return null;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
