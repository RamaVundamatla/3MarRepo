    <JadeMethod name="utlUpdateRFIDTagReader" id="bf6149a9-6bf3-467f-a40c-3d92a3dc23d2">
        <source>utlUpdateRFIDTagReader(_pxyTagReader : CM_RFIDTagReader input;
						_terminal : CM_Terminal input;
						_passport : CM_Passport input);
/*
----------   ----------  --------------------------------------------------
Created:	30 August 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	realTagReader 		: CM_RFIDTagReader;
	expectedEdition 	: Integer;
begin
	self.initialiseActivity();
	
	self.raiseExceptionIfNull(_pxyTagReader, 'RFID Tag Reader Proxy');
	
	_pxyTagReader.pxyGetRealObjectAndEdition(realTagReader, expectedEdition);
	self.raiseExceptionIfNull(realTagReader, 'RFID Tag Reader');
	
	_pxyTagReader.validateForUpdate();
	
	if not _passport.noErrors then
		return;
	endif;
	
	realTagReader.setForUpdate(_pxyTagReader,_terminal);
	
epilog

end;
</source>
        <Parameter name="_pxyTagReader" type="CM_RFIDTagReader" usage="input"/>
        <Parameter name="_terminal" type="CM_Terminal" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateRORODeck" id="46cc675d-ff14-4bd0-9faf-a30b42f5cb1e">
        <updating/>
        <source>utlUpdateRORODeck(_proxyDeck : CM_Deck input;_passport : CM_Passport input) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
24 March 2011	cnwer1	Initial creation

*/

vars
	realDeck : CM_Deck;
	beforeAuditText, 
	afterAuditText: String;
	beforeAuditTextLocn, 
	afterAuditTextLocn: String;
begin
	self.initialiseActivity();
	
	self.raiseExceptionIfNull(_proxyDeck, " Proxy is Null" );
	
	realDeck:=_proxyDeck.pxyGetRealObject.CM_Deck;
	if realDeck = null then
		self.raiseExceptionIfNull(_proxyDeck, " Real Deck is Null" );
	endif;

	app.setContinueCMExceptions(true);
	
	app.myValUA.valCM_Object(_proxyDeck, _passport);

	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;

	app.setContinueCMExceptions(false);
	
	if _passport.hasErrors then
		return;
	endif;
	
	/*can't use the self.myUpdateAuditAgent.audUpdateGeneric
		because the CM_Deck calls utls for its child references i.e deck layer
		if these also call self.myUpdateAuditAgent.audUpdateGeneric the beforeText
		will be for a different object to the end audit text
	
	*/
	
	beforeAuditTextLocn:= ""; // PAR 31671
	afterAuditTextLocn:=realDeck.getAuditTextForLocnDefn(_proxyDeck); // PAR 31671
	
	beforeAuditText:=realDeck.getAuditText();
	realDeck.setForUpdate(_proxyDeck,_passport);
	afterAuditText:=realDeck.getAuditText();

	afterAuditText := afterAuditText &amp; AuditStringSeparator &amp; afterAuditTextLocn; // PAR 31671
	
	app.myAA.auditUpdateTrx(realDeck, beforeAuditText, afterAuditText);

	
epilog
	
end;</source>
        <Parameter name="_proxyDeck" type="CM_Deck" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateRORODeckItem" id="0d15f673-7dca-4f63-8859-0bf1cede7975">
        <source>utlUpdateRORODeckItem(_proxyDeckItem : CM_DeckItem; _passport : CM_Passport input);
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
12 April 2011	cnwer1	Initial creation CCMS 1031

*/

vars

	realDeckItem	: CM_DeckItem;
	expectedEdition	: Integer;
	beforeAuditText, 
	afterAuditText: String;
begin
	self.initialiseActivity();

	_proxyDeckItem.raiseExceptionIfNotProxy(method);


	_proxyDeckItem.pxyGetRealObjectAndEdition(realDeckItem, expectedEdition);

	if realDeckItem= null then
		app.raiseCMException1(ProxyMgrCannotLocateReal, CM_DeckItem.name, null, null);
		return;
	endif;

	app.setContinueCMExceptions(true);
	
	app.myValUA.valCM_Object(_proxyDeckItem, _passport);

	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;

	app.setContinueCMExceptions(false);
	

	exclusiveLock(realDeckItem);

	if _passport.noErrors and realDeckItem.edition &lt;&gt; expectedEdition then
		app.raiseCMException1(ObjectUpdatedByAnotherUserSave, "Deck Item", null, null);
		return;
	endif;

	/*can't use the self.myUpdateAuditAgent.audUpdateGeneric
		because the CM_Deck calls utls for its child references i.e deck layer
		if these also call self.myUpdateAuditAgent.audUpdateGeneric the beforeText
		will be for a different object to the end audit text
	
	*/
	
	beforeAuditText:=realDeckItem.getAuditText();

	if _passport.noErrors then
		realDeckItem.setForUpdate(_proxyDeckItem,_passport);
	endif;

	afterAuditText:=realDeckItem.getAuditText();
	app.myAA.auditUpdateTrx(realDeckItem, beforeAuditText, afterAuditText);


epilog

end;</source>
        <Parameter name="_proxyDeckItem" type="CM_DeckItem"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateRORODeckRemarks" id="5ce1b260-e5ec-499e-984f-7d2c2f0f0997">
        <source>utlUpdateRORODeckRemarks(_deck :CM_DeckVoyage input; _theRemarks : String; _passport : CM_Passport input);
/*
Date		    Who			Reason
28 September 2011	cnwas3	 
*/

vars
	expectedEdition		: Integer;
	
begin

	self.initialiseActivity();
	
	if _deck = null then	
		app.raiseCMException1(ProxyMgrCannotLocateReal, _deck.code, null, null);
		return;
	endif;

	exclusiveLock(_deck);

	if (not _passport.noErrors) then
		app.raiseCMException1(ObjectUpdatedByAnotherUserSave, 'Deck Voyage', null, null);
		return;
	endif;
	
	if _deck.remarks &lt;&gt; _theRemarks then
		app.myAA.auditUpdate(_deck, "remarks", _theRemarks);
		_deck.setRemarks(_theRemarks,false);
		_deck.myVoyageStructure.myVoyage.causeEvent(_passport.myTerminal.getTerminalEvent(RORODeckRemarks_Event), true,_deck);
	endif;



end;</source>
        <Parameter name="_deck" type="CM_DeckVoyage" usage="input"/>
        <Parameter name="_theRemarks" type="String"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateRORODecksOrdinal" id="4831367b-ad50-4b65-a903-077ee32ed908">
        <updating/>
        <source>utlUpdateRORODecksOrdinal(_allDecks : CM_DeckVoyageByOrdDict input; _allGCs : CM_GeneralCCtrByordinalDict input; _passport : CM_Passport input) updating;
/*
Date		    Who			Reason
30 September 2011	cnwas3	  Initial creation: CCMS 1035 CargoSideView form
*/

vars
	roroStructure : CM_ROROVoyageStructure;
	gcStructure : CM_GeneralCargoVoyageStructure;
	realController : CM_GeneralCargoController;
begin
	self.initialiseActivity();
	
	if _allDecks = null and _allGCs = null then	
		//app.raiseCMException1(ProxyMgrCannotLocateReal, _deck.code, null, null);
		return;
	endif;

	if _allDecks &lt;&gt; null then
		exclusiveLock(_allDecks);
	
		if (not _passport.noErrors) then
			app.raiseCMException1(ObjectUpdatedByAnotherUserSave, app.getErrorString(Deck), null, null);
			return;
		endif;
		
		roroStructure := _allDecks.first.myVoyageStructure;
		
		if roroStructure &lt;&gt; null then
			roroStructure.allDecks.rearrangeOrdinals(_allDecks);
			// from 28687 Nov 2011 raise a note to refresh any enquiry forms
			roroStructure.causeEvent(EVENT_LOCATION_REFRESH, false, roroStructure);
		endif;
		
	elseif _allGCs &lt;&gt; null and not _allGCs.isEmpty then
	
		if (not _passport.noErrors) then
			return;
		endif;
		
		realController := _allGCs.first.pxyGetRealObject;
		if realController &lt;&gt; null then
			gcStructure := realController.myGCVoyage;
		endif;
		if gcStructure &lt;&gt; null then
			gcStructure.allLocationsByOrdinal.rearrangeOrdinals(_allGCs);
			gcStructure.causeEvent(EVENT_LOCATION_REFRESH, false, gcStructure);
		endif;
		
	endif;


epilog

end;</source>
        <Parameter name="_allDecks" type="CM_DeckVoyageByOrdDict" usage="input"/>
        <Parameter name="_allGCs" type="CM_GeneralCCtrByordinalDict" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateROROGraphicDeck" id="81d97c82-2c9f-41c1-941e-c5537463a3ef">
        <source>utlUpdateROROGraphicDeck(_pxyLayer : CM_ShipDeckLayer; _realLayer : CM_ShipDeckLayer ;  _passport : CM_Passport input) : Boolean;


vars
	aOK:Boolean;
	pxyGraphic,realGraphic,realGraphicNew,tmpGraphic : CM_Graphic;
	theObjects:	ObjectSet;
begin
	
	// ###############
	// ROROVesselStructure GRAPHICS
	if _passport.noErrors then
		// all of the graphics are proxied too
		// check for deletes
		aOK := false;
		create theObjects transient;
		foreach realGraphic in _realLayer.allGraphics do
			// if the real has no linked proxy then it must die!
			if realGraphic.pxyGetProxyObject = null then
				theObjects.add(realGraphic);
			endif;
		endforeach;
		while not theObjects.isEmpty do
			tmpGraphic := theObjects.first.CM_ROROGraphic;
			app.myUtilityDA.utlDeleteLayoutGraphic(tmpGraphic.CM_ROROGraphic,_passport);
			if not _passport.noErrors then
				break;
			endif;
			theObjects.remove(tmpGraphic);
		endwhile;
		delete theObjects;
		
		
		// #### Create and Update
		if _passport.noErrors then
			foreach pxyGraphic in _pxyLayer.allGraphics do
				if pxyGraphic.pxyGetRealObject() &lt;&gt; null then
					self.utlUpdateLayoutGraphic(pxyGraphic.CM_ROROGraphic,_passport);
				else

					// if the real has no linked proxy then it must be born!
					
					app.myUtilityCA.utlCreateROROGraphic(pxyGraphic.CM_ROROGraphic,realGraphicNew, _realLayer, _passport);
					aOK := true;
				endif;
				if not _passport.noErrors then
					break;
				endif;
			endforeach;
		endif;
		
	endif;
	
	return aOK;

epilog
	
end;</source>
        <Parameter name="_pxyLayer" type="CM_ShipDeckLayer"/>
        <Parameter name="_realLayer" type="CM_ShipDeckLayer"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateROROGraphicRemarks" id="333023da-5ec3-496f-a624-f4b469261200">
        <updating/>
        <source>utlUpdateROROGraphicRemarks(_realDeckItemLayout:CM_DeckItemLayout input; _remarks : String; _passport : CM_Passport input) updating;

vars
	
begin
	
	_realDeckItemLayout.setRemarks( _remarks);
	_realDeckItemLayout.causeEvent(EVENT_RORO_ITEM_UPDATE,true,null);
epilog
	
end;</source>
        <Parameter name="_realDeckItemLayout" type="CM_DeckItemLayout" usage="input"/>
        <Parameter name="_remarks" type="String"/>
