<GUIClass name="CMUI_FeetInchesMask" id="a236b488-4b2a-4087-8093-0d365bc2cd3f">
    <superclass name="CMUI_EditMask"/>
    <transient/>
    <sharedTransientAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>Used to display feet and inches on forms in the format ffff.ii where ii is a number o finches, not a decimal foot
e.g. 12.5 is 12 feet and 5 inches, not 12 and a half feet.
The mask allows 4 digits for foot entry and two digits for inch entry, and limits inch entry to 0-11 inclusive.</text>
    <DbClassMap file="_usergui"/>
    <Constant name="DefaultFeetInchesMask" id="988543d8-07b0-4672-a8cc-cb7064f5b280">
        <source>"R####@\.@##[0-11]"</source>
        <type name="String"/>
    </Constant>
    <JadeMethod name="getFeetInches" id="12eea232-ac02-4d4f-adad-fbfda879e00d">
        <source>getFeetInches() : String;
/*
Purpose:			Convert the return textUser value from an edit mask in to feet and inches,
					separated by a decimal place

Parameters:			

Return Value:		

Date		Who		Reason
11/03/2013	cnwdap1	Initial creation PAR #31155 CCMS SFW 1321 Imperial Measurements
26/09/2013	cnwdap1	PAR #32536 Correct handling of edit mask when no feet or no inches entered
*/
vars
	decimalSep	: String;
	newString	: String;
	pos			: Integer;
	inches		: String;
	feet		: String;
	firstChar	: String;						// PAR #32536
	idx			: Integer;						// PAR #32536
	firstCharPos: Integer;						// PAR #32536
	
begin
	decimalSep := app.getMyLocaleInfoJMT().numericInfo.decimalSeparator;
	newString := self.textUser;
	newString := newString.trimLeft;
	pos := newString.pos(Space, 1);
	if pos = null and newString.length &gt;= 5 then						// PAR #32536
		pos := 4;														// PAR #32536
	endif;																// PAR #32536
	if self.textUser.length &gt; 0 then									// PAR #32536
		idx := 1;														// PAR #32536
		firstChar := self.textUser.scanWhile(Space, idx);				// PAR #32536
		firstCharPos := firstChar.length + 1;							// PAR #32536
	endif;																// PAR #32536
	if pos = null then
		if firstCharPos &gt;= 5 then										// PAR #32536
			feet := "0";												// PAR #32536
			inches := self.textUser[firstCharPos:end];					// PAR #32536
		else															// PAR #32536
			if firstCharPos &lt;= 1 then									// PAR #32536
				inches := "0";											// PAR #32536
				if newString.length &gt; 0 then							// PAR #32536
					feet := newString[1:end];							// PAR #32536
				endif;													// PAR #32536
			else														// PAR #32536
				inches := newString[newString.length-1:end];
				feet := newString[1:4];
			endif;														// PAR #32536
		endif;															// PAR #32536
	else
		inches := newString[pos+1:end].trimBlanks;
		if newString.length &gt;= 5 and pos.isOneOf(4, null) then			// PAR #32536
			feet := newString[1:pos];									// PAR #32536
		else															// PAR #32536
			feet := newString[1:pos-1];
		endif;															// PAR #32536
	endif;
	newString := feet &amp; decimalSep &amp; inches;
	return newString;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="windowCreated" id="212881a4-473c-4d1c-b569-3fc34fb02070">
        <controlMethod name="Control::windowCreated"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <executionLocation>client</executionLocation>
        <source>windowCreated(cntrl: Control input; persistCntrl: Control) updating, clientExecution;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 March 2013	cnwdap1	Initial creation
*/
vars

begin
	inheritMethod(cntrl, persistCntrl);

	self.mask 				:= self.DefaultFeetInchesMask;
	self.selectionStyle 	:= self.SelectionStyle_Select;
	self.promptCharacter	:= null;
epilog

end;</source>
        <Parameter name="cntrl" type="Control" usage="input"/>
        <Parameter name="persistCntrl" type="Control"/>
    </JadeMethod>
