    <JadeMethod name="doCancelCustomDoc" id="7a92ed8c-ccc3-4a3d-9065-18679523dfde">
        <updating/>
        <source>doCancelCustomDoc()updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 November 2023 navmv20 CR 60425 Task 60987: Jade - Cust Doc Cancellation TRX

*/
vars
	theReturn : Integer;
	custDoc	: CM_CustomDocument;

begin
	if  self.tblData.row &lt;=  self.tblData.fixedRows then
		return;
	endif;
	
	if self.tblData.accessRow( self.tblData.row).selected then
		custDoc := self.tblData.accessedRow.itemObject.CM_CustomDocument;
	endif;

	if custDoc = null then
		app.msgBox(app.getErrorString(Record_selected), app.getErrorString(Warning),MsgBox_OK_Only);
		return;
	endif;
	
	if app.msgBox(app.getErrorString(Confirm_cancell_custom_documen), 
							app.getErrorString(Confirm_cancellation), MsgBox_Yes_No + MsgBox_Question_Mark_Icon) = MsgBox_Return_No then
		return;
	endif;
	
	while true do
	app.myTrxUA.trxUpdateCustDocCancellation(custDoc,app.myPassport);
		if app.myPassport.trxCompletedOK then
			// Clear errors/warnings from form and err/warnings window
			self.clearErrorWarnings();
			global.beep;
			
		else
			theReturn := app.showErrorWarningDialog("Cust Doc Cancelled", app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors 
			and theReturn = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
		endif;
		break;
	endwhile;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doClear" id="398d5df5-796a-42f9-8505-b533a89ed5f4">
        <updating/>
        <source>doClear()updating;
/*
Purpose:			

Date		Who		Reason
08AUG2023	NAVAB1	 CR 56094 TASK 59618
