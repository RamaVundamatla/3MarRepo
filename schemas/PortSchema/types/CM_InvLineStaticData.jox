    <JadeMethod name="setStaticFields" id="f9c22d16-6dbf-4ae9-94fc-4378f1c2fa51">
        <updating/>
        <source>setStaticFields(_invoiceStaticData : CM_InvStaticData; _bankName : String; _debtorName : String; _invoiceLineDescNarration : String; _invoiceContractID  : String; _transactionDesc : String) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 March 2024	navra1	Initial creation for TFS 57933 Invoice and Invoice Line details that need to be static &lt;&lt;54090&gt;&gt;

*/

vars

begin
	self.myInvoiceStaticData := _invoiceStaticData;
	self.bankName := _bankName[1:30];	// ### TFS BUG 65937 02SEP2024 NAVAB1
	self.debtorName := _debtorName[1:100];	// ### TFS BUG 65937 02SEP2024 NAVAB1
	self.invoiceLineDescNarration := _invoiceLineDescNarration[1:200];	// ### TFS BUG 65937 02SEP2024 NAVAB1
	self.invoiceContractID := _invoiceContractID[1:50];	// ### TFS BUG 65937 02SEP2024 NAVAB1
	self.transactionDesc := _transactionDesc[1:100];	// ### TFS BUG 65937 02SEP2024 NAVAB1


epilog

end;</source>
        <Parameter name="_invoiceStaticData" type="CM_InvStaticData"/>
        <Parameter name="_bankName" type="String"/>
        <Parameter name="_debtorName" type="String"/>
        <Parameter name="_invoiceLineDescNarration" type="String"/>
        <Parameter name="_invoiceContractID" type="String"/>
        <Parameter name="_transactionDesc" type="String"/>
    </JadeMethod>
