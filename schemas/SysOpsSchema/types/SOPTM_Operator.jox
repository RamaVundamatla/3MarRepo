    <JadeMethod name="loadCodeGroupTreeView" id="7633a602-270d-46e3-85a1-713f25a2ea1e">
        <updating/>
        <source>loadCodeGroupTreeView(_clearFirst :Boolean) updating;
// ---------------------------------------------------------------------------
// Created:     07 June 2002 by cnwth2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	codeGroupType			:CM_CodeGroupType;

	theForm 					:SOP_TableMaintForm;
	iter							:Iterator;
	obj								:CMUI_ViewModel;
begin
	theForm := self.myForm;
	theForm.shtViewTable1.visible := false;	
	if _clearFirst then
		self.allAvailableVMObjects.purge();
		
		theForm.lbAvailable.clear;
		//epr TFS 3581 6/3/17 noticed leaking transients
		delete self.myViewListboxAvailable;
		create self.myViewListboxAvailable transient;
		self.myViewListboxAvailable.myListbox := theForm.lbAvailable;
		
		iter := app.myRoot.allCodeGroupTypes.createIterator();
		while iter.next(codeGroupType) do
			codeGroupType.loadTreeViewArray(self.allAvailableVMObjects, 1);
		endwhile;
	endif;
	
	myViewListboxAvailable.vCreateIterator(self.allAvailableVMObjects, true);
	myViewListboxAvailable.vLoadListbox();
epilog
	delete iter;
  
end;</source>
        <Parameter name="_clearFirst" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="loadOperatorCodeGroupsTreeView" id="7250eeac-7487-4f65-8c18-fbc630988284">
        <updating/>
        <source>loadOperatorCodeGroupsTreeView(_clearFirst :Boolean) updating;
// ---------------------------------------------------------------------------
// Created:     07 June 2002 by cnwth2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	codeGroup							:CM_CodeGroup;
	theForm 							:SOP_TableMaintForm;
	iter								:Iterator;
	theOperator		 					:CM_Operator;
	vmCodeGroup							:SOPVM_CodeGroup;
	vmCodeGroupType					:SOPVM_CodeGroupType;
	obj,obj2							:Object;
	foundCodeGroupType					:Boolean;
	index								:Integer;
begin
	theForm := self.myForm;
	if _clearFirst then
		self.allSelectedVMObjects.purge();
		theForm.lbSelected.clear;

		//epr TFS 3581 6/3/17 noticed leaking transients
		delete self.myViewListboxSelected;
		create self.myViewListboxSelected transient;	
		self.myViewListboxSelected.myListbox := theForm.lbSelected;
			
		theOperator := theForm.myCurrentObject.CM_Operator;
		iter := theOperator.allCodeGroups.createIterator();
		while iter.next(codeGroup) do
			//first check to see if we have already created the codegroups parent view model object
			foundCodeGroupType := false;
			foreach obj in self.allSelectedVMObjects do 
				if obj.isKindOf(SOPVM_CodeGroupType) then
					if (obj.SOPVM_CodeGroupType.myObject.CM_CodeGroupType.id) = (codeGroup.myCodeGroupType.id) then
						foundCodeGroupType := true;
						vmCodeGroupType := obj.SOPVM_CodeGroupType;
					endif;
				endif;
			endforeach;
			//if we did not find the parent viewmodel object then create it and stick it in the self.allSelectedVMObjects collection
			if not foundCodeGroupType then
				create vmCodeGroupType transient;
				vmCodeGroupType.initializeMe(codeGroup.myCodeGroupType,1,null);
				self.allSelectedVMObjects.add(vmCodeGroupType);
			endif;
				
			create vmCodeGroup transient;
			vmCodeGroup.initializeMe(codeGroup,2,vmCodeGroupType);	
			self.allSelectedVMObjects.add(vmCodeGroup);
		endwhile;
	endif;	
	//now loop through and expand everything
	foreach obj in self.allSelectedVMObjects do
		obj.SOP_ViewModelObject.setExpanded(true);
	endforeach;
	
	myViewListboxSelected.vCreateIterator(self.allSelectedVMObjects, true);
	
	theForm.lbSelected.clear;
	foreach obj in self.allSelectedVMObjects do
		if obj.isKindOf(SOPVM_CodeGroupType) then
			index := theForm.lbSelected.addItem(obj.SOP_ViewModelObject.displayEntryListbox);
			theForm.lbSelected.itemLevel[index] := 1;
			theForm.lbSelected.itemExpanded[index] :=true;
			theForm.lbSelected.itemObject[index] :=  obj.SOPVM_CodeGroupType;
			foreach obj2 in obj.SOPVM_CodeGroupType.allChildren do
				index := theForm.lbSelected.addItem(obj2.SOP_ViewModelObject.displayEntryListbox);
				theForm.lbSelected.itemLevel[index] := 2;
				theForm.lbSelected.itemExpanded[index] :=true;
				theForm.lbSelected.itemObject[index] :=  obj2;
			endforeach; 
		endif;
	endforeach;
	
epilog
	delete iter;
  
end;</source>
        <Parameter name="_clearFirst" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="loadSealCheckTable" id="b10630dc-ba60-48c7-a865-e7b96871ab18">
        <source>loadSealCheckTable(_operator : CM_Operator);
//26 August 2010	cnwml2
//+cnwml2 PAR23715 SFW CCMS1131
// cnwdap1	11/08/2011	PAR #27972 Bulk release type no longer translatable, replaced by string constants
vars
	tbl		: CM_EntryTable;
begin
	tbl := self.myForm.tblFldSheet1;
	tbl.clear();
	tbl.columns := 3;
	tbl.rows := 4;
	
	tbl.accessCell(1,1).text := "Seal Check Type" &amp; Tab &amp; "Receivals" &amp; Tab &amp; "Releases";
	tbl.accessColumn(2).inputType := Table.InputType_ComboBox;	
	tbl.comboList := app.getString(Default) &amp; Tab &amp; app.getString(Strict) &amp; Tab &amp; app.getString(Full)&amp; Tab &amp; app.getString(View) &amp; Tab &amp; app.getString(None);
	tbl.accessColumn(3).inputType := Table.InputType_ComboBox;
	//tbl.accessCell(2,1).text := app.getString(BR_TYPE_DESCR_SHIP) &amp; Tab &amp; app.sealCheckTypeEnumToString(_operator.sealCheckShipReceival) &amp; Tab &amp; app.sealCheckTypeEnumToString(_operator.sealCheckShipRelease);	// PAR #27972
	//tbl.accessCell(3,1).text := app.getString(BR_TYPE_DESCR_RAIL) &amp; Tab &amp; app.sealCheckTypeEnumToString(_operator.sealCheckRailReceival) &amp; Tab &amp; app.sealCheckTypeEnumToString(_operator.sealCheckRailRelease);	// PAR #27972
	//tbl.accessCell(4,1).text := app.getString(BR_TYPE_DESCR_ROAD) &amp; Tab &amp; app.sealCheckTypeEnumToString(_operator.sealCheckRoadReceival) &amp; Tab &amp; app.sealCheckTypeEnumToString(_operator.sealCheckRoadRelease);	// PAR #27972
	tbl.accessCell(2,1).text := BR_TYPE_SHIP_STR &amp; Tab &amp; app.sealCheckTypeEnumToString(_operator.sealCheckShipReceival) &amp; Tab &amp; app.sealCheckTypeEnumToString(_operator.sealCheckShipRelease);						// PAR #27972
	tbl.accessCell(3,1).text := BR_TYPE_RAIL_STR &amp; Tab &amp; app.sealCheckTypeEnumToString(_operator.sealCheckRailReceival) &amp; Tab &amp; app.sealCheckTypeEnumToString(_operator.sealCheckRailRelease);						// PAR #27972
	tbl.accessCell(4,1).text := BR_TYPE_ROAD_STR &amp; Tab &amp; app.sealCheckTypeEnumToString(_operator.sealCheckRoadReceival) &amp; Tab &amp; app.sealCheckTypeEnumToString(_operator.sealCheckRoadRelease);						// PAR #27972
	tbl.width := self.myForm.shtFolder1.width;
	tbl.height := tbl.rows * 19;
epilog

end;</source>
        <Parameter name="_operator" type="CM_Operator"/>
    </JadeMethod>
    <JadeMethod name="removeCodeGroup" id="c69f9339-4bc6-4aa3-9585-3e4f4969f86c">
        <updating/>
        <source>removeCodeGroup()updating;
// ---------------------------------------------------------------------------
// Created:     10 June 2002 by cnwth2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	theForm 					:SOP_TableMaintForm;
	vmObj							:CMUI_ViewModelObject;
	vmCodeGroup				:SOPVM_CodeGroup;	
	vmCodeGroupType		:SOPVM_CodeGroupType;
	theOperator				:CM_Operator;
	index							:Integer;

begin
	theForm := self.myForm;
	if theForm.lbSelected.listObject &lt;&gt; null then
		if theForm.lbSelected.listObject.isKindOf(SOPVM_CodeGroup) then
			vmCodeGroup := theForm.lbSelected.listObject.SOPVM_CodeGroup;
			//find the parent code group type. If this is the only child under the found parent, then remove the
			//parent also
			vmCodeGroupType := vmCodeGroup.myParent.SOPVM_CodeGroupType;
			//vmCodeGroupType.allChildren.purge;
		
			if vmCodeGroupType.allChildren.size =1 then //which it always should be
				self.allSelectedVMObjects.remove(vmCodeGroupType);
				self.allSelectedVMObjects.remove(vmCodeGroup);
				delete vmCodeGroup;
				delete vmCodeGroupType; 
			else
				self.allSelectedVMObjects.remove(vmCodeGroup);
				delete vmCodeGroup;
			endif;
			self.loadOperatorCodeGroupsTreeView(false);
		else
			app.msgBox('You have selected to add a Code Group TYPE, rather than a code group.' &amp; CrLf &amp;
									'Please choose a code GROUP.','Error',0);
		endif;
	else
		app.msgBox('You must select a code group first','Error',0);
	endif;

end;</source>
    </JadeMethod>
    <JadeMethod name="setControlsForAddEdit" id="9cbba0d5-f8a0-4b95-9715-af93d45237da">
        <updating/>
        <source>setControlsForAddEdit() updating;

vars
	theForm		: SOP_TableMaintForm;
	
begin
	theForm	:=	self.myForm;
	theForm.tblInput1.userInputEnabled	:=	true;
	theForm.tblInput2.userInputEnabled	:=	true;
	theForm.tblInput3.userInputEnabled	:=	true;
	theForm.mulSelect1.userInputEnabled	:=	true;
	theForm.tblData5.userInputEnabled   :=  true;	// 26/05/2009 cnwar2 CCMS1040/#19796
	theForm.tblData5.tabKey 			:= 	J_key_Tab;
	
	
	//25 August 2009 NDL CCMS 1609 Par 20521
	if theForm.txtEmailName.getControl(2) &lt;&gt; null then
		theForm.mulSelect2.userInputEnabled := true;
		theForm.txtEmailName.getControl(2).enabled := true;
		theForm.txtName.getControl(2).enabled := true;
		theForm.btnAddNew.getControl(2).enabled := true;
	endif;
	
	if theForm.mode = theForm.Mode_Add then
		theForm.tblInput1.clearValues;
	   	theForm.cmbDebtor.setObject(null);
		theForm.tblInput1.setValueByName(ETRow_Colour, White.String);
		theForm.tblInput1.enableRowByName(ETRow_Code);
		theForm.tblInput1.enableRowByName(ETRow_Description);
		theForm.tblInput3.enabled := false;
		theForm.cmbTerminal.enabled := false; 
		theForm.tblInput3.setValueByName(ETRow_WeighImports, false);
		theForm.tblInput3.setValueByName(ETRow_WeighExports, false);
		theForm.tblData5.enabled := false;
//		theForm.tblInput1.setFocus;
		theForm.tblInput1.moveFirst();
		// call this last as sets cell input type (case etc)
		// if not called can get problems with case on entry. 
		theForm.tblInput1.gotFocus(theForm.tblInput1);		
		theForm.mulSelect1.setSelected(null);	
		theForm.btnAdvanced.enabled	:=	false;
	else
		theForm.tblInput3.enabled	:=	true;
		theForm.btnAdvanced.enabled	:=	theForm.mode = theForm.Mode_View;
		theForm.cmbTerminal.enabled	:=	true;
		theForm.tblData5.enabled 	:= 	true;
		// refresh the data from the newly created proxy
//		self.showThumbnail(theForm.myProxyObject.CM_Operator);
		// cannot update code
		theForm.tblInput1.enableRowByName(ETRow_Code);
		theForm.tblInput1.enableRowByName(ETRow_Description);
	endif;
	
	//set the code maintenance tables to allow editing
	theForm.lbAvailable.enabled		:=	true;
	theForm.lbSelected.enabled		:=	true;
	theForm.btnAddCodeGroup.enabled	:=	true;
	theForm.btnRemCodeGroup.enabled	:=	true;
	theForm.tblInput1.hideRowByName(ETRow_MyOperatorGroup, false);
	theForm.tblInput1.disableRowByName(ETRow_FinancialId);//04.Mar.24 navsp1 TFS 57177
	
//lorcan
	self.enableMulSelect1Contents();
	if theForm.mode = theForm.Mode_Update
	and theForm.mulSelect1.isMySheetVisible
	then
		theForm.mulSelect1.setFocus();
	else
		theForm.tblInput1.setFocus();
	endif;
	
	theForm.tblFldSheet1.userInputEnabled := true;			//+cnwml2 PAR23715 SFW CCMS1131
end;</source>
    </JadeMethod>
    <JadeMethod name="setCtrlsForView" id="754766c6-73a7-42fb-9113-e5dd819a0106">
        <updating/>
        <source>setCtrlsForView() updating;

vars
	theForm : SOP_TableMaintForm;

begin
	inheritMethod();
	
	theForm	:=	self.myForm;
	theForm.tblInput1.userInputEnabled	:=	false;
	theForm.tblInput2.userInputEnabled	:=	false;
	theForm.tblInput3.userInputEnabled	:=	false;
	theForm.tblData5.enabled 			:= 	true;
	theForm.tblData5.userInputEnabled 	:= 	false;	// 26/05/2009 cnwar2 CCMS1040/#19796
	theForm.tblData5.tabKey			 	:= 	0;
	theForm.shtViewTable1.visible		:=	true;
	theForm.tblInput1.showRowByName(ETRow_MyOperatorGroup, false);	  
	//set the code maintenance tables to disallow editing
	theForm.lbAvailable.enabled			:=	false;
	theForm.lbSelected.enabled			:=	false;
	theForm.btnAddCodeGroup.enabled		:=	false;
	theForm.btnRemCodeGroup.enabled		:=	false;
	theForm.btnAdvanced.visible			:=	true;
	
	//25 August 2009 NDL CCMS 1609 Par 20521
	if theForm.txtEmailName.getControl(2) &lt;&gt; null then
		theForm.txtEmailName.getControl(2).enabled := false;
		theForm.txtName.getControl(2).enabled := false;
		
		theForm.btnAddNew.getControl(2).enabled := false;
	endif;
	
	theForm.tblFldSheet1.userInputEnabled := false;				//+cnwml2 PAR23715 SFW CCMS1131
end;</source>
    </JadeMethod>
    <JadeMethod name="setOperatorTerminalConfig" id="61e5a147-9830-4083-a60a-0debff5a176c">
        <updating/>
        <source>setOperatorTerminalConfig() updating;

//you can only save the settings in the 'Terminal Configuration' for 1 terminal at a time
//
// Changed On	By			Reason
// ----------	--------	-------------------------------------------------------------
// 21/09/2011	cnwdap1		PAR #28223 CCMS MSL 1024 "Record Extra Edit Info" config options
// 05/12/2016	cnwdap1		TFS 3039 SNO Empty Container Pool Management
vars
	theForm				: SOP_TableMaintForm;
	tmpTable			: CM_DataTable;
	recCutoff			: CM_ReceivalCutoffOpTerm;
	recCutoffTermDef	: CM_ReceivalCutoffTermDef;
	idx					: Integer;
	code				: String;
	defaultRelativeTo	: Integer;
	defaultCutoff		: Decimal[7,2];
	defaultEarliest		: Decimal[7,2];
	defaultCutoffPN		: Decimal[7,2]; //20/03/2025	navkc1 JIRA Story MTN-34232
	defaultEarliestPN	: Decimal[7,2]; //20/03/2025	navkc1 JIRA Story MTN-34232
	terminal			: CM_Terminal;
	mtPoolParty			: CM_MTPoolingParty;				// TFS 3039
	
begin

	theForm := self.myForm;
	self.myCurrentOpTerminalObject.weighImports	:= theForm.tblInput3.getValueByName(ETRow_WeighImports).Boolean;
	self.myCurrentOpTerminalObject.weighExports	:= theForm.tblInput3.getValueByName(ETRow_WeighExports).Boolean;
	self.myCurrentOpTerminalObject.weighMTImports	:= theForm.tblInput3.getValueByName(ETRow_WeighMTImports).Boolean;
	self.myCurrentOpTerminalObject.weighMTExports	:= theForm.tblInput3.getValueByName(ETRow_WeighMTExports).Boolean;
	
	//th2 PAR 14641
//	self.myCurrentOpTerminalObject.freeStorageDays	:= theForm.tblInput3.getValueByName(ETRow_FreeStorageDays).Integer;
//	self.myCurrentOpTerminalObject.fullFreeStorageDays	:= theForm.tblInput3.getValueByName(ETRow_FullFreeStorageDays).Integer;
//	self.myCurrentOpTerminalObject.emptyFreeStorageDays	:= theForm.tblInput3.getValueByName(ETRow_EmptyFreeStorageDays).Integer;
	
	//cnwjo3 ccms 1039 par 22315
	self.myCurrentOpTerminalObject.restrictCargoBookingEdits := theForm.tblInput3.getValueByName(ETRow_RestrictCargoBookEdits).Boolean;
	
	// CCMS 1489
	self.myCurrentOpTerminalObject.weighTranships	:= theForm.tblInput3.getValueByName(ETRow_WeighTranships).Boolean;

	self.getTerminalsForUser();
	terminal := self.myForm.cmbTerminal.listObject.CM_Terminal;
	if terminal = null then
		terminal := self.allTerminalsForThisUser.first;
	endif;
	
	// 25/05/2009 cnwar2 CCMS1040
	tmpTable := self.myForm.tblData5;
	tmpTable.accessMode := tmpTable.AccessMode_Cell;
	tmpTable.column := 1;
	
	self.myCurrentOpTerminalObject.allReceivalCutoffs.purge;
	
	foreach idx in tmpTable.fixedRows + 1 to tmpTable.rows do
		if tmpTable.accessCell(idx, 3).text &lt;&gt; null or tmpTable.accessCell(idx, 4).text &lt;&gt; null or
			tmpTable.accessCell(idx, 5).text &lt;&gt; null or tmpTable.accessCell(idx, 6).text &lt;&gt; null //20/03/2025	navkc1 JIRA Story MTN-34232
			then
			create recCutoff transient;
			code := tmpTable.accessCell(idx, 1).text;
			recCutoffTermDef	:= terminal.allReceivalCutoffDefs[code];
			tmpTable.row 		:= idx;
			tmpTable.column		:= 2;
			defaultRelativeTo 	:= tmpTable.comboIndex;
			//defaultEarliest 	:= tmpTable.accessCell(idx, 3).text.Decimal;
			defaultEarliest 	:= tmpTable.accessCell(idx, 3).text.asDecimalJMT();// 01 APR 2010	NDL	Par 23556
			//defaultCutoff 		:= tmpTable.accessCell(idx, 4).text.Decimal;
			defaultCutoff 		:= tmpTable.accessCell(idx, 4).text.asDecimalJMT();// 01 APR 2010	NDL	Par 23556
			defaultEarliestPN	:= tmpTable.accessCell(idx, 5).text.asDecimalJMT(); //20/03/2025	navkc1 JIRA Story MTN-34232
			defaultCutoffPN		:= tmpTable.accessCell(idx, 6).text.asDecimalJMT(); //20/03/2025	navkc1 JIRA Story MTN-34232
			
			recCutoff.setValues(null, recCutoffTermDef, defaultRelativeTo, defaultCutoff, defaultEarliest, 
								defaultCutoffPN, 	//04/03/2025	navkc1 JIRA Story MTN-34227
								defaultEarliestPN);	//04/03/2025	navkc1 JIRA Story MTN-34227
			self.myCurrentOpTerminalObject.allReceivalCutoffs.add(recCutoff);
		endif;
	endforeach;
	
	// PAR #28223 start
	self.myCurrentOpTerminalObject.recordExtraEditInfoExports	:= theForm.tblInput3.getValueByName(ETRow_ExtraEditInfoExports).Boolean;
	self.myCurrentOpTerminalObject.recordExtraEditInfoImports	:= theForm.tblInput3.getValueByName(ETRow_ExtraEditInfoImports).Boolean;
	self.myCurrentOpTerminalObject.recordExtraEditInfoStorage	:= theForm.tblInput3.getValueByName(ETRow_ExtraEditInfoStorage).Boolean;
	self.myCurrentOpTerminalObject.recordExtraEditInfoTranships	:= theForm.tblInput3.getValueByName(ETRow_ExtraEditInfoTranships).Boolean;
	// PAR #28223 end
	
	code := theForm.tblInput3.getValueByName(ETRow_PoolParty).String;							// TFS 3039
	if code &lt;&gt; null then																		// TFS 3039
		mtPoolParty := self.myCurrentOpTerminalObject.myTerminal.allMTPoolingParties[code];		// TFS 3039
		if mtPoolParty &lt;&gt; null then																// TFS 3039
			self.myCurrentOpTerminalObject.myMTPoolParty := mtPoolParty;						// TFS 3039
		endif;																					// TFS 3039
	else																						// TFS 3039
		self.myCurrentOpTerminalObject.myMTPoolParty := null;									// TFS 3039
	endif;																						// TFS 3039
	
	//epr TFS 3581 6/3/17
	self.myCurrentOpTerminalObject.isExternallyMonitored := theForm.tblInput3.getValueByName(ETRow_IsExternallyMonitored).Boolean;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="setTableFromObjectSpecial" id="5451a9e8-de74-4f1e-b1d4-7389242dc235">
        <updating/>
        <source>setTableFromObjectSpecial(_tbl: CM_EntryTable input; _attrName: String; _row: Integer; _obj: Object): Boolean updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 05/12/2016	cnwdap1		Initial creation TFS 3039 SNO Empty Container Pool Management
//
vars
	form		: SOP_TableMaintForm;
	config	: CMIF_ConfigTerminal;
	rtnValue	: Boolean;
	proxyTerminal	: CM_Terminal;

begin
	if _tbl.name = SOP_TableMaintForm::tblInput1.name then
		return false;
	endif;
	
	form := self.myForm;
	proxyTerminal := form.myProxyObject.CM_Terminal;

	if _attrName = ETRow_PoolParty then
		form.cmbMTPoolParty.listCollection(proxyTerminal.allMTPoolingParties, true, ComboBox.DisplayCollection_Forward);
		return true;
		
	else
		return inheritMethod(_tbl, _attrName, _row, _obj);
	endif;
epilog

end;</source>
        <Parameter name="_tbl" type="CM_EntryTable" usage="input"/>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_row" type="Integer"/>
        <Parameter name="_obj" type="Object"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setupMulSelectSheet2" id="c25643aa-3420-4072-8925-30bfd18e7924">
        <source>setupMulSelectSheet2();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
25 August 2009	cnwndl1	Initial creation CCMS 1609 Par 20521

*/

vars

	theForm	: SOP_TableMaintForm;
	localTxtEmailName : CMUI_TextBox;
	localTxtEmailAddress : CMUI_TextBox;
	localButton : CMUI_Button;
	
begin

	theForm := self.myForm;
	theForm.shtMultiSelect2.caption := 'Emails';
	self.setupMultiSelect2('Email Addresses',app.myRoot.allEmailEntities,SOP_TableMaintForm::displayEntryEmailAddress.name);
	
	theForm.lblName2.visible := true;
	theForm.lblName2.caption := "Add New:";
	
	theForm.lblName3.visible := true;
	theForm.lblName3.caption := "Name";
	
	localTxtEmailName := theForm.txtEmailName.getControl(2);
	if localTxtEmailName = null then
		localTxtEmailName := theForm.txtEmailName.loadControl(2).CMUI_TextBox;
		localTxtEmailName.parent := theForm.shtMultiSelect2;
	endif;
	localTxtEmailName.visible := true;
	localTxtEmailName.enabled := false;
	localTxtEmailName.move(110, 32,205, 18);
	localTxtEmailName.text := "";
	
	theForm.lblName4.visible := true;
	theForm.lblName4.caption := "E-Mail Address";
	theForm.lblName4.move(50, 42,100, 18);
	
	localTxtEmailAddress := theForm.txtName.getControl(2);
	if localTxtEmailAddress = null then
		localTxtEmailAddress := theForm.txtName.loadControl(2).CMUI_TextBox;
		localTxtEmailAddress.parent := theForm.shtMultiSelect2;
	endif;
	localTxtEmailAddress.visible := true;
	localTxtEmailAddress.enabled := false;
	localTxtEmailAddress.move(110, 54,205, 18);	
	localTxtEmailAddress.text := "";	
	localTxtEmailAddress.case := TextBox.Case_Lower; 
	
	localButton := theForm.btnAddNew.getControl(2);
	if localButton = null then
		localButton := theForm.btnAddNew.loadControl(2).CMUI_Button;
		localButton.parent := theForm.shtMultiSelect2;
	endif;
	localButton.visible := true;
	localButton.enabled := false;
	localButton.bubbleHelp := "Enter a new email address and click here to add";
	localButton.move(localTxtEmailAddress.left + localTxtEmailAddress.width + 5, localTxtEmailAddress.top, 20, 20);
			
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setupThumbnailDetails" id="6b93b8a2-16b3-4075-b39b-b71542fe09b1">
        <updating/>
        <source>setupThumbnailDetails() updating;

vars
	theForm : SOP_TableMaintForm;
	terminology	: String;

begin
	theForm := self.myForm;
	theForm.shtViewTable1.visible := false;
	theForm.useProxyObject := true;
	theForm.setTblDataEntRows(ETDef_OperatorTbl);
//	theForm.zAddColumn('Operator Id', 'code', Table.InputType_None, 25);
//	theForm.zAddColumn('Description', 'description', Table.InputType_None, 60);
//	theForm.zAddColumn('Colour','colour',Table.InputType_None,15);
//12/01/2011 cnwdz2 25840
	//theForm.zClearSortColumns();
	//theForm.zAddSortColumn(ETRow_Code, false);

	theForm.shtTblInput1.caption := 'Details';
	theForm.initTblInput(theForm.tblInput1, ETDef_OperatorMaint);
	theForm.shtTblInput1.visible := true;

	theForm.shtTblInput2.caption := 'Auto Configuration';
	theForm.initTblInput(theForm.tblInput2, ETDef_OpAutoEdiDef);
	theForm.shtTblInput2.visible := true;
	
	theForm.shtTblInput3.caption := 'Terminal Configuration';
	theForm.initTblInput(theForm.tblInput3, ETDef_OperatorTerminal);
	theForm.tblInput3.top := 50;

	theForm.cmbTerminal.visible := true;
	theForm.cmbTerminal.top := 5;
	theForm.cmbTerminal.left:= 65;
	theForm.cmbTerminal.width := 200;
	theForm.shtTblInput3.visible := true;
	
	theForm.lblTerminal.visible := true;
	theForm.lblTerminal.height := theForm.cmbTerminal.height; //Added to allow for alignment of label control and combo control
	theForm.lblTerminal.width := 50;	
	theForm.lblTerminal.top := 5;
	theForm.lblTerminal.left := 5;
	theForm.lblTerminal.width := 50;
	theForm.lblTerminal.caption := 'Terminal';
	
	self.colourColumn := theForm.tblData.getColumnByRowName(ETRow_Colour);			

	theForm.fldInput.topSheet := theForm.shtTblInput1;
	
	// 25/05/2009 cnwar2 CCMS1040/#19796
	theForm.tblData5.left 	:= theForm.shtTblInput3.left + 10;
	theForm.tblData5.width 	:= theForm.shtTblInput3.width - 20;
	theForm.tblData5.top 	:= theForm.tblInput3.top + theForm.tblInput3.height + 10;
end;</source>
    </JadeMethod>
    <JadeMethod name="sheetChange" id="8e7d4906-9f59-4d9b-afe4-36731bd2ec50">
        <updating/>
        <source>sheetChange(folder: Folder input) updating;
// ---------------------------------------------------------------------------
// Created:		24 January 2003  by Jason Chapman  (cnwjc2)
// ---------------------------------------------------------------------------

vars
	theSheet	: Sheet;
	entTableDef	: EntTableDef;
	idx			: Integer;
	defName		: String;
	theTable	: CM_EntryTable;
		
begin

	theSheet := folder.topSheet;

	if theSheet.name &lt;&gt; self.myForm.shtTblInput2.name then
		return;
	endif;

	theTable := self.myForm.tblInput2;
	theTable.parent := theSheet;
	
	theSheet.cnEcResizeContents();
	theTable.resetSize();
	theTable.optimiseHeadingColumn();

end;</source>
        <Parameter name="folder" type="Folder" usage="input"/>
    </JadeMethod>
    <JadeMethod name="showThumbnail" id="d060999c-772b-458c-a076-fd97ad2740f0">
        <updating/>
        <source>showThumbnail(_operator : CM_Operator) updating;
//
// Changed On	By			Reason
// ----------	--------	------------------------------------------------------
// 20/10/2011	cnwdap1		PAR #28524 CCMS POL 2096 Add "Bookings Are Unique By Number" setting
vars
	operGroup 		: CM_OperatorGroup;
	form 			: SOP_TableMaintForm;
	str, notRailIds, notRoadIds, notRailIdsStr,
	notRoadIdsStr 	: String;
	i 				: Integer;
	codeGroup		: CM_CodeGroup;
	terminal		: CM_Terminal;
    table			: CM_EntryTable;
begin
	form 						:= self.myForm;
	form.shtViewTable1.visible 	:= false;
	
    self.getTerminalsForUser();
    
	form.cmbTerminal.listCollection(self.allTerminalsForThisUser, false, 0);
    
	terminal := self.allTerminalsForThisUser.first;
    
	if terminal &lt;&gt; null then
		form.cmbTerminal.text 		:= form.myAssistant.displayEntryTerminal(terminal);
		form.cmbTerminal.listObject := terminal;
	endif;	
	
	table := form.tblInput2;
	
	table.clearValues;
	table.setValueByName(ETRow_AllowBayPlan, _operator.getConfig(AllowBayPlan).Boolean);
	table.setValueByName(ETRow_AllowCustomStop, _operator.getConfig(AllowCustomStop).Boolean);
	table.setValueByName(ETRow_AllowOperatorStop, _operator.getConfig(AllowOperatorStop).Boolean);
	table.setValueByName(ETRow_AllowOutwardRail, _operator.getConfig(AllowOutwardRail).Boolean);
	table.setValueByName(ETRow_AllowPreNote, _operator.getConfig(AllowPreNote).Boolean);
	table.setValueByName(ETRow_AllowBookingRef, _operator.getConfig(AllowBookingRef).Boolean);
	
	table := form.tblInput1;
	
    table.clearValues;		
	table.setValueByName(ETRow_Code, _operator.code);
	table.setValueByName(ETRow_Description, _operator.description);
	table.setValueByName(ETRow_Colour,_operator.colour);
	table.setValueByName(ETRow_IsNotAvailableForEntry, _operator.isNotAvailableForEntry);
	table.setValueByName(ETRow_DisplayTempFahrenheit, _operator.displayTempFahrenheit);
	table.setValueByName(ETRow_RequiresBookingReference, _operator.requiresBookingReference);
	table.setValueByName(ETRow_RequiresCVC, _operator.requiresCVC);
	table.setValueByName(ETRow_RequiresConsigneeOr, _operator.requiresConsigneeConsignor);
	table.setValueByName(ETRow_RequiresDeliveryRelease, _operator.requiresDeliveryRelease);
	table.setValueByName(ETRow_RequiresHumidity, _operator.requiresHumidity);
	table.setValueByName(ETRow_RequiresRequestNumber, _operator.requiresRequestNumber);
	table.setValueByName(ETRow_RequiresVentilation, _operator.requiresVentilation);
	table.setValueByName(ETRow_RequiresVoyage, _operator.requiresVoyage);
	table.setValueByName(ETRow_ReeferReadingsPerDay, _operator.reeferReadingsPerDay);
//	table.setValueByName(ETRow_FreeStorageDays, _operator.getConfig(FreeStorageDays).String);
//	table.setValueByName(ETRow_EmptyFreeStorageDays, _operator.getConfig(EmptyFreeStorageDays).String);	// cnwdad1 01/05/2006 - CCMS #1396.
//	table.setValueByName(ETRow_FullFreeStorageDays, _operator.getConfig(FullFreeStorageDays).String);	// cnwdad1 01/05/2006 - CCMS #1396.
	table.setValueByName(ETRow_DefaultFreightPayerCode, _operator.getConfig(DefaultFreightPayerCode).String);
	table.setValueByName(ETRow_InwardsCharge, _operator.getConfig(InwardsChargeRate).Decimal);
	table.setValueByName(ETRow_ContCharge20, _operator.getConfig(ContainerPackingCharge20ft).Decimal);
	table.setValueByName(ETRow_ContCharge40, _operator.getConfig(ContainerPackingCharge40ft).Decimal);
	table.setValueByName(ETRow_PTIExpiryPeriodDays, _operator.getConfig(PTIExpiryPeriodDays).String);	
	table.setValueByName(ETRow_EDITempFormat, _operator.getConfig(EDITempFormat).String);
	table.setValueByName(ETRow_CargoRelImpFFUpdAllowed, _operator.getCargoReleaseImpFFUpdAllowed);
	
	//cnwrd1 4.11.08 CCMS JMT 1743/1764 
	table.setValueByName(ETRow_RequiresExpOperatorNo, _operator.getRequiresExportOperatorNo() );
	table.setValueByName(ETRow_RequiresImpFF, _operator.getRequiresImportFF() );
	table.setValueByName(ETRow_RequiresImpOperatorPIN, _operator.getRequiresImpOperatorPIN() );
	
	// cnwcs5 14/03/2011 par 26909
	table.setValueByName (ETRow_ShowOpExportReleaseMsg, _operator.getShowOpExportReleaseWarning);

	//cnwjo3 CCMS 1892, par 23587
	table.setValueByName(ETRow_ReeferWashExpiry, _operator.washExpiryReefer  );
	
	// PAR #28524
	table.setValueByName(ETRow_BookingsUniqueByNumber, _operator.bookingsUniqueByNumber);
		
	self.initRecCutoffsTbl();					// 26/05/2009 cnwar2 CCMS1040/#19796
	
	self.loadSealCheckTable(_operator);			//+cnwml2 PAR23715 SFW CCMS1131
	
	self.allOpTerminalConfigs.purge();
	self.getOperatorTerminalConfig(_operator);
		
	if (_operator.notRailIds &lt;&gt; null) then
		i := 1;
		while i &lt;= _operator.notRailIds.numStrings do 
	    	notRailIds := _operator.notRailIds.at(i);
	    	if (i &lt;&gt; _operator.notRailIds.numStrings) then
	    		notRailIdsStr := notRailIdsStr &amp; notRailIds &amp; ", ";
	    	else
	    		notRailIdsStr := notRailIdsStr &amp; notRailIds;	
	    	endif;	
	    	i := i+1;
	    endwhile;
		table.setValueByName(ETRow_NotRailIds,notRailIdsStr);
	endif;
		
	if(_operator.notRoadIds &lt;&gt; null) then	    
		i := 1;
		while i&lt;= _operator.notRoadIds.numStrings do 
	    	notRoadIds := _operator.notRoadIds.at(i);
	    	if(i &lt;&gt; _operator.notRoadIds.numStrings) then
	    		notRoadIdsStr := notRoadIdsStr &amp; notRoadIds &amp;", ";	
	    	else
	    		notRoadIdsStr := notRoadIdsStr &amp; notRoadIds;
	    	endif;
	    	i := i+1;
	    endwhile;
	    table.setValueByName(ETRow_NotRoadIds,notRoadIdsStr);
	endif;
	str := null;
	if (not _operator.allOperatorGroups.isEmpty) then
		foreach operGroup in _operator.allOperatorGroups do
			str := str &amp; operGroup.code &amp; ', ';
		endforeach;
		str := str[1:str.length-2];
		table.setValueByName(ETRow_MyOperatorGroup, str);
//		table.disableRowByName(ETRow_MyOperatorGroup);		
	endif;
	
	if _operator.debtor &lt;&gt; null then
		table.setValueByName(ETRow_MyDebtor,_operator.debtor.name);
		table.setValueByName(ETRow_FinancialId, _operator.debtor.code);	//04.Mar.24 navsp1 TFS 57177
    endif;
//	form.myAssistant.comboBoxOperatorGroup(form.cmbOperatorGroup, _operator.myOperatorGroup, true);
   	form.cmbDebtor.setObject(_operator.debtor);

	codeGroup := _operator.allCodeGroups[CodeGroup_LogSpecs];
	form.myAssistant.comboBoxCodeGroupLogSpecs(form.cmbCodeGroup1, codeGroup);
	table.setValueByName(ETRow_LogSpecCodeGroup, form.cmbCodeGroup1.text);
	
	self.initTreeViewMulti();
	if not self.codeGroupsLoaded then
		self.loadCodeGroupTreeView(true);
		self.codeGroupsLoaded := true;
	endif;
	
	form.mulSelect1.setSelected(_operator.allOperatorGroups);
	
	self.loadOperatorCodeGroupsTreeView(true);
		
	//25 Aug 2009	NDL	CCMS 1609 Par 20521
	form.mulSelect2.setSelected(_operator.allEmailAddresses);
end;</source>
        <Parameter name="_operator" type="CM_Operator"/>
    </JadeMethod>
    <JadeMethod name="tblDataShowDataSpecial" id="e34c245e-39b3-4a06-a5c9-8fbe31b0d3c6">
        <source>tblDataShowDataSpecial(_idxRow: Integer; _obj: Object);
//--------------------------------------------------
// Created:	25 November 2003 By: cnwgd1
//--------------------------------------------------
vars
	lOperator:CM_Operator;
	cell     :JadeTableCell;
begin

	lOperator := _obj.CM_Operator;
	if(_idxRow &lt;&gt; 1) then
		if colourColumn &gt; 0 then	
			cell := myForm.tblData.accessCell(_idxRow,colourColumn);
			cell.text := null;			
			cell.backColor := lOperator.colour;
		endif;
	endif;
	
end;</source>
        <Parameter name="_idxRow" type="Integer"/>
        <Parameter name="_obj" type="Object"/>
    </JadeMethod>
</Class>
