        <source>initTableData(_theEntDef: String) updating;
// ---------------------------------------------------------------------------
// Created:		11 August 2005  By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

begin
	inheritMethod(_theEntDef);
	self.tblData.multiSelect := CM_BaseTable.MultiSelect_None;
	self.tblData.disallowColumnSorter := true;
	self.tblData.selectMode := Table.SelectMode_FixedRow;

end;</source>
