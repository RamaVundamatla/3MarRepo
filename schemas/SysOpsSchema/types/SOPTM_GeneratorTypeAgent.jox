    <JadeMethod name="create" id="cad2016c-30e3-43cf-93ad-d2e5d4409588">
        <updating/>
        <source>create() updating;
/* ---------------------------------------------------------------------------
Created:	07 August 2008	by cnwvu1

Purpose:	
        
Change Date		Who		Reason

------------------------------------------------------------------------------*/
vars

begin

	self.name := SOP_TableMaintForm.Table_GeneratorType;
	self.permissionView	 := PmAdmGeneratorTypeView;
	self.permissionMaint := PmAdmGeneratorTypeUpdate;
	self.myDataClass := CM_GeneratorType;
	
	self.weightType := app.getDefaultMeasurementForType(Type_Weight);	//18 Mar 2014	NDL	Par 33268


end;</source>
