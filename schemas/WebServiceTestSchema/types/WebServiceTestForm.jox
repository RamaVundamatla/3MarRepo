    <JadeMethod name="messageExceptionHandler" id="6b214c11-a4f9-41ef-b09f-b5bb987e0027">
        <source>messageExceptionHandler(exc : Exception) : Integer;

/*

Purpose:			


Return Value:		


Date		Who		Reason
28 October 2004	cnwkpd1	Initial creation

*/

vars
	returnVal		: Integer;
	
begin
	returnVal := Ex_Pass_Back;

	logMessage("Exception " &amp; exc.errorCode.String &amp; " " &amp; exc.errorItem.String &amp; " " &amp; exc.extendedErrorText);

	if myCurrentWebService &lt;&gt; null then
		logMessage("soapResponse=" &amp; myCurrentWebService.getPropertyValue(JadeWebServiceConsumer::soapResponse.name).String);
	endif;
	
	returnVal := Ex_Resume_Next;
	
	
epilog
	return returnVal;
	
end;</source>
        <Parameter name="exc" type="Exception"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="preserveJadeSessionId" id="70c97c89-6bc5-4098-9baf-4ceadf9ed447">
        <source>preserveJadeSessionId() : Boolean;

/*

Purpose:			Determine whether or not to preserve the Jade session Id between calls

Parameters:			

Return Value:		


Date		Who		Reason
22 Jul 2008	cnwkpd1	PAR #17554 - Development of new RIA Web Service application

*/

vars

begin
	return true;
	
	
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="sendLogonMessage" id="42627d25-9c95-4462-bf80-ab64751a9609">
        <updating/>
        <source>sendLogonMessage(_xmlScript : XMLSessionScript) : Boolean updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
16 Feb 2009	cnwkpd1	PAR #17554 - JMT RIA Web Service

*/

vars
	payload			: XMLMessagePayload;
	
begin
	delete self.myCurrentWebService;
	self.setCurrentSessionId(null);
	
	create payload transient;
	payload.serviceName			:= JMTSecureService.name;
	payload.operationName		:= JMTSecureService::logon.name;
	payload.message				:= ''
					&amp; '&lt;Logon&gt;'
					&amp; '&lt;password&gt;' &amp; _xmlScript.password &amp; '&lt;/password&gt;'
					&amp; '&lt;userId&gt;' &amp; _xmlScript.usercode &amp; '&lt;/userId&gt;'
					&amp; '&lt;/Logon&gt;';

	return self.sendWebServiceMessage(payload);
	
	
epilog
	delete payload;
	
end;</source>
        <Parameter name="_xmlScript" type="XMLSessionScript"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="sendWebServiceMessage" id="e42f81c1-e058-4964-bf21-4d900a6636ab">
        <updating/>
        <source>sendWebServiceMessage(xmlMessage : XMLMessagePayload) : Boolean updating;

/*

Purpose:			


Return Value:		


Date		Who		Reason
28 Oct 2004	cnwkpd1	Initial creation
22 Jul 2008	cnwkpd1	PAR #17554 - Development of new RIA Web Service application
					Rework creation of Web Service Consumer to handle multiple providers
28 Mar 2018	jlgkpd1	Handle non-JADE Web Services without '&amp;' in the URL

*/

vars
	tranID			: String;
	tranStarted		: Boolean;
	statFile		: File;
	now				: TimeStamp;
	fileName		: String;
	profiler		: JadeProfiler;
	consumerClass	: Class;
	url				: String;
	input			: Object;
	xml				: JadeXMLDocument;
	createdObjects	: ObjectSet;
	connectTimeout	: Integer;
	sendTimeout		: Integer;
	receiveTimeout	: Integer;
	ampPos			: Integer;
	
begin
	on JadeSOAPException do messageExceptionHandler(exception);

	consumerClass := currentSchema.getClass(xmlMessage.serviceName);
	if consumerClass = null then
		return false;
	endif;
	
	if myCurrentWebService = null or not myCurrentWebService.isKindOf(consumerClass) then	
		delete myCurrentWebService;
		create myCurrentWebService as consumerClass transient;
	else
		myCurrentWebService.reset;
		self.myLastOutput:=null;
	endif;
	
//	myCurrentWebService.setTimeouts(1000, 1000, 1000);
//	myCurrentWebService.getTimeouts(connectTimeout, sendTimeout, receiveTimeout);
//	write "Before " &amp; connectTimeout.String &amp; Tab &amp; sendTimeout.String &amp; Tab &amp; receiveTimeout.String;
	
	myCurrentWebService.setSessionId(self.currentSessionId);

	myCurrentWebService.setPropertyValue(JadeWebServiceConsumer::logStatistics.name, getLogStatistics);
	url := myCurrentWebService.getEndpointURL;
	ampPos := url.pos("&amp;", 1);
	if ampPos &lt;&gt; 0 then
		myCurrentWebService.setEndpointURL(getWebServiceURL &amp; url[ampPos:end]);
	else
		myCurrentWebService.setEndpointURL(getWebServiceURL);
	endif;
	
	logMessage("Sending " &amp; xmlMessage.message &amp; " to " &amp; myCurrentWebService.getEndpointURL);

	tranID := method.name &amp; "_" &amp; xmlMessage.operationName;
	cnStartTransaction(tranID);
	tranStarted := true;
	
	create createdObjects transient;
	input := xmlMessage.message.asObjectUsingConvertFromXML(createdObjects);

	if getLogStatistics then
		now := app.actualTimeAppServer;
		create profiler transient;
		profiler.methodCount := 100;
		profiler.profileRemoteExecutions := true;
		profiler.fileName := app.myCnCntrl.logPath &amp; "profile_web_" &amp; cnGetInstanceId(process).String &amp; "_" &amp; now.getNumeralString &amp; ".log";
		profiler.start;
	endif;
	
	
	self.myLastOutput := myCurrentWebService.sendMsgWithParams(xmlMessage.operationName, input).Object;

	// Save off Jade session Id for the next call
	if self.preserveJadeSessionId then
		self.setCurrentSessionId(self.myCurrentWebService.getSessionId);
	endif;
	
	if profiler &lt;&gt; null then
		profiler.stop;
		profiler.report;
	endif;

	if getLogStatistics then
		// Can log details of every transaction's statistics to a file if required
		create statFile transient;
		fileName := "c:\temp\web_stats_" &amp; cnGetInstanceId(process).String &amp; "_" &amp; now.getNumeralString &amp; ".xml";
	
		statFile.openOutput(fileName);
		statFile.writeString(myCurrentWebService.getLastStatistics(false));
		statFile.close;
	endif;
	
//	myCurrentWebService.getTimeouts(connectTimeout, sendTimeout, receiveTimeout);
//	write "After " &amp; connectTimeout.String &amp; Tab &amp; sendTimeout.String &amp; Tab &amp; receiveTimeout.String;

	// Response could be null if we had a SOAP exception
	if self.myLastOutput &lt;&gt; null then
		cnEndTransaction;
		tranStarted := false;
		
		logMessage("Response received " &amp; self.myLastOutput.returnAsXMLString);
		return true;
	else
		cnSetTransactionError(true);
		return false;
	endif;
	

epilog
	if tranStarted then
		cnEndTransaction;
	endif;
	delete statFile;
	delete profiler;
	delete xml;
	delete input;
	if createdObjects &lt;&gt; null then
		createdObjects.purge;
		delete createdObjects;
	endif;
	
end;</source>
        <Parameter name="xmlMessage" type="XMLMessagePayload"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setCurrentSessionId" id="90f0977d-3ec7-4fb4-9732-f5d79861e84c">
        <updating/>
        <source>setCurrentSessionId(value: String) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
22 July 2008	cnwkpd1	PAR #17554 - Development of new RIA Web Service application

*/

vars

begin
	if currentSessionId &lt;&gt; value then 
		currentSessionId := value;
	endif;


epilog

end;</source>
        <Parameter name="value" type="String"/>
    </JadeMethod>
</GUIClass>
