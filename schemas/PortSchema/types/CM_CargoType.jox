// 	june 2005 par 7572 change from trackeditem type to cargotype for dss
vars

begin
	return id;
end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="updateForNonInversedReference" id="be64d4df-b527-46f0-9339-bc600685009e">
        <updating/>
        <source>updateForNonInversedReference() updating;
// ---------------------------------------------------------------------------
// Created:     04 March 2010 by cnwcs5
// Purpose:     par 22762
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	if self.hasNoNonInversedUsages then
		self.hasNoNonInversedUsages := false;
	endif;
epilog

end;</source>
