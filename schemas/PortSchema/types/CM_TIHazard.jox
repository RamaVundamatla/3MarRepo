    <JadeMethod name="getUndgCodesAsString" id="7b0a66a3-99aa-4bdb-a963-77f57e0c1da9">
        <source>getUndgCodesAsString( _trunacteTo80Chars : Boolean ):String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 September 2019	jlgndl1	Initial creation	TFS 46633

*/

vars

	strCode : String;
	str : String;
	
begin
	if self.allUNDGCodes.isEmpty then
		return null;
	endif;
	
	foreach strCode in self.allUNDGCodes do
		str := str &amp; ", " &amp; strCode;
	endforeach;	

	if _trunacteTo80Chars and str.length &gt; 76 then
		return str[3:76] &amp; "...";
	else
		return str[3:end];
	endif;

end;</source>
        <Parameter name="_trunacteTo80Chars" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
