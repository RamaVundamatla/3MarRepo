    <JadeMethod name="translateForm" id="145511db-e035-4912-8570-5c932d291557">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 22 March 2022 14:44:04.
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0007308, locale);
	btnAddRecipe.translateBubbleHelp(Xlat_0024231, locale);
	btnAddRecipe.translateCaption(Xlat_0024232, locale);
	btnAttachment.translateCaption(Xlat_0024625, locale);
	btnDelRecipe.translateBubbleHelp(Xlat_0024233, locale);
	btnDelRecipe.translateCaption(Xlat_0024234, locale);
	btnProductsForm.translateBubbleHelp(Xlat_0000187, locale);
	btnProductsForm.translateCaption(Xlat_0014542, locale);
	btnUpdRecipe.translateBubbleHelp(Xlat_0024235, locale);
	btnUpdRecipe.translateCaption(Xlat_0024236, locale);
	chkShowNotAvail.translateCaption(Xlat_0010877, locale);
	frmPolygon.translateCaption(Xlat_0014109, locale);
	lblSysType.translateCaption(Xlat_0000222, locale);
	mnuEditAttributes.translateCaption(Xlat_0010878, locale);
	mnuEditAttrtHdr.translateCaption(Xlat_0010879, locale);
	shtCommodities.translateCaption(Xlat_0010880, locale);
	shtDetails.translateCaption(Xlat_0010881, locale);
	shtDmgePosition.translateCaption(Xlat_0011860, locale);
	shtRecipes.translateCaption(Xlat_0024237, locale);
	shtSeals.translateCaption(Xlat_0015984, locale);
	shtTerminals.translateCaption(Xlat_0010882, locale);
end;</source>
    </JadeMethod>
    <JadeMethod name="zTblDataSelectRow" id="9cbd7781-5352-47a4-931f-8fede4971e6a">
        <updating/>
        <source>zTblDataSelectRow(_row: Integer) updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 March 2022	navak20	Initial creation #52821

*/

vars

	newRow : Integer;
	obj : CM_Object;
begin
	inheritMethod(_row);
	newRow := self.tblData.row;
	
	obj := self.tblData.accessRow(newRow).itemObject.CM_Object;

	if obj &lt;&gt; null then
	        self.btnAttachment.enabled := true;	
	        self.btnAttachment.userObject := obj;
	endif;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_row" type="Integer"/>
    </JadeMethod>
</GUIClass>
