    <JadeMethod name="isValidForEDIMode" id="4b68bc94-2bd7-4ba8-800e-8cba9712249b">
        <source>isValidForEDIMode(	_realBookingRef : CM_BookingRef; 
					_ediBookingRefTI : CM_EDIBookingRefTI; 
					_ediMode : String; 
					_extraInfo : String output ) : Boolean protected;
/* -----------------------------------------------------------------------------------------------------------
Created:	23 February 2009	by cnwvu1

Purpose:	Par 18495. If ediFileIssueDateTime from EDI is older then current _realBookingRef.ediFileIssueDateTime,
			then method gives false, otherwise true.
			Creates _extraInfo for CM_AuditObjectInformation.info
			_ediMode = ADD, UPDATE, DELETE.
			
Change Date		Who		Reason

--------------------------------------------------------------------------------------------------------------*/
vars
	ediIsOlder	: Boolean;
	tmpEdiMode	: String;
	
begin

	//checking whether EDI file is not old
	if _realBookingRef = null then	// EDI date time is always valid - there is no date time at all
		ediIsOlder := false;
		
	elseif _realBookingRef.ediFileIssueDateTime = null then	//// EDI date time is always valid - there is no date time at all
		ediIsOlder := false;
	
	elseif _ediBookingRefTI.ediFileIssueDateTime = null then	//assume that _ediBookingRefTI &lt;&gt; null always. 
		ediIsOlder := false;
		
	else	//when both dates &lt;&gt; null
		ediIsOlder := _realBookingRef.ediFileIssueDateTime &gt; _ediBookingRefTI.ediFileIssueDateTime;
		
	endif;
	
	if _ediMode = CM_EDITrackedItem.EDI_ACTION_ADD then
		tmpEdiMode := app.getErrorString(EDIData_ModeADD);
	elseif _ediMode = CM_EDITrackedItem.EDI_ACTION_UPDATE then
		tmpEdiMode := app.getErrorString(EDIData_ModeUPDATE);
	else
		tmpEdiMode := app.getErrorString(EDIData_ModeDELETE);
	endif;

	// prepare extraInfo for audit information (CM_AuditObjectInformation)
	if ediIsOlder then		// cannot load EDI file - it is older than current _realBookingRef.ediFileIssueDateTime

		_extraInfo := app.getErrorString1(EDIModeIgnored, tmpEdiMode) &amp;" "
					&amp; app.getErrorString3(EDIFileIsOlderThanCurrent, _ediBookingRefTI.myEDIData.fileName, _ediBookingRefTI.ediFileIssueDateTime.asStringJMT(), _realBookingRef.ediFileIssueDateTime.asStringJMT() );
	
	else // can load EDI file - it is fresh or there are issue dates = null
	
		_extraInfo := app.getErrorString(EDIMode) &amp;" "&amp; tmpEdiMode &amp; ". "
					&amp; app.getErrorString2(EDIFileNameCreatedDateTime, _ediBookingRefTI.myEDIData.fileName, _ediBookingRefTI.ediFileIssueDateTime.asStringJMT() );
		
	endif;

	return not ediIsOlder;	// when ediIsOlder - cannot load EDI

end;</source>
        <access>protected</access>
        <Parameter name="_realBookingRef" type="CM_BookingRef"/>
        <Parameter name="_ediBookingRefTI" type="CM_EDIBookingRefTI"/>
        <Parameter name="_ediMode" type="String"/>
        <Parameter name="_extraInfo" type="String" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="loadDB" id="3ba6174f-f737-45c8-8592-b45f8aa59e29">
        <updating/>
        <source>loadDB(_mergeCargo : Boolean; _passport : CM_Passport input) updating;

/*
	Created on 29 February 2008
	
	by Debby Hutchison
	
	Purpose: this is used to load the new multiitem brefs from file.
	The old loading of single item brefs has been saved as 'loadDBOld'

Changes

Date		Name	TFS#		Description
============================================================================
02 Jul 2012	cnwrs1	Par 29927 	EDI Booking Item replace not working
08 Aug 2013	cnwcs5	CCMS POL 2221 / par 32094(2)
08 Oct 2015	cnwrs1	Par 36863  	make EDI consistant times when refreshing progress bar
13 May 2016	cnwns1	TFS 488  	Multi Timezone Support
08 May 2018	jlgrs1	TFS 36425 	SingleLine Booking partial processing not working
27 Sep 2018	jlgrs1	TFS 40627 	STWR Make EDI MultiThreaded Stage 4
03 Sep 2019 jlgka1 	TFS 45332 	STWR - Better Forms and Interfaces for EDI Module
20 Oct 2020	jlgmd1	TFS 50204	Refactor progress updates to superclass method
============================================================================*/
vars
	realBookingRef			: CM_BookingRef;
	cmifAgent				: CMIF_EDIBookingRef;
	cmifBookingRef			: CMIF_BookingRef;
	cmifObject				: CMIF_Object;
	ediTI					: CM_EDITrackedItem;
	ediBookingRefTI,
	ediBookingRefTI_previous: CM_EDIBookingRefTI;
	ignoreWarnings			: Boolean;
	updateMon				: Boolean;
	tmpPorts				: StringArray;
	tmpHazards				: ObjectArray;
	terminalObj				: CM_Terminal;
	todo					: Integer;
	done					: Integer;
	passport				: CM_Passport;
	ediAction				: Boolean;
	allMatchedBRItems 		: CM_BookingRefItemDict;	
	progressTS 				: TimeStamp;
	newStatus 				: Integer;
begin
	progressTS := app.actualTimeServer();	// 13 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	passport	:=	app.myPassport;
	terminalObj	:=	self.getMyTerminal();
	create tmpPorts transient;
	create tmpHazards transient;
	create cmifAgent transient;
	create allMatchedBRItems transient;
	
	ignoreWarnings := true;
	todo := self.allEDITrackedItems.size();
	done := null;
	
	self.updateProgress(progressTS, "Creating/Updating Booking References", todo, done, true, _passport);
	
	if not self.allEDITrackedItems.isEmpty and 
	   self.allEDITrackedItems.first.messageMode &lt;&gt; null then
		ediAction := true;
	endif;
	
	if not ediAction then
		// ------------------------------------------------------------------------------------------------------
		//						N O R M A L    L O A D I N G    M O D E    (NO EDI ACTION)
		// ------------------------------------------------------------------------------------------------------
		// Behaviour as previous. Idea is - craetion all CMIF_BookingRefs and grouping all CM_EDIBookingRefTIs.
		// At the end, all trxs are processed.
	
		// first we create a cmif structure on the agent to represent all the edi lines
		// first pass - creates just the Booking Reference master cmifs (each may have &gt;1 edi line)
		foreach ediTI in self.allEDITrackedItems do
			if ediTI.status = CM_EDITrackedItem.EDI_STATUS_DBLOADED or
			   ediTI.status = CM_EDITrackedItem.EDI_STATUS_SKIP_PROCESSING or
			   ediTI.status = CM_EDITrackedItem.EDI_STATUS_SKIP_PROCESSING_X then
				continue;
			endif;
			beginLoad;
			cmifBookingRef := null;
			done := done + 1;
			
			self.updateProgress(progressTS, "Creating/Updating Booking References", todo, done, false, _passport);
			
			ediBookingRefTI := ediTI.CM_EDIBookingRefTI;
			// dh - first find the real database BRef object that matches this file line
			realBookingRef := ediBookingRefTI.findRealBookingRef(terminalObj);
			
			// dh - now see if we have already created a cmif for this booking ref.
			cmifBookingRef := cmifAgent.findAndLoadCMIFBookingRef(ediBookingRefTI, realBookingRef, terminalObj);
			endLoad;
		endforeach;
		
		// now we go through each master object creating a cmif for each of its detail objects (book ref items)
		// second pass
		foreach	cmifObject in cmifAgent.allCMIFBookingRefs do
			beginLoad;
			cmifBookingRef := cmifObject.CMIF_BookingRef;
			cmifBookingRef.processCMIFItemsFromEDILines(null, allMatchedBRItems);	//Par 18495 Jan 2009
			endLoad;
		endforeach;
		
		// now we save the entire structure
		foreach	cmifObject in cmifAgent.allCMIFBookingRefs do
		
			cmifBookingRef	:=	cmifObject.CMIF_BookingRef;
			self.processingBookingRefTrx(cmifBookingRef, cmifAgent, terminalObj, passport);
			
			if passport.trxCompletedOK = false then
				break;
			endif;
			
		endforeach;
	
	else
	
		// ------------------------------------------------------------------------------------------------------
		//							E D I    A C T I O N    L O A D I N G    M O D E
		// ------------------------------------------------------------------------------------------------------
		// Difference is - creates CMIF_BookingRef for each line in the EDI file (for each EDI Action)
		// Note. Multi booking ref takes one line in EDI file
		done := 0;
		todo := self.allEDITrackedItems.size;
		
		foreach ediTI in self.allEDITrackedItems do
			if ediTI.status = CM_EDITrackedItem.EDI_STATUS_DBLOADED or
			   ediTI.status = CM_EDITrackedItem.EDI_STATUS_SKIP_PROCESSING or
			   ediTI.status = CM_EDITrackedItem.EDI_STATUS_SKIP_PROCESSING_X then
				continue;
			endif;
			done := done + 1;
			self.updateProgress(progressTS, "Creating/Updating Booking References", todo, done, false, _passport);
			
			ediBookingRefTI := ediTI.CM_EDIBookingRefTI;

			if ediBookingRefTI_previous = null then	// the first iteration
				ediBookingRefTI_previous := ediBookingRefTI;
			else	// normal work
			
				if ediBookingRefTI.groupCodeForEDIMultiItem &lt;&gt; null and
				   ediBookingRefTI_previous.groupCodeForEDIMultiItem = ediBookingRefTI.groupCodeForEDIMultiItem and
				   ediBookingRefTI_previous.messageMode = ediBookingRefTI.messageMode then
					// there is multi booking ref, i.e. several containers on a booking ref. Should be the same cmifBookingRef 
					// creation CMIF_BookingRef or updating existing one.
					cmifBookingRef := processingCMIFBookingRef(ediBookingRefTI_previous, cmifAgent, terminalObj, allMatchedBRItems);
					
					ediBookingRefTI_previous := ediBookingRefTI;
					continue;	// go on until other cmifBookingRef is created
				else	// when there is next line in the EDI file
				
					cmifBookingRef := processingCMIFBookingRef(ediBookingRefTI_previous, cmifAgent, terminalObj, allMatchedBRItems);
					// go to trx
					self.processingBookingRefTrx(cmifBookingRef, cmifAgent, terminalObj, passport);
					//delete all proxies
					delete cmifAgent;
					if not passport.trxCompletedOK() then
						break;
					endif;
					
					ediBookingRefTI_previous := ediBookingRefTI;
					create cmifAgent transient;	// creating new one for next portion
				endif;
			endif;
		endforeach;
		
		if passport.trxCompletedOK or
		   ediBookingRefTI_previous = ediBookingRefTI then	//When previous transaction failed, it doesn't make sense to go on (plus cmifAgent = null). PAR20250 July 2009
			if ediBookingRefTI &lt;&gt; null then	// the last item in the loop wasn't processed - just proceed cmifBookingRef and exit
				cmifBookingRef := processingCMIFBookingRef(ediBookingRefTI, cmifAgent, terminalObj, allMatchedBRItems);
						// go to trx
				self.processingBookingRefTrx(cmifBookingRef, cmifAgent, terminalObj, passport);
				// pxy will be deleted in the epilog (delete cmifAgent)
			endif;
		endif;
	endif;
	
	self.updateProgress(progressTS, "Creating/Updating Booking References", todo, done, true, _passport);
	
epilog
	delete tmpPorts;
	delete allMatchedBRItems;
	
	if tmpHazards &lt;&gt; null then
		tmpHazards.purge();
		delete tmpHazards;
	endif;
	
	delete cmifAgent;
	self.setEDITIStatusFromErrors(false, _passport);
	
	if passport.noErrors() then
		newStatus := self.getStatusAfterVerifyOrDBLoad(false, _passport);
		app.myTrxUA.trxSetEDIDataStatus(self, newStatus); //ccms1845
	else // this should never occur as the verify should pick up any errors
		beginTransaction;																		// 24/06/2013 cnwmh5 #31614
		self.copyErrors();
		commitTransaction;
	endif;
	
	endLoad;
	
end;</source>
        <Parameter name="_mergeCargo" type="Boolean"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="processTIs" id="9f9c09e7-b356-4376-8ec4-d4a249a9d4f5">
        <updating/>
        <source>processTIs(_trackedItem : CM_TrackedItem; _type : Integer) updating;
// This method taks TI's from CMS and converts data to EDI TIs
// used to extract data from CMS
//02 Feb 2012	cnwrs1	Par 29076 Fix up Hazard Processing in EDI
// 31/05/2012	cnwcs5	CCMS SFW 1284 - EDI BGP Split - use setStatus instead of status := 
// 08 May 2018	jlgrs1	TFS 36425 SingleLine Booking partial processing not working
// 07 Apr 2019	jlgrs1	TFS 41913 STWR - Reconfiguration of the EDI Operation form to better handle EDI collection locks while loading 
//
vars
	tmpContainer	: CM_Container;
	ediTrackedItem: CM_EDIBookingRefTI;
	commodity: CM_Commodity;
	imCodes : StringArray;
begin
	if _trackedItem &lt;&gt; null then
		if _trackedItem.cargoType = TI_CargoType_Container then
			create ediTrackedItem persistent;
			ediTrackedItem.setForCreateNew(self);
			ediTrackedItem.setCargoType(_trackedItem.cargoType);
		else
			abortTransaction;
			return;
		endif;
		
		tmpContainer := _trackedItem.CM_Container;
		
		ediTrackedItem.setId(tmpContainer.bookingReference.toUpper);
		ediTrackedItem.commodity := tmpContainer.commodity;
		commodity := app.myRoot.allCommodities[tmpContainer.commodity];
		if commodity &lt;&gt; null then
			ediTrackedItem.commodityDescription := commodity.description;
		endif;
		ediTrackedItem.destinationPort := tmpContainer.destinationPort;
		ediTrackedItem.dischargePort := tmpContainer.dischargePort;
		ediTrackedItem.isoType := tmpContainer.getISOType;
		ediTrackedItem.loadPort := tmpContainer.loadPort;
		if tmpContainer.isEmpty then
			ediTrackedItem.fullOrMT := "E";
		else
			ediTrackedItem.fullOrMT := "F";
		endif;
		ediTrackedItem.operatorCode := tmpContainer.operatorCode;
		ediTrackedItem.remarks := tmpContainer.remarks;
		if tmpContainer.requiresTemperature then
			ediTrackedItem.temperature := tmpContainer.getTemperature;
		else
			ediTrackedItem.temperature := NULL_TEMPERATURE;
		endif;
		ediTrackedItem.weight := tmpContainer.totalWeight;				//+cnwml2 MSL CCMS 1017
		ediTrackedItem.width := tmpContainer.width;
		ediTrackedItem.length := tmpContainer.length;
		ediTrackedItem.height := tmpContainer.height;
		
		ediTrackedItem.density 		 := tmpContainer.density;		// MES1008 JMH 28/9/09 // ### TFS 52193 22Nov2021 NAVPW1
		ediTrackedItem.markNumber 	 := tmpContainer.markNumber;	// MES1008 JMH 28/9/09
				
		ediTrackedItem.imCodes.clear;					// MES1008 JMH 28/9/09 Add Hazards
		create imCodes transient;
		ediTrackedItem.processTIHazards(tmpContainer.allTIHazards, imCodes);
		imCodes.copy(ediTrackedItem.imCodes);
	endif;
	
	self.setStatus (CM_EDIFile.EDI_STATUS_LOADED);	// CCMS SFW 1285 May 2012
epilog
	delete imCodes;
end;</source>
        <Parameter name="_trackedItem" type="CM_TrackedItem"/>
        <Parameter name="_type" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="processingBookingRefCreateTrx" id="70b5b077-eea5-420c-8c76-dce55d36388b">
        <updating/>
        <source>processingBookingRefCreateTrx(_cmifBookingRef : CMIF_BookingRef input; _ediBookingRefTI : CM_EDIBookingRefTI; _extraInfo: String; _terminal : CM_Terminal; _passport : CM_Passport input) updating, protected;
/* ---------------------------------------------------------------------------
Created:	14 January 2009	by cnwvu1

Purpose:	
   
Change Date		Who		Reason

------------------------------------------------------------------------------*/
vars
	realBookingRef			: CM_BookingRef;
	realReleaseObj			: CM_BulkRelease;
	pxyReleaseObj			: CM_BulkRelease;

begin
	app.myPassport.setWarningsIgnored(true); //cnwrs1 19 May 2010 unit test stopped working
	pxyReleaseObj := _cmifBookingRef.createReleaseProxyFromEDI(_ediBookingRefTI, _terminal);
	app.myTrxCA.trxCreateBookingBulkRel_CMIF(	_cmifBookingRef,
												null,
												_passport,
												_ediBookingRefTI,
												realBookingRef,
												pxyReleaseObj,
												realReleaseObj,
												_extraInfo);

epilog
	if pxyReleaseObj &lt;&gt; null then
		delete pxyReleaseObj;
	endif;

end;</source>
        <access>protected</access>
        <Parameter name="_cmifBookingRef" type="CMIF_BookingRef" usage="input"/>
        <Parameter name="_ediBookingRefTI" type="CM_EDIBookingRefTI"/>
        <Parameter name="_extraInfo" type="String"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="processingBookingRefTrx" id="d1da8895-d6b5-469c-938f-b6decf89d63d">
        <updating/>
        <source>processingBookingRefTrx(_cmifBookingRef : CMIF_BookingRef input; _cmifAgent : CMIF_EDIBookingRef input; _terminal : CM_Terminal; _passport : CM_Passport input) updating, protected;
/* ---------------------------------------------------------------------------
Created:	14 January 2009	by cnwvu1

Purpose:	
   
Change Date		Who		Reason
04/04/2012		cnwcs5	par 29326 - unique booking by operator
08/08/2012		cnwcs5	par 30042 - make email on delete of non-existent booking conditional
//13 May 2015	cnwrs1	Par 36099 - never create an error when deleting EDI booking ref
------------------------------------------------------------------------------*/
vars
	ediBookingRefTI		: CM_EDIBookingRefTI;
	ediAction			: String;
	realBookingRef		: CM_BookingRef;
	expectedEdition		: Integer;
	extraInfo, subject, message,
	strType				: String;				// par 29326 - april 2012
	ediFile				: CM_EDIFile;			// par 29326 - april 2012
	ediData				: CM_EDIData;			// par 29326 - april 2012
	ediFileType			: CM_EDIFileType;		// par 29326 - april 2012
begin
	app.myPassport.setWarningsIgnored(true); //cnwrs1 19 May 2010 unit test stopped working
	
	ediBookingRefTI	:=	_cmifBookingRef.myProxyBookingRef.myEDIBookingRefTI;
	
	if _cmifBookingRef.allCMIF_BRItems.size &gt; 1 then
		_cmifBookingRef.myProxyBookingRef.setIsMultiItem(true);
	endif;

	ediAction := _cmifBookingRef.getEDIAction();
	
	if ediAction = null then	
		//----------------------------------------------------------------------------
		// 			behaviour as previous, when there is no EDI mode action
		//----------------------------------------------------------------------------
	
		if _cmifBookingRef.myRealBookingRef = null then
			self.processingBookingRefCreateTrx(_cmifBookingRef, ediBookingRefTI, extraInfo, _terminal, _passport);
			
		else
			app.myTrxUA.trxUpdateBookingRefMulti(_cmifBookingRef, _passport, ediBookingRefTI);
			
		endif;
		
	else	//Par18495, Jan 2009
		//----------------------------------------------------------------------------
		// 						processing in EDI action mode 
		//----------------------------------------------------------------------------

		_cmifBookingRef.myProxyBookingRef.pxyGetRealObjectAndEdition(realBookingRef, expectedEdition);
		
		if ediAction = CM_EDITrackedItem.EDI_ACTION_ADD			// MES1008 JMH 29/9/09
		or ediAction = CM_EDITrackedItem.EDI_ACTION_UPDATE		// MES1008 JMH 29/9/09
		then
			if self.isValidForEDIMode(realBookingRef, ediBookingRefTI, ediAction, extraInfo) then
				if realBookingRef &lt;&gt; null then	// if realBookingRef exists, then replace it
					app.myTrxDA.trxDeleteBookingRef(realBookingRef, /*null*/extraInfo, _passport);
				endif;
				self.processingBookingRefCreateTrx(_cmifBookingRef, ediBookingRefTI, extraInfo, _terminal, _passport);
			else	//cannot load EDI file, because EDI is older - just create a CM_AuditObjectInformation
				app.myTrxCA.trxCreateAuditInformation(realBookingRef, extraInfo, _passport);
			endif;
		
		elseif ediAction = CM_EDITrackedItem.EDI_ACTION_DELETE then	// MES1008 JMH 29/9/09
			if realBookingRef &lt;&gt; null then 
				if self.isValidForEDIMode(realBookingRef, ediBookingRefTI, ediAction, extraInfo) then
					app.myTrxDA.trxDeleteEDIBookingRef(realBookingRef, extraInfo, _passport);
				else	//cannot load EDI file, because EDI is older - just create a CM_AuditObjectInformation
					app.myTrxCA.trxCreateAuditInformation(realBookingRef, extraInfo, _passport);
				endif;
			else 
				// par 30042 - make email when no booking found to delete conditional
				if _terminal.getConfig (EdiBookingEmailNoDelete).Boolean then
					// par 29326 - send email if we get a delete message and we can't find the booking to delete it
					// we have a delete message but we have not found a booking to delete
					// send an email to the supporters email address saying this has happened.
					subject := 'Booking ' &amp; ediBookingRefTI.id &amp; ' for operator ' &amp; ediBookingRefTI.operatorCode &amp; ' could not be deleted by EDI';
					
					ediData	:= ediBookingRefTI.myEDIData;
					
					if ediData &lt;&gt; null then
						ediFile := ediData.myEDIFile;
					endif;
					
					if ediFile &lt;&gt; null then
						ediFileType := ediFile.myEDIFileType;
					
						if ediFileType &lt;&gt; null then
							strType := ediFileType.name;
						else
							strType := '&lt;Unknown file type&gt;';
						endif;
						
						message	:= strType &amp; ' ' &amp; ediFile.fileName &amp; ' loaded ' &amp; ediFile.fileCreatedTs.asStringJMT;
					endif;
					
					app.myTrxCA.trxCreateEmailSendRequest(app.getErrorString(BGP_Processing), 
															app.myRoot.getConfig(AutoSupportEmailAddress).String,	
															app.myRoot.getConfig(AutoSendersEmailAddress).String,
															null, null, 
															subject, message, 
															null, null, null, null, 
															EmailSource_System,  null, _passport);
				endif;
			endif;
		else
			app.raiseCMException1( EDI_Action_Is_Invalid, ediAction, ETRow_MessageMode, null );
		endif;
	endif;

end;</source>
        <access>protected</access>
        <Parameter name="_cmifBookingRef" type="CMIF_BookingRef" usage="input"/>
        <Parameter name="_cmifAgent" type="CMIF_EDIBookingRef" usage="input"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="processingCMIFBookingRef" id="9560990e-2c9d-483f-80bc-c720dd630303">
        <source>processingCMIFBookingRef(_ediBookingRefTI : CM_EDIBookingRefTI; _cmifAgent : CMIF_EDIBookingRef; _terminal : CM_Terminal; _allMatchedBRItems : CM_BookingRefItemDict io) : CMIF_BookingRef protected;
/* ---------------------------------------------------------------------------
Created:	29 January 2009	by cnwvu1

Purpose:	
   
Change Date		Who		Reason
08/04/2011		cnwmh5	PAR #27347 - Add cmsEndLoad or endLoad to epilog so that if error occurs it will not leave it in beginLoad state
//02 Jul 2012	cnwrs1		Par 29927 EDI Booking Item replace not working
------------------------------------------------------------------------------*/
vars
	realBookingRef	: CM_BookingRef;
	cmifBookingRef	: CMIF_BookingRef;
	
begin

	beginLoad;
	realBookingRef := _ediBookingRefTI.findRealBookingRef(_terminal);
	cmifBookingRef := _cmifAgent.findAndLoadCMIFBookingRef(_ediBookingRefTI, realBookingRef, _terminal);
	cmifBookingRef.processCMIFItemsFromEDILines(_ediBookingRefTI, _allMatchedBRItems);	
	endLoad;

	return cmifBookingRef;

epilog
	endLoad;				// 08/04/2011 cnwmh5 #27347
end;</source>
        <access>protected</access>
        <Parameter name="_ediBookingRefTI" type="CM_EDIBookingRefTI"/>
        <Parameter name="_cmifAgent" type="CMIF_EDIBookingRef"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_allMatchedBRItems" type="CM_BookingRefItemDict" usage="io"/>
        <ReturnType type="CMIF_BookingRef"/>
    </JadeMethod>
    <JadeMethod name="setEDITIStatusFromErrors" id="3bd522e8-936b-4c84-a1e7-41480cd571bd">
        <source>setEDITIStatusFromErrors(_verifyOnly : Boolean; _passport : CM_Passport);
//
// 22 May 2018	jlgrs1	TFS 36425 SingleLine Booking partial processing not working
//
vars
	error : CM_Error;
	newStatus : Integer;
	oldStatus : Integer;
	passport : CM_Passport;
	ediTI : CM_EDITrackedItem;
	invalid : Boolean;
begin
	on Exception do app.handleDeletedObject(exception, ediTI, invalid); //PAR24233 - cnwsh3 skip invalid voyage objects
	passport := _passport;
	foreach error in passport.allErrorWarnings do
		if error.myUserObject = null or
		   not error.myUserObject.isKindOf(CM_EDITrackedItem) then
			continue;
		endif;
		ediTI := error.myUserObject.CM_EDITrackedItem;
		oldStatus := ediTI.status;
		if invalid then
			continue;
		endif;
		if error.errorCode = Voyage_departed or
		   error.errorCode = CannotDeleteBRItem2 then
			newStatus := CM_EDITrackedItem.EDI_STATUS_SKIP_PROCESSING_X;
		else
			if _verifyOnly then
				if error.warningOnly then
					if oldStatus = CM_EDITrackedItem.EDI_STATUS_VERIFIED_ERRORS then
						newStatus := CM_EDITrackedItem.EDI_STATUS_VERIFIED_ERRORS;
					else
						newStatus := CM_EDITrackedItem.EDI_STATUS_VERIFIED_WARNINGS;
					endif;
				else
					newStatus := CM_EDITrackedItem.EDI_STATUS_VERIFIED_ERRORS;
				endif;
			else
				if error.warningOnly then
					if oldStatus = CM_EDITrackedItem.EDI_STATUS_DBLOADED_ERRORS then
						newStatus := CM_EDITrackedItem.EDI_STATUS_DBLOADED_ERRORS;
					else
						newStatus := CM_EDITrackedItem.EDI_STATUS_DBLOADED;
					endif;
				else
					newStatus := CM_EDITrackedItem.EDI_STATUS_DBLOADED_ERRORS;
				endif;
			endif;
		endif;
		if oldStatus = CM_EDITrackedItem.EDI_STATUS_SKIP_PROCESSING_X then
			newStatus := oldStatus;
		endif;
		app.myTrxUA.trxUpdateEDITIStatus(ediTI, newStatus, passport);
	endforeach;
	if _verifyOnly then
		newStatus := CM_EDITrackedItem.EDI_STATUS_VERIFIED;
		foreach ediTI in self.allEDITrackedItems do
			if ediTI.status = CM_EDITrackedItem.EDI_STATUS_UNPROCESSED then
				app.myTrxUA.trxUpdateEDITIStatus(ediTI, newStatus, passport);
			endif;
		endforeach;
	else
		newStatus := CM_EDITrackedItem.EDI_STATUS_DBLOADED;
		foreach ediTI in self.allEDITrackedItems do
			if ediTI.status = CM_EDITrackedItem.EDI_STATUS_VERIFIED then
				app.myTrxUA.trxUpdateEDITIStatus(ediTI, newStatus, passport);
			endif;
		endforeach;
	endif;
epilog

end;</source>
        <Parameter name="_verifyOnly" type="Boolean"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="shouldAuditProperty" id="89225101-3a18-4b33-810a-23dfa5180a07">
        <source>shouldAuditProperty(_rootClass: Class; _property: Property): Boolean protected;
//
// 11 Aug 2016	cnwrs1	Par 38117 make deleted EDI for finable
//
vars
	propName : String;
begin
	if _property = null then
		return false;
	endif;
	propName := _property.name;
	if propName = CM_EDIDataBookingRef::myEDITrackedItem.name then
		return false;
	endif;
	return inheritMethod(_rootClass, _property);
end;
</source>
        <access>protected</access>
        <Parameter name="_rootClass" type="Class"/>
        <Parameter name="_property" type="Property"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="verifyAll" id="59a58d66-3aea-417f-a302-aeee93fa3efa">
        <updating/>
        <source>verifyAll() updating;
//
// 09 May 2018	jlgrs1	TFS 36425 SingleLine Booking partial processing not working
//
vars
	ediTI : CM_EDITrackedItem;
begin
	if self.allErrorWarnings.size &gt; 0 then
		beginTransaction;
		self.allErrorWarnings.purge();
		foreach ediTI in self.allEDITrackedItems do
			ediTI.setStatus(CM_EDITrackedItem.EDI_STATUS_UNPROCESSED);
		endforeach;
		commitTransaction;
	endif;
	inheritMethod();

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="verifyEDIData" id="d09c9c1b-ff12-41ae-beeb-18a099b63f6c">
        <updating/>
        <source>verifyEDIData(): Integer updating;


vars

begin
	return 0;

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="verifyEDIDataTIForAction" id="e634f898-adcf-4073-8aec-b5df71299ece">
        <source>verifyEDIDataTIForAction(	_ediBookingRefTI : CM_EDIBookingRefTI; 
							_existingBookingRef : CM_BookingRef;
							_allEDITIs : CM_EDITIById;
							_passport : CM_Passport input) protected;
/* ---------------------------------------------------------------------------
Created:	07 January 2009	by cnwvu1

Purpose:	
			CM_EDIBookingRefTI.messageCode = 
				CM_EDITrackedItem.EDI_MODE_ADD;
				CM_EDITrackedItem.EDI_MODE_UPDATE;
				CM_EDITrackedItem.EDI_MODE_DELETE;
			Comes from EDI file
				'BGM+126+232818800+1' - 1 means DELETE
				'BGM+126+232818800+5' - 5 means UPDATE
				'BGM+126+232818800+9' - 9 means ADD
   
Change Date		Who		Reason

------------------------------------------------------------------------------*/
vars
	exception_EDI_alreadyLoaded	: Boolean;
	err							: CM_Error;
	
begin
	
	// when there is EDI action loading mode, the _exisitingBookingRef can be created before, and now it can be updated. All in the same EDI file.
	if _ediBookingRefTI.messageMode = "" then //par 21396 cnwrs1 Oct 2009
	elseif	_ediBookingRefTI.messageMode &lt;&gt; CM_EDITrackedItem.EDI_ACTION_ADD and
	   _ediBookingRefTI.messageMode &lt;&gt; CM_EDITrackedItem.EDI_ACTION_UPDATE and
	   _ediBookingRefTI.messageMode &lt;&gt; CM_EDITrackedItem.EDI_ACTION_DELETE then
		app.raiseCMException1( EDI_Action_Is_Invalid, _ediBookingRefTI.messageMode, ETRow_MessageMode, null );
		return;	// behaviour as before
	endif;
	
	// cnwrl1 09/10/2009 PAR 212444
	if _ediBookingRefTI.messageMode = CM_EDITrackedItem.EDI_ACTION_DELETE and _existingBookingRef = null then
		app.raiseCMWarning2(	Object_DoesNotExist_Too_Delete,// par 22366 cnwrs1 18 Mar 2010 change error to warning
								app.getString( Booking_reference),
								_ediBookingRefTI.id,
								ETRow_Id,
								null, null );
		return;
	endif;
	
	// when status is DB Loaded and booking ref number was edited and changed, there is active EDIData_alreadyLoaded exception
	exception_EDI_alreadyLoaded := false;	// We have to check whether it has been added from previous logs.
	foreach err in _passport.allErrors do
		if err.errorCode = EDIData_alreadyLoaded then
			exception_EDI_alreadyLoaded := true;
			break;
		endif;
	endforeach;
	if exception_EDI_alreadyLoaded then	
		// it doesn't make sense to check and show more exceptions, when there is EDIData_alreadyLoaded (EDI file already loaded, please reload the file etc.)
		return;	// going out saving time and client's nerves and their ability to read quickly a lot of warnings
	endif;
	
end;</source>
        <access>protected</access>
        <Parameter name="_ediBookingRefTI" type="CM_EDIBookingRefTI"/>
        <Parameter name="_existingBookingRef" type="CM_BookingRef"/>
        <Parameter name="_allEDITIs" type="CM_EDITIById"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="verifyEDIDataTIs" id="9b4dbcd7-ac01-444e-b0ce-a15bb50894d0">
        <updating/>
        <source>verifyEDIDataTIs(_passport : CM_Passport input): Integer updating;
// ---------------------------------------------------------------------------
// Created:     14 February 2001 by cnwrs1
//
/* Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 28/9/09      JMH         MES1008 Added density, now on EDI layout
// 21 May 2011	cnwcs5		CCMS SCT 2058/par 27460 - add carrier reference
// adm 160310 				Par 22937 remove bolType
// 02 Feb 2012	cnwrs1		Par 29076 Fix up Hazard Processing in EDI
// 08/03/2012	cnwcs5		Par 29158 - EDI Cutoffs
// 04/04/2012	cnwcs5		par 29326 - unique bookings by operator
// 17/10/2012	cnwcs5		par 30604 - pass voyage to method to find booking
// 21/11/2012	cnwcs5		par 30722 - use exception handler to so jump-to-line works
// 14/12/2012	cnwdap1		PAR #30882 - check whether this update will result in the removal of any partially packed release request lines
//										 Replace WARN_GENERIC with translatable messages
// 06/03/2013	cnwdap1		PAR #31219 Correct error message about removing line from booking - was using wrong booking number
// 27/05/2013	cnwdap1		PAR #31596 added freight forwarder parameter to setProxy method
// 24/06/2013 	cnwmh5		PAR #31614 Add checking for cargo requiring subtype but don't have any
// 03/07/2013	cnwdap1		PAR #31275 Cross-check cargo subtype operator and booking operator
// 19/8/2013    cnwgb1      PAR 31972  Reject bad Voyage codes as per Multiline Bookings
// 08/12/2014   cnwdb2		PAR #35364
// 04/03/2015 	cnwmh5		Transient Leak
//08 Oct 2015	cnwrs1		Par 36863 - make EDI consistant times when refreshing progress bar
// 13 May 2016	cnwns1		TFS 488 - Multi Timezone Support
// 08 May 2018	jlgrs1		TFS 36425 SingleLine Booking partial processing not working
// 05 Jun 2018	jlgrs1		TFS 39018 SNO Cargo Operator in COPRAR
// 14/09/2018 	JLGNS1		Bug 40384: POL - [Fwd: ##RE-8672## : Bookings for operator not on that Voyage]
   12 Jun 2019	jlgka1		TFS 44416 PNL Loading Default Cargo Type Settings via EDI
   03 Sep 2019 	jlgka1 		TFS 45332 	STWR - Better Forms and Interfaces for EDI Module
   02 Oct 2020  cnwma1  	ChangeRequest 50112: ASPA - GCI Stevedores
   20 Oct 2020	jlgmd1		TFS 50204	Refactor progress updates to superclass method
============================================================================*/
vars
	checkID						: String;		// cnwrl1 12/02/2010 PAR 22346
	pxyBookingRef,
	bookingRef					: CM_BookingRef;
	ediTI						: CM_EDITrackedItem;
	releaseEDIBookingRef,
	existingEDIbookingRef,
	ediBookingRef				: CM_EDIBookingRefTI;
	ignoreWarnings				: Boolean;
	tmpPorts					: StringArray;
	tmpHazards					: ObjectArray;
	objectArray					: ObjectArray;
	errorWarningLimit			: Integer;
	terminal					: CM_Terminal;
	totalTIs, tiCount			: Integer;
	passport					: CM_Passport;
	consignee,
	consignor					: CM_ConsigneeConsignor;
	product						: CM_Product;
	dischargePort, 
	destinationPort 			: String;
	iteratorObj					: Iterator;
	breleaseObj					: CM_BulkRelease;
	chkDateTime 				: TimeStamp;
	found						: Boolean;
	voyage						: CM_Voyage;
	existingEDIbookingRefs,
	releases					: ObjectLongNameDict;
	misVersionBookingRef 		: Boolean; //ccms 1855 cnwrs1 sept 2009
	tmpReleaseRequest			: CM_BulkRelease;
	allReleaseRequests			: CM_BulkReleaseSet;			// PAR #30882
	release						: CM_BulkRelease;				// PAR #30882
	child						: CM_ReserveDetail;				// PAR #30882
	releaseLine					: CM_ReserveSelection;			// PAR #30882
	iter						: Iterator;						// PAR #30882
	checkEDITI					: CM_EDITrackedItem;			// PAR #30882
	checkEDIBookRef				: CM_EDIBookingRefTI;			// PAR #30882
	foundReleaseLine			: Boolean;						// PAR #30882
	raisedError					: Boolean;						// PAR #31219
	lastBooking					: String;						// PAR #31219
	
	releaseVoyage				: String;			//cnwmc5 - 4 Sep 2015 - PAR 36802
	progressTS 					: TimeStamp;
	newStatus 					: Integer;
	operator 					: CM_Operator;		//Bug 40384
	stevedore                   : CM_Stevedore;
begin 
	passport := _passport;

	// Arm our base exception handlers
	on Exception do validationExceptionHandler(exception, app.myPassport);

	progressTS := app.actualTimeServer();		// 13 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	terminal := self.getMyTerminal();
	
	if terminal = null then
		app.raiseCMException1(Err_InvalidTerminal, null, null, null);
	endif;
	
	errorWarningLimit 		:= terminal.getConfig(EDIVerificationErrorLimit).Integer;
	misVersionBookingRef 	:= terminal.getConfig(ProcessMISVersionBkRef).Boolean; //cnwrs1 ccms 1855 Sept 2009
	
	create objectArray transient;
	create tmpPorts transient;
	create tmpHazards transient;
	create pxyBookingRef transient;	// par 29326
	create releases transient;
	create existingEDIbookingRefs transient;
	create allReleaseRequests transient;		// PAR #30882
	
	ignoreWarnings := false;
	
	passport.clearErrorsWarnings();
	app.setContinueCMExceptions(true);
	
	chkDateTime.setDate('01/01/3000'.Date);		// PAR 18030  

	totalTIs := self.allEDITrackedItems.size();
	tiCount := null;
	self.updateProgress(progressTS, "Verifying cargo details", totalTIs, tiCount, true, passport);

	// par 30722 - arm exception handler so that jump-to-line works
	on CM_Exception do self.xHandlerCMExceptionUserObject (exception, ediTI);
	
	foreach ediTI in self.allEDITrackedItems do
		ediBookingRef 	:= ediTI.CM_EDIBookingRefTI;
		tiCount 		:= tiCount + 1;
		
		self.updateProgress(progressTS, "Verifying cargo details", totalTIs, tiCount, false, passport);

		tmpHazards.purge();
		ediBookingRef.getProxyHazards(ediBookingRef.imCodes, tmpHazards, false);				//false); 		// 26/02/2013 cnwmh5 #31192   // 17/03/2014 cnwmh5 #33648
		
		consignee		:= ediBookingRef.getConsign(ediBookingRef.consignee);
		consignor		:= ediBookingRef.getConsign(ediBookingRef.consignor);
		stevedore       := ediBookingRef.getStevedore(ediBookingRef.stevedore); //04.11.2020 cnwma1 TFS #50112
		
		if consignor = null and ediBookingRef.consignor &lt;&gt; null then
			app.raiseCMWarning2(Consignor_Not_Matched, ediBookingRef.consignor, ediBookingRef.id, ETRow_Consignor, null, self);		// PAR #30882
		endif;
		
		if consignee = null and ediBookingRef.consignee &lt;&gt; null then
			app.raiseCMWarning2(Consignee_Not_Matched, ediBookingRef.consignee, ediBookingRef.id, ETRow_Consignee, null, self);		// PAR #30882
		endif;
		
		//02.10.2020 cnwma1 TFS #50112
		if stevedore = null and ediBookingRef.stevedore &lt;&gt; null then
			app.raiseCMWarning2(Stevedore_Not_Matched, ediBookingRef.stevedore, ediBookingRef.id, ETRow_Stevedore, null, self);		// PAR #30882
		endif;
		
		if ediBookingRef.product &lt;&gt; null then
			//jlgka1 TFS 44416 --&gt;
			product := ediBookingRef.getProduct(ediBookingRef.operatorCode, ediBookingRef.product);			
			//jlgka1 TFS 44416 &lt;--
		endif;
		
		if product = null then
			if ediBookingRef.product &lt;&gt; null then
				app.raiseCMException2(ERR_EDI_BR_FIELD,ediBookingRef.product, ETRow_Product, null, null);
			endif;
		endif;
				
		// 24/06/2013 cnwmh5 #31614
		if ediBookingRef.cargoType &lt;&gt; null then
			if app.myRoot.allCargoTypesById[ediBookingRef.cargoType].isSubCargoTypeRequired and ediBookingRef.product = null then 					
				app.raiseCMException(Unspecified_product,app.getErrorString(Unspecified_product),null);
			endif;
		endif;
		
		// PAR #31275 Check that the operator from the EDI booking line matches the operator 				// PAR #31275
		// (if any) on the cargo sub type																	// PAR #31275
		if product &lt;&gt; null and ediBookingRef.operatorCode &lt;&gt; null then										// PAR #31275
			if product.myOperator &lt;&gt; null and product.myOperator.code &lt;&gt; ediBookingRef.operatorCode then	// PAR #31275
				app.raiseCMException3(CargoSubtype_Operator_Mismatch, ediBookingRef.product, 				// PAR #31275
										product.myOperator.code, ediBookingRef.operatorCode, null, null);	// PAR #31275
			endif;																							// PAR #31275
		endif;																								// PAR #31275
		
		// Verify the port names PAR 17342
		destinationPort := ediBookingRef.destinationPort;
		
		if destinationPort.length &gt; pxyBookingRef.destinationPort.maxLength then
			app.raiseCMException2(ERR_EDI_BR_FIELD, destinationPort, ETRow_DestinationPort, null, null);
			destinationPort := destinationPort[1:pxyBookingRef.destinationPort.maxLength];
		endif;
		
		dischargePort := ediBookingRef.dischargePort;
		
		if dischargePort.length &gt; pxyBookingRef.dischargePort.maxLength then
			app.raiseCMException2(ERR_EDI_BR_FIELD, dischargePort, ETRow_DischargePort, null, null);
			dischargePort := dischargePort[1:pxyBookingRef.dischargePort.maxLength];
		endif;
		
		checkID	:= ediBookingRef.getId( misVersionBookingRef );
		
		if checkID.length &gt; 17 then
			app.raiseCMException3( ERR_STRING_TO_LONG, app.getErrorString(Id), '17', ETRow_Id, null, null );
		endif;
		
		pxyBookingRef.setProxy( checkID,					
						ediBookingRef.cargoType,//cargoType,
						null,//ediTI.clean.Boolean,
						ediBookingRef.commodity,
						null,	// RJS - need to determine this : consignorRef
						null,//ediTI.description.String,
						destinationPort,
						dischargePort,
						null,
						tmpPorts,
						tmpHazards,
						null,//ediTI.humidity.Integer,
						null,//ediTI.inspected.Boolean,
						ediBookingRef.isoType.String,
						consignor,
						consignee,
						app.myRoot.allOperators[ediBookingRef.operatorCode.String],
//						terminal.lookupVoyage(ediBookingRef.voyageCode.String, null, false),	// cnwrl1 09/06/2010 PAR 24299 - what it was
						terminal.lookupVoyage(ediBookingRef.getVoyageCode().String, null, false),
						ediBookingRef.number.Integer,
						//ediBookingRef.quantity,		// 03/03/2014 cnwar2 #33016
						ediBookingRef.bookingRemarks, //booking remakrs
						ediBookingRef.remarks,
						ediBookingRef.temperature,
						null,//ediBookingRef.ventilation,
						ediBookingRef.height, //height
						ediBookingRef.length, //length
						ediBookingRef.width, //width
						null,//heightString
						null,//lengthstring
						null,//widthstring
						null, //typeString
						ediBookingRef.density, //density	// MES1008 JMH 28/9/09
						ediBookingRef.volume, //volume
						ediBookingRef.productQuantity,		// 03/03/2014 cnwar2 #33016
						ediBookingRef.weight,
						ediBookingRef.volume,	//Cubic Metres
						terminal,
						product,
						false,
						ediBookingRef.isStockBookingRef,
						null, 
						null,
						ediBookingRef.shippingRef,
						null, 					// Carrier reference - par 27460
						null, 
						null, 
						null, 
						null,
						null, 
						null, 
						null, 
						null, 
						null, 
						null, 
						null, 
						null, 
						null, 
						null, 
						null, 
						null, 
						null, 
						false, 
						null, 
						null,
						null, 		// customsAgent	// cnwrl1 18/02/2010 PAR 22393
						null, 		// ediVoyageCode
						null, 		// ediVesselName //cnwrs1 CCMS 1882 03 June 2010
						null,	//direct delivery
						null,	// freight forwarder	// PAR #31596
						null, 	//carrier
						null    //Stevedore //02.10.2020 cnwma1 TFS #50112
						);
                        
        // cnwgb1 PAR 21972 19.8.2013 Reject bad Voyage codes as per Multiline Bookings
        if ediBookingRef.getVoyageCode() = null then
            // get the terminals null voayage
            voyage	:= terminal.getNullVoyage;
        else
            // attempt to find the voyage but not archived ones.
            voyage	:= terminal.lookupVoyage(ediBookingRef.getVoyageCode(), null, false);
        endif;
        
        if voyage = null then
            if ediBookingRef.messageMode &lt;&gt; CM_EDITrackedItem.EDI_ACTION_DELETE then //PAR 32447 cnwgb1 9.9.2013
                app.raiseCMException2(Voyage_DoesNotExist_4_Terminal,
                                        ediBookingRef.getVoyageCode().trimBlanks,
                                        terminal.code,
                                        ETRow_VoyageCode,
                                        ediBookingRef);
            endif;
        else			
			//epr par 37090 23/10/15 CCMS 2538 EDI Admin Improvements
			if  self.getMyTerminal.getConfig(EdiAddVoyageDepartError).Boolean and voyage.hasDeparted and not voyage.isNullVoyage then
				app.raiseCMException1(Voyage_departed,ediBookingRef.getVoyageCode,"Voyage Code", self);
			endif;
				
			operator := app.myRoot.allOperators[ediBookingRef.operatorCode];										//Bug 40384
			if operator &lt;&gt; null then																				//Bug 40384
				if not voyage.allOperators.includes(operator)
				and not voyage.isNullVoyage	//19 May 2021	NDL	TFS 50897
				then													//Bug 40384
					app.raiseCMException3 (VB_VALID_VOY,operator.code,voyage.code, self.class.name, null, null);	//Bug 40384
				endif;																								//Bug 40384
			endif;																									//Bug 40384
			
			// par 29158 - March 2012
			self.checkEDICutoff (ediBookingRef.getVoyageCode, ediBookingRef.getOperatorCode, ediBookingRef);	// par 29158
		endif;																									// par 29158

		// find the existing booking (if any) and then decide whether to create or update
		bookingRef := terminal.getBookingReference (ediBookingRef.operatorCode, ediBookingRef.id, voyage); 		// par 30604 october 2012 /par 29326 - april 2012

		if bookingRef = null then																				// par 29326 - april 2012
			pxyBookingRef.validateForCreate(passport, ediBookingRef, null);
		else
			pxyBookingRef.validateForUpdate(passport, ediBookingRef, null);
		endif;
		
		
		if bookingRef &lt;&gt; null then
			if bookingRef.dischargePort &lt;&gt; pxyBookingRef.dischargePort then																	// PAR #30882
				app.raiseCMWarning3(Discharge_Port_Differs, pxyBookingRef.bookingReference, pxyBookingRef.dischargePort, bookingRef.dischargePort, 		// PAR #30882
												ETRow_DischargePort, null, self);																		// PAR #30882
			endif;
			
			if bookingRef.voyageCode &lt;&gt; pxyBookingRef.voyageCode then																	// PAR #30882
				app.raiseCMWarning3(Voyage_Code_Differs, pxyBookingRef.bookingReference, pxyBookingRef.voyageCode, bookingRef.voyageCode, 				// PAR #30882
												ETRow_VoyageCode, null, self);																			// PAR #30882
			endif;
			
		else
			if ediBookingRef.myBookingRef &lt;&gt; null then
				app.raiseCMException1(EDIData_alreadyLoaded, null,null, null);
			endif;
		endif;
		
		self.verifyEDIDataTIForAction(ediBookingRef, bookingRef, self.allEDITrackedItems, _passport);	//Par 18495. Jan 2009
		
		if  ediBookingRef.isStockBookingRef = true then
			if ediBookingRef.product = null then
				if ediBookingRef.cargoType = null then 
				//	app.raiseCMException1(REQUIRED_FIELD, app.getErrorString(Product) ,null, null);
					app.raiseCMException1(Input_required_field_Required, app.getErrorString(Product) ,null, null);
				endif;
			endif;
		endif;
		
		// Moved from above and changed PAR 18030  
		// If we have a Release Number in the EDI then we need some extra checking:
		// 1. the Operator must exist
		// 2. the Release Request must be validated
		
		// Check there is a one to one relationship between booking ref and release number
		existingEDIbookingRef := existingEDIbookingRefs[ediBookingRef.id].CM_EDIBookingRefTI;
		
		if existingEDIbookingRef &lt;&gt; null then
			if existingEDIbookingRef.releaseRequestNumber &lt;&gt; ediBookingRef.releaseRequestNumber then
				app.raiseCMException2(Already_exists35364, ediBookingRef.id,existingEDIbookingRef.releaseRequestNumber, ETRow_ReleaseRequest, null); //cnwdb2 PAR35364
			endif;
		else
			existingEDIbookingRefs[ediBookingRef.id] := ediBookingRef;	// need to check existingEDIbookingRefs - it is always = null
		endif;
		
		if ediBookingRef.releaseRequestNumber &lt;&gt; null then
			
			// If an associated release request exists, the release number should be the same,
			// otherwise booking will be updated while the release request not - data will not match between this pair. PAR 17464 Nov 2009
			if (bookingRef &lt;&gt; null) and (not bookingRef.allReleaseRequests.isEmpty() ) then
				tmpReleaseRequest := bookingRef.allReleaseRequests.first;	// Nelson Warehousing - always one to one relationship
				if ediBookingRef.releaseRequestNumber &lt;&gt; tmpReleaseRequest.code then
					app.raiseCMException2(BookingHasAlreadyReleasRequest, ediBookingRef.id, tmpReleaseRequest.code, ETRow_ReleaseRequest, null);
				endif;
				// PAR #30882 remember this bulk release for checking later
				if not allReleaseRequests.includes(tmpReleaseRequest) then
					allReleaseRequests.add(tmpReleaseRequest);
				endif;
			endif;
			
			releaseEDIBookingRef := releases[ediBookingRef.releaseRequestNumber].CM_EDIBookingRefTI;
			
			if releaseEDIBookingRef &lt;&gt; null then
				if releaseEDIBookingRef.id &lt;&gt; ediBookingRef.id then
					app.raiseCMException2(Already_exists_Bulk_BookRef, ediBookingRef.releaseRequestNumber, releaseEDIBookingRef.id, ETRow_ReleaseRequest, null);// cnwdb2	PAR 35364
				endif;
			else
				releases[ediBookingRef.releaseRequestNumber] := ediBookingRef;
			endif;
			
			found := false;
			
			if bookingRef &lt;&gt; null then
				foreach breleaseObj in bookingRef.allReleaseRequests do
					if breleaseObj.code = ediBookingRef.releaseRequestNumber then
						found := true;
					endif;
				endforeach;
			endif;
			
			if (not found) then
				iteratorObj		:=	terminal.allBulkReleasesByCodeDate.createIterator();
				// allBulkReleasesByCodeDate collection is keyed descending on date 
				terminal.allBulkReleasesByCodeDate.startKeyGeq(ediBookingRef.releaseRequestNumber, chkDateTime, iteratorObj);
				
				while iteratorObj.next(breleaseObj) do
					if breleaseObj.code &lt;&gt; ediBookingRef.releaseRequestNumber then
						break;
					else
						terminal.validateBulkReleaseNumber(breleaseObj, 'Bulk Release');
						break;
					endif;
				endwhile;
				delete iteratorObj;
			endif;
		endif;
	endforeach;
	
	self.updateProgress(progressTS, "Verifying cargo details", totalTIs, tiCount, true, passport);
	
	// PAR #30882 Error Checking
	// 1. If one or more product lines have been removed from a packing request, 
	//	  but some of that product type has been packed, raise an error
	// 2. If the packing request is not complete, and the voyage is changing, 
	//	  and a line has been added to the request, raise an error
	// PAR #31219 only do these two checks if terminal config item set
	if terminal.getConfig(RemItemsIfBookItemDel).Boolean then
		tiCount := 0;
		self.updateProgress(progressTS, "Verifying cargo details (part 2)", totalTIs, tiCount, true, passport);
		
		foreach ediTI in self.allEDITrackedItems do
			tiCount := tiCount + 1;
			self.updateProgress(progressTS, "Verifying cargo details (part 2)", totalTIs, tiCount, false, passport);
			
			ediBookingRef := ediTI.CM_EDIBookingRefTI;
			if ediBookingRef.releaseRequestNumber = null then
				continue;
			endif;
			foundReleaseLine := false;
			if ediBookingRef.releaseRequestNumber &lt;&gt; lastBooking then		// PAR #31219
				raisedError := false;										// PAR #31219
			endif;															// PAR #31219
			foreach release in allReleaseRequests where release.code = ediBookingRef.releaseRequestNumber do
				foreach child in release.allReservePackingChildren do
					releaseLine := child.CM_ReserveSelection;
					if releaseLine.isEDIMatchForISOTypeProduct(ediBookingRef) then
						foundReleaseLine := true;
					endif;
					
					// if this child has been packed, does it still have a matching entry in the EDI data?
					if not releaseLine.allTrackedItemsReleased.isEmpty then
						iter := self.allEDITrackedItems.createIterator;
						found := false;
						while iter.next(checkEDITI) do
							checkEDIBookRef := checkEDITI.CM_EDIBookingRefTI;
							//if releaseLine.isEDIMatchForISOTypeProduct(checkEDIBookRef) then																				// PAR #31219
							if releaseLine.isEDIMatchForISOTypeProduct(checkEDIBookRef) and ediBookingRef.releaseRequestNumber = checkEDIBookRef.releaseRequestNumber then	// PAR #31219
								found := true;
								break;
							endif;
						endwhile;
						delete iter;
						if not found and not releaseLine.myReserveHeader.isComplete then
							// PAR #31219 correct error message - was showing the last booking number from the EDI file instead of the actual booking number in error
							if not raisedError then																													// PAR #31219
								//app.raiseCMException2(Booking_Remove_Packed_Line, checkEDIBookRef.releaseRequestNumber, releaseLine.myProduct.code, null, null);	// PAR #31219
								app.raiseCMException2(Booking_Remove_Packed_Line, ediBookingRef.releaseRequestNumber, releaseLine.myProduct.code, null, null);		// PAR #31219
								raisedError := true;																												// PAR #31219
							endif;																																	// PAR #31219
						endif;
					endif;
				endforeach;
				if not foundReleaseLine then
					// we have a line in the file that isn't in an existing incomplete release request
					// has the voyage changed? - if so, raise an exception
					if release.myVoyage &lt;&gt; null then													//cnwmc5 - 4 Sep 2015 - PAR 36802
						releaseVoyage := release.myVoyage.code;											//cnwmc5 - 4 Sep 2015 - PAR 36802
					endif;																				//cnwmc5 - 4 Sep 2015 - PAR 36802
					if not release.isComplete and releaseVoyage &lt;&gt; ediBookingRef.getVoyageCode then		//cnwmc5 - 4 Sep 2015 - PAR 36802
						app.raiseCMException4(Booking_AddLine_ChgVoyage, ediBookingRef.releaseRequestNumber, ediBookingRef.product, releaseVoyage, ediBookingRef.getVoyageCode, null, null);
					endif;
				endif;
			endforeach;
			lastBooking := ediBookingRef.releaseRequestNumber;		// PAR #31219
		endforeach;
		
		self.updateProgress(progressTS, "Verifying cargo details (part 2)", totalTIs, tiCount, true, passport);
	endif;
	// PAR #30882 end of error checking
	self.setEDITIStatusFromErrors(true, _passport);
	newStatus := self.getStatusAfterVerifyOrDBLoad(true, _passport);
	app.myTrxUA.trxSetEDIDataStatusAfterVerify(self, newStatus);	// par 27392 cnwrs1 14 Apr 2011
	return passport.allErrorWarnings.size();
epilog
	if objectArray &lt;&gt; null then
		objectArray.purge();
		delete objectArray;
	endif;
	
	if tmpHazards &lt;&gt; null then
		tmpHazards.purge();
		delete tmpHazards;
	endif;
	
	delete tmpPorts;
	delete pxyBookingRef;
	delete releases;
	delete existingEDIbookingRefs;
	delete iteratorObj;
	delete iter;
	delete allReleaseRequests;			// PAR #30882
end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="verifyRaiseEDIActionException" id="8e82d3d5-2b0d-49d5-af26-de6bc73a48cf">
        <source>verifyRaiseEDIActionException(	_err : Boolean; _xlatException : Integer; 
								_par1,_par2,_attr : String; 
								_passport : CM_Passport ) protected;
/* ---------------------------------------------------------------------------
Created:	08 January 2009	by cnwvu1

Purpose:	Raises an error or a warning, avoiding message duplicates.
			Can be caused by EDI multi item booking refs.
   
Change Date		Who		Reason

------------------------------------------------------------------------------*/
vars
	currentErrString: String;
	err				: CM_Error;
	
begin

	currentErrString := app.getErrorString2(_xlatException, _par1, _par2);
	
	foreach err in _passport.allErrorWarnings do
		if err.errorCode = _xlatException then
			if err.text.pos(currentErrString,1) &gt; 0 then
				return;	// the error already exists
			endif;
		endif;
	endforeach;
	
	if _err then
		app.raiseCMException2(_xlatException, _par1, _par2, _attr, null);
	else
		app.raiseCMWarning2(_xlatException, _par1, _par2, _attr, null, self);
	endif;

end;</source>
        <access>protected</access>
        <Parameter name="_err" type="Boolean"/>
        <Parameter name="_xlatException" type="Integer"/>
        <Parameter name="_par1" type="String"/>
        <Parameter name="_par2" type="String"/>
        <Parameter name="_attr" type="String"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
</Class>
