    <JadeMethod name="ctrlYardAlloc_showPopupMenu" id="7b4d7e7e-341b-43e4-b17c-850c08f81f9e">
        <controlMethod name="CMUI_YardAllocationControl::showPopupMenu"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>ctrlYardAlloc_showPopupMenu(_controlObj: Window input; _xPos: Real; _yPos: Real) updating;
// --------------------------------------------------------------------------------
// Created:		22 May 2006 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	actualXPos	: Real;
	actualYPos	: Real;
	
begin
	actualXPos	:=	_xPos;
	actualYPos	:=	_yPos;
	
	self.cnEcGetRelativePosition(_controlObj, actualXPos, actualYPos);
	self.popupMenu(mnuGroup, actualXPos.Integer, actualYPos.Integer);

end;</source>
