    <JadeMethod name="initFromUserWindow" id="8a63b30f-48dd-4bd8-a93f-e3a51b196729">
        <updating/>
        <source>initFromUserWindow(_userWindow: CM_UserWindow) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
06 August 2009	cnwml2	Initial creation

*/

vars
	xml : String;
begin
	inheritMethod(_userWindow);
	xml := _userWindow.xmlInfo.cnEcGetTagValueOfName(self.tblReceivals.XMLTag_Table &amp; self.tblReceivals.name);
	if xml &lt;&gt; null then
		self.xmlStringTblReceivals := global.formatAsXMLPrefix(self.tblReceivals.XMLTag_Table &amp; self.tblReceivals.name) &amp;  xml &amp;
								  global.formatAsXMLSuffix(self.tblReceivals.XMLTag_Table &amp; self.tblReceivals.name);
	endif;
	
	xml := _userWindow.xmlInfo.cnEcGetTagValueOfName(self.tblReleases.XMLTag_Table &amp; self.tblReleases.name);
	if xml &lt;&gt; null then
		self.xmlStringTblReleases := global.formatAsXMLPrefix(self.tblReleases.XMLTag_Table &amp; self.tblReleases.name) &amp;  xml &amp;
								  global.formatAsXMLSuffix(self.tblReleases.XMLTag_Table &amp; self.tblReleases.name);
	endif;

	self.tblExtraInfo.visible := _userWindow.xmlInfo.cnEcGetTagValueOfName(XMLTag_ShowMacro).Boolean;

epilog

end;</source>
