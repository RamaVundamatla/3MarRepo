			pCargoType.createOpsViewEWSActivity(BGP_OpsViewWSRequest.OPS_ACTION_DELETE, BGP_OpsViewWSRequest.OPS_TYPE_CARGOTYPE, pCargoType);
		endif;
		//&lt;&lt;--
