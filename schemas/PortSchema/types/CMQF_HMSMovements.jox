    <JadeMethod name="addInPortNoRecentMovement" id="d4797765-478e-418b-84a9-994aef279c2b">
        <source>addInPortNoRecentMovement( _terminal : CM_Terminal; _collection: Collection input );

/*

Purpose:			

Parameters:		 To optionally ensure that any vessel in port with no recent movement is still listed in the report.	

Return Value:		


Date		Who		Reason
24 February 2012	cnwndl1	Initial creation	Par 29121

*/

vars

//	passport : CM_Passport;
//	monitor : CMIF_Monitor;
//	parent : Object;
//	prop : Property;
//	obj : Object;
//	menuUserDtl : CM_MenuUserDtl;
//	queryRep : CM_QryReportUser;

	allCurrentVoyages : CM_VoyageSet;
	voyage : CM_Voyage;
	latestMovement : HMS_Movement;
	today : Date;
	iter : Iterator;

begin

	
	/*
	// Yuk, Yuk, Yuk, Couldn't do a reorg to allow this functionality to be option, as it was being back patched into 7.9.2.
	//will be removed in 8.1.1 and activated from a local boolean....
	passport := app.myPassport;
	if passport = null then
		return;
	endif;
	monitor := passport.myCMIFMonitor;
	if monitor = null or monitor.myParent = null then
		return;
	endif;
	parent :=  monitor.myParent;
	if parent = null or parent.class.getPropertyInHTree("myMenuEntity") = null  then
		return;
	endif;
	
	// the parent is actually a 'CMUI_ReportRunner' which is declared in a sub schema...
	obj := parent.getPropertyValue("myMenuEntity").Object;	
	if obj = null or not obj.isKindOf(CM_MenuUserDtl) then
		return;
	endif;
	
	menuUserDtl := obj.CM_MenuUserDtl;
	if menuUserDtl.myMenuDtl = null or not menuUserDtl.myMenuDtl.isKindOf(CM_QryReportUser) then
		return;
	endif;
	
	queryRep := menuUserDtl.myMenuDtl.CM_QryReportUser;
	if queryRep = null or not queryRep.jrwReportName.includes("CM_VesselsInPortSummary") then
		return;
	endif;
	*/
	
	if not self.movementIncludeInPort then
		return;
	endif;
	
	today := app.actualTimeServer.Date;
	create allCurrentVoyages transient;
	
	if self.movementDateFrom &lt;= today and today &lt;= self.movementDateTo then
		_terminal.getAllVoyagesInPort(allCurrentVoyages, true, app.myPassport);
	else
		iter := _terminal.allVoyagesByArrivalDTCode.createIterator;
		while iter.next( voyage ) do
			if not voyage.arrivedDT.date.isValid then
				continue;
			endif;
			if voyage.arrivedDT.date &gt; self.movementDateTo then
				// arrived after our period. (no more to check)
				break;
			endif;
			if voyage.displayOption = VoyageDisplayNever then
				continue;
			endif;	
			if voyage.isCancelled then  //jlier1 TFS51963 5/10/21
				continue;
			endif;
			// this was a voyage that arrived before or during our target period
			if voyage.departedDT.date = null or voyage.departedDT.date &gt;= self.movementDateFrom then
				// hasn't left yet, or left after the start of our target period. (so was here at some stage during the period)
				allCurrentVoyages.add(voyage);
			endif;
		endwhile;
		delete iter;
	endif;
	
	foreach voyage in allCurrentVoyages discreteLock do
		latestMovement := voyage.getLatestMovement();
		if latestMovement &lt;&gt; null then
			if not _collection.includes( latestMovement ) then
				_collection.add( latestMovement );
			endif;
		endif;
	endforeach;
	
epilog

	delete iter;

end;</source>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_collection" type="Collection" usage="input"/>
    </JadeMethod>
    <JadeMethod name="filterMoves" id="26d2864e-80b1-4a1e-ac22-0134fea2dbca">
        <updating/>
        <source>filterMoves(_collection: Collection input; _passport: CM_Passport) updating;

vars
	iterMove,
	iterMoveArc		: Iterator;
	harbour			: HMS_Harbour;
	moveFromDT,
	moveToDT		: TimeStamp;
	move			: HMS_VoyageMovement;
	terminal		: CM_Terminal;
	repHarbours		: HMS_HarbourByCodeDict;
	breakOut		: Boolean;
begin

//	harbour := HMS_Harbour.firstInstance;
	moveFromDT.setDate(self.movementDateFrom);
	moveFromDT.setTime(self.movementTimeFrom);
	moveToDT.setDate(self.movementDateTo);
	moveToDT.setTime(self.movementTimeTo);
	
	create repHarbours transient;
		
	foreach terminal in self.allTerminals do
		delete iterMove;
		delete iterMoveArc;
		
		harbour := terminal.myHarbour;
		if harbour = null
		or repHarbours.includes(harbour) then
			//dunnit
			continue;
		endif;
		repHarbours.add(harbour);
		
		iterMove := harbour.allVoyageMovements.createIterator();
		harbour.allVoyageMovements.startKeyGeq(moveFromDT, iterMove);
		while iterMove.next(move) do
			if move.occursOnDTNEW &gt; moveToDT then
				break;
			endif;
			
			if self.checkStatusIncludesObject(move, _passport, breakOut) then
				if not _collection.includes(move) then
					_collection.add(move);
				endif;
			endif;
			
		endwhile;
		
		iterMoveArc := harbour.allVoyageMovementsArchived.createIterator();
		harbour.allVoyageMovementsArchived.startKeyGeq(moveFromDT, iterMoveArc);
		while iterMoveArc.next(move) do
			self.numSearched := self.numSearched + 1; 
			if move.occursOnDTNEW &gt; moveToDT then
				break;
			endif;
						
			if self.checkStatusIncludesObject(move, _passport, breakOut) then
				if not _collection.includes(move) then
					self.numFound := self.numFound + 1;
					_collection.add(move);
				endif;
			endif;	
		endwhile;
		
		self.addInPortNoRecentMovement( terminal, _collection );	//24 Feb 2012 NDL	Par 29121
		
	endforeach;
	
	
epilog
	delete iterMove;
	delete iterMoveArc;
	delete repHarbours;
end;</source>
        <Parameter name="_collection" type="Collection" usage="input"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="filterObjects" id="db1d6c17-010e-41a0-abbd-cf3fc3ac116f">
        <updating/>
        <source>filterObjects(_collection: Collection input; _passport: CM_Passport) updating;
// -------------------------------------------
// Created 25 February 2005 by cnwdvb1
// -------------------------------------------
vars

	startTs,
	endTs		: TimeStamp;
	audit		: CMIF_HMS_AuditEnquiry;
	terminal	: CM_Terminal;
	passport	: CM_Passport;

begin

	inheritMethod(_collection, _passport);
	passport := _passport;
	
	startTs.setDate(self.movementDateFrom);
	startTs.setTime(self.movementTimeFrom);

	endTs.setDate(self.movementDateTo);
	endTs.setTime(self.movementTimeTo);
	
	
	if not startTs.isValid or not endTs.isValid then
		return;
	endif;
	
	create audit transient;
	
	audit.startDateTime	:= startTs;
	audit.endDateTime	:= endTs;
	
	audit.allSelectedTransactionTypes.add(TRANS_TYPE_EditMovement);
	audit.allSelectedTransactionTypes.add(TRANS_TYPE_AddMovement);
		
	foreach terminal in self.allTerminals do
		terminal.getHMSTransForAuditEnquiry(audit, passport);
	endforeach;
	
	audit.allFoundTransactions.copy(_collection);

epilog

	delete audit;	
end;</source>
        <Parameter name="_collection" type="Collection" usage="input"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="a4f2bb97-5805-4f2e-a4c7-72e0bbb4ddf7">
        <source>getDisplayStringForAttribute(_attrName: String; _getCalculatedDate: Boolean): String;
// ---------------------------------------------------------------------------
// Created:     19/07/2010 cnwdz2	
//
// Purpose:     PAR24513 extend the current existing getDisplayStringForAttribute method to return an object's oid.		 
// ----------   ----------  --------------------------------------------------
vars
	runDate	: Date;
	oid     : String;
begin
	return self.getOIDAndDescForAttribute(_attrName, _getCalculatedDate, oid);
	/*
	runDate := app.actualTimeServer().date;

	// Arrival
	if _attrName = ETRow_MovementDateFrom then
		if _getCalculatedDate then
			return self.setDateFromTemplate(self.movementDateFromType, self.movementDateFromFactor, runDate).shortFormatJMT();
		else
			return self.getTemplateDateStr(self.movementDateFromType, self.movementDateFromFactor);
		endif;
	endif;
	
	if _attrName = ETRow_MovementDateTo then
		if _getCalculatedDate then
			return self.setDateFromTemplate(self.movementDateToType, self.movementDateToFactor, runDate).shortFormatJMT();
		else
			return self.getTemplateDateStr(self.movementDateToType, self.movementDateToFactor);
		endif;
	endif;
	
	if _attrName = ETRow_MovementTimeFrom then
		return self.movementTimeFrom.shortFormatJMT();
	endif;
	
	if _attrName = ETRow_MovementTimeTo then
		return self.movementTimeTo.shortFormatJMT();
	endif;
// can use ETRow_ArrivalsDateFrom in some entdefs 	
	if _attrName = ETRow_ArrivalsDateFrom then
		if _getCalculatedDate then
			return self.setDateFromTemplate(self.movementDateFromType, self.movementDateFromFactor, runDate).shortFormatJMT();
		else
			return self.getTemplateDateStr(self.movementDateFromType, self.movementDateFromFactor);
		endif;
	endif;
	
	if _attrName = ETRow_ArrivalsDateTo then
		if _getCalculatedDate then
			return self.setDateFromTemplate(self.movementDateToType, self.movementDateToFactor, runDate).shortFormatJMT();
		else
			return self.getTemplateDateStr(self.movementDateToType, self.movementDateToFactor);
		endif;
	endif;
	
	
	return inheritMethod(_attrName, _getCalculatedDate);
*/
end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_getCalculatedDate" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getOIDAndDescForAttribute" id="8f581cd0-606e-4699-b1a4-bb6994a181c3">
        <source>getOIDAndDescForAttribute(_attrName: String; _getCalculatedDate: Boolean; _oid : String output): String;
// ---------------------------------------------------------------------------
// Created:     19/07/2010 cnwdz2	
//
// Purpose:     PAR24513 extend the current existing getDisplayStringForAttribute method to return an object's oid.		 
// ----------   ----------  --------------------------------------------------
vars
	runDate	: Date;

begin
	
	runDate := app.actualTimeServer().Date;	// 28/4/16 cnwmp6 TFS 488 - Multi timezone support

	// Arrival
	if _attrName = ETRow_MovementDateFrom then
		if _getCalculatedDate then
			return self.setDateFromTemplate(self.movementDateFromType, self.movementDateFromFactor, runDate).shortFormatJMT();
		else
			return self.getTemplateDateStr(self.movementDateFromType, self.movementDateFromFactor);
		endif;
	endif;
	
	if _attrName = ETRow_MovementDateTo then
		if _getCalculatedDate then
			return self.setDateFromTemplate(self.movementDateToType, self.movementDateToFactor, runDate).shortFormatJMT();
		else
			return self.getTemplateDateStr(self.movementDateToType, self.movementDateToFactor);
		endif;
	endif;
	
	if _attrName = ETRow_MovementTimeFrom then
		return self.movementTimeFrom.shortFormatJMT();
	endif;
	
	if _attrName = ETRow_MovementTimeTo then
		return self.movementTimeTo.shortFormatJMT();
	endif;
// can use ETRow_ArrivalsDateFrom in some entdefs 	
	if _attrName = ETRow_ArrivalsDateFrom then
		if _getCalculatedDate then
			return self.setDateFromTemplate(self.movementDateFromType, self.movementDateFromFactor, runDate).shortFormatJMT();
		else
			return self.getTemplateDateStr(self.movementDateFromType, self.movementDateFromFactor);
		endif;
	endif;
	
	if _attrName = ETRow_ArrivalsDateTo then
		if _getCalculatedDate then
			return self.setDateFromTemplate(self.movementDateToType, self.movementDateToFactor, runDate).shortFormatJMT();
		else
			return self.getTemplateDateStr(self.movementDateToType, self.movementDateToFactor);
		endif;
	endif;
	
	//27 Feb 2012	NDL	Par 29121
	if _attrName = ETRow_MovementIncludeInPort then
		return self.movementIncludeInPort.cnEcGetTableCheckBoxValue();
	endif;
	
	
	return inheritMethod(_attrName, _getCalculatedDate, _oid);

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_getCalculatedDate" type="Boolean"/>
        <Parameter name="_oid" type="String" usage="output"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="includesObject" id="1d219af5-d5f8-4164-b2d9-69e10f063d65">
        <updating/>
        <source>includesObject(_movement: HMS_VoyageMovement; _passport: CM_Passport; _breakOut: Boolean output): Boolean updating, protected;
//----------------------------------------------------------------
//	Created:	10 August 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	querySelf 	: CMQF_HMSMovements;
	
begin
	querySelf := self;
	querySelf.numSearched := querySelf.numSearched + 1;
	
	if _movement.myHMSVoyageData &lt;&gt; null
	and (not _movement.myHMSVoyageData.excludeReport) 
	and	( not _movement.myHMSVoyageData.isVoyageCancelled) // cnwrd1 par 23993 25.5.2010 ++
		then
		querySelf.numFound := querySelf.numFound + 1;
		return true;
	endif;
	
	return false;

end;</source>
        <access>protected</access>
        <Parameter name="_movement" type="HMS_VoyageMovement"/>
        <Parameter name="_passport" type="CM_Passport"/>
        <Parameter name="_breakOut" type="Boolean" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setDatesForTemplateRun" id="516acb32-d03c-4c67-82b1-c45b7ee71568">
        <updating/>
        <source>setDatesForTemplateRun(_runDate: Date) updating;
// ---------------------------------------------------------------------------
// Created:     29 April 2005	cnwhjg1
//
// Purpose:     
// ----------   ----------  --------------------------------------------------
vars

begin
	inheritMethod(_runDate);
	self.movementDateFrom := self.setDateFromTemplate(self.movementDateFromType, self.movementDateFromFactor, _runDate);
	self.movementDateTo := self.setDateFromTemplate(self.movementDateToType, self.movementDateToFactor, _runDate);
end;</source>
        <Parameter name="_runDate" type="Date"/>
    </JadeMethod>
    <JadeMethod name="setFromTemplate" id="db6acf80-490a-49da-a6b6-d4cda1fb99ba">
        <updating/>
        <source>setFromTemplate(_obj: CMQF_FilterReports; _runDate: Date; _allEventData: CM_EventDataByTypeDict) updating;
// ---------------------------------------------------------------------------
// Created:     29 April 2005	cnwhjg1
//
// Purpose:     
// ----------   ----------  --------------------------------------------------
vars

begin
	inheritMethod(_obj, _runDate, _allEventData);
	self.movementDateFrom := self.setDateFromTemplate(self.movementDateFromType, self.movementDateFromFactor, _runDate);
	self.movementDateTo := self.setDateFromTemplate(self.movementDateToType, self.movementDateToFactor, _runDate);

end;</source>
        <Parameter name="_obj" type="CMQF_FilterReports"/>
        <Parameter name="_runDate" type="Date"/>
        <Parameter name="_allEventData" type="CM_EventDataByTypeDict"/>
    </JadeMethod>
</Class>
