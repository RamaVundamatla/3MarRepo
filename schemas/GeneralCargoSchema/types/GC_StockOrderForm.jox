    <JadeMethod name="setControlsForAddEdit" id="6d61fbbf-b482-4cc2-a73e-0f5d1237376f">
        <updating/>
        <source>setControlsForAddEdit() updating;
// ---------------------------------------------------------------------------
// Created:     
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 19 Apr 2016	cnwns1	TFS 488 - Multi Timezone Support
// ---------------------------------------------------------------------------
vars
	localDT			: TimeStamp;
begin
	
	self.doChangeMasterEntryView();
//	self.cmbLineType.text := StockOrderLine_Product_Descr;
//	self.doChangeDetailEntryView();


	self.btnAddShow.enabled:= true;
	self.btnRemoveDtl.enabled := true;
	
	if self.mode = self.Mode_New then
		localDT := self.systemToLocalTime( app.actualTimeServer);
//		self.txtDeadDate.setDate(defaultDT.date);
//		self.txtDeadTime.setTime(defaultDT.time);
		self.tblMasterEnt.setValueByName(ETRow_DeadlineDate, localDT.date);
		self.tblMasterEnt.setValueByName(ETRow_DeadlineTime, localDT.time);
		self.cmbConsignee.setObject(null);  // clear any previous values set 
	else
		//date and time row values are null from the changing of the view above
		localDT := self.systemToLocalTime(self.myCurrentMasterObject.CM_StockOrderHeaderGeneric.deadlineDT);
		self.tblMasterEnt.setValueByName(ETRow_DeadlineDate, localDT.date());
		self.tblMasterEnt.setValueByName(ETRow_DeadlineTime, localDT.time());
	endif;
	
end;</source>
    </JadeMethod>
