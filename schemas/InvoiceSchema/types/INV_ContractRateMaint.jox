    <JadeMethod name="btnSave_click" id="13bd3667-a5b7-4964-8d2a-a05ab5c1dda7">
        <controlMethod name="CMUI_Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnSave_click(btn: Button input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 Feb 2023 navtnr20	TFS CR 55646 Task 55665: UI - Contract Details

*/

vars

begin
	//if not self.updateMode then
	if self.mode = self.MODE_CREATE then //31/01/2023	navkc1 Bug 61578
		self.createContractDetail();
	elseif self.mode = self.MODE_UPDATE then //31/01/2023	navkc1 Bug 61578
		self.updateContractDtl();
	elseif self.mode = self.MODE_COPY then //31/01/2023	navkc1 Bug 61578
		self.createCopiedContractDetail();
	endif;
	if self.myContractDetails &lt;&gt; null  then
		self.btnAdd.enabled := true;
		self.btnRemoveRtEnt.enabled := true;
		self.btnUpdate.enabled := true;
		self.btnNew.enabled := true;
	endif;
epilog

end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
