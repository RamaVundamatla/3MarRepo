	terminal 	: CM_Terminal;
	response 	: WS_JobSheetResponse;
	voyage 		: CM_Voyage;
	job			: CM_Job;
	jobSheet	: CM_JobSheet;
	pxyJobSheet : WS_JobSheet;
	completedOK	: Boolean;
	wle 		: CM_WorkListEntry;
	ti 			: CM_TrackedItem;
	
begin

	// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);

	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	
	// Initialise the passport for the new transaction
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	
	create response transient;
	
	terminal := app.myPassport.myTerminal;
	voyage:=terminal.lookupVoyage(_request.voyageCode,null,false);
	
	if voyage &lt;&gt; null then
		if _request.jobType = JOB_TYPE_DISCHARGE
		or _request.jobType = JOB_TYPE_LOAD
		or _request.jobType = JOB_TYPE_SOB then
			
			foreach jobSheet in voyage.allJobSheets discreteLock do			//06.03.2025 navma1 #MTN-34179
				foreach job in jobSheet.allJobsByOrder discreteLock do		//06.03.2025 navma1 #MTN-34179
					// add jobsheet if it has at least one incomplete job of the correct type
					if job.jobType = _request.jobType and not job.isJobComplete then
						create pxyJobSheet transient;
						pxyJobSheet.setProxyFromObject(jobSheet);
						response.allJobSheets.add(pxyJobSheet);
						break;
						
					elseif _request.jobType = JOB_TYPE_SOB and job.jobType = JOB_TYPE_DISCHARGE and not job.isJobComplete then
						// Hold SOB jobs look like discharge jobs, but the cargo is marked as SOB
						
						wle := job.workListEntries.first;
						if wle &lt;&gt; null then
							ti := wle.myTrackedItem;
							if ti &lt;&gt; null and ti.isSOB then
								create pxyJobSheet transient;
								pxyJobSheet.setProxyFromObject(jobSheet);
								response.allJobSheets.add(pxyJobSheet);
								break;
							endif;
						endif;
						
					endif;
				endforeach;
			endforeach;
			
		endif;
	endif;

	completedOK := true;
	return response;	
	
epilog

	if not completedOK then
		cnSetTransactionError(true);
		delete response;				// prevent transient leaks
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;
	
end;</source>
        <Parameter name="_request" type="WS_JobSheetsRequest"/>
        <ReturnType type="WS_JobSheetResponse"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="getJobsForJobSheet" id="8ca2db90-36a8-44ed-9d19-2c09e18e9237">
        <source>getJobsForJobSheet(_request : WS_JobsRequest) : WS_JobResponse webService;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
16 November 2021	jlizm1	Initial creation TFS 52028 Work hold jobs in handheld app
30 November 2021	jlizm1	TFS 52456 Job Lander SOB job cargo not found

*/

vars
	response : WS_JobResponse;
	job	: CM_Job;
	jobSheet	: CM_JobSheet;
	pxyJob : WS_Job;
	completedOK	: Boolean;
	wle : CM_WorkListEntry;
	ti : CM_TrackedItem;
	
begin

	// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);

	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	
	// Initialise the passport for the new transaction
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	
	create response transient;

	jobSheet := app.myPassport.getObjectOfTypeFromOid(_request.jobSheetOid, CM_JobSheet).CM_JobSheet;
	
	if jobSheet &lt;&gt; null then
		if _request.jobType = JOB_TYPE_DISCHARGE
		or _request.jobType = JOB_TYPE_LOAD then
			foreach job in jobSheet.allJobsByOrder do
				if job.jobType = _request.jobType and not job.isJobComplete then
					create pxyJob transient;
					pxyJob.setProxyFromObject(job);
					response.allJobs.add(pxyJob);
				endif;
			endforeach;	
			
		elseif _request.jobType = JOB_TYPE_SOB then
			foreach job in jobSheet.allJobsByOrder do
				// First, check for regular SOB jobs
				if job.jobType = _request.jobType and not job.isJobComplete then
					create pxyJob transient;
					pxyJob.setProxyFromObject(job);
					response.allJobs.add(pxyJob);
				
				// Hold SOB jobs look like discharge jobs, but the cargo is marked as SOB
				elseif job.jobType = JOB_TYPE_DISCHARGE and not job.isJobComplete then
					wle := job.workListEntries.first;
					if wle &lt;&gt; null then
						ti := wle.myTrackedItem;
						if ti &lt;&gt; null and ti.isSOB then
							create pxyJob transient;
							pxyJob.setProxyFromObject(job);
							response.allJobs.add(pxyJob);
						endif;
					endif;
				
				endif;
			endforeach;	
		endif;
	endif;

	completedOK := true;
	return response;	
	
epilog

	if not completedOK then
		cnSetTransactionError(true);
		delete response;				// prevent transient leaks
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;
	
end;</source>
        <Parameter name="_request" type="WS_JobsRequest"/>
        <ReturnType type="WS_JobResponse"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="getJobsForVoyage" id="7b67c637-1d67-4570-815b-918ef2423ff9">
        <usesRPC>default</usesRPC>
        <source>getJobsForVoyage(voyageId : String) : WS_JobResponse webService;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
25 September 2008	cnwkao1	Initial creation

*/

vars
	obj			: Object;
	voyage		: CM_Voyage;
	job			: CM_Job;
	pxyJob		: WS_Job;
	response	: WS_JobResponse;
	completedOK	: Boolean;
	failedDAC	: CM_DataAccessController;
	
begin
	// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);

	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	
	// Initialise the passport for the new transaction
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	
	create response transient;
	//epr TFS 5535 4/8/17 
	voyage := app.myPassport.getObjectOfTypeFromOid(voyageId,CM_Voyage).CM_Voyage;
	
	if voyage = null then
		voyage := app.myPassport.myTerminal.allVoyagesByCode.getAtKeyGeq(voyageId, null);
		if voyage &lt;&gt; null and voyage.code &lt;&gt; voyageId then
			voyage := null;
		endif;
		if voyage &lt;&gt; null and not voyage.canUserAccessSelf(app.getMyUser(), failedDAC, app.myPassport) then
			voyage := null;
		endif;
	endif;	
	
	if voyage &lt;&gt; null then
		foreach job in voyage.allVoyageJobs discreteLock do
			create pxyJob transient;
			pxyJob.setProxyFromObject(job);
			response.allJobs.add(pxyJob);
		endforeach;
	endif;
	
	completedOK := true;
	return response;	
	
	
epilog
	if not completedOK then
		cnSetTransactionError(true);
		delete response;				// prevent transient leaks
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;
	
end;</source>
        <wsdlName>getJobsForVoyage</wsdlName>
        <Parameter name="voyageId" type="String"/>
        <ReturnType type="WS_JobResponse"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="getKPICargoCounts" id="9beadca5-958a-462c-95e4-4fc93caef3b1">
        <source>getKPICargoCounts(_request : WS_KPICargoRequest input) : WS_KPICounterResponse webService;
/*

Date		Who		Reason
15 July 2015	cnwer1	Initial creation PAR
// 19 May 2016	cnwns1	TFS 488 - Multi Timezone Support
*/

vars

	completedOK : Boolean;
	response : WS_KPICounterResponse;
	terminal : CM_Terminal;
	startDate, 
	endDate : Date;
		now : Date;
begin
	// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);
	
	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	
	// Initialise the passport for the new transaction
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);

	// Create the response
	create response transient;
	
	// Check security access to this message
	app.checkCurrentUserHasAccess(PmShipCargoCounterView);
	if app.myPassport.hasErrors then
		completedOK := true;
		return response;
	endif;
	
	startDate:=_request.startDate.asDateFromWebInterface();
	endDate:=_request.endDate.asDateFromWebInterface();
	terminal := app.myPassport.myTerminal;
	
	now:= app.actualTimeServer.date;// 19 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	if endDate &gt; now then
		endDate:=now;
	endif;
	if not endDate.isValid then
		app.raiseCMException(Invalid_end_date, null, null);
		completedOK := true;
		return response;
	endif;
	if not startDate.isValid then
		app.raiseCMException(Invalid_start_date, null, null);
		completedOK := true;
		return response;
	endif;

	if startDate &gt; endDate then
		app.raiseCMException(EndDate_Before_StartDate, null, null);
		completedOK :=true;
		return response;
	endif;
	
	response.getKPICounterCargoTypes(terminal,_request.startDate,_request.endDate);
	
	// Got to here, everything is ok
	completedOK := true;
	return response;
epilog
	
	if not completedOK then
		cnSetTransactionError(true);
		delete response;
	endif;
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;

end;</source>
        <Parameter name="_request" type="WS_KPICargoRequest" usage="input"/>
        <ReturnType type="WS_KPICounterResponse"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="getLanderVoyages" id="6408fc5d-0f11-4448-a885-b6ab7ed0f088">
        <source>getLanderVoyages() : WS_VoyagesResponse webService;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 28/06/2019	jlgdap1		Initial creation TFS 44861 JMT Align the Lander apps with the old mobile app voyage code
// 23/08/2019	jlgdap1		TFS 46268 PEN Showing Voyage Without Arrival Date in Cargo / Job Lander
// 08/11/2019	cnwma1		Bug 47337: JMT - Can't Prenote Cargo for Future Voyages in Web Portal

//
vars
	response		: WS_VoyagesResponse;
	completedOK		: Boolean;
	now				: TimeStamp;
	proxyVoyage		: WS_Voyage;
	selectedVoyages	: CM_VoyageSet;
	voy				: CM_Voyage;
	thePassport		: CM_Passport;
	
begin
	// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);

	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	
	// Initialise the passport for the new transaction
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	
	// Create the response
	create response transient;
	create selectedVoyages transient;
	
	thePassport := app.myPassport;
	now 		:= app.actualTimeServer;	
	
	thePassport.myTerminal.getAllCurrentVoyages(selectedVoyages,true,true,false);
	
	foreach voy in selectedVoyages discreteLock do
		if voy.status = Voyage_Status_Departed then
			continue;
		endif;
		
		if not voy.arrivedDT.isValid then			// TFS 46268
			continue;								// TFS 46268
		endif;										// TFS 46268
		
		if voy.arrivedDT &gt;  now then                //08.11.2019 cnwma1 #47337
			continue;
		endif;
		
 		create proxyVoyage transient;
		proxyVoyage.setProxyFromObject(voy);
		response.allVoyages.add(proxyVoyage);
	endforeach;
	
	// Got to here, everything is ok
	completedOK := true;
	return response;
	
epilog
	// Tidy up local transients
	delete selectedVoyages;
	
	if not completedOK then
		cnSetTransactionError(true);
		delete response;				// prevent transient leaks
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;
end;</source>
        <ReturnType type="WS_VoyagesResponse"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="getLanesForCrane" id="b84a6231-b9b3-483a-872a-fc92f95f63d9">
        <source>getLanesForCrane(request : WS_CraneLaneRequest) : WS_CraneLaneResponse webService;
/*
Purpose:			
Date		Who		Reason
08 July 2015	cnwab1	Initial creation
*/

vars
	obj			: Object;
	terminal		: CM_Terminal;
	response	: WS_CraneLaneResponse;
	completedOK	: Boolean;
	craneCode : String;
	crane : CM_Crane;
	lc : CM_LocationsController;
	wscl: WS_CraneLane;
	idx : Integer;
begin
	// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);

	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	
	// Initialise the passport for the new transaction
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	
	create response transient;
	
	craneCode := request.craneCode;
	terminal := app.myPassport.myTerminal;
	
	crane := terminal.machines[craneCode].CM_Crane;
	
	if crane &lt;&gt; null then
		if request.laneType = WS_CraneLaneRequest.LaneTypeDischarge then // DISCHARGE ONLY
			foreach lc in crane.transferArea.dischargeLanes do
				idx := idx + 1;
				create wscl;
				wscl.code := lc.getFullId();
				wscl.index := idx;
				response.allCraneLanes.add(wscl);
			endforeach;
		elseif request.laneType = WS_CraneLaneRequest.LaneTypeLoad then // LOAD ONLY
			foreach lc in crane.transferArea.loadLanes do
				idx := idx + 1;
				create wscl;
				wscl.code := lc.getFullId();
				wscl.index := idx;
				response.allCraneLanes.add(wscl);
			endforeach;
		else // ALL LANES
			foreach lc in crane.transferArea.lanes do
				idx := idx + 1;
				create wscl;
				wscl.code := lc.getFullId();
				wscl.index := idx;
				response.allCraneLanes.add(wscl);
			endforeach;
		endif;
	endif;
	
	completedOK := true;
	return response;	
	
	
epilog
	if not completedOK then
		cnSetTransactionError(true);
		delete response;				// prevent transient leaks
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;
end;</source>
        <Parameter name="request" type="WS_CraneLaneRequest"/>
        <ReturnType type="WS_CraneLaneResponse"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="getLanesForGate" id="b5ad836a-9763-4375-b5c0-c709162df8d4">
        <source>getLanesForGate(request : WS_GateLaneRequest) : WS_GateLaneResponse webService;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25 Feb 2015 cnwma1   TFS 1488 JMT Mobile Apps - RecRel -  Gate Checker
14 Feb 2020 cnwma1	 Bug 48557: QTS - Gate Checker Issue
*/

vars
	obj			  : Object;
	terminal	  : CM_Terminal;
	response	  : WS_GateLaneResponse;
	completedOK	  : Boolean;
	gateCode 	  : String;
	wsgl		  : WS_GateLane;
	idx 		  : Integer;
	gateAreaUsage : CM_GateAreaUsage;
	gateArea 	  : CM_GateArea;
	gate		  : CM_Gate;
	laneColl 	  : CM_ObjectArray;
	glc 		  : CM_GateAreaLaneController;

begin
	// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);

	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	
	// Initialise the passport for the new transaction
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	
	create response transient;
	
	gateCode := request.gateCode;
	terminal := app.myPassport.myTerminal;
	gate     := terminal.getGate(gateCode);
	
	create laneColl transient;
	
	//In Lanes
	foreach  gateAreaUsage in gate.allGateAreas_IN   do
		gateArea := gateAreaUsage.myGateArea;
		
		if gateArea &lt;&gt; null then
			if not gateArea.CM_GateArea.isPGate then
				continue;
			endif;
			laneColl.clear();
			gateArea.CM_GateArea.getAllLaneControllers (laneColl);
			foreach obj in laneColl discreteLock do
				glc	:= obj.CM_GateAreaLaneController;
				if glc.isUnavailable then
					continue;
				endif;
				if glc.laneDirection &lt;&gt; CM_GateAreaLaneController.Is_In_Lane then
					continue;
				endif;
				idx := idx + 1;
				create wsgl;
				wsgl.setProxyFromObject(glc);		
				response.allGateLanes.add(wsgl);
			endforeach;
		endif;
	endforeach;
	

	// Out Lanes
	foreach  gateAreaUsage in gate.allGateAreas_OUT  do
			
		gateArea := gateAreaUsage.myGateArea;
		gateArea.CM_GateArea.getAllLaneControllers (laneColl);
		
		if gateArea &lt;&gt; null then
			if not gateArea.CM_GateArea.isPGate then
				continue;
			endif;
			laneColl.clear();
			gateArea.CM_GateArea.getAllLaneControllers (laneColl);
			foreach obj in laneColl discreteLock do
				glc	:= obj.CM_GateAreaLaneController;
				if glc.isUnavailable then
					continue;
				endif;
				
				if glc.laneDirection &lt;&gt; CM_GateAreaLaneController.Is_Out_Lane then
					continue;
				endif;
				
				if glc.hasVehicles then   //14.02.2020 cnwma1 #48557 
					continue;
				endif;
				
				idx := idx + 1;
				create wsgl;
				wsgl.setProxyFromObject(glc);		
				response.allGateLanes.add(wsgl);
			endforeach;
		endif;
	endforeach;

	
	completedOK := true;
	return response;	

epilog
	if not completedOK then
		cnSetTransactionError(true);
		delete response;				// prevent transient leaks
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;
end;</source>
        <Parameter name="request" type="WS_GateLaneRequest"/>
        <ReturnType type="WS_GateLaneResponse"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="getLanesForInterchangeArea" id="e68afe68-72b7-4587-a0e8-a72dd640bf7a">
        <source>getLanesForInterchangeArea(request : WS_CraneLaneRequest) : WS_LocationsResponse webService;
/*

Date		Who		Reason
08 November 2016	cnwer1	Initial creation TFS 2732

*/

vars
	response : WS_LocationsResponse;
	completedOK : Boolean;
	ta 	: CM_TerminalArea;
	craneTa : CM_CraneTransferArea;
	wpointTa : CM_WorkPointInterchangeArea;
	wpLanes : CM_LCArray;
	lc : CM_LocationsController;
	wsLC : WS_LocationsController;
begin
	// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);

	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	
	// Initialise the passport for the new transaction
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	
	create response transient;
	//epr TFS 5535 4/8/17
	ta := app.myPassport.getObjectOfTypeFromOid(request.taOid,CM_TerminalArea).CM_TerminalArea;
	if ta = null then
		completedOK :=true;
		return response;
	endif;
	
	if ta.isKindOf(CM_CraneTransferArea) then
		craneTa := ta.CM_CraneTransferArea;
		if request.laneType = WS_CraneLaneRequest.LaneTypeDischarge then // DISCHARGE ONLY
			foreach lc in craneTa.dischargeLanes do
				create wsLC transient;
				wsLC.setProxyFromObject(lc);
				response.allLocationsControllers.add(wsLC);
			endforeach;
		elseif request.laneType = WS_CraneLaneRequest.LaneTypeLoad then
			foreach lc in craneTa.loadLanes do
				create wsLC transient;
				wsLC.setProxyFromObject(lc);
				response.allLocationsControllers.add(wsLC);
			endforeach;
		endif;
	elseif ta.isKindOf(CM_WorkPointInterchangeArea) then
			wpointTa := ta.CM_WorkPointInterchangeArea;
			create wpLanes transient;
			wpointTa.getLanes(wpLanes);
			foreach lc in wpLanes do
				create wsLC transient;
				wsLC.setProxyFromObject(lc);
				response.allLocationsControllers.add(wsLC);
			endforeach;
			
	elseif ta.isKindOf(CM_InterchangeArea) then
		lc := ta.CM_InterchangeArea.getDefaultLane;
		if lc &lt;&gt; null then
			create wsLC transient;
			wsLC.setProxyFromObject(lc);
			response.allLocationsControllers.add(wsLC);
		endif;
	endif;
			
			
	completedOK := true;
	return response;	
epilog
	if not completedOK then
		cnSetTransactionError(true);
		delete response;				// prevent transient leaks
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;
end;</source>
        <Parameter name="request" type="WS_CraneLaneRequest"/>
        <ReturnType type="WS_LocationsResponse"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="getLanesForRoroArea" id="21547208-3959-4f73-a546-f97515fcfd1d">
        <source>getLanesForRoroArea(request : WS_GetLanesForRoroRequest): WS_GetLanesForRoroResponse webService;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
28 July 2017	jlgam15	TFS#5541 Return lanes, total scanned, left/right label for the given roro Area
31 Aug 2017		jlghl1	TFS 6771
*/

vars	
	terminalArea : CM_TerminalArea;
	roroArea : CM_RoRoLaneArea;
	roroLane : CM_RoRoController;
	proxyRoro : WS_RoroLaneController;
	response : WS_GetLanesForRoroResponse;
	completedOK : Boolean;
	totalScanned : Integer;
begin
	// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);

	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	
	// Initialise the passport for the new transaction
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	
	create response transient;
	terminalArea := app.myPassport.myTerminal.allTerminalAreasByTypeId[TA_TYPE_RORO_LANE_AREA, request.roroAreaId];
		
	if terminalArea &lt;&gt; null then
		roroArea := terminalArea.CM_RoRoLaneArea;
		response.leftLabel := roroArea.leftLabel;
		response.rightLabel := roroArea.rightLabel;
			
		foreach roroLane in roroArea.allLanesByLaneNumber do
			totalScanned := totalScanned + roroLane.getCarCountForVoyage(request.voyageCode);
			
			create proxyRoro transient;
			proxyRoro.setProxyFromObject(roroLane);
			response.roroLaneControllerArray.add(proxyRoro);
		endforeach;
	
		response.totalScannedForArea := totalScanned;
	endif;
		
	completedOK := true;
	return response;
	
epilog
	if not completedOK then
		cnSetTransactionError(true);
		delete response;				// prevent transient leaks
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;
end;</source>
